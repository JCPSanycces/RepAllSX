###########################################################
Subprog C_STOFCY(VALEUR)
Variable Char     VALEUR
Call VERFCY(VALEUR) From CONTX3
End
###########################################################
Subprog D_IPTDAT(VALEUR)
Variable Date     VALEUR
VALEUR = date$
End
###########################################################
Subprog C_IPTDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > date$
  mkstat = 2
Endif
End
###########################################################
Subprog B2_STOFCY(VALEUR)
Variable Char    VALEUR()
GCONSULT  = 2
Call OBJET("TRS",[M]TRSNUM,"") From GOBJET
GCONSULT = 0
End
############################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
GBOUT2 = mess(365,198,1) : # <MG> 27/04/00    
End

