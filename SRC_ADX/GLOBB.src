$DEF_CAL_GLOBALES
  Local Char L_NOMGLO
  If dim(G_GLOB) > 0 and G_GLOB <> "" : Return : Endif
  For I=1 To G_CALTRTNBR
   Case I
    When 1  : G_CALTRTGLO(00) = "G_GLOB"    : Global Char G_GLOB    : G_CALTRTNAM(00) = "GLOBI"
    When 2  : G_CALTRTGLO(01) = "G_GLOB0"   : Global Char G_GLOB0   : G_CALTRTNAM(01) = "GLOBI0"
    When 3  : G_CALTRTGLO(02) = "G_GLOB1"   : Global Char G_GLOB1   : G_CALTRTNAM(02) = "GLOBI1"
    When 4  : G_CALTRTGLO(03) = "G_GLOB2"   : Global Char G_GLOB2   : G_CALTRTNAM(03) = "GLOBI2"
    When 5  : G_CALTRTGLO(04) = "G_GLOB3"   : Global Char G_GLOB3   : G_CALTRTNAM(04) = "GLOBI3"
    When 6  : G_CALTRTGLO(05) = "G_GLOB4"   : Global Char G_GLOB4   : G_CALTRTNAM(05) = "GLOBI4"
    When 7  : G_CALTRTGLO(06) = "G_GLOB5"   : Global Char G_GLOB5   : G_CALTRTNAM(06) = "GLOBI5"
    When 8  : G_CALTRTGLO(07) = "G_GLOB6"   : Global Char G_GLOB6   : G_CALTRTNAM(07) = "GLOBI6"
    When 9  : G_CALTRTGLO(08) = "G_GLOB7"   : Global Char G_GLOB7   : G_CALTRTNAM(08) = "GLOBI7"
    When 10 : G_CALTRTGLO(09) = "G_GLOB8"   : Global Char G_GLOB8   : G_CALTRTNAM(09) = "GLOBI8"
    When 11 : G_CALTRTGLO(10) = "G_GLOB9"   : Global Char G_GLOB9   : G_CALTRTNAM(10) = "GLOBI9"
    When 12 : G_CALTRTGLO(11) = "G_GLOB4FR" : Global Char G_GLOB4FR : G_CALTRTNAM(11) = "GLOBI4FR"
    When 13 : G_CALTRTGLO(12) = "G_GLOB4RU" : Global Char G_GLOB4RU : G_CALTRTNAM(12) = "GLOBI4RU"  : # FQ59441
    When 14 : G_CALTRTGLO(13) = "G_GLOB5RU" : Global Char G_GLOB5RU : G_CALTRTNAM(13) = "GLOBI5RU"  : # FQ59441
    When 15 : G_CALTRTGLO(14) = "G_GLOB4PL" : Global Char G_GLOB4PL : G_CALTRTNAM(14) = "GLOBI4PL"  : # FQ67577
    When 16 : G_CALTRTGLO(15) = "G_GLOB5PL" : Global Char G_GLOB5PL : G_CALTRTNAM(15) = "GLOBI5PL"  : # FQ67577
   Endcase
   L_NOMGLO=G_CALTRTGLO(I-1) : Assign L_NOMGLO With G_CALTRTNAM(I-1)
  Next I
Return
$CALCUL_CRT_GLOBALES
  Global Integer G_DEJA     : G_DEJA = 0
  Global Integer G_TIMLIM
  Global Integer G_ETRPNT
  Global Integer G_CLCSTD
  Global Integer G_SKPSTD
  Global Integer G_ETP_GLOBI
  Global Integer G_ETP_GLOBI0
  Global Integer G_ETP_GLOBI1
  Global Integer G_ETP_GLOBI2
  Global Integer G_ETP_GLOBI3
  Global Integer G_ETP_GLOBI4
  Global Integer G_ETP_GLOBI4FR
  Global Integer G_ETP_GLOBI5
  Global Integer G_ETP_GLOBI6
  Global Integer G_ETP_GLOBI7
  Global Integer G_ETP_GLOBI8
  G_ETP_GLOBI    = find('GLOBI' ,  GENTSTD(1..GNBENTREE))
  G_ETP_GLOBI0   = find('GLOBI0',  GENTSTD(1..GNBENTREE))
  G_ETP_GLOBI1   = find('GLOBI1',  GENTSTD(1..GNBENTREE))
  G_ETP_GLOBI2   = find('GLOBI2',  GENTSTD(1..GNBENTREE))
  G_ETP_GLOBI3   = find('GLOBI3',  GENTSTD(1..GNBENTREE))
  G_ETP_GLOBI4   = find('GLOBI4',  GENTSTD(1..GNBENTREE))
  G_ETP_GLOBI4FR = find('GLOBI4FR',GENTSTD(1..GNBENTREE))
  G_ETP_GLOBI5   = find('GLOBI5',  GENTSTD(1..GNBENTREE))
  G_ETP_GLOBI6   = find('GLOBI6',  GENTSTD(1..GNBENTREE))
  G_ETP_GLOBI7   = find('GLOBI7',  GENTSTD(1..GNBENTREE))
  G_ETP_GLOBI8   = find('GLOBI8',  GENTSTD(1..GNBENTREE))
  If (  G_ETP_GLOBI  or G_ETP_GLOBI0 or G_ETP_GLOBI1 or G_ETP_GLOBI2 or G_ETP_GLOBI3 or G_ETP_GLOBI4 or G_ETP_GLOBI4FR or
&       G_ETP_GLOBI5 or G_ETP_GLOBI6 or G_ETP_GLOBI7 or G_ETP_GLOBI8 ) Then
    G_ETRPNT = 0
  Else
    G_ETRPNT = 1
  Endif
  Global Char    G_CLCVER   : G_CLCVER = "C00028"
  Global Integer G_CCNCLCSTD
  Global Integer G_PCPTOPN  : G_PCPTOPN = 0
  Global Integer G_PFISOPN  : G_PFISOPN = 0
  Global Integer G_PMINOPN  : G_PMINOPN = 0
  Global Integer G_PORIOPN  : G_PORIOPN = 0
  Global Integer G_PR76OPN  : G_PR76OPN = 0
  Global Integer G_PIASOPN  : G_PIASOPN = 0
  Global Integer G_PTECOPN  : G_PTECOPN = 0
  Global Integer G_PRETOPN  : G_PRETOPN = 0
  Global Integer G_PSUBOPN  : G_PSUBOPN = 0
  Global Integer G_PLI1OPN  : G_PLI1OPN = 0
  Global Integer G_PLI2OPN  : G_PLI2OPN = 0
  Global Integer G_PLI3OPN  : G_PLI3OPN = 0
  Global Integer G_PLI4OPN  : G_PLI4OPN = 0
  Global Integer G_PLI5OPN  : G_PLI5OPN = 0
  Global Integer G_PLI6OPN  : G_PLI6OPN = 0
  Global Integer G_PRPROPN  : G_PRPROPN = 0
  Global Integer G_BERRDER  : G_BERRDER = 0
  Global Integer G_BEFORE   : G_BEFORE  = 0  : # FQ104870
  If ( [M:DIV]TRTDEM = "CALBCO" or [M:DIV]TRTDEM = "CALSIM" ) Then
    Gosub DEBUG_DEF_VAR From GCALDEBUG
  Endif
Return
$CALCUL_DLT_GLOBALES
    If (dim(G_DEJA)    >0) Then : Kill G_DEJA     : Endif
    If (dim(G_TIMLIM)  >0) Then : Kill G_TIMLIM   : Endif  : # Temps limite d'un calcul (en minutes)
    If (dim(G_ETRPNT)  >0) Then : Kill G_ETRPNT   : Endif  : # Spécifique client
    If (dim(G_CLCSTD)  >0) Then : Kill G_CLCSTD   : Endif  : # Calcul Abel X3
    If (dim(G_CCNCLCSTD) >0) Then : Kill G_CCNCLCSTD  : Endif  : # Calcul Abel X3
    If (dim(G_SKPSTD)       >0) Then : Kill G_SKPSTD        : Endif
    If (dim(G_ETP_GLOBI)    >0) Then : Kill G_ETP_GLOBI     : Endif
    If (dim(G_ETP_GLOBI0)   >0) Then : Kill G_ETP_GLOBI0    : Endif
    If (dim(G_ETP_GLOBI1)   >0) Then : Kill G_ETP_GLOBI1    : Endif
    If (dim(G_ETP_GLOBI2)   >0) Then : Kill G_ETP_GLOBI2    : Endif
    If (dim(G_ETP_GLOBI3)   >0) Then : Kill G_ETP_GLOBI3    : Endif
    If (dim(G_ETP_GLOBI4)   >0) Then : Kill G_ETP_GLOBI4    : Endif
    If (dim(G_ETP_GLOBI4FR) >0) Then : Kill G_ETP_GLOBI4FR  : Endif
    If (dim(G_ETP_GLOBI5)   >0) Then : Kill G_ETP_GLOBI5    : Endif
    If (dim(G_ETP_GLOBI6)   >0) Then : Kill G_ETP_GLOBI6    : Endif
    If (dim(G_ETP_GLOBI7)   >0) Then : Kill G_ETP_GLOBI7    : Endif
    If (dim(G_ETP_GLOBI8)   >0) Then : Kill G_ETP_GLOBI8    : Endif
    If (dim(G_PCPTOPN) >0) Then : Kill G_PCPTOPN  : Endif
    If (dim(G_PFISOPN) >0) Then : Kill G_PFISOPN  : Endif
    If (dim(G_PMINOPN) >0) Then : Kill G_PMINOPN  : Endif
    If (dim(G_PORIOPN) >0) Then : Kill G_PORIOPN  : Endif
    If (dim(G_PR76OPN) >0) Then : Kill G_PR76OPN  : Endif
    If (dim(G_PIASOPN) >0) Then : Kill G_PIASOPN  : Endif
    If (dim(G_PTECOPN) >0) Then : Kill G_PTECOPN  : Endif
    If (dim(G_PRETOPN) >0) Then : Kill G_PRETOPN  : Endif
    If (dim(G_PSUBOPN) >0) Then : Kill G_PSUBOPN  : Endif
    If (dim(G_PLI1OPN) >0) Then : Kill G_PLI1OPN  : Endif
    If (dim(G_PLI2OPN) >0) Then : Kill G_PLI2OPN  : Endif
    If (dim(G_PLI3OPN) >0) Then : Kill G_PLI3OPN  : Endif
    If (dim(G_PLI4OPN) >0) Then : Kill G_PLI4OPN  : Endif
    If (dim(G_PLI5OPN) >0) Then : Kill G_PLI5OPN  : Endif
    If (dim(G_PLI6OPN) >0) Then : Kill G_PLI6OPN  : Endif
    If (dim(G_PRPROPN) >0) Then : Kill G_PRPROPN  : Endif
    If (dim(G_BERRDER) >0) Then : Kill G_BERRDER  : Endif
    If (dim(G_BEFORE)  >0) Then : Kill G_BEFORE   : Endif  : # FQ104870
    If (dim(G_GLOBB )  >0) Then : Kill G_GLOBB    : Endif
    If (dim(G_GLOBB0)  >0) Then : Kill G_GLOBB0   : Endif
    If (dim(G_GLOBB1)  >0) Then : Kill G_GLOBB1   : Endif
    If (dim(G_GLOBB2)  >0) Then : Kill G_GLOBB2   : Endif
    If (dim(G_GLOBB3)  >0) Then : Kill G_GLOBB3   : Endif
    If (dim(G_GLOBB4)  >0) Then : Kill G_GLOBB4   : Endif
    If (dim(G_GLOBB4FR)>0) Then : Kill G_GLOBB4FR : Endif
    If (dim(G_GLOBB4RU)>0) Then : Kill G_GLOBB4RU : Endif  : # FQ59441
    If (dim(G_GLOBB4PL)>0) Then : Kill G_GLOBB4PL : Endif  : # FQ67577
    If (dim(G_GLOBB5)  >0) Then : Kill G_GLOBB5   : Endif
    If (dim(G_GLOBB5RU)>0) Then : Kill G_GLOBB5RU : Endif  : # FQ59441
    If (dim(G_GLOBB5PL)>0) Then : Kill G_GLOBB5PL : Endif  : # FQ67577
    If (dim(G_GLOBB6)  >0) Then : Kill G_GLOBB6   : Endif
    If (dim(G_GLOBB7)  >0) Then : Kill G_GLOBB7   : Endif
    If (dim(G_GLOBB8)  >0) Then : Kill G_GLOBB8   : Endif
    If (dim(G_GLOBB9)  >0) Then : Kill G_GLOBB9   : Endif
    If ([M:DIV]TRTDEM = "CALBCO" or [M:DIV]TRTDEM = "CALSIM" ) Then
      Gosub DEBUG_KILL_VAR From GCALDEBUG
    Endif
Return
Subprog SIMULER_CALCUL_BIEN ( PSOC, PBCO, PPLN1, PPLN2, PTYP )
Value    Char    PSOC
Value    Char    PBCO
Value    Integer PPLN1
Value    Integer PPLN2
Value    Integer PTYP
Local Integer LNBF       : LNBF = 200   : # Nombre de champs dans le masque CALDEP
Local Integer PTABCNT(0..G300MAX-1)     : # Tableau des contextes à calculer
Local Integer N_C                       : # Indice du contexte
  If clalev([M:DIV])=0  : Local Mask CALDIV     [DIV]  :  Endif             : # Infos diverses
  If clalev([M:DIV2])=0  : Local Mask CALDIV2     [DIV2]  :  Endif             : # Infos diverses FQ77877
  [M:DIV]TRTDEM    = "CALSIM"
  Local Integer BGESCCN : BGESCCN = func AFNC.ACTIV("CCN") : [M:DIV]BACTCCN = BGESCCN
  Local Integer BGESKPL : BGESKPL = func AFNC.ACTIV("KPL") : [M:DIV]BACTKPL = BGESKPL
  Gosub CALCUL_CRT_GLOBALES
  [M:DIV]DATNUL    = [0/0/0]
  [M:DIV]MNTNUL    = 0
  [M:DIV]DATFMT    = "D:" + GFMDAT4
  [M:DIV]CSTLVLMAX = 11
  [M:DIV]CSTFIYMAX = func AFNC.ACTIV("NFIY") : # FQ59941
  [M:DIV]TRTLVL    = 0                    : # Niveau atteint dans le traitement
  [M:DIV]BDEBUG    = 2                    : # Debug
  [M:DIV]SIMPLN1   = PPLN1                : # Simulation plan 1
  [M:DIV]SIMPLN2   = PPLN2                : # Simulation plan 2
  [M:DIV]SIMEXEPER = PTYP                 : # Simulation Exercice/Périodique
  [M:DIV]BFS1OPN = 0
  [M:DIV]BFS2OPN = 0
  [M:DIV]ERROR   = 0
  [M:DIV]SOC    = PSOC                    : # Société courante
  [M:DIV]PROPLN = ""                      : # Plan de production à charger
  G_BERRDER     = 0                       : # Erreur derogatoire FQ82293
  [M:DIV]BONUS  = 0                       : # Bonus russe à charger FQ59941
  If ( !(GSERVEUR) and GTRACE = "" ) Then
    Call OUVRE_TRACE(mess(1,7774,1))  From LECFIC
  Endif
  Call ECR_TRACE(mess(61,7774,1)-G_CLCVER,0) From   GLOBB0   : # COMPTE RENDU TRAITEMENT DE CALCUL D'AMORT.
  Onerrgo KO From   GLOBB0
  Raz PTABCNT
  Call CAL_CNT_FROM_PLN (PSOC, [M:DIV]SIMPLN1, PTABCNT(0)) From   GLOBB0
  If not ([M:DIV]ERROR) Then
    If ([M:DIV]SIMPLN2 and [M:DIV]SIMPLN1 <> [M:DIV]SIMPLN2) Then
      Call CAL_CNT_FROM_PLN (PSOC, [M:DIV]SIMPLN2, PTABCNT(1)) From   GLOBB0
    Endif
  Endif
  If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif : # Société
  If clalev([F:WFAS])=0  : Local File FXDASSETS     [WFAS]  :  Endif        : # Biens comptables
  If clalev([F:WDEP])=0  : Local File DEPREC        [WDEP]  :  Endif        : # Plans d'amortissement
  If clalev([F:DEPC])=0  : Local File DEPREC        [DEPC]   :  Endif       : # DEPREC courant FQ79813
  If clalev([F:DEPS])=0  : Local File DEPREC        [DEPS]   :  Endif       : # DEPREC suivant FQ79813
  If clalev([F:SEPC])=0  : Local File DEPREC        [SEPC]   :  Endif       : # DEPREC courant FQ79813
  If clalev([F:SEPS])=0  : Local File DEPREC        [SEPS]   :  Endif       : # DEPREC suivant FQ79813
  If ([M:DIV]BACTCCN) Then
    If clalev([F:WRPR])=0  : Local File CCNRPR      [WRPR]  :  Endif        : # Provisions pour renouvellement
    If clalev([F:RPRC])=0  : Local File CCNRPR      [RPRC]  :  Endif        : # Provisions pour renouvellement FQ79813
    If clalev([F:RPRS])=0  : Local File CCNRPR      [RPRS]  :  Endif        : # Provisions pour renouvellement FQ79813
  Endif
  Gosub CALCUL_SOCIETE_PREPARE From   GLOBB
  Call CAL_LEC_BIEN(PBCO) From   GLOBB0
  Call  CALCUL_BIEN ( PTABCNT ) From   GLOBB
  Local Integer    PTABPLN(0..G301MAX-1)   : # FQ79856
  Call  EXPLOITER_CALCUL_BIEN ( PTABCNT, PTABPLN ) From   GLOBB   : # FQ79856
  Gosub CALCUL_SOCIETE_FERMETURE From   GLOBB
  If (clalev([F:WFAS]))  Then : Close Local File [WFAS]  : Endif : # Biens comptables
  If (clalev([F:WDEP]))  Then : Close Local File [WDEP]  : Endif : # Plans d'amortissement
  If (clalev([F:DEPC]))  Then : Close Local File [DEPC]  : Endif : # DEPREC courant FQ79813
  If (clalev([F:DEPS]))  Then : Close Local File [DEPS]  : Endif : # DEPREC suivant FQ79813
  If (clalev([F:SEPC]))  Then : Close Local File [SEPC]  : Endif : # DEPREC courant FQ79813
  If (clalev([F:SEPS]))  Then : Close Local File [SEPS]  : Endif : # DEPREC suivant FQ79813
  If ( !(GSERVEUR) ) Then
    If dim(GFXDNBERR) < 0
      [V]GLTRACE = 0
      Call FERME_TRACE From LECFIC
    Endif
  Endif
  If ( [M:DIV]NIVDET <> 0 ) Then
    Openo Using [FS1] : [M:DIV]BFS1OPN = 0
    Openo Using [FS2] : [M:DIV]BFS2OPN = 0
  Endif
  Local Integer LAFFTRACE1 : LAFFTRACE1=0
  If ( GDEBUG and dim(PBKPOINTLST)>0 ) Then
    Local Integer I_BKP : I_BKP = find("AFFTRACE1",PBKPOINTLST)
    If (I_BKP) Then
      If (PBKPOINTFLG(I_BKP) = G_OUI) Then : LAFFTRACE1 = 1 : Endif
    Endif
  Endif
  If ( LAFFTRACE1 ) Then : Call AFF_FICH ( "FS1" ) From   GLOBB0 : Endif
  Local Integer LAFFTRACE2 : LAFFTRACE2=0
  If ( GDEBUG and dim(PBKPOINTLST)>0 ) Then
    Local Integer I_BKP : I_BKP = find("AFFTRACE2",PBKPOINTLST)
    If (I_BKP) Then
      If (PBKPOINTFLG(I_BKP) = G_OUI) Then : LAFFTRACE2 = 1 : Endif
    Endif
  Endif
  If ( LAFFTRACE2 ) Then : Call AFF_FICH ( "FS2" ) From   GLOBB0 : Endif
  Gosub CALCUL_DLT_GLOBALES
  If (clalev([M:DIV]))  Then : Close Local Mask [DIV]  : Endif : # Infos diverses
  If (clalev([M:DIV2]))  Then : Close Local Mask [DIV2]  : Endif : # Infos diverses FQ77877
End
Subprog CALCULER_BIEN ( PSOC, PBCO, RERROR )
Value    Char    PSOC
Value    Char    PBCO
Variable Integer RERROR
Local Integer LNBF       : LNBF = 200   : # Nombre de champs écran CALDEP (Dimension de [M:DIV]TDFN)
Local Integer PTABCNT(0..G300MAX-1)       : # Tableau des contextes à calculer
Local Integer N_C                       : # Indice du contexte
Local Integer RTRN
  RERROR = -1
  If clalev([M:DIV])=0  : Local Mask CALDIV     [DIV]  :  Endif             : # Infos diverses
  If clalev([M:DIV2])=0  : Local Mask CALDIV2     [DIV2]  :  Endif             : # Infos diverses FQ77877
  [M:DIV]TRTDEM    = "CALBCO"
  Local Integer BGESCCN : BGESCCN = func AFNC.ACTIV("CCN") : [M:DIV]BACTCCN = BGESCCN
  Local Integer BGESKPL : BGESKPL = func AFNC.ACTIV("KPL") : [M:DIV]BACTKPL = BGESKPL
  Gosub CALCUL_CRT_GLOBALES
  [M:DIV]DATNUL    = [0/0/0]
  [M:DIV]MNTNUL    = 0
  [M:DIV]DATFMT    = "D:" + GFMDAT4
  [M:DIV]CSTLVLMAX = 11
  [M:DIV]CSTFIYMAX = func AFNC.ACTIV("NFIY") : # FQ59941
  [M:DIV]TRTLVL    = 0                    : # Niveau atteint dans le traitement
  [M:DIV]BDEBUG    = 2                    : # Debug
  [M:DIV]ERROR   = 0
  [M:DIV]BFS1OPN = 0
  [M:DIV]BFS2OPN = 0
  [M:DIV]SOC     = PSOC                    : # Société courante
  [M:DIV]PROPLN  = ""                      : # Plan de production à charger
  G_BERRDER      = 0                       : # Erreur derogatoire FQ82293
  [M:DIV]BONUS  = 0                        : # Bonus russe à charger FQ59941
  If ( !(GSERVEUR) and GTRACE = "" ) Then
    Call OUVRE_TRACE(mess(1,7774,1))  From LECFIC
  Endif
  Call ECR_TRACE(mess(61,7774,1)-G_CLCVER,0) From   GLOBB0   : # COMPTE RENDU TRAITEMENT DE CALCUL D'AMORT.
  Onerrgo KO From   GLOBB0
  Gosub SET_FIRST From TRTFIRST
  If ([M:DIV]BACTCCN) Then
    Call CCN_LEC_CCNRPR_FLD( LNBF, [M:DIV]TDFNCCN, [M:DIV]NBFCCN ) From   GLOBB0
    If ([M:DIV]NBFCCN > LNBF and GADONIX = 2) Then
      Call ECR_TRACE(mess(171,7774,1),1) From GLOBB0
      [M:DIV]NBF = 0
      Goto FIN_CALCULER_BIEN
    Endif
  Endif
  Call CAL_LEC_CALDEP_FLD( LNBF, [M:DIV]TDFN, [M:DIV]NBF ) From   GLOBB0
  If ([M:DIV]NBF > LNBF and GADONIX = 2) Then
    Call ECR_TRACE(mess(151,7774,1),1) From GLOBB0
    [M:DIV]NBF = 0
    Goto FIN_CALCULER_BIEN
  Endif
  If ([M:DIV]BACTCCN) Then
    Call CMP_CCNRPR_CCNRPR_EQ (RTRN) From   GLOBB0
    [M:DIV]BCCNLECMAJ = !(RTRN)
  Endif
  Call CMP_CALDEP_DEPREC_EQ (RTRN) From   GLOBB0
  [M:DIV]BLECMAJ = !(RTRN)
  If clalev([F:CNX])=0  : Local File CONTEXT  [CNX]  :  Endif
  Raz PTABCNT : N_C = 0
  For [CNX]CNX0 Where CPY=PSOC
    PTABCNT(N_C) = [F:CNX]CNX
    N_C += 1
  Next CNX0
  If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif : # Société
  If clalev([F:WFAS])=0  : Local File FXDASSETS     [WFAS]  :  Endif        : # Biens comptables
  If clalev([F:WDEP])=0  : Local File DEPREC        [WDEP]  :  Endif        : # Plans d'amortissement
  If clalev([F:DEPC])=0  : Local File DEPREC        [DEPC]   :  Endif       : # DEPREC courant FQ79813
  If clalev([F:DEPS])=0  : Local File DEPREC        [DEPS]   :  Endif       : # DEPREC suivant FQ79813
  If clalev([F:SEPC])=0  : Local File DEPREC        [SEPC]   :  Endif       : # DEPREC courant FQ79813
  If clalev([F:SEPS])=0  : Local File DEPREC        [SEPS]   :  Endif       : # DEPREC suivant FQ79813
  If ([M:DIV]BACTCCN) Then
    If clalev([F:WRPR])=0  : Local File CCNRPR      [WRPR]  :  Endif        : # Provisions pour renouvellement
    If clalev([F:RPRC])=0  : Local File CCNRPR      [RPRC]  :  Endif        : # Provisions pour renouvellement FQ79813
    If clalev([F:RPRS])=0  : Local File CCNRPR      [RPRS]  :  Endif        : # Provisions pour renouvellement FQ79813
  Endif
  If !(adxlog) Then :  Trbegin [WFAS], [WDEP] : Endif
  Gosub CALCUL_SOCIETE_PREPARE From   GLOBB
  If ([M:DIV]NIVDET >= 10 ) Then
    Call DUMP_HISTORIQUE_PATCHS  From   GLOBB0
  Endif
  Call CAL_LEC_BIEN(PBCO) From   GLOBB0
  Call  CALCUL_BIEN ( PTABCNT ) From   GLOBB
  Local Integer    PTABPLN(0..G301MAX-1)  : # FQ79856
  Call  EXPLOITER_CALCUL_BIEN ( PTABCNT, PTABPLN) From   GLOBB  : # FQ79856
  Gosub CALCUL_SOCIETE_FERMETURE From   GLOBB
  Local Integer LNOCOMMIT : LNOCOMMIT=0
  If ( GDEBUG and dim(PBKPOINTLST)>0 ) Then
    Local Integer I_BKP : I_BKP = find("NOCOMMIT",PBKPOINTLST)
    If (I_BKP) Then
      If (PBKPOINTFLG(I_BKP) = G_OUI) Then : LNOCOMMIT = 1 : Endif
    Endif
  Endif
  Call ECR_TRACE(mess(58,7774,1)-mess(59,7774,1),0) From   GLOBB0
  If ( LNOCOMMIT ) Then
    Rollback
  Else
    If (adxwrb > 0) Then : Flush [WDEP] : Endif : # FQ83206
    Commit
  Endif
  Gosub UNSET_FIRST From TRTFIRST
  If (clalev([F:WFAS]))   Then : Close Local File [WFAS]  : Endif : # Biens comptables
  If (clalev([F:WDEP]))   Then : Close Local File [WDEP]  : Endif : # Plans d'amortissement
  If (clalev([F:DEPC]))  Then : Close Local File [DEPC]  : Endif : # DEPREC courant FQ79813
  If (clalev([F:DEPS]))  Then : Close Local File [DEPS]  : Endif : # DEPREC suivant FQ79813
  If (clalev([F:SEPC]))  Then : Close Local File [SEPC]  : Endif : # DEPREC courant FQ79813
  If (clalev([F:SEPS]))  Then : Close Local File [SEPS]  : Endif : # DEPREC suivant FQ79813
  If ([M:DIV]BACTCCN) Then
    If (clalev([F:WRPR])) Then : Close Local File [WRPR]  : Endif : # Provisions pour renouvellement
    If (clalev([F:RPRC])) Then : Close Local File [RPRC]  : Endif : # Provisions pour renouvellement FQ79813
    If (clalev([F:RPRS])) Then : Close Local File [RPRS]  : Endif : # Provisions pour renouvellement FQ79813
  Endif
$FIN_CALCULER_BIEN
  If ( !(GSERVEUR) ) Then
    If dim(GFXDNBERR) < 0
      [V]GLTRACE = 0
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE   From LECFIC
     Endif
  Endif
  If ( [M:DIV]NIVDET <> 0 ) Then
    Openo Using [FS1] : [M:DIV]BFS1OPN = 0
    Openo Using [FS2] : [M:DIV]BFS2OPN = 0
  Endif
  Local Integer LAFFTRACE1 : LAFFTRACE1=0
  If ( GDEBUG and dim(PBKPOINTLST)>0 ) Then
    Local Integer I_BKP : I_BKP = find("AFFTRACE1",PBKPOINTLST)
    If (I_BKP) Then
      If (PBKPOINTFLG(I_BKP) = G_OUI) Then : LAFFTRACE1 = 1 : Endif
    Endif
  Endif
  If ( LAFFTRACE1 ) Then : Call AFF_FICH ( "FS1" ) From   GLOBB0 : Endif
  Local Integer LAFFTRACE2 : LAFFTRACE2=0
  If ( GDEBUG and dim(PBKPOINTLST)>0 ) Then
    Local Integer I_BKP : I_BKP = find("AFFTRACE2",PBKPOINTLST)
    If (I_BKP) Then
      If (PBKPOINTFLG(I_BKP) = G_OUI) Then : LAFFTRACE2 = 1 : Endif
    Endif
  Endif
  If ( LAFFTRACE2 ) Then : Call AFF_FICH ( "FS2" ) From   GLOBB0 : Endif
  Gosub CALCUL_DLT_GLOBALES
  If (clalev([M:DIV]))  Then : Close Local Mask [DIV]  : Endif : # Infos diverses
  If (clalev([M:DIV2])) Then : Close Local Mask [DIV2] : Endif : # Infos diverses FQ77877
  RERROR = 0
End
Subprog SIMULER_VALEUR_NETTE ( PDAT, PFLGTIAIML,  RVNC, RSORREG, RSORREGT, RSORREGI,  RERROR)
Value    Date    PDAT        : # Date de sortie
Value    Integer PFLGTIAIML  : # Prise en compte de la dépréciation dans la période courante
Variable Decimal RVNC(0..)   : # Valeur nette à date de sortie
Variable Date    RSORREG(0..)
Variable Date    RSORREGT(0..)
Variable Date    RSORREGI(0..)
Variable Integer RERROR
Local Integer LNBF       : LNBF = 200   : # Nombre de champs dans le masque CALDEP
Local Integer PTABCNT(0..G300MAX-1)       : # Tableau des contextes à calculer
Local Integer N_C                       : # Indice du contexte
  If not clalev([F:WFAS]) Then : RERROR = 28 : End : Endif
  RERROR = 0
  Global Integer G_CDIVOPN  : GCDIVOPN = 0
  If ( clalev([M:DIV])=0 ) Then : Local Mask CALDIV [DIV] : Else : G_CDIVOPN = 1 : Endif
  If ( clalev([M:DIV2])=0 ) Then : Local Mask CALDIV2 [DIV2] : Endif        : # Infos diverses FQ77877
  [M:DIV]TRTDEM    = "CALVNC"
  Local Integer BGESCCN : BGESCCN = func AFNC.ACTIV("CCN") : [M:DIV]BACTCCN = BGESCCN
  Local Integer BGESKPL : BGESKPL = func AFNC.ACTIV("KPL") : [M:DIV]BACTKPL = BGESKPL
  [M:DIV]FLGTIAIML = PFLGTIAIML
  Gosub CALCUL_CRT_GLOBALES
  [M:DIV]DATNUL    = [0/0/0]
  [M:DIV]MNTNUL    = 0
  [M:DIV]DATFMT    = "D:" + GFMDAT4
  [M:DIV]CSTLVLMAX = 11
  [M:DIV]CSTFIYMAX = func AFNC.ACTIV("NFIY") : # FQ59941
  [M:DIV]TRTLVL    = 0                    : # Niveau atteint dans le traitement
  [M:DIV]BDEBUG    = 2                    : # Debug
  [M:DIV]BFS1OPN = 0
  [M:DIV]BFS2OPN = 0
  [M:DIV]ERROR   = 0
  [M:DIV]LVL     = 0
  [M:DIV]SOC    = [F:WFAS]CPY             : # Société courante
  [M:DIV]PROPLN = ""                      : # Plan de production à charger
  G_BERRDER      = 0                       : # Erreur derogatoire FQ82293
  [M:DIV]BONUS  = 0                       : # Bonus russe à charger FQ59941
  Onerrgo KO From   GLOBB0
  Gosub SET_FIRST From TRTFIRST
  If clalev([F:CNX])=0  : Local File CONTEXT  [CNX]  :  Endif
  Raz PTABCNT : N_C = 0
  For [CNX]CNX0 Where CPY=[F:WFAS]CPY
    PTABCNT(N_C) = [F:CNX]CNX
    N_C += 1
  Next CNX0
  If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif : # Société
  If clalev([F:WDEP])  =0 : Local File DEPREC      [WDEP] : Endif : # Plans d'amortissement
  If clalev([F:DEPC])  =0 : Local File DEPREC      [DEPC] :  Endif       : # DEPREC courant FQ79813
  If clalev([F:DEPS])  =0 : Local File DEPREC      [DEPS] :  Endif       : # DEPREC suivant FQ79813
  If clalev([F:SEPC])  =0 : Local File DEPREC      [SEPC] :  Endif       : # DEPREC courant FQ79813
  If clalev([F:SEPS])  =0 : Local File DEPREC      [SEPS] :  Endif       : # DEPREC suivant FQ79813
  If ([M:DIV]BACTCCN) Then
    If clalev([F:WRPR])=0  : Local File CCNRPR      [WRPR]  :  Endif        : # Provisions pour renouvellement
    If clalev([F:RPRC])=0  : Local File CCNRPR      [RPRC]  :  Endif        : # Provisions pour renouvellement FQ79813
    If clalev([F:RPRS])=0  : Local File CCNRPR      [RPRS]  :  Endif        : # Provisions pour renouvellement FQ79813
  Endif
  Gosub CALCUL_SOCIETE_PREPARE From   GLOBB
  If not ([M:DIV]ERROR) Then
    Call  CALCUL_BIEN ( PTABCNT ) From   GLOBB
  Endif
  Local Integer IP
  Local Integer IEC
  Local Date    IPC
  Local Date    IPCP
  If not ([M:DIV]ERROR) Then
    IPC = [M:EGCF]DATSTRPER( [M:EGCF]INDDEBPER(find( GVML_TECOURA, [M:EGCF]STAFIY )-1)+
&                            [M:EGCF]INDCURPER(find( GVML_TECOURA, [M:EGCF]STAFIY )-1)   -2 )
    RVNC(G301CPT-1) = 0
    If ( clalev([M:PCPT]) and [M:DIV]PLNCPT ) Then
      If ( PDAT >= [M:PCPT]PERSTRDAT(0) ) Then
        If ( PDAT >= IPC ) Then
          IP = func GLOBB9.CAL_LOCALISE_DAT (PDAT, [M:PCPT]PERSTRDAT, [M:PCPT]PERENDDAT, 0, [M:PCPT]NB_DEP-1)
          If (IP < 0 ) Then : [M:DIV]ERROR = 18 : End : Endif
        Else
          IP = find(IPC, [M:PCPT]PERSTRDAT )
        Endif
      Else
        If ([M:DIV]BSOR) Then
          IP = find(IPC, [M:PCPT]PERSTRDAT )
        Else
          [M:DIV]ERROR = 18 : End
        Endif
      Endif
      RVNC(G301CPT-1) = [M:PCPT]NBV (IP)
      RSORREG (G301CPT-1) = [M:DIV]SORREG (G301CPT-1)
      RSORREGT(G301CPT-1) = [M:DIV]SORREGT(G301CPT-1)
      RSORREGI(G301CPT-1) = [M:DIV]SORREGI(G301CPT-1)
    Endif
    RVNC(G301FIS-1) = 0
    If ( clalev([M:PFIS]) and [M:DIV]PLNFIS ) Then
      If ( PDAT >= [M:PFIS]PERSTRDAT(0) ) Then
        If ( PDAT >= IPC ) Then
          IP = func GLOBB9.CAL_LOCALISE_DAT (PDAT, [M:PFIS]PERSTRDAT, [M:PFIS]PERENDDAT, 0, [M:PFIS]NB_DEP-1)
          If (IP < 0 ) Then : [M:DIV]ERROR = 18 : End : Endif
        Else
          IP = find(IPC, [M:PFIS]PERSTRDAT )
        Endif
      Else
        If ([M:DIV]BSOR) Then
          IP = find(IPC, [M:PFIS]PERSTRDAT )
        Else
          [M:DIV]ERROR = 18 : End
        Endif
      Endif
      RVNC(G301FIS-1) = [M:PFIS]NBV (IP)
      RSORREG (G301FIS-1) = [M:DIV]SORREG (G301FIS-1)
      RSORREGT(G301FIS-1) = [M:DIV]SORREGT(G301FIS-1)
      RSORREGI(G301FIS-1) = [M:DIV]SORREGI(G301FIS-1)
    Endif
    RVNC(G301MIN-1) = 0
    If ( clalev([M:PMIN]) and [M:DIV]PLNMIN ) Then
