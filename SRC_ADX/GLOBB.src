        Call EVALUE_PERIODE_COURANTE_PLAN (G301LI5, "[M:PLI5]", IPCP)
        If ( PDAT >= IPCP ) Then
          IP = func GLOBB9.CAL_LOCALISE_DAT (PDAT, [M:PLI5]PERSTRDAT, [M:PLI5]PERENDDAT, 0, [M:PLI5]NB_DEP-1)
          If (IP < 0 ) Then : [M:DIV]ERROR = 18 : End : Endif
        Else
          IP = find(IPCP, [M:PLI5]PERSTRDAT )
        Endif
      Else
        If ([M:DIV]BSOR) Then
          Call EVALUE_PERIODE_COURANTE_PLAN (G301LI5, "[M:PLI5]", IPCP)
          IP = find(IPCP, [M:PLI5]PERSTRDAT )
        Else
          [M:DIV]ERROR = 18 : End
        Endif
      Endif
      RVNC(G301LI5-1) = [M:PLI5]NBV (IP)
      RSORREG (G301LI5-1) = [M:DIV]SORREG (G301LI5-1)
      RSORREGT(G301LI5-1) = [M:DIV]SORREGT(G301LI5-1)
      RSORREGI(G301LI5-1) = [M:DIV]SORREGI(G301LI5-1)
    Endif
    RVNC(G301LI6-1) = 0
    If ( clalev([M:PLI6]) and [M:DIV]PLNLI6 ) Then
      If ( PDAT >= [M:PLI6]PERSTRDAT(0) ) Then
        Call EVALUE_PERIODE_COURANTE_PLAN (G301LI6, "[M:PLI6]", IPCP)
        If ( PDAT >= IPCP ) Then
          IP = func GLOBB9.CAL_LOCALISE_DAT (PDAT, [M:PLI6]PERSTRDAT, [M:PLI6]PERENDDAT, 0, [M:PLI6]NB_DEP-1)
          If (IP < 0 ) Then : [M:DIV]ERROR = 18 : End : Endif
        Else
          IP = find(IPCP, [M:PLI6]PERSTRDAT )
        Endif
      Else
        If ([M:DIV]BSOR) Then
          Call EVALUE_PERIODE_COURANTE_PLAN (G301LI6, "[M:PLI6]", IPCP)
          IP = find(IPCP, [M:PLI6]PERSTRDAT )
        Else
          [M:DIV]ERROR = 18 : End
        Endif
      Endif
      RVNC(G301LI6-1) = [M:PLI6]NBV (IP)
      RSORREG (G301LI6-1) = [M:DIV]SORREG (G301LI6-1)
      RSORREGT(G301LI6-1) = [M:DIV]SORREGT(G301LI6-1)
      RSORREGI(G301LI6-1) = [M:DIV]SORREGI(G301LI6-1)
    Endif
  Endif
  Gosub UNSET_FIRST From TRTFIRST
  Gosub CALCUL_SOCIETE_FERMETURE From   GLOBB
  If (clalev([F:WDEP]))  Then : Close Local File [WDEP]  : Endif : # Plans d'amortissement
  If (clalev([F:DEPC]))  Then : Close Local File [DEPC]  : Endif : # DEPREC courant FQ79813
  If (clalev([F:DEPS]))  Then : Close Local File [DEPS]  : Endif : # DEPREC suivant FQ79813
  If (clalev([F:SEPC]))  Then : Close Local File [SEPC]  : Endif : # DEPREC courant FQ79813
  If (clalev([F:SEPS]))  Then : Close Local File [SEPS]  : Endif : # DEPREC suivant FQ79813
  Gosub CALCUL_DLT_GLOBALES
  RERROR = [M:DIV]ERROR
  If (clalev([M:DIV]) and !(G_CDIVOPN) ) Then : Close Local Mask [DIV] : Endif : # Infos diverses
  If (clalev([M:DIV2]) and !(G_CDIVOPN)) Then : Close Local Mask [DIV2] : Endif : # Infos diverses FQ77877
  If (dim(G_CDIVOPN) >0) Then : Kill G_CDIVOPN  : Endif
End
Subprog EVALUE_PERIODE_COURANTE_PLAN (PPLN, PMSK, RPC)
  Value Integer    PPLN  : # Plan
  Value Char       PMSK  : # Abréviation du masque de type [M:DEP] pour le plan donné
  Variable Date    RPC   : # Période courante
  Local Integer I_PLN
  I_PLN = find(PPLN, [M:DIV]PLNCAA)
  Local Integer LCNX
  LCNX  = [M:DIV]PLNCNT(I_PLN-1)
  Case LCNX
    When G300CPFI : LCLAS = "[M:EGCF]"
    When G300IAS  : LCLAS = "[M:EIAS]"
    When G300TEC  : LCLAS = "[M:ETEC]"
    When G300RET  : LCLAS = "[M:ERET]"
    When G300SUB  : LCLAS = "[M:ESUB]"
    When G300LIB  : LCLAS = "[M:ELI1]"
    When G300SU1  : LCLAS = "[M:ELI2]"
    When G300SU2  : LCLAS = "[M:ELI3]"
    When G300SU3  : LCLAS = "[M:ELI4]"
    When G300SU4  : LCLAS = "[M:ELI5]"
    When G300SU5  : LCLAS = "[M:ELI6]"
    When Default  : LCLAS = "[M:EGCF]"
  Endcase
  Local Integer IEC, IDP, ICP, IND
  IEC   = evalue("find(GVML_TECOURA,"+LCLAS+"STAFIY"+")" )
  IDP   = evalue(LCLAS+"INDDEBPER("+num$(evalue(num$(IEC)+"-1"))+")")
  ICP   = evalue(LCLAS+"INDCURPER("+num$(evalue(num$(IEC)+"-1"))+")")
  IND   = IDP + ICP -2
  RPC   = evalue( LCLAS+"DATSTRPER("+num$(evalue(num$(IND)))+")")
End
Subprog CALCULER_SOCIETE (PCPY, PTABFCY, PTABCNT, PFASCLC, RERROR)
Value    Char    PCPY
Value    Char    PTABFCY()
Value    Integer PTABCNT()
Value    Integer PFASCLC
Variable Decimal RERROR
  RERROR        = 0
  [M:DIV]TRTDEM    = "CALSOC"
  Local Integer BGESCCN : BGESCCN = func AFNC.ACTIV("CCN") : [M:DIV]BACTCCN = BGESCCN
  Local Integer BGESKPL : BGESKPL = func AFNC.ACTIV("KPL") : [M:DIV]BACTKPL = BGESKPL
  Gosub CALCUL_CRT_GLOBALES
  [M:DIV]TRTLVL = 0
  [M:DIV]ERRID  = 0
  [M:DIV]ERROR  = 0
  [M:DIV]SOC    = PCPY                    : # Société courante
  [M:DIV]PROPLN = ""                      : # Plan de production à charger
  [M:DIV]BONUS  = 0                       : # Bonus russe à charger FQ59941
  G_BERRDER     = 0                       : # Erreur derogatoire FQ82293
  [M:DIV]BCO    = ""  : #FQ79813a
  Gosub SET_FIRST From TRTFIRST
  If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif : # Société
  Call TEMPON(mess(78,7774,1)-PCPY) From GESECRAN
  Filter [CPY] Where CPY=PCPY : Read [CPY]CPY0 Last : Filter [CPY]
  Call ECR_TRACE(string$(80, '-')+"\",0) From   GLOBB0
  Call ECR_TRACE(mess(22,7774,1)-num$(PCPY)-num$([F:CPY]CPYNAM)+"\",0) From   GLOBB0
  Local Integer I_CNX
  Local Integer RCOD
  For I_CNX = 0 To dim(PTABCNT)-1
    If (PTABCNT(I_CNX)) Then
      Call UPD_WAI_TRT(PCPY,PTABCNT(I_CNX),1,"*","CAL",RCOD) From UPDWAITRT
      If (RCOD) Then : Break : Endif : # FQ79813a
    Endif
  Next N_I
  If (RCOD) Then : RERROR = -1 : End : Endif
  Local Integer RCOD
  Local Char LPARAM
  Call PARAM("","CALTRACE",LPARAM) From ADOVAL
  If (LPARAM <> "" and val(LPARAM) = 10 ) Then
    Call CAL_OPTIMISATION (PCPY, RCOD) From   GLOBB0
    If (RCOD) Then : RERROR = -1 : End : Endif
  Endif
#CHECK IGNORE_BEGIN
  Local Integer B_SOCLCK : B_SOCLCK = 1
  If ( G_ETP_GLOBI ) Then : # FQ114113
    GPOINT = "SOCLCKCAL"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9000 : End
    Endif
  Endif
#CHECK IGNORE_END
  If (B_SOCLCK) Then
  If ( func GLOBIENS.LOCK_SYMBOLE ("CNX", PCPY, "", 0) = 0 ) Then
    RERROR = -3
    Call ECR_TRACE(mess(107,7774,1),1) From   GLOBB0
  Else
    [M:DIV]TRTLVL = 1
    If ( dim(GFILTRE_FAS) < 0 )  Then
      If ( func GLOBIENS.LOCK_SYMBOLE ("FAS", PCPY, "", 0) ) = 0 Then
        RERROR = -3
        Call ECR_TRACE(mess(107,7774,1),1) From   GLOBB0
      Endif
    Endif
    [M:DIV]TRTLVL = 2
  Endif
  Endif
  If ( RERROR = 0 ) Then
    If clalev([F:WFAS])=0  : Local File FXDASSETS     [WFAS]  :  Endif        : # Biens comptables
    If clalev([F:WDEP])=0  : Local File DEPREC        [WDEP]  :  Endif        : # Plans d'amortissement
    If clalev([F:DEPC])=0  : Local File DEPREC        [DEPC]  :  Endif       : # DEPREC courant FQ79813
    If clalev([F:DEPS])=0  : Local File DEPREC        [DEPS]  :  Endif       : # DEPREC suivant FQ79813
    If clalev([F:SEPC])=0  : Local File DEPREC        [SEPC]  :  Endif       : # DEPREC courant FQ79813
    If clalev([F:SEPS])=0  : Local File DEPREC        [SEPS]  :  Endif       : # DEPREC suivant FQ79813
    If ([M:DIV]BACTCCN) Then
      If clalev([F:WRPR])=0  : Local File CCNRPR      [WRPR]  :  Endif        : # Provisions pour renouvellement
      If clalev([F:RPRC])=0  : Local File CCNRPR      [RPRC]  :  Endif        : # Provisions pour renouvellement FQ79813
      If clalev([F:RPRS])=0  : Local File CCNRPR      [RPRS]  :  Endif        : # Provisions pour renouvellement FQ79813
    Endif
    If clalev([F:WFCY])=0  : Local File FACILITY     [WFCY]  :  Endif        : # Sites
    Gosub CALCUL_SOCIETE_PREPARE From   GLOBB
    If ([M:DIV]ERROR) Then
      Call CAL_ERREUR("", "", 0, 0) From  GLOBB0
      Call ECR_TRACE(mess(58,7774,1)-mess(60,7774,1),1) From   GLOBB0
    Else
      Local Integer    PTABPLN(0..G301MAX-1)  : # FQ79856 FQ88613
      Call  CALCULER_SOCIETE_BIENS (PTABFCY, PTABCNT, PTABPLN, PFASCLC) From   GLOBB
      Gosub CALCUL_SOCIETE_FERMETURE From   GLOBB
    Endif
    If (clalev([F:WFAS]))   Then : Close Local File [WFAS]  : Endif  : # Biens comptables
    If (clalev([F:WDEP]))   Then : Close Local File [WDEP]  : Endif  : # Plans d'amortissement
    If (clalev([F:DEPC]))   Then : Close Local File [DEPC]  : Endif  : # DEPREC courant FQ79813
    If (clalev([F:DEPS]))   Then : Close Local File [DEPS]  : Endif  : # DEPREC suivant FQ79813
    If (clalev([F:SEPC]))   Then : Close Local File [SEPC]  : Endif  : # DEPREC courant FQ79813
    If (clalev([F:SEPS]))   Then : Close Local File [SEPS]  : Endif  : # DEPREC suivant FQ79813
    If ([M:DIV]BACTCCN) Then
      If (clalev([F:WRPR])) Then : Close Local File [WRPR]  : Endif  : # Provisions pour renouvellement
      If (clalev([F:RPRC])) Then : Close Local File [RPRC]  : Endif  : # Provisions pour renouvellement FQ79813
      If (clalev([F:RPRS])) Then : Close Local File [RPRS]  : Endif  : # Provisions pour renouvellement FQ79813
    Endif
    If (clalev([F:WFCY]))   Then : Close Local File [WFCY]  : Endif  : # Sites FQ79813
  Endif
  If ( [M:DIV]ERROR = 20 ) Then
   RERROR = -2
  Endif
  Call UNLOCK_SYMBOLE ("CNX", PCPY, "") From GLOBIENS
  Call UNLOCK_SYMBOLE ("FAS", PCPY, "") From GLOBIENS
  Gosub UNSET_FIRST From TRTFIRST
  Gosub CALCUL_DLT_GLOBALES
End
Subprog SIMULER_SOCIETE (PCPY, PTABFCY, PTABCNT, PTABPLN, PHZEXE, PHZPER, PDETAI, PCRITSUP, RERROR)
Value    Char    PCPY
Value    Char    PTABFCY()
Value    Integer PTABCNT()
Value    Integer PTABPLN()
Value    Integer PHZEXE()
Value    Integer PHZPER()
Value    Integer PDETAI()
Value    Char    PCRITSUP()
Variable Decimal RERROR
  RERROR        = 0
  [M:DIV]TRTDEM    = "CALDPS"
  Local Integer BGESCCN : BGESCCN = func AFNC.ACTIV("CCN") : [M:DIV]BACTCCN = BGESCCN
  Gosub CALCUL_CRT_GLOBALES
  [M:DIV]TRTLVL = 0
  [M:DIV]ERRID  = 0
  [M:DIV]ERROR  = 0
  [M:DIV]SOC    = PCPY                    : # Société courante
  [M:DIV]SELSUP = PCRITSUP                : # Critères supplémentaires de la sélection étendue
  [M:DIV]PROPLN = ""                      : # Plan de production à charger
  G_BERRDER     = 0                       : # Erreur derogatoire FQ82293
  [M:DIV]BCO    = ""  : #FQ79813a
  Gosub SET_FIRST From TRTFIRST
  If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif : # Société
  Call TEMPON(mess(179,7774,1)-PCPY) From GESECRAN
  Filter [CPY] Where CPY=PCPY : Read [CPY]CPY0 Last : Filter [CPY]
  Call ECR_TRACE(string$(80, '-')+"\",0) From   GLOBB0
  Call ECR_TRACE(mess(22,7774,1)-num$(PCPY)-num$([F:CPY]CPYNAM)+"\",0) From   GLOBB0
  Local Integer I_CNX
  Local Integer RCOD
  For I_CNX = 0 To dim(PTABCNT)-1
    If (PTABCNT(I_CNX)) Then
      Call UPD_WAI_TRT(PCPY,PTABCNT(I_CNX),1,"*","CAL",RCOD) From UPDWAITRT
      If (RCOD) Then : Break : Endif : # FQ79813a
    Endif
  Next N_I
  If (RCOD) Then : RERROR = -1 : End : Endif
#CHECK IGNORE_BEGIN
  Local Integer B_SOCLCK : B_SOCLCK = 1
  If ( G_ETP_GLOBI ) Then : # FQ114113
    GPOINT = "SOCLCKSIM"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9000 : End
    Endif
  Endif
#CHECK IGNORE_END
  If (B_SOCLCK) Then
  If ( func GLOBIENS.LOCK_SYMBOLE ("CNX", PCPY, "", 0) = 0 ) Then
    RERROR = -3
    Call ECR_TRACE(mess(107,7774,1),1) From   GLOBB0
  Else
    [M:DIV]TRTLVL = 1
    If ( dim(GFILTRE_FAS) < 0 )  Then
      If ( func GLOBIENS.LOCK_SYMBOLE ("FAS", PCPY, "", 0) ) = 0 Then
        RERROR = -3
        Call ECR_TRACE(mess(107,7774,1),1) From   GLOBB0
      Endif
    Endif
    [M:DIV]TRTLVL = 2
  Endif
  Endif
  Local Integer LIR
  Local Integer LDIMREQ : LDIMREQ = int(func AFNC.ACTIV("SIT")/30)+5
  Local Char LREQ(250)(1..LDIMREQ)
  LIR = 1 : LREQ(LIR) = "DEPSIMU.CPY_0 = '"+[M:DIV]SOC+"' "
  Local Integer I_C
  LIR+=1  : LREQ(LIR) = " AND DEPSIMU.CNX_0 IN("+num$(PTABCNT(0))
  For I_C = 2 To dim(PTABCNT)
    If ( PTABCNT(I_C-1) = 0) Then : Break : Endif
    LREQ(LIR) += ","+num$(PTABCNT(I_C-1))
  Next I_C
  LREQ(LIR) += ")" : # Ferme IN
  If ( G_ETP_GLOBI ) Then : # FQ114113
    GPOINT = "DELTABSIM" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC
  Endif
  Call CAL_DELTAB (nomap,"DEPSIMU",LREQ, LIR)  From   GLOBB9
  If ( RERROR = 0 ) Then
    If clalev([F:WFAS])=0  : Local File FXDASSETS     [WFAS]  :  Endif       : # Biens comptables
    If clalev([F:DPS]) =0  : Local File DEPSIMU       [DPS]   :  Endif       : # Résultat de simulation
    If clalev([F:WDEP])=0  : Local File DEPREC        [WDEP]  :  Endif       : # Plans d'amortissement
    If clalev([F:DEPC])=0  : Local File DEPREC        [DEPC]  :  Endif       : # DEPREC courant
    If clalev([F:DEPS])=0  : Local File DEPREC        [DEPS]  :  Endif       : # DEPREC suivant
    If clalev([F:SEPC])=0  : Local File DEPREC        [SEPC]  :  Endif       : # DEPREC courant
    If clalev([F:SEPS])=0  : Local File DEPREC        [SEPS]  :  Endif       : # DEPREC suivant
    If ([M:DIV]BACTCCN) Then
      If clalev([F:WRPR])=0  : Local File CCNRPR      [WRPR]  :  Endif        : # Provisions pour renouvellement
      If clalev([F:RPRC])=0  : Local File CCNRPR      [RPRC]  :  Endif        : # Provisions pour renouvellement
      If clalev([F:RPRS])=0  : Local File CCNRPR      [RPRS]  :  Endif        : # Provisions pour renouvellement
    Endif
    If clalev([F:WFCY])=0  : Local File FACILITY     [WFCY]  :  Endif        : # Sites
    Gosub CALCUL_SOCIETE_PREPARE From   GLOBB
    If ([M:DIV]ERROR) Then
      Call CAL_ERREUR("", "", 0, 0) From  GLOBB0
      Call ECR_TRACE(mess(58,7774,1)-mess(60,7774,1),1) From   GLOBB0
    Else
      Call  CALCULER_SOCIETE_BIENS (PTABFCY, PTABCNT, PTABPLN, G_NON) From   GLOBB
      Gosub CALCUL_SOCIETE_FERMETURE From   GLOBB
    Endif
    If (clalev([F:WFAS]))   Then : Close Local File [WFAS]  : Endif  : # Biens comptables
    If (clalev([F:WDEP]))   Then : Close Local File [WDEP]  : Endif  : # Plans d'amortissement
    If (clalev([F:DEPC]))   Then : Close Local File [DEPC]  : Endif  : # DEPREC courant FQ79813
    If (clalev([F:DEPS]))   Then : Close Local File [DEPS]  : Endif  : # DEPREC suivant FQ79813
    If (clalev([F:SEPC]))   Then : Close Local File [SEPC]  : Endif  : # DEPREC courant FQ79813
    If (clalev([F:SEPS]))   Then : Close Local File [SEPS]  : Endif  : # DEPREC suivant FQ79813
    If ([M:DIV]BACTCCN) Then
      If (clalev([F:WRPR])) Then : Close Local File [WRPR]  : Endif  : # Provisions pour renouvellement
      If (clalev([F:RPRC])) Then : Close Local File [RPRC]  : Endif  : # Provisions pour renouvellement FQ79813
      If (clalev([F:RPRS])) Then : Close Local File [RPRS]  : Endif  : # Provisions pour renouvellement FQ79813
    Endif
    If (clalev([F:WFCY]))   Then : Close Local File [WFCY]  : Endif  : # Sites FQ79813
  Endif
  If ( [M:DIV]ERROR = 20 ) Then
   RERROR = -2
  Endif
  Call UNLOCK_SYMBOLE ("CNX", PCPY, "") From GLOBIENS
  Call UNLOCK_SYMBOLE ("FAS", PCPY, "") From GLOBIENS
  Gosub UNSET_FIRST From TRTFIRST
  Gosub CALCUL_DLT_GLOBALES
End
$CALCUL_SOCIETE_PREPARE
  NEWMOTEUR = 1
  adxftl    = 10
  adxwrb    = 10
  G_CCNCLCSTD = 1
  G_CLCSTD = 1
  [M:DIV]NIVDET = 0
  If ([M:DIV]TRTDEM = "CALBCO" or [M:DIV]TRTDEM = "CALSIM" ) Then
    Local Char LPARAM
    Call PARAM("","CALTRACE",LPARAM) From ADOVAL
    If (LPARAM <> "" ) Then
      [M:DIV]NIVDET = val(LPARAM)
      If ( [M:DIV]NIVDET > 10 ) Then : [M:DIV]NIVDET = 10 : Endif
      If ( [M:DIV]NIVDET < 0  ) Then : [M:DIV]NIVDET =  0 : Endif
    Endif
  Endif
  Call GET_OS("",[M:DIV]OS) From ORDSYS
  If ( [M:DIV]NIVDET > 0 ) Then
    Local Integer LSTA
    Call EFFACE( filpath("tmp", "CAL_"+[M:DIV]SOC+"_*","tmp",0), LSTA) From ORDSYS
    Call OUVRE_FICH ("FS1") From   GLOBB0
    Call OUVRE_FICH ("FS2") From   GLOBB0
    [M:DIV]TRTLVL = 3
  Endif
  If ( G_ETRPNT ) Then
  Endif
  Gosub CAL_LEC_SOCIETE From   GLOBB0
  If ( [M:DIV]ERROR ) Then : Return : Endif
  Gosub CAL_LEC_PARAMETRES From   GLOBB1
  If ( [M:DIV]ERROR ) Then : Return : Endif
  If clalev([M:DPM])=0  : Local Mask CALDPM     [DPM]  :  Endif    : # Dans le call le masque est refermé
  Gosub CAL_LEC_MODES From   GLOBB0
  If ( [M:DIV]ERROR ) Then : Return : Endif
  If clalev([M:CNX])=0  : Local Mask CALCNX     [CNX]  :  Endif    : # Dans le call le masque est refermé
  Call CAL_LEC_CONTEXTES ([M:DIV]SOC, [M:DIV]ERROR) From   GLOBB0
  If ( [M:DIV]ERROR ) Then : Return : Endif
  If clalev([M:TAB])=0   : Local Mask CALTAB    [TAB]  :  Endif    : # Dans le call le masque est refermé
  Call CAL_LEC_TABLE ([M:DIV]SOC) From   GLOBB0
  If ( [M:DIV]ERROR ) Then : Return : Endif
  If ([M:DIV]TRTDEM = "CALDPS") Then
    Local Integer L_C
    For I_C = 1 To dim(PTABCNT)
      If ( PTABCNT(I_C-1) = 0) Then : Break : Endif
      L_C = find(PTABCNT(I_C-1), [M:CNX]CNX)
      If (PHZEXE(I_C-1) <> 0) Then : [M:CNX]HRZEXE   (L_C-1) = PHZEXE(I_C-1) : Endif
      If (PHZEXE(I_C-1) <> 0) Then : [M:CNX]HRZPER   (L_C-1) = PHZPER(I_C-1) : Endif
      If (PDETAI(I_C-1) <> 0) Then : [M:CNX]FLGSIMDET(L_C-1) = PDETAI(I_C-1) : Endif
    Next I_C
    Call ECR_TRACE("",0) From   GLOBB0
  Endif
  If clalev([M:FIY])=0  : Local Mask CALFIY     [FIY]  :  Endif     : # Dans le call le masque est refermé
  If ( find(G300CPFI, PTABCNT)) Then
    If clalev([M:EGCF])=0  : Local Mask CALFIY     [EGCF] :  Endif        : # Comptable & fiscal
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300CPFI ) From   GLOBB0
    If ( [M:DIV]ERROR ) Then : Return : Endif
    Transmask [M:FIY] To [M:EGCF]
  Endif
  If ( find(G300IAS, PTABCNT) ) Then
    If clalev([M:EIAS])=0  : Local Mask CALFIY     [EIAS]  :  Endif
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300IAS ) From   GLOBB0
    If ( [M:DIV]ERROR ) Then : Return : Endif
    Transmask [M:FIY] To [M:EIAS]
  Endif
  If ( find(G300TEC, PTABCNT) ) Then
    If clalev([M:ETEC])=0  : Local Mask CALFIY     [ETEC]  :  Endif
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300TEC ) From   GLOBB0
    If ( [M:DIV]ERROR ) Then : Return : Endif
    Transmask [M:FIY] To [M:ETEC]
  Endif
  If ( find(G300RET, PTABCNT) ) Then
    If clalev([M:ERET])=0  : Local Mask CALFIY     [ERET]  :  Endif
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300RET ) From   GLOBB0
    If ( [M:DIV]ERROR ) Then : Return : Endif
    Transmask [M:FIY] To [M:ERET]
  Endif
  If ( find(G300SUB, PTABCNT) ) Then
    If clalev([M:ESUB])=0  : Local Mask CALFIY     [ESUB]  :  Endif
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SUB ) From   GLOBB0
    If ( [M:DIV]ERROR ) Then : Return : Endif
    Transmask [M:FIY] To [M:ESUB]
  Endif
  If ( find(G300LIB, PTABCNT) ) Then
    If clalev([M:ELI1])=0  : Local Mask CALFIY     [ELI1]  :  Endif
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300LIB ) From   GLOBB0
    Transmask [M:FIY] To [M:ELI1]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  If ( find(G300SU1, PTABCNT) ) Then
    If clalev([M:ELI2])=0  : Local Mask CALFIY     [ELI2]  :  Endif
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SU1 ) From   GLOBB0
    Transmask [M:FIY] To [M:ELI2]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  If ( find(G300SU2, PTABCNT) ) Then
    If clalev([M:ELI3])=0  : Local Mask CALFIY     [ELI3]  :  Endif
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SU2 ) From   GLOBB0
    Transmask [M:FIY] To [M:ELI3]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  If ( find(G300SU3, PTABCNT) ) Then
    If clalev([M:ELI4])=0  : Local Mask CALFIY     [ELI4]  :  Endif
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SU3 ) From   GLOBB0
    Transmask [M:FIY] To [M:ELI4]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  If ( find(G300SU4, PTABCNT) ) Then
    If clalev([M:ELI5])=0  : Local Mask CALFIY     [ELI5]  :  Endif
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SU4 ) From   GLOBB0
    Transmask [M:FIY] To [M:ELI5]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  If ( find(G300SU5, PTABCNT) ) Then
    If clalev([M:ELI6])=0  : Local Mask CALFIY     [ELI6]  :  Endif
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SU5 ) From   GLOBB0
    Transmask [M:FIY] To [M:ELI6]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  If ([M:DIV]BACTCCN) Then
    If clalev([M:RPR]) =0   : Local Mask CCNRPR   [RPR]   :  Endif  : # Provisoins pour renouvellement
    If clalev([M:PRPR])=0   : Local Mask CCNRPR   [PRPR]  :  Endif
    If clalev([M:WRPR])=0   : Local Mask CCNRPR   [WRPR]  :  Endif
    If clalev([M:CAD]) =0   : Local Mask CALDEP   [CAD]   :  Endif  : # Caducité
    If clalev([M:AMI]) =0   : Local Mask CALDEP   [AMI]   :  Endif  : # Amortissement industriel
    If ( [M:DIV]CCNGRTPLN <> 0 ) Then
      If clalev([M:SUB]) =0 : Local Mask CALDEP   [SUB]   :  Endif  : # Subvention
    Endif
  Endif
  If clalev([M:DEP]) =0  : Local Mask CALDEP     [DEP]   :  Endif
  If clalev([M:WDEP])=0  : Local Mask CALDEP     [WDEP]  :  Endif
  If clalev([M:PPL])=0   : Local Mask CALPPL     [PPL]   :  Endif
  Call ECR_ENTETE_CONTEXTE() From   GLOBB0
  Local Integer J_CNT
  Local Integer D_CNT
  Local Integer J_PLN
  J_CNT = 0
  While ( PTABCNT(J_CNT) <> 0 )
    Call ECR_LIGNE_CONTEXTE(PTABCNT(J_CNT)) From   GLOBB0
    D_CNT = find( PTABCNT(J_CNT), [M:DIV]PLNCNT )
    For J_PLN = D_CNT To [M:DIV]NB_PLN
      If ( [M:DIV]PLNCNT (J_PLN-1) <> PTABCNT(J_CNT) ) Then : Break : Endif
      Case [M:DIV]PLNCAA(J_PLN-1)
        When  G301CPT
          If ( clalev([M:PCPT])=0 ) Then
            Local Mask CALDEP     [PCPT]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PCPTOPN = 1 : Endif
          Endif
        When  G301FIS
          If ( clalev([M:PFIS])=0 ) Then
            Local Mask CALDEP     [PFIS]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PFISOPN = 1 : Endif
          Endif
        When  G301MIN
          If ( clalev([M:PMIN])=0 ) Then
            Local Mask CALDEP     [PMIN]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PMINOPN = 1 : Endif
          Endif
        When  G301ORI
          If ( clalev([M:PORI])=0 ) Then
            Local Mask CALDEP     [PORI]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PORIOPN = 1 : Endif
          Endif
        When  G301R76
          If ( clalev([M:PR76])=0 ) Then
            Local Mask CALDEP     [PR76]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PR76OPN = 1 : Endif
          Endif
        When  G301IAS
          If ( clalev([M:PIAS])=0 ) Then
            Local Mask CALDEP     [PIAS]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PIASOPN = 1 : Endif
          Endif
        When  G301TEC
          If ( clalev([M:PTEC])=0 ) Then
            Local Mask CALDEP     [PTEC]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PTECOPN = 1 : Endif
          Endif
        When  G301RET
          If ( clalev([M:PRET])=0 ) Then
            Local Mask CALDEP     [PRET]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PRETOPN = 1 : Endif
          Endif
        When  G301SUB
          If ( clalev([M:PSUB])=0 ) Then
            Local Mask CALDEP     [PSUB]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PSUBOPN = 1 : Endif
          Endif
        When  G301LI1
          If ( clalev([M:PLI1])=0 ) Then
            Local Mask CALDEP     [PLI1]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI1OPN = 1 : Endif
          Endif
        When  G301LI2
          If ( clalev([M:PLI2])=0 ) Then
            Local Mask CALDEP     [PLI2]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI2OPN = 1 : Endif
          Endif
        When  G301LI3
          If ( clalev([M:PLI3])=0 ) Then
            Local Mask CALDEP     [PLI3]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI3OPN = 1 : Endif
          Endif
        When  G301LI4
          If ( clalev([M:PLI4])=0 ) Then
            Local Mask CALDEP     [PLI4]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI4OPN = 1 : Endif
          Endif
        When  G301LI5
          If ( clalev([M:PLI5])=0 ) Then
            Local Mask CALDEP     [PLI5]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI5OPN = 1 : Endif
          Endif
        When  G301LI6
          If ( clalev([M:PLI6])=0 ) Then
            Local Mask CALDEP     [PLI6]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI6OPN = 1 : Endif
          Endif
        When  Default
      Endcase
    Next J_PLN
    J_CNT +=1
  Wend
  If ([M:DIV]TRTDEM = "CALDPS") Then
    Call ECR_TRACE(string$(107,"*")+"\",0) From   GLOBB0
  Else
    Call ECR_TRACE(string$(98,"*")+"\",0) From   GLOBB0
  Endif
  If ( [M:DIV]TRTDEM = "CALDPS" ) Then
    Call ECR_ENTETE_PLAN() From   GLOBB0
    J_PLN = 0
    While ( PTABPLN(J_PLN) <> 0 )
      Call ECR_LIGNE_PLAN(PTABPLN(J_PLN)) From   GLOBB0
      J_PLN +=1
    Wend
  Endif
  Call ECR_TRACE(string$(49,"*")+"\",0) From   GLOBB0
  If ([M:DIV]BACTCCN and [M:DIV]CCNMOD = GVML_GCRNW and [M:DIV]TRTDEM = "CALVNC" ) Then : G_PRPROPN = 1  :   Endif : # Provisions
  If ( [M:DIV]ERROR ) Then : Return : Endif
  If ([M:DIV]TRTDEM = "CALDPS") Then
    If ([M:DIV]SELSUP <> "") Then
      Call ECR_TRACE(mess(182,7774,1),0) From   GLOBB0  :# FQ79856
      Call ECR_TRACE([M:DIV]SELSUP+"\",0)   From   GLOBB0  :# FQ79856
    Endif
    Call ECR_TRACE(mess(181,7774,1)+"\",0)   From   GLOBB0  :# FQ79856
  Else
  Call ECR_TRACE(mess(134,7774,1)+"\",0) From   GLOBB0
  Endif
#CHECK IGNORE_BEGIN
  If ( G_ETP_GLOBI ) Then : # FQ114113
    GPOINT = "SOCPREPA" : # FQ75488
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9003 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
#CHECK IGNORE_END
Return
Subprog EXPLOITER_CALCUL_BIEN ( PTABCNT, PTABPLN )
Value    Integer PTABCNT()
Value    Integer PTABPLN()   : # FQ79856
  Case [M:DIV]TRTDEM
    When "CALSOC", "CALBCO"
      Call CALCUL_MAJ_CONTEXTES ( PTABCNT ) From   GLOBB0
      If ( [M:DIV]BACTCCN and [F:WFAS]OWNTYP = GVML_TDCONCE and [M:DIV]CCNMOD = GVML_GCRNW ) Then
        Call CALCUL_MAJ_PROVISION From   GLOBB0
      Endif
      Call CALCUL_MAJ_BIEN ( PTABCNT )  From   GLOBB0
#CHECK IGNORE_BEGIN
      If ( G_ETP_GLOBI ) Then : # FQ114113
        GPOINT = "AFTMAJFAS"
        Gosub ENTREE From EXEFNC
        If !(GOK) Then
          [M:DIV]ERRID = 9000 : End
        Endif
      Endif
#CHECK IGNORE_END
    When "CALSIM"
      Call CALCUL_MAJ_MASQUE_SIMULATION  From   GLOBB0
    When "CALDPS"
      Call SIMUL_MAJ_CONTEXTES ( PTABCNT, PTABPLN ) From   GLOBB0
  Endcase
  If ( [M:DIV]ERROR ) Then : End : Endif
End
$CALCUL_SOCIETE_FERMETURE
    If (clalev([M:FIY]))   Then : Close Local Mask [FIY]  : Endif : # Exercice
    If (clalev([M:DEP]))   Then : Close Local Mask [DEP]  : Endif : # Plan d'amortissement à calculer
    If (clalev([M:WDEP]))  Then : Close Local Mask [WDEP]  : Endif : # Plan d'amortissement à calculer
    If (clalev([M:PPL]))   Then : Close Local Mask [PPL]  : Endif : # Plan de production
    If (clalev([M:CNX]))   Then : Close Local Mask [CNX]  : Endif : # Globales propre à la boite noire
    If (clalev([M:DPM]))   Then : Close Local Mask [DPM]  : Endif : # Méthode d'amortissement
    If (clalev([M:TAB]))   Then : Close Local Mask [TAB]  : Endif : # Equipes & Véhicules
    If (clalev([M:EGCF])) Then : Close Local Mask [EGCF] : Endif : # Comptable & Fiscal
    If (clalev([M:EIAS])) Then : Close Local Mask [EIAS] : Endif : # IAS/IFRS
    If (clalev([M:ESUB])) Then : Close Local Mask [ESUB] : Endif : # Subvention
    If (clalev([M:ETEC])) Then : Close Local Mask [ETEC] : Endif : # Technique
    If (clalev([M:ERET])) Then : Close Local Mask [ERET] : Endif : # Retraité
    If (clalev([M:ELI1])) Then : Close Local Mask [ELI1] : Endif : # Libre 1
    If (clalev([M:ELI2])) Then : Close Local Mask [ELI2] : Endif : # Libre 2
    If (clalev([M:ELI3])) Then : Close Local Mask [ELI3] : Endif : # Libre 3
    If (clalev([M:ELI4])) Then : Close Local Mask [ELI4] : Endif : # Libre 4
    If (clalev([M:ELI5])) Then : Close Local Mask [ELI5] : Endif : # Libre 5
    If (clalev([M:ELI6])) Then : Close Local Mask [ELI6] : Endif : # Libre 6
    If (clalev([M:PFIS]) and !(G_PFISOPN) ) Then : Close Local Mask [PFIS] : Endif : # Fiscal
    If (clalev([M:PCPT]) and !(G_PCPTOPN) ) Then : Close Local Mask [PCPT] : Endif : # Comptable
    If (clalev([M:PMIN]) and !(G_PMINOPN) ) Then : Close Local Mask [PMIN] : Endif : # Minimum
    If (clalev([M:PORI]) and !(G_PORIOPN) ) Then : Close Local Mask [PORI] : Endif : # Origine
    If (clalev([M:PR76]) and !(G_PR76OPN) ) Then : Close Local Mask [PR76] : Endif : # Réévaluation 76
    If (clalev([M:PIAS]) and !(G_PIASOPN) ) Then : Close Local Mask [PIAS] : Endif : # IAS/IFRS
    If (clalev([M:PSUB]) and !(G_PSUBOPN) ) Then : Close Local Mask [PSUB] : Endif : # Subvention
    If (clalev([M:PTEC]) and !(G_PTECOPN) ) Then : Close Local Mask [PTEC] : Endif : # Technique
    If (clalev([M:PRET]) and !(G_PRETOPN) ) Then : Close Local Mask [PRET] : Endif : # Retraité
    If (clalev([M:PLI1]) and !(G_PLI1OPN) ) Then : Close Local Mask [PLI1] : Endif : # Libre 1
    If (clalev([M:PLI2]) and !(G_PLI2OPN) ) Then : Close Local Mask [PLI2] : Endif : # Libre 2
    If (clalev([M:PLI3]) and !(G_PLI3OPN) ) Then : Close Local Mask [PLI3] : Endif : # Libre 3
    If (clalev([M:PLI4]) and !(G_PLI4OPN) ) Then : Close Local Mask [PLI4] : Endif : # Libre 4
    If (clalev([M:PLI5]) and !(G_PLI5OPN) ) Then : Close Local Mask [PLI5] : Endif : # Libre 5
    If (clalev([M:PLI6]) and !(G_PLI6OPN) ) Then : Close Local Mask [PLI6] : Endif : # Libre 6
    If ([M:DIV]BACTCCN) Then
      If (clalev([M:RPR]))  Then : Close Local Mask [RPR]  : Endif
      If (clalev([M:PRPR]) and !(G_PRPROPN)) Then : Close Local Mask [PRPR] : Endif : # Libre 6
      If (clalev([M:WRPR])) Then : Close Local Mask [WRPR] : Endif
      If (clalev([M:CAD])) Then : Close Local Mask [CAD] : Endif : # Caducité
      If (clalev([M:SUB])) Then : Close Local Mask [SUB] : Endif : # Subvention
      If (clalev([M:AMI])) Then : Close Local Mask [AMI] : Endif : # Amortissement industriel
    Endif
#CHECK IGNORE_BEGIN
    If ( G_ETP_GLOBI ) Then : # FQ114113
      GPOINT = "SOCFERME" : # FQ75488
      Gosub ENTREE From EXEFNC
      If !(GOK) Then
        [M:DIV]ERRID = 9003 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
      Endif
    Endif
#CHECK IGNORE_END
Return
Subprog CALCULER_SOCIETE_BIENS (PTABFCY, PTABCNT, PTABPLN, PFASCLC)
Value    Char    PTABFCY()
Value    Integer PTABCNT()
Value    Integer PTABPLN()  : # FQ79856
Value    Integer PFASCLC    : # FQ88613
Local    Integer NBBIENCMT                          : # Nombre de biens calculés et validés
Local    Integer NBBIENCLC                          : # Nombre de biens calculés
Local    Char    REQUETE(250) (2)                   : # Compléments à la requête
Local    Char    TXTPROG(40)                        : # Gestion de la jauge : Titre
Local    Integer NBBCO                              : # Gestion de la jauge : Nbre de biens total
Local    Integer NBBCO_TRT                          : # Gestion de la jauge : Nbre de biens traités
Local    Integer LOK
Local    Integer B_SITCAL                           : # Au moins un bien à calculer pour le site courant
Local    Integer B_UNDO
Local    Integer B_FIRST
Local    Char    REQFAS(50)                         : # Compléments sélection sur AASREF
  NBBIENCLC = 0
  NBBIENCMT = 0
  Raz REQUETE
  Raz GBIDI1
  If ( dim(GFILTRE_FAS) > 0 ) Then
    If ( GFILTRE_FAS <> "") Then
      Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC, GFILTRE_FAS, "&") From GOBJSUB
    Endif
    Kill GFILTRE_FAS
  Endif
  If ( [M:DIV]TRTDEM <> "CALDPS" and PFASCLC <> G_OUI )  Then
  Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&               "FLGCLC <> G_NON", "&") From GOBJSUB
  Endif
  If ( [M:DIV]TRTDEM = "CALDPS" ) Then
    Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&                 "ISSDAT = [0/0/0]", "&") From GOBJSUB
    If ( [M:DIV]SELSUP <> "" )  Then
    Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&                 [M:DIV]SELSUP, "&") From GOBJSUB
    Endif
    Local    Char    LCURBCO  : LCURBCO = ""
    REQFAS = " AASREF > LCURBCO "
  Else
    REQFAS = " 1=1 "
  Endif
  Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&               "ENAFAS=G_OUI & ISSFIYPRE <> G_OUI", "&") From GOBJSUB
  Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&               "OWNTYP <> GVML_TDMODEL & OWNTYP <> GVML_TDANNUL", "&") From GOBJSUB
  Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&               "(GACACN=GVML_NIENSER | GACACN=GVML_NIENCOU | IASACN=GVML_NIENSER | IASACN=GVML_NIENCOU)", "&")
& From GOBJSUB
#CHECK IGNORE_BEGIN
  Local Char REQCPL(255) : REQCPL = "1=1"
  If ( G_ETP_GLOBI ) Then : # FQ114113
    GPOINT = "CALREQCPL"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9000 : End
    Endif
  Endif
  If (REQCPL <> "1=1") Then
    Call ECR_TRACE(mess(709,7773,1)-":"-REQCPL,0) From   GLOBB0
    Call ECR_TRACE(" ",0) From   GLOBB0
  Endif
#CHECK IGNORE_END
  Filter [WFCY] Where LEGCPY=[M:DIV]SOC
  For [WFCY]FCY1
    B_FIRST = 1 : # FQ79813
    If ( find([F:WFCY]FCY, PTABFCY) <> 0 ) Then
      Repeat
        B_UNDO = 0
        Filter [WFAS] Where CPY=[M:DIV]SOC & FCY=[F:WFCY]FCY & evalue(REQFAS) & evalue(REQUETE) & evalue(REQCPL)
        If (B_FIRST) Then : # FQ79813
          Raz NBBCO, NBBCO_TRT
          If ( [M:DIV]TRTDEM = "CALDPS" ) Then : # FQ79856
            TXTPROG = mess(179,7774,1)-mess(24,7778,1)-[F:WFCY]FCY
          Else
          TXTPROG = mess(1,7774,1)-mess(24,7778,1)-[F:WFCY]FCY
          Endif
          NBBCO   = rowcount([WFAS])
          If (NBBCO=0) Then : B_SITCAL=0 : Else : B_SITCAL=1 : Endif
          Call TEMPOFF() From GESECRAN
          Call OUVRE_BOITE(TXTPROG, NBBCO) From GESECRAN
          Call SET_BOITE(TXTPROG, NBBCO) From GESECRAN
          [M:DIV]TRTLVL = 4
          B_FIRST = 0 : # FQ79813
          If (B_SITCAL) Then
            Call ECR_TRACE(mess(24,7778,1)-[F:WFCY]FCY-mess(148,7774,1)-num$(NBBCO),0) From   GLOBB0
          Endif
        Endif
        For [WFAS]FAS2
          If !(adxlog) Then : Trbegin [WFAS], [WDEP] : Endif
          If (PFASCLC = G_OUI) Then
            [F:WFAS]FLGCLC = G_OUI
            Local Integer I_CNT
            For I_CNT = 1 To dim(PTABCNT)
              If ( PTABCNT(I_CNT-1) <> 0 ) Then
                [F:WFAS]FLGCNXCLC(PTABCNT(I_CNT-1)-1) = GVML_RCOUI
              Endif
            Next
            If ([M:DIV]BACTCCN and [M:DIV]CCNMOD = GVML_GCRNW and [F:WFAS]OWNTYP = GVML_TDCONCE) Then
              [F:WFAS]FLGRPRCLC = G_OUI
            Endif
          Endif
          NBBCO_TRT += 1
          TXTPROG    = [F:WFAS]CPY-'/'-[F:WFAS]AASREF+'['+num$(NBBCO_TRT)+'/'+num$(NBBCO)+']'
          Call AFF_BOITE(TXTPROG,NBBCO_TRT,LOK) From GESECRAN
          Call CALCUL_BIEN (PTABCNT) From   GLOBB
          If ( [M:DIV]ERROR = 0 ) Then
            Call EXPLOITER_CALCUL_BIEN (PTABCNT, PTABPLN) From   GLOBB   : # FQ79856
          Endif
          If ([M:DIV]ERROR) Then
            Call ECR_TRACE(mess(39,7774,1)-num$([F:WFAS]AASREF)-mess(153,7774,1)-num$([M:DIV]ERROR),0) From   GLOBB0
            Break 2
          Else
            NBBIENCLC += 1
          Endif
          If (mod(NBBIENCLC, [M:DIV]NBBCOTRA) = 0 ) Then
            If (adxlog) Then
              If (adxwrb > 0) Then : Flush [WDEP] : Endif : # FQ83206
              Commit
              NBBIENCMT = NBBIENCLC
            Endif
          Endif
          If ([M:DIV]TRTDEM <> "CALDPS" and PFASCLC <> G_OUI)
            If (mod(NBBIENCLC, [M:DIV]NBBCOUDO) = 0 ) Then
              B_UNDO = 1 : Break
            Endif
          Endif
          Gosub TIMOVRFLW From   GLOBB0
          If ( [M:DIV]ERROR = 20 )  Then
            If (adxlog) Then
              If (adxwrb > 0) Then : Flush [WDEP] : Endif  : # FQ83206
              Commit
              NBBIENCMT = NBBIENCLC
            Endif
            Break 3
          Endif
        Next FAS2
        Filter [WFAS]
        If ( B_UNDO )  Then
          LCURBCO = [F:WFAS]AASREF
        Endif
      Until B_UNDO = 0
      If (B_SITCAL) Then
        Filter [WFAS] Where CPY=[M:DIV]SOC  & FCY=[F:WFCY]FCY  & evalue(REQFAS) & evalue(REQUETE) & evalue(REQCPL)
        Call ECR_TRACE(mess(24,7778,1)-[F:WFCY]FCY -mess(149,7774,1)-num$(rowcount([WFAS]))+"\",0) From   GLOBB0
        Filter [WFAS]
      Endif
    Endif
  Next FCY1
  Filter [WFCY]
  If ( [M:DIV]ERROR = 0 ) Then
    If (adxlog) Then
      If (adxwrb > 0) Then : Flush [WDEP] : Endif  : # FQ83206
      Commit
    Endif
    Call ECR_TRACE(mess(45,7774,1)-num$(NBBIENCLC),0) From   GLOBB0
    Call ECR_TRACE(mess(58,7774,1)-mess(59,7774,1),0) From   GLOBB0
  Else
    If (adxlog) Then : Rollback : Endif
    Call ECR_TRACE(mess(45,7774,1)-num$(NBBIENCLC),0) From   GLOBB0
    Call ECR_TRACE(mess(152,7774,1)-num$(NBBIENCMT),0) From   GLOBB0
    If ( find([M:DIV]ERROR, 5, 14, 18, 20, 22, 23, 24, 26, 27, 29, 30, 31) > 0 ) Then
      Call CAL_ERREUR("", "", 0, 0) From   GLOBB0
    Else
      Call ECR_TRACE(mess(153,7774,1)-num$([M:DIV]ERROR), 0) From   GLOBB0
    Endif
    Call ECR_TRACE(mess(48,7774,1),0) From   GLOBB0
    Call ECR_TRACE(mess(58,7774,1)-mess(60,7774,1),1) From   GLOBB0
  Endif
  Call FERME_BOITE From GESECRAN
End
Subprog CALCUL_BIEN (PTABCNT)
Value    Integer PTABCNT()
Local Integer    N_C
  [M:DIV]BCO    = [F:WFAS]AASREF
  [M:DIV]DTFNCON = [0/0/0]
  If ( [M:DIV]BACTCCN and [F:WFAS]CCNREF <> "" ) Then
    [M:DIV]PC(0)= [F:WFAS]CPY : [M:DIV]PC(1)= [F:WFAS]CCNREF
    Gosub GSB_CAL_DATE_FIN_CONCESSION From   GLOBB0
    [M:DIV]DTFNCON = [M:DIV]RD(0)
  Endif
  If G_ACTCCN=G_OUI
   [M:DIV]COEACT = 0.
   If ( [M:DIV]BACTCCN and [F:WFAS]CCNREF <> "" and [F:WFAS]CCNACTCOD <> "" ) Then
     Local Decimal LCOEACT
     Call CCN_LEC_COEACT ([F:WFAS]CPY, [F:WFAS]CCNACTCOD,  LCOEACT) From   GLOBB1
     [M:DIV]COEACT = LCOEACT
   Endif
  Endif
  If([M:DIV]BACTKRU or [M:DIV]BACTKPL) Then
    [M:DIV]DOTSUP = 0. : # FQ67110
    [M:DIV]BONUS  = [F:WFAS]KBONUS
    [M:DIV]PSEPLN = [F:WFAS]KPSEPLN
    Gosub KRU_LEC_PSEPLN From   GLOBB4RU
  Endif
  If ([M:DIV]ERROR) Then : End : Endif
  Gosub SET_FIRST From TRTFIRST
  Call CALCUL_CONTEXTES_PREPARE ( PTABCNT ) From   GLOBB1
  For N_C = 1 To G300MAX
    If ( PTABCNT(N_C-1) <> 0 and ([M:DIV]TRTDEM <> "CALSOC" or [F:WFAS]FLGCNXCLC(PTABCNT(N_C-1)-1) <> G_NON) ) Then
      Call CALCUL_CONTEXTE (PTABCNT(N_C-1)) From   GLOBB1
      If ([M:DIV]ERROR) Then : Break : Endif
    Endif
  Next NC
  Gosub UNSET_FIRST From TRTFIRST
  If ([M:DIV]ERROR) Then : End : Endif
End
