      RSORREG (G301SUB-1) = [M:DIV]SORREG (G301SUB-1)
      RSORREGT(G301SUB-1) = [M:DIV]SORREGT(G301SUB-1)
      RSORREGI(G301SUB-1) = [M:DIV]SORREGI(G301SUB-1)
    Endif
    RVNC(G301LI1-1) = 0
    If ( clalev([M:PLI1]) and [M:DIV]PLNLI1 ) Then
      If ( PDAT >= [M:PLI1]PERSTRDAT(0) ) Then
        Call EVALUE_PERIODE_COURANTE_PLAN (G301LI1, "[M:PLI1]", IPCP)
        If ( PDAT >= IPCP ) Then
