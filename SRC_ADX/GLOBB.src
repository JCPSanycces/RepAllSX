        Else
          [M:DIV]ERROR = 18 : End
        Endif
      Endif
      RVNC(G301ORI-1) = [M:PORI]NBV (IP)
      RSORREG (G301ORI-1) = [M:DIV]SORREG (G301ORI-1)
      RSORREGT(G301ORI-1) = [M:DIV]SORREGT(G301ORI-1)
      RSORREGI(G301ORI-1) = [M:DIV]SORREGI(G301ORI-1)
    Endif
    RVNC(G301R76-1) = 0
    If ( clalev([M:PR76]) and [M:DIV]PLNR76 ) Then
      If ( PDAT >= [M:PR76]PERSTRDAT(0) ) Then
        Call EVALUE_PERIODE_COURANTE_PLAN (G301R76, "[M:PR76]", IPCP)
