      If ( PDAT >= [M:PORI]PERSTRDAT(0) ) Then
        Call EVALUE_PERIODE_COURANTE_PLAN (G301ORI, "[M:PORI]", IPCP)
        If ( PDAT >= IPCP ) Then
          IP = func GLOBB9.CAL_LOCALISE_DAT (PDAT, [M:PORI]PERSTRDAT, [M:PORI]PERENDDAT, 0, [M:PORI]NB_DEP-1)
          If (IP < 0 ) Then : [M:DIV]ERROR = 18 : End : Endif
        Else
