      RSORREGT(G301TEC-1) = [M:DIV]SORREGT(G301TEC-1)
      RSORREGI(G301TEC-1) = [M:DIV]SORREGI(G301TEC-1)
    Endif
    RVNC(G301RET-1) = 0
    If ( clalev([M:PRET]) and [M:DIV]PLNRET ) Then
      If ( PDAT >= [M:PRET]PERSTRDAT(0) ) Then
        Call EVALUE_PERIODE_COURANTE_PLAN (G301RET, "[M:PRET]", IPCP)
        If ( PDAT >= IPCP ) Then
