        Endif
      Endif
      RVNC(G301RET-1) = [M:PRET]NBV (IP)
      RSORREG (G301RET-1) = [M:DIV]SORREG (G301RET-1)
      RSORREGT(G301RET-1) = [M:DIV]SORREGT(G301RET-1)
      RSORREGI(G301RET-1) = [M:DIV]SORREGI(G301RET-1)
    Endif
    RVNC(G301SUB-1) = 0
    If ( clalev([M:PSUB]) and [M:DIV]PLNSUB ) Then
      If ( PDAT >= [M:PSUB]PERSTRDAT(0) ) Then
        If ( PDAT >= IPC ) Then
          IP = func GLOBB9.CAL_LOCALISE_DAT (PDAT, [M:PSUB]PERSTRDAT, [M:PSUB]PERENDDAT, 0, [M:PSUB]NB_DEP-1)
