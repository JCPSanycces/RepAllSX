#<AdxTL>@(#)2.0.0.0 $Revision$
##################################################
#                                                #
#    Consultation des temps passés               #
#                                       05/01    #
##################################################

########################################################
#
# Parametres de consultation via PARAM()
#
#
#1 = site
#
#2 = matricule
#
#3 = date suivi
#
#4 = POSTE DE CHARGE
#
#5 = n° de suivi
#
#6 = n° O.F.
#
#7 = Article lancé
#
#8 = GAMME
#
#9 = ALTERNATIVE DE GAMME
#
#10 = OPERATION
#
#11 = Affaire
#
#12 = Commande
#
#13 = TRI
#
#    1- N° de suivi
#    2- Date de suivi
#    3- N° OF
#    4- Poste
#
##########################################################

Local Char PARAM(20)(1..12)
PARAM(1)="GAL"
PARAM(2)=""
PARAM(3)=""
PARAM(4)=""
PARAM(5)=""
PARAM(6)=""
PARAM(7)=""
PARAM(8)=""
PARAM(9)=""
PARAM(10)=""
PARAM(11)=""
PARAM(12)=""
PARAM(13)=""

Call GCONSULT("MKO", "",PARAM) From GCONSULT
End

##################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LECTURE"  : Gosub LECTURE
 When Default
Endcase
Return

##################################################
$OUVRE

Integer I
Local Char CRITERE(255), CRITERE1(255), CRITERE2(255), CRITERE3(255), CRITERE4(255)
Local Date DEBDAT, FINDAT
Local Char DEBNUM(GLONVCR)    , FINNUM(GLONVCR)
Local Char DEBMFGNUM(GLONVCR) , FINMFGNUM(GLONVCR)
Local Char DEBWST(GLONWST) , FINWST(GLONWST)
Local Integer WSRT

If clalev ([F:MKO]) <= 0 : Local File MFGOPETRK [MKO] : Endif
If clalev ([F:MFG]) <= 0 : Local File MFGHEAD [MFG] : Endif
If clalev ([F:MFI]) <= 0 : Local File MFGITM  [MFI] : Endif
If clalev ([F:FCY]) <= 0 : Local File FACILITY [FCY] : Endif
If clalev ([F:MTK]) <= 0 : Local File MFGHEADTRK[MTK] : Endif

Gosub DEFCRIT

If !find ([M:CMKO]TRI,1,2,3,4) : [M:CMKO]TRI=1 : Endif

# Mail TS du 18/03/08
NAVIG="CONSMKO"
Return

##################################################
$DEFCRIT

#chargement par defaut : en fonction du site et de la date du jour, classement par N° de suivi


For I= 1 To dim(PARAM)
    Case I
        When 1 :     #site
            If  PARAM(I)<> ""
                Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                If !fstat & [F:FCY]MFGFLG = 2 : [M:MKO1]MFGFCY = PARAM(I) : Endif
            Endif
        When 2 :    #matricule
            If  PARAM(I)<> ""
               [M:MKO1]EMPNUMDEB = val(PARAM(I))
               [M:MKO1]EMPNUMFIN = val(PARAM(I))
            Endif
            If PARAM(I)= "": [M:MKO1]EMPNUMDEB = 0: [M:MKO1]EMPNUMFIN = 0 : Endif
        When 3 :   #date suivi
            If  PARAM(I)<> ""
                If instr(1, PARAM(I),"/")
                   [M:MKO1]MFGDATDEB = "["+PARAM(I)+"]"
                   [M:MKO1]MFGDATFIN = "["+PARAM(I)+"]"
                Else
                   [M:MKO1]MFGDATDEB= PARAM(I)
                   [M:MKO1]MFGDATFIN= PARAM(I)
                Endif
            Endif
            If [M:MKO1]MFGDATDEB = [0/0/0]
                [M:MKO1]MFGDATDEB = date$ :  [M:MKO1]MFGDATFIN = date$
            Endif
        When 4 :   #n° de suivi
               If  PARAM(I)<>  ""
                   [M:MKO1]MFGTNUMDEB = PARAM(I)
                   [M:MKO1]MFGTNUMFIN = PARAM(I)
                Endif
        When 5 :   #n° O.F.
            If  PARAM(I)<> ""
               [M:MKO1]MFGNUMDEB = PARAM(I)
               [M:MKO1]MFGNUMFIN = PARAM(I)
            Endif
        When 6 :  # article lancé
            If PARAM(I)<>""
               [M:MKO1]RELITMDEB = PARAM(I)
               [M:MKO1]RELITMFIN = PARAM(I)
            Endif
        When 7 :  #Gamme
            If  PARAM(I)<> ""
               Read [ITM]ITM0 = PARAM(I)
               If !fstat
                   [M:CMKO]ITMREFDEB = PARAM(I)
                   [M:CMKO]ITMREFFIN = PARAM(I)
                Endif
            Endif
        When 8 :   #Alternative de Gamme
            If  PARAM(I)<> ""
               [M:CMKO]ROUALTDEB = val(PARAM(I))
               [M:CMKO]ROUALTFIN = val(PARAM(I))
            Endif
            If PARAM(I) = "" : [M:CMKO]ROUALTDEB = 0: [M:CMKO]ROUALTFIN = 0 : Endif
        When 9 :    #Poste de charge
            If  PARAM(I)<> ""
                Read [MWS]WST0 = PARAM(I);[M:MKO1]MFGFCY        # llc 03.02
                If !fstat
                   [M:MKO1]CPLWSTDEB = PARAM(I)
                   [M:MKO1]CPLWSTFIN= PARAM(I)
                Endif
            Endif
       When 10 :   #Operation
            If  PARAM(I)<> ""
               [M:CMKO]OPENUMDEB = val(PARAM(I))
               [M:CMKO]OPENUMFIN = val(PARAM(I))
            Endif
            If PARAM(I)= "" : [M:CMKO]OPENUMDEB = 0 : [M:CMKO]OPENUMFIN = 0 : Endif
       When 11 :    # Affaire
            If  PARAM(I)<> ""
                 [M:CMKO]PJTDEB = PARAM(I)
                 [M:CMKO]PJTFIN= PARAM(I)
             Endif
       When 12 :    # Commande
             If  PARAM(I)<> ""
                 [M:CMKO]VCRORIDEB = PARAM(I)
                 #[M:CMKO]VRCORIFIN = PARAM(I)  # FGR 14/01/2010 : X3SUIVI60986
                 [M:CMKO]VCRORIFIN = PARAM(I)   # FGR 14/01/2010 : X3SUIVI60986
             Endif
       When 13 : # Tri
             If  PARAM(I)<> ""
                WSRT = val(PARAM(I))
                If WSRT<0 | WSRT > 4 : WSRT = 1 : Endif
                [M:CMKO]TRI = WSRT
             Endif
        When Default : Break

    Endcase
Next I

# Copie de l'ecran d'entête / ecran de criteres
Gosub CRITENT From =PROGCNS
Return

##################################################
$LECTURE

# Si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:MKO1]MFGFCY ="" : NBLU= 0 : Return : Endif
If PARAM(12)="" : PARAM(12)="1" : Endif

#-- Changement d'écran paramétrable
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif


#-- Positionnement des filtres
Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


#########################################################
#                                                       #
#    CHGPAG = 1  : Recherche                            #
#    ------ = 2  : Suite                                #
#    ------ = 3  : F5 (Rafraichissement page courante)  #
#                                                       #
#    CHGPAG = -1 : Dernier                              #
#    ------ = -2 : Retour (page precedente)             #
#                                                       #
#########################################################

#-- Application du filtre et positionnement des boutons
If CHGPAG >0
    SUITE = 1
    If CHGPAG = 1 : RETOUR =1    #recherche
    Elsif CHGPAG = 2 : RETOUR = 2   # suite
    Endif

# FQ 71414 GA 02/2011 il manque la ligne MFI dans les infos lues
#&                [MFI]MFI0 = [F:MKO]MFGTRKNUM;[F:MKO]OPETRKLIN,
    Local Integer WMFGLIN : WMFGLIN=1000
    Case [M:CMKO]TRI
      When 1 :    # tri par N° de suivi   -  60455 mm 11.09
        Link [MKO]
&            With [MTK]MTK0 = [F:MKO]MFGTRKNUM,
&                 [MFI]MFI0 = [F:MKO]MFGNUM;WMFGLIN,
&                 [MFG]MFG0 = [F:MKO]MFGNUM
&       As [LIE]
&       Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4)
&       Order By Key CLE =  [F:MKO]MFGTRKNUM
      When 2 :    #tri par Date suivi -  60455 mm 11.09
        Link [MKO]
&             With [MTK]MTK0 = [F:MKO]MFGTRKNUM,
&                  [MFI]MFI0 = [F:MKO]MFGNUM;WMFGLIN,
&                  [MFG]MFG0 = [F:MKO]MFGNUM
&       As [LIE]
&       Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4)
&       Order By Key CLE =  [F:MTK]MFGTRKDAT
      When 3 :    # N° OF -  60455 mm 11.09
        Link [MKO]
&             With [MTK]MTK0 = [F:MKO]MFGTRKNUM,
&                  [MFI]MFI0 = [F:MKO]MFGNUM;WMFGLIN,
&                  [MFG]MFG0 = [F:MKO]MFGNUM
&       As [LIE]
&       Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4)
&       Order By Key CLE = [F:MKO]MFGNUM
      When 4 :    # Poste -  60455 mm 11.09
        Link [MKO]
&             With [MTK]MTK0 = [F:MKO]MFGTRKNUM,
&                  [MFI]MFI0 = [F:MKO]MFGNUM;WMFGLIN,
&                  [MFG]MFG0 = [F:MKO]MFGNUM
&       As [LIE]
&       Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4)
&       Order By Key CLE = [F:MKO]CPLWST
    Endcase
Else
    RETOUR = 1
    If CHGPAG = -1 : SUITE =1    #dernier
    Elsif CHGPAG =-2 : SUITE = 2 #retour
    Endif

# FQ 71414 GA 02/2011 il manque la ligne MFI dans les infos lues
#&                [MFI]MFI0 = [F:MKO]MFGTRKNUM;[F:MKO]OPETRKLIN,
   Local Integer WMFGLIN : WMFGLIN=1000
   Case [M:CMKO]TRI
      When 1 :    # tri par N° de suivi
         Link [MKO]
&            With [MTK]MTK0 = [F:MKO]MFGTRKNUM,
&                 [MFI]MFI0 = [F:MKO]MFGNUM;WMFGLIN,
&                 [MFG]MFG0 = [F:MKO]MFGNUM
&        As [LIE]
&        Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4)
&        Order By Key CLE = [F:MKO]MFGTRKNUM Desc
      When 2 :    #tri par Date suivi
         Link [MKO]
&            With [MTK]MTK0 = [F:MKO]MFGTRKNUM,
&                 [MFI]MFI0 = [F:MKO]MFGNUM;WMFGLIN,
&                 [MFG]MFG0 = [F:MKO]MFGNUM
&        As [LIE]
&        Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4)
&        Order By Key CLE = [F:MTK]MFGTRKDAT Desc
      When 3 :    # N° OF
         Link [MKO]
&            With [MTK]MTK0 = [F:MKO]MFGTRKNUM,
&                 [MFI]MFI0 = [F:MKO]MFGNUM;WMFGLIN,
&                 [MFG]MFG0 = [F:MKO]MFGNUM
&        As [LIE]
&        Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4)
&        Order By Key CLE =[F:MKO]MFGNUM Desc
      When 4 :    # Poste
         Link [MKO]
&            With [MTK]MTK0 = [F:MKO]MFGTRKNUM,
&                 [MFI]MFI0 = [F:MKO]MFGNUM;WMFGLIN,
&                 [MFG]MFG0 = [F:MKO]MFGNUM
&        As [LIE]
&        Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4)
&        Order By Key CLE = [F:MKO]CPLWST Desc
    Endcase
Endif

#-- RAZ du masque
       If CHGPAG<>2 | CHGPAG<>-2 : Raz [M:MKO2] : Endif

#--  Lecture

For[LIE]
  If NBLU = 1
    If CHGPAG=2 | CHGPAG=-2 : Raz [M:MKO2] : Endif
    NBLU = 2
  Endif
  If CHGPAG >0
      If NOL>=MAXLIG-1 : SUITE = 2 : Break : Endif
      NOL +=1
      If NOL = 0
        DEBNUM = [F:MKO]MFGTRKNUM
        DEBDAT = [F:MTK]MFGTRKDAT
        DEBMFGNUM = [F:MKO]MFGNUM
        DEBWST = [F:MKO]CPLWST
      Endif
      FINNUM = [F:MKO]MFGTRKNUM
      FINDAT = [F:MTK]MFGTRKDAT
      FINMFGNUM = [F:MKO]MFGNUM
      FINWST = [F:MKO]CPLWST
  Else
     If NOL <=0 : RETOUR = 2 : Break : Endif
     NOL -=1
     If NOL = MAXLIG -1
        FINNUM = [F:MKO]MFGTRKNUM
        FINDAT = [F:MTK]MFGTRKDAT
        FINMFGNUM = [F:MKO]MFGNUM
        FINWST = [F:MKO]CPLWST
     Endif
     DEBNUM = [F:MKO]MFGTRKNUM
     DEBDAT = [F:MTK]MFGTRKDAT
     DEBMFGNUM = [F:MKO]MFGNUM
     DEBWST = [F:MKO]CPLWST
  Endif

  nolign = NOL +1
  [M:MKO2]MFGTRKNUM(nolign-1)  = [F:MKO]MFGTRKNUM
  [M:MKO2]TIMTYP(nolign-1)     = [F:MKO]TIMTYP
  [M:MKO2]CPLWST(nolign-1)     = [F:MKO]CPLWST
  [M:MKO2]OPENUM(nolign-1)     = [F:MKO]OPENUM
  [M:MKO2]CPLQTY(nolign-1)     = [F:MKO]CPLQTY
  [M:MKO2]REJCPLQTY(nolign-1)  = [F:MKO]REJCPLQTY
  [M:MKO2]QUACPLQTY(nolign-1)  = [F:MKO]QUACPLQTY
  [M:MKO2]OPEUOM(nolign-1)     = [F:MKO]OPEUOM
  [M:MKO2]OPEWORCOE(nolign-1)  = [F:MKO]OPEWORCOE
  [M:MKO2]TIMUOMCOD(nolign-1)  = [F:MKO]TIMUOMCOD
  [M:MKO2]CPLSETTIM(nolign-1)  = [F:MKO]CPLSETTIM
  [M:MKO2]CPLOPETIM(nolign-1)  = [F:MKO]CPLOPETIM
  [M:MKO2]MFGNUM(nolign-1)     = [F:MKO]MFGNUM
  [M:MKO2]RELITM(nolign-1)     = [F:MFI]ITMREF
  # si type de temps = OF, pas de gamme dans MKO, on prend la gamme de l'OF
  Case [F:MKO]TIMTYP
      When 1:        # OF
                     [M:MKO2]ITMREF(nolign-1)     = [F:MFG]ROUNUM
                     [M:MKO2]ROUALT(nolign-1)     = [F:MFG]ROUALT
                     [M:MKO2]PJT(nolign-1)        = [F:MFI]PJT
                     [M:MKO2]VCRNUMORI(nolign-1)  = [F:MFI]VCRNUMORI
      When Default:  # Article, divers
                     [M:MKO2]ITMREF(nolign-1)     = [F:MKO]ITMREF
                     [M:MKO2]ROUALT(nolign-1)     = [F:MKO]ROUALT
  Endcase
  [M:MKO2]CPLLAB(nolign-1)     = [F:MKO]CPLLAB
  [M:MKO2]MSGNUM(nolign-1)     = [F:MKO]MSGNUM
  [M:MKO2]DACDAT(nolign-1)     = [F:MKO]DACDAT
  [M:MKO2]DACHOU(nolign-1)     = [F:MKO]DACHOU
  [M:MKO2]DACMST(nolign-1)     = [F:MKO]DACMST
  [M:MKO2]POHNUM(nolign-1)     = [F:MKO]POHNUM
  [M:MKO2]POPLIN(nolign-1)     = [F:MKO]POPLIN
  [M:MKO2]PTHNUM(nolign-1)     = [F:MKO]PTHNUM
  [M:MKO2]BPSNUM(nolign-1)     = [F:MKO]BPSNUM
  [M:MKO2]EXTPRI(nolign-1)     = [F:MKO]EXTPRI
  [M:MKO2]CPLPRI(nolign-1)     = [F:MKO]CPLPRI
  [M:MKO2]CPLCRG(nolign-1)     = [F:MKO]CPLCRG
  [M:MKO2]MFGTRKDAT(nolign-1)  = [F:MTK]MFGTRKDAT
  [M:MKO2]EMPNUM(nolign-1)     = [F:MKO]EMPNUM
  # PE permettant de faire apparaitre dans la consultation des champs spécifiques de tables : demande 19161 08.03 MM
  GPOINT = "MKOMAJ" : Gosub ENTREE From EXEFNC
  #

Next
Affzo [M:MKO2]

Return

##################################################
$LOAD_FILTER

Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3
Raz CRITERE4

#site
If [M:MKO1]MFGFCY <> ""
    CRITERE = "[F:MKO]MFGFCY=[M:MKO1]MFGFCY"
Gosub LOAD_CRITERE
Endif


#Matricule
If [M:MKO1]EMPNUMDEB <> 0
 CRITERE = "[F:MKO]EMPNUM>=[M:MKO1]EMPNUMDEB"
Gosub LOAD_CRITERE
Endif

If [M:MKO1]EMPNUMFIN <> 0
 CRITERE = "[F:MKO]EMPNUM<=[M:MKO1]EMPNUMFIN"
Gosub LOAD_CRITERE
Endif


#date suivie
If [M:MKO1]MFGDATDEB <> [0/0/0]
 CRITERE = "[F:MTK]MFGTRKDAT>=[M:MKO1]MFGDATDEB"
Gosub LOAD_CRITERE
Endif

If [M:MKO1]MFGDATFIN<>[0/0/0]
 CRITERE = "[F:MTK]MFGTRKDAT<=[M:MKO1]MFGDATFIN"
Gosub LOAD_CRITERE
Endif

#Poste de charge
If [M:MKO1]CPLWSTDEB<> ""
 CRITERE = "[F:MKO]CPLWST>=[M:MKO1]CPLWSTDEB"
Gosub LOAD_CRITERE
Endif

If [M:MKO1]CPLWSTFIN<> ""
 CRITERE = "[F:MKO]CPLWST<=[M:MKO1]CPLWSTFIN"
Gosub LOAD_CRITERE
Endif

#N° de suivie
If [M:MKO1]MFGTNUMDEB <> ""
 CRITERE = "[F:MKO]MFGTRKNUM>=[M:MKO1]MFGTNUMDEB"
Gosub LOAD_CRITERE
Endif

If [M:MKO1]MFGTNUMFIN<>""
 CRITERE = "[F:MKO]MFGTRKNUM<=[M:MKO1]MFGTNUMFIN"
Gosub LOAD_CRITERE
Endif


# N° O.F.
If [M:MKO1]MFGNUMDEB<> ""
 CRITERE = "[F:MKO]MFGNUM>=[M:MKO1]MFGNUMDEB"
Gosub LOAD_CRITERE
Endif

If [M:MKO1]MFGNUMFIN<> ""
 CRITERE = "[F:MKO]MFGNUM<=[M:MKO1]MFGNUMFIN"
Gosub LOAD_CRITERE
Endif

# Article lancé
If [M:MKO1]RELITMDEB<>""
    CRITERE = "[F:MFI]ITMREF>=[M:MKO1]RELITMDEB"
    Gosub LOAD_CRITERE
Endif

If [M:MKO1]RELITMFIN<> ""
    CRITERE = "[F:MFI]ITMREF<=[M:MKO1]RELITMFIN"
    Gosub LOAD_CRITERE
Endif

#Gamme
If [M:CMKO]ITMREFDEB<> ""
 CRITERE = "[F:MKO]ITMREF>=[M:CMKO]ITMREFDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKO]ITMREFFIN <> ""
 CRITERE = "[F:MKO]ITMREF<=[M:CMKO]ITMREFFIN"
Gosub LOAD_CRITERE
Endif

#Alternative de gamme
If [M:CMKO]ROUALTDEB<> 0
 CRITERE = "[F:MKO]ROUALT>=[M:CMKO]ROUALTDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKO]ROUALTFIN<> 0
 CRITERE = "[F:MKO]ROUALT<=[M:CMKO]ROUALTFIN"
Gosub LOAD_CRITERE
Endif


#Operation
If [M:CMKO]OPENUMDEB<> 0
 CRITERE = "[F:MKO]OPENUM>=[M:CMKO]OPENUMDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKO]OPENUMFIN<> 0
 CRITERE = "[F:MKO]OPENUM<=[M:CMKO]OPENUMFIN"
Gosub LOAD_CRITERE
Endif


#Affaire
If [M:CMKO]PJTDEB<> ""
 CRITERE = "[F:MFI]PJT>=[M:CMKO]PJTDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKO]PJTFIN<> ""
 CRITERE = "[F:MFI]PJT<=[M:CMKO]PJTFIN"
Gosub LOAD_CRITERE
Endif


# Commande
If [M:CMKO]VCRORIDEB<> ""
 CRITERE = "[F:MFI]VCRNUMORI>=[M:CMKO]VCRORIDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKO]VCRORIFIN<> ""
 CRITERE = "[F:MFI]VCRNUMORI<=[M:CMKO]VCRORIFIN"
Gosub LOAD_CRITERE
Endif

#Type de temps
If [M:CMKO]TIMTYPDEB<>0
    CRITERE ="[F:MKO]TIMTYP>=[M:CMKO]TIMTYPDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKO]TIMTYPFIN<>0
    CRITERE ="[F:MKO]TIMTYP<=[M:CMKO]TIMTYPFIN"
Gosub LOAD_CRITERE
Endif


Case CHGPAG
    When 3 : # rafraichissement
        Case [M:CMKO]TRI
            When 1 : # Tri par N° de suivi
                CRITERE ="[F:MKO]MFGTRKNUM >= DEBNUM"
                Gosub LOAD_CRITERE
            When 2 :  # Tri par date suivi
                CRITERE = "[F:MTK]MFGTRKDAT >= DEBDAT"
                Gosub LOAD_CRITERE
            When 3 : # Tri par N° OF
                CRITERE = "[F:MKO]MFGNUM >= DEBMFGNUM"
                Gosub LOAD_CRITERE
            When 4 : # Tri par poste
                CRITERE = "[F:MKO]CPLWST >= DEBWST"
                Gosub LOAD_CRITERE
        Endcase

    When 2 : #suite
        Case [M:CMKO]TRI
          When 1 : # Tri par N° de suivi
              CRITERE ="[F:MKO]MFGTRKNUM > FINNUM"
              Gosub LOAD_CRITERE
          When 2 :  # Tri par date suivi
              CRITERE = "[F:MTK]MFGTRKDAT > FINDAT"
              Gosub LOAD_CRITERE
          When 3 : # Tri par N° OF
              CRITERE = "[F:MKO]MFGNUM > FINMFGNUM"
              Gosub LOAD_CRITERE
          When 4 : # Tri par poste
              CRITERE ="[F:MKO]CPLWST > FINWST"
              Gosub LOAD_CRITERE
        Endcase

    When -2 : #retour
        Case [M:CMKO]TRI
          When 1 : # Tri par N° de suivi
              CRITERE ="[F:MKO]MFGTRKNUM < DEBNUM"
              Gosub LOAD_CRITERE
          When 2 :  # Tri par date suivi
              CRITERE = "[F:MTK]MFGTRKDAT < DEBDAT"
              Gosub LOAD_CRITERE
          When 3 : # Tri par N° OF
              CRITERE = "[F:MKO]MFGNUM <  DEBMFGNUM"
              Gosub LOAD_CRITERE
          When 4 : # Tri par poste
              CRITERE ="[F:MKO]CPLWST < DEBWST"
              Gosub LOAD_CRITERE
        Endcase
Endcase

If CRITERE1 = "" : CRITERE1 ="1=1" : Endif
If CRITERE2 = "" : CRITERE2 ="1=1" : Endif
If CRITERE3 = "" : CRITERE3 ="1=1" : Endif
If CRITERE4 = "" : CRITERE4 ="1=1" : Endif

Return

########################################
$LOAD_CRITERE
If len(CRITERE)+len(CRITERE1)+1 <255
    If len(CRITERE1) <>0 : CRITERE1 += "&" : Endif
    CRITERE1 += CRITERE
Elsif len(CRITERE)+len(CRITERE2)+1 <255
    If len(CRITERE2) <>0 : CRITERE2 += "&" : Endif
    CRITERE2 += CRITERE
Elsif len(CRITERE)+len(CRITERE3)+1 <255
    If len(CRITERE3) <>0 : CRITERE3 += "&" : Endif
    CRITERE3 += CRITERE
Else
    If len(CRITERE4) <>0 : CRITERE4 += "&" : Endif
    CRITERE4 += CRITERE
Endif

Return
