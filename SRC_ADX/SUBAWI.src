#<AdxTL>@(#)0.0.0.0 $Revision$ Fenêtres
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AWI",GBIDC1,GBIDC2) From GOBJET
End

#--------------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBAWIB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "FILTRE"     : Gosub FILTRE
 When "LIENS"      : Gosub LIENS
 When "TITRE"      : Gosub TIT
 When "APRES_CRE"  : Gosub VALID
 When "APRES_MOD"  : Gosub VALID
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "VERIF_CRE"  : Gosub VERIF
 When "VERIF_MOD"  : Gosub VERIF : Filter [AWI] : # Si on fait des tunnels, on plante en réécriture
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "RAZCRE"     : Gosub RAZCRE
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "SEL_TABLE"  : Gosub SEL_TABLE
Endcase
If PSUBB
 Gosub ACTION From SUBAWIB
Endif
Return

#--------------------------------------------------------#
$OUVRE
If GLIAISON<>"" or GLIAISON(1)<>""
 If clalev([F:ALI])=0 : Local File ALINK [ALI] : Endif
 Local Integer WNB0 , WNB1
 Local Schar    WLNK0(max(GLONAOB,GLONACT)+3)(1..300) , WLNK1(max(GLONAOB,GLONACT)+3)(1..300)
Endif
Return

#--------------------------------------------------------#
$FILTRE
If GADONIX<>2
 FILTSUP = "WINTYP<>5" : # Sélection table
Endif
Return

#--------------------------------------------------------#
$SETBOUT
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"V23") From GOBJET : # Validation, Copie, Visu, Visu web
Else
 CHMEN += "6" : # Génération totale
Endif
If GBROWS and GFUSION=0
 Call VIREBOUT(CHAINE,"3") From GOBJET : # Visu
Endif
If [M:AWI1]WINTYP=5 : # Sélection table
 Call VIREBOUT(CHAINE,"3") From GOBJET : # Visu , visu web
Endif
If [M:AWI1]MDL=2
 Call VIREBOUT(CHAINE,"V3") From GOBJET
 Call VIREBOUT(CHMEN,"6") From GOBJET
Endif
#If GVIRTDIR=""
# Call VIREBOUT(CHAINE,"4") From GOBJET : # Visu Web
#Endif
Return

#--------------------------------------------------------#
$EXEBOUT
Case REP
 When "V"
  OK = 2
  Call OUINON(mess(28,126,1)-CLECUR1,OK) From GESECRAN : # Validation fenêtre
  If OK=2
   Gosub VALID
  Endif
 When "3"
  Call SIMUL(CLECUR1)
 When "4"
  Call SIMULWEB(CLECUR1)
Endcase
Return

#--------------------------------------------------------#
$LIENS
Call TEXTE([M]DES,[M]ZDES) From OBJDIV
Call LECTURE("AMK",[M]MSKENT,"") From CONTOBJ
For I=0 To [M]NBMSK-1
 Call LECTURE("AMK",[M]NOMMSK(I),"") From CONTOBJ
 Call TEXTE([F:AWI]INTMSK(I),[M]ZINTONG(I)) From OBJDIV
 If [M]INTFOLD(I)<>""
  [M]INTMSK(I) = 0
  [M]ZINTONG(I) = "$"
 Endif
Next I
nolign = 0
For [AWT] Where WIN=[F:AWI]WIN
 nolign += 1
 [M:AWI2] = [F:AWT]
 If [M:AWI2]TYPBOUT(nolign-1)=3
  [M:AWI2]VALBOUT(nolign-1) = 1
 Endif
 Call TEXTE([M:AWI2]TXTBOUT(nolign-1),[M:AWI2]ZTXTBOUT(nolign-1)) From OBJDIV
Next
[M:AWI2]NBBOUT = nolign
Gosub CHARGE_PARACT
Actzo [AWI3]
Call CHARGE_STD([M:AWI1]WINTYP)
Read [AWB]AWB0 = [F:AWI]WIN
If !fstat
 [M:AWI4] = [F:AWB]
 For I=0 To [M:AWI4]NBLIS-1
  Call TEXTE([M]INTLIS(I),[M]ZINTLIS(I)) From OBJDIV
 Next I
Endif
Call GRISE_WINTYP([F:AWI]WINTYP)
Call GRISE_TYP([F:AWI]TYP)
If GLIAISON(1)<>""
 WNB0 = 0
 For [AWT]AWT0 Where WIN=[F:AWI]WIN & ACTBOUT<>"" & !find(ACTBOUT,"STD","SPE","SPV")
  WNB0 += 1
  WLNK0(WNB0) = "ACT"+[F:AWT]ACTBOUT
 Next
 For I=1 To [F:AWB]NBLIS
  If [F:AWB]OBJLIS(I-1)<>[F:AWI]OBJ
   WNB0 += 1
   WLNK0(WNB0) = "AOB"+[F:AWB]OBJLIS(I-1)
  Endif
 Next I
Endif
Return

#--------------------------#
Subprog GRISE_WINTYP(TYP)
Value Integer TYP
Case TYP
 When 1 : # Divers
  Effzo [M:AWI1]ACS, OBJ, CNS
  Effzo [M:AWI4]DERLU, FIRLIS
  Grizo [AWI1]ACS, OBJ, CNS
  Grizo [AWI4]DERLU, FIRLIS
  Actzo [AWI1]TRN, LIBEL
  If dim([M:AWI1]LEG)>0 : Grizo [AWI1]LEG : Endif
 When 2 : # Objet
  Effzo [M:AWI1]CNS
  Grizo [AWI1]CNS
  Actzo [AWI1]ACS, OBJ, TRN, LIBEL
  Actzo [AWI4]DERLU, FIRLIS
  If dim([M:AWI1]LEG)>0 : Actzo [AWI1]LEG : Endif
 When 3 : # Consultation
  Effzo [M:AWI1]ACS, OBJ, TRN, LIBEL
  Effzo [M:AWI4]DERLU, FIRLIS
  Grizo [AWI1]ACS, OBJ, TRN, LIBEL
  Grizo [AWI4]DERLU, FIRLIS
  Actzo [AWI1]CNS
  For I=0 To [M:AWI3]NBBOUT-1
   [M:AWI3]ACTSTD(I) = ""
   Affzo [M:AWI3]ACTSTD(I)
   Grizo [M:AWI3]ACTSTD(I)
  Next I
  If dim([M:AWI1]LEG)>0 : Grizo [AWI1]LEG : Endif
 When 4 : # Critères consultation
  Effzo [M:AWI1]ACS, OBJ, TRN, LIBEL
  Effzo [M:AWI4]DERLU, FIRLIS
  Grizo [AWI1]ACS, OBJ, TRN, LIBEL
  Grizo [AWI4]DERLU, FIRLIS
  Actzo [AWI1]CNS
  For I=0 To [M:AWI3]NBBOUT-1
   [M:AWI3]ACTSTD(I) = ""
   Affzo [M:AWI3]ACTSTD(I)
   Grizo [M:AWI3]ACTSTD(I)
  Next I
  If dim([M:AWI1]LEG)>0 : Grizo [AWI1]LEG : Endif
 When 5 : # Sélection table
  Effzo [M:AWI1]ACS, OBJ, TRN, LIBEL, CNS
  Effzo [M:AWI4]DERLU, FIRLIS
  Grizo [AWI1]ACS, OBJ, TRN, LIBEL, CNS
  Grizo [AWI4]DERLU, FIRLIS
  For I=0 To [M:AWI3]NBBOUT-1
   [M:AWI3]ACTSTD(I) = ""
  Next I
  If dim([M:AWI1]LEG)>0 : Grizo [AWI1]LEG : Endif
Endcase
End

#--------------------------#
Subprog GRISE_TYP(TYP)
Value Integer TYP
Case TYP
 When 1,2
  Actzo [AWI4]NBLIS
 When Default
  Effzo [AWI4]NBLIS
  Grizo [AWI4]NBLIS
Endcase
End

#--------------------------------------------------------#
$RAZCRE
Call CHARGE_STD([F:AWI]WINTYP)
Affzo [AWI3]
Return

Subprog CHARGE_STD(TYP)
Value Integer TYP
Local Integer I
Local Char    LISBOU(50)
I = -1
Case TYP
 When 2 : # Objet
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(2,123,1)   : # Enregistrer
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(3,123,1)   : # Créer
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(4,123,1)   : # Supprimer
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(5,123,1)   : # Abandon
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(157,100,1) : # OK
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(189,133,1) : # Nouveau
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(187,133,1) : # Premier
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(188,133,1) : # Dernier
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(30,126,1)  : # Précédent
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(31,126,1)  : # Suivant
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(22,123,1)  : # Sélection
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(135,124,1) : # Changement clé
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(61,123,1)  : # Impression
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(137,124,1) : # Liste
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(118,124,1) : # Pièces jointes
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(123,124,1) : # Commentaires
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(199,123,1) : # Propriétés
  LISBOU = "MCA ON09<>RHELJK@"
  If GPRODUIT=1 : ## GEODE
   I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(186,133,1) : # Sélection picking
   LISBOU += "Q"
  Endif
  LISBOU += "F"
 When 3 : # Consultation
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(27,123,1)  : # Recherche
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(182,133,1) : # Critères
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(144,124,1) : # Retour
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(183,133,1) : # Suite
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(184,133,1) : # Dernier
  LISBOU = "RC-+D"
 When 4 : # Critères
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(157,100,1) : # OK
  LISBOU = "O"
 When Default
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(2,123,1)   : # Enregistrer
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(3,123,1)   : # Créer
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(4,123,1)   : # Supprimer
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(5,123,1)   : # Abandon
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(157,100,1) : # OK
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(189,133,1) : # Nouveau
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(187,133,1) : # Premier
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(188,133,1) : # Dernier
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(30,126,1)  : # Précédent
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(31,126,1)  : # Suivant
  I += 1 : [M:AWI3]VSTD(I) = 2 : [M:AWI3]LIBSTD(I) = mess(22,123,1)  : # Sélection
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(135,124,1) : # Changement clé
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(61,123,1)  : # Impression
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(137,124,1) : # Liste
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(118,124,1) : # Pièces jointes
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(123,124,1) : # Commentaires
  I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(199,123,1) : # Propriétés
  LISBOU = "ECSAON09<>XHILJMP"
  If GPRODUIT=1 : ## GEODE
   I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(186,133,1) : # Sélection picking
   LISBOU += "Q"
  Endif
  LISBOU += "F"
Endcase
#I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(65,123,1)  : # Fin
#  On remplace Fin par Fermer
I += 1 : [M:AWI3]VSTD(I) = 1 : [M:AWI3]LIBSTD(I) = mess(25,9801,1)  : # Fin
[M:AWI3]NBBOUT = I+1
For I=1 To [M:AWI3]NBBOUT
 [M:AWI3]CODE(I-1) = mid$(LISBOU,I,1)
Next I
End

$CHARGE_PARACT
Local Integer B, P, PAG
Local Char    ACT(GLONACT), ABRPAR(10)
PAG = 1 : # Boutons spéciaux
B = 0
For [AWT] Where WIN=[F:AWI]WIN
 B += 1
 ACT = [F:AWT]ACTBOUT
 Gosub LECACT
Next
PAG = 2 : # Boutons standards
For B=1 To dim([F:AWI]BSTD)-1
 ACT = [F:AWI]ACTSTD(B-1)
 Gosub LECACT
Next B
Return

$LECACT
While ACT<>""
 Read [ACT]ACTION = ACT
 If !fstat
  Gosub LECPAR
  ACT = [F:ACT]ACTSUI
 Else
  ACT = ""
 Endif
Wend
Return

$LECPAR
I = 0
For [ATR]NOPAR Where ACTION=ACT
 I += 1
 If [F:ACT]TYPACT<>2 or I>1
  If PAG=1
   ABRPAR = "[M:AWI2]"
  Else
   ABRPAR = "[M:AWI3]"
  Endif
  P = evalue(ABRPAR+"NBP(B-1)")
  K = 1
  For J=1 To P
   If evalue(ABRPAR+"P"+num$(J)+"(B-1)")=[F:ATR]CODPAR
    K = 0 : Break
   Endif
  Next J
  If K
   K = 100 * (PAG=2) + B
   Filter [AWP] Where WIN=[F:AWI]WIN & NUM=K & PARAM=[F:ATR]CODPAR
   Read [AWP]AWP0 First
   Filter [AWP]
   If fstat
    Raz [F:AWP]VALEUR
   Endif
   P += 1
   Assign ABRPAR+"NBP(B-1)" With P
   Assign ABRPAR+"P"+num$(P)+"(B-1)" With [F:ATR]CODPAR
   Assign ABRPAR+"V"+num$(P)+"(B-1)" With [F:AWP]VALEUR
  Endif
 Endif
Next
Return

#--------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "SELRES" : Gosub SELRES
Endcase
Return

$SELRES
Local Integer T
T = val(PARAM(1))
TIT = mess(129,133,1) : # Code réservé
Gosub SET_BR
NBTEX = len(BR)
For I=1 To NBTEX
 TEX(I) = mid$(BR,I,1)
 Case T
  When 2
   Case I
    When 1  : TEXTE(I) = TEX(I)-":"-mess(4,123,1)   : # Supprimer
    When 2  : TEXTE(I) = TEX(I)-":"-mess(3,123,1)   : # Créer
    When 3  : TEXTE(I) = TEX(I)-":"-mess(172,123,1) : # Duplication
    When 4  : TEXTE(I) = TEX(I)-":"-mess(61,123,1)  : # Editer
    When 5  : TEXTE(I) = TEX(I)-":"-mess(65,123,1)  : # Fin
    When 6  : TEXTE(I) = TEX(I)-":"-mess(135,124,1) : # Changement de Code
    When 7  : TEXTE(I) = TEX(I)-":"-mess(118,124,1) : # Pièces jointes
    When 8  : TEXTE(I) = TEX(I)-":"-mess(123,124,1) : # Commentaires
    When 9  : TEXTE(I) = TEX(I)-":"-mess(137,124,1) : # Liste
    When 10 : TEXTE(I) = TEX(I)-":"-mess(158,100,1) : # Modif
    When 11 : TEXTE(I) = TEX(I)-":"-mess(22,123,1)  : # Sélection
    When 12 : TEXTE(I) = TEX(I)-":"-mess(193,124,1) : # Transaction
    When 13 : TEXTE(I) = TEX(I)-":"-mess(207,123,1) : # Workflow
    When 14 : TEXTE(I) = TEX(I)-":"-mess(187,133,1) : # Premier
    When 15 : TEXTE(I) = TEX(I)-":"-mess(188,133,1) : # Dernier
    When 16 : TEXTE(I) = TEX(I)-":"-mess(199,123,1) : # Propriétés
    When 17 : TEXTE(I) = TEX(I)-":"-mess(246,123,1) : # Stats
    When 18 : TEXTE(I) = TEX(I)-":"-mess(214,123,1) : # Raffraichir
    When 19 : TEXTE(I) = TEX(I)-":"-mess(30,126,1)  : # Précédent
    When 20 : TEXTE(I) = TEX(I)-":"-mess(31,126,1)  : # Suivant
    When Default : TEXTE(I) = TEX(I)-":"-mess(129,133,1) : # Code réservé
   Endcase
  When 3
   Case I
    When 1  : TEXTE(I) = TEX(I)-":"-mess(182,133,1) : # Critères
    When 2  : TEXTE(I) = TEX(I)-":"-mess(215,123,1) : # Dernière page
    When 3  : TEXTE(I) = TEX(I)-":"-mess(61,123,1)  : # Editer
    When 4  : TEXTE(I) = TEX(I)-":"-mess(65,123,1)  : # Fin
    When 5  : TEXTE(I) = TEX(I)-":"-mess(137,124,1) : # Liste
    When 6  : TEXTE(I) = TEX(I)-":"-mess(127,123,1) : # Recherche
    When 7  : TEXTE(I) = TEX(I)-":"-mess(187,133,1) : # Premier
    When 8  : TEXTE(I) = TEX(I)-":"-mess(188,133,1) : # Dernier
    When 9  : TEXTE(I) = TEX(I)-":"-mess(30,126,1)  : # Précédent
    When 10 : TEXTE(I) = TEX(I)-":"-mess(31,126,1)  : # Suivant
    When 11 : TEXTE(I) = TEX(I)-":"-mess(214,123,1) : # Raffraichir
    When 12 : TEXTE(I) = TEX(I)-":"-mess(16,2,1)    : # Page +
    When 13 : TEXTE(I) = TEX(I)-":"-mess(17,3,1)    : # Page -
   Endcase
  When 4 : # Critères consultation
   Case I
    When 1  : TEXTE(I) = TEX(I)-":"-mess(64,123,1)  : # OK
   Endcase
  When Default
   Case I
    When 1  : TEXTE(I) = TEX(I)-":"-mess(5,123,1)   : # Abandon
    When 2  : TEXTE(I) = TEX(I)-":"-mess(3,123,1)   : # Créer
    When 3  : TEXTE(I) = TEX(I)-":"-mess(2,123,1)   : # Enregistrer
    When 4  : TEXTE(I) = TEX(I)-":"-mess(65,123,1)  : # Fin
    When 5  : TEXTE(I) = TEX(I)-":"-mess(135,124,1) : # Changement de Code
    When 6  : TEXTE(I) = TEX(I)-":"-mess(61,123,1)  : # Editer
    When 7  : TEXTE(I) = TEX(I)-":"-mess(118,124,1) : # Pièces jointes
    When 8  : TEXTE(I) = TEX(I)-":"-mess(137,124,1) : # Liste
    When 9  : TEXTE(I) = TEX(I)-":"-mess(123,124,1) : # Commentaires
    When 10 : TEXTE(I) = TEX(I)-":"-mess(189,133,1) : # Nouveau
    When 11 : TEXTE(I) = TEX(I)-":"-mess(64,123,1)  : # OK
    When 12 : TEXTE(I) = TEX(I)-":"-mess(199,123,1) : # Propriétés
    When 13 : TEXTE(I) = TEX(I)-":"-mess(4,123,1)   : # Supprimer
    When 14 : TEXTE(I) = TEX(I)-":"-mess(193,124,1) : # Transaction
    When 15 : TEXTE(I) = TEX(I)-":"-mess(22,123,1)  : # Sélection
    When 16 : TEXTE(I) = TEX(I)-":"-mess(50,109,1)  : # Premier
    When 17 : TEXTE(I) = TEX(I)-":"-mess(51,109,1)  : # Dernier
    When 18 : TEXTE(I) = TEX(I)-":"-mess(214,123,1) : # Raffraichir
    When 19 : TEXTE(I) = TEX(I)-":"-mess(30,126,1)  : # Précédent
    When 20 : TEXTE(I) = TEX(I)-":"-mess(31,126,1)  : # Suivant
    When Default : TEXTE(I) = TEX(I)-":"-mess(129,133,1) : # Code réservé
   Endcase
 Endcase
Next I
Return

#------------------------------------------------------------------------#
# Codes boutons réservés suivant le type de la fenêtre
#------------------------------------------------------------------------#

$SET_BR
Local Char BR(30)
Case T
 When 2 : # Objet
  # A Annuler
  # C Créer
  # D Dupliquer
  # E Editer
  # F Fin
  # H Changement de code
  # J Pièce Jointe
  # K Commentaire
  # L Liste
  # M Modif
  # R Sélection avancée
  # T Transaction
  # W Workflow
  # 0 Premier
  # 9 Dernier
  # @ Propriétés
  # + Statistiques
  # = Raffraîchir
  # < Précédent
  # > Suivant
  BR = "ACDEFHJKLMRTW09@+=<>"
  # S Supprimer
  # P Propriétés
  # X Sélection
  # I Impression
  # Q Picking Géode
  # N Nouveau
  BR += "SPXIQN"
 When 3 : # Consultation
  # C Critères
  # D Dernière Page
  # E Edition
  # F Fin
  # L Liste
  # R Recherche
  # 0 Premier
  # 9 Dernier
  # < Précédent
  # > Suivant
  # = Raffraichir
  # + Page +
  # - Page -
  BR = "CDEFLR09<>=+-"
 When 4 : # Critères consultation
  # O Ok
  BR = "O"
 When Default
  # A Abandon
  # C Créer
  # E Enregistrer
  # F Fin
  # H Changement de code
  # I Edition
  # J Pièce jointe
  # L Liste
  # M Commentaires
  # N Nouveau
  # O Ok
  # P Propriétés
  # S Supprimer
  # T Transaction
  # X Sélection
  # 0 Premier
  # 9 Dernier
  # = Raffaîchir
  # < Précédent
  # > Suivant
  BR = "ACEFHIJLMNOPSTX09=<>"
Endcase
Return

#--------------------------------------------------------#
$VERIF
Local Char ABRCUR(GLONABR) , ABRREF(GLONABR) , MESSA(250)
Local Char ABRECR(GLONABR)(0..16) , NOMECR(GLONAMK)(0..16)
If [M]NBMSK>1 & [M]MSKENT=""
  OK=0
  For I=1 To [M]NBMSK
    If [M]FLGMSK(I-1)=2
      OK+= 1
    Endif
  Next I
  If OK>1
    Call ERREUR(mess(187,123,1)) From GESECRAN : OK = 0 : # Il doit y avoir un écran d'en-tête
  Endif
Endif
If [M]NBMSK=0 & [M]MSKENT<>""
 Call ERREUR(mess(188,123,1)) From GESECRAN : OK = 0 : # Il doit y avoir un onglet
Endif
Raz ABRECR
If [M]MSKENT<>""
 Read [AMK]CODMSK = [M]MSKENT
 If !fstat
  ABRECR(0) = [F:AMK]ABRMSK
  NOMECR(0) = [F:AMK]CODMSK
 Endif
Endif
For I=1 To [M]NBMSK
 Read [AMK]CODMSK = [M]NOMMSK(I-1)
 If !fstat
  ABRECR(I) = [F:AMK]ABRMSK
  NOMECR(I) = [F:AMK]CODMSK
 Endif
Next I
OK = 1
For I=0 To [M]NBMSK
 If ABRECR(I)<>""
  K = find(ABRECR(I),ABRECR(I+1..[M]NBMSK))
  If K : K = I+K : OK = 0 : Break : Endif
 Endif
Next I
If !OK
 If [M]MDL=2
  OK = 2
  Call AVERTIR(NOMECR(I)-NOMECR(K)-":"-mess(21,126,1),OK) From GESECRAN : # Ecrans de même abréviation
  If OK<>2 : OK = 0 : Return : Endif
 Else
  Call ERREUR(NOMECR(I)-NOMECR(K)-":"-mess(21,126,1)) From GESECRAN : # Ecrans de même abréviation
  OK = 0 : Return
 Endif
Endif
OK = 0
For I=1 To [M]NBMSK
 If [M]FLGMSK(I-1)=2
  OK = 1 : Break
 Endif
Next I
If !OK
 OK = 2 : Call AVERTIR(mess(139,133,1),OK) From GESECRAN : # Il n'y a pas d'onglet visible
 If OK<>2 : OK = 0 : Return : Endif
Endif
OK = 0
If [M]MSKENT<>""
 Read [AMK]CODMSK = [M]MSKENT
 If !fstat
  If [F:AMK]MDL=2 & [M]MDL<>2
   OK = 1
  Elsif [F:AMK]TYPMSK<>5
   If [M:AWI1]FVT<>2 or ([M:AWI1]FVT=2 and [F:AMK]TYPMSK<>6)
     OK = 3
   Endif
  Endif
 Endif
Endif
If !OK
 For I=1 To [M]NBMSK
  Read [AMK]CODMSK = [M]NOMMSK(I-1)
  If !fstat
   If [F:AMK]MDL=2 & [M]MDL<>2
    OK = 1 : Break
   Endif
  Endif
 Next I
Endif
Case OK
 When 1
  # Ecran modèle\Les écrans modèles ne peuvent être définis que sur des fenêtres modèles
  Call ERREUR([F:AMK]CODMSK-":"-mess(121,133,1)+"\"+mess(7,139,1)) From GESECRAN
  OK = 0 : Return
 When 3
  # Ce n'est pas un écran d'entête
  Call ERREUR([F:AMK]CODMSK-":"-mess(189,123,1)) From GESECRAN
  OK = 0 : Return
Endcase
OK = 1
For I=1 To [M:AWI2]NBBOUT
 If [M:AWI2]TYPBOUT(I-1)>=2 & len([M:AWI2]CODBOUT(I-1))>1
  OK = 0
  CHAINE = left$([M:AWI2]CODBOUT(I-1),len([M:AWI2]CODBOUT(I-1))-1)
  For J=1 To [M:AWI2]NBBOUT
   If [M:AWI2]TYPBOUT(J-1)=2 & CHAINE=[M:AWI2]CODBOUT(J-1)
    OK = 1 : Break
   Endif
  Next J
  If !OK : Break : Endif
 Endif
Next I
If !OK
 Call ERREUR(CHAINE-":"-mess(154,124,1)) From GESECRAN : # Menu inexistant
 Return
Endif
For nolign=1 To [M]NBLIS
 Read [AOB]ABREV = [M]OBJLIS(nolign-1)
 Read [AOL]AOL0  = [M]OBJLIS(nolign-1)
 If [F:AOB]TYPGES=2
  Call ERREUR([M]OBJLIS(nolign-1)-mess(71,126,1)) From GESECRAN : # Liste de gauche impossible avec cet objet
  OK = 0 : Break
 Elsif [F:AOL]NBSEL=0
  Call ERREUR([M]OBJLIS(nolign-1)-mess(156,123,1)) From GESECRAN : # Le nombre de zones de sélection est nul
  OK = 0 : Break
 Endif
 Gosub SETCLE
 If find([M]TRELIS(nolign-1),2,3) & NCLE>[F:AOL]NBSEL & [M]OBJLIS(nolign-1)<>"ALI" : # Liste hiérachisée
  OK = 0
 Endif
 If !OK
  Call ERREUR([M]OBJLIS(nolign-1)-mess(73,126,1)) From GESECRAN
  # Champs de sélection incompatibles avec l'index
  Break
 Endif
 If nolign>1
  Raz ABRREF
  If [M]ABRLIS(nolign-1)<>""
   ABRREF = [M]ABRLIS(nolign-1)
  Else
   Read [ATB]CODFIC = [F:AOB]NOMFIC
   If !fstat : ABRREF = [F:ATB]ABRFIC+"_" : Endif
  Endif
  For I=1 To nolign-1
   Raz ABRCUR
   If [M]ABRLIS(I-1)<>""
    ABRCUR = [M]ABRLIS(I-1)
   Else
    Read [AOB]ABREV = [M]OBJLIS(I-1)
    Read [ATB]CODFIC = [F:AOB]NOMFIC
    If !fstat : ABRCUR = [F:ATB]ABRFIC+"_" : Endif
   Endif
   If [M]OBJLIS(I-1)+ABRCUR=[M]OBJLIS(nolign-1)+ABRREF
    # Ligne x Objet y Abréviation z
    # Objet utilisé avec la même abréviation
    MESSA = mess(136,105,1)-num$(I)-":"-mess(33,115,1)-[M]OBJLIS(I-1)-mess(180,115,1)-ABRCUR
    MESSA += "\"+mess(136,105,1)-num$(nolign)-":"-mess(33,115,1)-[M]OBJLIS(nolign-1)-mess(180,115,1)-ABRREF
    MESSA += "\"+mess(201,133,1)-num$(I)
    Call ERREUR(MESSA) From GESECRAN
    OK = 0 : Break
   Endif
  Next I
 Endif
Next nolign
Return

$SETCLE
Local Integer I , J , NCLE
Local Char    TCLE(200), FCLE(GLONAVA)(1..16)
Raz NCLE, FCLE
If [F:AOB]NOMFIC=""
 NCLE = [F:AOL]NBSEL
 Return
Elsif [M]CLELIS(nolign-1)<>""
 Read [ATI]CODIND = [F:AOB]NOMFIC;[M]CLELIS(nolign-1)
Else
 Read [ATI]NUMLIG(2) = [F:AOB]NOMFIC;1
Endif
TCLE = [F:ATI]DESCRIPT
While TCLE<>""
 NCLE += 1
 I = instr(1,TCLE,"+")
 J = instr(1,TCLE,"-")
 If I & J : I = min(I,J)
 Elsif !I : I = J
 Endif
 If I
  FCLE(NCLE) = left$(TCLE,I-1)
  TCLE = right$(TCLE,I+1)
 Else
  FCLE(NCLE) = TCLE
  TCLE = ""
 Endif
Wend
Return

#--------------------------------------------------------#
$CREATION
Gosub ECRIRE
If GLIAISON(1)<>""
 WNB0 = 0 : Gosub CRE_LIENS
Endif
Return

$ECRIRE
Call TEMPON("E") From GESECRAN
For NOL=0 To [M:AWI2]NBBOUT-1
 nolign = NOL+1
 [F:AWT] = [M:AWI2]
 [F:AWT]NUM = nolign
 [F:AWT]WIN = [F:AWI]WIN
 Write [AWT]
 If fstat
  GOK = 0 : Call FSTA("AWT") From GLOCK : Break
 Endif
 For K=1 To [M:AWI2]NBP(NOL)
  If evalue("[M:AWI2]P"+num$(K)+"("+num$(NOL)+")")<>""
   Raz [F:AWP]
   [F:AWP]WIN    = [F:AWI]WIN
   [F:AWP]NUM    = NOL+1
   [F:AWP]NOPAR  = K
   [F:AWP]PARAM  = evalue("[M:AWI2]P"+num$(K)+"("+num$(NOL)+")")
   [F:AWP]VALEUR = evalue("[M:AWI2]V"+num$(K)+"("+num$(NOL)+")")
   Write [AWP]
   If fstat
    GOK = 0 : Call FSTA("AWP") From GLOCK : Break 2
   Endif
  Endif
 Next K
Next NOL
For NOL=0 To [M:AWI3]NBBOUT-1
 For K=1 To [M:AWI3]NBP(NOL)
  If evalue("[M:AWI3]P"+num$(K)+"("+num$(NOL)+")")<>""
   Raz [F:AWP]
   [F:AWP]WIN    = [F:AWI]WIN
   [F:AWP]NUM    = NOL+101
   [F:AWP]NOPAR  = K
   [F:AWP]PARAM  = evalue("[M:AWI3]P"+num$(K)+"("+num$(NOL)+")")
   [F:AWP]VALEUR = evalue("[M:AWI3]V"+num$(K)+"("+num$(NOL)+")")
   Write [AWP]
   If fstat
    GOK = 0 : Call FSTA("AWP") From GLOCK : Break 2
   Endif
  Endif
 Next K
Next NOL
[F:AWB] = [M:AWI4]
[F:AWB]WIN = [F:AWI]WIN
Write [AWB]
If fstat
 GOK = 0 : Call FSTA("AWB") From GLOCK
Endif
Call TEMPOFF From GESECRAN
Return

#--------------------------------------------------------#
$MODIF
Delete [AWP] Where WIN=[F:AWI]WIN
Delete [AWT] Where WIN=[F:AWI]WIN
Delete [AWB] Where WIN=[F:AWI]WIN
Gosub ECRIRE
If GLIAISON(1)<>""
 Gosub CRE_LIENS
Endif
Return

$CRE_LIENS
WNB1 = 0
For [AWT]AWT0 Where WIN=[F:AWI]WIN & ACTBOUT<>"" & !find(ACTBOUT,"STD","SPE","SPV")
 WNB1 += 1
 WLNK1(WNB1) = "ACT"+[F:AWT]ACTBOUT
Next
Read [AWB]AWB0=[F:AWI]WIN
For I=1 To [F:AWB]NBLIS
 If [F:AWB]OBJLIS(I-1)<>[F:AWI]OBJ
  WNB1 += 1
  WLNK1(WNB1) = "AOB"+[F:AWB]OBJLIS(I-1)
 Endif
Next I
For I=1 To WNB0
 If !find(WLNK0(I),WLNK1(1..WNB1))
  Delete [ALI] Where USRCOD=GLIAISON(1) & SRCOBJ=left$(WLNK0(I),3) & SRCKEY=right$(WLNK0(I),4)
&                  & DSTOBJ="AWI" & DSTKEY=[F:AWI]WIN
 Endif
Next I
For I=1 To WNB1
 If !find(WLNK1(I),WLNK0(1..WNB0))
  Raz [F:ALI]
  [F:ALI]USRCOD = GLIAISON(1)
  [F:ALI]SRCOBJ = left$(WLNK1(I),3)
  [F:ALI]SRCKEY = right$(WLNK1(I),4)
  [F:ALI]DSTOBJ = "AWI"
  [F:ALI]DSTKEY = [F:AWI]WIN
  [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
  [F:ALI]DSTTIT = 12292
  Call TEXTE([F:AWI]DES,[F:ALI]DSTDES) From OBJDIV
  [F:ALI]LNK    = "U"
  [F:ALI]INVFLG = 2
  [F:ALI]AUTFLG = 2
  [F:ALI]ENAFLG = 2
  [F:ALI]CREDAT = date$
  [F:ALI]CREUSR = GUSER
  Write [ALI]
 Endif
Next I
Return

#--------------------------------------------------------#
$AP_ANNULE
Call DEL_TRTWIN([L]CODE,nomap) From MSKDIV
Return

#--------------------------------------------------------#
$AP_CHANGE
Call DEL_TRTWIN(OCODE,nomap) From MSKDIV
Call VALIDATION(NCODE,nomap,OK)
Read [AWI]AWI0 = NCODE
Return

#--------------------------------------------------------#
$VALID
If !GIMPORT
 Read [AWI]AWI0 = CLECUR1
 If [F:AWI]MDL=2
  Call DEL_TRTWIN(CLECUR1,nomap) From MSKDIV
  Return
 Endif
 Call VALID([F:AWI]WIN,nomap,0,OK) From VALWIN
 If !OK : Return : Endif
 If [M]CNS<>""
  # Traitements WWCNSxxx, CNSxxxSTD
  Call GENTRT(nomap,[M]CNS) From ACNTRT
  # Fonction et action CONSxxx
  Call GENACT(nomap,[M]CNS) From SUBACN
 Endif
 Read [AWI]AWI0 = CLECUR1
Endif
Return

#--------------------------------------------------------#
Subprog VALIDATION(COD,APPLI,OK)
Value Char COD
Value Char APPLI
Variable Integer OK
Call VALID(COD,APPLI,0,OK) From VALWIN
End

#--------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File AWINDOW  [AWI1]
 Local File AWINPAR  [AWP1]
 Local File AWINBRO  [AWB1]
 Local File AWINBOUT [AWT1]
 Local File ATEXTE   [ATX1]
Else
 Local File =[M]DOSORG+".AWINDOW"  [AWI1]
 Local File =[M]DOSORG+".AWINPAR"  [AWP1]
 Local File =[M]DOSORG+".AWINBRO"  [AWB1]
 Local File =[M]DOSORG+".AWINBOUT" [AWT1]
 Local File =[M]DOSORG+".ATEXTE"   [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AWINDOW  [AWI2]
 Local File AWINPAR  [AWP2]
 Local File AWINBRO  [AWB2]
 Local File AWINBOUT [AWT2]
 Local File ATEXTE   [ATX2]
Else
 Local File =[M]DOSDES+".AWINDOW"  [AWI2]
 Local File =[M]DOSDES+".AWINPAR"  [AWP2]
 Local File =[M]DOSDES+".AWINBRO"  [AWB2]
 Local File =[M]DOSDES+".AWINBOUT" [AWT2]
 Local File =[M]DOSDES+".ATEXTE"   [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AWI1], [AWP1], [AWB1], [AWT1], [ATX1]
&              , [AWI2], [AWP2], [AWB2], [AWT2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [AWI2] , [AWP2] , [AWB2] , [AWT2] , [ATX2]
 Delete [AWI2] Where WIN=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWINDOW" : Goto ROLL_TR_COP
 Endif
 Delete [AWP2] Where WIN=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWINPAR" : Goto ROLL_TR_COP
 Endif
 Delete [AWB2] Where WIN=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWINBRO" : Goto ROLL_TR_COP
 Endif
 Delete [AWT2] Where WIN=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWINBOUT" : Goto ROLL_TR_COP
 Endif
 For [AWI1]AWI0 Where WIN=TABLE
  [F:AWI2] = [F:AWI1]
  Call COPTEXTE([F:AWI1]DES,[F:AWI2]DES) From OBJDIV
  If GOK<1 : Break : Endif
  For I=0 To [F:AWI1]NBMSK-1
   Call COPTEXTE([F:AWI1]INTMSK(I),[F:AWI2]INTMSK(I)) From OBJDIV
   If GOK<1 : Break 2 : Endif
  Next I
  If dim([F:AWI2]UPDUSR)>0 : [F:AWI2]UPDUSR = GUSER : Endif
  If dim([F:AWI2]UPDDAT)>0 : [F:AWI2]UPDDAT = date$ : Endif
  If dim([F:AWI2]UPDTIM)>0 : [F:AWI2]UPDTIM = time  : Endif
  Write [AWI2]
  If fstat
   GOK=0 : Call FSTA("AWI2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AWP1]AWP0 Where WIN=TABLE
  [F:AWP2] = [F:AWP1]
  Write [AWP2]
  If fstat
   GOK = 0 : Call FSTA("AWP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Read [AWB1]AWB0 = TABLE
 If !fstat
  [F:AWB2] = [F:AWB1]
  For I=0 To [F:AWB1]NBLIS-1
   Call COPTEXTE([F:AWB1]INTLIS(I),[F:AWB2]INTLIS(I)) From OBJDIV
   If GOK<1 : Break : Endif
  Next I
  Write [AWB2]
  If fstat
   GOK = 0 : Call FSTA("AWB2") From GLOCK
  Endif
 Endif
 For [AWT1]AWT0 Where WIN=TABLE
  [F:AWT2] = [F:AWT1]
  Call COPTEXTE([F:AWT1]TXTBOUT,[F:AWT2]TXTBOUT) From OBJDIV
  If GOK<1 : Break : Endif
  Write [AWT2]
  If fstat
   GOK = 0 : Call FSTA("AWT2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#--------------------------------------------------------#
$TIT
If dim(OBJET)>0 and OBJET<>""
 TIT = mess(160,133,1)-OBJET : # Visualisation fenêtre
Endif
Return

#--------------------------------------------------------#
Subprog SIMUL(OBJET)
Value Char    OBJET

Local Char    WINPROG(GLONADC)
Local Integer REPONSE
Local Integer NBBOUT , NBSPE
Local Integer OK , ETABOU(1..GNBBOU)
Local Integer I , J , K , L , ER
Local Char    A_WINDPREV(60) , PARAM(10)

If OBJET="OAWI" : End : Endif

If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif

Read [AWI]AWI0 = OBJET
Call NOMTRTWIN(OBJET,WINPROG) From MSKDIV
If [F:AWI]OBJ<>""
 Gosub OUVFIC_DERLU From ="WO"+[F:AWI]OBJ
 Gosub OUVFIC From ="WO"+[F:AWI]OBJ
Endif

A_WINDPREV = "&WIN_PREVIEW"
Call PARAM("","ECRRESOL",PARAM) From ADOVAL
L = val(PARAM)
If L=1 : # Le dossier est en basse résolution
 Call RESOLUTION(L,I,J,K) From GLOBVAR
 A_WINDPREV += ";"+num$(L)+";"+num$(I-K)+";"+num$(I)+";"+num$(J+1)
#  Chargement de A_WINDPREV pour le client convergence  MB  - 04/02/2015
#  Pour les transactions d'objet
#  Pour les transactions de consultation
Elsif [F:AWI]TRN<>"" and [F:AWI]OBJ<>"" & GFUSION
 Local File AWINDOW [AWZ2]
 #  Si il y a une fenêtre sans transaction pour ce même objet, c'est la fenêtre modèle
 Filter [AWZ2] Where OBJ=[F:AWI]OBJ and TRN=""
 For [AWZ2]
  A_WINDPREV+=";;;"+[F:AWZ2]WIN
  Break
 Next
 Filter [AWZ2]
Elsif [F:AWI]CNS<>"" and left$([F:AWI]WIN,1)="W" & GFUSION
 If clalev([F:ACN])=0 : Local File ACONSULT [ACN] : Endif
 Read [ACN]ACN0=[F:AWI]CNS
 If fstat=0 and [F:AWI]WIN<>[F:ACN]WND1
  A_WINDPREV+=";;;"+[F:ACN]WND1
 Endif
Endif

Onerrgo RIEN

If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
Call LECTURE("TCU",GSYSCUR,"") From CONTOBJ
Call LECTURE("TCY",GPAYS,"") From CONTOBJ

Onerrgo ERREUR
Gosub VISU_BOITE From =WINPROG
Onerrgo RIEN
If ER
 #Gosub OUVRE_BOITE From =WINPROG
Endif
If [F:AWI]MSKENT<>""
 MA = 0 : Gosub SETMASK From =WINPROG : Gosub TITMASK From =WINPROG
 Grizo [M]
Endif
For I=1 To [F:AWI]NBMSK
 MA = I : Gosub SETMASK From =WINPROG : Gosub TITMASK From =WINPROG
 If I>1 : Affzo [M] : Endif
 Grizo [M]
Next I

Call SAVBOUT From GESECRAN
Raz ETABOU

NBSPE = 0
For [AWT] Where WIN=[F:AWI]WIN
 If [F:AWT]TYPBOUT=1
  NBSPE += 1
 Endif
Next

Case [F:AWI]WINTYP
 When 1 , 2 : # Divers, Gobjet
  NBBOUT = 0
  For I=1 To 5
   If [F:AWI]BSTD(I-1)=2
    NBBOUT += 1
    Case I
     When 1 : ETABOU(GENRE) = 1 : # Enregistrer
     When 2 : ETABOU(GCREE) = 1 : # Créer
     When 3 : ETABOU(GSUPP) = 1 : # Supprimer
     When 4 : ETABOU(GABAN) = 1 : # Abandon
     When 5 : ETABOU(GVALI) = 1 : # OK
    Endcase
   Endif
  Next I
  If (GPRODUIT<>1 & [F:AWI]BSTD(17)=2) | (GPRODUIT=1 & [F:AWI]BSTD(18)=2)
   NBBOUT += 1
   ETABOU(GBFIN) = 1
  Endif
 When 3
  NBBOUT = 0
  For I=1 To 6
   If [F:AWI]BSTD(I-1)=2
    NBBOUT += 1
    Case I
     When 1 : ETABOU(GSPE1) = 1 : # Recherche
     When 2 : ETABOU(GSPE2) = 1 : # Critères
     When 3 : ETABOU(GSPE3) = 1 : # Retour
     When 4 : ETABOU(GSPE4) = 1 : # Suite
     When 5 : ETABOU(GSPE5) = 1 : # Dernier
    Endcase
   Endif
  Next I
  If [F:AWI]BSTD(6)=2
   NBBOUT += 1
   ETABOU(GBFIN) = 1
  Endif
 When 4
  NBBOUT = 0
  For I=1 To 2
   If [F:AWI]BSTD(I-1)=2
    NBBOUT += 1
    Case I
     When 1 : ETABOU(GVALI) = 1 : # Ok
     When 2 : ETABOU(GBFIN) = 1 : # Fin
    Endcase
   Endif
  Next I
Endcase
If !NBBOUT & NBSPE
 Assign "ETABOU(GSPE"+num$(NBSPE)+")" With 1
Endif
For I=1 To GNBBOU
 GETABOU(I) = 2
Next I
Call SETBOUT(ETABOU) From GESECRAN
If !NBSPE & !NBBOUT & [F:AWI]TYP=3 : # Sur une messbox sans bouton , adonix ne rend pas la main
 Sleep 2
Else
 zonsui = "+" : # Pour se positionner directement sur les boutons
 Gosub SAISIE_BOITE From =WINPROG
Endif

Gosub FERME_BOITE From =WINPROG
Gosub FERME_MASK From =WINPROG
Onerrgo
Call RESTBOUT From GESECRAN
End

$RIEN
Resume

$ERREUR
ER = errn
Resume

#--------------------------------------------------------------#
Subprog SIMULWEB(OBJET)
Value Char    OBJET
If GBROWS<>0
  Call SIMUL(OBJET)
Else
  Local Char URL(200),RETOUR(200),AASEP
  AASEP="/"
  If instr(1,GVIRTDIR,"\") : AASEP="\" : Endif
  URL=GVIRTDIR+AASEP+nomap+AASEP+"GEN"+AASEP+GLANGUE
  URL+=AASEP+"FENW"+AASEP+OBJET+".xml"
  URL=ctrans(URL,"\","/")
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL
Endif
End

#--------------------------------------------------------------#
Subprog VALGWIN(NOMFEN)
Variable Char    NOMFEN()

Local Integer I,OK
OK = 2
Call OUINON(mess(28,126,1)-NOMFEN,OK) From GESECRAN : # Validation fenêtre
If OK<>2 : End : Endif

Local File AWINDOW [AWI] , AWINBRO [AWB_] , AOBJET [AOB_], ACTIV [ACV_]
Read [AWI]AWI0 = NOMFEN

If [F:AWI]MDL=2
 Call DEL_TRTWIN(NOMFEN,nomap) From MSKDIV
 End
Endif

Call OUVRE_TRACE(mess(28,126,1)-NOMFEN) From LECFIC

If [F:AWI]MSKENT<>""
 Call VALID([F:AWI]MSKENT,nomap,1,GLANGUE,0,OK) From VALMSK
Endif
For I=1 To [F:AWI]NBMSK
 #109929 check activity code
 Read [ACV_]CODACT = [F:AWI]ACTMSK(I-1)
 If [F:AWI]ACTMSK(I-1)="" | (!fstat & [F:ACV_]FLACT=2)
  Call VALID([F:AWI]NOMMSK(I-1),nomap,1,GLANGUE,0,OK) From VALMSK
 Endif
Next I

If [F:AWI]OBJ<>""
 Call VALID([F:AWI]OBJ,nomap,0,OK) From VALOBJ
 # Raz du fichier derniers lus
 If clalev([F:ALS])=0 : Local File ALSTRD [ALS] : Endif
 Trbegin [ALS]
  Delete [ALS] Where OBJ=[F:AWI]OBJ
 Commit
Elsif [F:AWI]CNS<>""
 Call GENTRT(nomap,[F:AWI]CNS) From ACNTRT
 Call GENACT(nomap,[F:AWI]CNS) From SUBACN
Endif

Read [AWB_]AWB0=NOMFEN
If !fstat
 For I=1 To [F:AWB_]NBLIS
  If !find([F:AWB_]OBJLIS(I-1),"","ALI",[F:AWI]OBJ)
   Read [AOB_]ABREV=[F:AWB_]OBJLIS(I-1)
   If !fstat & [F:AOB_]TYPGES=4 : # Browsers de type "Browser"
    #109929 check activity code
    Read [ACV_]CODACT = [F:AWB_]ACTLIS(I-1)
    If [F:AWB_]ACTLIS(I-1)="" | (!fstat & [F:ACV_]FLACT=2)
     Call VALID([F:AWB_]OBJLIS(I-1),nomap,0,OK) From VALOBJ
    Endif
   Endif
  Endif
 Next I
Endif

Call VALID(NOMFEN,nomap,0,OK) From VALWIN

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

########################################
## Etiquettes masque AWI0
########################################

Subprog C_WIN(VALEUR)
Variable Char     VALEUR
End

########################################
## Etiquettes masque AWI1
########################################

Subprog C_MSKENT(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If find(VALEUR,[M]NOMMSK(0..dim([M]NOMMSK)-1))
 GMESSAGE = mess(19,124,1) : # Masque référencé dans les onglets
 mkstat = 2 : End
Endif
Call CONTROLE("AMK","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Call LECTURE("AMK",VALEUR,"") From CONTOBJ
If [F:AMK]TYPMSK<>5
 If [M:AWI1]FVT<>2 or ([M:AWI1]FVT=2 and [F:AMK]TYPMSK<>6)
  GMESSAGE = mess(189,123,1) : # Ce n'est pas un écran d'en-tête
  mkstat = 2 : End
 Endif
Endif
If [F:AMK]MDL=2 & [M:AWI1]MDL<>2
 # Ecran modèle\Les écrans modèles ne peuvent être définis que sur des fenêtres modèles
 GMESSAGE = VALEUR-":"-mess(121,133,1)+"\"+mess(7,139,1)
 mkstat = 2 : End
Endif
If  [M:AWI1]FVT=2 & [F:AMK]TYPMSK<>6
 # Seuls les ecrans VT sont autorisés sur les fenêtres VT
# GMESSAGE = mess(223,133,1)
# mkstat = 2
Endif
End

Subprog AM_MSKENT(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : Raz [F:AMK] : Endif
End

Subprog C_NOMMSK(VALEUR)
Variable Char     VALEUR
If VALEUR=[M]MSKENT
 GMESSAGE = mess(18,124,1) : # Masque référencé en en-tête
 mkstat = 2 : End
Endif
Call CONTROLE("AMK","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Call LECTURE("AMK",VALEUR,"") From CONTOBJ
If [F:AMK]MDL=2 & [M:AWI1]MDL<>2
 # Ecran modèle\Les écrans modèles ne peuvent être définis que sur des fenêtres modèles
 GMESSAGE = VALEUR-":"-mess(121,133,1)+"\"+mess(7,139,1)
 mkstat = 2 : End
Endif
Call UNICITE(VALEUR,[M]NOMMSK) From OBJDIV
If  [M:AWI1]FVT=2 & [F:AMK]TYPMSK<>6
 # Seuls les ecrans VT sont autorisés sur les fenêtres VT
 GMESSAGE = mess(223,133,1)
 mkstat = 2
Endif

End

Subprog AM_NOMMSK(VALEUR)
Variable Char     VALEUR
Local Integer OK
If VALEUR="" : Raz [F:AMK] : End : Endif
Call LECTURE("AMK",VALEUR,"") From CONTOBJ
If [M]MSKENT<>"" & [F:AMK]TYPMSK<>1 & [M]FVT<>2
 Call AVERTIR(VALEUR-":"-mess(27,139,1),OK) From GESECRAN : # Ce n'est pas un onglet
 If OK<>2
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
GMENLOC(4) = 1 : # Indépendante
End

Subprog C_TYP(VALEUR)
Variable Integer  VALEUR
Call GRISE_TYP(VALEUR)
End

Subprog AS_WINTYP(VALEUR)
Variable Integer  VALEUR
If GADONIX<>2
 GMENLOC(5) = 1 : # Sélection table
Endif
End

Subprog AM_WINTYP(VALEUR)
Value Integer VALEUR
Local Integer I
Call CHARGE_STD(VALEUR)
Case VALEUR
 When 2 : # Objet
  For I=0 To [M:AWI3]NBBOUT-1
   If I=4 | (GPRODUIT=1 & I=17) : # Bouton ok # Bouton Sélection Picking si GEODE
    [M:AWI3]BSTD(I) = 1
   Else
    [M:AWI3]BSTD(I) = 2
   Endif
  Next I
 When 3 : # Consultation
  For I=0 To [M:AWI3]NBBOUT-1
   If I=1 : # Bouton critère
    [M:AWI3]BSTD(I) = 1
   Else
    [M:AWI3]BSTD(I) = 2
   Endif
  Next I
 When 4 : # Critères consultation
  [M:AWI3]BSTD(0) = 2 : # Ok
  [M:AWI3]BSTD(1) = 2 : # Fin
 When Default
  For I=0 To [M:AWI3]NBBOUT-1
   If find(I,4,[M:AWI3]NBBOUT-1) : # Bouton ok , fin
    [M:AWI3]BSTD(I) = 2
   Else
    [M:AWI3]BSTD(I) = 1
   Endif
  Next I
Endcase
Affzo [AWI3]
End

Subprog C_WINTYP(VALEUR)
Value Integer VALEUR
Call GRISE_WINTYP(VALEUR)
End

Subprog C_OBJ(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]WINTYP=2
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
If GREP="C" & [M]WINTYP=2  & [M:AWI4]NBLIS=0 : # Ajout du browser principal sur l'objet en création
 Call LECTURE("AOB",VALEUR,"") From CONTOBJ
 [M:AWI4]NBLIS = 1
 [M:AWI4]DERLU = 2
 [M:AWI4]OBJLIS(0) = VALEUR
 [M:AWI4]INTLIS(0) = [F:AOB]LIBEL
 [M:AWI4]CLELIS(0) = [F:AOB]SELCLE
 [M:AWI4]ORDLIS(0) = [F:AOB]SELORD
 [M:AWI4]TRELIS(0) = [F:AOB]SELTREE
 [M:AWI4]CHGLIS(0) = 2
 [M:AWI4]ABRLIS(0) = ""
 [M:AWI4]ROWLIS(0) = 5
 [M:AWI4]ACTLIS(0) = ""
 [M:AWI4]FLELIS(0) = 2
 [M:AWI4]EXPLIS(0) = ""
 [M:AWI4]BROLIS(0) = 2
 Affzo [M:AWI4]
Endif
End

Subprog AS_LIBEL(VALEUR)
Variable Char    VALEUR()
If [M]TRN="" : mkstat = 1 : End : Endif
End

Subprog C_LIBEL(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,'"')
 GMESSAGE = '"'-mess(94,123,1) : # caractère interdit
 mkstat = 2 : End
Endif
End

Subprog C_CNS(VALEUR)
Variable Char     VALEUR
If VALEUR="" & ([M]WINTYP=3 | [M]WINTYP=4) & GREP<>"C" & GREP<>"D"
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 1 : End
Endif
End

########################################
## Etiquettes masque AWI2
########################################

Subprog AS_NBBOUT
Gosub AFFPAR
End

Subprog AVANT_NBBOUT
Gosub AFFPAR
End

$AFFPAR
If nolign>=1 & nolign<=[M]NBBOUT
 [M]LIG = nolign
 Gosub SETNOL
 [M]NBPAR = [M]NBP(NOL)
 For I=1 To NBPAR
  [M]PARAM(I-1)  = evalue("[M]P"+num$(I)+"("+num$(NOL)+")")
  Read [AAR]CODPAR = [M]PARAM(I-1)
  [M]VALEUR(I-1) = evalue("[M]V"+num$(I)+"("+num$(NOL)+")")
 Next I
 Affzo 40
Endif
Return

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog IB_CODBOUT
GBOUT1 = ""
If [M]TYPBOUT(nolign-1)=1 : # Bouton
 GBOUT1 = mess(129,133,1) : # Code réservé
Endif
End

Subprog C_CODBOUT(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Integer I , T , OK , TROUVE
Local Char    MENU(2) , BOUTON(1)
Case [M]TYPBOUT(NOL)
 When 1 : # Bouton
  VALEUR = left$(VALEUR,1)
  MENU   = ""
  BOUTON = VALEUR
 When 2 : # Menu
  VALEUR = left$(VALEUR,2)
  MENU   = VALEUR
  BOUTON = ""
 When 3 : # Ligne
  MENU   = left$(VALEUR,len(VALEUR)-1)
  BOUTON = right$(VALEUR,len(VALEUR))
Endcase
OK = 1
TROUVE = 0
If MENU=BOUTON
 OK = 0
 I = NOL
Else
 For I=0 To [M]NBBOUT-1
  OK = 1
  If I<>NOL
   If VALEUR=[M]CODBOUT(I)
    OK = 0
   Else
    Case [M]TYPBOUT(I)
     When 1 : # Bouton
      If [M]CODBOUT(I)=BOUTON
       OK = 0
      Endif
     When 2 : # Menu
      If [M]CODBOUT(I)=MENU
       TROUVE = 1
      Endif
     When 3 : # Ligne
      MENU2 = left$([M]CODBOUT(I),len([M]CODBOUT(I))-1)
      BOUT2 = right$([M]CODBOUT(I),len([M]CODBOUT(I)))
      If BOUT2=BOUTON
       OK = 0
      Endif
    Endcase
   Endif
  Endif
  If !OK : Break : Endif
 Next I
Endif
If !OK
 GMESSAGE = mess(29,100,1)-num$(I+1) : # Code déjà saisi en ligne
 mkstat = 2 : End
Elsif TYPBOUT(NOL)=3 & !TROUVE
 GMESSAGE = MENU-":"-mess(154,124,1) : # Menu inexistant
 mkstat = 2 : End
Endif
If VALEUR<>""
 For I=1 To len(VALEUR)
  BOUTON = mid$(VALEUR,I,1)
  If [M]TYPBOUT(NOL)=3 & I=len(VALEUR) : # Menu du haut
   OK  = (!find(BOUTON,'"',"'","<",">"))
  Else
   OK  = (BOUTON>="A" & BOUTON<="Z")
   OK += (BOUTON>="a" & BOUTON<="z")
   OK += (BOUTON>="0" & BOUTON<="9")
  Endif
  If !OK : Break : Endif
 Next I
 If !OK
  GMESSAGE = BOUTON-mess(25,126,1) : # Code incorrect
  mkstat = 2 : End
 Endif
Endif
If find([M]TYPBOUT(nolign-1),1,3) : # Bouton /Ligne
 If find([M:AWI1]WINTYP,2,3) : # Objet/Consultation; pour les autres, ça dépend si les boutons sont actifs
  T = [M:AWI1]WINTYP
  Gosub SET_BR
  If instr(1,BR,right$(VALEUR,len(VALEUR)))
   GMESSAGE = '"'+right$(VALEUR,len(VALEUR))+'":'-mess(129,133,1) : # Code réservé
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog D_VALBOUT(VALEUR)
Variable Integer  VALEUR
Local Integer K
Case [M]TYPBOUT(nolign-1)
 When 1 : # Bouton
  If [M]CODBOUT(nolign-1)>="a" & [M]CODBOUT(nolign-1)<="z"
   VALEUR = 1
  Else
   VALEUR = 2
  Endif
Endcase
End

Subprog AS_VALBOUT(VALEUR)
Variable Integer  VALEUR
Case [M]TYPBOUT(nolign-1)
 When 2 : mkstat = 1
 When 3 : VALEUR = 1 : mkstat = 2
Endcase
End

Subprog AS_ACTBOUT(VALEUR)
Variable Char    VALEUR()
If [M]TYPBOUT(nolign-1)=2
 mkstat = 1 : End
Endif
End

Subprog AM_ACTBOUT(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
[M]NBP(NOL) = 0
Local Char ACTION(GLONACT)
If VALEUR<>""
 [L]ACTION = VALEUR
 Gosub CHARGE_PAR
 While [F:ACT]ACTSUI<>""
  [L]ACTION = [F:ACT]ACTSUI
  Gosub CHARGE_PAR
 Wend
Endif
Gosub AFFPAR
End

$CHARGE_PAR
Local Integer I, OK
Read [ACT]ACTION = [L]ACTION
For [ATR]NOPAR Where ACTION=[L]ACTION
 If [F:ATR]NOPAR>1 or [F:ACT]TYPACT<>2
  OK = 1
  For I=1 To [M]NBP(NOL)
   If [F:ATR]CODPAR=evalue("[M]P"+num$(I)+"("+num$(NOL)+")")
    OK = 0
   Endif
  Next I
  If OK
   [M]NBP(NOL) += 1
   Assign"[M]P"+num$([M]NBP(NOL))+"("+num$(NOL)+")" With [F:ATR]CODPAR
  Endif
 Endif
Next
Return

Subprog AM_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
If [M]LIG>0 & [M]LIG<=[M]NBBOUT
 Assign "[M]V"+num$(NOL+1)+"("+num$([M]LIG-1)+")" With VALEUR
Endif
End

Subprog IB_VALEUR
If [M]LIG<=0 | [M]ACTBOUT([M]LIG-1)<>"MEMO" | nolign<>2
 GBOUTS = ""
 GBOUT1 = ""
Endif
End

Subprog C_VALEUR(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If [M]LIG<=0 | [M]ACTBOUT([M]LIG-1)<>"MEMO" | nolign<>2 | VALEUR=""
 End
Endif
If clalev([F:AMM])=0 : Local File AMEMO : Endif
Gosub TRANSVAL
If len(NEWVAL)>type([F:AMM]MEMO)-10
 Call ERREUR(NEWVAL-":"-mess(23,100,1)) From GESECRAN : # Fiche inexistante
 mkstat = 1 : End
Endif
Call CONTROLE("AMM","",NEWVAL,"",mkstat) From CONTOBJ
End

Subprog B1_VALEUR(VALEUR)
Variable Char    VALEUR()
Gosub TRANSVAL
Call OBJET_CHAR(NEWVAL,"AMM","") From GOBJET
[L]VALEUR = '"'+NEWVAL+'"'
End

Subprog S_VALEUR(VALEUR)
Variable Char VALEUR()
Local Char PARAM(255)(1..20)
Gosub TRANSVAL
Call S_TAB_CHAR(NEWVAL,PARAM,"","SUBAWI","") From GACTION
[L]VALEUR = '"'+NEWVAL+'"'
End

$SEL_TABLE
Local Char CAR(1)
OBJET = "AMM"
Return

$TRANSVAL
Local Char NEWVAL(30)
Local Integer I
NEWVAL = [L]VALEUR
I = instr(1,NEWVAL,"~")
If I
 NEWVAL = right$(NEWVAL,I+1)
Endif
For CAR="'",'"'
 For I=1 To len([L]NEWVAL)
  If mid$([L]NEWVAL,I,1)=CAR
   [L]NEWVAL = left$([L]NEWVAL,I-1)+right$([L]NEWVAL,I+1)
  Endif
 Next I
Next CAR
Return

