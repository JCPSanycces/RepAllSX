## Etiquettes masque AWI3
########################################

Subprog AS_BSTD(VALEUR)
Value Integer VALEUR
End

Subprog AS_ACTSTD(VALEUR)
Variable Char    VALEUR()
If [M]BSTD(nolign-1)<>2
 mkstat = 1 : End
Elsif find([M]WINTYP,5)
 mkstat = 1 : End
Endif
End

Subprog AM_ACTSTD(VALEUR)
Variable Char    VALEUR()
Gosub     SETNOL
[M]NBP(NOL) = 0
Local Char ACTION(GLONACT)
If VALEUR<>""
 [L]ACTION = VALEUR
 Gosub CHARGE_PAR
 While [F:ACT]ACTSUI<>""
  [L]ACTION = [F:ACT]ACTSUI
  Gosub CHARGE_PAR
 Wend
Endif
End

########################################
## Etiquettes masque AWI4
########################################

Subprog AS_DERLU(VALEUR)
Variable Integer VALEUR()
If [M]OBJ<>""
 Read [AOB]ABREV = [M]OBJ
 Read [AOL]AOL0  = [M]OBJ
 If [F:AOL]NBSEL=0 | [F:AOB]TYPGES=2 | sum([F:AOL]SELFIC(0..[F:AOL]NBSEL-1))=""
  VALEUR = 1 : mkstat = 2
 Endif
Else
 VALEUR = 1 : mkstat = 2
Endif
End

Subprog AS_FIRLIS(VALEUR)
Variable Integer VALEUR()
If [M]DERLU<>2
 VALEUR = 1 : mkstat = 2 : End
Endif
End

Subprog AS_OBJLIS(VALEUR)
Variable Char    VALEUR()
If [M]NBLIS=0 & [M]OBJ<>""
 Read [AOB]ABREV=[M]OBJ
 If !fstat & find([F:AOB]TYPGES,1,3)
  VALEUR = [M]OBJ
 Endif
Endif
End

Subprog C_OBJLIS(VALEUR)
Variable Char    VALEUR()
Read [AOB]ABREV = VALEUR
Read [AOL]AOL0  = VALEUR
If [F:AOB]TYPGES=2
 GMESSAGE = VALEUR-mess(71,126,1) : # Liste de gauche impossible avec cet objet
 mkstat = 2 : End
Elsif [F:AOL]NBSEL=0
 GMESSAGE = VALEUR-mess(156,123,1) : # Le nombre de zones de sélection est nul
Endif
#Call UNICITE(VALEUR,[M]OBJLIS) From OBJDIV
End

Subprog D_ZINTLIS(VALEUR)
Variable Char    VALEUR()
Read [AOB]ABREV = [M]OBJLIS(nolign-1)
Call TEXTE([F:AOB]LIBEL,VALEUR) From OBJDIV
End

Subprog D_CLELIS(VALEUR)
Variable Char    VALEUR()
Read [AOB]ABREV = [M]OBJLIS(nolign-1)
VALEUR = [F:AOB]SELCLE
End

Subprog AS_CLELIS(VALEUR)
Variable Char     VALEUR
Read [AOB]ABREV = [M]OBJLIS(nolign-1)
[M]FICLIS = [F:AOB]NOMFIC
End

Subprog D_ORDLIS(VALEUR)
Variable Integer VALEUR()
Read [AOB]ABREV = [M]OBJLIS(nolign-1)
VALEUR = [F:AOB]SELORD
End

Subprog D_TRELIS(VALEUR)
Variable Integer VALEUR()
Read [AOB]ABREV = [M]OBJLIS(nolign-1)
VALEUR = [F:AOB]SELTREE
End

Subprog C_TRELIS(VALEUR)
Variable Integer VALEUR
Local Integer OK
Read [AOB]ABREV = [M]OBJLIS(nolign-1)
Read [AOL]AOL0  = [M]OBJLIS(nolign-1)
Gosub SETCLE
OK = 1
If find(VALEUR,2,3) & NCLE>[F:AOL]NBSEL & [M]OBJLIS(nolign-1)<>"ALI" : # Liste hiérachisée
 OK = 0
Endif
If !OK
 GMESSAGE = [M]OBJLIS(nolign-1)-mess(73,126,1) : # Champs de sélection incompatibles avec l'index
 mkstat = 2
Endif
End

Subprog AS_CHGLIS(VALEUR)
Variable Integer VALEUR()
If [M]OBJLIS(nolign-1)=[M]OBJ
 VALEUR = 2 : mkstat = 2
Endif
End

Subprog AS_ROWLIS(VALEUR)
Variable Decimal VALEUR()
If VALEUR=0
 If nolign=1
  VALEUR = 5
 Else
  VALEUR = [M]ROWLIS(nolign-2)+5
 Endif
Endif
End

Subprog AS_BROLIS(VALEUR)
Variable Integer VALEUR()
If find([M]TRELIS(nolign-1),3,5) : # Piking/Piking simple
 VALEUR = 1 : mkstat = 1
Elsif [M]OBJLIS(nolign-1)=[M]OBJ
 VALEUR = 2 : mkstat = 2
Endif
End

Subprog C_BROLIS(VALEUR)
Variable Integer VALEUR
End

Subprog AS_EXPLIS(VALEUR)
Variable Char    VALEUR()
If [M]TRELIS(nolign-1)<>4 : mkstat = 2 : End : Endif
End

Subprog C_EXPLIS(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End

Subprog D_FLELIS(VALEUR)
Variable Integer  VALEUR
If [M]CHGLIS(nolign-1)=3 | [M]OBJLIS(nolign-1)="ALI" : # Chargement complet
 VALEUR = 1 : # Pas de flêches
Else
 VALEUR = 2
Endif
End

Subprog AS_ROWMSK(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 If nolign=1
  VALEUR = 5
 Else
  VALEUR = [M]ROWMSK(nolign-2)+5
 Endif
Endif
End

Subprog AS_FLGMSK(VALEUR)
Variable Integer VALEUR
If VALEUR<1 or VALEUR>2
 VALEUR = 2
Endif
End

Subprog AV_AFLBRO(VALEUR)
Variable Integer VALEUR
#  Est-on en haute résolution sur ce dossier ?
Local Char PARHR
Local Integer RESOL
Call PARAM("","ECRRESOL",PARHR) From ADOVAL
RESOL = val(PARHR)
If RESOL=2 : Diszo AFLBRO : End : Endif
If [M]DERLU=1 and [M]NBLIS=0
  Diszo AFLBRO
Else
  Actzo AFLBRO
Endif
End

Subprog APRES_NBLIS
Local Char PARHR
Local Integer RESOL
Call PARAM("","ECRRESOL",PARHR) From ADOVAL
RESOL = val(PARHR)
If RESOL=2 : Diszo AFLBRO : End : Endif
If [M]OBJLIS(0)<>""
  Actzo AFLBRO
Else
  Diszo AFLBRO
Endif
End

Subprog AP_FVT(VALEUR)
Variable Integer VALEUR
#If VALEUR=2
#  [M]MSKENT="AVTENT"
#  Diszo MSKENT
#  Affzo MSKENT
#Else
#  Actzo MSKENT
#Endif
End

Subprog C_ABRLIS(VALEUR)
Variable Char     VALEUR
Local Char    TABLE(GLONATB)
Local Integer I , OK
If VALEUR<>""
 Call UNICITE(VALEUR,[M]ABRLIS) From OBJDIV
 If mkstat : End : Endif
Endif
If VALEUR=""
 Read [AOB]ABREV=[M]OBJLIS(nolign-1)
 If !fstat & [F:AOB]NOMFIC<>""
  TABLE = [F:AOB]NOMFIC
  NB = 0
  For I=1 To dim([M]ABRLIS)
   If I<>nolign & [M]OBJLIS(I-1)<>"" & [M]ABRLIS(I-1)=""
    Read [AOB]ABREV = [M]OBJLIS(I-1)
    If !fstat & [F:AOB]NOMFIC<>"" & [F:AOB]NOMFIC=TABLE
     # Plusieurs browsers utilisent la même table principale $1$.
     # Pour éviter des conflits, vous devez renseigner une abréviation pour cette liste
     Call AVERTIR(func AFNC.MES1(mess(84,143,1),TABLE)+"\"+mess(85,143,1),OK) From GESECRAN
     If OK<>2 : mkstat = 1 : Endif
     Break
    Endif
   Endif
  Next I
 Endif
Endif
End


