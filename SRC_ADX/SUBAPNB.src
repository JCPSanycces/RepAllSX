#<AdxTL>@(#)9.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SEL_CODMENS" : Gosub SEL_MEN
 When "C_OPTIONS"   : Gosub C_OPTIONS
Endcase
Return

##################################################################
## Sélection des options
##################################################################
$SEL_MEN
Case ACTION
 When "SEL_CODMENS" : Gosub SEL_OPTIONS
Endcase
Return

$SEL_OPTIONS
Case [M]FONCTION
 When "GESGAC"
  OBJET = "COA"
 When "GESCCE"
  OBJET = "DIE"
Endcase
Return

$C_OPTIONS
Case [M]FONCTION
 When "GESGAC"
  If clalev([F:COA])=0 : Local File GCOA [COA] : Endif
  Read [COA]COA0 = VALEUR
  If fstat
   ## Plan de compte inexistant
   GMESSAGE = mess(110,102,1)
   mkstat = 2 : End
  Endif
 When "GESCCE"
  If clalev([F:DIE])=0 : Local File GDIE [DIE] : Endif
  Read [DIE]DIE0 = VALEUR
  If fstat
   ## Axe inexistant
   GMESSAGE = mess(80,103,1)
   mkstat = 2 : End
  Endif
Endcase
Return



