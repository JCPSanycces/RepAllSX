# Classe CONTEXT

###############
# CLASS
###############
$METHODS
  Case CURPTH
    When Default
  Endcase
Return


###############
# PROPERTIES
###############
$PROPERTIES
  Case CURPRO
    When "ENDCURFIY" : Gosub ENDCURFIY
    When "ENDCURPER" : Gosub ENDCURPER
    When Default
  Endcase
Return

# Date de fin d'exercice courant
$ENDCURFIY
  Case ACTION
    When "GET" : Gosub ENDCURFIY_GET
  Endcase
Return

$ENDCURFIY_GET
  Local File FISCYEAR [FIS]

  # Reading current fiscal year
  Read [F:FIS]FIY1=this.CNX.CPY;this.CNX.CNX;2
  If fstat : Raz [F:FIS] : Endif

  this.ENDCURFIY = [F:FIS]DATENDFIY
Return

# Date de fin de péride courante de l'exercice courant
$ENDCURPER
  Case ACTION
    When "GET" : Gosub ENDCURPER_GET
  Endcase
Return

$ENDCURPER_GET
  Local File FISCYEAR [FIS]

  # Reading current fiscal year
  Read [F:FIS]FIY1=this.CNX.CPY;this.CNX.CNX;2
  If fstat : Raz [F:FIS] : Endif

  this.ENDCURPER = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
Return

