#<AdxTL>@(#)6.0.0.0 $Revision$
#########################################################################
# Pour exécution hors intégration de patch
#########################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE(mess(546, 196, 2)) From LECFIC
 Call FBPAINV(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

#########################################################################

#####################################################################################################################
# Alimentation du champs BPAINV de la table BPCUSTOMER pour la population des prospects    Module CRM    22/02/2002 #
#                                                                                                                   #
# Moulinette associée à la résolution du bug n°12927                                                                #
#                                                                                                                   #
#####################################################################################################################

Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

Read [ADS] DOSSIER=APPLI
If fstat
    Raz [F:ADS]
    End
Endif

If [F:ADS]MODULE(8) <> 2 : End : Endif

Call FBPAINV(APPLI)

End

#######################################################################
Subprog FBPAINV(SZAPPLI)
Value Char SZAPPLI

Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Call ECR_TRACE(mess(547, 196, 2) + SZAPPLI,0) From GESECRAN  #Début de l'alimentation du code adresse prospect
Call ECR_TRACE("--------------------------------------",0) From GESECRAN

If !clalev([F:BPC]) : Local File =SZAPPLI+".BPCUSTOMER" [BPC] : Endif
If !clalev([F:BPR]) : Local File =SZAPPLI+".BPARTNER" [BPR] : Endif

Local Integer ITER
Local Integer IPERF
Local Integer IPBL    #Statut d'erreur
Local Integer INTR
Local Char SZCLE
Local Integer ICLECOUNT
Local Integer ICUT
IPERF = 0
IPBL = 0
INTR = 0
ITER = 1
SZCLE = ""
ICUT = 1750
ICLECOUNT = ICUT

#Alimentation sur la base des représentants principaux
While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [BPC] Where [F:BPC]BPCTYP = 4 and [F:BPC]BPCNUM > SZCLE Order By [F:BPC]BPCNUM Asc

    For [BPC]
        SZCLE = [F:BPC]BPCNUM

        If IPERF = 0
            If !INTR
                Call DEBTRANS From GLOCK 
                Trbegin [BPC]
                INTR = 1
            Endif
        Endif

        Read [BPR] BPR0 = [F:BPC]BPCNUM
        If !fstat
            [F:BPC]BPAINV = [F:BPR]BPAADD
            Rewrite [BPC]
            If fstat
                #Erreur lors de l'enregistrement du prospect :  XXXXX
                Call ECR_TRACE(mess(550, 196, 2) + [F:BPC]BPCNUM,1) From GESECRAN
                IPBL = 1
                INTR = 0
                Rollback
                Break
            Else
                If IPERF >= 500
                    Commit
                    Call DEBTRANS From GLOCK 
                    Trbegin [BPC]
                    INTR = 1
                    IPERF = 1
                Else
                    IPERF += 1
                Endif
            Endif
        Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif

        If IPBL : Break : Endif
    Next

    Filter [BPC]

    If IPBL : Break : Endif
Wend

If IPBL
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TRACE(mess(549, 196, 2),0) From GESECRAN  #Alimentation des secteurs de marchés terminée sur erreur.
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    End
Endif

If INTR
    If !IPBL
        Commit
    Endif
Endif


Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Call ECR_TRACE(mess(548, 196, 2) + SZAPPLI,0) From GESECRAN  #Fin de l'alimentation des codes adresse prospect
Call ECR_TRACE("--------------------------------------",0) From GESECRAN

End


#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

If [F:ADS]MODULE(8) <> 2 : End : Endif
Call FBPAINV(APPLI)
End



