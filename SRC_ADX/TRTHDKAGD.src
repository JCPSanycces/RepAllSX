##########################################################################################################
Subprog GET_CHRONO_ITI(ILIGNE, SCHRONO)
Variable Integer ILIGNE
Variable Char SCHRONO

Local Integer NI
Local Integer NBEGIN
Local Integer NFOUND
Local Integer NTYPN1

  # FGR 11/07/2011 : X3SUIVI74817
  If [M:HDK2]NBLIGITN = 0 Then
    ILIGNE = -1
    Raz SCHRONO
  Else
    NBEGIN = ILIGNE + 1
    If NBEGIN > [M:HDK2]NBLIGITN-1 Then
      ILIGNE = -1
      Raz SCHRONO
    Else
      Local File ATABDIV [ADI]
      NFOUND = 0
      For NI = NBEGIN To [M:HDK2]NBLIGITN-1
        Read [ADI]CODE=407;[M:HDK2]TYP(NI)
        If !fstat Then
          NTYPN1 = [F:ADI]N1
        Else
          NTYPN1 = 1
        Endif
        If NTYPN1 = 2 Then
          ILIGNE = NI
          SCHRONO = [M:HDK2]ITNNUM(ILIGNE)
          NFOUND = 1
          Break
        Endif
      Next NI
      If NFOUND = 0 Then
        ILIGNE = -1
        Raz SCHRONO
      Endif
    Endif
  Endif
End

