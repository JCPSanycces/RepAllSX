Return

##########################################################################################################
$LOAD_SRE
  Gosub VAR_PE_HDKAGD  # FGR 02/03/2010 : X3SUIVI62968

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM) # FGR 17/02/2010 : X3SUIVI62624 pas (20)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZRECHERCHE(100)
Local Integer IBNONVIDE
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZVALEUR (250)

  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZRECHERCHE
  IBNONVIDE = 0
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZVALEUR
  Effzo [M:HDK1]20
  [M:HDK1]NBLIGSRE = 0
  # find
  SZWHERE(ILIGNEWHERE) = SZAND - "([F:SRE]SREASS<>5)"
  ILIGNEWHERE += 1
  SZAND = " AND "
  If GAUSHDKB <> 2 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:SRE]SREASS<>1)"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:HDK1]HDKQUEUE <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:SRE]SREASS=3 and [F:SRE]SREDET=[M:HDK1]HDKQUEUE)"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Else
    If [M:HDK0]HDKCOL <> "" Then
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:SRE]SREASS=2 and [F:SRE]SREDET=[M:HDK0]HDKCOL)"
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
  Endif
  If [M:HDK1]HDKSAT <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:SRE]SRESAT=[M:HDK1]HDKSAT)"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:HDK1]HDKGRALEV <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:SRE]SREGRALEV=[M:HDK1]HDKGRALEV)"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  # FGR 06/05/2009 Il n'y avait pas de dates sur les SRE (début)
  If [M:HDK0]DATMIN <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:SRE]CREDAT>=[M:HDK0]DATMIN"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:HDK0]DATMAX <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:SRE]CREDAT<=[M:HDK0]DATMAX"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  # FGR 06/05/2009 Il n'y avait pas de dates sur les SRE (fin)
  #
  SZCNTHDKAGD = "SERREQUEST"        # FGR 17/02/2010 : X3SUIVI62624
  Gosub PE_HDKAGD From TRTCRMPE     # FGR 17/02/2010 : X3SUIVI62624
  # FGR 14/01/2009 : X3SUIVI48957 (debut)
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  # FGR 14/01/2009 : X3SUIVI48957 (debut)
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "SRE") From CRMUTIL150  # FGR 24/04/2009 : X3SUIVI54295 : utilisation rôles normalisée
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [SRE] Where evalue(SZWHERE) Order By [F:SRE]CREDAT Desc; [F:SRE]CREHOU Desc
  Else
    Filter [SRE] Order By [F:SRE]CREDAT Desc; [F:SRE]CREHOU Desc
  Endif
  #Remplit le tableau
  ILIGNE = [M:HDK1]NBLIGSRE
  For [SRE]
    If ILIGNE = dim([M:HDK1]SREDATOPG)-1 Then
      Break
    Endif
    #Transclass Demandes de service
    nolign = ILIGNE + 1
    [M:HDK1] = [F:SRE]
    [M:HDK1]SREDATOPG(ILIGNE) = [F:SRE]CREDAT
    [M:HDK1]CREHOU(ILIGNE) = [F:SRE]CREHOU
    [M:HDK1]SRESAT(ILIGNE) = [F:SRE]SRESAT
    Call GET_LIB(422, [F:SRE]SRESAT, SZVALEUR) From CRM_UTIL
    [M:HDK1]SRESATCLA(ILIGNE) = SZVALEUR
    [M:HDK1]SREGRALEV(ILIGNE) = [F:SRE]SREGRALEV
    Call GET_LIB(428, [F:SRE]SREGRALEV, SZVALEUR) From CRM_UTIL
    [M:HDK1]GRALEVCLA(ILIGNE) = SZVALEUR
    [M:HDK1]SRERESDAT(ILIGNE) = [F:SRE]SRERESDAT
    [M:HDK1]SRERESHOU(ILIGNE) = [F:SRE]SRERESHOU
    [M:HDK1]SREBPC(ILIGNE)=[F:SRE]SREBPC
    Raz SZVALEUR
    If [F:SRE]SREBPC <> "" Then
      Read [BPR]BPR0=[F:SRE]SREBPC
      If fstat Then
        SZVALEUR = [F:SRE]SREBPC
      Else
        SZVALEUR = [F:BPR]BPRNAM
      Endif
    Endif
    [M:HDK1]SREBPCNAM(ILIGNE) = SZVALEUR
    Raz SZVALEUR
    [M:HDK1]SRECCN = [F:SRE]SRECCN
    If [F:SRE]SRECCN <> "" Then
      Read [AIN]AIN0=[F:SRE]SRECCN
      If fstat Then
        SZVALEUR = [F:SRE]SRECCN
      Else
        Call BUILDFULNAM("AIN", SZVALEUR) From CRMUTIL140
      Endif
    Endif
    [M:HDK1]SRECCNNAM(ILIGNE) = SZVALEUR  # FGR 18/11/2010 : X3SUIVI69047 manque (ILIGNE) et c'est SZVALEUR pas [F:SRE]SRECCN
    [M:HDK1]SRETTR(ILIGNE) = [F:SRE]SRETTR
    #Affichage du parc par défaut
    If [F:SRE]SREMAC = "" Then
      [M:HDK1]SREMACDES(ILIGNE) = ""
    Else
      Read [MAC]MAC0=[F:SRE]SREMAC
      If fstat Then
        [M:HDK1]SREMACDES(ILIGNE) = ""
      Else
        #Call LECTEXTRA([M:HDK1]SREMACDES(ILIGNE), "ITMMASTER", "DES1AXX", [F:MAC]MACPDTCOD, "") From ATEXTRA
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:MAC]MACPDTCOD,[M:HDK1]SREMACDES(ILIGNE), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      Endif
    Endif
    #Affichage de la famille de compétence globale
    If [F:SRE]SREPBLGRP = "" Then
      [M:HDK1]SREPBLGRP(ILIGNE) = ""
    Else
      Read [PBL]PBL0=[F:SRE]SREPBLGRP
      If fstat Then
        [M:HDK1]SREPBLGRP(ILIGNE) = ""
      Else
        # FGR 23/09/2009 : X3SUIVI58024
        #[M:HDK1]SREPBLGRP(ILIGNE) = [F:PBL]GRPPBLDES
        Call LECTEXTRA([M:HDK1]SREPBLGRP(ILIGNE),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      Endif
    Endif
    [M:HDK1]OVRCOV(ILIGNE) = [F:SRE]OVRCOV
    #Escalades
    [M:HDK1]SREESC(ILIGNE) = [F:SRE]SREESC
    Gosub LOADSREESC
    [M:HDK1]SRENUM(ILIGNE) = [F:SRE]SRENUM
    [M:HDK1]SALFCY(ILIGNE) = [F:SRE]SALFCY
    [M:HDK1]SRENUMBPC(ILIGNE) = [F:SRE]SRENUMBPC
    [M:HDK1]SREASS(ILIGNE) = [F:SRE]SREASS
    [M:HDK1]SREDET(ILIGNE) = [F:SRE]SREDET
    Case [M:HDK1]SREASS(ILIGNE)
      When 1
        Read [FCY]FCY0=[M:HDK1]SREDET(ILIGNE)
        If fstat Then
          [M:HDK1]SREDETNAM(ILIGNE) = [M:HDK1]SREDET(ILIGNE)
        Else
          [M:HDK1]SREDETNAM(ILIGNE) = [F:FCY]FCYNAM
        Endif
      When 2
        Read [AUS]CODUSR=[M:HDK1]SREDET(ILIGNE)
        If fstat Then
          [M:HDK1]SREDETNAM(ILIGNE) = [M:HDK1]SREDET(ILIGNE)
        Else
          [M:HDK1]SREDETNAM(ILIGNE) = [F:AUS]NOMUSR
        Endif
      When 3
        Read [QUE]QUE0=[M:HDK1]SREDET(ILIGNE)
        If fstat Then
          [M:HDK1]SREDETNAM(ILIGNE) = [M:SRE2]SREDET
        Else
          # FGR 23/09/2009 : X3SUIVI58037
          #[M:HDK1]SREDETNAM(ILIGNE) = [F:QUE]TTR
          Call LECTEXTRA([M:HDK1]SREDETNAM(ILIGNE),"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
        Endif
      When Default
        [M:HDK1]SREDETNAM(ILIGNE) = ""
   Endcase
   ILIGNE += 1
  Next
  Filter [SRE]
  [M:HDK1]NBLIGSRE = ILIGNE
  Affzo [M:HDK1]1-99
Return

##########################################################################################################
# Chargement des informations relatives aux escalades.
$LOADSREESC
  Filter [ECE] Where [F:ECE]SRENUM = [F:SRE]SRENUM Order By [F:ECE]ESCDAT Desc; [F:ECE]ESCHOU Desc
  For [ECE] Hint Key ECE1
    [M:HDK1]SREESCCOD(ILIGNE) = [F:ECE]ESCCOD  # FGR 06/05/2009 : Ajout du bouton "Historique escalades"
    [M:HDK1]SREESCNUM(ILIGNE) = [F:ECE]ESCNUM
    [M:HDK1]SREESCCAT(ILIGNE) = [F:ECE]ESCCAT
    Call GET_LIB(453, [F:ECE]ESCCAT, [M:HDK1]ESCCATCLA(ILIGNE)) From CRM_UTIL
    [M:HDK1]SREESCDAT(ILIGNE) = [F:ECE]ESCDAT
    [M:HDK1]SREESCHOU(ILIGNE) = [F:ECE]ESCHOU
    [M:HDK1]SREESCTYP(ILIGNE) = [F:ECE]ESCTYP
    If [F:ECE]ESCTYP > 1 Then
      [M:HDK1]ESCTYPCLA(ILIGNE) = mess([F:ECE]ESCTYP,3028,1)
    Else
      Raz [M:HDK1]ESCTYPCLA(ILIGNE)
    Endif
    Break
  Next
  Filter [ECE]
Return

##########################################################################################################
# LOADITN : Charge les interventions
#####################################################################################
$LOAD_ITN
  Gosub VAR_PE_HDKAGD  # FGR 02/03/2010 : X3SUIVI62968

Local Char CSTHEUREDEB
Local Char CSTHEUREFIN
Local Char SZROLE (250)
Local Char SZWHERE(250)(IFILTDIM) # FGR 17/02/2010 : X3SUIVI62624 pas (20)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZRECHERCHE (100)
Local Char SZLIBELLE(250)
Local Char SZCODE
Local Integer IBNONVIDE
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZVALEUR (250)

  CSTHEUREDEB = "0800"
  CSTHEUREFIN = "1800"
  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZRECHERCHE
  Raz SZLIBELLE
  Raz SZCODE
  IBNONVIDE = 0
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZVALEUR

  Local Mask HDKAGD2 [HDKW]
  Effzo [M:HDK2]20
  [M:HDK2]NBLIGITN = 0
  Effzo [M:HDKW]
  [M:HDKW]NBLIGITN = 0
  [M:HDKW]HDKITNTYP = [M:HDK2]HDKITNTYP
  [M:HDKW]ITNSCO = [M:HDK2]ITNSCO
  If [M:HDK0]HDKCOL <> "" Then
    If [M:HDK2]ITNSCO <> 2 Then
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:ITN]REP=[M:HDK0]HDKCOL) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Else
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:ITN]REP=[M:HDK0]HDKCOL or [F:ITN]SCO=2) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
  Else
    If [M:HDK2]ITNSCO = 2 Then
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:ITN]SCO=2) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
  Endif
  If [M:HDK2]HDKITNTYP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:ITN]TYP=[M:HDK2]HDKITNTYP) "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:HDK0]DATMIN <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:ITN]DATX<>[00/00/00] and [F:ITN]DATX>=[M:HDK0]DATMIN) "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:HDK0]DATMAX <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:ITN]DATX<>[00/00/00] and [F:ITN]DATX<=[M:HDK0]DATMAX) "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  #
  SZCNTHDKAGD = "AGDITN"            # FGR 17/02/2010 : X3SUIVI62624
  Gosub PE_HDKAGD From TRTCRMPE     # FGR 17/02/2010 : X3SUIVI62624
  # FGR 14/01/2009 : X3SUIVI48957 (debut)
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  # FGR 14/01/2009 : X3SUIVI48957 (fin)
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "ITN") From CRMUTIL150  # FGR 24/04/2009 : X3SUIVI54295 : utilisation rôles normalisée
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [ITN] Where evalue(SZWHERE) Order By [F:ITN]DATX Desc; [F:ITN]HOU Desc
  Else
    Filter [ITN] Order By [F:ITN]DATX Desc; [F:ITN]HOU Desc
  Endif
  ILIGNE = [M:HDKW]NBLIGITN
  For [ITN] Hint Key ITN1
    If ILIGNE >= dim([M:HDKW]ITNNUM)-1 Then
      Break
    Endif
    If [F:ITN]NUM <> "" Then
      IBCONTINUE = 1
      IBGENEREITN = 0
      IBDATEFINOK = 1
      If [F:ITN]DAT = [00/00/00] Then
        DTDATEDEB = [F:ITN]DATX
      Else
        DTDATEDEB = [F:ITN]DAT
      Endif
      SZHOURDEB = [F:ITN]HOU
      DTDATEFIN = [F:ITN]DATEND
      SZHOURFIN = [F:ITN]HOUEND
      If DTDATEFIN = [00/00/00] Then
        DTDATEFIN = DTDATEDEB
        IBDATEFINOK = 0
      Endif
      While IBCONTINUE = 1
        If ILIGNE>= dim([M:HDKW]ITNNUM)-1 Then
          Break
        Endif
        If DTDATEDEB <> [F:ITN]DATEND and IBDATEFINOK = 1 Then
          DTDATEFIN = DTDATEDEB
          SZHOURFIN = CSTHEUREFIN
        Else
          DTDATEFIN = DTDATEDEB
          SZHOURFIN = [F:ITN]HOUEND
          IBCONTINUE = 0
        Endif
        nolign = ILIGNE + 1
        [M:HDKW] = [F:ITN]
        #
        [M:HDKW]ADD0(ILIGNE) = [F:ITN]ADD(0)
        #
        [M:HDKW]ITNNUM(ILIGNE) = [F:ITN]NUM
        [M:HDKW]OBJET(ILIGNE) = "ITN"
        [M:HDKW]SEMAINE(ILIGNE) = num$(week(DTDATEDEB))
        [M:HDKW]DATDEB(ILIGNE) = DTDATEDEB
        Call CONVDI(DTDATEDEB, SZVALEUR) From CRMUTIL150
        [M:HDKW]DATDEBINT(ILIGNE) = SZVALEUR
        [M:HDKW]HEURDEB(ILIGNE) = SZHOURDEB
        [M:HDKW]DATFIN(ILIGNE) = DTDATEFIN
        Call CONVDI(DTDATEFIN, SZVALEUR) From CRMUTIL150
        [M:HDKW]DATFININT(ILIGNE) = SZVALEUR
        [M:HDKW]HEURFIN(ILIGNE) = SZHOURFIN
        [M:HDKW]TYPACT(ILIGNE) = 1
        [M:HDKW]EXE(ILIGNE) = [F:ITN]DON
        SZVALEUR = left$([F:ITN]OBJ, 250)
        If SZVALEUR<> "" Then
          Call REMOVECHAR(chr$(10), SZVALEUR) From CRMUTIL140
          Call REMOVECHAR(chr$(13), SZVALEUR) From CRMUTIL140
        Endif
        [M:HDKW]INFOS(ILIGNE) = SZVALEUR
        Raz SZVALEUR
        [M:HDKW]TYP(ILIGNE) = [F:ITN]TYP
        If [M:HDKW]TYP(ILIGNE) <> "" Then
          Call GET_LIB(407, [M:HDKW]TYP(ILIGNE), SZVALEUR) From CRM_UTIL
        Endif
        [M:HDKW]TYPNAM(ILIGNE) = SZVALEUR
        [M:HDKW]BPC(ILIGNE) = [F:ITN]BPC
        SZCODE = [M:HDKW]BPC(ILIGNE)
        If [M:HDKW]BPC(ILIGNE) <> "" Then
          Read [BPR]BPR0=[M:HDKW]BPC(ILIGNE)
          If fstat <> 0 Then
            [M:HDKW]BPCNAM(ILIGNE) = [F:ITN]BPC
            SZLIBELLE = ""
          Else
            [M:HDKW]BPCNAM(ILIGNE) = [F:BPR]BPRNAM
            SZLIBELLE = [F:BPR]BPRNAM
          Endif
        Else
          SZLIBELLE = ""
        Endif
        Call CRMAFFAGD (SZCODE, SZLIBELLE, [M:HDKW]LIBBPRAGD(ILIGNE)) From CRMUTIL150
        [M:HDKW]CCN(ILIGNE) = [F:ITN]CCN
        SZCODE = [M:HDKW]CCN(ILIGNE)
        If [M:HDKW]CCN(ILIGNE) <> "" Then
          Read [AIN]AIN0=[M:HDKW]CCN(ILIGNE)
          If fstat Then
            [M:HDKW]CCNNAM(ILIGNE) = [M:HDKW]CCN(ILIGNE)
            SZLIBELLE = ""
          Else
            Call BUILDFULNAM("AIN", [M:HDKW]CCNNAM(ILIGNE)) From CRMUTIL140
            SZLIBELLE = [M:HDKW]CCNNAM(ILIGNE)
          Endif
        Else
          [M:HDKW]CCNNAM(ILIGNE) = ""
          SZLIBELLE = ""
        Endif
        Call CRMAFFAGD(SZCODE, SZLIBELLE , [M:HDKW]LIBCCNAGD(ILIGNE)) From CRMUTIL150
        [M:HDKW]SCO(ILIGNE) = [F:ITN]SCO
        If [M:HDKW]SCO(ILIGNE) <> 2 Then
          Read [AUS]CODUSR=[F:ITN]REP
          If fstat Then
            [M:HDKW]COLNAM(ILIGNE) = [F:ITN]REP
          Else
            [M:HDKW]COLNAM(ILIGNE) = [F:AUS]NOMUSR
          Endif
        Else
          Read [BPR]BPR0=[F:ITN]SCONUM
          If fstat Then
            [M:HDKW]COLNAM(ILIGNE) = [F:ITN]SCONUM
          Else
            [M:HDKW]COLNAM(ILIGNE) = [F:BPR]BPRNAM
          Endif
        Endif
        [M:HDKW]SRENUM(ILIGNE) = [F:ITN]SRVDEMNUM
        If [F:ITN]SRVDEMNUM = "" Then
          [M:HDKW]SALFCY(ILIGNE) = [F:ITN]SALFCY
        Else
          Read [SRE]SRE0=[F:ITN]SRVDEMNUM
          If fstat Then
            [M:HDKW]SALFCY(ILIGNE) = [F:ITN]SALFCY
          Else
            [M:HDKW]SALFCY(ILIGNE) = [F:SRE]SALFCY
          Endif
        Endif
        ILIGNE += 1
        If IBCONTINUE = 1 Then
          INBDAY = nday(DTDATEDEB)
          INBDAY = INBDAY + 1
          DTDATEDEB = nday$(INBDAY)
          SZHOURDEB = CSTHEUREDEB
        Endif
      Wend
    Endif
  Next
  Filter [ITN]
  [M:HDKW]NBLIGITN = ILIGNE
  Sorta [M:HDKW]NBLIGITN [M:HDKW]NBLIGITN Order By [M:HDKW]DATDEB(indice), [M:HDKW]HEURDEB(indice), [M:HDKW]TYPACT(indice)
  # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
  #[M:HDK2] = [M:HDKW]
  Raz [M:HDK2] : Transmask [M:HDKW] To [M:HDK2]
  # Issue X3-35454 - 2017-05-03 by FGR : END
  Close Local Mask [HDKW]
  # FGR 29/01/2010 : X3SUIVI62017 (début) l'agenda doit toujours avoir au moins une ligne sinon il y a des pb avec les boutons graphiques
  If [M:HDK2]NBLIGITN = 0 Then
    [M:HDK2]NBLIGITN = 1
  Endif
  # FGR 29/01/2010 : X3SUIVI62017 (fin)
  Affzo [M:HDK2]1-99
Return

##########################################################################################################
$LOAD_INF
  Effzo [M:HDK3]10
  [M:HDK3]NBLIGINF = 0
  Gosub LD_INF_ITN
  Affzo [M:HDK3]1-99
Return

##########################################################################################################
$LD_INF_ITN
  Gosub VAR_PE_HDKAGD  # FGR 02/03/2010 : X3SUIVI62968

Local Char SZROLE (250)
Local Char SZWHERE(250)(IFILTDIM) # FGR 17/02/2010 : X3SUIVI62624 pas (20)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZRECHERCHE (100)
Local Integer IBNONVIDE
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZVALEUR (250)
Local Char SZINFO (250)
Local Char SZCOLNAM (100)
Local Integer IRETARD

  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZRECHERCHE
  IBNONVIDE = 0
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZVALEUR
  Raz SZINFO
  Raz SZCOLNAM
  IRETARD = 0
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:ITN]DON<>2 "
  ILIGNEWHERE += 1
  SZAND = " AND "
  If [M:HDK0]HDKCOL <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:ITN]REP=[M:HDK0]HDKCOL"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  SZWHERE(ILIGNEWHERE) = SZAND - "(([F:ITN]DAT< date$ and [F:ITN]DAT<>[00/00/00]) or ([F:ITN]DAT=[00/00/00] and [F:ITN]WEE<week(date$) and [F:ITN]DATX<date$)) "
  ILIGNEWHERE += 1
  SZAND = " AND "
  #
  SZCNTHDKAGD = "INFITN"            # FGR 17/02/2010 : X3SUIVI62624
  Gosub PE_HDKAGD From TRTCRMPE     # FGR 17/02/2010 : X3SUIVI62624
  # FGR 14/01/2009 : X3SUIVI48957 (debut)
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  # FGR 14/01/2009 : X3SUIVI48957 (fin)
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "ITN") From CRMUTIL150  # FGR 24/04/2009 : X3SUIVI54295 : utilisation rôles normalisée
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [ITN] Where evalue(SZWHERE) Order By [F:ITN]DATX Desc; [F:ITN]HOU Desc
  Else
    Filter [ITN] Order By [F:ITN]DATX Desc; [F:ITN]HOU Desc
  Endif
  ILIGNE = [M:HDK3]NBLIGINF
  For [ITN] Hint Key ITN1
    If ILIGNE = dim([M:HDK3]INFKEY)-1 Then
      Break
    Endif
    Raz SZINFO
    Raz SZCOLNAM
    If [F:ITN]SCO <> 2 Then
      Read [AUS]CODUSR=[F:ITN]REP
      If fstat <> 0 Then
        SZCOLNAM = [F:ITN]REP
      Else
        SZCOLNAM = [F:AUS]NOMUSR
      Endif
    Else
      Read [BPR]BPR0=[F:ITN]SCONUM
      If fstat <> 0 Then
        SZCOLNAM = [F:ITN]SCONUM
      Else
        SZCOLNAM = [F:BPR]BPRNAM
      Endif
    Endif
    #Intervention annulée ou non marquée effectuée
    SZINFO = mess(498,177,1)
    [M:HDK3]INFCOLNAM(ILIGNE) = SZCOLNAM
    [M:HDK3]INFINFO(ILIGNE) = SZINFO
    [M:HDK3]INFDELAY(ILIGNE) = nday(date$) - nday([F:ITN]DATX)
    [M:HDK3]INFKEY(ILIGNE) = [F:ITN]NUM
    [M:HDK3]CMPKEY(ILIGNE) = [F:ITN]BPC
    [M:HDK3]CCNKEY(ILIGNE) = [F:ITN]CCN
    [M:HDK3]SREKEY(ILIGNE) = [F:ITN]SRVDEMNUM
    [M:HDK3]INFTYPE(ILIGNE) = 4
    [M:HDK3]INFOBJ(ILIGNE) = "ITN"
    ILIGNE += 1
  Next
  Filter [ITN]
  [M:HDK3]NBLIGINF = ILIGNE
Return

