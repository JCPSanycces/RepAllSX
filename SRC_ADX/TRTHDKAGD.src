$ACTION
  Case ACTION
    When "INIT"         : Gosub INIT
    When "AVANT_PAR"    : Gosub AVANT_PAR
    When "SEL_LISTE"    : Gosub SEL_LISTE
    When "VERF_LISTE"   : Gosub VERF_LISTE
    When "CONTROLE"     : Gosub CONTROLE
    When "TITRE"        : Gosub TITR
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub MENU
    When "AVANT_MEN"    : Gosub AVANT_MEN
    When Default
  Endcase
Return

##########################################################################################################
$INIT
Global Char GHDKAGDHTRNUM
Local Integer INBHTR
Local Char SZHDKTRSNUM

  If clalev ([F:HTR])=0  : Local File HDKTRS [HTR] : Endif
  #
  GHDKAGDHTRNUM = ""
  INBHTR = 0
  SZHDKTRSNUM = ""
  Filter [HTR] Where [F:HTR]HTRTYP = 5 and ENAFLG = 2 # FGR 07/12/2011 : X3SUIVI78497 il manquait "and ENAFLG = 2"
  For [HTR]
    SZHDKTRSNUM = [F:HTR]HTRNUM
    INBHTR += 1
  Next
  Filter [HTR]
  #
  If INBHTR = 0 Then
    #On créé une transaction par défaut
    #Call CREHDKAGDHTR From SUBCMDB
    #Call OUVRE_TRACE(mess(100,196,1)-" : HDK - DEF") From LECFIC
    #Call VAL_HDKTRS(5,"DEF",nomap) From FUNHDKTRS
    #Call FERME_TRACE From LECFIC
    #GHDKHTRNUM = "DEF"
  Endif
  If INBHTR = 1 Then
    #On utilise la seule transaction qui soit définie
    GHDKAGDHTRNUM = SZHDKTRSNUM
  Endif
Return

##########################################################################################################
$AVANT_PAR
  If GHDKAGDHTRNUM = "" Then
    If GFLAG <> "" Then
      Read [HTR]HTR0=5;GFLAG
      If !fstat Then
        GHDKAGDHTRNUM = GFLAG
        Call LOAD_SITE_GRP([F:HTR]GFY) From CRMUTIL150 # FGR 14/01/2009 : X3SUIVI48957
        TYPPRG = 0
      Endif
    Endif
  Else
    Read [HTR]HTR0=5;GHDKAGDHTRNUM
    If !fstat Then
      Call LOAD_SITE_GRP([F:HTR]GFY) From CRMUTIL150   # FGR 14/01/2009 : X3SUIVI48957
      TYPPRG = 0
    Endif
  Endif
Return

##########################################################################################################
# Avant ouverture de la fenêtre de sélection des transactions #
#-------------------------------------------------------------#
# FGR 22/07/2010 : X3SUIVI65970 (début)
$SEL_LISTE
Local Integer NBACS
Local Integer I
Local Char TABACS(10)(100)
Local Char CRITERE(250)

  If !clalev([F:HTR]) : Local File HDKTRS [HTR] : Endif
  If !clalev([F:ACC]) : Local File ACCES  [ACC] : Endif
  #
  CRITERE = "HTRTYP = 5"
  Raz TABACS
  If GPROFIL <> GSUPER Then
    For [ACC]CODACC Where USR = GUSER
      If [F:ACC]EXEC = 2 Then
        [L]TABACS(NBACS) = vireblc([F:ACC]CODACC,1)
        NBACS += 1
      Endif
      If NBACS > 99 Then
        Break
      Endif
    Next
    CRITERE -= " And (ACSCOD='' or find(ACSCOD,TABACS(0..99)))"
  Endif
  #
  If GFLAG = "" Then
    Filter [HTR] Where evalue(CRITERE) and ENAFLG = 2
    If rowcount([HTR]) = 1 Then
      Read [HTR]First
      If !fstat Then
        GFLAG = [F:HTR]HTRNUM
      Endif
    Endif
    Filter [HTR]
  Endif
  #
  If GFLAG <> "" Then
    Filter [HTR] Where evalue(CRITERE) and ENAFLG = 2
    Read [HTR]HTR0=5;GFLAG
    If !fstat Then
      OK = 0
      GHDKAGDHTRNUM = GFLAG
    Endif
    Filter [HTR]
  Endif
  #
  If GFLAG = "" Then
    I = 1
    Raz TEX, TEXTE
    # FGR 03/07/2012 : X3SUIVI82218 : le for n'entre pas dans la boucle.
    Filter [HTR] Where evalue(CRITERE) and ENAFLG = 2
    #For [HTR]HTR0 Where evalue(CRITERE) and ENAFLG = 2
    Read [HTR]First
    While !fstat
      TEX(I) = [F:HTR]HTRNUM
      TEXTE(I) = [F:HTR]HTRNUM + space$(6-len([F:HTR]HTRNUM))
      Call LECTEXTRA(TIT, "HDKTRS", "DESAXX", num$([F:HTR]HTRTYP), [F:HTR]HTRNUM) From ATEXTRA
      TEXTE(I) += TIT + space$(GLONAX3-len(TIT)) + [F:HTR]ACSCOD
      I += 1
      If I >= dim(TEX) Then
        Break
      Endif
      Read [HTR]Next
    Wend
    #Next
    Filter [HTR]
    NBTEX = I - 1
    TIT = mess(3,126,1)
  Endif
Return
# FGR 22/07/2010 : X3SUIVI65970 (fin)

$OLDSEL_LISTE
  If !clalev([F:HTR])  Local File HDKTRS [HTR] : Endif
  I = 1
  Raz TEX, TEXTE
  For [HTR] HTR0 Where HTRTYP = 5 and ENAFLG = 2
    TEX(I) = [F:HTR]HTRNUM
    TEXTE(I) = [F:HTR]HTRNUM + space$(6-len([F:HTR]HTRNUM))
    Call LECTEXTRA(TIT, "HDKTRS", "DESAXX", num$(HTRTYP), HTRNUM) From ATEXTRA
    TEXTE(I) += TIT
    I += 1
    If I >= dim(TEX) Then
      Break
    Endif
  Next
  NBTEX = I - 1
  TIT = mess(3,126,1)
Return

##########################################################################################################
# La transaction de saisie a été choisie #
#----------------------------------------#
$VERF_LISTE
  GHDKAGDHTRNUM = VALEUR
Return

##########################################################################################################
$CONTROLE
  If GHDKAGDHTRNUM <> "" Then
    BOITE = "WOHDA" + GHDKAGDHTRNUM
    # FGR 14/01/2009 : X3SUIVI48957
    Read [HTR]HTR0=5;GHDKAGDHTRNUM
    If !fstat Then
      Call LOAD_SITE_GRP([F:HTR]GFY) From CRMUTIL150   # FGR 14/01/2009 : X3SUIVI48957
    Endif
  Else
    FIN = 1
  Endif
Return

##########################################################################################################
$TITR
Local Integer IONGLET
Local Integer IBRETOUR
Local Char SZMESSAGE(250)

  IONGLET = 0
  Call GET_ONGLET_DEF_HDK (5, GHDKAGDHTRNUM, "FHDKAGD", IONGLET, SZMESSAGE, IBRETOUR) From CRMTRSUTI
  If IONGLET <> 0 Then
    AFOLDEF = IONGLET
  Endif
Return

##########################################################################################################
$OUVRE
  If GHDKAGDHTRNUM = "" Then
    FIN = 1
    Return
  Endif
  #
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:SOL]) : Local File SOLUTION [SOL] : Endif
  If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:ECE]) : Local File ESCSRE [ECE] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:HDT]) : Local File HDKTASK [HDT] : Endif
  If !clalev([F:HDI]) : Local File HDKTASKINV [HDI] : Endif
  If !clalev([F:UOT]) : Local File UNITOFTIME [UOT] : Endif
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev([F:PCT]) : Local File PITCOUNT [PCT] : Endif
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:PCT2]) : Local File PITCOUNT [PCT2] : Endif
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNHDKAGD"
  #Renouvellement des garanties à tacite reconduction
  Call REWWARRANTY From SUBCONB2
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  # F Plan de dispatching
  # G Demandes à dispatcher
  #Autorisation dispatching
  If GAUSHDKB <> 2 Then
    Call VIREBOUT(CHMEN,"FG") From GOBJET
  Endif
  # 1 : Planifier une intervention
  # 2 : Enregistrer une intervention
  #Menu Actions   Module Action Co
  # Module Action Co
  # ) : Planifier un rendez-vous
  # ( : Planifier un appel
  # £ : Planifier une tâche
  # 3 : Enregistrer Demande de garantie
  # µ : Enregistrer un contrat de service
  # ! : Enregistrer une affaire
  # } : Enregistrer un rendez-vous
  # { : Enregistrer un appel
  # ~ : Enregistrer une tâche
  If GMODU(13) <> 2 Then
    #Si pas module commercial on les enlève
    Call VIREBOUT(CHMEN,")(£3µ!}{~") From GOBJET
  Endif
  #I Solutions
  #O Demandes de service
  #P Demandes sur description
  #Autorisation recherche demande
  If GAUSHDKF <> 2 Then
    Call VIREBOUT(CHMEN,"OP") From GOBJET
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Initialisation
Local Char SZREPCONNECT
Local Char SZMESSAGE(250)
Local Integer IMONTH
Local Integer IYEAR
Local Integer IBRETOUR
Local Char SZVALEUR
Local Integer IBISCOLHDK

  Raz SZREPCONNECT
  Raz SZMESSAGE
  IBRETOUR = 1
  Raz SZVALEUR
  IBISCOLHDK = 0
  #Initialisation collaborateur
  Call PARAMUTIL("AUSHDKA", SZVALEUR, [F:AUS]USR, "") From SUBAUS
  If SZVALEUR = "" Then
    SZVALEUR = "1"
  Endif
  IBISCOLHDK = val(SZVALEUR)
  If IBISCOLHDK = 2 Then
    [M:HDK0]HDKCOL = GUSER
  Endif
  #Vérification de l'accès au dispatching
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:HDK0]DISPAOK = 0
  Else
    Call PARAMUTIL("AUSHDKB", SZVALEUR, GUSER, "") From SUBAUS
    If SZVALEUR <> "1" and SZVALEUR <> "2" Then
      SZVALEUR = "1"
    Endif
    [M:HDK0]DISPAOK = val(SZVALEUR)
  Endif
  IMONTH = month(date$)
  IYEAR = year(date$)
  If IMONTH < 0 Then
    IYEAR = IYEAR - 1
    IMONTH = IMONTH + 12
  Endif
  [M:HDK0]DATMIN = gdat$(1, IMONTH, IYEAR)
  IMONTH = month(date$)
  IYEAR = year(date$)
  IMONTH = IMONTH + 1
  If IMONTH > 12 Then
    IMONTH = IMONTH - 12
    IYEAR = IYEAR + 1
  Endif
  [M:HDK0]DATMAX = eomonth(gdat$(1, IMONTH, IYEAR))
  #gere l'affectation des valeurs par la transaction
  Call AFFECT_VAL_TRS_HDK (5, GHDKAGDHTRNUM, SZMESSAGE, IBRETOUR) From CRMTRSUTI
  Affzo [M:HDK0]1-99
  # FGR 29/01/2010 : X3SUIVI62017 (début) l'agenda doit toujours avoir au moins une ligne sinon il y a des pb avec les boutons graphiques
  [M:HDK2]NBLIGITN = 1
  # FGR 29/01/2010 : X3SUIVI62017 (fin)
  Affzo [M:HDK2]1-99
Return

