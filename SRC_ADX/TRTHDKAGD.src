##########################################################################################################
$MENU
Local Integer IBLOAD

  IBLOAD = 0
  Case BOUT
    When "1"
      #Planifier Intervention
      IBLOAD = 1
    When ")"
      #Planifier Rendez-vous
    When "("
      #Planifier Appel
    When "£"
      #Planifier Tache
    When "2"
      #Enregistrer Intervention
      IBLOAD = 1
    When "}"
      #Enregistrer Rendez-vous
    When "{"
      #Enregistrer Appel
    When "~"
      #Enregistrer Tache
    When "!"
      #Enregistrer Affaire
    When "%"
      #Enregistrer demande de service
      IBLOAD = 1
  Endcase
  If IBLOAD = 1 Then
    Gosub ONLOAD
  Endif
Return

