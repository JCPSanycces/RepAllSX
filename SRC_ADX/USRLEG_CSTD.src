#<AdxTL>@(#)0.0.0.0 $Revision$ Current legislation
# Class USRLEG


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD_AFTER"
        this.LEG = func USRLEG_CSTD.GET_CUR_LEG(this.USR)
      Endcase
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**
#* Functions to set the LEG in the table used by the cache class
#* @param V_USER Char(GLONAUS), Current user
#* @return LEG, Instance legislation linked to current user
#*!
Funprog GET_CUR_LEG(V_USER)
Value Char V_USER
Local Char V_LEG(GLONADI)

Local Instance  I_USRLEGSOA Using C_USRLEGSOA
If (I_USRLEGSOA <> null) : FreeGroup I_USRLEGSOA : Endif
I_USRLEGSOA  = NewInstance C_USRLEGSOA AllocGroup null
READSTATUS = fmet I_USRLEGSOA.AREAD(V_USER)
#Test the read status to decide if the record must be updated or created
If READSTATUS = [V]CST_AOK
  V_LEG = I_USRLEGSOA.LEG
Endif
FreeGroup I_USRLEGSOA
End V_LEG






