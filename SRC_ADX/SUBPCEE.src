#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du masque PCEE
#######################################################################
# SUBPCEE : Saisie des informations CEE                  MBT 13/01/00 #
#           en contrôle des factures achats                           #
# ------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p de     #
#        saisie des informations CEE "SAISIE_INFOCEE" et ne sert qu'à #
#        gérer le MASQUE écran "PCEE [PCEE]".                         #
# Issue 100619 - 2014-07-24 by SR : [M:PCEE] remplacés par [M]        #
# Car le Webservice ouvre une autre abrébviation que PCEE             #
#######################################################################


Subprog AM_FFWNUM(VALEUR)
#----------------------------#
# Après modif du transitaire #
#----------------------------#
Variable Char    VALEUR()
If VALEUR<>""
  If [F:BPR2]BPRNUM<>VALEUR
    Read [BPR2] BPR0=VALEUR : If fstat Raz [F:BPR2] : Endif
  Endif
  [M]FFWNAM(0)=[F:BPR2]BPRNAM(0)
  [M]FFWNAM(1)=[F:BPR2]BPRNAM(1)
  [M]FFWADD   =[F:BPR2]BPAADD
  Actzo [M]FFWADD
Else
  Raz [M]FFWADD
  Diszo [M]FFWADD
Endif
Affzo [M]FFWADD
End


Subprog AS_FFWADD(VALEUR)
#------------------------------#
# Avant saisie du code adresse #
#------------------------------#
Variable Char    VALEUR()
If [M]FFWNUM=""  mkstat=2 : End : Endif
End


Subprog C_FFWADD(VALEUR)
#-----------------------#
# Contrôle code adresse #
#-----------------------#
Variable Char    VALEUR()
If [M]FFWNUM=""
  Raz [F:BPA], VALEUR : End
Elsif VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=1 : End
Endif
Read [BPA] BPA0=1;[M]FFWNUM;VALEUR
If fstat  Raz [F:BPA] : mkstat=1 : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran PCEE) 04/02/2013 11:48:05 (CPO)
######################################################################################
Subprog AV_EECNUM(VALEUR)
Variable Char    VALEUR()
#--CPO 71937 Différence avec la V8 (ajout..)
If GCONSDIA=1  Grizo [M]EECNUM : Endif
If GCONSDIA=2  Diszo [M]EECNUM : Endif
End


######################################################################################

