###################################################################################
Funprog SDH_SOHLINORI(NUM,LIN,WSEQ)  #106776
Value Char    NUM         # New EDI field LINORDNUM
Value Integer LIN
Value Integer WSEQ

  Local Char WSOH (20), WLINORI(5)
  Local File SORDERQ [SOQ]
  WSOH=NUM

  Read [SOQ]SOQ0=WSOH;LIN;WSEQ
  If fstat=[V]CST_AOK
    If len([F:SOQ]LINORDNUM)>5
      WLINORI=right$(num$([F:SOQ]LINORDNUM),len([F:SOQ]LINORDNUM)-4)
    Else
      WLINORI=num$([F:SOQ]LINORDNUM)
    Endif
   Endif

  LogicClose File [SOQ]

End WLINORI

###################################################################################
Funprog SDH_NUMOBS(NUM,N,NOTES)
Value Char    NUM         # Delivery number
Value Decimal N           # Notes type
Variable Char NOTES       # Notes fields

  Local Char NUMSDH(20), XCODE(50)
  Local Shortint STAT, LONG, INI

  LONG=100
  INI=1
  Raz NOTES
  NUMSDH=NUM

  Local File TEXCLOB [TXC]
  Local File SDELIVERY [SDH]

  Filter [SDH] Where SDHNUM=NUMSDH
  Read [SDH] First
  If fstat=[V]CST_AOK
    Case N
      When 1,2,3,4: XCODE="CODE=[F:SDH]SDHTEX1"
      When 5,6,7,8: XCODE="CODE=[F:SDH]SDHTEX2"
    Endcase

    Filter [TXC] Where evalue(XCODE)
    Read [TXC] First
    If fstat=[V]CST_AOK and [F:TXC]CODE<>"":

#      INI=instr(1,[F:TXC]TEXTE,"<pre>")  #X3-59085 (JUCON 09/10/2017)
#      ENDB=instr(INI,[F:TXC]TEXTE,"</pre>")-1
      INI=instr(1,[F:TXC]TEXTE,">")
      ENDB=instr(INI,[F:TXC]TEXTE,"</div>")-1
      If INI=0:  INI=1
#      Else INI+=5  #X3-59085 (JUCON 09/10/2017)
      Else INI+=1
      Endif
      Case N
        When 2,6: INI= LONG+INI
        When 3,7: INI=(2*LONG)+INI
        When 4,8: INI=(3*LONG)+INI
      Endcase
      FIN=LONG+INI
      If FIN>ENDB and ENDB>0: FIN=ENDB: Endif
      NOTES=seg$([F:TXC]TEXTE,INI,FIN)
      If NOTES<>"": STAT=1: Endif
    Endif
  Endif

  LogicClose File [SDH]
  LogicClose File [TXC]

End STAT


###################################################################################
Funprog SDH_TENOR_NUMOBSL(NUM,NL,PACNUM,TLIN)
Value Char    NUM         # Delivery number
Value Integer NL          # Number line
Value Char    PACNUM      # Pack. number
Variable Char TLIN        # Texts

  Local Char NUMREF(20)
  Local Integer I, WTX, WFLG
  Local Integer INI, LONG, INIB, ENDB
  Local File TEXCLOB [TXC]

  LONG=100
  NUMREF=NUM

  If PACNUM=""
    Local File SDELIVERYD [SDD]
    Read [SDD]SDD0=NUMREF;NL
    If fstat=[V]CST_AOK :
      Read [TXC]TXC0=[F:SDD]SDDTEX
      If fstat=[V]CST_AOK

#        INIB=instr(1,[F:TXC]TEXTE,"<pre>") #X3-59085 (JUCON 09/10/2017)
#        ENDB=instr(INIB,[F:TXC]TEXTE,"</pre>")-1
        INIB=instr(1,[F:TXC]TEXTE,">")
        ENDB=instr(INIB,[F:TXC]TEXTE,"</div>")-1
        If INIB=0:  INIB=1
#        Else INIB+=5 @jcc
        Else INIB+=1
        Endif

        For I=0 To 3
          INI=INIB+(LONG*I)
          FIN=LONG+INI
          If FIN>ENDB and ENDB>0: FIN=ENDB: Endif
          TLIN(I)=seg$([F:TXC]TEXTE,INI,FIN)
        Next
      Endif
      If TLIN(0)<>"":WFLG =1: Endif
      LogicClose File [SDD]
    Endif
  Else
    Local File SPACK [SPHX]
    Filter [SPHX] Where VCRNUM=NUMREF and PACNUM=PACNUM
    Read First
    If fstat=[V]CST_AOK
      Read [TXC]TXC0=[F:SPHX]SPHTEX
      If fstat=[V]CST_AOK

        INI=instr(1,[F:TXC]TEXTE,"<pre>")
        ENDB=instr(INI,[F:TXC]TEXTE,"</pre>")-1
        If INI=0:  INI=1: Endif

        For I=4 To 7
          INI=(LONG*(I-4))+1
          FIN=LONG+INI
          If FIN>ENDB and ENDB>0: FIN=ENDB: Endif
          TLIN(I)=seg$([F:TXC]TEXTE,INI,FIN)
        Next
      Endif
      If TLIN(0)<>"" or TLIN(4)<>"" :WFLG =1: Endif
      LogicClose File [SPHX]
    Endif
  Endif
  LogicClose File [TXC]

End WFLG
###################################################################################
Funprog FACE_OPIT(NUM,RESP,N)  #SAM 112148
Value Char    NUM         # Sales Invoice number
Variable Char RESP
Value Decimal N           # 1- Due date / 2 - Amount /3 - PAM

  Local Integer NBDUD            # Open item number
  Local Integer STA
  Local File SINVOICE    [SIH]
  Local File GACCDUDATE  [DUD]

  Read [SIH]SIH0=NUM
  If fstat=[V]CST_AOK
    Filter [DUD] Where TYP=[F:SIH]GTE and NUM=[F:SIH]NUM
    For [DUD]
      Case N
        When 1: RESP(NBDUD)=format$("D:YYYY[-]MM[-]DD",[F:DUD]DUDDAT)
        When 2: If [F:SIH]CUR=[F:DUD]CUR: RESP(NBDUD)=num$([F:DUD]AMTCUR) Else: RESP(NBDUD)=num$([F:DUD]AMTLOC): Endif
        When 3: RESP(NBDUD)=[F:DUD]PAM
      Endcase
      NBDUD+=1
    Next
    Filter [DUD]
  Endif

  LogicClose File [SIH]
  LogicClose File [DUD]

  If RESP(0)<>"": STA=[V]CST_AOK: Endif

End STA

###################################################################################
Funprog FACE_TXTMETCOR(NUM,WMET,WLAN,WLEG)  #SAM 112148
Value Char    NUM         # Sales Invoice number
Value Integer WMET        # Method of correction
Value Char    WLAN        # Language
Value Char    WLEG        # Legislation

Local File APLSTD      [APL]
Local File SINVOICE    [SIH]
Local Integer VALMET
Local Char TEXTE(80)
If WLAN="": WLAN="SPA": Endif

Read [SIH]SIH0=NUM
If fstat=[V]CST_AOK
  Read [APL]CLE=2069;WMET;WLAN
  If fstat=[V]CST_AOK
    TEXTE=[F:APL]LANMES
  Endif
Endif

End TEXTE

###################################################################################
Funprog FACE_RESDES(WEXT)  #SAM 112148
Value Char WEXT

Local Char TEXTE(80)
## ReasonDesciption property has to be in Spanish text or error
Case WEXT
  When "01": TEXTE="Número de la factura"
  When "02": TEXTE="Serie de la factura"
  When "03": TEXTE="Fecha expedición"
  When "04": TEXTE="Nombre y apellidos/Razón social - Emisor"
  When "05": TEXTE="Nombre y apellidos/Razón social - Receptor"
  When "06": TEXTE="Identificación fiscal Emisor/Obligado"
  When "07":TEXTE="Identificación fiscal Receptor"
  When "08":TEXTE=" Domicilio Emisor/Obligado"
  When "09":TEXTE=" Domicilio Receptor"
  When "10":TEXTE="Detalle Operación"
  When "11":TEXTE="Porcentaje impositivo a aplicar"
  When "12":TEXTE="Cuota tributaria a aplicar"
  When "13":TEXTE="Fecha/Periodo a aplicar"
  When "14":TEXTE="Clase de factura"
  When "15":TEXTE="Literales legales"
  When "16":TEXTE="Base imponible"
  When "80":TEXTE="Cálculo de cuotas repercutidas"
  When "81":TEXTE="Cálculo de cuotas retenidas"
  When "82":TEXTE="Base imponible modificada por devolución de envases/embalajes"
  When "83":TEXTE="Base imponible modificada por descuentos y bonificaciones"
  When "84":TEXTE="Base imponible modificada por resolución firme, judicial o administrativa"
  When "85":TEXTE="Base imponible modificada cuotas repercutidas no satisfechas. Auto de declaración de concurso"
Endcase


End TEXTE


###################################################################################
Funprog FACEPIH_BPRSAC(WBPS,WCPY,WTYP,WCODE)  #SAM 112148
Value Char WBPS   # BP number
Value Char WCPY   # Company code
Value Char WTYP   # Type. "F" for supplier
Value Char WCODE  # Accounting code

  If WBPS="" : End : Endif

  Local Char WACCCOD(5), COMPTE(15), WGCM(3), WLED(3), WCOA(3), WBPRSAC(4)

  If func ASYRFNC.ACTIV("MUL") >0 #X3-63010 JUCON 07/11/2017)
    Local File BPEXCEPT   [BPE]
    Read [BPE]BPE0=WBPS;WCPY
    If fstat=[V]CST_AOK
      WACCCOD = [F:BPE]ACCBPS
    Endif
    LogicClose File [BPE]
  Endif

  If WACCCOD=""
    Local File BPSUPPLIER [BPS]
    Read [BPS]BPS0=WBPS
    If fstat=[V]CST_AOK
      WACCCOD = [F:BPS]ACCCOD
    Endif
    LogicClose File [BPS]
  Endif

  Local File COMPANY [CPY]
  Read [CPY]CPY0=WCPY
  If fstat=[V]CST_AOK
    WGCM=[F:CPY]ACM
  Endif
  LogicClose File [CPY]

  If WGCM<>""
    Local File GACM [GCM]
    Read [GCM]GCM0=WGCM
    If fstat=[V]CST_AOK
      WLED=[F:GCM]LED
    Endif
    LogicClose File [GCM]
  Endif

  If WLED<>""
    Local File GLED [LED]
    Read [LED]LED0=WLED
    If fstat=[V]CST_AOK
      WCOA=[F:LED]COA
    Endif
    LogicClose File [LED]
  Endif

  If WCOA<>""
    Local File GACCCODE [CAC]
    Read [CAC]CAC0=3;WACCCOD;WCOA
    If fstat=[V]CST_AOK
      COMPTE=[F:CAC]ACC(0)
    Endif
    Close File [CAC]
  Endif

  #Call LECTURE("GAC",COMPTE,WCOA)  From CONTOBJ
  Local File GACCOUNT [GAC]
  Read [GAC]GAC0=WCOA;COMPTE
  If !fstat & [F:GAC]SAC=2: WBPRSAC=[F:GAC]ACCSHO : Endif
  LogicClose File [GAC]
End WBPRSAC


#*********************************************************************
# GETVALPARAMURL
#*********************************************************************
# Used for displaying an EDI document from a link (in SAS EDISTO)
# Must be called from all EDI representation
# in the AREAD_AFTER method :
# Gosub GETVALPARAMURL From TRTFUNEDI
#*********************************************************************
#*!
$GETVALPARAMURL
  Local Integer WOK
  Local Char WERR(250)
  Local Char WPARAM(250)(1..)
  WPARAM(1) = fmet this.AGETVALPARAMURL("CATACT")
  WPARAM(2) = fmet this.AGETVALPARAMURL("CATCOD")
  WPARAM(3) = fmet this.AGETVALPARAMURL("PARCOD")
  WPARAM(4) = fmet this.AGETVALPARAMURL("DUPLICATEFLG")
  WPARAM(5) = fmet this.AGETVALPARAMURL("TESTFLG")
  WPARAM(6) = fmet this.AGETVALPARAMURL("JSONUUID")
  If WPARAM(1) <> ""
    If WPARAM(1) = "1" #Send
#      WOK = fmet this.MET_AFTER_LOAD_REPRESENTATION(val(WPARAM(1)), WPARAM(2), WPARAM(3), val(WPARAM(4)), val(WPARAM(5)), WERR)
      WOK = fmet this.MET_AFTER_LOAD_REPRESENTATION(val(WPARAM(1)), WPARAM(2), WPARAM(3), val(WPARAM(4)), val(WPARAM(5)), "", WERR)  #Issue X3-112583 - 2018-10-11 by RBA - 7 parameters
    Else #Receive
      If WPARAM(6) <> ""
      Endif
    Endif
  Endif
Return

###################################################################################
Funprog FACEPIH_INVDTACOD(RAT, LEG)
Value Decimal RAT         # Rate tax
Value Char    LEG         # Legislation
Local Char TAXCOD(5)         # Tax code

Local File TABVAT      [TVT]

  Filter [TVT] Where LEG=LEG and VATRAT=RAT

  Read [TVT] First
  If fstat=[V]CST_AOK
    TAXCOD=[F:TVT]VAT
  Endif

  LogicClose File [TVT]

End VAT

####################################################################################
# issue 114721 Decimal separator in generated file
Funprog FMTDEC(PROPERT,SEPDEC)
Variable Char PROPERT
Value Char SEPDEC

#Local Char PROPERT(25)
Local Integer I, WOK
Local Char SEP(1)

  PROPERT=vireblc(PROPERT,4)
  Case SEPDEC
    When ",":
      I = instr(1,PROPERT,SEPDEC)
      If I=0: PROPERT=ctrans(PROPERT,".",SEPDEC) : Endif
    When ".":
      I = instr(1,PROPERT,SEPDEC)
      If I=0: PROPERT=ctrans(PROPERT,",",SEPDEC) : Endif
  Endcase

End PROPERT
#/ 114721

