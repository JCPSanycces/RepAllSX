#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
## Library of functions EDI  (head and lines) JUCON
###################################################################################
Funprog INV_QTYFREE(NUM,LIN)
Value Char    NUM         # Sales Invoice number
Value Decimal LIN         # Invoice line

Local Integer FREQTY      # free qty
Local File SINVOICED [SID]

Read [SID]SID0=NUM;LIN
If fstat=[V]CST_AOK and [F:SID]FOCFLG=3
  FREQTY=[F:SID]QTY
Else
  FREQTY=0
Endif

LogicClose File [SID]

End FREQTY

###################################################################################
Funprog INV_PERAMTLIN_DISC(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Integer N           # N.invoice element
Local Decimal AMT         # Amount or percentage

Local File SINVOICEV  [SIV]
Local File PRICSTRUCT [PRS]

AMT=0
Read [SIV]SIV0=NUM
If fstat=[V]CST_AOK
  Read [PRS]PRS0=1;[F:SIV]PLISTC
  If fstat=[V]CST_AOK and N<>0:
    If [F:PRS]VALTYP(N-1)=1 : AMT=1: Endif
    Endif

Endif

LogicClose File [SIV]
LogicClose File [PRS]

End AMT

###################################################################################
Funprog INV_CALAMTPERLIN_DISC(NUM,GROP,DAMT,N,POS)
Value Char    NUM         # Sales Invoice number
Value Decimal GROP        # Gross price unit
Value Decimal DAMT()      # discount element
Value Integer N,POS       # N.invoice element and position
Local Decimal AMT(1..4)      # Amounts

Local Shortint H,L
Local Decimal TGROP
Local File SINVOICEV  [SIV]
Local File PRICSTRUCT [PRS]
Raz TGROP, AMT(),H

#JUCON 010915
Local Integer LNBPRS
LNBPRS = max(1,func AFNC.ACTIV("SPR"))
If N>LNBPRS: Raz NUM: Endif
#JUCON 010915

Read [SIV]SIV0=NUM
If fstat=[V]CST_AOK
  Read [PRS]PRS0=1;[F:SIV]PLISTC

  If fstat=[V]CST_AOK and N<>0
    For I=1 To N
      L=I-1
      If [F:PRS]NPRNOTFLG(L)=2
        If [F:PRS]INCDCR(L)=2 :
          DAMT(H)=DAMT(H)*-1:
        Endif
        If I=1
          Case [F:PRS]VALTYP(L)
            When 1:       AMT(POS)=DAMT(H)
            When Default: AMT(POS)=GROP*(DAMT(H)/100)
          Endcase
         TGROP=GROP+AMT(POS)
        Else
          Case [F:PRS]VALTYP(L)
            When 1: AMT(POS)=DAMT(H)
            When 2: AMT(POS)=GROP*(DAMT(H)/100)
            When 3: AMT(POS)=TGROP*(DAMT(H)/100)
          Endcase
          H+=1
          TGROP=TGROP+AMT(POS)
        Endif
      Else
        TGROP=GROP
      Endif
    Next
  Endif

Endif

LogicClose File [SIV]
LogicClose File [PRS]

End AMT(POS)

###################################################################################
Funprog INV_TYPLIN_DISC(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # N.invoice element
Local Char    TYP(20)     # Type

Local Char    DES(10)
Raz TYP

Local File SINVOICEV   [SIV]
Local File PRICSTRUCT  [PRS]
Local File ATEXTRA     [AXX]

Read [SIV]SIV0=NUM
If fstat=[V]CST_AOK: Read [PRS]PRS0=1;[F:SIV]PLISTC
  DES="DESAXX("+num$(N)+")"
  If fstat=[V]CST_AOK: Read [AXX]AXX0="PRICSTRUCT";DES;[F:SIV]LAN;"1";[F:SIV]PLISTC
    If fstat=[V]CST_AOK: TYP=[F:AXX]TEXTE: Else TYP="": Endif
  Endif
Endif

LogicClose File [SIV]
LogicClose File [PRS]
LogicClose File [AXX]

End TYP

###################################################################################
Funprog INV_SEQUENLIN_DISC(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # N.invoice element
Local Integer SEQ         # Sequence

Local File SINVOICEV   [SIV]
Local File PRICSTRUCT  [PRS]

Read [SIV]SIV0=NUM
If fstat=[V]CST_AOK
  Read [PRS]PRS0=1;[F:SIV]PLISTC
  If fstat=[V]CST_AOK and [F:PRS]VALTYP(N-1)<>2 and N<>0
      If N=1 and [F:PRS]VALTYP(N)=2:  SEQ=0:   Else SEQ=1: Endif
  Endif
Endif

LogicClose File [SIV]
LogicClose File [PRS]

End SEQ

###################################################################################
Funprog INV_QUALIFLIN_DISC(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # N.invoice element
Local Decimal CALIF       # qualifier

  Local File SINVOICEV   [SIV]
  Local File PRICSTRUCT  [PRS]

CALIF=0

Read [SIV]SIV0=NUM
If fstat=[V]CST_AOK: Read [PRS]PRS0=1;[F:SIV]PLISTC
  If fstat=[V]CST_AOK: CALIF=[F:PRS]INCDCR(N-1): Endif
Endif

LogicClose File [SIV]
LogicClose File [PRS]

End num$(CALIF)

###################################################################################
Funprog INV_PERTAXLIN(NUM,LIN,N)
Value Char    NUM         # Sales Invoice number
Value Decimal LIN         # Invoice line
Value Decimal N           # 1- Tax 1 / 2 - Tax 2 / 3 - Tax 3
Local Char PERC(20)       # Percentage of tax

Local File SINVOICED   [SID]
Local File TABVAT      [TVT]
Local File TABRATVAT   [TRA]

Read [SID]SID0=NUM;LIN
If fstat=[V]CST_AOK: Read [F:TVT]TVT0=[F:SID]VAT(N-1)
  If fstat=[V]CST_AOK
    Filter [TRA] Where CPY=[F:SID]CPY & VAT=[F:SID]VAT(N-1) & STRDAT<=[F:SID]INVDAT
    Read [TRA]TRA0 Last
    If fstat>2
      Filter [TRA] Where CPY="" & VAT=[F:SID]VAT(N-1) & STRDAT<=[F:SID]INVDAT
      Read [TRA]TRA0 Last
    Endif

  Endif
  PERC=num$([F:TRA]VATRAT)
  Filter [TRA]
Endif

LogicClose File [SID]
LogicClose File [TVT]
LogicClose File [TRA]

End PERC

###################################################################################
Funprog INV_REFCLI(BPC, ITM)
Value Char    BPC         # Customer
Value Char    ITM         # Produit
Local Char    REFCLI(20)  # Item reference of the customer

Local File ITMBPC [ITU]

Read [ITU]ITU0=ITM;BPC
If fstat=[V]CST_AOK: REFCLI=[F:ITU]ITMREFBPC
Else REFCLI=""
Endif

LogicClose File [ITU]

End REFCLI

###################################################################################
Funprog INV_DATEDEL(NUM,NN)
Value Char    NUM         # Sales Invoice number
Value Decimal NN           # 1- First delivery / 2 - Last delivery / 3 - The majority delivery

Local Date DATDEL          # Delivery date
Local Char DELDAT(8)
Local Char WSDH(20)(1..99)
Local Integer I, K, N(99)

Local File SINVOICED   [SID]
Local File SINVOICE    [SIH]
Local File SDELIVERY   [SDH]
I=1

Read [SIH]SIH0=NUM
If fstat=[V]CST_AOK
  Case NN
    When 1: Filter [SID] Where SDHNUM<>""  and NUM=[F:SIH]NUM  #X3-46024
            Read First
            If fstat=[V]CST_AOK: Read [SDH]SDH0=[F:SID]SDHNUM
              If fstat=[V]CST_AOK: DATDEL=[F:SDH]DLVDAT: Endif
            Endif
    When 2: Filter [SID] Where SDHNUM<>""  and NUM=[F:SIH]NUM  #X3-46024
            Read Last
            If fstat=[V]CST_AOK: Read [SDH]SDH0=[F:SID]SDHNUM
              If fstat=[V]CST_AOK: DATDEL=[F:SDH]DLVDAT: Endif
            Endif
    When 3: For [SID] Where NUM=[F:SIH]NUM and SDHNUM<>""
              K=find([F:SID]SDHNUM,WSDH())
              If K=0: I+=1: WSDH(I)=[F:SID]SDHNUM: N(I)+=1: Endif
              If K>0: N(I)+=1: Endif
            Next
            If N>0: K=max(N())
              Read [SDH]SDH0=WSDH(K)
              If fstat=[V]CST_AOK: DATDEL=[F:SDH]DLVDAT: Endif
            Endif
  Endcase
Endif

If DATDEL=[00/00/00]
  DELDAT="00000000"
Else
  DELDAT=format$("D:YYYYMMDD",DATDEL)
Endif

LogicClose File [SID]
LogicClose File [SIH]
LogicClose File [SDH]

End DELDAT

###################################################################################
Funprog INV_PERAMT_DISC(NUM,N,M)
Value Char    NUM         # Sales Invoice number
Value Decimal N           #N.invoice element
Value Decimal M           # 1 - percentage / 2 amount
Local Decimal AMTPER      # Amount ot percentage

Local File SINVOICE  [SIH]
Local File SVCRFOOT  [SVF]

AMTPER=0
Read [SVF]SVF0=NUM;4;N          # 4 = Sales invoice
If fstat=[V]CST_AOK:
  Case M
    When 1: If [F:SVF]AMTCOD=1: AMTPER=[F:SVF]DTAAMT :Endif
            If [F:SVF]AMTCOD=2: AMTPER=[F:SVF]DTANOT :Endif
    When 2: If [F:SVF]AMTCOD=2: AMTPER=[F:SVF]DTAAMT :Endif
            If [F:SVF]AMTCOD=1
              Read [SIH]SIH0=NUM
              If fstat=[V]CST_AOK & [F:SIH]AMTNOT<>0 :  AMTPER= ar2(([F:SVF]DTAAMT*100)/[F:SIH]AMTNOT) : Endif
            Endif
  Endcase
Endif

LogicClose File [SIH]
LogicClose File [SVF]

End AMTPER

###################################################################################
Funprog INV_SEQUEN_DISC(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # N.invoice element
Local Decimal SEQ         # Sequence

Local File SINVOICE   [SIH]
Local File COMPANY    [CPY]
Local File PRICSTRUCT [PRS]

Read[SIH]SIH0=NUM
If fstat=[V]CST_AOK:
  Read [CPY]CPY0=[F:SIH]CPY
  If fstat=[V]CST_AOK:
    Read [PRS]PRS0=1;[F:CPY]PLISTC
    If fstat=[V]CST_AOK
      Local Shortint WLEV
      X=sum(INVDTA())
      If X<>0
        X=find(N,INVDTA())
        If X<>0
          If [F:PRS]INVDTA(0)=N and [F:PRS]VALTYP(0)<>2
            WLEV=1
          Else
            WLEV=X-1
          Endif
          If WLEV<>0 and [F:PRS]VALTYP(WLEV)<>2: SEQ=1:    Endif
        Endif
      Endif
    Endif
  Endif
Endif

LogicClose File [SIH], [CPY], [PRS]

End SEQ

###################################################################################
Funprog INV_QUALIF_DISC(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Integer N           # N.invoice element
Local Integer CALIF       # qualifier

Local File SINVOICEV [SIV]
Local File SFOOTINV  [SFI]

Read[SIV]SIV0=NUM
#If fstat=[V]CST_AOK and [F:SIV]INVDTA(N-1)<>0 : Read[SFI]SFI0= N
If fstat=[V]CST_AOK : Read[SFI]SFI0= N
  If fstat=[V]CST_AOK: CALIF=[F:SFI]INCDCR Else CALIF=0 : Endif
Endif

LogicClose File [SIV]
LogicClose File [SFI]

End CALIF

###################################################################################
Funprog INV_TYP_DISC(NUM,TXTYP,N)
Value Char    NUM         # Sales Invoice number
Variable Integer TXTYP    # Especial level tax
Value Integer N           # N.invoice element
Local Integer CALIF       # qualifier

Local File SINVOICEV [SIV]
Local File SFOOTINV  [SFI]

Read[SIV]SIV0=NUM
If fstat=[V]CST_AOK
  Read[SFI]SFI0= N
  If fstat=[V]CST_AOK
    CALIF=[F:SFI]INCDCR
    If [F:SFI]EXCTAXRUL=2: TXTYP=2 Else TXTYP=1 :Endif
  Else CALIF=0
  Endif
Endif

LogicClose File [SIV]
LogicClose File [SFI]

End CALIF

###################################################################################
Funprog INV_DESC_DISC(NUM,WLAN,WLEG,N)
Value Char    NUM         # Sales Invoice number
Value Char    WLAN        # Language
Value Char    WLEG        # Legislation
Value Integer N           # N.invoice element

Local Char TEXT (30)      # Texte

Local File SINVOICEV [SIV]
Local File SFOOTINV  [SFI]
Local File ATEXTRA   [ATX]

Read[SIV]SIV0=NUM
If fstat=[V]CST_AOK
  Read[SFI]SFI0= N
  If fstat=[V]CST_AOK
    Read [ATX]AXX0="SFOOTINV";"DESAXX";WLAN;num$([F:SFI]SFINUM);WLEG
    If fstat=[V]CST_AOK
      TEXT=[F:ATX]TEXTE
    Else
      Read [ATX]AXX0="SFOOTINV";"DESAXX";WLAN;num$([F:SFI]SFINUM);""
      If fstat=[V]CST_AOK
        TEXT=[F:ATX]TEXTE
      Endif
    Endif
  Endif
Endif

LogicClose File [SIV]
LogicClose File [SFI]
LogicClose File [ATX]

End TEXT
###################################################################################
Funprog INV_OPIT(NUM,N,M)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # 1- Due date / 2 - Amount
Value Decimal M           # 1 - first vto / 2 second vto / 3 third vto

Local Decimal AMTVTO      # Open Item amout
Local Char    DUDDAT(8)      # Due date

Local File SINVOICE    [SIH]
Local File GACCDUDATE  [DUD]

Read [SIH]SIH0=NUM
If fstat=[V]CST_AOK: Read [DUD]DUD0=[F:SIH]GTE;NUM;1;M
  If fstat=[V]CST_AOK:
    Case N
      When 1: DUDDAT=format$("D:YYYYMMDD",[F:DUD]DUDDAT)
      When 2: If [F:SIH]CUR=[F:DUD]CUR: AMTVTO=[F:DUD]AMTCUR Else: AMTVTO=[F:DUD]AMTLOC: Endif
    Endcase
  Endif
Endif

LogicClose File [SIH]
LogicClose File [DUD]

If N=1  : End DUDDAT        : Endif
If N=2  : End num$(AMTVTO)  : Endif

End

###################################################################################
Funprog INV_PERTAX(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Integer N           # 1- Tax 1 / 2 - Tax 2 / 3 - Tax 3 / 4 - Tax 4 / 5 - Tax 5 / 6 - Tax 6
Local Decimal PERC        # Percentage of tax

Local File SINVOICE    [SIH]
Local File TABVAT      [TVT]
Local File TABRATVAT   [TRA]

Raz PERC

Read [SIH]SIH0=NUM

If fstat=[V]CST_AOK
  Read [F:TVT]TVT0=[F:SIH]TAX(N-1)
  If fstat=[V]CST_AOK
    Filter [TRA] Where CPY=[F:SIH]CPY & VAT=[F:SIH]TAX(N-1) & STRDAT<=[F:SIH]ACCDAT
    Read [TRA]TRA0 Last
    If fstat>2
      Filter [TRA] Where CPY="" & VAT=[F:SIH]TAX(N-1) & STRDAT<=[F:SIH]ACCDAT
      Read [TRA]TRA0 Last
    Endif
    PERC=[F:TRA]VATRAT
  Endif
  Filter [TRA]
Endif

LogicClose File [SIH]
LogicClose File [TVT]
LogicClose File [TRA]

End PERC

###################################################################################
Funprog INV_CHADISC(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # 1- Charges / 2 - Discounts
Local Decimal TOTAMT      # Total amount

Local File SINVOICE  [SIH]
Local File SVCRFOOT  [SVF]

AMTPER=0

Read [SIH]SIH0=NUM
If fstat=[V]CST_AOK
  Case N
    When 1: Filter [SVF] Where VCRNUM=[F:SIH]NUM and VCRTYP=4 and DTANOT>0
            For [SVF]
              TOTAMT+=[F:SVF]DTANOT
            Next

    When 2: Filter [SVF] Where VCRNUM=[F:SIH]NUM and VCRTYP=4 and DTANOT<0
            For [SVF]
              TOTAMT-=[F:SVF]DTANOT
            Next
            TOTAMT=-1*TOTAMT
  Endcase

  Filter [SVF]
Endif

LogicClose File [SIH]
LogicClose File [SVF]

End TOTAMT

###################################################################################
Funprog INV_TOTAMT(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # 1- Gross amount / 2 - Net amount
Local Decimal TOTAMT      # Total amount

Local File SINVOICE   [SIH]
Local File SINVOICED  [SID]

Read [SIH]SIH0=NUM
If fstat=[V]CST_AOK
  Case N
    When 1: For [SID] Where NUM=[F:SIH]NUM
              TOTAMT+=([F:SID]GROPRI*[F:SID]QTY)
            Next
    When 2: For [SID] Where NUM=[F:SIH]NUM
              TOTAMT+=([F:SID]NETPRI*[F:SID]QTY)
            Next
  Endcase
Endif

LogicClose File [SIH]
LogicClose File [SID]

End TOTAMT

###################################################################################
Funprog INV_CONTRACT(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # 1- First Order / 2 - Last Order / 3 - The majority Order
Local Char    CONNUM(20)  # Sales contract number

Local Char WSRE(20)(1..99)
Local Integer I, K, N(99)

Local File SINVOICED   [SID]
Local File SINVOICE    [SIH]
Local File CONTSERV    [CON]
I=1

Read [SIH]SIH0=NUM
If fstat=[V]CST_AOK
  Case N
    When 1: Filter [SID] Where SDHNUM<>""
            Read First
            If fstat=[V]CST_AOK: Read [CON]CON0=[F:SID]SRENUM
              If fstat=[V]CST_AOK: CONNUM=[F:CON]CONNUM: Endif
            Endif
    When 2: Filter [SID] Where SRENUM<>""
            Read Last
            If fstat=[V]CST_AOK: Read [CON]CON0=[F:CON]SRENUM
              If fstat=[V]CST_AOK: CONNUM=[F:CON]CONNUM: Endif
            Endif
    When 3: For [SID] Where NUM=[F:SIH]NUM and SRENUM<>""
              K=find([F:SID]SRENUM,WSRE())
              If K=0: I+=1: WSRE(I)=[F:SID]SRENUM: N(I)+=1: Endif
              If K>0: N(I)+=1: Endif
            Next
            If N>0: K=max(N())
              Read [CON]CON0=WSRE(K)
              If fstat=[V]CST_AOK: CONNUM=[F:CON]CONNUM: Endif
            Endif
  Endcase
Endif

LogicClose File [SID]
LogicClose File [SIH]
LogicClose File [CON]

End CONNUM

###################################################################################
Funprog INV_SDH(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # 1- First Order / 2 - Last Order / 3 - The majority Order
Local Char    SDHNUM(20)  # Sales delivery number


Local Char WSDH(20)(1..99)
Local Integer I, K, N(99)

Local File SINVOICED   [SID]
Local File SINVOICE    [SIH]
Local File SDELIVERY   [SDH]
I=1
Read [SIH]SIH0=NUM
If fstat=[V]CST_AOK
  Case N
    When 1: Filter [SID] Where SDHNUM<>""  and NUM=[F:SIH]NUM  #X3-46024
            Read First
            If fstat=[V]CST_AOK: Read [SDH]SDH0=[F:SID]SDHNUM
              If fstat=[V]CST_AOK: SDHNUM=[F:SDH]SDHNUM: Endif
            Endif
    When 2: Filter [SID] Where SDHNUM<>""  and NUM=[F:SIH]NUM  #X3-46024
            Read Last
            If fstat=[V]CST_AOK: Read [SDH]SDH0=[F:SID]SDHNUM
              If fstat=[V]CST_AOK: SDHNUM=[F:SDH]SDHNUM: Endif
            Endif
    When 3: For [SID] Where NUM=[F:SIH]NUM and SDHNUM<>""
              K=find([F:SID]SDHNUM,WSDNUM())
              If K=0: I+=1: WSDNUM(I)=[F:SID]SDHNUM: N(I)+=1: Endif
              If K>0: N(I)+=1: Endif
            Next
            If N>0: K=max(N())
              Read [SDH]SDH0=WSDNUM(K)
              If fstat=[V]CST_AOK: SDHNUM=[F:SDH]SDHNUM: Endif
            Endif
  Endcase
Endif

LogicClose File [SID]
LogicClose File [SIH]
LogicClose File [SDH]

End SDHNUM

###################################################################################
Funprog INV_SOH(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # 1- First Order / 2 - Last Order / 3 - The majority Order
Local Char    SOHNUM(20)  # Sales order number

Local Char WSOH(20)(1..99)
Local Integer I, K, NL(99)

Local File SINVOICED   [SID]
Local File SINVOICE    [SIH]
Local File SORDER      [SOH]
I=1

  Read [SIH]SIH0=NUM
  If fstat=[V]CST_AOK
    Filter [SID] Where NUM=[F:SIH]NUM and [F:SID]SOHNUM <>""
    Case N
      When 1: Read[SID] First
              If fstat=[V]CST_AOK
                Read [SOH]SOH0=[F:SID]SOHNUM
                If fstat=[V]CST_AOK: SOHNUM=[F:SOH]CUSORDREF: Endif
              Endif
      When 2: Read Last
              If fstat=[V]CST_AOK
                Read [SOH]SOH0=[F:SID]SOHNUM
                If fstat=[V]CST_AOK: SOHNUM=[F:SOH]CUSORDREF: Endif
              Endif
      When 3: For [SID]
                K=find([F:SID]SOHNUM,WSOH())
                If K=0: I+=1: WSOH(I)=[F:SID]SOHNUM: NL(I)+=1: Endif
                If K>0: NL(I)+=1: Endif
              Next
              If NL>0: K=max(NL())
                Read [SOH]SOH0=WSOH(K)
                If fstat=[V]CST_AOK: SOHNUM=[F:SOH]CUSORDREF: Endif
              Endif
    Endcase
    Filter [SID]
  Endif

  LogicClose File [SID]
  LogicClose File [SIH]
  LogicClose File [SOH]

End SOHNUM

###################################################################################
Funprog INV_DUDTXT(NUM,WLAN,WLEG,N)
Value Char    NUM         # Sales Invoice number
Value Char    WLAN        # Language
Value Char    WLEG        # Legislation
Value Integer N           # 1 - first vto / 2 second vto / 3 third vto

Local Char TEXT(70)       # Text

Local File SINVOICE    [SIH]
Local File GACCDUDATE  [DUD]
Local File ATEXTRA     [ATX]

If WLAN="": WLAN="ENG": Endif

Read [SIH]SIH0=NUM
If fstat=[V]CST_AOK: Read [DUD]DUD0=[F:SIH]GTE;NUM;1;N
  If fstat=[V]CST_AOK:
    Read [ATX]AXX0="TABPAM";"DESAXX";WLAN;[F:DUD]PAM;WLEG
    If fstat=[V]CST_AOK
      TEXT=[F:ATX]TEXTE
    Else
      Read [ATX]AXX0="TABPAM";"DESAXX";WLAN;[F:DUD]PAM;""
      If fstat=[V]CST_AOK
        TEXT=[F:ATX]TEXTE
      Endif
    Endif
  Endif
Endif

LogicClose File [SIH]
LogicClose File [DUD]
LogicClose File [ATX]

End TEXT

###################################################################################
Funprog INV_TXTLEG(NUM,WLAN,WLEG,N,WTXTLEG)
Value Char    NUM         # Sales Invoice number
Value Char    WLAN        # Language
Value Char    WLEG        # Legislation
Value Decimal N           # 1 - discounts  / 2 charges
Variable Char WTXTLEG

#Local Char TEXT (70)(4)
Local Char WTEXT (70), CRIT(100)
Local Integer LG, NL, NP, STA
Local Decimal DIS(4), INC(4)

Local File SINVOICE    [SIH]
Local File TABDEPAGIO  [TDA]
Local File APLSTD      [APL]

If WLAN="": WLAN="ENG": Endif

Read [SIH]SIH0=NUM
If fstat=[V]CST_AOK: Read [TDA]TDA0=[F:SIH]DEP;WLEG
  If fstat=[V]CST_AOK:
    For I=0 To 11
      If [F:TDA]DEPRAT(I)<0
        If NL<4: DIS(NL)=[F:TDA]DEPRAT(I): NL+=1: Endif   # Only 4 discounts are treated
      Elsif [F:TDA]DEPRAT(I)>0
        If NP<4: INC(NP)=[F:TDA]DEPRAT(I): NP+=1: Endif   # Only 4 charges are treated
      Endif
    Next
  Endif
Endif

Case N
  When 1: Read [APL]CLE=2281;51;WLAN
  When 2: Read [APL]CLE=2281;52;WLAN
Endcase

If fstat=[V]CST_AOK
  LG=instr(1,[F:APL]LANMES,":")
  WTEXT=seg$([F:APL]LANMES,1,LG)
Endif

For I=0 To 3
  Case N
    When 1: WTXTLEG(I)=WTEXT-num$(INC(I))
    When 2: WTXTLEG(I)=WTEXT-num$(DIS(I))
  Endcase
Next

LogicClose File [SIH]
LogicClose File [TDA]
LogicClose File [APL]

If WTXTLEG<>"": STA=[V]CST_AOK: Endif
End STA

###################################################################################
Funprog INV_VATTXT(NUM,WLAN,WLEG,N)
Value Char    NUM         # Sales Invoice number
Value Char    WLAN        # Language
Value Char    WLEG        # Legislation
Value Integer N           # Text TAX number

Local Char TEXT(70)       # Text

Local File SINVOICE    [SIH]
Local File TABVAT      [TVT]
Local File ATEXTRA     [ATX]

If WLAN="": WLAN="ENG": Endif

Read [SIH]SIH0=NUM
If fstat=[V]CST_AOK: Read [TVT]TVT0=[F:SIH]TAX(N);WLEG
  If fstat=[V]CST_AOK:
    Read [ATX]AXX0="TABVAT";"TEXAXX";WLAN;[F:SIH]TAX(N);WLEG
    If fstat=[V]CST_AOK
      TEXT=[F:ATX]TEXTE
    Else
      Read [ATX]AXX0="TABVAT";"TEXAXX";WLAN;[F:SIH]TAX(N);""
      If fstat=[V]CST_AOK
        TEXT=[F:ATX]TEXTE
      Endif
    Endif
  Endif
Endif

LogicClose File [SIH]
LogicClose File [TVT]
LogicClose File [ATX]

End TEXT

###################################################################################
Funprog INV_NUMOBS(NUM,N,NOTES)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # Notes type
Variable Char NOTES       # Notes fields

Local Char NUMFAC(20), XCODE(20)
Local Shortint STAT, LONG, INI, FIN, WRET, OKFIN
Local Integer ENDB
LONG=70
Raz NOTES()
NUMFAC=NUM
Case N
  When 1:   # General comment
    Local File ACLOB [ACB]
    Filter [ACB] Where CODBLB="CO_SIH" and IDENT1= NUMFAC
    Read [ACB] First
    If fstat=[V]CST_AOK:
      INI=instr(1,[F:ACB]CLOB,"<pre>")
      ENDB=instr(INI,[F:ACB]CLOB,"</pre>")-1
      If INI=0:  INI=1
      Else INI+=5
      Endif

      For X=0 To 4
        FIN=LONG+INI
        If FIN>ENDB and ENDB>0: FIN=ENDB: Endif
        NOTES(X)=seg$([F:ACB]CLOB,INI,FIN-1)
        If NOTES(X)<>"": INI=INI+LONG :STAT=1: Else: Break: Endif
      Next
    Endif

    LogicClose File [ACB]
  When 2,3:   Gosub READ_CLOB # Comment of head or foot
  When 4:   # Description fields (0..4)
    Local File SINVOICE    [SIH]
    Read [SIH]SIH0=NUM
    If fstat=[V]CST_AOK
      For X=0 To 2
        NOTES(X)=[F:SIH]DES(X)
        If NOTES(X)<>"": STAT=1 :Endif
      Next X
    Endif
    LogicClose File [SIH]
  Endcase

End STAT

$READ_CLOB
    Local File TEXCLOB [TXC]
    Local File SINVOICEV [SIV]

    Local Char XCODE(50)

    Filter [SIV] Where NUM=NUMFAC
    Read [SIV] First
    If fstat=[V]CST_AOK
      If N=2 :XCODE="CODE=[F:SIV]SIHTEX1" Elsif N=3: XCODE="CODE=[F:SIV]SIHTEX2": Endif
      Filter [TXC] Where evalue(XCODE)
      Read [TXC] First
      If fstat=[V]CST_AOK and [F:TXC]CODE<>"":
#        INI=instr(1,[F:TXC]TEXTE,"<pre>")  #X3-59085 (JUCON 09/10/2017)
#        ENDB=instr(INI,[F:TXC]TEXTE,"</pre>")-1
        INI=instr(1,[F:TXC]TEXTE,">")
        ENDB=instr(INI,[F:TXC]TEXTE,"</div>")-1 #X3-59085 (JUCON 09/10/2017)
        If INI=0:  INI=1
#        Else INI+=5 #X3-59085 (JUCON 09/10/2017)
        Else INI+=1
        Endif

        For X=0 To 4
          FIN=LONG+INI
          If FIN>ENDB and ENDB>0: FIN=ENDB: Endif
            NOTES(X)=seg$([F:TXC]TEXTE,INI,FIN-1)
          If NOTES(X)<>"": INI=INI+LONG :STAT=1: Else: Break: Endif
        Next
      Endif
     Endif

    LogicClose File [SIV]
    LogicClose File [TXC]

Return

###################################################################################
Funprog INV_NUMOBS_TXC(NUM,N,NOTES)
Value Char    NUM         # Invoice number
Value Decimal N           # Notes type
Variable Char NOTES       # Notes fields

  Local Char NUMSIH(20), XCODE(50)
  Local Shortint STAT, LONG, INI, FIN, ENDB

  LONG=100
  INI=1
  Raz NOTES
  NUMSIH=NUM

  Local File TEXCLOB [TXC]
  Local File SINVOICEV [SIV]

  Filter [SIV] Where NUM=NUMSIH
  Read [SIV] First
  If fstat=[V]CST_AOK
    Case N
      When 1,2,3,4: XCODE="CODE=[F:SIV]SIHTEX1"
      When 5,6,7,8: XCODE="CODE=[F:SIV]SIHTEX2"
    Endcase

    Filter [TXC] Where evalue(XCODE)
    Read [TXC] First
    If fstat=[V]CST_AOK and [F:TXC]CODE<>"":
#      INI=instr(1,[F:TXC]TEXTE,"<pre>")  #X3-59085 (JUCON 09/10/2017)
#      ENDB=instr(INI,[F:TXC]TEXTE,"</pre>")-1
      INI=instr(1,[F:TXC]TEXTE,">")
      ENDB=instr(INI,[F:TXC]TEXTE,"</div>")-1 #X3-59085 (JUCON 09/10/2017)
      If INI=0:  INI=1
#      Else INI+=5  #X3-59085 (JUCON 09/10/2017)
      Else INI+=1
      Endif

      Case N
        When 2,6: INI= LONG+INI
        When 3,7: INI=(2*LONG)+INI
        When 4,8: INI=(3*LONG)+INI
      Endcase
      FIN= INI+LONG
      If FIN>ENDB and ENDB>0: FIN=ENDB: Endif
      NOTES=seg$([F:TXC]TEXTE,INI,FIN)
      If NOTES<>"": STAT=1: Endif
    Endif
  Endif

  LogicClose File [SIV]
  LogicClose File [TXC]

End STAT


###################################################################################
Funprog INV_NUMIMP(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # N. taxes

Local Decimal    TAX(10)

Local File SINVOICE    [SIH]

   Filter [SIH] Where NUM=NUM and TAX <> ""
   Read First
   If fstat=[V]CST_AOK : TAX+=1: Endif

LogicClose File [SIH]

End TAX

###################################################################################
Funprog INV_NUMDTO(NUM,N)
Value Char    NUM         # Sales Invoice number
Value Decimal N           # N. discount
Local Decimal    DISC(10)

Local File SVCRFOOT  [SVF]

  Filter [SVF] Where VCRNUM=NUM and VCRTYP=4
  Read First
  If fstat=[V]CST_AOK : DISC+=1: Endif

LogicClose File [SVF]

End DISC

###################################################################################
Funprog INV_EDICODE_FCY(WFCY,WEDIBP)
Value Char WFCY   #
Value Char WEDIBP    # EDI Partner

  Local Char EDICODE(20)

  Local File EDIFCYPAR [EFP]
  Read [EFP]EFP0=WFCY;WEDIBP
  If fstat=[V]CST_AOK
    EDICODE=[F:EFP]EXCEDICOD
  Endif

  LogicClose File [EFP]
End EDICODE

###################################################################################
# 110811_US8 : EDI code researsh algo
Funprog INV_EDICODE_SE(WFCY,WCPY,WBPPARCOD,WBPCOD)
Value Char WFCY      # Site
Value Char WCPY      # Company
Value Char WBPPARCOD # EDI Partner
Value Char WBPCOD    # BP code

Local Char EDICODE(20)

 Local File EDIBPRCPY [EBC]
 Read [EBC]EBC0=WBPCOD;WCPY;WBPPARCOD
 If fstat=[V]CST_AOK : EDICODE=[F:EBC]EXCEDICOD : Endif
 LogicClose File [EBC]

 Local File EDIFCYPAR [EFP]
 Read [EFP]EFP0=WFCY;WBPPARCOD
 If fstat=[V]CST_AOK : EDICODE=[F:EFP]EXCEDICOD : Endif
 LogicClose File [EFP]

 If EDICODE=""
    Local File EDICPYPAR [ECP]
    Read [ECP]ECP0=WCPY;WBPPARCOD
    If fstat=[V]CST_AOK
      EDICODE=[F:ECP]EXCEDICOD
    Else
# no edi site code
    Endif
    LogicClose File [ECP]
 Endif


End EDICODE

####################################################################################
Funprog ORD_EDICODE_SE(WIDSELLER,WBPPARCOD,WBPCOD,N) # 110811_US8 : EDI code researsh algo
Value Char WIDSELLER # code EDI Seller
Value Char WBPPARCOD # EDI Partner
Value Char WBPCOD    # BP code
Value Integer N      # 1: Site, 2: Cpy, 3: Price list of the company

Local Char SELLER (20)
Local Char WCPY (20)
Local Char WFCY (20)
Local Char WPRICE (20)
#
    Local File EDIBPRCPY [EBC]
    Filter [EBC] Where PARCOD = WBPPARCOD and BPRNUM = WBPCOD and EXCEDICOD = WIDSELLER and VALID=[V]CST_AYES
    Read First
    If fstat=[V]CST_AOK
      Local File COMPANY [CPY]
      Read [CPY]CPY0=[F:EBC]CPY
      If fstat=[V]CST_AOK
        WCPY  = [F:CPY]CPY
        WPRICE= [F:CPY]PLISTC   #Not use if you do not use discounts
        WFCY= [F:CPY]MAIFCY
        LogicClose File [CPY]
      Endif
    Endif
    LogicClose File [EBC]

    Local File EDIFCYPAR [EFP]

    Filter [EFP] Where PARCOD = WBPPARCOD and EXCEDICOD = WIDSELLER
    Read First
    If fstat=[V]CST_AOK
      Local File FACILITY [FCY]
      Read [FCY]FCY0=[F:EFP]FCY
      If fstat=[V]CST_AOK
        WFCY = [F:FCY]FCY
        If WCPY="" : WCPY = [F:FCY]LEGCPY :  Endif
      Endif
      LogicClose File [FCY]
    Endif
    LogicClose File [EFP]

    If WCPY=""
      Local File EDICPYPAR [ECP]
      Filter [ECP] Where PARCOD = WBPPARCOD and  EXCEDICOD = WIDSELLER
      Read First
      If fstat=[V]CST_AOK
        Local File COMPANY [CPY]
        Read [CPY]CPY0=[F:ECP]CPY
        If fstat=[V]CST_AOK
          WCPY    = [F:CPY]CPY
          WFCY= [F:CPY]MAIFCY
          LogicClose File [CPY]
        Endif
      Endif
      LogicClose File [ECP]
    Endif
  If N = 1 : SELLER = WFCY   : Endif
  If N = 2 : SELLER = WCPY   : Endif
  If N = 3 : SELLER = WPRICE : Endif

End SELLER
#/110811_US8
###################################################################################
Funprog TRANSCODE(WFLD,WTAB,WSNS)
Value Char WFLD
Value Integer WTAB
Value Integer WSNS

  Local Char WVAL(20)
  Local File AOBJEXTR [AOR]
  If WSNS=1   # issue
    Filter [AOR] Where NUMTAB=WTAB and CODLOC=WFLD
    Read First
    If fstat=[V]CST_AOK
      WVAL=[F:AOR]CODEXT
    Endif
  Else        # receipt
    Filter [AOR] Where NUMTAB=WTAB and CODEXT=WFLD
    Read First
    If fstat=[V]CST_AOK
      WVAL=[F:AOR]CODLOC
    Endif
  Endif

  LogicClose File [AOR]
End WVAL

###################################################################################
Funprog INV_DISCTOTRAIT(STR,NUM,LIG,WDNUM,WDISQ,WDIST)
Value Char STR
Value Char NUM
Value Integer LIG
Variable Shortint WDNUM
Variable Shortint WDISQ
Variable Shortint WDIST

  Local Shortint WWOK, WNUM

  Local File SINVOICED [SID]
  Local File PRICSTRUCT [PRS]

  Read [SID]SID0=NUM;LIG
  If fstat=[V]CST_AOK:
    If [F:SID]DISCRGVAL1<>0: WNUM=0: Gosub CHECK_APL:  Endif
    If [F:SID]DISCRGVAL2<>0: WNUM=1: Gosub CHECK_APL:  Endif
    If [F:SID]DISCRGVAL3<>0: WNUM=2: Gosub CHECK_APL:  Endif
    If [F:SID]DISCRGVAL4<>0: WNUM=3: Gosub CHECK_APL:  Endif
    If [F:SID]DISCRGVAL5<>0: WNUM=4: Gosub CHECK_APL:  Endif
    If [F:SID]DISCRGVAL6<>0: WNUM=5: Gosub CHECK_APL:  Endif
    If [F:SID]DISCRGVAL7<>0: WNUM=6: Gosub CHECK_APL:  Endif
    If [F:SID]DISCRGVAL8<>0: WNUM=7: Gosub CHECK_APL:  Endif
    If [F:SID]DISCRGVAL9<>0: WNUM=8: Gosub CHECK_APL:  Endif
  Endif

LogicClose File [SID], [PRS]

End WWOK

$CHECK_APL
  Read [PRS]PRS0=1;STR
  If fstat=[V]CST_AOK:
    If [F:PRS]NPRNOTFLG(WNUM)=2
      For J=0 To 3
        If WDNUM(J)=0: WDNUM(J)=WNUM+1: WWOK=1
           WDISQ(J)=[F:PRS]INCDCR(WNUM)
           If [F:PRS]VALTYP(WNUM)<>2
             If WNUM=0 and [F:PRS]VALTYP(WNUM)=2:  WDIST(J)=0:   Else WDIST(J)=1: Endif
          Endif
          Break
        Endif
      Next
    Endif
  Endif
Return

###################################################################################
Funprog INV_DISCLIN(STR,NUM,LIG,WLAN,WLEG,WDNUM,WPNHT,WDESL,WDCTYP)
Value Char STR
Value Char NUM
Value Integer LIG
Value Char WLAN
Value Char WLEG
Variable Shortint WDNUM
Variable Shortint WPNHT
Variable Char     WDESL
Variable Shortint  WDCTYP

  Local Shortint WWOK, WNUM, K

  Local File SINVOICED [SID]
  Local File PRICSTRUCT [PRS]

  Read [SID]SID0=NUM;LIG
  If fstat=[V]CST_AOK:
    If [F:SID]DISCRGVAL1<>0: WNUM=0: Gosub CHECK_PRIST:  Endif
    If [F:SID]DISCRGVAL2<>0: WNUM=1: Gosub CHECK_PRIST:  Endif
    If [F:SID]DISCRGVAL3<>0: WNUM=2: Gosub CHECK_PRIST:  Endif
    If [F:SID]DISCRGVAL4<>0: WNUM=3: Gosub CHECK_PRIST:  Endif
    If [F:SID]DISCRGVAL5<>0: WNUM=4: Gosub CHECK_PRIST:  Endif
    If [F:SID]DISCRGVAL6<>0: WNUM=5: Gosub CHECK_PRIST:  Endif
    If [F:SID]DISCRGVAL7<>0: WNUM=6: Gosub CHECK_PRIST:  Endif
    If [F:SID]DISCRGVAL8<>0: WNUM=7: Gosub CHECK_PRIST:  Endif
    If [F:SID]DISCRGVAL9<>0: WNUM=8: Gosub CHECK_PRIST:  Endif
  Endif

LogicClose File [SID], [PRS]

If WDNUM(0)>0 : WWOK=1: Endif

End WWOK

$CHECK_PRIST
  If K<4
    Read [PRS]PRS0=1;STR
    If fstat=[V]CST_AOK:
      Local Char TEXT(70), WCRI(15)       # Text
      Local File ATEXTRA     [ATX]

      If WLAN="": WLAN="ENG": Endif
      WCRI="DESAXX("+num$(WNUM)+")"

      Read [ATX]AXX0="PRICSTRUCT";WCRI;WLAN;"1";[F:PRS]PLISTC
      If fstat=[V]CST_AOK
        TEXT=[F:ATX]TEXTE
      Endif
      LogicClose File [ATX]

      WPNHT(K) =[F:PRS]NPRNOTFLG(WNUM)
      WDNUM(K) =WNUM+1
      WDCTYP(K)=[F:PRS]INCDCR(WNUM)
      WDESL(K) =TEXT
      K+=1
    Endif
  Endif

Return

###################################################################################
Funprog INV_NUMOBSL(NUM,NL,WPAR,TLIN)
Value Char    NUM         # Delivery number
Value Integer NL          # Number line
Value Char    WPAR        # EDI partner
Variable Char TLIN        # Texts

  Local Char NUMREF(20)
  Local Integer I, WTX, WFLG
  Local Integer INI, LONG, INIB, ENDB
  Local File TEXCLOB [TXC]

  LONG=100
  NUMREF=NUM

  If WPAR="EDICOM"
    LONG=70
  Endif

  Local File SINVOICED [SID]
  Read [SID]SID0=NUMREF;NL
    If fstat=[V]CST_AOK :
      Read [TXC]TXC0=[F:SID]SIDTEX
      If fstat=[V]CST_AOK
#        INIB=instr(1,[F:TXC]TEXTE,"<pre>")
        INIB=instr(1,[F:TXC]TEXTE,">")  #X3-59085 (JUCON 09/10/2017)
#        ENDB=instr(INIB,[F:TXC]TEXTE,"</pre>")-1
        ENDB=instr(INIB,[F:TXC]TEXTE,"</div>")-1  #X3-59085 (JUCON 09/10/2017)
        If INIB=0:  INIB=1
#       Else INIB+=5
        Else INIB+=1  #X3-59085 (JUCON 09/10/2017)
        Endif
        For I=0 To 3
          INI=INIB+(LONG*I)
          FIN=LONG+INI
          If FIN>ENDB and ENDB>0: FIN=ENDB: Endif
          TLIN(I)=seg$([F:TXC]TEXTE,INI,FIN)
        Next
      Endif
      If TLIN(0)<>"":WFLG =1: Endif
      LogicClose File [SID]
    Endif

  LogicClose File [TXC]

End WFLG


