Value Integer WSEQ

  Local Char WSOH (20)
  Local Decimal WQTY
  Local File SORDERQ [SOQ]
  WSOH=NUM

  Read [SOQ]SOQ0=WSOH;LIN;WSEQ
  If fstat=[V]CST_AOK
    WQTY=[F:SOQ]QTY
   Endif

  LogicClose File [SOQ]

End WQTY

