#  Endif
#
#  LogicClose File [ITM]
#End WREF

Funprog ORD_ITMREF(WEANCODE,N)
Value Char WEANCODE           # UPC code
Value Integer N               # 1 ITMREF 2 ITMDES
  Local File ITMMASTER [ITM]
  If N=1
    Local Char WREF (20)
  Else
    Local Char WREF (30)
  Endif
  Filter [ITM] Where EANCOD=WEANCODE
  Read First
  If fstat=[V]CST_AOK
    If N=1:    WREF=[F:ITM]ITMREF
    Else:      WREF=[F:ITM]ITMDES1
    Endif
  Endif

  LogicClose File [ITM]
End WREF





###################################################################################
Funprog ORD_ITMREFBPC(WBPC,WITMREF)
Value Char WBPC              # Customer
Value Char WITMREF           # ITMREFBPC code

  Local File ITMBPC [ITU]
  Local Char WREF (20)

  Read [ITU]ITU1=WBPC;WITMREF
  If fstat=[V]CST_AOK
    WREF=[F:ITU]ITMREF
  Endif

  LogicClose File [ITU]
End WREF
###################################################################################
Funprog ORD_DSCTYP(WLPRICE,N)
Value Char    WLPRICE     # Sales Invoice number
Value Integer N           # N.invoice element

  Local Decimal AMT         # Amount or percentage

  Local File PRICSTRUCT [PRS]

  AMT=0
  Read [PRS]PRS0=1;WLPRICE
  If fstat=[V]CST_AOK
    If [F:PRS]VALTYP(N)=1 : AMT=1: Endif
  Endif

  LogicClose File [PRS]

End AMT

###################################################################################
Funprog SDH_ORDNUM(NUM,N)
Value Char    NUM         # Sales order number
Value Shortint N          #1: Order, 2: Date

  Local Char WRES(20), WSOH (20)

  Local File SORDER [SOH]
  WSOH=NUM

  Read [SOH]SOH0=NUM
  If fstat=[V]CST_AOK
    Case N
      When 1: WRES=[F:SOH]CUSORDREF
      When 2: WRES=format$("D:YYYYMMDD",[F:SOH]ORDDAT)
    Endcase
  Endif

  LogicClose File [SOH]

End WRES

###################################################################################
Funprog SDH_NUMOBSL(NUM,NL,TLIN)
Value Char    NUM         # Delivery number
Value Integer NL          # Number line
Variable Char TLIN        # Texts

  Local Char NUMREF(20)
  Local Integer I, WFLG
  Local Char ZOBS(250)
  Local Integer INI, FIN, LONG, INIB, ENDB
  LONG=70

  NUMREF=NUM
  Local File TEXCLOB [TXC]
  Local File SDELIVERYD [SDD]

  Read [SDD]SDD0=NUMREF;NL
  If fstat=[V]CST_AOK :
    Read [TXC]TXC0=[F:SDD]SDDTEX
    If fstat=[V]CST_AOK:
#      INIB=instr(1,[F:TXC]TEXTE,"<pre>") #X3-59085 (JUCON 09/10/2017)
#      ENDB=instr(INIB,[F:TXC]TEXTE,"</pre>")-1
      INIB=instr(1,[F:TXC]TEXTE,">")
      ENDB=instr(INIB,[F:TXC]TEXTE,"</div>")-1 #X3-59085 (JUCON 09/10/2017)
      If INIB=0:  INIB=1
#      Else INIB+=5 #X3-59085 (JUCON 09/10/2017)
      Else INIB+=1
      Endif

      For I=0 To 4
        INI=INIB+(70*I)
        FIN=LONG+INI
        If FIN>ENDB and ENDB>0: FIN=ENDB: Endif
        TLIN(I)=seg$([F:TXC]TEXTE,INI,FIN)
      Next
    Endif
    If TLIN(0)<>"": WFLG=1: Endif
    LogicClose File [SDD]
    LogicClose File [TXC]

  Endif

End WFLG

###################################################################################
Funprog SDH_PRHDAT(NUM)
Value Char    NUM         # Sales order number

  Local Char WRES(20), WPRH (20)

  Local File STOPREH [PRH]
  WPRH=NUM

  Read [PRH]PRH0=NUM
  If fstat=[V]CST_AOK
    WRES=format$("D:YYYYMMDD",[F:PRH]DLVDAT)
  Endif

  LogicClose File [PRH]

End WRES

###################################################################################
Funprog SDH_OPENUM(NUM,DAT)
Value Char    NUM         # Sales order number
Value Date    DAT

  Local Shortint WRES, I
  Local Char WPRESDH(20)(99)
  Local File SDELIVERY  [SDH]
  Local File SDELIVERYD [SDD]

  Link [SDD] With [SDH]SDH0=[F:SDD]SDHNUM As [XSDD] Order By Key DAT1=[F:SDH]DLVDAT

  For [XSDD]DAT1 Where [F:SDD]SOHNUM=NUM & [SDH]DLVDAT<=DAT
    I=find([SDD]SDHNUM,WPRESDH())
    If I=0: WPRESDH(WRES)=[SDD]SDHNUM: WRES+=1:Endif
  Next

  LogicClose File [SDH], [SDD]

End WRES

###################################################################################
Funprog SDH_QTYFREE(NUM,LIN)
Value Char    NUM         # Delivery number
Value Decimal LIN         # DElivery line

Local Integer FREQTY      # free qty
Local File SDELIVERYD [SDD]

Read [SDD]SDD0=NUM;LIN
If fstat=[V]CST_AOK and [F:SDD]FOCFLG=3
  FREQTY=[F:SDD]QTY
Else
  FREQTY=0
Endif

LogicClose File [SDD]

End FREQTY

###################################################################################
Funprog SDH_SOHDAT(NUM)
Value Char    NUM         # Sales order number

  Local Char WRES(20), WSOH (20)

  Local File SORDER [SOH]
  WSOH=NUM

  Read [SOH]SOH0=NUM
  If fstat=[V]CST_AOK
    WRES=format$("D:YYYYMMDD",[F:SOH]ORDDAT)
  Endif

  LogicClose File [SOH]

End WRES

###################################################################################
Funprog SDH_SOHQTY(NUM,LIN,WSEQ)
Value Char    NUM         # Sales order number
