#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du fichier BPSUPPLIER
 Local Char VALBOUT(30)(1..3)
 Local Char PARBOUT(250)(1..3)
 VALBOUT(1) = "TVF"
 PARBOUT(2) = "ABREV"
 PARBOUT(3) = "FLG"
 Call TRAITE_CHAR(VALBOUT,PARBOUT,"","INFPARCPY","INFPARCPY",3,"") From GTRAITE  
End

#------------------------------
$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub INIT_DIA
 When "INIT_DIA" : Gosub INIT_DIA
 When default
Endcase
Return

#------------------------------
$OUVRE
Return

#------------------------------
$INIT_DIA
 Local Integer ERROR
 Effzo [M:FPC]
 Call LOAD_FASPARCPY(PARAM(1),PARAM(2),val(PARAM(3)),ERROR) From GLOFCYCPY
 Affzo [M:FPC]
Return

