#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char    LSENS : LSENS="-"
Local Date    WD1   : WD1=[21/11/2006]
Local Date    WD2
Local Integer LPER  : LPER=15    
Local Integer WAN, WMO
Local Integer WNB1, WNB2
Local Decimal WMD

          WNB1 = int((LPER-1)/12) 
          WNB2 = mod((LPER-1),12) 
          If LSENS="-"
             WMD = month(WD1)-WNB2
             If WMD<1 
                WMO  = WMD+12
                WNB1+= 1 
             Else
                WMO  = WMD
             Endif
             WAN = year(WD1)-WNB1
             WD2 = gdat$(01,WMO,WAN)
          Else
             WMD = month(WD1)+WNB2
             If WMD>12 
                WMO  = WMD-12
                WNB1+= 1  
             Else
                WMO  = WMD
             Endif 
             WAN = year(WD1)+WNB1
             WD2 = gdat$(31,WMO,WAN)
          Endif

Infbox num$(WNB1)-num$(WNB2)
Infbox num$(WD2)
End

#########################################################################
# CALDATPER   Calcul d'une date à partir d'une date origine en fonction 
#             d'un type et d'un nombre de périodes et selon un sens     
#------------------------------------------------------------------------
# Entrée      LTYP     : 1=Journée
#                        2=Semaine
#                        3=Quinzaine
#                        4=Mois
#                        5=Trimestre
#                        6=Semestre
#                        7=Année
#                        8=Décade
#             LPER     : Nombre de périodes
#             LSENS    : +=en plus
#                        -=en moins 
#             LOLDDAT  : Ancienne date origine
#             LNEWDAT  : Nouvelle date origine
#-----------------------------------------------------------------------
# Sortie      LCALDAT  : Date calculée 
#                        [00/00/00] si LOLDDAT et LNEWDAT dans la même 
#                        période (pas de calcul) 
#
######################################################################## 
Subprog CALDATPER (LTYP,LPER,LSENS,LOLDDAT,LNEWDAT,LCALDAT)
Value    Integer LTYP
Value    Integer LPER
Value    Char    LSENS
Value    Date    LOLDDAT
Value    Date    LNEWDAT
Variable Date    LCALDAT

Local    Date    WD1, WD2
Local    Integer WAN, WMO, WJO
Local    Integer WNB1, WNB2
Local    Decimal WMD

LCALDAT = [00/00/00]

If LNEWDAT=[00/00/00] | LPER=0 | !find(LSENS,"+","-") : End : Endif

If year(LOLDDAT)=year(LNEWDAT)
   Case LTYP
    When 2 : If week(LOLDDAT) =week(LNEWDAT)  : End : Endif 
    When 3 : If month(LOLDDAT)=month(LNEWDAT) & int(day(LOLDDAT)/16)=int(day(LNEWDAT)/16) : End : Endif 
    When 4 : If month(LOLDDAT)=month(LNEWDAT) : End : Endif 
    When 5 : If int(month(LOLDDAT)/3)=int(month(LNEWDAT)/3) : End : Endif 
    When 6 : If int(month(LOLDDAT)/6)=int(month(LNEWDAT)/6) : End : Endif 
    When 7 : End
    When 8 : If month(LOLDDAT)=month(LNEWDAT)
                If day(LOLDDAT)<=10 
                   If day(LNEWDAT)<=10 : End : Endif
                Elsif day(LOLDDAT)<=20  
                   If day(LNEWDAT)> 10 & day(LNEWDAT)<=20 : End : Endif
                Elsif day(LOLDDAT)> 20
                   If day(LNEWDAT)> 20 : End : Endif
                Endif
             Endif  
   Endcase
Endif

WD1 = LNEWDAT
WD2 = LCALDAT

Case LTYP
 When 1 : If LSENS="-"
             WD2 = WD1-(LPER-1)
          Else
             WD2 = WD1+(LPER-1)
          Endif
 When 2 : If LSENS="-"
             WD2 = WD1-(LPER-1)*7
             WD2-= dayn(WD2)-1      # passage au lundi précédent
          Else
             WD2 = WD1+(LPER-1)*7
             WD2+= 7-dayn(WD2)      # passage au dimanche suivant
          Endif

 When 4 : WNB1 = int((LPER-1)/12) 
          WNB2 = mod((LPER-1),12) 
          If LSENS="-"
             WMD = month(WD1)-WNB2
             If WMD<1 
                WMO  = WMD+12
                WNB1+= 1 
             Else
                WMO  = WMD
             Endif
             WAN = year(WD1)-WNB1
             WD2 = gdat$(01,WMO,WAN)
          Else
             WMD = month(WD1)+WNB2
             If WMD>12 
                WMO  = WMD-12
                WNB1+= 1  
             Else
                WMO  = WMD
             Endif 
             WAN = year(WD1)+WNB1
             Case WMO
              When 1,3,5,7,8,10,12 : WJO = 31
              When 4,6,9,11        : WJO = 30
              When 2               : If mod(2000+WAN,4)=0
                                        WJO=29 
                                     Else
                                        WJO = 28
                                     Endif
             Endcase
             WD2 = gdat$(WJO,WMO,WAN)
          Endif

 When 5 : WNB1 = int((LPER-1)/4) 
          WNB2 = mod((LPER-1),4) 
          If LSENS="-"
             WMD = month(WD1)-WNB2*3
             If WMD<1 
                WMO  = WMD+12
                WNB1+= 1
             Else
                WMO  = WMD
             Endif
             If    WMO>9  WMO=10
             Elsif WMO>6  WMO=7 
             Elsif WMO>3  WMO=4 
             Else         WMO=1
             Endif  
             WAN = year(WD1)-WNB1
             WD2 = gdat$(01,WMO,WAN)
          Else
             WMD = month(WD1)+WNB2*3
             If WMD>12 
                WMO  = WMD-12
                WNB1+= 1  
             Else
                WMO  = WMD
             Endif
             If    WMO<4  WMO=3
             Elsif WMO<7  WMO=6 
             Elsif WMO>10 WMO=9 
             Else         WMO=12
             Endif  
             WAN = year(WD1)+WNB1
             Case WMO
              When 3,12 : WJO = 31
              When 6,9  : WJO = 30
             Endcase
             WD2 = gdat$(WJO,WMO,WAN)
          Endif

 When 7 : If LSENS="-"
             WAN = year(WD1)-(LPER-1)
             WD2 = gdat$(01,01,WAN)
          Else
             WAN = year(WD1)+(LPER-1)
             WD2 = gdat$(31,12,WAN)
          Endif

Endcase

LCALDAT = WD2
     
End        
