#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# UTIGPA35  Module GPAO     Table WIPCOST,  Détail coûts matières suite à modif   #
###################################################################################
Local Char DOSSIER(30)

DOSSIER = nomap
If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=[L]DOSSIER
If fstat Then
  Raz [F:ADS]
Endif
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIGPA35: Update xxxCST of WIPCOST table for materials") From LECFIC
Call MAJ_UTIGPA35(DOSSIER)
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##########################################################################
# Recalcul des zones CSTELM(8..16) et xxxCST sur les matières
# qui ont subit une modification
##########################################################################
Subprog MAJ_UTIGPA35(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","WIPCOST","fde",DOSSIER),0) <= 0     End Endif
If filinfo(filpath("FIL","MFGHEAD","fde",DOSSIER),0) <= 0     End Endif

Local File =DOSSIER+".WIPCOST" [MWI]
Local File =DOSSIER+".WIPCOST" [MWIS]
Local File =DOSSIER+".MFGHEAD" [MFG]

Local Char LCRITSUP(250), CRITERE(250)
Local Decimal LAMT
Local Integer STOP, LMFCFLG, LREWFLG
Local Integer LSIMU
Local Char LMSG(250)

Local Char LVCRNUM(GLONVCR)

####################################################
LCRITSUP = "1=1"
LSIMU=0
GPOINT="UTIGPA35" : Gosub ENTREE From EXEFNC  #CHECK IGNORE_LINE
####################################################

Link [MWIS] With [MFG]MFG0=[F:MWIS]VCRNUM
&             As [LNK]
&           Where evalue(LCRITSUP)
&               & TXNTYP=1
&               & TXNACT=3
&               & VCRTYP=10
&           Order By Key KMWI=VCRNUM;MFGTRKNUM;MFGTRKLIN;ITMREF;WIPSEQ

$LOOP_MWI
Trbegin [MWI]
Raz STOP, LMFCFLG

For [LNK]KMWI(1) Where VCRNUM>LVCRNUM
  For [LNK]KMWI(4)
    For [LNK]KMWI
        For [MWI] Where MFGTRKNUM=[F:MWIS]MFGTRKNUM
&                     & MFGTRKLIN=[F:MWIS]MFGTRKLIN
&                     & ITMREF=[F:MWIS]ITMREF
&                     & VCRTYP=[F:MWIS]VCRTYP
&                     & VCRNUM=[F:MWIS]VCRNUM
&                     & TXNTYP=1
            Raz LREWFLG
            # Resynchro CSTELM(8..16)
            LAMT = sum([F:MWI]CSTELM(8..16))
            If LAMT<>[F:MWI]AMOUNT
                If LAMT<>0
                    For I=8 To 16
                        [F:MWI]CSTELM(I)= [F:MWI]CSTELM(I)*[F:MWI]AMOUNT/LAMT
                    Next
                Else
                    [F:MWI]CSTELM(8) = [F:MWI]AMOUNT
                    For I=9 To 16
                        [F:MWI]CSTELM(I)= 0
                    Next
                Endif
                LREWFLG += 1
            Endif
            # Resynchro xxxCST
            LAMT = sum([F:MWI]MATCST)+sum([F:MWI]MACCST)+sum([F:MWI]LABCST)+[F:MWI]SCOCST+[F:MWI]INVDTACST
&                 +[F:MWI]OVEMATCST  +[F:MWI]OVEMACCST  +[F:MWI]OVELABCST  +[F:MWI]OVESCOCST
            If LAMT<>[F:MWI]AMOUNT
                If LAMT<>0
                    For I=0 To dim([F:MWI]MATCST)-1
                        [F:MWI]MATCST(I)= [F:MWI]MATCST(I)*[F:MWI]AMOUNT/LAMT
                    Next
                    For I=0 To dim([F:MWI]MACCST)-1
                        [F:MWI]MACCST(I)= [F:MWI]MACCST(I)*[F:MWI]AMOUNT/LAMT
                    Next
                    For I=0 To dim([F:MWI]LABCST)-1
                        [F:MWI]LABCST(I)= [F:MWI]LABCST(I)*[F:MWI]AMOUNT/LAMT
                    Next
                    [F:MWI]SCOCST   = [F:MWI]SCOCST*[F:MWI]AMOUNT/LAMT
                    [F:MWI]INVDTACST= [F:MWI]INVDTACST*[F:MWI]AMOUNT/LAMT
                    [F:MWI]OVEMATCST= [F:MWI]OVEMATCST*[F:MWI]AMOUNT/LAMT
                    [F:MWI]OVEMACCST= [F:MWI]OVEMACCST*[F:MWI]AMOUNT/LAMT
                    [F:MWI]OVELABCST= [F:MWI]OVELABCST*[F:MWI]AMOUNT/LAMT
                    [F:MWI]OVESCOCST= [F:MWI]OVESCOCST*[F:MWI]AMOUNT/LAMT
                Else
                    For I=0 To dim([F:MWI]MATCST)-1
                        [F:MWI]MATCST(I)= 0
                    Next
                    [F:MWI]MATCST(max(0,[F:MWI]MATGRP-1)) = [F:MWI]AMOUNT
                    For I=0 To dim([F:MWI]MACCST)-1
                        [F:MWI]MACCST(I)= 0
                    Next
                    For I=0 To dim([F:MWI]LABCST)-1
                        [F:MWI]LABCST(I)= 0
                    Next
                    [F:MWI]SCOCST   = 0
                    [F:MWI]INVDTACST= 0
                    [F:MWI]OVEMATCST= 0
                    [F:MWI]OVEMACCST= 0
                    [F:MWI]OVELABCST= 0
                    [F:MWI]OVESCOCST= 0
                Endif
                LREWFLG += 2
            Endif
            If LREWFLG
                Raz LMSG
                If mod(LREWFLG,2)=1
                    LMSG-="CSTELM"
                Endif
                If mod(LREWFLG,4)>=2
                    LMSG-="xxxCST"
                Endif
                Call ECR_TRACE("Rewrite VCRNUM="+[F:MWI]VCRNUM-"wipseq="+num$([F:MWI]WIPSEQ)-"resync :"-LMSG,1) From GESECRAN
                Rewrite [MWI]
                If fstat
                    Call FSTA("MWI") From GLOCK
                    GOK=0
                    Break
                Endif
                LMFCFLG=1
            Endif
        Next
        Break
    Next
  Next
  If !GOK
    Break
  Endif
  If LMFCFLG=1
      LVCRNUM=[F:MWIS]VCRNUM
      STOP=1
      Break
  Endif
Next
If GOK=1
    If LSIMU
        Rollback
    Else
        Commit
    Endif
    If LMFCFLG=1
        Raz [F:MFG]
        Read [MFG]MFG0=[F:MWIS]VCRNUM
        If [F:MFG]MFGTRKFLG=6
            If LSIMU
                Call ECR_TRACE("Compute MFC :"-[F:MWIS]VCRNUM,0) From GESECRAN
            Else
                Call CALMFC([F:MWIS]MFGFCY, [F:MWIS]VCRTYP, [F:MWIS]VCRNUM) From FUNWIPMFC
            Endif
        Endif
    Endif
    If STOP
        Goto LOOP_MWI
    Endif
Else
    Rollback
Endif
Filter [MWI]

End
