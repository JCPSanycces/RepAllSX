#<AdxTL>@(#)2.0.0.0 $Revision$
###############################################################################
# UUMGTRTPUR41   Reprise des signatures/Règles d'affectation     Module Achats#
###############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR41") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR41(DOSSIER)
  Call MAJ_UUMGTRTPUR41(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR41(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Local Char WNAMPADM,WNAMPAPM,WNAMPACM
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPRECORD",WNAMPADM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPROVAL",WNAMPAPM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPCONF",WNAMPACM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPADM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMPAPM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMPACM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif

##2 - On vide les fichiers selon le cas
#######################################

Local File =DOSSIER+".AWRKREG"  [AWR]
Trbegin [AWR]
Delete [AWR] Where REGLE="PSDSIG" & CPY<>""
Commit
Trbegin [AWR]
Delete [AWR] Where REGLE="POHSIG" & CPY<>""
Commit
Trbegin [AWR]
Delete [AWR] Where REGLE="POCSIG" & CPY<>""
Commit

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR41",ERR) From TRTMIG

End

##############################################################################################
##############################################################################################
Subprog MAJ_UUMGTRTPUR41(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR
Local Integer TOTNBR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR41",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR41",7,ERR) From TRTMIG : #7=Erreur
  End
Endif


Local Char WNAMPADM,WNAMPAPM,WNAMPACM
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPRECORD",WNAMPADM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPROVAL",WNAMPAPM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPCONF",WNAMPACM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR41",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#

If filinfo(filpath("FIL",WNAMPADM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR41",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPAPM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR41",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPACM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR41",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################
Gosub MIG_OUVRE From TRTMIG

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR41",2,ERR) From TRTMIG : #2=En cours
Call MIGGETTOTNBR (DOSSIER,"PAPPCONF",TOTNBR,ERR) From TRTMIG : #gerer nb lignes a traiter
Trbegin [AMY]
Call MIGSTKTOTNBR (DOSSIER,"UUMGTRTPUR41",TOTNBR,ERR) From TRTMIG
Commit
###################

Local Char WTAB_AWR (50) (adxwrb)
Local Shortint WCPT_AWR

Call ECR_TIME("UUMGTRTPUR41 tables Approval Assignment rules Process : Write AWRKREG") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR41 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"AWRKREG",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:AWR])  = 0 : Local File =DOSSIER+".AWRKREG"    [AWR]  : Endif   # Fichier X3 "Vide"

If clalev([F:PACM]) = 0 : Local File =DOSSIER+"."+WNAMPACM   [PACM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_PUR09AWR

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR41",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  FILTER -----#
Filter [PACM] Where [F:PACM]CPY<>"" Order By Key CLE=[F:PACM]APPRUL;[F:PACM]CPY

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR41" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_PAC00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PACM]APPRUL=val(TABMIGKEY(1)) & [F:PACM]CPY>TABMIGKEY(2) "
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:PACM]APPRUL>val(TABMIGKEY(1))"
Else
 CRITERE = "1=1"
Endif

Trbegin [AWR]
GOK = 1

For [PACM]CLE Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR41" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLEAWR : Endif
  Endif

  #Appel proc de migration
  #  version < V6, traitement v6
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_AWR
    If GOK<1 : Break : Endif
  Endif
  #  version < V7, traitement v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_AWR
    If GOK<1 : Break : Endif
  Endif


  # --- alimentation des champs et écriture enreg
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
  # --- alimentation des champs et écriture enreg
#  If NEWMOTEUR
#      Gosub AWR_STK : # pour stocker ref
#      WriteB [F:AWR]
#  Else
#      Write [F:AWR]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File AWRKREG, Error ="-num$(fstat),1) From GESECRAN
#      Gosub AWR_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File AWRKREG(CPY/REGLE)"-[F:AWR]CPY-[F:AWR]REGLE+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
  Gosub AWR_STK : # pour stocker ref
  WriteB [F:AWR]
  If fstat
     Call ECR_TRACE("File AWRKREG, Error ="-num$(fstat),1) From GESECRAN
     Gosub AWR_ERRTRA : # pour afficher les ref
     GOK=0 : Break
  Endif
  # End issue 108760

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = num$([F:PACM]APPRUL)
    TABMIGKEY(2) = [F:PACM]CPY
    STOP=1
    Break
  Endif
$SUITE_BOUCLEAWR
Next

$FIN_BOUCLEAWR
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR41",7,ERR) From TRTMIG : #7=Erreur
Else
    # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:AWR]
    If fstat
        Call ECR_TRACE("File AWRKREG, Error ="-num$(fstat),1) From GESECRAN
        Gosub AWR_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEAWR : #on part sur rollback
    Endif
  # Endif
 # End issue 108760
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR41",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLEAWR
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR41",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_PAC00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
GLANGUE=SAV_GLANGUE

Close Local File [AWR]
Filter [PACM]
Close Local File [PACM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"AWRKREG",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR41") From TRTMIG
Call ECR_TIME("UUMGTRTPUR41 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$OUVRE_PUR09AWR
Local File =DOSSIER+".ADOVAL"    [ADW]
Local File =DOSSIER+".ADOPAR"    [ADP]
Local File =DOSSIER+".ATEXTRA"   [AXX]
Local File =DOSSIER+".ATABZON"   [ATZ]
#-----
Local Char     WPARAME(10), SAV_GLANGUE(GLONLAN)
SAV_GLANGUE=GLANGUE
GLANGUE="FRA"
Return

################################################
$AWR_STK
Call STK (WTAB_AWR,WCPT_AWR,[F:AWR]CPY+'/'+[F:AWR]REGLE) From TRTMIG
Return
##############################################################################################
$AWR_ERRTRA
Call ERRTRA (WTAB_AWR,WCPT_AWR,"File AWRKREG(CPY/REGLE)=") From TRTMIG
Return

##############################################################################################
$MAJV6_AWR
Case [F:PACM]APPRUL
When 1 : Gosub MAJ30_AWR1
When 2 : Gosub MAJ30_AWR2
When 3 : Gosub MAJ30_AWR3
Endcase
Return

##############################################################################################
$MAJV7_AWR
Return
##############################################################################################
$MAJ30_AWR1
    Raz [F:AWR]
    [F:AWR]=[F:PACM]
    [F:AWR]REGLE="PSDSIG"
    [F:AWR]MODELE="PREQUIS"
    [F:AWR]TABLIG="PREQUISD"
    #ce paramètre n'existe plus en V6
    #Call PARAML([F:PACM]CPY,"PSHAPPNBR",WPARAME) From ADOVAL
    #[F:AWR]NBRUSR=val(WPARAME)
    If [F:AWR]NBRUSR=0 : [F:AWR]NBRUSR=1 : Endif
    For I=0 To 4
      If [F:PACM]FIL(I)<>""
        [F:AWR]TABFLD(I)=[F:PACM]FIL(I)
        [F:AWR]OPEFLD(I)=8
        [F:AWR]EXPFLD(I)="[F:"+[F:PACM]ABB(I)+"]"+[F:PACM]FLD(I)
        [F:AWR]INTFLD(I)='"'+[F:PACM]CRIDES(I)+'"'
        [F:AWR]TYPFLD(I)=[F:PACM]FLDTYP(I)
        [F:AWR]LNGFLD(I)=[F:PACM]CRILEN(I)
        [F:AWR]LIBFLD(I)=[F:PACM]PPUMNU(I)
        Read [ATZ] CODZONE=[F:PACM]FIL(I);[F:PACM]FLD(I)
        If !fstat & ([F:ATZ]DIME>1 | [F:ATZ]CODACT<>"")
          [F:AWR]EXPFLD(I)+="("+num$([F:PACM]CRIIND(I))+")"
        Endif
        [F:AWR]NBRFLD+=1
      Else
        Break
      Endif
    Next I
    I=[F:AWR]NBRFLD
    [F:AWR]TABFLD(I)="PREQUISD"
    [F:AWR]OPEFLD(I)=7
    [F:AWR]EXPFLD(I)="func TRTX3FNC.CNVCPY([F:PSD]PSHFCY,[F:PSD]CUR,[F:PSD]CHGTYP,datesyst,[F:PSD]LINAMT)"
    [F:AWR]INTFLD(I)='"Valeur maximum"'
    [F:AWR]TYPFLD(I)="DCB"
    [F:AWR]LNGFLD(I)=11.2
    [F:AWR]NBRFLD+=1
    Call PARAML([F:PACM]CPY,"PSHFBUCIR",WPARAME) From ADOVAL
    If val(WPARAME)=2
      I=[F:AWR]NBRFLD
      [F:AWR]TABFLD(I)="PREQUISD"
      [F:AWR]OPEFLD(I)=2
      [F:AWR]EXPFLD(I)="[F:PSD]FBUFLG"
      [F:AWR]INTFLD(I)='"Dépassement budgétaire"'
      [F:AWR]TYPFLD(I)="M"
      [F:AWR]LIBFLD(I)=1
      [F:AWR]NBRFLD+=1
    Endif
    Call MAJTEXTRA ("Signature demandes d'achat","AWRKREG","INTIT",[F:AWR]REGLE,[F:AWR]CPY) From ATEXTRA
    If GOK<1
      Call ECR_TRACE("File ATEXTRA AWRKREG INTIT FRA PSDSIG, Error ="-num$(fstat),-1) From GESECRAN
      GOK=1
    Endif
Return
##############################################################################################
$MAJ30_AWR2
    Raz [F:AWR]
    [F:AWR]=[F:PACM]
    [F:AWR]REGLE="POHSIG"
    [F:AWR]MODELE="PORDER"
    #ce paramètre n'existe plus en V6
    #Call PARAML([F:PACM]CPY,"POHAPPNBR",WPARAME) From ADOVAL
    #[F:AWR]NBRUSR=val(WPARAME)
    If [F:AWR]NBRUSR=0 : [F:AWR]NBRUSR=1 : Endif
    For I=0 To 4
      If [F:PACM]FIL(I)<>""
        [F:AWR]TABFLD(I)=[F:PACM]FIL(I)
        [F:AWR]OPEFLD(I)=8
        [F:AWR]EXPFLD(I)="[F:"+[F:PACM]ABB(I)+"]"+[F:PACM]FLD(I)
        [F:AWR]INTFLD(I)='"'+[F:PACM]CRIDES(I)+'"'
        [F:AWR]TYPFLD(I)=[F:PACM]FLDTYP(I)
        [F:AWR]LNGFLD(I)=[F:PACM]CRILEN(I)
        [F:AWR]LIBFLD(I)=[F:PACM]PPUMNU(I)
        Read [ATZ] CODZONE=[F:PACM]FIL(I);[F:PACM]FLD(I)
        If !fstat & ([F:ATZ]DIME>1 | [F:ATZ]CODACT<>"")
          [F:AWR]EXPFLD(I)+="("+num$([F:PACM]CRIIND(I))+")"
        Endif
        [F:AWR]NBRFLD+=1
      Else
        Break
      Endif
    Next I
    I=[F:AWR]NBRFLD
    [F:AWR]TABFLD(I)="PORDER"
    [F:AWR]OPEFLD(I)=7
    [F:AWR]EXPFLD(I)="func TRTX3FNC.CNVCPY([F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,[F:POH]TOTORD)"
    [F:AWR]INTFLD(I)='"Valeur maximum"'
    [F:AWR]TYPFLD(I)="DCB"
    [F:AWR]LNGFLD(I)=11.2
    [F:AWR]NBRFLD+=1
    Call PARAML([F:PACM]CPY,"POHFBUCIR",WPARAME) From ADOVAL
    If val(WPARAME)=2
      I=[F:AWR]NBRFLD
      [F:AWR]TABFLD(I)="PORDER"
      [F:AWR]OPEFLD(I)=2
      [F:AWR]EXPFLD(I)="[F:POH]FBULINNBR>0"
      [F:AWR]INTFLD(I)='"Dépassement budgétaire"'
      [F:AWR]TYPFLD(I)="M"
      [F:AWR]LIBFLD(I)=1
      [F:AWR]NBRFLD+=1
    Endif
    Call MAJTEXTRA ("Signature commandes d'achat","AWRKREG","INTIT",[F:AWR]REGLE,[F:AWR]CPY) From ATEXTRA
    If GOK<1
      Call ECR_TRACE("File ATEXTRA AWRKREG INTIT FRA POHSIG, Error ="-num$(fstat),-1) From GESECRAN
      GOK=1
    Endif
Return
##############################################################################################
$MAJ30_AWR3
    Raz [F:AWR]
    [F:AWR]=[F:PACM]
    [F:AWR]REGLE="POCSIG"
    [F:AWR]MODELE="PORDER"
    #ce paramètre n'existe plus en V6
    #Call PARAML([F:PACM]CPY,"POCAPPNBR",WPARAME) From ADOVAL
    #[F:AWR]NBRUSR=val(WPARAME)
    If [F:AWR]NBRUSR=0 : [F:AWR]NBRUSR=1 : Endif
    For I=0 To 4
      If [F:PACM]FIL(I)<>""
        [F:AWR]TABFLD(I)=[F:PACM]FIL(I)
        [F:AWR]OPEFLD(I)=8
        [F:AWR]EXPFLD(I)="[F:"+[F:PACM]ABB(I)+"]"+[F:PACM]FLD(I)
        [F:AWR]INTFLD(I)='"'+[F:PACM]CRIDES(I)+'"'
        [F:AWR]TYPFLD(I)=[F:PACM]FLDTYP(I)
        [F:AWR]LNGFLD(I)=[F:PACM]CRILEN(I)
        [F:AWR]LIBFLD(I)=[F:PACM]PPUMNU(I)
        Read [ATZ] CODZONE=[F:PACM]FIL(I);[F:PACM]FLD(I)
        If !fstat & ([F:ATZ]DIME>1 | [F:ATZ]CODACT<>"")
          [F:AWR]EXPFLD(I)+="("+num$([F:PACM]CRIIND(I))+")"
        Endif
        [F:AWR]NBRFLD+=1
      Else
        Break
      Endif
    Next I
    I=[F:AWR]NBRFLD
    [F:AWR]TABFLD(I)="PORDER"
    [F:AWR]OPEFLD(I)=7
    [F:AWR]EXPFLD(I)="func TRTX3FNC.CNVCPY([F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,GHIDATE,[F:POH]TOTVLT)"
    [F:AWR]INTFLD(I)='"Valeur maximum"'
    [F:AWR]TYPFLD(I)="DCB"
    [F:AWR]LNGFLD(I)=11.2
    [F:AWR]NBRFLD+=1
    Call MAJTEXTRA ("Signature contrats d'achat","AWRKREG","INTIT",[F:AWR]REGLE,[F:AWR]CPY) From ATEXTRA
    If GOK<1
      Call ECR_TRACE("File ATEXTRA AWRKREG INTIT FRA POCSIG, Error ="-num$(fstat),-1) From GESECRAN
      GOK=1
    Endif
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR41(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR41(APPLI)
End

