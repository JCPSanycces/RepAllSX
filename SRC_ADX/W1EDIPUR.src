$ON_TESTFLGNO
Onevent INIT_AREA Call D_TESTFLGNO(zc) From W1EDIPUR
Onevent BEFORE_INPUT Call AS_TESTFLGNO(zc) From W1EDIPUR
Return

Subprog D_TESTFLGNO(VALEUR)
Variable Integer VALEUR
If varinit([M]TESTFLGNO,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TESTFLGNO(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

