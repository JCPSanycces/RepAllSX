Call CONTSEL("EPR","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "PARCODFIN" : GZNUM = 55009 : Endif
If !mkstat
 ## Action STD
 Call C_PARCODFIN(VALEUR) From EDIPURSTD
 If mkstat : GERR = 1 : GZONE = "PARCODFIN" : GZNUM = 55009 : Endif
Endif
Gosub _AFF
End

Subprog S_PARCODFIN(VALEUR)
