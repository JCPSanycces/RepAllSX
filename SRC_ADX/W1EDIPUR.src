#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EDIPUR 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:07"
A_USER  = "DOC"
A_STAMP = "20181109230407"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask EDIPUR [DIA]
Gosub HORODAT
Local Inpbox "EDIPUR" From GFONCTION At A_STAMP With A_WINDPREV Mask [DIA] As [SIM_]
Grizo [DIA]5
Grizo [DIA]10
Grizo [DIA]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DIA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=5
X1(1)=1 : X2(1)=74 : Y1(1)=6 : Y2(1)=7
X1(2)=1 : X2(2)=74 : Y1(2)=8 : Y2(2)=12
Return

$ON_NUMBATCHFIN
Onevent BEFORE_INPUT Call AS_NUMBATCHFIN(zc) From W1EDIPUR
Onevent CONTROL Call C_NUMBATCHFIN(zc) From W1EDIPUR
Return

Subprog AS_NUMBATCHFIN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NUMBATCHFIN(VALEUR) From EDIPURSTD
If mkstat=2
 [M]NUMBATCHFIN(INDIC) = VALEUR
 Affzo NUMBATCHFIN(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_NUMBATCHFIN(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_NUMBATCHFIN(VALEUR) From EDIPURSTD
If mkstat : GERR = 1 : GZONE = "NUMBATCHFIN" : GZNUM = 54967 : Endif
Gosub _AFF
End

$ON_CREDATDEB
Onevent BEFORE_AREA Gosub AV_CREDATDEB From W1EDIPUR
Return

$AV_CREDATDEB
Chgfmt [M]CREDATDEB(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_CREDATFIN
Onevent BEFORE_INPUT Call AS_CREDATFIN(zc) From W1EDIPUR
Onevent CONTROL Call C_CREDATFIN(zc) From W1EDIPUR
Onevent BEFORE_AREA Gosub AV_CREDATFIN From W1EDIPUR
Return

$AV_CREDATFIN
Chgfmt [M]CREDATFIN(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_CREDATFIN(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_CREDATFIN(VALEUR) From EDIPURSTD
If mkstat=2
 [M]CREDATFIN(INDIC) = VALEUR
 Affzo CREDATFIN(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_CREDATFIN(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_CREDATFIN(VALEUR) From EDIPURSTD
If mkstat : GERR = 1 : GZONE = "CREDATFIN" : GZNUM = 54969 : Endif
Gosub _AFF
End

$ON_PARCODDEB
Onevent CONTROL Call C_PARCODDEB(zc) From W1EDIPUR
Onevent BEFORE_INPUT Call AS_PARCODDEB(zc) From W1EDIPUR
Return

Subprog AS_PARCODDEB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(52052,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PARCODDEB(zc) From W1EDIPUR
Onkey   2 Titled GBOUTS Call S_PARCODDEB(zc) From W1EDIPUR
Onkey 144 Titled GBOUTP Call P_PARCODDEB(zc) From W1EDIPUR
Onkey 146 Titled GBOUTA Call SA_PARCODDEB(zc) From W1EDIPUR
Gosub _AFF
End

Subprog C_PARCODDEB(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("EPR","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "PARCODDEB" : GZNUM = 55008 : Endif
Gosub _AFF
End

Subprog S_PARCODDEB(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "EPR"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_PARCODDEB(VALEUR)
Variable Char    VALEUR()
Call OBJET("EPR",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_PARCODDEB(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EPR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PARCODDEB(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EPR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_PARCODFIN
Onevent BEFORE_INPUT Call AS_PARCODFIN(zc) From W1EDIPUR
Onevent CONTROL Call C_PARCODFIN(zc) From W1EDIPUR
Return

Subprog AS_PARCODFIN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(52052,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_PARCODFIN(VALEUR) From EDIPURSTD
If mkstat=2
 [M]PARCODFIN(INDIC) = VALEUR
 Affzo PARCODFIN(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_PARCODFIN(zc) From W1EDIPUR
Onkey   2 Titled GBOUTS Call S_PARCODFIN(zc) From W1EDIPUR
Onkey 144 Titled GBOUTP Call P_PARCODFIN(zc) From W1EDIPUR
Onkey 146 Titled GBOUTA Call SA_PARCODFIN(zc) From W1EDIPUR
