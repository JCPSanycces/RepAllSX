#<AdxTL>@(#)9.0.0.0 $Revision$
#######################################################################
# Sûˋlection pour Remplacement service
# La saisie initiale est une saisie de FENETRE sous "forme" de dialogue
#######################################################################
# Fenûˆtre principale :
# Affichage / modif / Validation des nouveaux liens de nomenclatures
# le masque de validation est le mûˆme que pour la suppression (BOSRPL1)
# GA 24/11/2005 remplacement d'un service nomenclature de sous-traitance
# GA 22/03/2006 table BOMS remplacûˋe par BOMD avec CPNTYP=7
#######################################################################
$ACTION
Case ACTION
    When "INIT":      Gosub INIT
    When "CONTROLE":  Gosub CONTROLE
    When "EXEC":      Gosub EXEC
    When "TERMINE":   Gosub TERMINE
    When "SORTIE":    Gosub SORTIE
    When "DEBUT":     If BOITE = "FBOSRPL" : Gosub DEBUTRPL : Else : Gosub DEBUT : Endif
    When "END","ABA": PARAM(1) = "END"
Endcase
Return

#######################################################################
$INIT
Local    Integer OK
Local    Char    TEX(15)(30), ERR_TRA(132)

If clalev([F:ACC]) = 0 : Local File ACCES     [ACC] : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT [TBO] : Endif
If clalev([F:ITB]) = 0 : Local File ITMBOM    [ITB] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:ITS]) = 0 : Local File ITMSALES  [ITS] : Endif
If clalev([F:BOH]) = 0 : Local File BOM       [BOH] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD      [BOD] : Endif
If clalev ([F:TFO])= 0 : Local File TABFOR    [TFO] : Endif

Local Mask BOSRPL0 [BOS0]

Return

#######################################################################
$CONTROLE
# paramû´tre en retour de la fenûˆtre initiale
If PARAM(1) = "END"
  FIN = 1
  Return
Endif

# ouverture prûˋalable des masques pour le chargement
If clalev([M:BOSH]) = 0 : Local Mask BOSRPLH [BOSH] : Endif : # pour entûˆte d'ûˋcran rûˋsultat
If clalev([M:BOS1]) = 0 : Local Mask BOSRPL1 [BOS1] : Endif : # pour alternatives de sous-traitance
Raz [BOS1]

Default Mask [BOS0]
OK = 1

Call EXTRACT(OK)

# "Erreur d'accû´s sur fichier Entûˆte de nomenclature ..."
If OK = 0
    GMESSAGE = mess(12,100,1)-"BOM:"-[F:BOD]ITMREF-num$([F:BOD]BOMALT)
    GERR = 1
    Return
Endif

If [M:BOS1]NBLIG = 0
    GMESSAGE = mess(113,199,1)
    GERR = 1
Endif

If GERR <> 1 : TMP = 1 :  Endif

Return

#######################################################################
$EXEC
# si on a cliquûˋ 'Fin' dans la fenûˆtre principale, on ne fait rien  :
If PARAM(1) = "END"
    SAI = 1
    Raz PARAM(1)
    Raz [M:BOS0]
Else
    Gosub VALID
Endif
Return

#######################################################################
$TERMINE
Close Local Mask [BOSH], [BOS1]
Raz [M:BOS0]
[M:BOS0]APPDAT = date$
TRA = 1
SAI = 1
Return

#######################################################################
$SORTIE
Raz GFONBOD
Raz [M:BOS0]
Return

#######################################################################
$DEBUT
[M:BOS0]APPDAT = date$
Affzo [M:BOS0]
Return

#######################################################################
$DEBUTRPL
# Affichage des ecrans de validation  "Rûˋsultat remplacement"
[M:BOSH] = [M:BOS0]
Affzo [BOSH]
Affzo [BOS1]

Diszo [BOSH]RPLCPN, UPDCPN
If [M:BOS1]NBLIG = 0 : Grizo [M:BOS1] : Endif
Return

###################################################################################
$FILTRE

Raz XCRITERE
Raz XCRITERE1
Raz XCRITERE2

XCRITERE1 = "1=1"

If [M]ITMREFDEB <> ""
    XCRITERE = "[F:BOH]ITMREF >= [M]ITMREFDEB"
    Gosub LOAD_CRITERE
Endif

If [M]ITMREFFIN <> ""
    XCRITERE = "[F:BOH]ITMREF <= [M]ITMREFFIN"
    Gosub LOAD_CRITERE
Endif

If ([M]ALTDEB <> 0 | [M]ALTFIN <> 0)
    XCRITERE = "[F:BOH]BOMALT >= [M]ALTDEB & [F:BOH]BOMALT <= [M]ALTFIN"
    Gosub LOAD_CRITERE
Endif
Return

############################################################
$LOAD_CRITERE
If len(XCRITERE)+len(XCRITERE1)+1 < 250
  If XCRITERE1 <> ""
      XCRITERE1 += "&"
  Endif
  XCRITERE1 += XCRITERE
Else
  If XCRITERE2 <> ""
     XCRITERE2 += "&"
  Endif
  XCRITERE2 += XCRITERE
Endif
Return

#######################################################################
# Ce sous-pro extrait les enreg selon les sûˋlections et charge [M]
Subprog EXTRACT(OK)
#######################################################################
Variable Integer OK
Local Integer    ILIG, NBTEX
Local    Char    XCRITERE(255)
Local    Char    XCRITERE1(255)
Local    Char    XCRITERE2(255)
Local    Char    FORMULE1(255)


Gosub FILTRE
If XCRITERE2 = "" : XCRITERE2 = "1=1" : Endif

# analyse prûˋsence formule de sûˋlection
If [M]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=31;[M]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

ILIG=0

Link [BOD] With [BOH]BOH0=[F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP, [ITM]ITM0=[F:BOD]ITMREF,
&               [TBO]TBO0=[F:BOD]BOMALTTYP;[F:BOD]BOMALT As [BODX]
&          Where CPNITMREF = [M:BOS0]RPLCPN &
&                BOMSTRDAT < [M:BOS0]APPDAT &
&               (BOMENDDAT > [M:BOS0]APPDAT | BOMENDDAT=[0/0/0]) &
&               evalue(XCRITERE1) & evalue(XCRITERE2) & evalue(FORMULE1)

For [BODX]
   Gosub CHARG_ECR
   If OK = 0 : Break : Endif
Next

[M:BOS1]NBLIG = ILIG
End

#######################################################################
$CHARG_ECR
Raz mkstat

# vûˋrifier droit de modif sur alternative
Call CTLMODALT([F:BOD]BOMALT,[F:BOD]BOMALTTYP) From TRTBOM
Raz GMESSAGE
If mkstat : Return : Endif

ILIG += 1
nolign = ILIG

# trop de liens d'alternative de sous-traitance. Le tableau sera incomplet
If ILIG > dim([M:BOS1]VALID)
    ILIG -= 1
    GMESSAGE = mess(512,199,1)
    GERR = 2
Else
    [M:BOS1] = [F:BOD]
    [M:BOS1]VALID(nolign-1)  = 2
    If [F:BOD]ITMREF = [M:BOS0]UPDCPN
        [M:BOS1]VALID(nolign-1) = 1
    Endif
#    [M:BOS1]ITMDES1(nolign-1)= [F:ITM]ITMDES1
    [M:BOS1]BOMSTRDAT(nolign-1) = [M:BOS0]APPDAT
Endif

Return

#######################################################################
$VALID
Global Integer GNIV, GBOHLLC
Local Integer  SYNCLLC, J
#Local Char    BOHMAX(20)(1..300)           # tableau des entetes par alternative
#Local Integer LLCMAX(1..300)               # avec les LLC max
#Local Integer ALT(1..300), NBALT, I, J, K  # et les numûˋros d'alternatives
Local Char    ABLIG(3)
Local Integer PROD_COMM                    # distinction de l'ûˋcran car MODI est utilisûˋ dans les 2 cas

Call OUVRE_TRACE(mess(115,199,1)) From LECFIC
Call PRTSCR("BOSRPL0","BOS0","",0,1) From ATRTX3
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(" ",0) From GESECRAN
ERR_TRA  = mess(35,197,1) - [M:BOS0]RPLCPN - mess(37,197,1)-[M:BOS0]UPDCPN
ERR_TRA -= mess(38,197,1) - format$("D:DD[/]MM[/]YY",[M:BOS0]APPDAT)
Call ECR_TRACE(ERR_TRA,0) From GESECRAN

# maj du lien existant et crûˋation du nouveau lien
Call DEBTRANS From GLOCK
Trbegin [BOD]
  # Alternatives de sous-traitance
  PROD_COMM = 1
  For nolign = 1 To [M:BOS1]NBLIG
      If [M:BOS1]VALID(nolign-1) = 2
          Default Mask [BOS1]
          Gosub MODI
          If GOK<1 : Break : Endif
      Endif
  Next
If GOK>0 : Commit : Else Rollback : Endif
If GOK>0 & SYNCLLC
   #Il est prûˋfûˋrable de lancer une resynchronisation des codes de plus bas niveau !
   Call ECR_TRACE(mess(198,196,1),1) From GESECRAN
   SYNCLLC=0
Endif
Call FERME_TRACE From LECFIC
Return

#######################################################################
$MODI
ERR_TRA = ""

# Rûˋecriture de l'ancien lien
Read [BOD]BOD0=[M]ITMREF(nolign-1);[M]BOMALT(nolign-1);[M]BOMSEQ(nolign-1);[M:BOS0]RPLCPN;[M]BOMALTTYP(nolign-1)
If [F:BOD]BOMENDDAT > [M:BOS0]APPDAT - 1 | [F:BOD]BOMENDDAT = [0/0/0]
   [F:BOD]BOMENDDAT = [M:BOS0]APPDAT - 1
   [F:BOD]UPDDAT    = date$
   [F:BOD]UPDUSR    = GUSER
   [F:BOD]EXPNUM    = [C]EXPORT
   # sr 07.02 demande 15091
   # point d'entrûˋe  pour mise û  jour supplûˋmentaires sur l'ancien lien
   GPOINT = "BOSMAJ" : Gosub ENTREE From EXEFNC

   Rewrite [BOD]
   If fstat
     ERR_TRA = "BOD:"-[M]ITMREF(nolign-1)-num$([M]BOMALT(nolign-1))-num$([M]BOMSEQ(nolign-1))-[M:BOS0]RPLCPN
     ERR_TRA -= mess(13,100,1)
     Goto ERR
   Endif
Endif

# Crûˋation du nouveau lien
Raz [F:BOD]
[F:BOD] = [M]
[F:BOD]CPNITMREF = [M:BOS0]UPDCPN
ABLIG = "BOD" : # pour zones standard
Gosub INICRE_LIG From TABLEAUX

#######################################################################
$ECRIT
Write [BOD]
# Si le cpn existe dûˋjû  on en crûˋûˋ un avec un nô¯ de sûˋquence +1
If fstat=3
   ERR_TRA="BOD:"-[M]ITMREF(nolign-1)-num$([M]BOMALT(nolign-1))-num$([M]BOMSEQ(nolign-1))-[M:BOS0]UPDCPN
   ERR_TRA -= mess(22,100,1) : # Fiche dûˋjû  existante
   Call ECR_TRACE(ERR_TRA,0) From GESECRAN
   # Signaler : "Crûˋation de nouveau lien avec sûˋquence supûˋrieure"
   ERR_TRA = mess(115,197,1)
   Call ECR_TRACE(ERR_TRA,0) From GESECRAN
   ERR_TRA = ""

   [F:BOD]BOMSEQ += 1
   Goto ECRIT  : # retente l'ûˋcriture avec seq + 1 (juste aprû´s et non pas BOMSTP plus loin)
Endif

# Issue 118021 GH 07/09/2016 - the standard routine is now used
#   Read [ITB]ITB0 = [F:BOD]ITMREF;[F:BOD]BOMALT;2
#   If fstat
#      ERR_TRA = "ITMBOM:"-[F:BOD]ITMREF-num$([F:BOD]BOMALT)-mess(12,100,1)
#      Goto ERR
#   Endif
## les composûˋs/alternatives n'ûˋtant pas forcûˋment dans l'ordre, il faut chercher
## dans le tableau et distinguer le cas de la crûˋation d'une occurence (21/06/99)
#   If I = 0
#      J = 1
#   Else
#      J = find([F:BOD]BOMALT,ALT)
#   Endif
#   If J = 0 | I = 0 : # soit on n'a pas trouvûˋ,soit le tableau est vide
#      I += 1
#      ALT(I)    = [F:BOD]BOMALT
#      LLCMAX(I) = [F:ITB]LLC
#      BOHMAX(I) = [F:ITB]ITMREF
#   Elsif [F:ITB]LLC > LLCMAX(J)
#      LLCMAX(J) = [F:ITB]LLC
#      BOHMAX(J) = [F:ITB]ITMREF
#   Elsif [F:ITB]LLC = LLCMAX(J) & BOHMAX(J) <> [F:ITB]ITMREF
#      BOHMAX(J) = ""
#   Endif
J=GOK : GOK=1
Call UPDLLC([F:BOD]BOMALTTYP, [F:BOD]BOMALT, [F:BOD]ITMREF, [F:BOD]CPNITMREF, [F:BOD]CPNTYP, +1) From SUBBODB
If GOK<1 : SYNCLLC=1 : Endif
GOK=J

# ûˋcriture trace de la modification
ERR_TRA  = mess(153,198,1)+":" - [F:BOD]ITMREF+"/"+num$([F:BOD]BOMALT)+"/"+num$([F:BOD]BOMSEQ) - mess([F:BOD]BOMALTTYP,224,1)
Call ECR_TRACE(ERR_TRA,0) From GESECRAN
Raz ERR_TRA
Return

#######################################################################
$ERR
#  ecrire la trace d'eventuelle erreur
If ERR_TRA <> ""
  Call ECR_TRACE(ERR_TRA,1) From GESECRAN
#  ou la clûˋ de l'enregistrement crûˋûˋ
Else
  ERR_TRA=[M]ITMREF(nolign-1)-num$([M]BOMALT(nolign-1))-num$([M]BOMSEQ(nolign-1))-[M:BOS0]UPDCPN
  Call ECR_TRACE(ERR_TRA,0) From GESECRAN
Endif
Return

################################################################
# ETIQUETTES SUR ZONES
################################################################
Subprog C_BOMSTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR < [F:BOH]BOHSTRDAT
   mkstat = 2 : GMESSAGE = mess(51,199,1)+"/"+mess(52,199,1)
Endif
End

################################################################
Subprog C_BOMENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [F:BOH]BOHENDDAT & [F:BOH]BOHENDDAT <> [0/0/0]
  mkstat = 2 : GMESSAGE = mess(51,199,1) +"/"+ mess(52,199,1)
Endif
End

################################################################
Subprog C_APPDAT(VALEUR)
Variable Date     VALEUR
If VALEUR < date$
   mkstat = 2 : GMESSAGE = mess(114,199,1)
Endif
End

################################################################
Subprog C_VALID(VALEUR)
Variable Integer  VALEUR
If VALEUR=2 & GFONBOD="BOR" & [M]ITMREF(nolign-1)=[M:BOS0]UPDCPN
  mkstat = 2 : GMESSAGE = mess(116,199,1)
Endif
End

################################################################
Subprog AVANT_NBLIG
# lire BOH l'entete correspondant
Read [BOH]BOH0 = [M]ITMREF(nolign-1);[M]BOMALT(nolign-1);[M]BOMALTTYP(nolign-1)
End

################################################################
Subprog C_UPDCPN(VALEUR)
Variable Char VALEUR()
If VALEUR = [M]RPLCPN : mkstat=2 : End  Endif
End

################################################################
Subprog B2_UPDCPN(VALEUR)
Variable Char    VALEUR()
Read [ITM]ITM0 = [M]RPLCPN
VALEUR = [F:ITM]RPLITM
End

################################################################
Subprog B3_UPDCPN(VALEUR)
Variable Char    VALEUR()
Read [ITS]ITS0 = [M]RPLCPN
VALEUR = [F:ITS]SBSITM
End

################################################################
Subprog IB_UPDCPN
# B2 mess(316,198,1): "ARTICLE remplacement";B3 mess(324,198,1): "ARTICLE substitution"
Read [ITM]ITM0 = [M]RPLCPN
If fstat | [F:ITM]RPLITM = ""
   GBOUT2 = ""
Endif

Read [ITS]ITS0 = [M]RPLCPN
If fstat | [F:ITS]SBSITM = ""
   GBOUT3 = ""
Endif
End

######################################################################################
## Etiquette ajoutûˋe par le superviseur (ûˋcran BOSRPL1) 25/11/2005 11:20:44 (GA)
######################################################################################
Subprog AS_CSTFLG(VALEUR)
Variable Integer VALEUR
End

################################################################
Subprog AS_PICPRN(VALEUR)
Variable Integer VALEUR
End


######################################################################################
## Etiquette ajoutûˋe par le superviseur (ûˋcran BOSRPL0) 07/04/2006 09:51:48 (LLCX)
######################################################################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]ITMREFFIN = VALEUR : Endif
End

################################################################
Subprog AM_ALTDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : [M]ALTFIN = VALEUR : Endif
End

################################################################
Subprog C_ALTFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]ALTDEB : mkstat = 2 : Endif
End
