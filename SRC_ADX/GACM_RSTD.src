#<AdxTL>@(#)5.0.0.0 $Revision$
# Représentation GACM

###########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When "GCM"
    Case [L]AEVENT
         When "AREAD_AFTER" : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
$AREAD_AFTER
Local File GLED [LED]
Local Integer I
For I=1 To len(mess(0,2644,1))
 this.LISLED(I).LEDTYP = I
 If this.LISLED(I).CFMAUT<>2 & this.LISLED(I).LED=""
  ASTATUS = fmet this.LISLED(I).ASETATTRIBUTE('RNDOPTBAL','$isHidden','true')
  ASTATUS = fmet this.LISLED(I).ASETATTRIBUTE('TYPRAT','$isHidden','true')
  ASTATUS = fmet this.LISLED(I).ASETATTRIBUTE('DACRAT','$isHidden','true')
 Endif
 If this.LISLED(I).FLGVCRRAT=2
  ASTATUS = fmet this.LISLED(I).ASETATTRIBUTE('TYPRAT','$isHidden','true')
 Endif
 If this.LISLED(I).CFMAUT<>2
  ASTATUS = fmet this.LISLED(I).ASETATTRIBUTE('ORILEDTYP','$isHidden','true')
 Endif

 Call LEC_LED(this.LISLED(I).LED) From CPTLEC
 If [F:LED]BAL<>2
  ASTATUS = fmet this.LISLED(I).ASETATTRIBUTE('RNDOPTBAL','$isHidden','true')
 Endif
Next
Return

