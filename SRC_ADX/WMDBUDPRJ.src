#<AdxTL>@(#)0.0.0.0 $Revision$
# Supervisor
## BI-DIMENSION ## Synchronization rule BUDPRJ

$OUVRE
Local Char FILTRE(250)
OUVTAB = GDOSSIER+".PROJET" : If clalev([F:PRJ])=0 : Local File =OUVTAB [PRJ] : Endif
OUVTAB = GDOSSIER+".ATEXTRA" : If clalev([F:AXX1])=0 : Local File =OUVTAB [AXX1] : Endif
OUVTAB = GDOSSIER+".ATEXTRA" : If clalev([F:AXX2])=0 : Local File =OUVTAB [AXX2] : Endif
OUVTAB = "Link [PRJ]"
Link [PRJ] With
& [AXX1]AXX0 = "PROJET";"DESTRA";GLANGUE;[F:PRJ]PRJ;"",
& [AXX2]AXX0 = "PROJET";"SHOTRA";GLANGUE;[F:PRJ]PRJ;""
& As [LNK_]
& Order By Key CLE = [PRJ]PRJ
FILTRE = ""
Return

$FERME
If clalev([F:PRJ]) : Close local File [PRJ] : Endif
If clalev([F:AXX1]) : Close local File [AXX1] : Endif
If clalev([F:AXX2]) : Close local File [AXX2] : Endif
Return

$DCLE
Local Char    DCLE(GLONAVA)(1..1)
Local Integer DTYP(1..1)
Local Integer NBDCLE
NBDCLE = 1
DCLE(1) = "PRJ"
DTYP(1) =  7
Return

$CHARGE_CLE
If dim([F:AAA_]PRJ)>0
 [F:AAA_]PRJ = [F:PRJ]PRJ
Endif
Return

########################################################################
# Return the filter necessary for incremental delete in synchroonization
Subprog GET_FLTDELINC(PFLT)
Variable Clbfile PFLT
PFLT = "1=1"
Append PFLT, " & [F:AAA_]PRJ=[F:PRJ]PRJ"

End

$MAJFLD
### PRJ
[L]FLD="PRJ"
[L]FORMULE='[F:PRJ]PRJ'
If dim([F:AAA_]PRJ)>0
 [F:AAA_]PRJ = [F:PRJ]PRJ
Endif

### DES
[L]FLD="DES"
[L]FORMULE='[F:AXX1]TEXTE'
If dim([F:AAA_]DES)>0
 [F:AAA_]DES = [F:AXX1]TEXTE
Endif

### DESSHO
[L]FLD="DESSHO"
[L]FORMULE='[F:AXX2]TEXTE'
If dim([F:AAA_]DESSHO)>0
