Endif

### REAEND
[L]FLD="REAEND"
[L]FORMULE='[F:PRJ]REAEND'
If dim([F:AAA_]REAEND)>0
 [F:AAA_]REAEND = [F:PRJ]REAEND
Endif

### GCF
[L]FLD="GCF"
[L]FORMULE='[F:PRJ]GCF'
If dim([F:AAA_]GCF)>0
