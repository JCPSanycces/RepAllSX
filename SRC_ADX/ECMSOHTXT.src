#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################
# Program Name: ECMSOHTEX (XJZORDTXT)
# Description:  Sales Order Comments Sub-Program
# Created Date: 09/07/2015
# Created By:   Dom Nash XM Developments
#-------------------------------------------------------
# Input Parameters:
# SONBR   - Sales Order Number
# COMMENTS - Sales Order Comments
# TXTLOC    - 0=Header;1=Footer;
#-------------------------------------------------------
# Output Parameters:
# RESULT  - This is an error containing any errors
########################################################
Subprog SOH_TEXT(SONBR, COMMENTS, TXTLOC, RESULT)

    Value Char SONBR
    Value Char COMMENTS
    Value Integer TXTLOC
    Variable Char RESULT() ()

    Local Integer ERR : ERR = 0

    # Validate Input Data
    ######################

    #Open TEXCLOB Table
    If clalev([F:TXC]) = 0 : Local File TEXCLOB [TXC] : Endif

    # Open SORDER Table & validate SONBR
    If clalev([F:SOH])= 0 : Local File SORDER [SOH] : Endif
    Read [F:SOH]SOH0=SONBR
    If fstat
        RESULT(ERR) = mess(9,7730,1)    # Invalid sales order number ("Invalid Sales Orderzzzzzzzzzzzz")
        ERR = ERR + 1
    Else
        If COMMENTS = ""
            RESULT(ERR) = mess(22,7730,1)  # Comment text required ("No comments detectedzzzzzzzzzzzzzzz")
            ERR = ERR + 1
        Endif
    Endif

    # Create Comments
    ######################
    # Only continue if no errors
    If ERR = 0
            # Return the Success Message
            RESULT(0) = mess(16,7730,1)   # Success

            Local Integer NEXTID : NEXTID = 0
            Local Char  NXTCOD : NXTCOD = ""

            Read [F:TXC]TXC0 Last
            NEXTID = uniqid([TXC]) + 1

            NXTCOD = format$("N0:8",num$(NEXTID))

            Raz [F:TXC]
            [F:TXC]CODE = "SOH~" + NXTCOD                    #UNIQ CODE
            [F:TXC]IDENT3 = "SOH~" + NXTCOD
            [F:TXC]CREUSR = mess(24,7730,1)                  # Create User
            [F:TXC]CREDAT = date$                            # Create Date
            [F:TXC]TEXTE = COMMENTS                          # Comments
            Write [F:TXC]

        #Assign Msg Key to order
        If TXTLOC = 0
            [F:SOH]SOHTEX1 = [F:TXC]CODE
        Else
            [F:SOH]SOHTEX2 = [F:TXC]CODE
        Endif
        Rewrite [F:SOH]

        Close Local File [TXC]
        Close Local File [SOH]
    Endif
End

$INITWS
    # Used to test the web service
    #SONBR = "SO000135"
    #COMMENTS = "comments again"
Return

$RESULTWS

Return





