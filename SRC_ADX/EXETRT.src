#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","EXETRT","EXETRT",3,"XYEXETRT") From GTRAITE
End

##############################################################
$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "EXEC"      : Gosub EXEC
 When "SEL_LISTE" : Gosub SELTRT
Endcase
Return

$INIT
Local Integer OK
Local Char    TRAIT(GLONADC)
Return

$INIT_DIA
[M:DIA]TRAIT = ""
Return

$EXEC
[L]TRAIT = [M:DIA]TRAIT
Close Local Mask
Close Local File
Run =[L]TRAIT
Return

##############################################################
$SELTRT
Local Char     BID(120), RACINE(GLONADC)
Local Integer  I , J , K
# Issue 82576 - 2012-06-04 by VPO : enlever les fichiers UUMG*
#Local Char     TEX(GLONADC+10)(1..200) , TEXTE(max(80,GLONDES))(1..200,1..2) , TRT(80)(1..200)
Local Char     TEX(GLONADC+10)(1..200) , TEXTE(max(80,GLONDES))(1..200,1..2) , TRT(80)(1..400)
Local File     ADICTRT [ADC]
BID = nomap
If adxmother<>nomap
 BID -= adxmother
Endif
If adxmother(1)<>nomap & adxmother(1)<>adxmother
 BID -= adxmother(1)
Endif

If VALEUR=""
 RACINE="UU"
Else
 RACINE=VALEUR
Endif

Call SYSTEME2(adxmac(0),'lsadx -a "'+BID+'" TRT'-RACINE+'*adx',"",K,TRT) From ORDSYS
K = min(K,dim(TRT))

NBTEX = 0
For I=1 To K
 J = instr(1,TRT(I),".")
 If J
  TRT(I) = left$(TRT(I),J-1)
 Endif
 # Issue 82576 - 2012-06-04 by VPO : enlever les fichiers UUMG*
 #If !find(TRT(I),TEX(1..NBTEX))
 If toupper(left$(TRT(I),4))<>"UUMG" & !find(TRT(I),TEX(1..NBTEX))
  NBTEX += 1
  TEX(NBTEX) = TRT(I)
  Call DES_TRAIT(TEX(NBTEX),TEXTE(NBTEX,2))
  # Issue 82576 - 2012-06-04 by VPO : enlever les fichiers UUMG*
  If NBTEX>=dim(TEX) : Break : Endif
 Endif
Next I

TIT(0) = mess(19,123,1) : # Traitement
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(82,123,1) : # Intitulé

FORCE = 1
Return

##############################################################
## Etiquettes de l'écran EXETRT
##############################################################

Subprog C_TRAIT(VALEUR)
Variable Char VALEUR()
Local Integer OKTRT
Call EXISTE_ADX("","",VALEUR,OKTRT) From ORDSYS
If !OKTRT
 GMESSAGE = mess(90,123,1) : # Traitement inexistant
 mkstat = 2 : End
Endif
End

Subprog DES_TRAIT(TRAIT,DES)
Value    Char TRAIT()
Variable Char DES()
Local Char BID(120)
Local Integer J
If clalev([F:ADC])=0 : Local File ADICTRT [ADC] : Endif
Onerrgo RIEN
Call INFO_ADX("","",TRAIT,20,BID) From ORDSYS
Onerrgo
If left$(BID,9)="$Revision"
 J=instr(9,BID,"$")
 If J
  BID=vireblc(right$(BID,J+1),2)
 Endif
Endif
DES = BID
If len(DES)=0
 Read [ADC]ADC0=TRAIT
 If !fstat
  DES = [F:ADC]DES
 Endif
Endif
End

$RIEN
Resume

Subprog IB_TRAIT
GBOUT1="" : # pas d'éditeur
End

