#<AdxTL>@(#)90.0.0.0 $Revision$
########################################################### 
#Sous programme de saisie inventaire numéro de série 
# LLIN = Numéro ligne écran INV2  
# LSER = Nombre de numéros de série (si validé)
# LRET = En retour : 2 = validation saisie 
Subprog INVSER(LLIN,LSER,LRET) 
Variable Integer LLIN 
Variable Decimal LSER  
Variable Integer LRET
# 
Local Integer CHOIX 
Local Integer SAVOBJET 
Local Char    SAVPROG 
Local Integer WPRE 
Local Integer WNOLIGN 
Local Integer WFSTAT  
Local Integer WBOU(1..GNBBOU)   
#   
Local Char    WCSER(GLONSER)  
# 
WNOLIGN = nolign 
Call SAVBOUT From GESECRAN 
SAVOBJET = GOBJET 
SAVPROG  = GPROGRAMME   
GOBJET   = 0  
#  
For I = 1 To GNBBOU   
  WBOU(I) = 0   
Next I   
WBOU(GVALI) = 1
WBOU(GABAN) = 1
Call SETBOUT(WBOU) From GESECRAN     
LRET = 0 
LSER = 0
#   
Local Mask INV3[INV3] 
Local Dlgbox Mask [INV3] 
&    Button mess(14,123,1),        mess(5,123,1) 
&    With left$(mess(14,123,1),1), left$(mess(5,123,1),1) 
&    Coded GSTAOK,                 GSTAFIN 
&    Titled mess(66,195,1) 
&    As [INV3] 
Boxact [INV3] 
# 
Raz [M:INV3] 
Read [ITM]ITM0=[M:INV2]ITMREF(LLIN) 
If fstat  
  Raz [F:ITM] 
Endif 
[M:INV3]CUNLISNUM = [M:INV0]CUNLISNUM 
[M:INV3]ITMLISNUM = [M:INV2]ITMLISNUM(LLIN) 
If dim([M:INV3]LOT) > 0
  [M:INV3]LOT     = [M:INV2]LOT(LLIN)
Endif
If dim([M:INV3]LOC) > 0
  [M:INV3]LOC     = [M:INV2]LOC(LLIN)
Endif
[M:INV3]ITMREF    = [F:ITM]ITMREF 
#[M:INV3]ITMDES1   = [F:ITM]ITMDES1 
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:INV3]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:INV3]STU       = [F:ITM]STU 
[M:INV3]QTYSTUNEW = [M:INV2]QTYSTUNEW(LLIN) 
Affzo [M:INV3]5-10
Gosub TRT_INI 
$INVSER1 
Boxinp [INV3] Using CHOIX 
  Case CHOIX 
    When GSTAOK, GSTARET : 
      Gosub TRT_VAL 
      Goto INVSER2  
    When GSTAFIN, GSTAESC : 
      Gosub TRT_ANN  
      Goto  INVSER2 
    When GSTAFIR : 
      Gosub TRT_PRE 
    When GSTALAS : 
      Gosub TRT_DER 
    When GSTAPRE :  
      WPRE = 0 
      Gosub PAG_PRE 
    When GSTASUI :  
      Gosub PAG_SUI 
  Endcase 
Goto INVSER1 
$INVSER2 
# 
nolign     = WNOLIGN 
GOBJET     = SAVOBJET 
GPROGRAMME = SAVPROG 
Call RESTBOUT From GESECRAN 
End  
########################################################### 
$SET_NOL 
Local Integer NOL  
NOL = nolign-1 
Return
########################################################### 
$AFF_TAB 
WFSTAT = fstat  
Grizo [M:INV3]5  
Affzo [M:INV3]10 
fstat = WFSTAT 
Return 
########################################################### 
$DEL_TAB 
Effzo [M:INV3]10 
Return 
########################################################### 
$TRT_INI 
#Positionnement fichier selon les choix 
Filter [CUS]  Where CUNLISNUM = [M:INV3]CUNLISNUM         & 
&                   ITMLISNUM = [M:INV3]ITMLISNUM 
&               Order By Key CUS0 
Affzo [INV3]5 
########################################################### 
#Lecture premier selectionné 
Raz [F:CUS] 
Read [CUS] First 
# 
$TRT_INI0 
If fstat Goto TRT_INI1 
Endif 
Gosub TRT_SEL 
If ISEL  = 2 
  WCSER  = [F:CUS]SERNUM 
  Gosub PAG_SUI 
  Return 
Endif 
Read [CUS]CUS0 Next  
Goto TRT_INI0 
# 
$TRT_INI1 
WBOU(GPREM) = 0   
WBOU(GSUIV) = 0   
WBOU(GPREC) = 0   
WBOU(GDERN) = 0   
Call SETBOUT(WBOU) From GESECRAN   
Gosub DEL_TAB 
[M:INV3]BASPAG2 = 0 
nolign          = 1 
#Call MESSAGE(mess(99,100,1)) From GESECRAN  
Return 
########################################################### 
$PAG_SUI 
# 
Local Integer WDIM 
WDIM = (dim([M:INV3]SERNUM)*0.9) 
If [F:CUS]SERNUM = WCSER  
  WBOU(GPREM) = 0   
  WBOU(GPREC) = 0   
  WBOU(GSUIV) = 1   
  WBOU(GDERN) = 1   
Else   
  WBOU(GPREM) = 1   
  WBOU(GPREC) = 1   
  WBOU(GSUIV) = 1   
  WBOU(GDERN) = 1   
Endif  
Call SETBOUT(WBOU) From GESECRAN 
Gosub DEL_TAB 
[M:INV3]BASPAG2 = 0 
nolign          = 1 
$PAG_SUI1 
If fstat = 0 
  Gosub TRT_SEL 
  If ISEL = 2   
    If [M:INV3]BASPAG2 < WDIM 
      [M:INV3] = [F:CUS]  
      nolign          += 1 
      [M:INV3]BASPAG2 += 1 
      Goto PAG_SUI2 
    Else 
      Goto PAG_SUI3 
    Endif 
  Else 
    Goto PAG_SUI2 
  Endif   
Else  
  WBOU(GSUIV) = 0   
  WBOU(GDERN) = 0   
  Call SETBOUT(WBOU) From GESECRAN    
  Goto PAG_SUI3 
Endif 
#Lecture suivant 
$PAG_SUI2 
Read [CUS]CUS0 Next 
Goto PAG_SUI1 
$PAG_SUI3 
Gosub AFF_TAB 
nolign = 1 
Return 
########################################################### 
#Pour selections ultérieures 
$TRT_SEL 
ISEL = 2 
Return 
########################################################### 
#Traitement page précedente 
$PAG_PRE 
If WPRE <> 0 
  WLEC = dim([M:INV3]SERNUM)-1 
Else 
  WLEC = ([M:INV3]BASPAG2+dim([M:INV3]SERNUM)) 
  If fstat : WLEC -= 1 : Endif 
Endif 
While WLEC <> 0  
Read [CUS]CUS0 Prev 
  If fstat  
    Break 
  Endif 
  Gosub TRT_SEL 
  If ISEL = 2 
    WLEC -= 1 
  Endif 
Wend 
If fstat  
  Read [CUS]CUS0 First 
Endif 
# 
Gosub PAG_SUI 
Return 
########################################################### 
$TRT_PRE 
#Lecture premier 
Read [CUS]CUS0 First 
Gosub PAG_SUI 
Return 
########################################################### 
$TRT_DER 
Read [CUS]CUS0 Last 
WPRE = 1 
Gosub PAG_PRE 
Return 
############################################################ 
$TRT_VAL 
Local Integer VS 
Local Decimal WNEW : WNEW = int([M:INV3]QTYSTUNEW) 
Local Decimal WCPT : WCPT = 0 
Filter [CUS] Where CUNLISNUM = [M:INV3]CUNLISNUM & 
&                  ITMLISNUM = [M:INV3]ITMLISNUM 
&            Order By Key CUS0 
For [CUS] With Lock 
  If [F:CUS]EXIFLGTMP <> 0 
    [F:CUS]EXIFLG = [F:CUS]EXIFLGTMP 
    Rewrite [CUS] 
      If fstat : GOK = 0 : Call FSTA("CUS") From GLOCK : Break : Endif 
  Endif  
  If [F:CUS]EXIFLG = 2 
    WCPT +=1 
  Endif 
Next 
Filter [CUS] 
If WCPT <> WNEW 
  Call MESSAGE(mess(4,187,1)+" ("+num$(WNEW)+" / "+num$(WCPT)+")") From GESECRAN 
Else 
  VS = 2 
  Call OUINON(mess(5,187,1),VS) From GESECRAN 
    If VS = 2  
      LSER = WCPT 
      LRET = 2 
    Endif 
Endif  
Return  
############################################################ 
$TRT_ANN 
Filter [CUS] Where CUNLISNUM = [M:INV3]CUNLISNUM & 
&                  ITMLISNUM = [M:INV3]ITMLISNUM 
&            Order By Key CUS0 
For [CUS] With Lock 
  If [F:CUS]EXIFLGTMP <> 0 
    [F:CUS]EXIFLGTMP = 0 
    Rewrite [CUS] 
      If fstat : GOK = 0 : Call FSTA("CUS") From GLOCK : Break : Endif 
  Endif 
  If [F:CUS]EXIFLG = 0 
    Delete [CUS] 
      If fstat : GOK = 0 : Call FSTA("CUS") From GLOCK : Break : Endif 
  Endif 
Next 
Filter [CUS] 
Return  
############################################################
Subprog AS_SERNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  mkstat = 2
Endif
End
############################################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR() 
VALEUR = vireblc(VALEUR,1)
VALEUR = toupper(VALEUR) 
Gosub SET_NOL
If VALEUR = ""
  mkstat = 2
  End
Endif
Call UNICITE(VALEUR,[M:INV3]SERNUM(0..[M:INV3]BASPAG2-1)) From OBJDIV
If mkstat
  End
Endif
Read [STS]STS0=[F:ITM]ITMREF;VALEUR 
  If fstat = 0 
    Local Integer VS : VS = 1
    Call AVERTIR(mess(60,187,1),VS) From GESECRAN
    If VS = 1
      mkstat = 2 
    Else
      mkstat = 0
    Endif 
  Endif   
End
############################################################
Subprog AM_EXIFLG(VALEUR)
Variable Integer VALEUR 
Gosub SET_NOL
Readlock [CUS]CUS0=[M:INV3]CUNLISNUM;[M:INV3]ITMLISNUM;[M:INV3]SERNUM(NOL) 
Case fstat  
  When 0 : 
    If [F:CUS]EXIFLG = 0
      Delete [CUS]
      If fstat : GOK = 0 : Call FSTA("CUS") From GLOCK : End : Endif 
    Else
      [F:CUS]EXIFLGTMP = VALEUR 
      Rewrite [CUS] 
      If fstat : GOK = 0 : Call FSTA("CUS") From GLOCK : End : Endif 
    Endif
  When 4, 5 : 
    Raz [F:CUS] 
    [F:CUS] = [M:INV3] 
    Read [STS]STS0=[F:ITM]ITMREF;[M:INV3]SERNUM(NOL)
    If fstat 
      [F:CUS]EXIFLG  = 0 
      [F:CUS]VCRTYP  = 9
      [F:CUS]VCRNUM  = [M:INV3]CUNLISNUM
    Else
      [F:CUS]EXIFLG  = 2
    Endif  
    [F:CUS]EXIFLGTMP = VALEUR 
    [F:CUS]CREUSR    = GUSER 
    [F:CUS]EXPNUM    = [C]EXPORT
    [F:CUS]CREDAT    = date$ 
    Write [CUS]  
      If fstat : GOK = 0 : Call FSTA("CUS") From GLOCK : End : Endif 
Endcase 
End

