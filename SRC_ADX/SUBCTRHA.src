#<AdxTL>@(#)0.0.0.0 $Revision$
$DECL_VAR_LOCAL
#----------------------------------#
# Local variable declaration       #
#----------------------------------#
Local  Char     WNUM(GLONVCR), WPOQLNK(16)
Local  Integer  I, J, K, WERR
Local  Shortint NOL, WPICK, SAVNBLIG
Local  Libelle  WDEBPICK
Local  Decimal  WQTESTU
Local  Char WMESS(250)
Local  Integer MY_STATUS, WRET
Return
#-------------------------------------------------------------#
$DEFLIG
#----------------------------------#
# Lines file definition            #
#----------------------------------#
Default Mask [CTRH1]
Default File [CTRD]
CRIT   = 'CTRNUM="'+[M:CTRH]CTRNUM+'"'
FICLIG = "CONTAINERD"
ABLIG  = "CTRD"
ZONLIG = "CTRLIN"
Return
#-------------------------------------------------------------#
$VALLIG
#---------------------------------------------------------------#
# After each creation, modification or deletion lines           #
#---------------------------------------------------------------#
Case TRTLIG
  When  "C"   Gosub VALLIG_CRE
  When  "M"   Gosub VALLIG_UPD
  When  "A"   Gosub VALLIG_DEL
Endcase
Return
#-------------------------------------------------------------#
$VALLIG_CRE
#--------------------------------#
# After creation lines           #
#--------------------------------#
Gosub INS_LIG
Return
#-------------------------------------------------------------#
$VALLIG_UPD
#--------------------------------#
# After modification lines       #
#--------------------------------#
If SIGN = -1 Gosub UPD_LIG Endif
Return
#-------------------------------------------------------------#
$VALLIG_DEL
#--------------------------------#
# After deletion lines           #
#--------------------------------#
If GREP <> "A" Gosub DEL_LIG : Endif
Return
#-------------------------------------------------------------#
$INS_LIG
#---------------------------------------#
# Insert one line in container class    #
#---------------------------------------#
Local Integer WPOS
WPOS = fmet WCONTAINER.ADDLINE("CTRD",[V]CST_ALASTPOS)
If WPOS = [V]CST_ANOTDEFINED
  #--The insertion was not possible
  GMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'CTRD','CONTAINER')
  GOK=0 : GERR=1
  Return
Endif
WCONTAINER.CTRD(WPOS).CTRNUM = [M:CTRH]CTRNUM
WCONTAINER.CTRD(WPOS).CTRLIN = [M:CTRH1]CTRLIN(nolign-1)
WCONTAINER.CTRD(WPOS).POHNUM = [M:CTRH1]POHNUM(nolign-1)
WCONTAINER.CTRD(WPOS).POPLIN = [M:CTRH1]POPLIN(nolign-1)
WCONTAINER.CTRD(WPOS).POQSEQ = [M:CTRH1]POQSEQ(nolign-1)
WCONTAINER.CTRD(WPOS).ITMREF = [M:CTRH1]ITMREF(nolign-1)
WCONTAINER.CTRD(WPOS).QTYUOM = [M:CTRH1]QTYUOM(nolign-1)
WCONTAINER.CTRD(WPOS).UOM = [M:CTRH1]UOM(nolign-1)
WCONTAINER.CTRD(WPOS).QTYPUU = [M:CTRH1]QTYPUU(nolign-1)
WCONTAINER.CTRD(WPOS).PUU = [M:CTRH1]PUU(nolign-1)
WCONTAINER.CTRD(WPOS).QTYSTU = [M:CTRH1]QTYSTU(nolign-1)
WCONTAINER.CTRD(WPOS).STU = [M:CTRH1]STU(nolign-1)
WCONTAINER.CTRD(WPOS).QTYWEU = [M:CTRH1]QTYWEU(nolign-1)
WCONTAINER.CTRD(WPOS).LINWEU = [M:CTRH1]LINWEU(nolign-1)
WCONTAINER.CTRD(WPOS).QTYVOU = [M:CTRH1]QTYVOU(nolign-1)
WCONTAINER.CTRD(WPOS).LINVOU = [M:CTRH1]LINVOU(nolign-1)
WCONTAINER.CTRD(WPOS).LINAMT = [M:CTRH1]LINAMT(nolign-1)
WCONTAINER.CTRD(WPOS).NETCUR = [M:CTRH1]NETCUR(nolign-1)
WCONTAINER.CTRD(WPOS).LEGCPY = [M:CTRH1]LEGCPY(nolign-1)
WCONTAINER.CTRD(WPOS).CHGTYP = [M:CTRH1]CHGTYP(nolign-1)
WCONTAINER.CTRD(WPOS).ORDDAT = [M:CTRH1]ORDDAT(nolign-1)
WCONTAINER.CTRD(WPOS).EECICT = [M:CTRH1]EECICT(nolign-1)
WCONTAINER.CTRD(WPOS).UOMPUUCOE = [M:CTRH1]UOMPUUCOE(nolign-1)
Return
#-------------------------------------------------------------#
$DEL_LIG
#---------------------------------------#
# Delete one line in container class    #
#---------------------------------------#
Local Integer WIND, WRET
Raz WRET

#--- Find the AUUID of the del line
WIND = find([F:CTRD]AUUID, WCONTAINER.CTRD(1..maxtab(WCONTAINER.CTRD)).AUUID)
If WIND <> 0
  WRET=fmet WCONTAINER.ADELLINE ("CTRD", WCONTAINER.CTRD(WIND).AORDER)
  If WRET>=[V]CST_AERROR
    GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'CTRD','CONTAINER')
    GOK=0 : GERR=1
    Return
  Endif
Endif
Return
#-------------------------------------------------------------#
$UPD_LIG
#---------------------------------------#
# Update one line in container class    #
#---------------------------------------#
Local Integer WIND
#--- Find the AUUID of the update line
WIND = find([F:CTRD]AUUID, WCONTAINER.CTRD(1..maxtab(WCONTAINER.CTRD)).AUUID)
  If WIND <> 0
    #--- Affect new values(M class) in the container class
    WCONTAINER.CTRD(WIND).CTRNUM = [M:CTRH]CTRNUM
    WCONTAINER.CTRD(WIND).CTRLIN = [M:CTRH1]CTRLIN(nolign-1)
    WCONTAINER.CTRD(WIND).POHNUM = [M:CTRH1]POHNUM(nolign-1)
    WCONTAINER.CTRD(WIND).POPLIN = [M:CTRH1]POPLIN(nolign-1)
    WCONTAINER.CTRD(WIND).POQSEQ = [M:CTRH1]POQSEQ(nolign-1)
    WCONTAINER.CTRD(WIND).ITMREF = [M:CTRH1]ITMREF(nolign-1)
    WCONTAINER.CTRD(WIND).QTYUOM = [M:CTRH1]QTYUOM(nolign-1)
    WCONTAINER.CTRD(WIND).UOM = [M:CTRH1]UOM(nolign-1)
    WCONTAINER.CTRD(WIND).QTYPUU = [M:CTRH1]QTYPUU(nolign-1)
    WCONTAINER.CTRD(WIND).PUU = [M:CTRH1]PUU(nolign-1)
    WCONTAINER.CTRD(WIND).QTYSTU = [M:CTRH1]QTYSTU(nolign-1)
    WCONTAINER.CTRD(WIND).STU = [M:CTRH1]STU(nolign-1)
    WCONTAINER.CTRD(WIND).QTYWEU = [M:CTRH1]QTYWEU(nolign-1)
    WCONTAINER.CTRD(WIND).LINWEU = [M:CTRH1]LINWEU(nolign-1)
    WCONTAINER.CTRD(WIND).QTYVOU = [M:CTRH1]QTYVOU(nolign-1)
    WCONTAINER.CTRD(WIND).LINVOU = [M:CTRH1]LINVOU(nolign-1)
    WCONTAINER.CTRD(WIND).LINAMT = [M:CTRH1]LINAMT(nolign-1)
    WCONTAINER.CTRD(WIND).NETCUR = [M:CTRH1]NETCUR(nolign-1)
    WCONTAINER.CTRD(WIND).LEGCPY = [M:CTRH1]LEGCPY(nolign-1)
    WCONTAINER.CTRD(WIND).CHGTYP = [M:CTRH1]CHGTYP(nolign-1)
    WCONTAINER.CTRD(WIND).ORDDAT = [M:CTRH1]ORDDAT(nolign-1)
    WCONTAINER.CTRD(WIND).EECICT = [M:CTRH1]EECICT(nolign-1)
    WCONTAINER.CTRD(WIND).UOMPUUCOE = [M:CTRH1]UOMPUUCOE(nolign-1)
  Endif
Return
#-------------------------------------------------------------#
$INICRE_LIG
#----------------------------#
# Before line write          #
#----------------------------#
[F:CTRD]=[M:CTRH]
Return
#-------------------------------------------------------------#
$OUVRE
#-------------------------------#
# before the window opening     #
#-------------------------------#
#--- To use the class CRUD instead of the object CRUD
ANOWRITE = 1
#---
If !clalev([M:PLCW])   Local Mask PCRITLCC  [PLCW]  : Endif
Local File CONTAINERD  [CTRD1]
Local File TABCONTAINER  [TCTR]
Local File COMPANY  [CPY]
Local File TABCUR  [TCU]
Raz [M:PLCW]
#---- Local variables
Gosub DECL_VAR_LOCAL
#--- Array variables
Gosub DECLARE From TABLEAUX
#--- Container class : global for sub prog ANUCOD
Global Instance WCONTAINER Using C_CONTAINER
# Issue RIN - 2016-03-14 by MAE : Déclaration des variables pour les requetes
Local Char REQUETE(255)(2)
Local Integer BASE
Local Decimal WSHIQTYSTU, WRCPQTYSTU
Case GTYPDBA
    When 1 : BASE=3 : # Oracle
    When 2 : BASE=5 : # Sql
    When 3 : BASE=2 : # Cisam
    When 4 : BASE=4 : # DB2
  Endcase
# End issue RIN
Return
#-------------------------------------------------------------#
$OUVRE_BOITE
#-------------------------------#
# After the window opening      #
#-------------------------------#
#----- Curbox name -----#
Global Char     GBOXPO6(10), GBOXSD2(10)
GBOXPO6="GAU_CHE"+num$(find("PO6",OBJLIS(1..8))) : # Porder picking
Return
#-------------------------------------------------------------#
$RAZCRE
If WCONTAINER<> null : FreeGroup WCONTAINER :Endif
#--- Class instanciation
WCONTAINER = NewInstance C_CONTAINER AllocGroup null
[L]MY_STATUS = fmet WCONTAINER.AINIT()
If [L]MY_STATUS >= [V]CST_AERROR
  #--- Header errors
  GMESSAGE = func LCCLIB.MAXMSG(WCONTAINER)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
Endif
#I don't have to reinit the screen because I don't have init in my class
#SetInstance [F:CTRH] With WCONTAINER
#[M:CTRH]=[F:CTRH]
#Affzo [M:CTRH]
Raz [M:PLCW]
Return
#-------------------------------------------------------------#
$INICRE
Return
#-------------------------------------------------------------#
$FILTRE
#-----------------------------#
# Filtre                      #
#-----------------------------#
Default File [CTRH]
Return
#-------------------------------------------------------------#
$EXEBOUT
#-------------------------------------------#
# After execution toolbar buttons           #
#-------------------------------------------#
Case BOUT
  When "1"  : Gosub APRESBOUT_CRIT
  When "2"  : Gosub CALCUL_TOTAUX
Endcase
Return
#-------------------------------------------------------------#
$SETBOUT
#--- No duplication
Call VIREBOUT (CHAINE,"D")    From GOBJET

If !find(GREP,"C","D") and !find("CONSPIA",GNAVIG(1..GPILNAV)) Then CHMEN += "O" Endif # FGR 01/06/2015 : X3SUIVI104697
Return
#-------------------------------------------------------------#
$APRESBOUT_CRIT
#---------------------#
# Picking criteria    #
#---------------------#
If !GIMPORT : Gosub TIROIR : Endif
Return
#-------------------------------------------------------------#
$HINTCLE
#-----------------------------------------------------------#
Case currbox
  When GBOXPO6 : HINTLIS(val(right$(GBOXPO6,8)))="POQ2"
Endcase
Return
#-------------------------------------------------------------#
$CREATION
#----------------------------------#
# Container creation               #
#----------------------------------#
# Issue 110325
Local Integer I
# Collection reinit in case of modification after a first creation with error
For I=1 To maxtab(WCONTAINER.CTRD)
  If (WCONTAINER.CTRD(I) <> null and find(WCONTAINER.CTRD(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0)
    WRET=fmet WCONTAINER.ADELLINE ("CTRD", WCONTAINER.CTRD(I).AORDER)
    If WRET<>[V]CST_AOK
      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'CTRD','CONTAINER')
      GOK=0 : GERR=1
      Return
    Endif
    Endif
Next
# End issue 110325
Gosub CREATION From TABLEAUX
If GOK<1 : Return : Endif
#--- Assign the class properties
SetInstance WCONTAINER With [F:CTRH]
WCONTAINER.BPSNUM = [M:CTRH2]BPSNUM
#--- AINSERT method
MY_STATUS = fmet WCONTAINER.AINSERT()
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WCONTAINER)
  If GOK=0 : Return : Endif
Endif
#--- Affect the [M]class with the Syracuse class
[M:CTRH2]CUR  = WCONTAINER.CUR
[M:CTRH2]TOTLINAMT = WCONTAINER.TOTLINAMT
[M:CTRH2]TOTLINWEU = WCONTAINER.TOTLINWEU
[M:CTRH2]TXWOU = WCONTAINER.TXWOU
[M:CTRH2]TXWOU2 = WCONTAINER.TXWOU2
[M:CTRH2]TOTLINVOU = WCONTAINER.TOTLINVOU
[M:CTRH2]MAXWEI = WCONTAINER.MAXWEI
[M:CTRH2]USFVOL = WCONTAINER.USFVOL
# Issue 111256 US2
[M:CTRH2]TCTRVOL = WCONTAINER.TCTRVOL
[M:CTRH2]CRRWEI = WCONTAINER.CRRWEI
[M:CTRH2]AVAWEI = WCONTAINER.AVAWEI
[M:CTRH2]AVAVOL = WCONTAINER.AVAVOL
[M:CTRH2]TARWEI = WCONTAINER.TARWEI
# End issue 111256 US2
[M:CTRH]CTRNUM = WCONTAINER.CTRNUM
If [F:CTRH]CTRNUM = AVOID.ACHAR : [F:CTRH]CTRNUM = [M:CTRH]CTRNUM : Endif
#--- Refresh the fields not in Syracused Class
#I must go to LIENS and not LIENS_SCR, modif after creation don't work
Gosub LIENS
Return
#-------------------------------------------------------------#
$MODIF
#--------------------------------------#
# Modification container               #
#--------------------------------------#
Gosub MODIF From TABLEAUX : If GOK<1  Return : Endif
#--- Assign the Syracuse class with [M]class
WCONTAINER.CTRUID=[M:CTRH]CTRUID
WCONTAINER.FCY=[M:CTRH2]FCY
WCONTAINER.BPSNUM=[M:CTRH2]BPSNUM
WCONTAINER.TCTRNUM = [M:CTRH2]TCTRNUM
WCONTAINER.FULFLG = [M:CTRH2]FULFLG
WCONTAINER.SEANUM1 = [M:CTRH2]SEANUM1
WCONTAINER.SEANUM2 = [M:CTRH2]SEANUM2
WCONTAINER.SEANUM3 = [M:CTRH2]SEANUM3

MY_STATUS = fmet WCONTAINER.AUPDATE()
#--- AUPDATE method
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WCONTAINER)
  If GOK=0 : Return : Endif
Endif
#--- Affect the [M]class with the Syracuse Class
[M:CTRH2]CUR  = WCONTAINER.CUR
[M:CTRH2]TOTLINAMT = WCONTAINER.TOTLINAMT
[M:CTRH2]TOTLINWEU = WCONTAINER.TOTLINWEU
[M:CTRH2]TXWOU = WCONTAINER.TXWOU
[M:CTRH2]TXWOU2 = WCONTAINER.TXWOU2
[M:CTRH2]TOTLINVOU = WCONTAINER.TOTLINVOU
[M:CTRH2]MAXWEI = WCONTAINER.MAXWEI
[M:CTRH2]USFVOL = WCONTAINER.USFVOL
# Issue 111256 US2
[M:CTRH2]TCTRVOL = WCONTAINER.TCTRVOL
[M:CTRH2]CRRWEI = WCONTAINER.CRRWEI
[M:CTRH2]AVAWEI = WCONTAINER.AVAWEI
[M:CTRH2]AVAVOL = WCONTAINER.AVAVOL
[M:CTRH2]TARWEI = WCONTAINER.TARWEI
# End issue 111256 US2

[M:CTRH]CTRNUM = WCONTAINER.CTRNUM

#--- Refresh the fields not in Syracused Class
If !GIMPORT Gosub LIENS_SCR Endif
Return
#------------------------------------#
# After field modification           #
#------------------------------------#
$APRES_MODIF
If !find(currbox,GBOXPO6)  Return : Endif
If !find(COUZON,"FCY","BPSNUM") | GIMPORT Return : Endif
If (FILGAUSUP(0)<>"[F:POQ]LINCLEFLG=9" )|
&  [M:PCOW]WBPSNUM<>"" | COUZON="BPSNUM"
  Gosub TIROIR
Endif
Return
#-------------------------------------------------------------#
$AV_ANNULE
#--- Must define again ANOWRITE because of subprog ANUCOD
ANOWRITE = 1
Return
#-------------------------------------------------------------#
$ANNULE
#--------------------------------------#
# Deletion container                   #
#--------------------------------------#
Local Integer I,MY_STATUS
Gosub ANNULE From TABLEAUX
#--- ADELETE method
MY_STATUS = fmet WCONTAINER.ADELETE()
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WCONTAINER)
  If GOK=0 : Return : Endif
Endif
Return
#-------------------------------------------------------------#
$FERME
#--- Free instance
If WCONTAINER<> null
  FreeGroup WCONTAINER
Endif
Return
#-------------------------------------------------------------#
$ABANDON
Raz [M:PLCW]
#--- Update picking list
If GREP="C" & !GIMPORT & BOUT="A"
  Raz [M:CTRH], [M:CTRH1], [M:CTRH2]
  Actzo [CTRH] : Actzo [CTRH1]10-99 : Gosub TIROIR
Endif
Return
#-------------------------------------------------------------#
$APRES_CRE
Gosub LIENS From TABLEAUX
#--- Update picking list
If !GIMPORT  Gosub TIROIR : Endif
Return
#-------------------------------------------------------------#
$APRES_MOD
Gosub LIENS From TABLEAUX
#--- Update picking list
If !GIMPORT  Gosub TIROIR : Endif
Return
#-------------------------------------------------------------#
$FILGAUCHE
#----------------------------------------------#
# Filtrer les enregistrements listes de gauche #
#----------------------------------------------#
GBIDI2=1
If GREP<>"C"
  GBIDC2="M": GFCY=[M:CTRH2]FCY : Gosub AUTORIS_OPT From CONTX3
Endif
#--- If no current key (except for creation) or shipped container => nothing in the picking list
If (GREP="" & !CLECUR) | [M:CTRH]SHIPNUM<>""
   FILGAUSUP(0) = "[F:POQ]ITMREF=''"
   Return
Endif

#-----

If (GREP="C" | GREP="D" | GREP="1" | [M:CTRH]CTRNUM<>"") & GBIDI2=1
  #----- Purchase order picking -----#
  If currbox=GBOXPO6
    #-----
    FILGAUSUP(0)="[F:POQ]LINCLEFLG=1 & [F:POQ]WIPSTA<2 "
    If [M:PLCW]WFCY<>""    FILGAUSUP(0)-="& pat([F:POQ]POHFCY,[M:PLCW]WFCY)<>0"       : Endif
    If [M:CTRH2]FCY<>""     FILGAUSUP(0)-="& pat([F:POQ]POHFCY,[M:CTRH2]FCY)<>0"       : Endif
    If [M:PLCW]WBPSNUM<>""    FILGAUSUP(0)-="& pat([F:POQ]BPSNUM,[M:PLCW]WBPSNUM)<>0"       : Endif
    If [M:CTRH2]BPSNUM<>""     FILGAUSUP(0)-="& pat([F:POQ]BPSNUM,[M:CTRH2]BPSNUM)<>0"       : Endif
    If [M:PLCW]WPOHNUM<>""    FILGAUSUP(0)-="& pat([F:POQ]POHNUM,[M:PLCW]WPOHNUM)<>0"       : Endif
    If [M:PLCW]WITMREF<>""    FILGAUSUP(0)-="& pat([F:POQ]ITMREF,[M:PLCW]WITMREF)<>0"       : Endif

     # Issue 112754 - 2016-11-29 by MAE : Pas de commandes de sous traitance ou de service
     # Issue 122224 - 2017-03-27 by MAE : Passage de FILGAUSUP(1) à FILGAUSUP(2)
    FILGAUSUP(2)-="& [F:POQ]ITMKND<>2"
    FILGAUSUP(2)-="& [F:POQ]LINSTA<>3 & [F:POQ]ORI<>2 & [F:POQ]LINTYP=1"    #--- no subcontract order
        #-----
    FILGAUSUP(1)-="& (([F:POQ]QTYSTU>[F:POQ]RCPQTYSTU )"
    FILGAUSUP(1)-="| (GRCPORD<>1 & [F:ITM]SCSFLG<>2))"
    FILGAUSUP(1)-="& [F:ITM]RCPFLG=2 & [F:POH]APPFLG>2 & [F:POH]SALFCY=''"
    #--- no open order
    FILGAUSUP(1)-="& [F:POQ]POHTYP<>2"
    #pas de commande inter site ou inter soc
    FILGAUSUP(1)-="& [F:POH]BETFCY<>2 & [F:POH]BETCPY<>2"
    #pas de commande si la qté expédiée + la qté réceptionnée est supérieure ou égale à la qté commandée
    FILGAUSUP(2)-="& [F:POQ]QTYSTU-[F:POQ]RCPQTYSTU-[F:POQ]SHIQTYSTU>0"
  Endif
Elsif find(currbox,GBOXPO6)
  FILGAUSUP(1)=""
  Case currbox
    When GBOXPO6 : FILGAUSUP(0) ="[F:POQ]LINCLEFLG=9"
  Endcase
Endif
Return

$AP_FILGAUCHE
#---------------------------------------------------------#
#--- update picking list
If !find(currbox,GBOXPO6) Return : Endif
WPICK=2 : Gosub ACTUALIS_MARQUAGE
Return

$TIROIR
#---------------------------------------------------#
# Click sur un tiroir                               #
# Désormais entièrement géré par l'objet :          #
# - le remplissage                                  #
# - et l'actualisation (boules bleues)              #
#   par l'appel à la suite de l'action AP_FILGAUCHE #
# ------------------------------------------------- #
# Autres appels par l'applicatif dans les cas       #
# d'abandon, d'après création, d'après modif ...etc #
#---------------------------------------------------#
If !find(currbox,GBOXPO6)  Return : Endif
#-----
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
Return

$DEB_PICK
#-----------------#
#--- Picking begin#
#-----------------#
If !find(currbox,GBOXPO6) Return : Endif
SAVNBLIG=[M:CTRH1]NBLIG
Raz WERR
WDEBPICK=1 : GPTH_PICK=1
Return

$PICKE
#-----------------------#
#--- New picked element #
#-----------------------#
If !find(currbox,GBOXPO6) Return : Endif
If REP=""
  If !CLECUR | !VERROU | !ACTMOD | GCONSULT  OK=0 : Return : Endif
Endif

Case currbox
  When GBOXPO6 : Gosub PICKE_CDE
Endcase
Gosub GRISAGE
Return

$DEPICK
#-------------------------#
#--- New depicked element #
#-------------------------#
If !find(currbox,GBOXPO6) Return : Endif
Case currbox
  When GBOXPO6 : Gosub DEPICK_CDE
  Endcase
Gosub GRISAGE
Return

$FIN_PICK
#----------------#
#--- End picking #
#----------------#
WDEBPICK=0 : GPTH_PICK=0
If REP=""
  If !VERROU
    GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
  Elsif !CLECUR | !ACTMOD | GCONSULT
    GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
  Endif
Endif
#-----
If !GIMPORT
  Affzo [CTRH]1-99
  Affzo [CTRH1]10
  Affzo [CTRH2]
  If WPICK=9  WPICK=2 : Affzo [CTRH]1-99 : Gosub TIROIR : Endif
Endif
zonsui="[M:CTRH1]NBLIG(max(0,nolign-1))"
Return

#-----------------------------------#
#--- Purchase order line selection  #
#-----------------------------------#
$PICKE_CDE
SAVNBLIG=nolign
WNUM=[F:POQ]POHNUM : WPOQLNK=[F:POQ]POQLNK
Read [POQ] POQ3=WNUM;WPOQLNK  : If fstat Raz [F:POQ] : Endif
If WDEBPICK | [F:POH]POHNUM<>[F:POQ]POHNUM
  Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
Endif
#-----
If !evalue(FILGAUSUP)  OK=0 : Return : Endif
#-----
#----- Read table for picking
Gosub LECFIC_PICKE_CDE
#-----
WDEBPICK=0
#----- Calcul de la quantité pouvant être expédiée : qté cdée - qté receptionnée - qté expédiée -----#
# Issue 111257 US70
#Somme des qtés expédiées

REQUETE(0) = "SELECT SUM(SHIQTYSTU_0)"
REQUETE(1)=" from SHIPMENTD WHERE POHNUM_0='"+[F:POQ]POHNUM+"'AND POPLIN_0 ="+num$([F:POQ]POPLIN)+ "AND POQSEQ_0 ="+num$([F:POQ]POQSEQ) + "AND QTYEXPFLG_0<>2"

  For (Decimal WSHIQTYSTU) From num$(BASE) Sql REQUETE As [SSHIP]
    WQTESTU = [F:POQ]QTYSTU - [SSHIP]WSHIQTYSTU
  Next

#Somme des qtés réceptionnées
REQUETE(0) = "SELECT SUM(QTYSTU_0)"
REQUETE(1)=" from PRECEIPTD WHERE POHNUM_0='"+[F:POQ]POHNUM+"'AND POPLIN_0 ="+num$([F:POQ]POPLIN)+"AND POQSEQ_0 ="+num$([F:POQ]POQSEQ)
& +" AND SHIPNUM_0 = ' '"

  For (Decimal WRCPQTYSTU) From num$(BASE) Sql REQUETE As [SRCP]
    WQTESTU = WQTESTU - [SRCP]WRCPQTYSTU
  Next

#WQTESTU=[F:POQ]QTYSTU-[F:POQ]RCPQTYSTU-[F:POQ]SHIQTYSTU
# End issue 111257 US70

# MAE, bug 110660
Read [SHD]SHD2=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
If [F:SHD]CTRNUM = AVOID.ACHAR
  If !fstat
    GMESSAGE=mess(530,194,1)
    GERR=1
    Return
  Endif
Endif
# MAE, fin bug 110660

# Issue 111257 US 70
#Link [CTRD] With [CTRH]CTRH0=[F:CTRD]CTRNUM As [LNK]
#
#Filter [LNK] Where [F:CTRD]POHNUM=[F:POQ]POHNUM & [F:CTRD]POPLIN=[F:POQ]POPLIN & [F:CTRD]POQSEQ=[F:POQ]POQSEQ & [F:CTRD]SHIPNUM = ""
#For [LNK]CTRD1
#  If [F:CTRD]QTYSTU <> 0
#    WQTESTU -= [F:CTRD]QTYSTU
#  Endif
#Next
#Filter [LNK]
#Somme des qtés en container et non expédiées
REQUETE(0) = "SELECT SUM(QTYSTU_0)"
REQUETE(1)=" from CONTAINERD WHERE POHNUM_0='"+[F:POQ]POHNUM+"'AND POPLIN_0 ="+num$([F:POQ]POPLIN)+"AND POQSEQ_0 ="+num$([F:POQ]POQSEQ)
& +" AND SHIPNUM_0 = ' '"

  For (Decimal WCTRQTYSTU) From num$(BASE) Sql REQUETE As [SCTR]
    WQTESTU = WQTESTU - [SCTR]WCTRQTYSTU
  Next
# End issue 111257 US 70

If WQTESTU<0 WQTESTU=0 : Endif
#---Receipt quantity = 0
If WQTESTU=0
  GMESSAGE=[F:POQ]POHNUM-[F:POQ]ITMREF+"\"+mess(482,194,1)
  OK=2 : Call OUINON (GMESSAGE,OK) From GESECRAN : Raz GMESSAGE
  If OK<>2  OK=0 : Return : Endif
Endif
#--- POQ Facility verification : must heve the same juridic company
For I=0 To [M:CTRH1]NBLIG
  If [M:CTRH1]LEGCPY(I)<> "" & [F:POQ]CPY <> [M:CTRH1]LEGCPY(I)
    GMESSAGE=mess(484,194,1)
    GERR=1
    Return
  Endif
Next

Gosub CHARG_LIG_CTRH
If !mkstat
  status=0 : Call LINNUM("CTRLIN") From TABLEAUX
Endif
Return
#--------------------------------------------------------------#
# Lectures des tables après le picking d'une ligne de commande #
#--------------------------------------------------------------#
$LECFIC_PICKE_CDE
#-----
Read [POP]POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ : If fstat  Raz [F:POP] : Endif
If [F:ITM]ITMREF<>[F:POQ]ITMREF
  Read [ITM] ITM0=[F:POQ]ITMREF : If fstat  Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[F:POQ]ITMREF | [F:ITF]STOFCY<>[M:CTRH2]FCY
  Read [ITF] ITF0=[F:POQ]ITMREF;[M:CTRH2]FCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
Return

$ACTUALIS_MARQUAGE
#---------------------------------------------------------------#
# Update picking list                                           #
# WPICK : 0 = nothing to do                                     #
#         1 = remove marking picked elements                    #
#         2 = Marked picked elements                            #
#---------------------------------------------------------------#
If [M:CTRH1]NBLIG>0
  For I=0 To [M:CTRH1]NBLIG-1
    Gosub MARQUAGE_LIGNE
  Next I
Endif
Return

$MARQUAGE_LIGNE
#--------------------------------------------------------------#
# Update picking list                                          #
# WPICK : 0 = nothing to do                                    #
#         1 = remove marking picked elements                   #
#         2 = Marked picked elements                           #
#--------------------------------------------------------------#
#----- Si appel depuis Subprog (C_NBLIG.. etc) les variables locales n'existent pas !
If dim(FILGAUSUP)<1
  #--- Supervisor locale variable
  Local Integer FILTREG : FILTREG=1
  Local Integer INDCUR  : INDCUR=1
  Local Integer ICRITERE, IFILROLE, IFILSUITE, IFILGAUSUP
  Local Char    FILTSUP(240), FILROLE(250)(0..2) , FILSUITE(250)(0..5), CRITERE(250)
  Local Char    FILGAUSUP(240)(0..3)
  Local Char    WINPROG(GLONADC), ACTION(20) : WINPROG="WGOCTRH"
  Local Char    HINTLIS(10)(0..8)
  #-----
  HINTLIS(val(right$(GBOXPO6,8)))="POQ2"
  #--- Picking local variable
  Local Char     WNUM(GLONVCR), WPOQLNK(16)
  Local Integer  WLIN
  Local Shortint J, K
Endif
#-----
If [M:CTRH1]POHNUM(I)<>""
  J=WPICK
  If currbox=GBOXPO6    : #----- Purchase order
    WNUM=[M:CTRH1]POHNUM(I) : WLIN=[M:CTRH1]CTRLIN(I)
    WPOQLNK=mid$("00000000",1,8-len(num$([M:CTRH1]POPLIN(I))))+num$([M:CTRH1]POPLIN(I))
&          +mid$("00000000",1,8-len(num$([M:CTRH1]POQSEQ(I))))+num$([M:CTRH1]POQSEQ(I))
    Read [POQ] POQ3=WNUM;WPOQLNK  : If fstat Raz [F:POQ] : Endif
    Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
    Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
    If [F:POH]POHNUM="" & [F:ITM]ITMREF="" WPICK=0 : Endif
  Endif
  If currbox=GBOXPO6
    Case WPICK
      When 1 : Gosub DEPICK From GOBJSUB
      When 2 : Gosub REPICK From GOBJSUB
    Endcase
  Endif
  WPICK=J
Endif
Return

$GRISAGE
#----------------------------#
#--- Screen fields gestion   #
#----------------------------#
If [M:CTRH1]NBLIG=0 & GREP="C"
  Actzo [M:CTRH2]FCY, BPSNUM
Else
  Diszo [M:CTRH2]FCY, BPSNUM
Endif
Return

#-------------------------------------#
# Depick purchase order line          #
#-------------------------------------#
$DEPICK_CDE
WNUM=[F:POQ]POHNUM : WPOQLNK=[F:POQ]POQLNK
Read [POQ] POQ3=WNUM;WPOQLNK  : If fstat Raz [F:POQ] : Endif
If WDEBPICK | [F:POH]POHNUM<>[F:POQ]POHNUM
  Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
Endif
WDEBPICK=0

Gosub RECHSUP_LIG_CDE   : # Recherche et suppression ligne

Return

#-------------------------------------------------------------#
#--- Find and delete the picked purchase order line           #
#-------------------------------------------------------------#
$RECHSUP_LIG_CDE
#-----
If [F:ITM]ITMREF<>[F:POQ]ITMREF
  Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#-----
Raz J
While J<[M:CTRH1]NBLIG
  K=find([F:POQ]POHNUM,[M:CTRH1]POHNUM(J..[M:CTRH1]NBLIG-1))
  I=J+(K-1)
  If K=0
    J=[M:CTRH1]NBLIG
  Elsif [M:CTRH1]POPLIN(I)=[F:POQ]POPLIN &
&       [M:CTRH1]POQSEQ(I)=[F:POQ]POQSEQ
    nolign=I+1 : status=65 : Call AVANT_NBLIG From SUBCTRH
    Dela I,1,[M:CTRH1]NBLIG-1 [M:CTRH1]NBLIG : [M:CTRH1]NBLIG-=1
    J+=K-1 : K=0 : status=0
  Else
    J+=K : K=0
  Endif
Wend
Affzo [M:CTRH1]
Return

#-------------------------------------------------------------#
# --- Picked line in the sreen                                #
#-------------------------------------------------------------#
$CHARG_LIG_CTRH
#-----
#--- Open the line
nolign = [M:CTRH1]NBLIG
Insa nolign,1,[M:CTRH1]NBLIG [M:CTRH1]NBLIG
[M:CTRH1]NBLIG += 1
nolign = [M:CTRH1]NBLIG
NOL = nolign-1
status = 0
NOL=nolign-1
#--- Container line from purchase order line
If [F:POQ]POHNUM<>""
  [M:CTRH1]=[F:POQ]
  #--- Max qty in stock unit
  [M:CTRH1]QTYSTU(NOL) = WQTESTU
  #--- Max qty in UOM
  If [F:POQ]QTYSTU <>0
    [M:CTRH1]QTYUOM(NOL) = [F:POQ]QTYUOM * WQTESTU /[F:POQ]QTYSTU
    [M:CTRH1]QTYPUU(NOL) = [F:POQ]QTYPUU * WQTESTU /[F:POQ]QTYSTU
    [M:CTRH1]LINAMT(NOL) = [F:POQ]LINAMT * WQTESTU /[F:POQ]QTYSTU   #Recalcul du montant
    Call ARRDEV([M:CTRH1]LINAMT(NOL),[F:POH]CUR) From TRTDIV      # Issue X3-70790 - 2018-01-15 by MAE
  Else
    [M:CTRH1]QTYUOM(NOL) = [F:POQ]QTYUOM
    [M:CTRH1]QTYPUU(NOL) = [F:POQ]QTYPUU
    [M:CTRH1]LINAMT(NOL) = [F:POQ]LINAMT
  Endif
  #--- Coefficient calcul UOM/UA
  If [M:CTRH1]QTYUOM<>0
    [M:CTRH1]UOMPUUCOE =arr([M:CTRH1]QTYPUU/[M:CTRH1]QTYUOM,0.00000001)
  Endif
  If [M:CTRH1]UOMPUUCOE=0 : [M:CTRH1]UOMPUUCOE=1 : Endif
  #--- weight and volume calcul in terms of max quantity for container
  Call CONVERT_VOUWEU("CTRH1",NOL,[M:CTRH1]LINWEU(NOL),[M:CTRH1]LINVOU(NOL),[M:CTRH1]QTYSTU(NOL),[F:POQ]QTYSTU) From STCLIB
  [M:CTRH1]LEGCPY(NOL) = [F:POQ]CPY
  [M:CTRH1]NETCUR(NOL) = [F:POH]CUR
  [M:CTRH1]CHGTYP(NOL) = [F:POH]CHGTYP
  [M:CTRH1]ORDDAT(NOL) = [F:POH]ORDDAT
  [M:CTRH1]EECICT(NOL) = [F:POH]EECICT
#---- Purchase order designation
  [M:CTRH1]ITMDES(NOL) = [F:POP]ITMDES
  [M:CTRH1]ITMDES1(NOL) = [F:POP]ITMDES1
Endif
Affzo [M:CTRH1]
Return
#------------------------------------#
$LIENS
#------------------------------------#
#--- Free instance
If WCONTAINER<> null  : FreeGroup WCONTAINER :Endif
#--- class instantiation
WCONTAINER = NewInstance C_CONTAINER AllocGroup null

WCONTAINER.CTRNUM=[M:CTRH]CTRNUM
#--- Read method
WRET = fmet WCONTAINER.AREAD([M:CTRH]CTRNUM)
If WRET >= [V]CST_AERROR
  Call GET_ERRORS(WCONTAINER)
  If GOK=0 : Return : Endif
Endif
Gosub LIENS From TABLEAUX
Gosub LIENS_SCR
Return
#-------------------------------------------------------------#
#--- Affect the screen fields with others informations        #
#-------------------------------------------------------------#
$LIENS_SCR
#--- Read container information
If WCONTAINER.TCTRNUM <>""
   Read [TCTR] TCTR0=WCONTAINER.TCTRNUM
   If !fstat
    [M:CTRH2]MAXWEI = [F:TCTR]MAXWEI
    [M:CTRH2]USFVOL = [F:TCTR]USFVOL
    #MAE,Exi 110713
    [M:CTRH2]DSPWEU    = [F:TCTR]WEU
    [M:CTRH2]DSPVOU    = [F:TCTR]VOU
    #MAE,Fin Exi 110713
    # Issue 111256 US2
    [M:CTRH2]TCTRVOL = [F:TCTR]TCTRVOL
    [M:CTRH2]TARWEI = [F:TCTR]TARWEI
    # End issue 111256 US2

   Endif
Endif
#--- read shipment information
If [M:CTRH]SHIPNUM <> ""
  Read [SHH]SHH0=[M:CTRH]SHIPNUM
   If !fstat
    [M:CTRH]TRNNUM = [F:SHH]TRNNUM
   Endif
Endif
#--- Filling rate
If [M:CTRH2]USFVOL <> AVOID.ADEC
  [M:CTRH2]TXWOU = [M:CTRH2]TOTLINVOU*100/[M:CTRH2]USFVOL
  If [M:CTRH2]TXWOU >100
   [M:CTRH2]TXWOU2 = 100
  Else
    [M:CTRH2]TXWOU2 =[M:CTRH2]TXWOU
  Endif
Endif



#--- Update picking list
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
If !GIMPORT : WPICK=2 : Gosub ACTUALIS_MARQUAGE : Endif
Raz [M:PLCW]

Affzo [M:CTRH]
Affzo [M:CTRH2]
Affzo [M:CTRH1]
Return
#------------------------------------#
$LIENS_LIG
#------------------------------------#
NOL = nolign-1
I = nolign
#--- Read PORDER information
If WCONTAINER.CTRD(I)<>null and find(WCONTAINER.CTRD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
  Read [POQ] POQ0=WCONTAINER.CTRD(I).POHNUM;WCONTAINER.CTRD(I).POPLIN;WCONTAINER.CTRD(I).POQSEQ
  If fstat Raz [F:POQ] : Endif
  Read [POP] POP0=WCONTAINER.CTRD(I).POHNUM;WCONTAINER.CTRD(I).POPLIN;WCONTAINER.CTRD(I).POQSEQ
  If fstat Raz [F:POP] : Endif
  [M:CTRH1]ITMREF(NOL) = WCONTAINER.CTRD(I).ITMREF
  [M:CTRH1]BPSNUM(NOL)=[F:POQ]BPSNUM
  [M:CTRH1]POHFCY(NOL)=[F:POQ]POHFCY
  [M:CTRH1]ITMDES(NOL)=[F:POP]ITMDES
  [M:CTRH1]ITMDES1(NOL)=[F:POP]ITMDES1
  If [M:CTRH]SHIPNUM = "" : [M:CTRH]SHIPNUM = WCONTAINER.CTRD(I).SHIPNUM : Endif
Endif
Return

#------------------------------------#
#--- Calcul the header totals        #
#------------------------------------#
$CALCUL_TOTAUX
#------------------------------------#
#--- Using another instance for not modify the principal
Local Instance WCONTAINER2 Using C_CONTAINER
Local Integer WPOS, WRET
Local Decimal WLINAMT,WDECIMAL


WCONTAINER2 = NewInstance C_CONTAINER AllocGroup null
WCONTAINER2.CTRNUM = [M:CTRH]CTRNUM
WCONTAINER2.DSPWEU = [M:CTRH2]DSPWEU
WCONTAINER2.DSPVOU = [M:CTRH2]DSPVOU
WCONTAINER2.MAXWEI = [M:CTRH2]MAXWEI
WCONTAINER2.USFVOL = [M:CTRH2]USFVOL
# Issue 111256 US2
WCONTAINER2.TCTRVOL = [M:CTRH2]TCTRVOL
WCONTAINER2.CRRWEI = [M:CTRH2]CRRWEI
WCONTAINER2.AVAWEI = [M:CTRH2]AVAWEI
WCONTAINER2.AVAVOL = [M:CTRH2]AVAVOL
WCONTAINER2.TARWEI = [M:CTRH2]TARWEI
# End issue 111256 US2

WCONTAINER2.TOTLINWEU = AVOID.ADEC
WCONTAINER2.TXWOU = AVOID.ADEC
WCONTAINER2.TXWOU2 = AVOID.ADEC
WCONTAINER2.TOTLINVOU = AVOID.ADEC
WCONTAINER2.TOTLINAMT = AVOID.ADEC
For I=0 To [M:CTRH1]NBLIG-1
  WPOS = fmet WCONTAINER2.ADDLINE("CTRD",[V]CST_ALASTPOS)
  If WPOS = [V]CST_ANOTDEFINED
    #--The insertion was not possible
    GMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'CTRD','CONTAINER')
    GOK=0 : GERR=1
    Return
  Endif
  WCONTAINER2.CTRD(WPOS).CTRNUM = [M:CTRH]CTRNUM
  WCONTAINER2.CTRD(WPOS).CTRLIN = [M:CTRH1]CTRLIN(I)
  WCONTAINER2.CTRD(WPOS).POHNUM = [M:CTRH1]POHNUM(I)
  WCONTAINER2.CTRD(WPOS).POPLIN = [M:CTRH1]POPLIN(I)
  WCONTAINER2.CTRD(WPOS).POQSEQ = [M:CTRH1]POQSEQ(I)
  WCONTAINER2.CTRD(WPOS).ITMREF = [M:CTRH1]ITMREF(I)
  WCONTAINER2.CTRD(WPOS).QTYUOM = [M:CTRH1]QTYUOM(I)
  WCONTAINER2.CTRD(WPOS).UOM = [M:CTRH1]UOM(I)
  WCONTAINER2.CTRD(WPOS).QTYPUU = [M:CTRH1]QTYPUU(I)
  WCONTAINER2.CTRD(WPOS).PUU = [M:CTRH1]PUU(I)
  WCONTAINER2.CTRD(WPOS).QTYSTU = [M:CTRH1]QTYSTU(I)
  WCONTAINER2.CTRD(WPOS).STU = [M:CTRH1]STU(I)
  WCONTAINER2.CTRD(WPOS).QTYWEU = [M:CTRH1]QTYWEU(I)
  WCONTAINER2.CTRD(WPOS).LINWEU = [M:CTRH1]LINWEU(I)
  WCONTAINER2.CTRD(WPOS).QTYVOU = [M:CTRH1]QTYVOU(I)
  WCONTAINER2.CTRD(WPOS).LINVOU = [M:CTRH1]LINVOU(I)
  WCONTAINER2.CTRD(WPOS).LINAMT = [M:CTRH1]LINAMT(I)
  WCONTAINER2.CTRD(WPOS).NETCUR = [M:CTRH1]NETCUR(I)
  WCONTAINER2.CTRD(WPOS).LEGCPY = [M:CTRH1]LEGCPY(I)
  WCONTAINER2.CTRD(WPOS).CHGTYP = [M:CTRH1]CHGTYP(I)
  WCONTAINER2.CTRD(WPOS).ORDDAT = [M:CTRH1]ORDDAT(I)
  WCONTAINER2.CTRD(WPOS).EECICT = [M:CTRH1]EECICT(I)
  WCONTAINER2.CTRD(WPOS).UOMPUUCOE = [M:CTRH1]UOMPUUCOE(I)
  WRET = fmet WCONTAINER2.CTRD(WPOS)._CALC_TOTAUX()
Next I

#calcul du poids courant : somme du poids des lignes  + tare du conteneur
WCONTAINER2.CRRWEI = WCONTAINER2.TOTLINWEU + WCONTAINER2.TARWEI
#calcul du poids disponible : poids max - poids total des lignes
WCONTAINER2.AVAWEI = max(0,WCONTAINER2.MAXWEI - WCONTAINER2.TOTLINWEU)
#calcul du volume disponible
WCONTAINER2.AVAVOL = max(0,WCONTAINER2.USFVOL - WCONTAINER2.TOTLINVOU)
# End issue 111256 US2

[M:CTRH2]CUR       = WCONTAINER2.CUR
[M:CTRH2]TOTLINWEU = WCONTAINER2.TOTLINWEU
[M:CTRH2]TXWOU = WCONTAINER2.TXWOU
[M:CTRH2]TXWOU2 = WCONTAINER2.TXWOU2
[M:CTRH2]TOTLINVOU = WCONTAINER2.TOTLINVOU
[M:CTRH2]TOTLINAMT = WCONTAINER2.TOTLINAMT
# Issue 111256
[M:CTRH2]AVAVOL = WCONTAINER2.AVAVOL
[M:CTRH2]CRRWEI = WCONTAINER2.CRRWEI
[M:CTRH2]AVAWEI = WCONTAINER2.AVAWEI

Affzo [M:CTRH2]TOTLINWEU,TOTLINVOU,TOTLINAMT,CUR,TXWOU,TXWOU2
Affzo [M:CTRH2]AVAVOL,CRRWEI,AVAWEI
FreeGroup WCONTAINER2
Return

#------------------------------------#
#--- Get the errors                  #
#------------------------------------#
Subprog GET_ERRORS(WCONTAINER)
Variable Instance WCONTAINER Using C_CONTAINER

Local Integer I
Local Char WTEXTE(50)

 GMESSAGE = func LCCLIB.MAXMSG(WCONTAINER)
 If GMESSAGE = AVOID.ACHAR
   #--- Lines errors
  For I=1 To maxtab(WCONTAINER.CTRD)
    GMESSAGE = func LCCLIB.MAXMSG(WCONTAINER.CTRD(I))
    If GMESSAGE <> AVOID.ACHAR
      Call TEXTE(53658, WTEXTE) From OBJDIV
      GMESSAGE = WTEXTE + " : " + GMESSAGE
      Break:  Endif
  Next I
Endif
GOK=0 : GERR=1

End

