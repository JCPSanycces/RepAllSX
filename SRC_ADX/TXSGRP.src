#<AdxTL>@(#)3.0.0.0 $Revision$

############################################################################
# Traitement de calcul en masse des tableaux
# Fait appel à des fonctions du traitement TXSCAL
#
############################################################################
#Raz GPILCOD, GBIDC1 : Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET : End
Local Char PARAM(30)(1..4) , VALEUR(10)
#PARAM(1) = "GEN" : PARAM(2) = "B" : PARAM(3) = "GB1"
Call TRAITE_CHAR(VALEUR,PARAM,"","TXSGRP","DTXSGRP",4,"") From GTRAITE : End
#Call SAISIE_CHAR(VALEUR,PARAM,"DTXSGRP","TXSGRP","SPETXSG") From GSAISIE : End


$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "AVANT_OK"    : Gosub AVANT_OK
 When "OK"          : Gosub OK
 When "FIN"         : Gosub FIN
 When "EXEC"        : Gosub EXEC
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

#####################################
$OUVRE
If clalev([F:TXS])=0  : Local File TXSA       [TXS] : Endif
If clalev([F:TXA])=0  : Local File TXSAC      [TXA] : Endif
If clalev([F:TXP])=0  : Local File TXSP       [TXP] : Endif
If clalev([F:TXW])=0  : Local File TXSW       [TXW] : Endif
If clalev([F:TXX])=0  : Local File TXSV       [TXX] : Endif
If clalev([F:ACC])=0  : Local File ACCES      [ACC] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER] : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR] : Endif
If clalev([F:TCA])=0  : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU] : Endif
Local Integer I, IC, IT, ITAB, NOL, MAXTBL, MAXCOL, MAXVAR
Local Char    A(1), TABLEAU(GLONTXS), VIRMEN(10), CRIT(250), GROUPE(8)
Local Char    TABDEB(GLONTXS), TABFIN(GLONTXS), NOMVAR(5)
Return

#####################################
$DEBUT
MAXTBL = dim([M]TXSNAM)
MAXCOL = dim([M]CPY)
MAXVAR = dim([M]VARNAM)
Global Char    GTSOC(GLONCPY)(MAXTBL,MAXCOL), GTSIT(GLONFCY)(MAXTBL,MAXCOL)
Global Char    GTDVS(GLONCUR)(MAXTBL,MAXCOL), GTDVR(GLONCUR)(MAXTBL,MAXCOL)
Global Date    GTDEB(MAXTBL,MAXCOL), GTFIN(MAXTBL,MAXCOL)
Global Libelle GTTYP(MAXTBL,MAXCOL), GTMNT(MAXTBL,MAXCOL)
Global Char    GTVAR(10)(MAXTBL,MAXVAR), GTVAL(30)(MAXTBL,MAXVAR) , GTDES(GLONDES)(MAXTBL,MAXVAR)
Global Char    GTTYV(GLONATY)(MAXTBL,MAXVAR), GTPAR(GLONAOB)(MAXTBL,MAXVAR)
Raz [M]
Affzo
Return

#####################################
$SETBOUT
Call VIREBOUT(CHMEN,VIRMEN) From GOBJET
Return

#####################################
$AVANT_OK
If [M]NBTAB=0 : FIN=0 : Return : Endif
Gosub CONTROLE
Return

$CONTROLE
Local Char DESIG(GLONAX3)
For IT=0 To [M]NBTAB-1
 If [M]LSTVER(IT)="" & [M]GESAUTVER<>2 & [M]NEWVER=""
#  GERR=1 : GMESSAGE = mess(146,111,1)   :# Version obligatoire
#  zonsui = "[M]LSTVER(IT)" : FIN=0
#  Break
 Endif
 Read [TXS]TXS1 = [M]TXSNAM(IT)
 For [TXA]TXA0 Where TXSNAM=[M]TXSNAM(IT)
  IC = [F:TXA]NUMCOL-1
  If [F:TXA]COLNUM="" & (GTDEB(IT,IC)=[0/0/0] | GTFIN(IT,IC)=[0/0/0] | GTDVR(IT,IC)="")
   Call LECTEXTRA(DESIG,"TXSAC","NAMCOL",[M]TXSNAM(IT),num$(IC+1)) From ATEXTRA
   GERR=1 : GMESSAGE = [M]TXSNAM(IT)-":"-mess(180,126,1)-mess(140,111,1)-'"'+DESIG+'"'
   # Paramètres non saisis colonne...
   zonsui = "[M]TXSNAM(IT)" : FIN=0
   Break 2
  Endif
 Next
Next IT
Return

#####################################
$OK
If [M]NBTAB=0 : Return : Endif
Call OUVRE_TRACE(mess(74,111,1)) From LECFIC   :# Calcul des tableaux

Gosub OUVRE From TXSCAL
Gosub DECLARE From TXSCAL

Call DEBTRANS From GLOCK
Gosub CALTAB

Call FERME_BOITE From GESECRAN
Call FERME_TRACE From LECFIC
Return

$EXEC
TRA = 1
Return

$CALTAB
# on passe par l'écran TXSCAL pour calculer les tableaux un par un
Default Mask [DIA]
# ici [M] représente l'écran TXSCAL
For IT=0 To [M:TXG]NBTAB-1
 TABLEAU = [M:TXG]TXSNAM(IT)
 Read [TXS]TXS1 = TABLEAU
 Call OUVRE_BOITE(mess(139,111,1)-TABLEAU,[F:TXS]NBRCOL*[F:TXS]NBLIG) From GESECRAN
 # on charge l'écran TXSCAL
 [M]LSTGRP = [F:TXS]LSTGRP
 [M]TXSNAM = TABLEAU
 [M]VERSION = [M:TXG]LSTVER(IT)
 Gosub CHARGE_TAB From TXSCAL    :# chargement des noms de colonnes et des variables dans [M]
 Gosub CHARGE_VALTAB      :# chargement des paramètres du tableau
 Gosub CHARGE_VAR         :# chargement des valeurs des variables du tableau
 If [M:TXG]GESAUTVER=2    :# Version auto : on le force à utiliser le compteur
  Raz [M]VERSION
 Endif
 Gosub TR1 From TXSCAL    :# sauvegarde des paramètres et affectation numero de version
 Call ECR_TRACE(mess(145,111,1)-TABLEAU-":"-[M:DIA]VERSION,0) From GESECRAN   :# Tableau
 Gosub TR2 From TXSCAL    :# le calcul
 If GOK<1 | GERR
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN   :# on écrit dans la trace et on continue
  Raz GERR, GMESSAGE
  GOK = 1
 Endif
 Call ECR_TRACE("",0) From GESECRAN
Next IT
Return

$CHARGE_VALTAB
For IC=0 To [F:TXS]NBRCOL-1
 [M]CPY(IC) = GTSOC(IT,IC)
 [M]FCY(IC) = GTSIT(IT,IC)
 [M]STRDAT(IC) = GTDEB(IT,IC)
 [M]ENDDAT(IC) = GTFIN(IT,IC)
 [M]CURSEL(IC) = GTDVS(IT,IC)
 [M]CURPRN(IC) = GTDVR(IT,IC)
 [M]TYPRAT(IC) = GTTYP(IT,IC)
 [M]TYPMNT(IC) = GTMNT(IT,IC)
Next IC
Return

$CHARGE_VAR
[M]NBVAR = [F:TXS]NBVAR
For I=0 To [F:TXS]NBVAR
 [M]VARNAM(I) = GTVAR(IT,I)
 [M]VARDES(I) = GTDES(IT,I)
 [M]VARVAL(I) = GTVAL(IT,I)
 [M]VARTYP(I) = GTTYV(IT,I)
 [M]VARPAR(I) = GTPAR(IT,I)
Next I
Return

#####################################
$FIN

Gosub KILL_VARGLOB
Inftxt "" At 1
Return

#####################################
$SEL_LISTE
Case GACTION
 When "SELGRP" : Gosub SEL_GRP
 When "SELVER" : Gosub SEL_VER
Endcase
Return

$SEL_GRP
Local Char DESIG(GLONAX3)
TIT = mess(12,123,1)-mess(129,105,1)   :# Choix groupe d'états
NBTEX = 0
For [TXS]TXS0(1)
 If NBTEX+1>=dim(TEX) | NBTEX+1>=dim(TEXTE)
  Break
 Endif
 NBTEX += 1
 TEX(NBTEX)=[F:TXS]LSTGRP
 #75140
 #Call LECTEXTRA(DESIG,"TXSA","GRPDES",[F:TXS]TXSNAM,"") From ATEXTRA
 Call LECTEXTRA(DESIG,"TXSA","GRPDES",[F:TXS]LSTGRP,"") From ATEXTRA
 TEXTE(NBTEX)=[F:TXS]LSTGRP-DESIG
Next
Return

$SEL_VER
TIT = mess(12,123,1)-mess(126,105,1)   :# Choix Version
NBTEX = 0
For [TXW]TXW1 Where TXSNAM=[M]TXSNAM(nolign-1) & VERSION>=VALEUR
 If NBTEX+1>=dim(TEX) | NBTEX+1>=dim(TEXTE)
  Break
 Endif
 NBTEX += 1
 TEX(NBTEX) = [F:TXW]VERSION
 TEXTE(NBTEX) = [F:TXW]VERSION-":"-[F:TXW]VERDES
Next
Return

#####################################
$SEL_TABLE
Case GACTION
 When "SELTXS" : Gosub S_TXS
Endcase
Return

$S_TXS
OBJET = "TXS"
CRITERE = "([M]LSTGRP='' | LSTGRP=[M]LSTGRP) & [F:ACC]EXEC=2"
Return


# Remplissage de la liste des tableaux
Funprog AFF_LISTE(GROUPE,ALLTAB,TABDEB,TABFIN)
Value Char GROUPE, TABDEB, TABFIN
Value Integer ALLTAB
Local Char CRITERE(200), A(1)
Local Integer IC, NOL , OK
Raz NOL, [M]NBTAB, [M]TXSNAM, LSTVER
Raz GTSOC, GTSIT, GTDEB, GTFIN, GTDVS, GTDVR, GTTYP, GTMNT, GTVAR, GTDES, GTVAL, GTTYV, GTPAR
CRITERE = "(GROUPE='' | LSTGRP=GROUPE) & (ALLTAB=2 | (TXSNAM>=TABDEB & TXSNAM<=TABFIN))"
For [TXS]TXS1 Where evalue(CRITERE)
 If NOL>=dim([M]TXSNAM)
  Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 OK = 1
 If [F:TXS]ACS<>""
  Read [ACC]CODACC = GUSER;[F:TXS]ACS
  If fstat or [F:ACC]EXEC<>2
   OK = 0
  Endif
 Endif
 If OK
  [M]TXSNAM(NOL) = [F:TXS]TXSNAM
  Filter [TXW] Where TXSNAM=[M]TXSNAM(NOL) Order By TXSNAM;GENDAT Desc;GENTIM Desc
  Read [TXW] First
  If !fstat
   [M]LSTVER(NOL) = [F:TXW]VERSION
  Endif
  A = func SET_PARAM([M]TXSNAM(NOL),[M]LSTVER(NOL),NOL)
  A = func SET_VAR([M]TXSNAM(NOL),[M]LSTVER(NOL),NOL)
  NOL += 1
 Endif
Next
Filter [TXW]
[M]NBTAB = NOL
If [M]NBTAB
 Read [TXS]TXS1 = [M]TXSNAM(0)
 A = func AFF_PARAM(0)
 A = func AFF_VAR(0)
Else
 Effzo [M]20, 30
Endif
Affzo [M]15
End ""

# Affectation des paramètres d'une version dans les variables globales
Funprog SET_PARAM(TABLEAU,VERS,ITAB)
Value Char TABLEAU, VERS
Value Integer ITAB
Local Integer IC
For [TXP]TXP0 Where TXSNAM=TABLEAU & VERSION=VERS
 IC = [F:TXP]COL-1
 GTSOC(ITAB,IC) = [F:TXP]CPY
 GTSIT(ITAB,IC) = [F:TXP]FCY
 If [F:TXP]STRDAT<>[0/0/0]
  GTDEB(ITAB,IC) = addmonth([F:TXP]STRDAT,[M]PERIOD)
 Endif
 If [F:TXP]ENDDAT<>[0/0/0]
  GTFIN(ITAB,IC) = addmonth([F:TXP]ENDDAT,[M]PERIOD)
 Endif
 GTDVS(ITAB,IC) = [F:TXP]CURSEL
 GTDVR(ITAB,IC) = [F:TXP]CURPRN
 GTTYP(ITAB,IC) = [F:TXP]TYPRAT
 GTMNT(ITAB,IC) = [F:TXP]TYPMNT
Next
End ""

# Affectation des variables du tableau dans les variables globales
Funprog SET_VAR(TABLEAU,VERS,ITAB)
Value Char TABLEAU, VERS
Value Integer ITAB
Local Integer I
I = 0
For [TXX]TXX0 Where TXSNAM=TABLEAU & VERSION=VERS
 GTVAR(ITAB,I) = [F:TXX]VARNAM
 If [F:TXX]VARVAL<>""
  GTVAL(ITAB,I) = [F:TXX]VARVAL
 Else
  GTVAL(ITAB,I) = [F:TXX]VARDEF
 Endif
 GTDES(ITAB,I) = [F:TXX]VARDES
 GTTYV(ITAB,I) = [F:TXX]VARTYP
 GTPAR(ITAB,I) = [F:TXX]VARPAR
 I += 1
Next
End ""

# Affichage des paramètres de la version courante
Funprog AFF_PARAM(ITAB)
Value Integer ITAB
Local Integer IC
Raz [M]NBCOL
For IC=0 To [F:TXS]NBRCOL-1
 Call LECTEXTRA([M]NAMCOL(IC),"TXSAC","NAMCOL",[M]TXSNAM(ITAB),num$(IC+1)) From ATEXTRA
 [M]CPY(IC)    = GTSOC(ITAB,IC)
 [M]FCY(IC)    = GTSIT(ITAB,IC)
 [M]STRDAT(IC) = GTDEB(ITAB,IC)
 [M]ENDDAT(IC) = GTFIN(ITAB,IC)
 [M]CURSEL(IC) = GTDVS(ITAB,IC)
 [M]CURPRN(IC) = GTDVR(ITAB,IC)
 [M]TYPRAT(IC) = GTTYP(ITAB,IC)
 [M]TYPMNT(IC) = GTMNT(ITAB,IC)
Next IC
[M]NBCOL = IC
Raz [M]FLG
[M]FLG(ITAB) = 1   :# Flag tableau courant
Affzo [M]20
End ""

# Affichage du tableau des variables
Funprog AFF_VAR(ITAB)
Value Integer ITAB
Local Integer I
Raz [M]NBVAR
For I=0 To [F:TXS]NBVAR-1
 [M]VARNAM(I) = GTVAR(ITAB,I)
 [M]VARDES(I) = GTDES(ITAB,I)
 [M]VARVAL(I) = GTVAL(ITAB,I)
 [M]VARTYP(I) = GTTYV(ITAB,I)
 [M]VARPAR(I) = GTPAR(ITAB,I)
Next I
[M]NBVAR = I
Affzo [M]30
End ""

###################################
#### Etiquettes du masque TXSGRP
###################################
Subprog C_LSTGRP(VALEUR)
Variable Char    VALEUR()
Local Char A(1)
If VALEUR<>""
 If VALEUR<>[M]LSTGRP
  Read [TXS]TXS0(1) = VALEUR
  If !fstat
   #75140
   #Call LECTEXTRA([M]GRPDES,"TXSA","GRPDES",[F:TXS]TXSNAM,"") From ATEXTRA
   Call LECTEXTRA([M]GRPDES,"TXSA","GRPDES",[F:TXS]LSTGRP,"") From ATEXTRA
  Else
   GMESSAGE = mess(66,134,1)   :# Groupe inexistant
   mkstat=2 : End
  Endif
 Endif
Else
 Effzo [M]GRPDES
Endif
If VALEUR<>[M]LSTGRP | (VALEUR="" & [M]NBTAB=0)
 A = func AFF_LISTE(VALEUR,[M]ALLTXS,[M]STRTXS,[M]ENDTXS)
Endif
End

Subprog D_ALLTXS(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M]STRTXS, ENDTXS
 Grizo [M]STRTXS, ENDTXS
Else
 Actzo [M]STRTXS, ENDTXS
Endif
End

Subprog AM_ALLTXS(VALEUR)
Variable Integer VALEUR
Local Char A(1)
If VALEUR=2
 Effzo [M]STRTXS, ENDTXS
 Grizo [M]STRTXS, ENDTXS
 A = func AFF_LISTE([M]LSTGRP,VALEUR,[M]STRTXS,[M]ENDTXS)
Else
 Actzo [M]STRTXS, ENDTXS
Endif
End

Subprog AM_STRTXS(VALEUR)
Variable Char    VALEUR()
Local Char A(1)
A = func AFF_LISTE([M]LSTGRP,[M]ALLTXS,VALEUR,[M]ENDTXS)
End

Subprog AS_ENDTXS(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]STRTXS
 VALEUR=[M]STRTXS
 Effzo [M]20, 30
 A = func AFF_LISTE([M]LSTGRP,[M]ALLTXS,[M]STRTXS,VALEUR)
Endif
End

Subprog C_ENDTXS(VALEUR)
Variable Char    VALEUR()
Local Char A(1)
If VALEUR<[M]STRTXS
 GMESSAGE=mess(8,135,1) : mkstat=2 : End
Endif
If VALEUR<>[M]ENDTXS
 Effzo [M]20, 30
 A = func AFF_LISTE([M]LSTGRP,[M]ALLTXS,[M]STRTXS,VALEUR)
Endif
End

Subprog C_GESAUTVER(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M]NEWVER
 Grizo [M]NEWVER
Else
 Actzo [M]NEWVER
Endif
End

Subprog AM_NEWVER(VALEUR)
Variable Char    VALEUR()
Local Integer I
For I=0 To [M]NBTAB-1
 If VALEUR=""
   Filter [TXW] Where TXSNAM=[M]TXSNAM(I) Order By TXSNAM;GENDAT Desc;GENTIM Desc
   Read [TXW] First
   Filter [TXW]
   If !fstat
    [M]LSTVER(I) = [F:TXW]VERSION
   Endif
 Else
   [M]LSTVER(I) = VALEUR
 Endif
Next I
Affzo [M]LSTVER
End

Subprog AM_PERIOD(VALEUR)
Variable Decimal VALEUR
Local Integer IT, IC
If [M]NBTAB
 For IT=0 To [M]NBTAB-1
   Look [TXW]TXW1 = [M]TXSNAM(IT);[M]LSTVER(IT)
   If !fstat
     For [TXP]TXP0 Where TXSNAM=[M]TXSNAM(IT) & VERSION=[M]LSTVER(IT)
       IC = [F:TXP]COL-1
       If [F:TXP]STRDAT<>[0/0/0]
        GTDEB(IT,IC) = addmonth([F:TXP]STRDAT,VALEUR)
       Endif
       If [F:TXP]ENDDAT<>[0/0/0]
        GTFIN(IT,IC) = addmonth([F:TXP]ENDDAT,VALEUR)
       Endif
     Next
   Else
     Read [TXS]TXS1 = [M]TXSNAM(IT)
     For IC=0 To [F:TXS]NBRCOL-1
       If GTDEB(IT,IC)<>[0/0/0]
        GTDEB(IT,IC) = addmonth(GTDEB(IT,IC),VALEUR)
       Endif
       If GTFIN(IT,IC)<>[0/0/0]
        GTFIN(IT,IC) = addmonth(GTFIN(IT,IC),VALEUR)
       Endif
     Next IC
   Endif
 Next IT
 IT = find(1,[M]FLG(0..[M]NBTAB-1))-1
 Read [TXS]TXS1 = [M]TXSNAM(IT)    :# tableau courant
 A = func AFF_PARAM(IT)
Endif
End

Subprog AS_NBTAB
Local Char A(1)
Local Integer I
Local Char DESIG(GLONAX3)
If nolign>[M]NBTAB
 If [M]NBTAB=0 : Effzo [M]15-30 : Endif
 mkstat=2 : End
Endif
If [M]NBTAB & [M]TXSNAM(nolign-1)<>""
 TABLEAU = [M]TXSNAM(nolign-1)
 Read [TXS]TXS1 = TABLEAU
 A = func AFF_PARAM(nolign-1)
 A = func AFF_VAR(nolign-1)
 Call LECTEXTRA(DESIG,"TXSA","TXSDES",TABLEAU,"") From ATEXTRA
 Inftxt [M]TXSNAM(nolign-1)-DESIG At 1
Endif
#Affzo [M]TXSNAM    # Ne gère pas correctement la couleur. Est remplacé par...
For I=0 To [M]NBTAB-1
 Affzo [M]TXSNAM(I)
Next I
End

Subprog APRES_NBTAB
Case status
 When 65 :   # suppression
   Gosub SUPP_NBTAB
Endcase
End

$SUPP_NBTAB
Local Integer MAXCOL, MAXVAR
MAXCOL = dim([M]CPY)
MAXVAR = dim([M]VARNAM)
For IT=nolign-1 To [M]NBTAB  :# jusqu'à [M]NBTAB pour remettre à blanc aussi le dernier indice
  For IC=0 To MAXCOL-1
    GTSOC(IT,IC) = GTSOC(IT+1,IC)
    GTSIT(IT,IC) = GTSIT(IT+1,IC)
    GTDEB(IT,IC) = GTDEB(IT+1,IC)
    GTFIN(IT,IC) = GTFIN(IT+1,IC)
    GTDVS(IT,IC) = GTDVS(IT+1,IC)
    GTDVR(IT,IC) = GTDVR(IT+1,IC)
    GTTYP(IT,IC) = GTTYP(IT+1,IC)
    GTMNT(IT,IC) = GTMNT(IT+1,IC)
  Next IC
  For I=0 To MAXVAR-1
    GTVAR(IT,I) = GTVAR(IT+1,I)
    GTDES(IT,I) = GTDES(IT+1,I)
    GTVAL(IT,I) = GTVAL(IT+1,I)
    GTTYV(IT,I) = GTTYV(IT+1,I)
    GTPAR(IT,I) = GTPAR(IT+1,I)
  Next I
Next IT
If nolign=[M]NBTAB & nolign>1
 Read [TXS]TXS1 = [M]TXSNAM(nolign-2)
 A = func AFF_PARAM(nolign-2)
 A = func AFF_VAR(nolign-2)
 Affzo [M]TXSNAM
Endif
Return

Subprog AV_TXSNAM(VALEUR)
Variable Char    VALEUR()
pcolor = GCOUL([M]FLG(nolign-1))
End

Subprog AS_LSTVER(VALEUR)
Variable Char    VALEUR()
If nolign>[M]NBTAB : mkstat=2 : End : Endif
End

Subprog C_LSTVER(VALEUR)
Variable Char    VALEUR()
Local Integer IT
Local Char TABLEAU(GLONTXS), A(1)
IT = nolign-1
TABLEAU = [M]TXSNAM(IT)
If VALEUR<>""
 Look [TXW]TXW1 = TABLEAU;VALEUR
 If !fstat
  If VALEUR<>[M]LSTVER(IT)
   A = func SET_PARAM(TABLEAU,VALEUR,IT)
   A = func AFF_PARAM(IT)
   A = func SET_VAR(TABLEAU,VALEUR,IT)
   A = func AFF_VAR(IT)
  Endif
 Endif
Endif
End

Subprog AS_NBCOL
If nolign>[M]NBCOL : mkstat=2 : Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Gosub SAIPAR
If mkstat : VALEUR="" : End : Endif
If VALEUR="" & nolign>1 : VALEUR = [M]CPY(nolign-2) : Endif
End

$SAIPAR
If [F:TXA]TXSNAM<>[M]TXSNAM | [F:TXA]NUMCOL<>nolign
 Read [TXA]TXA0=[M]TXSNAM;nolign
 If fstat : Return : Endif
Endif
If [F:TXA]COLNUM<>""
 mkstat=2
Endif
Return

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer IT
IT = find(1,[M]FLG(0..[M]NBTAB-1))-1
GTSOC(IT,nolign-1) = VALEUR
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Gosub SAIPAR
If [M]CPY(nolign-1)="" | mkstat : VALEUR="" : mkstat=2 : End : Endif
If VALEUR="" & nolign>1 : VALEUR = [M]FCY(nolign-2) : Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local Integer IT
IT = find(1,[M]FLG(0..[M]NBTAB-1))-1
GTSIT(IT,nolign-1) = VALEUR
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & GUSRFCY(1)<>"\"
 For [FCY]FCY1 Where LEGCPY=[M]CPY(nolign-1)
  If !find([F:FCY]FCY,GUSRFCY(1..GNBAUZ))
   GMESSAGE = [F:FCY]FCY-":"-mess(2,104,1)
   mkstat = 2 : Break
  Endif
 Next
Endif
End

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
Gosub SAIPAR
If VALEUR=[0/0/0] & nolign>1 : VALEUR = [M]STRDAT(nolign-2) : Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Integer IT
IT = find(1,[M]FLG(0..[M]NBTAB-1))-1
GTDEB(IT,nolign-1) = VALEUR
Call C_STRDAT(VALEUR) From TXSCAL
End

Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
Gosub SAIPAR
If VALEUR=[0/0/0] & nolign>1 : VALEUR = [M]ENDDAT(nolign-2) : Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer IT
IT = find(1,[M]FLG(0..[M]NBTAB-1))-1
GTFIN(IT,nolign-1) = VALEUR
Call C_ENDDAT(VALEUR) From TXSCAL
End

Subprog AS_CURSEL(VALEUR)
Variable Char    VALEUR()
Gosub SAIPAR
If mkstat : VALEUR="" : End : Endif
If VALEUR="" & nolign>1 : VALEUR = [M]CURSEL(nolign-2) : Endif
End

Subprog AM_CURSEL(VALEUR)
Variable Char    VALEUR()
Local Integer IT
IT = find(1,[M]FLG(0..[M]NBTAB-1))-1
GTDVS(IT,nolign-1) = VALEUR
End

Subprog AS_CURPRN(VALEUR)
Variable Char    VALEUR()
Local Char SOC(GLONCPY)
Gosub SAIPAR
If mkstat : VALEUR="" : End : Endif
If VALEUR=""
 If nolign=1
  SOC = [M]CPY(nolign-1)
  If SOC="" : SOC = GSOC(1) : Endif
  Read [CPY]CPY0 = SOC
  VALEUR = [F:CPY]ACCCUR
 Else
  VALEUR = [M]CURPRN(nolign-2)
 Endif
Endif
End

Subprog AM_CURPRN(VALEUR)
Variable Char    VALEUR()
Local Integer IT
IT = find(1,[M]FLG(0..[M]NBTAB-1))-1
GTDVR(IT,nolign-1) = VALEUR
End

Subprog AS_TYPRAT(VALEUR)
Variable Decimal VALEUR
Local Libelle ES, EP
Gosub SAIPAR
If mkstat : VALEUR=0 : End : Endif
If [M]CURSEL(nolign-1)=""
 ES = 1
Else
 Call LECTURE("TCU",[M]CURSEL(nolign-1),"") From CONTOBJ
 ES = ([F:TCU]EURFLG=2)
Endif
Call LECTURE("TCU",[M]CURPRN(nolign-1),"") From CONTOBJ
EP = ([F:TCU]EURFLG=2)
If [M]CURSEL(nolign-1)=[M]CURPRN(nolign-1) | (ES & EP)
 VALEUR=0 : mkstat=2
Endif
End

Subprog C_TYPRAT(VALEUR)
Variable Decimal VALEUR
Local Integer I, STAT
Local Decimal MTDES
Local Char DEVORG(GLONCUR)
Local Char SOC(GLONCPY)
Local Char CODLED(GLONLED)
Local Integer NUMREF

If VALEUR>len(mess(0,202,1))-1
 GMESSAGE = mess(154,124,1) : mkstat=2
Else
 I = nolign-1
 DEVORG = [M]CURSEL(I)
 If DEVORG=""
  SOC = [M]CPY(I)
  If SOC="" : SOC = GSOC(1) : Endif
  NUMREF = [F:TXS]GENLEDTYP
  If NUMREF<>0
   Call GET_LEDCUR(GACTX,SOC,NUMREF,CODLED,DEVORG,GMESSAGE) From FINACM_SYRA
  Else
   Read [CPY]CPY0 = SOC
   DEVORG = [F:CPY]ACCCUR
  Endif
 Endif
 Call CONVERT(DEVORG,[M]CURPRN(I),DEVORG,VALEUR,datesyst,10,MTDES,STAT) From TRTDEV
 If STAT
  # Pas de cours de devise DEVORG -> [M]CURPRN (datesyst)
  GMESSAGE = mess(16,114,1)-DEVORG-"->"-[M]CURPRN(I)-"("+format$(GFMDAT,datesyst)+")"
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_TYPMNT(VALEUR)
Variable Integer VALEUR
Gosub SAIPAR
If mkstat : VALEUR=0 : End : Endif
If VALEUR=0 & nolign>1 : VALEUR = [M]TYPMNT(nolign-2) : Endif
End

Subprog AM_TYPMNT(VALEUR)
Variable Integer VALEUR
Local Integer IT
IT = find(1,[M]FLG(0..[M]NBTAB-1))-1
GTMNT(IT,nolign-1) = VALEUR
End

Subprog AS_NBVAR
If nolign>[M]NBVAR : mkstat=2 : Endif
End

Subprog AM_VARVAL(VALEUR)
Variable Char    VALEUR()
Local Integer IT
VALEUR = toupper(VALEUR)
IT = find(1,[M]FLG(0..[M]NBTAB-1))-1
GTVAL(IT,nolign-1) = VALEUR
End


$KILL_VARGLOB
If dim(GTSOC)>0
 Kill GTSOC
Endif
If dim(GTSIT)>0
 Kill GTSIT
Endif
If dim(GTDEB)>0
 Kill GTDEB
Endif
If dim(GTFIN)>0
 Kill GTFIN
Endif
If dim(GTDVS)>0
 Kill GTDVS
Endif
If dim(GTDVR)>0
 Kill GTDVR
Endif
If dim(GTTYP)>0
 Kill GTTYP
Endif
If dim(GTMNT)>0
 Kill GTMNT
Endif
If dim(GTVAR)>0
 Kill GTVAR
Endif
If dim(GTDES)>0
 Kill GTDES
Endif
If dim(GTVAL)>0
 Kill GTVAL
Endif
If dim(GTTYV)>0
 Kill GTTYV
Endif
If dim(GTPAR)>0
 Kill GTPAR
Endif
Return


