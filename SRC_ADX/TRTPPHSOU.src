#<AdxTL>@(#)8.0.0.0 $Revision$
#------------------------------------------------------------------------
# TRTPPHSOU : Passage d'un bordereau de demande prépaie au statut SOUMIS
#             => Déclenchement du workflow pour approbation des demandes
#                (action sur bouton "s")
#------------------------------------------------------------------------
# (C) PROSPER 08/10
# LOT P03 - 66096
#------------------------------------------------------------------------

End

Subprog SOUMISSION(REQNUM)
Value Char REQNUM

If clalev([F:HRPPH]) = 0 : Local File PPREQUESTH [HRPPH] : Endif
If clalev([F:HRPPD]) = 0 : Local File PPREQUESTD [HRPPD] : Endif
If clalev([F:PVH]) = 0 : Local File PPVRALISH  [PVH] : Endif
If clalev([F:HRPVD]) = 0 : Local File PPVRALISD  [HRPVD] : Endif

Local Integer OK_TR, STA

Gosub GET_PPDSTA From TRTPREPAY

Call DEBTRANS From GLOCK

Repeat
    Trbegin [HRPPH], [HRPPD]
    [L]OK_TR = 2 : [V]GOK = 1

    Readlock [F:HRPPH]PPH0 = [L]REQNUM
    If fstat = 1
        [V]GOK = -1
        [V]GLOCK = "$PPREQUESTH"
    Elsif fstat <> 0
        [V]GOK = 0
        Call RSTA("HRPPH", [L]REQNUM) From GLOCK
    Endif

    If [V]GOK = 1
        Gosub TRAITEMENT
    Endif

    If [V]GOK = 1
        Commit
    Else
        Rollback
        If [V]GOK = -1
            Call ROLL From GLOCK
            If not [V]GROLL : [L]OK_TR = 1 : Endif
        Endif
    Endif

Until [L]OK_TR = 2

End

$TRAITEMENT
For [F:HRPPD]PPD0 Where [F:HRPPD]REQNUM = [F:HRPPH]REQNUM
&                        With Lock
    If [F:HRPPD]STA = [L]PPDSTA_BROUILLON
#MIPEA - 2018-06-15-  X3-96621- START
        Read [F:HRPVD]PVD1(3) = GCURLEG ; [F:HRPPH]PVHCOD ; [F:HRPPD]VRACOD
#        Read [F:HRPVD]PVD1(2) = [F:HRPPH]PVHCOD ; [F:HRPPD]VRACOD
#MIPEA - 2018-06-15-  X3-96621- END
        If fstat = 0
            If [F:HRPPD]DEMAMT = 0
                [L]STA = [L]PPDSTA_INACTIF
            Else
                If [F:HRPVD]FLGAPP = 2
                    [L]STA = [L]PPDSTA_DEMANDE
                    # Passage à l'état demande
                Else
                    [L]STA = [L]PPDSTA_ACCEPTE
                Endif
            Endif
        Else
            [L]STA = [L]PPDSTA_ACCEPTE
        Endif

        [F:HRPPD]STA = [L]STA

        If [F:HRPPD]STA = [L]PPDSTA_ACCEPTE
            [F:HRPPD]ACPAMT = [F:HRPPD]DEMAMT
        Endif

        [F:HRPPD]WRK = "s"

        Rewrite [F:HRPPD]
        If fstat <> 0
            [V]GOK = 0
            Call FSTA("HRPPD") From GLOCK
            Break
        Endif
    Endif
Next
If fstat = 1 & [V]GOK = 1 : [V]GOK = -1 : [V]GLOCK = "$PPREQUESTD" : Return : Endif
If [V]GOK < 1 : Return : Endif

[F:HRPPH]REQSTA = 2    : # Bordereau soumis
Rewrite [F:HRPPH]
If fstat <> 0
    [V]GOK = 0
    Call FSTA("HRPPH") From GLOCK
Endif

Return

