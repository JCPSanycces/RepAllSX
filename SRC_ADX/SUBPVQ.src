######################################################################## 
# SUBPVQ : Affichage détail Mts tarif achat ligne         MBT 04/03/08 # 
# -------------------------------------------------------------------- # 
# Ce traitement n'est pas un objet mais est utilisé par le s/p         # 
# d'affichage valorisation ligne cde ou rcp (Action VISUVALPOQ) et ne  # 
# sert qu'a gérer le masque écran "PVALPOQ [PVQ1]".                    # 
######################################################################## 


$ACTION
Case ACTION
 When default
Endcase
Return


##############################################
# Chargement du format des montants :        #
#   - répartis si I est différent de 0       #
#   - autres si I égal 0                     #
##############################################
Funprog FMT(I)
Value Integer I
Local Char FORMAT(15)
FORMAT="NZP:"+GDEVFMT1(max(find([M:PVQ1]CUR,GDEVISE(1..GNBDEV)),1))
If I>0
  #----- Faire disparaitre les montants répartis non utilisés -----#
  If evalue("[M:"+[M:PVQ1]WABMSK+"]INVDTALIN2(I-1)")=0 & evalue("[M:PVQ1]DISCRGAMT"+num$(I))=0
    FORMAT="-"+FORMAT
  Endif
  #-----
Endif
End FORMAT
