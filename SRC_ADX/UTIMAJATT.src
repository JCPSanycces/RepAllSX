#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Création des répertoires ATT, DEC etc.
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Create directories on folder") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJATT
End

#-------------------#
$MAJATT

Local Char    APPLI(GDIMFIC) , VOLUME(1)
Local Char    MACHINE(GDIMFIC)
Local Integer I , ERREUR

Local File ADOSSIER [ADS_] , AVOLUME [AVL_]

# Create folder
Read [ADS_]DOSSIER=DOSSIER
If !fstat
 MACHINE = adxmac(0)
 APPLI  = [F:ADS_]DOSSIER
 VOLUME = [F:ADS_]VOLUME
 Gosub SET_DIRECT_STO From DOSAPL
 For I=1 To NBDIR
  ERREUR = 0
  Call CREREP(filpath(TBDIR(I),"","",APPLI,VOLUME,MACHINE),ERREUR) From DOSAPL
 Next I
Endif

# Create record
Trbegin [AVL_]
 Read [AVL_]CODE="ATT"
 If fstat
  Raz [F:AVL_]
  [F:AVL_]VOLUME = "ATT"
  [F:AVL_]ROOT = "ATT"
  Write [AVL_]
  If fstat
   Call ERREUR("AVOLUME",1) From DOSDIC
  Endif
 Endif
Commit

Close Local File [ADS_] , [AVL_]

Return

