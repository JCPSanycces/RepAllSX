  IMPENT = [M]STG(indice)
 Endif
Endif
[M]STG = IMPENT

## Zone PDIFLG
mkstat = 0
zoncou = "PDIFLG"
indice = 0
IMPENT = [M]PDIFLG
WNUM = IMPENT
If varinit([M]PDIFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]PDIFLG,indice)=0
 [M]PDIFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PDIFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PDIFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PDIFLG(IMPENT) From SUBPOT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PDIFLG" : GZNUM = 55067 : Endif
