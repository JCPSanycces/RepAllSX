#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque POT3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CCV
mkstat = 0
zoncou = "CCV"
indice = 0
WCHAR = [M]CCV
If varmode([M]CCV,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CCV([M]CCV) From SUBPOT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CCV : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CCV" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTHRCCV"
  Call CONTHRCCV([M]CCV,GCURLEG) From SUBHRCCV
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CCV" : GZNUM = 11208 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]CCV
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]CCV = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CCV" : GZNUM = 11208 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]CCV or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_CCV([M]CCV) From SUBPOT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CCV" : GZNUM = 11208 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varinit([M]DES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DES,"CLASSCONV","DES",[M:POT3]CCV,GCURLEG) From ATEXTRA
 GACTION = SAVACT
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone CPYPOT
mkstat = 0
zoncou = "CPYPOT"
indice = 0
If varmode([M]CPYPOT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPYPOT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTCPY"
 Call CONTSOC([M]CPYPOT) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CPYPOT" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CPY","!A",[M]CPYPOT,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPYPOT" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone FCYPOT
mkstat = 0
zoncou = "FCYPOT"
indice = 0
WCHAR = [M]FCYPOT
If varmode([M]FCYPOT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCYPOT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]FCYPOT) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FCYPOT" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!",[M]FCYPOT,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "FCYPOT" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTFCYCPY"
   Call CONTFCYCPY([M]FCYPOT,[M]CPYPOT) From EXEFNC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FCYPOT" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]FCYPOT or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_FCYPOT([M]FCYPOT) From SUBPOT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "FCYPOT" : GZNUM = 1344 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

