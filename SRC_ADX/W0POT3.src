mkstat = 0
zoncou = "PDIEND"
indice = 0
If varmode([M]PDIEND,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PDIEND([M]PDIEND) From SUBPOT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PDIEND : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PDIEND" : Gosub ACTION From =IMPTRT
 Endif
