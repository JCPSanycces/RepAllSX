mkstat = 0
zoncou = "HDCFLG"
indice = 0
IMPENT = [M]HDCFLG
WNUM = IMPENT
If varinit([M]HDCFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]HDCFLG,indice)=0
 [M]HDCFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "HDCFLG" : Gosub ACTION From =IMPTRT
