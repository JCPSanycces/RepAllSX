## Zone HDCTYP
mkstat = 0
zoncou = "HDCTYP"
indice = 0
If varinit([M]HDCTYP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]HDCTYP,"11670","HDCTYP") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]HDCTYP,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "HDCTYP" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]HDCTYP,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "HDCTYP" : GZNUM = 55069 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]HDCTYP,"11670","HDCTYP") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "HDCTYP" : GZNUM = 55069 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]HDCTYP,"11670",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "HDCTYP" : GZNUM = 55069 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
