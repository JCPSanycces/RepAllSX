####################################
IMPTBL = 0

## Zone SCACPC
mkstat = 0
zoncou = "SCACPC"
indice = 0
If varinit([M]SCACPC,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SCACPC,"11702","SCACPC") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SCACPC,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SCACPC" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]SCACPC,"11702","SCACPC") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SCACPC" : GZNUM = 55065 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]SCACPC,"11702",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "SCACPC" : GZNUM = 55065 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone OFOCOD
mkstat = 0
zoncou = "OFOCOD"
indice = 0
If varmode([M]OFOCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OFOCOD" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("HRSOFO1","!",[M]OFOCOD,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OFOCOD" : GZNUM = 55243 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 6
####################################
IMPTBL = 0

## Zone EQUEMPTYP
mkstat = 0
zoncou = "EQUEMPTYP"
indice = 0
IMPENT = [M]EQUEMPTYP
If varinit([M]EQUEMPTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]EQUEMPTYP,indice)=0
 [M]EQUEMPTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EQUEMPTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EQUEMPTYP(indice)
 Endif
Endif
[M]EQUEMPTYP = IMPENT

## Zone STG
mkstat = 0
zoncou = "STG"
indice = 0
IMPENT = [M]STG
If varinit([M]STG,indice)=0
