  SAVACT = GACTION : GACTION = "STD"
  Call C_PDIEND([M]PDIEND) From SUBPOT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PDIEND" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
