#<AdxTL>@(#)4.0.0.0 $Revision$
###########################################################################################
#   Gestion des prestataires Help-Desk                   Module CRM         19 juillet 2000
###########################################################################################
###########################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

###########################################################################################
$OUVRE
Global Integer ISDIRTY

  ISDIRTY = 0
  If !clalev([F:PRX]) : Local File SUBCONT [PRX] : Endif
  If !clalev([F:SBG]) : Local File SBGEO [SBG] : Endif
  If !clalev([F:SBP]) : Local File SBPBL [SBP] : Endif
  If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
Return

###########################################################################################
$DEFBOUT
Return

###########################################################################################
$SETBOUT
  If ISDIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

###########################################################################################
$OUVRE_BOITE
Return

###########################################################################################
$DEBUT
Local Integer I
Local Char SZEXPCOD

  If clalev([F:ADI]) <= 0 Local File ATABDIV [ADI] : Endif
  SZEXPCOD = ""
  I = 0
  #Initialise la fenêtre avec les valeurs passées en paramètre.
  [M:PRX0]BPRNUM = PARAM(1)
  Read [BPR]BPR0=PARAM(1)
  If !fstat Then
    [M:PRX0]BPRNAM = [F:BPR]BPRNAM
  Endif
  [M:PRX3]CUR1 = PARAM(2)
  [M:PRX3]CUR2 = PARAM(2)
  Affzo [M:PRX3]
  #Chargement des informations
  #Chargement du tableau des familles de compétence
  Filter [SBP] Where [F:SBP]BPRNUM = PARAM(1)
  I = 0
  For [SBP]
    If I >= dim([M:PRX1]PBL)-1 Then
      Break
    Endif
    If [F:SBP]PBL = "" Then
      Break
    Endif
    [M:PRX1]PBL(I) = [F:SBP]PBL
    If [M:PRX1]PBL(I) = "" Then
      [M:PRX1]PBLCLA(I) = ""
    Else
      Read [PBL]PBL0=[M:PRX1]PBL(I)
      If fstat Then
        [M:PRX1]PBLCLA(I) = ""
      Else
        # FGR 23/09/2009 : X3SUIVI58024
        #[M:PRX1]PBLCLA(I) = [F:PBL]GRPPBLDES
        Call LECTEXTRA([M:PRX1]PBLCLA(I),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      Endif
    Endif
    I += 1
  Next
  [M:PRX1]NBPBL = I
  Filter [SBP]
  #Chargement du tableau des secteurs d'intervention
  Filter [SBG] Where [F:SBG]BPRNUM = PARAM(1)
  I = 0
  For [SBG]
    If I >= dim([M:PRX2]CRY)-1 Then
      Break
    Endif
    If [F:SBG]ARACOD = "" Then
      Break
    Endif
    [M:PRX2]CRY(I) = [F:SBG]CRY
    [M:PRX2]ARACOD(I) = [F:SBG]ARACOD
    [M:PRX2]ARANAM(I) = [F:SBG]ARANAM
    I += 1
  Next
  [M:PRX2]NBARA = I
  Filter [SBG]
  #Chargement des conditions financières
  Read [PRX]PRX0=PARAM(1)
  If !fstat Then
    [M:PRX2]EVRARA = [F:PRX]EVRARA 
    [M:PRX3]RATHOU = [F:PRX]RATHOU
    [M:PRX3]EXSINV = [F:PRX]EXSINV
    [M:PRX3]EXSVLT = [F:PRX]EXSVLT
    [M:PRX3]PTE = [F:PRX]PTE
    [M:PRX3]CUR1 = [F:PRX]CUR
    [M:PRX3]CUR2 = [F:PRX]CUR
    Read [ADI]CODE=423;[M:PRX3]EXSINV
    If !fstat Then
      SZEXPCOD = [F:ADI]A1
    Endif
    Case SZEXPCOD
      When "A"
        [M:PRX3]EXSVLT = 0
        [M:PRX3]CUR2 = ""
        [M:PRX3]EXSVLTX = ""
        Grizo [M:PRX3]EXSVLT
        Grizo [M:PRX3]EXSVLTX
        Grizo [M:PRX3]CUR2
      When "B"
        Actzo [M:PRX3]EXSVLT
        Actzo [M:PRX3]EXSVLTX
        Actzo [M:PRX3]CUR2
        If [M:PRX3]CUR2 = "" Then
          [M:PRX3]CUR2 = [M:PRX3]CUR1
        Endif
        [M:PRX3]EXSVLTX = mess(228,196,1)  #en tant que montant forfaitaire
      When "C"
        Actzo [M:PRX3]EXSVLT
        Actzo [M:PRX3]EXSVLTX
        Actzo [M:PRX3]CUR2
        If [M:PRX3]CUR2 = "" Then
          [M:PRX3]CUR2 = [M:PRX3]CUR1
        Endif
        [M:PRX3]EXSVLTX = mess(229,196,1)  #par kilomètre parcouru
      When "D"
        Actzo [M:PRX3]EXSVLT
        Actzo [M:PRX3]EXSVLTX
        Actzo [M:PRX3]CUR2
        If [M:PRX3]CUR2 = "" Then
          [M:PRX3]CUR2 = [M:PRX3]CUR1
        Endif
        [M:PRX3]EXSVLTX = mess(230,196,1)  #par heure écoulée
      When Default
    Endcase
  Endif
  ################################################################################
  # Grize le tableau des zones géographique si le prestataire est toutes zones.
  ################################################################################
  If [M:PRX2]EVRARA = 2 Then
    Grizo [M:PRX2]10
  Endif
  Affzo [M:PRX0]
  Affzo [M:PRX1]
  Affzo [M:PRX2]
  Affzo [M:PRX3]
Return

###########################################################################################
$AV_CHOIX
Return

###########################################################################################
AP_CHOIX
Return

###########################################################################################
$AVANT_BOUTON
Return

###########################################################################################
$FINSAI
  Raz [M:PRX0]
  Raz [M:PRX1]
  Raz [M:PRX2]
  Raz [M:PRX3]
  Kill ISDIRTY
  Close Local File [PRX]
Return

###########################################################################################
$FIN
Return

###########################################################################################
$ABANDON
Return

###########################################################################################
$APRES_MODIF
  ISDIRTY = 1
Return

###########################################################################################
$BOUTON
Return

###########################################################################################
$ONOK
  Gosub ONSAVE
  FIN = 0
Return

#########################################################
# Sous-programmes
#########################################################
###########################################################################################
# Traitement du bouton Enregistrer
$ONSAVE
Local Integer Z

  If [M:PRX0]BPRNUM = "" Then
    GMESSAGE = mess(226,196,1) #Un tiers doit être mentionné pour effectuer l'enregistrement.
    GERR = 2
    Return
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [PRX], [SBG], [SBP]
  #Enregistrement du tableau des familles de compétences :
  For Z = 0 To [M:PRX1]NBPBL-1
    If [M:PRX1]PBL(Z) <> "" Then
      Readlock [SBP]SBP2=[M:PRX0]BPRNUM;[M:PRX1]PBL(Z)
      If fstat Then
        #Il s'agit d'un nouvel enregistrement
        [F:SBP]BPRNUM = [M:PRX0]BPRNUM
        [F:SBP]PBL = [M:PRX1]PBL(Z)
        Write [SBP]
        If fstat Then
          GMESSAGE = mess(100,141,1) #Erreur création
          GERR = 1
          Unlock [SBP]
          Rollback
          End
        Endif
       Else
        # Il s'agit d'une modification
        [F:SBP]BPRNUM = [M:PRX0]BPRNUM
        [F:SBP]PBL = [M:PRX1]PBL(Z)
        Rewrite [SBP]
        If fstat Then
          GMESSAGE = mess(101,141,1) #Erreur modification
          GERR = 1
          Unlock [SBP]
          Rollback
          End
        Endif
      Endif
    Endif
  Next
  #Enregistrement du tableau des zones géographiques :
  For Z = 0 To [M:PRX2]NBARA-1
    If [M:PRX2]CRY(Z) <> "" and [M:PRX2]ARACOD(Z) <> "" Then
      Readlock [SBG]SBG2=[M:PRX0]BPRNUM;[M:PRX2]CRY(Z);[M:PRX2]ARACOD(Z)
      If fstat Then
        #Il s'agit d'un nouvel enregistrement
        [F:SBG]BPRNUM = [M:PRX0]BPRNUM
        [F:SBG]CRY = [M:PRX2]CRY(Z)
        [F:SBG]ARACOD = [M:PRX2]ARACOD(Z)
        [F:SBG]ARANAM = [M:PRX2]ARANAM(Z)
        Write [SBG]
        If fstat Then
          GMESSAGE = mess(100,141,1) #Erreur création
          GERR = 1
          Unlock [SBG]
          Rollback
          End
        Endif
      Else
        # Il s'agit d'une modification
        [F:SBG]BPRNUM = [M:PRX0]BPRNUM
        [F:SBG]CRY = [M:PRX2]CRY(Z)
        [F:SBG]ARACOD = [M:PRX2]ARACOD(Z)
        [F:SBG]ARANAM = [M:PRX2]ARANAM(Z)
        Rewrite [SBG]
        If fstat Then
          GMESSAGE = mess(101,141,1) #Erreur modification
          GERR = 1
          Unlock [SBG]
          Rollback
          End
        Endif
      Endif
    Endif
  Next
  Readlock [PRX]PRX0=[M:PRX0]BPRNUM
  If fstat = 5 Then
    #Enregistrement non trouvé, il faut le créer
    [F:PRX]EVRARA = [M:PRX2]EVRARA
    [F:PRX]RATHOU = [M:PRX3]RATHOU
    [F:PRX]EXSINV = [M:PRX3]EXSINV
    [F:PRX]EXSVLT = [M:PRX3]EXSVLT
    [F:PRX]PTE = [M:PRX3]PTE
    [F:PRX]CUR = [M:PRX3]CUR1
    [F:PRX]BPRNUM = [M:PRX0]BPRNUM
    Write [PRX]
    If fstat Then
      Rollback
      Unlock [PRX]
      GMESSAGE = mess(227,196,1) #Erreur lors de l'enregistrement. Transaction abandonnée.
      GERR = 1
      Return
    Endif
  Elsif fstat = 0 Then
    #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
    [F:PRX]EVRARA = [M:PRX2]EVRARA
    [F:PRX]RATHOU = [M:PRX3]RATHOU
    [F:PRX]EXSINV = [M:PRX3]EXSINV
    [F:PRX]EXSVLT = [M:PRX3]EXSVLT
    [F:PRX]PTE = [M:PRX3]PTE
    [F:PRX]CUR = [M:PRX3]CUR1
    [F:PRX]BPRNUM = [M:PRX0]BPRNUM
    Rewrite [PRX]
    If fstat Then
      Rollback
      Unlock [PRX]
      GMESSAGE = mess(227,196,1) #Erreur lors de l'enregistrement. Transaction abandonnée.
      GERR = 1
      Return
    Endif
  Endif
  Commit
  ISDIRTY = 0
  ETABOU(GSPE1) = 0
Return

############################################################
# Annulation de toutes les zones géographiques saisies pour un prestataire.
###########################################################################################
Subprog RAZARA(SZPRXNUM)
Value Char SZPRXNUM

  Call DEBTRANS From GLOCK
  Trbegin [SBG]
  Delete [SBG] Where [F:SBG]BPRNUM = SZPRXNUM
  If fstat Then
    Rollback
    End
  Endif
  Commit
End
