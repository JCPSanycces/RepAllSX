#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,"RECUPLNK","RECUPLNK",3,"XYRECUPLNK") From GTRAITE
End

#######################################################################
$ACTION
Case ACTION
 When "INIT_DIA"  : Gosub INIT_DIA
 When "EXEC"      : Gosub EXEC
Endcase
Return

$INIT_DIA
Raz [M:DIA]
[M:DIA]TOUOBJ = 2
TMP = 1
Return

$EXEC
Local Char    OBJET(GLONAOB), GROUPE(10)
Local Char    CLECUR1(30) , CLECUR2(30)(0..16)
Local Char    IDLNK(GLONID2) , IDDST(GLONID2) , TBDST(GLONATB)
Local Integer CL , I , K , N
Local Integer WNB0 , WNB1
Local Schar   WLNK0(20)(1..800) , WLNK1(20)(1..800)
Local Integer ERR , OKTRT
Local Char    MESSAGE(250)

Onerrgo ERREUR

If clalev([F:AOB])=0 : Local File AOBJET  [AOB] : Endif
If clalev([F:ALI])=0 : Local File ALINK   [ALI] : Endif

If !GSERVEUR
 Call OUVRE_TRACE(mess(177,115,1)) From LECFIC : # Récupération des liaisons
Endif
Call OUVRE_VLC(mess(177,115,1),"","") From GESECRAN : # Récupération des liaisons

GROUPE = [M:DIA]GRP
If [M:DIA]TOUOBJ=2
 For [AOB] Where NOMFIC<>""
  OBJET = [F:AOB]ABREV
  Gosub SUPPR
 Next AOB
 Raz OBJET, fstat
 Repeat
  If clalev([F:AOB])=0 : Local File AOBJET  [AOB] : Endif
  Filter [AOB] Where ABREV>OBJET & NOMFIC<>""
  Read [AOB]ABREV First
  Filter [AOB]
  If !fstat
   OBJET = [F:AOB]ABREV
   Gosub VERIF
   If OK : Gosub RECUP : Endif
   fstat = 0
  Endif
 Until fstat or GOK<1 or ERR
Else
 OBJET = [M:DIA]OBJ
 Read [AOB]ABREV = OBJET
 Gosub VERIF
 If OK
  Gosub SUPPR
  Gosub RECUP
 Endif
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Call FERME_VLC From GESECRAN
Return

$ERREUR
ERR = errn
MESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERR)-":"-errmes$(ERR)-errm
Call ECR_TRACE(MESSAGE,1) From GESECRAN
Resume

################################################################
$VERIF
OK = 1
If [F:AOB]CODACT<>""
 Local File ACTIV [AAA_]
 Read [AAA_]CODACT = [F:AOB]CODACT
 If fstat or [F:AAA_]FLACT<>2
  OK = 0
 Endif
 Close Local File [AAA_]
Endif
Call EXISTE_ADX("","","WO"+OBJET,OKTRT) From ORDSYS
If !OKTRT
 OK = 0
Endif
If [F:AOB]NOMFIC<>"" & filinfo(filpath("FIL",[F:AOB]NOMFIC,"fde"),0)<0
 OK = 0
Endif
Return

################################################################
$RECUP
If clalev([F:AOT])=0 : Local File AOBJTAB [AOT] : Endif
If clalev([F:AOK])=0 : Local File AOBJLNK [AOK] : Endif
If clalev([F:ALI])=0 : Local File ALINK   [ALI] : Endif
Read [AOT]ABREV = OBJET
Gosub NOMFIC From ="WO"+OBJET
If NBLNK
 Call AFF_VLC(mess(33,115,1),OBJET) From GESECRAN : # Objet
 Call ECR_TRACE(date$-time$-mess(177,115,1)-OBJET,0) From GESECRAN : # Récupération des liaisons
Endif
Gosub OUVRE  From ="WO"+OBJET
Gosub SETCLE From ="WO"+OBJET
Gosub LIENS
Gosub LIENS2
Close Local File
Return


################################################################
$SUPPR
Call AFF_VLC(mess(5,100,1),OBJET) From GESECRAN : # Annulation en cours ...
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [ALI]
 Delete [ALI] Where USRCOD=GROUPE & DSTOBJ=OBJET & AUTFLG=2
 If fstat=1
  GOK = -1 : GLOCK = "$ALINK"-OBJET : Goto ROLL_TR1
 Endif
 Delete [ALI] Where USRCOD=GROUPE & SRCOBJ=OBJET & INVFLG=2 & AUTFLG=2
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

################################################################
$LIENS
If ABFIC=""
 ERR = 1
Elsif evalue("clalev([F:"+ABFIC+"])")=0
 Gosub OUVFIC From ="WO"+OBJET
Endif
If ERR
 Call ECR_TRACE(mess(196,133,1)-NOMFIC,1) From GESECRAN : # Erreur à l'ouverture de la table
 ERR = 0 : Return 
Endif
Gosub DEFAUT From ="WO"+OBJET
Read [F] First
If ERR
 Call ECR_TRACE(mess(49,125,1)-NOMFIC-"["+ABFIC+"]",1) From GESECRAN : # Erreur de lecture
 ERR = 0 : Return 
Endif
If evalue("dim([F]"+CLEPRIM+")")<=0
 # Champ inexistant sur la table
 Call ECR_TRACE(mess(33,115,1)-OBJET-"[F:"+ABFIC+"]"+CLEPRIM-":"-mess(13,133,1)-NOMFIC,1) From GESECRAN
 ERR = 0 : Return
Endif
K = 1
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>"" & evalue("dim([F]"+CLESEC(I)+")")<=0
  # Champ inexistant sur la table
  Call ECR_TRACE(mess(33,115,1)-OBJET-"[F:"+ABFIC+"]"+CLESEC(I)-":"-mess(13,133,1)-NOMFIC,1) From GESECRAN
  K = 0 : Break
 Endif
Next I
If !K : ERR = 0 : Return : Endif
For [F]
 Gosub SET_CLE From GOBJSUB
 Call IDENT3(OBJET,IDLNK,CLECUR1,CLECUR2) From GOBJTXT
 Gosub LIAISONS From ="WO"+OBJET
 Call DEBTRANS From GLOCK
 Gosub TR2
Next
Return

$TR2
GOK = 1
Trbegin [ALI]
 For I=1 To NBLNK
  If NUMLNK(I)=0
   Gosub SET_LIAISON
  Else
   For J=1 To min(300,LIGLNK(I))
    indice = J-1
    Case NUMLNK(I)
     When 1 : Gosub LIAISONS_1 From ="WO"+OBJET
     When 2 : Gosub LIAISONS_2 From ="WO"+OBJET
     When 3 : Gosub LIAISONS_3 From ="WO"+OBJET
     When 4 : Gosub LIAISONS_4 From ="WO"+OBJET
     When 5 : Gosub LIAISONS_5 From ="WO"+OBJET
     When 6 : Gosub LIAISONS_6 From ="WO"+OBJET
     When 7 : Gosub LIAISONS_7 From ="WO"+OBJET
     When 8 : Gosub LIAISONS_8 From ="WO"+OBJET
     When 9 : Gosub LIAISONS_9 From ="WO"+OBJET
    Endcase
    Gosub SET_LIAISON
   Next J
  Endif
 Next I
Commit
Return

$SET_LIAISON
Call IDDST(OBJLNK(I),ABRLNK(I),IDDST,TBDST) From GOBJET1
If IDDST<>""
 Raz [F:ALI]
 [F:ALI]USRCOD = GROUPE
 [F:ALI]SRCOBJ = OBJLNK(I)
 [F:ALI]SRCKEY = IDDST
 [F:ALI]DSTOBJ = OBJET
 [F:ALI]DSTTIT = TITOBJ
 [F:ALI]DSTKEY = IDLNK
 [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
 If NOMINT<>""
  If evalue("dim([F:"+ABFIC+"]"+NOMINT+")")<=0
   N = instr(1,IDLNK,"~")
   If N
    Call LECTEXTRA([F:ALI]DSTDES,NOMFIC,NOMINT,left$(IDLNK,N-1),right$(IDLNK,N+1)) From ATEXTRA
   Else
    Call LECTEXTRA([F:ALI]DSTDES,NOMFIC,NOMINT,IDLNK,"") From ATEXTRA
   Endif
  Elsif evalue("type([F:"+ABFIC+"]"+NOMINT+")")>10
   [F:ALI]DSTDES = evalue("[F:"+ABFIC+"]"+NOMINT)
  Else
   N = evalue("[F:"+ABFIC+"]"+NOMINT)
   Call TEXTE(N,[F:ALI]DSTDES) From OBJDIV
  Endif
 Endif
 [F:ALI]LNK    = CODLNK(I)
 [F:ALI]ENAFLG = 2
 [F:ALI]INVFLG = 1
 [F:ALI]AUTFLG = 2
 [F:ALI]CREDAT = date$
 [F:ALI]CREUSR = GUSER
 If dim([F:ALI]CRETIM)>0 : [F:ALI]CRETIM = time  : Endif
 Write [ALI]
 K = find(CODLNK(I),GCODLNK(1..GNBLNK))
 If K & GINVLNK(K)<>""
  Raz [F:ALI]
  [F:ALI]USRCOD = GROUPE
  [F:ALI]SRCOBJ = OBJET
  [F:ALI]SRCKEY = IDLNK
  [F:ALI]DSTOBJ = OBJLNK(I)
  [F:ALI]DSTTIT = TITLNK(I)
  [F:ALI]DSTKEY = IDDST
  [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
  If DESLNK(I)<>""
   If evalue("dim("+DESLNK(I)+")")<=0
    N = instr(1,IDDST,"~")
    If N
     Call LECTEXTRA([F:ALI]DSTDES,TBDST,DESLNK(I),left$(IDDST,N-1),right$(IDDST,N+1)) From ATEXTRA
    Else
     Call LECTEXTRA([F:ALI]DSTDES,TBDST,DESLNK(I),IDDST,"") From ATEXTRA
    Endif
   Elsif evalue("type("+DESLNK(I)+")")>10
    [F:ALI]DSTDES = evalue(DESLNK(I))
   Else
    N = evalue(DESLNK(I))
    Call TEXTE(N,[F:ALI]DSTDES) From OBJDIV
   Endif
  Endif
  [F:ALI]LNK    = GINVLNK(K)
  [F:ALI]ENAFLG = 2
  [F:ALI]INVFLG = 2
  [F:ALI]AUTFLG = 2
  [F:ALI]CREDAT = date$
  [F:ALI]CREUSR = GUSER
  If dim([F:ALI]CRETIM)>0 : [F:ALI]CRETIM = time  : Endif
  Write [ALI]
 Endif
Endif
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

################################################################
$LIENS2
WNB0 = 0
Case OBJET
 When "AMK","AWI","ATB","AWA"
  If evalue("clalev([F:"+ABFIC+"])")=0
   Gosub OUVFIC From ="WO"+OBJET
  Endif
  Call AFF_VLC(mess(33,115,1),OBJET) From GESECRAN : # Objet
  Call ECR_TRACE(mess(177,115,1)-OBJET-"(2)",0) From GESECRAN : # Récupération des liaisons
  Gosub DEFAUT From ="WO"+OBJET
  For [F]
   Trbegin [ALI]
    Gosub CRE_LIENS From ="SUB"+OBJET
   Commit
  Next
Endcase
Return

########################################
Subprog AS_OBJ(VALEUR)
Variable Char    VALEUR()
If [M]TOUOBJ=2 : mkstat = 1 : Endif
End
