#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITC18   Table QLYCRD les désignations deviennent        Module TC #
#           traduisibles                                                 #
##########################################################################
# FGR 24/09/2009 : X3SUIVI58062
##########################################################################
Local Char DOSSIER(30)

  If 0=1 Then
    DOSSIER = nomap
    # Issue 108760 - 2015-08-07 by MAE :
    #Call SAIDOS(DOSSIER,"") From SAIDOS
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      # Issue 108760 - 2015-08-07 by MAE :
      #Read [ADS]DOSSIER=[L]DOSSIER
      #If fstat THEN
      #  Raz [F:ADS]
      #Endif
      If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITC18(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTITC18(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC18(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)

  IERR = 0
  Call ECR_TRACE("UTITC18: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table QLYCRD
  #
  If filinfo(filpath("FIL", "ATEXTRA", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".ATEXTRA" [AXX]
# hcb 72510 deb

If clalev([F:QLQ]) = 0 : Local File =SZAPPLI+".QLYCRDQST" [QLQ]   : Endif
If clalev([F:TCT]) = 0 : Local File =SZAPPLI+".TABCTL"    [TCT]   : Endif
If clalev([F:AMK1])= 0 : Local File =SZAPPLI+".AMSK"      [AMK1]  : Endif
If clalev([F:AMK2])= 0 : Local File =SZAPPLI+".AMSK"      [AMK2]  : Endif
If clalev([F:AMZ1])= 0 : Local File =SZAPPLI+".AMSKZON"   [AMZ1]  : Endif
If clalev([F:AMZ2])= 0 : Local File =SZAPPLI+".AMSKZON"   [AMZ2]  : Endif
If clalev([F:AMA1])= 0 : Local File =SZAPPLI+".AMSKACT"   [AMA1]  : Endif
If clalev([F:AMA2])= 0 : Local File =SZAPPLI+".AMSKACT"   [AMA2]  : Endif
If clalev([F:AMP1])= 0 : Local File =SZAPPLI+".AMSKPAR"   [AMP1]  : Endif
If clalev([F:AMP2])= 0 : Local File =SZAPPLI+".AMSKPAR"   [AMP2]  : Endif
If clalev([F:AWI1])= 0 : Local File =SZAPPLI+".AWINDOW"   [AWI1]  : Endif
If clalev([F:AWI2])= 0 : Local File =SZAPPLI+".AWINDOW"   [AWI2]  : Endif
If clalev([F:AWP1])= 0 : Local File =SZAPPLI+".AWINPAR"   [AWP1]  : Endif
If clalev([F:AWP2])= 0 : Local File =SZAPPLI+".AWINPAR"   [AWP2]  : Endif
If clalev([F:AWT1])= 0 : Local File =SZAPPLI+".AWINBOUT"  [AWT1]  : Endif
If clalev([F:AWT2])= 0 : Local File =SZAPPLI+".AWINBOUT"  [AWT2]  : Endif
If clalev([F:AWB1])= 0 : Local File =SZAPPLI+".AWINBRO"   [AWB1]  : Endif
If clalev([F:AWB2])= 0 : Local File =SZAPPLI+".AWINBRO"   [AWB2]  : Endif
If clalev([F:AWI1])= 0 : Local File =SZAPPLI+".AWINDOW"   [AWI1]  : Endif

# hcb52510 end

#  Ouverture des tables pour delmsk et delwin  cc et hcb 74033 22/05/2011

 If clalev([F:AMK])=0 : Local File =SZAPPLI+".AMSK"     [AMK] : Endif
 If clalev([F:AMZ])=0 : Local File =SZAPPLI+".AMSKZON"  [AMZ] : Endif
 If clalev([F:AMA])=0 : Local File =SZAPPLI+".AMSKACT"  [AMA] : Endif
 If clalev([F:AMP])=0 : Local File =SZAPPLI+".AMSKPAR"  [AMP] : Endif
 If clalev([F:AWI])=0 : Local File =SZAPPLI+".AWINDOW"  [AWI] : Endif
 If clalev([F:AWP])=0 : Local File =SZAPPLI+".AWINPAR"  [AWP] : Endif
 If clalev([F:AWB])=0 : Local File =SZAPPLI+".AWINBRO"  [AWB] : Endif
 If clalev([F:AWT])=0 : Local File =SZAPPLI+".AWINBOUT" [AWT] : Endif

Local Char APPLI : APPLI=SZAPPLI                                        # hcb 74365
If clalev([F:AEL])=0  : Local File =APPLI+".AELT"       [AEL] : Endif   # hcb 74365
If clalev([F:AEK])=0  : Local File =APPLI+".AELTLINK"   [AEK] : Endif   # hcb 74365
Gosub OUVFIC From VALMSKLEC                                             # hcb 74365
Gosub OUVFIC From VALWINLEC                                             # hcb 74365


  #
  If filinfo(filpath("FIL", "QLYCRD", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI + ".QLYCRD" [QLC]
    Local File =SZAPPLI + ".QLYCRD" [QLC_]
     If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif      # hcb 74365
 #   If dim([F:QLC]QLYCRDDES) > 0 or dim([F:QLC]TEX) > 0 Then     # hcb 74365
      Trbegin [QLC], [AXX]
      For [QLC]QLC0
        IUPDATE = 0
        If dim([F:QLC]QLYCRDDES) > 0 Then
           If [F:QLC]QLYCRDDES <> "" Then
              If [F:QLC]NUMLIN = 1            # hcb 74365
                 Call MAJTEXTRA([F:QLC]QLYCRDDES, "QLYCRD", "QLYDESAXX", [F:QLC]QLYCRD, "") From ATEXTRA
                 If GOK < 1 Then
                    Call ECR_TRACE("File ATEXTRA QLYCRD-QLYDESAXX" - [F:QLC]QLYCRD + ",Error =" - num$(fstat), 1) From GESECRAN
                    GOK = 1
                    IERR = 1
                    Break
                 Endif
              Endif                           # hcb 74365
              IUPDATE = 1
              [F:QLC]QLYCRDDES = ""
           Else
              Call LECTEXTRA(WCHAINE,"QLYCRD", "QLYDESAXX", [F:QLC]QLYCRD, "") From ATEXTRA
              If WCHAINE = "" Then
                 Call MAJTEXTRA(WCHAINE, "QLYCRD", "QLYDESAXX", [F:QLC]QLYCRD, "") From ATEXTRA
              Endif
           Endif
        Endif
#        Endif                         # hcb 74365
#        If dim([F:QLC]TEX) > 0 Then   # hcb 74365
          If [F:QLC]TEX <> "" Then
            Call MAJTEXTRA([F:QLC]TEX, "QLYCRD", "QSTTEXAXX", [F:QLC]QLYCRD, num$([F:QLC]NUMLIN)) From ATEXTRA
            If GOK < 1 Then
              Call ECR_TRACE("File ATEXTRA QLYCRD-QSTTEXAXX" - [F:QLC]QLYCRD + "/" + num$([F:QLC]NUMLIN) + ",Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              Break
            Endif
            IUPDATE = 1
            [F:QLC]TEX = ""
          Else
            Call LECTEXTRA(WCHAINE,"QLYCRD", "QSTTEXAXX", [F:QLC]QLYCRD, num$([F:QLC]NUMLIN)) From ATEXTRA
            If WCHAINE = "" Then
              Call MAJTEXTRA(WCHAINE, "QLYCRD", "QSTTEXAXX", [F:QLC]QLYCRD, num$([F:QLC]NUMLIN)) From ATEXTRA
            Endif
          Endif
#       Endif                        # hcb 74365
        If IUPDATE = 1 Then
          Rewrite [QLC]
        Endif
      Next
      If IERR = 0 Then
        Commit
      Else
        Rollback
      Endif
#    Endif                            # hcb 74365
    #
    If IERR = 0 Then
        If dim(GVALIDDIFF)>0            # hcb 77618
           Local Integer VALIDDIF
           VALIDDIF=GVALIDDIFF
           GVALIDDIFF=3
        Endif
       Filter [QLC_] Where NUMLIN = 1   # hcb 72510
              For [QLC_]QLC0
                  Call GENCRD(SZAPPLI,"QLYCRD1","IQLYCRD",[F:QLC_]QLYCRD) From CRDLIB
              Next
       Filter [QLC_]                    # hcb 72510
        If dim(GVALIDDIFF)>0            # hcb 77618
           GVALIDDIFF=VALIDDIF
       Endif
    Endif
    Close Local File [QLC]
    Close Local File [QLC_]
  Endif
  Close Local File [AXX]
  #
  If IERR = 0 Then
    If clalev([F:AOB]) = 0 : Local File =SZAPPLI + ".AOBJET"  [AOB] : Endif
    WOBJET = "QLC"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      Call MAJ_SEL(SZAPPLI, WOBJET) From PATCHAOB
      #
      If [F:AOB]TYPGES <> 4 Then
        # Pas de fenêtre pour les browsers
        Call VALID("O" + WOBJET, SZAPPLI, 1, IERR) From VALWIN
        If IERR <> 1 Then
          Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
        Endif
      Endif
      #
      Call VALID (WOBJET, SZAPPLI, 1, IERR) From VALOBJ
      If IERR <> 1 Then
        Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
      Endif
    Endif
  Endif
  #
  Call ECR_TRACE("UTITC18 : records processed", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"QLYCRD") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC18(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"QLYCRD") : End : Endif
  Call MAJ_UTITC18(APPLI)
End

