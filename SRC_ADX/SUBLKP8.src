#<AdxTL>@(#)6.0.0.0 $Revision$
########################################
Subprog IB_NBSOL
GBOUT1 = mess(31, 124, 1) #Détail
End

########################################
Subprog AS_NBSOL

Local Integer ISRE4NOL

If GILASTNOL <> nolign - 1
    ISRE4NOL = nolign - 1
    Gosub SETNEWSOL
    GILASTNOL = nolign - 1
Endif
End

########################################
Subprog C_NBSOL

Local Integer ISRE4NOL

If GILASTNOL <> nolign - 1
    ISRE4NOL = nolign - 1
    Gosub SETNEWSOL
    GILASTNOL = nolign - 1
Endif
End


#######################################################################################
# Sous programmes
#######################################################################################
$SETNEWSOL
Local Integer ITER
Local Integer ITER2
ITER = 0
ITER2 = 0

GSZSOLKEY = [M:LKP8]NUM(ISRE4NOL)
Read [SRE] SRE0 = [M:LKP8]NUM(ISRE4NOL)
If fstat
    [M:LKP8]TTR =""
    Raz [M:LKP8]FULDES
    [M:LKP8]DES =""
    [M:LKP8]DESICO =""
    [M:LKP8]DESFLG = 0
Else
    [M:LKP8]TTR = [F:SRE]SRETTR

    Read [HD1] HD10 = [M:LKP8]NUM(ISRE4NOL);"SRE"
    If fstat
        Raz [M:LKP8]FULDES
    Else
        [M:LKP8]FULDES = [F:HD1]CLOB
    Endif

    [M:LKP8]DES = [F:SRE]SREDES
    [M:LKP8]DESICO = ""
    [M:LKP8]DESFLG = [F:SRE]SREDESFLG
Endif

Gosub DISPICON

Affzo [M:LKP8]
Return

######################################################
#Affichage des icônes
######################################################
$DISPICON

#Gosub DEFICONNUM From SUBITNB1
Gosub DEFICONNUM From CRMUTIL150

#Synthèse description demande de service
Local Char SZDESCTL(250)
Raz SZDESCTL
Setlob SZDESCTL With [M:LKP8]FULDES
If SZDESCTL = ""
    [M:LKP8]DESICO = ""
    [M:LKP8]DES = ""
Else
    If len(SZDESCTL) > GLONCLE
        If [M:LKP8]DESFLG
            [M:LKP8]DESICO = SZICOSYNDON
        Else
            [M:LKP8]DESICO = SZICOSYN
            [M:LKP8]DES = SZDESCTL
        Endif
    Else    
        [M:LKP8]DES = SZDESCTL
        [M:LKP8]DESICO = ""    
    Endif
Endif

Return


