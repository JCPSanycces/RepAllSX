######################################################################################
Subprog C_CASH(VALEUR)
Variable Char    VALEUR()
If [M]BANOBL=2 & VALEUR="" GMESSAGE=mess(10,123,1) : mkstat=2 : End Endif
End
######################################################################################

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
Call CONTDEV(VALEUR,[M:IVPY]DATPAY) From TRTDEV
If fstat | mkstat End Endif
If [M:IVPY]BANK<>""
  Call CONTBAN([M:IVPY]DATPAY,[M:IVPY]BANK,VALEUR) From CPTSUB
Endif
End

Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
Local    Integer STAT
# Convertir le montant à régler dans la devise saisie
Call CONVERT([M:IVPY]CURINV,VALEUR,GLOCALDEV,[M]RATTYP,
&            date$,[M:IVPY]AMTINV,[M:IVPY]AMOUNT,[L]STAT) From TRTDEV
[M:IVPY]AMTLIN=[M:IVPY]AMTINV
Affzo [M:IVPY]AMOUNT
End

Subprog C_AMOUNT(VALEUR)
Variable Decimal VALEUR
Local Decimal VALINT
Local    Integer STAT
VALINT = VALEUR

## Bug 55769
Call CONVERT([M:IVPY]CURINV,[M:IVPY]CUR,GLOCALDEV,[M]RATTYP,
&            date$,[M:IVPY]AMTINV,VALINT,[L]STAT) From TRTDEV
 If VALEUR>VALINT

 ## Le montant doit être inférieur au solde de l'échéance
 GMESSAGE = mess(241,117,1)-":"-num$(VALINT)-[M]CUR
 mkstat = 2 : End
Endif
End

Subprog AM_AMOUNT(VALEUR)
Variable Decimal VALEUR
Local    Integer STAT
# Convertir le montant à régler dans la devise saisie
Call CONVERT([M:IVPY]CUR, [M:IVPY]CURINV,GLOCALDEV,[M]RATTYP,
&            date$,VALEUR,[M:IVPY]AMTLIN,[L]STAT) From TRTDEV
End

Subprog C_DATPAY(VALEUR)
Variable Date    VALEUR
Local Char       SOCIETE(GLONCPY)
Local Decimal    EXERCICE, PERIODE
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:BAN])=0 : Local File BANK     [BAN] : Endif
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
[L]SOCIETE = [F:FCY]LEGCPY
Call SETMAINREF([L]SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call CONTPER(VALEUR,GTYPGEN,[M:IVPY]FCY) From CPTSUB
If mkstat : End : Endif
If [M:IVPY]BANK<>"" & [M:IVPY]CUR<>""
 Call CONTBAN(VALEUR,[M:IVPY]BANK,[M:IVPY]CUR) From CPTSUB
Endif
End

