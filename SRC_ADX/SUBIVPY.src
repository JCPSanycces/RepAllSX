# 87923


Subprog AV_LSTFLD(VALEUR)
Variable Char    VALEUR()
# 78411 Sage Exchange - Hide Card fields for USA legislation
If GCURLEG="USA"
  Chgfmt [M:IVPY]CRDTYP With "-K:" + num$(type([M:IVPY]CRDTYP)-10) + "B"
  If dim([M:IVPY]ZCRDTYP)>0
    Chgfmt [M:IVPY]ZCRDTYP With "-KP:" + num$(type([M:IVPY]ZCRDTYP)-10) + "X"
  Endif
  Chgfmt [M:IVPY]CRDNUM With "-K:" + num$(type([M:IVPY]CRDNUM)-10) + "X"
  Chgfmt [M:IVPY]CRDEXYDAT With "-D:" + GFMDAT4
Endif
End

