######################################################################################
Subprog C_PAYMOD(VALEUR)
Variable Char    VALEUR()

End
######################################################################################
Subprog AM_PAYMOD(VALEUR)
Variable Char    VALEUR()

# 87923 : Gestion des prélèvements SDD
# Si la société gère le SDD il faut vérifier la cohérence du mode de règlement :
# Si l'ancien mode de règlement était de type SDD, le nvx doit être de type SDD
# Si l'ancien mode de règlement n'était pas de type SDD, le nvx ne doit pas être de type SDD
If dim(GSDDMGT)>0 & GSDDMGT=2
    If [M:IVPY]SDDFLG=2 & (dim([F:TAM]SDDFLG)<0 | [F:TAM]SDDFLG<>2)
    # Le mode de règlement doit être SDD
      GMESSAGE=mess(387,192,1) : mkstat = 2 : End
    Elsif [M:IVPY]SDDFLG=1 & (dim([F:TAM]SDDFLG)>0 & [F:TAM]SDDFLG=2)
    # Le mode de règlement ne doit pas être SDD
      GMESSAGE=mess(388,192,1) : mkstat = 2 : End
    Endif
Endif

# La transaction de saisie règlement est maintenant modifiable :
# --> On ne la recharge plus après modification du mode de règlement
## Si modif. du mode de paiement, recherche du type de règlement correspondant s'il ne venait du paramêtre tiers DENINVPAY
#If GDIV(4)<>[M:IVPY]PAYTYP & VALEUR<>[M:IVPY]PAYMOD
#    # recherche du 1er type règlement dt mode paiement=mode paiement de l'échéance à régler
#    Filter [KTPY] Where find (VALEUR,PAM) & SNS=2 & ENAFLG=2 & ([F:TPY]GFY="" | [F:FGR]FCY=GCURFCY) &
#&                       ([F:TPY]LEG="" | [F:TPY]LEG=GCURLEG)
#    Read [KTPY]TPY0 First
#    Filter [KTPY]
#    If fstat mkstat=2 : GMESSAGE=mess(215,192,1) : End Endif
#
#    [M:IVPY]PAYTYP=[F:TPY]PAYTYP
#    [M:IVPY]RATTYP=[F:TPY]RATTYP
#    [M:IVPY]BANCSH=[F:TPY]BANCSH
#    If[F:TPY]DACBAN=1 [M:IVPY]BANOBL=2 Else [M:IVPY]BANOBL=1 Endif
#Endif
#
#If [M:IVPY]BANCSH=1 Diszo [M:IVPY]CASH : Actzo [M:IVPY]BANK Else Actzo [M:IVPY]CASH : Diszo [M:IVPY]BANK Endif
#Effzo [M:IVPY]CHQNUM , CRDTYP , CRDNUM , CRDEXYDAT
# 87923

End

# 87923 : Gestion des prélèvements SDD
######################################################################################
# --------------------- Transaction de règlement
Subprog C_PAYTYP(VALEUR)
Variable Char    VALEUR()

# La transaction de règlement n'est pas de type recette
If [F:TPY]SNS<>2 GMESSAGE=mess(384,192,1) : mkstat = 2 : End Endif

# Si la société gère le SDD il faut vérifier la cohérence entre transaction de règlementet mode de règlement
If dim(GSDDMGT)>0 & GSDDMGT=2
    If [M:IVPY]SDDFLG=2 & (dim([F:TPY]EPACDTTRF)<0 | [F:TPY]EPACDTTRF<>2)
    # Transaction de règlement non SEPA incompatible avec un mode de règlement SDD
      GMESSAGE=mess(386,192,1) : mkstat = 2 : End
    Elsif [M:IVPY]SDDFLG=1 & (dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2)
    # Transaction de règlement non SEPA incompatible avec un mode de règlement SDD
      GMESSAGE=mess(385,192,1) : mkstat = 2 : End
    Endif
Endif

End

Subprog AM_PAYTYP(VALEUR)
Variable Char    VALEUR()
Gosub INIT_TPY From TRTVENSDD
Affzo [M:IVPY]1-99
End
# 87923

Subprog C_BANK(VALEUR)
Variable Char    VALEUR()
If [M]BANOBL=2 & VALEUR="" GMESSAGE=mess(10,123,1) : mkstat=2 : End Endif

If VALEUR <> ""
 If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
 Call LECTURE("BAN",VALEUR,"") From CONTOBJ
 If [F:BAN]FCY<>"" & GFINRSP<>[F:BAN]FCY
  # Banque/Caisse du site FCY
  GMESSAGE=mess([M]BANCSH,653,1)-mess(4,117,1)-[F:BAN]FCY : mkstat=2 : End
 Elsif [F:BAN]CPY<>"" & GSOCIETE<>[F:BAN]CPY
  # Banque/Caisse de la société CPY
  GMESSAGE=mess([M]BANCSH,653,1)-mess(5,117,1)-[F:BAN]CPY : mkstat=2 : End
 Elsif dim([F:BAN]ACS)>0 & [F:BAN]ACS<>"" : # GH 02/11/99
  Call CONTEXE([F:BAN]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif
 If [M:IVPY]CUR<>""
  Call CONTBAN([M:IVPY]DATPAY,VALEUR,[M:IVPY]CUR) From CPTSUB
 Endif

 # 87923 : Gestion des prélèvements SDD
 # Si saisie d'un règlement de type SDD, le pays doit gérer la norme SEPA
 If dim(GSDDMGT)>0 & GSDDMGT=2 & dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2
    If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY]  : Endif
    Call LEC_TCY([F:BAN]CRY) From CPTLEC
    If !fstat & [F:TCY]FLGSEPA<>2 : GMESSAGE=mess(267,117,1) : mkstat = 2 : End : Endif
 Endif
 # 87923
Endif

End

######################################################################################
