#<AdxTL>@(#)9.0.0.0 $Revision$
#########################################################################################################
#   Fenêtre générique de sélection d'un site tiers                  Module CRM             2 avril 2003 #
#########################################################################################################
#########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

#########################################################################################################
$OUVRE
Global Integer GISRE6HBDISP
Global Integer GPRESRE6NOL
Global Char GSZSRE6BPC(GLONBPC)

  GISRE6HBDISP = 0
  GPRESRE6NOL = 0
  If PARAM(1) = "" Then
    #Aucun client n'est indiqué. Sélection impossible.
    GMESSAGE = mess(75,182,1)
    GERR = 2
    FIN = 1
  Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:BPA2]) : Local File BPADDRESS [BPA2] : Endif
Return

#########################################################################################################
$DEFBOUT
Return

#########################################################################################################
$SETBOUT
Return

#########################################################################################################
$OUVRE_BOITE
Return

#########################################################################################################
$DEBUT
  GSZSRE6BPC = PARAM(1)
  Call LOADSRE6
  GISRE6HBDISP = 1
Return

#########################################################################################################
$AV_CHOIX
Return

#########################################################################################################
AP_CHOIX
Return

#########################################################################################################
$AVANT_BOUTON
Return

#########################################################################################################
$FINSAI
  If GISRE6HBDISP Then
    #Nettoie l'écran avant de partir.
    Raz [M:SRE6]
  Endif
  Kill GISRE6HBDISP
  Kill GSZSRE6BPC
  Kill GPRESRE6NOL
Return

#########################################################################################################
$FIN
Return

#########################################################################################################
$ABANDON
Return

#########################################################################################################
$APRES_MODIF
Return

#########################################################################################################
$BOUTON
Return

#########################################################################################################
$ONMENU
Return

#########################################################################################################
$ONOK
  VALEUR = [M:SRE6]CURBPAADD
  mkstat = 4
Return

############################################################################
#
# Sous-programmes
#
#
############################################################################
Subprog LOADSRE6
Local Integer ITER

  ITER = 0
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = GSZSRE6BPC Order By [F:BPA]BPAADD
  For [BPA]
    If ITER >= dim([M:SRE6]CODADR) Then
      Break
    Endif
    If ITER = 0 Then
      [M:SRE6]NBADRSEL(ITER) = "->"
    Else
      [M:SRE6]NBADRSEL(ITER) = ""
    Endif
    [M:SRE6]CODADR(ITER) = [F:BPA]BPAADD
    [M:SRE6]BPADES(ITER) = [F:BPA]BPADES
    [M:SRE6]POSCOD(ITER) = [F:BPA]POSCOD
    [M:SRE6]CTY(ITER) = [F:BPA]CTY
    [M:SRE6]SAT(ITER) = [F:BPA]SAT
    [M:SRE6]BPACRY(ITER) = [F:BPA]CRY
    If ITER = 0 Then
      [M:SRE6]CURBPAADD = [M:SRE6]CODADR(ITER)
      Call SETCURADD(1, [F:BPA]BPANUM, [F:BPA]BPAADD)
    Endif
    ITER += 1
  Next
  Filter [BPA]
  [M:SRE6]NBADR = ITER
  Affzo [M:SRE6]
End

##########################################################################
#
##########################################################################
Subprog SETCURADD(ITYP, SZBPANUM, SZBPAADD)
Value Integer ITYP
Value Char SZBPANUM
Value Char SZBPAADD

  Read [BPA2]BPA0=ITYP;SZBPANUM;SZBPAADD
  If !fstat Then
    [M:SRE6]XBPADES = [F:BPA2]BPADES
    [M:SRE6]XLIG(0) = [F:BPA2]BPAADDLIG(0)
    [M:SRE6]XLIG(1) = [F:BPA2]BPAADDLIG(1)
    [M:SRE6]XLIG(2) = [F:BPA2]BPAADDLIG(2)
    [M:SRE6]XBPACRY = [F:BPA2]CRY
    [M:SRE6]XSAT = [F:BPA2]SAT
    [M:SRE6]XPOSCOD = [F:BPA2]POSCOD
    [M:SRE6]XCTY = [F:BPA2]CTY
    [M:SRE6]XTEL = [F:BPA2]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA2]TEL
    [M:SRE6]XFAX = [F:BPA2]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA2]FAX
    [M:SRE6]XWEB = [F:BPA2]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA2]WEB
  Endif
End

