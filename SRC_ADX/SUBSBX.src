#<AdxTL>@(#)5.0.0.0 $Revision$
#
#--- Programme de mise a jour de la table STATIONBOX  / Centrale de pesée

Call OBJET ("SBX" , GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "STATUT"      : Gosub STATUT
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "ABANDON"     : Gosub ABANDON
 When "ANNULE"      : Gosub ANNULE
 When "INICRE"      : Gosub INICRE
 When "SETBOUT"     : Gosub SETBOUT
 When "RAZDUP"      : Gosub RAZDUP
 When "RAZCRE"      : Gosub RAZCRE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "CHANGE"      : Call CHANGE_AXX ("STATIONBOX",[L]SUPP(0),[L]OCODE,[L]SUPP(0),[L]NCODE) From TRTX3TEX
 When Default
Endcase
Return



#********************************************************************** OUVRE
$OUVRE
Return

#********************************************************************** SETBOUT
$SETBOUT
#--- activation desactivation des boutons
If GREP="C" | GREP="D" | CLECUR
   CHMEN += "Af"   # v 140
Endif


Return

#********************************************************************** RAZCRE
$RAZCRE

Call RAZ_CLOB From ACLOB

#--- suppression icone texte an bas a droite de l ecran
 Call RESET_IMAGE (4) From GESECRAN   :

#CATUA X3-67237.sn
#Disable fields when creating a new record
[M:SBX1]BOXOPGFLG = 1
[M:SBX1]WOREPYFLG = 1
[M:SBX1]PHAEPYFLG = 1
[M:SBX1]MATEPYFLG = 1
[M:SBX1]STAAUZ = 1
[M:SBX1]MATAUZ = 1

Grizo [M:SBX1]BOXOPGFLG
Grizo [M:SBX1]WOREPYFLG
Grizo [M:SBX1]PHAEPYFLG
Grizo [M:SBX1]MATEPYFLG
#CATUA X3-67237.en

Return


#********************************************************************** RAZDUP

$RAZDUP
Local Integer WRET,I
Call RAZ_CLOB From ACLOB
Call DUP_CLOB("SBX",[M:SBX1]STIBOXTEX,WRET) From TRTX3TEX
If WRET<1 Raz [M:SBX1]STIBOXTEX : Endif

Return


#********************************************************************** INICRE
$INICRE

If [M:SBX1]STIBOXTEX<>""
      Call CRE_CLOB([M:SBX1]STIBOXTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:SBX]STIBOXTEX = [M:SBX1]STIBOXTEX
Endif
Return

#********************************************************************** AVANTBOUT
#    Avant l'execution des boutons et des menus
$AVANTBOUT
Return

#********************************************************************** STATUT

$STATUT
If mkstat=4 & GREP=""
   #MAE, bg 50938
   #GREP="M" : REP="M"
   #Gosub SETBOUT From GOBJSUB
   Gosub ENTRE_MODIF From GOBJSUB
Endif
#---  activation icone texte en bas a droite de l ecran
If [M:SBX1]STIBOXTEX <> "" & !GIMPORT & !GBROWS
   Call SET_IMAGE (4) From GESECRAN
Elsif !GIMPORT & !GBROWS
   Call RESET_IMAGE (4) From GESECRAN
Endif
Return

#********************************************************************** ABANDON

$ABANDON
Local Integer WRET

If GREP = "D"
      Call SUP_CLOB([M:SBX1]STIBOXTEX,WRET) From TRTX3TEX
Endif
Call RAZ_CLOB From ACLOB
Return


#********************************************************************** ANNULE

$ANNULE
Local Integer WRET
#---  en cas d annulation de la fiche il faut aussi supprimer le texte si existant
Call SUP_CLOB([M:SBX1]STIBOXTEX,WRET) From TRTX3TEX
Call RAZ_CLOB From ACLOB
#--- maj de la table des libéllés traduisibles
Delete [AXX] Where CODFIC="STATIONBOX" & IDENT1=[L]SUPP(0) & IDENT2=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]SUPP(0)-[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]SUPP(0)-[L]CODE) From GLOCK : Return
Endif

Return


#********************************************************************** LIENS

$LIENS
#---  activation de l icone texte coin droit en bas

If [M:SBX1]STIBOXTEX <> "" & !GIMPORT & !GBROWS
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT & !GBROWS
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif

#---  si numero de fiche(s) renseigne activation des zones à cochees
#     sinon desactivation


If [M:SBX1]BOXOPGPCR <> ""
    Actzo [M:SBX1]BOXOPGFLG
Else
    [M:SBX1]BOXOPGFLG = 1
    Grizo [M:SBX1]BOXOPGFLG
Endif

Affzo [M:SBX1]BOXOPGPCR
Affzo [M:SBX1]BOXOPGFLG

If [M:SBX1]WOREPYPCR <> ""
    Actzo [M:SBX1]WOREPYFLG
Else
    [M:SBX1]WOREPYFLG = 1
    Grizo [M:SBX1]WOREPYFLG
Endif

Affzo [M:SBX1]WOREPYPCR
Affzo [M:SBX1]WOREPYFLG

If [M:SBX1]PHAEPYPCR <> ""
    Actzo [M:SBX1]PHAEPYFLG
Else
    [M:SBX1]PHAEPYFLG = 1
    Grizo [M:SBX1]PHAEPYFLG
Endif

Affzo [M:SBX1]PHAEPYPCR
Affzo [M:SBX1]PHAEPYFLG

#CATUA X3-67237.sn
#Include Materia Empty Station fields
If [M:SBX1]MATEPYPCR <> ""
    Actzo [M:SBX1]MATEPYFLG
Else
    [M:SBX1]MATEPYFLG = 1
    Grizo [M:SBX1]MATEPYFLG
Endif

Affzo [M:SBX1]MATEPYPCR
Affzo [M:SBX1]MATEPYFLG
#CATUA X3-67237.en
Return

####################################################################
$AVANT_MODFIC
#------------------------------------------#
# Traitement avant modification            #
#------------------------------------------#
Local Integer WRET

# on a viré le texte
If [M:SBX1]STIBOXTEX="" & [F:SBX]STIBOXTEX <> ""
   Call SUP_CLOB([F:SBX]STIBOXTEX,WRET) From TRTX3TEX
Endif
Return
#############################################################
$CREATION
Call MAJTEXTRA([M:SBX1]DESAXX,"STATIONBOX","DESAXX",[M:SBX1]BOX,[M:SBX1]FCY) From ATEXTRA
Call MAJTEXTRA([M:SBX1]SHOAXX,"STATIONBOX","SHOAXX",[M:SBX1]BOX,[M:SBX1]FCY) From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M:SBX1]DESAXX,"STATIONBOX","DESAXX",[M:SBX1]BOX,[M:SBX1]FCY) From ATEXTRA
Call MAJTEXTRA([M:SBX1]SHOAXX,"STATIONBOX","SHOAXX",[M:SBX1]BOX,[M:SBX1]FCY) From ATEXTRA

Return
#############################################################
#********************************************************************** ACTIONS ecran
#---  si numero de fiche(s) renseigne activation des zones à cochees
#     sinon desactivation

#######################################
Subprog AM_BOXOPGPCR(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
    Actzo [M:SBX1]BOXOPGFLG
Else
    [M:SBX1]BOXOPGFLG = 1
    Grizo [M:SBX1]BOXOPGFLG
Endif

[M:SBX1]BOXOPGPCR= VALEUR
Affzo [M:SBX1]BOXOPGPCR
Affzo [M:SBX1]BOXOPGFLG
End

