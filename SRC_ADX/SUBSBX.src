#######################################
Subprog C_PRTALL(VALEUR)
Variable Char    VALEUR()
Local Char    PARAM(250)(1..10) , SERVEUR(30)
Local Integer NBPAR, I , K
If VALEUR<>[M:SBX1]PRTALL & VALEUR<>""
    NBPAR = 0
    If VALEUR<>""
         NBPAR += 1
         PARAM(NBPAR) = "_PrinterName="+chr$(1)+VALEUR
         NBPAR += 1
         PARAM(NBPAR) = "_NoVisible="+chr$(1)+"1"
    Endif
    SERVEUR = [M:SBX1]PRTSRV
    If SERVEUR<>""
         NBPAR += 1
         PARAM(NBPAR) = "_PrinterServer="+chr$(1)+SERVEUR
         Selimp PARAM = SERVEUR+"@" With PARAM(1..NBPAR)
    Else
         Selimp PARAM = "" With PARAM(1..NBPAR)
    Endif
    J = 0
    For I=1 To dim(PARAM)
         If PARAM(I)="" : Break : Endif
         K = instr(1,PARAM(I),"=")
         If K
              PARAMETRE = left$(PARAM(I),K-1)
              VALPAR    = right$(PARAM(I),K+2)
              Case PARAMETRE
                   When "_PrinterName"        : VALEUR               = VALPAR
                   When "_PrinterDriver"      : [M:SBX1]PRTDRVALL    = VALPAR
                   When "_PrinterPort"        : [M:SBX1]PRTPORALL    = VALPAR
                   When "_PrinterDescription" : [M:SBX1]PRTDESALL(J) = VALPAR : J += 1
              Endcase
         Endif
    Next I
Endif
End

########################################
Subprog AM_PRTSRV(VALEUR)
Variable Char    VALEUR()
Raz [M:SBX1]PRTALL, PRTETI, PRTPHA,PRTOF
Affzo [M:SBX1]PRTALL
Affzo [M:SBX1]PRTETI        # 05.05 30186
Affzo [M:SBX1]PRTPHA
Affzo [M:SBX1]PRTOF

End

