Subprog AM_MATEPYPCR(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
    Actzo [M:SBX1]MATEPYFLG
Else
    [M:SBX1]MATEPYFLG = 1
    Grizo [M:SBX1]MATEPYFLG
Endif

[M:SBX1]MATEPYPCR= VALEUR
Affzo [M:SBX1]MATEPYPCR
Affzo [M:SBX1]MATEPYFLG
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SBX1) 20/06/2011 14:44:36 (MM)
######################################################################################
Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
Local Integer    I


If [M:SBX1]FCY <>[F:FCY]FCY
  Read [FCY]FCY0=[M:SBX1]FCY
  If fstat : Raz [F:FCY] : End : Endif
Endif

If GWRHACT = 2 & [F:FCY]WRHGES = 2
  VALEUR = toupper(VALEUR)
  ## > contrôler que la chaine ne contient que des lettres ou des caractères
  ##  interprétable par l'instruction pat : * # ? !  (type de donnée ?)
  For I=1 To len(VALEUR)
    If !instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789*#!?",seg$(VALEUR,I,I))
      mkstat = 2 : GMESSAGE = mess(149,100,1) # format incorrect
      Break
    Endif
  Next
  If mkstat | VALEUR="" End Endif
  If !clalev([STC]) Local File STOLOC [STC] Endif
  I=0
  If instr(1,VALEUR,"*")<> 0
   # l'emplacement saisi comporte le caractère "*"
    I = 1
  Endif
  Filter [STC] Where STOFCY = [M:SBX1]FCY
    For [STC]
      Case I
        When 0 :  If (VALEUR = [F:STC]LOC)
                   # l'emplacement a été trouvé
                   [M:SBX1]WRH = [F:STC]WRH
                   [M:SBX1]LOC = VALEUR
                   Affzo [M:SBX1]WRH,LOC
                   Break
                 Endif
        When 1 :  If pat([F:STC]LOC,VALEUR)=1
                 # la sous-chaîne a été trouvée
                   [M:SBX1]WRH = [F:STC]WRH
                   [M:SBX1]LOC = VALEUR
                   Affzo [M:SBX1]WRH,LOC
                   Break
                 Endif
      Endcase
    Next
  Filter [STC]
  Case I
    When 0 : If (VALEUR <> [F:STC]LOC)
               mkstat = 2 : GMESSAGE = mess(23,100,1) # "Fiche inexistante"
             Endif
    When 1 : If  !pat([F:STC]LOC,VALEUR)
               mkstat = 2 : GMESSAGE = mess(23,100,1) # "Fiche inexistante"
             Endif
  Endcase
Endif
End

