######################################################################################
## Etiquette ajoutée par le superviseur (écran SBX1) 07/12/2010 14:29:25 (MM)
######################################################################################
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHACT = 2 & [F:FCY]WRHGES = 2
  If [M:SBX1]LOC <>"" : Raz [M:SBX1]LOC : Affzo [M:SBX1]LOC : Endif
Endif
End

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SBX1) 11/01/2011 17:24:05 (MM)
######################################################################################
Subprog AV_WRH(VALEUR)
Variable Char    VALEUR()
# si le site n'est pas géré en dépôt, il faut griser cette zone
Read [FCY]FCY0=[M:SBX1]FCY
If fstat : Raz [F:FCY] : End : Endif

If  [F:FCY]WRHGES = 1
   Grizo [M:SBX1]WRH
Else
   Actzo [M:SBX1]WRH
Endif

End

#CATUA X3-67237.sn
#Default the User/Pwd field to the parameter when creating new records
######################################################################################
## Section automatically added (screen SBX1) 08/23/2018 23:55:11 (CATUA)
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

If GREP = "C"
   If func AFNC.PARAM("USRWEI",VALEUR) = "2"
      [M:SBX1]MATAUZ = 2
   Else
      [M:SBX1]MATAUZ = 1
   Endif

   Affzo [M:SBX1]MATAUZ
Endif

End
#CATUA X3-67237.en


