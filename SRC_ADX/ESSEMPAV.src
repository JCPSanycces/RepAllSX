#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "SETBOUT"     : Gosub SETBOUT
Endcase

Return

$SETBOUT
If REPONSE = 1102 or REPONSE = 1101
  #Disable sign buttons
  Call VIREBOUT(CHMEN,"a") From GOBJET
  Call VIREBOUT(CHMEN,"b") From GOBJET
Endif
Return


$OUVRE
Gosub OUVRE_OUT
#Manage Localisations
Call MANAGE_LOCALISATION("ESSEMPAV") From DIVPAYE

Return

$OUVRE_OUT
#Opening tables and declaring an instance of the main class
If clalev([F:ID1])        = 0 : Local File ESSWRKEMP        [ID1]       : Endif
If clalev([F:EWID1])      = 0 : Local File ESSWRKEMP        [EWID1]     : Endif
If clalev([F:EWUKI1])     = 0 : Local File ESSWRKUKI        [EWUKI1]    : Endif
If clalev([F:EWSA1])      = 0 : Local File ESSWRKSA         [EWSA1]     : Endif
If clalev([F:ESWD2])      = 0 : Local File ESSWRKFLWDET     [ESWD2]     : Endif
If clalev([F:ID3])        = 0 : Local File EMPLOID          [ID3]       : Endif
Return




$DEBUT
Gosub DEBUT_OUT
#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSEMPAVHIDE
Call SHOW_LEGACTCALLS From WESSEMPAVSHOW


Affzo [M:ESEMP]1-99

Return

$DEBUT_OUT
Local Char GLOBEML(GLONEML)
Local Integer MNOLIB
Raz [M:ESEMP]

#Set and change the style of the changed fields
Gosub SET_STYLE

GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1)

MNOLIB = func ESSEMP.SET_CIV([M:ESEMP]REFNUM)
If MNOLIB>0 and [M:ESEMP]CIV > 0
  [M:ESEMP]NOLIB  = MNOLIB
  [M:ESEMP]VALINT = num$([M:ESEMP]CIV)
  [M:ESEMP]CIVA   = mess([M:ESEMP]CIV,[M:ESEMP]NOLIB,1)
Endif

[M:ESEMP]WLEG = GCURLEG

[M:ESEMP]DEST = PARAM(4)
[M:ESEMP]CHRONO = PARAM(5)

Gosub HIDE_SHOW_ADDHOC From ESSEMP

Affzo [M:ESEMP]1-99



Return

$SET_STYLE
#EMPLOIDSA - KZA - RSA Employee information
If PARAM(3) = "EMPLOIDSA"
  Gosub UPDATE_ESSEMPKZA
Endif


#EMPLOIDUKI - UKI - RSA Employee information
If PARAM(3) = "EMPLOIDUKI"
  Gosub UPDATE_ESSEMPUKI
Endif

#ALL EMPLOID
Gosub UPDATE_ESSEMP

Return

$UPDATE_ESSEMP
Gosub DECLARE_EMPSTYLE From ESS_FUNCTIONS

WFILENAME = "WESSEMPDETSTYLE_"+GUSER

If GLOBEML <>""
  Read [ID3]ID0 = GLOBEML
  If !fstat
    [M:ESEMP]=[F:ID3]
  Endif
Endif

#Load the data from the class to the screen
If PARAM(3) = "EMPLOID"
  Read [F:EWID1]EWID0 = val(PARAM(2))
  If !fstat
   [M:ESEMP]=[F:EWID1]
   GLOBEML = [F:EWID1]REFNUM
   #Create style script
   Gosub CREATE_STYLE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS
    #Indicate changed fields
    If [F:EWID1]WRK = "M"
      WSTYLECODE = "ECCBODC"
      [M:ESEMP]WRKREQ = 2
      Chgstl [M:ESEMP]WRKREQ With "ECCBODC"
      Filter [F:ESWD2] Where UID = [F:EWID1]UID and WRK = "M" and MAIREC <> 2
      For [F:ESWD2]
        If evalue("dim([M:ESEMP]"+[F:ESWD2]FLDNAM+")")>0
          If [F:ESWD2]FLDNAM = "CIV"
            WFIELDNAME = "[M:ESEMP]CIVA"
          Else
            WFIELDNAME = "[M:ESEMP]"+[F:ESWD2]FLDNAM
          Endif
          STYLESTAT+=1
          Gosub CREATE_STYLE_SCRIPT_EMPDETAIL_DETAIL From ESS_FUNCTIONS
        Endif
      Next
      Filter [F:ESWD2]
    Elsif [F:EWID1]WRK = "D"
      WSTYLECODE = "ECCBODA"
      [M:ESEMP]WRKREQ = 3
      Chgstl [M:ESEMP]10 With "ECCBODA"
    Elsif [F:EWID1]WRK = "C"
      WSTYLECODE = "ECCBODC"
      [M:ESEMP]WRKREQ = 1
      Chgstl [M:ESEMP]10 With "ECCBODC"
    Endif
    #Close script
    Gosub CLOSE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS

    If STYLESTAT
      #Run script
      Call STYLE_FIELDS() From =WFILENAME
    Endif
  Endif
Endif



Return



$UPDATE_ESSEMPKZA

Gosub DECLARE_EMPSTYLE From ESS_FUNCTIONS
WFILENAME = "WESSEMPDETSTYLE_"+GUSER

#Load the data from the class to the screen
Read [F:EWSA1]EWSA0 = val(PARAM(2))
If !fstat
  [M:ESEMP]=[F:EWSA1]
  GLOBEML = [F:EWSA1]REFNUM

 #Create style script
 Gosub CREATE_STYLE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS
  #Indicate changed fields
  If [F:EWSA1]WRK = "M"
    WSTYLECODE = "ECCBODC"
    [M:ESEMP]WRKREQ = 2
    Chgstl [M:ESEMP]WRKREQ With "ECCBODC"
    Filter [F:ESWD2] Where UID = [F:EWSA1]UID and WRK = "M" and MAIREC <> 2
    For [F:ESWD2]
      If evalue("dim([M:ESEMP]"+[F:ESWD2]FLDNAM+")")>0
        WFIELDNAME = "[M:ESEMP]"+[F:ESWD2]FLDNAM
        STYLESTAT+=1
        Gosub CREATE_STYLE_SCRIPT_EMPDETAIL_DETAIL From ESS_FUNCTIONS
      Endif
    Next
    Filter [F:ESWD2]
  Elsif [F:EWSA1]WRK = "D"
    WSTYLECODE = "ECCBODA"
    [M:ESEMP]WRKREQ = 3
    Chgstl [M:ESEMP]10 With "ECCBODA"
  Elsif [F:EWSA1]WRK = "C"
    WSTYLECODE = "ECCBODC"
    [M:ESEMP]WRKREQ = 1
    Chgstl [M:ESEMP]10 With "ECCBODC"
  Endif
  #Close script
  Gosub CLOSE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS

  If STYLESTAT
    #Run script
    Call STYLE_FIELDS() From =WFILENAME
  Endif
Endif

Return

$UPDATE_ESSEMPUKI
#Load the data from the class to the screen
Read [F:EWUKI1]EWUKI0 = val(PARAM(2))
If !fstat
  [M:ESEMP]=[F:EWUKI1]
  GLOBEML = [F:EWUKI1]REFNUM

 #Create style script
 Gosub CREATE_STYLE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS
  #Indicate changed fields
  If [F:EWUKI1]WRK = "M"
    WSTYLECODE = "ECCBODC"
    [M:ESEMP]WRKREQ = 2
    Chgstl [M:ESEMP]WRKREQ With "ECCBODC"
    Filter [F:ESWD2] Where UID = [F:EWUKI1]UID and WRK = "M" and MAIREC <> 2
    For [F:ESWD2]
      If evalue("dim([M:ESEMP]"+[F:ESWD2]FLDNAM+")")>0
        WFIELDNAME = "[M:ESEMP]"+[F:ESWD2]FLDNAM
        STYLESTAT+=1
        Gosub CREATE_STYLE_SCRIPT_EMPDETAIL_DETAIL From ESS_FUNCTIONS
      Endif
    Next
    Filter [F:ESWD2]
  Elsif [F:EWUKI1]WRK = "D"
    WSTYLECODE = "ECCBODA"
    [M:ESEMP]WRKREQ = 3
    Chgstl [M:ESEMP]10 With "ECCBODA"
  Elsif [F:EWUKI1]WRK = "C"
    WSTYLECODE = "ECCBODC"
    [M:ESEMP]WRKREQ = 1
    Chgstl [M:ESEMP]10 With "ECCBODC"
  Endif
  #Close script
  Gosub CLOSE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS

  If STYLESTAT
    #Run script
    Call STYLE_FIELDS() From =WFILENAME
  Endif
Endif
Return

