####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMR0CCMCHGREQF4
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
this._AFCRIGHT = "GESCCM"
Gosub INIT_BOMCODE From WMR1CCMCHGREQF4 : Gosub TESTALLSTAT
Gosub INIT_BOMTYPE From WMR1CCMCHGREQF4 : Gosub TESTALLSTAT
Gosub INIT_ROUCODE From WMR1CCMCHGREQF4 : Gosub TESTALLSTAT
Gosub INIT_ROUSITE From WMR1CCMCHGREQF4 : Gosub TESTALLSTAT
If this.CCMCR<>null
 [L]ASTATUS = fmet this.CCMCR.AINIT : Gosub TESTALLSTAT
Endif
Gosub AINIT From WMR0CCMCHGREQF4 : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMR0CCMCHGREQF4
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMR0CCMCHGREQF4
Gosub LNKPRO_ROUSITE From WMR1CCMCHGREQF4 : Gosub TESTALLSTAT
If this.CCMCR<>null
 [L]ASTATUS = fmet this.CCMCR._ALNKPRO : Gosub TESTALLSTAT
Endif
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



