#<AdxTL>@(#)0.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#

Local Char PARAM(30)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"TPSVAR","TPSVAR","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "ABA"         : Gosub ABANDON
 When "ENR"         : Gosub ENREGISTRE
Endcase
Return

$OUVRE
If clalev([F:VRA])=0 : Local File VARIA   [VRA] : Endif
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If clalev([F:TIM])=0 : Local File TIMCOD  [TIM] : Endif
#*!
If clalev([F:TIM])=0 : Local File TIMCOD  [TIM] : Endif
#LIPET - 2017-05-20 - END
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
Local Integer FLMOD
Return

$DEBUT
Gosub CHARGE
Return

$CHARGE
Raz [M]
nolign = 0
For [VRA]VRA0 Where TYPINI=4
 nolign += 1
 [M] = [F:VRA]
 [M]VARCOD(nolign-1) = [F:VRA]COD
Next
[M]NBLIG = nolign
Affzo
Return

$APRES_MODIF
FLMOD = 1
Return

$SETBOUT
If FLMOD
 ETABOU(GENRE) = 1
 ETABOU(GABAN) = 1
Else
 ETABOU(GENRE) = 0
 ETABOU(GABAN) = 0
Endif
Return

$ABANDON
Gosub CHARGE
FLMOD = 0
Return

$ENREGISTRE
Call DEBTRANS From GLOCK
Gosub TR1
FLMOD = 0
Return

$TR1
GOK = 1
Trbegin [VRA]
 For nolign=1 To [M]NBLIG
  Readlock [VRA]VRA0 = GCURLEG;[M]VARCOD(nolign-1)
  If fstat=1
   GOK = -1 : GLOCK = "$VARIA"-[M]VARCOD(nolign-1) : Break
  Elsif fstat
   GOK = 0 : Call RSTA("VRA",[M]VARCOD(nolign-1)) From GLOCK : Break
  Endif
  [F:VRA] = [M]
  [F:VRA]TYPINI = 4
  Rewrite [VRA]
  If fstat
   GOK = 0 : Call FSTA("VRA") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 For [VRA]VRA0 Where TYPINI=4
  If !find([F:VRA]COD,[M]VARCOD(0..[M]NBLIG-1))
   Readlock [VRA]VRA0 Curr
   If fstat=1
    GOK = -1 : GLOCK = "$VARIA"-[F:VRA]COD : Break
   Elsif fstat
    GOK = 0 : Call RSTA("VRA",[F:VRA]COD) From GLOCK : Break
   Endif
   [F:VRA]TYPINI = 2
   Rewrite [VRA]
   If fstat
    GOK = 0 : Call FSTA("VRA") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

########################################
## Ecran TPSVAR
########################################
Subprog AS_TYPVAL(VALEUR)
Variable Integer VALEUR
If [M]TYPMAJ(nolign-1)=2 : mkstat = 1 : End : Endif
End

Subprog AS_TIMCOD(VALEUR)
Variable Char    VALEUR()
If [M]TYPMAJ(nolign-1)=2 : mkstat = 1 : End : Endif
End

Subprog AS_TIMVAR(VALEUR)
Variable Char    VALEUR()
If [M]TYPMAJ(nolign-1)=1 : mkstat = 1 : End : Endif
End

Subprog C_TIMVAR(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-05-20 - END
#** V7 : Waiting Time Mangement **#
#**If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
#**Read [ATZ]CODZONE = "TIMRECAP";VALEUR
#**If fstat or [F:ATZ]CODTYP<>"CDY"
#** GMESSAGE = mess(24,10709,1) : # Variable non définie dans TIMRECAP
#** mkstat = 2 : End
#**Endif
#*!
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
Read [ATZ]CODZONE = "TIMRECAP";VALEUR
If fstat or [F:ATZ]CODTYP<>"CDY"
 GMESSAGE = mess(24,10709,1) : # Variable non définie dans TIMRECAP
 mkstat = 2 : End
Endif
#LIPET - 2017-05-20 - END
End

Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VARCOD(0..[M]NBLIG)) From OBJDIV
End

