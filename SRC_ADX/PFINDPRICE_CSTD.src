#<AdxTL>@(#)3.0.0.0 $Revision$
# Classe PFINDPRICE_C_PLI  from FINDPRICE_CSTD 12/4/2013


$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
        When "AINIT"     :
                               Gosub AINIT
                               Return
        When "FINDPRICE" :
                               Gosub FINDPRICE
                               Return
         When "FINDPRICE_OP" :
                               #--This calls direclty the library func TRTVENTAR_SYRA.SEARCHPRICE
                               Gosub FINDPRICE_OP
                               Return
        When "LOADPARAM" :
                               Gosub LOADPARAM
                               Return
        When "INITPARAM" :
                               Gosub INITPARAM
                               Return
        When Default
      Endcase
Endcase
Return


$PROPERTIES
Case [L]CURPRO
Endcase
Return

$AINIT
Local Integer WRET

#--Normally, it's done by the supervisor (1 to 1 collection)
If this.C_PPKH(1) = null
    WRET = fmet this.ADDLINE("C_PPKH",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PPKH","PFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
Endif

#--Mandatory to have at list 1 item it this collection
  If this.C_LINE(1) = null
    WRET = fmet this.ADDLINE("C_LINE",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_LINE","PFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

#--Normally, it's done by the supervisor (1 to 1 collection)
  If this.C_LINE(1).C_PPKD(1) = null
    WRET = fmet this.C_LINE(1).ADDLINE("C_PPKD",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PPKD","PFINDPRICE.C_LINE(1)"), [V]CST_AERROR)
      Return
    Endif
  Endif

#--The PLI collection is filled by the calling object instance
  #--(it contains the price lists compatible with the current company as for the price structure)
  If this.PLI(1) = null
    WRET = fmet this.ADDLINE("PLI",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"PLI","PFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

  #--The FMTCOLREM collection is filled by the calling object instante trought the LOADPARAMFROMDOC method
  If this.FMTCOLREM(1) = null
    WRET = fmet this.ADDLINE("FMTCOLREM",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"FMTCOLREM","PFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

Return
#---------------------------------------------------------------------------------------------
$FINDPRICE
#Value Instance GENERIC_OBJ Using OBJECT
    If dim(INDEXLINE)<1
      Local Integer INDEXLINE
    Endif
    If INDEXLINE = 0 :INDEXLINE = 1 : Endif

    Local Integer WRET
    Local Char WMESSAGE(250)
    #--First, we need to initialize/load the properties
    #--Call to a private methode in order to instantiate all needed collection within this (if not done yet)
    WRET = fmet this.INITPARAM()
    #If WRET > [V]CST_AINFO
    #  [L]ASTATUS = this.ASETERROR ("", "Data Class PFINDPRICE: Error method call _INITPARAM", WRET)
    #  Return
    #Endif  98349.o
    If WRET >= [V]CST_AERROR # 98349.sn
      WMESSA = mess(68,123,1)-":"-mess(1,7845,1)-"INITPARAM"
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif                    # 98349.en

    #--It's done by calling the "private" method LOADPARAMFROMDOC, by passing on the MyDOC pointer
    WRET = fmet this.LOADPARAM(GENERIC_OBJ,INDEXLINE)
    #If WRET > [V]CST_AINFO
    #  [L]ASTATUS = this.ASETERROR ("", "Data Class PFINDPRICE: Method call PFINDPRICE error for LOADPARAM", WRET)
    #  Return
    #Endif   98349.o
    If WRET >= [V]CST_AERROR  # 98349.sn
      WMESSA = mess(68,123,1)-":"-mess(1,7845,1)-"LOADPARAM"
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
      [L]ARET_VALUE = [L]ASTATUS
      Return
  Endif                       # 98349.en

    #--New instance of the Result class
    #--It will be loaded by the SEARCHPRICE method called just bellow
    Local Instance MYRESULT Using C_RESULTPRICE
    MYRESULT = NewInstance C_RESULTPRICE  AllocGroup null

    MYRESULT.setAccessorEnabled = 0

    #--The black box for Price searching (in fact it's the future "syracusation" of the TARIFRECH subroutine from TRTVENPRI
    #--We pass in the pointer to the result class
    WRET = func TRTACHTAR_SYRA.SEARCHPRICE(this,INDEXLINE, MYRESULT,WMESSAGE)
#    If WRET > [V]CST_AINFO
#      [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, WRET) ### 2/11/2014
#      Goto END_FINDPRICE
#    Endif  98349.o
    If WRET >= [V]CST_AERROR   # 98349.sn
      WMESSA = "" # 98394.n
      #WMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"SEARCHPRICE" # 98394.o
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
      Goto END_FINDPRICE
    Endif                      # 98349.en

    #--Loading the Document from the Result class (Help yourself...)
    WRET = fmet MYRESULT.LOADFROMRESULT(GENERIC_OBJ,INDEXLINE,this)
#    If WRET > [V]CST_AINFO
#      [L]ASTATUS = fmet this.ASETERROR ("", "Data Class PFINDPRICE: Method call PFINDPRICE error returned by MYRESULT.LOADFROMRESULT", WRET)
#      Goto END_FINDPRICE
#    Endif   98349.o
    If WRET >= [V]CST_AERROR  # 98349.sn
      WMESSA = "" # 98394.n
      #WMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"LOADFROMRESULT" # 98394.o
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
      Goto END_FINDPRICE
    Endif                     # 98349.en

$END_FINDPRICE
#--Free the instance MYRESULT...
 FreeGroup MYRESULT
 [L]ARET_VALUE = [L]ASTATUS  # 98349.n

Return
#########################################################################################
#--This calls direclty the library func TRTVENTAR_SYRA.SEARCHPRICE
#--Input parameters : MYPARAM  => already loaded instance of SFINDPRICE class
#--Output           : MYRESULT => result of the price search fonction loaded into an instance of RESULTPRICE class
$FINDPRICE_OP
#Variable Instance MYPARAM  Using SFINDPRICE
#Variable Instance MYRESULT Using RESULTPRICE

    If MYPARAM = null
      [L]ASTATUS = fmet MYPARAM.ASETERROR ("", "Data Class PFINDPRICE: Method call FINDPRICE_OP the entry instance of PFINDPRICE is null", [V]CST_AWARNING)
      Return
    Endif

    Local Integer WRET

    If dim(INDEXLINE)<1
      Local Integer INDEXLINE
    Endif
    If INDEXLINE = 0 :INDEXLINE = 1 : Endif


    #---- initialisation
    If MYRESULT=null
      MYRESULT = NewInstance C_RESULTPRICE AllocGroup MYPARAM
    Endif

    #--The black box for Price searching (in fact it's the future "syracusation" of the TARIFRECH subroutine from TRTVENPRI
    #--We pass in the pointer to the result class
    WRET = func TRTACHTAR_SYRA.SEARCHPRICE(MYPARAM,INDEXLINE, MYRESULT)
#    If WRET >= [V]CST_AERROR
#      [L]ASTATUS = fmet MYPARAM.ASETERROR ("", "Data Class PFINDPRICE: Method call FINDPRICE_OP error for SEARCHPRICE", WRET)
#      Return
#    Endif   98349.o
    If WRET >= [V]CST_AERROR  # 98349.sn
      WMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"SEARCHPRICE"
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif                     # 98349.en

Return
#--------------------------------------------------------------------------------------------------

$INITPARAM
#--No Input parameters
    Local Integer WRET

  If this.C_PPKH(1) = null
    WRET = fmet this.ADDLINE("C_PPKH",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PPKH","PFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

  If this.C_LINE(1) = null
    WRET = fmet this.ADDLINE("C_LINE",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_LINE","PFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

  If this.C_LINE(1).C_PPKD(1) = null
    WRET = fmet this.C_LINE(1).ADDLINE("C_PPKD",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PPKD","PFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

  If this.PLI(1)=null
    WRET = fmet this.ADDLINE("PLI",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"PLI","PFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

  If this.FMTCOLREM(1)=null
    WRET = fmet this.ADDLINE("FMTCOLREM",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"FMTCOLREM","PFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

#--The PLI collection is filled by the calling object instance
  #--(it contains the price lists compatible with the current company as for the price structure)

  #--The FMTCOLREM collection is filled by the calling object instante trought the LOADPARAMFROMDOC method
  #--(loaded by the ALICOLREM call from TRTPRICE_SYRA)
Return
#------------------------------------------------------------------------------
#--LOADPARAMFROMDOC => sort of "interface" method
#--We ask the calling object to fill us
#--The object must therefor implement this method in order to be able to call the FINDPRICE method
$LOADPARAM
#Variable Instance GENERIC_OBJ Using OBJECT
  If dim(INDEXLINE)<1
    Local Integer INDEXLINE
  Endif
  If INDEXLINE = 0 :INDEXLINE = 1 : Endif

    Local Integer WRET

    If GENERIC_OBJ=null
      [L]ASTATUS = fmet this.ASETERROR ("", "GENERIC_OBJ"-mess(18,9137,1), [V]CST_AERROR)
      Return #WRET = [V]ACST_ERROR  3/4/2014
    Endif

    Local Instance MYDOC Using =GENERIC_OBJ.ObjectType

    MYDOC = cast(GENERIC_OBJ,=GENERIC_OBJ.ObjectType)

    #--We ask the calling object to fill us
    #--The object must therefor implement this method in order to be able to call the FINDPRICE method
    #--We pass in a pointer to the current instance
      WRET = fmet MYDOC.LOADPARAMFROMDOC(this,INDEXLINE)
    If WRET >= [V]CST_AERROR
      WMESSA = mess(68,123,1)-":"-mess(1,7845,1)-"LOADPARAMFROMDOC"
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
      Return
    Endif

Return

$ERR_LOADPARAMFROMDOC_METHNOTSUPPORTED

[L]WRET = fmet this.ASETERROR ("", "Class"-MYDOC.ObjectType-" : No such method defined LOADPARAMFROMDOC", [V]CST_AERROR)

Resume
#########################################################################################

