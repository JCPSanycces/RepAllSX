#<AdxTL>@(#)5.0.0.0 $Revision$
Call OUVRE_TRACE("MAJ champ dimension") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#########################################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ABIDIMFLD","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"ABI") : End : Endif

# Mise à jour de la table ABIDIMFLD (Champs table de dimension)
Call ECR_TRACE(mess(81,125,1)-"ABIDIMFLD"-time$,0) From GESECRAN
Call MAJDIMINT(DOSSIER)

End 

#########################################################################################
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ABIDIMFLD","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"ABI") : End : Endif

# Mise à jour de la table ABIDIMFLD (Champs table de dimension)
Call ECR_TRACE(mess(81,125,1)-"ABIDIMFLD"-time$,0) From GESECRAN
Call MAJDIMINT(DOSSIER)

End 

#########################################################################################
# Mise à jour des champs dimensions intitulés
#########################################################################################
Subprog MAJDIMINT(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ABIDIMFLD"    [ABJ]
Local File =DOSSIER+".ABIDIM"       [ABI]
Local File =DOSSIER+".ATEXTE"       [ATX]

If dim([F:ABJ]DIMINT)<0 : End : Endif

Filter [ATX] Where TEXTE = "$"
Read [F:ATX] First

Trbegin [ABJ]
 For [ABJ]ABJ0
  If [F:ABJ]DIMFAT<>"" & [F:ABJ]DIMINT=0
   Read [F:ABI]ABI0 = [F:ABJ]DIMFAT
   [F:ABJ]DIMVALINT  = [F:ABI]INTEVAL
   If [F:ABJ]DIMVALINT=""
    [F:ABJ]DIMINT    = [F:ABI]INTIT
   Else
    [F:ABJ]DIMINT    = [F:ATX]NUMERO
   Endif
   Rewrite [F:ABJ]
   If fstat
    Call ERREUR("ABIDIMFLD"-[F:ABJ]CODDIM,2) From DOSDIC
   Endif
  Endif
 Next
Commit

Close Local File [ABJ],[ABI],[ATX]
End

