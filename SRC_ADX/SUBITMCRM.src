#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################
# Gestion de l'onglet Après-vente de la fiche article                Module CRM        5 Septembre 2003
#
# SETGRAY      : Gestion du grisage des champs.
# LOADPIT      : Charge le nombre de points à débiter
# SAVEPIT      : Enregistre le nombre de points à débiter
########################################################################################################
########################################################################################################
$SETGRAY
  If GIMPORT Then
    Return
  Endif
  If clalev([M:ITAV]) = 0 Then
    Return
  Endif
  If GMODU(12) <> 2 Then
    Grizo [M:ITAV]
    Affzo [M:ITAV]
    Return
  Endif
  #Modèles de contrats
  If [M:ITAV]TPLCONGUA = "" Then
    If [M:ITAV]TPLCONSRV = "" Then
      If [M:ITAV]TPLCONLND = "" Then
        If [M:ITAV]HDKITMTYP = 5 Then
          Grizo [M:ITAV]TPLCONLND
          Grizo [M:ITAV]TPLCONGUA
          Actzo [M:ITAV]TPLCONSRV
        Else
          Actzo [M:ITAV]TPLCONLND
          Actzo [M:ITAV]TPLCONGUA
          Actzo [M:ITAV]TPLCONSRV
        Endif
      Else
        Actzo [M:ITAV]TPLCONLND
        Actzo [M:ITAV]TPLCONGUA
        Grizo [M:ITAV]TPLCONSRV
      Endif
    Else
      Grizo [M:ITAV]TPLCONLND
      Grizo [M:ITAV]TPLCONGUA
      Actzo [M:ITAV]TPLCONSRV
    Endif
  Else
    Actzo [M:ITAV]TPLCONLND
    Actzo [M:ITAV]TPLCONGUA
    Grizo [M:ITAV]TPLCONSRV
  Endif
  #Création de parc
  If [M:ITAV]TPLCONSRV = "" Then
    If [M:ITAV]HDKITMTYP = 5 Then
      [M:ITAV]CREMAC = 1
      [M:ITAV]FLYCAT = ""
      Raz [M:ITAV]ALTBOMHDK
      Grizo [M:ITAV]CREMAC
      Grizo [M:ITAV]FLYCAT
      Grizo [M:ITAV]ALTBOMHDK
    Else
      Actzo [M:ITAV]CREMAC
      Actzo [M:ITAV]FLYCAT
      Actzo [M:ITAV]ALTBOMHDK
    Endif
  Else
    [M:ITAV]CREMAC = 1
    [M:ITAV]FLYCAT = ""
    Raz [M:ITAV]ALTBOMHDK
    Grizo [M:ITAV]CREMAC
    Grizo [M:ITAV]FLYCAT
    Grizo [M:ITAV]ALTBOMHDK
  Endif
  #Gestion des points
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 07/08/2009 : X3SUIVI57045 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Actzo [M:ITAV]PITDEB
    Actzo [M:ITAV]NULPIO
  Endif
  If type([M:ITAV]PITCDT) > 0 Then
    Actzo [M:ITAV]PITCDT
    Actzo [M:ITAV]PITCDTUOM
  Endif
  If type([M:ITAV]PITCDT) > 0 Then
    If [M:ITAV]PITCDT = 0 Then
      [M:ITAV]PITCDTUOM = ""
      Grizo [M:ITAV]PITCDTUOM
    Else
      Actzo [M:ITAV]PITCDTUOM
    Endif
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 07/08/2009 : X3SUIVI57045 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    If [M:ITAV]TPLCONSRV <> "" or [M:ITAV]HDKITMTYP = 5 Then
      Grizo [M:ITAV]PITDEB
      Grizo [M:ITAV]NULPIO
    Endif
  Endif
  #Bloc gestion du temps
  If [M:ITAV]HDKITMTYP = 0 Then
    [M:ITAV]HDKITMTYP = 1
  Endif
  If [M:ITAV]HDKITMTYP = 3 Then
    Call SREC_COE([M:ITM0]ITMREF, "", [M:ITAV]HOUUOM, [M:ITAV]DAYUOM, [M:ITAV]COEHOUDAY) From TRTVENQTE
    Actzo [M:ITAV]DAYUOM
    Actzo [M:ITAV]HOUUOM
    Actzo [M:ITAV]MNTUOM
  Else
    [M:ITAV]COEHOUDAY = 0
    Grizo [M:ITAV]DAYUOM
    Grizo [M:ITAV]HOUUOM
    Grizo [M:ITAV]MNTUOM
  Endif
  #Sortie de stock
  If [M:ITAV]HDKITMTYP = 2 Then
    If [M:ITM2]STOMGTCOD > 1 Then
      Actzo [M:ITAV]STOISSDEF
    Else
      [M:ITAV]STOISSDEF = 1
      Grizo [M:ITAV]STOISSDEF
    Endif
  Else
    [M:ITAV]STOISSDEF = 1
    Grizo [M:ITAV]STOISSDEF
  Endif
  Affzo [M:ITAV]
Return

########################################################################################################
# Charge le nombre de points à débiter
########################################################
Subprog LOADPIT(SZITMNUM)
Value Char SZITMNUM

  If clalev([M:ITAV]) = 0 Then
    End
  Endif
  If GMODU(12) <> 2 Then
    End
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    [M:ITAV]PITDEB = 0
    [M:ITAV]NULPIO = 1
    Filter [PDB] Where [F:PDB]BPR = "" and [F:PDB]ITMREF = SZITMNUM and [F:PDB]PBL = ""
    For [PDB]
      [M:ITAV]PITDEB = [F:PDB]SGLNBRPIT
      [M:ITAV]NULPIO = [F:PDB]NULPIO
      Break
    Next
    Filter [PDB]
  Endif
End

########################################################################################################
# Enregistre le nombre de points à débiter
########################################################
Subprog SAVEPIT(SZITMNUM, IERRINF)
Value Char SZITMNUM
Variable Integer IERRINF

  If clalev([M:ITAV]) = 0 Then
    End
  Endif
  If GMODU(12) <> 2 Then
    End
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    Read [PDB]PDB0="";SZITMNUM;""
    If fstat Then
      Call DEBTRANS From GLOCK
      Trbegin [PDB]
      [F:PDB]BPR = ""
      [F:PDB]ITMREF = SZITMNUM
      [F:PDB]PBL = ""
      [F:PDB]SGLNBRPIT = [M:ITAV]PITDEB
      If [M:ITAV]NULPIO = 0 Then
        [F:PDB]NULPIO = 1
      Else
        [F:PDB]NULPIO = [M:ITAV]NULPIO
      Endif
      [F:PDB]CREDAT = date$
      [F:PDB]CREUSR = GUSER
      Write [PDB]
      If fstat Then
        #Erreur lors de l'enregistrement des points à débiter.
        IERRINF = 467
        Rollback
      Else
        Commit
      Endif
    Else
      Call DEBTRANS From GLOCK
      Trbegin [PDB]
      Readlock [PDB]PDB0="";SZITMNUM;""
      If fstat Then
        #Erreur lors de l'enregistrement des points à débiter.
        IERRINF = 467
        Rollback
      Else
        [F:PDB]SGLNBRPIT = [M:ITAV]PITDEB
        If [M:ITAV]NULPIO = 0 Then
          [F:PDB]NULPIO = 1
        Else
          [F:PDB]NULPIO = [M:ITAV]NULPIO
        Endif
        [F:PDB]UPDDAT = date$
        [F:PDB]UPDUSR = GUSER
        Rewrite [PDB]
        If fstat Then
          #Erreur lors de l'enregistrement des points à débiter.
          IERRINF = 467
          Rollback
          Unlock [PDB]
        Else
          Commit
          Unlock [PDB]
        Endif
      Endif
    Endif
  Endif
End
