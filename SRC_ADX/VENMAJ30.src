#<AdxTL>@(#)2.0.0.0 $Revision$
####################################################################################
# VENMAJ30 : Mises à jour à effectuer lors du passage à la version 6 Module ventes  #
# --------------------------------------------------------------------------------- #
# Avant mise à jour AVENMAJ30                                                       #
#                                                                                   #
#    - Table SFOOTINV                     : Eléments de facturation                 #
#      Bascule TRFDLY, TRFINV ds Tableau des règles éclatement et init.             #
#      CUR        : Devise                                                          #
#      BPCORI     : Origine client                                                  #
#      VALTYP     : Type de valeur                                                  #
#      DSPLIN     : Répartition                                                     #
#      CLCDEB     : Prise en compte DEB                                             #
#      Récupération des codes axes analytiques                                      #
#    - Table SDELIVERYD                   : Détail livraisons                       #
#      Bascule des sections analytiques dans CPTANALIN                              #
#      Bascule MFGNUM MFGLIN BOMSEQ ds VCRNUMORI VCRLINORI VCRSEQORI                #
#    - Table SINVOICE SINVOICEV SINVOICED : Factures                                #
#      LED        : Référentiel                                                     #
#      CURLED     : Devises référenciel                                             #
#      RATMLT     : Cours multiplicateurs                                           #
#      RATDIV     : Cours diviseurs                                                 #
#      DIE        : Code Axe                                                        #
#      AMTNOTL    : Mt HT (soc)                                                     #
#      AMTATIL    : Mt TTC (soc)                                                    #
#      BPAPYR     : Code adresse payeur                                             #
#      BPY*       : Détail adresse tiers payeur                                     #
#                                                                                   #
#      Suppression du "0" avant la valeur de la nature CEE                          #
#      Si STOMVTFLG=1 (pas maj stock) : EECNAT->EECNATR et EECSCH->EECSCHR          #
#      DSPTOTQTY  : Cumul quantité                                                  #
#      DSPTOTWEI  : Cumul poids                                                     #
#      DSPTOTVOL  : Cumul volume                                                    #
#      DSPWEU     : Unité Poids                                                     #
#      DSPVOU     : Unité Volume                                                    #
#                                                                                   #
#      CPY        : Société                                                         #
#      DSPLINFLG  : Flag répartition                                                #
#      DSPLINWEI  : Poids  ligne                                                    #
#      DSPLINVOL  : Volume ligne                                                    #
#      DSPWEU     : Unité Poids                                                     #
#      DSPVOU     : Unité Volume                                                    #
#      EECFLOPHY  : Flux physique                                                   #
#      STRDAT     : Date début prestation                                           #
#      ENDDAT     : Date fin prestation                                             #
#      Création d'un enregistrement CPTANALIN par ligne de facture                  #
#      Récup des sections analytiques, du compte et de la nature                    #
#      Factures / Avoirs non validés                                                #
#      Création d'un enregistrement CPTANALIN par élément de facturation            #
#    - Table SORDERP                      : Détail commandes                        #
#      Bascule des sections analytiques dans CPTANALIN                              #
#    - Table SRETURN SRETURND             : Retours                                 #
#      DIE        : Code Axe                                                        #
#      CPY        : Société                                                         #
#      BPIEECNUM  : Identification CEE                                              #
#      Suppression du "0" avant la valeur de la nature CEE (EECNAT)                 #
#      EECICT     : Incoterm                                                        #
#      EECLOC     : Lieu transport CEE                                              #
#      EECTRN     : Mode transport CEE                                              #
#                                                                                   #
#      CPY        : Société                                                         #
#    - Table VSORDER VSORDERP VSORDERQ    : Historique Commandes                    #
#            VSORDERC                                                               #
#      CPY        : Société                                                         #
#      APPFLG     : Flag Signée                                                     #
#      ORDNOTL    : Mt lignes HT (soc)                                              #
#      ORDATIL    : Mt lignes TTC (soc)                                             #
#      INVDTATYP  : Type de valeur                                                  #
#      EECICT     : Incoterm                                                        #
#      EECLOC     : Lieu transport CEE                                              #
#      DIE        : Code Axe                                                        #
#      DSPWEU     : Unité Poids                                                     #
#      DSPVOU     : Unité Volume                                                    #
#      BPAORD     : Code adresse commande                                           #
#      BPAINV     : Code adresse facture                                            #
#                                                                                   #
#      CPY        : Société                                                         #
#                                                                                   #
#      CPY        : Société                                                         #
#      DSPWEU     : Unité Poids                                                     #
#      DSPVOU     : Unité Volume                                                    #
#      DSPLINFLG  : Flag répartition                                                #
#                                                                                   #
#      CPY        : Société                                                         #
#      VACBPR     : Régime de taxe                                                  #
#      BPIEECNUM  : Identification CEE                                              #
#      EECICT     : Incoterm                                                        #
#      EECLOC     : Lieu transport CEE                                              #
#                                                                                   #
#    - Table SALTRS                       : Transactions                            #
#####################################################################################
# --------------------------------------------------------------------------------- #
# Après mise à jour VENMAJ30                                                        #
#                                                                                   #
#    - Table SDELIVERY SDELIVERYD         : Livraisons                              #
#      Suppression du "0" avant la valeur de la nature CEE                          #
#      CPY        : Société                                                         #
#      DLVNOTL    : Mt lignes HT (soc)                                              #
#      DLVATIL    : Mt lignes TTC (soc)                                             #
#      DLVINVNOT  : Valorisation HT                                                 #
#      DLVINVATI  : Valorisation TTC                                                #
#      DLVINVNOTL : Valorisation HT soc                                             #
#      DLVINVATIL : Valorisation TTC soc                                            #
#      INVDTATYP  : Type de valeur                                                  #
#      EECICT     : Incoterm                                                        #
#      EECLOC     : Lieu transport CEE                                              #
#      DIE        : Code Axe                                                        #
#      DSPTOTQTY  : Cumul quantité                                                  #
#      DSPTOTWEI  : Cumul poids                                                     #
#      DSPTOTVOL  : Cumul volume                                                    #
#      DSPWEU     : Unité Poids                                                     #
#      DSPVOU     : Unité Volume                                                    #
#      BPAINV     : Code adresse facture                                            #
#                                                                                   #
#      CPY        : Société                                                         #
#      DSPLINFLG  : Flag répartition                                                #
#      DSPLINWEI  : Poids  ligne                                                    #
#      DSPLINVOL  : Volume ligne                                                    #
#      DSPWEU     : Unité Poids                                                     #
#      DSPVOU     : Unité Volume                                                    #
#                                                                                   #
#      CPY        : Société                                                         #
#    - Table SORDER SORDERP SORDERQ       : Commandes                               #
#            SORDERC                                                                #
#      CPY        : Société                                                         #
#      APPFLG     : Flag Signée                                                     #
#      ORDNOTL    : Mt lignes HT (soc)                                              #
#      ORDATIL    : Mt lignes TTC (soc)                                             #
#      ORDINVNOTL : Valorisation HT soc                                             #
#      ORDINVATIL : Valorisation TTC soc                                            #
#      INVDTATYP  : Type de valeur                                                  #
#      EECICT     : Incoterm                                                        #
#      EECLOC     : Lieu transport CEE                                              #
#      DIE        : Code Axe                                                        #
#      DSPTOTQTY  : Cumul quantité                                                  #
#      DSPTOTWEI  : Cumul poids                                                     #
#      DSPTOTVOL  : Cumul volume                                                    #
#      DSPWEU     : Unité Poids                                                     #
#      DSPVOU     : Unité Volume                                                    #
#      BPAORD     : Code adresse commande                                           #
#      BPAINV     : Code adresse facture                                            #
#      BPAPYR     : Code adresse payeur                                             #
#                                                                                   #
#      CPY        : Société                                                         #
#                                                                                   #
#      CPY        : Société                                                         #
#      DSPLINFLG  : Flag répartition                                                #
#      DSPLINWEI  : Poids  ligne                                                    #
#      DSPLINVOL  : Volume ligne                                                    #
#      DSPWEU     : Unité Poids                                                     #
#      DSPVOU     : Unité Volume                                                    #
#                                                                                   #
#      CPY        : Société                                                         #
#      VACBPR     : Régime de taxe                                                  #
#      BPIEECNUM  : Identification CEE                                              #
#      EECICT     : Incoterm                                                        #
#      EECLOC     : Lieu transport CEE                                              #
#      BPAORD     : Code adresse commande                                           #
#      BPAINV     : Code adresse facturation                                        #
#      BPAPYR     : Code adresse paiement                                           #
#    - Table SQUOTE SQUOTED               : Devis                                   #
#      CPY        : Société                                                         #
#      APPFLG     : Flag Signée                                                     #
#      BPIEECNUM  : Identification CEE                                              #
#      QUONOTL    : Mt lignes HT (soc)                                              #
#      QUOATIL    : Mt lignes TTC (soc)                                             #
#      QUOINVNOTL : Valorisation HT soc                                             #
#      QUOINVATIL : Valorisation TTC soc                                            #
#      INVDTATYP  : Type de valeur                                                  #
#      EECICT     : Incoterm                                                        #
#      EECLOC     : Lieu transport CEE                                              #
#      DIE        : Code Axe                                                        #
#      DSPTOTQTY  : Cumul quantité                                                  #
#      DSPTOTWEI  : Cumul poids                                                     #
#      DSPTOTVOL  : Cumul volume                                                    #
#      DSPWEU     : Unité Poids                                                     #
#      DSPVOU     : Unité Volume                                                    #
#      BPAORD     : Code adresse commande                                           #
#                                                                                   #
#      CPY        : Société                                                         #
#      DSPLINFLG  : Flag répartition                                                #
#      DSPLINWEI  : Poids  ligne                                                    #
#      DSPLINVOL  : Volume ligne                                                    #
#      DSPWEU     : Unité Poids                                                     #
#      DSPVOU     : Unité Volume                                                    #
#      BPAORD     : Code adresse commande                                           #
#                                                                                   #
#####################################################################################
#################################################################################
# Moulinettes avec anciens et nouveaux champs màj concernant le module ventes   #
#################################################################################
Subprog AVENMAJ30

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ30 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".BPDLVCUST"  [BPD]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]

# Fichiers à ouvrir pour la valorisation des devis des commandes et des livraisons
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Local File =[F:ADS]DOSSIER+".TABCHANGE"  [TCH]
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Local File =[F:ADS]DOSSIER+".ATEXTRA"    [AXX]

Local File =[F:ADS]DOSSIER+".PRICSTRUCT" [PRS]
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Local File =[F:ADS]DOSSIER+".SFOOTINV"   [SFI]

Local File =[F:ADS]DOSSIER+".TABVAC"     [TVC]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]

Local File =[F:ADS]DOSSIER+".TABCOEFF"   [TCO]
Local File =[F:ADS]DOSSIER+".TABUNIT"    [TUN]

Local File =[F:ADS]DOSSIER+".BPCUSTOMER" [BPC]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]

Local File =[F:ADS]DOSSIER+".SVCRVAT"    [SVV]
Local File =[F:ADS]DOSSIER+".SVCRFOOT"   [SVF]

Local File =[F:ADS]DOSSIER+".ADOVAL"     [ADW]
Local File =[F:ADS]DOSSIER+".ADOPAR"     [ADP]

#----- Définition et chargement des GLONxx nécessaires aux moulinettes achats -----#
Local File =[F:ADS]DOSSIER+".ATYPE"      [ATY]

# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL00
#Local Mask =[F:ADS]DOSSIER+".SIH0" [SIH0]
#Local Mask =[F:ADS]DOSSIER+".SIH1" [SIH1]
#Local Mask =[F:ADS]DOSSIER+".SIH2" [SIH2]
#Local Mask =[F:ADS]DOSSIER+".SIH4" [SIH4]

#Local Mask =[F:ADS]DOSSIER+".SIHV" [SIHV]
#Local Mask =[F:ADS]DOSSIER+".SIHV" [SIHX]

#------
If dim(GLONVAT)<1  Global Shortint GLONVAT : Endif
Read [ATY] CODTYP="VAT"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONVAT=[F:ATY]LNGTYP

#----- Copie des règles de Workflox à partir du dossier de référence -----#
# Validation des livraisons.
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","VALSDH","","","")    From ACOPIE

Global Integer WSFINUM (0..999)
Global Integer WSFIAMTCOD (0..999)

Gosub SET_FIRST   From TRTFIRST
Call AV_SFI : # Moulinette des éléments de facturation

# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL06
#Call AV_SDD : # Moulinette des détails livraisons
# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL08
#Call AV_SIV : # Moulinette des factures
# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL02 et UUMGTRTSAL03
#Call AV_SOP : # Moulinette des détails commandes
# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL07
#Call AV_SRH : # Moulinette des retours
# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL04 et UUMGTRTSAL05
#Call AV_VOH : # Moulinette des historiques commande

Call AV_SLT : # Moulinette des transactions
Gosub UNSET_FIRST   From TRTFIRST

Close Local File [CAL], [BPD], [BPR], [TCU], [TVT], [TRA], [AXX], [PRS], [CPY], [TVC], [ADI], [BPC], [SFI], [SVV], [SVF]
Close Local File [ADW], [ADP], [ATY]

# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL00
#Close Local Mask [SIH0], [SIH1], [SIH2], [SIH4], [SIHV], [SIHX]

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

Kill WSFINUM
Kill WSFIAMTCOD

End

#---------------------------------------------------------------------------------------#
#    ---> Concerne la table SFOOTINV                                                    #
#---------------------------------------------------------------------------------------#
# Bascule TRFDLY et TRFINV dans Tableau des règles éclatement et initialisation         #
# Initialisation CUR                                                                    #
# Initialisation BPCORI    Client origine par défaut Client facture (1)                 #
# Initialisation VALTYP    Type de valeur par défaut HT (1) si Montant % (3) si taux    #
# Initialisation DSPLIN    Répartition sur les lignes                                   #
# Initialisation CLCDEB    Prise en compte ds la DEB                                    #
# Récupération des codes axes analytiques                                               #
# Chargement des éléments de facturation dans un tableau memoire                        #
# --> Pour connaître le type de valeur : Taux/Montant                                   #
#---------------------------------------------------------------------------------------#
Subprog AV_SFI
If filinfo(filpath("FIL","SFOOTINV","fde",[F:ADS]DOSSIER),0) <=0   End   Endif

Call ECR_TIME("DOSMAJ30 Invoice element Process : Update SFOOTINV") From DOSSUB

#Local File =[F:ADS]DOSSIER+".GDIE"      [DIE]
Local File =[F:ADS]DOSSIER+".CADIEDEF"   [CDI]

Local Integer NBENR, WI, WJ
Raz NBENR, WJ

$BOUCLE_AV_SFI

Trbegin [SFI]
For [SFI]SFI0

    # Chargement des éléments de facturation dans un tableau memoire
    # --> Pour connaître le type de valeur : Taux/Montant
    If WJ<=dim(WSFINUM)
        WSFINUM(WJ)=[F:SFI]SFINUM
        WSFIAMTCOD(WJ)=[F:SFI]AMTCOD
        WJ+=1
    Endif

    # Initialisation du Tableau des règles éclatement avec Bascule TRFDLY et TRFINV
    # Devis                      --> Commande
    # Regroupement=Oui : R.Regroupement=Somme montants devis
    [F:SFI]ORIVCR(0)=1 :[F:SFI]DESVCR(0)=10:[F:SFI]GRUFLG(0)=1
    If [F:SFI]AMTCOD=1 : [F:SFI]GRURUL(0)=1 : Else : [F:SFI]GRURUL(0)=5 : Endif
    # R.Eclatement=Ttes les commandes
    [F:SFI]BRDRUL(0)=5

    # Cde à facturation directe  --> Facture
    # Regroupement=Oui : R.Regroupement=Somme montants commandes
    [F:SFI]ORIVCR(1)=12:[F:SFI]DESVCR(1)=18:[F:SFI]GRUFLG(1)=1
    #If [F:SFI]AMTCOD=1 : [F:SFI]GRURUL(0)=2 : Else : [F:SFI]GRURUL(0)=6 : Endif : # Bug 78738
    If [F:SFI]AMTCOD=1 : [F:SFI]GRURUL(1)=2 : Else : [F:SFI]GRURUL(1)=6 : Endif  : # Bug 78738
    # R.Eclatement=1ère facture
    [F:SFI]BRDRUL(1)=3
    If [F:SFI]TRFINV=2 [F:SFI]BRDRUL(1)=7 Endif : # Si Trf cde fac=Ttes --> R.éclatement=Ttes les factures

    # Cde                        --> Livraison
    # Regroupement=Oui : R.Regroupement=Somme montants commandes
    [F:SFI]ORIVCR(2)=10:[F:SFI]DESVCR(2) =2:[F:SFI]GRUFLG(2)=1
    #If [F:SFI]AMTCOD=1 : [F:SFI]GRURUL(0)=2 : Else : [F:SFI]GRURUL(0)=6 : Endif : # Bug 78738
    If [F:SFI]AMTCOD=1 : [F:SFI]GRURUL(2)=2 : Else : [F:SFI]GRURUL(2)=6 : Endif  : # Bug 78738
    # R.Eclatement=1ère livraison
    [F:SFI]BRDRUL(2)=2
    If [F:SFI]TRFDLY=2 [F:SFI]BRDRUL(2)=6 Endif : # Si Trf cde liv=Ttes --> R.éclatement=Ttes les livraisons

    # Livraison                  --> Facture
    # Regroupement=Oui : R.Regroupement=Somme montants livraisons
    [F:SFI]ORIVCR(3)=2 :[F:SFI]DESVCR(3)=19:[F:SFI]GRUFLG(3)=1
    #If [F:SFI]AMTCOD=1 : [F:SFI]GRURUL(0)=3 : Else : [F:SFI]GRURUL(0)=7 : Endif : # Bug 78738
    If [F:SFI]AMTCOD=1 : [F:SFI]GRURUL(3)=3 : Else : [F:SFI]GRURUL(3)=7 : Endif  : # Bug 78738
    # R.Eclatement=1ère facture
    [F:SFI]BRDRUL(3)=3

    # Facture                    --> Avoir
    # R.Eclatement=1ère avo : Regroupement=Oui : R.Regroupement=Somme montants factures
    [F:SFI]ORIVCR(4)=4 :[F:SFI]DESVCR(4)=5 :[F:SFI]GRUFLG(4)=1
    #If [F:SFI]AMTCOD=1 : [F:SFI]GRURUL(0)=4 : Else : [F:SFI]GRURUL(0)=8 : Endif : # Bug 78738
    If [F:SFI]AMTCOD=1 : [F:SFI]GRURUL(4)=4 : Else : [F:SFI]GRURUL(4)=8 : Endif  : # Bug 78738
    # R.Eclatement=Ts les avoirs
    [F:SFI]BRDRUL(4)=8

    [F:SFI]CUR=[F:ADS]RPTCUR : # Initialisation de la devise avec la devise du dossier
    [F:SFI]DSPLIN=1          : # Repartition sur les lignes = non
    If [F:SFI]CLCDEB=0       : # Prise en compte dans la DEB = Valeur fiscale
      If !func AFNC.ACTIV("DEB")
        [F:SFI]CLCDEB=1
      Else
        [F:SFI]CLCDEB=2
      Endif
    Endif
    If [F:SFI]AMTCOD=1
        [F:SFI]VALTYP=3      : # Code montant 1=%       Type de valeur 3=%
    Else
        [F:SFI]VALTYP=1      : # Code montant 2=Montant Type de la valeur 1=HT
    Endif
    [F:SFI]BPCORI=1          : # Client origine 1=Client facture

    #----- Récupération des codes axes analytique
    Raz WI
    #MAE, bg 54027
    #For [DIE] DIE0
    #  If [F:SFI]DIE(WI)=""  [F:SFI]DIE(WI)=[F:DIE]DIE : Endif
    #  WI+=1
    #  If dim([F:SFI]DIE)<=WI   Break : Endif
    #Next
    Read [CDI]CDI0 = 10
    If !fstat
       For WI=0 To [F:CDI]NBRDIE-1
          If WI<dim([F:SFI]DIE)
            If [F:SFI]DIE(WI)=""  [F:SFI]DIE(WI)=[F:CDI]DIE(WI) : Endif
          Else
            Break
          Endif
       Next
    Endif

    # ACA - On initialise le nouveau champ SFINUMCAR, nécessaire au lien avec ATEXTRA
    [F:SFI]SFINUMCAR = num$([F:SFI]SFINUM)

    Rewrite [SFI]
    NBENR+=1
    If fstat
        Call ECR_TRACE("File SFOOTINV, Error ="-num$(fstat),1) From GESECRAN
    Endif
    $NEXT_SFI
Next
Commit

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN

#Close Local File [DIE]
Close Local File [CDI]

End


#########################################################################
## M.a.j. de SDELIVERYD             : Livraisons
##
## - Bascule des sections analytiques dans CPTANALIN
## - Bascule MFGNUM MFGLIN BOMSEQ ds VCRNUMORI VCRLINORI VCRSEQORI
#########################################################################
Subprog AV_SDD
If filinfo(filpath("FIL","SDELIVERYD","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TIME("DOSMAJ30 Sales Delivery Process : Update SDELIVERYD") From DOSSUB

Local File =[F:ADS]DOSSIER+".SDELIVERYD"   [SDD]

Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)
Local Integer  CLE2

Raz NBENR, STOP, CLE1, CLE2
Trbegin [SDD]
$B_AV_SDD
If  STOP=1
  CRITERE = 'SDHNUM="'+CLE1+'" & SDDLIN>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'SDHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif
#CRITERE -= '& MFGNUM<>""'

Raz COMPTEUR

For [SDD]SDD0 Where evalue(CRITERE)
    Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:SDD]STOFCY) From TRTX3CPT
    Gosub UPD_CAL_SDD
    #If dim([F:SDD]MFGNUM)>0                    : # 88714
    If dim([F:SDD]MFGNUM)>0 & [F:SDD]MFGNUM<>"" : # 88714
        [F:SDD]VCRTYPORI=10
        [F:SDD]VCRNUMORI=[F:SDD]MFGNUM
        [F:SDD]VCRLINORI=[F:SDD]MFGLIN
        [F:SDD]VCRSEQORI=[F:SDD]BOMSEQ
        Rewrite [SDD]
        If fstat
            Call ECR_TRACE("File SDELIVERYD"-[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)+", Error ="-num$(fstat),1) From GESECRAN
        Else
            COMPTEUR+=1
        Endif
    Endif
    NBENR+=1
    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SDD]
        CLE1=[F:SDD]SDHNUM : CLE2=[F:SDD]SDDLIN : STOP=1 : Break
    Endif
Next
If STOP Goto B_AV_SDD : Endif
Commit

Close Local File [SDD]

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN
End

# -------------------------------------------------- #
# Création des enregistrements de la table CPTANALIN #
# -------------------------------------------------- #
$UPD_CAL_SDD

Look [CAL] CAL0="SDD";0;[F:SDD]SDHNUM;[F:SDD]SDDLIN;0;"";1
If fstat
    Raz [F:CAL]
    [F:CAL]ABRFIC="SDD"
    [F:CAL]VCRNUM=[F:SDD]SDHNUM
    [F:CAL]VCRLIN=[F:SDD]SDDLIN
    [F:CAL]ANALIG=1
    For J=1 To max(GNBCOA,2)
        [F:CAL]LED(J-1)=GLEDSOC(J)
        [F:CAL]COA(J-1)=GCOA(J)
    Next J
    For J=1 To max(GNBDIE,GOPTCANA)
        [F:CAL]DIE(J-1)=GDIE(J)
        If evalue("dim([F:SDD]CCE"+num$(J)+")")>0
            [F:CAL]CCE(J-1)=evalue("[F:SDD]CCE"+num$(J))
        Endif
    Next J
    Write [CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN SDD 0"-[F:SDH]SDHNUM-num$([F:SDD]SDDLIN)
&                       +", Error ="-num$(fstat),1) From GESECRAN
    Endif
Endif

Return

#########################################################################
## M.a.j. de SINVOICEV  SINVOICED : Factures
## M.a.j. de SINVOICE : : Nouveaux champs :
## - LED        : Référentiel
## - CURLED     : Devises référenciel
## - RATMLT     : Cours multiplicateurs
## - RATDIV     : Cours diviseurs
## - DIE        : Code Axe
## - AMTNOTL    : Mt HT (soc)
## - AMTATIL    : Mt TTC (soc)
## - BPAPYR     : Code adresse payeur
## - BPY*       : Détail adresse tiers payeur
## - STARPT     : Flag impression
##
## M.a.j. de SINVOICEV : Nouveaux champs :
## - Suppression du "0" avant la valeur de la nature CEE
## - Si STOMVTFLG=1 (pas maj stock) : EECNAT->EECNATR et EECSCH->EECSCHR
## - DSPTOTQTY  : Cumul quantité
## - DSPTOTWEI  : Cumul poids
## - DSPTOTVOL  : Cumul volume
## - DSPWEU     : Unité Poids
## - DSPVOU     : Unité Volume
## - STARPT     : Flag impression
##
## M.a.j SINVOICED : Nouveaux champs :
## - CPY        : Société
## - DSPLINFLG  : Flag répartition
## - DSPLINWEI  : Poids  ligne
## - DSPLINVOL  : Volume ligne
## - DSPWEU     : Unité Poids
## - DSPVOU     : Unité Volume
## - EECFLOPHY  : Flux physique
##                   Champs déjà existants : Récup des valeurs de l'entête
## - STRDAT     : Date début prestation
## - ENDDAT     : Date fin prestation
## - Création d'un enregistrement CPTANALIN par ligne de facture
##   - Récup des sections analytiques, du compte et de la nature
##
## Factures / Avoirs non validés
## - Création d'un enregistrement CPTANALIN par élément de facturation
##
#########################################################################
Subprog AV_SIV
If filinfo(filpath("FIL","SINVOICEV","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","SINVOICED","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TIME("DOSMAJ30 Sales Invoice Process : Update SINVOICEV-D") From DOSSUB

Local File =[F:ADS]DOSSIER+".SINVOICEV"    [SIV]
Local File =[F:ADS]DOSSIER+".SINVOICED"    [SID]
Local File =[F:ADS]DOSSIER+".SINVOICE"     [SIH]

Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)
Local Integer  WI, WJ, WRET
Local Decimal  WCOURS
Local Char     WITMREF, WFICD(3), WFICD1(3), WFICE(3)
Local Decimal  WMNTCALC, WMONT

$B_AV_SIV
If  STOP=1
    CRITERE = 'NUM>"'+CLE1+'"'
    STOP = 0
Else
    CRITERE = "1=1"
Endif

# Pour tester
#CRITERE = 'find(NUM,"FCADX0211VEN149","FCADX0211VEN151")'
#CRITERE = 'find(NUM,"FAC0608GAL00001","FAC0607GAL00001")'
#CRITERE = 'find(NUM,"FCASN1012VEN00040")'

Raz COMPTEUR
Trbegin [SIV],[SID], [SIH]
  For [SIV]SIV0 Where evalue(CRITERE)
      #-- Mise à jour de la table SINVOICEV
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:SIV]SALFCY) From TRTX3CPT
      [F:SIV]CPY=GSOCIETE
      If len([F:SIV]EECNAT)>2 & left$([F:SIV]EECNAT,1)="0" : [F:SIV]EECNAT=right$([F:SIV]EECNAT,2) : Endif
      If [F:SIV]STOMVTFLG=1
          [F:SIV]EECNATR=[F:SIV]EECNAT : Raz [F:SIV]EECNAT
          [F:SIV]EECSCHR=[F:SIV]EECSCH : Raz [F:SIV]EECSCH
      Endif
      # Initialisation ds le tableau des éléments de facturation
      # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
      For WI=0 To dim([F:SIV]INVDTA)-1
          If [F:SIV]INVDTA(WI)<>0
              [F:SIV]INVDTATYP(WI)=1
              WJ=find([F:SIV]INVDTA(WI),WSFINUM(0..999))
              If WJ>0 & WSFIAMTCOD(WJ-1)=1 [F:SIV]INVDTATYP(WI)=3 Endif
          Endif
      Next
      # Renseignement des unités de répartition
      [F:SIV]DSPWEU=GSALDSPWEU
      [F:SIV]DSPVOU=GSALDSPVOU
      Raz [F:SIV]DSPTOTQTY, [F:SIV]DSPTOTWEI, [F:SIV]DSPTOTVOL
      # Initialisation flag impression (6.2 Certification)
      If dim([F:SIV]STARPT)>0 & [F:SIV]STARPT=0
          If [F:SIV]INVSTA>1
              [F:SIV]STARPT = 2
          Else
              [F:SIV]STARPT = 1
          Endif
      Endif
      #-- Mise à jour de la table SINVOICE
      Read [SIH] SIH0=[F:SIV]NUM
      If fstat
          Call ECR_TRACE("File SINVOICE"-[F:SIV]NUM+", Error ="-num$(fstat),1) From GESECRAN
      Else
          If [F:SIH]LED(0)=""
              For WI=1 To max(GNBCOA,2)
                  [F:SIH]LED   (WI-1)=GLEDSOC(WI)
                  [F:SIH]CURLED(WI-1)=GDEVLED(WI)
                  [F:SIH]RATDIV(WI-1)=1
                  If GDEVLED(WI)=GLOCALDEV
                      If dim([F:SIH]RATCUR)>0 [F:SIH]RATMLT(WI-1)=[F:SIH]RATCUR Else [F:SIH]RATMLT(WI-1)=0 Endif
                  Elsif GDEVLED(WI)=GSYSCUR
                      If dim([F:SIH]RATRPT)>0 [F:SIH]RATMLT(WI-1)=[F:SIH]RATRPT Else [F:SIH]RATMLT(WI-1)=0 Endif
                  Else
                      [F:SIH]RATMLT(WI-1)=0
                  Endif
              Next WI
          Endif
          If dim([F:SIH]DIE)>0 & [F:SIH]DIE(0)=""
              For WI=1 To max(GNBDIE,GOPTCANA)
                  [F:SIH]DIE(WI-1)=GDIE(WI)
              Next WI
          Endif
          #-- Chargement des montants HT et TTC facture en devise société
          WI=find(GLOCALDEV,[F:SIH]CURLED)
          If WI>0 & [F:SIH]RATDIV(WI-1)<>0
            WCOURS=[F:SIH]RATMLT(WI-1)/[F:SIH]RATDIV(WI-1)
          Else
            WCOURS=0
          Endif

          #Gbn-Fq76355
          If [F:SIH]CUR<>"" & GLOCALDEV<>""
           Call COURMNT([F:SIH]CUR,GLOCALDEV,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]RATDAT,1,
&                     [F:SIH]AMTNOT,[F:SIH]AMTNOTL,WCOURS,WRET) From TRTDEV
           If WRET <> 0 Then
             # FGR 12/01/2010 : X3SUIVI61184
              Call ECR_TRACE("     1-File SINVOICE"-[F:SIV]NUM+", Error ="-num$(WRET)-[F:SIH]CUR-"/"-GLOCALDEV,-1) From GESECRAN
           Endif
           Call COURMNT([F:SIH]CUR,GLOCALDEV,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]RATDAT,1,
&                     [F:SIH]AMTATI,[F:SIH]AMTATIL,WCOURS,WRET) From TRTDEV
           If WRET <> 0 Then
             # FGR 12/01/2010 : X3SUIVI61184
             Call ECR_TRACE("     2-File SINVOICE"-[F:SIV]NUM+", Error ="-num$(WRET)-[F:SIH]CUR-"/"-GLOCALDEV,-1) From GESECRAN
           Endif
          Endif

          # ACA Gestion des adresses BPAPYR+BPY*
          Read [BPC]BPC0=[F:SIH]BPR
          If fstat Raz [F:BPC] Endif
          If [F:SIH]BPRPAY=[F:BPC]BPCPYR
              [F:SIH]BPAPAY=[F:BPC]BPAPYR
          Else
              Read [BPR]BPR0=[F:SIH]BPRPAY
              If fstat Raz [F:BPR] Endif
              [F:SIH]BPAPAY=[F:BPR]BPAADD
          Endif
          If [F:BPC]BPCTYP=2
              # Si client divers, on récupère l'adresse facturation
              [F:SIH]BPYNAM(0)=[F:SIH]BPRNAM(0)
              [F:SIH]BPYNAM(1)=[F:SIH]BPRNAM(1)
              [F:SIH]BPYADDLIG(0)=[F:SIH]BPAADDLIG(0)
              [F:SIH]BPYADDLIG(1)=[F:SIH]BPAADDLIG(1)
              [F:SIH]BPYADDLIG(2)=[F:SIH]BPAADDLIG(2)
              [F:SIH]BPYPOSCOD=[F:SIH]POSCOD
              [F:SIH]BPYCTY=[F:SIH]CTY
              [F:SIH]BPYSAT=[F:SIH]SAT
              [F:SIH]BPYCRY=[F:SIH]CRY
              [F:SIH]BPYCRYNAM=[F:SIH]CRYNAM
          Else
              # Si client non divers, on prend le code adresse et on récupère le détail associé
              Read [BPA]BPA0=1;[F:SIH]BPRPAY;[F:SIH]BPAPAY
              If fstat Raz [F:BPA] Endif
              [F:SIH]BPYNAM(0)=""
              [F:SIH]BPYNAM(1)=""
              [F:SIH]BPYADDLIG(0)=[F:BPA]BPAADDLIG(0)
              [F:SIH]BPYADDLIG(1)=[F:BPA]BPAADDLIG(1)
              [F:SIH]BPYADDLIG(2)=[F:BPA]BPAADDLIG(2)
              [F:SIH]BPYPOSCOD=[F:BPA]POSCOD
              [F:SIH]BPYCTY=[F:BPA]CTY
              [F:SIH]BPYSAT=[F:BPA]SAT
              [F:SIH]BPYCRY=[F:BPA]CRY
              [F:SIH]BPYCRYNAM=[F:BPA]CRYNAM
          Endif

          # Initialisation flag impression (6.2 Certification)
          If dim([F:SIH]STARPT)>0 & [F:SIH]STARPT=0
              If [F:SIH]STA>1
                  [F:SIH]STARPT = 2
              Else
                  [F:SIH]STARPT = 1
              Endif
          Endif

          Rewrite [SIH]
          If fstat
              Call ECR_TRACE("File SINVOICE"-[F:SIV]NUM+", Error ="-num$(fstat),1) From GESECRAN
          Endif
      Endif
      #-- création des enr dans les tables SVCRVAT et SVCRFOOT à partir de la table SINVOICEV
      If [F:SIV]INVSTA=3 | [F:SIV]INVTYP=5
        Delete [SVF] Where VCRTYP=4 & VCRNUM=[F:SIV]NUM
        Delete [SVV] Where VCRTYP=4 & VCRNUM=[F:SIV]NUM
        Gosub UPD_SVV_SIV : Gosub UPD_SVF_SIV
#       Call ECR_TRACE("SINVOICE : "-[F:SIV]NUM,1) From GESECRAN
      Endif
      #-- Si facture / avoir non validé : creation des enr de CPTANALIN
      If find([F:SIV]INVTYP,1,2) & [F:SIV]INVSTA<>3
          For J=0 To dim([F:SIV]DTA)-1
              If [F:SIV]DTA(J)=0 : Break : Endif
              Read [F:SFI]SFI0=[F:SIV]DTA(J) : If fstat Raz [F:SFI] Endif
              #Look [CAL] CAL0="SVF";0;[F:SIV]NUM;0;0;num$([F:SIV]DTA(J));1   : # Bug 75847
              Look [CAL] CAL0="SVF";4;[F:SIV]NUM;0;[F:SIV]DTA(J);"";1         : # Bug 75847
              If fstat
                  Raz [F:CAL]
                  [F:CAL]ABRFIC="SVF"
                  [F:CAL]VCRTYP=4                     : # Bug 75847
                  [F:CAL]VCRNUM=[F:SIV]NUM
                  [F:CAL]VCRSEQ=[F:SIV]DTA(J)         : # Bug 75847
                  #[F:CAL]CPLCLE=num$([F:SIV]DTA(J))  : # Bug 75847
                  [F:CAL]ANALIG=1
                  For I=1 To max(GNBCOA,2)
                      [F:CAL]LED(I-1)=GLEDSOC(I)
                      [F:CAL]COA(I-1)=GCOA(I)
                  Next I
                  [F:CAL]DSP=[F:SFI]DSP
                  For I=1 To max(GNBDIE,GOPTCANA)
                      [F:CAL]DIE(I-1)=GDIE(I)
                      [F:CAL]CCE(I-1)=[F:SFI]CCE(I-1)
                  Next I
                  Write [CAL]
                  If fstat
                      Call ECR_TRACE("File CPTANALIN  SVF 0 "-[F:SIV]NUM-"0 0"-num$([F:SIV]DTA(J))
&                                     +", Error ="-num$(fstat),1) From GESECRAN
                  Endif
              Endif
          Next J
      Endif
      #-- Boucle sur les lignes
      For [SID] SID0 Where NUM=[F:SIV]NUM
          Look [CAL] CAL0="SID";0;[F:SID]NUM;[F:SID]SIDLIN;0;"";1
          If fstat
              Raz [F:CAL]
              [F:CAL]ABRFIC="SID"
              [F:CAL]VCRNUM=[F:SID]NUM
              [F:CAL]VCRLIN=[F:SID]SIDLIN
              [F:CAL]ANALIG=1
              For J=1 To max(GNBCOA,2)
                  [F:CAL]LED(J-1)=GLEDSOC(J)
                  [F:CAL]COA(J-1)=GCOA(J)
              Next J
              [F:CAL]ACC(0)=[F:SID]LINACC
              [F:CAL]ACC(1)=[F:SID]LINCNA
              For J=1 To max(GNBDIE,GOPTCANA)
                  [F:CAL]DIE(J-1)=GDIE(J)
                  If evalue("dim([F:SID]CCE"+num$(J)+")")>0
                      [F:CAL]CCE(J-1)=evalue("[F:SID]CCE"+num$(J))
                  Endif
              Next J
              Write [CAL]
              If fstat
                  Call ECR_TRACE("File CPTANALIN SID 0"-[F:SID]NUM-num$([F:SID]SIDLIN)
&                               +", Error ="-num$(fstat),1) From GESECRAN
              Endif
          Endif
          # Bug 72056 : Init. dates de prestation lignes à partir de l'entête (V6.1)
          If [F:SID]ENDDAT=[0/0/0] [F:SID]ENDDAT=[F:SIH]ENDDATSVC Endif
          If [F:SID]STRDAT=[0/0/0] [F:SID]STRDAT=[F:SIH]STRDATSVC Endif
          #----- Alimentation de la société sur les lignes de facture d'achat -----#
          WFICD="SID" : WFICD1="SID" : WFICE="SIV" : Gosub ALIM_FICD
          If [F:SID]EECFLOPHY=0  [F:SID]EECFLOPHY=1 : Endif
          Rewrite [SID]
          If fstat
              Call ECR_TRACE("File SINVOICED"-[F:SID]NUM-num$([F:SID]SIDLIN)+", Error ="-num$(fstat),1) From GESECRAN
          Endif
      Next
#         Update [SID] Where NUM=[F:SIV]NUM With CPY=[F:SIV]CPY
#         If fstat
#            Call ECR_TRACE("File SINVOICED"-[F:SIV]NUM+", Error ="-num$(fstat),1) From GESECRAN
#         Endif

      Rewrite [SIV]
      If fstat
          Call ECR_TRACE("File SINVOICEV"-[F:SIV]NUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif

      NBENR+=1
      COMPTEUR+=1
      If COMPTEUR>GMAXUPDTRS CLE1=[F:SIV]NUM : STOP=1 : Break : Endif
  Next
Commit

If STOP Goto B_AV_SIV : Endif

Close Local File [SIV], [SID], [SIH]

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN

End

# ------------------------------------------------- #
# Création des enregistrements de la table SVCRFOOT #
# ------------------------------------------------- #
$UPD_SVF_SIV
# Boucle sur la table des élements de pied
For I=0 To dim([F:SIV]DTA)-1
  If [F:SIV]DTA(I)<>0
      Read [SFI] SFI0=[F:SIV]DTA(I) : If fstat  Raz [F:SFI] : Endif
      Look [SVF] SVF0=[F:SIV]NUM;4;[F:SIV]DTA(I)
      If fstat
          Raz [F:SVF]
          [F:SVF]VCRTYP=4 : [F:SVF]VCRNUM=[F:SIV]NUM : [F:SVF]NUM=[F:SIV]NUM

          [F:SVF]CPY=[F:SIV]CPY
          [F:SVF]CUR=[F:SIV]CUR
          # Bug 74353
          #If evalue("dim([F:SVF]CREDAT)")>0
          #    Assign "[F:SVF]CREDAT" With date$
          #Endif
          #If evalue("dim([F:SVF]CREUSR)")>0
          #    Assign "[F:SVF]CREUSR" With GUSER
          #Endif
          [F:SVF]CREDAT = date$
          [F:SVF]CREUSR = GUSER
          # Bug 74353
          [F:SVF]DTA          = [F:SIV]DTA(I)
          [F:SVF]DTAAMT       = [F:SIV]DTAAMT(I)
#          [F:SVF]DTATYP       = [F:SIV]DTATYP(I)
          [F:SVF]DTATYP       = [F:SFI]CLCBAS
          [F:SVF]DTANOT       = [F:SIV]DTANOT(I)
          [F:SVF]DTAVATNOT(0) = [F:SIV]DTANOT(I)
          [F:SVF]DTANET(0)    = [F:SIV]DTANET(I)
          [F:SVF]DTAVAT(0)    = [F:SIV]DTAVAT(I)
          [F:SVF]DTAVATRAT(0) = [F:SIV]DTAVATRAT(I)
          [F:SVF]DTAVATAMT(0) = [F:SIV]DTAVATAMT(I)
          [F:SVF]CLCORD       = [F:SFI]CLCORD
          [F:SVF]AMTCOD       = [F:SFI]AMTCOD
          [F:SVF]DTADSP       = [F:SFI]DSP

          Write [F:SVF]
          If fstat Call ECR_TRACE("File SVCRFOOT"-[F:SIV]NUM-"4"-num$([F:SIV]INVDTA(I))+", Error ="-num$(fstat),1) From GESECRAN Endif
      Endif
  Endif
Next I
Return


# ------------------------------------------------- #
# Création des enregistrements de la table SVCRVAT  #
# ------------------------------------------------- #
$UPD_SVV_SIV
# Boucle sur la table des taxes liées aux produits
For I=0 To dim ([F:SIV]VAT)-1
  If [F:SIV]VAT(I)<>""
      Look [SVV] SVV0=4;[F:SIV]NUM;[F:SIV]VAT(I)
      If fstat
          Raz [F:SVV]
          [F:SVV]VCRTYP=4 : [F:SVV]VCRNUM=[F:SIV]NUM : [F:SVV]NUM=[F:SIV]NUM

          [F:SVV]CPY=[F:SIV]CPY
          [F:SVV]CUR=[F:SIV]CUR
          # Bug 74353
          #If evalue("dim([F:SVF]CREDAT)")>0
          #    Assign "[F:SVF]CREDAT" With date$
          #Endif
          #If evalue("dim([F:SVF]CREUSR)")>0
          #    Assign "[F:SVF]CREUSR" With GUSER
          #Endif
          [F:SVV]CREDAT = date$
          [F:SVV]CREUSR = GUSER
          # Bug 74353
          [F:SVV]VAT       = [F:SIV]VAT(I)
          [F:SVV]VATTYP    = [F:SIV]VATTYP(I)
          [F:SVV]VATRAT    = [F:SIV]VATRAT(I)

          [F:SVV]VATGRO    = [F:SIV]VATGRO(I)
          [F:SVV]VATNET    = [F:SIV]VATNET(I)
          [F:SVV]VATAMT    = [F:SIV]VATAMT(I)
          [F:SVV]VATSUPAMT = [F:SIV]VATSUPAMT(I)

          [F:SVV]BASTAX    = [F:SIV]VATNET(I)
          [F:SVV]AMTTAX    = [F:SIV]VATAMT(I)

          Write [F:SVV]
          If fstat Call ECR_TRACE("File SVCRVAT"-"4"-[F:SIV]VAT(I)+", Error ="-num$(fstat),1) From GESECRAN Endif
      Endif
  Endif
Next I
# Boucle sur la table des éléments de pied
For I=0 To dim([F:SIV]DTAVAT)-1
  If [F:SIV]DTAVAT(I)<>""
      Read [SVV]SVV0=4;[F:SIV]NUM;[F:SIV]DTAVAT(I)
      If fstat
          Raz [F:SVV]
          [F:SVV]VCRTYP=4 : [F:SVV]VCRNUM=[F:SIV]NUM

          [F:SVV]CPY=[F:SIV]CPY
          [F:SVV]CUR=[F:SIV]CUR
          # Bug 74353
          #If evalue("dim([F:SVF]CREDAT)")>0
          #    Assign "[F:SVF]CREDAT" With date$
          #Endif
          #If evalue("dim([F:SVF]CREUSR)")>0
          #    Assign "[F:SVF]CREUSR" With GUSER
          #Endif
          [F:SVV]CREDAT = date$
          [F:SVV]CREUSR = GUSER
          # Bug 74353
          [F:SVV]VAT    = [F:SIV]DTAVAT(I)
          [F:SVV]VATTYP = 1
          [F:SVV]VATRAT = [F:SIV]DTAVATRAT(I)

          [F:SVV]BASTAX = [F:SIV]DTANET(I)
          [F:SVV]AMTTAX = [F:SIV]DTAVATAMT(I)

          Write [F:SVV]
          If fstat Call ECR_TRACE("File SVCRVAT"-"4"-[F:SIV]VAT(I)+", Error ="-num$(fstat),1) From GESECRAN Endif
      Else
          [F:SVV]BASTAX += [F:SIV]DTANET(I)
          [F:SVV]AMTTAX += [F:SIV]DTAVATAMT(I)

          Rewrite [F:SVV]
          If fstat Call ECR_TRACE("File SVCRVAT"-"4"-[F:SIV]VAT(I)+", Error ="-num$(fstat),1) From GESECRAN Endif
      Endif
  Endif
Next I

Return



#########################################################################
## M.a.j. de SORDERP                : Commandes
##
## - Bascule MFGNUM MFGLIN BOMSEQ ds VCRNUMORI VCRLINORI VCRSEQORI
#########################################################################
Subprog AV_SOP
If filinfo(filpath("FIL","SORDERP","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TIME("DOSMAJ30 Sales Order Process : Update SORDERP") From DOSSUB

Local File =[F:ADS]DOSSIER+".SORDERP"   [SOP]

Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)
Local Integer  CLE2

Raz NBENR, STOP, CLE1, CLE2
Trbegin [SOP]
$B_AV_SOP
If  STOP=1
  CRITERE = 'SOHNUM="'+CLE1+'" & SOPLIN>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'SOHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif

Raz COMPTEUR

For [SOP]SOP0 Where evalue(CRITERE)
    Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:SOP]SALFCY) From TRTX3CPT
    Gosub UPD_CAL_SOP
    COMPTEUR+=1 : NBENR+=1
    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SOP]
        CLE1=[F:SOP]SOHNUM : CLE2=[F:SOP]SOPLIN : STOP=1 : Break
    Endif
Next
If STOP Goto B_AV_SOP : Endif
Commit

Close Local File [SOP]

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN
End

# -------------------------------------------------- #
# Création des enregistrements de la table CPTANALIN #
# -------------------------------------------------- #
$UPD_CAL_SOP

Look [CAL] CAL0="SOP";0;[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ;"";1
If fstat
    Raz [F:CAL]
    [F:CAL]ABRFIC="SOP"
    [F:CAL]VCRNUM=[F:SOP]SOHNUM
    [F:CAL]VCRLIN=[F:SOP]SOPLIN
    [F:CAL]VCRSEQ=[F:SOP]SOPSEQ
    [F:CAL]ANALIG=1
    For J=1 To max(GNBCOA,2)
        [F:CAL]LED(J-1)=GLEDSOC(J)
        [F:CAL]COA(J-1)=GCOA(J)
    Next J
    For J=1 To max(GNBDIE,GOPTCANA)
        [F:CAL]DIE(J-1)=GDIE(J)
        If evalue("dim([F:SOP]CCE"+num$(J)+")")>0
            [F:CAL]CCE(J-1)=evalue("[F:SOP]CCE"+num$(J))
        Endif
    Next J
    Write [CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN SOP 0"-[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)
&                                +", Error ="-num$(fstat),1) From GESECRAN
    Endif
Endif

Return

# ------------------------------------------------------------------ #
# Alimentation des champs lignes détails communs à toutes les tables #
# Alimentation des champs entête communs à toutes les tables         #
# --> Concerne entre autre les totalisations poids et volume         #
# Entête :                                                           #
# - DSPTOTQTY  : Cumul quantité                                      #
# - DSPTOTWEI  : Cumul poids                                         #
# - DSPTOTVOL  : Cumul volume                                        #
# - DSPWEU     : Unité Poids                                         #
# - DSPVOU     : Unité Volume                                        #
# Détail :                                                           #
# - DSPLINFLG  : Flag répartition                                    #
# - DSPLINWEI  : Poids  ligne                                        #
# - DSPLINVOL  : Volume ligne                                        #
# - DSPWEU     : Unité Poids                                         #
# - DSPVOU     : Unité Volume                                        #
#                                                                    #
# - CPY        : Société                                             #
# - DSPLINFLG  : Flag répartition                                    #
# ------------------------------------------------------------------ #
$ALIM_FICD

Assign "[F:"+WFICD+"]CPY" With evalue("[F:"+WFICE+"]CPY")

Assign "[F:"+WFICD+"]DSPLINFLG" With 2

WITMREF = evalue ("[F:"+WFICD+"]ITMREF")
If [F:ITM]ITMREF<>WITMREF
    Read [F:ITM]ITM0 = WITMREF : If fstat Raz [ITM] Endif
Endif

WMNTCALC = [F:ITM]ITMWEI * evalue("[F:"+WFICD+"]QTY") * evalue("[F:"+WFICD1+"]SAUSTUCOE")
Call CONVERT_QTY ([F:ITM]WEU,GSALDSPWEU,WMNTCALC) From TRTX3
Assign "[F:"+WFICD+"]DSPLINWEI" With WMNTCALC

WMNTCALC = [F:ITM]ITMVOU * evalue("[F:"+WFICD+"]QTY") * evalue("[F:"+WFICD1+"]SAUSTUCOE")
Call CONVERT_QTY ([F:ITM]VOU,GSALDSPVOU,WMNTCALC) From TRTX3
Assign "[F:"+WFICD+"]DSPLINVOL" With WMNTCALC

Assign "[F:"+WFICD+"]DSPWEU" With evalue("[F:"+WFICE+"]DSPWEU")
Assign "[F:"+WFICD+"]DSPVOU" With evalue("[F:"+WFICE+"]DSPVOU")

WMONT  = evalue("[F:"+WFICE+"]DSPTOTQTY")
If WFICD<>"SQD"
    WMONT += evalue("[F:"+WFICD+"]QTYSTU")
Else
    WMONT += evalue("[F:"+WFICD+"]QTY")
Endif
Assign "[F:"+WFICE+"]DSPTOTQTY" With WMONT

WMONT  = evalue("[F:"+WFICE+"]DSPTOTWEI")
WMONT += evalue("[F:"+WFICD+"]DSPLINWEI")
Assign "[F:"+WFICE+"]DSPTOTWEI" With WMONT

WMONT  = evalue("[F:"+WFICE+"]DSPTOTVOL")
WMONT += evalue("[F:"+WFICD+"]DSPLINVOL")
Assign "[F:"+WFICE+"]DSPTOTVOL" With WMONT

Return

# ---------------------------------------------------- #
# Creation dans la table SVCRFOOT à partir de [M:SIHV] #
# ---------------------------------------------------- #
$UPD_SVF_SIHV
# On boucle sur la table des élements de pied
For JL=0 To dim([M:SIHV]XFNUM)-1
  If [M:SIHV]XFNUM(JL)<>0
     Look [SVF] SVF0=WVCRNUM;WVCRTYP;[M:SIHV]XFNUM(JL)
     If fstat
         Raz [F:SVF]
         [F:SVF]VCRTYP=WVCRTYP : [F:SVF]VCRNUM=WVCRNUM

         [F:SVF]CPY=GSOCIETE
         [F:SVF]CUR=[M:SIHV]VCUR

         If evalue("dim([F:SVF]CREDAT)")>0
              Assign "[F:SVF]CREDAT" With date$
         Endif
         If evalue("dim([F:SVF]CREUSR)")>0
              Assign "[F:SVF]CREUSR" With GUSER
         Endif

         [F:SVF]DTA        = [M:SIHV]XFNUM(JL)
         [F:SVF]DTAAMT     = [M:SIHV]XFDTAAMT(JL)
         [F:SVF]DTATYP     = [M:SIHV]CLCBAS(JL)
         [F:SVF]DTANOT     = [M:SIHV]XFNOT(JL)

         For I=0 To dim([F:SVF]DTANET)-1
             [F:SVF]DTAVATNOT(I) = evalue ("[M:SIHV]DTANOT"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTANET(I)    = evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTAVAT(I)    = evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTAVATRAT(I) = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTAVATAMT(I) = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")
         Next

         [F:SVF]CLCORD     = [M:SIHV]CLCORD(JL)
         [F:SVF]AMTCOD     = [M:SIHV]AMTCOD(JL)
         [F:SVF]DTADSP     = [M:SIHV]DSP(JL)

         Write [F:SVF]
         If fstat Call ECR_TRACE("File SVCRFOOT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XFNUM(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
     Endif
  Endif
Next JL

Return

# --------------------------------------------------- #
# Creation dans la table SVCRVAT à partir de [M:SIHV] #
# --------------------------------------------------- #
$UPD_SVV_SIHV
Local Integer I
Local Char    WVAT (GLONVAT)

# On boucle sur la table des taxes liées aux produits
For JL=0 To dim ([M:SIHV]XVTAX)-1
  If [M:SIHV]XVTAX(JL)<>""
     Look [SVV] SVV0=WVCRTYP;WVCRNUM;[M:SIHV]XVTAX(JL)
     If fstat
         Raz [F:SVV]
         [F:SVV]VCRTYP=WVCRTYP : [F:SVV]VCRNUM=WVCRNUM

         [F:SVV]CPY=GSOCIETE
         [F:SVV]CUR=[M:SIHV]VCUR

         If evalue("dim([F:SVV]CREDAT)")>0
             Assign "[F:SVV]CREDAT" With date$
         Endif
         If evalue("dim([F:SVV]CREUSR)")>0
             Assign "[F:SVV]CREUSR" With GUSER
         Endif

         [F:SVV]VAT       = [M:SIHV]XVTAX(JL)
         [F:SVV]VATTYP    = [M:SIHV]XVTYP(JL)
         [F:SVV]VATRAT    = [M:SIHV]XVRAT(JL)

         [F:SVV]VATGRO    = [M:SIHV]XVNOT(JL)
         [F:SVV]VATNET    = [M:SIHV]XVSMI(JL)
         [F:SVV]VATAMT    = [M:SIHV]XVAMT(JL)
         [F:SVV]VATSUPAMT = [M:SIHV]XVSUP(JL)

         [F:SVV]BASTAX    = [M:SIHV]XVSMI(JL)
         [F:SVV]AMTTAX    = [M:SIHV]XVAMT(JL)

         Write [F:SVV]
         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
     Endif
  Endif
Next JL

# On boucle sur la table des éléments de pied
For JL=0 To dim([M:SIHV]XFTAX)-1
  If [M:SIHV]XFTAX(JL)<>""
     Read [SVV]SVV0=WVCRTYP;WVCRNUM;[M:SIHV]XFTAX(JL)
     If fstat
         Raz [F:SVV]
         [F:SVV]VCRTYP=WVCRTYP : [F:SVV]VCRNUM=WVCRNUM

         [F:SVV]CPY=GSOCIETE
         [F:SVV]CUR=[M:SIHV]VCUR

         If evalue("dim([F:SVV]CREDAT)")>0
             Assign "[F:SVV]CREDAT" With date$
         Endif
         If evalue("dim([F:SVV]CREUSR)")>0
             Assign "[F:SVV]CREUSR" With GUSER
         Endif

         [F:SVV]VAT    = [M:SIHV]XFTAX(JL)
         [F:SVV]VATTYP = 1
         [F:SVV]VATRAT = [M:SIHV]XFRAT(JL)

         [F:SVV]BASTAX = [M:SIHV]XFSMI(JL)
         [F:SVV]AMTTAX = [M:SIHV]XFVATAMT(JL)

         Write [F:SVV]
         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
     Else
         [F:SVV]BASTAX += [M:SIHV]XFSMI(JL)
         [F:SVV]AMTTAX += [M:SIHV]XFVATAMT(JL)

         Rewrite [F:SVV]
         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
     Endif
  Elsif [M:SIHV]XFVATAMT(JL)<>0
     For I=0 To dim([M:SIHV]XVTAX)-1
         If evalue ("dim([M:SIHV]DTAVAT"+format$("N0:2",I+1)+")")>0
             If evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")") <> ""
                 WVAT=evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                 Read [SVV]SVV0=WVCRTYP;WVCRNUM;WVAT
                 If fstat
                     Raz [F:SVV]
                     [F:SVV]VCRTYP=WVCRTYP : [F:SVV]VCRNUM=WVCRNUM

                     [F:SVV]CPY=GSOCIETE
                     [F:SVV]CUR=[M:SIHV]VCUR

                     If evalue("dim([F:SVV]CREDAT)")>0
                         Assign "[F:SVV]CREDAT" With date$
                     Endif
                     If evalue("dim([F:SVV]CREUSR)")>0
                         Assign "[F:SVV]CREUSR" With GUSER
                     Endif

                     [F:SVV]VAT    = WVAT
                     [F:SVV]VATTYP = 1
                     [F:SVV]VATRAT = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")

                     [F:SVV]BASTAX = evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                     [F:SVV]AMTTAX = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")

                     Write [F:SVV]
                     If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
                 Else
                     [F:SVV]BASTAX += evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                     [F:SVV]AMTTAX += evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")

                     Rewrite [F:SVV]
                     If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
                 Endif
             Endif
         Endif
     Next
  Endif
Next JL

Return

#########################################################################
## M.a.j. de SRETURN  : Nouveaux champs
## - DIE        : Code Axe
## - CPY        : Société
## - BPIEECNUM  : Identification CEE
##   M.a.j des champs suivants (déjà existants) :
## - Suppression du "0" avant la valeur de la nature CEE (EECNAT)
## - EECICT     : Incoterm
## - EECLOC     : Lieu transport CEE
## - EECTRN     : Mode transport CEE
## M.a.j. de SRETURND : Nouveaux champs
## - CPY        : Société
#########################################################################
Subprog AV_SRH
If filinfo(filpath("FIL","SRETURN","fde",[F:ADS]DOSSIER),0)<=0  : End : Endif
If filinfo(filpath("FIL","SRETURND","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TIME("DOSMAJ30 Sales Return Process : Update SRETURN-D") From DOSSUB

Local File =[F:ADS]DOSSIER+".SRETURN"    [SRH]
Local File =[F:ADS]DOSSIER+".SRETURND"   [SRD]
Local File =[F:ADS]DOSSIER+".TABMODELIV" [TMD]

Local Shortint I, STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)

$B_AV_SRH
If  STOP=1
    CRITERE = 'SRHNUM>"'+CLE1+'"'
    STOP = 0
Else
    CRITERE = "1=1"
Endif
Raz COMPTEUR

Trbegin [SRH],[SRD]
  For [SRH] SRH0 Where evalue(CRITERE)
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:SRH]STOFCY) From TRTX3CPT
      If dim([F:SRH]DIE)>0 & [F:SRH]DIE(0)=""
          For I=1 To max(GNBDIE,GOPTCANA)
              [F:SRH]DIE(I-1)=GDIE(I)
          Next I
      Endif
      [F:SRH]CPY=GSOCIETE
      If len([F:SRH]EECNAT)>2 & left$([F:SRH]EECNAT,1)="0" : [F:SRH]EECNAT=right$([F:SRH]EECNAT,2) : Endif
      If [F:SRH]EECICT="" | (GACTDEB=2 & ([F:SRH]EECLOC=0 | [F:SRH]EECTRN=0))
          # --- Alimentation incoterm, lieu de transport CEE et mode de transport CEE
          If [F:BPD]BPCNUM<>[F:SRH]BPCORD | [F:BPD]BPAADD<>[F:SRH]BPAADD
             Read [F:BPD]BPD0 = [F:SRH]BPCORD;[F:SRH]BPAADD : If fstat Raz [BPD] Endif
          Endif
          If [F:SRH]EECICT="" [F:SRH]EECICT=[F:BPD]EECICT Endif
          If GACTDEB=2
             If [F:SRH]EECLOC=0 [F:SRH]EECLOC=[F:BPD]EECLOC Endif
             If [F:SRH]EECTRN=0 & [F:BPD]MDL<>""
                If [F:TMD]MDL<>[F:BPD]MDL
                   Read [TMD]TMD0=[F:BPD]MDL
                   If fstat Raz [TMD] : Endif
                Endif
                [F:SRH]EECTRN=[F:TMD]EECTRN
             Endif
          Endif
      Endif
      If GACTDEB=2 & [F:SRH]BPIEECNUM=""
          # --- Alimentation n° d'identification CEE
          If [F:BPR]BPRNUM<>[F:SRH]BPCINV & [F:SRH]BPCINV<>""
             Read [F:BPR]BPR0 = [F:SRH]BPCINV : If fstat Raz [BPR] Endif
          Endif
          [F:SRH]BPIEECNUM=[F:BPR]EECNUM
      Endif
      Rewrite [SRH]
      If fstat
          Call ECR_TRACE("File SRETURN"-[F:SRH]SRHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      For [SRD] SRD0 Where SRHNUM=[F:SRH]SRHNUM
          Look [CAL] CAL0="SRD";0;[F:SRD]SRHNUM;[F:SRD]SRDLIN;0;"";1
          If fstat
            Raz [F:CAL]
            [F:CAL]ABRFIC="SRD"
            [F:CAL]VCRNUM=[F:SRD]SRHNUM
            [F:CAL]VCRLIN=[F:SRD]SRDLIN
            [F:CAL]ANALIG=1
            For J=1 To max(GNBCOA,2)
               [F:CAL]LED(J-1)=GLEDSOC(J)
               [F:CAL]COA(J-1)=GCOA(J)
            Next J
            For J=1 To max(GNBDIE,GOPTCANA)
               [F:CAL]DIE(J-1)=GDIE(J)
               If evalue("dim([F:SRD]CCE"+num$(J)+")")>0
                   [F:CAL]CCE(J-1)=evalue("[F:SRD]CCE"+num$(J))
               Endif
            Next J
            Write [CAL]
            If fstat
               Call ECR_TRACE("File CPTANALIN SRD 0"-[F:SRH]SRHNUM-num$([F:SRD]SRDLIN)
&                                 +", Error ="-num$(fstat),1) From GESECRAN
            Endif
          Endif
          #----- Alimentation de la société sur les lignes de facture d'achat -----#
          [F:SRD]CPY=[F:SRH]CPY
          Rewrite [SRD]
          If fstat
             Call ECR_TRACE("File SRETURND"-[F:SRD]SRHNUM-num$([F:SRD]SRDLIN)+", Error ="-num$(fstat),1) From GESECRAN
          Endif
      Next
#         Update [SRD] Where SRHNUM=[F:SRH]SRHNUM With CPY=[F:SRH]CPY
#         If fstat
#            Call ECR_TRACE("File SRETURND"-[F:SRH]SRHNUM+", Error ="-num$(fstat),1) From GESECRAN
#         Endif

     NBENR+=1
     COMPTEUR+=1
     If COMPTEUR>GMAXUPDTRS CLE1=[F:SRH]SRHNUM : STOP=1 : Break : Endif
  Next
Commit

If STOP Goto B_AV_SRH : Endif

Close Local File [SRH], [SRD], [TMD]

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN

End

#########################################################################
## M.a.j. de VSORDER  VSORDERP  VSORDERQ  VSORDERC : Historique Commandes
## M.a.j VSORDER  : Nouveaux champs :
## - CPY        : Société
## - ORDNOTL    : Mt lignes HT (soc)
## - ORDATIL    : Mt lignes TTC (soc)
## - INVDTATYP  : Type de valeur
## - EECICT     : Incoterm
## - EECLOC     : Lieu transport CEE
## - DIE        : Code Axe
## - DSPWEU     : Unité Poids
## - DSPVOU     : Unité Volume
## - BPAORD     : Code adresse commande
## - BPAINV     : Code adresse facture
## Les nouveaux champs suivants ne sont pas initialisés volontairement
## - ORDINVNOT  : Valorisation  HT
## - ORDINVATI  : Valorisation  TTC
## - ORDINVNOTL : Valorisation  HT (soc)
## - ORDINVATIL : Valorisation  TTC (soc)
## - DSPTOTQTY  : Cumul quantité
## - DSPTOTWEI  : Cumul poids
## - DSPTOTVOL  : Cumul volume
## M.a.j VSORDERP : Nouveaux champs :
## - CPY        : Société
## M.a.j VSORDERQ : Nouveaux champs :
## - CPY        : Société
## - DSPWEU     : Unité Poids
## - DSPVOU     : Unité Volume
## - DSPLINFLG  : Flag répartition
## Les nouveaux champs suivants ne sont pas initialisés volontairement
## - DSPLINWEI  : Cumul poids
## - DSPLINVOL  : Cumul volume
## M.a.j VSORDERC : Nouveaux champs :
## - CPY        : Société
## - VACBPR     : Régime de taxe
## - BPIEECNUM  : Identification CEE
## - EECICT     : Incoterm
## - EECLOC     : Lieu transport CEE
#########################################################################
Subprog AV_VOH
If filinfo(filpath("FIL","VSORDER","fde",[F:ADS]DOSSIER),0)<=0  : End : Endif
If filinfo(filpath("FIL","VSORDERP","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","VSORDERQ","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","VSORDERC","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TIME("DOSMAJ30 Sales Order Process : Update VSORDER-Q-P-C") From DOSSUB

Local File =[F:ADS]DOSSIER+".VSORDER"    [VOH]
Local File =[F:ADS]DOSSIER+".VSORDERP"   [VOP]
Local File =[F:ADS]DOSSIER+".VSORDERQ"   [VOQ]
Local File =[F:ADS]DOSSIER+".VSORDERC"   [VOC]

Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)
Local Integer  CLE2, WRET
Local Char     S_SALFCY : Raz S_SALFCY
Local Decimal  WMNTCALC, WMONT

$B_AV_VOH_A

If  STOP=1
  CRITERE = 'SOHNUM="'+CLE1+'" & REVNUM>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'SOHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif
#CRITERE = 'find(SOHNUM,"CDE-2006-0024")'
#CRITERE = 'find(SOHNUM,"CDE-2006-0101")'

Raz COMPTEUR

Trbegin [VOH],[VOQ],[VOP],[VOC]
  For [VOH] VOH0 Where evalue(CRITERE)
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:VOH]SALFCY) From TRTX3CPT
      If dim([F:VOH]DIE)>0 & [F:VOH]DIE(0)=""
          For I=1 To max(GNBDIE,GOPTCANA)
             [F:VOH]DIE(I-1)=GDIE(I)
          Next I
      Endif
      # On essaie de ne pas l'appeler à chaque fois
      If S_SALFCY<>[F:VOH]SALFCY Call GLOBVAR([F:VOH]SALFCY) From WWGLOBVEN : S_SALFCY=[F:VOH]SALFCY : Endif

      If dim([F:VOH]APPFLG)>0 & [F:VOH]APPFLG=0 [F:VOH]APPFLG=4 Endif : # Init du flag signée à 4 : Pas de signature
      [F:VOH]CPY=GSOCIETE
      If [F:VOH]SOHCAT<>4 & ([F:VOH]EECICT="" | (GACTDEB=2 & [F:VOH]EECLOC=0))
          # Si ce n'est pas une cde ouverte, alimentation incoterm et lieu de transport CEE
          # Si c'est une cde ouverte, l'alimentation se fera dans SORDERC
          If [F:BPD]BPCNUM<>[F:VOH]BPCORD | [F:BPD]BPAADD<>[F:VOH]BPAADD
             Read [F:BPD]BPD0 = [F:VOH]BPCORD;[F:VOH]BPAADD : If fstat Raz [BPD] Endif
          Endif
          If [F:VOH]EECICT="" [F:VOH]EECICT=[F:BPD]EECICT Endif
          If GACTDEB=2 & [F:VOH]EECLOC=0 [F:VOH]EECLOC=[F:BPD]EECLOC Endif
      Endif
      # Initialisation ds le tableau des éléments de facturation
      # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
      For WI=0 To dim([F:VOH]INVDTA)-1
          If [F:VOH]INVDTA(WI)<>0
             [F:VOH]INVDTATYP(WI)=1
             WJ=find([F:VOH]INVDTA(WI),WSFINUM(0..999))
             If WJ>0 & WSFIAMTCOD(WJ-1)=1 [F:VOH]INVDTATYP(WI)=3 Endif
          Endif
      Next
      # Renseignement des unités de répartition
      [F:VOH]DSPWEU=GSALDSPWEU
      [F:VOH]DSPVOU=GSALDSPVOU
      Raz [F:VOH]DSPTOTQTY, [F:VOH]DSPTOTWEI, [F:VOH]DSPTOTVOL
      # Alimentation des montants en devise société
      If [F:VOH]CUR <> "" and GLOCALDEV <> "" Then
        # FGR 12/01/2010 : X3SUIVI61184
        Call COURMNT([F:VOH]CUR,GLOCALDEV,GLOCALDEV,[F:VOH]CHGTYP,[F:VOH]ORDDAT,1,
&                    [F:VOH]ORDNOT,[F:VOH]ORDNOTL,[F:VOH]CHGRAT,WRET) From TRTDEV
        Call COURMNT([F:VOH]CUR,GLOCALDEV,GLOCALDEV,[F:VOH]CHGTYP,[F:VOH]ORDDAT,1,
&                    [F:VOH]ORDATI,[F:VOH]ORDATIL,[F:VOH]CHGRAT,WRET) From TRTDEV
      Endif
      # ACA - Gestion des adresses +BPAORD, +BPAINV
      Read [BPC]BPC0=[F:VOH]BPCORD
      If fstat Raz [F:BPC] Endif
      [F:VOH]BPAORD=[F:BPC]BPAADD
#      [F:VOH]BPAINV=[F:BPC]BPAINV
      If [F:VOH]BPCINV=[F:BPC]BPCINV
          [F:VOH]BPAINV=[F:BPC]BPAINV
      Else
          Read [BPR]BPR0=[F:VOH]BPCINV
          If fstat Raz [F:BPR] Endif
          [F:VOH]BPAINV=[F:BPR]BPAADD
      Endif

      Rewrite [VOH]
      If fstat
          Call ECR_TRACE("File VSORDER"-[F:VOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      Update [VOQ] Where SOHNUM=[F:VOH]SOHNUM With CPY=[F:VOH]CPY, DSPWEU=[F:VOH]DSPWEU, DSPVOU=[F:VOH]DSPVOU, DSPLINFLG=2
      If fstat
          Call ECR_TRACE("File VSORDERQ"-[F:VOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      #----
         For [VOP] VOP0 Where SOHNUM=[F:VOH]SOHNUM

             Look [CAL] CAL0="VOP";0;[F:VOP]SOHNUM;[F:VOP]SOPLIN;[F:VOP]SOPSEQ;num$([F:VOP]LINREVNUM);1
             If fstat
               Raz [F:CAL]
               [F:CAL]ABRFIC="VOP"
               [F:CAL]VCRNUM=[F:VOP]SOHNUM
               [F:CAL]VCRLIN=[F:VOP]SOPLIN
               [F:CAL]VCRSEQ=[F:VOP]SOPSEQ
               [F:CAL]CPLCLE=num$([F:VOP]LINREVNUM)
               [F:CAL]ANALIG=1
               For J=1 To max(GNBCOA,2)
                 [F:CAL]LED(J-1)=GLEDSOC(J)
                 [F:CAL]COA(J-1)=GCOA(J)
               Next J
               For J=1 To max(GNBDIE,GOPTCANA)
                 [F:CAL]DIE(J-1)=GDIE(J)
                 If evalue("dim([F:VOP]CCE"+num$(J)+")")>0
                     [F:CAL]CCE(J-1)=evalue("[F:VOP]CCE"+num$(J))
                 Endif
               Next J
               Write [CAL]
               If fstat
                 Call ECR_TRACE("File CPTANALIN VOP 0"-[F:VOP]SOHNUM-num$([F:VOP]SOPLIN)-num$([F:VOP]SOPSEQ)-num$([F:VOP]LINREVNUM)-
&                                +", Error ="-num$(fstat),1) From GESECRAN
               Endif

               [F:VOP]CPY=[F:VOH]CPY
               Rewrite [VOP]
               If fstat
                 Call ECR_TRACE("File VSORDERP"-[F:VOP]SOHNUM-num$([F:VOP]SOPLIN)-num$([F:VOP]SOPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
               Endif
             Endif
         Next
         #----
#         Update [VOP] Where SOHNUM=[F:VOH]SOHNUM With CPY=[F:VOH]CPY
#         If fstat
#            Call ECR_TRACE("File VSORDERP"-[F:VOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
#         Endif
      If [F:VOH]SOHCAT=4
         #-----
         For [VOC] VOC0 Where SOHNUM=[F:VOH]SOHNUM
             [F:VOC]CPY   =[F:VOH]CPY
             [F:VOC]VACBPR=[F:VOH]VACBPR
             If [F:VOC]EECICT="" | (GACTDEB=2 & [F:VOC]EECLOC=0)
                 # --- Alimentation incoterm, lieu de transport CEE
                 If [F:BPD]BPCNUM<>[F:VOC]BPCORD | [F:BPD]BPAADD<>[F:VOC]BPAADD
                     Read [F:BPD]BPD0 = [F:VOC]BPCORD;[F:VOC]BPAADD : If fstat Raz [BPD] Endif
                 Endif
                 If [F:VOC]EECICT="" [F:VOC]EECICT=[F:BPD]EECICT Endif
                 If GACTDEB=2 & [F:VOC]EECLOC=0 [F:VOC]EECLOC=[F:BPD]EECLOC Endif
             Endif
             If GACTDEB=2 & [F:VOC]BPIEECNUM=""
                 # --- Alimentation n° d'identification CEE
                 If [F:BPR]BPRNUM<>[F:VOH]BPCINV
                     Read [F:BPR]BPR0 = [F:VOH]BPCINV : If fstat Raz [BPR] Endif
                 Endif
                 [F:VOC]BPIEECNUM=[F:BPR]EECNUM
             Endif
             Rewrite [VOC]
             If fstat
               Call ECR_TRACE("File VSORDERC"-[F:VOC]SOHNUM-num$([F:VOC]SOPLIN)+", Error ="-num$(fstat),1) From GESECRAN
             Endif
         Next
             #-----
#            Update [VOC] Where SOHNUM=[F:VOH]SOHNUM With CPY=[F:VOH]CPY, VACBPR=[F:VOH]VACBPR
#            If fstat
#               Call ECR_TRACE("File VSORDERC"-[F:VOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
#            Endif
      Endif

      NBENR+=1
      COMPTEUR+=1
      If COMPTEUR>GMAXUPDTRS CLE1=[F:VOH]SOHNUM : CLE2=[F:VOH]REVNUM : STOP=1 : Break : Endif
  Next
Commit

If STOP Goto B_AV_VOH_A : Endif

# --- Boucle sur historique VSORDERC non m.a.j. dans boucle 1

Raz COMPTEUR, STOP, CLE1, CLE2

Filter [VOC] Where CPY=""

$B_AV_VOH_B

If  STOP=1
  CRITERE = 'SOHNUM="'+CLE1+'" & ITMREVNUM>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'SOHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif

Raz COMPTEUR

Trbegin [VOC]
  For [VOC] VOC0 Where evalue(CRITERE)
      Call GETDEV([F:ADS]DOSSIER,[F:VOC]SALFCY) From TRTX3CPT
      [F:VOC]CPY=GSOCIETE
      If [F:VOC]VACBPR="" | [F:VOC]EECICT="" | (GACTDEB=2 & [F:VOC]EECLOC=0)
          # --- Alimentation incoterm, lieu de transport CEE
          If [F:BPD]BPCNUM<>[F:VOC]BPCORD | [F:BPD]BPAADD<>[F:VOC]BPAADD
              Read [F:BPD]BPD0 = [F:VOC]BPCORD;[F:VOC]BPAADD : If fstat Raz [BPD] Endif
          Endif
          If [F:VOC]VACBPR="" [F:VOC]VACBPR=[F:BPD]VACBPR Endif
          If [F:VOC]EECICT="" [F:VOC]EECICT=[F:BPD]EECICT Endif
          If GACTDEB=2 & [F:VOC]EECLOC=0 [F:VOC]EECLOC=[F:BPD]EECLOC Endif
      Endif
      If GACTDEB=2 & [F:VOC]BPIEECNUM=""
          # --- Alimentation n° d'identification CEE
          # Bug 60875 : BPCINV n'existe pas dans SORDERC
          # Ces lignes article n'ont pas d'entête contrat (puisqu'elles n'ont pas été traitées ds la 1ère boucle)
          # On ne peut pas connaître BPCINV
          #If [F:BPR]BPRNUM<>[F:VOC]BPCINV
          #    Read [F:BPR]BPR0 = [F:VOC]BPCINV : If fstat Raz [BPR] Endif
          #Endif
          #[F:VOC]BPIEECNUM=[F:BPR]EECNUM
      Endif
      Rewrite [VOC]
      If fstat
          Call ECR_TRACE("File VSORDERC"-[F:VOC]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      NBENR+=1
      COMPTEUR+=1
      If COMPTEUR>GMAXUPDTRS CLE1=[F:VOC]SOHNUM : CLE2=[F:VOC]ITMREVNUM : STOP=1 : Break : Endif
  Next
Commit

If STOP Goto B_AV_VOH_B : Endif
Filter [VOC]

Close Local File [VOH], [VOQ], [VOP], [VOC]

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN

End

#################################################################################
#    ---> Concerne les transactions                                             #
#################################################################################
Subprog AV_SLT

Local Shortint INDIC, WI
Local Integer  I

If filinfo(filpath("FIL","SALTRS","fde",[F:ADS]DOSSIER),0)<=0  : End : Endif

#-------------------------------------------------------------------------------#
# Initialisation transactions ventes pour les nouvelles zones                   #
#-------------------------------------------------------------------------------#
Call ECR_TIME("DOSMAJ30 Sales Transactions Process : Update SALTRS") From DOSSUB

Local File =[F:ADS]DOSSIER+".SALTRS"    [SLT]
Local File =[F:ADS]DOSSIER+".DIETRS"    [DTR]
Local File =[F:ADS]DOSSIER+".GDIE"      [DIE]

Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)

Call ECR_TIME("DOSMAJ30 Sales Transactions Process : --- Step 1 ") From DOSSUB
Gosub TXNDEV

Call ECR_TIME("DOSMAJ30 Sales Transactions Process : --- Step 2 ") From DOSSUB
Gosub TXNCDE

Call ECR_TIME("DOSMAJ30 Sales Transactions Process : --- Step 3 ") From DOSSUB
Gosub TXNOUV

Call ECR_TIME("DOSMAJ30 Sales Transactions Process : --- Step 4 ") From DOSSUB
Gosub TXNLIV

Call ECR_TIME("DOSMAJ30 Sales Transactions Process : --- Step 5 ") From DOSSUB
Gosub TXNFAC

Call ECR_TIME("DOSMAJ30 Sales Transactions Process : --- Step 6 ") From DOSSUB
Gosub TXNRET

Close Local File [SLT]
Close Local File [DTR]
Close Local File [DIE]

End

#-------------------------------------------------------------------------------#
# Transaction pour les devis                                                    #
#-------------------------------------------------------------------------------#
$TXNDEV
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=1
      Raz INDIC
      If !find([F:SLT]OFFFLD,1,2)  INDIC=1 : [F:SLT]OFFFLD = 1 : Endif
      # Dde 65018 : Code incoterm
      If dim([F:SLT]EECICTCOD)>0
          If !find([F:SLT]EECICTCOD,1,2,3) : INDIC=1 : [F:SLT]EECICTCOD=3 : Endif : # Code incoterm (invisible)
      Endif
      Gosub TXNANA
      If INDIC=1
         Rewrite [SLT]
         If fstat
             Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
         Endif
      Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les commandes                                                #
#-------------------------------------------------------------------------------#
$TXNCDE
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=2
      Raz INDIC
      If dim([F:SLT]DRNCOD)>0
          If !find([F:SLT]DRNCOD,1,2,3)    INDIC=1 : [F:SLT]DRNCOD=3    : Endif   : # N°tournée (invisible)
          If !find([F:SLT]DRNCODD,1,2,3)   INDIC=1 : [F:SLT]DRNCODD=3   : Endif   : # N°tournée (invisible)
          If [F:SLT]DRNCODD<>0  & [F:SLT]DRNSCRD=0 INDIC=1 : [F:SLT]DRNSCRD=1  : Endif
      Endif
      If dim([F:SLT]PRECODCOD)>0
          If !find([F:SLT]PRECODCOD,1,2,3) INDIC=1 : [F:SLT]PRECODCOD=3 : Endif   : # Code prépa (invisible)
          If [F:SLT]PRECODCOD<>0  & [F:SLT]PRECODSCR=0 INDIC=1 : [F:SLT]PRECODSCR=1  : Endif
      Endif
      # Dde 65018 : Code incoterm
      If dim([F:SLT]EECICTCOD)>0
          If !find([F:SLT]EECICTCOD,1,2,3) : INDIC=1 : [F:SLT]EECICTCOD=3 : Endif : # Code incoterm (invisible)
      Endif
      Gosub TXNANA
      If INDIC=1
          Rewrite [SLT]
          If fstat
              Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
          Endif
      Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les commandes ouvertes                                       #
#-------------------------------------------------------------------------------#
$TXNOUV
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=3
    Raz INDIC
    If !find([F:SLT]VACBPRCODD,1,2,3)  INDIC=1 : [F:SLT]VACBPRCODD = 1 : Endif
    # V6.2 : 60763 Settlements Discounts
    If !find([F:SLT]DEPCOD,1,2,3)      INDIC=1 : [F:SLT]DEPCOD=3       : Endif   : # Escompte/agio (invisible)
    # Dde 65018 : Code incoterm
    If dim([F:SLT]EECICTCOD)>0
        If !find([F:SLT]EECICTCOD,1,2,3) : INDIC=1 : [F:SLT]EECICTCOD=3 : Endif : # Code incoterm (invisible)
    Endif
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les livraisons                                               #
#-------------------------------------------------------------------------------#
$TXNLIV
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=4
    Raz INDIC
    Gosub TXNSTOCK
    If dim([F:SLT]MFGNUMCOD)>0 [F:SLT]VCRNUMOCOD=[F:SLT]MFGNUMCOD : INDIC=1 : Endif
    If dim([F:SLT]MFGNUMSCR)>0 [F:SLT]VCRNUMOSCR=[F:SLT]MFGNUMSCR : INDIC=1 : Endif
    # V6.2 : 60763 Settlements Discounts
    If !find([F:SLT]DEPCOD,1,2,3) [F:SLT]DEPCOD=3                 : INDIC=1 : Endif   : # Escompte/agio (invisible)
    # Dde 65018 : Code incoterm
    If dim([F:SLT]EECICTCOD)>0
        If !find([F:SLT]EECICTCOD,1,2,3) : INDIC=1 : [F:SLT]EECICTCOD=3 : Endif : # Code incoterm (invisible)
    Endif
    Gosub TXNANA
    Rewrite [SLT]
    If fstat
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les factures                                                 #
#-------------------------------------------------------------------------------#
$TXNFAC
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=5
    Raz INDIC
    If !find([F:SLT]FLOPHYCODD,1,2,3) INDIC=1 : [F:SLT]FLOPHYCODD=3 : Endif   : # Flux physique (invisible)
    If [F:SLT]FLOPHYCODD<>0  & [F:SLT]FLOPHYSCRD=0 INDIC=1 : [F:SLT]FLOPHYSCRD=1  : Endif
    # Clt cde : Passe de MM(1) Affiché Non/Oui à MM(35) Saisi/Affiché/Invisible (Test INDIC pour ne faire la bascule
    If [F:SLT]BPCORDCOD=1 INDIC=1 : [F:SLT]BPCORDCOD=3 Endif
    If !find([F:SLT]AMTLINCOD,1,2,3) [F:SLT]AMTLINCOD=3 : [F:SLT]AMTLINSCR=1 : INDIC=1 Endif
    If [F:SLT]AMTLINCOD<>0   & [F:SLT]AMTLINSCR=0  INDIC=1 : [F:SLT]AMTLINSCR=1  : Endif
    If dim([F:SLT]SVCDATCODD)>0
        If !find([F:SLT]SVCDATCODD,1,2,3) [F:SLT]SVCDATCODD=3 : [F:SLT]SVCDATSCRD=1 : INDIC=1 Endif
        If [F:SLT]SVCDATCODD<>0   & [F:SLT]SVCDATSCRD=0  INDIC=1 : [F:SLT]SVCDATSCRD=1  : Endif
    Endif
    # Dde 65018 : Code incoterm
    If dim([F:SLT]EECICTCOD)>0
        If !find([F:SLT]EECICTCOD,1,2,3) : INDIC=1 : [F:SLT]EECICTCOD=3 : Endif : # Code incoterm (invisible)
    Endif
    # Dde 87923 : SDD management
    If dim([F:SLT]UMRNUMCOD)>0                  : # Référence mandat
      If !find([F:SLT]UMRNUMCOD,1,2,3)
          If dim([F:SLT]PTECOD)>0 & find([F:SLT]PTECOD,1,2,3)
              [F:SLT]UMRNUMCOD=[F:SLT]PTECOD    : # Same value as Payment terms
          Else
              [F:SLT]UMRNUMCOD=3                : # invisible
          Endif
          INDIC=1
      Endif
    Endif
    Gosub TXNSTOCK
    Gosub TXNANA
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les retours                                                  #
#-------------------------------------------------------------------------------#
$TXNRET
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=6 | STRTYP=7
    Raz INDIC
    If !find([F:SLT]BETFCYCOD,1,2)  INDIC=1 : [F:SLT]BETFCYCOD = 1 : Endif
    If !find([F:SLT]BETCPYCOD,1,2)  INDIC=1 : [F:SLT]BETCPYCOD = 1 : Endif
    # Dde 65018 : Code incoterm
    If dim([F:SLT]EECICTCOD)>0
        If !find([F:SLT]EECICTCOD,1,2,3) : INDIC=1 : [F:SLT]EECICTCOD=3 : Endif : # Code incoterm (invisible)
    Endif
    Gosub TXNSTOCK
    Gosub TXNANA
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return


$TXNANA
#----- Alimentation nouvelle table pour axes analytiques -----#
Look [DTR] DTR0="SLT";[F:SLT]STRTYP;[F:SLT]STRNUM;0;0
If fstat
    # Un enregistrement pour les données d'entête
    If [F:SLT]CCECOD=0      INDIC=1 : [F:SLT]CCECOD=3  : Endif
    If [F:SLT]CCECODS=0     INDIC=1 : [F:SLT]CCECODS=3 : Endif
    If [F:SLT]CCESCRD(0)=0  INDIC=1 : [F:SLT]CCESCRD=1 : Endif
    Raz [F:DTR]
    [F:DTR]ABRFIC="SLT"
    [F:DTR]DTRTYP=[F:SLT]STRTYP
    [F:DTR]DTRNUM=[F:SLT]STRNUM
    [F:DTR]DIE   =""
    [F:DTR]HEACCECOD=[F:SLT]CCECOD
    [F:DTR]STOCCECOD=[F:SLT]CCECODS
    [F:DTR]DSPCOD =3
    [F:DTR]DSPSCR =1
    [F:DTR]CCESCR =[F:SLT]CCESCRD(0)
    [F:DTR]CCESCR2=1
    [F:DTR]CCESCR3=1
    Write [DTR]
    If fstat
        Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
    Endif
    Raz WI
    # Un enregistrement pour chaque code axe pour les lignes
    For [DIE] DIE0
        Look [DTR] DTR1="SLT";[F:SLT]STRTYP;[F:SLT]STRNUM;1;[F:DIE]DIE
        If fstat
            [F:DTR]DTRTNU=1
            [F:DTR]DTRLIN=WI+1
            [F:DTR]DIE   =[F:DIE]DIE
            If dim([F:SLT]CCECODD)>WI & [F:SLT]CCECODD(WI)>0 & [F:SLT]CCECODD(WI)<3
              [F:DTR]CCECOD=[F:SLT]CCECODD(WI)
              Write [DTR]
              If fstat
                Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
              Endif
            Endif
        Endif
        WI+=1
    Next
Endif
Return

$TXNSTOCK
#   Bloc document
If !find([F:SLT]IDECOD01,1,2,3)  INDIC=1 : [F:SLT]IDECOD01=3 : Endif   : # Identifiant 1 (invisible)
If [F:SLT]IDECOD01<>0  & [F:SLT]IDESCR01=0 INDIC=1 : [F:SLT]IDESCR01=1  : Endif

If !find([F:SLT]IDECOD02,1,2,3)  INDIC=1 : [F:SLT]IDECOD02=3 : Endif   : # Identifiant 2 (invisible)
If [F:SLT]IDECOD02<>0  & [F:SLT]IDESCR02=0 INDIC=1 : [F:SLT]IDESCR02=1  : Endif
Return

##################################################################################
# Moulinettes avec champs version V6 uniquement màj concernant le module ventes #
##################################################################################
Subprog VENMAJ30

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ30 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".BPDLVCUST"  [BPD]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]

# Fichiers à ouvrir pour la valorisation des livraisons
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".TABCHANGE"  [TCH]
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Local File =[F:ADS]DOSSIER+".ATEXTRA"    [AXX]
Local File =[F:ADS]DOSSIER+".TABFOR"     [TFO]
Local File =[F:ADS]DOSSIER+".TAXLINK"    [TLK]

Local File =[F:ADS]DOSSIER+".PRICSTRUCT" [PRS]
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Local File =[F:ADS]DOSSIER+".SFOOTINV"   [SFI]

Local File =[F:ADS]DOSSIER+".TABVAC"     [TVC]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]

Local File =[F:ADS]DOSSIER+".TABCOEFF"   [TCO]
Local File =[F:ADS]DOSSIER+".TABUNIT"    [TUN]

Local File =[F:ADS]DOSSIER+".BPCUSTOMER" [BPC]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]

Local File =[F:ADS]DOSSIER+".SVCRVAT"    [SVV]
Local File =[F:ADS]DOSSIER+".SVCRFOOT"   [SVF]

Local File =[F:ADS]DOSSIER+".ADOVAL"     [ADW]
Local File =[F:ADS]DOSSIER+".ADOPAR"     [ADP]

#----- Définition et chargement des GLONxx nécessaires aux moulinettes achats -----#
Local File =[F:ADS]DOSSIER+".ATYPE"      [ATY]

# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL00
# Masques à ouvrir pour la valorisation des livraisons commandes et devis
#Local Mask =[F:ADS]DOSSIER+".SIH0" [SIH0]
#Local Mask =[F:ADS]DOSSIER+".SIH1" [SIH1]
#Local Mask =[F:ADS]DOSSIER+".SIH2" [SIH2]
#Local Mask =[F:ADS]DOSSIER+".SIH4" [SIH4]

#Local Mask =[F:ADS]DOSSIER+".SIHV" [SIHV]
#Local Mask =[F:ADS]DOSSIER+".SIHV" [SIHX]

#Call ECR_TRACE("VENMAJ30:[F:ADS]DOSSIER="-[F:ADS]DOSSIER, 0) From GESECRAN

#------
If dim(GLONVAT)<1  Global Shortint GLONVAT : Endif
Read [ATY] CODTYP="VAT"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONVAT=[F:ATY]LNGTYP

Global Integer WSFINUM (0..999)
Global Integer WSFIAMTCOD (0..999)
Local  Integer WJ : Raz WJ

For [SFI]SFI0
    # Chargement des éléments de facturation dans un tableau memoire
    # --> Pour connaître le type de valeur : Taux/Montant
    If WJ<=dim(WSFINUM)
        WSFINUM(WJ)=[F:SFI]SFINUM
        WSFIAMTCOD(WJ)=[F:SFI]AMTCOD
        WJ+=1
    Endif
Next

Gosub SET_FIRST   From TRTFIRST

# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL06
#Call AP_SDH : # Moulinette des livraisons
# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL02 et UUMGTRTSAL03
#Call AP_SOH : # Moulinette des commandes
# Issue 74060 - 2011-10-12 by LD : cf UUMGTRTSAL01
#Call AP_SQH : # Moulinette des devis

Gosub UNSET_FIRST   From TRTFIRST

Close Local File [CAL], [BPD], [BPR], [TCU], [TVT], [TRA], [AXX], [PRS], [CPY], [TVC], [ADI], [BPC], [SFI], [SVV], [SVF]
Close Local File [ADW], [ADP], [ATY]

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

Kill WSFINUM
Kill WSFIAMTCOD

End

#########################################################################
## M.a.j. de SDELIVERY  SDELIVERYD : Livraisons
## M.a.j. de SDELIVERY :
## - Suppression du "0" avant la valeur de la nature CEE
##                    Nouveaux champs :
## - CPY        : Société
## - DLVNOTL    : Mt lignes HT (soc)
## - DLVATIL    : Mt lignes TTC (soc)
## - DLVINVNOT  : Valorisation HT
## - DLVINVATI  : Valorisation TTC
## - DLVINVNOTL : Valorisation HT soc
## - DLVINVATIL : Valorisation TTC soc
## - INVDTATYP  : Type de valeur
## - EECICT     : Incoterm
## - EECLOC     : Lieu transport CEE
## - DIE        : Code Axe
## - DSPTOTQTY  : Cumul quantité
## - DSPTOTWEI  : Cumul poids
## - DSPTOTVOL  : Cumul volume
## - DSPWEU     : Unité Poids
## - DSPVOU     : Unité Volume
## - BPAINV     : Code adresse facture
## M.a.j SDELIVERYD : Nouveaux champs :
## - CPY        : Société
## - DSPLINFLG  : Flag répartition
## - DSPLINWEI  : Poids  ligne
## - DSPLINVOL  : Volume ligne
## - DSPWEU     : Unité Poids
## - DSPVOU     : Unité Volume
## M.a.j. de SPACK      SPACKD     : Colis de la livraison
##                    Nouveaux champs :
## - CPY        : Société
#########################################################################
## Cette moulinette doit être exécutée après maj
## --> Car elle nécessite l'écran SFITRF qui est un nouvel écran
##     Les nvx écrans n'existent dans le dossier fille qu'à ce moment là
#########################################################################
Subprog AP_SDH
If filinfo(filpath("FIL","SDELIVERY","fde", [F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","SDELIVERYD","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","SPACK","fde",     [F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","SPACKD","fde",    [F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TIME("DOSMAJ30 Sales Delivery Process : Update SDELIVERY-D  SPACK-D") From DOSSUB

Local File =[F:ADS]DOSSIER+".SDELIVERY"    [SDH]
Local File =[F:ADS]DOSSIER+".SDELIVERYD"   [SDD]
Local File =[F:ADS]DOSSIER+".SPACK"        [SPH]
Local File =[F:ADS]DOSSIER+".SPACKD"       [SPD]
Local File =[F:ADS]DOSSIER+".SORDER"       [SOH]
Local File =[F:ADS]DOSSIER+".SORDERP"      [SOP]
Local File =[F:ADS]DOSSIER+".SORDERQ"      [SOQ]

Local Mask =[F:ADS]DOSSIER+".SDH0"    [SDH0]
Local Mask =[F:ADS]DOSSIER+".SDH1"    [SDH1]
Local Mask =[F:ADS]DOSSIER+".SDH2"    [SDH2]
Local Mask =[F:ADS]DOSSIER+".SDH3"    [SDH3]
Local Mask =[F:ADS]DOSSIER+".SFITRF"  [SFIT]
Local Mask =[F:ADS]DOSSIER+".SFITRF"  [SFI2]

Local Shortint I, STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)
Local Char     S_SALFCY : Raz S_SALFCY
Local Integer  WVCRTYP, WRET
Local Char     WVCRNUM, WITMREF, WFICD(3), WFICD1(3), WFICE(3)
Local Decimal  WMNTCALC, WMONT

$B_AP_SDH
If  STOP=1
    CRITERE = 'SDHNUM>"'+CLE1+'"'
    STOP = 0
Else
    CRITERE = "1=1"
Endif

# Pour tester
#CRITERE = 'find(SDHNUM,"LIV-08ASN-0000748")'
#CRITERE = 'find(SDHNUM,"LIV-08ASN-0000954")'
#CRITERE = 'find(SDHNUM,"LIV-08ASN-0000756","LIV-08ASN-0001095")'
#CRITERE = 'find(SDHNUM,"LIV-08ASN-0001095")'
#CRITERE = 'find(SDHNUM,"LIV-09ASN-0001177")'

Raz COMPTEUR

Trbegin [SDH],[SDD]
  For [SDH] SDH0 Where evalue(CRITERE)
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:SDH]SALFCY) From TRTX3CPT
      If dim([F:SDH]DIE)>0 & [F:SDH]DIE(0)=""
          For I=1 To max(GNBDIE,GOPTCANA)
              [F:SDH]DIE(I-1)=GDIE(I)
          Next I
      Endif
      # On essaie de ne pas l'appeler à chaque fois
      If S_SALFCY<>[F:SDH]SALFCY Call GLOBVAR([F:SDH]SALFCY) From WWGLOBVEN : S_SALFCY=[F:SDH]SALFCY : Endif

      [F:SDH]CPY=GSOCIETE
      If len([F:SDH]EECNAT)>2 & left$([F:SDH]EECNAT,1)="0" : [F:SDH]EECNAT=right$([F:SDH]EECNAT,2) : Endif
      # Initialisation ds le tableau des éléments de facturation
      # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
      For WI=0 To dim([F:SDH]INVDTA)-1
          If [F:SDH]INVDTA(WI)<>0
              [F:SDH]INVDTATYP(WI)=1
              WJ=find([F:SDH]INVDTA(WI),WSFINUM(0..999))
              If WJ>0 & WSFIAMTCOD(WJ-1)=1 [F:SDH]INVDTATYP(WI)=3 Endif
          Endif
      Next
      # Renseignement des unités de répartition
      [F:SDH]DSPWEU=GSALDSPWEU
      [F:SDH]DSPVOU=GSALDSPVOU
      Raz [F:SDH]DSPTOTQTY, [F:SDH]DSPTOTWEI, [F:SDH]DSPTOTVOL
      # Pour les livraisons non validées et les livraisons validées non facturées :
      # Valorisation pour alimentation des tables SVCRFOOT et SVCRVAT
#      If ([F:SDH]CFMFLG=1 | ([F:SDH]CFMFLG=2 & [F:SDH]INVFLG=1)
      If [F:SDH]INVFLG=1
          # Valorisation
          #--- entete
          Raz [M:SDH0], [M:SDH1], [M:SDH2], [M:SDH3]
          [M:SDH0]=[F:SDH]
          [M:SDH1]=[F:SDH]
          # Pour l'alim du tableau des éléments voir s'il faut appeler SAISFOOT
          [M:SDH2]=[F:SDH]
          [M:SDH3]=[F:SDH]
          nolign=0
          For [SDD] SDD0 Where SDHNUM=[F:SDH]SDHNUM
              If nolign>=dim([M:SDH1]UPDFLG) Break Endif        : # Bug 69648
              nolign += 1
              [M:SDH1]=[F:SDD]
              WFICD="SDD" : WFICD1="SDD" : WFICE="SDH" : Gosub ALIM_FICD
              [M:SDH1]VAT1(nolign-1)    = [F:SDD]VAT(0)
              [M:SDH1]VAT2(nolign-1)    = [F:SDD]VAT(1)
              [M:SDH1]VAT3(nolign-1)    = [F:SDD]VAT(2)
              [M:SDH1]VACITM1(nolign-1) = [F:SDD]VACITM(0)
              [M:SDH1]VACITM2(nolign-1) = [F:SDD]VACITM(1)
              [M:SDH1]VACITM3(nolign-1) = [F:SDD]VACITM(2)
              [M:SDH1]NBLIG+=1
              Rewrite [SDD]
              If fstat
                  Call ECR_TRACE("File SDELIVERYD"-[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)+", Error ="-num$(fstat),1) From GESECRAN
              Endif
          Next
          # Bug 69648
          If nolign>=dim([M:SDH1]UPDFLG)
              Call ECR_TRACE("File SDELIVERY"-[F:SDH]SDHNUM-":"-mess (26,100,1)-mess(224,139,1)-":"-"SDH",1) From GESECRAN
          Else
          # Bug 69648
              [M:SIH0]ORICLC="GESSDHF"
              #Call CHARG_SIHX From TRTVENFACC : # Bug 70931
              Gosub CHARG_TABLEAUX  From TRTVENFACC
              If [M:SIH4]NBLIG>0
                 Gosub CAL_FACTURE     From TRTVENFACC
              Endif
              #-- création des enr dans les tables SVCRVAT et SVCRFOOT à partir de l'écran [M:SIHV]
              WVCRTYP=2 : WVCRNUM=[F:SDH]SDHNUM
              # Faut-il systématiquement supprimer
              Delete [SVF] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
#              If fstat=1
#                  GOK=-1 : GLOCK="$SVCRFOOT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
#              Endif
              Delete [SVV] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
#              If fstat=1
#                  GOK=-1 : GLOCK="$SVCRVAT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
#              Endif
              Gosub UPD_SVF_SIHV : Gosub UPD_SVV_SIHV
              [F:SDH]DLVINVNOT=[M:SIHV]INVNOT
              [F:SDH]DLVINVATI=[M:SIHV]INVATI
              [F:SDH]DLVINVNOTL=[M:SIHV]INVNOTRPT
              [F:SDH]DLVINVATIL=[M:SIHV]INVATIRPT
#              Call ECR_TRACE("SDELIVERY : "-[F:SDH]SDHNUM,1) From GESECRAN
          Endif :  # Bug 69648
      Else
          For [SDD] SDD0 Where SDHNUM=[F:SDH]SDHNUM
              WFICD="SDD" : WFICD1="SDD" : WFICE="SDH" : Gosub ALIM_FICD
              Rewrite [SDD]
              If fstat
                 Call ECR_TRACE("File SDELIVERYD"-[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)+", Error ="-num$(fstat),1) From GESECRAN
              Endif
          Next
      Endif

      #Gbn-Fq76355
      If [F:SDH]CUR<>"" & GLOCALDEV<>""
       # Alimentation des montants en devise société
       Call COURMNT([F:SDH]CUR,GLOCALDEV,GLOCALDEV,[F:SDH]CHGTYP,[F:SDH]DLVDAT,1,
&                   [F:SDH]DLVNOT,[F:SDH]DLVNOTL,[F:SDH]CHGRAT,WRET) From TRTDEV
       If WRET <> 0 Then
         # FGR 12/01/2010 : X3SUIVI61184
          Call ECR_TRACE("     1-File SDELIVERY"-[F:SDH]SDHNUM+", Error ="-num$(WRET)-[F:SDH]CUR-"/"-GLOCALDEV,-1) From GESECRAN
       Endif
       Call COURMNT([F:SDH]CUR,GLOCALDEV,GLOCALDEV,[F:SDH]CHGTYP,[F:SDH]DLVDAT,1,
&                   [F:SDH]DLVATI,[F:SDH]DLVATIL,[F:SDH]CHGRAT,WRET) From TRTDEV
       If WRET <> 0 Then
         # FGR 12/01/2010 : X3SUIVI61184
          Call ECR_TRACE("     2-File SDELIVERY"-[F:SDH]SDHNUM+", Error ="-num$(WRET)-[F:SDH]CUR-"/"-GLOCALDEV,-1) From GESECRAN
       Endif
      Endif

      # ACA Gestion des adresses +BPAINV
      Read [BPC]BPC0=[F:SDH]BPCINV
      If fstat Raz [F:BPC] Endif
#     [F:SDH]BPAINV=[F:BPC]BPAINV
      If [F:SDH]BPCINV=[F:BPC]BPCINV
          [F:SDH]BPAINV=[F:BPC]BPAINV
      Else
          Read [BPR]BPR0=[F:SDH]BPCINV
          If fstat Raz [F:BPR] Endif
          [F:SDH]BPAINV=[F:BPR]BPAADD
      Endif

      Rewrite [SDH]
      If fstat
          Call ECR_TRACE("File SDELIVERY"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
#      Update [SDD] Where SDHNUM=[F:SDH]SDHNUM With CPY=[F:SDH]CPY
#      If fstat
#         Call ECR_TRACE("File SDELIVERYD"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
#      Endif

      If [F:SDH]PACFLG=2                                       : # livraison colisée
          Update [SPH] Where VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM With CPY=[F:SDH]CPY
          If fstat
             Call ECR_TRACE("File SPACK - of delivery"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
          Endif
          Update [SPD] Where VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM With CPY=[F:SDH]CPY
          If fstat
             Call ECR_TRACE("File SPACKD - of delivery"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
          Endif
      Endif

      NBENR+=1
      COMPTEUR+=1
      If COMPTEUR>GMAXUPDTRS CLE1=[F:SDH]SDHNUM : STOP=1 : Break : Endif
  Next
Commit

If STOP Goto B_AP_SDH : Endif

Close Local File [SDH], [SDD], [SPH], [SPD]

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN

End


#########################################################################
## M.a.j. de SORDER  SORDERP  SORDERQ  SORDERC : Commandes
## M.a.j SORDER  : Nouveaux champs :
## - CPY        : Société
## - ORDNOTL    : Mt lignes HT (soc)
## - ORDATIL    : Mt lignes TTC (soc)
## - ORDINVNOTL : Valorisation HT soc
## - ORDINVATIL : Valorisation TTC soc
## - INVDTATYP  : Type de valeur
## - EECICT     : Incoterm
## - EECLOC     : Lieu transport CEE
## - DIE        : Code Axe
## - DSPTOTQTY  : Cumul quantité
## - DSPTOTWEI  : Cumul poids
## - DSPTOTVOL  : Cumul volume
## - DSPWEU     : Unité Poids
## - DSPVOU     : Unité Volume
## - BPAORD     : Code adresse commande
## - BPAINV     : Code adresse facture
## - BPAPYR     : Code adresse payeur
## M.a.j SORDERP : Nouveaux champs :
## - CPY        : Société
## M.a.j SORDERQ : Nouveaux champs :
## - CPY        : Société
## - DSPLINFLG  : Flag répartition
## - DSPLINWEI  : Poids  ligne
## - DSPLINVOL  : Volume ligne
## - DSPWEU     : Unité Poids
## - DSPVOU     : Unité Volume
## M.a.j SORDERC : Nouveaux champs :
## - CPY        : Société
## - VACBPR     : Régime de taxe
## - BPIEECNUM  : Identification CEE
## - EECICT     : Incoterm
## - EECLOC     : Lieu transport CEE
#########################################################################
#########################################################################
## Cette moulinette doit être exécutée après maj
## --> Car elle nécessite des nouveaux champs de l'écran SIHV
##     La nvelle structure des écrans n'existe dans le dossier fille qu'à ce moment là
#########################################################################
Subprog AP_SOH
If filinfo(filpath("FIL","SORDER","fde",[F:ADS]DOSSIER),0)<=0  : End : Endif
If filinfo(filpath("FIL","SORDERP","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","SORDERQ","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","SORDERC","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TIME("DOSMAJ30 Sales Order Process : Update SORDER-Q-P-C") From DOSSUB

Local File =[F:ADS]DOSSIER+".SORDER"    [SOH]
Local File =[F:ADS]DOSSIER+".SORDERP"   [SOP]
Local File =[F:ADS]DOSSIER+".SORDERQ"   [SOQ]
Local File =[F:ADS]DOSSIER+".SORDERC"   [SOC]

Local File =[F:ADS]DOSSIER+".BPCUSTOMER"   [BPC]

Local Mask =[F:ADS]DOSSIER+".SOH0"    [SOH0]
Local Mask =[F:ADS]DOSSIER+".SOH1"    [SOH1]
Local Mask =[F:ADS]DOSSIER+".SOH2"    [SOH2]
Local Mask =[F:ADS]DOSSIER+".SOH3"    [SOH3]
Local Mask =[F:ADS]DOSSIER+".SOH4"    [SOH4]

Local Shortint STOP, I
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)
Local Char     S_SALFCY : Raz S_SALFCY
Local Integer  WVCRTYP, WRET
Local Char     WVCRNUM, WITMREF, WFICD(3), WFICD1(3), WFICE(3)
Local Decimal  WMNTCALC, WMONT

$B_AP_SOH
If  STOP=1
    CRITERE = 'SOHNUM>"'+CLE1+'"'
    STOP = 0
Else
    CRITERE = "1=1"
Endif
Raz COMPTEUR

# Pour tester
#CRITERE = 'find(SOHNUM,"CDE-2005-0421", "CDE-2006-0148","CDE-2006-0205","CDE-2006-0207")'
#CRITERE = 'find(SOHNUM,"OUV-2000-0017")'

Trbegin [SOH],[SOQ],[SOP],[SOC]
  For [SOH] SOH0 Where evalue(CRITERE)
     Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:SOH]SALFCY) From TRTX3CPT
     If dim([F:SOH]DIE)>0 & [F:SOH]DIE(0)=""
         For I=1 To max(GNBDIE,GOPTCANA)
             [F:SOH]DIE(I-1)=GDIE(I)
         Next I
     Endif
     # On essaie de ne pas l'appeler à chaque fois
     If S_SALFCY<>[F:SOH]SALFCY Call GLOBVAR([F:SOH]SALFCY) From WWGLOBVEN : S_SALFCY=[F:SOH]SALFCY : Endif

     If dim([F:SOH]APPFLG)>0 & [F:SOH]APPFLG=0 [F:SOH]APPFLG=4 Endif : # Init du flag signée à 4 : Pas de signature
     [F:SOH]CPY=GSOCIETE
     If [F:SOH]SOHCAT<>4 & ([F:SOH]EECICT="" | (GACTDEB=2 & [F:SOH]EECLOC=0))
         # Si ce n'est pas une cde ouverte, alimentation incoterm et lieu de transport CEE
         # Si c'est une cde ouverte, l'alimentation se fera dans SORDERC
         If [F:BPD]BPCNUM<>[F:SOH]BPCORD | [F:BPD]BPAADD<>[F:SOH]BPAADD
             Read [F:BPD]BPD0 = [F:SOH]BPCORD;[F:SOH]BPAADD : If fstat Raz [BPD] Endif
         Endif
         If [F:SOH]EECICT="" [F:SOH]EECICT=[F:BPD]EECICT Endif
         If GACTDEB=2 & [F:SOH]EECLOC=0 [F:SOH]EECLOC=[F:BPD]EECLOC Endif
     Endif
     # Initialisation ds le tableau des éléments de facturation
     # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
     For WI=0 To dim([F:SOH]INVDTA)-1
         If [F:SOH]INVDTA(WI)<>0
             [F:SOH]INVDTATYP(WI)=1
             WJ=find([F:SOH]INVDTA(WI),WSFINUM(0..999))
             If WJ>0 & WSFIAMTCOD(WJ-1)=1 [F:SOH]INVDTATYP(WI)=3 Endif
         Endif
     Next
     # Renseignement des unités de répartition
     [F:SOH]DSPWEU=GSALDSPWEU
     [F:SOH]DSPVOU=GSALDSPVOU
     Raz [F:SOH]DSPTOTQTY, [F:SOH]DSPTOTWEI, [F:SOH]DSPTOTVOL
     # Pour les commande non soldées :
     # Valorisation pour alimentation des tables SVCRFOOT et SVCRVAT
     If ([F:SOH]ORDSTA<>2 & [F:SOH]SOHCAT<>4)
         # Valorisation
         #--- entete
         Raz [M:SOH0], [M:SOH1], [M:SOH2], [M:SOH3], [M:SOH4]
         [M:SOH0]=[F:SOH]
         [M:SOH1]=[F:SOH]
         # Pour l'alim du tableau des éléments voir s'il faut appeler SAISFOOT
         [M:SOH2]=[F:SOH]
         [M:SOH3]=[F:SOH]
         nolign=0
         For [SOP] SOP0 Where SOHNUM=[F:SOH]SOHNUM
             Read [SOQ]SOQ0=[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ
             If fstat
                 Call ECR_TRACE("File SORDERQ"-[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
             Else
                 If nolign>=dim([M:SOH4]UPDFLG) Break Endif        : # Bug 69648
                 nolign += 1
                 [M:SOH4]=[F:SOP]
                 [M:SOH4]=[F:SOQ]
                 [M:SOH4]VAT1(nolign-1)    = [F:SOP]VAT(0)
                 [M:SOH4]VAT2(nolign-1)    = [F:SOP]VAT(1)
                 [M:SOH4]VAT3(nolign-1)    = [F:SOP]VAT(2)
                 [M:SOH4]VACITM1(nolign-1) = [F:SOP]VACITM(0)
                 [M:SOH4]VACITM2(nolign-1) = [F:SOP]VACITM(1)
                 [M:SOH4]VACITM3(nolign-1) = [F:SOP]VACITM(2)
                 [M:SOH4]NBLIG+=1
                 [F:SOP]CPY=[F:SOH]CPY
                 Rewrite [SOP]
                 If fstat
                     Call ECR_TRACE("File SORDERP"-[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
                 Endif
                 WFICD="SOQ" : WFICD1="SOP" : WFICE="SOH" : Gosub ALIM_FICD
                 Rewrite [SOQ]
                 If fstat
                     Call ECR_TRACE("File SORDERQ"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOSEQ)+", Error ="-num$(fstat),1) From GESECRAN
                 Endif
             Endif
         Next
         # Bug 69648
         If nolign>=dim([M:SOH4]UPDFLG)
             Call ECR_TRACE("File SORDER"-[F:SOH]SOHNUM-":"-mess (26,100,1)-mess(224,139,1)-":"-"SOH",1) From GESECRAN
         Else
         # Bug 69648
             [M:SIH0]ORICLC="GESSOH"
             #Call CHARG_SIHX From TRTVENFACC : # Bug 70931
             Gosub CHARG_TABLEAUX  From TRTVENFACC
             If [M:SIH4]NBLIG>0
                 Gosub CAL_FACTURE     From TRTVENFACC
             Endif
             #-- création des enr dans les tables SVCRVAT et SVCRFOOT à partir de l'écran [M:SIHV]
             WVCRTYP=20 : WVCRNUM=[F:SOH]SOHNUM
             # Faut-il systématiquement supprimer
             Delete [SVF] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
#                 If fstat=1
#                     GOK=-1 : GLOCK="$SVCRFOOT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
#                 Endif
             Delete [SVV] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
#                 If fstat=1
#                     GOK=-1 : GLOCK="$SVCRVAT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
#                 Endif
             Gosub UPD_SVF_SIHV : Gosub UPD_SVV_SIHV
             [F:SOH]ORDINVNOT =[M:SIHV]INVNOT
             [F:SOH]ORDINVATI =[M:SIHV]INVATI
             [F:SOH]ORDINVNOTL=[M:SIHV]INVNOTRPT
             [F:SOH]ORDINVATIL=[M:SIHV]INVATIRPT
#             Call ECR_TRACE("SORDER : "-[F:SOH]SOHNUM,1) From GESECRAN
         Endif :  # Bug 69648
     Elsif [F:SOH]SOHCAT<>4
#         Update [SOQ] Where SOHNUM=[F:SOH]SOHNUM With CPY=[F:SOH]CPY
#         If fstat
#             Call ECR_TRACE("File SORDERQ"-[F:SOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
#         Endif
         For [SOP] SOP0 Where SOHNUM=[F:SOH]SOHNUM
             Read [SOQ]SOQ0=[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ
             If fstat
                 Call ECR_TRACE("File SORDERQ"-[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
             Else
                 [F:SOP]CPY=[F:SOH]CPY
                 Rewrite [SOP]
                 If fstat
                   Call ECR_TRACE("File SORDERP"-[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
                 Endif
                 WFICD="SOQ" : WFICD1="SOP" : WFICE="SOH" : Gosub ALIM_FICD
                 Rewrite [SOQ]
                 If fstat
                     Call ECR_TRACE("File SORDERQ"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)+", Error ="-num$(fstat),1) From GESECRAN
                 Endif
             Endif
         Next
     Endif

     #Gbn-Fq76355
     If [F:SOH]CUR<>"" & GLOCALDEV<>""
      # Alimentation des montants en devise société
      Call COURMNT([F:SOH]CUR,GLOCALDEV,GLOCALDEV,[F:SOH]CHGTYP,[F:SOH]ORDDAT,1,
&                  [F:SOH]ORDNOT,[F:SOH]ORDNOTL,[F:SOH]CHGRAT,WRET) From TRTDEV
      If WRET <> 0 Then
         # FGR 12/01/2010 : X3SUIVI61184
         Call ECR_TRACE("     1-File SORDER"-[F:SOH]SOHNUM+", Error ="-num$(WRET)-[F:SOH]CUR-"/"-GLOCALDEV,-1) From GESECRAN
      Endif
      Call COURMNT([F:SOH]CUR,GLOCALDEV,GLOCALDEV,[F:SOH]CHGTYP,[F:SOH]ORDDAT,1,
&                  [F:SOH]ORDATI,[F:SOH]ORDATIL,[F:SOH]CHGRAT,WRET) From TRTDEV
      If WRET <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184
        Call ECR_TRACE("     2-File SORDER"-[F:SOH]SOHNUM+", Error ="-num$(WRET)-[F:SOH]CUR-"/"-GLOCALDEV,-1) From GESECRAN
      Endif
     Endif

     # ACA - Gestion des adresses +BPAORD, +BPAINV, +BPAPYR
     Read [BPC]BPC0=[F:SOH]BPCORD
     If fstat Raz [F:BPC] Endif
     [F:SOH]BPAORD=[F:BPC]BPAADD
#     [F:SOH]BPAPYR=[F:BPC]BPAPYR
     If [F:SOH]BPCPYR=[F:BPC]BPCPYR
         [F:SOH]BPAPYR=[F:BPC]BPAPYR
     Else
         Read [BPR]BPR0=[F:SOH]BPCPYR
         If fstat Raz [F:BPR] Endif
         [F:SOH]BPAPYR=[F:BPR]BPAADD
     Endif
#     [F:SOH]BPAINV=[F:BPC]BPAINV
     If [F:SOH]BPCINV=[F:BPC]BPCINV
         [F:SOH]BPAINV=[F:BPC]BPAINV
     Else
         Read [BPR]BPR0=[F:SOH]BPCINV
         If fstat Raz [F:BPR] Endif
         [F:SOH]BPAINV=[F:BPR]BPAADD
     Endif

     Rewrite [SOH]
     If fstat
         Call ECR_TRACE("File SORDER"-[F:SOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
     Endif
     #-----
#         Update [SOP] Where SOHNUM=[F:SOH]SOHNUM With CPY=[F:SOH]CPY
#         If fstat
#            Call ECR_TRACE("File SORDERP"-[F:SOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
#         Endif
     If [F:SOH]SOHCAT=4
         #-----
         For [SOC] SOC0 Where SOHNUM=[F:SOH]SOHNUM
             [F:SOC]CPY   =[F:SOH]CPY
             [F:SOC]VACBPR=[F:SOH]VACBPR
             If [F:SOC]EECICT="" | (GACTDEB=2 & [F:SOC]EECLOC=0)
                 # --- Alimentation incoterm, lieu de transport CEE
                 If [F:BPD]BPCNUM<>[F:SOC]BPCORD | [F:BPD]BPAADD<>[F:SOC]BPAADD
                     Read [F:BPD]BPD0 = [F:SOC]BPCORD;[F:SOC]BPAADD : If fstat Raz [BPD] Endif
                 Endif
                 If [F:SOC]EECICT="" [F:SOC]EECICT=[F:BPD]EECICT Endif
                 If GACTDEB=2 & [F:SOC]EECLOC=0 [F:SOC]EECLOC=[F:BPD]EECLOC Endif
             Endif
             If GACTDEB=2 & [F:SOC]BPIEECNUM=""
                 # --- Alimentation n° d'identification CEE
                 If [F:BPR]BPRNUM<>[F:SOH]BPCINV
                     Read [F:BPR]BPR0 = [F:SOH]BPCINV : If fstat Raz [BPR] Endif
                 Endif
                 [F:SOC]BPIEECNUM=[F:BPR]EECNUM
             Endif
             Rewrite [SOC]
             If fstat
                 Call ECR_TRACE("File SORDERC"-[F:SOC]SOHNUM-num$([F:SOC]SOPLIN)+", Error ="-num$(fstat),1) From GESECRAN
             Endif
         Next
         Update [SOP] Where SOHNUM=[F:SOH]SOHNUM With CPY=[F:SOH]CPY
         If fstat
             Call ECR_TRACE("File SORDERP"-[F:SOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
         Endif
         Update [SOQ] Where SOHNUM=[F:SOH]SOHNUM With CPY=[F:SOH]CPY
         If fstat
             Call ECR_TRACE("File SORDERQ"-[F:SOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
         Endif
             #-----
#            Update [SOC] Where SOHNUM=[F:SOH]SOHNUM With CPY=[F:SOH]CPY, VACBPR=[F:SOH]VACBPR, EECICT=[F:SOH]EECICT,
#&                                                        EECLOC=[F:SOH]EECLOC, BPIEECNUM=[F:SOH]BPIEECNUM,
#            If fstat
#               Call ECR_TRACE("File SORDERC"-[F:SOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
#            Endif
     Endif

     NBENR+=1
     COMPTEUR+=1
     If COMPTEUR>GMAXUPDTRS CLE1=[F:SOH]SOHNUM : STOP=1 : Break : Endif
  Next
Commit

If STOP Goto B_AP_SOH : Endif

Close Local File [SOH], [SOQ], [SOP], [SOC]

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN

End

#########################################################################
## M.a.j. de SQUOTE  SQUOTED : Devis
## M.a.j SQUOTE  : Nouveaux champs :
## - CPY        : Société
## - BPIEECNUM  : Identification CEE
## - QUONOTL    : Mt lignes HT (soc)
## - QUOATIL    : Mt lignes TTC (soc)
## - QUOINVNOTL : Valorisation HT soc
## - QUOINVATIL : Valorisation TTC soc
## - INVDTATYP  : Type de valeur
## - EECICT     : Incoterm
## - EECLOC     : Lieu transport CEE
## - DIE        : Code Axe
## - DSPTOTQTY  : Cumul quantité
## - DSPTOTWEI  : Cumul poids
## - DSPTOTVOL  : Cumul volume
## - DSPWEU     : Unité Poids
## - DSPVOU     : Unité Volume
## - BPAORD     : Code adresse commande
## M.a.j SQUOTED : Nouveaux champs :
## - CPY        : Société
## - DSPLINFLG  : Flag répartition
## - DSPLINWEI  : Poids  ligne
## - DSPLINVOL  : Volume ligne
## - DSPWEU     : Unité Poids
## - DSPVOU     : Unité Volume
#########################################################################
#########################################################################
## Cette moulinette doit être exécutée après maj
## --> Car elle nécessite des nouveaux champs de l'écran SIHV
##     La nvelle structure des écrans n'existe dans le dossier fille qu'à ce moment là
#########################################################################
Subprog AP_SQH
If filinfo(filpath("FIL","SQUOTE","fde",[F:ADS]DOSSIER),0)<=0  : End : Endif
If filinfo(filpath("FIL","SQUOTED","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TIME("DOSMAJ30 Sales Quote Process : Update SQUOTE-D") From DOSSUB

Local File =[F:ADS]DOSSIER+".SQUOTE"  [SQH]
Local File =[F:ADS]DOSSIER+".SQUOTED" [SQD]

Local Mask =[F:ADS]DOSSIER+".SQH0"    [SQH0]
Local Mask =[F:ADS]DOSSIER+".SQH1"    [SQH1]
Local Mask =[F:ADS]DOSSIER+".SQH2"    [SQH2]
Local Mask =[F:ADS]DOSSIER+".SQH3"    [SQH3]

Local Shortint I, STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)
Local Char     S_SALFCY : Raz S_SALFCY
Local Integer  WVCRTYP, WRET
Local Char     WVCRNUM, WITMREF, WFICD(3), WFICD1(3), WFICE(3)
Local Decimal  WMNTCALC, WMONT

$B_AP_SQH
If  STOP=1
    CRITERE = 'SQHNUM>"'+CLE1+'"'
    STOP = 0
Else
    CRITERE = "1=1"
Endif
Raz COMPTEUR

# Pour tester
#CRITERE = 'find(SQHNUM,"DEV-2004-0079","DEV-2006-0039","DEV-2006-0055")'

Trbegin [SQH],[SQD]
  For [SQH] SQH0 Where evalue(CRITERE)
     #[F:SQH]CPY=GSOCIETE : # Bug 74353

     If dim([F:SQH]APPFLG)>0 & [F:SQH]APPFLG=0 [F:SQH]APPFLG=4 Endif : # Init du flag signée à 4 : Pas de signature
     Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:SQH]SALFCY) From TRTX3CPT
     [F:SQH]CPY=GSOCIETE  : # Bug 74353

     If dim([F:SQH]DIE)>0 & [F:SQH]DIE(0)=""
         For I=1 To max(GNBDIE,GOPTCANA)
             [F:SQH]DIE(I-1)=GDIE(I)
         Next I
     Endif
     # On essaie de ne pas l'appeler à chaque fois
     If S_SALFCY<>[F:SQH]SALFCY Call GLOBVAR([F:SQH]SALFCY) From WWGLOBVEN : S_SALFCY=[F:SQH]SALFCY : Endif
     If [F:SQH]EECICT="" | (GACTDEB=2 & [F:SQH]EECLOC=0)
         # --- Alimentation incoterm, lieu de transport CEE
         If [F:BPD]BPCNUM<>[F:SQH]BPCORD | [F:BPD]BPAADD<>[F:SQH]BPAADD
             Read [F:BPD]BPD0 = [F:SQH]BPCORD;[F:SQH]BPAADD : If fstat Raz [BPD] Endif
         Endif
         If [F:SQH]EECICT="" [F:SQH]EECICT=[F:BPD]EECICT Endif
         If GACTDEB=2 & [F:SQH]EECLOC=0 [F:SQH]EECLOC=[F:BPD]EECLOC Endif
     Endif
     If GACTDEB=2 & [F:SQH]BPIEECNUM=""
         # --- Alimentation n° d'identification CEE
         If [F:BPC]BPCNUM<>[F:SQH]BPCORD
             Read [F:BPC]BPC0 = [F:SQH]BPCORD : If fstat Raz [BPC] Endif
         Endif
         If [F:BPR]BPRNUM<>[F:BPC]BPCINV
             Read [F:BPR]BPR0 = [F:BPC]BPCINV : If fstat Raz [BPR] Endif
         Endif
         [F:SQH]BPIEECNUM=[F:BPR]EECNUM
     Endif
     # Initialisation ds le tableau des éléments de facturation
     # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
     For WI=0 To dim([F:SQH]INVDTA)-1
         If [F:SQH]INVDTA(WI)<>0
             [F:SQH]INVDTATYP(WI)=1
             WJ=find([F:SQH]INVDTA(WI),WSFINUM(0..999))
             If WJ>0 & WSFIAMTCOD(WJ-1)=1 [F:SQH]INVDTATYP(WI)=3 Endif
         Endif
     Next
     # Renseignement des unités de répartition
     [F:SQH]DSPWEU=GSALDSPWEU
     [F:SQH]DSPVOU=GSALDSPVOU
     Raz [F:SQH]DSPTOTQTY, [F:SQH]DSPTOTWEI, [F:SQH]DSPTOTVOL

     # Pour les devis validés et partellement ou non commandés :
     # Valorisation pour alimentation des tables SVCRFOOT et SVCRVAT
     If ([F:SQH]VLYDAT=[0/0/0] | [F:SQH]VLYDAT >= date$) & [F:SQH]QUOSTA<3
         # Valorisation
         #--- entete
         Raz [M:SQH0], [M:SQH1], [M:SQH2], [M:SQH3]
         [M:SQH0]=[F:SQH]
         [M:SQH1]=[F:SQH]
         # Pour l'alim du tableau des éléments voir s'il faut appeler SAISFOOT
         [M:SQH2]=[F:SQH]
         [M:SQH3]=[F:SQH]
         nolign=0
         For [SQD] SQD0 Where SQHNUM=[F:SQH]SQHNUM
             If nolign>=dim([M:SQH2]UPDFLG) Break Endif        : # Bug 69648
             nolign += 1
             [M:SQH2]=[F:SQD]
             [M:SQH2]VAT1(nolign-1)    = [F:SQD]VAT(0)
             [M:SQH2]VAT2(nolign-1)    = [F:SQD]VAT(1)
             [M:SQH2]VAT3(nolign-1)    = [F:SQD]VAT(2)
             [M:SQH2]VACITM1(nolign-1) = [F:SQD]VACITM(0)
             [M:SQH2]VACITM2(nolign-1) = [F:SQD]VACITM(1)
             [M:SQH2]VACITM3(nolign-1) = [F:SQD]VACITM(2)
             [M:SQH2]NBLIG+=1
             WFICD="SQD" : WFICD1="SQD" : WFICE="SQH" : Gosub ALIM_FICD

             Rewrite [SQD]
             If fstat
               Call ECR_TRACE("File SQUOTED"-[F:SQD]SQHNUM-num$([F:SQD]SQDLIN)+", Error ="-num$(fstat),1) From GESECRAN
             Endif
         Next
         # Bug 69648
         If nolign>=dim([M:SQH2]UPDFLG)
             Call ECR_TRACE("File SQUOTE"-[F:SQH]SQHNUM-":"-mess (26,100,1)-mess(224,139,1)-":"-"SQH",1) From GESECRAN
         Else
         # Bug 69648
             [M:SIH0]ORICLC="GESSQH"
             #Call CHARG_SIHX From TRTVENFACC : # Bug 70931
             Gosub CHARG_TABLEAUX  From TRTVENFACC
             If [M:SIH4]NBLIG>0
                 Gosub CAL_FACTURE     From TRTVENFACC
             Endif
             #-- création des enr dans les tables SVCRVAT et SVCRFOOT à partir de l'écran [M:SIHV]
             WVCRTYP=1 : WVCRNUM=[F:SQH]SQHNUM
             # Faut-il systématiquement supprimer
             Delete [SVF] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
#                 If fstat=1
#                     GOK=-1 : GLOCK="$SVCRFOOT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
#                 Endif
             Delete [SVV] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
#                 If fstat=1
#                     GOK=-1 : GLOCK="$SVCRVAT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
#                 Endif
             Gosub UPD_SVF_SIHV : Gosub UPD_SVV_SIHV
             [F:SQH]QUOINVNOT =[M:SIHV]INVNOT
             [F:SQH]QUOINVATI =[M:SIHV]INVATI
             [F:SQH]QUOINVNOTL=[M:SIHV]INVNOTRPT
             [F:SQH]QUOINVATIL=[M:SIHV]INVATIRPT
#             Call ECR_TRACE("SQUOTE : "-[F:SQH]SQHNUM,1) From GESECRAN
         Endif :  # Bug 69648
     Else
         For [SQD] SQD0 Where SQHNUM=[F:SQH]SQHNUM
             WFICD="SQD" : WFICD1="SQD" : WFICE="SQH" : Gosub ALIM_FICD
             Rewrite [SQD]
             If fstat
               Call ECR_TRACE("File SQUOTED"-[F:SQD]SQHNUM-num$([F:SQD]SQDLIN)+", Error ="-num$(fstat),1) From GESECRAN
             Endif
         Next
#         Update [SQD] Where SQHNUM=[F:SQH]SQHNUM With CPY=[F:SQH]CPY
#         If fstat
#            Call ECR_TRACE("File SQUOTED"-[F:SQH]SQHNUM+", Error ="-num$(fstat),1) From GESECRAN
#         Endif
     Endif

     #Gbn-Fq76355
     If [F:SQH]CUR<>"" & GLOCALDEV<>""
      # Alimentation des montants en devise société
      Call COURMNT([F:SQH]CUR,GLOCALDEV,GLOCALDEV,[F:SQH]CHGTYP,[F:SQH]QUODAT,1,
&                  [F:SQH]QUONOT,[F:SQH]QUONOTL,[F:SQH]CHGRAT,WRET) From TRTDEV
      If WRET <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184
         Call ECR_TRACE("     1-File SQUOTE"-[F:SQH]SQHNUM+", Error ="-num$(WRET)-[F:SQH]CUR-"/"-GLOCALDEV,-1) From GESECRAN
      Endif
      Call COURMNT([F:SQH]CUR,GLOCALDEV,GLOCALDEV,[F:SQH]CHGTYP,[F:SQH]QUODAT,1,
&                  [F:SQH]QUOATI,[F:SQH]QUOATIL,[F:SQH]CHGRAT,WRET) From TRTDEV
      If WRET <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184
         Call ECR_TRACE("     2-File SQUOTE"-[F:SQH]SQHNUM+", Error ="-num$(WRET)-[F:SQH]CUR-"/"-GLOCALDEV,-1) From GESECRAN
      Endif
     Endif

     # ACA - Nouveau champ adresse : BPAORD
     Read [BPC]BPC0=[F:SQH]BPCORD
     If fstat Raz [F:BPC] Endif
     [F:SQH]BPAORD=[F:BPC]BPAADD

     Rewrite [SQH]
     If fstat
         Call ECR_TRACE("File SQUOTE"-[F:SQH]SQHNUM+", Error ="-num$(fstat),1) From GESECRAN
     Endif

     NBENR+=1
     COMPTEUR+=1
     If COMPTEUR>GMAXUPDTRS CLE1=[F:SQH]SQHNUM : STOP=1 : Break : Endif
  Next
Commit

If STOP Goto B_AP_SQH : Endif

Close Local File [SQH], [SQD]

Close Local Mask [M:SQH0], [M:SQH1], [M:SQH2], [M:SQH3]

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN

End
