#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe BPCUSTOMER
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER                     From BPCUSTOMER_METHODS
        When "AINIT"                   : Gosub AINIT                           From BPCUSTOMER_METHODS
      Endcase
    When "C_INVDTAAMT"
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER_C_INVDTAAMT         From BPCUSTOMER_METHODS
        When Default
      Endcase
    When "BPD"
      Case [L]AEVENT
        When "AREAD_AFTER"             :  Gosub AREAD_AFTER_BPD                From BPCUSTOMER_METHODS
        When Default
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "INIT_TSCCODADI"              : Gosub INIT_TSCCODADI                  From BPCUSTOMER_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
    When "LOCK_UNLOCK"                 : Gosub LOCK_UNLOCK                     From BPCUSTOMER_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "C_INVDTAAMT.INVDTA"          :  Gosub INVDTA                         From BPCUSTOMER_PROPERTIES
  Endcase
Return

