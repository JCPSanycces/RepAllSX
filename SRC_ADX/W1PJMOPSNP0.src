#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMOPSNP0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:49"
A_USER  = "DOC"
A_STAMP = "20181109230549"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMOPSNP0 [PJSNP0]
Gosub HORODAT
Local Inpbox "PJMOPSNP0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJSNP0] As [SIM_]
Grizo [PJSNP0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJSNP0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=90 : Y1(0)=1 : Y2(0)=3
Return

$ON_OPPNUM
Onevent AFTER_CHANGE Gosub AMM_OPPNUM From W1PJMOPSNP0
Onevent CONTROL Call C_OPPNUM(zc) From W1PJMOPSNP0
Onevent BEFORE_INPUT Call AS_OPPNUM(zc) From W1PJMOPSNP0
Return

Subprog IB_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action IBUPJMPIM
Call IBUPIM(VALEUR) From PJMSELECT
Gosub _AFF
End

Subprog AS_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(14664,GBOUT1) From OBJDIV
Call TEXTE(14664,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_OPPNUM(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_OPPNUM(zc) From W1PJMOPSNP0
Onkey 130 Titled GBOUT2 Call B2_OPPNUM(zc) From W1PJMOPSNP0
Onkey   2 Titled GBOUTS Call S_OPPNUM(zc) From W1PJMOPSNP0
Onkey 144 Titled GBOUTP Call P_OPPNUM(zc) From W1PJMOPSNP0
Onkey 146 Titled GBOUTA Call SA_OPPNUM(zc) From W1PJMOPSNP0
Gosub _AFF
End

Subprog C_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("PIM","A",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
Endif
Gosub _AFF
End

$AMM_OPPNUM
Call AM_OPPNUM(zc)
If !mkstat & GOBJET
 zoncou = "OPPNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_OPPNUM(VALEUR) From SUBPJMOPSNP
If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZOPPNUM)")>indice
 [M]OPPNUM(indice) = VALEUR
 Affzo ZOPPNUM(indice)
Endif
Gosub _AFF
End

Subprog S_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "PIM"
PARMSK(2) = "A"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMPIM
 Call TUNPIM(VALEUR) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMOPP
 Call TUNCRM(VALEUR) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PIM"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("PIM",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZOPPNUM
Onevent BEFORE_AREA Gosub AV_ZOPPNUM From W1PJMOPSNP0
Return

$AV_ZOPPNUM
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]OPPNUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_SNPCOD
Onevent CONTROL Call C_SNPCOD(zc) From W1PJMOPSNP0
Return

Subprog C_SNPCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "SNPCOD" : GZNUM = 1003359 : Endif
Endif
Gosub _AFF
End

$ON_DESAXX
Onevent INIT_AREA Call D_DESAXX(zc) From W1PJMOPSNP0
Onevent BEFORE_INPUT Call AS_DESAXX(zc) From W1PJMOPSNP0
Onevent CONTROL Call C_DESAXX(zc) From W1PJMOPSNP0
Return

Subprog IB_DESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DESAXX(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESAXX,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PJMOPSNPH","DESAXX",[M:PJSNP0]SNPCOD,"") From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DESAXX(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DESAXX(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DESAXX(zc) From W1PJMOPSNP0
Gosub _AFF
End

Subprog C_DESAXX(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
Gosub _AFF
End

Subprog B1_DESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DESAXX" : PROGSUB = "SUBPJMOPSNP" : PROGSPE = "SPEPJMOPSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMOPSNPH"
 PARMSK(2) = "DESAXX"
 PARMSK(3) = [M:PJSNP0]SNPCOD
 PARMSK(4) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DESAXX" : PROGSUB = "SUBPJMOPSNP" : PROGSPE = "SPEPJMOPSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_SNPCREDAT
Onevent BEFORE_AREA Gosub AV_SNPCREDAT From W1PJMOPSNP0
Return

$AV_SNPCREDAT
Chgfmt [M]SNPCREDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$CHG_STY
Return


