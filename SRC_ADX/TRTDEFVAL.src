#<AdxTL>@(#)6.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
#####################################################################################################################
#  Gestion des valeurs par défaut complexes                   Module CRM                            31 aout 2000    #
#####################################################################################################################
#                                                                                                                   #
#  SETDEFVAL     : Définit les valeurs par défaut pour un objet et un paramètre donné.                              #
#  GETDEFVAL     : Affecte les valeurs par défaut pour un objet et un paramètre donné.                              #
#  CLEANSCR      : Nettoie les écrans après chaque saisie d'une valeur par défaut.                                  #
#  CANCELDV      : Effectue les opérations nécessaire à l'abandon de la saisie des valeurs par défaut               #
#  UPDDEFVAL     : Réaffecte des valeurs par défaut en cas de modification de la zone paramètre.                    #
#                                                                                                                   #
#####################################################################################################################
#  Liste des différents objets gérés                                                                                #
#                                                                                                                   #
#  CON : Contrats de services                                                                                       #
#                                                                                                                   #
#####################################################################################################################
#Configuration des tableaux par objet :                                                                             #
#                                                                                                                   #
#  Objet CON : Contrats de services                                                                                 #
#                                                                                                                   #
#  PARAM   = Nature du contrat (CONTYP)                                                                             #
#  ALHX(0) = Base d'indexation (CONBASIDX)                                                                          #
#  DCBX(0) = Coefficient de fréquence de facturation
#  INTX(0) = Toutes compétences (EVRPBL)                                                                            #
#  INTX(1) = Tous produits (EVRMAC)                                                                                 #
#  INTX(2) = Fréquence de renouvellement (REWFRY)                                                                   #
#  INTX(3) = Base de fréquence de renouvellement (REWFRYBAS)                                                        #
#  INTX(4) = Renouvelable tacitement (CONREW)                                                                       #
#  INTX(5) = Fréquence de facturation (INVFRY)                                                                      #
#  INTX(6) = Base de fréquence de facturation (INVFRYBAS)                                                           #
#  INTX(7) = Préavis de facturation (INVLTI)                                                                        #
#  INTX(8) = Base de préavis de facturation (INVLTIBAS)                                                             #
#  INTX(9) = Délai de paiement (PAYLTI)                                                                             #
#  INTX(10) = Base de délai de paiement (PAYLTIBAS)                                                                 #
#  INTX(11) = Fréquence de réévaluation (RVAFRY)                                                                    #
#  INTX(12) = Base de fréquence de réévaluation (RVAFRYBAS)                                                         #
#  INTX(13) = Préavis de résiliation (RSILTI)                                                                       #
#  INTX(14) = Base préavis de résiliation (RSILTIBAS)                                                               #
#  INTX(15) = Intervention/site non bloquant (ITTFCY)                                                               #
#  INTX(16) = Délai d'intervention max non bloquant (ITTLTIMAX)                                                     #
#  INTX(17) = Base de délai d'intervention max non bloquant (BASEXXITT)                                             #
#  INTX(18) = Délai de résolution max non bloquant (SOLLTIMAX)                                                      #
#  INTX(19) = Base de Délai de résolution max non bloquant (BASEXXSOL)                                              #
#  INTX(20) = Intervention/site bloquant (ITTFCYX)                                                                  #
#  INTX(21) = Délai d'intervention max bloquant (ITTLTIMAXX)                                                        #
#  INTX(22) = Base de délai d'intervention max bloquant (BASEXXITTX)                                                #
#  INTX(23) = Délai de résolution max bloquant (SOLLTIMAXX)                                                         #
#  INTX(24) = Base de Délai de résolution non bloquant (BASEXXSOLX)                                                 #
#  INTX(25) = Durée d'intervention sur site pour des problèmes non bloquants (ITTDUR)                               #
#  INTX(26) = Base de durée d'intervention sur site pour des problèmes non bloquants (ITTDURBAS)                    #
#  INTX(27) = Durée d'intervention sur site pour des problèmes bloquants (ITTDURX)                                  #
#  INTX(28) = Base de durée d'intervention sur site pour des problèmes bloquants (ITTDURBASX)                       #
#                                                                                                                   #
#####################################################################################################################




################################################################################
#Programme de définitions des valeurs par défaut.                              #
################################################################################
Subprog SETDEFVAL(SZOBJ, SZPARAM)
Value Char SZOBJ
Value Char SZPARAM
If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif

#Traitement de l'objet Contrat de services
If SZOBJ = "CON"
        Call DEBTRANS From GLOCK
        Trbegin [DVA]
        Readlock [DVA] DVA0 = SZOBJ;SZPARAM
        #Il s'agit d'un nouvel enregistrement
        If fstat
            [F:DVA]OBC = SZOBJ
            [F:DVA]PARAM = SZPARAM
            [F:DVA]ALHX(0) = [M:CON4]CONBASIDX
            [F:DVA]INTX(0) = [M:CON1]EVRPBL
            [F:DVA]INTX(1) = [M:CON1]EVRMAC
            [F:DVA]INTX(2) = [M:CON4]REWFRY
            [F:DVA]INTX(3) = [M:CON4]REWFRYBAS
            [F:DVA]INTX(4) = [M:CON4]CONREW
            [F:DVA]INTX(5) = [M:CON4]INVFRY
            [F:DVA]INTX(6) = [M:CON4]INVFRYBAS
            [F:DVA]DCBX(0) = [M:CON4]INVFRYCOE
            [F:DVA]INTX(7) = [M:CON4]INVLTI
            [F:DVA]INTX(8) = [M:CON4]INVLTIBAS
            [F:DVA]INTX(9) = [M:CON4]PAYLTI
            [F:DVA]INTX(10) = [M:CON4]PAYLTIBAS
            [F:DVA]INTX(11) = [M:CON4]RVAFRY
            [F:DVA]INTX(12) = [M:CON4]RVAFRYBAS
            [F:DVA]INTX(13) = [M:CON4]RSILTI
            [F:DVA]INTX(14) = [M:CON4]RSILTIBAS
            [F:DVA]INTX(15) = [M:CON3]ITTFCY
            [F:DVA]INTX(16) = [M:CON3]ITTLTIMAX
            [F:DVA]INTX(17) = [M:CON3]BASEXXITT
            [F:DVA]INTX(18) = [M:CON3]SOLLTIMAX
            [F:DVA]INTX(19) = [M:CON3]BASEXXSOL
            [F:DVA]INTX(20) = [M:CON3]ITTFCYX
            [F:DVA]INTX(21) = [M:CON3]ITTLTIMAXX
            [F:DVA]INTX(22) = [M:CON3]BASEXXITTX
            [F:DVA]INTX(23) = [M:CON3]SOLLTIMAXX
            [F:DVA]INTX(24) = [M:CON3]BASEXXSOLX
            [F:DVA]INTX(25) = [M:CON3]ITTDUR
            [F:DVA]INTX(26) = [M:CON3]ITTDURBAS
            [F:DVA]INTX(27) = [M:CON3]ITTDURX
            [F:DVA]INTX(28) = [M:CON3]ITTDURBASX

            Write [DVA]
            If fstat
                 GMESSAGE = mess(100,141,1)  #Erreur création
                 GERR = 1
                 Unlock [DVA]
                 Rollback
                 Return
            Else
                Commit
                Unlock [DVA]
            Endif
       # Il s'agit d'une modification
       Else
            [F:DVA]OBC = SZOBJ
            [F:DVA]PARAM = SZPARAM
            [F:DVA]ALHX(0) = [M:CON4]CONBASIDX
            [F:DVA]INTX(0) = [M:CON1]EVRPBL
            [F:DVA]INTX(1) = [M:CON1]EVRMAC
            [F:DVA]INTX(2) = [M:CON4]REWFRY
            [F:DVA]INTX(3) = [M:CON4]REWFRYBAS
            [F:DVA]INTX(4) = [M:CON4]CONREW
            [F:DVA]INTX(5) = [M:CON4]INVFRY
            [F:DVA]INTX(6) = [M:CON4]INVFRYBAS
            [F:DVA]DCBX(0) = [M:CON4]INVFRYCOE
            [F:DVA]INTX(7) = [M:CON4]INVLTI
            [F:DVA]INTX(8) = [M:CON4]INVLTIBAS
            [F:DVA]INTX(9) = [M:CON4]PAYLTI
            [F:DVA]INTX(10) = [M:CON4]PAYLTIBAS
            [F:DVA]INTX(11) = [M:CON4]RVAFRY
            [F:DVA]INTX(12) = [M:CON4]RVAFRYBAS
            [F:DVA]INTX(13) = [M:CON4]RSILTI
            [F:DVA]INTX(14) = [M:CON4]RSILTIBAS
            [F:DVA]INTX(15) = [M:CON3]ITTFCY
            [F:DVA]INTX(16) = [M:CON3]ITTLTIMAX
            [F:DVA]INTX(17) = [M:CON3]BASEXXITT
            [F:DVA]INTX(18) = [M:CON3]SOLLTIMAX
            [F:DVA]INTX(19) = [M:CON3]BASEXXSOL
            [F:DVA]INTX(20) = [M:CON3]ITTFCYX
            [F:DVA]INTX(21) = [M:CON3]ITTLTIMAXX
            [F:DVA]INTX(22) = [M:CON3]BASEXXITTX
            [F:DVA]INTX(23) = [M:CON3]SOLLTIMAXX
            [F:DVA]INTX(24) = [M:CON3]BASEXXSOLX
            [F:DVA]INTX(25) = [M:CON3]ITTDUR
            [F:DVA]INTX(26) = [M:CON3]ITTDURBAS
            [F:DVA]INTX(27) = [M:CON3]ITTDURX
            [F:DVA]INTX(28) = [M:CON3]ITTDURBASX

            Rewrite [DVA]
            If fstat
               GMESSAGE = mess(101,141,1)  # Erreur modification
               GERR = 1
               Unlock [DVA]
               Rollback 
               End
            Else
               Commit
               Unlock [DVA]
            Endif
        Endif

    #Réactive les zones grisées
    Actzo [M:CON0]CONNUM
    Actzo [M:CON0]CPY
    Actzo [M:CON0]SALFCY
    Actzo [M:CON0]CUR
    Actzo [M:CON0]CONBPC
    Actzo [M:CON0]CONCCN
    Actzo [M:CON1]SALREP
    Actzo [M:CON1]20
    Actzo [M:CON1]CONAMT
    Actzo [M:CON1]CONCUR3
    Actzo [M:CON2]5
    Actzo [M:CON2]15
    Actzo [M:CON3]AMTPLY
    Actzo [M:CON3]CONCUR1
    Actzo [M:CON3]BASEXXAMT
    Actzo [M:CON3]AMTPLYX
    Actzo [M:CON3]CONCUR2
    Actzo [M:CON3]BASEXXAMTX
    Actzo [M:CON3]OTHCNI
    Actzo [M:CON4]SIUDAT
    Actzo [M:CON4]CONSTRDAT
    Actzo [M:CON4]CONENDDAT
    Actzo [M:CON4]LASVALIDX
    Actzo [M:CON4]LASIDXDAT
    Actzo [M:CON5]5
    Actzo [M:CON5]10
    Actzo [M:CON5]RSIFLG
    Actzo [M:CON5]RSIDAT

    #Réaffiche tous les écrans.
    Affzo [M:CON0]
    Affzo [M:CON1]
    Affzo [M:CON2]
    Affzo [M:CON3]
    Affzo [M:CON4]
    Affzo [M:CON5]
Endif
End


################################################################################
#Programme d'affectation des valeurs par défaut.                               #
################################################################################
Subprog GETDEFVAL(SZOBJ, SZPARAM)
Value Char SZOBJ
Value Char SZPARAM
If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif

#Traitement de l'objet Contrat de services
If SZOBJ = "CON"
    #Affiche les valeurs prédéfinies
    Read [DVA] DVA0 = SZOBJ;SZPARAM
    If fstat
        Raz [M:CON0]
        Raz [M:CON1]
        Raz [M:CON2]
        Raz [M:CON3]
        Raz [M:CON4]
        Raz [M:CON5]

        [M:CON1]CONTYP = SZPARAM
    Else
        [M:CON1]CONTYP = SZPARAM
        [M:CON4]CONBASIDX = [F:DVA]ALHX(0)
        [M:CON1]EVRPBL = [F:DVA]INTX(0)
        [M:CON1]EVRMAC = [F:DVA]INTX(1)
        [M:CON4]REWFRY = [F:DVA]INTX(2)
        [M:CON4]REWFRYBAS = [F:DVA]INTX(3)
        [M:CON4]CONREW = [F:DVA]INTX(4)
        [M:CON4]INVFRY = [F:DVA]INTX(5)
        [M:CON4]INVFRYBAS = [F:DVA]INTX(6)
        [M:CON4]INVFRYCOE = [F:DVA]DCBX(0)
        [M:CON4]INVLTI = [F:DVA]INTX(7)
        [M:CON4]INVLTIBAS = [F:DVA]INTX(8)
        [M:CON4]PAYLTI = [F:DVA]INTX(9)
        [M:CON4]PAYLTIBAS = [F:DVA]INTX(10)
        [M:CON4]RVAFRY = [F:DVA]INTX(11)
        [M:CON4]RVAFRYBAS = [F:DVA]INTX(12)
        [M:CON4]RSILTI = [F:DVA]INTX(13)
        [M:CON4]RSILTIBAS = [F:DVA]INTX(14)
        [M:CON3]ITTFCY = [F:DVA]INTX(15)
        [M:CON3]ITTLTIMAX = [F:DVA]INTX(16)
        [M:CON3]BASEXXITT = [F:DVA]INTX(17)
        [M:CON3]SOLLTIMAX = [F:DVA]INTX(18)
        [M:CON3]BASEXXSOL = [F:DVA]INTX(19)
        [M:CON3]ITTFCYX = [F:DVA]INTX(20)
        [M:CON3]ITTLTIMAXX = [F:DVA]INTX(21)
        [M:CON3]BASEXXITTX = [F:DVA]INTX(22)
        [M:CON3]SOLLTIMAXX = [F:DVA]INTX(23)
        [M:CON3]BASEXXSOLX = [F:DVA]INTX(24)
        [M:CON3]ITTDUR = [F:DVA]INTX(25)
        [M:CON3]ITTDURBAS = [F:DVA]INTX(26)
        [M:CON3]ITTDURX = [F:DVA]INTX(27)
        [M:CON3]ITTDURBASX = [F:DVA]INTX(28)
    Endif
    #Réaffiche tous les écrans.
    Affzo [M:CON0]
    Affzo [M:CON1]
    Affzo [M:CON2]
    Affzo [M:CON3]
    Affzo [M:CON4]
    Affzo [M:CON5]
Endif

End

###################################################################
# Programme de nettoyage des écrans
###################################################################
Subprog CLEANSCR(SZOBJ)
Value Char SZOBJ

If SZOBJ = "CON"
        #Vide les zones non affectables
        Raz [M:CON0]CONNUM
        Raz [M:CON0]CPY
        Raz [M:CON0]SALFCY
        Raz [M:CON0]CUR
        Raz [M:CON0]CONBPC
        Raz [M:CON0]CONCCN
        Raz [M:CON1]SALREP
        Raz [M:CON1]PBLGRPCOV
        Raz [M:CON1]NBLIG
        Raz [M:CON1]CONAMT
        Raz [M:CON1]CONCUR3
        Raz [M:CON2]NBLIG1
        Raz [M:CON2]COVTYP
        Raz [M:CON2]CONMACCOD
        Raz [M:CON2]MACDES
        Raz [M:CON2]SERNUM
        Raz [M:CON2]CONPURDAT
        Raz [M:CON2]NBLIG2
        Raz [M:CON2]CONTYPSVC
        Raz [M:CON2]CONMINCOV
        Raz [M:CON2]CONMAXCOV
        Raz [M:CON2]CONLNDAUZ
        Raz [M:CON3]AMTPLY
        Raz [M:CON3]CONCUR1
        Raz [M:CON3]BASEXXAMT
        Raz [M:CON3]AMTPLYX
        Raz [M:CON3]CONCUR2
        Raz [M:CON3]BASEXXAMTX
        Raz [M:CON3]OTHCNI
        Raz [M:CON4]SIUDAT
        Raz [M:CON4]CONSTRDAT
        Raz [M:CON4]CONENDDAT
        Raz [M:CON4]LASVALIDX
        Raz [M:CON4]LASIDXDAT
        Raz [M:CON5]NBPAY
        Raz [M:CON5]DUD
        Raz [M:CON5]TPA
        Raz [M:CON5]PAI
        Raz [M:CON5]NBREW
        Raz [M:CON5]REWSTR
        Raz [M:CON5]REWEND
        Raz [M:CON5]RSIFLG
        Raz [M:CON5]RSIDAT
    
        #Réaffiche tous les écrans propres.
        Affzo [M:CON0]
        Affzo [M:CON1]
        Affzo [M:CON2]
        Affzo [M:CON3]
        Affzo [M:CON4]
        Affzo [M:CON5]
Endif

End

#######################################################################
# Programme d'annulation du mode de définition des valeurs par défaut
#######################################################################
Subprog CANCELDV(SZOBJ)
Value Char SZOBJ
    #Néttoie les écrans.
    Raz [M:CON0]
    Raz [M:CON1]
    Raz [M:CON2]
    Raz [M:CON3]
    Raz [M:CON4]
    Raz [M:CON5]

    #Réactive les zones grisées
    Actzo [M:CON0]CONNUM
    Actzo [M:CON0]CPY
    Actzo [M:CON0]SALFCY
    Actzo [M:CON0]CUR
    Actzo [M:CON0]CONBPC
    Actzo [M:CON0]CONCCN
    Actzo [M:CON1]SALREP
    Actzo [M:CON1]20

    Actzo [M:CON1]CONAMT
    Actzo [M:CON1]CONCUR3
    Actzo [M:CON2]5
    Actzo [M:CON2]15

    Actzo [M:CON3]AMTPLY
    Actzo [M:CON3]CONCUR1
    Actzo [M:CON3]BASEXXAMT
    Actzo [M:CON3]AMTPLYX
    Actzo [M:CON3]CONCUR2
    Actzo [M:CON3]BASEXXAMTX
    Actzo [M:CON3]OTHCNI
    Actzo [M:CON4]SIUDAT
    Actzo [M:CON4]CONSTRDAT
    Actzo [M:CON4]CONENDDAT
    Actzo [M:CON4]LASVALIDX
    Actzo [M:CON4]LASIDXDAT
    Actzo [M:CON5]5
    Actzo [M:CON5]10
    Actzo [M:CON5]RSIFLG
    Actzo [M:CON5]RSIDAT

    #Réaffiche tous les écrans propres.
    Affzo [M:CON0]
    Affzo [M:CON1]
    Affzo [M:CON2]
    Affzo [M:CON3]
    Affzo [M:CON4]
    Affzo [M:CON5]
End

#######################################################################
# Programme de réaffectation des paramètres en cas de modification de la zone paramètre
#######################################################################
Subprog UPDDEFVAL(SZOBJ, SZPARAM, IINDVMODE)
Value Char SZOBJ
Variable Char SZPARAM
Value Integer IINDVMODE

Local Integer OKREP
Local Char SZNEWCONTYP
SZNEWCONTYP = SZPARAM
OKREP = 0

#Traitement de l'objet Contrat de services
If SZOBJ = "CON"
    If IINDVMODE
        #Réaffectation des valeurs par défaut pour le nouveau type de contrat.
        Call GETDEFVAL("CON", SZNEWCONTYP)
    Else
        If GICONCREATION
            #Réaffectation des valeurs par défaut.
            Call GETDEFVAL("CON", SZNEWCONTYP)
        Else
            Call OUINON(mess(270, 196, 2), OKREP) From GESECRAN    
            If OKREP = 1
                #Réponse NON
                End
            Elsif OKREP = 2
                #Réponse OUI
                #Réaffectation des valeurs par défaut.
                Call GETDEFVAL("CON", SZNEWCONTYP)
            Endif
        Endif
    Endif
Endif
End
