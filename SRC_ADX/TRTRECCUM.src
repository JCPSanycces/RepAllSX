#<AdxTL>@(#)10.0.0.0 $Revision$
####################################################################################################################
# HCM V8 :
# To manage the filter by GCURLEG on the main process    : Already done by DBA
# To manage the filter on new concept of population      : Not yet
###################################################################################################################

Local Char PARAM(10 )(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTRECCUM","TRTRECCUM",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 :# GOK = 0
 When "BOUTON"      : Gosub BOUTON From TRTAUT :#81085
Endcase
Return

################################################
$DEBUT
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Raz [M:DIA]INI : # Pour déclencher le grisage des zones
Affzo [DIA]
# Pour éxécuter le contrôle de saisie s/date de paye
Setmok [M] With 0
Call AFF_MEMO From DIVPAYE: #81085
Return

################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$INIT

Local Char    MATRI(GLONEML) , SYMBOLE(80) , CRITERE(250), CTR(GLONHRCTR)
Local Integer NOK , OKC , PASAPAS
Local Date    DATMAT
Local Integer I , J , K, ICUM
Local Integer IC , PERIO , OKS
Local Decimal VALCUM1 , VALCUM2
Local Char    CODCUM(GLONCUM) , MESSA(250) , INICUM(24)
Local Date    DATPAY , DATPREC

Local Integer IRUBCUM
Local Char TRUBCUM(25)(200,500)
Local Integer NBRRUBCUM(200)

TIT = mess(53,10703,1)     : # Recalcul des cumuls
Gosub OUVFIC From TRTCAL
#JOJAC - 2016-08-12 - X3PEOP-963 - START
#Gosub OUVFIC From = "WP"+GCURLEG+"PLAN"
#JOJAC - 2016-08-12 - X3PEOP-963 - END

If clalev([F:CUM])=0 : Local File CUMUL   [CUM] : Endif
If clalev([F:ECC])=0 : Local File EXCEPTC [ECC] : Endif
If clalev([F:ECH])=0 : Local File EXCEPTH [ECH] : Endif
If clalev([F:VE2])=0 : Local File VALEMP  [VE2] : Endif

#91750
Gosub OUVRE From WPDEFTABLE
Local Decimal MAJCUM
Local Date DATMAT

Local Mask TRTRECCUM [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","rcu") From GMEMO
Call AFF_MEMO From DIVPAYE: #81085
Return

$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 If [M]NBRCUM=0 & [M]FLGPER=1
  # Il faut sélectionner la périodicité des cumuls ou la liste des cumuls
  GERR = 1 : GMESSAGE = mess(101,10703,1)
  SAI = 1
 Else
  If [M:DIA]FLGPER=2
   ICUM=0
   # Pas les cumuls intermédiaires
   Filter [CUM] Where CUMPER=[M:DIA]CUMPER & CUMTMP=1 & LEG=GCURLEG
   For [CUM]CUM0
    If ICUM>=dim([M:DIA]CUM)
     GERR = 1
     # Le nombre de cumuls à recalculer est limité à xxx
     GMESSAGE = mess(102,10703,1)-num$(dim([M:DIA]CUM))
     Break
    Endif
    [M:DIA]CUM(ICUM) = [F:CUM]CUMCOD
    ICUM +=1
   Next
   [M:DIA]NBRCUM=ICUM
   Filter [CUM]
   If GERR=1 : SAI=1 : Return : Endif
  Endif
  TMP = 1
  TRA = 1
 Endif
Endif
Return

$EXEC
Gosub OUVFIC From ="WP"+GCURLEG+"PLAN"
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

CRITERE = '[F:CPY]LEG="'+GCURLEG+'"'
If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITERE -= '& [F:VEP]FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:VEP]EMP>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:VEP]EMP<="'+[M:DIA]MATFIN+'"'
Endif
If [M:DIA]ALLSRV<>2  #service
 CRITERE -= '& [F:VEP]SRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2  #profil
 CRITERE -= '& [F:VEP]PRF = "'+[M:DIA]PRF+'"'
Endif
If [M:DIA]DATPAYSTR<>[0/0/0]
 CRITERE -= '& [F:VEP]PYRDAT>=['+format$(GFMD,[M:DIA]DATPAYSTR)+']'
Endif
If [M:DIA]DATPAYEND<>[0/0/0]
 CRITERE -= '& [F:VEP]PYRDAT<=['+format$(GFMD,[M:DIA]DATPAYEND)+']'
Endif

If [M:DIA]POP<>""
#JOJAC - 2016-08-04 - X3PEOP-963 - START
# Link [VEP] With
#&   [ID]ID0   = [F:VEP]EMP
#& , [FCY]FCY0 = [F:VEP]FCY
#& , [CPY]CPY0 = [F:FCY]LEGCPY
#& , [HRPOA]POA0 = [M:DIA]POP;[F:VEP]EMP
#&   As [LNK]
#&   Where evalue(CRITERE) & [F:HRPOA]REFNUM<>""
 Link [VEP] With
&   [ID]ID0   = [F:VEP]EMP
& , [FCY]FCY0 = [F:VEP]FCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
& , [HRPOA]POA0 = [M:DIA]POP;[F:VEP]EMP
&   As [LNK]
&   Where evalue(CRITERE) & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & [F:POA]REFNUM<>""
#JOJAC - 2016-08-04 - X3PEOP-963 - END
Else
#JOJAC - 2016-08-04 - X3PEOP-963 - START
# Link [VEP] With
#&   [ID]ID0   = [F:VEP]EMP
#& , [FCY]FCY0 = [F:VEP]FCY
#& , [CPY]CPY0 = [F:FCY]LEGCPY
#&   As [LNK]
#&   Where evalue(CRITERE)
 Link [VEP] With
&   [ID]ID0   = [F:VEP]EMP
& , [FCY]FCY0 = [F:VEP]FCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
&   As [LNK]
&   Where evalue(CRITERE) & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#JOJAC - 2016-08-04 - X3PEOP-963 - END
Endif

Gosub CHARGE_RUBCUM

NBPCE = 0

GOK=1
Trbegin [HSP]

For [LNK]VEP0
 Gosub TRTCONT
 If NOK=0
  Call DEBTRANS From GLOCK
  Gosub RECALCUL
  If GOK=1
   NBPCE += 1
  Else
   Break
  Endif
 Endif
 Unlock =SYMBOLE
Next

If GOK<=0 |[M:DIA]SIM=2
 Unlock =SYMBOLE
 Rollback
Else
 Commit
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif
Return

$RECALCUL
MATRI  = [F:VEP]EMP
DATPAY = [F:VEP]PYRDAT
CTR    = [F:VEP]CTRNUM
Call ECR_TRACE(MATRI-[F:ID]NAM-[F:ID]SRN-":"-format$("D:"+GFMDAT,[F:VEP]PYRDAT)-mess(104,10703,1)-[F:VEP]BUL,0) From GESECRAN
#DLE GCURLEG is got back from the company of the contract.
If dim([F:CPY]LEG)>0
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  Call LECTURE("HRCTR",[F:VEP]CTRNUM,"") From CONTOBJ
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  GCURLEG=[F:CPY]LEG
Endif

Call DEBTRANS From GLOCK
If [M:DIA]CAL=2
 PASAPAS = -2
 Gosub TR1
Else
 Gosub TR2
Endif
Call ECR_TRACE("",0) From GESECRAN
Return

################################################################################
## Recalcul avec recalcul des payes
################################################################################

$TR1
Call PLAN([F:VEP]BUL,PASAPAS,0) From GPLAN
Return

$ECRITURE
For IC=1 To [M:DIA]NBRCUM
 CODCUM  = [M:DIA]CUM(IC-1)
 Read [CUM]CUM0 = GCURLEG;CODCUM
 VALCUM1 = evalue("C_"+CODCUM+"(1)")
 VALCUM2 = evalue("C_"+CODCUM+"(2)")

 #Il faut traiter les paies d'extourne (negatives) mais les traiter differement (Cf $ECRITURE)
 If [F:VEP]ORIDAT<>[0/0/0]
  VALCUM1= VALCUM2-(VALCUM1-VALCUM2)
 Endif

 Read [HSP]HSP3 = BULLETIN;CODCUM;6
 If fstat : Raz [F:HSP] : Endif
 MESSA =  format$("K:12X",CODCUM)+" : "+format$("Nz:9.2",VALCUM1)
 MESSA += " ("+vireblc(format$("N:9.2",[F:HSP]AMT),2)+")    "+[M:DIA]ZCUM(IC-1)
 Call ECR_TRACE(MESSA,0) From GESECRAN
  Readlock [HSP]HSP3 = BULLETIN;CODCUM;6
  If fstat=1
   GOK = -1 : GLOCK = "$HISTOPAYE"-BULLETIN-MATRI-CODCUM : Break
  Elsif fstat
   Raz [F:HSP]
   [F:HSP]BUL = BULLETIN
   [F:HSP]EMP = MATRI
   [F:HSP]DAT = DATPAY
   [F:HSP]CTRNUM = CTR
   [F:HSP]RUB = CODCUM
   [F:HSP]ROW = [F:CUM]CUMROW
   [F:HSP]AMT = VALCUM1
   [F:HSP]BAS = VALCUM2
   [F:HSP]TYP = 6
   [F:HSP]LEG = GCURLEG
   Write [HSP]
  Else
   [F:HSP]AMT = VALCUM1
   [F:HSP]BAS = VALCUM2
   Rewrite [HSP]
  Endif
  If fstat
   GOK = 0 : Call FSTA("HSP") From GLOCK : Break
  Endif
Next IC
Return

$MEMRUB
Return

################################################################################
## Recalcul sans recalcul des payes
################################################################################

$TR2
#JOJAC - 2016-08-04 - X3PEOP-963 - START
DATMAT=DATPAY
#JOJAC - 2016-08-04 - X3PEOP-963 - END
Gosub LECEMP From WPDEFTABLE


 For IC=1 To [M:DIA]NBRCUM
  CODCUM  = [M:DIA]CUM(IC-1)
  Read [CUM]CUM0 = GCURLEG;CODCUM
  PERIO = [F:CUM]CUMPER
  Call PARAM(GCURLEG,"PERCUM"+num$(PERIO),INICUM) From ADOVAL
  For [ECC]ECC1 Where LEG=GCURLEG and PER=PERIO
   Read [ECH]ECH0 = GCURLEG;[F:ECC]COD
   OKS = 1
   If [F:ECH]FCY<>"" & [F:ECH]FCY<>[F:VEP]FCY  : OKS = 0 : Endif
   If [F:ECH]PRF<>"" & [F:ECH]PRF<>[F:VEP]PRF  : OKS = 0 : Endif
   If [F:ECH]PRF<>"" & [F:ECH]SRV<>[F:VEP]SRV  : OKS = 0 : Endif
   If [F:ECH]EMPSTR<>"" & MATRI<[F:ECH]EMPSTR  : OKS = 0 : Endif
   If [F:ECH]EMPEND<>"" & MATRI>[F:ECH]EMPEND  : OKS = 0 : Endif
   If [F:ECC]DATSTR<>[0/0/0] & DATPAY<[F:ECC]DATSTR : OKS = 0 : Endif
   If [F:ECC]DATEND<>[0/0/0] & DATPAY>[F:ECC]DATEND : OKS = 0 : Endif
   If OKS & [F:ECH]POP<>""
    Read [HRPOA]POA0 = [F:ECH]POP;MATRI
    If fstat : OKS = 0 : Endif
   Endif
   If OKS & [F:ECH]CRI<>""
    OKS = evalue([F:ECH]CRI)
   Endif
   If [L]OKS & dim([F:ECH]CTRCRI) > 0 & [F:ECH]CTRCRI(0) <> ""
       If !find([F:VEP]EMP+"~"+[F:VEP]CTRNUM, [F:ECH]CTRCRI)
           [L]OKS = 0
       Endif
   Endif
   If OKS
    INICUM = [F:ECC]TYP
    Break
   Endif
  Next
  INICUM = left$(INICUM+INICUM+string$(24,"N"),24)
  Filter [VE2] Where EMP=MATRI & CTRNUM=CTR & PYRDAT<=DATPAY & BUL<[F:VEP]BUL
  Read [VE2]VEP0 Last
  Filter [VE2]
  If fstat>2 : DATPREC = [0/0/0] : Else : DATPREC = [F:VE2]PYRDAT : Endif
  VALCUM1 = 0
  If DATPREC<>[0/0/0]
   J = month(DATPREC)+1
   K = month(DATPAY)+12*(year(DATPAY)-year(DATPREC))
   If K>=J & instr(1,seg$(INICUM,J,K),"O")
    If [F:CUM]CUMINI<>""
     Call EVALE(MATRI,DATPAY,DATPREC,[F:VEP]FCY,[F:CUM]CUMINI,VALCUM1)
    Else
     VALCUM1 = 0
    Endif
   Else
    Read [HSP]HSP3 = [F:VE2]BUL;CODCUM;6
    If !fstat : VALCUM1 = [F:HSP]AMT : Endif
   Endif
  Elsif [F:CUM]CUMREP<>""
   Call EVALE(MATRI,DATPAY,DATPREC,[F:VEP]FCY,[F:CUM]CUMREP,VALCUM1)
  Endif
  VALCUM2 = VALCUM1

   For [L]IRUBCUM = 0 To [L]NBRRUBCUM([L]IC-1) - 1
#JASMI - 2017-11-13 - X3-63808 - START
#   Read [F:RUB]RUB0 = [L]TRUBCUM([L]IC-1, [L]IRUBCUM)
   Read [F:RUB]RUB0 = GCURLEG; [L]TRUBCUM([L]IC-1, [L]IRUBCUM)
#JASMI - 2017-11-13 - X3-63808 - END
   J = 0
   Repeat
    K = find(CODCUM,[F:RUB]CUM(J..[F:RUB]NBRCUM-1))
    If K
     J +=K
     #91750
     MAJCUM=1
     If  [F:RUB]CNDCUM(J-1)<>""
      Call EVALE(MATRI,DATPAY,DATPREC,[F:VEP]FCY,[F:RUB]CNDCUM(J-1),MAJCUM)
     Endif
     If MAJCUM
     #
      Case [F:RUB]OPTCUM(J-1)
      When 1 : # -PS
       Read [HSP]HSP3 = [F:VEP]BUL;[F:RUB]COD;1
       If !fstat : VALCUM2 -= [F:HSP]AMT : Endif
       Read [HSP]HSP3 = [F:VEP]BUL;[F:RUB]COD;7
       If !fstat : VALCUM2 -= [F:HSP]AMT : Endif
      When 3 : # +PS
       Read [HSP]HSP3 = [F:VEP]BUL;[F:RUB]COD;1
       If !fstat : VALCUM2 += [F:HSP]AMT : Endif
       Read [HSP]HSP3 = [F:VEP]BUL;[F:RUB]COD;7
       If !fstat : VALCUM2 += [F:HSP]AMT : Endif
      When 2 : # -PP
       Read [HSP]HSP3 = [F:VEP]BUL;[F:RUB]COD;2
       If !fstat : VALCUM2 -= [F:HSP]AMT : Endif
       Read [HSP]HSP3 = [F:VEP]BUL;[F:RUB]COD;8
        If !fstat : VALCUM2 -= [F:HSP]AMT : Endif
      When 4 : # +PP
       Read [HSP]HSP3 = [F:VEP]BUL;[F:RUB]COD;2
       If !fstat : VALCUM2 += [F:HSP]AMT : Endif
       Read [HSP]HSP3 = [F:VEP]BUL;[F:RUB]COD;8
       If !fstat : VALCUM2 += [F:HSP]AMT : Endif
      When 5   : # Raz
       Filter [HSP] Where BUL=[F:VEP]BUL & RUB=[F:RUB]COD & TYP<>6
       Look [HSP]HSP3 First
       If !fstat : VALCUM2 = 0 : Endif
       Filter [HSP]
      Endcase
     Endif
    Endif
   Until K=0
  Next
  MESSA =  format$("K:12X",CODCUM)+" : "+format$("Nz:9.2",VALCUM2)
  MESSA += " ("+vireblc(format$("N:9.2",VALCUM1),2)+")    "+[M:DIA]ZCUM(IC-1)
  Call ECR_TRACE(MESSA,0) From GESECRAN
   Readlock [HSP]HSP3 = [F:VEP]BUL;CODCUM;6
   If fstat=1
    GOK = -1 : GLOCK = "$HISTOPAYE"-MATRI-CODCUM : Break
   Elsif fstat
    Raz [F:HSP]
    [F:HSP]BUL = [F:VEP]BUL
    [F:HSP]EMP = MATRI
    [F:HSP]DAT = DATPAY
    [F:HSP]CTRNUM = CTR
    [F:HSP]RUB = CODCUM
    [F:HSP]ROW = [F:CUM]CUMROW
    [F:HSP]AMT = VALCUM2
    [F:HSP]BAS = VALCUM1
    [F:HSP]TYP = 6
    [F:HSP]LEG = GCURLEG
    Write [HSP]
   Else
    [F:HSP]AMT = VALCUM2
    [F:HSP]BAS = VALCUM1
    Rewrite [HSP]
   Endif
   If fstat
    GOK = 0 : Call FSTA("HSP") From GLOCK : Break
   Endif
 Next IC
Return

################################################################################
Subprog EVALE(MATRI,DATPAY,DATPREC,SITE,FORMULE,VALEUR)
Value    Char    MATRI
Value    Date    DATPAY
Value    Date    DATPREC
Value    Char    SITE
Value    Char    FORMULE
Variable Decimal VALEUR

Local Integer P , K
Local Char    EXPRESS(250) , FRM(250) , C(1)
Local Char    VARIA(30) , CODE(30) , PFIX(5)
Local Integer NBVAR
Local Decimal V(1..100)

EXPRESS = vireblc(format$("KT:250X",FORMULE),2)
P = 1
VARIA = ""
NBVAR = 0
Raz V
While P<=len(EXPRESS)
 C = mid$(EXPRESS,P,1)
 If instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",C)
  VARIA += C
 Else
  If VARIA<>"" : Gosub SETVAR : Endif
  FRM += C
 Endif
 P += 1
Wend
If VARIA<>"" : Gosub SETVAR : Endif
Onerrgo ERRVAR
VALEUR = evalue(FRM)
Onerrgo
End

$ERRVAR
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-"("+num$(errn)-")"-errm,1) From GESECRAN
VALEUR = 0
Resume

$SETVAR
CODE = right$(VARIA,3)
PFIX = left$(VARIA,2)
K = find(PFIX,"C_","R_","V_")
If K
 NBVAR += 1
 VARIA = "V("+num$(NBVAR)+")"
 Case K
  When 1
   If DATPREC<>[0/0/0]
    Read [HSP]HSP3 = [F:VE2]BUL;CODE;6
    If !fstat : V(NBVAR) = [F:HSP]AMT : Endif
   Endif
  When 2
   Read [HSP]HSP3 = [F:VEP]BUL;CODE;1
   If !fstat : V(NBVAR) = [F:HSP]AMT : Endif
  When 3
   Read [VLA]VLA0 = 4;"";"";"";MATRI;DATPAY;CODE;[F:VEP]BUL
   If fstat
    Filter [VLA] Where TYP=3 & FCY=SITE & VARCOD=CODE & DAT<=DATPAY
    Read [VLA]VLA0 Last
    If fstat>2
     Call LECTURE("FCY",SITE,"") From CONTOBJ
     Filter [VLA] Where TYP=2 & CPY=[F:FCY]LEGCPY & VARCOD=CODE & DAT<=DATPAY
     Read [VLA]VLA0 Last
     If fstat>2
      Filter [VLA] Where TYP=1 & VARCOD=CODE & DAT<=DATPAY & LEG=GCURLEG
      Read [VLA]VLA0 Last
     Endif
    Endif
   Endif
   If fstat<=2
    V(NBVAR) = [F:VLA]VARVAL
   Endif
   Filter [VLA]
 Endcase
Endif
FRM += VARIA
VARIA = ""
Return

################################################################################
$TRTCONT
NOK = 1

Call CONTROLE([F:VEP]EMP,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[M:DIA]CRI,OKC,0) From DIVPAYE
If !OKC : Return : Endif

# Verrouillé US 2022 65062
# Les cumuls annuels, ou de périodicité supérieure à mensuel, se cumulent de paie en paie, il faut prendre tous les bulletins même comptabilisé et verrouillé

# Verrou
##**82073
Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE
Lock =SYMBOLE
If fstat
 Call ECR_TRACE([F:VEP]EMP-":"-mess(10,100,1),1) From GESECRAN
 Return
Endif

NOK=0
Return

$CHARGE_RUBCUM
# On lit une fois le plan de paye et on constitue pour chaque cumul la liste des rubriques à prendre
Raz [L]TRUBCUM, [L]NBRRUBCUM
For [RUB]RUB1 Where LEG=GCURLEG & NBRCUM<>0 & [F:RUB]VLYSTR<=[M:DIA]DATPAYEND & ([F:RUB]VLYEND=[0/0/0] | [F:RUB]VLYEND>=[M:DIA]DATPAYSTR)
 For [L]IRUBCUM = 0 To [M:DIA]NBRCUM - 1
  CODCUM  = [M:DIA]CUM([L]IRUBCUM)
  K = find(CODCUM, [F:RUB]CUM(0..[F:RUB]NBRCUM-1))
  If K > 0
   # Notre rubrique fait apparaitre le cumul que l'on cherche
   [L]TRUBCUM([L]IRUBCUM, [L]NBRRUBCUM([L]IRUBCUM) ) = [F:RUB]COD
   [L]NBRRUBCUM([L]IRUBCUM) += 1
  Endif
 Next
Next
Return

################################################################################
## Etiquettes écran TRTRECCUM
################################################################################
#JOJAC - 2016-08-04 - X3PEOP-963 - START
Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From DIVPAYE
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From DIVPAYE
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Call AS_CPY(VALEUR) From DIVPAYE
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
Call AS_FCY(VALEUR) From DIVPAYE
End

Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR
Call C_ALLSRV(VALEUR) From DIVPAYE
End

Subprog AS_SRV(VALEUR)
Variable Char     VALEUR
Call AS_SRV(VALEUR) From DIVPAYE
End

Subprog C_ALLPRF(VALEUR)
