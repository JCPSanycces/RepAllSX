Subprog C_DATPAYEND(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR<[M:DIA]DATPAYSTR
 # Période incorrecte
 GMESSAGE = mess(25,702,1)
 mkstat = 2 : End
Endif
End
#JOJAC - 2016-08-04 - X3PEOP-963 - END

Subprog C_CUM(VALEUR)
Variable Char    VALEUR()
Call LECTURE("CUM",VALEUR,GCURLEG) From CONTOBJ
If [F:CUM]CUMTMP=2
 # Cumul intermédiaire
 GMESSAGE = VALEUR-":"-mess(48,10703,1)
 mkstat = 2 : End
Endif
End

Subprog C_FLGPER(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Grizo [M]CUMPER
 Actzo [M]NBRCUM
Else
 Actzo [M]CUMPER
 Effzo [M:DIA]20
 Grizo [M]NBRCUM
Endif
End

Subprog AS_CUMPER(VALEUR)
Variable Integer VALEUR
If [M]FLGPER=1 : mkstat=1 : Endif
#JOJAC - 2016-08-04 - X3PEOP-963 - START
