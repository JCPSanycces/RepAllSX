Subprog D_INI(VALEUR)
Variable Char    VALEUR()
#JOJAC - 2016-08-04 - X3PEOP-963 - START
Gosub GRISE From DIVPAYE
#JOJAC - 2016-08-04 - X3PEOP-963 - END
If [M]FLGPER=1 : Grizo CUMPER : Else : Actzo CUMPER : Endif
End

