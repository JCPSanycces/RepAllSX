#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTI2018R05 UTI process for 2018Rn of X3
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2018Rn - passage de Rn-1 vers Rn
#
#      correction utility to be done at the end of the patch - move from Rn-1 to Rn
#
##########################################################################
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2018R05 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2018R05 (APPLI)

End

###################################################
Subprog EXE_UTI2018R05(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2018R05-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#-------------------------------------------------------------#
# Issue X3-64007 - 2018-06-01 by MAE : update for LPN project*
If [F:ADS]MODULE(6) = 2
  Call PATCH(LDOSSIER) From UTISTO26
  Call GENPATCH(0,LDOSSIER) From FUNSTKTRS
  Call PATCH(LDOSSIER) From CNSSDESTD
  Call PATCH(LDOSSIER) From CNSSSESTD
  Call PATCH(LDOSSIER) From CNSSXTSTD
  Call PATCH(LDOSSIER) From CNSSADSTD
  Call PATCH(LDOSSIER) From CNSSMVSTD
  Call PATCH(LDOSSIER) From CNSSMJSTD
  Call PATCH(LDOSSIER) From CNSSATSTD
  Call PATCH(LDOSSIER) From CNSSMASTD
  Call PATCH(LDOSSIER) From CNSSEASTD
Endif

# Issue X3-81838 - 2018-06-01 by MUARN : order, receipt and return for LPN
If [F:ADS]MODULE(5)=2
  Call PATCH(LDOSSIER) From SUBPTC
  Call PATCH(LDOSSIER) From SUBPTR
  Call PATCH(LDOSSIER) From SUBPTN
Endif

# X3-69438 TOOL TO INITIALIZE THE LPNCOD & LPNSCR FIELDS IN THE
# TRANSACTION OF CUSTOMER RETURNS  (LCC 27/02/2018)
# X3-69439 TOOL TO INITIALIZE THE LPNCOD & LPNSCR FIELDS IN THE
# TRANSACTION OF LOAN RETURNS  (LCC 16/03/2018)
# X3-81835 TOOL TO INITIALIZE THE LPNCOD & LPNSCR FIELDS IN THE
# TRANSACTION OF SALE ISSUES DOCUMENTS
If [F:ADS]MODULE(4)=2
  Call PATCH(LDOSSIER) From UTIVEN69438
  Call PATCH(LDOSSIER) From UTIVEN69439
  Call PATCH(LDOSSIER) From UTIVEN81835
  Call PATCH(LDOSSIER) From UTIVEN201805001      # Issue X3-86349 - 2018-04-12 by FGR
Endif
# End X3-69438

# Issue X3-93716 - 2018-05-30 by RBA : EDI category / partner
  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTIEDI201805001
    Call PATCH(LDOSSIER) From UTIHDK201805001    # Issue X3-90641 - 2018-06-04 by FGR
  Endif

# Issue X3-83028 - 2018-05-18 by CBO : Add a parameter to modify or not purchase order
If [F:ADS]MODULE(2) = 2
  Call PATCH(LDOSSIER) From UTICPT97
Endif
# End issue X3-83028

If [F:ADS]MODULE(7) = 2
  # Issue X3-96124 - 2018-06-21 by GH : Regeneration transactions for production tracking
  Call PATCH(LDOSSIER) From SUBMTL
Endif

# Issue X3-48236 - 2018-06-05 by GH : Deletion parameters MRPECCSO* and MPSECCSO*
Call PATCH(LDOSSIER) From UTIGPA51

#X3-91078 - Initialize ISMASKABLE field in table AMSKZON.
Call PATCH(LDOSSIER) From UTIINIMASKABLE
# Issue end

# Issue X3-59123 - 2018-06-15 by CCC : Initialize sequence in group of tasks
Call PATCH(LDOSSIER) From UTIINIABGSEQ
# Issue X3-59123 - 2018-06-15 by CCC : Revalidate BI Dimensions for new label in script generated
Call PATCH(LDOSSIER) From SUBABI

Call ECR_TRACE("END : UTI2018R05-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2018R05
End

