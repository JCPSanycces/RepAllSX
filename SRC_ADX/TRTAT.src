######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran TRTAT) 15/07/2013 12:44:14 (LNEBR)
######################################################################################
Subprog C_BANRGL(VALEUR)
Variable Char    VALEUR()
If [M]CPY <>""
 If [F:BAN]CPY<> [M]CPY
  mkstat=2: GMESSAGE = [L]VALEUR-":"-mess(27,10704,1) #Cette banque n'est pas rattachée à la société saisie
 Endif
Else
 Call LECTURE ("BAN",VALEUR,"") From CONTOBJ
 Call LECTURE ("CPY",[F:BAN]CPY, "") From CONTOBJ
 If [F:CPY]LEG<>GCURLEG
   mkstat=2: GMESSAGE = [L]VALEUR-":"-mess(14,10712,1) : # Fiche inexistante pour la législation courante
 Endif
Endif
End


