#<AdxTL>@(#)4.0.0.0 $Revision$
##** V7 : Waiting Time Mangement **#
##*********************************#
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTAT","TRTAT",4,"TRTAT") From GTRAITE
End

#############################################
$ACTION
Case ACTION
 When "INIT"         : Gosub OUVRE
 When "CONTROLE"     : Gosub CONTROLE
 When "DEBUT"        : Gosub DEBUT
 When "EXEC"         : Gosub EXEC
 When "OK"           : FIN = 1 : GOK = 1
 When "END"          : FIN = 1
 When "SORTIE"       : Gosub SORTIE
 When "BOUTON"       : Gosub BOUTON :#81085
Endcase
Return

#############################################
$OUVRE
#86255
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#
Local Mask TRTAT [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","tat") From GMEMO
Call AFF_MEMO From DIVPAYE :#81085
Gosub OUVFIC
Gosub DECLARATION
#86255
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif

If dim([M:TAT0]REFNUM)>=0
 Raz [M:DIA]
 [M:DIA]MATDEB=[M:TAT0]REFNUM
 [M:DIA]MATFIN=[M:TAT0]REFNUM
 [M:DIA]DATSTR=[M:TAT0]DAT
 [M:DIA]DATEND=eomonth([M:TAT0]DAT)
 If dim([M:TAT0]LEG)>=0
  [M:DIA]LEG=[M:TAT0]LEG
  GCURLEG=[M:TAT0]LEG
 Endif
Endif
#
Return

#############################################
#81085
$DEBUT
Affzo [M:DIA]: Setmok [DIA] With 0
Call AFF_MEMO From DIVPAYE :#81085
Gosub AFF_BANK
Return

#############################################
#81085
$BOUTON
Case BOITE
When "TRTAT", "TRTMAL"
Case BOUT
  When "R" :
   # Button "Rappel MEMO"
   Call AFF_MEMO From DIVPAYE
   Gosub AFF_BANK
  Endcase
Endcase
Return

#81085
$AFF_BANK
If [M:DIA]ENAFLG>=2 & [M:DIA]ENAFLG<=3
 Actzo [M:DIA]BANRGL
Else
 Diszo [M:DIA]BANRGL
Endif
Return

#############################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#############################################
$OUVFIC
If clalev([F:HRTAT])=0    : Local File TABAT      [HRTAT]   : Endif
If clalev([F:TAT1])=0   : Local File TABAT      [TAT1]  : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif

If clalev([F:BPA])=0    : Local File BPADDRESS  [BPA]   : Endif
If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
If clalev([F:AD])=0     : Local File EMPLOAD    [AD]    : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
If clalev([F:CTR1])=0   : Local File EMPLOCTR   [CTR1]  : Endif
If clalev([F:HSP])=0    : Local File HISTOPAYE  [HSP]   : Endif
If clalev([F:RUB])=0    : Local File RUBRIQUE   [RUB]   : Endif
If clalev([F:VEP])=0    : Local File VALEMP     [VEP]   : Endif
If clalev([F:CNT])=0    : Local File CONTACT    [CNT]   : Endif
If clalev([F:AIN])=0    : Local File CONTACTCRM [AIN]   : Endif
If clalev([F:BAN])=0    : Local File BANK       [BAN]   : Endif
If clalev([F:WAC])=0    : Local File TRVACC     [WAC]   : Endif
If clalev([F:WAR])=0    : Local File TRVACCRAT  [WAR]   : Endif
If clalev([F:ORG])=0    : Local File ORGANISME  [ORG]   : Endif
If clalev([F:ADI])=0    : Local File ATABDIV    [ADI]   : Endif

#LIPET - 2017-05-20 - START
##** V7 : Waiting Time Mangement **#
#If clalev([F:TIM])=0    : Local File TIMCOD     [TIM]   : Endif
#If clalev([F:TIP])=0    : Local File TIMEMP     [TIP]   : Endif
#If GTPS=1
# If clalev([F:TIG])=0   : Local File TIMREGUL   [TIG]   : Endif
# If clalev([F:TG2])=0   : Local File TIMREGUL   [TG2]   : Endif
#Endif
#If clalev([F:TP2])=0    : Local File TIMEMP     [TP2]   : Endif
#If clalev([F:TP3])=0    : Local File TIMEMP     [TP3]   : Endif
##**
If clalev([F:TIM])=0    : Local File TIMCOD     [TIM]   : Endif
If clalev([F:TIP])=0    : Local File TIMEMP     [TIP]   : Endif
If GTPS=1
 If clalev([F:TIG])=0   : Local File TIMREGUL   [TIG]   : Endif
 If clalev([F:TG2])=0   : Local File TIMREGUL   [TG2]   : Endif
Endif
If clalev([F:TP2])=0    : Local File TIMEMP     [TP2]   : Endif
If clalev([F:TP3])=0    : Local File TIMEMP     [TP3]   : Endif
#LIPET - 2017-05-20 - END
#86255
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
Return

#############################################
$DECLARATION
##** V7 : Waiting Time Mangement **#
Global Integer GLONTPS
GLONTPS=5
##**

Local Integer NBSAL, PERPAY
Local Integer I, J, K, OK

Local Integer NBRABS,NBRAT,NBRAVN,NBRBRU,NBRCHO,NBRCOT,NBRENT
Local Integer NBRFRS,NBRIND,NBRMAL,NBRMAT,NBRRAP

Local Decimal TOTCOL4, TOTCOL5, TOTCOL6, TOTCOL7

Local Char    CRITFCY (250), CRITEMP (250), CRITTIP (250), CRITTIG(250), CRITCTR(250)
Local Char    EVTAT(GLONTPS),EVTATJ(GLONTPS),EVTMAL(GLONTPS),VALPAR(30)

Local Char    RUBABS(GLONRUB)(1..GNBRUBATT)   :# Période partiellement accomplie car congés non payés autorisés
Local Char    CODABS(10), TIMABS(GLONTPS)
Local Char    RUBAT(GLONRUB)(1..GNBRUBATT)    :# Période partiellement accomplié car AT
Local Char    CODAT(10), TIMAT(GLONTPS)
Local Char    RUBAVN(GLONRUB)(1..GNBRUBATT)   :# Avantages en nature+pourboires
Local Char    RUBBRU(GLONRUB)(1..GNBRUBATT)   :# Salaire brut
Local Char    RUBCHO(GLONRUB)(1..GNBRUBATT)   :# Période partiellement accomplié car chômage
Local Char    CODCHO(10), TIMCHO(GLONTPS)
Local Char    RUBCOT(GLONRUB)(1..GNBRUBATT)   :# Cotisations s/salaire+accessoires
Local Char    RUBENT(GLONRUB)(1..GNBRUBATT)   :# Période partiellement accomplié car entrée
Local Char    CODENT(10), TIMENT(GLONTPS)
Local Char    RUBFRS(GLONRUB)(1..GNBRUBATT)   :# Frais professionnels soumis
Local Char    RUBIND(GLONRUB)(1..GNBRUBATT)   :# Indemnités+Primes+Gratifications
Local Char    RUBMAL(GLONRUB)(1..GNBRUBATT)   :# Période partiellement accomplié car maladie
Local Char    CODMAL(10), TIMMAL(GLONTPS)
Local Char    RUBMAT(GLONRUB)(1..GNBRUBATT)   :# Période partiellement accomplié car maternité
Local Char    CODMAT(10), TIMMAT(GLONTPS)
Local Char    RUBRAP(GLONRUB)(1..GNBRUBATT)   :# Rappels de salaire
Local Date    DEBARRET, FINARRET       :# Date de début et de fin de l'arrêt de travail
Local Date    REPRISE, FINPAYE
Local Date    LADATE, OLDDAT, LADATPYR
Local Char    LISEVT(GLONTPS)
Local Char    TABEVT (GLONTPS) (0..99)
Local Integer NBREVT
Local Decimal NBJABSMOI
#88414
Local Date DATDEB, DATFIN
#
Return

#############################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#############################################
$EXEC
# ouverture de la trace et écriture de l'en-tête
If [M:DIA]GRDABS=1
 TIT = mess(83,10703,1) : # Extraction Attestation AT
Else
 TIT = mess(187,10703,1) : # Extraction Attestation Maladie professionnelle
Endif
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

SYMBOLE = "TAT"+num$(date$)
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif

Gosub RECUP_RUBRIQUE
If FIN=1 : Return : Endif

CRITFCY="1=1"
If [M:DIA]ALLCPY<>2  #société
 CRITFCY -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITFCY -= '& [F:FCY]FCY = "'+[M:DIA]FCY+'"'
Endif


CRITEMP="[F:ID]FLGPAY=2"
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITEMP -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITEMP -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif


CRITCTR = '[F:HRCTR]CTRDAT<=['+num$([M:DIA]DATEND)+'] & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=['+num$([M:DIA]DATEND)+'])'
#LIPET - 2017-05-20 - START
##** V7 : Waiting Time Mangement **#
#CRITTIP = '[F:TIP]REFNUM=[F:ID]REFNUM & ([F:TIP]STRDAT>=['+num$([M:DIA]DATSTR)+']'
#CRITTIP -= '& [F:TIP]ENDDAT<=['+num$([M:DIA]DATEND)+']) & [F:TIP]CTRNUM=[F:HRCTR]CTRNUM'
#If [M:DIA]GRDABS=1 : # Attestation AT
# CRITTIP -= '& ([F:TIP]TIM="'+EVTAT+'" | [F:TIP]TIM="'+EVTATJ+'")'
#Else              : # Attestation Maladie professionnelle
# CRITTIP -= '& [F:TIP]TIM="'+EVTMAL+'"'
#Endif
#CRITTIP -= '& [F:TIP]TYPPGN=1'
#If [M:DIA]ALLFCY<>2  #site
# CRITTIP -= '& [F:TIP]FCY="'+[M:DIA]FCY+'"'
#Endif
#If GTPS=1
# CRITTIG = '[F:TIG]REFNUM=[F:ID]REFNUM & ([F:TIG]STRDAT>=['+num$([M:DIA]DATSTR)+']'
# CRITTIG -= '& [F:TIG]ENDDAT<=['+num$([M:DIA]DATEND)+']) & [F:TIG]CTRNUM=[F:HRCTR]CTRNUM'
# If [M:DIA]GRDABS=1 : # Attestation AT
#  CRITTIG -= '& ([F:TIG]TIM="'+EVTAT+'" | [F:TIP]TIM="'+EVTATJ+'")'
# Else              : # Attestation Maladie professionnelle
#  CRITTIG -= '& [F:TIG]TIM="'+EVTMAL+'"'
# Endif
#Endif
#CRITTIG -= '& [F:TIG]TYPPGN=1'
#If [M:DIA]ALLFCY<>2  #site
# CRITTIG -= '& [F:TIG]FCY="'+[M:DIA]FCY+'"'
#Endif
##**

#** V7 : Waiting Time Mangement **#
CRITTIP = '[F:TIP]REFNUM=[F:ID]REFNUM & ([F:TIP]STRDAT>=['+num$([M:DIA]DATSTR)+']'
CRITTIP -= '& [F:TIP]ENDDAT<=['+num$([M:DIA]DATEND)+']) & [F:TIP]CTRNUM=[F:HRCTR]CTRNUM'
If [M:DIA]GRDABS=1 : # Attestation AT
 CRITTIP -= '& ([F:TIP]TIM="'+EVTAT+'" | [F:TIP]TIM="'+EVTATJ+'")'
Else              : # Attestation Maladie professionnelle
 CRITTIP -= '& [F:TIP]TIM="'+EVTMAL+'"'
Endif
CRITTIP -= '& [F:TIP]TYPPGN=1'
If [M:DIA]ALLFCY<>2  #site
 CRITTIP -= '& [F:TIP]FCY="'+[M:DIA]FCY+'"'
Endif
If GTPS=1
 CRITTIG = '[F:TIG]REFNUM=[F:ID]REFNUM & ([F:TIG]STRDAT>=['+num$([M:DIA]DATSTR)+']'
 CRITTIG -= '& [F:TIG]ENDDAT<=['+num$([M:DIA]DATEND)+']) & [F:TIG]CTRNUM=[F:HRCTR]CTRNUM'
 If [M:DIA]GRDABS=1 : # Attestation AT
  CRITTIG -= '& ([F:TIG]TIM="'+EVTAT+'" | [F:TIP]TIM="'+EVTATJ+'")'
 Else              : # Attestation Maladie professionnelle
  CRITTIG -= '& [F:TIG]TIM="'+EVTMAL+'"'
 Endif
Endif
CRITTIG -= '& [F:TIG]TYPPGN=1'
If [M:DIA]ALLFCY<>2  #site
 CRITTIG -= '& [F:TIG]FCY="'+[M:DIA]FCY+'"'
Endif
#LIPET - 2017-05-20 - END
NBSAL = 0
#86255 : Ajout filtre sur HRPOA
If [M:DIA]POP<>""
 Link [HRCTR] With
&    [ID]ID0=[F:HRCTR]REFNUM,
&    [FCY]FCY0=[F:HRCTR]ETRFCY,
&    [HRPOA]POA0= [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
& As [LCTR]
& Where evalue(CRITEMP) & evalue(CRITCTR) & evalue(CRITFCY) & [F:HRPOA]REFNUM<>""
Else
 Link [HRCTR] With
&    [ID]ID0=[F:HRCTR]REFNUM,
&    [FCY]FCY0=[F:HRCTR]ETRFCY
& As [LCTR]
& Where evalue(CRITEMP) & evalue(CRITCTR) & evalue(CRITFCY)
Endif

# Rupture sur refnum/ctrnum
For [LCTR]CTR0(2)
 Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,"",OK,0) From DIVPAYE
 If OK=1
  Call DEBTRANS From GLOCK
  Gosub TR1
 Endif
Next

If NBSAL=0
 Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
Endif

Unlock =SYMBOLE
Call FERME_TRACE From LECFIC
Return

#############################################
$RECUP_RUBRIQUE
# Recup des codes évenements AT
Raz GMESSAGE
If [M:DIA]GRDABS=1
 Call PARAM("","AT",VALPAR)From ADOVAL
 EVTAT = VALPAR
 Call PARAM("","ATTRAJET",VALPAR)From ADOVAL
 EVTATJ = VALPAR
 If EVTAT=""
  GMESSAGE = "AT"-mess(1,10710,1)        :# AT : Paramètre non renseigné
 Endif
 If EVTATJ=""
  GMESSAGE = "ATTRAJET"-mess(1,10710,1)  :# ATTRAJET : Paramètre non renseigné
 Endif
Else
 Call PARAM("","MALPROF",VALPAR)From ADOVAL
 EVTMAL = VALPAR
 If EVTMAL=""
  GMESSAGE = "MALPROF"-mess(1,10710,1)   :# MALPROF : Paramètre non renseigné
 Endif
Endif

If GMESSAGE<>""
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 FIN = 1 : Raz GMESSAGE : Return
Endif

NBRABS = 0
NBRAT  = 0
NBRAVN = 0
NBRBRU = 0
NBRCHO = 0
NBRCOT = 0
NBRENT = 0
NBRFRS = 0
NBRIND = 0
NBRMAL = 0
NBRMAT = 0
NBRRAP = 0

For [F:RUB]RUB0 Where LEG=GCURLEG & ATTAT<>""
 # Table diverse 390
 Case [F:RUB]ATTAT
  When "ABS" : NBRABS+=1 : RUBABS(NBRABS) = [F:RUB]COD
  When "AT"  : NBRAT+=1  : RUBAT(NBRAT)   = [F:RUB]COD
  When "AVN" : NBRAVN+=1 : RUBAVN(NBRAVN) = [F:RUB]COD
  When "BRU" : NBRBRU+=1 : RUBBRU(NBRBRU) = [F:RUB]COD
  When "CHP" : NBRCHO+=1 : RUBCHO(NBRCHO) = [F:RUB]COD
  When "COT" : NBRCOT+=1 : RUBCOT(NBRCOT) = [F:RUB]COD
  When "ENT" : NBRENT+=1 : RUBENT(NBRENT) = [F:RUB]COD
  When "FRS" : NBRFRS+=1 : RUBFRS(NBRFRS) = [F:RUB]COD
  When "IND" : NBRIND+=1 : RUBIND(NBRIND) = [F:RUB]COD
  When "MAL" : NBRMAL+=1 : RUBMAL(NBRMAL) = [F:RUB]COD
  When "MAT" : NBRMAT+=1 : RUBMAT(NBRMAT) = [F:RUB]COD
  When "RAP" : NBRRAP+=1 : RUBRAP(NBRRAP) = [F:RUB]COD
 Endcase
Next

For [ADI] Where NUMTAB=10396
 Case [F:ADI]A1
  When "ABS" : CODABS = [F:ADI]CODE : TIMABS = [F:ADI]A2
  When "AT"  : CODAT  = [F:ADI]CODE : TIMAT  = [F:ADI]A2
  When "CHP" : CODCHO = [F:ADI]CODE : TIMCHO = [F:ADI]A2
  When "ENT" : CODENT = [F:ADI]CODE : TIMENT = [F:ADI]A2
  When "MAL" : CODMAL = [F:ADI]CODE : TIMMAL = [F:ADI]A2
  When "MAT" : CODMAT = [F:ADI]CODE : TIMMAT = [F:ADI]A2
 Endcase
Next

If RUBABS(1)=""
 #Aucune rubrique n'a été paramétrée pour l'absence congés non payés autorisés
 Call ECR_TRACE(mess(10,10710,1),-1) From GESECRAN
Endif
If RUBAT(1)=""
 #Aucune rubrique n'a été paramétrée pour l'absence AT
 Call ECR_TRACE(mess(13,10710,1),-1) From GESECRAN
Endif
If RUBAVN(1)=""
 #Aucune rubrique n'a été paramétrée pour les avantages en nature et pourboires
 Call ECR_TRACE(mess(17,10710,1),-1) From GESECRAN
Endif
If RUBBRU(1)=""
 # Aucune rubrique n'a été paramétrée pour le salaire brut
 Call ECR_TRACE(mess(12,10710,1),-1) From GESECRAN
Endif
If RUBCHO(1)=""
 # Aucune rubrique n'a été paramétrée pour l'absence chômage total ou partiel
 Call ECR_TRACE(mess(23,10710,1),-1) From GESECRAN
Endif
If RUBCOT(1)=""
 # Aucune rubrique n'a été paramétrée pour les cotisations sur salaires et accessoires
 Call ECR_TRACE(mess(19,10710,1),-1) From GESECRAN
Endif
If RUBENT(1)=""
 # Aucune rubrique n'a été paramétrée une entrée en cours de période
 Call ECR_TRACE(mess(21,10710,1),-1) From GESECRAN
Endif
If RUBFRS(1)=""
 # Aucune rubrique n'a été paramétrée pour les frais professionnels soumis à cotisations
 Call ECR_TRACE(mess(20,10710,1),-1) From GESECRAN
Endif
If RUBIND(1)=""
 # Aucune rubrique n'a été paramétrée pour les indemnités, primes et gratifications
 Call ECR_TRACE(mess(18,10710,1),-1) From GESECRAN
Endif
If RUBMAL(1)=""
 # Aucune rubrique n'a été paramétrée pour l'absence MALADIE
 Call ECR_TRACE(mess(2,10710,1),-1) From GESECRAN
Endif
If RUBMAT(1)=""
 # Aucune rubrique n'a été paramétrée pour l'absence MATERNITE
 Call ECR_TRACE(mess(3,10710,1),-1) From GESECRAN
Endif
If RUBRAP(1)=""
 # Aucune rubrique n'a été paramétrée pour les rappels de salaire
 Call ECR_TRACE(mess(22,10710,1),-1) From GESECRAN
Endif
Call ECR_TRACE("",0) From GESECRAN
Return

#############################################
##** V7 : Waiting Time Mangement **#
$TR1
#ADNGO - 2017-02-16 - START
#Infbox 'Waiting time management ' : Return
#ADNGO - 2017-02-16 - END
GOK = 1
Trbegin [HRTAT]
##**82073
For [LECT]CTR0(2)
 OK = 1
 Call CONTROLE([F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,"",OK,0) From DIVPAYE
 If OK
  Gosub TR0 From TRTMAL
  For IP=0 To NBTDAT
   CRITDAT='CTRDAT>=['+num$([L]TSTRDAT(IP))+'] & CTRDAT<=['+num$([L]TENDDAT(IP))+']'
   For [TIP]TIP1 Where evalue(CRITTIP) & evalue(CRITDAT)
    LADATE = [F:TIP]STRDAT
    LISEVT = [F:TIP]TIM
    Gosub PREM_ARRET From TRTMAL
    If OK=1
     DEBARRET = [F:TIP]STRDAT
     FINARRET = [F:TIP]ENDDAT
     LADATPYR = [F:TIP]DATPYR
     #si existant je supprime et je recommence
     Read [HRTAT]TAT0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
     If fstat | (!fstat & [F:HRTAT]STAATT=1)
      Delete [F:HRTAT]TAT0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
      If fstat=1 | fstat>5
       GOK=-1 : GLOCK="TAT"-[F:ID]REFNUM-num$(DEBARRET)-[F:HRCTR]CTRNUM
       Break
      Endif
      Gosub CAL_NBJABSMOI
      Gosub RECUP_INFOS
      If GOK<=0 : Break : Endif
     Endif
    Endif
   Next
   If GOK=0 : Goto AB_TR1
   Elsif GOK=-1 : Goto ROLL_TR1
   Endif
   If GTPS=1
    For [TIG]TIG1 Where evalue(CRITTIG) & NBRDAY>=0 & NBRHOU>=0 & evalue(CRITDAT)  :##**82073
     LADATE = [F:TIG]STRDAT
     LISEVT = [F:TIG]TIM
     Gosub PREM_ARRET From TRTMAL
     If OK=1
      DEBARRET = [F:TIG]STRDAT
      FINARRET = [F:TIG]ENDDAT
      LADATPYR = [F:TIG]DATPYR
      #si existant je supprime et je recommence
      Read [HRTAT]TAT0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
      If fstat | (!fstat & [F:HRTAT]STAATT=1)
       Delete [F:HRTAT]TAT0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
       If fstat=1 | fstat>5
        GOK=-1 : GLOCK="TAT"-[F:ID]REFNUM-num$(DEBARRET)-[F:HRCTR]CTRNUM
        Break
       Endif
       Gosub CAL_NBJABSMOI
       Gosub RECUP_INFOS
       If GOK<=0 : Break : Endif
      Endif
     Endif
    Next
    If GOK=0 : Goto AB_TR1
    Elsif GOK=-1 : Goto ROLL_TR1
    Endif
   Endif
  Next
 Endif
Next
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

#############################################
## Nombre de jours de l'attestation = Nb de jours consécutifs
$CAL_NBJABSMOI
NBJABSMOI=0
Raz OLDDAT
# On relit l'enregistrement
##**82073
Filter [TP2] Where [F:TP2]REFNUM=[F:ID]REFNUM & [F:TP2]CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT) & [F:TP2]STRDAT>=LADATE
&&                 LADATPYR=[F:TP2]DATPYR & [F:TP2]ENDDAT<=[M:DIA]DATEND & [F:TP2]TIM=LISEVT
For [TP2]TIP2
 If OLDDAT=[0/0/0] | [F:TP2]STRDAT=OLDDAT+1
  #64943
  #NBJABSMOI +=[F:TP2]NBRDAY
  NBJABSMOI +=[F:TP2]ENDDAT-[F:TP2]STRDAT +1
  OLDDAT = [F:TP2]ENDDAT
 Endif
Next
Filter [TP2]

Raz OLDDAT
If GTPS=1
 Filter [TG2] Where [F:TG2]REFNUM=[F:ID]REFNUM & [F:TG2]CTRNUM=[F:HRCTR]CTRNUM & [F:TG2]STRDAT>=LADATE
&&                  LADATPYR=[F:TG2]DATPYR & [F:TG2]ENDDAT<=[M:DIA]DATEND & [F:TG2]TIM=LISEVT
 For [TG2]
  If OLDDAT=[0/0/0] | [F:TG2]STRDAT=OLDDAT+1
   #64943
   #NBJABSMOI +=[F:TG2]NBRDAY
   NBJABSMOI +=[F:TG2]ENDDAT-[F:TG2]STRDAT +1
   OLDDAT = [F:TG2]ENDDAT
  Endif
 Next
 Filter [TG2]
Endif
Return

#############################################
$RECUP_INFOS
Raz [F:HRTAT]
Gosub INFOS_EMP
If GOK>0
 Gosub INFOS_FCY
 Gosub INFOS_CPY
Endif
If GOK>0
 [F:HRTAT]NBRDAYMON = NBJABSMOI
 [F:HRTAT]STAATT    = 1
 [F:HRTAT]DAT       = DEBARRET
 [F:HRTAT]NUM       = 1
 If dim([F:HRTAT]CREDAT)>0 : [F:HRTAT]CREDAT = date$ : Endif
 If dim([F:HRTAT]CREUSR)>0 : [F:HRTAT]CREUSR = GUSER : Endif
 If dim([F:HRTAT]CRETIM)>0 : [F:HRTAT]CRETIM = time  : Endif
 Write [F:HRTAT]
 If fstat
  GOK = 0 : Call FSTA("HRTAT") From GLOCK
 Else
 # If OLDMATRI<>[F:ID]REFNUM | OLDCTR<>[F:HRCTR]CTRNUM
   NBSAL +=1
   #Extraction des infos pour l'absence du ...
   If [F:HRTAT]RCVDAT<>[0/0/0]
    Call ECR_TRACE([F:ID]REFNUM-[F:ID]NAM-":"-mess(11,10710,1)-num$([F:HRTAT]DAT)-"-"-num$([F:HRTAT]RCVDAT),0) From GESECRAN
   Else
    Call ECR_TRACE([F:ID]REFNUM-[F:ID]NAM-":"-mess(11,10710,1)-num$([F:HRTAT]DAT),0) From GESECRAN
   Endif
  Endif
 #Endif
Endif
Return

#############################################

$INFOS_EMP
[F:HRTAT] = [F:ID]
[F:HRTAT]REFNUM = [F:ID]REFNUM
[F:HRTAT]CTRNUM = [F:HRCTR]CTRNUM

##**82073
[F:HRTAT]CTRDAT = LSTCTRDAT(IP)


If [F:ID]NTT="FR"
 [F:HRTAT]NTTTYP = 1
Else
 Read[TCY]TCY0=[F:ID]NTT
 If [F:TCY]EECFLG=2 : # Appartenance CEE
  [F:HRTAT]NTTTYP = 2
 Else
  [F:HRTAT]NTTTYP = 3
 Endif
Endif

# Contrat
Filter [CTR1] Where REFNUM=[F:HRTAT]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<=DEBARRET
Read [CTR1]CTR1 Last
Filter [CTR1]
If !fstat
 [F:HRTAT]JOB    = [F:CTR1]JOB
 [F:HRTAT]DATANC = [F:CTR1]DATANC
 If [F:CTR1]DATANCAPT<>[0/0/0] : # Le salarié est un apprenti
  [F:HRTAT]NUMCON = [F:CTR1]NUMCON
  ##**82073
  #[F:HRTAT]CTRDAT = [F:CTR1]CTRDAT
  [F:HRTAT]CTRDATAPT = [F:CTR1]CTRDAT
 Endif
 [F:HRTAT]ETRDAT = [F:CTR1]DATCPY

 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ

 # Medecine du travail (ex ENT)
 #MIPEA - 2016-09-28 - X3PEOP-752 - START
Local Integer ORGLINE
Local Integer COUNTER
If clalev([F:PCA])=0 : Local File CAISSE [PCA] : Endif
If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif

Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG # & [ADIZZ]CODE = [V]GINDMED

For [ADIZZ]
  [L]COUNTER+=1
    If [ADIZZ]CODE = [V]GINDMED
      [L]ORGLINE=[L]COUNTER-1 : Break
    Endif
Next
 Call ORGANISME([F:HRTAT]REFNUM,[F:HRCTR]ETRFCY,[F:CTR1]CTRNUM,[F:HRTAT]MEDORG,[L]ORGLINE) From SUBORG
 #Call ORGANISME([F:HRTAT]REFNUM,[F:HRCTR]ETRFCY,[F:CTR1]CTRNUM,[F:HRTAT]MEDORG,[V]GINDMED-1) From SUBORG
#MIPEA - 2016-09-28 - X3PEOP-752 - END
 Call LECTURE("ORG",[F:HRTAT]MEDORG,[F:CPY]LEG) From CONTOBJ
 [F:HRTAT]MEDADD = [F:ORG]ADD(0)-[F:ORG]POS-[F:ORG]CTY
 # Position professionnelle (ex PRO)
 [F:HRTAT]QLF = [F:CTR1]QLF
 Read[WAC]WAC0=[F:CTR1]RSKWRK
 If !fstat
  [F:HRTAT]CODRSK = [F:WAC]CODRSK
 Endif
Else
 #Erreur de lecture sur le fichier
 Call ECR_TRACE(mess(4,10707,1)-"EMPLOCTR",1) From GESECRAN
 GOK = 0 : Return
Endif

#42655
Gosub EVTW From TRTMAL

#Dernier jour travaillé (Regul)

#43680 : Ajout condition GTPS=1
If GTPS=1
 Raz[F:TG2]
 ##**82073
 Filter [F:TG2] Where STRDAT<DEBARRET & REFNUM=[F:ID]REFNUM & find(TIM,TABEVT(0..NBREVT)) & NBRDAY>=0 & NBRHOU>=0
&&                    CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT)
 Read [F:TG2]TIG1 Last
 Filter [F:TG2]
 If !fstat & [F:TG2]ENDDAT>[F:HRTAT]LSTDAYDAT
  [F:HRTAT]LSTDAYDAT=[F:TG2]ENDDAT
 Endif
Endif

#Dernier jour travaillé
Raz[F:TP2]
##**82073
Filter [F:TP2] Where STRDAT<DEBARRET & REFNUM=[F:ID]REFNUM & find(TIM,TABEVT(0..NBREVT))
&&                   CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT)
Read [F:TP2]TIP1 Last
Filter [F:TP2]
If fstat=0
 If [F:TP2]ENDDAT>[F:HRTAT]LSTDAYDAT
  [F:HRTAT]LSTDAYDAT=[F:TP2]ENDDAT
 Endif
Else
#DBA 02/03/06 : Attention maintenant salarié sans planning, donc pas obligé de boucher les trous par du W !!!
If dayn(DEBARRET-1)=7    :#Si ça donne un dimanche, on met le samedi précédent.
 [F:HRTAT]LSTDAYDAT=DEBARRET-2
Else
 [F:HRTAT]LSTDAYDAT=DEBARRET-1
Endif
 #Dernier jour travaillé précédent l'absence, non valide
 Call ECR_TRACE([F:ID]REFNUM-[F:ID]NAM-":"-mess(15,10710,1)-num$([F:HRTAT]LSTDAYDAT),1) From GESECRAN
Endif


# Accident du travail ou  Maladie profess.
[F:HRTAT]GRDABS = [M:DIA]GRDABS

Gosub JOUR_REPRISE
Gosub SALAIRES
Gosub SUBROGATION
Gosub RAPPEL_SAL
Return

#############################################

$INFOS_FCY
[F:HRTAT]FCY    = [F:FCY]FCY
[F:HRTAT]FCYCRN = [F:FCY]CRN
#86255
[F:HRTAT]LEG = [F:FCY]LEG
Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
If !fstat
 [F:HRTAT]FCYADDLIG(0) = [F:BPA]BPAADDLIG(0)
 [F:HRTAT]FCYADDLIG(1) = [F:BPA]BPAADDLIG(1)
 [F:HRTAT]FCYADDLIG(2) = [F:BPA]BPAADDLIG(2)
 [F:HRTAT]FCYPOSCOD    = [F:BPA]POSCOD
 [F:HRTAT]FCYCTY       = [F:BPA]CTY
 [F:HRTAT]FCYCRY       = [F:BPA]CRY
 [F:HRTAT]FCYTEL       = [F:BPA]TEL
Else
 #Erreur de lecture sur le fichier
 Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS",1) From GESECRAN
 Return
Endif
Read [F:CNT]CNT0=3;[F:FCY]FCY;[F:FCY]CNTNAM
If !fstat
 Read [F:AIN]AIN0=[F:FCY]CNTNAM
 If !fstat
  [F:HRTAT]FCYRPB    = [F:AIN]CNTLNA-[F:AIN]CNTFNA
  [F:HRTAT]FCYRPBFNC = [F:CNT]CNTFNC
  Read [BPA]BPA0=3;[F:FCY]FCY;[F:CNT]BPAADD
  If fstat= 0
   [F:HRTAT]PLCREF=[F:BPA]CTY
  Endif
 Endif
Endif
[F:HRTAT]DATREF = date$
Return

#############################################

$INFOS_CPY
[F:HRTAT]CPY = [F:FCY]LEGCPY
Read [CPY]CPY0=[F:FCY]LEGCPY
If !fstat
 Read [BPA]BPA0=2;[F:CPY]CPY;[F:CPY]BPAADD
 If !fstat
  [F:HRTAT]CPYADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [F:HRTAT]CPYADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [F:HRTAT]CPYADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [F:HRTAT]CPYPOSCOD    = [F:BPA]POSCOD
  [F:HRTAT]CPYCTY       = [F:BPA]CTY
  [F:HRTAT]CPYCRY       = [F:BPA]CRY
 Else
  #Erreur de lecture sur le fichier
  Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS",1) From GESECRAN
  Return
 Endif
Endif
Return

#############################################
$JOUR_REPRISE
#Jour de reprise (Régul)
Raz REPRISE
If GTPS=1
 Raz[F:TG2]
 ##**82073
 Filter [F:TG2] Where ((STRDAT<FINARRET & ENDDAT>FINARRET) | STRDAT>FINARRET) & REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM
&                     & evalue(CRITDAT) & NBRDAY>=0 & NBRHOU>=0 & !find([F:TG2]TIM,EVTAT,EVTATJ,EVTMAL)
 Read [F:TG2]TIG1 First
 Filter [F:TG2]
 If !fstat
  If [F:TG2]STRDAT<FINARRET & [F:TG2]ENDDAT>FINARRET
   [F:HRTAT]RCVDAT=FINARRET+1
  Else
   [F:HRTAT]RCVDAT=[F:TG2]STRDAT
  Endif
  REPRISE= [F:HRTAT]RCVDAT
  [F:HRTAT]FLGRCV=1
 Endif
Endif

#Jour de reprise
Raz [F:TP2]
##**82073
Filter [F:TP2] Where ((STRDAT<FINARRET & ENDDAT>FINARRET) | STRDAT>FINARRET) & REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM
&                    & evalue(CRITDAT) & !find([F:TP2]TIM,EVTAT,EVTATJ,EVTMAL)
Read [F:TP2]TIP1 First
Filter [F:TP2]
If !fstat
 If [F:TP2]STRDAT<FINARRET & [F:TP2]ENDDAT>FINARRET
  [F:HRTAT]RCVDAT=FINARRET+1
 Else
  [F:HRTAT]RCVDAT=[F:TP2]STRDAT
 Endif
 # si pas de régul ou date de reprise des temps<date de reprise de la régul, on prend la reprise des temps
 If REPRISE=[0/0/0] | REPRISE>[F:HRTAT]RCVDAT
  REPRISE = [F:HRTAT]RCVDAT
  [F:HRTAT]FLGRCV=1
 Else
  [F:HRTAT]RCVDAT = REPRISE
 Endif
Else
 [F:HRTAT]FLGRCV=2  :#Non repris à ce jour
Endif
Return

#############################################
$SALAIRES
# Remplissage du tableau A des salaires en fonction de la périodicité des payes du salarié
Raz TOTCOL4, TOTCOL5, TOTCOL6, TOTCOL7
J = 0
K = 0
#88414
#PERPAY = 0
#Raz FINPAYE
## 57997 : Ajout critère '& FLGOUT<>2'
###**82073
#Filter [VEP] Where EMP=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT) & PYRDAT<DEBARRET & FLGOUT<>2 Order By PYRDAT Desc
#For [VEP]
# If FINPAYE<>[0/0/0] & PERPAY=0
#  If FINPAYE-[F:VEP]PYRDAT=1                   : # Paiement journalier
#   PERPAY = 1
#  Elsif FINPAYE-[F:VEP]PYRDAT=7                : # Paiement hebdomadaire
#   PERPAY = 2
#  Elsif FINPAYE-[F:VEP]PYRDAT=15               : # Paiement à la quinzaine
#   PERPAY = 3
#  Elsif month(FINPAYE)-month([F:VEP]PYRDAT)=1  : # Paiement mensuel
#   PERPAY = 4
#  Elsif month(FINPAYE)-month([F:VEP]PYRDAT)<=3
#& &     month(FINPAYE)-month([F:VEP]PYRDAT)>1  : # Paiement trimestriel
#   PERPAY = 5
#  Elsif month(FINPAYE)-month([F:VEP]PYRDAT)>3
#   PERPAY = 6
#  Else
#   PERPAY = 4
#  Endif
# Endif
# If (PERPAY=1 & [F:VEP]PYRDAT<DEBARRET-30) | (PERPAY=2 & J=4) | (PERPAY=3 & J=2) | PERPAY=4
#& | (PERPAY=5 & [F:VEP]PYRDAT<DEBARRET-90)
#& | (PERPAY=6 & [F:VEP]PYRDAT<gdat$(day$(DEBARRET),month(DEBARRET),year(DEBARRET)-1))
#  Break
# Endif
# Gosub AJOUTPAYE
# FINPAYE = [F:VEP]PYRDAT
# J +=1
# If J>=dim([F:HRTAT]AMT1) : Break : Endif
#Next
#Filter [VEP]
#If FINPAYE=[0/0/0]
# # Dernière paye précédent l'absence, non valide
# Call ECR_TRACE([F:ID]REFNUM-[F:ID]NAM-":"-mess(16,10710,1),1) From GESECRAN
# #GOK=0
# Return
#Endif

#88414
Raz DATDEB, DATFIN, [F:TAT]STRDAT1(J), [F:TAT]ENDDAT1(J), [F:TAT]DAT1(J), [F:TAT]RATPFL(J)
DATFIN=eomonth(addmonth(DEBARRET,-1))
DATDEB=gdat$(1,month(DATFIN),year(DATFIN))
Filter [F:VEP] Where EMP=[F:ID]REFNUM  & PYRDAT>=DATDEB & PYRDAT<=DATFIN & CTRNUM=[F:HRCTR]CTRNUM & FLGOUT<>2 Order By PYRDAT
For [VEP]
  Gosub AJOUTPAYE
Next
[F:TAT]NBR1 = 1
#
Filter [VEP]

# Pour le calcul des cotisations en tableau B et C, on proratise par rapport aux cotisations du tableau A
#88414
#For I=0 To [F:HRTAT]NBR1-1
 TOTCOL4 += [F:HRTAT]AMT1(I)
 TOTCOL5 += [F:HRTAT]AMTAVN(I)
 TOTCOL6 += [F:HRTAT]AMTALC(I)
 TOTCOL7 += [F:HRTAT]AMTCTB1(I)
#Next

If (TOTCOL4+TOTCOL5+TOTCOL6)>0
 For K=0 To [F:HRTAT]NBR3-1
  #40496 : Ajout arr
  [F:HRTAT]AMTCTB3(K) = arr(([F:HRTAT]LOSSAL(K)*TOTCOL7)/(TOTCOL4+TOTCOL5+TOTCOL6),0.01)
 Next
Endif

Return


$AJOUTPAYE
[F:HRTAT]DAT1(J)    = [F:VEP]PYRDAT
[F:HRTAT]STRDAT1(J) = [F:VEP]STRDAT
#88414
#[F:HRTAT]STRDAT1(J) = [F:VEP]STRDAT
If [F:HRTAT]STRDAT1(J)=[0/0/0]
 [F:HRTAT]STRDAT1(J)=[F:VEP]STRDAT
Endif
#
For I=1 To NBRBRU
 Read [F:HSP]HSP3 = [F:VEP]BUL;RUBBRU(I);1
 If !fstat
  [F:HRTAT]AMT1(J) +=[F:HSP]AMT
 Endif
Next
For I=1 To NBRAVN
 Read [F:HSP]HSP3 = [F:VEP]BUL;RUBAVN(I);1
 If !fstat
  [F:HRTAT]AMTAVN(J) +=[F:HSP]AMT
 Endif
Next
For I=1 To NBRIND
 Read [F:HSP]HSP3 = [F:VEP]BUL;RUBIND(I);1
 If !fstat
  [F:HRTAT]AMTALC(J) +=[F:HSP]AMT
 Endif
Next
For I=1 To NBRCOT
 Read [F:HSP]HSP3 = [F:VEP]BUL;RUBCOT(I);1
 If !fstat
  [F:HRTAT]AMTCTB1(J) +=[F:HSP]AMT
 Endif
Next
For I=1 To NBRFRS
 Read [F:HSP]HSP3 = [F:VEP]BUL;RUBFRS(I);1
 If !fstat
  [F:HRTAT]CRGPFL(J) +=[F:HSP]AMT
 Endif
Next

#88414
#If [F:CTR1]DED>0
# [F:HRTAT]RATPFL(J) = [F:CTR1]DED
#Endif
Read [CTR1]CTR0=[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
If !fstat
 [F:HRTAT]RATPFL(J)=max([F:HRTAT]RATPFL(J),[F:CTR1]DED)
Endif
#[F:HRTAT]NBR1 += 1
#

## Remplissage du tableau C
Call PERTE_SAL(NBRABS,RUBABS,CODABS,TIMABS,K)
Call PERTE_SAL(NBRAT,RUBAT,CODAT,TIMAT,K)
Call PERTE_SAL(NBRCHO,RUBCHO,CODCHO,TIMCHO,K)
Call PERTE_SAL(NBRENT,RUBENT,CODENT,TIMENT,K)
Call PERTE_SAL(NBRMAL,RUBMAL,CODMAL,TIMMAL,K)
Call PERTE_SAL(NBRMAT,RUBMAT,CODMAT,TIMMAT,K)
Return


Subprog PERTE_SAL(NBRPERT,RUBPERT,CODPERT,EVTPERT,K)
Value    Integer NBRPERT
Value    Char    RUBPERT()(1..)
Value    Char    CODPERT
Value    Char    EVTPERT
Variable Integer K

Local Integer I

#88414
Local Integer I, OKENT
[L]OKENT=0
#

If K>=dim([F:HRTAT]GRD3) : End : Endif

Raz  [F:HRTAT]LOSSAL(K)    #88414

For I=1 To NBRPERT
 Read [F:HSP]HSP3 = [F:VEP]BUL;RUBPERT(I);1
 If !fstat
  [F:HRTAT]LOSSAL(K) += [F:HSP]AMT
 Endif
Next

If [F:HRTAT]LOSSAL(K)=0 : End : Endif
If [F:HRTAT]LOSSAL(K)<0
 [F:HRTAT]LOSSAL(K) *=-1
Endif

If EVTPERT<>""
 Raz [F:TP2]
 ##**82073
 #Filter [F:TP2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & DATPYR=[F:VEP]PYRDAT & TIM=EVTPERT & evalue(CRITDAT)
 Filter [F:TP2] Where REFNUM=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & TIM=EVTPERT & CTRDAT=[F:VEP]CTRDAT
 Read [TP2]TIP2 First
 Filter [F:TP2]
 If !fstat
  [F:HRTAT]STRDAT3(K) = [F:TP2]STRDAT
  [F:HRTAT]ENDDAT3(K) = [F:TP2]ENDDAT
 Endif
Elsif CODPERT="ENT"
#88414
# Filter [CTR1] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<=[F:VEP]PYRDAT
# Read [CTR1]CTR1 Last
# Filter [CTR1]
# If !fstat
#  [F:HRTAT]STRDAT3(K) = [F:VEP]STRDAT
#  [F:HRTAT]ENDDAT3(K) = [F:CTR1]CTRDAT
# Endif
Read [CTR1]CTR0=[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
 If !fstat
  # vrai sortie définitive sur la période
  If [F:CTR1]XITDAT<>[0/0/0] & [F:CTR1]XITFNL=2 & [F:CTR1]XITDAT<=[F:VEP]ENDDAT
   [L]OKENT=1
  Else
  # vrai entrée sur la période
  Filter [CTR1] Where REFNUM=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & CTRDAT<[F:VEP]CTRDAT
  Read [CTR1]CTR1 Last
  Filter [CTR1]
   If fstat |([F:CTR1]XITDAT<>[0/0/0] & [F:CTR1]XITFNL=2)
    [L]OKENT=1
   Endif
  Endif
 Endif
 If OKENT
  [F:HRTAT]STRDAT3(K) = [F:VEP]STRDAT
  [F:HRTAT]ENDDAT3(K) = [F:VEP]ENDDAT
 Endif
Endif
If OKENT
 [F:HRTAT]GRD3(K)     = CODPERT
 [F:HRTAT]FLGSAL(K)   = 1
 [F:HRTAT]NBR3 += 1
 K +=1
Endif
End


#############################################
$SUBROGATION
[F:HRTAT]ENAFLG=[M:DIA]ENAFLG
If [M:DIA]ENAFLG<>1     :# 1=Non
 [F:HRTAT]STRSBG=DEBARRET
 [F:HRTAT]ENDSBG=FINARRET
 Read [F:BAN]BAN0=[M:DIA]BANRGL
 If fstat=0
  [F:HRTAT]FCYBID    = [F:BAN]BIDNUM
  [F:HRTAT]FCYBIDCRY = [F:BAN]CRY
  [F:HRTAT]FCYCUR    = [F:BAN]CUR
  [F:HRTAT]DESBID    = [F:BAN]PAB1
 Else
  #Banque de règlement non définie
  Call ECR_TRACE([F:FCY]FCY-mess(9,10710,1),1) From GESECRAN
  #GOK=0
  Return
 Endif
Endif
Return

#############################################
$RAPPEL_SAL
# Remplissage du tableau B
# On prend la dernière feuille de paye où la rubrique est présente
J = 0
# 57997 : Ajout critère '& FLGOUT<>2'
##**82073
Link [HSP] With
&    [VEP]VEP5=[F:HSP]BUL
& As [LHSP]
& Where EMP=[F:ID]REFNUM & DAT<DEBARRET & find(RUB,RUBRAP(1..NBRRAP)) & TYP=1 & CTRNUM=[F:HRCTR]CTRNUM & [VEP]FLGOUT<>2
#& Where EMP=[F:ID]REFNUM & DAT<DEBARRET & find(RUB,RUBRAP(1..NBRRAP)) & TYP=1 & CTRNUM=[F:CTR]CTRNUM & evalue(CRITDAT) & [VEP]FLGOUT<>2

#88414
#For I=1 To NBRRAP
# Filter [LHSP] Where RUB=RUBRAP(I)
# Read[LHSP]HSP1 Last
# If !fstat
#  [F:HRTAT]DAT2(J)    = [F:HSP]DAT
#  [F:HRTAT]STRDAT2(J) = gdat$(day([F:HSP]DAT+1),month([F:HSP]DAT+1),year([F:HSP]DAT+1)-1)
#  [F:HRTAT]ENDDAT2(J) = [F:HSP]DAT
#  [F:HRTAT]AMT2(J)    = [F:HSP]AMT
#  If (TOTCOL4+TOTCOL5+TOTCOL6)>0
#   # 40496 : Ajout arr
#   [F:HRTAT]AMTCTB2(J) = arr(([F:HSP]AMT*TOTCOL7)/(TOTCOL4+TOTCOL5+TOTCOL6),0.01)
#  Endif
#  [F:HRTAT]NBR2 +=1
#  J +=1
# Endif
# Filter [LHSP]
# If J>=dim([F:HRTAT]DAT2) : Break : Endif
#Next

Local Integer NBMOIS
Local Date DATBULPRE
NBMOIS=0
Filter [F:VEP] Where EMP=[F:ID]REFNUM  & PYRDAT<DEBARRET & CTRNUM=[F:HRCTR]CTRNUM & FLGOUT<>2
Read [VEP]VEP0 Last
Filter [F:VEP]
If fstat=0
 Raz DATDEB, DATFIN
 DATFIN=gdat$(31,12,year([F:VEP]PYRDAT)-1)
 DATDEB=gdat$(1,01,year([F:VEP]PYRDAT)-1)
Endif
For [F:VEP]VEP0 Where EMP=[F:ID]REFNUM & PYRDAT>=DATDEB & PYRDAT<=DATFIN & CTRNUM=[F:HRCTR]CTRNUM & FLGOUT<>2
  For I=1 To NBRRAP
    If NBMOIS>3: Break: Endif
    Read [F:HSP]HSP3 = [F:VEP]BUL;RUBRAP(I);1
    If !fstat
      If DATBULPRE=[F:HSP]DAT
        [F:HRTAT]AMT2(NBMOIS) += [F:HSP]AMT
        If (TOTCOL4+TOTCOL5+TOTCOL6)>0
         [F:HRTAT]AMTCTB2(NBMOIS) += arr(([F:HSP]AMT*TOTCOL7)/(TOTCOL4+TOTCOL5+TOTCOL6),0.01)
        Endif
      Else
        [F:HRTAT]DAT2(NBMOIS)=[F:HSP]DAT
        [F:HRTAT]AMT2(NBMOIS) += [F:HSP]AMT
        [F:HRTAT]STRDAT2(NBMOIS)=DATDEB
        [F:HRTAT]ENDDAT2(NBMOIS)=DATFIN
        If (TOTCOL4+TOTCOL5+TOTCOL6)>0
         [F:HRTAT]AMTCTB2(NBMOIS) += arr(([F:HSP]AMT*TOTCOL7)/(TOTCOL4+TOTCOL5+TOTCOL6),0.01)
        Endif
        DATBULPRE=[F:HSP]DAT
        NBMOIS+=1
      Endif
    Endif
  Next
Next
[F:HRTAT]NBR2=NBMOIS
Return


