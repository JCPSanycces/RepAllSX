Subprog C_DATEND(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:DIA]DATSTR
#Période incorrecte
 GMESSAGE = mess(25,10702,1)
 mkstat = 2 : End
Endif
End

## DBA le 13/07/2004 : Sugg 22606 -> rendre paramètrable la banque pour
## la subrogation.
Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR
If VALEUR<>1
 Actzo [M:DIA]BANRGL
Else
 Effzo [M:DIA]BANRGL
 Grizo [M:DIA]BANRGL
Endif
Affzo [M:DIA]BANRGL
End

