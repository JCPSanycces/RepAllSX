#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################################
# UUMGPOSCDA01   Moulinette de Migration des contremarques   Module Common Data #
#################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0 :  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSCDA01") From LECFIC
  Endif

  Call MAJ_UUMGPOSCDA01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

###################################################################################
## GH 20/05/2014 bug 100128

Subprog RAZ_UUMGPOSCDA01(DOSSIER)
Value Char DOSSIER

Local Integer ERR

Call MIGRAZKEY(DOSSIER,"UUMGPOSCDA01",ERR) From TRTMIG
End

###################################################################################
Subprog MAJ_UUMGPOSCDA01(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSSUB.ISHISTFOLD(DOSSIER)
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCDA01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# 90029
#----- Récupération du n° de version
Local Char CVERSION(3)
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCDA01",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

# Issue 106947 - 20150811 by LD : Migration of historic folder
Gosub MIG_OUVRE From TRTMIG
# Issue 106947 - 20150811 by LD

# La moulinette de postmigration concerne la création des affectations pour les contremarques
# Elle doit se faire uniquement lors du passage en V6
# Gbn.X3-15185 Modification of the execution condition. This process has to be executed even if the source folder
#              version is greater than V6.

Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCDA01",2,ERR) From TRTMIG : #2=En cours

If VERSION<GMIGX3VER112
    Call EXE_UTITC72(DOSSIER) From UTITC72
Endif

Call MIGTRTEND (DOSSIER,"UUMGPOSCDA01") From TRTMIG
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGPOSCDA01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGPOSCDA01(APPLI)
End

