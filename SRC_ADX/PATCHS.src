#<AdxTL>@(#)6.0.0.0 $Revision$
###################################################################
## Intégration sélective de patch de paye
###################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"PATCHS","PATCHP","PATCHP",3,"") From GTRAITE
End
###################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "DEBUT"     : Gosub DEBUT
 When "END"       : Gosub FIN
 When "OK"        : Gosub OK
 When "EDI"       : Gosub IMPRIME
 When "FINSAI"    : Gosub FINSAI
 When "SETBOUT"   : Gosub SETBOUT
Endcase
Return

###################################################################
$OUVRE
If [M:DIA]INTSEL<>2 or GSERVEUR
 FIN = 1
 # SBA FQ92041 - US1927
Else
  Gosub VAR_LOCALFILE From PATCHP
  Gosub GET_LOCALFILE From PATCHP
  # ne sert à rien mais sécurisation si on ajoute du code après
   If STAT : Return : Endif
# SBA fin
Endif
Return

$DEBUT
GCURLEG="FRA" : #For the moment...
# SBA FQ92041 - US1927 : variables déclarées dans GET_LOCALFILE
#Call LIRE_PATCH
Call LIRE_PATCH(WFICHIER,WFICCLI)
Return

$SETBOUT
CHBOU += "I"
Return

$FIN
OK = 2 : Call ABANDON(OK) From GESECRAN
If OK<>2 : FIN = 0 : Endif
Return

$OK
OK = 2 : Call OUINON(mess(138,10703,1),OK) From GESECRAN : # Intégration mise à jour
If OK<>2 : FIN = 0 : Endif
Return

$FINSAI
If GSTATUT<>GSTAOK or [M:DIA]INTSEL<>2 : Return : Endif
J = 0
OK = 1
For I=0 To [M:PS1]NBLIG-1
 If [M:PS1]SEL(I)=2
  If J<dim([M:DIA]OBJET)-1
   [M:DIA]OBJET(J) = num$([M:PS1]NUM(I))-"RUB"-[M:PS1]RUB(I)
   J += 1
  Else
   OK = 0 : Break
  Endif
 Endif
Next I
If !OK : Goto ERRSAI : Endif
For I=0 To [M:PS2]NBLIG-1
 If [M:PS2]SEL(I)=2
  If J<dim([M:DIA]OBJET)-1
   [M:DIA]OBJET(J) = num$([M:PS2]NUM(I))-"VRA"-[M:PS2]VRA(I)
   J += 1
  Else
   OK = 0 : Break
  Endif
 Endif
Next I
If !OK : Goto ERRSAI : Endif
For I=0 To [M:PS3]NBLIG-1
 If [M:PS3]SEL(I)=2
  If J<dim([M:DIA]OBJET)-1
   [M:DIA]OBJET(J) = num$([M:PS3]NUM(I))-"CUM"-[M:PS3]CUM(I)
   J += 1
  Else
   OK = 0 : Break
  Endif
 Endif
Next I
If !OK : Goto ERRSAI : Endif
For I=0 To [M:PS4]NBLIG-1
 If [M:PS4]SEL(I)=2
  If J<dim([M:DIA]OBJET)-1
   [M:DIA]OBJET(J) = num$([M:PS4]NUM(I))-"VLA"-[M:PS4]VRA(I)
   J += 1
  Else
   OK = 0 : Break
  Endif
 Endif
Next I
If !OK : Goto ERRSAI : Endif
For I=0 To [M:PS5]NBLIG-1
 If [M:PS5]SEL(I)=2
  If J<dim([M:DIA]OBJET)-1
   [M:DIA]OBJET(J) = num$([M:PS5]NUM(I))-[M:PS5]TUN(I)-[M:PS5]COD(I)
   J += 1
  Else
   OK = 0 : Break
  Endif
 Endif
Next I
If !OK : Goto ERRSAI : Endif
[M:DIA]NBOBJ = J
Return

$ERRSAI
Call ERREUR(mess(140,10703,1)) From GESECRAN : # Trop d'objets à mettre à jour
GSTATUT = GSTAESC
Return

$IMPRIME
Local Char    LIGNE(250) , TBPAR(10)(1..5) , TBVAL(10)(1..5)
Local Clbfile CLOB(4)
Call OUVRE_TRACE(mess(55,100,1)-[M:PS0]FIC) From LECFIC : # Fichier
For I=1 To [M:PSC]NBPATCH
 Setlob CLOB With [M:PSC]TEX([M:PSC]DEBCOM(I)..[M:PSC]FINCOM(I))
 If len(CLOB)>0
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(mess(55,100,1)-[M:PSC]FICHIER(I),0) From GESECRAN
  Call ECR_TRACE(string$(len(mess(55,100,1))+1+len([M:PSC]FICHIER(I)),"-"),0) From GESECRAN
  Wrseq CLOB
 Endif
Next I
Call ECR_TRACE("",0) From GESECRAN
LIGNE  = format$("K:30X",mess(141,10703,1)) : # Objet
LIGNE += format$("K:30X",mess(142,10703,1)) : # Champ
LIGNE += format$("K:32X",mess(143,10703,1)) : # Ancienne valeur
LIGNE += format$("K:32X",mess(144,10703,1)) : # Nouvelle valeur
Call ECR_TRACE(LIGNE,0) From GESECRAN
LIGNE  = format$("K:30X",string$(len(mess(141,10703,1)),"-"))
LIGNE += format$("K:30X",string$(len(mess(142,10703,1)),"-"))
LIGNE += format$("K:32X",string$(len(mess(143,10703,1)),"-"))
LIGNE += format$("K:32X",string$(len(mess(144,10703,1)),"-"))
Call ECR_TRACE(LIGNE,0) From GESECRAN
For I=0 To [M:PSD]NBLIG-1
 LIGNE  = format$("K:30X",[M:PSD]OBJ(I))
 LIGNE += format$("K:30X",[M:PSD]FLD(I))
 J = max(len([M:PSD]ANC(I)),len([M:PSD]NOU(I)))
 For K=1 To int((J-1)/30)+1
  If K>1 : LIGNE = space$(60) : Endif
  LIGNE += format$("K:32X",seg$([M:PSD]ANC(I),30*K-29,30*K))
  LIGNE += format$("K:32X",seg$([M:PSD]NOU(I),30*K-29,30*K))
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Next K
Next I
Call FERME_TRACE From LECFIC
TBPAR(1) = "nomfic" : TBVAL(1) = GTRACE
TBPAR(2) = "erreur" : TBVAL(2) = "1"
Call ETAT("ATRACEPAYS",GFONCTION,TBPAR,TBVAL) From ETAT
Return

########################################################################
## Lecture du patch
########################################################################

##*****************************************************************#
# SBA FQ92041 - US1927
# Ajout de deux paramètres pour gérer le poste local
#Subprog LIRE_PATCH
Subprog LIRE_PATCH(FICBASE,FICCLI)
Value    Char    FICBASE
Value    Char    FICCLI
Gosub DECLARE From PATCHP
APPLI = nomap
Gosub OUVFIC From PATCHP
# SBA FQ92041 - US1927
# Local Char    FICBASE(250) , CHPDES(GLONADC)
Local Integer DIFF , TYPVAL , IDIF , CALRUB
Local Char    OLDVAL(80) , NEWVAL(80) , TDIFF(80)
Local Char    FILDIF(GLONATB) , ABRDIF(5) , TITDIF(GLONDES) , ACTDIF(GLONACV)
Local Integer OKRUB , OKVRA , OKCUM , OKVAL , OKDIV , OKCOM
Call TEMPON("L") From GESECRAN

# SBA FQ92041 - US1927
If find(right$(FICBASE,len(FICBASE)),"\","/")
 FICBASE = left$(FICBASE,len(FICBASE)-1)
Endif
Call EXISTE(FICBASE,TYPFIC) From ORDSYS
#Call EXISTE([M:DIA]FICHIER,TYPFIC) From ORDSYS
# SBA fin
Case TYPFIC
 When 2       : # C'est un répertoire
  #FICBASE = [M:DIA]FICHIER : # SBA FQ92041 - US1927
  EXT = "pay"
  Call SYSTEME2("",'lsadx -a'-nomap-'"'+FICBASE+'"'-EXT,"",NBTRAIT,TRAIT) From ORDSYS
  If NBTRAIT>=dim(TRAIT)
   Call ERREUR(mess(154,10703,1)-num$(NBTRAIT)+"/"+num$(dim(TRAIT))) From GESECRAN
#              Trop de fichiers
   NBTRAIT = dim(TRAIT)
  Endif
 When 1       : # C'est un fichier normal
  NBTRAIT  = 1
  # SBA FQ92041 - US1927
  # ajout
  #Call REPERT([M:DIA]FICHIER,FICBASE,TRAIT(1),EXT) From PATCH
  If FICCLI<>""
   Call SETNAM(FICCLI,TRAIT(1),EXT) From GOBJTXT
  Else
   #Call REPERT(FICBASE,FICBASE,TRAIT(1),EXT)
  Call REPERT(FICBASE,FICBASE,TRAIT(1),EXT) From PATCH
  Endif
 When Default : # Ca n'existe pas
  Return
Endcase
Raz [M:PS0]
Raz [M:PS1]
Raz [M:PS2]
Raz [M:PS3]
Raz [M:PS4]
Raz [M:PS5]
Raz [M:PSC]
Raz [M:PSD]
OKRUB = 1
OKVRA = 1
OKCUM = 1
OKVAL = 1
OKDIV = 1
OKCOM = 1
 # SBA FQ92041 - US1927
If FICCLI<>""
  [M:PS0]FIC     = FICCLI
Else
  [M:PS0]FIC     = [M:DIA]FICHIER
Endif
# SBA fin
[M:PS0]NBFIC   = NBTRAIT
[M:PSC]NBPATCH = NBTRAIT
For I=1 To NBTRAIT
  # SBA FQ92041 - US1927
  # si poste local path ok
  #FICPATCH = filpath(FICBASE,TRAIT(I),EXT)
  If(FICCLI<>"")
   FICPATCH = FICBASE
 Else
    FICPATCH = filpath(FICBASE,TRAIT(I),EXT)
 Endif
 # SBA fin
 [M:PSC]FICHIER(I) = TRAIT(I)
 Openi FICPATCH
 adxifs = ","
 adxirs = chr$(10)
 Gosub LIRE From PATCHP
 If fstat or TYPENR<>1
  Openi : Break
 Endif
 Gosub LIRE From PATCHP
 NBACT = 0
 While CHAMP(4)<>""
  NBACT += 1
  K = instr(1,CHAMP(4),"/")
  If K
   ACTIV(NBACT) = left$(CHAMP(4),K-1)
   CHAMP(4)     = right$(CHAMP(4),K+1)
  Else
   ACTIV(NBACT) = CHAMP(4)
   CHAMP(4)     = ""
  Endif
 Wend
 While !fstat & TYPENR<>8
  TYPOBJ = CHAMP(1)
  NOMOBJ = vireblc(format$("KT:80X",CHAMP(2)),2)
  Gosub CHAMP_SPE
  Case TYPOBJ
   When "CMT"   : Gosub COMMENT
   When "RUB"   : Gosub RUBRIQUE
   When "VRA"   : Gosub VARIA
   When "VLA"   : Gosub VALEUR
   When "CUM"   : Gosub CUMUL
   When "EXO"   : Gosub EXO
   When "DCH"   : Gosub CHARGES
   When "FTD"   : Gosub TDS
   When "ADV"   : Gosub TABDIV
   When "ADP"   : Gosub PARAM
   When "TIM"   : If GTPS
                   Gosub TEMPS
                  Else
                   Gosub FIN_OBJ From PATCHP
                  Endif
   When Default : Gosub FIN_OBJ From PATCHP
  Endcase
  Gosub LIRE From PATCHP
 Wend
 Openi
Next I
Call TEMPOFF From GESECRAN
Affzo [PS0]
Affzo [PS1]
Affzo [PS2]
Affzo [PS3]
Affzo [PS4]
Affzo [PS5]
Affzo [PSD]
End

$COMMENT
NBLIG = val(CHAMP(2))
If NBLIG & OKCOM
 [M:PSC]DEBCOM(I) = [M:PSC]PTCOM+1
 For J=1 To NBLIG
  Getseq 64,LIG64
  If [M:PSC]PTCOM<dim([M:PSC]TEX)-1
   [M:PSC]PTCOM += 1
   [M:PSC]TEX([M:PSC]PTCOM) = LIG64
  Else
   Call ERREUR(mess(145,10703,1)) From GESECRAN : # Trop de commentaires
   OKCOM = 0
   Break
  Endif
 Next J
 [M:PSC]FINCOM(I) = [M:PSC]PTCOM
Endif
Rdseq LIG64
Gosub LIRE From PATCH
Return

$RUBRIQUE
If OKRUB & [M:PS1]NBLIG<dim([M:PS1]RUB)
 [M:PS1]RUB([M:PS1]NBLIG) = NOMOBJ
 [M:PS1]AVT([M:PS1]NBLIG) = CHAMP(3)
 [M:PS1]APR([M:PS1]NBLIG) = CHAMP(4)
 [M:PS1]SEL([M:PS1]NBLIG) = 2
 [M:PS1]NUM([M:PS1]NBLIG) = I
 Read [RUB]RUB0 = GCURLEG;NOMOBJ
 If fstat
  [M:PS1]NOU([M:PS1]NBLIG) = 2
 Else
  [M:PS1]NOU([M:PS1]NBLIG) = 1
  If [F:RUB]CODACT<>"" & !find([F:RUB]CODACT,ACTIV(1..NBACT))
   [M:PS1]ACT([M:PS1]NBLIG) = [F:RUB]CODACT
   [M:PS1]SEL([M:PS1]NBLIG) = 1
  Endif
 Endif
 DIFF = 0
 Repeat
  Gosub LIRE From PATCHP
  If fstat : Break : Endif
  If TYPENR=4
   If CHAMP(1)="ROW"
    [M:PS1]ROW([M:PS1]NBLIG) = val(CHAMP(3))
   Elsif CHAMP(1)="DES"
    [M:PS1]DES([M:PS1]NBLIG) = CHAMP(3)
   Endif
   If [M:PS1]NOU([M:PS1]NBLIG)=1
    FILDIF = "RUBRIQUE"
    ABRDIF = "RUB"
    TITDIF = mess(55,10702,1) : # Rubrique
    Gosub DIFFERENCE
   Endif
  Elsif TYPENR=3 & CHAMP(1)="CRB" & [M:PS1]NOU([M:PS1]NBLIG)=1
   Read [PRF]PRF0 = [F:RUB]LEG;CHAMP(2)
   If !fstat
    Read [CRB]CRB0 = [F:RUB]COD;CHAMP(2);[F:RUB]LEG
    If fstat & val(CHAMP(3))>0
     CALRUB = 1
    Elsif !fstat & val(CHAMP(3))=0
     CALRUB = 2
    Else
     CALRUB = 0
    Endif
    If CALRUB & [M:PSD]NBLIG<dim([M:PSD]OBJ)
     If !DIFF
      [M:PSD]TYPOBJ([M:PSD]NBLIG) = TYPOBJ-NOMOBJ
      [M:PSD]OBJ([M:PSD]NBLIG) = TITDIF-NOMOBJ
     Endif
     Case CALRUB
      When 1
       [M:PSD]FLD([M:PSD]NBLIG) = mess(155,10703,1) : # Ajout du profil
       [M:PSD]NOU([M:PSD]NBLIG) = CHAMP(2)
      When 2
       [M:PSD]FLD([M:PSD]NBLIG) = mess(156,10703,1) : # Suppression du profil
       [M:PSD]ANC([M:PSD]NBLIG) = CHAMP(2)
     Endcase
     DIFF = 1
     [M:PSD]NBLIG += 1
    Endif
   Endif
  Endif
 Until TYPENR=7
 [M:PS1]NBLIG += 1
 If DIFF & [M:PSD]NBLIG<dim([M:PSD]OBJ)
  [M:PSD]NBLIG += 1
 Endif
Else
 Call ERREUR(mess(146,10703,1)) From GESECRAN : # Trop de rubriques
 OKRUB = 0
Endif
Return

$VARIA
If OKVRA & [M:PS2]NBLIG<dim([M:PS2]VRA)
 [M:PS2]VRA([M:PS2]NBLIG) = NOMOBJ
 [M:PS2]SEL([M:PS2]NBLIG) = 2
 [M:PS2]NUM([M:PS2]NBLIG) = I
 Read [VRA]VRA0 = GCURLEG;NOMOBJ
 If fstat
  [M:PS2]NOU([M:PS2]NBLIG) = 2
 Else
  [M:PS2]NOU([M:PS2]NBLIG) = 1
  If [F:VRA]CODACT<>"" & !find([F:VRA]CODACT,ACTIV(1..NBACT))
   [M:PS2]ACT([M:PS2]NBLIG) = [F:VRA]CODACT
   [M:PS2]SEL([M:PS2]NBLIG) = 1
  Endif
 Endif
 DIFF = 0
 Repeat
  Gosub LIRE From PATCHP
  If fstat : Break : Endif
  If TYPENR=4
   If CHAMP(1)="DES"
    #[M:PS2]DES([M:PS2]NBLIG) = CHAMP(3)
    Call MAJTEXTRA(CHAMP(3),"VARIA","DES",GCURLEG,NOMOBJ) From ATEXTRA
    Call LECTEXTRA([M:PS2]DES([M:PS2]NBLIG),"VARIA","DES",GCURLEG,NOMOBJ) From ATEXTRA
   Endif
   If [M:PS2]NOU([M:PS2]NBLIG)=1
    FILDIF = "VARIA"
    ABRDIF = "VRA"
    TITDIF = mess(118,10702,1) : # Variable
    Gosub DIFFERENCE
   Endif
  Endif
 Until TYPENR=7
 [M:PS2]NBLIG += 1
 If DIFF & [M:PSD]NBLIG<dim([M:PSD]OBJ)
  [M:PSD]NBLIG += 1
 Endif
Else
 Call ERREUR(mess(147,10703,1)) From GESECRAN : # Trop de variables
 OKVRA = 0
Endif
Return

$CUMUL
If OKCUM & [M:PS3]NBLIG<dim([M:PS3]CUM)
 [M:PS3]CUM([M:PS3]NBLIG) = NOMOBJ
 [M:PS3]SEL([M:PS3]NBLIG) = 2
 [M:PS3]NUM([M:PS3]NBLIG) = I
 Read [CUM]CUM0 = GCURLEG;NOMOBJ
 If fstat
  [M:PS3]NOU([M:PS3]NBLIG) = 2
 Else
  [M:PS3]NOU([M:PS3]NBLIG) = 1
  If [F:CUM]CODACT<>"" & !find([F:CUM]CODACT,ACTIV(1..NBACT))
   [M:PS3]ACT([M:PS3]NBLIG) = [F:CUM]CODACT
   [M:PS3]SEL([M:PS3]NBLIG) = 1
  Endif
 Endif
 DIFF = 0
 Repeat
  Gosub LIRE From PATCHP
  If fstat : Break : Endif
  If TYPENR=4
   If CHAMP(1)="CUMDES"
    [M:PS3]DES([M:PS3]NBLIG) = CHAMP(3)
   Endif
   If [M:PS3]NOU([M:PS3]NBLIG)=1
    FILDIF = "CUMUL"
    ABRDIF = "CUM"
    TITDIF = mess(82,10702,1) : # Cumul
    Gosub DIFFERENCE
   Endif
  Endif
 Until TYPENR=7
 [M:PS3]NBLIG += 1
 If DIFF & [M:PSD]NBLIG<dim([M:PSD]OBJ)
  [M:PSD]NBLIG += 1
 Endif
Else
 Call ERREUR(mess(148,10703,1)) From GESECRAN : # Trop de cumuls
 OKCUM = 0
Endif
Return

$VALEUR
If OKVAL & [M:PS4]NBLIG<dim([M:PS4]VRA)
 [M:PS4]VRA([M:PS4]NBLIG) = NOMOBJ
 [M:PS4]SEL([M:PS4]NBLIG) = 2
 [M:PS4]NUM([M:PS4]NBLIG) = I
 Read [VRA]VRA0 = GCURLEG;NOMOBJ
 If !fstat
  #[M:PS4]DES([M:PS4]NBLIG) = [F:VRA]DES
  Call LECTEXTRA([M:PS4]DES([M:PS4]NBLIG),"VARIA","DES",GCURLEG,NOMOBJ) From ATEXTRA
 Else
  [M:PS4]DES([M:PS4]NBLIG) = "<"+mess(149,10703,1)+">" : # Nouvelle Variable
 Endif
 Repeat
  Gosub LIRE From PATCHP
  If fstat : Break : Endif
  If TYPENR=4 & CHAMP(1)="DAT"
   [M:PS4]DA2([M:PS4]NBLIG) = gdat$(CHAMP(3))
  Elsif TYPENR=4 & CHAMP(1)="VARVAL"
   [M:PS4]NOU([M:PS4]NBLIG) = val(CHAMP(3))
  Endif
 Until TYPENR=7
 Filter [VLA] Where TYP=1 & LEG=GCURLEG & CPY="" & FCY="" & EMP="" & VARCOD=NOMOBJ & BUL=""
& Order By Key CLE=TYP;CPY;FCY;EMP;VARCOD;DAT
 Read [VLA]CLE Last
 If fstat<=2
  [M:PS4]DA1([M:PS4]NBLIG) = [F:VLA]DAT
  [M:PS4]ANC([M:PS4]NBLIG) = [F:VLA]VARVAL
 Endif
 Filter [VLA]
 [M:PS4]NBLIG += 1
Else
 Call ERREUR(mess(150,10703,1)) From GESECRAN : # Trop de valeurs
 OKVAL = 0
Endif
Return

$EXO
[M:PS5]TUN([M:PS5]NBLIG) = "EXO"
[M:PS5]TYP([M:PS5]NBLIG) = mess(98,10702,1) : # Exonération
FILDIF = "EXOPAY"
ABRDIF = "EXO"
TITDIF = mess(98,10702,1) : # Exonération
Read [EXO]EXO0(2) = GCURLEG;NOMOBJ
Goto DIVERS

$CHARGES
[M:PS5]TUN([M:PS5]NBLIG) = "DCH"
[M:PS5]TYP([M:PS5]NBLIG) = mess(102,10702,1) : # Déclaration de charges
FILDIF = "DECCHARGE"
ABRDIF = "DCH"
TITDIF = mess(124,10702,1) : # Charge
CHPDES = "DESDCC"
Read [DCH]DCH0 = NOMOBJ
Goto DIVERS

$TDS
[M:PS5]TUN([M:PS5]NBLIG) = "FTD"
[M:PS5]TYP([M:PS5]NBLIG) = mess(125,10702,1) : # DADS-U
FILDIF = "HRFILTDS"
ABRDIF = "FTD"
TITDIF = mess(125,10702,1) : # DADS-U
CHPDES = "DESREC"
#Read [FTD]FTD0 = NOMOBJ
Read [FTD]FTD0 = val(NOMOBJ)
Goto DIVERS

$TABDIV
[M:PS5]TUN([M:PS5]NBLIG) = "ADV"
[M:PS5]TYP([M:PS5]NBLIG) = mess(63,139,1) : # Table diverse
FILDIF = "ATABTAB"
ABRDIF = "ADV"
TITDIF = mess(63,139,1) : # Table diverse
CHPDES = "LNGDES"
Read [ADV]CODE = val(NOMOBJ)
Goto DIVERS

$PARAM
[M:PS5]TUN([M:PS5]NBLIG) = "ADP"
[M:PS5]TYP([M:PS5]NBLIG) = mess(81,123,1) : # Paramètre
FILDIF = "ADOPAR"
ABRDIF = "ADP"
TITDIF = mess(81,123,1) : # Paramètre
CHPDES = "NAM"
Read [ADP]ADP1 = NOMOBJ
Goto DIVERS

$TEMPS
[M:PS5]TUN([M:PS5]NBLIG) = "TIM"
[M:PS5]TYP([M:PS5]NBLIG) = mess(128,10702,1) : # Evénement temps
FILDIF = "TIMCOD"
ABRDIF = "TIM"
TITDIF = mess(128,10702,1) : # Evénement temps
CHPDES = "DES"
Read [TIM]TIM0 = NOMOBJ
Goto DIVERS

$DIVERS
If OKDIV & [M:PS5]NBLIG<dim([M:PS5]COD)
 If fstat
  [M:PS5]NOU([M:PS5]NBLIG) = 2
 Else
  [M:PS5]NOU([M:PS5]NBLIG) = 1
  If evalue("dim([F:"+ABRDIF+"]CODACT)")>0
   ACTDIF = evalue("[F:"+ABRDIF+"]CODACT")
   If ACTDIF<>"" & !find(ACTDIF,ACTIV(1..NBACT))
    [M:PS5]ACT([M:PS5]NBLIG) = ACTDIF
    [M:PS5]SEL([M:PS5]NBLIG) = 1
   Endif
  Endif
 Endif
 [M:PS5]COD([M:PS5]NBLIG) = NOMOBJ
 [M:PS5]SEL([M:PS5]NBLIG) = 2
 [M:PS5]NUM([M:PS5]NBLIG) = I
 DIFF = 0
 IDIF = 1
 Repeat
  Gosub LIRE From PATCHP
  If fstat : Break : Endif
  If TYPENR=3
   IDIF = 0
  Endif
  If TYPENR=4
   If CHAMP(1)=CHPDES
    [M:PS5]DES([M:PS5]NBLIG) = CHAMP(3)
   Endif
   If [M:PS5]NOU([M:PS5]NBLIG)=1
    If IDIF
     Gosub DIFFERENCE
    Elsif FILDIF="ATABTAB" & CHAMP(1)="CODE"
     Read [ADI]CODE = val(NOMOBJ);CHAMP(3)
     If fstat
      If !DIFF
       [M:PSD]TYPOBJ([M:PSD]NBLIG) = TYPOBJ-NOMOBJ
       [M:PSD]OBJ([M:PSD]NBLIG) = TITDIF-NOMOBJ
      Endif
      [M:PSD]FLD([M:PSD]NBLIG) = mess(151,10703,1) : # Nouveau code
      [M:PSD]NOU([M:PSD]NBLIG) = CHAMP(3)
      [M:PSD]NUM([M:PSD]NBLIG) = I
      [M:PSD]NBLIG += 1
      DIFF = 1
     Endif
    Endif
   Endif
  Elsif TYPENR=5 & CHAMP(1)=CHPDES & [M:PS5]DES([M:PS5]NBLIG)=""
   [M:PS5]DES([M:PS5]NBLIG) = CHAMP(3)
  Elsif TYPENR=9 & CHAMP(1)=CHPDES & [M:PS5]DES([M:PS5]NBLIG)=""
   [M:PS5]DES([M:PS5]NBLIG) = CHAMP(3)
  Elsif FILDIF="ATABTAB" & TYPENR=9 & CHAMP(1)="LNGDES"
&     & [M:PSD]NBLIG>0 & [M:PSD]NOU([M:PSD]NBLIG-1)=CHAMP(6)
   [M:PSD]NOU([M:PSD]NBLIG-1) -= CHAMP(3)
  Endif
 Until TYPENR=7
 [M:PS5]NBLIG += 1
 If DIFF & [M:PSD]NBLIG<dim([M:PSD]OBJ)
  [M:PSD]NBLIG += 1
 Endif
Else
 Call ERREUR(mess(152,10703,1)) From GESECRAN : # Trop d'objets divers
 OKDIV = 0
Endif
Return

$DIFFERENCE
If !find(CHAMP(1),CHPSPE(1..NBSPE))
 TYPVAL = evalue("type([F:"+ABRDIF+"]"+CHAMP(1)+")")
 Case TYPVAL
  When 1,2,4,5,6,7,8,9
   #77170
   If evalue("dim([F:"+ABRDIF+"]"+CHAMP(1)+")")>val(CHAMP(2))
    OLDVAL = num$(evalue("[F:"+ABRDIF+"]"+CHAMP(1)+"("+CHAMP(2)+")"))
   Else
    OLDVAL=""
   Endif
   NEWVAL = num$(val(CHAMP(3)))
  When 3
   #77170
   If evalue("dim([F:"+ABRDIF+"]"+CHAMP(1)+")")>val(CHAMP(2))
    OLDVAL = format$("D:"+GFMDAT4,evalue("[F:"+ABRDIF+"]"+CHAMP(1)+"("+CHAMP(2)+")"))
   Else
    OLDVAL="[0/0/0]"
   Endif
   NEWVAL = format$("D:"+GFMDAT4,gdat$(CHAMP(3)))
  When Default
   #77170
   If evalue("dim([F:"+ABRDIF+"]"+CHAMP(1)+")")>val(CHAMP(2))
    OLDVAL = evalue("[F:"+ABRDIF+"]"+CHAMP(1)+"("+CHAMP(2)+")")
   Else
    OLDVAL=""
   Endif
   NEWVAL = CHAMP(3)
 Endcase
 If OLDVAL<>NEWVAL & [M:PSD]NBLIG<dim([M:PSD]OBJ)
  If !DIFF
   [M:PSD]TYPOBJ([M:PSD]NBLIG) = TYPOBJ-NOMOBJ
   [M:PSD]OBJ([M:PSD]NBLIG) = TITDIF-NOMOBJ
  Endif
  [M:PSD]FLD([M:PSD]NBLIG) = CHAMP(1)
  If val(CHAMP(2))<>0
   [M:PSD]FLD([M:PSD]NBLIG) += "("+CHAMP(2)+")"
  Endif
  Read [ATZ]CODZONE = FILDIF;CHAMP(1)
  If !fstat
   Call TEXTE([F:ATZ]NOCOURT,TDIFF) From OBJDIV
   [M:PSD]FLD([M:PSD]NBLIG) -= TDIFF
  Endif
  [M:PSD]ANC([M:PSD]NBLIG) = OLDVAL
  [M:PSD]NOU([M:PSD]NBLIG) = NEWVAL
  [M:PSD]NUM([M:PSD]NBLIG) = I
  [M:PSD]NBLIG += 1
  DIFF = 1
 Endif
Endif
Return

##########################################################################
## Champs non modifiés par les patchs
##########################################################################
$CHAMP_SPE
Local Integer NBSPE
Local Char    CHPSPE(GLONADC)(1..100)
NBSPE = 0
NBSPE += 1 : CHPSPE(NBSPE) = "CREDAT"
NBSPE += 1 : CHPSPE(NBSPE) = "UPDDAT"
NBSPE += 1 : CHPSPE(NBSPE) = "CRETIM"
NBSPE += 1 : CHPSPE(NBSPE) = "UPDTIM"
NBSPE += 1 : CHPSPE(NBSPE) = "CREUSR"
NBSPE += 1 : CHPSPE(NBSPE) = "UPDUSR"
NBSPE += 1 : CHPSPE(NBSPE) = "EXPNUM"
# SBA FQ92041 - US1927
NBSPE += 1 : CHPSPE(NBSPE) = "CREDATTIM"
NBSPE += 1 : CHPSPE(NBSPE) = "UPDDATTIM"
NBSPE += 1 : CHPSPE(NBSPE) = "AUUID"
Case TYPOBJ
 When "RUB"
  NBSPE += 1 : CHPSPE(NBSPE) = "DES"
  NBSPE += 1 : CHPSPE(NBSPE) = "DESSHO"
  NBSPE += 1 : CHPSPE(NBSPE) = "CODACC"
  NBSPE += 1 : CHPSPE(NBSPE) = "LFEBEF"
  NBSPE += 1 : CHPSPE(NBSPE) = "LFEAFT"
  NBSPE += 1 : CHPSPE(NBSPE) = "PRNFLG"
  NBSPE += 1 : CHPSPE(NBSPE) = "NBRACC"
  NBSPE += 1 : CHPSPE(NBSPE) = "SAC"
  NBSPE += 1 : CHPSPE(NBSPE) = "ACC"
  NBSPE += 1 : CHPSPE(NBSPE) = "TYPAMT"
  NBSPE += 1 : CHPSPE(NBSPE) = "SNS"
  NBSPE += 1 : CHPSPE(NBSPE) = "DETEMP"
  #NBSPE += 1 : CHPSPE(NBSPE) = "CUMNUM"
  NBSPE += 1 : CHPSPE(NBSPE) = "CUMNUMADI"
  NBSPE += 1 : CHPSPE(NBSPE) = "DESPRN"
  #59176
  NBSPE += 1 : CHPSPE(NBSPE) = "CODGRP"
  NBSPE += 1 : CHPSPE(NBSPE) = "TYPMAS"
 When "VRA"
  NBSPE += 1 : CHPSPE(NBSPE) = "DES"
  NBSPE += 1 : CHPSPE(NBSPE) = "DESSHO"
  NBSPE += 1 : CHPSPE(NBSPE) = "PAGFDR"
  NBSPE += 1 : CHPSPE(NBSPE) = "ROWFDR"
  NBSPE += 1 : CHPSPE(NBSPE) = "PAGCPY"
  NBSPE += 1 : CHPSPE(NBSPE) = "ROWCPY"
  NBSPE += 1 : CHPSPE(NBSPE) = "PAGFCY"
  NBSPE += 1 : CHPSPE(NBSPE) = "ROWFCY"
  NBSPE += 1 : CHPSPE(NBSPE) = "PAGEMP"
  NBSPE += 1 : CHPSPE(NBSPE) = "ROWEMP"
  NBSPE += 1 : CHPSPE(NBSPE) = "PRNFLG"
 When "CUM"
  NBSPE += 1 : CHPSPE(NBSPE) = "CUMROW"
  NBSPE += 1 : CHPSPE(NBSPE) = "CUMDES"
  NBSPE += 1 : CHPSPE(NBSPE) = "CUMSHO"
  NBSPE += 1 : CHPSPE(NBSPE) = "CODACC"
  NBSPE += 1 : CHPSPE(NBSPE) = "CUMPRN"
  #NBSPE += 1 : CHPSPE(NBSPE) = "CUMNUM"
  NBSPE += 1 : CHPSPE(NBSPE) = "CUMNUMADI"
  NBSPE += 1 : CHPSPE(NBSPE) = "PRNFLG"
  #59176
  NBSPE += 1 : CHPSPE(NBSPE) = "CODGRP"
 When "EXO"
  NBSPE += 1 : CHPSPE(NBSPE) = "DES"
  NBSPE += 1 : CHPSPE(NBSPE) = "SHO"
  NBSPE += 1 : CHPSPE(NBSPE) = "CODACC"
 When "DCH"
  NBSPE += 1 : CHPSPE(NBSPE) = "DESDCC"
  NBSPE += 1 : CHPSPE(NBSPE) = "DESEDT"
 When "FTD"
  NBSPE += 1 : CHPSPE(NBSPE) = "DESREC"
 When "TIM"
  NBSPE += 1 : CHPSPE(NBSPE) = "DES"
  NBSPE += 1 : CHPSPE(NBSPE) = "SHO"
  NBSPE += 1 : CHPSPE(NBSPE) = "ENAFLG"
  NBSPE += 1 : CHPSPE(NBSPE) = "ACS"
  NBSPE += 1 : CHPSPE(NBSPE) = "WRKFLG"
Endcase
Return

$TRF_SPE
Local Integer II , JJ
For II=1 To NBSPE
 For JJ=0 To evalue("dim([F:"+ABR+"]"+CHPSPE(II)+")")-1
  Assign "[F:"+ABR+"]"+CHPSPE(II)+"("+num$(JJ)+")"
&  With evalue("[F:"+ABR+"2]"+CHPSPE(II)+"("+num$(JJ)+")")
 Next JJ
Next II
Return

##########################################################################
## Ecrans PATCHSx
##########################################################################
Subprog AS_NBLIG
If [M]NUM(nolign-1)<>[M:PSC]COMCUR
 [M:PSC]COMCUR = [M]NUM(nolign-1)
 If [M:PSC]DEBCOM([M:PSC]COMCUR)<>0
  Setlob [M:PS0]COMMENT With [M:PSC]TEX([M:PSC]DEBCOM([M:PSC]COMCUR)..[M:PSC]FINCOM([M:PSC]COMCUR))
 Else
  Raz [M:PS0]COMMENT
 Endif
 Affzo [M:PS0]COMMENT
Endif
[M]NBCOM = 0
Local Integer K
Local Char    TYPOBJ(30)
Case maskcou
 When "PATCHS1" : TYPOBJ = "RUB"-[M]RUB(nolign-1)
 When "PATCHS2" : TYPOBJ = "VRA"-[M]VRA(nolign-1)
 When "PATCHS3" : TYPOBJ = "CUM"-[M]CUM(nolign-1)
Endcase
If TYPOBJ<>""
 K = find(TYPOBJ,[M:PSD]TYPOBJ)
 If K
  While K<[M:PSD]NBLIG & [M]NBCOM<dim([M]FLD) & [M:PSD]FLD(K-1)<>""
   [M]FLD([M]NBCOM)    = [M:PSD]FLD(K-1)
   [M]ANCVAL([M]NBCOM) = [M:PSD]ANC(K-1)
   [M]NOUVAL([M]NBCOM) = [M:PSD]NOU(K-1)
   [M]NBCOM += 1
   K += 1
  Wend
 Endif
 Affzo 30
Endif
End

Subprog B2_NBLIG
Local Integer NOL
For NOL=0 To [M]NBLIG-1
 [M]SEL(NOL) = 2
Next NOL
Affzo SEL
End

Subprog B3_NBLIG
Local Integer NOL
For NOL=0 To [M]NBLIG-1
 [M]SEL(NOL) = 1
Next NOL
Affzo SEL
End

Subprog AS_SEL(VALEUR)
Variable Integer VALEUR
#If dim([M]ACT)>0 & [M]ACT(nolign-1)<>""
# VALEUR = 1 : mkstat = 2 : End
#Endif
End

Subprog IB_NBLIG
Raz GBOUT1
Case [M]TUN(nolign-1)
 When "EXO" : GBOUT1 = mess(98,10702,1)  : # Exonération
 When "DCH" : GBOUT1 = mess(102,10702,1) : # Charges
 When "FTD" : GBOUT1 = mess(125,10702,1) : # DADS-U
 When "ADV" : GBOUT1 = mess(63,139,1)  : # Table diverse
 When "ADP" : GBOUT1 = mess(81,123,1)  : # Paramètre
 When "TIM" : GBOUT1 = mess(128,10702,1) : # Evénement
Endcase
[M]OBJ = [M]TUN(nolign-1)
Case [M]TUN(nolign-1)
 When "ADV"
  [M]OBJ = "ADI"
  [M]CLE = ""
  [M]SUP = [M]COD(nolign-1)+"-"-[M]COD(nolign-1)
 When "ADP"
  [M]CLE = [M]COD(nolign-1)
  If clalev([F:ADP])=0 : Local File ADOPAR [ADP] : Endif
  Read [ADP]ADP1 = [M]CLE
  If !fstat
   [M]SUP = [F:ADP]CHAPITRE
  Endif
 When Default
  [M]CLE = [M]COD(nolign-1)
  [M]SUP = ""
Endcase
End
