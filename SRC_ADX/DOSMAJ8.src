##################################################################################
# DOSMAJ8 : Mises à jour à effectuer lors du passage à la version 13x (Release 8) 
# moulinette avant la version 137 
##################################################################################
Subprog AMAJ
#----------------------------------------#
#       Avant mise à jour                #
#----------------------------------------#
Onerrgo ERREUR

Onerrgo
End


###################################################################################
###################################################################################
###################################################################################
Subprog MAJ
#----------------------------------------#
# Après mise à jour
#----------------------------------------#

Onerrgo ERREUR

# recupération dernier patch pour avoir une idée de la version installée chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)

Local Shortint WPATCH
WPATCH = 0

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif


Filter [ZAP] Where TYP = "P"
Read [ZAP] Last 
If fstat 
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]


Filter [ZAX] Where TYP = "P"
Read [ZAX] Last 
If fstat 
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
#WPATCH = max ([F:ZAP]PATNUM,[F:ZAX]PATNUM)
#WVERSION = max ([F:ZAP]RELEASE,[F:ZAX]RELEASE)
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

# si version des patchs est une v12x alors wpatch = 0
If left$(WVERSION,3) = "1.2"
    WPATCH =0
Endif


# pas possible de tester le GVERSION car le dossier X3 est déja a jour de la version
# ici c'est trop tard

# module stock
#If [F:ADS]MODULE(6) = 2
#    # moulinette utisto n'est pas a faire/se fait deja dans la validation de dossier valdico
#    If WPATCH < 61
#        Call UTI_MOUL([F:ADS]DOSSIER) From UTISTO04
#    Endif

#Endif

# module gpao
#If [F:ADS]MODULE(7) = 2
#    If WPATCH < 58
#        Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA05
#    Endif
#Endif

Onerrgo
End

###################################################################################
###################################################################################
###################################################################################

$ERREUR
Call ECR_TRACE(mess(6,123,1)-num$(errn)-errmes$(errn)-errm-errp-mess(61,100,1)-num$(errl),1) From GESECRAN 
# Erreur...ligne no...
Resume 



