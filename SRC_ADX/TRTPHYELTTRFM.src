#<AdxTL>@(#)7.0.0.0 $Revision$
######################################################################
#
# TRTPHYELTTRFM - Transfert massif des éléments physiques
#
######################################################################
# MODIF :
#
######################################################################


$ACTION

  #Infbox num$(ACTION)
  Case ACTION
    When "INIT"             : Gosub INIT
    When "AVANT_PAR"        : Gosub AVANT_PAR
    When "INIT_DIA"         : Gosub INIT_DIA
#
    When "OUVRE"            : Gosub OUVRE
    When "OUVRE_BATCH"      : Gosub OUVRE_BATCH
#
    When "DEBUT"            : Gosub DEBUT
    When "AP_CHOIX"         : Gosub AP_CHOIX
    When "APRES_MODIF"      : Gosub APRES_MODIF
    When "SETBOUT"          : Gosub SETBOUT
#
    When "CONTROLE"         : Gosub CONTROLE
    When "CONT_BATCH"       : Gosub CONT_BATCH

    When "EXEC"             : Gosub EXEC
    When "TERMINE"          : Gosub TERMINE

    When "OK"               : Gosub OK

    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$INIT_DIA
  # Action - Traitement ( Standard & Saisie et Execution - Batch)

  Global Integer ABANDON_TRT        : # -- Flag alimenté à 1 quand on clique sur le bouton FIN

  GOK=1

  # Chargement & affichage de la fenêtre de dialogue
  Gosub INIT_WIN_PHYELTTRFM

  #=> On rend le masque en-tête invalide pour faire tous les contrôles
  Setmok [M:PHYM] With 0

  #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
  If clalev([M:ASL]) = 0 : Local Mask ASELOBJ [ASL] : Endif
  Default Mask [ASL]
  Gosub DEBUT From ASELOBJ
Return

#-------------------------------------------------------------------------------
$INIT
  # Action - ( Standard & Execution - Batch)

  Global Integer ABANDON_TRT   : # Flag alimenté à 1 quand on clique sur le bouton FIN

  # -- Ouverture des fichiers
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif
  If clalev([F:PHY]) = 0 : Local File PHYELT    [PHY]  : Endif # Open for Memo

  Local Char DBGSTR_SAV(255)
  If clalev([M:PHYM])=0
    DBGSTR_SAV=dbgstr(1)         : # sauvegarde de la liste des masques par défaut
    Local Mask PHYELTTRFM [PHYM] : # ouverture de [PHYM]
    Default Mask DBGSTR_SAV      : # restauration de la liste des masques
  Endif
  If clalev([M:PHYM1])=0
    DBGSTR_SAV=dbgstr(1)            : # sauvegarde de la liste des masques par défaut
    Local Mask PHYELTTRFM1 [PHYM1]  : # ouverture de [PHYM1]
    Default Mask DBGSTR_SAV    : # restauration de la liste des masques
  Endif

  If GSERVEUR=1
    Gosub OUVRE From ASELOBJ
  Endif

Return


#-------------------------------------------------------------------------------
$OUVRE
 # Action  ( Saisie - Batch )
  # -- Ouverture des fichiers
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif

  If GBATCH=0
      # Ouverture de l'écran de sélection étendue
      PARAM(1) = "PHY"
      #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
      Gosub OUVRE From ASELOBJ
      If clalev([M:ASL]) = 0 : Local Mask ASELOBJ [ASL] : Endif
      Default Mask [ASL]
      Gosub DEBUT From ASELOBJ
  Endif
Return


#-------------------------------------------------------------------------------
$OUVRE_BATCH
 # Action  ( Saisie - Batch )
  # -- Ouverture des fichiers
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif


  # Ouverture de l'écran de sélection étendue
  PARAM(1) = "PHY"
  #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
  Gosub OUVRE From ASELOBJ

Return


#-------------------------------------------------------------------------------
$AVANT_PAR
 # Action  (Massif uniquement - Interactif et soumission batch)

Return


#-------------------------------------------------------------------------------
$DEBUT
  # Action - Traitement ( Standard & Saisie et Execution - Batch)
  GOK=1

  # Chargement & affichage de la fenêtre de dialogue
  Gosub INIT_WIN_PHYELTTRFM

  #=> On rend le masque en-tête invalide pour faire tous les contrôles
  Setmok [M:PHYM] With 0

  #=> Raz de l'onglet supplémentaire
  Raz [M:ASL]FLD1, [M:ASL]VAL1
  Raz [M:ASL]FLD2, [M:ASL]VAL2
  Raz [M:ASL]FLD3, [M:ASL]VAL3
  Raz [M:ASL]FLD4, [M:ASL]VAL4
  Raz [M:ASL]FLD5, [M:ASL]VAL5

Return


#-------------------------------------------------------------------------------
$AP_CHOIX
  Case REPONSE
    When GSTAOK   : ABANDON_TRT = 0
    When GSTAEND  : ABANDON_TRT = 1
  Endcase

Return

#-------------------------------------------------------------------------------
$SETBOUT
  Grizo [M:ASL]TBL1
  Grizo [M:ASL]TBL2
  Grizo [M:ASL]TBL3
  Grizo [M:ASL]TBL4
  Grizo [M:ASL]TBL5
  Affzo [M:ASL]
Return


#-------------------------------------------------------------------------------
$APRES_MODIF

Return


#-------------------------------------------------------------------------------
$OK

Return

#-------------------------------------------------------------------------------
$CONTROLE
  # Action - Traitement ( Standard & Execution - Batch)
  If GSERVEUR = 0
    If ABANDON_TRT = 1
      Return
    Endif

    # Contrôle
    Gosub CTRL_TRANSFERT
  Endif
Return

#-------------------------------------------------------------------------------
$CONT_BATCH

  # Action - Traitement ( Standard & Execution - Batch)
  If ABANDON_TRT = 1
    Return
  Endif

  # Contrôle
  Gosub CTRL_TRANSFERT
Return

$CTRL_TRANSFERT
  #------------------------------
  If [M:PHYM1]CCLTRF <> [V]CST_AYES
    If ( [M:PHYM1]LCTCODD = "" ) Then
      GMESSAGE = mess(183,GML_MSGPHY,1) : # La localisation est obligatoire
      FIN  = 0
      GERR = 1
    Endif
  Endif

  If [M:PHYM1]FLGSIM = [V]CST_AYES and [M:PHYM1]FLGTRC <> [V]CST_AYES
    [M:PHYM1]FLGTRC = [V]CST_AYES
    Affzo [M:PHYM1]FLGTRC
  Endif
  #------------------------------
Return

#-------------------------------------------------------------------------------
$EXEC
  If ABANDON_TRT = 1
    Return
  Endif

  Local Integer RET

  If GBATCH=0 and GSERVEUR=0
    Gosub OUVRE From ASELOBJ
  Endif


  # Construction de la clause WHERE
  Gosub BUILD_WHERE_FILTER

  # Ouverture du Compte-rendu
  If [M:PHYM1]FLGTRC= G_OUI Then
    # CFF Local Instance CLOG Using C_FXDLOG
    Global Instance CLOG Using C_FXDLOG

    Gosub ECR_TRACE_INIT
    Gosub ECR_TRACE_HEADER
  Endif

  # Traitement de transfert
  Call TEMPON('C') From GESECRAN
  If [M:PHYM1]CCLTRF = [V]CST_AYES
    Gosub ANN_TRANSFERT
  Else
    Gosub TRANSFERT
  Endif
  Call TEMPOFF() From GESECRAN

  If [M:PHYM1]FLGTRC= G_OUI  Then
    Gosub ECR_TRACE_FOOTER
  Endif

# CFF  If !(GSERVEUR) and [M:PHYM1]FLGTRC= G_OUI Then
  If [M:PHYM1]FLGTRC= G_OUI Then
    # Fermeture du Compte-rendu
    [L]RET = fmet CLOG.LOG_CLOSE()

    # Visualisation du Compte-rendu (code CLASSIC)
    Local Char STRACE(GLONTRA)
    STRACE = GTRACE
    GTRACE = CLOG.LOG_NAME
    Call LEC_TRACE From LECFIC
    GTRACE = STRACE

    # Free class
    FreeGroup CLOG
    # Kill the global declaration
    If (dim(CLOG) > 0)
      Kill CLOG
    Endif

  Endif

Return

#-------------------------------------------------------------------------------
$TERMINE

  # Action - Traitement ( Standard & Execution - Batch)
  Call TEMPOFF() From GESECRAN

  # -- Interactif
  If (dim(ABANDON_TRT) > 0)
    Kill ABANDON_TRT
  Endif

  If (clalev([M:PHYM])) Then
    Close Mask [PHYM]
  Endif

  If (clalev([M:PHYM1])) Then
    Close Mask [PHYM1]
  Endif

  If (clalev([M:ASL])) Then
    Close Mask [ASL]
  Endif
  FIN = 1
Return

#-------------------------------------------------------------------------------
$TRANSFERT
  #==================================
  # Transfert des éléments physiques
  #==================================
  Global Integer NBPHY_TRT : Raz NBPHY_TRT
  Global Integer NBPHY_WAR : Raz NBPHY_WAR
  Global Integer NBPHY_ERR : Raz NBPHY_ERR
  Local Integer LOK

  Trbegin [CPY]
  # Warning: use [CPY] file because the [PHY] file will be open later

  # -- Progress bar declaration "TRANSFERT MASSIF D'ELEMENTS PHYSIQUES"
  Global Char TXTPROG(40) : TXTPROG = mess(195, GML_MSGPHY, 1) : # Gestion de la jauge : Titre
  Call TEMPOFF() From GESECRAN
  Call OUVRE_BOITE(TXTPROG, 0) From GESECRAN

  # -- Call the class transfer function
  Local Instance TRF_PARAM Using C_PHYELTTRF
  TRF_PARAM = NewInstance C_PHYELTTRF AllocGroup null
  # Set parameter class properties
  TRF_PARAM.TRFDAT     = [M:PHYM1]TRFDAT
  TRF_PARAM.TRFTYP     = [M:PHYM1]TRFTYP
  TRF_PARAM.TRFLCTCOD  = [M:PHYM1]LCTCODD
  TRF_PARAM.PHY_FILTER = LFILTER
  If [M:PHYM1]FLGTRC= G_OUI
    TRF_PARAM.TRT_CALLBACK = "TRTPHYELTTRFM"
  Else
    TRF_PARAM.TRT_CALLBACK = AVOID.ACHAR
  Endif

  # Call the class transfer function with link option
  [L]LOK = func PHYELT_C_MPR._TRANSFER_PHYELT_FROM_PHY(TRF_PARAM)
  # Free parameter class
  FreeGroup TRF_PARAM

  # -- Close progress bar
  Call FERME_BOITE From GESECRAN

  If ([M:PHYM1]FLGSIM = G_OUI) Then
    Rollback
  Else
    Commit
  Endif

Return

#-------------------------------------------------------------------------------
$ANN_TRANSFERT

  #==================================
  # Annulation Transfert des éléments physiques
  #==================================
  Global Integer NBPHY_TRT : Raz NBPHY_TRT
  Global Integer NBPHY_WAR : Raz NBPHY_WAR
  Global Integer NBPHY_ERR : Raz NBPHY_ERR
  Local Integer LOK

  Trbegin [CPY]
  # Warning: use [CPY] file because the [PHY] file will be open later

  # -- Progress bar declaration "TRANSFERT MASSIF D'ELEMENTS PHYSIQUES"
  Global Char TXTPROG(40) : TXTPROG = mess(195, GML_MSGPHY, 1) : # Gestion de la jauge : Titre
  Call TEMPOFF() From GESECRAN
  Call OUVRE_BOITE(TXTPROG, 0) From GESECRAN

  # -- Call the class transfer function
  Local Instance TRF_PARAM Using C_PHYELTTRF
  TRF_PARAM = NewInstance C_PHYELTTRF AllocGroup null
  # Set parameter class properties
  TRF_PARAM.TRFDAT     = [M:PHYM1]TRFDAT
  TRF_PARAM.PHY_FILTER = LFILTER
  If [M:PHYM1]FLGTRC= G_OUI
    TRF_PARAM.TRT_CALLBACK = "TRTPHYELTTRFM"
  Else
    TRF_PARAM.TRT_CALLBACK = AVOID.ACHAR
  Endif

  # Call the class transfer function with link option
  [L]LOK = func PHYELT_C_MPR._CNL_TRANSFER_PHYELT_FROM_PHY(TRF_PARAM)
  # Free parameter class
  FreeGroup TRF_PARAM

  # -- Close progress bar
  Call FERME_BOITE From GESECRAN

  If ([M:PHYM1]FLGSIM = G_OUI) Then
    Rollback
  Else
    Commit
  Endif

Return

#-------------------------------------------------------------------------------
$INIT_WIN_PHYELTTRFM

  Effzo [M:PHYM]

  Diszo [M:PHYM]FCY
  Diszo [M:PHYM]BUICOD
  Diszo [M:PHYM]LCTCODO

  #--> Réaffichage du masque paramètre et positionnement à non valide pour forcer tous les contrôles
  Affzo  [M:PHYM]
  Affzo  [M:PHYM1]
  Setmok [M:PHYM] With 0
Return

#-------------------------------------------------------------------------------
# FQ110251
Funprog LCT_NBR(PCPY)
Value Char PCPY()

Local Integer RRET
Local Char LFILTER(50)

  [L]RRET = 0
  If PCPY = ""
    End [L]RRET
  Endif

  Local File PHYLCT   [LCT]

  [L]LFILTER = "CPY = '" + PCPY + "'"

  Filter [LCT] Where evalue(LFILTER)
  [L]RRET = rowcount([LCT])
  Filter [LCT]
  Close File [LCT]

End [L]RRET


#-------------------------------------------------------------------------------
$BUILD_WHERE_FILTER
  # Construction critère principal
  # Warning : Not use this syntax     : "LCTCOD <> [M:PHYM1]LCTCODD"
  #           You should use this one : "LCTCOD <> '"+[M:PHYM1]LCTCODD+"'"
  Local Char LFILTER(250)
# CFF  LFILTER =   " LCTCOD <> '"+[M:PHYM1]LCTCODD+"'"

  LFILTER =  AVOID.ACHAR
  LFILTER = "CPY = '" + [M:PHYM]CPY + "'"

  If ([M:PHYM]FCY <> "") Then
    LFILTER -= "and FCY = '" + [M:PHYM]FCY + "'"
  Endif

  If ([M:PHYM]BUICOD <> "") Then
    # Warning: [F:tle] is mandatory on the second table if use link option
    LFILTER -= "and [F:LCT]BUICOD = '" + [M:PHYM]BUICOD + "'"
  Endif

  If ([M:PHYM]LCTCODO <> "") Then
    LFILTER -= "and LCTCOD = '" + [M:PHYM]LCTCODO + "'"
  Endif

  # Cancel transfer case (If [M:PHYM1]CCLTRF = [V]CST_AYES)

#  Warning :
#  this condition is done in the _CNL_TRANSFER_PHYELT_FROM_PHY function
#  because the test and join with PHYMVT table depend if the [M:PHYM1]TRFDAT date is empty or not.

  # Construction critère supplémentaire (onglet ASELOBJ)
  [M]NBTBL = 0
  Gosub EXPRESSION From ASELOBJ
  If (EXPRESSION <> "") Then
   LFILTER -= "and" - EXPRESSION
  Endif
Return

#-------------------------------------------------------------------------------
$ECR_TRACE_INIT

Local Integer LDESC

  CLOG = NewInstance  C_FXDLOG AllocGroup null

  # Class init
  [L]RET = fmet CLOG.LOG_INIT()

  # Separator character, Underlining character, Space character, Length line
  [L]RET = fmet CLOG.LOG_SET_PARAMS(" ", "=", "", 115)

  # Columns(s) definition
  # Number
  [L]RET = fmet CLOG.LOG_ADD_COLUMN("I", [V]CST_ANO, 5, [V]CST_AYES, 0, "", [V]CST_ANO, mess(208, GML_MSGPHY, 1))
  # Reference
  [L]RET = fmet CLOG.LOG_ADD_COLUMN("A", [V]CST_AYES, GLONPHY, [V]CST_AYES, 0, "", [V]CST_ANO, mess(209, GML_MSGPHY, 1))
  # Desc
  LDESC = 50
  If [M:PHYM1]CCLTRF = [V]CST_AYES
    LDESC -= GLONLCT + 8
  Endif
  [L]RET = fmet CLOG.LOG_ADD_COLUMN("A", [V]CST_AYES, LDESC, [V]CST_AYES, 0, "", [V]CST_ANO, mess(210, GML_MSGPHY, 1))

  If [M:PHYM1]CCLTRF = [V]CST_AYES
    # Start localizat
    [L]RET = fmet CLOG.LOG_ADD_COLUMN("A", [V]CST_AYES, GLONLCT - 3, [V]CST_AYES, 0, "", [V]CST_ANO, mess(211, GML_MSGPHY, 1))
#    # End localizat
#    # Localisation destination (26 car out of limit !!!)
    [L]RET = fmet CLOG.LOG_ADD_COLUMN("A", [V]CST_AYES, GLONLCT - 3, [V]CST_AYES, 0, "", [V]CST_ANO, mess(211, GML_MSGPHY, 1))
    [L]RET = fmet CLOG.LOG_ADD_COLUMN("D", [V]CST_AYES, 15, [V]CST_AYES, 0, "", [V]CST_ANO, mess(201, GML_MSGPHY, 1))
  Else
    # Start localizat
    [L]RET = fmet CLOG.LOG_ADD_COLUMN("A", [V]CST_AYES, GLONLCT, [V]CST_AYES, 0, "", [V]CST_ANO, mess(211, GML_MSGPHY, 1))
  Endif

  # Open trace file of log
  # si GSERVEUR c'est le traitement batch lui-même qui ouvre la trace
  If !(GSERVEUR) Then
    If [M:PHYM1]CCLTRF = [V]CST_AYES
      [L]RET = fmet CLOG.LOG_CREATE(mess(226, GML_MSGPHY, 1))
    Else
      [L]RET = fmet CLOG.LOG_CREATE(mess(212, GML_MSGPHY, 1))
    Endif
  Endif

  # Standard Parameters of header
  [L]RET = fmet CLOG.LOG_SET_H_USR(GACTX.USER)
  [L]RET = fmet CLOG.LOG_SET_H_CPY([M:PHYM]CPY)
  [L]RET = fmet CLOG.LOG_SET_H_FCY([M:PHYM]FCY)
  [L]RET = fmet CLOG.LOG_SET_H_SIM([M:PHYM1]FLGSIM)

Return

$ECR_TRACE_HEADER
  #Call OUVRE_TRACE(mess(1,GML_MSGCAL,1))  From LECFIC

  # Header XXXX
  [L]RET = fmet CLOG.LOG_WRITE_HEADER()

  [L]RET = fmet CLOG.LOG_WRITE_STRING_SEPARATOR()
  # Critères
  [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(195, GML_MSGPHY, 1))
  If ( [M:PHYM]BUICOD <> "")
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(196, GML_MSGPHY, 1)-[M:PHYM]BUICOD-"/"-[M:PHYM]ZBUICOD)
  Endif
  If ( [M:PHYM]LCTCODO <> "")
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(197, GML_MSGPHY, 1)-[M:PHYM]LCTCODO-"/"-[M:PHYM]ZLCTCODO)
  Endif
  If [M:PHYM1]CCLTRF = [V]CST_AYES
    If ([M:PHYM1]TRFDAT <> [0/0/0]) Then
      [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(63, GML_MSGPHY, 1)-" = "-format$(GFMD, gdat$([M:PHYM1]TRFDAT)))
    Endif
  Endif

  # Sélection étendue
  If ( EXPRESSION <> "" ) Then
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(198, GML_MSGPHY, 1))
    [L]RET = fmet CLOG.LOG_WRITE_STRING(EXPRESSION)
  Endif
  # Destination
  [L]RET = fmet CLOG.LOG_WRITE_LINEFEED(1)
  If [M:PHYM1]CCLTRF = CST_ANO
    # Transfer
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(199, GML_MSGPHY, 1))
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(200, GML_MSGPHY, 1)-[M:PHYM1]LCTCODD-"/"-[M:PHYM1]ZLCTCODD)
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(201, GML_MSGPHY, 1)-num$([M:PHYM1]TRFDAT))
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(202, GML_MSGPHY, 1)-num$([M:PHYM1]TRFTYP)-"/"-[M:PHYM1]ZTRFTYP)
  Endif
  # Options
  [L]RET = fmet CLOG.LOG_WRITE_LINEFEED(1)

  [L]RET = fmet CLOG.LOG_WRITE_STRING_SEPARATOR()
  [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(203, GML_MSGPHY, 1) - num$(date$) - time$)

  [L]RET = fmet CLOG.LOG_WRITE_LINEFEED(1)
  [L]RET = fmet CLOG.LOG_WRITE_TITLES()
  [L]RET = fmet CLOG.LOG_WRITE_STRING_SEPARATOR()

Return

$ECR_TRACE_FOOTER
  # Footer

  [L]RET = fmet CLOG.LOG_WRITE_LINEFEED(1)
  [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(204, GML_MSGPHY, 1) - num$(date$) - time$)
  [L]RET = fmet CLOG.LOG_WRITE_STRING_SEPARATOR()
  [L]RET = fmet CLOG.LOG_WRITE_LINEFEED(1)

  [L]RET = fmet CLOG.LOG_WRITE_STRING(num$(NBPHY_TRT) - mess(205, GML_MSGPHY, 1))
  If (NBPHY_TRT - NBPHY_ERR) > 0
    [L]RET = fmet CLOG.LOG_WRITE_STRING(num$(NBPHY_TRT - NBPHY_ERR) - mess(206, GML_MSGPHY, 1))
  Endif
  If NBPHY_ERR > 0
    [L]RET = fmet CLOG.LOG_WRITE_STRING(num$(NBPHY_ERR) - mess(207, GML_MSGPHY, 1))
  Endif

  #[L]RET = fmet CLOG.LOG_NB_OK(NBPHY_TRT, NBPHY_TRT-NBPHY_ERR, NBPHY_ERR)
Return


######################################################################################
#                                                                                    #
#         GESTION DU MASQUE DE CONTROLE MPHYELTM [M:PHYM]                            #
#                                                                                    #
######################################################################################

#-------------------------------------------------------------------------------
Subprog AM_CPY(VALEUR)
Variable Char VALEUR()

  # [M:PHYM]
  [M:PHYM]ALLFCY = G_OUI
  [M:PHYM]ALLBUI = G_OUI
  [M:PHYM]ALLLCT = G_OUI
  Raz [M:PHYM]FCY, BUICOD, LCTCODO

  Diszo [M:PHYM]FCY, BUICOD, LCTCODO

  Raz [M:PHYM1]LCTCODD, FCYD
  # FQ110251
  If func LCT_NBR(VALEUR) < 1
    Diszo [M:PHYM1]LCTCODD
  Else
    Actzo [M:PHYM1]LCTCODD
  Endif
  Raz [M:PHYM1]TRFDAT, TRFTYP

  #--> Réaffichage du masque paramètre et positionnement à non valide pour forcer tous les contrôles
  Affzo  [M:PHYM]
  Affzo  [M:PHYM1]
  Setmok [M:PHYM] With 0
End


#-------------------------------------------------------------------------------
Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR

  If (VALEUR = G_OUI) Then
    Raz [M:PHYM]FCY
    Diszo [M:PHYM]FCY
  Else
    Actzo [M:PHYM]FCY
  Endif

End

#-------------------------------------------------------------------------------
Subprog AM_ALLBUI(VALEUR)
Variable Integer VALEUR
  If (VALEUR = G_OUI) Then
    Raz [M:PHYM]BUICOD
    Diszo [M:PHYM]BUICOD
  Else
    Actzo [M:PHYM]BUICOD
  Endif
End

#-------------------------------------------------------------------------------
Subprog AM_ALLLCT(VALEUR)
Variable Integer VALEUR
  If (VALEUR = G_OUI) Then
    Raz [M:PHYM]LCTCODO
    Diszo [M:PHYM]LCTCODO
  Else
    Actzo [M:PHYM]LCTCODO
  Endif
End

######################################################################################
#                                                                                    #
#         GESTION DU MASQUE DE CONTROLE PHYELTM1 [M:PHYM1]                          #
#                                                                                    #
######################################################################################

#-------------------------------------------------------------------------------
Subprog AM_LCTCODD(VALEUR)
Variable Char    VALEUR()

  Local File PHYLCT   [LCT]
  Local File FACILITY [FCY]
  Read [LCT]LCT0 = VALEUR
  If (fstat)
    Raz [M:PHYM1]FCYD
  Else
    Read [FCY]FCY0 = [F:LCT]FCY
    If (fstat)
      Raz [M:PHYM1]FCYD
    Else
      [M:PHYM1]FCYD = [F:LCT]FCY
    Endif
  Endif
  Close File [FCY]
  Close File [LCT]

  #--> Réaffichage du masque paramètre et positionnement à non valide pour forcer tous les contrôles
  Affzo  [M:PHYM1]
  Setmok [M:PHYM] With 0
End

#**
#* Callback function of Transfer
#*
#* @param PHY
#* @param PCASE
#* @param PVALUE
#* @param PPHYREF
#* @param PPHYDES1
#* @param PLCTCOD
#* @return CST_ATRUE or CST_AFALSE to stop transfer process
#*!
Funprog  CALLBACK_TRF(PARAM_PHY, PCASE, PVALUE, PPHYREF, PPHYDES1, PLCTCOD)
Variable Instance PARAM_PHY Using C_PHYELTTRF
Value Integer PCASE
Value Integer PVALUE
Value Char PPHYREF()
Value Char PPHYDES1()
Value Char PLCTCOD()

  Local Integer LOK
  Local Integer NBPHY_INF

  Case PCASE
    When 1:
      # Set progress bar
      Call SET_BOITE(TXTPROG, PVALUE) From GESECRAN
    When 2:
      # Increase transfer physical assets number
      NBPHY_TRT += 1

      # Update progress bar
      Local Char MSGPROG(40)
      MSGPROG = PPHYREF + '['+num$(NBPHY_TRT) + ']'
      Call AFF_BOITE(MSGPROG, NBPHY_TRT, LOK) From GESECRAN

      # Set log value columns
      [L]LOK = fmet CLOG.LOG_INIT_LINE()
      [L]LOK = fmet CLOG.LOG_PUT_INT_COLUMN(1, NBPHY_TRT)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(2, PPHYREF)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(3, PPHYDES1)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(4, PLCTCOD)
      [L]LOK = fmet CLOG.LOG_WRITE([V]CST_AOK)

      # Write contents of stack messages
      # (CLOG is global variable)
      # Issue 110494
      Call LOG_WRITE_AERROR_GENERAL_COUNT(PARAM_PHY, CLOG, [L]NBPHY_INF, NBPHY_WAR, NBPHY_ERR) From FXDLOG_CSTD
#      Call LOG_WRITE_AERROR_STACK_COUNT(PARAM, CLOG, [L]NBPHY_INF, NBPHY_WAR, NBPHY_ERR, NBPHY_ERR) From FXDLOG_CSTD
      # End Issue 110494
    When 3:
    When Default:
  Endcase

End [V]CST_ATRUE

#**
#* Callback function of Cancel tranfer
#*
#* @param PHY
#* @param PCASE
#* @param PVALUE
#* @param PPHYREF
#* @param PPHYDES1
#* @param PLCTCOD
#* @return CST_ATRUE or CST_AFALSE to stop transfer process
#*!
Funprog  CALLBACK_CNL_TRF(PARAM_PHY, PCASE, PVALUE, PPHYREF, PPHYDES1, PLCTCODO, PLCTCODD, PTRFDAT)
Variable Instance PARAM_PHY Using C_PHYELTTRF
Value Integer PCASE
Value Integer PVALUE
Value Char PPHYREF()
Value Char PPHYDES1()
Value Char PLCTCODO()
Value Char PLCTCODD()
Value Date PTRFDAT

  Local Integer LOK
  Local Integer NBPHY_INF

  Case PCASE
    When 1:
      # Set progress bar
      Call SET_BOITE(TXTPROG, PVALUE) From GESECRAN
    When 2:
      # Increase transfer physical assets number
      NBPHY_TRT += 1

      # Update progress bar
      Local Char MSGPROG(40)
      MSGPROG = PPHYREF + '['+num$(NBPHY_TRT) + ']'
      Call AFF_BOITE(MSGPROG, NBPHY_TRT, LOK) From GESECRAN

      # Set log value columns
      [L]LOK = fmet CLOG.LOG_INIT_LINE()
      [L]LOK = fmet CLOG.LOG_PUT_INT_COLUMN(1, NBPHY_TRT)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(2, PPHYREF)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(3, PPHYDES1)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(4, PLCTCODO)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(5, PLCTCODD)
      [L]LOK = fmet CLOG.LOG_PUT_DATE_COLUMN(6, PTRFDAT)
      [L]LOK = fmet CLOG.LOG_WRITE([V]CST_AOK)

      # Write contents of stack messages
      # (CLOG is global variable)
      # Issue 110494
      Call LOG_WRITE_AERROR_GENERAL_COUNT(PARAM_PHY, CLOG, [L]NBPHY_INF, NBPHY_WAR, NBPHY_ERR) From FXDLOG_CSTD
#      Call LOG_WRITE_AERROR_STACK_COUNT(PARAM, CLOG, [L]NBPHY_INF, NBPHY_WAR, NBPHY_ERR, NBPHY_ERR) From FXDLOG_CSTD
      # End Issue 110494
    When 3:
    When Default:
  Endcase

End [V]CST_ATRUE

