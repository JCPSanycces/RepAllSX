#<AdxTL>@(#)10.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call COPIES
End

Subprog COPIES
Local Char VALEUR(10), PARAM(10)(1.1)
Call TRAITE_CHAR(VALEUR,PARAM,"","ADOSCOPDAT","ADOSCOPDAT",4,"SPEDOSCOPDAT") From GTRAITE
#Call S_LIS_CHAR(VALEUR,PARAM,"","ASYRLICFOL","") From GACTION
End

#-----------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Gosub DEBUT
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return

#----------------------#
$SEL_LISTE
Local Char TEXTE(30)(1..200,1..2) , TIT(30)(0..2)
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
Local File =GDOSX3+".ADELIVER" [ADLV] , =GDOSX3+".ATEXTRA" [AXX]
NBTEX = 0
For [ADLV]ADLV0 Where ADLVTYP=2
 ASTATUS = func ASYRLICFOL.ACTIVE_KIT([F:ADLV]COD)
 If ASTATUS=CST_ATRUE
  NBTEX += 1
  TEX(NBTEX)   = [F:ADLV]COD
  TEXTE(NBTEX,1)   = [F:ADLV]COD
  Call LECTEXTRA(TEXTE(NBTEX,2),"ADELIVER","DLVDES",[F:ADLV]COD,"") From ATEXTRA
 Endif
Next ADLV
Return

#---------------------#
$INIT
$OUVRE_BATCH
Local Char    TBLIV(GLONADLV)(1..10)
Local Integer I
Local Mask ADOSCOPDAT0 [ACOP0] , ADOSCOPDAT1 [ACOP1] , ADOSCOPDAT2 [ACOP2]
Raz [M:ACOP0] , [ACOP1] , [ACOP2]
If clalev([F:ADS])=0  : Local File ADOSSIER            [ADS]  : Endif
If clalev([F:ADA])=0  : Local File ADOSACT             [ADA]  : Endif
If clalev([F:ADK])=0  : Local File ADOSLIV             [ADK]  : Endif
If clalev([F:ADLV])=0 : Local File =GDOSX3+".ADELIVER" [ADLV] : Endif
Return

#---------------------#
$DEBUT
Read [ADS]DOSSIER = nomap
[M:ACOP0]DOSORI = [F:ADS]DOSCOP
[M:ACOP0]DOSDES = [F:ADS]DOSCOP
If !fstat
 Gosub CHARGE_DEST
Endif
Read [ADS]DOSSIER = nomap
If !fstat
 Gosub CHARGE_ORI
Endif
If GADONIX=2
 [M:ACOP1]DETAIL = 2
Endif
Affzo [M:ACOP0]
Affzo [M:ACOP1]
Return

#---------------------#
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1 : Return
Endif
If [M:ACOP1]NBLEG=0
 # Il doit y avoir au moins une législation
 Call ERREUR(mess(241,133,1)) From GESECRAN
 SAI = 1
 Return
Endif
Read [ADA]ADA0 = [M:ACOP0]DOSDES;"LEG"
If !fstat
 If [F:ADA]FLACT<>2
  If [M:ACOP1]NBLEG>1
   Call ERREUR(mess(250,133,1)) From GESECRAN : # Trop de législation parametrées
   SAI = 1 : Return
  Endif
  If !find([M:ACOP1]LEGD(0),[M:ACOP1]LEG)
   Call ERREUR([M:ACOP1]LEGD(0)-":"-mess(249,133,1)-[M:ACOP0]DOSDES) From GESECRAN : # Législation non gérée par le dossier
   SAI = 1 : Return
  Endif
 Endif
Endif
For I=1 To [M:ACOP2]NBKITD
 If !find([M:ACOP2]KITCODD(I-1),[M:ACOP2]KITCOD(0..[M:ACOP2]NBKIT-1))
  # Kit non géré dans le dossier $1$
  Call AVERTIR([M:ACOP2]KITCODD(I-1)+":"-func AFNC.MES1(mess(272,143,1),[M:ACOP0]DOSDES),OK) From GESECRAN
  If OK<>2 : SAI = 1 : Break : Endif
 Endif
Next I
If SAI=1 : Return : Endif
If [M:ACOP0]DOSDES=GDOSX3
 Call ERREUR(mess(222,00139,1)) From GESECRAN : # Dossier racine
 SAI = 1 : Return
Endif
# Pour éviter de passer les variable de bas de tableau en argument
For I=[M:ACOP1]NBLEG+1 To dim([M:ACOP1]LEG)
 If I<=dim([M:ACOP1]LEG)
  [M:ACOP1]LEG(I-1) = ""
 Endif
Next I
For I=[M:ACOP1]NBLEGD+1 To dim([M:ACOP1]LEGD)
 If I<=dim([M:ACOP1]LEGD)
  [M:ACOP1]LEGD(I-1) = ""
 Endif
Next I
For I=[M:ACOP2]NBLIVD+1 To dim([M:ACOP2]LIVCODD)
 If I<=dim([M:ACOP2]LIVCODD)
  [M:ACOP2]LIVCODD(I-1) = ""
 Endif
Next I
For I=[M:ACOP2]NBKITD+1 To dim([M:ACOP2]KITCODD)
 If I<=dim([M:ACOP2]KITCODD)
  [M:ACOP2]KITCODD(I-1) = ""
 Endif
Next I
Return

#-------------------------------------------------#
$CHARGE_ORI
Local Char    TBLIV(GLONADLV)(1..10)
Local Integer ASTATUS , I
[M:ACOP1]NBLIG  = len(mess(0,26,1))
[M:ACOP1]NBLEG = [F:ADS]NBLEG
For I=0  To [M:ACOP1]NBLIG-1
 [M:ACOP1]OPTINI(I) = [F:ADS]OPTINI(I)
Next I
For I=0 To [F:ADS]NBLEG-1
 If [F:ADS]DOSLEG(I)<>""
  [M:ACOP1]LEG(I) = [F:ADS]DOSLEG(I)
  Call LECTEXTRA([M:ACOP1]INTITLEGORI(I),"ATABDIV","LNGDES","909",[M:ACOP1]LEG(I)) From ATEXTRA
 Endif
Next I
[M:ACOP2]NBKIT = 0
[M:ACOP2]NBLIV = 0
If [F:ADS]DOSSIER=GDOSX3
 For [ADLV] Where ENAFLG=2
  Case [F:ADLV]ADLVTYP
   When 1 : # Livrable
    [M:ACOP2]NBLIV += 1
    [M:ACOP2]LIVCOD([M:ACOP2]NBLIV-1) = [F:ADLV]COD
    [M:ACOP2]INSLIV([M:ACOP2]NBLIV-1) = 2
   When 2 : # Kit
    [M:ACOP2]NBKIT += 1
    [M:ACOP2]KITCOD([M:ACOP2]NBKIT-1) = [F:ADLV]COD
    [M:ACOP2]INSKIT([M:ACOP2]NBKIT-1) = 2
  Endcase
 Next ADLV
Else
 For [ADK] Where DOSSIER=[F:ADS]DOSSIER & INSTAL=2
  Read [ADLV]ADLV0=[F:ADK]COD
  If !fstat & [F:ADLV]ENAFLG=2
   Case [F:ADLV]ADLVTYP
    When 1 : # Livrable
     [M:ACOP2]NBLIV += 1
     [M:ACOP2]LIVCOD([M:ACOP2]NBLIV-1) = [F:ADK]COD
     [M:ACOP2]INSLIV([M:ACOP2]NBLIV-1) = [F:ADK]INSTAL
    When 2 : # Kit
     [M:ACOP2]NBKIT += 1
     [M:ACOP2]KITCOD([M:ACOP2]NBKIT-1) = [F:ADK]COD
     [M:ACOP2]INSKIT([M:ACOP2]NBKIT-1) = [F:ADK]INSTAL
   Endcase
  Endif
 Next ADK
Endif
Affzo [M:ACOP2]NBKIT , KITCOD , INSKIT
Affzo [M:ACOP2]NBLIV , LIVCOD , INSLIV
Affzo [M:ACOP1]LEG,INTITLEGORI
Affzo [M:ACOP1]OPTINI
Return

#--------------------------------------------------#
$CHARGE_DEST
Local Char    TBLIV(GLONADLV)(1..10)
Local Integer ASTATUS , I
[M:ACOP1]NBLIG  = len(mess(0,26,1))
[M:ACOP1]NBLEGD = [F:ADS]NBLEG
For I =0  To [M:ACOP1]NBLIG-1
 [M:ACOP1]OPTINI(I) = [F:ADS]OPTINI(I)
Next
For I=0 To [F:ADS]NBLEG-1
 If [F:ADS]DOSLEG(I)<>""
  [M:ACOP1]LEGD(I) = [F:ADS]DOSLEG(I)
  Call LECTEXTRA([M:ACOP1]INTLEG(I),"ATABDIV","LNGDES","909",[M:ACOP1]LEGD(I)) From ATEXTRA
 Endif
Next I
[M:ACOP2]NBKITD = 0
[M:ACOP2]NBLIVD = 0
ASTATUS = func ASYRLICFOL.GETPOLICY(TBLIV)
For I=1 To dim(TBLIV)
 If TBLIV(I)<>""
  [M:ACOP2]NBLIVD += 1
  [M:ACOP2]LIVCODD([M:ACOP2]NBLIVD-1) = TBLIV(I)
  Read [ADK]ADK0=[F:ADS]DOSSIER;TBLIV(I)
  If !fstat
   [M:ACOP2]INSLIVD([M:ACOP2]NBLIVD-1) = [F:ADK]INSTAL
  Else
   [M:ACOP2]INSLIVD([M:ACOP2]NBLIVD-1) = 1
  Endif
 Endif
Next I
For [ADK]ADK0 Where DOSSIER=[F:ADS]DOSSIER
 Read [ADLV]ADLV0=[F:ADK]COD
 If !fstat & [F:ADLV]ADLVTYP=2 : # Kit
  [M:ACOP2]NBKITD += 1
  [M:ACOP2]KITCODD([M:ACOP2]NBKITD-1) = [F:ADK]COD
  [M:ACOP2]INSKITD([M:ACOP2]NBKITD-1) = [F:ADK]INSTAL
  For I=1 To dim(TBLIV)
   Read [ADLV]ADLV0=TBLIV(I)
   If !fstat
    J = find([F:ADK]COD,[F:ADLV]ITYKIT)
    If J
     [M:ACOP2]ROWKITD([M:ACOP2]NBKITD-1) = [F:ADLV]ITYKITROW(J-1)
     Break
    Endif
   Endif
  Next I
 Endif
Next ADK
Affzo [M:ACOP2]NBKITD , KITCODD , INSKITD
Affzo [M:ACOP2]NBLIVD , LIVCODD , INSLIVD
Affzo [M:ACOP1]LEGD,INTLEG
Affzo [M:ACOP1]OPTINI
If func AFNC.ACVDOSACT([F:ADS]DOSSIER,"LEG")=0
 [M:ACOP1]AJOUT = 2
 Affzo [M:ACOP1]AJOUT
 Grizo [M:ACOP1]AJOUT
Else
 Actzo [M:ACOP1]AJOUT
Endif
# 114946 CCL various troubles in legislation copy (ADOSCOPDAT)
Grizo  [M:ACOP1]NBLEGD
Return

#---------------------------------------------------#
$EXEC
Local Integer NBCOP
Local Char    TBCOP(GLONATB)(1..2000)

Read [F:ADS]DOSSIER = [M:ACOP0]DOSDES
If fstat
 # Dossier inexistant
 Call ERREUR([M:ACOP0]DOSDES-":"-mess(7,125,1)) From GESECRAN
 Return
Endif

# Utilisé pour la copie des tables diverses
Gosub DEFVAR From SUBADS
GNBSPE = 0
For [ADA]ADA0 Where DOSSIER=[F:ADS]DOSSIER & CODACT>="X"
 If GDOSREF=GDOSX3 or [F:ADA]COP<>2
  GNBSPE += 1
  GSPE(GNBSPE) = [F:ADA]CODACT
 Endif
Next ADA

# Mise à jour du livrable
If [M:ACOP2]LIVCODD(1)<>""
 Read [ADK]ADK0=[F:ADS]DOSSIER;[M:ACOP2]LIVCODD(1)
 If fstat
  Trbegin [ADK]
   Raz [ADK]
   [F:ADK]DOSSIER = [F:ADS]DOSSIER
   [F:ADK]COD     = [M:ACOP2]LIVCODD(1)
   [F:ADK]INSTAL  = 2
   Write [ADK]
  Commit
 Endif
Endif

# Tri des kits

Sorta [M:ACOP2]NBKITD [M:ACOP2]ROWKITD,[M:ACOP2]KITCODD Order By [M:ACOP2]ROWKITD(indice+1) Asc

If !GSERVEUR & !GIMPORT
 GINFO = 1
Else
 GINFO = 0
Endif

If GINFO
 Call OUVRE_VLC(mess(174,125,1)-[F:ADS]DOSSIER,"","") From GESECRAN : # Copie
Endif

# Copie des données
Call OUVRE_TRACE(mess(30,125,1)-[F:ADS]DOSSIER) From LECFIC

# Début de copie
Call ECR_TRACE(mess(174,125,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

# Copie des données
Call COPY_FILE([M:ACOP0]DOSDES,[M:ACOP0]DOSORI,[F:ADS]DOSREF,[M:ACOP1]OPTINI,[F:ADS]MODULE,[F:ADS]CRYDEF
& ,([M:ACOP1]AJOUT=2),[M:ACOP1]LEG,[M:ACOP2]LIVCODD,[M:ACOP2]KITCODD,([M:ACOP1]DETAIL=2),NBCOP,TBCOP)

# Copie des valeurs des paramétres généraux
Call COPY_PARAMETER([M:ACOP0]DOSDES,[M:ACOP0]DOSORI,[F:ADS]DOSREF,[M:ACOP1]LEGD,[M:ACOP2]LIVCODD,[M:ACOP2]KITCODD
& ,([M:ACOP1]AJOUT=2),([M:ACOP1]DETAIL=2))

# Copie des tables diverses
Call COPY_TABDIV([M:ACOP0]DOSDES,[M:ACOP0]DOSORI,[F:ADS]DOSREF,[M:ACOP1]LEGD,[M:ACOP2]LIVCODD,[M:ACOP2]KITCODD
& ,([M:ACOP1]AJOUT=2),([M:ACOP1]DETAIL=2))

# Vérif des liens
Call CONTROL_LINKS([M:ACOP0]DOSDES,([M:ACOP1]DETAIL=2),NBCOP,TBCOP)

# Fiche du dossier destinataire et paramètre général DOSLEG
Call UPDATE_FOLDER_LEG([M:ACOP0]DOSDES,[M:ACOP1]LEG,[M:ACOP1]NBLEG) : #  114946 CCL various troubles in legislation copy (ADOSCOPDAT)
Call UPDATE_FOLDER_KIT([M:ACOP0]DOSDES,[M:ACOP2]LIVCODD,[M:ACOP2]KITCODD)

# Fin de génération
Call ECR_TRACE(mess(175,125,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

Call FERME_TRACE From LECFIC

If GINFO
 Call FERME_VLC From GESECRAN
Endif

TRA = 1
Return

#----------------------------------------------------------------------------------------------------------#
# Copie des données
#----------------------------------------------------------------------------------------------------------#

Subprog COPY_FILE(DOSSIER,DOSCOP,DOSREF,OPTINI,MODULE,CRYDEF,LEGNUL,TBLEG,TBLIV,TBKIT,DETAIL,NBCOP,TBCOP)
Value    Char    DOSSIER
Value    Char    DOSCOP
Value    Char    DOSREF
Value    Integer OPTINI(1..)
Value    Integer MODULE(1..)
Value    Char    CRYDEF
Value    Integer LEGNUL
Value    Char    TBLEG()(1..) : # Législations
Value    Char    TBLIV()(1..) : # Livrables
Value    Char    TBKIT()(1..) : # Kits
Value    Integer DETAIL
Variable Integer NBCOP
Variable Char    TBCOP()(1..)

Local Integer I , J , K , L , T , OK , M
Local Shortint MAXCOP : MAXCOP = dim(TBCOP)
Local Integer WORI , WNUL , NUTAB , ONELEG , ERR , WLEG
Local Integer TBORI(1..MAXCOP) , TBNUL(1..MAXCOP) , TBALL(1..MAXCOP)
Local Integer NBCOPKIT , TBNULKIT(1..MAXCOP) , TBORIKIT(1..MAXCOP) , TBALLKIT(1..MAXCOP)
Local Char    TBCOPKIT(GLONATB)(1..MAXCOP)
Local Char    WTAB(GLONATB) , MIGTABLE(GLONATB)
Local Char    TBLAN(GLONLAN)(1..50)
Local Integer NBLAN , NBLEG , OLDLEG , NEWLEG , NBCLEG
Local Char    TBOLEG(GLONADI)(1..250) , TBNLEG(GLONADI)(1..250) , TBCLEG(GLONADI)(1..250)

If clalev([F:AWM])=0  : Local File =DOSCOP+".AWRKLNK"   [AWM]  : Endif
If clalev([F:AWK])=0  : Local File =DOSCOP+".AWRKTAB"   [AWK]  : Endif
If clalev([F:ATB])=0  : Local File =DOSCOP+".ATABLE"    [ATB]  : Endif
If clalev([F:ATI])=0  : Local File =DOSCOP+".ATABIND"   [ATI]  : Endif
If clalev([F:AMP])=0  : Local File =DOSCOP+".AMSKPAR"   [AMP]  : Endif
If clalev([F:ATZ])=0  : Local File =DOSCOP+".ATABZON"   [ATZ]  : Endif
If clalev([F:ATY])=0  : Local File =DOSCOP+".ATYPE"     [ATY]  : Endif
If clalev([F:ADLO])=0 : Local File =GDOSX3+".ADELIVERO" [ADLO] : Endif
If clalev([F:ADL2])=0 : Local File =GDOSX3+".ADELIVERO" [ADL2] : Endif
If clalev([F:ATB2])=0 : Local File =DOSSIER+".ATABLE"   [ATB2] : Endif
If clalev([F:AXX2])=0 : Local File =DOSSIER+".ATEXTRA"  [AXX2] : Endif
If clalev([F:ACV8])=0 : Local File =DOSSIER+".ACTIV"    [ACV8] : Endif

# Copie des données - Autres tables

Call ECR_TIME(mess(30,125,1)-mess(276,125,1)) From DOSSUB
If GINFO
 Call AFF_VLC(mess(30,125,1),mess(276,125,1)) From GESECRAN
Endif

# Dossier mono-législation

ONELEG = !func AFNC.ACVDOSACT(DOSSIER,"LEG")

# Rajout de législation ?

Call SETLEG([L]DOSSIER,TBOLEG,OLDLEG) From DOSCONT
If ONELEG
 TBNLEG(1) = [F:ADS]DOSLEG(0)
 If TBOLEG=""
  Call ECR_TIME(mess(79,127,1)-":"-[L]TBNLEG(1)) From DOSSUB : # Nouvelle législation
 Endif
Else
 For I=1 To dim(TBLEG)
  If [L]TBLEG(I)=""
   NBLEG = I-1
   Break
  Endif
  If !find([L]TBLEG(I),TBOLEG(1..OLDLEG))
   NEWLEG += 1
   TBNLEG(NEWLEG) = [L]TBLEG(I)
   Call ECR_TIME(mess(79,127,1)-":"-[L]TBLEG(I)) From DOSSUB : # Nouvelle législation
  Endif
 Next I
Endif

# Tables impactées par le livrable

If GINFO
 # Copie des données - Livrable
 Call AFF_VLC(mess(30,125,1),mess(1,2907,1)) From GESECRAN
Endif

For I=1 To dim(TBLIV)
 If TBLIV(I)="" : Break : Endif
 NEWLIV = 0
 Read [ADK]ADK0=DOSSIER;[L]TBLIV(I)
 If fstat or [F:ADK]INSTAL<>2
  Call ECR_TIME(mess(268,143,1)-":"-[L]TBLIV(I)) From DOSSUB : # Nouveau livrable
  NEWLIV = 1
 Endif
 For [ADL2]ADLO0(2) Where COD=TBLIV(I) & TABCOD<>"ATABDIV"
  If dim(GTESTFILE)<1 or GTESTFILE="" or GTESTFILE=[F:ADL2]TABCOD
   WTAB = [F:ADL2]TABCOD
   WNUL = 0
   Read [ATB]CODFIC=WTAB
   If !fstat & ([F:ATB]CRE=2) or ([F:ATB]CRE=3 & [L]OPTINI([F:ATB]OPT)=2)
    Call MIGTABNAME([L]DOSSIER,WTAB,MIGTABLE,ERR) From TRTMIG
    Read [ATB2]CODFIC=MIGTABLE
    If !fstat & [F:ATB2]CODACT="MIG"
     WNUL = 1 : # Table en cours de migration, toutes les autres tables du modèle ne sont pas copiées
    Endif
    If [F:ADL2]NULRECFLG=2
     WNUL = 1
    Endif
    If !WNUL
     WORI = 0
     If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSSIER),0)>=0
      If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSCOP),0)>=0
       WORI = 1
      Elsif filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSREF),0)>=0
       WORI = 2
      Elsif filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",GDOSX3),0)>=0
       WORI = 3
      Endif
     Endif
     If !WORI
      WNUL = 1
     Endif
    Endif
    If !WNUL
     Local File =[L]DOSSIER+"."+[F:ATB]CODFIC [F2]
     If nbrecord([F2])=0 or NEWLIV
      WLEG = 1
     Elsif [F:ATB]FLGLEG=2 & NEWLEG
      WLEG = 0
     Else
      WNUL = 1
     Endif
     Close Local File [F2]
    Endif
   Else
    WNUL = 1
   Endif
   Gosub ADDTABCOP
   NUTAB = find(WTAB,TBCOP(1..NBCOP))
   If [F:ADL2]TABAWM<>""
    Read [AWM]AWM0=[F:ADL2]TABAWM
    WTAB = [F:AWM]TABREF
    Gosub ADDTABCOP
    For [AWK] Where MODELE=[F:AWM]MODELE
     WTAB = [F:AWK]TABLNK
     Gosub ADDTABCOP
    Next AWK
   Endif
   If !TBNUL(NUTAB)
    If DETAIL
     # Copie du $1$ $2$ (table $3$)
     Call ECR_TIME(mess(30,125,1)-func AFNC.MES3(mess(266,143,1),mess(1,2907,1),[F:ADL2]COD,[F:ADL2]TABCOD)) From DOSSUB
    Endif
    WLEG = TBALL(NUTAB)
    Gosub LOAD_LEG
    Call COPY(DOSSIER,DOSCOP,DOSREF,TBORI(NUTAB),TBCLEG,NBCLEG,TBLAN,NBLAN,CRYDEF,LEGNUL,ONELEG,MODULE
&       ,[F:ADL2]COD,[F:ADL2]TABAWM,DETAIL) From ADOSCOPMOD
   Endif
  Endif
 Next ADL2
Next I

# Tables non impactées par les livrables

For [ATB]CODFIC Where TYPFIC<3 & CODFIC<>"ATEXTRA"
 If !find([F:ATB]CODFIC,TBCOP(1..NBCOP)) & (dim(GTESTFILE)<1 or GTESTFILE="" or GTESTFILE=[F:ATB]CODFIC)
  If ([F:ATB]CRE=2) or ([F:ATB]CRE=3 & [L]OPTINI([F:ATB]OPT)=2)
   WTAB = [F:ATB]CODFIC
   WNUL = 0
   Call MIGTABNAME([L]DOSSIER,WTAB,MIGTABLE,ERR) From TRTMIG
   Read [ATB2]CODFIC=MIGTABLE
   If !fstat and [F:ATB2]CODACT="MIG"
    WNUL = 1
   Endif
   If !WNUL
    WORI = 0
    If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSSIER),0)>=0
     If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSCOP),0)>=0
      WORI = 1
     Elsif filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSREF),0)>=0
      WORI = 2
     Elsif filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",GDOSX3),0)>=0
      WORI = 3
     Endif
    Endif
    If !WORI
     WNUL = 1
    Endif
   Endif
   If !WNUL
    Local File =[L]DOSSIER+"."+[F:ATB]CODFIC [F2]
    If nbrecord([F2])=0 or (dim(GTESTFILE)>0 and GTESTFILE=[F:ATB]CODFIC)
     WLEG = 1
    Elsif [F:ATB]FLGLEG=2 & NEWLEG
     WLEG = 0
    Else
     WNUL = 1
    Endif
    Close Local File [F2]
   Endif
  Else
   WNUL = 1
  Endif
  Gosub ADDTABCOP
  If !WNUL
   If GINFO
    # Copie des données - Table
    Call AFF_VLC(mess(30,125,1),mess(56,123,1)-[F:ATB]CODFIC) From GESECRAN
   Endif
   If DETAIL
    Call ECR_TIME(mess(30,125,1)-mess(56,123,1)-[F:ATB]CODFIC) From DOSSUB
   Endif
   Gosub LOAD_LEG
   Call COPY(DOSSIER,DOSCOP,DOSREF,WORI,TBCLEG,NBCLEG,TBLAN,NBLAN,CRYDEF,LEGNUL,ONELEG,MODULE
&        ,[F:ATB]CODFIC,DETAIL) From ADOSCOPTAB
  Endif
 Endif
Next ATB

# Copy des kits

If GINFO
 # Copie des données - Kit
 Call AFF_VLC(mess(30,125,1),mess(2,2907,1)) From GESECRAN
Endif

For I=1 To dim(TBKIT)
 If TBKIT(I)="" : Break : Endif
 NEWKIT = 0
 Read [ADK]ADK0=DOSSIER;[L]TBKIT(I)
 If fstat or [F:ADK]INSTAL<>2
  Call ECR_TIME(mess(269,143,1)-":"-[L]TBKIT(I)) From DOSSUB : # Nouveau kit
  NEWKIT = 1
 Endif
 For [ADL2]ADLO0(2) Where COD=TBKIT(I) & TABCOD<>"ATABDIV"
  If dim(GTESTFILE)<1 or GTESTFILE="" or GTESTFILE=[F:ADL2]TABCOD
   WTAB = [F:ADL2]TABCOD
   WNUL = 0
   Read [ATB]CODFIC=WTAB
   If !fstat & ([F:ATB]CRE=2) or ([F:ATB]CRE=3 & [L]OPTINI([F:ATB]OPT)=2)
    Call MIGTABNAME([L]DOSSIER,WTAB,MIGTABLE,ERR) From TRTMIG
    Read [ATB2]CODFIC=MIGTABLE
    If !fstat & [F:ATB2]CODACT="MIG"
     WNUL = 1 : # Table en cours de migration, toutes les autres tables du modèle ne sont pas copiées
    Endif
    If [F:ADL2]NULRECFLG=2
     WNUL = 1
    Endif
    If !WNUL
     WORI = 0
     If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSSIER),0)>=0
      If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSCOP),0)>=0
       WORI = 1
      Elsif filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSREF),0)>=0
       WORI = 2
      Elsif filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",GDOSX3),0)>=0
       WORI = 3
      Endif
     Endif
     If !WORI
      WNUL = 1
     Endif
    Endif
    If !WNUL
     Local File =[L]DOSSIER+"."+[F:ATB]CODFIC [F2]
     If nbrecord([F2])=0 or NEWKIT
      WLEG = 1
     Elsif [F:ATB]FLGLEG=2 & NEWLEG
      WLEG = 0
     Else
      WNUL = 1
     Endif
     Close Local File [F2]
    Endif
   Else
    WNUL = 1
   Endif
   Gosub ADDCOPKIT
   NUTAB = find(WTAB,TBCOPKIT(1..NBCOPKIT))
   If [F:ADL2]TABAWM<>""
    Read [AWM]AWM0=[F:ADL2]TABAWM
    WTAB = [F:AWM]TABREF
    Gosub ADDCOPKIT
    For [AWK] Where MODELE=[F:AWM]MODELE
     WTAB = [F:AWK]TABLNK
     Gosub ADDCOPKIT
    Next AWK
   Endif
   If !TBNULKIT(NUTAB)
    If DETAIL
     # Copie du $1$ $2$ (table $3$)
     Call ECR_TIME(mess(30,125,1)-func AFNC.MES3(mess(266,143,1),mess(2,2907,1),[F:ADL2]COD,[F:ADL2]TABCOD)) From DOSSUB
    Endif
    WLEG = TBALLKIT(NUTAB)
    Gosub LOAD_LEG
    Call COPY(DOSSIER,DOSCOP,DOSREF,TBORIKIT(NUTAB),TBCLEG,NBCLEG,TBLAN,NBLAN,CRYDEF,LEGNUL,ONELEG,MODULE
&       ,[F:ADL2]COD,[F:ADL2]TABAWM,DETAIL) From ADOSCOPMOD
   Endif
  Endif
 Next ADL2
Next I
For I=1 To NBCOPKIT
 J = find(TBCOPKIT(I),TBCOP(1..NBCOP))
 If !J
  WTAB = TBCOPKIT(I)
  WNUL = TBNULKIT(I)
  WORI = TBORIKIT(I)
  Gosub ADDTABCOP
 Endif
Next I
J = 0
For I=1 To NBCOP
 If TBNUL(I)
  TBCOP(I) = ""
 Else
  J += 1
 Endif
Next I
Sorta NBCOP TBCOP Order By TBCOP(indice+1) Desc
NBCOP = J

# Pour gérer le cas des adresses par exemple

ACTION = "DOSCOP" : Gosub ACTION From SUBADS

End

#--------------------#
$LOAD_LEG
Raz TBCLEG , NBCLEG
If WLEG
 For L=1 To dim(TBLEG)
  If TBLEG(L)="" : NBCLEG = L-1 : Break : Endif
  TBCLEG(L) = TBLEG(L)
 Next L
Else
 For L=1 To dim(TBNLEG)
  If TBNLEG(L)="" : NBCLEG = L-1 : Break : Endif
  TBCLEG(L) = TBNLEG(L)
 Next L
Endif
Return

#-------------------------------#
$ADDTABCOP
T = find(WTAB,TBCOP(1..NBCOP))
If T
 TBCOP(T) = WTAB
 TBNUL(T) = WNUL
 TBORI(T) = WORI
 TBALL(T) = WLEG
Else
 NBCOP += 1
 TBCOP(NBCOP) = WTAB
 TBNUL(NBCOP) = WNUL
 TBORI(NBCOP) = WORI
 TBALL(NBCOP) = WLEG
Endif
Return

#-------------------------------#
$ADDCOPKIT
T = find(WTAB,TBCOPKIT(1..NBCOPKIT))
If T
 TBCOPKIT(T) = WTAB
 TBNULKIT(T) = WNUL
 TBORIKIT(T) = WORI
 TBALLKIT(T) = WLEG
Else
 NBCOPKIT += 1
 TBCOPKIT(NBCOPKIT) = WTAB
 TBNULKIT(NBCOPKIT) = WNUL
 TBORIKIT(NBCOPKIT) = WORI
 TBALLKIT(NBCOPKIT) = WLEG
Endif
Return

#---------------------------------------------------------------------------------------#
Subprog UPDATE_TEXTRA(TBLAN,NBLAN,REPET,ABRORG,ABRDES,TABLE1,ZONE,CLECUR1,CLECUR2)
Variable Char    TBLAN()(1..)
Variable Integer NBLAN
Value    Integer REPET
Value    Char    ABRORG , ABRDES
Value    Char TABLE1 , ZONE , CLECUR1 , CLECUR2

Local Integer I , ODIME
Local Char    ODEFCLA(250) , NDEFCLA(10)
Local Char    TABLEORG(50) , ZONEORG(50) , KEY1ORG(50) , KEY2ORG(80)
Local Char    TABLEDES(50) , ZONEDES(50) , KEY1DES(50) , KEY2DES(80)
If NBLAN=0
 For [AXX2]AXX1(1)
  NBLAN += 1
  If NBLAN>dim(TBLAN)
   Break
  Endif
  TBLAN(NBLAN) = [F:AXX2]LANGUE
 Next AXX2
Endif
ODEFCLA = dbgstr(2)
ODIME   = indice
NDEFCLA = "["+ABRORG+"]"
Default File NDEFCLA
Default [F],[L],[S],[V],[M]
For I=1 To REPET
 nolign = I
 indice = nolign-1
 NDEFCLA = "["+ABRORG+"]"
 Default File NDEFCLA
 TABLEORG = num$(evalue(ctrans(TABLE1,"¨",'"')))
 ZONEORG  = num$(evalue(ctrans(ZONE,"¨",'"')))
 KEY1ORG = num$(evalue(ctrans(CLECUR1,"¨",'"')))
 KEY2ORG = num$(evalue(ctrans(CLECUR2,"¨",'"')))
 For [AXX1]AXX0 Where CODFIC=TABLEORG & ZONE=ZONEORG & IDENT1=KEY1ORG & IDENT2=KEY2ORG
  If find([F:AXX1]LANGUE,TBLAN) or 1=1 : # On copie toutes finalement toutes les langues
   NDEFCLA = "["+ABRDES+"]"
   Default File NDEFCLA
   TABLEDES = num$(evalue(ctrans(TABLE1,"¨",'"')))
   ZONEDES  = num$(evalue(ctrans(ZONE,"¨",'"')))
   KEY1DES  = num$(evalue(ctrans(CLECUR1,"¨",'"')))
   KEY2DES  = num$(evalue(ctrans(CLECUR2,"¨",'"')))
   Look [AXX2]AXX0=TABLEDES;ZONEDES;[F:AXX1]LANGUE;KEY1DES;KEY2DES
   If fstat
    [F:AXX2]CODFIC = TABLEDES
    [F:AXX2]ZONE   = ZONEDES
    [F:AXX2]IDENT1 = KEY1DES
    [F:AXX2]IDENT2 = KEY2DES
    [F:AXX2]LANGUE = [F:AXX1]LANGUE
    [F:AXX2]LANORI = [F:AXX1]LANORI
    [F:AXX2]TEXTE  = [F:AXX1]TEXTE
    If dim([F:AXX2]CREDAT)>0 : [F:AXX2]CREDAT = [F:AXX1]CREDAT : Endif
    If dim([F:AXX2]UPDDAT)>0 : [F:AXX2]UPDDAT = date$ : Endif
    If dim([F:AXX2]CREUSR)>0 : [F:AXX2]CREUSR = [F:AXX1]CREUSR : Endif
    If dim([F:AXX2]UPDUSR)>0 : [F:AXX2]UPDUSR = GUSER : Endif
    If dim([F:AXX2]CREDATTIM)>0 : [F:AXX2]CREDATTIM = [F:AXX1]CREDATTIM : Endif
    Write [AXX2]
    If fstat
     Call ERREUR([F:AXX2]CODFIC-[F:AXX2]ZONE-[F:AXX2]LANGUE-[F:AXX2]IDENT1-[F:AXX2]IDENT1,2) From DOSDIC
    Endif
   Endif
  Endif
 Next AXX1
Next I
Default [L],[S],[V],[M],[F]
If ODEFCLA<>"" : Default File ODEFCLA : Endif
indice = ODIME
nolign = indice+1
End

#--------------------------------------#
Subprog COPY_LNKFILES(TYP,COD)
Value Integer TYP
Value Char    COD
Case TYP
 When 2 : # Requêtes SQL
  Gosub COPY_ACB
  Gosub COPY_ARX
  Gosub COPY_ARV
 When 3 : # Requêtes STD
  Gosub COPY_ARX
  Gosub COPY_ARV
 When 4 : # Modèle d'import
  Gosub COPY_ARX
  Gosub COPY_ARV
Endcase
End

#------------------------------------#
$COPY_ACB
Gosub PFIX From SUBALQ
Read [ACB]ACB0=IDCLOB;COD;"";""
If !fstat
 [F:DEST_ACB] = [F:ACB]
 Write [DEST_ACB]
 If fstat
  Call ERREUR("ACLOB",1) From DOSDIC
 Endif
Endif
Return

#------------------------------------------------#
$COPY_ARX
Delete [DEST_ARX] Where TYPCOD=TYP & INTCOD=COD
For [ARX] Where TYPCOD=TYP & INTCOD=COD
 [F:DEST_ARX] = [F:ARX]
 Write [DEST_ARX]
 If fstat
  Call ERREUR("AREPORTX",1) From DOSDIC
 Endif
Next ARX
Return

#-----------------------------------------------#
$COPY_ARV
Delete [DEST_ARV] Where TYPCOD=TYP & ETAT=COD
For [ARV] Where TYPCOD=TYP & ETAT=COD
 [F:DEST_ARV] = [F:ARV]
 Write [DEST_ARV]
 If fstat
  Call ERREUR("AREPORTV",1) From DOSDIC
 Endif
Next ARV
Return

#---------------------------------#
$COPY_TCA
If [F:TCA]CPY="" & [F:TCA]LEG="" & ONELEG
 [F:TCA]LEG = TBLEG(1)
Endif
Readlock [DEST_]TCA0 = [F:TCA]MODULE;[F:TCA]LEG;[F:TCA]CPY
If fstat=1
 Call ERREUR("TABCOUAFF",5) From DOSDIC
Elsif fstat
 [F:DEST_] = [F:TCA]
 Write [DEST_]
 If fstat
  Call ERREUR("TABCOUAFF",1) From DOSDIC
 Endif
Else
 [F:DEST_] = [F:TCA]
 Rewrite [DEST_]
 If fstat
  Call ERREUR("TABCOUAFF",2) From DOSDIC
 Endif
Endif
Return

#---------------------------------#
$COPY_TFO
Readlock [DEST_]TFO0 = [F:TFO]FORTYP;[F:TFO]FORCOD
If fstat=1
 Call ERREUR("TABFOR",5) From DOSDIC
Elsif fstat
 Raz [F:DEST_]
 [F:DEST_]FORTYP = [F:TFO]FORTYP
 [F:DEST_]FORCOD = [F:TFO]FORCOD
 Gosub MAJ_FORMULES
 Write [DEST_]
 If fstat
  Call ERREUR("TABFOR",1) From DOSDIC
 Endif
Else
 Gosub MAJ_FORMULES
 Rewrite [DEST_]
 If fstat
  Call ERREUR("TABFOR",2) From DOSDIC
 Endif
Endif
Return

#---------------------------------#
$MAJ_FORMULES
If sum([F:TFO]FORTYP)<>21
 [F:DEST_]FORFOR(0) = [F:TFO]FORFOR(0)
Else
 Local Char TBOLEG(GLONADI)(1..250)
 Local Integer OLDLEG
 Call SETLEG([L]DOSSIER,TBOLEG,OLDLEG) From DOSCONT

 For I=1 To dim(TBLEG)
  If TBLEG(I)="" : Break : Endif
  K = find(TBLEG(I),[F:TFO]LEG)
  J = find(TBLEG(I),[F:DEST_]LEG)
  M = find(TBLEG(I),TBOLEG(1..OLDLEG))
  If K & J & !M
   [F:DEST_]FORFOR(J-1) = [F:TFO]FORFOR(K-1)
  Elsif K & !J
   J = find("",[F:DEST_]LEG)
   If J
    [F:DEST_]LEG(J-1)    = [F:TFO]LEG(K-1)
    [F:DEST_]FORFOR(J-1) = [F:TFO]FORFOR(K-1)
   Endif
  Endif
 Next I
 For I=1 To [F:ADS]NBLEG
  K = find([F:ADS]DOSLEG(I-1),[F:TFO]LEG)
  J = find([F:ADS]DOSLEG(I-1),[F:DEST_]LEG)
  M = find([F:ADS]DOSLEG(I-1),TBOLEG(1..OLDLEG))
  If K & J & !M
   [F:DEST_]FORFOR(J-1) = [F:TFO]FORFOR(K-1)
  Endif
 Next I
Endif
[F:DEST_]FORNUM = [F:TFO]FORNUM
Call COPTEXTRA("TABFOR","DES",num$([F:TFO]FORTYP),[F:TFO]FORCOD) From ATEXTRA
Call COPTEXTRA("TABFOR","DESSHO",num$([F:TFO]FORTYP),[F:TFO]FORCOD) From ATEXTRA
Return

#------------------------------------------------------#
# Mise à jour du dossier
#------------------------------------------------------#

Subprog UPDATE_FOLDER_LEG(DOSSIER,LEGD,NBLEGD)
Value Char    DOSSIER
Value Char    LEGD()(1..)
Value Integer NBLEGD

Local Integer I , OK

Local File =[L]DOSSIER+".ADOVAL" [ADW]

If GINFO
 Call AFF_VLC(mess(3,125,1)-DOSSIER,"") From GESECRAN : # Mise à jour du dossier
Endif
Call ECR_TIME(mess(3,125,1)-DOSSIER) From DOSSUB : # Mise à jour du dossier

Trbegin [F:ADS]

 # Mise à jour législations
 Read [F:ADS]DOSSIER = [L]DOSSIER
 If !fstat
  For I=1 To [L]NBLEGD
   If !find(LEGD(I),[F:ADS]DOSLEG(0..[F:ADS]NBLEG-1)) & LEGD(I)<> ""
    [F:ADS]DOSLEG([F:ADS]NBLEG) = LEGD(I)
    [F:ADS]NBLEG += 1
    OK = 1
   Endif
  Next I
  If OK
   Rewrite [F:ADS]
   If fstat
    Call ERREUR("ADOSSIER"-[F:ADS]DOSSIER,2) From DOSDIC
   Else
    Call MAJPAR("DOSLEG",sigma(0,[F:ADS]NBLEG-1,string$(indcum>0,"~")+[F:ADS]DOSLEG(indcum)))  From DOSDIV
   Endif
  Endif
 Endif

Commit

End

#------------------------------------------------------------------#
Subprog UPDATE_FOLDER_KIT(DOSSIER,TBLIV,TBKIT)
Value Char    DOSSIER
Value Char    TBLIV()(1..) , TBKIT()(1..)

Local Integer I , OK

Local File =[L]DOSSIER+".ADOVAL" [ADW]

If GINFO
 Call AFF_VLC(mess(3,125,1)-DOSSIER,"") From GESECRAN : # Mise à jour du dossier
Endif
Call ECR_TIME(mess(3,125,1)-DOSSIER) From DOSSUB : # Mise à jour du dossier

Trbegin [F:ADS]

 # On ajoute les nouveaux livrables
 For I=1 To dim(TBLIV)
  If TBLIV(I)="" : Break : Endif
  Read [ADK]ADK0=[L]DOSSIER;TBLIV(I)
  If fstat
   Raz [F:ADK]
   [F:ADK]DOSSIER = [L]DOSSIER
   [F:ADK]COD     = TBLIV(I)
   [F:ADK]INSTAL  = 2
   Write [ADK]
   If fstat
    Call ERREUR("ADOSLIV"-[F:ADK]DOSSIER-[F:ADK]COD,1) From DOSDIC
   Endif
  Elsif !fstat and [F:ADK]INSTAL<>2
   [F:ADK]INSTAL  = 2
   Rewrite [ADK]
   If fstat
    Call ERREUR("ADOSLIV"-[F:ADK]DOSSIER-[F:ADK]COD,2) From DOSDIC
   Endif
  Endif
 Next I

 # Et les nouveaux kits
 For I=1 To dim(TBKIT)
  If TBKIT(I)="" : Break : Endif
  Read [ADK]ADK0=[L]DOSSIER;TBKIT(I)
  If fstat
   Raz [F:ADK]
   [F:ADK]DOSSIER = [L]DOSSIER
   [F:ADK]COD     = TBKIT(I)
   [F:ADK]INSTAL  = 2
   Write [ADK]
   If fstat
    Call ERREUR("ADOSLIV"-[F:ADK]DOSSIER-[F:ADK]COD,1) From DOSDIC
   Endif
  Elsif !fstat and [F:ADK]INSTAL<>2
   [F:ADK]INSTAL  = 2
   Rewrite [ADK]
   If fstat
    Call ERREUR("ADOSLIV"-[F:ADK]DOSSIER-[F:ADK]COD,2) From DOSDIC
   Endif
  Endif
 Next I

Commit

End

#---------------------------------------------------------------------------------------#
# Copie des valeurs des paramétres généraux
#---------------------------------------------------------------------------------------#

Subprog COPY_PARAMETER(DOSSIER,DOSCOP,DOSREF,TBLEG,TBLIV,TBKIT,LEGNUL,DETAIL)
Value Char    DOSSIER
Value Char    DOSCOP
Value Char    DOSREF
Value Char    TBLEG()(1..)
Value Char    TBLIV()(1..)
Value Char    TBKIT()(1..)
Value Integer LEGNUL
Value Integer DETAIL

Local File =[L]DOSSIER+".ADOVAL"  [DADW]
Local File =[L]DOSCOP+".ADOVAL"   [ADW]
Local File =[L]DOSSIER+".ADOPAR"  [DADP]
Local File =GDOSX3+".ADELIVERP"   [ADLP]
If clalev([F:ADA])=0 : Local File ADOSACT [ADA] : Endif

Local Integer I , J , K , OK
Local Char    TBOLEG(GLONADI)(1..200) , TBNLEG(GLONADI)(1..200)
Local Integer NBLEG , ONELEG , NEWLEG , OLDLEG , NEWKIT , NEWLIV

# Copie des données - Paramètres généraux

Call ECR_TIME(mess(30,125,1)-mess(25,125,1)) From DOSSUB
If GINFO
 Call AFF_VLC(mess(30,125,1),mess(25,125,1)) From GESECRAN
Endif

# Mono-législation ?

ONELEG = !func AFNC.ACVDOSACT(DOSSIER,"LEG")

# Rajout de législation ?

If ONELEG
 TBNLEG(1) = [F:ADS]DOSLEG(0)
Else
 Call SETLEG([L]DOSSIER,TBOLEG,OLDLEG) From DOSCONT
 For I=1 To dim(TBLEG)
  If [L]TBLEG(I)=""
   NBLEG = I-1
   Break
  Endif
  If !find([L]TBLEG(I),TBOLEG(1..OLDLEG))
   NEWLEG += 1
   TBNLEG(NEWLEG) = [L]TBLEG(I)
   If DETAIL
    Call ECR_TIME(mess(79,127,1)-":"-[L]TBLEG(I)) From DOSSUB : # Nouvelle législation
   Endif
  Endif
 Next I
Endif

Gosub COPY_KIT
Gosub COPY_STD

End

#-----------------------------#
$COPY_KIT

# Livrables

For I=1 To dim(TBLIV)
 If TBLIV(I)="" : Break : Endif
 NEWLIV = 0
 Read [ADK]ADK0=DOSSIER;[L]TBLIV(I)
 If fstat or (!fstat and [F:ADK]INSTAL<>2)
  If DETAIL
   Call ECR_TIME(mess(268,143,1)-":"-[L]TBLIV(I)) From DOSSUB : # Nouveau livrable
  Endif
  NEWLIV = 1
 Endif
 If NEWLIV or NEWLEG
  For [ADLP] Where COD=TBLIV(I)
   Read [DADP]ADP1=[F:ADLP]PARAM
   If !fstat & (dim(GTESTFILE)<1 or GTESTFILE="" or GTESTFILE=[F:DADP]PARAM)
    OK = 1
    If [F:ADLP]CLEPARAM=""
     Read [DADW]ADW0="";"";[F:ADLP]PARAM
    Elsif ONELEG
     If [F:ADLP]CLEPARAM<>TBNLEG(1)
      OK = 0
     Else
      Read [DADW]ADW0="*";TBNLEG(1);[F:ADLP]PARAM
     Endif
    Elsif (NEWLIV & find([F:ADLP]CLEPARAM,TBLEG)) or (NEWLEG & find([F:ADLP]CLEPARAM,TBNLEG(1..NEWLEG)))
     Read [DADW]ADW0="*";[F:ADLP]CLEPARAM;[F:ADLP]PARAM
    Else
     OK = 0
    Endif
    If OK
     If fstat
      Raz [F:DADW]
      If [F:ADLP]CLEPARAM=""
       [F:DADW]CMP = ""
       [F:DADW]FCY = ""
      Else
       [F:DADW]CMP = "*"
       [F:DADW]FCY = [F:ADLP]CLEPARAM
      Endif
      [F:DADW]PARAM = [F:ADLP]PARAM
      [F:DADW]VALEUR = [F:ADLP]VALPARAM
      Write [DADW]
      If fstat
       Call ERREUR("ADOVAL"-[F:DADW]PARAM-[F:DADW]CMP-[F:DADW]FCY,1) From DOSDIC
      Elsif DETAIL
       # $1$ du paramètre $2$ (législation $3$) avec la valeur $4$
       Call ECR_TIME(func AFNC.MES4(mess(270,143,1),mess(59,123,1),[F:DADW]PARAM,[F:DADW]FCY,[F:DADW]VALEUR)) From DOSSUB
      Endif
     Else
      [F:DADW]VALEUR = [F:ADLP]VALPARAM
      Rewrite [DADW]
      If fstat
       Call ERREUR("ADOVAL"-[F:DADW]PARAM-[F:DADW]CMP-[F:DADW]FCY,2) From DOSDIC
      Elsif DETAIL
       # $1$ du paramètre $2$ (législation $3$) avec la valeur $4$
       Call ECR_TIME(func AFNC.MES4(mess(270,143,1),mess(271,143,1),[F:DADW]PARAM,[F:DADW]FCY,[F:DADW]VALEUR)) From DOSSUB
      Endif
     Endif
    Endif
   Endif
  Next ADLP
 Endif
Next I

# kits

For I=1 To dim(TBKIT)
 If TBKIT(I)="" : Break : Endif
 NEWKIT = 0
 Read [ADK]ADK0=DOSSIER;[L]TBKIT(I)
 If fstat or (!fstat and [F:ADK]INSTAL<>2)
  If DETAIL
   Call ECR_TIME(mess(269,143,1)-":"-[L]TBKIT(I)) From DOSSUB : # Nouveau kit
  Endif
  NEWKIT = 1
 Endif
 If NEWKIT or NEWLEG
  For [ADLP] Where COD=TBLIV(I)
   Read [DADP]ADP1=[F:ADLP]PARAM
   If !fstat & (dim(GTESTFILE)<1 or GTESTFILE="" or GTESTFILE=[F:DADP]PARAM)
    OK = 1
    If [F:ADLP]CLEPARAM=""
     Read [DADW]ADW0="";"";[F:ADLP]PARAM
    Elsif ONELEG
     If [F:ADLP]CLEPARAM<>TBNLEG(1)
      OK = 0
     Else
      Read [DADW]ADW0="*";TBNLEG(1);[F:ADLP]PARAM
     Endif
    Elsif (NEWKIT & find([F:ADLP]CLEPARAM,TBLEG)) or (NEWLEG & find([F:ADLP]CLEPARAM,TBNLEG(1..NEWLEG)))
     Read [DADW]ADW0="*";[F:ADLP]CLEPARAM;[F:ADLP]PARAM
    Else
     OK = 0
    Endif
    If OK
     If fstat
      Raz [F:DADW]
      If [F:ADLP]CLEPARAM=""
       [F:DADW]CMP = ""
       [F:DADW]FCY = ""
      Else
       [F:DADW]CMP = "*"
       [F:DADW]FCY = [F:ADLP]CLEPARAM
      Endif
      [F:DADW]PARAM = [F:ADLP]PARAM
      [F:ADW]VALEUR = [F:ADLP]VALPARAM
      Write [DADW]
      If fstat
       Call ERREUR("ADOVAL"-[F:DADW]PARAM-[F:DADW]CMP-[F:DADW]FCY,1) From DOSDIC
      Elsif DETAIL
       # $1$ du paramètre $2$ (législation $3$) avec la valeur $4$
       Call ECR_TIME(func AFNC.MES4(mess(270,143,1),mess(59,123,1),[F:DADW]PARAM,[F:DADW]FCY,[F:DADW]VALEUR)) From DOSSUB
      Endif
     Else
      [F:ADW]VALEUR = [F:ADLP]VALPARAM
      Rewrite [DADW]
      If fstat
       Call ERREUR("ADOVAL"-[F:DADW]PARAM-[F:DADW]CMP-[F:DADW]FCY,2) From DOSDIC
      Elsif DETAIL
       # $1$ du paramètre $2$ (législation $3$) avec la valeur $4$
       Call ECR_TIME(func AFNC.MES4(mess(270,143,1),mess(271,143,1),[F:DADW]PARAM,[F:DADW]FCY,[F:DADW]VALEUR)) From DOSSUB
      Endif
     Endif
    Endif
   Endif
  Next ADLP
 Endif
Next I
Return

#-----------------------------#
$COPY_STD
Trbegin [ADW]
 For [DADP]ADP0
  If dim(GTESTFILE)<1 or GTESTFILE="" or GTESTFILE=[F:DADP]PARAM
   # Si le dossier validé est en mono-législation,
   # On copie la valeur de la législation du dossier validé dans la valeur dossier
   If ONELEG
    Read [DADW]ADW0 = "";"";[F:DADP]PARAM
    If fstat
     Read [ADW]ADW0 = "*";[L]TBNLEG(1);[F:DADP]PARAM
     If !fstat
      [F:DADW] = [F:ADW]
      [F:DADW]CMP = ""
      [F:DADW]FCY = ""
      Write [DADW]
      If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
     Endif
    Endif
    Delete [DADW] Where PARAM=[F:DADP]PARAM & CMP="*"
   Else
    # Sinon on copie les valeurs des nouvelles législations
    For I=1 To NEWLEG
     If [L]TBNLEG(I)="" : Break : Endif
     Read [DADW]ADW0 = "*";[L]TBNLEG(I);[F:DADP]PARAM
     If fstat
      Read [ADW]ADW0 = "*";[L]TBNLEG(I);[F:DADP]PARAM
      If !fstat
       [F:DADW] = [F:ADW]
       Write [DADW]
       If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
      Endif
     Endif
    Next I
   Endif
  Endif
 Next DADP
Commit
Return

#--------------------------------------------------------------------------------------#
# Copie des tables diverses
#--------------------------------------------------------------------------------------#

Subprog COPY_TABDIV(DOSSIER,DOSCOP,DOSREF,TBLEG,TBLIV,TBKIT,LEGNUL,DETAIL)
Value Char    DOSSIER
Value Char    DOSCOP
Value Char    DOSREF
Value Char    TBLEG()(1..)
Value Char    TBLIV()(1..)
Value Char    TBKIT()(1..)
Value Integer LEGNUL
Value Integer DETAIL

Local Char    CHAINE(250)
Local Integer I , J , K , LIV, T , NEWKIT , NEWLIV
Local Shortint MAXDIV : MAXDIV = 2000
Local Integer OKLEG , SPEC , OLD , NEWREC
Local Integer STA1 , STA2 , ONELEG , NUTAB , WNUL , WNUM
Local Char    TBCOD(GLONADI)(1..MAXDIV)
Local Integer TBNUL(1..MAXDIV) , TBNUM(1..MAXDIV) , NBNUM , NBCOD
Local Integer FLGLIV , OLDLEG , NEWLEG , NBLEG , FLGREF
Local Char    TBOLEG(GLONADI)(1..250) , TBNLEG(GLONADI)(1..250)

Local File =[L]DOSREF +".ATABTAB" [ADV]
Local File =[L]DOSCOP +".ATABDIV" [ADI]
Local File =GDOSX3+".ADELIVERO"   [ADL2]

Local File =[L]DOSSIER+".ATABTAB" [DADV]
Local File =[L]DOSSIER+".ATABDIV" [DADI]
Local File =[L]DOSSIER+".ATEXTRA" [DAXX]
Local File =[L]DOSCOP +".ATEXTRA" [CAXX]
Local File =[L]DOSREF +".ATEXTRA" [RAXX]

Local Integer DIFFA(0..dim([F:ADV]COLALPTYP)-1)
Local Integer DIFFN(0..dim([F:ADV]COLNUMTYP)-1)

If clalev([F:ADA])=0  : Local File ADOSACT [ADA] : Endif

[L]FLGREF = (filinfo(filpath("","reference_folder","",DOSSIER),0)>0)

# Copie des données - Tables diverses

Call ECR_TIME(mess(30,125,1)-mess(75,125,1)) From DOSSUB
If GINFO
 Call AFF_VLC(mess(30,125,1)-mess(75,125,1),"") From GESECRAN
Endif

# Multi législation

ONELEG = !func AFNC.ACVDOSACT(DOSSIER,"LEG")

# Rajout de législation ?

If ONELEG
 TBNLEG(1) = [F:ADS]DOSLEG(0)
Else
 Call SETLEG([L]DOSSIER,TBOLEG,OLDLEG) From DOSCONT
 For I=1 To dim(TBLEG)
  If [L]TBLEG(I)=""
   NBLEG = I-1
   Break
  Endif
  If !find([L]TBLEG(I),TBOLEG(1..OLDLEG))
   NEWLEG += 1
   TBNLEG(NEWLEG) = [L]TBLEG(I)
   If DETAIL
    Call ECR_TIME(mess(79,127,1)-":"-[L]TBLEG(I)) From DOSSUB : # Nouvelle législation
   Endif
  Endif
 Next I
Endif

Trbegin [DADV]

 # Ménage

 For [DADV]
  Call SPEC([F:DADV]CODACT,SPEC) From DOSSUB
  #108011 If !SPEC and (GADONIX<>2 or [L]FLGREF)
  If !SPEC and (GADONIX<>2 or [L]FLGREF=0)
& and (dim(GTESTFILE)<1 or GTESTFILE="" or val(GTESTFILE)=[F:DADV]NUMTAB)
   Read [ADV]CODE = [F:DADV]NUMTAB
   If fstat
    # 114331 error in valdos with lock
    Delete [DAXX] Where CODFIC="ATABDIV" & IDENT1=num$([F:DADV]NUMTAB)
    #If fstat=1 : Call ERREUR("ATEXTRA ATABDIV"-num$([F:DADV]NUMTAB),3) From DOSDIC : Endif
    Delete [DAXX] Where CODFIC="ATABTAB" & IDENT1=num$([F:DADV]NUMTAB)
    #If fstat=1 : Call ERREUR("ATEXTRA ATABTAB"-num$([F:DADV]NUMTAB),3) From DOSDIC : Endif
    # 114331
    Delete [DADI] Where NUMTAB=[F:DADV]NUMTAB
    If fstat=1 : Call ERREUR("ATABDIV"-num$([F:DADV]NUMTAB),3) From DOSDIC : Endif
    Delete [DADV]
    If fstat=1 : Call ERREUR("ATABTAB"-num$([F:DADV]NUMTAB),3) From DOSDIC : Endif
   Endif
  Endif
 Next DADV

 # Ménage tables superviseur 901..999

 For [DADV] Where NUMTAB>900 & NUMTAB<1000
  If dim(GTESTFILE)<1 or GTESTFILE="" or val(GTESTFILE)=[F:DADV]NUMTAB
   For [DADI] Where NUMTAB=[F:DADV]NUMTAB & CODE<"X"
    Read [ADI]CODE = [F:DADI]NUMTAB ; [F:DADI]CODE
    If fstat
     Delete [DAXX] Where CODFIC="ATABDIV" & IDENT1=num$([F:DADI]NUMTAB) & IDENT2=[F:DADI]CODE
     If fstat=1 : Call ERREUR("ATABDIV"-num$([F:DADI]NUMTAB)-[F:DADI]CODE,3) From DOSDIC : Endif
     Delete [DADI]
     If fstat=1 : Call ERREUR("ATABDIV"-num$([F:DADI]NUMTAB)-[F:DADI]CODE,3) From DOSDIC : Endif
    Endif
   Next DADI
  Endif
 Next DADV

Commit

# Update from delivery

LIV = 1
NEWKIT = 0
For I=1 To dim(TBLIV)
 If TBLIV(I)="" : Break : Endif
 NEWLIV = 0
 Read [ADK]ADK0=DOSSIER;TBLIV(I)
 If fstat or (!fstat and [F:ADK]INSTAL<>2)
  If DETAIL
   Call ECR_TIME(mess(268,143,1)-":"-[L]TBLIV(I)) From DOSSUB : # Nouveau livrable
  Endif
  NEWLIV = 1
 Endif
 For [ADL2]ADLO0(2) Where COD=TBLIV(I) & TABCOD="ATABDIV"
  If dim(GTESTFILE)<1 or GTESTFILE="" or val(GTESTFILE)=[F:ADL2]TABADINUM
   WNUM = [F:ADL2]TABADINUM
   WNUL = 0
   NUTAB = find(WNUM,TBNUM(1..NBNUM))
   If !NUTAB
    If [F:ADL2]NULRECFLG=2
     WNUL = 1
    Endif
    Read [ADV]CODE=WNUM
    If !fstat & ([F:ADV]FLGLEG=2 & NEWLEG) or NEWLIV
     # It's ok
    Else
     WNUL = 1
    Endif
    Gosub ADDNUMTAB
    NUTAB = NBNUM
   Else
    Read [ADV]CODE=WNUM
   Endif
   If !TBNUL(NUTAB)
    If DETAIL
     # Copie du $1$ $2$ (table $3$)
     Call ECR_TIME(func AFNC.MES3(mess(266,143,1),mess(1,2907,1),[F:ADL2]COD,num$(TBNUM(NUTAB)))) From DOSSUB
    Endif
    Gosub LOAD_COD
    Gosub MAJ_TABDIV
   Endif
  Endif
 Next ADL2
Next I

# Update if not delivery

LIV = 0
NEWLIV = 0
For [ADV] Where !find(NUMTAB,TBNUM(1..NBNUM))
 If dim(GTESTFILE)<1 or GTESTFILE="" or val(GTESTFILE)=[F:ADV]NUMTAB
  If GINFO
   # MAJ dictionnaire - Tables diverses
   Call AFF_VLC(mess(15,125,1)-mess(75,125,1),num$([F:ADV]NUMTAB)) From GESECRAN
  Endif
  If DETAIL
   Call ECR_TIME(mess(75,125,1)-num$([F:ADV]NUMTAB)) From DOSSUB
  Endif
  Gosub MAJ_TABDIV
 Endif
Next ADV

# Update from kit

LIV = 1
Raz TBNUL , NBNUM
For I=1 To dim(TBKIT)
 If TBKIT(I)="" : Break : Endif
 NEWKIT = 0
 Read [ADK]ADK0=DOSSIER;[L]TBKIT(I)
 If fstat or (!fstat and [F:ADK]INSTAL<>2)
  If DETAIL
   Call ECR_TIME(mess(269,143,1)-":"-[L]TBLIV(I)) From DOSSUB : # Nouveau kit
  Endif
  NEWKIT = 1
 Endif
 For [ADL2]ADLO0(2) Where COD=TBKIT(I) & TABCOD="ATABDIV"
  If dim(GTESTFILE)<1 or GTESTFILE="" or val(GTESTFILE)=[F:ADL2]TABADINUM
   WNUM = [F:ADL2]TABADINUM
   WNUL = 0
   NUTAB = find(WNUM,TBNUM(1..NBNUM))
   If !NUTAB
    If [F:ADL2]NULRECFLG=2
     WNUL = 1
    Endif
    Read [ADV]CODE=WNUM
    If !fstat & ([F:ADV]FLGLEG=2 & NEWLEG) or NEWKIT
     # It's ok
    Else
     WNUL = 1
    Endif
    Gosub ADDNUMTAB
    NUTAB = NBNUM
   Else
    Read [ADV]CODE=WNUM
   Endif
   If !TBNUL(NUTAB)
    If DETAIL
     # Copie du $1$ $2$ (table $3$)
     Call ECR_TIME(func AFNC.MES3(mess(266,143,1),mess(2,2907,1),[F:ADL2]COD,num$(TBNUM(NUTAB)))) From DOSSUB
    Endif
    Gosub LOAD_COD
    Gosub MAJ_TABDIV
   Endif
  Endif
 Next ADL2
Next I

Close Local File [ADV] , [DADV]
Close Local File [ADI] , [DADI]
Close Local File [ADL2]
Close Local File [DAXX] , [CAXX] , [RAXX]
End

#---------------------------------#
$LOAD_COD
NBCOD = 0
For [ADL2]ADLO0
 T = instr(1,[F:ADL2]TABKEY,"~")
 If T
  K = 0
  If [F:ADV]FLGLEG<>2
   K = 1
  Elsif [F:ADL2]TABLEG=""
   K = 1
  Elsif ONELEG & [F:ADL2]TABLEG=TBLEG(1)
   K = 1
  Elsif !ONELEG & [F:ADL2]TABLEG<>"" & (NEWKIT & find([F:ADL2]TABLEG,TBLEG)) or (NEWLEG & find([F:ADL2]TABLEG,TBNLEG(1..NEWLEG)))
   K = 1
  Endif
  If K
   NBCOD += 1
   TBCOD(NBCOD) = right$([F:ADL2]TABKEY,T+1)
  Endif
 Endif
Next ADL2
Return

#---------------------#
$ADDNUMTAB
NBNUM += 1
TBNUM(NBNUM) = WNUM
TBNUL(NBNUM) = WNUL
Return

#-------------------------------------------#
$MAJ_TABDIV
If [F:ADV]NUMTAB>900 & [F:ADV]NUMTAB<1000
 Gosub MAJ_TABDIV_STD
 Gosub MAJ_TABDIV_SUP
Else
 Gosub MAJ_TABDIV_STD
Endif
Return

#-----------------------------------------------------#
$MAJ_TABDIV_STD
Trbegin [DADV]
 OLD = 0
 SPEC = 0
 Read [DADV]CODE = [F:ADV]NUMTAB
 If !fstat
  OLD = 1
  Call SPEC([F:DADV]CODACT,SPEC) From DOSSUB
 Endif
 Call NEWREC([L]DOSSIER,[F:ADV]CODACT,[F:ADV]MODULE,NEWREC) From DOSSUB
 If !NEWREC and GADONIX=2 and [L]FLGREF : NEWREC = 1 : Endif
 If !SPEC
  If OLD and !NEWREC : # On le vire
   # 114331
   Delete [DAXX] Where find(CODFIC,"ATABDIV","ATABTAB")<>0 & IDENT1=num$([F:ADV]NUMTAB)
   #If fstat=1 : Call ERREUR("ATEXTRA"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif
   Delete [DADI] Where NUMTAB=[F:ADV]NUMTAB
   If fstat=1 : Call ERREUR("ATABDIV"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif
   Delete [DADV] Where NUMTAB=[F:ADV]NUMTAB
   If fstat=1 : Call ERREUR("ATABTAB"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif
  Elsif NEWREC and !OLD
   Raz [F:DADV]
   [F:DADV] = [F:ADV]
   Call COPTEXREF("ATABTAB","LNGDES",num$([F:ADV]NUMTAB),"")  From DOSDICDIV
   Call COPTEXREF("ATABTAB","SHODES",num$([F:ADV]NUMTAB),"")  From DOSDICDIV
   For K=0 To dim([F:ADV]COLALPTYP)-1
    Call COPTEXREF("ATABTAB","COLALPDES",num$([F:ADV]NUMTAB),num$(K)) From DOSDICDIV
   Next K
   For K=0 To dim([F:ADV]COLNUMTYP)-1
    Call COPTEXREF("ATABTAB","COLNUMDES",num$([F:ADV]NUMTAB),num$(K)) From DOSDICDIV
   Next K
   Write [DADV]
   If fstat : Call ERREUR("ATABTAB"-num$([F:DADV]NUMTAB),1) From DOSDIC : Endif
   Delete [DADI] Where NUMTAB=[F:ADV]NUMTAB
   If fstat=1 : Call ERREUR("ATABDIV"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif
   For [ADI]CODE Where NUMTAB=[F:ADV]NUMTAB
    K = 0
    If !LIV or find([F:ADI]CODE,TBCOD(1..NBCOD))
     If [F:ADV]FLGLEG<>2
      K = 1
     Elsif [F:ADI]LEG="" & LEGNUL
      K = 1
     Elsif ONELEG & [F:ADI]LEG=TBLEG(1)
      K = 1
     Elsif !ONELEG & [F:ADI]LEG<>"" & (!NEWLEG & find([F:ADI]LEG,TBLEG)) or (NEWLEG & find([F:ADI]LEG,TBNLEG(1..NEWLEG)))
      K = 1
     Endif
    Endif
    If K
     [F:DADI] = [F:ADI]
     If [L]ONELEG & [F:ADV]FLGLEG=2
      [F:DADI]LEG = TBLEG(1)
     Endif
     Call COPTEXTRA("ATABDIV","LNGDES",num$([F:ADV]NUMTAB),[F:ADI]CODE)  From DOSDICDIV
     Call COPTEXTRA("ATABDIV","SHODES",num$([F:ADV]NUMTAB),[F:ADI]CODE)  From DOSDICDIV
     Write [DADI]
     If fstat
      Call ERREUR("ATABDIV"-num$([F:DADV]NUMTAB)-[F:ADI]CODE,1) From DOSDIC
     Elsif DETAIL
      # Création code
      Call ECR_TIME(mess(59,123,1)-mess(37,100,1)-":"+[F:DADI]CODE-"("+[F:DADI]LEG+")") From DOSSUB
     Endif
    Endif
   Next ADI
  Elsif NEWREC and OLD and (GADONIX<>2 or ![L]FLGREF)
   Raz DIFFA
   Raz DIFFN
   For K=0 To dim([F:ADV]COLALPTYP)-1
    Read [RAXX]AXX0 = "ATABTAB";"COLALPDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
    If fstat or [F:RAXX]TEXTE=""
     STA1 = 0
    Else
     STA1 = 1
    Endif
    Read [DAXX]AXX0 = "ATABTAB";"COLALPDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
    If fstat or [F:DAXX]TEXTE=""
     STA2 = 0
    Else
     STA2 = 1
    Endif
    If STA1=0 & STA2<>0
     DIFFA(K) = -1
     Delete [DAXX]
     If fstat : Call ERREUR("ATEXTRA"-"ATABTAB"-"COLALPDES"-num$([F:DADV]NUMTAB)-num$(K),3) From DOSDIC : Endif
    Elsif STA1<>0 & STA2=0
     DIFFA(K) =  1
     Call COPTEXREF("ATABTAB","COLALPDES",num$([F:ADV]NUMTAB),num$(K)) From DOSDICDIV
     #118905
     If [F:DADV]COLALPTYP(K)<>"" & [F:DADV]COLALPTYP(K)=[F:ADV]COLALPTYP(K) : DIFFA(K) =  0 : Endif
    Endif
    [F:DADV]COLALPTYP(K) = [F:ADV]COLALPTYP(K)
    [F:DADV]COLALPSUP(K) = [F:ADV]COLALPSUP(K)
   Next K
   For K=0 To dim([F:ADV]COLNUMTYP)-1
    Read [RAXX]AXX0 = "ATABTAB";"COLNUMDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
    If fstat or [F:RAXX]TEXTE=""
     STA1 = 0
    Else
     STA1 = 1
    Endif
    Read [DAXX]AXX0 = "ATABTAB";"COLNUMDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
    If fstat or [F:DAXX]TEXTE=""
     STA2 = 0
    Else
     STA2 = 1
    Endif
    If STA1=0 & STA2<>0
     DIFFN(K) = -1
     Delete [DAXX]
     If fstat : Call ERREUR("ATEXTRA"-"ATABTAB"-"COLNUMDES"-num$([F:DADV]NUMTAB)-num$(K),3) From DOSDIC : Endif
    Elsif STA1<>0 & STA2=0
     DIFFN(K) =  1
     Call COPTEXREF("ATABTAB","COLNUMDES",num$([F:ADV]NUMTAB),num$(K)) From DOSDICDIV
     #118905
     If [F:DADV]COLNUMTYP(K)<>"" & [F:DADV]COLNUMTYP(K)=[F:ADV]COLNUMTYP(K) : DIFFN(K) =  0 : Endif
    Endif
    [F:DADV]COLNUMTYP(K) = [F:ADV]COLNUMTYP(K)
    [F:DADV]COLNUMSUP(K) = [F:ADV]COLNUMSUP(K)
   Next K
   [F:DADV]CODACT  = [F:ADV]CODACT
   [F:DADV]UPDFLG  = [F:ADV]UPDFLG
   [F:DADV]LNGFLG  = [F:ADV]LNGFLG
   If [F:ADV]LNGFLG<>2 or [F:DADV]LNG=0
    [F:DADV]LNG = [F:ADV]LNG
   Endif
   [F:DADV]MODULE = [F:ADV]MODULE
   [F:DADV]FLGLEG = [F:ADV]FLGLEG
   [F:DADV]FLGSOC = [F:ADV]FLGSOC
   Rewrite [DADV]
   If fstat : Call ERREUR("ATABTAB"-num$([F:DADV]NUMTAB),2) From DOSDIC : Endif
   For [DADI]CODE Where NUMTAB=[F:ADV]NUMTAB
    Read [ADI]CODE = [F:DADI]NUMTAB ; [F:DADI]CODE
    For K=1 To dim([F:ADV]COLALPTYP)
     If DIFFA(K-1)>0
      If !fstat
       Assign "[F:DADI]A"+num$(K) With evalue("[F:ADI]A"+num$(K))
      Else
       Assign "[F:DADI]A"+num$(K) With ""
      Endif
     Elsif DIFFA(K-1)<0
      Assign "[F:DADI]A"+num$(K) With ""
     Endif
    Next K
    For K=1 To dim([F:ADV]COLNUMTYP)
     If DIFFN(K-1)>0
      If !fstat
       Assign "[F:DADI]N"+num$(K) With evalue("[F:ADI]N"+num$(K))
      Else
       Assign "[F:DADI]N"+num$(K) With 0
      Endif
     Elsif DIFFN(K-1)<0
      Assign "[F:DADI]N"+num$(K) With 0
     Endif
    Next K
    Rewrite [DADI]
    If fstat : Call ERREUR("ATABDIV"-num$([F:DADV]NUMTAB-[F:DADI]CODE),2) From DOSDIC : Endif
   Next DADI
   For [ADI]CODE Where NUMTAB=[F:ADV]NUMTAB
    K = 0
    If !LIV or find([F:ADI]CODE,TBCOD(1..NBCOD))
     If [F:ADV]FLGLEG<>2
      K = 1
     Elsif [F:ADI]LEG="" & LEGNUL
      K = 1
     Elsif ONELEG & [F:ADI]LEG=TBLEG(1)
      K = 1
     Elsif !ONELEG & [F:ADI]LEG<>"" & (!NEWLEG & find([F:ADI]LEG,TBLEG)) or (NEWLEG & find([F:ADI]LEG,TBNLEG(1..NEWLEG)))
      K = 1
     Endif
    Endif
    If K
     Read [DADI]CODE = [F:ADI]NUMTAB ; [F:ADI]CODE
     If fstat
      [F:DADI] = [F:ADI]
      If [L]ONELEG & [F:ADV]FLGLEG=2
       [F:DADI]LEG = TBLEG(1)
      Endif
      Call COPTEXTRA("ATABDIV","SHODES",num$([F:ADV]NUMTAB),[F:ADI]CODE)  From DOSDICDIV
      Call COPTEXTRA("ATABDIV","LNGDES",num$([F:ADV]NUMTAB),[F:ADI]CODE)  From DOSDICDIV
      Write [DADI]
      If fstat
       Call ERREUR("ATABDIV"-num$([F:DADV]NUMTAB)-[F:ADI]CODE,1) From DOSDIC
      Elsif DETAIL
       # Création code
       Call ECR_TIME(mess(59,123,1)-mess(37,100,1)-":"+[F:DADI]CODE-"("+[F:DADI]LEG+")") From DOSSUB
      Endif
     Elsif [F:ADI]LEG<>[F:DADI]LEG & DETAIL : # It's a warning, not mandatory to display
      # $1$ : Législation origine $2$ différente législation destination $3$/Table
      Call ECR_TRACE(func AFNC.MES3(mess(78,127,1),mess(56,123,1)-num$([F:ADI]NUMTAB)
&     -"("+[F:ADI]CODE+")","'"+[F:ADI]LEG+"'","'"+[F:DADI]LEG+"'"),-1) From GESECRAN
     Endif
    Endif
   Next ADI
  Endif
 Endif
Commit
Return

#-------------------------------------#
$MAJ_TABDIV_SUP
Trbegin [DADV]
 Call NEWREC([F:ADS]DOSSIER,[F:ADV]CODACT,[F:ADV]MODULE,NEWREC) From DOSSUB
 If NEWREC or (GADONIX=2 and [L]FLGREF)
  For [ADI] Where NUMTAB=[F:ADV]NUMTAB & CODE<GXX
   K = 0
   If !LIV or find([F:ADI]CODE,TBCOD(1..NBCOD))
    If [F:ADV]FLGLEG<>2
     K = 1
    Elsif [F:ADI]LEG="" & LEGNUL
     K = 1
    Elsif ONELEG & [F:ADI]LEG=TBLEG(1)
     K = 1
    Elsif !ONELEG & [F:ADI]LEG<>"" & (!NEWLEG & find([F:ADI]LEG,TBLEG)) or (NEWLEG & find([F:ADI]LEG,TBNLEG(1..NEWLEG)))
     K = 1
    Endif
   Endif
   If K
    Read [DADI]CODE = [F:ADI]NUMTAB ; [F:ADI]CODE
    If fstat
     [F:DADI] = [F:ADI]
     If [L]ONELEG & [F:ADV]FLGLEG=2
      [F:DADI]LEG = TBLEG(1)
     Endif
     Call COPTEXTRA("ATABDIV","LNGDES",num$([F:ADI]NUMTAB),[F:ADI]CODE) From DOSDICDIV
     Call COPTEXTRA("ATABDIV","SHODES",num$([F:ADI]NUMTAB),[F:ADI]CODE) From DOSDICDIV
     Write [DADI]
     If fstat
      Call ERREUR("ATABDIV"-num$([F:DADI]NUMTAB)-[F:DADI]CODE,1) From DOSDIC
     Elsif DETAIL
      # Création code
      Call ECR_TIME(mess(59,123,1)-mess(37,100,1)-":"+[F:DADI]CODE-"("+[F:DADI]LEG+")") From DOSSUB
     Endif
    Else
     [F:DADI] = [F:ADI]
     If [L]ONELEG & [F:ADV]FLGLEG=2
      [F:DADI]LEG = TBLEG(1)
     Endif
     Call COPTEXTRA("ATABDIV","LNGDES",num$([F:ADI]NUMTAB),[F:ADI]CODE) From DOSDICDIV
     Call COPTEXTRA("ATABDIV","SHODES",num$([F:ADI]NUMTAB),[F:ADI]CODE) From DOSDICDIV
     Rewrite [DADI]
     If fstat
      Call ERREUR("ATABDIV"-num$([F:DADI]NUMTAB)-[F:DADI]CODE,2) From DOSDIC
     Elsif DETAIL
       # Mise à jour code
      Call ECR_TIME(mess(271,143,1)-mess(37,100,1)-":"+[F:DADI]CODE-"("+[F:DADI]LEG+")") From DOSSUB
     Endif
    Endif
   Endif
  Next ADI
 Endif
Commit
Return

#---------------------------------------------------------------------------------------#
## Pour copier les adresses, contact et rib d'une entité (tiers, utilisateur, etc.)
#---------------------------------------------------------------------------------------#

Subprog COPY_PARTNERS(TABLE,ZONTYP,TYP)
Value Char    TABLE     : # Code de la table (BPADDRESS, CONTACT, BID)
Value Char    ZONTYP    : # Nom du champ type entité
Value Integer TYP       : # Value de l'entité

Local Integer  NBRAZ , NBREC , MAXREC
Local Char     ZONRAZ(10)(1..50)
Local Integer  I , J , K , T , D , OK

MAXREC = 1000

If TABLE="" or ZONTYP=""
 End
Elsif filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSSIER),0)<=0
 End
Endif

OK = 1
If filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSCOP),0)>=0
 Local File =[F:ADS]DOSCOP+"."+TABLE  [F1]
Elsif filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSREF),0)>=0
 Local File =[F:ADS]DOSREF+"."+TABLE  [F1]
Elsif filinfo(filpath("FIL",TABLE,"fde",GDOSX3),0)>=0
 Local File =GDOSX3+"."+TABLE [F1]
Else
 OK = 0
Endif
If OK & evalue("dim([F:F1]"+ZONTYP+")")<=0
 OK = 0
Endif
If OK
 Local File =[F:ADS]DOSSIER+"."+TABLE [F2]
 NBRAZ = 0
 For [ATZ]CODZONE Where CODFIC=TABLE & ZERO=2
  NBRAZ += 1
  ZONRAZ(NBRAZ) = [F:ATZ]CODZONE
 Next ATZ

 # Copie des données - Table

 Call ECR_TIME(mess(30,125,1)-mess(56,123,1)-TABLE) From DOSSUB
 If GINFO
  Call AFF_VLC(mess(30,125,1),mess(56,123,1)-TABLE) From GESECRAN
 Endif

 NBREC = 0
 Trbegin [F2]
  For [F1]
   OK = 1
   If dim([F:F1]CODACT)>0 & [F:F1]CODACT<>""
    Read [ACV8]CODACT=[F:F1]CODACT
    If fstat or [F:ACV8]FLACT<>2 : OK = 0 : Endif
   Endif
   If dim([F:F1]MODULE)>0 & [F:F1]MODULE>0
    If [F:ADS]MODULE([F:F1]MODULE-1)<>2 : OK = 0 : Endif
   Endif
   If evalue("[F:F1]"+ZONTYP)<>TYP : OK = 0 : Endif
   If OK
    If NBREC>=MAXREC
     Commit
     Trbegin [F2]
     NBREC = 0
    Endif
    NBREC += 1
    [F:F2] = [F:F1]
    Look [F2] =
    If fstat
     For I=1 To NBRAZ
      D = evalue("dim([F:F2]"+ZONRAZ(I)+")")
      T = evalue("type([F:F2]"+ZONRAZ(I)+")")
      For J=1 To D
       Case T
        When 1,2,4,5,6,7,8,9
         Assign "[F:F2]"+ZONRAZ(I)+"("+num$(J-1)+")" With 0
        When 3
         Assign "[F:F2]"+ZONRAZ(I)+"("+num$(J-1)+")" With [0/0/0]
        When Default
         Assign "[F:F2]"+ZONRAZ(I)+"("+num$(J-1)+")" With ""
       Endcase
      Next J
     Next I
     Write [F2]
     If fstat
      Call ERREUR(TABLE,1) From DOSDIC
     Endif
    Endif
   Endif
  Next F1
 Commit
 Close Local File [F1] , [F2]
Endif
End

#----------------------------------------------------------------------#
## La vérif des liens se fait après à cause des objets générés
#----------------------------------------------------------------------#

Subprog CONTROL_LINKS(DOSSIER,DETAIL,NBCOP,TBCOP)
Value     Char    DOSSIER
Value     Integer DETAIL
Variable  Integer NBCOP
Variable  Char    TBCOP()(1..)

Onerrgo ERREUR

Local Integer MAXLIEN
MAXLIEN = 30
Local Integer NBLIEN , NZLIEN(1..MAXLIEN) , NZCLE(1..MAXLIEN) , NBKEY , SUPCLE
Local Integer TYPLIEN(1..MAXLIEN) , OBLIEN(1..MAXLIEN)
Local Char    ZCLE(GLONAVA)(1..MAXLIEN,1..16) , ZKEY(GLONAVA)(1..16)
Local Char    LIEN(GLONAVA)(1..MAXLIEN) , ZLIEN(30)(1..MAXLIEN,0..16)
Local Integer I , J , K , T , Z , D , X , OK , ERR , SUPP , RW
Local Char    CHAINE(120) , CLE0(120) , ZONEL(120) , ZONEO(120) , CRITERE(20)

Local File =[L]DOSSIER+".ATABLE"  [ATB]
Local File =[L]DOSSIER+".ATABZON" [ATZ]
Local File =[L]DOSSIER+".ATABIND" [ATI]

# Copie des données - Contrôle des liens

Call ECR_TIME(mess(30,125,1)-mess(71,125,1)) From DOSSUB
If GINFO
 Call AFF_VLC(mess(30,125,1),mess(71,125,1)) From GESECRAN
Endif

#SCM DETAIL=3 special case for INDUSPRD to clean datas extract from REPOSX3
If DETAIL=3
  CRITERE="ANNUL=2"
Else
  CRITERE="1=1"
Endif

For I=1 To NBCOP

# Etablissement des liens
 NBLIEN = 0
 For [ATZ]CODZONE Where CODFIC=TBCOP(I) & LIEN<>"" & VERIF=2 & TBCOP(I)<>"" & evalue(CRITERE)
  If NBLIEN>=MAXLIEN : Break : Endif
  OK = 1
  If filinfo(filpath("FIL",[F:ATZ]LIEN,"fde",[L]DOSSIER),0)<0
   Read [ATB]CODFIC = [F:ATZ]LIEN
   If fstat
    OK = 0 : # C'est normal à cause des codes activités
   Elsif  [F:ATB]TYPFIC=3 # 118858
    OK = 0 : # C'est normal table systeme on controle plus
   Elsif [F:ATB]TYPFIC<>3
    # Table inexistante
    Call ERREUR(TBCOP(I)-"=>"-[F:ATZ]LIEN-mess(73,125,1),4) From DOSDIC
    OK = 0
   Endif
  Endif
  If OK
   NBLIEN += 1
   LIEN(NBLIEN)    = [F:ATZ]LIEN
   TYPLIEN(NBLIEN) = [F:ATZ]ANNUL
   OBLIEN(NBLIEN)  = [F:ATZ]OBLIG
   ZLIEN(NBLIEN,0) = [F:ATZ]CODZONE
   If [F:ATZ]EXPLIEN=""
    NZLIEN(NBLIEN) = 1
    ZLIEN(NBLIEN,1) = [F:ATZ]CODZONE
   Else
    CHAINE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
    NZLIEN(NBLIEN) = 0
    While CHAINE<>""
     K = instr(1,CHAINE,";")
     If K
      NZLIEN(NBLIEN) += 1
      ZLIEN(NBLIEN,NZLIEN(NBLIEN)) = left$(CHAINE,K-1)
      CHAINE = right$(CHAINE,K+1)
     Else
      NZLIEN(NBLIEN) += 1
      ZLIEN(NBLIEN,NZLIEN(NBLIEN)) = CHAINE
      CHAINE = ""
     Endif
    Wend
   Endif
   Read [ATI]NUMLIG(2) = [F:ATZ]LIEN;1
   CHAINE = [F:ATI]DESCRIPT
   NZCLE(NBLIEN) = 0
   While CHAINE<>""
    NZCLE(NBLIEN) += 1
    J = instr(1,CHAINE,"+")
    K = instr(1,CHAINE,"-")
    If    J & K  : J = min(J,K)
    Elsif K & !J : J = K
    Endif
    If J
     ZCLE(NBLIEN,NZCLE(NBLIEN)) = left$(CHAINE,J-1)
     CHAINE = right$(CHAINE,J+1)
    Else
     ZCLE(NBLIEN,NZCLE(NBLIEN)) = CHAINE
     CHAINE = ""
    Endif
   Wend
   If NZCLE(NBLIEN)<>NZLIEN(NBLIEN)
    # Erreur sur lien
    Call ERREUR(TBCOP(I)-"=>"-[F:ATZ]LIEN-mess(72,125,1),4) From DOSDIC
    NBLIEN -= 1
   Endif
  Endif
 Next

 # Parcours du fichier
 If NBLIEN>0
  If GINFO
   Call AFF_VLC(mess(30,125,1),mess(71,125,1)-mess(56,123,1)-TBCOP(I)) From GESECRAN
  Endif

  # Table
  If DETAIL
   Call ECR_TIME(mess(56,123,1)-TBCOP(I)) From DOSSUB
  Endif
  Local File =[L]DOSSIER+"."+TBCOP(I) [F0]
  Local File =[L]DOSSIER+"."+TBCOP(I) [F1]
  Read [ATI]NUMLIG(2) = TBCOP(I);1
  CHAINE = [F:ATI]DESCRIPT
  NBKEY = 0
  While CHAINE<>""
   NBKEY += 1
   J = instr(1,CHAINE,"+")
   K = instr(1,CHAINE,"-")
   If    J & K  : J = min(J,K)
   Elsif K & !J : J = K
   Endif
   If J
    ZKEY(NBKEY) = left$(CHAINE,J-1)
    CHAINE = right$(CHAINE,J+1)
   Else
    ZKEY(NBKEY) = CHAINE
    CHAINE = ""
   Endif
  Wend
  For K=1 To NBLIEN
   Gosub OUVFIC
  Next K
  Onerrgo ERRLIEN : # Y'a des erreurs à cause du mauvais remplissage du dico
  ERR = 0
  Trbegin [F0]
   For [F0]
    SUPP = 0
    RW   = 0
    For K=1 To NBLIEN
     Gosub DEFAUT
     T = evalue("type([F:F0]"+ZLIEN(K,0)+")")
     For D=1 To evalue("dim([F:F0]"+ZLIEN(K,0)+")")
      indice = D-1
      OK = 1
      Case T
       When 1,2,3,4,5,6,7,8,9 : If evalue("[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")")=0       : OK = 0 : Endif
       When 3                 : If evalue("[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")")=[0/0/0] : OK = 0 : Endif
       When Default           : If evalue("[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")")=""      : OK = 0 : Endif
      Endcase
      # On ne contrôle pas les liens sur les objets générés
      If find(LIEN(K),"AMSK","AWINDOW")
       If left$(evalue("[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")"),1)="W"
        OK = 0
       Endif
      Endif
      If OK
       CHAINE = ""
       For Z=1 To NZLIEN(K)
        If ZLIEN(K,Z) <> "[V]GSUPCLE"
         ZONEL = "[F:L"+num$(K)+"]"+ZCLE(K,Z)
         If ZLIEN(K,Z)>="A" & ZLIEN(K,Z)<"ZZZZZZZZZZ"
          ZONEO = "[F:F0]"+ZLIEN(K,Z)
         Else
          ZONEO = ZLIEN(K,Z)
         Endif
         Assign ZONEL With evalue(ZONEO)
         CHAINE -= num$(evalue(ZONEO))
        Else
         SUPCLE = NZLIEN(K)-1
        Endif
       Next Z
       If SUPCLE
        Assign "[G:L"+num$(K)+"]currind" With 1
        Assign "[G:L"+num$(K)+"]currlen" With SUPCLE
        SUPCLE = 0
       Else
        Assign "[G:L"+num$(K)+"]currind" With 1
        Assign "[G:L"+num$(K)+"]currlen" With 0
       Endif
       Read =
       If fstat
        Case TYPLIEN(K)
         When 1 : # Bloquant
          If OBLIEN(K)=2
           SUPP = 1
           Gosub TR_LIEN
           Break 2
          Else
           [F:F1] = [F:F0]
           Case T
            When 1,2,4,5,6,7,8,9 : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With 0
            When 3               : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With [0/0/0]
            When Default         : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With ""
           Endcase
           RW = 1
           Gosub TR_LIEN
          Endif
         When 2 : # Suppression
          SUPP = 1
          Gosub TR_LIEN
          Break 2
         When 3   : # RAZ
          [F:F1] = [F:F0]
          Case T
           When 1,2,4,5,6,7,8,9 : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With 0
           When 3               : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With [0/0/0]
           When Default         : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With ""
          Endcase
          RW = 1
          Gosub TR_LIEN
        Endcase
       Endif
      Endif
      If ERR : Break 3 : Endif : # On ne signale que la première erreur
     Next D
    Next K
    If SUPP
     Delete [F0]
    Elsif RW
     Rewrite [F0]
     If fstat
      [F:F0] = [F:F1]
      Delete [F0] =
     Endif
    Endif
   Next
  Commit
  Onerrgo
  For K=1 To NBLIEN
   Gosub FERME
  Next K
  Close Local File [F0] , [F1]
 Endif
Next I
Onerrgo
End

#--------------------#
$TR_LIEN
If DETAIL
 CLE0 = ""
 For X=1 To NBKEY
  CLE0 -= num$(evalue("[F:F0]"+ZKEY(X)))
 Next X
 Call ECR_TIME(space$(10)-CLE0-ZLIEN(K,0)-"=>"-LIEN(K)-":"-CHAINE) From DOSSUB
Endif
Return

#----------------------#
$ERRLIEN
ERR = errn
Call ERREUR(TBCOP(I)-"=>"-LIEN(K)-errmes$(errn)-num$(errl)-errm,4) From DOSDIC
Resume

#-----------#
$ERREUR
GMESSAGE = mess(6,123,1)-num$(errn)-errmes$(errn)-errm-errp-mess(61,100,1)-num$(errl) : # Erreur x ligne no y
Call ERREUR(GMESSAGE,4) From DOSDIC
GMESSAGE = ""
Resume

#-----------------------------#
$OUVFIC
Case K
 When  1 : Local File =[L]DOSSIER+"."+LIEN(K) [L1]
 When  2 : Local File =[L]DOSSIER+"."+LIEN(K) [L2]
 When  3 : Local File =[L]DOSSIER+"."+LIEN(K) [L3]
 When  4 : Local File =[L]DOSSIER+"."+LIEN(K) [L4]
 When  5 : Local File =[L]DOSSIER+"."+LIEN(K) [L5]
 When  6 : Local File =[L]DOSSIER+"."+LIEN(K) [L6]
 When  7 : Local File =[L]DOSSIER+"."+LIEN(K) [L7]
 When  8 : Local File =[L]DOSSIER+"."+LIEN(K) [L8]
 When  9 : Local File =[L]DOSSIER+"."+LIEN(K) [L9]
 When 10 : Local File =[L]DOSSIER+"."+LIEN(K) [L10]
 When 11 : Local File =[L]DOSSIER+"."+LIEN(K) [L11]
 When 12 : Local File =[L]DOSSIER+"."+LIEN(K) [L12]
 When 13 : Local File =[L]DOSSIER+"."+LIEN(K) [L13]
 When 14 : Local File =[L]DOSSIER+"."+LIEN(K) [L14]
 When 15 : Local File =[L]DOSSIER+"."+LIEN(K) [L15]
 When 16 : Local File =[L]DOSSIER+"."+LIEN(K) [L16]
 When 17 : Local File =[L]DOSSIER+"."+LIEN(K) [L17]
 When 18 : Local File =[L]DOSSIER+"."+LIEN(K) [L18]
 When 19 : Local File =[L]DOSSIER+"."+LIEN(K) [L19]
 When 20 : Local File =[L]DOSSIER+"."+LIEN(K) [L20]
 When 21 : Local File =[L]DOSSIER+"."+LIEN(K) [L21]
 When 22 : Local File =[L]DOSSIER+"."+LIEN(K) [L22]
 When 23 : Local File =[L]DOSSIER+"."+LIEN(K) [L23]
 When 24 : Local File =[L]DOSSIER+"."+LIEN(K) [L24]
 When 25 : Local File =[L]DOSSIER+"."+LIEN(K) [L25]
 When 26 : Local File =[L]DOSSIER+"."+LIEN(K) [L26]
 When 27 : Local File =[L]DOSSIER+"."+LIEN(K) [L27]
 When 28 : Local File =[L]DOSSIER+"."+LIEN(K) [L28]
 When 29 : Local File =[L]DOSSIER+"."+LIEN(K) [L29]
 When 30 : Local File =[L]DOSSIER+"."+LIEN(K) [L30]
Endcase
Return

#------------------#
$DEFAUT
Case K
 When  1 : Default File [L1]
 When  2 : Default File [L2]
 When  3 : Default File [L3]
 When  4 : Default File [L4]
 When  5 : Default File [L5]
 When  6 : Default File [L6]
 When  7 : Default File [L7]
 When  8 : Default File [L8]
 When  9 : Default File [L9]
 When 10 : Default File [L10]
 When 11 : Default File [L11]
 When 12 : Default File [L12]
 When 13 : Default File [L13]
 When 14 : Default File [L14]
 When 15 : Default File [L15]
 When 16 : Default File [L16]
 When 17 : Default File [L17]
 When 18 : Default File [L18]
 When 19 : Default File [L19]
 When 20 : Default File [L20]
 When 21 : Default File [L21]
 When 22 : Default File [L22]
 When 23 : Default File [L23]
 When 24 : Default File [L24]
 When 25 : Default File [L25]
 When 26 : Default File [L26]
 When 27 : Default File [L27]
 When 28 : Default File [L28]
 When 29 : Default File [L29]
 When 30 : Default File [L30]
Endcase
Return

#----------------------------#
$FERME
Case K
 When  1 : Close Local File [L1]
 When  2 : Close Local File [L2]
 When  3 : Close Local File [L3]
 When  4 : Close Local File [L4]
 When  5 : Close Local File [L5]
 When  6 : Close Local File [L6]
 When  7 : Close Local File [L7]
 When  8 : Close Local File [L8]
 When  9 : Close Local File [L9]
 When 10 : Close Local File [L10]
 When 11 : Close Local File [L11]
 When 12 : Close Local File [L12]
 When 13 : Close Local File [L13]
 When 14 : Close Local File [L14]
 When 15 : Close Local File [L15]
 When 16 : Close Local File [L16]
 When 17 : Close Local File [L17]
 When 18 : Close Local File [L18]
 When 19 : Close Local File [L19]
 When 20 : Close Local File [L20]
 When 21 : Close Local File [L21]
 When 22 : Close Local File [L22]
 When 23 : Close Local File [L23]
 When 24 : Close Local File [L24]
 When 25 : Close Local File [L25]
 When 26 : Close Local File [L26]
 When 27 : Close Local File [L27]
 When 28 : Close Local File [L28]
 When 29 : Close Local File [L29]
 When 30 : Close Local File [L30]
Endcase
Return

#----------------------------------------------------------------------#
Subprog AM_DOSDES(VALEUR)
Variable Char    VALEUR()
Read [ADS]DOSSIER = VALEUR
If !fstat
 Gosub CHARGE_DEST
Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]LEG(0..[M]NBLEG-1)) From OBJDIV
If mkstat : End : Endif
Read [F:ADS]DOSSIER = [M:ACOP0]DOSORI
If !fstat
 If !find(VALEUR,[F:ADS]DOSLEG(0..dim([F:ADS]DOSLEG)-1))
  # Législation non gérée par le dossier
  GMESSAGE = mess(249,133,1)-":"-[M:ACOP0]DOSORI
  mkstat   = 2 : End
 Endif
Endif
End

Subprog C_DOSORI(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_DOSORI(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_ORI
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call DOSORGDES([M]DOSORI,VALEUR) From DOSCONT
End

Subprog C_LEGD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]LEGD(0..[M]NBLEGD-1)) From OBJDIV
If mkstat : End : Endif
If !find(VALEUR,[M]LEG(0..[M]NBLEG-1))
 # Législation non gérée par le dossier
 GMESSAGE = mess(249,133,1)-[M:ACOP0]DOSORI
 mkstat =2 : End
Endif
ASTATUS = func ASYRLICFOL.ACTIVE_LEGISLATION(VALEUR)
If ASTATUS<>CST_ATRUE
 # La license actuelle ne permet pas d'activer la législation "$1$"
 GMESSAGE = func AFNC.MES1(mess(272,125,1),VALEUR)
 mkstat = 1 : End
Endif
End

Subprog AS_AJOUT(VALEUR)
Variable Integer VALEUR
End

Subprog C_LIVCODD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]LIVCODD(0..[M]NBLIVD-1)) From OBJDIV
End

Subprog C_KITCODD(VALEUR)
Variable Char    VALEUR()
Local Integer I , OK , ASTATUS
Call UNICITE(VALEUR,[M]KITCODD(0..[M]NBKITD-1)) From OBJDIV
If mkstat : End : Endif
ASTATUS = func ASYRLICFOL.ACTIVE_KIT(VALEUR)
If ASTATUS<>CST_ATRUE
 # La license actuelle ne permet pas d'activer le kit "$1$"
 GMESSAGE = func AFNC.MES1(mess(269,125,1),VALEUR)
 mkstat = 1 : End
Endif
If !find(VALEUR,[M:ACOP2]KITCOD(0..[M:ACOP2]NBKIT-1))
 # Kit non installé dans le dossier $1$
 Call AVERTIR(VALEUR+":"-func AFNC.MES1(mess(272,143,1),[M:ACOP0]DOSORI),OK) From GESECRAN
 If OK<>2 : mkstat = 1 : End : Endif
Endif
End

Subprog AM_KITCODD(VALEUR)
Variable Char    VALEUR()
Local Integer I , J , ASTATUS
Local Char    TBLIV(GLONADLV)(1..10)
ASTATUS = func ASYRLICFOL.GETPOLICY(TBLIV)
For I=1 To dim(TBLIV)
 If TBLIV(I)<>""
  Read [ADLV]ADLV0=TBLIV(I)
  If !fstat
   J = find(VALEUR,[F:ADLV]ITYKIT)
   If J
    [M]ROWKITD(nolign-1) = [F:ADLV]ITYKITROW(J-1)
   Endif
  Endif
 Endif
Next I
End

Subprog C_NBLIVD
If find(status,68,65,83) : # Suppression ligne
 If nolign1=0 : nolign1 = nolign : Endif
 If find(2,[M]INSLIVD(nolign-1..nolign1-1))
  GMESSAGE = mess(267,125,1) : # Kit impossible à supprimer
  mkstat = 1 : End
 Endif
Endif
End

Subprog C_NBKITD
If find(status,68,65,83) : # Suppression ligne
 If nolign1=0 : nolign1 = nolign : Endif
 If find(2,[M]INSKITD(nolign-1..nolign1-1))
  GMESSAGE = mess(267,125,1) : # Kit impossible à supprimer
  mkstat = 1 : End
 Endif
Endif
End

######################################################################################
# 114946 CCL various troubles in legislation copy (ADOSCOPDAT)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA([M:ACOP1]INTITLEGORI(nolign-1),"ATABDIV","LNGDES","909",VALEUR) From ATEXTRA
End

Subprog AM_LEGD(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA([M:ACOP1]INTLEG(nolign-1),"ATABDIV","LNGDES","909",VALEUR) From ATEXTRA
End


