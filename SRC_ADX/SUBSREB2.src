#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des demandes de services  Module CRM
# RUNTARIF :Calcul le montant consommé pour chaque ligne d'un même code article du tableau des consommations
# RAZMAC : Suppression du parc concerné
# DUPLICPN : Duplication des composants concernés
# ONMACFLT :Affectation d'un parc filtré à une demande de service
# SETSRE7REC
# RAZCPN :Supprime les composants en cours de saisie.
# ASSIGNSRE : Affecte une demande de service sur la base d'une famille de compétence.
# ASSDSCTOSRE : Affecte la demande à un collaborateur
# ASSQUETOSRE : Affecte la demande à un collaborateur
# ASSREPTOSRE : Affecte la demande à un collaborateur
# SETINVFLG : Détermine si la demande est facturable ou totalement gratuite. Classe M
# GETINVFLG : Détermine si la demande est facturable ou totalement gratuite. Classe F
# CLOSRE : Clôture d'une demande de service
# RERTOCSM : Transforme les points mobilisés par la demande en consommés
# COMMITINV : Effectue le travail nécessaire suite à la facturation d'une demande de service.
#        Travaille en classe F
# DELHDI : Supprime les consommations à facturer d'une demande de service
# SETDONDATFLG : Détecte s'il y a des consommations non effectuées.
# AFFSRE2MIS : Affichage des particularités de l'onglet Gestion
# DETECTDOO : Détermine si un client est un client unique d'un donneur d'ordre
# CHECKDOO : Vérifie si le donneur d'ordre par défaut est compatible avec le tiers
# GETSREOPP : Retourne le code d'une affaire associé à une demande de service
# CREPIT : Création d'une mobilisation ou d'une consommation de points
# SAVEHDTWKEY : Enregistrement des points mobilisés suite à la transaction de création de la demande
# SAVEPITWKEY : Enregistrement des points mobilisés suite à la transaction de création de la demande
# SELECTCOT : Sélection d'un modèle de contrat de service pour assurer la couverture globale
#                   d'une demande de service (Pas utilisé)
# SLTCOT
##########################################################################################################
##########################################################################################################
# Calcul le montant consommé pour chaque ligne d'un même code article du tableau des consommations
################################################################
Subprog RUNTARIF(IDELFLG, SZITM, DCBQTY, SZUOM, INOL)
Value Integer IDELFLG
Value Char SZITM
Value Decimal DCBQTY
Value Char SZUOM
Value Integer INOL

Local Integer ITER
Local Decimal GROPRI
Local Decimal NETPRI
Local Decimal MAJREM(0..8)
Local Integer ITERNET
Local Char SZVACBPR
Local Decimal DCBCUMQTY
Local Decimal DCBCLCQTY
Local Decimal ICOEFPARAM
Local Integer IERRINF
Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
Local Decimal IINVPITFLG  # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal
Local Integer ISVHDTINV   # FGR 25/11/2010 : X3SUIVI68826

  IERRINF = 0
  If SZITM = "" Then
    [M:SRE9]HDTAMT(INOL) = 0
    End
  Endif
  Read [ITS]ITS0=SZITM
  If fstat Then
    [M:SRE9]HDTAMT(INOL) = 0
    End
  Endif
  Read [ITM]ITM0=SZITM
  If fstat Then
    [M:SRE9]HDTAMT(INOL) = 0
    End
  Endif
  #On obtient un régime de taxe
  If [M:SRE8]SREVACBPR = "" Then
    Read [BPC]BPC0=[M:SRE0]SREBPC
    If fstat Then
      SZVACBPR = ""
    Else
      SZVACBPR = [F:BPC]VACBPR
    Endif
  Else
    SZVACBPR = [M:SRE8]SREVACBPR
  Endif
  If SZVACBPR = "" Then
    [M:SRE9]HDTAMT(INOL) = [F:ITS]BASPRI * DCBQTY
    Raz [M:SRE9]VAT1
    Raz [M:SRE9]VAT2
    Raz [M:SRE9]VAT3
    Raz [M:SRE9]CLCAMT1
    Raz [M:SRE9]CLCAMT2
    Raz [M:SRE9]PRIREN
    Raz [M:SRE9]SAUSTUCOE
    Raz [M:SRE9]HDTSTUQTY
    Read [ACV]CODACT="SP1"
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(0) = 1
      Raz [M:SRE9]DISCRGVAL1
      Raz [M:SRE9]DISCRGREN1
    Endif
    Read [ACV]CODACT="SP2"
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(1) = 1
      Raz [M:SRE9]DISCRGVAL2
      Raz [M:SRE9]DISCRGREN2
    Endif
    Read [ACV] CODACT = "SP3"
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(2) = 1
      Raz [M:SRE9]DISCRGVAL3
      Raz [M:SRE9]DISCRGREN3
    Endif
    Read [ACV]CODACT="SP4"
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(3) = 1
      Raz [M:SRE9]DISCRGVAL4
      Raz [M:SRE9]DISCRGREN4
    Endif
    Read [ACV] CODACT = "SP5"
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(4) = 1
      Raz [M:SRE9]DISCRGVAL5
      Raz [M:SRE9]DISCRGREN5
    Endif
    Read [ACV] CODACT = "SP6"
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(5) = 1
      Raz [M:SRE9]DISCRGVAL6
      Raz [M:SRE9]DISCRGREN6
    Endif
    Read [ACV] CODACT = "SP7"
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(6) = 1
      Raz [M:SRE9]DISCRGVAL7
      Raz [M:SRE9]DISCRGREN7
    Endif
    Read [ACV] CODACT = "SP8"
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(7) = 1
      Raz [M:SRE9]DISCRGVAL8
      Raz [M:SRE9]DISCRGREN8
    Endif
    Read [ACV] CODACT = "SP9"
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(8) = 1
      Raz [M:SRE9]DISCRGVAL9
      Raz [M:SRE9]DISCRGREN9
    Endif
  Else
    Local Mask SPSW [SPSW]
    [M:SPSW]BPCREF = [M:SRE0]SREBPC
    [M:SPSW]DATREF = date$
    [M:SPSW]USRREF = GUSER
    [M:SPSW]CUR = [M:SRE8]SRECUR
    [M:SPSW]PRITYP = [M:SRE8]SREPRITYP
    [M:SPSW]VACBPR = [M:SRE8]SREVACBPR
    [M:SPSW]CHGTYP = [M:SRE8]SRECHGTYP
    [M:SPSW]SAU = [F:ITM]STU
    [M:SPSW]CONTEXT = "SRE"
    Call RECHVATCOD(1,1,[M:SPSW]BPCREF,[F:ITM]ITMREF,"CRM1",INOL,[M:SPSW]VAT) From TRTX3
    #Calcul des taxes complémentaire pour la seule ligne courante.
    Call ALICLCAMT([F:ITM]ITMREF, DCBQTY, INOL, "CRM1", [M:SRE9]CLCAMT1(INOL), [M:SRE9]CLCAMT2(INOL)) From TRTX3
    #Calcul de la quantité courante en unité de stock
    Call SREC_COE(SZITM, [M:SRE0]SREBPC, [F:ITM]STU, SZUOM, ICOEFPARAM) From TRTVENQTE
    [M:SRE9]SAUSTUCOE(INOL) = ICOEFPARAM
    DCBCUMQTY = DCBQTY * [M:SRE9]SAUSTUCOE(INOL)
    DCBCLCQTY = DCBQTY * [M:SRE9]SAUSTUCOE(INOL)
    [M:SRE9]HDTSTUQTY(INOL) = DCBCUMQTY
    # ----------------------------------------------------
    #Sortie de stock
    # FGR 25/01/2011 : X3SUIVI79472 utiliser INOL et pas nolign-1
    If [M:SRE9]HDTTYP(INOL) = 2 Then
      If [M:SRE9]HDTDONDAT(INOL) <> [00/00/00] Then
        If [M:SRE9]HDTSTOISS(INOL) = 2 Then
          [M:SRE9]HDTISSQTY(INOL) = [M:SRE9]HDTSTUQTY(INOL)
        Endif
      Endif
    Endif
    # ----------------------------------------------------
    #Calcul de la quantité cumulée en unité de stock
    For ITER = 0 To [M:SRE9]NBLIG-1
      If ITER <> INOL Then
        #If SZITM = [M:SRE9]HDTITM(ITER) Then                           # FGR 25/11/2010 : X3SUIVI68826
        If SZITM = [M:SRE9]HDTITM(ITER) and [M:SRE9]HDTINV(ITER) Then   # FGR 25/11/2010 : X3SUIVI68826 : Slt sur ce qu'on facture
          DCBCUMQTY += [M:SRE9]HDTSTUQTY(ITER)
        Endif
      Endif
    Next
    #Recherche du tarif
    Call ALICLCAMT([F:ITM]ITMREF, DCBCUMQTY, -1, "CRM2", [M:SPSW]CLCAMT1, [M:SPSW]CLCAMT2) From TRTX3
    #PROVISOIRE
    Gosub CRM_OPEN_BPR_VENTE From CRMMULTISOC
    Gosub CRM_OPEN_BPC_VENTE From CRMMULTISOC
    Call RECH_TARIF(1, [F:ITM]ITMREF, 0, DCBCUMQTY, "CRM", GROPRI) From TRTVENTAR
    Gosub CRM_CLOSE_BPR_VENTE From CRMMULTISOC
    Gosub CRM_CLOSE_BPC_VENTE From CRMMULTISOC
    Raz MAJREM
    NETPRI = 0
    For ITERNET = 1 To 9
      If evalue("dim([M:SPSW]DISCRGVAL" + num$(ITERNET) + ")") > 0 Then
        MAJREM(ITERNET-1) = evalue("[M:SPSW]DISCRGVAL" + num$(ITERNET))
      Endif
    Next
    If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
    If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
    If [F:FCY]FCY <> [M:SRE0]SALFCY Then
      Read [FCY]FCY0=[M:SRE0]SALFCY
      If fstat Then
        Raz [F:FCY]
      Endif
    Endif
    GSOCIETE = [F:FCY]LEGCPY
    If [F:CPY]CPY <> GSOCIETE Then
      Read [CPY]CPY0=GSOCIETE
      If fstat Then
        Raz [F:CPY]
      Endif
    Endif
    #Calcul du prix net unitaire
    Call CALNET (1,[F:CPY]PLISTC,GROPRI,MAJREM, DCBCUMQTY, NETPRI, [M:SPSW]CUR) From TRTPRICE
    #Calcul du prix net de la ligne courante
    [M:SRE9]HDTAMT(INOL) = NETPRI * [M:SRE9]HDTSTUQTY(INOL)
    If IDELFLG Then
      If [M:SRE9]MANAMTFLG(INOL) <> 2 Then
        [M:SRE9]HDTAMTINV(INOL) = arr(NETPRI * [M:SRE9]HDTSTUQTY(INOL),10^-2)
        If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
          # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
          Call AMOUNT(1, "SRE9", INOL, [M:SRE9]HDTAMT(INOL), [M:SRE9]HDTINV(INOL), [M:SRE9]HDTAMTINV(INOL), [M:SRE9]PITHDT(INOL), [M:SRE9]INVPITFLG(INOL), IERRINF) From TRTAMOUNT
        Else
          IPITHDT = 0
          IINVPITFLG = 0
          Call AMOUNT(1, "SRE9", INOL, [M:SRE9]HDTAMT(INOL), [M:SRE9]HDTINV(INOL), [M:SRE9]HDTAMTINV(INOL), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
        Endif
        If IERRINF Then
          GMESSAGE = mess(IERRINF,182,1)
          GERR = 1
          End
        Endif
      Endif
    Else
      # FGR 20/01/2012 : X3SUIVI71065 Vu avec Lucie
      #[M:SRE9]HDTAMTINV(INOL) = arr(NETPRI * [M:SRE9]HDTSTUQTY(INOL),10^-2)
      If [M:SRE9]HDTINV(INOL) = G_OUI and [M:SRE9]MANAMTFLG(INOL) <> 2 Then
        [M:SRE9]HDTAMTINV(INOL) = arr(NETPRI * [M:SRE9]HDTSTUQTY(INOL),10^-2)
      Endif
    Endif
    #Calcul du prix net des autres lignes du même article
    For ITER = 0 To [M:SRE9]NBLIG-1
      If ITER <> INOL Then
        If SZITM = [M:SRE9]HDTITM(ITER) Then
          If [M:SRE9]HDTINV(ITER) = G_OUI Then  # FGR 03/01/2012 : X3SUIVI76710 : on applique le tarif que sur les lignes déjà facturables
            ISVHDTINV = [M:SRE9]HDTINV(ITER)                              # FGR 25/11/2010 : X3SUIVI68826
            [M:SRE9]HDTAMT(ITER) = NETPRI * [M:SRE9]HDTSTUQTY(ITER)
            If [M:SRE9]MANAMTFLG(ITER) <> 2 Then
              [M:SRE9]HDTAMTINV(ITER) = arr(NETPRI * [M:SRE9]HDTSTUQTY(ITER),10^-2)
              If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
                # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
                #Call AMOUNT(0, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), [M:SRE9]PITHDT(ITER), [M:SRE9]INVPITFLG(ITER), IERRINF) From TRTAMOUNT
                Call AMOUNT(0, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), ISVHDTINV, [M:SRE9]HDTAMTINV(ITER), [M:SRE9]PITHDT(ITER), [M:SRE9]INVPITFLG(ITER), IERRINF) From TRTAMOUNT # FGR 25/11/2010 :
# X3SUIVI68826
              Else
                IPITHDT = 0
                IINVPITFLG = 0
                #Call AMOUNT(0, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
                Call AMOUNT(0, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), ISVHDTINV, [M:SRE9]HDTAMTINV(ITER), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT # FGR 25/11/2010 : X3SUIVI68826
              Endif
              If IERRINF Then
                GMESSAGE = mess(IERRINF,182,1)
                GERR = 1
                Break
              Endif
            Endif
          Else
            # FGR 20/01/2012 : X3SUIVI71065 Vu avec Lucie
            [M:SRE9]HDTAMT(ITER) = arr(NETPRI * [M:SRE9]HDTSTUQTY(ITER), 10^-2)
          Endif
        Endif
      Endif
    Next
    If GERR Then
      End
    Endif
    #Transfert des informations du masque vers l'écran (Ligne courante)
    [M:SRE9]VAT1(INOL) = [M:SPSW]VAT(0)
    [M:SRE9]VAT2(INOL) = [M:SPSW]VAT(1)
    [M:SRE9]VAT3(INOL) = [M:SPSW]VAT(2)
    [M:SRE9]PRIREN(INOL) = [M:SPSW]PRIREN
    #
    For ITER = 1 To 9
      If evalue("dim([M:SRE9]DISCRGVAL" + num$(ITER) + ")") > 0 Then
        If evalue("dim([M:SPSW]DISCRGVAL" + num$(ITER) + ")") > 0 Then
          Assign "[M:SRE9]DISCRGVAL" + num$(ITER) + "(INOL)" With evalue("[M:SPSW]DISCRGVAL" + num$(ITER))
          Assign "[M:SRE9]DISCRGREN" + num$(ITER) + "(INOL)" With evalue("[M:SPSW]DISCRGREN" + num$(ITER))
        Endif
      Endif
    Next ITER
    #Transfert des informations du masque vers l'écran (Lignes du même article)
    For ITER = 0 To [M:SRE9]NBLIG-1
      If ITER <> INOL Then
        If SZITM = [M:SRE9]HDTITM(ITER) Then
          If [M:SRE9]MANAMTFLG(ITER) <> 2 Then
            [M:SRE9]PRIREN(ITER) = [M:SPSW]PRIREN
            For ITERNET = 1 To 9
              If evalue("dim([M:SRE9]DISCRGVAL" + num$(ITERNET) + ")") > 0 Then
                If evalue("dim([M:SPSW]DISCRGVAL" + num$(ITERNET) + ")") > 0 Then
                  Assign("[M:SRE9]DISCRGVAL" + num$(ITERNET) + "(ITER)") With evalue("[M:SPSW]DISCRGVAL" + num$(ITERNET))
                  Assign("[M:SRE9]DISCRGREN" + num$(ITERNET) + "(ITER)") With evalue("[M:SPSW]DISCRGREN" + num$(ITERNET))
                Endif
              Endif
            Next ITERNET
          Endif
        Endif
      Endif
    Next ITER
    Close Local Mask [SPSW]
  Endif
End

##########################################################################################################
# Suppression du parc concerné
#####################################################################
Subprog RAZMAC
  Raz [M:SRE0]SREMAC
  Raz [M:SRE7]PRESRE7NOL
  Raz [M:SRE7]NBMAC
  Raz [M:SRE7]NBMACSEL
  Raz [M:SRE7]MAC
  Raz [M:SRE7]ITM
  Raz [M:SRE7]ITMDES
  Raz [M:SRE7]SER
  Raz [M:SRE7]QTY
  Raz [M:SRE7]PBL
  Raz [M:SRE7]COVFLG
  Raz [M:SRE7]COVSPT
  Raz [M:SRE7]COVVCR
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Raz [M:SRE7]PITMAC
  Endif
  Raz [M:SRE7]MACDEF
  Raz [M:SRE7]ITNGRU
  Raz [M:SRE7]NBCPN
  Raz [M:SRE7]CPNITM
  Raz [M:SRE7]CPNITMDES
  Raz [M:SRE7]CPNQTY
  Raz [M:SRE7]CPNCOVFLG
  Raz [M:SRE7]CPNCOVSPT
  Raz [M:SRE7]CPNCOVVCR
  Raz [M:SRE7]CPNSEQ
  Call DEBTRANS From GLOCK
  Trbegin [SRM], [SRN]
  If GREP = "C" Then
    Delete [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
    If fstat Then
      If fstat <> 4 Then
        Rollback
        Affzo [M:SRE7]1-99
        End
      Endif
    Endif
  Elsif GREP = "D" Then
    Delete [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
    If fstat Then
      If fstat <> 4 Then
        Rollback
        Affzo [M:SRE7]1-99
        End
      Endif
    Endif
  Else
    Delete [SRM] Where [F:SRM]SRENUM = [M:SRE0]SRENUM
    If fstat Then
      If fstat <> 4 Then
        Rollback
        Affzo [M:SRE7]1-99
        End
      Endif
    Endif
    Delete [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
    If fstat Then
      If fstat <> 4 Then
        Rollback
        Affzo [M:SRE7]1-99
        End
      Endif
    Endif
  Endif
  Commit
End

##########################################################################################################
# Duplication des composants concernés
#####################################################################
Subprog DUPLICPN(SZSRENUM, SZCRESEQ)
Value Char SZSRENUM
Value Char SZCRESEQ

  #CHECK FILE_DECLARE SREMACCPN [SRN2]
  Call DEBTRANS From GLOCK
  Trbegin [SRN]
  Filter [SRN2] Where [F:SRN2]SRENUM = SZSRENUM and [F:SRN2]TPYFLG = 0 and [F:SRN2]FGVCAH = 0
  For [SRN2]
    [F:SRN] = [F:SRN2]
    [F:SRN]SRENUM = SZCRESEQ
    [F:SRN]TPYFLG = 1
    [F:SRN]CREDAT = date$
    [F:SRN]CREUSR = GUSER
    Write [SRN]
    If fstat Then
      #Erreur lors de l'enregistrement des composants du parc concerné.
      GMESSAGE = mess(181,182,1)
      GERR = 1
      Rollback
      Break
    Endif
  Next
  If GERR Then
    End
  Else
    Commit
  Endif
End

##########################################################################################################
# Affectation d'un parc filtré à une demande de service
#######################################################################
Subprog ONMACFLT(SZSRENUM, SZQURNUM, IBPCFLT)
Value Char SZSRENUM
Value Char SZQURNUM
Value Integer IBPCFLT

Local Char SZMACDEF
Local Integer IFINPPL
Local Integer ILINDEB
Local Char SZMESS(250)
Local Integer ITOOMUCH
Local Integer INOL
Local Integer INOL2

  If [M:SRE7]AMMGD1FLG Then
    [M:SRE7]AMMGD1FLG = 0
    End
  Endif
  [M:SRE7]AMMGD1FLG = 0
  ILINDEB = 0
  IFINPPL = 0
  SZMACDEF = ""
  SZMESS = ""
  ITOOMUCH = 0
  INOL = 0
  INOL2 = 0
  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    #Erreur lors de l'alimentation du parc filtré.
    GMESSAGE = mess(256,182,1)
    GERR = 1
    End
  Endif
  #Suppression du parc
  If [M:SRE7]NBMAC > 0 Then
    INOL = 0
    INOL2 = [M:SRE7]NBMAC - 1
    Gosub DELMACLINES From SUBSREB4
    Call RAZMAC
    If GERR Then
      End
    Endif
  Endif
  #Identification du parc
  Call TEMPON(mess(259,182,1)) From GESECRAN
  IFINPPL = [F:MQR]FINPPL
  If IBPCFLT = 2 Then
    #Avec filtre client
    If [M:SRE0]SREBPC = "" Then
      Filter [QTP] Where [F:QTP]QURNUM = SZQURNUM and [F:QTP]PPLORD = IFINPPL
      For [QTP]QTP1
        If ILINDEB >= dim([M:SRE7]MAC) Then
          ITOOMUCH = 1
          Break
        Endif
        Gosub SETSRE7REC
      Next
      Filter [QTP]
      [M:SRE7]NBMAC = ILINDEB
    Else
      Link [QTP] With [MAC] MAC0 = [F:QTP]KEYTGR As [LNK] Order By Key KBID = [F:QTP]KEYTGR Asc
      Filter [LNK] Where [F:MAC]BPCNUM = [M:SRE0]SREBPC and [F:MAC]MACITNTYP = 1 and [F:QTP]QURNUM = SZQURNUM and [F:QTP]PPLORD = IFINPPL Order By [F:QTP]KEYTGR Asc
      For [LNK]
        If ILINDEB >= dim([M:SRE7]MAC) Then
          ITOOMUCH = 1
          Break
        Endif
        Gosub SETSRE7REC
      Next
      Filter [LNK]
      [M:SRE7]NBMAC = ILINDEB
    Endif
  Else
    #Sans filtre client
    Filter [QTP] Where [F:QTP]QURNUM = SZQURNUM and [F:QTP]PPLORD = IFINPPL
    For [QTP]QTP1
      If ILINDEB >= dim([M:SRE7]MAC) Then
        ITOOMUCH = 1
        Break
      Endif
      Gosub SETSRE7REC
    Next
    Filter [QTP]
    [M:SRE7]NBMAC = ILINDEB
  Endif
  #On rédéfini le parc par défaut
  If SZMACDEF <> "" Then
    [M:SRE0]SREMAC = SZMACDEF
    If SZSRENUM <> "" Then
      Trbegin [SRE]
      [F:SRE]SREMAC = SZMACDEF
      Rewrite [SRE]
      If fstat Then
        #Erreur lors de la définition du nouveau parc par défaut.
        GMESSAGE = mess(257,182,1)
        GERR = 1
        Rollback
      Else
        Commit
      Endif
    Endif
  Endif
  Call TEMPOFF From GESECRAN
  If ITOOMUCH Then
    #Un maximum de 999 fiches parc est autorisé sur une demande de service.
    # Seule une partie de la sélection a été prise en compte.
    SZMESS = mess(260,182,1) - mess(261,182,1)
    GMESSAGE = SZMESS
    GERR = 3
  Endif
  ###########################
  # Contrôle de la couverture
  ###########################
  Call COVERM From TRTCOVER
  Affzo [M:SRE7]1-99
  Affzo [M:SRE2]1-99
  Affzo [M:SRE9]1-99
End

##########################################################################################################
$SETSRE7REC
  If [F:QTP]KEYTGR <> "" Then
    #Alimente SREMAC
    If SZMACDEF = "" Then
      SZMACDEF = [F:QTP]KEYTGR
    Endif
    If ILINDEB = 0 Then
      [M:SRE7]NBMACSEL(ILINDEB) = "->"
    Else
      [M:SRE7]NBMACSEL(ILINDEB) = ""
    Endif
    [M:SRE7]MAC(ILINDEB) = [F:QTP]KEYTGR
    If [M:SRE7]MAC(ILINDEB) = "" Then
      [M:SRE7]ITM(ILINDEB) = ""
      [M:SRE7]ITMDES(ILINDEB) = ""
      [M:SRE7]SER(ILINDEB) = ""
      [M:SRE7]QTY(ILINDEB) = 0
    Else
      Read [MAC]MAC0=[M:SRE7]MAC(ILINDEB)
      If fstat Then
        [M:SRE7]ITM(ILINDEB) = ""
        [M:SRE7]ITMDES(ILINDEB) = ""
        [M:SRE7]SER(ILINDEB) = ""
        [M:SRE7]QTY(ILINDEB) = 0
      Else
        [M:SRE7]ITM(ILINDEB) = [F:MAC]MACPDTCOD
        If [M:SRE7]ITM(ILINDEB) = "" Then
          [M:SRE7]ITMDES(ILINDEB) = ""
        Else
          #Call LECTEXTRA([M:SRE7]ITMDES(ILINDEB), "ITMMASTER", "DES1AXX", [M:SRE7]ITM(ILINDEB), "") From ATEXTRA
          Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:SRE7]ITM(ILINDEB),[M:SRE7]ITMDES(ILINDEB), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
        Endif
        [M:SRE7]SER(ILINDEB) = [F:MAC]MACSERNUM
        [M:SRE7]QTY(ILINDEB) = [F:MAC]MACQTY
        If [M:SRE7]QTY(ILINDEB) = 0 Then
          [M:SRE7]QTY(ILINDEB) = 1
        Endif
      Endif
    Endif
    [M:SRE7]PBL(ILINDEB) = [M:SRE7]SREPBLGRP
    [M:SRE7]ITNGRU(ILINDEB) = ""
    ILINDEB += 1
  Endif
Return

##########################################################################################################
# Supprime les composants en cours de saisie.
#########################################################
$RAZCPN
  If [M:SRE7]NBCPN > 0 Then
    Raz [M:SRE7]NBCPN
    Raz [M:SRE7]CPNITM
    Raz [M:SRE7]CPNQTY
    Raz [M:SRE7]CPNCOVFLG
    Raz [M:SRE7]CPNCOVSPT
    Raz [M:SRE7]CPNCOVVCR
    Raz [M:SRE7]CPNSEQ
    Call DEBTRANS From GLOCK
    Trbegin [SRN]
    If GREP = "C" Then
      Delete [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM = [M:SRE7]MAC(nolign-1) and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
    Elsif GREP = "D" Then
      Delete [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM = [M:SRE7]MAC(nolign-1) and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
    Else
      Delete [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM = [M:SRE7]MAC(nolign-1) and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
    Endif
    If fstat Then
      If fstat = 4 Then
        Commit
      Else
        Rollback
      Endif
    Else
      Commit
    Endif
  Endif
Return

##########################################################################################################
# Affecte une demande de service sur la base d'une famille de compétence.
########################################################
$ASSIGNSRE
Local Char SZMESS(250)
Local Integer IMESSREP
Local Integer IMINCOUNT
Local Integer IFIRSTSTEP
Local Char SZSKILLEDREP
Local Char SZQUEUE
Local Char SZHDKREP
Local Integer IHDKREP
Local Integer ISREFLG
Local Integer ISRECOUNT
Local Integer ISREPBRCOUNT
Local Char SZDES(GLONDCO)    # FGR 23/09/2009 : X3SUIVI58037

  SZHDKREP = ""
  IHDKREP = 0
  IMINCOUNT = 0
  IFIRSTSTEP = 0
  SZSKILLEDREP = ""
  SZQUEUE = ""
  ISREFLG = 0
  ISRECOUNT = 0
  ISREPBRCOUNT = 0
  If !clalev([F:PBR]) : Local File FAMPBREP [PBR] : Endif
  Filter [PBR] Where [F:PBR]GRPPBLNUM = VALEUR and [F:PBR]STTFLG = 0
  For [PBR]
    Read [AUS]CODUSR=[F:PBR]REPNUM
    If !fstat Then
      Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:PBR]REPNUM, "") From SUBAUS
      If SZHDKREP = "" Then
        IHDKREP = 1
      Else
        IHDKREP = val(SZHDKREP)
      Endif
      If IHDKREP = 2 Then
        If !IFIRSTSTEP Then
          IMINCOUNT = [F:PBR]SRECOU
          SZSKILLEDREP = [F:PBR]REPNUM
        Else
          If [F:PBR]SRECOU < IMINCOUNT Then
            IMINCOUNT = [F:PBR]SRECOU
            SZSKILLEDREP = [F:PBR]REPNUM
          Endif
        Endif
        IFIRSTSTEP += 1
      Endif
    Endif
  Next
  Filter [PBR]
  If IFIRSTSTEP = 0 Then
    #Aucun représentant n'est trouvé
    #Recherche de la queue concernée la moins utilisée.
    If !clalev([F:PBQ]) : Local File FAMPBQUE [PBQ] : Endif
    Filter [PBQ] Where [F:PBQ]GRPPBLNUM = VALEUR and [F:PBQ]STTFLG = 0
    For [PBQ]
      If !IFIRSTSTEP Then
        IMINCOUNT = [F:PBQ]SRECOU
        SZQUEUE = [F:PBQ]QUENUM
      Else
        If [F:PBQ]SRECOU < IMINCOUNT Then
          IMINCOUNT = [F:PBQ]SRECOU
          SZQUEUE = [F:PBQ]QUENUM
        Endif
      Endif
      IFIRSTSTEP += 1
    Next
    Filter [PBQ]
    If IFIRSTSTEP = 0 Then
      #Aucune queue n'est trouvée. Affectation du site.
      If [M:SRE2]SREASS <> 1 Then
        If [M:SRE0]SALFCY = "" Then
          #Confimez-vous l'affectation de la demande au dispatching global ?
          SZMESS = mess(550,182,1)
        Else
          Read [FCY]FCY0=[M:SRE0]SALFCY
          If fstat Then
            #Confimez-vous l'affectation de la demande au dispatching du site
            SZMESS = mess(551,182,1) - ":" - [M:SRE0]SALFCY - "?"
          Else
            #Confimez-vous l'affectation de la demande au dispatching du site
            SZMESS = mess(551,182,1) - ":" - [F:FCY]FCYNAM - "(" + [M:SRE0]SALFCY + ") ?"
          Endif
        Endif
        IMESSREP = 0
        Call OUINON(SZMESS, IMESSREP) From GESECRAN
        If IMESSREP = 2 Then
          Gosub ASSDSCTOSRE
        Endif
      Else
        Gosub ASSDSCTOSRE
      Endif
    Else
      #Une queue a été trouvée.
      If [M:SRE2]SREASS = 2 Then
        If [M:SRE2]SREDET <> "" Then
          #Confimez-vous l'affectation de la demande à la queue
          Read [QUE]QUE0=SZQUEUE
          If fstat Then
            SZMESS = mess(552,182,1) - ":" - SZQUEUE - "?"
          Else
            # FGR 23/09/2009 : X3SUIVI58037
            #SZMESS = mess(552,182,1) - ":" - [F:QUE]TTR - "(" + SZQUEUE + ") ?"
            Call LECTEXTRA(SZDES,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
            SZMESS = mess(552,182,1) - ":" - SZDES - "(" + SZQUEUE + ") ?"
          Endif
          IMESSREP = 0
          Call OUINON(SZMESS, IMESSREP) From GESECRAN
          If IMESSREP = 2 Then
            Gosub ASSQUETOSRE
          Endif
        Endif
      Else
        Gosub ASSQUETOSRE
      Endif
    Endif
  Else
    #Un représentant a été trouvé.
    #Recherche le collaborateur vraiment le moins occupé
    Filter [PBR] Where [F:PBR]GRPPBLNUM = VALEUR and [F:PBR]STTFLG = 0 and [F:PBR]REPNUM <> SZSKILLEDREP and [F:PBR]SRECOU = IMINCOUNT
    For [PBR]
      If ISREFLG = 0 Then
        Filter [SRE] Where [F:SRE]SREASS = 2 and [F:SRE]SREDET = SZSKILLEDREP and [F:SRE]SREMACPBL = "" and [F:SRE]SREPBLGRP = ""
        For [SRE]
          ISRECOUNT += 1
        Next
        Filter [SRE]
        ISREFLG = 1
      Endif
      Read [AUS]CODUSR=[F:PBR]REPNUM
      If !fstat Then
        Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:PBR]REPNUM, "") From SUBAUS
        If SZHDKREP = "" Then
          IHDKREP = 1
        Else
          IHDKREP = val(SZHDKREP)
        Endif
        If IHDKREP = 2 Then
          ISREPBRCOUNT = 0
          Filter [SRE] Where [F:SRE]SREASS = 2 and [F:SRE]SREDET = [F:PBR]REPNUM and [F:SRE]SREMACPBL = "" and [F:SRE]SREPBLGRP = ""
          For [SRE]
            ISREPBRCOUNT += 1
          Next
          Filter [SRE]
          If ISREPBRCOUNT < ISRECOUNT Then
            ISRECOUNT = ISREPBRCOUNT
            SZSKILLEDREP = [F:PBR]REPNUM
          Endif
        Endif
      Endif
    Next
    Filter [PBR]
    If [M:SRE2]SREASS = 2 Then
      If [M:SRE2]SREDET <> SZSKILLEDREP Then
        #Confimez-vous l'affectation de la demande au collaborateur
        Read [AUS]CODUSR=SZSKILLEDREP
        If fstat Then
          SZMESS = mess(549,182,1) - ":" - SZSKILLEDREP - "?"
        Else
          SZMESS = mess(549,182,1) - ":" - [F:AUS]NOMUSR - "(" + SZSKILLEDREP + ") ?"
        Endif
        IMESSREP = 0
        Call OUINON(SZMESS, IMESSREP) From GESECRAN
        If IMESSREP = 2 Then
          Gosub ASSREPTOSRE
        Endif
      Endif
    Else
      Gosub ASSREPTOSRE
    Endif
  Endif
Return

##########################################################################################################
# Affecte la demande à un collaborateur
#############################################################################
$ASSDSCTOSRE
  [M:SRE2]SREASS = 1
  [M:SRE2]SREDET = [M:SRE0]SALFCY
  [M:SRE2]SREDATASS = date$
  [M:SRE2]SREHOUASS = left$(time$, 2) + mid$(time$, 4, 2)
  Read [FCY]FCY0=[M:SRE0]SALFCY
  If fstat Then
    [M:SRE2]SREDETCLA = [M:SRE0]SALFCY
  Else
    [M:SRE2]SREDETCLA = [F:FCY]FCYNAM
  Endif
Return

##########################################################################################################
# Affecte la demande à un collaborateur
#############################################################################
$ASSQUETOSRE
  [M:SRE2]SREASS = 3
  [M:SRE2]SREDET = SZQUEUE
  [M:SRE2]SREDATASS = date$
  [M:SRE2]SREHOUASS = left$(time$,2) + mid$(time$,4,2)
  Read [QUE]QUE0=SZQUEUE
  If fstat Then
    [M:SRE2]SREDETCLA = SZQUEUE
  Else
    # FGR 23/09/2009 : X3SUIVI58037
    #[M:SRE2]SREDETCLA = [F:QUE]TTR
    Call LECTEXTRA([M:SRE2]SREDETCLA,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
  Endif
Return

##########################################################################################################
# Affecte la demande à un collaborateur
#############################################################################
$ASSREPTOSRE
  [M:SRE2]SREASS = 2
  [M:SRE2]SREDET = SZSKILLEDREP
  [M:SRE2]SREDATASS = date$
  [M:SRE2]SREHOUASS = left$(time$, 2) + mid$(time$, 4, 2)
  Read [AUS]CODUSR=SZSKILLEDREP
  If fstat Then
    [M:SRE2]SREDETCLA = SZSKILLEDREP
  Else
    [M:SRE2]SREDETCLA = [F:AUS]NOMUSR
  Endif
Return

##########################################################################################################
# Détermine si la demande est facturable ou totalement gratuite. Classe M
#############################################################################
Subprog SETINVFLG
Local Integer ITER

  If [M:SRE2]SREINVFLG = 3 Then
    End
  Endif
  [M:SRE2]SREINVFLG = 1
  If GCLOINV <> 2 Then
    End
  Endif
  For ITER = 0 To [M:SRE9]NBLIG-1
    If [M:SRE9]HDTINV(ITER) = 2 Then
      [M:SRE2]SREINVFLG = 2
      Break
    Endif
  Next
End

##########################################################################################################
# Détermine si la demande est facturable ou totalement gratuite. Classe F
#############################################################################
Subprog GETINVFLG(SZSRENUM, IINVFLG)
Value Char SZSRENUM
Variable Integer IINVFLG

  IINVFLG = 1
  Filter [HDT] Where [F:HDT]SRENUM = SZSRENUM and [F:HDT]TPL <> 2 and [F:HDT]HDTINV = 2
  IINVFLG = 1
  For [HDT]HDT1
    IINVFLG = 2
    Break
  Next
  Filter [HDT]
End

##########################################################################################################
# Clôture d'une demande de service
#############################################################################
Subprog CLOSRE(SZSRENUM, SZITN, SZBPC, ISREASS, IPREASS, ISREINVFLG, IDONDATFLG, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Value Char SZITN
Value Char SZBPC
Value Libelle ISREASS
Value Libelle IPREASS
Value Libelle ISREINVFLG
Value Integer IDONDATFLG
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer ISPGTIMHOU
Local Integer ISPGTIMMNT
Local Integer IHDTDONHOU
Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #---------------------------------------------------#
  # Séquence commune à toutes les demandes
  If ISREASS <> 5 Then
    End
  Endif
  If IPREASS = 5 Then
    End
  Endif
  #---------------------------------------------------#
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [HDT]
  Endif
  If GPILNAV > 0 Then
    #Etape 1 : On passe tous les points mobilisés en consommés
    If GNAVIG(GPILNAV) = "GESSRE" Then
      If GREP = "C" Then
        Call RERTOCSM([M:SRE0]CRESEQ, 1, IERRINF, ICHAPTER, IBRETOUR)
      Elsif GREP = "D" Then
        Call RERTOCSM([M:SRE0]CRESEQ, 1, IERRINF, ICHAPTER, IBRETOUR)
      Else
        Call RERTOCSM(SZSRENUM, 0, IERRINF, ICHAPTER, IBRETOUR)
      Endif
    Else
      Call RERTOCSM(SZSRENUM, 0, IERRINF, ICHAPTER, IBRETOUR)
    Endif
  Else
    Call RERTOCSM(SZSRENUM, 0, IERRINF, ICHAPTER, IBRETOUR)
  Endif
  If IBRETOUR = 0 Then
    GOK = 0
  Endif
  If GOK < 1 Then
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
    End
  Endif
  #Etape 2 : On transforme les consommations en effectué.
  If IDONDATFLG Then
    #Trbegin [HDT]  # FGR 20/08/2010 : X3SUIVI66590 : Pas de raison de faire ça.
    Filter [HDT] Where [F:HDT]SRENUM = SZSRENUM and [F:HDT]TPL <> 2 and [F:HDT]HDTINV = 2 and [F:HDT]HDTDONDAT = [00/00/00]
    For [HDT]HDT1
      [F:HDT]HDTDONDAT = date$
      IHDTDONHOU = 0
      Call HOUTOSEC(val(left$(time$, 2)), val(mid$(time$, 4, 2)), IHDTDONHOU) From CRMUTIL140
      [F:HDT]HDTDONHOU = IHDTDONHOU
      If [F:HDT]ITNNUM = "" Then
        [F:HDT]SPGTIMHOU = 0
        [F:HDT]SPGTIMMNT = 0
      Else
        If [F:HDT]HDTTYP = 3 Then
          If [F:HDT]SPGTIMHOU = 0 Then
            If [F:HDT]SPGTIMMNT = 0 Then
              ISPGTIMHOU = 0
              ISPGTIMMNT = 0
              Call DEFSPGTIM(SZBPC, [F:HDT]HDTQTY, [F:HDT]HDTUOM, [F:HDT]HDTITM, ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
              [F:HDT]SPGTIMHOU = ISPGTIMHOU
              [F:HDT]SPGTIMMNT = ISPGTIMMNT
            Endif
          Endif
        Endif
      Endif
      Rewrite [HDT]
      If fstat Then
        #Erreur lors de la transformation des consommations facturables.
        IERRINF = 317
        ICHAPTER = 182
        IBRETOUR = 0
        Call FSTA("HDT") From GLOCK
        GOK = 0
        Break
      Endif
    Next
    Filter [HDT]
  Endif
  If GOK < 1 Then
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
    End
  Endif
  #Etape 3 : On transforme toutes les interventions en effectué
  Filter [ITN] Where [F:ITN]SRVDEMNUM = SZSRENUM and [F:ITN]DON <> 2
  For [ITN]
    [F:ITN]DON = 2
    [F:ITN]PBLSOL = 2
    Call ITNSPGTIM([F:ITN]NUM, ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
    [F:ITN]HTOTTIMSPG = ISPGTIMHOU
    [F:ITN]MTOTTIMSPG = ISPGTIMMNT
    Rewrite [ITN]
    If fstat Then
      #Erreur lors de la transformation des interventions.
      IERRINF = 318
      ICHAPTER = 182
      IBRETOUR = 0
      Call FSTA("ITN") From GLOCK
      GOK = 0
      Break
    Endif
    If SZITN <> "" Then
      If [F:ITN]NUM = SZITN Then
        [M:ITN4]HTOTTIMSPG = ISPGTIMHOU
        [M:ITN4]MTOTTIMSPG = ISPGTIMMNT
      Endif
    Endif
  Next
  Filter [ITN]
  If GOK < 1 Then
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
    End
  Endif
  #---------------------------------------------------#
  # Le reste de la séquence concerne uniquement les demandes facturables.
  If ISREINVFLG < 2 Then
    End
  Endif
  #Etape 4 : On alimente la table des lignes de facture.
  Call FEEDHDI(SZSRENUM, IERRINF, ICHAPTER, IBRETOUR) From TRTFSOL
  If IBRETOUR = 0 Then
    GOK = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Transforme les points mobilisés par la demande en consommés
################################################################################
Subprog RERTOCSM(SZSRENUM, ITPYFLG, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Value Integer ITPYFLG
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer ICONTOTCSM
Local Integer IBDEBTRANSFLG

  #CHECK FILE_DECLARE PITCOUNT [PCT2]
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  ICONTOTCSM = 0
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [PCT]
  Endif
  Filter [PCT] Where [F:PCT]SRENUM = SZSRENUM and [F:PCT]TPYFLG = ITPYFLG and [F:PCT]FGVCAH = 0
  For [PCT]
    If [F:PCT]SAT <> 2 Then
      [F:PCT]SAT = 2
      Rewrite [PCT]
      If fstat Then
        #Erreur lors de la conversion des points mobilisés en consommés.
        IERRINF = 508
        ICHAPTER = 182
        IBRETOUR = 0
        Call FSTA("PCT") From GLOCK
        GOK = 0
        Break
      Endif
    Endif
  Next
  Filter [PCT]
  #On vérifie s'il y a des contrats à archivé
  If GOK < 1 Then
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
    End
  Endif
  Filter [PCT] Where [F:PCT]SRENUM = SZSRENUM and [F:PCT]TPYFLG = ITPYFLG and [F:PCT]FGVCAH = 0
  For [PCT]
    If [F:PCT]CONNUM <> "" Then
      Read [CON]CON0=[F:PCT]CONNUM
      If !fstat Then
        ICONTOTCSM = 0
        Filter [PCT2] Where [F:PCT2]CONNUM = [F:PCT]CONNUM and [F:PCT2]FGVCAH = 0
        For [PCT2] PCT1
          ICONTOTCSM += [F:PCT2]PIT
        Next
        Filter [PCT2]
        If ICONTOTCSM >= [F:CON]PITCDT Then
          Readlock [CON]CON0=[F:PCT]CONNUM
          If fstat Then
            #Erreur lors de  l'archivage des contrats à points.
            IERRINF = 509
            ICHAPTER = 182
            IBRETOUR = 0
            Call FSTA("CON") From GLOCK
            GOK = 0
            Break
          Else
            If [F:CON]CONAMT > 0 Then
              If [F:CON]INVMET = 2 Then
                [F:CON]NEXINVDAT = date$
                Call SNEXSHIINV([F:CON]NEXINVDAT, [F:CON]INVLTI, [F:CON]INVLTIBAS, [F:CON]NEXSHIINV) From SUBCOND
              Else
                [F:CON]FDDFLG = 2
                [F:CON]FDDUSR = GUSER
                [F:CON]RSIDAT = date$
              Endif
            Else
              [F:CON]FDDFLG = 2
              [F:CON]FDDUSR = GUSER
              [F:CON]RSIDAT = date$
            Endif
            Rewrite [CON]
            If fstat Then
              #Erreur lors de  l'archivage des contrats à points.
              IERRINF = 509
              ICHAPTER = 182
              IBRETOUR = 0
              Call FSTA("CON") From GLOCK
              GOK = 0
              Break
            Else
              Unlock [CON]
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [PCT]
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Effectue le travail nécessaire suite à la facturation d'une demande de service. Travaille en classe F
#############################################################################
Subprog COMMITINV(SZSRENUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBERROR
Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  IBERROR = 0
  If SZSRENUM = "" Then
    #Le statut de facturation de la demande de service n'a pas pu être mis à jour. Code non communiqué.
    IERRINF = 305
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:HDI]) : Local File HDKTASKINV [HDI] : Endif
  If !clalev([F:CAL]) : Local File CPTANALIN [CAL] : Endif
  Read [SRE]SRE0=SZSRENUM
  If fstat Then
    #Le statut de facturation de la demande de service n'a pas pu être mis à jour. Demande non lue.
    IERRINF = 306
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 and IBERROR = 0 Then
    Trbegin [SRE]
  Endif
  If IBERROR = 0 Then
    Readlock [SRE]SRE0=SZSRENUM
    If fstat Then
      #Le statut de facturation de la demande de service n'a pas pu être mis à jour. Demande en cours d'utilisation.
      IERRINF = 307
      ICHAPTER = 182
      IBRETOUR = 0
      IBERROR = 1
    Endif
    If IBERROR = 0 Then
      [F:SRE]SREINVFLG = 3
      Rewrite [SRE]
      If fstat Then
        #Erreur lors de la mise à jour du statut de facturation de la demande de service.
        IERRINF = 308
        ICHAPTER = 182
        IBRETOUR = 0
        IBERROR = 1
        Unlock [SRE]
      Endif
    Endif
  Endif
  If IBERROR = 0 Then
    Call DELHDI(SZSRENUM, IERRINF, ICHAPTER, IBRETOUR)   # FGR 03/11/2010 : X3SUIVI68364 : pas la peine de réécrire ce qui existe
  Endif
  If IBDEBTRANSFLG = 0 Then
    If IBERROR = 0 Then
      Commit
    Else
      Rollback
    Endif
  Endif
End

##########################################################################################################
# Supprime les consommations à facturer d'une demande de service
#############################################################################
Subprog DELHDI(SZSRENUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If GOK = 0 Then
    End
  Endif
  If SZSRENUM = "" Then
    #Les consommations facturables de la demande n'ont pas pu être supprimées. Code de la demande non communiqué.
    IERRINF= 311
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [HDI]
  Endif
  For [HDI] Where [F:HDI]SRENUM = SZSRENUM
    Call ENREG_ACCCCE(0, "", "", "", "HDI", 0, [F:HDI]SRENUM, [F:HDI]HDTORD, 0, "", "A") From TRTX3CPT  # FGR 03/11/2010 : X3SUIVI68364 manque [F:HDI]HDTORD
    If GOK < 1 Then
      #Erreur lors de la suppression des axes analytiques associés aux consommations de l'intervention.
      IERRINF = 431
      ICHAPTER = 177
      IBRETOUR = 0
      IBERROR = 1
      Break
    Endif
  Next
  If IBRETOUR = 1 Then
    Delete [HDI] Where [F:HDI]SRENUM = SZSRENUM
    If fstat Then
      #Erreur lors de la suppression des lignes de consommations facturables.
      IERRINF= 312
      ICHAPTER = 182
      IBRETOUR = 0
      Call FSTA("HDI") From GLOCK
      GOK = 0
    Endif
  Endif
  If IBDEBTRANSFLG = 0 Then
    If IBRETOUR = 0 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Détecte s'il y a des consommations non effectuées.
#####################################################################
Subprog SETDONDATFLG(SZSRENUM, IDONDATFLG)
Value Char SZSRENUM
Variable Integer IDONDATFLG

Local Integer ITERHDT
Local Integer IDONEFLG
Local Integer IREP

  ITERHDT = 0
  IDONEFLG = 0
  IREP = 0
  If SZSRENUM = "" Then
    IDONEFLG = 0
    For ITERHDT = 0 To [M:SRE9]NBLIG-1
      If [M:SRE9]HDTINV(ITERHDT) = 2 Then
        If [M:SRE9]HDTDONDAT(ITERHDT) = [00/00/00] Then
          IDONEFLG = 1
          Break
        Endif
      Endif
    Next
  Else
    IDONEFLG = 0
    Filter [HDT] Where [F:HDT]SRENUM = SZSRENUM and [F:HDT]TPL <> 2 and [F:HDT]HDTINV = 2 and [F:HDT]HDTDONDAT = [00/00/00]
    For [HDT]HDT1
      IDONEFLG = 1
      Break
    Next
    Filter [HDT]
  Endif
  #Si oui, on demande si on doit les passer en effectué.
  If IDONEFLG Then
    IREP = 0
    If GCLOINV = 2 Then
      #Souhaitez-vous transformer les consommations non effectuées en effectuées.
      #Celles-ci seront alors facturables.
      Call OUINON(mess(316,182,1), IREP) From GESECRAN
    Else
      #Souhaitez-vous transformer les consommations non effectuées en effectuées.
      Call OUINON(mess(340,182,1), IREP) From GESECRAN
    Endif
    If IREP = 2 Then
      IDONDATFLG = 1
    Else
      IDONDATFLG = 0
    Endif
  Else
    IDONDATFLG = 0
  Endif
End

##########################################################################################################
# Affichage des particularités de l'onglet Gestion
######################################################
$AFFSRE2MIS
  If [M:SRE2]SREASS = 5 Then
    # Affiche le nom du technicien qui a traité une demande clôturée
    If [M:SRE2]REP <> "" Then
      Read [AUS]CODUSR=[M:SRE2]REP
      If !fstat Then
        [M:SRE2]SREDETCLA = mess(351,196,1) + [F:AUS]NOMUSR
      Endif
    Endif
    If GCLOINV = 2 Then
      Case [M:SRE2]SREINVFLG
        When 0
          [M:SRE2]OVRCOVCLA = ""
        When 1
          #Demande non facturable.
          [M:SRE2]OVRCOVCLA = mess(320,182,1)
        When 2
          #Demande en attente de facturation.
          [M:SRE2]OVRCOVCLA = mess(321,182,1)
        When 3
          #Demande facturée.
          [M:SRE2]OVRCOVCLA = mess(322,182,1)
      Endcase
    Else
      If [M:SRE2]OVRCOVREN = 0 Then
        [M:SRE2]OVRCOVCLA = ""
      Else
        [M:SRE2]OVRCOVCLA = mess([M:SRE2]OVRCOVREN,178,1)
      Endif
    Endif
  Else
    Case [M:SRE2]OVRCOV
      When 1
        If [M:SRE2]SRECOVNUM = "" Then
          [M:SRE2]OVRCOVCLA = ""
        Else
          [M:SRE2]OVRCOVCLA = mess(331,182,1) - [M:SRE2]SRECOVNUM
        Endif
      When 2
        If [M:SRE2]SRECOVNUM = "" Then
          [M:SRE2]OVRCOVCLA = ""
        Else
          [M:SRE2]OVRCOVCLA = mess(331,182,1) - [M:SRE2]SRECOVNUM
        Endif
      When 3
        If [M:SRE2]OVRCOVREN = 0 Then
          [M:SRE2]OVRCOVCLA = ""
        Else
          [M:SRE2]OVRCOVCLA = mess([M:SRE2]OVRCOVREN,178,1)
        Endif
      When 4
        If [M:SRE2]SRECOVNUM = "" Then
          [M:SRE2]OVRCOVCLA = ""
        Else
          [M:SRE2]OVRCOVCLA = mess(331,182,1) - [M:SRE2]SRECOVNUM
        Endif
      When 5
        If [M:SRE2]SRECOVNUM = "" Then
          [M:SRE2]OVRCOVCLA = ""
        Else
          [M:SRE2]OVRCOVCLA = mess(332,182,1) - [M:SRE2]SRECOVNUM
        Endif
      When 6
        [M:SRE2]OVRCOVCLA = ""
      When 7
        [M:SRE2]OVRCOVCLA = ""
    Endcase
  Endif
Return

##########################################################################################################
# Détermine si un client est un client unique d'un donneur d'ordre
###################################################################################
Subprog DETECTDOO(SZBPCNUM, SZDOONUM)
Value Char SZBPCNUM
Variable Char SZDOONUM

Local Integer INBDBL
Local Char SZBUFFER

  INBDBL = 0
  SZBUFFER = ""
  SZDOONUM = ""
  If SZBPCNUM = "" Then
    End
  Endif
  Read [DBI]DBI0=SZBPCNUM
  If fstat Then
    End
  Endif
  If [F:DBI]INTBPC = 2 Then
    End
  Endif
  Filter [DBL] Where [F:DBL]BPCNUM = SZBPCNUM
  For [DBL] DBL2
    If INBDBL = 0 Then
      SZBUFFER = [F:DBL]DOONUM
    Endif
    INBDBL += 1
    If INBDBL >= 5 Then
      Break
    Endif
  Next
  Filter [DBL]
  If INBDBL = 1 Then
    SZDOONUM = SZBUFFER
  Endif
End

##################################################################################################################
# Vérifie si le donneur d'ordre par défaut est compatible avec le tiers
##################################################################################################################
$CHECKDOO
Local Char SZMESSX(250)
Local Integer IFOUND2
Local Integer IONREP2

  IONREP2 = 0
  IFOUND2 = 0
  SZMESSX = ""
  If [M:SRE0]SREBPC <> "" Then
    If [M:SRE0]SREDOO = "" Then
      Call DETECTDOO([M:SRE0]SREBPC, [M:SRE0]SREDOO)
      If [M:SRE0]SREDOO <> "" Then
        Read [BPR]BPR0=[M:SRE0]SREDOO
        If fstat Then
          [M:SRE0]SREDOOX = [M:SRE0]SREDOO
        Else
          [M:SRE0]SREDOOX = [F:BPR]BPRNAM
        Endif
      Endif
    Else
      Filter [DBL] Where [F:DBL]DOONUM = [M:SRE0]SREDOO
      For [DBL]DBL0
        If [F:DBL]BPCNUM = [M:SRE0]SREBPC Then
          IFOUND2 = 1
          Break
        Endif
      Next
      Filter [DBL]
      If !IFOUND2 Then
        If GINTRA
           SZMESSX = [M:SRE0]SREBPC - mess(607,196,1) - [M:SRE0]SREDOOX
          GERR = 2
        Else
          #Le client saisi n'est pas un client de : [M:SRE0]SREDOOX
          #Souhaitez-vous supprimer le donneur d'ordre ?
          SZMESSX = [M:SRE0]SREBPC - mess(607,196,1) - [M:SRE0]SREDOOX + '.' - mess(609,196,1)
          Call OUINON(SZMESSX, IONREP2) From GESECRAN
          If IONREP2 = 2 Then
            [M:SRE0]SREDOO = ""
            [M:SRE0]SREDOOX = ""
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Retourne le code d'une affaire associé à une demande de service
#######################################################################
Subprog GETSREOPP(SZSRENUM, SZOPPNUM)
Value Char SZSRENUM
Variable Char SZOPPNUM

  SZOPPNUM = ""
  If SZSRENUM <> "" Then
    # FGR 04/12/2008 : Si on n'a pas de référence SRENUM il ne faut rien faire
    #                  Sinon on récupère la première affaire qui a un SRENUM vide.
    If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
    Filter [OPP] Where [F:OPP]OPPSRENUM = SZSRENUM Order By [F:OPP]OPPNUM Desc
    For [OPP]
      SZOPPNUM = [F:OPP]OPPNUM
      Break
    Next
    Filter [OPP]
  Endif
End

##########################################################################################################
# Création d'une mobilisation ou d'une consommation de points
######################################################################
Subprog CREPIT(SZSRENUM, ITPYFLG, SZCONNUM, SZBPC, SZMAC, SZPBL, SZHDT, SZHDTSEQ, IPIT, ISAT, IERRINF)
Value Char SZSRENUM
Value Integer ITPYFLG
Value Char SZCONNUM
Value Char SZBPC
Value Char SZMAC
Value Char SZPBL
Value Char SZHDT
Value Char SZHDTSEQ
Value Integer IPIT
Value Integer ISAT
Variable Integer IERRINF

Local Integer IPITCREATION
Local Integer IPITTYP
Local Char SZLOOP(100)
Local Integer ITRANSFLG

  IERRINF = 0
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:PCT]) : Local File PITCOUNT [PCT] : Endif
  #On détermine s'il s'agit d'un nouveau débit de point ou de la modification d'un débit existant.
  Read [PCT]PCT0=SZSRENUM;ITPYFLG;1;SZBPC;SZMAC;SZPBL;SZHDT;SZHDTSEQ
  If fstat Then
    IPITCREATION = 1
  Else
    IPITCREATION = 0
  Endif
  SZLOOP = SZSRENUM + num$(ITPYFLG) + "0" + SZBPC + SZMAC + SZPBL + SZHDT + SZHDTSEQ
  IPITTYP = 1
  #Détermine le type de points à générer
  If SZHDT <> "" Then
    IPITTYP = 2
  Endif
  If SZHDTSEQ <> "" Then
    IPITTYP = 2
  Endif
  If adxlog Then
    ITRANSFLG = 1
  Else
    ITRANSFLG = 0
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [PCT], [DVA]
  Endif
  Read [PCT]PCT0=SZSRENUM;ITPYFLG;0;SZBPC;SZMAC;SZPBL;SZHDT;SZHDTSEQ
  If fstat = 5 Then
    #Enregistrement non trouvé il faut le créer
    Gosub CREPIT_AFFCT_PCT
    [F:PCT]CREDAT = date$
    [F:PCT]CREUSR = GUSER
    Write [PCT]
    If fstat Then
      If ISAT = 2 Then
        #Erreur lors de l'enregistrement des points mobilisés.
        IERRINF = 505
      Else
        #Erreur lors de l'enregistrement des points consommés.
        IERRINF = 506
      Endif
    Endif
  Elsif fstat = 0 Then
    #Enregistrement trouvé il faut le mettre à jour
    Gosub CREPIT_AFFCT_PCT
    Rewrite [PCT]
    If fstat Then
      If ISAT = 2 Then
        #Erreur lors de l'enregistrement des points mobilisés.
        IERRINF = 505
      Else
        #Erreur lors de l'enregistrement des points consommés.
        IERRINF = 506
      Endif
    Endif
  Endif
  If IERRINF Then
    If !ITRANSFLG Then
      Rollback
    Endif
    End
  Endif
  #Enregistrement du contrôle des sessions
  Raz [F:DVA]
  [F:DVA]OBC = "PIT"
  [F:DVA]PARAM = SZLOOP
  If IPITCREATION <> 1 Then
    [F:DVA]ALHX(0) = "UPDATE"
  Endif
  [F:DVA]ALHX(1) = SZSRENUM
  [F:DVA]ALHX(2) = SZBPC
  [F:DVA]ALHX(3) = SZMAC
  [F:DVA]ALHX(4) = SZPBL
  [F:DVA]ALHX(5) = SZHDT
  [F:DVA]ALHX(6) = SZHDTSEQ
  [F:DVA]INTX(0) = adxuid(1)
  [F:DVA]INTX(1) = IPIT
  [F:DVA]INTX(2) = ITPYFLG
  [F:DVA]INTX(3) = IPITTYP
  Write [DVA]
  If !ITRANSFLG Then
    If IERRINF Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

#####################################################################
$CREPIT_AFFCT_PCT
  [F:PCT]SRENUM = SZSRENUM
  [F:PCT]TPYFLG = ITPYFLG
  [F:PCT]FGVCAH = 0
  [F:PCT]PITTYP = IPITTYP
  [F:PCT]CONNUM = SZCONNUM
  [F:PCT]BPC = SZBPC
  [F:PCT]MAC = SZMAC
  [F:PCT]PBL = SZPBL
  [F:PCT]HDT = SZHDT
  [F:PCT]HDTSEQ = SZHDTSEQ
  [F:PCT]PIT = IPIT
  [F:PCT]SAT = ISAT
  [F:PCT]LOO = SZLOOP
Return

##########################################################################################################
# Enregistrement des points mobilisés suite à la transaction de création de la demande
#####################################################################
Subprog SAVEHDTWKEY(SZCONTEXT, SZSCREEN, SZMESSAGE, IBRETOUR)
Value Char SZCONTEXT
Value Char SZSCREEN
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Integer ITESTERR
Local Integer ITER
Local Char SZHDTNUM
Local Char SZLOOP(100)

  #CHECK FILE_DECLARE PITCOUNT [PCT2]
  Raz SZMESSAGE
  IBRETOUR = 1
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  SZLOOP = ""
  ITER = 0
  SZHDTNUM = ""
  ITESTERR = 0
  #On récrée sur la base de l'ancien numéro de séquence
  If SZSCREEN = "SRE" Then
    If SZCONTEXT = "C" or SZCONTEXT = "D" Then
      Filter [PCT2] Where [F:PCT2]SRENUM = [M:SRE0]CRESEQ and [F:PCT2]TPYFLG = 1 and [F:PCT2]FGVCAH = 0 and [F:PCT2]HDTSEQ <> ""
    Else
      Filter [PCT2] Where [F:PCT2]SRENUM = [M:SRE0]SRENUM and [F:PCT2]TPYFLG = 0 and [F:PCT2]FGVCAH = 0 and [F:PCT2]HDTSEQ <> ""
    Endif
  Elsif SZSCREEN = "ITN" Then
    Filter [PCT2] Where [F:PCT2]SRENUM = [M:ITN0]SRVDEMNUM and [F:PCT2]TPYFLG = 0 and [F:PCT2]FGVCAH = 0 and [F:PCT2]HDTSEQ <> ""
  Endif
  For [PCT2]
    SZHDTNUM = ""
    If SZSCREEN = "SRE" Then
      If SZCONTEXT = "C" or SZCONTEXT = "D" Then
        #On recherche d'abord l'identifiant provenant d'un horodatage manuel saisi au cours de la création
        If [M:SRE0]HORHDTSEQ <> "" Then
          If [M:SRE0]HORHDTSEQ = [F:PCT2]HDTSEQ Then
            SZHDTNUM = [M:SRE0]HORHDTNUM
          Endif
        Endif
      Endif
      #Obtient le numéro définitif de la consommation
      If SZHDTNUM = "" Then
        For ITER = 0 To [M:SRE9]NBLIG-1
          If [M:SRE9]HDTNUMSEQ(ITER) = [F:PCT2]HDTSEQ Then
            SZHDTNUM = [M:SRE9]HDTNUM(ITER)
            Break
          Endif
        Next
      Endif
    Elsif SZSCREEN = "ITN" Then
      #Obtient le numéro définitif de la consommation
      For ITER = 0 To [M:ITN8]NBLIG-1
        If [M:ITN8]HDTNUMSEQ(ITER) = [F:PCT2]HDTSEQ Then
          SZHDTNUM = [M:ITN8]HDTNUM(ITER)
          Break
        Endif
      Next
    Endif
    If SZHDTNUM = "" Then
      ITESTERR = 1
      Break
    Endif
    [F:PCT] = [F:PCT2]
    [F:PCT]HDT = SZHDTNUM
    [F:PCT]HDTSEQ = ""
    [F:PCT]CREDAT = date$
    [F:PCT]CREUSR = GUSER
    SZLOOP = [F:PCT]SRENUM + num$([F:PCT]TPYFLG) + num$([F:PCT]FGVCAH) + [F:PCT]BPC + [F:PCT]MAC + [F:PCT]PBL + [F:PCT]HDT + [F:PCT]HDTSEQ
    [F:PCT]LOO = SZLOOP
    Write [PCT]
    If fstat <> 0 Then
      ITESTERR = 1
      Break
    Endif
  Next
  If ITESTERR Then
    #Erreur lors de l'enregistrement des points mobilisés ou consommés.
    SZMESSAGE = mess(507,182,1)
    IBRETOUR = 0
    GOK = 0
    End
  Endif
  #On efface tout
  If SZSCREEN = "SRE" Then
    If SZCONTEXT = "C" or SZCONTEXT = "D" Then
      Delete [PCT2] Where [F:PCT2]SRENUM = [M:SRE0]CRESEQ and [F:PCT2]TPYFLG = 1 and [F:PCT2]FGVCAH = 0 and [F:PCT2]HDTSEQ <> ""
    Else
      Delete [PCT2] Where [F:PCT2]SRENUM = [M:SRE0]SRENUM and [F:PCT2]TPYFLG = 0 and [F:PCT2]FGVCAH = 0 and [F:PCT2]HDTSEQ <> ""
    Endif
  Elsif SZSCREEN = "ITN" Then
    Delete [PCT2] Where [F:PCT2]SRENUM = [M:ITN0]SRVDEMNUM and [F:PCT2]TPYFLG = 0 and [F:PCT2]FGVCAH = 0 and [F:PCT2]HDTSEQ <> ""
  Endif
  If fstat <> 0 Then
    #Erreur lors de l'enregistrement des points mobilisés ou consommés.
    SZMESSAGE = mess(507,182,1)
    IBRETOUR = 0
    GOK = 0
  Endif
End

##########################################################################################################
# Enregistrement des points mobilisés suite à la transaction de création de la demande
#####################################################################
Subprog SAVEPITWKEY(SZSEQNUM, SZSRENUM, SZMESSAGE, IBRETOUR)
Value Char SZSEQNUM
Value Char SZSRENUM
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Integer ITESTERR
Local Char SZLOOP(100)

  #CHECK FILE_DECLARE PITCOUNT [PCT2]
  Raz SZMESSAGE
  IBRETOUR = 1
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  SZLOOP = ""
  ITESTERR = 0
  #On récrée sur la base de l'ancien numéro de séquence
  Filter [PCT2] Where [F:PCT2]SRENUM = SZSEQNUM and [F:PCT2]TPYFLG = 1 and [F:PCT2]FGVCAH = 0
  For [PCT2]
    [F:PCT] = [F:PCT2]
    [F:PCT]SRENUM = SZSRENUM
    [F:PCT]TPYFLG = 0
    [F:PCT]CREDAT = date$
    [F:PCT]CREUSR = GUSER
    SZLOOP = [F:PCT]SRENUM + num$([F:PCT]TPYFLG) + num$([F:PCT]FGVCAH) + [F:PCT]BPC + [F:PCT]MAC + [F:PCT]PBL + [F:PCT]HDT + [F:PCT]HDTSEQ
    [F:PCT]LOO = SZLOOP
    Write [PCT]
    If fstat <> 0 Then
      ITESTERR = 1
      Break
    Endif
  Next
  If ITESTERR Then
    #Erreur lors de l'enregistrement des points mobilisés ou consommés.
    SZMESSAGE = mess(507,182,1)
    IBRETOUR = 0
    GOK = 0
    End
  Endif
  #On efface tout
  Delete [PCT2] Where [F:PCT2]SRENUM = SZSEQNUM and [F:PCT2]TPYFLG = 1 and [F:PCT2]FGVCAH = 0
  If fstat <> 0 Then
    #Erreur lors de l'enregistrement des points mobilisés ou consommés.
    SZMESSAGE = mess(507,182,1)
    IBRETOUR = 0
    GOK = 0
  Endif
End

##########################################################################################################
# Sélection d'un modèle de contrat de service pour assurer la couverture globale d'une demande de service
# (Pas utilisé)
#########################################################################
$SELECTCOT
  If type(GSZSRECXT) > 0 Then
    If GSZSRECXT = "OVRCOVCON" Then
      If type(GSZSRECON) > 0 Then
        If GSZSRECON <> [M:COT0]CONNUM Then
          If [M:COT0]CONNUM <> "" Then
            If [M:SRE2]SREASS < 4 Then
              If [M:SRE2]OVRCOV = 4 Then
                If [M:SRE0]SREGREP = "" and [M:SRE0]SRENUM = "" Then
                  Return
                Else
                  Gosub SLTCOT
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$SLTCOT
Local Integer ISREASK

  #Demande si on doit modifier le contrat couvrant la demande.
  ISREASK = 0
  #Souhaitez-vous couvrir la demande de service avec le nouveau contrat de prêt sélectionné ?
  Call OUINON(mess(504,182,1), ISREASK) From GESECRAN
  If ISREASK = 2 Then
    #On modifie le contrat couvrant la demande.
    Call DEBTRANS From GLOCK
    Trbegin [SRE]
    Read [SRE]SRE0=[M:SRE0]SRENUM
    If fstat Then
      Rollback
      #Erreur lors de la modification du contrat couvrant la demande de service. Transaction abandonnée.
      GMESSAGE = mess(829,196,1)
      GERR = 1
    Else
      [F:SRE]OVRCOVTYP = "COT"
      [F:SRE]SRECOVNUM = [M:COT0]CONNUM
      [F:SRE]SRECOVAUT = 0
      [F:SRE]CONSPT = [M:COT0]CONNUM
      [F:SRE]CONSPTTYP = "COT"
      [F:SRE]CONSPTFLG = 1
      [F:SRE]MANUPD = 2
      #Obtient le niveau de réactivité SAV.
      Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:COT0]CONNUM, "COT", [M:SRE2]SREGRALEV, 0, [F:SRE]SRERESDAT, [F:SRE]SRERESHOU) From TRTCOVER
      Rewrite [SRE]
      If fstat Then
        Rollback
        #Erreur lors de la modification du contrat couvrant la demande de service.
        GMESSAGE = mess(829,196,1)
        GERR = 1
      Else
        Commit
      Endif
      [M:SRE2]OVRCOVTYP = "COT"
      [M:SRE2]SRECOVNUM = [M:COT0]CONNUM
      [M:SRE2]SRECOVAUT = 0
      #Contrat défini manuellement.
      [M:SRE2]CONSPTCLA = mess(302,182,1)
      [M:SRE2]CONSPT = [M:COT0]CONNUM
      [M:SRE2]CONSPTTYP = "COT"
      [M:SRE2]CONSPTFLG = 1
      [M:SRE2]MANUPD = 2
      #Obtient le niveau de réactivité SAV.
      Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:COT0]CONNUM, "COT", [M:SRE2]SREGRALEV, 1, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
      GSZSRECXT = ""
      Gosub AFFSRE2MIS From SUBSREB2
      Affzo [M:SRE2]1-99
    Endif
  Endif
Return

