#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(10)(1..2), VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CPTINTCPY","FCPTINTCPY",4,"") From GTRAITE
End

#######################################################
## Process actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

#######################################################
$DEBUT
Affzo [DIA]
Call DEBUT(GUSER) From CPTTRT
Setmok [DIA] With 0
Return

##############################################################################
$OUVRE
Gosub OUVFIC

Local Integer  OK, STAT, MORT
Local Char     CRITERE(250), MESSA(250), SYMBOLE(30)
Local Char     COMPANY(GLONCPY)

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Local Mask  CPTINTCPY   [DIA]
Local Mask GACCENT0 [HAE0], GACCENT1 [HAE1], GACCENT2 [HAE2], VENTILE  [VTL], VENTILE2 [VT2]


TIT = mess(328,107,1) : # Intercompany journal creation

Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","cptint") From GMEMO
Return


##############################################################################
$OUVFIC
If clalev([F:GAU])=0  : Local File GAUTACE     [GAU]  : Endif
If clalev([F:GAD])=0  : Local File GAUTACED    [GAD]  : Endif
If clalev([F:GAG])=0  : Local File GAUTACEF    [GAG]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY     [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY    [FCY]  : Endif
If clalev([F:GCM])=0  : Local File GACM        [GCM]  : Endif
If clalev([F:COA])=0  : Local File GCOA        [COA]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT    [GAC]  : Endif
If clalev([F:DIE])=0  : Local File GDIE        [DIE]  : Endif
If clalev([F:CCE])=0  : Local File CACCE       [CCE]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR      [TCU]  : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT  [GTE]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR  [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD      [PER]  : Endif
If clalev([F:BPR])=0  : Local File BPARTNER    [BPR]  : Endif
If clalev([F:TUN])=0  : Local File TABUNIT     [TUN]  : Endif
If clalev([F:DSP])=0  : Local File CADSP       [DSP]  : Endif
If clalev([F:AUZ])=0  : Local File CAAUZ       [AUZ]  : Endif
If clalev([F:ANM])=0  : Local File ACODNUM     [ANM]  : Endif
If clalev([F:AVN])=0  : Local File AVALNUM     [AVN]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV     [ADI]  : Endif
If clalev([F:GIC])=0  : Local File GACCINTCPY  [GIC]  : Endif
If clalev([F:GID])=0  : Local File GACCINTCPYD [GID]  : Endif
If clalev([F:GIA])=0  : Local File GACCINTCPYA [GIA]  : Endif
If clalev([F:ICF])=0  : Local File INTCOFLO    [ICF]  : Endif
If clalev([F:CPY2])=0 : Local File COMPANY     [CPY2] : Endif
If clalev([F:GDE])=0  : Local File GDIAENTRY   [GDE]  : Endif
If clalev([F:GDD])=0  : Local File GDIAENTRYD  [GDD]  : Endif
If clalev([F:PBS])=0  : Local File GAPARBSE    [PBS]  : Endif
If clalev([F:JOU])=0  : Local File GJOURNAL    [JOU]  : Endif
If clalev([F:JST])=0  : Local File GAJOUSTA    [JST]  : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY   [HAE]  : Endif
If clalev([F:HA2])=0  : Local File GACCENTRY   [HA2]  : Endif
Return

##############################################################################
$SEL_TABLE
Case COUZON
 When "STRVCR", "ENDVCR"
  OBJET = "GIC" : Gosub SELGIC
Endcase
Return

$SELGIC
CRITERE = 'FLGPST<>3'
If [M:DIA]ALLCPY<>2
 CRITERE -= '& CPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= '& FCY = "'+[M:DIA]FCY+'"'
Endif
Return

##############################################################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
Endif

If FIN : Return : Endif
If [M:DIA]TYP=1 : Call AVERTDGI([M:DIA]ALLCPY,[M:DIA]CPY,1,FIN) From CPTDIV2 : Endif
If FIN : Return : Endif

If [M:DIA]TYP<3
 Call PRESENCE(MORT) From CPTBATCH
 If MORT
  GERR = 1 : FIN = 1 : GMESSAGE = mess(49,134,1)
 Endif
Endif
If FIN : Return : Endif

If [M:DIA]ALLCPY=2
 COMPANY = ""
Else
 COMPANY = [M:DIA]CPY
Endif
Call LOCKCPY(COMPANY,OK) From AX3MONO
If !OK : FIN=1 : Endif
Return


##############################################################################
$EXEC
If GSERVEUR
 [M:DIA]TRACE = 2
Endif

If !GSERVEUR & [M:DIA]TRACE=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRACE=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

CRITERE = "FLGPST<>3"
If [M:DIA]ALLFCY<>2
 CRITERE -= '& FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]STRDAT<>[0/0/0]
 CRITERE -= "& ACCDAT>=["+format$(GFMD,[M:DIA]STRDAT)+"]"
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITERE -= "& ACCDAT<=["+format$(GFMD,[M:DIA]ENDDAT)+"]"
Endif
If [M:DIA]STRVCR<>""
 CRITERE -= '& NUM>="'+[M:DIA]STRVCR+'"'
Endif
If [M:DIA]ENDVCR<>""
 CRITERE -= '& NUM<="'+[M:DIA]ENDVCR+'"'
Endif
If [M:DIA]ALLUSR<>2
 CRITERE -= '& (UPDUSR="'+[M:DIA]USR+'" | (UPDUSR="" & CREUSR="'+[M:DIA]USR+'"))'
Endif

For [CPY2] Where ([M:DIA]ALLCPY=2 | CPY=[M:DIA]CPY) & CPYLEGFLG=2 & LEG=GCURLEG
 COMPANY= [F:CPY2]CPY
 If GTRACE<>""
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(mess(2,45,1)-COMPANY-":",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Endif
 Gosub TRT_GIC
Next

If !GSERVEUR & [M:DIA]TRACE=2
 Call FERME_TRACE From LECFIC
Endif
Return

$TRT_GIC
For [GIC] Where evalue(CRITERE) & CPY=COMPANY
 Gosub TRTVALGIC
 If GTRACE<>""
  Call ECR_TRACE("",0) From GESECRAN
 Endif
Next
Return


$TRTVALGIC
OK = 1 : mkstat=0
Call CONTFCY([F:GIC]FCY) From CPTSUB
If mkstat : OK = 0 : Endif
If OK
 SYMBOLE = "GIC"+[F:GIC]NUM
 Lock =SYMBOLE With lockwait=0
 If fstat=1
  If GTRACE<>"" : Call ECR_TRACE([F:GIC]NUM-mess(10,100,1),1) From GESECRAN : Endif
 Else
  If GTRACE<>"" Call ECR_TRACE(mess(333,107,1)-[F:GIC]NUM-":",0) From GESECRAN : Endif
  ## Note : The VALID Subprogram
  ##            - Deletes the eventual simulations
  ##            - Creates the right journals on the source company + target company for the current template journal
  ##            - Displays in the log file the journals generated for the current template journal

  #Issue X3-76846 by MRDAB
  If [M:DIA]TYP = 1
    Local Tinyint LTYPGEN, LTYPANA
    For [F:GID]GID0 Where [F:GID]NUM = [F:GIC]NUM
      If (func AFNC.ACTIV("FIFRC") & [F:GIC]NUM <> '')
        If (func AFNC.PARAM("FIFRC", [F:GID]FCYLIN) = "2")
          Call SETMAINREF([F:GID]CPYLIN, [L]LTYPGEN, [L]LTYPANA) From CPTDIV
          If (func FIFOCONVAR_CSTD.IS_ACC_ASSIGNED_TO_FIFO_BANK([F:GID]ACC([L]LTYPGEN - 1)) = 0) and
&            (func FIFOCONVAR_CSTD.DOES_FIFO_EXIST_FOR_ACC_CPY_DATE([F:GID]ACC([L]LTYPGEN - 1), [F:GID]CPYLIN, [F:GIC]ACCDAT) = 0)
            If ([F:GID]LEDTYP = [L]LTYPGEN)
              If GTRACE <> ""
                Call ECR_TRACE([F:GID]TYPLIN - [F:GIC]NUM - [F:GID]CPYLIN + ":", 0) From GESECRAN
                Call ECR_TRACE(mess(12,7708,1), 1) From GESECRAN
              Endif
              OK = 0 : Break
            Endif
          Endif
        Endif
      Endif
    Next
  Endif

  If OK
    Call VALID([F:GIC]NUM) From GICVAL
  Endif
  #Issue end

  Unlock =SYMBOLE
 Endif
Endif
Return


#######################################################
$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If !GSERVEUR & [M:DIA]TRACE=2
 TRA = 1
Else
 TRA = 0
Endif
Return


#######################################################
$SORTIE
Call UNLOCKCPY() From AX3MONO
Return


#######################################################
$ERREUR
Call ECR_TRACE(MESSA,1) From GESECRAN
Return


#######################################################
# Screen field actions
#######################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY, FCY : Grizo CPY, FCY
 [M]ALLFCY=2 : Affzo ALLFCY : Grizo ALLFCY
 If dim([M]LEG)>0 : Actzo LEG : Endif
Else
 Actzo CPY, ALLFCY
 If dim([M]LEG)>0  & [M]CPY = "" : Effzo LEG : Grizo LEG : Endif
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY=2 : mkstat = 1 : End : Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
Call AS_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR)From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
Call AS_FCY(VALEUR) From CPTTRT
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR
Call C_FCY(VALEUR) From CPTTRT
End

Subprog AS_USR(VALEUR)
Variable Char     VALEUR
If [M]ALLUSR = 2 : mkstat = 1 : End : Endif
If VALEUR=""
 VALEUR = GUSER
Endif
End


Subprog AS_ENDVCR(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]STRVCR : VALEUR=[M]STRVCR : Endif
End

Subprog C_ENDVCR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]STRVCR
 # End range is less than Start range
 GMESSAGE = mess(44,199,1)
 mkstat = 1 : End
Endif
End

Subprog AS_STRDAT(VALEUR)
Variable Date     VALEUR
Call AS_STRDAT(VALEUR) From CPTTRT
End

Subprog D_STRDAT(VALEUR)
Variable Date VALEUR
Call D_STRDAT(VALEUR) From CPTTRT
End


Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE
End

$GRISE
If [M]ALLCPY=2
 [M]CPY = "" : [M]FCY = ""
 Grizo CPY, FCY
 [M]ALLFCY=2 : Affzo ALLFCY : Grizo ALLFCY
Else
 Actzo CPY, ALLFCY
Endif
If [M]ALLFCY=2 : [M]FCY = "" : Grizo FCY : Else : Actzo FCY : Endif
If [M]ALLUSR=2 : [M]USR = "" : Affzo USR : Grizo USR : Else : Actzo USR : Endif
Return


Subprog C_ALLUSR(VALEUR)
Variable Integer VALEUR
Call C_ALLUSR(VALEUR) From CPTTRT
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>1 : [M]STA = 1 : Grizo STA : Else : Actzo STA : Endif
If VALEUR = 1
 If [M]CPY<>"" & func AFNC.PARAM("FRADGI",[M]CPY)="2"
  [M]STA = 2 : Grizo STA
 Else
  [M]STA = 1 : Actzo STA
 Endif
Endif
End

Subprog AS_STA(VALEUR)
Variable Integer VALEUR
If [M]CPY<>"" & func AFNC.PARAM("FRADGI",[M]CPY)="2" & [M]TYP=1
 VALEUR = 2 : mkstat = 2 : End
Endif
If VALEUR=0 : VALEUR = 1 : Endif
End

