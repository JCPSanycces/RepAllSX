# Classe PHYBUI

$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
       When "AQUERY_TRANS_AFTER"          : Gosub AQUERY_TRANS_AFTER
       When Default                       : Gosub METHODS From PHYBUI_C_MPR
    Endcase
Endcase

Return

$METHODS
Return
#
$OPERATIONS
Return

$PROPERTIES
#
#  Case [L]CURPRO
#    Endcase
##
Return

# -------------------------------------
# PHYBUI standard data class methods
# -------------------------------------
$AQUERY_TRANS_AFTER
 ASTATUS = func _FILL_QUERY_PROPERTIES(this, this.BUI.BUICOD, this.BUI.BPAADD)
Return

# -------------------------------------
Funprog _FILL_QUERY_PROPERTIES(PREPQUERY, PBUICOD, PBPAADD)
#* This function fill representation properties for default adress . These properties
#* can be available on the query facet as technical properties and used with the office plugin.
#* #*
#* @param PREPQUERY Instance of the representation to be enriched
#* @param PBPRNUM   Building code
#* @param PBPAADD   Default address building
#*
#* @return LRET     Return value
#*
#* @private
#*!
Variable Instance PREPQUERY Using OBJECT
Const    Char     PBUICOD
Const    Char     PBPAADD
Local Integer     LRET

  # Additionnal technical properties in the query coming from default address
    Local File BPADDRESS [BPA]
    Filter [F:BPA] Where BPATYP=7 and BPANUM=PBUICOD and BPAADDFLG=2
      Read [F:BPA]First
      If !fstat
        PREPQUERY.BUIPOSCOD      =  [F:BPA]POSCOD
        PREPQUERY.BUIADDLIG1     =  [F:BPA]BPAADDLIG(0)
        PREPQUERY.BUICTY         =  [F:BPA]CTY
        PREPQUERY.BUISAT         =  [F:BPA]SAT
        PREPQUERY.BUICRY         =  [F:BPA]CRY
      Endif
    Filter[F:BPA]
End LRET

