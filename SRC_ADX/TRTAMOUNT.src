      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(ICSMTYP), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #---------------------------------------------------#
