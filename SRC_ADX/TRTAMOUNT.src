##########################################################################################################
# Calcul d'un montant pour une couverture financière non listée.
##############################################################
$CPTINV
Local Decimal ISHOULDINV
Local Decimal ISHOULD2INV
Local Decimal IFULLCSM
Local Decimal ITPYAMT
Local Decimal ITPYAMT2
Local Decimal IFRANCTOADD
Local Decimal INOTAMT

  ISHOULDINV = 0
  ISHOULD2INV = 0
  IFRANCTOADD = 0
  INOTAMT = 0
  ITPYAMT = 0
  ITPYAMT2 = 0
  IFULLCSM = ICSMCSM + IAMT
  IPARTRECFOUND += 1
  #Calcul du montant facturable total trans-ligne
  If IICDFLG = 2 Then
    #Inclusion
    If ICCVHEIPRC <= 0 Then
      ISHOULDINV = IFULLCSM
    Elsif ICCVHEIPRC >= 100 Then
      ISHOULDINV = 0
    Else
      ISHOULDINV = IFULLCSM * (ICCVHEIPRC / 100)
    Endif
  Else
    #Exclusion
    If ICCVHEIPRC <= 0 Then
      ISHOULDINV = 0
    Elsif ICCVHEIPRC >= 100 Then
      ISHOULDINV = IFULLCSM
    Else
      INOTAMT = IFULLCSM * (ICCVHEIPRC / 100)
      ISHOULDINV = IFULLCSM - INOTAMT
    Endif
  Endif
  #Gestion de la franchise
  If ICCVMINCOV > ISHOULDINV Then
    ISHOULDINV = ICCVMINCOV
  Endif
  If ISHOULDINV <= ICSMINV Then
    If IICDFLG = 2 Then
      #Inclusion
      If ICCVHEIPRC <= 0 Then
        IAMTINV = IAMT
      Elsif ICCVHEIPRC >= 100 Then
        IAMTINV = 0
      Else
        IAMTINV = IAMT * (ICCVHEIPRC / 100)
      Endif
    Else
      #Exclusion
      If ICCVHEIPRC <= 0 Then
        IAMTINV = 0
      Elsif ICCVHEIPRC >= 100 Then
        IAMTINV = IAMT
      Else
        INOTAMT = IAMT * (ICCVHEIPRC / 100)
        IAMTINV = IAMT - INOTAMT
      Endif
    Endif
  Else
    IAMTINV = ISHOULDINV - ICSMINV
  Endif
  If IAMTINV <= 0 Then
    IAMTINV = 0
    IINV = 1
    ISOLVED = 1
    Return
  Endif
  If ICCVMAXCOV <= 0 Then
    ISOLVED = 1
    Return
  Endif
  #Gestion du montant maximum de prise en charge
  ITPYAMT2 = IFULLCSM - ICCVMAXCOV
  If IFULLCSM > ICCVMAXCOV Then
    If IICDFLG = 2 Then
      #Inclusion
      If ICCVHEIPRC <= 0 Then
        ITPYAMT = ICCVMAXCOV
      Elsif ICCVHEIPRC >= 100 Then
        ITPYAMT = 0
      Else
        ITPYAMT = ICCVMAXCOV * (ICCVHEIPRC / 100)
      Endif
    Else
      #Exclusion
      If ICCVHEIPRC <= 0 Then
        ITPYAMT = 0
      Elsif ICCVHEIPRC >= 100 Then
        ITPYAMT = ICCVMAXCOV
      Else
        INOTAMT = ICCVMAXCOV * (ICCVHEIPRC / 100)
        ITPYAMT = ICCVMAXCOV - INOTAMT
      Endif
    Endif
    ISHOULD2INV = ITPYAMT + ITPYAMT2
    IAMTINV = ISHOULD2INV - ICSMINV
  Endif
  If IAMTINV <= 0 Then
    IAMTINV = 0
    IINV = 1
  Else
    IINV = 2
  Endif
  ISOLVED = 1
Return

##########################################################################################################
# Ajoute ou enlève des points sur les consommations relatives au même code article consommé et au même parc concerné
############################################################################
Subprog REMORADDPIT(SZCONTEXT, INOL, SZBPC, SZCON, SZDEFMACPIT, SZMACFORPIT, SZCPNFORPIT, SZITMFORPIT, INBRPIT, IDEBFRY, SZDEBFRYBAS, IPIT, IERRINF)
Value Char SZCONTEXT
Value Integer INOL
Value Char SZBPC
Value Char SZCON
Value Char SZDEFMACPIT
Value Char SZMACFORPIT
Value Char SZCPNFORPIT
Value Char SZITMFORPIT
Value Integer INBRPIT
Value Decimal IDEBFRY
Value Char SZDEBFRYBAS
Variable Decimal IPIT
Variable Integer IERRINF

Local Char SZHDTSEQ
Local Char SZSRESEQ
Local Char SZSRENUM
Local Char SZITN8HDTNUM
Local Integer IINC_IN_ITN8
Local Integer IDELTAPIT
Local Integer IREMOVEDPIT
Local Integer ICPLPIT
Local Decimal DCBCNVQTY
Local Decimal DCBCOEFUOM
Local Decimal DCBCUMQTY
Local Integer ICUMPIT
Local Integer ISHOULDPIT
Local Char SZHDTLINECTL(100)
Local Char SZMACLINECTL(100)
Local Char SZSREDEFMAC
Local Integer ITER
Local Integer ISAVEINOL
Local Integer ISAVEIPIT
Local Char SZSAVECONTEXT
Local Integer ITRANSLINEPIT
Local Integer ISECONDLOOP

  IERRINF = 0
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  ISECONDLOOP = 1
  ITRANSLINEPIT = 1
  IINC_IN_ITN8 = 0
  ITER = 0
  SZSRENUM = ""
  SZSRESEQ = ""
  SZHDTSEQ = ""
  SZITN8HDTNUM = ""
  SZSREDEFMAC = ""
  SZHDTLINECTL = ""
  SZMACLINECTL = ""
  DCBCUMQTY = 0
  ICUMPIT = 0
  DCBCOEFUOM = 0
  DCBCNVQTY = 0
  ISHOULDPIT = 0
  ICPLPIT = 0
  IREMOVEDPIT = 0
  IDELTAPIT = 0
  ISAVEINOL = INOL
  ISAVEIPIT = IPIT
  SZSAVECONTEXT = SZCONTEXT
  If SZCONTEXT = "SRE9" Then
    #On recherche le nom du parc par défaut
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]MAC(ITER) <> "" Then
        If [M:SRE7]MACDEF(ITER) = 2 Then
          SZSREDEFMAC = [M:SRE7]MAC(ITER)
          Break
        Endif
      Endif
    Next
    If SZSREDEFMAC = "" Then
      SZHDTLINECTL = "---" + SZITMFORPIT + "-"
    Else
      If SZMACFORPIT = "" Then
        SZHDTLINECTL = "-" + SZSREDEFMAC + "-" + SZCPNFORPIT + "-" + SZITMFORPIT + "-"
      Else
        SZHDTLINECTL = "-" + SZMACFORPIT + "-" + SZCPNFORPIT + "-" + SZITMFORPIT + "-"
      Endif
    Endif
    For ITER = 0 To dim([M:SRE9]HDTITM)-1
      If [M:SRE9]HDTITM(ITER) <> "" Then
        If SZSREDEFMAC = "" Then
          SZMACLINECTL = "---" + [M:SRE9]HDTITM(ITER) + "-"
        Else
          If [M:SRE9]HDTMACSRE(ITER) = "" Then
            SZMACLINECTL = "-" + SZSREDEFMAC + "-" + [M:SRE9]HDTCPN(ITER) + "-" + [M:SRE9]HDTITM(ITER) + "-"
          Else
            SZMACLINECTL = "-" + [M:SRE9]HDTMACSRE(ITER) + "-" + [M:SRE9]HDTCPN(ITER) + "-" + [M:SRE9]HDTITM(ITER) + "-"
          Endif
        Endif
        If SZHDTLINECTL = SZMACLINECTL Then
          If [M:SRE9]INVPITFLG(ITER) Then
            If [M:SRE9]HDTUOM(ITER) = SZDEBFRYBAS Then
              #Pas de conversion à effectuer
              DCBCUMQTY += [M:SRE9]HDTQTY(ITER)
            Else
              #Conversion nécesaire
              Read [ITM]ITM0=[M:SRE9]HDTITM(ITER)
              If fstat Then
                #L'article concerné par la consommation n'a pas pu être lue.
                # Le calcul du montant facturable est abandonné.
                IERRINF = 546
                Break
              Else
                #Calcul de la quantité consommée en unité de stock
                Call SREC_COE([M:SRE9]HDTITM(ITER), SZBPC, SZDEBFRYBAS, [M:SRE9]HDTUOM(ITER), DCBCOEFUOM) From TRTVENQTE
                DCBCNVQTY = [M:SRE9]HDTQTY(ITER) * DCBCOEFUOM
                DCBCUMQTY += DCBCNVQTY
              Endif
            Endif
            ICUMPIT += [M:SRE9]PITHDT(ITER)
          Endif
        Endif
      Endif
      If IERRINF Then
        Break
      Endif
    Next
    If IERRINF Then
      End
    Endif
    #Calcul du nombre de points qui devraient être débités
    If IDEBFRY <= 0 Then
      ISHOULDPIT = 0
    Else
      ISHOULDPIT = (INBRPIT * DCBCUMQTY) / IDEBFRY
    Endif
    If ICUMPIT = ISHOULDPIT Then
      End
    Endif
    #Traitement de l'ajout de points complémentaires.
    If ICUMPIT < ISHOULDPIT Then
      ICPLPIT = ISHOULDPIT - ICUMPIT
      IPIT += ICPLPIT
      Gosub CSMPIT
    Endif
    #Traitement de la suppression de points excédentaires
    If ICUMPIT > ISHOULDPIT Then
      ICPLPIT = ICUMPIT - ISHOULDPIT
      IREMOVEDPIT = 0
      If IPIT > 0 Then
        If IPIT >= ICPLPIT Then
          IPIT -= ICPLPIT
          IREMOVEDPIT += ICPLPIT
        Else
          IREMOVEDPIT += IPIT
          IPIT = 0
        Endif
        Gosub CSMPIT
      Endif
      If IREMOVEDPIT < ICPLPIT Then
        ISAVEIPIT = IPIT
        ISAVEINOL = INOL
        For INOL = 0 To dim([M:SRE9]HDTITM)-1
          If [M:SRE9]HDTITM(INOL) <> "" Then
            If [M:SRE9]PITHDT(INOL) > 0 Then
              If SZSREDEFMAC = "" Then
                SZMACLINECTL = "---" + [M:SRE9]HDTITM(INOL) + "-"
              Else
                If [M:SRE9]HDTMACSRE(INOL) = "" Then
                  SZMACLINECTL = "-" + SZSREDEFMAC + "-" + [M:SRE9]HDTCPN(INOL) + "-" + [M:SRE9]HDTITM(INOL) + "-"
                Else
                  SZMACLINECTL = "-" + [M:SRE9]HDTMACSRE(INOL) + "-" + [M:SRE9]HDTCPN(INOL) + "-" + [M:SRE9]HDTITM(INOL) + "-"
                Endif
              Endif
              If SZHDTLINECTL = SZMACLINECTL Then
                If [M:SRE9]INVPITFLG(INOL) Then
                  IDELTAPIT = ICPLPIT - IREMOVEDPIT
                  If [M:SRE9]PITHDT(INOL) >= IDELTAPIT Then
                    [M:SRE9]PITHDT(INOL) -= IDELTAPIT
                    IREMOVEDPIT += IDELTAPIT
                  Else
                    IREMOVEDPIT += [M:SRE9]PITHDT(INOL)
                    [M:SRE9]PITHDT(INOL) = 0
                  Endif
                  IPIT = [M:SRE9]PITHDT(INOL)
                  Gosub CSMPIT
                Endif
              Endif
            Endif
          Endif
          If IREMOVEDPIT >= ICPLPIT Then
            Break
          Endif
        Next
        INOL = ISAVEINOL
        IPIT = ISAVEIPIT
      Endif
    Endif
  Elsif SZCONTEXT = "ITN8" Then
    SZSREDEFMAC = SZDEFMACPIT
    If SZSREDEFMAC = "" Then
      SZHDTLINECTL = "---" + SZITMFORPIT + "-"
    Else
      If SZMACFORPIT = "" Then
        SZHDTLINECTL = "-" + SZSREDEFMAC + "-" + SZCPNFORPIT + "-" + SZITMFORPIT + "-"
      Else
        SZHDTLINECTL = "-" + SZMACFORPIT + "-" + SZCPNFORPIT + "-" + SZITMFORPIT + "-"
      Endif
    Endif
    #Calcul des éléments cumulés avec le tableau ITN8
    For ITER = 0 To dim([M:ITN8]HDTITM)-1
      If [M:ITN8]HDTITM(ITER) <> "" Then
        If SZSREDEFMAC = "" Then
          SZMACLINECTL = "---" + [M:ITN8]HDTITM(ITER) + "-"
        Else
          If [M:ITN8]HDTMACSRE(ITER) = "" Then
            SZMACLINECTL = "-" + SZSREDEFMAC + "-" + [M:ITN8]HDTCPN(ITER) + "-" + [M:ITN8]HDTITM(ITER) + "-"
          Else
            SZMACLINECTL = "-" + [M:ITN8]HDTMACSRE(ITER) + "-" + [M:ITN8]HDTCPN(ITER) + "-" + [M:ITN8]HDTITM(ITER) + "-"
          Endif
        Endif
        If SZHDTLINECTL = SZMACLINECTL Then
          If [M:ITN8]INVPITFLG(ITER) Then
            If [M:ITN8]HDTUOM(ITER) = SZDEBFRYBAS Then
              #Pas de conversion à effectuer
              DCBCUMQTY += [M:ITN8]HDTQTY(ITER)
            Else
              #Conversion nécesaire
              Read [ITM]ITM0=[M:ITN8]HDTITM(ITER)
              If fstat Then
                #L'article concerné par la consommation n'a pas pu être lue.
                # Le calcul du montant facturable est abandonné.
                IERRINF = 546
                Break
              Else
                #Calcul de la quantité consommée en unité de stock
                Call SREC_COE([M:ITN8]HDTITM(ITER), SZBPC, SZDEBFRYBAS, [M:ITN8]HDTUOM(ITER), DCBCOEFUOM) From TRTVENQTE
                DCBCNVQTY = [M:ITN8]HDTQTY(ITER) * DCBCOEFUOM
                DCBCUMQTY += DCBCNVQTY
              Endif
            Endif
            ICUMPIT += [M:ITN8]PITHDT(ITER)
          Endif
        Endif
      Endif
      If IERRINF Then
        Break
      Endif
    Next
    If IERRINF Then
      End
    Endif
    #On complète le cumul avec les consommations restées sur la demande de service
    Filter [HDT] Where [F:HDT]SRENUM = [M:ITN0]SRVDEMNUM and [F:HDT]TPL <> 2
    For [HDT] HDT1
      If [F:HDT]HDTITM <> "" Then
        If [F:HDT]HDTNUM <> "" Then
          If SZSREDEFMAC = "" Then
            SZMACLINECTL = "---" + [F:HDT]HDTITM + "-"
          Else
            If [F:HDT]HDTMACSRE = "" Then
              SZMACLINECTL = "-" + SZSREDEFMAC + "-" + [F:HDT]HDTCPN + "-" + [F:HDT]HDTITM + "-"
            Else
              SZMACLINECTL = "-" + [F:HDT]HDTMACSRE + "-" + [F:HDT]HDTCPN + "-" + [F:HDT]HDTITM + "-"
            Endif
          Endif
          If SZHDTLINECTL = SZMACLINECTL Then
            If [F:HDT]INVPITFLG Then
              IINC_IN_ITN8 = 1
              For ITER = 0 To dim([M:ITN8]HDTITM)-1
                If [M:ITN8]HDTITM(ITER) <> "" Then
                  If [M:ITN8]HDTNUM(ITER) <> "" Then
                    If [M:ITN8]HDTNUM(ITER) = [F:HDT]HDTNUM Then
                      IINC_IN_ITN8 = 0
                      Break
                    Endif
                  Endif
                Endif
              Next
              If IINC_IN_ITN8 Then
                If [F:HDT]HDTUOM = SZDEBFRYBAS Then
                  #Pas de conversion à effectuer
                  DCBCUMQTY += [F:HDT]HDTQTY
                Else
                  #Conversion nécesaire
                  Read [ITM]ITM0=[F:HDT]HDTITM
                  If fstat Then
                    #L'article concerné par la consommation n'a pas pu être lue.
                    # Le calcul du montant facturable est abandonné.
                    IERRINF = 546
                    Break
                  Else
                    #Calcul de la quantité consommée en unité de stock
                    Call SREC_COE([F:HDT]HDTITM, SZBPC, SZDEBFRYBAS, [F:HDT]HDTUOM, DCBCOEFUOM) From TRTVENQTE
                    DCBCNVQTY = [F:HDT]HDTQTY * DCBCOEFUOM
                    DCBCUMQTY += DCBCNVQTY
                  Endif
                Endif
                #Il faut aller chercher le débit de points dans PITCOUNT
                Read [PCT]PCT0=[M:ITN0]SRVDEMNUM;0;1;"";"";"";[F:HDT]HDTNUM;""
                If !fstat Then
                  ICUMPIT += [F:PCT]PIT
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
      If IERRINF Then
        Break
      Endif
    Next
    Filter [HDT]
    If IERRINF Then
      End
    Endif
    #Calcul du nombre de points qui devraient être débités
    If IDEBFRY <= 0 Then
      ISHOULDPIT = 0
    Else
      ISHOULDPIT = (INBRPIT * DCBCUMQTY) / IDEBFRY
    Endif
    If ICUMPIT = ISHOULDPIT Then
      End
    Endif
    #Traitement de l'ajout de points complémentaires.
    If ICUMPIT < ISHOULDPIT Then
      ICPLPIT = ISHOULDPIT - ICUMPIT
      IPIT += ICPLPIT
      Gosub CSMPIT
    Endif
    #Traitement de la suppression de points excédentaires
    If ICUMPIT > ISHOULDPIT Then
      ICPLPIT = ICUMPIT - ISHOULDPIT
      IREMOVEDPIT = 0
      If IPIT > 0 Then
        If IPIT >= ICPLPIT Then
          IPIT -= ICPLPIT
          IREMOVEDPIT += ICPLPIT
        Else
          IREMOVEDPIT += IPIT
          IPIT = 0
        Endif
        Gosub CSMPIT
      Endif
      #On décremente avec ce que l'on trouve dans le tableau ITN8
      If IREMOVEDPIT < ICPLPIT Then
        ISAVEIPIT = IPIT
        ISAVEINOL = INOL
        For INOL = 0 To dim([M:ITN8]HDTITM)-1
          If [M:ITN8]HDTITM(INOL) <> "" Then
            If [M:ITN8]PITHDT(INOL) > 0 Then
              If SZSREDEFMAC = "" Then
                SZMACLINECTL = "---" + [M:ITN8]HDTITM(INOL) + "-"
              Else
                If [M:ITN8]HDTMACSRE(INOL) = "" Then
                  SZMACLINECTL = "-" + SZSREDEFMAC + "-" + [M:ITN8]HDTCPN(INOL) + "-" + [M:ITN8]HDTITM(INOL) + "-"
                Else
                  SZMACLINECTL = "-" + [M:ITN8]HDTMACSRE(INOL) + "-" + [M:ITN8]HDTCPN(INOL) + "-" + [M:ITN8]HDTITM(INOL) + "-"
                Endif
              Endif
              If SZHDTLINECTL = SZMACLINECTL Then
                If [M:ITN8]INVPITFLG(INOL) Then
                  IDELTAPIT = ICPLPIT - IREMOVEDPIT
                  If [M:ITN8]PITHDT(INOL) >= IDELTAPIT Then
                    [M:ITN8]PITHDT(INOL) -= IDELTAPIT
                    IREMOVEDPIT += IDELTAPIT
                  Else
                    IREMOVEDPIT += [M:ITN8]PITHDT(INOL)
                    [M:ITN8]PITHDT(INOL) = 0
                  Endif
                  IPIT = [M:ITN8]PITHDT(INOL)
                  Gosub CSMPIT
                Endif
              Endif
            Endif
          Endif
          If IREMOVEDPIT >= ICPLPIT Then
            Break
          Endif
        Next
        INOL = ISAVEINOL
        IPIT = ISAVEIPIT
      Endif
      #Si cela ne suffit pas
      #On décremente avec les consommations restées sur la demande de service
      If IREMOVEDPIT < ICPLPIT Then
        SZSAVECONTEXT = SZCONTEXT
        ISAVEIPIT = IPIT
        ISAVEINOL = INOL
        SZCONTEXT = "ITN8HDT"
        Filter [HDT] Where [F:HDT]SRENUM = [M:ITN0]SRVDEMNUM and [F:HDT]TPL <> 2
        For [HDT] HDT1
          If [F:HDT]HDTITM <> "" Then
            If [F:HDT]HDTNUM <> "" Then
              If SZSREDEFMAC = "" Then
                SZMACLINECTL = "---" + [F:HDT]HDTITM + "-"
              Else
                If [F:HDT]HDTMACSRE = "" Then
                  SZMACLINECTL = "-" + SZSREDEFMAC + "-" + [F:HDT]HDTCPN + "-" + [F:HDT]HDTITM + "-"
                Else
                  SZMACLINECTL = "-" + [F:HDT]HDTMACSRE + "-" + [F:HDT]HDTCPN + "-" + [F:HDT]HDTITM + "-"
                Endif
              Endif
              If SZHDTLINECTL = SZMACLINECTL Then
                If [F:HDT]INVPITFLG Then
                  IINC_IN_ITN8 = 1
                  For ITER = 0 To dim([M:ITN8]HDTITM)-1
                    If [M:ITN8]HDTITM(ITER) <> "" Then
                      If [M:ITN8]HDTNUM(ITER) <> "" Then
                        If [M:ITN8]HDTNUM(ITER) = [F:HDT]HDTNUM Then
                          IINC_IN_ITN8 = 0
                          Break
                        Endif
                      Endif
                    Endif
                  Next
                  If IINC_IN_ITN8 Then
                    #Il faut aller chercher le débit de points dans PITCOUNT
                    Read [PCT]PCT0=[M:ITN0]SRVDEMNUM;0;1;"";"";"";[F:HDT]HDTNUM;""
                    If !fstat Then
                      If [F:PCT]PIT > 0 Then
                        IDELTAPIT = ICPLPIT - IREMOVEDPIT
                        If [F:PCT]PIT >= IDELTAPIT Then
                          IPIT = [F:PCT]PIT
                          IPIT -= IDELTAPIT
                          IREMOVEDPIT += IDELTAPIT
                        Else
                          IREMOVEDPIT += [F:PCT]PIT
                          IPIT = 0
                        Endif
                        SZITN8HDTNUM = [F:HDT]HDTNUM
                        Gosub CSMPIT
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
          If IERRINF Then
            Break
          Endif
          If IREMOVEDPIT >= ICPLPIT Then
            Break
          Endif
        Next
        Filter [HDT]
        INOL = ISAVEINOL
        IPIT = ISAVEIPIT
        SZCONTEXT = SZSAVECONTEXT
      Endif
    Endif
  Elsif SZCONTEXT = "HDT" or SZCONTEXT = "SCH" Then
    Local File HDKTASK [HDT5]
    If SZCONTEXT = "HDT" Then
      #On recherche le nom du parc par défaut
      SZSRENUM = [M:SRE0]SRENUM
      SZSRESEQ = [M:SRE0]CRESEQ
      For ITER = 0 To [M:SRE7]NBMAC-1
        If [M:SRE7]MAC(ITER) <> "" Then
          If [M:SRE7]MACDEF(ITER) = 2 Then
            SZSREDEFMAC = [M:SRE7]MAC(ITER)
            Break
          Endif
        Endif
      Next
    Elsif SZCONTEXT = "SCH" Then
      #On recherche le nom du parc par défaut
      SZSRENUM = [M:SCH0]SRENUM
      For ITER = 0 To [M:SCH7]NBMAC-1
        If [M:SCH7]MAC(ITER) <> "" Then
          If [M:SCH7]MACDEF(ITER) = 2 Then
            SZSREDEFMAC = [M:SCH7]MAC(ITER)
            Break
          Endif
        Endif
      Next
    Endif
    If SZSREDEFMAC = "" Then
      SZHDTLINECTL = "---" + SZITMFORPIT + "-"
    Else
      If SZMACFORPIT = "" Then
        SZHDTLINECTL = "-" + SZSREDEFMAC + "-" + SZCPNFORPIT + "-" + SZITMFORPIT + "-"
      Else
        SZHDTLINECTL = "-" + SZMACFORPIT + "-" + SZCPNFORPIT + "-" + SZITMFORPIT + "-"
      Endif
    Endif
    #Calcul des éléments cumulés avec la consommation courante
    If [F:HDT]HDTUOM = SZDEBFRYBAS Then
      #Pas de conversion à effectuer
      DCBCUMQTY += [F:HDT]HDTQTY
    Else
      #Conversion nécesaire
      Read [ITM]ITM0=[F:HDT]HDTITM
      If fstat Then
        #L'article concerné par la consommation n'a pas pu être lue.
        # Le calcul du montant facturable est abandonné.
        IERRINF = 546
        Close Local File [HDT5]
        End
      Else
        #Calcul de la quantité consommée en unité de stock
        Call SREC_COE([F:HDT]HDTITM, SZBPC, SZDEBFRYBAS, [F:HDT]HDTUOM, DCBCOEFUOM) From TRTVENQTE
        DCBCNVQTY = [F:HDT]HDTQTY * DCBCOEFUOM
        DCBCUMQTY += DCBCNVQTY
      Endif
    Endif
    ICUMPIT += IPIT
    #Calcul des éléments cumulés avec toutes les autres consommations
    Filter [HDT5] Where [F:HDT5]SRENUM = SZSRENUM and [F:HDT5]TPL <> 2 and [F:HDT5]HDTNUM <> [F:HDT]HDTNUM
    For [HDT5] HDT1
      If [F:HDT5]HDTITM <> "" Then
        If [F:HDT5]HDTNUM <> "" Then
          If SZSREDEFMAC = "" Then
            SZMACLINECTL = "---" + [F:HDT5]HDTITM + "-"
          Else
            If [F:HDT5]HDTMACSRE = "" Then
              SZMACLINECTL = "-" + SZSREDEFMAC + "-" + [F:HDT5]HDTCPN + "-" + [F:HDT5]HDTITM + "-"
            Else
              SZMACLINECTL = "-" + [F:HDT5]HDTMACSRE + "-" + [F:HDT5]HDTCPN + "-" + [F:HDT5]HDTITM + "-"
            Endif
          Endif
          If SZHDTLINECTL = SZMACLINECTL Then
            If [F:HDT5]INVPITFLG Then
              If [F:HDT5]HDTUOM = SZDEBFRYBAS
                #Pas de conversion à effectuer
                DCBCUMQTY += [F:HDT5]HDTQTY
              Else
                #Conversion nécesaire
                Read [ITM]ITM0=[F:HDT5]HDTITM
                If fstat Then
                  #L'article concerné par la consommation n'a pas pu être lue.
                  # Le calcul du montant facturable est abandonné.
                  IERRINF = 546
                  Break
                Else
                  #Calcul de la quantité consommée en unité de stock
                  Call SREC_COE([F:HDT5]HDTITM, SZBPC, SZDEBFRYBAS, [F:HDT5]HDTUOM, DCBCOEFUOM) From TRTVENQTE
                  DCBCNVQTY = [F:HDT5]HDTQTY * DCBCOEFUOM
                  DCBCUMQTY += DCBCNVQTY
                Endif
              Endif
              #Il faut aller chercher le débit de points dans PITCOUNT
              If SZCONTEXT = "HDT" Then
                If GREP = "C" or GREP = "D" Then
                  #On  recherche le numéro de séquence provisoire de la consommation
                  SZHDTSEQ = ""
                  For ITER = 0 To [M:SRE9]NBLIG-1
                    If [M:SRE9]HDTNUM(ITER) <> "" Then
                      If [M:SRE9]HDTNUM(ITER) = [F:HDT5]HDTNUM Then
                        SZHDTSEQ = [M:SRE9]HDTNUMSEQ(ITER)
                        Break
                      Endif
                    Endif
                  Next
                  If SZHDTSEQ = "" Then
                    #Aucun identifiant n'a été obtenu pour la consommation horodatée.
                    # Le calcul du montant facturable est abandonné.
                    IERRINF = 548
                    Break
                  Endif
                  Read [PCT]PCT0=SZSRESEQ;1;0;"";"";"";"";SZHDTSEQ
                Else
                  Read [PCT]PCT0=SZSRENUM;0;0;"";"";"";[F:HDT5]HDTNUM;""
                Endif
              Elsif SZCONTEXT = "SCH" Then
                Read [PCT]PCT0=SZSRENUM;0;0;"";"";"";[F:HDT5]HDTNUM;""
              Endif
              If !fstat Then
                ICUMPIT += [F:PCT]PIT
              Endif
            Endif
          Endif
        Endif
      Endif
      If IERRINF Then
        Break
      Endif
    Next
    Filter [HDT5]
    If IERRINF Then
      Close Local File [HDT5]
      End
    Endif
    #Calcul du nombre de points qui devraient être débités
    If IDEBFRY <= 0 Then
      ISHOULDPIT = 0
    Else
      ISHOULDPIT = (INBRPIT * DCBCUMQTY) / IDEBFRY
    Endif
    If ICUMPIT = ISHOULDPIT Then
      End
    Endif
    #Avec les horodatages on ne traite que le cas de l'ajout de points complémentaires.
    If ICUMPIT < ISHOULDPIT Then
      ICPLPIT = ISHOULDPIT - ICUMPIT
      IPIT += ICPLPIT
      Gosub CSMPIT
    Endif
    Close Local File [HDT5]
  Endif
End

##########################################################################################################
# Défini un numéro de séquence pour une consommation associée à un débit de point en classe F
##########################################################################################################
Subprog FILLHORHDT(SZHDTNUM, SZHORHDTSEQ, IERRINF)
Value Char SZHDTNUM
Variable Char SZHORHDTSEQ
Variable Integer IERRINF

Local Char SZSEQ

  SZHORHDTSEQ = ""
  SZSEQ = ""
  Call SETSEQNUM(SZSEQ) From SUBSREB1
  If GERR Then
    #Erreur lors de la génération du compteur d'identification séquentielle.
    IERRINF = 536
    End
  Endif
  #On enregistre le numéro de séquence à la première place disponible
  [M:SRE0]HORHDTNUM = SZHDTNUM
  [M:SRE0]HORHDTSEQ = SZSEQ
  SZHORHDTSEQ = SZSEQ
  If SZHORHDTSEQ = "" Then
    #Erreur lors de la génération du compteur d'identification séquentielle.
    IERRINF = 536
    End
  Endif
End

##########################################################################################################
# Met en mémoire tous les contrats pouvant potentiellement offrir une couverture partielle
##########################################################################################################
$DOPARTIALMAC
  # FGR 02/07/2010 : X3SUIVI65808 : ça ne sert a rien au contraire ça fait planter si on ne vient pas de SRE
  #If [M:SRE2]OVRCOV <> 2 Then
  #  Return
  #Endif
  INBPARTIALCON = 0
  Filter [CON] Where [F:CON]CONBPC = SZBPC and [F:CON]CONCAT <> 4 and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONSTRDAT <= date$
&                and [F:CON]CONENDDAT >= date$ and [F:CON]EVRMAC <> 2
  For [CON] Hint Key CON4
    #Contrôle du réglement du contrat
    SZ2LITCOD = ""
    I2CONTOK = 1
    Call CHECKPAY([F:CON]CONNUM, [F:CON]CONBPC, SZ2LITCOD, I2CONTOK) From TRTCOVER
    If I2CONTOK Then
      INBPARTIALCON += 1
    Else
      If SZ2LITCOD <> "" Then
        Call CHECK2LIT([F:CON]CONNUM, SZ2LITCOD, I2CONTOK) From TRTCOVER
        If I2CONTOK Then
          INBPARTIALCON += 1
        Endif
      Endif
    Endif
  Next
  Filter [CON]
  If INBPARTIALCON > 1 Then
    Local Char SZPARTIALCON(GLONVCR)(INBPARTIALCON)

    Raz SZPARTIALCON
    INBPARTIALCON = 0
    Filter [CON] Where [F:CON]CONBPC = SZBPC and [F:CON]CONCAT <> 4 and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONSTRDAT <= date$
&                  and [F:CON]CONENDDAT >= date$ and [F:CON]EVRMAC <> 2
    For [CON] Hint Key CON4
      #Contrôle du réglement du contrat
      SZ2LITCOD = ""
      I2CONTOK = 1
      Call CHECKPAY([F:CON]CONNUM, [F:CON]CONBPC, SZ2LITCOD, I2CONTOK) From TRTCOVER
      If I2CONTOK Then
        SZPARTIALCON(INBPARTIALCON) = [F:CON]CONNUM
        INBPARTIALCON += 1
      Else
        If SZ2LITCOD <> "" Then
          Call CHECK2LIT([F:CON]CONNUM, SZ2LITCOD, I2CONTOK) From TRTCOVER
          If I2CONTOK Then
            SZPARTIALCON(INBPARTIALCON) = [F:CON]CONNUM
            INBPARTIALCON += 1
          Endif
        Endif
      Endif
    Next
    Filter [CON]
  Endif
Return

