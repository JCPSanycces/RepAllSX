      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Si parc externe. On s'arrête la.
  If IEXTERNALMAC Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 2
  # Couverture de niveau référence article
  #---------------------------------------------------#
  Read [MAC]MAC0=SZMAC
  If fstat Then
    #Le parc concerné par la consommation n'a pas pu être lue. Le calcul du montant facturable est abandonné.
