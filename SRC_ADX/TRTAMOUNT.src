&                and [F:CCV]CPNSRT = "BCPNITM"
&                and [F:CCV]PAEKEY(0) = SZPBL
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = ""
&                and [F:CCV]PAEKEYTYP(1) = "ITM"
  For [CCV]CCV1
    Case ICSMTYP
      When 0
        If [F:CCV]ITMICDFLG = 0 Then
          If GITMICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GITMICD
          Endif
        Else
          IICDFLG = [F:CCV]ITMICDFLG
        Endif
      When 1
        If [F:CCV]LABICDFLG = 0 Then
          If GLABICD = 0 Then
            IICDFLG = 1
