        Endif
    Endcase
    ICCVHEIPRC = [F:CCV]HEIPRC(ICSMTYP)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(ICSMTYP)
      ICCVMAXCOV = [F:CCV]MAXCOV(ICSMTYP)
    Else
