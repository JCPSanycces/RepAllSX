    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(ICSMTYP), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 3
  # Couverture de niveau famille commerciale de produit
  #---------------------------------------------------#
  Read [ITM]ITM0=[F:MAC]MACPDTCOD
  If fstat Then
    #L'article concerné par la consommation n'a pas pu être lue. Le calcul du montant facturable est abandonné.
    IERRINF = 546
    Return
  Endif
  #Recherche des couvertures listées
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "AAA"
&                and [F:CCV]SBBRECTYP = SZCSMTYP
&                and [F:CCV]RECNUM = SZCSM
&                and [F:CCV]CMT = [F:ITM]TSICOD(GFAMCIA-1)
&                and [F:CCV]CPNSRT = "AAAACPNCIA"
&                and [F:CCV]PAEKEY(0) = ""
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = SZCPN
&                and [F:CCV]PAEKEYTYP(1) = "CIA"
  For [CCV]CCV1
    IICDFLG = [F:CCV]ICDFLG
    ICCVHEIPRC = [F:CCV]HEIPRC(0)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(0)
      ICCVMAXCOV = [F:CCV]MAXCOV(0)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(0), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(0), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Recherche des couvertures non listées
  ICSMCSM = 0
  ICSMINV = 0
  ICCVMINCOV = 0
  ICCVMAXCOV = 0
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "CPN"
&                and [F:CCV]SBBRECTYP = ""
&                and [F:CCV]RECNUM = SZCPN
&                and [F:CCV]CMT = [F:ITM]TSICOD(GFAMCIA-1)
&                and [F:CCV]CPNSRT = "ACPNCIA"
&                and [F:CCV]PAEKEY(0) = ""
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = ""
&                and [F:CCV]PAEKEYTYP(1) = "CIA"
  For [CCV]CCV1
    Case ICSMTYP
      When 0
        If [F:CCV]ITMICDFLG = 0 Then
          If GITMICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GITMICD
          Endif
        Else
          IICDFLG = [F:CCV]ITMICDFLG
        Endif
      When 1
        If [F:CCV]LABICDFLG = 0 Then
          If GLABICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GLABICD
          Endif
        Else
          IICDFLG = [F:CCV]LABICDFLG
        Endif
      When 2
        If [F:CCV]EXSICDFLG = 0 Then
          If GEXSICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GEXSICD
          Endif
        Else
          IICDFLG = [F:CCV]EXSICDFLG
        Endif
    Endcase
    ICCVHEIPRC = [F:CCV]HEIPRC(ICSMTYP)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(ICSMTYP)
      ICCVMAXCOV = [F:CCV]MAXCOV(ICSMTYP)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(ICSMTYP), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
Return

##########################################################################################################
# Montant pour une consommation relative à une fiche parc + composant + compétence
####################################################
$DO_111
  #Calcul du montant total déjà consommé pour cet article.
  If SZCONTEXT = "SRE9" Then
    For ITER = 0 To [M:SRE9]NBLIG-1
      If ITER <> INOL Then
        If [M:SRE9]HDTMACSRE(ITER) = SZMAC Then
          If [M:SRE9]HDTCPN(ITER) = SZCPN Then
            If [M:SRE9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SRE9]HDTAMT(ITER)
              ICSMINV += [M:SRE9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "ITN8" Then
    For ITER = 0 To [M:ITN8]NBLIG-1
      If ITER <> INOL Then
        If [M:ITN8]HDTMACSRE(ITER) = SZMAC Then
          If [M:ITN8]HDTCPN(ITER) = SZCPN Then
            If [M:ITN8]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:ITN8]HDTAMT(ITER)
              ICSMINV += [M:ITN8]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "HDT" Then
    For ITER = 0 To [M:SRE9]NBLIG-1
      If [M:SRE9]HDTNUM(ITER) <> [F:HDT]HDTNUM Then
        If [M:SRE9]HDTMACSRE(ITER) = SZMAC Then
          If [M:SRE9]HDTCPN(ITER) = SZCPN Then
            If [M:SRE9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SRE9]HDTAMT(ITER)
              ICSMINV += [M:SRE9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "SCH" Then
    For ITER = 0 To [M:SCH9]NBLIG-1
      If [M:SCH9]HDTNUM(ITER) <> [F:HDT]HDTNUM Then
        If [M:SCH9]HDTMACSRE(ITER) = SZMAC Then
          If [M:SCH9]HDTCPN(ITER) = SZCPN Then
            If [M:SCH9]HDTITM(ITER) = SZCSM
              ICSMCSM += [M:SCH9]HDTAMT(ITER)
              ICSMINV += [M:SCH9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  #---------------------------------------------------#
  # Etape 1
  # Couverture de niveau parc
  #---------------------------------------------------#
  #Recherche des couvertures listées
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "AAA"
&                and [F:CCV]SBBRECTYP = SZCSMTYP
&                and [F:CCV]RECNUM = SZCSM
&                and [F:CCV]CMT = SZMAC
&                and [F:CCV]CPNSRT = "CAAACPNMAC"
&                and [F:CCV]PAEKEY(0) = SZPBL
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = SZCPN
&                and [F:CCV]PAEKEYTYP(1) = "MAC"
  For [CCV]CCV1
    IICDFLG = [F:CCV]ICDFLG
    ICCVHEIPRC = [F:CCV]HEIPRC(0)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(0)
      ICCVMAXCOV = [F:CCV]MAXCOV(0)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(0), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(0), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Recherche des couvertures non listées
  ICSMCSM = 0
  ICSMINV = 0
  ICCVMINCOV = 0
  ICCVMAXCOV = 0
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "CPN"
&                and [F:CCV]SBBRECTYP = ""
&                and [F:CCV]RECNUM = SZCPN
&                and [F:CCV]CMT = SZMAC
&                and [F:CCV]CPNSRT = "CCPNMAC"
&                and [F:CCV]PAEKEY(0) = SZPBL
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = ""
&                and [F:CCV]PAEKEYTYP(1) = "MAC"
  For [CCV]CCV1
    Case ICSMTYP
      When 0
        If [F:CCV]ITMICDFLG = 0 Then
