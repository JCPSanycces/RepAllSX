#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires de gestion de la couverture SAV           Module CRM            13 Octobre 2003
#
#  AMOUNT        : Détermine le montant à facturer d'une ligne de consommation.
#  CHKSIMPLE     : Traitement des cas simples pour une consommation avec parc saisi
#  CHECKPIT      : Détermine le débit complémentaire de points d'une consommation
#  DELPIT        : Suppression du débit de points complémentaires d'une consommation
#  REMORADDPIT   : Ajoute ou enlève des points sur les consommations relatives au même code article et
#                    au même parc
#  FILLHORHDT    : Défini un numéro de séquence pour une consommation associée à un débit de point
#                    en classe F
#  DOPARTIALMAC  : Met en mémoire tous les contrats pouvant potentiellement offrir une couverture partielle
#  DOPARTIALPBL  : Met en mémoire tous les contrats pouvant potentiellement offrir une couverture partielle
#  PARTIALMACPBL : Met en mémoire tous les contrats pouvant potentiellement offrir une couverture partielle
#
##########################################################################################################
##########################################################################################################
# Détermine le montant à facturer d'une ligne de consommation.
###########################################################################
Subprog AMOUNT(ITRANSLINEPIT, SZCONTEXT, INOL, IAMT, IINV, IAMTINV, IPIT, IPITFLG, IERRINF)
Value Integer ITRANSLINEPIT
Value Char SZCONTEXT
Value Integer INOL
Value Decimal IAMT
Variable Integer IINV
Variable Decimal IAMTINV
Variable Decimal IPIT          # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal
Variable Decimal IPITFLG       # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal
Variable Integer IERRINF

Local Integer IPARTRECFOUND
Local Integer IEXTERNALMAC
Local Char SZ2LITCOD
Local Integer I2CONTOK
Local Decimal IARRAMTINV
Local Integer INULPIOVAL
Local Integer INBRPIT
Local Decimal IDEBFRY
Local Char SZDEBFRYBAS
Local Char SZDEFMACPIT
Local Char SZMACFORPIT
Local Char SZCPNFORPIT
Local Char SZITMFORPIT
Local Char SZAMTCASE
Local Integer ISRENBMAC
Local Decimal IQTY
Local Integer ITYP
Local Integer ICSMTYP
Local Integer ISOLVED
Local Integer ITER
Local Integer IDEFMAC
Local Integer ISAMEMAC
Local Char SZCSMTYP
Local Char SZBPC
Local Char SZCSM
Local Char SZITM
Local Char SZMAC
Local Char SZCPN
Local Char SZPBL
Local Char SZCON
Local Char SZCONCUR
Local Char SZSRECUR
Local Char SZUOM
Local Char SZFCY(GLONFCY)
Local Decimal ICCVMINCOV
Local Decimal ICCVMAXCOV
Local Decimal ICSMCSM
Local Decimal ICSMINV
Local Integer IICDFLG
Local Integer ICCVHEIPRC
Local Integer ISECONDLOOP
Local Integer INBPARTIALCON
Local Integer ITERPARTIALCON
Local Decimal IFINALAMTINV
Local Integer IBTSTFIRSET

  IERRINF = 0
  #Valeurs par défaut
  IINV = 2
  IAMTINV = IAMT
  IPIT = 0
  IPITFLG = 0
  ITERPARTIALCON = 0
  IFINALAMTINV = 0
  INBPARTIALCON = 0
  IARRAMTINV = 0
  IDEFMAC = 0
  ISAMEMAC = 0
  ISECONDLOOP = 0
  INULPIOVAL = 0
  INBRPIT = 0
  IDEBFRY = 0
  ICSMCSM = 0
  ICSMINV = 0
  ICCVMINCOV = 0
  ICCVMAXCOV = 0
  IICDFLG = 0
  ICCVHEIPRC = 0
  SZDEBFRYBAS = ""
  SZDEFMACPIT = ""
  SZMACFORPIT = ""
  SZCPNFORPIT = ""
  SZITMFORPIT = ""
  SZMAC = ""
  SZCPN = ""
  SZPBL = ""
  SZCON = ""
  SZCONCUR = ""
  SZSRECUR = ""
  SZITM = ""
  SZBPC = ""
  ITER = 0
  ISOLVED = 0
  ISRENBMAC = 0
  SZAMTCASE = ""
  IEXTERNALMAC = 0
  IPARTRECFOUND = 0
  IBTSTFIRSET = 0
  #
  Case SZCONTEXT
    When "SRE9"
      SZCSM = [M:SRE9]HDTITM(INOL)
      SZUOM = [M:SRE9]HDTUOM(INOL)
      IQTY = [M:SRE9]HDTQTY(INOL)
      ITYP = [M:SRE9]HDTTYP(INOL)
      SZBPC = [M:SRE0]SREBPC
      SZSRECUR = [M:SRE8]SRECUR
      SZFCY = [M:SRE0]SALFCY
      SZMACFORPIT = [M:SRE9]HDTMACSRE(INOL)
      SZCPNFORPIT = [M:SRE9]HDTCPN(INOL)
      SZITMFORPIT = [M:SRE9]HDTITM(INOL)
    When "ITN8"
      Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
      If fstat Then
        #La demande de service n'a pas pu être lue. Le calcul du montant facturable est abandonné.
        IERRINF = 541
        End
      Endif
      SZDEFMACPIT = [F:SRE]SREMAC
      SZBPC = [F:SRE]SREBPC
      SZSRECUR = [F:SRE]SRECUR
      SZFCY = [F:SRE]SALFCY
      SZCSM = [M:ITN8]HDTITM(INOL)
      SZUOM = [M:ITN8]HDTUOM(INOL)
      IQTY = [M:ITN8]HDTQTY(INOL)
      ITYP = [M:ITN8]HDTTYP(INOL)
      SZMACFORPIT = [M:ITN8]HDTMACSRE(INOL)
      SZCPNFORPIT = [M:ITN8]HDTCPN(INOL)
      SZITMFORPIT = [M:ITN8]HDTITM(INOL)
    When "HDT"
      SZCSM = [F:HDT]HDTITM
      SZUOM = [F:HDT]HDTUOM
      IQTY = [F:HDT]HDTQTY
      ITYP = [F:HDT]HDTTYP
      SZBPC = [M:SRE0]SREBPC
      SZSRECUR = [F:HDT]HDTCUR
      SZFCY = [M:SRE0]SALFCY
      SZMACFORPIT = [F:HDT]HDTMACSRE
      SZCPNFORPIT = [F:HDT]HDTCPN
      SZITMFORPIT = [F:HDT]HDTITM
    When "SCH"
      SZCSM = [F:HDT]HDTITM
      SZUOM = [F:HDT]HDTUOM
      IQTY = [F:HDT]HDTQTY
      ITYP = [F:HDT]HDTTYP
      SZBPC = [M:SCH0]SREBPC
      SZSRECUR = [F:HDT]HDTCUR
      SZFCY = [M:SCH0]SALFCY
      SZMACFORPIT = [F:HDT]HDTMACSRE
      SZCPNFORPIT = [F:HDT]HDTCPN
      SZITMFORPIT = [F:HDT]HDTITM
  Endcase
  #Si le trio : Article, Quantité, Unité n'est pas au complet. Aucune recherche n'est effectuée.
  If IQTY <= 0 Then
    End
  Endif
  If SZUOM  = "" Then
    End
  Endif
  If SZCSM = "" Then
    End
  Endif
  Case ITYP
    When 2
      SZCSMTYP = "ITM"
      ICSMTYP = 0
    When 3
      SZCSMTYP = "LAB"
      ICSMTYP = 1
    When 4
      SZCSMTYP = "EXS"
      ICSMTYP = 2
  Endcase
  #On a besoin d'un identifiant pour chaque consommation à traiter
  If SZCONTEXT = "SRE9" Then
    If [M:SRE9]HDTNUM(INOL) = "" Then
      If [M:SRE9]HDTNUMSEQ(INOL) = "" Then
        Call SETSEQNUM([M:SRE9]HDTNUMSEQ(INOL)) From SUBSREB1
        If GERR Then
          #Erreur lors de la génération du compteur d'identification séquentielle.
          IERRINF = 536
          End
        Endif
      Endif
    Endif
  Elsif SZCONTEXT = "ITN8" Then
    If [M:ITN8]HDTNUM(INOL) = "" Then
      If [M:ITN8]HDTNUMSEQ(INOL) = "" Then
        Call SETSEQNUM([M:ITN8]HDTNUMSEQ(INOL)) From SUBSREB1
        If GERR Then
          #Erreur lors de la génération du compteur d'identification séquentielle.
          IERRINF = 536
          End
        Endif
      Endif
    Endif
  Elsif SZCONTEXT = "HDT" or SZCONTEXT = "SCH" Then
    If [F:HDT]HDTNUM = "" Then
      #Aucun identifiant n'a été obtenu pour la consommation horodatée. Le calcul du montant facturable est abandonné.
      IERRINF = 548
      End
    Endif
  Endif
  #On supprime tout débit de point déjà enregistré pour cette consommation
  Call DELPIT(SZCONTEXT, INOL, IERRINF)
  If IERRINF Then
    End
  Endif
  #Première partie
  #Traitement des cas simples
  If SZCONTEXT = "SRE9" Then
    If [M:SRE9]HDTMACSRE(INOL) = "" Then
      If [M:SRE7]NBMAC = 0 Then
        SZPBL = [M:SRE7]SREPBLGRP
        Case [M:SRE2]OVRCOV
          When 1
            SZCON = [M:SRE2]SRECOVNUM
            # FGR 21/12/2012 : X3SUIVI86670 : appel TRTCONH.COVERED_COMPONENT
            If func TRTCONH.COVERED_COMPONENT([M:SRE2]CONSPT, [M:SRE2]OVRCOV, [M:SRE9]HDTMACSRE(INOL), [M:SRE9]HDTITM(INOL)) = G_YES Then
              Gosub CHECKPIT
            Endif
          When 4
            If [M:SRE2]SRECOVNUM = "" Then
              IINV = 1
              IAMTINV = 0
              ISOLVED = 1
            Else
              SZCON = [M:SRE2]SRECOVNUM
              Gosub CHECKPIT
            Endif
          When 5,6
            IINV = 1
            IAMTINV = 0
            ISOLVED = 1
          When 3,7
            ISOLVED = 1
          When 2
            Gosub DOPARTIALPBL
            SZCON = [M:SRE2]SRECOVNUM
          Endcase
        Else
          For ITER = 0 To [M:SRE7]NBMAC-1
            If [M:SRE7]MACDEF(ITER) = 2 Then
              IEXTERNALMAC = 0
              IDEFMAC = 1
              SZMAC = [M:SRE7]MAC(ITER)
              Read [MAC]MAC0=SZMAC
              If !fstat Then
                SZITM = [F:MAC]MACPDTCOD
                If [F:MAC]BPCNUM <> "" Then
                  If SZBPC <> "" Then
                    If [F:MAC]BPCNUM <> SZBPC Then
                      IEXTERNALMAC = 1
                    Endif
                  Endif
                Endif
              Endif
              SZPBL = [M:SRE7]PBL(ITER)
            Case [M:SRE7]COVFLG(ITER)
              When 1
                Case [M:SRE7]COVSPT(ITER)
                  When 1
                    If [M:SRE7]COVVCR(ITER) = "" Then
                      IINV = 1
                      IAMTINV = 0
                      ISOLVED = 1
                    Else
                      SZCON = [M:SRE7]COVVCR(ITER)
                      Gosub CHECKPIT
                    Endif
                  When 2,3,5
                    IINV = 1
                    IAMTINV = 0
                    ISOLVED = 1
                  When 4
                    ISOLVED = 1
                Endcase
              When 2
                If SZPBL = "" Then
                  Gosub DOPARTIALMAC
                Else
                  Gosub PARTIALMACPBL
                Endif
                SZCON = [M:SRE7]COVVCR(ITER)
              When 3
                ISOLVED = 1
            Endcase
            Break
          Endif
        Next
      Endif
    Else
      IEXTERNALMAC = 0
      SZMAC = [M:SRE9]HDTMACSRE(INOL)
      Read [MAC]MAC0=SZMAC
      If !fstat Then
        SZITM = [F:MAC]MACPDTCOD
        If [F:MAC]BPCNUM <> "" Then
          If SZBPC <> "" Then
            If [F:MAC]BPCNUM <> SZBPC Then
              IEXTERNALMAC = 1
            Endif
          Endif
        Endif
      Endif
      SZCPN = [M:SRE9]HDTCPN(INOL)
      For ITER = 0 To [M:SRE7]NBMAC-1
        If [M:SRE7]MAC(ITER) = [M:SRE9]HDTMACSRE(INOL) Then
          If [M:SRE7]MACDEF(ITER) = 2 Then
            IDEFMAC = 1
          Endif
          SZPBL = [M:SRE7]PBL(ITER)
          If SZCPN = "" Then
            Case [M:SRE7]COVFLG(ITER)
              When 1
                Case [M:SRE7]COVSPT(ITER)
                  When 1
                    If [M:SRE7]COVVCR(ITER) = "" Then
                      IINV = 1
                      IAMTINV = 0
                      ISOLVED = 1
                    Else
                      SZCON = [M:SRE7]COVVCR(ITER)
                      Gosub CHECKPIT
                    Endif
                  When 2,3,5
                    IINV = 1
                    IAMTINV = 0
                    ISOLVED = 1
                  When 4
                    ISOLVED = 1
                Endcase
              When 2
                If SZPBL = "" Then
                  Gosub DOPARTIALMAC
                Else
                  Gosub PARTIALMACPBL
                Endif
                SZCON = [M:SRE7]COVVCR(ITER)
              When 3
                ISOLVED = 1
            Endcase
          Else
            Gosub CHKSIMPLE
          Endif
          Break
        Endif
      Next
    Endif
  Elsif SZCONTEXT = "ITN8" Then
    If [M:ITN8]HDTMACSRE(INOL) = "" Then
      ISRENBMAC = 0
      Filter [SRM] Where [F:SRM]SRENUM = [M:ITN0]SRVDEMNUM
      For [SRM]
        If [F:SRM]MACNUM = [F:SRE]SREMAC Then
          IEXTERNALMAC = 0
          IDEFMAC = 1
          SZMAC = [F:SRM]MACNUM
          Read [MAC]MAC0=SZMAC
          If !fstat Then
            SZITM = [F:MAC]MACPDTCOD
            If [F:MAC]BPCNUM <> "" Then
              If SZBPC <> "" Then
                If [F:MAC]BPCNUM <> SZBPC Then
                  IEXTERNALMAC = 1
                Endif
              Endif
            Endif
          Endif
          SZPBL = [F:SRM]PBLNUM
          Case [F:SRM]COVFLG
            When 1
              Case [F:SRM]COVSPT
                When 1
                  If [F:SRM]COVVCR = "" Then
                    IINV = 1
                    IAMTINV = 0
                    ISOLVED = 1
                  Else
                    SZCON = [F:SRM]COVVCR
                    Gosub CHECKPIT
                  Endif
                When 2,3,5
                  IINV = 1
                  IAMTINV = 0
                  ISOLVED = 1
                When 4
                  ISOLVED = 1
              Endcase
            When 2
              If SZPBL = "" Then
                Gosub DOPARTIALMAC
              Else
                Gosub PARTIALMACPBL
              Endif
              SZCON = [F:SRM]COVVCR
            When 3
              ISOLVED = 1
          Endcase
          Break
        Endif
        ISRENBMAC += 1
      Next
      Filter [SRM]
      If ISRENBMAC = 0 Then
        SZPBL = [F:SRE]SREPBLGRP
        Case [F:SRE]OVRCOV
          When 1
            SZCON = [F:SRE]SRECOVNUM
            # FGR 21/12/2012 : X3SUIVI86670 : appel TRTCONH.COVERED_COMPONENT
            If func TRTCONH.COVERED_COMPONENT([F:SRE]CONSPT, [F:SRE]OVRCOV, [M:ITN8]HDTMACSRE(INOL), [M:ITN8]HDTITM(INOL)) = G_YES Then
              Gosub CHECKPIT
            Endif
          When 4
            If [F:SRE]SRECOVNUM = "" Then
              IINV = 1
              IAMTINV = 0
              ISOLVED = 1
            Else
              SZCON = [F:SRE]SRECOVNUM
              Gosub CHECKPIT
            Endif
          When 5,6
            IINV = 1
            IAMTINV = 0
            ISOLVED = 1
          When 3,7
            ISOLVED = 1
          When 2
            Gosub DOPARTIALPBL
            SZCON = [F:SRE]SRECOVNUM
        Endcase
      Endif
    Else
      If [M:ITN8]HDTMACSRE(INOL) = [F:SRE]SREMAC Then
        IDEFMAC = 1
      Endif
      IEXTERNALMAC = 0
      SZMAC = [M:ITN8]HDTMACSRE(INOL)
      Read [MAC]MAC0=SZMAC
      If !fstat Then
        SZITM = [F:MAC]MACPDTCOD
        If [F:MAC]BPCNUM <> "" Then
          If SZBPC <> "" Then
            If [F:MAC]BPCNUM <> SZBPC Then
              IEXTERNALMAC = 1
            Endif
          Endif
        Endif
      Endif
      SZCPN = [M:ITN8]HDTCPN(INOL)
      Filter [SRM] Where [F:SRM]SRENUM = [M:ITN0]SRVDEMNUM and [F:SRM]MACNUM = [M:ITN8]HDTMACSRE(INOL)
      For [SRM]SRM1
        SZPBL = [F:SRM]PBLNUM
        If SZCPN = "" Then
          Case [F:SRM]COVFLG
            When 1
              Case [F:SRM]COVSPT
                When 1
                  If [F:SRM]COVVCR = "" Then
                    IINV = 1
                    IAMTINV = 0
                    ISOLVED = 1
                  Else
                    SZCON = [F:SRM]COVVCR
                    Gosub CHECKPIT
                  Endif
                When 2,3,5
                  IINV = 1
                  IAMTINV = 0
                  ISOLVED = 1
                When 4
                  ISOLVED = 1
              Endcase
            When 2
              If SZPBL = "" Then
                Gosub DOPARTIALMAC
              Else
                Gosub PARTIALMACPBL
              Endif
              SZCON = [F:SRM]COVVCR
            When 3
              ISOLVED = 1
          Endcase
        Else
          Gosub CHKSIMPLE
        Endif
        Break
      Next
      Filter [SRM]
    Endif
  Elsif SZCONTEXT = "HDT" Then
    If [F:HDT]HDTMACSRE = "" Then
      If [M:SRE7]NBMAC = 0 Then
        SZPBL = [M:SRE7]SREPBLGRP
        Case [M:SRE2]OVRCOV
          When 1
            SZCON = [M:SRE2]SRECOVNUM
            # FGR 21/12/2012 : X3SUIVI86670 : appel TRTCONH.COVERED_COMPONENT
            If func TRTCONH.COVERED_COMPONENT([M:SRE2]CONSPT, [M:SRE2]OVRCOV, [M:SRE9]HDTMACSRE(INOL), [M:SRE9]HDTITM(INOL)) = G_YES Then
              Gosub CHECKPIT
            Endif
          When 4
            If [M:SRE2]SRECOVNUM = "" Then
              IINV = 1
              IAMTINV = 0
              ISOLVED = 1
            Else
              SZCON = [M:SRE2]SRECOVNUM
              Gosub CHECKPIT
            Endif
          When 5,6
            IINV = 1
            IAMTINV = 0
            ISOLVED = 1
          When 3,7
            ISOLVED = 1
          When 2
            Gosub DOPARTIALPBL
            SZCON = [M:SRE2]SRECOVNUM
        Endcase
      Else
        For ITER = 0 To [M:SRE7]NBMAC-1
          If [M:SRE7]MACDEF(ITER) = 2 Then
            IEXTERNALMAC = 0
            IDEFMAC = 1
            SZMAC = [M:SRE7]MAC(ITER)
            Read [MAC]MAC0=SZMAC
            If !fstat Then
              SZITM = [F:MAC]MACPDTCOD
              If [F:MAC]BPCNUM <> "" Then
                If SZBPC <> "" Then
                  If [F:MAC]BPCNUM <> SZBPC Then
                    IEXTERNALMAC = 1
                  Endif
                Endif
              Endif
            Endif
            SZPBL = [M:SRE7]PBL(ITER)
            Case [M:SRE7]COVFLG(ITER)
              When 1
                Case [M:SRE7]COVSPT(ITER)
                  When 1
                    If [M:SRE7]COVVCR(ITER) = "" Then
                      IINV = 1
                      IAMTINV = 0
                      ISOLVED = 1
                    Else
                      SZCON = [M:SRE7]COVVCR(ITER)
                      Gosub CHECKPIT
                    Endif
                  When 2,3,5
                    IINV = 1
                    IAMTINV = 0
                    ISOLVED = 1
                  When 4
                    ISOLVED = 1
                Endcase
              When 2
                If SZPBL = "" Then
                  Gosub DOPARTIALMAC
                Else
                  Gosub PARTIALMACPBL
                Endif
                SZCON = [M:SRE7]COVVCR(ITER)
              When 3
                ISOLVED = 1
            Endcase
            Break
          Endif
        Next
      Endif
    Else
      IEXTERNALMAC = 0
      SZMAC = [F:HDT]HDTMACSRE
      Read [MAC]MAC0=SZMAC
      If !fstat Then
        SZITM = [F:MAC]MACPDTCOD
        If [F:MAC]BPCNUM <> "" Then
          If SZBPC <> "" Then
            If [F:MAC]BPCNUM <> SZBPC Then
              IEXTERNALMAC = 1
            Endif
          Endif
        Endif
      Endif
      SZCPN = [F:HDT]HDTCPN
      For ITER = 0 To [M:SRE7]NBMAC-1
        If [M:SRE7]MAC(ITER) = [F:HDT]HDTMACSRE Then
          If [M:SRE7]MACDEF(ITER) = 2 Then
            IDEFMAC = 1
          Endif
          SZPBL = [M:SRE7]PBL(ITER)
          If SZCPN = "" Then
            Case [M:SRE7]COVFLG(ITER)
              When 1
                Case [M:SRE7]COVSPT(ITER)
                  When 1
                    If [M:SRE7]COVVCR(ITER) = "" Then
                      IINV = 1
                      IAMTINV = 0
                      ISOLVED = 1
                    Else
                      SZCON = [M:SRE7]COVVCR(ITER)
                      Gosub CHECKPIT
                    Endif
                  When 2,3,5
                    IINV = 1
                    IAMTINV = 0
                    ISOLVED = 1
                  When 4
                    ISOLVED = 1
                Endcase
              When 2
                If SZPBL = "" Then
                  Gosub DOPARTIALMAC
                Else
                  Gosub PARTIALMACPBL
                Endif
                SZCON = [M:SRE7]COVVCR(ITER)
              When 3
                ISOLVED = 1
            Endcase
          Else
            Gosub CHKSIMPLE
          Endif
          Break
        Endif
      Next
    Endif
  Elsif SZCONTEXT = "SCH" Then
    If [F:HDT]HDTMACSRE = "" Then
      If [M:SCH7]NBMAC = 0 Then
        SZPBL = [M:SCH7]SREPBLGRP
        Case [M:SCH2]OVRCOV
          When 1
            SZCON = [M:SCH2]SRECOVNUM
            Gosub CHECKPIT
          When 4
            If [M:SCH2]SRECOVNUM = "" Then
              IINV = 1
              IAMTINV = 0
              ISOLVED = 1
            Else
              SZCON = [M:SCH2]SRECOVNUM
              Gosub CHECKPIT
            Endif
          When 5,6
            IINV = 1
            IAMTINV = 0
            ISOLVED = 1
          When 3,7
            ISOLVED = 1
          When 2
            Gosub DOPARTIALPBL
            SZCON = [M:SCH2]SRECOVNUM
        Endcase
      Else
        For ITER = 0 To [M:SCH7]NBMAC-1
          If [M:SCH7]MACDEF(ITER) = 2 Then
            IEXTERNALMAC = 0
            IDEFMAC = 1
            SZMAC = [M:SCH7]MAC(ITER)
            Read [MAC]MAC0=SZMAC
            If !fstat Then
              SZITM = [F:MAC]MACPDTCOD
              If [F:MAC]BPCNUM <> "" Then
                If SZBPC <> "" Then
                  If [F:MAC]BPCNUM <> SZBPC Then
                    IEXTERNALMAC = 1
                  Endif
                Endif
              Endif
            Endif
            SZPBL = [M:SCH7]PBL(ITER)
            Case [M:SCH7]COVFLG(ITER)
              When 1
                Case [M:SCH7]COVSPT(ITER)
                  When 1
                    If [M:SCH7]COVVCR(ITER) = "" Then
                      IINV = 1
                      IAMTINV = 0
                      ISOLVED = 1
                    Else
                      SZCON = [M:SCH7]COVVCR(ITER)
                      Gosub CHECKPIT
                    Endif
                  When 2,3,5
                    IINV = 1
                    IAMTINV = 0
                    ISOLVED = 1
                  When 4
                    ISOLVED = 1
                Endcase
              When 2
                If SZPBL = "" Then
                  Gosub DOPARTIALMAC
                Else
                  Gosub PARTIALMACPBL
                Endif
                SZCON = [M:SCH7]COVVCR(ITER)
              When 3
                ISOLVED = 1
            Endcase
            Break
          Endif
        Next
      Endif
    Else
      IEXTERNALMAC = 0
      SZMAC = [F:HDT]HDTMACSRE
      Read [MAC]MAC0=SZMAC
      If !fstat Then
        SZITM = [F:MAC]MACPDTCOD
        If [F:MAC]BPCNUM <> "" Then
          If SZBPC <> "" Then
            If [F:MAC]BPCNUM <> SZBPC Then
              IEXTERNALMAC = 1
            Endif
          Endif
        Endif
      Endif
      SZCPN = [F:HDT]HDTCPN
      For ITER = 0 To [M:SCH7]NBMAC-1
        If [M:SCH7]MAC(ITER) = [F:HDT]HDTMACSRE Then
          If [M:SCH7]MACDEF(ITER) = 2 Then
            IDEFMAC = 1
          Endif
          SZPBL = [M:SCH7]PBL(ITER)
          If SZCPN = "" Then
            Case [M:SCH7]COVFLG(ITER)
              When 1
                Case [M:SCH7]COVSPT(ITER)
                  When 1
                    If [M:SCH7]COVVCR(ITER) = "" Then
                      IINV = 1
                      IAMTINV = 0
                      ISOLVED = 1
                    Else
                      SZCON = [M:SCH7]COVVCR(ITER)
                      Gosub CHECKPIT
                    Endif
                  When 2,3,5
                    IINV = 1
                    IAMTINV = 0
                    ISOLVED = 1
                  When 4
                    ISOLVED = 1
                Endcase
              When 2
                If SZPBL = "" Then
                  Gosub DOPARTIALMAC
                Else
                  Gosub PARTIALMACPBL
                Endif
                SZCON = [M:SCH7]COVVCR(ITER)
              When 3
                ISOLVED = 1
            Endcase
          Else
            Gosub CHKSIMPLE
          Endif
          Break
        Endif
      Next
    Endif
  Endif
  If IERRINF Then
    End
  Endif
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    If ITRANSLINEPIT Then
      If IPITFLG Then
        If INULPIOVAL <> 2 Then
          Call REMORADDPIT(SZCONTEXT, INOL, SZBPC, SZCON, SZDEFMACPIT, SZMACFORPIT, SZCPNFORPIT, SZITMFORPIT, INBRPIT, IDEBFRY, SZDEBFRYBAS, IPIT, IERRINF)
        Endif
      Endif
    Endif
    #On arrondi le montant facturable renvoyé
    IARRAMTINV = IAMTINV
    IAMTINV = arr(IARRAMTINV,10^-GDECPRI)
    End
  Endif
  #Deuxième partie
  #Traitement des couvertures financières
  #Masque : MAC, CPN, PBL.
  If SZCON = "" Then
    #Le contrat de service n'a pas pu être lue. Le calcul du montant facturable est abandonné.
    IERRINF = 542
    End
  Endif
  Read [CON]CON0=SZCON
  If fstat Then
    #Le contrat de service n'a pas pu être lue. Le calcul du montant facturable est abandonné.
    IERRINF = 542
    End
  Endif
  SZAMTCASE = ""
  If SZMAC ="" Then
    If SZCPN = "" Then
      If SZPBL = "" Then
        End
      Else
        SZAMTCASE = "001"
      Endif
    Endif
  Else
    If SZCPN = "" Then
      If SZPBL = "" Then
        SZAMTCASE = "100"
      Else
        SZAMTCASE = "101"
      Endif
    Else
      If SZPBL = "" Then
        SZAMTCASE = "110"
      Else
        SZAMTCASE = "111"
      Endif
    Endif
  Endif
  If INBPARTIALCON > 1 Then
    #Recherche de la couverture partielle la plus favorable
    For ITERPARTIALCON = 0 To INBPARTIALCON-1
      Read [CON]CON0=SZPARTIALCON(ITERPARTIALCON)
      If !fstat Then
        SZCON = [F:CON]CONNUM
        SZCONCUR = [F:CON]CUR
        ICSMCSM = 0
        ICSMINV = 0
        IAMTINV = 0
        ISOLVED = 0
        IPARTRECFOUND = 0
        Case SZAMTCASE
          When "001"
            Gosub DO_001
          When "100"
            Gosub DO_100
          When "101"
            Gosub DO_101
          When "110"
            Gosub DO_110
          When "111"
            Gosub DO_111
        Endcase
        If IBTSTFIRSET = 0 Then
          If IAMTINV > 0 Then
            IFINALAMTINV = IAMTINV
            IBTSTFIRSET = 1
          Endif
        Else
          If IPARTRECFOUND Then
            If IAMTINV < IFINALAMTINV Then
              IFINALAMTINV = IAMTINV
            Endif
          Endif
        Endif
        #ITSTFIRLOOP += 1  # FGR 14/11/2012 : X3SUIVI85786 ne sert à rien et fait planter
      Endif
    Next
    #On arrondi le montant facturable renvoyé
    IARRAMTINV = IFINALAMTINV
    IAMTINV = arr(IARRAMTINV,10^-GDECPRI)
    If IAMTINV <= 0 Then
      IINV = 1
    Else
      IINV = 2
    Endif
  Else
    SZCONCUR = [F:CON]CUR
    Case SZAMTCASE
      When "001"
        Gosub DO_001
      When "100"
        Gosub DO_100
      When "101"
        Gosub DO_101
      When "110"
        Gosub DO_110
      When "111"
        Gosub DO_111
    Endcase
    #On arrondi le montant facturable renvoyé
    IARRAMTINV = IAMTINV
    IAMTINV = arr(IARRAMTINV,10^-GDECPRI)
  Endif
End

##########################################################################################################
# Traitement des cas simples pour une consommation avec parc saisi
################################################################
$CHKSIMPLE
  If SZCONTEXT = "SRE9" or SZCONTEXT = "HDT" Then
    If GREP = "C" Then
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]MACNUM = SZMAC and [F:SRN]CPNITM = SZCPN
    Elsif GREP = "D" Then
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]MACNUM = SZMAC and [F:SRN]CPNITM = SZCPN
    Else
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]MACNUM = SZMAC and [F:SRN]CPNITM = SZCPN
    Endif
  Elsif SZCONTEXT = "SCH" Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SCH0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]MACNUM = SZMAC and [F:SRN]CPNITM = SZCPN
  Elsif SZCONTEXT = "ITN8" Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:ITN0]SRVDEMNUM and [F:SRN]TPYFLG = 0 and [F:SRN]MACNUM = SZMAC and [F:SRN]CPNITM = SZCPN
  Endif
  For [SRN]
    Case [F:SRN]CPNCOVFLG
      When 1
        Case [F:SRN]CPNCOVSPT
          When 1
            If [F:SRN]CPNCOVVCR = "" Then
              IINV = 1
              IAMTINV = 0
              ISOLVED = 1
            Else
              SZCON = [F:SRN]CPNCOVVCR
              Gosub CHECKPIT
            Endif
          When 2,3,5
            IINV = 1
            IAMTINV = 0
            ISOLVED = 1
          When 4
            ISOLVED = 1
        Endcase
      When 2
        If SZPBL = "" Then
          Gosub DOPARTIALMAC
        Else
          Gosub PARTIALMACPBL
        Endif
        SZCON = [F:SRN]CPNCOVVCR
      When 3
        ISOLVED = 1
    Endcase
  Next
  Filter [SRN]
Return

##########################################################################################################
# Détermine le débit complémentaire de points d'une consommation
#################################################################
$CHECKPIT
Local Integer IPBDFOUND

  IPBDFOUND = 0
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on fait directement comme "If [F:CON]CONCAT <> 4 Then"
    # Pas la peine d'aller lire le contrat pour que la situation n'est pas possible
    IINV = 1
    IAMTINV = 0
    ISOLVED = 1
    Return
  Endif
  #
  If SZCON = "" Then
    #Le contrat de service n'a pas pu être lue. Le calcul du montant facturable est abandonné.
    IERRINF = 542
    Return
  Endif
  Read [CON]CON0=SZCON
  If fstat Then
    #Le contrat de service n'a pas pu être lue. Le calcul du montant facturable est abandonné.
    IERRINF = 542
    Return
  Endif
  If [F:CON]CONCAT <> 4 Then
    IINV = 1
    IAMTINV = 0
    ISOLVED = 1
    Return
  Endif
  #Recherche Client + PBL MAC
  Filter [PBD] Where [F:PBD]BPR = SZBPC and [F:PBD]ITMREF = SZITM and [F:PBD]PBL = SZPBL and [F:PBD]ITM = SZCSM
  For [PBD]
    Gosub SETPIT
  Next
  Filter [PBD]
  If IPBDFOUND Then
    Return
  Endif
  #Recherche PBL + MAC
  Filter [PBD] Where [F:PBD]BPR = "" and [F:PBD]ITMREF = SZITM and [F:PBD]PBL = SZPBL and [F:PBD]ITM = SZCSM
  For [PBD]
    Gosub SETPIT
  Next
  Filter [PBD]
  If IPBDFOUND Then
    Return
  Endif
  #Recherche Client
  Filter [PBD] Where [F:PBD]BPR = SZBPC and [F:PBD]ITMREF = "" and [F:PBD]PBL = "" and [F:PBD]ITM = SZCSM
  For [PBD]
    Gosub SETPIT
  Next
  Filter [PBD]
  If IPBDFOUND Then
    Return
  Endif
  #Recherche finale par défaut
  Filter [PBD] Where [F:PBD]BPR = "" and [F:PBD]ITMREF = "" and [F:PBD]PBL = "" and [F:PBD]ITM = SZCSM
  For [PBD]
    Gosub SETPIT
  Next
  Filter [PBD]
  If IPBDFOUND Then
    Return
  Endif
  #Pas de débit complémentaires. La consommation est totalement couverte.
  ISOLVED = 1
  IINV = 1
  IAMTINV = 0
  IPIT = 0
  IPITFLG = 1
Return

##########################################################################################################
# Calcul le débit de points complémentaires d'une consommation
################################################################
$SETPIT
Local Decimal ICNVCSM
Local Decimal ICNVPBD
Local Decimal ICOEFCSM
Local Decimal ICOEFPBD

  If [F:PBD]DEBFRY <= 0 Then
    Return
  Endif
  ICNVCSM = 0
  ICNVPBD = 0
  ICOEFCSM = 0
  ICOEFPBD = 0
  INBRPIT = [F:PBD]NBRPIT
  IDEBFRY = [F:PBD]DEBFRY
  SZDEBFRYBAS = [F:PBD]DEBFRYBAS
  INULPIOVAL = [F:PBD]NULPIOVAL
  #Contrôle qu'il y ait des points à débiter
  If [F:PBD]NBRPIT <= 0 Then
    If [F:PBD]NULPIOVAL = 2 Then
      IPIT = 0
      Gosub CSMPIT
      Return
    Endif
  Endif
  If SZUOM = [F:PBD]DEBFRYBAS Then
    #Pas de conversion à effectuer
    IPIT = ([F:PBD]NBRPIT * IQTY) / [F:PBD]DEBFRY
    #Consommation des points ou facturation complémentaire
    Gosub CSMPIT
    Return
  Else
    #Conversion nécesaire
    Read [ITM]ITM0=SZCSM
    If fstat Then
      Return
    Endif
    #Calcul de la quantité consommée en unité de stock
    Call SREC_COE(SZCSM, SZBPC, [F:ITM]STU, SZUOM, ICOEFCSM) From TRTVENQTE
    ICNVCSM = IQTY * ICOEFCSM
    #Calcul de la quantité à débiter en unité de stock
    Call SREC_COE([F:PBD]ITM, SZBPC, [F:ITM]STU, [F:PBD]DEBFRYBAS, ICOEFPBD) From TRTVENQTE
    ICNVPBD = [F:PBD]DEBFRY * ICOEFPBD
    IPIT = ([F:PBD]NBRPIT * ICNVCSM) / ICNVPBD
    #Consommation des points ou facturation complémentaire
    Gosub CSMPIT
    Return
  Endif
Return

##########################################################################################################
#Consommation de points sur un contrat
######################################################################
$CSMPIT
Local Integer ICONTOTPIT
Local Integer ICONPITCDT
Local Integer ICONPITREM
Local Integer IPITDEBFLG
Local Integer IPITCSM
Local Integer ICONTOK
Local Char SZLITCOD
Local Char SZHORHDTSEQ

  SZHORHDTSEQ = ""
  IPITCSM = IPIT
  Filter [PCT] Where [F:PCT]CONNUM = SZCON and [F:PCT]FGVCAH = 0
  ICONTOTPIT = 0
  For [PCT] PCT1
    ICONTOTPIT += [F:PCT]PIT
  Next
  Filter [PCT]
  If ICONTOTPIT < [F:CON]PITCDT Then
    #On ajoute la tolérance de point du contrat
    ICONPITCDT = [F:CON]PITCDT + ([F:CON]PITCDT * ([F:CON]PITTOL / 100))
    #On calcul le nombre de points maximum consommables sur ce contrat
    ICONPITREM = ICONPITCDT - ICONTOTPIT
    If IPITCSM <= ICONPITREM Then
      If ICONTOTPIT + IPITCSM >= [F:CON]PITCDT Then
        IPITCSM = [F:CON]PITCDT - ICONTOTPIT
      Endif
      Gosub CHECKINF
      If ICONTOK Then
        #On consomme
        If SZCONTEXT = "SRE9" Then
          #Il faut un identifiant à la consommation pour mobiliser des points.
          If [M:SRE9]HDTNUM(INOL) = "" Then
            If GREP = "C" Then
              Call CREPIT([M:SRE0]CRESEQ, 1, SZCON, "", "", "", "", [M:SRE9]HDTNUMSEQ(INOL), IPITCSM, 1, IERRINF) From SUBSREB2
            Elsif GREP = "D" Then
              Call CREPIT([M:SRE0]CRESEQ, 1, SZCON, "", "", "", "", [M:SRE9]HDTNUMSEQ(INOL), IPITCSM, 1, IERRINF) From SUBSREB2
            Else
              Call CREPIT([M:SRE0]SRENUM, 0, SZCON, "", "", "", "", [M:SRE9]HDTNUMSEQ(INOL), IPITCSM, 1, IERRINF) From SUBSREB2
            Endif
          Else
            If GREP = "C" Then
              Call CREPIT([M:SRE0]CRESEQ, 1, SZCON, "", "", "", [M:SRE9]HDTNUM(INOL), "", IPITCSM, 1, IERRINF) From SUBSREB2
            Elsif GREP = "D" Then
              Call CREPIT([M:SRE0]CRESEQ, 1, SZCON, "", "", "", [M:SRE9]HDTNUM(INOL), "", IPITCSM, 1, IERRINF) From SUBSREB2
            Else
              Call CREPIT([M:SRE0]SRENUM, 0, SZCON, "", "", "", [M:SRE9]HDTNUM(INOL), "", IPITCSM, 1, IERRINF) From SUBSREB2
            Endif
          Endif
        Elsif SZCONTEXT = "ITN8" Then
          If [M:ITN8]HDTNUM(INOL) = "" Then
            Call CREPIT([M:ITN0]SRVDEMNUM, 0, SZCON, "", "", "", "", [M:ITN8]HDTNUMSEQ(INOL), IPITCSM, 1, IERRINF) From SUBSREB2
          Else
            Call CREPIT([M:ITN0]SRVDEMNUM, 0, SZCON, "", "", "", [M:ITN8]HDTNUM(INOL), "", IPITCSM, 1, IERRINF) From SUBSREB2
          Endif
        Elsif SZCONTEXT = "ITN8HDT" Then
          Call CREPIT([M:ITN0]SRVDEMNUM, 0, SZCON, "", "", "", SZITN8HDTNUM, "", IPITCSM, 1, IERRINF) From SUBSREB2
        Elsif SZCONTEXT = "HDT" Then
          If GREP = "C" Then
            If ITRANSLINEPIT Then
              If ISECONDLOOP Then
                Call CREPIT([M:SRE0]CRESEQ, 1, SZCON, "", "", "", "", [M:SRE0]HORHDTSEQ, IPITCSM, 1, IERRINF) From SUBSREB2
              Else
                #Il faut un identifiant à la consommation pour mobiliser des points.
                Call FILLHORHDT([F:HDT]HDTNUM, SZHORHDTSEQ, IERRINF)
                If IERRINF Then
                  Return
                Endif
                Call CREPIT([M:SRE0]CRESEQ, 1, SZCON, "", "", "", "", SZHORHDTSEQ, IPITCSM, 1, IERRINF) From SUBSREB2
              Endif
            Endif
          Elsif GREP = "D" Then
            If ITRANSLINEPIT Then
              If ISECONDLOOP Then
                Call CREPIT([M:SRE0]CRESEQ, 1, SZCON, "", "", "", "", [M:SRE0]HORHDTSEQ, IPITCSM, 1, IERRINF) From SUBSREB2
              Else
                #Il faut un identifiant à la consommation pour mobiliser des points.
                Call FILLHORHDT([F:HDT]HDTNUM, SZHORHDTSEQ, IERRINF)
                If IERRINF Then
                  Return
                Endif
                Call CREPIT([M:SRE0]CRESEQ, 1, SZCON, "", "", "", "", SZHORHDTSEQ, IPITCSM, 1, IERRINF) From SUBSREB2
              Endif
            Endif
          Else
            Call CREPIT([M:SRE0]SRENUM, 0, SZCON, "", "", "", [F:HDT]HDTNUM, "", IPITCSM, 1, IERRINF) From SUBSREB2
          Endif
        Elsif SZCONTEXT = "SCH" Then
          #Il faut un identifiant à la consommation pour mobiliser des points.
          Call CREPIT([M:SCH0]SRENUM, 0, SZCON, "", "", "", [F:HDT]HDTNUM, "", IPITCSM, 1, IERRINF) From SUBSREB2
        Endif
        If IERRINF Then
          Return
        Endif
        IPIT = IPITCSM
        IPITFLG = 1
        IINV = 1
        IAMTINV = 0
        IPBDFOUND = 1
        ISOLVED = 1
      Else
        IPBDFOUND = 1
        ISOLVED = 1
      Endif
    Else
      IPBDFOUND = 1
      ISOLVED = 1
    Endif
  Else
    IPBDFOUND = 1
    ISOLVED = 1
  Endif
Return

##########################################################################################################
#Vérification de l'échéance et du réglement du contrat
$CHECKINF
  ICONTOK = 1
  If [F:CON]CONENDDAT < date$ Then
    ICONTOK = 0
  Else
    If [F:CON]CONSTRDAT > date$ Then
      ICONTOK = 0
    Else
      #Contrôle du réglement du contrat
      SZLITCOD = ""
      Call CHECKPAY(SZCON, SZBPC, SZLITCOD, ICONTOK) From TRTCOVER
      If !ICONTOK Then
        If SZLITCOD <> "" Then
          Call CHECK2LIT(SZCON, SZLITCOD, ICONTOK) From TRTCOVER
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Suppression du débit de points complémentaires d'une consommation
####################################################################
Subprog DELPIT(SZCONTEXT, INOL, IERRINF)
Value Char SZCONTEXT
Value Integer INOL
Variable Integer IERRINF

Local Integer ITRANSFLG
Local Char SZSRENUM
Local Integer ITPYFLG
Local Char SZHDTNUM
Local Char SZHDTNUMSEQ

  IERRINF = 0
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  If adxlog Then
    ITRANSFLG = 1
  Else
    ITRANSFLG = 0
  Endif
  If SZCONTEXT = "SRE9" Then
    SZHDTNUM = [M:SRE9]HDTNUM(INOL)
    SZHDTNUMSEQ = [M:SRE9]HDTNUMSEQ(INOL)
    If GREP = "C" Then
      SZSRENUM = [M:SRE0]CRESEQ
      ITPYFLG = 1
    Elsif GREP = "D" Then
      SZSRENUM = [M:SRE0]CRESEQ
      ITPYFLG = 1
    Else
      SZSRENUM = [M:SRE0]SRENUM
      ITPYFLG = 0
    Endif
  Elsif SZCONTEXT = "ITN8" Then
    SZHDTNUM = [M:ITN8]HDTNUM(INOL)
    SZHDTNUMSEQ = [M:ITN8]HDTNUMSEQ(INOL)
    SZSRENUM = [M:ITN0]SRVDEMNUM
    ITPYFLG = 0
  Elsif SZCONTEXT = "HDT" Then
    SZHDTNUM = [F:HDT]HDTNUM
    SZHDTNUMSEQ = ""
    If GREP = "C" Then
      End
    Elsif GREP = "D" Then
      End
    Else
      SZSRENUM = [M:SRE0]SRENUM
      ITPYFLG = 0
    Endif
  Elsif SZCONTEXT = "SCH" Then
    SZHDTNUM = [F:HDT]HDTNUM
    SZHDTNUMSEQ = ""
    SZSRENUM = [M:SCH0]SRENUM
    ITPYFLG = 0
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [PCT]
  Endif
  If SZHDTNUM <> "" Then
    Delete [PCT] Where [F:PCT]SRENUM = SZSRENUM and [F:PCT]TPYFLG = ITPYFLG and [F:PCT]FGVCAH = 0 and [F:PCT]PITTYP = 2 and [F:PCT]HDT = SZHDTNUM and [F:PCT]SAT <> 2
    If fstat Then
      #Erreur de la suppression des débits de points complémentaires. Le calcul du montant facturable est abandonné.
      IERRINF = 543
      If !ITRANSFLG Then
        Rollback
      Endif
      End
    Endif
    #Suppression du contrôle de session associé au point
    Delete [DVA] Where [F:DVA]OBC = "PIT" and [F:DVA]ALHX(1) = SZSRENUM and [F:DVA]INTX(2) = ITPYFLG and [F:DVA]INTX(3) = 2 and [F:DVA]ALHX(5) = SZHDTNUM
    If fstat Then
      #Erreur de la suppression des débits de points complémentaires. Le calcul du montant facturable est abandonné.
      IERRINF = 543
      If !ITRANSFLG Then
        Rollback
      Endif
      End
    Endif
  Endif
  If SZHDTNUMSEQ <> "" Then
    Delete [PCT] Where [F:PCT]SRENUM = SZSRENUM and [F:PCT]TPYFLG = ITPYFLG and [F:PCT]FGVCAH = 0 and [F:PCT]PITTYP = 2 and [F:PCT]HDTSEQ = SZHDTNUMSEQ and [F:PCT]SAT <> 2
    If fstat Then
      #Erreur de la suppression des débits de points complémentaires. Le calcul du montant facturable est abandonné.
      IERRINF = 543
      If !ITRANSFLG Then
        Rollback
      Endif
      End
    Endif
    #Suppression du contrôle de session associé au point
    Delete [DVA] Where [F:DVA]OBC = "PIT" and [F:DVA]ALHX(1) = SZSRENUM and [F:DVA]INTX(2) = ITPYFLG and [F:DVA]INTX(3) = 2 and [F:DVA]ALHX(6) = SZHDTNUMSEQ
    If fstat Then
      #Erreur de la suppression des débits de points complémentaires. Le calcul du montant facturable est abandonné.
      IERRINF = 543
      If !ITRANSFLG Then
        Rollback
      Endif
      End
    Endif
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
End

##########################################################################################################
# Montant pour une consommation relative à une compétence
####################################################
$DO_001
  #Calcul du montant total déjà consommé pour cet article.
  If SZCONTEXT = "SRE9" Then
    For ITER = 0 To [M:SRE9]NBLIG-1
      If ITER <> INOL Then
        If [M:SRE9]HDTMACSRE(ITER) = "" Then
          If [M:SRE9]HDTCPN(ITER) = "" Then
            If [M:SRE9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SRE9]HDTAMT(ITER)
              ICSMINV += [M:SRE9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "ITN8" Then
    For ITER = 0 To [M:ITN8]NBLIG-1
      If ITER <> INOL Then
        If [M:ITN8]HDTMACSRE(ITER) = "" Then
          If [M:ITN8]HDTCPN(ITER) = "" Then
            If [M:ITN8]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:ITN8]HDTAMT(ITER)
              ICSMINV += [M:ITN8]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "HDT" Then
    For ITER = 0 To [M:SRE9]NBLIG-1
      If [M:SRE9]HDTNUM(ITER) <> [F:HDT]HDTNUM Then
        If [M:SRE9]HDTMACSRE(ITER) = "" Then
          If [M:SRE9]HDTCPN(ITER) = "" Then
            If [M:SRE9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SRE9]HDTAMT(ITER)
              ICSMINV += [M:SRE9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "SCH" Then
    For ITER = 0 To [M:SCH9]NBLIG-1
      If [M:SCH9]HDTNUM(ITER) <> [F:HDT]HDTNUM Then
        If [M:SCH9]HDTMACSRE(ITER) = "" Then
          If [M:SCH9]HDTCPN(ITER) = "" Then
            If [M:SCH9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SCH9]HDTAMT(ITER)
              ICSMINV += [M:SCH9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  #Recherche des couvertures listées
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "AAA"
&                and [F:CCV]SBBRECTYP = SZCSMTYP
&                and [F:CCV]RECNUM = SZCSM
&                and [F:CCV]PAEKEY(0) = SZPBL
&                and [F:CCV]PAEKEY(1) = ""
&                and [F:CCV]PAEKEY(2) = ""
  For [CCV]CCV1
    IICDFLG = [F:CCV]ICDFLG
    ICCVHEIPRC = [F:CCV]HEIPRC(0)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(0)
      ICCVMAXCOV = [F:CCV]MAXCOV(0)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(0), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(0), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Recherche des couvertures non listées
  ICSMCSM = 0
  ICSMINV = 0
  ICCVMINCOV = 0
  ICCVMAXCOV = 0
  Filter [CCV] Where [F:CCV]CONNUM = SZCON and [F:CCV]TPL <> 2 and [F:CCV]BPC = SZBPC and [F:CCV]RECTYP = "PBL" and [F:CCV]RECNUM = SZPBL
  For [CCV]CCV1
    Case ICSMTYP
      When 0
        If [F:CCV]ITMICDFLG = 0 Then
          If GITMICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GITMICD
          Endif
        Else
          IICDFLG = [F:CCV]ITMICDFLG
        Endif
      When 1
        If [F:CCV]LABICDFLG = 0 Then
          If GLABICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GLABICD
          Endif
        Else
          IICDFLG = [F:CCV]LABICDFLG
        Endif
      When 2
        If [F:CCV]EXSICDFLG = 0 Then
          If GEXSICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GEXSICD
          Endif
        Else
          IICDFLG = [F:CCV]EXSICDFLG
        Endif
    Endcase
    ICCVHEIPRC = [F:CCV]HEIPRC(ICSMTYP)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(ICSMTYP)
      ICCVMAXCOV = [F:CCV]MAXCOV(ICSMTYP)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(ICSMTYP), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
Return

##########################################################################################################
# Montant pour une consommation relative à une fiche parc
####################################################
$DO_100
  #Calcul du montant total déjà consommé pour cet article.
  If SZCONTEXT = "SRE9" Then
    For ITER = 0 To [M:SRE9]NBLIG-1
      If ITER <> INOL Then
        ISAMEMAC = 0
        If [M:SRE9]HDTMACSRE(ITER) = "" Then
          If IDEFMAC Then
            ISAMEMAC = 1
          Endif
        Else
          If [M:SRE9]HDTMACSRE(ITER) = SZMAC Then
            ISAMEMAC = 1
          Endif
        Endif
        If ISAMEMAC Then
          If [M:SRE9]HDTCPN(ITER) = "" Then
            If [M:SRE9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SRE9]HDTAMT(ITER)
              ICSMINV += [M:SRE9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "ITN8" Then
    For ITER = 0 To [M:ITN8]NBLIG-1
      If ITER <> INOL Then
        ISAMEMAC = 0
        If [M:ITN8]HDTMACSRE(ITER) = "" Then
          If IDEFMAC Then
            ISAMEMAC = 1
          Endif
        Else
          If [M:ITN8]HDTMACSRE(ITER) = SZMAC Then
            ISAMEMAC = 1
          Endif
        Endif
        If ISAMEMAC Then
          If [M:ITN8]HDTCPN(ITER) = "" Then
            If [M:ITN8]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:ITN8]HDTAMT(ITER)
              ICSMINV += [M:ITN8]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "HDT" Then
    For ITER = 0 To [M:SRE9]NBLIG-1
      If [M:SRE9]HDTNUM(ITER) <> [F:HDT]HDTNUM Then
        ISAMEMAC = 0
        If [M:SRE9]HDTMACSRE(ITER) = "" Then
          If IDEFMAC Then
            ISAMEMAC = 1
          Endif
        Else
          If [M:SRE9]HDTMACSRE(ITER) = SZMAC Then
            ISAMEMAC = 1
          Endif
        Endif
        If ISAMEMAC Then
          If [M:SRE9]HDTCPN(ITER) = "" Then
            If [M:SRE9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SRE9]HDTAMT(ITER)
              ICSMINV += [M:SRE9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "SCH" Then
    For ITER = 0 To [M:SCH9]NBLIG-1
      If [M:SCH9]HDTNUM(ITER) <> [F:HDT]HDTNUM Then
        ISAMEMAC = 0
        If [M:SCH9]HDTMACSRE(ITER) = "" Then
          If IDEFMAC Then
            ISAMEMAC = 1
          Endif
        Else
          If [M:SCH9]HDTMACSRE(ITER) = SZMAC Then
            ISAMEMAC = 1
          Endif
        Endif
        If ISAMEMAC Then
          If [M:SCH9]HDTCPN(ITER) = "" Then
            If [M:SCH9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SCH9]HDTAMT(ITER)
              ICSMINV += [M:SCH9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  #---------------------------------------------------#
  # Etape 1
  # Couverture de niveau parc
  #---------------------------------------------------#
  #Recherche des couvertures listées
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "AAA"
&                and [F:CCV]SBBRECTYP = SZCSMTYP
&                and [F:CCV]RECNUM = SZCSM
&                and [F:CCV]CMT = SZMAC
&                and [F:CCV]CPNSRT = "CAAACPNMAC"
&                and [F:CCV]PAEKEY(0) = ""
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = ""
&                and [F:CCV]PAEKEYTYP(1) = "MAC"
  For [CCV]CCV1
    IICDFLG = [F:CCV]ICDFLG
    ICCVHEIPRC = [F:CCV]HEIPRC(0)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(0)
      ICCVMAXCOV = [F:CCV]MAXCOV(0)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(0), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(0), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Recherche des couvertures non listées
  ICCVMINCOV = 0
  ICCVMAXCOV = 0
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "MAC"
&                and [F:CCV]SBBRECTYP = "MAC"
&                and [F:CCV]RECNUM <> ""
&                and [F:CCV]CMT = SZMAC
&                and [F:CCV]CPNSRT = "CMACMAC"
&                and [F:CCV]PAEKEY(0) = ""
&                and [F:CCV]PAEKEY(1) = ""
&                and [F:CCV]PAEKEY(2) = ""
  For [CCV]CCV1
    Case ICSMTYP
      When 0
        If [F:CCV]ITMICDFLG = 0 Then
          If GITMICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GITMICD
          Endif
        Else
          IICDFLG = [F:CCV]ITMICDFLG
        Endif
      When 1
        If [F:CCV]LABICDFLG = 0 Then
          If GLABICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GLABICD
          Endif
        Else
          IICDFLG = [F:CCV]LABICDFLG
        Endif
      When 2
        If [F:CCV]EXSICDFLG = 0 Then
          If GEXSICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GEXSICD
          Endif
        Else
          IICDFLG = [F:CCV]EXSICDFLG
        Endif
    Endcase
    ICCVHEIPRC = [F:CCV]HEIPRC(ICSMTYP)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(ICSMTYP)
      ICCVMAXCOV = [F:CCV]MAXCOV(ICSMTYP)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(ICSMTYP), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Si parc externe. On s'arrête la.
  If IEXTERNALMAC Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 2
  # Couverture de niveau référence article
  #---------------------------------------------------#
  Read [MAC]MAC0=SZMAC
  If fstat Then
    #Le parc concerné par la consommation n'a pas pu être lue. Le calcul du montant facturable est abandonné.
    IERRINF = 544
    Return
  Endif
  If [F:MAC]MACPDTCOD = "" Then
    #Le parc concerné par la consommation ne comporte pas de code article. Le calcul du montant facturable est abandonné.
    IERRINF = 545
    Return
  Endif
  #Recherche des couvertures listées
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "AAA"
&                and [F:CCV]SBBRECTYP = SZCSMTYP
&                and [F:CCV]RECNUM = SZCSM
&                and [F:CCV]CMT = [F:MAC]MACPDTCOD
&                and [F:CCV]CPNSRT = "BAAACPNITM"
&                and [F:CCV]PAEKEY(0) = ""
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = ""
&                and [F:CCV]PAEKEYTYP(1) = "ITM"
  For [CCV]CCV1
    IICDFLG = [F:CCV]ICDFLG
    ICCVHEIPRC = [F:CCV]HEIPRC(0)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(0)
      ICCVMAXCOV = [F:CCV]MAXCOV(0)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(0), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(0), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Recherche des couvertures non listées
  ICCVMINCOV = 0
  ICCVMAXCOV = 0
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "MAC"
&                and [F:CCV]SBBRECTYP = "ITM"
&                and [F:CCV]RECNUM <> ""
&                and [F:CCV]CMT = [F:MAC]MACPDTCOD
&                and [F:CCV]CPNSRT = "BMACITM"
&                and [F:CCV]PAEKEY(0) = ""
&                and [F:CCV]PAEKEY(1) = ""
&                and [F:CCV]PAEKEY(2) = ""
  For [CCV]CCV1
    Case ICSMTYP
      When 0
        If [F:CCV]ITMICDFLG = 0 Then
          If GITMICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GITMICD
          Endif
        Else
          IICDFLG = [F:CCV]ITMICDFLG
        Endif
      When 1
        If [F:CCV]LABICDFLG = 0 Then
          If GLABICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GLABICD
          Endif
        Else
          IICDFLG = [F:CCV]LABICDFLG
        Endif
      When 2
        If [F:CCV]EXSICDFLG = 0 Then
          If GEXSICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GEXSICD
          Endif
        Else
          IICDFLG = [F:CCV]EXSICDFLG
        Endif
    Endcase
    ICCVHEIPRC = [F:CCV]HEIPRC(ICSMTYP)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(ICSMTYP)
      ICCVMAXCOV = [F:CCV]MAXCOV(ICSMTYP)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(ICSMTYP), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 3
  # Couverture de niveau famille commerciale de produit
  #---------------------------------------------------#
  Read [ITM]ITM0=[F:MAC]MACPDTCOD
  If fstat Then
    #L'article concerné par la consommation n'a pas pu être lue. Le calcul du montant facturable est abandonné.
    IERRINF = 546
    Return
  Endif
  #Recherche des couvertures listées
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "AAA"
&                and [F:CCV]SBBRECTYP = SZCSMTYP
&                and [F:CCV]RECNUM = SZCSM
&                and [F:CCV]CMT = [F:ITM]TSICOD(GFAMCIA-1)
&                and [F:CCV]CPNSRT = "AAAACPNCIA"
&                and [F:CCV]PAEKEY(0) = ""
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = ""
&                and [F:CCV]PAEKEYTYP(1) = "CIA"
  For [CCV]CCV1
    IICDFLG = [F:CCV]ICDFLG
    ICCVHEIPRC = [F:CCV]HEIPRC(0)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(0)
      ICCVMAXCOV = [F:CCV]MAXCOV(0)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(0), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(0), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Recherche des couvertures non listées
  ICCVMINCOV = 0
  ICCVMAXCOV = 0
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "MAC"
&                and [F:CCV]SBBRECTYP = "CIA"
&                and [F:CCV]RECNUM <> ""
&                and [F:CCV]CMT = [F:ITM]TSICOD(GFAMCIA-1)
&                and [F:CCV]CPNSRT = "AMACCIA"
&                and [F:CCV]PAEKEY(0) = ""
&                and [F:CCV]PAEKEY(1) = ""
&                and [F:CCV]PAEKEY(2) = ""
  For [CCV]CCV1
    Case ICSMTYP
      When 0
        If [F:CCV]ITMICDFLG = 0 Then
          If GITMICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GITMICD
          Endif
        Else
          IICDFLG = [F:CCV]ITMICDFLG
        Endif
      When 1
        If [F:CCV]LABICDFLG = 0 Then
          If GLABICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GLABICD
          Endif
        Else
          IICDFLG = [F:CCV]LABICDFLG
        Endif
      When 2
        If [F:CCV]EXSICDFLG = 0 Then
          If GEXSICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GEXSICD
          Endif
        Else
          IICDFLG = [F:CCV]EXSICDFLG
        Endif
    Endcase
    ICCVHEIPRC = [F:CCV]HEIPRC(ICSMTYP)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(ICSMTYP)
      ICCVMAXCOV = [F:CCV]MAXCOV(ICSMTYP)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(ICSMTYP), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
Return

##########################################################################################################
# Montant pour une consommation relative à une fiche parc + compétence
####################################################
$DO_101
  #Calcul du montant total déjà consommé pour cet article.
  If SZCONTEXT = "SRE9" Then
    For ITER = 0 To [M:SRE9]NBLIG-1
      If ITER <> INOL Then
        ISAMEMAC = 0
        If [M:SRE9]HDTMACSRE(ITER) = "" Then
          If IDEFMAC Then
            ISAMEMAC = 1
          Endif
        Else
          If [M:SRE9]HDTMACSRE(ITER) = SZMAC Then
            ISAMEMAC = 1
          Endif
        Endif
        If ISAMEMAC Then
          If [M:SRE9]HDTCPN(ITER) = "" Then
            If [M:SRE9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SRE9]HDTAMT(ITER)
              ICSMINV += [M:SRE9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "ITN8" Then
    For ITER = 0 To [M:ITN8]NBLIG-1
      If ITER <> INOL Then
        ISAMEMAC = 0
        If [M:ITN8]HDTMACSRE(ITER) = "" Then
          If IDEFMAC Then
            ISAMEMAC = 1
          Endif
        Else
          If [M:ITN8]HDTMACSRE(ITER) = SZMAC Then
            ISAMEMAC = 1
          Endif
        Endif
        If ISAMEMAC Then
          If [M:ITN8]HDTCPN(ITER) = "" Then
            If [M:ITN8]HDTITM(ITER) = SZCSM
              ICSMCSM += [M:ITN8]HDTAMT(ITER)
              ICSMINV += [M:ITN8]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "HDT" Then
    For ITER = 0 To [M:SRE9]NBLIG-1
      If [M:SRE9]HDTNUM(ITER) <> [F:HDT]HDTNUM Then
        ISAMEMAC = 0
        If [M:SRE9]HDTMACSRE(ITER) = "" Then
          If IDEFMAC Then
            ISAMEMAC = 1
          Endif
        Else
          If [M:SRE9]HDTMACSRE(ITER) = SZMAC Then
            ISAMEMAC = 1
          Endif
        Endif
        If ISAMEMAC Then
          If [M:SRE9]HDTCPN(ITER) = "" Then
            If [M:SRE9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SRE9]HDTAMT(ITER)
              ICSMINV += [M:SRE9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "SCH" Then
    For ITER = 0 To [M:SCH9]NBLIG-1
      If [M:SCH9]HDTNUM(ITER) <> [F:HDT]HDTNUM Then
        ISAMEMAC = 0
        If [M:SCH9]HDTMACSRE(ITER) = "" Then
          If IDEFMAC Then
            ISAMEMAC = 1
          Endif
        Else
          If [M:SCH9]HDTMACSRE(ITER) = SZMAC Then
            ISAMEMAC = 1
          Endif
        Endif
        If ISAMEMAC Then
          If [M:SCH9]HDTCPN(ITER) = "" Then
            If [M:SCH9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SCH9]HDTAMT(ITER)
              ICSMINV += [M:SCH9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  #---------------------------------------------------#
  # Etape 1
  # Couverture de niveau parc
  #---------------------------------------------------#
  #Recherche des couvertures listées
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "AAA"
&                and [F:CCV]SBBRECTYP = SZCSMTYP
&                and [F:CCV]RECNUM = SZCSM
&                and [F:CCV]CMT = SZMAC
&                and [F:CCV]CPNSRT = "CAAACPNMAC"
&                and [F:CCV]PAEKEY(0) = SZPBL
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = ""
&                and [F:CCV]PAEKEYTYP(1) = "MAC"
  For [CCV]CCV1
    IICDFLG = [F:CCV]ICDFLG
    ICCVHEIPRC = [F:CCV]HEIPRC(0)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(0)
      ICCVMAXCOV = [F:CCV]MAXCOV(0)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(0), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(0), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Recherche des couvertures non listées
  ICSMCSM = 0
  ICSMINV = 0
  ICCVMINCOV = 0
  ICCVMAXCOV = 0
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "MAC"
&                and [F:CCV]SBBRECTYP = "MAC"
&                and [F:CCV]RECNUM <> ""
&                and [F:CCV]CMT = SZMAC
&                and [F:CCV]CPNSRT = "CMACMAC"
&                and [F:CCV]PAEKEY(0) = SZPBL
&                and [F:CCV]PAEKEY(1) = ""
&                and [F:CCV]PAEKEY(2) = ""
  For [CCV]CCV1
    Case ICSMTYP
      When 0
        If [F:CCV]ITMICDFLG = 0 Then
          If GITMICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GITMICD
          Endif
        Else
          IICDFLG = [F:CCV]ITMICDFLG
        Endif
      When 1
        If [F:CCV]LABICDFLG = 0 Then
          If GLABICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GLABICD
          Endif
        Else
          IICDFLG = [F:CCV]LABICDFLG
        Endif
      When 2
        If [F:CCV]EXSICDFLG = 0 Then
          If GEXSICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GEXSICD
          Endif
        Else
          IICDFLG = [F:CCV]EXSICDFLG
        Endif
    Endcase
    ICCVHEIPRC = [F:CCV]HEIPRC(ICSMTYP)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(ICSMTYP)
      ICCVMAXCOV = [F:CCV]MAXCOV(ICSMTYP)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(ICSMTYP), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Si parc externe. On s'arrête la.
  If IEXTERNALMAC Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 2
  # Couverture de niveau référence article
  #---------------------------------------------------#
  Read [MAC]MAC0=SZMAC
  If fstat Then
    #Le parc concerné par la consommation n'a pas pu être lue. Le calcul du montant facturable est abandonné.
    IERRINF = 544
    Return
  Endif
  If [F:MAC]MACPDTCOD = "" Then
    #Le parc concerné par la consommation ne comporte pas de code article. Le calcul du montant facturable est abandonné.
    IERRINF = 545
    Return
  Endif
  #Recherche des couvertures listées
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "AAA"
&                and [F:CCV]SBBRECTYP = SZCSMTYP
&                and [F:CCV]RECNUM = SZCSM
&                and [F:CCV]CMT = [F:MAC]MACPDTCOD
&                and [F:CCV]CPNSRT = "BAAACPNITM"
&                and [F:CCV]PAEKEY(0) = SZPBL
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = ""
&                and [F:CCV]PAEKEYTYP(1) = "ITM"
  For [CCV]CCV1
    IICDFLG = [F:CCV]ICDFLG
    ICCVHEIPRC = [F:CCV]HEIPRC(0)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(0)
      ICCVMAXCOV = [F:CCV]MAXCOV(0)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(0), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(0), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Recherche des couvertures non listées
  ICSMCSM = 0
  ICSMINV = 0
  ICCVMINCOV = 0
  ICCVMAXCOV = 0
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "MAC"
&                and [F:CCV]SBBRECTYP = "ITM"
&                and [F:CCV]RECNUM <> ""
&                and [F:CCV]CMT = [F:MAC]MACPDTCOD
&                and [F:CCV]CPNSRT = "BMACITM"
&                and [F:CCV]PAEKEY(0) = SZPBL
&                and [F:CCV]PAEKEY(1) = ""
&                and [F:CCV]PAEKEY(2) = ""
  For [CCV]CCV1
    Case ICSMTYP
      When 0
        If [F:CCV]ITMICDFLG = 0 Then
          If GITMICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GITMICD
          Endif
        Else
          IICDFLG = [F:CCV]ITMICDFLG
        Endif
      When 1
        If [F:CCV]LABICDFLG = 0 Then
          If GLABICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GLABICD
          Endif
        Else
          IICDFLG = [F:CCV]LABICDFLG
        Endif
      When 2
        If [F:CCV]EXSICDFLG = 0 Then
          If GEXSICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GEXSICD
          Endif
        Else
          IICDFLG = [F:CCV]EXSICDFLG
        Endif
    Endcase
    ICCVHEIPRC = [F:CCV]HEIPRC(ICSMTYP)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(ICSMTYP)
      ICCVMAXCOV = [F:CCV]MAXCOV(ICSMTYP)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(ICSMTYP), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 3
  # Couverture de niveau famille commerciale de produit
  #---------------------------------------------------#
  Read [ITM]ITM0=[F:MAC]MACPDTCOD
  If fstat Then
    #L'article concerné par la consommation n'a pas pu être lue. Le calcul du montant facturable est abandonné.
    IERRINF = 546
    Return
  Endif
  #Recherche des couvertures listées
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "AAA"
&                and [F:CCV]SBBRECTYP = SZCSMTYP
&                and [F:CCV]RECNUM = SZCSM
&                and [F:CCV]CMT = [F:ITM]TSICOD(GFAMCIA-1)
&                and [F:CCV]CPNSRT = "AAAACPNCIA"
&                and [F:CCV]PAEKEY(0) = SZPBL
&                and [F:CCV]PAEKEY(1) <> ""
&                and [F:CCV]PAEKEY(2) = ""
&                and [F:CCV]PAEKEYTYP(1) = "CIA"
  For [CCV]CCV1
    IICDFLG = [F:CCV]ICDFLG
    ICCVHEIPRC = [F:CCV]HEIPRC(0)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(0)
      ICCVMAXCOV = [F:CCV]MAXCOV(0)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(0), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(0), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
  #Recherche des couvertures non listées
  ICSMCSM = 0
  ICSMINV = 0
  ICCVMINCOV = 0
  ICCVMAXCOV = 0
  Filter [CCV] Where [F:CCV]CONNUM = SZCON
&                and [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPC
&                and [F:CCV]RECTYP = "MAC"
&                and [F:CCV]SBBRECTYP = "CIA"
&                and [F:CCV]RECNUM <> ""
&                and [F:CCV]CMT = [F:ITM]TSICOD(GFAMCIA-1)
&                and [F:CCV]CPNSRT = "AMACCIA"
&                and [F:CCV]PAEKEY(0) = SZPBL
&                and [F:CCV]PAEKEY(1) = ""
&                and [F:CCV]PAEKEY(2) = ""
  For [CCV]CCV1
    Case ICSMTYP
      When 0
        If [F:CCV]ITMICDFLG = 0 Then
          If GITMICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GITMICD
          Endif
        Else
          IICDFLG = [F:CCV]ITMICDFLG
        Endif
      When 1
        If [F:CCV]LABICDFLG = 0 Then
          If GLABICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GLABICD
          Endif
        Else
          IICDFLG = [F:CCV]LABICDFLG
        Endif
      When 2
        If [F:CCV]EXSICDFLG = 0 Then
          If GEXSICD = 0 Then
            IICDFLG = 1
          Else
            IICDFLG = GEXSICD
          Endif
        Else
          IICDFLG = [F:CCV]EXSICDFLG
        Endif
    Endcase
    ICCVHEIPRC = [F:CCV]HEIPRC(ICSMTYP)
    If SZCONCUR = SZSRECUR Then
      ICCVMINCOV = [F:CCV]MINCOV(ICSMTYP)
      ICCVMAXCOV = [F:CCV]MAXCOV(ICSMTYP)
    Else
      #On converti
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MINCOV(ICSMTYP), ICCVMINCOV) From SUBCOND
      Call SETCOVAMT(SZFCY, SZCONCUR, SZSRECUR, [F:CCV]MAXCOV(ICSMTYP), ICCVMAXCOV) From SUBCOND
    Endif
    Gosub CPTINV
  Next
  Filter [CCV]
  #Si le montant a déjà pu être déterminé. On s'arrête la.
  If ISOLVED Then
    Return
  Endif
Return

##########################################################################################################
# Montant pour une consommation relative à une fiche parc + composant
####################################################
$DO_110
  #Calcul du montant total déjà consommé pour cet article.
  If SZCONTEXT = "SRE9" Then
    For ITER = 0 To [M:SRE9]NBLIG-1
      If ITER <> INOL Then
        If [M:SRE9]HDTMACSRE(ITER) = SZMAC Then
          If [M:SRE9]HDTCPN(ITER) = SZCPN Then
            If [M:SRE9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SRE9]HDTAMT(ITER)
              ICSMINV += [M:SRE9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "ITN8" Then
    For ITER = 0 To [M:ITN8]NBLIG-1
      If ITER <> INOL Then
        If [M:ITN8]HDTMACSRE(ITER) = SZMAC Then
          If [M:ITN8]HDTCPN(ITER) = SZCPN Then
            If [M:ITN8]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:ITN8]HDTAMT(ITER)
              ICSMINV += [M:ITN8]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "HDT" Then
    For ITER = 0 To [M:SRE9]NBLIG-1
      If [M:SRE9]HDTNUM(ITER) <> [F:HDT]HDTNUM Then
        If [M:SRE9]HDTMACSRE(ITER) = SZMAC Then
          If [M:SRE9]HDTCPN(ITER) = SZCPN Then
            If [M:SRE9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SRE9]HDTAMT(ITER)
              ICSMINV += [M:SRE9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Elsif SZCONTEXT = "SCH" Then
    For ITER = 0 To [M:SCH9]NBLIG-1
      If [M:SCH9]HDTNUM(ITER) <> [F:HDT]HDTNUM Then
        If [M:SCH9]HDTMACSRE(ITER) = SZMAC Then
          If [M:SCH9]HDTCPN(ITER) = SZCPN Then
            If [M:SCH9]HDTITM(ITER) = SZCSM Then
              ICSMCSM += [M:SCH9]HDTAMT(ITER)
              ICSMINV += [M:SCH9]HDTAMTINV(ITER)
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
