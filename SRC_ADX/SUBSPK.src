#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du fichier STKTRS

#######################################################################
# SUBSPK : Transactions de colisage                                   #
# [F:SRT]PKGTYP = 1        # colisage declaratif                      #
# [F:SRT]PKGTYP = 2        # post colisage                            #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SRT]STKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWP]AWINBRO  Table des browser fenêtres    #
#                       [F:AWP]AWINBOUT Table des boutons fenêtres    #
#                                                                     #
# Génération de 1 écran de saisie à partir des écrans de base         #
#                                                                     #
# Nom des écrans générés : WT11yyy                                    #
#                          yyy = nom de la transaction (SRTNUM)       #
#                                                                     #
#######################################################################
Call OBJET("SPK",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:SPK0]SRTTYP = 11
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="STKTRS" & IDENT1=num$([F:SRT]SRTTYP) & IDENT2=[F:SRT]SRTNUM
                      Gosub TRT_ECRAN
 When "AV_IMPRIME"   : Gosub COP_ECRAN
 When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBETR : # Sélection sur code pièce auto
 When "FERME"        : Call IMPSCR        From ATRTX3
 When Default
Endcase
Return

$PE_STKTRS

Gosub PE_STKTRS From SUBSKX
Return

############################################################
$COP_ECRAN
Local Char WINT(20)(2)
Local Char WTIT(100)
Local Char WMSK(10)(3)
Local Char WABR(06)(3)
#
Raz WMSK, WABR
Call TEXTFIC("STKTRS","TRSNUM",2,WINT(0)) From OBJDIV
Call TEXTFIC("STKTRS","ACSCOD",2,WINT(1)) From OBJDIV
WTIT = WINT(0)+" : "+[M:SPK0]SRTNUM-[M:SPK0]DESAXX-WINT(1)+" : "+[M:SPK0]ACSCOD
WMSK(0) = "SPK1"
Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock
Local Char     APPLI            : APPLI=nomap
Local Char     WMODU(3)         : WMODU="T"
Local Integer  WNUM(2)          : WNUM = 2
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WENAFLG
Local Char     WABR(5)
Return

#-----------------------------------------------------------#
#                                                           #
#-----------------------------------------------------------#
$FILTRE

 FILTSUP = "SRTTYP=11"

Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
    If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case BOUT
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When "2" :
  When Default
Endcase
Return

#------------------------------------------------------------#
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
#-- Positionnement des valeurs si non renseignées
#** Onglet entête
If [M:SPK0]ENAFLG=0 [M:SPK0]ENAFLG=2         : Endif

Gosub TRT_SPK1


WMODU +=format$("N0:2",[M:SPK0]SRTTYP)

Gosub PE_STKTRS
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
[M:SPK0]ENAFLG=2
Gosub VAL_DEFAUT

Actzo [SPK0]

WMODU +=format$("N0:2",[M:SPK0]SRTTYP)

Gosub PE_STKTRS
Affzo [SPK0]1-99
Return
#---------------------------------------#
# gestion affichage ecran SPK1          #
#---------------------------------------#
$VAL_DEFAUT

Raz [M:SPK1]
[M:SPK1]PKGTYP=1     : # declaratif/post-colisage
Gosub TRT_SPK1

Return

#---------------------------------------#
# gestion affichage ecran SPK1          #
#---------------------------------------#
$TRT_SPK1
#** Onglet général
Actzo [M:SPK1]
If [M:SPK1]PKGTYP   = 0 [M:SPK1]PKGTYP   =1  : Endif : # Type colisage
If [M:SPK1]DOCFLG   = 0 [M:SPK1]DOCFLG   =1  : Endif : # Impression auto
If [M:SPK1]PCKFLT   = 0 [M:SPK1]PCKFLT   =1  : Endif : # filtre emballage

If [M:SPK1]PKGTYP          = 1
   If [M:SPK1]IDEDSTCOD1   = 0  [M:SPK1]IDEDSTCOD1 = 1 : Endif
   If [M:SPK1]IDEDSTSCR1   = 0  [M:SPK1]IDEDSTSCR1 = 1 : Endif
   If [M:SPK1]WEICOD1      = 0  [M:SPK1]WEICOD1    = 1 : Endif
   If [M:SPK1]WEISCR1      = 0  [M:SPK1]WEISCR1    = 1 : Endif
   If dim([M:SPK1]LOTCOD)  > 0
      If  [M:SPK1]LOTCOD   = 0  [M:SPK1]LOTCOD     = 1 : Endif
      If  [M:SPK1]LOTSCR   = 0  [M:SPK1]LOTSCR     = 1 : Endif
   Endif
   If dim([M:SPK1]SLOCOD)  > 0
      If  [M:SPK1]SLOCOD   = 0  [M:SPK1]SLOCOD     = 1 : Endif
      If  [M:SPK1]SLOSCR   = 0  [M:SPK1]SLOSCR     = 1 : Endif
   Endif
   If dim([M:SPK1]SERCOD)  > 0
      If  [M:SPK1]SERCOD   = 0  [M:SPK1]SERCOD     = 1 : Endif
      If  [M:SPK1]SERSCR   = 0  [M:SPK1]SERSCR     = 1 : Endif
   Endif
   If dim([M:SPK1]IDECOD1) > 0
      If  [M:SPK1]IDECOD1  = 0  [M:SPK1]IDECOD1    = 1 : Endif
      If  [M:SPK1]IDESCR1  = 0  [M:SPK1]IDESCR1    = 1 : Endif
   Endif
   If dim([M:SPK1]IDECOD2) > 0
      If  [M:SPK1]IDECOD2  = 0  [M:SPK1]IDECOD2    = 1 : Endif
      If  [M:SPK1]IDESCR2  = 0  [M:SPK1]IDESCR2    = 1 : Endif
   Endif
   If [M:SPK1]QTYSTUCOD    = 0  [M:SPK1]QTYSTUCOD  = 1 : Endif
   If [M:SPK1]QTYSTUSCR    = 0  [M:SPK1]QTYSTUSCR  = 1 : Endif
   If [M:SPK1]VCRLINCOD    = 0  [M:SPK1]VCRLINCOD  = 1 : Endif
   If [M:SPK1]VCRLINSCR    = 0  [M:SPK1]VCRLINSCR  = 1 : Endif
   If [M:SPK1]WEICOD       = 0  [M:SPK1]WEICOD     = 1 : Endif
   If [M:SPK1]WEISCR       = 0  [M:SPK1]WEISCR     = 1 : Endif
   If [M:SPK1]DIUCOD       = 0  [M:SPK1]DIUCOD     = 1 : Endif
   If [M:SPK1]DIUSCR       = 0  [M:SPK1]DIUSCR     = 1 : Endif
   If [M:SPK1]VOLCOD       = 0  [M:SPK1]VOLCOD     = 1 : Endif
   If [M:SPK1]VOLSCR       = 0  [M:SPK1]VOLSCR     = 1 : Endif
   If [M:SPK1]SCCCODCOD    = 0  [M:SPK1]SCCCODCOD  = 1 : Endif
   If [M:SPK1]SCCCODSCR    = 0  [M:SPK1]SCCCODSCR  = 1 : Endif
   If [M:SPK1]PRNCOD1      = 0  [M:SPK1]PRNCOD1    = 1 : Endif
   If [M:SPK1]PRNSCR1      = 0  [M:SPK1]PRNSCR1    = 1 : Endif
   If [M:SPK1]SCCCODCOD    = 0  [M:SPK1]SCCCODCOD  = 1 : Endif
   If [M:SPK1]SCCCODSCR    = 0  [M:SPK1]SCCCODSCR  = 1 : Endif
   If [M:SPK1]BPTNUMCOD    = 0  [M:SPK1]BPTNUMCOD  = 1 : Endif
   If [M:SPK1]PACNBRCOD    = 0  [M:SPK1]PACNBRCOD  = 2 : Endif
   If [M:SPK1]GROWEICOD    = 0  [M:SPK1]GROWEICOD  = 1 : Endif
   Grizo [M:SPK1]WEISCR
   Grizo [M:SPK1]DIUSCR
   Grizo [M:SPK1]VOLSCR
   Grizo [M:SPK1]PRNSCR1
   Grizo [M:SPK1]SCCCODSCR
   Grizo [M:SPK1]PACNBRCOD
Else
   If [M:SPK1]IDEDSTCOD1   = 0  [M:SPK1]IDEDSTCOD1 = 1 : Endif
   If [M:SPK1]IDEDSTSCR1   = 0  [M:SPK1]IDEDSTSCR1 = 1 : Endif
   If [M:SPK1]WEICOD1      = 0  [M:SPK1]WEICOD1    = 1 : Endif
   If [M:SPK1]WEISCR1      = 0  [M:SPK1]WEISCR1    = 1 : Endif
   If dim([M:SPK1]LOTCOD)  > 0
      [M:SPK1]LOTCOD       = 2
      [M:SPK1]LOTSCR       = 1
   Endif
   If dim([M:SPK1]SLOCOD)  > 0
      [M:SPK1]SLOCOD       = 2
      [M:SPK1]SLOSCR       = 1
   Endif
   If dim([M:SPK1]SERCOD)  > 0
      [M:SPK1]SERCOD       = 2
      [M:SPK1]SERSCR       = 1
   Endif
   If dim([M:SPK1]IDECOD1) > 0
      If  [M:SPK1]IDECOD1  = 0  [M:SPK1]IDECOD1    = 2 : Endif
      If  [M:SPK1]IDESCR1  = 0  [M:SPK1]IDESCR1    = 1 : Endif
   Endif
   If dim([M:SPK1]IDECOD2) > 0
      If  [M:SPK1]IDECOD2  = 0  [M:SPK1]IDECOD2    = 2 : Endif
      If  [M:SPK1]IDESCR2  = 0  [M:SPK1]IDESCR2    = 1 : Endif
   Endif
   If [M:SPK1]QTYSTUCOD    = 0  [M:SPK1]QTYSTUCOD  = 1 : Endif
   If [M:SPK1]QTYSTUSCR    = 0  [M:SPK1]QTYSTUSCR  = 1 : Endif
   If [M:SPK1]VCRLINCOD    = 0  [M:SPK1]VCRLINCOD  = 1 : Endif
   If [M:SPK1]VCRLINSCR    = 0  [M:SPK1]VCRLINSCR  = 1 : Endif
   If [M:SPK1]WEICOD       = 0  [M:SPK1]WEICOD     = 1 : Endif
   If [M:SPK1]WEISCR       = 0  [M:SPK1]WEISCR     = 1 : Endif
   If [M:SPK1]DIUCOD       = 0  [M:SPK1]DIUCOD     = 1 : Endif
   If [M:SPK1]DIUSCR       = 0  [M:SPK1]DIUSCR     = 1 : Endif
   If [M:SPK1]VOLCOD       = 0  [M:SPK1]VOLCOD     = 1 : Endif
   If [M:SPK1]VOLSCR       = 0  [M:SPK1]VOLSCR     = 1 : Endif
   If [M:SPK1]SCCCODCOD    = 0  [M:SPK1]SCCCODCOD  = 1 : Endif
   If [M:SPK1]SCCCODSCR    = 0  [M:SPK1]SCCCODSCR  = 1 : Endif
   If [M:SPK1]PRNCOD1      = 0  [M:SPK1]PRNCOD1    = 1 : Endif
   If [M:SPK1]PRNSCR1      = 0  [M:SPK1]PRNSCR1    = 1 : Endif
   If [M:SPK1]BPTNUMCOD    = 0  [M:SPK1]BPTNUMCOD  = 1 : Endif
   If [M:SPK1]PACNBRCOD    = 0  [M:SPK1]PACNBRCOD  = 1 : Endif
   If [M:SPK1]GROWEICOD    = 0  [M:SPK1]GROWEICOD  = 1 : Endif
   If dim([M:SPK1]LOTCOD)  > 0
      Grizo [M:SPK1]LOTCOD
   Endif
   If dim([M:SPK1]SLOCOD)  > 0
      Grizo [M:SPK1]SLOCOD
   Endif
   If dim([M:SPK1]SERCOD)  > 0
      Grizo [M:SPK1]SERCOD
   Endif
   [M:SPK1]PCKFLT = 1
   Grizo [M:SPK1]PCKFLT

# hcb 62879 deb
#   If dim([M:SPK1]IDECOD1)  > 0
#      Grizo [M:SPK1]IDECOD1
#   Endif
#   If dim([M:SPK1]IDECOD1)  > 0
#      Grizo [M:SPK1]IDESCR1
#   Endif
#   If dim([M:SPK1]IDECOD2)  > 0
#      Grizo [M:SPK1]IDECOD2
#   Endif
#   If dim([M:SPK1]IDECOD2)  > 0
#      Grizo [M:SPK1]IDESCR2
#   Endif
# hcb 62879 fin
   If [M:SPK1]WEICOD       = 2  Grizo [M:SPK1]WEISCR      Else Actzo [M:SPK1]WEISCR       : Endif
   If [M:SPK1]DIUCOD       = 2  Grizo [M:SPK1]DIUSCR      Else Actzo [M:SPK1]DIUSCR       : Endif
   If [M:SPK1]VOLCOD       = 2  Grizo [M:SPK1]VOLSCR      Else Actzo [M:SPK1]VOLSCR       : Endif
   If [M:SPK1]SCCCODCOD    = 2  Grizo [M:SPK1]SCCCODSCR   Else Actzo [M:SPK1]SCCCODSCR    : Endif
   If [M:SPK1]PRNCOD1      = 2  Grizo [M:SPK1]PRNSCR1     Else Actzo [M:SPK1]PRNSCR1      : Endif
Endif

If [M:SPK1]IDEDSTCOD1      = 2  Grizo [M:SPK1]IDEDSTSCR1  Else Actzo [M:SPK1]IDEDSTSCR1   : Endif
If [M:SPK1]WEICOD1         = 3  Grizo [M:SPK1]WEISCR1     Else Actzo [M:SPK1]WEISCR1      : Endif
If dim([M:SPK1]LOTCOD)  > 0
   If [M:SPK1]LOTCOD          = 2
      Grizo [M:SPK1]LOTSCR
   Else
      Actzo [M:SPK1]LOTSCR
   Endif
Endif
If dim([M:SPK1]SLOCOD)  > 0
   If [M:SPK1]SLOCOD          = 2
      Grizo [M:SPK1]SLOSCR
   Else
      Actzo [M:SPK1]SLOSCR
   Endif
Endif
If dim([M:SPK1]SERCOD)  > 0
   If [M:SPK1]SERCOD          = 2
      Grizo [M:SPK1]SERSCR
   Else
      Actzo [M:SPK1]SERSCR
   Endif
Endif
If dim([M:SPK1]IDECOD1)  > 0
   If [M:SPK1]IDECOD1         = 2
      Grizo [M:SPK1]IDESCR1
   Else
      Actzo [M:SPK1]IDESCR1
   Endif
Endif
If dim([M:SPK1]IDECOD2)  > 0
   If [M:SPK1]IDECOD2         = 2
      Grizo [M:SPK1]IDESCR2
   Else
      Actzo [M:SPK1]IDESCR2
   Endif
Endif
If [M:SPK1]VCRLINCOD       = 2  Grizo [M:SPK1]VCRLINSCR   Else Actzo [M:SPK1]VCRLINSCR    : Endif
If [M:SPK1]QTYSTUCOD       = 2  Grizo [M:SPK1]QTYSTUSCR   Else Actzo [M:SPK1]QTYSTUSCR    : Endif

If [M:SPK1]PRNCOD1         = 1
   Raz [M:SPK1]DOCNAM
   [M:SPK1]DOCFLG = 1
   Grizo [M:SPK1]DOCNAM
   Grizo [M:SPK1]DOCFLG
   Grizo [M:SPK1]PRNSCR1
Else
   Actzo [M:SPK1]DOCNAM
   Actzo [M:SPK1]DOCFLG
Endif


Affzo [SPK1]1-99

Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON

  When "IDEDSTCOD1"                                : # Designation
       If val(CZ)=2
         [M:SPK1]IDEDSTSCR1=1
         If !GIMPORT Affzo [M:SPK1]IDEDSTSCR1 : Grizo [M:SPK1]IDEDSTSCR1 : Endif
       Elsif !GIMPORT
         Actzo [M:SPK1]IDEDSTSCR1
       Endif
  When "WEICOD1"                                   : # Poids
       If val(CZ)=3
         [M:SPK1]WEISCR1=1
         If !GIMPORT Affzo [M:SPK1]WEISCR1    : Grizo [M:SPK1]WEISCR1    : Endif
       Elsif !GIMPORT
         Actzo [M:SPK1]WEISCR1
       Endif
  When "LOTCOD"                                    : # Lot
       If val(CZ)=2
         [M:SPK1]LOTSCR=1
         If !GIMPORT Affzo [M:SPK1]LOTSCR     : Grizo [M:SPK1]LOTSCR     : Endif
       Elsif !GIMPORT
         Actzo [M:SPK1]LOTSCR
       Endif
  When "SLOCOD"                                    : # Sous-lot
       If val(CZ)=2
         [M:SPK1]SLOSCR=1
         If !GIMPORT Affzo [M:SPK1]SLOSCR     : Grizo [M:SPK1]SLOSCR     : Endif
       Elsif !GIMPORT
         Actzo [M:SPK1]SLOSCR
       Endif
  When "SERCOD"                                    : # Série
       If val(CZ)=2
         [M:SPK1]SERSCR=1
         If !GIMPORT Affzo [M:SPK1]SERSCR     : Grizo [M:SPK1]SERSCR     : Endif
       Elsif !GIMPORT
         Actzo [M:SPK1]SERSCR
       Endif
  When "IDECOD1"                                   : # Identifiant 1
       If val(CZ)=2
         [M:SPK1]IDESCR1=1
         If !GIMPORT Affzo [M:SPK1]IDESCR1    : Grizo [M:SPK1]IDESCR1    : Endif
       Elsif !GIMPORT
         Actzo [M:SPK1]IDESCR1
       Endif
  When "IDECOD2"                                   : # Identifiant 2
       If val(CZ)=2
         [M:SPK1]IDESCR2=1
         If !GIMPORT Affzo [M:SPK1]IDESCR2    : Grizo [M:SPK1]IDESCR2    : Endif
       Elsif !GIMPORT
         Actzo [M:SPK1]IDESCR2
       Endif
  When "VCRLINCOD"                                   : # Ligne document
       If val(CZ)=2
         [M:SPK1]VCRLINSCR=1
         If !GIMPORT Affzo [M:SPK1]VCRLINSCR    : Grizo [M:SPK1]VCRLINSCR  : Endif
       Elsif !GIMPORT
         Actzo [M:SPK1]VCRLINSCR
       Endif
  When "QTYSTUCOD"                                 : # Qté traitée US
       If val(CZ)=2
         [M:SPK1]QTYSTUSCR=1
         If !GIMPORT Affzo [M:SPK1]QTYSTUSCR  : Grizo [M:SPK1]QTYSTUSCR  : Endif
       Elsif !GIMPORT
         Actzo [M:SPK1]QTYSTUSCR
       Endif
  When "WEICOD"                                    : # Poids
       If [M:SPK1]PKGTYP = 2       : # Post-colisage
          If val(CZ)=2
            [M:SPK1]WEISCR=1
            If !GIMPORT Affzo [M:SPK1]WEISCR     : Grizo [M:SPK1]WEISCR     : Endif
          Elsif !GIMPORT
            Actzo [M:SPK1]WEISCR
          Endif
       Endif
  When "DIUCOD"                                    : # Dimension
       If [M:SPK1]PKGTYP = 2       : # Post-colisage
          If val(CZ)=2
            [M:SPK1]DIUSCR=1
            If !GIMPORT Affzo [M:SPK1]DIUSCR     : Grizo [M:SPK1]DIUSCR     : Endif
          Elsif !GIMPORT
            Actzo [M:SPK1]DIUSCR
          Endif
       Endif
  When "VOLCOD"                                    : # Volume
       If [M:SPK1]PKGTYP = 2       : # Post-colisage
          If val(CZ)=2
            [M:SPK1]VOLSCR=1
            If !GIMPORT Affzo [M:SPK1]VOLSCR     : Grizo [M:SPK1]VOLSCR     : Endif
          Elsif !GIMPORT
            Actzo [M:SPK1]VOLSCR
          Endif
       Endif
  When "SCCCODCOD"                                    : # code SSCC
       If val(CZ)=2
         [M:SPK1]SCCCODSCR=1
         If !GIMPORT Affzo [M:SPK1]SCCCODSCR     : Grizo [M:SPK1]SCCCODSCR     : Endif
       Elsif !GIMPORT
         Actzo [M:SPK1]SCCCODSCR
       Endif
  When "PRNCOD1"                                   : # Impression
       If [M:SPK1]PKGTYP = 2       : # Post-colisage
          If val(CZ)=1
            [M:SPK1]PRNSCR1=1
            If !GIMPORT Affzo [M:SPK1]PRNSCR1    : Grizo [M:SPK1]PRNSCR1   : Endif
          Elsif !GIMPORT
            Actzo [M:SPK1]PRNSCR1
          Endif
       Endif

  When Default
       Gosub PE_STKTRS
Endcase

Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
WABR = "SPK0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
WABR = "SPK0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If dim(WMODU)<0 Local Char WMODU(3) : Endif
If APPLI=""    APPLI=nomap      : Endif
If dim(OK)<0  : Local Integer OK : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     BOUTONS(10)(4)
Local Char     TEXTE(40), LISTE(3), REPONS(1)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK


If WMODU=""
    WMODU = "T"+format$("N0:2",[M:SPK0]SRTTYP)
Endif

#---------------- Noms fenêtres et traitement colisage ---------#
If [M:SPK1]PKGTYP = 1
   Local Char     WINREF1(GLONFEN) : WINREF1="FPKD"
   Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WOPKD"+[M:SPK0]SRTNUM
   Local Char     NOMTRT1(GLONADC) : NOMTRT1="WGOPKD"+[M:SPK0]SRTNUM
   Local Char     NOMMSKENT(GLONAMK)
   MFROM="PKD0"                  # Nom du masque d'entête colisage declaratif
Else
   Local Char     WINREF1(GLONFEN) : WINREF1="FPKP"
   Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WOPKP"+[M:SPK0]SRTNUM
   Local Char     NOMTRT1(GLONADC) : NOMTRT1="WGOPKP"+[M:SPK0]SRTNUM
   Local Char     NOMMSKENT(GLONAMK)    # Nom du masque d'entête de la fenêtre
Endif
#-------------------------- écran en-tête ---------------------------#
If [M:SPK1]PKGTYP = 1
    MTO="W"+WMODU+[M:SPK0]SRTNUM+"0"
    NOMMSKENT=MTO
    Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
    If ACTION<>"ANNULE"
# rubriques entete
      OPT1=2
      Gosub PE_STKTRS
    Else OPT1=9
    Endif
    Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
    If RETOUR<>0 GOK=0 : Return : Endif
Endif

#-------------------------- 1er écran    ----------------------#
If [M:SPK1]PKGTYP = 1        # colisage declaratif
   MFROM="PKD1"
Else
   MFROM="PKP1"              # post colisage
Endif

MTO="W"+WMODU+[M:SPK0]SRTNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:SPK1]PKGTYP = 1
# --------------------------- Colisage declaratif
            If [M:SPK1]DIUCOD>1     TZONE(IZON)="PCKLEN"            : # Longueur
                                    TMOD(IZON) =3
                                    IZON+=1
                                    TZONE(IZON)="PCKWID"            : # Largeur
                                    TMOD(IZON) =3
                                    IZON+=1
                                    TZONE(IZON)="PCKHEI"            : # Hauteur
                                    TMOD(IZON) =3
                                    IZON+=1
                                    TZONE(IZON)="DIU"               : # Unite dimension
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]VOLCOD>1     TZONE(IZON)="VOL"               : # Volume
                                    TMOD(IZON) =3
                                    IZON+=1
                                    TZONE(IZON)="VOU"               : # Unite volume
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]WEICOD>1     TZONE(IZON)="PCKWEI"            : # Tare
                                    TMOD(IZON) =3
                                    IZON+=1
                                    TZONE(IZON)="WEU"               : # Unite poids
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]SCCCODCOD>1  TZONE(IZON)="PACNUM"            : # Numéro colis
                                    TMOD(IZON) =[M:SPK1]SCCCODCOD
                                    IZON+=1
            Endif
            If [M:SPK1]PRNCOD1=1    TZONE(IZON)="LBLFMT"            : # Format étiquette
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]IDEDSTCOD1>1 TZONE(IZON)="ITMDES1"            : # Designation
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]SCCCODCOD>1  TZONE(IZON)="SCCCOD"            : # Code SSSCC
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]IDEDSTSCR1>1 TZONE(IZON)="ITMDES1"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]IDEDSTSCR1)
                                    IZON+=1
            Endif
            If dim([M:SPK1]LOTCOD)>0
               If [M:SPK1]LOTCOD>1  TZONE(IZON)="LOT"               : # Lot
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]LOTSCR>1  TZONE(IZON)="LOT"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]LOTSCR)
                                    IZON+=1
               Endif
            Endif
            If dim([M:SPK1]SLOCOD)>0
               If [M:SPK1]SLOCOD>1  TZONE(IZON)="SLO"               : # Sous/lot
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]SLOSCR>1  TZONE(IZON)="SLO"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]SLOSCR)
                                    IZON+=1
               Endif
            Endif
            If dim([M:SPK1]SERCOD)>0
               If [M:SPK1]SERCOD>1  TZONE(IZON)="SERNUM"            : # Serie
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]SERSCR>1  TZONE(IZON)="SERNUM"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]SERSCR)
                                    IZON+=1
               Endif
#                                                                                      # hcb 110327-pck deb
               If [M:SPK1]SERCOD>1  TZONE(IZON)="SERFIN"            : # Serie fin
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]SERSCR>1  TZONE(IZON)="SERFIN"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]SERSCR)
                                    IZON+=1
               Endif
#                                                                                      # hcb 110327-pck fin
            Endif
            If dim([M:SPK1]IDECOD1)>0
               If [M:SPK1]IDECOD1>1 TZONE(IZON)="PALNUM"            : # Identifiant 1
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]IDESCR1>1 TZONE(IZON)="PALNUM"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]IDESCR1)
                                    IZON+=1
               Endif
            Endif
            If dim([M:SPK1]IDECOD2)>0
               If [M:SPK1]IDECOD2>1 TZONE(IZON)="CTRNUM"            : # Identifiant 2
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]IDESCR2>1 TZONE(IZON)="CTRNUM"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]IDESCR2)
                                    IZON+=1
               Endif
            Endif
            If [M:SPK1]VCRLINCOD>1  TZONE(IZON)="VCRLIN"            : # Ligne document
                                    TMOD(IZON) =3
                                    IZON+=1
             Endif
             If [M:SPK1]VCRLINSCR>1 TZONE(IZON)="VCRLIN"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]VCRLINSCR)
                                    IZON+=1
            Endif
            If dim([M:SPK1]QTYSTUCOD)>0
               If [M:SPK1]QTYSTUCOD>1 TZONE(IZON)="QTYSTU"            : # Qté traitée US
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]QTYSTUSCR>1 TZONE(IZON)="QTYSTU"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]QTYSTUSCR)
                                    IZON+=1
               Endif
            Endif
            If dim([M:SPK1]QTYSTUCOD)>0
               If [M:SPK1]QTYSTUCOD>1 TZONE(IZON)="STU"               : #  US
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]QTYSTUSCR>1 TZONE(IZON)="STU"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]QTYSTUSCR)
                                    IZON+=1
               Endif
            Endif
            If [M:SPK1]WEICOD1>1    TZONE(IZON)="NETWEI"            : # Poids
                                    TMOD(IZON) =[M:SPK1]WEICOD1
                                    IZON+=1
            Endif
            If [M:SPK1]WEISCR1>1    TZONE(IZON)="NETWEI"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]WEISCR1)
                                    IZON+=1
            Endif
            If [M:SPK1]WEICOD1>1    TZONE(IZON)="LIGWEU"            : # Poids
                                    TMOD(IZON) =[M:SPK1]WEICOD1
                                    IZON+=1
            Endif
            If [M:SPK1]WEISCR1>1    TZONE(IZON)="LIGWEU"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]WEISCR1)
                                    IZON+=1
            Endif


            If [M:SPK1]BPTNUMCOD>1  TZONE(IZON)="BPTNUM"            : # Transporteur
                                    TMOD(IZON) =[M:SPK1]BPTNUMCOD
                                    IZON+=1
            Endif
            If [M:SPK1]BPTNUMCOD>1  TZONE(IZON)="BPTSHO"            : # Transporteur intitulé court
                                    TMOD(IZON) =[M:SPK1]BPTNUMCOD
                                    IZON+=1
            Endif
            If [M:SPK1]GROWEICOD>1  TZONE(IZON)="GROWEI"            : # Poids du colis
                                    TMOD(IZON) =[M:SPK1]GROWEICOD
                                    IZON+=1
            Endif
            If [M:SPK1]GROWEICOD>1  TZONE(IZON)="GROWEU"            : # Poids du colis unité
                                    TMOD(IZON) =[M:SPK1]GROWEICOD
                                    IZON+=1
            Endif
   Else
# --------------------------- Post-colisage
            If dim([M:SPK1]QTYSTUCOD)>0
               If [M:SPK1]QTYSTUCOD>1 TZONE(IZON)="QTYSAUSTU"        : # Qté à coliser US
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]QTYSTUSCR>1 TZONE(IZON)="QTYSAUSTU"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]QTYSTUSCR)
                                    IZON+=1
               Endif
            Endif
            If dim([M:SPK1]QTYSTUCOD)>0
               If [M:SPK1]QTYSTUCOD>1 TZONE(IZON)="QTYSTU"            : # Qté traitée US
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]QTYSTUSCR>1 TZONE(IZON)="QTYSTU"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]QTYSTUSCR)
                                    IZON+=1
               Endif
            Endif
            If dim([M:SPK1]QTYSTUCOD)>0
               If [M:SPK1]QTYSTUCOD>1 TZONE(IZON)="STU"               : #  US
                                    TMOD(IZON) =3
                                    IZON+=1
               Endif
               If [M:SPK1]QTYSTUSCR>1 TZONE(IZON)="STU"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]QTYSTUSCR)
                                    IZON+=1
               Endif
            Endif


            If [M:SPK1]DIUCOD>1     TZONE(IZON)="PCKLEN"            : # Longueur
                                    TMOD(IZON) =3
                                    IZON+=1
                                    TZONE(IZON)="PCKWID"            : # Largeur
                                    TMOD(IZON) =3
                                    IZON+=1
                                    TZONE(IZON)="PCKHEI"            : # Hauteur
                                    TMOD(IZON) =3
                                    IZON+=1
                                    TZONE(IZON)="DIU"               : # Unite dimension
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]WEISCR>1     TZONE(IZON)="PCKLEN"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]WEISCR)
                                    IZON+=1
                                    TZONE(IZON)="PCKWID"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]WEISCR)
                                    IZON+=1
                                    TZONE(IZON)="PCKHEI"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]WEISCR)
                                    IZON+=1
                                    TZONE(IZON)="DIU"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]WEISCR)
                                    IZON+=1
            Endif
            If [M:SPK1]VOLCOD>1     TZONE(IZON)="VOL"               : # Volume
                                    TMOD(IZON) =3
                                    IZON+=1
                                    TZONE(IZON)="VOU"               : # Unite volume
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]VOLSCR>1     TZONE(IZON)="VOL"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]VOLSCR)
                                    IZON+=1
                                    TZONE(IZON)="VOU"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]VOLSCR)
                                    IZON+=1
            Endif
            If [M:SPK1]WEICOD>1     TZONE(IZON)="PCKWEI"            : # Tare
                                    TMOD(IZON) =3
                                    IZON+=1
                                    TZONE(IZON)="WEU"               : # Unite poids
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]WEISCR>1     TZONE(IZON)="PCKWEI"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]WEISCR)
                                    IZON+=1
                                    TZONE(IZON)="WEU"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]WEISCR)
                                    IZON+=1
            Endif
            If [M:SPK1]PRNCOD1=1    TZONE(IZON)="LBLFMT"            : # Format étiquette
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]PRNSCR1>1    TZONE(IZON)="LBEFMT"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]PRNSCR1)
                                    IZON+=1
            Endif
            If [M:SPK1]IDEDSTCOD1>1 TZONE(IZON)="ITMDES1"            : # Designation
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]IDEDSTSCR1>1 TZONE(IZON)="ITMDES1"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]IDEDSTSCR1)
                                    IZON+=1
            Endif
            If [M:SPK1]WEICOD1>1    TZONE(IZON)="NETWEI"            : # Poids
                                    TMOD(IZON) =[M:SPK1]WEICOD1
                                    IZON+=1
            Endif
            If [M:SPK1]WEISCR1>1    TZONE(IZON)="NETWEI"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]WEISCR1)
                                    IZON+=1
            Endif
            If [M:SPK1]BPTNUMCOD>1  TZONE(IZON)="BPTNUM"            : # Transporteur
                                    TMOD(IZON) =[M:SPK1]BPTNUMCOD
                                    IZON+=1
            Endif
            If [M:SPK1]BPTNUMCOD>1  TZONE(IZON)="BPTSHO"            : # Transporteur intitule court
                                    TMOD(IZON) =[M:SPK1]BPTNUMCOD
                                    IZON+=1
            Endif
            If [M:SPK1]GROWEICOD>1  TZONE(IZON)="GROWEI"            : # Poids des colis
                                    TMOD(IZON) =[M:SPK1]GROWEICOD
                                    IZON+=1
            Endif
            If [M:SPK1]GROWEICOD>1  TZONE(IZON)="GROWEU"            : # Poids des colis
                                    TMOD(IZON) =[M:SPK1]GROWEICOD
                                    IZON+=1
            Endif
            If [M:SPK1]PACNBRCOD>1  TZONE(IZON)="PACNBR"            : # Nombre colis
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]VCRLINCOD>1  TZONE(IZON)="VCRLIN"            : # Ligne document
                                    TMOD(IZON) =3
                                    IZON+=1
             Endif
             If [M:SPK1]VCRLINSCR>1 TZONE(IZON)="VCRLIN"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]VCRLINSCR)
                                    IZON+=1
            Endif
            If [M:SPK1]SCCCODCOD>1  TZONE(IZON)="SCCCOD"            : # Code SSCC
                                    TMOD(IZON) =3
                                    IZON+=1
            Endif
            If [M:SPK1]SCCCODSCR>1  TZONE(IZON)="SCCCOD"
                                    TMOD(IZON) =9
                                    TINT(IZON) =num$([M:SPK1]SCCCODSCR)
                                    IZON+=1
            Endif
   Endif

   OPT1=2
   Gosub PE_STKTRS
Else
    OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif


################################

#-------------------------- 2eme écran    ----------------------#
If [M:SPK1]PKGTYP  =  2                                     # post colisage
   WINREF1 = "IPKP2"
   NOMWIN1 = "WOPKP2"+[M:SPK0]SRTNUM
   NOMTRT1 = "WGOPKP2"+[M:SPK0]SRTNUM
   MFROM="PKP2"                                           # post colisage

   MTO="W"+WMODU+[M:SPK0]SRTNUM+"2"
   Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
   If ACTION<>"ANNULE"
      If dim([M:SPK1]QTYSTUCOD)>0
         If [M:SPK1]QTYSTUCOD>1 TZONE(IZON)="QTYSTU"            : # Qté traitée US
                                TMOD(IZON) =3
                                IZON+=1
         Endif
         If [M:SPK1]QTYSTUSCR>1 TZONE(IZON)="QTYSTU"
                                TMOD(IZON) =9
                                TINT(IZON) =num$([M:SPK1]QTYSTUSCR)
                                IZON+=1
         Endif
      Endif
      If dim([M:SPK1]QTYSTUCOD)>0
         If [M:SPK1]QTYSTUCOD>1 TZONE(IZON)="STU"               : #  US
                                TMOD(IZON) =3
                                IZON+=1
         Endif
         If [M:SPK1]QTYSTUSCR>1 TZONE(IZON)="STU"
                                TMOD(IZON) =9
                                TINT(IZON) =num$([M:SPK1]QTYSTUSCR)
                                IZON+=1
         Endif
      Endif
      If dim([M:SPK1]IDECOD1)>0
         If [M:SPK1]IDECOD1>1 TZONE(IZON)="PALNUM"           : # Identifiant 1
                              TMOD(IZON) =3
                              IZON+=1
         Endif
         If [M:SPK1]IDESCR1>1 TZONE(IZON)="PALNUM"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SPK1]IDESCR1)
                              IZON+=1
         Endif
      Endif
      If dim([M:SPK1]IDECOD2)>0
         If [M:SPK1]IDECOD2>1 TZONE(IZON)="CTRNUM"            : # Identifiant 2
                              TMOD(IZON) =3
                              IZON+=1
         Endif
         If [M:SPK1]IDESCR2>1 TZONE(IZON)="CTRNUM"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SPK1]IDESCR2)
                              IZON+=1
         Endif
      Endif

      OPT1=2
      Gosub PE_STKTRS
   Else
      OPT1=9
   Endif
   Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
   If RETOUR<>0 GOK=0 : Return : Endif
   If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif
Endif

#--- Génération des écrans et fenêtres de stock  Entrées
WNOMTRS = [M:SPK0]SRTNUM
If [M:SPK1]PKGTYP = 1
   WNOMOBJ = "PKD"
Else
   WNOMOBJ = "PKP"
Endif
ACSCOD  = [M:SPK0]ACSCOD
WLIBEL  = [M:SPK0]DESAXX
WENAFLG = [M:SPK0]ENAFLG

Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW"  [AWI] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR"  [AWP] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS
#----- Suppression fenêtre -------------#
Gosub TRT_SUP_FEN
If [M:SPK0]ENAFLG=1 : Return : Endif
#----- Génération fenêtre pour changement stock si transaction active -----#
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  [F:AWI]MSKENT    = NOMMSKENT
  WNOMMSK=MTO : Gosub ONGLET_INVISIBLE
If [M:SPK1]PKGTYP = 1
   I=find("PKD1",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
Else
   I=find("PKP1",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
Endif

  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS       = [M:SPK0]ACSCOD
  [F:AWI]LIBEL     = [M:SPK0]DESAXX
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:SPK0]SRTNUM
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
# Pour v140
Call VALID(NOMWIN1,APPLI,0,OK) From VALWIN
GOK = !!OK
Return

#---------------------------------------#
# Modification des écrans de base       #
# pour arranger l'esthétique si des     #
# blocs disparaissent                   #
#---------------------------------------#
$MODIF_ECRAN
Return

#---------------------------------------#
# Restauration des écrans de base       #
# suite à l'action MODIF_ECRAN          #
#---------------------------------------#
$RESTAUR_ECRAN
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"    [AMK] : Endif
If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON" [AMZ] : Endif
Read [AMK] CODMSK=WNOMMSK
If fstat  Raz [F:AMK]  : WFLGMSK=2 : Return : Endif
WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
  If [F:AMK]TYPBLOC(I)=1
    Read [AMZ] CODE=WNOMMSK;[F:AMK]BASPAG(I) : If fstat  Raz [F:AMZ] : Endif
    If [F:AMZ]SAIAFF<>3  WFLGMSK=2 : Break : Endif
  Elsif [F:AMK]TYPBLOC(I)<>5
    WFLGMSK=2 : Break
  Endif
Next I
Return



#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call GENPATCH(11,APPLI) From FUNSTKTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

Call GENDOS(11,APPLI) From FUNSTKTRS

End


#################################################
$TRTCOP
# TABLE contient la valeur du paramètre 2 de l'action ACOPIE (ici [M]TRUCOD)
If [M]DOSORG=nomap
 Local File STKTRS [SRT1]
Else
 Local File =[M]DOSORG+".STKTRS" [SRT1]
Endif
If [M]DOSDES=nomap
 Local File STKTRS [SRT2]
Else
 Local File =[M]DOSDES+".STKTRS" [SRT2]
Endif
OK = 1
If GTRACE=""
 Read [SRT2]SRT0 = 11;TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [SRT1], [SRT2]
Return

$TR_COP
GOK = 1
Trbegin [SRT2]
 Delete [SRT2] Where SRTTYP = 11 &
&                    SRTNUM = TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".STKTRS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SRT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [SRT1]SRT0=11;TABLE
 If !fstat
  [F:SRT2] = [F:SRT1]
  If dim([F:SRT2]UPDUSR)>0 : [F:SRT2]UPDUSR = GUSER : Endif
  If dim([F:SRT2]UPDDAT)>0 : [F:SRT2]UPDDAT = date$ : Endif
  If dim([F:SRT2]UPDTIM)>0 : [F:SRT2]UPDTIM = time  : Endif
  Write [SRT2]
  If fstat
   GOK=0 : Call FSTA("SRT2") From GLOCK
  Endif
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


#########################################################################
#                   Actions sur champs écran [M:SPK1]                  #
#########################################################################
Subprog AS_SRTNUM(VALEUR)
Variable Char    VALEUR()
[M:SPK0]SRTTYP = 11
End

Subprog AS_PRNCOD1(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
GMENLOC(4) = 1
GMENLOC(5) = 1
GMENLOC(6) = 1                     # hcb X3-92342
GMENLOC(7) = 1                     # hcb X3-92342
End

Subprog AP_PKGTYP(VALEUR)
Variable Integer VALEUR
Raz [M:SPK1]
[M:SPK1]PKGTYP = VALEUR     : # declaratif/post-colisage
Gosub TRT_SPK1
End

Subprog AS_BPTNUMCOD(VALEUR)
Variable Integer VALEUR
If [M:SPK1]PKGTYP = 1
   GMENLOC(1) = 1
Endif
End




Subprog AP_PRNCOD1(VALEUR)
Variable Integer VALEUR

[M:SPK1]PRNCOD1 = VALEUR
If [M:SPK1]PRNCOD1         = 1
   Raz [M:SPK1]DOCNAM
   [M:SPK1]DOCFLG = 1
   Grizo [M:SPK1]DOCNAM
   Grizo [M:SPK1]DOCFLG
   Grizo [M:SPK1]PRNSCR1
Else
   Actzo [M:SPK1]DOCNAM
   Actzo [M:SPK1]DOCFLG
   If [M:SPK1]PKGTYP          = 2
      Actzo [M:SPK1]PRNSCR1
   Else
      Diszo [M:SPK1]PRNSCR1
   Endif
Endif



End


