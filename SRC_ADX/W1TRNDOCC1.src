#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TRNDOCC1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:53"
A_USER  = "DOC"
A_STAMP = "20181109230653"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask TRNDOCC1 [TDC1]
Gosub HORODAT
Local Inpbox "TRNDOCC1" From GFONCTION At A_STAMP With A_WINDPREV Mask [TDC1] As [SIM_]
Grizo [TDC1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [TDC1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=110 : Y1(0)=1 : Y2(0)=23
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1TRNDOCC1
Return

Subprog IB_NBLIG
Local Decimal BASPAG
## Action STD
Call IB_NBLIG From CNSTDCSTD
Gosub _AFF
End

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(52761,GBOUT1) From OBJDIV
Call TEXTE(5169,GBOUT2) From OBJDIV
Call TEXTE(40356,GBOUT3) From OBJDIV
Call IB_NBLIG
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1TRNDOCC1
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1TRNDOCC1
Onkey 131 Titled GBOUT3 Call B3_NBLIG From W1TRNDOCC1
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B1_NBLIG From CNSTDCSTD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B2_NBLIG From CNSTDCSTD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B3_NBLIG From CNSTDCSTD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_FLG
Onevent BEFORE_AREA Gosub AV_FLG From W1TRNDOCC1
Onevent INIT_AREA Call D_FLG(zc) From W1TRNDOCC1
Onevent BEFORE_INPUT Call AS_FLG(zc) From W1TRNDOCC1
Return

$AV_FLG
## Action STD
Call AV_FLG(zc) From CNSTDCSTD
Gosub _AFF
Return

Subprog D_FLG(VALEUR)
Variable Integer VALEUR
If varinit([M]FLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_LINDOCTYP
Onevent INIT_AREA Call D_LINDOCTYP(zc) From W1TRNDOCC1
Return

Subprog D_LINDOCTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]LINDOCTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_LINFCY
Return

$ON_NUM
Return

$ON_BPRNUM
Return

$ON_DOCDAT
Onevent BEFORE_AREA Gosub AV_DOCDAT From W1TRNDOCC1
Return

$AV_DOCDAT
Chgfmt [M]DOCDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_ATDTINPTYP
Onevent INIT_AREA Call D_ATDTINPTYP(zc) From W1TRNDOCC1
Return

Subprog D_ATDTINPTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]ATDTINPTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ATDTCOD
Onevent BEFORE_INPUT Call AS_ATDTCOD(zc) From W1TRNDOCC1
Onevent AFTER_CHANGE Gosub AMM_ATDTCOD From W1TRNDOCC1
Return

Subprog AS_ATDTCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_ATDTCOD(VALEUR) From CNSTDCSTD
If mkstat=2
 [M]ATDTCOD(INDIC) = VALEUR
 Affzo ATDTCOD(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$AMM_ATDTCOD
Call AM_ATDTCOD(zc)
If !mkstat & GOBJET
 zoncou = "ATDTCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ATDTCOD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_ATDTCOD(VALEUR) From CNSTDCSTD
If mkstat : GERR = 1 : GZONE = "ATDTCOD" : GZNUM = 52730 : Endif
Gosub _AFF
End

$ON_UPDFLG
Onevent INIT_AREA Call D_UPDFLG(zc) From W1TRNDOCC1
Return

Subprog D_UPDFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]UPDFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


