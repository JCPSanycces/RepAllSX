#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EDK1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CATTYP
mkstat = 0
zoncou = "CATTYP"
indice = 0
IMPENT = [M]CATTYP
If varinit([M]CATTYP,indice)=0
 IMPENT = 1
Endif
[M]CATTYP = IMPENT

## Zone CATACTFLT
mkstat = 0
zoncou = "CATACTFLT"
indice = 0
IMPENT = [M]CATACTFLT
WNUM = IMPENT
If varinit([M]CATACTFLT,indice)=0
 IMPENT = 1
Endif
If varmode([M]CATACTFLT,indice)=0
 [M]CATACTFLT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CATACTFLT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CATACTFLT(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_CATACTFLT(IMPENT) From CNSEDKSTD
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CATACTFLT" : GZNUM = 90 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]CATACTFLT = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "EDK1"
Return

