#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################
# UTIIND09 
# ---------------------------------------------------------------------- #
#      mise a jour du parametre CTLTEL uniquement suite à patch 
##########################################################################
Infbox "only update folder by patch"
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

# mettre a jour le dossier X3 (et uniquement ce dossier)
If APPLI<> "X3" : End : Endif

Call EXE_UTIIND09 (APPLI)  
End



Subprog EXE_UTIIND09(LDOSSIER)
Value Char LDOSSIER

#----- Variables locales -----#
Local Char     WMSG(80)

#-----
Call ECR_TRACE("UTIIND09: Update CTLTEL for Folder "+LDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#

If clalev([F:ZZZ]) =0  Local File =LDOSSIER+".ADOVAL"     [ZZZ] : Endif

#-----
$MISE_JOUR_ADOVAL
#-----------------------------#
#   mise a jour table ADOVAL  #
#------------------------------#


# Changement du param CTLTEL dans x3 si ca valeur est 3 par 1
Trbegin [ZZZ] 
 Read [ZZZ]ADW0 = "";"";"CTLTEL" 
 If fstat 
      Call ERREUR("ADOVAL",4) From DOSDIC 
 Else
    If [F:ZZZ]VALEUR = "3"
         [F:ZZZ]VALEUR = "1"
         Rewrite [ZZZ] 
         If fstat 
              Call ERREUR("ADOVAL",2) From DOSDIC 
         Endif 
    Endif    
 Endif 

Commit 


#----- Fin du traitement -----#
$FIN_UTIIND09
WMSG ="UTIIND09: end of Update param CTLTEL"
Call ECR_TRACE(WMSG,0) From GESECRAN

End




