#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################################################
#   Composants technique de gestion des taches     Module CRM       27 décembre 2005
#
# UPDTSK    : Sous-programme de mise à jour d'une tache.
#
##########################################################################################################
Subprog TEST
Local Char SZTSKNUM(GLONVCR)
Local Integer LERRCOD

  GSYNCOUTLOOK = 1
  SZTSKNUM = "000000000000014"
  Call UPDTSK("SUBTSKCM", 2, 2, SZTSKNUM, LERRCOD) 
  GSYNCOUTLOOK = 0
End

##########################################################################################################
Subprog UPDTSK(SZUPDTSKTRT, ITRACE, ILEC_TRACE, SZTSKNUM, LERRCOD) 
Value Char SZUPDTSKTRT
Value Integer ITRACE
Value Integer ILEC_TRACE
Value Char SZTSKNUM
Variable Integer LERRCOD

Global Char GSZUPDTSKTRT
Global Integer GIUPDTSKTRACE

Local Integer IBOPENTRACE
Local Integer IBDEBTRANSFLG

  IBOPENTRACE = 0
  GSZUPDTSKTRT = SZUPDTSKTRT
  GIUPDTSKTRACE = ITRACE
  If GSZUPDTSKTRT = "" Then
    GSZUPDTSKTRT = "SUBTSKCM"
  Endif
  Raz LERRCOD, GMESSAGE
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If ITRACE Then
    If GTRACE = "" Then
      #Modification de tâche démarré à partir du contexte :+ GSZUPDTSKTRT
      Call OUVRE_TRACE (mess(220,177,1) + GSZUPDTSKTRT) From LECFIC
      IBOPENTRACE = 1
    Endif
  Endif
  If ITRACE Then
    #Modification de la tâche + " : " + SZTSKNUM
    Call ECR_TRACE(mess(252,177,1)+ " : " + SZTSKNUM,0)From GESECRAN
  Endif
#--- variables
Local  Integer OK, SAVGIMPORT 
Local  Char    ACTION(20), ABREV(5) 
Local Char SAVGABREV

  #--- declaration et chargement des variables objet 
  ABREV = "TSK"
  SAVGABREV = GABREV
  GABREV = "TSK"
  Gosub DEFVAR From GOBJET    # FGR 07/06/2010 : X3SUIVI64666 A faire juste après GABREV
  #
  SAVFONC = GFONCTION         # FGR 16/09/2009 : X3SUIVI57846
  GFONCTION = "GES"+ABREV     # FGR 16/09/2009 : X3SUIVI57846
  #Gosub DEFVAR From GOBJET   # FGR 07/06/2010 : X3SUIVI64666 là on perd SAVFONC !
  SAVGIMPORT = GIMPORT 
  GIMPORT = 1
  #Gestion des autorisations
  Call AUTORIS From EXEFNC
  GOK = 1
  OK = 1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=AVANT_OUVRE",0) From GESECRAN
  Endif
  ACTION = "AVANT_OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR AVANT_OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- ouverture de la fenêtre contrat
  If clalev([M:TSK0])=0 : Local Mask TSK0 [TSK0] : Endif
  If clalev([M:TSK1])=0 : Local Mask TSK1 [TSK1] : Endif
  If clalev([M:TSK2])=0 : Local Mask TSK2 [TSK2] : Endif
  Raz [M:TSK0], [M:TSK1], [M:TSK2]
  #--- ouverture des tables necessaires
  If clalev([F:TSK])=0 : Local File TASK [TSK] : Endif
  Gosub OUVRE From WOTSK 
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=OUVRE",0) From GESECRAN
  Endif
  ACTION = "OUVRE"       : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  WINPROG = "WGOTSK"
  GREP = "M"
  Read [TSK]TSK0=SZTSKNUM
  If fstat Then
    LERRCOD = 4
    #Erreur lors de la lecture de la tâche + " : " +SZTSKNUM
    Call ECR_TRACE(mess(234,177,1)+ " : " +SZTSKNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  [M:TSK0] = [F:TSK]
  [M:TSK1] = [F:TSK]
  [M:TSK2] = [F:TSK]
  Default Mask [TSK0]
  Default Mask [TSK1]
  Default Mask [TSK2]
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=LIENS",0) From GESECRAN
  Endif
  ACTION = "LIENS"   : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR LIENS",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #------------------------------------------------------------------------  
  # chargement masques enregistrement entête tache
  #--- chargement des masques de objet
  If ITRACE > 1 Then
    Call ECR_TRACE("MASK",0) From GESECRAN
  Endif
  Default Mask [TSK0]
  Call SAIMSK("TSK","IMP_ZONE","SUBTSKCM") From W0TSK0
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK TSK0 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [TSK1]
  Call SAIMSK("TSK","IMP_ZONE","SUBTSKCM") From W0TSK1
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK TSK1 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [TSK2]
  Call SAIMSK("TSK","IMP_ZONE","SUBTSKCM") From W0TSK2
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK TSK2 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  #Point entrée après saisi masque
  Gosub PE_MSKTSK From TRTCRMPE
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  GPOINT=MSKUPDTSK mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 8
    Gosub ONERROR
    End
  Endif
  OK = 1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=VERIF_MOD",0) From GESECRAN
  Endif
  ACTION = "VERIF_MOD"   : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR VERIF_MOD",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  Read [TSK]TSK0=SZTSKNUM
  If fstat Then
    LERRCOD = 4
    #Erreur lors de la lecture de la tâche + " : " +SZTSKNUM
    Call ECR_TRACE(mess(234,177,1)+ " : " +SZTSKNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  Readlock [TSK]Curr
  If fstat <> 0 Then
    #Impossible de locker la tâche+" : "+SZTSKNUM
    Call ECR_TRACE(mess(326,177,1)+" : "+SZTSKNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  Raz [F:TSK]
  Default File [F:TSK]
  [F:TSK] = [M:TSK0]
  [F:TSK] = [M:TSK1]
  [F:TSK] = [M:TSK2]
  [F:TSK]UPDUSR = GUSER
  [F:TSK]UPDDAT = date$
  If ITRACE > 1 Then
    #Réécriture [F:TSK]  -  TSKNUM=+[F:TSK]TSKNUM
    Call ECR_TRACE(mess(221,177,1)+[F:TSK]TSKNUM,0) From GESECRAN
  Endif
  GOK = 1
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [TSK]
  Endif
  Rewrite [F:TSK]
  If fstat Then
    Call ECR_TRACE("  ERROR Rewrite [F:TSK] fstat="+num$(fstat),1) From GESECRAN
    LERRCOD = 9
    GOK=0
    Call FSTA("TSK") From GLOCK
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=MODIF",0) From GESECRAN
  Endif
  ACTION = "MODIF"    : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR MODIF",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=APRES_MOD",0) From GESECRAN
  Endif
  ACTION = "APRES_MOD"   : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR APRES_MOD",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=FERME",0) From GESECRAN
  Endif
  ACTION = "FERME"       : Gosub ACTION From GOBJSUB
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  Kill GSZUPDTSKTRT 
  Kill GIUPDTSKTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
End

##########################################################################################################
$ACTION
Local Char SZVALBEFORE
Local Char SZVALAFTER
Local Integer IBTESTOK

  IBTESTOK = 0
  Raz SZVALBEFORE
  Raz SZVALAFTER
  If evalue("type([M]"+IMPZON+")") < 300 Then
    IBTESTOK = 1
  Endif
  If IBTESTOK = 1 Then
    SZVALBEFORE = num$(evalue("[M]"+IMPZON))
  Endif
  If GIUPDTSKTRACE > 1 Then
    Call ECR_TRACE("ACTION = "+ACTION-"IMPZON="+IMPZON-"XOK="+num$(XOK),0) From GESECRAN
    If IBTESTOK = 1 Then
      #"    "+Valeur avant = +" : " +SZVALBEFORE
      Call ECR_TRACE("    "+  mess(369,177,1)+" : "+ SZVALBEFORE,0) From GESECRAN 
    Endif
  Endif
  Case ACTION 
    When "IMP_ZONE"
      Gosub TSK_SET_HEA_INFO From=GSZUPDTSKTRT
    When "IMP_TAB"
      Gosub TSK_SET_DET_INFO From=GSZUPDTSKTRT
  Endcase
  If IBTESTOK = 1 Then
    SZVALAFTER = num$(evalue ("[M]"+IMPZON))
    If SZVALAFTER <> SZVALBEFORE Then
      IMPMOD = 1
    Endif
  Else
    IMPMOD = 1
  Endif
  If GIUPDTSKTRACE > 1 Then
    If IBTESTOK = 1 Then
      #"    "+Valeur après = +" : " +SZVALAFTER
      Call ECR_TRACE("    "+mess(370,177,1)+" : "+ SZVALAFTER,0) From GESECRAN 
    Endif
  Endif
Return

##########################################################################################################
$ONERROR
  If IBDEBTRANSFLG = 0 Then
    If adxlog  Then
      Rollback
    Endif
  Endif
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GOK = 0
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  Kill GSZUPDTSKTRT 
  Kill GIUPDTSKTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la modification d'une tache. (exemple)
#############################################################################
$TSK_SET_HEA_INFO
  Case IMPZON
    When "TSKPJT"
      #[M:TSK0]TSKPJT=""
    When "TSKDON"
      [M:TSK0]TSKDON=1
    When "TSKDAT"
      #[M:TSK1]TSKDAT=date$+10
    When "TSKSTR"
      #[M:TSK1]TSKSTR=date$
      #[M:TSK1]TSKORI=8
      #[M:TSK1]TSKORITXT=""
      #[M:TSK1]TSKORIVCR=""
      #[M:TSK1]TSKORIVCRL=0
      #[M:TSK1]TSKCMGNUM=""
      #[M:TSK1]TSKOPGNUM=""    
      #[M:TSK1]TSKOPGTYP=""
    When "TSKTYP"
      #[M:TSK1]TSKTYP=""
    When "TSKREP"
      #[M:TSK1]TSKREP="LSE12"
    When "TSKDEL"
      [M:TSK1]TSKDEL=6
    When "HOUTIMSPG"
      [M:TSK2]HOUTIMSPG=21
    When "MNTTIMSPG"
      [M:TSK2]MNTTIMSPG=11
    When "TSKSAO"
      #[M:TSK2]TSKSAO=""
  Endcase
Return

##########################################################################################################
# Affectation des valeurs pour la création d'une tache. (exemple)
#############################################################################
$TSK_SET_HEA_INFO_EXMPLE
  Case IMPZON
    When "TSKNUM"     
      [M:TSK0]TSKNUM=""       
    When "SALFCY"
      [M:TSK0]SALFCY=""
    When "TSKCMP"
      [M:TSK0]TSKCMP=""
    When "TSKCCN"
      [M:TSK0]TSKCCN=""
    When "TSKPJT"
      [M:TSK0]TSKPJT=""
    When "TSKDON"
      [M:TSK0]TSKDON=""
    When "TSKDAT"
      [M:TSK1]TSKDAT=""
    When "TSKSTR"
      [M:TSK1]TSKSTR=""
      #[M:TSK1]TSKORI=""
      [M:TSK1]TSKORIADI = "MAN1"  # FGR 08/03/2010 : X3SUIVI62924
      #[M:TSK1]TSKORITXT=""
      [M:TSK1]TSKORIVCR=""
      [M:TSK1]TSKORIVCRL=""
      [M:TSK1]TSKCMGNUM=""
      [M:TSK1]TSKOPGNUM=""    
      [M:TSK1]TSKOPGTYP=""
    When "TSKTYP"
      [M:TSK1]TSKTYP=""
    When "TSKREP"
      [M:TSK1]TSKREP=""
    When "TSKDEL"
      [M:TSK1]TSKDEL=""
    When "CREDAT"
      [M:TSK1]CREDAT=""
    When "CREHOUP"
      [M:TSK1]CREHOU=""
    When "HOUTIMPSG"
      [M:TSK2]HOUTIMPSG=""
    When "MNTTIMSPG"
      [M:TSK2]MNTTIMSPG=""
    When "TSKSAO"
      [M:TSK2]TSKSAO=""
  Endcase
Return
