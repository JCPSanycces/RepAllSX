#<AdxTL>@(#)0.0.0.0 $Revision$
# Import des coûts standards

$ACTION
Case ACTION
    When "EXPORT" :        Gosub EXPORT
    When "EXP_ZONE"      : Gosub EXP_ZONE
    When Default
Endcase
Return

###################################################################################
$EXPORT
Raz GIMP(1), GIMP(2), GIMP(3), GIMP(4)
Return

#######################################################################
$EXP_ZONE
Local Integer LINDMAX
Case EXPZON
  When "GIMP(1)"    : # Recherche du type de FG
                      LINDMAX=1
                      For I=1 To dim([F:ICN]NATAMTLEV)-1
                          If [F:ICN]NATAMTLEV(I)+[F:ICN]NATAMTSSE(I)>[F:ICN]NATAMTLEV(LINDMAX)+[F:ICN]NATAMTSSE(LINDMAX)
                              LINDMAX=I
                          Endif
                      Next
                      If find(LINDMAX,1,6)
                          GIMP(1) = "2"
                      Else
                          GIMP(1) = num$(LINDMAX)
                      Endif
  When "GIMP(2)"    :
  When "GIMP(3)"    :
  When "GIMP(4)"    :
  When Default

Endcase

$OUVRE
Local Integer CTL_OK, ITC_OK, ICN_OK, N
Local Decimal YEA_COUT
Local Char    ERR_TRA(120)
Local Decimal TOT_NAT, LTOTLEV
Local Char    W_NAT(3)(20)    : # Récap des NATURES
Local Char    SIT_AN(7)(20)   : # combinaisons site,année
Local Integer NBSIT

Local Mask CLCCST    [CST]
Local Mask CLCCST0   [CST0]
Local Mask CLCCSTPAR [CTP]

If clalev([F:TCU])=0 Local File TABCUR     [TCU] Endif
If clalev([F:FCY])=0 Local File FACILITY   [FCY] Endif
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM] Endif
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF] Endif
If clalev([F:ICN])=0 Local File ITCNAT     [ICN] Endif : # détails natures de FG
If clalev([F:ICC])=0 Local File ITCMAT     [ICC] Endif : # détails natures de FG
If clalev([F:IWC])=0 Local File ITCWST     [IWC] Endif : # détails natures de FG
If clalev([F:ITC2])=0 Local File ITMCOST   [ITC2] Endif : # Pour lire le dernier
If clalev([F:ICN2])=0 Local File ITCNAT    [ICN2] Endif : # lecture
If !clalev([F:ICC2]) : Local File ITCMAT   [ICC2] Endif
If !clalev([F:IWC2]) : Local File ITCWST   [IWC2] Endif
If clalev([F:ONA])=0 Local File OVENAT     [ONA]  Endif : # natures de FG
If !clalev([F:ITB]) : Local File ITMBOM    [ITB]  Endif
If !clalev([F:ITH]) : Local File ITMMVTHIS [ITH]  Endif # Pour écriture mouvement changement de valeur
If !clalev([F:STJ1]) : Local File STOJOU   [STJ1] Endif # Pour écriture mouvement changement de valeur
Return

$RAZCRE
Raz [M:CST],[M:CTP],[M:CST0]
Raz TOT_NAT
Return

$SAIMSK
Local Integer J

#If GUSER = "CCC"
#    Local Integer CCRET
#    CCRET=2
#    Call OUINON("Debug saimsk?",CCRET) From GESECRAN
#    If CCRET=2 : Dbgaff : Endif
#Endif

# pour ITC la classe F reste chargée jusqu'à l'écriture Attention elle est lue en avance pour les ruptures !
Case IMPFIC
    When "ITC" :    #------------ Coût global --------------#
        [M:CTP]NIV     = 2
        [M:CST0]STOFCY = [F:ITC]STOFCY
        [M:CTP]ITMREF  = [F:ITC]ITMREF
        [M:CTP]ECCVALMAJ = [F:ITC]ECCVALMAJ
        [M:CTP]ECCVALMIN = [F:ITC]ECCVALMIN
        [M:CTP]QTYCLC  = [F:ITC]CLCQTY
        [M:CTP]BOMALT  = [F:ITC]BOMALT
        [M:CTP]CLCDAT  = [F:ITC]ITCDAT

    When "ICN" :
        If [F:ICN]NATAMTLEV<>0
            [M:CST]ITMREF([M:CST]NBFGITM)  = [F:ITC]ITMREF
            [M:CST]NATITM([M:CST]NBFGITM)  = [F:ICN]OVENAT
            Read [ONA]ONA0=[F:ICN]OVENAT
            If fstat
                GERR=1
                Call RSTA("ONA",[F:ICN]OVENAT) From GLOCK
                Return
            Endif
            If val(GIMP(1))<>0
                [M:CST]IOVETYP([M:CST]NBFGITM) = val(GIMP(1))
            Else
                [M:CST]IOVETYP([M:CST]NBFGITM) = [F:ONA]TYPCST
            Endif
            [M:CST]IVARAMT([M:CST]NBFGITM) = [F:ICN]NATAMTLEV * [M:CTP]QTYCLC
            [M:CST]NBFGITM += 1
        Endif
        If [F:ICN]NATAMTSSE<>0
            [M:CST]MATREF([M:CST]NBFGMAT)  = ""
            [M:CST]NATMAT([M:CST]NBFGMAT)  = [F:ICN]OVENAT
            Read [ONA]ONA0=[F:ICN]OVENAT
            If fstat
                GERR=1
                Call RSTA("ONA",[F:ICN]OVENAT) From GLOCK
                Return
            Endif
            If val(GIMP(1))<>0
                [M:CST]MOVETYP([M:CST]NBFGMAT) = val(GIMP(1))
            Else
                [M:CST]MOVETYP([M:CST]NBFGMAT) = [F:ONA]TYPCST
            Endif
            [M:CST]MVARAMT([M:CST]NBFGMAT) = [F:ICN]NATAMTSSE * [M:CTP]QTYCLC
            [M:CST]CLCLEV([M:CST]NBFGMAT)=1
            [M:CST]NBFGMAT += 1
        Endif
        TOT_NAT += [F:ICN]NATAMTLEV+[F:ICN]NATAMTSSE

    When "ICC" :
        If [F:ICC]QTYTOP>0
            If [F:ICC]CPNTYP=1
                [M:CST]MATREF([M:CST]NBMAT)  = [F:ICC]MATREF
                [M:CST]MECCVALMAJ([M:CST]NBMAT) = [F:ICC]ECCVALMAJ
                [M:CST]MECCVALMIN([M:CST]NBMAT) = [F:ICC]ECCVALMIN
                [M:CST]SCOFLG([M:CST]NBMAT)  = [F:ICC]SCOFLG
                #[M:CST]MQTYSTU([M:CST]NBMAT) = [F:ICC]QTYSTU
                [M:CST]MQTYSTU([M:CST]NBMAT) = [F:ICC]QTYTOP
                [M:CST]MSTU([M:CST]NBMAT)    = [F:ICC]STU
                [M:CST]MBRDCOD([M:CST]NBMAT) = [F:ICC]BRDCOD
                [M:CST]MCSTCOD([M:CST]NBMAT) = [F:ICC]CSTCOD
                For J=0 To GACTMAT-1
                    [M:CST]MMATCST([M:CST]NBMAT*GACTMAT+J) = [F:ICC]MATCST(J) * [M:CST]MQTYSTU([M:CST]NBMAT)
                Next
                For J=0 To GACTMAC-1
                    [M:CST]MMACCST([M:CST]NBMAT*GACTMAC+J) = [F:ICC]MACCST(J) * [M:CST]MQTYSTU([M:CST]NBMAT)
                Next
                For J=0 To GACTLAB-1
                    [M:CST]MLABCST([M:CST]NBMAT*GACTLAB+J) = [F:ICC]LABCST(J) * [M:CST]MQTYSTU([M:CST]NBMAT)
                Next
                [M:CST]MSCOCST([M:CST]NBMAT)    = [F:ICC]SCOCST    * [M:CST]MQTYSTU([M:CST]NBMAT)
                [M:CST]MOVEMATCST([M:CST]NBMAT) = [F:ICC]OVEMATCST * [M:CST]MQTYSTU([M:CST]NBMAT)
                [M:CST]MOVEMACCST([M:CST]NBMAT) = [F:ICC]OVEMACCST * [M:CST]MQTYSTU([M:CST]NBMAT)
                [M:CST]MOVELABCST([M:CST]NBMAT) = [F:ICC]OVELABCST * [M:CST]MQTYSTU([M:CST]NBMAT)
                [M:CST]MOVESCOCST([M:CST]NBMAT) = [F:ICC]OVESCOCST * [M:CST]MQTYSTU([M:CST]NBMAT)

                [M:CST]NBMAT+= 1
            Else
                [M:CST]ITMREF([M:CST]NBITM)  = [F:ICC]MATREF
                [M:CST]ITMTYP([M:CST]NBITM) = 2
                [M:CST]IQTYSTU([M:CST]NBITM) = [F:ICC]QTYTOP
                [M:CST]ISTU([M:CST]NBITM)    = [F:ICC]STU
                [M:CST]IBRDCOD([M:CST]NBITM) = [F:ICC]BRDCOD
                [M:CST]ICSTCOD([M:CST]NBITM) = [F:ICC]CSTCOD
                For J=0 To GACTMAT-1
                    [M:CST]IMATCST([M:CST]NBITM*GACTMAT+J) = [F:ICC]MATCST(J) * [M:CST]IQTYSTU([M:CST]NBITM)
                Next
                For J=0 To GACTMAC-1
                    [M:CST]IMACCST([M:CST]NBITM*GACTMAC+J) = [F:ICC]MACCST(J) * [M:CST]IQTYSTU([M:CST]NBITM)
                Next
                For J=0 To GACTLAB-1
                    [M:CST]ILABCST([M:CST]NBITM*GACTLAB+J) = [F:ICC]LABCST(J) * [M:CST]IQTYSTU([M:CST]NBITM)
                Next
                [M:CST]ISCOCST([M:CST]NBITM)    = [F:ICC]SCOCST    * [M:CST]IQTYSTU([M:CST]NBITM)
                [M:CST]IOVEMATCST([M:CST]NBITM) = [F:ICC]OVEMATCST * [M:CST]IQTYSTU([M:CST]NBITM)
                [M:CST]IOVEMACCST([M:CST]NBITM) = [F:ICC]OVEMACCST * [M:CST]IQTYSTU([M:CST]NBITM)
                [M:CST]IOVELABCST([M:CST]NBITM) = [F:ICC]OVELABCST * [M:CST]IQTYSTU([M:CST]NBITM)
                [M:CST]IOVESCOCST([M:CST]NBITM) = [F:ICC]OVESCOCST * [M:CST]IQTYSTU([M:CST]NBITM)

                [M:CST]NBITM+= 1
            Endif
      Endif

    When "IWC" :
        If [F:IWC]WSTTYP <> 3 & ([F:IWC]OPETIMTOP>0 | [F:IWC]SETTIMTOP>0)    # MO ou machine
            [M:CST]WST([M:CST]NBWST) = [F:IWC]WST
            [M:CST]WSTTYP([M:CST]NBWST) = [F:IWC]WSTTYP
            [M:CST]WBRDCOD([M:CST]NBWST) = [F:IWC]BRDCOD
            [M:CST]WCSTTYP([M:CST]NBWST) = [F:IWC]WCSTTYP
            [M:CST]WRATCOD([M:CST]NBWST) = [F:IWC]RATCOD
            [M:CST]WSETCST([M:CST]NBWST) = [F:IWC]SETCST
            [M:CST]WSETTIM([M:CST]NBWST) = [F:IWC]SETTIMTOP
            [M:CST]WOPECST([M:CST]NBWST) = [F:IWC]OPECST
            [M:CST]WOPETIM([M:CST]NBWST) = [F:IWC]OPETIMTOP
            [M:CST]WSETAMT([M:CST]NBWST) = [F:IWC]SETCST * [F:IWC]SETTIMTOP
            [M:CST]WOPEAMT([M:CST]NBWST) = [F:IWC]OPECST * [F:IWC]OPETIMTOP
            [M:CST]WSETTIM([M:CST]NBWST) = [F:IWC]SETTIMTOP
            [M:CST]WOPETIM([M:CST]NBWST) = [F:IWC]OPETIMTOP
            # On ne renseigne pas OVENAT (de toute façon on ne peut pas) car les FG doivent déjà être dans ICN
            If [F:IWC]OVEAMTTOP>0
                [M:CST]WVARAMT([M:CST]NBFGWST) = [F:IWC]OVEAMTTOP
                [M:CST]OWST([M:CST]NBFGWST)    = [M:CST]WST([M:CST]NBWST)
                [M:CST]NBFGWST+=1
            Endif
            [M:CST]NBWST += 1
        Elsif [F:IWC]WSTTYP=3 & ([F:IWC]OPETIMTOP>0 | [F:IWC]SETTIMTOP>0)    # Sous-traitance
            [M:CST]SCOWST([M:CST]NBSCO)  = [F:IWC]WST
            [M:CST]SBRDCOD([M:CST]NBSCO) = [F:IWC]BRDCOD
            [M:CST]SCSTTYP([M:CST]NBSCO) = [F:IWC]WCSTTYP
            [M:CST]SRATCOD([M:CST]NBSCO) = [F:IWC]RATCOD
            [M:CST]SSETCST([M:CST]NBSCO) = [F:IWC]SETCST
            [M:CST]SSETTIM([M:CST]NBSCO) = [F:IWC]SETTIMTOP
            [M:CST]SOPECST([M:CST]NBSCO) = [F:IWC]OPECST
            [M:CST]SOPETIM([M:CST]NBSCO) = [F:IWC]OPETIMTOP
            [M:CST]SSETAMT([M:CST]NBSCO) = [F:IWC]SETCST * [F:IWC]SETTIMTOP
            [M:CST]SOPEAMT([M:CST]NBSCO) = [F:IWC]OPECST * [F:IWC]OPETIMTOP
            [M:CST]SCOITMREF([M:CST]NBSCO) = [F:IWC]SCOITMREF
            [M:CST]SCSTCOD([M:CST]NBSCO) = [F:IWC]CSTCOD
            [M:CST]PRISCO([M:CST]NBSCO)  = [F:IWC]PRISCO
            [M:CST]SSETTIM([M:CST]NBSCO) = [F:IWC]SETTIMTOP
            [M:CST]SOPETIM([M:CST]NBSCO) = [F:IWC]OPETIMTOP

            # On ne renseigne pas OVENAT (de toute façon on ne peut pas) car les FG doivent déjà être dans ICN
            If [F:IWC]OVEAMTTOP>0
                J=find([M:CST]SCOWST([M:CST]NBSCO),[M:CST]OSCOWST(0..[M:CST]NBFGSCO-1))-1
                [M:CST]SVARAMT([M:CST]NBFGSCO) = [F:IWC]OVEAMTTOP
                [M:CST]OSCOWST([M:CST]NBFGSCO) = [M:CST]SCOWST([M:CST]NBSCO)
                [M:CST]NBFGSCO+=1
            Endif
            [M:CST]NBSCO += 1

        Endif
Endcase

Return

$VALID

# la toute première rupture se fait sur un buffer vide !!? >
#CCC: ZZZ a été remplacé par AAA_
If [F:AAA_]STOFCY="" | [F:AAA_]ITMREF=""
  Return
Endif

CTL_OK = 1
Read [F:ITF]ITF0=[F:AAA_]ITMREF;[F:AAA_]STOFCY
If fstat
  CTL_OK = 0
  Call ECR_TRACE(mess(23,100,1)-mess(4,198,1)-[F:AAA_]ITMREF-[F:AAA_]STOFCY,1) From GESECRAN
Endif

# récupérer la classe qui avait été écrite à la dernière rupture
[F:ITC] = [F:AAA_]

# Issue 80336 - 2012-02-23 by CCC
If  sigma(0,dim([F:ITC]MATCST)-1,[F:ITC]MATCST(indcum)<0)>0
& | sigma(0,dim([F:ITC]MACCST)-1,[F:ITC]MACCST(indcum)<0)>0
& | sigma(0,dim([F:ITC]LABCST)-1,[F:ITC]LABCST(indcum)<0)>0
& | [F:ITC]SCOCST<0
& | [F:ITC]OVEMATCST<0
& | [F:ITC]OVEMACCST<0
& | [F:ITC]OVELABCST<0
& | [F:ITC]OVESCOCST<0
& | sigma(0,dim([F:ITC]FXDMATCST)-1,[F:ITC]FXDMATCST(indcum)<0)>0
& | sigma(0,dim([F:ITC]FXDMACCST)-1,[F:ITC]FXDMACCST(indcum)<0)>0
& | sigma(0,dim([F:ITC]FXDLABCST)-1,[F:ITC]FXDLABCST(indcum)<0)>0
& | [F:ITC]FXDSCOCST<0
& | [F:ITC]FXDOVEMAT<0
& | [F:ITC]FXDOVEMAC<0
& | [F:ITC]FXDOVELAB<0
& | [F:ITC]FXDOVESCO<0
& | sigma(0,dim([F:ITC]MATLEVCST)-1,[F:ITC]MATLEVCST(indcum)<0)>0
& | sigma(0,dim([F:ITC]MACLEVCST)-1,[F:ITC]MACLEVCST(indcum)<0)>0
& | sigma(0,dim([F:ITC]LABLEVCST)-1,[F:ITC]LABLEVCST(indcum)<0)>0
& | [F:ITC]SCOLEVCST<0
& | [F:ITC]OVEMATLEV<0
& | [F:ITC]OVEMACLEV<0
& | [F:ITC]OVELABLEV<0
& | [F:ITC]OVESCOLEV<0
& | sigma(0,dim([F:ITC]FXDMATLEV)-1,[F:ITC]FXDMATLEV(indcum)<0)>0
& | sigma(0,dim([F:ITC]FXDMACLEV)-1,[F:ITC]FXDMACLEV(indcum)<0)>0
& | sigma(0,dim([F:ITC]FXDLABLEV)-1,[F:ITC]FXDLABLEV(indcum)<0)>0
& | [F:ITC]FXDSCOLEV<0
& | [F:ITC]FXDOVEMATL<0
& | [F:ITC]FXDOVEMACL<0
& | [F:ITC]FXDOVELABL<0
& | [F:ITC]FXDOVESCOL<0
    CTL_OK=0
    Call ECR_TRACE(mess(1,175,1)-[F:AAA_]ITMREF-[F:AAA_]STOFCY,1) From GESECRAN
Endif

[F:ITC]MATTOT = sum([F:ITC]MATCST)
[F:ITC]MACTOT = sum([F:ITC]MACCST)
[F:ITC]LABTOT = sum([F:ITC]LABCST)
[F:ITC]SCOTOT = [F:ITC]SCOCST

[F:ITC]OVETOT = [F:ITC]OVEMATCST+[F:ITC]OVEMACCST+[F:ITC]OVELABCST+[F:ITC]OVESCOCST
[F:ITC]CSTTOT = [F:ITC]MATTOT+[F:ITC]MACTOT+[F:ITC]LABTOT+[F:ITC]SCOTOT
[F:ITC]VLTTOT = [F:ITC]CSTTOT+[F:ITC]OVETOT

# CCC (04/07/07) DM 42006
If [F:ITC]CLCQTY = 0
    If [F:ITF]REOMINQTY <> 0
        [F:ITC]CLCQTY = [F:ITF]REOMINQTY
    Elsif [F:ITF]MFGLOTQTY > 0
        [F:ITC]CLCQTY = [F:ITF]MFGLOTQTY :# calcul pour le lot technique
    Else
        [F:ITC]CLCQTY = 1
    Endif
Endif

If [F:ITC]CSTTYP = 0 [F:ITC]CSTTYP = 1 Endif
If [F:ITC]ITCDAT = [0/0/0] [F:ITC]ITCDAT=date$ Endif

Raz GMESSAGE

# contrôles d'existence...
Look [F:ITM]ITM0=[F:ITC]ITMREF
If fstat
  CTL_OK = 0
  Call ECR_TRACE(mess(23,100,1)-mess(80,197,1)-[F:ITC]ITMREF,1) From GESECRAN
Endif

Look [F:FCY]FCY0=[F:ITC]STOFCY
If fstat
  CTL_OK = 0
  Call ECR_TRACE(mess(23,100,1)-mess(154,198,1)-[F:ITC]STOFCY,1) From GESECRAN
Endif

# droits sur le site
Call CONTFCY([F:ITC]STOFCY) From CPTSUB
If GMESSAGE <> ""
  CTL_OK = 0
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Endif

Call GETDEV([F:ITC]STOFCY) From DEVSUB # on aura [F:TCU]CUR
# la devise des montants importés doit être celle du site  (sinon convertir ??)

Raz ERR_TRA
If CTL_OK>0
    # Contrôle des dates de validité
    If find([F:ITC]CSTTYP,1,3)
        # Pour les types 1 et 2, au minimum, l'exercice doit être renseigné
        If [F:ITC]FIYNUM>0
            Read [F:FIY]FIY0=GSOCIETE;GTYPGEN;[F:ITC]FIYNUM
            If fstat
                CTL_OK = 0
                ERR_TRA= GSOCIETE-num$([F:ITC]FIYNUM)-":"-mess(7,101,1)
            Endif
            If [F:ITC]ITCSTRDAT=[0/0/0]
                [F:ITC]ITCSTRDAT = [F:FIY]FIYSTR
            Endif
            If [F:ITC]ITCENDDAT=[0/0/0]
                [F:ITC]ITCENDDAT = [F:FIY]FIYEND
            Endif
            If !([F:FIY]FIYSTR<=[F:ITC]ITCSTRDAT & [F:ITC]ITCSTRDAT<=[F:FIY]FIYEND)
                CTL_OK = 0
            Endif
            If !([F:FIY]FIYSTR<=[F:ITC]ITCENDDAT & [F:ITC]ITCENDDAT<=[F:FIY]FIYEND)
                CTL_OK = 0
            Endif
        Else
            CTL_OK = 0
        Endif
    Endif
    If [F:ITC]ITCSTRDAT > [F:ITC]ITCENDDAT
        CTL_OK = 0
    Endif
    If CTL_OK=0
        If ERR_TRA=""
            Call ECR_TRACE(mess(148,192,1),1) From GESECRAN
        Else
            Call ECR_TRACE(ERR_TRA,1) From GESECRAN
        Endif
    Endif
Endif

Raz GPE
GPOINT="BEFCTLOVE"
Gosub ENTREE From EXEFNC

# controler que la somme des natures de FG = OVETOT
If TOT_NAT <> [F:ITC]OVETOT
   If GPE=1
      Local Decimal LVALMAX
      Local Char LZONMAX(30), LZON(30)
      Raz LVALMAX, LZONMAX
      LZONMAX="[F:ITC]OVEMATCST"
      For LZON="[F:ITC]OVEMATCST","[F:ITC]OVEMACCST","[F:ITC]OVELABCST","[F:ITC]OVESCOCST"
          If evalue(LZON)>LVALMAX
              LZONMAX = LZON
              LVALMAX = evalue(LZON)
          Endif
      Next
      Assign LZONMAX With TOT_NAT-[F:ITC]OVETOT
      [F:ITC]OVETOT = TOT_NAT
   Else
       # "Le total des natures de frais est différent du total frais généraux"
       ERR_TRA = num$(TOT_NAT)+"/"+num$([F:ITC]OVETOT)-":"-mess(311,199,1)-":"- [F:ITC]STOFCY - [F:ITC]ITMREF
       ERR_TRA -= mess([F:ITC]CSTTYP,347,1)-num$([F:ITC]YEA)-num$([F:ITC]CSTSEQ)
       Call ECR_TRACE(ERR_TRA,1) From GESECRAN
       CTL_OK = 0
   Endif
Endif

If CTL_OK < 1 Goto FIN_VALID Endif

# Issue 89368 - 2013-07-04 by CCC : Le coût mono-niveau doit correspondre au coût multi-niveaux
LTOTLEV = sigma(0,dim([F:ITC]MATLEVCST)-1,[F:ITC]MATLEVCST(indcum))
&       + sigma(0,dim([F:ITC]MACLEVCST)-1,[F:ITC]MACLEVCST(indcum))
&       + sigma(0,dim([F:ITC]LABLEVCST)-1,[F:ITC]LABLEVCST(indcum))
&       + [F:ITC]SCOLEVCST
&       + [F:ITC]OVEMATLEV
&       + [F:ITC]OVEMACLEV
&       + [F:ITC]OVELABLEV
&       + [F:ITC]OVESCOLEV
If LTOTLEV <> [F:ITC]VLTTOT
    ERR_TRA = num$(LTOTLEV)+"/"+num$([F:ITC]VLTTOT)-":"-mess(414,184,1)-":"- [F:ITC]STOFCY - [F:ITC]ITMREF
    ERR_TRA -= mess([F:ITC]CSTTYP,347,1)-num$(max(1,[F:ITC]ITCSEQ))
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    CTL_OK=0
Endif

If CTL_OK < 1 Goto FIN_VALID Endif

# création de l'enregistrement coûts
ITC_OK = 1
Call DEBTRANS From GLOCK

$TR1
Trbegin [ITC]
[F:ITC]UID       = adxuid(1)
[F:ITC]CREDAT    = date$
[F:ITC]CREUSR    = GUSER
[F:ITC]EXPNUM    = [C]EXPORT

If [F:ITC]ITCSEQ=0
    Filter [ITC2] Where ITMREF = [F:ITC]ITMREF
&                     & STOFCY = [F:ITC]STOFCY
&                     & CSTTYP = [F:ITC]CSTTYP
    Read [ITC2] First
    [F:ITC]ITCSEQ = [F:ITC2]ITCSEQ+1
Else
    Delete [ITC2] Where ITMREF = [F:ITC]ITMREF
&                    & STOFCY = [F:ITC]STOFCY
&                    & CSTTYP = [F:ITC]CSTTYP
&                    & ITCSEQ = [F:ITC]ITCSEQ
&                    & UID    = adxuid(1)
    Delete [ICN2] Where ITMREF = [F:ITC]ITMREF
&                    & STOFCY = [F:ITC]STOFCY
&                    & CSTTYP = [F:ITC]CSTTYP
&                    & ITCSEQ = [F:ITC]ITCSEQ
&                    & UID    = adxuid(1)
    Delete [ICC2] Where ITMREF = [F:ITC]ITMREF
&                    & STOFCY = [F:ITC]STOFCY
&                    & CSTTYP = [F:ITC]CSTTYP
&                    & ITCSEQ = [F:ITC]ITCSEQ
&                    & UID    = adxuid(1)
    Delete [IWC2] Where ITMREF = [F:ITC]ITMREF
&                    & STOFCY = [F:ITC]STOFCY
&                    & CSTTYP = [F:ITC]CSTTYP
&                    & ITCSEQ = [F:ITC]ITCSEQ
&                    & UID    = adxuid(1)
Endif

Write [ITC]

If fstat
  ITC_OK = 0
  Goto FIN_TR1
Endif

Call ECR_TRACE("savicn",0) From GESECRAN
Call SAVICN(CTL_OK) From TRTCOST
If CTL_OK > 0
    ITC_OK = 0
    Goto FIN_TR1
Endif

Call ECR_TRACE("SAVICC",0) From GESECRAN
Call SAVICC(CTL_OK) From TRTCOST
If CTL_OK > 0
    ITC_OK = 0
    Goto FIN_TR1
Endif


Call ECR_TRACE("SAVIWC",0) From GESECRAN
Call SAVIWC(CTL_OK) From TRTCOST
If CTL_OK > 0
    ITC_OK = 0
    Goto FIN_TR1
Endif


$FIN_TR1
If ITC_OK = 1
    Readlock [ITC]ITC0=[F:ITC]STOFCY;[F:ITC]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[F:ITC]UID
    Call UPDITC(1,ITC_OK) From SUBICC
    ITC_OK = !ITC_OK
Endif
If ITC_OK = 1
   ERR_TRA = mess(51,197,1)-":"-[F:ITC]STOFCY -[F:ITC]ITMREF- mess([F:ITC]CSTTYP,347,1)
   ERR_TRA -= num$([F:ITC]ITCSEQ)-num$([F:ITC]UID)
   Call ECR_TRACE(ERR_TRA,0) From GESECRAN
   If [M:CST]NBFGITM > 0
     ERR_TRA = mess(312,199,1)-":"- sigma(N=0,[M:CST]NBFGITM-1,[M:CST]NATITM(N)-" ")
     Call ECR_TRACE(ERR_TRA,0) From GESECRAN
   Endif
   Commit
Else
   ERR_TRA = mess(13,100,1) - "ITMCOST" - mess(14,100,1) -[F:ITC]STOFCY -[F:ITC]ITMREF- mess([F:ITC]CSTTYP,347,1)
   ERR_TRA -= num$([F:ITC]ITCSEQ)-num$([F:ITC]UID)

   Call ECR_TRACE(ERR_TRA,1) From GESECRAN
   Rollback : GOK = 0
Endif

$FIN_VALID

Return

