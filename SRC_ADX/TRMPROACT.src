#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################
# TRMPROACT : Action métier massive - trt commun - Modèle 2
#
# RAF :
#
# MODIF :
#
#  - XXX - dd.mm.yyyy - FQ zzzzz - Commentaire
#  - CBO - 30.09.2014 - FQ102807 - exclusion des biens sortis de l'exercice
#  - GLE - 12.02.2014 - FQ 96606 - gestion correcte de l'activation/désactivation du bouton OK en sélection toutes/aucune société
#  - MWA - 31.12.2013 - FQ 83184 - message en français
#  - GLE - 15.03.2013 - FQ 88667 - Appel au traitement métier sur le clic droit Toutes/Aucune Sociétés ou Sites
#  - GLE - 19.09.2012 - FQ 84645 - Aucun bien sélectionné si expression de lien dans le contexte
#                                  de l'objet et utilisation des sélection étendues
#  - CBO - 25.10.2012 - FQ 85023 - Chargement des axes de la société si accès direct par le site
#  - GLE - 15.03.2012 - FQ 80772 - Messages en français
#  - CBO - 15.02.2012 - FQ 80130 - ajout de  + 20 pour les EPH et cpsts)
#  - GBO - 01.03.2011 - FQ 70465 - Les sociétés ne sont pas éligibles si un contexte est désynchronisé
#  - GBO - 22.12.2010 - FQ 68447 - Vérification des sources
#  - GLE - 19.07.2010 - FQ 66106 - Optimisation
#  - GLE - 26.05.2010 - FQ 64912 - Chargement du masque FASPARCPY pour le serveur batch
#  - GBO - 01.04.2010 - FQ 63487 - Action interdite si aucun paramétrage dans le dossier.
#  - GLE - 09.12.2009 - FQ 60746 - Déplacement des déclarations et suppressions des globales G_MODIF_LOC et G_ORI_TRFDAT qui sont liées au transfert dans TRTFASTRF
#  - GLE - 02.12.2009 - FQ 60561 - Correction erreur classe [M:FPC] inexistante lors du cochage d'une société en soumission de requête batch
#  - GLE - 01.12.2009 - FQ 59102 - Problème d'initialisation de l'onglet sélection avancée en soumission de requête
######################################################################
 Local Char MASUNI : MASUNI="M"
 Local Char ACTNAM : ACTNAM="FASTEST"
 Call LAUNCH_ACT(MASUNI) From ="TRT"+ACTNAM
End
######################################################################
$ACTION
If 1=0 & GUSER ="GBO" & GSERVEUR & dim(GTRACE)>0 : Call ECR_TRACE("TRMPROACT /"-ACTION,0) From GESECRAN : Endif
#If GUSER = "GLE" : Infbox "TRMPROACT /"-ACTION : Endif
 Case ACTION                                   # Intéractif    Batch
  When "OUVRE_BATCH" : Gosub OUVRE_BATCH       #      -         O
  When "INIT_DIA"    : Gosub INIT_DIA          #      -         O
  When "INIT"        : Gosub INIT              #      O         O
  When "AVANT_PAR"   : Gosub AVANT_PAR         #      O         O
  When "OUVRE"       : Gosub OUVRE             #      O         -
  When "DEBUT"       : Gosub DEBUT             #      O         -

  When "SETBOUT"     : Gosub SETBOUT           #      O         -
  When "BOUTON"      : Gosub BOUTON            #
  When "AV_CHOIX"    : Gosub AV_CHOIX          #      O         -
  When "APRES_MODIF" : Gosub APRES_MODIF       #      O         -
  When "AP_CHOIX"    : Gosub AP_CHOIX          #      O         -
  When "AVANT_OK"    : Gosub AVANT_OK          #      O         -
  When "OK"          : Gosub OK                #      O         -
  When "END"         : Gosub END_BOITE         #      O         -
  When "FIN"         : Gosub FIN               #      O         -
  When "FINSAI"      : Gosub FINSAI            #      O         -
  When "CONTROLE"    : Gosub CONTROLE          #      O         O
  When "EXEC"        : Gosub EXEC              #      O         O
  When "TERMINE"     : Gosub TERMINE           #      O         O
  When "SORTIE"      : Gosub SORTIE            #      O         O
  When Default
 Endcase
Return

#########################################################################
$OUVRE_BATCH
Return

#########################################################################
$INIT_DIA # (Initialisation diverses en massif batch - Utilisé uniquement en saisie paramétre à partir de la gestion des requêtes)
 #=> Initialisation de la partie modèle de la fenêtre critère de l'action massive (batch)
 If GBATCH
  Gosub OPEN_WIN                                                  #=> Ouverture des masques de la fenêtre critère FQ60561
  Gosub DEF_GLO_MAS #FQ38386
  Gosub INIT_WIN From TRMPROACT
  # FQ59102
  If clalev([M:ASL]) : Close Mask [M:ASL] : Endif                 # Fermeture du masque car il est déjà ouvert et il y a un test dans ASELOBJ
  Gosub OUVRE From ASELOBJ                                        #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
 Endif
 If [M:MHC]NBFCY=0 : End : Endif
 #=> On rend le masque en-tête invalide pour faire tous les contrôles
 Setmok [M:MHC] With 0
Return

#########################################################################
$INIT  #(Uniquement en execution d'une action massive batch)
 If GSERVEUR                                                      # Si on est en massif à l'exécution d'une requête batch:
  Gosub DEF_GLO_MAS                                               #=> Déclaration des globales particulières au massif
  Gosub OUVRE From ASELOBJ                                        #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
 Endif
Return

#########################################################################
$AVANT_PAR #(Uniquement en massif interactif ou à la soumission de la requête batch)
 If !GSERVEUR                                                     # Si on est en massif interactif ou soumission requête batch :
  Gosub OPEN_WIN                                                  #=> Ouverture des masques de la fenêtre critère
  Gosub DEF_GLO_MAS                                               #=> Déclaration des globales particulières au massif
  Gosub OUVRE From ASELOBJ                                        #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
 Else
  If !clalev([M:FPC]) : Local Mask FASPARCPY [FPC] : Endif : # FQ64912
 Endif
Return

#########################################################################
$OUVRE
  # FQ60746 : déplacé dans TRTFASTRF
  #If GPHY = G_OUI Then
  #   # Variable globale pour savoir s'il n'y a que la localisation de modifiée pour ne générer l'évènement que sur les éléments physiques
  #   If dim(G_MODIF_LOC) <0 Then
  #      Global Integer G_MODIF_LOC
  #   Endif
  #   # Variable indiquant si la date de transfert récupérée est :
  #   # - la date du dernier transfert du bien ("B")
  #   # - la date du dernier transfert d'un élément physique rattaché au bien ("T")
  #   # - la date de réception d'un élément physique rattaché au bien ("R")
  #   If dim(G_ORI_TRFDAT) <0 Then
  #      Global Char G_ORI_TRFDAT
  #   Endif
  #Endif
  # FIN FQ60746

  #Fq63487-Pas de société / site / contexte : action métier interdite
  If !clalev([F:CNX]) : Local File CONTEXT [CNX]  : Endif
  Read [F:CNX] First
  If fstat
   Call ERREUR(mess(255,7770,1)) From GESECRAN
   GOK=0
   ABANDON_TRT=1
   FIN=1
   Return
  Endif

Return

#########################################################################
$DEBUT # (Initialisation diverses en massif intéractif)

 If !GSERVEUR # Si on est en massif interactif ou soumission requête batch :
  Gosub DEF_GLO_MAS                                               #=> Déclaration des globales particulières au massif
                      Raz [M:ASL]FLD1 : Raz [M:ASL]OPE1 : Raz [M:ASL]VAL1 : Raz [M:ASL]VALI1
  Raz [M:ASL]ANDOR2 : Raz [M:ASL]FLD2 : Raz [M:ASL]OPE2 : Raz [M:ASL]VAL2 : Raz [M:ASL]VALI2
  Raz [M:ASL]ANDOR3 : Raz [M:ASL]FLD3 : Raz [M:ASL]OPE3 : Raz [M:ASL]VAL3 : Raz [M:ASL]VALI3
  Raz [M:ASL]ANDOR4 : Raz [M:ASL]FLD4 : Raz [M:ASL]OPE4 : Raz [M:ASL]VAL4 : Raz [M:ASL]VALI4
  Raz [M:ASL]ANDOR5 : Raz [M:ASL]FLD5 : Raz [M:ASL]OPE5 : Raz [M:ASL]VAL5 : Raz [M:ASL]VALI5
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif

  Gosub DEBUT From ASELOBJ                                        #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
 Endif
 #=> Initialisation de la partie modèle de la fenêtre critère de l'action massive (Interactif)
 If !GBATCH
  Gosub INIT_WIN From TRMPROACT
 Else
  Affzo [M:MHC]
 Endif
 Setmok [M:MHC] With 0
Return

#########################################################################
$SETBOUT
 # Grisage / dégrisage des boutons OK et CONTROLER
 # en fonction des sociétés sélectionnées
 If ((ACTMONCPY=G_NON) | (ACTMONCPY=G_OUI & G_NBR_SELCPY=0))
  If G_NBR_SELCPY=0 & G_NOCHOI_SELALL=G_NON
   If ( dim(CHBOU)>0 ) Then : Call VIREBOUT (CHBOU,"O") From GOBJET : Endif
   If ( dim(CHMEN)>0 ) Then : Call VIREBOUT (CHMEN,"D") From GOBJET : Endif
  Endif
 Endif
 # Si la population est en table temporaire et que les paramètres n'ont pas été appliqués : "Ok" interdit
 If ACTSTATUS=STA_TEMP
  If ( dim(CHBOU)>0 ) Then : Call VIREBOUT (CHBOU,"O") From GOBJET : Endif
 Endif
 # En saisie des paramètres batch : "Contrôler" interdit
 If GBATCH
  If ( dim(CHMEN)>0 ) Then : Call VIREBOUT (CHMEN,"D") From GOBJET : Endif
 Endif
Return

#########################################################################
$BOUTON
 Local Integer ERR      # Code erreur retourné par les sous-programmes de traitement de la population
 Local Char    MES(255) # Message retourné par les sous-programmes de traitement de la population
 Case BOUT
  When "D"
    If dim(CONTROLER)<0 : Local Integer CONTROLER : Endif
    Gosub CONTROLER
  When "R"
    G_NBR_SELCPY=func TRMPROACT.NBR_SOCSEL(0,0)
    Local Integer NBDLREC,ERR
    Local Char    MES
    Call VIDER(NUMACT,TMPTAB,NBDLREC,ERR) From TRCPROCOM
    ACTSTATUS=STA_DEBUT
  When Default
 Endcase
Return

#########################################################################
$AV_CHOIX
Return

#########################################################################
$APRES_MODIF
 #> Comptage du nombre de société sélectionnées et stockage dans la variable G_NBR_SELCPY
 Case COUZON
  When "FLGCPY"
    G_NBR_SELCPY=func TRMPROACT.NBR_SOCSEL(nolign,val(CZ))
  When "FLGFCY"
    G_NBR_SELCPY=func TRMPROACT.NBR_SOCSEL(0,0)
  When Default
 Endcase
 #> Vérif si modification des critères de sélection sur l'écran "Sélection étendue" #Bug 25078
 Gosub MODIF_ASELOBJ
Return

#########################################################################
$AP_CHOIX
Return

#########################################################################
$AVANT_OK
Return

#########################################################################
$OK
 ABANDON_TRT = 0
 Gosub SET_CRITERE                                      #=> Construction des critères de sélection
Return

#########################################################################
$END_BOITE
 ABANDON_TRT = 1
Return

#########################################################################
$FIN
Return

#########################################################################
$FINSAI
  # FQ60746 - Déplacé dans TRTFASTRF
  #If GPHY = G_OUI Then
  #   # Variable globale pour savoir s'il n'y a que la localisation de modifiée pour ne générer l'évènement que sur les éléments physiques
  #   If dim(G_MODIF_LOC)>0 Then Kill G_MODIF_LOC Endif
  #   If dim(G_ORI_TRFDAT)>0 Then Kill G_ORI_TRFDAT Endif
  #Endif
  # FIN FQ60746
Return

#########################################################################
$CONTROLE
 If [M:MHC]NBFCY=0 : FIN=1 : Endif : #Gle-300306-Fq 35284-Aucun site dans le tableau, on quitte
 # FQ64912
 If GSERVEUR=1
  Local Integer I_CPY : I_CPY=find(G_OUI,[M:MHC]FLGCPY)
  If I_CPY
   GSOCIETE=[M:MHC]CPY(I_CPY-1)
   Call CHARGE_ENVIRONNEMENT() From GLOFCYCPY
  Endif
 Endif
Return

#########################################################################
$EXEC

 If ABANDON_TRT : Return : Endif
 If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA] : Endif
 TRTYP=1 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2 #=> OUVERTURE de la trace
 FLGSIM=[M:MHC]FLGSIM #: Infbox "FLGSIM -"-num$(FLGSIM) # Tst
 FLGREP=[M:MHC]FLGREP #: Infbox "FLGREP -"-num$(FLGREP) # Tst
 FLGETA=[M:MHC]FLGETA #: Infbox "FLGETA -"-num$(FLGETA) # Tst
 FLGDET=[M:MHC]FLGDET #: infbox "FLGDET -"-num$(FLGDET) # Tst
 #=> Variables nécessaires au traitement
 Local Char    MES(255)
 Local Integer ERR
 #=> Emission des informations relatives à l'action dans la trace :
 #-> Emssion dans la trace des options du traitement massif
 TRTYP=2  : TRPARM=1 : Gosub GESTRACE From TRCPROCOM2 #-> En-tête "option du traitement"
 TRTYP=25 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2 #-> Liste des options du traitement massif
 #-> Emission dans la trace des critères de sélection
 TRTYP=2  : TRPARM=2 : Gosub GESTRACE From TRCPROCOM2 #-> En-tête "En-tête critères de sélection"
 TRTYP=21 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2 #-> Emission dans la trace des critères de sélection
 #-> Emission dans la trace des paramètres de l'action
 TRTYP=2  : TRPARM=3 : Gosub GESTRACE From TRCPROCOM2  #-> Emission de l'en-tête "Paramètres de l'action" dans la trace
 TRTYP=20 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2  #-> Edition des paramètres dans la trace
 TRTYP=2  : TRPARM=4 : Gosub GESTRACE From TRCPROCOM2  #-> Emission de l'en-tête "Compte-rendu des modifications" dans la trace
 #-> Traitement de la population
 If ACTSTATUS=STA_DEBUT   #=> Cas 1 - Clic directe sur OK
  If GUSER=USRDBG : Infbox "EXEC-CAS1-Mise à jour directe. Trace"-GTRACE : Endif
  FLGREP=G_NON  # Tst : ça semble bien marcher même quand on ne l'affecte pas !!
  Gosub SET_CRITERE
  If GUSER=USRDBG : Gosub AFF_CRITERE From TRCPROCOM : Endif
  If !GSERVEUR & ACTTYPGES=GTAMMAS & dim(ACTSILENCE)<0 : Call TEMPON('R') From GESECRAN : Endif  #Gbn-270405-Ajout d'une boîte pour patienter
  Gosub LOCKER_POPULATION
  If !GSERVEUR & ACTTYPGES=GTAMMAS & dim(ACTSILENCE)<0 : Call TEMPOFF() From GESECRAN   : Endif  #Gbn-270405-Fermeture de la boîte pour patienter
  If ACTSTATUS=STA_LOCK & !ERR
   Gosub MAJ_DIRECTE
   If ERR
    Return
   Endif
  Else
   Return
  Endif
 Else                     #=> Cas 2 - On était passé par Contrôler
  If GUSER=USRDBG : Infbox "EXEC-CAS2-Report TMP->Tables" : Endif
  Gosub REPORTER_TABLE
 Endif
Return

#########################################################################
$TERMINE
 Gosub NETTOYER                                       #=> Vide les tables temporaires et unlocke
 #If GUSER=USRDBG  & !GSERVEUR : Dbgaff : Endif
 If ACTSILENCE=G_OUI
  If NBCPYERR | !NBCPYMAJ
   G_MAJOK=G_NON
  Endif
 Else
  If dim(GNUMTRACE)>0
   If !GSERVEUR
     Call FERME_TRACE(1) From TRACEABX3 : TRA=1
   Else
    Call VIDE_TRACE(1) From TRACEABX3
   Endif
  Else
   If !GSERVEUR
    Call FERME_TRACE From LECFIC : TRA=1
   Endif
  Endif
 Endif
Return

#########################################################################
$SORTIE
 Gosub KILL_CONSTANTES From TRCPROCOM                 #=> Destruction des constantes
 Gosub KILL_GLOBALES   From TRCPROCOM                 #=> Destruction des variables globales
 If dim(NUMACT)>0 : Kill NUMACT : Endif               #=> Fin d'une action massive, on détruit la globale numéro de traitement
Return

##########################################################################
## Sous-programmes et routines communs
##########################################################################

#------------------------------------------------------------------------#
# Contrôle que borne début est bien inférieure à borne de fin            #
#------------------------------------------------------------------------#
# Si PZCONT=2 PVALEUR contrôle de la valeur de la borne fin / borne deb  #
#    PZCONT=1 PVALEUR contrôle de la valeur de la borne déb / borne fin  #
#------------------------------------------------------------------------#
Subprog CONT_BORNE(PZON,PMASK,PVALEUR,PZCONT)
Value Char    PZON
Value Char    PMASK
Value Char    PVALEUR()
Value Integer PZCONT

If PZCONT=2
 If evalue('"'+PVALEUR+'"'+'<[M:'+PMASK+']'+PZON+'DEB')
  GERREUR=1
  GMESSAGE= mess(185,7770,1)    #"Valeur de fin inférieure à valeur de début"
  mkstat=2
 Endif
Elsif PZCONT=1
 If evalue('"'+PVALEUR+'"'+'>[M:'+PMASK+']'+PZON+'FIN')
  GERREUR=1
  GMESSAGE= mess(185,7770,1)    #"Valeur de fin inférieure à valeur de début"
  mkstat=2
 Endif
Else
 GERREUR=1
 GMESSAGE=  mess(186,7770,1)   # "S/p TRMOBJACT.CONT_BORNE paramètre PZCONT valeur incorrecte : "-num$(PZCONT)
Endif

End

#---------------------------------------------------------------------
# Renvoi le nombre de sociétés sélectionnées
#---------------------------------------------------------------------
Funprog NBR_SOCSEL(PINDCUR,PVALCUR)
Value Integer PINDCUR
Value Integer PVALCUR

Local Integer NBR_SOCSEL : NBR_SOCSEL=0
Local Integer I_CPY

For I_CPY=1 To [M:MHC]NBCPY
 If I_CPY=PINDCUR
  If PVALCUR=G_OUI : NBR_SOCSEL+=1 : Endif
 Else
  If [M:MHC]FLGCPY(I_CPY-1)=G_OUI   : NBR_SOCSEL+=1 : Endif
 Endif
Next I_CPY

End NBR_SOCSEL

#---------------------------------------------------------------------
# Permet de récupérer la société sélectionnée quand il n'y en a qu'une
#---------------------------------------------------------------------
Funprog GET_SOCSEL(PINDCUR,PVALCUR)
Value Integer PINDCUR
Value Integer PVALCUR

Local Char    SELCPY
Local Integer I_CPY
Local Integer TROUVE

SELCPY=""
TROUVE=0

If PVALCUR=G_OUI
 SELCPY=[M:MHC]CPY(PINDCUR-1)
 TROUVE=1
Endif

For I_CPY=1 To [M:MHC]NBCPY
 If I_CPY<>PINDCUR
  If [M:MHC]FLGCPY(I_CPY-1)=G_OUI
   If !TROUVE
    SELCPY=[M:MHC]CPY(I_CPY-1)
    TROUVE=1
   Else
    SELCPY=""
    Break
   Endif
  Endif
 Endif
Next I_CPY

End SELCPY

#########################################################################

$OPEN_WIN

 #=> OUVERTURE des masques de la fenêtre critère

 Local  Char    WINACT : WINACT=PARAM(1)+"M"
 Local  Integer I_MSK
 Global Char    GACTMSKLIS(255)
 Local  Integer NBMASK

 If !clalev([F:AWI]) : Local File AWINDOW : Endif
 If !clalev([F:AMK]) : Local File AMSK    : Endif

 Read [AWI]AWI0=WINACT
 If !fstat
  Local Mask =[F:AWI]MSKENT
  For I_MSK=0 To [F:AWI]NBMSK
    Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
    Local Mask =[F:AMK]CODMSK
    NBMASK+=1
    If NBMASK>1
     GACTMSKLIS+=";"
    Endif
    GACTMSKLIS+="[M:"+[F:AMK]ABRMSK+"]"
  Next I_MSK
 Endif

 If !clalev([M:FPC])  : Local Mask FASPARCPY [FPC]  : Endif

 Raz GCOUSOC
 Raz GCOUSIT

Return

#========================================================================
$INIT_WIN

 Local Integer SEL_FCY_TECH : SEL_FCY_TECH=0

 Local Char    SCPY         # Gestion de la rupture société
 Local Integer LIMMOCPY     # Société immo ? G_OUI / G_NON
 If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

 Effzo [M:MHC]

 #> Chargement du tableau des sites

 Raz nolign
 Filter [FCY] Where (FINFLG=G_OUI) #& (find(CREUSR,LSTUSR)<>0 | find(UPDUSR,LSTUSR)<>0)
 For [FCY]FCY1
  If [F:FCY]LEGCPY<>SCPY
   SCPY=[F:FCY]LEGCPY
   LIMMOCPY=func TRCPROCOM.IS_SOC_IMMO(SCPY)
  Endif
  If LIMMOCPY=G_OUI
   If G_CTRL_CPY=G_OUI
     mkstat = 0 : # GLE !! EN ATTENTE DE CORRECTION DE LA FICHE 22733 PAR SOPHIA !!
     # Contrôle si l'utilisateur est habilité pour toute la société
     Call CONTALLFCY([F:FCY]LEGCPY) From SUPCPT
   Else
     # Contrôle si l'utilisateur est habilité pour ce site
     Call CONTFCY([F:FCY]FCY) From SUPCPT
   Endif
   # FQ70465
   If func GLOBIENS.IS_DESYNC_CNX(SCPY, 0)=G_OUI
     mkstat = 2
   Endif
   If !mkstat
    #Gle-300306-Fq 35284-Au moins un site est eligible techniquement, on en prend note
    SEL_FCY_TECH = 1
    #Gbn-090106-Fq 34177-Ajout critère de sélection sur les sites utilisables ou pas ... GOK à 0 si site à rejeter
    GOK=1 : ACTMET="SET_CRIT_FCY" : Gosub ACTMET From TRCPROCOM   : # Critère supplémentaire site
    If GOK
     nolign+=1
     [M:MHC]FCYCPY(nolign-1) = [F:FCY]LEGCPY
     [M:MHC]FCY(nolign-1)    = [F:FCY]FCY
    Endif
   Endif
  Endif
 Next
 GOK=1
 Filter [FCY]
 [M:MHC]NBFCY=nolign

 If [M:MHC]NBFCY=0 Then
  If !SEL_FCY_TECH Then
    # L'utilisateur n'est habilité pour aucun site
    If G_CTRL_CPY=G_OUI
      Infbox(mess(189,7770,1)) : # Vous n'êtes habilité pour aucune société dans sa totalité.
    Else
      Infbox(mess(190,7770,1)) : # Vous n'êtes habilité pour aucun site.
    Endif
  Else
    # L'utilisateur est habilité pour au moins un site. Il y a donc eu un interdiction fonctionnelle sur au moins un site.
    If G_MESS_FCY(0)<>0 & G_MESS_FCY(1)<>0 : # La globale G_MESS_FCY donne le numéro et le chapitre du message de rejet fonctionnel
      Infbox(mess(G_MESS_FCY(0),G_MESS_FCY(1),1))
    Else                : # Message générique
      Infbox(mess(191,7770,1)) : # Aucune société n'est éligible pour ce traitement.
    Endif
  Endif
  FIN=1
  Return
 Endif

 #> Chargement du tableau des sociétés

 Local Integer I_FCY
 Local Char    CUR_FCYCPY
 Raz CUR_FCYCPY, nolign
 For I_FCY=1 To [M:MHC]NBFCY
  If CUR_FCYCPY<>[M:MHC]FCYCPY(I_FCY-1)
   CUR_FCYCPY=[M:MHC]FCYCPY(I_FCY-1)
   nolign+=1
   [M:MHC]CPY(nolign-1)=CUR_FCYCPY
  Endif
 Next I_FCY
 [M:MHC]NBCPY=nolign

 #> Désactivation par défaut de la coche Etat

 Grizo [M:MHC]FLGETA

 #> réaffichage du masque en-tête

 Affzo [M:MHC]

Return

#========================================================================
$DEF_GLO_MAS

 #-> Options techniques de l'action massive

  Global Integer FLGTRC                    # Flag d'activation de trace
  Global Integer FLGREP                    # Flag d'activation du contrôle mise à jour
  Global Integer FLGSIM                    # Flag de traitement simulé ou réél
  Global Integer FLGETA                    # Flag de lancement d'états Crystal associés à l'action massive
  Global Integer FLGDET                    # Flag de trace détaillée

 #-> Globales pour la gestion de la trace

  Global Integer TRLVL                     # Niveau de trace
  Global Integer TRTYP                     # Numéro de message à emettre
  Global Integer TRPARM                    # Nombre de caractère sur ligne de séparation ou code erreur si erreur

 #-> Globales techniques

  Global Integer ABANDON_TRT               # Flag alimenté à 1 quand on clique sur le bouton FIN

 #-> Globales de gestion de l'en-tête

  Global Integer G_NOCHOI_SELALL   : G_NOCHOI_SELALL  = G_NON   # Si aucune cpy ou fcy cochée on sélectionne tout ?
  Global Integer G_NOCHOI_CONTSOC  : G_NOCHOI_CONTSOC = G_OUI   # Si aucune cpy cochée, on peut sortir du tableau ?
  Global Integer G_CPYTAB_DISABLE  : G_CPYTAB_DISABLE = G_NON   # Tableau des sites accessible en saisie ?
  Global Integer G_FCYTAB_DISABLE  : G_FCYTAB_DISABLE = G_NON   # Tableau des sites accessible en saisie ?
  Global Integer G_NBR_SELCPY      :                            # Nombre de sociétés sélectionnées
  Global Integer G_MESS_ERREUR     :
  Global Integer G_CTRL_CPY        : G_CTRL_CPY = G_NON         # Contrôle de l'habilitation pour tous les sites de la société ?
  Global Integer G_MESS_FCY(2)     : Raz G_MESS_FCY             # Message + chapitre en cas d'exclusion de toutes les sociétés pour raison fonctionnelle

  ACTMET="SET_GLO_MAS" : Gosub ACTMET From TRCPROCOM            # Ouverture de tables annexes

Return

#========================================================================
$KILL_GLO_MAS
 If dim(FLGTRC)>0           : Kill FLGTRC            : Endif
 If dim(FLGREP)>0           : Kill FLGREP            : Endif
 If dim(FLGSIM)>0           : Kill FLGSIM            : Endif
 If dim(FLGETA)>0           : Kill FLGETA            : Endif
 If dim(FLGDET)>0           : Kill FLGDET            : Endif
 If dim(TRLVL)>0            : Kill TRLVL             : Endif
 If dim(TRTYP)>0            : Kill TRTYP             : Endif
 If dim(TRPARM)>0           : Kill TRPARM            : Endif
 If dim(ABANDON_TRT)>0      : Kill ABANDON_TRT       : Endif
 If dim(G_NOCHOI_SELALL)>0  : Kill G_NOCHOI_SELALL   : Endif
 If dim(G_NOCHOI_CONTSOC)>0 : Kill G_NOCHOI_CONTSOC  : Endif
 If dim(G_CPYTAB_DISABLE)>0 : Kill G_CPYTAB_DISABLE  : Endif
 If dim(G_FCYTAB_DISABLE)>0 : Kill G_FCYTAB_DISABLE  : Endif
 If dim(G_NBR_SELCPY)>0     : Kill G_NBR_SELCPY      : Endif
 If dim(G_CTRL_CPY)>0       : Kill G_CTRL_CPY        : Endif
 If dim(GACTMSKLIS)         : Kill GACTMSKLIS        : Endif
 If dim(GINITDIA)<0         : Kill GINITDIA          : Endif
Return

#========================================================================
$MODIF_ASELOBJ
 # Bug 25078
 # On cherche si la zone modifiée se trouve dans la liste des champs servant de critère pour ASELOBJ
 # Si c'est le cas et que la nouvelle valeur est différente de "", on appelle l'action CHGACTCRIT
 #

 Local Integer NB_ZON_ASL : NB_ZON_ASL = 20
 Local Char    LIS_ZON_ASL(15)(0..NB_ZON_ASL) : Raz LIS_ZON_ASL
 Local Integer I_ZON_ASL

 LIS_ZON_ASL(0)  = "TBL1"
 LIS_ZON_ASL(1)  = "FLD1"
 LIS_ZON_ASL(2)  = "OPE1"
 LIS_ZON_ASL(3)  = "VAL1"

 LIS_ZON_ASL(4)  = "TBL2"
 LIS_ZON_ASL(5)  = "FLD2"
 LIS_ZON_ASL(6)  = "OPE2"
 LIS_ZON_ASL(7)  = "VAL2"

 LIS_ZON_ASL(8)  = "TBL3"
 LIS_ZON_ASL(9)  = "FLD3"
 LIS_ZON_ASL(10) = "OPE3"
 LIS_ZON_ASL(11) = "VAL3"

 LIS_ZON_ASL(12) = "TBL4"
 LIS_ZON_ASL(13) = "FLD4"
 LIS_ZON_ASL(14) = "OPE4"
 LIS_ZON_ASL(15) = "VAL4"

 LIS_ZON_ASL(16) = "TBL5"
 LIS_ZON_ASL(17) = "FLD5"
 LIS_ZON_ASL(18) = "OPE5"
 LIS_ZON_ASL(19) = "VAL5"

 LIS_ZON_ASL(20) = "EXP1"

 I_ZON_ASL=find(COUZON,LIS_ZON_ASL)
#If I_ZON_ASL & CZ<>""
 If I_ZON_ASL # Gbn 12102004-si on blanchit la zone c'est aussi une modification de critère
  Call ACTCHGCRIT() From TRCPROCOM
 Endif

Return

#========================================================================
$NETTOYER

 Local Integer NBDLREC,ERR
 Local Char    MES

 If FLGREP=G_OUI
  Call VIDER(NUMACT,TMPTAB,NBDLREC,ERR) From TRCPROCOM         #=> Nettoyage la table temporaire principale
  If GUSER=USRDBG : Infbox "NBR enr supprimés dans TMPMASFAS :"-num$(NBDLREC) : Endif
  If ACTGESPLN=G_OUI
   Call VIDER(NUMACT,TMPTABPLN,NBDLREC,ERR) From TRCPROCOM     #=> Nettoyage de la table temporaire par plan
   If GUSER=USRDBG : Infbox "NBR enr supprimés dans TMPPLNFAS :"-num$(NBDLREC) : Endif
  Endif
 Endif

 Local Integer LUNLOCKER : LUNLOCKER=G_OUI
 GPOINT = "ACTMETUNLOCK" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE
 If LUNLOCKER=G_OUI
  Call UNLOCKER(NUMACT,MES,ERR) From TRCPROCOM                 #=> Suppression des locks posés pendant l'action
 Endif

 If dim(LIST_FCY)>0 : Kill LIST_FCY : Endif

Return

#========================================================================
$LOCKER_POPULATION

 #-> Détermination du numéro de traitement

 Gosub SET_TRTNUM From TRCPROCOM

 #-> Locke de la population
 Call LOCKER(CRITSUPR,CRITOBJ,CRITACT,CRITSUP1,TABOBJ,MES,ERR) From TRCPROCOM

 If ACTSILENCE=G_OUI
  Local  Integer NB_MAX_ERR : NB_MAX_ERR=10
  If dim(I_OBJ)>0      : Kill I_OBJ      : Endif
  If dim(G_MAJOK)>0    : Kill G_MAJOK    : Endif
  If dim(G_LIS_ERR)>0  : Kill G_LIS_ERR  : Endif
  Global Integer I_OBJ   : I_OBJ=0
  Global Integer G_MAJOK : G_MAJOK=G_OUI
  Global Char    GT_LIS_ERR(100)(NB_MAX_ERR)
  If NBOBJLCK<>0

   # CBO 20120215 FQ80130 : ajout de  + 20 pour les EPH et cpsts)
   If dim(GT_OBJ_REF)>0 : Kill GT_OBJ_REF : Endif
   If dim(GT_OBJ_DES)>0 : Kill GT_OBJ_DES : Endif
   Global Char    GT_OBJ_REF( 20)(NBOBJLCK + 20)
   Global Char    GT_OBJ_DES(100)(NBOBJLCK + 20)
  Endif
 Endif

 If ERR=0
  ACTSTATUS=STA_LOCK                                                             # Pas d'erreur, on fait progresser le status de l'action
 Else
  If ERR=5
   If dim(CONTROLER)>0
    Infbox mess(467,GML_MSGFAS,1)
    Kill CONTROLER
   Else
    #Gbn-010605-Bug n°30529-On remplace le message par la  globale GMSGNOOBJLCK.
    If ACTSILENCE<>G_OUI : Call ECR_TRACE("",GTRC_STAT,GMSGNOOBJLCK,0,1) From TRACEABX3 : Endif
   Endif
   # FQ83184 "Aucun bien sélectionné"
   If ACTSILENCE =G_OUI : G_MAJOK=G_NON : GT_LIS_ERR(0)=mess(118,GML_MSGTRC,1) : Endif
  Else
   If MES<>""
    If GTRACE<>""
     # FQ83184 "Erreur n°"-num$(ERR)-"dans le s/p LOCKER"+"\"+MES
     If ACTSILENCE<>G_OUI : Call ECR_TRACE("",GTRC_STAT,mess(114,GML_MSGTRC,1)-num$(ERR)-mess(115,GML_MSGTRC,1)+"\"+MES,1,1) From TRACEABX3 : Endif
     If ACTSILENCE =G_OUI : G_MAJOK=G_NON : GT_LIS_ERR(0)=MES : Endif
    Else
     # FQ83184 "Erreur n°"-num$(ERR)-"dans le s/p LOCKER"+"\"+MES
     If ACTSILENCE<>G_OUI : Call ERREUR(mess(114,GML_MSGTRC,1)-num$(ERR)-mess(115,GML_MSGTRC,1)+"\"+MES) From GESECRAN : Endif    # Erreur, on affiche à l'écran et on nettoie tout
    Endif
    Endif
   Gosub NETTOYER
  Endif
 Endif

 If GUSER=USRDBG : Infbox "ACTSTATUS"-num$(ACTSTATUS) : Endif # Tst

Return

#========================================================================
$CHARGER_POPULATION

 Call CHARGER(CRITSUPR,CRITOBJ,CRITACT,CRITSUP1,TABOBJ,MES,ERR) From TRCPROCOM
 If ERR=0
  ACTSTATUS=STA_TEMP
 Else
  # FQ83184 "Erreur n°"-num$(ERR)-"dans le s/p CHARGER"+"\"+MES
  Call ERREUR(mess(114,GML_MSGTRC,1)-num$(ERR)-mess(116,GML_MSGTRC,1)+"\"+MES) From GESECRAN # Erreur
  Gosub NETTOYER
  ACTSTATUS=STA_DEBUT
 Endif

Return

#========================================================================
$APPLIQUER_MODIF

 Call APPLIQUE_TEMP(NUMACT,TMPTAB,TMPTABPLN,MES,ERR) From TRCPROCOM
 If ERR=0
  ACTSTATUS=STA_MODIF
 Else
  # FQ83184 "Erreur n°"-num$(ERR)-"dans le s/p APPLIQUE_TEMP"+"\"+MES
  Call ERREUR(mess(114,GML_MSGTRC,1)-num$(ERR)-mess(117,GML_MSGTRC,1)-"\"+MES) From GESECRAN # Erreur
  Gosub NETTOYER
  ACTSTATUS=STA_DEBUT
 Endif

Return

#========================================================================
$CONTROLER
Local Integer OUVRBOIT : OUVRBOIT=G_NON
 GOK=1 : # FQ48623
 # Ré-initialisation du NBTMP (alimenté dans les MAS1_ALIM_TMP1 des différentes traitements) pour permettre affichage
 # correct si on clique deux fois consécutivement sur le bouton Contrôler
 NBTMP=0
 Gosub SET_TRTNUM From TRCPROCOM

 If GUSER=USRDBG : Infbox "Sélectionner" : Endif              # tst

  If ACTSTATUS<=STA_DEBUT
   Gosub SET_CRITERE                                          #=> Construction des critères de sélection
   If !GSERVEUR & ACTTYPGES=GTAMMAS : Call TEMPON('R') From GESECRAN : Endif #Gbn-270405-Ajout d'une boîte pour patienter
   Gosub LOCKER_POPULATION                                    #=> Lock des éléments de la population
   If !GSERVEUR & ACTTYPGES=GTAMMAS : Call TEMPOFF() From GESECRAN   : Endif #Gbn-270405-Fermeture de la boîte pour patienter
  Endif

 If GUSER=USRDBG :  Infbox "Charger"     : Endif              # tst

  If ACTSTATUS>=STA_LOCK & ACTSTATUS < STA_TEMP
   Gosub SET_CRITERE
   If !GSERVEUR & ACTTYPGES=GTAMMAS & ACTSILENCE<>G_OUI : OUVRBOIT=G_OUI : Call OUVRE_BOITE("Action massive",NBOBJLCK) From GESECRAN            : Endif  #Gbn-270405-Ajout d'une boîte pour patienter
   If !GSERVEUR & ACTTYPGES=GTAMMAS & ACTSILENCE<>G_OUI : Call SET_BOITE("Chargement de la population",NBOBJLCK) From GESECRAN : Endif  #Gbn-270405-Ajout d'une boîte pour patienter
   Gosub CHARGER_POPULATION                                   #=> Chargement de la population dans les tables temporaires
  Endif

 If GUSER=USRDBG :  Infbox "Appliquer"   : Endif              # tst

  If ACTSTATUS>=STA_TEMP
   Gosub SET_CRITERE
   # Après CHARGER_POPULATION, NBTMP peut être différent de NBOBJLCK : par exemple, dans le cadre des biens, on charge
   # les biens composants en plus des biens initiaux (sélectionnés dans NBOBJLCK). Il faut donc ré-initialiser NBOBJLCK
   # sinon, la jauge est fausse (>100%)
   # Par ailleurs, NBTMP peut être nul si on clique deux fois sur le bouton Contrôler sans changement de critère
   If OUVRBOIT=G_NON or (NBTMP<>NBOBJLCK and NBTMP<>0) Then
     If NBTMP<>0 Then NBOBJLCK = NBTMP Endif
     # OUVRE_BOITE permet de réafficher la boîte de jauge si on clique deux fois sur Contrôler.
     # FQ83184 "Action massive"
     If !GSERVEUR & ACTTYPGES=GTAMMAS & ACTSILENCE<>G_OUI : Call OUVRE_BOITE(mess(119,GML_MSGTRC,1),NBOBJLCK) From GESECRAN            : Endif  #Gbn-270405-Ajout d'une boîte pour patienter
   Endif
   # FQ83184 "Application des paramètres"
   If !GSERVEUR & ACTTYPGES=GTAMMAS & ACTSILENCE<>G_OUI : Call SET_BOITE(mess(111,GML_MSGTRC,1),NBOBJLCK) From GESECRAN : Endif
   Gosub APPLIQUER_MODIF                                      #=> Application des paramètres de l'action
  Endif

 If GUSER=USRDBG :  Infbox "Ajuster"     : Endif              # tst

  If !GSERVEUR & ACTTYPGES=GTAMMAS  & ACTSILENCE<>G_OUI : Call FERME_BOITE() From GESECRAN : Endif

  If ACTSTATUS>=STA_MODIF
   Call VISUALISER() From TRCPROCOM                           #=> OUVERTURE de l'objet de reprise
  Endif

Return

#========================================================================
$REPORTER_TABLE
 Call REPORTER(NUMACT,TABOBJ,MES,ERR) From TRCPROCOM
Return

#========================================================================
$MAJ_DIRECTE
 # FQ83184 "Action massive"
 If !GSERVEUR & dim(ACTSILENCE)<0 : Call OUVRE_BOITE(mess(119,GML_MSGTRC,1),NBOBJLCK) From GESECRAN  : Endif  #Gbn-270405-Ajout d'une boîte pour patienter
 # FQ83184 "Traitement de la population"
 If !GSERVEUR & dim(ACTSILENCE)<0 : Call SET_BOITE(mess(120,GML_MSGTRC,1),NBOBJLCK) From GESECRAN : Endif  #Gbn-270405-Ajout d'une boîte pour patienter

 Call APPLIQUE_DIRT(CRITSUPR,CRITOBJ,CRITACT,CRITSUP1,TABOBJ,MES,ERR) From TRCPROCOM
 If ERR=0
 Else
  If GUSER="GBO" : Call ECR_TRACE("Erreur dans le s/p APPLIQUE_DIRT"-num$(ERR),0) From GESECRAN : Endif
 Endif

 If !GSERVEUR & dim(ACTSILENCE)<0 : Call FERME_BOITE() From GESECRAN : Endif #Gbn-270405-Fermeture de la boîte pour patienter


Return

#========================================================================
$SET_CRITERE

 Raz CRITSUPR, CRITOBJ

 # Pour l'instant, on sÃ©lectionne sur les sites. Voir si on peut optimiser en sÃ©lectionnant sur sociÃ©tÃ© lorsque
 # tous les sites d'une sociÃ©tÃ© sont sÃ©lectionnÃ©s.

 Local Integer NBR_FCY, I_FCY
 Raz NBR_FCY

 # On commence par compter le nombre de sites sÃ©lectionnÃ©s

 For I_FCY=1 To [M:MHC]NBFCY
  If [M:MHC]FLGFCY(I_FCY-1)=G_OUI : NBR_FCY+=1 : Endif
 Next I_FCY

 # En fonction du nombre de sites sÃ©lectionnÃ©s et de la globale G_NOCHOI_SELALL

 If NBR_FCY # Un ou plusieurs sites sont sÃ©lectionnÃ©s
  # DÃ©claration de la variable destinÃ©e Ã  recevoir les sites Ã  sÃ©lectionner
  If dim(LIST_FCY)>0 : Kill LIST_FCY : Endif
  #***FQ 33893Local Char    LIST_FCY(5)(0..NBR_FCY)
  #Gbn-230207-Fq 38563-Une occurrence de trop dans LIST_FCY => Sélection à tort de bien qui auraient le site vide !??
  Global Char    LIST_FCY(GLONFCY)(0..NBR_FCY-1)
  # Remplissage de la variable contenant les sites Ã  sÃ©lectionner
  Local Integer I_LIST_FCY
  Raz I_LIST_FCY
  For I_FCY=1 To [M:MHC]NBFCY
   #If [M:MHC]FLGFCY(I_FCY-1)=G_OUI : # FQ70465
   If (!GSERVEUR and [M:MHC]FLGFCY(I_FCY-1)=G_OUI)
&  or (GSERVEUR  and [M:MHC]FLGFCY(I_FCY-1)=G_OUI and func GLOBIENS.IS_DESYNC_CNX([M:MHC]FCYCPY(I_FCY-1), 0)<>G_OUI)
    I_LIST_FCY+=1
    LIST_FCY(I_LIST_FCY-1)=[M:MHC]FCY(I_FCY-1)
   Endif
  Next I_FCY
#/////////////////////////////////:
#Gbn-FQ 33893
# Si le nombre de site dépasse GSZ_PAQ, on tronçonne le tableau de sites en n tableaux nécessaire
# de taille GSZ_PAQ. Le traitement traite les tableaux de sites les uns après les autres.
Local Integer LNGFCYCOD : LNGFCYCOD=GLONFCY
Local Decimal LRESTE

# Déclaration de la variable destinataire  recevoir le nombre de liste de sites à créer
If dim(GNB_CRITFCY)>0 : Kill GNB_CRITFCY: Endif
If dim(LIST_FCY_X)>0 : Kill LIST_FCY_X : Endif

If dim(LIST_FCY)>GSZ_PAQ
  Global Integer GNB_CRITFCY
  Local Integer SZ_LST_TAB
  Local Integer I, J
  Local Integer I_DEP
  Local Char    NOMZON

   LRESTE = mod(dim(LIST_FCY), GSZ_PAQ)

   If LRESTE
     GNB_CRITFCY = int(dim(LIST_FCY)/GSZ_PAQ)
   Else
     GNB_CRITFCY = int((dim(LIST_FCY)-GSZ_PAQ)/GSZ_PAQ)
   Endif

  SZ_LST_TAB = dim(LIST_FCY)-(GNB_CRITFCY*GSZ_PAQ)

  If GNB_CRITFCY>0
    If dim(LIST_FCY_1)>0 : Kill LIST_FCY_1 : Endif
    If dim(LIST_FCY_2)>0 : Kill LIST_FCY_2 : Endif
    If dim(LIST_FCY_3)>0 : Kill LIST_FCY_3 : Endif
    If dim(LIST_FCY_4)>0 : Kill LIST_FCY_4 : Endif

    For I=1 To GNB_CRITFCY
       Case I
        When 1 : Global Char LIST_FCY_1(LNGFCYCOD)(0..GSZ_PAQ-1)
        When 2 : Global Char LIST_FCY_2(LNGFCYCOD)(0..GSZ_PAQ-1)
        When 3 : Global Char LIST_FCY_3(LNGFCYCOD)(0..GSZ_PAQ-1)
        When 4 : Global Char LIST_FCY_4(LNGFCYCOD)(0..GSZ_PAQ-1)
       Endcase
    Next I
  Endif

   If GNB_CRITFCY>0
        For I=1 To GNB_CRITFCY
           For J=1 To GSZ_PAQ
              NOMZON = "LIST_FCY_"+num$(I)+"("+num$(J-1)+")"
              Assign NOMZON With LIST_FCY(((I-1)*GSZ_PAQ)+(J-1))
           Next J
        Next I
   Endif

  Global Char LIST_FCY_X(LNGFCYCOD)(0..SZ_LST_TAB-1)

  If  GNB_CRITFCY>0
    I_DEP=GNB_CRITFCY*GSZ_PAQ+1
  Else
    I_DEP=1
  Endif

  For I=I_DEP To dim(LIST_FCY)
   NOMZON="LIST_FCY_X("+num$(I-I_DEP)+")"
   Assign NOMZON With LIST_FCY(I-1)
  Next I
  CRITSUPR = ""
Else
  # FQ66106 : utilisation de la synthaxe optimisé du find() dans la mesure où la contrainte d'avoir une liste limitée à environ 60 sites
  #           est gérée ci-dessus
  #CRITSUPR ='Find(FCY,LIST_FCY)'
  CRITSUPR ='Find(FCY,LIST_FCY)<>0'
Endif

#Gbn-Mdj-FQ 33893
#/////////////////////////////////:
Else # Aucun site n'est sélectionné ...

  #Gbn-260405-Bug n°29958-Modif du critère si G_NOCHOI_SELALL=G_OUI
  # If G_NOCHOI_SELALL=G_OUI # ... signifie qu'on sélectionne tous les sites
  #   # Déclaration de la variable destinée à recevoir les sites à sélectionner
  #   If dim(LIST_FCY)>0 : Kill LIST_FCY : Endif
  #   Global Char    LIST_FCY(5)(0..[M:MHC]NBFCY-1)
  #   # Remplissage de la variable contenant les sites à sélectionner
  #   Local Integer I_LIST_FCY
  #   For I_LIST_FCY=1 To [M:MHC]NBFCY
  #    LIST_FCY(I_LIST_FCY-1)=[M:MHC]FCY(I_LIST_FCY-1)
  #   Next I_FCY
  #   CRITSUPR="Find(FCY,LIST_FCY)<>0"
  #  Endif
    If G_NOCHOI_SELALL=G_OUI
     CRITSUPR="1=1"
    Endif
  #Gbn-Bug n°29958-Fin

 Endif

 #Gbn-070405-Bug n° FQ29415- On ne sélectionne pas les biens dont le type de détention est "annulé"
 #FQ33811                    ni les biens "inactifs"
 Case ACTREFOBJ
  When "FAS"
   CRITOBJ="[F:MAS1]OWNTYP<>GVML_TDANNUL & [F:MAS1]ENAFAS<>G_NON"
   # FQ102807
   # un bien sorti dans l'exercice précédent n'est elligible à aucune action.
   CRITOBJ -= "& [F:MAS1]ISSFIYPRE <> G_OUI"
  When "PHY"           #on ne selectionne pas les éléments physiques inactifs.
     # CRITOBJ="[F:MAS1]ENAPHY<>G_NON"
  When Default
   CRITOBJ="1=1"
 Endcase

 #=> Construction critère supplémentaire (onglet ASELOBJ)
Raz CRITSUP1

# FQ84645 : dans le cas où une expression de lien est renseignée dans le paramétrage
#           du contexte de l'objet, ASELOBJ prefixe les noms de champ par
#           l'abréviation de la classe [F] contenu dans [M]ABR.
#           [M]NBTBL à 0 permet de ne pas prefixer le champ par la classe
[M]NBTBL=0
Gosub EXPRESSION From ASELOBJ

If EXPRESSION<>""
 CRITSUP1=EXPRESSION
Endif

If GUSER="XXX" : Gosub AFF_LIST_FCY From TRCPROCOM : Endif

Return

#========================================================================
$ABANDON_TRT

 # Abandon du traitement quand :
 # ===========================
 #
 #  Contrôle des modifications :
 #  --------------------------
 #   Si le s/p reporter s'est mal passé (ERR<>0)
 #
 #  Mise à jour directe :
 #  -------------------
 #   Si le s/p Locker ou le s/p applique_dirt se sont mal déroulés
 #
 # Qu'est-ce qu'on y fait ?
 # ======================
 #
 #  si ACTSTATUS>=STA_LOCK on unlock ce qui a été locké
 #  On emet un message dans la trace

Return

##########################################################################
## Gestion des masques en-tête des actions massives [MHC] Modèle V1 d'en-tête
##########################################################################

#CHECK UNUSED_BEGIN

#------------------------------------------------------------------------#
# Action champs options du traitement                                    #
#------------------------------------------------------------------------#

Subprog D_FLGREP(VALEUR)
Variable Integer VALEUR
 If GSERVEUR
  [M:MHC]FLGREP=1
  Grizo [M:MHC]FLGREP
 Endif
End

#------------------------------------------------------------------------#
# Action champs critères communs tous objets toutes actions              #
#------------------------------------------------------------------------#

Subprog AM_FLGREP(VALEUR)
Variable Integer VALEUR
 FLGREP=VALEUR
End

Subprog AM_USRDEB(VALEUR)
Variable Char    VALEUR()
 If VALEUR<>""
  Actzo [M:MHC]USRFIN
 Else
  Effzo [M:MHC]USRFIN
  Grizo [M:MHC]USRFIN
 Endif
End

Subprog AV_USRFIN(VALEUR)
Variable Char    VALEUR()
 Effzo [M:MHC]USRFIN
 VALEUR=[M:MHC]USRDEB
End

Subprog C_USRFIN(VALEUR)
Variable Char    VALEUR()
 Call CONT_BORNE("USR","MHC",VALEUR,2)
End

Subprog AM_CPYDEB(VALEUR)
Variable Char    VALEUR()
Local Integer SREMAFCY
 If ACTMONCPY=G_NON
  If VALEUR<>""
   Actzo [M:MHC]CPYFIN
  Else
   Effzo [M:MHC]CPYFIN
   Grizo [M:MHC]CPYFIN
  Endif
 Elsif ACTMONCPY=G_OUI
  Effzo [M:MHC]CPYFIN
  Grizo [M:MHC]CPYFIN
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  Filter [FCY] Where LEGCPY=VALEUR
  Read [FCY] First
  If !fstat
   Local Char RCPY
   SREMAFCY=GREMAFCY : GREMAFCY=G_OUI : Raz [M:FPC] : Call ACTION_FCY ([F:FCY]FCY,RCPY) From GLOFCYCPY : GREMAFCY=SREMAFCY
  Endif
  Filter [FCY]
 Endif
End

Subprog C_CPYDEB(VALEUR)
Variable Char    VALEUR()
 If ACTMONCPY=G_OUI & VALEUR=""
  GERREUR=1
  GMESSAGE=  mess(10,123,1)      # "Zone obligatoire"
  mkstat=2
 Endif
End

Subprog AV_CPYFIN(VALEUR)
Variable Char    VALEUR()
 If ACTMONCPY=G_NON
  VALEUR=[M:MHC]CPYDEB
 Else
  Effzo [M:MHC]CPYFIN
 Endif
End

Subprog C_CPYFIN(VALEUR)
Variable Char    VALEUR()
 Call CONT_BORNE("CPY","MHC",VALEUR,2)
End

Subprog AM_FCYDEB(VALEUR)
Variable Char    VALEUR()
 If VALEUR<>""
  Actzo [M:MHC]FCYFIN
 Else
  Effzo [M:MHC]FCYFIN
  Grizo [M:MHC]FCYFIN
 Endif
End

Subprog AV_FCYFIN(VALEUR)
Variable Char    VALEUR()
 If VALEUR=""
  VALEUR=[M:MHC]FCYDEB
 Endif
End

Subprog C_FCYFIN(VALEUR)
Variable Char    VALEUR()
 Call CONT_BORNE("FCY","MHC",VALEUR,2)
End

