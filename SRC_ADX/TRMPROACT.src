#--> Pour les zones LINLOF

# Si CODLOFDEB uniquement -> Sélection des lignes de la dépenses dans CODLOFDEB
# Si DEB et FIN -----------> Sélection de 1 à n (n nombre de lignes max de FIN)

#------------------------------------------------------------------------#
# Action champs critères Particuliers à chaque action massive            #
#                                                                        #
# Il y a un masque par objet MCFASCRI, MCLOFCRI et MCLEACRI. Pour une    #
# action massive associée à l'un de ces objets il est possible de créer  #
# un nouveau masque MC+Nom action+CRI d'abréviation MHC dans lequel on   #
# ajoutera un nouveau bloc comportant de nouvelles zones de sélection    #
# Les actions champs sont à écrire sous ce commentaire.                  #
#------------------------------------------------------------------------#

#CHECK UNUSED_END

##########################################################################
## Gestion des masques en-tête des actions massives [MHC] Modèle d'en-tête V2
##########################################################################

#=> Avant zone de la variable de bas de tableau du tableau des sites

Subprog AV_NBCPY
 If G_CPYTAB_DISABLE=G_OUI
  Grizo [M:MHC]10
 Endif
End

#=> Avant saisie de la variable de bas de tableau du tableau des sociétés
#   Supprime les boutons Toutes sociétés et aucune

Subprog AS_NBCPY
 If ACTMONCPY=G_OUI
  GBOUT1=""
  GBOUT2=""
 Endif

 ACTMET="AS_NBCPY" : Gosub ACTMET From TRCPROCOM                          # Point d'entrée pour les trt
End

#=> Avant zone de la variable de bas de tableau du tableau des sites

Subprog AV_NBFCY
 If G_FCYTAB_DISABLE=G_OUI
  Grizo [M:MHC]15
 Endif
End

#=> Avant saisie de la variable de bas de tableau du tableau des sites
#   Supprime les boutons Tous sites et aucun

Subprog AS_NBFCY
 If ACTMONCPY=G_OUI
  GBOUT1=""
  GBOUT2=""
 Endif
End

#=> Après zone de la variable de bas de tableau du tableau des sociétés

Subprog AP_NBCPY

 If (ACTMONCPY=G_OUI & G_NOCHOI_CONTSOC=G_OUI)
&  |(ACTMONCPY=G_NON & G_NOCHOI_CONTSOC=G_OUI)

  #Infbox "Dans AP_NBCPY"-num$(status)
  # Action mono-société
  #If status=21 | status=20
  # Gbn - 30/07/04 : On fait le contrôle "Au moins une société saisie" en sortie de tableau
  #                  et sur clique d'un des boutons de la fenêtre.

  If status=1 | status=20 | status=1101 | status=1029
   # On essaie de sortir du tableau
   Local Integer I_CPY, SELCPY
   Raz SELCPY
   #If GUSER="GBO" : Infbox "nolign"-num$(nolign) : Endif
   For  I_CPY=1 To [M:MHC]NBCPY
    If [M:MHC]FLGCPY(I_CPY-1)=G_OUI : SELCPY=1 : Endif
   Next I_CPY
   If !SELCPY
    Call ERREUR (mess(18,GML_MSGACT,1)) From GESECRAN : # FQ80772
    mkstat=2
   Endif
  Endif

  # MHB : point d'entrée pour raz le site financier, sit géo et loc dans le transfert des éléments physiques
  ACTMET="AP_NBCPY" : Gosub ACTMET From TRCPROCOM
 Endif

End

#=> Après modif du flag CPY

Subprog AM_FLGCPY(VALEUR)
Variable Integer VALEUR

 Local Integer I_FCY, I_CPY, SREMAFCY

# Répercussions d'un changement d'état d'une société sur ses sites
 If VALEUR    = G_OUI
  # On sélectionne la société
  If ACTMONCPY = G_OUI
   # Si l'action est mono-société, on cherche si une société a déjà été cochée
   For I_CPY=1 To [M:MHC]NBCPY
    If !(I_CPY=nolign)
     # Si on en trouve une, on demande à l'utilisateur de confirmer son choix
     If [M:MHC]FLGCPY(I_CPY-1)=G_OUI
      Local Integer ROK
#     Call AVERTIR("Voulez-vous désélectionner la société "-[M:MHC]CPY(I_CPY-1),ROK) From GESECRAN
      # FQ83184 "Voulez-vous désélectionner la société "
      Call OUINON(mess(121,GML_MSGTRC,1)-[M:MHC]CPY(I_CPY-1),ROK) From GESECRAN
      Case ROK
       When G_NON
        mkstat=2
        End
       When Default
        # Si le choix est confirmé, on désélectionne la société déjà sélectionnée ainsi que tous ses sites
        For I_FCY=1 To [M:MHC]NBFCY
         If [M:MHC]FCYCPY(I_FCY-1)=[M:MHC]CPY(I_CPY-1) & [M:MHC]FLGFCY(I_FCY-1)=G_OUI
          [M:MHC]FLGFCY(I_FCY-1)=G_NON
         Endif
        Next I_FCY
        [M:MHC]FLGCPY(I_CPY-1)=G_NON : Affzo [M:MHC]FLGCPY(I_CPY-1)
      Endcase
     Endif
    Endif
   Next I_CPY
  Endif
  # On coche tous les sites correspondants à la société qui vient d'être cochée
  For I_FCY=1 To [M:MHC]NBFCY
   If [M:MHC]FCYCPY(I_FCY-1)=[M:MHC]CPY(nolign-1) & [M:MHC]FLGFCY(I_FCY-1)=G_NON
    [M:MHC]FLGFCY(I_FCY-1)=G_OUI
   Endif
  Next I_FCY
  # On charge l'environnement correspondant à la société :
  SREMAFCY=GREMAFCY : GREMAFCY=G_OUI : Call ACTION_CPY ([M:MHC]CPY(nolign-1)) From GLOFCYCPY : GREMAFCY=SREMAFCY
 Elsif VALEUR = G_NON
  # On désélectionne la société
  Raz I_FCY
  For I_FCY=1 To [M:MHC]NBFCY
   If [M:MHC]FCYCPY(I_FCY-1)=[M:MHC]CPY(nolign-1) & [M:MHC]FLGFCY(I_FCY-1)=G_OUI
    [M:MHC]FLGFCY(I_FCY-1)=G_NON
   Endif
  Next I_FCY
 Endif

 Affzo [M:MHC]15

 #Gbn-060405-Bug n°29596-Ajout d'un point d'entrée pour les actions en après modif du champ FLGCPY
 ACTMET="AM_FLGCPY" : Gosub ACTMET From TRCPROCOM                         # Point d'entrée pour les trt

End

#=> Après modif du flag FCY

Subprog AM_FLGFCY(VALEUR)
Variable Integer VALEUR

 Local Integer I_CPY, I_FCY, ROK

 # On coche un site
 If VALEUR= G_OUI
  If ACTMONCPY = G_OUI
   For I_CPY=1 To [M:MHC]NBCPY
    If [M:MHC]CPY(I_CPY-1)<>[M:MHC]FCYCPY(nolign-1) & [M:MHC]FLGCPY(I_CPY-1)=G_OUI
#    Call AVERTIR("Voulez-vous désélectionner les sites de la société "-[M:MHC]CPY(I_CPY-1),ROK) From GESECRAN
     # FQ83184 "Voulez-vous désélectionner les sites de la société "
     Call OUINON(mess(92,GML_MSGTRC,1)-[M:MHC]CPY(I_CPY-1),ROK) From GESECRAN
     Case ROK
      When G_NON
       mkstat=2
       End
      When G_OUI
       For I_FCY=1 To [M:MHC]NBFCY
        If !(nolign=I_FCY)
         If [M:MHC]FCYCPY(I_FCY-1)=[M:MHC]CPY(I_CPY-1) & [M:MHC]FLGFCY(I_FCY-1)=G_OUI
          [M:MHC]FLGFCY(I_FCY-1)=G_NON : Affzo [M:MHC]FLGFCY(I_FCY-1)
         Endif
        Endif
       Next I_FCY
       [M:MHC]FLGCPY(I_CPY-1)=G_NON
     Endcase
    Elsif [M:MHC]CPY(I_CPY-1)=[M:MHC]FCYCPY(nolign-1) & [M:MHC]FLGCPY(I_CPY-1)=G_NON
     [M:MHC]FLGCPY(I_CPY-1)=G_OUI
    Endif
   Next I_CPY
  Else
   For I_CPY=1 To [M:MHC]NBCPY
    If [M:MHC]CPY(I_CPY-1)=[M:MHC]FCYCPY(nolign-1) & [M:MHC]FLGCPY(I_CPY-1)=G_NON
     [M:MHC]FLGCPY(I_CPY-1)=G_OUI
    Endif
   Next I_CPY
  Endif
 Elsif VALEUR=G_NON
  Local Integer FIND_FCY : Raz FIND_FCY
  For I_FCY=1 To [M:MHC]NBFCY
   If !(I_FCY=nolign)
    If [M:MHC]FCYCPY(I_FCY-1)=[M:MHC]FCYCPY(nolign-1) & [M:MHC]FLGFCY(I_FCY-1)=G_OUI
     FIND_FCY=1
    Endif
   Endif
  Next I_FCY
  If !FIND_FCY
   For I_CPY=1 To [M:MHC]NBCPY
    If [M:MHC]FCYCPY(nolign-1)=[M:MHC]CPY(I_CPY-1) & [M:MHC]FLGCPY(I_CPY-1)=G_OUI
     [M:MHC]FLGCPY(I_CPY-1)=G_NON
    Endif
   Next I_CPY
   # Compter le nombre de sociétés :
  Endif
 Endif

 Affzo [M:MHC]10
 If VALEUR= G_NON
   # MHB : point d'entrée pour raz les sites et loc si plus aucune société sélectionnée
   ACTMET="AP_NBCPY" : Gosub ACTMET From TRCPROCOM
 Endif

  # FQ85023 changement ou 1° affectation de société
  If VALEUR = G_OUI and GSOCIETE <> [M:MHC]FCYCPY(nolign-1)
    # On charge l'environnement correspondant à la société :
    SREMAFCY=GREMAFCY
    GREMAFCY=G_OUI
    Call ACTION_CPY ([M:MHC]FCYCPY(nolign-1)) From GLOFCYCPY
    GREMAFCY=SREMAFCY
    ACTMET="AM_FLGCPY"
    Gosub ACTMET From TRCPROCOM
  Endif
End

#=> Après zone de la variable de bas de tableau du tableau des sociétés

Subprog AP_NBFCY
  If (ACTMONCPY=G_OUI & G_NOCHOI_CONTSOC=G_OUI)
&   |(ACTMONCPY=G_NON & G_NOCHOI_CONTSOC=G_OUI) Then

  #Infbox "Dans AP_NBCPY"-num$(status)
  # Action mono-société
  #If status=21 | status=20
  # Gbn - 30/07/04 : On fait le contrôle "Au moins une société saisie" en sortie de tableau
  #                  et sur clique d'un des boutons de la fenêtre.
  #Infbox "status"-num$(status)

    If status=1 | status=20 | status=1101 | status=1029
      # On essaie de sortir du tableau des sites
      Local Integer I_CPY, SELCPY
      Raz SELCPY
      #If GUSER="GBO" : Infbox "nolign"-num$(nolign) : Endif
      For  I_CPY=1 To [M:MHC]NBCPY
        If [M:MHC]FLGCPY(I_CPY-1)=G_OUI : SELCPY=1 : Break : Endif
      Next I_CPY
      If !SELCPY Then
        Call ERREUR (mess(18,GML_MSGACT,1)) From GESECRAN : # FQ80772
        mkstat=2
        End
      Endif
      # MHB : point d'entrée pour initialiser le site financier dans le transfert des éléments physiques
      ACTMET="AP_NBFCY" : Gosub ACTMET From TRCPROCOM
    Endif
  Endif
End


#=> Toutes sociétés

Subprog B1_NBCPY
 If ACTMONCPY=G_NON : Gosub SELTOUT : Endif
End

#=> Tous sites

Subprog B1_NBFCY
 If ACTMONCPY=G_NON : Gosub SELTOUT : Endif
End

#=> Aucune Sélection

Subprog B2_NBCPY
 If ACTMONCPY=G_NON : Gosub SELRIEN : Endif
End

#=> Aucune Sélection

Subprog B2_NBFCY
 If ACTMONCPY=G_NON : Gosub SELRIEN : Endif
End

#=> Tous sélectionner

$SELTOUT
 Local Integer I_CPY, I_FCY
 For I_CPY=1 To [M:MHC]NBCPY
  [M:MHC]FLGCPY(I_CPY-1)=G_OUI
 Next I_CPY
 Affzo [M:MHC]10
 For I_FCY=1 To [M:MHC]NBFCY
  [M:MHC]FLGFCY(I_FCY-1)=G_OUI
 Next I_FCY
 Affzo [M:MHC]15

 ACTMET="SELTOUT" : Gosub ACTMET From TRCPROCOM                          # Point d'entrée pour les trt FQ88667

 # FQ96606
 G_NBR_SELCPY = func TRMPROACT.NBR_SOCSEL(0,0)
 mkstat = 4
Return

#=> Tout déselectionner

$SELRIEN
 Local Integer I_CPY, I_FCY
 For I_CPY=1 To [M:MHC]NBCPY
  [M:MHC]FLGCPY(I_CPY-1)=G_NON
 Next I_CPY
 Affzo [M:MHC]10
 For I_FCY=1 To [M:MHC]NBFCY
  [M:MHC]FLGFCY(I_FCY-1)=G_NON
 Next I_FCY
 Affzo [M:MHC]15

 ACTMET="SELRIEN" : Gosub ACTMET From TRCPROCOM                          # Point d'entrée pour les trt FQ88667

 # FQ96606
 G_NBR_SELCPY = func TRMPROACT.NBR_SOCSEL(0,0)
 mkstat = 4
Return

