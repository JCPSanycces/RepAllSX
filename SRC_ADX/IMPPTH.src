#<AdxTL>@(#)4.0.0.0 $Revision$
###########################################################################
# IMPPTH : Import/Export des réceptions d'achat            MBT 26/12/2003 #
# ----------------------------------------------------------------------- #
# Traitements des actions spécifiques à l'import/export de réceptions     #
# ----------------------------------------------------------------------- #
# L'import classique de réception est prévu ici mais l'import devant      #
#    être utilisé pour un import correct des entrées en stock est         #
#    l'import spécifique contenu dans le traitement IMPPTHS.              #
###########################################################################


$ACTION
Case ACTION
  When "IMP_OUVRE"     : Gosub OUVRE
  When "IMPORT"        : Gosub IMPORT
  When "IMP_ZONE"      : Gosub IMP_ZONE
  When "IMP_TAB"       : Gosub IMP_TAB
  When "IMP_FERME"     : Gosub FERME
  #-----
  When "EXP_OUVRE"     : Gosub EXP_OUVRE  
  When "EXPORT"        : Gosub EXPORT 
  When "EXP_ZONE"      : Gosub EXP_ZONE
Endcase
Return



##########################################################################
#                              IMPORT / EXPORT                           #
##########################################################################


#---------------------------------------------------------------#
# Début import/export, étiquette appelée depuis le traitement : #
#   - IMPPTH ou IMPPTHS si import (G_IMPORT=1)                  #
#   - IMPPTH            si export (G_EXPORT=1)                  #
# ------------------------------------------------------------- #
# Entête *71 à *78  / Pied *81 à *88  / Ligne *91 à *98         #
#     les zones TSTCHAMP  1 à  8 déterminent l'entête           #
#     les zones TSTCHAMP 11 à 18 déterminent le pied            #
#     les zones TSTCHAMP 21 à 28 déterminent le détail          #
#---------------------------------------------------------------#
$OUVRE_TEXTE
#----- Lignes texte entête  -----#
Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
TSTCHAMP(1) ="PTH*71" : TSTCHAMP(2) ="PTH*72" : TSTCHAMP(3) ="PTH*73" : TSTCHAMP(4) ="PTH*74"
TSTCHAMP(5) ="PTH*75" : TSTCHAMP(6) ="PTH*76" : TSTCHAMP(7) ="PTH*77" : TSTCHAMP(8) ="PTH*78"
#----- Lignes texte pied -----#
Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
TSTCHAMP(11)="PTH*81" : TSTCHAMP(12)="PTH*82" : TSTCHAMP(13)="PTH*83" : TSTCHAMP(14)="PTH*84"
TSTCHAMP(15)="PTH*85" : TSTCHAMP(16)="PTH*86" : TSTCHAMP(17)="PTH*87" : TSTCHAMP(18)="PTH*88"
#----- Lignes texte détail -----#
Raz GIMP(91), GIMP(92), GIMP(93), GIMP(94), GIMP(95), GIMP(96), GIMP(97), GIMP(98)
TSTCHAMP(21)="PTD*91" : TSTCHAMP(22)="PTD*92" : TSTCHAMP(23)="PTD*93" : TSTCHAMP(24)="PTD*94"
TSTCHAMP(25)="PTD*95" : TSTCHAMP(26)="PTD*96" : TSTCHAMP(27)="PTD*97" : TSTCHAMP(28)="PTD*98"
#-----
Gosub OUVRE_TEXTE From TRTX3IMP
Return



##########################################################################
#                                  IMPORT                                #
##########################################################################


#-------------------#
# Début de l'import #
#-------------------#
$OUVRE
Local Integer  OKCHAMP
Local Shortint WNOL
#----- Gestion des textes -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_IMPORT=1 : Gosub OUVRE_TEXTE
Return


#-----------------------------------------------------#
# Après lecture d'un enregistrement (entête ou ligne) #
#                                                     #
# IMPFIC : Abréviation du fichier en cours            #
#-----------------------------------------------------#
$IMPORT
Gosub IMPORT_TEXTE
Case IMPFIC
  When "PTH"
    #------------------#
    # Entête réception #
    #------------------#
  When "PTD"
    #-------------------------------------------------------------#
    # Lignes réception : Déterminer si nouvelle ligne (nolign<>0) #
    #-------------------------------------------------------------#
    Raz WNOL
    Gosub IMP_DECLARE From TRTX3IMP
    If GREP="M"
       ICLEPRIM(0)="PTDLIN"
       ICLEPRIM(1)="ITMREF"
       NBASTAB="NBLIG"
       Gosub RECHERCHE_LIGNE From TRTX3IMP
       WNOL=nolign
       #-------------------------------------------------------#
       # Cas de la suppression de ligne (Qté réceptionnée = 0) #
       #-------------------------------------------------------#
       Call TST_CHAMP(IMPFIC,"QTYUOM",OKCHAMP) From SUBIMPOBJ
       If OKCHAMP & [F:PTD]QTYUOM=0 & nolign<>0
          status=65
          Call C_NBLIG     From SUBPTH : If mkstat Return : Endif
          Call AVANT_NBLIG From SUBPTH
          Call APRES_NBLIG From SUBPTH
       Endif
    Endif
Endcase
Return


#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
$IMP_ZONE
If IMPZON="SRGLOCDEF"  : # Dernier champ saisissable de l'entête
  Gosub IMP_ZONE_TEXTE : # Traitement des textes entête et pied
Endif
Return


#-------------------------------------------#
# Equivalent à la saisie d'un champ tableau #
#                                           #
# IMPFIC : Abréviation du fichier           #
# IMPMSK : Nom de l'écran en cours          #
# IMPZON : Nom du champ en cours            #
# IMPMOD : Déclenche l'Après_modif          #
# OK     : Conditionne IMP_ZONE standard    #
#-------------------------------------------#
$IMP_TAB
If IMPZON="LINCAT"       : # Dernier champ saisissable de la ligne
  Gosub IMP_ZONE_TEXTE : # Traitement des textes ligne
Endif
Return


#-----------------#
# Fin de l'import #
#-----------------#
$FERME
Return


#-------------------------------------------------------------------------------#
# Import d'un texte, étiquette appelée depuis les traitements IMPPTH et IMPPTHS #
#-------------------------------------------------------------------------------#
$IMPORT_TEXTE
Raz G_NLDET
Case IMPFIC
  When "PTH" : 
    If G_ENT     : # --- Texte entete ---
       Raz [M:ITC]T_CLE_CLOB(1) 
       Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
    Endif 
    If G_PIE     : # --- Texte pied --- 
       Raz [M:ITC]T_CLE_CLOB(2)
       Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(2)=G_CLE_CLOB
    Endif
  When "PTD"
    If G_DET     : # --- Texte detail ---
       Raz [M:ITC]T_CLE_CLOB(3)
       Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
    Endif
Endcase
Return


#-------------------------------------------------------#
# Chargement de la clé du texte dans la classe [M:PTH0] #
#-------------------------------------------------------#
$IMP_ZONE_TEXTE
Case IMPFIC
  When "PTH"
    If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & GREP="C" : # --- Texte entête ---
      [M:PTH0]TEX1=[M:ITC]T_CLE_CLOB(1)
   Endif
    If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & GREP="C" : # --- Texte pied ---
      [M:PTH0]TEX2=[M:ITC]T_CLE_CLOB(2)
    Endif
  When "PTD"
    If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" & GREP="C" : # --- texte détail ligne ---
      [M:PTH1]LINTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
    Endif 
Endcase
Return



##########################################################################
#                                   EXPORT                               #
##########################################################################


#-----------------------------------------------------------------#
# Début export, étiquette appelée directement depuis le SUBEXPOBJ #
#-----------------------------------------------------------------#
$EXP_OUVRE
#----- Gestion dess textes -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_EXPORT=1 : Gosub OUVRE_TEXTE
#----- Changement pseudo table CPTFOOTLNK par CPTANALIN bis -----#
If clalev([F:CFL])  Close Local File [CFL] : Endif
Local File CPTANALIN [CFL]
#-----
Return


#---------------------------------------------------#
# Après lecture d'un enregistrement (entête, ligne) #
# ------------------------------------------------- #
# EXPFIC : Abréviation du fichier en cours          #
#---------------------------------------------------#
$EXPORT
Case EXPFIC
  When "PTH"
    If G_ENT 
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:PTH]TEX1)>0 & [F:PTH]TEX1<>"" 
          G_CLE_CLOB=[F:PTH]TEX1   : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP 
       Endif
    Endif 
    If G_PIE 
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:PTH]TEX2)>0 & [F:PTH]TEX2<>""
          G_CLE_CLOB=[F:PTH]TEX2   : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP 
       Endif
    Endif 
  When "PTD"
    If [F:PTD]LINTYP>2
       Raz OK
    Elsif G_DET 
       Gosub EXP_RAZ_T3 From TRTX3IMP
       If dim([F:PTD]LINTEX)>0 & [F:PTD]LINTEX<>""
          G_CLE_CLOB=[F:PTD]LINTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP 
       Endif
    Endif 
Endcase
Return


#------------------------------------------#
# Export d'un champ                        #
# ---------------------------------------- #
# EXPFIC : Abréviation du fichier en cours #
#------------------------------------------#
$EXP_ZONE
Return
