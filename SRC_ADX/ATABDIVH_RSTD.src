#<AdxTL>@(#)1.0.0.0 $Revision$
#########################
# Representation ATABDIVH
#########################
###############
# METHODS
###############
$METHODS

Case CURPTH
   When ""
     Case ACTION
       When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
       When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
       When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
       When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
       When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
     Endcase
   When "ADI.ACOLADI"
     Gosub AREAD_AFTER
Endcase
Return

#################### Standard Query Events #########################

$AQUERY_DECODE_CRITERIA_AFTER

Raz NBPRO
NBPRO += 1
TBPRO(NBPRO) = "NUMTAB_REF"
TBTYP(NBPRO) = 2
TBPTH(NBPRO) = "ADI.NUMTAB"
TBFIL(NBPRO) = "[LNK_]NUMTAB"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]NUMTAB"
Return

$AQUERY_OPEN_AFTER
#PQRY.QWHERE -= 'NUMTAB ne ""'
Local File ATABDIV [QRY_ADI]
Local Integer I : I=0
Local Integer TNUMTAB(1..)
For [QRY_ADI]CODE(1)
 I+=1
 TNUMTAB(I) = [F:QRY_ADI]NUMTAB
Next
Local File (Integer NUMTAB) From Variable TNUMTAB As [LNK_]
Return

$AQUERY_TRANS_AFTER
this.ADI.NUMTAB = [LNK_]NUMTAB
Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return

$PROPERTIES
Case CURPRO
  When "ADI.ACOLADI.NUMTAB"     : Gosub NUMTAB
  When Default:
Endcase

Return

$NUMTAB
Call ECR_TRACE("NUMTAB-CURPRO= ["+CURPRO+"]"-"ACTION= ["+ACTION+"]",0) From GESECRAN
Case ACTION
  When "INIT" : #Gosub NUMTAB_PROPAGATE
Endcase
Return

$AREAD_AFTER
#[L]ASTATUS = fmet this.ADI.ASETATTRIBUTE("A1","$isHidden","true")
#[L]ASTATUS = fmet this.APARENT.ACOLADI.ASETATTRIBUTE("A1","$isHidden","true")
Return



$NUMTAB_PROPAGATE
[L]ASTATUS = fmet this.ADI.ACOLADI.ASETATTRIBUTE("A1","$isHidden","true")
Return
