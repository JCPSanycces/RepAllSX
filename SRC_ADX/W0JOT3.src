#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque JOT3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CCV
mkstat = 0
zoncou = "CCV"
indice = 0
WCHAR = [M]CCV
If varmode([M]CCV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CCV" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTHRCCV"
 Call CONTHRCCV([M]CCV,GCURLEG) From SUBHRCCV
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CCV" : GZNUM = 11208 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]CCV
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]CCV = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CCV" : GZNUM = 11208 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]CCV or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_CCV([M]CCV) From SUBJOT
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CCV" : GZNUM = 11208 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varinit([M]DES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DES,"CLASSCONV","DES",[M:JOT3]CCV,GCURLEG) From ATEXTRA
 GACTION = SAVACT
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone FLGSAL
mkstat = 0
zoncou = "FLGSAL"
indice = 0
IMPENT = [M]FLGSAL
If varinit([M]FLGSAL,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGSAL,indice)=0
 [M]FLGSAL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGSAL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGSAL(indice)
 Endif
Endif
[M]FLGSAL = IMPENT

## Zone SALMED
mkstat = 0
zoncou = "SALMED"
indice = 0
If varmode([M]SALMED,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_SALMED([M]SALMED) From SUBJOT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]SALMED : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "SALMED" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone OCPLEV
mkstat = 0
zoncou = "OCPLEV"
indice = 0
IMPENT = [M]OCPLEV
If varinit([M]OCPLEV,indice)=0
 IMPENT = 1
Endif
If varmode([M]OCPLEV,indice)=0
 [M]OCPLEV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OCPLEV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OCPLEV(indice)
 Endif
Endif
[M]OCPLEV = IMPENT

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone SCACPC
mkstat = 0
zoncou = "SCACPC"
indice = 0
If varinit([M]SCACPC,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SCACPC,"11702","SCACPC") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SCACPC,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SCACPC" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]SCACPC,"11702","SCACPC") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SCACPC" : GZNUM = 55065 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]SCACPC,"11702",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "SCACPC" : GZNUM = 55065 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 6
####################################
IMPTBL = 0

## Zone EQUEMPTYP
mkstat = 0
zoncou = "EQUEMPTYP"
indice = 0
IMPENT = [M]EQUEMPTYP
If varinit([M]EQUEMPTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]EQUEMPTYP,indice)=0
 [M]EQUEMPTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EQUEMPTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EQUEMPTYP(indice)
 Endif
Endif
[M]EQUEMPTYP = IMPENT

## Zone STG
mkstat = 0
zoncou = "STG"
indice = 0
IMPENT = [M]STG
If varinit([M]STG,indice)=0
 IMPENT = 1
Endif
If varmode([M]STG,indice)=0
 [M]STG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "STG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]STG(indice)
 Endif
Endif
[M]STG = IMPENT

## Zone PDIFLG
mkstat = 0
zoncou = "PDIFLG"
indice = 0
IMPENT = [M]PDIFLG
WNUM = IMPENT
If varinit([M]PDIFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]PDIFLG,indice)=0
 [M]PDIFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PDIFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PDIFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PDIFLG(IMPENT) From SUBJOT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PDIFLG" : GZNUM = 55067 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PDIFLG = IMPENT

## Zone RCEGRP
mkstat = 0
zoncou = "RCEGRP"
indice = 0
IMPENT = [M]RCEGRP
If varinit([M]RCEGRP,indice)=0
 IMPENT = 1
Endif
If varmode([M]RCEGRP,indice)=0
 [M]RCEGRP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RCEGRP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RCEGRP(indice)
 Endif
Endif
[M]RCEGRP = IMPENT

## Zone SEX
mkstat = 0
zoncou = "SEX"
indice = 0
IMPENT = [M]SEX
If varinit([M]SEX,indice)=0
 IMPENT = 1
Endif
If varmode([M]SEX,indice)=0
 [M]SEX(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SEX" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SEX(indice)
 Endif
Endif
[M]SEX = IMPENT

## Zone PDISTR
mkstat = 0
zoncou = "PDISTR"
indice = 0
If varmode([M]PDISTR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PDISTR([M]PDISTR) From SUBJOT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PDISTR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PDISTR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PDIEND
mkstat = 0
zoncou = "PDIEND"
indice = 0
If varmode([M]PDIEND,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PDIEND([M]PDIEND) From SUBJOT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PDIEND : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PDIEND" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DATDEBFIN"
  Call DATDEBFIN([M]PDIEND,[M]PDISTR) From EXEFNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PDIEND" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone HDCFLG
mkstat = 0
zoncou = "HDCFLG"
indice = 0
IMPENT = [M]HDCFLG
WNUM = IMPENT
If varinit([M]HDCFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]HDCFLG,indice)=0
 [M]HDCFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "HDCFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]HDCFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_HDCFLG(IMPENT) From SUBJOT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "HDCFLG" : GZNUM = 46526 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]HDCFLG = IMPENT

## Zone HDCTYP
mkstat = 0
zoncou = "HDCTYP"
indice = 0
If varinit([M]HDCTYP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]HDCTYP,"11670","HDCTYP") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]HDCTYP,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "HDCTYP" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]HDCTYP,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "HDCTYP" : GZNUM = 55069 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]HDCTYP,"11670","HDCTYP") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "HDCTYP" : GZNUM = 55069 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]HDCTYP,"11670",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "HDCTYP" : GZNUM = 55069 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone HDCSTR
mkstat = 0
zoncou = "HDCSTR"
indice = 0
If varmode([M]HDCSTR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_HDCSTR([M]HDCSTR) From SUBJOT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]HDCSTR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "HDCSTR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone HDCEND
mkstat = 0
zoncou = "HDCEND"
indice = 0
If varmode([M]HDCEND,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_HDCEND([M]HDCEND) From SUBJOT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]HDCEND : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "HDCEND" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DATDEBFIN"
  Call DATDEBFIN([M]HDCEND,[M]HDCSTR) From EXEFNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "HDCEND" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "JOT3"
Return

