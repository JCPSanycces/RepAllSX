#<AdxTL>@(#)0.0.0.0 $Revision$Class XML files
# Supervisor
## CRUD-CLASSE ## EDIXMLFIL
# 2018-11-06 07:05:18 076


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EDIXMLFIL [EXF_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EDIXMLFIL") From ASYRCOM : Endif
Local Instance EDIXMLFIL Using C_EDIXMLFIL

If !SILENCE : Call TRACE("3 --> New Instance C_EDIXMLFIL") From ASYRCOM : Endif
EDIXMLFIL = NewInstance C_EDIXMLFIL AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [EXF_]EXF0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EDIXMLFIL") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.AREAD([EXF_]MSGCOD,[EXF_]MSGREL,[EXF_]MSGFILNOR))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EDIXMLFIL.MSGCOD ="-num$(EDIXMLFIL.MSGCOD)) From ASYRCOM
 Call TRACE("EDIXMLFIL.MSGREL ="-num$(EDIXMLFIL.MSGREL)) From ASYRCOM
 Call TRACE("EDIXMLFIL.MSGFILNOR ="-num$(EDIXMLFIL.MSGFILNOR)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EDIXMLFIL.AKEYS)
  Call TRACE("-"-num$(I)-":"-EDIXMLFIL.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [EXF_]
FreeGroup EDIXMLFIL
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EDIXMLFIL,ACLE,ASTATUS,_ETAG)
Variable Instance EDIXMLFIL Using C_EDIXMLFIL
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _MSGCOD(20)
Local Char _MSGREL(5)
Local Char _MSGFILNOR(20)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_MSGCOD = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_MSGREL = num$([L]CLE(2)) : Endif
If [L]CLE(3)<>"" : [L]_MSGFILNOR = num$([L]CLE(3)) : Endif
Raz [L]_ETAG
Local File EDIXMLFIL [EXF]
Default File [F:EXF]
Read [F:EXF]EXF0 = [L]_MSGCOD;[L]_MSGREL;[L]_MSGFILNOR
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:EXF]UPDTICK)>0
 [L]_ETAG = num$([F:EXF]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EDIXMLFIL,ACLE,ASTATUS)
Variable Instance EDIXMLFIL Using C_EDIXMLFIL
Value Char ACLE
Variable Integer ASTATUS
Local Char _MSGCOD(20)
Local Char _MSGREL(5)
Local Char _MSGFILNOR(20)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_MSGCOD = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_MSGREL = num$([L]CLE(2)) : Endif
If [L]CLE(3)<>"" : [L]_MSGFILNOR = num$([L]CLE(3)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.AREAD([L]_MSGCOD,[L]_MSGREL,[L]_MSGFILNOR))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EDIXMLFIL,_MSGCOD,_MSGREL,_MSGFILNOR,ASTATUS)
Variable Instance EDIXMLFIL Using C_EDIXMLFIL
Value Char _MSGCOD
Value Char _MSGREL
Value Char _MSGFILNOR
Variable Integer ASTATUS

If EDIXMLFIL = null : End : Endif

Gosub AVARIABLES From WMC00EDIXMLFIL
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EDIXMLFIL.APARENT=null
 [L]A_I = EDIXMLFIL.freeSnapshot
 EDIXMLFIL.snapshotEnabled = 0
 EDIXMLFIL.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EDIXMLFIL.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EDIXMLFIL.APARENT=null
 EDIXMLFIL.snapshotEnabled = 1
 EDIXMLFIL.setAccessorEnabled = 1
Endif
LogicClose File [EXF] ,[EXFD] ,[EXSD] ,[EXFF]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL._ACTION_PARAM("AREAD_BEFORE",[L]_MSGCOD,[L]_MSGREL,[L]_MSGFILNOR))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:EXF]
Read [F:EXF]EXF0 = [L]_MSGCOD;[L]_MSGREL;[L]_MSGFILNOR
If fstat
[L]A_ERROR = [L]_MSGCOD+"~"+[L]_MSGREL+"~"+[L]_MSGFILNOR
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EDIXMLFIL,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:EXF]AUUID)>0 & [F:EXF]AUUID=NullUuid
 [F:EXF]AUUID = getUuid
Endif
SetInstance EDIXMLFIL With [F:EXF]
EDIXMLFIL.ASTALIN = [V]CST_ALL

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:EXFD]
 [L]A_N2=0
 For [F:EXFD]EXFD1 Where MSGCOD=[F:EXF]MSGCOD & MSGREL=[F:EXF]MSGREL & MSGFILNOR=[F:EXF]MSGFILNOR
  [L]A_N2 +=1
  EDIXMLFIL.EXFD(A_N2) = NewInstance  C_EDIXMLFILD(EDIXMLFIL.ACTX,NullUuid,[L]A_N2,EDIXMLFIL,"EXFD") AllocGroup EDIXMLFIL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ADDINSTANCE_BOUND)
  If dim([F:EXFD]AUUID)>0 & [F:EXFD]AUUID=NullUuid
   [F:EXFD]AUUID = getUuid
  Endif
  SetInstance EDIXMLFIL.EXFD(A_N2) With [F:EXFD]
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIXMLFIL.EXFD(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ASETATTRIBUTE("MSGCOD","$namProParent","MSGCOD"))
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ASETATTRIBUTE("MSGREL","$namProParent","MSGREL"))
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ASETATTRIBUTE("MSGFILNOR","$namProParent","MSGFILNOR"))
 Next EXFD
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:EXSD]
 [L]A_N2=0
 For [F:EXSD]EXSD1 Where MSGCOD=[F:EXF]MSGCOD & MSGREL=[F:EXF]MSGREL & MSGFILNOR=[F:EXF]MSGFILNOR
  [L]A_N2 +=1
  EDIXMLFIL.EXSD(A_N2) = NewInstance  C_EDIXMLFILXSD(EDIXMLFIL.ACTX,NullUuid,[L]A_N2,EDIXMLFIL,"EXSD") AllocGroup EDIXMLFIL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ADDINSTANCE_BOUND)
  If dim([F:EXSD]AUUID)>0 & [F:EXSD]AUUID=NullUuid
   [F:EXSD]AUUID = getUuid
  Endif
  SetInstance EDIXMLFIL.EXSD(A_N2) With [F:EXSD]
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIXMLFIL.EXSD(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ASETATTRIBUTE("MSGCOD","$namProParent","MSGCOD"))
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ASETATTRIBUTE("MSGREL","$namProParent","MSGREL"))
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ASETATTRIBUTE("MSGFILNOR","$namProParent","MSGFILNOR"))
 Next EXSD
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:EXFF]
 [L]A_N2=0
 For [F:EXFF]EXFF1 Where MSGCOD=[F:EXF]MSGCOD & MSGREL=[F:EXF]MSGREL & MSGFILNOR=[F:EXF]MSGFILNOR
  [L]A_N2 +=1
  EDIXMLFIL.EXFF(A_N2) = NewInstance  C_EDIXMLFILF(EDIXMLFIL.ACTX,NullUuid,[L]A_N2,EDIXMLFIL,"EXFF") AllocGroup EDIXMLFIL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ADDINSTANCE_BOUND)
  If dim([F:EXFF]AUUID)>0 & [F:EXFF]AUUID=NullUuid
   [F:EXFF]AUUID = getUuid
  Endif
  SetInstance EDIXMLFIL.EXFF(A_N2) With [F:EXFF]
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIXMLFIL.EXFF(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ASETATTRIBUTE("MSGCOD","$namProParent","MSGCOD"))
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ASETATTRIBUTE("MSGREL","$namProParent","MSGREL"))
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ASETATTRIBUTE("MSGFILNOR","$namProParent","MSGFILNOR"))
 Next EXFF
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

[L]A_NEWCOL = 0
For [L]A_I=1 To 20
 If ([F:EXF]COMTYP([L]A_I-1)<>0 or [F:EXF]COMVAL([L]A_I-1)<>"")
  [L]A_NEWCOL += 1
  EDIXMLFIL.EXFN(A_NEWCOL) = NewInstance  C_EDIXMLFIL_EXFN(EDIXMLFIL.ACTX,NullUuid,[L]A_I,EDIXMLFIL,"EXFN") AllocGroup EDIXMLFIL
  EDIXMLFIL.EXFN(A_NEWCOL).COMTYP = [F:EXF]COMTYP([L]A_I-1)
  EDIXMLFIL.EXFN(A_NEWCOL).COMVAL = [F:EXF]COMVAL([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFN(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



