#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Gestion de l'action SELAMT de sélection des champs de type montant dans la table
# passée en paramètres
#
# Création : MABON 12/05/11
######################################################################################

$ACTION

  Case ACTION
    When "SEL_LISTE"  : Gosub SEL_LISTE
    When Default
  Endcase
Return

$SEL_LISTE

  Case LISTE
    When "SELAMT" : Gosub SELAMT
  Endcase
Return

$SELAMT
Local Char    CODPVH(GLONPVH)
Local Char    TEXTE(80)(1..200,1..2)

  TIT(0)=mess(50,104,1) : # Montant
  TIT(1)=mess(37,100,1) : # Code
  TIT(2)=mess(36,105,1) : # Libellé
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
  Filter [F:ATZ] Where CODFIC=PARAM(1) & (CODTYP='MD2' or CODTYP='DCB' or (PARAM(1)='HREXPENSES' & CODZONE='QTY'))
&                Order By CODZONE
#  For [F:ATZ] Where CODFIC=PARAM(1) & (CODTYP='MD2' or CODTYP='DCB' or (PARAM(1)='EXPENSES' & CODZONE='QTY'))
  For [F:ATZ]
    NBTEX += 1
    TEX(NBTEX)     = [F:ATZ]CODZONE
    Read [F:ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT
    If !fstat Then
      TEXTE(NBTEX,2) = [F:ATX]TEXTE
    Endif
  Next
  Filter [F:ATZ]
Return

