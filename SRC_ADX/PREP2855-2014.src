#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################################
# Programme : PREP2855
#
# Fonction  :
#      1- Maj de la table TMP2855  pour l'état FAS2855 : Taxe sur véhicules sociétés
# Création     :  03/11/2010
#
# Modification :
# MDJ   30.09.2014 FQ86292   : Taxe VEH FY2014 + suppression ouverture TDIV 628/629
# MDJ   05.09.2012 FQ80049   : Taxe VEH : changement taux et puissance
# MDJ   03.09.2012 FQ84228   : Nb trim erroné si période exonération terminée en début période
# MDJ   29.11.2010 FQ68482
#########################################################################################

$ACTION

    Case ACTION
        When "OUVRE" :   Gosub OUVRE
        When "FIN"   :   Gosub FIN
    Endcase
Return
######################################################################################
$OUVRE

If clalev([F:FAS])=0     :    Local File FXDASSETS       [FAS]    : Endif
If clalev([F:TVS])=0     :    Local File TMP2855         [TVS]    : Endif
If clalev([F:TVSM])=0    :    Local File TMP2855         [TVSM]   : Endif
If clalev([F:FIY])=0     :    Local File FISCYEAR        [FIY]    : Endif
If clalev([F:A965])=0    :    Local File ATABDIV         [A965]   : Endif

SYMBOLE = "PREP2855"
Lock SYMBOLE With lockwait = 3
If fstat
   Return
Endif

Return
######################################################################################
$FIN

Unlock=SYMBOLE

Return
#=============================================================================
# traitement PREP2855 : alimentation de la table TMP2855
#=============================================================================
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char       PARAM(30)
Local Char       VALEUR(30)

Gosub OUVRE
Gosub MAJ_TMP2855
End
###################################################
$MAJ_TMP2855
#-------------------------------------------------------------------------------------------#
#--- Création table temporaire TMP2855 pour la liasse fiscale Taxe sur véhicules sociétés---#
#-------------------------------------------------------------------------------------------#
    Local Integer I                 # Compteur de paramètres
    Local Char    LCPY              # Société
    Local Char    LCPYNAM           # Raison sociale
    Local Date    LIMPSTRDAT        # Date imposition début
    Local Date    LIMPENDDAT        # Date imposition dfin
    Local Integer LEDTNUM           # Identifiant session
    Local Char    LCRITERE  (250)   # Critère de sélection
    Local Char    LCRITERE2 (250)   # Critère de sélection
    Local Date    LDATNULL         : LDATNULL    = [01/01/1900]
    Local Date    LFIRICIDAT       : LFIRICIDAT  = [31/12/2003]
    Local Date    LPURDAT          : LPURDAT     = [31/12/2005]
    Local Integer LANNEE           # Année d'imposition
    Local Date    DATEXOTRIM1
    Local Date    DATEXOTRIM2
    Local Date    DATEXOTRIM3
    Local Date    DATEXOTRIM4

    If clalev([TVS])=0 : Local File TMP2855 [TVS] : Endif
    Trbegin [TVS]
    Delete [TVS] Where CREUSR = GUSER #Fq-84228 & CREDAT < date$
    If fstat = 1
      Rollback
      #  "Problème à l'effacement du fichier temporaire"
         Call MESSAGE (mess(155,197,1)) From GESECRAN
    Else
       Commit
    Endif

   Call GETPARAM("cpy",NBPAR,PARAMETRE,LCPY)
   Call GETPARAM("annee",NBPAR,PARAMETRE,PARAM)       :  LANNEE    = val(PARAM)
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)          :  LEDTNUM   = val(PARAM)

  LIMPSTRDAT = gdat$(01, 10, LANNEE-1)
  LIMPENDDAT = gdat$(30, 09, LANNEE)

 Local Date LDEBTRIM1, LDEBTRIM2, LDEBTRIM3, LDEBTRIM4
 Local Date L1FIRICIDAT, L1PURDAT, LEXODAT
 Local Date DEBEXODA,  FINEXODAT

 LDEBTRIM1 = gdat$(01, 10, year(LIMPSTRDAT))
 LDEBTRIM2 = gdat$(01, 01, year(LIMPSTRDAT)+1)
 LDEBTRIM3 = gdat$(01, 04, year(LIMPSTRDAT)+1)
 LDEBTRIM4 = gdat$(01, 07, year(LIMPSTRDAT)+1)

 L1FIRICIDAT = gdat$(01, 06, 2004)
 L1PURDAT    = gdat$(01, 01, 2006)
 LEXODAT     = gdat$(01, 01, 2007)
 FINEXODAT   = gdat$(01,01,1900)

   LCRITERE  = "1=1"
   For I=1 To NBPAR
      J=instr(1,[L]PARAMETRE(I),"=")
      If J
         [L]PARAM  = left$([L]PARAMETRE(I),J-1)
         [L]VALEUR = right$([L]PARAMETRE(I),J+1)
         Case [L]PARAM
            When "cpy"            :     LCRITERE    =   "CPY='"+LCPY+"'"
            When "datimpfin"      :     LCRITERE   +=   "& PURDAT<=["+format$(GFMD,LIMPENDDAT)+"]"
         Endcase
      Endif
   Next

   LCRITERE2    =  "  OWNTYP>="+num$(1)
   LCRITERE2   +=  "& OWNTYP<="+num$(3)
   LCRITERE2   +=  "& (ISSDAT    <=  ["+format$(GFMD,LDATNULL)+"]"
   LCRITERE2   +=  "| ISSDAT     >=  ["+format$(GFMD,LIMPSTRDAT)+"])"
   LCRITERE2   +=  "& FIRICIDAT  >=  ["+format$(GFMD,LDATNULL)+"]"

   If clalev([F:TVS])=0    :    Local File TMP2855         [TVS]    : Endif
   #--------------------------------
   Call DEBTRANS From GLOCK
   Trbegin [TVS]
   Delete [TVS] Where  (CREUSR =  GUSER) #Fq-84228 &  (EDTNUM = LEDTNUM)
   If fstat=1 | fstat>5
      GOK = 0
      Call RSTA("TVS","") From GLOCK
      Rollback
   Endif
   Commit
   If !GOK : Return : Endif

If clalev([F:CPY])=0     :    Local File COMPANY         [CPY]    : Endif
If clalev([F:FAS])=0     :    Local File FXDASSETS       [FAS]    : Endif
If clalev([F:TVS])=0     :    Local File TMP2855         [TVS]    : Endif
If clalev([F:TVSM])=0    :    Local File TMP2855         [TVSM]   : Endif
If clalev([F:FIY])=0     :    Local File FISCYEAR        [FIY]    : Endif
If clalev([F:A965])=0    :    Local File ATABDIV         [A965]    : Endif

  Read [CPY]CPY0=LCPY
  If fstat= 0
    LCPYNAM = [F:CPY]CPYNAM
  Endif

   Call DEBTRANS From GLOCK
   Trbegin [TVS], [TVSM]
   Filter [FAS] Where ( evalue(LCRITERE) & evalue (LCRITERE2)) and NPL <> ""
   For [FAS]
      Read[A965]=965;[F:FAS]VEHTYP
      If fstat=0
        If [F:A965]N1 <> G_OUI
          Goto NEXTFAS
        Endif
      Endif
      Raz[TVS]
      Raz[TVSM]
      [F:TVSM] = [F:FAS]
      GOK=1
      #1------------
      Gosub CHARGE_TVSM
      [F:TVS]=[F:TVSM]
      #========================================================
      [F:TVS]           =  [F:TVSM]
      [F:TVS]EDTNUM     =  LEDTNUM
      [F:TVS]CREUSR     =  GUSER
      [F:TVS]CREDAT     =  date$
      [F:TVS]CPY        =  LCPY
      [F:TVS]CPYNAM     =  LCPYNAM
      [F:TVS]IMPSTRDAT  =  LIMPSTRDAT
      [F:TVS]IMPENDDAT  =  LIMPENDDAT
       If EDTNUM <> 0
         Write [F:TVS]
         If fstat : GOK=0 : Call FSTA("TVS") From GLOCK : Endif
         If !GOK : Break :  Goto ROLL_TR1 : Endif
      Endif
      $NEXTFAS
   Next
   Filter[FAS]

  If GOK : Commit : Else Gosub ROLL_TR1 : Endif

Return
######################################################################################
$ROLL_TR1
Rollback : Call ROLL From GLOCK
If GROLL : Return  : Endif
Return
######################################################################################
$CHARGE_TVSM
#@durée--------------------------------
   If [F:FAS]OWNTYP = 2
      If [F:FAS]RNTENDDAT >= LIMPSTRDAT and  [F:FAS]RNTENDDAT <= LIMPENDDAT
         [F:TVSM]RNTDUR = (([F:FAS]RNTENDDAT - [F:FAS]RNTSTRDAT)+1)
      Else
         If [F:FAS]RNTENDDAT >= LIMPSTRDAT and  [F:FAS]RNTENDDAT > LIMPENDDAT
            [F:TVSM]RNTDUR = ((LIMPENDDAT- [F:FAS]RNTSTRDAT)+1)
         Else
            If [F:FAS]RNTENDDAT < LIMPSTRDAT and  [F:FAS]RNTENDDAT <= LIMPENDDAT
              [F:TVSM]RNTDUR = ((LIMPENDDAT- LIMPSTRDAT)+1)
            Endif
         Endif
      Endif
   Endif


    If       [F:FAS]VEHCO2  > 0   and [F:FAS]VEHCO2  <= 50  : [F:TVSM]TARIFCO2 = 0
      Elsif  [F:FAS]VEHCO2  > 50  and [F:FAS]VEHCO2  <= 100 : [F:TVSM]TARIFCO2 = 2
      Elsif  [F:FAS]VEHCO2  > 100 and [F:FAS]VEHCO2  <= 120 : [F:TVSM]TARIFCO2 = 4
      Elsif  [F:FAS]VEHCO2  > 120 and [F:FAS]VEHCO2  <= 140 : [F:TVSM]TARIFCO2 = 5.5
      Elsif  [F:FAS]VEHCO2  > 140 and [F:FAS]VEHCO2  <= 160 : [F:TVSM]TARIFCO2 = 11.5
      Elsif  [F:FAS]VEHCO2  > 160 and [F:FAS]VEHCO2  <= 200 : [F:TVSM]TARIFCO2 = 18
      Elsif  [F:FAS]VEHCO2  > 200 and [F:FAS]VEHCO2  <= 250 : [F:TVSM]TARIFCO2 = 21.5
      Elsif  [F:FAS]VEHCO2  > 250                           : [F:TVSM]TARIFCO2 = 27
   Endif

   #*FQ86292 Catégorie carburant et Tarif Air --------------------------------

   If [F:FAS]FUEL> 0
     [F:TVSM]FUELDES=mess([F:FAS]FUEL,3167,1) #FQNEW
   Endif

    If [F:FAS]FIRICIDAT <= [31/12/1996]
      If  [F:FAS]FUEL  = 1 :   [F:TVSM]TARIFAIR = 70 : Endif
      If  [F:FAS]FUEL  = 2 :   [F:TVSM]TARIFAIR = 600 : Endif
    Endif

    If [F:FAS]FIRICIDAT > [31/12/1996]  and  [F:FAS]FIRICIDAT <= [31/12/2000]
      If  [F:FAS]FUEL  = 1 :   [F:TVSM]TARIFAIR = 45  : Endif
      If  [F:FAS]FUEL  = 2 :   [F:TVSM]TARIFAIR = 400 : Endif
    Endif

    If [F:FAS]FIRICIDAT > [31/12/2000]  and  [F:FAS]FIRICIDAT <= [31/12/2005]
      If  [F:FAS]FUEL  = 1 :   [F:TVSM]TARIFAIR = 45  : Endif
      If  [F:FAS]FUEL  = 2 :   [F:TVSM]TARIFAIR = 300 : Endif
    Endif

    If [F:FAS]FIRICIDAT > [31/12/2005]  and  [F:FAS]FIRICIDAT <= [31/12/2010]
      If  [F:FAS]FUEL  = 1 :   [F:TVSM]TARIFAIR = 45  : Endif
      If  [F:FAS]FUEL  = 2 :   [F:TVSM]TARIFAIR = 100 : Endif
    Endif

    If [F:FAS]FIRICIDAT > [31/12/2010]
      If  [F:FAS]FUEL  = 1 :   [F:TVSM]TARIFAIR = 20  : Endif
      If  [F:FAS]FUEL  = 2 :   [F:TVSM]TARIFAIR = 40 : Endif
   Endif
   #*FQ86292 END

#@I-calcfinexodat--------------------------------
#/ BIEN acquis à partir du 01/01/2007 et exonérés partiellement ou totalement pendant 8 mois
#+ Cas particulier des véhicules dont la date 1ère mise en circulation >= 01/01/2007
#+ et ayant bénéficié d'une exonération totale ou partielle l'exonération ne s'applique
#+ que pendant 8 trimestres à partir du 1er jour du trimestre dans lequel se situe la date de 1ère mise en circulation
  If ( [F:FAS]FIRICIDAT >= [01/01/2007] ) and ( [F:FAS]TAXPLI > 1 )
     DATEXOTRIM1 =  gdat$(01, 01, year([F:FAS]FIRICIDAT))
     DATEXOTRIM2 =  gdat$(01, 04, year([F:FAS]FIRICIDAT))
     DATEXOTRIM3 =  gdat$(01, 07, year([F:FAS]FIRICIDAT))
     DATEXOTRIM4 =  gdat$(01, 10, year([F:FAS]FIRICIDAT))
     If  [F:FAS]FIRICIDAT>= DATEXOTRIM1 and [F:FAS]FIRICIDAT < DATEXOTRIM2
        DEBEXODAT = DATEXOTRIM1
     Else
        If [F:FAS]FIRICIDAT >= DATEXOTRIM2 and [F:FAS]FIRICIDAT < DATEXOTRIM3
           DEBEXODAT = DATEXOTRIM2
        Else
           If  [F:FAS]FIRICIDAT >= DATEXOTRIM3 and [F:FAS]FIRICIDAT < DATEXOTRIM4
              DEBEXODAT = DATEXOTRIM3
           Else
              If  [F:FAS]FIRICIDAT >= DATEXOTRIM4
                 DEBEXODAT = DATEXOTRIM4
              Endif
           Endif
        Endif
     Endif
     FINEXODAT =  gdat$(day(DEBEXODAT)-1, month(DEBEXODAT), year(DEBEXODAT)+2)
  Else
     FINEXODAT=[F:FAS]FIRICIDAT
  Endif

 [F:TVSM]EXOENDDAT = FINEXODAT

#--------------I. VEHICULES TAXES SELON LES EMISSIONS DE CO2 ----------------------------
#@I-calcnbtrim--------------------------------
If [F:FAS]VEHTAXRUL = 2
  If [F:FAS]OWNTYP <> 2  #-------- <> En Crédit-Bail
    If    [F:FAS]TAXPLI = 1    :       Gosub CALTRM_NEXO      # ==> Plein Tarif
    Elsif [F:FAS]TAXPLI >= 2   :       Gosub CALTRM_EXO    # ==> n trimestres Exonérés
    Endif
  Else #----------OWNTYP = 2 (En location) ou 3 (En crédit bail)
    If   [F:FAS]OWNTYP = 2
       If  [F:TVSM]RNTDUR < 31
           [F:TVSM]NBTRIM1P = 0
       Else
          If  [F:TVSM]RNTDUR> 30 and [F:TVSM]RNTDUR < 91
              [F:TVSM]NBTRIM1P = 1
          Else
             If  [F:TVSM]RNTDUR> 90 and [F:TVSM]RNTDUR < 181
                 [F:TVSM]NBTRIM1P = 2
             Else
                If  [F:TVSM]RNTDUR> 180 and [F:TVSM]RNTDUR < 271
                    [F:TVSM]NBTRIM1P = 3
                Else
                   If  [F:TVSM]RNTDUR> 270
                       [F:TVSM]NBTRIM1P =4
                   Endif
                Endif
             Endif
          Endif
       Endif
    Endif
    [F:TVSM]NBTRIM1T =  [F:TVSM]NBTRIM1P + [F:TVSM]NBTRIM1E
  Endif
  #--------------------------------


  #FQ86292 1ère composante (Tarif CO2) : porte sur le nb de trimestres non exonérés dans la période
  [F:TVSM]TAXECOL1 =  (( [F:FAS]VEHCO2 * [F:TVSM]TARIFCO2 ) / 4) * [F:TVSM]NBTRIM1P

  #FQ86292 2ème composante (Tarif Air) : porte sur le nb de trimestres de détention dans la période
  [F:TVSM]TAXECOL2 =  ([F:TVSM]TARIFAIR / 4 ) * [F:TVSM]NBTRIM1T

     [F:TVSM]TAXECOL1 =[F:TVSM]TAXECOL1 + [F:TVSM]TAXECOL2


Else   #----------------------II. AUTRES VEHICULES---------------------------------------
    If [F:FAS]VEHTAXRUL <> 1 : Return : Endif

    If       [F:FAS]VEHPWR  = 0                             : [F:TVSM]TARIFPWR = 0
    Elsif    [F:FAS]VEHPWR  > 0    and [F:FAS]VEHPWR   <=3  : [F:TVSM]TARIFPWR = 750
    Elsif    [F:FAS]VEHPWR  >= 4   and [F:FAS]VEHPWR  <= 6  : [F:TVSM]TARIFPWR = 1400
    Elsif    [F:FAS]VEHPWR  >= 7   and [F:FAS]VEHPWR  <= 10 : [F:TVSM]TARIFPWR = 3000
    Elsif    [F:FAS]VEHPWR  >= 11  and [F:FAS]VEHPWR  <= 15 : [F:TVSM]TARIFPWR = 3600
    Elsif    [F:FAS]VEHPWR  >= 16                           : [F:TVSM]TARIFPWR = 4500
    Endif
    #@II-calcnbtrim--------------------------------
    #/ BIEN PRÉSENT AU 01/07/N
    If [F:FAS]OWNTYP <> 2
     If  [F:FAS]PURDAT <= LIMPSTRDAT and  ([F:FAS]ISSDAT > LDEBTRIM4 or [F:FAS]ISSDAT < LDATNULL)
           [F:TVSM]NBTRIM2 = 4
     Else
       #// BIEN PRÉSENT AU 01/04/N
        If   [F:FAS]PURDAT   <= LDEBTRIM2  and   ([F:FAS]ISSDAT   >  LDEBTRIM3 or [F:FAS]ISSDAT< LDATNULL)
            [F:TVSM]NBTRIM2= 3
        Else
           #// BIEN PRÉSENT AU 01/01/N
           If   [F:FAS]PURDAT <=  LDEBTRIM3  and  ([F:FAS]ISSDAT >   LDEBTRIM2 or [F:FAS]ISSDAT< LDATNULL)
              [F:TVSM]NBTRIM2= 2
           Else
              #// BIEN PRÉSENT AU 01/10/N-1
              If   [F:FAS]PURDAT <=  LDEBTRIM4  and  ([F:FAS]ISSDAT >  LDEBTRIM1 or [F:FAS]ISSDAT< LDATNULL)
                  [F:TVSM]NBTRIM2= 1
              Else
                  [F:TVSM]NBTRIM2= 0
              Endif
           Endif
        Endif
     Endif
  Else
    If [F:FAS]OWNTYP<=3
       If   ([F:TVSM]RNTDUR) < 31
          [F:TVSM]NBTRIM2=0
       Else
          If  [F:TVSM]RNTDUR> 30 and [F:TVSM]RNTDUR < 91
                 [F:TVSM]NBTRIM2=1
          Else
             If  [F:TVSM]RNTDUR> 90 and [F:TVSM]RNTDUR < 181
                   [F:TVSM]NBTRIM2=2
             Else
                If  [F:TVSM]RNTDUR> 180 and [F:TVSM]RNTDUR < 271
                     [F:TVSM]NBTRIM2=3
                Else
                   If  [F:TVSM]RNTDUR> 270
                     [F:TVSM]NBTRIM2=4
                   Endif
                Endif
             Endif
          Endif
       Endif
    Endif
  Endif

  [F:TVSM]TAXECOL4 = 0

  #--------------------------------

    [F:TVSM]TAXECOL3 =  ([F:TVSM]TARIFPWR + [F:TVSM]TARIFAIR) * [F:TVSM]NBTRIM2 / 4

Endif

Return
####################################################
$CALTRM_NEXO

 #// BIEN PRÉSENT AU 01/07/N
 If  [F:FAS]PURDAT <= LIMPSTRDAT and  ( [F:FAS]ISSDAT > LDEBTRIM4 or [F:FAS]ISSDAT < LDATNULL )
     If     ( [F:FAS]PURDAT>=   LDEBTRIM1 and  [F:FAS]PURDAT <  LDEBTRIM2 )
         [F:TVSM]NBTRIM1P = 4
     Elsif  ( [F:FAS]PURDAT >=  LDEBTRIM2 and  [F:FAS]PURDAT <  LDEBTRIM3 )
         [F:TVSM]NBTRIM1P = 3
     Elsif  ( [F:FAS]PURDAT >=  LDEBTRIM3 and  [F:FAS]PURDAT <  LDEBTRIM4 )
         [F:TVSM]NBTRIM1P = 2
     Elsif  ( [F:FAS]PURDAT >=  LDEBTRIM4 and  [F:FAS]PURDAT < LIMPENDDAT)
         [F:TVSM]NBTRIM1P = 1
     Elsif  ( [F:FAS]PURDAT >=  LIMPENDDAT )
         [F:TVSM]NBTRIM1P = 0
     Else
       [F:TVSM]NBTRIM1P = 4
     Endif
 Else
     #// BIEN PRÉSENT AU 01/04/N
     If   [F:FAS]PURDAT  <= LDEBTRIM2  and   ([F:FAS]ISSDAT   >  LDEBTRIM3 or [F:FAS]ISSDAT< LDATNULL)
         If     (  [F:FAS]PURDAT >=  LDEBTRIM2 and   [F:FAS]PURDAT <  LDEBTRIM3 )
            [F:TVSM]NBTRIM1P = 3
         Elsif  (  [F:FAS]PURDAT >=  LDEBTRIM3 and   [F:FAS]PURDAT <  LDEBTRIM4 )
            [F:TVSM]NBTRIM1P = 2
         Elsif  (  [F:FAS]PURDAT >=  LDEBTRIM4 and (  [F:FAS]PURDAT <  LIMPENDDAT ) )
            [F:TVSM]NBTRIM1P = 1
         Elsif    (  [F:FAS]PURDAT >=  LIMPENDDAT )
           [F:TVSM]NBTRIM1P = 0
         Else
            [F:TVSM]NBTRIM1P =3
         Endif
     Else
         #// BIEN PRÉSENT AU 01/01/N
         If  [F:FAS]PURDAT <=  LDEBTRIM3  and  ([F:FAS]ISSDAT >   LDEBTRIM2 or [F:FAS]ISSDAT< LDATNULL)
             If     (  [F:FAS]PURDAT >=  LDEBTRIM3 and   [F:FAS]PURDAT <  LDEBTRIM4 )
               [F:TVSM]NBTRIM1P = 2
             Elsif  (  [F:FAS]PURDAT >=  LDEBTRIM4 and (  [F:FAS]PURDAT <  LIMPENDDAT ) )
               [F:TVSM]NBTRIM1P = 1
             Elsif    (  [F:FAS]PURDAT >= LIMPENDDAT )
                [F:TVSM]NBTRIM1P = 0
             Else
                [F:TVSM]NBTRIM1P = 2
             Endif
         Else
           #// BIEN PRÉSENT AU 01/10/N-1
           If   [F:FAS]PURDAT <=  LDEBTRIM4  and  ([F:FAS]ISSDAT >  LDEBTRIM1 or [F:FAS]ISSDAT< LDATNULL)
             If     (  [F:FAS]PURDAT >=  LDEBTRIM4 and   [F:FAS]PURDAT <  LIMPENDDAT )
               [F:TVSM]NBTRIM1P = 1
             Elsif  (  [F:FAS]PURDAT >=  LIMPENDDAT )
               [F:TVSM]NBTRIM1P = 0
             Else
                [F:TVSM]NBTRIM1P = 1
             Endif
         Endif
      Endif
    Endif
 Endif

 [F:TVSM]NBTRIM1T =   [F:TVSM]NBTRIM1E +  [F:TVSM]NBTRIM1P

Return
####################################################
$CALTRM_EXO

 #// BIEN PRÉSENT AU 01/07/N
 If  [F:FAS]PURDAT <= LIMPSTRDAT and  ( [F:FAS]ISSDAT > LDEBTRIM4 or [F:FAS]ISSDAT < LDATNULL )
     If  FINEXODAT < LIMPSTRDAT
         [F:TVSM]NBTRIM1E  = 0
         [F:TVSM]NBTRIM1P  = 4
     Elsif  ( FINEXODAT >=  LDEBTRIM1 and  FINEXODAT <  LDEBTRIM2 )
         [F:TVSM]NBTRIM1E  = 1
         [F:TVSM]NBTRIM1P  = 3
     Elsif  ( FINEXODAT >=  LDEBTRIM2 and  FINEXODAT <  LDEBTRIM3 )
         [F:TVSM]NBTRIM1E  = 2
         [F:TVSM]NBTRIM1P  = 2
     Elsif  ( FINEXODAT >=  LDEBTRIM3 and  FINEXODAT <  LDEBTRIM4 )
         [F:TVSM]NBTRIM1E  = 3
         [F:TVSM]NBTRIM1P  = 1
     Elsif  ( FINEXODAT >=  LDEBTRIM4 )
         [F:TVSM]NBTRIM1E  = 4
         [F:TVSM]NBTRIM1P  = 0
     Endif
 Else
    #// BIEN PRÉSENT AU 01/04/N
    If   [F:FAS]PURDAT   <= LDEBTRIM2  and  ([F:FAS]ISSDAT   >  LDEBTRIM3 or [F:FAS]ISSDAT< LDATNULL)
       #Fq-84228 If ( FINEXODAT >=  LDEBTRIM2 and  FINEXODAT <  LDEBTRIM3 )
        If ( FINEXODAT < LDEBTRIM2 )
           [F:TVSM]NBTRIM1E  = 0
           [F:TVSM]NBTRIM1P  = 3
        Elsif ( FINEXODAT >=  LDEBTRIM2 and  FINEXODAT <  LDEBTRIM3 )
           [F:TVSM]NBTRIM1E  = 1
           [F:TVSM]NBTRIM1P  = 2
        Elsif  ( FINEXODAT >=  LDEBTRIM3 and  FINEXODAT <  LDEBTRIM4 )
           [F:TVSM]NBTRIM1E  = 2
           [F:TVSM]NBTRIM1P  = 1
        Elsif  ( FINEXODAT >=  LDEBTRIM4 )
           [F:TVSM]NBTRIM1E  = 3
           [F:TVSM]NBTRIM1P  = 0
        Endif
    Else
       #// BIEN PRÉSENT AU 01/01/N
       If   [F:FAS]PURDAT <=  LDEBTRIM3  and  ([F:FAS]ISSDAT >   LDEBTRIM2 or [F:FAS]ISSDAT< LDATNULL)
           #Fq-84228 If  ( FINEXODAT >=  LDEBTRIM3 and  FINEXODAT <  LDEBTRIM4 )
           If   ( FINEXODAT < LDEBTRIM3 )
              [F:TVSM]NBTRIM1E  = 0
              [F:TVSM]NBTRIM1P  = 2
           Elsif  ( FINEXODAT >=  LDEBTRIM3 and  FINEXODAT <  LDEBTRIM4 )
               [F:TVSM]NBTRIM1E  = 1
               [F:TVSM]NBTRIM1P  = 1
           Elsif  ( FINEXODAT >=  LDEBTRIM4 )
               [F:TVSM]NBTRIM1E  = 2
               [F:TVSM]NBTRIM1P  = 0
           Endif
       Else
          #// BIEN PRÉSENT AU 01/10/N-1
          If   [F:FAS]PURDAT <=  LDEBTRIM4  and  ([F:FAS]ISSDAT >  LDEBTRIM1 or [F:FAS]ISSDAT< LDATNULL)
             #Fq-84228 If ( FINEXODAT >=  LDEBTRIM4 and  FINEXODAT <  LIMPENDDAT )
             If ( FINEXODAT < LDEBTRIM4 )
                [F:TVSM]NBTRIM1E  = 0
                [F:TVSM]NBTRIM1P  = 1
             Else
                [F:TVSM]NBTRIM1E  = 1
                [F:TVSM]NBTRIM1P  = 0
             Endif
          Endif
       Endif
    Endif
 Endif

 [F:TVSM]NBTRIM1T =   [F:TVSM]NBTRIM1E +  [F:TVSM]NBTRIM1P

Return
####################################################
#================================================================
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

   Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
   L = len(PARAM)
   If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
   Endif

End
####################################################
