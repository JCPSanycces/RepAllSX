#MABOS-04/03/13-FQ81085-US1335- add a trace
Subprog INFO_FLD(WFLD,WCOL,LIBFLD,WNOLIB)
Value Char WFLD
Variable Integer WCOL
Variable Char LIBFLD
Variable Integer WNOLIB
Local Integer WIND
#Variable Char WVALCHAR

Local Char NOMCOD(50), CPLT(5)
Local Integer K, T
#Gosub APRES_MODIF

[L]NOMCOD=[L]WFLD
# FQ81085 - 17/12/13 - SITFAM et CIV ont été changés en SITFAMA et CIVA
If find([L]WFLD,"SITFAMA","CIVA","CIVCTRA")>0 Then
  [L]NOMCOD=left$([L]WFLD,len([L]WFLD)-1)
Endif
# Fin FQ81085
[L]WIND = 0
[L]CPLT=" "
 If instr(0,[L]NOMCOD,"_") > 0 Then
    [L]NOMCOD=left$([L]NOMCOD, instr(0,[L]NOMCOD,"_")-1)
    [L]WIND = val(right$([L]WFLD,instr(0,[L]WFLD,"_")+1))
    [L]CPLT="("+num$([L]WIND)+")"
 Endif

 [L]WCOL = find([L]NOMCOD,[M:DIB]CODZONE)
 If [L]WCOL > 0
  [L]LIBFLD=[M:DIB]LIBZONE([L]WCOL-1)+[L]CPLT

  If toupper([M:DIB]CODZONE([L]WCOL-1))<>toupper(mess(59,10709,1))
    If clalev([F:ATZ])=0   : Local File ATABZON    [ATZ]   : Endif
    Read [ATZ]CODZONE = [M:DIB]CODFIC([L]WCOL-1);[M:DIB]CODZONE([L]WCOL-1)
    [L]WNOLIB = [F:ATZ]NOLIB
  Endif

 Endif
 End

#MABOS-04/03/13-FQ81085-US1335- add a trace
Subprog LIST_MOD(WFLD, I, LIBFLD, WNOLIB)
Value Char WFLD, LIBFLD
Value Integer I, WNOLIB
Local Char VALCOD(250)
Local Char CPLT(5)
Local Char L_CONTRAT(250)
    L_CONTRAT = [M:GEN]REFNUM(I)
    If [F:HRSMH]FLGMAT<2
      L_CONTRAT += [M:GEN]CTRNUM(I)+format$("D:"+GFMDAT,[M:GEN]CTRDAT(I))
    Endif
    [L]VALCOD= func VALCHAR("zc",0,[L]WNOLIB)
    If !find([L]L_CONTRAT+"~"+[L]WFLD,[V]CONTRAT_FLD_MOD)
      [V]INDCTR+=1
#      [V]GEN_NOLIG([V]INDCTR)=nolign-1
      [V]CONTRAT_MOD([V]INDCTR)=[L]L_CONTRAT
      [V]CONTRAT_FLD_MOD([V]INDCTR)=[L]L_CONTRAT+"~"+[L]WFLD
#      [V]DIB_NO([V]INDCTR)=K-1
      [V]GEN_BEFORE([V]INDCTR)= func VALCHAR("[M:GEN]"+[L]WFLD,I,[L]WNOLIB)
    Endif
    If [L]VALCOD =  [V]GEN_BEFORE([V]INDCTR)
    # Pas de changment de valeur / origine
      [V]CONTRAT_MOD([V]INDCTR)=""
      [V]CONTRAT_FLD_MOD([V]INDCTR)=""
      [V]CTR_FLD([V]INDCTR)=""
    Else
      [V]CTR_FLD([V]INDCTR)=space$(5)+[L]LIBFLD-":"
      [V]CTR_FLD([V]INDCTR)-= mess(00369,00177,1)  -":"- [V]GEN_BEFORE([V]INDCTR) :#:  Valeur avant
      [V]CTR_FLD([V]INDCTR)-="/"- mess(00370,00177,1) -":"-[L]VALCOD : #  Valeur après
    Endif
End

#MABOS-04/03/13-FQ81085-US1335- add a trace
Funprog VALCHAR(WFLD,I,WNOLIB)
Value Char WFLD
Value Integer I
Value Integer WNOLIB
Local Char VALEUR(250), FLDLIG(250)
Local Date WDAT
Local Integer T

 T = evalue("type("+[L]WFLD+")")
 [L]FLDLIG = [L]WFLD
 If I>0 Then
  [L]FLDLIG +="("+num$(I)+")"
 Endif
  If [L]T>=10
    [L]VALEUR = evalue([L]FLDLIG)
  Elsif T=3 :#Date
     [L]WDAT = evalue([L]FLDLIG)
     If [L]WDAT=[0/0/0]

     Else
      [L]VALEUR -= vireblc(format$("DD2",[L]WDAT),2)
     Endif
  Elsif [L]WNOLIB>0
    [L]VALEUR -=mess(evalue([L]FLDLIG),[L]WNOLIB,1)
  Else
    [L]VALEUR -=vireblc(format$("N:15F",evalue([L]FLDLIG)),2)
  Endif

End [L]VALEUR

INIT_TRACE
Global Integer INDCTR
Global Char CONTRAT_MOD(250)(1000)
Global Char CONTRAT_FLD_MOD(250)(1000)
Global Char CTR_FLD(250)(1000)
Global Char GEN_BEFORE(250)(1000)
Return

