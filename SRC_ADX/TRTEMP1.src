##################################
Subprog C_SMH(VALEUR)
Variable Char    VALEUR()
#DBA : Ligne indispensable (cf.89980)  !!! Pourquoi avoir mis cette ligne en cmt ?!?

#JASMI
  GCURLEG=[F:HRSMH]LEG
  [M:DIA]LEG=GCURLEG
#JASMI

[M:DIA]MYLEG=GCURLEG

#JASMI
#Call LECTURE("SMH",GCURLEG,VALEUR) From CONTOBJ
Call LECTURE("HRSMH",GCURLEG,VALEUR) From CONTOBJ
#JASMI
If [F:HRSMH]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:HRSMH]CODACS
 If fstat | [F:ACC]EXEC<>2
  GMESSAGE = mess(81,10702,1) : # Vous n'avez pas le droit d'accès à cet écran
  mkstat = 2 : End
 Endif
Endif
If [F:HRSMH]CODACT<>""
 Read [ACV]CODACT=[F:HRSMH]CODACT
 If fstat | [F:ACV]FLACT<>2
  GMESSAGE = mess(81,10702,1) : # Vous n'avez pas le droit d'accès à cet écran
  mkstat = 2 : End
 Endif
Endif
#
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#If VALEUR<>[M]SMH
# [M]SMH = VALEUR
#Endif
#JOJAC - 2016-04-04 - REQ114309 US83 - END
End

##################################
Subprog AS_DATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
VALEUR=GMOIPAY
End

##################################
Subprog AS_DATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
VALEUR=eomonth(GMOIPAY)
End

################################################################################################
#                         FENETRE PRINCIPALE GENEMP2
################################################################################################

################################################################################################
# Remplissage d'un tableau GTABLES contenant les tables à gérer dans la fênetre principale
################################################################################################
$DEBUT
#JOJAC - 2016-04-08 - REQ114309 US83 - START
Global Char SCPAR (GLONSMH)
SCPAR=PARAM(1)
##JOJAC - 2016-04-08 - REQ114309 US83 - END
Local Char DES (GLONAX3)
Global Char DES1 (GLONAX3)
Case BOITE
 When "OGENEMP" :
#JOJAC - 2016-04-04 - REQ114309 US83 - START
# Global Char     GTABLES (15)(1..20,1..2)
  Global Char     GTABLES (GLONATB)(1..20,1..3)
#JOJAC - 2016-04-04 - REQ114309 US83 - END
  Global Integer  NBTABLE, J, K
  Global Shortint GFLAGMODIF
  Affzo [M:DIA]
  #Raz [M:DIA]INI

  Setmok [DIA] With 0

 Call AFF_MEMO From DIVPAYE
#JOJAC - 2016-04-04 - REQ114309 US83 - START
 #If PARAM(1)<>"" & PARAM(2)<>""
 If PARAM(1)<>""
#JOJAC - 2016-04-04 - REQ114309 US83 - END
GCURLEG=PARAM(2)
   If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
   [M:DIA]MYLEG = GCURLEG
   Read [HRSMH]SMH0 = PARAM(2);PARAM(1)
   Call LECTEXTRA([L]DES,"SCREMPH","DES",GCURLEG,[F:HRSMH]COD) From ATEXTRA
   # JOJAC - 2016-04-04 - REQ114309 US83 - START
   DES1 = [L]DES
   If [L]DES <>""
   Titled [DIA] [L]DES
   Chgtfd [M:DIA] With [L]DES
   Endif
   # JOJAC - 2016-04-04 - REQ114309 US83 - END
   [M:DIA]SMH = PARAM(1)
   [M:DIA]ZSMH = [L]DES
   If dim ([M:DIA]LEG)>=0
    [M:DIA]LEG = PARAM(2)
# JOJAC - 2016-04-04 - REQ114309 US83 - START
[M:DIA]LEG = GCURLEG
# JOJAC - 2016-04-04 - REQ114309 US83 - END

    Call LECTEXTRA([M:DIA]ZLEG,"ATABDIV","LNGDES","909",PARAM(2)) From ATEXTRA
    Affzo [DIA]LEG,ZLEG
# JOJAC - 2016-04-04 - REQ114309 US83 - START
#    Grizo [DIA]LEG
# JOJAC - 2016-04-04 - REQ114309 US83 - END
   Endif
   Affzo [DIA]SMH,ZSMH
   #JOJAC
   # Grizo [DIA]SMH
   #JOJAC
   Grizo [M:DIA]FLGPOP : #MABOS-04/03/13-FQ81085-US1335-synchronize populations
  Endif

#JOJAC - 2016-04-04 - REQ114309 US83 - START
If [M:DIA]LEG <> ''
Read [F:HRSMH]SMH0 = [M:DIA]LEG;[V]SCPAR
 If fstat
  Raz [M:DIA]SMH : Affzo [M:DIA]SMH
 Endif
Endif
#JOJAC - 2016-04-04 - REQ114309 US83 - END


 When "WFEM"+[M:DIA]MYLEG+[M:DIA]SMH
  Local Integer EXISTE
  GFLAGMODIF=1
  NBTABLE=0
  For nolign=1 To [M:DIB]BPAG
   EXISTE=0
   If toupper([M:DIB]CODZONE(nolign-1))<>toupper(mess(59,10709,1))
    If NBTABLE<>0
     For J=1 To NBTABLE
      If GTABLES(J,1)=[M:DIB]CODFIC(nolign-1)
       EXISTE=1 : Break
      Endif
     Next J
    Endif
    If EXISTE=0
     If toupper([M:DIB]CODZONE(nolign-1))<>toupper(mess(59,10709,1))
      NBTABLE=NBTABLE+1
      GTABLES(NBTABLE,1)=[M:DIB]CODFIC(nolign-1)
#JOJAC - 2016-04-04 - REQ114309 US83 - START
      # FQ112187 - 02/11/15 - Stockage de l'abréviation
      Read [F:ATB]CODFIC=GTABLES(NBTABLE,1)
      If !fstat Then
        GTABLES(NBTABLE,3)=[F:ATB]ABRFIC
      Endif
#JOJAC - 2016-04-04 - REQ114309 US83 - END

      If [M:DIB]OPT(nolign-1)=1
       GTABLES(NBTABLE,2)="S"    :#Saisir
      Else
       GTABLES(NBTABLE,2)="A"    :#Afficher
      Endif
     Endif
    Else
     If GTABLES(J,2)="A"
      If [M:DIB]OPT(nolign-1)=1
       GTABLES(J,2)="S"    :#Saisir
      Endif
     Endif
    Endif
   Endif
  Next nolign
  [M:DIB]NBHIS = 0
  For I=1 To NBTABLE
   Read [ATI]NUMLIG = GTABLES(I,1);2
   If !fstat
    J = instr(1,[F:ATI]DESCRIPT,"+")
    K = instr(J+1,[F:ATI]DESCRIPT,"+")
    If J | K
     If K
      Read [ATZ]CODZONE = GTABLES(I,1);right$([F:ATI]DESCRIPT,K+1)
     Else
      Read [ATZ]CODZONE = GTABLES(I,1);right$([F:ATI]DESCRIPT,J+1)
     Endif
     If !fstat & [F:ATZ]CODTYP="D"
      [M:DIB]NBHIS += 1
      [M:DIB]HISDAT([M:DIB]NBHIS) = [F:ATZ]CODZONE
      [M:DIB]HISTBL([M:DIB]NBHIS) = GTABLES(I,1)
      Read [ATB]CODFIC = [F:ATZ]CODFIC
      [M:DIB]HISDES([M:DIB]NBHIS) = [F:ATB]INTIT
     Endif
    Endif
   Endif
  Next I
  Call TEMPON("L") From GESECRAN
  Gosub CHARGE_DONNEES
  Call TEMPOFF From GESECRAN
Endcase
Return



##################################
$ENR
Case BOITE
 When "WFEM"+[M:DIA]MYLEG+[M:DIA]SMH :
 # MABOS-04/03/13-FQ81085-US1335-Add a question to confirm recording
  Local Integer WOK
  Call OUINON(mess(161,10701,1), [L]WOK) From GESECRAN : # Confirmez-vous la modification des employés et contrats ? ?
  If [L]WOK = 1 Then SAI=1 : Return : Endif
  Gosub SAUVE_DONNEES
 # FIN = 0 : GOK = 1

Endcase
Return

##################################
# Gestion des boutons (griser, dégriser...)
##################################
$SETBOUT
Case BOITE
 When "WFEM"+[M:DIA]MYLEG+[M:DIA]SMH
  If GFLAGMODIF=0
   ETABOU(GENRE) = 1
  Else
   ETABOU(GENRE) = 0
  Endif
  ETABOU(GEDIT) = 1
  ETABOU(GRAFF) = 1
 Endcase
Return

##################################
# Gestion des modifs
##################################
$APRES_MODIF
Local Char LIBFLD(30), VALCOD(250)
Local Char CPLT(5)
Local Integer WNOLIB

Case BOITE
 When "WFEM"+[M:DIA]MYLEG+[M:DIA]SMH
  GFLAGMODIF = 0
  REP        = "M"
  #59756 : Si aucun enregistrement présent, la date est vide
  #MABOS-04/03/13-FQ81085-US1335-Add a trace
  Call INFO_FLD(COUZON,K,[L]LIBFLD,[L]WNOLIB)
  If K
   K = find([M:DIB]CODFIC(K-1),[M:DIB]HISTBL)
   If K & [M:DIB]HISDAT(K-1)<>COUZON & evalue("dim([M:GEN]"+[M:DIB]HISDAT(K-1)+")")>0
&   & evalue([M:DIB]HISDAT(K-1)+"("+num$(nolign-1)+")")=[0/0/0]
    # Date obligatoire
    GERR = 1 : GMESSAGE = mess(69,10702,1)-[M:DIB]HISDAT(K-1)
   Else
     #MABOS-04/03/13-FQ81085-US1335-Add a trace
     Call LIST_MOD(COUZON, nolign-1,[L]LIBFLD, [L]WNOLIB)
     [M:GEN]FLG(nolign-1)=1
   Endif

  Endif
  # fin 59756
Endcase
Return

##################################
# Chargement des données correspondant aux champs choisis
# en tenant compte des critères de sélection
##################################
$CHARGE_DONNEES
# Lecture pour un matricule
Local Integer J
Local Char    TABLE(10) , MATRI(GLONEML)
Local Char    CRITERECPY (50), CRITEREFCY (50), CRITERESRV (50), CRITEREPRF (50), CRITERELEG (50)
Local Char    CRITEREPOT (50), CRITEREJOBPOT (50) :#SEGAY 25/09/12 84268 US 805
Local Char    CRITEREDEB (50), CRITEREFIN (50), CRITERELIBRE (100)
Local Date    DATMAT
Local Date    DATDEB , DATFIN

Read [HRSMH]SMH0 = [M:DIA]MYLEG;[M:DIA]SMH
GERR = 0
nolign = 0

For J=1 To NBTABLE
#JOJAC - 2016-04-04 - REQ114309 US83 - START
 # FQ112187 - 02/11/15 - Test sur l'ébréviation directement
# If evalue("clalev([F:"+right$(GTABLES(J,1),6)+"])")=0
 If evalue("clalev([F:"+GTABLES(J,3)+"])")=0
#JOJAC - 2016-04-04 - REQ114309 US83 - END
   Local File =GTABLES(J,1)
 Endif
Next J

Local Char    CRITEREDAT (250)
CRITEREDAT = '[F:HRCTR]CTRDAT<=['+format$(GFMD,[M:DIA]DATFIN)+'] & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=['+format$(GFMD,[M:DIA]DATDEB)+'])'

#78892
Call FILTREROLE("EML",CRITEREDAT) From SUBEML
Call FILTREROLE("CTR",CRITEREDAT) From SUBEML

If [M:DIA]POP<>""
#86255 : [DBA] impact population déjà mis en place mais pourquoi avec un ~ ici ?!?
#Link [HRCTR] With
#&   [ID]ID0   = [F:HRCTR]REFNUM
#& , [FCY]FCY0 = [F:HRCTR]ETRFCY
#& , [HRPOA]POA0 ~= [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
#&   As [LNK]
#&   Where evalue(CRITEREDAT) & [F:HRPOA]REFNUM<>""
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [HRPOA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&   As [LNK]
&   Where evalue(CRITEREDAT) & [F:HRPOA]REFNUM<>""
Else
 Link [HRCTR] With
&  [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
&   As [LNK]
&   Where evalue(CRITEREDAT)
Endif

If dim([M:DIA]LEG)>0 & [M:DIA]LEG<>""
  CRITERELEG="[F:FCY]LEG=[M:DIA]LEG"
Else
  CRITERELEG="1=1"
Endif

If [M:DIA]CPY<>""
 CRITERECPY="[F:FCY]LEGCPY=[M:DIA]CPY"
Else
 CRITERECPY="1=1"
Endif

If [M:DIA]FCY<>""
 CRITEREFCY="[F:HRCTR]ETRFCY=[M:DIA]FCY"
Else
 CRITEREFCY="1=1"
Endif

If [M:DIA]SRV<>""
 CRITERESRV="[F:HRCTR]ETRSRV=[M:DIA]SRV"
Else
 CRITERESRV="1=1"
Endif

If [M:DIA]PRF<>""
 CRITEREPRF="[F:HRCTR]PROPRF=[M:DIA]PRF"
Else
 CRITEREPRF="1=1"
Endif

#SEGAY 25/09/12 84268 US 805
If [M:DIA]ALLPOT<>2
 CRITEREPOT="[F:HRCTR]POT=[M:DIA]POT"
Else
 CRITEREPOT="1=1"
Endif

If [M:DIA]ALLJOBPOT<>2
 CRITEREJOBPOT="[F:HRCTR]JOBPOT=[M:DIA]JOBPOT"
Else
 CRITEREJOBPOT="1=1"
Endif
#END SEGAY 25/09/12 84268 US 805

If [M:DIA]MATDEB<>""
 CRITEREDEB='[F:HRCTR]REFNUM>="'+[M:DIA]MATDEB+'"'
Else
 CRITEREDEB="1=1"
Endif

If [M:DIA]MATFIN<>""
 CRITEREFIN="[F:HRCTR]REFNUM<=[M:DIA]MATFIN"
Else
 CRITEREFIN="1=1"
Endif

If [M:DIA]CRITERE<>""
 CRITERELIBRE=[M:DIA]CRITERE
Else
 CRITERELIBRE="1=1"
Endif

Local Integer MAXFRM
## MAXFRM = 100
MAXFRM = 500 ##78392
Local Integer NBFRM
Local Integer FRM(1..MAXFRM) , TYPFRM(1..MAXFRM), FRMIND(1..MAXFRM)
Local Char    FORMULE(250) , EXPRESS(250)
Local Char    OPE(2) , CODE(20)
Local Char    OPELNG(3)
Local Integer NRUB , NCUM , NVAR , NPAT , NTPS , NSYN , NCAL , NFIL
Local Integer NTRA, NTRB, NTRC, NBAS, NTAX, NPTX
#Tax band
Local Integer NTRD, NTRE, NTRF, NTRG, NTRH, NTRI
Local Decimal RU(1..MAXFRM) , CU(1..MAXFRM) , VA(1..MAXFRM) , PA(1..MAXFRM)
Local Decimal TS(1..MAXFRM) , TP(1..MAXFRM)
Local Decimal TRAAMT(1..MAXFRM), TRBAMT(1..MAXFRM), TRCAMT(1..MAXFRM), BASAMT(1..MAXFRM), TAXAMT(1..MAXFRM), PTXAMT(1..MAXFRM)
#Tax band
Local Decimal TRDAMT(1..MAXFRM), TREAMT(1..MAXFRM), TRFAMT(1..MAXFRM),TRGAMT(1..MAXFRM), TRHAMT(1..MAXFRM), TRIAMT(1..MAXFRM)

#67822
If GPAYE
 Local Char    CRUB(GLONRUB)(1..MAXFRM) , CCUM(GLONCUM)(1..MAXFRM) , CVAR(GLONVRA)(1..MAXFRM) , CPAT(10)(1..MAXFRM)
 Local Char CTRA(GLONRUB)(1..MAXFRM), CTRB(GLONRUB)(1..MAXFRM), CTRC(GLONRUB)(1..MAXFRM)
 Local Char CBAS(GLONRUB)(1..MAXFRM), CTAX(GLONRUB)(1..MAXFRM), CPTX(GLONRUB)(1..MAXFRM)
 #Tax Band
 Local Char CTRD(GLONRUB)(1..MAXFRM), CTRE(GLONRUB)(1..MAXFRM), CTRF(GLONRUB)(1..MAXFRM)
 Local Char CTRG(GLONRUB)(1..MAXFRM), CTRH(GLONRUB)(1..MAXFRM), CTRI(GLONRUB)(1..MAXFRM)
Else
 Local Char    CRUB(10)(1..MAXFRM) , CCUM(10)(1..MAXFRM) , CVAR(10)(1..MAXFRM) , CPAT(10)(1..MAXFRM)
 Local Char CTRA(10)(1..MAXFRM), CTRB(10)(1..MAXFRM), CTRC(10)(1..MAXFRM), CBAS(10)(1..MAXFRM), CTAX(10)(1..MAXFRM), CPTX(10)(1..MAXFRM)
 #Tax Band
 Local Char CTRD(10)(1..MAXFRM), CTRE(10)(1..MAXFRM), CTRF(10)(1..MAXFRM)
 Local Char CTRG(10)(1..MAXFRM), CTRH(10)(1..MAXFRM), CTRI(10)(1..MAXFRM)
Endif

Local Char    FORMU(250)(1..MAXFRM)
Local Decimal RATIO
Local Integer NBNUM
Local Char    CHPNUM(10)(1..MAXFRM) , LIBNUM(30)(1..MAXFRM)
Local Decimal TOTAL(1..MAXFRM) , MINI(1..MAXFRM) , MAXI(1..MAXFRM) , VALCUR
Local Char    FILT(250)(1..dim([F:HRSMH]FILTRE))
Local Char OLDMAT(GLONEML)

##78562
Local Integer IUNIQ

# Var used to contain Field Name plus Index
Local Char FLDNAMIND (250)
Raz [M:GEN]
For J=1 To [M:DIB]BPAG
 If toupper([M:DIB]CODZONE(J-1))=toupper(mess(59,10709,1))
  NBFRM += 1
  FRM(NBFRM)    = J
  TYPFRM(NBFRM) = [M:DIB]TYPFRM(J-1)
 Endif
Next J
Gosub INI_HISPAY
If GERR : Return : Endif

Local Integer COLLOOP
Local Integer DICIND
Local Integer FIELD_DIMENSION

For [LNK]CTR0 (2) Where evalue(CRITERELEG) & evalue(CRITERECPY) & evalue(CRITEREFCY)
& & evalue(CRITERESRV) & evalue(CRITEREPRF)
& & evalue(CRITEREPOT) & evalue(CRITEREJOBPOT)
& & evalue(CRITEREDEB) & evalue(CRITEREFIN) & [F:ID]ENAFLG=2
 OK = 1
 If [F:HRSMH]FLGMAT=2
  If OLDMAT=[F:ID]REFNUM
   OK = 0
  Else
   OLDMAT = [F:ID]REFNUM
  Endif
 Endif
 If OK
  For [LNK]CTR0
   #67916
   #Si date contrat>datesyst, [F:HRCTR] est raz par le LECEMP From WPDEFTABLE du Call CONTROLE ci-dessous
   Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,CRITERELIBRE,OK,1) From DIVPAYE
   If OK
    nolign += 1
    # GTABLES contient les tables saisis dans les écrans employés, pas forcément EMPLOID et EMPLOCTR => Il faut charger [M:GEN]
    [M:GEN] = [F:ID]
    [M:GEN] = [F:HRCTR]
    MATRI = [F:ID]REFNUM
    CTR   = [F:HRCTR]CTRNUM
    DATMAT= [F:HRCTR]CTRDAT
    [M:GEN]WCTRDAT(nolign-1) = num$([F:HRCTR]CTRDAT)
    DATDEB=max([F:HRCTR]CTRDAT,[M:DIA]DATDEB)
    #70189 ajout du min()
    If [F:HRCTR]XITDAT<>[0/0/0] : DATFIN=min([F:HRCTR]XITDAT,[M:DIA]DATFIN)  : Else : DATFIN=[M:DIA]DATFIN  : Endif
    For J=1 To NBTABLE
     TABLE = GTABLES(J,1) : Gosub DEFAUT From WPDEFTABLE
     Case TABLE
      When "EMPLOID","EMPLOCTR"
       [M:GEN] = [F]
       #88174-US2305
       If dim ([M:GEN]FLGBULDEM)>0
        [M:GEN]VALORI(nolign-1)=[M:GEN]FLGBULDEM(nolign-1)
       Endif
       # FQ81085 - 17/12/13 - Récupération de la situation familiale et civilité selon menu local
       If TABLE="EMPLOID" Then
         Local    Char    NUMLIB(10)
         If dim([M:GEN]CIVA)>0 & [F:ID]CIV>0 Then
          Call PARAM([F:ID]FCYORI,"CIVIL",NUMLIB) From ADOVAL
          [M:GEN]CIVA(nolign-1)=mess([F:ID]CIV,val(NUMLIB),1)
         Endif
         If dim([M:GEN]SITFAMA)>0 & [F:ID]SITFAM>0 Then
          Call PARAM([F:ID]FCYORI,"SITFAM",NUMLIB) From ADOVAL
          [M:GEN]SITFAMA(nolign-1)=mess([F:ID]SITFAM,val(NUMLIB),1)
         Endif
         If [M:DIA]MYLEG="FRA" & [F:ID]SITFAM=1 Then
            If dim([M:GEN]JNTNAM)>0     Then Effzo [M:GEN]JNTNAM(nolign-1)     : Grizo [M:GEN]JNTNAM(nolign-1)     : Endif
            If dim([M:GEN]JNTREFNUM)>0  Then Effzo [M:GEN]JNTREFNUM(nolign-1)  : Grizo [M:GEN]JNTREFNUM(nolign-1)  : Endif
            If dim([M:GEN]JNTTEL)>0     Then Effzo [M:GEN]JNTTEL(nolign-1)     : Grizo [M:GEN]JNTTEL(nolign-1)     : Endif
         Else
          If dim([M:GEN]JNTNAM)>0     Then Actzo [M:GEN]JNTNAM(nolign-1)    : Endif
          If dim([M:GEN]JNTREFNUM)>0  Then Actzo [M:GEN]JNTREFNUM(nolign-1) : Endif
          If dim([M:GEN]JNTTEL)>0     Then Actzo [M:GEN]JNTTEL(nolign-1)    : Endif
         Endif
       Endif
       # FQ81085 - 17/12/13 - Récupération de la situation familiale et civilité selon menu local
       If TABLE="EMPLOCTR" Then
         Local    Char    NUMLIB(10)
         If dim([M:GEN]CIVCTRA)>0 & [F:HRCTR]CIVCTR>0 Then
          Call PARAM([F:HRCTR]ETRFCY,"CIVIL",NUMLIB) From ADOVAL
          [M:GEN]CIVCTRA(nolign-1)=mess([F:HRCTR]CIVCTR,val(NUMLIB),1)
         Endif
       Endif
       # Fin FQ81085
      When Default
       # Special processing child records of employees
       If func IS_EMP_CHILD_TABLE(TABLE) = 1
          Gosub POSE_FILTRE
          For COLLOOP=1 To [M:DIB]BPAG
            If [M:DIB]CODFIC(COLLOOP-1) = TABLE
              FLDNAMIND = "[M:GEN]" + [M:DIB]CODZONE(COLLOOP-1) + "_" + num$([M:DIB]IND(COLLOOP-1)) + "(" + num$(nolign-1) + ")"
              For [F] Where NUMLIG = [M:DIB]IND(COLLOOP-1)
                # Construct name of field eg CHLDNAM_1 = child name 1
                Assign FLDNAMIND With evalue("[F]" + [M:DIB]CODZONE(COLLOOP-1))
              Next
            Endif
          Next COLLOOP
       Endif
       [G]currind = 1
       Gosub POSE_FILTRE
       Read Last
       If fstat<=2
        [M:GEN] = [F]
       Endif
       Filter [F]
     Endcase
     ###dimension fields
     For COLLOOP=1 To [M:DIB]BPAG
       If [M:DIB]CODFIC(COLLOOP-1) = TABLE
         FIELD_DIMENSION = func EMP_FIELD_DIMENSION([M:DIB]CODFIC(COLLOOP-1), [M:DIB]CODZONE(COLLOOP-1))
         If FIELD_DIMENSION > 1
           FLDNAMIND = "[M:GEN]" + [M:DIB]CODZONE(COLLOOP-1) + "_" + num$([M:DIB]IND(COLLOOP-1)) + "(" + num$(nolign-1) + ")"
           If [M:DIB]IND(COLLOOP-1) > 0
             Assign FLDNAMIND With evalue("[F]" + [M:DIB]CODZONE(COLLOOP-1) + "(" + num$([M:DIB]IND(COLLOOP-1) -1) + ")")
           Else
             Assign FLDNAMIND With evalue("[F]" + [M:DIB]CODZONE(COLLOOP-1) + "(" + num$(FIELD_DIMENSION -1) + ")")
           Endif
         Endif
       Endif
     Next COLLOOP
     [M:GEN]FLG(nolign-1)=0
    Next J
    F = 0
    For J=1 To NBFRM
     If TYPFRM(J)=1
      Onerrgo RIEN
      Assign "[M:GEN]F0"+num$(J)+"("+num$(nolign-1)+")" With evalue([M:DIB]EXPR(FRM(J)-1))
      If GERR : Break 2 : Endif
      Onerrgo
     Endif
    Next J
    Gosub HISPAY
    #LIPET - 2017-05-20 - START
    #** V7 : Waiting Time Mangement **#
    #**Gosub HISTPS
    #**Gosub HISSYN
    #**
    #*!
    Gosub HISTPS
    Gosub HISSYN
    #LIPET - 2017-05-20 - END
    Gosub CALCUL
    OK = 1
    For J=1 To NFIL
     If FILT(J)<>""
      Onerrgo RIEN
      OK = evalue(FILT(J))
      Onerrgo
      If !OK : Break : Endif
     Endif
    Next J
    If !OK
     nolign -= 1
    Endif
    If [F:HRSMH]FLGMAT=2 : Break : Endif  :#1 ligne par matricule car pas d'infos contrat à afficher
   Endif
  Next
 Endif
Next
If GERR : Return : Endif
[M:GEN]BPAG2 = nolign
If [F:HRSMH]FLGMAT=2
 Chgfmt [M:GEN]CTRNUM With "-K:20X"
 Chgfmt [M:GEN]WCTRDAT With "-K:10X"
Endif
Affzo [GEN]
Affzo [DIB]:#MABOS-04/03/13-FQ81085-US1335-Add a trace
Gosub STAT
Return

##################################
$POSE_FILTRE
If TABLE="EMPLOEXM"
 Filter [F] Where REFNUM=[F:HRCTR]REFNUM & DATEXM<=DATFIN
Elsif TABLE="EMPLOEXN"
 Filter [F] Where REFNUM=[F:HRCTR]REFNUM & EXSDAT<=DATFIN
Elsif TABLE="EMPLOPAR"
 Filter [F] Where REFNUM=[F:HRCTR]REFNUM & PARDAT<=DATFIN
Elsif TABLE="EMPLOTRY"
 Filter [F] Where REFNUM=[F:HRCTR]REFNUM & STRDATTRY<=DATFIN & ENDDATTRY>=DATDEB
Elsif TABLE="EMPLOPOT"
 Filter [F] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & DATPOT<=DATFIN
Elsif TABLE="EMPLOSAL"
 #Evolution de salaire en fin de période
 Filter [F] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM &  SALDAT<=DATFIN
Elsif TABLE="EMPLOMED"
 Filter [F] Where REFNUM=[F:HRCTR]REFNUM & (CTRNUM=[F:HRCTR]CTRNUM | CTRNUM="") & MEDDAT<=DATFIN
#68246 : le dim de suffit par car dbgstr(2) ne peut pas être vidé
#Elsif dim([F]CTRNUM)>0
Else
 Look [ATZ]CODZONE = TABLE;"CTRNUM"
 If !fstat
  Filter [F] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM
 Else
  Filter [F] Where REFNUM=[F:HRCTR]REFNUM
 Endif
Endif
Return

##################################
$INI_HISPAY
Raz NRUB,NCUM,NVAR,NPAT,NTPS,NSYN,NCAL
Raz NTRA, NTRB, NTRC, NBAS, NTAX, NPTX
#Tax band
Raz NTRD, NTRE, NTRF,NTRG, NTRH, NTRI
For K=1 To NBFRM
 Case TYPFRM(K)
  When 2
   FORMULE = vireblc(format$("KT:250X",[M:DIB]EXPR(FRM(K)-1)),2)
   I = 1
   EXPRESS = ""
   While I<=len(FORMULE)
    OPE = mid$(FORMULE,I,2)
    OPELNG = mid$(FORMULE,I,3)
    If find(OPE,"R_","V_","C_")
     J = I+2 : I += 2
     While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
      I += 1
     Wend
     CODE = seg$(FORMULE,J,I)
     #76200
     If [M:DIC]FLGFRM(FRM(K)-1)<>2
      If OPE="F0" #a formula
       If CODE=num$(val(CODE))
        J = val(CODE)
        If toupper([M:DIB]CODZONE(J-1))=toupper(mess(59,10709,1))
         J = find(J,FRM(1..NBFRM))
         If J=0 : EXPRESS = "0" : Break : Endif
         If len(EXPRESS)+19+len(num$(J))>250
          # L'évaluation de la formule dépasse les 250 caractères
          GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
         Else
          EXPRESS += "[M:GEN]F0"+num$(J)+"(nolign-1)"
         Endif
        Elsif J>0 & J<[M:DIB]BPAG
         If len(EXPRESS)+17+len([M:DIB]CODZONE(J-1))>250
          # L'évaluation de la formule dépasse les 250 caractères
          GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
         Else
           If [M:DIB]IND(J-1) > 0 #if there is an index, put _INDEX at the end
            EXPRESS += "[M:GEN]"+[M:DIB]CODZONE(J-1)+ "_" + num$([M:DIB]IND(J-1)) + "(nolign-1)"
           Else
             FIELD_DIMENSION = func EMP_FIELD_DIMENSION([M:DIB]CODFIC(J-1), [M:DIB]CODZONE(J-1))
             If FIELD_DIMENSION > 1
               EXPRESS += "[M:GEN]"+[M:DIB]CODZONE(J-1)+"_0(nolign-1)"
             Else
               EXPRESS += "[M:GEN]"+[M:DIB]CODZONE(J-1)+"(nolign-1)"
             Endif
           Endif
         Endif
        Else
         EXPRESS = "0" : Break
        Endif
       Else
        EXPRESS = "0" : Break
       Endif
      Endif
     Endif

     If OPE="R_"
      If mid$(FORMULE,I+1,3)="(1)" #Employee amount
       I += 3
      Elsif mid$(FORMULE,I+1,3)="(2)" #Employer amount
       OPE = "P_" : I += 3
      Elsif mid$(FORMULE,I+1,3)="(3)" #Employee rate
       OPE = "X_" : I += 3
      Elsif mid$(FORMULE,I+1,3)="(4)" #Employer rate
       OPE = "Y_" : I += 3
      Elsif mid$(FORMULE,I+1,3)="(0)" #Base
       OPE = "B_" : I += 3
      Endif
     Endif
     Case OPE
      When "R_"
       If len(EXPRESS)+4+len(num$(NRUB))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        ##78562
        IUNIQ= find(CODE,CRUB(1..MAXFRM))
        If !IUNIQ | [M:DIC]FLGFRM(FRM(K)-1)<>2
          NRUB += 1
          If [M:DIC]FLGFRM(FRM(K)-1)=2 : CRUB(NRUB) = CODE : Endif
          EXPRESS += "RU("+num$(NRUB)+")"
          FRMIND(FRM(K)) = NRUB
        Else
          EXPRESS += "RU("+num$(IUNIQ)+")"
          FRMIND(FRM(K)) = IUNIQ
        Endif
       Endif
      When "P_"
       If len(EXPRESS)+4+len(num$(NPAT))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        ##78562
        IUNIQ= find(CODE,CPAT(1..MAXFRM))
        If !IUNIQ | [M:DIC]FLGFRM(FRM(K)-1)<>2
         NPAT += 1
         If [M:DIC]FLGFRM(FRM(K)-1)=2 : CPAT(NPAT) = CODE : Endif
         EXPRESS += "PA("+num$(NPAT)+")"
         FRMIND(FRM(K)) = NPAT
        Else
         EXPRESS += "PA("+num$(IUNIQ)+")"
         FRMIND(FRM(K)) = IUNIQ
        Endif
      Endif
      When "X_"
       If len(EXPRESS)+4+len(num$(NTAX))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        ##78562
        IUNIQ= find(CODE,CTAX(1..MAXFRM))
        If !IUNIQ | [M:DIC]FLGFRM(FRM(K)-1)<>2
         NTAX += 1
         If [M:DIC]FLGFRM(FRM(K)-1)=2 : CTAX(NTAX) = CODE  : Endif
         EXPRESS += "TAXAMT("+num$(NTAX)+")"
         FRMIND(FRM(K)) = NTAX
        Else
         EXPRESS += "TAXAMT("+num$(IUNIQ)+")"
         FRMIND(FRM(K)) = IUNIQ
        Endif
       Endif
      When "Y_"
       If len(EXPRESS)+4+len(num$(NPTX))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
       ##78562
        IUNIQ= find(CODE,CPTX(1..MAXFRM))
        If !IUNIQ | [M:DIC]FLGFRM(FRM(K)-1)<>2
         NPTX += 1
         If [M:DIC]FLGFRM(FRM(K)-1)=2 : CPTX(NPTX) = CODE : Endif
         EXPRESS += "PTXAMT("+num$(NPTX)+")"
         FRMIND(FRM(K)) = NPTX
        Else
         EXPRESS += "PTXAMT("+num$(IUNIQ)+")"
         FRMIND(FRM(K)) = IUNIQ
        Endif
       Endif
      When "B_"
       If len(EXPRESS)+4+len(num$(NBAS))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
       ##78562
        IUNIQ= find(CODE,CBAS(1..MAXFRM))
        If !IUNIQ | [M:DIC]FLGFRM(FRM(K)-1)<>2
         NBAS += 1
         If [M:DIC]FLGFRM(FRM(K)-1)=2 : CBAS(NBAS) = CODE : Endif
         EXPRESS += "BASAMT("+num$(NBAS)+")"
         FRMIND(FRM(K)) = NBAS
        Else
         EXPRESS += "BASAMT("+num$(IUNIQ)+")"
         FRMIND(FRM(K)) = IUNIQ
        Endif
       Endif
      When "C_"
       If len(EXPRESS)+4+len(num$(NCUM))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
       ##78562
        IUNIQ= find(CODE,CCUM(1..MAXFRM))
        If !IUNIQ | [M:DIC]FLGFRM(FRM(K)-1)<>2
         NCUM += 1
         If [M:DIC]FLGFRM(FRM(K)-1)=2 : CCUM(NCUM) = CODE : Endif
         EXPRESS += "CU("+num$(NCUM)+")"
         FRMIND(FRM(K)) = NCUM
        Else
         EXPRESS += "CU("+num$(IUNIQ)+")"
         FRMIND(FRM(K)) = IUNIQ
        Endif
       Endif
      When "V_"
       If len(EXPRESS)+4+len(num$(NVAR))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
       ##78562
        IUNIQ= find(CODE,CVAR(1..MAXFRM))
        If !IUNIQ | [M:DIC]FLGFRM(FRM(K)-1)<>2
         NVAR += 1
         If [M:DIC]FLGFRM(FRM(K)-1)=2 : CVAR(NVAR) = CODE : Endif
         EXPRESS += "VA("+num$(NVAR)+")"
         FRMIND(FRM(K)) = NVAR
        Else
         EXPRESS += "VA("+num$(IUNIQ)+")"
         FRMIND(FRM(K)) = IUNIQ
        Endif
       Endif
     Endcase
    Elsif find(OPELNG, "TA_", "TB_", "TC_", "TD_", "TE_", "TF_", "TG_", "TH_", "TI_")
     J = I+3 : I += 3
     While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
      I += 1
     Wend
     CODE = seg$(FORMULE,J,I)
     Case OPELNG
      When "TA_"
       If len(EXPRESS)+4+len(num$(NTRA))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        NTRA += 1 : CTRA(NTRA) = CODE : EXPRESS += "TRAAMT("+num$(NTRA)+")"
        FRMIND(FRM(K)) = NTRA
       Endif
      When "TB_"
       If len(EXPRESS)+4+len(num$(NTRB))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        NTRB += 1 : CTRB(NTRB) = CODE : EXPRESS += "TRBAMT("+num$(NTRB)+")"
        FRMIND(FRM(K)) = NTRB
       Endif
      When "TC_"
       If len(EXPRESS)+4+len(num$(NTRC))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        NTRC += 1 : CTRC(NTRC) = CODE : EXPRESS += "TRCAMT("+num$(NTRC)+")"
        FRMIND(FRM(K)) = NTRC
       Endif
      When "TD_"
       If len(EXPRESS)+4+len(num$(NTRD))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        NTRD += 1 : CTRD(NTRD) = CODE : EXPRESS += "TRDAMT("+num$(NTRD)+")"
        FRMIND(FRM(K)) = NTRD
       Endif
      When "TE_"
       If len(EXPRESS)+4+len(num$(NTRE))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        NTRE += 1 : CTRE(NTRE) = CODE : EXPRESS += "TREAMT("+num$(NTRE)+")"
        FRMIND(FRM(K)) = NTRE
       Endif
      When "TF_"
       If len(EXPRESS)+4+len(num$(NTRF))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        NTRF += 1 : CTRF(NTRF) = CODE : EXPRESS += "TRFAMT("+num$(NTRF)+")"
        FRMIND(FRM(K)) = NTRF
       Endif
      When "TG_"
       If len(EXPRESS)+4+len(num$(NTRG))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        NTRG += 1 : CTRG(NTRG) = CODE : EXPRESS += "TRGAMT("+num$(NTRG)+")"
        FRMIND(FRM(K)) = NTRG
       Endif
      When "TH_"
       If len(EXPRESS)+4+len(num$(NTRH))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        NTRH += 1 : CTRH(NTRH) = CODE : EXPRESS += "TRHAMT("+num$(NTRH)+")"
        FRMIND(FRM(K)) = NTRH
       Endif
      When "TI_"
       If len(EXPRESS)+4+len(num$(NTRI))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        NTRI += 1 : CTRI(NTRI) = CODE : EXPRESS += "TRIAMT("+num$(NTRI)+")"
        FRMIND(FRM(K)) = NTRI
       Endif
     Endcase
    Else
     If len(EXPRESS)+1>250
      # L'évaluation de la formule dépasse les 250 caractères
      GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
     Else
      EXPRESS += mid$(FORMULE,I,1)
     Endif
    Endif
    I += 1
   Wend
   FORMU(K)  = EXPRESS
  When 3
   NTPS += 1
  When 4
   NSYN += 1
  When 5
   NCAL += 1
   FORMULE = vireblc(format$("KT:250X",[M:DIB]EXPR(FRM(K)-1)),2)
   I = 1
   EXPRESS = ""
   While I<=len(FORMULE)
    OPE = mid$(FORMULE,I,2)
    If OPE="F0"
     J = I+2 : I += 2
     While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
      I += 1
     Wend
     CODE = seg$(FORMULE,J,I)
     If CODE=num$(val(CODE))
      J = val(CODE)
      If toupper([M:DIB]CODZONE(J-1))=toupper(mess(59,10709,1))
       J = find(J,FRM(1..NBFRM))
       If J=0 : EXPRESS = "0" : Break : Endif
       If len(EXPRESS)+19+len(num$(J))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
        EXPRESS += "[M:GEN]F0"+num$(J)+"(nolign-1)"
       Endif
      Elsif J>0 & J<[M:DIB]BPAG
       If len(EXPRESS)+17+len([M:DIB]CODZONE(J-1))>250
        # L'évaluation de la formule dépasse les 250 caractères
        GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
       Else
         If [M:DIB]IND(J-1) > 0 #if there is an index, put _INDEX at the end
          EXPRESS += "[M:GEN]"+[M:DIB]CODZONE(J-1)+ "_" + num$([M:DIB]IND(J-1)) + "(nolign-1)"
         Else
           FIELD_DIMENSION = func EMP_FIELD_DIMENSION([M:DIB]CODFIC(J-1), [M:DIB]CODZONE(J-1))
           If FIELD_DIMENSION > 1
             EXPRESS += "[M:GEN]"+[M:DIB]CODZONE(J-1)+"_0(nolign-1)"
           Else
             EXPRESS += "[M:GEN]"+[M:DIB]CODZONE(J-1)+"(nolign-1)"
           Endif
         Endif
       Endif
      Else
       EXPRESS = "0" : Break
      Endif
     Else
      EXPRESS = "0" : Break
     Endif
    Else
     If len(EXPRESS)+1>250
      # L'évaluation de la formule dépasse les 250 caractères
      GERR = 1 : GMESSAGE = mess(109,10702,1)-":"-FORMULE : Break
     Else
      EXPRESS += mid$(FORMULE,I,1)
     Endif
    Endif
    I += 1
   Wend
   FORMU(K)  = EXPRESS
 Endcase
Next K
NFIL = [F:HRSMH]NBRFIL
For K=1 To NFIL
 FORMULE = vireblc(format$("KT:250X",[F:HRSMH]FILTRE(K-1)),2)
 I = 1
 EXPRESS = ""
 While I<=len(FORMULE)
  OPE = mid$(FORMULE,I,2)
  If OPE="F0"
   J = I+2 : I += 2
   While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
    I += 1
   Wend
   CODE = seg$(FORMULE,J,I)
   If CODE=num$(val(CODE))
    J = val(CODE)
    If toupper([M:DIB]CODZONE(J-1))=toupper(mess(59,10709,1))
     J = find(J,FRM(1..NBFRM))
     If J=0 : EXPRESS = "0" : Break : Endif
     If len(EXPRESS)+19+len(num$(J))>250
      # L'évaluation de la formule dépasse les 250 caractères
      GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
     Else
      EXPRESS += "[M:GEN]F0"+num$(J)+"(nolign-1)"
     Endif
    Elsif J>0 & J<[M:DIB]BPAG
     If len(EXPRESS)+17+len([M:DIB]CODZONE(J-1))>250
      # L'évaluation de la formule dépasse les 250 caractères
      GERR = 1 : GMESSAGE =  mess(109,10702,1)-":"-FORMULE : Break
     Else
      EXPRESS += "[M:GEN]"+[M:DIB]CODZONE(J-1)+"(nolign-1)"
     Endif
    Else
     EXPRESS = "0" : Break
    Endif
   Else
    EXPRESS = "0" : Break
   Endif
  Else
   If len(EXPRESS)+1>250
    # L'évaluation de la formule dépasse les 250 caractères
    GERR = 1 : GMESSAGE = mess(109,10702,1)-":"-FORMULE : Break
   Else
    EXPRESS += mid$(FORMULE,I,1)
   Endif
  Endif
  I += 1
 Wend
 FILT(K)  = EXPRESS
Next K
Return

############################
$HISPAY
If !GPAYE : Return : Endif
Raz RU,CU,VA,PA
Raz TRAAMT, TRBAMT, TRCAMT, BASAMT, TAXAMT, PTXAMT
#Tax Band
Raz TRDAMT, TREAMT, TRFAMT, TRGAMT, TRHAMT, TRIAMT

For DICIND = 0 To (dim([M:DIC]TOTTYP) - 1)
 #76200
 If [M:DIC]FLGFRM(DICIND)<>2    :#not a check formula
  If [M:DIC]TOTTYPCOD(DICIND) <> ""
    K = FRMIND(DICIND+1)
    Case [M:DIC]TOTTYP(DICIND)
      When 1 #Rubrique
        Case [M:DIC]TOTTYPELM(DICIND)
          When 1 # Employee value
           If NRUB
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END

             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=1 |TYP=7)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CRUB(1..NRUB))
              If K
               RU(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 2 # Employer Value
           If NPAT
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=2 |TYP=8)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CPAT(1..NPAT))
              If K
               PA(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 3 # Bracket A
           If NTRA
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=3)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CTRA(1..NTRA))
              If K
               TRAAMT(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 4 # Bracket B
           If NTRB
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=4)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CTRB(1..NTRB))
              If K
               TRBAMT(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 5 # Bracket C
           If NTRC
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=5)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CTRC(1..NTRC))
              If K
               TRCAMT(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 10 # Base
           Local Char OLD_RUB (250)
           Local Char NEW_RUB (250)
           If NBAS
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             Raz OLD_RUB, NEW_RUB
             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=1 |TYP=7 |TYP=2 |TYP=8) & AMT <> 0
             For [HSP]
              NEW_RUB = [HSP]RUB
              If K and OLD_RUB <> NEW_RUB
                BASAMT(K) += [F:HSP]BAS
              Endif
              OLD_RUB = [HSP]RUB
             Next
             Filter [HSP]
            Next
           Endif
          When 11 # Employee Rate
           If NTAX
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=1 |TYP=7)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CTAX(1..NTAX))
              If K
               TAXAMT(K) = [F:HSP]RAT #don't accumulate a rate!
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 12 # Employer Rate
           If NPTX
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=2 |TYP=8)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CPTX(1..NPTX))
              If K
               PTXAMT(K) = [F:HSP]RAT #don't accumulate a rate!
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          #Tax Band
          When 13 # Bracket D
           If NTRD
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=10)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CTRD(1..NTRD))
              If K
               TRDAMT(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 14 # Bracket E
           If NTRE
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=11)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CTRE(1..NTRE))
              If K
               TREAMT(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 15 # Bracket F
           If NTRF
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
            Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=12)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CTRF(1..NTRF))
              If K
               TRFAMT(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 16 # Bracket G
           If NTRG
#JOJAC - 2016-05-16 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END

            Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=13)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CTRG(1..NTRG))
              If K
                TRGAMT(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 17 # Bracket H
           If NTRH
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
           Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=14)
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CTRH(1..NTRH))
              If K
               TRHAMT(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
           Endif
          When 18 # Bracket I
           If NTRI
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
             Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & (TYP=15)
             For [HSP]HSP0
             #K = find([F:HSP]RUB,CTRI(1..NTRI))
              If K
               TRIAMT(K) += [F:HSP]AMT
              Endif
             Next
             Filter [HSP]
            Next
          Endif
        Endcase
      When 6 #Cumulator
       If NCUM
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END
         Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & RUB=[M:DIC]TOTTYPCOD(DICIND) & TYP=6
         For [HSP]HSP0
         #K = find([F:HSP]RUB,CCUM(1..NCUM))
          If K
           CU(K) += [F:HSP]AMT
          Endif
         Next
         Filter [HSP]
        Next
       Endif
      When 7 #Variable
       If NVAR
#JOJAC - 2016-04-04 - REQ114309 US83 - START
#            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
#&                           & CTRDAT=DATMAT    :#85478
            For [VEP] Where EMP=MATRI & STRDAT>=[M:DIC]PRDFRM(DICIND) & ENDDAT<=[M:DIC]PRDUTL(DICIND) & CTRNUM=CTR & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] & RVS <> 2
&                           & CTRDAT=DATMAT    :#85478
#JOJAC - 2016-04-04 - REQ114309 US83 - END

         Filter [VLA] Where TYP=4 & CPY="" & FCY="" & EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & VARCOD=[M:DIC]TOTTYPCOD(DICIND)
         For [VLA]VLA0
         #K = find([F:VLA]VARCOD,CVAR(1..NVAR))
          If K
           VA(K) += [F:VLA]VARVAL
          Endif
         Next
         Filter [VLA]
        Next
       Endif
      Endcase
   Endif
  Endif
Next DICIND

#old processing for calculation fields
For [VEP] Where EMP=MATRI & STRDAT>=DATDEB & ENDDAT<=DATFIN & CTRNUM=CTR & RVSDAT=[0/0/0] & RVS<>2
&             & CTRDAT=DATMAT    :#85478
 If NRUB
  Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & (TYP=1 |TYP=7)
  For [HSP]HSP0
   K = find([F:HSP]RUB,CRUB(1..NRUB))
   If K
    RU(K) += [F:HSP]AMT
   Endif
  Next
  Filter [HSP]
 Endif
 If NPAT
  Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & (TYP=2 |TYP=8)
   For [HSP]HSP0
   K = find([F:HSP]RUB,CPAT(1..NPAT))
   If K
    PA(K) += [F:HSP]AMT
   Endif
  Next
  Filter [HSP]
 Endif
 If NCUM
  Filter [HSP] Where EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & TYP=6
  For [HSP]HSP0
   K = find([F:HSP]RUB,CCUM(1..NCUM))
   If K
    CU(K) += [F:HSP]AMT
   Endif
  Next
  Filter [HSP]
 Endif
 If NVAR
  Filter [VLA] Where TYP=4 & CPY="" & FCY="" & EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL
   For [VLA]VLA0
   K = find([F:VLA]VARCOD,CVAR(1..NVAR))
   If K
     VA(K) += [F:VLA]VARVAL
   Endif
  Next
  Filter [VLA]
 Endif
Next VEP

If NRUB or NPAT or NCUM or NVAR or NTRA or NTRB or NTRC or NTAX or NPTX or NBAS or NTRD or NTRE or NTRF or NTRG or NTRH or NTRI
For K=1 To NBFRM
 If TYPFRM(K)=2
   Onerrgo RIEN
   Assign "[M:GEN]F0"+num$(K)+"("+num$(nolign-1)+")" With evalue(FORMU(K))
   If GERR : Break : Endif
   Onerrgo
  Endif
 Next K
Endif
Return

##################################
$HISTPS
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If NTPS
#** Raz TP
#** For DICIND = 0 To dim([M:DIC]TPS1) - 1
#**  If [M:DIC]TPS1(DICIND) <> ""
#**   For [TIP]TIP1 Where REFNUM=MATRI & STRDAT<=[M:DIC]PRDUTL(DICIND) & ENDDAT>=[M:DIC]PRDFRM(DICIND) & CTRNUM=[F:HRCTR]CTRNUM
#**     K = [M:DIC]FRMIND(DICIND)
#**     If TYPFRM(K)=3
#**      If pat([F:TIP]TIM,[M:DIB]TPS1(FRM(K)-1))
#**&      | pat([F:TIP]TIM,[M:DIB]TPS2(FRM(K)-1))
#**&      | pat([F:TIP]TIM,[M:DIB]TPS3(FRM(K)-1))
#**       RATIO = (min([M:DIC]PRDUTL(DICIND),[F:TIP]ENDDAT)-max([M:DIC]PRDFRM(DICIND),[F:TIP]STRDAT)+1)/([F:TIP]ENDDAT-[F:TIP]STRDAT+1)
#**       Case [M:DIB]TYPTPS(FRM(K)-1)
#**        When 1 : TP(K) += [F:TIP]NBRDAY*RATIO
#**        When 2 : TP(K) += [F:TIP]NBRHOU*RATIO
#**        When 3 : If GTPS=1 : TP(K) += [F:TIP]QTY1*RATIO : Endif
#**        When 4 : If GTPS=1 : TP(K) += [F:TIP]QTY2*RATIO : Endif
#**       Endcase
#**      Endif
#**     Endif
#**   Next
#**   If GTPS=1
#**    For [TIG]TIG1 Where REFNUM=MATRI & STRDAT<=[M:DIC]PRDUTL(DICIND) & ENDDAT>=[M:DIC]PRDFRM(DICIND) & CTRNUM=[F:HRCTR]CTRNUM
#**     K = [M:DIC]FRMIND(DICIND)
#**      If TYPFRM(K)=3
#**       RATIO = (min([M:DIC]PRDUTL(DICIND),[F:TIG]ENDDAT)-max([M:DIC]PRDFRM(DICIND),[F:TIG]STRDAT)+1)/([F:TIG]ENDDAT-[F:TIG]STRDAT+1)
#**       If pat([F:TIP]TIM,[M:DIB]TPS1(FRM(K)-1))
#**&       | pat([F:TIP]TIM,[M:DIB]TPS2(FRM(K)-1))
#**&       | pat([F:TIP]TIM,[M:DIB]TPS3(FRM(K)-1))
#**        Case [M:DIB]TYPTPS(FRM(K)-1)
#**         When 1 : TP(K) += [F:TIG]NBRDAY*RATIO
#**         When 2 : TP(K) += [F:TIG]NBRHOU*RATIO
#**         When 3 : TP(K) += [F:TIG]QTY1*RATIO
#**         When 4 : TP(K) += [F:TIG]QTY2*RATIO
#**        Endcase
#**       Endif
#**      Endif
#**    Next
#**   Endif
#**  Endif
#** Next DICIND
#**
#** For K=1 To NBFRM
#**  If TYPFRM(K)=3
#**   Onerrgo RIEN
#**   Assign "[M:GEN]F0"+num$(K)+"("+num$(nolign-1)+")" With TP(K)
#**   If GERR : Break : Endif
#**   Onerrgo
#**  Endif
#** Next K
#**Endif
#**
#*!
If NTPS
 Raz TP
 For DICIND = 0 To dim([M:DIC]TPS1) - 1
  If [M:DIC]TPS1(DICIND) <> ""
   For [TIP]TIP1 Where REFNUM=MATRI & STRDAT<=[M:DIC]PRDUTL(DICIND) & ENDDAT>=[M:DIC]PRDFRM(DICIND) & CTRNUM=[F:HRCTR]CTRNUM
     K = [M:DIC]FRMIND(DICIND)
     If TYPFRM(K)=3
      If pat([F:TIP]TIM,[M:DIB]TPS1(FRM(K)-1))
&      | pat([F:TIP]TIM,[M:DIB]TPS2(FRM(K)-1))
&      | pat([F:TIP]TIM,[M:DIB]TPS3(FRM(K)-1))
       RATIO = (min([M:DIC]PRDUTL(DICIND),[F:TIP]ENDDAT)-max([M:DIC]PRDFRM(DICIND),[F:TIP]STRDAT)+1)/([F:TIP]ENDDAT-[F:TIP]STRDAT+1)
       Case [M:DIB]TYPTPS(FRM(K)-1)
        When 1 : TP(K) += [F:TIP]NBRDAY*RATIO
        When 2 : TP(K) += [F:TIP]NBRHOU*RATIO
        When 3 : If GTPS=1 : TP(K) += [F:TIP]QTY1*RATIO : Endif
        When 4 : If GTPS=1 : TP(K) += [F:TIP]QTY2*RATIO : Endif
       Endcase
      Endif
     Endif
   Next
   If GTPS=1
    For [TIG]TIG1 Where REFNUM=MATRI & STRDAT<=[M:DIC]PRDUTL(DICIND) & ENDDAT>=[M:DIC]PRDFRM(DICIND) & CTRNUM=[F:HRCTR]CTRNUM
     K = [M:DIC]FRMIND(DICIND)
      If TYPFRM(K)=3
       RATIO = (min([M:DIC]PRDUTL(DICIND),[F:TIG]ENDDAT)-max([M:DIC]PRDFRM(DICIND),[F:TIG]STRDAT)+1)/([F:TIG]ENDDAT-[F:TIG]STRDAT+1)
       If pat([F:TIP]TIM,[M:DIB]TPS1(FRM(K)-1))
&       | pat([F:TIP]TIM,[M:DIB]TPS2(FRM(K)-1))
&       | pat([F:TIP]TIM,[M:DIB]TPS3(FRM(K)-1))
        Case [M:DIB]TYPTPS(FRM(K)-1)
         When 1 : TP(K) += [F:TIG]NBRDAY*RATIO
         When 2 : TP(K) += [F:TIG]NBRHOU*RATIO
         When 3 : TP(K) += [F:TIG]QTY1*RATIO
         When 4 : TP(K) += [F:TIG]QTY2*RATIO
        Endcase
       Endif
      Endif
    Next
   Endif
  Endif
 Next DICIND

 For K=1 To NBFRM
  If TYPFRM(K)=3
   Onerrgo RIEN
   Assign "[M:GEN]F0"+num$(K)+"("+num$(nolign-1)+")" With TP(K)
   If GERR : Break : Endif
   Onerrgo
  Endif
 Next K
Endif
#LIPET - 2017-05-20 - END
Return

##################################
$HISSYN
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If NSYN
#** Raz TS
#** For DICIND = 0 To dim([M:DIC]TIMVAR) - 1
#**  If [M:DIC]TIMVAR(DICIND) <> ""
#**   For [TIR]TIR0 Where REFNUM=MATRI & CTRNUM=[F:HRCTR]CTRNUM & PYRDAT<=[M:DIC]PRDUTL(DICIND) & PYRDAT>=[M:DIC]PRDFRM(DICIND)
#**     K = [M:DIC]FRMIND(DICIND)#DICIND + 1
#**     If K <> -1 and TYPFRM(K)=4
#**      TS(K) += evalue("sum([F:TIR]"+[M:DIB]TIMVAR(FRM(K)-1)+")")
#**     Endif
#**   Next
#**  Endif
#** Next DICIND
#** For K=1 To NBFRM
#**  If TYPFRM(K)=4
#**   Onerrgo RIEN
#**   Assign "[M:GEN]F0"+num$(K)+"("+num$(nolign-1)+")" With TS(K)
#**   If GERR : Break : Endif
#**   Onerrgo
#**  Endif
#** Next K
#**Endif
#**
#*!
If NSYN
 Raz TS
 For DICIND = 0 To dim([M:DIC]TIMVAR) - 1
  If [M:DIC]TIMVAR(DICIND) <> ""
   For [TIR]TIR0 Where REFNUM=MATRI & CTRNUM=[F:HRCTR]CTRNUM & PYRDAT<=[M:DIC]PRDUTL(DICIND) & PYRDAT>=[M:DIC]PRDFRM(DICIND)
     K = [M:DIC]FRMIND(DICIND)#DICIND + 1
     If K <> -1 and TYPFRM(K)=4
      TS(K) += evalue("sum([F:TIR]"+[M:DIB]TIMVAR(FRM(K)-1)+")")
     Endif
   Next
  Endif
 Next DICIND
 For K=1 To NBFRM
  If TYPFRM(K)=4
   Onerrgo RIEN
   Assign "[M:GEN]F0"+num$(K)+"("+num$(nolign-1)+")" With TS(K)
   If GERR : Break : Endif
   Onerrgo
  Endif
 Next K
Endif

#LIPET - 2017-05-20 - END
Return

##################################
$CALCUL
If NCAL
 For K=1 To NBFRM
  If TYPFRM(K)=5
   Onerrgo RIEN
   Assign "[M:GEN]F0"+num$(K)+"("+num$(nolign-1)+")" With evalue(FORMU(K))
   If GERR : Break : Endif
   Onerrgo
  Endif
 Next K
Endif
Return

##################################
$RIEN
Call ERREUR(errmes$(errn)-"\"-errm) From GESECRAN
GERR = 1
Resume

##################################
$RAFRAICHIR
Gosub STAT
Return

##################################
$STAT
NBFRM = 0
NBNUM = 0
For J=1 To [M:DIB]BPAG
 If toupper([M:DIB]CODZONE(J-1))=toupper(mess(59,10709,1)) : # FORMULE
  NBFRM += 1 : FRM(NBFRM) = J
  TYP = [M:DIB]TYP(J-1)
 Else
  Read [ATZ]CODZONE = [M:DIB]CODFIC(J-1);[M:DIB]CODZONE(J-1)
  TYP = [F:ATZ]CODTYP
 Endif
 If [M:DIB]OPT(J-1)<>3
  Read [ATY]CODTYP = TYP
  # Type numérique ou champ=historique des temps / historique de paye/ Synthèse des temps
  # Si c'est un champ de type calcul, alors il doit être numérique
  If find([F:ATY]TYPTYP,2,3,4,5,6) or ([M:DIB]TYPFRM(J-1)>1 & [M:DIB]TYPFRM(J-1)<5)
    # FQ81085 - 17/12/13 - Si SITFAM et CIV, les champs ont été changés en SITFAMA et CIVA, d'où le test sur find()
    If find([M:DIB]CODZONE(J-1),"CIV","CIVA","CIVCTR","CIVCTRA","SITFAM","SITFAMA")=0 Then
     NBNUM += 1
     LIBNUM(NBNUM) = [M:DIB]LIBZONE(J-1)
     If toupper([M:DIB]CODZONE(J-1))=toupper(mess(59,10709,1))
      CHPNUM(NBNUM) = "F0"+num$(NBFRM)
     Else
      CHPNUM(NBNUM) = [M:DIB]CODZONE(J-1)
      If [M:DIB]IND(J-1) <> 0
       CHPNUM(NBNUM) += "_" + num$([M:DIB]IND(J-1))
      Endif
     Endif
   Endif
  Endif
 Endif
Next J
For I=1 To NBNUM
 TOTAL(I) = 0
 MINI(I)  = +10^10
 MAXI(I)  = -10^10
Next I
For I=1 To [M:GEN]BPAG2
 For J=1 To NBNUM
  VALCUR = 0
  Onerrgo RIEN
  VALCUR = evalue("[M:GEN]"+CHPNUM(J)+"("+num$(I-1)+")")
  TOTAL(J) += VALCUR
  If VALCUR>MAXI(J) : MAXI(J) = VALCUR : Endif
  If VALCUR<MINI(J) : MINI(J) = VALCUR : Endif
  If GERR : Break 2 : Endif
  Onerrgo
 Next J
Next I
If GERR : Return : Endif
For I=1 To NBNUM
 [M:GEN3]FLD(I-1) = LIBNUM(I)
 [M:GEN3]TOT(I-1) = TOTAL(I)
 If [M:GEN]BPAG2<>0
  [M:GEN3]MOY(I-1) = TOTAL(I)/[M:GEN]BPAG2
 Endif
 [M:GEN3]MINI(I-1) = MINI(I)
 [M:GEN3]MAXI(I-1) = MAXI(I)
Next I
[M:GEN3]NBRLIG = NBNUM
Affzo [GEN3]
Return

##################################
# Enregistrement des modifications
##################################
$SAUVE_DONNEES
#73522
Local Char TEMPO (100) (0..2)

Local Integer COLLOOP
Local Shortint RECFOUND
Local Integer FIELD_DIMENSION
Local Shortint MANDATORY_FIELDS_PRESENT
Local Shortint MANDATORY_WARNING_SHOWN
Local Char SYMBOLE (80) :#MABOS-04/03/13-FQ 81085-US1335

#MABOS-04/03/13-FQ81085-US1335-Add a Trace
Local  Integer NBENREG_CTR
Local  Char    L_MESSAGE(250)
Local  Char    L_CONTRAT(250)
Local  Char    L_SAV_CONTRAT(250)
Local Integer DEP, K

Local Char    GRPDEB(GLONVCR) :#88174 - US2305

SYMBOLE = "TRTEMP1"
Lock =SYMBOLE
If fstat
  GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
  Unlock =SYMBOLE
  GERR = 1 : SAI = 1 : Return
Endif
TIT = mess(160,10701,1) : # 'Saisie personnalisée'
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

Raz L_MESSAGE
#END MABOS-04/03/13-FQ81085-US1335-Add a Trace

# MABOS-04/03/13-FQ81085-US1335- synchronize the populations
If [M:DIA]FLGPOP = 2 Then
  Gosub OUVRE_POPUL From SUBEML
  Gosub DEFPOP From SUBPOP
Endif
#END MABOS-04/03/13-FQ81085-US1335
For nolign=1 To [M:GEN]BPAG2
 If [M:GEN]FLG(nolign-1)=1
  #MABOS-04/03/13-FQ81085-US1335- Trace de MAJ
  L_CONTRAT = [M:GEN]REFNUM(nolign-1)
  If [F:HRSMH]FLGMAT<2
    L_CONTRAT += [M:GEN]CTRNUM(nolign-1)+format$("D:"+GFMDAT,[M:GEN]CTRDAT(nolign-1))
  Endif
  If find(L_CONTRAT, [V]CONTRAT_MOD)
    Read [ID]ID0 = [M:GEN]REFNUM(nolign-1)
    L_MESSAGE =""
    L_MESSAGE -= mess(5,10935,1)-[M:GEN]REFNUM(nolign-1)-":"-[F:ID]NAM-[F:ID]SRN
    If [F:HRSMH]FLGMAT<2
      L_MESSAGE -= "/"-mess(72,10720,1)-[M:GEN]CTRNUM(nolign-1)-"/"
      L_MESSAGE -= format$("D:"+GFMDAT,[M:GEN]CTRDAT(nolign-1))-":"
    Endif
    Call ECR_TRACE(L_MESSAGE,0) From GESECRAN : # Matricule / Contrat

  ###63137
  Read[F:HRCTR]CTR0=[M:GEN]REFNUM(nolign-1);[M:GEN]CTRNUM(nolign-1);[M:GEN]CTRDAT(nolign-1)
  If !fstat
   DATDEB=max([F:HRCTR]CTRDAT,[M:DIA]DATDEB)
   #70189 ajout du min()
   If [F:HRCTR]XITDAT<>[0/0/0] : DATFIN=min([F:HRCTR]XITDAT,[M:DIA]DATFIN)   : Else : DATFIN=[M:DIA]DATFIN  : Endif
   ###
   Raz MANDATORY_WARNING_SHOWN
   For J=1 To NBTABLE
    If GTABLES(J,2)="S"
     TABLE = GTABLES(J,1) : Gosub DEFAUT From WPDEFTABLE
     Case TABLE
     When "EMPLOCTR"
      # 53330
      Raz [F]
      ###63137
      #Filter [F] Where CTRNUM=[M:GEN]CTRNUM (nolign-1)
      #Readlock [F]CTR0 Last
      #Filter [F]
      Readlock [F]CTR0=[M:GEN]REFNUM(nolign-1);[M:GEN]CTRNUM(nolign-1);[M:GEN]CTRDAT(nolign-1)
      ###
      If fstat=1
        GOK = -1 : GLOCK = "$"+GTABLES(J,1) : Break
      Elsif !fstat
        [F] = [M:GEN]
       Rewrite [F]
      Endif
      ###63137 : Ajout condition '& DATFIN>=eomonth(date$)', mais
      # Risque de maj sur un contrat qui ne serait pas le dernier (si absent de la saisie courante)
      # en cas de saisie anticipée de contrats (> date$)
      #73522 : The defaut file [F] change after the 'Update' to become [ID] and [ID]ETRFCY not exist !
      If dim([F]ETRFCY)>=0 : TEMPO(0)=[F]ETRFCY : Endif
      If dim([F]ETRSRV)>=0 : TEMPO(1)=[F]ETRSRV : Endif
      If dim([F]PROPRF)>=0 : TEMPO(2)=[F]PROPRF : Endif
      If dim([F]ETRFCY)>=0 & DATFIN>=eomonth(date$)
       Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With FCY=TEMPO (0)
      Endif
      If dim([F]ETRSRV)>=0  & DATFIN>=eomonth(date$)
       Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With SRV=TEMPO (1)
      Endif
      If dim([F]PROPRF)>=0 & DATFIN>=eomonth(date$)
       Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With PRF=TEMPO (2)
      Endif
     When Default
      If func IS_EMP_CHILD_TABLE(TABLE) = 1
       Raz [F]
       Gosub POSE_FILTRE
          For COLLOOP=1 To [M:DIB]BPAG
            If [M:DIB]CODFIC(COLLOOP-1) = TABLE
              # Construct name of field eg CHLDNAM_1 = child name 1
              FLDNAMIND = "[M:GEN]" + [M:DIB]CODZONE(COLLOOP-1) + "_" + num$([M:DIB]IND(COLLOOP-1)) + "(" + num$(nolign-1) + ")"

              Raz RECFOUND
              Raz MANDATORY_FIELDS_PRESENT

              If ([M:DIB]IND(COLLOOP-1) = 0) #0 is the last record
                FLDNAMIND = "[M:GEN]" + [M:DIB]CODZONE(COLLOOP-1)
                  Readlock Last
                  If rowcount([F]) > 0
                    If fstat=1
                      GOK = -1 : GLOCK = "$"+GTABLES(J,1) : Break
                    Endif
                     Assign "[F]" + [M:DIB]CODZONE(COLLOOP-1) With evalue(FLDNAMIND)
                    Rewrite [F]
                    RECFOUND = 1
                  Endif
              Else #we're not dealing with 0 which is the last record
                For [F] Where NUMLIG = [M:DIB]IND(COLLOOP-1)
                  Readlock Curr
                  If fstat=1
                    GOK = -1 : GLOCK = "$"+GTABLES(J,1) : Break
                  Endif
                    Assign "[F]" + [M:DIB]CODZONE(COLLOOP-1) With evalue(FLDNAMIND)
                  Rewrite [F]
                  RECFOUND = 1
                Next
              Endif

                #record not found therefore create it with a numlig specified in IND field.
                If RECFOUND = 0
                  #Mandatory field checks, if these fields don't exist in the screen can't add the record
                    #EMPLOID: NAMCNT & SRNCNT
                    #EMPLOCHD: CHDNAM & CHDSRN
                    #EMPLOAD: CHEF
                    #EMPLOHAB: HAB
                    #EMPLORIB: MODSTL, CUR & PAYPCT
                    #EMPLOPAR: FDSPAR, PDSPARPRC, FDSITS & FDSITSPRC
                    #EMPLOEXN: EXSDAT, EXSVAR & EXSAMT
                  Case TABLE
                    When "EMPLOID" #not possible to create a new employee but include for future proofing
                      MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "NAMCNT", [M:DIB]IND(COLLOOP-1), nolign-1)
                      If MANDATORY_FIELDS_PRESENT <> 0
                        MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "SRNCNT", [M:DIB]IND(COLLOOP-1), nolign-1)
                      Endif
                    When "EMPLOCHD"
                      MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "CHDNAM", [M:DIB]IND(COLLOOP-1), nolign-1)
                      If MANDATORY_FIELDS_PRESENT <> 0
                        MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "CHDSRN", [M:DIB]IND(COLLOOP-1), nolign-1)
                      Endif
                    When "EMPLOAD"
                      MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "CHEF", [M:DIB]IND(COLLOOP-1), nolign-1)
                    When "EMPLOHAB"
                      MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "HAB", [M:DIB]IND(COLLOOP-1), nolign-1)
                    When "EMPLORIB"
                      MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "MODSTL", [M:DIB]IND(COLLOOP-1), nolign-1)
                      If MANDATORY_FIELDS_PRESENT <> 0
                        MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "CUR", [M:DIB]IND(COLLOOP-1), nolign-1)
                      Endif
                      If MANDATORY_FIELDS_PRESENT <> 0
                        MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "PAYPCT", [M:DIB]IND(COLLOOP-1), nolign-1)
                      Endif
                    When "EMPLOPAR"
                      MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "FDSPAR", [M:DIB]IND(COLLOOP-1), nolign-1)
                      If MANDATORY_FIELDS_PRESENT <> 0
                        MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "PDSPARPRC", [M:DIB]IND(COLLOOP-1), nolign-1)
                      Endif
                      If MANDATORY_FIELDS_PRESENT <> 0
                        MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "FDSITS", [M:DIB]IND(COLLOOP-1), nolign-1)
                      Endif
                      If MANDATORY_FIELDS_PRESENT <> 0
                        MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "FDSITSPRC", [M:DIB]IND(COLLOOP-1), nolign-1)
                      Endif
                    When "EMPLOEXN"
                      MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "EXSDAT", [M:DIB]IND(COLLOOP-1), nolign-1)
                      If MANDATORY_FIELDS_PRESENT <> 0
                        MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "EXSVAR", [M:DIB]IND(COLLOOP-1), nolign-1)
                      Endif
                      If MANDATORY_FIELDS_PRESENT <> 0
                        MANDATORY_FIELDS_PRESENT = func VERIFY_FIELD_AND_INDEX_EXIST(TABLE, "EXSAMT", [M:DIB]IND(COLLOOP-1), nolign-1)
                      Endif
                    When Default
                      MANDATORY_FIELDS_PRESENT = 1
                  Endcase

                  If MANDATORY_FIELDS_PRESENT = 1 #all the fields required to create a new record are present
                    Raz [F]
                    [F] = [M:GEN]
                    If [M:DIB]IND(COLLOOP-1) = 0
                      [F]NUMLIG += 1
                    Else
                      [F]NUMLIG += [M:DIB]IND(COLLOOP-1)
                    Endif
                    Assign "[F]" + [M:DIB]CODZONE(COLLOOP-1) With evalue(FLDNAMIND)
                    Write [F]
                    # Update the relevant number count field on the employee record
                    Case TABLE
                      When "EMPLOCHD"
                        Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With NBRCHD=func COUNT_EMP_RECS(TABLE,[M:GEN]REFNUM(nolign-1))
                      When "EMPLORIB"
                        Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With NBRRIB=func COUNT_EMP_RECS(TABLE,[M:GEN]REFNUM(nolign-1))
                      When "EMPLOSAL"
                        Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With NBRSAL=func COUNT_EMP_RECS(TABLE,[M:GEN]REFNUM(nolign-1))
                      When "EMPLOMED"
                        Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With NBRVIS=func COUNT_EMP_RECS(TABLE,[M:GEN]REFNUM(nolign-1))
                      When "EMPLOEXM"
                        Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With NBREXM=func COUNT_EMP_RECS(TABLE,[M:GEN]REFNUM(nolign-1))
                      When "EMPLOTRY"
                        Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With NBRTRY=func COUNT_EMP_RECS(TABLE,[M:GEN]REFNUM(nolign-1))
                      When "EMPLOPOT"
                        Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With NBRPOT=func COUNT_EMP_RECS(TABLE,[M:GEN]REFNUM(nolign-1))
                      When "EMPLOHAB"
                        Update [ID] Where REFNUM=[M:GEN]REFNUM (nolign-1) With NBRHAB=func COUNT_EMP_RECS(TABLE,[M:GEN]REFNUM(nolign-1))
                    Endcase
                  Elsif MANDATORY_WARNING_SHOWN = 0
                    Infbox mess(3, 10711, 1) - mess(61, 100, 1) - num$(nolign) #"Valeur obligatoire inexistante" - "ligne no" - nolign
                    MANDATORY_WARNING_SHOWN = 1
                    Call ECR_TRACE(space$(5)+mess(3, 10711, 1) - TABLE - [M:DIB]LIBZONE(COLLOOP-1),0) From GESECRAN :#mabos
                  Endif
                Endif #If RECFOUND = 0

            Endif
          Next COLLOOP
      Endif

      [G]currind = 1
      Raz [F]
      Gosub POSE_FILTRE
      Readlock Last
      Filter [F]
      If fstat=1
       GOK = -1 : GLOCK = "$"+GTABLES(J,1) : Break
      Endif
      K = find(TABLE,[M:DIB]HISTBL(1..[M:DIB]NBHIS))
      If K & evalue("dim([M:GEN]"+[M:DIB]HISDAT(K)+")")>0
       If  evalue("[M:GEN]"+[M:DIB]HISDAT(K)+"("+num$(nolign-1)+")")<>[0/0/0]
        [F]REFNUM = [M:GEN]REFNUM(nolign-1)
        If dim([F]CTRNUM)>0
         [F]CTRNUM = [M:GEN]CTRNUM(nolign-1)
        Endif
        If dim([F]CTRDAT)>0
         [F]CTRDAT = [M:GEN]CTRDAT(nolign-1)
        Endif
        Assign "[F]"+[M:DIB]HISDAT(K) With evalue("[M:GEN]"+[M:DIB]HISDAT(K)+"("+num$(nolign-1)+")")
        [G]currind = 2
        Read =
        If !fstat
         [F] = [M:GEN]
         Rewrite [F]
        Else
         [F] = [M:GEN]
         [F]NUMLIG += 1
         Write [F]
        Endif
        If fstat
         GOK = 0 : Call GSTA From GLOCK : Break
        Endif
       Endif
      Else
       If fstat=0
        [F] = [M:GEN]
        Rewrite [F]
        If fstat
         GOK = 0 : Call GSTA From GLOCK : Break
        Endif
        #88174 - US2305
        If TABLE='EMPLOID'&  dim ([M:GEN]FLGBULDEM)>0
         If [M:GEN]VALORI(nolign-1)<>[M:GEN]FLGBULDEM(nolign-1)
           Call WORKPLUS(1,"DIV","","","BULDEM",0,0,0,GRPDEB) From AWRK
           [M:GEN]VALORI(nolign-1)=[M:GEN]FLGBULDEM(nolign-1)
         Endif
        Endif
        #
       Endif
      Endif
     Endcase

      ##handle dimension field
      [G]currind = 1
      #Raz [F]
      #Gosub POSE_FILTRE
      #Readlock Last

      If TABLE = "EMPLOCTR"
        Readlock [F]CTR0=[M:GEN]REFNUM(nolign-1);[M:GEN]CTRNUM(nolign-1);[M:GEN]CTRDAT(nolign-1)
      Else
        Gosub POSE_FILTRE
        Readlock Last
      Endif

      Filter [F]
      If fstat=1
       GOK = -1 : GLOCK = "$"+GTABLES(J,1) : Break
      Endif
      K = find(TABLE,[M:DIB]HISTBL(1..[M:DIB]NBHIS))
      If K & evalue("dim([M:GEN]"+[M:DIB]HISDAT(K)+")")>0
       If  evalue("[M:GEN]"+[M:DIB]HISDAT(K)+"("+num$(nolign-1)+")")<>[0/0/0]
        [F]REFNUM = [M:GEN]REFNUM(nolign-1)
        If dim([F]CTRNUM)>0
         [F]CTRNUM = [M:GEN]CTRNUM(nolign-1)
        Endif
        If dim([F]CTRDAT)>0
         [F]CTRDAT = [M:GEN]CTRDAT(nolign-1)
        Endif
        Assign "[F]"+[M:DIB]HISDAT(K) With evalue("[M:GEN]"+[M:DIB]HISDAT(K)+"("+num$(nolign-1)+")")
        [G]currind = 2
        Read =
        If !fstat
         #[F] = [M:GEN]

         For COLLOOP=1 To [M:DIB]BPAG
           If [M:DIB]CODFIC(COLLOOP-1) = TABLE
             FIELD_DIMENSION = func EMP_FIELD_DIMENSION([M:DIB]CODFIC(COLLOOP-1), [M:DIB]CODZONE(COLLOOP-1))
             #If func EMP_FIELD_DIMENSION([M:DIB]CODFIC(COLLOOP-1), [M:DIB]CODZONE(COLLOOP-1)) > 1
             If FIELD_DIMENSION > 1
               FLDNAMIND = "[M:GEN]" + [M:DIB]CODZONE(COLLOOP-1) + "_" + num$([M:DIB]IND(COLLOOP-1) ) + "(" + num$(nolign-1) + ")"
               Readlock Curr
               If fstat=1
                 GOK = -1 : GLOCK = "$"+GTABLES(J,1) : Break
               Endif

               # If index entered was 0 then assume updating the last dimension
               If [M:DIB]IND(COLLOOP-1) > 0
                 Assign "[F]" + [M:DIB]CODZONE(COLLOOP-1) + "(" + num$([M:DIB]IND(COLLOOP-1) -1) + ")" With evalue(FLDNAMIND)
               Else
                 Assign "[F]" + [M:DIB]CODZONE(COLLOOP-1) + "(" + num$(FIELD_DIMENSION -1) + ")" With evalue(FLDNAMIND)
               Endif
               Rewrite [F]
             Endif
           Endif
         Next COLLOOP
         Rewrite [F]
        Else
         #[F] = [M:GEN]
         For COLLOOP=1 To [M:DIB]BPAG
           If [M:DIB]CODFIC(COLLOOP-1) = TABLE
             FIELD_DIMENSION = func EMP_FIELD_DIMENSION([M:DIB]CODFIC(COLLOOP-1), [M:DIB]CODZONE(COLLOOP-1))
             #If func EMP_FIELD_DIMENSION([M:DIB]CODFIC(COLLOOP-1), [M:DIB]CODZONE(COLLOOP-1)) > 1
             If FIELD_DIMENSION > 1
               FLDNAMIND = "[M:GEN]" + [M:DIB]CODZONE(COLLOOP-1) + "_" + num$([M:DIB]IND(COLLOOP-1) ) + "(" + num$(nolign-1) + ")"
               Readlock Curr
               If fstat=1
                 GOK = -1 : GLOCK = "$"+GTABLES(J,1) : Break
               Endif

               # If index entered was 0 then assume updating the last dimension
               If [M:DIB]IND(COLLOOP-1) > 0
                 Assign "[F]" + [M:DIB]CODZONE(COLLOOP-1) + "(" + num$([M:DIB]IND(COLLOOP-1) -1) + ")" With evalue(FLDNAMIND)
               Else
                 Assign "[F]" + [M:DIB]CODZONE(COLLOOP-1) + "(" + num$(FIELD_DIMENSION -1) + ")" With evalue(FLDNAMIND)
               Endif
               Rewrite [F]
             Endif
           Endif
         Next COLLOOP
         [F]NUMLIG += 1
         Write [F]
        Endif
        If fstat
         GOK = 0 : Call GSTA From GLOCK : Break
        Endif
       Endif
      Else
       If fstat=0
        #[F] = [M:GEN]
         For COLLOOP=1 To [M:DIB]BPAG
           If [M:DIB]CODFIC(COLLOOP-1) = TABLE
             FIELD_DIMENSION = func EMP_FIELD_DIMENSION([M:DIB]CODFIC(COLLOOP-1), [M:DIB]CODZONE(COLLOOP-1))
             #If func EMP_FIELD_DIMENSION([M:DIB]CODFIC(COLLOOP-1), [M:DIB]CODZONE(COLLOOP-1)) > 1
             If FIELD_DIMENSION > 1
               FLDNAMIND = "[M:GEN]" + [M:DIB]CODZONE(COLLOOP-1) + "_" + num$([M:DIB]IND(COLLOOP-1) ) + "(" + num$(nolign-1) + ")"
               Readlock Curr
               If fstat=1
                 GOK = -1 : GLOCK = "$"+GTABLES(J,1) : Break
               Endif

               # If index entered was 0 then assume updating the last dimension
               If [M:DIB]IND(COLLOOP-1) > 0
                 Assign "[F]" + [M:DIB]CODZONE(COLLOOP-1) + "(" + num$([M:DIB]IND(COLLOOP-1) -1) + ")" With evalue(FLDNAMIND)
               Else
                 Assign "[F]" + [M:DIB]CODZONE(COLLOOP-1) + "(" + num$(FIELD_DIMENSION -1) + ")" With evalue(FLDNAMIND)
               Endif
               Rewrite [F]
             Endif
           Endif
         Next COLLOOP
        Rewrite [F]
        If fstat
         GOK = 0 : Call GSTA From GLOCK : Break
        Endif
       Endif
      Endif

    Endif


   Next J

#   MABOS-04/03/13-FQ81085-US1335- Trace de MAJ
    If GOK = 1 Then
      L_CONTRAT = [M:GEN]REFNUM(nolign-1)
      If [F:HRSMH]FLGMAT<2
        L_CONTRAT +=[M:GEN]CTRNUM(nolign-1)+format$("D:"+GFMDAT,[M:GEN]CTRDAT(nolign-1))
      Endif
      [L]DEP=1 : L_MESSAGE =""
      K=1
      While K>0
         K= find([L]L_CONTRAT,[V]CONTRAT_MOD([L]DEP..[V]INDCTR))
         If K>0
           [L]DEP+=K
           [L]L_MESSAGE=[V]CTR_FLD([L]DEP-1)
           Call ECR_TRACE(L_MESSAGE,0) From GESECRAN : # Matricule / Contrat
         Endif
      Wend
      NBENREG_CTR+=1
      # MABOS-04/03/13-FQ81085-US1335-synchronize the populations
      If [M:DIA]FLGPOP = 2 Then
         Gosub POPUL_CTR From SUBEML
         If GOK<1 : Break : Endif
            Call ECR_TRACE(space$(5)+mess(163,10701,1),0) From GESECRAN :#Mise à jour des populations effectuée'
         Endif
     Endif
     # end MABOS-04/03/13-FQ81085-US1335-synchronize the populations
  Endif
#  Unlock= "ID "+ [M:GEN]REFNUM(nolign-1)
#  Unlock= "CTR"+[M:GEN]CTRNUM(nolign-1)+"\"+[M:GEN]REFNUM(nolign-1)+"\"+[M:GEN]CTRDAT(nolign-1)
 Endif
 Endif
Next nolign

Unlock =SYMBOLE
# Gestion de la trace
Local Char WMES(250)
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If NBENREG_CTR>0  Then
#MABOS - 15/01/14 - 88515+FQ88174 - amélioration trace
   If [F:HRSMH]FLGMAT=2
    [L]WMES=mess(176,10701,1):#'Nombre d'employés mis à jour'
   Else
     [L]WMES=mess(117,10701,1) : # Nombre de contrat mis à jour'
   Endif
  Call ECR_TRACE([L]WMES-":"-num$(NBENREG_CTR),0) From GESECRAN
Else
   If [F:HRSMH]FLGMAT=2
    [L]WMES=mess(177,10701,1) :#'Aucun employé à traiter'
   Else
     [L]WMES=mess(118,10701,1):#Aucun contrat à traiter'
   Endif
  Call ECR_TRACE([L]WMES,0) From GESECRAN
Endif
Call FERME_TRACE From LECFIC
# Lecture de la trace, sinon avec la nouvelle étiquette EXEC, on ne la voit pas
Call LEC_TRACE From LECFIC
GMESSAGE=""

#END MABOS-04/03/13-FQ81085-US1335 Trace de MAJ

GFLAGMODIF=1
REP=""
#MABOS-15/01/14-Modif Trace
Kill [V]CONTRAT_MOD, CTR_FLD, INDCTR, CONTRAT_FLD_MOD, GEN_BEFORE
Gosub INIT_TRACE
#MABOS-15/01/14-Modif Trace
Return

##################################
# A chaque action sur une ligne :
# Controle vérouillage
# Vérifications des divers droits d'accès
##################################
Subprog C_BPAG2
If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
Local Integer NUMSITE, MOK
If nolign<1 or nolign>[M]BPAG2 : End : Endif
If status=75
 Lock= "ID "+ [M:GEN]REFNUM(nolign-1)
 If fstat
  GMESSAGE = mess(10,100,1) :  #Modification en cours sur autre poste...
  mkstat = 1 : End
 Endif
 Lock= "CTR"+[M:GEN]CTRNUM(nolign-1)+"\"+[M:GEN]REFNUM(nolign-1)+"\"+[M:GEN]CTRDAT(nolign-1)
 If fstat
  GMESSAGE = mess(10,100,1) :  #Modification en cours sur autre poste...
  mkstat = 1 : End
 Endif
Endif

#Gestion des autorisations par site
Read [F:ECT]ECT0=[M:GEN]REFNUM(nolign-1);[M:GEN]CTRNUM(nolign-1)
If fstat=0
 For NUMSITE=1 To GNBSITE
  If GUSRFCY(NUMSITE)=[F:ECT]FCY
   If !instr(1,GUSRAUZ(NUMSITE),"M")
    GMESSAGE = mess(2,104,1) :  #Pas les droits pour ce site
    mkstat = 1 : End
   Endif
  Endif
 Next NUMSITE
 If status=75 &  [M:GEN]FLG(nolign-1)<>1 & dim([M:GEN]WCTRDAT)>0
  Read [F:HRCTR2]CTR0=[M:GEN]REFNUM(nolign-1);[M:GEN]CTRNUM(nolign-1);[M:GEN]CTRDAT(nolign-1)
  If [F:ECT]NBRCTR<>[F:HRCTR2]NUMLIG
   MOK = 2
   #Modification d'informations sur un contrat historisé
   Call AVERTIR(mess(87,10701,1),MOK) From GESECRAN
   If MOK=1 : mkstat = 1 : End : Endif
  Endif
 Endif
Endif

#Gestion des droits d'accès
If status=75     :#Modification ligne
 If [F:ID]CODACS<>"" & GUSRACS<>2
  Read[F:ACC]CODACC= GUSER;[F:ID]CODACS
  If fstat=0
   If [F:ACC]MODIF<>2 :#oui
    GMESSAGE = mess(123,141,1) :  #Pas les droits pour créer ou modifier
    GERR=1 : End
   Endif
  Endif
 Endif
Endif

#[M:GEN]FLG(nolign-1)=1 : #MABOS-04/03/13-FQ81085-US1335-Add a trace

# Multi_leg & multi_société
Read [F:HRCTR2]CTR0=[M:GEN]REFNUM(nolign-1);[M:GEN]CTRNUM(nolign-1);[M:GEN]CTRDAT(nolign-1)
Call LECTURE("FCY",[F:HRCTR2]ETRFCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GSOCIETE=[F:CPY]CPY : GCURLEG=[F:CPY]LEG
End

##################################
## Avant chaque action sur une ligne :
## Chargement des classes [f] du salarié
##################################
Subprog AVANT_BPAG2
Local Date DATDEB, DATFIN
For J=1 To NBTABLE
 TABLE = GTABLES(J,1) : Gosub DEFAUT From WPDEFTABLE
 [G]currind = 1
 If GTABLES(J,1)<>"EMPLOID" & GTABLES(J,1)<>"EMPLOCTR"
  DATDEB=max([F:HRCTR]CTRDAT,[M:DIA]DATDEB)
  #70189 ajout du min()
  If [F:HRCTR]XITDAT<>[0/0/0] : DATFIN=min([F:HRCTR]XITDAT,[M:DIA]DATFIN)   : Else : DATFIN=[M:DIA]DATFIN  : Endif
  Gosub POSE_FILTRE
  Read Last
  Filter [F]
 Endif
Next J
End

##################################
## Dévérouillage du symbole
## Si on a fait des modifs mais qu'on abandonne celles-ci, il faut déverouiller
## les enregistrements aussi !
##################################
$MYEND
Case BOITE
 When "WFEM"+[M:DIA]MYLEG+[M:DIA]SMH
  Unlock="WMEM"+[M:DIA]MYLEG+[M:DIA]SMH
  For nolign=1 To [M:GEN]BPAG2
#   If [M:GEN]FLG(nolign-1)=1 :  #MABOS-04/03/13-FQ81085-US1335
    Unlock= "ID "+ [M:GEN]REFNUM(nolign-1)
    ###63137
    Unlock= "CTR"+[M:GEN]CTRNUM(nolign-1)+"\"+[M:GEN]REFNUM(nolign-1)+"\"+[M:GEN]CTRDAT(nolign-1)
    ###
#   Endif :MABOS-04/03/13-FQ81085-US1335
  Next nolign
  Kill [V]CONTRAT_MOD, CTR_FLD, INDCTR, CONTRAT_FLD_MOD, GEN_BEFORE:#MABOS-04/03/13-FQ81085-US1335-add trace
  # FQ81085 - 19/12/13 - Globale utilisée dans DIVPAYE.INIMNL pour le menu local civilité ou statut marital
  If dim(GNOLIB)>0 Then Kill GNOLIB : Endif
Endcase
FIN = 1 :# GOK = 0
Return

####################################################################################
##                            Tri salarié
####################################################################################

## Génère la liste des champs pour proposition de tri
##################################
$SEL_TRI
F = 0
NBTEX += 1
TEX(NBTEX)   = "REFNUM"
TEXTE(NBTEX) = TEX(NBTEX)-mess(80,10703,1) : # Matricule
For I=0 To [M:DIB]BPAG-1
 If [M:DIB]OPT(I)<>3
  NBTEX += 1
  If toupper([M:DIB]CODZONE(I))=toupper(mess(59,10709,1))
   F += 1
   TEX(NBTEX) = "F0"+num$(F)
  Else
   TEX(NBTEX) = [M:DIB]CODZONE(I)
  Endif
  TEXTE(NBTEX) = TEX(NBTEX)-[M:DIB]LIBZONE(I)
 Endif
Next I
TIT = mess(429,200,1)    :#Critères de tri
Return

## Tri les enregistrements, suivant le champ choisi dans la liste
##################################
$VERF_TRI
Sorta [M]BPAG2 [M]BPAG2 Order By evalue(TEX(CHOIX)+"(indice)")
Affzo [GEN]
Return

#################################################################################
##                     Impression
#################################################################################


## Pas d'état préci car dépendant l'écran, donc impression par HardCopy !
##################################
$XIMPRIMER
Local Char TITLE (40)


TITLE=mess(37,10702,1) #Impression des informations salariales

Call PRTSCR("WFEM"+[M:DIA]MYLEG+[M:DIA]SMH,"GEN",TITLE,0,0) From ATRTX3
Call PRTSCR("GENEMP3","GEN3",TITLE,0,0) From ATRTX3
Call IMPSCR From ATRTX3
Return

########################################
## Ecran GENAUG
########################################
Subprog C_TYPAUG(VALEUR)
Variable Integer VALEUR
If VALEUR=3
 Grizo TYPAMT, ARD
Else
 Actzo TYPAMT
Endif
End

Subprog AS_TYPAMT(VALEUR)
Variable Integer VALEUR
If [M]TYPAUG=3 : mkstat = 2 : End : Endif
End

Subprog C_TYPAMT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Grizo ARD
Else
 Actzo ARD
Endif
End

Subprog C_ARD(VALEUR)
Variable Decimal VALEUR
Local Char    DECIM(10)
Local Decimal MINI
If VALEUR<=0 : mkstat = 2 : End : Endif
Call PARAM("","NBRDEC",DECIM) From ADOVAL
MINI = 10^(-val(DECIM))
If VALEUR<MINI : VALEUR = MINI : Endif
End

$EXEC
If GSTATUT=GSTAOK
 Local Decimal OLDVAL , NEWVAL
 Local Char    ZONE(10)
 Local Integer NOL , NUMLIG
 ZONE   = PARAM(1)
 NUMLIG = val(PARAM(2))
#JOJAC - 2016-04-04 - REQ114309 US83 - START
# For NOL=NUMLIG-1 To [M:GEN]BPAG2
For NOL=NUMLIG-1 To [M:GEN]BPAG2-1
#JOJAC - 2016-04-04 - REQ114309 US83 - END
   OLDVAL = evalue("[M:GEN]"+ZONE+"("+num$(NOL)+")")
  Case [M:AUG]TYPAUG
   When 1 : # Augmentation
    Case [M:AUG]TYPAMT
     When 1 : NEWVAL = arr(OLDVAL*(1+[M:AUG]AMT/100),[M:AUG]ARD)
     When 2 : NEWVAL = OLDVAL+[M:AUG]AMT
    Endcase
   When 2 : # Diminution
    Case [M:AUG]TYPAMT
     When 1 : NEWVAL = arr(OLDVAL*(1-[M:AUG]AMT/100),[M:AUG]ARD)
     When 2 : NEWVAL = OLDVAL-[M:AUG]AMT
    Endcase
   When 3 : # Affectation
    NEWVAL = [M:AUG]AMT
  Endcase
  Assign "[M:GEN]"+ZONE+"("+num$(NOL)+")" With NEWVAL
#JOJAC - 2016-04-04 - REQ114309 US83 - START
[M:GEN]FLG(NOL)=1 :#102578
#JOJAC - 2016-04-04 - REQ114309 US83 - END
  If NOL=NUMLIG-1 : VALEUR = NEWVAL : Endif
 Next NOL
 Affzo ="[M:GEN]"+ZONE
Endif
Return

########################################################################################
## Impression
########################################################################################
$IMPRIMER
Local Char    FMT(30)(0..100) , CHFMT(250) , CHAMP(250) , TITL(250) , ETAT(GLONARP) , TYP(3)
Local Integer FMTL(0..100) , FMTT(0..100)
Local Integer L1 , L2 , LIG , NUMREQ , POLICE , PAYSAGE , NBPAR , NRCOL , NOLIB
Local Decimal LONG , LFMT, REPQST
Local Char    TBPAR(10)(1..20),TBVAL(50)(1..20)
If clalev([F:SPS])=0 : Local File SAIPERLIS [SPS] : Endif
[L]NUMREQ = uniqid([SPS])
TITL = ""
Raz FMTL
NRCOL = 0
K = 0
REQST = 1
# Voulez-vous imprimer la colonne contrat ?
Qstbox mess(66,10701,1) Using [L]REPQST Sleep 10
If [L]REPQST=2 : Raz [L]REPQST : Endif
For I=0 To [M:DIB]BPAG+[L]REPQST
 If I=0
  FMT(I)  = "K:"+num$(GLONEML)+"X"
  FMTL(I) = GLONEML
  FMTT(I) = 1
  Raz [F:ATY]
  TITL = format$(FMT(I),mess(80,10703,1))+" " : # Matricule
 Elsif I=1 & REPQST=1
  FMT(I)  = "K:"+num$(GLONHRCTR)+"X"
  FMTL(I) = GLONHRCTR
  FMTT(I) = 1
  Raz [F:ATY]
  TITL += format$(FMT(I),mess(156,10702,1))+" " : # Contrat
 Elsif [M:DIB]OPT(I-1-[L]REPQST)<>3
  If toupper([M:DIB]CODZONE(I-1-[L]REPQST))<>toupper(mess(59,10709,1))
   Read [DIC]DIC0 = [M:DIB]CODZONE(I-1-[L]REPQST)
   Read [ATZ]CODZONE = [F:DIC]TBL;[F:DIC]FLD
   Read [ATY]CODTYP = [F:ATZ]CODTYP
   If [F:ATZ]LONG<>0
    LONG = [F:ATZ]LONG
   Else
    LONG = [F:ATY]LNGTYP
   Endif
   If [F:ATZ]NOLIB<>0
    NOLIB = [F:ATZ]NOLIB
   Else
    NOLIB = [F:ATY]NOLIB
   Endif
  Else
   Case [M:DIB]TYPFRM(I-1-[L]REPQST)
    When 1
     TYP   = [M:DIB]TYP(I-1-[L]REPQST)
     LONG  = [M:DIB]LNG(I-1-[L]REPQST)
     NOLIB = [M:DIB]NOLIB(I-1-[L]REPQST)
    When 2
     TYP   = "DCB"
     LONG  = 11.2
     NOLIB = 0
    When 3
     TYP   = "DCB"
     LONG  = 6.2
     NOLIB = 0
   Endcase
   Read [ATY]CODTYP = TYP
  Endif
  Case [F:ATY]TYPTYP
   When 1
    FMT(I) = "LA"+num$(NOLIB)+":"+num$(LONG)+"X"
    LFMT   = LONG
    FMTT(I) = 1
   When 2,3
    FMT(I) = "Nz:"+num$(LONG)+"#"
    LFMT   = LONG
    FMTT(I) = 2
   When 4,5,6
    FMT(I) = "Nz3:"+num$(LONG)
    L1 = int(LONG)
    L2 = 10*(LONG-L1)
    LFMT = L1+int((L1-1)/3)+(L2+1)*(L2<>0)
    FMTT(I) = 2
   When 7
    If [F:ATY]FORTYP<>"" & left$([F:ATY]FORTYP,1)<>"="
     FMT(I) = "Kz:"+[F:ATY]FORTYP
     LFMT   = len(format$(FMT(I),""))
    Else
     FMT(I) = "K:"+num$(LONG)+"X"
     LFMT   = LONG
    Endif
    FMTT(I) = 1
   When 8
    FMT(I) = "DzZ:"+GFMDAT
    LFMT   = 8
    FMTT(I) = 1
  Endcase
  FMTL(I) = max(LFMT,len([M:DIB]LIBZONE(I-1-[L]REPQST)))
  If len(TITL)+FMTL(I)>250
   Break
  Endif
  Case [F:ATY]TYPTYP
   When 2,3,4,5,6
    TITL += space$(FMTL(I)-len([M:DIB]LIBZONE(I-1-[L]REPQST)))+[M:DIB]LIBZONE(I-1-[L]REPQST)+" "
   When Default
    TITL += left$([M:DIB]LIBZONE(I-1-[L]REPQST)+space$(FMTL(I)),FMTL(I))+" "
  Endcase
 Endif
 NRCOL = I
Next I
TITL = left$(TITL,len(TITL)-1)
If len(TITL)>217
 PAYSAGE = 1 : POLICE = 5
Elsif len(TITL)>187
 PAYSAGE = 1 : POLICE = 6
Elsif len(TITL)>163
 PAYSAGE = 1 : POLICE = 7
Elsif len(TITL)>142
 PAYSAGE = 1 : POLICE = 8
Elsif len(TITL)>130
 PAYSAGE = 1 : POLICE = 9
Elsif len(TITL)>97
 PAYSAGE = 1 : POLICE = 10
Elsif len(TITL)>90
 PAYSAGE = 0 : POLICE = 9
Else
 PAYSAGE = 0 : POLICE = 10
Endif
Call DEBTRANS From GLOCK
Gosub TR_IMP
If GOK=1
 NBPAR = 0
 NBPAR += 1 : TBPAR(NBPAR)="liste"  : TBVAL(NBPAR) = [M:DIA]MYLEG+[M:DIA]SMH
 NBPAR += 1 : TBPAR(NBPAR)="user"   : TBVAL(NBPAR) = GUSER
 NBPAR += 1 : TBPAR(NBPAR)="titre"  : TBVAL(NBPAR) = [M:DIA]MYLEG+[M:DIA]SMH
 NBPAR += 1 : TBPAR(NBPAR)="niveau" : TBVAL(NBPAR) = "1"
 NBPAR += 1 : TBPAR(NBPAR)="numreq" : TBVAL(NBPAR) = num$([L]NUMREQ)
 NBPAR += 1 : TBPAR(NBPAR)="police" : TBVAL(NBPAR) = num$(POLICE)
 NBPAR += 1 : TBPAR(NBPAR)="tit1"   : TBVAL(NBPAR) = mid$(TITL,1,50)
 NBPAR += 1 : TBPAR(NBPAR)="tit2"   : TBVAL(NBPAR) = mid$(TITL,51,100)
 NBPAR += 1 : TBPAR(NBPAR)="tit3"   : TBVAL(NBPAR) = mid$(TITL,101,150)
 NBPAR += 1 : TBPAR(NBPAR)="tit4"   : TBVAL(NBPAR) = mid$(TITL,151,200)
 NBPAR += 1 : TBPAR(NBPAR)="tit5"   : TBVAL(NBPAR) = mid$(TITL,201,250)
 If PAYSAGE : ETAT = "SAIPERPAY" : Else : ETAT = "SAIPERPOR" : Endif
 Call ETATN(ETAT,"",TBPAR,TBVAL) From ETAT
Endif
OK = 0
Return

##################################
$TR_IMP
GOK = 1
Trbegin [SPS]
 For LIG=1 To [M:GEN]BPAG2
  CHFMT = ""
  K = 0
  For I=0 To NRCOL
   #62904
   #If I<>0 & [M:DIB]OPT(I-1)=3 : # champ invisible
   If I<>0 & (I<>1 | [L]REPQST=0) & [M:DIB]OPT(I-1-[L]REPQST)=3 : # champ invisible
    If toupper([M:DIB]CODZONE(I-1-[L]REPQST))=toupper(mess(59,10709,1)) : K +=1 : Endif
   Else
    If I=0
     CHAMP = format$(FMT(I),[M:GEN]REFNUM(LIG-1))
    Elsif I=1 & REPQST=1
     CHAMP = format$(FMT(I),[M:GEN]CTRNUM(LIG-1))
    Else
     #62904 : ajout [L]REPQST
     If toupper([M:DIB]CODZONE(I-1-[L]REPQST))<>toupper(mess(59,10709,1))
      CHAMP = format$(FMT(I),evalue("[M:GEN]"+[M:DIB]CODZONE(I-1-[L]REPQST)+"("+num$(LIG-1)+")"))
     Else
      K += 1
      CHAMP = format$(FMT(I),evalue("[M:GEN]F0"+num$(K)+"("+num$(LIG-1)+")"))
     Endif
    Endif
    If FMTT(I)=1
     CHFMT += CHAMP+space$(FMTL(I)-len(CHAMP))+" "
    Else
     CHFMT += space$(FMTL(I)-len(CHAMP))+CHAMP+" "
    Endif
   Endif
  Next I
  CHFMT = left$(CHFMT,len(CHFMT)-1)
  Raz [F:SPS]
  [F:SPS]NUMREQ = [L]NUMREQ
  [F:SPS]USR    = GUSER
  [F:SPS]COD    = [M:DIA]MYLEG+[M:DIA]SMH
  [F:SPS]NUMLIG = LIG+1
  [F:SPS]DES    = CHFMT
  Write [SPS]
  If fstat
   GOK = 0 : Call FSTA("SPS") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_IMP : Endif
Commit
Return

##################################
$AB_TR_IMP
Rollback
Return

##################################
Subprog GET_CURRENT_PAY_PERIOD(RESULT_FROM, RESULT_UNTIL, PAY_DATE)
Variable Date RESULT_FROM
Variable Date RESULT_UNTIL
Variable Date PAY_DATE

Onerrgo RIEN
RESULT_FROM = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
RESULT_UNTIL = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
PAY_DATE = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
Onerrgo
End

##################################
Subprog GET_MONTHLY(RESULT_FROM, RESULT_UNTIL, MONTH_INDICATOR, YEAR_INDICATOR)
Variable Date RESULT_FROM
Variable Date RESULT_UNTIL
Value Integer MONTH_INDICATOR
Value Integer YEAR_INDICATOR

Local Integer CURRENT_MONTH : CURRENT_MONTH = month(GMOIPAY) ##month(date$)
Local Integer YEAR_TO_USE: YEAR_TO_USE = year(GMOIPAY) ##year(date$)

If YEAR_INDICATOR < 0
 YEAR_TO_USE = YEAR_TO_USE + YEAR_INDICATOR
Endif

If MONTH_INDICATOR > 0 and MONTH_INDICATOR <= 12 #month number
 RESULT_FROM = gdat$(1, MONTH_INDICATOR, YEAR_TO_USE)
Elsif MONTH_INDICATOR < 0 #month difference
 RESULT_FROM = addmonth(gdat$(1, CURRENT_MONTH, YEAR_TO_USE), MONTH_INDICATOR)
Else #current month
 RESULT_FROM = gdat$(1, CURRENT_MONTH, YEAR_TO_USE)
Endif

RESULT_UNTIL = addmonth(RESULT_FROM, 1) - 1
End

##################################
Subprog GET_QUARTERLY(RESULT_FROM, RESULT_UNTIL, QUARTER_INDICATOR, YEAR_INDICATOR)
Variable Date RESULT_FROM
Variable Date RESULT_UNTIL
Value Integer QUARTER_INDICATOR
Value Integer YEAR_INDICATOR

Local Integer CURRENT_YEAR: CURRENT_YEAR = year(GMOIPAY) ##year(date$)
Local Integer QUARTER_TO_USE
Local Integer CURRENT_QUARTER
Local Integer START_MONTH
Local Integer END_MONTH

Case month(GMOIPAY) ##(date$)
 When 1, 2, 3
  CURRENT_QUARTER = 1
 When 4, 5, 6
  CURRENT_QUARTER = 2
 When 7, 8, 9
  CURRENT_QUARTER = 3
 When 10, 11, 12
  CURRENT_QUARTER = 4
Endcase
If QUARTER_INDICATOR > 0 and QUARTER_INDICATOR <= 4
 QUARTER_TO_USE = QUARTER_INDICATOR
Else
 #[**DBA pour P14
  #QUARTER_TO_USE = CURRENT_QUARTER
  If CURRENT_QUARTER > abs(QUARTER_INDICATOR)
   QUARTER_TO_USE = CURRENT_QUARTER-abs(QUARTER_INDICATOR)
  Else
   QUARTER_TO_USE = 4-abs(QUARTER_INDICATOR)+CURRENT_QUARTER
   CURRENT_YEAR-=1
  Endif
 #**]
Endif
Case QUARTER_TO_USE
 When 1 : START_MONTH = 1 : END_MONTH = 3
 When 2 : START_MONTH = 4 : END_MONTH = 6
 When 3 : START_MONTH = 7 : END_MONTH = 9
 When 4 : START_MONTH = 10 : END_MONTH = 12
Endcase
RESULT_FROM = gdat$(1, START_MONTH, CURRENT_YEAR)
If YEAR_INDICATOR < 0
 RESULT_FROM = addmonth(RESULT_FROM, 12 * YEAR_INDICATOR)
Endif
#[**DBA pour P14
 #If QUARTER_INDICATOR < 0
 # RESULT_FROM = addmonth(RESULT_FROM, 3 * QUARTER_INDICATOR)
 #Endif
#**]
RESULT_UNTIL = addmonth(gdat$(1, END_MONTH, year(RESULT_FROM)), 1) - 1
End

##################################
Subprog GET_HALFYEARLY(RESULT_FROM, RESULT_UNTIL, HALF_INDICATOR, YEAR_INDICATOR)
Variable Date RESULT_FROM
Variable Date RESULT_UNTIL
Value Integer HALF_INDICATOR
Value Integer YEAR_INDICATOR

Local Date REFERENCE_DATE
REFERENCE_DATE = addmonth(GMOIPAY, 12 * YEAR_INDICATOR) ##addmonth(date$, 12 * YEAR_INDICATOR)

If month(REFERENCE_DATE) > 6
  REFERENCE_DATE = gdat$(1, 7, year(REFERENCE_DATE))
Else
  REFERENCE_DATE = gdat$(1, 1, year(REFERENCE_DATE))
Endif
If HALF_INDICATOR = 1
  REFERENCE_DATE = gdat$(1, 1, year(REFERENCE_DATE))
Elsif HALF_INDICATOR = 2
  REFERENCE_DATE = gdat$(1, 7, year(REFERENCE_DATE))
Endif
If HALF_INDICATOR < 0
  REFERENCE_DATE = addmonth(REFERENCE_DATE, 6 * HALF_INDICATOR)
Endif
RESULT_FROM = REFERENCE_DATE
RESULT_UNTIL = addmonth(RESULT_FROM, 6) - 1
End

##################################
Subprog GET_ANNUALLY(RESULT_FROM, RESULT_UNTIL, YEAR_INDICATOR)
Variable Date RESULT_FROM
Variable Date RESULT_UNTIL
Value Integer YEAR_INDICATOR

RESULT_FROM = gdat$(1, 1, year(GMOIPAY)) ##gdat$(1, 1, year(date$))
If YEAR_INDICATOR < 0
  RESULT_FROM = addmonth(RESULT_FROM, 12 * YEAR_INDICATOR)
Endif
RESULT_UNTIL = addmonth(RESULT_FROM, 12) - 1
End

##################################
Funprog IS_EMP_CHILD_TABLE(TABLENAME)
Value Char TABLENAME
Local Shortint EXISTS
Local File ATABIND [ATI]
If left$(TABLENAME,5) = "EMPLO"
  For [F:ATI] Where [F:ATI]CODFIC = TABLENAME
    If [F:ATI]DESCRIPT = "REFNUM+NUMLIG" or [F:ATI]DESCRIPT = "REFNUM+CTRNUM+NUMLIG"
      EXISTS = 1
      Break
    Endif
  Next
Endif
End EXISTS

##################################
Funprog EMP_FIELD_DIMENSION(TABLENAME, FIELDNAME)
Value Char TABLENAME
Value Char FIELDNAME
Local Shortint DIMENSION
Local File DICOEMP [DIC]

Read [DIC]DIC3 = TABLENAME;FIELDNAME
If !fstat
  DIMENSION = [F:DIC]FLDDIM
Endif

End DIMENSION

##################################
Funprog VERIFY_FIELD_AND_INDEX_EXIST(TABLENAME, FIELDNAME, INDEX, ROW)
Value Char TABLENAME
Value Char FIELDNAME
Value Integer INDEX
Value Integer ROW
Local Shortint RESULT
Local Shortint LINE
Local Char FIELDSCREENNAME(250)

RESULT = 0

For LINE = 0 To [M:DIB]BPAG -1
  If [M:DIB]CODFIC(LINE) = TABLENAME and [M:DIB]CODZONE(LINE) = FIELDNAME and [M:DIB]IND(LINE) = INDEX
    RESULT = 1
    Break
  Endif
Next LINE

#check if a value has been entered for the field
If RESULT <> 0
  FIELDSCREENNAME = "[M:GEN]" + FIELDNAME
  If INDEX <> 0
    FIELDSCREENNAME = FIELDSCREENNAME + "_" + num$(INDEX)
  Endif
  FIELDSCREENNAME = FIELDSCREENNAME + "(" + num$(ROW) + ")"
  RESULT = evalue("varinit(" + FIELDSCREENNAME + ")")
Endif

#double check a value has been entered for the field!
If RESULT <> 0
  If evalue ("num$(" + FIELDSCREENNAME + ")")="" or evalue("num$(" + FIELDSCREENNAME + ")")="0"
    RESULT = 0
  Endif
Endif

End RESULT

##################################
# Function to count number of child record attached to an employee
# e.g. number of emplochd, emplorib etc..
Funprog COUNT_EMP_RECS(TABLENAME,EMPREF)
  Value Char TABLENAME
  Value Char EMPREF
  Local Integer NUM_RECORDS
  Local File=TABLENAME [CNT] Where REFNUM = EMPREF
  NUM_RECORDS = rowcount([CNT])
  Close Local File [CNT]
End NUM_RECORDS


