#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AOW",GBIDC1,GBIDC2) From GOBJET
End
#######################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "FIN"      : Gosub FIN
 When "OK"       : Gosub OK
Endcase
Return
#######################################################
$DEBUT
If [M:AOW0]FILEXT<>""
 [M:AOW2]NOMEXP = [M:AOW0]FILEXT
 If GOS(1)="unix"
  If pat([M:AOW0]FILEXT,"|:\") or instr(1,[M:AOW0]FILEXT,"\")
   [M:AOW2]TYPEXP = 1
  Else
   [M:AOW2]TYPEXP = 2
  Endif
 Else
  [M:AOW2]TYPEXP = 2
 Endif
Else
 [M:AOW2]NOMEXP = [F:AOE]FILEXT
 [M:AOW2]TYPEXP = [F:AOE]TYPEXP
Endif
Affzo
Return

$OUVRE
Local Char    QUOTE(10), SEPDEC(1), MESSAGE(255)
Local Char    NOMTRT(GLONADC) , FLDS(255)
Local Char    TRTSRC(GDIMFIC)
Local Char    FICDON(GDIMFIC) , FICTMP(GDIMFIC)
Local Char    REPTMP(GDIMFIC) , FICBAS(GDIMFIC) , FICCRE(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10) , CHAINE(250)
Local Char    REPERT(GDIMFIC) , FICDONCLI(GDIMFIC)
Local Char    SEPCHP(4) , SEPENR(8) , SEPDEC(1)
Local Char    SEPREC(5)(dim([F:AOE]FLGREC))
Local Integer ER,I,II,CPT,TYPFMT,IMPSTA,STA,NBEXP
Local Char    SAVIFS(10) , SAVIRS(10)
Local Integer SAVIUM
Local Char    SAVLOT(10)
Local Decimal SAVNUM(9)

If clalev([F:APX]) =0 : Local File APARIMPEXP    [APX] : Endif
If clalev([F:AOE]) =0 : Local File AOBJEXT        [AOE] : Endif

Read [AOE]AOE0 = [M:AOW0]EXT
If fstat : FIN = 1 : Return : Endif

Read [AOW]AOW0 = [M:AOW0]NUMLOT
If fstat : FIN = 1 : Return : Endif

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
SAVLOT = [M:AOW0]NUMLOT
SAVNUM = [M:AOW0]NUMLIG

If [F:AOE]FLDLIM="'"
 QUOTE = '"'+"'"+'"'
Else
 QUOTE = "'"+[F:AOE]FLDLIM+"'"
Endif

SEPCHP = [F:AOE]SEPFLD
SEPENR = [F:AOE]SEPREC
SEPDEC = [F:AOE]SEPDEC : If SEPDEC="" : SEPDEC = "." : Endif

I = 1
$SEP1
I = instr(1,SEPCHP,"\")
If I
 SEPCHP = left$(SEPCHP,I-1)+chr$(val(mid$(SEPCHP,I+1,3)))+right$(SEPCHP,I+4)
 I += 1
 Goto SEP1
Endif

I = 1
$SEP2
I = instr(1,SEPENR,"\")
If I
 SEPENR = left$(SEPENR,I-1)+chr$(val(mid$(SEPENR,I+1,3)))+right$(SEPENR,I+4)
 I += 1
 Goto SEP2
Endif

$SEP3
For J=0 To dim([F:AOE]FLGREC)-1
 SEPREC(J) = [F:AOE]FLGREC(J)
Next J

Gosub COMPILE From SUBEXPAOW

If [L]NOMTRT<>""
 GMESSAGE = ""
 Call VALID("TRT",NOMTRT,nomap,OK) From VALMSKSUB
 If !OK : IMPSTA = 7 : Gosub ERREUR : Return: Endif
Endif
Return
#######################################################
$FIN
If IMPSTA<8
 Call EFFACE(TRTSRC,STA) From ORDSYS
 Call EFFACE_ADX("","",NOMTRT,STA) From ORDSYS
Endif
Return

#######################################################
$OK
If [L]NOMTRT=""
 Return
Endif

FICDON = [M:AOW2]NOMEXP
If [M:AOW2]TYPEXP=1 : # Client
 FICDONCLI = FICDON
 Call SET_FICNAM(FICDONCLI,FICDON,CHAINE) From ORDSYS
Else
 FICDONCLI = ""
Endif
FICTMP = FICDON

ER = 0
Onerrgo ERFIC
Openo FICTMP , 0 Using [AEXP]
Onerrgo
If ER
 IMPSTA = 5 : GBIDC3 = FICTMP : Gosub ERREUR : Return
Endif

Case [F:AOE]TYPFIL
 When 1 : adxirs = SEPCHP : adxifs = ""
 When 2 : adxirs = SEPENR : adxifs = SEPCHP
 When 3 : adxirs = SEPENR : adxifs = SEPCHP
 When 4 : adxirs = SEPENR : adxifs = ""
 When 5 : adxirs = SEPENR : adxifs = SEPCHP
 When 6 : adxirs = SEPENR : adxifs = SEPCHP
Endcase

Case [F:AOE]CODDBA
 When 1 : adxium = GASCII
 When 2 : adxium = GUTF8
 When 3 : adxium = GUCS2
Endcase

ER = 0
NBEXP = 0

Call EXPORT(NBEXP,SEPREC,ER) From =NOMTRT
If ER : IMPSTA = 8 : Endif

Openo Using [AEXP]

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

If IMPSTA=0 & FICDONCLI<>""
 Call COPCLI(FICDON,FICDONCLI,STA) From ORDSYS
 If STA=1
  IMPSTA = 19 : GBIDC3 = FICDONCLI
 Elsif STA>1
  IMPSTA = 5 : GBIDC3 = FICDONCLI-"("+num$(STA)+")"
 Endif
Endif

If FICDONCLI<>""
 If len(FICDONCLI)<80
  FICCRE = FICDONCLI
 Else
  Call SETNAM(FICDONCLI,FICCRE,CHAINE) From GOBJTXT
  FICCRE += "."+CHAINE
 Endif
Else
 If len(FICDON)<80
  FICCRE = FICDON
 Else
  Call SETNAM(FICDON,FICCRE,CHAINE) From GOBJTXT
  FICCRE += "."+CHAINE
 Endif
Endif

If IMPSTA=0
 Gosub SAV_EXTFIL
 If GOK=1
  [M:AOW0]FILEXT = [F:AOW]FILEXT
  Affzo [M:AOW0]FILEXT
 Endif
Endif

# Lignes exportées/Fichier
If IMPSTA=0 & [L]NOMTRT<>""
 Call ECR_TRACE('|'+num$(NBEXP)-mess(82,141,1)-'('+mess(55,100,1)-FICCRE+')',0) From GESECRAN
Else
 Gosub ERREUR
Endif

Return

#######################################################
$ERREUR
Call ERR_EXPORT(IMPSTA,MESSAGE) From GEXPOBJ
Call MESSAGE(MESSAGE) From GESECRAN
Return
#######################################################
$ERFIC
ER = errn
Resume
#######################################################
$SAV_EXTFIL
GOK=1
Trbegin [AOW]
 For [AOW] Where NUMLOT=[M:AOW0]NUMLOT
  If FICDONCLI<>""
   [F:AOW]FILEXT = FICDONCLI
  Else
   [F:AOW]FILEXT = FICDON
  Endif
  Rewrite [AOW]
  If fstat
   GOK = 0 : Call FSTA("AOW") From GLOCK : Break
  Endif
 Next AOW
 If GOK<1
  Rollback
 Else
  Commit
 Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran EXPAOW) 05/12/2006 11:44:57 (CCL)
######################################################################################
Subprog AS_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Diszo NOMEXP
Else
 Actzo NOMEXP
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
Call SET_NOMFIC([F:AOE]FILEXT,[M]NOMEXP,VALEUR)
If VALEUR=1
 Grizo NOMEXP
Else
 Actzo NOMEXP
Endif
End

Subprog AS_NOMEXP(VALEUR)
Variable Char VALEUR
End

Subprog SET_NOMFIC(FICHIER,NOMEXP,TYPEXP)
Value Char FICHIER
Variable Char NOMEXP
Value Integer TYPEXP
Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)
NOMEXP = FICHIER
If TYPEXP=1
 Call SET_NAMCLI(NOMEXP) From ORDSYS
Elsif !instr(1,NOMEXP,"@") & !find(left$(NOMEXP,1),"/") & !pat(left$(NOMEXP,3),"!:\")
 Call GETREP("REPEXPDEF",REPERT) From SUBEXPOBJ
 If REPERT<>""
  Call MACHINE(REPERT,MACHINE,REPERT) From ORDSYS
  Call SETFIC(REPERT,FICHIER,MACHINE,NOMEXP) From SUBEXPOBJ
 Endif
Endif
End

Subprog C_NOMEXP(VALEUR)
Variable Char VALEUR()
Local Integer ER , K
Local Char    REPERT(GDIMFIC) , FICHIER(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)
Local Char    NAM(GDIMFIC) , SUF(30)


#Local Char FICPATCH(250)
#
#Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
#mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, VALEUR,[L]FICPATCH,E_TYPE_FILEOVERWRITE,GMESSAGE)
#
#End

If VALEUR=""
 GMESSAGE = mess(35,126,1) : # Nom de fichier incorrect
 mkstat=1 : End
Elsif left$(VALEUR,1)="#"
 GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
 mkstat = 2 : End
Endif
Call MACHINE(VALEUR,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat = 2 : End
Elsif OS="unix"
 If pat(left$(REPERT,3),"!:\")
  GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
  mkstat = 2 : End
 Elsif left$(REPERT,1)="\"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : End
 Endif
Else
 If left$(REPERT,1)="/"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : End
 Endif
Endif
Raz ER
Call EXISTE(VALEUR,ER) From ORDSYS
Case ER
 When 2 : # répertoire
  GMESSAGE = mess(55,141,1) : # Ce fichier est un répertoire
  mkstat = 2 : End
 When 0 : # fichier
  Call ABSOLU(VALEUR,ER) From ORDSYS
  If ER
   GMESSAGE = mess(160,100,1) : # Le chemin doit être indiqué en absolu
   mkstat = 2 : End
  Endif
  Call SETNAM(VALEUR,NAM,SUF) From GOBJTXT
  If SUF<>""
   NAM += "."+SUF
  Endif
  REPERT = left$(VALEUR,instr(1,VALEUR,NAM)-1)
  Call EXISTE(REPERT,ER) From ORDSYS
  If ER<>2
   GMESSAGE = mess(9,141,1) : # Répertoire inexistant
   mkstat = 2 : End
  Endif
Endcase
End

Subprog AP_NOMEXP(VALEUR)
Variable Char     VALEUR
Local Integer OK
If [M]TYPEXP=2 & filinfo(VALEUR,0)>=0
 OK =2 : Call OUINON(mess(7,141,1),OK) From GESECRAN : # Fichier destination présent, effacement ?
 If OK<>2 : mkstat=2 : End : Endif
Endif
[M]NOMEXP = VALEUR
End
