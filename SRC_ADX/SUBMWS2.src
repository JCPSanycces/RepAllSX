#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du masque MWS2
$ACTION
Case ACTION
Endcase
Return

###########################################################################
## Lecture des lignes
#########################################################################
$LIENS
Local Integer I : I=0
#
Call RAZ_CLOB From ACLOB

[M:MWS2]NBLIG = 0
Read [CPV]CPV0=[M:MWS0]WST;[M:MWS0]WCRFCY
If fstat : Return : Endif
For I = 0 To 24
    If [F:CPV]STRDAT(I) = [0/0/0] : Break : Endif
    [M:MWS2]STRDAT(I)    =[F:CPV]STRDAT(I)
    [M:MWS2]ENDDAT(I)    =[F:CPV]ENDDAT(I)
    [M:MWS2]CODVAR(I)    =[F:CPV]CODVAR(I)
    [M:MWS2]VARTWD(I)    =[F:CPV]TWD(I)
    [M:MWS2]VARWSTNBR(I) =[F:CPV]WSTNBR(I)
    [M:MWS2]VARTEX(I)    =[F:CPV]VARTEX(I)
Next I
[M:MWS2]NBLIG = I
Return

#########################################################################
$VERIF_MOD
# Tri tableau sur date fin avant écriture
Sorta [M:MWS2]NBLIG [M:MWS2]NBLIG Order By [M:MWS2]STRDAT(indice)
Affzo [M:MWS2]5
Return

###########################################################################
## Modification des lignes
#########################################################################
$MODIF
Local Integer I, WRET

#
Readlock [CPV]CPV0=[M:MWS0]WST;[M:MWS0]WCRFCY
If fstat=1 : GOK=-1 : GLOCK="$"+"CAPVAR"-num$(I) : Return : Endif

For I=0 To 24
   If I < [M:MWS2]NBLIG
       [F:CPV]STRDAT(I)        =[M:MWS2]STRDAT(I)
       [F:CPV]ENDDAT(I)        =[M:MWS2]ENDDAT(I)
       [F:CPV]CODVAR(I)        =[M:MWS2]CODVAR(I)
       [F:CPV]TWD(I)           =[M:MWS2]VARTWD(I)
       [F:CPV]WSTNBR(I)        =[M:MWS2]VARWSTNBR(I)
       [F:CPV]VARTEX(I)        =[M:MWS2]VARTEX(I)
       # on a viré le texte
       If [M:MWS2]VARTEX(I)="" & [F:CPV]VARTEX(I) <> ""
          Call SUP_CLOB([F:CPV]VARTEX(I),WRET) From TRTX3TEX
       Elsif [M:MWS2]VARTEX(I) <> ""
          Call CRE_CLOB([F:CPV]VARTEX(I),WRET) From TRTX3TEX
       Endif
    Else
       [F:CPV]STRDAT(I)        =[0/0/0]
       [F:CPV]ENDDAT(I)        =[0/0/0]
       [F:CPV]CODVAR(I)        =""
       [F:CPV]TWD(I)           =""
       [F:CPV]WSTNBR(I)        =0
       [F:CPV]VARTEX(I)        =""
       Call SUP_CLOB([F:CPV]VARTEX(I),WRET) From TRTX3TEX

    Endif
Next I
If    fstat=0
    [F:CPV]UPDDAT = date$
    [F:CPV]UPDUSR = GUSER
    [F:CPV]EXPNUM = [C]EXPORT
    Rewrite [CPV]
Elsif fstat=5
    [F:CPV]WST           =[M:MWS0]WST
    [F:CPV]WCRFCY        =[M:MWS0]WCRFCY
    [F:CPV]CREDAT = date$
    [F:CPV]CREUSR = GUSER
    [F:CPV]EXPNUM = [C]EXPORT
    Write [CPV]
Endif

# pour tri
Gosub VERIF_MOD
Return

###########################################################################
## Création des lignes
#########################################################################
$CREATION
Local Integer I
# Issue 113358 - 2016-01-07 by BEEBE : initialize new row CPV/ close old row of previously selected WC
Raz [F:CPV]

[F:CPV]WST           =[M:MWS0]WST
[F:CPV]WCRFCY        =[M:MWS0]WCRFCY

For I=0 To [M:MWS2]NBLIG-1
    [F:CPV]STRDAT(I)        =[M:MWS2]STRDAT(I)
    [F:CPV]ENDDAT(I)        =[M:MWS2]ENDDAT(I)
    [F:CPV]CODVAR(I)        =[M:MWS2]CODVAR(I)
    [F:CPV]TWD(I)           =[M:MWS2]VARTWD(I)
    [F:CPV]WSTNBR(I)        =[M:MWS2]VARWSTNBR(I)
    [F:CPV]VARTEX(I)        =[M:MWS2]VARTEX(I)
    If [M:MWS2]VARTEX(I) <> ""
       Call CRE_CLOB([F:CPV]VARTEX(I),WRET) From TRTX3TEX
    Endif

Next I

[F:CPV]CREDAT = date$
[F:CPV]CREUSR = GUSER
[F:CPV]EXPNUM = [C]EXPORT

Write [CPV]
If fstat : GOK=0 : Call FSTA("CPV") From GLOCK : Endif

Return

###########################################################################
## Annulation des lignes
#########################################################################
$ANNULE
Local Integer WRET
Local Char    WNUMTEX (12)

Readlock [CPV]CPV0=[M:MWS0]WST;[M:MWS0]WCRFCY
If fstat=1 : GOK=-1 : GLOCK="$"+"CAPVAR"-num$(I) : Return : Endif

For I = 0 To 24
    Call SUP_CLOB([F:CPV]VARTEX(I),WRET) From TRTX3TEX
Next I

Delete [CPV]

Return


########################################
$ABANDON
Local Integer WRET, I
If GREP = "D"
   For I=0 To [M:MWS2]NBLIG-1
          Call SUP_CLOB([M:MWS2]VARTEX(I),WRET) From TRTX3TEX
   Next I
Endif
Call RAZ_CLOB From ACLOB
Return


########################################
Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0]
    If nolign = 1
        VALEUR = date$
    Else
        VALEUR = [M:MWS2]ENDDAT(nolign-2) + 1
    Endif
Endif
End

########################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local    Integer I
If [M:MWS2]ENDDAT(nolign-1) <> [0/0/0] &
&  VALEUR          > [M:MWS2]ENDDAT(nolign-1)
    mkstat = 2
    End
Endif
For  I = 0 To dim([M:MWS2]STRDAT)-1
     If  VALEUR >= [M:MWS2]STRDAT(I) & VALEUR <= [M:MWS2]ENDDAT(I) & I <> nolign-1
         GMESSAGE = mess(142,193,1) -num$(I+1)
         mkstat   = 1
         Break
     Endif
Next I
End

########################################
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0] : VALEUR = [M:MWS2]STRDAT(nolign-1) : Endif
End

########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer I

If VALEUR < [M:MWS2]STRDAT(nolign-1) : mkstat = 2 : Endif
For  I = 0 To dim([M:MWS2]STRDAT)-1
     If  [M:MWS2]STRDAT(nolign-1) < [M:MWS2]STRDAT(I) & VALEUR >= [M:MWS2]STRDAT(I)
         If   VALEUR <= [M:MWS2]ENDDAT(I)
              GMESSAGE = mess(142,193,1) -num$(I+1)
         Else GMESSAGE = mess(142,193,1) -num$(I+1)
         Endif
         mkstat = 1
         Break
     Endif
Next I

End

########################################
Subprog AS_VARTWD(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : VALEUR = [M:MWS1]TWD : Endif
End

########################################
Subprog C_VARWSTNBR(VALEUR)
Variable Decimal VALEUR

If [M:MWS2]VARTWD(nolign-1) = [M:MWS1]TWD & VALEUR = [M:MWS1]WSTNBR
    GMESSAGE = mess(143,193,1)
    mkstat = 1
Endif

# MM 08.02
#la valeur oui est interdite pour le regroupement si le poste est multi-exemplaire
If VALEUR >1
# Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields
    If dim([M:MWS1]GRPFLG)>0 & dim([M:MWS1]GRPHOR)>0 & [M:MWS1]GRPFLG<>1
        [M:MWS1]GRPFLG= 1 : Affzo [M:MWS1]GRPFLG
        [M:MWS1]GRPHOR= 0 : Grizo [M:MWS1]GRPHOR
        Call MESSAGE (mess(204,193,1)) From GESECRAN
    Endif
Endif

End


########################################
Subprog AS_NBLIG

If !GIMPORT
  If [M:MWS2]STRDAT(nolign-1) = [0/0/0]
      GBOUT1 = ""
      GBOUT2 = ""    # 15158 08.02 MM
      GBOUT3 = ""    # 15158 08.02 MM
  Else
      GBOUT1 =  mess(38,198,1)
      GBOUT2 =  mess(273,198,1)    # 15158 08.02 MM
      GBOUT3 =  mess(171,190,1)    # 15158 08.02 MM
  Endif
Endif

End


########################################
Subprog APRES_NBLIG
Local Integer NOL

Case status
    When 65:        # Annulation simple
                    NOL=nolign-1
                    Gosub SUP_TEX
    When 68,83:     # Annulation multiple
                    For NOL=nolign-1 To nolign1-1
                        Gosub SUP_TEX                # llc 08.01 10123
                    Next NOL
Endcase
End

#########################################################################
$SUP_TEX
Local Integer WRET

If[M:MWS2]VARTEX(NOL) <> ""
    WRET = 0
    Call SUP_CLOB([M:MWS2]VARTEX(NOL),WRET) From TRTX3TEX
Endif

Return

