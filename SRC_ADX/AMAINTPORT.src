######################################################################################
## Etiquette ajoutée par le superviseur (écran APR5) 08/10/2007 11:10:07 (CCORA)
######################################################################################
$SELUTIP
Local File APORTUSER [APU]
Raz TEXTE,TEX,NBTEX
TIT=""
Filter [APU] Where CODUSR>=toupper(VALEUR)
For [APU]
  If vireblc([F:APU]CODUSR,2)<>""
    NBTEX+= 1
    If NBTEX>100 : Break 1 : Endif
    TEX(NBTEX)   = [F:APU]CODUSR
    TEXTE(NBTEX) = [F:APU]CODUSR-[F:APU]TITELT
  Endif
Next
Filter [APU]
Return

# -------------------------------------------------------------------------------------

Subprog CONTROLALLPORT
If clalev([F:APU])=0  : Local File APORTUSER  [APU]  : Endif
If clalev([F:APA])=0  : Local File APORTTAB  [APA]  : Endif

Local Integer ERR,ERRTRACE
Local Char VALL1(200),MESSAG(120)

#  Contrôle des pages portail des utilisateurs
Call OUVRE_TRACE(mess(166,150,1)) From LECFIC


For [APU]
  Call CONTROLPORT([F:APU]CODUSR,MESSAG,ERR)
  ERRTRACE=0
  If ERR<>0 : ERRTRACE=1 : Endif
#

  Call ECR_TRACE([F:APU]CODUSR-"   "-mess(173,150,1)-num$([F:APU]NBTAB)-"     "-MESSAG,ERRTRACE) From GESECRAN

Next

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC


End


Subprog CONTROLPORT(USER,MESSAG,ERR)
Value Char USER
Variable Char MESSAG()
Variable Integer ERR


# Contrôle du portail de l'utilisateur USER
# ERR        0 :   OK
#            1 :   Utilisateur inexistant dans la table APORTUSER                            ------------   mess(168,150,1)
#            2 :   Un des codes onglet du portail est vide ou incorrect                      ------------   mess(169,150,1)
#            3 :   Un des onglets défini pour le portail n'existe pas dans la tableAPORTTAB  ------------   mess(170,150,1)
#            4 :   L'onglet ACTIF du portail n'existe pas                                    ------------   mess(171,150,1)
#            5 :   La valeur du compteur de dernier rang est incohérente dans la table       ------------   mess(172,150,1)

ERR=0 : MESSAG=mess(157,100,1)  : #  OK
If clalev([F:APU])=0  : Local File APORTUSER  [APU]  : Endif
If clalev([F:APA])=0  : Local File APORTTAB  [APA]  : Endif

Read [APU]APU0=toupper(USER)
If fstat<>0 
 ERR=1 : MESSAG=mess(168,150,1): End 
Endif

Local Integer I,MAXNUM,J,JM,MAXMOD

For I=0 To [F:APU]NBTAB-1
  If len([F:APU]CODTAB(I))<2
    ERR=2 : MESSAG=mess(169,150,1)
  Endif
  Read [APA]APA0=toupper(USER);[F:APU]CODTAB(I)
  If fstat<>0
    ERR=3 : MESSAG=mess(170,150,1)
  Endif
  J=val(right$([F:APU]CODTAB(I),2))
  If J>MAXNUM : MAXNUM=J : Endif
# Contrôle LASTMOD
  MAXMOD=0
  For JM=0 To [F:APA]NBMOD-1
     J=instr(1,[F:APA]CODMOD(JM),"M")
     K=val(right$([F:APA]CODMOD(JM),J+1))
     If K>MAXMOD : MAXMOD=K : Endif
  Next JM
  If [F:APA]LASTMOD<MAXMOD : ERR=5 : MESSAG=mess(172,150,1)-"APORTTAB" : Endif  
Next I
If ERR<>0 : End : Endif

# Contrôle ACTIF
If [F:APU]ACTIF<>"" and !find([F:APU]ACTIF,[F:APU]CODTAB(0..[F:APU]NBTAB-1))
  ERR=4 : MESSAG=mess(171,150,1) : End
Endif

# Contrôle LASTNUM
If [F:APU]LASTNUM<MAXNUM : ERR=5 : MESSAG=mess(172,150,1)-"APORTUSER" : Endif  

End


######################################################################################
## Etiquette ajoutée par le superviseur (écran APR5) 24/09/2012 14:49:23 (CCORA)
######################################################################################
Subprog C_UT1(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
  If left$(VALEUR,1)="_"
# La valeur doit correspondre à un code métier
    If clalev([F:AME])=0 : Local File AMETUTI [AME] : Endif
    Read [AME]AME0=right$(VALEUR,2)
    If fstat<>0
# Attention ! Code métier inexistant
      Call MESSAGE(mess(231,124,1)-":"-right$(VALEUR,2)) From GESECRAN
    Endif  
  Else
    Read [AUS]CODUSR=VALEUR
    If fstat<>0
# Attention ce code ne correspond pas à un code utilisateur X3
      Call MESSAGE(mess(174,150,1)) From GESECRAN
    Endif
  Endif    
Endif

End

Subprog AV_DUPFAV(VALEUR)
Variable Integer VALEUR
If [M]UT1="" or [M]INITSUPP=2 or [M]INITVIDE=2
  VALEUR=0
  mkstat=1
Endif
End


