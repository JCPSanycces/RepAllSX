######################################################################################
Subprog C_UT2(VALEUR)
Variable Char    VALEUR()
If [M]UT1="" : End : Endif
If [M]UT1=VALEUR
  mkstat=2
  GMESSAGE=mess(104,104,1) :# Les critères doivent être différents
Endif
If clalev([F:APU])=0  : Local File APORTUSER  [APU]  : Endif
Read [APU]APU0=VALEUR
If fstat<>0
  mkstat=2
  GMESSAGE=mess(23,100,1)
Endif
End


