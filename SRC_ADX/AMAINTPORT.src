######################################################################################
## Etiquette ajoutée par le superviseur (écran APR5) 08/10/2007 10:57:11 (CCORA)
######################################################################################
Subprog AP_INITVIDE(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz INITSUPP,UT2    
  Diszo INITSUPP,UT2
Else
  Actzo INITSUPP,UT2
Endif
End


Subprog AP_INITSUPP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz INITVIDE,UT2
  Diszo INITVIDE,UT2
Else
  Actzo INITVIDE,UT2
Endif
End

Subprog AP_UT2(VALEUR)
Variable Char    VALEUR()
If VALEUR=2
  Raz INITSUPP,INITVIDE
  Diszo INITSUPP,INITVIDE
Else
  Actzo INITSUPP,INITVIDE
Endif
End

Subprog CL_ALANCER(VALEUR)
Variable Char    VALEUR()
Local Integer ERR

If [M]UT1="" : End : Endif
If [M]INITVIDE=2
  Call INITABS([M]UT1) From ACREVIG
  Call MESSAGE(mess(18,7837,1)) From GESECRAN
  End
Endif
If [M]INITSUPP=2
  Call SUPTABS([M]UT1) From ACREVIG
  Call MESSAGE(mess(60,126,1)) From GESECRAN
  End
Endif
If [M]INITVIDE<>2 and [M]INITSUPP<>2 and [M]UT2<>""
  Call DUPTABS([M]UT2,[M]UT1,0,ERR) From ACREVIG
# duplication favoris
  If [M]DUPFAV=2
    Call DUPFAV([M]UT2,[M]UT1) From INTRUTILB
  Endif
  Call MESSAGE(mess(18,7837,1)) From GESECRAN
  End
Endif

End


