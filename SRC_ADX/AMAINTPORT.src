Subprog AP_UT1(VALEUR)
Variable Char    VALEUR()
If clalev([F:APU])=0  : Local File APORTUSER  [APU]  : Endif
Read [APU]APU0=toupper(VALEUR)
If fstat<>0 : End : Endif
Local Char SYMBPORT : SYMBPORT="PORT-"+VALEUR
Lock =SYMBPORT With lockwait=0
If fstat=1  
  mkstat=2
  GMESSAGE=mess(17,7837,1)    : #  Ce portail est bloqué en mise à jour
Else
  Unlock =SYMBPORT 
Endif

#If fstat<>0 or [F:APU]PIDUSE="" : End : Endif
#  -- Si le portail est bloqué on interdit la mise à jour 
#Local Mask PSADX [PSA]
#Call LISTE([F:APU]PIDUSE) From PSADX
#If [M:PSA]NBLIG=1
#  mkstat=2
#  GMESSAGE=mess(17,7837,1)    : #  Ce portail est bloqué en mise à jour
#Endif

End


