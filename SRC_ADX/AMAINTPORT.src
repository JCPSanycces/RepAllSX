######################################################################################
Subprog CL_LANCEVERIF(VALEUR)
Variable Char    VALEUR()
Call CONTROLALLPORT
End


######################################################################################


Subprog CL_ARECH(VALEUR)
Variable Char    VALEUR()
If clalev([F:AMO])=0  : Local File APORTMOD  [AMO]  : Endif
If clalev([F:APA])=0  : Local File APORTTAB  [APA]  : Endif
Local Integer NBUS
Local Char CTAB
Effzo [M]15
Filter [AMO] Where VIGNETTE=[M]VIGNETTE
For [AMO]
    [M]AUT1([M]NBLIG)=[F:AMO]CODUSR
    Read [APA]APA0=[F:AMO]CODUSR;[F:AMO]CODTAB
    If fstat=0
      [M]ATAB([M]NBLIG)=[F:APA]TITELT
    Else
      Raz [M]ATAB([M]NBLIG)
    Endif
    [M]AMOD([M]NBLIG)=[F:AMO]TITELT
    [M]NBLIG+=1
    If [M]NBLIG=499 : Break 1 : Endif
Next
Filter [AMO]
[M]NBUST=[M]NBLIG
Affzo [M]
End


