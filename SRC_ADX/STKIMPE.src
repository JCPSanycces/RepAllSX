#<AdxTL>@(#)7.0.0.0 $Revision$
########################################################################
# Traitement STKIMPE - Librairie des composants de màj stock      V140 #
#                      Import entrée                          MBT 2003 #
########################################################################
# Etiquette appelée par Gosub depuis le STKIMP                         #
#                                                                      #
# ENTREES     : Traitement de l'import des entrées en stock            #
#                                                                      #
########################################################################


$ENTREES
If GSTK_TRACE=2 & GSTK_ACTION<>"IMP_ZONE"
  GSTK_ACT=GSTK_ACTION : GSTK_PGM="STKIMPE" : Gosub TRACE_DETAILLEE From STKIMP
Endif
Case GSTK_ACTION
  When "OUVRE"       : Gosub OUVRE
  When "RAZCRE"      : Gosub RAZCRE
  When "SAIMSK"      : Gosub SAIMSK
  When "IMP_ZONE"    : Gosub IMP_ZONE
  When "RUPT_LIGDOC" : Gosub RUPT_LIGDOC
  When "VALID"       : Gosub VALID
  When "IMP_FERME"   : Gosub IMP_FERME
Endcase
Return


#--------------#
# Début import #
#--------------#
$OUVRE
#----- Variables globales -----#
Global Integer  GSTK_NBLIG              : # Nbre lignes document
Global Char     GSTK_TRSCOD(GLONADI)    : # Code mouvement
Global Char     GSTK_ENTCOD(GLONGAU)    : # Code pièce auto
#----- Globales spécifiques aux composants d'entrée -----#
Global Char     GSAIFLG(15)
Global Char     GCHPSTO(GLONAVA)(1..15)
Global Char     GFILLOCENT(255)
Global Integer  GMAJLIGDOC
Global Decimal  GQTYPHY
#----- Locales spécifiques aux composants d'entrée -----#
Local  Integer  LOUVAUTO
Local  Char     LBOI(GLONFEN)
Local  Integer  LTYP
Local  Char     LFIC(4)
Local  Integer  LLIGDOC
Local  Char     LABR(4)
Local  Decimal  LQTYSTU
Local  Decimal  LCOEF
Local  Char     LPCU(GLONUOM)
Local Decimal   LQTYPCU    # hcb 160205 28512

Local  Integer  I
#----- Variables locales -----#
Local  Char     WSTK_ITMREF(GLONITM), WSTK_STOFCY(GLONFCY)
Local  Shortint WSTK_I, WSTK_J, WSTK_K
Local  Integer  WSTK_WSTOSEQ, WSTK_WRET, WSTK_NBLIGENT
Local  Char     WSTK_ABRMSK(10), WSTK_ANA(10)
Local  Char     WSTK_BPRNUM(GLONBPR)
Local  Char     WSTK_ABRTTR(5)
Local Date      WSTK_DLUDAT   #MAE, bg 84735
Local    Integer  WLTI

#----- Chargement abréviation du masque des lignes du document -----#
[L]WSTK_ABRMSK=mid$(GSTK_BASTAB,4,instr(1,GSTK_BASTAB,"]")-4)
#----- Principaux contrôles sur le modèle -----#
If find("[F:STJ]QTYPCU(0)",[M:AOE2]ZONMSK1) &
& !find("[F:STJ]PCU(0)",[M:AOE2]ZONMSK1)
  [L]WSTK_WRET=1 : Gosub TRT_ERREUR : Return : # Qté en UC sans l'UC !
Endif
If find("[F:STJ]ACTQTY(0)",[M:AOE2]ZONMSK1) &
& !find("[F:STJ]LOT(0)",[M:AOE2]ZONMSK1)    &
& !find("[F:STJ]POT(0)",[M:AOE2]ZONMSK1)    &
& !find("[F:STJ]ACT(0)",[M:AOE2]ZONMSK1)
  [L]WSTK_WRET=2 : Gosub TRT_ERREUR : Return : # Qté en Uactive et ni lot, ni titre !
Endif
#----- Ouverture fichiers si nécessaire -----#
If !clalev([F:TUN])  Local File TABUNIT   [TUN]  : Endif
If !clalev([F:TCO])  Local File TABCOEFF  [TCO]  : Endif
If !clalev([F:STL])  Local File STOLOT    [STL]  : Endif
If !clalev([F:ACV])  Local File ACTIV     [ACV]  : Endif                          # hcb X3-85853
If !clalev([F:LPN])  Local File LPN       [LPN]  : Endif                          # hcb X3-85853
#----- Ouverture masques écrans si nécessaire -----#
If !clalev([M:ENT])  Local Mask STOENT    [ENT]  : Raz [M:ENT]  : Endif
If !clalev([M:ENTL]) Local Mask STOENTLOT [ENTL] : Raz [M:ENTL] : Endif
If !clalev([M:STA])  Local Mask STOANA    [STA]  : Raz [M:STA]  : Endif

Return


#-----------------------------#
# Nouveau document à importer #
#-----------------------------#
$RAZCRE
Raz GSTK_NBLIG

Return


#--------------------------------------------#
# Chargement masque écran des entrées STOENT #
#--------------------------------------------#
$SAIMSK

#----- Nouvelle ligne de document -----#
If !GSTK_NBLIG
  #----- Si article non géré en stock c'est fini ! -----#
  If [F:ITF]STOMGTCOD<2  Return : Endif
  #-----
  GSTK_NBLIG=evalue(GSTK_BASTAB)
  [L]WSTK_ITMREF=[F:ITM]ITMREF
  [L]WSTK_STOFCY=[F:ITF]STOFCY
  Gosub NOUV_LIGDOC
Endif
#                                                             # hcb X3-96610 deb
#[M:ENT]LOTACT = 1
[M:ENT]LOTACT = 0
#Read [ACV] CODACT = "LOT"
#If !fstat[M:ENT]LOTACT =[F:ACV]FLACT Endif
[M:ENT]LOTACT     = func AFNC.ACTIV("LOT")    # Is LOT activated ?
[M:ENT]LOTACT  +=1
#                                                             # hcb X3-96610 end

#----- Chargement d'une ligne de détail stock -----#
[M:ENT]NBLIG+=1
nolign=[M:ENT]NBLIG : indice=nolign-1
#--- Bug 65944
#status=73
If [M:ENT]QTYSTU(indice)<>0
   status=75 : # Ligne déjà chargée
Else
   status=73 : # Nouvelle ligne
Endif
#---
Default File [STJ]  : # Voir si utile ?
If GSTK_TRACE=2
  GSTK_ACT="SAI_NBLIG("+num$(indice)+")" : GSTK_PGM="W0STOENT" : Gosub TRACE_DETAILLEE From STKIMP
Endif
Default Mask [ENT]
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
Call SAI_NBLIG("STJ","IMP_ZONE","SUBIMPOBJ") From W0STOENT
Setmode
If mkstat
  GREP="" : REP="" : mkstat=0 : [L]WSTK_WRET=9 : Gosub TRT_ERREUR : Return
Endif

# hcb 54712
If dim(GCCE_STJ) > 0 & GCCE_STJ = 1
   For J=1 To GNBDIE
#       If  evalue("[F:STJ]CCE"+num$(J))  <> ""                  # hcb 69190 deb
#          [M:ENT]CCE(J-1)=evalue("[F:STJ]CCE"+num$(J))
        If [F:STJ]CCE(J-1)  <> ""
           [M:ENT]CCE(J-1)=[F:STJ]CCE(J-1)                       # hcb 69190 fin
       Endif
   Next J
   Default Mask [STA]
   For J=1 To GNBDIE : [M:STA]CCE(J-1)=[M:ENT]CCE(J-1) : Next J
   If GSTK_TRACE=2
      GSTK_ACT="SAIMSK" : GSTK_PGM="W0STOANA" : Gosub TRACE_DETAILLEE From STKIMP
   Endif
   Default Mask [STA]
   Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
   Call SAIMSK("STJ","IMP_ZONE","SUBIMPOBJ") From W0STOANA
   Setmode
   If mkstat  GREP="" : REP="" : mkstat=0 : GOK=0 : Return : Endif
   For J=1 To GNBDIE : [M:ENT]CCE(J-1)=[M:STA]CCE(J-1) : Next J
Endif
# hcb 54712

# hcb 50773
GPOINT = "STJTOENT"
Gosub  ENTREE From EXEFNC

#                                                                                 # hcb X3-85853 deb
#----- Chargement complément lot -----#
If [M:ENT]NUMLIGLOT([M:ENT]NBLIG-1)>0 & [M:ENT]GESLOTAFF([M:ENT]NBLIG-1)<>"B"
#                                                              # hcb 71276 deb
  If dim([M:ENT]ECCVALMAJ) > 0
     If find("[F:STJ]ECCVALMAJ(0)",[M:AOE2]ZONMSK1)
        If [F:STJ]ECCVALMAJ <> ""
           [M:ENT]ECCVALMAJ([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=[F:STJ]ECCVALMAJ
        Endif
     Endif
     If find("[F:STJ]ECCVALMIN(0)",[M:AOE2]ZONMSK1)
        If [F:STJ]ECCVALMIN <> ""
           [M:ENT]ECCVALMIN([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=[F:STJ]ECCVALMIN
        Endif
     Endif
  Endif
#                                                              # hcb 71276 fin
  #-----
  If find("[F:STJ]POT(0)",[M:AOE2]ZONMSK1)
    [M:ENT]POT([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=[F:STJ]POT
  Endif
  If find("[F:STJ]ACT(0)",[M:AOE2]ZONMSK1)
    [M:ENT]ACT([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=[F:STJ]ACT
  Endif
  If find("[F:STJ]SHLDAT(0)",[M:AOE2]ZONMSK1)
    [M:ENT]SHLDAT([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=[F:STJ]SHLDAT
    #MAE, bug 84735, recalcul de la date limite d'utilisation
    If [F:STJ]SHLDAT <> [0/0/0]
      Call CALDLU([F:ITM]EXYMGTCOD,[M:ENT]REFPER([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1)),
&     [M:ENT]SHLDAT([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1)),[M:ENT]DLU([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1)),
&     "",WSTK_DLUDAT,WLTI) From STKLIB
      [M:ENT]DLUDAT([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=WSTK_DLUDAT
    Endif
  Endif
  #MAE, bg 84735, import de la date limite d'utilisation uniquement si la date de péremption est vide
  If find("[F:STJ]DLUDAT(0)",[M:AOE2]ZONMSK1)
    If [F:STJ]SHLDAT=[0/0/0]
      [M:ENT]DLUDAT([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=[F:STJ]DLUDAT
    Endif
  Endif
  If find("[F:STJ]USRFLD1(0)",[M:AOE2]ZONMSK1)
    [M:ENT]USRFLD1([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=[F:STJ]USRFLD1
  Endif
  If find("[F:STJ]USRFLD2(0)",[M:AOE2]ZONMSK1)
    [M:ENT]USRFLD2([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=[F:STJ]USRFLD2
  Endif
  If find("[F:STJ]USRFLD3(0)",[M:AOE2]ZONMSK1)
    [M:ENT]USRFLD3([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=[F:STJ]USRFLD3
  Endif
  If find("[F:STJ]USRFLD4(0)",[M:AOE2]ZONMSK1)
    [M:ENT]USRFLD4([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=[F:STJ]USRFLD4
  Endif
  #-----
  If [M:ENT]POT([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=0
    [M:ENT]POT([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=100
  Endif
  If [M:ENT]ACT([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=0
    [M:ENT]ACT([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=1
  Endif
  [M:ENT]VALIDE([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))=2
#                                                              # hcb 71276 deb

  If dim([M:ENT]ECCVALMAJ) > 0
     If [F:ITM]ECCSTO > 1
        If [M:ENT]ECCVALMAJ([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1)) = ""
           [M:ENT]ECCSAIFLG([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1)) = 0
           Call STKINIECC([M:ENT]ITMREF,[F:STJ]LOT,"ENT",2,2,[M:ENT]NUMLIGLOT([M:ENT]NBLIG-1),2,[M:ENT]ECCVALMAJ([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1)),"ECCVALMAJ","ECCVALMIN","","",1,"") From STKACT
        Endif
        Call STKCTRECC([M:ENT]ITMREF,[M:ENT]ECCVALMAJ([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1)),[M:ENT]ECCVALMIN([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1)),[F:STJ]LOT,2) From STKACT
        If dim(GIMPORT_ERR) > 0
           If GIMPORT_ERR <> 0
              GREP=""
              REP=""
              mkstat=0
              GOK = 0
              GERR=1
              Gosub ECR_ERREUR
           Endif
        Endif
     Else
        Raz [M:ENT]ECCVALMAJ([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))
        Raz [M:ENT]ECCVALMIN([M:ENT]NUMLIGLOT([M:ENT]NBLIG-1))
     Endif
  Endif
Endif
#                                                              # hcb 71276 fin

Return

#                                                              # hcb 71276 deb
$ECR_ERREUR
Case GIMPORT_ERR
     When 50
# La version saisie n est pas active
          GMESSAGE=(mess(397,184,1)-" : "-[M:ENT]ITMREF-","-[F:STJ]LOT-","-[F:STJ]ECCVALMAJ-","-[F:STJ]ECCVALMIN)
     When 51
# La version saisie est differentre de celle du lot
          GMESSAGE=(mess(395,184,1)-" : "-[M:ENT]ITMREF-","-[F:STJ]LOT-","-[F:STJ]ECCVALMAJ-","-[F:STJ]ECCVALMIN)
     When 52
 # La version saisie est differentre de celle du lot
          GMESSAGE=(mess(395,184,1)-" : "-[M:ENT]ITMREF-","-[F:STJ]LOT-","-[F:STJ]ECCVALMAJ-","-[F:STJ]ECCVALMIN)
     When 53
# pas de version en cours !
          GMESSAGE=(mess(406,184,1)-" : "-[M:ENT]ITMREF-","-[F:STJ]LOT-","-[F:STJ]ECCVALMAJ-","-[F:STJ]ECCVALMIN)
     When 54
 # La version saisie est superieure à celle de  article site
          GMESSAGE=(mess(396,184,1)-" : "-[M:ENT]ITMREF-","-[F:STJ]LOT-","-[F:STJ]ECCVALMAJ-","-[F:STJ]ECCVALMIN)
     When 55
 # Version mineure inexistante !
          GMESSAGE=(mess(434,184,1)-" : "-[M:ENT]ITMREF-","-[F:STJ]LOT-","-[F:STJ]ECCVALMAJ-","-[F:STJ]ECCVALMIN)
     When 56
 # Version majeure ou mineure incorrecte !
          GMESSAGE=(mess(420,184,1)-" : "-[M:ENT]ITMREF-","-[F:STJ]LOT-","-[F:STJ]ECCVALMAJ-","-[F:STJ]ECCVALMIN)
#                                                                                 # hcb X3-85853 deb
     When 60
 # L emplacement saisi ne correspond pas à l'emplacment du no de contenant !
          GMESSAGE=(mess(523,184,1)-" : "-[F:STJ]LOC-"-->"-[F:LPN]LOC)
#                                                                                 # hcb X3-85853 deb

Endcase
Return
#                                                              # hcb 71276 fin

#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
# --------------------------------------- #
# IMPFIC : Abréviation du fichier (STJ)   #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
$IMP_ZONE
Case IMPZON
  When "BPSLOTAFF"
    If find("[F:STJ]BPSLOT(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE(BPSLOT)" : GSTK_PGM="STKIMPE"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      If [M:ENT]BPSLOTAFF(indice)<>[F:STJ]BPSLOT
        [M:ENT]BPSLOTAFF(indice)=[F:STJ]BPSLOT : IMPMOD=1
      Endif
      OK=0
    Endif
  When "LOTAFF"
    If find("[F:STJ]LOT(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE(LOT)" : GSTK_PGM="STKIMPE"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      If [M:ENT]LOTAFF(indice)<>[F:STJ]LOT
#                                                          # hcb 71276 deb
        If dim ([M:ENT]ECCVALMAJAFF) > 0
           [M:ENT]ECCVALMAJAFF(indice)=[F:STJ]ECCVALMAJ
           [M:ENT]ECCVALMINAFF(indice)=[F:STJ]ECCVALMIN
        Endif
#                                                          # hcb 71276 fin
        [M:ENT]LOTAFF(indice)=[F:STJ]LOT : IMPMOD=1
      Endif
      OK=0
    Endif
  When "SLOAFF"
    If find("[F:STJ]SLO(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE(SLO)" : GSTK_PGM="STKIMPE"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      If [M:ENT]SLOAFF(indice)<>[F:STJ]SLO
        [M:ENT]SLOAFF(indice)=[F:STJ]SLO : IMPMOD=1
      Endif
      OK=0
    Endif
  When "LOC"                             : #--- Bug 65601
    If find("[F:STJ]LOC(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE(LOC)" : GSTK_PGM="STKIMPE"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      If [M:ENT]LOC(indice)<>[F:STJ]LOC
        [M:ENT]LOC(indice)=[F:STJ]LOC : IMPMOD=1
      Endif
      OK=0
      If !find("[F:STJ]WRH(0)",[M:AOE2]ZONMSK1)
        If [F:STJ]LOC<>""
          If dim([M:ENT]WRH)>0 [M:ENT]WRH(indice)="" Endif
        Endif
      Endif
    Endif

#                                                 # hcb 106014 deb
  When "STA"
    If find("[F:STJ]STA(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE(STA)" : GSTK_PGM="STKIMPE"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      If [M:ENT]STA(indice)<>[F:STJ]STA
         [M:ENT]STA(indice)=[F:STJ]STA : IMPMOD=1
      Endif
      OK=0
    Endif
    If find("[F:STJ]LOC(0)",[M:AOE2]ZONMSK1)
       If [M:ENT]LOC(indice)<>[F:STJ]LOC
          [M:ENT]LOC(indice)=[F:STJ]LOC : IMPMOD=1
       Endif
    Endif
#                                                 # hcb 106014 fin
#                                                 # hcb 110327 deb
 When "SERNUM"
    If [F:ITM]SERMGTCOD = 4
       If find("[F:STJ]SERDEB(0)",[M:AOE2]ZONMSK1)
          If GSTK_TRACE=2
             GSTK_ACT="IMP_ZONE(SERDEB)" : GSTK_PGM="STKIMPE"
             Gosub TRACE_DETAILLEE From STKIMP
          Endif
          If [M:ENT]SERNUM(indice)<>[F:STJ]SERDEB
             [M:ENT]SERNUM(indice)=[F:STJ]SERDEB : IMPMOD=1
          Endif
          OK=0
       Endif
    Else
       If find("[F:STJ]SERNUM(0)",[M:AOE2]ZONMSK1)
          If GSTK_TRACE=2
             GSTK_ACT="IMP_ZONE(SERNUM)" : GSTK_PGM="STKIMPE"
             Gosub TRACE_DETAILLEE From STKIMP
          Endif
          If [M:ENT]SERNUM(indice)<>[F:STJ]SERNUM
             [M:ENT]SERNUM(indice)=[F:STJ]SERNUM : IMPMOD=1
          Endif
          OK=0
       Endif
    Endif

#                                                 # hcb 110327 fin
#                                                                                 # hcb X3-85853 deb
When "LPNNUM"
   If [F:ITF]LPNMGTCOD = 2
      Global Integer GIMPORT_ERR
      Raz GIMPORT_ERR
      If find("[F:STJ]LPNNUM(0)",[M:AOE2]ZONMSK1) & find("[F:STJ]LOC(0)",[M:AOE2]ZONMSK1)
         If [F:STJ]LPNNUM <> "" & [F:STJ]LOC <> ""
            Read [LPN]LPN0=[F:STJ]LPNNUM
            If fstat
               Raz [F:LPN]
            Endif
            If [F:LPN]LOC<>"" & [F:LPN]LOC <> [F:STJ]LOC
               GIMPORT_ERR = 60
               Gosub ECR_ERREUR
               If GTRACE<>""
                  Call ECR_TRACE(GMESSAGE,0) From GESECRAN
               Endif
               [F:STJ]LOC = [F:LPN]LOC
               [M:ENT]LOC(indice)=[F:STJ]LOC
            Endif
         Endif
      Endif
   Endif
#                                                                                 # hcb X3-85853 fin
When Default
    If find("[F:STJ]"+IMPZON+"(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE("+IMPZON+")" : GSTK_PGM="STKIMPE"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      If evalue("[M:ENT]"+IMPZON+"("+num$(indice)+")")<>evalue("[F:STJ]"+IMPZON)
        Assign "[M:ENT]"+IMPZON+"("+num$(indice)+")" With evalue("[F:STJ]"+IMPZON)
        IMPMOD=1
      Endif
      OK=0
    Endif
Endcase
Return


#----------------------------------------------#
# Avant transaction de màj du document importé #
# Si erreur OK=0                               #
#----------------------------------------------#
$VALID
If GSTK_NBLIG
  If GSTK_TRACE=2
    GSTK_ACT="RUPT_LIGDOC" : GSTK_PGM="STKIMPE" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
  Gosub RUPT_LIGDOC : Raz GSTK_NBLIG
Endif
Return


#------------#
# Fin import #
#------------#
$IMP_FERME
If dim(GSTK_NBLIG)>0 Kill GSTK_NBLIG, GSTK_TRSCOD, GSTK_ENTCOD : Endif
If dim(GSTK_MESS)>0  Kill GSTK_MESS,  GSTK_PGM,    GSTK_ACT    : Endif
Return


#-----------------------------------------------------------------#
# Nouvelle ligne de document : début chargement écran des entrées #
#-----------------------------------------------------------------#
$NOUV_LIGDOC
If GSTK_TRACE=2
  GSTK_ACT="NOUV_LIGDOC" : GSTK_PGM="STKIMPE" : Gosub TRACE_DETAILLEE From STKIMP
Endif
GSAIFLG    = "000000000000000"
GCHPSTO(1) = "PCU"
GCHPSTO(2) = "QTYPCU"
GCHPSTO(3) = "PCUSTUCOE"
GCHPSTO(4) = "STA"
GCHPSTO(5) = "LOCTYP"
GCHPSTO(6) = "LOC"
GCHPSTO(7) = "BPSLOTAFF"
GCHPSTO(8) = "LOTAFF"
GCHPSTO(10)= "SLOAFF"
GCHPSTO(11)= "SERNUM"
Raz GFILLOCENT, GMAJLIGDOC
#-----
[L]LOUVAUTO=0 : # Indicateur si détail ouvert par clic droit (0=clic droit)
[L]LBOI=""
[L]LTYP=GSTK_VCRTYP
[L]LFIC=[L]WSTK_ABRTTR
[L]LLIGDOC=GSTK_NBLIG-1
[L]LABR=[L]WSTK_ABRMSK
#-----
Default Mask "["+[L]WSTK_ABRMSK+"]"
Call LECFICENT([L]WSTK_STOFCY,[L]WSTK_BPRNUM,"",GSTK_NBLIG-1,GSTK_TRSTYP,
&              GSTK_TRSCOD,0) From STKECR
Default Mask [ENT]
Raz [M:ENT]
[M:ENT]STOFCY=[L]WSTK_STOFCY
[M:ENT]BPRNUM=[L]WSTK_BPRNUM
[M:ENT]TRSTYP=GSTK_TRSTYP
[M:ENT]TRSCOD=GSTK_TRSCOD
Gosub CHARG_PARAM_STOENT From TRTSTOENTA
#If [M:ENT]QTYENT=0  [L]WSTK_WRET=4 : Gosub TRT_ERREUR : Return : Endif
If [M:ENT]BPRNUM<>""
  Case [M:ENT]TRSTYP
    When  3      : [M:ENT]TYPBPR=1
    When 12      : [M:ENT]TYPBPR=2
    When Default : [M:ENT]TYPBPR=3
  Endcase
Else
  [M:ENT]TYPBPR=3
Endif
Default Mask [ENT]
#----- Lecture de la règle de gestion des stocks -----#
Call LECSRU([M:ENT]STOFCY,[F:ITM]TCLCOD,[M:ENT]TRSTYP,[M:ENT]TRSCOD,"",
&           [L]WSTK_WRET) From STKLIB
If [L]WSTK_WRET  [L]WSTK_WRET=5 : Gosub TRT_ERREUR : Return : Endif
#----- Positionnement de la variable globale GSAIFLG -----#
If [F:SRU]DACLOT=1  GSAIFLG=left$(GSAIFLG,7)+"2"+right$(GSAIFLG,9) : Endif
If mid$(GSAIFLG,11,1)<>"0" & [F:ITM]SERMGTCOD>1
  GSAIFLG="222"+right$(GSAIFLG,4)
Endif
#----- Positionnement de la variable GFILLOCENT (filtre type emplacement) -----#
If evalue("dim([F:"+[L]LFIC+"]SRGWAIFLG)")>0 & evalue("[F:"+[L]LFIC+"]SRGWAIFLG")<>2
  If GFILLOCENT=""
    GFILLOCENT="[F:TLO]LOCCAT<>2"
  Else
    GFILLOCENT=GFILLOCENT+"&[F:TLO]LOCCAT<>2"
  Endif
Endif
If evalue("dim([F:"+LFIC+"]CCECODS)")>0
  [M:ENT]CCECODS=evalue("[F:"+[L]LFIC+"]CCECODS")
Endif
#----- Chargement des lignes à partir des mouvements de stock du document origine -----#
Gosub LIGNE_STOENTW From TRTSTOENTA
If [M:ENT]COETOENT=0  [M:ENT]COETOENT=1 : Endif
#----- Alimentation des globales GTOTQTY, GQQQQTY et GRRRQTY -----#
# hcb 160205 28582  remplacement de [m] par  [m:ent] sur le 7 lignes suivantes
[M:ENT]PECQTY=sum([M:ENT]QTYSTU(0..max([M:ENT]NBLIG-1,nolign-1)))/[M:ENT]COETOENT
If dim(GTOTQTY)>0  GTOTQTY=[M:ENT]PECQTY : Endif
If dim(GQQQQTY)>0
  GQQQQTY=sigma(I=0,max([M:ENT]NBLIG-1,nolign-1),[M:ENT]QTYSTU(I)*(left$([M:ENT]STA(I),1)="Q"))
Endif
If dim(GRRRQTY)>0
  GRRRQTY=sigma(I=0,max([M:ENT]NBLIG-1,nolign-1),[M:ENT]QTYSTU(I)*(left$([M:ENT]STA(I),1)="R"))
Endif
#-----
If [L]LABR<>"SSL1"  [M:ENT]VCRTYP=[L]LTYP : Endif
[M:ENT]STU=[F:ITM]STU
[M:ENT]TABLE1=[L]LFIC
[M:ENT]COEFUCUS=[M:ENT]PCUTOENT+"="+format$("N:5.4",[M:ENT]COETOENT)-[F:ITM]STU
If evalue("[F:"+[M:ENT]TABLE1+"]PRNCOD1")=1  Raz [M:ENT]LBEFMT, [M:ENT]LBENBR  : Endif
#----- Désactivation des rubriques écrans suivant le contexte -----#
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
Gosub FORMAT_INV From STKLIB
#----- Choix traitement numéros de série -----#
If find([L]LTYP,6,12,15,19,23,27)
  If [F:ITM]SERMGTCOD=1 | ([F:ITM]SERMGTCOD=2 & [M:ENT]SERNUM(0)="")
    Gosub FORMAT_INV_ENT From STKLIB
  Endif
Endif
#-----
If left$(GWSINVSER,1)<>"-"
  If dim([M:ENT]SERNUMF)>0  Grizo [M:ENT]SERNUMF : Endif
Endif
#-----
Gosub DESACTIV_RUB From TRTSTOENTA
Setmode
#-----
[L]WSTK_NBLIGENT=[M:ENT]NBLIG
Raz [M:ENT]NBLIG
#----- Chargement de la désignation du mouvement si nécessaire -----#
If find("[F:STJ]MVTDES(0)",[M:AOE2]ZONMSK1) & [F:STJ]MVTDES<>""
  If GSTK_TRACE=2
    GSTK_ACT="IMP_ZONE(MVTDES)" : GSTK_PGM="STKIMPE"
    Gosub TRACE_DETAILLEE From STKIMP
  Endif
  [M:ENT]MVTDES=[F:STJ]MVTDES
Endif
Return


#-------------------------------#
# Rupture sur ligne de document #
#-------------------------------#
$RUPT_LIGDOC
Raz GSTK_NBLIG
If [L]WSTK_NBLIGENT>[M:ENT]NBLIG  [M:ENT]NBLIG=[L]WSTK_NBLIGENT : Endif
Raz [L]WSTK_WRET
If find(1,[M:ENT]WFLG)  [L]WSTK_WRET=6 : Gosub TRT_ERREUR : Return : Endif
Call ENRENT("ENT") From TRTSTOENTB
If mkstat  [L]WSTK_WRET=7 : Gosub TRT_ERREUR : Return : Endif
[L]LQTYSTU=sigma(I=0,[M:ENT]NBLIG-1,[M:ENT]QTYSTU(I))
[L]LPCU   =string$(!!(sigma(I=0,[M:ENT]NBLIG-1,([M:ENT]PCU(0)=[M:ENT]PCU(I)))=[M:ENT]NBLIG),
&         [M:ENT]PCU(0))
[L]LCOEF  =!!(sigma(I=0,[M:ENT]NBLIG-1,([M:ENT]PCUSTUCOE(0)=[M:ENT]PCUSTUCOE(I)))=[M:ENT]NBLIG)
&          *[M:ENT]PCUSTUCOE(0)

If LPCU <> "" & LCOEF <> 0                                    # hcb 160205 28512
    LQTYPCU    = sigma (I=0,[M:ENT]NBLIG-1,[M:ENT]QTYPCU(I))  # hcb 160205 28512
Endif                                                         # hcb 160205 28512



#----- Donne la main au document origine pour effectuer ses propres contrôles -----#
Gosub CTL_LIGNE_DOCUMENT From TRTSTOENTB
If mkstat  [L]WSTK_WRET=8 : Gosub TRT_ERREUR : Return : Endif
#----- Vérification que les compléments lots sont renseignés -----#
For I=1 To [M:ENT]NBLIGLOT-1
  If [M:ENT]VALIDE(I)=1 & find(I,[M:ENT]NUMLIGLOT)
    [L]WSTK_WRET=10 : Break
  Endif
Next
If [L]WSTK_WRET  Gosub TRT_ERREUR : Return : Endif
#-----
Gosub STOCKAGE_LIGNE     From TRTSTOENTA
Gosub MAJ_LIGNE_DOCUMENT From TRTSTOENTA
#----- Charge les champs stock sur la ligne du document -----#
If evalue("dim([M:"+LABR+"]MVTDES(LLIGDOC))")>0
  Assign "[M:"+LABR+"]MVTDES(LLIGDOC)" With [M:ENT]MVTDES
Endif
Assign "[M:"+LABR+"]WSTOFLG(LLIGDOC)"  With 1
Call LOAD_FROM_ENTW(LABR,LLIGDOC,[M:ENT]STOFCY,[M:ENT]WSTOSEQ,[M:ENT]ITMREF,
&                   [M:ENT]VCRTYPORI) From STKENT
#-----
GOUVENT   =0
GMAJLIGDOC=1
Return


#---------------------------------------------------------------------------------#
#                            Traitement des erreurs                               #
# ------------------------------------------------------------------------------- #
#  1 = Modèle d'import erroné : L'unité de conditionnement doit être paramétrée ! #
#  2 = Modèle d'import erroné : Le lot ou le titre doivent être paramétrés !      #
#  3 = La quantité est nulle, la ligne ne sera pas enregistrée                    #
#  4 = Quantité à entrer nulle !                                                  #
#  5 = xxxxxxxxxxxxxx : Règle de gestion des stocks introuvable !                 #
#  6 = Détail des entrées en stock erroné ! Erreur en ligne 999                   #
#  7 = Détail des entrées en stock erroné !                                       #
#  8 = Erreur après contrôle document d'origine !                                 #
#  9 = Erreur chargement ligne détail stock !                                     #
# 10 = Complément lot non renseigné ! Ereur en ligne 999                          #
#---------------------------------------------------------------------------------#
$TRT_ERREUR
Case [L]WSTK_WRET
  When  1 : GMESSAGE=mess(558,197,1)
  When  2 : GMESSAGE=mess(559,197,1)
  When  3 : GMESSAGE=mess(6,194,1)
  When  4 : GMESSAGE=mess(475,199,1)
  When  5 : GMESSAGE=mess(GSTK_TRSTYP,704,1)-":"-mess(476,199,1)
  When  6 : GMESSAGE=mess(582,197,1)-mess(93,100,1)-num$(find(1,[M:ENT]WFLG))
  When  7 : GMESSAGE=mess(582,197,1)
  When  8 : GMESSAGE=mess(583,197,1)
  When  9 : GMESSAGE=mess(580,197,1)
  When 10 : GMESSAGE=mess(581,197,1)-mess(93,100,1)-num$(I)
Endcase
If GTRACE<>""
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Else
  Call ERREUR(GMESSAGE)      From GESECRAN
Endif
[L]OK=0 : GOK=0
Return

