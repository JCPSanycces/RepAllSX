#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMTIMEMP
###################################################################################################
###################################################################################################
$ACONTROL
Local Integer IRET
Local Integer IDATCTRL
Local Integer ISTRPRD
Local Integer IENDPRD

  [L]ASTATUS = [V]CST_AOK
  # -----------------------------
  Local File PIMPL [PIM]
  Local File PJMTSKOPE [PTKO]
  # -----------------------------
  IDATCTRL = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.FCY, "PJMDATCTRL")
  If IDATCTRL = [V]CST_AYES and this.ASTALIN = [V]CST_ANEW Then
    ISTRPRD = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.FCY, "PJMSTRPRD")
    IENDPRD = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.FCY, "PJMENDPRD")
    If this.PTEDAT > date$ Then
      If IENDPRD < (this.PTEDAT - date$) Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(412,2260,1),num$(IENDPRD)), [V]CST_AERROR))
      Endif
    Endif
    If this.PTEDAT < date$ Then
      If abs(ISTRPRD) < (date$ - this.PTEDAT) Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(411,2260,1),num$(abs(ISTRPRD))), [V]CST_AERROR))
      Endif
    Endif
  Endif
  # -----------------------------
  If this.OPENUM > 0 Then
    If this.OPESPLNUM = 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESPLNUM", mess(18,9804,1), [V]CST_AERROR))
    Endif
    If this.PIMTASCOD = AVOID.ACHAR Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUM", mess(267,2260,1), [V]CST_AERROR))
    Else
      Read [PIM]PIM0=this.PIMTASCOD
      Read [PTKO]PTKO0=[F:PIM]OPPNUM;[F:PIM]TASCOD;this.OPENUM;this.OPESPLNUM
      If fstat Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUM", mess(243,107,1), [V]CST_AERROR))
      Else
        If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and (this.PTEQTY <> this.snapshot.PTEQTY or this.PIMPBUCOD <> this.snapshot.PIMPBUCOD or
&          this.PIMTASCOD <> this.snapshot.PIMTASCOD or this.OPENUM <> this.snapshot.OPENUM or this.PTEUOM <> this.snapshot.PTEUOM))
&       Then
          If [F:PTKO]OPESTA <> 4 Then
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUM", func AFNC.MES1(mess(271,2260,1), mess([F:PTKO]OPESTA,308,1)), [V]CST_AERROR))
          Endif
          # -----------------------------
          # Allowed period for time entries
          [L]ASTATUS = max([L]ASTATUS, fmet this.CTRL_PTEDAT(this.PTEDAT))
        Endif
      Endif
    Endif
  Else
    If this.OPESPLNUM <> 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESPLNUM", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  # -----------------------------
  If this.ASTALIN = [V]CST_ANEW or this.ASTALIN = [V]CST_AUPD Then
    If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.FCY, "PJMTIMTAS") <> [V]CST_AYES Then
      # Only if something has changed to manage the case of parameter value has been updated
      If this.PIMTASCOD <> AVOID.ACHAR and this.OPENUM = 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUM", mess(1016,2260,1), [V]CST_AERROR))
      Endif
    Endif
    # -----------------------------
    # Issue X3-100803 - 2018-07-16 by SINGC : START
    If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.FCY, "PJMTIMBUD") <> [V]CST_AYES Then
      # Only if something has changed to manage the case of parameter value has been updated
      If this.PIMTASCOD = AVOID.ACHAR and this.PIMPBUCOD <> AVOID.ACHAR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMPBUCOD", mess(1103,2260,1), [V]CST_AERROR))
      Endif
    Endif
    # Issue X3-100803 - 2018-07-16 by SINGC : END
  Endif
  # -----------------------------
Return

###################################################################################################
$AINSERT_CONTROL_BEFORE
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
Return

###################################################################################################
$AUPDATE_CONTROL_BEFORE
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
Return

###################################################################################################
$AINSERT_AUPDATE_CONTROL_BEFORE
Local Char KEYCONCAT(250)

  [L]ASTATUS = [V]CST_AOK
  # -----------------------------
  Local File OPPORPJM [OPPPJM]
  Local File PJMTSK [PTA]
  Local File PJMTSKOPE [PTKO]
  Local File PJMOPEAFF [PJOA]
  Local File PIMPL [PIM]
  Local File PIMPL [PIMB]
  Local File PIMPL [PIMP]
  Local File PJMCOSTCTR [PCC]
  # -----------------------------
  # FIRST STEP MANDADOTY AT THIS LEVEL : DATA STRUCUTRAL CHECKS
  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and
&   (this.PTEQTY <> this.snapshot.PTEQTY or this.PIMPBUCOD <> this.snapshot.PIMPBUCOD or
&    this.PIMTASCOD <> this.snapshot.PIMTASCOD or this.OPENUM <> this.snapshot.OPENUM or this.PTEUOM <> this.snapshot.PTEUOM))
& Then
    # -----------------------------
    # Control to do for a new record or if keys elements has been changed
    Read [PIMB]PIM0=this.PIMPBUCOD
    # -----------------------------
    If this.PIMTASCOD <> AVOID.ACHAR Then
      # -----------------------------
      Read [PIM]PIM0=this.PIMTASCOD
      Read [PIMP]PIM0=[F:PIM]OPPNUM
      # -----------------------------
      If [F:PIM]OPPNUM <> [F:PIMB]OPPNUM Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMPBUCOD", mess(266,2260,1), [V]CST_AERROR))
      Endif
      # -----------------------------
      # 1°) Get OPPNUM, TASCOD, PBUCOD from PIMTASCOD [F:PIM]TASSTATE
      this.OPPNUM = [F:PIM]OPPNUM
      this.TASCOD = [F:PIM]TASCOD
      this.PBUCOD = [F:PIM]PBUCOD
      # -----------------------------
      If this.FCY <> [F:PIM]FCY Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("FCY", mess(269,2260,1), [V]CST_AERROR))
      Endif
      If this.OPENUM > 0 Then
        # -----------------------------
        Filter [PJOA] Where [F:PJOA]OPPNUM = this.OPPNUM and [F:PJOA]TASCOD = this.TASCOD and [F:PJOA]OPENUM = this.OPENUM and [F:PJOA]OPESPLNUM = this.OPESPLNUM and [F:PJOA]POACLB = this.CLB
        For [PJOA]
          this.POANUM = [F:PJOA]POANUM
        Next
        Filter [PJOA]
        # Get the description from the operation/ work centre
        If this.PTEDESAXX = AVOID.ACHAR Then
          # Issue X3-68131 - 2018-02-12 by FGR : add context : BEGIN
          #KEYCONCAT = func PJMTSKOPE_CSTD_PROGS.GET_KEYCONCAT_VARIABLES(this.OPPNUM, this.TASCOD, this.OPENUM, this.OPESPLNUM)
          KEYCONCAT = func PJMTSKOPE_CSTD_PROGS.GET_KEYCONCAT_VARIABLES(this.ACTX, this.OPPNUM, this.TASCOD, this.OPENUM, this.OPESPLNUM)
          # Issue X3-68131 - 2018-02-12 by FGR : add context : END
          this.PTEDESAXX = func PJMTSKOPE_CSTD_PROGS.GET_ROODESAXX(this.ACTX, KEYCONCAT)
        Endif
      Else
        # -----------------------------
        # Get the description from the task
        If this.PTEDESAXX = AVOID.ACHAR Then
          this.PTEDESAXX = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(this.ACTX, this.PIMTASCOD)
        Endif
      Endif
      # -----------------------------
    Else
      Read [PIMP]PIM0=[PIMB]OPPNUM
      # -----------------------------
      # 2°) Get OPPNUM, PBUCOD from PIMPBUCOD
      this.OPPNUM = [F:PIMB]OPPNUM
      Raz this.TASCOD
      this.PBUCOD = [F:PIMB]PBUCOD
      # -----------------------------
      # Get the description from the budget
      If this.PTEDESAXX = AVOID.ACHAR Then
        this.PTEDESAXX = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(this.ACTX, this.PIMPBUCOD)
      Endif
    Endif
    # -----------------------------
    If [F:PIMP]OPPNUM = AVOID.ACHAR Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPNUM", mess(1067,2260,1), [V]CST_AERROR))
      Return       # Not necessary to continue in this error case.
    Endif
    Read [OPPPJM]OPPPJM0=[F:PIMP]OPPNUM
    If [F:OPPPJM]OPPSTATE <> 2 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPNUM", mess(204,2260,1), [V]CST_AERROR))
    Endif
    # -----------------------------
    If this.PIMTASCOD = AVOID.ACHAR Then
      If this.FCY <> [F:PIMB]FINRSPFCY Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("FCY", mess(270,2260,1), [V]CST_AERROR))
      Endif
      If this.OPENUM > 0 or this.OPESPLNUM > 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUM", mess(267,2260,1), [V]CST_AERROR))
      Endif
    Endif
    #If [L]ASTATUS <> [V]CST_AOK Then  # Issue X3-85806 - 2018-06-04 by FGR
    #If [L]ASTATUS < [V]CST_AERROR Then # Issue X3-85806 - 2018-06-04 by FGR
    If [L]ASTATUS >= [V]CST_AERROR Then # Issue number - 2018-08-24 by FGR : test was at the opposite
      # Strutural checks : It's not necessary to do something else if there is an error at this level
      Return
    Endif
  Else
    If this.OPPNUM <> this.snapshot.OPPNUM Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPNUM", mess(18,9804,1), [V]CST_AERROR))
    Endif
    If this.TASCOD <> this.snapshot.TASCOD Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASCOD", mess(18,9804,1), [V]CST_AERROR))
    Endif
    If this.PBUCOD <> this.snapshot.PBUCOD Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  If this.PJMPCC = AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.GET_PJMPCC(this.PJMPCC))
  Endif
  If this.PTEUOM = AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.GET_PTEUOM(this.PTEUOM))
  Endif
  If this.PJMCST = 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.GET_PJMCST(this.PJMPCC, this.PTEDAT, this.PTEUOM, this.CUR, this.CHGTYP, this.PTEQTY, this.PJMCST))
  Endif
  If this.CLBPCC = AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.GET_CLBPCC(this.CLBPCC))
  Endif
  If this.CLBCST = 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.GET_CLBCST(this.CLBPCC, this.PTEDAT, this.PTEUOM, this.CUR, this.CHGTYP, this.PTEQTY, this.CLBCST))
  Endif
Return

# Issue X3-111733 - 2018-10-08 by FGR : BEBIN : Move at PJMTIMEMPH level
