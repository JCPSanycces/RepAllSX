#<AdxTL>@(#)2.0.0.0 $Revision$
# Gestion du masque AVERIFSRC3
# CBO 2010.07.29 sélection des erreurs

$ACTION

    Case ACTION
        When "OUVRE"    : Gosub OUVRE
        When "DEBUT"    : Gosub DEBUT
        When "OK"       : Gosub OK
        When "ABA"      : Gosub ABA
    
    
    Endcase
Return

$OUVRE

Local Integer WCPTR

    GCONTROLE = 0
    If dim([M:DIA]VERIFCALL) >= 0 and [M:DIA]VERIFCALL = 2
        GCONTROLE = 1
    Elsif dim([M:DIA]VERIFVAR) >= 0 and [M:DIA]VERIFVAR = 2
        GCONTROLE = 2
    Elsif dim([M:DIA]VERIFMOD) >= 0 and [M:DIA]VERIFMOD = 2
        GCONTROLE = 3
    Elsif dim([M:DIA]VERIFTYPE) >= 0 and [M:DIA]VERIFTYPE = 2
        GCONTROLE = 4
    Elsif dim([M:DIA]VERIFAUT) >= 0 and [M:DIA]VERIFAUT = 2
        GCONTROLE = 9
    Endif
Return


$DEBUT
     
    nolign = 0
    [M:DI3]BASTAB = 0
    For WCPTR = 1 To GNBERREUR(GCONTROLE)
        
        If GBTDESACTIVE(GCONTROLE, WCPTR) = 0 and GTLIBERREUR(GCONTROLE, WCPTR) <> ""
            [M:DI3]NUMERREUR(nolign) = WCPTR
            [M:DI3]LIBERREUR(nolign) = GTLIBERREUR(GCONTROLE, WCPTR)
            [M:DI3]BASTAB += 1
            nolign += 1
        Endif
        
        If nolign  >= 30
            Break
        Endif
    
    Next
    
    Affzo [M:DI3]
    
Return



$ABA


Return

$OK

#    [M:DIA]LIBERREUR = [M:DI3]LIBERREUR(nolign - 1)
    [M:DIA]NUMERR = [M:DI3]NUMERREUR(nolign - 1)
    GAWNUMERR = [M:DIA]NUMERR
    Affzo [M:DIA]

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran AVERIFSRC3) 11-12-2010 11:18:46 (MB)
######################################################################################
Subprog S_BASTAB
End


