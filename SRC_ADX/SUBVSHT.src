#<AdxTL>@(#)10.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"      :
    Case GACTION
      When "VISUSHT" : Gosub OUVRE_SHT
    Endcase
  When "FERME"      : 
    Case GACTION
      When "VISUSHT" : Gosub FERME_SHT
    Endcase
  When "DEBUT"      :
    Case GACTION
      When "VISUSHT" : Gosub DEBUT_SHT
    Endcase
Endcase
Return
############################################################
# Visualisation opération
############################################################
$OUVRE_SHT
If clalev([F:FCY])= 0 : Local File FACILITY  [FCY] : Endif
If clalev([F:ITM])= 0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:ORD])= 0 : Local File ORDERS    [ORD] : Endif
Return
############################################################
$FERME_SHT
Return
############################################################
$DEBUT_SHT
Local Char     WFCY(GLONFCY) : WFCY = PARAM(1)
Local Char     WITM(GLONITM) : WITM = PARAM(2)
Local Decimal  WBES
Raz [M:VSHT]
Read [FCY]FCY0=WFCY
If fstat = 0
  [M:VSHT]FCY    = [F:FCY]FCY
  [M:VSHT]FCYSHO = [F:FCY]FCYSHO
Endif
Read [ITM]ITM0=WITM
If fstat
  FIN = 1
Endif
[M:VSHT]ITMREF  = [F:ITM]ITMREF
#[M:VSHT]ITMDES1 = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:VSHT]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:VSHT]STU0    = [F:ITM]STU
#
If [M:VSHT]FCY = ""
  Filter [ORD] Where (WIPTYP = 1 | WIPTYP = 6) &
&                     WIPSTA = 1               &
&                     ITMREF = WITM
&              Order By Key ORD1
Else
  Filter [ORD] Where (WIPTYP = 1 | WIPTYP = 6) &
&                     WIPSTA = 1               &
&                     STOFCY = WFCY            &
&                     ITMREF = WITM
&              Order By Key ORD1
Endif
# 
For [ORD]
  WBES = [F:ORD]RMNEXTQTY-[F:ORD]ALLQTY-[F:ORD]SHTQTY
  If WBES > 0
    [M:VSHT]REQNOTALLT += WBES
    If [M:VSHT]NBLIG < dim([M:VSHT]WIPTYPSTA)
      [M:VSHT]NBLIG += 1
      nolign   = [M:VSHT]NBLIG 
      [M:VSHT] = [F:ORD]
      [M:VSHT]WIPTYPSTA(nolign-1) = mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)
      [M:VSHT]STU      (nolign-1) = [F:ITM]STU
      [M:VSHT]REQNOTALL(nolign-1) = WBES
    Endif
  Endif
Next
Filter [ORD] 
Affzo [M:VSHT]
Return
