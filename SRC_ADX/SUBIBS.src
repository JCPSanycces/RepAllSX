# Traitement SUBIBS pour la consultation (LLC) des codes de plus bas niveau (TB)
################################################################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" [M]ITMREFFIN = VALEUR Endif
End

########################################
Subprog AM_BOMALTDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 [M]BOMALTFIN = VALEUR Endif
End


