#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque POP1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]COD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTPOP"
  Call CONTPOP([M]COD,"") From SUBPOP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJW"
   PARAM(1) = "POP"
   Local Char    VALEUR(250)
   VALEUR = [M]COD
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
   [M]COD = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varinit([M]DES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DES,"","","","") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DES,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 [M]LEG = GLEGFIL
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]LEG,"909","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]LEG,"909",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_LEG([M]LEG) From SUBPOP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]LEG or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_LEG([M]LEG) From SUBPOP
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone AUZPRH
mkstat = 0
zoncou = "AUZPRH"
indice = 0
IMPENT = [M]AUZPRH
If varinit([M]AUZPRH,indice)=0
 IMPENT = 1
Endif
If varmode([M]AUZPRH,indice)=0
 [M]AUZPRH(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "AUZPRH" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AUZPRH(indice)
 Endif
Endif
[M]AUZPRH = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRPOP
mkstat = 0
zoncou = "NBRPOP"
indice = 0
status = 1
zoncou = "NBRPOP"
If varmode([M]NBRPOP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRPOP" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRPOP
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRPOP = nolign
   status = 75
   Call SAI_NBRPOP(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBRMAT
mkstat = 0
zoncou = "NBRMAT"
indice = 0
status = 1
zoncou = "NBRMAT"
If varmode([M]NBRMAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRMAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRMAT
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRMAT = nolign
   status = 75
   Call SAI_NBRMAT(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone CRI
mkstat = 0
zoncou = "CRI"
indice = 0
If varmode([M]CRI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRI" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "AFRCONTB"
 Call C_FORMULE([M]CRI) From AFORMULEB
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CRI" : GZNUM = 13781 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone CMT
mkstat = 0
zoncou = "CMT"
For indice=0 To 2
 If varmode([M]CMT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CMT" : Gosub ACTION From =IMPTRT
  Endif
 Endif
 mkstat = 0
Next indice
If mkstat : End : Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRPOP(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRPOP
mkstat = 0
zoncou = "NBRPOP"

## Zone POP
mkstat = 0
zoncou = "POP"
WCHAR = [M]POP(indice)
If varmode([M]POP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POP" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]POP(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTPOP"
  Call CONTPOP([M]POP(indice),GCURLEG) From SUBPOP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("POP","$",[M]POP(indice),"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_POP([M]POP(indice)) From SUBPOP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]POP(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_POP([M]POP(indice)) From SUBPOP
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone POPLEG
mkstat = 0
zoncou = "POPLEG"
If varinit([M]POPLEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]POPLEG(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone NBRPOP
mkstat = 0
zoncou = "NBRPOP"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBRMAT(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRMAT
mkstat = 0
zoncou = "NBRMAT"

## Zone REFNUM
mkstat = 0
zoncou = "REFNUM"
WCHAR = [M]REFNUM(indice)
If varmode([M]REFNUM,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_REFNUM([M]REFNUM(indice)) From SUBPOP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]REFNUM(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "REFNUM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]REFNUM(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "DROITEMP"
   Call DROIT([M]REFNUM(indice),"","","") From DIVPAYE
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("EML","",[M]REFNUM(indice),"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]REFNUM(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_REFNUM([M]REFNUM(indice)) From SUBPOP
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone CTRNUM
mkstat = 0
zoncou = "CTRNUM"
WCHAR = [M]CTRNUM(indice)
If varmode([M]CTRNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CTRNUM(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTVCR"
  Call CONTVCR([M]CTRNUM(indice)) From TRTDIV
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CTR","",[M]CTRNUM(indice),"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CTRNUM([M]CTRNUM(indice)) From SUBPOP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]CTRNUM(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_CTRNUM([M]CTRNUM(indice)) From SUBPOP
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone MAJTYP
mkstat = 0
zoncou = "MAJTYP"
IMPENT = [M]MAJTYP(indice)
If varinit([M]MAJTYP,indice)=0
 IMPENT = 2
Endif
[M]MAJTYP(indice) = IMPENT

## Zone CTRLEG
mkstat = 0
zoncou = "CTRLEG"
If varinit([M]CTRLEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]CTRLEG(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone NBRMAT
mkstat = 0
zoncou = "NBRMAT"
status = 71
SAVACT = GACTION : GACTION = "STD"
Call APRES_NBRMAT From SUBPOP
GACTION = SAVACT

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "POP1"
Return

