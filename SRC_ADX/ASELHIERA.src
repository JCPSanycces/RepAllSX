#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Local Char    VALEUR(30), PARAM(250)(1..20)
VALEUR = "[ATT]/SUBATT/t1.docx"
#VALEUR = ""
PARAM(1) = "2"
PARAM(2) = "2": # WITHFILE : 1 folder,2files
PARAM(3) = "" : # [ATT]
#Call TRAITE_CHAR(VALEUR,PARAM,"","ASELHIERA","ASELHIERA",3,"XWASELHIERA") From GTRAITE
Call SAISIE_CHAR(VALEUR,PARAM,"ASELHIERA","ASELHIERA","SPEASELHIERA") From GSAISIE

End

######################################################################################
$ACTION
Case ACTION
 When "INIT","OUVRE"            : Gosub INIT
 When "INIT_DIA","DEBUT"       : Gosub INIT_DIA
 When "CONTROLE","AVANT_OK"     : Gosub CONTROLE
 When "SORTIE","FIN"       : Gosub SORTIE
 When "EXEC" ,"OK"          : Gosub EXEC
 When "END"            : Gosub SORTIE2
Endcase
Return

######################################################################################
$SORTIE2
GCONSDIA = SAV_GCONSDIA
VALEUR=SAVVALEUR
Return

######################################################################################
$SORTIE
GCONSDIA = SAV_GCONSDIA
If [M:ASEL]LOADFILE=2
 VALEUR  = ctrans([M:ASEL]SELECTED,"\","/")
 Return
Endif
Return

######################################################################################
$EXEC
VALEUR  = ctrans([M:ASEL]SELECTED,"\","/")
Return

######################################################################################
$CONTROLE
If [M:ASEL]WPATH=""
 If [M:ASEL]WITHFILE=1
  Call ERREUR(func AFNC.MES1(mess(68,149,1), [M:ASEL]SELECTED)) From GESECRAN
 Elsif [M:ASEL]WITHFILE=2
  Call ERREUR(func AFNC.MES1(mess(67,149,1), [M:ASEL]SELECTED)) From GESECRAN
 Endif
 FIN = 0 : Return
Endif
Local Integer POS
POS= find([M:ASEL]WPATH ,[M:ASEL]FULLPATH)-1
 If POS>=0
 If ([M:ASEL]ISFOLD(POS)=2 & [M:ASEL]WITHFILE=2)
  Call ERREUR(func AFNC.MES1(mess(66,149,1), [M:ASEL]SELECTED)) From GESECRAN : # $1$ n'est pas un fichier
  Raz  [M:ASEL]WPATH
  Raz [M:ASEL]SELECTED
  Affzo [M:ASEL]
  FIN = 0 : Return
 Endif
 If ([M:ASEL]ISFOLD(POS) <>2 & [M:ASEL]WITHFILE<2)
  Call ERREUR(func AFNC.MES1(mess(52,149,1), [M:ASEL]SELECTED)) From GESECRAN : # $1$ n'est pas un répertoire
  Raz  [M:ASEL]WPATH
  Raz [M:ASEL]SELECTED
  Affzo [M:ASEL]
  FIN = 0 : Return
 Endif
Endif
Gosub CONTROL_SELECTED
If STAT >0
 Call ERREUR(GMESSAGE) From GESECRAN
 FIN =0 : Return
Endif
Return

######################################################################################
$INIT
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
If clalev([F:AVL])=0 : Local File AVOLUME  [AVL] : Endif
If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif
Link [AVL] With
& [ACC]CODACC=GUSER;[F:AVL]CODACC
& As [AVL_]
Local Integer SAV_GCONSDIA : SAV_GCONSDIA= GCONSDIA : GCONSDIA=0
Return

######################################################################################
$SET_IMG
Local Char IMGHEAD(20) , IMGVOL(20) , IMGFOL(20),IMGFIL(20)
Local Char IMGDOC(20), IMGXLS(20),IMGPDF(20),IMGXML(20),IMGTXT(20),IMGPPT(20),IMGZIP(20),IMGJPG(20)
IMGHEAD = "Info1.gif"
IMGVOL   = "asp.gif"
IMGFOL   = "Folder.gif"
IMGFIL    = "new.gif"
IMGDOC   = "doc.gif"
IMGPDF   = "pdf.gif"
IMGXML   = "xml.gif"
IMGTXT  = "txt.gif"
IMGPPT  = "txt.gif"
IMGZIP  = "zip.gif"
IMGJPG = "jpg.gif"
IMGXLS =  "xls.gif"
Return

######################################################################################
$INIT_DIA
Local Char WCRITERIA(250)
Local Char LPARAM(250)(1..3)
Local Char SAVVALEUR(250) : SAVVALEUR=VALEUR
Raz [M:ASEL]
Affzo [M:ASEL]
If sum(PARAM)<>""
 If PARAM(2)="" :
   LPARAM(2)="2"
  Else
  LPARAM(2)=PARAM(2)
 Endif
 If PARAM(1)=""
   LPARAM(1)="2"
  Else
  LPARAM(1)=PARAM(1)
 Endif
 LPARAM(3)=PARAM(3)
Else
 LPARAM(1)="2"
 LPARAM(2)="3"
 LPARAM(3)=""
Endif

[M:ASEL]WITHFILE = val(LPARAM(2))
[M:ASEL]ALLFILES = val(LPARAM(1))
[M:ASEL]DEFVOL   = LPARAM(3)
Gosub SET_IMG

Gosub ADD_VOLUME

If VALEUR="" & [M:ASEL]DEFVOL<>""
 Gosub LOAD_VOLUME
Endif

If VALEUR<>""
 [M:ASEL]SELECTED = VALEUR
 #{SAM 120677  Gosub CONTROL_SELECTED
 #control 'VALEUR'
 Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
 STAT = func ASYRSTO.CTL_VOLFIL(2,[M:ASEL]SELECTED,[M:ASEL]WPATH,E_TYPE_FOLDER,GMESSAGE)
 If STAT >0 &  [M:ASEL]WITHFILE=2 :#it can also be a file
  STAT = func ASYRSTO.CTL_VOLFIL(2,[M:ASEL]SELECTED,[M:ASEL]WPATH,E_TYPE_FILEREAD,GMESSAGE)
 Endif
 #SAM 120677}
 If STAT >0
  Raz GMESSAGE,VALEUR
 Endif
Endif

If VALEUR<>""
 Local Char WVOL(10),WCHAINE(250)
 Local Char WFOLDER(GDIMFIC)(1..)
 Local Char WFILE(GDIMFIC)
 Local Integer I,J
 I = instr(1,VALEUR,"[")
 J = instr(1,VALEUR,"]")

 If I>0 and J>0
  [M:ASEL]DEFVOL= seg$(VALEUR,I+1,J-1)
  Gosub LOAD_VOLUME_FULL
  WCHAINE = right$(VALEUR,J+1)
  J = func ASYRSUB.SPLIT(WFOLDER,WCHAINE,"/")
  Raz WCHAINE
  WCHAINE ="["+[M:ASEL]DEFVOL+"]"
  For J=1 To maxtab(WFOLDER) : # 119295
   WCHAINE += "/"+WFOLDER(J)
   I= find(WCHAINE ,[M:ASEL]PATH)-1
   If I>=0
    Call LOAD_FILE([M:ASEL]WITHFILE,[M:ASEL]KEYS(I), [M:ASEL]FULLPATH(I),I,[V]CST_AYES)
   Endif
  Next
  WCHAINE += "/"+WFOLDER(maxtab(WFOLDER))
 Endif
Endif
#Raz VALEUR
Affzo [M:ASEL]

# 120747
If VALEUR<>"" and I<[M:ASEL]NBSEL-1 and I>=0
 zonsui ="[M:ASEL]INTIT("+num$(I)+")"
Endif

Return

$ADD_VOLUME
# Start
[M:ASEL]VOLUME([M:ASEL]NBSEL) = "__DEP"
[M:ASEL]EXPFLG([M:ASEL]NBSEL) = 2
[M:ASEL]ICONE([M:ASEL]NBSEL) = IMGHEAD
[M:ASEL]INTIT([M:ASEL]NBSEL) = mess(60,143,1)
[M:ASEL]KEYS([M:ASEL]NBSEL) = "__DEP"
[M:ASEL]PARENT([M:ASEL]NBSEL) = ""
[M:ASEL]ISLOAD([M:ASEL]NBSEL) = 1
[M:ASEL]ISFOLD([M:ASEL]NBSEL) = 1
[M:ASEL]NBSEL += 1

If [M:ASEL]DEFVOL<>"" & [M:ASEL]ALLFILES <2
 WCRITERIA = '[F:AVL]VOLUME = "'+[M:ASEL]DEFVOL+'"'
Else
 WCRITERIA = "1=1"
Endif

# filter on access code
If GUSRACS<>2
 WCRITERIA +=  "and ([F:AVL]CODACC='' or [F:ACC]CONSUL=2)"
Endif

# Add volumes
For [AVL_] Where evalue(WCRITERIA)
 [M:ASEL]KEYS([M:ASEL]NBSEL) = [AVL]VOLUME
 [M:ASEL]PARENT([M:ASEL]NBSEL) = "__DEP"
 [M:ASEL]VOLUME([M:ASEL]NBSEL) = [AVL]VOLUME
 [M:ASEL]PATH([M:ASEL]NBSEL) = '['+ [AVL]VOLUME + "]"
 [M:ASEL]FULLPATH([M:ASEL]NBSEL) = func AVOLUME_CSTD._GETFULLPATH([AVL]ROOT,"")
 [M:ASEL]EXPFLG([M:ASEL]NBSEL) = 1
 [M:ASEL]ICONE([M:ASEL]NBSEL) = IMGVOL
 [M:ASEL]INTIT([M:ASEL]NBSEL) = "["+[AVL]VOLUME+"]"-func ASYRFNC.TEXTRA("AVOLUME","DES",[AVL]VOLUME,"")
 [M:ASEL]ISLOAD([M:ASEL]NBSEL) = 1
 [M:ASEL]ISFOLD([M:ASEL]NBSEL) = 2
 [M:ASEL]NBSEL += 1
Next
Return

$LOAD_VOLUME
If [M:ASEL]DEFVOL<>""
 I= find([M:ASEL]DEFVOL,[M:ASEL]KEYS)-1
 If I>=0
  Call LOAD_FILE([M:ASEL]WITHFILE,[M:ASEL]KEYS(I), [M:ASEL]FULLPATH(I),I,[V]CST_ANO)
 Endif
Endif
Return

$LOAD_VOLUME_FULL
If [M:ASEL]DEFVOL<>""
 I= find([M:ASEL]DEFVOL,[M:ASEL]KEYS)-1
 If I>=0
  Call LOAD_FILE([M:ASEL]WITHFILE,[M:ASEL]KEYS(I), [M:ASEL]FULLPATH(I),I,[V]CST_AYES)
 Endif
Endif
Return

