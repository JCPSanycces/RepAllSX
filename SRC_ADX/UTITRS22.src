#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################
# UTITRS22   UTI process
#
#
# Deletion of params : SWIVAT & GERDSC
#
########################################################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Deletion of params : SWIVAT & GERDSC") From LECFIC
  Call MAJ_UTITRS22(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog MAJ_UTITRS22(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Call ECR_TRACE("UTITRS22 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ADP])  =0  Local File =DOSSIER+".ADOPAR"   [ADP] : Endif
If clalev([F:ADW])  =0  Local File =DOSSIER+".ADOVAL"   [ADW] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [ADP]

Delete [ADP] Where PARAM="SWIVAT"
If fstat
 GOK=0 : Call ECR_TRACE(mess(28,125,1)-"ADOPAR : SWIVAT",-1) From GESECRAN
Elsif adxdlrec>0
 WCOMPTEUR+=adxdlrec
Endif

Delete [ADW] Where PARAM="SWIVAT"
If fstat
 GOK=0 : Call ECR_TRACE(mess(28,125,1)-"ADOVAL : SWIVAT",-1) From GESECRAN
Elsif adxdlrec>0
 WCOMPTEUR+=adxdlrec
Endif

Delete [ADP] Where PARAM="GERDSC"
If fstat
 GOK=0 : Call ECR_TRACE(mess(28,125,1)-"ADOPAR : GERDSC",-1) From GESECRAN
Elsif adxdlrec>0
 WCOMPTEUR+=adxdlrec
Endif

Delete [ADW] Where PARAM="GERDSC"
If fstat
 GOK=0 : Call ECR_TRACE(mess(28,125,1)-"ADOVAL : GERDSC",-1) From GESECRAN
Elsif adxdlrec>0
 WCOMPTEUR+=adxdlrec
Endif

If GOK=1
 Commit
Else
 Rollback
Endif

Close Local File [ADP], [ADW]
Call ECR_TRACE("UTITRS22 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN
End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
#If [F:ADS]MODULE(N)<>2 : End : Endif                                 : # N= module
#If filinfo(filpath("FIL","XXXXXX","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table

Call MAJ_UTITRS22(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3: End : Endif
#If [F:ADS]MODULE(N)<>2 : End : Endif                                 : # N= module
#If filinfo(filpath("FIL","XXXXXX","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table

Call MAJ_UTITRS22(APPLI)
End
