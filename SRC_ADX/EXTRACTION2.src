#<AdxTL>@(#)0.0.0.0 $Revision$
######################################
$OUVFIC
#DNA
If clalev([F:DNA])=0 : Local File DADDNA   [DNA] : Endif
If clalev([F:DNB])=0 : Local File DADDNA2  [DNB] : Endif
If clalev([F:DNC])=0 : Local File DADDNA3  [DNC] : Endif
If clalev([F:DND])=0 : Local File DADDNA4  [DND] : Endif
If clalev([F:DNE])=0 : Local File DADDNA5  [DNE] : Endif
If clalev([F:DNF])=0 : Local File DADDNA6  [DNF] : Endif
If clalev([F:DNG])=0 : Local File DADDNA7  [DNG] : Endif
#58108
If GINTMT
 If clalev([F:DNH])=0 : Local File DADDNA8  [DNH] : Endif
Endif
Return

######################################
$DECLARATION
#DNA
Local Integer VDNA
Local Decimal BRTASS
#Prime versée
Local Integer NBRPRM, NBRPRM2
Local Libelle CODPRM (0..99)
Local Decimal AMTPRM (0..99)
#Indemnité mensuelle versée
Local Integer NBRMTH, NBRMTH2
Local Libelle INDMTH (0..2)
Local Decimal AMTMTH (0..2)
#Indemnité de départ versée (Variables sufixées par DNA car  déjà existante dans EXTRACTION de la Dads-u)
Local Integer NBRINDDNA, NBRINDDNA2
Local Libelle CODINDDNA (0..len(mess(0,10969,1))-1)
Local Decimal AMTINDDNA (0..len(mess(0,10969,1))-1)
Local Decimal NBRTPS, NBRCNG
Local Libelle CODTPS
#Durée du travail
Local Integer NBRCODTIM
Local Libelle CODTIM (0..2)
Local Decimal NBRTIM (0..2)
#Rappel de paie
Local Integer NBRCODRAP,NBRCODRAP2
Local Libelle CODRAP (0..99)
Local Decimal AMTRAP (0..99)
#Rémunération spectacle
Local Integer NBRTYPSAL
Local Libelle TYPSAL (0..3)
Local Decimal AMTSAL (0..3)
Return

######################################
$INITIALISATION
BRTASS=0
Raz CODPRM : Raz AMTPRM : NBRPRM=0 : NBRPRM2=0
Raz INDMTH : Raz AMTMTH : NBRMTH=0 : NBRMTH2=0
Raz CODINDDNA : Raz AMTINDDNA : NBRINDDNA=0 : NBRINDDNA2=0

NBRTPS=0 : NBRCNG=0
NBRTIM=0
Raz CODRAP : AMTRAP=0 : NBRCODRAP=0 : NBRCODRAP2=0
Raz TYPSAL : AMTSAL=0 : NBRTYPSAL =0

Return

######################################
$AFFECTE_DNA
Gosub AFFECTE
Gosub AFFECTE_DNB
Gosub AFFECTE_DNC
Gosub AFFECTE_DND
Gosub AFFECTE_DNE
Gosub AFFECTE_DNF
Gosub AFFECTE_DNG
Gosub AFFECTE_DNH
Return

######################################
$AFFECTE
Delete [F:DNA] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA

#Raz [F:DNA]
[F:DNA] = [F:DAE]
[F:DNA] = [F:HRCTR]
[F:DNA]DNAPAYDAT = [F:VEP]PAYDAT
[F:DNA]DNACCPNUM = [F:HRCTR]NUMCCP
[F:DNA]DNAENDCDD = [F:HRCTR]ENDCON
[F:DNA]DNASTRCAE = [F:HRCTR]STRCAE
[F:DNA]DNAREFCAE = [F:HRCTR]REFCAE

# N4DS - Arrondi au centime d'euro sur les montants
#[F:DNA]DNABRTASS=arr(BRTASS,0.01)
[F:DNA]DNACODTPS=arr(CODTPS,1)
[F:DNA]DNANBRTPS=arr(NBRTPS,0.01)    : # Attention passe en heure / centiemes avec séparateur decimal

#Si sortie définitive ou pas
If [F:HRCTR]XITDAT<>[0/0/0] #& [F:HRCTR]XITFNL=2
 [F:DNA]DNASTRDAT=[L]CTRDATMIN
 # Date de fin contrat ne peut pas être supérieure à la date de fin de préavis payé ou pas / effectué ou pas !
 [F:DNA]DNAENDDAT=max([F:HRCTR]XITDAT,[F:HRCTR]ENDTIMNTC)
 [F:DNA]DNAENDDAT=max([F:DNA]DNAENDDAT,[F:HRCTR]ENDNTC2)
 [F:DNA]DNAENDDAT=max([F:DNA]DNAENDDAT,[F:HRCTR]ENDNTC3)
 [F:DNA]DNADATNTF=[F:HRCTR]NTFDAT
 [F:DNA]DNADATLIC=[F:HRCTR]DATLIC
 [F:DNA]DNALSTDAY=[F:HRCTR]LSTDAY


 [F:DNA]DNANBRCNG=arr(NBRCNG,1)
 Call ORGANISME ([F:DNA]EMPDDS,[F:HRCTR]ETRFCY,"",ORGCOURANT,GINDARR-1) From SUBORG
 Read [F:ORG]ORG0=GCURLEG;ORGCOURANT
 If !fstat & [F:ORG]TYPIRC>2
  If [F:ORG]NUMDCS<>""
   [F:DNA]RGMCOD(0)=[F:ORG]NUMDCS :#Code Régime/Institution (Arrco/Agirc)
  Endif
  If [F:DNA]RGMCOD(0)<>"" & [F:HRCTR]STAEMP>1
   Call ORGANISME ([F:DNA]EMPDDS,[F:HRCTR]ETRFCY,"",ORGCOURANT,GINDAGI-1) From SUBORG
   Read [F:ORG]ORG0=GCURLEG;ORGCOURANT
   If !fstat & [F:ORG]TYPIRC>2
    If [F:ORG]NUMDCS<>""
     [F:DNA]RGMCOD(1)=[F:ORG]NUMDCS :#Code Régime/Institution (Arrco/Agirc)
    Endif
   Endif
  Endif
 Endif
Endif
Write [F:DNA]
If fstat<>0
 GOK = 0 : Call FSTA("DNA") From GLOCK
Endif
Return

######################################
$AFFECTE_DNB
Delete [F:DNB] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA

#Primes versées
X=0
For J=0 To NBRPRM-1
 #N4DS que si un mtt !
 If arr(AMTPRM(J),0.01)
    Filter [F:DNB] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&        & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA & DNACODPRM=CODPRM(J)

    Read [F:DNB]DNB0 First
    Filter [F:DNB]
    If fstat
        X+=1
        #Raz [F:DNB]
        [F:DNB]=[F:DAE]
        [F:DNB]NUMLIG=X
        [F:DNB]DNACODPRM=CODPRM(J)
        [F:DNB]DNAAMTPRM=arr(AMTPRM(J),0.01)
        [F:DNB]DNASTRPRM=[L]DATVEPMIN
        [F:DNB]DNAENDPRM=[L]DATVEPMAX
        Write [F:DNB]
        If fstat<>0
            GOK = 0 : Call FSTA("DNB") From GLOCK
        Endif
    Else
        [F:DNB]DNAAMTPRM+=arr(AMTPRM(J),0.01)
        Rewrite [F:DNB]
        If fstat<>0
            GOK = 0 : Call FSTA("DNB") From GLOCK
        Endif
    Endif
Endif
Next
Return

######################################
$AFFECTE_DNC
Delete [F:DNC] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA

#Indemnités mensuelles versées (max 2)
X=0
For J=0 To NBRMTH-1
 #N4DS que si un mtt !
 If arr(AMTMTH(J),0.01)
    Filter [F:DNC] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&           & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA & [F:DNC]DNAINDMTH=INDMTH(J)
    Read [F:DNC]DNC0 First
    Filter [F:DNC]
    If fstat
        X+=1
        #Raz [F:DNC]
        [F:DNC]=[F:DAE]
        [F:DNC]NUMLIG=X
        [F:DNC]DNAINDMTH=INDMTH(J)
        [F:DNC]DNAAMTMTH=arr(AMTMTH(J),0.01)
        Write [F:DNC]
        If fstat<>0
            GOK = 0 : Call FSTA("DNC") From GLOCK
        Endif
    Else
        [F:DNC]DNAAMTMTH+=arr(AMTMTH(J),0.01)
        Rewrite [F:DNC]
        If fstat<>0
            GOK = 0 : Call FSTA("DNC") From GLOCK
        Endif
    Endif
 Endif
Next
Return

######################################
$AFFECTE_DND
Delete [F:DND] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA


# Si sortie définitive
If [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITFNL<>2 : Return : Endif

X=0
#Préavis effectué & payé
If [F:HRCTR]FLGPRV=2
 X+=1
 #Raz[F:DND]
 [F:DND]=[F:DAE]
 [F:DND]NUMLIG=X
 [F:DND]DNACODPRV=1
 [F:DND]DNASTRPRV=[F:HRCTR]STRTIMNTC
 [F:DND]DNAENDPRV=[F:HRCTR]ENDTIMNTC
 Write [F:DND]
 If fstat<>0
  GOK = 0 : Call FSTA("DND") From GLOCK
 Endif
Endif

#Préavis Non effectué & payé
If [F:HRCTR]FLGPRV2=2
 X+=1
 #Raz[F:DND]
 [F:DND]=[F:DAE]
 [F:DND]NUMLIG=X
 [F:DND]DNACODPRV=2
 [F:DND]DNASTRPRV=[F:HRCTR]STRNTC2
 [F:DND]DNAENDPRV=[F:HRCTR]ENDNTC2
 Write [F:DND]
 If fstat<>0
  GOK = 0 : Call FSTA("DND") From GLOCK
 Endif
Endif

#Préavis Non effectué & non payé
If [F:HRCTR]FLGPRV3=2
 X+=1
 #Raz[F:DND]
 [F:DND]=[F:DAE]
 [F:DND]NUMLIG=X
 [F:DND]DNACODPRV=3
 [F:DND]DNASTRPRV=[F:HRCTR]STRNTC3
 [F:DND]DNAENDPRV=[F:HRCTR]ENDNTC3
 Call SIMPLEREAD([M]XITGRD,GCURLEG,GERRHRM) From SUBHRXGD
 If !GERRHRM & right$([F:HRXGD]CODN4H,1+len([F:HRXGD]CODN4H)-3)="026"
  [F:DND]DNACODPRV=5
  Raz [F:DND]DNASTRPRV
  Raz [F:DND]DNAENDPRV
 Endif
 Write [F:DND]
 If fstat<>0
  GOK = 0 : Call FSTA("DND") From GLOCK
 Endif
Endif

If !X
 #Raz[F:DND]
 [F:DND]=[F:DAE]
 [F:DND]NUMLIG=1
 [F:DND]DNACODPRV=4 :#Pas de clause de préavis applicable -> pas de période !
  Write [F:DND]
  If fstat<>0
   GOK = 0 : Call FSTA("DND") From GLOCK
  Endif
Endif
Return

######################################
$AFFECTE_DNE
Delete [F:DNE] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA

# Si sortie définitive
If [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITFNL<>2 : Return : Endif

#Indemnités de départ versées (max 20)
X=0
For J=0 To NBRINDDNA-1
 #N4DS que si un mtt !
 If arr(AMTINDDNA(J),0.01)
    Filter [F:DNE] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&       & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA & [F:DNE]DNACODIND=CODINDDNA(J)

    Read [F:DNE]DNE0 First
    Filter [F:DNE]
    If fstat
        X+=1
        #Raz[F:DNE]
        [F:DNE]=[F:DAE]
        [F:DNE]NUMLIG=X
        [F:DNE]DNACODIND=CODINDDNA(J)
        [F:DNE]DNAAMTIND=arr(AMTINDDNA(J),0.01)
        Write [F:DNE]
        If fstat<>0
            GOK = 0 : Call FSTA("DNE") From GLOCK
        Endif
    Else
        [F:DNE]DNAAMTIND+=arr(AMTINDDNA(J),0.01)
        Rewrite [F:DNE]
        If fstat<>0
            GOK = 0 : Call FSTA("DNE") From GLOCK
        Endif
    Endif
 Endif
Next
Return

######################################
$AFFECTE_DNF
Delete [F:DNF] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA

Filter [F:DNF] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA & [F:DNF]DNACODTIM=[F:HRCTR]DNACODTIM

Read [F:DNF]DNF0 First
Filter [F:DNF]
If fstat
 #Raz[F:DNF]
 [F:DNF]=[F:DAE]
 [F:DNF]NUMLIG=1
 [F:DNF]DNACODTIM=[F:HRCTR]DNACODTIM
 [F:DNF]DNANBRTIM=fix(NBRTIM)
 #Horaire contractuelle  #80791: Add all Ar2(---------/12)
 Case [F:DNF]DNACODTIM
  When 3            :#10 Heure(=mensuel)
  [F:DNF]DNAHORCPY=val(func AFNC.PARAM("HOUMONLEG",[F:HRCTR]ETRFCY))
  [F:DNF]DNAHORCTR=[F:HRCTR]HRSMTH
  When 5,9        :#20 Forfait jour / 12 Jour
   #82257 : condition VNATFIL
   If VNATFIL="15"
    # Base mensuelle
    [F:DNF]DNAHORCPY=ar2(val(func AFNC.PARAM("DAYYEA",[F:HRCTR]ETRFCY))/12)
    [F:DNF]DNAHORCTR=ar2([F:HRCTR]NBRDAYCTR/12)
   Else
    # Base annuelle
    [F:DNF]DNAHORCPY=val(func AFNC.PARAM("DAYYEA",[F:HRCTR]ETRFCY))
    [F:DNF]DNAHORCTR=[F:HRCTR]NBRDAYCTR
   Endif
  When 6        :#21 Forfait heure
   #82257 : condition VNATFIL
   If VNATFIL="15"
    # Base mensuelle
    [F:DNF]DNAHORCPY=ar2(val(func AFNC.PARAM("HRSYEA",[F:HRCTR]ETRFCY))/12)
    [F:DNF]DNAHORCTR=ar2(val(func AFNC.PARAM("HRSYEA",[F:HRCTR]ETRFCY))/12)
   Else
    # Base annuelle
    [F:DNF]DNAHORCPY=val(func AFNC.PARAM("HRSYEA",[F:HRCTR]ETRFCY))
    [F:DNF]DNAHORCTR=val(func AFNC.PARAM("HRSYEA",[F:HRCTR]ETRFCY))
   Endif
  When Default :
  [F:DNF]DNAHORCPY=0
  [F:DNF]DNAHORCTR=0
 Endcase
 Write [F:DNF]
 If fstat<>0
  GOK = 0 : Call FSTA("DNF") From GLOCK
 Endif
Else
 [F:DNF]DNANBRTIM+=fix(NBRTIM)
 Rewrite [F:DNF]
 If fstat<>0
  GOK = 0 : Call FSTA("DNF") From GLOCK
 Endif
Endif
Return

######################################
$AFFECTE_DNG
Delete [F:DNG] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA

#Rappel de paie
X=0
For J=0 To NBRCODRAP-1
 #N4DS que si un mtt !
 If arr(AMTRAP(J),0.01)
    Filter [F:DNG] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA
&              & [F:DNG]DNACODRAP=CODRAP(J)
    Read [F:DNG]DNG0 First
    Filter [F:DNG]
    If fstat
        X+=1
        #Raz[F:DNG]
        [F:DNG]=[F:DAE]
        [F:DNG]NUMLIG=X
        [F:DNG]DNACODRAP=CODRAP (J)
        [F:DNG]DNAAMTRAP=arr(AMTRAP(J),0.01)
        [F:DNG]DNASTRRAP=[L]DATVEPMIN
        [F:DNG]DNAENDRAP=[L]DATVEPMAX
        Write [F:DNG]
        If fstat<>0
            GOK = 0 : Call FSTA("DNG") From GLOCK
        Endif
    Else
        [F:DNG]DNACODRAP=CODRAP (J)
        [F:DNG]DNAAMTRAP+=arr(AMTRAP(J),0.01)
        Rewrite [F:DNG]
        If fstat<>0
            GOK = 0 : Call FSTA("DNG") From GLOCK
        Endif
    Endif
 Endif
Next
Return

#Rémunération spectacle
######################################
$AFFECTE_DNH
If GINTMT<>1 : Return : Endif
Delete [F:DNH] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA

#Rappel de paie
X=0
For J=0 To NBRTYPSAL-1
 #N4DS que si un mtt !
 If arr(AMTSAL(J),0.01)
    Filter [F:DNH] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA & [F:DNH]DNATYPSAL=TYPSAL(J)

    Read [F:DNH]DNH0 First
    Filter [F:DNH]
    If fstat
        X+=1
        #Raz[F:DNH]
        [F:DNH]=[F:DAE]
        [F:DNH]NUMLIG=X
        [F:DNH]DNATYPSAL=TYPSAL(J)
        [F:DNH]DNAAMTSAL=arr(AMTSAL(J),0.01)
        Write [F:DNH]
        If fstat<>0
            GOK = 0 : Call FSTA("DNH") From GLOCK
        Endif
    Else
        [F:DNH]DNAAMTSAL+=arr(AMTSAL(J),0.01)
        Rewrite [F:DNH]
        If fstat<>0
            GOK = 0 : Call FSTA("DNH") From GLOCK
        Endif
    Endif
 Endif
Next
Return

