#<AdxTL>@(#)6.0.0.0 $Revision$
###########################################################################
## Default value for miscellaneous table
###########################################################################

Funprog ADI_INI(AINSTANCE,APRONAME, AVALUE, NUMTAB)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Shortint NUMTAB
Local File ATABDIV [ADI]
For [ADI] Where [F:ADI]NUMTAB=[L]NUMTAB & [F:ADI]DEFVAL=CST_AYES
 AVALUE = [F:ADI]CODE
 Break
Next
End CST_AOK


#-----------------------------------------------------------------#
###########################################################################
## control
###########################################################################
Funprog ADI_CONT(AINSTANCE,APRONAME, AVALUE, NUMTAB, DEPCOD)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Shortint  NUMTAB
Value Char  DEPCOD
Local Char MESSAGE (250)
Local Integer ASTATUS
ASTATUS=CST_AOK
If NUMTAB<>0 and AVALUE <> AVOID.ACHAR
 Local File ATABTAB [ADV]
 Local File ATABDIV [ADI]
 Read [ADV]CODE = [L]NUMTAB
 If fstat= CST_AOK
  Read [ADI]CODE=[L]NUMTAB;AVALUE
  If fstat=CST_AOK
   If [L]DEPCOD<>AVOID.ACHAR & [F:ADV]DEPNUM<>0 & [F:ADI]DEPCOD<>AVOID.ACHAR & [F:ADI]DEPCOD<>[L]DEPCOD
    # [L]AVALUE ne dépend pas de [L]DEPCOD
    # [L]AVALUE is not link to [L]DEPCOD
    ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,func ASYRFNC.MES2(mess(271,133,1),[L]AVALUE, [L]DEPCOD),CST_AERROR)
   Endif
   If NUMTAB=909
    If !find(AVALUE, AINSTANCE.ACTX.AFOLD.ALISTLEG(1..AINSTANCE.ACTX.AFOLD.ANBLEG))
      #La législation $1$ n'est pas gérée dans le dossier $2$
      #The legislation $1$ is not managed in the folder $2$
      ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,func ASYRFNC.MES2(mess(142,127,1),[L]AVALUE, AINSTANCE.ACTX.AFOLDER),CST_AERROR)
    Endif
   Endif
   #112574
   If dim([F:ADV]FLGENA)>0 & dim([F:ADI]ENAFLG)>0 & [F:ADV]FLGENA=2 & [F:ADI]ENAFLG<>2
    Local Instance INST_ADV Using C_ATABTAB
    Local Integer INST_STATUS
    INST_ADV = NewInstance C_ATABTAB AllocGroup null
    [L]INST_STATUS = fmet INST_ADV.AREAD(NUMTAB)
    MESSAGE = mess(63,139,1)-num$(NUMTAB)-fmet INST_ADV.AGETTEXTRA("LNGDES")- ":" - AVALUE - mess(2,126,1) : # Fiche inactive
    FreeGroup INST_ADV
    ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,MESSAGE ,CST_AERROR)
   Endif
  Else
   # LSE SAM 110263
   Local Instance INST_ADV Using C_ATABTAB
   Local Integer INST_STATUS
   INST_ADV = NewInstance C_ATABTAB AllocGroup null
   [L]INST_STATUS = fmet INST_ADV.AREAD(NUMTAB)
   #MESSAGE = mess(63,139,1)- ":" - AVALUE - "\"-mess(23,100,1)  # Fiche inexistante
   #MESSAGE = Table divers xxx lib xxx : code  AVALUE inexistant
   MESSAGE = func ASYRFNC.MES3(mess(356,139,1),num$(NUMTAB), fmet INST_ADV.AGETTEXTRA("LNGDES"),AVALUE)
   FreeGroup INST_ADV
   ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,MESSAGE ,CST_AERROR)
  Endif
 Endif
Endif
End ASTATUS

