#<AdxTL>@(#)2.0.0.0 $Revision$
##################################################################################
# UUAOBCCN                                                                       #
# Mise à jour de la liste gauche principale de l'objet CCN                       #
# GBO 04/05/2010 FQ64521 - Warning à la place d'erreur pour le test sur CODACT   #
##################################################################################
 Call OUVRE_TRACE("Test moulinette UUAOBCCN") From LECFIC
 Call PATCH(nomap)
 Call LEC_TRACE From LECFIC
End
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI

If filinfo(filpath("FIL","AOBJLST","fde",PAPPLI),0)<=0
      End
Else
   Call EXE_UUAOBCCN(PAPPLI)
Endif

End
##################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

 Local Char FICHIER(250)
 FICHIER=filpath("FIL","AOBJLST","fde",APPLI)
 If filinfo(FICHIER,0) < 0
  End
 Endif 
  Call EXE_UUAOBCCN(APPLI)
End

End
 
#------ Suppression des infos de l'onglet Données du dictionnaire des états ------#
Subprog EXE_UUAOBCCN(LDOSSIER)
Value Char LDOSSIER

#----- Variables locales -----#
Local Char     WMSG(80)
Local Integer OK

GOK =1

#-----
Call ECR_TRACE("UUAOBCCN: Update main left list of the CCN object "+LDOSSIER,0) From GESECRAN

#-----
If dim(G_ACTCCN)>0 & G_ACTCCN<>G_OUI
 Call ECR_TRACE("Activity code CCN disabled in this folder",-1) From GESECRAN
 Goto FIN2
Endif

#----- Ouverture des fichiers -----#
If clalev([F:ZAOL]) =0  Local File =LDOSSIER+".AOBJLST"     [ZAOL] : Endif
#-------------------------------#
#   mise a jour table AOBJLST   #
#-------------------------------#
Trbegin [ZAOL]
Read [F:ZAOL]AOL0="CCN"
If fstat
 Call ECR_TRACE("Error : The CCN object doesn't exist.",-1) From GESECRAN
 GOK=0 : Goto FIN
Endif 
Raz [F:ZAOL]
[F:ZAOL]ABREV     = "CCN"
[F:ZAOL]DELDEF    = 1
[F:ZAOL]NBSEL     = 6
[F:ZAOL]SELEXP(4) = "mess([CCN]CCNSTA,3284,1)"
[F:ZAOL]SELEXP(5) = "[CCN]CCNDES1"
[F:ZAOL]SELFIC(0) = "CONCESSION"
[F:ZAOL]SELFIC(1) = "CONCESSION"
[F:ZAOL]SELFIC(2) = "CONCESSION"
[F:ZAOL]SELFIC(3) = "CONCESSION"
[F:ZAOL]SELINT(0) = 1371
[F:ZAOL]SELINT(1) = 1343
[F:ZAOL]SELINT(2) = 1344
[F:ZAOL]SELINT(3) = 34416
[F:ZAOL]SELINT(4) = 0    
[F:ZAOL]SELINT(5) = 282
[F:ZAOL]SELLNG(4) = 10
[F:ZAOL]SELLNG(5) = 10
[F:ZAOL]SELTYP(4) = "A"
[F:ZAOL]SELTYP(5) = "A"
[F:ZAOL]SELZON(0) = "CCNREF"
[F:ZAOL]SELZON(1) = "CPY"
[F:ZAOL]SELZON(2) = "FCY"
[F:ZAOL]SELZON(3) = "CCNUSR"
Rewrite [F:ZAOL]

$FIN
 If GOK=1
  Commit
 Else
  Rollback
 Endif

 If GOK
  Call VALID("OCCN",LDOSSIER,1,GOK) From VALWIN
 Endif
 If GOK
  Call VALID("CCN",LDOSSIER,1,GOK) From VALOBJ
 Endif

 If !GSERVEUR : GSERVEUR=1 : Local Integer LGSERVEUR : Endif
 Call VALFCT(LDOSSIER) From AVALAFC 
 If dim(LGSERVEUR)>0
  GSERVEUR = 0
 Endif
 
$FIN2
#----- Fin du traitement -----#
WMSG ="UUAOBCCN: end of process"
Call ECR_TRACE(WMSG,0) From GESECRAN

End


