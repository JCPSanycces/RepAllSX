#<AdxTL>@(#)2.0.0.0 $Revision$
##################################
# 104943 : version management in Work orders
#          - Enterprise Planning, planning workbench
##################################

##################################
# for usage in SMW3
##################################
Subprog AM_ITMREF_SMW3(VALEUR)
Variable Char VALEUR
Local Integer LALT

# Enable, Disable ECCVALMAJ, ECCVALMIN, BOMALT
Call ECCAFF(VALEUR,"SMW3")  From MFGECCLIB
If func ECCLIB.NBRCPN(VALEUR)
    # ECC preload of major and minor version + Subcontracting BOM code
    LALT = [M:SMW3]BOMALT2
    Raz [M:SMW3]ECCVALMAJ, ECCVALMIN, BOMALT2
    Call INIECCBOM(VALEUR, [M:SMW3]PRHFCY, [M:SMW3]STRDAT2, 3, [M:SMW3]ECCVALMAJ,[M:SMW3]ECCVALMIN,LALT)  From MFGECCLIB
    [M:SMW3]BOMALT2 = LALT
    Affzo [M:SMW3]ECCVALMAJ, ECCVALMINM, BOMALT2
Else
    Effzo [M:SMW3]ECCVALMAJ, ECCVALMIN
Endif

End

#################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M]ITMREF)<1
    mkstat=2
Endif
End

##################################
# for usage in MBW1, MBW3, MBW3, SMW3
# - Start-date (=Order date for SCO)
##################################
Subprog C_ECCVALMAJ(VALEUR, ABR)
Variable Char    VALEUR()
Value    Char    ABR()

Call CTRECC([M]ITMREF,ABR,"ECCVALMAJ",VALEUR,[M]ECCVALMIN,
&           [M]STRDAT2,GERR,GMESSAGE) From ECCLIB

# Only Warning Message
If GERR>0
    GERR=2
    mkstat=2
Endif
End

##################################

Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M]ITMREF)<2
&  |    [M]ECCVALMAJ=""
    mkstat=2
Endif
End

##################################
# for usage in MBW1, MBW3, MBW3, SMW3
# - Start-date (=Order date for SCO)
##################################
Subprog C_ECCVALMIN(VALEUR, ABR)
Variable Char    VALEUR()
Value    Char    ABR

Call CTRECC([M]ITMREF, ABR,"ECCVALMIN",[M]ECCVALMAJ,VALEUR,
&           [M]STRDAT2,GERR,GMESSAGE) From ECCLIB

# Only Warning Message
If GERR>0
    GERR=2
    mkstat=2
Endif

End

##################################
Subprog C_STRDAT2(VALEUR, ABR)
Variable Date VALEUR
Value    Char ABR

Local Date LSAVDAT
Local Integer IND

# VALEUR can contain a new value, but CTRECCPRD needs [M:MBWx]STRDAT2
Case ABR
    When "SMW1"
            LSAVDAT = [M:SMW1]STRDAT2
            If LSAVDAT <> VALEUR
                [M:SMW1]STRDAT2 = VALEUR
            Endif
            Call CTRECCPRD(ABR) From MFGECCLIB      # Control each line of product and highlight them if necessary
            IND = find(GERR,1,4)
    When "SMW3"
            LSAVDAT = [M:SMW3]STRDAT2
            If LSAVDAT <> VALEUR
                [M:SMW3]STRDAT2 = VALEUR
            Endif
            Call CTRECCPRD(ABR) From MFGECCLIB     # Control each line of product and highlight them if necessary
            IND = find(GERR,1,4)
Endcase

Local Integer LALT

Case ABR
  When "SMW1"
    # Only when major-version is loaded and startdate has been changed
    If [M:SMW1]ECCVALMAJ=""
        Call ECCAFF([M:SMW1]ITMREF,"SMW1") From MFGECCLIB
        If [M:SMW1]ALLSTA > 1 | [M:SMW1]WIPSTA<3 : # Issue 107089 - 2015-12-22 by GH : In case of a product not versioned, BOM code is always actived by ECCAFF
           Diszo [M:SMW1]BOMALT2
        Endif
        If func ECCLIB.NBRCPN([M:SMW1]ITMREF)
            # ECC preload of major and minor version + BOM code
            LALT = [M:SMW1]BOMALT2
            Raz [M:SMW1]ECCVALMAJ,[M:SMW1]ECCVALMIN
            Call INIECCBOM([M:SMW1]ITMREF, [M:SMW1]POHFCY, [M:SMW1]STRDAT2, 3, [M:SMW1]ECCVALMAJ,[M:SMW1]ECCVALMIN,LALT) From MFGECCLIB
            [M:SMW1]BOMALT2 = LALT
            Affzo [M:SMW1]ECCVALMAJ,ECCVALMIN,BOMALT2
            GERR=0
            GMESSAGE=""
            End
        Endif
    Endif
  When "SMW3"
    # Only when major-version is loaded and startdate has been changed
    If [M:SMW3]ECCVALMAJ=""
        Call ECCAFF([M:SMW3]ITMREF,"SMW3") From MFGECCLIB
        If func ECCLIB.NBRCPN([M:SMW3]ITMREF)
            # ECC preload of major and minor version + BOM code
            LALT = [M:SMW3]BOMALT2
            Raz [M:SMW3]ECCVALMAJ,[M:SMW3]ECCVALMIN
            Call INIECCBOM([M:SMW3]ITMREF, [M:SMW3]PRHFCY, [M:SMW3]STRDAT2, 3, [M:SMW3]ECCVALMAJ,[M:SMW3]ECCVALMIN,LALT) From MFGECCLIB
            [M:SMW3]BOMALT2 = LALT
            Affzo [M:SMW3]ECCVALMAJ,ECCVALMIN,BOMALT2
            GERR=0
            GMESSAGE=""
            End
        Endif
    Endif
Endcase

# In case of an error -> error-message
If IND>0 | GERR>0
    Case ABR
        When "SMW1"
            [M:SMW1]STRDAT2 = LSAVDAT
            Affzo [M:SMW1]STRDAT2
        When "SMW3"
            [M:SMW3]STRDAT2 = LSAVDAT
            Affzo [M:SMW3]STRDAT2
    Endcase
    GERR=1
    mkstat=2
Endif

End

