#<AdxTL>@(#)0.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#

GACTION = "TPSVAR"
Local Char PARAM(30)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"TPSVAR","MAJVAR","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "ABA"         : Gosub ABANDON
 When "ENR"         : Gosub ENREGISTRE
 #** V7 : Waiting Time Mangement **#
 When "FIN"         : Gosub FIN
Endcase
Return

$OUVRE
If clalev([F:VRA])=0 : Local File VARIA   [VRA] : Endif
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If clalev([F:TIM])=0 : Local File TIMCOD  [TIM] : Endif
#*!
If clalev([F:TIM])=0 : Local File TIMCOD  [TIM] : Endif
#ADNGO - 2017-05-20 - END
Global Integer GTPS2 : GTPS2=0 #don't use GTPS because treatment can be called by SUBVRA
#***
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Local Integer FLMOD , OKVAR , PLEIN
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif

#JOJAC - START
# bug 103920
Local Integer IS_MAJVAR1
IS_MAJVAR1=(GACTION="MAJVAR1")
#JOJAC - END

Return

$FIN
If dim(GTPS2)>-1 : Kill GTPS2 : Endif
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$DEBUT
#If GCURLEG="" & (GNBLEG = 1 | GLEGFIL="")
 # GCURLEG = GDOSLEG
#Elsif GCURLEG=""
 # GCURLEG=GLEGFIL
#Endif

If GLEGFIL <> "" Then
  GCURLEG=GLEGFIL
Endif


Gosub CHARGE
Return

$CHARGE
Raz [M]
[M]LEG = GCURLEG

nolign = 0
PLEIN = 0
Filter [F:VRA] Where LEG = GCURLEG

For [VRA]VRA0 Where FLGEXS<>2 & LEG=GCURLEG
 Gosub TEST
 If OKVAR
  If nolign>=dim([M]VARCOD)
   PLEIN = 1 : Break
  Endif
  nolign += 1
  [M] = [F:VRA]
  [M]VARCOD(nolign-1) = [F:VRA]COD
  Gosub LIRE
 Endif
Next
[M]NBLIG = nolign
Affzo
If PLEIN
 Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
Endif


Return

$APRES_MODIF
FLMOD = 1
#JOJAC - START
# bug 103920
If !IS_MAJVAR1
#JOJAC - END
# Grisage des champs à la l'activation de la ligne
  If GTPS2 <> 0
    Call GRISE_TYPMAJ([M]TYPMAJ(nolign-1))
    Call GRISE_TYPVAL([M]TYPVAL(nolign-1))
  Endif
Endif
If COUZON = 'LEG'
  GCURLEG = CZ
  Gosub CHARGE
Endif
Return

$SETBOUT
If FLMOD
 ETABOU(GENRE) = 1
 ETABOU(GABAN) = 1
Else
 ETABOU(GENRE) = 0
 ETABOU(GABAN) = 0
Endif
Return

$ABANDON
Gosub CHARGE
FLMOD = 0
Return

$ENREGISTRE
Call DEBTRANS From GLOCK
Gosub TR1
FLMOD = 0
Return

###########################################################################
$TEST
Case GACTION
 When "TPSVAR"
  OKVAR = ([F:VRA]TYPINI=4)
 When "MAJVAR1"
  OKVAR = find(2,[F:VRA]PRNFLG(0..1))
Endcase
Return

$RAZE
Case GACTION
 When "TPSVAR"
  [F:VRA]TYPINI = 2
  Raz [F:VRA]TIMCOD,[F:VRA]TIMCMT,[F:VRA]TIMVAR
 When "MAJVAR1"
  [F:VRA]PRNFLG(0) = 1
  [F:VRA]PRNFLG(1) = 1
Endcase
Return

$LIRE
Case GACTION
 When "TPSVAR"
 When "MAJVAR1"
  [M]PRNFLG1(nolign-1)  = min(max([F:VRA]PRNFLG(0),1),2)
  [M]PRNFLG2(nolign-1)  = min(max([F:VRA]PRNFLG(1),1),2)
Endcase
Return

$ECRIRE
Case GACTION
 When "TPSVAR"
  [F:VRA]TYPINI = 4
 When "MAJVAR1"
  [F:VRA]PRNFLG(0) = [M]PRNFLG1(nolign-1)
  [F:VRA]PRNFLG(1) = [M]PRNFLG2(nolign-1)
Endcase
Return

###########################################################################

$TR1
GOK = 1
Trbegin [VRA]
 For nolign=1 To [M]NBLIG
  Readlock [VRA]VRA0 = GCURLEG;[M]VARCOD(nolign-1)
  If fstat=1
   GOK = -1 : GLOCK = "$VARIA"-[M]VARCOD(nolign-1) : Break
  Elsif fstat
   GOK = 0 : Call RSTA("VRA",[M]VARCOD(nolign-1)) From GLOCK : Break
  Endif
  [F:VRA] = [M]
  Gosub ECRIRE
  Rewrite [VRA]
  If fstat
   GOK = 0 : Call FSTA("VRA") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 For [VRA]VRA0 Where FLGEXS<>2 & LEG=GCURLEG
  Gosub TEST
  If OKVAR
   If !find([F:VRA]COD,[M]VARCOD(0..[M]NBLIG-1))
    Readlock [VRA]VRA0 Curr
    If fstat=1
     GOK = -1 : GLOCK = "$VARIA"-[F:VRA]COD : Break
    Elsif fstat
     GOK = 0 : Call RSTA("VRA",[F:VRA]COD) From GLOCK : Break
    Endif
    Gosub RAZE
    Rewrite [VRA]
    If fstat
     GOK = 0 : Call FSTA("VRA") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

########################################
## Ecran TPSVAR
########################################
Subprog AS_TYPVAL(VALEUR)
Variable Integer VALEUR
If GTPS2
 If [M]TYPMAJ(nolign-1)=2 : mkstat = 1 : End : Endif
Endif
End

Subprog C_TYPVAL(VALEUR)
Variable Integer VALEUR
Call GRISE_TYPVAL(VALEUR)
End

Subprog GRISE_TYPVAL(VALEUR)
Value Integer VALEUR
If GTPS2
 If VALEUR=1 & [M]TYPMAJ(nolign-1)=1
  Actzo [M]DAYTYP(nolign-1)
 Else
  Grizo [M]DAYTYP(nolign-1)
 Endif
 # WGA : W00001 Prolongation
 If VALEUR=5 & [M]TYPMAJ(nolign-1)=1
  Grizo [M]NATCOD(nolign-1)
 Endif
#W00001
Endif
End

Subprog AS_TIMCOD(VALEUR)
Variable Char    VALEUR()
If GTPS2
 If [M]TYPMAJ(nolign-1)=2  | [M]NATCOD(nolign-1)<>"" : mkstat = 1 : End : Endif
Endif
End

Subprog C_TIMCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 If !GTPS2 | [M]TYPVAL(nolign-1) = 5
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat=2 : End
 Else
  Actzo [M]NATCOD(nolign-1)
 Endif
Else
 VALEUR=toupper(VALEUR)
 #ADNGO - 2017-05-20 - START
 #** V7 : Waiting Time Mangement **#
 #**If !instr(1,VALEUR,"*") & !instr (1,VALEUR,"?") & !instr (1,VALEUR,"#") & !instr (1,VALEUR,"!")
 #** Call CONTROLE("TIM","!",VALEUR,"",mkstat) From CONTOBJ
 #** If mkstat : End : Endif
 #**Endif
 #**If [M]TYPMAJ(nolign-1) = 1 & [M]TYPVAL(nolign-1) = 5
#**&  &  VALEUR <> func AFNC.PARAM("AT","")
#**&  &  VALEUR <> func AFNC.PARAM("MALADIE","")
#**&  &  VALEUR <> func AFNC.PARAM("MATERNITE","")
#**&  &  VALEUR <> func AFNC.PARAM("ATTRAJET","")
#**&  &  VALEUR <> func AFNC.PARAM("PATERNITE","")
#**&  &  VALEUR <> func AFNC.PARAM("MALPROF","")
#**&  &  VALEUR <> func AFNC.PARAM("PATHPOST","")
#**&  &  VALEUR <> func AFNC.PARAM("PATHPREN","")
#**     GMESSAGE = mess(187,10709,1) # L'évènement doit être une valeur des paramétres d'absence ( chapitre PAY / ATT )
#**     mkstat=2
#**     End
#** Endif
If !instr(1,VALEUR,"*") & !instr (1,VALEUR,"?") & !instr (1,VALEUR,"#") & !instr (1,VALEUR,"!")
  Call CONTROLE("TIM","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
 Endif
 If [M]TYPMAJ(nolign-1) = 1 & [M]TYPVAL(nolign-1) = 5
&  &  VALEUR <> func AFNC.PARAM("AT","")
&  &  VALEUR <> func AFNC.PARAM("MALADIE","")
&  &  VALEUR <> func AFNC.PARAM("MATERNITE","")
&  &  VALEUR <> func AFNC.PARAM("ATTRAJET","")
&  &  VALEUR <> func AFNC.PARAM("PATERNITE","")
&  &  VALEUR <> func AFNC.PARAM("MALPROF","")
&  &  VALEUR <> func AFNC.PARAM("PATHPOST","")
&  &  VALEUR <> func AFNC.PARAM("PATHPREN","")
     GMESSAGE = mess(187,10709,1) # L'évènement doit être une valeur des paramétres d'absence ( chapitre PAY / ATT )
     mkstat=2
     End
Endif
#ADNGO - 2017-05-20 - END
Endif
End

Subprog AS_TIMVAR(VALEUR)
Variable Char    VALEUR()
If GTPS2
 If [M]TYPMAJ(nolign-1)=1 : mkstat = 1 : End : Endif
Endif
End

Subprog C_TIMVAR(VALEUR)
Variable Char    VALEUR()
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
#**Read [ATZ]CODZONE = "TIMRECAP";VALEUR
#**If fstat or [F:ATZ]CODTYP<>"CDY"
#** GMESSAGE = mess(24,10709,1) : # Variable non définie dans TIMRECAP
#** mkstat = 2 : End
#**Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
Read [ATZ]CODZONE = "TIMRECAP";VALEUR
If fstat or [F:ATZ]CODTYP<>"CDY"
 GMESSAGE = mess(24,10709,1) : # Variable non définie dans TIMRECAP
 mkstat = 2 : End
Endif
#*!
#ADNGO - 2017-05-20 - END
End

Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VARCOD(0..[M]NBLIG)) From OBJDIV
End

Subprog AS_NATCOD(VALEUR)
Variable Char    VALEUR()
If GTPS2
 If [M]TYPMAJ(nolign-1)=2 | [M]TIMCOD(nolign-1)<>"" : mkstat = 1 : End : Endif
Endif
End

Subprog C_NATCOD(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If !instr(1,VALEUR,"*") & !instr (1,VALEUR,"?") & !instr (1,VALEUR,"#") & !instr (1,VALEUR,"!")
 Call CONTROLE("NAT","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
Endif
End

Subprog C_FORVAR(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

Subprog CONTFRM(FORMULE)
Variable Char FORMULE
Local Integer I , J , T , OK
Local Char    OP2(2) , OP(3) , CODE(80)
FORMULE = vireblc(format$("KT:250X",FORMULE),2)
I = 0
GERR = 0

While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 T = 0
 If find(OP2,"E_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  If OP="E_"
   Read [ADI]CODE = 10606;CODE
   If fstat
    GERR = 1 : GMESSAGE = mess(302,197,1) :# Opération INEXISTANTE : Break
   Endif
  Endif
  I += 1
 Else
  I += 1
 Endif
Wend
If GERR
 GMESSAGE = CODE+"\"+GMESSAGE : mkstat = 2
Endif
End

Subprog IB_FORVAR
#50308 : En attendant la modif superviseur pour gérer le contenu d'une table diverse dans l'éditeur de formule
Raz GBOUT1
End

Subprog C_TYPMAJ(VALEUR)
Variable Integer VALEUR
Call GRISE_TYPMAJ(VALEUR)
End

Subprog GRISE_TYPMAJ(VALEUR)
Value Integer VALEUR
If VALEUR=1
 Actzo [M]TYPVAL(nolign-1),TIMCOD(nolign-1),TIMCMT(nolign-1),CMTDET(nolign-1)
 Effzo [M]FORVAR(nolign-1)
 Grizo [M]FORVAR(nolign-1)
 If GTPS2
  Actzo [M]DAYTYP(nolign-1)
  If [M]TIMCOD(nolign-1)="" & [M]NATCOD(nolign-1)<>""
   Actzo [M]NATCOD(nolign-1)
   Grizo [M]TIMCOD(nolign-1)
  Endif
  Effzo [M]TIMVAR(nolign-1)
  Grizo [M]TIMVAR(nolign-1)
 Endif
Elsif VALEUR=2
 Effzo [M]TIMCOD(nolign-1),TIMCMT(nolign-1),CMTDET(nolign-1),FORVAR(nolign-1)
 Grizo [M]TYPVAL(nolign-1),TIMCOD(nolign-1),TIMCMT(nolign-1),CMTDET(nolign-1),FORVAR(nolign-1)
 If GTPS2
  Actzo [M]TIMVAR(nolign-1)
  Effzo [M]NATCOD(nolign-1)
  Grizo [M]NATCOD(nolign-1),DAYTYP(nolign-1)
 Endif
Else
 Actzo [M]FORVAR(nolign-1)
 Effzo [M]TIMCOD(nolign-1),TIMCMT(nolign-1),CMTDET(nolign-1)
 Grizo [M]TYPVAL(nolign-1),TIMCOD(nolign-1),TIMCMT(nolign-1),CMTDET(nolign-1)
 If GTPS2
  Effzo [M]NATCOD(nolign-1),TIMVAR(nolign-1)
  Grizo [M]NATCOD(nolign-1),TIMVAR(nolign-1),DAYTYP(nolign-1)
 Endif
Endif
End

Subprog AS_TYPMAJ(VALEUR)
Variable Integer VALEUR
If !GTPS2 : GMENLOC(2)=1 : Endif :# Pas le choix 'synthèse'
End


