#<AdxTL>@(#)12.0.0.0 $Revision$
Local Clbfile CLBP(12)
Local Integer ERR
Call CREPORT("USR11",CLBP,"ALL")
Call READCLB(CLBP) From ACREVIG
End
Local Char IDPAR(10)(1..10)
Local Clbfile VALPAR(1)(1..10)
Local Clbfile CLBP(9)
Local Integer ERR

Call INTERTAB("INI_PANE",IDPAR,VALPAR,CLBP,ERR)
Call READCLB(CLBP) From ACREVIG
End


#
#       ACREVIG    -         Création et mise à jour du portail interactif
#
#
# ----------------------------------------------------------------------------------------------------------------------------

# INTERTAB(ACTION,IDPAR,VALPAR,CLBP,ERR)                            Programme d'interaction avec le portail
#
# TOXMLTABS(UTILIS,CLBP)                                            Crée le clob du portail utilisateur
#
# UPDAPP(UTILIS,VALOUV,ERR)                                         Ferme ou ouvre la liste des menus
# ORDTAB(UTILIS,ORDRE,ERR)                                          Reordonne les onglets
# VISTAB(UTILIS,CODTAB,ERR)                                         Rend actif un onglet
#
# SUPTABS(UTILIS)                                                   Supprime un portail utilisateur
# SUPALLTABS                                                        Supprime tous les portails utilisateur
# INITABS(UTILIS)                                                   Crée un portail utilisateur vide
# DUPTABS(UTILIS,NEWUSE,CONN,ERR)                                   Duplique un portail utilisateur pour un autre utilisateur
#
# CRETAB(UTILIS,CODTAB,TIT,ERR)                                     Crée un onglet
# MODTAB(UTILIS,CODTAB,TIT,ICONE,NBCOL,ERR)                         Modifie un onglet
# SUBTAB(UTILIS,CODTAB,ERR)                                         Supprime un onglet
#
# CREMOD(UTILIS,CODTAB,CODMOD,MORD,ID,VIGNETTE,ERR)                 Crée un module
# MODMOD(UTILIS,CODTAB,CODMOD,PARAMID,PARAMVAL,CLBP,ERR)            Modifie un module
# SUPMOD(UTILIS,CODTAB,CODMOD,ERR)                                  Supprime un module
#
# SUPVIG(CODVIG,ERR) *****  A faire                                 Supprime une vignette pour tous les utilisateurs

# ----------------------------------------------------------------------------------------------------------------------------


Subprog VSPORT(UTILIS)
Value Char UTILIS
If clalev([F:APU])=0  : Local File APORTUSER [APU]  : Endif
If clalev([F:APA])=0  : Local File APORTTAB  [APA]  : Endif
If clalev([F:AMO])=0  : Local File APORTMOD  [AMO]  : Endif
If clalev([F:AVP])=0  : Local File APORTVIG  [AVP]  : Endif
If clalev([F:ATP])=0  : Local File APORTTYP  [ATP]  : Endif
Call OUVRE_TRACE("Portal trace : "+UTILIS) From LECFIC
Read [APU]APU0=UTILIS
If fstat=0
  Call ECR_TRACE("[APU]  OK"+"    NBTAB  : "+num$([F:APU]NBTAB),0) From GESECRAN
Else
  Call ECR_TRACE("[APU]  KO",1) From GESECRAN
Endif
Local Integer I,J

For I=0 To [F:APU]NBTAB-1
  Read [APA]APA0=UTILIS;[F:APU]CODTAB(I)
  If fstat=0
    Call ECR_TRACE("[APA]  OK  :"-[F:APU]CODTAB(I)-[F:APA]TITELT-"  ("+num$([F:APA]NBMOD)-"modules)",0) From GESECRAN
    Gosub ANAMOD
  Else
    Call ECR_TRACE("[APA]  KO  :"-[F:APU]CODTAB(I),1) From GESECRAN
  Endif
Next I
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

$ANAMOD
#   Boucle sur création de modules
For J=0 To [F:APA]NBMOD-1
  Read [AMO]AMO0=UTILIS;[F:APU]CODTAB(I);[F:APA]CODMOD(J)
  If fstat<>0 :   Call ECR_TRACE("KO 1 ",1) From GESECRAN  : Endif
  Read [AVP]AVP0=[F:AMO]VIGNETTE
  If fstat<>0 :   Call ECR_TRACE("KO 2 ",1) From GESECRAN  : Endif
  Read [ATP]ATP0=[F:AVP]CODFA
  If fstat<>0 :   Call ECR_TRACE("KO 3 ",1) From GESECRAN  : Endif
  Call ECR_TRACE("     Lecture [AMO]    :"-[F:APA]CODMOD(J)-num$([F:APA]COLNUM(J))-[F:AMO]TITELT,0) From GESECRAN
Next J
Return


# ----------------------------------------------------------------------------------------------------------------------------


Subprog INTERTAB(ACTION,IDPAR,VALPARCLB,CLBP,ERR)
Value Char ACTION
Value Char IDPAR()(1..)
Value Clbfile VALPARCLB()(1..)
Variable Clbfile CLBP
Variable Integer ERR
Local Char VALPAR(250)(1..10)
Local Char ID
Local Integer I

#   Incohérence entre les scripts portail et les programmes superviseur. Contactez votre administrateur
If type(VALPARCLB)<15
  Call ERREUR(mess(165,150,1)) From GESECRAN
Endif

For I=1 To 10
  If IDPAR(I) <> "map"
    Setlob VALPAR(I) With VALPARCLB(I)
  Else
    VALPAR(I) = "~"
  Endif
Next I
If ACTION<>"ini_port" and ACTION<>"ini_tabs" and ACTION<>"ini_pane"
  If dim(GMODPORTAUT)<0 or GMODPORTAUT<>1 : ERR=1 : End : Endif
Endif
Case tolower(ACTION)
  When "ini_port"   : Gosub INIPORT
  When "ini_tabs"   : Gosub INI_TABS
  When "ini_pane"   : Gosub INIPANE
  When "tab_new"    : Gosub TABNEW
  When "tab_delete" : Gosub TABDEL
  When "tab_update" : Gosub TABUPD
  When "mod_new","mod_delete","mod_update"    : Gosub MODUPD
  When "app_update" : Gosub APPUPD
Endcase
End

$INIPORT
Call CREPORT(GUSER,CLBP,"ALL")
Return


$INI_TABS
Call CREPORT(GUSER,CLBP,"TABS")
Return

$INIPANE
Call CREPORT(GUSER,CLBP,"PANE")
Return

$TABNEW
ID=""
If clalev([F:APA])=0  : Local File APORTTAB  [APA]  : Endif
Call CRETAB(GUSER,ID,VALPAR(2),ERR)
Local Char ACTTAB,AVIS,UTILIS
Local Integer J
CLBP='<result datatype="object">'
Append CLBP,'<properties>'
Append CLBP,'<property name="id" datatype="string">'+VALPAR(1)+'</property>'
Append CLBP,'<property name="method" datatype="string">updTab</property>'
Append CLBP,'</properties>'
Append CLBP,'<params datatype="object">'
CODTAB=ID : ACTTAB=ID : UTILIS=GUSER
Gosub TOXMLTAB
Append CLBP,'</params>'
Append CLBP,'</result> '
Return


$TABDEL
Call SUBTAB(GUSER,VALPAR(1),ERR)
Return

$TABUPD

If IDPAR(2)="visible"
  Call VISTAB(GUSER,VALPAR(1),ERR)
Elsif left$(IDPAR(2),4)="mord"
  Call DEPMOD(GUSER,VALPAR(1),VALPAR(2),ERR)
Elsif left$(IDPAR(2),7)="old_tid"
  Call DEPMODO(GUSER,VALPAR(1),VALPAR(2),VALPAR(3),VALPAR(4),ERR)
Else
  Local Char ATIT(100) : ATIT="~"
  Local Char AICO(100) : AICO="~"
  Local Integer ACOL   : ACOL=-1
  Local Clbfile AMAP(1)     : AMAP="~"
  Local Char FSHBORD(5)     : FSHBORD="~"
  Local Char SHSEP(5)       : SHSEP="~"

  For I=1 To 10
    Case IDPAR(I)
      When "title"    : ATIT=VALPAR(I)
      When "ico"      : AICO=VALPAR(I)
      When "colcount" : ACOL=val(VALPAR(I))
      When "map"      : AMAP=VALPARCLB(I)
      When "forceShowBorders"  : FSHBORD=VALPAR(I)
      When "showSeparators"  : SHSEP=VALPAR(I)
      When ""         : Break 1
    Endcase
  Next I
  Call MODTAB(GUSER,VALPAR(1),ATIT,AICO,ACOL,AMAP,FSHBORD,SHSEP,ERR)
Endif
Return

$MODUPD
ID=""
Local Char MORD(250)
Local Char CODTAB,UTILIS,CODMOD,VIGNETTE,ID
Local Integer K,POS,COLNUMMOD
If clalev([F:APA])=0  : Local File APORTTAB  [APA]  : Endif
If clalev([F:AMO])=0  : Local File APORTMOD  [AMO]  : Endif
If clalev([F:AVP])=0  : Local File APORTVIG  [AVP]  : Endif
If clalev([F:ATP])=0  : Local File APORTTYP  [ATP]  : Endif
For I=1 To 10
  Case IDPAR(I)
    When "tid"                  : CODTAB=VALPAR(I)
    When "iid"                  : VIGNETTE=VALPAR(I)
    When "mid"                  : ID=VALPAR(I)
    When "mord","morder"        : MORD=VALPAR(I)
    When ""                     : Break 1
  Endcase
Next I

Case tolower(ACTION)
  When "mod_new"    : Gosub MODNEW
  When "mod_delete" : Call SUPMOD(GUSER,CODTAB,ID,ERR)
  When "mod_update" : Call MODMOD(GUSER,CODTAB,ID,IDPAR,VALPAR,CLBP,ERR)
Endcase
Return

$MODNEW
Call CREMOD(GUSER,CODTAB,CODMOD,MORD,ID,VIGNETTE,ERR)
If ERR<>0 : Return : Endif
CLBP='<result datatype="object">'
Append CLBP,'<properties>'
Append CLBP,'<property name="id" datatype="string">'+ID+'</property>'
Append CLBP,'<property name="method" datatype="string">updMod</property>'
Append CLBP,'</properties>'
Append CLBP,'<params datatype="object">'
UTILIS=GUSER
POS=instr(1,MORD,ID+":")
POS=instr(POS+1,MORD,":")
COLNUMMOD=val(mid$(MORD,POS+1,1))
Gosub TOXMLMOD
Append CLBP,'</params>'
Append CLBP,'</result> '
Return


$APPUPD
If IDPAR(1)="torder"
  Call ORDTAB(GUSER,VALPAR(1),ERR)
  Return
Endif
Call UPDAPP(GUSER,VALPAR(1),ERR)
Return


# ----------------------------------------------------------------------------

$TOXMLTAB
Read [APA]APA0=UTILIS;CODTAB
If fstat<>0 : Return : Endif
Append CLBP,'<tab datatype="object">'
Append CLBP,'<properties>'
Append CLBP,'<property name="title" datatype="string">'+[F:APA]TITELT+'</property>'
Append CLBP,'<property name="colcount" datatype="int">'+num$([F:APA]COLCOUNT)+'</property>'
If ACTTAB=CODTAB : AVIS='true' : Else : AVIS='false' : Endif
Append CLBP,'<property name="visible" datatype="bool">'+AVIS+'</property>'
If [F:APA]ICONE<>""
  Append CLBP,'<property name="icone" datatype="string">'
  If left$([F:APA]ICONE,4)="http"
    Append CLBP,[F:APA]ICONE
  Else
    Local Integer PA1 : PA1=instr(1,[F:APA]ICONE,"\")
    If GBROWS=0
      Append CLBP,"http://"+GVIRTDIR+"/X3_ROOT/"+left$([F:APA]ICONE,PA1-1)+"/IMG/"+right$([F:APA]ICONE,PA1+1)
    Else
      Append CLBP,"../../"+left$([F:APA]ICONE,PA1-1)+"/IMG/"+right$([F:APA]ICONE,PA1+1)
    Endif
  Endif
  Append CLBP,'</property>'
Endif


Append CLBP,'<property name="id" datatype="string">'+CODTAB+'</property>'
If [F:APA]MAPT <> ""
    Append CLBP,'<property name="map" datatype="string">'+[F:APA]MAPT+'</property>'
Endif
If ([F:APA]FSHBORDT <> "" and [F:APA]FSHBORDT <> "false")
    Append CLBP,'<property name="forceShowBorders" datatype="string">'+[F:APA]FSHBORDT +'</property>'
Endif
If ([F:APA]SHSEPT <> "" and [F:APA]SHSEPT <> "false")
    Append CLBP,'<property name="showSeparators" datatype="string">'+[F:APA]SHSEPT +'</property>'
Endif
Append CLBP,'</properties>'
Append CLBP,'<modules datatype="array">'

#   Boucle sur création de modules
For J=0 To [F:APA]NBMOD-1
  CODMOD=[F:APA]CODMOD(J)
  COLNUMMOD=[F:APA]COLNUM(J)
  Gosub TOXMLMOD
Next J

Append CLBP,'</modules>'
Append CLBP,'</tab>'
Return

# ----------------------------------------------------------------------------

$TOXMLMOD
Read [AMO]AMO0=UTILIS;CODTAB;CODMOD
If fstat<>0 : Return : Endif
Read [AVP]AVP0=[F:AMO]VIGNETTE
If fstat<>0 : Return : Endif
Read [ATP]ATP0=[F:AVP]CODFA
If fstat<>0 : Return : Endif


Append CLBP,'<module datatype="object">'
Append CLBP,'<properties>'
Local Char AEXPEND : AEXPEND="true"
If [F:AMO]EXPEND<>2 : AEXPEND="false" : Endif
Append CLBP,'<property name="exp" datatype="bool">'+AEXPEND+'</property>'
Append CLBP,'<property name="colnum" datatype="int">'+num$(COLNUMMOD)+'</property>'
Local Char TITVIG(100)
TITVIG=[F:AMO]TITELT

Call MODVAL(TITVIG) From INTRUTILA
Append CLBP,'<property name="title" datatype="string">'+TITVIG+'</property>'
Append CLBP,'<property name="modtype" datatype="string">'+[F:AMO]MODTYP+'</property>'
If [F:AMO]ICONE<>""
  Append CLBP,'<property name="ico" datatype="string">'
  If left$([F:AMO]ICONE,4)="http"
    Append CLBP,[F:AMO]ICONE
  Else
    Local Integer PA1 : PA1=instr(1,[F:AMO]ICONE,"\")
    If GBROWS=0
      Append CLBP,"http://"+GVIRTDIR+"/X3_ROOT/"+left$([F:AMO]ICONE,PA1-1)+"/IMG/"+right$([F:AMO]ICONE,PA1+1)
    Else
      Append CLBP,"../../"+left$([F:AMO]ICONE,PA1-1)+"/IMG/"+right$([F:AMO]ICONE,PA1+1)
    Endif
  Endif
  Append CLBP,'</property>'
Endif

If ([F:AMO]SHBORDM<>"" and [F:AMO]SHBORDM<>"true")
    Append CLBP,'<property name="showBorder" datatype="bool">'+[F:AMO]SHBORDM+'</property>'
Endif
If ([F:AMO]SHHEADM<>"" and [F:AMO]SHHEADM<>"true")
    Append CLBP,'<property name="showHeader" datatype="bool">'+[F:AMO]SHHEADM+'</property>'
Endif

Append CLBP,'<property name="id" datatype="string">'+CODMOD+'</property>'
Append CLBP,'</properties>'
Append CLBP,'<params datatype="array">'

#   Boucle sur création de parametres
Local Char TYPPAR,INTPA(40)

For K=0 To dim([F:AMO]NAMPAR)-1
  If [F:AMO]NAMPAR(K)="" : Break 1 : Endif
  Case [F:ATP]PROPT(K)
     When 1       : TYPPAR="string"
     When 2       : TYPPAR="int"
     When 3       : TYPPAR="bool"
     When 4       : TYPPAR="number"
     When 5       : TYPPAR="date"
     When 6       : TYPPAR="text"
     When 7       : TYPPAR="enum"
     When Default : TYPPAR="string"
  Endcase
  Gosub TOXMLPAR
Next K

Append CLBP,'<properties>'
Append CLBP,'<property name="id" datatype="string">'+CODMOD+"G1"+'</property>'
Append CLBP,'</properties>'
Append CLBP,'</params>'
Append CLBP,'</module>'
Return

# ----------------------------------------------------------------------------
$TOXMLPAR
Append CLBP,'<param datatype="object">'
Append CLBP,'<properties>'
Append CLBP,'<property name="name" datatype="string">'+[F:AMO]NAMPAR(K)+'</property>'
If [F:AMO]MODTYP="webnote" and [F:AMO]NAMPAR(K)="Text"
  Append CLBP,'<property name="value" datatype="'+TYPPAR+'">'+[F:AMO]TEXTCL+'</property>'
#Elsif [F:AVP]CODFA="PROC" and [F:AMO]NAMPAR(K)="IDATA"
#  Append CLBP,'<property name="Value" datatype="'+TYPPAR+'">'+[F:AMO]VALPAR(K)+';'
#  Append CLBP,[F:AMO]VALPAR(K+1)+'</PROPERTY>'
Elsif [F:AMO]NAMPAR(K)="URI" and left$([F:AMO]VALPAR(K),1)="="
    Onerrgo ERRP1
    Local Char VALUR1(250)
    VALUR1=evalue(right$([F:AMO]VALPAR(K),2))
    If TYPPAR="string" : Call MODVAL(VALUR1) From INTRUTILA : Endif
    Onerrgo
    Append CLBP,'<property name="value" datatype="'+TYPPAR+'">'+VALUR1+'</property>'
Else
    If TYPPAR="string"
      Local Char VALUR1(250)         :# Bug 76789    CC   02/02/2012
      VALUR1=[F:AMO]VALPAR(K)
      Call MODVAL(VALUR1) From INTRUTILA
      Append CLBP,'<property name="value" datatype="'+TYPPAR+'">'+VALUR1+'</property>'
    Else
      Append CLBP,'<property name="value" datatype="'+TYPPAR+'">'+[F:AMO]VALPAR(K)+'</property>'
    Endif
Endif
If [F:AMO]INTPART(K)<>0
  Call TEXTE([F:AMO]INTPART(K),INTPA) From OBJDIV
Else
  INTPA=""
Endif
Append CLBP,'<property name="title" datatype="string">'+INTPA+'</property>'
Append CLBP,'<property name="paramtype" datatype="string">'+TYPPAR+'</property>'
Append CLBP,'<property name="id" datatype="string">'+CODMOD+'P'+num$(K)+'</property>'
Append CLBP,'</properties>'
Append CLBP,'</param>'
Return

# ----------------------------------------------------------------------------
# SUPTABS : supprime un portail utilisateur
Subprog SUPTABS(UTILIS)
Value Char UTILIS
If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif
Read [APU]APU0=UTILIS
If fstat<>0 : End : Endif
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif
If clalev([F:AMO])=0 : Local File APORTMOD [AMO]  : Endif
Trbegin [APU],[APA],[AMO]
Delete [APU] Where CODUSR=UTILIS
Delete [APA] Where CODUSR=UTILIS
Delete [AMO] Where CODUSR=UTILIS
Commit
End

# ----------------------------------------------------------------------------
# SUPALLTABS : supprime tous les portails utilisateur
Subprog SUPALLTABS
If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif
If clalev([F:AMO])=0 : Local File APORTMOD [AMO]  : Endif

Trbegin [APU],[APA],[AMO]
For [AMO]
 Delete [AMO]
Next

For [APA]
 Delete [APA]
Next

For [APU]
 Delete [APU]
Next
Commit
End

# ----------------------------------------------------------------------------
# SUPTAB  : supprime un onglet
Subprog SUBTAB(UTILIS,CODTAB,ERR)
Value Char UTILIS
Value Char CODTAB
Variable Integer ERR
If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif
If clalev([F:AMO])=0 : Local File APORTMOD  [AMO] : Endif
Local Integer I,J
ERR=0
Read [APU]APU0=UTILIS
If fstat<>0 : ERR=4 : End : Endif
Trbegin [APU],[APA],[AMO]
For I=0 To [F:APU]NBTAB-1
  If [F:APU]CODTAB(I)=CODTAB
    J=1 : [F:APU]CODTAB(I)=""
  Else
     If J=1
       [F:APU]CODTAB(I-1)=[F:APU]CODTAB(I)
     Endif
  Endif
Next I
If J=1 : [F:APU]NBTAB-=1 : Endif

For I=[F:APU]NBTAB To dim([F:APU]CODTAB)-1
 [F:APU]CODTAB(I)=""
Next I

Rewrite [APU]

Delete [AMO] Where CODUSR=UTILIS & CODTAB=[L]CODTAB
ERR=fstat
ERR=adxdlrec
Delete [APA]APA0=UTILIS;CODTAB
ERR=fstat

Commit

End

# ----------------------------------------------------------------------------
# SUPMOD  : supprime un module
Subprog SUPMOD(UTILIS,CODTAB,CODMOD,ERR)
Value Char UTILIS
Value Char CODTAB
Value Char CODMOD
Variable Integer ERR
Local Integer I,J
ERR=0
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif
If clalev([F:AMO])=0 : Local File APORTMOD [AMO]  : Endif
Read [APA]APA0=UTILIS;CODTAB
If fstat<>0 : ERR=4 : End : Endif
Trbegin [APA],[AMO]
For I=0 To [F:APA]NBMOD-1
  If [F:APA]CODMOD(I)=CODMOD
    J=1 : [F:APA]CODMOD(I)="" : [F:APA]COLNUM(I)=0
  Else
     If J=1
       [F:APA]CODMOD(I-1)=[F:APA]CODMOD(I)
       [F:APA]COLNUM(I-1)=[F:APA]COLNUM(I)
     Endif
  Endif
Next I
If J=1 : [F:APA]NBMOD-=1 : Endif

For I=[F:APA]NBMOD To dim([F:APA]CODMOD)-1
 [F:APA]CODMOD(I)=""
Next I


Rewrite [APA]
Delete [AMO]AMO0=UTILIS;CODTAB;CODMOD
Commit
End

# ----------------------------------------------------------------------------
# DEPMOD  : déplace un module
Subprog DEPMOD(UTILIS,CODTAB,MORD,ERR)
Value Char UTILIS
Value Char CODTAB
Value Char MORD
Variable Integer ERR

Local Integer I,POS,DEB
Local Char CODMT

ERR=0
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif
Read [APA]APA0=UTILIS;CODTAB
If fstat<>0 : ERR=4 : End : Endif

Raz [F:APA]CODMOD
Raz [F:APA]COLNUM
DEB=1
For I=1 To [F:APA]NBMOD
  POS=instr(DEB,MORD,",")
  If POS<>0
    CODMT=mid$(MORD,DEB,POS-DEB)
    DEB=POS+1
  Else
    CODMT=right$(MORD,DEB)
  Endif
  POS=instr(1,CODMT,":")
  [F:APA]COLNUM(I-1)=val(right$(CODMT,POS+1))
  [F:APA]CODMOD(I-1)=left$(CODMT,POS-1)
Next I

Trbegin [APA]
Local Char ABFIC : ABFIC="APA"
Gosub INIMOD From GOBJSUB
Rewrite [APA]
Commit

End

# ----------------------------------------------------------------------------
# DEPMODO  : déplace un module vers un autre onglet
Subprog DEPMODO(UTILIS,NEWTAB,OLDTAB,CODMOD,MORD,ERR)
Value Char UTILIS
Value Char NEWTAB
Value Char OLDTAB
Value Char CODMOD
Value Char MORD
Variable Integer ERR

Local Integer I,POS,DEB
Local Char CODMT

ERR=0
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif
If clalev([F:AMO])=0 : Local File APORTMOD [AMO]  : Endif

Read [APA]APA0=UTILIS;OLDTAB
If fstat<>0 : ERR=4 : End : Endif

# On supprime CODMOD de OLDTAB
IMOD=find(CODMOD,[F:APA]CODMOD(0..[F:APA]NBMOD))
If IMOD=0 : ERR=3 : End : Endif

For I=IMOD-1 To [F:APA]NBMOD-1
  [F:APA]CODMOD(I)=[F:APA]CODMOD(I+1)
  [F:APA]COLNUM(I)=[F:APA]COLNUM(I+1)
Next I
[F:APA]NBMOD-=1
Trbegin [APA],[AMO]
Local Char ABFIC : ABFIC="APA"
Gosub INIMOD From GOBJSUB
Rewrite [APA]

# On modifie CODMOD pour l'associer à NEWTAB
Read [AMO]AMO0=UTILIS;OLDTAB;CODMOD
[F:AMO]CODTAB=NEWTAB
Local Char ABFIC : ABFIC="AMO"
Gosub INIMOD From GOBJSUB
Write [AMO]
If fstat<>0 : ERR=4 : Rollback : End : Endif    :# Write Error on AMO file
Delete [AMO]AMO0=UTILIS;OLDTAB;CODMOD

# On rajoute CODMOD dans NEWTAB

Read [APA]APA0=UTILIS;NEWTAB
If fstat<>0 : ERR=4 : Rollback : End : Endif
[F:APA]NBMOD+=1
For I=[F:APA]NBMOD To 1 Step -1
  [F:APA]CODMOD(I)=[F:APA]CODMOD(I-1)
  [F:APA]COLNUM(I)=[F:APA]COLNUM(I-1)
Next I
[F:APA]CODMOD(0)=CODMOD
[F:APA]COLNUM(0)=0
Rewrite [APA]

Commit
End

# ----------------------------------------------------------------------------
# DUPTABS : duplique un portail utilisateur pour un autre utilisateur
Subprog DUPTABS(UTILIS,NEWUSE,CONN,ERR)
Value Char UTILIS
Value Char NEWUSE
Value Integer CONN
Variable Integer ERR

If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif
If clalev([F:AMO])=0 : Local File APORTMOD [AMO]  : Endif
ERR=0
If UTILIS="" or NEWUSE="" or UTILIS=NEWUSE : ERR=4 : Endif
#   Portail en cours d'utilisation
Read [APU]APU0=NEWUSE
#If fstat=0 and [F:APU]PIDUSE<>"" : ERR=6 : End : Endif
Local Integer I,J,K
Local Char CODTAB(10),CODMOD(10)

Read [APU]APU0=UTILIS
If fstat<>0 : ERR=5 : End : Endif
Call SUPTABS(NEWUSE)
Trbegin [APU],[APA],[AMO]
Read [APU]APU0=UTILIS
[F:APU]CODUSR=NEWUSE
For I=1 To [F:APU]NBTAB
  CODTAB=[F:APU]CODTAB(I-1)
  [F:APU]CODTAB(I-1)="T"+num$(I)
  Gosub XCRETAB
  If ERR=1 : Raz [F:APU]CODTAB(I-1..dim([F:APU]CODTAB)) : [F:APU]NBTAB=I-1 : Break 1 : Endif
Next I
#If CONN=0 : [F:APU]PIDUSE="" : Endif
[F:APU]LASTNUM=[F:APU]NBTAB
If !find([F:APU]ACTIF,[F:APU]CODTAB(0..[F:APU]NBTAB))
 If [F:APU]NBTAB>=1
   [F:APU]ACTIF=[F:APU]CODTAB(0)
 Else
   [F:APU]ACTIF=""
 Endif
Endif
Write [APU]
Commit
End

$XCRETAB
Read[APA]APA0=UTILIS;CODTAB
If fstat<>0 : ERR=1  : Return : Endif
[F:APA]CODUSR=NEWUSE
[F:APA]CODTAB="T"+num$(I)
For J=1 To [F:APA]NBMOD
  CODMOD=[F:APA]CODMOD(J-1)
  [F:APA]CODMOD(J-1)="T"+num$(I)+"M"+num$(J)
  Gosub XCREMOD
  If ERR=1 : Raz [F:APA]CODMOD(J-1..dim([F:APA]CODMOD)) : [F:APA]NBMOD=J-1 : Break 1 : Endif
Next J
[F:APA]LASTMOD=[F:APA]NBMOD
Write [APA]
Return

$XCREMOD
Read[AMO]AMO0=UTILIS;CODTAB;CODMOD
If fstat<>0 : ERR=1  : Return : Endif
[F:AMO]CODUSR=NEWUSE
[F:AMO]CODTAB="T"+num$(I)
[F:AMO]CODMOD="T"+num$(I)+"M"+num$(J)
Write [AMO]
Return


# ----------------------------------------------------------------------------
# SUPVIG  : supprime une vignette pour tous les utilisateurs
Subprog SUPVIG(CODVIG,ERR)
Value Char CODVIG
Variable Integer ERR

If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif
If clalev([F:AMO])=0 : Local File APORTMOD  [AMO] : Endif


End


# ----------------------------------------------------------------------------
# INITABS  : crée un portail utilisateur vide
Subprog INITABS(UTILIS)
Value Char UTILIS
Local Integer ERR,AMAJ
Local Char CODTAB,CODMOD,MORD,AMETIER

Call INIPO(UTILIS,AMETIER,AMAJ)
If AMETIER<>""
   Call DUPTABS(AMETIER,UTILIS,0,ERR)
   If ERR=0 : End : Endif
Endif
CODTAB="T1"
Call SUPTABS(UTILIS)
If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif
[F:APU]CODUSR=UTILIS
[F:APU]LASTNUM=0
#[F:APU]PIDUSE=num$(adxpid)
[F:APU]ACTIF=""
[F:APU]NBTAB=0
Raz [F:APU]CODTAB
Local Char ABFIC : ABFIC="APU"
Gosub INICRE From GOBJSUB
Trbegin [APU]
Write [APU]
Commit

#  On crée les vignettes de navigation si elles n'existent pas
#  La table des familles de vignette (système) est supposée chargée
Call INIVIGNAV("NAVIGX3","NAVIG","",10)
Call INIVIGNAV("FAVX3","FAV","",20)

Call CRETAB(UTILIS,CODTAB,mess(16,7837,1),ERR)
Call MODTAB(UTILIS,CODTAB,"~","~",2,"~","~","~",ERR)
CODMOD="T1M1" : MORD="T1M1:0"
Call CREMOD(UTILIS,CODTAB,CODMOD,MORD,CODMOD,"NAVIGX3",ERR)
CODMOD="T1M2" : MORD="T1M1:0,T1M2:1"
Call CREMOD(UTILIS,CODTAB,CODMOD,MORD,CODMOD,"FAVX3",ERR)

End

# ----------------------------------------------------------------------------
# CRETAB  : crée un onglet
Subprog CRETAB(UTILIS,CODTAB,TIT,ERR)
Value Char UTILIS
Variable Char CODTAB
Value Char TIT
Variable Integer ERR

Local Integer I
ERR=0
If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif

Read [APU]APU0=UTILIS
If fstat<>0 : Call INITABS(UTILIS) : End : Endif

  Local Char TITA(80) : TITA=TIT
  If TITA="" : TITA=mess(4,7837,1) : Endif
  CODTAB="T"+num$([F:APU]LASTNUM+1)
  [F:APA]CODUSR=UTILIS
  [F:APA]CODTAB=CODTAB
  [F:APA]COLCOUNT=1
  [F:APA]TITELT=TITA
  [F:APA]ICONE=""
  Raz [F:APA]CODMOD
  Raz [F:APA]COLNUM
  [F:APA]LASTMOD=0
  [F:APA]NBMOD=0
  Local Char ABFIC : ABFIC="APA"
  Gosub INICRE From GOBJSUB
  Read [APU]APU0=UTILIS
  If fstat<>0 : ERR=5 : End : Endif

  Trbegin [APA],[APU]
  Write [APA]

  [F:APU]LASTNUM+=1
  [F:APU]ACTIF=CODTAB
  [F:APU]NBTAB+=1
  [F:APU]CODTAB([F:APU]NBTAB-1)=CODTAB
  Rewrite [APU]
  Commit
End

# ----------------------------------------------------------------------------
# MODTAB  : modifie un onglet
Subprog MODTAB(UTILIS,CODTAB,TIT,ICONE,NBCOL,MAP,FSHBORD,SHSEP,ERR)
Value Char UTILIS
Variable Char CODTAB
Value Char TIT
Value Char ICONE
Value Integer NBCOL
Value Clbfile MAP
Value Char FSHBORD
Value Char SHSEP
Variable Integer ERR

Local Integer I,OKT
ERR=0
OKT=2

If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif

Read [APU]APU0=UTILIS
If fstat<>0 : Call INITABS(UTILIS) : End : Endif

Read [APA]APA0=UTILIS;CODTAB
If fstat<>0 : ERR=6 : End : Endif
If TIT<>"~"
  If left$([F:APA]TITELT,1)="="
# Vous modifiez un titre défini par une formule, confirmez vous le remplacement ?
    Call OUINON(mess(29,7837,1)-"["-[F:APA]TITELT-"]",OKT) From GESECRAN
  Endif
  If OKT=2 : [F:APA]TITELT=TIT : Endif
Endif
If ICONE<>"~" :[F:APA]ICONE=ICONE : Endif
If [F:APA]COLCOUNT<>NBCOL and NBCOL<>-1
  For I=0 To [F:APA]NBMOD-1
    If [F:APA]COLNUM(I)>NBCOL : [F:APA]COLNUM(I)=NBCOL : Endif
  Next I
  [F:APA]COLCOUNT=NBCOL
Endif
If MAP<>"~" : [F:APA]MAPT=MAP : Endif
If FSHBORD<>"~" : [F:APA]FSHBORDT=FSHBORD : Endif
If SHSEP<>"~" : [F:APA]SHSEPT=SHSEP : Endif
Local Char ABFIC : ABFIC="APA"
Gosub INIMOD From GOBJSUB
Trbegin [APA],[APU]
Rewrite [APA]

Read [APU]APU0=UTILIS
If fstat<>0 : ERR=5 : End : Endif
[F:APU]ACTIF=CODTAB
Rewrite [APU]
Commit
End


# ----------------------------------------------------------------------------
# VISTAB  : rend actif un onglet
Subprog VISTAB(UTILIS,CODTAB,ERR)
Value Char UTILIS
Value Char CODTAB
Variable Integer ERR

If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif

ERR=0
Trbegin [APU]
Read [APU]APU0=UTILIS
If fstat<>0 : ERR=5 : End : Endif
If !find(CODTAB,CODTAB(0..NBTAB-1)) : ERR=6 : End : Endif
[F:APU]ACTIF=CODTAB
Local Char ABFIC : ABFIC="APU"
Gosub INIMOD From GOBJSUB
Rewrite [APU]
Commit
End


# ----------------------------------------------------------------------------
# UPDAPP  : ferme ou ouvre la liste des menus
Subprog UPDAPP(UTILIS,VALOUV,ERR)
Value Char UTILIS
Value Char VALOUV
Variable Integer ERR

If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif

ERR=0
Trbegin [APU]
Read [APU]APU0=UTILIS
If fstat<>0 : ERR=5 : End : Endif
[F:APU]MENUOPEN=1
If VALOUV="true" : [F:APU]MENUOPEN=2 : Endif
Local Char ABFIC : ABFIC="APU"
Gosub INIMOD From GOBJSUB
Rewrite [APU]
Commit
End

# ----------------------------------------------------------------------------
# ORDTAB  : reordonne les onglets
Subprog ORDTAB(UTILIS,TORD,ERR)
Value Char UTILIS
Value Char TORD
Variable Integer ERR

If clalev([F:APU])=0 : Local File APORTUSER [APU] : Endif
Local Integer I,DEB,POS
Local Char CODT

ERR=0
Trbegin [APU]
Read [APU]APU0=UTILIS
If fstat<>0 : ERR=5 : End : Endif
# CODTAB NBTAB
DEB=1
For I=1 To [F:APU]NBTAB
  POS=instr(DEB,TORD,",")
  If POS<>0
    CODT=mid$(TORD,DEB,POS-DEB)
    DEB=POS+1
  Else
    CODT=right$(TORD,DEB)
  Endif
  [F:APU]CODTAB(I-1)=CODT
Next I

Local Char ABFIC : ABFIC="APU"
Gosub INIMOD From GOBJSUB
Rewrite [APU]
Commit
End


# ----------------------------------------------------------------------------
# CREMOD  : crée un module
Subprog CREMOD(UTILIS,CODTAB,CODMOD,MORD,IDLOC,VIGNETTE,ERR)
Value Char UTILIS
Value Char CODTAB
Variable Char CODMOD
Value Char MORD
Value Char IDLOC
Value Char VIGNETTE
Variable Integer ERR
ERR=0
If clalev([F:APA])=0 : Local File APORTTAB  [APA] : Endif
If clalev([F:AMO])=0 : Local File APORTMOD  [AMO] : Endif
If clalev([F:AVP])=0 : Local File APORTVIG  [AVP] : Endif
If clalev([F:ATP])=0 : Local File APORTTYP  [ATP] : Endif
Local Integer I,POS,DEB
Local Char CODMT

#  Modif dans la table des onglets
Read [APA]APA0=UTILIS;CODTAB
If fstat<>0 : ERR=6 : End : Endif

Read [AVP]AVP0=VIGNETTE
If fstat<>0 : ERR=7 : End : Endif

Read [ATP]ATP0=[F:AVP]CODFA
If fstat<>0 : ERR=9 : End : Endif

#                                  On décode MORD et on remplace IDLOC par sa nouvelle valeur
Raz [F:APA]CODMOD
Raz [F:APA]COLNUM
CODMOD=CODTAB+"M"+num$([F:APA]LASTMOD+1)
[F:APA]LASTMOD+=1
[F:APA]NBMOD+=1
DEB=1
For I=1 To [F:APA]NBMOD
  POS=instr(DEB,MORD,",")
  If POS<>0
    CODMT=mid$(MORD,DEB,POS-DEB)
    DEB=POS+1
  Else
    CODMT=right$(MORD,DEB)
  Endif
  POS=instr(1,CODMT,":")
  [F:APA]COLNUM(I-1)=val(right$(CODMT,POS+1))
  CODMT=left$(CODMT,POS-1)
  If CODMT=IDLOC : CODMT=CODMOD : Endif
  [F:APA]CODMOD(I-1)=CODMT
Next I



Trbegin [APA],[AMO]
Local Char ABFIC : ABFIC="APA"
Gosub INIMOD From GOBJSUB
Rewrite [APA]

#  Création dans la table des modules à partir de la description vignette
[F:AMO]CODUSR=UTILIS
[F:AMO]CODTAB=CODTAB
[F:AMO]CODMOD=CODMOD
#Call TEXTE([F:AVP]INTIT,[F:AMO]TITELT) From OBJDIV
Call LECTEXTRA([F:AMO]TITELT,"APORTVIG","INTIT1",VIGNETTE,"") From ATEXTRA
[F:AMO]ICONE=[F:AVP]ICONE
[F:AMO]EXPEND=2
[F:AMO]VIGNETTE=VIGNETTE
[F:AMO]MODTYP=[F:ATP]MODTYP
Raz [F:AMO]NAMPAR,[F:AMO]VALPAR,[F:AMO]INTPART
For I=0 To [F:ATP]NBPAR-1
 # [F:AMO]CODPAR(I)=CODMOD+"P"+num$(I+1)
  If [F:AVP]MODVAL(I)=2
    [F:AMO]INTPART(I)=[F:ATP]PROPI(I)
  Endif
  [F:AMO]NAMPAR(I)=[F:ATP]PROPN(I)
  If tolower([F:AMO]MODTYP)="webnote" and [F:AMO]NAMPAR(I)="Text"
     If [F:AVP]PROPVAL(I)="Entrez votre texte ici  ..." and mess(21,7837,1)<>""
       [F:AMO]TEXTCL=mess(21,7837,1)
     Else
       [F:AMO]TEXTCL=[F:AVP]PROPVAL(I)
     Endif
  Elsif [F:AVP]CODFA="PROC" and [F:AMO]NAMPAR(I)="IDATA"
    [F:AMO]VALPAR(I)=[F:AVP]PROPVAL(I)+";"+[F:AVP]PROPVAL(I+1)
  Else
    [F:AMO]VALPAR(I)=[F:AVP]PROPVAL(I)
  Endif
Next I
Local Char ABFIC : ABFIC="AMO"
Gosub INICRE From GOBJSUB
Write [AMO]
Commit

End

# ---------------------------------------------------------------------------
# MODMOD  : Modifie un module
Subprog MODMOD(UTILIS,CODTAB,CODMOD,PARAMID,PARAMVAL,CLBP,ERR)
Value Char UTILIS
Value Char CODTAB
Variable Char CODMOD
Value Char PARAMID()(1..)
Value Char PARAMVAL()(1..)
Value Clbfile CLBP
Variable Integer ERR

If clalev([F:AMO])=0 : Local File APORTMOD  [AMO] : Endif
Local Integer I,J
Local Char CODMT

Read [AMO]AMO0=UTILIS;CODTAB;CODMOD
If fstat<>0 : ERR=6 : End : Endif
For I=3 To dim(PARAMID)
  If PARAMID(I)="" : Break 1 : Endif
  If left$(PARAMID(I),1)<>"$"
    J=find(PARAMID(I),[F:AMO]NAMPAR(0..9))
  Else
    J=find(right$(PARAMID(I),2),[F:AMO]NAMPAR(0..9))
  Endif
  If J=0
    If PARAMID(I)="title" : [F:AMO]TITELT=PARAMVAL(I) : Endif
    If PARAMID(I)="ico"   : [F:AMO]ICONE=PARAMVAL(I)  : Endif
    If PARAMID(I)="exp"
      [F:AMO]EXPEND=2
      If PARAMVAL(I)="false" : [F:AMO]EXPEND=1 : Endif
    Endif
    If PARAMID(I)="showBorder"   : [F:AMO]SHBORDM=PARAMVAL(I)  : Endif
    If PARAMID(I)="showHeader"   : [F:AMO]SHHEADM=PARAMVAL(I)  : Endif
  Else
    If [F:AMO]NAMPAR(J-1)="Text"
      [F:AMO]TEXTCL=CLBP
    Else
      [F:AMO]VALPAR(J-1)=PARAMVAL(I)
    Endif
  Endif
Next I

Trbegin [AMO]
Local Char ABFIC : ABFIC="AMO"
Gosub INIMOD From GOBJSUB
Rewrite [AMO]
Commit

End

# ---------------------------------------------------------------------------
Subprog READCLB(MYCLOB)
Value Clbfile MYCLOB
Local Char TTCLOB(200)(1..10000),NOMFIC(250)
Local Integer I
Setlob TTCLOB With MYCLOB
Call NAMEFIC(nomap,"TMP","",GUSER+".xml",NOMFIC) From INTRUTILA
Openo NOMFIC,0 Using [XML_]
Iomode adxifs "" Using [XML_]
Iomode adxirs "" Using [XML_]
Iomode adxium GUTF8 Using [XML_]

For I=1 To dim(TTCLOB)
  If TTCLOB(I)="" : Break 1 : Endif
  Wrseq TTCLOB(I) Using [XML_]
Next I
Openo Using [XML_]

  Local Char URL(200),RETOUR(200)
  URL=GVIRTDIR+"/"+nomap+"/"+"TMP"+"/"+GUSER+".xml"
  URL=ctrans(URL,"\","/")
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL ,
&                           "UIAdxPubSubFile="+ chr$(1) + "1"

End

# --------------------------------------------------------------------------------------------------

Subprog READPORT(BID,CLBP)
Value Char BID
Variable Clbfile CLBP()
Global Integer NOLOCKP
Call CREPORT(GUSER,CLBP,"ALL")
Kill NOLOCKP
End

# -------------------------------------------------------------------------

Subprog INIVIGNAV(CODVIG,CODFAM,MENRAT,RANG)
Value Char CODVIG
Value Char CODFAM
Value Char MENRAT
Value Integer RANG

If clalev([F:AVP])=0  : Local File APORTVIG  [AVP]  : Endif
If clalev([F:ATP])=0  : Local File APORTTYP  [ATP]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA  [AXX] : Endif

Read [AVP]AVP0=CODVIG
If fstat=0 : End : Endif
Read [ATP]ATP0=CODFAM
If fstat<>0 : End : Endif
Trbegin [AVP]
[F:AVP]CODVI=CODVIG
#[F:AVP]INTIT=[F:ATP]INTITF
Local Char LIBF1(50)
Call TEXTE([F:ATP]INTITF,LIBF1) From OBJDIV
Call MAJTEXTRA(LIBF1,"APORTVIG","INTIT1",CODVIG,"") From ATEXTRA
#Call MAJTEXTRA([F:AVP]INTIT1,"APORTVIG","INTIT1",CODVIG,"") From ATEXTRA

[F:AVP]DESCR=[F:ATP]DESCR
[F:AVP]CODFA=CODFAM
[F:AVP]CODACT=""
[F:AVP]CODACC=""
[F:AVP]ICONE=[F:ATP]ICONE
[F:AVP]MENUR=MENRAT
[F:AVP]RANGR=RANG
[F:AVP]NBPAR=[F:ATP]NBPAR
For indice=0 To [F:ATP]NBPAR-1
  [F:AVP]MODVAL(indice)=[F:ATP]PROPMOD(indice)
  [F:AVP]PROPVAL(indice)=[F:ATP]PROPDEF(indice)
Next indice
Local Char ABFIC : ABFIC="AVP"
Gosub INICRE From GOBJSUB
Write [AVP]
Commit
End

# -------------------------------------------------------------------------

Subprog INIPO(UTILIS,USRINIT,AMAJP)
Value Char UTILIS
Variable Char USRINIT
Variable Integer AMAJP

If clalev([F:APU])=0  : Local File APORTUSER [APU]  : Endif
If clalev([F:AFT])=0  : Local File AFCTFCT [AFT]    : Endif
If clalev([F:AUS])=0  : Local File AUTILIS [AUS]  : Endif
If clalev([F:AME])=0  : Local File AMETUTI [AME]  : Endif

USRINIT=""
AMAJP=0
Local Char PFC,PFC1
Read [AUS]CODUSR=UTILIS
If fstat<>0 : End : Endif
PFC=[F:AUS]PRFFCT
If PFC=""
  If [F:AUS]CODMET="" : End : Endif
  Read [AME]AME0=[F:AUS]CODMET
  If fstat<>0 : End : Endif
  PFC=[F:AME]PRFFCT
  PFC1=[F:AUS]CODMET   :  # CC 31/07/2013
Endif


Read [AFT]AFT0=PFC
If fstat=0
  If PFC1<>"" : PFC=PFC1 : Endif  :  # CC 31/07/2013
  Read [APU]APU0="_"+PFC       
  If fstat=0 : USRINIT="_"+PFC : Endif
  If [F:AFT]FLGPOR=2 : AMAJP=1 : Endif
Endif

End

# -------------------------------------------------------------------------



$MODIFAUTH
If dim(NOLOCKP)>0 : Return : Endif
GMODPORTAUT=1
Local Char USRINIT
Local Integer AMAJP,ERR
If clalev([F:APU])=0  : Local File APORTUSER [APU]  : Endif
Call INIPO(UTILIS,USRINIT,AMAJP)

Read [APU]APU0=UTILIS
If fstat=0
  If USRINIT<>"" and AMAJP=1
    Call DUPTABS(USRINIT,UTILIS,1,ERR)
  Endif
Else
  If USRINIT<>""
    Call DUPTABS(USRINIT,UTILIS,1,ERR)
  Else
    Call INITABS(UTILIS)
  Endif
  If AMAJP=1 : GMODPORTAUT=0 : Return : Endif
  Return
Endif
If AMAJP=1 : GMODPORTAUT=0 : Return : Endif
Local Char SYMBPORT : SYMBPORT="PORT-"+UTILIS
Lock =SYMBPORT With lockwait=0
If fstat=1 : GMODPORTAUT=0 : Return : Endif
Return

$ERRP1
Resume


# ----------------------------------------------------------------------------------------------

Subprog CREPORT(UTILIS,CLBP,MODE)
Value Char UTILIS
Variable Clbfile CLBP()
Value Char MODE

#  MODE : "ALL"    on constitue le flux complet tabs + panel
#         "PANE"   on ne crée que le panel
#         "TABS"   on ne crée que les onglets

If dim(GMODPORTAUT)<0 : Global Integer GMODPORTAUT : Endif
If clalev([F:APU])=0 : Local File APORTUSER  [APU] : Endif

Gosub MODIFAUTH From ACREVIG
Local Char PVIS : PVIS="true"
If GMODPORTAUT=1 and dim(NOLOCKP)<0 and MODE<>"PANE" and [F:APU]LASTNUM>9000
  Local Integer ERR
  Local Char CLEDUP(5)
  CLEDUP=right$(num$(adxuid(2)),len(num$(adxuid(2)))-1)+num$(int(rnd(10)))+num$(int(rnd(10)))+num$(int(rnd(10)))
  Call DUPTABS(UTILIS,CLEDUP,1,ERR) From ACREVIG
  Call DUPTABS(CLEDUP,UTILIS,1,ERR) From ACREVIG
  Call SUPTABS(CLEDUP) From ACREVIG
Endif
Read [APU]APU0=UTILIS
If fstat<>0 or [F:APU]NBTAB=0
  Call INITABS(UTILIS) From ACREVIG
Else
  If [F:APU]MENUOPEN<>2 : PVIS="false" : Endif
Endif
Local Char CARF :  CARF=chr$(10)
Global Integer COUNTPROP,BASEPROP,MENOP
Global Char TMENOP(10)(1..100)

CLBP='<?xml version="1.0" encoding="UTF-8"?>'+CARF
If MODE<>"PANE"
 Append CLBP,'<application datatype="object" modifauth="'+num$(GMODPORTAUT)+'">'+CARF
 Append CLBP,'<properties>'+CARF
 Append CLBP,'<property name="shPanelCaption" datatype="string">'+mess(1,7837,1)+'</property>'+CARF
#Append CLBP,'<property name="inCaption" datatype="string">'+mess(2,7837,1)+'</property>'+CARF
#Append CLBP,'<property name="outCaption" datatype="string">'+mess(3,7837,1)+'</property>'+CARF
#    On ne veut pas le bouton connexion/déconnexion - on donne un intitulé vide
 Append CLBP,'<property name="inCaption" datatype="string">'+'</property>'+CARF
 Append CLBP,'<property name="outCaption" datatype="string">'+'</property>'+CARF
 Append CLBP,'<property name="ntCaption" datatype="string">'+mess(4,7837,1)+'</property>'+CARF
 Append CLBP,'<property name="delTabConfirm" datatype="string">'+mess(5,7837,1)+'</property>'+CARF
 Append CLBP,'<property name="loadCaption" datatype="string">'+mess(6,7837,1)+'</property>'+CARF
 Append CLBP,'<property name="c_title" datatype="string">'+mess(7,7837,1)+'</property>'+CARF
 Append CLBP,'<property name="c_columns" datatype="string">'+mess(8,7837,1)+'</property>'+CARF
 Append CLBP,'<property name="c_icon" datatype="string">'+mess(9,7837,1)+'</property>'+CARF
 Append CLBP,'<property name="c_save" datatype="string">'+mess(10,7837,1)+'</property>'+CARF
 If MODE="TABS"
  Append CLBP,'<property name="panelOnDemand" datatype="bool">'+PVIS+'</property>'+CARF
  PVIS="false"
 Endif
 Append CLBP,'<property name="panelVisible" datatype="bool">'+PVIS+'</property>'+CARF
 PVIS="true"
 Append CLBP,'<property name="supportTabMove" datatype="bool">'+PVIS+'</property>'+CARF
 Append CLBP,'<property name="supportModTabMove" datatype="bool">'+PVIS+'</property>'+CARF
 PVIS="false"
 Append CLBP,'<property name="canChangeTabIcon" datatype="bool">'+PVIS+'</property>'+CARF
 Append CLBP,'<property name="canChangeModuleIcon" datatype="bool">'+PVIS+'</property>'+CARF
 Append CLBP,'<property name="c_export" datatype="string">'+mess(11,7837,1)+'</property>'+CARF            : # Export ...
 Append CLBP,'<property name="c_maximize" datatype="string">'+mess(12,7837,1)+'</property>'+CARF          : # Agrandir
 Append CLBP,'<property name="c_minimize" datatype="string">'+mess(13,7837,1)+'</property>'+CARF          : # Restaurer
 Append CLBP,'<property name="c_rss_next" datatype="string">'+mess(14,7837,1)+'</property>'+CARF          : # Suivant
 Append CLBP,'<property name="c_rss_prev" datatype="string">'+mess(15,7837,1)+'</property>'+CARF          : # Précédent
 Append CLBP,'<property name="c_exportNetvibes" datatype="string">'+''+'</property>'+CARF           : # Add to Netvibes
 Append CLBP,'<property name="c_exportGoogle" datatype="string">'+''+'</property>'+CARF             : # Add to Google
 Append CLBP,'<property name="c_exportVistaGadget" datatype="string">'+''+'</property>'+CARF        : # Add to Desktop
 Append CLBP,'<property name="c_exportWindowsLive" datatype="string">'+''+'</property>'+CARF        : # Add to Windows Live
 Append CLBP,'<property name="c_ForceShowBorders" datatype="string">'+mess(24,7837,1)+'</property>'+CARF
 Append CLBP,'<property name="c_ShowSeparators" datatype="string">'+mess(25,7837,1)+'</property>'+CARF
 Append CLBP,'<property name="c_ShowBorder" datatype="string">'+mess(26,7837,1)+'</property>'+CARF
 Append CLBP,'<property name="c_ShowHeader" datatype="string">'+mess(27,7837,1)+'</property>'+CARF
 Append CLBP,'<property name="c_map" datatype="string">'+mess(28,7837,1)+'</property>'+CARF
 Gosub ADDPROPERT
 Append CLBP,'</properties>'+CARF
Endif
If MODE<>"PANE"
  Call TOXMLTABS(UTILIS,CLBP)
Endif

If MODE<>"TABS"
 Append CLBP,'<panel datatype="object">'+CARF
&                    +'<items datatype="array">'+CARF
&                    +'<properties>'+CARF
 Gosub ADDPROPERT
 Append CLBP,'</properties>'+CARF

 Global Integer NBM
 Global Char MENCOU,MENREF
 Call CREPANEL(UTILIS,CLBP,"","")
 Append CLBP,'</items>'+CARF+'</panel>'+CARF
 Kill NBM,MENCOU,MENREF
Endif

If MODE<>"PANE"
  Append CLBP,'</application>'+CARF
Endif

Kill COUNTPROP,BASEPROP,MENOP,TMENOP

End

$ADDPROPERT
COUNTPROP+=1
Append CLBP,'<property name="id" datatype="string">'+num$(COUNTPROP+BASEPROP)+'</property>'+CARF
Return

$CREPARAM
COUNTPROP+=1
Append CLBP,'<param datatype="object">'+CARF+'<properties>'+CARF+'<property name="name" datatype="string">'+TT(1)
Append CLBP,'</property>'+CARF+'<property name="value" datatype="string">'+TT(2)+'</property>'+CARF
&        +'<property name="title" datatype="string">'
Append CLBP,TT(3)+'</property>'+CARF+'<property name="paramtype" datatype="string">'+TT(4)+'</property>'+CARF
&       +'<property name="id" datatype="string">'+num$(COUNTPROP+BASEPROP)+'</property>'+CARF
&       +'</properties>'+CARF+'</param>'+CARF
Return


# ---------------------------------------------------------------------------------------------------

Subprog TOXMLTABS(UTILIS,CLBP)
Value Char UTILIS
Variable Clbfile CLBP

Local Integer I,J,K,COLNUMMOD
Local Char CODTAB,CODMOD,ACTTAB,AVIS,DESIGG(200)

Append CLBP,'<tabs datatype="array">'
If clalev([F:APU])=0  : Local File APORTUSER [APU]  : Endif
If clalev([F:APA])=0  : Local File APORTTAB  [APA]  : Endif
If clalev([F:AMO])=0  : Local File APORTMOD  [AMO]  : Endif
If clalev([F:AVP])=0  : Local File APORTVIG  [AVP]  : Endif
If clalev([F:ATP])=0  : Local File APORTTYP  [ATP]  : Endif
If clalev([F:ACC])=0  : Local File ACCES [ACC]      : Endif
If clalev([F:ACV])=0  : Local File ACTIV [ACV]      : Endif
If clalev([F:A_US])=0 : Local File AUTILIS [A_US]   : Endif
If clalev([F:APR])=0  : Local File APROCESSUS [APR] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA [AXX]    : Endif


Local Integer ISSELECT,ALLAC

Read [A_US]CODUSR=UTILIS
If fstat=0 : ALLAC=[F:A_US]ALLACS : Endif

Read [APU]APU0=UTILIS
If fstat<>0 : Goto FINTABS : Endif
ACTTAB=[F:APU]ACTIF
If [F:APU]NBTAB>=1 and !find(ACTTAB,[F:APU]CODTAB(0..[F:APU]NBTAB-1)) : ACTTAB=[F:APU]CODTAB(0) : Endif
#   Boucle sur création d'onglets
For I=0 To [F:APU]NBTAB-1
  CODTAB=[F:APU]CODTAB(I)
  Gosub TOXMPTAB
Next I

$FINTABS
Append CLBP,'</tabs>'

End

$SUITEVAL
Resume

$TOXMPTAB
Read [APA]APA0=UTILIS;CODTAB
If fstat<>0 : Return : Endif
DESIGG=[F:APA]TITELT
If left$(DESIGG,1)="="
  Onerrgo SUITEVAL
  DESIGG=evalue(right$(DESIGG,2))
  Onerrgo
Endif
Call MODVAL(DESIGG) From INTRUTILA
Append CLBP,'<tab datatype="object">'
&                    +'<properties>'
&                    +'<property name="title" datatype="string">'+DESIGG+'</property>'
&                    +'<property name="colcount" datatype="int">'+num$([F:APA]COLCOUNT)+'</property>'
If ACTTAB=CODTAB : AVIS='true' : Else : AVIS='false' : Endif
Append CLBP,'<property name="visible" datatype="bool">'+AVIS+'</property>'
#If GUSER="CCORA" & I=2
#  Append CLBP,'<property name="canModify" datatype="bool">'+"false"+'</property>'
#  Append CLBP,'<property name="canDelete" datatype="bool">'+"false"+'</property>'
#Endif
If [F:APA]ICONE<>""
  Append CLBP,'<property name="icone" datatype="string">'
  If left$([F:APA]ICONE,4)="http"
    Append CLBP,[F:APA]ICONE
  Else
    Local Integer PA1 : PA1=instr(1,[F:APA]ICONE,"\")
    If GBROWS=0
      Append CLBP,"http://"+GVIRTDIR+"/X3_ROOT/"+left$([F:APA]ICONE,PA1-1)+"/IMG/"+right$([F:APA]ICONE,PA1+1)
    Else
      Append CLBP,"../../"+left$([F:APA]ICONE,PA1-1)+"/IMG/"+right$([F:APA]ICONE,PA1+1)
    Endif
  Endif
  Append CLBP,'</property>'
Endif

Append CLBP,'<property name="id" datatype="string">'+CODTAB+'</property>'
If [F:APA]MAPT <> ""
    Append CLBP,'<property name="map" datatype="string">'+[F:APA]MAPT+'</property>'
Endif
If ([F:APA]FSHBORDT <> "" and [F:APA]FSHBORDT <> "false")
    Append CLBP,'<property name="forceShowBorders" datatype="string">'+[F:APA]FSHBORDT +'</property>'
Endif
If ([F:APA]SHSEPT <> "" and [F:APA]SHSEPT <> "false")
    Append CLBP,'<property name="showSeparators" datatype="string">'+[F:APA]SHSEPT +'</property>'
Endif
Append CLBP,'</properties>'
Append CLBP,'<modules datatype="array">'

#   Boucle sur création de modules
For J=0 To [F:APA]NBMOD-1
  CODMOD=[F:APA]CODMOD(J)
  COLNUMMOD=[F:APA]COLNUM(J)
  Gosub TOXMPMOD
Next J

Append CLBP,'</modules>'+'</tab>'
Return

# ----------------------------------------------------------------------------

$TOXMPMOD
Read [AMO]AMO0=UTILIS;CODTAB;CODMOD
If fstat<>0 : Return : Endif
Read [AVP]AVP0=[F:AMO]VIGNETTE
If fstat<>0 : Return : Endif
Read [ATP]ATP0=[F:AVP]CODFA
If fstat<>0 : Return : Endif

If ALLAC<>2
 If [F:AVP]CODACC<>""  : #  CC  29/12/2009  Bug 59433
   Read [ACC]CODACC = UTILIS;[F:AVP]CODACC
   If fstat<>0 or ([F:ACC]CONSUL<>2 and [F:ACC]EXEC<>2 and [F:ACC]MODIF<>2) : Return : Endif
 Endif
Endif
 If [F:AVP]CODFA="PROC"    :# On teste si le processus a un code d'accès
# On choisit à présent le processus en fonction du code legislation
#  Read [APR]APR0=[F:AVP]PROPVAL(2)
   Local Char LEGISL(10)
   Local Integer MONOLEG
   If dim(GLEGFIL)>0 : LEGISL = GLEGFIL : Endif
   If LEGISL=""
    MONOLEG = 0
    If clalev([F:ACV])>0
     Read [ACV]CODACT="LEG"
     If fstat or [F:ACV]FLACT<>2
      MONOLEG = 1
     Endif
    Endif
    If MONOLEG
     LEGISL = GDOSLEG(1)
    Endif
   Endif
   Read [APR]APR1=LEGISL;[F:AVP]PROPVAL(2)
   If fstat<>0
     Read [APR]APR1="";[F:AVP]PROPVAL(2)
   Endif
   If fstat=0 and [F:APR]CODACC<>""
     Read [ACC]CODACC = UTILIS;[F:APR]CODACC
     If fstat<>0 or ([F:ACC]CONSUL<>2 and [F:ACC]EXEC<>2 and [F:ACC]MODIF<>2) : Return : Endif
   Elsif fstat<>0
     Return
   Endif
 Endif


Append CLBP,'<module datatype="object">'+'<properties>'
Local Char AEXPEND : AEXPEND="true"
If [F:AMO]EXPEND<>2 : AEXPEND="false" : Endif
Append CLBP,'<property name="exp" datatype="bool">'+AEXPEND+'</property>'
&                    +'<property name="colnum" datatype="int">'+num$(COLNUMMOD)+'</property>'
#DESIGG=[F:AMO]TITELT
Call LECTEXTRALA(DESIGG,[F:AMO]TITELT,"APORTVIG","INTIT1",[F:AMO]VIGNETTE,"")
Call MODVAL(DESIGG) From INTRUTILA
Append CLBP,'<property name="title" datatype="string">'+DESIGG+'</property>'
&                    +'<property name="modtype" datatype="string">'+[F:AMO]MODTYP+'</property>'
If [F:AMO]ICONE<>""
  Append CLBP,'<property name="ico" datatype="string">'
  If left$([F:AMO]ICONE,4)="http"
    Append CLBP,[F:AMO]ICONE
  Else
    Local Integer PA1 : PA1=instr(1,[F:AMO]ICONE,"\")
    If GBROWS=0
      Append CLBP,"http://"+GVIRTDIR+"/X3_ROOT/"+left$([F:AMO]ICONE,PA1-1)+"/IMG/"+right$([F:AMO]ICONE,PA1+1)
    Else
      Append CLBP,"../../"+left$([F:AMO]ICONE,PA1-1)+"/IMG/"+right$([F:AMO]ICONE,PA1+1)
    Endif
  Endif
  Append CLBP,'</property>'
Endif

If ([F:AMO]SHBORDM<>"" and [F:AMO]SHBORDM<>"true")
    Append CLBP,'<property name="showBorder" datatype="bool">'+[F:AMO]SHBORDM+'</property>'
Endif
If ([F:AMO]SHHEADM<>"" and [F:AMO]SHHEADM<>"true")
    Append CLBP,'<property name="showHeader" datatype="bool">'+[F:AMO]SHHEADM+'</property>'
Endif

Append CLBP,'<property name="id" datatype="string">'+CODMOD+'</property>'
&                    +'</properties>'+'<params datatype="array">'

#   Boucle sur création de parametres
Local Char TYPPAR,INTPA(40)

For K=0 To dim([F:AMO]NAMPAR)-1
  If [F:AMO]NAMPAR(K)="" : Break 1 : Endif
  Case [F:ATP]PROPT(K)
     When 1       : TYPPAR="string"
     When 2       : TYPPAR="int"
     When 3       : TYPPAR="bool"
     When 4       : TYPPAR="number"
     When 5       : TYPPAR="date"
     When 6       : TYPPAR="text"
     When 7       : TYPPAR="enum"
     When Default : TYPPAR="string"
  Endcase
  Gosub TOXMPPAR
Next K

Append CLBP,'<properties>'
&                    +'<property name="id" datatype="string">'+CODMOD+"G1"+'</property>'
&                    +'</properties>'+'</params>'+'</module>'
Return

# ----------------------------------------------------------------------------
$TOXMPPAR
Append CLBP,'<param datatype="object">'+'<properties>'
&                    +'<property name="name" datatype="string">'+[F:AMO]NAMPAR(K)+'</property>'
If [F:AMO]MODTYP="webnote" and [F:AMO]NAMPAR(K)="Text"
  Append CLBP,'<property name="value" datatype="'+TYPPAR+'">'
  Local Char TTR(250)(1..100)
  Setlob TTR With [F:AMO]TEXTCL
  For indice=1 To 250
    If TTR(indice)="" : Break 1 : Endif
    Append CLBP,TTR(indice)
  Next indice
  Append CLBP,'</property>'
Else
  If [F:AMO]NAMPAR(K)="URI" and left$([F:AMO]VALPAR(K),1)="="
    Onerrgo ERRP1
    DESIGG=evalue(right$([F:AMO]VALPAR(K),2))
    Onerrgo
  Else
    DESIGG=[F:AMO]VALPAR(K)
  Endif
  If TYPPAR="string" : Call MODVAL(DESIGG) From INTRUTILA : Endif
  Append CLBP,'<property name="value" datatype="'+TYPPAR+'">'+DESIGG+'</property>'
Endif
If [F:AMO]INTPART(K)<>0
  Call TEXTE([F:AMO]INTPART(K),INTPA) From OBJDIV
Else
  INTPA=""
Endif
Append CLBP,'<property name="title" datatype="string">'+INTPA+'</property>'
&                    +'<property name="paramtype" datatype="string">'+TYPPAR+'</property>'
&                    +'<property name="id" datatype="string">'+CODMOD+'P'+num$(K)+'</property>'
&                    +'</properties>'+'</param>'
Return

# -------------------------------------------------------------------------

Subprog CREPANEL(UTILIS,CLBP,VIGNETTE,MENURAT)
Value Char UTILIS
Variable Clbfile CLBP
Value Char VIGNETTE,MENURAT
#
#  Boucle sur la création des "item" après les avoir triés en fonction de leur rang
#
#  For .... Gosub CREITEM   .... Next

Local Char CARF :  CARF=chr$(10)
Local File APORTVIG [AP_V]
Local File APORTTYP [AP_T]
If clalev([F:APR])=0 : Local File APROCESSUS [APR] : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
If clalev([F:A_US])=0 : Local File AUTILIS [A_US] : Endif
Local Char TT(250)(1..7)
Local Integer ISSELECT,ALLAC

Read [A_US]CODUSR=UTILIS
If fstat=0 : ALLAC=[F:A_US]ALLACS : Endif


If MENOP=0
  MENOP+=1 : TMENOP(MENOP)=MENURAT
Else
  If MENURAT=TMENOP(MENOP)
    MENOP+=1
  Else
    Append CLBP,'<properties>'+CARF
    Gosub ADDPROPERT
    Append CLBP,'</properties>'+CARF+'</items>'+CARF+'</item>'+CARF
  Endif
  TMENOP(MENOP)=VIGNETTE
Endif
Filter [AP_V]
Filter [AP_V] Where MENUR=VIGNETTE
For [AP_V]AVP1
  Gosub CONTACC
  If ISSELECT=0
    Gosub CREITEM
    If [F:AP_V]CODFA="MENU"
      NBM+=1
      Call CREPANEL(UTILIS,CLBP,[F:AP_V]CODVI,[F:AP_V]MENUR)
    Endif
  Endif
Next
Filter [AP_V]

If VIGNETTE<>""
  Append CLBP,'<properties>'+CARF
  Gosub ADDPROPERT
  Append CLBP,'</properties>'+CARF+'</items>'+CARF+'</item>'+CARF
  MENOP-=1
Endif
End

$CONTACC
ISSELECT=0
If ALLAC<>2
 If [F:AP_V]CODACC<>""  : #  CC  29/12/2009  Bug 59433
   Read [ACC]CODACC = UTILIS;[F:AP_V]CODACC
   If fstat<>0 or ([F:ACC]CONSUL<>2 and [F:ACC]EXEC<>2 and [F:ACC]MODIF<>2) :  ISSELECT=1 : Return : Endif
 Endif
 If [F:AP_V]CODACT<>""
   Read [ACV]CODACT = [F:AP_V]CODACT
   If fstat<>0 or [F:ACV]FLACT<>2 : ISSELECT=1 : Return : Endif
 Endif

 If [F:AP_V]CODFA="PROC"    :# On teste si le processus a un code d'accès
# On choisit à présent le processus en fonction du code legislation
#  Read [APR]APR0=[F:AP_V]PROPVAL(2)
   Local Char LEGISL(10)
   Local Integer MONOLEG
   If dim(GLEGFIL)>0 : LEGISL = GLEGFIL : Endif
   If LEGISL=""
    MONOLEG = 0
    If clalev([F:ACV])>0
     Read [ACV]CODACT="LEG"
     If fstat or [F:ACV]FLACT<>2
      MONOLEG = 1
     Endif
    Endif
    If MONOLEG
     LEGISL = GDOSLEG(1)
    Endif
   Endif
   Read [APR]APR1=LEGISL;[F:AP_V]PROPVAL(2)
   If fstat<>0
     Read [APR]APR1="";[F:AP_V]PROPVAL(2)
   Endif
   If fstat=0 and [F:APR]CODACC<>""
     Read [ACC]CODACC = UTILIS;[F:APR]CODACC
     If fstat<>0 or ([F:ACC]CONSUL<>2 and [F:ACC]EXEC<>2 and [F:ACC]MODIF<>2) : ISSELECT=1 : Return : Endif
   Elsif fstat<>0
      ISSELECT=1
   Endif
 Endif
Endif
Return

$CREITEM
#  Call TEXTE([F:AP_V]INTIT,TT(1)) From OBJDIV
  Call LECTEXTRA(TT(1),"APORTVIG","INTIT1",[F:AP_V]CODVI,"") From ATEXTRA
  Call MODVAL(TT(1)) From INTRUTILA
  Read [AP_T]ATP0=[AP_V]CODFA
  If fstat=0
    TT(2)=[F:AP_T]MODTYP
  Endif
  TT(3)="true" : TT(4)="true" : TT(5)="false"
  TT(6)=""
  If left$([F:AP_V]ICONE,5)="http:"
    TT(6)=[F:AP_V]ICONE
  Elsif vireblc([F:AP_V]ICONE,2)<>""
    Local Integer PA1 : PA1=instr(1,[F:AP_V]ICONE,"\")
    If PA1<>0
      If GBROWS=0
        TT(6)="http://"+GVIRTDIR+"/X3_ROOT/"+left$([F:AP_V]ICONE,PA1-1)+"/IMG/"+right$([F:AP_V]ICONE,PA1+1)
      Else
        TT(6)="../../"+left$([F:AP_V]ICONE,PA1-1)+"/IMG/"+right$([F:AP_V]ICONE,PA1+1)
      Endif
    Endif
  Endif
  TT(7)="false"
  Case [F:AP_T]TYPVIG
   When 1 :                     #  Vignette
   When 2 : TT(2)="" : TT(3)="false" : TT(4)="false" : TT(5)=[F:AP_V]PROPVAL(0)     : # Menu
            If TT(5)<>"true" and TT(5)<>"false" : TT(5)="true" : Endif
   When 3 : TT(3)="false" : TT(7)="true" : TT(1)=[F:AP_V]PROPVAL(0) : Call MODVAL(TT(1)) From INTRUTILA   : # Séparateur
  Endcase

Append CLBP,'<item datatype="object">'+CARF
&                     +'<properties>'+CARF
&                     +'<property name="title" datatype="string">'+TT(1)+'</property>'+CARF
Append CLBP,'<property name="modtype" datatype="string">'+TT(2)+'</property>'+CARF
&        +'<property name="candrag" datatype="bool">'+TT(3)+'</property>'+CARF
&        +'<property name="leaf" datatype="bool">'+TT(4)+'</property>'+CARF
&        +'<property name="expanded" datatype="bool">'+TT(5)+'</property>'+CARF
If TT(6)<>""
  Append CLBP,'<property name="ico" datatype="string">'+TT(6)+'</property>'+CARF
Endif
Append CLBP,'<property name="sep" datatype="bool">'+TT(7)+'</property>'+CARF
&        +'<property name="id" datatype="string">'+[F:AP_V]CODVI+'</property>'+CARF
&        +'</properties>'+CARF
&        +'<params datatype="array">'+CARF
&        +'<properties>'+CARF
Gosub ADDPROPERT
Append CLBP,'</properties>'+CARF

#
#    Boucle sur la création des paramètres
#

If [F:AP_T]TYPVIG=1
Local Integer NBP
 For NBP=0 To [F:AP_V]NBPAR-1
   TT(1)=[F:AP_T]PROPN(NBP)
   TT(2)=[F:AP_V]PROPVAL(NBP)
   If TT(1)="URI"
     If left$(TT(2),1)="="
       Onerrgo ERRP1
       TT(2)=evalue(right$(TT(2),2))
       Onerrgo
     Endif
     Call MODVAL(TT(2)) From INTRUTILA
   Endif
   If [F:AP_V]CODFA="WNOTE" and [F:AP_T]PROPN(NBP)="Text" and [F:AP_V]PROPVAL(NBP)="Entrez votre texte ici  ..." and mess(21,7837,1)<>""
     TT(2)=mess(21,7837,1)  : # Entrez votre texte ici  ...     traduit
   Endif
   If [F:AP_V]CODFA="PROC" and [F:AP_T]PROPN(NBP)="IDATA" and instr(1,[F:AP_V]PROPVAL(NBP),";")=0
     TT(2)=[F:AP_V]PROPVAL(NBP)+";"+[F:AP_V]PROPVAL(NBP+1)
   Endif
   If [F:AP_V]MODVAL(NBP)=2
     Call TEXTE([F:AP_T]PROPI(NBP),TT(3)) From OBJDIV
     Call MODVAL(TT(3)) From INTRUTILA
   Else
     TT(3)=""
   Endif
   Case [F:AP_T]PROPT(NBP)
     When 1       : TT(4)="string"
     When 2       : TT(4)="int"
     When 3       : TT(4)="bool"
     When 4       : TT(4)="number"
     When 5       : TT(4)="date"
     When 6       : TT(4)="text"
     When 7       : TT(4)="enum"
     When Default : TT(4)="string"
   Endcase
   Gosub CREPARAM
 Next NBP
Endif
Append CLBP,'</params>'+CARF


If [F:AP_T]TYPVIG=3
  Append CLBP,'<items datatype="array">'+CARF+'<properties>'+CARF
  Gosub ADDPROPERT
  Append CLBP,'</properties>'+CARF+'</items>'+CARF
Endif
If [F:AP_T]TYPVIG=2
  Append CLBP,'<items datatype="array">'+CARF
Else
  Append CLBP,'</item>'+CARF
Endif


Return

Subprog LECTEXTRALA(VALTRA,VALREF,ATABLE,ACHAMP,ACLE1,ACLE2)
Variable Char    VALTRA()
Value    Char    VALREF, ATABLE, ACHAMP, ACLE1, ACLE2
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
Local Char TEXTT(80)
Local Integer TROUV
Filter [AXX] Where CODFIC=ATABLE & ZONE=ACHAMP & IDENT1=ACLE1 & IDENT2=ACLE2
For [AXX]
  If [F:AXX]TEXTE=VALREF : TROUV=1 : Endif
  If [F:AXX]LANGUE=GLANGUE : TEXTT=[F:AXX]TEXTE : Endif
Next
Filter [AXX]
VALTRA=VALREF
If TROUV=1 and TEXTT<>"" : VALTRA=TEXTT : Endif
End
