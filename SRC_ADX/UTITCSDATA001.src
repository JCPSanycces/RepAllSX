#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITCSDATA001   Positionnement du flag audit SDATA sur       Module TC #
#                 TABUNIT et ITMCATEG                                    #
##########################################################################
# FGR 25/05/2012 : X3SUIVI82410
##########################################################################
Local Char DOSSIER(30)

  If 1=1 Then
    DOSSIER = nomap
    Call SAIDOS(DOSSIER, "") From SAIDOS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      Read [ADS]DOSSIER=[L]DOSSIER
      If fstat Then
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITCSDATA001(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "SLXTEST" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTITCSDATA001(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITCSDATA001(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Char STABLE(GLONATB)

  IERR = 0
  Call ECR_TRACE("UTITCSDATA001: Process Start on : "+SZAPPLI, 0) From GESECRAN
  #
  Local File =SZAPPLI+".ATABLE" [DATS]
  Local File ADOSACT [ADAS]
  # ----------
  Read [ADAS]ADA0=[F:ADS]DOSSIER;"GCRM"
  If !fstat Then
    # FGR 24/05/2012 : X3SUIVI 82410 : Ajout de TABUNIT et ITMCATEG
    For STABLE = "TABUNIT", "ITMCATEG"
      Read [DATS]CODFIC=STABLE
      Trbegin [DATS]
      If [F:ADAS]FLACT = G_YES and [F:DATS]AUDSDA = G_NO Then
        # Si GCRM actif et flag SDATA non coché : on coche
        [F:DATS]AUDSDA = G_YES
        [F:DATS]UPDFLG = G_NO
        IUPDATE = G_OUI
      Elsif [F:ADAS]FLACT = G_NO and [F:DATS]AUDSDA = G_YES Then
        # Si GCRM inactif et flag SDATA coché : on décoche
        [F:DATS]AUDSDA = G_NO
        [F:DATS]UPDFLG = G_NO
        IUPDATE = G_NO
      Else
        IUPDATE = G_NO
      Endif
      Rewrite [F:DATS]
      Commit
      Call SD_TRIGGER(SZAPPLI, STABLE) From ASDUTITR1
      If IUPDATE = G_OUI Then
        Local File =SZAPPLI+"."+STABLE [AAA]
        Trbegin [AAA]
        Update [AAA] With [F:AAA]CREUSR = [F:AAA]CREUSR
        Commit
        Close Local File [AAA]
      Endif
    Next
  Endif
  # ----------
  Close Local File [DATS]
  Close Local File [ADAS]
  #
  Call ECR_TRACE("UTITCSDATA001 : tables processed", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTITCSDATA001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  # Ne rien faire dans ce cas, c'est fait par validation de dossier
End
