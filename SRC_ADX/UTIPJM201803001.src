#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201803001
# Issue X3-66474 - 2018-02-22 by SINGC
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201803001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201803001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR
Local Integer NI

  Call ECR_TRACE("UTIPJM201803001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".PJMTIMEMP" [PTE]
  Local File =DOSSIER + ".OPPORPJM"  [OPPPJM]
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [PTE]
  Filter [PTE] Where [F:PTE]DIE(0) = ""
  For [PTE]
    Read [OPPPJM]OPPPJM0=[F:PTE]OPPNUM
    For NI = 0 To dim([F:OPPPJM]DIE)-1
      If [F:OPPPJM]DIE(NI) <> AVOID.ACHAR Then
        [F:PTE]DIE(NI) = [F:OPPPJM]DIE(NI)
        [F:PTE]CCE(NI) = [F:OPPPJM]CCE(NI)
      Else
        Break
      Endif
    Next NI
    Rewrite [PTE]
    COMPTEUR += 1
    If fstat Then
      Call ECR_TRACE("File PJMTIMEMP" - [F:PTE]CLB + "~" + [F:PTE]OPPNUM + "~" + [F:PTE]PTEDAT + "~" + [F:PTE]PTESEQ + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Next
  Filter [PTE]
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201803001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201803001 : records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTIMEMP","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTIMEMP") : End : Endif
  If filinfo(filpath("FIL","OPPORPJM","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "OPPORPJM") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201803001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTIMEMP","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTIMEMP") : End : Endif
  If filinfo(filpath("FIL","OPPORPJM","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "OPPORPJM") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201803001(APPLI)
End

