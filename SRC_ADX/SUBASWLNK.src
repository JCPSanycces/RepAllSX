#<AdxTL>@(#)0.0.0.0 $Revision$
Call AGENASWLNK

End

Subprog AGENASWLNK
Local Char VALEUR(10), PARAM(10)(1.1)
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBASWLNK","",3,"") From GTRAITE
End

#####################
$ACTION
Case ACTION
 When "EXEC"      : Gosub EXEC
 When "TERMINE"   : Gosub TERMINE
Endcase
Return

#####################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(mess(206,143,1)-[M]AFOLDER) From LECFIC : # Synchronisation des liens
Endif

Call TRTMAJ_FILTER_ASWLNK([M]AFOLDER,[M]VALIDDIFF,[M]DEBASW,[M]FINASW) From SUBASW_TOOL

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return


###############
$TERMINE
TRA = 1
Return

#################################################################################################
Subprog AS_AFOLDER(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = nomap
Endif
Call AM_SELREP([M]SELREP)
Setmok [M] With 0
End

Subprog AM_SELREP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [M]DEBASW
 Actzo [M]FINASW
Else
 Effzo [M]DEBASW
 Effzo [M]FINASW
 Grizo [M]DEBASW
 Grizo [M]FINASW
Endif
End

Subprog AS_FINASW(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]DEBASW<>"" : VALEUR = [M]DEBASW : Endif
End

Subprog C_FINASW(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]DEBASW
 GMESSAGE = mess(83,123,1) : # valeur incorrecte
 mkstat = 2
Endif
End

#################################################################################################
$_TRTMAJ_ALL_ASWLNK
Local Integer ERR,SAVGVALID,INTERRUPT,COUNT,N
Local Char CRITERE(250)

#Validation différée (à la volée)
[L]SAVGVALID=GVALIDDIFF
If [L]PVALDIF=2
  GVALIDDIFF=3
Else
  GVALIDDIFF=1
Endif

If GTRACE<>""
 Call ECR_TIME(mess(206,143,1)-"-"-mess(3,23,1)-[L]DOSSIER) From DOSSUB
Endif

Local File =[L]DOSSIER+".ASHW" [ASWZ]

DEBDEB = DEBASW
FINFIN = FINASW
If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif

Raz [L]CRITERE
If [L]DEBASW<>""
 [L]CRITERE = 'CODREP>="'+[L]DEBASW+'"'
Endif
If [L]FINASW<>""
 If [L]CRITERE<>"" : [L]CRITERE -= '&' : Endif
 [L]CRITERE -= 'CODREP<="'+[L]FINASW+'"'
Endif
If CRITERE<>""
 Filter [ASWZ] Where evalue([L]CRITERE)
Endif
COUNT=rowcount([F:ASWZ])

If !GSERVEUR
 Call OUVRE_BOITE(mess(206,143,1),COUNT) From GESECRAN
Endif
If GADONIX=2
    Call ECR_TIME("rowcount([F:ASWZ])"-num$(COUNT)) From DOSSUB
Endif
N=0
Gosub OPEN_FILE  From ASHWVALLEC
For [ASWZ]
  If !GSERVEUR
   Call AFF_BOITE(mess(23,140,1)-[F:ASWZ]CODREP,N,INTERRUPT) From GESECRAN
  Endif
  If GTRACE<>"" & ([L]DEBASW<>"" | [L]FINASW<>"")
    Call ECR_TRACE(mess(23,140,1)-[F:ASWZ]CODREP,0) From GESECRAN
  Endif
    If GADONIX=2
        Call ECR_TIME("Call _TRTMAJ_ASWLNK(0,1,"+[L]DOSSIER+","+[F:ASWZ]CODREP+")") From DOSSUB
    Endif
  Call _TRTMAJ_ASWLNK(0,1,[L]DOSSIER,[F:ASWZ]CODREP,ERR)
    If GADONIX=2
        Call ECR_TIME("_TRTMAJ_ASWLNK finished") From DOSSUB
    Endif
  N+=1
Next

Filter [ASWZ]
If !GSERVEUR
 Call FERME_BOITE From GESECRAN
Endif

GVALIDDIFF=[L]SAVGVALID

Return

#----------------------------------------------------------#
Subprog _TRTMAJ_ASWLNK(TEST,SILENCE,DOSSIER,CODREP,ERR)
Value Integer TEST,SILENCE
Value Char    DOSSIER
Value Char    CODREP
Variable    Integer  ERR

Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Local Integer OK, ISASWLOCK : [L]ISASWLOCK=1

If TEST : Call ECR_TRACE("-"-mess(23,140,1)-[L]CODREP,0) From GESECRAN : Endif

If [L]DOSSIER=nomap
 Lock ="ASW"+[L]CODREP With lockwait=0
Else
 Lock ="ASW"+[L]CODREP From =[L]DOSSIER With lockwait=0
Endif
If fstat
 [L]ISASWLOCK=0
 If GTRACE<>""
  Call ECR_TRACE([L]CODREP-mess(10,100,1)-":"-mess(258,143,1),-1) From GESECRAN
 Endif
 Goto FIN_TRTMAJ_ASWLNK
Else
 [L]ISASWLOCK=1
Endif

Read [ASW]ASW0=[L]CODREP
If fstat
 If GTRACE<>"" : Call ECR_TRACE([L]CODREP-mess(15,140,1),1) From GESECRAN : Endif
 Goto FIN_TRTMAJ_ASWLNK
Endif

If filinfo(filpath("ECR","ASHW5","msk",DOSSIER),7)<=0
  If dim(GACTX.LAN)>0 & GACTX.LAN<>""
  Call VALIDDIRECT ("ASHW5",DOSSIER,1,GACTX.LAN,1,OK) From VALMSK
  Elsif dim(GLANGUE)>0 & GLANGUE<>""
  Call VALIDDIRECT ("ASHW5",DOSSIER,1,GLANGUE,1,OK) From VALMSK
  Else
  Call VALIDDIRECT ("ASHW5",DOSSIER,1,"FRA",1,OK) From VALMSK
  Endif
Endif
If filinfo(filpath("ECR","ASHW6","msk",DOSSIER),7)<=0
  If dim(GACTX.LAN)>0 & GACTX.LAN<>""
  Call VALIDDIRECT ("ASHW6",DOSSIER,1,GACTX.LAN,1,OK) From VALMSK
  Elsif dim(GLANGUE)>0 & GLANGUE<>""
  Call VALIDDIRECT ("ASHW6",DOSSIER,1,GLANGUE,1,OK) From VALMSK
  Else
  Call VALIDDIRECT ("ASHW6",DOSSIER,1,"FRA",1,OK) From VALMSK
  Endif
Endif

Local Mask =[L]DOSSIER+".ASHW5" [ASW5]
Local Mask =[L]DOSSIER+".ASHW6" [ASW6]
Local Integer I,MAJLNK,MAJPAR,EXISTINVLNK

#Raz [M:ASW5]
#Raz [M:ASW6]

Gosub _CHARGE_ASWLNK

Call _LOAD_STDLNK_ASW6(TEST,1,[L]DOSSIER,[L]CODREP,2) From SUBASWLNK

Gosub _MAJ_ASWLNK

Close Local Mask

$FIN_TRTMAJ_ASWLNK
If [L]DOSSIER=nomap
 Unlock ="ASW"+[L]CODREP With lockwait=0
Else
 Unlock ="ASW"+[L]CODREP From =[L]DOSSIER With lockwait=0
Endif
#104343/2
#Gosub CLOSE_FILE From ASHWVALLEC
If TEST : Call ECR_TRACE("              ERR  :"-num$([L]ERR),0) From GESECRAN : Endif
nolign=SAVNOLIGN
End


#------------------------------------------------
$_CHARGE_ASWLNK
For [ASWK]ASWK0 Where CODREP=[L]CODREP
  I=[M:ASW6]NBRLNK
  [M:ASW6]NBRLNK+=1
  nolign = [M:ASW6]NBRLNK
  [M:ASW6] = [ASWK]
  [M:ASW6]STDNEW(I)=1
  [M:ASW6]METLNK(I) = [F:ASWK]CODMETLNK+[F:ASWK]CODOPELNK
  [M:ASW6]IDENT2(I) = func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW6]AFFLNK(I),[M:ASW6]ANCLNK(I),[M:ASW6]CODLNK(I))
  If [M:ASW6]FLGSTDLNK(I)=2
    [M:ASW6]STDNEW(I)=0
  Else
    [M:ASW6]STDNEW(I)=1
  Endif
  For [ASWP]ASWP0 Where CODREP=[L]CODREP & TYPPAR=3 & CODFLD=[F:ASWK]ANCLNK & CODLNK=[F:ASWK]CODLNK & AFFLNK=[F:ASWK]AFFLNK
    I=[M:ASW5]NBRPAR
    [M:ASW5]NBRPAR+=1
    nolign = [M:ASW5]NBRPAR
    [M:ASW5] = [ASWP]
    [M:ASW5]TYPINTPAR(I)=[F:ASWP]TYPINT
    [M:ASW5]STDNEW(I)=0
    [M:ASW5]IDENT2(I)=func SUBASW_TOOL.BUILD_ASW5_IDENT2([M:ASW5]TYPPAR(I),[M:ASW5]AFFLNK(I),[M:ASW5]TYPKEY(I),[M:ASW5]CODLNK(I),[M:ASW5]CODFLD(I),[M:ASW5]CODPAR(I))
  Next
Next
#on doit charger les param des champs de la rep
For [ASWP]ASWP0 Where CODREP=[L]CODREP & TYPPAR=1
  I=[M:ASW5]NBRPAR
  [M:ASW5]NBRPAR+=1
  nolign = [M:ASW5]NBRPAR
  [M:ASW5] = [ASWP]
  [M:ASW5]TYPINTPAR(I)=[F:ASWP]TYPINT
  [M:ASW5]STDNEW(I)=1
  [M:ASW5]IDENT2(I)=func SUBASW_TOOL.BUILD_ASW5_IDENT2([M:ASW5]TYPPAR(I),[M:ASW5]AFFLNK(I),[M:ASW5]TYPKEY(I),[M:ASW5]CODLNK(I),[M:ASW5]CODFLD(I),[M:ASW5]CODPAR(I))
Next
Return
#------------------------------------------------
$_MAJ_ASWLNK
Local Char ERRMES(250)(1..)
Local Integer ERRFLG (1..)
Call VERIF_PARAM_ASW5(0,[L]CODREP,0,1,ERRMES,ERRFLG) From SUBASW_TOOL


MAJLNK=find(2,[M:ASW6]STDNEW(0..[M:ASW6]NBRLNK-1))+find(0,[M:ASW6]STDNEW(0..[M:ASW6]NBRLNK-1))
If TEST : Call ECR_TRACE("              MAJLNK  :"-num$([L]MAJLNK),0) From GESECRAN : Endif
ERR=0
Onerrgo ERR_MAJ_ASWLNK
Trbegin [ASWK],[ASWP]
For I=0 To [M:ASW6]NBRLNK-1
  If [M:ASW6]FLGSTDLNK(I)=2 & [M:ASW6]STDNEW(I)=0
   # remove the link
   If [L]ISASWLOCK=1
    If TEST : Call ECR_TRACE(" - Remove link"-num$([M:ASW6]AFFLNK(I))+"~"+[M:ASW6]ANCLNK(I)+"~"+[M:ASW6]CODLNK(I),0) From GESECRAN : Endif
    Delete [ASWK] Where CODREP=[L]CODREP & AFFLNK=[M:ASW6]AFFLNK(I) & ANCLNK=[M:ASW6]ANCLNK(I) & CODLNK=[M:ASW6]CODLNK(I)
#    Dela I,1 [M:ASW6]NBRLNK
#    [M:ASW6]NBRLNK -=1
#    I-=1
   Else
    [L]ISASWLOCK=-1
   Endif
  Elsif [M:ASW6]FLGSTDLNK(I)=2 & [M:ASW6]STDNEW(I)=2
   If [M:ASW6]INVLNK(I)=2 : EXISTINVLNK=1 : Endif
   If [L]ISASWLOCK=1
    # update the link
    If TEST : Call ECR_TRACE(" - Update link"-num$([M:ASW6]AFFLNK(I))+"~"+[M:ASW6]ANCLNK(I)+"~"+[M:ASW6]CODLNK(I),0) From GESECRAN : Endif
    Delete [ASWK] Where CODREP=[L]CODREP & AFFLNK=[M:ASW6]AFFLNK(I) & ANCLNK=[M:ASW6]ANCLNK(I) & CODLNK=[M:ASW6]CODLNK(I)
    nolign=I+1
    Raz [F:ASWK]
    [F:ASWK]=[M:ASW6]
    [F:ASWK]CODREP    = [L]CODREP
    [F:ASWK]NUMLNK    = nolign
    Case [F:ASWK]TYPLNK
      When 2 : [F:ASWK]CODMETLNK = [M:ASW6]METLNK(I)  : # Méthode
      When 3 : [F:ASWK]CODOPELNK = [M:ASW6]METLNK(I)  : # Opération
    Endcase
    [F:ASWK]ORDTECLNK=func SUBASW_TOOL.BUILD_ASWK_ORDTECLNK
    Write [F:ASWK]
    If fstat
     If GTRACE<>""
     Call ERREUR("ASHWLNK"-[F:ASWK]CODREP-[M:ASW6]IDENT2(I),1) From DOSDIC
     Endif
      ERR=1 : Break
    Endif
   Else
    [L]ISASWLOCK=-1
   Endif
  Elsif [M:ASW6]FLGSTDLNK(I)<>2
   If [M:ASW6]INVLNK(I)=2 : EXISTINVLNK=1 : Endif
   # load all link parameters/keys
   Call LOAD_PARLNK_ASW5(1,[L]DOSSIER,[L]CODREP,[F:ASW]CODCLA,[M:ASW6]CMPLNK(I),[M:ASW6]AFFLNK(I),[M:ASW6]ANCLNK(I),[M:ASW6]CODLNK(I), [M:ASW6]TYPLNK(I),
&         [M:ASW6]CLALNK(I), [M:ASW6]REPLNK(I), [M:ASW6]CLAPTRLNK(I), [M:ASW6]METLNK(I)+[M:ASW6]RPTCOD(I),
&         [M:ASW6]CODFNCLNK(I)) From SUBASW_TOOL
  Else
   If [M:ASW6]INVLNK(I)=2 : EXISTINVLNK=1 : Endif
  Endif
Next I
If TEST : Call ECR_TRACE("              EXISTINVLNK  :"-num$([L]EXISTINVLNK),0) From GESECRAN : Endif

MAJPAR=find(2,[M:ASW5]STDNEW(0..[M:ASW5]NBRPAR-1))+find(0,[M:ASW5]STDNEW(0..[M:ASW5]NBRPAR-1))
If TEST : Call ECR_TRACE("              MAJPAR  :"-num$([L]MAJPAR),0) From GESECRAN : Endif
If MAJPAR & !ERR
  For I=0 To [M:ASW5]NBRPAR-1
    If [M:ASW5]TYPPAR(I)=3 & [M:ASW5]STDNEW(I)=0
     If [L]ISASWLOCK=1
      If TEST : Call ECR_TRACE("  - Remove ASWP 3"+"~"+num$([M:ASW5]TYPKEY(I))+"~"+[M:ASW5]CODFLD(I)+"~"+[M:ASW5]CODLNK(I)+"~"+num$([M:ASW5]AFFLNK(I))+"~"+[M:ASW5]CODPAR(I),0) From GESECRAN : Endif
      Delete [ASWP] Where CODREP=[L]CODREP & TYPPAR=3 & TYPKEY=[M:ASW5]TYPKEY(I) & AFFLNK=[M:ASW5]AFFLNK(I) & CODFLD=[M:ASW5]CODFLD(I) & CODLNK=[M:ASW5]CODLNK(I) & CODPAR=[M:ASW5]CODPAR(I)
  #    Dela I,1 [M:ASW5]NBRPAR
  #    [M:ASW5]NBRPAR -= 1
  #    I-=1
     Else
      [L]ISASWLOCK=-1
     Endif
    Elsif [M:ASW5]TYPPAR(I)=3 & [M:ASW5]STDNEW(I)=2
     If [L]ISASWLOCK=1
      If TEST : Call ECR_TRACE("  - Update ASWP 3"+"~"+num$([M:ASW5]TYPKEY(I))+"~"+[M:ASW5]CODFLD(I)+"~"+[M:ASW5]CODLNK(I)+"~"+num$([M:ASW5]AFFLNK(I))+"~"+[M:ASW5]CODPAR(I),0) From GESECRAN : Endif
      Delete [ASWP] Where CODREP=[L]CODREP & TYPPAR=3 & TYPKEY=[M:ASW5]TYPKEY(I) & AFFLNK=[M:ASW5]AFFLNK(I) & CODFLD=[M:ASW5]CODFLD(I) & CODLNK=[M:ASW5]CODLNK(I) & CODPAR=[M:ASW5]CODPAR(I)
      nolign=I+1
      [F:ASWP]=[M:ASW5]
      [F:ASWP]CODREP = [L]CODREP
      [F:ASWP]TYPINT = [M:ASW5]TYPINTPAR(I)
      Write [F:ASWP]
      If fstat
        If GTRACE<>"" : Call ERREUR("ASHWPAR"-[F:ASWP]CODREP-[M:ASW5]IDENT2(I),1) From DOSDIC
        Endif
        ERR=1 : Break
      Endif
     Else
      [L]ISASWLOCK=-1
     Endif
    Endif
  Next I
Endif

If ERR | [L]ISASWLOCK<>1
Rollback
Else
Commit
Endif

If !ERR & (MAJPAR | MAJLNK) & [L]ISASWLOCK=-1
  If GTRACE<>""
   Call ECR_TRACE([L]CODREP-mess(10,100,1)-":"-mess(258,143,1),-1) From GESECRAN
  Endif
Elsif !ERR & (MAJPAR | MAJLNK)
  If GTRACE<>""
    Call ECR_TRACE("-"-mess(23,140,1)-[L]CODREP,0) From GESECRAN
  Endif
  If MAJLNK
    Call ECR_TRACE(mess(207,143,1),0) From GESECRAN
  Endif
  If MAJPAR
    Call ECR_TRACE(mess(208,143,1),0) From GESECRAN
  Endif
  If EXISTINVLNK
   Call ECR_TRACE(func AFNC.MES1(mess(225,143,1),[L]CODREP)-":"-mess(259,143,1),-1) From GESECRAN
  Endif
  Gosub DOSS_CODREP_VALIDATION From SUBASW
  If nomap=[L]DOSSIER : Call TRACE_COR("ASW", [L]CODREP,"","m") From GOBJET :  Endif : # X3PLAT-2115
Elsif EXISTINVLNK
   Call ECR_TRACE(func AFNC.MES1(mess(225,143,1),[L]CODREP)-":"-mess(259,143,1),-1) From GESECRAN
Endif

Onerrgo

Return

#----------------------------------
$ERR_MAJ_ASWLNK
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
ERR=1
Resume

#----------------------------------------------------------#
Subprog MAJ_STDLNK_ASW6(TEST,SILENCE,DOSSIER,CODREP,TYPCHG)
Value Integer TEST,SILENCE
Value Char    DOSSIER
Value Char    CODREP
Value Integer TYPCHG : #-1 ENACOM -2 PROP/ALL

If !SILENCE
Call TEMPON(mess(201,143,1)-[L]CODREP) From GESECRAN
Endif

Local Integer I,NOLASW6

If [L]TYPCHG<>1
 For I=0 To [M:ASW5]NBRPAR-1
  If [M:ASW5]TYPPAR(I)=3
    [M:ASW5]STDNEW(I)=1
    NOLASW6=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW5]AFFLNK(I),[M:ASW5]CODFLD(I),[M:ASW5]CODLNK(I)),[M:ASW6]IDENT2(0..[M:ASW6]NBRLNK-1))
    If NOLASW6>0 & ([M:ASW6]FLGSTDLNK(NOLASW6-1)=2 | [M:ASW6]REPLNK(NOLASW6-1)=[L]CODREP)
      [M:ASW5]STDNEW(I)=0
    Endif
  Endif
 Next I
Endif

For I=0 To [M:ASW6]NBRLNK-1
  [M:ASW6]STDNEW(I)=1
  If [M:ASW6]FLGSTDLNK(I)=2 & ([L]TYPCHG<>1 | find([M:ASW6]AFFLNK(I),4,5))
    [M:ASW6]STDNEW(I)=0
  Endif
Next I

Gosub OPEN_FILE  From ASHWVALLEC
Call _LOAD_STDLNK_ASW6(TEST,1,[L]DOSSIER,[L]CODREP,[L]TYPCHG) From SUBASWLNK


For I=0 To [M:ASW6]NBRLNK-1
  If [M:ASW6]FLGSTDLNK(I)=2 & [M:ASW6]STDNEW(I)=0
    # remove the parameters/keys
    If [L]TYPCHG=1
    Call REMOVE_PARAM_ASW5([M:ASW6]AFFLNK(I),[M:ASW6]ANCLNK(I),[M:ASW6]CODLNK(I),3) From SUBASW_TOOL
    Endif
    Dela I,1 [M:ASW6]NBRLNK
    [M:ASW6]NBRLNK -=1
    I-=1
    [M:ASW0]MODIFLNK=2
  Elsif [L]TYPCHG<>1 & [M:ASW6]FLGSTDLNK(I)<>2 & [M:ASW6]REPLNK(I)=[L]CODREP
   # load all link parameters/keys
   Call LOAD_PARLNK_ASW5(1,[L]DOSSIER,[M:ASW0]CODREP,[M:ASW1]CODCLA,[M:ASW6]CMPLNK(I),[M:ASW6]AFFLNK(I),[M:ASW6]ANCLNK(I),[M:ASW6]CODLNK(I), [M:ASW6]TYPLNK(I),
&         [M:ASW6]CLALNK(I), [M:ASW6]REPLNK(I), [M:ASW6]CLAPTRLNK(I), [M:ASW6]METLNK(I)+[M:ASW6]RPTCOD(I),
&         [M:ASW6]CODFNCLNK(I)) From SUBASW_TOOL
  Endif
Next I

If [L]TYPCHG<>1
  For I=0 To [M:ASW5]NBRPAR-1
    If [M:ASW5]TYPPAR(I)=3 & [M:ASW5]STDNEW(I)=0
      Dela I,1 [M:ASW5]NBRPAR
      [M:ASW5]NBRPAR -= 1
      I-=1
      [M:ASW0]MODIFPAR=2
    Endif
  Next I
Endif

Effzo [M:ASW7]10 : #paramètres
Effzo [M:ASW7]15 : #clés
Gosub AFFZO_ASW5 From SUBASW
Call DISPLAY_LNK_ASW7(1,[M:ASW7]TYPANCLNK, [M:ASW7]CODANCLNK, [M:ASW7]OPTSTDLNK,[M:ASW7]OPTINVLNK) From SUBASW_TOOL
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif
End
#----------------------------------------------------------#
Subprog _LOAD_STDLNK_ASW6(TEST,SILENCE,DOSSIER,CODREP,TYPCHG)
Value Integer TEST,SILENCE
Value Char    DOSSIER
Value Char    CODREP
Value Integer TYPCHG : #-1 ENACOM -2 PROP

Local Integer SAVNOLIGN : SAVNOLIGN=nolign

If !SILENCE
Call TEMPON(mess(202,143,1)-[L]CODREP) From GESECRAN
Endif

Local  Instance  AERR(1..) Using C_AERROR
Local Instance ASWACTIONS(1..) Using C_ASWACTION
Local  Instance  ASHW Using C_ASW
Local Integer AFAC

ASHW  = NewInstance C_ASW AllocGroup null
If clalev([M:ASW0])>0 & clalev([M:ASW1])>0 & [M:ASW0]CODREP=[L]CODREP
  SetInstance ASHW With [M:ASW1]
  ASHW.CODREP = [L]CODREP
  ASHW.CODECLA =  ASHW.CODREP
  ASHW.INTITREP = [M:ASW0]AZINTREP
  For AFAC=1 To 5
     ASHW.ASWFAC(AFAC) = NewInstance C_ASWFAC AllocGroup ASHW
     ASHW.ASWFAC(AFAC).CODFAC = AFAC
     ASHW.ASWFAC(AFAC).ENAFAC = [M:ASW1]ENAFAC(AFAC-1)
     ASHW.ASWFAC(AFAC).DEFLNKFAC = [M:ASW8]DEFLNKFAC(AFAC-1)
     ASHW.ASWFAC(AFAC).AFFLNKFAC = [M:ASW8]AFFLNKFAC(AFAC-1)
     ASHW.ASWFAC(AFAC).LNKMENFAC = [M:ASW8]LNKMENFAC(AFAC-1)
     ASHW.ASWFAC(AFAC).ACTLNKFAC = [M:ASW8]ACTLNKFAC(AFAC-1)
     Call DEFLNKFAC(AFAC,ASHW,ASHW.ASWFAC(AFAC)) From SUBASW
  Next
Else
  Read [ASW]ASW0=[L]CODREP
  If fstat : Goto FIN_LOAD_STDLNK_ASW6 : Endif
  SetInstance ASHW With [F:ASW]
  ASHW.INTITREP = func ASYRFNC.TEXTE([F:ASW]INTREP)
  For AFAC=1 To 5
     ASHW.ASWFAC(AFAC) = NewInstance C_ASWFAC AllocGroup ASHW
     ASHW.ASWFAC(AFAC).CODFAC = AFAC
     ASHW.ASWFAC(AFAC).ENAFAC = [F:ASW]ENAFAC(AFAC-1)
     ASHW.ASWFAC(AFAC).DEFLNKFAC = [F:ASW]DEFLNKFAC(AFAC-1)
     ASHW.ASWFAC(AFAC).AFFLNKFAC = [F:ASW]AFFLNKFAC(AFAC-1)
     ASHW.ASWFAC(AFAC).LNKMENFAC = [F:ASW]LNKMENFAC(AFAC-1)
     ASHW.ASWFAC(AFAC).ACTLNKFAC = [F:ASW]ACTLNKFAC(AFAC-1)
     Call DEFLNKFAC(AFAC,ASHW,ASHW.ASWFAC(AFAC)) From SUBASW
  Next
Endif
ASHW.ACLA  = NewInstance C_ACLA AllocGroup ASHW
Read [ACLA]ACLA0=ASHW.CODCLA
SetInstance ASHW.ACLA With [F:ACLA]
Call CHARGE_ACLE(ASHW.CODCLA,ASHW.ACLA,AERR) From ACLAVALLEC
If maxtab(AERR)>0  : Goto FIN_LOAD_STDLNK_ASW6 : Endif

Call LOAD_ACTIONS(ASWACTIONS) From SUBASW_TOOL

#On gère des liens std pour
# 1. Propriété
# 4. Page
# 5. Fiche

# 1. Propriété
If [L]TYPCHG<>1
  Local Integer LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM : #facette of the link
  If clalev([M:ASW0])>0 & clalev([M:ASW4])>0 & [M:ASW0]CODREP=[L]CODREP
    Local Integer OLDNOLASW4,NOLASW4,NOLASW4BIS,OKCODPRO
    For NOLASW4=0 To [M:ASW4]NBRPRO-1
     Raz LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM
     OKCODPRO=1
     If NOLASW4>0
      If find([M:ASW4]CODPRO(NOLASW4),[M:ASW4]CODPRO(0..NOLASW4-1))
       OKCODPRO=0
      Endif
     Endif
     If OKCODPRO
      OLDNOLASW4=NOLASW4
      NOLASW4BIS=find([M:ASW4]CODPRO(NOLASW4), [M:ASW4]CODPRO(OLDNOLASW4..[M:ASW4]NBRPRO-1))
      While NOLASW4BIS>0
        NOLASW4BIS=NOLASW4BIS+OLDNOLASW4

        LK_DET=max(LK_DET,[M:ASW4]DETPRO(NOLASW4BIS-1))
        LK_QRY=max(LK_QRY,[M:ASW4]QRYPRO(NOLASW4BIS-1))
        LK_EDI=max(LK_EDI,[M:ASW4]EDIPRO(NOLASW4BIS-1))
        LK_LOK=max(LK_LOK,[M:ASW4]LOKPRO(NOLASW4BIS-1))
        LK_SUM=max(LK_SUM,[M:ASW4]SUMPRO(NOLASW4BIS-1))

        ### CCL : OK si unicité des CODPRO
        If [M:ASW4]STADETPRO(NOLASW4BIS-1)=3  : LK_DET = 1 : Endif
        If [M:ASW4]STAQRYPRO(NOLASW4BIS-1)=3  : LK_QRY = 1 : Endif
        If [M:ASW4]STALOKPRO(NOLASW4BIS-1)=3   : LK_LOK = 1 : Endif
        If [M:ASW4]STASUMPRO(NOLASW4BIS-1)=3  : LK_SUM = 1 : Endif
        If [M:ASW4]STAEDIPRO(NOLASW4BIS-1)=3   : LK_EDI = 1   : Endif
        ###


        OLDNOLASW4=NOLASW4BIS
        NOLASW4BIS=find([M:ASW4]CODPRO(NOLASW4), [M:ASW4]CODPRO(OLDNOLASW4..[M:ASW4]NBRPRO-1))
      Wend
      If LK_DET=2 | LK_QRY=2 | LK_EDI=2 | LK_LOK=2 | LK_SUM=2
      Call _LOAD_1_STDLNK_ASW6(TEST,DOSSIER,[L]CODREP,ASHW,1, [M:ASW4]CODPRO(NOLASW4),
&           LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,
&           [M:ASW4]CODPRONBCLA(NOLASW4), [M:ASW4]CODPROCLA(NOLASW4), [M:ASW4]CODPROISACTX(NOLASW4), [M:ASW4]CODPROOBJ(NOLASW4),
&           ASWACTIONS,AERR)
      Endif
     Endif
    Next NOLASW4
  Else
    Local Char TABCLA(80)(1..50),TABPTR(80)(1..50),PRO(50),CLA(80),WCODPRO(GLONAVC)
    Local Integer NBCLA,ISACTX
    For [ASWR]ASWR3(2) Where CODREP=[L]CODREP
     WCODPRO=[F:ASWR]CODPRO
     Call DECODE_PRO(WCODPRO,0,"PRO",[L]DOSSIER,[F:ASWR]CODREP,[F:ASW]ABRCLA,[F:ASW]CODCLA,TABPTR,TABCLA,PRO,ISACTX,NBCLA) From SUBASW
     If NBCLA>0
       CLA=TABCLA(NBCLA)
     Else
       CLA=""
     Endif
     Raz LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM
     For [ASWR]ASWR3
      LK_DET=max(LK_DET,[F:ASWR]DETPRO)
      LK_QRY=max(LK_QRY,[F:ASWR]QRYPRO)
      LK_EDI=max(LK_EDI,[F:ASWR]EDIPRO)
      LK_LOK=max(LK_LOK,[F:ASWR]LOKPRO)
      LK_SUM=max(LK_SUM,[F:ASWR]SUMPRO)
      ### CCL : OK si unicité des CODPRO
      If [F:ASWR]STADETPRO=3  : LK_DET = 1 : Endif
      If [F:ASWR]STAQRYPRO=3  : LK_QRY = 1 : Endif
      If [F:ASWR]STALOKPRO=3   : LK_LOK = 1 : Endif
      If [F:ASWR]STASUMPRO=3  : LK_SUM = 1 : Endif
      If [F:ASWR]STAEDIPRO=3   : LK_EDI = 1   : Endif
      ###
     Next
     If LK_DET=2 | LK_QRY=2 | LK_EDI=2 | LK_LOK=2 | LK_SUM=2
     Call _LOAD_1_STDLNK_ASW6(TEST,DOSSIER,[L]CODREP,ASHW,1, WCODPRO,
&          LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,
&          NBCLA,CLA, ISACTX, PRO,
&          ASWACTIONS,AERR)
     Endif
    Next
  Endif
Endif

# 4. Page
Call _LOAD_1_STDLNK_ASW6(TEST,DOSSIER,[L]CODREP,ASHW,4, "",
&     ASHW.ENAFAC(1),ASHW.ENAFAC(3),ASHW.ENAFAC(2),ASHW.ENAFAC(4),ASHW.ENAFAC(5),
&     0, "", 0, "",
&     ASWACTIONS,AERR)

# 5. Fiche
Call _LOAD_1_STDLNK_ASW6(TEST,DOSSIER,[L]CODREP,ASHW,5, "",
&     ASHW.ENAFAC(1),ASHW.ENAFAC(3),ASHW.ENAFAC(2),ASHW.ENAFAC(4),ASHW.ENAFAC(5),
&     0, "", 0, "",
&     ASWACTIONS,AERR)

$FIN_LOAD_STDLNK_ASW6
#Gosub CLOSE_FILE From ASHWVALLEC
FreeInstance [ACLA]
If ASWACTIONS<>null
 FreeGroup ASWACTIONS
Endif
If AERR<>null
 FreeGroup AERR
Endif
If ASHW<>null
 FreeGroup ASHW
Endif
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif
nolign=SAVNOLIGN
End
#----------------------------------------------------------#
Subprog _LOAD_1_STDLNK_ASW6(TEST,DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC, LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM, NBCLA, CODCLA, ISACTX, CODOBJ,ASWACTIONS,AERR)
Value Integer TEST
Value Char    DOSSIER
Value Char    CODREP
Variable Instance  ASHW Using C_ASW
Value Integer LNK_AFF
Value Char    LNK_ANC
Value Integer LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM : #facette of the link
Value Integer NBCLA
Value Char    CODCLA
Value Integer ISACTX
Value Char    CODOBJ
Variable Instance ASWACTIONS(1..) Using C_ASWACTION
Variable Instance  AERR(1..) Using C_AERROR

Local Instance ACLAF Using C_ACLAFLD
Local Integer CMPLNK,NOLASW6
Local Char CODLNK(GLONAVA)

#On gère des liens std pour
# 1. Propriété
# 4. Page
# 5. Fiche
Case LNK_AFF
When 1
  Gosub STDLNK_PRO
When 4
  Gosub STDLNK_PAG
When 5
  Gosub STDLNK_FIC
When Default
Endcase

End

#--------------------------------#
$STDLNK_PAG

# Add link STD
 If ASHW.ENAFAC(3)=2 : #Query
  [L]CMPLNK=5 : #  Lister
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMLNK
  Endif
 Endif

 If ASHW.FONCTION<>"" : #Convergence PAGE/Liens sur fonction dans tous les cas
  Read [AFC]CODINT=ASHW.FONCTION
  If !fstat & [F:AFC]ACTION="GOBJET"
   If [F:AFC]VALPAR(0)<>""
    Read [AOB]ABREV=evalue([F:AFC]VALPAR(0))
    If !fstat
     If [AOB]TYPGES=2 : # Pour gestion des tableaus , pas de lien en create
      [L]CMPLNK=3 : #Modifier sur fonction
      Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,1,LK_QRY,1,1,1,ACLAF,[L]CODLNK,[L]NOLASW6)
      If [L]CODLNK<>""
      # load all link parameters/keys
      Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&      [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&      [M:ASW6]CODFNCLNK([L]NOLASW6)) From SUBASW_TOOL
      Gosub MAJ_PARAMLNK
      Endif
     Else
      [L]CMPLNK=1 : #Créer
      Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,1,LK_QRY,1,1,1,ACLAF,[L]CODLNK,[L]NOLASW6)
      If [L]CODLNK<>""
       # load all link parameters/keys
       Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&      [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&      [M:ASW6]CODFNCLNK([L]NOLASW6)) From SUBASW_TOOL
       Gosub MAJ_PARAMLNK
      Endif
     Endif
    Endif
   Endif
  Else
   [L]CMPLNK=1 : #Créer
   Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,1,LK_QRY,1,1,1,ACLAF,[L]CODLNK,[L]NOLASW6)
   If [L]CODLNK<>""
    # load all link parameters/keys
    Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&  [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&  [M:ASW6]CODFNCLNK([L]NOLASW6)) From SUBASW_TOOL
    Gosub MAJ_PARAMLNK
   Endif
  Endif
 Elsif ASHW.FONCTION="" & ASHW.ENACOM(1)=2 & ASHW.ENAFAC(2)=2: # CMP Création+Edit
  [L]CMPLNK=1 : #Créer
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     [M:ASW6]CODFNCLNK([L]NOLASW6)) From SUBASW_TOOL
  Gosub MAJ_PARAMLNK
  Endif
 Endif

 If ASHW.ENACOM(4)=2 : # Impression PDF
  [L]CMPLNK=12 : # Lister en PDF
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
#  If [L]CODLNK<>""
#  # load all link parameters/keys
#  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
#&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
#&     "") From SUBASW_TOOL
#  Gosub MAJ_PARAMLNK
#  Endif
 Endif
 If ASHW.ENACOM(5)=2 : # Reporting Excel
  [L]CMPLNK=8 : # Lister dans Excel
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
#  If [L]CODLNK<>""
#  # load all link parameters/keys
#  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
#&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
#&     "") From SUBASW_TOOL
#  Gosub MAJ_PARAMLNK
#  Endif
 Endif
 If ASHW.ENACOM(6)=2 : # Reporting Word
  [L]CMPLNK=14: # Lister dans Word
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
#  If [L]CODLNK<>""
#  # load all link parameters/keys
#  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
#&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
#&     "") From SUBASW_TOOL
#  Gosub MAJ_PARAMLNK
#  Endif
 Endif
 If ASHW.ENACOM(7)=2 : # Word Mail Merge
  [L]CMPLNK=16 : # Publiposter liste
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
#  If [L]CODLNK<>""
#  # load all link parameters/keys
#  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
#&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
#&     "") From SUBASW_TOOL
#  Gosub MAJ_PARAMLNK
#  Endif
 Endif

 If ASHW.ENAFAC(2)=2 & (ASHW.ENACOM(1)=2 | ASHW.ENACOM(2)=2) : #CMP Création ou Modification
  [L]CMPLNK=17 : # Enregistrer
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)

  [L]CMPLNK=18 : # Abandon
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
 Endif
 #115007
 If ASHW.TYPMSKREP=1
  [L]CMPLNK=22 : # Aide
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
 Endif
Return
#--------------------------------#
$STDLNK_FIC

# Add link STD
 If ASHW.ENAFAC(1)=2 : #Detail
  [L]CMPLNK=2 : #  Details
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMLNK
  Endif
 Endif

 If ASHW.ENACOM(1)=2 & ASHW.ENAFAC(2)=2 : #Création+Edit
  #Gosub NEW_LNK : # Duplication
 Endif
 If ASHW.FONCTION<>"" : #Convergence Modifier dans tous les cas
  [L]CMPLNK=3 : #Modifier
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     [M:ASW6]CODFNCLNK([L]NOLASW6)) From SUBASW_TOOL
  Gosub MAJ_PARAMLNK
  Endif
 Elsif ASHW.FONCTION="" & ASHW.ENACOM(2)=2 & ASHW.ENAFAC(2)=2 : #Modification+Edit
  [L]CMPLNK=3 : #Modifier
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     [M:ASW6]CODFNCLNK([L]NOLASW6)) From SUBASW_TOOL
  Gosub MAJ_PARAMLNK
  Endif
 Endif
 If ASHW.ENACOM(3)=2 : #Suppression
  [L]CMPLNK=4 : # suppression
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMLNK
  Endif
 Endif
 If ASHW.ENACOM(4)=2 : # Impression PDF
  [L]CMPLNK=11 : # Afficher en PDF
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMLNK
  Endif
 Endif
 If ASHW.ENACOM(5)=2 : # Reporting Excel
  [L]CMPLNK=7 : # Afficher dans Excel
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMLNK
  Endif
 Endif
 If ASHW.ENACOM(6)=2 : # Reporting Word
  [L]CMPLNK=13 : # Afficher dans Word
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMLNK
  Endif
 Endif
 If ASHW.ENACOM(7)=2 : # Word Mail Merge
  [L]CMPLNK=15 : # Publiposter fiche
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMLNK
  Endif
 Endif
Return

#---------------------------------------------------------------------------------------------------#
# Add parameters of links of action and
#---------------------------------------------------------------------------------------------------#

$MAJ_PARAMLNK

#If find(ASHW.ACLA.TYPCLA,2,5)=0 : Return : Endif

Local Integer NOL,I,MAJ
For NOL=0 To [M:ASW5]NBRPAR-1
 If [M:ASW5]AFFLNK(NOL)=[L]LNK_AFF & [M:ASW5]CODFLD(NOL)=[L]LNK_ANC & [M:ASW5]CODLNK(NOL)=[L]CODLNK
   For I=1 To ASHW.ACLA.NBCLEREF
    MAJ=0
    If [M:ASW5]TYPKEY(NOL)=2 & [M:ASW5]CODPAR(NOL)=ASHW.ACLA.ACLAI(I).CLEREF
      If [M:ASW5]STDNEW(NOL)=2 | [M:ASW5]INTVAL(NOL)=[M:ASW5]VALEUR(NOL)
        MAJ=1
      Endif
      Read [ACLAF]ACLAF0 = ASHW.CODCLA;ASHW.ACLA.ACLAI(I).CLEREF
      If !fstat & [F:ACLAF]FLDGRP<>""
        [M:ASW5]INTVAL(NOL)=ASHW.ABRCLA+"."+[F:ACLAF]FLDGRP+"."+ASHW.ACLA.ACLAI(I).CLEREF
      Else
        [M:ASW5]INTVAL(NOL)=ASHW.ABRCLA+"."+ASHW.ACLA.ACLAI(I).CLEREF
      Endif
      If MAJ & [M:ASW5]INTVAL(NOL)<>[M:ASW5]VALEUR(NOL)
        [M:ASW5]STDNEW(NOL)=2
        [M:ASW5]VALEUR(NOL)= [M:ASW5]INTVAL(NOL)
      Endif
    Endif
  Next I
 Endif
Next NOL

Return
#--------------------------------#
$STDLNK_PRO
Gosub RECH_ACLAF
If maxtab(AERR)>0 | ACLAF=null | ACLAF.ATY=null : Goto FIN_STDLNK_PRO : Endif
Case ASHW.TYPMSKREP
  When 1
  DEFREP=ACLAF.ATY.DEFREPDES
  When 2
  DEFREP=ACLAF.ATY.DEFREPMOB
  When 3
  DEFREP=ACLAF.ATY.DEFREPTAB
  When Default : Goto FIN_STDLNK_PRO
Endcase
#TODO il faudra regarder si on a des liens à recupérer du type de données
If find(ACLAF.ATY.TYPTYP,9,10) #liens sur LOB
 [L]DEFREP=[L]CODREP
Else
 If ACLAF.ATY.CODCLA="" : Goto FIN_STDLNK_PRO : Endif
Endif
#
If [L]DEFREP="" : Goto FIN_STDLNK_PRO : Endif
If [L]DEFREP=[L]CODREP
  If clalev([M:ASW0])>0 & clalev([M:ASW1])>0 & [M:ASW0]CODREP=[L]CODREP
    Raz [F:ASW2]
    [F:ASW2]=[M:ASW0]
    [F:ASW2]=[M:ASW1]
  Else
    Raz [F:ASW2]
    [F:ASW2]=[F:ASW]
  Endif
Else
  Read [ASW2]ASW0=[L]DEFREP
  If fstat : Goto FIN_STDLNK_PRO : Endif
Endif

Gosub ADD_LINKS_STD
$FIN_STDLNK_PRO
If ACLAF<>null
 FreeGroup ACLAF
Endif
Return

$RECH_ACLAF
Local Integer J,K,TYPCLA
Local Char CLAPRO(60), DEFREP (60)
K=1
If NBCLA>0
 If [L]CODCLA=""
  If !ISACTX
   If clalev([M:ASW0])>0 & clalev([M:ASW9])>0 & [M:ASW0]CODREP=[L]CODREP
     J=find([L]CODOBJ,[M:ASW9]CODFLD(0..[M:ASW9]NBRFLD-1))
     If J>0
       ACLAF = NewInstance C_ACLAFLD AllocGroup null
       #ne marche pas
       #nolign=J
       #SetInstance ACLAF With [M:ASW9]
       ACLAF.FLDCLA = [M:ASW9]CODFLD(J-1)
       ACLAF.FLDGRP = [M:ASW9]FLDGRP(J-1)
       ACLAF.PTHGRP = [M:ASW9]FLDGRP(J-1)
       CLAPRO = "R_"+[L]CODREP
       ACLAF.ACTFLD=[M:ASW9]ACTFLD(J-1)
       ACLAF.CODTYP=[M:ASW9]CODTYP(J-1)
       ACLAF.INTSHTFLD=[M:ASW9]INTSHTFLD(J-1)
       ACLAF.INTFLD=[M:ASW9]INTFLD(J-1)
       ACLAF.INTITFLD=[M:ASW9]AZINTFLD(J-1)
       ACLAF.LONG=[M:ASW9]LONG(J-1)
       ACLAF.NOLIB=[M:ASW9]NOLIB(J-1)
       ACLAF.OBLIG=[M:ASW9]OBLIG(J-1)
       Call CHARGE_FLD(AERR,ACLAF,[M:ASW9]CODTYP(J-1),K,"",[M:ASW9]NOLIB(J-1),[M:ASW9]LONG(J-1),TEST) From ACLAVALLEC
       Call CHARGE_PARFLD(AERR,ACLAF,[L]CODREP,1)
       TYPCLA = 1
  #     Gosub ADD_PTRASW From ASHWVALLEC
  #     Gosub ALIAS_PARFLD From ASHWVALLEC
     Endif
   Else
    Read [ASWF]ASWF0=[L]CODREP;[L]CODOBJ
    If !fstat
       ACLAF = NewInstance C_ACLAFLD AllocGroup null
       SetInstance ACLAF With [F:ASWF]
       ACLAF.FLDCLA = [F:ASWF]CODFLD
       ACLAF.FLDGRP = [F:ASWF]FLDGRP
       ACLAF.PTHGRP = [F:ASWF]FLDGRP
       CLAPRO = "R_"+[L]CODREP
       ACLAF.INTITFLD=func ASYRFNC.TEXTE([F:ASWF]INTFLD)
       Call CHARGE_FLD(AERR,ACLAF,[F:ASWF]CODTYP,K,"",[F:ASWF]NOLIB,[F:ASWF]LONG,TEST) From ACLAVALLEC
       Call CHARGE_PARFLD(AERR,ACLAF,[L]CODREP,1)
       TYPCLA = 1
    Endif
   Endif
  Else
   Read [F:ACTX]ACTX0=[L]CODOBJ
   If !fstat
     ACLAF = NewInstance C_ACLAFLD AllocGroup null
     FLDCLA = [L]CODOBJ
     PTHGRP = ""
     CLAPRO = ""
     ACLAF.INTITFLD= func ASYRFNC.TEXTE([ACTX]INTIT)
     J=0
     If [ACTX]LNGTYP<>""
      Onerrgo ER_LNGTYP From ASHWVALLEC
       J = evalue([ACTX]LNGTYP)
      Onerrgo
     Endif
     Call CHARGE_FLD(AERR,ACLAF,[ACTX]CODTYP,K,"",0,J,TEST) From ACLAVALLEC
     TYPCLA = 0
   Endif
  Endif
 Else
  If [F:ACLA]CODCLA<>[L]CODCLA
   Read [ACLA]ACLA0 = [L]CODCLA
   If fstat : Raz [F:ACLA] : Endif
  Endif
  If find([F:ACLA]TYPCLA,3,4)
      Return
  Endif
  Read [ACLAF]ACLAF0 = [L]CODCLA;[L]CODOBJ
  If !fstat
    ACLAF = NewInstance C_ACLAFLD AllocGroup null
    SetInstance ACLAF With [F:ACLAF]
    CLAPRO = "C_"+ [F:ACLAF]CODCLA
    Call CHARGE_FLD(AERR,ACLAF,[F:ACLAF]CODTYP,K,"",[F:ACLAF]NOLIB,[F:ACLAF]LONG,TEST) From ACLAVALLEC
    Call CHARGE_PARFLD(AERR,ACLAF) From ACLAVALLEC
    TYPCLA=2
  Endif
 Endif
Endif
Return


#---------------------------------------------------------------------------------------------------#
# Parameters of fields
#---------------------------------------------------------------------------------------------------#
Subprog CHARGE_PARFLD(AERR,ACLAF,CODREP,TYPPAR)
Variable  Instance  AERR(1..) Using C_AERROR
Variable  Instance  ACLAF  Using C_ACLAFLD
Value Integer TYPPAR
Value Char CODREP
Local Integer I
Local Integer NBR_NBP,NBR_NBK
NBR_NBP = maxtab(ACLAF.ATBPAR)
NBR_NBK = maxtab(ACLAF.ATBKEY)
For I=0 To [M:ASW5]NBRPAR-1
 If [M:ASW5]CODFLD(I)=ACLAF.FLDCLA & [M:ASW5]TYPPAR(I)=[L]TYPPAR
   If [M:ASW5]TYPKEY(I)=2
    NBR_NBK += 1
    ACLAF.ATBKEY(NBR_NBK) = NewInstance =ACLAF.AllocGrp , C_ACLAPARFLD
    #ne marche pas
#    nolign=I+1
#    SetInstance ACLAF.ATBKEY(NBR_NBK) With  [M:ASW5]
    ACLAF.ATBKEY(NBR_NBK).CODPAR = [M:ASW5]CODPAR(I)
    ACLAF.ATBKEY(NBR_NBK).VALEUR = [M:ASW5]VALEUR(I)
    #ACLAF.ATBKEY(NBR_NBK).CODTYP =
    ACLAF.ATBKEY(NBR_NBK).TYPINT = [M:ASW5]TYPINTPAR(I)
    #ACLAF.ATBKEY(NBR_NBK).ALIAS =
   Else
    NBR_NBP += 1
    ACLAF.ATBPAR(NBR_NBP) = NewInstance =ACLAF.AllocGrp , C_ACLAPARFLD
    #ne marche pas
#    nolign=I+1
#    SetInstance ACLAF.ATBPAR(NBR_NBP) With  [M:ASW5]
    ACLAF.ATBPAR(NBR_NBP).CODPAR = [M:ASW5]CODPAR(I)
    ACLAF.ATBPAR(NBR_NBP).VALEUR = [M:ASW5]VALEUR(I)
    #ACLAF.ATBPAR(NBR_NBP).CODTYP =
    ACLAF.ATBPAR(NBR_NBP).TYPINT = [M:ASW5]TYPINTPAR(I)
    #ACLAF.ATBPAR(NBR_NBP).ALIAS =
   Endif
 Endif
Next I
End

#---------------------------------------------------------------------------------------------------#
# Add values for parameters of links of properties exposed
#---------------------------------------------------------------------------------------------------#
$MAJ_PARAMPROLNK
Local Char WPTHPRO(250),W0PTHPRO(250),WCHAINE(250)
Local Integer NOL,J,I,K,MAJ,BFOUND
Local Integer FLG_IS_NUM : # flag to indicate if using a formula =num$(...)
Local Integer FLG_IS_VAL : # flag to indicate if using a formula =val(...)

For NOL=0 To [M:ASW5]NBRPAR-1
 If [M:ASW5]AFFLNK(NOL)=[L]LNK_AFF & [M:ASW5]CODFLD(NOL)=[L]LNK_ANC & [M:ASW5]CODLNK(NOL)=[L]CODLNK
  For J=1 To max([L]CMPLNK=19,maxtab(ACLAF.ATY.CHPLIEN))
   For I=1 To maxtab(ACLAF.ATBKEY)
    MAJ=0
    If [M:ASW5]TYPKEY(NOL)=2 &
&     ([L]CMPLNK=19 | ACLAF.ATBKEY(I).CODPAR=ACLAF.ATY.CHPLIEN(J)) & [M:ASW5]CODPAR(NOL)=ACLAF.ATBKEY(I).CODPAR
      If [M:ASW5]STDNEW(NOL)=2 | [M:ASW5]INTVAL(NOL)=[M:ASW5]VALEUR(NOL)
        MAJ=1
      Endif
      #108442
      If WISADI & WCHNUMTAB="" & [M:ASW5]CODPAR(NOL)="NUMTAB"
       WCHNUMTAB=[M:ASW5]VALEUR(NOL)
      Endif
      [M:ASW5]INTVAL(NOL)=ACLAF.ATBKEY(I).VALEUR
      #
      WPTHPRO = LNK_ANC
      WCHAINE = ACLAF.ATBKEY(I).VALEUR
      #
      FLG_IS_NUM=0
      FLG_IS_VAL=0
      If left$([L]WCHAINE,6) = "=num$(" and seg$([L]WCHAINE,len([L]WCHAINE),len([L]WCHAINE)) = ")"
       FLG_IS_NUM = 1
       [L]WCHAINE = seg$([L]WCHAINE,7,len([L]WCHAINE)-1)
      Elsif left$([L]WCHAINE,5) = "=val(" and seg$([L]WCHAINE,len([L]WCHAINE),len([L]WCHAINE)) = ")"
       FLG_IS_VAL = 1
       [L]WCHAINE = seg$([L]WCHAINE,6,len([L]WCHAINE)-1)
      Endif
      #
      K=instr(1,WCHAINE,".")
      While K>0
       WCHAINE = right$(WCHAINE,K+1)
       K=instr(1,WCHAINE,".")
      Wend
      #
      BFOUND=0
      While !BFOUND
        If  (!instr(1,WPTHPRO,".")
&       or instr(1,ACLAF.ATBKEY(I).VALEUR,"ACTX.")<>0
&       or (instr(1,WPTHPRO,".")>0  & left$(WPTHPRO,instr(1,WPTHPRO,".")-1)<>ASHW.ABRCLA)): # Propriete propre representation
          If len(WCHAINE)
            WPTHPRO += "."+WCHAINE
          Elsif !instr(1,WPTHPRO,".")
            WPTHPRO = ACLAF.ATBKEY(I).CODPAR
          Endif
          If clalev([M:ASW0])>0 & clalev([M:ASW4])>0 & [M:ASW0]CODREP=[L]CODREP
            K=find(WPTHPRO,[M:ASW4]CODPRO(0..[M:ASW4]NBRPRO-1))
            If K>0
              If FLG_IS_NUM
               [M:ASW5]INTVAL(NOL)="=num$("+WPTHPRO+")"
              Elsif FLG_IS_VAL
               [M:ASW5]INTVAL(NOL)="=val("+WPTHPRO+")"
              Else
               [M:ASW5]INTVAL(NOL)=WPTHPRO
              Endif
              BFOUND=1
            Endif
          Else
            Read [ASWR2]ASWR3 = ASHW.CODREP;WPTHPRO
            If !fstat
              If FLG_IS_NUM
               [M:ASW5]INTVAL(NOL)="=num$("+WPTHPRO+")"
              Elsif FLG_IS_VAL
               [M:ASW5]INTVAL(NOL)="=val("+WPTHPRO+")"
              Else
               [M:ASW5]INTVAL(NOL)=WPTHPRO
              Endif
              BFOUND=1
            Endif
          Endif
          If !BFOUND
            WPTHPRO = ACLAF.ATBKEY(I).VALEUR
            BFOUND=1
          Endif
        Else
          WPTHPRO = func ASHWVALLEC.PATHCLAPRO(WPTHPRO)
          If WPTHPRO<>""
            W0PTHPRO=left$(WPTHPRO,len(WPTHPRO)-1)
          Else
            W0PTHPRO=""
          Endif
          WPTHPRO += WCHAINE
          If clalev([M:ASW0])>0 & clalev([M:ASW4])>0 & [M:ASW0]CODREP=[L]CODREP
            K=find(WPTHPRO,[M:ASW4]CODPRO(0..[M:ASW4]NBRPRO-1))
            If K>0
              If FLG_IS_NUM
               [M:ASW5]INTVAL(NOL)="=num$("+WPTHPRO+")"
              Elsif FLG_IS_VAL
               [M:ASW5]INTVAL(NOL)="=val("+WPTHPRO+")"
              Else
               [M:ASW5]INTVAL(NOL)=WPTHPRO
              Endif
              BFOUND=1
            Endif
          Else
            Read [ASWR2]ASWR3 = ASHW.CODREP;WPTHPRO
            If !fstat
              If FLG_IS_NUM
               [M:ASW5]INTVAL(NOL)="=num$("+WPTHPRO+")"
              Elsif FLG_IS_VAL
               [M:ASW5]INTVAL(NOL)="=val("+WPTHPRO+")"
              Else
               [M:ASW5]INTVAL(NOL)=WPTHPRO
              Endif
              BFOUND=1
            Endif
          Endif
          If !BFOUND
            WPTHPRO=W0PTHPRO
          Endif
        Endif
      Wend
      If MAJ & [M:ASW5]INTVAL(NOL)<>[M:ASW5]VALEUR(NOL)
        [M:ASW5]STDNEW(NOL)=2
        [M:ASW5]VALEUR(NOL)= [M:ASW5]INTVAL(NOL)
        If [L]CMPLNK=9 & [M:ASW5]VALEUR(NOL)=[L]LNK_ANC
           [M:ASW5]ADRVAL(NOL)=1
        Endif
        #108442
        If WISADI & [M:ASW5]CODPAR(NOL)="NUMTAB" & [M:ASW5]INTVAL(NOL)<>""
         WCHNUMTAB=[M:ASW5]INTVAL(NOL)
        Endif
      Endif
    Endif
   Next I
   If [L]CMPLNK=19
   For I=1 To maxtab(ACLAF.ATBPAR)
    MAJ=0
    If [M:ASW5]TYPKEY(NOL)<>2 &
&     ([L]CMPLNK=19 | ACLAF.ATBPAR(I).CODPAR=ACLAF.ATY.CHPLIEN(J)) & [M:ASW5]CODPAR(NOL)=ACLAF.ATBPAR(I).CODPAR
      If [M:ASW5]STDNEW(NOL)=2 | [M:ASW5]INTVAL(NOL)=[M:ASW5]VALEUR(NOL)
        MAJ=1
      Endif
      [M:ASW5]INTVAL(NOL)=ACLAF.ATBPAR(I).VALEUR
      #
      WPTHPRO = LNK_ANC
      WCHAINE = ACLAF.ATBPAR(I).VALEUR
      #
      FLG_IS_NUM=0
      FLG_IS_VAL=0
      If left$([L]WCHAINE,6) = "=num$(" and seg$([L]WCHAINE,len([L]WCHAINE),len([L]WCHAINE)) = ")"
       FLG_IS_NUM = 1
       [L]WCHAINE = seg$([L]WCHAINE,7,len([L]WCHAINE)-1)
      Elsif left$([L]WCHAINE,5) = "=val(" and seg$([L]WCHAINE,len([L]WCHAINE),len([L]WCHAINE)) = ")"
       FLG_IS_VAL = 1
       [L]WCHAINE = seg$([L]WCHAINE,6,len([L]WCHAINE)-1)
      Endif
      #
      K=instr(1,WCHAINE,".")
      While K>0
       WCHAINE = right$(WCHAINE,K+1)
       K=instr(1,WCHAINE,".")
      Wend
      #
      BFOUND=0
      While !BFOUND
        If  (!instr(1,WPTHPRO,".")
&       or instr(1,ACLAF.ATBPAR(I).VALEUR,"ACTX.")<>0
&       or (instr(1,WPTHPRO,".")>0  & left$(WPTHPRO,instr(1,WPTHPRO,".")-1)<>ASHW.ABRCLA)): # Propriete propre representation
          If len(WCHAINE)
            WPTHPRO += "."+WCHAINE
          Elsif !instr(1,WPTHPRO,".")
            WPTHPRO = ACLAF.ATBPAR(I).CODPAR
          Endif
          If clalev([M:ASW0])>0 & clalev([M:ASW4])>0 & [M:ASW0]CODREP=[L]CODREP
            K=find(WPTHPRO,[M:ASW4]CODPRO(0..[M:ASW4]NBRPRO-1))
            If K>0
              If FLG_IS_NUM
               [M:ASW5]INTVAL(NOL)="=num$("+WPTHPRO+")"
              Elsif FLG_IS_VAL
               [M:ASW5]INTVAL(NOL)="=val("+WPTHPRO+")"
              Else
               [M:ASW5]INTVAL(NOL)=WPTHPRO
              Endif
              BFOUND=1
            Endif
          Else
            Read [ASWR2]ASWR3 = ASHW.CODREP;WPTHPRO
            If !fstat
              If FLG_IS_NUM
               [M:ASW5]INTVAL(NOL)="=num$("+WPTHPRO+")"
              Elsif FLG_IS_VAL
               [M:ASW5]INTVAL(NOL)="=val("+WPTHPRO+")"
              Else
               [M:ASW5]INTVAL(NOL)=WPTHPRO
              Endif
              BFOUND=1
            Endif
          Endif
          If !BFOUND
            WPTHPRO = ACLAF.ATBPAR(I).VALEUR
            BFOUND=1
          Endif
        Else
          WPTHPRO = func ASHWVALLEC.PATHCLAPRO(WPTHPRO)
          If WPTHPRO<>""
            W0PTHPRO=left$(WPTHPRO,len(WPTHPRO)-1)
          Else
            W0PTHPRO=""
          Endif
          WPTHPRO += WCHAINE
          If clalev([M:ASW0])>0 & clalev([M:ASW4])>0 & [M:ASW0]CODREP=[L]CODREP
            K=find(WPTHPRO,[M:ASW4]CODPRO(0..[M:ASW4]NBRPRO-1))
            If K>0
              If FLG_IS_NUM
               [M:ASW5]INTVAL(NOL)="=num$("+WPTHPRO+")"
              Elsif FLG_IS_VAL
               [M:ASW5]INTVAL(NOL)="=val("+WPTHPRO+")"
              Else
               [M:ASW5]INTVAL(NOL)=WPTHPRO
              Endif
              BFOUND=1
            Endif
          Else
            Read [ASWR2]ASWR3 = ASHW.CODREP;WPTHPRO
            If !fstat
              If FLG_IS_NUM
               [M:ASW5]INTVAL(NOL)="=num$("+WPTHPRO+")"
              Elsif FLG_IS_VAL
               [M:ASW5]INTVAL(NOL)="=val("+WPTHPRO+")"
              Else
               [M:ASW5]INTVAL(NOL)=WPTHPRO
              Endif
              BFOUND=1
            Endif
          Endif
          If !BFOUND
            WPTHPRO=W0PTHPRO
          Endif
        Endif
      Wend
      If MAJ & [M:ASW5]INTVAL(NOL)<>[M:ASW5]VALEUR(NOL)
        [M:ASW5]STDNEW(NOL)=2
        [M:ASW5]VALEUR(NOL)= [M:ASW5]INTVAL(NOL)
        If [L]CMPLNK=9 & [M:ASW5]VALEUR(NOL)=[L]LNK_ANC
           [M:ASW5]ADRVAL(NOL)=1
        Endif
      Endif
    Endif
   Next I
   Elsif WISADI & find([L]CMPLNK,5,9)>0 & WCHNUMTAB<>"" & [M:ASW5]CODPAR(NOL)="NUMTAB" & WCHNUMTAB<>[M:ASW5]INTVAL(NOL)
      #108442
      [M:ASW5]STDNEW(NOL)=2
      [M:ASW5]VALEUR(NOL)=WCHNUMTAB
      [M:ASW5]INTVAL(NOL)=WCHNUMTAB
   Endif
  Next J
 Endif
Next NOL
Return

#----------------------------------------------------------#
$ADD_LINKS_STD
Local Integer WISADI : WISADI=0
Local Char WCHNUMTAB(30) : WCHNUMTAB=""
Read [ACV]CODACT = [F:ASW2]CODACT
If [F:ASW2]CODACT="" or (!fstat & [F:ACV]FLACT=2)
 #108442
 If ACLAF.ATY.CODTYP="ADI"
  WISADI=1
 Endif
 #
 If find(ACLAF.ATY.TYPTYP,9,10)
  [L]CMPLNK=19
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMPROLNK
  Endif
 Else
 If [F:ASW2]ENAFAC(0)=2 : # Read
  [L]CMPLNK=2
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMPROLNK
  Endif
 Endif
 If [F:ASW2]ENAFAC(3)=2 : #  lookup
  [L]CMPLNK=9
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMPROLNK
  Endif
 Endif
 If [F:ASW2]ENAFAC(2)=2 : # Query
  [L]CMPLNK=5
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMPROLNK
  Endif
 Endif
 If [F:ASW2]ENAFAC(4)=2 : # Summary
  [L]CMPLNK=10
  Call ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,[L]CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,[L]CODLNK,[L]NOLASW6)
  If [L]CODLNK<>""
  # load all link parameters/keys
  Call LOAD_PARLNK_ASW5(1,DOSSIER,ASHW.CODREP,ASHW.CODCLA,[L]CMPLNK,LNK_AFF,LNK_ANC,[L]CODLNK, [M:ASW6]TYPLNK([L]NOLASW6),
&     [M:ASW6]CLALNK([L]NOLASW6), [M:ASW6]REPLNK([L]NOLASW6), "", "",
&     "") From SUBASW_TOOL
  Gosub MAJ_PARAMPROLNK
  Endif
 Endif
 Endif
Endif
Return

#----------------------------------------------------------#
Subprog ADD_LNK_STD(DOSSIER,CODREP,ASHW,LNK_AFF, LNK_ANC,ASWACTIONS,CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM,ACLAF,CODLNK,NOL)
Value Char    DOSSIER
Value Char    CODREP
Variable Instance  ASHW Using C_ASW
Value Integer LNK_AFF
Value Char    LNK_ANC
Variable Instance ASWACTIONS(1..) Using C_ASWACTION
Value Integer CMPLNK
Value Integer LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM : #facette of the link
Variable Instance ACLAF Using C_ACLAFLD
Variable Char    CODLNK
Variable Integer    NOL

[L]CODLNK=ASWACTIONS([L]CMPLNK).CODLNK
Local Char WIDENT2(255)
WIDENT2=func SUBASW_TOOL.BUILD_ASW6_IDENT2([L]LNK_AFF,[L]LNK_ANC,[L]CODLNK)

#Local Integer PROCLE
#On ne gère pas le Imprimer pour le moment
#If [L]DOSSIER<>"SUPERV" & find([L]CMPLNK,11,12)
If find([L]CMPLNK,11,12)
  Raz [L]CODLNK
  End
Endif

Local Integer I
I=find(WIDENT2,[M:ASW6]IDENT2(0..[M:ASW6]NBRLNK-1))
Gosub VERIF_FACET

If I=0 & [L]CODLNK="" : End : Endif

If I>0
  #le lien existe déjà !!
  NOL=I-1
  If [M:ASW6]STDNEW(NOL)=0 : [M:ASW6]STDNEW(NOL)=1 : Endif
  nolign=I
  [F:ASWK2]=[M:ASW6]
  If [L]CODLNK="" : [M:ASW6]STDNEW(NOL)=0 : Endif
Else
  NOL=[M:ASW6]NBRLNK
  [M:ASW6]NBRLNK+=1
  [M:ASW6]STDNEW(NOL)=2
  [M:ASW6]MENLNK(NOL)=""
  [M:ASW6]ORDLNK(NOL)=0
  [M:ASW6]ENALNK(NOL)=2
  [M:ASW6]INVLNK(NOL)=1
  [M:ASW6]REMSTDLNK(NOL)=""
  [M:ASW6]ACVLNK(NOL)=""
  [M:ASW6]CODLNK(NOL)=[L]CODLNK
  [M:ASW6]AFFLNK(NOL)=[L]LNK_AFF
  [M:ASW6]ANCLNK(NOL)=[L]LNK_ANC
  [M:ASW6]IDENT2(NOL) = WIDENT2
Endif

If [M:ASW6]ORDLNK(NOL)=0 : [M:ASW6]ORDLNK(NOL)=ASWACTIONS([L]CMPLNK).ORDLNK : Endif
If [L]CMPLNK=19 : #Gestion LOB
  [M:ASW6]TYPLNK(NOL)=5 : # LIBRE
#115007/1
Elsif find([L]CMPLNK,17,18,22) : #Enregistrer,abandon
  [M:ASW6]TYPLNK(NOL)=1 : #Représentation
  [M:ASW6]REPLNK(NOL)=ASHW.CODREP
Else
  [M:ASW6]TYPLNK(NOL)=1 : #Représentation
  If [L]LNK_AFF=1
    [M:ASW6]REPLNK(NOL)=[F:ASW2]CODREP
    [M:ASW6]CLALNK(NOL)=ACLAF.ATY.CODCLA
    #indic dernière cle
#11/07
#    If [L]CMPLNK=9 & ASHW.ACLA.NBCLEREF>0
#      Read [ACLAF]ACLAF0 = ASHW.CODCLA;ASHW.ACLA.ACLAI(ASHW.ACLA.NBCLEREF).CLEREF
#      If !fstat & [F:ACLAF]FLDGRP<>""
#        If ASHW.ABRCLA+"."+[F:ACLAF]FLDGRP+"."+ASHW.ACLA.ACLAI(ASHW.ACLA.NBCLEREF).CLEREF=[L]LNK_ANC
#          [L]PROCLE=1
#        Endif
#      Else
#        If ASHW.ABRCLA+"."+ASHW.ACLA.ACLAI(ASHW.ACLA.NBCLEREF).CLEREF=[L]LNK_ANC
#          [L]PROCLE=1
#        Endif
#      Endif
#    Endif
  Else
    [M:ASW6]REPLNK(NOL)=ASHW.CODREP
    [M:ASW6]CLALNK(NOL)=ASHW.CODCLA
  Endif
Endif
[M:ASW6]CMPLNK(NOL)=[L]CMPLNK
[M:ASW6]CLAPTRLNK(NOL)=""
[M:ASW6]METLNK(NOL)=""
[M:ASW6]CODFNCLNK(NOL)=""
[M:ASW6]FREELNK(NOL)=""
[M:ASW6]RPTCOD(NOL)="" :#104754/3
[M:ASW6]FLGSTDLNK(NOL)=2
If NEW_ATTLNK<>0
 [M:ASW6]ATTLNK(NOL)=NEW_ATTLNK
Else
 [M:ASW6]ATTLNK(NOL)=1
Endif

#If ASHW.FONCTION<>""
If NEW_TYPLNK<>0
 [M:ASW6]TYPLNK(NOL)=NEW_TYPLNK
 [M:ASW6]REPLNK(NOL)=NEW_REPLNK
 [M:ASW6]CLALNK(NOL)=NEW_CLALNK
 [M:ASW6]CODFNCLNK(NOL)=NEW_CODFNCLNK
Endif

If NEW_INTLNK<>0
 [M:ASW6]INTITLNK(NOL)=NEW_INTITLNK
 [M:ASW6]INTLNK(NOL)=NEW_INTLNK
Else
 [M:ASW6]INTITLNK(NOL)=ASWACTIONS([L]CMPLNK).INTITLNK
 [M:ASW6]INTLNK(NOL)=ASWACTIONS([L]CMPLNK).INTLNK
Endif

[M:ASW6]DETLNK(NOL)=NEW_DETLNK
[M:ASW6]QRYLNK(NOL)=NEW_QRYLNK
[M:ASW6]EDILNK(NOL)=NEW_EDILNK
[M:ASW6]LOKLNK(NOL)=NEW_LOKLNK
[M:ASW6]SUMLNK(NOL)=NEW_SUMLNK

If [M:ASW6]STDNEW(NOL)=1 &
&   ([M:ASW6]INTLNK(NOL)<>[F:ASWK2]INTLNK
&    | [M:ASW6]CMPLNK(NOL)<>[F:ASWK2]CMPLNK
&    | [M:ASW6]TYPLNK(NOL)<>[F:ASWK2]TYPLNK
&    | [M:ASW6]CODFNCLNK(NOL)<>[F:ASWK2]CODFNCLNK
&    | [M:ASW6]CLALNK(NOL)<>[F:ASWK2]CLALNK
&    | [M:ASW6]REPLNK(NOL)<>[F:ASWK2]REPLNK
&    | [M:ASW6]ATTLNK(NOL)<>[F:ASWK2]ATTLNK
&    | [M:ASW6]DETLNK(NOL)<>[F:ASWK2]DETLNK
&    | [M:ASW6]QRYLNK(NOL)<>[F:ASWK2]QRYLNK
&    | [M:ASW6]EDILNK(NOL)<>[F:ASWK2]EDILNK
&    | [M:ASW6]LOKLNK(NOL)<>[F:ASWK2]LOKLNK
&    | [M:ASW6]SUMLNK(NOL)<>[F:ASWK2]SUMLNK
&    | [M:ASW6]ORDLNK(NOL)<>[F:ASWK2]ORDLNK
&    | [M:ASW6]FLGSTDLNK(NOL)<>[F:ASWK2]FLGSTDLNK)
    [M:ASW6]STDNEW(NOL)=2
  Endif

End
#----------------------------------------------------------#


######################################################################################
$VERIF_FACET
Local Integer IACLAI
Local Integer NEW_DETLNK,NEW_QRYLNK,NEW_EDILNK,NEW_LOKLNK,NEW_SUMLNK : #facette of the link
Local Integer NEW_TYPLNK,NEW_ATTLNK,NEW_INTLNK
Local Char NEW_REPLNK(60),NEW_CLALNK(60),NEW_CODFNCLNK(GLONAFC)
Local Char NEW_INTITLNK(80)

Raz NEW_TYPLNK,NEW_ATTLNK,NEW_INTLNK
Raz NEW_REPLNK,NEW_CLALNK,NEW_CODFNCLNK
Raz NEW_INTITLNK

# Selon AML 7971
Case [L]CMPLNK
When 1  : # Créer une fiche
  #pour LNK_AFF=4
  If ASHW.FONCTION<>""
    NEW_TYPLNK=4
    NEW_REPLNK=""
    NEW_CLALNK=""
    NEW_CODFNCLNK=ASHW.FONCTION
  Endif
  #108421 NEW_DETLNK=1
  NEW_DETLNK=2
  NEW_QRYLNK=2
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 2  : # Afficher détail
  #pour LNK_AFF=1 ou 5
  NEW_ATTLNK=2
  If [L]LNK_AFF=1
    If ACLAF.ATY.CODCLA<>ASHW.CODCLA
      NEW_DETLNK=2
    Else
      #Si champ clé : pas de détail en détail
      IACLAI=find(ACLAF.FLDCLA,ASHW.ACLA.ACLAI(1..ASHW.ACLA.NBCLEREF).CLEREF)
      If IACLAI>0
        NEW_DETLNK=1
      Else
        NEW_DETLNK=2
      Endif
    Endif
  Else
    NEW_DETLNK=1
  Endif
  NEW_QRYLNK=2
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 3  : # Modifier une fiche
  #pour LNK_AFF=5 ou 4
  If ASHW.FONCTION<>""
    NEW_TYPLNK=4
    NEW_REPLNK=""
    NEW_CLALNK=""
    NEW_CODFNCLNK=ASHW.FONCTION
  Endif
  If [L]LNK_AFF=4
   NEW_DETLNK=1
   If [F:AFC]CODINT<>ASHW.FONCTION
    Read [AFC]CODINT = ASHW.FONCTION
    If fstat : Raz [F:AFC] : Endif
   Endif
   If [F:AFC]LIBMENU<>0
    NEW_INTITLNK=func ASYRFNC.TEXTE([F:AFC]LIBMENU)
    NEW_INTLNK=[F:AFC]LIBMENU
   Endif
  Else
   NEW_DETLNK=2
  Endif
  NEW_QRYLNK=2
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 4  : # Supprimer une fiche
  #pour LNK_AFF=5
  NEW_DETLNK=2
  NEW_QRYLNK=2
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 5  : # Afficher liste
  #pour LNK_AFF=1 ou 4
  If [L]LNK_AFF=1
    If ACLAF.ATY.CODCLA<>ASHW.CODCLA
      NEW_DETLNK=2
      NEW_QRYLNK=2
    Else
      #Si champ clé : pas de liste en détail ni query
      IACLAI=find(ACLAF.FLDCLA,ASHW.ACLA.ACLAI(1..ASHW.ACLA.NBCLEREF).CLEREF)
      If IACLAI>0
        NEW_DETLNK=1
        NEW_QRYLNK=1
      Else
        NEW_DETLNK=2
        NEW_QRYLNK=2
      Endif
    Endif
  Else
    NEW_DETLNK=2
    NEW_QRYLNK=1
  Endif
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 6  : # Dupliquer une fiche
  #pour LNK_AFF=5
  NEW_DETLNK=2
  NEW_QRYLNK=1
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 7  : # Afficher dans Excel
  #pour LNK_AFF=5
  NEW_DETLNK=2
  NEW_QRYLNK=1
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=2
When 8  : # Lister dans Excel
  #pour LNK_AFF=4
  NEW_DETLNK=1
  NEW_QRYLNK=2
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 9  : # Sélection
  #pour LNK_AFF=1
  NEW_ATTLNK=3
  NEW_QRYLNK=2
  #96945 NEW_LOKLNK=1
  NEW_LOKLNK=2
#11/07
#  If [L]PROCLE=1 : # si dernière clé : pas de lookup en Edit qq soit la classe
#    NEW_SUMLNK=1
#    NEW_DETLNK=1
#    NEW_EDILNK=1
#  ELS
  If ACLAF.ATY.CODCLA<>ASHW.CODCLA
    NEW_SUMLNK=2
    NEW_DETLNK=2
    NEW_EDILNK=2
  Else
    NEW_SUMLNK=1
    NEW_DETLNK=1
    IACLAI=find(ACLAF.FLDCLA,ASHW.ACLA.ACLAI(1..ASHW.ACLA.NBCLEREF).CLEREF)
    If IACLAI=0
      NEW_EDILNK=2
#11/07
#    Elsif IACLAI=ASHW.ACLA.NBCLEREF : # si dernière clé : pas de lookup en Edit
#      NEW_EDILNK=1
    Else
#11/07
#      NEW_EDILNK=2
      NEW_EDILNK=1
    Endif
  Endif
When 10 : # Afficher résumé
  #pour LNK_AFF=1
  NEW_ATTLNK=4
  NEW_DETLNK=2
  NEW_QRYLNK=2
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 11 : # Afficher en PDF
  #pour LNK_AFF=5
  NEW_DETLNK=2
  NEW_QRYLNK=1
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=2
When 12 : # Lister en PDF
  #pour LNK_AFF=4
  NEW_DETLNK=1
  NEW_QRYLNK=2
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 13 : # Afficher dans Word
  #pour LNK_AFF=5
  NEW_DETLNK=2
  NEW_QRYLNK=1
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=2
When 14 : # Lister dans Word
  #pour LNK_AFF=4
  NEW_DETLNK=1
  NEW_QRYLNK=2
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 15 : # Publiposter fiche
  #pour LNK_AFF=5
  NEW_DETLNK=2
  NEW_QRYLNK=1
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=2
When 16 : # Publiposter liste
  #pour LNK_AFF=4
  NEW_DETLNK=1
  NEW_QRYLNK=2
  NEW_EDILNK=1
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 17 : # Enregistrer
  #pour LNK_AFF=4
  NEW_DETLNK=1
  NEW_QRYLNK=1
  NEW_EDILNK=2
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 18 : # Abandon
  #pour LNK_AFF=4
  NEW_DETLNK=1
  NEW_QRYLNK=1
  NEW_EDILNK=2
  NEW_LOKLNK=1
  NEW_SUMLNK=1
When 19  : # Gestion LOB
  #pour LNK_AFF=1
  NEW_DETLNK=2
  NEW_QRYLNK=2
  NEW_EDILNK=2
  NEW_LOKLNK=2
  NEW_SUMLNK=2
When 22  : # Aide 115007/1
  #pour LNK_AFF=4
  NEW_DETLNK=2
  NEW_QRYLNK=2
  NEW_EDILNK=2
  NEW_LOKLNK=1
  NEW_SUMLNK=1
Endcase

If LK_DET<>2 & NEW_DETLNK=2 : NEW_DETLNK=1 : Endif
If LK_QRY<>2 & NEW_QRYLNK=2 : NEW_QRYLNK=1 : Endif
If LK_EDI<>2 & NEW_EDILNK=2 : NEW_EDILNK=1 : Endif
If LK_LOK<>2 & NEW_LOKLNK=2 : NEW_LOKLNK=1 : Endif
If LK_SUM<>2 & NEW_SUMLNK=2 : NEW_SUMLNK=1 : Endif

If find([L]LNK_AFF,4,5)=0 & NEW_DETLNK<>2 & NEW_EDILNK<>2 & NEW_QRYLNK<>2 & NEW_LOKLNK<>2 & NEW_SUMLNK<>2
  [L]CODLNK="" : #Pour ne pas charger les params
Endif
Return

