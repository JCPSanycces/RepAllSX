$ON_PRV
Onevent BEFORE_AREA Gosub AV_PRV From W1HRAFRCLS1
Onevent BEFORE_INPUT Call AS_PRV(zc) From W1HRAFRCLS1
Onevent CONTROL Call C_PRV(zc) From W1HRAFRCLS1
Return

Subprog IB_PRV(VALEUR)
Variable Char    VALEUR()
## Action INISAT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "INISAT"
PARMSK(1) = CRY
PARMSK(2) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"INISAT","TRTDIV","") From GACTION
GACTION = SAVACT
Gosub _AFF
End

$AV_PRV
If !GWEBSERV
 ## Action FMTSAT
 Call FMTSATPAY(CRY,"") From TRTDIV
Endif
If GFMT<>""
 Chgfmt [M]PRV(indice) With "K:"+GFMT
Else
 Chgfmt [M]PRV(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_PRV(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(31745,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_PRV(VALEUR)
If  GWEBSERV
 ## Action SAISAT
 Call SAISAT(CRY,"") From TRTDIV
 If mkstat=2
  [M]PRV(INDIC) = VALEUR
  Affzo PRV(INDIC) : mkstat = 2
 Endif
Endif
Onkey 130 Titled GBOUT2 Call B2_PRV(zc) From W1HRAFRCLS1
Onkey   2 Titled GBOUTS Call S_PRV(zc) From W1HRAFRCLS1
Gosub _AFF
End

Subprog C_PRV(VALEUR)
Variable Char    VALEUR()
## Action CTLSAT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CTLSAT"
PARMSK(1) = CRY
PARMSK(2) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"CTLSAT","TRTDIV","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "PRV" : GZNUM = 13511 : Endif
Gosub _AFF
End

Subprog S_PRV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELSAT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSAT"
 PARMSK(1) = CRY
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELSAT","TRTDIV","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B2_PRV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNSAT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "TUNSAT"
 PARMSK(1) = CRY
 PARMSK(2) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"TUNSAT","TRTDIV","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CHGCMT
Onevent CONTROL Call C_CHGCMT(zc) From W1HRAFRCLS1
Return

Subprog C_CHGCMT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_CHGCMT(VALEUR) From SUBHRACSA
If mkstat : GERR = 1 : GZONE = "CHGCMT" : GZNUM = 821 : Endif
Gosub _AFF
End

$CHG_STY
Return


