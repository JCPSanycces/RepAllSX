#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRAFRCLS1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:34"
A_USER  = "DOC"
A_STAMP = "20181109230434"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "LIGNUM"
  If [M]LIGNUM=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRAFRCLS1 [HRAC1]
Gosub HORODAT
Local Inpbox "HRAFRCLS1" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRAC1] As [SIM_]
Grizo [HRAC1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRAC1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=114 : Y1(0)=1 : Y2(0)=25
Return

$ON_PYRMON
Onevent CONTROL Call C_PYRMON(zc) From W1HRAFRCLS1
Onevent BEFORE_AREA Gosub AV_PYRMON From W1HRAFRCLS1
Return

$AV_PYRMON
Chgfmt [M]PYRMON(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_PYRMON(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PYRMON" : GZNUM = 44798 : Endif
Gosub _AFF
End

$ON_FCY
Onevent CONTROL Call C_FCY(zc) From W1HRAFRCLS1
Onevent BEFORE_INPUT Call AS_FCY(zc) From W1HRAFRCLS1
Return

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1427,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_FCY(zc) From W1HRAFRCLS1
Onkey   2 Titled GBOUTS Call S_FCY(zc) From W1HRAFRCLS1
Onkey 144 Titled GBOUTP Call P_FCY(zc) From W1HRAFRCLS1
Onkey 146 Titled GBOUTA Call SA_FCY(zc) From W1HRAFRCLS1
Gosub _AFF
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
## Action ACONTFCY
Call CONTSITE(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("FCY","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
Endif
Gosub _AFF
End

Subprog S_FCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_FCY(VALEUR)
Variable Char    VALEUR()
Call OBJET("FCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_FCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_FCY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

