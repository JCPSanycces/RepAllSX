#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("CTR",GBIDC1,GBIDC2) From GOBJET
End

#--------------------------------------------------------------------------------------
# TRTVARAVT : Génération d'un avenant (copie du contrat) avec infos pour VAR
#--------------------------------------------------------------------------------------
End

$ACTION
Case [L]ACTION
 When "OUVRE" :  Gosub OUVRE
 When "DEBUT" :  Gosub DEBUT
 When "OK"    :  Gosub OK
 When "FERME" :  Gosub FERME
Endcase
Return

$OUVRE
#MIPEA - 2017-02-13- X3-11258- START
If !clalev([F:HRCTR1]) : Local File EMPLOCTR [HRCTR1] : Endif
If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
#If !clalev([F:CTR1]) : Local File EMPLOCTR [CTR1] : Endif
#If !clalev([F:CTR2]) : Local File EMPLOCTR [CTR2] : Endif
#MIPEA - 2017-02-13- X3-11258- END
If !clalev([F:ID])   : Local File EMPLOID    [ID]  : Endif
If !clalev([F:ID3])  : Local File EMPLOID   [ID3]  : Endif # FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
#JOJAC - 2018-03-20 - X3-82996 - START
If !clalev([F:CPR])  : Local File EMPLOCTRCPT  [CPR]   : Endif :#108400
If !clalev([F:CPR2]) : Local File EMPLOCTRCPT  [CPR2]  : Endif :#108400
#JOJAC - 2018-03-20 - X3-82996 - END
Local Integer STAT
Local Char CTR (GLONHRCTR)
Local Char COMPTEUR(GLONANM)

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$DEBUT
Raz [M:DIA]
[M:DIA]REFNUM=PARAM(1)
[M:DIA]CTRNUM=PARAM(2)
[M:DIA]CTRDAT=PARAM(3)
[M:DIA]XITDAT=PARAM(4)
# FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN([M:DIA]REFNUM,"[M:DIA]","","SRN",0,0) From DIVPAYE
Affzo [M:DIA]
Return


###########################
$OK
Call DEBTRANS From GLOCK
#MIPEA - 2017-02-13- X3-11258- START
Trbegin [HRCTR2],[ID]
#Trbegin [CTR2],[ID]
#MIPEA - 2017-02-13- X3-11258- END
Gosub TR1
If GOK<=0
 [L]PARAM(5) = ""
 [L]PARAM(6) = ""
 Rollback
Else
 Commit
 [L]PARAM(5) = [L]CTR
 [L]PARAM(6) = num$([M:DIA]AVTCTRDAT)
Endif
Return

$TR1
#MIPEA - 2017-02-13- X3-11258- START
Read [F:HRCTR1]CTR0 = [M:DIA]REFNUM ; [M:DIA]CTRNUM ; [M:DIA]CTRDAT
#Read [F:CTR1]CTR0 = [M:DIA]REFNUM ; [M:DIA]CTRNUM ; [M:DIA]CTRDAT
#MIPEA - 2017-02-13- X3-11258- END
If !fstat
 If [M:DIA]FLGNEWCTR=2
   Gosub NEWCTR
 Else
  [L]CTR=[M:DIA]CTRNUM
 Endif
 If [L]CTR<>""
#MIPEA - 2017-02-13- X3-11258- START
  [F:HRCTR2]=[F:CTR1]
  [F:HRCTR2]CTRNUM = [L]CTR
  [F:HRCTR2]CTRDAT = [M:DIA]AVTCTRDAT
  [F:HRCTR2]CTRGRD = [M:DIA]AVTCTRGRD
  [F:HRCTR2]XITDAT = [M:DIA]AVTXITDAT
  [F:HRCTR2]XITGRD = [M:DIA]AVTXITGRD
  [F:HRCTR2]FLGVAR = 2
  [F:HRCTR2]XITFNL = 1
  If GPAYE : [F:HRCTR2]RAZCUM = 1 : Endif
  [F:HRCTR2]CLEEVETIM = 1
  [F:HRCTR2]SUICAR = 1
  #JOJAC - 2018-03-20 - X3-82996 - START
  #96373 : RAZ infos de rétro !
  [F:HRCTR2]FLGRET=1
  [F:HRCTR2]RETTYP=1
  [F:HRCTR2]RETSTATUT =1
  Raz [F:HRCTR2]RETDATEFF,[F:HRCTR2]RETCTRNUMORI,[F:HRCTR2]RETCTRDATORI,[F:HRCTR2]RETGRD

  If GPAYE & dim([F:HRCTR2]FLGCREBUL)>=0 : [F:HRCTR2]FLGCREBUL=2 : Endif
  #JOJAC - 2018-03-20 - X3-82996 - END

  Write [F:HRCTR2]
#  [F:CTR2]=[F:CTR1]
#  [F:CTR2]CTRNUM = [L]CTR
#  [F:CTR2]CTRDAT = [M:DIA]AVTCTRDAT
#  [F:CTR2]CTRGRD = [M:DIA]AVTCTRGRD
#  [F:CTR2]XITDAT = [M:DIA]AVTXITDAT
#  [F:CTR2]XITGRD = [M:DIA]AVTXITGRD
#  [F:CTR2]FLGVAR = 2
#  [F:CTR2]XITFNL = 1
#  If GPAYE : [F:CTR2]RAZCUM = 1 : Endif
#  [F:CTR2]CLEEVETIM = 1
#  [F:CTR2]SUICAR = 1
#  Write [F:CTR2]
#MIPEA - 2017-02-13- X3-11258- END
  If fstat
   GOK = 0 : Call FSTA("HRCTR") From GLOCK
  Endif
  #JOJAC - 2018-03-20 - X3-82996 - START
  #LIPET - 2018-10-05 - X3-110779 - START
    #FRLAA  - 2015-04-02 - Requirement 104590 US 3297 - START - This section was commented when QA 2015/12/08
  #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) > 0 & (func DIVPAYE.IS_KFR_LEG(GCURLEG)=0 & func DIVPAYE.IS_KPO_LEG(GCURLEG)=0)
    Call SET_EMPCTRSA([M:DIA]REFNUM,[M:DIA]CTRNUM,[M:DIA]CTRDAT,[M:DIA]AVTCTRDAT) From SUBCTRKSA
  Endif
  #FRLAA  - 2015-04-07 - Requirement 104590 US 3297 - END
  #LIPET - 2018-10-05 - X3-110779 - END

  #108400 - Reprise des info comptables
  Read [F:CPR]=[F:CTR1]REFNUM;[F:CTR1]CTRNUM;[F:CTR1]CTRDAT
  If !fstat
   Raz [F:CPR2]
   [F:CPR2]=[F:CPR]
   [F:CPR2]CTRNUM = [L]CTR
   [F:CPR2]CTRDAT = [M:DIA]AVTCTRDAT
   Write [F:CPR2]
   If fstat
    GOK = 0 : Call FSTA("CPR") From GLOCK
   Endif
  Endif
  #
  #JOJAC - 2018-03-20 - X3-82996 - END
 Else
  #Création impossible : Erreur sur compteur
  GOK=0 :  Call ERREUR (mess(7,123,1)-":"-mess(4,10702,1)) From GESECRAN
 Endif
Endif
If !GOK : Return : Endif

If [M:DIA]FLGNEWCTR=2
 Readlock[F:ID]ID0=[M:DIA]REFNUM
 If !fstat
  [F:ID]FLGMULCTR=2
  [F:ID]UPDDAT = date$
  [F:ID]UPDUSR = GUSER
  [F:ID]UPDTIM = time
  Rewrite [F:ID]
  If fstat
   GOK = 0 : Call FSTA("ID") From GLOCK : Return
  Endif
 Endif
 If !GOK : Return : Endif
Endif

#MIPEA - 2017-02-13- X3-11258- START
Call SET_EMPCTR([F:HRCTR2]REFNUM, [F:HRCTR2]CTRNUM, 1) From TRTRETAVT    : # Recalcul EMPCTR
#Call SET_EMPCTR([F:CTR2]REFNUM, [F:CTR2]CTRNUM, 1) From TRTRETAVT    : # Recalcul EMPCTR
#MIPEA - 2017-02-13- X3-11258- END
If GOK<1 : Return : Endif

#THRAM  - 2017-08-21 - REQ - START
If func DIVPAYE.IS_KZA(GCURLEG) or  func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
  Call SET_EMPCTRSA([M:DIA]REFNUM,[M:DIA]CTRNUM,[M:DIA]CTRDAT,[M:DIA]AVTCTRDAT) From SUBCTRKSA
Endif
#THRAM  - 2017-08-21 - REQ - END

Return

############################
$NEWCTR
If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

#MIPEA - 2017-02-13- X3-11258- START
Call LECTURE("FCY",[F:HRCTR1]ETRFCY,"") From CONTOBJ
#Call LECTURE("FCY",[F:CTR1]ETRFCY,"") From CONTOBJ
#MIPEA - 2017-02-13- X3-11258- END
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GSOCIETE=[F:CPY]CPY
If GNBLEG = 1
  GCURLEG = GDOSLEG
Else
  If dim([F:CPY]LEG)>0
    GCURLEG =[F:CPY]LEG
  Endif
Endif
Call LECTCA(9,STAT) From SUBTCA
If !STAT
  Call ERREUR (mess(12,114,1)) From GESECRAN : # Compteur inexistant
  Raz [L]CTR : Return
Else
  COMPTEUR= [F:TCA]CODNUM(3)
Endif

#MIPEA - 2017-02-13- X3-11258- START
Call NUMERO(COMPTEUR,[F:HRCTR1]ETRFCY,[M:DIA]AVTCTRDAT,[F:HRCTR1]NATCON,[L]CTR,STAT) From SUBANM
#Call NUMERO(COMPTEUR,[F:CTR1]ETRFCY,[M:DIA]AVTCTRDAT,[F:CTR1]NATCON,[L]CTR,STAT) From SUBANM
#MIPEA - 2017-02-13- X3-11258- END
If STAT
 Call ERREUR (mess(4,10702,1)-COMPTEUR) From GESECRAN : # "Erreur sur compteur"
 Raz [L]CTR : Return
Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran TRTVARAVT) 19/04/2011 17:34:48 (DBA)
######################################################################################
Subprog AS_AVTCTRDAT(VALEUR)
Variable Date    VALEUR
If [L]VALEUR = [0/0/0] : [L]VALEUR = GMOIPAY : Endif
End

Subprog C_AVTCTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M:DIA]XITDAT
 #La date du nouveau contrat ne peut pas être antérieure à la date de sortie du contrat d'origine
 GMESSAGE=mess(114,10701,1)
 mkstat=2 : End
Endif
#MIPEA - 2017-02-13- X3-11258- START
If !clalev([F:HRCTR1]) : Local File EMPLOCTR [HRCTR1] : Endif
Look [F:HRCTR1]CTR0=[M]REFNUM;[M]CTRNUM;VALEUR
#If !clalev([F:CTR1]) : Local File EMPLOCTR [CTR1] : Endif
#Look [F:CTR1]CTR0=[M]REFNUM;[M]CTRNUM;VALEUR
#MIPEA - 2017-02-13- X3-11258- END
If fstat<=2
 #Il existe déjà un contrat à la date demandée
 GMESSAGE=mess(115,10701,1)
 mkstat=2 : End
Endif
End

Subprog AS_AVTCTRGRD(VALEUR)
Variable Char    VALEUR()
Call FIND_N4H(VALEUR)
#Call FIND_VAR(VALEUR,386,"095")
End

Subprog AS_AVTXITDAT(VALEUR)
Variable Date    VALEUR
If [L]VALEUR = [0/0/0] : [L]VALEUR = [M:DIA]AVTCTRDAT : Endif
End

Subprog AS_AVTXITGRD(VALEUR)
Variable Char    VALEUR()
Call FIND_VAR(VALEUR,359,"096")
End

Subprog FIND_VAR (PVALEUR,PNUMTAB, PNUMTDS)
Variable Char    PVALEUR()
Value Integer    PNUMTAB
Value Char    PNUMTDS ()

#JOJAC - 2018-03-20 - X3-82996 - START
If !clalev([F:ADI])   : Local File ATABDIV    [ADI]  : Endif
#JOJAC - 2018-03-20 - X3-82996 - END
Filter [F:ADI] Where NUMTAB=PNUMTAB & A1=PNUMTDS
Read[F:ADI]CODE Last
Filter [F:ADI]
If !fstat
 PVALEUR=[F:ADI]CODE
Else
 PVALEUR="VAR" :# au cas où...
Endif
End

Subprog FIND_N4H(PVALEUR)
Variable Char PVALEUR()
If clalev([F:HRCGD3])=0 : Local File HRCTRGRD [HRCGD3] : Endif
Filter [F:HRCGD3] Where COD=PVALEUR & LEG=GCURLEG & CODN4H="095"
Read [F:HRCGD3] Last
Filter [F:HRCGD3]
If !fstat
 PVALEUR = [F:ADI]COD
Else
 PVALEUR = "VAR"
Endif
End



######################################################################################

