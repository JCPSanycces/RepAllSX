#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "FIN"        : Gosub FIN
  When "DEBUT"      : Gosub DEBUT
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE

Endcase
Return
############################################################
$OUVRE
Local Integer IFCY, IITM, ICUL, ICUD, IITF
#
If clalev([F:FCY1]) = 0 Local File FACILITY   [FCY1] : IFCY = 1 : Endif
If clalev([F:ITM1]) = 0 Local File ITMMASTER  [ITM1] : IITM = 1 : Endif
If clalev([F:CUL1]) = 0 Local File CUNLISTE   [CUL1] : ICUL = 1 : Endif
If clalev([F:CUD1]) = 0 Local File CUNLISDET  [CUD1] : ICUD = 1 : Endif
If clalev([F:ITF1]) = 0 Local File ITMFACILIT [ITF1] : IITF = 1 : Endif
Return

$OUVRE_BOITE
#desactivation des rubriques ecrans suivant le contexte
Gosub FORMAT_INV_SNL1 From STKINV

Return

############################################################
$FIN
If IFCY = 1 : Close Local File [FCY1] : Endif
If IITM = 1 : Close Local File [ITM1] : Endif
If ICUL = 1 : Close Local File [CUL1] : Endif
If ICUD = 1 : Close Local File [CUD1] : Endif
If IITF = 1 : Close Local File [ITF1] : Endif
Return
############################################################
############################################################
$DEBUT
Local Char    WLIS(GLONVCR)
Local Char    WWRH(GLONWRH)
Local Integer WCUD
Local Char    WFILSUP

WFILSUP = "1=1"
If PARAM(3) <> ""
   WWRH = PARAM(3)
   WFILSUP = "[F:CUD1]WRH = WWRH"
Endif 

Raz [M:VCUN]
#
Read [FCY1]FCY0= PARAM(1)
If fstat 
  Raz [F:FCY1]
Endif
[M:VCUN] = [F:FCY1]
#
Read [ITM1]ITM0=PARAM(2)
If fstat
  Raz [F:ITM1]
Endif
[M:VCUN] = [F:ITM1]
#
nolign         = 0
[M:VCUN]BASPAG = 0
Raz WLIS

$NEXT_CUD
Raz WCUD
Filter [CUD1] Where STOFCY    = PARAM(1) &
&                   ITMREF    = PARAM(2) &
&                   CUNLISNUM > WLIS     &
&                   CUNLISSTA <  3       &
&                   evalue(WFILSUP)     
&             Order By Key CUD1    
For [CUD1]
    If nolign < dim([M:VCUN]CUNLISNUM)-1
       nolign         += 1
       [M:VCUN]BASPAG += 1 
       [M:VCUN] = [F:CUD1]
       # lecture cunliste
       If [F:CUL1]CUNSSSNUM <> [F:CUD1]CUNSSSNUM | [F:CUL1]CUNLISNUM <> [F:CUD1]CUNLISNUM
          Read [CUL1]CUL0=[F:CUD1]CUNSSSNUM;[F:CUD1]CUNLISNUM
          If fstat
             Raz [F:CUL1]   
          Endif
       Endif
       [M:VCUN] = [F:CUL1]
       WLIS     = [F:CUD1]CUNLISNUM
       WCUD     = 2
       Break
    Endif
Next
Filter [CUD1]  
If WCUD = 2
   Goto NEXT_CUD
Endif

#
Affzo [M:VCUN]
Return
############################################################

