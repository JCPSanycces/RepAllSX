#<AdxTL>@(#)12.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : MDJ
# LE          : 26/10/2010
# Moulinette pour l'objet RDE
# FQ68573
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM019: RDE object upgrade") From LECFIC
  Call EXE_UTIIMM019(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM019(APPLI)
 Value Char APPLI
  If clalev([F:ZAOL]) : Close Local File [ZAOL] : Endif
  Local File =APPLI+".AOBJLST" [ZAOL]
  Call ECR_TRACE("UTIIMM019: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM019
  Call ECR_TRACE("UTIIMM019: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM019

# ---------------------
  Trbegin [ZAOL]

  Read [F:ZAOL]AOL0="RDE"
  If fstat
   Call ECR_TRACE("Error : RDE object doesn't exist.",-1) From GESECRAN
   GOK=0 : Goto AB_UTIIMM019
  Endif
  Raz [F:ZAOL]
  [F:ZAOL]ABREV     = "RDE"
  [F:ZAOL]DELDEF    = 1
  [F:ZAOL]NBSEL     = 5

  [F:ZAOL]SELEXP(0) = "num$([F:RDE]REFOBJ)-mess([RDE]REFOBJ,3141,1)"
  [F:ZAOL]SELEXP(1) = "num$([F:RDE]DETAAS)-mess([F:RDE] DETAAS,3113,1)"
  [F:ZAOL]SELEXP(2) = ""
  [F:ZAOL]SELEXP(3) = ""
  [F:ZAOL]SELEXP(4) = "string$([F:RDE]CPY='',mess(36,7770,1))+string$([F:RDE]CPY<>'',[F:CPY]CPYSHO)"
  [F:ZAOL]SELEXP(5) = ""

  [F:ZAOL]SELFIC(0) = ""
  [F:ZAOL]SELFIC(1) = ""
  [F:ZAOL]SELFIC(2) = "ATEXTRA"
  [F:ZAOL]SELFIC(3) = "RUBASSDEF"
  [F:ZAOL]SELFIC(4) = ""
  [F:ZAOL]SELFIC(5) = ""

  [F:ZAOL]SELINT(0) = 1158
  [F:ZAOL]SELINT(1) = 34010
  [F:ZAOL]SELINT(2) = 615
  [F:ZAOL]SELINT(3) = 1343
  [F:ZAOL]SELINT(4) = 0
  [F:ZAOL]SELINT(5) = 0

  [F:ZAOL]SELLNG(2) = 30

  [F:ZAOL]SELTYP(0) = "A"
  [F:ZAOL]SELTYP(1) = "A"
  [F:ZAOL]SELTYP(2) = ""
  [F:ZAOL]SELTYP(3) = ""
  [F:ZAOL]SELTYP(4) = "A"

  [F:ZAOL]SELZON(0) = ""
  [F:ZAOL]SELZON(1) = ""
  [F:ZAOL]SELZON(2) = "TEXTE"
  [F:ZAOL]SELZON(3) = "CPY"
  [F:ZAOL]SELZON(4) = ""
  [F:ZAOL]SELZON(5) = ""

  Rewrite [F:ZAOL]

  If fstat
   GOK=0
   Call ECR_TRACE("   Error Rewrite [F:ZAOL] fstat="+num$(fstat),1) From GESECRAN
  Else
   Call ECR_TRACE("RDE object left list modified",0) From GESECRAN
  Endif

# ---------------------
  If !GOK Then
    Goto AB_UTIIMM019
  Else
    Commit
  Endif

  # Validation de l'objet
  Call VALFEN(APPLI,"RDE") From SUBAOB

Return

$AB_UTIIMM019
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM019(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM019(APPLI)
End
