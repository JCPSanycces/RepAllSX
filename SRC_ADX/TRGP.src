#<AdxTL>@(#)0.0.0.0 $Revision$ Properties for ELSTER file out
#################################################################################################################
#
#   Tax declaration Gemany - Data ouput
#
#   PURPOSE :    Exports or prints German VAT declaration or 1/11 pre-payment.
#   AUTHORS :    ANGRE
#   DATE    :
#   UPDATES :    2014-05-15 DNE - Output is now volume aware and can be downloaded (US #729)
#
#################################################################################################################



#** #############################################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#** #############################################################################################################

$ACTION
    Case ACTION
        When "BOUTON"        : Gosub BOUTON
        When "DEBUT"         : Gosub DEBUT
        When "FIN"           : Gosub FIN
    Endcase
Return


#** #############################################################################################
#* FIN is triggered after closing the window.
#*! #############################################################################################

$FIN
  # Delete temporary report data from AREPORTM table.
    If !clalev([ARM]): Local File AREPORTM[ARM] : Endif

    GOK = 1
    Call DEBTRANS From GLOCK
    Trbegin [ARM]
    Delete [ARM] Where (RPTCOD = "TRG" | RPTCOD = "TRGVAL1" | RPTCOD = "TRGVAL2" | RPTCOD = "TRGVAL3" | RPTCOD = "TRGVAL4") & USR = GUSER # and CREDAT = date$
    Commit
    Close Local File [ARM]
Return

$BOUTON
    Local Integer C
    Local Char VVALUE(255)
    Local Char VKEY(255)

    Case BOUT
        When "A" # Button "Print"
            If PARAM(2) = "ERR"
              Call WARNINGMESSAGE(0) From CNSTRGSTD
            Endif
            Call OPEN_REPORT( GFONCTION ) From CNSRSGSTDLIB
        When "B" # Button "File"
            #If PARAM(2) = "ERR"
              #Call WARNINGMESSAGE(1) From CNSTRGSTD
              #Return
            #Else
              Gosub WRITEFILE
            #Endif
    Endcase
Return

#** #############################################################################################################
#*
#* Sub chunk:  WRITEFILE
#*
#* Purpose:    Writes a CSV file using the Lib gervatcsvlib.src
#*
#** #############################################################################################################
# 2014-05-15 DNE MODIF BEGIN (US #729)
$WRITEFILE
    Local Char FILENAMETR(GDIMFIC)    : FILENAMETR = ""
    Local Char URL(GDIMFIC)           : URL = ""
    Local Char EXPORTNAME(GDIMFIC)    : EXPORTNAME = ""
    Local Char EXPORTFILE(GDIMFIC)    : EXPORTFILE = ""
    Local Integer STAT                : STAT = 0
    Local Integer DCLTYPE             : DCLTYPE = 0
    Local Integer FILEEXISTS
    Local Integer YESNO               : YESNO = 1           # ... Defaults to NO.

    Case PARAM(1)
        When "UST" : DCLTYPE = 1
        When "DAU" : DCLTYPE = 2
    Endcase

    FILENAMETR = func GERVATCSVLIB.GETFILENAME( DCLTYPE )

    If [M]TYPEXP = 1 : # Client
        EXPORTNAME = FILENAMETR
        EXPORTFILE = [M]DIRXMLDESC
        Call SET_FICNAM( FILENAMETR, EXPORTFILE, URL ) From ORDSYS
        FILENAMETR= EXPORTFILE
    Else # Server
        FILENAMETR = [M]DIRXMLDESC
&                  + func GDPDU1.GETDIRSEPARATOR()
&                  + FILENAMETR

        # Validate file path in server mode.
        Call EXISTE( FILENAMETR, FILEEXISTS ) From ORDSYS
        If FILEEXISTS = 1
            Call OUINONT( mess(260,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMETR, "\", "/" ), YESNO ) From GESECRAN # "Data already exists.\Do you want to overwrite it?"
            If YESNO = 1 # No --> Cancel.
                Return
            Endif
        Endif
    Endif

    #open the file and write masterdata to the file
    Call INITFILE( FILENAMETR, DCLTYPE, [M:TRGP]GRP, [M:TRGP]CPY,
&                  [M:TRGP]DATDEB, [M:TRGP]DATFIN, func CORRECTED(), 0, 0 ) From GERVATCSVLIB

    Case DCLTYPE
        When 1 : Gosub WRITETAXDECTOFILE # Write lines for VAT declaration
        When 2 : Gosub WRITEDAUTOFILE    # Write lines for 1/11 prepayment
    Endcase

    # Write lines for code 22, 26 and 29
    Gosub WRITEFLAGLINES

    # Close file
    Gosub CLOSEFILE From GERVATCSVLIB

    # If the file is to be downloaded to the client initiate the download.
    If [M]TYPEXP = 1 : # Client
        Call COPCLI( EXPORTFILE, EXPORTNAME, STAT ) From ORDSYS
        If STAT = 1
            Call ERREUR( mess(164,141,1) ) From GESECRAN # 'File not copied to the client workstation'
        Elsif STAT > 1
            Call ERREUR( mess(159,141,1) - "(" +num$( STAT ) + ")" ) From GESECRAN # 'File or directory do not exist'
        Endif
    Endif
Return
