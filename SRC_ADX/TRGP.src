#** #############################################################################################################
#*
#* Sub chunk:  WRITETAXDECTOFILE
#*
#* Purpose:    Writes specific lines for Tax declaration
#*
#** #############################################################################################################
$WRITETAXDECTOFILE
Local Decimal K83SUM
#Local Decimal K61SUM
Local Decimal ADVPAYMENT
Local Integer VALUETYPE


  For C = 0 To [M:TRG1]NBLIG-1
    VKEY = [M:TRG1]REPLINE(C)

    #additional calculation for linecode 83 and 61
    If find(VKEY, "81","86","36","80","89","69","47","53","74","85","65","79","93","96","98")
      K83SUM += [M:TRG1]AMTVAT(C)#abs([M:TRG1]AMTVAT(C))
    Elsif find (VKEY,"61","66","62","67","63","64","59")
       K83SUM -= [M:TRG1]AMTVAT(C)#abs([M:TRG1]AMTVAT(C))
    Endif
    #sum for linecode '61'
    #If find (VKEY,"61","89","93","98","96") Then
    #  K61SUM += abs([M:TRG1]AMTVAT(C))
    #Endif
    # prepayment of tax must be subtrated from taxsum
    If VKEY = "39"
      [L]ADVPAYMENT = [M:TRG1]AMTVAT(C)#abs([M:TRG1]AMTVAT(C))
    Endif

    #set value
    If [M:TRG1]AMTVATBASE(C) <> 0
      VVALUE = num$([M:TRG1]AMTVATBASE(C)*100)#amount in cent
      VALUETYPE = 2
    Elsif [M:TRG1]AMTVAT(C) <> 0
      VVALUE = num$([M:TRG1]AMTVAT(C)*100)#amount in cent
      VALUETYPE = 1
    Endif
    #line 61 must be printed at the end because of additional calculation
    #If VKEY <> "61"
      #write line to the file
      Call WRITEFILELINE(4,5,"0",VKEY, VVALUE, VALUETYPE) From GERVATCSVLIB
    #Endif
  Next
  #write additional lines for linecode 61 and linecode 83
  #Call WRITEFILELINE (4,5,"0","61", num$(K61SUM)) From GERVATCSVLIB
  Call WRITEFILELINE (4,5,"0","83", num$((K83SUM*100) - (ADVPAYMENT*100)),1) From GERVATCSVLIB
Return

#** #############################################################################################################
#*
#* Sub chunk:  WRITEDAUTOFILE
#*
#* Purpose:    Writes specific lines for 'Dauerfristverlängerung'
#*
#** #########################################################################################################
$WRITEDAUTOFILE
  If [M:TRGP]DFV <> 2
    Call WRITEFILELINE (4,5,"0","38", num$([M:PPG1]AMTPRT11*100),2) From GERVATCSVLIB
  Endif
Return

#** #############################################################################################################
#*
#* Sub chunk:  WRITEFLAGLINES
#*
#* Purpose:    Writes lines in the csv file for codes represented by a flag
#*
#** #############################################################################################################
$WRITEFLAGLINES
  If [M:TRGP]KNZ22 = 2 : Call WRITEFILELINE(4,5,"0","22", "1",0 ) From GERVATCSVLIB : Endif
# 2016-11-16 DNE INSERT BEGIN (x3-6002)
  If [M:TRGP]KNZ23 = 2 : Call WRITEFILELINE(4,5,"0","23", "1",0 ) From GERVATCSVLIB : Endif
# 2016-11-16 DNE INSERT END
  If [M:TRGP]KNZ26 = 2 : Call WRITEFILELINE(4,5,"0","26", "1",0 ) From GERVATCSVLIB : Endif
  If [M:TRGP]KNZ29 = 2 : Call WRITEFILELINE(4,5,"0","29", "1",0 ) From GERVATCSVLIB : Endif
Return

#** #####################################################################################
#*
#* Sub chunk:  DEBUT
#*
#* Purpose:    Handler before entering the window
#*             Reads data from the parent screen and prefills the property window.
#*
#*! #####################################################################################

$DEBUT
  Gosub SETSCREENFIELDS
Return

#** #############################################################################################################
#*
#* Function that returns the file directory for the CSV file
#* This directory is declared as parameter VATFILPAT
#*
#* @return  Char Result       file directory
#*! #############################################################################################################
Funprog GETDIR()
  Local Char RESULT(255)
  Local Char COMPORGRP(255)

  [L]COMPORGRP = [M:TRGP]GRP
  If [L]COMPORGRP = "" : [L]COMPORGRP = [M:TRGP]CPY : Endif
  Call PARAM(COMPORGRP,"VATFILPAT",RESULT) From ADOVAL
End RESULT

#** #############################################################################################################
#*
#* Function that determines if the Ustva or the 1/11 prepaymetn is corrected or not
#*
#* @return  Integer Result       1 -> corrected; 0 -> not corrected
#*! #############################################################################################################
Funprog CORRECTED()
  Local Integer RESULT
  If [M:TRGP]KNZ10 = 2 : RESULT = 1 : Else : RESULT = 0 : Endif
End RESULT

#** #############################################################################################################
#*
#* Function that checks if the given Path exists or not
#*
#* @param Value Char PATH        Path to check
#* @return  Integer Result       1 -> exists; 2 -> exists not
#*! #############################################################################################################
Funprog CHECKFILEPATH(PATH)
Value Char PATH
  Local Integer EXISTS
  Local Integer RESULT : RESULT = 1

  Call EXISTE( PATH, EXISTS ) From ORDSYS
  If !EXISTS
    Call ERREURT( mess(111,148,1), 1 ) From GESECRAN # 'Non-existent destination directory'
    RESULT = 0
  Endif
End RESULT


#** #############################################################################################################
#*
#* Subprog:  SETSCREENFIELDS
#* enable or disable screenfields in dependency if the screen is opened for Ustva or 1/11 prepayment
#*
#*
#*! #############################################################################################################
$SETSCREENFIELDS
  Local Char COMPANY(GLONCPY)

  #When opened from VAT declaration
  [M:TRGP] = [M:TRG0]
  [M]TYPEXP = 1
  Call AM_TYPEXP( [M]TYPEXP )
  Affzo [M:TRGP] 1 - 99
  If PARAM(1) = "UST" Then
    #Set the "display only" parameteres from the main window
    Diszo [M:TRGP]DFV
  #When opened from Dauerfristverlängerung
  Elsif PARAM(1) = "DAU" Then
    Diszo [M:TRGP]KNZ22
  Endif

# 2016-12-02 DNE INSERT BEGIN
  # Make sure that box 23 is only available from year 2017.
  If year( [M:TRGP]DATDEB ) < 2017
    Diszo [M:TRGP]KNZ23
  Endif
# 2016-12-02 DNE INSERT END
Return



#** #####################################################################################
#*
#* Sub chunk:  AM_DFV
#*
#* Purpose:    Handler is called after the modification of the DFV checkbox
#*             Enable or disable fields in dependency of the status of the checkbox DFV
#*
#*! #####################################################################################
Subprog AM_DFV(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2
    [M:TRGP]KNZ10 = 1 : [M:TRGP]KNZ26 = 1 : [M:TRGP]KNZ29 = 1
    Affzo [M:TRGP]KNZ10 :  Affzo [M:TRGP]KNZ26 :  Affzo [M:TRGP]KNZ29
    Diszo [M:TRGP]KNZ10 : Diszo [M:TRGP]KNZ26 : Diszo [M:TRGP]KNZ29
  Else
    Actzo [M:TRGP]KNZ10 :  Actzo [M:TRGP]KNZ26 :  Actzo [M:TRGP]KNZ29
  Endif
End


#################################################################################################################
#
#    Event: While changing field VOLFIL
#    Does:  Checks if the volume/directory exists and that it is a directory.
#
#################################################################################################################

Subprog C_VOLFIL(VALEUR)
Variable Char VALEUR()

    Gosub ENUM_VOLFIL_TYPE From ASYRSTO
    mkstat = func ASYRSTO.CTL_VOLFIL( [M]TYPEXP, VALEUR, [M]DIRXMLDESC, E_TYPE_FOLDER, GMESSAGE )
End



#################################################################################################################
#
#    Event: After having changed the TYPEXP field
#    Does:  Updates fields after modification of the export to client/server selection
#
#################################################################################################################

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

    If VALEUR = 1
        Raz   [M]VOLFIL
        Affzo [M]VOLFIL
        Grizo [M]VOLFIL
    Else
         Actzo [M]VOLFIL
         [M]VOLFIL = func AFNC.PARAM( "VATFILPAT", [M]CPY )
         Affzo [M]VOLFIL
    Endif
End



