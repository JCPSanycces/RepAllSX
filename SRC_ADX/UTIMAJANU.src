#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour nouveaux champs de la table ANNUAIRE
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update new fields ANNUAIRE file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

#-------------------#
$MAJ

Local Integer I , VALMOD(20)

If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

Local File =DOSSIER+".ADOVAL"    [ADW]
Local File =DOSSIER+".ANNUAIRE"  [ANU]
Local File =DOSSIER+".ADOPAR"    [ADP]
If dim([F:ANU]ENAFLG)<0
 Close Local File
 Return
Endif

Local Char ANU(50)
Local Integer ENR

ANU = ""
Read [ADW]ADW0 = "";"";"SSODIRECT"
If !fstat & [F:ADW]VALEUR<>""
 ANU = [F:ADW]VALEUR
Endif

# Mise à jour de la table ANNUAIRE
Call ECR_TRACE(mess(81,125,1)-"ANNUAIRE:"-time$,0) From GESECRAN

Trbegin [ANU]

 For [ANU]ANU0
  ENR = 0
  If ANU<>""
   If [F:ANU]COD=ANU
    [F:ANU]ENAFLG = 2
   Else
    [F:ANU]ENAFLG = 1
   Endif
   ENR = 1
  Elsif [F:ANU]ENAFLG=0
   [F:ANU]ENAFLG = 1
   ENR = 1
  Endif
  If ENR
   Rewrite [ANU]
   If fstat
    Call ERREUR("ANNUAIRE"-[F:ANU]CODE,2) From DOSDIC
   Endif
  Endif
 Next ANU

 If ANU<>""
  Read [ADP]ADP1="SSODIRECT"
  If !fstat
   Delete [ADP] Curr
   Delete [ADW] Where PARAM="SSODIRECT"
  Endif
 Endif

Commit

Close Local File

If ANU<>""
 Call ECR_TRACE("Default active directory :"-ANU,0) From GESECRAN
Endif

If DOSSIER<>GDOSX3

 # Onglet Sélection

 Call MAJ_SEL(DOSSIER,"ANU") From PATCHAOB

 # Validation de l'objet ANU

# Call VALID_TRT(DOSSIER,0,"","","","","","","","","ANU","ANU","","","","","","",VALMOD) From VALDICO
 Call VALID_TRT(DOSSIER,0,"","","","","","","","","ANU","ANU","","","","","","","","","","",VALMOD) From VALDICO
 Call VALFEN(DOSSIER,"ANU") From SUBAOB

Endif

Return
