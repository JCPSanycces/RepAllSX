#<AdxTL>@(#)9.0.0.0 $Revision$
########################################################################
# SUBPSOW : Visualisation des commande d'une DA           MBT 09/01/04 #
# -------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par l'action       #
#   VISUPOHPSH et ne sert qu'à gérer le masque écran "PSOW [PSOW]".    #
########################################################################


$ACTION
Case ACTION
 When "AB1_NBCDE" : Gosub AB1_NBCDE
Endcase
Return


Subprog IB_NBCDE
#-------------------------------------------------------#
#      Initialisation des boutons sur champ NBLIG       #
# ----------------------------------------------------- #
# - Bouton 1 : Action GOBJETC0  Tunnel vers commandes   #
#-------------------------------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4
If nolign>[M:PSOW]NBCDE  nolign=[M:PSOW]NBCDE : Endif
If [M:PSOW]POHNUM(nolign-1)<>""
  GBOUT1=mess(191,198,1)-[M:PSOW]POHNUM(nolign-1) : # Commande
Else
  Raz GBOUT1
Endif
End


$AB1_NBCDE
#------------------------------------------------#
# Avant exécution du bouton Tunnel sur commandes #
#------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
If [M:PSOW]POHTYP(NOL)=2
  WOBJET="POD"
  WCLE1=num$([M:PSOW]POPLIN(NOL))
  WCLE2=[M:PSOW]POHNUM(NOL)
Else
  WOBJET="POH"
  WCLE1=[M:PSOW]POHNUM(NOL)
  WCLE2=""
Endif
Return
