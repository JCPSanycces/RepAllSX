#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque RCPLBE2

########################################################################
# Impression des étiquettes de stocks / contenant suite à entrée       #
# -------------------------------------------------------------------- #
# Fenêtre : IRCBLBE1          Etiquette stock                          #
# Fenêtre : IRCBLBE2          Etiquette contenant                      #
# Fenêtre : IRCBLBE3          Etiquette stock et contenant             #
# -------------------------------------------------------------------- #
########################################################################

$ACTION
Case ACTION
 When "DEBUT"   : Gosub DEBUT   From SUBRCPLBEA
 When "OUVRE"   : Gosub OUVRE   From SUBRCPLBEA
 When "SETBOUT" : Gosub SETBOUT From SUBRCPLBEA
 When "BOUTON"  : Gosub BOUTON  From SUBRCPLBEA
 When Default
Endcase
Return

######################################################################################
## Action écran RCPLBE1    etiquette stock
######################################################################################

Subprog IB_NBLIG1
GBOUT4 = mess(2,1,1) : # Oui
GBOUT5 = mess(1,1,1) : # Non
End

Subprog AS_NBLIG1
Raz GBOUT2
Raz GBOUT3
Case [M:RCB0]VCRTYP
    When 10      :
        GBOUT2 = mess(166,198,1)              # ordre de fabrication
    When Default :
        GBOUT3 = mess(16,198,1)               # mouvements
        [M:RCB0]FLT = " [F:STJ]VCRNUM='"+[M:RCB0]VCRNUMSTR+"'"
&                    +"&[F:STJ]UPDCOD="+num$([M:RCB1]UPDCOD(nolign-1))
&                    +"&[F:STJ]MVTSEQ="+num$([M:RCB1]MVTSEQ(nolign-1))
Endcase
End

Subprog B4_NBLIG1
Local Integer I
For I=1 To [M:RCB1]NBLIG1
    [M:RCB1]TRT1(I-1) = 2
Next I
Affzo [M:RCB1]TRT1
End

Subprog B5_NBLIG1
Local Integer I
For I=1 To [M:RCB1]NBLIG1
    [M:RCB1]TRT1(I-1) = 1
Next I
Affzo [M:RCB1]TRT1
End


Subprog C_LBEFMT1(VALEUR)
Variable Char    VALEUR()
Local Integer STAT
Call CONT_RPTCOD(VALEUR,GMESSAGE,STAT) From AIMP1

End

Subprog AM_LBEFMT1(VALEUR)
Variable Char    VALEUR()
Local Char TBPAR(15)(1..50),TBVAL(30)(1..50)
Local Char LPRT(GLONAIM)
# Recherche de l'imprimante par défaut
Call AIMDEF(LPRT,VALEUR,TBPAR,TBVAL) From IMPRIME
[M:RCB1]LBEFMT1(nolign-1)=VALEUR
If LPRT<>""
    [M:RCB1]PRT1(nolign-1) = LPRT
Endif
Call C_PRT1([M:RCB1]PRT1(nolign-1))
If mkstat
   Raz GMESSAGE, GERR, mkstat
   Raz [M:RCB1]PRT1(nolign-1)
Elsif  [M:RCB1]PRT1(nolign-1)<>""
       Diszo [M:RCB1]SERIMP1(nolign-1), DEFIMP1(nolign-1)
Endif
Affzo [M:RCB1]PRT1(nolign-1), SERIMP1(nolign-1), DEFIMP1(nolign-1)
End

Subprog B2_LBEFMT1(VALEUR)
Variable Char    VALEUR()
Local Integer I
Call C_LBEFMT1(VALEUR)
If !mkstat
   For I=nolign To [M:RCB1]NBLIG1-1
       If [M:RCB1]TRT1   (I) = 2
          [M:RCB1]LBEFMT1(I) = VALEUR
          [M:RCB1]PRT1   (I) = [M:RCB1]PRT1(nolign-1)
       Endif
   Next
   Affzo [M:RCB1]LBEFMT1,PRT1
Endif
End

Subprog C_PRT1(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
    Call AIMCONT(VALEUR,[M:RCB1]LBEFMT1(nolign-1),GBATCH) From IMPRIME
    If mkstat
        Raz [M:RCB1]SERIMP1(nolign-1), DEFIMP1(nolign-1)
        End
    Endif
    [M:RCB1]SERIMP1(nolign-1)    = [F:AIM]PRTSRV
    [M:RCB1]DEFIMP1(nolign-1)    = [F:AIM]PRTNAM
Else
    Raz [M:RCB1]SERIMP1(nolign-1), [M:RCB1]DEFIMP1(nolign-1)
Endif
End

Subprog AM_PRT1(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Diszo [M:RCB1]SERIMP1(nolign-1), DEFIMP1(nolign-1)
Else
    Actzo [M:RCB1]SERIMP1(nolign-1), DEFIMP1(nolign-1)
Endif
End

######################################################################################
## Action écran RCPLBE2    etiquette contenant
######################################################################################
Subprog IB_NBLIG2
GBOUT4 = mess(2,1,1) : # Oui
GBOUT5 = mess(1,1,1) : # Non
End

Subprog B4_NBLIG2
Local Integer I
For I=1 To [M:RCB2]NBLIG2
    [M:RCB2]TRT2(I-1) = 2
Next I
Affzo [M:RCB2]TRT2
End

Subprog B5_NBLIG2
Local Integer I
For I=1 To [M:RCB2]NBLIG2
    [M:RCB2]TRT2(I-1) = 1
Next I
Affzo [M:RCB2]TRT2
End

Subprog C_LBEFMT2(VALEUR)
Variable Char    VALEUR()
Local Integer STAT
Call CONT_RPTCOD(VALEUR,GMESSAGE,STAT) From AIMP1
End

Subprog AM_LBEFMT2(VALEUR)
Variable Char    VALEUR()
Local Char TBPAR(15)(1..50),TBVAL(30)(1..50)
Local Char LPRT(GLONAIM)
# Recherche de l'imprimante par défaut
Call AIMDEF(LPRT,VALEUR,TBPAR,TBVAL) From IMPRIME
[M:RCB2]LBEFMT2(nolign-1)=VALEUR
If LPRT<>""
    [M:RCB2]PRT2(nolign-1) = LPRT
Endif
Call C_PRT2([M:RCB2]PRT2(nolign-1))
If mkstat
   Raz GMESSAGE, GERR, mkstat
   Raz [M:RCB2]PRT2(nolign-1)
Elsif  [M:RCB2]PRT2(nolign-1)<>""
       Diszo [M:RCB2]SERIMP2(nolign-1), DEFIMP2(nolign-1)
Endif
Affzo [M:RCB2]PRT2(nolign-1), SERIMP2(nolign-1), DEFIMP2(nolign-1)
End

Subprog B2_LBEFMT2(VALEUR)
Variable Char    VALEUR()
Call C_LBEFMT2(VALEUR)
If !mkstat
   For I=nolign To [M:RCB2]NBLIG2-1
       If [M:RCB2]TRT2   (I) = 2
          [M:RCB2]LBEFMT2(I) = VALEUR
          [M:RCB2]PRT2   (I) = [M:RCB2]PRT2(nolign-1)
       Endif
   Next
   Affzo [M:RCB2]LBEFMT2,PRT2
Endif
End
Subprog C_PRT2(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
    Call AIMCONT(VALEUR,[M:RCB2]LBEFMT2(nolign-1),GBATCH) From IMPRIME
    If mkstat
        Raz [M:RCB2]SERIMP2(nolign-1), DEFIMP2(nolign-1)
        End
    Endif
    [M:RCB2]SERIMP2(nolign-1)    = [F:AIM]PRTSRV
    [M:RCB2]DEFIMP2(nolign-1)    = [F:AIM]PRTNAM
Else
    Raz [M:RCB2]SERIMP2(nolign-1), [M:RCB2]DEFIMP2(nolign-1)
Endif
End
Subprog AM_PRT2(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Diszo [M:RCB2]SERIMP2(nolign-1), DEFIMP2(nolign-1)
Else
    Actzo [M:RCB1]SERIMP2(nolign-1), DEFIMP2(nolign-1)
Endif
End

