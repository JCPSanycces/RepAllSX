#<AdxTL>@(#)5.0.0.0 $Revision$
Call OBJET ("SLC",GBIDC1,GBIDC2) From GOBJET
End
#######################################################################
# SUBSLC : Transactions de saisie des commandes          EB  03/12/97 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SLC]SALTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                                                                     #
# Génération de 2 écrans de saisie à partir des écrans de base SOH1   #
#                                                              SOH2   #
#                                                              SOH3   #
#                                                              SOH4   #
# Nom des écrans générés : WKxyyyz                                    #
#                            x = type de la transaction (STRTYP)      #
#                                1 -    devis                         #
#                                2 -    commandes                     #
#                                3 -    commandes ouvertes            #
#                                                                     #
#                          yyy = no de la transaction   (STRNUM)      #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                1 et 2 devis                         #
#                                1 et 2 cde ouverte                   #
#                                1 2 3 et 4 commande                  #
#######################################################################
# Issue 118906 - 20161006 by LD : Display bloc Payment/Last documents

$ACTION

Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Gosub OUVRE From SUBSLX
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=2
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M]STRTYP = 2
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "LIENS"       : Gosub LIENS
                      Gosub TRT_DIETRS From SUBDST : Gosub LIENS From SUBSLX
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
                      Gosub ANNULE From SUBSLX
 When "APRES_MODIF" : Gosub APRES_MODIF From SUBSLX
 When "INICRE"      : Gosub INICRE From SUBSLX
 When "INIMOD"      : Gosub INICRE From SUBSLX
 When Default
Endcase
Return

#-------------------------------------------------------#
#                                                       #
#-------------------------------------------------------#
$OUVRE
Local Char APPLI
APPLI=nomap
Return

#-------------------------------------------------------#
# Ne traiter que les transactions de type commande      #
#-------------------------------------------------------#
$FILTRE
FILTSUP="STRTYP=2"
Return

#---------------------------------#
# Désactivation des boutons       #
#---------------------------------#
$SETBOUT
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur les boutons         #
#-------------------------------------#
$EXEBOUT
Case BOUT
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#-------------------------------------------------------------#
# Initialisation des codes de saisie des sections analytiques #
#-------------------------------------------------------------#
$LIENS
#If dim([M]NBAXE)>0
#  If [M:SLC1]NBAXE=0 : [M:SLC1]NBAXE=GOPTCANA : Endif
#Endif
Return

#-------------------------------------------------------------#
# Initialisation des codes de saisie des sections analytiques #
#-------------------------------------------------------------#
$RAZCRE
[M:SLC0]ENAFLG = 2
#If dim([M]NBAXE)>0
#   If [M:SLC1]NBAXE=0 : [M:SLC1]NBAXE=GOPTCANA : Endif
#   For indice=0 To GOPTCANA-1
#       If CCECODD(indice) = 0 : CCECODD(indice) = 1 : Endif
#   Next indice
#   Affzo [M:SLC1] 30
#Endif
Return

#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If APPLI=""     APPLI=nomap      : Endif
Local Char    MFROM(GLONAMK)
Local Char    MTO(GLONAMK)
Local Integer TBLOC(15)
Local Char    TZONE(GLONAVA)(200)
Local Integer TMOD(200)
Local Char    TINT(1)(200)
Local Char    TTAB(1)(1)
Local Char    TFLD(1)(1)
Local Integer OPT1, OPT2, OPT3, RETOUR
Local Integer IZON, I, FLAG
# Local Char    BOUTONS(10)(4), TEXTE(40), LISTE(3), REPONS(1)

MFROM="SOH1"
MTO="WK"+num$([M:SLC0]STRTYP)+[M:SLC0]STRNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If   ACTION <> "ANNULE"
     #---- client facture
     If   [M:SLC2]BPCINVCOD > 1 TZONE(IZON)="BPCINV"
                                TMOD(IZON) =[M:SLC2]BPCINVCOD
                                IZON+=1
                                TZONE(IZON)="BPINAM"
                                TMOD(IZON) =[M:SLC2]BPCINVCOD
                                IZON+=1
     Endif
     #---- tiers payeur
     If   [M:SLC2]BPCPYRCOD > 1 TZONE(IZON)="BPCPYR"
                                TMOD(IZON) =[M:SLC2]BPCPYRCOD
                                IZON+=1
     Endif
     #---- client groupe
     If   [M:SLC2]BPCGRUCOD > 1 TZONE(IZON)="BPCGRU"
                                TMOD(IZON) =[M:SLC2]BPCGRUCOD
                                IZON+=1
     Endif
     #---- adresse livraison
     If   [M:SLC2]BPAADDCOD > 1 TZONE(IZON)="BPAADD"
                                TMOD(IZON) =[M:SLC2]BPAADDCOD
                                IZON+=1
                                TZONE(IZON)="BPDNAM"
                                TMOD(IZON) =[M:SLC2]BPAADDCOD
                                IZON+=1
     Endif
     #---- affaire
     If   [M:SLC2]PJTCOD > 1    TZONE(IZON)="PJT"
                                TMOD(IZON) =[M:SLC2]PJTCOD
                                IZON+=1
     Endif
     #---- représentant
     If   [M:SLC2]REPCOD > 1    TZONE(IZON)="REP"
                                TMOD(IZON) =[M:SLC2]REPCOD
                                IZON+=1
     Endif
     #---- date retour prêt
     If   [M:SLC2]LNDRTNCOD > 1 TZONE(IZON)="LNDRTNDAT"
                                TMOD(IZON) =[M:SLC2]LNDRTNCOD
                                IZON+=1
     Endif
     #---- motif d'annulation
     If   find([M:SLC5]CCLRENCOD,0,1)   TZONE(IZON)="CCLREN"
                                        TMOD(IZON) =3
                                        IZON+=1
                                        TZONE(IZON)="CCLDAT"
                                        TMOD(IZON) =3
                                        IZON+=1
     Endif
     #---- régime de taxe
     If   [M:SLC2]VACBPRCOD > 1 TZONE(IZON)="VACBPR"
                                TMOD(IZON) =[M:SLC2]VACBPRCOD
                                IZON+=1
     Endif
     #LTA.sn entity/use code for local taxing
     If func AFNC.ACTIV("LTA") and [M:SLC2]SSTENTCOD > 1
                                TZONE(IZON)="SSTENTCOD"
                                TMOD(IZON) =[M:SLC2]SSTENTCOD
                                IZON+=1
     Endif
     #LTA.en
     #---- devise
     If   [M:SLC2]CURCOD    > 1 TZONE(IZON)="CUR"
                                TMOD(IZON) =[M:SLC2]CURCOD
                                IZON+=1
     Endif
     #---- prix HT/TTC
     If   [M:SLC2]PRITYPCOD > 1 TZONE(IZON)="PRITYP"
                                TMOD(IZON) =[M:SLC2]PRITYPCOD
                                IZON+=1
     Endif
     #---- état commande (ARC imprimé, Etat commande, allocation, livraison, facture, crédit)
     If   [M:SLC5]STACOD = 1 TZONE(IZON)="OCNPRN"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="ORDSTA"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="ALLSTA"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="DLVSTA"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="INVSTA"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="CDTSTA"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="APPFLG"
                             TMOD(IZON) =3
                             IZON+=1
                                TZONE(IZON)="CDTBTN"
                                TMOD(IZON) =3
                                 IZON+=1
     Endif
     #---- Hold status (hold status, hold button, hold code) order holds
     If   [M:SLC5]HLDCOD < 2 TZONE(IZON)="HLDSTA"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="HLDBTN"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="HLDCOD"
                             TMOD(IZON) =3
                             IZON+=1
     Endif
 #---- credit release V7
     If   [M:SLC5]CDTBTNCOD < 2 TZONE(IZON)="CDTBTN"
                                TMOD(IZON) =3
                             IZON+=1
     Endif

     #---- inter-sites
     If   [M:SLC5]BETFCYCOD = 1 TZONE(IZON)="BETFCY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- inter-sociétés
     If   [M:SLC5]BETCPYCOD = 1 TZONE(IZON)="BETCPY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

     #---- visualisation du masque généré
     OPT1 = 2
#     If ACTION<>"MASSE"
#        BOUTONS(1)=mess(2,1,1)    : # Oui
#        BOUTONS(2)=mess(1,1,1)    : # Non
#        BOUTONS(3)=mess(71,198,1) : # Abandon
#        TEXTE= " "+mess(1,196,1)  : LISTE="ONA" : REPONS="N"
#        Call CHOIXM(BOUTONS,TEXTE,LISTE,REPONS) From TRTX3
#        If REPONS="A" GOK=0  : Return : Endif
#        If REPONS="O" OPT2=1 : Endif
#     Endif
     #---- suppression du masque
Else OPT1=9
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif

#------------------------- écran SOH2 -------------------------#
MFROM="SOH2"
MTO="WK"+num$([M:SLC0]STRTYP)+[M:SLC0]STRNUM+"2"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
     #---- site expédition
     If   [M:SLC2]STOFCYCOD > 1 TZONE(IZON)="STOFCY"
                                TMOD(IZON) =[M:SLC2]STOFCYCOD
                                IZON+=1
     Endif
     #---- priorité livraison
     If   [M:SLC2]DLVPIOCOD > 1 TZONE(IZON)="DLVPIO"
                                TMOD(IZON) =[M:SLC2]DLVPIOCOD
                                IZON+=1
     Endif
     #---- date liv demandée
     If   [M:SLC2]DEMDLVCOD > 1 TZONE(IZON)="DEMDLVDAT"
                                TMOD(IZON) =[M:SLC2]DEMDLVCOD
                                IZON+=1
     Endif
     #---- délai livraison
     If   [M:SLC2]DAYLTICOD > 1 TZONE(IZON)="DAYLTI"
                                TMOD(IZON) =[M:SLC2]DAYLTICOD
                                IZON+=1
     Endif
     #---- date expédition
     If   [M:SLC2]SHIDATCOD > 1 TZONE(IZON)="SHIDAT"
                                TMOD(IZON) =[M:SLC2]SHIDATCOD
                                IZON+=1
     Endif
     #---- n° tournée
     If   [M:SLC2]DRNCOD > 1    TZONE(IZON)="DRN"
                                TMOD(IZON) =[M:SLC2]DRNCOD
                                IZON+=1
     Endif
     #---- mode livraison
     If   [M:SLC2]MDLCOD > 1    TZONE(IZON)="MDL"
                                TMOD(IZON) =[M:SLC2]MDLCOD
                                IZON+=1
     Endif
     #---- transport
     If   [M:SLC2]BPTNUMCOD > 1 TZONE(IZON)="BPTNUM"
                                TMOD(IZON) =[M:SLC2]BPTNUMCOD
                                IZON+=1
     Endif
     #---- CPO 65018
     #---- Incoterm et ville Incoterm
     If   [M:SLC2]EECICTCOD > 1 TZONE(IZON)="EECICT"
                                TMOD(IZON) =[M:SLC2]EECICTCOD
                                IZON+=1
                                TZONE(IZON)="ICTCTY"
                                TMOD(IZON) =[M:SLC2]EECICTCOD
                                IZON+=1
     Endif
     #---- dernière livraison
     If   [M:SLC5]LASDLVCOD = 1 TZONE(IZON)="LASDLVNUM"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="LASDLVDAT"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     # 75115 : V7 : Extension of Digital Signature : New field delivery type
     #---- Type de livraison
     If   [M:SLC5]SDHTYPCOD = 1 TZONE(IZON)="SDHTYP"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     # 75115
     #---- autorisation solde cde
     If   [M:SLC2]ORDCLECOD > 1 TZONE(IZON)="ORDCLE"
                                TMOD(IZON) =[M:SLC2]ORDCLECOD
                                IZON+=1
     Endif
     #---- 1 cde par livraison
     If   [M:SLC2]ODLCOD > 1    TZONE(IZON)="ODL"
                                TMOD(IZON) =[M:SLC2]ODLCOD
                                IZON+=1
     Endif
     #---- déblocage
     If   [M:SLC2]UNLCOD    > 1 TZONE(IZON)="UNL"
                                TMOD(IZON) =[M:SLC2]UNLCOD
                                IZON+=1
     Endif
     #---- livraison partielle
     If   [M:SLC2]DMECOD > 1    TZONE(IZON)="DME"
                                TMOD(IZON) =[M:SLC2]DMECOD
                                IZON+=1
     Endif
     #---- type allocation
     If   [M:SLC2]ALLTYPCOD > 1 TZONE(IZON)="ALLTYP"
                                TMOD(IZON) =[M:SLC2]ALLTYPCOD
                                IZON+=1
     Endif

     # 106776 EDI fields
     If func AFNC.ACTIV("EDIX3")
       If [M:SLC2]DEMDLVHCOD > 1    #SAM 113672
         TZONE(IZON)="DEMDLVHOU"
         TMOD(IZON) =[M:SLC2]DEMDLVHCOD
         IZON+=1
       Endif
     Endif

     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif

#------------------------- écran SOH3 -------------------------#
MFROM="SOH3"
MTO="WK"+num$([M:SLC0]STRTYP)+[M:SLC0]STRNUM+"3"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
     #---- mode facturation
     If   [M:SLC2]IMECOD    > 1 TZONE(IZON)="IME"
                                TMOD(IZON) =[M:SLC2]IMECOD
                                IZON+=1
     Endif
     # 107890 : Scheduled invoices : (LD:08/12/15)
     #---- invoicing condition
     If   [M:SLC2]INVCNDCOD > 1 TZONE(IZON)="INVCND"
                                TMOD(IZON) =[M:SLC2]INVCNDCOD
                                IZON+=1
                                TZONE(IZON)="VCRINVCNDDAT"
                                TMOD(IZON) =[M:SLC2]INVCNDCOD
                                IZON+=1
     Endif
     # 107890 : Scheduled invoices : (LD:08/12/15)
     #---- condition de paiement
     If   [M:SLC2]PTECOD    > 1 TZONE(IZON)="PTE"
                                TMOD(IZON) =[M:SLC2]PTECOD
                                IZON+=1
     Endif
     #---- escompte
     If   [M:SLC2]DEPCOD    > 1 TZONE(IZON)="DEP"
                                TMOD(IZON) =[M:SLC2]DEPCOD
                                IZON+=1
     Endif
     #---- no de devis
     If   [M:SLC5]SQHNUMCOD = 1 TZONE(IZON)="SQHNUM"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- no facture proforma
     If   [M:SLC5]PRFNUMCOD = 1 TZONE(IZON)="PRFNUM"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- dernière facture
     If   [M:SLC5]LASINVCOD = 1 TZONE(IZON)="LASINVNUM"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="LASINVDAT"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
#     #---- Sections analytiques d'entête
#     #------- Test si toutes les sections d'entête sont affichées --------#
#     If dim([M:SLC1]CCECOD)>0
#         If [M:SLC1]CCECOD=2    TZONE(IZON)="CCE"
#                                TMOD(IZON)=2
#                                TBLOC(2)=2
#                                IZON+=1
#         Endif
#     Endif
#     #------- Test si toutes les sections sont invisibles --------#
#     If (dim([M:SLC1]CCECOD)>0 & [M:SLC1]CCECOD=3) | dim([M:SLC1]CCECOD)<1
#         TBLOC(2)=1
#     Endif
     #----- Test si les sections d'entête sont affichées -----#
     If dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=2
        TZONE(IZON)="CCE"
        TMOD(IZON)=2
        # Issue 118906
        #TBLOC(2)=2
        #TBLOC(3)=2 # X3-76038 error message Mandatory field for field Product
        # End issue 118906
        IZON+=1
     Endif
     #----- Test si les sections d'entête sont invisibles -----#
     If (dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=3) | dim([M:DST]HEACCECOD)<1
        # Issue 118906
        #TBLOC(2)=1
        TBLOC(3)=1
        # End issue 118906
     Endif

     #---- Eléments de facturation
     #------- Test si tous les éléments de facturation sont affichées --------#
     If   [M:SLC1]INVDTACOD=2  TZONE(IZON)="INVDTAAMT"
                               TMOD(IZON)=2
                               # Issue 118906
                               #TBLOC(3)=2
                               #TBLOC(4)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                               # End issue 118906
                               IZON+=1
                               TZONE(IZON)="INVDTATYP"
                               TMOD(IZON) =2
                               # Issue 118906
                               #TBLOC(3)=2
                               #TBLOC(4)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                               # End issue 118906
                               IZON+=1
                               TZONE(IZON)="SFISSTCOD" # 101380.n
                               TMOD(IZON) =2           # 101380.n
                               # Issue 118906
                               #TBLOC(3)=2              # 101380.n
                               #TBLOC(4)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                               # End issue 118906
                               IZON+=1                 # 101380.n
     Endif
     #------- Test si tous les éléments de facturation sont invisibles --------#
     # Issue 118906
     #If   [M:SLC1]INVDTACOD=3  TBLOC(3)=1 Endif
     If   [M:SLC1]INVDTACOD=3  TBLOC(4)=1 Endif
     # End issue 118906

     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif

#------------------------- écran SOH4 -------------------------#
Local Char    ZT : # nom de zone dans table transaction
Local Char    ZM : # nom de zone dans le masque
Local Integer ZI : # pour les zones indicées
MFROM="SOH4"
MTO="WK"+num$([M:SLC0]STRTYP)+[M:SLC0]STRNUM+"4"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
     #---- désignation traduite de l'article
     If   [M:SLC3]ITMDESCOD > 1 TZONE(IZON)="ITMDES"
                                TMOD(IZON) =[M:SLC3]ITMDESCOD
                                IZON+=1
     Endif
     If   [M:SLC3]ITMDESCOD = 1 | [M:SLC3]ITMDESCOD = 2
        ZT="ITMDESSCR" : ZM="ITMDES" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- désignation standard de l'article
     If   [M:SLC3]ITMDES1COD> 1 TZONE(IZON)="ITMDES1"
                                TMOD(IZON) =[M:SLC3]ITMDES1COD
                                IZON+=1
     Endif
     If   [M:SLC3]ITMDES1COD = 1 | [M:SLC3]ITMDES1COD = 2
        ZT="ITMDES1SCR" : ZM="ITMDES1" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     # FGR 04/02/2015 : X3SUIVI105605 (début)
     If func AFNC.ACTIV("ECC") Then
       #---- Version majeure
       If   [M:SLC3]ECCCOD> 1     TZONE(IZON)="ECCVALMAJ"
                                  TMOD(IZON) =[M:SLC3]ECCCOD
                                  IZON+=1
       Endif
       If   [M:SLC3]ECCCOD = 1 | [M:SLC3]ECCCOD = 2
          ZT="ECCSCR" : ZM="ECCVALMAJ" : Gosub TABLEAU_FICHE From SUBSLX
       Endif
       #---- Version mineure
       If   [M:SLC3]ECCCODMIN> 1  TZONE(IZON)="ECCVALMIN"
                                  TMOD(IZON) =[M:SLC3]ECCCODMIN
                                  IZON+=1
       Endif
       If   [M:SLC3]ECCCODMIN = 1 | [M:SLC3]ECCCODMIN = 2
          ZT="ECCSCRMIN" : ZM="ECCVALMIN" : Gosub TABLEAU_FICHE From SUBSLX
       Endif
     Endif
     # FGR 04/02/2015 : X3SUIVI105605 (fin)
     #---- unité de vente
     If   [M:SLC3]SAUCOD    > 1 TZONE(IZON)="SAU"
                                TMOD(IZON) =[M:SLC3]SAUCOD
                                IZON+=1
     Endif
     If   [M:SLC3]SAUCOD = 1 | [M:SLC3]SAUCOD = 2
        ZT="SAUSCR" : ZM="SAU" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- coef UV-US
     If   [M:SLC3]SAUCOECOD > 1 TZONE(IZON)="SAUSTUCOE"
                                TMOD(IZON) =[M:SLC3]SAUCOECOD
                                IZON+=1
     Endif
     If   [M:SLC3]SAUCOECOD = 1 | [M:SLC3]SAUCOECOD = 2
