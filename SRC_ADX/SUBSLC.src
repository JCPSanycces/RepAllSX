        ZT="VACITMSCR" : ZM="VACITM3" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="VACITMSCR" : ZM="SSTCOD"  : Gosub TABLEAU_FICHE From SUBSLX   # 101380.n
     Endif
     # 107890 : Scheduled invoices : (LD:08/12/15)
     #---- invoicing condition
     If   [M:SLC3]INVCNDCODD >1 TZONE(IZON)="DINVCND"
                                TMOD(IZON) =[M:SLC3]INVCNDCODD
                                IZON+=1
     Endif
