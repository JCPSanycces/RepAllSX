        ZT="CPRPRISCR" : ZM="CPRPRI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- marge détail et totale
     If   [M:SLC5]PFMCOD    = 1 TZONE(IZON)="PFM"
