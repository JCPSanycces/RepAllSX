     # 106776 EDI fields
     If func AFNC.ACTIV("EDIX3")
      If   [M:SLC3]BPCSALPRICOD > 1 TZONE(IZON)="BPCSALPRI"
                                TMOD(IZON) =[M:SLC3]BPCSALPRICOD
                                IZON+=1
      Endif
      If   [M:SLC3]BPCSALPRICOD = 1 | [M:SLC3]BPCSALPRICOD = 2
        ZT="BPCSALPRISCR" : ZM="BPCSALPRI" : Gosub TABLEAU_FICHE From SUBSLX
      Endif

      If   [M:SLC3]USELIMDCOD > 1 TZONE(IZON)="USELIMDAT"
                                TMOD(IZON) =[M:SLC3]USELIMDCOD
                                IZON+=1
      Endif
      If   [M:SLC3]USELIMDCOD = 1 | [M:SLC3]USELIMDCOD = 2
        ZT="USELIMDSCR" : ZM="USELIMDAT" : Gosub TABLEAU_FICHE From SUBSLX
      Endif

      If   [M:SLC4]DEMDLVLCOD > 1 TZONE(IZON)="DEMDLVHOU"
                                TMOD(IZON) =[M:SLC4]DEMDLVLCOD
                                IZON+=1
      Endif
      If   [M:SLC4]DEMDLVLCOD = 1 | [M:SLC4]DEMDLVLCOD = 2
        ZT="DEMDLVLSCR" : ZM="DEMDLVHOU" : Gosub TABLEAU_FICHE From SUBSLX
      Endif

      If   [M:SLC4]MAXDLVHCOD > 1 TZONE(IZON)="MAXDLVHOU"
                                TMOD(IZON) =[M:SLC4]MAXDLVHCOD
                                IZON+=1
      Endif
      If   [M:SLC4]MAXDLVHCOD = 1 | [M:SLC4]MAXDLVHCOD = 2
        ZT="MAXDLVHSCR" : ZM="MAXDLVHOU" : Gosub TABLEAU_FICHE From SUBSLX
      Endif

      If   [M:SLC4]MAXDLVDCOD > 1 TZONE(IZON)="MAXDLVDAT"
                                TMOD(IZON) =[M:SLC4]MAXDLVDCOD
                                IZON+=1
      Endif
      If   [M:SLC4]MAXDLVDCOD = 1 | [M:SLC4]MAXDLVDCOD = 2
        ZT="MAXDLVDSCR" : ZM="MAXDLVDAT" : Gosub TABLEAU_FICHE From SUBSLX
      Endif
     Endif
     # User Story X3-46075 Task X3-48218 - 2017-08-17 by CPO : ANALYSIS_FDMA_Display_Quantity_Available_field_on_Sales_Order_line
     If   [M:SLC5]AVASTOCOD > 1   TZONE(IZON)="WSTKTXT"
                                  TMOD(IZON) =2
                                  IZON+=1
                                  TZONE(IZON)="WALLTXT"
                                  TMOD(IZON) =2
                                  IZON+=1
     Else TBLOC(5)=1
     Endif
     # /User Story X3-46075 Task X3-48218 - 2017-08-17 by CPO

     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

Endif

## 8 dans param WCTLFCY de l'écran de base SOH4
## si section ana en mode fiche uniquement (contrôle non bloquant)
#Gosub PARAM_CTRL_CCE_AV : If GOK<1 : Return : Endif
Local Char NBRC_MSK   (12) : NBRC_MSK=MFROM
Local Char NBRC_NBLIG (12) : NBRC_NBLIG="NBLIG"
Gosub NBR_COL_AV From SUBSLX   : If GOK<1 Return Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
Gosub NBR_COL_AP From SUBSLX   : If GOK<1 Return Endif
## Restitution de l'écran de base SOH4 (3 dans param WCTLFCY)
## si section ana en mode fiche uniquement (contrôle non bloquant)
#Gosub PARAM_CTRL_CCE_AP : If GOK<1 : Return : Endif

#---- suppression ou génération fenêtre AWINDOW
If ACTION="ANNULE"
  Gosub TRT_SUP_FEN From SUBSLX
Else
  Gosub TRT_GEN_FEN From SUBSLX
Endif
If GOK<1 : Return : Endif

#--------------------------------------------------------------#
#If (dim([M:SLC1]CCECOD)>0 & [M:SLC1]CCECOD=3) | dim([M:SLC1]CCECOD)<1
