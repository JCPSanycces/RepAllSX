     Endif
     # 107890 : Scheduled invoices : (LD:08/12/15)
     #---- représentants / tx comm
     If   [M:SLC3]REPCODD   > 1 TZONE(IZON)="REP1"
                                TMOD(IZON) =[M:SLC3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REP2"
                                TMOD(IZON) =[M:SLC3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPRAT1"
                                TMOD(IZON) =[M:SLC3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPRAT2"
                                TMOD(IZON) =[M:SLC3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPCOE"
                                TMOD(IZON) =[M:SLC3]REPCODD
                                IZON+=1
     Endif
     If   [M:SLC3]REPCODD = 1 | [M:SLC3]REPCODD = 2
        ZT="REPSCRD" : ZM="REP1"    : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REP2"    : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REPRAT1" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REPRAT2" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REPCOE"  : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- date livraison demandée
     If   [M:SLC3]DEMDLVCODD > 1 TZONE(IZON)="DDEMDLVDAT"
                                TMOD(IZON) =[M:SLC3]DEMDLVCODD
                                IZON+=1
     Endif
