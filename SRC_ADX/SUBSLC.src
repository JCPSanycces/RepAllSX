        ZT="DAYLTISCRD" : ZM="DDAYLTI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif

     #---- date expédition
     If   [M:SLC3]SHIDATCODD >1 TZONE(IZON)="DSHIDAT"
                                TMOD(IZON) =[M:SLC3]SHIDATCODD
                                IZON+=1
