        ZT="CCLRENSCRD" : ZM="DCCLREN" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="CCLRENSCRD" : ZM="DCCLDAT" : Gosub TABLEAU_FICHE From SUBSLX
     Endif

     #---- sections analytiques
#     For I=0 To dim([M:SLC1]CCECODD)-1
#         If   [M:SLC1]CCECODD(I) > 1 TZONE(IZON)="CCE"+num$(I+1)
#                                     TMOD(IZON) =[M:SLC1]CCECODD(I)
#                                     IZON+=1
#         Endif
#         If   [M:SLC1]CCECODD(I) = 1 | [M:SLC1]CCECODD(I) = 2
#            ZT="CCESCRD" : ZM="CCE"+num$(I+1) : ZI=I : Gosub TABLEAU_FICHE From SUBSLX
#         Endif
#     Next I
     If [M:DST]CCESCR>1
       For I=0 To 19
         TZONE(IZON)="CCE"+num$(I+1)
         TMOD(IZON) =9
         TINT(IZON) =num$([M:DST]CCESCR)
         IZON+=1
       Next I
     Endif

     If   [M:SLC5]AMTCOD    = 1 TZONE(IZON)="DLRNOT"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="ORDNOT"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="ORDATI"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="ORDINVNOT"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="ORDINVATI"
                                TMOD(IZON) =3
                                IZON+=1
