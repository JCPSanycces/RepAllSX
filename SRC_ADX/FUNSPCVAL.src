#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# FUNSPCVAL : Validation automatique des paramétrages des tarifs Ventes #
#                         entre deux bornes                             #
#-----------------------------------------------------------------------#
#  Validation des tarifs de ventes dans un patch :  EXE  SUBSPC         #
#  ( la traitement contient le s/p   Subprog SUBSPC                     #
#########################################################################
Local File ACTION
#-- ajout parametre = nom de l'application à traiter 
#-- pour résoudre le probleme de la validation dossier de X3 vers appli client

Call SPCVAL (nomap)
End


#########################################################################

Subprog SPCVAL(APPLI)
Value Char APPLI

Raz GLIBDES, GNBREM

Local  Integer OK , I
Local  Integer I_MOD   : I_MOD=0 : # pas de suppression des lignes tarifs
Local  Integer DESTARIFS 
Local  Char    DEBUT(6) , FIN(6)

If clalev([M:SPC0])<=0 : Local Mask SPC0 [SPC0] : Endif 
If clalev([M:SPC1])<=0 : Local Mask SPC1 [SPC1] : Endif 
If clalev([M:SPC2])<=0 : Local Mask SPC2 [SPC2] : Endif 
If clalev([M:SPC3])<=0 : Local Mask SPC3 [SPC3] : Endif 
If clalev([M:SPCV])<=0 : Local Mask SPCVAL [SPCV] : Endif 
Local Integer REPONSE 

$SELECTION
OK=2 : Call DIALWIN(OK,mess(36,198,1),"ISPCVAL") From GESECRAN
If OK<>2 : End :Endif
If [M:SPCV]FINTAR < [M:SPCV]DEBTAR
  Call MESSAGE (mess(202,100,1)) From GESECRAN
  Goto SELECTION
Endif

Call OUVRE_TRACE(mess(56,195,1)) From LECFIC

If clalev ([F:SPC])<=0 : Local File SPRICCONF  [SPC] : Endif
If clalev ([F:PRS])<=0 : Local File PRICSTRUCT [PRS] : Endif

DEBUT = [M:SPCV]DEBTAR
FIN   = [M:SPCV]FINTAR
If FIN="" : FIN = chr$(255) : Endif

Filter [SPC] Where PLI>=DEBUT & PLI<=FIN

Gosub GENER_ECRAN

Filter [SPC]

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#########################################################################
# suppose que le fichier trace soit ouvert avant appel                  #
# Appelé par le SUBSPC (depuis sous-prog PATCH ou GENDOS)               #
#                   pour validation tarif en gestion des patchs         #
#########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

Raz GLIBDES, GNBREM 

Local  Integer OK , I
Local  Integer I_MOD   : I_MOD=0 : # pas de suppression des lignes tarifs
Local  Integer DESTARIFS 
Local  Char    DEBUT(6) , FIN(6)

Onerrgo ON_SCASSE
If clalev([M:SPC0])<=0 : Local Mask =APPLI+".SPC0" [SPC0] : Endif 
If clalev([M:SPC1])<=0 : Local Mask =APPLI+".SPC1" [SPC1] : Endif 
If clalev([M:SPC2])<=0 : Local Mask =APPLI+".SPC2" [SPC2] : Endif 
If clalev([M:SPC3])<=0 : Local Mask =APPLI+".SPC3" [SPC3] : Endif 
Onerrgo

Local File =APPLI+".AWINDOW"    [AWI] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINPAR"    [AWP] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINBRO"    [AWB] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINBOUT"   [AWT] : # Déjà ouvert en local, le réouvrir !
If clalev ([F:SPC])<=0 : Local File =APPLI+".SPRICCONF"  [SPC] : Endif
If clalev ([F:PRS])<=0 : Local File =APPLI+".PRICSTRUCT" [PRS] : Endif
#If clalev ([F:AMK])<=0 : Local File =APPLI+".AMSK"       [AMK] : Endif
#If clalev ([F:AMZ])<=0 : Local File =APPLI+".AMSKZON"    [AMZ] : Endif
#If clalev ([F:AMA])<=0 : Local File =APPLI+".AMSKACT"    [AMA] : Endif
#If clalev ([F:AMP])<=0 : Local File =APPLI+".AMSKPAR"    [AMP] : Endif
#If clalev ([F:ATY])<=0 : Local File =APPLI+".ATYPE"      [ATY] : Endif
#If clalev ([F:ACT])<=0 : Local File =APPLI+".ACTION"     [ACT] : Endif
#If clalev ([F:ATR])<=0 : Local File =APPLI+".ACTPAR"     [ATR] : Endif
#If clalev ([F:AAR])<=0 : Local File =APPLI+".ACTCODPAR"  [AAR] : Endif
#If clalev ([F:ATB])<=0 : Local File =APPLI+".ATABLE"     [ATB] : Endif
#If clalev ([F:ATZ])<=0 : Local File =APPLI+".ATABZON"    [ATZ] : Endif
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]

# Déjà ouvert en local, le réouvrir !
Local File =APPLI+".ACTIV"      [ACV]
Local File =APPLI+".AOBJET"     [AOB]

#If clalev ([F:ATX])<=0 : Local File =APPLI+".ATEXTE"     [ATX] : Endif
#If clalev ([F:ADV])<=0 : Local File =APPLI+".ATABTAB"    [ADV] : Endif
Local File =APPLI+".ATEXTE"     [ATX]
Local File =APPLI+".ATABTAB"    [ADV]

Filter [SPC]

Gosub GENER_ECRAN

$ON_SCASSE
End

#-----------------------------------------------------------------------#
# Regeneration des ecrans et traitements                                #
#-----------------------------------------------------------------------#
$GENER_ECRAN

#Read [F:PRS]PRS0=1;""
For [SPC]

Read [F:PRS]PRS0=1;[F:SPC]PLISTC
If fstat : Break  : Endif
For I=0 To dim([F:PRS]INCDCR)-1
  If [F:PRS]INCDCR(I)=0 : Break : Endif
  Call LECTEXTRA (GLIBDES(I),"PRICSTRUCT","DESAXX("+num$(I)+")","1",[F:PRS]PLISTC) From ATEXTRA
Next I

GNBREM=I

GOK=1
Trbegin [SPC]
  [M:SPC0]=[F:SPC]
  [M:SPC1]=[F:SPC]
  [M:SPC2]=[F:SPC]
  [M:SPC3]=[F:SPC]
  Default File [SPC]
  Gosub DEL_ECR From SUBSPC
  Gosub GEN_ECR From SUBSPC
  If GOK <> 1
    Call ECR_TRACE (mess(14,100,1)-mess(49,198,1)-[F:SPC]PLI,1) From GESECRAN
    Rollback
  Else
    Call ECR_TRACE (mess(87,197,1)-mess(49,198,1)-[F:SPC]PLI,0) From GESECRAN
    Commit
  Endif
Next

Return

#########################################################################
