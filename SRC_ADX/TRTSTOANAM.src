#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# Traitement TRTSTOANAM - Modification des sections analytiques stock  #
#                                                                V140  #
########################################################################
# Action SAISTOANAM
#    Paramètres     - LABR    Abréviation masque : "SOM" ou "ENM"
#
########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "DEBUT"     : Gosub DEBUT
 When "SETBOUT"   : Gosub SETBOUT
 When "AVANT_ENR" : Gosub AVANT_ENR
 When "ENR"       : Gosub ENR
 When "ABA"       : Gosub ABA
 When "FINSAI"    : Gosub FINSAI
Endcase

##########################################################################
$OUVRE
Local Char    LFCY(GLONFCY)
Local Integer LTYP
Local Char    LNUM(GLONVCR)
Local Integer LLIN
Local Char    LITM(GLONITM)
Local Integer I, WGCONSULT
WGCONSULT=1

# Récupération des paramètres
LFCY = PARAM(1)
LTYP = val(PARAM(2))
LNUM = PARAM(3)
LLIN = val(PARAM(4))
LITM = PARAM(5)

If clalev([F:STJ])=0  Local File STOJOU     [STJ]   Endif
If find(LTYP,12,15,26)
   If clalev([F:MWI])=0  Local File WIPCOST  [MWI]   Endif
Endif

Return

##########################################################################
$DEBUT

# Si les mouvements ont déjà été interfacés --> uniquement consultation
Filter [STJ] Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN &
&                  ITMREF=LITM & REGFLG<>2 & AGGIFAFLG=2
Read [STJ]STJ1 First
Filter [STJ]
If !fstat
   WGCONSULT=2
Else
   # Sinon, on peut modifier les section analytiques
   Filter [STJ] Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN &
&                     REGFLG<>2 & ITMREF=LITM
   Read [STJ]STJ1 First
   Filter [STJ]
   If fstat FIN=1 : Return Endif
Endif

For I=1 To GNBDIE
   [M:STM]CCE(I-1) = [F:STJ]CCE(I-1)
   [M:STM]DIE(I-1) = [F:STJ]DIE(I-1)
Next I
[M:STM]IPTDAT = [F:STJ]IPTDAT                # hcb X3-103706
[M:STM]NBAXE = GNBDIE

# Consultation
If WGCONSULT=2
   Diszo [M:STM]
Endif

Affzo [M:STM]1-99

Return

#########################################################################
$SETBOUT

If WGCONSULT<>2
   If !find("A",CHBOU) CHBOU+="A" Endif
   If !find("E",CHBOU) CHBOU+="E" Endif
Endif

Return

##########################################################################
$AVANT_ENR

For I=1 To GNBDIE
    Call CTRL_CCEH([M:STM]CCE(I-1),I,GFINRSP,[M:STM]IPTDAT) From TRTX3CPT
    If mkstat Break Endif
Next I
If mkstat FOK=0 Endif

Return

##########################################################################
$ENR

# Transaction de mise à jour
Call DEBTRANS From GLOCK
Trbegin [STJ]

# Maj des mouvements de stock
For [STJ]STJ1 Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN & ITMREF=LITM
   Readlock Curr
   If fstat
      Call RSTA("STJ",num$([F:STJ]VCRTYP)-[F:STJ]VCRNUM-num$([F:STJ]VCRLIN)) From GLOCK
      Raz GOK : Goto AB_TRT
   Else
      For I=1 To GNBDIE
         [F:STJ]CCE(I-1) = [M:STM]CCE(I-1)
         [F:STJ]DIE(I-1) = [M:STM]DIE(I-1)
      Next I
      Rewrite [STJ]
      If fstat
         Call FSTA("STJ") From GLOCK
         Raz GOK : Goto AB_TRT
      Endif
   Endif
Next

# Si GPAO maj du Wipcost
If find(LTYP,12,15,26)
   For [MWI]MWI1 Where MFGTRKNUM=LNUM & MFGTRKLIN=LLIN & TXNACT<3 & find(TXNTYP,1,14)
      Readlock [MWI] Curr
      If fstat
         Call RSTA("MWI",[F:MWI]MFGTRKNUM-num$([F:MWI]MFGTRKLIN)) From GLOCK
         Raz GOK : Goto AB_TRT
      Else
         For I=1 To GNBDIE
            [F:MWI]CCE(I-1) = [M:STM]CCE(I-1)
            [F:MWI]DIE(I-1) = [M:STM]DIE(I-1)
         Next I
         Rewrite [MWI]
         If fstat
            Call FSTA("MWI") From GLOCK
            Raz GOK : Goto AB_TRT
         Endif
      Endif
   Next
Endif

Commit

FIN = 1
Return

##########################################################################
$FINSAI

Return

##########################################################################
$ABA

Filter [STJ] Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN &
&                  REGFLG<>2 & ITMREF=LITM
Read [STJ]STJ1 First
If !fstat
   For I=1 To GNBDIE
      [M:STM]CCE(I-1) = [F:STJ]CCE(I-1)
      [M:STM]DIE(I-1) = [F:STJ]DIE(I-1)
   Next I
   [M:STM]NBAXE = GNBDIE
Endif
Filter [STJ]

Affzo [M]1-99

Return

##########################################################################
$AB_TRT
Rollback
Return

