$ON_NBCOD
Onevent BEFORE_INPUT Call AS_NBCOD From W1SITRAFIL
Onevent BEFORE_AREA Call AV_NBCOD From W1SITRAFIL
Return

Subprog AV_NBCOD
Local Decimal BASPAG
If adxgtb=1 & !GORITITCOL & nolign=1
 Local Char BASPAG(10)
 BASPAG = "NBCOD" : Gosub TIT_COL From W1SITRAFIL
Endif
Gosub _AFF
End

Subprog AS_NBCOD
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(16984,GBOUT2) From OBJDIV
Onkey 130 Titled GBOUT2 Call B2_NBCOD From W1SITRAFIL
Gosub _AFF
End

Subprog B2_NBCOD
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B2_NBCOD From SUBSITF
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CODE
Onevent BEFORE_AREA Gosub AV_CODE From W1SITRAFIL
Onevent INIT_AREA Call D_CODE(zc) From W1SITRAFIL
Return

$AV_CODE
## Action STD
Call AV_CODE(zc) From SUBSITF
Gosub _AFF
Return

Subprog D_CODE(VALEUR)
Variable Char    VALEUR()
If varinit([M]CODE,indice)=0
 VALEUR = [M]COD(nolign-1)-string$([M]COD2(nolign-1)<>"","; "+[M]COD2(nolign-1))
Endif
Gosub _AFF
End

$ON_X3CLE
Onevent BEFORE_AREA Gosub AV_X3CLE From W1SITRAFIL
Onevent BEFORE_INPUT Call AS_X3CLE(zc) From W1SITRAFIL
Onevent CONTROL Call C_X3CLE(zc) From W1SITRAFIL
Onevent AFTER_CHANGE Gosub AMM_X3CLE From W1SITRAFIL
Return

Subprog IB_X3CLE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call IB_X3CLE From SUBSITF
Gosub _AFF
End

$AV_X3CLE
## Action STD
Call AV_X3CLE(zc) From SUBSITF
Gosub _AFF
Return

Subprog AS_X3CLE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_X3CLE(VALEUR)
## Action STD
Call AS_X3CLE(VALEUR) From SUBSITF
If mkstat=2
 [M]X3CLE(INDIC) = VALEUR
 Affzo X3CLE(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_X3CLE(zc) From W1SITRAFIL
Gosub _AFF
End

Subprog C_X3CLE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_X3CLE(VALEUR) From SUBSITF
If mkstat : GERR = 1 : GZONE = "X3CLE" : GZNUM = 0 : Endif
Gosub _AFF
End

$AMM_X3CLE
Call AM_X3CLE(zc)
If !mkstat & GOBJET
 zoncou = "X3CLE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_X3CLE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_X3CLE(VALEUR) From SUBSITF
If mkstat : GERR = 1 : GZONE = "X3CLE" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog S_X3CLE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJ1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJ1"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_X3CLE" : PROGSUB = "SUBSITF" : PROGSPE = "SPESITF" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M]SEL
 PARMSK(2) = [M]OPTSEL
 PARMSK(3) = GBIDC1
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 ACTION = "BS_X3CLE" : PROGSUB = "SUBSITF" : PROGSPE = "SPESITF" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

