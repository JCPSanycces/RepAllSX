#<AdxTL>@(#)0.0.0.0 $Revision$
#-------------------------------------#
# Traitement d'import des engagements #
#-------------------------------------#

$ACTION
Case ACTION
 When "IMPORT"   : Gosub IMPORT
 When "IMP_TAB"  : Gosub IMP_TAB
Endcase
Return

$IMPORT
Case IMPFIC
 When "CMD"
  If GREP="M" & [F:CMD]LIN>=1 & [F:CMD]LIN<=[M]NBLIG
   nolign = [F:CMD]LIN
  Else
   [M]NBLIG += 1
   nolign = [M]NBLIG
  Endif
Endcase
Return

$IMP_TAB
If IMPZON="AMT"
 Assign "[M]AMT("+num$(indice)+")" With [F:CMD]AMTCUR
 Call ECR_TRACE(num$(evalue("[M]AMT("+num$(indice)+")")),-1) From GESECRAN
Elsif left$(IMPZON,3) = "ACC" & IMPZON<>"ACCDAT" 
 I = val(right$(IMPZON,4))
 Assign "[M]ACC"+num$(I)+"("+num$(indice)+")" With evalue("[F:CMD]ACC("+num$(I-1)+")")
Elsif left$(IMPZON,3) = "CCE"
 I = val(right$(IMPZON,4))
 Assign "[M]CCE"+num$(I)+"("+num$(indice)+")" With evalue("[F:CMD]CCE("+num$(I-1)+")")
Endif
Return
