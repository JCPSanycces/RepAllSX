#<AdxTL>@(#)0.0.0.0 $Revision$Class Spouses (>1)
# Supervisor
## CRUD-CLASSE ## EMPLOJNT
# 2018-11-06 07:06:06 402


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EMPLOJNT,ASTATUS)
Variable Instance EMPLOJNT Using C_EMPLOJNT
Variable Integer ASTATUS

If EMPLOJNT = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOJNT

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EMPLOJNT

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EMPLOJNT,ASTATUS)
Variable Instance EMPLOJNT Using C_EMPLOJNT
Variable Integer ASTATUS

If EMPLOJNT = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOJNT
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EMPLOJNT
Else
 Gosub AINSERT_EMPLOJNT
Endif

Gosub _AINSERT_AFTER
[L]A_I = EMPLOJNT.freeSnapshot
EMPLOJNT.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOJNT._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOJNT._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOJNT._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EMPLOJNT.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOJNT.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EMPLOJNT
Trbegin [F:JNT]
 Gosub AINSERT_EMPLOJNT
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EMPLOJNT
Raz [F:JNT]
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOJNT._MAJSQL_EMPLOJNT(EMPLOJNT))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EMPLOJNT.snapshotEnabled=1
 [L]A_RETIK = EMPLOJNT.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOJNT.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EMPLOJNT.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOJNT.ASTALIN = [V]CST_ALL
Endif
Return



