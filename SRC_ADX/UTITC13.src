#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTITC13   Table TABROUND les désignations deviennent        Module TC #
#           traduisibles                                                 #
##########################################################################
# FGR 18/09/2009 : X3SUIVI57927
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-08-07 by MAE :
    #Read [ADS]DOSSIER=[L]DOSSIER
    #If fstat THEN
    #  Raz [F:ADS]
    #Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC13(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC13(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)

  IERR = 0
  Call ECR_TRACE("UTITC13: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table TABROUND
  #
  If filinfo(filpath("FIL", "ATEXTRA", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".ATEXTRA" [AXX]
  #
  If filinfo(filpath("FIL", "TABROUND", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI + ".TABROUND" [TRN]
    If dim([F:TRN]RNDDES) > 0 or dim([F:TRN]RNDSHO) > 0  Then
      Trbegin [TRN], [AXX]
      For [TRN]TRD0
        IUPDATE = 0
        If dim([F:TRN]RNDDES) > 0 Then
          If [F:TRN]RNDDES <> "" Then
            Call MAJTEXTRA([F:TRN]RNDDES, "TABROUND", "RNDDESAXX", [F:TRN]RNDCOD, "") From ATEXTRA
            If GOK < 1 Then
              Call ECR_TRACE("File ATEXTRA TABROUND-RNDDESAXX" - [F:TRN]RNDCOD + ",Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              Break
            Endif
            IUPDATE = 1
            [F:TRN]RNDDES = ""
          Else
            Call LECTEXTRA(WCHAINE,"TABROUND", "RNDDESAXX", [F:TRN]RNDCOD, "") From ATEXTRA
            If WCHAINE = "" Then
              Call MAJTEXTRA(WCHAINE, "TABROUND", "RNDDESAXX", [F:TRN]RNDCOD, "") From ATEXTRA
            Endif
          Endif
        Endif
        If dim([F:TRN]RNDSHO) > 0  Then
          If [F:TRN]RNDSHO <> "" Then
            Call MAJTEXTRA([F:TRN]RNDSHO, "TABROUND", "RNDSHOAXX", [F:TRN]RNDCOD, "") From ATEXTRA
            If GOK < 1 Then
              Call ECR_TRACE("File ATEXTRA TABROUND-RNDSHOAXX" - [F:TRN]RNDCOD + ",Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              Break
            Endif
            IUPDATE = 1
            [F:TRN]RNDSHO = ""
          Else
            Call LECTEXTRA(WCHAINE,"TABROUND", "RNDSHOAXX", [F:TRN]RNDCOD, "") From ATEXTRA
            If WCHAINE = "" Then
              Call MAJTEXTRA(WCHAINE, "TABROUND", "RNDSHOAXX", [F:TRN]RNDCOD, "") From ATEXTRA
            Endif
          Endif
        Endif
        If IUPDATE = 1 Then
          Rewrite [TRN]
        Endif
      Next
      If IERR = 0 Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Close Local File [TRN]
  Endif
  Close Local File [AXX]
  #
  If IERR = 0 Then
    If clalev([F:AOB]) = 0 : Local File =SZAPPLI + ".AOBJET"  [AOB] : Endif
    WOBJET = "TRN"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      Call MAJ_SEL(SZAPPLI, WOBJET) From PATCHAOB
      #
      If [F:AOB]TYPGES <> 4 Then
        # Pas de fenêtre pour les browsers
        Call VALID("O" + WOBJET, SZAPPLI, 1, IERR) From VALWIN
        If IERR <> 1 Then
          Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
        Endif
      Endif
      #
      Call VALID (WOBJET, SZAPPLI, 1, IERR) From VALOBJ
      If IERR <> 1 Then
        Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
      Endif
    Endif
  Endif
  #
  Call ECR_TRACE("UTITC13 : records processed", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"TABROUND") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC13(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"TABROUND") : End : Endif
  Call MAJ_UTITC13(APPLI)
End

