Subprog AV_CPNITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer L     : L     = nolign-1

# FQ 71053 GA 02/2011
#If [M:VGHT]PHAFLG(L) = 2 & [M:VGHT]ILEV(L) = 1
If [M:VGHT]PHAFLG(L) = 2
    pcolor = GCOUL(3)
Else
    pcolor = GCOUL(0)
Endif

End

