  this.ITMREF = [L]ITMREF
  this.STOFCY = [L]STOFCY
  this.CUR    = fmet this._GETCPYCUR([L]STOFCY)

  this.DECCST = func ASYRFNC.ACTIV("SPD")
  this.CSTMETHOD = 2
  Gosub CALCSTD

  [L]ARET_VALUE = this.PRI

Return

# Standard price budget
$GET_STD_BUD
# Char ITMREF
# Char STOFCY
# Char ECCMAJ
# Char ECCMIN
# Char DAT
# Long Int UID

  this.ITMREF = [L]ITMREF
  this.STOFCY = [L]STOFCY
  this.CUR    = fmet this._GETCPYCUR([L]STOFCY)

  this.DECCST = func ASYRFNC.ACTIV("SPD")
  this.CSTMETHOD = 3
  Gosub CALCSTD

  [L]ARET_VALUE = this.PRI

Return

# Simulated standard price
$GET_STD_SIM
# Char ITMREF
# Char STOFCY
# Char ECCMAJ
# Char ECCMIN
# Char DAT
# Long Int UID

  this.ITMREF = [L]ITMREF
  this.STOFCY = [L]STOFCY
  this.CUR    = fmet this._GETCPYCUR([L]STOFCY)

  this.DECCST = func ASYRFNC.ACTIV("SPD")
  this.CSTMETHOD = 4
  Gosub CALCSTD

  [L]ARET_VALUE = this.PRI

Return

$CALCSTD
  Local Char LCRITECC(250)
  Local Integer IRET
  # Several locations of the code calling this requires local ITC to be repositioned
  # so check for table open already and only open if needed.
  If !clalev([F:ITC]) : Local File ITMCOST [ITC] : Endif

  fstat = 1

  LCRITECC = "1=1"
  If [L]ECCMAJ<>"" & dim([F:ITC]ECCVALMAJ)>0
    LCRITECC+="&ECCVALMAJ='"+[L]ECCMAJ+"'"
    If [L]ECCMIN<>""
      LCRITECC+="&ECCVALMIN='"+[L]ECCMIN+"'"
    Endif
  Endif

  # Dans le cas du calcul des coûts standards il faut privilégier le coût calculé par l'utilisateur
  If [L]UID<>0
    Filter [ITC] Where STOFCY = [L]STOFCY
&                    & ITMREF = [L]ITMREF
&                    & CSTTYP = this.CSTMETHOD
&                    & ITCSTRDAT<= [L]DAT & [L]DAT<=ITCENDDAT
&                    & UID    = [L]UID
&                    & evalue (LCRITECC)
&                Order By Key ITC0
    Read [ITC] First
  Endif

  If fstat
    Filter [ITC] Where STOFCY = [L]STOFCY
&                    & ITMREF = [L]ITMREF
&                    & CSTTYP = this.CSTMETHOD
&                    & ITCSTRDAT<= [L]DAT & [L]DAT<=ITCENDDAT
&                    & UID    = 0
&                    & evalue (LCRITECC)
&                Order By Key ITC0
    Read [ITC] First
  Endif

  If fstat    # Si le prix standard de l'année de la fin d'exercice en cours n'est pas trouvé, on essaie avec l'année précédente
    Filter [ITC] Where STOFCY = [L]STOFCY
&                    & ITMREF = [L]ITMREF
&                    & CSTTYP = this.CSTMETHOD
&                    & ITCSTRDAT<= [L]DAT
&                    & UID    = 0
&                    & evalue (LCRITECC)
&                Order By Key ITC2

    Read [ITC]ITC2 Last
  Endif

  If !fstat
    this.PRI = [F:ITC]VLTTOT

    If this.DECCST | [L]DETVAL=1
      IRET = fmet this._LOADDETAIL("[F:ITC]", "", "CST", 1)
    Else
      IRET = fmet this._LOADPRICE([L]ITMREF)
    Endif
  Else
    this.PRI = 0
  Endif
  Filter [ITC]

Return

#**********************************************************
#* FIFO/LIFO related methods
#*!
# FIFO
$GET_FIFO
# Char ITMREF
# Char STOFCY
# Decimal QTY

  this.ITMREF = [L]ITMREF
  this.STOFCY = [L]STOFCY
  this.CUR    = fmet this._GETCPYCUR([L]STOFCY)

  this.DECCST = func ASYRFNC.ACTIV("SPD")
  this.CSTMETHOD = 5
  Gosub CALCIFO

  [L]ARET_VALUE = this.PRI

Return

#LIFO
$GET_LIFO
# Char ITMREF
# Char STOFCY
# Decimal QTY

  this.ITMREF = [L]ITMREF
  this.STOFCY = [L]STOFCY
  this.CUR    = fmet this._GETCPYCUR([L]STOFCY)

  this.DECCST = func ASYRFNC.ACTIV("SPD")
  this.CSTMETHOD = 8
  Gosub CALCIFO

  [L]ARET_VALUE = this.PRI

Return

# Shared FIFO/LIFO routine (uses CSTMETHOD property to determine type)
$CALCIFO
  If [L]QTY=0 : Return : Endif

  Local File STOCOST [STP]

  Local Integer ACTMAT, ACTMAC, ACTLAB
  ACTMAT = func ASYRFNC.ACTIV("MATS")
  ACTMAC = func ASYRFNC.ACTIV("MACS")
  ACTLAB = func ASYRFNC.ACTIV("LABS")

  Local Decimal WQTE, WCUMM, WQTEOFF, LCOE
  Local Decimal LDELTASTP(1+(ACTMAT+ACTMAC+ACTLAB+1+4+1)*this.DECCST)
  Local Integer I, IRET

  If [L]QTY <> -99 : [L]WQTE  = [L]QTY : Endif
  Case this.CSTMETHOD
    When 5:
      Filter [STP] Where ITMREF=[L]ITMREF & STOFCY=[L]STOFCY & QTYSTUACT>0
    When 8:
      Filter [STP] Where ITMREF=[L]ITMREF & STOFCY=[L]STOFCY & QTYSTUACT>0 Order By Key STP0 Desc
  Endcase

  For [STP]
    If WQTEOFF<[L]QTYOFF
      If ([L]QTYOFF - WQTEOFF) >= [F:STP]QTYSTUACT
        WQTEOFF += [F:STP]QTYSTUACT
        [F:STP]QTYSTUACT = 0
      Else
        # L'offset est inférieur à l'élément de pile
        #  => Décrémentation des montants de la pile
        [F:STP]CST-=[F:STP]CST*([L]QTYOFF - WQTEOFF)/[F:STP]QTYSTUACT   # Issue 83496 - 2012-08-09 by CCC
        If this.DECCST
          Call LOADVAR(LDELTASTP,"[F:STP]",0, "", ([L]QTYOFF - WQTEOFF)/[F:STP]QTYSTUACT, 0, 10^-GDECPRI) From STKVALECR
          Call LOADFIC("[F:STP]",LDELTASTP, "", "CST", -1, 1) From STKVALECR
        Endif
        # => Décrémentation de la quantité dans la pile
        [F:STP]QTYSTUACT -= ([L]QTYOFF - WQTEOFF)
        WQTEOFF = [L]QTYOFF
      Endif
    Endif
    If WQTEOFF=[L]QTYOFF & [F:STP]QTYSTUACT>0
      If [L]WQTE > [F:STP]QTYSTUACT | [L]QTY = -99
        [L]WCUMM += [F:STP]CST
        [L]WQTE  -= [F:STP]QTYSTUACT
        If this.DECCST
          IRET = fmet this._LOADDETAIL("[F:STP]", "", "CST", 1)
        Endif
      Else
        [L]WCUMM += [F:STP]CST*[L]WQTE/[F:STP]QTYSTUACT
        If this.DECCST
          IRET = fmet this._LOADDETAIL("[F:STP]", "", "CST", [L]WQTE/[F:STP]QTYSTUACT)
        Endif
        [L]WQTE = 0
        Break
      Endif
    Endif
  Next
  Filter [STP]

  # 0 on hand, so set price to 0 and return
  If [L]WQTE = 0 & [L]QTY=-99 : this.PRI = 0 : Return : Endif

  If [L]QTY = -99 : [L]QTY=abs(WQTE) : Raz WQTE : Endif

  If [L]WQTE = 0 & [L]QTY<>0
    this.PRI = [L]WCUMM / [L]QTY
    If this.DECCST
      LCOE = 1/[L]QTY
      For I=1 To maxtab(this.MATERIAL)
        this.MATERIAL(I).MATCST = this.MATERIAL(I).MATCST * LCOE
      Next
      this.OVEMATCST = this.OVEMATCST * LCOE

      For I=1 To maxtab(this.MACHINE)
        this.MACHINE(I).MACCST = this.MACHINE(I).MACCST * LCOE
      Next
      this.OVEMACCST = this.OVEMACCST * LCOE

      For I=1 To maxtab(this.LABOR)
        this.LABOR(I).LABCST = this.LABOR(I).LABCST * LCOE
      Next
      this.OVELABCST = this.OVELABCST * LCOE

      this.SCOCST = this.SCOCST * LCOE
      this.SCOTOT = this.SCOTOT * LCOE
      this.OVESCOCST = this.OVESCOCST * LCOE

      this.INVDTACST = this.INVDTACST * LCOE
    Else
      IRET = fmet this._LOADPRICE([L]ITMREF)
    Endif
  Else
    LRET = 5
  Endif
Return

#**********************************************************
#* Last price
#*!
$GET_LAST_PRICE
  Local Integer IRET
  Local File ITMMVT [ITV]

  this.ITMREF = [L]ITMREF
  this.STOFCY = [L]STOFCY
  this.CUR    = fmet this._GETCPYCUR([L]STOFCY)

  this.DECCST = func ASYRFNC.ACTIV("SPD")

  Read [ITV]ITV0=[L]ITMREF;[L]STOFCY
  If fstat
    # Record not found is not necessarily an error. If it's an error it has to be detected somewhere else
    Raz [F:ITV]
  Endif

  # If the document is a receipt, the last purchase price is recovered, otherwise the last entry price
  If dim(LTYP)>0 & LTYP = 3
    this.PRI = [F:ITV]LASPURPRI
    IRET = fmet this._LOADPRICE([L]ITMREF)
  Else
    this.PRI = [F:ITV]LASRCPPRI
    If this.DECCST
      IRET = fmet this._LOADDETAIL("[F:ITV]", "L", "CST", 1)
    Else
      IRET = fmet this._LOADPRICE([L]ITMREF)
    Endif
  Endif

  [L]ARET_VALUE = this.PRI

Return

$GET_LAST_PUR
  Local Integer IRET
  Local File ITMMVT [ITV]

  this.ITMREF = [L]ITMREF
  this.STOFCY = [L]STOFCY
  this.CUR    = fmet this._GETCPYCUR([L]STOFCY)

  Read [ITV]ITV0=[L]ITMREF;[L]STOFCY
  If fstat
    # Record not found is not necessarily an error. If it's an error it has to be detected somewhere else
    Raz [F:ITV]
  Endif

  this.PRI = [F:ITV]LASPURPRI
  IRET = fmet this._LOADPRICE([L]ITMREF)

  [L]ARET_VALUE = this.PRI

Return


#**********************************************************
#* Shared methods
#*!
$_GETCPYCUR
#Value Char    STOFCY

  Local Char COMPANY(GLONCPY)
  Local Char CPYCUR(GLONCUR)
  Local Integer I

  COMPANY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR([L]STOFCY,'LEGCPY')
  CPYCUR = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(COMPANY,"ACCCUR")
  [L]ARET_VALUE = CPYCUR

Return

$_LOADDETAIL
#Value Char    PFIC
#Value Char    PREFIX
#Value Char    SUFFIX
#Value Decimal COE

  Local Char LOSUFFIX(len(SUFFIX))

  [L]ARET_VALUE = [V]CST_AOK

  # Pour pouvoir charger le coût standard du niveau
  If SUFFIX="LEVCST"
    LOSUFFIX = "LEV"
  Elsif PREFIX="DEV"
    LOSUFFIX = ""
  Else
    LOSUFFIX = SUFFIX
  Endif

  Local Integer I, IMAX, ILINE, IRET

  #---- Material ----#
  IMAX = func ASYRFNC.ACTIV("MAT")-1
  For I=0 To IMAX
    Raz ILINE
    If evalue(PFIC+PREFIX+"MAT"+SUFFIX+"(I)")*COE <> 0
      ILINE = find(I,this.MATERIAL(1..maxtab(this.MATERIAL)).MATIDX)
      If ILINE = 0 : ILINE = fmet this.ADDLINE("MATERIAL",[V]CST_ALASTPOS) : Endif
      If ILINE <> [V]CST_ANOTDEFINED
        this.MATERIAL(ILINE).MATCST = evalue(PFIC+PREFIX+"MAT"+SUFFIX+"(I)")*COE
        this.MATERIAL(ILINE).MATIDX  = I
      Else
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"MATERIAL","STKVAL"), [V]CST_AERROR)
        Return
      Endif
    Endif
  Next

  If evalue("dim("+PFIC+PREFIX+"OVEMAT"+LOSUFFIX+")")>0
    this.OVEMATCST += evalue(PFIC+PREFIX+"OVEMAT"+LOSUFFIX+"")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"OVEMATTOT)")>0
    this.OVEMATCST += evalue(PFIC+PREFIX+"OVEMATTOT")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"OVEMAT)")>0
    this.OVEMATCST += evalue(PFIC+PREFIX+"OVEMAT")*COE
  Endif

  #---- Machine ----#
  IMAX = func ASYRFNC.ACTIV("MAC")-1
  For I=0 To IMAX
    If evalue(PFIC+PREFIX+"MAC"+SUFFIX+"(I)")*COE <> 0
      ILINE = find(I,this.MACHINE(1..maxtab(this.MACHINE)).MACIDX)
      If ILINE = 0 : ILINE = fmet this.ADDLINE("MACHINE",[V]CST_ALASTPOS) : Endif
      If ILINE <> [V]CST_ANOTDEFINED
        this.MACHINE(ILINE).MACCST = evalue(PFIC+PREFIX+"MAC"+SUFFIX+"(I)")*COE
        this.MACHINE(ILINE).MACIDX  = I
      Else
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"MACHINE","STKVAL"), [V]CST_AERROR)
        Return
      Endif
    Endif
  Next

  If evalue("dim("+PFIC+PREFIX+"OVEMAC"+LOSUFFIX+")")>0
    this.OVEMACCST += evalue(PFIC+PREFIX+"OVEMAC"+LOSUFFIX+"")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"OVEMACTOT)")>0
    this.OVEMACCST += evalue(PFIC+PREFIX+"OVEMACTOT")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"OVEMAC)")>0
    this.OVEMACCST += evalue(PFIC+PREFIX+"OVEMAC")*COE
  Endif

  #---- Labor ----#
  IMAX = func ASYRFNC.ACTIV("LAB")-1
  For I=0 To IMAX
    If evalue(PFIC+PREFIX+"LAB"+SUFFIX+"(I)")*COE <> 0
      ILINE = find(I,this.LABOR(1..maxtab(this.LABOR)).LABIDX)
      If ILINE = 0 : ILINE = fmet this.ADDLINE("LABOR",[V]CST_ALASTPOS) : Endif
      If ILINE <> [V]CST_ANOTDEFINED
        this.LABOR(ILINE).LABCST = evalue(PFIC+PREFIX+"LAB"+SUFFIX+"(I)")*COE
        this.LABOR(ILINE).LABIDX  = I
      Else
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"LABOR","STKVAL"), [V]CST_AERROR)
        Return
      Endif
    Endif
  Next

  If evalue("dim("+PFIC+PREFIX+"OVELAB"+LOSUFFIX+")")>0
    this.OVELABCST += evalue(PFIC+PREFIX+"OVELAB"+LOSUFFIX+"")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"OVELABTOT)")>0
    this.OVELABCST += evalue(PFIC+PREFIX+"OVELABTOT")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"OVELAB)")>0
    this.OVELABCST += evalue(PFIC+PREFIX+"OVELAB")*COE
  Endif

  #---- Sub-contract ----#
  If evalue("dim("+PFIC+PREFIX+"SCO"+SUFFIX+")")>0
    this.SCOCST += evalue(PFIC+PREFIX+"SCO"+SUFFIX+"")*COE
    this.SCOTOT += evalue(PFIC+PREFIX+"SCO"+SUFFIX+"")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"SCOTOT)")>0
    this.SCOCST += evalue(PFIC+PREFIX+"SCOTOT")*COE
    this.SCOTOT += evalue(PFIC+PREFIX+"SCOTOT")*COE
  Endif
  If evalue("dim("+PFIC+PREFIX+"OVESCO"+LOSUFFIX+")")>0
    this.OVESCOCST += evalue(PFIC+PREFIX+"OVESCO"+LOSUFFIX+"")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"OVESCOTOT)")>0
    this.OVESCOCST += evalue(PFIC+PREFIX+"OVESCOTOT")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"OVESCO)")>0
    this.OVESCOCST += evalue(PFIC+PREFIX+"OVESCO")*COE
  Endif

  #---- /s-traitance ----#
  If evalue("dim("+PFIC+PREFIX+"INVDTA"+SUFFIX+")")>0
    this.INVDTACST += evalue(PFIC+PREFIX+"INVDTA"+SUFFIX+"")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"INVDTACST)")>0
    this.INVDTACST += evalue(PFIC+PREFIX+"INVDTACST")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"INVDTATOT)")>0
    this.INVDTACST += evalue(PFIC+PREFIX+"INVDTATOT")*COE
  Elsif evalue("dim("+PFIC+PREFIX+"INVDTA)")>0
    this.INVDTACST += evalue(PFIC+PREFIX+"INVDTA")*COE
  Endif

Return

$_LOADPRICE
  Local Integer ILINE,IRET

  Local File ITMMASTER [ITM1]
  Read [ITM1]ITM0 = ITMREF

  ILINE = find([F:ITM1]BRDCOD,this.MATERIAL(1..maxtab(this.MATERIAL)).MATIDX)
  If ILINE = 0 : ILINE = 1 : Endif

  If this.MATERIAL(ILINE)=null
    ILINE = fmet this.ADDLINE("MATERIAL",ILINE)
    If ILINE = [V]CST_ANOTDEFINED
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"MATERIAL","STKVAL"), [V]CST_AERROR)
      Return
    Endif
  Endif
  this.MATERIAL(ILINE).MATCST = this.PRI

Return

