#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class STKVAL
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return [L]ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return [L]ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "GET_PRI"        : Gosub GET_PRI         # Wrapper class that can be used for any valuation method
    When "GET_AVC"        : Gosub GET_AVC         # Average cost
    When "GET_ALC"        : Gosub GET_ALC         # Average lot cost
    When "GET_STD"        : Gosub GET_STD         # Standard cost
    When "GET_STD_REV"    : Gosub GET_STD_REV     # Revised Standard cost
    When "GET_STD_BUD"    : Gosub GET_STD_BUD     # Budgeted Standard cost
    When "GET_STD_SIM"    : Gosub GET_STD_SIM     # Simulated Standard cost
    When "GET_FIFO"       : Gosub GET_FIFO        # FIFO
    When "GET_LIFO"       : Gosub GET_LIFO        # LIFO
    When "GET_LAST_PRICE" : Gosub GET_LAST_PRICE  # Last price
    When "GET_LAST_PUR"   : Gosub GET_LAST_PUR    # Last purchase price

    When "_GETCPYCUR"     : Gosub _GETCPYCUR
    When "_LOADDETAIL"    : Gosub _LOADDETAIL
    When "_LOADPRICE"     : Gosub _LOADPRICE
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return [L]ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return [L]ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

$GET_PRI

  Case [L]VLT
    When 1 : [L]ARET_VALUE = fmet this.GET_STD([L]ITMREF, [L]STOFCY, [L]ECCMAJ, [L]ECCMIN, [L]DAT, 0, 0)      # Standard
    When 2 : [L]ARET_VALUE = fmet this.GET_STD_REV([L]ITMREF, [L]STOFCY, [L]ECCMAJ, [L]ECCMIN, [L]DAT, 0, 0)  # Revised Standard
    When 3 : [L]ARET_VALUE = fmet this.GET_LAST_PRICE([L]ITMREF, [L]STOFCY)                                   # Last price
    When 4 : [L]ARET_VALUE = fmet this.GET_AVC([L]ITMREF, [L]STOFCY)                                          # Average Cost
    When 5 : [L]ARET_VALUE = fmet this.GET_FIFO([L]ITMREF, [L]STOFCY, [L]QTY, 0)                              # FIFO
    When 6 : [L]ARET_VALUE = fmet this.GET_ALC([L]ITMREF, [L]STOFCY, [L]LOT, [L]SLO)                          # Average Lot Cost
    When 8 : [L]ARET_VALUE = fmet this.GET_LIFO([L]ITMREF, [L]STOFCY, [L]QTY, 0)                              # LIFO
    When 9 : [L]ARET_VALUE = fmet this.GET_LAST_PUR([L]ITMREF, [L]STOFCY)                                     # Last purchase price
    When 10: [L]ARET_VALUE = fmet this.GET_STD_BUD([L]ITMREF, [L]STOFCY, [L]ECCMAJ, [L]ECCMIN, [L]DAT, 0, 0)  # Budgeted Standard
    When 11: [L]ARET_VALUE = fmet this.GET_STD_SIM([L]ITMREF, [L]STOFCY, [L]ECCMAJ, [L]ECCMIN, [L]DAT, 0, 0)  # Simulated Standard
  Endcase

Return

#**********************************************************
#* Average and lot average cost related functions
#*!
# Average Cost
$GET_AVC
# Input parameters:
# Char ITMREF
# Char STOFCY

  this.ITMREF = [L]ITMREF
  this.STOFCY = [L]STOFCY
  this.CUR    = fmet this._GETCPYCUR([L]STOFCY)

  this.DECCST = func ASYRFNC.ACTIV("SPD")

  # Attention: Si c'est positionné il ne faut pas relire
  # car en régul de sortie on écrase les valeurs de PMP par ce qu'on attend
  Local File ITMMVT [PRI]
  Read [PRI] ITV0=[L]ITMREF;[L]STOFCY
  If fstat
      # Si on est en entrée, c'est une création de lot
      # sinon c'est qu'il y a une grosse erreur dans les stocks
    Raz [F:PRI]
  Endif

  Gosub CALCAVG

  [L]ARET_VALUE = this.PRI

Return

# Average Lot Cost
$GET_ALC
# Input parameters:
# Char ITMREF
# Char STOFCY
# Char LOT
# Char SLO

  this.ITMREF = [L]ITMREF
  this.STOFCY = [L]STOFCY
  this.CUR    = fmet this._GETCPYCUR([L]STOFCY)

  this.DECCST = func ASYRFNC.ACTIV("SPD")

  Local File STOLOTFCY [PRI]

  If [L]LOT=""
    For [PRI] Where ITMREF=[L]ITMREF & STOFCY=[L]STOFCY
      Break
    Next
  Else
    Read [PRI]SLF0=[L]ITMREF;[L]LOT;[L]SLO;[L]STOFCY
    If fstat
      # Si on est en entrée, c'est une création de lot
      # sinon c'est qu'il y a une grosse erreur dans les stocks
      Raz [F:PRI]
    Endif
  Endif

  Gosub CALCAVG

  [L]ARET_VALUE = this.PRI

Return

$CALCAVG
  Local Decimal LPRI
  Local Integer IRET

  If [F:PRI]AVCBASQTY<>0 & [F:PRI]AVCBASAMT<>0
    [L]LPRI = [F:PRI]AVCBASAMT/[F:PRI]AVCBASQTY
  Else
    [L]LPRI = [F:PRI]AVC
  Endif

  this.PRI = [L]LPRI

  If this.DECCST
    If [F:PRI]AVCBASQTY<>0 & [F:PRI]AVCBASAMT<>0    # Si on a une base montant=0 et le PMP <>0 => il faut prendre le PMP
      IRET = fmet this._LOADDETAIL("[F:PRI]", "A", "CST", 1/[F:PRI]AVCBASQTY)
    Else
      IRET = fmet this._LOADDETAIL("[F:PRI]", "A", "AVC", 1)
    Endif
  Else
    IRET = fmet this._LOADPRICE([L]ITMREF)
  Endif

Return

#**********************************************************
#* Standard cost related methods
#*!
# Standard Price
$GET_STD
# Char ITMREF
# Char STOFCY
# Char ECCMAJ
# Char ECCMIN
# Char DAT
# Long Int UID

  this.ITMREF = [L]ITMREF
  this.STOFCY = [L]STOFCY
  this.CUR    = fmet this._GETCPYCUR([L]STOFCY)

  this.DECCST = func ASYRFNC.ACTIV("SPD")
  this.CSTMETHOD = 1
  Gosub CALCSTD

  [L]ARET_VALUE = this.PRI

Return

# Revised standard price
$GET_STD_REV
# Char ITMREF
