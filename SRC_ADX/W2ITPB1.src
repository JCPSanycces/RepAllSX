#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITPB1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_ZPCU
Onevent BEFORE_AREA Gosub AV_ZPCU From W2ITPB1
Return

$AV_ZPCU
Call LECTEXTRA(zc,"TABUNIT","DES",num$([M]PCU(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_PCUSTUCOE
Onevent BEFORE_AREA Gosub AV_PCUSTUCOE From W2ITPB1
Return

$AV_PCUSTUCOE
zc = arr([M]PCUPUUCOE*[M]PUUSTUCOE,10^-6)
Gosub _AFF
Return

$ON_QUAFLG
Onevent INIT_AREA Call D_QUAFLG(zc) From W2ITPB1
Return

Subprog D_QUAFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]QUAFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_BOMALT
Return

$ON_ZBOMALT
Onevent BEFORE_AREA Gosub AV_ZBOMALT From W2ITPB1
Return

$AV_ZBOMALT
Call LECTEXTRA(zc,"TABBOMALT","TBODESAXX","3",num$([M]BOMALT(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


