#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(30)(1..2)
Local Date VALEUR
Call SAISIE_DAT(VALEUR,PARAM,"FMDTDAT","MDTDAT","") From GSAISIE
End

#################################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "FINSAI"       : Gosub FINSAI
 When Default
Endcase
Return

$OUVRE
If clalev([F:HMDT])=0 : Local File HISTOMDT [HMDT] : Endif
Return

$AP_CHOIX
If REPONSE<>GSTAOK : Raz [M]ENDDAT : Endif
Return

$FINSAI
VALEUR = [M]ENDDAT
Return

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
# if records are found in HISTOMDT, the revocation date must be greater than or equal to the date of the most recent open item
# if no record is found in HISTOMDT, the revocation date must be greater than or equal to the signature date of the mandate
Filter [HMDT] Where CPY=[M:MDT0]CPY and UMRNUM=[M:MDT0]UMRNUM Order With "PAYDAT Desc"
If rowcount([HMDT])>0
 Read [HMDT] First
 If VALEUR<[HMDT]PAYDAT : GMESSAGE = mess(6,199,1) : mkstat=2 : Endif
Elsif VALEUR<[M:MDT1]SIGDAT
 GMESSAGE=mess(289,117,1)-format$("D:"+GFMDAT,[F:MDT]SIGDAT) : mkstat = 2
Endif
Filter [HMDT]
End
