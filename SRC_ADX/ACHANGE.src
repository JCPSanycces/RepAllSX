#<AdxTL>@(#)9.0.0.0 $Revision$
#Call DOSCHGCOD("TEST2","TEST2*") : End
#GBIDC1 = func ACHANGE.C("ADI","502~TCK") : Infbox GBIDC1 : End
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACHANGE","ACHANGE",4,"") From GTRAITE
End

#-------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
Endcase
Return

#------------------#
$INIT
$OUVRE_BATCH
Local Integer NBSES
Local Mask ACHANGE [ACHG]
Raz [M:ACHG]
If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
If clalev([F:ATX])>0 : Close Local File [ATX] : Endif
Return

#------------------#
$OUVRE
If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
Gosub OUVFIC
Return

#------------------#
$OUVFIC
If [M]APPLI<>""
 Local File =APPLI+".ACHANGE" [ACG] , =APPLI+".ATEXTRA" [AXX]
Else
 Local File ACHANGE [ACG] , ATEXTRA [AXX]
Endif
Return

#------------------#
$APRES_MODIF
Case zoncou
 When "APPLI"
  If clalev([F:ACG])>0 : Close Local File [ACG] : Endif
  If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
  [M]APPLI = zc
  Gosub OUVFIC
  Raz [M]INTIT
  Gosub CHARGE
  Affzo
Endcase
Return

#------------------#
$DEBUT
If nomap<>GDOSX3
 [M]APPLI = ""
 Affzo APPLI
 Diszo APPLI
Endif
Gosub CHARGE
[M]SIMUL = 2
Affzo
Return

#------------------#
$CHARGE
nolign = 0
For [ACG]ACG0(1) Where ENAFLG=2
 nolign += 1
 [M] = [F:ACG]
Next ACG
[M]NBLIG = nolign
Return

#------------------#
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1 : Return
Endif
If [M]NBLIG=0
 Call ERREUR(mess(20,124,1)) From GESECRAN : # Tableau vide
 SAI = 1 : Return
Endif
If !GBATCH & !GSERVEUR
 If [M]SIMUL<>2
  # Voulez-vous lancer la recodification de masse ?
  Call AVERTIR(mess(225,115,1),OK) From GESECRAN
  If OK<>2
   SAI = 1 : Return
  Endif
 Endif
 # Nombre d'utilisateurs connectés
 # Le changement de clé peut générer des conflits si les tables modifiées sont utilisées sur d'autres sessions
 # Voulez-vous continuer ?
 Call USER_NBCON_APP([M]APPLI,0,NBSES) From PSADX
 If NBSES>2
  Call AVERTIR(mess(150,124,1)-[M]APPLI-":"-num$(nbruser)+"\"+mess(226,115,1)+"\"+mess(205,100,1),OK) From GESECRAN
  If OK<>2 : SAI = 1 : Return : Endif
 Endif
Endif
Return

#------------------#
$EXEC
Local Char    TIT(50)

# Changement de clé/Simulation
TIT = mess(217,115,1)-string$([M]SIMUL=2,"("+mess(27,107,1)+")")-[M]APPLI
If !GSERVEUR
 TRA = 1
 Call OUVRE_TRACE(TIT) From LECFIC
 Call TEMPON("O") From GESECRAN
Else
 Call ECR_TRACE(TIT,0) From GESECRAN
Endif

Call CHANGE_ACG([M]APPLI,[M]COD,[M]SIMUL=2)

If !GSERVEUR
 Call TEMPOFF From GESECRAN
 Call FERME_TRACE From LECFIC
Endif
Return

#--------------------------------------------------------#
Subprog CHANGE_ACG(APPLI,COD,SIMUL)
Value Char APPLI, COD()(1..)
Value Integer SIMUL

Local Char    SYMBOLE(GLONASYM) , CHAMP(255) , FONC(250) , CHAINE(250)
Local Char    OBJET(30) , CLE(250) , CLE1(250) , CLE2(250)
Local Integer I , J , K , T , C , F , D , K , L , U , V , P , CHG , ER , OK

If [L]APPLI<>""
 Local File =[L]APPLI+".ACHANGE" [ACG2] , =[L]APPLI+".ATABZON" [ATZ] , =[L]APPLI+".ATABIND" [ATI]
Else
 Local File ACHANGE [ACG2] , ATABZON [ATZ] , ATABIND [ATI]
Endif

If [L]SIMUL
 Trbegin ADOVAL
Endif

Call ECR_TRACE(string$(30,"*")-mess(110,123,1),0) From GESECRAN : # Objets

For I=1 To dim([L]COD)
 If [L]COD(I)="" : Break : Endif
 Read [ACG2]ACG0(1) = [L]COD(I)
 If !fstat & [F:ACG2]ENAFLG=2
  # Code paramétrage changement de clé
  Call ECR_TRACE(mess(231,115,1)-[L]COD(I),0) From GESECRAN
  For [ACG2]ACG0 Where COD=[L]COD(I)
   Call CONTOBJ([L]APPLI,[F:ACG2]OBJ,[F:ACG2]CLE1,[F:ACG2]CLE2,[F:ACG2]NEWCOD,SYMBOLE,OK)
   If OK
    Call CHANGE([L]APPLI,[F:ACG2]OBJ,[F:ACG2]CLE1,[F:ACG2]CLE2,[F:ACG2]NEWCOD,OK)
    If [L]APPLI<>""
     Unlock =SYMBOLE From =[L]APPLI
    Else
     Unlock =SYMBOLE
    Endif
   Endif
  Next ACG
 Endif
Next I

FONC = "func ACHANGE.C"
Call ECR_TRACE(string$(30,"*")-mess(233,115,1)-'"'+FONC+'"',0) From GESECRAN : # Formules

Gosub SET_TABFNC

For T=1 To NBTAB
 If [L]APPLI<>""
  Local File =[L]APPLI+"."+TABFNC(T) [FIC]
 Else
  Local File =TABFNC(T) [FIC]
 Endif
 For [FIC]
  CHG = 0
  For F=1 To NBFLD
   If TABNUM(F)=T
    D = evalue("dim([F:FIC]"+TABFLD(F)+")")
    If D=1
     CHAMP = evalue("[F:FIC]"+TABFLD(F))
     If instr(1,CHAMP,FONC)
      Gosub CHANGE_FONC
      If C : Assign "[F:FIC]"+TABFLD(F) With CHAMP : CHG += 1 : Endif
     Endif
    Else
     For L=0 To D-1
      CHAMP = evalue("[F:FIC]"+TABFLD(F)+"("+num$(L)+")")
      If instr(1,CHAMP,FONC)
       Gosub CHANGE_FONC
       If C : Assign "[F:FIC]"+TABFLD(F)+"("+num$(L)+")" With CHAMP : CHG += 1 : Endif
      Endif
     Next L
    Endif
   Endif
  Next F
  If CHG & ![L]SIMUL
   Rewrite [FIC]
   If fstat
    Call ERREUR(TABFNC(T),2) From DOSDIC
   Endif
  Endif
 Next FIC
 Close Local File [FIC]
Next T

If [L]SIMUL
 Rollback
Endif
End

#---------------------------------------------------------#
$CHANGE_FONC
C = 0
For I=1 To dim([L]COD)
 If [L]COD(I)="" : Break : Endif
 Read [ACG2]ACG0(1) = [L]COD(I)
 If !fstat & [F:ACG2]ENAFLG=2
  For [ACG2]ACG0 Where COD=[L]COD(I)
   K = instr(1,CHAMP,FONC)
   While K
    U = instr(K,CHAMP,"(")
    If !U : Break : Endif
    V = instr(U,CHAMP,",")
    If !V : Break : Endif
    P = instr(V,CHAMP,")")
    If !P : Break : Endif
    ER = 0
    Onerrgo ER
    OBJET = num$(evalue(seg$(CHAMP,U+1,V-1)))
    CLE   = num$(evalue(seg$(CHAMP,V+1,P-1)))
    Onerrgo
    If ER
     # Changement de clé impossible à réaliser sur cette formule
     Call ECR_TRACE(format$("KTv2:250X",CHAMP)+"\"+TABFNC(T)+"/"+TABFLD(F)-":"-mess(234,115,1),1) From GESECRAN
    Elsif OBJET=[F:ACG2]OBJ
     Call CLE2(OBJET,CLE,CLE1,CLE2)
     If CLE1=[F:ACG2]CLE1 & CLE2=[F:ACG2]CLE2
      CHAMP = left$(CHAMP,V+1)+func NEWCLE(OBJET,[F:ACG2]NEWCOD,CLE2)+right$(CHAMP,P-1)
      C += 1
     Endif
    Endif
    K = instr(K+1,CHAMP,FONC)
   Wend
  Next ACG2
 Endif
Next I
If C
 Onerrgo RIEN
 Call ECR_TRACE("|"+TABFNC(T)-TABFLD(F)-evalue(TABCLE(T))-"->"-CHAMP,0) From GESECRAN
 Onerrgo
Endif
Return

$RIEN
Resume

$ER
ER = errn
Resume

#----------------------------------------------------------------------------------#
# Subprog Changement de clé
#----------------------------------------------------------------------------------#
# CLE1   = clé primaire
# CLE2   = clesec1~clesec2~clesecn ($SETCLE From WOobjet)
# NEWCOD = clé primaire
#----------------------------------------------------------------------------------#

Subprog CHANGE(APPLI,OBJET,CLE1,CLE2,NEWCOD,OK)
Value Char APPLI , OBJET , CLE1 , CLE2 , NEWCOD
Variable Integer OK
Local Char     CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..16)
Local Char     OCLECUR1(GLONID1) , OCLECUR2(GLONID2)(0..16)
Local Char     PROGOBJ(GLONADC) , SUPP(250) , NEWCLE(250) , OLDCLE(250)
Local Char     CHAINE(250)
Local Integer  I , J , K , OK , OKTRT
PROGOBJ = "WO"+OBJET
If APPLI<>""
 Call EXISTE_ADX("",APPLI,PROGOBJ,OKTRT) From ORDSYS
 If OKTRT
  PROGOBJ = APPLI+"."+PROGOBJ
 Endif
Endif
Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ
If APPLI<>""
 Local File =APPLI+"."+NOMFIC
Else
 Gosub OUVFIC From =PROGOBJ
Endif
CLECUR1  = CLE1
OCLECUR1 = CLECUR1
OLDCLE   = CLECUR1
CHAINE   = CLE2
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>""
  If I=0
   OLDCLE += "/"
  Else
   OLDCLE +="~"
  Endif
  K = instr(1,CHAINE,"~")
  If K
   CLECUR2(I) = left$(CHAINE,K-1)
   CHAINE = right$(CHAINE,K+1)
  Else
   CLECUR2(I) = CHAINE
  Endif
  OLDCLE += CLECUR2(I)
  OCLECUR2(I) = CLECUR2(I)
 Endif
Next I
Call CHGCOD(APPLI,OBJET,CLECUR1,CLECUR2,NEWCOD,OK)
If !OK
 If GTRACE<>""
  OK = 0 : Call ECR_TRACE(OBJET-OLDCLE-":"-GMESSAGE,1) From GESECRAN
 Endif
Else
 NEWCLE = CLECUR1
 For I=0 To dim(CLESEC)-1
  If CLESEC(I)<>"" & CLESEC(I)<>CLELIG
   If I=0
    NEWCLE += "/"
   Else
    NEWCLE += "~"
   Endif
   NEWCLE += CLECUR2(I)
  Endif
 Next I
 Call CHGCOD(APPLI,OBJET,OBJET,OCLECUR1,OCLECUR2,CLECUR1,CLECUR2) From GOBJTXT
 Call CHGCOD(APPLI,OBJET,OCLECUR1,OCLECUR2,CLECUR1,CLECUR2) From SUBALI
 If GTRACE<>""
  Call ECR_TRACE(OBJET-OLDCLE-"->"-NEWCLE,0) From GESECRAN
 Endif
Endif
Close Local File
End

#--------------------------------------------------------------------#
Subprog CONTOBJ(APPLI,OBJET,CLE1,CLE2,NEWCOD,SYMBOLE,OK)
Value Char APPLI , OBJET , CLE1 , CLE2 , NEWCOD
Variable Char    SYMBOLE
Variable Integer OK
Local Integer I , K , OKTRT
Local Char    PROGOBJ(GLONADC) , OLDCLE(250)
Local Char    CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..16)
PROGOBJ = "WO"+OBJET
If APPLI<>""
 Call EXISTE_ADX("",APPLI,PROGOBJ,OKTRT) From ORDSYS
 If OKTRT
  PROGOBJ = APPLI+"."+PROGOBJ
 Endif
Endif
Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ
CLECUR1  = CLE1
OLDCLE   = CLE1
CHAINE   = CLE2
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>""
  If I=0
   OLDCLE += "/"
  Else
   OLDCLE +="~"
  Endif
  K = instr(1,CHAINE,"~")
  If K
   CLECUR2(I) = left$(CHAINE,K-1)
   CHAINE = right$(CHAINE,K+1)
  Else
   CLECUR2(I) += CHAINE
  Endif
  OLDCLE += CLE2(I)
 Endif
Next I
If NEWCOD=""
 If GTRACE<>""
  Call ECR_TRACE(OBJET-OLDCLE-"->"-mess(223,115,1),1) From GESECRAN : # Nouveau code vide
 Endif
 OK = 0 : End
Endif
If APPLI<>""
 Local File =APPLI+"."+NOMFIC
Else
 Gosub OUVFIC From =PROGOBJ
Endif
Call LECTURE(OBJET,CLE1,CLE2) From CONTOBJ
If fstat
 If GTRACE<>""
  Call ECR_TRACE(OBJET-OLDCLE-":"-mess(23,100,1),1) From GESECRAN : # Fiche inexistante
 Endif
 OK = 0 : End
Endif
Gosub SYMBOLE From GOBJET
If APPLI<>""
 Lock =SYMBOLE From =APPLI With lockwait=0
Else
 Lock =SYMBOLE With lockwait=0
Endif
If fstat
 If GTRACE<>""
  # Modification en cours sur un autre poste
  Call ECR_TRACE(OBJET-OLDCLE-":"-mess(10,100,1),1) From GESECRAN
 Endif
 OK = 0 : End
Endif
OK = 1
End

#--------------------------------------------------------------------#
Subprog CHGCOD(APPLI,OBJET,CLE1,CLE2,NEWCOD,OK)
Value    Char APPLI
Value    Char OBJET
Variable Char CLE1()
Variable Char CLE2()(1..)
Value    Char NEWCOD
Variable Integer OK
Local Char    VALBOUT(30), PARBOUT(250)(1..7)
Local Integer I , J
PARBOUT(1) = OBJET
PARBOUT(2) = CLE1
PARBOUT(3) = ""
For I=1 To dim(CLE2)
 If sum(CLE2)="" : Break : Endif
 If I>1 : PARBOUT(3) += "~" : Endif
 PARBOUT(3) += CLE2(I)
Next I
PARBOUT(4) = "1"    : # Status de retour
PARBOUT(5) = NEWCOD : # Nouveau code
PARBOUT(6) = "1"    : # Silence
PARBOUT(7) = APPLI
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","CHGCOD","CHGCOD",1,"XYCHGCOD") From GTRAITE
CLE1 = PARBOUT(2)
Raz CLE2 : J=1
While PARBOUT(3)<>""
 I = instr(1,PARBOUT(3),"~")
 If I
  CLE2(J) = left$(PARBOUT(3),I-1)
  PARBOUT(3) = right$(PARBOUT(3),I+1)
 Else
  CLE2(J) = PARBOUT(3)
  PARBOUT(3) = ""
 Endif
 J+=1
Wend
OK = val(PARBOUT(4))
End

#-----------------------------------------------------#
# Tables contenant les func ACHANGE.C
#-----------------------------------------------------#

$SET_TABFNC
Local Shortint MAXFIC , MAXZON
MAXFIC = 10
MAXFLD = 30
Local Char    TABFNC(GLONATB)(1..MAXFIC) , TABFLD(GLONAVA)(1..MAXFLD)
Local Char    TABLE(GLONATB) , TABCLE(200)(1..MAXFIC)
Local Integer TABNUM(1..MAXFLD)
Local Integer NBTAB , NBFLD
Raz NBTAB , NBFLD
For TABLE="GAUTACE","GAUTACED","GAUTACEF","TABFOR","ZZMB12345678"
 If filinfo(filpath("FIL",TABLE,"fde",[L]APPLI),0)>0 & NBTAB<dim(TABFNC)
  NBTAB += 1
  TABFNC(NBTAB) = TABLE
  TABCLE(NBTAB) = ""
  Read [ATI]NUMLIG=TABLE;1
  CHAINE = [F:ATI]DESCRIPT
  While CHAINE<>""
   I = instr(1,CHAINE,"+")
   J = instr(1,CHAINE,"-")
   If I & J
    I = min(I,J)
   Elsif J & !I
    I = J
   Endif
   If TABCLE(NBTAB)<>""
    TABCLE(NBTAB) += "+'-'+"
   Endif
   If I
    TABCLE(NBTAB) += "num$([F:FIC]"+left$(CHAINE,I-1)+")"
    CHAINE = right$(CHAINE,I+1)
   Else
    TABCLE(NBTAB) += "num$([F:FIC]"+CHAINE+")"
    CHAINE = ""
   Endif
  Wend
  For [ATZ]CODZONE Where CODFIC=TABFNC(NBTAB) & find(CODTYP,"AFR","AFF")
   If NBFLD<dim(TABFLD)
    NBFLD += 1
    TABNUM(NBFLD) = NBTAB
    TABFLD(NBFLD) = [F:ATZ]CODZONE
   Endif
  Next ATZ
 Endif
Next TABLE
Return

#----------------------------------------------------------------------------------#
# Funprog utilisé dans les formules (pièces auto)
#----------------------------------------------------------------------------------#
# CODE = cle1~cle2~clen (ordre des parties de clé de la table principale
#----------------------------------------------------------------------------------#

Funprog C(OBJET,CODE)
Value Char OBJET , CODE
Local Integer NBCLE , I , OKTRT , TYPGES
Local Char    PROGOBJ(GLONADC)
Local Char    CLE(GLONAVA)(1..16) , CHAINE(250) , CLE1(GLONID1) , CLE2(GLONID2)
If instr(1,CODE,"~")=0
 End CODE
Endif
If OBJET<>""
 PROGOBJ = "WO"+OBJET
 Call EXISTE_ADX("","",PROGOBJ,OKTRT) From ORDSYS
 If OKTRT
  Gosub NOMFIC From =PROGOBJ
  Gosub SETCLE From =PROGOBJ
 Else
  TYPGES = 1
 Endif
Else
 TYPGES = 1
Endif
CHAINE = CODE
NBCLE = 0
While CHAINE<>""
 NBCLE += 1
 I = instr(1,CHAINE,"~")
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Raz CLE1 , CLE2
Case NBCLE
 When 1
  CLE1 = CLE(1)
 When 2
  If TYPGES=3
   CLE1 = CLE(1) : CLE2 = CLE(2)
  Else
   CLE1 = CLE(2) : CLE2 = CLE(1)
  Endif
 When Default
  CLE1 = CLE(2) : CLE2 = CLE(1)
  For I=3 To NBCLE
   CLE2 += "~"+CLE(I)
  Next I
Endcase
End CLE1

#----------------------------------------------------------------------------------#
# Permet de retrouver la clé primaire et les clés secondaires
#----------------------------------------------------------------------------------#
# CODE = cle1~cle2~clen (ordre des parties de clé de la table principale
#----------------------------------------------------------------------------------#

Subprog CLE2(OBJET,CODE,CLE1,CLE2)
Value    Char OBJET , CODE
Variable Char CLE1 , CLE2
Local Integer NBCLE , I , OKTRT , TYPGES
Local Char    PROGOBJ(GLONADC)
Local Char    CLE(GLONAVA)(1..16) , CHAINE(250)
If instr(1,CODE,"~")=0
 CLE1 = CODE
 CLE2 = ""
Endif
If OBJET<>""
 PROGOBJ = "WO"+OBJET
 Call EXISTE_ADX("","",PROGOBJ,OKTRT) From ORDSYS
 If OKTRT
  Gosub NOMFIC From =PROGOBJ
  Gosub SETCLE From =PROGOBJ
 Else
  TYPGES = 1
 Endif
Else
 TYPGES = 1
Endif
CHAINE = CODE
NBCLE = 0
While CHAINE<>""
 NBCLE += 1
 I = instr(1,CHAINE,"~")
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Raz CLE1 , CLE2
Case NBCLE
 When 1
  CLE1 = CLE(1)
 When 2
  If TYPGES=3
   CLE1 = CLE(1) : CLE2 = CLE(2)
  Else
   CLE1 = CLE(2) : CLE2 = CLE(1)
  Endif
 When Default
  CLE1 = CLE(2) : CLE2 = CLE(1)
  For I=3 To NBCLE
   CLE2 += "~"+CLE(I)
  Next I
Endcase
End

#----------------------------------------------------------------------------------#
# Permet de reconstituer la clé à partir de la clé primaire et des clés secondaires
#----------------------------------------------------------------------------------#

Funprog NEWCLE(OBJET,NEWCOD,CLE2)
Value Char    OBJET
Variable Char NEWCOD
Value Char    CLE2
Local Integer NBCLE , I , OKTRT
Local Char    PROGOBJ(GLONADC)
Local Char    CLE(GLONAVA)(0..16) , CHAINE(250) , CLE1(GLONID1)
If OBJET<>""
 PROGOBJ = "WO"+OBJET
 Call EXISTE_ADX("","",PROGOBJ,OKTRT) From ORDSYS
 If OKTRT
  Gosub NOMFIC From =PROGOBJ
  Gosub SETCLE From =PROGOBJ
 Else
  TYPGES = 1
 Endif
Else
 TYPGES = 1
Endif
CHAINE = CLE2
NBCLE = 1
CLE(1) = NEWCOD
While CHAINE<>""
 NBCLE += 1
 I = instr(1,CHAINE,"~")
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Case NBCLE
 When 1
  NEWCOD = CLE(1)
 When 2
  If TYPGES=3
   NEWCOD = CLE(1)+"~"+CLE(2)
  Else
   NEWCOD = CLE(2)+"~"+CLE(1)
  Endif
 When Default
  NEWCOD = CLE(2)+"~"+CLE(1)
  For I=3 To NBCLE
   NEWCOD += "~"+CLE(I)
  Next I
Endcase
End NEWCOD

#----------------------------------------------------------------------------------#
# Subprog Changement de clé appelé depuis la validation de dossier
#----------------------------------------------------------------------------------#

Subprog DOSCHGCOD(APPLI,PATTERN)
Value Char APPLI , PATTERN
Local Integer I , OK , SIMUL
Local Char    TIT(50) , SYMBOLE(GLONASYM) , CRITERE(250) , COD(GLONACG)(1..1000)
SIMUL = 0
# Changement de clé/Simulation
TIT = mess(217,115,1)-string$(SIMUL<>0,"("+mess(27,107,1)+")")-APPLI
Call ECR_TRACE(TIT,0) From GESECRAN
If APPLI<>""
 Local File =APPLI+".ACHANGE" [ACG2]
Else
 Local File ACHANGE [ACG2]
Endif
CRITERE = "ENAFLG=2"
If PATTERN<>""
 If instr(1,PATTERN,"?") or instr(1,PATTERN,"*")
  CRITERE -= '& pat(COD,"'+PATTERN+'")'
 Else
  CRITERE -= '& left$(COD,'+num$(len(PATTERN))+')="'+PATTERN+'"'
 Endif
Endif
I = 0
For [ACG2]ACG0(1) Where evalue(CRITERE)
 I += 1
 COD(I) = [F:ACG2]COD
Next ACG2
Call CHANGE_ACG(APPLI,COD,SIMUL<>0)
End

