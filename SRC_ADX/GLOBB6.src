$CAL_CLORE_EXERCICE_AMT
  If not ([M:DIV]BCUME_1)
  [F:DEPC]EXCDPR     = [F:DEPC]PERCLOEXC  + [F:DEPC]PEREXCDPR    : # Cum E-1 Amt. Except.
  [F:DEPC]EXCDPRT    = [F:DEPC]PERCLOEXCT + [F:DEPC]PEREXCDPRT   : # Cum E-1 Amt. Except. Théo.
  [F:DEPC]EXCDPRI    = [F:DEPC]PERCLOEXCI + [F:DEPC]PEREXCDPRI   : # Cum E-1 Amt. Except. Init.
  Endif
  [F:DEPS]MTCDEVADJ  = 0      : # Type gestion écart "Pas de changement de méthode"
  [F:DEPS]MTCDPEDEV  = 0      : # Ecart sur cumul E-1
  [F:DEPS]MTCDPEDEVI = 0      : # Ecart sur cumul E-1 Init
  [F:DEPS]MTCDPEDEVT = 0      : # Ecart sur cumul E-1 Théo
  [F:DEPS]MTCTIATYP  = 0      : # Prise d'effet du changement de méthode
  [F:DEPS]MTCTIADAT = [0/0/0] : # Date d'effet du changement de méthode
  [F:DEPS]MTCDPEDAT = [0/0/0] : # Date du changement de méthode
  [F:DEPS]PERREFCLC  = func GLOBB9.CAL_DAT_PLUS( [F:DEPC]FIYENDDAT, 1, "D" )     : # Début exercice
  [F:DEPS]PERREFCLCT = [F:DEPS]PERREFCLC
  [F:DEPS]PERREFCLCI = [F:DEPS]PERREFCLC
  [F:DEPS]DPRCUMFLG  = G_OUI                                                  : # Cum E-1 forcé
  [F:DEPS]DPRCUM     = [F:DEPC]DPRCUM     + [F:DEPC]ENDDPE  + [F:DEPC]EXCDPR  : # Entretien Cum E-1
  [F:DEPS]EXECLOCUMT = [F:DEPC]EXECLOCUMT + [F:DEPC]ENDDPET + [F:DEPC]EXCDPRT : # Cum E-1 Théorique
  [F:DEPS]EXECLOCUMI = [F:DEPC]EXECLOCUMI + [F:DEPC]ENDDPEI + [F:DEPC]EXCDPRI : # Cum E-1 Initial
  [F:DEPS]PERCLOCUM  = 0                                                    : # 0-> Cum P-1
  [F:DEPS]PERCLOCUMT = 0                                                    : # 0-> Cum P-1 Théo.
  [F:DEPS]PERCLOCUMI = 0                                                    : # 0-> Cum P-1 Init.
  [F:DEPS]ENDDPE     = 0                                                    : # 0-> Dot Exe
  [F:DEPS]ENDDPET    = 0                                                    : # 0-> Dot Exe Théo.
  [F:DEPS]ENDDPEI    = 0                                                    : # 0-> Dot Exe Init.
  [F:DEPS]ENDDPEFLG  = G_NON                                                : # Dot Exe non forcée
  [F:DEPS]PERCLOEXC  = 0                                                    : # 0-> Cum P-1 Amt. Except. Reel.
  [F:DEPS]PERCLOEXCT = 0                                                    : # 0-> Cum P-1 Amt. Except. Théo.
  [F:DEPS]PERCLOEXCI = 0                                                    : # 0-> Cum P-1 Amt. Except. Init.
  [F:DEPS]EXCCUM     = [F:DEPC]EXCCUM     + [F:DEPC]EXCDPR                  : # Cum E-1 Amt. Except.
  [F:DEPS]EXCCUMT    = [F:DEPC]EXCCUMT    + [F:DEPC]EXCDPRT                 : # Cum E-1 Amt. Except. Théo.
  [F:DEPS]EXCCUMI    = [F:DEPC]EXCCUMI    + [F:DEPC]EXCDPRI                 : # Cum E-1 Amt. Except. Init.
  [F:DEPS]EXCDPR     = 0                                                    : # 0-> Amt Exc.
  [F:DEPS]EXCDPRT    = 0                                                    : # 0-> Amt Exc. Théo.
  [F:DEPS]EXCDPRI    = 0                                                    : # 0-> Amt Exc. Init.
  [F:DEPS]CRBCUM     = [F:DEPC]CRBCUM     + [F:DEPC]CRBAMT                  : # Entretien Cum E-1
  [F:DEPS]CRBCUMFLG  = G_OUI                                              : # Cum E-1 forcé
  [F:DEPS]CRBAMT     = 0                                                    : # 0-> Réint. Exe
  [F:DEPS]ALWCUM    = [F:DEPC]ALWCUM + [F:DEPC]ALWAMT   : # Entretien Cum E-1 Aides Fiscales
  [F:DEPS]ALWCUMFLG = G_OUI                             : # Cumul E-1 Aides Fiscales forcée
  [F:DEPS]ALWAMT    = 0                                 : # Aides Fiscales
  [F:DEPS]ALWAMTFLG = G_NON                             : # Aides fiscales non forcée
  If ([F:DEPC]ALWCOD = GVML_RPDED40 and [F:WFAS]ISSDAT = [0/0/0] ) Then
    If ( func GLOBB9.CAL_DAT_INSIDE([F:DEPC]ENDDPRDAT, [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT, "I") ) Then
      If ( abs([M:DIV2]GLODED40) > abs([F:DEPC]ALWCUM + [F:DEPC]ALWAMT) ) Then
        [F:DEPS]ALWAMT = [M:DIV2]GLODED40 - ([F:DEPC]ALWCUM + [F:DEPC]ALWAMT)
      Endif
    Endif
  Endif
    [F:DEPS]PERQTYCUM  = 0                              : # Réinit. UO Cum P-1
    [F:DEPS]FIYQTY     = 0                              : # Réinit. UO Exercice
  Local Decimal RVACRBIML : # Reprise de réévaluation suite à dépréciation
  RVACRBIML = func TRTFASIML.GET_RVARVE
&             ([F:DEPC]IML, [F:DEPC]EXERVADEV+[F:DEPC]PERRVADEV-[F:DEPC]RVACRB)
  [F:DEPS]EXERVADEV = [F:DEPC]EXERVADEV + [F:DEPC]PERRVADEV + [F:DEPC]RVAAMT
&                   - [F:DEPC]RVACRB    - RVACRBIML
  [F:DEPS]PERRVACUM = 0
  [F:DEPS]PERRVADEV = 0
  [F:DEPS]RVATIADAT = 0
  [F:DEPS]EXEIMLCUM = [F:DEPC]EXEIMLCUM   + [F:DEPC]PERIMLCUM  + [F:DEPC]IML
  [F:DEPS]EXERVECUM = [F:DEPC]EXERVECUM   + [F:DEPC]PERRVECUM  + [F:DEPC]IMLRVE
  [F:DEPS]EXETRFCUM = [F:DEPC]EXETRFCUM   + [F:DEPC]PERTRFCUM  + [F:DEPC]IMLRVETRF
  [F:DEPS]PERIMLCUM = 0
  [F:DEPS]PERRVECUM = 0
  [F:DEPS]PERTRFCUM = 0
  If ( [M:DIV]DIFTYP = GVML_DFBENEF or [M:DIV]DIFRGL = GVML_RGREPDR  ) Then
    [F:DEPS]DFDBLC    = 0
  Else
    [F:DEPS]DFDBLC    = [F:DEPC]DFDBLC + [F:DEPC]DFD - [F:DEPC]DFDRVE
  Endif
  [F:DEPS]DFD       = 0
  [F:DEPS]DFDRVE    = 0
  Raz [M:DIV]PRVCUME_1R
  Raz [M:DIV]PRVCUME_1I
  Raz [M:DIV]PRVCUME_1T
  If ( find([F:DEPC]DPM, G_DPMCR, G_DPMLR,  G_DPMSR, G_DPMUR, G_DPMDR) <> 0) Then
    [F:DEPS]KFIYNBMSTP = 0
    If ( [M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0 ) Then
      If ( [F:WFAS]KPSEPLN <> "" and val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1)) = G_OUI) Then
        If ( [F:PSE]ACTFLG(month([F:DEPS]PERSTRDAT)-1) = G_OUI ) Then
          [F:DEPS]KFIYNBMSTP = 1
        Endif
      Else
        [F:DEPS]KFIYNBMSTP = 1
      Endif
    Endif
  Endif
  If ( find([F:DEPC]DPM, G_DPMRL, G_DPMRX,  G_DPMRD) <> 0) Then
    [F:DEPS]KFIYNBMSTP = 0
    If ( find([F:DEPC]KSTPDEPSTA, GVML_SSSTOPD, GVML_SSRSTDI, GVML_SSRSTPR) <> 0 ) Then
      [F:DEPS]KFIYNBMSTP = 1
    Endif
  Endif
  If ([M:DIV]BACTKPL) Then
    If ( [F:DEPC]KMDRDAT <> [0/0/0] and [F:DEPC]KMDRDAT < [F:DEPC]FIYENDDAT + 1 ) Then
      [F:DEPS]KMDRDAT = [0/0/0]
    Endif
  Endif
  If ( [F:DEPC]RVATIADAT = GVML_ERENDEX ) Then
    If ( [F:DEPC]RVATYP = GVML_MODVMA ) Then
      [F:DEPS]DPRBAS     = [F:DEPC]NBV
      [F:DEPS]DPRCUM     = 0
      [F:DEPS]EXECLOCUMT = 0
      [F:DEPS]NBV        = [F:DEPC]NBV
      [F:DEPS]NBVT       = [F:DEPC]NBVT
      [F:DEPS]EXETRFCUM  = 0
      [F:DEPS]EXEIMLCUM  = 0
      [F:DEPS]EXERVECUM  = 0
      [F:DEPS]IMLBLC     = 0
      [F:DEPS]DPM       = [M:DPM]DPMRSD   ([M:DIV]INDMOD-1)
      If ( find([F:DEPC]DPM, G_DPMHL, G_DPMHD, G_DPMRE, G_DPMUL, G_DPMUD, G_DPMTD) = 0 ) Then
        [F:DEPS]PRATYP  = [M:DPM]PRODPMRSD([M:DIV]INDMOD-1)
      Else
        [F:DEPS]PRATYP  = [F:DEPC]PRATYP
      Endif
      If ( [F:DEPS]DPM <> G_DPMML ) Then
        [F:DEPS]PERREFCLC = func GLOBB9.CAL_DAT_PLUS( [F:DEPC]PERENDDAT, 1, "D" )
      Endif
    Else
      Local Decimal XCUME_1R, XCUMP_1R, XDPER, XEXCE_1R, XEXCP_1R, XEXCR
      Local Decimal XCUME_1T, XCUMP_1T, XDPET, XEXCE_1T, XEXCP_1T, XEXCT
      Local Decimal XTRFE_1,  XTRFP_1,  XTRF,  XIMLE_1,  XIMLP_1,  XIML, XRVEE_1, XRVEP_1, XRVE
      Local Decimal XIMLBLC, XNBV, XRVAAMT
      Call  CAL_RVACOE_ENDFIY ( [F:DEPC]RVACOE, [M:DIV]CUR, [F:DEPC]NBV-[F:DEPC]RVAAMT,
&               [F:DEPC]DPRBAS, [F:DEPC]DPRCUM,     [F:DEPC]PERCLOCUM,  [F:DEPC]PERENDDPE,
&                               [F:DEPC]EXCCUM,     [F:DEPC]PERCLOEXC,  [F:DEPC]PEREXCDPR,
&                               [F:DEPC]EXECLOCUMT, [F:DEPC]PERCLOCUMT, [F:DEPC]DPET,
&                               [F:DEPC]EXCCUMT,    [F:DEPC]PERCLOEXCT, [F:DEPC]PEREXCDPRT,
&                               [F:DEPC]EXETRFCUM,  [F:DEPC]PERTRFCUM,  [F:DEPC]IMLRVETRF,
&                               [F:DEPC]EXEIMLCUM,  [F:DEPC]PERIMLCUM,  [F:DEPC]IML,
&                               [F:DEPC]EXERVECUM,  [F:DEPC]PERRVECUM,  [F:DEPC]IMLRVE,
&               [F:DEPS]DPRBAS, XCUME_1R, XCUMP_1R, XDPER, XEXCE_1R, XEXCP_1R, XEXCR,
&                               XCUME_1T, XCUMP_1T, XDPET, XEXCE_1T, XEXCP_1T, XEXCT,
&                               XTRFE_1,  XTRFP_1,  XTRF,  XIMLE_1,  XIMLP_1,  XIML, XRVEE_1, XRVEP_1, XRVE,
&                               XIMLBLC, XNBV, XRVAAMT )
      If ([F:DEPC]RVAAMT <> XRVAAMT) Then
        [M:DIV]ERRID = 46 : Call ERRFND From   GLOBB0  : # Dépilement suite à erreur logique
        Return
      Else
        [F:DEPS]DPRCUM     = XCUME_1R + XCUMP_1R + XDPER + XEXCP_1R + XEXCR
        [F:DEPS]EXCCUM     = XEXCE_1R + XEXCP_1R + XEXCR
        [F:DEPS]EXECLOCUMT = XCUME_1T + XCUMP_1T + XDPET + XEXCP_1T + XEXCT
        [F:DEPS]EXCCUMT    = XEXCE_1T + XEXCP_1T + XEXCT
        [F:DEPS]EXEIMLCUM  = XIMLE_1  + XIMLP_1 + XIML
        [F:DEPS]EXERVECUM  = XRVEE_1  + XRVEP_1 + XRVE
        [F:DEPS]EXETRFCUM  = XTRFE_1  + XTRFP_1 + XTRF
      Endif
    Endif
  Endif
  [M:DIV]ECACUME_1R = 0
  [M:DIV]ECACUME_1T = 0
  [M:DIV]ECACUME_1I = 0
Return
$CAL_CLORE_PERIODE_AMT
  If ( [F:DEPC]MTCTIATYP <> GVML_PEDBPE  and
&      [F:DEPC]MTCDEVADJ <> GVML_RDOTPER and [F:DEPC]MTCDEVADJ <> GVML_REXCPER and
&      [F:DEPC]MTCDEVADJ <> GVML_RDOTEXE and [F:DEPC]MTCDEVADJ <> GVML_REXCEXE ) Then
    [F:DEPS]MTCTIATYP = 0
    [F:DEPS]MTCTIADAT = [0/0/0]
  Endif
  Case [F:DEPC]MTCDEVADJ
    When GVML_RREPAN
      [F:DEPS]MTCDEVADJ  = 0      : # Type gestion écart "Pas de changement de méthode"
      [F:DEPS]MTCDPEDEV  = 0      : # Ecart sur cumul E-1
      [F:DEPS]MTCDPEDEVI = 0      : # Ecart sur cumul E-1 Init
      [F:DEPS]MTCDPEDEVT = 0      : # Ecart sur cumul E-1 Théo
  Endcase
  [F:DEPS]MTCDPEDAT = [0/0/0]
  [F:DEPS]PERCLOCUM   = [F:DEPC]PERCLOCUM    +  [F:DEPC]PERENDDPE
  [F:DEPS]PERCLOCUMT  = [F:DEPC]PERCLOCUMT   +  [F:DEPC]DPET
  [F:DEPS]PERCLOCUMI  = [F:DEPC]PERCLOCUMI   +  [F:DEPC]DPEI
  [F:DEPS]PERCLOEXC   = [F:DEPC]PERCLOEXC    +  [F:DEPC]PEREXCDPR
  [F:DEPS]PERCLOEXCT  = [F:DEPC]PERCLOEXCT   +  [F:DEPC]PEREXCDPRT
  [F:DEPS]PERCLOEXCI  = [F:DEPC]PERCLOEXCI   +  [F:DEPC]PEREXCDPRI
  [F:DEPS]PERENDDPE= 0
  [F:DEPS]PERDPEFLG= G_NON
  [F:DEPS]DPET = 0
  [F:DEPS]DPEI = 0
  [F:DEPS]PEREXCDPR  = 0
  [F:DEPS]PEREXCDPRT = 0
  [F:DEPS]PEREXCDPRI = 0
  If ( [F:DEPC]DPM = G_DPMUO or  [F:DEPC]DPM = G_DPMUR ) Then
    [F:DEPS]PERQTYCUM  = [F:DEPC]PERQTYCUM + [F:DEPC]PERQTY : # UO Cum P-1    (+ UO Période)
    [F:DEPS]RSDQTY     = [F:DEPC]RSDQTY    - [F:DEPC]PERQTY : # UO Résiduelle (- UO Periode)
    [F:DEPS]PERQTY     = 0                              : # Réinit. UO Periode
  Endif
  Local Decimal RVACRBIML : # Reprise de réévaluation suite à dépréciation
  RVACRBIML = func TRTFASIML.GET_RVARVE
&             ([F:DEPC]IML, [F:DEPC]EXERVADEV+[F:DEPC]PERRVADEV-[F:DEPC]RVACRB)
  [F:DEPS]PERRVACUM = [F:DEPC]PERRVACUM + [F:DEPC]RVAAMT
  [F:DEPS]PERRVADEV = [F:DEPC]PERRVADEV + [F:DEPC]RVAAMT - [F:DEPC]RVACRB - RVACRBIML
  [F:DEPS]RVAAMT    = 0                  # : Réevaluation à 0
  [F:DEPS]RVACRB    = 0                  # : Repr. réev.  à 0
  [F:DEPS]RVADAT    = [0/0/0]            # : Date de Réevaluation
  [F:DEPS]RVATYP    = 0                  # : Type de Réevaluation
  [F:DEPS]RVACOE    = 0                  # : Coef de Réevaluation
  [F:DEPS]RVACOEREF = ""                 # : Référence Coef de Réevaluation
  [F:DEPS]RVATIADAT = 0
  If (([M:DIV]BSRA and [F:DEPC]PERSTRDAT = [M:FIY]DATSTRPER([M:DIV]FPC-1) ) or
&     ([F:WFAS]ISSDAT <> [0/0/0] and [F:DEPC]IMLBLC <> 0 and
&      [F:WFAS]ISSDAT >= [F:DEPC]PERSTRDAT and [F:WFAS]ISSDAT <= [F:DEPC]PERENDDAT ) ) Then
    [F:DEPS]IMLBLC = [F:DEPC]IMLBLC + [F:DEPC]IML - [F:DEPC]IMLRVE - [F:DEPC]IMLRVETRF
&                  - [F:WFAS]IMLRVEISS([F:DEPC]DPRPLN-1)
  Else
    [F:DEPS]IMLBLC = [F:DEPC]IMLBLC + [F:DEPC]IML - [F:DEPC]IMLRVE - [F:DEPC]IMLRVETRF
  Endif
  If ( [F:DEPC]IML <> 0 or [F:DEPC]IMLRVE <> 0  ) Then
    [F:DEPS]DPM       = [M:DPM]DPMRSD   ([M:DIV]INDMOD-1)
    If ( find([F:DEPC]DPM, G_DPMHL, G_DPMHD, G_DPMRE, G_DPMUL, G_DPMUD, G_DPMTD, G_DPMTL) = 0 ) Then
      [F:DEPS]PRATYP  = [M:DPM]PRODPMRSD([M:DIV]INDMOD-1)
    Else
      [F:DEPS]PRATYP  = [F:DEPC]PRATYP
    Endif
    If ( [F:DEPS]DPM <> G_DPMML ) Then
      [F:DEPS]PERREFCLC = func GLOBB9.CAL_DAT_PLUS( [F:DEPC]PERENDDAT, 1, "D" )
    Endif
    [F:DEPS]PERIMLCUM = [F:DEPC]PERIMLCUM + [F:DEPC]IML
    [F:DEPS]PERRVECUM = [F:DEPC]PERRVECUM + [F:DEPC]IMLRVE
  Endif
  [F:DEPS]PERTRFCUM = [F:DEPC]PERTRFCUM + [F:DEPC]IMLRVETRF
  [F:DEPS]IMLRVETRF = 0                                      : # Repr. à 0
  [F:DEPS]IML       = 0                                      : # Dépr. à 0
  [F:DEPS]IMLFLG    = G_NON                                  : # Dépr. non forcée
  [F:DEPS]IMLRVE    = 0                                      : # Repr. à 0
  [F:DEPS]IMLRVEFLG = G_NON                                  : # Repr. non forcée
  [F:DEPS]IMLTYP    = 0                                      : # Type de dépréciation à 0
  [F:DEPS]EXTIMLTYP = ""                                     : # Pas de motif externe
  [F:DEPS]INTIMLTYP = ""                                     : # Pas de motif interne
  [F:DEPS]DPEDEV    = 0
  [F:DEPS]EXCDEV    = 0
  [F:DEPS]DERDEV    = 0
  [F:DEPS]DERRVEDEV = 0
  [F:DEPS]RVETRFDEV = 0
  [F:DEPS]RVACRBDEV = 0
  [F:DEPS]DPRCUMFLG = G_OUI
  [F:DEPS]FLGUPDISS = G_NON
  [F:DEPS]RSDDUR = 0
  If ( find([F:DEPC]DPM, G_DPMCR, G_DPMLR,  G_DPMSR, G_DPMUR, G_DPMDR) <> 0) Then
    If (  [M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0 ) Then
      If ( [F:WFAS]KPSEPLN <> "" and val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1)) = G_OUI) Then
        If ( [F:PSE]ACTFLG(month([F:DEPS]PERSTRDAT)-1) = G_OUI ) Then
          [F:DEPS]KFIYNBMSTP = [F:DEPC]KFIYNBMSTP + 1
        Endif
      Else
        [F:DEPS]KFIYNBMSTP = [F:DEPC]KFIYNBMSTP + 1
      Endif
    Endif
  Endif
  If ( find([F:DEPC]DPM, G_DPMRL, G_DPMRX,  G_DPMRD) <> 0) Then
    If ( find([F:DEPC]KSTPDEPSTA, GVML_SSTOSTP,GVML_SSSTOPD) <> 0 ) Then
      [F:DEPS]KFIYNBMSTP = [F:DEPC]KFIYNBMSTP + 1
    Endif
  Endif
  If ([M:DIV]BACTKPL) Then
    If (find([F:DEPC]DPM , G_DPMML, G_DPMMD) <> 0 and [F:DEPC]KMDRDEV <> 0 and [M:DIV]BMDR) Then
      If ( [F:DEPC]KMDRDAT < [F:DEPC]PERSTRDAT and [F:DEPC]KMDRDEV <> 0) Then
          [F:DEPS]KMDRDEV = 0
      Endif
      If ( [F:DEPC]KMDRDAT = [F:DEPC]PERSTRDAT and [F:DEPC]KMDRDEV <> 0) Then
          [F:DEPS]KMDRDEV = 0
      Endif
    Endif
  Endif
Return
Subprog  CAL_PLAFOND_REPR_DEPRECIATION ( PVLNRFP, PVLNTFP, PSLDIML, RPLFRPRIML )
Value    Decimal PVLNRFP      : # Valeur nette "Reel"      fin de période
Value    Decimal PVLNTFP      : # Valeur nette "Théorique" fin de période
Value    Decimal PSLDIML      : # Solde de dépréciation    début de période
Variable Decimal RPLFRPRIML   : # Plafond de reprise de dépréciation
    If (  ( abs(PVLNTFP) > abs(PVLNRFP) )  and PSLDIML <> 0 ) Then
      RPLFRPRIML = PVLNTFP - PVLNRFP
    Else
      RPLFRPRIML = 0
    Endif
End
Subprog  CAL_REINT_VEH ( PCODREIVEH, PDOTEXE, PBASE, PCUMREI, PDTFNAMT, PDTDBEXE, PDTFNEXE,  RMNTREI )
Value    Char    PCODREIVEH   : # Code véhicule
Value    Decimal PDOTEXE      : # Dotation exercice
Value    Decimal PBASE        : # Base
Value    Decimal PCUMREI      : # Cumul du montant déjà réintégré
Value    Date    PDTFNAMT     : # Fin d'amortissement
Value    Date    PDTDBEXE     : # Début exercice
Value    Date    PDTFNEXE     : # Fin   exercice
Variable Decimal RMNTREI      : # Montant à réintégrer
Local Integer I_PLF
  RMNTREI = 0
  If ( PCODREIVEH <> "" and PDOTEXE <> 0 ) Then
    I_PLF = find (PCODREIVEH, [M:TAB]CODVEHPLF)
    If ( I_PLF <> 0 ) Then
      If ( PBASE <> 0 and abs(PBASE) > [M:TAB]VEHPLF(I_PLF-1))  Then
        RMNTREI = abs(PDOTEXE) * ( ( abs(PBASE) - [M:TAB]VEHPLF(I_PLF-1) ) / abs(PBASE) )
      Endif
    Else
    Endif
    [M:DIV]PV(0)= RMNTREI : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : RMNTREI = [M:DIV]RV(1)
    If ( RMNTREI <> 0 ) Then
    Endif
    If ( abs(PBASE) > [M:TAB]VEHPLF(I_PLF-1) and (abs(PCUMREI)+abs(RMNTREI)) > (abs(PBASE) - [M:TAB]VEHPLF(I_PLF-1)) ) Then
       RMNTREI = abs(PBASE)-[M:TAB]VEHPLF(I_PLF-1) - PCUMREI
    Endif
    If ( func GLOBB9.CAL_DAT_INSIDE(PDTFNAMT, PDTDBEXE, PDTFNEXE,"I") ) Then
       RMNTREI = abs(PBASE)-[M:TAB]VEHPLF(I_PLF-1) - PCUMREI
    Endif
    If ( abs(PBASE) < [M:TAB]VEHPLF(I_PLF-1) ) Then
       RMNTREI = abs(PCUMREI) * -1
    Endif
    If (PBASE < 0 and RMNTREI <> 0 ) Then : RMNTREI = RMNTREI * -1  : Endif
    If ( RMNTREI <> 0 ) Then
    Endif
  Endif
End
Subprog  CAL_RVACOE_ENDFIY ( PRVACOE, PCUR, PVALNET,
&                     PBASE, PCUME_1R, PCUMP_1R, PDPER, PEXCE_1R, PEXCP_1R, PEXCR,
&                            PCUME_1T, PCUMP_1T, PDPET, PEXCE_1T, PEXCP_1T, PEXCT,
&                            PTRFE_1 , PTRFP_1 , PTRF , PIMLE_1 , PIMLP_1 , PIML , PRVEE_1 , PRVEP_1 , PRVE,
&                     RBASE, RCUME_1R, RCUMP_1R, RDPER, REXCE_1R, REXCP_1R, REXCR,
&                            RCUME_1T, RCUMP_1T, RDPET, REXCE_1T, REXCP_1T, REXCT,
&                            RTRFE_1 , RTRFP_1 , RTRF , RIMLE_1 , RIMLP_1 , RIML , RRVEE_1 , RRVEP_1 , RRVE,
&                     RIMLBLC, RVALNET, RRVAAMT )
Value    Decimal PRVACOE      : # Coefficient de réévaluation
Value    Char    PCUR         : # Devise
Value    Decimal PVALNET      : # Valeur nette
Value    Decimal PBASE        : # Base
Value    Decimal PCUME_1R     : # Cumul Amt. E-1 Réel
Value    Decimal PCUMP_1R     : # Cumul Amt. P-1 Réel
Value    Decimal PDPER        : # Amt. Période Réel
Value    Decimal PEXCE_1R     : # Cumul Exc. E-1 Réel
Value    Decimal PEXCP_1R     : # Cumul Exc. P-1 Réel
Value    Decimal PEXCR        : # Exc. Période Réel
Value    Decimal PCUME_1T     : # Cumul Amt. E-1 Théorique
Value    Decimal PCUMP_1T     : # Cumul Amt. P-1 Théorique
Value    Decimal PDPET        : # Amt. Période Théorique
Value    Decimal PEXCE_1T     : # Cumul Exc. E-1 Théorique
Value    Decimal PEXCP_1T     : # Cumul Exc. P-1 Théorique
Value    Decimal PEXCT        : # Exc. Période Théorique
Value    Decimal PTRFE_1      : # Cumul E-1 Repr. Dépréc. transférée en Amort. Excpt.
Value    Decimal PTRFP_1      : # Cumul P-1 Repr. Dépréc. transférée en Amort. Excpt
Value    Decimal PTRF         : # Repr. Dépréc. transféré en Amort. Excpt Période
Value    Decimal PIMLE_1      : # Cumul Dépréciation E-1
Value    Decimal PIMLP_1      : # Cumul Dépréciation P-1
Value    Decimal PIML         : # Dépréciation Période
Value    Decimal PRVEE_1      : # Cumul Reprise Dépréciation E-1
Value    Decimal PRVEP_1      : # Cumul Reprise Dépréciation P-1
Value    Decimal PRVE         : # Reprise Dépréciation Période
Variable Decimal RBASE        : # Base
Variable Decimal RCUME_1R     : # Cumul Amt. E-1 Réel
Variable Decimal RCUMP_1R     : # Cumul Amt. P-1 Réel
Variable Decimal RDPER        : # Amt. Période Réel
Variable Decimal REXCE_1R     : # Cumul Exc. E-1 Réel
Variable Decimal REXCP_1R     : # Cumul Exc. P-1 Réel
Variable Decimal REXCR        : # Exc. Période Réel
Variable Decimal RCUME_1T     : # Cumul Amt. E-1 Théorique
Variable Decimal RCUMP_1T     : # Cumul Amt. P-1 Théorique
Variable Decimal RDPET        : # Amt. Période Théorique
Variable Decimal REXCE_1T     : # Cumul Exc. E-1 Théorique
Variable Decimal REXCP_1T     : # Cumul Exc. P-1 Théorique
Variable Decimal REXCT        : # Exc. Période Théorique
Variable Decimal RTRFE_1      : # Cumul E-1 Repr. Dépréc. transférée en Amort. Excpt.
Variable Decimal RTRFP_1      : # Cumul P-1 Repr. Dépréc. transférée en Amort. Excpt
Variable Decimal RTRF         : # Repr. Dépréc. transféré en Amort. Excpt Période
Variable Decimal RIMLE_1      : # Cumul Dépréciation E-1
Variable Decimal RIMLP_1      : # Cumul Dépréciation P-1
Variable Decimal RIML         : # Dépréciation Période
Variable Decimal RRVEE_1      : # Cumul Reprise Dépréciation E-1
Variable Decimal RRVEP_1      : # Cumul Reprise Dépréciation P-1
Variable Decimal RRVE         : # Reprise Dépréciation Période
Variable Decimal RIMLBLC      : # Solde de dépréciation
Variable Decimal RVALNET      : # Valeur nette
Variable Decimal RRVAAMT      : # Montant de la réévaluation
  RBASE     = PBASE
  RCUME_1R  = PCUME_1R
  RCUMP_1R  = PCUMP_1R
  RDPER     = PDPER
  REXCE_1R  = PEXCE_1R
  REXCP_1R  = PEXCP_1R
  REXCR     = PEXCR
  RCUME_1T  = PCUME_1T
  RCUMP_1T  = PCUMP_1T
  RDPET     = PDPET
  REXCE_1T  = PEXCE_1T
  REXCP_1T  = PEXCP_1T
  REXCT     = PEXCT
  RTRFE_1   = PTRFE_1
  RTRFP_1   = PTRFP_1
  RTRF      = PTRF
  RIMLE_1   = PIMLE_1
  RIMLP_1   = PIMLP_1
  RIML      = PIML
  RRVEE_1   = PRVEE_1
  RRVEP_1   = PRVEP_1
  RRVE      = PRVE
  If ( PRVACOE > 0 ) Then
    RBASE = PBASE * PRVACOE
    Call CAL_ARRONDI_MNT (RBASE , PCUR , RBASE) From   GLOBB8
    RCUME_1R = PCUME_1R * PRVACOE
    Call CAL_ARRONDI_MNT (RCUME_1R , PCUR , RCUME_1R) From   GLOBB8
    RCUMP_1R = PCUMP_1R * PRVACOE
    Call CAL_ARRONDI_MNT (RCUMP_1R , PCUR , RCUMP_1R) From   GLOBB8
    RDPER = PDPER * PRVACOE
    Call CAL_ARRONDI_MNT (RDPER , PCUR , RDPER) From   GLOBB8
    REXCE_1R = PEXCE_1R * PRVACOE
    Call CAL_ARRONDI_MNT (REXCE_1R , PCUR , REXCE_1R) From   GLOBB8
    REXCP_1R = PEXCP_1R * PRVACOE
    Call CAL_ARRONDI_MNT (REXCP_1R , PCUR , REXCP_1R) From   GLOBB8
    REXCR = PEXCR * PRVACOE
    Call CAL_ARRONDI_MNT (REXCR , PCUR , REXCR) From   GLOBB8
    RCUME_1T = PCUME_1T * PRVACOE
    Call CAL_ARRONDI_MNT (RCUME_1T , PCUR , RCUME_1T) From   GLOBB8
    RCUMP_1T = PCUMP_1T * PRVACOE
    Call CAL_ARRONDI_MNT (RCUMP_1T , PCUR , RCUMP_1T) From   GLOBB8
    RDPET = PDPET * PRVACOE
    Call CAL_ARRONDI_MNT (RDPET , PCUR , RDPET) From   GLOBB8
    REXCE_1T = PEXCE_1T * PRVACOE
    Call CAL_ARRONDI_MNT (REXCE_1T , PCUR , REXCE_1T) From   GLOBB8
    REXCP_1T = PEXCP_1T * PRVACOE
    Call CAL_ARRONDI_MNT (REXCP_1T , PCUR , REXCP_1T) From   GLOBB8
    REXCT = PEXCT * PRVACOE
    Call CAL_ARRONDI_MNT (REXCT , PCUR , REXCT) From   GLOBB8
    RTRFE_1 = PTRFE_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RTRFE_1 , PCUR , RTRFE_1) From   GLOBB8
    RTRFP_1 = PTRFP_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RTRFP_1 , PCUR , RTRFP_1) From   GLOBB8
    RTRF = PTRF * PRVACOE
    Call CAL_ARRONDI_MNT (RTRF , PCUR , RTRF) From   GLOBB8
    RIMLE_1 = PIMLE_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RIMLE_1 , PCUR , RIMLE_1) From   GLOBB8
    RIMLP_1 = PIMLP_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RIMLP_1 , PCUR , RIMLP_1) From   GLOBB8
    RIML = PIML * PRVACOE
    Call CAL_ARRONDI_MNT (RIML , PCUR , RIML) From   GLOBB8
    RRVEE_1 = PRVEE_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RRVEE_1 , PCUR , RRVEE_1) From   GLOBB8
    RRVEP_1 = PRVEP_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RRVEP_1 , PCUR , RRVEP_1) From   GLOBB8
    RRVE = PRVE * PRVACOE
    Call CAL_ARRONDI_MNT (RRVE , PCUR , RRVE) From   GLOBB8
    RIMLBLC      =  ( RIMLE_1 + RIMLP_1 + RIML ) - ( RRVEE_1 + RRVEP_1 + RRVE ) - ( RTRFE_1 + RRVEP_1 + RRVE )
    RVALNET = RBASE - (RCUME_1R + RCUMP_1R + RDPER) - (REXCP_1R + REXCR) - RIMLBLC
    RRVAAMT = RVALNET - PVALNET
  Endif
End
Subprog  CAL_SORTIE_TVA
Local Decimal WTVANR
Local Decimal WDURDET
Local Decimal WDURRES
  If ( [F:WFAS]ISSVATFLG <> G_OUI ) Then
    [F:WFAS]ISSVATAMT = [F:WFAS]ISSAMT(0) * ([F:WFAS]ISSVATRAT / 100.)
  Endif
  If ( [F:WFAS]ISSVATAMT <> 0 ) Then
  Endif
  [F:WFAS]ACGREVVAT = 0
  [F:WFAS]IASREVVAT = 0
  [F:WFAS]ACGCPLDED = 0
  [F:WFAS]IASCPLDED = 0
  [F:WFAS]ISSVATTRF  = 0
  [F:WFAS]ISSVATTRFI = 0
  Case [F:WFAS]PYBVATTYP
    When GVML_SNSREGU
    When GVML_RVTVA
      WDURDET = (year([F:WFAS]ISSDAT) - year([F:WFAS]VATREGDAT))+1
      WDURRES = [F:WFAS]THESLI - WDURDET
      [F:WFAS]ISSVATTRF = [F:WFAS]IVCVATAMT * (WDURRES / [F:WFAS]THESLI)
      [M:DIV]PV(0)= [F:WFAS]ISSVATTRF : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:WFAS]ISSVATTRF = [M:DIV]RV(1)
      If ( WDURRES > 0 and [F:WFAS]DEDVATAMT <> 0 ) Then
        [F:WFAS]ACGREVVAT = ((0 - [F:WFAS]DEDCOEF ) * [F:WFAS]IVCVATAMT ) * (WDURRES / [F:WFAS]THESLI)
        [M:DIV]PV(0)= [F:WFAS]ACGREVVAT : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:WFAS]ACGREVVAT = -[M:DIV]RV(1)
      Endif
      If ([M:DIV]PLNIAS) Then
        [F:WFAS]ISSVATTRFI = [F:WFAS]IVCVATAMTI * (WDURRES / [F:WFAS]THESLI)
        [M:DIV]PV(0)= [F:WFAS]ISSVATTRFI : [M:DIV]PC(0)= [F:WFAS]IASCUR
        Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:WFAS]ISSVATTRFI = [M:DIV]RV(1)
        If ( WDURRES > 0 and [F:WFAS]DEDVATAMTI <> 0 ) Then
          [F:WFAS]IASREVVAT = ((0 - [F:WFAS]DEDCOEF ) * [F:WFAS]IVCVATAMTI ) * (WDURRES / [F:WFAS]THESLI)
          [M:DIV]PV(0)= [F:WFAS]IASREVVAT : [M:DIV]PC(0)= [F:WFAS]IASCUR
          Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:WFAS]IASREVVAT = -[M:DIV]RV(1)
        Endif
      Endif
    When GVML_DEDCOMP
      WDURDET = year([F:WFAS]ISSDAT) - year([F:WFAS]VATREGDAT)+1
      WDURRES = [F:WFAS]THESLI - WDURDET
      If ( WDURRES > 0  and ([F:WFAS]IVCVATAMT - [F:WFAS]DEDVATAMT ) <> 0  ) Then
        [F:WFAS]ACGCPLDED = ((1 - [F:WFAS]DEDCOEF ) * [F:WFAS]IVCVATAMT ) * (WDURRES / [F:WFAS]THESLI)
        [M:DIV]PV(0)= [F:WFAS]ACGCPLDED : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:WFAS]ACGCPLDED = [M:DIV]RV(1)
      Endif
      If ([M:DIV]PLNIAS) Then
        If ( WDURRES > 0  and ([F:WFAS]IVCVATAMTI - [F:WFAS]DEDVATAMTI ) <> 0 ) Then
          [F:WFAS]IASCPLDED = ((1 - [F:WFAS]DEDCOEF ) * [F:WFAS]IVCVATAMTI ) * (WDURRES / [F:WFAS]THESLI)
          [M:DIV]PV(0)= [F:WFAS]IASCPLDED : [M:DIV]PC(0)= [F:WFAS]IASCUR
          Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:WFAS]IASCPLDED = [M:DIV]RV(1)
        Endif
      Endif
    When Default
  Endcase
  [M:DIV]PV(0)= [F:WFAS]ISSVATAMT : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:WFAS]ISSVATAMT = [M:DIV]RV(1)
  If ( [F:WFAS]ACGCPLDED<> 0 ) Then
  Endif
  If ( [F:WFAS]IASCPLDED <> 0 ) Then
  Endif
   If ( [F:WFAS]ACGREVVAT <> 0 ) Then
  Endif
   If ( [F:WFAS]IASREVVAT <> 0 ) Then
  Endif
End
Subprog  CAL_SORTIE_PMV
Local Decimal WVALNET
Local Decimal WPMV
  [F:WFAS]GAL   ([F:DEPC]DPRPLN-1) = 0
  [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = 0
  [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1) = 0
  If ( [F:DEPC]DPRPLN <>  G301SUB ) Then
    If ( [M:DIV]LEGSOC = "FRA" and  [F:DEPC]DPRPLN =  G301FIS and
&        [F:WFAS]PURDAT < [01/01/1977] and [F:DEPC]DPRBAS > [F:WFAS]GALREFBAS  ) Then
      If ( [F:WFAS]R76COE <> 0 ) Then
        WPMV = [F:WFAS]ISSAMT([F:DEPC]DPRPLN-1) - ( [F:DEPC]NBV / [F:WFAS]R76COE )
      Else
        WPMV = [F:WFAS]ISSAMT([F:DEPC]DPRPLN-1) - [F:DEPC]NBV
      Endif
    Else
      If ( [M:DIV]FLGTVAPMV = G_OUI ) Then
        If ( [F:DEPC]DPRPLN =  G301CPT or [F:DEPC]DPRPLN =  G301FIS or [F:DEPC]DPRPLN = G301MIN or
&            [F:DEPC]DPRPLN =  G301ORI or [F:DEPC]DPRPLN =  G301IAS ) Then
          If ( [F:DEPC]DPRPLN =  G301IAS ) Then
            WVALNET =  [F:DEPC]NBV - [F:WFAS]IASCPLDED + [F:WFAS]IASREVVAT
          Else
            WVALNET =  [F:DEPC]NBV - [F:WFAS]ACGCPLDED + [F:WFAS]ACGREVVAT
          Endif
        Else
            WVALNET =  [F:DEPC]NBV
        Endif
      Else
        WVALNET =  [F:DEPC]NBV
      Endif
      WPMV = [F:WFAS]ISSAMT([F:DEPC]DPRPLN-1) - WVALNET
    Endif
    [M:DIV]PV(0)= WPMV : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:WFAS]GAL([F:DEPC]DPRPLN-1) = [M:DIV]RV(1)
  Endif
  If ( [F:WFAS]GAL([F:DEPC]DPRPLN-1) <> 0 ) Then
  Endif
  If ( [M:DIV]LEGSOC = "FRA" and [F:DEPC]DPRPLN =  G301FIS and
&      find ([F:WFAS]ISSTYP, GVML_TSVENTE, GVML_TSREBUT, GVML_TSCIG, GVML_TSVOLDI) ) Then
    Call CAL_SORTIE_LT_CT  From   GLOBB6
  Endif
End
Subprog  CAL_SORTIE_LT_CT
Local Decimal WCUMAMTPRA
Local Date    W2ANS
  [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = 0
  [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1) = 0
  If ([M:DIV2]TAXRUL = GVML_TRCMPNY) Then
    [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
  Else
    W2ANS = func GLOBB9.CAL_DAT_PLUS( [F:WFAS]GALREFDAT, 2, "Y" )
    If ( [F:DEPC]DPM = G_DPMSA ) Then
      If ( [F:WFAS]ISSDAT < W2ANS ) Then
        [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
      Else
        [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
      Endif
    Else
      If ( [F:WFAS]ISSDAT < W2ANS ) Then
        [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
      Else
        If ( [F:WFAS]GAL([F:DEPC]DPRPLN-1) > 0 ) Then
          WCUMAMTPRA = [F:DEPC]DPRCUM + [F:DEPC]ENDDPE + [F:DEPC]EXCDPR
          If ( [F:WFAS]GAL([F:DEPC]DPRPLN-1) > WCUMAMTPRA ) Then
            [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = WCUMAMTPRA
            [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)- WCUMAMTPRA
          Else
            [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
          Endif
        Else
          [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
        Endif
      Endif
    Endif
  Endif
  If ( [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) <> 0 or [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1) <> 0 ) Then
  Endif
End
$CAL_LNK_FISC_MINI
   Local Decimal LECAFISMIN
  If ( [F:DEPC]DPRPLN = G301FIS and [M:DIV]PLNMIN  ) Then
    If ( abs([F:DEPC]DPRCUM) >
&        abs([M:PMIN]DPRCUM([M:DIV]DL-1)+[M:PMIN]ENDDPE([M:DIV]DL-1)+[M:PMIN]EXCDPR([M:DIV]DL-1)) ) Then
      WDOTMIN = 0
    Else
      Local Decimal WDOTMIN
      WDOTMIN = ( [M:PMIN]DPRCUM([M:DIV]DL-1) + [M:PMIN]ENDDPE([M:DIV]DL-1) + [M:PMIN]EXCDPR([M:DIV]DL-1) )
&             -   [F:DEPC]DPRCUM
      Endif
  Endif
  If ( [F:DEPC]DPRPLN = G301FIS and [M:DIV]PLNMIN and  !([M:DIV]BCUME_1)  ) Then
    If ( [F:DEPC]ALWCOD = GVML_RPALOGI ) Then
    Else
      If ( abs(WDOTMIN) > abs([F:DEPC]ENDDPE+[F:DEPC]EXCDPR ) and [F:DEPC]IMLBLC = 0 ) Then
        LECAFISMIN = ( WDOTMIN - ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR ) )
        If (  [F:WFAS]ISSDATRUL = GVML_IRVLNAE and ([F:DEPC]DPM = G_DPMSA or [M:DIV]DIFRGL = GVML_RGNODER)  ) Then
            [F:DEPC]EXCDPR += [M:PMIN]EXCDPR([M:DIV]DL-1)
            [M:DIV]AMTEXC   = [F:DEPC]EXCDPR
        Endif
        [M:DIV]DOTEXE    = [M:DIV]DOTEXE  + ( WDOTMIN - ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR ) )
        [F:DEPC]ENDDPE   = [F:DEPC]ENDDPE + ( WDOTMIN - ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR ) )
      Endif
    Endif
  Endif
  If ( [F:DEPC]DPRPLN = G301FIS and [M:DIV]PLNMIN and  !([M:DIV]BCUME_1)  ) Then
    If ( abs([F:DEPC]ENDDPE+[F:DEPC]EXCDPR) > abs(WDOTMIN) ) Then
      [F:DEPC]DFDLIM = ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR ) - WDOTMIN
    Else
      [F:DEPC]DFDLIM = 0.
    Endif
  Else
    [F:DEPC]DFDLIM = 0.
  Endif
  If ( [F:DEPC]DPRPLN = G301FIS and [M:DIV]PLNMIN and  !([M:DIV]BCUME_1)  ) Then
    [F:DEPC]DFD    = 0.
    [F:DEPC]DFDRVE = 0.
    If ( [F:DEPC]FIYSTRDAT = [M:FIY]DATSTRFIY ([M:DIV]FEC-1) ) Then
      Case [M:DIV]DIFTYP
        When GVML_DFAUCUN
        When GVML_DFBENEF
          If ( [F:DEPC]DFDLIM <> 0 ) Then
            Case [M:DIV]DIFRGL
              When GVML_RGPOURC
                [F:DEPC]DFD = [F:DEPC]DFDLIM * ( [M:DIV]DIFRAT / 100.)
                [M:DIV]PV(0)= [F:DEPC]DFD : [M:DIV]PC(0)= [M:DIV]CUR
                Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:DEPC]DFD = [M:DIV]RV(1)
              When GVML_RGNODER
                If ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR >
&                    [M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1) ) Then
                  [F:DEPC]DFD = ( [F:DEPC]ENDDPE              + [F:DEPC]EXCDPR              )
&                            - ( [M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1) )
                Endif
                If ( abs([F:DEPC]DFD) > abs([F:DEPC]DFDLIM) ) Then : [F:DEPC]DFD = [F:DEPC]DFDLIM : Endif
              When Default
            Endcase
          Endif
        When GVML_DFDEFIC
          If ( [F:DEPC]DFDLIM <> 0 ) Then
            Case [M:DIV]DIFRGL
              When GVML_RGPOURC
                [F:DEPC]DFD = [F:DEPC]DFDLIM * ( [M:DIV]DIFRAT / 100. )
                [M:DIV]PV(0)= [F:DEPC]DFD : [M:DIV]PC(0)= [M:DIV]CUR
                Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:DEPC]DFD = [M:DIV]RV(1)
              When GVML_RGNODER
                If ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR >
&                    [M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1) ) Then
                  [F:DEPC]DFD = ( [F:DEPC]ENDDPE              + [F:DEPC]EXCDPR              )
&                             - ( [M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1) )
                Endif
                If ( abs([F:DEPC]DFD) > abs([F:DEPC]DFDLIM) ) Then : [F:DEPC]DFD = [F:DEPC]DFDLIM : Endif
              When Default
            Endcase
          Endif
        When GVML_DFREPR
          If ( [F:DEPC]DFDBLC <> 0 ) Then
            Case [M:DIV]DIFRGL
              When GVML_RGPOURC
                [F:DEPC]DFDRVE = [F:DEPC]DFDBLC * ( [M:DIV]DIFRAT / 100. )
                [M:DIV]PV(0)= [F:DEPC]DFDRVE : [M:DIV]PC(0)= [M:DIV]CUR
                Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:DEPC]DFDRVE = [M:DIV]RV(1)
              When GVML_RGREPDR
              When Default
            Endcase
          Endif
        When Default
      Endcase
    Endif
    If ( [F:DEPC]DFD <> 0 or [F:DEPC]DFDRVE <> 0 ) Then
    Endif
  Else
    [F:DEPC]DFD    = 0.
    [F:DEPC]DFDRVE = 0.
  Endif
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") and [F:DEPC]DFDBLC <> 0 ) Then
    [F:DEPC]DFD    = 0.
    [F:DEPC]DFDRVE = [F:DEPC]DFDBLC
  Else
    [F:DEPC]ENDDPE   = [F:DEPC]ENDDPE - [F:DEPC]DFD + [F:DEPC]DFDRVE
    [M:DIV]DOTEXE    = [M:DIV]DOTEXE  - [F:DEPC]DFD + [F:DEPC]DFDRVE
    If ( LECAFISMIN <> 0 ) Then
      If ( abs([F:DEPC]DFDBLC) > abs(LECAFISMIN - [F:DEPC]DFDRVE) ) Then
        [F:DEPC]DFDRVE += LECAFISMIN - [F:DEPC]DFDRVE
      Else
        [F:DEPC]DFDRVE = [F:DEPC]DFDBLC
      Endif
    Endif
  Endif
  If ([F:DEPC]DFD + [F:DEPC]DFDRVE <> 0 ) Then
  Endif
Return
$CAL_DIF_ESP_2013_2014
  If ([F:DEPC]DPRPLN = G301FIS and !([M:DIV]BCUME_1) ) Then
    [F:DEPC]DFD    = 0.
    [F:DEPC]DFDRVE = 0.
    Local Integer WDIFTYP, B_FIY
    B_FIY = find([F:DEPC]FIYENDDAT,[M:FIY]DATENDFIY)
    If (B_FIY) Then
      WDIFTYP = [M:FIY]DFDTYP(B_FIY-1)
      If (WDIFTYP <> GVML_DFD1314) Then : WDIFTYP = GVML_DFAUCUN : Endif
    Else
      WDIFTYP = GVML_DFAUCUN
    Endif
    If ( WDIFTYP = GVML_DFAUCUN and [F:DEPC]DFDBLC <> 0 and [F:DEPC]FIYSTRDAT >= [01/01/2015]) Then
      WDIFTYP = GVML_DFREPR
    Endif
    Case WDIFTYP
      When GVML_DFAUCUN
      When GVML_DFD1314
        If( func GLOBB9.CAL_DAT_INSIDE([F:DEPC]FIYSTRDAT, [01/01/2013], [31/12/2014],"I") ) Then
          Local Integer WPLNPIO : WPLNPIO = [M:DIV2]DPRPLNPIO
          If (WPLNPIO = G301FIS) Then
            WPLNPIO = G301CPT
          Endif
          Local Decimal WLIM1314
          Local Integer WDEP
          Case WPLNPIO
            When  G301CPT
              WDEP = find([F:DEPC]PERENDDAT, [M:PCPT]PERENDDAT)
              WLIM1314 = ([M:PCPT]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301FIS
              WDEP = find([F:DEPC]PERENDDAT, [M:PFIS]PERENDDAT)
              WLIM1314 = ([M:PFIS]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301MIN
              WDEP = find([F:DEPC]PERENDDAT, [M:PMIN]PERENDDAT)
              WLIM1314 = ([M:PMIN]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301ORI
              WDEP = find([F:DEPC]PERENDDAT, [M:PORI]PERENDDAT)
              WLIM1314 = ([M:PORI]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301R76
              WDEP = find([F:DEPC]PERENDDAT, [M:PR76]PERENDDAT)
              WLIM1314 = ([M:PR76]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301IAS
              WDEP = find([F:DEPC]PERENDDAT, [M:PIAS]PERENDDAT)
              WLIM1314 = ([M:PIAS]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301TEC
              WDEP = find([F:DEPC]PERENDDAT, [M:PTEC]PERENDDAT)
              WLIM1314 = ([M:PTEC]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301RET
              WDEP = find([F:DEPC]PERENDDAT, [M:PRET]PERENDDAT)
              WLIM1314 = ([M:PRET]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301SUB
              WDEP = find([F:DEPC]PERENDDAT, [M:PSUB]PERENDDAT)
              WLIM1314 = ([M:PSUB]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI1
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI1]PERENDDAT)
              WLIM1314 = ([M:PLI1]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI2
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI2]PERENDDAT)
              WLIM1314 = ([M:PLI2]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI3
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI3]PERENDDAT)
              WLIM1314 = ([M:PLI3]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI4
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI4]PERENDDAT)
              WLIM1314 = ([M:PLI4]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI5
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI5]PERENDDAT)
              WLIM1314 = ([M:PLI5]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI6
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI6]PERENDDAT)
              WLIM1314 = ([M:PLI6]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  Default
          Endcase
          [M:DIV]PV(0)= WLIM1314 : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WLIM1314 = [M:DIV]RV(1)
          If ( abs(WLIM1314) > = abs([F:DEPC]ENDDPE) ) Then
            [F:DEPC]DFD = 0
          Else
            [F:DEPC]DFD = [F:DEPC]ENDDPE - WLIM1314
          Endif
        Endif
      When GVML_DFREPR
        Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice
        Local Decimal WDURRES  : WDURRES  = 0.       : # Durée réstant à amortir
        Local Decimal WDOTEXE  : WDOTEXE  = 0.       : # Dotation de l'exercice
        Local Date    WDBREPR              : # Début reprise dans l'exercice
        Local Date    WFNREPR              : # Date de fin de reprise
        WDBREPR = [F:DEPC]FIYSTRDAT
        If (day([F:DEPC]FIYENDDAT) = 31 and month([F:DEPC]FIYENDDAT) = 12  ) Then
          WFNREPR = [31/12/2024]
        Else
          WFNREPR = gdat$(day([F:DEPC]FIYENDDAT),month(FIYENDDAT),2025)
        Endif
        WFNREPR = min([M:DIV]DTFNAMT, WFNREPR)
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= WDBREPR
        [M:DIV]PD(3)= WFNREPR          : [M:DIV]PD(4)= [M:DIV]DATNUL   : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_DUR_DET From   GLOBB8
        WDURDET = [M:DIV]RV(1)
        Call  CAL_DUR_REST_AMT ([01/01/2013], [M:DIV]EXEDATREF, WFNREPR, "D", WDURRES) From   GLOBB8
        If ( WDURRES <> 0 ) Then
          [F:DEPC]DFDRVE = [F:DEPC]DFDBLC * ( WDURDET / WDURRES)
          [M:DIV]PV(0)= [F:DEPC]DFDRVE : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [F:DEPC]DFDRVE = [M:DIV]RV(1)
        Endif
      When Default
    Endcase
    If ( [F:DEPC]DFD <> 0 or [F:DEPC]DFDRVE <> 0 ) Then
    Endif
  Else
    [F:DEPC]DFD    = 0.
    [F:DEPC]DFDRVE = 0.
  Endif
  If ( [F:DEPC]FIYSTRDAT >= [01/01/2015] and [M:DIV]DTFNAMT < [F:DEPC]FIYSTRDAT and
&      ( [F:DEPC]DFDBLC <> 0 or [F:DEPC]DFD <> 0 ) ) Then
    [F:DEPC]DFDRVE = [F:DEPC]DFDBLC + [F:DEPC]DFD
  Endif
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSOREXE, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") and
&      ( [F:DEPC]DFDBLC <> 0 or [F:DEPC]DFD <> 0 ) ) Then
    [F:DEPC]DFDRVE = [F:DEPC]DFDBLC + [F:DEPC]DFD
  Endif
  [F:DEPC]ENDDPE   = [F:DEPC]ENDDPE - [F:DEPC]DFD + [F:DEPC]DFDRVE
  [M:DIV]DOTEXE    = [M:DIV]DOTEXE  - [F:DEPC]DFD + [F:DEPC]DFDRVE
Return
Subprog  CAL_REGLE_DF_AMT30_2001 ( PAMT, RAMT, RAFI )
Value Decimal    PAMT
Variable Decimal RAMT
Variable Decimal RAFI
Local Date     WDTDB                             : # Borne début
Local Date     WDTFN                             : # Borne fin
Local Decimal  WCOE                              : # Borne fin
Local Decimal  WDURAPP                           : # Durée d'application (12 mois)
Local Date     WDTFNAPP                          : # Date de fin d'application
Local Decimal  WAPP                              : # Nombre de mois sur lesquels la règle fiscale doit s'appliquer
Local Decimal  WDETEXE                           : # Nombre de mois de détention dans l'exercice
  If ( [M:DIV]DTDBAMTREG >= [F:DEPC]FIYSTRDAT and [M:DIV]DTDBAMTREG <= [F:DEPC]FIYENDDAT ) Then
    WCOE = 0.3
  Else
    Call CAL_DAT_BORNES
&        ( [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG, [M:DIV]DATNUL,
&          [M:DIV]DATSORREG,  [M:DIV]DETVTEDAT,  WDTDB, WDTFN ) From   GLOBB9
    If ([M:DIV]ERROR) Then : End : Endif
    WDURAMT = 1.
    WDURAPP = 12
    Call CAL_DAT_FIN_SELON_DUREE
&        ( [M:DIV]DTDBAMTREG, WDURAPP, [M:DIV]TYPPRO, WDTFNAPP ) From   GLOBB9
    If ( WDTFNAPP > WDTDB ) Then
      Call CAL_DAT_DIFF( WDTDB, WDTFNAPP, [M:DIV]TYPPRODAT, WAPP ) From   GLOBB9
      Call CAL_DAT_DIFF( WDTDB, WDTFN, [M:DIV]TYPPRODAT, WDETEXE ) From   GLOBB9
      WAPP = min (WAPP, WDETEXE)
      WCOE = 0.3 * (WAPP / WDETEXE)
    Else
      WCOE = 0.0
    Endif
  Endif
  RAMT = PAMT * ( 1. + WCOE )
  [M:DIV]PV(0)= RAMT : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : RAMT = [M:DIV]RV(1)
  RAFI = RAMT - PAMT
End
$CCN_CLORE_EXERCICE_RPR
  [F:RPRS]STRRNWVAL  = [F:RPRC]ENDRNWVAL  : # Valeur de remplacement
  [F:RPRS]RNWVALFLG  = G_NON              : # Valeur de remplacement déforcée sur les exercices futurs
  [F:RPRS]E_1ACGRPR  = [F:RPRC]E_1ACGRPR  + [F:RPRC]EXEACGRPR    : # Cum E-1 Prov. Cpt.
  [F:RPRS]E_1FISRPR  = [F:RPRC]E_1FISRPR  + [F:RPRC]EXEFISRPR    : # Cum E-1 Prov. Fis.
  [F:RPRS]E_1RVERPR  = [F:RPRC]E_1RVERPR  + [F:RPRC]EXERVERPR    : # Cum E-1 Repr. Prov. Fis.
  [F:RPRS]E_1SUPCAD  = [F:RPRC]E_1SUPCAD  + [F:RPRC]EXESUPCAD    : # Cum E-1 Supplément de caducité
  [F:RPRS]EXEACGRPR  = 0                                         : # 0-> Prov. Cpt.
  [F:RPRS]EXEFISRPR  = 0                                         : # 0-> Prov. Fis.
  [F:RPRS]EXERVERPR  = 0                                         : # 0-> Repr. Prov. Fis.
  [F:RPRS]EXESUPCAD  = 0                                         : # 0-> Supplément de caducité
  [F:RPRS]P_1ACGRPR  = 0                                         : # 0-> Cum P-1 Prov. Cpt.
  [F:RPRS]P_1FISRPR  = 0                                         : # 0-> Cum P-1 Prov. Fis.
  [F:RPRS]P_1RVERPR  = 0                                         : # 0-> Cum P-1 Repr. Prov. Fis.
  [F:RPRS]P_1SUPCAD  = 0                                         : # 0-> Cum P-1 Supplément de caducité
Return
$CCN_CLORE_PERIODE_RPR
  [F:RPRS]P_1ACGRPR  = [F:RPRC]P_1ACGRPR  + [F:RPRC]PERACGRPR    : # Cum P-1 Prov. Cpt.
  [F:RPRS]P_1FISRPR  = [F:RPRC]P_1FISRPR  + [F:RPRC]PERFISRPR    : # Cum P-1 Prov. Fis.
  [F:RPRS]P_1RVERPR  = [F:RPRC]P_1RVERPR  + [F:RPRC]PERRVERPR    : # Cum P-1 Repr. Prov. Fis.
  [F:RPRS]P_1SUPCAD  = [F:RPRC]P_1SUPCAD  + [F:RPRC]PERSUPCAD    : # Cum P-1 Supplément de caducité
  [F:RPRS]PERACGRPR  = 0                                         : # 0-> Prov. Cpt.
  [F:RPRS]PERFISRPR  = 0                                         : # 0-> Prov. Fis.
  [F:RPRS]PERRVERPR  = 0                                         : # 0-> Repr. Prov. Fis.
  [F:RPRS]PERSUPCAD  = 0                                         : # 0-> Supplément de caducité
Return
