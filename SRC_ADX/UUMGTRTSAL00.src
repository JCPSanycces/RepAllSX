$OUVRE_SAL
# Déclaration des variables communes de travail
Local Integer COMPTEUR, I, J

#déclaration des variables locales de travail
Local Char     WSOCIETE(GLONCPY),WSITE(GLONFCY)
Local Integer  WI, WJ, WJTUN, WRET , WCCE
Local Decimal  WCOURS
Local Char     WITMREF, WFICD(3), WFICD1(3), WFICE(3)
Local Decimal  WMNTCALC, WMONT
Local Integer  WVCRTYP
Local Char     WVCRNUM

Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".BPDLVCUST"  [BPD]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
Local File =[F:ADS]DOSSIER+".GLED"       [LED]

# Fichiers à ouvrir pour la valorisation des devis des commandes et des livraisons
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU0]
#Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]                : # Dde 81811 : Optimisation
Local File =[F:ADS]DOSSIER+".TABCHANGE"  [TCH]
#Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]                : # Dde 81811 : Optimisation
Local File =[F:ADS]DOSSIER+".ATEXTRA"    [AXX]

Local File =[F:ADS]DOSSIER+".PRICSTRUCT" [PRS]
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Local File =[F:ADS]DOSSIER+".SFOOTINV"   [SFI]
Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]

Local File =[F:ADS]DOSSIER+".TABVAC"     [TVC]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]
Local File =[F:ADS]DOSSIER+".TAXLINK"    [TLK]
#Local File =[F:ADS]DOSSIER+".AGRPCPY"    [AGC]                : # Dde 81811 : Optimisation
Local File =[F:ADS]DOSSIER+".TABDEPAGIO" [TDA]

Local File =[F:ADS]DOSSIER+".TABCOEFF"   [TCO]
NBTCO=nbrecord([TCO])
Local Char WTCOREF(GLONUOM*3)(0..NBTCO)
Local Decimal WTCOCOEUOM(0..NBTCO)
Raz WJ
For [TCO]
    # Chargement des éléments dans un tableau memoire
    WTCOREF(WJ)=[F:TCO]UOM1+"/"+[F:TCO]UOM2
    WTCOCOEUOM(WJ)=[F:TCO]COEUOM
    WJ+=1
Next

# Dde 81811 : Optimisation : Chargement en mémoire de la table AGRPCPY
Local File =[F:ADS]DOSSIER+".AGRPCPY"    [AGC]
Global Integer NBAGC : NBAGC=nbrecord([AGC])
Global Char WAGCGRP(GLONAGF)(0..NBAGC)
Global Char WAGCCPY(GLONCPY)(0..NBAGC)

Raz WJ
For [AGC] AGC1
  WAGCGRP(WJ)=[F:AGC]GRP
  WAGCCPY(WJ)=[F:AGC]CPY
  WJ+=1
Next

# Dde 81811 : Optimisation : Chargement en mémoire de la table TABRATVAT
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Global Integer NBTRA : NBTRA=nbrecord([TRA])
Global Char WTRAVAT(GLONVAT)(0..NBTRA)
Global Char WTRACPY(GLONCPY)(0..NBTRA)
Global Date WTRASTRDAT(0..NBTRA)
Global Decimal WTRAVATRAT(0..NBTRA)
Global Decimal WTRADEDRAT(0..NBTRA)
Global Decimal WTRAAMTTSD(0..NBTRA)
Global Integer WTRAVATEXEFLG(0..NBTRA)

Raz WJ
For [TRA]TRA0
    WTRAVAT   (WJ)=[F:TRA]VAT
    WTRACPY       (WJ)=[F:TRA]CPY
    WTRASTRDAT    (WJ)=[F:TRA]STRDAT
    WTRAVATRAT    (WJ)=[F:TRA]VATRAT
    WTRADEDRAT    (WJ)=[F:TRA]DEDRAT
    WTRAAMTTSD    (WJ)=[F:TRA]AMTTSD
    WTRAVATEXEFLG (WJ)=[F:TRA]VATEXEFLG
  WJ+=1
Next

# Dde 81811 : Optimisation : Chargement en mémoire de la table TABVAT
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Global Integer NBTVT : NBTVT=nbrecord([TVT])
Global Char WTVTVAT(GLONVAT)(0..NBTVT)
Global Integer WTVTVATCHA(0..NBTVT)
Global Integer WTVTVATBAS(0..NBTVT)
Global Integer WTVTVATTYP(0..NBTVT)
Raz WJ
For [TVT]
    # Chargement des éléments dans un tableau memoire
    WTVTVAT(WJ)=[F:TVT]VAT
    WTVTVATCHA(WJ)=[F:TVT]VATCHA
    WTVTVATBAS(WJ)=[F:TVT]VATBAS
    WTVTVATTYP(WJ)=[F:TVT]VATTYP
    WJ+=1
Next
# Dde 81811 : Optimisation

Local File =[F:ADS]DOSSIER+".TABUNIT"    [TUN]
Local Integer NBTUN : NBTUN=nbrecord([TUN])
Local Char WTUNUOM(GLONUOM)(0..NBTUN)
Local Integer WTUNUOMDEC(0..NBTUN)
Local Char WTUNUOMOLD(GLONUOM)
Raz WJTUN
Raz WJ
For [TUN]
    # Chargement des éléments dans un tableau memoire
    WTUNUOM(WJ)=[F:TUN]UOM
    WTUNUOMDEC(WJ)=[F:TUN]UOMDEC
    WJ+=1
Next

# Issue 74556 - 2011-07-04 by LD : chargement code activité PTX
Local File =[F:ADS]DOSSIER+".ACTIV"      [ACV]
Call SET_ACTIVPTX From TRTX3

# 100121 : Init GLOCUSATAX pour la valorisation
# --- Code activité "KUS" Localisation USA
Global Integer GACTKUS
Read [ACV] CODACT="KUS"
If !fstat
  GACTKUS=[F:ACV]FLACT
Else
  GACTKUS=0
Endif
# 100121

# 101380 : gbn
# --- activity code "LTA" Sage Sales Tax
Global Integer GACTLTA
Read [ACV] CODACT="LTA"
If !fstat
  GACTLTA=[F:ACV]FLACT
Else
  GACTLTA=0
Endif
# 101380

Local File =[F:ADS]DOSSIER+".BPCUSTOMER" [BPC]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]

Local File =[F:ADS]DOSSIER+".SVCRVAT"    [SVV]
Local File =[F:ADS]DOSSIER+".SVCRFOOT"   [SVF]

Local File =[F:ADS]DOSSIER+".ADOVAL"     [ADW]
Local File =[F:ADS]DOSSIER+".ADOPAR"     [ADP]

#----- Définition et chargement des GLONxx nécessaires aux moulinettes achats -----#
Local File =[F:ADS]DOSSIER+".ATYPE"      [ATY]

# Dde 81811 : Optimisation
## Validation des écrans
