# Dde 81811 : Optimisation

# Issue 106947 - 20150811 by LD : Migration of historic folder
# No test of the version in case the version is not known at this time ...
Local Char WHISTFOLD(GLONADS)
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    WHISTFOLD=[F:ADS]DOSSIER
Else
    WHISTFOLD=[F:ADS]DOSREF
Endif

#Local Mask =[F:ADS]DOSSIER+".SIH0" [SIH0]
#Local Mask =[F:ADS]DOSSIER+".SIH1" [SIH1]
#Local Mask =[F:ADS]DOSSIER+".SIH2" [SIH2]
#Local Mask =[F:ADS]DOSSIER+".SIH4" [SIH4]
#Local Mask =[F:ADS]DOSSIER+".SIHV" [SIHV]
#Local Mask =[F:ADS]DOSSIER+".SIHV" [SIHX]

#Gbn-119003-Temporary fix for U11.0.0. Tobe removed in V11.0.1 after investigation by the techno team. (And delivered as hotfix if possible)
If VERSION<GMIGX3VER60
  Local Mask =WHISTFOLD+".SIH0" [SIH0]
  Local Mask =WHISTFOLD+".SIH1" [SIH1]
  Local Mask =WHISTFOLD+".SIH2" [SIH2]
  Local Mask =WHISTFOLD+".SIH4" [SIH4]
  Local Mask =WHISTFOLD+".SIHV" [SIHV]
  Local Mask =WHISTFOLD+".SIHV" [SIHX]
Endif
# Issue 106947 - 20150811 by LD

#------
If dim(GLONVAT)<1  Global Shortint GLONVAT : Endif
Read [ATY] CODTYP="VAT"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONVAT=[F:ATY]LNGTYP

# Dde 81811 : Optimisation passage en global
Global Integer  WNBSFI
WNBSFI=nbrecord([SFI])
Global Integer  WSFINUM (0..WNBSFI)
Global Integer  WSFIAMTCOD (0..WNBSFI)
Global Char     WSFIDSP (GLONDSP) (0..WNBSFI)
Global Integer  WSFICLCBAS (0..WNBSFI)
Global Integer  WSFICLCORD (0..WNBSFI)
Global Char     WSFICCE (GLONCCE) (GOPTCANA,0..WNBSFI)
Global Char     WSFIVACITM(GLONADI) (0..WNBSFI) : # Dde 81811 : Optimisation
#Global Char     WSFICLCVACITM(GLONTVI) (0..WNBSFI) : # Bug 82733 : # 84132
Global Char     WSFICLCVACITM(GLONADI) (0..WNBSFI)  : # Bug 84132
If GACTLTA : Global Char WSFISSTCOD(GLONADI) (0..WNBSFI) : Endif #gbn-101380
Raz WJ
For [SFI]SFI0
    # Chargement des éléments de facturation dans un tableau memoire
    # --> Pour connaître le type de valeur : Taux/Montant
    WSFINUM(WJ)=[F:SFI]SFINUM
    WSFIAMTCOD(WJ)=[F:SFI]AMTCOD
    WSFIDSP(WJ)=[F:SFI]DSP
    WSFICLCBAS(WJ)=[F:SFI]CLCBAS
    WSFICLCORD(WJ)=[F:SFI]CLCORD
    WSFIVACITM(WJ)=[F:SFI]VACITM : # Dde 81811 : Optimisation
    WSFICLCVACITM(WJ)=[F:SFI]CLCVACITM : # Bug 82733
    If GACTLTA : WSFISSTCOD(WJ)=[F:SFI]SSTCOD : Endif #gbn-101380
    For WCCE=1 To GOPTCANA
        WSFICCE (WCCE-1,WJ)=[F:SFI]CCE(WCCE-1)
    Next I

    WJ+=1
Next

Gosub INISOC

Return

#################################
$RECUP_SFI
If WJ>0
    [F:SFI]SFINUM=WSFINUM(WJ-1)
    [F:SFI]AMTCOD=WSFIAMTCOD(WJ-1)
    [F:SFI]DSP=WSFIDSP(WJ-1)
    [F:SFI]CLCBAS=WSFICLCBAS(WJ-1)
    [F:SFI]CLCORD=WSFICLCORD(WJ-1)
    For WCCE=1 To GOPTCANA
        [F:SFI]CCE(WCCE-1)=WSFICCE(WCCE-1,WJ-1)
    Next I
Else
    Raz [F:SFI]
Endif
Return

########################################
$READ_ITM
If [F:ITM]ITMREF<>WITMREF
    Read [F:ITM]ITM0 = WITMREF : If fstat Raz [ITM] Endif
Endif
Return

###########################################
###########################
$ALIM_FICD_SAV

Assign "[F:"+WFICD+"]CPY" With evalue("[F:"+WFICE+"]CPY")

Assign "[F:"+WFICD+"]DSPLINFLG" With 2

WITMREF = evalue ("[F:"+WFICD+"]ITMREF")
If [F:ITM]ITMREF<>WITMREF
    Read [F:ITM]ITM0 = WITMREF : If fstat Raz [ITM] Endif
Endif

WMNTCALC = [F:ITM]ITMWEI * evalue("[F:"+WFICD+"]QTY") * evalue("[F:"+WFICD1+"]SAUSTUCOE")
WUOM1=[F:ITM]WEU
WUOM2=GSALDSPWEU
WQTY=WMNTCALC
#Call CONVERT_QTY ([F:ITM]WEU,GSALDSPWEU,WMNTCALC)
Gosub CONVERT_QTY
WMNTCALC=WQTY
Assign "[F:"+WFICD+"]DSPLINWEI" With WMNTCALC

WMNTCALC = [F:ITM]ITMVOU * evalue("[F:"+WFICD+"]QTY") * evalue("[F:"+WFICD1+"]SAUSTUCOE")
WUOM1=[F:ITM]VOU
WUOM2=GSALDSPVOU
WQTY=WMNTCALC
#Call CONVERT_QTY ([F:ITM]VOU,GSALDSPVOU,WMNTCALC)
Gosub CONVERT_QTY
WMNTCALC=WQTY
Assign "[F:"+WFICD+"]DSPLINVOL" With WMNTCALC

Assign "[F:"+WFICD+"]DSPWEU" With evalue("[F:"+WFICE+"]DSPWEU")
Assign "[F:"+WFICD+"]DSPVOU" With evalue("[F:"+WFICE+"]DSPVOU")

WMONT  = evalue("[F:"+WFICE+"]DSPTOTQTY")
If WFICD<>"SQD"
    WMONT += evalue("[F:"+WFICD+"]QTYSTU")
Else
    WMONT += evalue("[F:"+WFICD+"]QTY")
Endif
Assign "[F:"+WFICE+"]DSPTOTQTY" With WMONT

WMONT  = evalue("[F:"+WFICE+"]DSPTOTWEI")
WMONT += evalue("[F:"+WFICD+"]DSPLINWEI")
Assign "[F:"+WFICE+"]DSPTOTWEI" With WMONT

WMONT  = evalue("[F:"+WFICE+"]DSPTOTVOL")
WMONT += evalue("[F:"+WFICD+"]DSPLINVOL")
Assign "[F:"+WFICE+"]DSPTOTVOL" With WMONT

Return
###########################

#-------------------------------------------------------------#
# Conversion quantité d"une unité vers une autre avec arrondi #
# ----------------------------------------------------------- #
# WUOM1 : Unité d'origine                                     #
# WUOM2 : Unité destination                                   #
# WQTY  : Quantité à convertir puis quantité convertie        #
#-------------------------------------------------------------#
$CONVERT_QTY
#----- Conversion quantité si unités différentes -----#
If WUOM1<>WUOM2
  Local    Decimal WCOEF
  WJ=find(WUOM1+"/"+WUOM2,WTCOREF(0..NBTCO))
  If WJ>0
      WCOEF=WTCOCOEUOM(WJ-1)
  Else
      WJ=find(WUOM2+"/"+WUOM1,WTCOREF(0..NBTCO))
      If WJ>0 & WTCOCOEUOM(WJ-1)<>0
        WCOEF=1/WTCOCOEUOM(WJ-1)
      Else
        WCOEF=1
      Endif
  Endif
  WQTY*=WCOEF
Endif
Gosub RECHTUN
Return

$RECHTUN
#----- Arrondi de la quantité -----#
If WTUNUOMOLD<>WUOM2
    If WUOM2>WTUNUOMOLD
    WJ=find(WUOM2,WTUNUOM(WJTUN..NBTUN))
    WJTUN+=WJ
    Else
    WJTUN=find(WUOM2,WTUNUOM(0..WJTUN))
    Endif
    WTUNUOMOLD=WUOM2
Endif
If WJTUN>0
    WQTY=arr(WQTY,10^-WTUNUOMDEC(WJTUN-1))
Endif
Return


##############################################################
## Init des tables société/sites                            ##
##############################################################
$INISOC

Local Integer LNBSOC : LNBSOC=rowcount([F:CPY])

Global Integer GSSTTAX(1..GDIMSOC) #108649.n

If LNBSOC>GDIMSOC
 GDIMSOC=LNBSOC+20
 Global Char    GSOC(GLONCPY)(1..GDIMSOC)
 Global Char    GDEVSOC(GLONCUR)(1..GDIMSOC)
 Global Char    GLEGSOC(GLONADI)(1..GDIMSOC)
 Global Libelle GTYPSOC(1..GDIMSOC)
 Global Char    GGCMSOC(GLONGCM)(1..GDIMSOC)
 Global Integer GSSTTAX(1..GDIMSOC) #108649.n
Endif

Raz GNBSOC
For [CPY]
 GNBSOC += 1
 GSOC(GNBSOC)    = [F:CPY]CPY
 If dim([F:CPY]ACCCUR)>0
  GDEVSOC(GNBSOC) = [F:CPY]ACCCUR
 Else
  GDEVSOC(GNBSOC) = ""
 Endif
 GLEGSOC(GNBSOC) = [F:CPY]LEG
 If dim(GTYPSOC)>0
  GTYPSOC(GNBSOC) = [F:CPY]CPYLEGFLG
 Endif
 If dim(GGCMSOC)>0
  If dim([F:CPY]ACM)>0
   GGCMSOC(GNBSOC) = [F:CPY]ACM
  Else
   GGCMSOC(GNBSOC) = ""
  Endif
 Endif

 #108649.sn
 If GACTLTA & [F:CPY]SSTTAXACT = 2
   GSSTTAX(GNBSOC) = 1
 Else
   GSSTTAX(GNBSOC) = 0
 Endif
 #108649.en
Next

Local Integer LNBSIT : LNBSIT=rowcount([F:FCY])
If LNBSIT>GDIMSIT
 GDIMSIT=LNBSIT+20
 Global Char GSITE(GLONFCY)(1..GDIMSIT)
 Global Char GSOCSITE(GLONCPY)(1..GDIMSIT)
 Global Char GFINSITE(GLONFCY)(1..GDIMSIT)
Endif

Raz GNBSITE
For [FCY]
 GNBSITE += 1
 GSITE(GNBSITE)    = [F:FCY]FCY
 GSOCSITE(GNBSITE) = [F:FCY]LEGCPY
 GFINSITE(GNBSITE) = [F:FCY]FINRSPFCY
 #----------------------------------------------#
 # si le site financier n'est pas renseigné     #
 # dans ce cas le site est lui même financier   #
 #----------------------------------------------#
 If GFINSITE(GNBSITE)  = ""
  GFINSITE(GNBSITE) = [F:FCY]FCY
 Endif
Next

Return

# Dde 81811 : Optimisation
$LEC_VAT
    Local Integer WJ
    If [F:TVT]VAT<>WVAT
        Raz [F:TVT]
       WJ=find(WVAT,WTVTVAT(0..NBTVT))
        If WJ
            [F:TVT]VAT     = WTVTVAT(WJ-1)
            [F:TVT]VATCHA  = WTVTVATCHA(WJ-1)
            [F:TVT]VATBAS  = WTVTVATBAS(WJ-1)
            [F:TVT]VATTYP  = WTVTVATTYP(WJ-1)
        Else
            Return
        Endif
    Endif

    For WJ=NBTRA-1 To 0 Step -1
        If WTRACPY(WJ)=GSOCIETE & WTRAVAT(WJ)=WVAT & WTRASTRDAT(WJ)<=GBIDA1
                [F:TRA]VAT= WTRAVAT(WJ)
                [F:TRA]CPY       =  WTRACPY       (WJ)
                [F:TRA]STRDAT    =  WTRASTRDAT    (WJ)
                [F:TRA]VATRAT    =  WTRAVATRAT    (WJ)
                [F:TRA]DEDRAT    =  WTRADEDRAT    (WJ)
                [F:TRA]AMTTSD    =  WTRAAMTTSD    (WJ)
                [F:TRA]VATEXEFLG =  WTRAVATEXEFLG (WJ)
           Break
        Elsif WTRACPY(WJ)<GSOCIETE & WTRAVAT(WJ)=WVAT
            Break
        Elsif WTRAVAT(WJ)<WVAT
            Break
        Endif
    Next WJ
    If [F:TRA]VAT=""
        For WJ=NBTRA-1 To 0 Step -1
            If WTRACPY(WJ)="" & WTRAVAT(WJ)=WVAT & WTRASTRDAT(WJ)<=GBIDA1
                    [F:TRA]VAT= WTRAVAT(WJ)
                    [F:TRA]CPY       =  WTRACPY       (WJ)
                    [F:TRA]STRDAT    =  WTRASTRDAT    (WJ)
                    [F:TRA]VATRAT    =  WTRAVATRAT    (WJ)
                    [F:TRA]DEDRAT    =  WTRADEDRAT    (WJ)
                    [F:TRA]AMTTSD    =  WTRAAMTTSD    (WJ)
                    [F:TRA]VATEXEFLG =  WTRAVATEXEFLG (WJ)
               Break
            Elsif WTRAVAT(WJ)<WVAT
                Break
            Endif
        Next WJ
    Endif
Return
# Dde 81811 : Optimisation

