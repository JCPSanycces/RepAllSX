#<AdxTL>@(#)11.0.0.0 $Revision$


###############################################################################
# PFCY    = site
# LSTOCOU = Chrono stock
# LQTY    = Quantité à réserver
# LPOT    = coef. permettant de calculer la quantité en UA
# LQTYRES = Quantité réservée
# NOL     = indice de la ligne
$CRERESSTO

Local Integer WTRBEGIN
# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO]
   WTRBEGIN=1
Endif

Readlock [STO]STO0=[M:QCR1]STOFCY;LSTOCOU
If !fstat
    If [F:ITF]STOMGTCOD=3
        If [F:STL]ITMREF<>[F:STO]ITMREF | [F:STL]LOT<>[F:STO]LOT | [F:STL]SLO<>[F:STO]SLO
            Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
        Endif
        LPOT = [F:STL]POT/100
    Else
        LPOT = 1
    Endif

    [M:QCR1]POT(NOL) = LPOT
    LQTY = max(0, min(LQTY, [F:STO]QTYSTU-[F:STO]CUMWIPQTY))

   # LQTY =  min(LQTY, [F:STO]QTYSTU-[F:STO]CUMWIPQTY)
    LQTYRES = min(LQTY,[F:STO]QTYSTU-[F:STO]CUMWIPQTY-[F:STO]CUMALLQTY)

    If LQTY>0
        [F:STO]CUMWIPQTY += LQTYRES
        [F:STO]CUMWIPQTA += LQTYRES*LPOT
        Rewrite [STO]
        # Création quantité en cours de traitement
        Call CRE_STOWIPW([F:STO]STOCOU,LQTYRES,LQTYRES*LPOT) From STKLIB
    Else
        Unlock [STO]
    Endif
Endif

# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif

Return

###############################################################################
# ALISTW : Alimente le masque STOWORK et effectue la mise à jour des tables stock
###############################################################################
# Paramètres E : PNOL = indice de la ligne en cours d'enregistrement
###############################################################################
Subprog ALISTW( PNOL )
Value Integer PNOL
Local Decimal LQTA
Local Decimal LSHT
Local Integer LRET
Local Integer LNBR, LNBJ


# Initialisation de l'en-tête
[M:STW]STOFCY     = [M:QCR1]STOFCY       # Site
[M:STW]TRFFCY     = [M:QCR1]STOFCY       # Site
[M:STW]TRSTYP     = [M:QCR1]TRSTYP       # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:QCR1]VCRTYP       # Type pièce (M.701)
[M:STW]VCRNUM     = [F:SGD]VCRNUM        # Numéro pièce
[M:STW]VCRLIN     = [F:SGD]VCRLIN        # Numero ligne pièce
[M:STW]ITMREF     = [M:QCR1]ITMREF(PNOL) # Article
[M:STW]MVTDES     = [M:QCR1]MVTDES(PNOL) # Désignation mouvement
[M:STW]TRSFAM     = ""                   # Famille mouvement
[M:STW]ENTCOD     = ""                   # Famille mouvement
[M:STW]IPTDAT     = [M:QCR1]IPTDAT       # Date imputation
[M:STW]TRSCOD     = ""                   # Code mouvement
[M:STW]PJT        = ""                   # Affaire
Call ALISTOWORK( 12, PNOL, LQTA, LSHT, LNBR, LNBJ, LRET ) From STKINT
If !LRET
   Call MAJ_STOCK From STKMAJ
Else
   GOK = 0
Endif

End

###############################################################################
# DEPICK : Depick d'une ligne de stock
###############################################################################
# Paramètres E : PSTOFCY = Site
#                PSTOCOU = Chrono stock
#                PABR    = Abréviation de l'écran document
#                PRET    = Code retour (0=OK, 1=Erreur)
#
# Il faut faire Affzo du mask en sortie
###############################################################################
Subprog DEPICK(PSTOFCY, PSTOCOU, PABR, PRET)
Value Char    PSTOFCY
Value Decimal PSTOCOU
Value Char    PABR
Variable Integer PRET

Local Integer  LRET
Local Shortint WRET
Local Integer  LSEQ
Local Integer  I1, LLIGDOC
Local Decimal  LWIPQTY, LWIPQTA
Local Integer  LNB
Local Char     LPCU(GLONUOM)
Local Decimal  LCOEF, LQTYSTYU
Local Decimal  LSTOCOU
Local Char     LSERF(GLONSER)
Local Integer  WTRBEGIN


#-- Toute sortie prématurée est signe d'erreur
PRET = 1

Raz WTRBEGIN
If clalev([F:STO1])=0  Local File STOCK   [STO1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW [SWW]   Endif

# Si pas de transaction en cours
If adxlog<>1
   Trbegin [STO1]
   WTRBEGIN=1
Endif

Readlock [STO1]STO0=PSTOFCY;PSTOCOU
If fstat
    Goto ENDTRANSAC
Endif


If [F:STO1]SERNUM<>""
    LLIGDOC = find(PSTOCOU, [M:QCR1]WSTOCOU(0..[M:QCR1]NBLIG-1))
    If !LLIGDOC : Goto ENDTRANSAC : Endif
    LLIGDOC -= 1
    [M:QCR1]WSTOCOU  (LLIGDOC) = 0
    [M:QCR1]QTYSTUDES(LLIGDOC) = 0

    # Dans le cas où l'on serait passé en négatif
    LWIPQTY = min([F:STO1]CUMWIPQTY, [F:STO1]QTYSTU)
    LWIPQTA = min([F:STO1]CUMWIPQTA, [F:STO1]QTYSTUACT)
    [F:STO1]CUMWIPQTY -= LWIPQTY
    [F:STO1]CUMWIPQTA -= LWIPQTA
    # Suppression qté en cours de traitement
    LSTOCOU = [F:STO1]STOCOU
    Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
    Rewrite [F:STO1]

    Dela LLIGDOC,1 [M:QCR1]NBLIG
    [M:QCR1]NBLIG -= 1
    Raz GRAFFRAICHIQCR
Else
#                                                                                          # hcb 110327 deb
   # Le dépick d'une ligne de stock peut entraîner la suppression
   # de plusieurs lignes de [QCR1] (même chrono stock) si article est avec no série en global
   Local Integer I
   Local Integer J
   Local Integer OK
   Raz I,J
   OK = 0
   If [M:QCR1]NBLIG <> 0
      While OK <> 1
         I = find(PSTOCOU,[M:QCR1]WSTOCOU(J..[M:QCR1]NBLIG-1))
         If I<>0
            LLIGDOC = J+I-1
            J   = LLIGDOC
            Call DELSTO(PSTOFCY, LLIGDOC, LLIGDOC, LRET) From SUBQCRB
            Dela LLIGDOC,1,[M:QCR1]NBLIG-1 [M:QCR1]NBLIG
            [M:QCR1]NBLIG -= 1
            If J>[M:QCR1]NBLIG-1 OK=1 Endif
         Else
           OK=1
        Endif
     Wend
   Endif
Endif
#
#    #--- On cherche la ligne dans le document
#    LLIGDOC = evalue("find(PSTOCOU, [M:"+PABR+"]WSTOCOU(0..[M:"+PABR+"]NBLIG))")
#    If !LLIGDOC : Goto ENDTRANSAC : Else LLIGDOC-=1 : Endif
    #--- On fait le ménage dans le document
#    Call DELSTO(PSTOFCY, LLIGDOC, LLIGDOC, LRET) From SUBQCRB
#    Dela LLIGDOC,1 [M:QCR1]NBLIG
#    [M:QCR1]NBLIG -= 1
#Endif
#                                                                                          # hcb 110327 end


Affzo [M:QCR1]

Raz PRET

GOK=1

$ENDTRANSAC
# Si on a ouvert une transaction
If WTRBEGIN=1
   If GOK : Commit : Else : Rollback : Endif
   Raz WTRBEGIN
Endif

End

###############################################################################
# ALI_DOC : Alimente la ligne de document en cours (nolign-1) avec [F:STO]
#            Les valeurs de destination sont initialisées
###############################################################################
$ALI_DOC
Local Shortint WPBSTA, WPBLOC
Local Shortint WRET
Local Integer  LRET, I
Local Char     LSEC
Local Char     VAT(GLONVAT)(3)
Local Decimal  WQTE
    #---- Positionnement sur les tables ------------#
    Call POSTABLE([M:QCR1]STOFCY, [F:STO]ITMREF, [F:STO]LOT, [F:STO]SLO, LRET)
    If LRET
        OK=0
        Return
    Endif

    # Ouverture de la ligne
    nolign = [M:QCR1]NBLIG
    Insa nolign,1,[M:QCR1]NBLIG [M:QCR1]NBLIG
    [M:QCR1]NBLIG += 1
    nolign = [M:QCR1]NBLIG
    NOL = nolign-1
    status = 73
    Call INSERE("VCRLIN") From TABLEAUX
    status = 71
    Call LINNUM("VCRLIN") From TABLEAUX
    status = 0

    Actzo [M]QTYSTUDES(NOL)
    Actzo [M]QTYPCU(NOL)
    Actzo [M]STADES(NOL)
#    If dim([M]LOCDES)>0
#        Actzo [M]LOCDES(NOL)
#    Endif
#    If dim([M]LOCTYPDES)>0
#        Actzo [M]LOCTYPDES(NOL)
#    Endif
    If dim([M]MVTDES)>0
        Actzo [M]MVTDES(NOL)
    Endif

    [M:QCR1]ITMREF    (NOL)     = [F:STO]ITMREF
    [M:QCR1]ITMDES1   (NOL)     = [F:ITM] ITMDES1
    If dim([M:QCR1]LOT)>0
        [M:QCR1]LOT   (NOL)     = [F:STO]LOT
    Endif
    If dim([M:QCR1]SLO)>0
        [M:QCR1]SLO   (NOL)     = [F:STO]SLO
    Endif
    If dim([M:QCR1]PALNUM)>0
        [M:QCR1]PALNUM(NOL)     = [F:STO]PALNUM
    Endif
    If dim([M:QCR1]CTRNUM)>0
        [M:QCR1]CTRNUM(NOL)     = [F:STO]CTRNUM
    Endif
    [M:QCR1]STA       (NOL)     = [F:STO]STA
    If dim([M:QCR1]LOC)>0
       [M:QCR1]LOC    (NOL)     = [F:STO]LOC
    Endif
    If dim([M:QCR1]LOCTYP)>0
       [M:QCR1]LOCTYP (NOL)     = [F:STO]LOCTYP
    Endif
    If dim([M:QCR1]SERNUM)>0
        [M:QCR1]SERNUM(NOL)     = [F:STO]SERNUM
    Endif
    If dim([M:QCR1]WRH)>0
       [M:QCR1]WRH    (NOL)     = [F:STO]WRH
    Endif
#                                                                 # hcb 77041 deb
    If dim([M:QCR1]LPNNUM)>0
       [M:QCR1]LPNNUM (NOL)     = [F:STO]LPNNUM
    Endif
#                                                                 # hcb 77041 fin

    [M:QCR1]OWNER     (NOL)     = [F:STO]OWNER
    [M:QCR1]PCU       (NOL)     = [F:STO]PCU
    [M:QCR1]PCUSTUCOE (NOL)     = [F:STO]PCUSTUCOE
    [M:QCR1]QTYPCU    (NOL)     = [F:STO]QTYPCU
    [M:QCR1]WSTOCOU   (NOL)     = [F:STO]STOCOU
    [M:QCR1]STU       (NOL)     = [F:ITM]STU
    [M:QCR1]WWIPQTY   (NOL)     = [F:STO]CUMWIPQTY
    [M:QCR1]WWIPQTA   (NOL)     = [F:STO]CUMWIPQTA

    nolign=NOL+1
    Gosub MAJ_STUDIS
    [M:QCR1]QTYSTUDES(NOL)      = [M:QCR1]STUDIS(NOL)

    Call MAJQTY(2,[M:QCR1]QTYSTUDES(NOL),LRET)
    If [M:QCR1]PCU(NOL)         = [F:ITM]STU
        Diszo QTYPCU(NOL)
    Endif


    # Si ligne avec no série pas d'accés qte en US
    If dim([M:QCR1]SERNUM)>0 & [M:QCR1]SERNUM(NOL)<>""
       If dim([M]QTYSTUDES)>0 Diszo [M:QCR1]QTYSTUDES(NOL) Endif
    Endif


    Raz WPBSTA, WPBLOC

    If left$([F:STO]STA,1) <> "Q"
       Call STKINISTA([M:QCR1]STADES(NOL),"",[F:ITF]QUAFLG) From STKACT
       If [M:QCR1]STADES(NOL) = ""
          [M:QCR1]STADES(NOL) = "Q"
       Endif
    Else
       [M:QCR1]STADES(NOL) = [F:STO]STA
    Endif

#    If [F:ITF]LOCMGTCOD<>2  & dim([M:QCR1]LOCTYPDES)>0
#        Diszo [M:QCR1]LOCTYPDES(NOL)
#        Diszo [M:QCR1]LOCDES(NOL)
#    Else
#        If dim([M:QCR1]LOCTYPDES)> 0
#            Actzo [M:QCR1]LOCTYPDES(NOL)
#            Actzo [M:QCR1]LOCDES(NOL)
#        Endif
#    Endif
#    If [M:QCR1]WLOCSEQ(NOL)=0
#        Call STKWLOCSEQ("QCR1", NOL, LRET) From STKECR
#    Endif
    # Initialisation de l'emplacement
#    If dim([M:QCR1]LOCDES)>0 & [F:ITF]LOCMGTCOD > 1
#       [M:QCR1]LOCTYPDES(NOL) = [M:QCR1]LOCTYP(NOL)
#       [M:QCR1]LOCDES(NOL)    = [M:QCR1]LOC(NOL)
#       Call STKMODREMP([M:QCR1]WLOCSEQ(NOL),
#&                      [M:QCR1]STOFCY,
#&                      [M:QCR1]ITMREF(NOL),
#&                      [M:QCR1]PCU(NOL),
#&                      [M:QCR1]QTYPCU(NOL),
#&                      [M:QCR1]STA(NOL),
#&                      [M:QCR1]LOC(NOL),
#&                      "",mkstat,"") From STKLOC
#    Endif

Return


###############################################################################
$MAJ_STUDIS

[M:QCR1]STUDIS(nolign-1) = [F:STO]QTYSTU-[F:STO]CUMWIPQTY
Affzo [M:QCR1]STUDIS(nolign-1)

Return

###############################################################################
# MAJQTY : Mise à jour des quantités et n° de série après modif
#            de QTYPCU ou QTYSTUDES
###############################################################################
# Paramètres E : PCOD = 1: MAJ de QTYPCU
#                       2: MAJ de QTYSTUDES
#                PVAL = Nouvelle valeur
#            S : PRET = Code retour (0:OK / 1:Erreur)
###############################################################################
Subprog MAJQTY( PCOD, PVAL, PRET )
Value    Integer PCOD
Value    Decimal PVAL
Variable Integer PRET

Local Decimal LQTYSTU
Local Integer LNOL          : LNOL = nolign-1
#                                                                               # hcb 110327 deb
Local Decimal WQTYSTU
WQTYSTU = [M:QCR1]QTYSTUDES(LNOL)
#                                                                               # hcb 110327 deb

Raz PRET

If PCOD=1
    LQTYSTU = PVAL*[M:QCR1]PCUSTUCOE(LNOL)
    Call QTEARR(LQTYSTU, [M:QCR1]STU(LNOL)) From TRTDIV
Else
    LQTYSTU=PVAL
Endif

If [M:QCR1]STUDIS(LNOL)<LQTYSTU
   GMESSAGE = mess(207,197,1)
   PRET = 1
   End
Endif


[M:QCR1]QTYSTUDES(LNOL) = LQTYSTU    # On l'affecte dans tous les cas pour le calcul de STUDIS
If PCOD=1
    Affzo [M:QCR1]QTYSTUDES(LNOL)
Else
    [M:QCR1]QTYPCU(LNOL) = LQTYSTU / [M:QCR1]PCUSTUCOE(LNOL)
    Affzo [M:QCR1]QTYPCU(LNOL)
Endif

Gosub MAJ_STUDIS
#                                                                               # hcb 110327 deb
# Suppression no série en cours de traitement
If [F:ITM]SERMGTCOD=4 & [M:QCR1]SERNUM(LNOL)<>""
    Call DEL_STOSERW([F:ITM]ITMREF,[M:QCR1]SERNUM(LNOL),WQTYSTU,PRET) From STKLIB
    If PRET<>0
       End
    Else
       Raz   [M:QCR1]SERNUM (LNOL)
       Raz   [M:QCR1]SERNUMF(LNOL)
       Affzo [M:QCR1]SERNUM (LNOL)
       Affzo [M:QCR1]SERNUMF(LNOL)
    Endif
Endif
#                                                                               # hcb 110327 end

End

###############################################################################
# DISZOSTO: Diszo des champs STADES, LOCTYPDES, LOCDES
###############################################################################
# Paramètres E : PNOL = indice de la ligne concernée
#
# Attention : le masque par défaut est modifié: qcr1
###############################################################################
Subprog DISZOSTO(PABR, PNOL)
Value Integer PNOL

    Default Mask "["+PABR+"]"
    Diszo STADES   (PNOL)
#    Diszo LOCTYPDES(PNOL)
#    Diszo LOCDES   (PNOL)

End


########################################################################
# POSTABLE : Positionnement sur les tables ITM, ITF, ITFD, ITG, STL
########################################################################
Subprog POSTABLE(PFCYDES, PITM, PLOT, PSLO, PRET)
Value Char PFCYDES
Value Char PITM
Value Char PLOT
Value Char PSLO
Value Integer PRET

#---- Positionnement sur les tables ------------#
Call LECITM2( PFCYDES, PITM, "", PRET ) From STKLIB

If dim(PLOT)>0
    If dim(PSLO)>0
        If [F:STL]LOT<>PLOT | [F:STL]SLO<>PSLO
            Read [STL]STL0=PITM;PLOT;PSLO
            If fstat
                Call RSTA("STL",PITM+";"+PLOT+";"+PSLO) From GLOCK
                PRET = 1
                End
            Endif
        Endif
    Else
        If [F:STL]LOT<>PLOT | [F:STL]SLO<>""
            Read [STL]STL0=PITM;PLOT;""
            If fstat
                Call RSTA("STL",PITM+";"+PLOT+";") From GLOCK
                PRET = 1
                End
            Endif
        Endif
    Endif
Else
    If [F:STL]LOT<>"" | [F:STL]SLO<>""
        Read [STL]STL0=PITM;"";""
        If fstat
            Call RSTA("STL",PITM+";;") From GLOCK
            PRET = 1
            End
        Endif
    Endif
Endif


End




###############################################################################
# DELSTO : Efface le détail
###############################################################################
# Paramètres E : PFCY   = Site de départ
#                PLIG   = Premier indice de ligne de document supprimé
#                         (= -1 -> supprime toutes les lignes par RAZ)
#                PLIG1  = N-ième indice de ligne de document à supprimer
#
#            S : PRET   = Code retour (0=OK, 1=Erreur)
#
# Appelé dans le cadre de la suppression d'un bloc de ligne
# ou de toutes les lignes
###############################################################################
Subprog DELSTO(PFCY, PLIG, PLIG1, PRET )
Value    Char    PFCY
Value    Integer PLIG
Value    Integer PLIG1
Variable Integer PRET

Local Integer I, IND, F

Local Integer WTRBEGIN
Local Decimal LSTOCOU
Local Decimal LWIPQTY, LWIPQTA

Raz WTRBEGIN

If clalev([F:STO1])=0  Local File STOCK   [STO1]  Endif

# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO1]
   WTRBEGIN=1
Endif

For I=PLIG  To PLIG1
    Readlock [STO1]STO0=PFCY;[M:QCR1]WSTOCOU(I)
    If fstat
       If fstat=1
          GOK=0
          Call RSTA("STO1",PFCY-num$([M:QCR1]WSTOCOU(I))) From GLOCK
          LRET=1 : Break
       Endif
    Else
    # Dans le cas où l'on serait passé en négatif
       If [F:STO1]SERNUM<>""
          LWIPQTY = [F:STO1]QTYSTU
          LWIPQTA = [F:STO1]QTYSTUACT
       Else
          LWIPQTY = [M:QCR1]WWIPQTY(I)
          LWIPQTA = [M:QCR1]WWIPQTY(I)*[M:QCR1]POT(I)
       Endif
       [F:STO1]CUMWIPQTY  = max(0,[F:STO1]CUMWIPQTY-LWIPQTY)
       [F:STO1]CUMWIPQTA  = max(0,[F:STO1]CUMWIPQTA-LWIPQTA)

            # Suppression qté en cours de traitement
       LSTOCOU = [F:STO1]STOCOU
       Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
       Rewrite [STO1]
       If fstat
          GOK=0  : Call FSTA("STO1") From GLOCK
          LRET=1 : Break
       Endif
#                                                                             # hcb 110327 deb
       # Suppression série en cours de traitement
       If [F:ITM]SERMGTCOD = 4 & [M:QCR1]SERNUM(I) <> ""
          Call DEL_STOSERW([F:STO]ITMREF,[M:QCR1]SERNUM(I),[M:QCR1]QTYSTUDES(I),PRET) From STKLIB
       Endif
#                                                                             # hcb 110327 end
       IND+=1
    Endif
Next I

# Si on a ouvert une transaction
If WTRBEGIN=1
    If GOK=0
        Rollback
        End
    Else
        Commit
        Raz WTRBEGIN
    Endif
Endif

End

