#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# PJMECCSTKTOOLS
#######################################################################################
# Toolbox on ECC properties.
# FGR
#######################################################################################
#######################################################################################
# STKINIECC Recherche  versions majeure et mineure d'un article
#######################################################################################
# Limité aux besoins PJM
#######################################################################################
#                PITM       = Article
#                PTYPTIERS  = 0 = toujours préchargement > 0 préchargement
#                             1 = fournisseur 2 = client 3 client et fournisseur = client
#                PBPRNUM     = Numéro de tiers
#                PMAJ       = Version majeure
# Fonction [V]CST_AOK si pas de souci ou [V]CST_AERROR et l'erreur est dans SMESSAGE
#######################################################################################
Funprog STKINIECC(CTX, PITM, PTYPTIERS, PBPRNUM, PMAJ, SMESSAGE)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value Char PITM
Value Integer PTYPTIERS
Value Char PBPRNUM
Variable Char PMAJ
Variable Char SMESSAGE

Local Integer IARENDRE
Local Integer WECCSAIFLG
Local Integer WLOAECCFLG

  # -------------------------------
  IARENDRE = [V]CST_AOK
  Raz SMESSAGE
  # -------------------------------
  If func ASYRFNC.ACTIV("ECC") = [V]CST_AFALSE Then
    End IARENDRE
  Endif
  # -------------------------------
  Local File ITMMASTER [ITM]
  Local File ITMSALES [ITS]
  Local File ITMBPS [ITP]
  Local File ITMBPC [ITU]
  Local File ECCSTA [ECS]
  # -------------------------------
  Raz WECCSAIFLG
  Raz WLOAECCFLG
  # -------------------------------
  Read [ITM]ITM0=PITM
  If !fstat Then
    If [F:ITM]ECCSTO >= 2 Then
      If PMAJ = AVOID.ACHAR Then
        If PTYPTIERS = 0 Then
          WLOAECCFLG = [V]CST_AYES
        Else
          WECCSAIFLG = 1
          WLOAECCFLG = [F:ITM]LOAECCFLG
          # lecture article fournisseur
          If PTYPTIERS = 1 & PBPRNUM <> AVOID.ACHAR Then
            # Positionnement dans la table ITMBPS
            Read [ITP]ITP0=PITM;PBPRNUM
            If !fstat Then
              WLOAECCFLG = [F:ITP]LOAECCFLG
            Endif
          Endif
          # lecture article client
          If PTYPTIERS > 1 Then
            Read [ITS]ITS0=PITM
            If !fstat Then
              WLOAECCFLG = [F:ITS]LOAECCFLG
              If PBPRNUM  <> AVOID.ACHAR Then
                # Positionnement dans la table ITMBPC
                Read [ITU]ITU0=PITM;PBPRNUM
                If !fstat Then
                  If dim([F:ITU]LOAECCFLG) > 0 Then
                    WLOAECCFLG = [F:ITU]LOAECCFLG
                  Endif
                Endif
              Endif
            Else
              IARENDRE = [V]CST_AERROR
              SMESSAGE = func AFNC.MES1(mess(392,2260,1), PITM)
            Endif
          Endif
        Endif
        #
        If IARENDRE <> [V]CST_AERROR Then
          If WECCSAIFLG = 9 Then
            # si les versions sont issues d une nomenclature le prechargement est à oui on sort
            WLOAECCFLG = [V]CST_AYES
            End IARENDRE
          Endif
          If WLOAECCFLG <> [V]CST_AYES Then
            # si le prechargement version(s) n est pas à oui on sort
            WECCSAIFLG = 2
            End IARENDRE
          Endif
          WECCSAIFLG = 2
          If PMAJ = AVOID.ACHAR Then
            # premiere passe recherche derniere version "Active" STA = 2
            Filter [ECS] Where ITMREF = PITM & ECCSTA = 2
            Look [ECS]ECS1 First
            If !fstat Then
              Read [ECS]Curr
              PMAJ = [F:ECS]ECCVALMAJ
              WECCSAIFLG = 2
            Endif
            Filter [ECS]
            # si pas trouvée deuxieme passe recherche derniere version "Arretée" STA = 3
            If PMAJ = AVOID.ACHAR Then
              Filter [ECS] Where ITMREF = PITM & ECCSTA = 3
              Look [ECS]ECS1 First
              If !fstat Then
                Read [ECS]Curr
                PMAJ = [F:ECS]ECCVALMAJ
                WECCSAIFLG = 2
                Endif
              Filter [ECS]
            Endif
          Else
            WECCSAIFLG = 2
          Endif
        Endif
      Endif
    Endif
  Else
    IARENDRE = [V]CST_AERROR
    SMESSAGE = PITM - ":" - mess(212,199,1)
  Endif
  # -------------------------------
End IARENDRE

#######################################################################################
Funprog READECCMIN(CTX, PITM, PMAJ, PMIN, SMESSAGE)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value Char PITM
Value Char PMAJ
Variable Char PMIN
Variable Char SMESSAGE

Local Integer IARENDRE

  # -------------------------------
  IARENDRE = [V]CST_AOK
  Raz SMESSAGE
  # -------------------------------
  If func ASYRFNC.ACTIV("ECC") = [V]CST_AFALSE Then
    End IARENDRE
  Endif
  # -------------------------------
  Local File ECCVAL [EVL]
  Local File ITMMASTER [ITM]
  # -------------------------------
  If PMAJ <> AVOID.ACHAR Then
    Read [ITM]ITM0=PITM
    If !fstat Then
    If [F:ITM]ECCSTO = 3 Then
      Filter [EVL] Where ITMREF = PITM & ECCVALMAJ = PMAJ & ECCTYP = 4 Order By Key CLE = ITMREF;ECCVALMAJ;ECCVALMIN Desc
      Look [EVL]CLE First
      If !fstat Then
        Read [EVL]Curr
        PMIN = [F:EVL]ECCVALMIN
      Endif
      Filter [EVL]
    Endif
    Else
      IARENDRE = [V]CST_AERROR
      SMESSAGE = PITM - ":" - mess(212,199,1)
    Endif
  Endif
  # -------------------------------
End IARENDRE

