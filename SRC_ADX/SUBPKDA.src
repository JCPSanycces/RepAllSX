#<AdxTL>@(#)4.0.0.0 $Revision$

######################################################################"
# OUVRE                                                          OUVRE  
######################################################################"
$OUVRE

# Si on vient par tunnel il faut sauvegarder les variables globales   
If GFONC1<>"GESPKD" Gosub SAUV_GLOB From TRTX3GLOB : Endif            
If clalev([F:SRT])=0 Local File STKTRS     [SRT]  Endif                  
If clalev([F:ACV])=0 Local File ACTIV      [ACV]  Endif 
If clalev([F:FCY])=0 Local File FACILITY   [FCY]  Endif
If clalev([F:BPD])=0 Local File BPDLVCUST  [BPD]  Endif


Call INIVAR From GLOBSTO

GSRTNUM = GFLAG

Read [SRT] SRT0=11;GFLAG
If fstat | [F:SRT]ENAFLG=1 OK=0 : Endif


Return    

######################################################################"
# FERME                                                          FERME  
######################################################################"
$FERME

If GFONC1 <>"GESPKD" 
   Gosub REST_GLOB From TRTX3GLOB
   Return
Endif          

Return



######################################################################"
# FIN                                                              FIN
######################################################################"
$FIN

Return


######################################################################"
# SETBOUT                                                      SETBOUT
######################################################################"
$SETBOUT

# Menu Options / Visu transaction
CHMEN += "c"
  
Return

######################################################################"
# AVANTBOUT                                                  AVANTBOUT
######################################################################"
$AVANTBOUT


Return


######################################################################"
# AVANT_MODFIC                                            AVANT_MODFIC
######################################################################"
$AVANT_MODFIC


Return

######################################################################"
# APRES_MOD                                                  APRES_MOD
######################################################################"
$APRES_MOD

Return

######################################################################"
# LIENS                                                          LIENS  
######################################################################"
$LIENS

# Récupération des paramètres
Local Integer LTYP
LTYP              = [F:SPH]VCRTYP
Chgtzn [M:PKD0]VCRNUM With mess(LTYP,701,1)

Gosub CHARGE_COLIS

Return

######################################################################"
# FILGAUCHE                                                  FILGAUCHE  
######################################################################"
$FILGAUCHE

Return

######################################################################"
# DEFTRANS                                                    DEFTRANS  
######################################################################"

$DEFTRANS

Local Shortint OUVFICFLG
If GFONC1 <> "GESPKD" Raz GFLAG Endif                                 
If GFLAG<>""                                                          
  Read [F:SRT] SRT0=11;GFLAG                                             
  If fstat | [F:SRT]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif    
  If [F:SRT]ACSCOD<>"" & GPROFIL<>GSUPER                              
    If clalev ([F:ACC])=0                                             
        Local File ACCES  [ACC]                                       
        OUVFICFLG=1                                                   
    Endif                                                             
    Read [ACC] CODACC=GUSER;[F:SRT]ACSCOD                             
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif   
  Endif                                                               
Endif                                                                 
$FIN_DEFTRANS                                                         
If OUVFICFLG=1 Close File [ACC] : Raz OUVFICFLG : Endif               
Return                                                                
######################################################################"
# VARIANTE                                                    VARIANTE 
######################################################################"
$VARIANTE
                                                             
# La transaction lue est elle utilisable ?                            
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                   
Read [SRT]SRT0=11;[F:AWI]TRN                                             
If fstat | [F:SRT]ENAFLG<>2                                           
   OK = 0                                                             
Endif
Return                                                                
######################################################################"
# SETTRANS                                                    SETTRANS
######################################################################"
$SETTRANS
                                                                      
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                   
Read [SRT]SRT0=11;GFLAG                                                  
                                                                      
Return 


#####################################################
# Chargement du detail  colisage                    #
#         mode colisage                             #
#####################################################
$CHARGE_COLIS

Local Integer I, J, OK, REPONSE, WNBCOL, WPACSEQ
Local Integer WLIGCOL       : # Nb lignes écrans déjà colisées
Local Decimal WQTECOL       : # Qté déjà colisée sur une ligne de liv
Local Decimal WQTACOL       : # Qté à coliser en automatique sur une ligne de liv
Local Integer WDACDLV       : # No élément facturation dans livraison pour colisage





Local Char    RACINE 

#Call GETDEV([F:SDH]SALFCY)  From DEVSUB
#Call GLOBVAR([F:SDH]SALFCY) From WWGLOBVEN


Raz [M:PKD1]
[M:PKD1]       = [F:SPH]

nolign = 0
# lecture de la livraison
If [M:PKD0]VCRTYP = 4
   If [M:PKD0]VCRNUM  <> [F:SDH]SDHNUM
      Read [SDH]SDH0=[M:PKD0]VCRNUM
      If fstat
         Raz [F:SDH]
      Endif
   Endif
   [M:PKD0]BPCORD       = [F:SDH]BPCORD
   [M:PKD0]BPAADD       = [F:SDH]BPAADD
   If [F:SDH]BPDNAM(0) <> ""
      [M:PKD0]BPDNAM = [F:SDH]BPDNAM(0) 
   Else 
       If [F:BPD]BPCNUM <> [F:SDH]BPCORD | [F:BPD]BPAADD <> [F:SDH]BPAADD 
          Read [BPD]BPD0 = [F:SDH]BPCORD;[F:SDH]BPAADD
          If fstat 
             Raz [F:BPD]
          Endif
       Endif
      [M:PKD0]BPDNAM = [F:BPD]BPDNAM
   Endif
# Alimentation de l'écran des détails colis
   For [SPD]SPD0 Where VCRTYP=[M:PKD0]VCRTYP & VCRNUM=[M:PKD0]VCRNUM
       nolign += 1
      [M:PKD1] = [F:SPD]
   Next
Endif


[M:PKD1]NBLIG = nolign
# Il n'y a rien à traiter 
If [M:PKD1]NBLIG = 0 Return Endif


Affzo [M:PKD0]
Affzo [M:PKD1]
Return


# Alimentation du nombre de colis
#[M:SPK2]PACNBR = max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))



    If nolign = 1 & len([F:SPD]PACNUM) > 4
       If mid$([F:SPD]PACNUM,len([F:SPD]PACNUM)-4,1)="-" 
          RACINE = left$([F:SPD]PACNUM,len([F:SPD]PACNUM)-5)
       Else
          RACINE=""
       Endif   
    Elsif RACINE <> ""
       If len([F:SPD]PACNUM) > 4
          If RACINE <> left$([F:SPD]PACNUM,len([F:SPD]PACNUM)-5)
             RACINE = ""
          Endif
       Else
          RACINE = ""
       Endif
    Endif








