#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################
#                                                                       #
#      TRAITEMENTS EPURATION dans la GPAO                               #
#                                                                       #
#    Le fichier maître est ouvert par le superviseur avec               #
#    l'abréviation "F1"                                                 #
#    Tous les fichiers liés (voir paramétrage) sont gérés par           #
#    le superviseur. Seuls les fichiers avec un lien direct             #
#    avec le fichier maître peuvent être liés dans le paramétrage       #
#    En épuration/historisation des OF et suivis, seuls les textes      #
#    seront à gérer ici.Tous les autres fichiers seront gérés par       #
#    le superviseur                                                     #
#-----------------------------------------------------------------------#
# Issue 90275 GA 07/2013 en V6
# - ajout des sections CPTANALIN
# - MFGNUM remplacé par VCRTYP=10 + VCRNUM
#
#########################################################################
$ACTION
Case ACTION
    When "OUVRE"       : Gosub OUVRE_EPURE
    When "HISTO"       : Gosub EPURE
    When "EPURE"       : Gosub EPURE
    When "FERME"       : Gosub FERME_EPURE
Endcase
Return
#################################################################################
#    OUVRE_EPURE                                                                #
#################################################################################
$OUVRE_EPURE
Case [F:AHI]COD
    When "ORD"    :    Gosub OUVRE_EPU_ORD
    When "MFG"    :    Gosub OUVRE_EPU_MFG
    When "MTK"    :    Gosub OUVRE_EPU_MTK
Endcase
Return

#################################################################################
#    EPURE                                                                      #
#################################################################################
$EPURE
Case [F:AHI]COD
    When "ORD"    :    Gosub EPURE_ORD
    When "MFG"    :    Gosub EPURE_MFG
    When "MTK"    :    Gosub EPURE_MTK
Endcase
Return
#################################################################################
#    FERME_EPURE                                                                #
#################################################################################
$FERME_EPURE
Case [F:AHI]COD
    When "ORD"    :    Gosub FERME_EPU_ORD
    When "MFG"    :    Gosub FERME_EPU_MFG
    When "MTK"    :    Gosub FERME_EPU_MTK
Endcase
Return

#################################################################################
#    Epuration des prévisions de consommation                                   #
# ------------------------------------------------------------------------------#
#    ORD : Actions liées à l'épuration des prévisions de consommation           #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_ORD
Gosub DCLVAR
Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'une prévision de consommation             #
#-------------------------------------------------------------------------------#
$EPURE_ORD
WMESSAGE= mess(80,190,1)+"/"+[F:F1]WIPNUM+"/"+[F:F1]ITMREF
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WMESSAGE,0) From GESECRAN
Endif
Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_ORD
Return

#################################################################################
#    Epuration des OF                                                           #
# Formule d'épuration MFG :      MFGSTA = 4 & MFGTRKFLG = 6                     #
# ------------------------------------------------------------------------------#
#    MFG : Actions liées à l'épuration des OF                                   #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_MFG
Gosub DCLVAR
If HISTO
    If OKEPU=0
      #-- Historisation
           If clalev([F:MFI])=0 : Local File =[L]APPLI+".MFGITM"      [MFI] : Endif  # Issue 90275 GA 07/2013
           If clalev([F:MFO])=0 : Local File =[L]APPLI+".MFGOPE"      [MFO] : Endif
           If clalev([F:MFM])=0 : Local File =[L]APPLI+".MFGMAT"      [MFM] : Endif
           If clalev([F:TXC])=0 : Local File =[L]APPLI+".TEXCLOB"     [TXC] : Endif
           If clalev([F:CAL])=0 : Local File =[L]APPLI+".CPTANALIN"   [CAL] : Endif  # Issue 90275 GA 07/2013 Sections analytiques
           #-----------------------#
           # Fichier historisation #
           #-----------------------#
           If filinfo(filpath("FIL","TEXCLOB","fde",HISAPL),0)<0
              OK=1
           Else
             Call VUE_OK("TEXCLOB",HISAPL,"FIL",OK) From DOSVUE
           Endif
           If OK
             TABLE="TEXCLOB"
             Gosub CRETAB_HISTO
             If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
           Endif
           If clalev([F:TXC1])= 0 : Local File =[L]HISAPL+".TEXCLOB" [TXC1] : Endif
          #----- Issue 90275 GA 07/2013 Historiser CPTANALIN
            If filinfo(filpath("FIL","CPTANALIN","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("CPTANALIN",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If clalev([F:CAL1])=0 : Local File =[L]HISAPL+".CPTANALIN" [CAL1] : Endif
    Else
     #-- Epuration après historisation (Pour les vérifs et épuration du texte lié)
           If clalev([F:MFI])=0 : Local File =[L]HISAPL+".MFGITM"      [MFI] : Endif  # Issue 90275 GA 07/2013
           If clalev([F:MFO])=0 : Local File =[L]HISAPL+".MFGOPE"      [MFO] : Endif
           If clalev([F:MFM])=0 : Local File =[L]HISAPL+".MFGMAT"      [MFM] : Endif
           If clalev([F:TXC])=0 : Local File =[L]HISAPL+".TEXCLOB"     [TXC] : Endif
           If clalev([F:CAL])=0 : Local File =[L]HISAPL+".CPTANALIN"   [CAL] : Endif  # Issue 90275 GA 07/2013
    Endif
Else
   #-- Epuration seule (Pour les vérifs et épuration du texte lié)
    If clalev([F:MFI])=0 : Local File =[L]APPLI+".MFGITM"      [MFI] : Endif         # Issue 90275 GA 07/2013
    If clalev([F:MFO])=0 : Local File =[L]APPLI+".MFGOPE"      [MFO] : Endif
    If clalev([F:MFM])=0 : Local File =[L]APPLI+".MFGMAT"      [MFM] : Endif
    If clalev([F:TXC])=0 : Local File =[L]APPLI+".TEXCLOB"     [TXC] : Endif
    If clalev([F:CAL])=0 : Local File =[L]APPLI+".CPTANALIN"   [CAL] : Endif         # Issue 90275 GA 07/2013
Endif

# Issue 90275 GA 07/2013 Tables relatives aux coûts
Gosub OUVRE_EPU_CST From EPURCST

Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'un OF                                     #
#-------------------------------------------------------------------------------#
$EPURE_MFG

WCLE=[F:F1]MFGNUM : WOK=1
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif

Call RAZ_CLOB From ACLOB : # GH 19/08/2014 bug 102088

# --- Supression des tables associées à l'OF
WNUMTEX = [F:F1]MFGTEX
If WNUMTEX <> "" & left$(WNUMTEX,3) = "MFG" : Gosub EPURE_TEXTE : Endif

# --- Boucle de supression des tables associées aux articles lancés
Columns [MFI] (MFGNUM, MFGLIN)
For [F:MFI] Where MFGNUM=[F:F1]MFGNUM
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="MFI" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
Next
Columns [MFI]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif

# --- Boucle de supression des tables associées aux opérations
Columns [MFO] (MFGNUM, OPENUM, OPESPLNUM, MFOTEX)
For [F:MFO] Where MFGNUM=[F:F1]MFGNUM
    WNUMTEX = [F:MFO]MFOTEX
    If WNUMTEX <> "" & left$(WNUMTEX,3) = "MFO" : Gosub EPURE_TEXTE : Endif
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="MFOW" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="MFOL" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
Next
Columns [MFO]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif

# --- Boucle de supression des tables associées aux matières
Columns [MFM] (MFGNUM, MFGLIN, BOMSEQ, ITMREF, MFMTEX)
For [F:MFM] Where MFGNUM=[F:F1]MFGNUM
    WNUMTEX = [F:MFM]MFMTEX
    If WNUMTEX <> "" & left$(WNUMTEX,3) = "MFM" : Gosub EPURE_TEXTE : Endif
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="MFM" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
Next
Columns [MFM]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif

# Issue 90275 GA 07/2013 Historisation des tables de coûts liées à l'OF
Gosub HISTO_EPURE_MFGNUM
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif

Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_MFG
If clalev([F:MFI]) : Close Local File [MFI]  : Endif # Issue 90275 GA 07/2013
If clalev([F:MFO]) : Close Local File [MFO]  : Endif
If clalev([F:MFM]) : Close Local File [MFM]  : Endif
If clalev([F:TXC]) : Close Local File [TXC]  : Endif # Issue 90275 GA 07/2013
If clalev([F:TXC1]): Close Local File [TXC1] : Endif # Issue 90275 GA 07/2013

If clalev([F:CAL]) : Close Local File [CAL]  : Endif # Issue 90275 GA 07/2013
If clalev([F:CAL1]): Close Local File [CAL1] : Endif # Issue 90275 GA 07/2013

# Issue 90275 GA 07/2013 Tables relatives aux coûts
Gosub FERME_EPU_CST From EPURCST

Return

#################################################################################
#    Epuration des suivis                                                       #
# ------------------------------------------------------------------------------#
#    MTK : Actions liées à l'épuration des suivis                               #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_MTK
Gosub DCLVAR
If HISTO
    If OKEPU=0
      #-- Historisation
            If clalev([F:MKI])=0 : Local File =[L]APPLI+".MFGITMTRK"      [MKI] : Endif  # Issue 90275 GA 07/2013
            If clalev([F:MKO])=0 : Local File =[L]APPLI+".MFGOPETRK"      [MKO] : Endif
            If clalev([F:MKM])=0 : Local File =[L]APPLI+".MFGMATTRK"      [MKM] : Endif
            If clalev([F:TXC])=0 : Local File =[L]APPLI+".TEXCLOB"        [TXC] : Endif
            If clalev([F:CAL])=0 : Local File =[L]APPLI+".CPTANALIN"      [CAL] : Endif  # Issue 90275 GA 07/2013
          #-----------------------#
           # Fichier historisation #
           #-----------------------#
            If filinfo(filpath("FIL","TEXCLOB","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("TEXCLOB",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="TEXCLOB"
              Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If clalev([F:TXC1])= 0 : Local File =[L]HISAPL+".TEXCLOB" [TXC1] : Endif
          #----- Issue 90275 GA 07/2013
            If filinfo(filpath("FIL","CPTANALIN","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("CPTANALIN",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If !clalev([F:CAL1]) Local File =[L]HISAPL+".CPTANALIN"    [CAL1] : Endif
    Else
     #-- Epuration après historisation (Pour les vérifs et épuration du texte lié)
           If clalev([F:MKI])=0 : Local File =[L]HISAPL+".MFGITMTRK"     [MKI] : Endif  # Issue 90275 GA 07/2013
           If clalev([F:MKO])=0 : Local File =[L]HISAPL+".MFGOPETRK"     [MKO] : Endif
           If clalev([F:MKM])=0 : Local File =[L]HISAPL+".MFGMATTRK"     [MKM] : Endif
           If clalev([F:TXC])=0 : Local File =[L]HISAPL+".TEXCLOB"       [TXC] : Endif
           If clalev([F:CAL])=0 : Local File =[L]HISAPL+".CPTANALIN"     [CAL] : Endif  # Issue 90275 GA 07/2013
    Endif
Else
     #-- Epuration seule (Pour les vérifs et épuration du texte lié)
    If clalev([F:MKI])=0 : Local File =[L]APPLI+".MFGITMTRK"      [MKI] : Endif  # Issue 90275 GA 07/2013
    If clalev([F:MKO])=0 : Local File =[L]APPLI+".MFGOPETRK"      [MKO] : Endif
    If clalev([F:MKM])=0 : Local File =[L]APPLI+".MFGMATTRK"      [MKM] : Endif
    If clalev([F:TXC])=0 : Local File =[L]APPLI+".TEXCLOB"        [TXC] : Endif
    If clalev([F:CAL])=0 : Local File =[L]APPLI+".CPTANALIN"      [CAL] : Endif  # Issue 90275 GA 07/2013
Endif


Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'un suivi                                  #
#-------------------------------------------------------------------------------#
$EPURE_MTK

WCLE=[F:F1]MFGTRKNUM : WOK=1
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif

Call RAZ_CLOB From ACLOB : # GH 19/08/2014 bug 102088

# --- Supression des textes associés au suivi
WNUMTEX = [F:F1]MTKTEX
If WNUMTEX <> "" & left$(WNUMTEX,3) = "MTK" : Gosub EPURE_TEXTE : Endif

# --- Boucle de supression des tables associées aux articles lancés
Columns [MKI] (MFGTRKNUM, ITMTRKLIN)  # Issue 102616 before MFGTRKLIN
For [F:MKI] Where MFGTRKNUM=[F:F1]MFGTRKNUM
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="MKI" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
Next
Columns [MKI]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif

# --- Boucle de supression des textes associés aux suivis opérations
Columns [MKO] (MFGTRKNUM, OPETRKLIN, MKOTEX)
For [F:MKO] Where MFGTRKNUM=[F:F1]MFGTRKNUM
    WNUMTEX = [F:MKO]MKOTEX
    If WNUMTEX <> "" & left$(WNUMTEX,3) = "MKO" : Gosub EPURE_TEXTE : Endif
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="MKOW" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="MKOL" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
Next
Columns [MKO]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif

# --- Boucle de supression des textes associés aux suivis matières
Columns [MKM] (MFGTRKNUM, MATTRKLIN, MKMTEX)
For [F:MKM] Where MFGTRKNUM=[F:F1]MFGTRKNUM
    WNUMTEX = [F:MKM]MKMTEX
    If WNUMTEX <> ""  & left$(WNUMTEX,3) = "MKM"  : Gosub EPURE_TEXTE : Endif
  # Issue 90275 GA 07/2013 Sections analytiques V6
    WABRFIC="MKM" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
Next
Columns [MKM]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_MTK
If clalev([F:MKO]) : Close Local File [MKO]  : Endif
If clalev([F:MKM]) : Close Local File [MKM]  : Endif
If clalev([F:TXC]) : Close Local File [TXC]  : Endif # Issue 90275 GA 07/2013
If clalev([F:TXC1]): Close Local File [TXC1] : Endif # Issue 90275 GA 07/2013

If clalev([F:CAL]) : Close Local File [CAL]  : Endif # Issue 90275 GA 07/2013
If clalev([F:CAL1]): Close Local File [CAL1] : Endif # Issue 90275 GA 07/2013
Return


####################################################################
#    Traitements complémentaires                                   #
####################################################################
#    Routine de suppression d'un texte associé à un document       #
# A REVOIR AVEC CLOB !!!!!                                         #
#------------------------------------------------------------------#
$EPURE_TEXTE
OK=1
If [L]OKHIS & ![L]OKEPU & ![L]SIMUL
    Read [TXC]TXC0 = WNUMTEX
    If !fstat
       [F:TXC1] = [F:TXC]
       If dim([F:TXC1]CREHISDAT)>0 : [F:TXC1]CREHISDAT = date$    : Endif
       If dim([F:TXC1]CREHISUSR)>0 : [F:TXC1]CREHISUSR = [V]GUSER : Endif
       Write [TXC1]
       If fstat
          OK = 0 : Call ECR_TRACE("$TEXCLOB"-WCLE-mess(13,100,1),1) From GESECRAN : Return
       Endif
    Endif
Endif

If ![L]SIMUL
   Local Integer WRET
   Call SUP_CLOB(WNUMTEX,WRET) From TRTX3TEX
Endif

If [L]TRACEDET
  Call ECR_TRACE ("--"-WCLE-mess(4,38,1),0) From GESECRAN
Endif
Return


#-------------------------------------------------------#
# Positionnement du répertoire et déclaration variables #
#-------------------------------------------------------#
$DCLVAR
#----- Variables locales -----#
Local Char    WNUMTEX (12), WTYP(4), WMESSAGE(100), WCLE(GLONVCR)
Local Integer WCLEI
Local Char    NEWTEX(250), OLDTEX(250)
Local Integer WRETOUR
Local Integer WAPPRUL
  # Issue 90275 GA 07/2013 Sections analytiques V6
Local Integer WOK
Local Char    WCRITERE(100)
Local Char    WABRFIC(4)
Local Integer WVCRTYP,          WVCRTYP2
Local Char    WVCRNUM(GLONVCR), WVCRNUM2(GLONVCR)
Local Integer WVCRLIN
Local Integer WVCRSEQ
Local Char    WCPLCLE(30)
Local Char    WCLEFIC(50),      WCLEFIC2(50)
Local Integer WNBLNK
Return

#########################################################
$CRETAB_HISTO
#--- Création des tables non liées
NEWTAB = TABLE
Call CRETABLE(APPLI,HISAPL,TYPDBA,NEWTAB,COEFF,1) From CREHISTO
Return


#--------------------------------------------------------------------------------#
# Historisation / Epuration des tables associées aux lignes document VCRTYP=10   #
#--------------------------------------------------------------------------------#
$HISTO_EPURE_MFGNUM                                      # Issue 90275 GA 07/2013
#-----
Raz [L]WVCRLIN, [L]WVCRSEQ, [L]WCPLCLE
[L]WVCRTYP=10 : [L]WVCRNUM=[F:F1]MFGNUM
#-----

# Issue 90275 GA 07/2013 Tables relatives aux coûts
Gosub EPURE_CST From EPURCST

#-----
If [L]TRACEDET
  Call ECR_TRACE("-- WO - Tables VCRNUM"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return
#--------------------------------------------------------------------------------#
# Historisation / Epuration des comptes et sections associés aux lignes document #
#--------------------------------------------------------------------------------#
$HISTO_EPURE_CAL                 # Issue 90275 GA 07/2013 Sections analytiques V6
#-----
Raz [L]WVCRTYP, [L]WVCRNUM, [L]WVCRLIN, [L]WVCRSEQ, [L]WCPLCLE
#-----
Case WABRFIC
  When "MFI" : [L]WVCRNUM=[F:MFI]MFGNUM    : [L]WVCRLIN=[F:MFI]MFGLIN
  When "MFOW": [L]WABRFIC="MFO"
               [L]WVCRNUM=[F:MFO]MFGNUM    : [L]WVCRLIN=[F:MFO]OPENUM
               [L]WVCRSEQ=[F:MFO]OPESPLNUM : [L]WCPLCLE="EXTWST" # [F:MFO]EXTWST
  When "MFOL": [L]WABRFIC="MFO"
               [L]WVCRNUM=[F:MFO]MFGNUM    : [L]WVCRLIN=[F:MFO]OPENUM
               [L]WVCRSEQ=[F:MFO]OPESPLNUM : [L]WCPLCLE="EXTLAB" # [F:MFO]EXTLAB
  When "MFM" : [L]WVCRNUM=[F:MFM]MFGNUM    : [L]WVCRLIN=[F:MFM]MFGLIN
               [L]WVCRSEQ=[F:MFM]BOMSEQ    : [L]WCPLCLE=[F:MFM]ITMREF
  When "MKI" : [L]WVCRNUM=[F:MKI]MFGTRKNUM : [L]WVCRLIN=[F:MKI]ITMTRKLIN # Issue 102616 before MFGTRKLIN
  When "MKOW": [L]WABRFIC="MKO"
               [L]WVCRNUM=[F:MKO]MFGTRKNUM : [L]WVCRLIN=[F:MKO]OPETRKLIN
                                             [L]WCPLCLE=[F:MKO]CPLWST
  When "MKOL": [L]WABRFIC="MKO"
               [L]WVCRNUM=[F:MKO]MFGTRKNUM : [L]WVCRLIN=[F:MKO]OPETRKLIN
                                             [L]WCPLCLE=[F:MKO]CPLLAB
  When "MKM" : [L]WVCRNUM=[F:MKM]MFGTRKNUM : [L]WVCRLIN=[F:MKM]MATTRKLIN
Endcase
[L]WCLEFIC=[L]WABRFIC-num$([L]WVCRTYP)-[L]WVCRNUM-num$([L]WVCRLIN)-num$([L]WVCRSEQ)-[L]WCPLCLE
#----- Historisation -----#
If OKHIS
  Read [CAL] CAL0=[L]WABRFIC;[L]WVCRTYP;[L]WVCRNUM;[L]WVCRLIN;[L]WVCRSEQ;[L]WCPLCLE;1
  If !fstat & ![L]SIMUL
    [F:CAL1]=[F:CAL]
    If dim([F:CAL1]CREHISDAT)>0  [F:CAL1]CREHISDAT=date$    : Endif
    If dim([F:CAL1]CREHISUSR)>0  [F:CAL1]CREHISUSR=[V]GUSER : Endif
    Write [CAL1]
    If fstat
      Call ECR_TRACE("$CPTANALIN"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
      WOK=0 : Return
    Endif
  Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [CAL] Where ABRFIC=[L]WABRFIC
&                  & VCRTYP=[L]WVCRTYP
&                  & VCRNUM=[L]WVCRNUM
&                  & VCRLIN=[L]WVCRLIN
&                  & VCRSEQ=[L]WVCRSEQ
&                  & CPLCLE=[L]WCPLCLE
&                  & ANALIG=1
  If fstat
    Call ECR_TRACE("$CPTANALIN"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- CPTANALIN"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return
