Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Return

$LEC_DERLU
Read [CPY]CPY0=[F:POT]CPYPOT
If fstat : Raz [F:CPY] : Endif
Read [FCY]FCY0=[F:POT]FCYPOT
If fstat : Raz [F:FCY] : Endif
Read [SRV]SRV0=[F:POT]SRVPOT
If fstat : Raz [F:SRV] : Endif
Read [AX3]AXX0="COURSEI";"DES";GLANGUE;num$([F:POT]SRVPOT);num$("")
If fstat : Raz [F:AX3] : Endif
Read [AX4]AXX0="POSTE";"DES";GLANGUE;[F:POT]COD;""
If fstat : Raz [F:AX4] : Endif
Return

$CHARGE_DERLU
Return

$REMP_DERLU
Return

$CLE_DERLU
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 2
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(1)"
SELEXP(NBSEL) = "[F:POT]CPYPOT-[F:CPY]CPYNAM"
Call TEXTE(1343,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(2)"
SELEXP(NBSEL) = "[F:POT]FCYPOT-[F:FCY]FCYNAM"
Call TEXTE(1344,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(3)"
SELEXP(NBSEL) = "[F:POT]SRVPOT-[F:AX3]TEXTE"
Call TEXTE(18735,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:POT]COD"
Call TEXTE(22321,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:POT]COD"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(5)"
SELEXP(NBSEL) = "[F:AX4]TEXTE"
Call TEXTE(35,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
If clalev([F:POT_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:CPY])=0 : Local file COMPANY [CPY] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:SRV])=0 : Local file SERVICE [SRV] : Endif
If clalev([F:AX3])=0 : Local file ATEXTRA [AX3] : Endif
If clalev([F:AX4])=0 : Local file ATEXTRA [AX4] : Endif
Link [POT] With
& [CPY]CPY0=[F:POT]CPYPOT,
& [FCY]FCY0=[F:POT]FCYPOT,
& [SRV]SRV0=[F:POT]SRVPOT,
& [AX3]AXX0="COURSEI";"DES";GLANGUE;num$([F:POT]SRVPOT);num$(""),
& [AX4]AXX0="POSTE";"DES";GLANGUE;[F:POT]COD;""
& As [POT_]
[G:POT_]currind = 4
Return

$DEFAUT_LISTE
Default file [POT_]
Return

$OUVRE_JOIN
Return

$TIT_JOIN
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:10c"
LG = 0
TIT = ""
End

$LIENS
Read [CPY]CPY0 = [F:POT]CPYPOT
If fstat : Raz [F:CPY] : Endif
Read [FCY]FCY0 = [F:POT]FCYPOT
If fstat : Raz [F:FCY] : Endif
Read [SRV]SRV0 = [F:POT]SRVPOT
If fstat : Raz [F:SRV] : Endif
Read [AX3]AXX0 = "COURSEI";"DES";GLANGUE;num$([F:POT]SRVPOT);num$("")
If fstat : Raz [F:AX3] : Endif
Read [AX4]AXX0 = "POSTE";"DES";GLANGUE;[F:POT]COD;""
If fstat : Raz [F:AX4] : Endif
Return

