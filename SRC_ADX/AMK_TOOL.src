#**
#* return the name of the given field of the given screen
#*
#* @param SCREEN_CODE
#* @param FIELD_CODE
#*!
Funprog GET_FIELD_LABEL(SCREEN_CODE, FIELD_CODE)
Value Char SCREEN_CODE, FIELD_CODE
 Local Char RES_LABEL(50)
 If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif

 Read [AMZ]CODE = SCREEN_CODE; FIELD_CODE
 If !fstat
  RES_LABEL= func ASYRFNC.TEXTE([F:AMZ]INTIT)
 Endif

End RES_LABEL

#**
#* return the num name of the given field of the given screen
#*
#* @param SCREEN_CODE
#* @param FIELD_CODE
#*!
Funprog GET_FIELD_NUMLABEL(SCREEN_CODE, FIELD_CODE)
Value Char SCREEN_CODE, FIELD_CODE
 If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif

 Read [AMZ]CODE = SCREEN_CODE; FIELD_CODE
 If !fstat
  End [F:AMZ]INTIT
 Endif

End 0
