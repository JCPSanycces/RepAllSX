RESULTAT="EN4"

#Qtûˋ 1 : Licenciement ûˋco
RESULTAT+=string$(15-len(num$(GRDZE(0))),"0")+num$(GRDZE(0))
#Qtûˋ 2 : Fin CDD
RESULTAT+=string$(15-len(num$(GRDZE(1))),"0")+num$(GRDZE(1))
#Qtûˋ 3 :Embauche CDI
