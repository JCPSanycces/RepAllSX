#########################################
$ENREG_GEN
#Effectif û  Zûˋro si dûˋclaration nûˋant
If [M:DIA]FLGNEA=2 : Raz AMTTOT : Raz AMTMSS : Endif

#code enreg
RESULTAT="GEN"
#Pûˋriode de ref
If [M:DIA]ENDDAT-[M:DIA]STRDAT>360
 Call RECUP_DATE ([M:DIA]STRDAT, "AAAA", WDAT) From TRTDCS
 RESULTAT+=WDAT+space$(31)+"602"
Elsif [M:DIA]ENDDAT-[M:DIA]STRDAT<31
 Call RECUP_DATE ([M:DIA]STRDAT, "AAAAMM", WDAT) From TRTDCS
 RESULTAT+=WDAT+space$(29)+"610"
Else
 Call RECUP_DATE ([M:DIA]STRDAT, "AAAAT", WDAT) From TRTDCS
 RESULTAT+=WDAT+space$(30)+"608"
Endif
#pûˋriode2 + qualifiant pûˋriode2
RESULTAT+=space$(38)
#Effectif au 31/12 sociûˋtûˋ si bordereau DRA ou AVA
If val(NUMBORD)=922 | val(NUMBORD)=923 | val(NUMBORD)=924 | val(NUMBORD)=926 | val(NUMBORD)=928 | val(NUMBORD)=929
 RESULTAT+=string$(15-len(num$(EFFMRK)),"0")+num$(EFFMRK)
Else
 RESULTAT+=string$(15,"0")
Endif
#statut juridique (facultatif)
RESULTAT+=space$(35)
#Montant 1 : Total cotisation si bordereau ADV ou AVA
If (val(NUMBORD)=920 | val(NUMBORD)=921 | val(NUMBORD)=924 | val(NUMBORD)=926 | val(NUMBORD)=927)
 RESULTAT+=string$(18-len(num$(abs(AMTTOT))),"0")+num$(abs(AMTTOT))
 #Qualifiant montant 1
 If AMTTOT>=0 : RESULTAT+="277" : Else :  RESULTAT+="977" :  Endif
Else
 RESULTAT+=string$(18,"0")+space$(3)
Endif
#Montant 2 : Masse salariale si bordereau DRA
If (val(NUMBORD)=922 | val(NUMBORD)=923 | val(NUMBORD)=929 | val(NUMBORD)=928 )
 RESULTAT+=string$(18-len(num$(abs(AMTMSS))),"0")+num$(abs(AMTMSS))
 #Qualifiant montant 2
 If AMTMSS>=0 : RESULTAT+="276" : Else :  RESULTAT+="976" :  Endif
Else
 RESULTAT+=string$(18,"0")+space$(3)
Endif
#Montant 3 + Qualifiant 3
RESULTAT+=string$(18,"0")+space$(3)
#nb lignes(18 caractû´res)
RESULTAT+=string$(18,"0")
#authentification
RESULTAT+=space$(35)
#Devise
RESULTAT+=DEVISE
#filler
RESULTAT+=space$(7)
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Return

#########################################
$ENREG_EN
#Code enreg
RESULTAT="EN1"
#qualif intervenant
RESULTAT+="WP"+space$(1)
#identification intervenant
Read[F:FCY2]FCY0=[F:FCY]FCY
If fstat=0
 INFO=[F:FCY2]CRN
 Gosub RECUP_INFO From TRTDCS
 RESULTAT+=space$(3)
 Gosub RECUP_FCY From TRTDCS
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Gosub ENREG_EN2
Else
 Call ECR_TRACE("EN1"-mess(4,10707,1)-"FACILITY [FCY2]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_EN2
#Code enreg
RESULTAT="EN2"
#collaborateur
Read[F:CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Gosub RECUP_CNT From TRTDCS
 Call ORGAFFIL ([M:DIA]ORG,[F:FCY2]FCY,"","",VNUMAFF,VNUMCTR) From SUBORA
 #Si PG
 #No ref. 1: no compte ASSEDIC affiliation (que site secondaire)
 If [F:FCY2]FCY<>[F:DUC]FCYDCL & (val(NUMBORD)=921 |  val(NUMBORD)=923 | val(NUMBORD)=926 | val(NUMBORD)=929)
  Read[F:ORG]ORG0=GCURLEG;[M:DIA]ORG
  If fstat | [F:ORG]NUMASS="" | VNUMAFF=""
   #Rûˋfûˋrence 1
   Call ECRIT_TRACE("EN2",mess(6,159,1)-"1") From TRTDCS
   RESULTAT+=space$(35)
  Else
   #44297
   If len([F:ORG]NUMASS)<3
    VNUMAFF=string$(3-len([F:ORG]NUMASS),"0")+[F:ORG]NUMASS+VNUMAFF
   Else
    VNUMAFF=[F:ORG]NUMASS+VNUMAFF
   Endif
   If len (VNUMAFF)<35
    RESULTAT+=VNUMAFF+space$(35-len(VNUMAFF))
   Else
    RESULTAT+=left$(VNUMAFF,35)
   Endif
  Endif
 Else
  RESULTAT+=space$(35)
 Endif
 #No ref. 2: no compte ASSEDIC recouvrement
 Read[F:ORG]ORG0=GCURLEG;[M:DIA]ORG
 If fstat | [F:ORG]NUMASS="" | VNUMAFF=""
  #Rûˋfûˋrence 2
  Call ECRIT_TRACE("EN2",mess(6,159,1)-"2") From TRTDCS
  RESULTAT+=space$(35)
 Else
  #44297
  If len([F:ORG]NUMASS)<3
   VNUMAFF=string$(3-len([F:ORG]NUMASS),"0")+[F:ORG]NUMASS+VNUMAFF
  Else
   VNUMAFF=[F:ORG]NUMASS+VNUMAFF
  Endif
  If len (VNUMAFF)<35
   RESULTAT+=VNUMAFF+space$(35-len(VNUMAFF))
  Else
   RESULTAT+=left$(VNUMAFF,35)
  Endif
 Endif
 #No ref. 3: Code APE/NAF
 If len ([F:FCY2]NAF)<35
  RESULTAT+=[F:FCY2]NAF+space$(35-len([F:FCY2]NAF))
 Else
  RESULTAT+=left$([F:FCY2]NAF,35)
 Endif
 #No ref. 4 :  (que pour DRA) : rûˋmunûˋration brute DADS contient le mois de dûˋcembre ? (0=non ; 1=oui)
 If val(NUMBORD)=922 | val(NUMBORD)=923  | val(NUMBORD)=928 | val(NUMBORD)=929
  Call PARAM([F:FCY2]FCY,"FLGSALDEC",VALPAR) From ADOVAL
  If val(VALPAR)=2 : VFLGEDI=1 :  Else : VFLGEDI=0 : Endif
  RESULTAT+=num$(VFLGEDI)+space$(35-len(num$(VFLGEDI)))
 Else
  RESULTAT+=space$(35)
 Endif
 #Zones inutilisûˋes
 RESULTAT+=space$(27)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Gosub ENREG_EN3
Else
 Call ECR_TRACE("EN2"-mess(4,10707,1)-"CONTACT [CNT]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_EN3
#En PG le EN3 doit ûˆtre prûˋsent que pour le site dûˋclarant...-> on passe direct au EN4
If (NUMBORD="921" | NUMBORD="923" | NUMBORD="926" | NUMBORD="929") & [M:DIA]FLGNEA<>2 & [F:FCY2]FCY<>[F:DUC]FCYDCL
 Gosub ENREG_EN4
Else

 #Mtt û  Zûˋro si dûˋclaration nûˋant
 If [M:DIA]FLGNEA=2 : Raz AMTFCY: Raz MSSFCY : Raz AMTBRT : Endif

 #Code enreg
 RESULTAT="EN3"
 #Date/Pûˋriode : Si DRA alors date de versement des salaires
 If val(NUMBORD)=922 | val(NUMBORD)=923 | val(NUMBORD)=928 | val(NUMBORD)=929
  Call RECUP_DATE (DATVERS,"AAAAMMJJ",WDAT) From TRTDCS
  RESULTAT+=WDAT+space$(35-len(WDAT))+"102"
 Else
  RESULTAT+=space$(38)
 Endif

 #Montant : Uniquement ADV et AVA
 If (val(NUMBORD)=920 | val(NUMBORD)=921| val(NUMBORD)=924 | val(NUMBORD)=926 |val(NUMBORD)=927) & AMTFCY<>0
  #Total cotisations
  RESULTAT+=string$(18-len(num$(abs(AMTFCY))),"0")+num$(abs(AMTFCY))
  If AMTFCY>0 : RESULTAT+="277" : Else : RESULTAT+="977" : Endif
 Else
  RESULTAT+=string$(18,"0")+space$(3)
 Endif

 #Montant2 : Uniquement pour les DRA
 If (val(NUMBORD)=922 | val(NUMBORD)=923 | val(NUMBORD)=928 | val(NUMBORD)=929) & MSSFCY<>0
  RESULTAT+=string$(18-len(num$(abs(MSSFCY))),"0")+num$(abs(MSSFCY))
  #Qualifiant montant 2
  If MSSFCY>0 : RESULTAT+="276" : Else : RESULTAT+="976" : Endif
 Else
  RESULTAT+=string$(18,"0")+space$(3)
 Endif

 #Montant3 non utilisûˋ + qualifiant montant 3
 RESULTAT+=string$(18,"0")+space$(3)

 #Qualifiant date/pûˋriode : Uniquement pour les DRA ou AVA
 #+ Date/Pûˋriode et qualifiant
 #Montant 4
 If (val(NUMBORD)=922 | val(NUMBORD)=923 | val(NUMBORD)=924 | val(NUMBORD)=926 | val(NUMBORD)=928 | val(NUMBORD)=929)
  Gosub DERNIERMOIS From TRTDCS
  If LASTMOIS=12 : RESULTAT+="901"  : Else : RESULTAT+="902" : Endif
  If len(num$(day(DATVERS)))=2
   RESULTAT+=num$(day(DATVERS))+"110"
  Else
   RESULTAT+=space$(1)+num$(day(DATVERS))+"110"
  Endif
  If AMTBRT<>0
   RESULTAT+=string$(18-len(num$(abs(AMTBRT))),"0")+num$(abs(AMTBRT))
   #Qualifiant montant 4
   If AMTBRT>0 : RESULTAT+="172" : Else : RESULTAT+="972" : Endif
  Else
   RESULTAT+=string$(18,"0")+space$(3)
  Endif
 Else
  RESULTAT+=space$(8)+string$(18,"0")+space$(3)
 Endif
 #Filler
 RESULTAT+=space$(122)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Gosub ENREG_EN4
Endif
Return

#########################################
$ENREG_EN4
#Code enreg
RESULTAT="EN4"
#Effectif û  Zûˋro si dûˋclaration nûˋant
If [M:DIA]FLGNEA=2
 RESULTAT+=string$(240,"0")
 #qualifiant
 RESULTAT+="RG"
Else
 #Effectifs dependant du bordereau...
 If val(NUMBORD)= 920 | val(NUMBORD)= 921  | val(NUMBORD)= 927
  Gosub EFFADV
 Else
  Gosub EFFDRA_AVA
 Endif
Endif
#filler
RESULTAT+=space$(10)
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]

#Motif d'ûˋcart dans les DRA si pas nûˋant
If [M:DIA]FLGNEA<>2
 If (val(NUMBORD)= 922 | val(NUMBORD)= 923)
  Gosub ENREG_EN4BIS
 Endif
 If NUMBORD="921" | NUMBORD="923" | NUMBORD="926" | NUMBORD="929"
  #Paiement groupûˋ (PG)
  CRITCOT="1=1"
  Gosub ENREG_COT
 Else
  #Cotisations du site courant
  CRITCOT="FCY=[F:FCY2]FCY"
  Gosub ENREG_COT
 Endif
Endif
Return

#########################################
$ENREG_COT
For[F:TDU]TDU0 Where USR=GUSER & CREDAT=date$ & CAI=[M:DIA]CAI & evalue(CRITCOT)
 #Code enreg
 RESULTAT="COT"
 #Qualif ligne cotisation"
#65985
 #RESULTAT+="906"
 Read[F:ADI]CODE=10377;[F:TDU]CODDCS
 If fstat=0
  If [F:ADI]N1>99 & [F:ADI]N1<1000
   RESULTAT+=num$([F:ADI]N1)
  Else
   RESULTAT+="906" :#Assedic par dûˋfaut
  Endif
#
  #Type cotisation
  RESULTAT+=[F:ADI]A2
 Else
  Call ECR_TRACE("COT"-mess(4,10707,1)-"ATABDIV [ADI]",1) From GESECRAN
  OK=0 : Break
 Endif
 #Qualif instruction+instruction codûˋe
 RESULTAT+=space$(6)
 #No ligne
 RESULTAT+=string$(6,"0")
 #Date de dûˋbut de changements de cotisations sur 35 cacarctû´res
 If [F:TDU]PERDEB<>[0/0/0]
  Call RECUP_DATE ([F:TDU]PERDEB, "AAAAMMJJ", WDAT) From TRTDCS
  RESULTAT+=WDAT+space$(35-len(WDAT))+"102"
 Else
  RESULTAT+=space$(38)
 Endif
 #Taux % cotisations
 RESULTAT+=string$(8-len(num$([F:TDU]RAT*10000)),"0")+num$([F:TDU]RAT*10000)
 #Type montant(930 = salaires reels positif ; 932 = nûˋgatif)
 If [F:TDU]AMT1>=0 :  RESULTAT+="930" : Else :  RESULTAT+="932" : Endif
 #Montant1
 RESULTAT+=string$(18-len(num$(abs(arr([F:TDU]AMT1,1)))),"0")+num$(abs(arr([F:TDU]AMT1,1)))
 #Champ rûˋservûˋ
 RESULTAT+=space$(3)
 #####################
 #Salaires forfaitaires -> pour les dockers et en Avril 2007, les dûˋclarations EDI pour les dockers ne sont pas acceptûˋes...
 #Type montant(931 = salaires forfaits positif ; 933 = nûˋgatif)
 #If [F:TDU]AMT2>=0 :  RESULTAT+="931" : Else :  RESULTAT+="933" : Endif
 RESULTAT+="931"
 #Montant2
 #RESULTAT+=string$(18-len(num$(abs(arr([F:TDU]AMT2,1)))),"0")+num$(abs(arr([F:TDU]AMT2,1)))
 RESULTAT+=string$(18,"0")
 #####################
 #Champ rûˋservûˋ
 RESULTAT+=space$(3)
 #Effectifs inutilisûˋs
 RESULTAT+=string$(30,"0")
 #Zones non utilisûˋes
 RESULTAT+=space$(110)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Next
If !OK : Return : Endif
Return

#########################################
$ENREG_PAI
#Code enreg
RESULTAT="PAI"
Call ORGBAN([M:DIA]ORG,[M:DIA]CPY,[L]MODPAY,[L]BAN(0),[L]BAN(1)) From SUBORA
If [L]MODPAY
 #Mode de paiement +Qualif du compte bancaire
 If [L]MODPAY=1     :#chû´que
  RESULTAT+="20"+space$(1)
  RESULTAT+="BF"+space$(1)
  RESULTAT+=space$(75)
 Elsif [L]MODPAY=2  :#virement
  RESULTAT+="30"+space$(1)
  RESULTAT+="BF"+space$(1)
  Call RECUP_ORG ([M:DIA]COD,RESULTAT,OK)From TRTDCS
 Else                      :#tûˋlûˋrû´glement
  RESULTAT+="Z10"
  RESULTAT+="OR"+space$(1)
  If [M:DIA]BANFCY(NUMBANK)<>""
   Call RECUP_BANK ([M:DIA]BANFCY(NUMBANK),RESULTAT,OK)From TRTDCS
  Else
   #Banque non renseignûˋe
   Call ECR_TRACE("PAI"-mess(20,10711,1),1) From GESECRAN
   OK=0 : Return
  Endif
 Endif
 If OK=0 : Return : Endif
 #Montant rûˋglûˋ
 If NUMBANK=0
  If MAXAMT<>0 & MAXAMT<AMTTOT
   RESULTAT+=string$(18-len(num$(abs(MAXAMT))),"0")+num$(abs(MAXAMT))
  Else
   RESULTAT+=string$(18-len(num$(abs(AMTTOT))),"0")+num$(abs(AMTTOT))
  Endif
 Else
  RESULTAT+=string$(18-len(num$(abs(AMTTOT)-abs(MAXAMT))),"0")+num$(abs(AMTTOT)-abs(MAXAMT))
 Endif
 #Devise
 RESULTAT+=DEVISE+space$(3-len(DEVISE))
 #Type de rûˋfûˋrence
 If [L]MODPAY<3     :#chû´que ou virement
  RESULTAT+="PQ"+space$(1)
  RESULTAT+="99" :#pour clûˋ non calculûˋe
  RESULTAT+="S2" :#ASSEDIC
  Call ORGAFFIL ([M:DIA]ORG,[M:DIA]CPY,"","",VNUMAFF,VNUMCTR) From SUBORA
  Read[F:ORG]ORG0=GCURLEG;[M:DIA]ORG
  INFO="0"+[F:ORG]NUMASS+VNUMAFF
  Gosub REF_SOCIALE From TRTDCS
 Else
  RESULTAT+="CR"+space$(1)
  RESULTAT+="ASSEDIC"+space$(1)
  Gosub REF_CPOP From TRTDCS
 Endif
#Filler
 RESULTAT+=space$(71)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Else
 Call ECR_TRACE("PAI"-mess(4,10707,1)-"ORGBAN [ORB]",1) From GESECRAN
 OK=0 : Return
Endif
Return


#############################################
$EFFADV
#Nb total salariûˋ hommes prûˋsent au dernier jour de la pûˋriode dans le site
RESULTAT+=string$(15-len(num$(EFFMENFCY)),"0")+num$(EFFMENFCY)
#Nb total salariûˋ femmes prûˋsent au dernier jour de la pûˋriode dans le site
RESULTAT+=string$(15-len(num$(EFFWOMFCY)),"0")+num$(EFFWOMFCY)
#Effectifs inutilisûˋs
RESULTAT+=string$(210,"0")
#Qualifiant (pos 244)
RESULTAT+="RG"
Return

#RG = Regime general
#AEM : Intermitant  (On gû´re pas encore...)
#CT = Collectivitûˋ territoriale (On gû´re pas)
#DS : Dispositif simplifiûˋ  (On gû´re pas)
#############################################
$EFFDRA_AVA

#(RG)
If val(NUMBORD)< 928
 #Nb salariûˋ hommes en CDD (pos 04)
 RESULTAT+=string$(15-len(num$(EFFMENCDD)),"0")+num$(EFFMENCDD)
 #Nb salariûˋ femmes en CDD (pos 19)
 RESULTAT+=string$(15-len(num$(EFFWOMCDD)),"0")+num$(EFFWOMCDD)
 #Nb salariûˋ hommes en CDI (pos 34)
 RESULTAT+=string$(15-len(num$(EFFMENCDI)),"0")+num$(EFFMENCDI)
 #Nb salariûˋ femmes en CDI (pos 49)
 RESULTAT+=string$(15-len(num$(EFFWOMCDI)),"0")+num$(EFFWOMCDI)
#(CT)
Else
 #Effectifs inutilisûˋs (pos 04 û  19)
 RESULTAT+=string$(30,"0")
 #Nb salariûˋ hommes en Contrat temps complet (pos 34)
 RESULTAT+=string$(15,"0")
 #Nb salariûˋ femmes en Contrat temps complet (pos 49)
 RESULTAT+=string$(15,"0")
Endif

#Tous les bordereaux AVA et DRA (RG et CT)
#Nb salariûˋ hommes apprenti (pos 64)
RESULTAT+=string$(15-len(num$(EFFMENAPP)),"0")+num$(EFFMENAPP)
#Nb salariûˋ femmes apprenti (pos 79)
RESULTAT+=string$(15-len(num$(EFFWOMAPP)),"0")+num$(EFFWOMAPP)

#(RG)
If val(NUMBORD)< 928
 #Nb salariûˋ hommes +65ans (pos 94)
 RESULTAT+=string$(15-len(num$(EFFMENOLD)),"0")+num$(EFFMENOLD)
 #Nb salariûˋ femmes +65ans (pos 109)
 RESULTAT+=string$(15-len(num$(EFFWOMOLD)),"0")+num$(EFFWOMOLD)
 #Nb salariûˋ hommes Direction (pos 124)
 RESULTAT+=string$(15-len(num$(EFFMENDIR)),"0")+num$(EFFMENDIR)
 #Nb salariûˋ femmes Direction (pos 139)
 RESULTAT+=string$(15-len(num$(EFFWOMDIR)),"0")+num$(EFFWOMDIR)
#(CT)
Else
 #Nb salariûˋ hommes Emploi de Ville ou Emploi Jeune(pos 94)
 RESULTAT+=string$(15,"0")
 #Nb salariûˋ femmes Emploi de Ville ou Emploi Jeune (pos 109)
 RESULTAT+=string$(15,"0")
 #Nb salariûˋ hommes Assistant d'ûˋducation (pos 124)
 RESULTAT+=string$(15,"0")
 #Nb salariûˋ femmes Assistant d'ûˋducation (pos 139)
 RESULTAT+=string$(15,"0")
Endif

#Tous les bordereaux AVA et DRA (RG et CT)
#Nb salariûˋ hommes Contrat Emploi Solidaritûˋ (pos 154)
RESULTAT+=string$(15-len(num$(EFFMENCES)),"0")+num$(EFFMENCES)
#Nb salariûˋ femmes Contrat Emploi Solidaritûˋ (pos 169)
RESULTAT+=string$(15-len(num$(EFFWOMCES)),"0")+num$(EFFWOMCES)

#(RG)
If val(NUMBORD)< 928
 #Nb salariûˋ hommes Contrat Nouvelle Embauche  (pos 184)
 RESULTAT+=string$(15-len(num$(EFFMENCNE)),"0")+num$(EFFMENCNE)
 #Nb salariûˋ femmes Contrat Nouvelle Embauche (pos 199)
 RESULTAT+=string$(15-len(num$(EFFWOMCNE)),"0")+num$(EFFWOMCNE)
Else
 #(AEM mais on ne gû´re pas encore...)
 If NUMBORD="U01"
  #Nb salariûˋ total Intermittents payûˋ sur le mois(pos 184)
  RESULTAT+=string$(30,"0")
  #Nb salariûˋ total de fin de contrat sur le mois (pos 199)
  RESULTAT+=string$(30,"0")
 # (CT)
 Else
  #Nb salariûˋ hommes Contrat Temps partiel  (pos 184)
  RESULTAT+=string$(15,"0")
  #Nb salariûˋ femmes Contrat Temps partiel (pos 199)
  RESULTAT+=string$(15,"0")
 Endif
Endif

RESULTAT+=string$(30,"0")

#Qualifiant (pos 244)
If val(NUMBORD)< 928 | NUMBORD="U01"
 RESULTAT+="RG"
Else
 RESULTAT+="CT"
Endif

Return


