#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################
$ENREG_DEB
#Code enreg
RESULTAT="DEB"
#Identification de l'ûˋmetteur
RESULTAT+="ES"
Read[F:FCY2]FCY0=[F:DUC]FCYSEN
If !fstat
 If [F:FCY2]CRN=""
  #Identification de l'ûˋmetteur physique
  Call ECRIT_TRACE("DEB",mess(7,10707,1)) From TRTDCS
 Else
  If len ([F:FCY2]CRN)<33
   RESULTAT+=[F:FCY2]CRN+space$(33-len([F:FCY2]CRN))
  Else
   RESULTAT+=left$([F:FCY2]CRN,33)
  Endif
 Endif
Else
 Call ECR_TRACE("DEB"-mess(4,10707,1)-"FACILITY [FCY2]",1) From GESECRAN
 OK=0 : Return
Endif
#qualifiant de l'identifiant emetteur
RESULTAT+="ZZZ"+space$(1)
#Identification du recepteur
#63040
#If [M:DIA]FLGSND=2 :#oui
If [M:DIA]FLGSND<>2 :#oui
 RESULTAT+="H03S000DUCS"+space$(24)
Else
 RESULTAT+="H02S000DUCS"+space$(24)
Endif
#qualifiant de l'identifiant recepteur
RESULTAT+="ZZZ"+space$(1)
Gosub COMDEB1 From TRTDCS
#Type dûˋclaration
RESULTAT+="902"
Gosub COMDEB2 From TRTDCS
#Type de borderau
Read[F:ORG]ORG0=GCURLEG;[M:DIA]ORG
If !fstat
 RESULTAT+=NUMBORD
Else
 Call ECR_TRACE("DEB"-mess(4,10707,1)-"ORGANISME [ORG]",1) From GESECRAN
 OK=0 : Return
Endif
Gosub COMDEB3 From TRTDCS
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Gosub ENREG_FR
Gosub ENREG_DT
Gosub ENREG_MR
#Tiers dûˋclarant
If [F:DUC]FLGEXT=2 : Gosub ENREG_AE : Endif
#Paiement groupûˋ (PG).
If NUMBORD="921" | NUMBORD="923" | NUMBORD="926" | NUMBORD="929"
 Gosub ENREG_FZ
Endif
Gosub ENREG_GEN
Return

#########################################
$ENREG_FR
#code enreg
RESULTAT="FR1"
#Intervenant
RESULTAT+="FR"+space$(1)
RESULTAT+="ES"
Read[F:FCY2]FCY0=[F:DUC]FCYSEN
If !fstat
 If [F:FCY2]CRN=""
  #Identification de l'ûˋmetteur physique
  Call ECRIT_TRACE("FR1",mess(7,10707,1)) From TRTDCS
 Else
  If len ([F:FCY2]CRN)<33
   RESULTAT+=[F:FCY2]CRN+space$(33-len([F:FCY2]CRN))
  Else
   RESULTAT+=left$([F:FCY2]CRN,33)
  Endif
 Endif
Else
 Call ECR_TRACE("FR1"-mess(4,10707,1)-"FACILITY [FCY2]",1) From GESECRAN
 OK=0 : Return
Endif
#Zone reservûˋe
RESULTAT+=space$(3)
Gosub RECUP_FCY From TRTDCS
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Gosub ENREG_FR2
Return

#########################################
$ENREG_FR2
#code enreg
RESULTAT="FR2"
#collaborateur
Read[F:CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Read [AIN]AIN0=[F:FCY2]CNTNAM
 If fstat=0
  Gosub RECUP_CNT From TRTDCS
  #Zones non utilisûˋes
  RESULTAT+=space$(167)
  Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
  Gosub ENREG_FR3
 Else
  Call ECR_TRACE("FR2"-mess(4,10707,1)-"CONTACTCRM [AIN]",1) From GESECRAN
  OK=0 : Return
 Endif
Else
 Call ECR_TRACE("FR2"-mess(4,10707,1)-"CONTACT [CNT]",1) From GESECRAN
 OK=0 : Return
Endif
Return

