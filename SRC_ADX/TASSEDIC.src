#Qtûˋ 4 :Embauche CDD
RESULTAT+=string$(15-len(num$(GRDZE(3))),"0")+num$(GRDZE(3))
#Qtûˋ 5 : Transfert
RESULTAT+=string$(15-len(num$(GRDZE(4))),"0")+num$(GRDZE(4))
#Qtûˋ 6 : Reprise
RESULTAT+=string$(15-len(num$(GRDZE(5))),"0")+num$(GRDZE(5))
#Qtûˋ 7 : Redressemnt
RESULTAT+=string$(15-len(num$(GRDZE(6))),"0")+num$(GRDZE(6))
#Qtûˋ 8 : Autres
RESULTAT+=string$(15-len(num$(GRDZE(7))),"0")+num$(GRDZE(7))
#Qtûˋ 9 : CNE
