#########################################
$ENREG_MR
#code enreg
RESULTAT="MR1"
#Intervenant
RESULTAT+="MR"+space$(1)
Read[F:ORG]ORG0=GCURLEG;[M:DIA]ORG
If fstat=0
 #Siret organisme
 INFO=[F:ORG]CRN
 Gosub RECUP_INFO From TRTDCS
 #Zone reservûˋe
 RESULTAT+=space$(3)
 #Nom1
 If len([F:ORG]DES)<35
  RESULTAT+=[F:ORG]DES+space$(35-len([F:ORG]DES))
 Else
  RESULTAT+=left$([F:ORG]DES,35)
 Endif
 #Nom2
 RESULTAT+=space$(35)
 #Adresse
 If len([F:ORG]ADD(0))<35
  RESULTAT+=[F:ORG]ADD(0)+space$(35-len([F:ORG]ADD(0)))
 Else
  RESULTAT+=left$([F:ORG]ADD(0),35)
 Endif
 If len([F:ORG]ADD(1))<35
  RESULTAT+=[F:ORG]ADD(1)+space$(35-len([F:ORG]ADD(1)))
 Else
  RESULTAT+=left$([F:ORG]ADD(1),35)
 Endif
 If len([F:ORG]CTY)<35
  RESULTAT+=[F:ORG]CTY+space$(35-len([F:ORG]CTY))
 Else
  RESULTAT+=left$([F:ORG]CTY,35)
 Endif
 If len([F:ORG]POS)<9
  RESULTAT+=[F:ORG]POS+space$(9-len([F:ORG]POS))
 Else
  RESULTAT+=left$([F:ORG]POS,9)
 Endif
 #Filler
 RESULTAT+=space$(27)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Else
 Call ECR_TRACE("MR1"-mess(4,10707,1)-"ORGANISME [ORG]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_AE
#code enreg
RESULTAT="AE1"
#Intervenant
RESULTAT+="AE"+space$(1)
#Siret tiers dûˋclarant
INFO=[F:DUC]CRNEXT
Gosub RECUP_INFO From TRTDCS
#Zone reservûˋe
RESULTAT+=space$(3)
#Nom1
If len([F:DUC]DESEXT)<35
 RESULTAT+=[F:DUC]DESEXT+space$(35-len([F:DUC]DESEXT))
Else
 RESULTAT+=left$([F:DUC]DESEXT,35)
Endif
#Nom2
RESULTAT+=space$(35)
#Adresse
If len([F:DUC]ADDEXT(0))<35
 RESULTAT+=[F:DUC]ADDEXT(0)+space$(35-len([F:DUC]ADDEXT(0)))
Else
 RESULTAT+=left$([F:DUC]ADDEXT(0),35)
Endif
If len([F:DUC]ADDEXT(1))<35
 RESULTAT+=[F:DUC]ADDEXT(1)+space$(35-len([F:DUC]ADDEXT(1)))
Else
 RESULTAT+=left$([F:DUC]ADDEXT(1),35)
Endif
If len([F:DUC]CTYEXT)<35
 RESULTAT+=[F:DUC]CTYEXT+space$(35-len([F:DUC]CTYEXT))
Else
 RESULTAT+=left$([F:DUC]CTYEXT,35)
Endif
If len([F:DUC]POSEXT)<9
 RESULTAT+=[F:DUC]POSEXT+space$(9-len([F:DUC]POSEXT))
Else
 RESULTAT+=left$([F:DUC]POSEXT,9)
Endif
#Filler
RESULTAT+=space$(27)
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Gosub ENREG_AE2
Return

#########################################
$ENREG_AE2
#code enreg
RESULTAT="AE2"
#collaborateur
If len ([F:DUC]CNTEXT)<35
 RESULTAT+=[F:DUC]CNTEXT+space$(35-len([F:DUC]CNTEXT))
Else
 RESULTAT+=left$([F:DUC]CNTEXT,35)
Endif
#tûˋlûˋphone
If len ([F:DUC]TELEXT)<25
 RESULTAT+=[F:DUC]TELEXT+space$(25-len([F:DUC]TELEXT))
Else
 RESULTAT+=left$([F:DUC]TELEXT,25)
Endif
#fax
If len ([F:DUC]FAXEXT)<25
 RESULTAT+=[F:DUC]FAXEXT+space$(25-len([F:DUC]FAXEXT))
Else
 RESULTAT+=left$([F:DUC]FAXEXT,25)
Endif
#Zones inutilisûˋes+filler
RESULTAT+=space$(167)
Wrseq RESULTAT Using [FIC]
Gosub ENREG_AE3
Return

#########################################
$ENREG_AE3
