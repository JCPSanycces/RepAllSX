#<AdxTL>@(#)5.0.0.0 $Revision$
#-----------------------------------------------------------------------#
# Moulinettes version GPAO en cours ...                                 #
#-----------------------------------------------------------------------#
$MFGVERSION
Gosub TRSLLC3
End 
 
############## 
$TRSSYL
Goto ROUTING
$ROUOPESTD
#Moulinette sur ROUOPESTD
Local File WORKSTATIO [MWS]
Local File ROUOPESTD  [ROT]
Call DEBTRANS From GLOCK
Trbegin [ROT]
For [F:ROT]
    Filter [F:MWS] Where WST = [F:ROT]WST
    Read [F:MWS]WST0 First
    If !fstat [F:ROT]FCY = [F:MWS]WCRFCY
        Rewrite [F:ROT]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINOPESTD
Close File [MWS]
Close File [ROT]
#
$ROUOPE
#Moulinette sur ROUOPE
Local File WORKSTATIO [MWS]
Local File ROUOPE     [ROO]
Call DEBTRANS From GLOCK
Trbegin [ROO]
For [F:ROO]
    Filter [F:MWS] Where WST = [F:ROO]WST
    Read [F:MWS]WST0 First
    If !fstat [F:ROO]FCY = [F:MWS]WCRFCY
        Rewrite [F:ROO]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINOPE
Close File [MWS]
Close File [ROO]
#
$ROUTING
#Moulinette sur ROUTING
Local File ROUOPE     [ROO]
Local File ROUTING    [ROH]
Call DEBTRANS From GLOCK
Trbegin [ROH]
For [F:ROH]
    Filter [F:ROO] Where ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROO]ROUALT
    Read [F:ROO]ROO0 First
    If !fstat [F:ROH]FCY = [F:ROO]FCY
        Rewrite [F:ROH]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINROUTING
Close File [ROH]
Close File [ROO]
Return


########################################################################
$TRSSYL2
#-----------------------------------------------------------------------#
# Mise à jour de l'entete OF                                            #
#-----------------------------------------------------------------------#
$MAJMFG
Local Integer XTOT
Local Integer I, GOK
Local File MFGHEAD [MFG]
Local File MFGMAT  [MFM]
#
GTEST = 1
Call DEBTRANS From GLOCK
Trbegin [MFG]
Filter [F:MFG] Where OVRALLNBR < 0 | [F:MFG]DETALLNBR < 0 | [F:MFG]SHTMATNBR < 0
For [MFG] 
    Readlock [F:MFG]MFG0 Curr
    If fstat = 1
       GOK = -1 : GLOCK = "$MFGHEAD"+[F:MFG]MFGNUM 
       Gosub ROL_TRT : GOK = 0 : Break
    Elsif fstat
       GOK = 0  : Call RSTA("MFG",   [F:MFG]MFGNUM) From GLOCK
       Gosub AB_TRT : GOK = 0 
    Endif
    Raz [F:MFG]OVRALLNBR, DETALLNBR, SHTMATNBR
#
    Filter [F:MFM] Where MFGNUM = [F:MFG]MFGNUM
    For [F:MFM]
        Case [F:MFM]ALLSTA    # évaluation nouveaux totaux en fonction de l'évolution du statut
              When 2:  [F:MFG]OVRALLNBR += 1
                       [F:MFG]SHTMATNBR += 1 
              When 3:  [F:MFG]OVRALLNBR += 1
              When 4:  [F:MFG]DETALLNBR += 1
                       [F:MFG]SHTMATNBR += 1
              When 5:  [F:MFG]DETALLNBR += 1
        Endcase
    Next
#
    Gosub MAJSTATUT
#
    Rewrite [MFG]
    If fstat
       GOK = 0 : Call FSTA("MFG") From GLOCK
       Gosub AB_TRT : GOK = 0 : Break
    Endif
Next
If GOK = 0 : Rollback : Else : Commit : Endif
#
Return

#-----------------------------------------------------------------------#
# Recalcul statut allocation                                            #
#-----------------------------------------------------------------------#
$MAJSTATUT
Local Integer XTOT
# nouveau statut allocation (non alloué, partiel, complet)
XTOT = [F:MFG]OVRALLNBR + [F:MFG]DETALLNBR
If (XTOT = 0)                     
    [F:MFG]ALLSTA = 1 
Else 
    If (XTOT < [F:MFG]MATLINNBR)      
        [F:MFG]ALLSTA = 2 
    Else 
        If (XTOT = [F:MFG]MATLINNBR)         
            [F:MFG]ALLSTA = 3 
        Endif 
    Endif 
Endif

# si des ruptures existent, statut allocation + 2
If [F:MFG]SHTMATNBR <> 0 : [F:MFG]ALLSTA += 2 : Endif
# si toutes les matières sont soldées, on force le statut à "complet" ...
If [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
    [F:MFG]ALLSTA = 3
Endif
Return

########################################################
$ROL_TRT
Rollback
Call ROLL From GLOCK
Return

$AB_TRT
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

##########################################################
############## 
$TRSLLC1
$BOMD
#Moulinette sur BOMD (pour type composant)
Local File BOM   [BOH]
Local File BOMD  [BOD]
Call DEBTRANS From GLOCK
Trbegin [BOH]
Link [BOD] With [BOH]BOH0=[F:BOD]ITMREF;[F:BOD]BOMALT As [NOM] 
&            Where [F:BOH]BOMALTTYP = 2  
&            Order By Key BOD0  

For [NOM]
    Readlock [BOD] Curr    
    If !fstat 
        [F:BOD]CPNTYP = 1
        Rewrite [F:BOD]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINBOMD
Close File [BOH]
Close File [BOD]

############## 
$TRSLLC2
$BTRS
# moulinettes sur BENCHTRS (pour paramétrage affichage)
# en 2 parties:
#     - avant mise à jour, lecture et stockage paramètres d'affichage dans MFGVERSION
#     - après mise à jour, alimentation tableau des champs
# Ceci est un algorithme de test sur des tables de test ZBTS et ZBTS2

# avant mise à jour
Gosub BTRS1
# après mise à jour
Gosub BTRS2
Return

$BTRS1
Local File ZBTS   [ZBT]
Local File MFGVERSION [MFV]
Local Char VER : VER = "1.2.0"
Local Char TAB : TAB = "BENCHTRS"
Local Char CLE, DATA

Call DEBTRANS From GLOCK
Trbegin [ZBT]
For [ZBT]
    [F:MFV]TABLE     = TAB
    [F:MFV]VERSION   = VER
    CLE              = num$([F:ZBT]BTSTYP)+[F:ZBT]BTSNUM
    [F:MFV]CLE       = CLE

    # si la clé existe, pas de traitement
    Read [MFV]MFV0=TAB;VER;CLE
    If !fstat : Goto NXT1 : Endif
    
    # sauvegarde paramétrages dans DATA(1)
    [F:MFV]DATA(0)=       num$([F:ZBT]MRPMES)+num$([F:ZBT]MRPDAT)+num$([F:ZBT]MRPQTY) +
&                         num$([F:ZBT]EXTQTY)+num$([F:ZBT]ALLQTY)+num$([F:ZBT]SHTQTY) + 
&                         num$([F:ZBT]WORTIAQTY)+num$([F:ZBT]CPLQTY)+num$([F:ZBT]ITMDES1)+
&                         num$([F:ZBT]ORIFCY)+num$([F:ZBT]PJT)+num$([F:ZBT]BPRNUM)+
&                         num$([F:ZBT]PIO)+num$([F:ZBT]FMI)+num$([F:ZBT]VCRTYPORI)+
&                         num$([F:ZBT]VCRNUMORI)+num$([F:ZBT]VCRLINORI)+num$([F:ZBT]VCRSEQORI)+
&                         num$([F:ZBT]BOMOPE)+num$([F:ZBT]BOMALT)+num$([F:ZBT]BUY)+
&                         num$([F:ZBT]ITMREFORI)

    Write [MFV]
$NXT1
Next
Commit
Close File [ZBT]
Close File [MFV]
Return

$BTRS2
Local File ZBTS2      [ZB2]
Local File MFGVERSION [MFV]
Local File AMSKZON    [AMZ] 
Local Char VER : VER = "1.2.0"
Local Char TAB : TAB = "BENCHTRS"
Local Char CLE, DATA
Local Char MASKREF, LIBEL(30)

Local Integer I, J, OK, NBCLE, OFFSET
Local Integer INC

Call DEBTRANS From GLOCK
Trbegin [ZB2]
For [ZB2] With Lock
    [F:MFV]TABLE     = TAB
    [F:MFV]VERSION   = VER
    CLE              = num$([F:ZB2]BTSTYP)+[F:ZB2]BTSNUM
    [F:MFV]CLE       = CLE

    # si la clé absente, pas de traitement
    Read [MFV]MFV0=TAB;VER;CLE
    If fstat : Goto NXT1 : Endif

    Case [F:ZB2]BTSTYP
        When 51: MASKREF = "MFGBENCH"
                 NBCLE   = 7
                 [F:ZB2]NBRLIG = 301
                 [F:ZB2]NBRCOL = 4
        When 52: MASKREF = "MFGBENCHD"
                 NBCLE   = 5
                 [F:ZB2]NBRLIG = 301
                 [F:ZB2]NBRCOL = 3
        When 53: MASKREF = "MFGPICK"
                 NBCLE   = 5
                 [F:ZB2]NBRLIG = 51
                 [F:ZB2]NBRCOL = 3
    Endcase

    # chargement des zones
    [F:ZB2]NBRFLD = 0
    # dans quel bloc se situe le tableau ?
    Read [AMZ]CODE = MASKREF;"NBLIG"
    If fstat=0 : J=[F:AMZ]NUMBLOC : Else J=0 : Endif

    For [AMZ]CODZON Where CODMSK=MASKREF
        OK = 1
        If [F:AMZ]CODTYP="ABS" | [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J)
            OK = 0
        Endif
        If OK & !find([F:AMZ]CODZON,[F:ZB2]FLD(0..[F:ZB2]NBRFLD-1))
            I = [F:ZB2]NBRFLD
            [F:ZB2]FLD(I) = [F:AMZ]CODZON
            [F:ZB2]NBRFLD += 1 
        Endif 
    Next 

    # activation des champs "clés"
    INC = 0
    For I = 0 To NBCLE
        INC += 5
        [F:ZB2]DAC(I) = INC
    Next I
    # récupération paramétrage 
    For I = NBCLE + 1 To [F:ZB2]NBRFLD
        Case [F:ZB2]FLD(I)
            When  "XMRPMES"   :    OFFSET = 1
            When  "MRPDAT"    :    OFFSET = 2
            When  "MRPQTY"    :    OFFSET = 3
            When  "EXTQTY"    :    OFFSET = 4
            When  "ALLQTY"    :    OFFSET = 5
            When  "SHTQTY"    :    OFFSET = 6
            When  "WORTIAQTY" :    OFFSET = 7
            When  "CPLQTY"    :    OFFSET = 8
            When  "ITMDES1"   :    OFFSET = 9
            When  "ORIFCY"    :    OFFSET = 10
            When  "PJT"       :    OFFSET = 11
            When  "BPRNUM"    :    OFFSET = 12
            When  "PIO"       :    OFFSET = 13
            When  "FMI"       :    OFFSET = 14  
            When  "VCRTYPORI" :    OFFSET = 15
            When  "VCRNUMORI" :    OFFSET = 16
            When  "VCRLINORI" :    OFFSET = 17
            When  "VCRSEQORI" :    OFFSET = 18
            When  "BOMOPE"    :    OFFSET = 19
            When  "BOMALT"    :    OFFSET = 20
            When  "BUY"       :    OFFSET = 21
            When  "ITMREFORI" :    OFFSET = 22
        Endcase
        If mid$([F:MFV]DATA(0), OFFSET, 1) = "2" 
            INC += 5
            [F:ZB2]DAC(I) = INC
        Else
            [F:ZB2]DAC(I) = 0
        Endif
    Next I
    Rewrite [ZB2]
Next    
Commit
$FINBTRS
Close File [ZB2]
Close File [MFV]
Close File [AMZ]
Return

############## 
$TRSLLC3
# moulinette initialisation nb poste = 1
$WORKSTATIO
Local File WORKSTATIO [MWS]
Call DEBTRANS From GLOCK
Trbegin [MWS]
For [MWS]
    Readlock [MWS]WST0 Curr
    If !fstat 
        [F:MWS]TWD = "SC5"
        Rewrite [MWS]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINWORKSTATION
Close File [MWS]
Return

############## 
$TRSLLC4
# moulinette initialisation schéma hebdo dans WORKSTATIO
# on prend le schéma actif à la date de moulinage !
# en 2 parties:
#     - avant mise à jour, lecture et stockage schéma dans MFGVERSION
#     - après mise à jour, alimentation schéma
# avant mise à jour
Gosub SCHEMA1
# après mise à jour
Gosub SCHEMA2
Return

$SCHEMA1
Local Char WLAST
Local Char VER : VER = "1.2.0"
Local Char TAB : TAB = "WORKSTATIO"
Local Char CLE, DATA

Local File WORKSTATIO [MWS]
Local File CALENDAR   [CAL]
Local File MFGVERSION [MFV]

Call DEBTRANS From GLOCK
Trbegin [MWS]

For [MWS]
    Gosub GET_TWD
    [F:MFV]TABLE     = TAB
    [F:MFV]VERSION   = VER
    CLE              = num$([F:MWS]WST)+[F:MWS]WCRFCY
    [F:MFV]CLE       = CLE

    # si la clé existe, pas de traitement
    Read [MFV]MFV0=TAB;VER;CLE
    If !fstat : Goto NXTMWS : Endif
    
    # sauvegarde schéma
    [F:MFV]DATA(0)   = WLAST
    Write [MFV]
$NXTMWS        
Next    

If GOK < 1 : Rollback: Else : Commit : Endif

$FINSCHEMA1
Close File [MWS]
Close File [CAL]
Close File [MFV]
Return

$GET_TWD
Filter [CAL] Where CAL = [F:MWS]CAL
&            Order By Key CAL0
WLAST = ""
For [CAL]
    If fstat : Break : Endif
    WLAST = [F:CAL]TWD
    If [F:CAL]STRDAT <= date$ & [F:CAL]ENDDAT >= date$ : Break : Endif
Next
Return


$SCHEMA2
Local Char VER : VER = "1.2.0"
Local Char TAB : TAB = "WORKSTATIO"
Local Char CLE, DATA

Local File WORKSTATIO [MWS]
Local File MFGVERSION [MFV]

Call DEBTRANS From GLOCK
Trbegin [MWS]

For [MWS]
    [F:MFV]TABLE     = TAB
    [F:MFV]VERSION   = VER
    CLE              = num$([F:MWS]WST)+[F:MWS]WCRFCY
    [F:MFV]CLE       = CLE

    # si la clé n'existe pas, pas de traitement
    Read [MFV]MFV0=TAB;VER;CLE
    If fstat : Goto NXTMWS2 : Endif
    
    Readlock [MWS] Curr
    # récupération schéma
    [F:MWS]TWD = [F:MFV]DATA(0)  
    Rewrite [MWS]
$NXTMWS2        
Next    

If GOK < 1 : Rollback: Else : Commit : Endif

$FINSCHEMA2
Close File [MWS]
Close File [MFV]
Return


############## 
$TRSLLC5
# moulinette initialisation schéma hebdo dans PARMRP
# on prend le schéma actif à la date de moulinage !
# en 2 parties:
#     - avant mise à jour, lecture et stockage schéma dans MFGVERSION
#     - après mise à jour, alimentation schéma
# avant mise à jour
Gosub SCHEMAPLN1
# après mise à jour
Gosub SCHEMAPLN2
Return

$SCHEMAPLN1
Local Char WLAST
Local Char VER : VER = "1.2.0"
Local Char TAB : TAB = "PARMRP"
Local Char CLE, DATA

Local File PARMRP [PCB]
Local File CALENDAR   [CAL]
Local File MFGVERSION [MFV]

Call DEBTRANS From GLOCK
Trbegin [PCB]

For [PCB]
    [F:MFV]TABLE     = TAB
    [F:MFV]VERSION   = VER
    CLE              = [F:PCB]STOFCY
    [F:MFV]CLE       = CLE

    # si la clé existe, pas de traitement
    Read [MFV]MFV0=TAB;VER;CLE
    If !fstat : Goto NXTPCB : Endif
    fstat = 0    

    Gosub GET_MPSTWD   
    # sauvegarde schéma
    [F:MFV]DATA(0)   = WLAST
    Gosub GET_MRPTWD
    [F:MFV]DATA(1)   = WLAST
    Write [MFV]
$NXTPCB
Next    

If GOK < 1 : Rollback: Else : Commit : Endif

$FINSCHEMAPLN1
Close File [PCB]
Close File [CAL]
Close File [MFV]
Return

$GET_MPSTWD
Filter [CAL] Where CAL = [F:PCB]MPSCAL
&            Order By Key CAL0
WLAST = ""
For [CAL]
    If fstat : Break : Endif
    WLAST = [F:CAL]TWD
    If [F:CAL]STRDAT <= date$ & [F:CAL]ENDDAT >= date$ : Break : Endif
Next
Return

$GET_MRPTWD
Filter [CAL] Where CAL = [F:PCB]MRPCAL
&            Order By Key CAL0
WLAST = ""
For [CAL]
    If fstat : Break : Endif
    WLAST = [F:CAL]TWD
    If [F:CAL]STRDAT <= date$ & [F:CAL]ENDDAT >= date$ : Break : Endif
Next
Return


$SCHEMAPLN2
Local Char VER : VER = "1.2.0"
Local Char TAB : TAB = "PARMRP"
Local Char CLE, DATA

Local File PARMRP [PCB]
Local File MFGVERSION [MFV]

Call DEBTRANS From GLOCK
Trbegin [PCB]

For [PCB]
    [F:MFV]TABLE     = TAB
    [F:MFV]VERSION   = VER
    CLE              = [F:PCB]STOFCY
    [F:MFV]CLE       = CLE

    # si la clé n'existe pas, pas de traitement
    Read [MFV]MFV0=TAB;VER;CLE
    If fstat : Goto NXTPCB2 : Endif
    
    Readlock [PCB] Curr
    # récupération schéma
    [F:PCB]MPSTWD = [F:MFV]DATA(0)  
    [F:PCB]MRPTWD = [F:MFV]DATA(1)  
    Rewrite [PCB]
$NXTPCB2        
Next    

If GOK < 1 : Rollback: Else : Commit : Endif

$FINSCHEMAPLN2
Close File [PCB]
Close File [MFV]
Return


############## 
$TRSLLC6
# moulinette initialisation paramétrage Planning global
$PGLOBAL
Local File BENCHTRS [BTS] Where BTSTYP = 51
Local Integer I
Local Integer OFFSET : OFFSET = 0
Call DEBTRANS From GLOCK
Trbegin [BTS]
For [BTS]
    Readlock [BTS]BTS0 Curr
    If !fstat 
        If [F:BTS]PLANNER = 2
            [F:BTS]SUG(3) = 2
            [F:BTS]PLN(3) = 2
            [F:BTS]LAN(3) = 2
            [F:BTS]CRIT(3) = 2
            [F:BTS]RES = 2
        Endif
        If [F:BTS]BUYER = 2
            [F:BTS]SUG(1) = 2
            [F:BTS]PLN(1) = 2
            [F:BTS]LAN(1) = 2
            [F:BTS]CRIT(1) = 2
            [F:BTS]SUG(5) = 2
            [F:BTS]PLN(5) = 2
            [F:BTS]LAN(5) = 2
            [F:BTS]CRIT(5) = 2
            [F:BTS]LAN(6) = 2
            [F:BTS]RES = 2
        Endif
        [F:BTS]GESAFF = 1
        Rewrite [BTS]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINGLOBAL
Close File [BTS]

$TRSLLC7
# moulinette initialisation paramétrage Plan de travail
$PPLAN
Local File BENCHTRS [BTS] 
Local Integer I
Local Integer OFFSET : OFFSET = 0
Call DEBTRANS From GLOCK
Trbegin [BTS]
For [BTS]
    Readlock [BTS]BTS0 Curr
    If !fstat 
        Rewrite [BTS]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINPLAN
Close File [BTS]

$TRSLLC8
# moulinette initialisation paramétrage Regroupements
$PREG
Local File BENCHTRS [BTS] Where BTSTYP = 53
Local Integer I
Local Integer OFFSET : OFFSET = 0
Call DEBTRANS From GLOCK
Trbegin [BTS]
For [BTS]
    Readlock [BTS]BTS0 Curr
    If !fstat 
        [F:BTS]GESAFF = 1
        [F:BTS]APPBUY = [F:BTS]BUYER
        [F:BTS]BUYER  = 1
        Rewrite [BTS]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINREG
Close File [BTS]

############## 
$TRSLLC9
# moulinette initialisation BUY dans ITMFACILITY
$ITMFACILITY
Local File ITMFACILIT [ITF]
Local File ITMMASTER  [ITM]
Call DEBTRANS From GLOCK
Trbegin [ITF]
For [ITF]
    If [F:ITF]BUY = ""
        Read [ITM]ITM0=[F:ITF]ITMREF
        If fstat : Goto N9 : Endif
        If [F:ITM]BUY <> ""
            Readlock [ITF]ITF0 Curr
            If !fstat 
                [F:ITF]BUY = [F:ITM]BUY
            Endif
        Endif
        If [F:ITF]RELSCATIA = 0 : [F:ITF]RELSCATIA = 2 : Endif
        Rewrite [ITF]
    Endif
$N9
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINITMFACILITY
Close File [ITF]
Close File [ITM]
Return

############## 
$TRSTABREJQTY
# moulinette initialisation de TABREJQTY(0) avec CPLREJQTY dans MFGOPETRK
$MFGOPETRK
Local File MFGOPETRK [MKO]
Call DEBTRANS From GLOCK
Trbegin [MKO]
For [MKO]
    If [F:MKO]REJCPLQTY <> 0
            Readlock [MKO]MKO0 Curr
            If !fstat 
                [F:MKO]TABREJQTY(0) = [F:MKO]REJCPLQTY
                Rewrite [MKO]
            Endif
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINMFGOPETRK
Close File [MKO]
Return

$LLCROU
Local File ROUOPE [ROO]
Local File ITMMASTER [ITM]

Call DEBTRANS From GLOCK
Trbegin [ROO]
For [ROO]
    Read [ITM]ITM0=[F:ROO]ITMREF
    If !fstat
            Readlock [ROO]ROO0 Curr
            If !fstat 
                [F:ROO]OPEUOM = [F:ITM]STU
                Rewrite [ROO]
            Endif
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINROO
Close File [ROO]
Close File [ITM]

Return

$LLCNEW
Local File WORKSTATIO [MWS]
Local File TABWRKCTR  [TWC]
Call DEBTRANS From GLOCK
Trbegin [MWS]
For [MWS]
    [F:MWS]DSPLEV = 1
    Rewrite [MWS]
Next  
For [TWC]
    [F:TWC]DSPLEV = 1
    Rewrite [TWC]
Next  
  
If GOK < 1 : Rollback: Else : Commit : Endif
$FINLLCNEW
Close File [MWS]
