#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"VERSYMB","VERSYMB","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "SETBOUT"  : Gosub SETBOUT
 When "BOUTON"   : Gosub BOUTON
 When "RAF"      : Gosub RAF
Endcase
Return

$OUVRE
Local Mask VERSYMB [VSY] , PSADX [PSA]
Local File APLLCK [APK]

Local Integer I , J , K , N , T , H , M , S , OK , TOUS
Local Char    MACHINE(GDIMFIC) , USER(50)
Local Char    PROCESS(20) , LOGIN(GLONALO) , NOM(GLONDES)
TOUS = 0
Return

$DEBUT
Gosub LIRE
Return

$SETBOUT
CHBOU += "=" : # Rafraîchir
Return

$BOUTON
Case BOUT
 When "1"    : Gosub LIRE
Endcase
Return

$RAF
$LIRE
Raz [M:VSY]
Call TEMPON("O") From GESECRAN
Call LISTE("") From PSADX
N = 0
For [APK]LCKCLE(1)
 PROCESS = num$([F:APK]LCKPID)
 K = find(PROCESS,[M:PSA]UID(0..[M:PSA]NBLIG-1))
 Raz OK , LOGIN , USER , MACHINE , NOM
 If K
  LOGIN   = toupper([M:PSA]USER(K-1))
  MACHINE = [M:PSA]CLIENT(K-1)
  If LOGIN<>""
   If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
   Read [AUS]LOGIN = LOGIN
   If !fstat
    USER = [F:AUS]USR
    NOM =  [F:AUS]NOMUSR
   Endif
  Endif
  If MACHINE<>"" or USER<>""
   OK = 1
  Endif
 Endif 
 If OK or TOUS
  If N>=dim([M:VSY]UID)
   Call ERREUR(mess(161,115,1)) From GESECRAN : # Trop de lignes
   Break
  Else
   N += 1
   [M:VSY]SYMBOLE(N-1) = [F:APK]LCKSYM
   [M:VSY]UID(N-1)     = PROCESS
   If [F:APK]LCKDAT<>[0/0/0]
    T = [F:APK]LCKTIM
    H = int(T/3600)
    M = int(mod(T,3600)/60)
    S = mod(T,60)
    [M:VSY]DAT(N-1)    = format$(GFMD,[F:APK]LCKDAT)
    [M:VSY]DAT(N-1)   -= "-"-format$("N0:2#",H)+":"+format$("N0:2#",M)+":"+format$("N0:2#",S)
   Endif
   [M:VSY]MACHINE(N-1) = MACHINE
   [M:VSY]USER(N-1)    = USER
   [M:VSY]NOM(N-1)     = NOM
  Endif
 Endif
Next APK
[M:VSY]NBLIG = N
Call TEMPOFF From GESECRAN
Affzo
Return

