#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_TBLABBR UTI process                                 PAY Module
#                   Migration To U12 - Vnext version
#
# ==>  Update TABLE ABBREVIATIONS to the new V12 naming
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_TBLABBR: Update TABLE ABBREVIATIONS to the new V12 naming",0) From GESECRAN

  Call AMAJ_EMHRMAJ90_TBLABBR(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog  AMAJ_EMHRMAJ90_TBLABBR(LDOSSIER)
Value Char LDOSSIER
Local Char TABLEARRAY(GLONATB)(1..,1..10)
Local Char TABLEARRAYNOTUSED(GLONATB)(1..,1..10)
Local Char DATATYPEARRAY(GLONATB)(1..,1..10)
Local Char TABLEARRAYDUPLICATES(GLONATB)(1..,1..10)

  Onerrgo CYCLECHECKERROR

  Call ECR_TRACE("EMHRMAJ90_TBLABBR: Update TABLE ABBREVIATIONS to the new V12 naming",0) From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_TBLABBR: Start of process on : "+LDOSSIER,0) From GESECRAN

  If clalev([WATB])=0 : Local File = LDOSSIER + ".ATABLE" [WATB] : Endif
  If clalev([WATY])=0 : Local File = LDOSSIER + ".ATYPE"  [WATY] : Endif

  Gosub DEFINE_TABLES
  Call ECR_TRACE("EMHRMAJ90_TBLABBR: Update TABLE ABBREVIATIONS to the new V12 naming",0) From GESECRAN
  Gosub UPDATE_TABLES

  Gosub DEFINE_NOT_USED_TABLE
  Call ECR_TRACE("EMHRMAJ90_TBLABBR: Rename TABLE ABBREVIATIONS to D_",0) From GESECRAN
  Gosub UPDATE_NOT_USED_TABLE

  Gosub DEFINE_DATA_TYPES
  Call ECR_TRACE("EMHRMAJ90_TBLABBR: Update data type SIT to HRSIT",0) From GESECRAN
  Gosub UPDATE_DATA_TYPES

  Call ECR_TRACE("EMHRMAJ90_TBLABBR : End of process on : "+LDOSSIER,0) From GESECRAN

  Close Local File [WATB],[WATY]

End

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_TBLABBR: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN

Resume

$DEFINE_TABLES
#Index start at 1
  I=0
  I+=1 : TABLEARRAY(I,1)="BASIND" : TABLEARRAY(I,2)="HRBAI"
  I+=1 : TABLEARRAY(I,1)="CLACTR" : TABLEARRAY(I,2)="HRCLC"
  I+=1 : TABLEARRAY(I,1)="CLASSCONV" : TABLEARRAY(I,2)="HRCCV"
  I+=1 : TABLEARRAY(I,1)="COTISATION" : TABLEARRAY(I,2)="HRCOT"
  I+=1 : TABLEARRAY(I,1)="COUTREEL" : TABLEARRAY(I,2)="HRCOR"
  I+=1 : TABLEARRAY(I,1)="EMPLOCTR" : TABLEARRAY(I,2)="HRCTR"
  I+=1 : TABLEARRAY(I,1)="EMPLODIRNUM" : TABLEARRAY(I,2)="HREDM"
  I+=1 : TABLEARRAY(I,1)="EMPLOEXM" : TABLEARRAY(I,2)="HREXM"
  I+=1 : TABLEARRAY(I,1)="GRPCPCD" : TABLEARRAY(I,2)="HRGCD"
  I+=1 : TABLEARRAY(I,1)="HISTOREGUL" : TABLEARRAY(I,2)="HRHSR"
  I+=1 : TABLEARRAY(I,1)="MSFLDATM" : TABLEARRAY(I,2)="HRMFA"
  I+=1 : TABLEARRAY(I,1)="PATCHPDP" : TABLEARRAY(I,2)="HRPPP"
  I+=1 : TABLEARRAY(I,1)="POPUL" : TABLEARRAY(I,2)="HRPOP"
  I+=1 : TABLEARRAY(I,1)="POSTEKSA" : TABLEARRAY(I,2)="PSS"
  I+=1 : TABLEARRAY(I,1)="PPREQUESTD" : TABLEARRAY(I,2)="HRPPD"
  I+=1 : TABLEARRAY(I,1)="PPREQUESTH" : TABLEARRAY(I,2)="HRPPH"
  I+=1 : TABLEARRAY(I,1)="PPVRALISD" : TABLEARRAY(I,2)="HRPVD"
  I+=1 : TABLEARRAY(I,1)="PROFILDEF" : TABLEARRAY(I,2)="HRPFD"
  I+=1 : TABLEARRAY(I,1)="PRVCLOB" : TABLEARRAY(I,2)="HRPCB"
  I+=1 : TABLEARRAY(I,1)="REPART" : TABLEARRAY(I,2)="HRREP"
  I+=1 : TABLEARRAY(I,1)="SCALE" : TABLEARRAY(I,2)="HRSCA"
  I+=1 : TABLEARRAY(I,1)="SCALED" : TABLEARRAY(I,2)="HRSDD"
  I+=1 : TABLEARRAY(I,1)="SCREMPD" : TABLEARRAY(I,2)="HRSMD"
  I+=1 : TABLEARRAY(I,1)="SCREMPH" : TABLEARRAY(I,2)="HRSMH"
  I+=1 : TABLEARRAY(I,1)="SCRMHCH" : TABLEARRAY(I,2)="HRSCH"
  I+=1 : TABLEARRAY(I,1)="SCRPLFD" : TABLEARRAY(I,2)="HRSPD"
  I+=1 : TABLEARRAY(I,1)="SCRPLFH" : TABLEARRAY(I,2)="HRSPH"
  I+=1 : TABLEARRAY(I,1)="SESSIONS" : TABLEARRAY(I,2)="HRSES"
  I+=1 : TABLEARRAY(I,1)="SITEPAYE" : TABLEARRAY(I,2)="HRSIT"
  I+=1 : TABLEARRAY(I,1)="SOLDPAY" : TABLEARRAY(I,2)="HRSDP"
  I+=1 : TABLEARRAY(I,1)="STAGEPRH" : TABLEARRAY(I,2)="HRSTP"
  I+=1 : TABLEARRAY(I,1)="STAGETRG" : TABLEARRAY(I,2)="HRSTR"
  I+=1 : TABLEARRAY(I,1)="STLPAY" : TABLEARRAY(I,2)="HRSTL"
  I+=1 : TABLEARRAY(I,1)="TABAT" : TABLEARRAY(I,2)="HRTAT"
  I+=1 : TABLEARRAY(I,1)="TMPDUCSEFF" : TABLEARRAY(I,2)="HRTDE"
  I+=1 : TABLEARRAY(I,1)="TMPLIVRE" : TABLEARRAY(I,2)="HRTML"
  I+=1 : TABLEARRAY(I,1)="TMPLIVRESTD" : TABLEARRAY(I,2)="HRTMD"
  I+=1 : TABLEARRAY(I,1)="TRAINER" : TABLEARRAY(I,2)="HRTRN"
  I+=1 : TABLEARRAY(I,1)="TXTCTR" : TABLEARRAY(I,2)="HRTXC"

Return

$UPDATE_TABLES
  Local Integer COUNTER

  For COUNTER = 1 To maxtab(TABLEARRAY)
    If TABLEARRAY(COUNTER,1) > ""
      Read [WATB]CODFIC=TABLEARRAY(COUNTER,1)
      If !fstat
        [WATB]ABRFIC=TABLEARRAY(COUNTER,2)
        Rewrite [WATB]
        Call ECR_TRACE("Update abbreviation for table: "+TABLEARRAY(COUNTER,1),0) From GESECRAN
      Endif
    Endif
  Next

Return

$DEFINE_NOT_USED_TABLE
#Index start at 1
  I=0
  I+=1 : TABLEARRAYNOTUSED(I,1)="DPERSOIDSA" : TABLEARRAYNOTUSED(I,2)="D_DPS"
  I+=1 : TABLEARRAYNOTUSED(I,1)="DPERSOMED" : TABLEARRAYNOTUSED(I,2)="D_DPM"
  I+=1 : TABLEARRAYNOTUSED(I,1)="PORPRHCLB" : TABLEARRAYNOTUSED(I,2)="D_PPC"
  I+=1 : TABLEARRAYNOTUSED(I,1)="SAIPERLIS" : TABLEARRAYNOTUSED(I,2)="D_SPL"
  I+=1 : TABLEARRAYNOTUSED(I,1)="SCREVAD" : TABLEARRAYNOTUSED(I,2)="D_ESD"
  I+=1 : TABLEARRAYNOTUSED(I,1)="SCREVAH" : TABLEARRAYNOTUSED(I,2)="D_ESH"
  I+=1 : TABLEARRAYNOTUSED(I,1)="TMPEMPLO" : TABLEARRAYNOTUSED(I,2)="D_TCT"
  I+=1 : TABLEARRAYNOTUSED(I,1)="TMPPLN" : TABLEARRAYNOTUSED(I,2)="D_TPL"
  I+=1 : TABLEARRAYNOTUSED(I,1)="TMPPLNTYP" : TABLEARRAYNOTUSED(I,2)="D_TPT"
  I+=1 : TABLEARRAYNOTUSED(I,1)="TMPSYNTPS" : TABLEARRAYNOTUSED(I,2)="D_TMS"
  I+=1 : TABLEARRAYNOTUSED(I,1)="FRMPAY" : TABLEARRAYNOTUSED(I,2)="D_FRM"
  I+=1 : TABLEARRAYNOTUSED(I,1)="PORPRHCLB" : TABLEARRAYNOTUSED(I,2)="D_TPC"

Return

$UPDATE_NOT_USED_TABLE
  Local Integer COUNTER

  For COUNTER = 1 To maxtab(TABLEARRAYNOTUSED)
    If TABLEARRAYNOTUSED(COUNTER,1) > ""
      Read [WATB]CODFIC=TABLEARRAYNOTUSED(COUNTER,1)
      If !fstat
        [WATB]ABRFIC=TABLEARRAYNOTUSED(COUNTER,2)
        Rewrite [WATB]
        Call ECR_TRACE("Update abbreviation to D_ for table: "+TABLEARRAYNOTUSED(COUNTER,1),0) From GESECRAN
      Endif
    Endif
  Next

Return

$DEFINE_DATA_TYPES
#Index start at 1
  I=0
  I+=1 : DATATYPEARRAY(I,1)="SIT" : DATATYPEARRAY(I,2)="FCY"

Return


$UPDATE_DATA_TYPES
  Local Integer COUNTER

  For COUNTER = 1 To maxtab(DATATYPEARRAY)
    If DATATYPEARRAY(COUNTER,1) > ""
      Read [WATY]CODTYP=DATATYPEARRAY(COUNTER,1)
      If !fstat
        Read [WATY]CODTYP=DATATYPEARRAY(COUNTER,2)
        If fstat
          Read [WATY]CODTYP=DATATYPEARRAY(COUNTER,1)
          [WATY]CODTYP=DATATYPEARRAY(COUNTER,2)
          Rewrite [WATY]
          Call ECR_TRACE("Rename data type "+DATATYPEARRAY(COUNTER,1)+" to "+DATATYPEARRAY(COUNTER,2),0) From GESECRAN
        Endif
      Endif
    Endif
  Next
Return

