#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDISEQFILDUP                                                     #
# Manages Duplicate class for EDISEQFIL                                       #
# Author : RBA                                                                #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"    : Gosub AREAD_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
 $PROPERTIES
  Case CURPRO
    When "MSGCODNEW" :
      Case [L]ARULE
        When "CONTROL"   : Gosub MSGCODNEW_CONTROL
        When "PROPAGATE" : Gosub MSGCODNEW_PROPAGATE
      Endcase
    When "MSGRELNEW" :
      Case [L]ARULE
        When "CONTROL"   : Gosub MSGRELNEW_CONTROL
        When "PROPAGATE" : Gosub MSGRELNEW_PROPAGATE
      Endcase
    When "MSGFILNORNEW" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub MSGFILNORNEW_PROPAGATE
    Endcase
  Endcase
Return

####################################################################

$MSGCODNEW_CONTROL
  If this.MSGCODNEW <> ""
    this.MSGCODNEW = func EDILIBA.FORMATVAL("MSGCOD", this.MSGCODNEW)
  Endif
Return

$MSGCODNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("MSGCODNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGRELNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGFILNORNEW")

  If this.MSGCODNEW <> "" and this.MSGRELNEW <> ""
    If func CTRL_EXIST_MSG(this.MSGCODNEW,this.MSGRELNEW) = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("MSGCODNEW",mess(126,143,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW,[V]CST_AERROR)
    Endif
  Endif

  If func CTRL_EXIST_SEQ(this.MSGCODNEW,this.MSGRELNEW,this.MSGFILNORNEW) = [V]CST_ATRUE
    ASTATUS = fmet this.ASETERROR("MSGCODNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW,[V]CST_AERROR)
  Endif
Return

####################################################################

$MSGRELNEW_CONTROL
  If this.MSGRELNEW <> ""
    this.MSGRELNEW = func EDILIBA.FORMATVAL("MSGREL", this.MSGRELNEW)
  Endif
Return

$MSGRELNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("MSGCODNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGRELNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGFILNORNEW")

  If this.MSGCODNEW <> "" and this.MSGRELNEW <> ""
    If func CTRL_EXIST_MSG(this.MSGCODNEW,this.MSGRELNEW) = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("MSGRELNEW",mess(126,143,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW,[V]CST_AERROR)
    Endif
  Endif

  If func CTRL_EXIST_SEQ(this.MSGCODNEW,this.MSGRELNEW,this.MSGFILNORNEW) = [V]CST_ATRUE
    ASTATUS = fmet this.ASETERROR("MSGRELNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW,[V]CST_AERROR)
  Endif
Return

####################################################################

$MSGFILNORNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("MSGCODNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGRELNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGFILNORNEW")
  If func CTRL_EXIST_SEQ(this.MSGCODNEW,this.MSGRELNEW,this.MSGFILNORNEW) = [V]CST_ATRUE
    ASTATUS = fmet this.ASETERROR("MSGFILNORNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW,[V]CST_AERROR)
  Endif
Return


####################################################################

$AREAD_AFTER
  If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
    Local File EDISEQFIL [ESF]
    Read [ESF]ESF0 = this.MSGCOD; this.MSGREL; this.MSGFILNOR
    If !fstat
      this.FILDES    = [ESF]FILDES
      this.FILDESNEW = [ESF]FILDES-"(Copy)"
    Else
      this.FILDES    = ""
      this.FILDESNEW = ""
    Endif
    LogicClose File [ESF]
  Endif
Return

####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.MSGCODNEW <> "" and this.MSGRELNEW <> "" and this.MSGFILNORNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_SEQ(this.MSGCODNEW,this.MSGRELNEW,this.MSGFILNORNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("MSGCODNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_SEQ(this.MSGCOD, this.MSGREL, this.MSGFILNOR, this.MSGCODNEW, this.MSGRELNEW, this.MSGFILNORNEW, this.FILDESNEW, WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

####################################################################

Funprog CTRL_EXIST_SEQ(WMSGCOD,WMSGREL,WMSGFILNOR)
Value Char WMSGCOD
Value Char WMSGREL
Value Char WMSGFILNOR

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WMSGCOD <> "" and WMSGREL <> "" and WMSGFILNOR <> ""
    Local File EDISEQFIL [ESF]
    Filter [ESF] Where MSGCOD = WMSGCOD and MSGREL = WMSGREL and MSGFILNOR = WMSGFILNOR
    For [ESF]
      WOK = [V]CST_ATRUE
      Break
    Next
    Filter [ESF]
    LogicClose File [ESF]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

####################################################################

Funprog CTRL_EXIST_MSG(WMSGCOD,WMSGREL)
Value Char WMSGCOD
Value Char WMSGREL

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WMSGCOD <> "" and WMSGREL <> ""
    Local File EDIMSG [EMS]
    Read [EMS]EMS0 = WMSGCOD;WMSGREL
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [EMS]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

####################################################################

Funprog COPY_SEQ(WMSGCOD, WMSGREL, WMSGFILNOR, WMSGCOD_NEW, WMSGREL_NEW, WMSGFILNOR_NEW, WFILDES_NEW, WERR)
Value Char WMSGCOD
Value Char WMSGREL
Value Char WMSGFILNOR
Value Char WMSGCOD_NEW
Value Char WMSGREL_NEW
Value Char WMSGFILNOR_NEW
Value Char WFILDES_NEW
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AOK

  If WOK = [V]CST_AOK
    Local File EDISEQFILF [ESFF]
    Filter [ESFF] Where MSGCOD = WMSGCOD and MSGREL = WMSGREL and MSGFILNOR = WMSGFILNOR
    For [ESFF]
      If WOK = [V]CST_AOK
        Local File EDISEQFILF [C_ESFF]
        Trbegin [C_ESFF]
        [C_ESFF]          = [ESFF]
        [C_ESFF]MSGCOD    = WMSGCOD_NEW
        [C_ESFF]MSGREL    = WMSGREL_NEW
        [C_ESFF]MSGFILNOR = WMSGFILNOR_NEW
        Write [C_ESFF]
        If !fstat
          Commit
        Else
          WOK = [V]CST_AERROR
          WERR = "EDISEQFILF ("+mess(3,40,1)-num$([C_ESFF]NUMLIN)+")"
          Rollback
        Endif
        LogicClose File [C_ESFF]
      Else
        #supprimer la copie
      Endif
    Next
    Filter [ESFF]
    LogicClose File [ESFF]
  Endif

  If WOK = [V]CST_AOK
    Local File EDISEQFILD [ESFD]
    Filter [ESFD] Where MSGCOD = WMSGCOD and MSGREL = WMSGREL and MSGFILNOR = WMSGFILNOR
    For [ESFD]
      If WOK = [V]CST_AOK
        Local File EDISEQFILD [C_ESFD]
        Trbegin [C_ESFD]
        [C_ESFD]          = [ESFD]
        [C_ESFD]MSGCOD    = WMSGCOD_NEW
        [C_ESFD]MSGREL    = WMSGREL_NEW
        [C_ESFD]MSGFILNOR = WMSGFILNOR_NEW
        Write [C_ESFD]
        If !fstat
          Commit
        Else
          WOK = [V]CST_AERROR
          WERR = "EDISEQFILD ("+mess(3,40,1)-num$([C_ESFD]NUMLIN)+")"
          Rollback
        Endif
        LogicClose File [C_ESFD]
      Else
        #supprimer la copie
      Endif
    Next
    Filter [ESFD]
    LogicClose File [ESFD]
  Endif

  If WOK = [V]CST_AOK
    Local File EDISEQFIL [ESF]
    Read [ESF]ESF0 = WMSGCOD;WMSGREL;WMSGFILNOR
    If !fstat
      Local File EDISEQFIL [C_ESF]
      Trbegin [C_ESF]
      [C_ESF]          = [ESF]
      [C_ESF]VALID     = [V]CST_ANO
      [C_ESF]CACHEUUID = NullUuid()
      [C_ESF]FILDES    = WFILDES_NEW #[ESF]FILDES-"(Copy)"
      [C_ESF]MSGCOD    = WMSGCOD_NEW
      [C_ESF]MSGREL    = WMSGREL_NEW
      [C_ESF]MSGFILNOR = WMSGFILNOR_NEW
      Write [C_ESF]
      If !fstat
        Commit
      Else
        #WOK = 3#[V]CST_AERROR
        WOK = [V]CST_AERROR
        WERR = "EDISEQFIL ("+mess(1,7983,1)+")"
        Rollback
      Endif
      LogicClose File [C_ESF]
    Else
#      WOK = 4#[V]CST_AERROR
      WOK = [V]CST_AERROR
      WERR = "EDISEQFIL ("+mess(7,7983,1)+")"
    Endif
    Filter [ESF]
    LogicClose File [ESF]
  Endif

End WOK

