#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################################
# UTIBOX201808001   Fix 1099 box definition data values for 2018 1099-DIV form          #
#########################################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI Testing") From LECFIC
  Call PATCH([L]WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File

End

#################################################################################
Subprog MAJ_UTIBOX201808001(DOSSIER)
Value Char DOSSIER()

  Local Integer WOUV_TRACE
  Local Integer NBENR

  If GTRACE = "" Then
    Call OUVRE_TRACE("UTIBOX201808001 : Box definition correction for 1099DIV") From LECFIC
    WOUV_TRACE = 1
  Endif

  If !clalev([F:BX9])    : Local File =DOSSIER+".BOX1099" [BX9]    : Endif
  If !clalev([F:BX9DEL]) : Local File =DOSSIER+".BOX1099" [BX9DEL] : Endif

  Trbegin [BX9], [BX9DEL]

  #1099DIV Move existing Box 5 thru Box 14 down a slot
  Read [BX9]BX90=4;"14"
  If !fstat #Record exists
    If toupper(vireblc([BX9]DES,2)) = "STATE TAX WITHHELD"

      Read [BX9DEL]BX90=4;"15"
      If !fstat #Record exists
        Delete [BX9DEL] Where FRM1099=4 & BOX1099="15"
      Endif

      Update [BX9] Where FRM1099=4 & BOX1099="14" With BOX1099="15"
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to update 1099DIV Box 15",0) From GESECRAN
        End
      Endif
    Endif
  Endif

  Read [BX9]BX90=4;"13"
  If !fstat #Record exists
    If toupper(vireblc([BX9]DES,2)) = "STATE IDENTIFICATION NO."

      Read [BX9DEL]BX90=4;"14"
      If !fstat #Record exists
        Delete [BX9DEL] Where FRM1099=4 & BOX1099="14"
      Endif

      Update [BX9] Where FRM1099=4 & BOX1099="13" With BOX1099="14"
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to update 1099DIV Box 14",0) From GESECRAN
        End
      Endif
    Endif
  Endif

  Read [BX9]BX90=4;"12"
  If !fstat #Record exists
    If toupper(vireblc([BX9]DES,2)) = "STATE"

      Read [BX9DEL]BX90=4;"13"
      If !fstat #Record exists
        Delete [BX9DEL] Where FRM1099=4 & BOX1099="13"
      Endif

      Update [BX9] Where FRM1099=4 & BOX1099="12" With BOX1099="13"
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to update 1099DIV Box 13",0) From GESECRAN
        End
      Endif
    Endif
  Endif

  Read [BX9]BX90=4;"11"
  If !fstat #Record exists
    If toupper(vireblc([BX9]DES,2)) = "PRIVATE ACTIVITY BOND INT DIVIDENDS"

      Read [BX9DEL]BX90=4;"12"
      If !fstat #Record exists
        Delete [BX9DEL] Where FRM1099=4 & BOX1099="12"
      Endif

      Update [BX9] Where FRM1099=4 & BOX1099="11" With BOX1099="12"
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to update 1099DIV Box 12",0) From GESECRAN
        End
      Endif
    Endif
  Endif

  Read [BX9]BX90=4;"10"
  If !fstat #Record exists
    If toupper(vireblc([BX9]DES,2)) = "EXEMPT-INTEREST DIVIDENDS"

      Read [BX9DEL]BX90=4;"11"
      If !fstat #Record exists
        Delete [BX9DEL] Where FRM1099=4 & BOX1099="11"
      Endif

      Update [BX9] Where FRM1099=4 & BOX1099="10" With BOX1099="11"
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to update 1099DIV Box 11",0) From GESECRAN
        End
      Endif
    Endif
  Endif

  Read [BX9]BX90=4;"9"
  If !fstat #Record exists
    If toupper(vireblc([BX9]DES,2)) = "NONCASH LIQUIDATION DISTR"

      Read [BX9DEL]BX90=4;"10"
      If !fstat #Record exists
        Delete [BX9DEL] Where FRM1099=4 & BOX1099="10"
      Endif

      Update [BX9] Where FRM1099=4 & BOX1099="9" With BOX1099="10"
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to update 1099DIV Box 10",0) From GESECRAN
        End
      Endif
    Endif
  Endif

  Read [BX9]BX90=4;"8"
  If !fstat #Record exists
    If toupper(vireblc([BX9]DES,2)) = "CASH LIQUIDATION DISTR"

      Read [BX9DEL]BX90=4;"9"
      If !fstat #Record exists
        Delete [BX9DEL] Where FRM1099=4 & BOX1099="9"
      Endif

      Update [BX9] Where FRM1099=4 & BOX1099="8" With BOX1099="9"
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to update 1099DIV Box 9",0) From GESECRAN
        End
      Endif
    Endif
  Endif

  Read [BX9]BX90=4;"7"
  If !fstat #Record exists
    If toupper(vireblc([BX9]DES,2)) = "FOREIGN OR US POSSESSION"

      Read [BX9DEL]BX90=4;"8"
      If !fstat #Record exists
        Delete [BX9DEL] Where FRM1099=4 & BOX1099="8"
      Endif

      Update [BX9] Where FRM1099=4 & BOX1099="7" With BOX1099="8"
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to update 1099DIV Box 8",0) From GESECRAN
        End
      Endif
    Endif
  Endif

  Read [BX9]BX90=4;"6"
  If !fstat #Record exists
    If toupper(vireblc([BX9]DES,2)) = "FOREIGN TAX PAID"

      Read [BX9DEL]BX90=4;"7"
      If !fstat #Record exists
        Delete [BX9DEL] Where FRM1099=4 & BOX1099="7"
      Endif

      Update [BX9] Where FRM1099=4 & BOX1099="6" With BOX1099="7"
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to update 1099DIV Box 7",0) From GESECRAN
        End
      Endif
    Endif
  Endif

  Read [BX9]BX90=4;"5"
  If !fstat #Record exists
    If toupper(vireblc([BX9]DES,2)) = "INVESTMENT EXPENSES"

      Read [BX9DEL]BX90=4;"6"
      If !fstat #Record exists
        Delete [BX9DEL] Where FRM1099=4 & BOX1099="6"
      Endif

      Update [BX9] Where FRM1099=4 & BOX1099="5" With BOX1099="6"
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to update 1099DIV Box 6",0) From GESECRAN
        End
      Endif

      Raz [BX9]
      [BX9]FRM1099= 4
      [BX9]BOX1099= "5"
      [BX9]DES = "Section 199A dividends"
      [BX9]BOXTYP = 1
      [BX9]ENAFLG = 2
      [BX9]LOWLIM = 0.01

      Write [F:BX9]
      NBENR += adxuprec

      If fstat
        Rollback
        Call ECR_TRACE("UTIBOX201808001 : Unable to insert 1099DIV Box 5",0) From GESECRAN
        End
      Endif
    Endif
  Endif

  Commit

  Call ECR_TRACE("UTIBOX201808001 : Correction in table BOX1099 : Ended"-"("-num$(NBENR)+" records processed"-")",0) From GESECRAN
  Close Local File [BX9]

  #--------------------------------
  #--------------------------------
  If WOUV_TRACE = 1 Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif

End


########################################################################
# Executed during integration of patches from EXE patch element type
########################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER

  If [L]DOSSIER = GDOSX3 and GADONIX <> 2 Then
    End
  Endif

  If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If [F:ADS]MODULE(1) <> 2 : End : Endif

  If !func TABLE_CHECK([L]DOSSIER) Then
    End
  Endif

  Call MAJ_UTIBOX201808001([L]DOSSIER)

End

#######################################################################
# Executed during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER

  If [L]DOSSIER = GDOSX3 and GADONIX <> 2 Then
    End
  Endif

  If [F:ADS]MODULE(1) <> 2 : End : Endif

  If !func TABLE_CHECK([L]DOSSIER) Then
    End
  Endif

  Call MAJ_UTIBOX201808001([L]DOSSIER)

End

########################################################################
# Check for the existence of every table needed
# Verify that the tables are not a view - indicates historic folder
# If any fail this check, do not run the script
########################################################################
Funprog TABLE_CHECK(DOSSIER)
Value Char DOSSIER

  If filinfo(filpath("FIL","BOX1099","fde",DOSSIER),0)<=0 : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER,"BOX1099") : End 0 : Endif

End 1

