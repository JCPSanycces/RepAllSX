#<AdxTL>@(#)0.0.0.0 $Revision$
# Class AOBJEXTR
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD"                  : Gosub AREAD
      When "AREAD_BEFORE"           : Gosub AREAD_BEFORE
      When "AINSERT"                : Gosub AINSERT
      When "AUPDATE"                : Gosub AUPDATE
      When "ADELETE"                : Gosub ADELETE
    Endcase
  When "AOR"
    Case [L]AEVENT
      When "AREAD_AFTER"            : Gosub AOR_AREAD_AFTER
      When "ADDLINE_AFTER"          : Gosub AOR_ADDLINE_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "INTIT"                          : Gosub INTIT
  When "NUMTAB"                         : Gosub NUMTAB
  When "AOR.NUMLIG"                     : Gosub AOR_NUMLIG
  When "AOR.INTIT"                      : Gosub AOR_INTIT
  When "AOR.NUMTAB"                     : Gosub AOR_NUMTAB
  When "AOR.CODLOC"                     : Gosub AOR_CODLOC
  When "AOR.CODEXT"                     : Gosub AOR_CODEXT
  When "AOR.CODINTIT"                   : Gosub AOR_CODINTIT
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return







$AREAD_BEFORE
Local Integer ERW


Return

##############################################################################################################
$AREAD
Local Integer TMP,MY_STATUS,ASTATUS
Local Integer ILINE,JLINE
Local File AOBJEXTR [AOR]
For [F:AOR] Where [F:AOR]NUMTAB = this.NUMTAB
  ILINE = fmet this.ADDLINE("AOR",[V]CST_ALASTPOS)
  this.AOR(ILINE).INTINTIT = [F:AOR]CODLOC+"~"+[F:AOR]CODEXT
  [L]MY_STATUS = fmet this.AOR(ILINE).AREAD([F:AOR]NUMTAB,[F:AOR]NUMLIG)
  If [L]MY_STATUS <> [V]CST_AOK
    # Invalid value
    [L]MY_STATUS = fmet this.ASETERROR("AOBJEXTRD",mess(126,143,1)-num$([F:AOR]NUMTAB)-num$([F:AOR]NUMLIG),[L]MY_STATUS)
    [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
  Endif
Next
#
## 7/17/14 remove
#If ILINE>=1
#  this.INTIT = fmet this.AOR(1).INTIT.AGETTEXT
#Endif # 7/17/14


Return

##############################################################################################################
$AINSERT
Local Integer ILINE, MY_STATUS

# Consistency controls
  Gosub CTL_CONSISTENCY : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Loop on every line that has to be created
  For ILINE=1 To maxtab(this.AOR)
    If this.AOR(ILINE)<>null
      If this.AOR(ILINE).ASTALIN = CST_ANEW
        this.AOR(ILINE).INTINTIT = this.AOR(ILINE).CODLOC+"~"+this.AOR(ILINE).CODEXT #####
        [L]MY_STATUS = fmet this.AOR(ILINE).AINSERT()
        If [L]MY_STATUS <> [V]CST_AOK
          # Invalid value
          [L]MY_STATUS = fmet this.ASETERROR("AOBJEXTRD",mess(126,143,1)-num$(this.AOR(ILINE).NUMTAB)-num$(this.AOR(ILINE).NUMLIG),[L]MY_STATUS)
          [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
        Endif
      Endif
    Endif
  Next

Return

##############################################################################################################
$AUPDATE
Local Integer ILINE,MY_STATUS

  Gosub CTL_CONSISTENCY : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Delete the lines
  For ILINE= 1 To maxtab(this.AOR)
    If this.AOR(ILINE)<>null
      If this.AOR(ILINE).ASTALIN = [V]CST_ADEL
        [L]MY_STATUS = fmet this.AOR(ILINE).ADELETE()
        If [L]MY_STATUS <> [V]CST_AOK
          # Invalid value
          [L]MY_STATUS = fmet this.ASETERROR("AOBJEXTRD",mess(126,143,1)-num$(this.AOR(ILINE).NUMTAB)-num$(this.AOR(ILINE).NUMLIG),[L]MY_STATUS)
          [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
        Endif
      Endif
    Endif
  Next

# Update the lines
  For ILINE= 1 To maxtab(this.AOR)
    If this.AOR(ILINE)<>null
      If this.AOR(ILINE).ASTALIN = [V]CST_AUPD
        [L]MY_STATUS = fmet this.AOR(ILINE).AUPDATE()
        If [L]MY_STATUS <> [V]CST_AOK
          # Invalid value
          [L]MY_STATUS = fmet this.ASETERROR("AOBJEXTRD",mess(126,143,1)-num$(this.AOR(ILINE).NUMTAB)-num$(this.AOR(ILINE).NUMLIG),[L]MY_STATUS)
          [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
        Endif
      Endif
    Endif
  Next

# Insert the lines
  For ILINE= 1 To maxtab(this.AOR)
    If this.AOR(ILINE)<>null
      If this.AOR(ILINE).ASTALIN = [V]CST_ANEW
        this.AOR(ILINE).NUMTAB = this.NUMTAB
        #this.AOR(ILINE).INTIT = this.INTIT  ##############
        [L]MY_STATUS = fmet this.AOR(ILINE).AINSERT()
         If [L]MY_STATUS <> [V]CST_AOK
          # Invalid value
          [L]MY_STATUS = fmet this.ASETERROR("AOBJEXTRD",mess(126,143,1)-num$(this.AOR(ILINE).NUMTAB)-num$(this.AOR(ILINE).NUMLIG),[L]MY_STATUS)
          [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
        Endif
      Endif
    Endif
  Next
Return

##############################################################################################################
$ADELETE
Local Integer ILINE,MY_STATUS
  For ILINE= 1 To maxtab(this.AOR)
    If this.AOR(ILINE)<>null
      If this.AOR(ILINE).ASTALIN<>[V]CST_ANEWDEL
        [L]MY_STATUS = fmet this.AOR(ILINE).ADELETE()
        If [L]MY_STATUS <> [V]CST_AOK
          [L]MY_STATUS = fmet this.ASETERROR("AOBJEXTRD",mess(126,143,1)-num$(this.AOR(ILINE).NUMTAB)-num$(this.AOR(ILINE).NUMLIG),[L]MY_STATUS)
          [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
        Endif
      Endif
    Endif
  Next
Return

##############################################################################################################
$CTL_CONSISTENCY
Local Char MESSAGE(50)

#At least one row
[L]ASTATUS = func SUPER_TOOL._REQUIRE_ROW(this.AOR, MESSAGE)
If [L]ASTATUS=[V]CST_AFALSE
  [L]ASTATUS = fmet this.ASETERROR("NUMLIG",MESSAGE,[V]CST_AERROR)
  Return
Endif

# at least one line deleted, so global description must be copied to all detail lines
If find([V]CST_ADEL,this.AOR(1..maxtab(this.AOR)).ASTALIN)
  For ILINE=1 To maxtab(this.AOR)
    If this.AOR(ILINE)<>null
      If !find(this.AOR(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
        #this.AOR(ILINE).INTIT = this.INTIT #########################
      Endif
    Endif
  Next
Endif
Return

##############################################################################################################
$AOR_AREAD_AFTER
# Assign ASTALIN to CST_ALL (they have the value 'CST_ANEW' just after AREAD method)
this.ASTALIN = [V]CST_ALL
Return

##############################################################################################################
$AOR_ADDLINE_AFTER

Return


##############################################################################################################
$INTIT
Case [L]ARULE
  When 'PROPAGATE'                      : Gosub INTIT_PROPAGATE
Endcase
Return

$INTIT_PROPAGATE
Local Integer ILINE
For ILINE=1 To maxtab(this.AOR)
  If this.AOR(ILINE)<>null
   #this.AOR(ILINE).INTIT=this.TITLE # INTIT #########################

  Endif
Next
Return

#############################################################################################################
$NUMTAB
Case [L]ARULE
  When 'INIT'                      : Gosub NUMTAB_INIT
Endcase

Return

$NUMTAB_INIT

If this.ASTALIN=[V]CST_ANEW
  Local File AOBJEXTR  [AOR]
  Read[AOR]AOR0 Last
  If !fstat
    this.NUMTAB = [F:AOR]NUMTAB + 1
  Endif
Endif

Return
############################################################################################################

$AOR_NUMLIG
Case [L]ARULE
  When "INIT"                        : Gosub AOR_NUMLIG_INIT
Endcase
Return


$AOR_NUMLIG_INIT
# Determine last not deleted NUMLIG value
Local Integer ILINE
this.NUMLIG=0
For ILINE=1 To maxtab(this.APARENT.AOR)
  If this.APARENT.AOR(ILINE)<>null
    If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
      this.NUMLIG=max(this.NUMLIG,this.APARENT.AOR(ILINE).NUMLIG)
    Endif
  Endif
Next
this.NUMLIG+=1
Return

##############################################################################################################
$AOR_INTIT
Case [L]ARULE
  When 'INIT'                        : Gosub AOR_INTIT_INIT
Endcase
Return

$AOR_INTIT_INIT
### this.INTIT = this.APARENT.INTIT ######################
Return

##############################################################################################################
$AOR_NUMTAB
Case [L]ARULE
  When 'INIT'                        : Gosub AOR_NUMTAB_INIT
Endcase
Return

$AOR_NUMTAB_INIT
this.NUMTAB = this.APARENT.NUMTAB
this.NUMCAR = num$(this.NUMTAB)
Return

##############################################################################################################
$AOR_CODEXT
Case [L]ARULE
  When 'CONTROL'                       : Gosub CODLOC_CODEXT_CONTROL
Endcase
Return

##############################################################################################################
$AOR_CODLOC
Case [L]ARULE
  When 'CONTROL'                       : Gosub CODLOC_CODEXT_CONTROL
Endcase
Return

##############################################################################################################
$CODLOC_CODEXT_CONTROL
If this.CODLOC=this.CODEXT
  # Local code and external code are identical
  [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(191,126,1),[V]CST_AERROR)
Endif
Return

##############################################################################################################
$AOR_CODINTIT ###################
Case [L]ARULE
  When 'INIT'                        : Gosub AOR_CODINTIT_INIT
Endcase
Return

$AOR_CODINTIT_INIT

Return ########

   [L]ASTATUS = fmet this.CODINTIT.AGETTEXT ### ???????????????

