#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management BGR
######################################################################################
## Section automatically added (Object BGR) 04/09/2013 13:26:46 (JUCON)
######################################################################################
$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "LIENS"       : Gosub LIENS
  When "VERIF_CRE"   : Gosub VERIF_CRE
  When "VERIF_MOD"   : Gosub VERIF_MOD
Endcase
Return

$OUVRE
If !clalev([F:BGR]): Local File BGRBAN   [BGR]  : Endif
If !clalev([F:BAN]): Local File BANK     [BAN]  : Endif
If !clalev([F:AGC]): Local File AGRPCPY  [AGC]  : Endif

Local Char WBAN(GLONBAN)
Local Integer X
Return

$LIENS
For X=0 To dim([F:BGR]BAN)-1
  If [F:BGR]BAN(X)<>""
    [M:BGR1]BAN(X)=[F:BGR]BAN(X)
    WBAN=[M:BGR1]BAN(X)
    Gosub READ_BAN
    [M:BGR1]NBLIG=X+1
  Else
    Break
  Endif
Next
Affzo [M:BGR1]
Return

$VERIF_CRE
If   [M:BGR1]NBLIG = 0
     GERR=1 : GMESSAGE = mess(61,199,1) : OK=0 : Return
Endif
Return

$VERIF_MOD
If   [M:BGR1]NBLIG = 0
     GERR=1 : GMESSAGE = mess(61,199,1) : OK=0 : Return
Endif
Return
######################################################################################
Subprog C_BAN(VALEUR)
Variable Char    VALEUR()

Local Char BLIN(GLONBAN), WCPY(GLONCPY)(1..dim([M:BGR1]BAN)), WGRP(GLONAGF)(1..dim([M:BGR1]BAN))
Local Integer I, J, NBCPY, NBGRP, GRPOK, NL

Call UNICITE(VALEUR, [M]BAN) From OBJDIV

NL=nolign-1

If NL=0 and [M:BGR1]NBLIG=1 : End: Endif
  For I=0 To [M:BGR1]NBLIG-1
    Read [BAN]BAN0=[M:BGR1]BAN(I)
    If !fstat
      If find([F:BAN]CPY,WCPY(1..50))=0
        NBCPY+=1:  WCPY(NBCPY)=[F:BAN]CPY
      Endif
    Endif
  Next

  If NBCPY>0
    Read [BAN]BAN0=VALEUR
    If !fstat
      If find([F:BAN]CPY,WCPY(1..50))=0
        NBCPY+=1: WCPY(NBCPY)=[F:BAN]CPY
        BLIN=VALEUR
        Gosub CHECK_GROUP
      Endif
    Endif
  Endif

#Endif

End

######################################################################################
Subprog AM_BAN(VALEUR)
Variable Char VALEUR
Local Char WBAN(GLONBAN)
Local Integer X, WOKK,WOK

WBAN=VALEUR
Read [BAN]BAN0=WBAN
If !fstat and [F:BAN]CFOEXD=2
  Call OUINON(mess(192,187,1)+"."-mess(288,184,1) , WOKK) From GESECRAN
  If WOKK = 2: WOK=0: Else WOK=1: Endif
Endif
If WOK=0
  X=nolign-1
  Gosub READ_BAN
Else mkstat=2: End
Endif
Affzo [M:BGR1]

End
######################################################################################
$CHECK_GROUP
Local Integer J, K, X

GRPOK=1: J=1
For [AGC] Where CPY=WCPY(NBCPY) and GRP<>WCPY(NBCPY)
  WGRP(J)=[F:AGC]GRP
  J+=1
Next
For X=1 To J-1
  NBGRP=0
  For [AGC] Where GRP=WGRP(X)
    K=1
    For K=1 To NBCPY
      If [F:AGC]CPY=WCPY(K): NBGRP+=1: Endif
    Next
  Next
  If NBGRP=NBCPY: GRPOK=0: Break: Endif
Next
If GRPOK=1 and GREP<>"" : GMESSAGE=mess(202,121,1): mkstat=2: Endif
#No company group exists for these bank companies
Return

######################################################################################
$READ_BAN
Read [BAN]BAN0=WBAN
If !fstat
  [M:BGR1]BAN(X)    = WBAN
  [M:BGR1]ACC(X)    = [F:BAN]BANACC
  [M:BGR1]CPY(X)    = [F:BAN]CPY
  [M:BGR1]CUR(X)    = [F:BAN]CUR
  [M:BGR1]IBACOD(X) = [F:BAN]IBACOD
Endif
Return
