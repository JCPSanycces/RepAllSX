#**
#* Return table info (code + name)
#* @param CODE the code of the table
#*!
Funprog GETTABLEINFO(CODE)
Value Char    CODE()

Local Char    NAME(255)
Local Char    TABLECODE(255)
Local Clbfile FIELDS(1)

If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif

NAME = ""
FIELDS = ""
TABLECODE = func GETTABLECODE(CODE)
Read [F:ATB]CODFIC=TABLECODE
If fstat=0
    Call TEXTE([F:ATB]INTITFIC, NAME) From OBJDIV
    FIELDS += TABLECODE + GXDT_VALUE_SEP + NAME + GXDT_NL_SEP 
Endif
Close Local File [F:ATB]
End FIELDS

#**
#* Return view info (code + name)
#* @param CODE the code of the view
#*!
Funprog GETVIEWINFO(CODE)
Value Char    CODE()

Local Char    NAME(255)
Local Char    VIEWCODE(255)
Local Clbfile FIELDS(1)

If clalev([F:AVW])=0 : Local File AVIEW [AVW] : Endif

NAME = ""
FIELDS = ""
VIEWCODE = func GETVIEWCODE(CODE)
Read [F:AVW]CODVUE = VIEWCODE
If fstat=0
    Call TEXTE([F:AVW]INTIT, NAME) From OBJDIV
    FIELDS += VIEWCODE + GXDT_VALUE_SEP + NAME + GXDT_NL_SEP 
Endif
Close Local File [F:AVW]
End FIELDS

#**
#* Return mask info (code + name) 
#* @param CODE the code fo the mask
#*!
Funprog GETMASKINFO(CODE)
