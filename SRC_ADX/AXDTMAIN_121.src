#**
#* Lock a file
#* 
#* @param APPL
#* @param DIR
#* @param NAME
#* @param EXT extension
#* @since 01/04/2010
#*!
Funprog LOCK_FILE(APPL, DIR, NAME, EXT)
Value Char APPL()
Value Char DIR()
Value Char NAME()
Value Char EXT()
Local Clbfile VERROU(1)
VERROU = func INTERNAL_LOCK_FILE(APPL, DIR, NAME, EXT, 1)
End VERROU


#**
#* Lock a file
#* 
#* @param APPL
#* @param DIR
#* @param NAME
#* @param EXT extension
#* @since 01/04/2010
#*!
Funprog INTERNAL_LOCK_FILE(APPL, DIR, NAME, EXT, WITHEXT)
Value Char APPL()
Value Char DIR()
Value Char NAME()
Value Char EXT()
Value Integer WITHEXT

Local Clbfile VERROU(1)
Local Char    FICLCK(GDIMFIC)
Local Char    LOCKDATE
Local Char    LOCKRESULT

FICLCK = filpath(DIR, NAME, "LCK"+EXT, APPL)
If filinfo(FICLCK,0)>0
 LOCKRESULT = "0"
 LOCKDATE = func GETLOCKDATETIME(FICLCK)
Else
 LOCKDATE = format$(GFMD,date$)-"-"-time$
 Openo FICLCK Using [LOK]
 Iomode adxifs ""       Using [LOK]
 Iomode adxirs chr$(10) Using [LOK]
 Iomode adxium GASCII   Using [LOK]
 Wrseq adxmac(-2) Using [LOK]
 Wrseq adxusr Using [LOK]
 Wrseq LOCKDATE Using [LOK]
 Openo Using [LOK]
 LOCKRESULT = "1"
Endif
If WITHEXT<>0
  VERROU = LOCKRESULT + GXDT_NL_SEP + NAME+"."+EXT + GXDT_VALUE_SEP + adxmac(-2) + GXDT_VALUE_SEP 
  VERROU += adxusr + GXDT_VALUE_SEP + LOCKDATE
Else
  VERROU = LOCKRESULT + GXDT_NL_SEP + NAME + GXDT_VALUE_SEP + adxmac(-2) + GXDT_VALUE_SEP
  VERROU += adxusr + GXDT_VALUE_SEP + LOCKDATE
Endif 
# VERROU = LOCKRESULT + GXDT_VALUE_SEP + NAME + GXDT_VALUE_SEP + adxmac(-2) + GXDT_VALUE_SEP + adxusr + GXDT_VALUE_SEP + LOCKDATE 
If LOCKRESULT <> "1"
 VERROU += GXDT_NL_SEP + func GETMESSLOCK(FICLCK)
Endif
End VERROU



#**
#* Unlock a file
#* 
#* @param APPL
#* @param DIR
#* @param NAME
#* @since 01/04/2010
#*!
Subprog UNLOCK_FILE(APPL, DIR, NAME, EXT)
Value Char APPL()
Value Char DIR()
Value Char NAME()
Value Char EXT()

Local Char    FICLCK(GDIMFIC)
Local Integer STAT

FICLCK = filpath(DIR, NAME, "LCK"+EXT, APPL)

If FICLCK<>"" & filinfo(FICLCK, 0)>0
 Call EFFACE(FICLCK, STAT) From ORDSYS
Endif
End

#**
#* Gets lock message
#* 
#* @param LOCKEDFILE
#*!
Funprog GETMESSLOCK(LOCKEDFILE)
Value Char    LOCKEDFILE()

Local Char LCKERR(250)(1..3)
Local Clbfile MESSLOCK(1)

Openi LOCKEDFILE Using [LOK]

Iomode adxifs ""       Using [LOK]
Iomode adxirs chr$(10) Using [LOK]
Iomode adxium GASCII   Using [LOK]

Rdseq LCKERR(1) Using [LOK]
Rdseq LCKERR(2) Using [LOK]
Rdseq LCKERR(3) Using [LOK]
Openi Using [LOK]
#Call ERREUR(mess(200,124,1)+"\|"+LCKERR(1)+"|\|"+LCKERR(2)+"|\|"+LCKERR(3)) From GESECRAN
MESSLOCK = mess(200,124,1)+" "+LCKERR(1)+" ("+LCKERR(2)+") - "+LCKERR(3)
End MESSLOCK

#**
#* Gets lock date time
#* @param LOCKEDFILE
#*!
Funprog GETLOCKDATETIME(LOCKEDFILE)
Value Char    LOCKEDFILE()

Local Char LCKERR(250)(1..3)
Local Char MESSLOCK(250)

Openi LOCKEDFILE Using [LOK]

Iomode adxifs ""       Using [LOK]
Iomode adxirs chr$(10) Using [LOK]
Iomode adxium GASCII   Using [LOK]

Rdseq LCKERR(1) Using [LOK]
Rdseq LCKERR(2) Using [LOK]
Rdseq LCKERR(3) Using [LOK]
Openi Using [LOK]
MESSLOCK = LCKERR(3)
End MESSLOCK


#**
#* Compiles a file
#* 
#* @param PROG
#* @param DOSSIER
#*!
Funprog COMPILTRT(PROG, DOSSIER)
Value    Char    PROG()
Value    Char    DOSSIER()

Local Integer STAT , SAVSEEK
Local Char    FICTRA(GDIMFIC)
Local Char    ORDSYS(250)(1..2)
Local Char    MESSAGE(80)(1..5) , MESSA(80)
Local Char    SAVIFS(20), SAVIRS(20)
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

Local Clbfile MESSCOMPILE(1)

Call MACHINE(DOSSIER, MACHINE, APPLI) From ORDSYS

SAVIFS = adxifs
SAVIRS = adxirs
ORDSYS(1) = "valtrt"-APPLI-PROG
MESSA = mess(20,123,1) : # Erreur en validation du traitement

FICTRA = filpath("tmp", PROG, "tra", APPLI, "", MACHINE)
Openo FICTRA, 0
Openo

ORDSYS(2)  = FICTRA
Call SYSTEME(MACHINE, ORDSYS, "", STAT) From ORDSYS
#If STAT
# Call ECR_TRACE(mess(6,123,1)-NUM$(STAT)-"SYSTEME"+"\|"+ORDSYS(1),1) From GESECRAN : # Erreur
#Endif

adxifs = ""
adxirs = chr$(10)
Openi FICTRA
Raz MESSAGE
Rdseq MESSAGE(1)
Rdseq MESSAGE(2)
Rdseq MESSAGE(3)
Rdseq MESSAGE(4)
Rdseq MESSAGE(5)
Openi

If MESSAGE(1)<>""
# Call ECR_TRACE(MESSA-PROG+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3)+"|\|"+MESSAGE(4),1)
#& From GESECRAN
 MESSCOMPILE = MESSA-PROG+GXDT_VALUE_SEP+MESSAGE(1)+GXDT_VALUE_SEP+MESSAGE(2)+GXDT_VALUE_SEP
 MESSCOMPILE += MESSAGE(3)+GXDT_VALUE_SEP+MESSAGE(4)
Else
 MESSCOMPILE = "1"
 Call EFFACE(FICTRA, STAT) From ORDSYS
# If STAT
#  Call ECR_TRACE(mess(6,123,1)-NUM$(STAT)-"EFFACE"+"\|"+FICTRA,1) From GESECRAN : # Erreur
# Endif
Endif

adxifs = SAVIFS
adxirs = SAVIRS

End MESSCOMPILE


#**
#* Get local menu label or messages from chapter if number = -1
#* 
#* @param CHAPTER
#* @param NUMBER
#* @param FILENUMBER
#*!
Funprog GETLOCALMENU(CHAPTER, NUMBER, FILENUMBER)
Value    Char    CHAPTER()
Value    Char    NUMBER()
Value    Char    FILENUMBER()

Local Integer NCHAPTER
Local Integer NNUMBER
Local Integer NFILENUMBER

NCHAPTER = val(CHAPTER)
NNUMBER = val(NUMBER)
NFILENUMBER = val(FILENUMBER)

Local Clbfile MESSAGE(6)
Local Char MSG(250)
Local Char CHAPTER_TITLE(250)
Local Integer I
Local Integer NBMAX : NBMAX = 300

If NNUMBER = -1 # return all messages from chapter

  # Read local menu title  
  If clalev([F:AST7])=0 : Local File APLSTD  [AST7] : Endif
  If NCHAPTER<100 
    Read [AST7]CLE = 0;NCHAPTER;GLANGUE 
  Else
    Read [AST7]CLE = 200;NCHAPTER-200;GLANGUE 
  Endif
  If fstat
    Read [AST7]CLE = NCHAPTER;0;GLANGUE
  Endif
  If !fstat
    CHAPTER_TITLE = [F:AST7]LANMES

    # Read first NBMAX records
    For I = 1 To NBMAX
      MSG = mess(I, NCHAPTER, NFILENUMBER)
      If MSG <> ""
        If MESSAGE <> ""
          MESSAGE += GXDT_VALUE_SEP
        Endif
        MESSAGE += num$(I)
        MESSAGE += " - "
        MESSAGE += MSG
      Endif
    Next I

    # If more than NBMAX records, display "..."
    MSG = mess(NBMAX + 1, NCHAPTER, NFILENUMBER)
    If MSG <> ""
      If MESSAGE <> ""
        MESSAGE += GXDT_VALUE_SEP
      Endif
      MESSAGE += " ... "
    Endif
  
    If MESSAGE <> ""
      MSG = CHAPTER + " - '" + CHAPTER_TITLE + "'" + GXDT_VALUE_SEP
      MESSAGE = MSG + MESSAGE
    Endif
  Endif
  
Else
  MESSAGE = mess(NNUMBER, NCHAPTER, NFILENUMBER)
Endif
End MESSAGE


#**
#* Format source header 
#*!
Funprog GETFILEHEADER()
Local Char FILEHEADER(80)
FILEHEADER = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
FILEHEADER = ctrans(FILEHEADER,chr$(0),"")
End FILEHEADER

#**
#* Gets source from server (as a clob)
#*
#* @param X3FOLDER folder
#* @param SRCCODE file name
#* @param FILEEXT file extension (src, stc)
#* @param FILEDIR file directory (TRT, STC)
#* @since 01/04/2010
#*!
Funprog GET_FILE(X3FOLDER, SRCCODE, FILEEXT, FILEDIR)
Value Char    X3FOLDER()
Value Char    SRCCODE()
Value Char    FILEEXT()
Value Char    FILEDIR()

#Local Char    FILEHEADER(80)
#FILEHEADER = func GETFILEHEADER()

Local Char SRCNAME(GDIMFIC)
SRCNAME = filpath(FILEDIR, SRCCODE, FILEEXT, X3FOLDER)

Local Clbfile FILECONTENT(11)
Raz FILECONTENT

Local Integer DIME, I, J, K, NB, R
If filinfo(SRCNAME, 0)<0 : End FILECONTENT : Endif

Local Char    CHAINE(250)
DIME = 10000
Local Char    LINE(255)(1..DIME)

Openi SRCNAME Using [TRT]
Iomode adxifs "" Using [TRT]
Iomode adxirs chr$(10) Using [TRT]
Iomode adxium GUTF8 Using [TRT]

Raz LINE, NB
Rdseq CHAINE Using [TRT]
#If !fstat & left$(CHAINE,5)<>left$(FILEHEADER,5)
 NB += 1
 LINE(NB) = ctrans(CHAINE,chr$(0),"_") + chr$(10) 
#Endif

Iomode adxirs "" Using [TRT]
Rdseq CHAINE Using [TRT]
While CHAINE<>""
 While CHAINE<>""
  If NB>=DIME
#   Call ERREUR("|"+SRCNAME-"|\"-mess(175,115,1)) From GESECRAN : # Taille du fichier trop grande
   Break 2
  Else
   K = instr(1,CHAINE,chr$(10))
   If K
    NB += 1
    LINE(NB) = left$(CHAINE,K)
    CHAINE = right$(CHAINE,K+1)
   Else
    NB += 1
    LINE(NB) = CHAINE
    CHAINE = ""
   Endif
  Endif
 Wend
 Rdseq CHAINE Using [TRT]
Wend
Openi Using [TRT]
fstat=0
# Le fichier .src contient des LF en fin de ligne
# La saisie du clob par le client x3 rajoute des CR+LF en fin de ligne
# A la lecture du .src , on rajoute des CR+LF en bout de ligne pour eviter une apres_modif inutile
R = 1
For I=1 To NB
 K = len(LINE(I))
 If right$(LINE(I),K)=chr$(10)
#  If R
#   LINE(I) = format$("KTv1:"+num$(type(LINE))+"X",left$(LINE(I),K-1))+chr$(13)+chr$(10)
#  Else
   LINE(I) = left$(LINE(I),K-1)+chr$(13)+chr$(10)
#  Endif
  R = 1
 Else
  R = 0
 Endif
Next I
Setlob FILECONTENT With LINE

If func IS_TRACE_ON()
  Call TRACE(".GET_FILE: name=" + SRCNAME + ", lines=" + num$(NB))
Endif
End FILECONTENT


#**
#* Puts source to server (receive as a clob)
#*  
#* @param X3FOLDER folder
#* @param SRCCODE file name
#* @param FILEEXT file extension (src, stc)
#* @param FILEDIR file directory (TRT, STC)
#* @param FILECONTENT file content
#* @since 01/04/2010
#*!
Funprog PUT_FILE(X3FOLDER, SRCCODE, FILEEXT, FILEDIR, FILECONTENT)
Value Char    X3FOLDER()
Value Char    SRCCODE()
Value Char    FILEEXT()
Value Char    FILEDIR()
Value Clbfile FILECONTENT()

Local Char OK
Local Integer DIME , I , K , NB
DIME = 10000
Local Char    LIGNE(255)(1..DIME)

#Local Char    FILEHEADER(80)
#FILEHEADER = func GETFILEHEADER()

Local Char SRCNAME(GDIMFIC)
SRCNAME = filpath(FILEDIR, SRCCODE, FILEEXT, X3FOLDER)

Local Integer STA
Local Char    MACHINE(250), APPLI(GLONADS)
Local Char    MES(250)

Raz LIGNE
Setlob LIGNE With FILECONTENT
If LIGNE=""
 # Delete empty file
 Call DELETE_FILE(SRCCODE, X3FOLDER, "1", "", FILEEXT, FILEDIR)
 OK = "0"
 End
Endif

OK = "1"
NB = DIME
While NB & LIGNE(NB)=""
 NB -= 1
Wend
# Deletion of CR from clob before writing file
For I=1 To NB
 LIGNE(I) = ctrans(LIGNE(I),chr$(13),"")
Next I

Openo SRCNAME, 0 Using [TRT]
Iomode adxifs ""       Using [TRT]
Iomode adxirs chr$(10) Using [TRT]
Iomode adxium GUTF8 Using [TRT]

#Wrseq FILEHEADER-[M]DES Using [TRT]
#Wrseq FILEHEADER       Using [TRT]
Iomode adxirs ""       Using [TRT]
For I=1 To NB
 Wrseq LIGNE(I) Using [TRT]
Next I
Openo Using [TRT]

# Fill ADICTRT table
Onerrgo ERR_PUT_FILE
Call MACHINE(X3FOLDER, MACHINE, APPLI) From ORDSYS
STA = func SUBADC.DICTRT(SRCCODE, FILEEXT, X3FOLDER, MACHINE, "", 1, MES)
Onerrgo

If func IS_TRACE_ON()
  Call TRACE(".PUT_FILE: name=" + SRCNAME + ", lines=" + num$(NB))
Endif
End OK

$ERR_PUT_FILE
Resume

#**
#* Delete a file from server
#* 
#* @param SRCCODE trt code (eg SUBITM)
#* @param X3FOLDER folder (eg SUPERV)
#* @param DELETEADX "1" for ADX deletion 
#* @param CONDITION deletion condition (eg GADONIX<>2)
#* @param FILEEXT file extension (src, stc)
#* @param FILEDIR file directory (TRT, STC)
#* @since 01/04/2010
#*!
Subprog DELETE_FILE(SRCCODE, X3FOLDER, DELETEADX, CONDITION, FILEEXT, FILEDIR)
  Value Char    SRCCODE()
  Value Char    X3FOLDER()
  Value Char    DELETEADX()
  Value Char    CONDITION()
  Value Char    FILEEXT()
  Value Char    FILEDIR()
 
  Local Integer STAT
  Local Char NOMSRC(GDIMFIC)
  Local Integer NEED_TO_DELETE

  If CONDITION = ""
    NEED_TO_DELETE = 1
  Else
    NEED_TO_DELETE = evalue(CONDITION)
  Endif
 
  If NEED_TO_DELETE = 1
    NOMSRC = filpath(FILEDIR, SRCCODE, FILEEXT, X3FOLDER)
    Call EFFACE(NOMSRC, STAT) From ORDSYS
    If DELETEADX = "1"
      Call EFFACE_ADX("", X3FOLDER, SRCCODE, STAT) From ORDSYS
    Endif
  Endif
End


#**
#* Gets the list of programs on server (in a folder)
#* Exclude W* programs (generated programs)
#*  
#* @param DOSSIER
#* @param START
#* @param NBMAX
#*!
Funprog GETFILESLIST(DOSSIER, START, NBMAX)

Value Char    DOSSIER()
Value Char    START()
Value Char    NBMAX()

Local Char    FILTRE(250)
Local Clbfile FILES(10)

FILTRE = 'left$(TRT,1)<>"W"'
FILES = func GETFILTEREDFILESLIST(DOSSIER, START, FILTRE, NBMAX)

End FILES


#**
#* Gets the filtered list of programs on server (in a folder) 
#* @param DOSSIER
#* @param START
#* @param FILTERS
#* @param NBMAX
#*!
Funprog GETFILTEREDFILESLIST(DOSSIER, START, FILTERS, NBMAX)
Value Char    DOSSIER()
Value Char    START()
Value Char    FILTERS()
Value Char    NBMAX()

Local Clbfile FILES(10)
FILES = func GETFILES(DOSSIER, START, FILTERS, NBMAX, "src", "TRT")
End FILES


#**
#* Gets a filtered list of files on server (in specified folder and directory) 
#*
#* @param DOSSIER folder
#* @param START starting name
#* @param FILTERS caller filters
#* @param NBMAX max number of files returned
#* @param FILEEXT file extension (src, stc)
#* @param FILEDIR file directory (TRT, STC)
#* @since 01/04/2010
#*!
Funprog GETFILES(DOSSIER, START, FILTERS, NBMAX, FILEEXT, FILEDIR)
Value Char    DOSSIER()
Value Char    START()
Value Char    FILTERS()
Value Char    NBMAX()
Value Char    FILEEXT()
Value Char    FILEDIR()

Local Char    FILTRE(250), REPERT(GDIMFIC)
Local Char    MACHINE(250), APPLI(GLONADS), ORDSYS(250)
Local Char    CODTRT(GLONADC)
Local Integer NB_TRT, K
Local Integer NB_MAX

Local Clbfile FILES(10)


# Default values initialization
If NBMAX = "-1" : NB_MAX = GNBSEL : Else : NB_MAX = val(NBMAX) : Endif
If DOSSIER="" : DOSSIER = nomap : Endif

Call MACHINE(DOSSIER, MACHINE, APPLI) From ORDSYS
REPERT = filpath(FILEDIR, "", "", APPLI, "", MACHINE)

# Insert start filter
If START="" 
  FILTRE = ""
Else
  FILTRE = 'TRT>="'+START+'"'
Endif

# Exclude empty named files
If FILTRE<>"" : FILTRE += "&" : Endif
FILTRE += 'TRT<>""'

# insert caller filters
If FILTERS<>"" 
  If FILTRE<>"" : FILTRE += "&" : Endif
  FILTRE += FILTERS
Endif

If clalev([F:TRT_])>0 : Close Local File [TRT_] : Endif
Case FILEEXT
 When "src"
  ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REPERT
  FILTRE += '& pat(TRT,"*.src")'
 When "stc"
  ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REPERT
  FILTRE += '& pat(TRT,"*.stc")'
 When Default
  ORDSYS = MACHINE+"@"+'archive -d '+DOSSIER-' -t "adx" -l "*" -v'
Endcase
Local File (TRT(30)) From System ORDSYS As [TRT_]

NB_TRT =0
For [TRT_] Where evalue(FILTRE)
 NB_TRT += 1
 K = instr(1, [F:TRT_]TRT, "."+FILEEXT)
 If K
  CODTRT = left$([F:TRT_]TRT, K-1)
 Else
  CODTRT = [F:TRT_]TRT
 Endif
 If NB_TRT > NB_MAX
   Break
 Endif
 FILES+=CODTRT+GXDT_VALUE_SEP
Next TRT_
End FILES


$KEEP_ERROR
ER = errn
Resume

#**
#* Get locked files list
#* @since 01/04/2010
#*!
Funprog GET_LOCKED_FILES
Local Clbfile FILELIST(10)
FILELIST = func INTERNAL_GET_LOCKED_FILES("STC", "stc", 1)
FILELIST += func INTERNAL_GET_LOCKED_FILES("TRT", "src", 1)
End FILELIST

#**
#* Get locked files list for special directory and extension
#*
#* @param DIR directory 
#* @param EXT extension
#*!
Funprog INTERNAL_GET_LOCKED_FILES(DIR, EXT, WITHEXT)
Value Char DIR()
Value Char EXT()
Value Integer WITHEXT

Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    APPLI(GLONADS) , FILEEXT(10)
Local Char    FICHIER(250)
Local Integer NBTRT , I
Local Char    TBTRT(GLONADC+2)(1..300)
Local Char    STR(250)(3)

Local Clbfile FILES(10)

APPLI = nomap
FILEEXT   = "LCK"+EXT

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GASCII

# Infbox(adxtct-adxmac(-1)-" | "-adxmac(-2))
Call SYSTEME2(adxmac(0), "lsadx -a"-APPLI-DIR-FILEEXT, "", NBTRT, TBTRT) From ORDSYS
For I=1 To min(NBTRT, dim(TBTRT))
 FICHIER = filpath(DIR, TBTRT(I), FILEEXT, APPLI)
 If filinfo(FICHIER, 0)>=0
  Openi FICHIER
  Rdseq STR(0)
  Rdseq STR(1)
  Rdseq STR(2)
  Openi

  # Program / Machine / User / DateTime
  If WITHEXT <> 0
    FILES += TBTRT(I)+"."+EXT + GXDT_VALUE_SEP + STR(0)+ GXDT_VALUE_SEP
    FILES += STR(1) + GXDT_VALUE_SEP + STR(2) + GXDT_NL_SEP
  Else
    FILES += TBTRT(I) + GXDT_VALUE_SEP + STR(0)+ GXDT_VALUE_SEP 
    FILES += STR(1) + GXDT_VALUE_SEP + STR(2) + GXDT_NL_SEP
  Endif
  
 Endif
Next I

adxirs = SAVIRS
adxifs = SAVIFS
adxium = SAVIUM
End FILES


#**
#* Get default help location
#*!
Funprog GET_HELP_PATH()
Local Char RETOUR(200)
Local Integer OK
Call RECHPROP("doc.files.clientwebaccessurl", RETOUR, OK) From INTRUTILA
End RETOUR

#**
#* Get Solution name
#*!
Funprog GET_SOLUTION_NAME()
Local Char SOLUTION(200)
Local Char NOMFIC(200), VALL1(200)

Call NAMEFIC(nomap,"SOL","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,7)<0 : Goto ERRLEC : Endif
fstat=0
Openi NOMFIC,0 Using [CST_]
If fstat<>0 : Goto ERRLEC : Endif
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
fstat=0
While fstat=0
  Rdseq VALL1 Using [CST_]
  If instr(1,VALL1,"<solution")<>0
    I1=instr(1,VALL1,"name")
    I2=instr(I1+6,VALL1,'"')
    If I2-I1-6>0
      SOLUTION=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
    Endif
  Endif
Wend
End SOLUTION

$ERRLEC:
End ""

#**
#* Launch a program in Eclipse IDE (via http server)
#* 
#* @param NOMFIC the source file name (eg : GTRAITE.src)
#* @param READONLY 1 for open readonly, 0 for open read/write
#*!
Subprog LAUNCH_TRT(NOMFIC, READONLY)
Value Char NOMFIC()
Value Integer READONLY
  
Local Integer NB_PARAM
Local Integer I
NB_PARAM=11
I=1
Local Char JAR_NAME(250)    
Local Char JAR_FULLNAME(250)    
Local Char JAR_EXT(10)    
Local Char PARAM_NAME(250)(1..NB_PARAM)
Local Char PARAM_VALUE(250)(1..NB_PARAM)
Local Char RESULT(250)

Onerrgo ERR_LAUNCH

JAR_NAME="ideclient"
JAR_EXT="jar"
JAR_FULLNAME=JAR_NAME + "." + JAR_EXT

# set parameters
PARAM_NAME(I)="folder"
PARAM_VALUE(I) = func GET_FOLDER(NOMFIC)
If PARAM_VALUE(I) = ""
  PARAM_VALUE(I)=nomap
Endif

I+=1
PARAM_NAME(I)="server"
PARAM_VALUE(I)=tolower(GMACADO)

I+=1
PARAM_NAME(I)="port"
PARAM_VALUE(I)=num$(adxtcp)

I+=1
PARAM_NAME(I)="src"
PARAM_VALUE(I)=NOMFIC

I+=1
PARAM_NAME(I)="readonly"
If READONLY = 1
    PARAM_VALUE(I)="true"
Else
    PARAM_VALUE(I)="false"
Endif

I+=1
PARAM_NAME(I)="trace"
PARAM_VALUE(I)="false"

I+=1
PARAM_NAME(I)="x.lang"
PARAM_VALUE(I)=GLANGUE

I+=1
PARAM_NAME(I)="x.user"
PARAM_VALUE(I)=GUSER

Local Char PWD(50)
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
Read [AUS]CODUSR = GUSER
If fstat=0
  PWD=[F:AUS]NEWPAS
Else
  PWD="error"
Endif

I+=1
PARAM_NAME(I)="x.pwd"
PARAM_VALUE(I)=PWD

I+=1
PARAM_NAME(I)="x.osuser"
PARAM_VALUE(I)=adxcus

I+=1
PARAM_NAME(I)="x.ospwd"
PARAM_VALUE(I)=adxcpw

# check if jar file is available
Local Char INFOFILE(GDIMFIC)(3)
Local Integer INFORET
INFORET = func GET_X3CLI_FILE_INFO(JAR_NAME, JAR_EXT, INFOFILE)
If (INFORET <> 0)
  # Execution impossible - Fichier inexistant : ...
  Errbox mess(160,115,1) + " - " + mess(101,100,1) + " :" + chr$(13) 
&   + "'" + INFOFILE(0) + "'" + chr$(13)
  End
Endif

#CALLIU "XDT_ECLI:openSRC" With JAR_NAME, PARAM_NAME, PARAM_VALUE
RESULT = Funciu "XDT_ECLI:openSRC" With (JAR_FULLNAME, PARAM_NAME, PARAM_VALUE)

Onerrgo

End

$ERR_LAUNCH
  # Execution impossible - Verifier votre installation :
  # 'SAFE X3 Studio for Eclipse'
  # Cette application n'est pas configuree sur votre poste. Veuillez contacter l'administrateur du systeme.
Errbox mess(160,115,1) + " - " + mess(2,9119,1) + " :" + chr$(13)
& + "'SAFE X3 Studio for Eclipse'" + chr$(13)
& + mess(22, 9137,1) 
Resume

#**
#* Return folder where source file could be found
#*
#* @param SOURCEFILE source name (with or without extension)
#*!
Funprog GET_FOLDER(SOURCEFILE)
Value Char SOURCEFILE()
Local Char SOURCENAME(250)

Local Char FOLDR(250)
Local Char WNAME(GDIMFIC)
Local Integer POSEXT
POSEXT = instr(0, SOURCEFILE, ".")
If POSEXT > 0
  SOURCENAME = left$(SOURCEFILE, POSEXT - 1)
Else
  SOURCENAME = SOURCEFILE
Endif

Local Integer I
For I = 0 To dim(nomap)
  If nomap(I) <> ""
     WNAME = filpath("TRT", SOURCENAME, "src", I)
     If filinfo(WNAME, 0) >= 0
      FOLDR = nomap(I)
      Break
    Endif
  Endif
Next I
End FOLDR


#**
#* Get file properties (infos displayed in ADICTRT)
#* 
#* @param NOMFIC
#*!
Funprog GET_FILE_PROPERTIES(NOMFIC)
Value Char NOMFIC()

Local Clbfile RETOUR(6)

Local Char WSRC(250)
Local Char WSRCINT(250)
Local Char WINFO(250)(0..6)
Local Char WSEPARATOR(5) : WSEPARATOR = "|"
Local Clbfile TEXT(4) : TEXT = ""

If clalev([F:ADC])=0 : Local File ADICTRT [ADC] : Endif

NAME = ""

Read [F:ADC]ADC0=NOMFIC
If !fstat
#    Call TEXTE([F:ADC]INTITFIC, NAME) From OBJDIV

    If [F:ADC]SRC <> 2
        WSRC = "false"
    Else
        WSRC = "true"
    Endif

    If [F:ADC]SRCINT <> 2
        WSRCINT = "false"
    Else
        WSRCINT = "true"
    Endif

    Call INFOS(NOMFIC, WINFO)

    TEXT = func GETTEXT("TRT", NOMFIC)

    RETOUR += [F:ADC]CODTRT + GXDT_VALUE_SEP 
&    + [F:ADC]DES + GXDT_VALUE_SEP
&    + num$([F:ADC]MODULE) + GXDT_VALUE_SEP
&    + mess([F:ADC]MODULE, 14, 1) + GXDT_VALUE_SEP
&    + [F:ADC]CODACT + GXDT_VALUE_SEP
&    + WSRC + GXDT_VALUE_SEP
&    + WSRCINT + GXDT_VALUE_SEP
&    + TEXT + GXDT_VALUE_SEP
&    + WINFO(0) + WSEPARATOR + WINFO(1) + WSEPARATOR + WINFO(2) + WSEPARATOR
&    + WINFO(3) + WSEPARATOR + WINFO(4) + WSEPARATOR + WINFO(5) + WSEPARATOR
&    + WINFO(6) + GXDT_NL_SEP

Endif

Close Local File [F:ADC]

End RETOUR

#**
#* 
#* @param FICHIER
#* @param INFOS
#*!
Subprog INFOS(FICHIER, INFOS)
Value Char    FICHIER()
Variable Char INFOS()(0..6)
Raz INFOS
Local Integer L

Local Decimal PROPRIO
Local Decimal TAILLE
Local Date    DATMOD
Local Char    HREMOD
Local Integer OK

Gosub CHARGE_USR From SUBADC

L = 0
Call INFOFIC("TRT", FICHIER, "src", PROPRIO, TAILLE, DATMOD, HREMOD, OK) From SUBADC
If OK<0
 INFOS(L) = mess(55,100,1)-"src"-mess(87,100,1) : # Fichier...inexistant
Else
 INFOS(L) = mess(55,100,1)-"src"-mess(172,126,1)-nomap(OK) : # Fichier...present dans le dossier
 L += 1
 INFOS(L) = num$(TAILLE)-mess(133,133,1) : # octets
 If NBUSER
  Gosub USER From SUBADC
  INFOS(L) += ","-mess(134,133,1)-IDUSR : # Proprietaire
 Endif
 INFOS(L) += ","-mess(162,124,1)-format$("D:"+GFMDAT4,DATMOD)-HREMOD-"GMT" : # Modifie le
Endif
L += 2
Call INFOADX(FICHIER,PROPRIO,TAILLE,DATMOD,HREMOD,OK) From SUBADC
If OK<0
 INFOS(L) = mess(158,139,1) : # Traitement inexistant dans l'archive
Else
 INFOS(L) = mess(159,139,1)-nomap(OK) : # Traitement existant dans l'archive du dossier
Endif
If TAILLE>=0
 L += 1
 INFOS(L) = num$(TAILLE)-mess(133,133,1) : # octets
 If NBUSER
  Gosub USER From SUBADC
  INFOS(L) += ","-mess(134,133,1)-IDUSR : # Proprietaire
 Endif
 INFOS(L) += ","-mess(162,124,1)-format$("D:"+GFMDAT4,DATMOD)-HREMOD-"GMT" : # Modifie le
Endif
L += 2
Call VERSACH(nomap,INFOS(L)) From SUBADC
INFOS(L) = mess(199,115,1)-"->"-INFOS(L)
End

#**
#* Gets modules 
#*!
Funprog GETMODULES()

Local Clbfile MODULES(9)

Local Char    LABEL(255)
Local Integer INDEX
Local Integer NB
Local Integer CHAPTER : CHAPTER = 14

MODULES = ""

 NB = len(mess(0, CHAPTER, 1))
For INDEX=1 To NB
    LABEL = func GETLOCALMENU(num$(CHAPTER), num$(INDEX), "1")
    MODULES += num$(INDEX) + GXDT_VALUE_SEP + LABEL + GXDT_NL_SEP
Next INDEX

End MODULES

#**
#* Set file properties (with additional TEXT parameter) in ADICTRT
#* 
#* @param NOMFIC
#* @param RECORD
#* @param TEXT 
#*!
Funprog SET_FILE_PROPERTIES(NOMFIC, RECORD, TEXT)
Value Char NOMFIC()
Value Char RECORD()
Value Clbfile TEXT()

Local Char RETOUR(250)

Local Char WDES(250)
Local Integer WMODULE
Local Char WCODACT(250)
Local Integer WSRC
Local Integer WSRCINT

Local Integer NBMOT
Local Integer NBMOTMAX : NBMOTMAX = 30
Local Char    TABSPLIT(255)(NBMOTMAX+1) : 

Local Char SYMBOLE

If clalev([F:ADC])=0 : Local File ADICTRT [ADC] : Endif

SYMBOLE="ADC"+NOMFIC    
Lock =SYMBOLE With lockwait=0
If [S]fstat = 1     # locked record
    RETOUR = "0" + GXDT_NL_SEP + NOMFIC + " : " + mess(60,100,1)
Else
  Trbegin [ADC]
  Readlock [F:ADC]ADC0 = NOMFIC
  If [S]fstat <> 1 
    
    NBMOT = func SPLIT(RECORD, GXDT_VALUE_SEP, TABSPLIT)
    
    WDES = TABSPLIT(0)
    WMODULE = val(TABSPLIT(1))
    WCODACT = TABSPLIT(2)
    WSRC = val(TABSPLIT(3))
    WSRCINT = val(TABSPLIT(4))
    If TEXT = ""
      Setlob TEXT With TABSPLIT(5)
    Endif
    
    [F:ADC]DES = WDES
    [F:ADC]MODULE = WMODULE
    [F:ADC]CODACT = WCODACT
    [F:ADC]SRC = WSRC
    [F:ADC]SRCINT = WSRCINT
        
    If [S]fstat=0
      Rewrite [F:ADC]
    Else
      [F:ADC]CODTRT = NOMFIC
      Write [F:ADC]
    Endif
    Call SETTEXT("TRT", NOMFIC, TEXT, WDES, WMODULE, WCODACT)
    
    Commit
    Unlock =SYMBOLE
    RETOUR = "1"
  Else      # locked record
    Rollback
    RETOUR = "0" + GXDT_NL_SEP + NOMFIC + " : " + mess(60,100,1)
  Endif
Endif  

Close Local File [F:ADC]

End RETOUR


#fonction deja presente dans ARECHMEN (voir pour la centraliser quelque-part)
#**
#* Splits a string with a given separator
#* 
#* @param CHAINE
#* @param SEPARATEUR
#* @param RETOUR
#*!
Funprog SPLIT(CHAINE,SEPARATEUR,RETOUR)
Value Char CHAINE()
Value Char SEPARATEUR()
Variable Char RETOUR()()

Local Clbfile CHAINE_LOB(1)
CHAINE_LOB = CHAINE

Local Integer NBMOT
NBMOT = func SPLIT_LOB(CHAINE_LOB, SEPARATEUR, RETOUR)
End NBMOT

#**
#* Splits a clbfile with a given separator
#* 
#* @param CHAINE
#* @param SEPARATEUR
#* @param RETOUR
#*!
Funprog SPLIT_LOB(CHAINE,SEPARATEUR,RETOUR)
Value Clbfile CHAINE()
Value Char SEPARATEUR()
Variable Char RETOUR()() #tableau de chaines de caracteres ou sont renvoyees les chaines decoupees

Local Integer DEBUT , FIN , FINBOUCLE , NBMOT

DEBUT=1 #debut du mot
FIN=1 #fin du mot
FINBOUCLE=0 #sortie de boucle
NBMOT=0 #nombre de mot

#parcourt de la chaine
Repeat
 #recherche d'un mot
 FIN=instr(DEBUT,CHAINE,SEPARATEUR)
 If FIN=0
  FINBOUCLE=1
  FIN=len(CHAINE)+1
 Endif
 RETOUR(NBMOT)=seg$(CHAINE,DEBUT,FIN-1) #ajout du mot au retour
 DEBUT=FIN+len(SEPARATEUR)
 NBMOT+=1  
Until FINBOUCLE | NBMOT=dim(RETOUR)
End NBMOT

#**
#* Return label corresponding to an object code 
#* @param OBJECTCODE
#* @param KEYCODE
#*!
Funprog GET_OBJECT_LABEL(OBJECTCODE, KEYCODE)
Value Char    OBJECTCODE()
Value Char    KEYCODE()

Local Char    LABEL(255)
LABEL = func AFNC.INTCLE(OBJECTCODE, KEYCODE)

End LABEL

#**
#* Evaluates an expression
#* @param EXPR the expression to evaluate
#* @return RETOUR error code (0=OK) + separator + evaluated result
#*!
Funprog EVALUE_EXPR(EXPR)
Value Char EXPR()

Local Integer ERRCODE
Local Clbfile EVAL(10)
Local Clbfile RETOUR(11)
Local Char ERR(250)

ERRCODE = parse(EXPR)

Onerrgo EVALUE_EXPR_ERROR

Local Integer OK
Call FLUSHADX(OK) From AFLUSHADX

EVAL = ""
RETOUR = ""
If ERRCODE = 0
  EVAL = evalue(EXPR)
  # If the error has been trapped ERRCODE is not 0 at this point 
  If ERRCODE <> 0
    ERRCODE = 0
    EVAL = num$(evalue(EXPR))
  Endif
Endif

If ERRCODE = 0
  ERR = "1" + GXDT_NL_SEP
  RETOUR = ERR + EVAL
Else
  ERR = "0" + GXDT_NL_SEP + errmes$(ERRCODE) + GXDT_NL_SEP + num$(ERRCODE)
  RETOUR = ERR 
Endif

End RETOUR


$EVALUE_EXPR_ERROR
  ERRCODE = errn
Resume

#**
#* Return <code>0</code> if file exists in the X3CLI directory and 
#* <code>1</code> if it not exists 
#* @param FILE_NAME
#* @param FILE_EXT
#*!
Funprog GET_X3CLI_FILE_INFO(FILE_NAME, FILE_EXT, INFO)
Value Char FILE_NAME
Value Char FILE_EXT
Variable Char INFO()()

Local Char REP(GDIMFIC)
Local Char NAMEREP(GDIMFIC)
Local Integer RETVAL

REP = "X3_ROOT/X3CLI"
# == get filename ==
NAMEREP = filpath(REP, FILE_NAME, FILE_EXT, "X3_PUB", "", adxmac(-1))
INFO(0) = NAMEREP   
# == get size ==
INFO(1) = num$(filinfo(NAMEREP,7))
#Infbox "ret=" + num$(FILE_ERR)
If val(INFO(1)) > 0 
#  Infbox mess(101,100,1) + " : " + NAMEREP
  # == get modification date ==
  INFO(2) = num$(filinfo(NAMEREP,9))
  RETVAL = 0 : #OK
Else
  RETVAL = 1 : #KO
Endif

End RETVAL

#**
#* @return if ASUBPROGD table is present (used to determine which method to use).
#*!
Funprog ISASUBPROGDOK()
  Local Integer PRESENT
  PRESENT = filinfo(filpath("FIL", "ASUBPROGD", "fde", -1), 0)  # Table exists 
End PRESENT 

#**
#* Return method (Funprog or Subprog) info from ASUBPROG table 
#* @param PROGRAM
#* @param SUBPRO
#*!
Funprog GETMETHODINFO(PROGRAM, SUBPRO)
Value Char    PROGRAM()
Value Char    SUBPRO()

Local Char    NAME(255)
Local Clbfile TEXT(4)
Local Clbfile FIELDS(4)
Local Char SUBPRO_TYPE(255)
Local Integer OK
Local Integer MAXPARAMIDX

If clalev([F:ASU])=0 : Local File ASUBPROG  [ASU] : Endif

# Initializations
NAME = ""
FIELDS = ""
TEXT = ""

Read [F:ASU]ASU0=PROGRAM;SUBPRO
If fstat=0
    Call TEXTE([F:ASU]INTIT, NAME) From OBJDIV
    If ([F:ASU]FONCTION = 1)
      SUBPRO_TYPE = "Subprog"
    Else
      SUBPRO_TYPE = "Funprog"
    Endif
    
    # Read text
    TEXT = func GETTEXT("ASU", PROGRAM + "_" + SUBPRO)
        
    # Concat method informations
    FIELDS = PROGRAM + "." + SUBPRO + GXDT_VALUE_SEP
&          + NAME + GXDT_VALUE_SEP
&          + SUBPRO_TYPE + GXDT_VALUE_SEP
&          + num$([F:ASU]TYPFCT) + GXDT_VALUE_SEP
&          + mess([F:ASU]TYPFCT, 33, 1) + GXDT_VALUE_SEP
&          + [F:ASU]CODACT + GXDT_VALUE_SEP
&          + num$([F:ASU]MODULE) + GXDT_VALUE_SEP
&          + mess([F:ASU]MODULE, 14, 1) + GXDT_VALUE_SEP
&          + num$([F:ASU]TYPASU) + GXDT_VALUE_SEP
&          + mess([F:ASU]TYPASU, 7849, 1) + GXDT_VALUE_SEP
&          + TEXT + GXDT_VALUE_SEP

    FIELDS += "" + GXDT_VALUE_SEP # deprecated
    FIELDS += "" + GXDT_VALUE_SEP # see
    FIELDS += "" + GXDT_VALUE_SEP # since
    FIELDS += "" + GXDT_VALUE_SEP # return

    # Concat method parameters informations
    Local Integer ASUBPROGDOK : ASUBPROGDOK = func ISASUBPROGDOK() 
    If ASUBPROGDOK > 0

      #------------------------------------------------------------------------------------    
      # New method (params in a different table, ASUBPROGD)
      #------------------------------------------------------------------------------------    
      If clalev([F:ASP])=0 : Local File ASUBPROGD [ASP] : Endif

      For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
        Call TEXTE([F:ASP]INTITPAR, NAME) From OBJDIV
        FIELDS += [F:ASP]PARAM + GXDT_VALUE_SEP
&              + NAME + GXDT_VALUE_SEP
&              + num$([F:ASP]TYPPAR) + GXDT_VALUE_SEP
&              + mess([F:ASP]TYPPAR, 33, 1) + GXDT_VALUE_SEP
&              + num$([F:ASP]DIME) + GXDT_VALUE_SEP
&              + num$([F:ASP]ADRVAL) + GXDT_VALUE_SEP
&              + mess([F:ASP]ADRVAL, 34, 1) + GXDT_VALUE_SEP
      Next ASP
      Close Local File [F:ASP] 
      #------------------------------------------------------------------------------------
      
    Else
    
      #------------------------------------------------------------------------------------    
      # Old method (params in ASUBPROG table)
      #------------------------------------------------------------------------------------    
      MAXPARAMIDX = [F:ASU]NBRPAR - 1
      For I = 0 To MAXPARAMIDX Step 1
        Call TEXTE([F:ASU]INTITPAR(I), NAME) From OBJDIV
        FIELDS += [F:ASU]PARAM(I) + GXDT_VALUE_SEP
&              + NAME + GXDT_VALUE_SEP
&              + num$([F:ASU]TYPPAR(I)) + GXDT_VALUE_SEP
&              + mess([F:ASU]TYPPAR(I), 33, 1) + GXDT_VALUE_SEP
&              + num$([F:ASU]DIME(I)) + GXDT_VALUE_SEP
&              + num$([F:ASU]ADRVAL(I)) + GXDT_VALUE_SEP
&              + mess([F:ASU]ADRVAL(I), 34, 1) + GXDT_VALUE_SEP
      Next I
      #------------------------------------------------------------------------------------
          
    Endif

    FIELDS += GXDT_NL_SEP

Endif
Close Local File [F:ASU]
End FIELDS

#**
#* Set text documentation (ASUBPROG)
#* @param PROGRAM
#* @param SUBPRO
#* @param TEXT
#*!
Subprog SETMETHODINFOTEXT(PROGRAM, SUBPRO, TEXT, MODUL, ACTIVITY)
Value Char    PROGRAM()
Value Char    SUBPRO()
Value Clbfile TEXT()
Value Integer MODUL
Value Char    ACTIVITY()

Local Char TIT
Call SETTEXT("ASU", PROGRAM + "_" + SUBPRO, TEXT, TIT, MODUL, ACTIVITY)
End


#**
#* Set method info (ASUBPROG)
#* @param PROGRAM
#* @param SUBPRO
#* @param RECORD infos (concateneted with separator)
#* @param TEXT explaination
#*!
Funprog SET_METHOD_INFO(PROGRAM, SUBPRO, RECORD, TEXT)
Value Char  PROGRAM()
Value Char  SUBPRO()
Value Clbfile RECORD()
Value Clbfile TEXT()

Local Char RETOUR(250)

Local Integer INTIT_NUMBER
Local Integer I
Local Integer PARAM_IDX, PARAM_NBR
Local Integer NBSPLIT
Local Integer MAXPARAMIDX
Local Integer NBSPLITMAX : NBSPLITMAX = 265
Local Integer WFSTAT
Local Char    TABSPLIT(255)(NBSPLITMAX+1)

Local Char SYMBOLE

If clalev([F:ASU])=0 : Local File ASUBPROG  [ASU] : Endif

SYMBOLE="ASU"+SUBPRO+"\"+PROGRAM
Lock =SYMBOLE With lockwait=0
If [S]fstat = 1     # locked record
    RETOUR = "0" + GXDT_NL_SEP + PROGRAM + "." + SUBPRO + " : " + mess(60,100,1)
Else
  Trbegin [ASU]
  Readlock [F:ASU]ASU0 = PROGRAM;SUBPRO
  WFSTAT = [S]fstat
  If WFSTAT <> 1 
    NBSPLIT = func SPLIT_LOB(RECORD, GXDT_VALUE_SEP, TABSPLIT)
    
    Call SETMETHODINFOTEXT(PROGRAM, SUBPRO, TEXT, val(TABSPLIT(2)), TABSPLIT(1))
        
    Call NUMERO(TABSPLIT(0), INTIT_NUMBER) From OBJDIV
    [F:ASU]INTIT = INTIT_NUMBER
    [F:ASU]CODACT = TABSPLIT(1)
    [F:ASU]MODULE = val(TABSPLIT(2))
    [F:ASU]TYPASU = val(TABSPLIT(3))
    [F:ASU]FONCTION = val(TABSPLIT(4))
    [F:ASU]TYPFCT = val(TABSPLIT(5))
        
    # Parameters informations
    PARAM_IDX = 6 # number of occurences
    PARAM_NBR = 5 # number of elements by occurence
    MAXPARAMIDX = ( NBSPLIT - PARAM_IDX ) / PARAM_NBR

    Local Integer ASUBPROGDOK : ASUBPROGDOK = func ISASUBPROGDOK() 
    If ASUBPROGDOK > 0
      #------------------------------------------------------------------------------------    
      # New method (params in a different table, ASUBPROGD)
      #------------------------------------------------------------------------------------
      If clalev([F:ASP])=0 : Local File ASUBPROGD [ASP] : Endif
    
      Delete [ASP] Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
      If fstat
       Rollback : RETOUR = "0" + GXDT_NL_SEP + "" + PROGRAM + "." + SUBPRO
       Close Local File [F:ASU],[F:ASP]
       End RETOUR    
      Endif
  
      [F:ASU]NBRPAR = MAXPARAMIDX
  
      If WFSTAT <> 0
        [F:ASU]PRG = PROGRAM
        [F:ASU]SUBPRG = SUBPRO
        Write [F:ASU]
      Else
        Rewrite [F:ASU]
      Endif
  
      # write parameters in ASUBPROGD
      If fstat = 0
        For I = 0 To MAXPARAMIDX - 1 Step 1 
          [F:ASP]PRG = [F:ASU]PRG 
          [F:ASP]SUBPRG = [F:ASU]SUBPRG
          [F:ASP]LIGNE = I 
          [F:ASP]PARAM = TABSPLIT(I * PARAM_NBR + PARAM_IDX + 0)
          Call NUMERO(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 1), INTIT_NUMBER) From OBJDIV
          [F:ASP]INTITPAR = INTIT_NUMBER
          [F:ASP]TYPPAR = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 2)) 
          [F:ASP]DIME = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 3))
          [F:ASP]ADRVAL = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 4))
          Write [F:ASP]
        Next I
      Endif
      Close Local File [F:ASU],[F:ASP]
      #------------------------------------------------------------------------------------    
    
    Else
    
      #------------------------------------------------------------------------------------    
      # Old method (params in ASUBPROG table)
      #------------------------------------------------------------------------------------    
      [F:ASU]NBRPAR = MAXPARAMIDX
      For I = 0 To MAXPARAMIDX - 1 Step 1
        [F:ASU]PARAM(I) = TABSPLIT(I * PARAM_NBR + PARAM_IDX + 0)
        Call NUMERO(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 1), INTIT_NUMBER) From OBJDIV
        [F:ASU]INTITPAR(I) = INTIT_NUMBER
        [F:ASU]TYPPAR(I) = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 2)) 
        [F:ASU]DIME(I) = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 3))
        [F:ASU]ADRVAL(I) = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 4))
      Next I
  
      If WFSTAT <> 0
        [F:ASU]PRG = PROGRAM
        [F:ASU]SUBPRG = SUBPRO
        Write [F:ASU]
      Else
        Rewrite [F:ASU]
      Endif
      #------------------------------------------------------------------------------------    
    
    Endif    
    Commit
    Unlock =SYMBOLE
    RETOUR = "1"
  Else      # locked record
    Rollback
    RETOUR = "0" + GXDT_NL_SEP + "" + PROGRAM + "." + SUBPRO + " : " + mess(60,100,1)
  Endif
Endif  

Close Local File [F:ASU]

End RETOUR

Funprog GETTEXT(TYP, COD)
Value Char    TYP()
Value Char    COD()

If clalev([F:ADO])=0 : Local File ADOCUMENT  [ADO] : Endif
If clalev([F:ADH])=0 : Local File ADOCCLB    [ADH] : Endif

Local Integer OK
Local Clbfile TEXT(6) : TEXT = ""
Call LECTURE_DOC(TYP, COD, TEXT, OK) From SUBADO

#Close Local File [F:ADO]
#Close Local File [F:ADH]
        
End TEXT


Subprog SETTEXT(TYP,COD,TEX,TIT,MODU,ACT)
Value Char TYP , COD
Value Clbfile TEX
Value Char TIT
Value Integer MODU
Value Char ACT

If clalev([F:ADO])=0 : Local File ADOCUMENT  [ADO] : Endif
If clalev([F:ADH])=0 : Local File ADOCCLB    [ADH] : Endif

Call ECRIRE_DOC(TYP,COD,TEX,TIT,MODU,ACT) From SUBADO

#Close Local File [F:ADO]
#Close Local File [F:ADH]
        
End

#**
#* Return folder info (displayed in About dialog) 
#* @param FLDER folder
#* @return info values
#*!
Funprog GET_PROJECT_INFO(FLDER)
Value Char FLDER

Local Char VERSION, RELEASE, NOPATCH
Local Char PROCESS_SVR(255)
Local Char RESULT(255)

Call VERSX3(FLDER, VERSION, RELEASE, NOPATCH) From INTRUTILA

# Process server
PROCESS_SVR = ""
Local Char CHAINE
Local Integer I
CHAINE = ver$(0)
I = instr(1,CHAINE," ")
If I
 CHAINE = right$(ver$(0),I+1)
 I = instr(1, CHAINE," ")
 PROCESS_SVR = left$(CHAINE,I)
Endif

RESULT = "VER" + GXDT_VALUE_SEP + VERSION + GXDT_NL_SEP + 
&        "REL" + GXDT_VALUE_SEP + RELEASE + GXDT_NL_SEP +
&        "PCH" + GXDT_VALUE_SEP + NOPATCH + GXDT_NL_SEP +
&        "PROSVR" + GXDT_VALUE_SEP + vireblc(PROCESS_SVR,1) + GXDT_NL_SEP + 
&        "SOL" + GXDT_VALUE_SEP + GINSTID + GXDT_NL_SEP +
&        "SOLVER" + GXDT_VALUE_SEP + GVERSOL + GXDT_NL_SEP +
&        "SOLADR" + GXDT_VALUE_SEP + "http://"+GVIRTDIR+"/" + GXDT_NL_SEP 

End RESULT


#**
#* Return filtered sessions list 
#*!
Funprog GET_SESSIONS(FILTERS)
  Value Char FILTERS()
  
  Local Clbfile SESSIONS(6)
  SESSIONS = ""

  Local Char ID(250) 
  Local Char PORT(250)
  Local Char CLI(250)
  Local Char TYP(25)
  Local Char PROC(250)
  Local Char PROCID(250)
  Local Char USER(250)
  Local Char ADDR(250)
  Local Char FLDR(250)
  
  Local Char    WFUNCTION(250)
  Local Integer WMODULE
  Local Char    WLOGIN(250)

  Local Integer PORT_NUM

  Local Integer POS
  Local Char COMMAND(250)
  [L]COMMAND = "psadx -axptgf"
  If FILTERS = ""
    Local File (SID, SPORT, SCLI, SADDR, SFLDR, SUSER, STYP, SPROC) From System adxmac(0)+"@" + [L]COMMAND + " " As [SYS_]
  Else
    Local File (SID, SPORT, SCLI, SADDR, SFLDR, SUSER, STYP, SPROC) From System adxmac(0)+"@" + [L]COMMAND + " " As [SYS_] Where evalue(FILTERS)
  Endif
  Onerrgo GET_SESS_ERR
  For [SYS_]
    If [F:SYS_]SID <> "Id" and left$([F:SYS_]SID,1) <> "-" 
      If [F:SYS_]SPORT <> "" : [L]PORT = [F:SYS_]SPORT : Endif
      If [F:SYS_]SCLI <> "" : [L]CLI = [F:SYS_]SCLI : Endif
      If [F:SYS_]STYP <> "" : [L]TYP = [F:SYS_]STYP : Endif
      If [F:SYS_]SADDR <> "" : [L]ADDR = [F:SYS_]SADDR : Endif
      If [F:SYS_]SFLDR <> "" : [L]FLDR = [F:SYS_]SFLDR : Endif
      If [F:SYS_]SPROC = "" 
        [L]PROC = [F:SYS_]SID
      Else
        [L]PROC = [F:SYS_]SPROC
      Endif
      If [F:SYS_]SUSER <> "" : [L]USER = [F:SYS_]SUSER : Endif
    
      POS = instr(0, [L]PORT, ":")
      If POS > 1
        [L]PORT = left$([L]PORT, POS - 1)
      Endif
      PORT_NUM = val([L]PORT)
      If PORT_NUM > 0

        POS = instr(0, [F:SYS_]SID, ":")
        If POS > 1
          [L]ID = left$([L]ID, POS - 1)
        Else
          [L]ID = [F:SYS_]SID
        Endif

        POS = instr(0, [L]PROC, ":")
        If POS > 1
          [L]PROCID = left$([L]PROC, POS - 1)
          [L]PROC = right$([L]PROC, POS + 1)
        Endif
        
        [L]WFUNCTION = ""
        [L]WMODULE = -1
        [L]WLOGIN = ""
        Call GET_CURFCT("", [L]FLDR, [F:SYS_]SID, [L]WFUNCTION, [L]WMODULE, [L]WLOGIN) From PSADX
  
        SESSIONS += [L]ID + GXDT_VALUE_SEP+ "" + GXDT_VALUE_SEP  
        SESSIONS += [L]PROCID + GXDT_VALUE_SEP
        SESSIONS += [L]TYP + GXDT_VALUE_SEP
        SESSIONS += [L]CLI + GXDT_VALUE_SEP
        SESSIONS += [L]PORT + GXDT_VALUE_SEP
        SESSIONS += [L]USER + GXDT_VALUE_SEP
        SESSIONS += [L]PROC + GXDT_VALUE_SEP
        SESSIONS += [L]ADDR + GXDT_VALUE_SEP
        SESSIONS += [L]FLDR + GXDT_VALUE_SEP
        SESSIONS += [L]WFUNCTION + GXDT_NL_SEP
        
      Endif
    Endif
  Next SYS_
  Onerrgo
  Close Local File [SYS_]
  
End SESSIONS

$GET_SESS_ERR
Resume

#**
#* Attach to process
#* 
#* @param ID proccess id to attach 
#*!
Funprog ATTACH_PROCESS(HOST, PORT, ID)
Value Char HOST()
Value Char PORT()
Value Char ID()

  If func IS_TRACE_ON()
    Call TRACE(".ATTACH_PROCESS: host=" + HOST + ", port=" + PORT + ", id=" + ID)
  Endif

  Local Integer STAT 
  Local Char RES
  Local Char METHODNAME(250)
  [L]METHODNAME = [S]adxdpg + ".ATTACH_PROCESS"
  
  [L]STAT = func =METHODNAME With (HOST, PORT, ID)
  
  If func IS_TRACE_ON()
    Call TRACE(".ATTACH_PROCESS: call " + [L]METHODNAME + ", return " + num$([L]STAT))
  Endif

  If [L]STAT = 0
    [L]RES = "1"
  Else
    [L]RES = "0" + GXDT_NL_SEP + errmes$([L]STAT)
  Endif
  
End RES


Funprog INIT_ENV(TRACEON)
  Value Libelle TRACEON
  
  Local Char RES(1)
  RES = func INIT_VARIABLES()
  
  If TRACEON
    Call TRACE_CLEAR()
    Call TRACE(".INIT_ENV: traceon=" + num$(TRACEON) + ", dim(GXDT_TRACE)=" + num$(dim(GXDT_TRACE)))  
  Endif
  
  GXDT_TRACE = TRACEON
End ""

#**
#* Initialize global variables
#*!
Funprog INIT_VARIABLES()

  If dim(GXDT_TRACE) < 0
    Global Libelle GXDT_TRACE
  Endif

  If dim(GXDT_NL_SEP) < 0
    Global Char GXDT_NL_SEP(4)
    GXDT_NL_SEP = "#NL#"
  Endif

  If dim(GXDT_VALUE_SEP) < 0
    Global Char GXDT_VALUE_SEP(4)
    GXDT_VALUE_SEP = "#SP#"
  Endif

End ""

Funprog IS_TRACE_ON()
  If dim(GXDT_TRACE) < 0
    End 0
  Endif
End GXDT_TRACE

Subprog TRACE(DBGT_LINE)
  Value Char DBGT_LINE()
  
  Onerrgo ERR_TRACE
  Openo filpath("TRA","XDT_" + ctrans(toupper(adxusr),".\/|*@","______"),"tra",0), -1 Using [XTR_]
  Wrseq date$ + "-" + time$ + ": " + DBGT_LINE Using [XTR_]

  Openo Using [XTR_]
  Onerrgo
End

Subprog TRACE_CLEAR
  Onerrgo ERR_TRACE
  Openo filpath("TRA","XDT_" + ctrans(toupper(adxusr),".\/|*@","______"),"tra",0), 0 Using [XTR_]
  Openo Using [XTR_]
  Onerrgo
End

$ERR_TRACE
Resume

$TEST
