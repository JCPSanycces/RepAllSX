#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTISTO27   Update SCHGH for LPN Opérations                             #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap

Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS

If DOSSIER <> ""

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("SCHGH update") From LECFIC

  Call MAJ_UTISTO27(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC

Endif

End
##########################################################################
##########################################################################
Subprog MAJ_UTISTO27(DOSSIER)
Value Char     DOSSIER

Local Integer GOK

GOK = 1

# If we have stock module
If [F:ADS]MODULE(6)<>2 : End : Endif

Call ECR_TRACE("UTISTO27: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Open tables -----#
If filinfo(filpath("FIL","SCHGH", "fde",DOSSIER),0) < 0 : End : Endif

If clalev([F:SGH]) = 0 : Local File =DOSSIER+".SCHGH"   [SGH] : Endif


#validation TCTR object after update selection
Call ECR_TRACE("UTISTO27: valid LPNOPE object",0) From GESECRAN
Call MAJ_SEL(DOSSIER,"LPNOPE") From PATCHAOB
Call VALID("LPNOPE",DOSSIER,1,GOK) From VALOBJ
If GOK = 0 : Gosub TRT_END : Endif

If adxlog = 0
  Trbegin [SGH]
Endif
#Update SCHGH columns
Call ECR_TRACE("UTISTO27: update SCHGH : MODOPELPN",0) From GESECRAN
For [F:SGH] Where [F:SGH]MODOPELPN = 0 and [F:SGH]TRSTYP=36
  [F:SGH]MODOPELPN = 1
  Rewrite [F:SGH]
  If fstat
    Call ECR_TRACE("UTISTO27: error update SCHGH : fstat="+num$(fstat)+" num:"+[F:SGH]VCRNUM,0) From GESECRAN
    GOK = 0
    Break
  Endif
Next

Gosub TRT_END


Call ECR_TRACE("UTISTO27: end update SCHGH",0) From GESECRAN


Call ECR_TRACE("UTISTO27: Process End",0) From GESECRAN

End

$TRT_END
If GOK = 0
  Rollback
  Return
Else
  Commit
Endif

Return
########################################################################
# For execution upon patch integration                                 #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UTISTO27(APPLI)

End
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
#---
If filinfo(filpath("FIL","SCHGH","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"SCHGH") : End : Endif                  : # For Archive folder
#---
Call MAJ_UTISTO27(APPLI)
End

