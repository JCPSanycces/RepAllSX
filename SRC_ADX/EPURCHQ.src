#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

########################################################################################################
##                                                                                                     #
## Historisation / Epuration pièces comptables  V6    -   Module AP-AR                                 #
##                                                                                                     #
########################################################################################################
#   - CHQNUM    : Historisation / Epuration des factures client                                        #
########################################################################################################
# HISTO = 1 => Historisation
#
#              Les données passent d'APPLI vers HISAPL
#              Les données historisées sont supprimées d'APPLI  
#              Uniquement des contrôles liés au dossier APPLI
#
#
# EPUR  = 1 => Epuration
#
#    Soit Epuration seule (EPUR=1 et HISTO=0) 
#         Les données sont supprimées d'APPLI
#         Uniquement des contrôles liés au dossier APPLI.
#
#    Soit Epuration suite à l'historisation (EPUR=1 et HISTO=1) 
#                    L'historisation a fait les vérifications nécessaires (cf HISTO=1)
#                    L'épuration concerne donc le dossier HISAPL mais aucun contrôle sur ce dossier.
#
########################################################################################################

$ACTION

Case ACTION
  When "OUVRE"   
            Case [F:AHI]COD
                When "CHQ"    : Gosub OUVRE_CHQNUM
            Endcase


   When "HISTO"
            Case [F:AHI]COD
                 When "CHQ"   : Gosub HISTO_CHQNUM
            Endcase

  When "EPURE"
            Case [F:AHI]COD
                 When "CHQ"   : Gosub EPURE_CHQNUM
            Endcase

  When "FERME"
            Case [F:AHI]COD
                 When "CHQ"   : Gosub FERME_CHQNUM
            Endcase

Endcase
Return




#######################################################################################
# Historation / Epuration des règlements                                              #
# Formule d'épuration :   [F1]STA<>1  and PAYNUM<>"" and PAYMENTH Not found           #
#######################################################################################

$OUVRE_CHQNUM
If clalev([F:F1])=0  : Local File =[L]APPLI+".CHQNUM"   [F1]  : Endif
If clalev([F:PYH])=0 : Local File =[L]APPLI+".PAYMENTH" [PYH] : Endif
Return



$HISTO_CHQNUM
Case TABLE
   When "CHQNUM"  
          If  [F:F1]STA<>3
              Look [F:PYH]PYH0=[F:F1]PAYNUM    
              If  !fstat : Raz [L]OKHIS : Endif
          Else
              If [F:F1]CLODAT>date$-[F:AHI]TIM1 : Raz [L]OKHIS : Endif
          Endif
Endcase

Return

$EPURE_CHQNUM
Case TABLE
   When "CHQNUM" 
          If  [F:F1]STA<>3
              Look [F:PYH]PYH0=[F:F1]PAYNUM    
              If  !fstat : Raz [L]OKEPU : Endif
          Else
              If [F:F1]CLODAT>date$-[F:AHI]TIM2 : Raz [L]OKEPU : Endif
          Endif
Endcase

Return

$FERME_CHQNUM
If clalev([F:F1])   Close Local File [F1]  : Endif
If clalev([F:PYH])  Close Local File [PYH] : Endif

Return



