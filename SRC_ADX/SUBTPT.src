######################################################################################
## Etiquette ajoutée par le superviseur (écran TPT1) 17/02/2009 09:50:12 (MAE)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#MAE, positionnement de GCURLEG

GCURLEG = VALEUR
End

######################################################################################
Subprog C_PAM(VALEUR)
Variable Char    VALEUR()

  # FGR 22/03/2012 : X3SUIVI71937
  If VALEUR <> "" Then
    If [M:TPT1]LEG = "" and [F:TAM]LEG <> "" Then
      # Le mode de règlement ne doit pas être rattaché à une législation
      GMESSAGE = mess(589,199,1)
      mkstat = 1
      End
    Elsif [M:TPT1]LEG <> "" and [F:TAM]LEG <> "" and [F:TAM]LEG <> [M:TPT1]LEG Then
      # La légistlation du mode de règlement doit être vide ou égale à
      GMESSAGE = mess(590,199,1) - ":" - [M:TPT1]LEG
      mkstat = 1
      End
    Endif
  Endif
End

####################################################################################
# Subprog SELTPT2 : Controle condition de paiement depuis tiers                   ##
####################################################################################
Subprog SELTPT2(AZC,LEG,SOC)
Variable Char    AZC()
Value    Char    LEG
Value    Char    SOC


Local Char PARMSK(30)(1..10)
If clalev([F:TPT])=0 : Local File TABPAYTERM [TPT] : Endif
PARMSK(1) = [L]LEG
If GNBLEG=1 : PARMSK(1) = GDOSLEG : Endif
PARMSK(2)=SOC
Call S_TAB_CHAR(AZC,PARMSK,"SELTPT2","SELTPT","") From GACTION

End

####################################################################################
# Subprog CONTTPT2 : Controle conditions de paiement depuis tiers                 ##
####################################################################################
Subprog CONTTPT2(AZC,LEG,SOC)
Value Char       AZC()
Value Char       LEG()
Value Char       SOC()

If AZC = "" : End : Endif

Local Char WLEG
If clalev([F:TPT])=0 : Local File TABPAYTERM [TPT] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY    [AGC] : Endif : #- Groupes de sociétés

#-- On recoit la société , on lit avec la LEG de la société ----#
Call GETLEG(SOC,"",WLEG) From TRTLECLEG

Read [TPT]TPT0=AZC;WLEG
If fstat
 Gosub TIT From WOTPT
 GMESSAGE = TIT-":"-[L]AZC
 GMESSAGE -=  "&" - mess(218,107,1) -"'"+[L]WLEG+ "'"
 GMESSAGE -= ":"- mess(23,100,1)                                 : #-- conditions de paiement & législation xxx :Fiche inexistante
 mkstat = 2 : End
Endif


#-- Cas ou la condition de paiement a un groupe --#
If SOC <> '' & [F:TPT]GFY<>''
 #-- test pour voir si un groupe existe pour la société de la ligne tiers/société lue  ----#
 Local Integer WGRP
 WGRP=1
 Filter [F:AGC] Where [F:AGC]CPY=[L]SOC & [F:AGC]GRP=[F:TPT]GFY
 For  [AGC]
  WGRP=2
  Break
 Next
 Filter [F:AGC]
 #-- Si la conditon de paiement lue a un groupe ne correspondant pas à la société --> rejet----#
 If WGRP<>2
   Gosub TIT From WOTPT
   GMESSAGE = TIT-":"-[L]AZC
   GMESSAGE +=  '\' + mess(129,104,1)-[F:TPT]GFY      : #-- Societe non incluse dans le groupe
   mkstat = 2 : End
 Endif
Endif

#-- Cas ou la condition de paiement n'a pas de groupe --#
If SOC <> '' & [F:TPT]GFY=''
 Local Integer WGRP
 Local Char    WGROUPE
 WGRP=0
 Filter [F:AGC] Where [F:AGC]CPY=[L]SOC
 For  [AGC]
  WGRP+=1
  If WGRP=1 : WGROUPE=[F:AGC]GRP : Endif
 Next
 Filter [F:AGC]
 #-- Si la conditon de paiement lue n'a pas de groupe alors que la la societe apparetient a un groupe ayant plusieurs sociétés ---#
 #-- (En création de SOC, le groupe associé est créé) --#
 If WGRP>1
   Gosub TIT From WOTPT
   GMESSAGE = TIT-":"-[L]AZC
   GMESSAGE +=  '\' + mess(137,127,1)- WGROUPE      : #-- Societe incluse dans le groupe
   mkstat = 2 : End
 Endif
Endif

End
###################################################################################################
##--CPO 71937 Contrôle global de cohérence avant enregistrement
$CONTROLE_COHERENCE

#Local Integer WSTAT
#Local Char    WMESSA(250)
#Local Char  WCODE(250)
#Local Char    WLEG
#Local Char    WCTX_CPY
#Local Char    WCTX_FCY
#Local Char    WCTX_LEG
#
#WCODE=[M:TPT1]PTE
#WLEG =[M:TPT1]LEG
#
#Call CTL_ML_CONSISTENCY("TPT", "NON", WCODE, WLEG , WCTX_CPY, WCTX_FCY, WCTX_LEG, WSTAT, WMESSA) From TRTVENCTL
#If WSTAT>0 or WMESSA<>""
#  GMESSAGE = WMESSA : GOK=0 : GERR=1 #--Si on ne veux pas bloquer..GERR=2
#Endif

Return
#--------------------------------------------------------------------------------------------------
$CHECK_CONSISTENCY

Local Integer WRET
Local Integer I
Local Char WPTE(GLONPTE)

If clalev([F:TPT])=0 : Local File TABPAYTERM [TPT] : Endif

#--Vérification de la compatibilité des sous-données déclinées elles aussi

#--  P_CODE<>"" and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

#--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
If P_LEG<>"" and PACTUAL_LEG<>"" and P_LEG<>PACTUAL_LEG
  VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-PACTUAL_LEG :# "Législations différentes"
  Return
Endif

#--Cohérence [TPT] et paramètres
If GFONCTION<>"GESTPT"
  Call CONTTPT(P_CODE,  PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTPT
  If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif
#--CPO 96248 Lors du ttt de cette fiche => il ne faut plus appeler le sous-contrôles car appelés lors du CONT principal
#Endif
Else
  WPTE=[F:TPT]PTE
  #--Cohérence de chaque mode de réglement
  For [TPT] Where PTE=WPTE and LEG=PACTUAL_LEG

    #--Cohérence [TPT]EECSCH et paramètres
    Call CONTTAM([TPT]PAM, PACTUAL_LEG, PACTUAL_FCY) From SUBTAM
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Break : Endif

  Next
Endif

Return
#--------------------------------------------------------------------------------------------------
$FIND_CONTEXT

Local Integer I,IJ
Local Integer RET,I
Local Integer CAS
Local Char LEGS(GLONADI)(1..)
Local Integer COHERENCE_OK

#--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
If P_LEG<>"" and [F:TPT]LEG<>"" and P_LEG<>[F:TPT]LEG
  VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-[F:TPT]LEG :# "Législations différentes"
  Return
Endif

Local Instance GROUPES Using C_GRPCOLL

If clalev([F:TPT])=0  : Local File TABPAYTERM [TPT]  : Endif
If clalev([F:TAM])=0  : Local File TABPAM     [TAM]  : Endif

#--On connait la détermination
#--On cherche un contexte compatible
#--Si pas de contexte compatible, alors la donnée multi-lég est mal paramétrée

#-- P_CODE<>"" and (PACTUAL_CPY="" and PACTUAL_FCY=""and PACTUAL_LEG="")

#--Lecture du [F]
#--Seulement si besoin
#--De plus si on est dans GESTPT il ne faut pas relire car
#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
#--Si Modification => idem
If GFONCTION<>"GESTPT" and ( [F:TPT]PTE<>P_CODE | find([F:TPT]LEG,P_LEG,"")=0 )
  If P_LEG<>""
    Read [TPT]TPT0=P_CODE;P_LEG;1
    If fstat
      Read [TPT]TPT0=P_CODE;"";1
    Else
      CAS = 2 : # Legislation isn't empty
    Endif
  Else
    Read [TPT]TPT2(1)=P_CODE
    If !fstat
      P_LEG = [F:TPT]LEG
      CAS = 2
    Endif
  Endif
  If fstat
    Filter [TPT] Where PTE=P_CODE
    Look [TPT]TPT0 First
    If !fstat
      # Fiche inexistante pour la législation courante
      GMESSAGE = P_CODE-":"-mess(232,107,1)-"["+P_LEG+"]"
    Else
      # Fiche inexistante
      GMESSAGE = P_CODE-":"-mess(23,100,1)
    Endif
    Filter [TPT]
    mkstat = 2 : End
  Endif
Endif

P_LEG=[F:TPT]LEG
LEGS(1)=P_LEG

If P_LEG=""
  #--Le code retenu est toutes législations
  #--Il faut d'abord trouver une législation commune
  #--Puis pour cette législation, il faut déterminer une société commune aux groupes, sinon on renvoye ""
  I = 2
  #--Législation(s) de chaque mode de réglement
  For [TPT] Where PTE=P_CODE and LEG=P_LEG #and PTELIN=1

    If [F:TPT]PAM<>""

      For [TAM] Where PAM=[F:TPT]PAM
        If [F:TAM]LEG<>"" and find([F:TAM]LEG,LEGS)=0
          LEGS(I) = [F:TAM]LEG
          I += 1
        Endif
      Next

    Endif

  Next
Endif


For I=1 To maxtab(LEGS)

  GROUPES = NewInstance [GRPTPT] With C_GRPCOLL

  RET= fmet GROUPES.GROUPADD([F:TPT]GFY)

  #--Cohérence de chaque mode de réglement
  For [TPT] Where PTE=P_CODE and LEG=P_LEG

    #--Le code retenu contient une législation en particulier
    #--Cette législation sera renvoyée
    #--Reste à déterminer une société commune aux groupes, sinon on renvoye ""

    #--On commence par lire les sous-données déclinées

    #--Lecture du Régime
    If [F:TPT]PAM<>""
      Call LEC_TAM_LEG(LEGS(I),[F:TPT]PAM,RET) From TRTLECLEG
      If RET
        #--On passe à la lég suivante
        Goto NEXT_LEGS1
      Endif
    Else
      Raz [F:TAM] :#--On continue pour les autres et on ne tient pas compte de ce dernier
    Endif

    #--Il reste à trouver une société commune aux différents groupes
    #--La société doit être de la législation retenue

    RET= fmet GROUPES.GROUPADD([F:TAM]GFY)

    $NEXT_LEGS2
  Next

  If maxtab(GROUPES.L_FCY)>0

    For IJ = 1 To maxtab(GROUPES.L_FCY)

      If GROUPES.L_FCY(IJ)<>null and find(GROUPES.L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        If LEGS(I)="" | GROUPES.L_FCY(IJ).FCYCPYLEG = LEGS(I)

        PACTUAL_FCY = GROUPES.L_FCY(IJ).FCY
        PACTUAL_CPY = GROUPES.L_FCY(IJ).FCYCPY
        PACTUAL_LEG = GROUPES.L_FCY(IJ).FCYCPYLEG

        FreeInstance =GROUPES.AllocGrp

        COHERENCE_OK = 1
        Break 2

        Endif
      Endif

    Next IJ

  Else
    #--On a trouvé une lég, et il n'y a pas de groupes
    #--C'est bon...
    #--Les lectures ont abouti
    #--On peut renvoyer le legs(i) comme législation du contexte
    PACTUAL_LEG = LEGS(I)
    COHERENCE_OK = 1

    FreeInstance =GROUPES.AllocGrp

    Break

  Endif

  $NEXT_LEGS1
  #--On libère proprement...
  FreeInstance =GROUPES.AllocGrp

Next I

#--On positionne le VSTATUS si rien trouvé
If COHERENCE_OK <>1
  VMESSAGE = mess(799,197,1)
  VSTATUS  = 1 : Return
Endif

Return
#--------------------------------------------------------------------------------------------------
$FIND_CODE

If clalev([F:TPT]) =0 : Local File TABPAYTERM [TPT]  : Endif
If clalev([F:TPTW])=0 : Local File TABPAYTERM [TPTW] : Endif

#--On connait le contexte
#--On cherche une détermination compatible

#--  P_CODE=""  and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

#--Filtre sur la législation ou "toutes législations"
Filter [F:TPTW] Where find(LEG,"",PACTUAL_LEG)>0
&  Order By Key WCLE=PTE Asc;LEG Desc;PTELIN Asc

For [F:TPTW]WCLE(2)

  Raz VSTATUS : Raz VMESSAGE

  #--Cohérence [TPT] et paramètres
  Call CONTTPT([F:TPTW]PTE,PACTUAL_LEG,"","", PACTUAL_FCY,"",PACTUAL_CPY) From SUBTPT
  If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif

  #--CPO 96248 Lors du ttt de cette fiche => il ne faut plus appeler le sous-contrôles car appelés lors du CONT principal
  #  If VSTATUS=0
  #    For [F:TPTW]WCLE
  #
  #      #--Cohérence [TPT]EECSCH et paramètres
  #      Call CONTTAM([TPTW]PAM,PACTUAL_LEG, PACTUAL_FCY) From SUBTAM
  #      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Break : Endif
  #
  #    Next
  #  Endif

  If VSTATUS=0
    #--Le code trouvé est cohérent avec le contexte
    P_CODE=[F:TPT]PTE
    P_LEG =[F:TPT]LEG
    Break
  Endif

Next

Filter [F:TPTW]

If VSTATUS>0 | P_CODE=""
  VMESSAGE = mess(798,197,1)-":"-mess(218,107,1)-PACTUAL_LEG+","-mess(2,45,1)-PACTUAL_CPY
Endif

Return

