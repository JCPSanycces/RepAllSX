Subprog AM_PAM(VALEUR)
Variable Char    VALEUR()

  # FGR 24/07/2013 : X3SUIVI87923
  If dim([M:TPT1]TAMSDDFLG) >= 0 Then
    [M:TPT1]TAMSDDFLG(nolign-1) = [F:TAM]SDDFLG
    If [M:TPT1]TAMSDDFLG(nolign-1) = G_YES Then
      [M:TPT1]SDDFLG = G_YES
    Endif
    Affzo [M:TPT1]TAMSDDFLG(nolign-1)
    Affzo [M:TPT1]SDDFLG
  Endif
End


Subprog C_DUDPRC(VALEUR)
Variable Decimal  VALEUR
# controle du total de la répartition
# !! à la 2eme valeur erronnée la variable [M]... contient encore la 1ere
If (sum([M]DUDPRC(0..[M]BASTAB-1)) - [M]DUDPRC(nolign-1) + VALEUR) > 100 & nolign > 1
   GMESSAGE = mess(4,199,1)
   mkstat = 2
Endif
If VALEUR > 100 : mkstat = 1 : Endif
End

Subprog D_DUDPRC(VALEUR)
Variable Decimal  VALEUR
# initialiser le taux par le complément à 100
If nolign > 1
   VALEUR = 100 - sum([M]DUDPRC(0..[M]BASTAB - 1))
Endif
End

Subprog D_VATPRC(VALEUR)
Variable Decimal VALEUR

# Initialiser le % de tva par le % echeance
VALEUR = [M]DUDPRC(nolign-1)
If nolign > 1
#  Si la somme des % de tva devient supérieure à 100 on initialise avec le complément
   If (sum([M]VATPRC(0..[M]BASTAB-1)) - [M]VATPRC(nolign-1) + VALEUR) > 100
       VALEUR = 100 - sum([M]VATPRC(0..[M]BASTAB - 1))
   Endif
Endif
End

Subprog C_VATPRC(VALEUR)
Variable Decimal VALEUR
End


