#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################
# SUBTPT : Condition de paiement                                       #
########################################################################
################################################################################
# Subprog SIMULECHE(CODECHE,DEPECHE,MONT,ARODEV,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,NECHE,CODSUBS,SITE)
################################################################################
# Subprog DATECHE(PTE,DEPART,MNT,ARODEV,PAM,TYP,MNTECH,DATECH,RELEVE,NBECH,SITE)
# calcul d'échéances avec répartition de montant
################################################################################
# Subprog DATECHE_TVA(CODECHE,DEPECHE,MONT,TVA,ARODEV,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,NECHE,SITE)
################################################################################
 GBIDC1 = "TPT"
 GBIDC2 = "0"
 GBIDC3 = ""
 Call OBJET(GBIDC1,GBIDC2, GBIDC3) From GOBJET
End

$ACTION
  Case ACTION
     When "OUVRE"     : Gosub OUVRE
     When "SETBOUT"   : Gosub SETBOUT
     When "INICRE"    : Gosub INICRE
     When "INIMOD"    : Gosub INICRE
     When "LIENS"     : Gosub LIENS
     When "VERIF_CRE" : Gosub VERIF_CRE
     When "VERIF_MOD" : Gosub VERIF_CRE
     When "RAZCRE"    : Gosub RAZCRE
     When "AFFMASK"   : Gosub AFFMASK    #MAE, bg52848
     When "VERF_ANU"  : Gosub VERF_ANU
     When "ANNULE"    : Gosub ANNULE
     When "FERME"     : Gosub FERME #MAE, bg 52550

    #-- X3Suivi 71937-------- : Données par législation pour le Condition de paiement----#
     When "SEL_TABLE" : Case TABLE :      When "SELTPT"    : Gosub SELTPT :    Endcase

    When "CHGCOD"    : Gosub CHGCOD
    # FGR 22/04/2013 : X3SUIVI71937 (début)
    When "READ_CHGCOD" : Gosub READ_CHGCOD
    When "CHANGE"      : Call CHANGE_AXX ("TABPAYTERM", [L]OCODE, [L]SUPP(0), [L]NCODE, [L]SUPP(0)) From TRTX3TEX
    # FGR 22/04/2013 : X3SUIVI71937 (fin)

    When Default
  Endcase
Return

#################################################################################
$READ_CHGCOD
  # FGR 22/04/2013 : X3SUIVI71937 : changement de clé sur PK > 2 éléments
  IREADDEF = 1
  Read [F:TPT]TPT0(2)=
Return

#################################################################################
$CHGCOD
  # X3Suivi 71937
  Call CHGCOD(ABREV, CLECUR1, CLECUR2, OK) From CHGCLELEG
Return

#####################################################################
$OUVRE
Local Decimal WMNTORG(0..1)
Local Decimal WMNTDES(0..1)
Local Integer SPSTAT
#Local  Char    SAV_GCURLEG(GLONADI)  : SAV_GCURLEG=GCURLEG        #MAE, bg 52550

  If clalev([F:TAMX])=0  : Local File TABPAM [TAMX]  : Endif  # FGR 24/07/2013 : X3SUIVI87923
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB

#---- Chargement de GCUR
Call CHARGE_GCUR() From TRTX3
Return

#####################################################################
$SETBOUT
  If CLECUR = 0 | GREP <> "" :# au lieu de CLECUR1 = ""
    Call VIREBOUT(CHAINE,"12") From GOBJET
  Endif
  If GREP = "" Then
    # Note FGR : obligé de l'ajouter à la main. comme il y a plus de deux
    #            éléments dans la clé, le superviseur ne le mets pas tout seul
    CHAINE += "A"
    # FGR 23/04/2013 : X3SUIVI71937 : obligé de le réactivé à la main parce que 3 éléments de PK
    CHAINE += "H"
  Endif
Return

######################################################################
$AFFMASK
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG
Return

######################################################################
$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [TPT1]LEG
  [M:TPT1]LEG=GDOSLEG(1)
  Affzo [TPT1]LEG : If dim([M:TPT1]ZLEG)>0  Affzo [TPT1]ZLEG : Endif
Endif
Return

######################################################################
$INICRE

# Réalimentation des mnts saisis en dev soc dans [M] pour stockage en dev dossier dans [F]
WMNTORG(0) = [M:TPT1]DUDMINAMT(nolign-1)
WMNTORG(1) = [M:TPT1]PTEMINAMT
Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
If SPSTAT = 0
   [F:TPT]DUDMINAMT = WMNTDES(0)
   [F:TPT]PTEMINAMT = WMNTDES(1)
Endif
[F]DAYMON(0) = [M:TPT1]J1(nolign-1)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]
[F]DAYMON(1) = [M:TPT1]J2(nolign-1)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]
[F]DAYMON(2) = [M:TPT1]J3(nolign-1)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]
[F]DAYMON(3) = [M:TPT1]J4(nolign-1)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]
[F]DAYMON(4) = [M:TPT1]J5(nolign-1)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]
[F]DAYMON(5) = [M:TPT1]J6(nolign-1)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]

#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:TPT1]DESAXX,"TABPAYTERM","DESAXX",[M:TPT1]PTE,[M:TPT1]LEG) From ATEXTRA
Call MAJTEXTRA ([M:TPT1]SHOAXX,"TABPAYTERM","SHOAXX",[M:TPT1]PTE,[M:TPT1]LEG) From ATEXTRA

#    SOS libellés
If dim([F:TPT]LANDESSHO)>0
   [F:TPT]LANDESSHO=GLANGUE+"~"+[M:TPT1]DESAXX+"~"+[M:TPT1]SHOAXX
Endif

  # FGR 24/07/2013 : X3SUIVI87923 (début)
  If dim([M:TPT1]SDDFLG) >= 0 Then
    [F]SDDFLG = [M:TPT1]SDDFLG
  Endif
  # FGR 24/07/2013 : X3SUIVI87923 (fin)

#--CPO 71937 Contrôle global de cohérence avant enregistrement
#Gosub CONTROLE_COHERENCE

Return

######################################################################################
#-- X3SUIVI 71937 : Données par législation pour le Condition de paiement
######################################################################################
Subprog CONTTPT (COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY )
Value    Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local Integer WNBTOT, WI, WNO_ERR,  WENROK
Local Char    WLEG  (GLONADI), WMESS1 (120), WMESS2 (120), WMESS3 (120)
Local Integer CAS
Local Char    OPTIONS(30)

If GFONCTION = "GESTPT" | COD="" : End : Endif

#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif :#--CPO 71937
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif :#--CPO 71937
If clalev([F:TPT])=0  : Local File TABPAYTERM [TPT] : Endif
If clalev([F:AMZZ])= 0 : Local File AMSKZON   [AMZZ] : Endif :#--for the selection options of the object

If func AFNC.ACTIV("LEG")=0
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
  LEG = GCURLEG
Endif

CAS = 1 : # Legislation is empty

#-------------------------------------------------------------------#
#--CPO 71937
#--Cas particulier : pas de GCURLEG mais société ou site en ligne
#-------------------------------------------------------------------#
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
  If [L]FCY<>""
    If [F:FCY]FCY<>[L]FCY
      Read [F:FCY]FCY0=[L]FCY
      If fstat : Raz [F:FCY] Endif
    Endif
    If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
  Endif

  If [L]CPY<>""
    If [F:CPY]CPY<>[L]CPY
      Read [F:CPY]CPY0=[L]CPY
      If fstat : Raz [F:CPY] Endif
    Endif
    [L]LEG=[F:CPY]LEG
  Endif
Endif
#--/CPO

If LEG<>""
  Read [TPT]TPT0=COD;LEG;1
  If fstat
    Read [TPT]TPT0=COD;"";1
  Else
    CAS = 2 : # Legislation isn't empty
  Endif
Else
  Read [TPT]TPT0(1)=COD
  If !fstat
    LEG = [F:TPT]LEG
    CAS = 2
  Endif
Endif
If fstat
  Filter [TPT] Where PTE=[L]COD
  Look [TPT]TPT0 First
  If !fstat
    # Fiche inexistante pour la législation courante
    GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
  Else
    # Fiche inexistante
    GMESSAGE = [L]COD-":"-mess(23,100,1)
  Endif
  Filter [TPT]
  mkstat = 2 : End
Endif

#----------------------------------------------------------------------------------------------------------------------#
#--Filtrage par groupe de société3

#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GFY de TABPAYTERM, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#----------------------------------------------------------------------------------------------------------------------#
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TPT]GFY<>""
  #--CPO 71937
  If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
  Read [AGF]AGF0=[F:TPT]GFY
  If !fstat
    If [F:AGF]FLGLEG=2
      #--Société
      If [F:TPT]GFY<>[L]CPY
        GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TPT]GFY : # Réservé au groupe de société
        mkstat = 2 : End
      Endif
    Elsif [F:AGF]FLGCPY=2
      #--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TPT]GFY;[L]CPY
        If fstat
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TPT]GFY : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

#--Contrôle de cohérence entre le groupe  et la législation
If [F:TPT]GFY<>"" and LEG<>""
  Call CTLGFYLEG([F:TPT]GFY,LEG,"","") From TRTVENCTL
  If mkstat : End : Endif
Endif

#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If GROUPE<>"" and [F:TPT]LEG<>""
  Call CTLGFYLEG(GROUPE,[F:TPT]LEG,"","") From TRTVENCTL
  If mkstat : End : Endif
Endif

#--Contrôle de la cohérence entre le groupe passé en param et celui courant
#--uniquement si pas de contexte site ou société !
#--Il faut que le groupe  et celui du paramétrage aient au moins une soc en commun
If GROUPE<>""
  If CPY="" & FCY="" & [F:TPT]GFY<>"" & [F:TPT]GFY<>GROUPE
    #--Les groupes doivent avoir au moins une société en commun
    Gosub CTLGFYGRP
    If mkstat : End : Endif
  Endif
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
  Call CONTROLE("TPT",OPTIONS,LEG,COD,mkstat) From CONTOBJ
 Else
  Call CONTROLE("TPT",OPTIONS,"",COD,mkstat) From CONTOBJ
Endif

#--CPO 96248 Contrôle global de cohérence
#--Cohérence [TPT]PAM et paramètres en entrée
If mkstat > 0 : End : Endif

If clalev([F:TPTCTL])=0 : Local File TABPAYTERM [TPTCTL] : Endif
If clalev([F:TAM])=0    : Local File TABPAM [TAM]        : Endif

Filter [F:TPTCTL] Where PTE=[F:TPT]PTE and LEG=[F:TPT]LEG
For [F:TPTCTL]
  If [F:TPTCTL]PAM<>""

    Call CONTTAM([F:TPTCTL]PAM,[F:TPT]LEG, [L]FCY) From SUBTAM
    If mkstat
    If [F:TPT]LEG=""
    GMESSAGE = [L]COD-":"-GMESSAGE
    Else
    GMESSAGE = [L]COD-"["+[F:TPT]LEG+"]"-":"-GMESSAGE
    Endif
    Break
    Endif
  Endif
Next
Filter [F:TPTCTL]
#--/

End

###############################
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TPT]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTPTZGRP"
    Local File =SZVIEW [TPTZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TPTZ]TPTZ0 = [L]GROUPE;[F:TPT]PTE;[F:TPT]GFY;[F:TPT]LEG
  If fstat
    GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TPT]GFY-":"-mess(178,187,1)
    mkstat=1
    Return
  Endif
Else
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTPTYGRP"
    Local File =SZVIEW [TPTY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    #-- Si problème, pas de contrôle
    Return
  Endif

  Read [F:TPTY]TPTY0 = [L]GROUPE;[F:TPT]PTE;[F:TPT]GFY;[F:TPT]LEG #--CPO 96238 Clé TPTY0 et non pas TPTZ0
  If fstat
   GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TPT]GFY-":"-mess(178,187,1)
   mkstat=1
   Return
  Endif
Endif
Return

######################################################################################
#-- X3SUIVI 71937 : Données par législation pour le Condition de paiement
######################################################################################
## Tunnel Condition de paiement
######################################################################################
Subprog TUNTPT(COD,LEG)
Variable Char    COD()
Value    Char    LEG()

Global Char VCOD(GLONPTE)
Local Char  VLEG(GLONADI)
# To update the TPT code after the tunnel order
VCOD = COD
VLEG = LEG
If clalev([F:TPT])=0 : Local File TABPAYTERM [TPT] : Endif
If func AFNC.ACTIV("LEG")=0 : VLEG = GDOSLEG : Endif

Read [TPT]TPT0 = VCOD;VLEG;1
If fstat : VLEG = "" : Endif
Call OBJET("TPT",VLEG,VCOD) From GOBJET
COD = VCOD
Kill VCOD
End

####################################################################################################
## $SELTPT : X3SUIVI 71937 : Données par législation pour le Condition de paiement                ##
##       --> Si [L]LEG<>""                           --> Utilisation de la vue LEGTPTSEL  (TPTS)  ##
##       --> Si [L]LEG=""                            --> Utilisation de la vue LEGTPTPAR  (TPTP)  ##
##       --> Si [L]LEG=<>"" OU (LEG="" & GROUPE<>'') --> Utilisation de la vue LEGTPTGRP  (TPTG)  ##
##   FACGROUP --> Table de lien Groupe et site                                                    ##
##   AGRPCPY  --> Table de lien Groupe et société                                                 ##
####################################################################################################
$SELTPT

If clalev([F:TPT])=0 : Local File TABPAYTERM  [TPT] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

If clalev([F:AGF])=0  : Local File AGRPFCY   [AGF]  : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON  [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection

Local Char    FCY(GLONFCY), CPY(GLONCPY), LEG(GLONADI),   GRP(GLONAGC)
Local Integer WNOL, ERR
Local Integer ERR
Local Char    AUTRE_CRIT(250)
Local Char    SZVIEW(GLONAVW)

If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif #--CPO 71937 Pour déterminer les options de sélection
Local Char CODMSK   (GLONAMK)  #--CPO 71937 Pour déterminer les options de sélection
Local Char CHAMPCOD (GLONAVA)  #--CPO 71937 Pour déterminer les options de sélection

AUTRE_CRIT = '1=1'

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
LEG      = PARAM(1)
FCY      = PARAM(2)
GRP      = PARAM(3)
CPY      = PARAM(4)
CODMSK   = PARAM(5)
CHAMPCOD = PARAM(6)

Local Char GFY

GFY = GRP
#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
Endif
#--/CPO

#-- Initialisation de législation
If func AFNC.ACTIV("LEG")=0
 [L]LEG = GDOSLEG
Endif

If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

#jde
If [L]LEG="" & GFONCTION <> "GESTPT" :  [L]LEG = GCURLEG : Endif

#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------

Gosub OUVRE_LISTE From WOTPT
For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I)  = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL   = NBSEL
SIZCOL  = 240
SIZLIG  = 100
TIT(0)  = mess(12,123,1)  # Choix
Call TITOBJ("TPT","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START   = "[F:TPT]PTE"
ORDRE   = "[F:TPT]PTE;[F:TPT]LEG;[F:TPT]PTELIN"
OBJET   = ""
#--------------------------------------------------------------------------------------------------
## Standard selection criteria
#--------------------------------------------------------------------------------------------------
ICRITERE = 0
ICRITERE += 1
#CRITERE(ICRITERE) = '1=1'
CRITERE(ICRITERE) = '[F:TPT]PTELIN=1'
#--Groupe de soc/sites
If FCY="" & CPY="" & GFY<>""
 Read [F:AGF]AGF0=[L]GFY
 If !fstat
 If [F:AGF]FLGLEG=2 : [L]CPY=[L]GFY : Endif
Endif
Endif
#--Facility
If    [L]FCY<>""
  CRITERE(ICRITERE) -= '& ([F:TPT]GFY="" | ([F:TPT]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
#--Company
Elsif [L]CPY<>""
  CRITERE(ICRITERE) -= '& ([F:TPT]GFY="" | ([F:TPT]GFY<>"" & [F:TPTC]LEGCPY="'+[L]CPY+'"))'
Endif
#--Legislation
ICRITERE += 1
If LEG<>""
  CRITERE(ICRITERE) -= '& ([F:TPT]LEG="'+[L]LEG+'" | [F:TPT]LEG="")'
Endif
#--First selection character

If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(ICRITERE) -= '& left$([F:TPT]PTE,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

CRITERE(ICRITERE) -= '&'-[L]AUTRE_CRIT

ICRITERE += 1

#MGG X3-38593 Row level permission
#Call FILROLE(OBJET,FILROLE) From SUBARL
Call FILROLE("TPT",FILROLE) From SUBARL
#END MGG X3-38593 Row level permission

If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
#--Views calls
#--------------------------------------------------------------------------------------------------
If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
If [L]LEG<>""
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTPTYGRP"
      Local File =SZVIEW [TPTY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TPT"
      Return
    Endif
Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTPTZGRP"
      Local File =SZVIEW [TPTZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TPT"
      Return
    Endif
Endif
Endif
If 1=1
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTPTCPY"
    Local File =SZVIEW [TPTC]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, on se déroute sur le select standard
    OBJET = "TPT"
    Return
  Endif
  If [L]LEG<>""
    #--View throughout GCURLEG
    #--------------------------------------------------------------------------------------------------
    ## Appel à la vue
    #--------------------------------------------------------------------------------------------------
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTPTSEL"
      Local File =SZVIEW [TPTS]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TPT"
      Return
    Endif
    If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
  Link [TPT] With [F:AXX]AXX0    = "TABPAYTERM";"DESAXX";GLANGUE;[F:TPT]PTE;[F:TPT]LEG,
&                 [F:TPTY]TPTY0 ~= [L]GRP;[F:TPT]PTE;[F:TPT]GFY;[F:TPT]LEG,
&                 [F:TPTS]TPT0  ~= [F:TPT]PTE;[F:TPT]LEG;[L]LEG
&              As [LTPT]
Else
    Link [TPT] With [F:AXX]AXX0   = "TABPAYTERM";"DESAXX";GLANGUE;[F:TPT]PTE;[F:TPT]LEG,
&                [F:FGR]FGR1    = [L]FCY;[F:TPT]GFY,
&                [F:TPTC]TPT0   = [F:TPT]PTE;[F:TPT]LEG;[F:TPT]GFY;[L]CPY,
&                [F:TPTS]TPT0  ~= [F:TPT]PTE;[F:TPT]LEG;[L]LEG
&     As [LTPT]
Endif
  Else
   #--View without legislation
   ERR = 0
   Repeat
     # -----------------------------------------------------------------------------------------------
     # ERR=0  : Pas d'erreur, on sort
     # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
     # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
     # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
     # -----------------------------------------------------------------------------------------------
     Onerrgo ERRVUE
     SZVIEW = "LEGTPTPAR"
     Local File =SZVIEW [TPTP]
     Onerrgo
   Until ERR <> -1
   If ERR Then
    # Si problème, on se déroute sur le select standard
     OBJET = "TPT"
     Return
   Endif
   If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
  Link [TPT] With [F:AXX]AXX0    = "TABPAYTERM";"DESAXX";GLANGUE;[F:TPT]PTE;[F:TPT]LEG,
&                 [F:TPTZ]TPTZ0 ~= [L]GRP;[F:TPT]PTE;[F:TPT]GFY;[F:TPT]LEG
&              As [LTPT]
 Else
   Link [TPT] With [F:AXX]AXX0    = "TABPAYTERM";"DESAXX";GLANGUE;[F:TPT]PTE;[F:TPT]LEG,
&                [F:FGR]FGR1    = [L]FCY;[F:TPT]GFY,
&                 [F:TPTC]TPT0   = [F:TPT]PTE;[F:TPT]LEG;[F:TPT]GFY;[L]CPY,
&                 [F:TPTP]TPT0  ~= [F:TPT]PTE;[F:TPT]LEG
&      As [LTPT]
Endif
  Endif
Endif

# Options de sélection
If OPTIONS<>""
  Gosub OPTIONS From WOTPT
  ICRITERE=2
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
Endif

Default File [LTPT]
DEFPAG = 1

Return

################################
#$ERRVUE
#ERR = errn
#Resume

################################
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume


#####################################################################
$LIENS

# Alimentation des mnts stockés en dev dossier dans [F] pour saisie en dev soc dans [M]
WMNTORG(0) = [F:TPT]DUDMINAMT
WMNTORG(1) = [F:TPT]PTEMINAMT
Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
If SPSTAT = 0
   [M:TPT1]DUDMINAMT(nolign-1) = WMNTDES(0)
   [M:TPT1]PTEMINAMT = WMNTDES(1)
Endif

[M:TPT1]J1(nolign-1) = [F]DAYMON(0)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]
[M:TPT1]J2(nolign-1) = [F]DAYMON(1)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]
[M:TPT1]J3(nolign-1) = [F]DAYMON(2)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]
[M:TPT1]J4(nolign-1) = [F]DAYMON(3)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]
[M:TPT1]J5(nolign-1) = [F]DAYMON(4)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]
[M:TPT1]J6(nolign-1) = [F]DAYMON(5)  # FGR 07/10/2014 : X3SUIVI102337 : Manquait [M:TPT1]

[M:TPT1]AFFCUR    = GCUR
[M:TPT1]AFFCURDUD(nolign-1) = GCUR

GCURLEG = [F:TPT]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
GGRPFCY = [F:TPT]GFY

  # FGR 24/07/2013 : X3SUIVI87923 (début)
  If dim([M:TPT1]TAMSDDFLG) >= 0 Then
    Read [TAMX]TAM0=[F:TPT]PAM;[F:TPT]LEG
    [M:TPT1]TAMSDDFLG(nolign-1) = [F:TAMX]SDDFLG
  Endif
  # FGR 24/07/2013 : X3SUIVI87923 (fin)
Return

#####################################################################
$VERIF_CRE
Local Integer NI

If sum([M]DUDPRC(0..[M]BASTAB-1)) < 100
   GERR=1 : GMESSAGE=mess(5,199,1)
Elsif sum([M]DUDPRC(0..[M]BASTAB-1)) > 100
   GERR=1 : GMESSAGE=mess(4,199,1)
Endif
If GTPTTVA
 If sum([M]VATPRC(0..[M]BASTAB-1)) < 100
   GERR=1 : GMESSAGE=mess(335,199,1)
 Elsif sum([M]VATPRC(0..[M]BASTAB-1)) > 100
   GERR=1 : GMESSAGE=mess(334,199,1)
 Endif
Endif

  # FGR 24/07/2013 : X3SUIVI87923 (début)
  If dim([M:TPT1]SDDFLG) >= 0 Then
    [M:TPT1]SDDFLG = G_NO
    For NI = 0 To [M]BASTAB-1
      If [M:TPT1]TAMSDDFLG(NI) = G_YES Then
        [M:TPT1]SDDFLG = G_YES
        Break
      Endif
    Next NI
    Affzo [M:TPT1]SDDFLG
  Endif
  # FGR 24/07/2013 : X3SUIVI87923 (fin)

Gosub CTRL_PAM

# SAM 110033: Swiss localization: do additional checks
If func AFNC.ACTIV("KSW") Then
  Gosub VERIF_CRE From SUBTPTSWI
Endif
# SAM 110033 END
Return

##############################################################
# $CTRL_PAM : controle de tous les modes de reglement
##############################################################
$CTRL_PAM
  For NI = 0 To [M]BASTAB-1
    #Chgstl [M]PAM(NI) With ""
  Next NI
  #If GREP = "D" Then
    # En duplication on redéclenche un contrôle ligne à ligne.
    For NI = 0 To [M]BASTAB-1
      #Chgstl [M]PAM(NI) With ""
      Call C_PAM([M]PAM(NI)) From W1TPT1
      If mkstat Then
        #Chgstl [M]PAM(NI) With "AWARN"
        OK = 0
        Break
      Endif
    Next NI
  #Endif

Return

#####################################################################
$RAZCRE
Gosub GRILEG
[M:TPT1]AFFCUR = GCUR
Return
#####################################################################
$VERF_ANU


#Vérification dans les clients et les fournisseurs que le code n'est pas utilisé
If clalev([F:BPC])=0 : Local File = "BPCUSTOMER" [BPC] : Endif
If clalev([F:BPS])=0 : Local File = "BPSUPPLIER" [BPS] : Endif

Local Char MESSA(250)
OK=1
For [BPC] Where PTE=[F:TPT]PTE & BPCSTA=1
   OK = 0 : MESSA = mess(78,117,1)-[F:BPC]BPCNUM : Break : # Fonction
Next
If OK
 For [BPS] Where PTE=[F:TPT]PTE & ENAFLG = 2
    OK = 0 : MESSA = mess(17,7,1)-[F:BPS]BPSNUM : Break : # Objet
 Next
Endif
If !OK
 Call ERREURT(mess(1,115,1)+"\"+mess(49,139,1)-MESSA,1) From GESECRAN
 # Suppression impossible/Clé utilisée dans
Endif

Return

#####################################################################
$ANNULE
#Delete [AXX]Where CODFIC="TABPAYTERM" & IDENT1=[F:TPT]PTE
Delete [AXX]Where CODFIC="TABPAYTERM" & IDENT1=[F:TPT]PTE & IDENT2=[F:TPT]LEG
Return

#####################################################################
$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONPTE) : Endif

VCOD = CLE2
Return



######################################################################
$CHANGE
#--CPO 71937 - Déclinaison par législation
Call CHANGE_AXX ("TABPAYTERM", [L]SUPP(0), [L]OCODE, [L]SUPP(0), [L]NCODE ) From TRTX3TEX
## transformer les enregistrements ATEXTRA rattachés : bug 23386 (27/07/04)
#Update [AXX] Where CODFIC="TABPAYTERM" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
