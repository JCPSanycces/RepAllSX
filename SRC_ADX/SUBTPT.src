#Endif
#--/CPO
Return

#####################################################################
Subprog SIMULECHE(CODECHE,DEPECHE,MONT,ARODEV,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,NECHE,CODSUBS,SITE)
Value    Char     CODECHE()        : # Code règlement
Value    Date     DEPECHE          : # Départ échéance
Value    Decimal  MONT             : # Montant
Value    Decimal  ARODEV           : # Arrondi saupoudrage
Variable Char     MODECHE()(1..)   : # Mode règlement / échéance
Variable Integer  TYPECHE  (1..)   : # Type règlement / échéance
Variable Decimal  MNTECHE(1..)     : # Montant        / échéance
Variable Date     DATECHE(1..)     : # Date           / échéance
Variable Integer  RELEVE(1..)      : # =2 si relevé à faire
Variable Shortint NECHE            : # Nb échéance
Variable Char     CODSUBS()        : # Code règlt substitution
Value    Char     SITE             : # pour jours d'indisponibilité
Local Decimal TVA : TVA = 0
Goto ECHEANCE
End  # FGR 09/02/2010 : X3SUIVI60986

#####################################################################
Subprog DATECHE(CODECHE,DEPECHE,MONT,ARODEV,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,NECHE,SITE)
Variable Char     CODECHE()        : # Code règlement
Value    Date     DEPECHE          : # Départ échéance
Value    Decimal  MONT             : # Montant
Value    Decimal  ARODEV           : # Arrondi saupoudrage
Variable Char     MODECHE()(1..)   : # Mode règlement / échéance
Variable Integer  TYPECHE  (1..)   : # Type règlement / échéance
Variable Decimal  MNTECHE(1..)     : # Montant        / échéance
Variable Date     DATECHE(1..)     : # Date           / échéance
Variable Integer  RELEVE(1..)      : # =2 si relevé à faire
Variable Shortint NECHE            : # Nb échéance
Value    Char     SITE             : # pour jours d'indisponibilité
Local    Char     CODSUBS(15)
Local Decimal TVA : TVA = 0
Goto ECHEANCE
End  # FGR 09/02/2010 : X3SUIVI60986

#####################################################################
Subprog DATECHE_TVA(CODECHE,DEPECHE,MONT,TVA,ARODEV,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,NECHE,SITE,DATECOURS)
Variable Char     CODECHE()        : # Code règlement
Value    Date     DEPECHE          : # Départ échéance
Value    Decimal  MONT             : # Montant HT
Value    Decimal  TVA              : # Montant TVA
Value    Decimal  ARODEV           : # Arrondi saupoudrage
Variable Char     MODECHE()(1..)   : # Mode règlement / échéance
Variable Integer  TYPECHE  (1..)   : # Type règlement / échéance
Variable Decimal  MNTECHE(1..)     : # Montant        / échéance
Variable Date     DATECHE(1..)     : # Date           / échéance
Variable Integer  RELEVE(1..)      : # =2 si relevé à faire
Variable Shortint NECHE            : # Nb échéance
Value    Char     SITE             : # pour jours d'indisponibilité
#MAE, bg 73547, ajout du paramétre date du cours
Variable Date     DATECOURS        : #date du cours pour la conversion
Local    Char     CODSUBS(15)
If !GTPTTVA
 MONT += TVA
 TVA   = 0
Endif
Goto ECHEANCE

##############################################################
## $ECHEANCE
##############################################################
$ECHEANCE
Onerrgo ERREUR From CONTROLE

If clalev([F:TPT])=0    : Local File TABPAYTERM [TPT] : Endif
If clalev([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:TUV]) <= 0 : Local File TABUNAVAIL [TUV] : Endif
# aura-t-on un parametre concernant les modes de pmt sur relevé ?
# Local File ADOENT [ADO]
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Local Integer JSEM(1..7) , JFER
Local Integer QT , I , QUANT
Local Date DAT , DAT1
Local Char CODE(15)
Local Decimal MNT1 , MNT2 , WMNT
Local Decimal RESTE, SOMPRC
Local Integer STAT, DATMOD :# indicateur modif de date calculée
Local Integer PTELIN(1..30)  #MAE, bg68870
Local Integer MOIS #MAE, bg72791
Local Integer NBDAYFEB, DYEAR #MAE, bg 79838


Raz NECHE,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,RESTE,SOMPRC,PTELIN


CODE=CODECHE

#Gbn-24092012-Ajout LEG dans la lecture
If dim(GCURLEG)>0 & GCURLEG<>""
 Read [TPT]TPT0(2) = CODE;GCURLEG
 If fstat=5
  Read [TPT]TPT0(2) = CODE;""
 Endif
Else
 Read [TPT]TPT0(1) = CODE
Endif

Raz WMNT
If fstat=0 & [F:TPT]PTEMINAMT<>0
  #MAE, BG 73547
 If dim(DATECOURS)>0
    If DATECOURS=[0/0/0]
      Call CONVERT(GSYSCUR,[F:TCU]CUR,GLOCALDEV,0,datesyst,[F:TPT]PTEMINAMT,WMNT,STAT) From TRTDEV
    Else
      Call CONVERT(GSYSCUR,[F:TCU]CUR,GLOCALDEV,0,DATECOURS,[F:TPT]PTEMINAMT,WMNT,STAT) From TRTDEV
    Endif
 Else
    Call CONVERT(GSYSCUR,[F:TCU]CUR,GLOCALDEV,0,datesyst,[F:TPT]PTEMINAMT,WMNT,STAT) From TRTDEV
 Endif
Endif
Raz CODSUBS
While fstat=0 & [F:TPT]RPLPTE<>"" & MONT<WMNT
 CODE=[F:TPT]RPLPTE
 CODSUBS=CODE

 #Gbn-24092012-Ajout LEG dans la lecture
 If dim(GCURLEG)>0 & GCURLEG<>""
  Read [TPT]TPT0(2) = [F:TPT]RPLPTE;GCURLEG
  If fstat=5
   Read [TPT]TPT0(2) = [F:TPT]RPLPTE;""
  Endif
 Else
  Read [TPT]TPT0(1) = [F:TPT]RPLPTE
 Endif


 Raz WMNT
 If fstat=0 & [F:TPT]PTEMINAMT<>0
  #MAE, BG 73547
  If dim(DATECOURS)>0
    If DATECOURS=[0/0/0]
      Call CONVERT(GSYSCUR,[F:TCU]CUR,GLOCALDEV,0,datesyst,[F:TPT]PTEMINAMT,WMNT,STAT) From TRTDEV
    Else
      Call CONVERT(GSYSCUR,[F:TCU]CUR,GLOCALDEV,0,DATECOURS,[F:TPT]PTEMINAMT,WMNT,STAT) From TRTDEV
    Endif
   Else
     Call CONVERT(GSYSCUR,[F:TCU]CUR,GLOCALDEV,0,datesyst,[F:TPT]PTEMINAMT,WMNT,STAT) From TRTDEV
   Endif
 Endif
Wend
If fstat
 End
Endif

#Gbn-24092012-Ajout LEG dans la lecture
#For [TPT]TPT0 Where PTE=CODE & (LEG=GCURLEG | LEG="")

Local Integer WTPT_OK : #-- 0-pas traité , 1-encours 2-terminé
WTPT_OK=0

#Filter [TPT] Where PTE=CODE & (LEG=GCURLEG | LEG="") Order By Key MACLE=CODE Asc;PTELIN Asc ;LEG Desc

# FGR 24/10/2013 : X3SUIVI93841 : mauvais nom de colonne
#Filter [TPT] Where PTE=[L]CODE & LEG=GCURLEG  Order By Key MACLE=CODE Asc;PTELIN Asc ;LEG Desc
Filter [TPT] Where PTE=[L]CODE & LEG=GCURLEG  Order By Key MACLE=PTE Asc;PTELIN Asc ;LEG Desc
For [TPT]MACLE(2)
 Gosub TRT_TPT
 If WTPT_OK=2 : Break : Endif
Next
Filter [F:TPT] #Gbn-fin

If WTPT_OK=0
 # FGR 24/10/2013 : X3SUIVI93841 : mauvais nom de colonne
 #Filter [TPT] Where PTE=[L]CODE &  LEG="" Order By Key MACLE=CODE Asc;PTELIN Asc ;LEG Desc
 Filter [TPT] Where PTE=[L]CODE &  LEG="" Order By Key MACLE=PTE Asc;PTELIN Asc ;LEG Desc
 For [TPT]MACLE(2)
  Gosub TRT_TPT
  If WTPT_OK=2 : Break : Endif
 Next
 Filter [F:TPT] #Gbn-fin
Endif

# Pour le cas où il y aurait un pb de paramétrage
If sum(MNTECHE(1..NECHE))<>MONT+TVA
 MNTECHE(1) += MONT+TVA-sum(MNTECHE(1..NECHE))
Endif

If NECHE>0
# Sorta NECHE MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE Order By DATECHE(indice+1)   MAE, bg68870
 Sorta NECHE MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE Order By DATECHE(indice+1),PTELIN(indice+1)
 MNT1=0
 For I=1 To NECHE
  MNT2=MNTECHE(I)
  MNTECHE(I)=arr((MNT1+MNTECHE(I)),ARODEV)-arr(MNT1,ARODEV)
  MNT1 += MNT2
 Next I
 I=1
 While I<=NECHE & NECHE>1
  If MNTECHE(I)=0
   Dela I MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE
   NECHE-=1
  Else
   I+=1
  Endif
 Wend
Endif
CODECHE = CODE
End


###############################
##$TRT_TPT
###############################
$TRT_TPT

 WTPT_OK=1
 Raz WMNT
 WMNT=-((abs(MONT)+abs(TVA))*2)
 If [F:TPT]DUDMINAMT<>0
  #MAE, bg 73547
  If dim(DATECOURS)>0
    If DATECOURS=[0/0/0]
      Call CONVERT(GSYSCUR,[F:TCU]CUR,GLOCALDEV,0,datesyst,[F:TPT]DUDMINAMT,WMNT,STAT) From TRTDEV
    Else
      Call CONVERT(GSYSCUR,[F:TCU]CUR,GLOCALDEV,0,DATECOURS,[F:TPT]DUDMINAMT,WMNT,STAT) From TRTDEV
    Endif
  Else
    Call CONVERT(GSYSCUR,[F:TCU]CUR,GLOCALDEV,0,datesyst,[F:TPT]DUDMINAMT,WMNT,STAT) From TRTDEV
  Endif
 Endif
 DAT=DEPECHE
 NECHE+=1
 If NECHE=1
  For I=1 To 7
   JSEM(I)=[F:TPT]FBDDAYFLG(I-1)
  Next
  JFER=[F:TPT]FBDHLYFLG
 Endif

 If NECHE>dim(DATECHE)
  NECHE-=1
  WTPT_OK=2
  Return
  #Break
 Endif
# rajout du test du mnt minimum de l'echeance
 SOMPRC += [F:TPT]DUDPRC

# BY 28/12/2000
# On calcule séparément la TVA, ça ne change rien pour l'appel V120 où TVA=0

 MNT1 = (MONT * ([F:TPT]DUDPRC/100)) + (TVA * ([F:TPT]VATPRC/100)) + RESTE
 If MNT1 < WMNT & SOMPRC < 100
  RESTE = MNT1
 Else
  RESTE = 0
  MODECHE(NECHE) = [F:TPT]PAM
  TYPECHE(NECHE) = [F:TPT]PAMTYP
  MNTECHE(NECHE) = MNT1
  Gosub CALDATE
  DATECHE(NECHE) = DAT
  RELEVE(NECHE)  = [F:TPT]SOIFLG
  PTELIN(NECHE)  = [F:TPT]PTELIN    #MAE, bg68870
 Endif

Return

###############################
##$CALDATE
###############################
$CALDATE

# Fin de mois avant
If [F:TPT]ENDMONFLG=3 : DAT=eomonth(DAT) : Endif
# Ajout des mois et des jours
DAT=addmonth(DAT,[F:TPT]NBRMON)+[F:TPT]NBRDAY

# Fin de mois après
If [F:TPT]ENDMONFLG=2 : DAT=eomonth(DAT) : Endif

# 04/07/12 Payment days in customer function SAM #82280
Gosub CALDAYS From SUBTPT2


# Quantièmes
QUANT=day(DAT)
#MAE, bg72791, si mois de février et jour de paiement > 29, on passe au jour de paiement suivant
MOIS = month(DAT)
#MAE, bg79838
DYEAR = year(DAT)
#Si année bissextile, mois de février a 29 jours
 If ((int(DYEAR/4)=DYEAR/4) and (int(DYEAR/100)<>DYEAR/100))
&   or (int(DYEAR/400)=DYEAR/400) Then
    WNBDAYFEB = 29
 Else
   WNBDAYFEB = 28
 Endif
If [F:TPT]DAYMON(0)<>0
#MAE, bg 78905
  If MOIS <> 2
    If QUANT<=[F:TPT]DAYMON(0)  QT=[F:TPT]DAYMON(0) : Gosub QUANTIEME
    Elsif QUANT<=[F:TPT]DAYMON(1) QT=[F:TPT]DAYMON(1) : Gosub QUANTIEME
    Elsif QUANT<=[F:TPT]DAYMON(2) QT=[F:TPT]DAYMON(2) : Gosub QUANTIEME
    Elsif QUANT<=[F:TPT]DAYMON(3) QT=[F:TPT]DAYMON(3) : Gosub QUANTIEME
    Elsif QUANT<=[F:TPT]DAYMON(4) QT=[F:TPT]DAYMON(4) : Gosub QUANTIEME
    Elsif QUANT<=[F:TPT]DAYMON(5) QT=[F:TPT]DAYMON(5) : Gosub QUANTIEME
    Else  QT=[F:TPT]DAYMON(0) : Gosub QUANTIEME
    Endif
  Else
    #MAE, bg79838
    If (QUANT<=[F:TPT]DAYMON(0) & [F:TPT]DAYMON(0)<=WNBDAYFEB)|([F:TPT]DAYMON(0)=99)
       QT=[F:TPT]DAYMON(0) : Gosub QUANTIEME
    Elsif (QUANT<=[F:TPT]DAYMON(1)& [F:TPT]DAYMON(1)<=WNBDAYFEB)|([F:TPT]DAYMON(1)=99)
       QT=[F:TPT]DAYMON(1) : Gosub QUANTIEME
    Elsif (QUANT<=[F:TPT]DAYMON(2) & [F:TPT]DAYMON(2)<=WNBDAYFEB)|([F:TPT]DAYMON(2)=99)
       QT=[F:TPT]DAYMON(2) : Gosub QUANTIEME
    Elsif (QUANT<=[F:TPT]DAYMON(3) & [F:TPT]DAYMON(3)<=WNBDAYFEB)|([F:TPT]DAYMON(3)=99)
       QT=[F:TPT]DAYMON(3) : Gosub QUANTIEME
    Elsif (QUANT<=[F:TPT]DAYMON(4) & [F:TPT]DAYMON(4)<=WNBDAYFEB)|([F:TPT]DAYMON(4)=99)
       QT=[F:TPT]DAYMON(4) : Gosub QUANTIEME
    Elsif (QUANT<=[F:TPT]DAYMON(5) & [F:TPT]DAYMON(5)<=WNBDAYFEB)|([F:TPT]DAYMON(5)=99)
       QT=[F:TPT]DAYMON(5) : Gosub QUANTIEME
    Else  QT=[F:TPT]DAYMON(0) : Gosub QUANTIEME
    Endif
  Endif
Endif

# 04/07/12 Payment days in customer function SAM #82280
Gosub UNAVAILABLE From SUBTPT2

# Traitement des jours interdits       (Modif 03/09/99 Bug 3087 -- TB)
While JSEM(dayn(DAT))=2
 DAT += 1
Wend

$FERIES
If JFER = 2 :# exclusion des jours fériés
 If [F:FCY]FCY <> SITE
  Read [FCY]FCY0 = SITE
 Endif
 # point d'entrée (n'avait pas été reporté en 140) (TB 28/09/04)
 GPOINT = "FERIES" : Gosub ENTREE From EXEFNC
 # controle sur les 24 périodes d'indisponibilité
 DATMOD = 0
 If [F:FCY]UVYCOD <> ""
  Read [TUV]UVY0 = [F:FCY]UVYCOD
  For I=0 To [F:TUV]UVYNBR-1
    If DAT >= [F:TUV]UVYSTRDAT(I) & DAT <= [F:TUV]UVYENDDAT(I)
        DAT = [F:TUV]UVYENDDAT(I) + 1
        DATMOD = 1
    Endif
  Next I
 Endif
 If DATMOD = 1
    DATMOD = 0  : # retester les jours interdits !
    While JSEM(dayn(DAT))=2
        DAT += 1 : DATMOD = 1
    Wend
    If DATMOD = 1 Goto FERIES Endif
 Endif
Endif

# 08/05/13 Law of bad debt SAM #88427
Gosub MAXDAYPAY From SUBTPT2

# demande pour pouvoir forcer une date fixe  Dem 25275 (TB 28/09/04)
GPOINT = "DATCLC" : Gosub ENTREE From EXEFNC
Return

$QUANTIEME
# Le quantième 99 correspond à la fin de mois (mb 18.7.2 bug 15219)
If QT=99
 DAT = eomonth(DAT)
Elsif day(DAT)<=QT
  #MAE, bg 78905
  #si on veut le 29,30 ou 31 et qu'on est en février, on rajoute 1 mois
  If QT>28 & month(DAT)=2
    DAT=gdat$(QT,month(DAT)+1,year(DAT))
  Else
    DAT=gdat$(QT,month(DAT),year(DAT))
  Endif
Else
  #MAE, bg 78905
  #si on veut le 29,30 ou 31 et qu'on est en janvier, on rajoute 2 mois
  If QT>28 & month(DAT)=1
    DAT=gdat$(QT,month(DAT)+2,year(DAT))
  Else
    DAT=gdat$(QT,month(DAT)+1,year(DAT))
  Endif
Endif
Return


