If VALEUR = ""
 [M]PTEMINAMT = 0
Endif
End

Subprog C_PTE(VALEUR)
Variable Char     VALEUR
# Controle d'unicité
If GREP="C" | GREP="D"
 If VALEUR="" : mkstat=1 : End : Endif
 Look [TPT]TPT0 = VALEUR ; [M:TPT1]LEG;1
 If !fstat
  GMESSAGE = mess(22,100,1) : mkstat=2 : End
 Endif
Endif
End

Subprog AS_PTEMINAMT(VALEUR)
Variable Decimal VALEUR
If [M]RPLPTE="" : mkstat=2 : Endif
End

Subprog C_FBDDAYFLG(VALEUR)
Variable Integer VALEUR
Local Integer I, COK
COK=0
For I=0 To 6
 If I=indice
  If VALEUR=1 : COK=1 : Break : Endif
 Elsif [M]FBDDAYFLG(I)=1
  COK=1 : Break
 Endif
Next I
If !COK
 GMESSAGE=mess(64,187,1)   # Tous les jours sont exclus!
 mkstat=2
Endif
End

