###########################################################################
$TRTCOP
#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie d'une condition de paiement        #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
  Local File TABPAYTERM [TPT1]
  Local File ATEXTRA    [AXX1]
Else
  Local File =[M]DOSORG+".TABPAYTERM" [TPT1]
  Local File =[M]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [M]DOSDES=nomap
  Local File TABPAYTERM [TPT2]
  Local File ATEXTRA    [AXX2]
  Local File ACTIV      [ACV2]
Else
  Local File =[M]DOSDES+".TABPAYTERM" [TPT2]
  Local File =[M]DOSDES+".ATEXTRA"    [AXX2]
  Local File =[M]DOSDES+".ATABDIV"    [ADI2]
  Local File =[M]DOSDES+".ACTIV"      [ACV2]
  Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2] : #-- car ADOSSIER uniquement sur dossier mère --#
Endif
OK=1
#Look [TPT2]TPT0=TABLE
#If !fstat
#   OK= 2 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
#   If OK<>2  OK=0 : Endif
#Endif
If OK
  Gosub OUVDOS  From ATEXTRA
  Call DEBTRANS From GLOCK
  Gosub TRT_COPIE
Endif
Close Local File [TPT1], [AXX1], [TPT2], [AXX2]
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return

######################################################################################
# $TRT_COPIE
######################################################################################
$TRT_COPIE
#--------------------------------------------------#
# Transaction de copie d'une condition de paiement #
#--------------------------------------------------#
Local Char    LEGDES
Local Integer WMONOLEGDES
# Par défaut : Leg destination=leg de l'enregistrement à copier
LEGDES=TABLE2
GOK=1
#If TABLE2<>''
# If [M]DOSDES<>nomap
#  Local Char SZDOSSIER(GLONADS)
#  Local Integer LG
#  Read [ADI2]CODE=909; TABLE2
#  If fstat
#   Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
#   Return
#  Endif
#
#  LG = instr(1, [M]DOSDES, "@")
#  If LG = 0 Then
#    SZDOSSIER = [M]DOSDES
#  Else
#    SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
#  Endif
#  Read [ADS2]DOSSIER=SZDOSSIER
#    If !fstat Then
#      If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
#        Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
#        Return
#      Endif
#  Endif
#
# Endif
#Endif

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Pb lecture dossier
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Pas de législation pour le dossier
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
            Return
        Endif
        If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1) ) From GESECRAN
            Return
        Elsif TABLE2=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE2<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE2
          If fstat
           Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

#Read [TPT2]TPT0=TABLE ;TABLE2
Read [TPT2]TPT0(2)=TABLE;LEGDES
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

Trbegin [TPT2]
  #Delete [TPT2] Where PTE=TABLE & LEG=[M:TPT1]LEG
  Delete [TPT2] Where PTE=TABLE & LEG=LEGDES
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABPAYTERM"-TABLE : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("TPT2",TABLE) From GLOCK    : Goto AB_COPIE
  Endif
  #--- copie des textes traduits de l'en-tête
  #Gbn-Pb copie texte cf.mail CH.
  #Read [TPT1]TPT0 First
  #If !fstat
  If TABLE2=LEGDES
    Call COPTEXTRA("TABPAYTERM","DESAXX",TABLE,LEGDES) From ATEXTRA
    If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
    Call COPTEXTRA("TABPAYTERM","SHOAXX",TABLE,LEGDES) From ATEXTRA
    If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
  Else
    Call COPTEXTRA1("TABPAYTERM","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
    If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
    Call COPTEXTRA1("TABPAYTERM","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
    If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
  Endif
  #Endif
  #--- copie des lignes
  #For [TPT1]TPT0 Where PTE=TABLE & LEG=[M:TPT1]LEG
  For [TPT1]TPT0 Where PTE=TABLE & LEG=TABLE2
    If !fstat
      [F:TPT2]=[F:TPT1]
      [F:TPT2]LEG=LEGDES
      Write [TPT2]
      If fstat GOK=0 : Call FSTA("TPT2") From GLOCK : Break : Endif
    Endif
  Next
  If GOK=0 : Goto AB_COPIE : Endif
Commit

Return
#----- Abandon de la copie -----#
$AB_COPIE
Rollback : Return
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif : Return
