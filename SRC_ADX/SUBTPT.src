Subprog C_RPLPTE(VALEUR)
Variable Char     VALEUR()
Local Integer IRET
# Il est impératif de (re)déclarer localement le fichier (déjà ouvert!)
# Recherche en cascade pour vérifier si la substitution ne boucle pas
Local File TABPAYTERM [TPT]
Onerrgo
If GERREUR : GERREUR = 0 : End : Endif
If VALEUR = [M]PTE : mkstat=1 : End : Endif
If VALEUR <> ""
 #--CPO 71937
 Call LEC_TPT_LEG([M:TPT1]LEG,VALEUR,1,IRET) From TRTLECLEG
 If IRET : mkstat = 2 : End : Endif
 #Read [TPT]TPT0 = VALEUR;[M:TPT1]LEG;1
 #If fstat mkstat = 2 : GMESSAGE = mess(23,100,1) : Endif
 #--/CPO
 While fstat = 0 & [F]RPLPTE <> ""
  If [F]RPLPTE = [M]PTE
   GMESSAGE = [M]PTE-mess(28,101,1)-[F]PTE
   mkstat=2 : Break
  Endif
  Read [TPT]TPT0(1)=[F]RPLPTE
 Wend
Endif
#--CPO 71937 13.08.2013 Suite remontée tests
#--Il faut vérifier la compatibilité des groupes


#--/
End

