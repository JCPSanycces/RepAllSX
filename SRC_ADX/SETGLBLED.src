#<AdxTL>@(#)4.0.0.0 $Revision$
Subprog GLOBVAR
If clalev([F:LED])=0 : Local File GLED [LED] : Endif
Global Integer GLEDNBR : GLEDNBR = nbrecord([F:LED])

Global Char    GLED(GLONLED)(1..GLEDNBR)    : # Tableaux des codes référentiels
Global Char    GLEDCOA(GLONCOA)(1..GLEDNBR) : # Code plan du référentiel

Global Libelle GLEDFLGGEN(1..GLEDNBR)       : # Référentiel flagué Général
Global Libelle GLEDFLGANA(1..GLEDNBR)       : # Référentiel flagué Analytique
Global Libelle GLEDFLGBUD(1..GLEDNBR)       : # Référentiel flagué Budget
Global Libelle GLEDFLGCMM(1..GLEDNBR)       : # Référentiel flagué Engagements
Global Libelle GLEDEQLRAN(1..GLEDNBR)       : # Report à nouveau équilibré

Global Integer GLEDDIENBR(1..GLEDNBR)       : # Nombre d'axes gérés par code référentiel (analytique)
Global Integer GLEDDIEOBY(1..GLEDNBR)       : # Saisie axe obligatoire
Global Integer GLEDDIEIPT(1..GLEDNBR)       : # Stockage des imputations vides

Global Char    GDIE1(GLONDIE)(1..GLEDNBR)   : # Axe 1
Global Char    GDIE2(GLONDIE)(1..GLEDNBR)   : # Axe 2
Global Char    GDIE3(GLONDIE)(1..GLEDNBR)   : # Axe 3
Global Char    GDIE4(GLONDIE)(1..GLEDNBR)   : # Axe 4
Global Char    GDIE5(GLONDIE)(1..GLEDNBR)   : # Axe 5
Global Char    GDIE6(GLONDIE)(1..GLEDNBR)   : # Axe 6
Global Char    GDIE7(GLONDIE)(1..GLEDNBR)   : # Axe 7
Global Char    GDIE8(GLONDIE)(1..GLEDNBR)   : # Axe 8
Global Char    GDIE9(GLONDIE)(1..GLEDNBR)   : # Axe 9

Call INIGLBLED
End

Subprog INIGLBLED

If clalev([F:LED])=0 : Local File GLED [LED] : Endif

GLEDNBR = 0
For [LED]LED0
 GLEDNBR += 1
 GLED(GLEDNBR)       = [F:LED]LED
 GLEDCOA(GLEDNBR)    = [F:LED]COA 
 GLEDFLGGEN(GLEDNBR) = [F:LED]GEN
 GLEDFLGANA(GLEDNBR) = [F:LED]ANA
 GLEDFLGBUD(GLEDNBR) = [F:LED]BUD
 GLEDFLGCMM(GLEDNBR) = [F:LED]CMM
 GLEDDIENBR(GLEDNBR) = [F:LED]DIENBR
 GLEDDIEOBY(GLEDNBR) = [F:LED]DIEDACOBY
 GLEDDIEIPT(GLEDNBR) = [F:LED]DIEIPT
 GLEDEQLRAN(GLEDNBR) = [F:LED]EQLRANANA
 GDIE1(GLEDNBR)      = [F:LED]DIE(0)
 GDIE2(GLEDNBR)      = [F:LED]DIE(1)
 GDIE3(GLEDNBR)      = [F:LED]DIE(2)
 GDIE4(GLEDNBR)      = [F:LED]DIE(3)
 GDIE5(GLEDNBR)      = [F:LED]DIE(4)
 GDIE6(GLEDNBR)      = [F:LED]DIE(5)
 GDIE7(GLEDNBR)      = [F:LED]DIE(6)
 GDIE8(GLEDNBR)      = [F:LED]DIE(7)
 GDIE9(GLEDNBR)      = [F:LED]DIE(8)
Next
End



