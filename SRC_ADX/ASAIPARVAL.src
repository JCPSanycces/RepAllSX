#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"ADOVAL","ADOVAL","XWADOVAL") From GSAISIE
End

#-----------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "OK"         : Gosub OK
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
Endcase
Return

#----------------------#
$ACTIONB
Local Integer PSUBB
Call EXISTE_ADX("","","ASAIPARVALB",PSUBB) From ORDSYS
If PSUBB
 Gosub ACTION From ASAIPARVALB
Endif
Return

#------------------------------------------------#
$OUVRE
Local Char CHAPITRE(GLONADI) , SOCIETE(GLONCPY) , SITE(GLONFCY) , LEG(GLONADI) , GROUPE(GLONADI)
Local Char PARLIG(GLONADP)
CHAPITRE = [M:ADW1]CHAPITRE
SOCIETE  = [M:ADW1]CMP
SITE     = [M:ADW1]FCY
If dim([M:ADW1]LEG)>0
 LEG = [M:ADW1]LEG
Else
 LEG = ""
Endif
GROUPE = PARAM(1)
PARLIG = PARAM(2)
Return

#------------------------------------------------#
$DEBUT
Raz [M:ADWP] , I
[M]CHAPITRE = CHAPITRE
[M]CMP = SOCIETE
[M]FCY = SITE
If dim([M]LEG)>0
 [M]LEG = LEG
Endif
[M:ADWP]GRPPAR = [L]GROUPE
For [ADP]ADP5 Where CHAPITRE=[L]CHAPITRE & GRPPAR=[L]GROUPE
 K = find([F:ADP]PARAM,[M:ADW1]PARAM)
 If K
  I += 1
  [M:ADWP]PARAM(I-1)    = [M:ADW1]PARAM(K-1)
  [M:ADWP]NAME(I-1)     = [M:ADW1]NAME(K-1)
  [M:ADWP]VALEUR(I-1)   = [M:ADW1]VALEUR(K-1)
  [M:ADWP]GRPDEF(I-1)   = [M:ADW1]GRPDEF(K-1)
  [M:ADWP]NIVDEF(I-1)   = [M:ADW1]NIVDEF(K-1)
  [M:ADWP]NIVEAU(I-1)   = [M:ADW1]NIVEAU(K-1)
  [M:ADWP]VALINT(I-1)   = [M:ADW1]VALINT(K-1)
  [M:ADWP]TYP(I-1)      = [M:ADW1]TYP(K-1)
  [M:ADWP]NOLIB(I-1)    = [M:ADW1]NOLIB(K-1)
  [M:ADWP]LONG(I-1)     = [M:ADW1]LONG(K-1)
  [M:ADWP]FMT(I-1)      = [M:ADW1]FMT(K-1)
  If dim([M:ADWP]AUTMOD)>0
   [M:ADWP]AUTMOD(I-1)  = [M:ADW1]AUTMOD(K-1)
  Endif
 Endif
Next ADP
[M:ADWP]NBVAR = I
Affzo

For I=1 To [M:ADWP]NBVAR
 If dim([M:ADWP]AUTMOD)>0 & [M:ADWP]AUTMOD(I-1)=0
  Diszo [ADWP]VALEUR(I-1)
 Else
  Actzo [ADWP]VALEUR(I-1)
 Endif
Next I

If PARLIG<>""
 I = find(PARLIG,[M:ADWP]PARAM)
 If I
  zonsui = "[M:ADWP]NBVAR("+num$(I-1)+")"
 Endif
Endif
Return

#--------------------------------------------------------#
$SETBOUT
If GCONSULT
 Diszo [M:ADWP]
 Call VIREBOUT(CHBOU,"O") From GOBJET
 IMGFLG(5) = 1 : # Croix blanche
Else
 IMGFLG(5) = 0
Endif
Return

#------------------------------------------------#
$OK
For I=1 To [M:ADWP]NBVAR
 K = find([M:ADWP]PARAM(I-1),[M:ADW1]PARAM)
 If K
  [M:ADW1]GRPDEF(K-1) = [M:ADWP]GRPDEF(I-1)
  [M:ADW1]VALEUR(K-1) = [M:ADWP]VALEUR(I-1)
  [M:ADW1]VALINT(K-1) = [M:ADWP]VALINT(I-1)
  [M:ADW1]NIVEAU(K-1) = [M:ADWP]NIVEAU(I-1)
 Endif
Next I
mkstat = 4
Return

#------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "SELADGVAL" : Gosub SEL_ADG
Endcase
Return

#------------------------------------------------#
$VERF_LISTE
Case LISTE
 When "SELADGVAL" : Gosub VERF_ADG
Endcase
Return

#------------------------------------------------#
$SEL_ADG
If clalev([F:ADG])=0 : Local File ADOVALGRP [ADG] : Endif
Local Char CRITERE(250)
CRITERE = 'CHAPITRE="'+PARAM(1)+'" & GRPPAR="'+PARAM(2)+'"'
Raz NBTEX
K = 0
For I=1 To [M:ADWP]NBVAR
 If dim([M:ADWP]AUTMOD)>0 & [M:ADWP]AUTMOD(I-1)=0
  K = I : Break
 Endif
Next I
If K
 Call MESSAGE([M:ADWP]PARAM(K-1)-":"-mess(59,143,1)) From GESECRAN : # Paramètre non modifiable
Else
 For [ADG]ADG1(1) Where evalue(CRITERE)
  NBTEX += 1
  TEX(NBTEX) = [F:ADG]GRPDEF
  Call LECTEXTRA(TEXTE(NBTEX),"ATABDIV","LNGDES","912",[F:ADG]GRPDEF) From ATEXTRA
  TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
 Next ADG
 If NBTEX=0
  Call MESSAGE(mess(107,139,1)) From GESECRAN : # Aucun jeu disponible
 Endif
Endif
FORCE = 1
Call TITOBJ("ADG","",TIT) From CONTOBJ
Return

#------------------------------------------------#
$VERF_ADG
For I=1 To [M:ADWP]NBVAR
 [M:ADWP]GRPDEF(I-1) = TEX(CHOIX)
 Read [ADG]ADG1 = TEX(CHOIX);[M:ADWP]CHAPITRE;[M:ADWP]GRPPAR;[M:ADWP]PARAM(I-1)
 If !fstat
  [M:ADWP]VALINT(I-1) = [F:ADG]VALEUR
  [M:ADWP]VALEUR(I-1) = [F:ADG]VALEUR
  Call CHARGE([M:ADWP]VALEUR(I-1),[M:ADWP]TYP(I-1),[M:ADWP]NOLIB(I-1)
&            ,[M:ADWP]LONG(I-1),[M:ADWP]VALINT(I-1)) From FMTVAR
  If dim([M:ADWP]LEG)>0 & [M:ADWP]LEG<>""
   [M:ADWP]NIVEAU(I-1) = 5
  Elsif [M]CMP<>""
   [M:ADWP]NIVEAU(I-1) = 2
  Elsif [M]FCY<>""
   [M:ADWP]NIVEAU(I-1) = 3
  Else
   [M:ADWP]NIVEAU(I-1) = 1
  Endif
 Endif
Next I
Affzo
Return


########################################################################################
# Controle Valeur parametre commun ASAIVALPAR et GESADLV
#  RPARAM    = Code paramètre
#  RVALPARAM = Valeur a controler
#  RLEG      = Code legislation
#  RSILENCE  = 1  si on ne veut pas les messages de suite sinon  0 (positionne le GSILENCE)
#  RERROR    = Code erreur de retour
#  RMESSAGE  = Message de retour
#
# prerequis : on a lu ADP et donc classe ADP est chargé et ecran ADWP est ouvert    #
########################################################################################

Subprog CTRL_VALEUR (RPARAM,RVALPARAM,RLEG,RSILENCE,RERROR,RMESSAGE,RVALINT,VALEUR)
Value Char RPARAM
Value Char RVALPARAM
Value Char RLEG
Value Integer RSILENCE
Variable Integer RERROR
Variable Char    RMESSAGE
Variable Char    RVALINT
Variable Char    VALEUR

# attention on laisse la vara en valeur car dans action et gosub le dev utilise valeur


#---------------------------#
# ici ecran adwp est ouvert
# et on a lu le param ADP
#---------------------------#

RERROR = 0

Local Integer OK
Local Char    WSUPP(250)
Local Shortint WOK
Local Decimal WVALEUR
Local Char    ACTION(20)

WOK =0
WVALEUR =0

# ici il faut bidouiller positionner gsilence pour ne pas afficher les erreurs depuis prog appelé
If RSILENCE = 1
    GSILENCE = 1
Endif
ACTION = "C_VALEUR_DEB" : Gosub ACTIONB
GSILENCE = 0
If mkstat
     RMESSAGE = mess(83,123,1) : # Valeur incorrecte
     RERROR = 2
Else
    If [F:ADP]OBJET<>""
        Onerrgo RIEN
        If left$([F:ADP]VALUES(0),1)="="
             WSUPP = evalue(right$([F:ADP]VALUES(0),2))
        Else
             WSUPP = [F:ADP]VALUES(0)
        Endif
        WOK = 0
        Case [F:ADP]TYPVAL
              When 2
               WVALEUR = val(RVALPARAM)
               Call CONTNUM([F:ADP]OBJET,"!"+[F:ADP]SELOPT,WVALEUR,WSUPP,WOK) From CONTOBJ
              When Default
               Call CONTROLE([F:ADP]OBJET,"!"+[F:ADP]SELOPT,RVALPARAM,WSUPP,WOK) From CONTOBJ
        Endcase
        Onerrgo
        RERROR = WOK
        If !WOK
            # ici il faut bidouiller positionner gsilence pour ne pas afficher les erreurs depuis prog appelé
            If RSILENCE = 1
                GSILENCE = 1
            Endif
            ACTION = "C_VALEUR_OBJ" : Gosub ACTIONB
            GSILENCE = 0
            If mkstat
                 RMESSAGE = mess(83,123,1) : # Valeur incorrecte
                 RERROR = 2
            Endif
        Endif
    Elsif [F:ADP]VALFLG<>2
         If !find(num$(RVALPARAM),[F:ADP]VALUES(0..[F:ADP]NBVAL-1))
              RMESSAGE = mess(83,123,1) : # Valeur incorrecte
              RERROR = 2
         Endif
    Endif
Endif
# si pas d erreur on continue les controles sinon on arrete
If RERROR = 0
    If [F:ADP]TRAIT<>""
         RVALINT = RVALPARAM
         Call EXISTE_ADX("","",[F:ADP]TRAIT,OK) From ORDSYS
         If OK
              OK = 1
              # ici il faut bidouiller poistionner gsilence pour ne pas afficher les erreurs depuis prog appelé
              If RSILENCE = 1
                  GSILENCE = 1
              Endif
              Call VERF_PARAM(RPARAM,RVALINT,OK) From =[F:ADP]TRAIT
              GSILENCE = 0
              If !OK
                  RMESSAGE = mess(83,123,1) : # Valeur incorrecte
                  RERROR = 2
              Endif
         Endif
    Endif
Endif
End

#-----------------------------------------------#
# Gestion du masque ADWP
#-----------------------------------------------#

Subprog B1_NBVAR
Local Decimal BASPAG
Local Char    PARMSK(250)(1..20)
PARMSK(1) = [M]CHAPITRE
PARMSK(2) = [M]GRPPAR
Call S_LIS_NUM(BASPAG,PARMSK,"SELADGVAL","ASAIPARVAL","") From GACTION
End

Subprog B2_NBVAR
Local Char CHP(GLONADI) , JEU(GLONADP)
Gosub SETNOL
CHP = [M]CHAPITRE
JEU = [M]GRPDEF(NOL)
If JEU=""
 Filter [ADG] Where CHAPITRE=[M]CHAPITRE & GRPPAR=[M]GRPPAR
 Read [ADG] First
 If !fstat
  JEU = [F:ADG]GRPDEF
 Endif
 Filter [ADG]
Endif
Call OBJET_CHAR(CHP,"ADG",[M]GRPPAR+"~"+JEU) From GOBJET
For I=1 To [M]NBVAR
 Read [ADG]ADG1 = [M]GRPDEF(NOL);[M]CHAPITRE;[M]GRPPAR;[M]PARAM(I-1)
 If !fstat
  If [M]VALINT(I-1)<>[F:ADG]VALEUR
   [M]VALINT(I-1) = [F:ADG]VALEUR
   [M]VALEUR(I-1) = [F:ADG]VALEUR
   Call CHARGE([M]VALEUR(I-1),[M]TYP(I-1),[M]NOLIB(I-1),[M]LONG(I-1),[M]VALINT(I-1)) From FMTVAR
   Affzo [M]VALEUR(I-1)
  Endif
 Endif
Next I
End

Subprog B3_NBVAR
Hlpbox "ADP_"+[M]CHAPITRE+"_"+[M]PARAM(nolign-1)
End

#------------------------------------------------#
Subprog AS_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
If dim([M]LEG)>0 & [M]LEG<>""
 GMODIF = 5
Elsif [M]CMP<>""
 GMODIF = 2
Elsif [M]FCY<>""
 GMODIF = 3
Else
 GMODIF = 1
Endif
End

#------------------------------------------------#
Subprog C_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Local Integer OK , OKTRT
Local Char    VALINT(GLONADW) , SUPP(250)
Local Char ACTION(20)

Read [ADP]ADP1 = [M]PARAM(NOL)
If fstat : End : Endif

Local Integer OK , OKTRT

If GUSER = "CG"
    # test mise en commun gesadlv et adoval
    OK = 0
    Local Char    WVALINT(GLONADW)
    WVALINT=[M]VALINT(NOL)
    Call CTRL_VALEUR ([M]PARAM(NOL),[M]VALINT(NOL),[M]LEG,0,OK,GMESSAGE,WVALINT,VALEUR)
    If OK <> 0
         mkstat = 2
    Else
        If WVALINT<>[M]VALINT(NOL)
          [M]VALINT(NOL) = WVALINT
          [L]VALEUR = [L]VALINT
          Call CHARGE([L]VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
        Endif
    Endif
    End
Endif




ACTION = "C_VALEUR_DEB" : Gosub ACTIONB
If mkstat : End : Endif

If [F:ADP]OBJET<>""
 Onerrgo RIEN : # Dans le superviseur on peut avoir des erreurs
 If left$([F:ADP]VALUES(0),1)="="
  SUPP = evalue(right$([F:ADP]VALUES(0),2))
 Else
  SUPP = [F:ADP]VALUES(0)
 Endif
 Case [F:ADP]TYPVAL
  When 2
   Call CONTNUM([F:ADP]OBJET,"!"+[F:ADP]SELOPT,val([M]VALINT(NOL)),SUPP,mkstat) From CONTOBJ
  When Default
   Call CONTROLE([F:ADP]OBJET,"!"+[F:ADP]SELOPT,[M]VALINT(NOL),SUPP,mkstat) From CONTOBJ
 Endcase
 Onerrgo
 If mkstat : End : Endif

 Local Char ACTION(20)
 ACTION = "C_VALEUR_OBJ" : Gosub ACTIONB
 If mkstat : End : Endif

Elsif [F:ADP]VALFLG<>2
 OK = 1
 If !find(num$([M]VALINT(NOL)),[F:ADP]VALUES(0..[F:ADP]NBVAL-1)) : OK = 0 : Endif
 If !OK
  GMESSAGE = mess(83,123,1) : # Valeur incorrecte
  mkstat=2 : End
 Endif
Endif
If [F:ADP]TRAIT<>""
 [L]VALINT = [M]VALINT(NOL)
 Call EXISTE_ADX("","",[F:ADP]TRAIT,OKTRT) From ORDSYS
 If OKTRT
  OK = 1
  Call VERF_PARAM([M]PARAM(NOL),[L]VALINT,OK) From =[F:ADP]TRAIT
  If !OK
   mkstat = 2 : End
  Endif
 Endif
 If [L]VALINT<>[M]VALINT(NOL)
  [M]VALINT(NOL) = [L]VALINT
  [L]VALEUR = [L]VALINT
  Call CHARGE([L]VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
 Endif
Endif
End

#------------------------------------------------#
Subprog AM_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Local Integer I
Case GMODIF
 When 1 : [M]NIVEAU(NOL) = 1 : # Dossier
 When 2 : [M]NIVEAU(NOL) = 2 : # Société
 When 3 : [M]NIVEAU(NOL) = 3 : # Site
 When 5 : [M]NIVEAU(NOL) = 5 : # Législation
Endcase
[M]VALEUR(NOL) = VALEUR
For I=1 To [M]NBVAR
 [M]GRPDEF(I-1) = ""
Next I
Affzo 20
End

$RIEN
Resume

#------------------------------------------------#
Subprog IB_VALEUR
Raz GBOUT2, GBOUT3, GBOUT4 , GBOUT5
Read [ADP]ADP1 = [M]PARAM(nolign-1)
If [F:ADP]OBJET<> ""
 Call LECTURE("AOB",[F:ADP]OBJET,"") From CONTOBJ
 If !fstat & [F:AOB]TYPGES=4
  Raz GBOUT1
 Endif
Endif
If  [F:ADP]NBVAL<>0
& & [F:ADP]OBJET=""    # Issue X3-44568 - 2017-06-12 by CCC : NBVAL=1 if parameter of object
 GBOUT5 = mess(133,126,1) : # Liste de valeurs
Endif
If [M]FCY<>""
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 Read [ADW]ADW0 = [F:FCY]LEGCPY;"";[M]PARAM(nolign-1)
 If !fstat
  # Issue X3-104567 - 2018-08-30 by ALSHE : change button text to "Standard value"
  GBOUT4 = mess(288,123,1) : # Valeur standard: société
 Endif
Endif
# Issue X3-104567 - 2018-08-30 by ALSHE : activate button only if upper level record doesn't exist
If dim([M]LEG)>0 & ([M]FCY<>"" | [M]CMP<>"") & GBOUT4=""
 If [M]CMP<>""
  Call LECTURE("CPY",[M]CMP,"") From CONTOBJ
 Elsif [M]FCY<>""
  Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 Endif
 Read [ADW]ADW0 = "*";[F:CPY]LEG;[M]PARAM(nolign-1)
 If !fstat
  GBOUT3 = mess(288,123,1) : # Valeur standard: legislation
 Endif
Endif
# Issue X3-104567 - 2018-08-30 by ALSHE : activate button only if upper level record doesn't exist
If sum(GBOUT4+GBOUT3)=""
 Read [ADW]ADW0 = "";"";[M]PARAM(nolign-1)
 If !fstat
  GBOUT2 = mess(288,123,1)  : # Valeur standard: dossier
 Endif
Endif
End

#------------------------------------------------#
Subprog B1_VALEUR(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(250)(1..10)
Read [ADP]ADP1 = [M]PARAM(nolign-1)
PARAM(1) = [M]TYP(nolign-1)
If left$([F:ADP]VALUES(0),1)="="
 Onerrgo RIEN
 PARAM(2) = evalue(right$([F:ADP]VALUES(0),2))
 Onerrgo
Else
 PARAM(2) = [F:ADP]VALUES(0)
Endif
Call S_AFF_CHAR(VALEUR,PARAM,"AFMTB1","FMTVAR","") From GACTION
End

#------------------------------------------------#
Subprog B2_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ADW]ADW0 = "";"";[M]PARAM(NOL)
If !fstat
 VALEUR = [F:ADW]VALEUR
 Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
 mkstat = 4
 GMODIF = 1
Endif
End

#------------------------------------------------#
Subprog B3_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
If [M]CMP<>""
 Call LECTURE("CPY",[M]CMP,"") From CONTOBJ
Elsif [M]FCY<>""
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
Endif
Read [ADW]ADW0 = "*";[F:CPY]LEG;[M]PARAM(NOL)
If !fstat
 VALEUR = [F:ADW]VALEUR
 mkstat = 4
 GMODIF = 5
Else
 Read [ADW]ADW0 = "";"";[M]PARAM(NOL)
 If !fstat
  VALEUR = [F:ADW]VALEUR
  mkstat = 4
  GMODIF = 1
 Endif
Endif
Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
End

#------------------------------------------------#
Subprog B4_VALEUR(VALEUR)
Variable Char VALEUR()
Local Integer OK
OK = 0
Gosub SETNOL
Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
Read [ADW]ADW0 = [F:FCY]LEGCPY;"";[M]PARAM(NOL)
If !fstat
 VALEUR = [F:ADW]VALEUR
 mkstat = 4
 GMODIF = 2
 OK = 1
Endif
If !OK & dim([M]LEG)>0
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 Read [ADW]ADW0 = "*";[F:CPY]LEG;[M]PARAM(NOL)
 If !fstat
  VALEUR = [F:ADW]VALEUR
  mkstat = 4
  GMODIF = 5
  OK = 1
 Endif
Endif
If !OK
 Read [ADW]ADW0 = "";"";[M]PARAM(NOL)
 If !fstat
  VALEUR = [F:ADW]VALEUR
  mkstat = 4
  GMODIF = 1
 Endif
Endif
Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

