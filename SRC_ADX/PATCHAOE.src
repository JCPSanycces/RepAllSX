#<AdxTL>@(#)9.0.0.0 $Revision$
#############################################
## Intégration d'un modèle d'import/export
#############################################

$MODELE
Read [AOE]AOE0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:AOE]
 Elsif [F:AOE]CODACT>="X" & !find([F:AOE]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Return
 Else
  NEWOBJ = 0
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_MODELE
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_AOE
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Return

$TR_MODELE
Trbegin [AOE] , [AOD]
 Delete [AOD] Where EXT=NOMOBJ
 If fstat : GOK = 0 : ER = 99 : ERFIC = "AOBJEXT"-NOMOBJ : Goto ABORT : Endif
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Un bout de fenêtre
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "AOE"   : Gosub MODELE1
     When "AOD"   : Gosub MODELE2
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif

Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AOE",[F:AOE]EXT,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

$DEL_AOE
Trbegin [AOE] , [AOD],[AXX]
Delete [AXX] Where CODFIC="AOBJEXT" & ZONE = "INTIT"  & IDENT1=[L]NOMOBJ
Delete [AOD] Where EXT=NOMOBJ
Delete [AOE] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "AOE"-NOMOBJ: Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AOE",[L]NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

## En-tête modèle

$MODELE1
FICHIER = "AOBJEXT" : ABR = "AOE"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ & find(VARIA,"CHRNUM","ENAFLG") and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
   OK = 0
  Elsif NEWOBJ & VARIA="CHRNUM"
   [F:AOE]CHRNUM = 0
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:AOE]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:AOE]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:AOE]CREDAT = date$
  [F:AOE]CREUSR = GUSER
  If dim([F:AOE]CRETIM)>0 : [F:AOE]CRETIM = time  : Endif
  [F:AOE]UPDDAT = date$
  [F:AOE]UPDUSR = GUSER
  If dim([F:AOE]UPDTIM)>0 : [F:AOE]UPDTIM = time  : Endif
 Endif
 Write [AOE]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:AOE]UPDDAT = date$
  [F:AOE]UPDUSR = GUSER
  If dim([F:AOE]UPDTIM)>0 : [F:AOE]UPDTIM = time  : Endif
 Endif
 Rewrite [AOE]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AOBJEXT"-[F:AOE]EXT : Return
Endif
Delete [AOD] Where EXT=[F:AOE]EXT
If fstat : GOK = 0 : ER = 99 : ERFIC = "AOBJEXTD"-[F:AOE]EXT : Return : Endif
Return

## lignes modèle
$MODELE2
FICHIER = "AOBJEXTD" : ABR = "AOD"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Write [AOD]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AOBJEXTD"-[F:AOE]EXT-num$([F:AOD]NUMLIG) : Return
Endif
Return


$ABORT
Rollback
Return

