#<AdxTL>@(#)2.0.0.0 $Revision$
##############################################################################################################################
#   Traitement de gestion de la saisie des critères de recherche de solutions    Module CRM                  27 septembre 2000
##############################################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When Default
Endcase
Return


$OUVRE
If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
Global Integer ISDIRTY
Global Integer GIPBLGRP
Global Integer GIAUS
ISDIRTY = 0
GIPBLGRP = 0
GIAUS = 0
Return

$DEFBOUT
Return

$SETBOUT
If ISDIRTY
    ETABOU(GSPE1) = 1
Else
    ETABOU(GSPE1) = 0
Endif
ETAMEN(1) = 1
Return

$OUVRE_BOITE
Return

$DEBUT
[M:SRE3]KEYWRDFLG = 1
[M:SRE3]KEYWRD = ""
Grizo [M:SRE3]KEYWRD

[M:SRE3]TTRDESFLG = 1
[M:SRE3]TTRDESSAM = 1
[M:SRE3]TTRDES = ""
Grizo [M:SRE3]TTRDESSAM
Grizo [M:SRE3]SREHD1FLG
Grizo [M:SRE3]TTRDES

[M:SRE3]SOLFLG = 1
[M:SRE3]SOLSAM = 1
[M:SRE3]SOL = ""
Grizo [M:SRE3]SOLSAM
Grizo [M:SRE3]SOLHD3FLG
Grizo [M:SRE3]SOL

[M:SRE3]CREDATFLG = 1
[M:SRE3]STRDAT = [00/00/00]
[M:SRE3]ENDDAT = [00/00/00]
Grizo [M:SRE3]STRDAT
Grizo [M:SRE3]ENDDAT

Affzo [M:SRE3]

Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:SRE3]

Kill ISDIRTY
Kill GIPBLGRP
Kill GIAUS
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
ISDIRTY = 0

If [M:SRE3]KEYWRD <> ""
    ISDIRTY = 1
Endif

If [M:SRE3]TTRDES <> ""
    ISDIRTY = 1
Endif

If [M:SRE3]SOL <> ""
    ISDIRTY = 1
Endif

If GIPBLGRP
    ISDIRTY = 1
Endif

If GIAUS
    ISDIRTY = 1
Endif

If [M:SRE3]STRDAT <> [00/00/00] and [M:SRE3]ENDDAT <> [00/00/00]
    If [M:SRE3]ENDDAT >= [M:SRE3]STRDAT
        ISDIRTY = 1
    Endif
Endif
Return

$BOUTON
Case BOUT
    When "B"
        Gosub ONRAZ
    When Default
Endcase
Return

$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################
$ONRAZ
Raz [M:SRE3]
[M:SRE3]KEYWRDFLG = 1
[M:SRE3]KEYWRD = ""
Grizo [M:SRE3]KEYWRD

[M:SRE3]TTRDESFLG = 1
[M:SRE3]SREHD1FLG = 1
[M:SRE3]TTRDESSAM = 1
[M:SRE3]TTRDES = ""
Grizo [M:SRE3]TTRDESSAM
Grizo [M:SRE3]TTRDES

[M:SRE3]SOLFLG = 1
[M:SRE3]SOLHD3FLG = 1
[M:SRE3]SOLSAM = 1
[M:SRE3]SOL = ""
Grizo [M:SRE3]SOLSAM
Grizo [M:SRE3]SOL

[M:SRE3]CREDATFLG = 1
[M:SRE3]STRDAT = [00/00/00]
[M:SRE3]ENDDAT = [00/00/00]
Grizo [M:SRE3]STRDAT
Grizo [M:SRE3]ENDDAT

ISDIRTY = 0
Affzo [M:SRE3]
Return


