#<AdxTL>@(#)11.0.0.0 $Revision$
# Etape 6 de la définition d'un mailing                             Module CRM          5 décembre 2000  #
##########################################################################################################
# Expédition du mailing
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "SETBOUT"      : Gosub SETBOUT
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When "BOUTON"       : Gosub BOUTON
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GSZSND(250)
Global Integer GISND
Global Char GSZONUM(GLONVCR)
Global Char GSZEMAKEY(GLONVCR)
Global Char GSZMREWEB(GLONMAI)
Global Char GSZEMAOBC(90)
Global Char GSZEMATEX(250)

  If !clalev([F:MRE]) : Local File OMMRESULT [MRE] : Endif
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  GSZEMAOBC = ""
  GSZEMATEX = ""
  GSZEMAKEY = ""
  GSZMREWEB = ""
  If PARAM(1) = "" Then
    GSZONUM = GSZOPGNUM
  Else
    GSZONUM = PARAM(1)    #Code mailing
  Endif
  Read [OMM]OMM0=GSZONUM
  If fstat Then
    FIN = 1
    Return
  Else
    Case [F:OMM]SHIMOD
      When 1
        GSZSND = mess(389,196,1)
        GISND = 1
      When 2
        GSZSND = mess(390,196,1)
        GISND = 2
      When 3
        GSZSND = mess(391,196,1)
        GISND = 3
      When 4
        GSZSND = mess(665,182,1)
        GISND = 4
      When Default
    Endcase
  Endif
Return

##########################################################################################################
$DEBUT
  Raz [F:OMM]
  Read [OMM]OMM0=GSZONUM
  If fstat Then
    FIN = 1
    Return
  Else
    If [F:OMM]CREHIS = 0 Then
      [M:MAI6]CREHIS = 2
    Else
      [M:MAI6]CREHIS = [F:OMM]CREHIS
    Endif
    [M:MAI6]TPLNAM = [F:OMM]TPL
    [M:MAI6]TYPMRG = [F:OMM]TYPMRG
    [M:MAI6]DEFADD = [F:OMM]DEFADD
    [M:MAI6]HIEBPR = [F:OMM]HIEBPR
    [M:MAI6]TYPSEA = [F:OMM]TYPSEA
    [M:MAI6]CNTTTR = [F:OMM]CNTTTR
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "GESOMM" Then
        If [M:OMM2]SHISTA = 1 Then
          Grizo [M:MAI6]CREHIS
        Endif
      Endif
    Endif
  Endif
  # -----------------------------------
  If [M:MAI6]TYPMRG = 2 Then
    # Il n'y a pas de modèle avec Word
    Chgfmt [M:MAI6]TPLNAM With "-K:1X"
  Endif
  If [M:MAI6]TYPMRG <> 3 and [M:MAI6]TYPMRG <> 4 Then
    # Champ visible uniquement pour le XML
    Chgfmt [M:MAI6]TPLVOL With "-K:1X"
    Chgfmt [M:MAI6]TPLFIL With "-K:1X"
    Chgfmt [M:MAI6]TPLDIRFIL With "-K:1X"
  Else
    [M:MAI6]TPLFIL = [M:MAI6]TPLNAM + "_" + GUSER + "_" + date$ + left$(time$,2) + mid$(time$,4,2)  + mid$(time$,7,2)  + ".xml"
  Endif
  # -----------------------------------
  Affzo [M:MAI6]1-99
Return

##########################################################################################################
$SETBOUT
  # -------------------------
  # Boutons :
  #          A-Démarrer
  #          B-Reporter
  # -------------------------
  #Bouton Démarrer
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESOMM" Then
      If [M:OMM2]SHISTA = 1 Then
        Call VIREBOUT(CHMEN, "B") From GOBJET
      Endif
    Endif
  Endif
  # -----------------------------
  If dim(GMAI6VIREBOUT) >= 0 Then
    # Si on a appelé le subprog ONWORD on désactive les deux boutons
    Call VIREBOUT(CHMEN, "A") From GOBJET
    Call VIREBOUT(CHMEN, "B") From GOBJET
  Endif
  # -----------------------------
  Gosub SET_BOUT_SPE From GSAISIE
  # -----------------------------
Return

##########################################################################################################
$FINSAI
  Raz [M:MAI6]
  Kill GSZSND
  Kill GISND
  Kill GSZONUM
  Kill GSZEMAKEY
  Kill GSZMREWEB
  Kill GSZEMAOBC
  Kill GSZEMATEX
  If dim(GMAI6VIREBOUT) >= 0 Then
    Kill GMAI6VIREBOUT
  Endif
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONSTART
    When "B"
      Gosub ONSCH
    When Default
  Endcase
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONSTART
  # --------------------------------
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESOMM" Then
      If [M:OMM2]SHISTA = 1 Then
        Local Integer IMESSREP
        #
        IMESSREP = 0
        #Ce publipostage a déjà été expédié. Confirmez-vous l'exécution d'une nouvelle expédition ?
        Call OUINON(mess(693,182,1), IMESSREP) From GESECRAN
        If IMESSREP <> 2 Then
          #L'expédition du publipostage est abandonnée.
          GMESSAGE = mess(694,182,1)
          GERR = 2
          Return
        Endif
      Endif
    Endif
  Endif
  # --------------------------------
  If [M:MAI6]TYPMRG = 2 Then
    # Utilisation de Microsoft Word
    Gosub WORD
    # Pour activer le bouton "Suivant" dans l'assistant
    If PARAM(1) = "" Then
      GISTECPL(GICSTEP-1) = 1
    Endif
  Else
    Gosub CRYSTAL_XML
    # --------------------------------
    # Ne pas faire pour Word parce que sinon on ne pourra pas cliquer sur le lien !
    If PARAM(1) = "" Then
      GISTECPL(GICSTEP-1) = 1
    Endif
    FIN = 1
  Endif
Return

##########################################################################################################
$WORD
  # Appeler l'API qui va créer le lien et enregistrer dans l'historique si c'est à faire
  Call ONWORD
Return

##########################################################################################################
Subprog ONWORD
Local Integer LRET_VALUE
Local Char SKEY(type(GSZONUM)-10)
Local Char SWHERE(250)

  Call SETSHIINF(GISND)          # Défini les informations d'expédition.
  Call CRESNDMAIHST              # Crée l'historique des envois de mailing
  # --------------------------------
  SKEY = GSZONUM
  SWHERE = "OPGNUM eq '" + SKEY + "'"
  LRET_VALUE = func AOFFDOC.WORD_MAILMERGE("OMMRESULT", "OMMRESULT", SKEY, SWHERE, 1, isomess, GSOCIETE, GCURLEG, "")
  # --------------------------------
  Global Integer GMAI6VIREBOUT

  GMAI6VIREBOUT = 1
End

##########################################################################################################
$CRYSTAL_XML
  Case [M:MAI6]TYPMRG
    When 1
      # Crystal
      Case GISND
        When 1
          # Courrier
          Call ONMAIL2
        When 2
          # E-mail
          Call ONEMAIL2
        When 3
          # Fax
          Call ONFAX2
        When Default
      Endcase
    When 3, 4
      # XML sur client
      Call MAIL_XML
    When Default
  Endcase
Return

##########################################################################################################
Subprog MAIL_XML
Local Integer IOK
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Char SFICCLI(250)

Local Char SZMXL(type([M:MAI6]TPLNAM)-10)
Local Char SFILEXML(type([M:MAI6]TPLDIRFIL)-10)
Local Char SZTYPSEA(type([M:MAI6]TYPSEA)-10)
Local Char SZOPGNUM(type(GSZONUM)-10)
Local Integer IDEFADD
Local Integer IHIEBPR
Local Char SZCNTTTR(type([M:MAI6]CNTTTR)-10)

  # --------------------------------
  SZMXL = [M:MAI6]TPLNAM
  SFILEXML = [M:MAI6]TPLDIRFIL
  SZTYPSEA = [M:MAI6]TYPSEA
  SZOPGNUM = GSZONUM
  IDEFADD = [M:MAI6]DEFADD
  IHIEBPR = [M:MAI6]HIEBPR
  SZCNTTTR = [M:MAI6]CNTTTR
  # --------------------------------
  IOK = func TRTMAILXML.GENMAILXML(SZMXL, SFILEXML, SZTYPSEA, SZOPGNUM, IDEFADD, IHIEBPR, SZCNTTTR, SMESSAGE)
  If IOK <> [V]CST_ASUCCESS Then
    GMESSAGE = SMESSAGE
    GERR = 1
  Else
    Call SETSHIINF(GISND)          # Défini les informations d'expédition.
    Call CRESNDMAIHST              # Crée l'historique des envois de mailing
    # --------------------------------
    If [M:MAI6]TYPMRG = 3 Then
      # XML sur client
      # On recopie le fichier sur le poste client
      Call COPCLI([M:MAI6]TPLDIRFIL, SFICCLI, IOK) From ORDSYS
      If IOK <> 0 Then
        GMESSAGE = mess(19,139,1) - ":" - mess(7,21,1)
        GERR = 1
        End
      Endif
    Endif
  Endif
  # --------------------------------
End

##########################################################################################################
#Crée l'historique des envois de mailing
###########################################################
Subprog CRESNDMAIHST
Local Char SZLOOPCLE(GLONVCR)
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  SZLOOPCLE = ""
  ILOOPCUT = 8500
  ILOOPCLECOUNT = ILOOPCUT
  If [M:MAI6]CREHIS = 2 Then
    Call TEMPON("E") From GESECRAN
    While ILOOPCLECOUNT >= ILOOPCUT
      ILOOPCLECOUNT = 0
      Filter [MRE] Where [F:MRE]OPGNUM = GSZONUM and [F:MRE]MRENUM > SZLOOPCLE
      For [MRE]
        SZLOOPCLE = [F:MRE]MRENUM
        Call MKHISTO(GSZONUM, [F:MRE]BPRNUM, [F:MRE]CCNNUM)
        ILOOPCLECOUNT += 1
        If ILOOPCLECOUNT >= ILOOPCUT Then
          Break
        Endif
      Next
      Filter [MRE]
    Wend
    Call TEMPOFF From GESECRAN
  Endif
End

##########################################################################################################
Subprog ONMAIL2
Local Char SZPREVISU(250)
Local Integer IERRPRN
Local Char SMESSAGE(250)
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

  # Courrier
  # ----------------------------------------------
  SZPREVISU = ""
  IERRPRN = 0
  Raz TBPAR
  Raz TBVAL
  NBPAR = 0
  NBPAR += 1 : TBPAR(NBPAR) = "opgkey" : TBVAL(NBPAR) = ""
  NBPAR += 1 : TBPAR(NBPAR) = "opgnum" : TBVAL(NBPAR) = GSZONUM
  NBPAR += 1 : TBPAR(NBPAR) = "opgsnd" : TBVAL(NBPAR) = "MAI"
  Call GETPREVISUIMP(SZPREVISU, IERRPRN) From TRTMAY5
  If IERRPRN Then
    #Erreur lors de la création d'une imprimante de type Pré-visualisation. L'exécution du publipostage est abandonnée.
    GMESSAGE = mess(848,182,1)
    GERR = 1
    End
  Endif
  # ----------------------------------------------
  # On crée l'état dans le dictionnaire le temps du job
  IERRPRN = func TRTMAI5.DEFINE_ETAT([M:MAI6]TPLNAM, SMESSAGE)
  If IERRPRN <> 1 Then
    GMESSAGE = SMESSAGE
    GERR = 1
    End
  Endif
  # ----------------------------------------------
  Call ETAT([M:MAI6]TPLNAM, SZPREVISU, "", 0, "", TBPAR, TBVAL) From AIMP3
  # ----------------------------------------------
  # On supprime l'état du dictionnaire quand c'est fait
  IERRPRN = func TRTMAI5.DELETE_ETAT([M:MAI6]TPLNAM, SMESSAGE)
  If IERRPRN <> 1 Then
    GMESSAGE = SMESSAGE
    GERR = 1
    End
  Endif
  # ----------------------------------------------
  # Crée l'historique des envois de mailing
  Call CRESNDMAIHST
  Call SETSHIINF(GISND)
End

##########################################################################################################
Subprog ONEMAIL2
# Obtient le sujet et le texte de l'E-Mail.
Local Char SZPRN(250)
Local Integer IERRPRN
Local Char SMESSAGE(250)
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
Local Char SZLOOPCLE(GLONVCR)
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  # E-mail
  # ----------------------------------------------
  SZLOOPCLE = ""
  ILOOPCUT = 8500
  ILOOPCLECOUNT = ILOOPCUT
  SZPRN = ""
  IERRPRN = 0
  Call TEMPON("B") From GESECRAN
  Read [OMM]OMM0=GSZONUM
  If fstat Then
    GSZEMAOBC = ""
    GSZEMATEX = ""
  Else
    GSZEMAOBC = [F:OMM]EMAOBC
    GSZEMATEX = [F:OMM]EMATEX
  Endif
  # ----------------------------------------------
  # On crée l'état dans le dictionnaire le temps du job
  IERRPRN = func TRTMAI5.DEFINE_ETAT([M:MAI6]TPLNAM, SMESSAGE)
  If IERRPRN <> 1 Then
    GMESSAGE = SMESSAGE
    GERR = 1
    End
  Endif
  # ----------------------------------------------
  Call GETEMAILIMP(SZPRN, IERRPRN) From TRTMAY5
  If IERRPRN Then
    #Erreur lors de la création d'une imprimante de type Messagerie
    #L'exécution du publipostage est abandonnée.
    GMESSAGE = mess(849,182,1)
    GERR = 1
    End
  Endif
  # ----------------------------------------------
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [MRE] Where [F:MRE]OPGNUM = GSZONUM and [F:MRE]MRENUM <> '0' and [F:MRE]CLSNUM <> 0 and [F:MRE]MRENUM > SZLOOPCLE
    For [MRE]
      SZLOOPCLE = [F:MRE]MRENUM
      If [F:MRE]WEB <> "" Then
        GSZEMAKEY = [F:MRE]MRENUM
        GSZMREWEB = [F:MRE]WEB
        If GSZEMAOBC = "" Then
          # Au cas où il n'y aurait pas de texte on remet le mail !
          GSZEMAOBC = [F:MRE]WEB
          GSZEMATEX = [F:MRE]WEB
        Endif
        # ----------------------------------------------
        Raz TBPAR
        Raz TBVAL
        NBPAR = 0
        NBPAR += 1 : TBPAR(NBPAR) = "opgkey" : TBVAL(NBPAR) = GSZEMAKEY
        NBPAR += 1 : TBPAR(NBPAR) = "opgnum" : TBVAL(NBPAR) = GSZONUM
        NBPAR += 1 : TBPAR(NBPAR) = "opgsnd" : TBVAL(NBPAR) = "EMA"
        # ----------------------------------------------
        Call ETAT([M:MAI6]TPLNAM, SZPRN, "", 0, "", TBPAR, TBVAL) From AIMP3
        # ----------------------------------------------
        #Crée l'historique des envois de mailing
        If [M:MAI6]CREHIS = 2 Then
          Call MKHISTO(GSZONUM, [F:MRE]BPRNUM, [F:MRE]CCNNUM)
        Endif
        # ----------------------------------------------
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
    Filter [MRE]
    If GERR Then
      Break
    Endif
  Wend
  # ----------------------------------------------
  # On supprime l'état du dictionnaire quand c'est fait
  IERRPRN = func TRTMAI5.DELETE_ETAT([M:MAI6]TPLNAM, SMESSAGE)
  If IERRPRN <> 1 Then
    If GMESSAGE = "" Then
      GMESSAGE -= SMESSAGE
      GERR = 1
    Endif
  Endif
  # ----------------------------------------------
  If !GERR Then
    Call SETSHIINF(GISND)
  Endif
  Call TEMPOFF From GESECRAN
End

##########################################################################################################
Subprog ONFAX2
Local Char SZFAXPRN(250)
Local Char SMESSAGE(250)
Local Integer IERRPRN
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

  # Fax
  # ----------------------------------------------
  SZFAXPRN = ""
  IERRPRN = 0
  Raz TBPAR
  Raz TBVAL
  NBPAR = 0
  NBPAR += 1 : TBPAR(NBPAR) = "opgkey" : TBVAL(NBPAR) = ""
  NBPAR += 1 : TBPAR(NBPAR) = "opgnum" : TBVAL(NBPAR) = GSZONUM
  NBPAR += 1 : TBPAR(NBPAR) = "opgsnd" : TBVAL(NBPAR) = "MFA"
  Call GETFAXIMP(SZFAXPRN, IERRPRN) From TRTMAY5
  If IERRPRN Then
    #Erreur lors de la création d'une imprimante de type ActiveFax. L'exécution du publipostage est abandonnée.
    GMESSAGE = mess(850,182,1)
    GERR = 1
    End
  Endif
  # ----------------------------------------------
  # On crée l'état dans le dictionnaire le temps du job
  IERRPRN = func TRTMAI5.DEFINE_ETAT([M:MAI6]TPLNAM, SMESSAGE)
  If IERRPRN <> 1 Then
    GMESSAGE = SMESSAGE
    GERR = 1
    End
  Endif
  # ----------------------------------------------
  Call ETAT([M:MAI6]TPLNAM, SZFAXPRN, "", 0, "", TBPAR, TBVAL) From AIMP3
  # ----------------------------------------------
  # On supprime l'état du dictionnaire quand c'est fait
  IERRPRN = func TRTMAI5.DELETE_ETAT([M:MAI6]TPLNAM, SMESSAGE)
  If IERRPRN <> 1 Then
    GMESSAGE = SMESSAGE
    GERR = 1
    End
  Endif
  # ----------------------------------------------
  #Crée l'historique des envois de mailing
  Call CRESNDMAIHST
  Call SETSHIINF(GISND)
End

##########################################################################################################
Subprog SETSHIINF(ITYPSHI)
Value Integer ITYPSHI

  # Défini les informations d'expédition.
  Call DEBTRANS From GLOCK
  Trbegin [OMM]
  Readlock [OMM]OMM0=GSZONUM
  # Il s'agit d'un nouvel enregistrement
  If fstat Then
    Rollback
    End
  Else
    [F:OMM]SHIDAT = date$
    [F:OMM]SHIMOD = ITYPSHI
    [F:OMM]SHISTA = 1
    [F:OMM]CREHIS = [M:MAI6]CREHIS
    [F:OMM]UPDUSR = GUSER
    [F:OMM]UPDDAT = date$
    Rewrite [OMM]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Rollback
      End
    Else
      Commit
      If GPILNAV>1 Then
        If GNAVIG(GPILNAV-1) = "GESOMM" Then
          [M:OMM2]SHIDAT = date$
          [M:OMM2]SHISTA = 1
          [M:OMM2]SHISTAX = mess(1,968,1)  #Terminé avec succès
          Affzo [M:OMM2]1-99
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
$ONSCH
  # Défini les informations d'expédition.
  Call DEBTRANS From GLOCK
  Trbegin [OMM]
  Readlock [OMM]OMM0=GSZONUM
  # Il s'agit d'un nouvel enregistrement
  If fstat Then
    Rollback
  Else
    [F:OMM]SHIDAT = [00/00/00]
    [F:OMM]SHIMOD = GISND
    [F:OMM]SHISTA = 2
    [F:OMM]CREHIS = [M:MAI6]CREHIS
    [F:OMM]UPDUSR = GUSER
    [F:OMM]UPDDAT = date$
    Rewrite [OMM]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Rollback
      End
    Else
      Commit
    Endif
  Endif
  If PARAM(1) = "" Then
    GISTECPL(GICSTEP-1) = 1
  Endif
  FIN = 1
Return

##########################################################################################################
Subprog MKHISTO(SZOPGOMM, SZBPR, SZCCN)
Value Char SZOPGOMM
Value Char SZBPR
Value Char SZCCN

Local Integer HIMLASTKEY

  Local File HISTOOMM [HIM]
  #Calcul une clé pour le nouvel historique
  HIMLASTKEY = nbrecord([HIM]) + 1
  While 1
    Read [HIM]HIM0=num$(HIMLASTKEY)
    If fstat Then
      Break
    Endif
    HIMLASTKEY += 1
  Wend
  Call DEBTRANS From GLOCK
  Trbegin [HIM]
  Readlock [HIM]HIM2=SZOPGOMM;SZBPR;SZCCN
  If fstat = 5 Then
    #Enregistrement non trouvé, il faut le créer
    [F:HIM]HIMNUM = num$(HIMLASTKEY)
    [F:HIM]OMMNUM = SZOPGOMM
    [F:HIM]BPRNUM = SZBPR
    [F:HIM]CCNNUM = SZCCN
    [F:HIM]DATSND = date$
    Write [HIM]
    If fstat Then
      GMESSAGE = mess(100,141,1) #Erreur création
      GERR = 1
      Rollback
      End
    Endif
  Elsif fstat = 0 Then
    #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
    [F:HIM]HIMNUM = num$(HIMLASTKEY)
    [F:HIM]OMMNUM = SZOPGOMM
    [F:HIM]BPRNUM = SZBPR
    [F:HIM]CCNNUM = SZCCN
    [F:HIM]DATSND = date$
    Rewrite [HIM]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Rollback
      End
    Endif
  Endif
  Commit
End

##########################################################################################################
$CANCELSTEP
Local Integer ITRANSFLG

  If !clalev([F:HIM]) : Local File HISTOOMM [HIM] : Endif
  If adxlog Then
    ITRANSFLG = 1
  Else
    ITRANSFLG = 0
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [HIM]
  Endif
  Delete [HIM] Where [F:HIM]OMMNUM = GSZOPGNUM
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("HIM") From GLOCK
      Return
    Else
      Rollback
      Return
    Endif
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
Return
