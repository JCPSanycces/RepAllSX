#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPOR
#######################################################################################
# CRM OPERATIONS                                                                      #
#######################################################################################
#######################################################################################
$CRM_ADD_STEPB
#Value Char OPPNUM ()
#Value Char TYP ()
#Value Char VCRNUM ()
#Value Char PREOPPNUM ()
#Local Integer ARET_VALUE

  # Contrôles préliminaires (fait en amont dans un souci d'optimisation)
  # ------------------------------------
  If find(TYP,"SQH","SOH","CLL","BAP") = 0 Then
    # Contrôle des types acceptés
    [L]ARET_VALUE = fmet this.SETERROR("", mess(1178,196,1) - ":" - TYP, [V]CST_AERROR)
    Return
  Endif
  # ------------------------------------
  Local File OPPOR [OPP]
  Local File OPPORCRM [OPPCRM]
  Local File PIMPL [PIM]
  # ------------------------------------
  Read [PIM]PIM0=OPPNUM
  If fstat Then
    If find(TYP,"CLL","BAP") > 0 Then
      [L]ARET_VALUE = fmet this.SETERROR("", mess(1177,196,1) - "(a1) :" - OPPNUM, [V]CST_AERROR)
    Else
      If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, "", "CTLOPPCOD") = [V]CST_AYES Then
        [L]ARET_VALUE = fmet this.SETERROR("", mess(1177,196,1) - "(a2) :" - OPPNUM, [V]CST_AERROR)
      Endif
    Endif
    Return
  Endif
  If find([F:PIM]PIMTYP,1,3) = 0 Then
    Return  # L'affaire n'est ni CRM, ni mixte : rien à faire
  Endif
  # ------------------------------------
  Read [OPP]OPP0=OPPNUM
  If fstat Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(1177,196,1) - "(b) :" - OPPNUM, [V]CST_AERROR)
    Return
  Endif
  # ------------------------------------
  Read [OPPCRM]OPPCRM0=OPPNUM
  If fstat Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(1177,196,1) - "(c) :" - OPPNUM, [V]CST_AERROR)
    Return
  Endif
  If [F:OPPCRM]OPPSTEA2 = "WIN" Then
    # Si l'affaire est déjà gagnée, on n'enregistre plus d'étapes avant-vente, même si elle n'est pas close
    Return
  Elsif [F:OPPCRM]OPPSTEA2 = "LOS" or [F:OPPCRM]OPPSTEA2 = "FOR" Then
    # Si l'affaire est perdue ou abandonnée, et qu'on enregistre un CLL/BAP c'est qu'elle revient dans le circuit.
    # Même close elle sera réouverte. Donc on continue. On ne fait rien ici
  Elsif [F:OPP]OPPCLO = [V]CST_AYES Then
    Return  # Si l'affaire est close, c'est fini
  Endif
  # ------------------------------------
  # Les contrôles sont bons. D'abord lire l'affaire
  this.TCHTOREAD = "CRM"
  [L]ARET_VALUE = fmet this.AREAD(OPPNUM)
  If [L]ARET_VALUE <> [V]CST_AOK Then
    [L]ARET_VALUE = fmet this.SETERROR("", "[OPPOR-CRM_ADD_STEPB] Error OPP.AREAD :" - mess(1177,196,1) - "(d) :" - OPPNUM, [V]CST_AERROR)
    Return
  Endif
  # ------------------------------------
  [L]ARET_VALUE = fmet this._CRM_ADD_STEPB(TYP, VCRNUM, PREOPPNUM)
  If [L]ARET_VALUE <> [V]CST_AERROR Then
    [L]ARET_VALUE = fmet this.AUPDATE()
  Endif
  # ------------------------------------
Return

#######################################################################################
$CRM_DEL_STEPB
#Value Char OPPNUM ()
#Value Char TYP ()
#Value Char VCRNUM ()
#Local Integer ARET_VALUE

  # Contrôles préliminaires (fait en amont dans un souci d'optimisation)
  # ------------------------------------
  If find(TYP,"SQH","SOH","CLL","BAP") = 0 Then
    # Contrôle des types acceptés
    [L]ARET_VALUE = fmet this.SETERROR("", mess(1178,196,1) - ":" - TYP, [V]CST_AERROR)
    Return
  Endif
  # ------------------------------------
  Local File OPPOR [OPP]
  Local File OPPORCRM [OPPCRM]
  Local File PIMPL [PIM]
  # ------------------------------------
  Read [PIM]PIM0=OPPNUM
  If fstat Then
    If find(TYP,"CLL","BAP") > 0 Then
      [L]ARET_VALUE = fmet this.SETERROR("", mess(1177,196,1) - "(a1) :" - OPPNUM, [V]CST_AERROR)
    Else
      If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, "", "CTLOPPCOD") = [V]CST_AYES Then
        [L]ARET_VALUE = fmet this.SETERROR("", mess(1177,196,1) - "(a2) :" - OPPNUM, [V]CST_AERROR)
      Endif
    Endif
    Return
  Endif
  If find([F:PIM]PIMTYP,1,3) = 0 Then
    Return  # L'affaire n'est ni CRM, ni mixte : rien à faire
  Endif
  # ------------------------------------
  Read [OPP]OPP0=OPPNUM
  If fstat Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(1177,196,1) - "(b) :" - OPPNUM, [V]CST_AERROR)
    Return
  Endif
  # ------------------------------------
  Read [OPPCRM]OPPCRM0=OPPNUM
  If fstat Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(1177,196,1) - "(c) :" - OPPNUM, [V]CST_AERROR)
    Return
  Endif
  # ------------------------------------
  # Les contrôles sont bons. D'abord lire l'affaire
  this.TCHTOREAD = "CRM"
  [L]ARET_VALUE = fmet this.AREAD(OPPNUM)
  If [L]ARET_VALUE <> [V]CST_AOK Then
    [L]ARET_VALUE = fmet this.SETERROR("", "[OPPOR-CRM_ADD_STEPB] Error OPP.AREAD :" - mess(1177,196,1) - "(d) :" - OPPNUM, [V]CST_AERROR)
    Return
  Endif
  # ------------------------------------
  [L]ARET_VALUE = fmet this._CRM_DEL_STEPB(TYP, VCRNUM)
  If [L]ARET_VALUE <> [V]CST_AERROR Then
    [L]ARET_VALUE = fmet this.AUPDATE()
  Endif
  # ------------------------------------
Return

