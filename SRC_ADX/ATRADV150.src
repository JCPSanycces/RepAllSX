#  traduction APLSTD : mise a jour des différents produits pour la V5
#  utilise par INDUS
##################################################################################################
End


#-----------------------------#
#     SUPERVISEUR             #
#-----------------------------#
$MAJSUPER_150
# mettre a jour le dossier superviseur et les autres produits
# dans le cas d'un chapitre du module superviseur (il est commun)
# sauf les menus locaux modifiables et les spec par produit
#
# si on est deja dans l'appli superviseur on ne fait rien.
# superv150 n'est pas accessible pour les filiales.
#------------------
If GPRODUIT = -1
    Return
Endif

# lecture table amenloc pour connaitre le module
# Cas du Titre d'un menu local : WCHAPITRE=0 ou 200 
# amenloc du dossier en cours
#-------------------
WCHAPITRES=WCHAPITRE
If WCHAPITRE= 0   : WCHAPITRES=WNUMERO     : Endif
If WCHAPITRE= 200 : WCHAPITRES=200+WNUMERO : Endif
Read [XVM]MENLOC = WCHAPITRES
If fstat = 0
      If [F:XVM]MODULE <> 1
            Return
      Endif
      If [F:XVM]AUZMOD = 2
            Return
      Endif
Else
      Return
Endif

# lecture table amenloc du superviseur pour connaitre si menu local perso par produit
# il n'y a que dans SUPERV qu'on a l'info
# amenloc superv150
# ------------------------------------------------
Read [XVA]MENLOC = WCHAPITRES
If fstat = 0
      If [F:XVA]FLGPRO = 2
            Return
      Endif
Else
      Return
Endif



# ok on est sur un chapitre superviseur
# lecture aplstd superv et verification si c'est le même
#------------------------
WLANTRAD = [M]LAN
Gosub SUPERV150_APLSTD From ATRADAML


# ok on est sur un chapitre superviseur
#---------------------------
#--------------#
# -- x3 
#--------------#
WLANTRAD = [M]LAN
If GFOLDER_V150(1) <> "" 
   Gosub X3IND150_APLSTD From ATRADAML
Endif


#--------------#
# - abel       #
#--------------#
WLANTRAD = [M]LAN
If GFOLDER_V150(4) <> "" 
    Gosub ABEIND150_APLSTD From ATRADAML
Endif
#--------------#
# - geode
#--------------#
WLANTRAD = [M]LAN
If GFOLDER_V150(2) <> "" 
    Gosub GEOIND150_APLSTD From ATRADAML
Endif
#--------------#
#--- paye
#--------------#
WLANTRAD = [M]LAN
If GFOLDER_V150(3) <> "" 
   # on ne fait rien sur paye v5 car que fra
Endif

Return

