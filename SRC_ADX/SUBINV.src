Subprog C_REFDAT(VALEUR)
Variable Date    VALEUR

#104427 RICAR 2015/01/14 - Inventory - BEGIN
Local Integer LEDT : [L]LEDT = 0

# Get the main general ledger
Call LECLEDMAIN(1,[M:INV1]CPY,[L]LEDT) From CPTDIV
# Get fiscal year
Filter [F:FIY] Where [F:FIY]FIYSTR<=VALEUR & [F:FIY]FIYEND>=VALEUR & [F:FIY]LEDTYP=[L]LEDT & [F:FIY]CPY=[M:INV1]CPY
Read [F:FIY] First
If fstat
    Filter [F:FIY]
    GERR= 1
    GMESSAGE = mess(7,101,1)
    End
Endif
If VALEUR <> [F:FIY]FIYEND
  GERR= 1
  GMESSAGE = mess(174,7711,1)-mess(175,7711,1)
  End
Endif
Filter [F:FIY]
#104427 RICAR 2015/01/14 - Inventory - END

End

Subprog AM_ORIGIN(VALEUR)
Variable Integer VALEUR

#104427 RICAR 2015/01/14 - Inventory - BEGIN
If VALEUR = 2
  Raz [M:INV1]STRDAT,ENDDAT
  Diszo [M:INV1]STRDAT,ENDDAT
Else
  Actzo [M:INV1]STRDAT,ENDDAT
Endif
Affzo [M:INV1]STRDAT,ENDDAT
#104427 RICAR 2015/01/14 - Inventory - END

End


