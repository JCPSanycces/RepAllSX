$ON_ALG
Onevent BEFORE_AREA Gosub AV_ALG From W2ITM2
Onevent CONTROL Call C_ALG(zc) From W2ITM2
Onevent BEFORE_INPUT Call AS_ALG(zc) From W2ITM2
Return

$AV_ALG
## Action STD
Call AV_ALG(zc) From SUBITM
Gosub _AFF
Return

Subprog AS_ALG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_ALG(zc) From W2ITM2
Gosub _AFF
End

Subprog C_ALG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_ALG(VALEUR) From SUBITM
If mkstat : GERR = 1 : GZONE = "ALG" : GZNUM = 53002 : Endif
Gosub _AFF
End

Subprog S_ALG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action FOASEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "FOASEL"
 PARMSK(1) = [M:ITM0]ITMREF
 PARMSK(2) = num$(!([F:ITG]MFGFLG-1))
 Call SAISIE_CHAR(VALEUR,PARMSK,"FOASEL","SUBFOA","") From GSAISIE
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_ALGDAT
Onevent BEFORE_AREA Gosub AV_ALGDAT From W2ITM2
