#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITM2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_ECCSTA
Onevent INIT_AREA Call D_ECCSTA(zc) From W2ITM2
Return

Subprog D_ECCSTA(VALEUR)
Variable Integer VALEUR
If varinit([M]ECCSTA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ECCMIN
Onevent CONTROL Call C_ECCMIN(zc) From W2ITM2
Onevent BEFORE_INPUT Call AS_ECCMIN(zc) From W2ITM2
Onevent AFTER_CHANGE Gosub AMM_ECCMIN From W2ITM2
Return

Subprog AS_ECCMIN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(48896,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ECCMIN(zc) From W2ITM2
Onkey   2 Titled GBOUTS Call S_ECCMIN(zc) From W2ITM2
Onkey 144 Titled GBOUTP Call P_ECCMIN(zc) From W2ITM2
Onkey 146 Titled GBOUTA Call SA_ECCMIN(zc) From W2ITM2
Gosub _AFF
End

Subprog C_ECCMIN(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ICV","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "ECCMIN" : GZNUM = 48844 : Endif
If !mkstat
 ## Action STD
 Call C_ECCMIN(VALEUR) From SUBITM
 If mkstat : GERR = 1 : GZONE = "ECCMIN" : GZNUM = 48844 : Endif
Endif
Gosub _AFF
End

$AMM_ECCMIN
Call AM_ECCMIN(zc)
If !mkstat & GOBJET
 zoncou = "ECCMIN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ECCMIN(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZECCMIN)")>indice
 [M]ECCMIN(indice) = VALEUR
 Affzo ZECCMIN(indice)
Endif
Gosub _AFF
End

Subprog S_ECCMIN(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ICV"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_ECCMIN(VALEUR)
Variable Char    VALEUR()
Call OBJET("ICV",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_ECCMIN(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ICV"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ECCMIN(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ICV",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZECCMIN
Onevent BEFORE_AREA Gosub AV_ZECCMIN From W2ITM2
Return

$AV_ZECCMIN
Call LECTEXTRA(zc,"ITMCPTVER","DESAXX",num$([M]ECCMIN(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_ECCVALMIN
Return

$ON_ECCROUFLG
Onevent BEFORE_INPUT Call AS_ECCROUFLG(zc) From W2ITM2
Onevent CONTROL Call C_ECCROUFLG(zc) From W2ITM2
Onevent INIT_AREA Call D_ECCROUFLG(zc) From W2ITM2
Return

Subprog D_ECCROUFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]ECCROUFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ECCROUFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_ECCROUFLG(VALEUR) From SUBITM
If mkstat=2
 [M]ECCROUFLG(INDIC) = VALEUR
 Affzo ECCROUFLG(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_ECCROUFLG(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_ECCROUFLG(VALEUR) From SUBITM
If mkstat : GERR = 1 : GZONE = "ECCROUFLG" : GZNUM = 54431 : Endif
Gosub _AFF
End

$ON_BRDCOD
Onevent BEFORE_INPUT Call AS_BRDCOD(zc) From W2ITM2
Onevent CONTROL Call C_BRDCOD(zc) From W2ITM2
Onevent INIT_AREA Call D_BRDCOD(zc) From W2ITM2
Return

Subprog D_BRDCOD(VALEUR)
Variable Integer VALEUR
If varinit([M]BRDCOD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_BRDCOD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(325) From COMBOS
## Action STD
Call AS_BRDCOD(VALEUR) From SUBITM
If mkstat=2
 [M]BRDCOD(INDIC) = VALEUR
 Affzo BRDCOD(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,325,1))))
Endif
If !mkstat
 Discombo 0 From BRDCOD(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From BRDCOD(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_BRDCOD(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
If !GWEBSERV
 ## Action STD
 Call C_BRDCOD(VALEUR) From SUBITM
 If mkstat : GERR = 1 : GZONE = "BRDCOD" : GZNUM = 13912 : Endif
Endif
Gosub _AFF
End

