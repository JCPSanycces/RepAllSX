######################################################################################
## Etiquette ajoutée par le superviseur (écran EXPOBJ) 17/09/2013 13:24:53 (ERB)
######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()

# X3-09889 08.08.2018
If instr(1,VALEUR,"#") and [M]CHRONO <> 2
  GMESSAGE = mess(191, 141, 1)
  mkstat = 2
Else
  Local Integer ASTATUS
  Local Char FULLPATH(250)
  Local Char MESSAGE(250)

  # Issue X3-43015 - 2017-06-19 by CCC : replace # by Export number
  Local Char FICDON(250)
  FICDON = func GEXPOBJ.GET_EXPFILE_NAME(VALEUR)

  #control de la valeur [espace]chemin relatif
  #calcul du chemin absolu
  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO

  #mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, VALEUR,[M]NOMEXP,E_TYPE_FILEWRITE,GMESSAGE)
  If GBATCH
      mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, FICDON,[M]NOMEXP,E_TYPE_FILEOVERWRITE,GMESSAGE)
  Else
      mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, FICDON,[M]NOMEXP,E_TYPE_FILEWRITE,GMESSAGE)
  Endif
Endif

End

