#<AdxTL>@(#)9.0.0.0 $Revision$
GBIDC1 = ""
Call EXPORTATION(GBIDC1)
End

####################################################################
Subprog EXPORTATION(MODL)
Value Char MODL
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = MODL
Call TRAITE_CHAR(VALEUR,PARAM,"","GEXPOBJ","DEXPOBJ",4,"XYGEXPOBJ") From GTRAITE
End

#######################################################
$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "DEBUT"        : Gosub DEBUT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON_SAI
 When "SETBOUT"      : Gosub SETBOUT_SAI
 When "BOUTON"       : Gosub BOUTON_SAI
 When "OK"           : Gosub OK_SAI
 When "OUVRE_BATCH"  : Gosub OUVRE
 When Default
Endcase
Return

#######################################################
$AVANT_BOUTON_SAI
[M:EXP2] = [M:DIA]
Return

#######################################################
$SETBOUT_SAI
Local Char AUZ(23)
Call DROITSITE("",AUZ,OK) From EXEFNC
If (!OK | !instr(1,AUZ,"T"))
 Call VIREBOUT(CHMEN,"1") From GOBJET
Endif
Return

#######################################################
$BOUTON_SAI
Case BOUT
 When "1" : FIN = 1
Endcase
Return

#######################################################
$OK_SAI
[M:EXP2]OKIMP = 1
Return

#######################################################
$INIT
Local Char    TIT(50)
If PARAM(1)="***"
 FIN = 1 : Return
Endif
TIT  = mess(93,141,1) : # Exportation de données
Gosub OUVRE
Local Mask EXPOBJ [DIA] : # Saisie paramètres export
Raz [M:DIA]
Raz [M:EXP2]
[M:DIA]MODELE = PARAM(1)
Return

#######################################################
$DEBUT
If [M:DIA]MODELE<>""
 Call C_MODELE([M:DIA]MODELE)
 If mkstat
  GERR = 1 : FIN = 1 : Return
 Else
  Default Mask [DIA]
  Call AM_MODELE([M:DIA]MODELE)
  If mkstat : FIN = 1 : Return : Endif
 Endif
 Grizo [DIA]MODELE
Else
 Call GET_DERLU([M:DIA]MODELE,"AOE","ENAFLG=2 & EXPORT=2") From GOBJACT
 If [M:DIA]MODELE<>""
  Call C_MODELE([M:DIA]MODELE)
  If mkstat
   [M:DIA]MODELE = "" : Return
  Else
   Default Mask [DIA]
   Call CHARGE([M:DIA]MODELE,K)
   If K : [M:DIA]MODELE = "" : Return : Endif
  Endif
 Endif
Endif
If [M:DIA]NOMEXP<>""
 [M:DIA]VOLFIL = [M:DIA]NOMEXP
 #Call GETREP("REPEXPDEF",[M:DIA]VOLFIL) From SUBEXPOBJ
 Affzo [M:DIA]VOLFIL
Endif
Return

#######################################################
$OUVRE
If clalev([F:AOE])=0  : Local File AOBJEXT    [AOE]  : Endif
If clalev([F:AOD])=0  : Local File AOBJEXTD   [AOD]  : Endif
If clalev([F:AOR])=0  : Local File AOBJEXTR   [AOR]  : Endif
If clalev([F:AOB])=0  : Local File AOBJET     [AOB]  : Endif
If clalev([F:ATB])=0  : Local File ATABLE     [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File ATABZON    [ATZ]  : Endif
If clalev([F:ATI])=0  : Local File ATABIND    [ATI]  : Endif
If clalev([F:AMP])=0  : Local File AMSKPAR    [AMP]  : Endif
If clalev([F:ATX])=0  : Local File ATEXTE     [ATX]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif
If clalev([F:ATY])=0  : Local File ATYPE      [ATY]  : Endif
If clalev([F:APX])=0  : Local File APARIMPEXP [APX]  : Endif
If clalev([F:AFC])=0  : Local File AFONCTION  [AFC]  : Endif

If clalev([M:AOE0])=0 : Local Mask AOE0       [AOE0] : Endif
If clalev([M:AOE1])=0 : Local Mask AOE1       [AOE1] : Endif
If clalev([M:AOE2])=0 : Local Mask AOE2       [AOE2] : Endif
If clalev([M:EXP1])=0 : Local Mask EXPOBJ     [EXP1] : Endif : # Pour charger le modèle
If clalev([M:EXP2])=0 : Local Mask EXPOBJ2    [EXP2] : Endif : # Ecran référence (export + export enchaîné)
If clalev([F:ARV])=0  : Local File AREPORTV   [ARV]  : Endif
Return

#######################################################
$CONTROLE
TIT -= [M:DIA]MODELE
If GSERVEUR
 [M:EXP2] = [M:DIA]
Elsif [M:EXP2]OKIMP
 [M:EXP2] = [M:DIA]
 TMP = 1
Else
 FIN = 1
Endif
Call SET_DERLU("AOE",[M:DIA]MODELE+'~') From GOBJACT
Return

#######################################################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

Call EXPORTSIL

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

Return

#######################################################
$TERMINE
If !GSERVEUR & [M:EXP2]DEBUG<>2
 TRA = 1
Else
 TRA = 0
Endif
Return

#########################################################################################
## Export "silencieux" -  Les paramètres doivent être renseignés dans l'écran [EXP2]   ##
#########################################################################################
Subprog EXPORTSIL
Local Integer IMPSTA, INCREMENT_COUNTER
Local Char    MESSAGE(250)
Local Char    PARAM(15)(1..4) , VALEUR(15)

Call CHARGE_MODELE([M:EXP2]MODELE,IMPSTA)
If IMPSTA
 [M:EXP2]STAT = IMPSTA
Else
 If [M:EXP2]TYPEXP=0
  [M:EXP2]TYPEXP = 2
 Endif
 If [F:AOE]OBJ<>""
  Read [AOB]ABREV = [F:AOE]OBJ
 Endif

 If [M:EXP2]CHRONO=2
  Gosub COUNTER_HANDLER
 Else
  [M:EXP2]FINCHRONO = [C]EXPORT
 Endif
Endif

# Issue X3-43015 - 2017-06-20 by CCC : Delete file if it already exists
If !GSERVEUR
    IMPSTA = Delfile (func GET_EXPFILE_NAME([M:EXP2]NOMEXP))
    If IMPSTA=-27
        IMPSTA = 4
    Else
        Raz IMPSTA
    Endif
Endif

Call WORKFLOW(8,[M:EXP2]MODELE,"ED","") From AWRK

If [M:EXP2]STAT=0
 Call TRAITE_CHAR(VALEUR,PARAM,"","TRTEXPOBJ","",4,"XYTRTEXPOBJ") From GTRAITE
Endif

Call WORKFLOW(8,[M:EXP2]MODELE,"EF","") From AWRK

If [M:EXP2]STAT=0 & [M:EXP2]CHRONO=2
 Read [AOE]AOE0 = [M:AOE0]EXT
 # Mise à jour chrono
 Call ECR_TRACE("\"+mess(106,141,1)-[M:AOE0]EXT-num$([F:AOE]CHRNUM)-"->"-num$([M:EXP2]FINCHRONO),0)
&     From GESECRAN
 If !adxlog
  Call DEBTRANS From GLOCK
  Gosub TR_MOD
 Else
  Gosub MAJ_MOD
 Endif
 If GOK<1 : [M:EXP2]STAT = 11 : Endif
Endif

If [M:EXP2]STAT
 Call ERR_EXPORT([M:EXP2]STAT,MESSAGE) From GEXPOBJ
 If MESSAGE<>""
  Call ECR_TRACE(MESSAGE,1) From GESECRAN
 Endif
Endif

End

$MAJ_MOD
Update [AOE] Where EXT=[M:AOE0]EXT With CHRNUM(0)=[M:EXP2]FINCHRONO
If fstat=1
 GOK=-1 : GLOCK="$AOBJEXT"-[M:AOE0]EXT
Elsif fstat
 GOK=0 : Call RSTA("AOE",[M:AOE0]EXT) From GLOCK
Endif
Return

$TR_MOD
GOK=1
Trbegin [AOE]
 Gosub MAJ_MOD
 If GOK=-1 : Goto ROLL_TR_MOD
 Elsif GOK=0 : Goto AB_TR_MOD
 Endif
Commit
Return

$ROLL_TR_MOD
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_MOD : Endif

$AB_TR_MOD
Rollback
Return

$INC_EXPORT
Lock EXPORT
If fstat
 [M:EXP2]STAT = 6 : Return
Else
 [M:EXP2]FINCHRONO = [C]EXPORT
Endif
If !adxlog
 Trbegin [APX]
 Gosub MAJ_EXPORT
 If [M:EXP2]STAT=6
  Rollback
 Else
  Commit
 Endif
Else
 Gosub MAJ_EXPORT
Endif
Unlock EXPORT
Return

$MAJ_EXPORT
GPE = 0
GPOINT = "CTR_EXPORT" : Gosub ENTREE From EXEFNC
If !GPE
 Local Integer MAXCPT
 MAXCPT = func MAXCPTEXP
 [C]EXPORT = mod([C]EXPORT,MAXCPT)+1
 INCREMENT_COUNTER += 1
 If [C]EXPORT=1
  # Counter $1$ has been reinitialized
  Call ECR_TRACE(func AFNC.MES1(mess(177,141,1),"[C]EXPORT"),1) From GESECRAN
 Elsif [C]EXPORT>MAXCPT-10
  # Caution, the value of counter $1$ is $2$. When this value reaches $3$, it will be reinitialized.
  Call ECR_TRACE(func AFNC.MES3(mess(176,141,1),"[C]EXPORT",num$([C]EXPORT),num$(MAXCPT)),-1) From GESECRAN
 Endif
Endif
If fstat : [M:EXP2]STAT = 6 : Endif
Return

###########################################################
Funprog MAXCPTEXP
End 10^8-1

###########################################################
Subprog ERR_EXPORT(IMPSTA,MESSAGE)
Value Integer IMPSTA
Variable Char MESSAGE()
Case IMPSTA
 When 1  : MESSAGE = GBIDC3+"\"+mess(30,141,1)                      : # Modèle inexistant
 When 2  : MESSAGE = "|"+GBIDC3+"|\"+mess(101,100,1)                : # Fichier inexistant
 When 3  : MESSAGE = mess(13,141,1)                                 : # Exportation impossible sur fichier
 When 4  : MESSAGE = mess(57,141,1)                                 : # Accès non autorisé à ce fichier
 When 5  : MESSAGE = "|"+GBIDC3+"|\"+errmes$(27)                    : # Problème d'accès sur un fichier
 When 6  : MESSAGE = mess(30,100,1)                                 : # En cours autre poste
 When 7  : MESSAGE = mess(62,141,1)                                 : # Erreur système (valtrt)
 When 8  : MESSAGE = mess(63,141,1)                                 : # Erreur système (prog exp/imp)
 When 9  : MESSAGE = GBIDC3+"\"+mess(41,100,1)                      : # Champ inexistant
 When 10 : MESSAGE = "|"+GMESSAGE+"|\"+mess(64,141,1)               : # Lien impossible
 When 11 : MESSAGE = mess(13,100,1)+"\|"+GBIDC3                     : # Erreur écriture
 When 13 : MESSAGE = mess(72,141,1)-":"+GMESSAGE                    : # Modèle incorrect
 When 14 : MESSAGE = mess(97,141,1)+"\|"+GBIDC3+"|\"+mess(2,126,1)  : # Modèle export-import, Fiche inactive
 When 15 : MESSAGE = "|"+GBIDC3+"|\"+mess(1,123,1)                  : # Fonction non autorisée
 When 16 : MESSAGE = "|"+GBIDC3+"|\"+mess(123,141,1)                : # Pas les droits pour créer ou modifier
 When 18 : MESSAGE = GBIDC3+"\"+mess(110,141,1)                     : # Export impossible sur ce modèle
 When 19 : MESSAGE = "|"+GBIDC3+"|\"+mess(164,141,1)                : # Fichier non copié sur le poste client
 When 20 : MESSAGE = "|"+GBIDC3+"|\"+mess(35,126,1)                 : # Nom de fichier incorrect
 When 22 : MESSAGE = "|"+GBIDC3+"|\"+mess(132,133,1)                : # File already exists: X3-43015
Endcase
End

##################################################################
Subprog CHARGE_MODELE(MODELE,IMPSTA)
Variable Char    MODELE()
Variable Integer IMPSTA

Local    Integer OK , I , J , K, LNGFMT
Local    Char    ZONE1(GLONAVA) , CAR(1)
Local Char WINDICE(30) : Local Integer L,SAV_INDICE : #117336
Local    Char    TYPFMT(10) , OPTFMT(10) , CHFMT(20) , NUMFMT(10)
IMPSTA = 0
Read [AOE]AOE0 = MODELE
If fstat               : IMPSTA = 1  : GBIDC3 = MODELE : End
Elsif [F:AOE]ENAFLG<>2 : IMPSTA = 14 : GBIDC3 = MODELE : End
Elsif [F:AOE]EXPORT<>2 : IMPSTA = 18 : GBIDC3 = MODELE : End
Endif

[M:EXP1] = [M:DIA]
[M:AOE0] = [F:AOE]
[M:AOE1] = [F:AOE]
[M:AOE2] = [F:AOE]
[M:EXP1]MODELE = [F:AOE]EXT
Raz [M:EXP1]CRITERE
Raz I, J, nolign
For [AOD]AOD0 Where EXT=[M:AOE0]EXT
 nolign += 1
 [M:AOE2] = [F:AOD]
 If [F:ATB]CODFIC<>[F:AOD]FIL
  Read [ATB]CODFIC = [F:AOD]FIL
 Endif
 [M:AOE2]ZONE(nolign-1) = [F:ATB]ABRFIC-[M:AOE2]FLD(nolign-1)
 If find([F:AOD]FIL,[M:EXP1]FICHIER(0..I-1))=0
  [M:EXP1]FICHIER(I) = [F:AOD]FIL
  [M:EXP1]ABREV(I)   = [F:ATB]ABRFIC
  K = find([F:AOD]FIL,[F:AOE]FIL)
  If K
   [M:EXP1]CRITERE(I) = [F:AOE]FLGEXP(K-1)
  Endif
  I += 1
 Endif
 If find([F:AOD]SEL,2,3)
  [M:EXP1]BCLE(J) = [F:AOD]FLD
  K = instr(1,[F:AOD]FLD,"(")
  WINDICE="0" : #117336
  If K
   ZONE1 = left$([F:AOD]FLD,K-1)
   #117336
   L = instr(K,[F:AOD]FLD,")")
   If L
    WINDICE=mid$([F:AOD]FLD,K+1,L-K-1)
   Endif
  Else
   ZONE1 = [F:AOD]FLD
  Endif
  [M:EXP1]BABR(J)    = [F:ATB]ABRFIC
  Read [ATZ]CODZONE  = [F:ATB]CODFIC;ZONE1
  Read [ATY]CODTYP   = [F:ATZ]CODTYP
  [M:EXP1]TABCONT(J) = "[F:"+[F:ATB]ABRFIC+"]"+ZONE1
  [M:EXP1]CODTYP(J)  = [F:ATY]CODTYP
  [M:EXP1]TYP(J)     = [F:ATY]TYPTYP
  Call TEXTE([F:ATZ]NOCOURT,[M:EXP1]BNOM(J)) From OBJDIV
  Case [F:ATY]CODTYP
   When "AXX","AX1","AX2","AX3"
    If [F:ATY]LNGTYP<>0
     [M:EXP1]LONG(J)  = [F:ATY]LNGTYP
    Elsif [F:ATZ]LONG<>0
     [M:EXP1]LONG(J)  = [F:ATZ]LONG
    Else
     [M:EXP1]LONG(J)   = GLONDES
    Endif
   When "ADI"
    Read [AMP]CODPAR=2;[F:ATB]CODFIC;[F:ATZ]CODZONE;"ADI"
    If !fstat
     #117336
     SAV_INDICE=indice
     indice=val(WINDICE)
     [M:EXP1]NOLIB(J) = val(num$(evalue([F:AMP]VALPAR)))
     #117336
     indice=SAV_INDICE
    Endif
    [M:EXP1]LONG(J)  = GLONADI
   When Default
    Case [F:ATY]TYPTYP
     When 1
      If [F:ATY]NOLIB<>0
       [M:EXP1]NOLIB(J) = [F:ATY]NOLIB
      Else
       [M:EXP1]NOLIB(J) = [F:ATZ]NOLIB
      Endif
     When 8
     When Default
      If [M:EXP1]TYP(J)=7
       If [F:ATY]LNGTYP<>0
        [M:EXP1]LONG(J)  = [F:ATY]LNGTYP
       Else
        [M:EXP1]LONG(J)  = [F:ATZ]LONG
       Endif
      Endif
    Endcase
  Endcase
  [M:EXP1]BDEB(J) = [F:AOD]STRVAL
  [M:EXP1]BFIN(J) = [F:AOD]ENDVAL
  Call CHARGE([M:EXP1]BDEB(J),[M:EXP1]CODTYP(J),[M:EXP1]NOLIB(J),[M:EXP1]LONG(J),[M:EXP1]CODDEB(J))
& From FMTVAR
  Call CHARGE([M:EXP1]BFIN(J),[M:EXP1]CODTYP(J),[M:EXP1]NOLIB(J),[M:EXP1]LONG(J),[M:EXP1]CODFIN(J))
& From FMTVAR
   If dim(GFCTIMP)>0 & GFCTIMP<>""
   Read [F:ARV]ARV0 = [V]GFCTIMP;[V]GTYPIMP;MODELE;[AOD]FIL+"~"+[AOD]FLD
   If !fstat
    [M:EXP1]BDEB(J) = ""
    [M:EXP1]BFIN(J) = ""
    If [F:ARV]VALDEF1<>""
     Call EVALE([F:ARV]VALDEF1,[M:EXP1]BDEB(J),[M:EXP1]TYP(J)) From AIMP1
     Call CHARGE([M:EXP1]BDEB(J),[M:EXP1]CODTYP(J),[M:EXP1]NOLIB(J),[M:EXP1]LONG(J),[M:EXP1]CODDEB(J))
&    From FMTVAR
    Endif
    If [F:ARV]VALDEF2<>""
     Call EVALE([F:ARV]VALDEF2,[M:EXP1]BFIN(J),[M:EXP1]TYP(J)) From AIMP1
     Call CHARGE([M:EXP1]BFIN(J),[M:EXP1]CODTYP(J),[M:EXP1]NOLIB(J),[M:EXP1]LONG(J),[M:EXP1]CODFIN(J))
&    From FMTVAR
    Endif
   Endif
  Endif
  J += 1
 Endif
Next
[M:EXP1]NBFIC = I
[M:EXP1]NBCLE = J
If GPRODUIT=1 & [F:AOE]OBJ<>"" : ## GEODE GX
 Call MODELEW
Endif
mkstat = 0
Call CONTROLE From SUBAOE
If mkstat
 GMESSAGE = MODELE+"\"+GMESSAGE : IMPSTA = 13
Endif
End

###########################################################################################
## Pour les modèles sans les zones FCY/DEP associés à un objet GEODE géré par
## environnement, ajout dans les critères de la table associée à l'objet
## - géré par site de FCY=[V]GFCY
## - géré par déposant de FCY=[V]GFCY & DEP=[V]GDEP
###########################################################################################

Subprog MODELEW
Gosub NOMFIC From = "WO"+[F:AOE]OBJ
Gosub SETCLE From = "WO"+[F:AOE]OBJ
# cas particuliers pour les configs site, entrée, sortie, stock ...
If [L]NOMFIC="SITE" & !(dim([L]CLEFCY)>0 & [L]CLEFCY<>"")
 Local Char CLEFCY(GLONAVA), CLEDEP(GLONAVA), CLEVALEUR(GLONAVA)
 [L]CLEFCY="FCY" : [L]CLEVALEUR=[L]CLEFCY
Elsif [L]NOMFIC="DEPOSITOR" & dim([L]CLEDEP)>0 & [L]CLEDEP=""
 [L]CLEDEP="DEP"
Endif
If !(dim([L]CLEVALEUR)>0 & ([L]CLEDEP<>"" | [L]CLEFCY<>"")) : End : Endif

Local Integer K, I, J, L
Local Char    CRIT(200), LETTRE(1), ZONE(20), CRIT2(50)

If dim([L]CLEFCY)>0 & [L]CLEFCY<>"" & !find(ABFIC-CLEFCY,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
 K=find(NOMFIC,[M:EXP1]FICHIER(0..[M:EXP1]NBFIC-1))
 If K
  CRIT = format$("KT:200X",[M:EXP1]CRITERE(K-1))
  ZONE = [L]CLEFCY
  Gosub SUBSTR
  If !J
   CRIT2 = [L]CLEFCY+"=GFCY" : Endif
 Endif
Endif

If dim([L]CLEDEP)>0 & [L]CLEDEP<>"" & !find(ABFIC-CLEDEP,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
 K=find(NOMFIC,[M:EXP1]FICHIER(0..[M:EXP1]NBFIC-1))
 If K
  CRIT = format$("KT:200X",[M:EXP1]CRITERE(K-1))
  ZONE = [L]CLEDEP
  Gosub SUBSTR
  If !J
   If CRIT2<>"" : CRIT2 -= "&" : Endif
   CRIT2 -= [L]CLEDEP+"=GDEP"
  Endif
 Endif
Endif

If CRIT2<>""
 L=len([M:EXP1]CRITERE(K-1))
 If L=0
  [M:EXP1]CRITERE(K-1)+=[L]CRIT2
 Else
  J=0
  For ZONE="|","&","?","and","or","xor"
   If instr(1,[M:EXP1]CRITERE(K-1),[L]ZONE)
    J=1 : Break
   Endif
  Next
  If L+J*2+3+len([L]CRIT2) <= mod(type([M:EXP1]CRITERE(K-1))-10,256)
   If J : [M:EXP1]CRITERE(K-1)="("+[M:EXP1]CRITERE(K-1)+") & "+[L]CRIT2
   Else : [M:EXP1]CRITERE(K-1)=[M:EXP1]CRITERE(K-1)+" & "+[L]CRIT2
   Endif
  Endif
 Endif
Endif
End

$SUBSTR
L=len(ZONE) : J=0
Repeat
 I=instr(1,CRIT,ZONE)
 If !I : Break : Endif
 J=1
 If I>1
  LETTRE=mid$(CRIT,I-1,1)
  If LETTRE>="A" & LETTRE<="Z" : J=0 : Endif
 Endif
 If J
  LETTRE=mid$(CRIT,I+L,1)
  If LETTRE>="A" & LETTRE<="Z" : J=0 : Endif
 Endif
 If !J : CRIT=right$(CRIT,I+L) : Endif
Until J or CRIT=""
Return

### Pour Geode
$P1_AS_B
If GPRODUIT=1 & [M:AOE1]OBJ<>"" & [M]BABR(nolign-1)=[M]ABREV(0)
 Gosub SETCLE From ="WO"+[M:AOE1]OBJ
 If nolign>1 & dim([L]CLEDEP)>0 & [L]CLEDEP<>"" & [M]BCLE(nolign-1)=[L]CLEDEP
& & [M]BABR(nolign-2)=[M]BABR(nolign-1) & [M]BCLE(nolign-2)=[L]CLEFCY
& & ([M]BDEB(nolign-2)<>[M]BFIN(nolign-2) | [M]BDEB(nolign-2)="")
   mkstat=1 : Return
 Endif
Endif
Return

$P1_C_BFIN
If GPRODUIT=1 & [M:AOE1]OBJ<>"" & [M]BABR(nolign-1)=[M]ABREV(0)
 Gosub SETCLE From ="WO"+[M:AOE1]OBJ
 If dim([L]CLEFCY)>0 & [L]CLEFCY<>"" & [M]BCLE(nolign-1)=[L]CLEFCY
  If [M]BDEB(nolign-1)=VALPAR & VALPAR<>""
   [M]FCY=VALPAR
  Else
   [M]FCY=""
  Endif
 Elsif dim([L]CLEDEP)>0 & [L]CLEDEP<>"" & [M]BCLE(nolign-1)=[L]CLEDEP
  If [M]BDEB(nolign-1)=VALPAR & VALPAR<>""
   [M]DEP=VALPAR
  Else
   [M]DEP=""
  Endif
 Endif
Endif
Return
################

################################################################
# Etiquettes du masque EXPOBJ
###########################################################################
Subprog IB_MODELE
If GADONIX<>2
 GBOUT2 = ""
Endif
End

Subprog C_MODELE(VALEUR)
Variable Char VALEUR()
Call CONTROLE("AOE","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Call CONTEXE([F:AOE]ACS) From SUBACS
If mkstat : End : Endif
If [F:AOE]EXPORT<>2
 GMESSAGE = mess(110,141,1) : # Export impossible sur ce modèle
 mkstat = 1 : End
Endif
End

Subprog AM_MODELE(VALEUR)
Variable Char VALEUR()
Local Integer IMPSTA, WOK
Local Char    MESSAGE(250)
Call CHARGE(VALEUR,IMPSTA)
If IMPSTA
 Call ERR_EXPORT(IMPSTA,MESSAGE)
 Call ERREUR(MESSAGE) From GESECRAN
 GMESSAGE = "" : mkstat=2 : End
Endif
End

Subprog CHARGE(MODELE,IMPSTA)
Value Char MODELE
Variable Integer IMPSTA
Call CHARGE_MODELE(MODELE,IMPSTA)
If IMPSTA : End : Endif
If GBATCH
 [M:EXP1]TYPEXP = 2
Else
 [M:EXP1]TYPEXP = [F:AOE]TYPEXP
 [M:EXP1]VOLFIL   = [F:AOE]FILEXT
Endif
If GOS(1)="unix" & !GBATCH
 If left$([M:EXP1]NOMEXP,2)="#@"
  [M:EXP1]TYPEXP = 1
  [M:EXP1]NOMEXP = right$([M:EXP1]NOMEXP,3)
 Elsif left$([M:EXP1]NOMEXP,2)="#" or pat(left$([M:EXP1]NOMEXP,3),"!:\")
  [M:EXP1]TYPEXP = 1
 Endif
Endif
Call SET_NOMFIC([F:AOE]FILEXT,[M:EXP1]NOMEXP,[M:EXP1]TYPEXP)
[M:DIA] = [M:EXP1]
If [F:AOE]OBJ<>""
 Call LECTURE("AOB",[F:AOE]OBJ,"") From CONTOBJ
 If fstat : [M:DIA]CHRONO = 1 : Grizo [M:DIA]CHRONO : End : Endif
 Filter [ATZ] Where CODFIC=[F:AOB]NOMFIC & CODZONE="EXPNUM"
 Read [ATZ]CODZONE First
 Filter [ATZ]
Else
 Filter [ATZ] Where CODFIC=[F:AOE]FLGFIL(0) & CODZONE="EXPNUM"
 Read [ATZ]CODZONE First
 Filter [ATZ]
Endif
If fstat
 [M:DIA]CHRONO = 1 : Grizo [M:DIA]CHRONO
Endif
Actzo [M:DIA]CHRONO
If [F:AOE]CHRNUM<>0 & [M:DIA]CHRONO=0
 [M:DIA]CHRONO = 2
Endif
If [M:DIA]TYPEXP=1
 Diszo [M]VOLFIL
 Raz [M]VOLFIL,[M]NOMEXP
Else
 Actzo [M]VOLFIL
 #101458
 #Call C_VOLFIL([M]VOLFIL)
 #If mkstat
 # mkstat = 0
 # Raz [M]VOLFIL
 #Endif
Endif
Affzo [M:DIA]5, TYPEXP, VOLFIL,NOMEXP, NBCLE, BNOM, BDEB, BFIN, NBFIC, FICHIER, CRITERE
End

