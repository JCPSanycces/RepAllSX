End

Subprog AS_BDEB(VALEUR)
Variable Char VALEUR()
Gosub P1_AS_B
If mkstat : Raz [M]CODDEB(nolign-1) : Endif
End

Subprog AM_BDEB(VALEUR)
Variable Char    VALEUR()
Local Integer INF
Case [M]TYP(nolign-1)
 When 1,2,3,4,5,6
  If val([M]CODFIN(nolign-1))<>0 & val([M]CODFIN(nolign-1))<val([M]CODDEB(nolign-1)) : INF = 1 : Endif
 When 7
  If [M]CODFIN(nolign-1)<>"" & [M]CODFIN(nolign-1)<[M]CODDEB(nolign-1) : INF = 1 : Endif
 When 8
  If gdat$([M]CODFIN(nolign-1))<>[0/0/0] & gdat$([M]CODFIN(nolign-1))<gdat$([M]CODDEB(nolign-1))
   INF = 1
  Endif
Endcase
If INF
 [M]BFIN(nolign-1) = VALEUR
 Call CONTROLE([M]BFIN(nolign-1),[M]CODTYP(nolign-1),[M]NOLIB(nolign-1)
&              ,[M]LONG(nolign-1),[M]CODFIN(nolign-1)) From FMTVAR
 Affzo [M]BFIN(nolign-1)
Endif
End

Subprog AS_BFIN(VALEUR)
Variable Char VALEUR()
Gosub P1_AS_B
If mkstat : Raz [M]CODFIN(nolign-1) : Endif
End

Subprog C_BFIN(VALPAR)
Variable Char VALPAR()
Local Integer OK
OK = 1
Case [M]TYP(nolign-1)
 When 1,2,3,4,5,6
  If val([M]CODFIN(nolign-1))<>0 & val([M]CODFIN(nolign-1))<val([M]CODDEB(nolign-1)) : OK = 0 : Endif
 When 7
  If [M]CODFIN(nolign-1)<>"" & [M]CODFIN(nolign-1)<[M]CODDEB(nolign-1) : OK = 0 : Endif
 When 8
  If gdat$([M]CODFIN(nolign-1))<>[0/0/0] & gdat$([M]CODFIN(nolign-1))<gdat$([M]CODDEB(nolign-1))
   OK = 0
  Endif
Endcase
If !OK
 GMESSAGE = mess(8,135,1) : # Valeur trop petite
 mkstat = 2 : End
Endif
Gosub P1_C_BFIN
End

