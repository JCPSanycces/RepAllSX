Local Char URL(10)
#If !GFUSION
#Call SET_NOMFIC([F:AOE]FILEXT,[M]NOMEXP,VALEUR)
#Endif
If VALEUR=1
# Call SET_FICNAM([M]VOLFIL,[M]NOMEXP,URL) From ORDSYS
 Raz [M]VOLFIL
 Affzo [M]VOLFIL
 Grizo [M]VOLFIL
Else
 Actzo [M]VOLFIL
Endif
End

Subprog AS_NOMEXP(VALEUR)
