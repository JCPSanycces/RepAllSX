######################################################################################
#**
#* Get name of file for export (replace # by [C]EXPORT)
#*
#* @param PNAM : Path of file
#*!
Funprog GET_EXPFILE_NAME(PNAM)
Value Char PNAM()

Local Char FICDON(250)
Local Char CHAINE(250) , SUF(10)
Local Integer I, FINCHRONO
FINCHRONO = [C]EXPORT
FICDON = PNAM
Call SETNAM(FICDON,CHAINE,SUF) From GOBJTXT
If instr(1,CHAINE,"#")
    I = instr(1,FICDON,CHAINE+"."+SUF)
    I = instr(I,FICDON,"#")
    If FINCHRONO>99999
        FICDON = left$(FICDON,I-1)+format$("N0:"+num$(len(num$(func GEXPOBJ.MAXCPTEXP)))+"#",FINCHRONO)+right$(FICDON,I+1)
    Else
        FICDON = left$(FICDON,I-1)+format$("N0:5#",FINCHRONO)+right$(FICDON,I+1)
    Endif
Endif
End FICDON

######################################################################################
Subprog AM_CHRONO(VALEUR)
Variable Integer VALEUR
  # X3-09889 08.08.2018
  If VALEUR <> 2 and instr(1,[M]VOLFIL,"#")
    Raz [M]VOLFIL
    Affzo [M]VOLFIL
  Endif
End

######################################################################################
$COUNTER_HANDLER
  # X3-90899 08.08.2018
  # When filename contains placeholder for sequence(#) it is possible that file already exists
  # in this case we try to find not occupied number
  Local Char RES(30), PATH(250), FILE_NAME(250), FILE_CANDIDATE(250), FILE_EXTENSION(30), VOLUME(30)
  Local Integer RES_STAT, NUMBER_CANDIDATE, POSITION

  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
  Call FINDFILES([M]NOMEXP,RES_STAT) From ASYRSTO #X3-107977 20.09.2018

  If instr(1,VOLFIL,"#") and GSERVEUR > 0 and RES_STAT = 1
    Call SETNAM([M]VOLFIL,FILE_NAME,FILE_EXTENSION) From GOBJTXT

    For I = 1 To 4
      NUMBER_CANDIDATE = mod([C]EXPORT,func GEXPOBJ.MAXCPTEXP)+I
      J = instr(1,[M]VOLFIL,FILE_NAME+"."+FILE_EXTENSION)
      J = instr(I,[M]VOLFIL,"#")
      FILE_CANDIDATE = left$([M]VOLFIL,J-1)+format$("N0:"+num$(len(num$(func GEXPOBJ.MAXCPTEXP)))+"#",NUMBER_CANDIDATE)+right$([M]VOLFIL,J+1)
      RES_STAT = func ASYRSTO.CTL_VOLFIL(2, FILE_CANDIDATE,PATH,E_TYPE_FILEREAD,RES)

      If RES_STAT
        Break
      Endif
    Next I

    If I < 5 # loop finished by break, that means free number has been found
      J = instr(1,FILE_CANDIDATE,']/')
      VOLUME =  mid$( FILE_CANDIDATE,2, [L]J-2)
      FILE_NAME = right$(FILE_CANDIDATE,[L]J+2)
      PATH = func ASYRSTO.GETFULLPATH(VOLUME,FILE_NAME)
      [M:EXP2]NOMEXP = PATH

      For J = 1 To I
        Gosub INC_EXPORT
      Next J
    Endif
  Endif
  Gosub INC_EXPORT

Return

