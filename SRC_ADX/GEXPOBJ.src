Subprog SET_NOMFIC(FICHIER,NOMEXP,TYPEXP)
Value Char FICHIER
Variable Char NOMEXP
Value Integer TYPEXP
Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)
NOMEXP = FICHIER
If TYPEXP=1
 Call SET_NAMCLI(NOMEXP) From ORDSYS
Elsif !instr(1,NOMEXP,"@") & !find(left$(NOMEXP,1),"/") & !pat(left$(NOMEXP,3),"!:\")
 Call GETREP("REPEXPDEF",REPERT) From SUBEXPOBJ
 If REPERT<>""
  Call MACHINE(REPERT,MACHINE,REPERT) From ORDSYS
  Call SETFIC(REPERT,FICHIER,MACHINE,NOMEXP) From SUBEXPOBJ
 Endif
Endif
End

Subprog C_NOMEXP(VALEUR)
Variable Char VALEUR()

End

Subprog AP_NOMEXP(VALEUR)
Variable Char     VALEUR
Local Integer OK
If [M]TYPEXP=2 & filinfo(VALEUR,0)>=0
 OK =2 : Call OUINON(mess(7,141,1),OK) From GESECRAN : # Fichier destination présent, effacement ?
 If OK<>2 : mkstat=2 : End : Endif
Endif
[M:EXP1]NOMEXP = VALEUR
End

