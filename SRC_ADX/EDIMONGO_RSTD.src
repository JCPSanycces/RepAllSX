###############################################################################
# Representation EDIMONGO                                                     #
# Author : RBA                                                                #
###############################################################################

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
        When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
        When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
        When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
        When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
        When "AREAD_AFTER"                  : Gosub AREAD_AFTER
      Endcase
  Endcase
Return

###############
# METHODS
###############
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

###############
# PROPERTIES
###############
$PROPERTIES
#  Case [L]CURPRO
#     Case [L]ARULE
#     Endcase
#  Endcase
Return

###############################################################################

$AQUERY_DECODE_CRITERIA_AFTER
  NBPRO += 1 : TBPRO(NBPRO) = "POS"        : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "EMG.POS"        : TBFIL(NBPRO) = "[LNK_]POS"
Return

###############################################################################

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = ""
  ASTDKEY = ASTDKEY + "[LNK_]POS asc;"
Return

###############################################################################
$AQUERY_OPEN_AFTER
  #Declare temp variables
  Local Integer I, J
  Local Integer WPOS_TAB(1..)
  Local Char    WOBJTYP_TAB(100)(1..)
  Local Char    WKEYS_TAB(100)(1..)
  Local Char    WDES_TAB(100)(1..)
  Local Char    WCACHEUUID_TAB(36)(1..)
  Local Char    WUUIDXMLTYP(36)(1..)

  I = 0

  Local File EDIPTC [EPT]
  Filter [EPT] Where [EPT]VALID = [V]CST_AYES Order By [EPT]PTCCOD Desc
  For [EPT]
    I = I + 1
    WPOS_TAB(I)       = I
    WOBJTYP_TAB(I)    = "EDIPTC"
    WKEYS_TAB(I)      = [EPT]PTCCOD
    WDES_TAB(I)       = [EPT]PTCDES
    WCACHEUUID_TAB(I) = num$([EPT]CACHEUUID)
    WUUIDXMLTYP(I)    = ""
  Next
  Filter [EPT]
  LogicClose File [EPT]

  Local File EDIMSG [EMS]
  Filter [EMS] Where [EMS]VALID = [V]CST_AYES Order By [EMS]MSGCOD Desc; [EMS]MSGREL Desc
  For [EMS]
    I = I + 1
    WPOS_TAB(I)       = I
    WOBJTYP_TAB(I)    = "EDIMSG"
    WKEYS_TAB(I)      = [EMS]MSGCOD+"-"+[EMS]MSGREL
    WDES_TAB(I)       = [EMS]MSGDES
    WCACHEUUID_TAB(I) = num$([EMS]CACHEUUID)
    WUUIDXMLTYP(I)    = ""
  Next
  Filter [EMS]
  LogicClose File [EMS]

  Local File EDISEQFIL [ESF]
  Filter [ESF] Where [ESF]VALID = [V]CST_AYES Order By [ESF]MSGCOD Desc; [ESF]MSGREL Desc; [ESF]MSGFILNOR Desc
  For [ESF]
    I = I + 1
    WPOS_TAB(I)       = I
    WOBJTYP_TAB(I)    = "EDISEQFIL"
    WKEYS_TAB(I)      = [ESF]MSGCOD+"-"+[ESF]MSGREL+"-"+[ESF]MSGFILNOR
    WDES_TAB(I)       = [ESF]FILDES
    WCACHEUUID_TAB(I) = num$([ESF]CACHEUUID)
    WUUIDXMLTYP(I)    = ""
  Next
  Filter [ESF]
  LogicClose File [ESF]

  Local File EDIXSDUPL [EXU]
  Filter [EXU] Order By [EXU]CODE Desc
  For [EXU]
    I = I + 1
    WPOS_TAB(I)       = I
    WOBJTYP_TAB(I)    = "EDIXSDUPL"
    WKEYS_TAB(I)      = [EXU]CODE
    WDES_TAB(I)       = [EXU]FILDES
    WCACHEUUID_TAB(I) = num$([EXU]UUIDXSD)
    WUUIDXMLTYP(I)    = ""
  Next
  Filter [EXU]
  LogicClose File [EXU]

  Local File EDIFLO [EDF]
  Filter [EDF] Where [EDF]VALID = [V]CST_AYES Order By [EDF]FLOCOD Desc; [EDF]FLOREL Desc
  For [EDF]
    I = I + 1
    WPOS_TAB(I)       = I
    WOBJTYP_TAB(I)    = "EDIFLO"
    WKEYS_TAB(I)      = [EDF]FLOCOD+"-"+[EDF]FLOREL
    WDES_TAB(I)       = [EDF]FLODES
    WCACHEUUID_TAB(I) = num$([EDF]CACHEUUID)
    WUUIDXMLTYP(I)    = ""
  Next
  Filter [EDF]
  LogicClose File [EDF]


  #Transfert into temp table
  Local File
& (
&    Integer POS,
&    Char    OBJTYP(100),
&    Char    KEYS(100),
&    Char    DES(100),
&    Char    CACHEUUID(36)
& )
&  From Variable
&            WPOS_TAB,
&            WOBJTYP_TAB,
&            WKEYS_TAB,
&            WDES_TAB,
&            WCACHEUUID_TAB
&   As [LNK_]
Return


###############################################################################

$AQUERY_TRANS_AFTER
  this.EMG.POS       = [LNK_]POS
  this.EMG.OBJTYP    = [LNK_]OBJTYP
  this.EMG.KEYS      = [LNK_]KEYS
  this.EMG.DES       = [LNK_]DES
  this.EMG.CACHEUUID = [LNK_]CACHEUUID
Return

###############################################################################

$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
Return

###############################################################################

$AREAD_AFTER
  #Load the Detail facet
Return

