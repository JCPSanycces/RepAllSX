#<AdxTL>@(#)0.0.0.0 $Revision$
# Class SFTSHIFT_BREAKS


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "SHFCOD"
    Case [L]ACTION
      When "PROPAGATE"  : Gosub SHFCOD_PROP
    Endcase
  When "SHFSTR"
    Case [L]ACTION
      When "PROPAGATE"  : Gosub SHFSTR_PROPAGATE
    Endcase
  When "SHFEND"
    Case [L]ACTION
      When "PROPAGATE"  :  Gosub SHFEND_PROPAGATE
    Endcase
  When "BREAKS.BRKSTR"
    Case [L]ACTION
      When "PROPAGATE"  : Gosub BRKSTR_PROPAGATE
      When "CONTROL"    : Gosub BRKSTR_CONTROL
    Endcase
  When "BREAKS.BRKEND"
    Case [L]ACTION
      When "PROPAGATE"  : Gosub BRKEND_PROPAGATE
      When "CONTROL"    : Gosub BRKEND_CONTROL
    Endcase
  When "BREAKS.BRKCOD"
    Case [L]ACTION
      When "CONTROL"    : Gosub BRKCOD_CONTROL
    Endcase
Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

############################################
$SHFSTR_PROPAGATE
  If this.DURCHECKS <> 1 and this.DURCHECKS <> 11
    this.DURCHECKS += 1
  Endif

  If this.DURCHECKS = 11
    Local Decimal RESULT
    Call CALC_DUR(this.SHFSTR, this.SHFEND, RESULT)
    this.SHFDUR = RESULT
  Endif
Return

############################################
$SHFEND_PROPAGATE

  If this.DURCHECKS < 10
    this.DURCHECKS += 10
  Endif

  If this.DURCHECKS = 11
    Local Decimal RESULT
    Call CALC_DUR(this.SHFSTR, this.SHFEND, RESULT)
    this.SHFDUR = RESULT
  Endif
Return

############################################
Subprog CALC_DUR(START_T, END_T, RESULT)
Value Char START_T
Value Char END_T
Variable  Decimal RESULT
    Local Integer HOUR_START, HOUR_END
    Local Integer MIN_START,  MIN_END
    Local Decimal START_TIME
    Local Decimal END_TIME
    Local Char TEMP(25)

    TEMP = left$(START_T,2)
    HOUR_START = val(TEMP)

    TEMP = left$(END_T,2)
    HOUR_END = val(TEMP)

    TEMP = mid$(START_T,3, 2)
    MIN_START = val(TEMP)

    TEMP = mid$(END_T,3, 2)
    MIN_END = val(TEMP)

    END_TIME = MIN_END / 60
    END_TIME += HOUR_END
    START_TIME = MIN_START / 60
    START_TIME += HOUR_START

    If START_T <= END_T
      RESULT = END_TIME - START_TIME
    Else
      RESULT = END_TIME - START_TIME + 24
    Endif
End

############################################
$BRKSTR_CONTROL
If (this.APARENT.SHFSTR <> "000000" or this.APARENT.SHFEND <> "000000") and this.APARENT.DURCHECKS = 0 : Gosub INITIALIZE : Endif

#if this is an edit and not a create, we need to have durchecks know that shift start/end time is valid

If this.APARENT.DURCHECKS = 1
  [L]ASTATUS = fmet this.ASETERROR ("SHFEND", mess(58,2422,1), [V]CST_AERROR)
  Return
Elsif this.APARENT.DURCHECKS = 10 or this.APARENT.DURCHECKS = 0
  [L]ASTATUS = fmet this.ASETERROR ("SHFSTR", mess(59,2422,1), [V]CST_AERROR)
  Return
Endif

Local Decimal RESULT
Call CALC_DUR(this.BRKSTR, this.BRKEND, RESULT)


If this.APARENT.SHFSTR < this.APARENT.SHFEND
  If this.APARENT.SHFSTR > this.BRKSTR
    [L]ASTATUS = fmet this.ASETERROR ("BRKSTR", mess(64,2422,1), [V]CST_AERROR)
    Return
  Elsif this.APARENT.SHFEND < this.BRKSTR
    [L]ASTATUS = fmet this.ASETERROR ("BRKSTR", mess(65,2422,1), [V]CST_AERROR)
    Return
  Elsif RESULT > this.APARENT.SHFDUR and this.DURCHECKB > 10
    [L]ASTATUS = fmet this.ASETERROR ("BRKSTR", mess(66,2422,1), [V]CST_AERROR)
    Return
  Endif
Else
  If this.APARENT.SHFEND < this.BRKSTR and this.APARENT.SHFSTR > this.BRKSTR
    [L]ASTATUS = fmet this.ASETERROR ("BRKSTR", mess(65,2422,1), [V]CST_AERROR)
    Return
  Elsif RESULT > this.APARENT.SHFDUR and this.DURCHECKB > 10
    [L]ASTATUS = fmet this.ASETERROR ("BRKSTR", mess(66,2422,1), [V]CST_AERROR)
    Return
  Endif
Endif

  #Break cannot start during previous break
  If this.AORDER > 1 # first one doesn't matter
    If this.BRKSTR <= this.APARENT.BREAKS(this.AORDER - 1).BRKEND
      [L]ASTATUS = fmet this.ASETERROR ("BRKSTR", mess(72,2422,1), [V]CST_AERROR)
      Return
    Endif
  Endif
Return

############################################
$BRKSTR_PROPAGATE
  Gosub BRKSTR_CONTROL
  If this.DURCHECKB <> 1 and this.DURCHECKB <> 11
    this.DURCHECKB += 1
  Endif

  If this.DURCHECKB = 11
    Local Decimal RESULT
    Call CALC_DUR(this.BRKSTR, this.BRKEND, RESULT)
    this.BRKDUR = RESULT
  Endif
Return

############################################
$BRKEND_CONTROL
If (this.APARENT.SHFSTR <> "000000" or this.APARENT.SHFEND <> "000000") and this.APARENT.DURCHECKS = 0 : Gosub INITIALIZE : Endif
#if this is an edit and not a create, we need to have durchecks know that shift start/end time is valid

If this.APARENT.DURCHECKS = 1
  [L]ASTATUS = fmet this.ASETERROR ("SHFEND", mess(58,2422,1), [V]CST_AERROR)
  Return
Elsif this.APARENT.DURCHECKS = 10 or this.APARENT.DURCHECKS = 0
  [L]ASTATUS = fmet this.ASETERROR ("SHFSTR", mess(59,2422,1), [V]CST_AERROR)
  Return
Endif

Local Decimal RESULT
Call CALC_DUR(this.BRKSTR, this.BRKEND, RESULT)

If this.APARENT.SHFSTR < this.APARENT.SHFEND
  If this.APARENT.SHFSTR > this.BRKEND
    [L]ASTATUS = fmet this.ASETERROR ("BRKEND", mess(60,2422,1), [V]CST_AERROR)
    Return
  Elsif this.APARENT.SHFEND < this.BRKEND
    [L]ASTATUS = fmet this.ASETERROR ("BRKEND", mess(61,2422,1), [V]CST_AERROR)
    Return
  Elsif RESULT > this.APARENT.SHFDUR
    [L]ASTATUS = fmet this.ASETERROR ("BRKEND", mess(62,2422,1), [V]CST_AERROR)
    Return
  Endif
Else
  If this.APARENT.SHFEND < this.BRKEND and this.APARENT.SHFSTR > this.BRKEND
    [L]ASTATUS = fmet this.ASETERROR ("BRKEND", mess(61,2422,1), [V]CST_AERROR)
    Return
  Elsif RESULT > this.APARENT.SHFDUR and this.DURCHECKB > 10
    [L]ASTATUS = fmet this.ASETERROR ("BRKEND", mess(62,2422,1), [V]CST_AERROR)
    Return
  Endif
Endif
Return

############################################
$BRKEND_PROPAGATE

  Gosub BRKEND_CONTROL
  If this.DURCHECKB < 10
    this.DURCHECKB += 10
  Endif

  If this.DURCHECKB = 11
    Local Decimal RESULT
    Call CALC_DUR(this.BRKSTR, this.BRKEND, RESULT)
    this.BRKDUR = RESULT
  Endif
Return

############################################
$BRKCOD_CONTROL
  Local File SFTINDREF [IND]
  Read [IND]SFTAG0  = this.BRKCOD

  If [IND]INDTYP <> 5
    [L]ASTATUS = fmet this.ASETERROR ("BRKCOD", mess(63,2422,1), [V]CST_AERROR)
  Endif

Return

############################################

$INITIALIZE
  this.APARENT.DURCHECKS = 11

  Local Integer I
  For I = maxtab(this.APARENT.BREAKS) To 1 Step -1
    this.APARENT.BREAKS(I).DURCHECKB = 11
  Next

Return

$SHFCOD_PROP
  this.SHFCOD = toupper(this.SHFCOD)
Return

