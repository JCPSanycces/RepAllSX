Return

$AV_BOMUOM
## Action STD
Call AV_BOMUOM(zc) From SUBBOR
Gosub _AFF
Return

Subprog AS_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3612,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_BOMUOM(VALEUR) From SUBBOR
If mkstat=2
 [M]BOMUOM(INDIC) = VALEUR
 Affzo BOMUOM(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_BOMUOM(zc) From W1BOMRPL1
Onkey   2 Titled GBOUTS Call S_BOMUOM(zc) From W1BOMRPL1
Onkey 144 Titled GBOUTP Call P_BOMUOM(zc) From W1BOMRPL1
Onkey 146 Titled GBOUTA Call SA_BOMUOM(zc) From W1BOMRPL1
Gosub _AFF
End

Subprog C_BOMUOM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "BOMUOM" : GZNUM = 8127 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("TUN","E",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BOMUOM" : GZNUM = 8127 : Endif
Endif
Gosub _AFF
End

$AMM_BOMUOM
Call AM_BOMUOM(zc)
If !mkstat & GOBJET
 zoncou = "BOMUOM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_BOMUOM(VALEUR)
Variable Char    VALEUR()
## Action BOMCOE
Call BOMCOE(VALEUR,[M:BOR1]STU(nolign-1),[M:BOR1]RPLITMREF(nolign-1),"BOR1") From UOMLIB
If mkstat : GERR = 1 : GZONE = "BOMUOM" : GZNUM = 8127 : Endif
If !mkstat
 ## Action STD
 Call AM_BOMUOM(VALEUR) From SUBBOR
 If mkstat : GERR = 1 : GZONE = "BOMUOM" : GZNUM = 8127 : Endif
Endif
Gosub _AFF
End

Subprog S_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TUN"
PARMSK(2) = "E"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_BOMUOM(VALEUR)
Variable Char    VALEUR()
Call OBJET("TUN",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TUN"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TUN",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

