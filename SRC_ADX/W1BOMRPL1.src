$ON_LEVSET
Onevent BEFORE_INPUT Call AS_LEVSET(zc) From W1BOMRPL1
Onevent AFTER_CHANGE Gosub AMM_LEVSET From W1BOMRPL1
Onevent INIT_AREA Call D_LEVSET(zc) From W1BOMRPL1
Onevent CONTROL Call C_LEVSET(zc) From W1BOMRPL1
Return

Subprog D_LEVSET(VALEUR)
Variable Integer VALEUR
If varinit([M]LEVSET,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LEVSET(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(2394) From COMBOS
## Action PASECCUSE2
Call PASECCUSE2 From ECCLIB
If mkstat=2
 [M]LEVSET(INDIC) = VALEUR
 Affzo LEVSET(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action STD
 Call AS_LEVSET(VALEUR) From SUBBOR
 If mkstat=2
  [M]LEVSET(INDIC) = VALEUR
  Affzo LEVSET(INDIC) : mkstat = 2
 Endif
 If VALEUR<1 | GMENLOC(VALEUR)=1
  VALEUR = find(0,GMENLOC(1..len(mess(0,2394,1))))
 Endif
 If !mkstat
  Discombo 0 From LEVSET(INDIC)
  If sum(GMENLOC)<>0
   Gosub COMBOS From COMBOS
   For WI=1 to WN : Discombo WCOMBO(WI) From LEVSET(INDIC) : Next WI
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog C_LEVSET(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$AMM_LEVSET
Call AM_LEVSET(zc)
If !mkstat & GOBJET
 zoncou = "LEVSET" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

