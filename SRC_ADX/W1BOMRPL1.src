Subprog AS_CTN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(16813,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CTN(zc) From W1BOMRPL1
Onkey   2 Titled GBOUTS Call S_CTN(zc) From W1BOMRPL1
Onkey 144 Titled GBOUTP Call P_CTN(zc) From W1BOMRPL1
Onkey 146 Titled GBOUTA Call SA_CTN(zc) From W1BOMRPL1
Gosub _AFF
End

Subprog C_CTN(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("CTN","!A",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CTN" : GZNUM = 17435 : Endif
Gosub _AFF
End

$AMM_CTN
Call AM_CTN(zc)
If !mkstat & GOBJET
 zoncou = "CTN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CTN(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CTN(VALEUR) From SUBBOR
If mkstat : GERR = 1 : GZONE = "CTN" : GZNUM = 17435 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZCTN)")>indice
 [M]CTN(indice) = VALEUR
 Affzo ZCTN(indice)
Endif
Gosub _AFF
End

Subprog S_CTN(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "CTN"
PARMSK(2) = "!A"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CTN(VALEUR)
