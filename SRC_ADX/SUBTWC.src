#<AdxTL>@(#)3.0.0.0 $Revision$
###########################################################
## Programme de gestion des centres de charge            ##
###########################################################
## écrit en novembre 1997 par Adeline Lenoir (mod 3/04)  ##
##Modifié par Sylvie Rosset en Mars 2000                 ##
###########################################################
$ACTION
Case ACTION
 When "SETBOUT"  : Gosub SETBOUT
 When "LIENS"    : Gosub LIENS
 When "RAZCRE"   : Gosub RAZCRE
 When "RAZDUP"   : Gosub RAZCRE
 When "ANNULE"   : Gosub ANNULE
 When "CREATION" : Gosub CREATION
 When "MODIF"    : Gosub MODIF
 When "CHANGE"   : Call CHANGE_AXX ("TABWRKCTR", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

###########################################################
$SETBOUT

# pas de charge si tableau vide
If [M:TWC1]NBWST = 0
    Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

Return


###########################################################
#Chargement dans le tableau de tous les postes de charge
#rattachés à ce centre
$LIENS
Local Integer WMAX : WMAX = 299
nolign = 0
Filter [F:MWS] Where WCR = [M:TWC1]WCR
# 03.05 Performances
For [F:MWS]WST1
    If nolign +1 >= WMAX : Break : Endif
    nolign += 1
    [M:TWC1] = [F:MWS]
    #LECTURE du libellé traduisible
    Call LECTEXTRA([M:TWC1]WSTDES(nolign-1),"WORKSTATIO","WSTDESAXX",[M:TWC1]WST(nolign-1),[M:TWC1]WCRFCY(nolign-1)) From ATEXTRA

Next
[M:TWC1]NBWST = nolign
Sorta [M:TWC1]NBWST [M:TWC1]NBWST Order By [M:TWC1]WCRFCY(indice),
&                                          [M:TWC1]WST(indice)
# Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields
If dim([M:TWC1]DSPLEV)>0
    [M:TWC1]DSPLEV = [F:TWC]DSPLEV        # llc 01.01 USA
Endif
Return

###########################################################
#En création ou duplication de centre, effacement du tableau
$RAZCRE
Raz [M:TWC1]NBWST
Return
#############################################################
$ANNULE
Delete [AXX] Where CODFIC="TABWRKCTR" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif

Return
#############################################################
$CREATION
Call MAJTEXTRA([M:TWC1]WCRDESAXX,"TABWRKCTR","WCRDESAXX",[M:TWC1]WCR,"") From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M:TWC1]WCRDESAXX,"TABWRKCTR","WCRDESAXX",[M:TWC1]WCR,"") From ATEXTRA

Return
##########################################################################
## Etiquette ajoutée par le superviseur 15/04/2003 09:56:47 (SR)
##########################################################################
Subprog IB_NBWST
Raz GBOUT1
If [M:TWC1]WST(nolign-1) <> "" : GBOUT1 = mess(225,198,1) : Endif
End

