#<AdxTL>@(#)2.0.0.0 $Revision$
####################################################################################
# Program Name: DCHQNUM
# Description : Check Range Update
# Author      : GRNA
####################################################################################

$ACTION

Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "DEBUT"         : Gosub DEBUT
  When "OK"            : Gosub OK
Endcase

Return


######################################################################################
$OUVRE

# Exit if not coming from [M:CHN]
If dim([M:CHN]NBRCHQ)<=0 : FIN=1 : Return : Endif

Return


######################################################################################
$DEBUT

Raz [M:DCN]
[M:DCN]CHQDEB = [M:CHN]CHQDEB
[M:DCN]CHQFIN = [M:CHN]CHQFIN
Affzo [M:DCN]

Return


######################################################################################
$OK

# If statuses are equal, just exit
If [M:DCN]OLDSTA=[M:DCN]NEWSTA : Return : Endif

# Update lines with old status to new
For NOL=0 To [M:CHN]NBRCHQ-1
  If [M:CHN]STA(NOL)=[M:DCN]OLDSTA & 
&   ((!instr(1,"0123456789",left$([M:CHN]CHQNUM(NOL),1)) & [M:DCN]CHQDEB<=[M:CHN]CHQNUM(NOL) & [M:CHN]CHQNUM(NOL)<=[M:DCN]CHQFIN) |
&    (instr(1,"0123456789",left$([M:CHN]CHQNUM(NOL),1)) & val([M:DCN]CHQDEB)<=val([M:CHN]CHQNUM(NOL)) & val([M:CHN]CHQNUM(NOL))<=val([M:DCN]CHQFIN)))

    [M:CHN]STA(NOL) = [M:DCN]NEWSTA
    If [M:DCN]NEWSTA=1
      Raz [M:CHN]PAYNUM(NOL)
    Endif
    PARAM(1) = "1"
  Endif
Next

Return


######################################################################################
Subprog AS_OLDSTA(VALEUR)
Variable Integer VALEUR

# Disable invalid menu options
GMENLOC(2) = 1  # Issued
GMENLOC(4) = 1  # Posted
GMENLOC(5) = 1  # Cleared

End


######################################################################################
Subprog AS_NEWSTA(VALEUR)
Variable Integer VALEUR

# Disable invalid menu options
GMENLOC(2) = 1  # Issued
GMENLOC(4) = 1  # Posted
GMENLOC(5) = 1  # Cleared

End


######################################################################################
Subprog C_CHQDEB(VALEUR)
Variable Char    VALEUR()

If val(VALEUR)<val([M:CHN]CHQDEB)
  GMESSAGE = mess(83,123,1)
  GERR=1 : mkstat=2 : End
Endif

End


######################################################################################
Subprog C_CHQFIN(VALEUR)
Variable Char    VALEUR()

If val(VALEUR)>val([M:CHN]CHQFIN)
  GMESSAGE = mess(83,123,1)
  mkstat=2 : End
Endif

If val(VALEUR)<val([M:DCN]CHQDEB)
  GMESSAGE = mess(44,199,1)
  mkstat=2 : End
Endif

End

