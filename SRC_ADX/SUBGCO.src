#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GBIDC1, GBIDC2
Call OBJET("GCO",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "MODIF"     : Gosub MODIF
 When "CREATION"  : Gosub CREATION
 When "ANNULE"    : Gosub ANNULE
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "FERME"     : Gosub FERME
 When Default
Endcase
Return

$OUVRE
If clalev([F:CAC])=0  : Local File GACCCODE  [CAC]  : Endif
If clalev([F:CAC2])=0 : Local File GACCCODE  [CAC2] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$INICRE
$INIMOD
If dim([F:GCO]DES)>0
 [F:GCO]DES = [M:GCO1]DESTRA
Endif
If func AFNC.ACTIV("LEG")=0 : [F:GCO]LEG = GDOSLEG(1) : Endif
Return

$LIENS
Call LECTEXTRA([M:GCO1]DESTRA,"GCACCOA","DESTRA",[M:GCO1]COD,"") From ATEXTRA
GCURLEG = [F:GCO]LEG
Return

$MODIF
$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
For I=0 To [M:GCO1]NBRCOA-1
 # Parcours de codes comptables / code plan lié à la transaction
 For [CAC]CAC0(2) With Lock
  For [CAC]CAC0
   J = 0
   If [F:CAC]COA=[M:GCO1]COA(I)
    J=1 : Break
   Elsif [F:CAC]COA>[M:GCO1]COA(I)
    Break
   Endif
  Next
  If !J : Gosub TR1  : Endif
 Next
Next
Return

$TR1
Raz [F:CAC2]
[F:CAC2] = [F:CAC]
Raz [F:CAC2]ACC
[F:CAC2]COA  = [M:GCO1]COA(I)
Write [F:CAC2]
If fstat
 GOK = 0 : Call FSTA("CAC2") From GLOCK
Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GCACCOA","DESTRA",CLECUR1,"","GCACCOA","DESTRA",[M:GCO1]COD,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:GCO1]DESTRA,"GCACCOA","DESTRA",[M:GCO1]COD,"") From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("GCACCOA","DESTRA",[M:GCO1]COD,"") From ATEXTRA
Return

$AP_CHANGE
Call CHGTEXTRA("GCACCOA","DESTRA",[M:GCO1]COD,"",NCODE,"") From ATEXTRA
Return

#######################################################################################
## Etiquettes masque GCO1
######################################################################################
Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

Subprog AM_COA(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:GCO1]COA) From OBJDIV
End
