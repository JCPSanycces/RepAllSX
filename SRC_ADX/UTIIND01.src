#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTIIND01  
# ---------------------------------------------------------------------- #
#      mise a jour du parametre RELEASE uniquement suite à patch 
##########################################################################
Infbox "only update folder by patch"
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

# mettre a jour aussi le dossier X3
#If APPLI="X3" : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTIIND01 (APPLI)  
End



Subprog EXE_UTIIND01(LDOSSIER)
Value Char LDOSSIER

#----- Variables locales -----#
Local Char     WMSG(80)

#-----
Call ECR_TRACE("UTIIND01: Update RELEASE for Folder "+LDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ZZZ]) =0  Local File =LDOSSIER+".ADOVAL"     [ZZZ] : Endif
If clalev([F:ZZA]) =0  Local File ADOSSIER    [ZZA] : Endif


#-----
$MISE_JOUR_RELEASE
#-------------------------------#
#   mise a jour table ADOSSIER  #
#-------------------------------#
Trbegin [ZZA]  
 Read [ZZA]DOSSIER=LDOSSIER
 If fstat = 0
     If [F:ZZA]RELEASE < 7
         Call ECR_TRACE([F:ZZA]DOSSIER+" : "+mess(93,125,1)-"7",0) From GESECRAN 
   
         [F:ZZA]RELEASE = 7
         Rewrite [ZZA]  
         If fstat 
               #  Erreur d'écriture 
               Call ECR_TRACE(mess(26,125,1)-"ADOSSIER"-"RELEASE:7",1) From GESECRAN 
         Endif 
    Endif

 Endif
Commit


# Changement du numéro de RELEASE 
Trbegin [ZZZ] 
 Read [ZZZ]ADW0 = "";"";"RELEASE" 
 If fstat 
      Call ERREUR("ADOVAL",4) From DOSDIC 
 Else
    If [F:ZZZ]VALEUR < "7"
         [F:ZZZ]VALEUR = "7"
         Rewrite [ZZZ] 
         If fstat 
              Call ERREUR("ADOVAL",2) From DOSDIC 
         Endif 
    Endif    
 Endif 

Commit 


#----- Fin du traitement -----#
$FIN_UTIIND01
WMSG ="UTIIND01: end of Update param RELEASE"
Call ECR_TRACE(WMSG,0) From GESECRAN

End


