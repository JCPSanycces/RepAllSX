IMPENT = [M]HRMDADFLG
WNUM = IMPENT
If varinit([M]HRMDADFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]HRMDADFLG,indice)=0
 [M]HRMDADFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "HRMDADFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]HRMDADFLG(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_HRMDADFLG(IMPENT) From SUBFCYB
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "HRMDADFLG" : GZNUM = 47537 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_HRMDADFLG(IMPENT) From SUBFCYB
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "HRMDADFLG" : GZNUM = 47537 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]HRMDADFLG = IMPENT

## Zone HRMDADFCY
mkstat = 0
zoncou = "HRMDADFCY"
indice = 0
WCHAR = [M]HRMDADFCY
If varmode([M]HRMDADFCY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_HRMDADFCY([M]HRMDADFCY) From SUBFCYB
 GACTION = SAVACT
 If mkstat=1 : Raz [M]HRMDADFCY : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "HRMDADFCY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTFCY"
  Call CONTSITE([M]HRMDADFCY) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "HRMDADFCY" : GZNUM = 11232 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("FCY","!$H",[M]HRMDADFCY,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "HRMDADFCY" : GZNUM = 11232 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_HRMDADFCY([M]HRMDADFCY) From SUBFCYB
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "HRMDADFCY" : GZNUM = 11232 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]HRMDADFCY or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_HRMDADFCY([M]HRMDADFCY) From SUBFCYB
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "HRMDADFCY" : GZNUM = 11232 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

