 IMPENT = 1
Endif
If varmode([M]PAYFLG,indice)=0
 [M]PAYFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PAYFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PAYFLG(indice)
 Endif
Endif
[M]PAYFLG = IMPENT

## Zone HRMDADFLG
mkstat = 0
zoncou = "HRMDADFLG"
