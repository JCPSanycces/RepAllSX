#<AdxTL>@(#)3.0.0.0 $Revision$
# Gestion du mask SUBHRHLN0 : ecran de critère de saisie des honoraires

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
 Effzo [M:DIA]FCY
 Grizo [M:DIA]FCY 
Else 
 Actzo [M:DIA]FCY
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
If [M:DIA]ALLFCY=2 : mkstat = 1 : End : Endif
End

Subprog AS_STRDAT(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0]
  VALEUR=gdat$(01,01,val([M:DIA]YEA))
Endif
End

Subprog AS_ENDDAT(VALEUR)
Variable Date     VALEUR
Local Char DAT(12)
If VALEUR=[0/0/0]
 VALEUR=gdat$(31,12,val([M:DIA]YEA))
Endif
End

Subprog AS_ALLPRVNUM(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M:DIA]PRVNUM
 Grizo [M:DIA]PRVNUM
Else 
 Actzo [M:DIA]PRVNUM
Endif
End

Subprog AS_PRVNUM(VALEUR)
Variable Char    VALEUR()
If [M]ALLPRVNUM = 2 : mkstat = 1 : End : Endif
End

Subprog AS_HON(VALEUR)
Variable Integer    VALEUR()
If [M]ALLHON = 2 : mkstat = 1 : End : Endif
End

Subprog AS_ALLHON(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M:DIA]HON
 Grizo [M:DIA]HON
Else 
 Actzo [M:DIA]HON
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran HONLIN0) 06/08/2009 13:20:25 (DBA)
######################################################################################
Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
If dim([M]ALLPRVNUM)>0
 If [M]ALLPRVNUM=2 : Diszo PRVNUM  : Else : Actzo PRVNUM : Endif
Endif
If dim([M]ALLHON)>0
 If [M]ALLHON=2 : Diszo HON  : Else : Actzo HON : Endif
Endif
End


