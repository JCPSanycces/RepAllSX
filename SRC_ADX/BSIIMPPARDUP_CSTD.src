# Description   : Manages duplicate class for Bank import settings (Class BSIIMPPAR)
######################################################################################################
# Updates       :
# Date          |Author |Version| Description
######################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "CODNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub CODNEW_CONTROL
      Endcase
    When Default
  Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


####################################################################

$CODNEW_CONTROL
  If this.CODNEW <> ""
    If func CTRL_EXIST_IMPPAR(this.CODNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("CODNEW",mess(45,7779,1)-":"-this.CODNEW,[V]CST_AERROR)
    Endif
  Endif
Return


####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.CODNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_IMPPAR(this.CODNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("BSIIMPPARNEW",mess(45,7779,1)-":"-this.CODNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_IMPPAR(this.CODIMPPAR, this.CODNEW, WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.CODNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.CODNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return


Funprog CTRL_EXIST_IMPPAR(WCOD)
Value Char WCOD

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WCOD <> ""
    Local File BSIIMPPAR [BSIIP]
    Read [BSIIP]BSIIP0 = WCOD
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [BSIIP]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

Funprog COPY_IMPPAR(WCOD, WCOD_NEW, WERR)
Value Char WCOD
Value Char WCOD_NEW
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AOK
  Local File BSIIMPPAR [BSIIP]
  Read [BSIIP]BSIIP0 = WCOD
  If !fstat
    Local File BSIIMPPAR [BSIIP2]
    Trbegin [BSIIP2]
    [BSIIP2]          = [BSIIP]
    [BSIIP2]CODIMPPAR = WCOD_NEW
    Write [BSIIP2]
    If !fstat
      Commit
    Else
      WOK = [V]CST_AERROR
      WERR = "BSIIMPPAR ("+mess(1,7983,1)+")"
      Rollback
    Endif
    LogicClose File [BSIIP2]
  Else
    WOK = [V]CST_AERROR
    WERR = "BSIIMPPAR ("+mess(7,7983,1)+")"
  Endif
  LogicClose File [BSIIP]
End WOK

