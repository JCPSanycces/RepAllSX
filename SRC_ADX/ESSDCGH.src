#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase
Return

$OUVRE
If clalev([F:DCG])    = 0 : Local File DEMCONGE     [DCG]     : Endif
If clalev([F:ID])     = 0 : Local File EMPLOID      [ID]     : Endif
Default File [F:DCG]
Return

$DEBUT
Local Integer STAT(1..10)

##Update header icon
#[M]WSTA3 = func ESS_FUNCTIONS.SET_ICON(3)
#[M]WSTADES3 = 3
#[M]WSTA4 = func ESS_FUNCTIONS.SET_ICON(4)
#[M]WSTADES4 = 4
#[M]WSTA6 = func ESS_FUNCTIONS.SET_ICON(6)
#[M]WSTADES6 = 6
#[M]WSTA7 = func ESS_FUNCTIONS.SET_ICON(7)
#[M]WSTADES7 = 7

STAT(1) = 1
#STAT(2) = 2
STAT(3) = 3
STAT(4) = 4
#STAT(5) = 5
STAT(6) = 6
STAT(7) = 7

Call POPULATE_MASK(STAT,PARAM(1)) From ESSDCGR

Return

