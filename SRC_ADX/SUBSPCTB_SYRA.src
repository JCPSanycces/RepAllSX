#<AdxTL>@(#)0.0.0.0 $Revision$
#------------------------------------------------------------------------
# tarif groupe : génération traitement
#------------------------------------------------------------------------
$TR_GROUPE
Local Shortint ILK            : # pour ne pas generer Call ALIPLK
#--- pas d'appel à ALIPLK si : absence de SPRICLINK dans les critères
#                              si traitement du prix ( par formule ou coefficient)
#                              si maj des prix nul ( pour test de [F:SPK]FOCITM )
#
#--CPO => plus besoin car la classe des paramètres contient un tableau de paramètres déjà chargés liés à chaque ligne
#ILK= find("SPK",[F:SPC]ABB) + find([F:SPC]PRIPRO,4,5) + ([F:SPC]UPDNULPRI=2)
#--/
Wrseq "Raz UPDGRP"
Wrseq "If !PARAM.GSPLXGRP           : # pour faire une recherche multiple des groupes"
Wrseq "  If sum(PARAM.C_LINE(1..maxtab(PARAM.C_LINE)).GRPFLG)=maxtab(PARAM.C_LINE) : End : Endif"
Wrseq "Endif"

#------------------------------------------------------------------------
#     Generation Boucle primaire (A:NLD) sur les lignes du document

Wrseq ""
Wrseq "#--- Boucle (A:NLD) sur les lignes du document -------------------"
Wrseq "For NLD=1 To maxtab(PARAM.C_LINE)"
Wrseq "  If !PARAM.GSPLXGRP"
Wrseq "    If sum(PARAM.C_LINE(1..maxtab(PARAM.C_LINE)).GRPFLG)=maxtab(PARAM.C_LINE) : Break : Endif"
Wrseq "  Endif"
Wrseq "  If (PARAM.C_LINE(NLD).GRPFLG=0 | PARAM.GSPLXGRP) & UPDGRP(NLD-1)=0"

#--CPO => plus besoin car la classe des paramètres contient un tableau de paramètres déjà chargés liés à chaque ligne
#If ILK                                       : # appel de ALIPLK uniquement si necessaire
#  Wrseq "    SAVNOLIGN=nolign : nolign=NLD"
#  Wrseq "    GALIPLK=TRAIT : Gosub GALIPLK From TRTPRICE"
#  Wrseq "    nolign=SAVNOLIGN"
#Endif

#If find("ITM",[F:SPC]ABB)                   : # lecture systématique ITMMASTER pour tester [F:ITM]SALFLG
  Wrseq "    If [F:ITM]ITMREF<>PARAM.C_LINE(NLD).ITMREF"
  Wrseq "      Read [ITM]ITM0=PARAM.C_LINE(NLD).ITMREF"
  Wrseq "      If fstat : Raz [F:ITM] : Endif"
  Wrseq "    Endif"
#Endif

If find("ITS",[F:SPC]ABB)                    : # lecture ITMSALES si present dans les criteres
  Wrseq "    If [F:ITS]ITMREF<>PARAM.C_LINE(NLD).ITMREF"
  Wrseq "      Read [ITS]ITS0=PARAM.C_LINE(NLD).ITMREF"
  Wrseq "      If fstat : Raz [F:ITS] : Endif"
  Wrseq "    Endif"
Endif

If find("BPD",[F:SPC]ABB)                    : # lecture BPDLVCUST si present dans les criteres
  Wrseq "    If    dim(PARAM.C_LINE(NLD).DBPAADD)>0   [L]WBPAADD=PARAM.C_LINE(NLD).DBPAADD"
  Wrseq "    Elsif dim(PARAM.BPAADD)>0           [L]WBPAADD=PARAM.BPAADD"
  Wrseq "    Endif"
  Wrseq "    If [F:BPD]BPCNUM<>[F:BPC]BPCNUM | [F:BPD]BPAADD<>[L]WBPAADD"
  Wrseq "      Read [BPD]BPD0=[F:BPC]BPCNUM;[L]WBPAADD"
  Wrseq "      If fstat : Raz [F:BPD] : Endif"
  Wrseq "    Endif"
Endif

If find("REP",[F:SPC]ABB)                    : # lecture SALESREP si present dans les criteres
  Wrseq "    If [F:REP]REPNUM<>PARAM.C_LINE(NLD).REP1"
  Wrseq "      Read [REP]REP0=PARAM.C_LINE(NLD).REP1"
  Wrseq "      If fstat : Raz [F:REP] : Endif"
  Wrseq "    Endif"
Endif

If find("SPK",[F:SPC]ABB)                    : # lecture SPRICELINK si present dans les criteres
Wrseq "#--Transclasse [F:SPK] with PARAM.C_SPKH(1) et PARAM.C_LINE(NLD).C_SPKD(1)"
Wrseq "If PARAM.C_SPKH(1)<>null"
Wrseq "  WERR = fmet PARAM.C_SPKH(1).LOAD_TO_SPK_FILE()"
Wrseq "  If WERR >= [V]CST_AERROR"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', mess(68,123,1)-':'-mess(1,7845,1)-'LOAD_TO_SPK_FILE', WERR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq "If PARAM.C_LINE(NLD).C_SPKD(1)<>null"
Wrseq "  WERR = fmet PARAM.C_LINE(NLD).C_SPKD(1).LOAD_TO_SPK_FILE()"
Wrseq "  If WERR >= [V]CST_AERROR"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', mess(68,123,1)-':'-mess(1,7845,1)-'LOAD_TO_SPK_FILE', WERR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq ""
Endif

Wrseq "    If [F:ITM]SALFLG=2                : # Application de la recherche uniquement sur les articles vendus"
Wrseq "      If !find(PARAM.C_LINE(NLD).C_SPKD(1).LINTYP,10)      : # L'application de la recherche ne se fait pas sur les articles sous-traités"
Wrseq "        WCRIT=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:SPC]FLD(I)<>""
    Case [F:SPC]FLDTYP(I)
    When "CCE"
      Wrseq "[F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(max(find('";[F:SPC]CRIDIE(I);"',[F:";[F:SPC]ABB(I);"]DIE)-1,0))+'~'";
    When "C", "L", "DCB", "M"
      Wrseq "num$([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";num$([F:SPC]CRIIND(I));"))+'~'";
    When "D"
      Wrseq "num$(val([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";num$([F:SPC]CRIIND(I));")))+'~'";
    When Default
      Wrseq "[F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";num$([F:SPC]CRIIND(I));")+'~'";
    Endcase
  Else
    Wrseq "'~'";
  Endif
Next I
Wrseq
Wrseq "        Gosub CRIT_IDEM_NLD"
Wrseq "      Endif"
Wrseq "    Endif"
Wrseq "  Endif"
Wrseq "Next"
Wrseq "End"
Wrseq ""

#------------------------------------------------------------------------
#     Generation Boucle secondaire (B:SPL) sur les lignes de tarif ayant :
#        - critères de la ligne en cours de la boucle (A:NLD)
#        - valides a la date du document
#        - de meme devise ( uniquement si conversion devise a Non )
#        - pas de filtre des unites ( selection effectuee sur les lignes )

Gosub TR_GRP_CI_NLD From SUBSPCT_SYRA

Return

$CONSULTATION
#--CPO Dépassement du nombre d'instructions possible

Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Pour extraction et stockage des lignes de toutes les fiches"
Wrseq "# stockage dans le masque SPSIMUL0 ( utilisé dans FUNVENSPSI )"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$CONSULTATION"
Wrseq "Local Date DATPLUS     : # date borne de simulation des tarifs (+1mois par défaut)"
Wrseq "Local Decimal QTYPLUS  : # qté  borne de simulation des tarifs (+100% si PARAM.C_LINE(PLINEDOC).QTY<>0)"
Wrseq "Local Decimal QTYMOINS : # qté  borne de simulation des tarifs (-50%  si PARAM.C_LINE(PLINEDOC).QTY<>0)"
Wrseq "Local Integer ONPREND,JLV,ILINE, IRETLINE"
Wrseq "If dim(PARAM.MOIS)>0 DATPLUS=addmonth(PARAM.DOCDAT,PARAM.MOIS) Else DATPLUS=addmonth(PARAM.DOCDAT,1) Endif"
Wrseq "If PARAM.C_LINE(PLINEDOC).QTY<>0 : QTYMOINS=PARAM.C_LINE(PLINEDOC).QTY*0.5 : QTYPLUS=PARAM.C_LINE(PLINEDOC).QTY*2 : Endif"
Wrseq "# Les critères existent ?"
For I=0 To 4
 If [F:SPC]ABB(I)<>""
  Wrseq "If dim([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";[F:SPC]CRIIND(I);")) < 0 : Return : Endif"
 Endif
Next I

Wrseq "# Lecture des tarifs"
Wrseq "Filter [SPL] Where PLI='"+[F:SPC]PLI+"'"
Wrseq "&  & PLICRI=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:SPC]FLD(I)<>""
     If [F:SPC]FLDTYP(I)="CCE"
        Wrseq "num$([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(max(find('";[F:SPC]CRIDIE(I);"',[F:";[F:SPC]ABB(I);"]DIE)-1,0)))+'~'";
     Elsif [F:SPC]FLDTYP(I)="D"     : # si critere de type date
        Wrseq "num$(val([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";[F:SPC]CRIIND(I);")))+'~'";
     Else                       : # autres types
        Wrseq "num$([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";[F:SPC]CRIIND(I);"))+'~'";
     Endif
  Else
     Wrseq "'~'";
  Endif
Next
Wrseq
#--CPO ajout [F:SPL] devant PLISTRDAT et PLIENDDAT => afin de ne pas confondre
Wrseq "&  & [F:SPL]PLISTRDAT<=[L]DATPLUS"
Wrseq "&  & [F:SPL]PLIENDDAT>=PARAM.DOCDAT"
#--/
If [F:SPC]UOMCNVFLG=1 & ZZ(8)=1
  Wrseq "&  & UOM=PARAM.C_LINE(PLINEDOC).SAU"
Endif
If [F:SPC]CURCNVFLG=1 & SAISIEDEV=1
  Wrseq "&  & CUR=PARAM.CUR"
Endif
# Wrseq "&    Order by Key SPL1"
Wrseq "&    Order by PLI; PLICRI; PLISTRDAT; MAXQTY"

Wrseq "For [SPL]"
If [F:SPC]PRIQTYFLG=2
  Wrseq "Raz ONPREND"
Else
  Wrseq "ONPREND=1"
Endif
Wrseq "  COEFUNITE=1 : COEFPOURN=1 : COEFDEVISE=1"
Wrseq "  If [F:SPL]UOM='*' : [F:SPL]UOM=[F:ITM]SAU : Endif"
If [F:SPC]PRIPRO<4
  Wrseq "  If [F:SPL]PRIDIV<>0 : COEFPOURN=[F:SPL]PRIDIV : Endif"
Endif
Wrseq "  If dim(COEFUNITE)>1 : COEFUNITE(1)=0 : Endif"
If [F:SPC]CURCNVFLG=2
# Bug 60443
  Wrseq "  If [F:SPL]CUR<>PARAM.CUR"
  #--CPO
  #Wrseq "    If [F:SPL]CUR<>PARAM.CUR & [F:SPL]CUR=GLOCALDEV & val(PARAM_T(2))<>0"
  #Wrseq "      COEFDEVISE=val(PARAM_T(2))"
  Wrseq "    If [F:SPL]CUR<>PARAM.CUR & [F:SPL]CUR=PARAM.GLOCALDEV & PARAM.MLTDIVCOE<>0"
  Wrseq "      COEFDEVISE=PARAM.MLTDIVCOE"
  ##--/
  Wrseq "    Else"
  Wrseq "      Call CONVERT(PARAM.ACTX,[F:SPL]CUR,PARAM.CUR,PARAM.GLOCALDEV,PARAM.CHGTYP,PARAM.DOCDAT,1000000000000.00,COEFDEVISE,WBIDI) From TRTDEV_SYRA"
  Wrseq "      If WBIDI=0 & COEFDEVISE<>0 COEFDEVISE=COEFDEVISE/1000000000000.00 Else COEFDEVISE=1 Endif"
  Wrseq "    Endif"
  Wrseq "  Endif"
# Bug 60443
Endif
If [F:SPC]UOMCNVFLG=2 : # si conversion unité acceptée
  Wrseq "# Conversion qte mini maxi (pas d'arrondi)"
  Wrseq "  If [F:SPL]UOM<>PARAM.C_LINE(PLINEDOC).SAU"
  Wrseq "    Call SREC_COE ([F:ITM]ITMREF,[F:BPC]BPCNUM,[F:SPL]UOM,PARAM.C_LINE(PLINEDOC).SAU,COEFUNITE) From TRTVENQTE_SYRA"
  Wrseq "    If COEFUNITE=0 : ONPREND=0 : Goto SI_ONPREND : Endif"
  Wrseq "    [F:SPL]MINQTY   = [F:SPL]MINQTY/COEFUNITE"
  Wrseq "    [F:SPL]MAXQTY   = [F:SPL]MAXQTY/COEFUNITE"
  Wrseq "    [F:SPL]FOCQTYMIN= [F:SPL]FOCQTYMIN/COEFUNITE"
  Wrseq "    [F:SPL]FOCQTYBKT= [F:SPL]FOCQTYBKT/COEFUNITE"
  If [F:SPC]FOCPRO=2 : # si qté gratuite sur meme article
  Wrseq "    [F:SPL]FOCQTY   = [F:SPL]FOCQTY/COEFUNITE"
  Wrseq "    Call QTEARR ([F:SPL]FOCQTY,PARAM.C_LINE(PLINEDOC).SAU) From TRTDIV_SYRA"
  Endif
  Wrseq "  Endif"
Endif
If [F:SPC]PRIQTYFLG=2
  Wrseq "  If    PARAM.C_LINE(PLINEDOC).QTY=0"
  Wrseq "    ONPREND=1"
  Wrseq "  Elsif QTYPLUS>=[F:SPL]MINQTY & QTYMOINS<=[F:SPL]MAXQTY"
  Wrseq "    ONPREND=1"
  Wrseq "  Endif"
Endif
Wrseq "$SI_ONPREND"
Wrseq "  If ONPREND=1"
#--CPO ajout => il faut instancier les éléments de la collection
Wrseq "    JLV = fmet RESULT.ADDLINE('C_PRICEINQ',JLV)" #11)"
Wrseq "    If JLV = [V]CST_ANOTDEFINED"
Wrseq "      #--The insertion was not possible"
Wrseq "      WMESSAGE= func ASYRFNC.MES2(mess(266,133,1),'C_PRICEINQ','RESULTPRICE')"
Wrseq "      [L]WERR = fmet RESULT.ASETERROR('', WMESSAGE, [V]CST_AERROR)"
Wrseq "      Return"
Wrseq "    Endif"
#--
#Wrseq "    JLV=[M:SPM0]NBTAR"
Wrseq "    RESULT.C_PRICEINQ(JLV).DATDEB   = [F:SPL]PLISTRDAT"
Wrseq "    RESULT.C_PRICEINQ(JLV).DATFIN   = [F:SPL]PLIENDDAT"
Wrseq "    RESULT.C_PRICEINQ(JLV).MINQTY   = [F:SPL]MINQTY"
Wrseq "    RESULT.C_PRICEINQ(JLV).MAXQTY   = [F:SPL]MAXQTY"
Wrseq "    RESULT.C_PRICEINQ(JLV).MINAMT   = [F:SPL]MINAMT"
Wrseq "    RESULT.C_PRICEINQ(JLV).MAXAMT   = [F:SPL]MAXAMT"
Wrseq "    RESULT.C_PRICEINQ(JLV).CUR      = [F:SPL]CUR"
Wrseq "    If [F:SPL]UOM<>''"
Wrseq "      RESULT.C_PRICEINQ(JLV).UOM    = PARAM.C_LINE(PLINEDOC).SAU"
Wrseq "    Endif"
Wrseq "    RESULT.C_PRICEINQ(JLV).LTI      = [F:SPL]LTI"
Wrseq "    RESULT.C_PRICEINQ(JLV).PRIDIV   = [F:SPL]PRIDIV"
If [F:SPC]PRIPRO=4
    Wrseq "    RESULT.C_PRICEINQ(JLV).COE      = [F:SPL]PRI"          : # coefficient
  Else
    Wrseq "    RESULT.C_PRICEINQ(JLV).PRI      = [F:SPL]PRI"          : # prix
Endif
If [F:SPC]PRIPRO<4
  Wrseq "    If [F:SPL]PRIDIV<>0 : RESULT.C_PRICEINQ(JLV).PRI=[F:SPL]PRI/[F:SPL]PRIDIV : Endif"
  Wrseq "    RESULT.C_PRICEINQ(JLV).PRI=RESULT.C_PRICEINQ(JLV).PRI*COEFUNITE"
Endif
Wrseq "    RESULT.C_PRICEINQ(JLV).FOCQTYMIN = [F:SPL]FOCQTYMIN"
Wrseq "    RESULT.C_PRICEINQ(JLV).FOCQTYBKT = [F:SPL]FOCQTYBKT"
Wrseq "    RESULT.C_PRICEINQ(JLV).FOCUOM    = [F:SPL]FOCUOM"
Wrseq "    RESULT.C_PRICEINQ(JLV).FOCQTY    = [F:SPL]FOCQTY"
Wrseq "    If dim(RESULT.C_PRICEINQ(JLV).PLISEA)>0"
Wrseq "        RESULT.C_PRICEINQ(JLV).PLISEA = ";num$([F:SPC]PLISEA)
Wrseq "    Endif"
Wrseq "    RESULT.C_PRICEINQ(JLV).PLI       = [F:SPL]PLI"
Wrseq "    RESULT.C_PRICEINQ(JLV).PLICRD    = [F:SPL]PLICRD"
Wrseq "    RESULT.C_PRICEINQ(JLV).PLILIN    = [F:SPL]PLILIN"
#For I=1 To dim([F:SPL]DCGVAL)
  #--CPO ajout => il faut instancier les éléments de la collection
#  Wrseq "  For ILINE=1 To dim([F:SPL]DCGVAL)"
#  Wrseq "    If RESULT.C_PRICEINQ(JLV).C_FRAREM(";I;") = null"
#  Wrseq "      WLINE = fmet RESULT.C_PRICEINQ(JLV).ADDLINE('C_FRAREM',";I;")"
#  Wrseq "      If WLINE = [V]CST_ANOTDEFINED"
#  Wrseq "        #--The insertion was not possible"
#  Wrseq "        WMESSAGE = 'Data Class SPRICESEARCH : Method call LOADDOCFROMRESULT result error for RESULT.C_PRICEINQ(JLV).ADDLINE:'"
#  Wrseq "        [L]WERR = fmet RESULT.ASETERROR('', WMESSAGE, [V]CST_AERROR)"
#  Wrseq "        Return"
#  Wrseq "      Endif"
#  Wrseq "    Endif"
#  #--
#  Wrseq "    If dim(RESULT.C_PRICEINQ(JLV).C_FRAREM(";I;").FRAREM)>0"
#  Wrseq "      RESULT.C_PRICEINQ(JLV).C_FRAREM(";I;").FRAREM=[F:SPL]DCGVAL(";I-1;")";
  Wrseq "  For ILINE=1 To dim([F:SPL]DCGVAL)"
  Wrseq "    If RESULT.C_PRICEINQ(JLV).C_FRAREM(ILINE) = null"
  Wrseq "      IRETLINE = fmet RESULT.C_PRICEINQ(JLV).ADDLINE('C_FRAREM',ILINE)"
  Wrseq "      If IRETLINE = [V]CST_ANOTDEFINED"
  Wrseq "        #--The insertion was not possible"
  Wrseq "        [L]WMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'C_FRAREM','RESULTPRICE.C_PRICEINQ')"
  Wrseq "        [L]WERR     = fmet RESULT.ASETERROR('', [L]WMESSAGE, [V]CST_AERROR)"
  Wrseq "        Break"
  Wrseq "      Endif"
  Wrseq "    Endif"
  #--
  Wrseq "    If dim(RESULT.C_PRICEINQ(JLV).C_FRAREM(IRETLINE).FRAREM)>0"
  Wrseq "      RESULT.C_PRICEINQ(JLV).C_FRAREM(IRETLINE).FRAREM=[F:SPL]DCGVAL(ILINE-1)";
#           si colonne en montant et par unité
  If [F:PRS]VALTYP(I-1)=1 & [F:PRS]CLCRUL(I-1)=1
    Wrseq "/COEFPOURN*COEFUNITE"
  Else
    Wrseq ""
  Endif
  Wrseq "    Endif"
  Wrseq "  Next ILINE"
#Next I

#--CPO Problème des Points d'entrée
Wrseq "    Gosub PE_SIMTARIF From TRTPRICE_SYRA"
#--/
Wrseq "    RESULT.NBPRICEINQ += 1 : JLV += 1" :#[M:SPM0]NBTAR += 1
Wrseq "  Endif"

Wrseq "Next"
Wrseq ""
Wrseq "Filter [SPL]"
Wrseq "Return"

Return
