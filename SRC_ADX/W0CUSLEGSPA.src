#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CUSLEGSPA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SPACUSDAT
mkstat = 0
zoncou = "SPACUSDAT"
indice = 0
If varmode([M]SPACUSDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPACUSDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SPACUS
mkstat = 0
zoncou = "SPACUS"
indice = 0
If varmode([M]SPACUS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPACUS" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SPACUSBPR
mkstat = 0
zoncou = "SPACUSBPR"
indice = 0
If varmode([M]SPACUSBPR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPACUSBPR" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("BPS","!",[M]SPACUSBPR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SPACUSBPR" : GZNUM = 48854 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CUSLEGSPA"
Return

