#<AdxTL>@(#)5.0.0.0 $Revision$
#######################################################################################
##                                                                                    #
## Historisation / Epuration  -  Module Immobilisations                               #
##                                                                                    #
#######################################################################################
#   - ISSAAS    : Historisation / Epuration des biens sortis d'actif                  #
#   - CLOEVE    : Historisation / Epuration des événements des exercices clos         #
#   - CLODPR    : Historisation / Epuration des amortissements antérieurs             #
#######################################################################################
#    GBO - 20.01.2011 FQ68447 : Contrôle des sources 
#######################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End


$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "HISTO"    : Gosub HISTO
 When "EPURE"    : Gosub EPURE
 When "FERME"    : Gosub FERME
Endcase
Return

$OUVRE
Case [F:AHI]COD
    When "ISSAAS"
        If clalev([F:FIS]) =0 : Local File FISCYEAR   [FIS]  : Endif
        If clalev([F:LOF]) =0 : Local File LAYOUTFAS  [LOF]  : Endif
        If clalev([F:EFS]) =0 : Local File EVEFAS     [EFS]  : Endif
        If clalev([F:ELF]) =0 : Local File EVELOF     [ELF]  : Endif
        Gosub LOAD_CNXDAT
    When "CLOEVE" , "CLODPR"
        If clalev([F:FIS]) =0 : Local File FISCYEAR   [FIS]  : Endif
        Gosub LOAD_CNXDAT
Endcase
Return

$LOAD_CNXDAT
# Chargement en tableau des dates de fin des derniers exercice clos / sociétés et contextes 
Local Integer I_SOC, I_CNX
Local Date CNX_LSTCLODAT(1..GNBSOC,1..G300MAX)
For I_SOC=1 To GNBSOC
  If GSOC(I_SOC)=SOCIETE | SOCIETE=""
    For I_CNX=1 To G300MAX
      Filter [FIS] Where CPY=GSOC(I_SOC) & CNX=I_CNX & STAFIY=1
      Read [FIS]FIY0 Last
      If !fstat
        CNX_LSTCLODAT(I_SOC,I_CNX)=[F:FIS]DATENDFIY
      Endif
    Next I_CNX
  Endif
Next I_SOC
Return

$HISTO
Case TABLE
    When "FXDASSETS"
        Gosub VERIF_FIY
        If OKHIS : Gosub HISTO_EFS : Endif
        If OKHIS : Gosub HISTO_LOF : Endif
    When "GACCENTRY"
        Gosub HISTOHAE
    When "BALANCE" , "BALANA" , "GCOMMIT"
        Gosub VERIF_FIY
Endcase
Return

$VERIF_FIY
I_SOC=find([F:F1]CPY,GSOC(1..GNBSOC))

# Plan à contexte
If dim([F:F1]PLN)>0
  I_CNX=[F:F1]PLN - 4
Elsif dim([F:F1]DPRPLN)>0
  I_CNX=[F:F1]DPRPLN - 4
Else
  I_CNX=1
Endif
If I_CNX < 1 : I_CNX=1 : Endif

If !I_SOC | CNX_LSTCLODAT(I_SOC,I_CNX) < evalue("[F:F1]"+[F:AHD]DATFLD)
  OKHIS = 0
Endif
Return

$HISTO_EFS
$EPUR_EFS
If ![L]SIMUL
  Delete [EFS] Where REF=[F:F1]AASREF
  If fstat=1
    [V]GOK = -1 : [V]GLOCK = "$EVEFAS"-[F:F1]AASREF : Return
  Endif
Endif
Return

$HISTO_LOF
For [LOF] Where AASREF=[F:F1]AASREF
  For [ELF] Where REF=[F:LOF]CODLOF & LIN=[F:LOF]LINLOF
    #
  Next
Next
Return

$HISTOHAE
Gosub VERIF_FIY
If !OKHIS  : Return : Endif
For [DAE]DAE0 Where TYP=[F:F1]TYP & NUM=[F:F1]NUM

#Call ECR_TRACE([F:DAE]TYP-num$([F:DAE]NUM)-[F:DAE]ACC,1) From GESECRAN

    If [F:DAE]ACC<>""
    Read [GAC]GAC0 = [F:DAE]ACC
        If [F:GAC]MTC=2

    # On n'historise pas si la pièce comporte :
    # - une ligne d'écriture non lettrée sur un compte lettrable
    # - ou une ligne d'écriture lettrée en miniscule
    # - ou une écriture lettrée avec une pièce dont la date est supérieure à la date d'historisation

            If [F:DAE]MTC<"A" or [F:DAE]MTC>"ZZZZZ" or [F:DAE]MTCDATMAX>date$-TEMPS
                OKHIS = 0

#Call ECR_TRACE([F:DAE]TYP-num$([F:DAE]NUM)-"*"-[F:DAE]MTC-"*"-num$([DAE]MTCDATMAX)-"*"-num$(date$-TEMPS),1) From GESECRAN

     # Si on trouve sur la pièce à conserver des lignes lettrées en majuscule et avec une date maximale
     # de lettrage inférieure ou égale à la date jusqu'à laquelle on épure, on met à 1 le champ FLGMTC  

                
                For [DAE2]DAE0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIG<>[F:DAE]LIN & MTC<>""
                    If [F:DAE2]MTC>"A" & [F:DAE2]MTC<"ZZZZZ" & [F:DAE2]MTCDATMAX<=date$-TEMPS
                       [F:DAE2]FLGMTC = 1
                       Rewrite [DAE2]
                       If fstat
                          Call ECR_TRACE(mess(13,100,1)-"GACCENTRYD [DAE2]"-mess(12,107,1)-
&                                    [F:DAE2]TYP-[F:DAE2]NUM-tolower(mess(3,61,1))-num$([F:DAE2]LIN),1) From GESECRAN
                        Endif
                    Endif
                Next
                If OKHIS = 0 : Break : Endif  
            Endif
        Endif
    Endif
Next
Return

$EPURE
# Même contrôle que l'historisation
Local Integer SVG_OKHIS
SVG_OKHIS = OKHIS
OKHIS = OKEPU
Gosub HISTO
OKEPU = OKHIS
OKHIS = SVG_OKHIS
Return

$FERME
Case TABLE
 When "ISSAAS"
  If clalev([F:FIS])>0 : Close Local File [FIS]  : Endif
  If clalev([F:LOF])>0 : Close Local File [LOF]  : Endif
  If clalev([F:EFS])>0 : Close Local File [EFS]  : Endif
  If clalev([F:ELF])>0 : Close Local File [ELF]  : Endif
 When "GACCENTRY" , "BALANCE" , "BALANA" , "GCOMMIT"
  If clalev([F:FIS])>0 : Close Local File [FIS] : Endif
Endcase 
Return
