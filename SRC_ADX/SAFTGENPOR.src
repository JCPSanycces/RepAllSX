#######################################################################################
#######################################################################################
$OPEN_FILE
#Onerrgo $ERROR
#opening file to write to (on temporary folder)
#[L]FILEPATHTMP = filpath('tmp','SAFT_PT_'+[L]SOC+"_"+format$("D:DDMMYYYYhhmmss", date$),'xml')

Case [L]SAFTTYPE
  When 2
    [L]HETTAXACCBAS = "I"
  When 3
    [L]HETTAXACCBAS = "F"
  When 4
    [L]HETTAXACCBAS = "C"
  When 5, 7
    [L]HETTAXACCBAS = "S"
  When 6, 8
    [L]HETTAXACCBAS = "P"
Endcase

NAM    = 'SAFT_PT_'+[L]SOC+"_"+[L]HETTAXACCBAS+"_"+format$("D:DDMMYYYYhhmmss", date$)
EXT    = "xml"

FICHIER = [M:SAFT]FIC
Call MACHINE(FICHIER,MACHINE,CHEMIN) From ORDSYS
NOMFIC  = [L]NAM

If [L]FILDESTYP=1 : # Client
 FICHIER = filpath(CHEMIN,NOMFIC,EXT)
 Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
Else
 FICDON = filpath(CHEMIN,NOMFIC,EXT,"","",MACHINE)
 If filinfo(FICDON,7)>0
  ## Fichier existant, souhaitez-vous l'écraser ?
  Call OUINON(mess(127,105,1), OK) From GESECRAN
  If OK=1 : Return : Endif
 Endif
Endif

#empty file if exists
Openo [L]FICDON, 0              Using [SAFT]
Iomode adxirs chr$(10)          Using [SAFT]
Iomode adxifs ''                Using [SAFT]
Iomode adxium 50                Using [SAFT]

Wrseq '<?xml version="1.0" encoding="Windows-1252"?>' Using [SAFT]
Wrseq '<AuditFile xmlns="urn:OECD:StandardAuditFile-Tax:PT_'+[L]SAFTVER+'" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">' Using [SAFT]
#Onerrgo

Return
#######################################################################################
#######################################################################################
$WRITE_TAGS
#Call OUVRE_BOITE("SAF-T",0) From GESECRAN

[L]RECSWRI = 0
#Header section
SECTION = "Header"
Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
Gosub HEADER From SAFTGENPORHD
Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created
If !OK : Goto FIM : Endif

Gosub OPENMASTERFILES From SAFTGENPORTG

[L]RECSWRI = 0
#GeneralLedger section
If find([L]SAFTTYPE,2,4)
  SECTION = "GeneralLedger"
  Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
  Gosub GENERALLEDGER From SAFTGENPORGLE
  Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created
Endif

[L]RECSWRI = 0
#Customers section
SECTION = "Customers"
Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
Gosub CUSTOMERS From SAFTGENPORBPC
Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created

[L]RECSWRI = 0
#Suppliers section
If find([L]SAFTTYPE,2,3,4,8)
  SECTION = "Suppliers"
  Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
  Gosub SUPPLIERS From SAFTGENPORBPS
  Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created
Endif

[L]RECSWRI = 0
#Products section
If find([L]SAFTTYPE,2,3)
  SECTION = "Products"
  Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
  Gosub PRODUCTS From SAFTGENPORITM
  Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created
Endif

[L]RECSWRI = 0
#TaxTable section
If find([L]SAFTTYPE,2,3,6,7)
  SECTION = "TaxTable"
  Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
  Gosub TAX_TABLE From SAFTGENPORVAT
  Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created
Endif
Gosub CLOSEMASTERFILES     From SAFTGENPORTG

[L]RECSWRI = 0
#GeneralLedgerEntries section
If find([L]SAFTTYPE,2,4)
  SECTION = "GeneralLedgerEntries"
  Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
  Gosub GENLEDGENT From SAFTGENPORGLENT
  Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created
Endif

[L]RECSWRI = 0
#SourceDocuments section
#Invoices
If find([L]SAFTTYPE,2,3,6)
  SECTION = "SourceDocuments:Invoices"
  Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
  Gosub INVOICES From SAFTGENPORSIH
  Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created
Endif

[L]RECSWRI = 0
#MovementofGoods
If find([L]SAFTTYPE,2,3,8)
  SECTION = "SourceDocuments:MovementofGoods"
  Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
  Gosub MOVEGOODS From SAFTGENPORMG
  Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created
Endif

[L]RECSWRI = 0
#WorkingDocuments
If find([L]SAFTTYPE,2,3)
  SECTION = "SourceDocuments:WorkingDocuments"
  Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
  Gosub WORKDOCUMENTS From SAFTGENPORWD
  Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created
Endif

[L]RECSWRI = 0
#Payments
If find([L]SAFTTYPE,2,3,4,6)
  SECTION = "SourceDocuments:Payments"
  Call ECR_TRACE (func AFNC.MES1(mess(22,7711,1), SECTION) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN
  Gosub PAYMENT From SAFTGENPORPYH
  Call ECR_TRACE ("   " + num$([L]RECSWRI)-mess(103,141,1), 0) From GESECRAN # n records created
Endif

$FIM
#Call FERME_BOITE From GESECRAN
Call ECR_TRACE (mess(31,154,1) - format$("D:DD[-]MM[-]YYYY", date$) + " " + time$, 0) From GESECRAN

Return
#######################################################################################
#######################################################################################
$CLOSE_FILE

Wrseq '</AuditFile>' Using [SAFT]

#close the file
Openo Using [SAFT]

[L]STAT = 0

#
#If [M:SAFT]TYPEXP=1 : # Client
#  # Check that de file to copy is existing
#  If filinfo([L]FILEPATHTMP, 7) < 0 Then
#    GMESSAGE = mess(4,95,1) - [L]FILEPATHTMP - tolower(mess(87,100,1))
#    GERR = 1
#    Return
#  Else
#    Call COPCLI([L]FILEPATHTMP, [M:SAFT]NOMIMP, [L]STAT) From ORDSYS
#    If [L]STAT=1
#      Call ERREUR(mess(164,141,1)) From GESECRAN
#    Elsif [L]STAT>1
#      Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
#    Endif
#  Endif
#
#Else
#  Call MOVE([L]FILEPATHTMP, [M:SAFT]NOMIMP, [L]STAT) From ORDSYS
#  If [L]STAT : Call ERREUR (mess(23,7711,1) + " ("+num$([L]STAT)+")") From GESECRAN : Endif
#Endif

If [L]FILDESTYP=1
 Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : TRA=0
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 : TRA=0
 Endif
Endif

Return
#######################################################################################
#######################################################################################
$ERROR

GMESSAGE = mess(93,100,1)- num$(errl) - "("+errp+"):" - errmes$(errn)+"\"+errm
OK = 0

Resume
#######################################################################################
#######################################################################################
$ERRONTAGWRI

Call ERREUR (mess(93,100,1)- num$(errl) - "("+errp+"):" - errmes$(errn)+"\"+errm) From GESECRAN
Call FERME_BOITE From GESECRAN

Resume
