#######################################################################################
#######################################################################################
$CHECK_ACCDOCS_STA

# Issue 114518 - 2016-02-18 by RICAR : Verification of accounting documents with Temporary status
# Issue 114518
If find([L]SAFTTYPE,2,4) Then
  Local Integer V_MSG

  If !clalev([F:HAE]) : Local File GACCENTRY  [HAE] : Endif
  If !clalev([F:JOU]) : Local File GJOURNAL   [JOU] : Endif
  If !clalev([F:GTE]) : Local File GTYPACCENT [GTE] : Endif

  Link [F:HAE] With [F:JOU]JOU0 = [F:HAE]JOU, [F:GTE]GTE0=[F:HAE]TYP  As [CTA]
&  Where [F:GTE]PER <> 2 & [F:HAE]CAT = 1 & [F:HAE]ACCDAT >= [L]STRDATE & [F:HAE]ACCDAT  <= [L]ENDDATE &
& [F:HAE]CPY=[L]SOC & [F:HAE]STA <> 2
  For [CTA]
    Call ECR_TRACE (func AFNC.MES1 (mess(198,7711,1),[F:HAE]NUM),0) From GESECRAN
    [L]V_MSG = 1
  Next

  If clalev([CTA]) = 1 : Close File [CTA] : Endif

  If [L]V_MSG=1
    Call ECR_TRACE (mess(199,7711,1),1) From GESECRAN
    OK = 0
  Endif

Endif
# End issue 114518

Return
#######################################################################################
#######################################################################################
$INITIALIZE_VERSION_MANAGEMENT

# Issue X3-31864 - 2017-04-06 by MRDAB: declare var to hold text informing about version current(1) or previous(0)
Local Char        SAFTVER(30)
Local Tinyint     ISSAFTVERCURRENT

#If this label is updated, consider PORLEGETFATLIB
[L]SAFTVER   =  mess ([L]VERSION, 2082, 1)

If [L]SAFTVER = "1.04_01"
  [L]ISSAFTVERCURRENT = 1
Else
  [L]ISSAFTVERCURRENT = 0
Endif
# End issue X3-31864

Return
#######################################################################################
#######################################################################################
$SET_LEDT
#Also called from DKSLIB

#Ledgertype
Call PARAM([L]SOC, "LEDTYP", [L]LEDTA) From ADOVAL
[L]LEDT = val([L]LEDTA)
If [L]LEDT = 0
  ###--- Get the main general ledger                                 ---###
  Call LECLEDMAIN(1, [L]SOC, [L]LEDT) From CPTDIV
Endif

Return
#######################################################################################
#######################################################################################
$SET_COA

Read [F:CPY]CPY0=[L]SOC
Read [F:GCM]GCM0=[F:CPY]ACM
Read [F:LED]LED0=[F:GCM]LED([L]LEDT-1)
[L]COA = [F:LED]COA

Return
#######################################################################################
#######################################################################################
$SET_SAFPRIRND

Call PARAM([L]SOC, "SAFTPRIRN",[L]SAFPRIRNC) From ADOVAL

If SAFPRIRNC = "" | SAFPRIRNC = "0"
  SAFPRIRNC = "0.0001"
Endif

SAFPRIRND = val(SAFPRIRNC)

Return
#######################################################################################
#######################################################################################
$SET_SAFTPRDKITACTIVE

# Issue X3-105529 by MRDAB: fixed KIT communication in SAF-T
If func AFNC.ACTIV("SAFT")
  Call PARAM([L]SOC, "SAFTPRDKIT", [L]SAFTPRDKITACTIVE) From ADOVAL
Endif
# If parameter is not set the default value is YES
If [L]SAFTPRDKITACTIVE = "" | [L]SAFTPRDKITACTIVE = "0"
  [L]SAFTPRDKITACTIVE = "2"
Endif
# Issue X3-105529 end

Return
#######################################################################################
#######################################################################################
Funprog GET_PERIOD_NUMBER(CPY, DAT)
#Issue 86039 – 2018-04-17  by MADOR - PT certification - SAF-T Period tag needs to match with the fiscal period
Value Char CPY
Value Date DAT

Local Decimal FISCALYEAR , PERIODE
Local Libelle MAINGENLED, MAINANALED
Local Date    PERSTRDAT, PERENDDAT

# get main general ledger
Call SETMAINREF([L]CPY, [L]MAINGENLED, [L]MAINANALED) From CPTDIV
# get fiscal year
Call GETEXE([L]CPY, [L]MAINGENLED, [L]DAT, [L]FISCALYEAR) From CPTSUB
# get start date and end date for the fiscal year
Call DATEXE([L]CPY, [L]MAINGENLED, [L]FISCALYEAR, [L]PERSTRDAT, [L]PERENDDAT) From CPTSUB

[L]PERIODE = month([L]DAT) - month([L]PERSTRDAT)

If [L]PERIODE < 0
    [L]PERIODE += 12
Endif

[L]PERIODE += 1
#Issue end
End [L]PERIODE
#######################################################################################
#######################################################################################
Subprog LECTEXTRA_POR(VALEUR, TABLE, CHAMP, CLE1, CLE2)
Variable Char    VALEUR()
Value    Char    TABLE, CHAMP, CLE1, CLE2

# Issue X3-99026 by MRDAB
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
Read [AXX]AXX0 = TABLE;CHAMP;"POR";CLE1;CLE2
If fstat = 0
  VALEUR = [F:AXX]TEXTE
Else
  Call LECTEXTRA(VALEUR, TABLE, CHAMP, CLE1, CLE2) From ATEXTRA
Endif
# Issue X3-99026 end

End
