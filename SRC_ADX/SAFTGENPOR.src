#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################
######################################################################################
### before any call to this process, the following variables should exist and have the
### correct value
### [L]SOC       = company
### [L]COMMENT   = comment for saft
### [L]STRDATE   = starting date of extraction
### [L]ENDDATE   = end date of extraction
### [L]FILEPATH  = file name and path
### [L]SAFTTYPE  = saft type
### [L]FILDESTYP = file destiny (client/server)
### [L]LEG       = legislation
### [L]EVRDOCTYP = todos os tipos de documento (de transporte)
### [L]DOCTYP    = tipo de documento (de transporte)
### [L]PIHBPS    = fornecedor de auto-faturação
### [L]FICHIER   = nome do ficheiro de exportação
######################################################################################
######################################################################################
$ACTION

Case ACTION
    When "CONTROLE"    Gosub CONTROLE
    When "EXEC"        Gosub EXEC
Endcase

Return
######################################################################################
######################################################################################
$CONTROLE

Gosub INIT_CTR

Gosub COMMON_VALUES_AND_CONTROLS

#--- Check if all tax rates have classification
For [F:TVT] Where ([F:TVT]LEG = [L]LEG | [F:TVT]LEG = "") & find([F:TVT]VATTYP,1,2,3)
  [L]TVTCTR = 0
  If find([F:TVT]VATTYP,2,3) & [F:TVT]VATFOR<>""
    [L]TVTCTR = 1
  Else
    Filter [F:TRA] Where [F:TRA]VAT = [F:TVT]VAT & [F:TRA]LEG = [F:TVT]LEG & ([F:TRA]CPY = [L]SOC | [F:TRA]CPY = '')
    Look [F:TRA] First
    If fstat = 0
      [L]TVTCTR = 1
    Endif
    Filter [F:TRA]
  Endif
  If [L]TVTCTR
    Read [F:VCL]VCL0=[L]SOC;[F:TVT]VAT
    If fstat
      GERR     = 1
      GMESSAGE = func AFNC.MES1(mess(19,7711,1), [F:TVT]VAT) #Tax code $1$ it's not classified. Review the tax classification.
      OK       = 0
      Break
    Endif
  Endif
Next
If !OK : Return : Endif

If [L]FILDESTYP = 1
  #get the value from SAFTEXP parameter
  [L]SAFTPEXP = func AFNC.PARAMUTIL("SAFTEXP",GUSER,[L]SOC)
Endif

#Check if dates are ok
Call DATFIY([L]SOC, [L]LEDT, [L]EXE, [L]STRFYDAT, [L]ENDFYDAT) From CPTSUB
If [L]STRDATE <> [L]STRFYDAT & day([L]STRDATE) <> 1
  GERR     = 1
  GMESSAGE = mess(20,7711,1) #Incorrect initial date: it must be the begining of the fiscal year or the begining of a month.
  OK = 0
Elsif [L]ENDDATE <> [L]ENDFYDAT & eomonth([L]ENDDATE)<> [L]ENDDATE & [L]ENDDATE <> date$
  GERR     = 1
  GMESSAGE = mess(21,7711,1) #Incorrect end date: it must be the end of the fiscal year, the end of a month or the current date.
  OK = 0
Elsif !([L]STRDATE >= [L]STRFYDAT & [L]STRDATE <= [L]ENDFYDAT) or !([L]ENDDATE >= [L]STRFYDAT & [L]ENDDATE <= [L]ENDFYDAT)
  GERR     = 1
  GMESSAGE = mess(20,107,1) #The dates are not in the same fiscal year
  OK = 0
Endif
If GERR=1 : Return : Endif

[L]STRDATECTB = [L]STRFYDAT #Accounting begining date for extraction is always the initial date of the fiscal year
[L]ENDDATECTB = [L]ENDDATE  #Accounting ending date for extraction is always the end date entered by the user

Return
######################################################################################
######################################################################################
$INIT_CTR

If !clalev ([F:VCL]) : Local File VATCLS     [VCL] : Endif
If !clalev ([F:TVT]) : Local File TABVAT     [TVT] : Endif
If !clalev ([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev ([F:PER]) : Local File PERIOD     [PER] : Endif
If !clalev ([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev ([F:TRA]) : Local File TABRATVAT  [TRA] : Endif

Gosub INITIALIZE_VERSION_MANAGEMENT

Gosub COMMON_DECLARE

Local Integer FISCALYEAR
Local Date    STRFYDAT, ENDFYDAT, STRDATECTB, ENDDATECTB
Local Char    SAFTPEXP(GDIMFIC)

Return
######################################################################################
######################################################################################
$COMMON_DECLARE

If !clalev ([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif

Local Decimal EXE
Local Char    SAFTPGROU(2), LAN(GLONLAN)

#Local SAF-T PT Vars
Local Char     PYR(30)
Local Char     COA(30)
Local Char     SYMBOLE(30)
Local Integer  LEDT
Local Char     LEDTA(30)
Local Char     TYPONDAN(30)
Local Char     SAFPRIRNC(30)
Local Decimal  SAFPRIRND
Local Char     SAFPRIFMT(30)
Local Char     ACCRET(30)
Local Char     PIHBPS(60)
Local Integer  OTHIMP        #Other taxes then VAT (for IEC)
Local Shortint DO_OTHIMP     #Other taxes then VAT - exist on present document (for IEC)
Local Decimal  VALTMP        #valor a adicionar\subtrair (outros impostos) (for IEC)
Local Char     ELTAX(5)      #código de taxa a usar para os elementos de faturação sem iva no presente documento (baseado nas linhas)
Local Integer  TVTCTR        #Para controlar se as taxas estão todas parametrizadas antes da geração do SAF-T
Local Shortint VENEXEFLG     #Para indicar se a taxa é isenta nas vendas

# Issue X3-31864 - 2017-04-25 by MRDAB - Variable lengths for version maintenance
Local Integer HETADDREETAIL, GLTACCODESCRL, SUTIADDRDETL, GLEGLSODOCIDL, ITTITMNUMCL, SDHASHCTRLL, SDDELIVERIL, SDSHIPIDL, ADDDETL, STRNAMEL
Local Integer CUTCUSTAXIDL
#Footer elements
Local Integer DIMSVV, DIMSVF : DIMSVV = func AFNC.ACTIV("SVA")  : DIMSVF = func AFNC.ACTIV("SFIV")

If [L]ISSAFTVERCURRENT
  [L]ADDDETL = 210
  [L]STRNAMEL = 200
  [L]HETADDREETAIL = 210
  [L]GLTACCODESCRL = 100
  [L]SUTIADDRDETL = 210
  [L]GLEGLSODOCIDL = 60
  [L]SDHASHCTRLL = 70
  [L]SDDELIVERIL = 255
  [L]SDSHIPIDL = 255
  [L]ITTITMNUMCL = 60
  [L]CUTCUSTAXIDL= 30
Else
  [L]ADDDETL = 100
  [L]STRNAMEL = 50
  [L]HETADDREETAIL = 60
  [L]GLTACCODESCRL = 60
  [L]SUTIADDRDETL = 60
  [L]GLEGLSODOCIDL = 30
  [L]SDHASHCTRLL = 40
  [L]SDDELIVERIL = 30
  [L]SDSHIPIDL = 30
  [L]ITTITMNUMCL = 50
  [L]CUTCUSTAXIDL= 20
Endif
# End issue X3-31864

# Issue X3-105529 by MRDAB: fixed KIT communication in SAF-T
Local Char SAFTPRDKITACTIVE(1)
# Issue X3-105529 end

Return
######################################################################################
######################################################################################
$COMMON_VALUES_AND_CONTROLS

####--- Get the main general ledger
#Call LECLEDMAIN(1, [L]SOC, [L]LEDT) From CPTDIV
Gosub SET_LEDT

###---- Get fiscal year
Call GETEXE([L]SOC, [L]LEDT, [L]STRDATE, [L]EXE) From CPTSUB
If [L]EXE  = 0
  GERR     = 1
  GMESSAGE = mess(7,101,1) #Fiscal Year Not Yet Defined
  OK       = 0
  Return
Endif

#get the value from SAFTPGROU parameter
Call PARAM([L]SOC,"SAFTPGROU",[L]SAFTPGROU) From ADOVAL
If val([L]SAFTPGROU) < 1 or val([L]SAFTPGROU) > func AFNC.ACTIV("STI")
  GERR     = 1
  GMESSAGE = mess(3,2647,1)+":"-mess(143,105,1)-"SAFTPGROU" #Incorrect value: Parameter SAFTPGROU
  OK       = 0
  Return
Endif

#get default language for company
If [F:CPY]CPY <> [L]SOC
  Read [F:CPY]CPY0 = [L]SOC
  If fstat : Raz [F:CPY] : Endif
Endif
Read [F:TCY]TCY0=[F:CPY]CRY
[L]LAN = [F:TCY]LAN

Return
######################################################################################
######################################################################################
$EXEC

#open trace
Call OUVRE_TRACE("SAF-T") From LECFIC

# declare and assign variables regarding XML SAF-T schema version management
Gosub INITIALIZE_VERSION_MANAGEMENT

#open tables and declare variables
Gosub DECLARE

#empty temporary customer table
Delete [F:SAFTP] Where 1=1

#Genarel parameters and other variables used on SAF-T POR
Gosub LOAD_PARAM

# Issue 114518 - 2016-02-18 by RICAR : Verification of accounting documents with Temporary status
# Issue 114518
Gosub CHECK_ACCDOCS_STA
If !OK : Goto END_EXEC : Endif
# End issue 114518

#open file to write
Gosub OPEN_FILE
If !OK
  Call ECR_TRACE(GMESSAGE, 1) From GESECRAN
  Goto END_EXEC
Endif

# Issue X3-99026 by MRDAB - verify connection language
If GLANGUE <> "POR"
  Call ECR_TRACE (mess(66,123,1) + ":" - mess(243,7711,1), 1) From GESECRAN
  # we treat it as a warning so we decrement error counter
  GERRTRACE -= 1
Endif
# Issue X3-99026 end

If find([L]SAFTTYPE,5,7)
  #Purchanse Auto-invoicing
  Gosub WRITE_TAGS_PIH From SAFTGENPORPIH
Else
  #Sales, Accounting, et..
  Gosub WRITE_TAGS
Endif

#close the file
Gosub CLOSE_FILE

$END_EXEC
#close the trace
Call FERME_TRACE From LECFIC
#read the trace
Call LEC_TRACE From LECFIC

Return
######################################################################################
######################################################################################
$LOAD_PARAM

Gosub LOAD_COMMON_VALUES

If [L]FILDESTYP = 1
  #get the value from SAFTEXP parameter
  [L]SAFTPEXP = func AFNC.PARAMUTIL("SAFTEXP",GUSER,[L]SOC)
Endif

#write the content of the file
[L]EVRDOCTYP = [M:SAFT]EVRDOCTYP
[L]DOCTYP    = [M:SAFT]DOCTYP
[L]PIHBPS    = [M:SAFT]BPSNUM

Return
#######################################################################################
#######################################################################################
$LOAD_COMMON_VALUES

#Ledgertype
#Call PARAM([L]SOC, "LEDTYP", [L]LEDTA) From ADOVAL
#[L]LEDT = val([L]LEDTA)
#If [L]LEDT = 0
#  ###--- Get the main general ledger                                 ---###
#  Call LECLEDMAIN(1, [L]SOC, [L]LEDT) From CPTDIV
#Endif
Gosub SET_LEDT
Gosub SET_COA
Gosub SET_SAFPRIRND

Call PARAM([L]SOC, "SAFTACCRET",[L]ACCRET) From ADOVAL
Call PARAM([L]SOC, "TYPONDAN",[L]TYPONDAN) From ADOVAL

If instr(0,SAFPRIRNC,".")
   SAFPRIFMT = "N20." + num$(len(right$(SAFPRIRNC,instr(0,SAFPRIRNC,".")+1)))
Else
   SAFPRIFMT = "N20"
Endif

#Accounting Pyramid
Call PARAM([L]SOC, "PORPYR", [L]PYR) From ADOVAL
If [L]PYR = ""
    [L]PYR = "POR"
Endif

Filter [F:TVT] Where [F:TVT]VATTYP <> 1 & ([F:TVT]LEG = "" | [F:TVT]LEG = "POR")
Read [F:TVT] First
If !fstat : [L]OTHIMP = 1 : Else : [L]OTHIMP = 0 : Endif
Filter [F:TVT]

Gosub SET_SAFTPRDKITACTIVE

Return
#######################################################################################
#######################################################################################
$DECLARE
#Tables
If !clalev([F:ADI])   : Local File ATABDIV    [ADI]   : Endif #Supervisor
If !clalev([F:BPC])   : Local File BPCUSTOMER [BPC]   : Endif #Common Data        (9)
If !clalev([F:PIL])   : Local File BPSINVLIG  [PIL]   : Endif #Common Data        (9)
If !clalev([F:BPS])   : Local File BPSUPPLIER [BPS]   : Endif #Common Data        (9)
If !clalev([F:CNT])   : Local File CONTACT    [CNT]   : Endif #Supervisor         (1)
If !clalev([F:AIN])   : Local File CONTACTCRM [AIN]   : Endif #Supervisor         (1)
If !clalev([F:FIY])   : Local File FISCALYEAR [FIY]   : Endif #Common Data        (9)
If !clalev([F:CAC])   : Local File GACCCODE   [CAC]   : Endif #Common Data        (9)
If !clalev([F:GRY])   : Local File GACCGRUPYM [GRY]   : Endif #Common Data        (9)
If !clalev([F:GR2])   : Local File GACCGRUPYM [GR2]   : Endif #Common Data        (9)
If !clalev([F:GYK])   : Local File GACCPYMLIK [GYK]   : Endif #Common Data        (9)
If !clalev([F:LED])   : Local File GLED       [LED]   : Endif #Common Data        (9)
If !clalev([F:GTE])   : Local File GTYPACCENT [GTE]   : Endif #Common Data        (9)
If !clalev([F:ITG])   : Local File ITMCATEG   [ITG]   : Endif #Common Data        (9)
If !clalev([F:PIH])   : Local File PINVOICE   [PIH]   : Endif #Common Data        (9)
If !clalev([F:PTH])   : Local File PRECEIPT   [PTH]   : Endif #Common Data        (9)
If !clalev([F:SAFTP]) : Local File SAFTPTTMP1 [SAFTP] : Endif #Common Data        (9)
If !clalev([F:TDA])   : Local File TABDEPAGIO [TDA]   : Endif #Common Data        (9)
If !clalev([F:TPV])   : Local File TABPIVTYP  [TPV]   : Endif #Common Data        (9)
If !clalev([F:TRA])   : Local File TABRATVAT  [TRA]   : Endif #Common Data        (9)

If GMODU(2) = 2 # test the presence of the Accounting module
  If !clalev([F:BAL])   : Local File BALANCE    [BAL]   : Endif #Accouting          (2)
  If !clalev([F:JOU])   : Local File GJOURNAL   [JOU]   : Endif #Accouting          (2)
  If !clalev([F:HA2])   : Local File GACCENTRY  [HA2]   : Endif #Accouting          (2)
  If !clalev([F:DA2])   : Local File GACCENTRYD [DA2]   : Endif #Accouting          (2)
  If !clalev([F:GA2])   : Local File GACCOUNT   [GA2]   : Endif #Accouting          (2)
  If !clalev([F:PYHV])  : Local File PAYVAT     [PYHV]  : Endif #Accouting          (2)
  If !clalev([F:CLS])   : Local File GACCCLS    [CLS]   : Endif #Accouting          (2)
  If !clalev([F:CL2])   : Local File GACCCLS    [CL2]   : Endif #Accouting          (2)
  If !clalev([F:VER])   : Local File VATEXEREA  [VER]   : Endif #Accouting          (2)
Endif

If GMODU(3) = 2 # test the presence of the A/P-A/R Accounting module
  If !clalev([F:PYH]) : Local File PAYMENTH   [PYH] : Endif #A/P-A/R Accounting (3)
  If !clalev([F:PYD]) : Local File PAYMENTD   [PYD] : Endif #A/P-A/R Accounting (3)
  If !clalev([F:PH2]) : Local File PAYMENTH   [PH2] : Endif #A/P-A/R Accounting (3)
  If !clalev([F:CDA]) : Local File GACCDENCOD [CDA] : Endif #A/P-A/R Accounting (3)
Endif

If GMODU(6) = 2 # test the presence of the Purchase module
  If !clalev([F:PID])   : Local File PINVOICED  [PID]   : Endif #Purchase        (6)
  If !clalev([F:PIV])   : Local File PINVOICEV  [PIV]   : Endif #Purchase        (6)
Endif

If GMODU(7) = 2 # test the presence of the Stock module
  If !clalev([F:SGH]) :  Local File SCHGH      [SGH]  : Endif #Stock              (7)
  # Issue X3-31864 - 2017-04-06 by MRDAB:
  If !clalev([F:STJ])  : Local File STOJOU     [STJ]  : Endif #Stock              (7)
  # End issue X3-31864
Endif

Gosub DECLARE_TABS_INVOICE

