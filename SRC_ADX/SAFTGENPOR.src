$DECLARE_TABS_INVOICE

If !clalev([F:ADC]) : Local File BPADDRESS  [ADC] : Endif #Supervisor         (1)
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif #Supervisor         (1)
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif #Supervisor         (1)

If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif #Common Data        (9)
If !clalev([F:BPD])  : Local File BPDLVCUST  [BPD]  : Endif #Common Data        (9)
If !clalev([F:DKD])  : Local File DKSDATA    [DKD]  : Endif #Common Data        (9)
If !clalev([F:DKD2]) : Local File DKSDATA    [DKD2] : Endif #Common Data        (9)
If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]  : Endif #Common Data        (9)
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif #Common Data        (9)
If !clalev([F:GCM])  : Local File GACM       [GCM]  : Endif #Common Data        (9)
If !clalev([F:ITM])  : Local File ITMMASTER  [ITM]  : Endif #Common Data        (9)
If !clalev([F:SIH])  : Local File SINVOICE   [SIH]  : Endif #Common Data        (9)
If !clalev([F:SIH2]) : Local File SINVOICE   [SIH2] : Endif #Common Data        (9)
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif #Common Data        (9)
If !clalev([F:TAM])  : Local File TABPAM     [TAM]  : Endif #Common Data        (9)
If !clalev([F:TSV])  : Local File TABSIVTYP  [TSV]  : Endif #Common Data        (9)
If !clalev([F:TVB])  : Local File TABVACBPR  [TVB]  : Endif #Common Data        (9)
If !clalev([F:TVT])  : Local File TABVAT     [TVT]  : Endif #Common Data        (9)
If !clalev([F:VCL])  : Local File VATCLS     [VCL]  : Endif #Common Data        (9)
If !clalev([F:DKK])  : Local File DKSKEY     [DKK]  : Endif #Common Data        (9)

If GMODU(2) = 2 # test the presence of the Accounting module
  If !clalev([F:DVPT])  : Local File DCLVATPORT [DVPT]  : Endif #Accouting          (2)
  If !clalev([F:HAE])   : Local File GACCENTRY  [HAE]   : Endif #Accouting          (2)
  If !clalev([F:DAE])   : Local File GACCENTRYD [DAE]   : Endif #Accouting          (2)
Endif

If GMODU(3) = 2 # test the presence of the A/P-A/R Accounting module
  If !clalev([F:SIL]) : Local File BPCINVLIG  [SIL] : Endif #A/P-A/R Accounting (3)
  If !clalev([F:SI2]) : Local File BPCINVLIG  [SI2] : Endif #A/P-A/R Accounting (3)
Endif

If GMODU(5) = 2 # test the presence of the Sales module
  If !clalev([F:SDH]) : Local File SDELIVERY  [SDH] : Endif #Sales              (5)
  If !clalev([F:SID]) : Local File SINVOICED  [SID] : Endif #Sales              (5)
  If !clalev([F:SIV]) : Local File SINVOICEV  [SIV] : Endif #Sales              (5)
  If !clalev([F:SOH]) : Local File SORDER     [SOH] : Endif #Sales              (5)
  If !clalev([F:SVF]) : Local File SVCRFOOT   [SVF] : Endif #Sales              (5)
  If !clalev([F:SVV]) : Local File SVCRVAT    [SVV] : Endif #Sales              (5)
Endif

Return
