#**
#* Start method to be called at the beginning of a test case
#*
#* @param DESCRIPTION
#*!
Subprog TESTCASE_START(SUBPRG, DESCRIPTION)
  Value Char SUBPRG()
  Value Char DESCRIPTION()

  If dim(GXUNIT_CASESTAMP) < 0 : Global Char GXUNIT_CASESTAMP(20) : Endif
  GXUNIT_CASESTAMP = timestamp$
  If dim(GXUNIT_DESCRIPTION) < 0 : Global Char GXUNIT_DESCRIPTION(255) : Endif
  GXUNIT_DESCRIPTION = DESCRIPTION
  If dim(GXUNIT_TESTID) < 0 : Global Integer GXUNIT_TESTID : Endif
  GXUNIT_TESTID = 0

  Call CREATE_RESULT_CONTEXT
  GXUNIT_SUCCESS = 0
  GXUNIT_FAILURE = 0
  Raz GXUNIT_RESULT

  If dim(GXUNIT_ERROR) < 0 : Global Integer GXUNIT_ERROR : Endif
  GXUNIT_ERROR = 0

  If GXUNIT_CASE_ID > 0
    Append GXUNIT_JSON, ','
  Endif
  GXUNIT_CASE_ID += 1
  Call LOG_APPEND(chr$(10))
  Call LOG_LINE("Start test case - " + GXUNIT_DESCRIPTION)

  # Start JSON case entry
  Append GXUNIT_JSON, '{'
  Append GXUNIT_JSON, '"id":'
  Append GXUNIT_JSON, num$(GXUNIT_CASE_ID)
  Append GXUNIT_JSON, ',"name":"' + SUBPRG + '"'
  Append GXUNIT_JSON, ',"description":"'
  Call JSON_ESCAPE(DESCRIPTION, GXUNIT_JSON_TMP)
  Append GXUNIT_JSON, GXUNIT_JSON_TMP
  Append GXUNIT_JSON, '"'

  Append GXUNIT_JSON, ', "checks":['
End

#**
#* End method to be called at the end of a test case
#*!
Subprog TESTCASE_END()
  Local Integer ELAPSED
  ELAPSED = val(timestamp$) - val(GXUNIT_CASESTAMP)
  Append GXUNIT_JSON, '],"elapsed":' + num$(ELAPSED)
  Append GXUNIT_JSON, ',"success":'
  Append GXUNIT_JSON, num$(GXUNIT_SUCCESS)
  Append GXUNIT_JSON, ',"failure":'
  Append GXUNIT_JSON, num$(GXUNIT_FAILURE)

  If GXUNIT_FAILURE = 0
   Append GXUNIT_RESULT, ">0001 "
  Else
   Append GXUNIT_RESULT, "<0001 "
  Endif
  Append GXUNIT_RESULT, "success="
  Append GXUNIT_RESULT, num$(GXUNIT_SUCCESS)
  Append GXUNIT_RESULT, ", failure="
  Append GXUNIT_RESULT, num$(GXUNIT_FAILURE)
  Append GXUNIT_RESULT, ", elapsed="
  Append GXUNIT_RESULT, num$(ELAPSED)
  Append GXUNIT_RESULT, "ms"
  Append GXUNIT_RESULT, chr$(10)
  If GXUNIT_FAILURE > 0
    GXUNIT_CASE_FAILURE += 1
  Else
    GXUNIT_CASE_SUCCESS += 1
  Endif
  If GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 0) > 0 &
&    GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 0) <> GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 1)
    Append GXUNIT_RESULT, "Mismatch number of assertions: expected "
    Append GXUNIT_RESULT, num$(GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 0))
    Append GXUNIT_RESULT, " got "
    Append GXUNIT_RESULT, num$(GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 1))
    Append GXUNIT_RESULT, chr$(10)
    Append GXUNIT_JSON, ',"warnings":["Mismatch number of assertions: expected '
    Append GXUNIT_JSON, num$(GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 0))
    Append GXUNIT_JSON, ' got '
    Append GXUNIT_JSON, num$(GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 1))
    Append GXUNIT_JSON, '"]'
  Endif
  Call LOG_APPEND(GXUNIT_RESULT)

  # End JSON case entry
  Append GXUNIT_JSON, '}'

#  Call LOG_LINE("End test case: " + GXUNIT_DESCRIPTION)
End

#**
#* Gets the test suite result summary
#*!
Funprog SUITE_RESULT()
End GXUNIT_SUITE_RESULT

#**
#* Gets the test case result
#*!
Funprog CHECK_RESULT()
End GXUNIT_RESULT

#**
#* Verify if the check is valid in the current context
#* @private
#*!
Funprog VERIFY_CHECK
  If dim(GXUNIT_CURRENT_CASE) < 0 | GXUNIT_CURRENT_CASE <= 0 | (dim(GXUNIT_SUITE_RUNNING) > 0 & not GXUNIT_SUITE_RUNNING)
    Call APPEND_ERROR("Warning: No current test case, the check has been skipped")
    Call APPEND_ERROR(chr$(10))
    Local Integer STAT
    If dim(GSTACK) < 0 : Global Clbfile GSTACK(7) : Endif

    Onerrgo STACK_ERROR
    STAT = dbgCallStack(0, GSTACK)
    Onerrgo
    If STAT = 0
      Call APPEND_STACK(GXUNIT_SUITE_ERROR, GSTACK)
    Endif

    Call APPEND_ERROR(chr$(10))
    Call FLUSH_ERROR
    End 0
  Endif
End 1

#**
#* Creates the minimum context to report results
#* @private
#*!
Subprog CREATE_RESULT_CONTEXT
  If dim(GXUNIT_RESULT) < 0 : Global Clbfile GXUNIT_RESULT(10) : Endif
  If dim(GXUNIT_SUCCESS) < 0 : Global Integer GXUNIT_SUCCESS : Endif
  If dim(GXUNIT_FAILURE) < 0 : Global Integer GXUNIT_FAILURE : Endif
End

#**
#* Check if GOT equals to EXPECTED
#*
#* @param GOT
#* @param EXPECT
#*!
Subprog CHECK_EQUAL(GOT, EXPECT)
  Local Integer FAILED : FAILED=0
  Local Integer L, D

  If not (func VERIFY_CHECK) : End: Endif

  Onerrgo CHECK_ERR

  GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 1) += 1
  GXUNIT_TESTID += 1

  Call JSON_START_CHECK("equal")

  If GOT = EXPECT Then
    GXUNIT_SUCCESS += 1
    Call JSON_CASE_SUCCESS("OK: ")
  Else
    FAILED = 1
    Call JSON_CASE_FAILED("FAILED: expected ")
    Call APPEND_VALUE(EXPECT)
    Append GXUNIT_RESULT, ", got "
    Append GXUNIT_JSON, ', got '
  Endif
  Call APPEND_VALUE(GOT)
  Append GXUNIT_JSON, '"'
  Append GXUNIT_RESULT, chr$(10)
  If FAILED
    Gosub CHECK_FAILED
  Endif
  Call JSON_END_CHECK

  Onerrgo
End

#**
#* Check if GOT not equals to EXPECTED
#*
#* @param GOT
#* @param EXPECT
#*!
Subprog CHECK_NOTEQUAL(GOT, EXPECT)
  Local Integer FAILED : FAILED=0

  If not (func VERIFY_CHECK) : End: Endif

  Onerrgo CHECK_ERR

  GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 1) += 1
  GXUNIT_TESTID += 1

  Call JSON_START_CHECK("notEqual")

  If not func TYPE_COMPATIBLE(type(GOT), type(EXPECT)) | (GOT <> EXPECT) Then
    GXUNIT_SUCCESS += 1
    Call JSON_CASE_SUCCESS("OK: ")
  Else
    FAILED = 1
    Call JSON_CASE_FAILED("FAILED: expected value different of ")
    Call APPEND_VALUE(EXPECT)
    Append GXUNIT_RESULT, ", got "
    Append GXUNIT_JSON, ', got '
  Endif
  Call APPEND_VALUE(GOT)
  Append GXUNIT_JSON, '"'
  Append GXUNIT_RESULT, chr$(10)
  If FAILED
    Gosub CHECK_FAILED
  Endif
  Call JSON_END_CHECK
  Onerrgo
End

#**
#* Check if GOT is true
#*
#* @param GOT
#*!
Subprog CHECK_TRUE(GOT)
  If not (func VERIFY_CHECK) : End: Endif

  Onerrgo CHECK_ERR

  GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 1) += 1
  GXUNIT_TESTID += 1

  Call JSON_START_CHECK("isTrue")

  If GOT
    GXUNIT_SUCCESS += 1
    Call JSON_CASE_SUCCESS("OK")
    Append GXUNIT_JSON, '"'
    Append GXUNIT_RESULT, chr$(10)
  Else
    Call JSON_CASE_FAILED("Failed")
    Append GXUNIT_RESULT, chr$(10)
    Append GXUNIT_JSON, '"'
    Gosub CHECK_FAILED
  Endif
  Call JSON_END_CHECK
  Onerrgo
End

#**
#* Check if GOT is false
#*
#* @param GOT
#*!
Subprog CHECK_FALSE(GOT)
  If not (func VERIFY_CHECK) : End: Endif

  Onerrgo CHECK_ERR

  GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 1) += 1
  GXUNIT_TESTID += 1

  Call JSON_START_CHECK("isFalse")

  If !GOT
    GXUNIT_SUCCESS += 1
    Call JSON_CASE_SUCCESS("OK")
    Append GXUNIT_JSON, '"'
    Append GXUNIT_RESULT, chr$(10)
  Else
    Call JSON_CASE_FAILED("Failed")
    Append GXUNIT_RESULT, chr$(10)
    Append GXUNIT_JSON, '"'
    Gosub CHECK_FAILED
  Endif
  Call JSON_END_CHECK
  Onerrgo
End

Subprog CHECK_NULL(GOT)
  If not (func VERIFY_CHECK) : End: Endif

  Onerrgo CHECK_ERR

  GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 1) += 1
  GXUNIT_TESTID += 1

  Call JSON_START_CHECK("isNull")

  If GOT = null
    GXUNIT_SUCCESS += 1
    Call JSON_CASE_SUCCESS("OK")
    Append GXUNIT_JSON, '"'
    Append GXUNIT_RESULT, chr$(10)
  Else
    Call JSON_CASE_FAILED("Failed")
    Append GXUNIT_RESULT, chr$(10)
    Append GXUNIT_JSON, '"'
    Gosub CHECK_FAILED
  Endif
  Call JSON_END_CHECK
  Onerrgo
End

Subprog CHECK_NOTNULL(GOT)
  If not (func VERIFY_CHECK) : End: Endif

  Onerrgo CHECK_ERR

  GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CURRENT_CASE, 1) += 1
  GXUNIT_TESTID += 1

  Call JSON_START_CHECK("isNull")

  If GOT <> null
    GXUNIT_SUCCESS += 1
    Call JSON_CASE_SUCCESS("OK")
    Append GXUNIT_JSON, '"'
    Append GXUNIT_RESULT, chr$(10)
  Else
    Call JSON_CASE_FAILED("Failed")
    Append GXUNIT_RESULT, chr$(10)
    Append GXUNIT_JSON, '"'
    Gosub CHECK_FAILED
  Endif
  Call JSON_END_CHECK
  Onerrgo
End

$CHECK_ERR
  Append GXUNIT_RESULT, "Error"
  Append GXUNIT_JSON, '"error"'
  If errn
    Append GXUNIT_RESULT, ": ["
    Append GXUNIT_RESULT, num$(errn)
    Append GXUNIT_RESULT, "] "
    Append GXUNIT_RESULT, errmes$(errn)

    Append GXUNIT_JSON, ": ["
    Append GXUNIT_JSON, num$(errn)
    Append GXUNIT_JSON, "] "
    Append GXUNIT_JSON, errmes$(errn)
  Endif
  Append GXUNIT_RESULT, chr$(10)
  Append GXUNIT_JSON, '\n'
  GXUNIT_ERROR = errn
  Gosub CHECK_FAILED
  Resume

$CHECK_FAILED
  Local Integer STAT
  If dim(GSTACK) < 0 : Global Clbfile GSTACK(7) : Endif
  GXUNIT_FAILURE += 1
  Onerrgo STACK_ERROR
  STAT = dbgCallStack(0, GSTACK)
  If STAT = 0
    Call APPEND_STACK(GXUNIT_RESULT, GSTACK)
  Endif
  Append GXUNIT_RESULT, chr$(10)

  Append GXUNIT_JSON, ','
  Call PARSE_STACK(GXUNIT_JSON, GSTACK, "APPEND_STACK_JSON")
#  Call APPEND_STACK_JSON(GXUNIT_JSON, GSTACK, '\n')
  Onerrgo

  Return

$STACK_ERROR
  STAT = 1
Resume

Subprog APPEND_ERROR(STR)
  If dim(GXUNIT_SUITE_ERROR) < 0 : Global Clbfile GXUNIT_SUITE_ERROR(3) : Endif
  Append GXUNIT_SUITE_ERROR, STR
End

Subprog FLUSH_ERROR()
  If dim(GXUNIT_SUITE_ERROR) < 0 : End : Endif
  Call LOG_APPEND(GXUNIT_SUITE_ERROR)
  Raz GXUNIT_SUITE_ERROR
End

Subprog APPEND_VALUE(VALUE_)
    Case type(VALUE_)
      When 1, 2, 3, 4, 5, 6, 7, 525, 526
        # 525 Uuident
        # 526 Datetime (mb 7.7.14)
        Append GXUNIT_RESULT, num$(VALUE_)
        Append GXUNIT_JSON, num$(VALUE_)
      When Default
        Append GXUNIT_RESULT, "'"
        Append GXUNIT_RESULT, VALUE_
        Append GXUNIT_RESULT, "'"

#        L = len(VALUE_)
#        D = max(0, ln((L + 2) / 512) / ln(2))
#        Local Clbfile TMP(D+1)
        Call JSON_CASE_MESSAGE_STRING(VALUE_)
    Endcase
End

Funprog TYPE_COMPATIBLE(T1, T2)
Value Integer T1, T2
End (T1 = T2) | (T1 = 523 & T2 > 10 & T2 < 265) | (T2 = 523 & T1 > 10 & T1 < 265)
#=================================================================
# JSON Helper
#=================================================================

#**
#* Start a JSON case
#*
#* @param CHECK_TYPE
#*!
Subprog JSON_START_CHECK(CHECK_TYPE)
  Value Char CHECK_TYPE()

  Append GXUNIT_RESULT, num$(GXUNIT_CASE_ID) + "." + num$(GXUNIT_TESTID)
  Append GXUNIT_RESULT, " - check " + CHECK_TYPE + " - "

  If GXUNIT_TESTID > 1
    Append GXUNIT_JSON, ','
  Endif
  Append GXUNIT_JSON, '{'
    Append GXUNIT_JSON, '"id":'
    Append GXUNIT_JSON, num$(GXUNIT_TESTID)
    Append GXUNIT_JSON, ',"type":'
    Append GXUNIT_JSON, '"' + CHECK_TYPE + '"'
End

Subprog JSON_CASE_SUCCESS(MESSAGE)
    Append GXUNIT_RESULT, MESSAGE

    Append GXUNIT_JSON, ',"success":true'
    Append GXUNIT_JSON, ',"message":"'
    Append GXUNIT_JSON, MESSAGE
End

Subprog JSON_CASE_FAILED(MESSAGE)
    Append GXUNIT_RESULT, MESSAGE

    Append GXUNIT_JSON, ',"success":false'
    Append GXUNIT_JSON, ',"message":"'
    Append GXUNIT_JSON, MESSAGE
End

Subprog JSON_CASE_MESSAGE_STRING(MESSAGE)
    Call JSON_ESCAPE(MESSAGE, GXUNIT_JSON_TMP)
    Append GXUNIT_JSON, '\"'
    Append GXUNIT_JSON, GXUNIT_JSON_TMP
    Append GXUNIT_JSON, '\"'
End

#**
#* End a JSON case
#*!
Subprog JSON_END_CHECK()
  Append GXUNIT_JSON, '}'
End

#**
#* Escape char for JSON output
#*
#* @param IN
#* @param OUT
#*!
Subprog JSON_ESCAPE(IN, OUT)
#  Variable Clbfile IN
  Variable Clbfile OUT
  Local Integer I
  Local Integer LENGTH
  Local Char C(1)
  Local Integer N

  LENGTH = len(IN)
  Raz OUT
  For I = 1 To LENGTH
    C = mid$(IN, I, 1)
    N = ascii(C)
    If N < 32
      Case N
        When 8
          Append OUT, "\b"
        When 9
          Append OUT, "\t"
        When 10
          Append OUT, "\n"
        When 12
          Append OUT, "\f"
        When 13
          Append OUT, "\r"
        When Default
#          Append OUT, "u" + format$("N0:4", N)
      Endcase
    Else
      Case C
        When '"'
          Append OUT, '\"'
        When '\'
          Append OUT, '\\'
        When Default
          Append OUT, C
      Endcase
    Endif
  Next I
End

#**
#* Appends a formatted form of the stack trace to the given clob
#*
#* @param CLB
#* @param STACK
#*!
Subprog PARSE_STACK(CLB, STACK, CALLBACK)
  Variable Clbfile CLB()
  Variable Clbfile STACK()
  Value Char CALLBACK()

  Local Integer TOK_POS
  Local Integer TOK_START
  Local Integer TOK_END
  Local Integer RES, COUNT
  Local Char FNAME(255)
  Local Char LINE(255)
  Local Char PROG(255)

  RES = func =CALLBACK With (-1, CLB, PROG, FNAME, LINE)
  If RES <> 0
    End
  Endif
  TOK_START = 1
  COUNT = 0
  Repeat
    TOK_POS = instr(TOK_START, STACK, '<stack ')
    If TOK_POS = 0 : Break : Endif

    Raz FNAME
    Raz LINE
    Raz PROG

    TOK_START = TOK_POS + 7
    TOK_POS = instr(TOK_START, STACK, 'filename="')
    If TOK_POS <> 0
      TOK_START = TOK_POS + 10
      If instr(TOK_START, STACK, 'x3://') > 0
        TOK_START += 5
      Endif
      TOK_END = instr(TOK_START, STACK, '" ')
      FNAME = mid$(STACK, TOK_START, TOK_END - TOK_START)
    TOK_START = TOK_END + 2
    Endif
    TOK_POS = instr(TOK_START, STACK, 'lineno="')
    If TOK_POS <> 0
      TOK_START = TOK_POS + 8
      TOK_END = instr(TOK_START, STACK, '" ')
      LINE = num$(val(mid$(STACK, TOK_START, TOK_END - TOK_START)) + 1)
      TOK_START = TOK_END + 2
    Endif
    TOK_POS = instr(TOK_START, STACK, 'where="')
    If TOK_POS <> 0
      TOK_START = TOK_POS + 7
      TOK_END = instr(TOK_START, STACK, '" ')
      PROG = mid$(STACK, TOK_START, TOK_END - TOK_START)
      TOK_START = TOK_END + 2
    Endif
    RES = func =CALLBACK With (COUNT, CLB, PROG, FNAME,LINE)
    If RES <> 0
      Break
    Endif
    COUNT += 1
  Until 0

  RES = func =CALLBACK With (-2, CLB, PROG, FNAME, LINE)
  If RES <> 0
    End
  Endif
End

#**
#* Appends a formatted form of the stack trace to the given clob
#*
#* @param CLB
#* @param STACK
#*!
Subprog APPEND_STACK(CLB, STACK)
  Variable Clbfile CLB()
  Variable Clbfile STACK()
  Call PARSE_STACK(CLB, STACK, "APPEND_STACK_TRACE")
End

Funprog APPEND_STACK_TRACE(FLAG, CLB, PROG, FNAME, LINE)
  Value Integer FLAG
  Variable Clbfile CLB()
  Const Char PROG
  Const Char FNAME
  Const Char LINE

  Case FLAG
    When -1,-2
    When Default
      Append CLB, "    at "
      Append CLB, PROG
      Append CLB, "("
      Append CLB, FNAME
      Append CLB, ":"
      Append CLB, LINE
      Append CLB, ")"
      Append CLB, chr$(10)
  Endcase
End 0

Funprog APPEND_STACK_JSON(FLAG, CLB, PROG, FNAME, LINE)
  Value Integer FLAG
  Variable Clbfile CLB()
  Const Char PROG
  Const Char FNAME
  Const Char LINE
  Local Char SEP
  Local Char LB
  Local Char RB
  SEP = ''
  LB = '{'
  RB = ''
  Case FLAG
    When -1
      Append CLB, '"callstack":['
    When -2
      Append CLB, ']'
    When Default
      If FLAG > 0
        Append CLB, ','
      Endif
      If len(PROG) <> 0
        Append CLB, SEP + LB + '"where":"' + PROG + '"'
        SEP = ',' : LB = '' : RB = '}'
      Endif
      If len(FNAME) <> 0
        Append CLB, SEP + LB + '"file":"' + FNAME + '"'
        SEP = ',' : LB = '' : RB = '}'
      Endif
      If len(LINE) <> 0
        Append CLB, SEP + LB + '"line":' + LINE
        SEP = ',' : LB = '' : RB = '}'
      Endif
      Append CLB, RB
  Endcase
End 0

Funprog RUN_ALL2(EXCLUDES, NODEBUG)
  Value Clbfile EXCLUDES
  Value Libelle NODEBUG
  Local Clbfile FILES(10)
  Local Clbfile RES(4)
  Local Integer ENDPOS
  Local Integer STARTPOS
  Local Integer DBG_MODE
  Local Libelle IGNORE
  Local Libelle TRAP_ERRN

  Onerrgo RUN_ERR
  # disable eclipse debugger
  DBG_MODE = dbgmode(0)
  If (NODEBUG)
    dbgmode(0) = 2
  Endif

  Call SAVE_ENV

  Call TRACE_CLEAR
  FILES = func GET_REGULAR_QLF_LIST("", ";")
  L = len(FILES)

  If L > 0
    STARTPOS = 1
    Repeat
      ENDPOS = instr(STARTPOS, FILES, ";")
      FNAME = mid$(FILES, STARTPOS, ENDPOS - STARTPOS)
      STARTPOS = ENDPOS + 1
      IGNORE = 0
      Onerrgo TRAP_ERROR
      If len(FNAME) > 0
        IGNORE = func =FNAME + ".IGNORE" With ()
        Call ="IGNORE" With From =GXUNIT_MODULE_NAME
      Endif
      Onerrgo
      If not IGNORE and instr(0, EXCLUDES, ";" + FNAME + ";") = 0
        If len(FNAME) > 0 & left$(FNAME,5)<>"QLFAE"
          Call TRACE_LINE("Run " + FNAME + ".TESTSUITE")
          #Call TRACE_LINE("maxmem="+num$(maxmem)-"freemem="+num$(freemem))
          Onerrgo TRAP_AND_GET_ERROR
            TRAP_ERRN=0
            Append RES, func =FNAME + ".TESTSUITE" With ()
            Append RES, chr$(10)
          Onerrgo
          If TRAP_ERRN
            Call TRACE_LINE("ERROR: Failed to call " + FNAME + ".TESTSUITE")
          Endif
        Endif
      Else
        Call TRACE_LINE("Skip " + FNAME + ".TESTSUITE")
      Endif
    Until ENDPOS = 0 or STARTPOS > L
  Endif
  Onerrgo
  # restore dbgmode
  dbgmode(0) = DBG_MODE

  Call RESTORE_ENV
End RES

#**
#* Run all test suites
#*!
Funprog RUN_ALL()
  Local Char EXCLUDES
  EXCLUDES = ""
End func RUN_ALL2(EXCLUDES, 0)

#**
#* Run all test suites
#*!
Funprog RUN_ALL_NODEBUG()
  Local Char EXCLUDES
  EXCLUDES = ""
End func RUN_ALL2(EXCLUDES, 1)

$RUN_ERR
  Call TRACE_LINE("  Error(" + num$(errn) + "): " + errmes$(errn) + "[" + errp + ":" + num$(errl) + "]")
  Append RES, chr$(10)
  Append RES, "  Error(" + num$(errn) + "): " + errmes$(errn) + "[" + errp + ":" + num$(errl) + "]"
  Append RES, chr$(10)
Resume

#**
#* Run a set of test suites
#*
#* @param SET the set name
#* <ul>
#* <li>"RTM" for runtime</li>
#* <li>"SUP" for supervisor</li>
#* <li>"JAV" for java bridge</li>
#* <li>"WEB" for web and web services</li>
#* </ul>
#*!
Funprog RUN_SET(SET)
  Value Char SET()

  Local Clbfile FILES(10)
  Local Clbfile RES(4)
  Local Integer I
  Local Integer STARTPOS
  Local Integer L

  Onerrgo RUN_ERR
  FILES = func GET_QLF_LIST("", SET, ";")
  L = len(FILES)

  If L > 0
    STARTPOS = 1
    Repeat
      I = instr(STARTPOS, FILES, ";")
      FNAME = mid$(FILES, STARTPOS, I - STARTPOS)
      STARTPOS = I + 1
      If len(FNAME) > 0 #and FNAME <> "QLFRTM_DBGUTILITIES"
        Append RES, func =FNAME + ".TESTSUITE" With ()
        Append RES, chr$(10)
      Endif
    Until I = 0 or STARTPOS > L
  Endif
  Onerrgo
End RES

Funprog GET_QLF_LIST(DOSSIER, SET, SEP)
  Value Char    DOSSIER()
  Value Char    SET()
  Value Char    SEP()
  Local Char    FILTRE(250)
  Local Clbfile FILES(10)

  FILTRE = 'left$(TRT,' + num$(len(SET)+3) + ')="QLF' + SET + '"'
  FILES = func GET_FILES(DOSSIER, "QLF", FILTRE, 100000, "adx", "TRT", SEP)
End FILES

Funprog GET_REGULAR_QLF_LIST(DOSSIER, SEP)
  Value Char    DOSSIER()
  Value Char    SEP()
  Local Char    FILTRE(250)
  Local Clbfile FILES(10)

  FILTRE = 'pat(TRT,"QLF*_*")'
  FILES = func GET_FILES(DOSSIER, "QLF", FILTRE, 100000, "adx", "TRT", SEP)
End FILES

Funprog GET_FILES(DOSSIER, START, FILTERS, NBMAX, FILEEXT, FILEDIR, SEP)
  Value Char    DOSSIER()
  Value Char    START()
  Value Char    FILTERS()
  Value Integer NBMAX
  Value Char    FILEEXT()
  Value Char    FILEDIR()
  Value Char    SEP()

  Local Char    FILTRE(250), REPERT(GDIMFIC)
  Local Char    MACHINE(250), APPLI(GLONADS), ORDSYS(250)
  Local Char    CODTRT(GLONADC)
  Local Integer NB_TRT, K
  Local Integer NB_MAX

  Local Clbfile FILES(10)

  Call INIT_VERSION

  # Default values initialization
  If NBMAX = -1 : NB_MAX = GNBSEL : Else : NB_MAX = NBMAX : Endif
  If DOSSIER="" : DOSSIER = nomap : Endif

  Call MACHINE(DOSSIER, MACHINE, APPLI) From ORDSYS
  REPERT = filpath(FILEDIR, "", "", APPLI, "", MACHINE)

  # Insert start filter
  If START=""
    FILTRE = ""
  Else
    FILTRE = 'TRT>="'+START+'"'
  Endif

  # Exclude empty named files
  If FILTRE<>"" : Append FILTRE, "&" : Endif
  Append FILTRE, 'TRT<>""'

  # insert caller filters
  If FILTERS<>""
    If FILTRE<>"" : Append FILTRE, "&" : Endif
    Append FILTRE, FILTERS
  Endif

  If clalev([F:TRT_])>0 : Close Local File [TRT_] : Endif
  Case FILEEXT
   When "src"
    ORDSYS = MACHINE + "@" + 'lsadx -a' - toupper(APPLI) - REPERT
    Append FILTRE, '& pat(' + FILEDIR + ',"*.src")'
   When "stc"
    ORDSYS = MACHINE + "@" + 'lsadx -a' - toupper(APPLI) - REPERT
    Append FILTRE, '& pat(' + FILEDIR + ',"*.stc")'
   When "adx"
    ORDSYS = MACHINE + "@" + 'lsadx -a' - toupper(APPLI) - REPERT
    Append FILTRE, '& pat(' + FILEDIR + ',"*.adx")'
   When Default
    ORDSYS = MACHINE + "@" + "archive -d " + DOSSIER + " -t"
    If GXUNIT_RUNTIME_VERSION < "17r.106"
      ORDSYS += ' "adx"'
    Endif
    ORDSYS += ' -l "*" -v'
  Endcase
  Local File (TRT(30)) From System ORDSYS As [TRT_]

  NB_TRT =0
  For [TRT_] Where evalue(FILTRE)
   NB_TRT += 1
   K = instr(1, [F:TRT_]TRT, "." + FILEEXT)
   If K
    CODTRT = left$([F:TRT_]TRT, K-1)
   Else
    CODTRT = [F:TRT_]TRT
   Endif
   If NB_TRT > NB_MAX
     Break
   Endif
   Append FILES, CODTRT
   Append FILES, SEP
  Next TRT_
End FILES

Subprog INIT_VERSION
  If dim(GXUNIT_RUNTIME_VERSION) < 0
    Global Char GXUNIT_RUNTIME_VERSION(20)
    GXUNIT_RUNTIME_VERSION = func AFNC.PARTSEP(ver$(0), 2, " ")
  Endif
End

Funprog GET_SELF_NAME
  If dim(GXUNIT_SELF_NAME) < 0 : Global Char GXUNIT_SELF_NAME(30) : Endif
  If GXUNIT_SELF_NAME = ""
    Local Integer POS1
    Local Integer POS2
    POS1 = instr(1, adxpno(0), "/")
    POS2 = instr(POS1 + 1, adxpno(0), "$")
    GXUNIT_SELF_NAME = mid$(adxpno(0), POS1 + 1, POS2 - POS1 - 1)
  Endif
End GXUNIT_SELF_NAME

#**
#* Adds a line to the log file
#* @internal
#*
#* @param LINE
#*!
Subprog LOG_APPEND(LINE)
  Openo func LOG_NAME, -1 Using [LOG_]
  Iomode adxium GUTF8 Using [LOG_]
  Iomode adxirs "" Using [LOG_]
#  Wrseq DBGT_LINE+chr$(10) Using [LOG_]
#  Wrseq DBGT_LINE Using [LOG_]
  Wrseq LINE Using [LOG_]
  Openo Using [LOG_]
End

#**
#* Adds a line to the log file
#* @internal
#*
#* @param LINE
#*!
Subprog LOG_LINE(LINE)
  Openo func LOG_NAME, -1 Using [LOG_]
#  Iomode adxium GASCII Using [LOG_]
  Iomode adxium GUTF8 Using [LOG_]
  Iomode adxirs "" Using [LOG_]
#  Wrseq DBGT_LINE+chr$(10) Using [LOG_]
#  Wrseq DBGT_LINE Using [LOG_]
  Wrseq format$("D:YYYY[-]MM[-]DD", date$) + "T" + time$ + "." + format$("N0:3", mod(val(timestamp$), 1000)) + ": " Using [LOG_]
  Wrseq LINE Using [LOG_]
  Wrseq chr$(10) Using [LOG_]
  Openo Using [LOG_]
End


Subprog LOG_JSON(JSON)
  Local Char JSON_FILE_NAME(250)

  Openo func JSON_LOG_NAME, -1 Using [LOG_]
  Iomode adxium GUTF8 Using [LOG_]
  Iomode adxirs "" Using [LOG_]
#  Wrseq format$("D:YYYY[-]MM[-]DD", date$) + "T" + time$ + "." + format$("N0:3", mod(val(timestamp$), 1000)) + ": " Using [LOG_]
  Wrseq JSON Using [LOG_]
  Openo Using [LOG_]
End

Funprog SAVE_ENV
  If dim(GXU_GUSER) < 0 : Global Char GXU_GUSER(5) : Endif
  GXU_GUSER = GUSER
  If dim(GXU_GLOGIN) < 0 : Global Char GXU_GLOGIN(30) : Endif
  GXU_GLOGIN = GLOGIN
  If dim(GXU_ADXUSR) < 0 : Global Char GXU_ADXUSR(12) : Endif
  GXU_ADXUSR = adxusr
End GXU_GUSER - GXU_GLOGIN - GXU_ADXUSR

Funprog RESTORE_ENV
  If dim(GXU_GUSER) > 0 : GUSER = GXU_GUSER : Endif
  If dim(GXU_GLOGIN) > 0 : GLOGIN = GXU_GLOGIN : Endif
  If dim(GXU_ADXUSR) > 0 : adxusr = GXU_ADXUSR : Endif
End GUSER - GLOGIN - adxusr

#**
#* Run a test suite.</br>
#*
#* A test suite must fit the following code template:
#*
#* <pre>
#* Funprog TESTSUITE()
#*   Call ADD_TESTCASE("TEST_MYCASE1", "My description of the test case 1", NB_CHECKS_IN_TEST_CASE_1)
#*   Call ADD_TESTCASE("TEST_MYCASE2", "My description of the test case 2", NB_CHECKS_IN_TEST_CASE_2)
#* End func AXUNIT.RUN_TESTSUITE("REQ-99999", "My description of the test suite for requirement 99999")
#*
#* Subprog TEST_MYCASE1
#*   ...
#*   Call CHECK_EQUAL(GOT, EXPECT) From AXUNIT
#*   ...
#*   Call CHECK_TRUE(GOT) From AXUNIT
#*   ...
#* End
#* </pre>
#* @param SUITE_ID
#* @param SUITE_DESCRIPTION
#*!
Funprog RUN_TESTSUITE(SUITE_ID, SUITE_DESCRIPTION)
  Value Char SUITE_ID()
  Value Char SUITE_DESCRIPTION()

  Local Integer FATAL_ERR

  Call SAVE_ENV

  Onerrgo SUITE_ERR
  Call TESTSUITE_START(SUITE_ID, SUITE_DESCRIPTION)
  If FATAL_ERR <> 0
    Goto END_SUITE
  Endif

  Local Integer I
  For I = 1 To GXUNIT_CASE_COUNT
    GXUNIT_CURRENT_CASE = I

    Call RUN_TESTCASE(GXUNIT_CASES(I, 0), GXUNIT_CASES(I, 1), GXUNIT_CASE_ASSERT_COUNT(I, 0),FATAL_ERR)
    If FATAL_ERR <> 0
      Goto END_SUITE
    Endif
  Next I

$END_SUITE
  Call TESTSUITE_END
  Call RESTORE_ENV

  Onerrgo
End func SUITE_RESULT()

$SUITE_ERR
  Local Char FATAL_MES(250)
  FATAL_ERR = errn
  FATAL_MES = "** FATAL SUITE ERROR ** (" + num$(errn) + "): " + errmes$(errn) + "[" + errp + ":" + num$(errl) + "]"
  Append GXUNIT_SUITE_RESULT, chr$(10)
  Append GXUNIT_SUITE_RESULT, FATAL_MES

#  Append GXUNIT_SUITE_RESULT, chr$(10)
#  Local Integer STAT
#  If dim(GSTACK) < 0 : Global Clbfile GSTACK(7) : Endif
#  STAT = dbgCallStack(0, GSTACK)
#  Call APPEND_STACK(GXUNIT_SUITE_RESULT, GSTACK)

  Call RESET_UNIT
Resume

Subprog LOAD_SVG_TEST_SET
If filinfo(filpath("",GXUNIT_MODULE_NAME,"",nomap),0)>0
 # il y avait un jeux de test

 If clalev([F:JXT])=0 : Local File (FICHEJXT(30)) From System 'lsadx -a '+nomap+' '+GXUNIT_MODULE_NAME+ ' dat' As [JXT] : Endif
 For [JXT]
   Call INTEG(DOSSIER,"SVG","","",FICHEJXT,"2","2","1",0,FICTRA,RETOUR) From DOSINTEG
 Next

Endif
End


Subprog RESET_UNIT
  GXUNIT_SUITE_RUNNING = 0
  GXUNIT_CURRENT_CASE = 0
  GXUNIT_CASE_COUNT = 0
  GXUNIT_MODULE_NAME = ""
  GXUNIT_TSTAMP = ""
End

#**
#* Run a test case
#* @internal
#*
#* @param SUBPRG
#* @param DESCRIPTION
#*!
Subprog RUN_TESTCASE(SUBPRG, DESCRIPTION, ASSERT_COUNT,FATAL_ERR)
  Value Char SUBPRG()
  Value Char DESCRIPTION()
  Value Integer ASSERT_COUNT
  Variable Integer FATAL_ERR

  Onerrgo CASE_ERR
  Call TESTCASE_START(SUBPRG, DESCRIPTION)
  Call =SUBPRG With From =GXUNIT_MODULE_NAME
  Call TESTCASE_END
  Onerrgo
End

$CASE_ERR
  Local Char FATAL_MES(250)
  GXUNIT_FAILURE += 1

  FATAL_ERR = errn
  FATAL_MES=": Error(" + num$(errn) + ") - " + errmes$(errn) + "[" + errp + ":" + num$(errl) + "]" + chr$(10)

  Call APPEND_ERROR(chr$(10))
  Call APPEND_ERROR("** FATAL CASE ERROR ** in '" + GXUNIT_CASES(GXUNIT_CURRENT_CASE, 0) + "'")
  Call APPEND_ERROR(FATAL_MES)
  Call FLUSH_ERROR

#  Local Integer STAT
#  If dim(GSTACK) < 0 : Global Clbfile GSTACK(7) : Endif
#  STAT = dbgCallStack(0, GSTACK)
#  Append GXUNIT_SUITE_RESULT, chr$(10)
#  Call APPEND_STACK(GXUNIT_SUITE_RESULT, GSTACK, chr$(10))
Resume

Subprog ADD_TESTCASE(SUBPRG, DESCRIPTION, ASSERT_COUNT)
  Value Char SUBPRG()
  Value Char DESCRIPTION()
  Value Integer ASSERT_COUNT

  Call INIT_UNIT

  GXUNIT_CASE_COUNT += 1
  GXUNIT_CASES(GXUNIT_CASE_COUNT, 0) = SUBPRG
  GXUNIT_CASES(GXUNIT_CASE_COUNT, 1) = DESCRIPTION
  GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CASE_COUNT, 0) = ASSERT_COUNT
  GXUNIT_CASE_ASSERT_COUNT(GXUNIT_CASE_COUNT, 1) = 0
End

#**
#* Clears the content of the log file
#* @internal
#*!
Subprog LOG_CLEAR
  Openo func LOG_NAME,0 Using [LOG_]
  Openo Using [LOG_]
  Openo func JSON_LOG_NAME,0 Using [LOG_]
  Openo Using [LOG_]
End

#**
#* Returns the trace name
#* @internal
#*!
Funprog LOG_NAME()
  If dim(GXUNIT_LOG_NAME) < 0  : Global Char GXUNIT_LOG_NAME(255) : Endif
  If dim(GXUNIT_MODULE_NAME) < 0 : Global Char GXUNIT_MODULE_NAME(255) : Endif
  If [V]GXUNIT_LOG_NAME = ""
    Local Char NAME(255)
    If GXUNIT_MODULE_NAME = "" : Call INIT_UNIT : Endif
    If dim(GXU_GUSER) < 0 : Call SAVE_ENV : Endif
    NAME = GXUNIT_MODULE_NAME + "_" + toupper(ctrans(GXU_GUSER,".\/|*@","______"))
    [V]GXUNIT_LOG_NAME = filpath("TRA", NAME, "tra", 0)
  Endif
End [V]GXUNIT_LOG_NAME

Funprog TRACE_NAME()
  If dim(GXUNIT_TRACE_NAME) < 0  : Global Char GXUNIT_TRACE_NAME(255) : Endif

  If [V]GXUNIT_TRACE_NAME = ""
    Local Char NAME(255)
    NAME = func GET_SELF_NAME + "_RUN_" + toupper(ctrans(GXU_GUSER,".\/|*@","______"))
    [V]GXUNIT_TRACE_NAME = filpath("TRA", NAME, "tra", 0)
  Endif
End [V]GXUNIT_TRACE_NAME

Subprog TRACE_CLEAR
  Openo func TRACE_NAME,0 Using [TRA_]
  Openo Using [TRA_]
  Raz GXUNIT_TRACE_NAME
End

Subprog TRACE_LINE(LINE)
  Openo func TRACE_NAME, -1 Using [TRA_]
  Iomode adxium GUTF8 Using [TRA_]
  Iomode adxirs "" Using [TRA_]
  Wrseq format$("D:YYYY[-]MM[-]DD", date$) + "T" + time$ + "." + format$("N0:3", mod(val(timestamp$), 1000)) + ": " Using [TRA_]
  Wrseq LINE Using [TRA_]
  Wrseq chr$(10) Using [TRA_]
  Openo Using [TRA_]
End

#**
#* Returns the json log name
#* @internal
#*!
Funprog JSON_LOG_NAME()
  If dim(GXUNIT_JSON_NAME) < 0  : Global Char GXUNIT_JSON_NAME(255) : Endif
  If [V]GXUNIT_JSON_NAME = ""
    Local Char NAME(255)
    If GXUNIT_MODULE_NAME = "" : Call INIT_UNIT : Endif
    NAME = GXUNIT_MODULE_NAME + "_" + toupper(ctrans(GXU_GUSER,".\/|*@","______"))
    [V]GXUNIT_JSON_NAME = filpath(nomap + "/TMP", NAME, "json", "X3_PUB")
  Endif
End [V]GXUNIT_JSON_NAME

Funprog RAZ_CONTEXT()
  Onerrgo TRAP_ERROR
  If dim(GXUNIT_TSTAMP) > 0 : Kill GXUNIT_TSTAMP : Endif
  If dim(GXUNIT_ID) > 0 : Kill GXUNIT_ID : Endif
  If dim(GXUNIT_DESCRIPTION) > 0 : Kill GXUNIT_DESCRIPTION : Endif
  If dim(GXUNIT_SUCCESS) > 0 : Kill GXUNIT_SUCCESS : Endif
  If dim(GXUNIT_FAILURE) > 0 : Kill GXUNIT_FAILURE : Endif
  If dim(GXUNIT_TESTID) > 0 : Kill GXUNIT_TESTID : Endif
  If dim(GXUNIT_RESULT) > 0 : Kill GXUNIT_RESULT : Endif
  If dim(GXUNIT_ERROR) > 0 : Kill GXUNIT_ERROR : Endif
  If dim(GXUNIT_FILE) > 0 : Kill GXUNIT_FILE : Endif
  Onerrgo
End "ok"

$TRAP_ERROR
Resume

$TRAP_AND_GET_ERROR
If dim(TRAP_ERRN) > 0 : TRAP_ERRN = errn : Endif
Resume

# ===========================================================
# == Helpers
# ===========================================================
#**
#* Dumps a class to the log file
#* @internal
#*
#* @param LINE
#*!
Subprog LOG_CLASS(STRUCTURE,VARNAME,ERRORS)
  Variable Instance STRUCTURE Using OBJECT
  Value Char VARNAME
  Value Integer ERRORS

  Openo func LOG_NAME, -1 Using [LOG_]
  Iomode adxium GUTF8 Using [LOG_]
  Iomode adxirs "" Using [LOG_]
  Wrseq format$("D:YYYY[-]MM[-]DD", date$) + "T" + time$ + "." + format$("N0:3", mod(val(timestamp$), 1000)) + ": " Using [LOG_]
  Wrseq "Instance"-VARNAME-"of class"-STRUCTURE.ObjectType+chr$(10) Using [LOG_]
  Wrseq func STRUCT_DUMP(STRUCTURE, VARNAME, ERRORS) Using [LOG_]
  Openo Using [LOG_]
End

Funprog STRUCT_DUMP(STRUCTURE, VARNAME, ERRORS)
End func STRUCT_LINE(STRUCTURE, VARNAME, ERRORS,0)

Funprog STRUCT_LINE(STRUCTURE, VARNAME, ERRORS, LEVEL)
Value Integer LEVEL
Local Clbfile CHAINE,CHAINE1
Local Char PROG(100)
Local Integer I,J,K,L,N

  PROG="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".STRUCT_LINE"

  If dim(STRUCTURE,0)>1
    End "Cannot handle multi-dimensional arrays"
  Endif
  If type(STRUCTURE)=524 and STRUCTURE=null
    Append CHAINE, space$(2)+string$(LEVEL,"|    ")+"Null instance"-VARNAME+chr$(10)
  Elsif dim(STRUCTURE)=32767 and type(STRUCTURE)=524
    L=maxtab(STRUCTURE)
    CHAINE=space$(2)+string$(LEVEL,"|    ")+"Collection"-VARNAME-"of"-STRUCTURE.ObjectType-"(1.."+num$(L+1)+")"+chr$(10)
    For I=0 To L
      Gosub HEAD_ARRAY
      Gosub ADD_MEMBER
    Next I
  Elsif dim(STRUCTURE)=1 and type(STRUCTURE)=524
    CHAINE=space$(2)+string$(LEVEL,"|    ")+"Instance"-VARNAME-"of"-STRUCTURE.ObjectType+chr$(10)
    I=0
    Gosub ADD_MEMBER
  Elsif dim(STRUCTURE)>1 and type(STRUCTURE)<>524
    CHAINE=space$(2)+string$(LEVEL,"|    ")+"Array"-VARNAME-"of"
    Gosub ADD_TYPE
#   CHAINE+=chr$(10)
    For I=1 To maxtab(I)
      Append CHAINE, space$(2)+string$(LEVEL,"|    ")+format$("N0:3",I)+": "
      Gosub ADD_MEMBER
    Next I
  Else
    CHAINE=space$(2)+string$(LEVEL,"|    ")
    I=0
    Gosub ADD_TYPE
    CHAINE-=VARNAME+" : "
    Gosub ADD_MEMBER
  Endif
End CHAINE

$ADD_MEMBER
Case type(STRUCTURE)
  When 1,2,4,5,6,7 : Append CHAINE, num$(STRUCTURE(I))+chr$(10)
  When 3 : Append CHAINE,  '"'+format$("D:4Y[-]MM[-]DD",STRUCTURE(I))+'"'+chr$(10)
  When 522 : K=b64Encode(STRUCTURE(I),CHAINE1) : Append CHAINE,  "'"+CHAINE1+"'"+chr$(10)
  When 524 : LEVEL+=1
             If dim(STRUCTURE(I).AERROR) < 0
               M = 0
             Else
               M = maxtab(STRUCTURE(I).AERROR)
             Endif
             If M<>0 and ERRORS<>0
               For J=1 To M
                 If STRUCTURE(I).AERROR(J)<>null and STRUCTURE(I).AERROR(J).PRO=""
                   Append CHAINE, space$(2)+string$(LEVEL,"|    ")+" ** "+func ERVAR(STRUCTURE(I).AERROR(J).STA)-STRUCTURE(I).AERROR(J).MES+chr$(10)
                 Endif
               Next J
             Endif
             K=STRUCTURE(I).ObjectNbs
             For J=1 To K
               If find(STRUCTURE(I).ObjectVar(J),"AATTRIBUTES","ACTX","AERROR","AINF","AKEYS","AORDER","APARENT","ASTALIN","AUUID","ACURFCY")=0
&              and ((LEVEL=1) or find(STRUCTURE(I).ObjectVar(J),"CREDATTIM","UPDDATTIM","CREUSR","UPDUSR")=0)
                 Append CHAINE, evalue(PROG+"(STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J)+',"'+STRUCTURE(I).ObjectVar(J)+'"'+",ERRORS,LEVEL)")
                 If M<>0 and ERRORS<>0
                   For N=1 To M
                     If STRUCTURE(I).AERROR(N)<>null and STRUCTURE(I).AERROR(N).PRO=STRUCTURE(I).ObjectVar(J)
                       Append CHAINE, space$(2)+string$(LEVEL,"|    ")+" ** "+func ERVAR(STRUCTURE(I).AERROR(N).STA)-STRUCTURE(I).AERROR(N).MES+chr$(10)
                     Endif
                   Next N
                 Endif
               Endif
             Next J
             LEVEL=max(LEVEL-1,0)
  When 525,526 : Append CHAINE, '"'+num$(STRUCTURE(I))+'"'+chr$(10)
  When Default : Append CHAINE,  '"'+escJson(STRUCTURE(I))+'"'+chr$(10)
 Endcase
 Return

$HEAD_ARRAY
  Append CHAINE, space$(2)+string$(LEVEL,"|    ")+" "+format$("N0:3",I+1)+": "
  If STRUCTURE(I)=null
    Append CHAINE, "[Null]"
  Elsif type(STRUCTURE(I).ASTALIN)>0
    Append CHAINE, "["
    Case STRUCTURE(I).ASTALIN
      When [V]CST_ANEW   : Append CHAINE, "NEW,"+format$("N0:3",STRUCTURE(I).AORDER)+"]   "
      When [V]CST_ADEL   : Append CHAINE, "DEL,"+format$("N0:3",STRUCTURE(I).AORDER)+"]   "
      When [V]CST_ANEWDEL: Append CHAINE, "NEWDEL,"+format$("N0:3",STRUCTURE(I).AORDER)+"]"
      When [V]CST_AUPD   : Append CHAINE, "UPD,"+format$("N0:3",STRUCTURE(I).AORDER)+"]   "
      When Default       : Append CHAINE, "NOTMOD,"+format$("N0:3",STRUCTURE(I).AORDER)+"]"
    Endcase
  Endif
 Append CHAINE, chr$(10)
Return

$ADD_TYPE
  Case type(STRUCTURE)
    When 1 : Append CHAINE, "TinyInt"
    When 2 : Append CHAINE, "ShortInt"
    When 3 : Append CHAINE, "Date"
    When 4 : Append CHAINE, "Integer"
    When 5 : Append CHAINE, "Float"
    When 6 : Append CHAINE, "Double"
    When 7 : Append CHAINE, "Decimal"
    When 522 : Append CHAINE, "Blbfile"
    When 523 : Append CHAINE, "Clbfile"
    When 525 : Append CHAINE, "Uuident"
    When 526 : Append CHAINE, "Datetime"
    When Default : Append CHAINE, "String("+num$(type(STRUCTURE)-10)+")"
  Endcase
Return

Funprog ERVAR(I)
Value Integer I
Case I
  When [V]CST_AOK : End "AOK"
  When [V]CST_AINFO : End "AINFO"
  When [V]CST_AWARNING : End "AWARNING"
  When [V]CST_AERROR : End "AERROR"
  When [V]CST_AFATAL : End "AFATAL"
Endcase
End "UNKNOWN"


# ===========================================================
# == TEST
# ===========================================================
$TEST_
Local Clbfile RES(3)
# use intermediate variable to prevent infbox double evaluation issue see #80096
RES = func TESTSUITE
#RES = func RUN_ALL
#  Local Clbfile EXCLUDES(4)
#  Append EXCLUDES, ";"
#  Append EXCLUDES, "QLFSUP_ASYRMAIN;"
#
#  RES = func AXUNIT.RUN_ALL2(EXCLUDES, 0)
#  RES = func QLFSUP_ASYRMAIN.TESTSUITE
#  RES = func QLFRTM_ENCODE.TESTSUITE
  Infbox RES
End

Funprog TESTSUITE()
  # hack to init the module for the Unit test module itself
  If dim(GXUNIT_MODULE_NAME) < 0 : Global Char GXUNIT_MODULE_NAME(255) : Endif
  GXUNIT_MODULE_NAME = func GET_SELF_NAME

  Call ADD_TESTCASE("TC_010", '"abc" <> 2', 1)
  Call ADD_TESTCASE("TC_011", '"" <> "" must fail', 1)
  Call ADD_TESTCASE("TC_012", '"" + "z" <> "z" must fail', 1)
  Call ADD_TESTCASE("TC_020", '"abc" = "abc"', 1)
  Call ADD_TESTCASE("TC_021", 'Check null / not null', 2)
  Call ADD_TESTCASE("TC_030", '(1 = 1) = true', 1)
  Call ADD_TESTCASE("TC_040", '(1 = 0) = false', 1)
  Call ADD_TESTCASE("TC_050", 'callstack trace 1', 4)
  Call ADD_TESTCASE("TC_051", 'callstack json 1', 4)
  Call ADD_TESTCASE("TC_060", 'callstack trace 2', 1)
  Call ADD_TESTCASE("TC_070", 'callstack trace 3', 1)
  Call ADD_TESTCASE("TC_100", 'log class', 0)
End func RUN_TESTSUITE("AXUNIT", "AXUNIT self test")

Subprog TC_010
  Local Char A(250) : A = "abc"

  Call CHECK_NOTEQUAL(A, 2)
End

Subprog TC_011
  # This test must fail
  Local Char A(1) : A = ""
  Call CHECK_NOTEQUAL(A, "")
End

Subprog TC_012
  # This test must fail
  Local Char A(1) : A = ""
  Call CHECK_NOTEQUAL(A + "z", "z")
End

Subprog TC_020
  Local Char A(250) : A = "abc"

  Call CHECK_EQUAL(A, "abc")
End

Subprog TC_021
  Local Instance A Using C_ACLA

  Call CHECK_NULL(A)
  A = NewInstance C_ACLA
  Call CHECK_NOTNULL(A)
  FreeInstance A
End

Subprog TC_030
  Call CHECK_TRUE(1=1)
End

Subprog TC_040
  Call CHECK_FALSE(1=0)
End

Subprog TC_050
  Local Clbfile ST(2)
  Local Clbfile GOT(2)
  Local Clbfile EXPECT(2)

  Raz GOT
  Raz ST
  Append ST, '<stack level="0" type="file" filename="x3://sodaix02:17000/SUPERV/ZXUNIT.src" lineno="253" where="ZXUNIT.TEST_STACK" cmdbegin="253:0" cmdend="253:-1"/>'
  Raz EXPECT
  Append EXPECT, "    at ZXUNIT.TEST_STACK(sodaix02:17000/SUPERV/ZXUNIT.src:254)"
  Append EXPECT, chr$(10)
  Call APPEND_STACK(GOT, ST)
  Call CHECK_EQUAL(GOT, EXPECT)

  Raz GOT
  Raz ST
  Append ST, '<stack level="0" type="file" lineno="253" where="ZXUNIT.TEST_STACK" cmdbegin="253:0" cmdend="253:-1"/>'
  Raz EXPECT
  Append EXPECT, "    at ZXUNIT.TEST_STACK(:254)"
  Append EXPECT, chr$(10)
  Call APPEND_STACK(GOT, ST)
  Call CHECK_EQUAL(GOT, EXPECT)

  Raz GOT
  Raz ST
  Append ST, '<stack level="0" type="file" where="ZXUNIT.TEST_STACK" cmdbegin="253:0" cmdend="253:-1"/>'
  Raz EXPECT
  Append EXPECT, "    at ZXUNIT.TEST_STACK(:)"
  Append EXPECT, chr$(10)
  Call APPEND_STACK(GOT, ST)
  Call CHECK_EQUAL(GOT, EXPECT)

  Raz GOT
  Raz ST
  Append ST, '<stack level="0" type="file" cmdbegin="253:0" cmdend="253:-1"/>'
  Raz EXPECT
  Append EXPECT, "    at (:)"
  Append EXPECT, chr$(10)
  Call APPEND_STACK(GOT, ST)
  Call CHECK_EQUAL(GOT, EXPECT)
End

Subprog TC_051
  Local Clbfile ST(2)
  Local Clbfile GOT(2)
  Local Clbfile EXPECT(2)

  Raz GOT
  Raz ST
  Append ST, '<stack level="0" type="file" filename="x3://sodaix02:17000/SUPERV/ZXUNIT.src" lineno="253" where="ZXUNIT.TEST_STACK" cmdbegin="253:0" cmdend="253:-1"/>'
  Raz EXPECT
  Append EXPECT, '"callstack":[{"where":"ZXUNIT.TEST_STACK","file":"sodaix02:17000/SUPERV/ZXUNIT.src","line":254}]'
  Call PARSE_STACK(GOT, ST, "APPEND_STACK_JSON")
  Call CHECK_EQUAL(GOT, EXPECT)

  Raz GOT
  Raz ST
  Append ST, '<stack level="0" type="file" lineno="253" where="ZXUNIT.TEST_STACK" cmdbegin="253:0" cmdend="253:-1"/>'
  Raz EXPECT
  Append EXPECT, '"callstack":[{"where":"ZXUNIT.TEST_STACK","line":254}]'
  Call PARSE_STACK(GOT, ST, "APPEND_STACK_JSON")
  Call CHECK_EQUAL(GOT, EXPECT)

  Raz GOT
  Raz ST
  Append ST, '<stack level="0" type="file" where="ZXUNIT.TEST_STACK" cmdbegin="253:0" cmdend="253:-1"/>'
  Raz EXPECT
  Append EXPECT, '"callstack":[{"where":"ZXUNIT.TEST_STACK"}]'
  Call PARSE_STACK(GOT, ST, "APPEND_STACK_JSON")
  Call CHECK_EQUAL(GOT, EXPECT)

  Raz GOT
  Raz ST
  Append ST, '<stack level="0" type="file" cmdbegin="253:0" cmdend="253:-1"/>'
  Raz EXPECT
  Append EXPECT, '"callstack":[]'
  Call PARSE_STACK(GOT, ST, "APPEND_STACK_JSON")
  Call CHECK_EQUAL(GOT, EXPECT)
End

Subprog TC_060
  Local Clbfile ST(2)
  Local Clbfile GOT(2)
  Local Clbfile EXPECT(2)
  ST = ''
  Append ST, '<stack level="0" type="file" filename="x3://sodaix02:17000/SUPERV/ZXUNIT.src" lineno="253" where="ZXUNIT.TEST_STACK" cmdbegin="253:0" cmdend="253:-1"/>'
  Append ST, '<stack level="1" type="file" filename="x3://sodaix02:17000/SUPERV/.src" lineno="2015" where="WMAXDCOR_122.EVALUE_EXPR" cmdbegin="2015:0" cmdend="2015:-1"/>'

  Append EXPECT, "    at ZXUNIT.TEST_STACK(sodaix02:17000/SUPERV/ZXUNIT.src:254)"
  Append EXPECT, chr$(10)
  Append EXPECT, "    at WMAXDCOR_122.EVALUE_EXPR(sodaix02:17000/SUPERV/.src:2016)"
  Append EXPECT, chr$(10)

  Call APPEND_STACK(GOT, ST)

  Call CHECK_EQUAL(GOT, EXPECT)
End

Subprog TC_070
  Local Clbfile ST(4)
  Local Clbfile GOT(4)
  Local Clbfile EXPECT(4)
  ST = ''
  Append ST, '<stack level="0" type="file" filename="x3://sodaix02:17000/SUPERV/AXUNIT.src" lineno="323" where="AXUNIT.CHECK_EQUAL" cmdbegin="323:0" cmdend="323:-1"/>'
  Append ST, '<stack level="1" type="file" filename="x3://sodaix02:17000/SUPERV/QLFSUP_ASYRQRY.src" lineno="229" where="QLFSUP_ASYRQRY.CHECK_PRO_EQUAL" cmdbegin="229:0" cmdend="229:-1"/>'
  Append ST, '<stack level="2" type="file" filename="x3://sodaix02:17000/SUPERV/QLFSUP_ASYRQRY.src" lineno="319" where="QLFSUP_ASYRQRY.TC004" cmdbegin="319:0" cmdend="319:-1"/>'
  Append ST, '<stack level="3" type="file" filename="x3://sodaix02:17000/SUPERV/AXUNIT.src" lineno="792" where="AXUNIT.RUN_TESTCASE" cmdbegin="792:0" cmdend="792:-1"/>'
  Append ST, '<stack level="4" type="file" filename="x3://sodaix02:17000/SUPERV/AXUNIT.src" lineno="740" where="AXUNIT.RUN_TESTSUITE" cmdbegin="740:0" cmdend="740:-1"/>'
  Append ST, '<stack level="5" type="file" filename="x3://sodaix02:17000/SUPERV/QLFSUP_ASYRQRY.src" lineno="32" where="QLFSUP_ASYRQRY.TESTSUITE" cmdbegin="32:0" cmdend="32:-1"/>'
  Append ST, '<stack level="6" type="file" filename="x3://sodaix02:17000/SUPERV/QLFSUP_ASYRQRY.src" lineno="6" where="QLFSUP_ASYRQRY" cmdbegin="6:0" cmdend="6:-1"/>'
  Append ST, '<stack level="7" type="file" lineno="1" where="MENU" cmdbegin="1:0" cmdend="1:-1"/>'

  Append EXPECT, "    at AXUNIT.CHECK_EQUAL(sodaix02:17000/SUPERV/AXUNIT.src:324)"
  Append EXPECT, chr$(10)
  Append EXPECT, "    at QLFSUP_ASYRQRY.CHECK_PRO_EQUAL(sodaix02:17000/SUPERV/QLFSUP_ASYRQRY.src:230)"
  Append EXPECT, chr$(10)
  Append EXPECT, "    at QLFSUP_ASYRQRY.TC004(sodaix02:17000/SUPERV/QLFSUP_ASYRQRY.src:320)"
  Append EXPECT, chr$(10)
  Append EXPECT, "    at AXUNIT.RUN_TESTCASE(sodaix02:17000/SUPERV/AXUNIT.src:793)"
  Append EXPECT, chr$(10)
  Append EXPECT, "    at AXUNIT.RUN_TESTSUITE(sodaix02:17000/SUPERV/AXUNIT.src:741)"
  Append EXPECT, chr$(10)
  Append EXPECT, "    at QLFSUP_ASYRQRY.TESTSUITE(sodaix02:17000/SUPERV/QLFSUP_ASYRQRY.src:33)"
  Append EXPECT, chr$(10)
  Append EXPECT, "    at QLFSUP_ASYRQRY(sodaix02:17000/SUPERV/QLFSUP_ASYRQRY.src:7)"
  Append EXPECT, chr$(10)
  Append EXPECT, "    at MENU(:2)"
  Append EXPECT, chr$(10)

  Call APPEND_STACK(GOT, ST)

  Call CHECK_EQUAL(GOT, EXPECT)
End

Subprog TC_100()
 Local Instance  DELTAS Using C_ADELTA

 DELTAS = NewInstance C_ADELTA AllocGroup JSO

 Call LOG_CLASS(DELTAS, "DELTAS", 1)

 Call CHECK_EQUAL(DELTAS.CAT, 0)
 Call CHECK_EQUAL(num$(DELTAS.UID), "00000000-0000-0000-0000-000000000000")
End

Funprog STACK()
  Local Clbfile ST(1)
  Local Clbfile ST2(1)
  ST = ''
  Append ST, '<stack level="0" type="file" filename="x3://sodaix02:17000/SUPERV/ZXUNIT.src" lineno="253" where="ZXUNIT.TEST_STACK" cmdbegin="253:0" cmdend="253:-1"/>'
  Append ST, '<stack level="1" type="file" filename="x3://sodaix02:17000/SUPERV/.src" lineno="2015" where="WMAXDCOR_122.EVALUE_EXPR" cmdbegin="2015:0" cmdend="2015:-1"/>'
  Call APPEND_STACK(ST2, ST)
