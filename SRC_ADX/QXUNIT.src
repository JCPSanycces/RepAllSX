End "ok: " +chr$(10) + ST2

Funprog TEST_STACK
End func TEST_STACK2

Funprog TEST_STACK2
  Local Integer STAT
  Local Clbfile STACK(10)
  Local Clbfile STACK2(10)
  Onerrgo STACK_ERROR
  STAT = dbgCallStack(0, STACK)
  Onerrgo
  Append STACK2, "stat=" + num$(STAT) + chr$(10)
  Append STACK2, STACK
  Append STACK2, chr$(10)
  Call APPEND_STACK(STACK2, STACK)
End STACK2


Subprog TEST_SUITE_LINE(UNIT_ID, UNIT_DES, FLDER)
Value Char UNIT_ID, UNIT_DES, FLDER
Local File ZAQRESSUITE [ZAQRS]
Trbegin [ZAQRS]
Delete [F:ZAQRS] Where UNIT_ID=[L]UNIT_ID
[F:ZAQRS]UNIT_ID=[L]UNIT_ID
[F:ZAQRS]DESCRIPTION=[L]UNIT_DES
[F:ZAQRS]ENDPOINT=[L]FLDER
Read [F:ZAQRS]ZAQRS0=UNIT_ID
If fstat
Endif
End

