Gosub $TEST_
End

#**
#* Start method to be called at the beginning of a test suite<br>
#*
#* @param SUITE_ID
#* @param SUITE_DESCRIPTION
#* @private
#* @deprecated
#* @see #RUN_TESTSUITE
#*!
Subprog TESTSUITE_START(SUITE_ID, SUITE_DESCRIPTION)
  Value Char SUITE_ID()
  Value Char SUITE_DESCRIPTION()

  Call INIT_UNIT
  Call SAVE_ENV

  If dim(GXUNIT_ID) < 0 : Global Char GXUNIT_ID(255) : Endif
  GXUNIT_ID = SUITE_ID
  If dim(GXUNIT_SUITE_DESCRIPTION) < 0 : Global Char GXUNIT_SUITE_DESCRIPTION(255) : Endif
  GXUNIT_SUITE_DESCRIPTION = SUITE_DESCRIPTION
  If dim(GXUNIT_CASE_ID) < 0 : Global Integer GXUNIT_CASE_ID : Endif
  GXUNIT_CASE_ID = 0
  If dim(GXUNIT_CASE_SUCCESS) < 0 : Global Integer GXUNIT_CASE_SUCCESS : Endif
  GXUNIT_CASE_SUCCESS = 0
  If dim(GXUNIT_CASE_FAILURE) < 0 : Global Integer GXUNIT_CASE_FAILURE : Endif
  GXUNIT_CASE_FAILURE = 0

  If dim(GXUNIT_LOG_NAME) < 0  : Global Char GXUNIT_LOG_NAME(255) : Endif
  GXUNIT_LOG_NAME = ""
  If dim(GXUNIT_JSON_NAME) < 0  : Global Char GXUNIT_JSON_NAME(255) : Endif
  GXUNIT_JSON_NAME = ""

  GXUNIT_TSTAMP = timestamp$
  Call LOG_CLEAR
  Call LOG_LINE("Start suite - " + GXUNIT_MODULE_NAME + " - " + GXUNIT_ID + " - " + GXUNIT_SUITE_DESCRIPTION)
  Call TEST_SUITE_LINE(GXUNIT_ID, GXUNIT_SUITE_DESCRIPTION, nomap) From QXUNIT     # RCB
  Raz GXUNIT_JSON_SUM,GXUNIT_JSON,GXUNIT_JSON_TMP
  Append GXUNIT_JSON_SUM, '{"module":"' + GXUNIT_MODULE_NAME + '"'
  Append GXUNIT_JSON_SUM, ',"id":"' + GXUNIT_ID + '"'
  Append GXUNIT_JSON_SUM, ',"description":"'
  Call JSON_ESCAPE(GXUNIT_SUITE_DESCRIPTION, GXUNIT_JSON_TMP)
  Append GXUNIT_JSON_SUM, GXUNIT_JSON_TMP
  Append GXUNIT_JSON_SUM, '"'
  Append GXUNIT_JSON, '"cases":['

  Onerrgo TRAP_ERROR
    Call ="SETUP" With From =GXUNIT_MODULE_NAME
  Onerrgo

  Call CHARGE_JEUX_DE_TEST
End

Subprog INIT_UNIT()

  Call INIT_VERSION

  If dim(GXUNIT_TSTAMP) < 0 : Global Char GXUNIT_TSTAMP(20) : Endif
  If GXUNIT_TSTAMP = ""
    GXUNIT_TSTAMP = timestamp$
  Endif
  If dim(GXUNIT_MODULE_NAME) < 0 : Global Char GXUNIT_MODULE_NAME(255) : Endif
  If GXUNIT_MODULE_NAME = ""
    Local Integer NIVEAU
    While adxpno(NIVEAU) = adxpno(0)
      NIVEAU += 1
    Wend
    Local Integer POS1
    Local Integer POS2
    POS1 = instr(1, adxpno(NIVEAU), "/")
    POS2 = instr(POS1 + 1, adxpno(NIVEAU), "$")
    GXUNIT_MODULE_NAME = mid$(adxpno(NIVEAU), POS1 + 1, POS2 - POS1 - 1)
  Endif

  If dim(GXUNIT_SUITE_RUNNING) < 0 : Global Libelle GXUNIT_SUITE_RUNNING : Endif
  GXUNIT_SUITE_RUNNING = 1
  If dim(GXUNIT_SUITE_RESULT) < 0 : Global Clbfile GXUNIT_SUITE_RESULT(2) : Endif
  Raz GXUNIT_SUITE_RESULT
  If dim(GXUNIT_JSON) < 0 : Global Clbfile GXUNIT_JSON(8) : Endif
  If dim(GXUNIT_JSON_SUM) < 0 : Global Clbfile GXUNIT_JSON_SUM : Endif
  If dim(GXUNIT_JSON_TMP) < 0 : Global Clbfile GXUNIT_JSON_TMP(8) : Endif
  Raz GXUNIT_JSON


  If dim(GXUNIT_CASE_COUNT) < 0 : Global Integer GXUNIT_CASE_COUNT : Endif
  If dim(GXUNIT_CURRENT_CASE) < 0 : Global Integer GXUNIT_CURRENT_CASE : Endif
  If dim(GXUNIT_CASES) < 0 : Global Char GXUNIT_CASES(100)(1..,2) : Endif
  If dim(GXUNIT_CASE_ASSERT_COUNT) < 0 : Global Integer GXUNIT_CASE_ASSERT_COUNT(1.., 2) : Endif
End

#**
#* Chargement du jeux de test
#**
Subprog CHARGE_JEUX_DE_TEST
Local Char FICTRA
Local Char RETOUR
Local Char REPDOS
Local Char DOSSIERS

If filinfo(filpath("",GXUNIT_MODULE_NAME,"",nomap),0)>0
# il y a un jeux de test !

  REPDOS = GXUNIT_MODULE_NAME
  DOSSIERS = nomap

 # On sauvegarde si besoin
  If clalev([F:JXT])=0 : Local File (FICHEJXT(30)) From System 'lsadx -a '+nomap+' '+GXUNIT_MODULE_NAME+ ' dat' As [JXT]  : Endif

  For [JXT]
     If filinfo(filpath("SVG",FICHEJXT,"dat",-1),1)<0
       Call EXTRA(DOSSIERS,"SVG","","",FICHEJXT,"2","2","1",0,FICTRA,RETOUR) From DOSEXTRA
     Endif
  Next

 # Mise en ligne du jeux de test
  Call INTEG(DOSSIERS,REPDOS,"","","*","1","1","1",0,FICTRA,RETOUR) From DOSINTEG

Endif
End

#**
#* End method to be called at the end of a test suite
#*!
Subprog TESTSUITE_END
#  Call LOG_LINE("End suite: " + GXUNIT_ID + " - " + GXUNIT_SUITE_DESCRIPTION)
#  Append GXUNIT_SUITE_RESULT, num$(GXUNIT_CASE_SUCCESS + GXUNIT_CASE_FAILURE)
#  Append GXUNIT_SUITE_RESULT, " test cases run - "
  If dim(GXUNIT_SUITE_ERROR) > 0 & len(GXUNIT_SUITE_ERROR) > 0
    Append GXUNIT_SUITE_RESULT, GXUNIT_SUITE_ERROR
    Raz GXUNIT_SUITE_ERROR
  Endif

  Local Integer ELAPSED
  ELAPSED = val(timestamp$) - val(GXUNIT_TSTAMP)

  Append GXUNIT_SUITE_RESULT, GXUNIT_MODULE_NAME + " - " + GXUNIT_ID + " - "
  Append GXUNIT_SUITE_RESULT, num$(GXUNIT_CASE_SUCCESS)
  Append GXUNIT_SUITE_RESULT, " Succeed, "
  Append GXUNIT_SUITE_RESULT, num$(GXUNIT_CASE_FAILURE)
  Append GXUNIT_SUITE_RESULT, " Failed, "
  Append GXUNIT_SUITE_RESULT, num$(ELAPSED)
  Append GXUNIT_SUITE_RESULT, "ms elapsed"
  Append GXUNIT_SUITE_RESULT, chr$(10)
  Append GXUNIT_SUITE_RESULT, "Trace has been written to '"
  Append GXUNIT_SUITE_RESULT, func LOG_NAME()
  Append GXUNIT_SUITE_RESULT, "'"
#  Append GXUNIT_SUITE_RESULT, chr$(10)
#  Append GXUNIT_SUITE_RESULT, "JSON result has been written to '"
#  Append GXUNIT_SUITE_RESULT, func JSON_LOG_NAME()
#  Append GXUNIT_SUITE_RESULT, "'"

  Append GXUNIT_SUITE_RESULT, chr$(10)
  Append GXUNIT_SUITE_RESULT, "JSON result is available at: "
  Append GXUNIT_SUITE_RESULT, "http://"
  Append GXUNIT_SUITE_RESULT, GVIRTDIR
  Append GXUNIT_SUITE_RESULT, "/" + nomap + "/TMP/"
  Append GXUNIT_SUITE_RESULT, GXUNIT_MODULE_NAME + "_" + toupper(ctrans(GXU_GUSER,".\/|*@","______"))
  Append GXUNIT_SUITE_RESULT, ".json"

  Call LOG_APPEND(chr$(10))
  Call LOG_LINE(GXUNIT_SUITE_RESULT)

  Append GXUNIT_JSON_SUM ,',"elapsed":'
  Append GXUNIT_JSON_SUM , num$(ELAPSED)
  Append GXUNIT_JSON_SUM ,',"ok":'
  Append GXUNIT_JSON_SUM , num$(GXUNIT_CASE_SUCCESS)
  Append GXUNIT_JSON_SUM ,',"fail":'
  Append GXUNIT_JSON_SUM , num$(GXUNIT_CASE_FAILURE)
  Append GXUNIT_JSON_SUM ,','
  Append GXUNIT_JSON     ,']'

  Call LOG_JSON(GXUNIT_JSON_SUM)
  Call LOG_JSON(GXUNIT_JSON)
  Call LOG_JSON('}')

