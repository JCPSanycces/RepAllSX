#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PRF4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:05"
A_USER  = "DOC"
A_STAMP = "20181109230605"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRDIC"
  If [M]NBRDIC=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PRF4 [PRF4]
Gosub HORODAT
Local Inpbox "PRF4" From GFONCTION At A_STAMP With A_WINDPREV Mask [PRF4] As [SIM_]
Grizo [PRF4]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PRF4]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=20
Return

$ON_NBRDIC
Onevent BEFORE_INPUT Call AS_NBRDIC From W1PRF4
Return

Subprog AS_NBRDIC
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(13751,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBRDIC From W1PRF4
Gosub _AFF
End

Subprog B1_NBRDIC
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B1_NBRDIC From SUBPRF
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_FLD
Onevent CONTROL Call C_FLD(zc) From W1PRF4
Onevent BEFORE_INPUT Call AS_FLD(zc) From W1PRF4
Return

Subprog AS_FLD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44944,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_FLD(zc) From W1PRF4
Onkey   2 Titled GBOUTS Call S_FLD(zc) From W1PRF4
Gosub _AFF
End

Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_FLD(VALEUR) From SUBPRF
If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
Gosub _AFF
End

Subprog S_FLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call S_FLD(VALEUR) From SUBPRF
Endif
Gosub _AFF
End

Subprog B1_FLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GOBJET1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJET1"
 Call OBJET_CHAR(VALEUR,"DIC",VALEUR) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CODTYP
Return

$ON_NOLIB
Return

$ON_LEV
Onevent BEFORE_INPUT Call AS_LEV(zc) From W1PRF4
Onevent CONTROL Call C_LEV(zc) From W1PRF4
Onevent INIT_AREA Call D_LEV(zc) From W1PRF4
Return

Subprog D_LEV(VALEUR)
Variable Integer VALEUR
If varinit([M]LEV,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LEV(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10508) From COMBOS
## Action STD
Call AS_LEV(VALEUR) From SUBPRF
If mkstat=2
 [M]LEV(INDIC) = VALEUR
 Affzo LEV(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10508,1))))
Endif
If !mkstat
 Discombo 0 From LEV(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From LEV(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_LEV(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_LEV(VALEUR) From SUBPRF
If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
Gosub _AFF
End

$ON_CPY
Onevent CONTROL Call C_CPY(zc) From W1PRF4
Onevent BEFORE_INPUT Call AS_CPY(zc) From W1PRF4
Return

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3529,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_CPY(VALEUR) From SUBPRF
If mkstat=2
 [M]CPY(INDIC) = VALEUR
 Affzo CPY(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CPY(zc) From W1PRF4
Onkey   2 Titled GBOUTS Call S_CPY(zc) From W1PRF4
Onkey 144 Titled GBOUTP Call P_CPY(zc) From W1PRF4
Onkey 146 Titled GBOUTA Call SA_CPY(zc) From W1PRF4
Gosub _AFF
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
If !mkstat
 ## Action ACONTCPY
 Call CONTSOC(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("CPY","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  If !mkstat
   ## Action CONTCPYLEG
   Call CONTCPYLEG(VALEUR,func TOOLSHRLEG.LEGWRK) From TRTX3
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CPY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCPYLEGH
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCPYLEGH"
 PARMSK(1) = func TOOLSHRLEG.LEGWRK
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCPYLEGH","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CPY(VALEUR)
Variable Char    VALEUR()
Call OBJET("CPY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CPY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CPY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

