Subprog AS_POP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45582,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_POP(VALEUR) From SUBPRF
If mkstat=2
 [M]POP(INDIC) = VALEUR
 Affzo POP(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_POP(zc) From W1PRF4
Onkey   2 Titled GBOUTS Call S_POP(zc) From W1PRF4
Onkey 144 Titled GBOUTP Call P_POP(zc) From W1PRF4
Onkey 146 Titled GBOUTA Call SA_POP(zc) From W1PRF4
Gosub _AFF
End

Subprog C_POP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
If !mkstat
 ## Action CONTPOP
 Call CONTPOP(VALEUR,GCURLEG) From SUBPOP
 If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("POP","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
 Endif
Endif
Gosub _AFF
End

