$ON_VALDEF
Onevent BEFORE_INPUT Call AS_VALDEF(zc) From W1PRF4
Onevent CONTROL Call C_VALDEF(zc) From W1PRF4
Return

Subprog IB_VALDEF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,[M]CODTYP(nolign-1),[M]NOLIB(nolign-1),"") From FMTVAR
Endif
Gosub _AFF
End

Subprog AS_VALDEF(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(877,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_VALDEF(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,[M]CODTYP(nolign-1)) From FMTVAR
If mkstat=2
 [M]VALDEF(INDIC) = VALEUR
 Affzo VALDEF(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_VALDEF(zc) From W1PRF4
Onkey   2 Titled GBOUTS Call S_VALDEF(zc) From W1PRF4
Gosub _AFF
End

Subprog C_VALDEF(VALEUR)
Variable Char    VALEUR()
## Action AFMTCONT
Call CONTROLE(VALEUR,[M]CODTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT(nolign-1)) From FMTVAR
If mkstat : GERR = 1 : GZONE = "VALDEF" : GZNUM = 88 : Endif
If !mkstat
 ## Action ACONTACL
 Call CONTACL([M]VALINT(nolign-1),[M]CODTYP(nolign-1),"","") From SUBACL
 If mkstat : GERR = 1 : GZONE = "VALDEF" : GZNUM = 88 : Endif
 If !mkstat
  ## Action STD
  Call C_VALDEF(VALEUR) From SUBPRF
  If mkstat : GERR = 1 : GZONE = "VALDEF" : GZNUM = 88 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_VALDEF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = [M]CODTYP(nolign-1)
 PARMSK(2) = num$([M]NOLIB(nolign-1))
 PARMSK(3) = num$([M]LONG(nolign-1))
 PARMSK(4) = [M]VALINT(nolign-1)
 PARMSK(5) = [M]VALPAR(nolign-1)
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = [M]CODTYP(nolign-1)
 PARMSK(2) = num$([M]NOLIB(nolign-1))
 PARMSK(3) = num$([M]LONG(nolign-1))
 PARMSK(4) = [M]VALINT(nolign-1)
 PARMSK(5) = [M]VALPAR(nolign-1)
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_VALDEF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTB1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTB1"
 PARMSK(1) = [M]CODTYP(nolign-1)
 PARMSK(2) = [M]VALPAR(nolign-1)
 PARMSK(3) = num$([M]NOLIB(nolign-1))
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFMTB1","FMTVAR","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


