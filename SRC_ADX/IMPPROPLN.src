#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
# IMPPROPLN : Import des plans de production
# --------------------------------------------------------------------- #
# dans les tables PROPLNH et PROPLN                                     #
#########################################################################

# CBO 28.05.2013 FQ93592    : Import de plans de production en création


$ACTION
  Case ACTION
    When "IMP_OUVRE"     : Gosub OUVRE

    When "AP_IMPORT"     : Gosub AP_IMPORT
    When "IMPORT"        : Gosub IMPORT
    When "IMP_ZONE"      : Gosub IMP_ZONE
    When "IMP_APRES_CRE" : Gosub IMP_APRES_CRE

    When "IMP_FERME"     : Gosub FERME
  Endcase
Return

##########################################################################################################
#                                  IMPORT                                #
##########################################################################
$OUVRE

Local Integer I, WERR_INIT_SOC
Local Char WCPY_SV(10), WFCY_SV(10)
Local Integer WCNX_SV

Local Char SV_ACTION(50)

    If !clalev([F:FAS])
        Local File FXDASSETS [FAS]
    Endif
    If !clalev([F:PLH])
        Local File PROPLNH [PLH]
    Endif

    If !clalev([F:PLP])
        Local File PROPLN [PLP]
    Endif

    If clalev([F:CPY]) = 0
        Local File COMPANY    [CPY]
    Endif

    If clalev([F:FCY]) = 0
        Local File FACILITY    [FCY]
    Endif


    If clalev([F:CNX]) = 0
        Local File CONTEXT    [CNX]
    Endif
    If clalev([F:FIS])=0
        Local File FISCYEAR   [FIS]
    Endif

    # bonne gestion des ruptures
    WCPY_SV = "e Ea"
    WFCY_SV = "e Ea"
    WCNX_SV = -2

Return


$IMP_ZONE

  Case IMPZON
    When "PLNQTY0"
        If GIMP(1) <> ""
            IMPMOD = 1
            [M:PPL0]PLNQTY0 = val(GIMP(1))
        Endif
    When Default
  Endcase

Return


# 1°) Après l'import d'une ligne du fichier en entrée
$AP_IMPORT

    GMESSAGE = ""
    GERR = 0

    If SEPNUM = 1 # entête

        Gosub INIT_SOC
        If WERR_INIT_SOC
            Return
        Endif
        [F:PLH]FCY = WFCY_SV
        [F:PLH]CPY = WCPY_SV
        [F:PLH]CNX = WCNX_SV

        [F:PLH]ENAFLG = G_OUI


    Else # détail

        [F:PLP]PROPLN = [F:PLH]PROPLN

    Endif

Return



# 2°) A chaque chargement de la classe F à partir du fichier d'import
$IMPORT

    If SEPNUM = 2

        nolign = find([F:PLP]PERENDDAT, [M:PPL1]PERENDDAT)

        If nolign = 0
            # période du contexte non trouvée
            GERR = 1
            OK = 0
            GOK = 0
            GMESSAGE = mess(195, 100, 1) - "(" + format$("D:" + GFMDAT4, [F:PLP]PERENDDAT) + ")"
            Return
        Endif

        If nolign > 1 and [F:PLP]CPLQTY
            GERR = 1
            OK = 0
#            GMESSAGE = "UO réalisée autorisée uniquement sur la période courante" - "(" + format$("D:" + GFMDAT4, [F:PLP]PERENDDAT) + ")"
            GMESSAGE = mess(929, 7773, 1) - "(" + format$("D:" + GFMDAT4, [F:PLP]PERENDDAT) + ")"
            Return
        Endif


        [F:PLP]FIYSTRDAT = [M:PPL1]FIYSTRDAT(nolign - 1)
        [F:PLP]FIYENDDAT = [M:PPL1]FIYENDDAT(nolign - 1)
        [F:PLP]PERSTRDAT = [M:PPL1]PERSTRDAT(nolign - 1)

        [M:PPL1]PERENDDATC(nolign - 1) = format$("D:" + GFMDAT4, [F:PLP]PERENDDAT)

        [M:PPL1]EXTQTY(nolign - 1) = [F:PLP]EXTQTY
        [M:PPL1]CPLQTY(nolign - 1) = [F:PLP]CPLQTY


        SV_ACTION = ACTION


        # Exécution des contrôles et des actions pour la ligne d'amortissement
        indice = nolign - 1
        Default Mask [PPL1]
        Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2

        Call SAI_NBLIG(IMPFIC, "IMP_TAB","SUBIMPOBJ") From W0PLP1

        Setmode
        If mkstat
            GREP = ""
            Call TRACE2(2,GMESSIMP,-10) From SUBIMPOBJ
        Endif
        Raz GERREUR

        ACTION = SV_ACTION
    Endif

Return



$INIT_SOC

    If WFCY_SV = [F:PLH]FCY
        Return
    Endif
    WFCY_SV = [F:PLH]FCY

    Read [FCY]FCY0 = [F:PLH]FCY
    If fstat
        WERR_INIT_SOC = 1
        GERR = 1
        OK = 0
        GOK = 0
        GMESSAGE = mess(15, 104, 1) - "(" + [F:PLH]FCY + ")"
        mkstat = 2
        Return
    Endif
    If WCPY_SV = [F:FCY]LEGCPY
        Return
    Endif
    WCPY_SV = [F:FCY]LEGCPY

    Read [CPY]CPY0 = [F:FCY]LEGCPY
    If fstat
        WERR_INIT_SOC = 1
        GERR = 1
        OK = 0
        GOK = 0
        GMESSAGE = mess(1, 7771, 1) - "(" + [F:FCY]LEGCPY + ")"
        mkstat = 2
        Return
    Endif

    Filter [CNX] Where CPY = WCPY_SV and FLGCNXUO = G_OUI
    Read [CNX] First
    Filter [CNX]
    If fstat
        WERR_INIT_SOC = 1
        GERR = 1
        OK = 0
        GOK = 0
        GMESSAGE = mess(121, 7770, 1) - "(" + [F:FCY]LEGCPY + ")"
        mkstat = 2
        Return
    Endif
    WCNX_SV = [F:CNX]CNX


    # Exercice courant
    Read [FIS]FIY1 = [F:CNX]CPY; [F:CNX]CNX; GVML_TECOURA
    If fstat
        WERR_INIT_SOC = 1
        GERR = 1
        OK = 0
        GOK = 0
        GMESSAGE = mess(194, 7770, 1) - "(" + [F:FCY]LEGCPY + ")"
        mkstat = 2
        Return
    Endif

Return


######################################################################



$IMP_APRES_CRE

    If func CALCPLP([F:PLH]PROPLN, [F:PLH]PPLENDDAT0, [M:PPL0]PLNQTY0) = 0

    Endif

Return



##########################################################################
#------------------------#
# Fin de l'import/export #
#------------------------#
$FERME


Return

#**
#* calc of the differents amounts
#*
#* @param PPROPLN
#*!
Funprog CALCPLP(PPROPLN, PPPLENDDAT, PPLNQTY)
Value Char PPROPLN()
Value Date PPPLENDDAT
Value Decimal PPLNQTY

    Local Integer WPLNQTY_TOT_SV, WPLNQTY_EXE_SV, WRSD_SV
    Local Decimal WPPLNQTY
    Local Date WFIYENDDAT_SV

    Local File PROPLN [PLPC]
    Local File PROPLN [PLPC2]

    # 1°) calcul des sommes + maj du cumul exercice
    WPLNQTY_TOT_SV = 0
    WPLNQTY_EXE_SV = 0
    WFIYENDDAT_SV = [0/0/0]

    For [PLPC] Where PROPLN = PPROPLN

        If [F:PLPC]CPLQTY
            WPLNQTY_TOT_SV += [F:PLPC]CPLQTY
        Else
            WPLNQTY_TOT_SV += [F:PLPC]EXTQTY
        Endif

        If WFIYENDDAT_SV <> [0/0/0] and WFIYENDDAT_SV <> [F:PLPC]FIYENDDAT
            Update [PLPC2] Where PROPLN = PPROPLN and FIYENDDAT = WFIYENDDAT_SV
&                          With FIYQTY = WPLNQTY_EXE_SV
            WPLNQTY_EXE_SV = 0
        Endif
        WFIYENDDAT_SV = [F:PLPC]FIYENDDAT

        If [F:PLPC]CPLQTY
            WPLNQTY_EXE_SV += [F:PLPC]CPLQTY
        Else
            WPLNQTY_EXE_SV += [F:PLPC]EXTQTY
        Endif
    Next

    # le reste de prévu est affecté à la dernière période
    WPPLNQTY = PPLNQTY - WPLNQTY_TOT_SV
    If WPPLNQTY < 0
            WPPLNQTY = 0
    Endif
    WPLNQTY_EXE_SV += WPPLNQTY
    WPLNQTY_TOT_SV = PPLNQTY

    # Maj du dernier exercice
    If WFIYENDDAT_SV <> [0/0/0]
        Update [PLPC2] Where PROPLN = PPROPLN and FIYENDDAT = WFIYENDDAT_SV
&                      With FIYQTY = WPLNQTY_EXE_SV

    # Maj de la dernière période du dernier exercice

        Update [PLPC2] Where PROPLN = PPROPLN and
&                            FIYENDDAT = WFIYENDDAT_SV and
&                            PERENDDAT = PPPLENDDAT
&                      With EXTQTY = WPPLNQTY

    Endif


    # 2°) maj du cumul total et du résiduel
    WRSD_SV = 0
    For [PLPC] Where PROPLN = PPROPLN

        [F:PLPC]PLNQTY = WPLNQTY_TOT_SV
        [F:PLPC]RSDQTY = [F:PLPC]PLNQTY - WRSD_SV


        If [F:PLPC]CPLQTY
            WRSD_SV += [F:PLPC]CPLQTY
        Else
            WRSD_SV += [F:PLPC]EXTQTY
        Endif

        Rewrite [PLPC]
    Next


    Close File [PLPC], [PLPC2]
End 1
