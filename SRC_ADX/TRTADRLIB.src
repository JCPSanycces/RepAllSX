        Chgfmt [M:SDH2]ZSSTENTCOD With "-KP:" + num$(type([M:SDH2]ZSSTENTCOD)-10) + "X"  # Hide
      Endif
    Endif
    Affzo [M:SDH2]SSTENTCOD
    If dim([M:SDH2]ZSSTENTCOD) > 0
