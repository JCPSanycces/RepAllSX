$DEFAULT_SSTENTCOD

If !clalev([F:BPD]) : Local File BPDLVCUST [BPD] : Endif
Read [F:BPD]BPD0=[F:BPA]BPANUM;[F:BPA]BPAADD
If fstat = 0
  [M:BIC1]SSTENTCOD = [F:BPD]SSTENTCOD
  Affzo [M:BIC1]SSTENTCOD
Endif

Return

