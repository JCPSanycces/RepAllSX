#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Process Name: TRTADRLIB
# Description : X3 Address Verification Library
####################################################################################
#
# Called from the Click Icon within Customers, Sites, Leads, and Prospects
#
####################################################################################
Subprog VALADR_CLICK(IBPATYP, IBPANUM, IBPACOD)
Value  Integer IBPATYP
Value  Char    IBPANUM
Value  Char     IBPACOD

Local Char    OTYPE(1), OERRMSG(250), INAME(GLONNAM)
Local Integer OERR

Local File BPADDRESS  [BPA]  # BP Address
Local File LEAD       [LDS]  # Leads
Local File BPCUSTOMER [BPC]  # BP Customers and Prospects
Local File FACILITY   [FCY]  # Sites

If IBPATYP = 6                  # Leads
  If [F:LDS]PSTNUM <> IBPANUM
    Read [F:LDS]LDS0=IBPANUM
    If fstat = 0
      INAME = [F:LDS]CPYNAM
    Endif
  Else
    INAME = [F:LDS]CPYNAM
  Endif
Elsif IBPATYP = 3               # Sites
  If [F:FCY]FCY <> IBPANUM
    Read [F:FCY]FCY0=IBPANUM
    If fstat = 0
      INAME = [F:FCY]FCYNAM
    Endif
  Else
    INAME = [F:FCY]FCYNAM
  Endif
Else                            # Customers
  If [F:BPC]BPCNUM <> IBPANUM
    Read [F:BPC]BPC0=IBPANUM
    If fstat = 0
      INAME = [F:BPC]BPCNAM
    Endif
  Else
    INAME = [F:BPC]BPCNAM
  Endif
Endif

Read [F:BPA]BPA0=IBPATYP;IBPANUM;IBPACOD
If fstat = 0
  Local Integer NOL
  If dim([M]XNUMLIG) > 0
    NOL = [M]XNUMLIG
  Else
    NOL = 0
  Endif

  OERR = 0
  Call ADR_VALID("",IBPATYP,IBPANUM,IBPACOD,INAME,[F:BPA]BPAADDLIG(0),[F:BPA]BPAADDLIG(1),[F:BPA]BPAADDLIG(2),[F:BPA]CTY,[F:BPA]SAT,
&   [F:BPA]POSCOD,[F:BPA]CRY,OTYPE,1,OERR,OERRMSG)

  If OERR = 0
    [F:BPA]ADRVAL = 2
    [M] = [F:BPA]
    If dim([M]BPACRY(NOL)) > 0  : [M]BPACRY(NOL)  = [F:BPA]CRY : Endif
    [M]ADDLIG1(NOL) = [F:BPA]BPAADDLIG(0)
    [M]ADDLIG2(NOL) = [F:BPA]BPAADDLIG(1)
    [M]ADDLIG3(NOL) = [F:BPA]BPAADDLIG(2)

    If dim([M]XADDLIG1) > 0 and dim([M]CTY) > 0 and dim([M]POSCOD) > 0
      Gosub REMP_ADR From TRTBPA
    Endif

  Else
    [F:BPA]ADRVAL = 1
    [M]ADRVAL(NOL) = 1
    If dim([M]XADRVAL) > 0  : [M]XADRVAL = 1  : Endif
  Endif

  Rewrite [F:BPA]
  Affzo [M]

Endif

End
####################################################################################
#
# Called from the Click Icon within Address Free form entry within a sales document
#
####################################################################################
Subprog VALADRFF_CLICK()

Local Char    OTYPE(1), OERRMSG(250)
Local Integer OERR

OERR = 0
Call ADR_VALID("",1,"","","",[M]BPAADDLIG(0),[M]BPAADDLIG(1),[M]BPAADDLIG(2),[M]CTY,[M]SAT,
&   [M]POSCOD,[M]CRY,OTYPE,2,OERR,OERRMSG)

If OERR = 0
  [M]ADRVAL = 2
Else
  [M]ADRVAL = 1
Endif

Affzo [M]

End

####################################################################################
#
# Called from within Sales document to attempt to validate a header delivery address
#
####################################################################################
Subprog CHECK_DOC_TOADR(IDOCTYP, OERR)
Value    Integer IDOCTYP
Variable Integer OERR

Local Char    OTYPE(1), OERRMSG(250), INAME(GLONNAM)

Case IDOCTYP

  When 1 :  #Quotes
      If func TRTADRLIB.CHKADR_CRY([F:SQH]BPDCRY)
        Call ADR_VALID("",1,[F:SQH]BPCORD,[F:SQH]BPAADD,INAME,[F:SQH]BPDADDLIG(0),[F:SQH]BPDADDLIG(1),[F:SQH]BPDADDLIG(2),
&         [F:SQH]BPDCTY,[F:SQH]BPDSAT,[F:SQH]BPDPOSCOD,[F:SQH]BPDCRY,OTYPE,2,OERR,OERRMSG)
      Endif

  When 2 : #Orders
      If func TRTADRLIB.CHKADR_CRY([F:SOH]BPDCRY)
        Call ADR_VALID("",1,[F:SOH]BPCORD,[F:SOH]BPAADD,INAME,[F:SOH]BPDADDLIG(0),[F:SOH]BPDADDLIG(1),[F:SOH]BPDADDLIG(2),
&         [F:SOH]BPDCTY,[F:SOH]BPDSAT,[F:SOH]BPDPOSCOD,[F:SOH]BPDCRY,OTYPE,2,OERR,OERRMSG)
      Endif

  When 3 : #Deliveries
      If func TRTADRLIB.CHKADR_CRY([F:SDH]BPDCRY)
        Call ADR_VALID("",1,[F:SDH]BPCORD,[F:SDH]BPAADD,INAME,[F:SDH]BPDADDLIG(0),[F:SDH]BPDADDLIG(1),[F:SDH]BPDADDLIG(2),
&         [F:SDH]BPDCTY,[F:SDH]BPDSAT,[F:SDH]BPDPOSCOD,[F:SDH]BPDCRY,OTYPE,2,OERR,OERRMSG)
      Endif

Endcase

End
####################################################################################
#
# Called from within Sales document to see if the line address code is validated or not
# and if it isn't then try to validate it.
#
####################################################################################
Subprog CHECK_LIN_TOADR(IBPATYP,IBPANUM,IBPACOD)
Value  Integer IBPATYP
Value  Char    IBPANUM
Value  Char    IBPACOD

Local Char    OTYPE(1), OERRMSG(250), INAME(GLONNAM)
Local Integer OERR

Local File BPADDRESS  [BPA]  # BP Address

Read [F:BPA]BPA0=IBPATYP;IBPANUM;IBPACOD
If fstat = 0 and [F:BPA]ADRVAL <> 2 and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)
    Call ADR_VALID("",IBPATYP,IBPANUM,IBPACOD,INAME,[F:BPA]BPAADDLIG(0),[F:BPA]BPAADDLIG(1),[F:BPA]BPAADDLIG(2),[F:BPA]CTY,[F:BPA]SAT,
&   [F:BPA]POSCOD,[F:BPA]CRY,OTYPE,2,OERR,OERRMSG)
Endif

End

####################################################################################
#
# Called from within Sales document to see if the site address code is validated or not
# The argument ITRY indicates whether or not we should try to validate the address or just warn the user
# that the address has not been validated.
# If Validated addresses are mandatory and the address is not validated, then OOK is set to 0
# the calling program can use this if they wish.
####################################################################################
Subprog CHECK_FRADR(ISTOFCY,ITRY, OOK)
Value    Char    ISTOFCY
Value    Integer ITRY
Variable Integer OOK

Local Char    OTYPE(1), OERRMSG(250), INAME(GLONNAM)
Local Integer OERR
Local File    BPADDRESS  [BPA]  # BP Address

Filter [F:BPA] Where BPATYP=3 and BPANUM=ISTOFCY and BPAADDFLG=2
Read [F:BPA] First
If fstat = 0 and [F:BPA]ADRVAL <> 2 and  func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)
  If ITRY
    Call ADR_VALID("",[F:BPA]BPATYP,[F:BPA]BPANUM,[F:BPA]BPAADD,INAME,[F:BPA]BPAADDLIG(0),[F:BPA]BPAADDLIG(1),[F:BPA]BPAADDLIG(2),[F:BPA]CTY,[F:BPA]SAT,
&   [F:BPA]POSCOD,[F:BPA]CRY,OTYPE,2,OERR,OERRMSG)
  Else
    If  func TRTADRLIB.CHKADR_MANDATORY()
      OOK = 0
      Call ERREUR(mess(366,192,1)) From GESECRAN  # Address has not been validated
    Else
      Call MESSAGE(mess(366,192,1)) From GESECRAN  # Address has not been validated
    Endif
  Endif
Endif
Filter [F:BPA]
End
####################################################################################
#
# Called when saving/creating addresses by TRTBPA and also SUBBPD
# We are only concerned about Customers, Sites, Leads, Prospects, Ship-To Customers
#
####################################################################################
$ECRIT_BPA
#
# If Address Validation fields exist and the country should be validated
If dim([F:BPA]ADRVAL) > 0 and dim([M]ADRVAL) > 0 and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)

  Local Integer OERR, TNOL
  Local Char    OTYPE(1), OERRMSG(250)
  Call ADR_VALID("",[F:BPA]BPATYP,[F:BPA]BPANUM,[F:BPA]BPAADD,"",[F:BPA]BPAADDLIG(0),[F:BPA]BPAADDLIG(1),[F:BPA]BPAADDLIG(2),[F:BPA]CTY,[F:BPA]SAT,
&   [F:BPA]POSCOD,[F:BPA]CRY,OTYPE,2,OERR,OERRMSG)


  # The Customers, Sites, Leads, and Prospects functions (TRTBPA) need to know which line we are dealing with
  # Ship-To Customers  (SUBBPD) will always be 0
  TNOL = nolign - 1
  If TNOL < 0
    TNOL = 0
  Endif

  If OERR
    [F:BPA]ADRVAL = 1
    [M]ADRVAL(TNOL)  = [F:BPA]ADRVAL
    If dim([M]XADRVAL) > 0
      [M]XADRVAL = [M]ADRVAL(TNOL)
    Endif
  Else
    [F:BPA]ADRVAL = 2
    [M]ADDLIG1(TNOL) = [F:BPA]BPAADDLIG(0)
    [M]ADDLIG2(TNOL) = [F:BPA]BPAADDLIG(1)
    [M]ADDLIG3(TNOL) = [F:BPA]BPAADDLIG(2)

    If dim([M]XSAT)>0
      [M]SAT(TNOL)   = [F:BPA]SAT
    Endif

    [M]POSCOD(TNOL)  = [F:BPA]POSCOD
    [M]CTY(TNOL)     = [F:BPA]CTY
    [M]ADRVAL(TNOL)  = [F:BPA]ADRVAL

    # Move to the X fields if appropriate
    If dim([M]XADDLIG1) > 0 and dim([M]XCTY) > 0 and dim([M]XPOSCOD) > 0
      [M]XADDLIG1 = [M]ADDLIG1(TNOL)
      [M]XADDLIG2 = [M]ADDLIG2(TNOL)
      [M]XADDLIG3 = [M]ADDLIG3(TNOL)
      [M]XCTY     = [M]CTY(TNOL)
      [M]XPOSCOD  = [M]POSCOD(TNOL)
      If dim([M]XSAT) > 0
        [M]XSAT = [M]SAT(TNOL)
      Endif
      If dim([M]XADRVAL) > 0
        [M]XADRVAL = [M]ADRVAL(TNOL)
      Endif
    Endif
  Endif
  Affzo [M]
Endif

Return

####################################################################################
# Subroutine : ADR_VALID
#
# Description : Retrieves a validated address
#
####################################################################################
Subprog ADR_VALID(ICPY, IBPTYP,IBPNUM,ICODADR,INAM,IOLINE1,IOLINE2,IOLINE3,IOCTY,IOREGION,IOPOSCOD,IOCRY,OTYPE,IDISPLAY,OERR,OMSG)
Value    Char    ICPY
Value    Integer IBPTYP
Value    Char    IBPNUM
Value    Char    ICODADR
Value    Char    INAM
Variable Char    IOLINE1
Variable Char    IOLINE2
Variable Char    IOLINE3
Variable Char    IOCTY
Variable Char    IOREGION
Variable Char    IOPOSCOD
Variable Char    IOCRY
Variable Char    OTYPE
Value    Integer IDISPLAY # 0 - no display, 1 - display errors and success, 2 - display errors only
Variable Integer OERR
Variable Char    OMSG

If !clalev([F:LTP]) Local File LTAPAR [LTP] Endif

Local Integer OK

Raz OK, OERR, OMSG

Call SST_VRF_ADR(ICPY,IOLINE1,IOLINE2,IOLINE3,IOCTY,IOREGION,IOPOSCOD,IOCRY,OTYPE,OERR,OMSG) From SSTADRLIB

# ADR_TYPE= "P" then it is a post office address
# ADR_TYPE= "S" then it is a street or residential address

# Somewhere in the refresh process of BP Address update, a trace file is opened and therefore all future messages are lost
# Need to track this down so I can go back to using ECR_TRACE below

If OERR
    # Address validation has Failed
    If IBPNUM <> "" or ICODADR <> "" or INAM <> ""
        OMSG = IBPNUM - "/" - ICODADR - INAM - mess(364,192,1) - mess(290,196,1) - OMSG
    Else
        OMSG = mess(364,192,1) - mess(290,196,1) - OMSG
    Endif

    If IDISPLAY > 0
        Call MESSAGE(OMSG) From GESECRAN # X3-60931 BODEL.sn
        #Call ERREUR(OMSG) From GESECRAN # X3-60931 BODEL.en
 #       Call ECR_TRACE(OMSG,1) From GESECRAN  #A trace file was somehow getting opened and ECR_TRACE stopped reporting
    Endif

Else
    # Address validation Successful
    If IBPNUM <> "" or ICODADR <> "" or INAM <> ""
        OMSG = IBPNUM - "/" - ICODADR - INAM - mess(364,192,1) - mess(2,585,1)
    Else
        OMSG = OMSG - mess(364,192,1) - mess(2,585,1)
    Endif

    If IDISPLAY = 1
        Call MESSAGE(OMSG) From GESECRAN
    #    Call ECR_TRACE(OMSG,0) From GESECRAN  #A trace file was somehow getting opened and ECR_TRACE stopped reporting
    Endif
Endif

End
############################################################################
Funprog CHKADRVAL_MANAGED()

Local Integer ADRMANAGED

ADRMANAGED = 0

If func AFNC.ACTIV("LTA") and PARAM(1) = "ADB2" and dim([M:ADC]VALADR) > 0
  ADRMANAGED = 1
Endif

End ADRMANAGED
############################################################################
Funprog CHKADR_CRY(ICRY)
Value Char ICRY

Local Integer CRYVALID, J
CRYVALID = 0

If func AFNC.ACTIV("LTA")
  If !clalev([F:LTP]) Local File LTAPAR [LTP] Endif

  If [F:LTP]DOSSIER <> nomap

      Read [F:LTP]LTP0=nomap
      If  fstat
          End CRYVALID
      Endif

  Endif

  # To test for Country being supported
  If find(ICRY,[F:LTP]CRY)
    CRYVALID = 1
  Endif
Endif

End CRYVALID
############################################################################
Funprog CHKADR_MANDATORY()

Local Integer ADR_MANDATORY
ADR_MANDATORY = 0

If func AFNC.ACTIV("LTA")
  If !clalev([F:LTP]) Local File LTAPAR [LTP] Endif

  If [F:LTP]DOSSIER <> nomap
      Read [F:LTP]LTP0=nomap
      If  fstat
          End ADR_MANDATORY
      Endif
  Endif

  If  [F:LTP]AVRREQ = 2
    ADR_MANDATORY = 1
  Endif
Endif

End ADR_MANDATORY
############################################################################
$CHKADR_QUOTE

# Check the Shipping Site on the Header
Filter [F:BPA] Where BPATYP=3 and BPANUM=[M:SQH1]STOFCY and BPAADDFLG=2
Read [F:BPA] First
If fstat = 0 and [F:BPA]ADRVAL <> 2 and  func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)
  GERR=1
  GMESSAGE =  mess(711,7773,1) - [M:SQH1]STOFCY - mess(366,192,1)
  Return
Endif
Filter [F:BPA]

# Check the Delivery Address on the Header
If !find([M:ADB2]ADBFLG,0,1)
  If func TRTADRLIB.CHKADR_CRY([M:ADB2]CRY) and [M:ADB2]ADRVAL <> 2
    GERR=1
    GMESSAGE = mess(137,148,1) - mess(366,192,1)
    Return
  Endif
Else
  Read [F:BPA]BPA0=1;[M:SQH0]BPCORD;[M:SQH1]BPAADD
  If fstat = 0 and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY) and [F:BPA]ADRVAL <> 2
    GERR=1
    GMESSAGE = [M:SQH0]BPCORD + "/" + [M:SQH1]BPAADD -  mess(366,192,1)
    Return
  Endif
Endif

# Check the line from/to addresses
Local Integer I

For I=0 To [M:SQH2]NBLIG-1
  # Check Delivery Address on the Line
  If [M:SQH2]DBPAADD(I) <> [M:SQH1]BPAADD
    Read [F:BPA]BPA0=1;[M:SQH0]BPCORD;[M:SQH2]DBPAADD(I)
    If !fstat and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY) and [F:BPA]ADRVAL <> 2
      GMESSAGE = [M:SQH0]BPCORD + "/" + [M:SQH2]DBPAADD(I) -  mess(366,192,1)
      GERR=1
      Break
    Endif
  Endif
Next

Return
############################################################################
$CHKADR_ORDER

# Check the Shipping Site on the Header
Filter [F:BPA] Where BPATYP=3 and BPANUM=[M:SOH2]STOFCY and BPAADDFLG=2
Read [F:BPA] First
If fstat = 0 and [F:BPA]ADRVAL <> 2 and  func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)
  GERR=1
  GMESSAGE = mess(711,7773,1) - [M:SOH2]STOFCY - mess(366,192,1)
  Return
Endif
Filter [F:BPA]

# Check the Delivery Address on the Header
If !find([M:ADB2]ADBFLG,0,1)
  If func TRTADRLIB.CHKADR_CRY([M:ADB2]CRY) and [M:ADB2]ADRVAL <> 2
    GERR=1
    GMESSAGE = mess(137,148,1) - mess(366,192,1)
    Return
  Endif
Else
  Read [F:BPA]BPA0=1;[M:SOH0]BPCORD;[M:SOH1]BPAADD
  If fstat = 0 and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY) and [F:BPA]ADRVAL <> 2
    GERR=1
    GMESSAGE = [M:SOH0]BPCORD + "/" + [M:SOH1]BPAADD - mess(366,192,1)
    Return
  Endif
Endif

# Check the line from/to addresses
Local Integer I

For I=0 To [M:SOH4]NBLIG-1
  # Check Delivery Address on the Line
  If [M:SOH4]DBPAADD(I) <> [M:SOH1]BPAADD
    Read [F:BPA]BPA0=1;[M:SOH0]BPCORD;[M:SOH4]DBPAADD(I)
    If !fstat and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY) and [F:BPA]ADRVAL <> 2
      GERR=1
      GMESSAGE = [M:SOH0]BPCORD - "/" - [M:SOH4]DBPAADD(I) -  mess(366,192,1)
      Break
    Endif
  Endif
  # Check Site Address on the Line
  If [M:SOH4]DSTOFCY(I) <> [M:SOH2]STOFCY
    Filter [F:BPA] Where BPATYP=3 and BPANUM=[M:SOH4]DSTOFCY(I) and BPAADDFLG=2
    Read [F:BPA] First
    If fstat = 0 and [F:BPA]ADRVAL <> 2 and  func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)
      GERR=1
      GMESSAGE = mess(711,7773,1) - [M:SOH4]DSTOFCY(I) - mess(366,192,1)
    Endif
    Filter [F:BPA]
  Endif
Next

Return
############################################################################
$CHKADR_DELIVERY

# Check the Delivery Address
If !find([M:ADB2]ADBFLG,0,1)
  If func TRTADRLIB.CHKADR_CRY([M:ADB2]CRY) and [M:ADB2]ADRVAL <> 2
    GERR=1
    GMESSAGE = mess(137,148,1) - mess(366,192,1)
    Return
  Endif
Else
  Read [F:BPA]BPA0=1;[M:SDH0]BPCORD;[M:SDH0]BPAADD
  If fstat = 0 and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY) and [F:BPA]ADRVAL <> 2
    GERR=1
    GMESSAGE = [M:SDH0]BPCORD + "/" + [M:SDH0]BPAADD - mess(366,192,1)
    Return
  Endif
Endif

#Check the Site Address
Filter [F:BPA] Where BPATYP=3 and BPANUM=[M:SDH0]STOFCY and BPAADDFLG=2
Read [F:BPA] First
If fstat = 0 and [F:BPA]ADRVAL <> 2 and  func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)
  GERR=1
  GMESSAGE = mess(711,7773,1) - [M:SDH0]STOFCY - mess(366,192,1)
Endif
Filter [F:BPA]

Return
############################################################################
$CHKADR_SLSINVOICE

# Check the Delivery Address on the Header
If !find([M:ADB2]ADBFLG,0,1)
  If func TRTADRLIB.CHKADR_CRY([M:ADB2]CRY) and [M:ADB2]ADRVAL <> 2
    GERR=1
    GMESSAGE = mess(137,148,1) - mess(366,192,1)
    Return
  Endif
Else
  Read [F:BPA]BPA0=1;[M:SIH1]BPCORD;[M:SIH1]BPAADD
  If fstat = 0 and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY) and [F:BPA]ADRVAL <> 2
    GERR=1
    GMESSAGE = [M:SIH1]BPCORD + "/" + [M:SIH1]BPAADD - mess(366,192,1)
    Return
  Endif
Endif

# Check the line addresses
Local Integer I

For I=0 To [M:SIH4]NBLIG-1

  # Check Site Address on the Line if we haven't already
  If (I = 0) or (I > 0 and !find([M:SIH4]DSTOFCY(I), [M:SIH4]DSTOFCY(0..I)))

    Filter [F:BPA] Where BPATYP=3 and BPANUM=[M:SIH4]DSTOFCY(I) and BPAADDFLG=2
    Read [F:BPA] First
    If fstat = 0 and [F:BPA]ADRVAL <> 2 and  func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)
      GERR=1
      GMESSAGE = mess(711,7773,1) - [M:SIH4]DSTOFCY(I) - mess(366,192,1)
      Break
    Endif
  Endif
Next
Filter [F:BPA]
Return
############################################################################
$FMT_ADRVAL

If dim([M]XADRVAL) > 0
  If func TRTADRLIB.CHKADR_CRY(TCRY)
    Chgfmt [M]XADRVAL With "LA:1"
    Chgfmt [M]VALADR  With "K:10X"
  Else
    Chgfmt [M]XADRVAL With "-LA:1"
    Chgfmt [M]VALADR  With "-K:10X"
  Endif
Endif

Return

####################################################################################
# Read the Sage Sales Tax LTAPAR record.
####################################################################################
Subprog READ_LTA()

If !clalev([F:LTP]) : Local File LTAPAR   [LTP]  : Endif

Look [LTP]LTP0=nomap
If fstat
    Raz [LTP]
Endif

End
###################################################
$SHOW_HIDE_ENTCOD

If !func AFNC.ACTIV("LTA")  : Return  :Endif

#Sales Quotes
If dim([M:SQH1]SSTENTCOD)>0
 # When ENTCOD field exists, hide it and ShortDescript if the company is not setup for SST
 # If !(func TRTADRLIB.CHKADR_CRY([M:ADB2]CRY)) or GLOCUSATAX = 0
# If GLOCUSATAX = 0   # 106867.o
  If !func TRTTAXSST.CHK_SSTTAXACT(GSOCIETE)   # 106867.n
    Raz [M:SQH1]SSTENTCOD
    Chgfmt [M:SQH1]SSTENTCOD  With "-K:"  + num$(type([M:SQH1]SSTENTCOD)-10)  + "B"     # Hide
    If dim([M:SQH1]ZSSTENTCOD ) > 0
      Chgfmt [M:SQH1]ZSSTENTCOD With "-KP:" + num$(type([M:SQH1]ZSSTENTCOD)-10) + "X"   # Hide
    Endif
  Else
    If GSSTENTCOD <= 1
      Chgfmt [M:SQH1]SSTENTCOD  With "K:"   + num$(type([M:SQH1]SSTENTCOD)-10)  + "B"    # Show enterable
      If dim([M:SQH1]ZSSTENTCOD ) > 0
        Chgfmt [M:SQH1]ZSSTENTCOD With "KP:"  + num$(type([M:SQH1]ZSSTENTCOD)-10) + "X"  # Display
      Endif
    Elsif GSSTENTCOD = 2
      Chgfmt [M:SQH1]SSTENTCOD  With "KP:"  + num$(type([M:SQH1]SSTENTCOD)-10)  + "B"    # Show display only
      If dim([M:SQH1]ZSSTENTCOD ) > 0
        Chgfmt [M:SQH1]ZSSTENTCOD With "KP:"  + num$(type([M:SQH1]ZSSTENTCOD)-10) + "X"  # Display
      Endif
    Elsif GSSTENTCOD = 3
      Chgfmt [M:SQH1]SSTENTCOD  With "-K:"  + num$(type([M:SQH1]SSTENTCOD)-10)  + "B"    # Hide
      If dim([M:SQH1]ZSSTENTCOD ) > 0
        Chgfmt [M:SQH1]ZSSTENTCOD With "-KP:" + num$(type([M:SQH1]ZSSTENTCOD)-10) + "X"  # Hide
      Endif
    Endif
    Affzo [M:SQH1]SSTENTCOD
    If dim([M:SQH1]ZSSTENTCOD ) > 0
      Affzo [M:SQH1]ZSSTENTCOD
    Endif
  Endif
