#Sales Invoices
If dim([M:SIH1]SSTENTCOD)>0
  # When ENTCOD field exists, hide it and ShortDescript if the company is not setup for SST
# If GLOCUSATAX = 0   # 106867.o
  If !func TRTTAXSST.CHK_SSTTAXACT(GSOCIETE)   # 106867.n
