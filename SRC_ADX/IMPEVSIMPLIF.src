#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
#* Modifications :
# FQ79574 - SEGAY 25/01/12
# Le nombre de jour est mis à jour si l'événement n'est pas de type heure,
# par contre on garde le fait de le mettre à jour par le calcul  du nombre d'heure, si l'événement est de type heure et si la date de début et de fin sont égale (voir BUG 77018)
# FQ79603+FQ83867 - SEGAY 25/01/12 01/08/12
# Si un évènement non géré en heures, et que la période  était sur une seule journée, si on avait déjà saisie un évènement pour la même période
# on n'avait pas de message d'erreur de doublon.
# FQ74044 - SEGAY - 13/02/12 -
#      Ajout vérification du nouveau champ FILTRE sur la nature d'évènement
# FQ83299 - SEGAY - 04/07/12 -
#      Test si on est en nature d'évènement heure pour le calcul du nombre de jour
# FQ85489 - SEGAY - 02/11/12 -
#      Le write de TIMEMP n'at pas à faire dans TR_AB_IMPORT car il est fait en auto dans SUBIMPOBJ0
# FQ85498 - SEGAY - 02/11/12 -
#      Saisie des heures par le nombre de l'import quand les heures dans l'import sont ="00:00""
#      +  Test de doublon si l'évènement n'est pas en plage horaire et que du temps a déjà été saisi pour la même journée ou 1/2 journée.
# FQ86336 - SEGAY - 05/12/12 -
#      Pour le cas où l'on veut saisir un temps en jour partiel avec Nbre (heures) renseignés
#      + Erreur quand on dépasse le nombre jour calendaire
# FQ89121 -  MABOS-03/04/13 -
#      Correction valorisation d'une seule journée en heures
# FQ89718 -  MABOS - 30/04/13
#      test "Pas plus de 1 jour par journée calendaire" -Uniquement pour la même journée
# FQ89268 -  MABOS - 22/05/13 - US1612 -
#      Modif pour multi-contrats
# FQ89268 -  MABOS - 10/07/13 - US1728
#      Ajout parametres, appel SEARCH_CTR
# FQ92969 - SBA - 29/10/2013
#      US2029_92969 : Ajout matricule nom prénom dans la trace
# FQ81491 - 15/11/13 - prise en compte date d'effet + fiches de rétroactivité
######################################################################################

######################################################################################

Call IMPORTATION("EVSIMPLIF") From GIMPOBJ
End

###################################################################################
$ACTION
Case [L]ACTION
 When "IMP_OUVRE" : Gosub IMP_OUVRE
 When "AP_IMPORT" : Gosub AP_IMPORT
Endcase
Return

####################################
$IMP_OUVRE
#LIPET - X3-11621 - 18-01-2017 - START
#If !clalev([F:PEO])  : Local File PERIOD   [PEO]  : Endif
#If !clalev([F:CTR])  : Local File EMPLOCTR [CTR]  : Endif
#If !clalev([F:CTR2]) : Local File EMPLOCTR [CTR2] : Endif
If !clalev([F:HRPEOD])  : Local File HRPEODET   [HRPEOD]  : Endif
If !clalev([F:HRCTR])  : Local File EMPLOCTR [HRCTR]  : Endif
If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
#LIPET - X3-11621 - 18-01-2017 - END
If !clalev([F:TIM])  : Local File TIMCOD   [TIM]  : Endif
If !clalev([F:ID])   : Local File EMPLOID  [ID]   : Endif
If !clalev([F:TIP2]) : Local File TIMEMP   [TIP2] : Endif
If !clalev([F:TIA])  : Local File TIMANA   [TIA]  : Endif
If !clalev([F:FCY])  : Local File FACILITY [FCY]  : Endif
Local Decimal HEURE(1..60), JOUR(1..60)
###75722
Local Decimal VALHMDEB, VALHMFIN, RESULT
Local Decimal JOUR3,HEURE3 # FQ86336 - SEGAY - 05/12/12 -

Return

#-------------------------------------------------------------------------------

#-------------------------------------------------------------------------------

$AP_IMPORT

Call LECTURE("EML",[F:TIP]REFNUM,"") From CONTOBJ

If fstat & 0
 #LIPET - X3-11621 - 18-01-2017 -START
 #Call TRACE(2,mess(83,702,1)-":"-[F:TIP]REFNUM) From SUBIMPOBJ
 Call TRACE(2,mess(83,10702,1)-":"-[F:TIP]REFNUM) From SUBIMPOBJ
 #            Matricule inexistant
 #LIPET - X3-11621 - 18-01-2017 - END
 [V]GOK=0
 Return
Endif
#LIPET - X3-11621 - 18-01-2017 - START
Filter  [HRCTR] Where REFNUM=[F:TIP]REFNUM
Read [HRCTR] First
Filter [HRCTR]
Read [FCY]FCY0 = [F:HRCTR]ETRFCY
 If !fstat
    GCURLEG = [F:FCY]LEG
Endif
#LIPET - X3-11621 - 18-01-2017 - END
#SBA US2029_92969 : on récupère le texte pour l'afficher dans la trace
Local Char WTTRACE(250)
[L]WTTRACE=[F:TIP]REFNUM-"-"-[F:ID]NAM-[F:ID]SRN-"/"
#LIPET - X3-11621 - 18-01-2017 - START
#Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#LIPET - X3-11621 - 18-01-2017 - END
If fstat
  #LIPET - X3-11621 - 18-01-2017 - START
  #Call TRACE(2,mess(143,709,1)-":"-[F:TIP]TIM) From SUBIMPOBJ
  #SBA US2029_92969
  #Call TRACE(2,[L]WTTRACE-mess(143,709,1)-":"-[F:TIP]TIM) From SUBIMPOBJ
  Call TRACE(2,[L]WTTRACE-mess(143,10709,1)-":"-[F:TIP]TIM) From SUBIMPOBJ
 #            Nature d'évènement inexistante
  #LIPET - X3-11621 - 18-01-2017 - END
 [V]GOK=0
 Return
Else
# FQ74044 - SEGAY 13/02/12 - Ajout vérification du nouveau champ FILTRE
  If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
    Local Integer RET
    Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[F:TIP]REFNUM,[F:TIP]CTRNUM,RET) From DIVPAYE
    If RET>0 Then
      #SBA US2029_92969
      #Call TRACE(2,[F:TIP]REFNUM-"-"-[F:ID]NAM-"/"-mess(320,199,1)-":"-[F:TIP]TIM) From SUBIMPOBJ : # Nature d'événement incompatible avec ce salarié
      Call TRACE(2,[L]WTTRACE-mess(320,199,1)-":"-[F:TIP]TIM) From SUBIMPOBJ : # Nature d'événement incompatible avec ce salarié
      [V]GOK=0
      Return
    Endif
  Endif
# END FQ74044 - SEGAY
Endif

Call SETDATE([F:TIP]STRDAT,[V]GIMP(2),[L]A_ER)
If [L]A_ER
 #SBA US2029_92969
 #Call TRACE2(2,mess(1,104,1)-"STRDAT"-[V]GIMP(2),-1) From SUBIMPOBJ : # Date incorrecte
 Call TRACE2(2,[L]WTTRACE-mess(1,104,1)-"STRDAT"-[V]GIMP(2),-1) From SUBIMPOBJ : # Date incorrecte
 [V]GOK=0
 Return
Endif

Call SETDATE([F:TIP]ENDDAT,[V]GIMP(3),[L]A_ER)
If [L]A_ER
 #SBA US2029_92969
 #Call TRACE2(2,mess(1,104,1)-"ENDDAT"-[V]GIMP(3),-1) From SUBIMPOBJ : # Date incorrecte
 Call TRACE2(2,[L]WTTRACE-mess(1,104,1)-"ENDDAT"-[V]GIMP(3),-1) From SUBIMPOBJ : # Date incorrecte
 [V]GOK=0
 Return
Endif

# FQ92876 - 27/06/14 - Récupération des axes depuis le planning personnel Ou initialisation si pas de planning
Local Integer INI
Local Decimal JOUR(1..2), HEURE(1..2)
Local Integer LTYPDAY, LDAYNGT
Local Char    PLESTRTIM(6), PLEENDTIM(6), PLENATCOD(GLONNAT)
Local Decimal PLEBRKTIM
Local Char CCE    (GLONCCE) (1..max(1,GOPTCANA))
Local Char DIE    (GLONDIE) (1..max(1,GOPTCANA))

Call JOUR_AXE( [F:TIP]REFNUM,[F:TIP]STRDAT,LTYPDAY,JOUR,HEURE
&       , LDAYNGT,[F:TIP]FCY,[F:TIP]CTRNUM,0,PLESTRTIM,PLEENDTIM,PLEBRKTIM
&       , [F:TIP]NATCOD,CCE,INI,DIE
&       ) From SUBPLN

[F:TIP]DAYNGT=LDAYNGT
Gosub CALC_CCEDIE From IMPBADGEUSE
# Fin FQ92876

###75722
#Call SETNUM([V]GIMP(4),[F:AOE]SEPDEC) From SUBIMPOBJ
#[F:TIP]NBRHOU=val([V]GIMP(4))
#SEGAY 83299 04/07/12
#If val([V]GIMP(4))=0
#SEGAY 85498 02/11/12
#If [F:TIP]STRTIM <>"" &  [F:TIP]ENDTIM<>""
Call CONVERTHM([F:TIP]STRTIM,VALHMDEB)
Call CONVERTHM([F:TIP]ENDTIM,VALHMFIN)
If VALHMDEB <> 0 & VALHMFIN <> 0
#END SEGAY 85498 02/11/12
 Raz RESULT
 Call CONVERTHM([F:TIP]STRTIM,VALHMDEB)
 Call CONVERTHM([F:TIP]ENDTIM,VALHMFIN)
 If VALHMDEB<=VALHMFIN
  RESULT = VALHMFIN-VALHMDEB-[F:TIP]BRKTIM
 Else
  RESULT = 24-VALHMDEB+VALHMFIN-[F:TIP]BRKTIM
 Endif
 [F:TIP]NBRHOU=ar2(RESULT)
#SEGAY 83299 04/07/12
Else
#SEGAY 83299 05/07/12 (si on test val([V]GIMP(4)) <> 0 si la décimal ="," pour un nombre < 1 on a toujours 0 ?
 If [V]GIMP(4)<>""
  #LIPET - X3-11621 - 18-01-2017 - START
  #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
  Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
  #LIPET - X3-11621 - 18-01-2017 - END
#SEGAY 83299 04/07/12
# FQ86336 - SEGAY - 05/12/12 On met à jour NBRDAY dans le cas pour un Evenement en jour avec une fraction de jour
  If [F:TIM]DAYDAC = 1
     Call SETNUM([V]GIMP(4),[F:AOE]SEPDEC) From SUBIMPOBJ
     [F:TIP]NBRHOU=val([V]GIMP(4))
  Else
     If [F:TIP]ENDDAT=[F:TIP]STRDAT & ![F:TIP]NBRDAY
       Call SETNUM([V]GIMP(4),[F:AOE]SEPDEC) From SUBIMPOBJ
       [F:TIP]NBRDAY=val([V]GIMP(4))
     Endif
  Endif
 Endif
#END 83299 04/07/12
Endif
###

Call SETDATE([F:TIP]CREDAT,[V]GIMP(5),[L]A_ER)
If [L]A_ER
 #SBA US2029_92969
 #Call TRACE2(2,mess(1,104,1)-"CREDAT"-[V]GIMP(5),-1) From SUBIMPOBJ : # Date incorrecte
 Call TRACE2(2,[L]WTTRACE-mess(1,104,1)-"CREDAT"-[V]GIMP(5),-1) From SUBIMPOBJ : # Date incorrecte
 [V]GOK=0
 Return
Endif

#62004 : Ajout de la transaction
Call DEBTRANS From GLOCK
Gosub TR_AP_IMPORT
Return

$TR_AP_IMPORT
GOK=1
Local Integer AM # FICHE 68631 - SYMEU : 27/10/2010
Local Integer WPLGHOR2 # FQ79603 - SEGAY 25/01/12 sauvegarde type plage horaire de [F:TIP2]TIM

Trbegin [TIP]
# fin 62004

#SBA US2029_92969 : on récupère le texte pour l'afficher dans la trace
Local Char WTTRACE(250)
[L]WTTRACE=[F:TIP]REFNUM-"-"-[F:ID]NAM-[F:ID]SRN-"/"


# FICHE 68631 - SYMEU : 27/10/2010
# Si "Saisie plage horaire" = Non ou si on a saisi une fourchette de dates, les champs
# heure de début et de fin ne doivent pas être renseignés
#LIPET - X3-11621 - 18-01-2017 - START
#Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#LIPET - X3-11621 - 18-01-2017 - END
If [F:TIM]PLGHOR<>2 | [F:TIP]STRDAT<>[F:TIP]ENDDAT Then
  [F:TIP]STRTIM=""
  [F:TIP]ENDTIM=""
Endif
WPLGHOR2=[F:TIM]PLGHOR # FQ79603 - SEGAY 25/01/12
# Aucun évènement ne doit déjà exister aux mêmes dates pour le salarié
[F:TIP2]=[F:TIP]
#MIPEA - X3-11621 - 09-02-2017 - START
Link [TIP] With [TIM]TIM0=GCURLEG;TIM As [LNK]
#Link [TIP] With [TIM]TIM0=TIM As [LNK]
#MIPEA - X3-11621 - 09-02-2017 - END
Local Integer IS_DOUBLON
For [LNK]TIP1 Where REFNUM=[F:TIP2]REFNUM & STRDAT<=[F:TIP2]ENDDAT
&                 & ENDDAT>=[F:TIP2]STRDAT
# FICHE 68931 - SYMEU : 08/11/2010
# If func NMIN([F:TIP2]STRDAT,[F:TIP2]STRTIM)<func NMIN([F:TIP]ENDDAT,[F:TIP]ENDTIM)
#& & func NMIN([F:TIP2]ENDDAT,[F:TIP2]ENDTIM)>func NMIN([F:TIP]STRDAT,[F:TIP]STRTIM)
 # FQ76632 - MABON 06/10/11 - Prendre en compte les heures consécutives qui ne se chevauchent pas pour autant
# If func NMIN([F:TIP2]STRDAT,[F:TIP2]STRTIM)<=func NMIN([F:TIP]ENDDAT,[F:TIP]ENDTIM)
#& & func NMIN([F:TIP2]ENDDAT,[F:TIP2]ENDTIM)>=func NMIN([F:TIP]STRDAT,[F:TIP]STRTIM)

 IS_DOUBLON=1
# FQ79603 - SEGAY 25/01/12
# Si un évènement non géré en heures, et que la période  était sur une seule journée, si on avait déjà saisie un évènement pour la même période
# on n'avait pas de message d'erreur de doublon.
 If [F:TIP2]STRDAT<>[F:TIP2]ENDDAT Then
  If func NMIN([F:TIP2]STRDAT,[F:TIP2]STRTIM)<=func NMIN([F:TIP]ENDDAT,[F:TIP]ENDTIM)
& & func NMIN([F:TIP2]ENDDAT,[F:TIP2]ENDTIM)>=func NMIN([F:TIP]STRDAT,[F:TIP]STRTIM)
    IS_DOUBLON=2
  Endif
 Else
# FQ79603 - SEGAY 25/01/12
# FQ83867 - SEGAY 02/08/12
  If ([F:TIM]PLGHOR<>2 or WPLGHOR2<>2) Then
   If [F:TIM]PLGHOR=WPLGHOR2
    If [F:TIP2]STRDAT=[F:TIP]ENDDAT & [F:TIP2]ENDDAT=[F:TIP]STRDAT &
&   [F:TIP2]STRDAY <> [F:TIP2]ENDDAY & [F:TIP]STRDAY <> [F:TIP]ENDDAY &
&   ([F:TIP]STRDAY = [F:TIP2]STRDAY | [F:TIP]ENDDAY = [F:TIP2]ENDDAY)
#SEGAY 85498 02/11/12  FQ86336 - SEGAY - 05/12/12 on test pas le doublon dans ce cas
#     On testera plus bas le nbre de jour si > à la journée
#     Maximum 1 par jour
#    If [F:TIP2]STRDAT=[F:TIP]ENDDAT & [F:TIP2]ENDDAT=[F:TIP]STRDAT &
#&  ( [F:TIP2]STRDAY <> [F:TIP2]ENDDAY & [F:TIP]STRDAY <> [F:TIP]ENDDAY &
#&   ([F:TIP]STRDAY = [F:TIP2]STRDAY | [F:TIP]ENDDAY = [F:TIP2]ENDDAY) )
#&   | ([F:TIP]STRDAY = [F:TIP2]STRDAY & [F:TIP]ENDDAY = [F:TIP2]ENDDAY) Then
      IS_DOUBLON=2
    Endif
   Else
    If func NMIN([F:TIP2]STRDAT,"")<=func NMIN([F:TIP]ENDDAT,"")
& & func NMIN([F:TIP2]ENDDAT,"")>=func NMIN([F:TIP]STRDAT,"")
    IS_DOUBLON=2
    Endif
   Endif
  Else
# END FQ79603
# END FQ83867 - SEGAY 02/08/12
   If (val([F:TIP]STRTIM)<val([F:TIP]ENDTIM) & val([F:TIP2]STRTIM)>val([F:TIP]STRTIM) & val([F:TIP2]STRTIM)<val([F:TIP]ENDTIM))
&   | (val([F:TIP]STRTIM)>val([F:TIP]ENDTIM) & (val([F:TIP2]STRTIM)>val([F:TIP]STRTIM) | val([F:TIP2]STRTIM)<val([F:TIP]ENDTIM))) Then
    IS_DOUBLON=2
   Endif
   If val([F:TIP2]ENDTIM)>val([F:TIP]STRTIM) & val([F:TIP2]ENDTIM)<val([F:TIP]ENDTIM)
&    | ( val([F:TIP2]ENDTIM)>val([F:TIP2]STRTIM) & val([F:TIP2]ENDTIM)>val([F:TIP]STRTIM) & val([F:TIP2]STRTIM)<val([F:TIP]ENDTIM))
&    | ( val([F:TIP2]ENDTIM)<val([F:TIP2]STRTIM) & val([F:TIP2]ENDTIM)>val([F:TIP]STRTIM) & val([F:TIP2]STRTIM)>val([F:TIP]ENDTIM))
    IS_DOUBLON=2
   Endif
  Endif
 Endif

 If IS_DOUBLON=2
 # Fin MABON
  If [F:TIP]CREDAT=[0/0/0] | [F:AOE]OPTUPD<2
   #SBA US2029_92969
   #Call TRACE(2,mess(162,709,1)) From SUBIMPOBJ : # Temps déjà saisi sur cette période
   #LIPET - X3-11621 - 18-01-2017 - START
   #Call TRACE(2,[L]WTTRACE-mess(162,709,1)) From SUBIMPOBJ : # Temps déjà saisi sur cette période
   Call TRACE(2,[L]WTTRACE-mess(162,10709,1)) From SUBIMPOBJ : # Temps déjà saisi sur cette période
   #LIPET - X3-11621 - 18-01-2017 - END
   [V]GOK=0
   Break
  #62004
  #Else
  Elsif dim([M:IMP2]TEST)>0 & [M:IMP2]TEST<>2

   If [F:TIP]ANAFLG=1
    Delete [TIA] Where LIG=[F:TIP]LIG
    If fstat=1
     [V]GOK  =-1
     [V]GLOCK="$TIMANA"-num$([F:TIP]LIG)
     Break
    Endif
   Endif
   If [F:TIM]CATTIM=3
    Call SUPP_CPPRIS() From TPSSTD1
    If [V]GOK<1 : Break : Endif
   Endif

   Delete [TIP] Curr
   If fstat=1
    [V]OK   =-1
    [V]GLOCK="$TIMEMP"-[F:TIP]REFNUM-[F:TIP]STRDAT-num$([F:TIP]LIG)
    Break
   Elsif fstat
    [V]GOK=0
    Call RSTA("TIP","") From GLOCK
    Break
   Endif
  Endif
 Endif
Next
# FQ103092 - 03/10/14 - Déplacement de la ligne après le Rollback, sinon création possible d'une ligne avec LIG=0
#[F:TIP]=[F:TIP2]
#62004
#If [V]GOK<1 : Return : Else : [V]GOK=1 : Endif
If [V]GOK<1 : Goto AB_TR_AP_IMPORT : Else : [V]GOK=1 : Endif
# FQ103092 - 03/10/14 - Déplacement de la ligne
[F:TIP]=[F:TIP2]

# Calcul de la date de paie
#MABOS-22/05/13-FQ89268-US1612
#Filter [CTR] Where REFNUM=[F:TIP]REFNUM & CTRDAT<=[F:TIP]STRDAT
#&                & (XITDAT=[0/0/0] | XITDAT>=[F:TIP]ENDDAT)
#&     Order By Key CLE=CTRDAT Desc
#Read [CTR] First
GMESSAGE=""
#MABOS-10/07/13-FQ89268-US1728-Ajout parametres, appel SEARCH_CTR
Call SEARCH_CTR([F:TIP]REFNUM, [F:TIP]CTRNUM,[F:TIP]CTRDAT,[F:TIP]STRDAT, [F:TIP]ENDDAT,GMESSAGE) From DIVPAYE
If [V]GOK<1
   #SBA US2029_92969
   #Call TRACE(2,GMESSAGE) From SUBIMPOBJ
   Call TRACE(2,[L]WTTRACE-GMESSAGE) From SUBIMPOBJ
   GMESSAGE=""
   Goto AB_TR_AP_IMPORT
Else [V]GOK=1
Endif
#end MABOS-22/05/13-FQ89268-US1612

If fstat
#SBA US2029_92969
 #Call TRACE(2,mess(15,718,1)) From SUBIMPOBJ : # Salarié non présent en ce jour
 #LIPET - X3-11621 - 18-01-2017 - START
 #Call TRACE(2,[L]WTTRACE-mess(15,718,1)) From SUBIMPOBJ : # Salarié non présent en ce jour
 Call TRACE(2,[L]WTTRACE-mess(15,10718,1)) From SUBIMPOBJ : # Salarié non présent en ce jour
 #LIPET - X3-11621 - 18-01-2017 - END
 [V]GOK=0
 Goto AB_TR_AP_IMPORT : # 62004 Return
Endif
[F:TIP]DATPYR=[F:TIP]STRDAT
# SEGAY bug 67983
#Call CADRE_PYRDAT([F:TIP]DATPYR,[F:CTR]ETRFCY) From TPSSUB
#LIPET - X3-11621 - 18-01-2017 - START
#Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#LIPET - X3-11621 - 18-01-2017 - END
#MIPEA - X3-11621 - 09-02-2017 - START
#LIPET - X3-11621 - 28-02-2017 - START
#Call CADRE_PYRDAT_MD([F:TIP]DATPYR,[F:HRCTR]ETRFCY,[F:TIM]MONDAC) From TPSSUB
Call CADRE_PYRDAT_MD([F:TIP]DATPYR,[F:HRCTR]PERCOD,[F:TIM]MONDAC) From TPSSUB
#LIPET - X3-11621 - 28-02-2017 - END
#Call CADRE_PYRDAT_MD([F:TIP]DATPYR,[F:CTR]ETRFCY,[F:TIM]MONDAC) From TPSSUB
#MIPEA - X3-11621 - 09-02-2017 - END
# FQ86336 - SEGAY - 05/12/12
#[F:TIP]LIG   =uniqid([TIP])
#LIPET - X3-11621 - 18-01-2017 - START
#[F:TIP]FCY   =[F:CTR]ETRFCY
#[F:TIP]SRV   =[F:CTR]ETRSRV
#[F:TIP]CTRNUM=[F:CTR]CTRNUM
#[F:TIP]AUTFLG=1 : # Génération automatique
[F:TIP]FCY   =[F:HRCTR]ETRFCY
[F:TIP]SRV   =[F:HRCTR]ETRSRV
[F:TIP]CTRNUM=[F:HRCTR]CTRNUM
[F:TIP]AUTFLG=1 : # Génération automatique
#LIPET - X3-11621 - 18-01-2017 - END

# FICHE 68631 - SYMEU : 27/10/2010 - DEBUT
# Si STRDAY et ENDDAY sont alimentés, je vais renseigner la variable AM qui est utilisée
# dans VALORDET
If  [F:TIP]STRDAT=[F:TIP]ENDDAT
& & ([F:TIP]STRDAY = 2 and [F:TIP]ENDDAY = 1)
& | ([F:TIP]STRDAY = 1 and [F:TIP]ENDDAY = 2) Then
  [L]AM = 1
Else
  Raz [L]AM
Endif
# FICHE 68631 - SYMEU : 27/10/2010 - FIN

If [L]AM = 0 Then # FICHE 68631 - SYMEU : 27/10/2010
  Call VALORDET( [F:TIP]STRDAT,[F:TIP]ENDDAT,[F:TIP]REFNUM,[F:TIP]TIM,[L]JOUR
&            , [L]HEURE,[F:TIP]FCY,[F:TIP]CTRNUM
&            ) From SUBPLN
# FICHE 68631 - SYMEU : 27/10/2010 - DEBUT
Else
  Call VALORDETAM( [F:TIP]STRDAT,[F:TIP]ENDDAT,[F:TIP]REFNUM,[F:TIP]TIM,[L]JOUR
&            , [L]HEURE,[F:TIP]FCY,[F:TIP]CTRNUM,[L]AM
&            ) From SUBPLN
Endif
# FICHE 68631 - SYMEU : 27/10/2010 - FIN


# FQ86336 - SEGAY - 05/12/12
# On en a besoin pour tester le max nbr heure/jour et si nbr jour > 1
  # FQ77018 - MABON 11/10/11 - On recherche les enregistrements déjà existants, pour ces mêmes dates importées,
  # quelle que soit la date de paie
Local Decimal HPASS, JPASS
If [F:TIP]STRDAT=[F:TIP]ENDDAT
  If clalev([F:TIPP])=0 : Local File TIMEMP [TIPP] : Endif
  Filter [F:TIPP] Where REFNUM=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & STRDAT=[F:TIP]STRDAT & ENDDAT=[F:TIP]ENDDAT
   #  On dé-commente ces lignes pour empêcher la saisie de plus de 1 journée
  For [TIPP]TIP1
     HPASS += [F:TIPP]NBRHOU
     JPASS += [F:TIPP]NBRDAY
  Next
  Filter [F:TIPP]
Endif

# FQ76632 - MABON 06/10/11 - Calculer au prorata des heures
#  If ![F:TIP]NBRHOU : [F:TIP]NBRHOU=sum([L]HEURE) : Endif
#LIPET - X3-11621 - 18-01-2017 - START
#Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#LIPET - X3-11621 - 18-01-2017 - END
#SEGAY 83299 04/07/12
#If [F:TIM]PLGHOR=2 & [F:TIP]STRDAT=[F:TIP]ENDDAT Then
If ([F:TIM]PLGHOR=2 |([F:TIM]PLGHOR<>2 & [F:TIM]DAYDAC = 1))
& & [F:TIP]STRDAT=[F:TIP]ENDDAT Then

# FQ86336 - SEGAY - 05/12/12
# Fait plus haut
# Local Decimal VALHMDEB, VALHMFIN, SUMHRS, HPASS, JPASS, JOUR2, VALHOU
 Local Decimal VALHMDEB, VALHMFIN, SUMHRS, JOUR2, VALHOU
 If [F:TIM]PLGHOR=2
  Call CONVERTHM([F:TIP]STRTIM,VALHMDEB)From SUBSTY
  Call CONVERTHM([F:TIP]ENDTIM,VALHMFIN)From SUBSTY
  If VALHMFIN>=VALHMDEB
    SUMHRS = VALHMFIN-VALHMDEB
  Else
    SUMHRS = 24-VALHMDEB + VALHMFIN
  Endif
  SUMHRS -= [F:TIP]BRKTIM
  SUMHRS  = ar2(SUMHRS)
 Else
 #MABOS-89121-03/04/2013
  If ([F:TIM]PLGHOR<>2 & [F:TIM]DAYDAC = 1) & ![F:TIP]NBRHOU : [F:TIP]NBRHOU=sum([L]HEURE) : Endif
  SUMHRS = [F:TIP]NBRHOU #SEGAY 83299 04/07/12
 Endif
# FQ86336 - SEGAY - 05/12/12
# Fait plus haut
#  If clalev([F:TIPP])=0 : Local File TIMEMP [TIPP] : Endif
#  # FQ77018 - MABON 11/10/11 - On recherche les enregistrements déjà existants, pour ces mêmes dates importées,
#  # quelle que soit la date de paie
#  # + Bug sur [F:TIP]NBRHOU au lieu de [F:TIPP]NBRHOU; idem pour NBRDAY
##  For [TIPP]TIP1 Where REFNUM=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & STRDAT=[F:TIP]STRDAT & ENDDAT=[F:TIP]ENDDAT & DATPYR<>[F:TIP]DATPYR
##    HPASS += [F:TIP]NBRHOU
##    JPASS += [F:TIP]NBRDAY
##  Next
#  For [TIPP]TIP1 Where REFNUM=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & STRDAT=[F:TIP]STRDAT & ENDDAT=[F:TIP]ENDDAT
#    HPASS += [F:TIPP]NBRHOU
#    JPASS += [F:TIPP]NBRDAY
#  Next
  # Fin MABON
  HPASS += SUMHRS
  #LIPET - X3-11621 - 18-01-2017 - START
  #VALHOU=val(func AFNC.PARAM("HOUDAYLEG",[F:CTR]ETRFCY))
  VALHOU=val(func AFNC.PARAM("HOUDAYLEG",[F:HRCTR]ETRFCY))
  #LIPET - X3-11621 - 18-01-2017 - END
  If VALHOU>0 & HPASS>VALHOU Then
   #SBA US2029_92969
   #Call TRACE(2,mess(4,709,1)) From SUBIMPOBJ : # Maximum d'heures par jour
   #LIPET - X3-11621 - 18-01-2017 - START
   #Call TRACE(2,[L]WTTRACE-mess(4,709,1)) From SUBIMPOBJ : # Maximum d'heures par jour
   Call TRACE(2,[L]WTTRACE-mess(4,10709,1)) From SUBIMPOBJ : # Maximum d'heures par jour
   #LIPET - X3-11621 - 18-01-2017 - END

    [V]GOK=0
    Goto AB_TR_AP_IMPORT
  Endif

  [F:TIP]NBRHOU = SUMHRS
  #LIPET - X3-11621 - 18-01-2017 - START
  #Call VALORIS([F:TIP]STRDAT,[F:TIP]ENDDAT,[F:TIP]REFNUM,[F:TIP]TIM,JOUR2,HPASS,[F:CTR]ETRFCY,[F:CTR]CTRNUM) From SUBPLN
  Call VALORIS([F:TIP]STRDAT,[F:TIP]ENDDAT,[F:TIP]REFNUM,[F:TIP]TIM,JOUR2,HPASS,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM) From SUBPLN
  #LIPET - X3-11621 - 18-01-2017 - END
  If HPASS<>0 Then
    # FQ86336 - SEGAY - 05/12/12
    # si on est pas en plage horaire et pas en saisie jour on recalcule simplement NBRDAY
    If [F:TIM]PLGHOR<>2
      [F:TIP]NBRDAY = ar2(SUMHRS*JOUR2/HPASS)
    Else
      [F:TIP]NBRDAY = min(JOUR2-JPASS,ar2(SUMHRS*JOUR2/HPASS))
    Endif
  Else
    [F:TIP]NBRDAY = 0
  Endif
Else
  # FQ86336 - SEGAY - 05/12/12
#  If ![F:TIP]NBRHOU : [F:TIP]NBRHOU=sum([L]HEURE) : Endif
  Raz JOUR3,HEURE3
  If val([V]GIMP(4)) >0  & ![F:TIP]NBRHOU & [F:TIP]NBRDAY & [L]AM=0 & [F:TIM]DAYDAC = 2 & [F:TIP]ENDDAT=[F:TIP]STRDAT
    #LIPET - X3-11621 - 18-01-2017 - START
#    If [F:TIM]COD=GTPSW
#      Call VALORIS([F:TIP]STRDAT,[F:TIP]STRDAT,[F:TIP]REFNUM,"",JOUR3,HEURE3,[F:CTR]ETRFCY,[F:CTR]CTRNUM) From SUBPLN
#    Else
#      Call VALORIS([F:TIP]STRDAT,[F:TIP]STRDAT,[F:TIP]REFNUM,[F:TIM]COD,JOUR3,HEURE3,[F:CTR]ETRFCY,[F:CTR]CTRNUM) From SUBPLN
#    Endif
    If [F:TIM]COD=GTPSW
      Call VALORIS([F:TIP]STRDAT,[F:TIP]STRDAT,[F:TIP]REFNUM,"",JOUR3,HEURE3,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM) From SUBPLN
    Else
      Call VALORIS([F:TIP]STRDAT,[F:TIP]STRDAT,[F:TIP]REFNUM,[F:TIM]COD,JOUR3,HEURE3,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM) From SUBPLN
    Endif
    #LIPET - X3-11621 - 18-01-2017 - END
    If JOUR3<>0
     [F:TIP]NBRHOU = ar2(HEURE3*[F:TIP]NBRDAY/JOUR3)
    Endif
  Else
    If ![F:TIP]NBRHOU : [F:TIP]NBRHOU=sum([L]HEURE) : Endif
  Endif
Endif
# Fin MABON

# FICHE 68631 - SYMEU : 27/10/2010 : on alimente aussi le nombre de jours
# FQ77018 - MABON 11/10/11 - Si NBRDAY est à 0, c'est peut-être parce qu'on a effectivement déjà saisi un total de
# 1 jour pour cette journée, d'où le test en plus sur le nombre d'heures
#If ![F:TIP]NBRDAY : [F:TIP]NBRDAY=sum([L]JOUR) : Endif
# FQ79574 - SEGAY 25/01/12
#If ![F:TIP]NBRDAY & [F:TIP]NBRHOU=0: [F:TIP]NBRDAY=sum([L]JOUR) : Endif
# Fin MABON
# FQ79574 - SEGAY 25/01/12
# Le nombre de jour est mis à jour si l'événement n'est pas de type heure,
# par contre on garde le fait de le mettre à jour par le calcul  du nombre d'heure, si l'événement est de type heure et si la date de début et de fin sont égale (voir BUG 77018)
#SEGAY 83299 04/07/12
#If ![F:TIP]NBRDAY  & ([F:TIP]NBRHOU=0 or !([F:TIM]PLGHOR=2 & [F:TIP]STRDAT=[F:TIP]ENDDAT)) : [F:TIP]NBRDAY=sum([L]JOUR) : Endif
If ![F:TIP]NBRDAY
& & ([F:TIP]NBRHOU=0 | !([F:TIM]PLGHOR=2 & [F:TIP]STRDAT=[F:TIP]ENDDAT) | !([F:TIM]PLGHOR<>2 & [F:TIM]DAYDAC = 1 & [F:TIP]STRDAT=[F:TIP]ENDDAT)) Then
 [F:TIP]NBRDAY=sum([L]JOUR)
Endif
# END FQ79574

# FQ86336 - SEGAY - 05/12/12 Modifier NBRHOU si l'import ne l'a pas initilisé par [V]GIMP(4)
#LIPET - X3-11621 - 18-01-2017 - START
#Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#LIPET - X3-11621 - 18-01-2017 - END
If !([V]GIMP(4)<>"" & [F:TIM]DAYDAC = 1)
# FICHE 68631 - SYMEU : 27/10/2010 : on recalcule éventuellement le nombre d'heures
 If [L]AM = 1 and [F:TIP]NBRDAY <> 1 Then
  [F:TIP]NBRHOU = [F:TIP]NBRHOU * [F:TIP]NBRDAY
 Endif
Endif

# FQ86336 - SEGAY - 05/12/12
If [F:TIM]DAYDAC=2 & [F:TIP]STRDAT=[F:TIP]ENDDAT : #MABOS-Bug 89718-30/04/13
# Uniquement pour la même journée
# On dé-commente ces lignes pour empêcher la saisie de plus de 1 journée
# Fait plus haut
  If JPASS+[F:TIP]NBRDAY>1 Then
    #SBA US2029_92969
    #Call TRACE(2,mess(3,709,1)) From SUBIMPOBJ : # Maximum 1 par jour
    #LIPET - X3-11621 - 18-01-2017 - START
    #Call TRACE(2,[L]WTTRACE-mess(3,709,1)) From SUBIMPOBJ : # Maximum 1 par jour
    Call TRACE(2,[L]WTTRACE-mess(3,10709,1)) From SUBIMPOBJ : # Maximum 1 par jour
    #LIPET - X3-11621 - 18-01-2017 - END
    [V]GOK=0
    Goto AB_TR_AP_IMPORT
  Endif
Endif

# FQ86336 - SEGAY - 05/12/12 On le place ici car si on avait une erreur aprés uniquid la ligne était créée
[F:TIP]LIG   =uniqid([TIP])

# FQ82073 - MABON 07/12/12 - Si [F:TIP]CTRDAT n'est pas importé, il faut le calculer
If [F:TIP]CTRDAT=[0/0/0] Then
 #LIPET - X3-11621 - 18-01-2017 - START
 #[F:TIP]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:PEO]PEREND(0),[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
 [F:TIP]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:HRPEOD]PEREND(0),[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
 #LIPET - X3-11621 - 18-01-2017 - END
Else
 # Contrôle date saisie
 #LIPET - X3-11621 - 18-01-2017 - START
 #Read [F:CTR2]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
 Read [F:HRCTR2]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
 #LIPET - X3-11621 - 18-01-2017 - END
 If fstat
  #GMESSAGE=[F:TIP]REFNUM+"/"+[F:TIP]CTRNUM+"/"+format$("D:"+GFMDAT4,[F:TIP]CTRDAT)-mess(26,701,1) : # Contrat inexistant
  #LIPET - X3-11621 - 18-01-2017 - START
  #GMESSAGE=[L]WTTRACE-[F:TIP]REFNUM+"/"+[F:TIP]CTRNUM+"/"+format$("D:"+GFMDAT4,[F:TIP]CTRDAT)-mess(26,701,1) : # Contrat inexistant
  GMESSAGE=[L]WTTRACE-[F:TIP]REFNUM+"/"+[F:TIP]CTRNUM+"/"+format$("D:"+GFMDAT4,[F:TIP]CTRDAT)-mess(26,10701,1) : # Contrat inexistant
  #LIPET - X3-11621 - 18-01-2017 - END
  Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
  GOK=0
  Return
 Else
   #LIPET - X3-11621 - 18-01-2017 - START
#   # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
#   If  ([F:CTR2]CTRDAT<=[F:TIP]DATPYR | ([F:CTR2]FLGRET=2 & [F:CTR2]RETDATEFF<=[F:TIP]DATPYR)) & ([F:CTR2]XITDAT=[0/0/0] | [F:TIP]ENDDAT<=[F:CTR2]XITDAT) Then
#     # Date ok
#   Else
#     GMESSAGE=[L]WTTRACE-mess(138,701,1) : # Contrat incompatible avec l'événement
#     Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
#     GOK=0
#     Return
#   Endif
   # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
   If  ([F:HRCTR2]CTRDAT<=[F:TIP]DATPYR | ([F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF<=[F:TIP]DATPYR)) & ([F:HRCTR2]XITDAT=[0/0/0] | [F:TIP]ENDDAT<=[F:HRCTR2]XITDAT) Then
     # Date ok
   Else
     GMESSAGE=[L]WTTRACE-mess(138,10701,1) : # Contrat incompatible avec l'événement
     Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
     GOK=0
     Return
   Endif
   #LIPET - X3-11621 - 18-01-2017 - END
 Endif
Endif
# Fin MABON

If dim([F:TIP]CREUSR)=1 & [F:TIP]CREUSR=""      : [F:TIP]CREUSR=[V]GUSER : Endif
If dim([F:TIP]CREDAT)=1 & [F:TIP]CREDAT=[0/0/0] : [F:TIP]CREDAT=date$    : Endif
If dim([F:TIP]CRETIM)=1 & [F:TIP]CRETIM=0       : [F:TIP]CRETIM=time     : Endif

#62004 : Ajout de la condition
If dim([M:IMP2]TEST)>0 & [M:IMP2]TEST<>2
#SEGAY 85489 02/11/12
# Le write est fait en auto dans SUBIMPOBJ0
# Write [TIP]
# If fstat
#  [V]GOK=0
#  Call FSTA("TIP") From GLOCK
#  Goto AB_TR_AP_IMPORT : # 62004 Return
# Endif
 #LIPET - X3-11621 - 18-01-2017 - START
 #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
 Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
 #LIPET - X3-11621 - 18-01-2017 - END
 If [F:TIM]CATTIM=3
  Call ADD_CPPRIS([L]JOUR) From TPSSTD1
  #62004
  #If [V]GOK<1 : Return : Endif
  If [V]GOK<1 : Goto AB_TR_AP_IMPORT : Endif
 Endif
Endif

#62004
Call TRACE(0,[L]WTTRACE-[F:TIP]TIM-format$("D:"+GFMDAT4,[F:TIP]STRDAT)-format$("D:"+GFMDAT4,[F:TIP]ENDDAT)) From SUBIMPOBJ
#Call TRACE(0,[F:TIP]REFNUM-[F:ID]NAM-[F:TIP]TIM-format$("D:"+GFMDAT4,[F:TIP]STRDAT)-format$("D:"+GFMDAT4,[F:TIP]ENDDAT)) From SUBIMPOBJ
Commit
Return

#62004
$AB_TR_AP_IMPORT
Rollback
Return
#fin 62004

################################################################################
#
# Routines
#
################################################################################

Subprog SETDATE(DAT,VALEUR,A_ER)
Variable Date    DAT
Value    Char    VALEUR()
Variable Integer A_ER

Local Char CHAINE(len([L]VALEUR))

[L]CHAINE=ctrans([L]VALEUR,ctrans([L]VALEUR,"0123456789",""),"")
Call SETDATE([L]DAT,[L]CHAINE,[F:AOE]OPTDAT,[L]A_ER) From SUBIMPOBJ

End

Funprog NMIN(DAT,HOU)
Value Date DAT
Value Char HOU()

End 1E4*([L]DAT-[V]GDATDEB)+val(ctrans([L]HOU,ctrans([L]HOU,"0123456789",""),""))

###75722
#############################
Subprog CONVERTHM(VALEUR,NBHEURE)
Value Char VALEUR ()
Variable Decimal NBHEURE
Local Integer HH, MM
Call CONTHM(VALEUR) From OBJDIV
HH = val(left$(VALEUR,2))
MM = val(right$(VALEUR,3))
NBHEURE = ((HH*60)+MM)/60
End

