#<AdxTL>@(#)6.0.0.0 $Revision$
################################################################################################################
# Historique prospect/client                                              Module CRM          13 novembre 2000 #
################################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "FIR"          : Gosub PREMIER
 When "PRE"          : Gosub PRECEDENT
 When "SUI"          : Gosub SUIVANT
 When "LAS"          : Gosub DERNIER
 When Default
Endcase
Return


$OUVRE
If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif

Global Integer GHBP2PARMOD
GHBP2PARMOD = 0

Return

$PREMIER
Return

$PRECEDENT
Return

$SUIVANT
Return

$DERNIER
Return

$DEFBOUT
Return

$SETBOUT
Return

$OUVRE_BOITE
Return

$DEBUT

Gosub LOADHBP2

Affzo [M:HBP2]
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
Raz [M:HBP2]

If GHBP2PARMOD
    #Recalcul l'historique en fonction des nouveaux paramètres

    Call TEMPON("R") From GESECRAN

    Local Integer IPBL2
    IPBL2 = 0
    Call RAZ_HST From TRTHBP1
    Call RAZHBP From TRTHBP1

    [M:HBP1]TTR = mess(349, 196, 2) #Liste des actions effectuées.

    Call FILLHST(0, IPBL2) From TRTHBP1
    Call LOADHBP(0, 0, IPBL2) From TRTHBP1

    GSZHBPREC = [M:HBP1]NUM(0)
    GSZHBPTYP = [M:HBP1]TYP(0)
    GIFILLTODO = 0
    GIDONE = 1

    Call TEMPOFF From GESECRAN
Endif

Kill GHBP2PARMOD

Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
Return

$BOUTON
Return

$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
$LOADHBP2

Local Integer INBDTA
INBDTA = 0

#Devis
[M:HBP2]DSYDTA(INBDTA) = mess(121, 198, 1) #Devis
If GHBP1SQH
    [M:HBP2]DSYFLG(INBDTA) = 2
Else
    [M:HBP2]DSYFLG(INBDTA) = 1
Endif
INBDTA += 1

#Commande
[M:HBP2]DSYDTA(INBDTA) = mess(48, 198, 1) #Commandes
If GHBP1SOH
    [M:HBP2]DSYFLG(INBDTA) = 2
Else
    [M:HBP2]DSYFLG(INBDTA) = 1
Endif
INBDTA += 1

#Livraisons
[M:HBP2]DSYDTA(INBDTA) = mess(90, 198, 1) #Livraisons
If GHBP1SDH
    [M:HBP2]DSYFLG(INBDTA) = 2
Else
    [M:HBP2]DSYFLG(INBDTA) = 1
Endif
INBDTA += 1

#Factures
[M:HBP2]DSYDTA(INBDTA) = mess(369, 198, 1) #Factures
If GHBP1SIV
    [M:HBP2]DSYFLG(INBDTA) = 2
Else
    [M:HBP2]DSYFLG(INBDTA) = 1
Endif
INBDTA += 1

#Factures tiers
[M:HBP2]DSYDTA(INBDTA) = mess(304, 183, 1) #Factures tiers
If GHBP1BPRSIH
    [M:HBP2]DSYFLG(INBDTA) = 2
Else
    [M:HBP2]DSYFLG(INBDTA) = 1
Endif
INBDTA += 1

[M:HBP2]NBDTA = INBDTA

Return




