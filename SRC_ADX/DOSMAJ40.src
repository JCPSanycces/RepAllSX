#<AdxTL>@(#)1.0.0.0 $Revision$
##################################################################################
# DOSMAJ40 : Mises à jour à effectuer lors du passage à la version 7 (Release 40)
# Moulinette avant la version 7
##################################################################################
# Issue 106947 - 20151105 by LD : Migration of historic folder

#-------------------------------------#
#         Avant mise à jour           #
#-------------------------------------#

#######################################
Subprog AMAJ
Local Integer VERSION

Onerrgo ERREUR
VERSION = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ40 - AMAJ - VERSION = "-num$(VERSION),-1) From GESECRAN

#----- Rectification du dico Tronc commun
#Call ECR_TRACE("************** ADICMAJ40 TRCMAJ40 ***************",-1) From GESECRAN
#Call ADICMAJ40 From TRCMAJ40 : # Moulinettes Tronc commun

#-----
# Rajout des types de données
# Rajout des codes activités
# Rajout des nouveaux champs V7
# Les index sont préservés
#-----

Call MAJDIC From SUPMAJ40
# Issue 108760 - 2015-06-12 by SR : adaptation
# COSTSTCD table creation : only on a historic folder
## if COSTSTCD   is a view and if one of the module that used it is present
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=1 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"COSTSTCD")=1
&                                           & find([F:ADS]MODULE(5)=2)
  Call CRE_HISTAB([F:ADS]DOSREF,[F:ADS]DOSSIER,[F:ADS]TYPDBA, "COSTSTCD") From CREHISTO
Endif
# End issue 108760
#----- Superviseur en premier

Call AMAJ   From SUPMAJ40      : # Moulinettes Superviseur

GVALIDE(2) = 1 : # Ecrans
GVALIDE(3) = 1 : # Objets
GVALIDE(4) = 1 : # Fenêtres et TRT générés superviseur
GVALIDE(5) = 1 : # Consultations

#----- Puis Tronc commun
#Gbn-106947
Call ECR_TRACE("************** ATRCMAJ40 TRCMAJ40 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  Call ATRCMAJ40   From TRCMAJ40 : # Moulinettes Tronc commun
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

#----- Ensuite les autres modules
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** ATRCMAJ40 CPTMAJ40 ***************",-1) From GESECRAN
 Call ATRCMAJ40 From CPTMAJ40 : # Moulinettes Compta - Commun
 If [F:ADS]MODULE(1)=2
  Call ECR_TRACE("************** ACPTMAJ40 CPTMAJ40 ***************",-1) From GESECRAN
  Call ACPTMAJ40 From CPTMAJ40 : # Moulinettes Compta
  GVALTRANS(2)=2
 Endif
Endif

If [F:ADS]MODULE(2)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** ATRSMAJ40 CPTMAJ40 ***************",-1) From GESECRAN
 Call ATRSMAJ40 From CPTMAJ40 : # Moulinettes Tiers
 GVALTRANS(3)=2
Endif

#Gbn-106947
If [F:ADS]MODULE(4)=2
  Call ECR_TRACE("************** AVENMAJ40 VENMAJ40 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call AVENMAJ40 From VENMAJ40 : # Moulinettes Ventes
    GVALTRANS(5)=2               : # TRT générés Ventes (transactions, tarifs)
  Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

#Gbn-106947
If [F:ADS]MODULE(5)=2
  Call ECR_TRACE("************** AACHMAJ40 ACHMAJ40 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call AACHMAJ40 From ACHMAJ40 : # Moulinettes Achats
    GVALTRANS(6)=2
  Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

#Gbn-106947
If [F:ADS]MODULE(6)=2
  Call ECR_TRACE("************** ASTOMAJ40 STOMAJ40 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call ASTOMAJ40 From STOMAJ40 : # Moulinettes Stocks
    GVALTRANS(7)=2
  Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

#Gbn-108091
If [F:ADS]MODULE(7)=2
  Call ECR_TRACE("************** AGPAMAJ40 GPAMAJ40 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call AGPAMAJ40 From GPAMAJ40 : # Moulinettes GPAO
    GVALTRANS(8)=2
  Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

#Gbn-106947
If [F:ADS]MODULE(11)=2
  Call ECR_TRACE("************** ACR1MAJ40 CRMMAJ40 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    # FGR 27/03/2014 : X3SUIVI98472 (début)
    Call ACR1MAJ40 From CRMMAJ40 : # Moulinettes CRM1
    GVALTRANS(12)=2              : # TRT générés Support clients
  Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

#Gbn-106947
If [F:ADS]MODULE(12)=2
  Call ECR_TRACE("************** ACR2MAJ40 CRMMAJ40 ***************",-1) From GESECRAN
# Issue 106947
# To do if historic folder
#  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
# End issue 106947
    Call ACR2MAJ40 From CRMMAJ40 : # Moulinettes CRM2
    GVALTRANS(13)=2              : # TRT générés Action commerciale
# Issue 106947
#  Else
#    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
#  Endif
# End issue 106947
Endif

Call ECR_TRACE("************** AFASMAJ40 FASMAJ40 ***************",-1) From GESECRAN
If [F:ADS]MODULE(13)=2
  Call AFASMAJ40 From FASMAJ40 : # Moulinettes Immobilisations
  GVALTRANS(14)=2              : # TRT générés Immobilisations
Endif

Onerrgo
End



#-------------------------------------#
#          Après mise à jour          #
#-------------------------------------#

#######################################
Subprog MAJ
Local Integer VERSION

Onerrgo ERREUR

###########################################
# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH

Raz WVERSION, WPATCH

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

## Ne pas razer WPATCH si left$(WVERSION,3)="1.6"

###########################################

VERSION = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ40 - MAJ - VERSION = "-num$(VERSION),0) From GESECRAN

#----- Superviseur en premier

Call ECR_TRACE("************** MAJ SUPMAJ40 ***************",-1) From GESECRAN
Call MAJ      From SUPMAJ40     : # Moulinettes Superviseur

#----- Puis Tronc commun et CRM
Call ECR_TRACE("************** TRCMAJ40 TRCMAJ40 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  Call TRCMAJ40 From TRCMAJ40     : # Moulinettes Tronc commun
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

#----- Ensuite les autres modules

If [F:ADS]MODULE(1)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** CPTMAJ40 CPTMAJ40 ***************",-1) From GESECRAN
 Call CPTMAJ40  From CPTMAJ40  : # Moulinettes Compta
Endif

If [F:ADS]MODULE(2)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** TRSMAJ40 CPTMAJ40 ***************",-1) From GESECRAN
 Call TRSMAJ40  From CPTMAJ40  : # Moulinettes Tiers
Endif

#Gbn-106947
If [F:ADS]MODULE(4)=2
  Call ECR_TRACE("************** VENMAJ40 VENMAJ40 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
    Call VENMAJ40  From VENMAJ40  : # Moulinettes Ventes
    If left$(WVERSION,3) = "1.6" & WPATCH<27 : ## si le dossier avant mise à jour était en V6 < patch 27
       Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA25 : ## GH 10/10/2013 bug 90029
    Endif
  Else
   Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

# Issue 108760 - 2015-06-12 by SR : To be checked
#Gbn-106947
If  [F:ADS]MODULE(5)=2
  Call ECR_TRACE("************** ACHMAJ40 ACHMAJ40 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call ACHMAJ40  From ACHMAJ40  : # Moulinettes Achats
  Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

# Issue 108760 - 2015-06-12 by SR : To be checked
#Gbn-106947
If [F:ADS]MODULE(6)=2
  Call ECR_TRACE("************** STOMAJ40 STOMAJ40 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
   Call STOMAJ40  From STOMAJ40  : # Moulinettes Stocks
  Else
   Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

# Issue 107012 - 2015-11-09 by BEEBE : Initialize ROUOPENUM = 0 for unexpected tracked OPs
If [F:ADS]MODULE(7)=2 # Manufacturing
    Call ECR_TRACE("************** MAJ UTIGPA47 ***************",-1) From GESECRAN
    If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
        Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA47
    Else
        Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
    Endif
Endif

# FGR 27/03/2014 : X3SUIVI98472 (début)

# Issue 108760 - 2015-06-12 by SR : To be checked
#Gbn-106947
If  [F:ADS]MODULE(11)=2
  Call ECR_TRACE("************** CR1MAJ40 CRMMAJ40 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call CR1MAJ40  From CRMMAJ40  : # Moulinettes CRM1
  Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif



# Issue 108760 - 2015-06-12 by SR : To be checked
#Gbn-106947
If [F:ADS]MODULE(12)=2
  Call ECR_TRACE("************** CR2MAJ40 CRMMAJ40 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call CR2MAJ40  From CRMMAJ40  : # Moulinettes CRM2
  Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

Call ECR_TRACE("************** FASMAJ40 FASMAJ40 ***************",-1) From GESECRAN
If [F:ADS]MODULE(13)=2
  Call FASMAJ40  From FASMAJ40  : # Moulinettes Immo
Endif

Onerrgo
End

###################################################################################
###################################################################################
###################################################################################

$ERREUR
GERRDOS = errn
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Resume

