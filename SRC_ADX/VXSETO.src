#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management VXSETO
####################################################################################
$ACTION

Case ACTION
  When "DEBUT"         : Gosub DEBUT
  When "OUVRE"         : Gosub OUVRE
  When "OK"            : Gosub OK
Endcase

Return
####################################################################################
$OUVRE

  Global Char    GMTSNUM(GLONTRS) : GMTSNUM = GFLAG

  If !clalev([SFTX])  : Local File SFTTXN   [SFTX]  : Endif
  If !clalev([F:TMA]) : Local File TABMAT   [TMA]  : Endif

Return
####################################################################################
$DEBUT

Raz [M:VXSETO]
Affzo [M:VXSETO]

Return
####################################################################################
$OK

  Local Integer   NUM_STOPPED, MY_STATUS, RESTART_OPER
  Local Date ODATE
  Local Char OTIME(5)

  Local Integer   SFTTYP(1)     : SFTTYP(0) = 4
  Local Char      VCRNUM(20)(1) : VCRNUM(0) = [M:VXSETO]VCRNUM
  Local Integer   SFTSEQ(1)     : SFTSEQ(0) = [M:VXSETO]SFTSEQ

  # Variables to pass to class method that we don't need
  Local Integer   INDTYP(1) # Indirect Type
  Local Integer   CPLQTY(1) # Completed Quantity
  Local Integer   REJQTY(1) # Rejected Quantity
  Local Integer   SCANUM(1) # Rejection Code
  Local Integer   CLEFLG(1) # Completed (Binary)

  # Initialization
  NUM_STOPPED   = 1
  Call STOP_OPERATIONS([M:VXSETO]EMPNUM, [M:VXSETO]FCY, SFTTYP, VCRNUM, [M:VXSETO]OPENUM, SFTSEQ,
&                      INDTYP, CPLQTY, REJQTY, SCANUM, CLEFLG, NUM_STOPPED) From SFTLIB

  # Confirmation message
  Call TIMESTAMP([M:VXSETO]FCY, ODATE, OTIME) From SFTLIB
  Call MESSAGE(func AFNC.MES2(mess(78,2422,1), [M:VXSETO]VCRNUM+" "+num$([M:VXSETO]OPENUM), left$(OTIME,2) + ":" + right$(OTIME,3))) From GESECRAN

Return
####################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal  VALEUR

  Local Integer EMPTYP

  # check if employee exist
  Read [TMA]TMA0=VALEUR
  If fstat
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 2
    End
  Endif

  EMPTYP =  [TMA]EMPTYP

  # Check if employee is active
  If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
    mkstat = 2
    End
  Endif

  Local Integer EMPLIST(1..)
  EMPLIST(1) = VALEUR
  Call TEAM_LIST (VALEUR, "A", EMPLIST) From SFTLIB
  [M:VXSETO]EMPLST = EMPLIST(1) #CT-1993

  #Check if an employee or team is on a break or on an exclusive indirect
  If func SFTLIB.EMPLOYEE_ON_BREAK(EMPLIST(1)) = [V]CST_AYES
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV

    #X3-1801 sn
    Case EMPTYP
      When 0,1 #Employee
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(18,2422,1)
      When 2 #Detail Team
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(122,2422,1)
      When 3 #Summary Team
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(121,2422,1)
    Endcase
    #X3-1801 en

    mkstat = 2
    End
  Endif

End
######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  #Get the employee default site (if it exists)
  Read [TMA]TMA0=VALEUR
  If !fstat
    # Default employee description and the site if populated
    [M:VXSETO]EMPDES  = [F:TMA]EMPDES
    [M:VXSETO]FCY     = [F:TMA]DEFFCY
    [M:VXSETO]EMPTYP  = [F:TMA]EMPTYP

    Affzo [M:VXSETO]FCY
  Else    # Not found
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 2
    End
  Endif

End
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer  EMP_LIST(1..)

  # Make sure the global variables and parameters are updated
  GFCY=VALEUR : Gosub CHARG_PARAM From SUBMTKA

  Local Char PARAMRET(4)
  Raz PARAMRET

  # check if clock in is needed for this site
  Call PARAM(VALEUR,"SFTEMPCLK",PARAMRET) From ADOVAL
  If val([L]PARAMRET) = [V]CST_AYES
    If [M:VXSETO]EMPTYP = 2
      #X3-1717 sn
      # Check if team members are clocked in or not on any individual activities
      Call TEAM_LIST ([M:VXSETO]EMPNUM, 'A', EMP_LIST) From SFTLIB
      If maxtab(EMP_LIST) = 0   # No team member found
        Call ERREUR(func AFNC.MES1(mess(110,2422,1), num$([M:VXSETO]EMPNUM))) From GESECRAN
        mkstat = 1
        End
      Endif
      #X3-1717 en
    Else #Detailed teams dont clock in
      If func SFTLIB.EMPLOYEE_CLOCKED_IN([M:VXSETO]EMPNUM) = [V]CST_ANO
        Call ERREUR(func AFNC.MES1(mess(12,2422,1), num$([M:VXSETO]EMPNUM))) From GESECRAN #CT-1797
        mkstat = 1
        End
      Endif
    Endif
  Elsif [M:VXSETO]EMPTYP = 2 #Detailed teams must be on sites that require clock-in
    GMESSAGE = func AFNC.MES1(mess(111,2422,1), "SFTEMPCLK")
    mkstat = 1
    End
  Endif

End
######################################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()

  # Manually enter the WO. Check if the order currently running
  Filter [F:SFTX] Where EMPNUM = [M:VXSETO]EMPLST & SFTTYP = 4 & FCY = [M:VXSETO]FCY & VCRNUM = VALEUR & UTCENDDATTIM = AVOID.ADATTIM &
&                       (MACFLG <> [V]CST_AYES | TXNUUID = AVOID.AUUID |
&                       (TEAMNUM <> [M:VXSETO]EMPLST & TEAMNUM <> 0 & MACFLG = [V]CST_AYES)) #CT-1993
  Look [F:SFTX]SFT0 First
  Filter [F:SFTX]
  If fstat
    GERR=1 : GMESSAGE = func AFNC.MES1(mess(82,2422,1),num$(VALEUR))
    mkstat = 2
  Endif

End
######################################################################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR

  # Verify if the operation running
  Filter [F:SFTX] Where EMPNUM = [M:VXSETO]EMPLST & SFTTYP = 4 & FCY = [M:VXSETO]FCY & VCRNUM = [M:VXSETO]VCRNUM & OPENUM = VALEUR & UTCENDDATTIM = AVOID.ADATTIM &
&                       (MACFLG <> [V]CST_AYES | TXNUUID = AVOID.AUUID |
&                       (TEAMNUM <> [M:VXSETO]EMPLST & TEAMNUM <> 0 & MACFLG = [V]CST_AYES)) #CT-1993
  Read [F:SFTX]SFT0 First
  Filter [F:SFTX]
  If fstat    # Record found
    GERR=1 : GMESSAGE = func AFNC.MES1(mess(82,2422,1),num$(VALEUR))
    mkstat = 2
  Else
    [M:VXSETO]SFTSEQ =  [F:SFTX]SFTSEQ
  Endif

End
######################################################################################

