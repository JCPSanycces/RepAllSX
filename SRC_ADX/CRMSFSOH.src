#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################
# Subprogram for reading sales orders for Salesforce
####################################################################################################


Subprog READSALESORDER(SOLDTO,
&                      DESSOLDTO,
&                      ORDERNUMBER,
&                      ORDERREFERENCE,
&                      ORDERTYPE,
&                      DESORDERTYPE,
&                      SALESSITE,
&                      DESSALESSITE,
&                      ORDERDATE,
&                      CURRENCY,
&                      DESCURRENCY,
&                      PAYBY,
&                      DESPAYBY,
&                      SALESREP,
&                      DESSALESREP,
&                      TAXRULE,
&                      DESTAXRULE,
&                      SIGNEDSTATUS,
&                      ORDERSTATE,
&                      ALLOCATIONSTATUS,
&                      HOLDSTATUS,
&                      CREDITSTATUS,
&                      DELIVERYSTATUS,
&                      INVOICESTATUS,
&                      BILLTOCUSTOMER,
&                      DESBILLTOCUSTOMER,
&                      CLOSINGREASON,
&                      DESCLOSINGREASON,
&                      DELIVERYADDRESS,
&                      DELIVERYADDRESSCITY,
&                      DELIVERYADDRESSPROVINCE,
&                      DELIVERYADDRESSPOSTALCODE,
&                      DELIVERYADDRESSCOUNTRY,
&                      SHIPMENTSITE,
&                      DESSHIPMENTSITE,
&                      DELIVERYPRIORITY,
&                      REQUIREDDELIVERYDATE,
&                      SHIPMENTDATE,
&                      DELIVERYMODE,
&                      DESDELIVERYMODE,
&                      CARRIER,
&                      DESCARRIER,
&                      INVOICEELEMENT,
&                      PERCENTORAMOUNT,
&                      VALUETYPE,
&                      PRODUCT,
&                      PRODUCTDESCRIPTION,
&                      QUANTITY,
&                      UNITOFMEASURE,
&                      NETPRICE,
&                      RESPONSESTATUS,
&                      RESPONSEMESSAGES,
&                      LBLSOLDTO,
&                      LBLORDERNUMBER,
&                      LBLORDERREFERENCE,
&                      LBLORDERTYPE,
&                      LBLSALESSITE,
&                      LBLORDERDATE,
&                      LBLCURRENCY,
&                      LBLPAYBY,
&                      LBLSALESREP,
&                      LBLTAXRULE,
&                      LBLSIGNEDSTATUS,
&                      LBLORDERSTATE,
&                      LBLALLOCATIONSTATUS,
&                      LBLHOLDSTATUS,
&                      LBLCREDITSTATUS,
&                      LBLDELIVERYSTATUS,
&                      LBLINVOICESTATUS,
&                      LBLBILLTOCUSTOMER,
&                      LBLCLOSINGREASON,
&                      LBLDELIVERYADDRESS,
&                      LBLSHIPMENTSITE,
&                      LBLDELIVERYPRIORITY,
&                      LBLREQUIREDDELIVERYDATE,
&                      LBLSHIPMENTDATE,
&                      LBLDELIVERYMODE,
&                      LBLCARRIER,
&                      LBLINVOICEELEMENT,
&                      LBLPERCENTORAMOUNT,
&                      LBLVALUETYPE,
&                      LBLPRODUCT,
&                      LBLPRODUCTDESCRIPTION,
&                      LBLQUANTITY,
&                      LBLUNITOFMEASURE,
&                      LBLNETPRICE)

  Variable Char SOLDTO
  Variable Char DESSOLDTO
  Variable Char ORDERNUMBER
  Variable Char ORDERREFERENCE
  Variable Char ORDERTYPE
  Variable Char DESORDERTYPE
  Variable Char SALESSITE
  Variable Char DESSALESSITE
  Variable Char ORDERDATE
  Variable Char CURRENCY
  Variable Char DESCURRENCY
  Variable Char PAYBY
  Variable Char DESPAYBY
  Variable Char SALESREP
  Variable Char DESSALESREP
  Variable Char TAXRULE
  Variable Char DESTAXRULE
  Variable Char SIGNEDSTATUS
  Variable Char ORDERSTATE
  Variable Char ALLOCATIONSTATUS
  Variable Char HOLDSTATUS
  Variable Char CREDITSTATUS
  Variable Char DELIVERYSTATUS
  Variable Char INVOICESTATUS
  Variable Char BILLTOCUSTOMER
  Variable Char DESBILLTOCUSTOMER
  Variable Char CLOSINGREASON
  Variable Char DESCLOSINGREASON
  Variable Char DELIVERYADDRESS
  Variable Char DELIVERYADDRESSCITY
  Variable Char DELIVERYADDRESSPROVINCE
  Variable Char DELIVERYADDRESSPOSTALCODE
  Variable Char DELIVERYADDRESSCOUNTRY
  Variable Char SHIPMENTSITE
  Variable Char DESSHIPMENTSITE
  Variable Char DELIVERYPRIORITY
  Variable Char REQUIREDDELIVERYDATE
  Variable Char SHIPMENTDATE
  Variable Char DELIVERYMODE
  Variable Char DESDELIVERYMODE
  Variable Char CARRIER
  Variable Char DESCARRIER
  Variable Char INVOICEELEMENT()(1..)
  Variable Char PERCENTORAMOUNT()(1..)
  Variable Char VALUETYPE()(1..)
  Variable Char PRODUCT()(1..)
  Variable Char PRODUCTDESCRIPTION()(1..)
  Variable Char QUANTITY()(1..)
  Variable Char UNITOFMEASURE()(1..)
  Variable Char NETPRICE()(1..)

  Variable Integer RESPONSESTATUS
  Variable Char    RESPONSEMESSAGES()(1..)

  Variable Char LBLSOLDTO
  Variable Char LBLORDERNUMBER
  Variable Char LBLORDERREFERENCE
  Variable Char LBLORDERTYPE
  Variable Char LBLSALESSITE
  Variable Char LBLORDERDATE
  Variable Char LBLCURRENCY
  Variable Char LBLPAYBY
  Variable Char LBLSALESREP
  Variable Char LBLTAXRULE
  Variable Char LBLSIGNEDSTATUS
  Variable Char LBLORDERSTATE
  Variable Char LBLALLOCATIONSTATUS
  Variable Char LBLHOLDSTATUS
  Variable Char LBLCREDITSTATUS
  Variable Char LBLDELIVERYSTATUS
  Variable Char LBLINVOICESTATUS
  Variable Char LBLBILLTOCUSTOMER
  Variable Char LBLCLOSINGREASON
  Variable Char LBLDELIVERYADDRESS
  Variable Char LBLSHIPMENTSITE
  Variable Char LBLDELIVERYPRIORITY
  Variable Char LBLREQUIREDDELIVERYDATE
  Variable Char LBLSHIPMENTDATE
  Variable Char LBLDELIVERYMODE
  Variable Char LBLCARRIER
  Variable Char LBLINVOICEELEMENT
  Variable Char LBLPERCENTORAMOUNT
  Variable Char LBLVALUETYPE
  Variable Char LBLPRODUCT
  Variable Char LBLPRODUCTDESCRIPTION
  Variable Char LBLQUANTITY
  Variable Char LBLUNITOFMEASURE
  Variable Char LBLNETPRICE

  # Environment
  Local Char    WEBSERVICELANGUAGE(GLONLAN) : WEBSERVICELANGUAGE = GLANGUE
  Local Char    ERRMSG(255)

  # Used across gosubs
  Local Char    FUNCTION(30) : FUNCTION = "soapRead"
  Local Clbfile ARGUMENTS
  Local Clbfile RESBODY

  # Logging across gosubs
  Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance C_ALOG AllocGroup null
  OK=fmet MYLOG.ABEGINLOG("CRMSFSOHR"-mess(3,7845,1))
  OK=fmet MYLOG.APUTLINE("Reading sales order"-ORDERNUMBER,OK)   # TODO translate this text
  OK=fmet MYLOG.AFLUSHLOG

  # Build call to BPC web service
  ARGUMENTS = '"'
  Append ARGUMENTS, WEBSERVICELANGUAGE    # <codeLang> from ws call to this subprogram
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'SFCRMPOOL'            # TODO can this come from call?  <poolAlias>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'CRMSFSOH'            # <publicName>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'SOHNUM'              # <objectKeys.key>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, ORDERNUMBER           # <objectKeys.value>
  Append ARGUMENTS, '"'

#-------------------------------------------------------------------------------------------------#
# Unremark below line to log contents of ARGUMENTS
#OK = fmet MYLOG.APUTLINE("ARGUMENTS ="-ARGUMENTS, OK) : OK = fmet MYLOG.AFLUSHLOG
#-------------------------------------------------------------------------------------------------#

If ERRMSG <> ""
     RESPONSEMESSAGES(1) = ERRMSG
  Else
    Gosub CALLBUNDLE From CRMSF
    If ERRMSG <> ""
      RESPONSEMESSAGES(1) = ERRMSG
    Else
      RESPONSESTATUS = func CRMSF.GETRESPONSESTATUS(RESBODY)
      If RESPONSESTATUS=0
        Gosub LOADRESPONSES From CRMSF
      Else
        Gosub PROCESSRETURNEDXML
        If OK
          OK=fmet MYLOG.APUTLINE("Read sales order"-ORDERNUMBER,OK)    # TODO translation
       Endif
      Endif
    Endif
  Endif

  # End logging
  OK = fmet MYLOG.AENDLOG
  FreeGroup MYLOG

End

####################################################################################################

$PROCESSRETURNEDXML

  OK = fmet MYLOG.APUTLINE(mess(RESPONSESTATUS,189,1), OK) : OK = fmet MYLOG.AFLUSHLOG

  # Populate return variables
  Gosub LOADRETURNVALUES
  If ERRMSG = ""
    # Get field labels
    Gosub LOADLABELS
  Endif

Return

####################################################################################################

$LOADRETURNVALUES

  Local Clbfile ADDRESSLINES
  Local Integer LOOP
  Local Char    CURRENCYFORMAT(30)
  Local Char    QUANTITYFORMAT(30)
  Local Char    NETPRICEFORMAT(30)
  Local Char    DESUNITOFMEASURE(30)
  Local Integer INVOICEELEMENTS
  Local Integer ORDERLINES

  # Header fields
  SOLDTO                    = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "BPCORD")
  DESSOLDTO                 = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "BPCNAM")
  ORDERNUMBER               = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "SOHNUM")
  ORDERREFERENCE            = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "CUSORDREF")
  ORDERTYPE                 = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "SOHTYP")
  DESORDERTYPE              = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "DESAXX")
  SALESSITE                 = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "SALFCY")
  DESSALESSITE              = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "FCYNAM")
  ORDERDATE                 = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "DESORDDAT")
  CURRENCY                  = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "CUR")
  DESCURRENCY               = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS01_1", 0, "INTDES")
  PAYBY                     = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "BPCPYR")
  DESPAYBY                  = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "BPCPYRNAM")
  SALESREP                  = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "REP")
  DESSALESREP               = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "REPNAM")
  TAXRULE                   = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "VACBPR")
  DESTAXRULE                = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "VACBPRDES")
  SIGNEDSTATUS              = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "DESAPPFLG")
  ORDERSTATE                = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "DESORDSTA")
  ALLOCATIONSTATUS          = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "DESALLSTA")
  HOLDSTATUS                = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "DESHLDSTA")
  CREDITSTATUS              = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "DESCDTSTA")
  DELIVERYSTATUS            = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "DESDLVSTA")
  INVOICESTATUS             = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "DESINVSTA")
  BILLTOCUSTOMER            = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "BPCINV")
  DESBILLTOCUSTOMER         = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "DESBPCINV")
  CLOSINGREASON             = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "CCLREN")
  DESCLOSINGREASON          = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_1", 0, "ZCCLREN")
  ADDRESSLINES              = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_2", 0, "BPDADDLIG")
  DELIVERYADDRESS1          = func CRMSF.GETLISTVALUE(ADDRESSLINES, 1)
  DELIVERYADDRESS2          = func CRMSF.GETLISTVALUE(ADDRESSLINES, 2)
  DELIVERYADDRESS3          = func CRMSF.GETLISTVALUE(ADDRESSLINES, 3)
  Call COMBINEADDRESSES(DELIVERYADDRESS1, DELIVERYADDRESS2, DELIVERYADDRESS3, DELIVERYADDRESS) From CRMSF
  DELIVERYADDRESSCITY       = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_2", 0, "BPDCTY")
  DELIVERYADDRESSPROVINCE   = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_2", 0, "DESBPDSAT")
  DELIVERYADDRESSPOSTALCODE = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_2", 0, "BPDPOSCOD")
  DELIVERYADDRESSCOUNTRY    = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS02_2", 0, "BPDCRYNAM")
  SHIPMENTSITE              = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS03_1", 0, "STOFCY")
  DESSHIPMENTSITE           = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS03_1", 0, "FCYNAM")
  DELIVERYPRIORITY          = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS03_1", 0, "DESDLVPIO")
  REQUIREDDELIVERYDATE      = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS03_1", 0, "DESDEMDLVDAT")
  SHIPMENTDATE              = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS03_1", 0, "DESSHIDAT")
  DELIVERYMODE              = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS03_1", 0, "MDL")
  DESDELIVERYMODE           = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS03_1", 0, "MDLDES")
  CARRIER                   = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS03_1", 0, "BPTNUM")
  DESCARRIER                = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS03_1", 0, "BPTNAM")

  # Invoicing elements
  CURRENCYFORMAT = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS04_1", 1, "FORMAT")
  INVOICEELEMENTS = int(val(func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS04_1", 0, "SIZE")))

  If INVOICEELEMENTS
    For LOOP = 1 To INVOICEELEMENTS
      INVOICEELEMENT(LOOP)  = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS04_1", LOOP, "DES")
      PERCENTORAMOUNT(LOOP) = format$(CURRENCYFORMAT, func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS04_1", LOOP, "INVDTAAMT"))
      VALUETYPE(LOOP)       = mess(val(func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS04_1", LOOP, "INVDTATYP")), 2227, 1)
    Next
  Endif

  # Lines
  QUANTITYFORMAT = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS05_1", 1, "QTYFMT")
  NETPRICEFORMAT = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS05_1", 1, "NETPRIFMT")
  ORDERLINES     = int(val(func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS05_1", 0, "SIZE")))

  For LOOP = 1 To ORDERLINES
    PRODUCT(LOOP)            = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS05_1", LOOP, "ITMREF")
    PRODUCTDESCRIPTION(LOOP) = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS05_1", LOOP, "ITMDES")

    QUANTITY(LOOP)           = format$(QUANTITYFORMAT, func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS05_1", LOOP, "QTY"))
    UNITOFMEASURE(LOOP)      = func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS05_1", LOOP, "DESSAU") - "(" + func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS05_1", LOOP, "SAU") + ")"


    NETPRICE(LOOP)           = format$(NETPRICEFORMAT, func CRMSF.GETXMLVALUE(RESBODY, "CRMSFS05_1", LOOP, "NETPRI"))
  Next

  OK=fmet MYLOG.APUTLINE("Sales order detail return values loaded",OK) : OK=fmet MYLOG.AFLUSHLOG     # TODO translate

  # Decode any XML escaped characters in the returned values
  If DESSOLDTO                 <> "" : DESSOLDTO                 = func CRMSF.ESCAPECHARS(DESSOLDTO                , "OUT") : Endif
  If ORDERREFERENCE            <> "" : ORDERREFERENCE            = func CRMSF.ESCAPECHARS(ORDERREFERENCE           , "OUT") : Endif
  If DESORDERTYPE              <> "" : DESORDERTYPE              = func CRMSF.ESCAPECHARS(DESORDERTYPE             , "OUT") : Endif
  If DESSALESSITE              <> "" : DESSALESSITE              = func CRMSF.ESCAPECHARS(DESSALESSITE             , "OUT") : Endif
  If DESCURRENCY               <> "" : DESCURRENCY               = func CRMSF.ESCAPECHARS(DESCURRENCY              , "OUT") : Endif
  If DESPAYBY                  <> "" : DESPAYBY                  = func CRMSF.ESCAPECHARS(DESPAYBY                 , "OUT") : Endif
  If DESSALESREP               <> "" : DESSALESREP               = func CRMSF.ESCAPECHARS(DESSALESREP              , "OUT") : Endif
  If DESTAXRULE                <> "" : DESTAXRULE                = func CRMSF.ESCAPECHARS(DESTAXRULE               , "OUT") : Endif
  If SIGNEDSTATUS              <> "" : SIGNEDSTATUS              = func CRMSF.ESCAPECHARS(SIGNEDSTATUS             , "OUT") : Endif
  If ORDERSTATE                <> "" : ORDERSTATE                = func CRMSF.ESCAPECHARS(ORDERSTATE               , "OUT") : Endif
  If ALLOCATIONSTATUS          <> "" : ALLOCATIONSTATUS          = func CRMSF.ESCAPECHARS(ALLOCATIONSTATUS         , "OUT") : Endif
  If HOLDSTATUS                <> "" : HOLDSTATUS                = func CRMSF.ESCAPECHARS(HOLDSTATUS               , "OUT") : Endif
  If CREDITSTATUS              <> "" : CREDITSTATUS              = func CRMSF.ESCAPECHARS(CREDITSTATUS             , "OUT") : Endif
  If DELIVERYSTATUS            <> "" : DELIVERYSTATUS            = func CRMSF.ESCAPECHARS(DELIVERYSTATUS           , "OUT") : Endif
  If INVOICESTATUS             <> "" : INVOICESTATUS             = func CRMSF.ESCAPECHARS(INVOICESTATUS            , "OUT") : Endif
  If DESBILLTOCUSTOMER         <> "" : DESBILLTOCUSTOMER         = func CRMSF.ESCAPECHARS(DESBILLTOCUSTOMER        , "OUT") : Endif
  If DESCLOSINGREASON          <> "" : DESCLOSINGREASON          = func CRMSF.ESCAPECHARS(DESCLOSINGREASON         , "OUT") : Endif
  If DELIVERYADDRESS           <> "" : DELIVERYADDRESS           = func CRMSF.ESCAPECHARS(DELIVERYADDRESS          , "OUT") : Endif
  If DELIVERYADDRESSCITY       <> "" : DELIVERYADDRESSCITY       = func CRMSF.ESCAPECHARS(DELIVERYADDRESSCITY      , "OUT") : Endif
  If DELIVERYADDRESSPROVINCE   <> "" : DELIVERYADDRESSPROVINCE   = func CRMSF.ESCAPECHARS(DELIVERYADDRESSPROVINCE  , "OUT") : Endif
  If DELIVERYADDRESSPOSTALCODE <> "" : DELIVERYADDRESSPOSTALCODE = func CRMSF.ESCAPECHARS(DELIVERYADDRESSPOSTALCODE, "OUT") : Endif
  If DESSHIPMENTSITE           <> "" : DESSHIPMENTSITE           = func CRMSF.ESCAPECHARS(DESSHIPMENTSITE          , "OUT") : Endif
  If DELIVERYPRIORITY          <> "" : DELIVERYPRIORITY          = func CRMSF.ESCAPECHARS(DELIVERYPRIORITY         , "OUT") : Endif
  If DESDELIVERYMODE           <> "" : DESDELIVERYMODE           = func CRMSF.ESCAPECHARS(DESDELIVERYMODE          , "OUT") : Endif
  If DESCARRIER                <> "" : DESCARRIER                = func CRMSF.ESCAPECHARS(DESCARRIER               , "OUT") : Endif

  If INVOICEELEMENTS
    For LOOP = 1 To INVOICEELEMENTS
      If INVOICEELEMENT(LOOP)     <> "" : INVOICEELEMENT(LOOP)     = func CRMSF.ESCAPECHARS(INVOICEELEMENT(LOOP)    , "OUT") : Endif
      If VALUETYPE(LOOP)          <> "" : VALUETYPE(LOOP)          = func CRMSF.ESCAPECHARS(VALUETYPE(LOOP)         , "OUT") : Endif
    Next
  Endif

  For LOOP = 1 To ORDERLINES
    If PRODUCT(LOOP)            <> "" : PRODUCT(LOOP)            = func CRMSF.ESCAPECHARS(PRODUCT(LOOP)           , "OUT") : Endif
    If PRODUCTDESCRIPTION(LOOP) <> "" : PRODUCTDESCRIPTION(LOOP) = func CRMSF.ESCAPECHARS(PRODUCTDESCRIPTION(LOOP), "OUT") : Endif
    If UNITOFMEASURE(LOOP)      <> "" : UNITOFMEASURE(LOOP)      = func CRMSF.ESCAPECHARS(UNITOFMEASURE(LOOP)     , "OUT") : Endif
  Next

  OK=fmet MYLOG.APUTLINE("Character conversion completed for sales order details",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

Return

####################################################################################################
$LOADLABELS

  LBLSOLDTO               = func AFNC.TEXTE(2951)
  LBLORDERNUMBER          = func AFNC.TEXTE(171)
  LBLORDERREFERENCE       = func AFNC.TEXTE(1371)
  LBLORDERTYPE            = func AFNC.TEXTE(680)
  LBLSALESSITE            = func AFNC.TEXTE(5060)
  LBLORDERDATE            = func AFNC.TEXTE(212)
  LBLCURRENCY             = func AFNC.TEXTE(323)
  LBLPAYBY                = func AFNC.TEXTE(6730)
  LBLSALESREP             = func AFNC.TEXTE(2929)
  LBLTAXRULE              = func AFNC.TEXTE(3673)
  LBLSIGNEDSTATUS         = func AFNC.TEXTE(2579)
  LBLORDERSTATE           = func AFNC.TEXTE(4549)
  LBLALLOCATIONSTATUS     = func AFNC.TEXTE(3104)
  LBLHOLDSTATUS           = func AFNC.TEXTE(48618)
  LBLCREDITSTATUS         = func AFNC.TEXTE(3107)
  LBLDELIVERYSTATUS       = func AFNC.TEXTE(23630)
  LBLINVOICESTATUS        = func AFNC.TEXTE(8498)
  LBLBILLTOCUSTOMER       = func AFNC.TEXTE(1647)
  LBLCLOSINGREASON        = func AFNC.TEXTE(19333)
  LBLDELIVERYADDRESS      = func AFNC.TEXTE(1719)
  LBLSHIPMENTSITE         = vireblc(func AFNC.TEXTE(3676),1)   # trailing spaces
  LBLDELIVERYPRIORITY     = vireblc(func AFNC.TEXTE(1724),1)   # trailing spaces
  LBLREQUIREDDELIVERYDATE = func AFNC.TEXTE(53195)
  LBLSHIPMENTDATE         = func AFNC.TEXTE(8571)
  LBLDELIVERYMODE         = func AFNC.TEXTE(1722)
  LBLCARRIER              = func AFNC.TEXTE(1434)
  LBLINVOICEELEMENT       = func AFNC.TEXTE(10942)
  LBLPERCENTORAMOUNT      = func AFNC.TEXTE(5476)
  LBLVALUETYPE            = func AFNC.TEXTE(1334)
  LBLPRODUCT              = func AFNC.TEXTE(3651)
  LBLPRODUCTDESCRIPTION   = func AFNC.TEXTE(282)
  LBLQUANTITY             = func AFNC.TEXTE(4620)
  LBLUNITOFMEASURE        = func AFNC.TEXTE(44634)
  LBLNETPRICE             = func AFNC.TEXTE(2619)

Return

####################################################################################################

