#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("ACM",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "INICRE"    : Gosub INICRE
 When "LIENS2"    : Gosub LIENS2
 When "FILGAUCHE" : Gosub FILGAUCHE
Endcase
Return

$FILGAUCHE
Local Char WCAR(20)
WCAR = CLELIG+"=1"
I = instr(1,CRITERE,WCAR)
If I
 CRITERE = left$(CRITERE,I-1)+CLELIG+"=0"+right$(CRITERE,I+len(WCAR))
Endif
Return

$INICRE
[F]COMTYP = [M]TYP+299
[F]COMIND = [M]COMIND(nolign-1)
Return

$LIENS2
[M]TYP = [F]COMTYP-299
Gosub GRISE_LNG
Return

$GRISE_LNG
If [M]TYP<>7
 [M]COMLEN = 0
 Affzo COMLEN
 Grizo COMLEN
Else
 Actzo COMLEN
Endif
Return

########################################
Subprog AS_COMLEN(VALEUR)
Variable Decimal VALEUR
If [M]TYP<>7 : mkstat = 1 : End : Endif
End

Subprog AS_TYP(VALEUR)
Variable Integer  VALEUR
For I=1 To len(mess(0,30,1))
 Case I
  When 2,3,4,7,8 : GMENLOC(I) = 0
  When Default   : GMENLOC(I) = 1
 Endcase
Next I
End

Subprog AM_TYP(VALEUR)
Variable Integer  VALEUR
[M]TYP = VALEUR
Gosub GRISE_LNG
End
