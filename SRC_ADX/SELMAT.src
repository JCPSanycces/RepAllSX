#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
Case ACTION
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "FIN_TABLE" : Gosub FIN_TABLE
Endcase
Return

$SEL_TABLE
Case GACTION
 When "SELEMP"
  Gosub SELEMP
 When "SELEMPACS"
  Gosub SELEMPACS
 When "SELEMPBOR"
  Gosub SELEMPBOR
 When "SELEMPCTR"
  Gosub SELEMPCTR
 When "SELCTRPSN"
  Gosub SELCTRPSN
Endcase
Return

$FIN_TABLE
#US1840 81085 01/08/2013 Selection DISPLAY columns and title
Case TABLE
 When "SELEMPCTR"
   If status = 28 : GCURLEG = [F:TMC]LEGID : GSOCIETE=[F:TMC]CPY : Endif
    Gosub BAS_CTRNUM From TOOLSHRLEG
 When "SELCTRPSN"
   If status = 28 & PARAM(7) <> [F:TMC]CTRNUM
      PARAM(7) = [F:TMC]CTRNUM
      GCURLEG = [F:TMC]LEGID : GSOCIETE=[F:TMC]CPY
   Endif
Endcase
#END US1840 81085
Return

$SELEMP
If clalev([F:ID])=0     : Local File EMPLOID   [ID]     : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]  : Endif
If clalev([F:ECT])=0    : Local File EMPCTR    [ECT]    : Endif
If clalev([F:FCY])=0    : Local File FACILITY  [FCY]    : Endif
If clalev([F:ACC])=0    : Local File ACCES     [ACC]    : Endif
If clalev([F:TMT])=0    : Local File TMPSELMAT [TMT]    : Endif

Local Char    SOC([V]GLONCPY) , SIT([V]GLONFCY) , SER([V]GLONSRV) , PRO([V]GLONPRF), POT([V]GLONPOT), JOT([V]GLONJOT)
Local Char    CRIT1(250), CRIT2(250)
Local Integer FLG    :#   0=All employees ; 1=only payroll employee ; 2=only time management employee
Local Char LEG (GLONADI)

Local Integer I
SOC = PARAM(1)
SIT = PARAM(2)
SER = PARAM(3)
PRO = PARAM(4)
FLG = val(PARAM(5))
LEG = PARAM(6)
POT = PARAM(7)
JOT = PARAM(8)

COL(1) = "[F:TMT]REFNUM"
COL(2) = "[F:TMT]NAM"
COL(3) = "[F:TMT]SRN"
COL(4) = "[F:TMT]CPY"
COL(5) = "[F:TMT]FCY"
COL(6) = "[F:TMT]LEGID"

TIT(1) = mess(1,10319,1)  : # Employee
TIT(2) = mess(20,159,1)   : # Name
TIT(3) = mess(69,10701,1) : # Surnam
TIT(4) = mess(2,45,1)     : # Company
TIT(5) = mess(3,45,1)     : # Site
TIT(6) = mess(218,107,1)  : # Legislation

TIT = mess(46,10702,1) : # Employees Selection
NBCOL = 6

If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
Link [ILEG] With [ACC]CODACC=GUSER;[F:ID]CODACS
&   As [LEMP]
CRIT1 = '[F:ILEG]ENAFLG=2 & ([F:ILEG]CODACS="" or [F:ACC]EXEC=2)'
CRIT2 = '1=1'

If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 CRIT1 -= "& find([F:ILEG]ETRFCY,GUSRFCY(1..GNBAUZ))"
Endif

If GUSRACS<>2
 CRIT1 -= "& find([F:ILEG]ETRSRV,GAUTSRV(1..GNBSERV))"
Endif

If SOC<>""
# CRIT1 -= '& [F:ILEG]LEGCPY="'+SOC+'"'
Local Integer I, K
Local Char    LIS_CPY(GLONCPY)(0..100)
  I=0 : Call CALC_GRPCPY(SOC, LIS_CPY, I) From TOOLSVAR
  If I>0 Then
    CRIT1 -= "& find([F:ILEG]LEGCPY,"
    For K=0 To I-1
      CRIT1 += "'"+LIS_CPY(K)+"'"
      If K<I-1 Then CRIT1 += "," : Endif
    Next
    CRIT1 += ")>0"
  Endif
Endif

If SIT<>""
# CRIT1 -= '& [F:ILEG]ETRFCY="'+SIT+'"'
 CRIT1 -= '& [F:ILEG]FCYID="'+SIT+'"'
Endif

If SER<>""
 CRIT1 -= '& [F:ILEG]ETRSRV="'+SER+'"'
Endif

If PRO<>""
 CRIT1 -= '& [F:ILEG]PROPRF="'+PRO+'"'
Endif

If LEG<>""
 CRIT1 -= "& [F:ILEG]LEGID='"+LEG+"'"
 HASTOCHECK=2
Endif

If FLG=1
 CRIT1 -= "& [F:ILEG]FLGPAY=2"
Endif

If FLG=2
 CRIT1 -= "& [F:ILEG]FLGTPS=2"
Endif

Local Integer HASTOCHECK : HASTOCHECK=1
If SOC="" & SIT="" & SER="" & PRO="" & LEG="" & GLEGFIL<>"" Then
  CRIT1 -= "& [F:ILEG]LEGID='"+GLEGFIL+"'"
  HASTOCHECK=2
Endif

If POT<>""
 CRIT2 -= '& [F:ILEG]POT="'+POT+'"'
Endif

If JOT<>""
 CRIT2 -= '& [F:ILEG]JOBPOT="'+JOT+'"'
Endif

DEFPAG = 1    :# To have page up and page down

#EXPSTART="[F:TMT]REFNUM>='"+VALEUR+"'"
#JOJAC - 2016-08-12 - X3PEOP-975 - START
#Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'REFNUM>="'+VALEUR+'"',"&") From GOBJSUB
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","","&") From GOBJSUB
#JOJAC - 2016-08-12 - X3PEOP-975 - END

Call DEBTRANS From GLOCK
Gosub TR1
Default File [F:TMT]
If GOK=0 : OK = 0 : Return : Endif

Return

$TR1
Local Integer OKENR
If dim(CRIT2)<0
  Local Char CRIT2(250)
  CRIT2="1=1"
Endif
If dim(CRITSUP)<0
  Local Char CRITSUP(250)
  CRITSUP="1=1"
Endif
Trbegin [TMT]
Delete [TMT] Where 1=1
Commit
Trbegin [TMT]
 For [LEMP]ECT0(1) Where evalue(CRIT1) & evalue(CRIT2) & evalue(CRITSUP)
  OKENR=2
  If HASTOCHECK=2 Then
    Look [F:TMT]TMT0=[F:ILEG]REFNUM
    If fstat=0 Then OKENR=1 : Endif
  Endif
#  If [F:ILEG]CTRDAT>date$ | ([F:ILEG]XITDAT<>[0/0/0] & [F:ILEG]XITDAT<date$) Then
#    OKENR=1
#  Endif
  If OKENR=2 Then
    [F:TMT]       = [F:ILEG]
    [F:TMT]CPY    = [F:ILEG]LEGCPY
    [F:TMT]FCY    = [F:ILEG]FCYID
    Write [TMT]
    If fstat
      GOK=0 : Call FSTA("TMT") From GLOCK : Break
    Endif
  Endif
 Next
 If GOK=0 : Rollback : Return : Endif
Commit
Return


$SELEMPACS
Local Char CRIT1(250)
If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
If clalev([F:TMT])=0  : Local File TMPSELMAT [TMT] : Endif
Link [ILEG] With [ACC]CODACC=GUSER;[F:ID]CODACS
&   As [LEMP]
TIT = mess(46,10702,1) : # Employee selection
NBCOL = 0
NBCOL +=1 : COL(NBCOL) = "REFNUM" : TIT(NBCOL) = mess(1,10319,1)  : # Matricule
NBCOL +=1 : COL(NBCOL) = "NAM"    : TIT(NBCOL) = mess(20,159,1)   : # Nom
NBCOL +=1 : COL(NBCOL) = "SRN"    : TIT(NBCOL) = mess(69,10701,1) : # Prénom
NBCOL +=1 : COL(NBCOL) = "CPY"    : TIT(NBCOL) = mess(2,45,1)     : # Société
NBCOL +=1 : COL(NBCOL) = "FCY"    : TIT(NBCOL) = mess(3,45,1)     : # Site
NBCOL +=1 : COL(NBCOL) = "LEGID"  : TIT(NBCOL) = mess(218,107,1)  : # Legislation

CRIT1  = '[F:ILEG]ENAFLG=2 & ([F:ILEG]CODACS="" or [F:ACC]EXEC=2)'
CRIT1 -= '& [F:ILEG]FLGNEWSAL<>2 & [F:ILEG]LEGID="'+GCURLEG+'"'
CRIT1 -= '& ([F:ILEG]CTRDAT=[31/12/2040] | ([F:ILEG]CTRDAT<=date$ & ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=date$)))'
#MABOS-02/11/2012-US918-population block in CTR6-The list starts at the RefNum seized
CRIT1 -= '& ([F:ILEG]REFNUM>="'+VALEUR+'" )'
DEFPAG = 1    :# To have page up and page down

Local Integer HASTOCHECK : HASTOCHECK=2
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=0 : OK = 0 : Return : Endif
Default File [TMT]
Return

#Select employees tacking "registry number range", "population" and "other criterion" filters into account.
$SELEMPBOR
If clalev([F:ID])=0     : Local File EMPLOID   [ID]     : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]  : Endif
If clalev([F:ECT])=0    : Local File EMPCTR    [ECT]    : Endif
If clalev([F:FCY])=0    : Local File FACILITY  [FCY]    : Endif
If clalev([F:ACC])=0    : Local File ACCES     [ACC]    : Endif
If clalev([F:TMT])=0    : Local File TMPSELMAT [TMT]    : Endif
If clalev([F:HRPOA])=0  : Local File POPULA    [HRPOA]  : Endif

Local Char    SOC([V]GLONCPY) , SIT([V]GLONFCY) , SER([V]GLONSRV) , PRO([V]GLONPRF), CRIT1(250)
Local Char    MATD([V]GLONEML) , MATF([V]GLONEML)
Local Char    POP([V]GLONPOP)
Local Integer FLG    :#   0=All employees ; 1=only payroll employee ; 2=only time management employee
Local Char LEG (GLONADI)
Local Integer I
Local Char CRIT2(250)
Local Char CRITSUP(250)

CRIT2="1=1"

SOC = PARAM(1)
SIT = PARAM(2)
SER = PARAM(3)
PRO = PARAM(4)
FLG = val(PARAM(5))
LEG = PARAM(6)
MATD =PARAM(7)
MATF =PARAM(8)
POP = PARAM(9)
CRITSUP = PARAM(10)
If CRITSUP="" : CRITSUP="1=1" : Endif

COL(1) = "[F:TMT]REFNUM"
COL(2) = "[F:TMT]NAM"
COL(3) = "[F:TMT]SRN"
COL(4) = "[F:TMT]CPY"
COL(5) = "[F:TMT]FCY"
COL(6) = "[F:TMT]LEGID"

TIT(1) = mess(1,10319,1)  : # Employee
TIT(2) = mess(20,159,1)   : # Name
TIT(3) = mess(69,10701,1) : # Surnam
TIT(4) = mess(2,45,1)     : # Company
TIT(5) = mess(3,45,1)     : # Site
TIT(6) = mess(218,107,1)  : # Legislation

TIT = mess(46,10702,1) : # Employees Selection
NBCOL = 6

If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
Link [ILEG] With [ACC]CODACC=GUSER;[F:ID]CODACS
&   As [LEMP]
CRIT1 = '[F:ILEG]ENAFLG=2 & ([F:ILEG]CODACS="" or [F:ACC]EXEC=2)'

If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 CRIT1 -= "& find([F:ILEG]ETRFCY,GUSRFCY(1..GNBAUZ))"
Endif

If GUSRACS<>2
 CRIT1 -= "& find([F:ILEG]ETRSRV,GAUTSRV(1..GNBSERV))"
Endif

If SOC<>""
Local Integer I, K
Local Char    LIS_CPY(GLONCPY)(0..100)
  I=0 : Call CALC_GRPCPY(SOC, LIS_CPY, I) From TOOLSVAR
  If I>0 Then
    CRIT1 -= "& find([F:ILEG]LEGCPY,"
    For K=0 To I-1
      CRIT1 += "'"+LIS_CPY(K)+"'"
      If K<I-1 Then CRIT1 += "," : Endif
    Next
    CRIT1 += ")>0"
  Endif
Endif

If SIT<>""
 CRIT1 -= '& [F:ILEG]FCYID="'+SIT+'"'
Endif

If SER<>""
 CRIT1 -= '& [F:ILEG]ETRSRV="'+SER+'"'
Endif

If PRO<>""
 CRIT1 -= '& [F:ILEG]PROPRF="'+PRO+'"'
Endif

Local Integer HASTOCHECK
HASTOCHECK=1

If LEG<>""
 CRIT1 -= "& [F:ILEG]LEGID='"+LEG+"'"
 HASTOCHECK=2
Elsif SOC="" & SIT="" & SER="" & PRO="" & GLEGFIL<>""
  CRIT1 -= "& [F:ILEG]LEGID='"+GLEGFIL+"'"
  HASTOCHECK=2
Endif

If FLG=1
 CRIT1 -= "& [F:ILEG]FLGPAY=2"
Endif

If FLG=2
 CRIT1 -= "& [F:ILEG]FLGTPS=2"
Endif

If MATD<>""
 CRIT2 -= '& [F:ILEG]REFNUM >="'+MATD+'"'
Endif

If MATF<>""
 CRIT2 -= '& [F:ILEG]REFNUM <="'+MATF+'"'
Endif

# DBA : Add MAXPOP because 100 isn't enought...
If POP<>""
  Local Integer MAXPOP
  Filter [HRPOA] Where COD=POP
  MAXPOP = min(rowcount([HRPOA]),65535)
  If dim(LIS_EMLPOP)<0 : Local Char LIS_EMLPOP(GLONEML)(1..MAXPOP) : Endif
  [L]I=1
  For [HRPOA]
    LIS_EMLPOP(I)=[HRPOA]REFNUM
    I+=1
  Next
  Filter [HRPOA]
  If  LIS_EMLPOP(1)<>""
    CRIT2 -= '& find([F:ILEG]REFNUM,LIS_EMLPOP)'
  Endif
Endif

DEFPAG = 1    :# To have page up and page down

Call DEBTRANS From GLOCK
Gosub TR1
Default File [F:TMT]
If GOK=0 : OK = 0 : Return : Endif

Return

#US1840 81085 01/08/2013 Selection DISPLAY columns and title
$START_SELEMPCTR
If clalev([F:TMC])=0    : Local File TMPSELCTR [TMC]    : Endif
If clalev([F:ILEG])=0   : Local File EMPLOLEG [ILEG] : Endif
If clalev([F:ACC])=0    : Local File ACCES   [ACC]  : Endif

Local Char    SOC([V]GLONCPY) , SIT([V]GLONFCY) , SER([V]GLONSRV) , PRO([V]GLONPRF), CRIT1(250)
Local Integer FLG    :#   0=All employees ; 1=only payroll employee ; 2=only time management employee
Local Char    LEG([V]GLONADI) , WREFNUM([V]GLONEML) , WCTRNUM([V]GLONHRCTR)
Local Integer ACT_ZONE :# 0=no action, 1=AV_CTRNUM, 2=AM_REFNUM
Local Integer I, K
Local Char    LIS_CPY(GLONCPY)(0..100)
Local Integer WI
Local Char    WACTION(30), TEMP(10)

[L]SOC = PARAM(1)
[L]SIT = PARAM(2)
[L]SER = PARAM(3)
[L]PRO = PARAM(4)
[L]FLG = val(PARAM(5))
[L]LEG = PARAM(6)
[L]WACTION = PARAM(8)
[L]ACT_ZONE = 0
WI=instr(0, [L]WACTION,"_")

If(WI)
 TEMP=left$([L]WACTION,WI-1)
 Case TEMP
  When "AAS":
      [L]ACT_ZONE = 1
  When "AAM"
      [L]ACT_ZONE = 2
  When "AB2"
      [L]ACT_ZONE = 2
  When Default:
 Endcase
Endif

Case [L]ACT_ZONE
 When 1 :
    [L]WREFNUM = PARAM(7)
    [L]WCTRNUM = VALEUR
 When 2 :
   [L]WREFNUM = VALEUR
   [L]WCTRNUM = PARAM(7)

When Default:
    [L]WREFNUM = PARAM(7)
    [L]WCTRNUM = VALEUR
Endcase

NBCOL = 0
# Si en avant-modif de CTRNUM le champ est renseigné on n'ouvre pas le fenêtre de sélection
If ([L]ACT_ZONE = 1 & [L]WCTRNUM <> "" ) : End : Endif

#If GUSER='MABON' Dbgaff Endif
Raz TIT
#NBCOL +=1 : COL(NBCOL) = "[F:TMC]REFNUM" : Call TEXTE(10793,TIT(NBCOL)) From OBJDIV    : # Matricule
NBCOL +=1 : COL(NBCOL) = "[F:TMC]CTRNUM" : Call TEXTE(5481,TIT(NBCOL)) From OBJDIV     : # Contrat
NBCOL +=1 : COL(NBCOL) = "[F:TMC]CTRDAT" : Call TEXTE(212,TIT(NBCOL)) From OBJDIV      : # Date
NBCOL +=1 : COL(NBCOL) = "[F:TMC]XITDAT" : Call TEXTE(7830,TIT(NBCOL)) From OBJDIV     : # Date sortie
NBCOL +=1 : COL(NBCOL) = "[F:TMC]CPY"    : Call TEXTE(1343,TIT(NBCOL)) From OBJDIV     : # Société
NBCOL +=1 : COL(NBCOL) = "[F:TMC]FCY"    : Call TEXTE(1344,TIT(NBCOL)) From OBJDIV     : # Site
NBCOL +=1 : COL(NBCOL) = "[F:TMC]LEGID"  : Call TEXTE(26213,TIT(NBCOL)) From OBJDIV    : # Législation
NBCOL +=1 : COL(NBCOL) = "[F:TMC]ETRSRV" : Call TEXTE(18735,TIT(NBCOL)) From OBJDIV    : # Service
NBCOL +=1 : COL(NBCOL) = "[F:TMC]PROPRF" : Call TEXTE(8750,TIT(NBCOL)) From OBJDIV     : # Profil
NBCOL +=1 : COL(NBCOL) = "[F:TMC]JOBPOT" : Call TEXTE(45853,TIT(NBCOL)) From OBJDIV    : # Emploi type
NBCOL +=1 : COL(NBCOL) = "[F:TMC]POT"    : Call TEXTE(22321,TIT(NBCOL)) From OBJDIV    : # Poste
TIT(0) = mess(151,10702,1) : # Choix du contrat
Link [ILEG] With [HRCTR]CTR0=[F:ILEG]REFNUM;[F:ILEG]CTRNUM;[F:ILEG]CTRDAT
&   As [LCTR]

START = "[F:TMC]CTRNUM"
If ([L]ACT_ZONE = 2) : START = "[F:TMC]REFNUM" : Endif
CRIT1 = "CTRNUM<>''"
If WREFNUM <> "" : CRIT1 -= "& REFNUM='"+WREFNUM+"'" Endif

If SOC<>""
  I=0 : Call CALC_GRPCPY(SOC, LIS_CPY, I) From TOOLSVAR
  If I>0 Then
    CRIT1 -= "& find([F:ILEG]LEGCPY,"
    For K=0 To I-1
      CRIT1 += "'"+LIS_CPY(K)+"'"
      If K<I-1 Then CRIT1 += "," : Endif
    Next
    CRIT1 += ")>0"
  Endif
Endif

If SIT<>""
 CRIT1 -= '& [F:ILEG]FCYID="'+SIT+'"'
Endif

If SER<>""
 CRIT1 -= '& [F:ILEG]ETRSRV="'+SER+'"'
Endif

If PRO<>""
 CRIT1 -= '& [F:ILEG]PROPRF="'+PRO+'"'
Endif

If LEG<>""
 CRIT1 -= "& [F:ILEG]LEGID='"+LEG+"'"
Endif

If FLG=1
 CRIT1 -= "& [F:ILEG]FLGPAY=2"
Endif

If FLG=2
 CRIT1 -= "& [F:ILEG]FLGTPS=2"
Endif

If [L]SOC="" & [L]SIT="" & [L]SER="" & [L]PRO="" & [L]LEG="" & GLEGFIL<>"" Then
  CRIT1 -= "& [F:ILEG]LEGID='"+GLEGFIL+"'"
Endif

DEFPAG = 1    :# To have page up and page down

#EXPSTART="[F:TMC]REFNUM>='"+VALEUR+"'"
If WREFNUM <> "" :Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'REFNUM="'+WREFNUM+'"',"&") From GOBJSUB : Endif

If(PARAM(9)<>"")
  If CRITERE<>"" : CRITERE-="&" : Endif
  CRITERE-=PARAM(9)
Else
  If CRITERE<>"" : CRITERE-="&" : Endif
  CRITERE-="[F:ILEG]CTRDAT<=date$ & ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=date$)"
Endif
If(PARAM(10)<>"")
  If CRITERE<>"" : CRITERE-="&" : Endif
  CRITERE-=PARAM(10)
Endif
If PARAM(11)<>"" Then
   ORDRE="[F:HRCTR]REFNUM"
Endif

Call DEBTRANS From GLOCK
Return

#US1840 81085 01/08/2013 Selection DISPLAY columns and title
#**
#* Save value field CTRNUM in global GW_VALCTR
#*
#* @param WVAL : value field CTRNUM
#*!
Subprog INI_VALCTR(WVAL)
Value Char WVAL()
If(dim(GW_VALCTR)<0) : Global Char GW_VALCTR(GLONHRCTR) : Endif
[V]GW_VALCTR=[L]WVAL
End
Subprog KILL_VALCTR()
If(dim(GW_VALCTR)>0) : Kill GW_VALCTR : Endif
End
#US1840 81085 01/08/2013 Selection DISPLAY columns and title
$END_SELEMPCTR
Default File [F:TMC]
If GOK=0 : OK = 0 : Return : Endif
Filter [F:TMC] Where CREUSR=GUSER
If rowcount([F:TMC]) = 1
  NBCOL = 0
  Case [L]ACT_ZONE
   When 1 :
      VALEUR = [F:TMC]CTRNUM
   When 2 :
      PARAM(7) = [F:TMC]CTRNUM
   When Default:
      VALEUR = [F:TMC]CTRNUM
  Endcase
Endif
#SBA US1840 81085 20/08/2013 : suppression du filter car la boite de sélection utilise les résultats de la table et elle est déclenchée après.
#Filter [F:TMC]
Return

#US1840 81085 01/08/2013 Selection DISPLAY columns and title
$SELEMPCTR
Gosub START_SELEMPCTR
Gosub TR1_CTR
Gosub END_SELEMPCTR
Return

#US1840 81085 01/08/2013 Selection DISPLAY columns and title
$SELCTRPSN
Gosub START_SELEMPCTR
Gosub TR1_CTR_PSN
Gosub END_SELEMPCTR
Return

#US1840 81085 01/08/2013 Selection DISPLAY columns and title
$TR1_CTR
Local Integer OKENR
If dim(CRIT2)<0
  Local Char CRIT2(250)
  CRIT2="1=1"
Endif
If dim(CRITSUP)<0
  Local Char CRITSUP(250)
  CRITSUP="1=1"
Endif
# FQ81085 - 17/09/13 - Ajout CRITERE dans le filtre
If dim(CRITERE)<0
  Local Char CRITERE(250)
  CRITERE="1=1"
Endif
# Fin FQ81085
Trbegin [TMC]
Delete [TMC] Where 1=1 and CREUSR=GUSER
Commit
Trbegin [TMC]
# FQ81085 - 17/09/13 - Ajout CRITERE dans le filtre
For [F:ILEG]ECT0 Where evalue(CRIT1) & evalue(CRIT2) & evalue(CRITSUP) & evalue(CRITERE)
 If GUSRACS<>2
   If [F:ILEG]CODACS <> ""
    Read [F:ACC]CODACC = GUSER;[F:ILEG]CODACS
   Endif
 Endif
 If GUSRACS = 2 | ( !fstat & ([F:ILEG]CODACS="" or [F:ACC]CONSUL=2) & (func DIVPAYE.AUTSRV([F:ILEG]ETRSRV)))
    [F:TMC]       = [F:ILEG]
    [F:TMC]CPY    = [F:ILEG]LEGCPY
    [F:TMC]FCY    = [F:ILEG]FCYID
    Write [TMC]
    If fstat
      GOK=0 : Call FSTA("TMC") From GLOCK : Break
    Endif
  Endif
Next
If GOK=0 : Rollback : Return : Endif
Commit
Return

#US1840 81085 01/08/2013 Selection DISPLAY columns and title
$TR1_CTR_PSN
Local Integer OKENR
If dim(CRIT2)<0
  Local Char CRIT2(250)
  CRIT2="1=1"
Endif
If dim(CRITSUP)<0
  Local Char CRITSUP(250)
  CRITSUP="1=1"
Endif
START = "[F:TMC]REFNUM"
Trbegin [TMC]
Delete [TMC] Where 1=1 and CREUSR=GUSER
Commit
Trbegin [TMC]
For [F:ILEG]ECT0 Where evalue(CRIT1) & evalue(CRIT2) & evalue(CRITSUP)
 [L]OKENR = 0
 For [PSN] Where CTRNUM=[F:ILEG]CTRNUM & BUL<>"" & NUMCER=""
  [L]OKENR = 2 : Break
 Next
 If [L]OKENR=2 Then
   If GUSRACS<>2
     If [F:ILEG]CODACS <> ""
      Read [F:ACC]CODACC = GUSER;[F:ILEG]CODACS
     Endif
   Endif
   If GUSRACS = 2 | ( !fstat & ([F:ILEG]CODACS="" or [F:ACC]CONSUL=2) & (func DIVPAYE.AUTSRV([F:ILEG]ETRSRV)))
    [F:TMC]       = [F:ILEG]
    [F:TMC]CPY    = [F:ILEG]LEGCPY
    [F:TMC]FCY    = [F:ILEG]FCYID
    Write [TMC]
    If fstat
      GOK=0 : Call FSTA("TMC") From GLOCK : Break
    Endif
   Endif
 Endif
Next
If GOK=0 : Rollback : Return : Endif
Commit
Return


#-----------------------------------------------------------
# List of spouses -> Selection of child's parents
# For each children, parent must be in the list of spouses
#     MABOS - 17/01/14 - FQ92313 US2312 : Several spouses
#-----------------------------------------------------------
$SELJNTNAM
Raz TEXTE,TEX,NBTEX
Local Integer WI
Local Char PAR(80)
For WI=1 To [M]NBRJNT
  [L]PAR = vireblc([M]SJNTNAM(WI-1)-[M]SJNTSRN(WI-1),2) :# MABOS-17/01/14-FQ92313 US2312
  If [L]PAR<>"" & (NBTEX=0 | !find([L]PAR,TEXTE(1..NBTEX)))
    NBTEX+=1
    TEX(NBTEX)=[L]PAR
    TEXTE(NBTEX)=[L]PAR
  Endif
Next
TIT = mess(18,100,1)
Return
#end MABOS-FQ92313-US2023

