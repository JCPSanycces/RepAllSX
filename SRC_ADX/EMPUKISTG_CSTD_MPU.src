#<AdxTL>@(#)0.0.0.0 $Revision$

#EMPUKISTG
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
  When "PROPVALUE"          : Gosub PROPVALUE
  When "EMPLOID_UPDATE"     : Gosub EMPLOID_UPDATE
Endcase
Return


$PROPVALUE
#(PPROPERTY,PVALUE,PLEG) - Parameters
Gosub PROPVALUE From PIHRMFAIR_FUNCTIONS
Return

$INIT_CURRCLASS
Local Integer EMPSTGINIT
Local Instance  I_EMPUKISTG  Using C_EMPUKISTG
I_EMPUKISTG  = NewInstance C_EMPUKISTG AllocGroup null
INITCLASS  = [V]CST_AOK
#INITCLASS  = fmet I_EMPUKISTG.AINIT()
Return

$WRITE_CURRCLASS
Local Integer WRITESTATUS,ERRHANDLE
#Invoke the creation process and handle the error if applicable
#We will always invoke creation here as it is the staging tables
#Before writing the values - we need to check for errors

#Add system properties / keys
I_EMPUKISTG.INTUID = VUNIQID

#Additional handling
#Control of fields or Legislation specific handling
Gosub CONTROL_FIELDS

##Handle possible errors - ERRHANLDE will be called before and during the AINSERT
#ERRHANDLE = func PIHRMFAIR_FUNCTIONS.HANDLE_EMPLOYEE_ERRORS_CLASS(I_EMPUKISTG,"Employment",1,"Validation","ERROR",VUNIQID,VLEG,VPROCESSID,I_EMPUKISTG.INTID,I_EMPUKISTG.REFNUM,ACTIVE_CLASS)

[L]WRITESTATUS = fmet I_EMPUKISTG.AINSERT()
If ([L]WRITESTATUS >= [V]CST_AERROR)
  ERRHANDLE = func PIHRMFAIR_FUNCTIONS.HANDLE_EMPLOYEE_ERRORS_CLASS(I_EMPUKISTG,"Employment",1,"Validation","ERROR",VUNIQID,VLEG,VPROCESSID,I_EMPUKISTG.INTID,I_EMPUKISTG.REFNUM,ACTIVE_CLASS)
Endif

Gosub FREE_CURRCLASS
Return

$FREE_CURRCLASS
FreeGroup I_EMPUKISTG
Return


$PROPVAL_INIT
Local Char ERROR_MSG(250)
Local Integer INVOKE_ERROR
PROPRETVAL = fmet I_EMPUKISTG.PROPVALUE(PROPERTY,PROPVAL,VLEG,ERROR_MSG)

##Handle the possible error - Add it as a warning and let the supervisor handle it on CRUD
#If ([L]PROPRETVAL >= [V]CST_AWARNING)
#  INVOKE_ERROR = fmet I_EMPUKISTG.ASETERROR(PROPERTY,ERROR_MSG,PROPRETVAL)
#Endif
Return

$CONTROL_FIELDS
Return

$CLASS_UPDATE
Local Integer READSTATUS,UPDSTATUS,AINITSTATUS,NUMREC,EMP_UPDFLG,NUMERR
Local Char ERRMSG(250)
Local File EMPUKISTG [IDUSG1]
For [IDUSG1]IDUSG1 Where INTUID = PINTUID
  Local Instance  I_EMPUKISTG_UPD  Using C_EMPUKISTG
  I_EMPUKISTG_UPD  = NewInstance C_EMPUKISTG AllocGroup null
  READSTATUS = fmet I_EMPUKISTG_UPD.AREAD([F:IDUSG1]REFNUM)
  #Test READSTATUS
  If [L]READSTATUS = [V]CST_AOK
    Gosub EMPLOID_UPDATE
    If [L]ARET_VALUE <>[V]CST_AOK
      [L]EMP_UPDFLG = [V]CST_AWARNING
      [L]NUMERR+=1
      Call GET_ERRORS(I_EMPUKIINS,ERRMSG)
    Else
      [L]NUMREC+=1
    Endif
  Endif
  FreeGroup I_EMPUKISTG_UPD
Next


#TODO: Create function - pass results back to main method
If [L]EMP_UPDFLG = [V]CST_AOK
  ASTATUS = fmet this.ASETERROR("","Employee UK records updated : "+num$(NUMREC),[V]CST_AINFO)
Else
  ASTATUS = fmet this.ASETERROR("","Employee UK records updated : "+num$(NUMREC)+ " , Errors found ; "+num$(NUMERR)-ERRMSG,[V]CST_AWARNING)
Endif
LogicClose File [IDUSG1]
Return

$EMPLOID_UPDATE
Local Integer READSTATUS,UPDSTATUS,WRITESTATUS,INITSTATUS

#This was set as a method on the class but removed and set as normal prog
#Setting the return value for the method
[L]ARET_VALUE = [V]CST_AWARNING
[L]INITSTATUS = [V]CST_AWARNING
[L]WRITESTATUS = [V]CST_AERROR

#Instantiate the employee class
Local Instance  I_EMPUKIINS Using C_EMPUKIINS
If (I_EMPUKIINS <> null) : FreeGroup I_EMPUKIINS : Endif
I_EMPUKIINS  = NewInstance C_EMPUKIINS AllocGroup null
READSTATUS = fmet I_EMPUKIINS.AREAD(I_EMPUKISTG_UPD.REFNUM)
#Test the read status to decide if the record must be updated or created
If READSTATUS = [V]CST_AOK
  #Record exist - Update
  Gosub UPDATE_FIELD From EMPUKIINS_CSTD
  [L]ARET_VALUE = UPDSTATUS
Else
  INITSTATUS    = fmet I_EMPUKIINS.AINIT()
  If INITSTATUS = [V]CST_AOK
    Gosub DUPLICATE From EMPUKIINS_CSTD
    [L]ARET_VALUE = WRITESTATUS
  Endif
Endif
Return

Subprog GET_ERRORS(WCONTAINER,VERRMSG)
Variable Char VERRMSG
Variable Instance WCONTAINER Using C_EMPUKIINS

Local Integer I
Local Char WTEXTE(50)

 VERRMSG = func LCCLIB.MAXMSG(WCONTAINER)
End

