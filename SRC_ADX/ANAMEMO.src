#<AdxTL>@(#)4.0.0.0 $Revision$
# Recherche des mémos existants sur des objets
# On les considère critiques au delà de NB_LIG_TB enregistrements dans la tabke
#
# Written by Dominique BOPP
# (C) ADONIX 2002
# This program is program which should not be used whithout written authorization of an official of ADONIX
# Normal use on a running ADONIX folder cannot be guaranteed
#

Local Char PARAM(30)(1..1) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ANAMEMO","ANAMEMO",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
 When "TERMINE" : Gosub TERMINE
Endcase
Return

$INIT
Local Integer MAXMEN : MAXMEN = 5000
Local Integer NB_LIG_TB,NB_LIG_WARN, NB_LIG_BIG,TOPTEN,PBL_DETECTE,ERR
Local Schar   TOPTEN_MEMO(200)(1..2000) 
Local Integer TOPTEN_NB(1..2000),TOPTEN_NUMLIG(1..2000)
Local Char    FIC_MEMO(40)(1..MAXMEN)
Local Char    ER_MSG(80), SV_GUSER(20),MSG_TRA(255), ER_TEX(100)
Local Schar   USR_MEMO(5)(1..MAXMEN),TBL_MEMO(20)(1..MAXMEN),NOM_MEMO(GLONAMM)(1..MAXMEN),CH_TMP(255)
Local Integer TYP_MEMO(1..MAXMEN)
Local Integer NB_MEMO,NB_LOC,NB_GLO,II,JJ,KK,OPERAT,ANDOR,NB_LIG,NB_STD

# Variables pour analyse des tables
Local Integer NUMFIC_COUR,LL,MM,MAXTB,MAXKEY
MAXTB=1500 : MAXKEY=20
Local Char FIC_COUR(12),OBJ_COUR(10),CLE_COUR(12)
Local Integer NB_IND(1..MAXTB),NB_SCLES(1..MAXTB,1..20)
Local Integer SI_HOMONY(1..MAXTB,1..MAXKEY)
Local Integer NB_COMP_LUS : # Composants de clés pour lecture
Local Char CHAINE2(255), CHAINE3(255)
Local Schar INDEX_TB(12)(1..MAXTB,1..MAXKEY)
Local Schar DESC_IND(12)(1..MAXTB,1..MAXKEY,1..16)
Local Schar TAB_FIC(12)(1..MAXTB)
Local Integer NTAB(1..MAXTB)
Local Schar CHAMPS_WHERE(12)(1..MAXTB,1..5)
Local Integer NB_CHAMPS_WHERE(1..MAXTB),IL,IM
Local Schar NOM_TABLE(100)(1..MAXTB)
# Variables utilisées pour la notation des clés
Local Integer NB_MATCH(1..MAXKEY), MAX_MATCH, CUR_MATCH

# Variables utiles pour les analyses syntaxiques
Local Char ALPHA(27) : ALPHA="ABCDEFGHIJKLMNOPQRSTUVWXYZ_"
Local Char ALPHAN(37) : ALPHAN=ALPHA+"0123456789"
Local Char SPACEN(37) : SPACEN=space$(len(ALPHAN))
Local Char ESPACES(100) : ESPACES=space$(100)
Return

$TERMINE
TRA = 1
Return

$EXEC
NB_LIG_BIG  = [M]NBLIGBIG
NB_LIG_TB   = [M]NBLIGTB
NB_LIG_WARN = [M]NBLIGWARN
#NB_LIG_BIG=50000 : NB_LIG_TB=20000 : NB_LIG_WARN=5000
#NB_LIG_BIG=100 : NB_LIG_TB=50 : NB_LIG_WARN=10

# On lit le répertoire des mémos par utilisateur et on décompose
 Call SYSTEME2("","lsadx -a "+nomap-"ETM sel","",NB_LOC,FIC_MEMO) From ORDSYS
 Raz KK,NB_STD
 For II=1 To NB_LOC
    If pat(FIC_MEMO(II),"?*_?*_?*")<>0
        NB_STD+=pat(FIC_MEMO(II),"?*_STD_?*")<>0
        KK+=1
        JJ=instr(1,FIC_MEMO(II),"_")
        USR_MEMO(KK)=left$(FIC_MEMO(II),JJ-1)
        CH_TMP=right$(FIC_MEMO(II),JJ+1)
        JJ=instr(1,CH_TMP,"_")
        TBL_MEMO(KK)=left$(CH_TMP,JJ-1)
        NOM_MEMO(KK)=right$(CH_TMP,JJ+1)
        TYP_MEMO(KK)=1
        If TBL_MEMO(KK)="" : KK -= 1 : Endif
    Endif
 Next II
 NB_LOC=KK

# On lit le répertoire des mémos globaux et on décompose
 Call SYSTEME2("","lsadx -a "+nomap-"ETM glo","",NB_GLO,FIC_MEMO) From ORDSYS
 For II=1 To NB_GLO
    If pat(FIC_MEMO(II),"?*_?*_?*")<>0
        NB_STD+=pat(FIC_MEMO(II),"?*_STD_?*")<>0
        KK+=1
        JJ=instr(1,FIC_MEMO(II),"_")
        USR_MEMO(KK)=left$(FIC_MEMO(II),JJ-1)
        CH_TMP=right$(FIC_MEMO(II),JJ+1)
        JJ=instr(1,CH_TMP,"_")
        TBL_MEMO(KK)=left$(CH_TMP,JJ-1)
        NOM_MEMO(KK)=right$(CH_TMP,JJ+1)
        TYP_MEMO(KK)=2
        If TBL_MEMO(KK)="" : KK -= 1 : Endif
    Endif
 Next II
 NB_GLO=KK-NB_LOC : # Pour info
 NB_MEMO=KK

# Tri par objet, puis par user, puis par code mémo
 Sorta NB_MEMO TBL_MEMO,USR_MEMO,TYP_MEMO, NOM_MEMO

# For II=1 To NB_MEMO
#  infbox "Mémo"-string$(TYP_MEMO(II)=2,"global")-NOM_MEMO(II)-"table"-TBL_MEMO(II)-"user"-USR_MEMO(II)
# Next II

# Boucle de lecture des mémos et analyse de table
Call OUVRE_TRACE(mess(115,115,1)-time$) From LECFIC : # Analyse des mémos
Local Mask ASELOBJ [ASL]
If clalev ([F:ATB])=0 : Local File ATABLE : Endif
If clalev ([F:ATI])=0 : Local File ATABIND : Endif
If clalev ([F:AOB])=0 : Local File AOBJET : Endif
If clalev ([F:ATX])=0 : Local File ATEXTE : Endif
If clalev ([F:ANX])=0 : Local File AINDEX : Endif
FIC_COUR="" : NUMFIC_COUR=0

Call ECR_TRACE(mess(116,115,1)-num$(NB_MEMO),0) From GESECRAN : # Nombre de mémos trouvés dans le dossier :
Call ECR_TRACE("---"-mess(117,115,1)-num$(NB_GLO),0) From GESECRAN         : # Dont globaux :
Call ECR_TRACE("---"-mess(118,115,1)-num$(NB_MEMO-NB_GLO),0) From GESECRAN : # Dont locaux :
Call ECR_TRACE("---"-mess(119,115,1)-num$(NB_STD),0) From GESECRAN         : # Dont standards : 
Call ECR_TRACE(mess(120,115,1),0) From GESECRAN               : # Options de test :
I = instr(1,mess(121,115,1),"#") : # Avertissement WARN si plus de # lignes dans la table
If !I : I = len(mess(121,115,1)) : Endif
Call ECR_TRACE("---"-left$(mess(121,115,1),I-1)+num$(NB_LIG_WARN)+right$(mess(121,115,1),I+1),0) From GESECRAN
I = instr(1,mess(122,115,1),"#") : # Problème de performance [PERF] si plus de # lignes dans la table
If !I : I = len(mess(122,115,1)) : Endif
Call ECR_TRACE("---"-left$(mess(122,115,1),I-1)+num$(NB_LIG_TB)+right$(mess(122,115,1),I+1),0) From GESECRAN
I = instr(1,mess(123,115,1),"#") : # Problème critique [CRIT] si plus de # lignes dans la table
If !I : I = len(mess(123,115,1)) : Endif
Call ECR_TRACE("---"-left$(mess(123,115,1),I-1)+num$(NB_LIG_BIG)+right$(mess(123,115,1),I+1),0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(124,115,1),0) From GESECRAN : # Liste des problèmes trouvés"
Call ECR_TRACE("---------------------------",0) From GESECRAN

For II=1 To min(NB_MEMO,NB_MEMO)
    SV_GUSER=GUSER : GUSER=USR_MEMO(II)
    Call LECMEMO(NOM_MEMO(II),"[M:ASL]",
&                TBL_MEMO(II)+string$(TYP_MEMO(II)=1,"~sel")+string$(TYP_MEMO(II)=2,"~glo")) From GMEMO
    GUSER=SV_GUSER
    If FIC_COUR<>TBL_MEMO(II)
        FIC_COUR=TBL_MEMO(II) : Gosub CHARGE_FIC
        If fstat : Raz FIC_COUR : Goto SUITEBOUCLE : Endif

# Quel est l'objet qui gère cette table, et sur quel index ?
        Raz OBJ_COUR, CLE_COUR
        For [AOB] Where NOMFIC=FIC_COUR
            OBJ_COUR=[AOB]ABREV
            Break
        Next
        If OBJ_COUR<>""
            CLE_COUR=[AOB]SELCLE
            If CLE_COUR=""
                Read [ATI]NUMLIG(2)=FIC_COUR;1
                If fstat=0
                    CLE_COUR=[ATI]CODIND
                Endif
            Endif
        Endif
    Endif
    # Mémo local/Mémo global/Sur table
    MSG_TRA=format$("N0:3",TOPTEN+1)
    MSG_TRA-=string$(TYP_MEMO(II)=1,mess(125,115,1))-string$(TYP_MEMO(II)=2,mess(126,115,1))
    MSG_TRA-=USR_MEMO(II)+"."+NOM_MEMO(II)-mess(127,115,1)-TBL_MEMO(II)+"("+NOM_TABLE(NUMFIC_COUR)+") : "
    NB_CHAMPS_WHERE(II)=0
    PBL_DETECTE=0
    ERR=0 : Onerrgo ERR_OUVRE
    Local File =FIC_COUR [AAA_] : NB_LIG=nbrecord([AAA_]) : Close Local File [AAA_]
    Onerrgo : If ERR<>0 : NB_LIG=0 : Endif
    If NB_LIG>NB_LIG_BIG
        ER_MSG="   *** CRIT ("-num$(NB_LIG)-") ***"
    Elsif NB_LIG>NB_LIG_TB
        ER_MSG="   *** PERF ("-num$(NB_LIG)-") ***"
    Elsif NB_LIG>NB_LIG_WARN
        ER_MSG="   *** WARN ("-num$(NB_LIG)-") ***"
    Else
        Goto SUITEBOUCLE
    Endif
    If [M:ASL]EXP1<>""
        If MSG_TRA<>"" : Call ECR_TRACE(MSG_TRA,0) From GESECRAN : Gosub CLASSE : Endif
        # Sélection sur expression
        Call ECR_TRACE(ER_MSG-mess(128,115,1)-":"-vireblc(format$("KT:200X",[M:ASL]EXP1),2),0) From GESECRAN
    Endif
    For JJ=1 To 5
        NTAB(II)=0
        CHAINE2=evalue("[M:ASL]FLD"+num$(JJ))
        CHAINE3=evalue("[M:ASL]TBL"+num$(JJ))
        Break CHAINE3="" or CHAINE2=""
        NB_CHAMPS_WHERE(II)+=1
        CHAMPS_WHERE(II,NB_CHAMPS_WHERE(II))=CHAINE2
        OPERAT=evalue("[M:ASL]OPE"+num$(JJ))
        If JJ>=2 : ANDOR=evalue("[M:ASL]ANDOR"+num$(JJ)) : Endif
        If find(OPERAT,3,8)
            If MSG_TRA<>"" : Call ECR_TRACE(MSG_TRA,0) From GESECRAN : Gosub CLASSE : Endif
            I = instr(1,mess(129,115,1),"#") : # Opérateur # sur champ
            If !I : I = len(mess(129,115,1)) : Endif
            ER_TEX = ER_MSG-left$(mess(129,115,1),I-1)+'"'+mess(OPERAT,55,1)+'"'+right$(mess(129,115,1),I+1)
            ER_TEX -= CHAINE2
            Call ECR_TRACE(ER_TEX,0) From GESECRAN
        Endif
        If ANDOR=2
            If MSG_TRA<>"" : Call ECR_TRACE(MSG_TRA,0) From GESECRAN : Gosub CLASSE : Endif
            Call ECR_TRACE(ER_MSG-mess(130,115,1),0) From GESECRAN : # Opérateur 'ou' entre deux conditions
        Endif
        If CHAINE3<>TBL_MEMO(II)
            If MSG_TRA<>"" : Call ECR_TRACE(MSG_TRA,0) From GESECRAN : Gosub CLASSE : Endif
            # Plusieurs tables dans le mémo, vérifier la requête
            Call ECR_TRACE(ER_MSG-mess(131,115,1),0) From GESECRAN
            NTAB(II)=1
            If find(CHAINE3,TAB_FIC(1..NUMFIC_COUR))=0
                FIC_COUR=CHAINE3 : Gosub CHARGE_FIC
            Endif
        Endif
    Next JJ

    # Recherche de l'index le plus pertinent dans le cas simple pour le moment
    If NTAB(II)=0 & NB_CHAMPS_WHERE(II)>0

        For IL=1 To NB_IND(NUMFIC_COUR)
            NB_MATCH(IL)=0
            For IM=1 To NB_SCLES(NUMFIC_COUR,IL)
                If find(DESC_IND(NUMFIC_COUR,IL,IM),CHAMPS_WHERE(II,1..NB_CHAMPS_WHERE(II)))
                    NB_MATCH(IL)+=1
                Else
                    Break
                Endif
            Next IM
        Next IL

        MAX_MATCH=max(NB_MATCH(1..IL-1)) : # Meilleure clé
        IL=find(MAX_MATCH,NB_MATCH(1..IL-1)) : # Position de cette clé

        # Quelle clé est utilisée ?
        IM=find(CLE_COUR,INDEX_TB(NUMFIC_COUR,1..NB_IND(NUMFIC_COUR)))
        If IM : CUR_MATCH=NB_MATCH(IM) : Else CUR_MATCH=0 : Endif

        If CUR_MATCH<>MAX_MATCH
            If MSG_TRA<>"" : Call ECR_TRACE(MSG_TRA,0) From GESECRAN : Gosub CLASSE : Endif
            # La clé de tri de la liste gauche # est différente de la clé de filtrage
            I = instr(1,mess(132,115,1),"#")
            If !I : I = len(mess(132,115,1)) : Endif
            ER_TEX = ER_MSG-left$(mess(132,115,1),I-1)+'("'+CLE_COUR+'")'+right$(mess(132,115,1),I+1)
            ER_TEX -= '('+INDEX_TB(NUMFIC_COUR,IL)+')'
            Call ECR_TRACE(ER_TEX,0) From GESECRAN
        Elsif CUR_MATCH=0
            If MSG_TRA<>"" : Call ECR_TRACE(MSG_TRA,0) From GESECRAN : Gosub CLASSE : Endif
            ER_TEX = ER_MSG-mess(133,115,1)+" " : # Pas d'index adapté au filtre sur le champ
            For JJ=1 To NB_CHAMPS_WHERE(II)
                ER_TEX += CHAMPS_WHERE(II,JJ)+string$(JJ<>NB_CHAMPS_WHERE(II),";")
            Next JJ
            Call ECR_TRACE(ER_TEX,0) From GESECRAN
            Call ECR_TRACE(mess(134,115,1),0) From GESECRAN : # Problème de performance
        Endif
    Endif
    Gosub SETCLASSE
$SUITEBOUCLE
Next II
# Classement des problèmes par ordre de gravité décroissante
Call ECR_TRACE("\"+mess(135,115,1)+"\"+string$(80,"-"),0) From GESECRAN
Sorta TOPTEN TOPTEN_NB,TOPTEN_MEMO,TOPTEN_NUMLIG
For II=TOPTEN To 1 Step -1
 Call ECR_TRACE(format$("N0:3",TOPTEN_NUMLIG(II))-TOPTEN_MEMO(II),0) From GESECRAN
Next
# Fin de l'analyse : # problèmes trouvés
Call ECR_TRACE("\"+mess(136,115,1)-num$(TOPTEN)-mess(137,115,1),0) From GESECRAN
Return



# Chargement des caractéristiques de chaque table

# Chargement des caractéristiques d'un fichier
$CHARGE_FIC
 NUMFIC_COUR+=1
 TAB_FIC(NUMFIC_COUR)=FIC_COUR
 Read [ATB]CODFIC=FIC_COUR
 If  fstat : Return : Endif
 NB_IND(NUMFIC_COUR)=0
 Read [ATX]NUMERO=GLANGUE;[ATB]INTITFIC
 NOM_TABLE(NUMFIC_COUR)=[ATX]TEXTE

# Index standards
 LL=0
 For [ATI]CODIND Where CODFIC=[ATB]CODFIC
    LL+=1
    INDEX_TB(NUMFIC_COUR,LL)=[ATI]CODIND
    CHAINE3=right$(vireblc([ATI]DESCRIPT,0),1+(find(left$(vireblc([ATI]DESCRIPT,0),1),"+","-")<>0))
    MM=1
    Repeat
        DESC_IND(NUMFIC_COUR,LL,MM)=
&         vireblc(left$(CHAINE3,len(CHAINE3)-len(vireblc(ctrans(CHAINE3,ALPHAN+"()",SPACEN+"  "),0))),1)
        CHAINE3=vireblc(right$(CHAINE3,
&                               1+len(CHAINE3)-len(vireblc(ctrans(CHAINE3,ALPHAN+"()",SPACEN+"  "),0))+1),0)
        MM+=1
    Until CHAINE3=""
    NB_SCLES(NUMFIC_COUR,LL)=MM-1
    SI_HOMONY(NUMFIC_COUR,LL)=[ATI]HOMONYM
Next

# Index d'optimisation
 For [ANX]ANX1 Where TABLE=[ATB]CODFIC & FLACT=2
    LL+=1
    INDEX_TB(NUMFIC_COUR,LL)=[ANX]CODIND
    CHAINE3=right$(vireblc([ANX]DESCRIPT,0),1+(find(left$(vireblc([ANX]DESCRIPT,0),1),"+","-")<>0))
    MM=1
    Repeat
        DESC_IND(NUMFIC_COUR,LL,MM)=
&         vireblc(left$(CHAINE3,len(CHAINE3)-len(vireblc(ctrans(CHAINE3,ALPHAN+"()",SPACEN+"  "),0))),1)
        CHAINE3=vireblc(right$(CHAINE3,
&                               1+len(CHAINE3)-len(vireblc(ctrans(CHAINE3,ALPHAN+"()",SPACEN+"  "),0))+1),0)
        MM+=1
    Until CHAINE3=""
    NB_SCLES(NUMFIC_COUR,LL)=MM-1
    SI_HOMONY(NUMFIC_COUR,LL)=2
Next
NB_IND(NUMFIC_COUR)=LL

Return


$CLASSE
TOPTEN+=1 : TOPTEN_NUMLIG(TOPTEN)=TOPTEN
PBL_DETECTE=TOPTEN
MSG_TRA=""
Return

$SETCLASSE
If PBL_DETECTE=0 : Return : Endif
TOPTEN_MEMO(TOPTEN)  = USR_MEMO(II)+"."+NOM_MEMO(II)+"/"+TBL_MEMO(II)
TOPTEN_MEMO(TOPTEN) += string$(TYP_MEMO(II)=2," "+mess(138,115,1)+" ")     : # global
TOPTEN_MEMO(TOPTEN) += string$(NOM_MEMO(II)='STD'," "+mess(139,115,1)+" ") : # standard
TOPTEN_MEMO(TOPTEN) -= num$(NB_LIG)-mess(140,115,1)                        : # lignes
TOPTEN_MEMO(TOPTEN) -=mess(141,115,1)-"("                                  : # filtre sur champ
For JJ=1 To NB_CHAMPS_WHERE(II)
    TOPTEN_MEMO(TOPTEN) += string$(JJ>1,",")+CHAMPS_WHERE(II,JJ)
Next JJ
TOPTEN_MEMO(TOPTEN)+=")"
If [M:ASL]EXP1<>""
    TOPTEN_MEMO(TOPTEN) += " ["+vireblc(format$('KT:200X',[M:ASL]EXP1),2)+"]"
Endif

TOPTEN_NB(TOPTEN)=NB_LIG+10000000*(TYP_MEMO(II)=2)+20000000*(NOM_MEMO(II)='STD')
MSG_TRA=""
Return

$ERR_OUVRE
ERR=1
Resume

