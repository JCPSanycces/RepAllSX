#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# X3-100003 - Clustered index improvement
# Initialize the default clustered index and clustered index activated columns
########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
    If clalev([F:ADS])=0 Local File ADOSSIER [ADS] : Endif
    If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTI Testing") From LECFIC
    Call MAJ_UTISUP201807001(WDOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif

Close Local File

End

########################################################################
# Executed during integration of patches from EXE patch element type
########################################################################

Subprog PATCH(DOSSIER)

Value Char DOSSIER

# Do not execute in GDOSX3 exception being GADONIX being set (SCM)
#If [L]DOSSIER = GDOSX3 and GADONIX <> 2 Then
#    End
#Endif

#Open the folder table and read the current record - you don't need to do this in UTI_MOUL because it will be done for you
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

# Check that all tables exist and are not views
If !func CHECK_TABLES([L]DOSSIER) Then
    End
Endif

# Perform the updates
Call MAJ_UTISUP201807001(DOSSIER)
End

#######################################################################
# Executed during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (DOSSIER)
Value Char DOSSIER

# Do not execute in GDOSX3 exception being GADONIX being set (SCM)
#If [L]DOSSIER = GDOSX3 and GADONIX <> 2 Then
#    End
#Endif

# Check that the main tables exist and is not a view
If !func CHECK_TABLES([L]DOSSIER) Then
    End
Endif

# Perform the updates
Call MAJ_UTISUP201807001(DOSSIER)

End

########################################################################
# Check for the existence of every table needed
# Verify that the tables are not a view - indicates historic folder
# If any fail this check, do not run the script
########################################################################
Funprog CHECK_TABLES(IDOSSIER)
Value Char IDOSSIER

# Check that the main tables exist and is not a view
If !func TABLE_CHECK([L]IDOSSIER,"ATABLE") Then
    End 0
Endif
If !func TABLE_CHECK([L]IDOSSIER,"ATABIND") Then
    End 0
Endif

End 1

Funprog TABLE_CHECK(IDOSSIER, ICODFIC)

Value Char IDOSSIER
Value Char ICODFIC

If filinfo(filpath("FIL",ICODFIC,"fde",IDOSSIER),0)<=0 : End 0 : Endif
If func DOSVUE.ISVIEW(IDOSSIER,ICODFIC) : End 0 : Endif

End 1

########################################################################

# This subprogram will perform the updates!

########################################################################

Subprog MAJ_UTISUP201807001(DOSSIER)
Value Char DOSSIER()

Local Integer KOUNT, DEFEXISTS, CUSEXISTS

Call ECR_TIME("UTISUP201807001 : Start of process on : " - DOSSIER) From DOSSUB  #Display start message with time to the log

#----- Open tables using the folder passed in-----#
Local File =DOSSIER+".ATABLE"  [UATB]
Local File =DOSSIER+".ATABIND" [UATI]

Trbegin [F:UATB], [F:UATI]

For [F:UATB] Where ORDINDSTA=0

      Raz DEFEXISTS, CUSEXISTS

      Filter [F:UATI] Where CODFIC=[F:UATB]CODFIC Order By NUMLIG Asc

      For [F:UATI]

        #Does customer have an index set
        If [F:UATI]ORDIND=2
          CUSEXISTS=1
        Endif

        #Is there a default already
        If [F:UATI]DEFORDIND=2
          DEFEXISTS=1
        Else
          #Initialize if necessary
          If [F:UATI]DEFORDIND=0
            [F:UATI]DEFORDIND=1
            Rewrite [F:UATI]
          Endif
        Endif
      Next

      #If a default clustered index was not set then set the default to the first index
      If !DEFEXISTS
        Read [F:UATI] First
        If fstat=0
          [F:UATI]DEFORDIND=2
          Rewrite [F:UATI]
        Endif
      Endif

      #If the customer already uses clustered indexes then set the activated column
      If CUSEXISTS & [F:ADS]TYPDBA=2
        [F:UATB]ORDINDSTA=2
      Else
        [F:UATB]ORDINDSTA=1
      Endif
      Rewrite [F:UATB]
      If fstat<>[V]CST_AOK
        Call ERREUR("ATABLE", 2) From DOSDIC
      Else
        KOUNT+=1
      Endif
Next

Commit

#Display how many records were updated
Call ECR_TRACE("UTISUP201807001 :"-num$(KOUNT)-"records were processed",0) From GESECRAN

#Close tables
Close Local File [UATB]
Close Local File [UATI]

#Display an ending message with time to the log
Call ECR_TIME("UTISUP201807001 : End of process on :"-DOSSIER) From DOSSUB

End

