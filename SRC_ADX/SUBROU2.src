Subprog C_WORMAXQTY(VALEUR)
Variable Decimal  VALEUR
If [M:ROU2]WORMINQTY <> 0 & VALEUR < [M:ROU2]WORMINQTY
   GMESSAGE=mess(24,193,1) : mkstat=2
Endif
End

########################################################################

Subprog AV_ITMUOM(VALEUR)
Variable Char     VALEUR 
If [M:ROU0]ITMREF <> ""
   If clalev([ITM])=0 : Local File ITMMASTER [ITM] : Endif   
   Read [ITM]ITM0=[M:ROU0]ITMREF
   If ! fstat
      VALEUR=[F:ITM]STU
      [M:ROU2]XMINUOM=VALEUR
      [M:ROU2]XMAXUOM=VALEUR
      [M:ROU2]XWORUOM=VALEUR
      If !GIMPORT : Affzo [ROU2]XMINUOM, XMAXUOM, XWORUOM : Endif
   Endif
Endif
End
