#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion objet MHR
Raz GPILOBJ
Call OBJET("MHR",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Etiquette ajoutée par le superviseur (Objet MHR) 25/02/2009 13:36:13 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "INICRE"      : Gosub INICRE
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "ANNULE"      : Gosub ANNULE
 When "MODIF"       : Gosub MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "RAZDUP"      : [M:MHR0]FLGCLO=1 : Affzo [M:MHR0]FLGCLO
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "FERME"       : Gosub FERME
Endcase
Return


#####################################
$OUVRE
If clalev ([F:MHR])=0 : Local File MSHYPRUB  [MHR] : Endif
If clalev ([F:MSR])=0 : Local File MSRUB     [MSR] : Endif
If clalev ([F:BCB])=0 : Local File BCLOB     [BCB] : Endif
If clalev ([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
If clalev ([F:MCL])=0 : Local File MSSCENAL  [MCL] : Endif
If clalev ([F:MCH])=0 : Local File MSSCENAH  [MCH] : Endif
If clalev ([F:CPY])=0 : Local File COMPANY   [CPY] : Endif

Local Char    COMPTEUR(GLONANM)
Local Integer STAT

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only
Return

#####################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#####################################
$SETBOUT
If GREP<>"" | !VERROU | [M:MHR0]FLGCLO=2
 Call VIREBOUT (CHAINE,"AH") From GOBJET
Endif
If [M:MHR0]FLGCLO=2
 Call VIREBOUT (CHAINE,"M") From GOBJET
Endif
Return

#####################################
$LIENS
# On décoche Définitif si l'hypothèse n'est stockée dans aucun scénario définitif
Link [MCL] With [MCH]MCH0=[MCL]COD
& As [LMC]
& Where [MCH]FLGCLO=2 & [MCL]TYPHYP=2 & [MCL]CODHYP=[F:MHR]COD
Read [LMC]MCL1 First
If fstat
 [M:MHR0]FLGCLO = 1
 Call DEBTRANS From GLOCK
 Gosub TR_LIEN
Endif
Return

$TR_LIEN
Trbegin [MHR]
 [F:MHR]FLGCLO = 1
 Rewrite[MHR]
 If fstat : Call FSTA("MHR") From GLOCK : Rollback : Return : Endif
Commit
Return

#####################################
$LIENS2
Gosub CHARGE_STYLE
If [M:MHR0]FLGCLO=2
 Grizo [MHR0]5
Endif
#CMT commun à toutes les lignes
Default Mask [M:MHR0]
Call CHARGE_CMT ("SUBMHR",[F:MHR]COD,"","","")From SUBMSR
Return

#####################################
$CHARGE_STYLE
# Affzo avant le chgstl sinon ça marche pas !?!
Affzo [M:MHR0]20
For nolign=1 To [M:MHR0]NBLIG
 If [M:MHR0]ENAFLG1(nolign-1)=2
  Chgstl [M:MHR0]NBLIG(nolign-1) With "CONTRAT"
 Else
  Chgstl [M:MHR0]NBLIG(nolign-1) With ""
 Endif
Next
Return

#####################################
$INICRE
## Affectation du no de MSR
If [F:MHR]COD=""
 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(51,10722,1) : # Compteur MSR non défini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(9)
 Endif
 Call NUMERO(COMPTEUR,"",date$,"",[F:MHR]COD,STAT) From SUBANM
 If STAT
  # Erreur sur compteur
  GMESSAGE = mess(4,10702,1)-COMPTEUR
  GOK = 0 : Return
 Endif
 Call VERIF_CPT([F:MHR]COD,COMPTEUR)
 If GOK=0 : Return : Endif
 [M:MHR0]COD = [F:MHR]COD
 Affzo [M:MHR0]COD
Endif
Return

####################################
$MODIF
#CMT commun à toutes les lignes
Default Mask [M:MHR0]
Call SAUVE_CMT ("SUBMHR",[F:MHR]COD,"","","")From SUBMSR
Return

####################################
Subprog VERIF_CPT(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:MHRZ])=0 : Local File MSHYPRUB [MHRZ] : Endif
Read [MHRZ]MHR0=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",date$,"",NUM,STAT) From SUBANM
 Read [MHRZ]MHR0=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-COMPTEUR
 GOK = 0 : End
Endif
End

#####################################
$ANNULE
#CMT commun à toutes les lignes
Call ANNULE_CMT ("SUBMHR",[F:MHR]COD,"","","")From SUBMSR
Return

#####################################
## Changement de clé
$AP_CHANGE
Call APCHANGE(2,OCODE,NCODE)
Return

Subprog APCHANGE(TYPH,ANC,NOUV)
Value Integer TYPH
Value Char ANC, NOUV
Local Integer STAT, EXISTE
Local Char FICHIER(250)
If clalev([F:MHS])=0 : Local File MSHISTO  [MHS] : Endif
If clalev([F:MCL])=0 : Local File MSSCENAL [MCL] : Endif
If clalev([F:MHA])=0 : Local File MSVALEUR [MHA] : Endif
Call DEBTRANS From GLOCK
Gosub TR_CHANGE
End

$TR_CHANGE
Trbegin [MHS],[MCL],[MHA]
 Update [MHS] Where CODHYP=ANC & TYPHYP=TYPH With CODHYP=NOUV
 If fstat=1
   GOK=-1 : GLOCK="$MSHISTO" : Goto ROLL_TR_CHANGE
 Elsif fstat
  GOK=0 : Call FSTA("MHS") From GLOCK : Goto AB_TR_CHANGE
 Endif
 Update [MCL] Where CODHYP=ANC & TYPHYP=TYPH With CODHYP=NOUV
 If fstat=1
   GOK=-1 : GLOCK="$MSSCENAL" : Goto ROLL_TR_CHANGE
 Elsif fstat
  GOK=0 : Call FSTA("MCL") From GLOCK : Goto AB_TR_CHANGE
 Endif
 Update [MHA] Where CODHYP=ANC & TYPHYP=TYPH With CODHYP=NOUV
 If fstat=1
   GOK=-1 : GLOCK="$MSVALEUR" : Goto ROLL_TR_CHANGE
 Elsif fstat
  GOK=0 : Call FSTA("MHA") From GLOCK : Goto AB_TR_CHANGE
 Endif
 If find(TYPH,1,4,5,6)
  FICHIER = "WPMS"+num$(TYPH)+ANC
  Call EFFACE_ADX("",nomap,FICHIER,STAT) From ORDSYS
  If filinfo(filpath("TRT",FICHIER,"src",0),0)>=0
   Call EFFACE(filpath("TRT",FICHIER,"src",0),STAT) From ORDSYS
  Endif
  Case TYPH
   When 1 : Call GENHYPO(nomap,NOUV) From SUBMHV
   When 4 : Call GENHYPO(nomap,NOUV) From SUBMHE
   When 5 : Call GENHYPO(nomap,NOUV) From SUBMHX
   When 6 : Call GENHYPO(nomap,NOUV) From SUBMHC
  Endcase
 Endif
Commit
End

$AB_TR_CHANGE
Rollback
Return

$ROLL_TR_CHANGE
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CHANGE : Endif

#####################################
Subprog C_ENAFLG1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Chgstl NBLIG(nolign-1) With "CONTRAT"
Else
 Chgstl NBLIG(nolign-1) With ""
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran MHR0) 04/03/2010 16:53:52 (DBA)
######################################################################################
Subprog C_CODMSR(VALEUR)
Variable Char    VALEUR()
End


