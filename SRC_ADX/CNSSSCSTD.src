#<AdxTL>@(#)8.0.0.0 $Revision$
#Script has changed since US 71069/135
#########################################################################
# CNSSSCSTD : Consultation des lignes de commandes d'achat RBA 28/01/16 #
# ECRAN 1   : CONSSSC1                                                  #
# ECRAN 2   : CONSSSC2                                                  #
# ECRAN CRIT: CRITSSC                                                   #
#########################################################################
Local Char PARAM(20)(1..2)
PARAM(1) = "2204"
PARAM(2) = "GAL"
Call GCONSULT("SSC","",PARAM) From GCONSULT
End

#########################################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "SETBOUT"      : Gosub SETBOUT # Issue 116424
  #---------------------------#
  # Actions champs modèlisées #
  #---------------------------#
  When "AB1_NBLIG"    : Gosub AB1_NBLIG
  When Default
Endcase
Return

#########################################################################
$SETBOUT
  If [M]VCRTYPORI = 1 #Issue 116424
    #bornes grisées
    Diszo [M] VCRNUMORIDEB, VCRNUMORIFIN
  Else
    Actzo [M] VCRNUMORIDEB, VCRNUMORIFIN
  Endif
Return

#########################################################################
$AUTORIS
Return

#########################################################################
#   analyse paramètres, initialisations, ouvertures et déclarations     #
#########################################################################
$OUVRE
NAVIG="CONSSSC"
Local Char    WFIL(250),WFIL1(250),WFIL2(250),WFIL3(250),WFIL4(250),WFIL5(250),WFIL6(250),WFIL7(250)
Local Char    DEBNUM(GLONPOH), FINNUM(GLONPOH)
Local Date    DEBDAT, FINDAT
Local Integer DEBLIN, FINLIN

Gosub DEFCRIT
If !clalev([F:BPR]) : Local File BPARTNER [BPR]  : Endif
If !clalev([F:TCU]) : Local File TABCUR [TCU]    : Endif
If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
Return

# --------------------------------------------------------------------------#
# Analyse paramètres, initialisations                                       #
# --------------------------------------------------------------------------#
$DEFCRIT
If GNBAUZ=1 : PARAM(3)=GUSRFCY(1) : Endif

For I = 1 To dim(PARAM)
  Case I
    When 1 : # Parametre Article sous-traité
      If PARAM(I) <> ""
        If [F:ITM]ITMREF <> PARAM(I)
          Read [ITM]ITM0 = PARAM(I)
          If fstat  Raz [F:ITM], PARAM(I) : Endif
        Endif
#        [M:SSC1]ITMREF = PARAM(I)
        [M:SSC1]ITMREFDEB = PARAM(I)
      Endif

    When 2 : # Parametre Fournisseur
      If PARAM(I) <> ""
        If [F:BPS]BPSNUM <> PARAM(I)
          Read [BPS] BPS0 = PARAM(I)
          If fstat  Raz [F:BPS], PARAM(I) : Endif
        Endif
#US 71069/138  by RBA
#        [M:SSC1]BPSNUM = PARAM(I)
        [M:SSC1]BPSNUMDEB = PARAM(I)
        [M:SSC1]BPSNUMFIN = PARAM(I)
#/US 71069/138  by RBA
      Endif
    When 3 : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)
          Read [FCY] FCY0 = PARAM(I)
          If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif
        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
          [M:SSC1]POHFCY = PARAM(I)
          [M:SSC1]CPY = GSOCIETE
        Endif
      Endif
    When 4 : # Parametre commande
      If PARAM(I) <> ""
        [M:SSC1]POHNUMDEB=PARAM(I)
        [M:SSC1]POHNUMFIN=PARAM(I)
      Endif
  Endcase

Next I

# soldée oui
If !find([M:SSC1]CLEFLGO,1,2) : [M:SSC1]CLEFLGO= 1 : Endif
# non soldée
If !find([M:SSC1]CLEFLGN,1,2) : [M:SSC1]CLEFLGN= 2 : Endif
# signée oui
If !find([M:SSC1]APPFLGO,1,2) : [M:SSC1]APPFLGO= 2 : Endif
# signée non
If !find([M:SSC1]APPFLGN,1,2) : [M:SSC1]APPFLGN= 2 : Endif
# reçue oui
If !find([M:CSSC]RCPFLGO,1,2) : [M:CSSC]RCPFLGO= 2 : Endif
# reçue non
If !find([M:CSSC]RCPFLGN,1,2) : [M:CSSC]RCPFLGN= 2 : Endif
# facturée oui
If !find([M:CSSC]INVFLGO,1,2) : [M:CSSC]INVFLGO= 2 : Endif
# facturée non
If !find([M:CSSC]INVFLGN,1,2) : [M:CSSC]INVFLGN= 2 : Endif
# imprimée oui
If !find([M:CSSC]PRNFLGO,1,2) : [M:CSSC]PRNFLGO= 2 : Endif
# imprimée non
If !find([M:CSSC]PRNFLGN,1,2) : [M:CSSC]PRNFLGN= 2 : Endif
If !find ([M:CSSC]TRI,1,2,3,4,5,6) : [M:CSSC]TRI=1 : Endif

#----- Initialisation dates début et fin -----#
Gosub INIT_DATES From TRTACHGRH1
[M:SSC1]ORDDATDEB=WDATDEB
[M:SSC1]ORDDATFIN=WDATFIN

[M:SSC1]VCRTYPORI = 1# Issue 116424 #11

# landed cost - descente des flags
If GPILNAV>1
  If find(GNAVIG(GPILNAV),"CONSCPO")
    [M:SSC1]CLEFLGO=[M:CPO1]CLEFLGO
    [M:SSC1]CLEFLGN=[M:CPO1]CLEFLGN
    [M:SSC1]APPFLGO=[M:CPO1]APPFLGO
    [M:SSC1]APPFLGN=[M:CPO1]APPFLGN
    [M:SSC1]ORDDATDEB=[M:CPO1]ORDDATDEB
    [M:SSC1]ORDDATFIN=[M:CPO1]ORDDATFIN
  Endif
Endif

#----- Copie du masque 1 (SSC1) vers l'écran critères (CSSC) -----#
Gosub CRITENT From =PROGCNS
Return

#########################################################################
$DEB_CRIT
If GPILNAV>1
  #acces depuis article ou article site
  If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
    If find(GNAVIG(GPILNAV-1),"GESITM")
#      Diszo [M:CSSC]ITMREF
      Diszo [M:CSSC]ITMREFFIN
      Diszo [M:CSSC]ITMREFDEB
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
#      Diszo [M:CSSC]ITMREF
      Diszo [M:CSSC]ITMREFFIN
      Diszo [M:CSSC]ITMREFDEB
      Diszo [M:CSSC]POHFCY
      Diszo [M:CSSC]CPY
    Endif
    If dim([M:CSSC]TSICOD) > 0
      For I = 0 To dim([M:CSSC]TSICOD)-1
        Diszo [M:CSSC]TSICOD(I)
      Next I
    Endif
  Endif

  #acces depuis clients ou fournisseurs
  If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
#    Diszo [M:CSSC]BPSNUM
    Diszo [M:CSSC]BPSNUMDEB : Diszo [M:CSSC]BPSNUMFIN
    If dim([M:CSSC]TSICOD) > 0
      For I = 0 To dim([M:CSSC]TSICOD)-1
        Diszo [M:CSSC]TSICOD(I)
      Next I
    Endif
  Endif

  #acces depuis consultation des commandes, les nums de commande sont grisés
  If find(GNAVIG(GPILNAV-1),"CONSCPO")
    Diszo [M:CSSC]POHNUMDEB
    Diszo [M:CSSC]POHNUMFIN
  Endif
Endif

  If [M]VCRTYPORI = 1 #Issue 116424
    #bornes grisées
    Diszo [M] VCRNUMORIDEB, VCRNUMORIFIN
  Else
    Actzo [M] VCRNUMORIDEB, VCRNUMORIFIN
  Endif
Return

#########################################################################
$LECTURE
Local   Decimal  WMNTORG(0..1), WMNTDES(0..1)
Local   Integer  SPSTAT
Local   Char     WBPRNAM(GLONNAM)(2)

#acces depuis article ou article site
If GPILNAV>1
  If find(GNAVIG(GPILNAV-1),"GESITM")
#    Diszo [M:SSC1]ITMREF
    Diszo [M:SSC1]ITMREFFIN
    Diszo [M:SSC1]ITMREFDEB
  Elsif find(GNAVIG(GPILNAV-1),"GESITF")
#    Diszo [M:SSC1]ITMREF
    Diszo [M:SSC1]ITMREFFIN
    Diszo [M:SSC1]ITMREFDEB
    Diszo [M:SSC1]POHFCY
    Diszo [M:SSC1]CPY
  Endif

  #acces depuis clients ou fournisseurs
  If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
#    Diszo [M:SSC1]BPSNUM
     Diszo [M:SSC1]BPSNUMDEB
     Diszo [M:SSC1]BPSNUMFIN
  Endif

  #acces depuis consultation des commandes, les nums de commande sont grisés
  If find(GNAVIG(GPILNAV-1),"CONSCPO")
    Diszo [M:SSC1]POHNUMDEB
    Diszo [M:SSC1]POHNUMFIN
  Endif
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [POQ] With [POH]POH0=[POQ]POHNUM,
&               [POP]POP0=[POQ]POHNUM;[POQ]POPLIN;[POQ]POQSEQ
&          As [LNK]



# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
  SUITE=1
  If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
#  Case [M:CSSC]TRI
#    When 1 : # tri par numéro
#      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
#&                  Order By Key POQ0
#    When 2 : # tri par date
#      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
#&                  Order By Key CLE=[F:POQ]ORDDAT;[F:POQ]POHNUM;[F:POQ]POPLIN
#  Endcase
  Case [M:CSSC]TRI
    When 1:    # tri par N° ordre
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]VCRNUMORI

    When 2:    # tri par article sous-traité
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]ITMREFORI

    When 3:    # tri par article sous-traitance
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]ITMREF

    When 4:    # tri par n° de commande
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]POHNUM

    When 5:    # tri par date commande
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]ORDDAT

    When 6:    # tri par fournisseur
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]BPSNUM
  Endcase
Else
  RETOUR=1
  If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
#  Case [M:CSSC]TRI
#    When 1 : # tri par numéro
#      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
#&                  Order By Key POQ0 Desc
#    When 2 : # tri par date
#      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
#&                  Order By [F:POQ]ORDDAT Desc ;[F:POQ]POHNUM Desc;[F:POQ]POPLIN Desc
#  Endcase
  Case [M:CSSC]TRI
    When 1 :    # tri par N° ordre de sous-traitance
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]VCRNUMORI Desc

    When 2:    # tri par article sous-traité
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]ITMREFORI Desc

    When 3:    # tri par article sous-traitance
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]ITMREF Desc

    When 4 :   # tri par n° de commande
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]POHNUM Desc

    When 5 :   # tri par date commande
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]ORDDAT Desc

    When 6:    # tri par fournisseur
      Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) & evalue(WFIL6) & evalue(WFIL7)
&         Order By Key CLE =[F:POQ]BPSNUM Desc
  Endcase
Endif

#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:SSC2] : Endif

#-- lecture
$BOUCLE
For [LNK]
# Filtre sur la société
  If [M:SSC1]CPY <> ""
    If [F:FCY]FCY <> [F:POH]POHFCY
      Read [FCY] FCY0 = [F:POH]POHFCY
      If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY <> [M:SSC1]CPY
      Goto SUIV
    Endif
  Endif

  If NBLU = 1
    If CHGPAG=2 | CHGPAG=-2 : Raz [M:SSC2] : Endif
    NBLU = 2
  Endif
  If CHGPAG > 0
    If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
    NOL += 1
    If NOL=0
      If CHGPAG=2
        If [F:POQ]POHNUM=FINNUM and [F:POQ]POPLIN<=FINLIN : NOL-=1 : Goto SUIV : Endif
      Endif
      DEBNUM = [F:POH]POHNUM
      DEBDAT = [F:POH]ORDDAT
      DEBLIN = [F:POQ]POPLIN
    Endif
    FINNUM = [F:POH]POHNUM
    FINDAT = [F:POH]ORDDAT
    FINLIN = [F:POQ]POPLIN
  Else
    If NOL <= 0 : RETOUR=2 : Break : Endif
    NOL    -= 1
    If NOL=MAXLIG-1
      If CHGPAG=-2
        If [F:POQ]POHNUM=DEBNUM and [F:POQ]POPLIN>=DEBLIN : NOL+=1 : Goto SUIV : Endif
      Endif
      FINNUM = [F:POH]POHNUM
      FINDAT = [F:POH]ORDDAT
      FINLIN = [F:POQ]POPLIN
    Endif
    DEBNUM = [F:POH]POHNUM
    DEBDAT = [F:POH]ORDDAT
    DEBLIN = [F:POQ]POPLIN
  Endif
  nolign = NOL+1

  If NOL>0 : [L]WBPRNAM(0)=[M:SSC2]BPRNAM(0) : Endif
  If NOL>1 : [L]WBPRNAM(1)=[M:SSC2]BPRNAM(1) : Endif
  [M:SSC2]=[F:POH] : # trans classe sur PORDER
  [M:SSC2]=[F:POQ] : # trans classe sur PORDERQ
  [M:SSC2]=[F:POP] : # trans classe sur PORDERP
  If NOL=1 : [M:SSC2]BPRNAM(1)=[F:POH]BPRNAM(0) : Endif
  If NOL>0 : [M:SSC2]BPRNAM(0)=[L]WBPRNAM(0) : Endif
  If NOL>1 : [M:SSC2]BPRNAM(1)=[L]WBPRNAM(1) : Endif

  If [M:SSC2]BPRNAM(NOL)=""
    If [F:BPR]BPRNUM<>[M:SSC2]BPSNUM(NOL)
      Read [BPR] BPR0=[M:SSC2]BPSNUM(NOL) : If fstat  Raz [F:BPR] : Endif
    Endif
    [M:SSC2]BPRNAM(NOL)=[F:BPR]BPRNAM(0)
  Endif

  If GLOCALDEV <> [F:POH]CUR
    Read [TCU] TCU0 = GLOCALDEV
    If fstat Raz [F:TCU] : Endif
  Endif

  #conversion en devise document (société pour LINAMT)
  If GLOCALDEV <> [F:POH]CUR & [F:POH]CHGCOE<>0
    [M:SSC2]LINAMTSOC(nolign-1)    = arr([M:SSC2]LINAMT(nolign-1)*[F:POH]CHGCOE,[F:TCU]CURRND)
    [M:SSC2]CSTPURDOC(nolign-1)    = arr([M:SSC2]CSTPUR(nolign-1)/[F:POH]CHGCOE,[F:TCU]CURRND)
    [M:SSC2]REACSTPURDOC(nolign-1) = arr([M:SSC2]REACSTPUR(nolign-1)/[F:POH]CHGCOE,[F:TCU]CURRND)
    [M:SSC2]LINCSTPURDOC(nolign-1) = arr([M:SSC2]LINCSTPUR(nolign-1)/[F:POH]CHGCOE,[F:TCU]CURRND)
    [M:SSC2]LINATISOC(nolign-1)    = arr([M:SSC2]LINATI(nolign-1)*[F:POH]CHGCOE,[F:TCU]CURRND)
  Else
    [M:SSC2]LINAMTSOC(nolign-1)    = [M:SSC2]LINAMT(nolign-1)
    [M:SSC2]CSTPURDOC(nolign-1)    = [M:SSC2]CSTPUR(nolign-1)
    [M:SSC2]REACSTPURDOC(nolign-1) = [M:SSC2]REACSTPUR(nolign-1)
    [M:SSC2]LINCSTPURDOC(nolign-1) = [M:SSC2]LINCSTPUR(nolign-1)
    [M:SSC2]LINATISOC(nolign-1)    = [M:SSC2]LINATI(nolign-1)
  Endif

##  US 71069/10  PJT by RBA
  [M:SSC2]PJT(nolign-1)       = [F:POP]PJT
  [M:SSC2]ITMREFORI(nolign-1) = [F:POQ]ITMREFORI
  If [F:POQ]VCRTYPORI = 10
    Read [ITM]ITM0=[F:POQ]ITMREFORI
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:POQ]ITMREFORI,[M:SSC2]ITMDESORI(nolign-1), "[F:ITM]") From TRTX3
  Else
    [M:SSC2]ITMDESORI(nolign-1) = func AFNC.TEXTRA("ITMMASTER","DES1AXX",[F:POQ]ITMREFORI,"")
  Endif
  [M:SSC2]ITMREF(nolign-1)    = [F:POQ]ITMREF
$SUIV
Next
Filter [LNK]

Return

#########################################################################
#    Préparation du filtre                                              #
#########################################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFIL3 = "1=1"
WFIL4 = "1=1"
WFIL5 = "1=1"
WFIL6 = "1=1"
WFIL7 = "1=1"

#n°pièce origine
If [M:SSC1]VCRNUMORIDEB <> ""
  WFIL4 += "&[F:POQ]VCRNUMORI>=[M:SSC1]VCRNUMORIDEB"
Endif
If [M:SSC1]VCRNUMORIFIN <> ""
  WFIL4 += "&[F:POQ]VCRNUMORI<=[M:SSC1]VCRNUMORIFIN"
Endif

#on ne prend pas les commandes ouvertes
WFIL3 += "&[F:POH]POHTYP<>2"
##US 71069/138  by RBA
#Issue 116424
Case [M]VCRTYPORI
  When 1  : WFIL3 += "&(([F:POQ]VCRTYPORI = 10 & [F:POQ]LINTYP = 1) or ([F:POQ]VCRTYPORI = 36 & [F:POQ]LINTYP = 3))"
  When 11 : WFIL3 += "&(([F:POQ]VCRTYPORI = 10 & [F:POQ]LINTYP = 1))"
  When 37 : WFIL3 += "&(([F:POQ]VCRTYPORI = 36 & [F:POQ]LINTYP = 3))"
Endcase
#/Issue 116424
#WFIL3 += "&(([F:POQ]VCRTYPORI = 10 & [F:POQ]LINTYP = 1) or ([F:POQ]VCRTYPORI = 36 & [F:POQ]LINTYP = 3))"
##WFIL += "&(([F:POQ]VCRTYPORI = 36 & [F:POQ]LINPURTYP=1 & [F:POQ]LINTYP = 3) or ([F:POQ]VCRTYPORI = 10 & [F:POQ]LINPURTYP=3 & [F:POQ]LINTYP = 1))"
##/US 71069/138  by RBA
# Site de commande
If [M:SSC1]POHFCY <> ""
  WFIL += "&[F:POH]POHFCY=[M:SSC1]POHFCY"
Endif
# Autorisation site
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  WFIL += "& find([F:POH]POHFCY,GUSRFCY(1..GNBAUZ))"
Endif
## Numéro de fournisseur
#If [M:SSC1]BPSNUM <> ""
#  WFIL += "&[F:POH]BPSNUM =[M:SSC1]BPSNUM"
#Endif

# Numéro de fournisseur
If [M:SSC1]BPSNUMDEB <> ""
   WFIL2 += "&[F:POH]BPSNUM >=[M:SSC1]BPSNUMDEB"
Endif
If [M:SSC1]BPSNUMFIN <> ""
   WFIL2 += "&[F:POH]BPSNUM <=[M:SSC1]BPSNUMFIN"
Endif

# Article lancé
#If [M:SSC1]ITMREFORI <> ""
#  WFIL += "&[F:POQ]ITMREFORI =[M:SSC1]ITMREFORI"
#Endif
If [M:SSC1]ITMREFORIDEB <> ""
  WFIL5 += "&[F:POQ]ITMREFORI >=[M:SSC1]ITMREFORIDEB"
Endif
If [M:SSC1]ITMREFORIFIN <> ""
  WFIL5 += "&[F:POQ]ITMREFORI <=[M:SSC1]ITMREFORIFIN"
Endif
# Article ss-traité
#If [M:SSC1]ITMREF <> ""
#  WFIL += "&[F:POQ]ITMREF =[M:SSC1]ITMREF"
#Endif
If [M:SSC1]ITMREFDEB <> ""
  WFIL5 += "&[F:POQ]ITMREF >=[M:SSC1]ITMREFDEB"
Endif
If [M:SSC1]ITMREFFIN <> ""
  WFIL5 += "&[F:POQ]ITMREF <=[M:SSC1]ITMREFFIN"
Endif
# Filtre sur les commandes
If [M:SSC1]POHNUMDEB <> ""
  WFIL += "&[F:POH]POHNUM>=[M:SSC1]POHNUMDEB"
Endif
If [M:SSC1]POHNUMFIN <> ""
  WFIL += "&[F:POH]POHNUM<=[M:SSC1]POHNUMFIN"
Endif

#    Prise en compte des lignes et non commandes soldées
#    si la ligne est soldée LINCLEFLG = 2
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:SSC1]CLEFLGO = 1
  WFIL1 += "&[F:POQ]LINCLEFLG<>2"
Endif

#    Prise en compte des lignes et non commandes soldées
#    si la ligne n'est pas soldée LINCLEFLG = 1
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:SSC1]CLEFLGN = 1
  WFIL1 += "&[F:POQ]LINCLEFLG=2"
Endif

#    Prise en compte des commandes signées
#    si la commande est totalement signée APPFLG > 2
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:SSC1]APPFLGO = 1
   WFIL1 += "&[F:POH]APPFLG<3"
Endif

#    Prise en compte des commandes non signées
#    si la commande n'est pas totalement signée APPFLG <3
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:SSC1]APPFLGN = 1
   WFIL1 += "&[F:POH]APPFLG>2"
Endif

#    Prise en compte des commandes recues
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CSSC]RCPFLGO= 1
   WFIL1 += "&[F:POH]RCPFLG<3"
Endif

#    Prise en compte des commandes non recues
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CSSC]RCPFLGN= 1
   WFIL1 += "&[F:POH]RCPFLG>2"
Endif

#    Prise en compte des commandes facturées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CSSC]INVFLGO= 1
   WFIL1 += "&[F:POH]INVFLG<3"
Endif

#    Prise en compte des commandes non facturées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CSSC]INVFLGN= 1
   WFIL1 += "&[F:POH]INVFLG>2"
Endif

#    Prise en compte des commandes imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CSSC]PRNFLGO= 1
   WFIL1 += "&[F:POH]PRNFLG<>2"
Endif

#    Prise en compte des commandes non imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CSSC]PRNFLGN= 1
   WFIL1 += "&[F:POH]PRNFLG=2"
Endif

If [M:CSSC]ORDDATDEB <> [0/0/0]
   WFIL += "&[F:POH]ORDDAT>=[M:CSSC]ORDDATDEB"
Endif
If [M:CSSC]ORDDATFIN <> [0/0/0]
   WFIL += "&[F:POH]ORDDAT<=[M:CSSC]ORDDATFIN"
Endif

If dim([M:CSSC]TSICOD) > 0
  For I = 0 To dim([M:CSSC]TSICOD)-1
    If [M:CSSC]TSICOD(I) <> ""
      If len(WFIL6) > 200
        WFIL7 += "&[F:POP]TSICOD("+num$(I)+")='"+[M:CSSC]TSICOD(I)+"'"
      Else
        WFIL6 += "&[F:POP]TSICOD("+num$(I)+")='"+[M:CSSC]TSICOD(I)+"'"
      Endif
    Endif
  Next I
Endif

If dim([M:CSSC]TSSCOD) > 0
  For I = 0 To dim([M:CSSC]TSSCOD)-1
    If [M:CSSC]TSSCOD(I) <> ""
      If len(WFIL6) > 200
        WFIL7 += "&[F:POH]TSSCOD("+num$(I)+")='"+[M:CSSC]TSSCOD(I)+"'"
      Else
        WFIL6 += "&[F:POH]TSSCOD("+num$(I)+")='"+[M:CSSC]TSSCOD(I)+"'"
      Endif
    Endif
  Next I
Endif

#US 71069/10  PJT by RBA
If [M:CSSC]PJTDEB <> ""
   WFIL2 += "&[F:POP]PJT>=[M:CSSC]PJTDEB"
Endif
If [M:CSSC]PJTFIN <> ""
   WFIL2 += "&[F:POP]PJT<=[M:CSSC]PJTFIN"
Endif
#/US 71069/10  PJT by RBA

#Case CHGPAG
#  When 3 : # rafraichissement
#    Case [M:CSSC]TRI
#      When 1 : # tri par numéro
#        WFIL += "&[F:POH]POHNUM>=DEBNUM"
#      When 2 : # tri par date
#        WFIL += "&([F:POH]ORDDAT>DEBDAT | ([F:POH]ORDDAT=DEBDAT & [F:POH]POHNUM>=DEBNUM))"
#    Endcase
#  When 2 : # suite
#    Case [M:CSSC]TRI
#      When 1 : # tri par numéro
#        WFIL += "&[F:POH]POHNUM>=FINNUM"
#      When 2 : # tri par date
#        WFIL += "&([F:POH]ORDDAT>FINDAT | ([F:POH]ORDDAT=FINDAT & [F:POH]POHNUM>=FINNUM))" :# 69747
#    Endcase
#  When -2 : # retour
#    Case [M:CSSC]TRI
#      When 1 : # tri par numéro
#       WFIL += "&[F:POH]POHNUM<=DEBNUM"
#      When 2 : # tri par date
#       WFIL += "&([F:POH]ORDDAT<DEBDAT | ([F:POH]ORDDAT=DEBDAT & [F:POH]POHNUM<=DEBNUM))" :# 69747
#    Endcase
#Endcase
Case CHGPAG
    When 3 : # rafraichissement
        Case [M:CSSC]TRI
            When 1 :
                WFIL += "&[F:POQ]VCRNUMORI >= VCRNUMORIDEB"
            When 2 :
                WFIL += "&[F:POQ]ITMREFORI >= ITMREFORIDEB"
            When 3 :
                WFIL += "&[F:POQ]ITMREF >= ITMREFDEB"
            When 4 :
                WFIL += "&[F:POQ]POHNUM >= POHNUMDEB"
            When 5 :
                WFIL += "&[F:POQ]ORDDAT >= ORDDATDEB"
            When 6 :
                WFIL += "&[F:POQ]BPSNUM >= BPSNUMDEB"
        Endcase
    When 2 : #suite
        Case [M:CSSC]TRI
            When 1:
                WFIL += "&[F:POQ]VCRNUMORI > VCRNUMORIFIN"
            When 2 :
                WFIL += "&[F:POQ]ITMREFORI > ITMREFORIFIN"
            When 3:
                WFIL += "&[F:POQ]ITMREF > ITMREFFIN"
            When 4:
                WFIL += "&[F:POQ]POHNUM > POHNUMFIN"
            When 5:
                WFIL += "&[F:POQ]ORDDAT > ORDDATFIN"
            When 6:
                WFIL += "&[F:POQ]BPSNUM > BPSNUMFIN"
        Endcase
    When -2: # retour
        Case [M:CSSC]TRI
            When 1:
                WFIL += "&[F:POQ]VCRNUMORI < VCRNUMORIDEB"
            When 2 :
                WFIL += "&[F:POQ]ITMREFORI < ITMREFORIDEB"
            When 3 :
                WFIL += "&[F:POQ]ITMREF < ITMREFDEB"
            When 4:
                WFIL += "&[F:POQ]POHNUM < POHNUMDEB"
            When 5:
                WFIL += "&[F:POQ]ORDDAT < ORDDATDEB"
            When 6:
                WFIL += "&[F:POQ]BPSNUM < BPSNUMDEB"
        Endcase
Endcase
Return

#########################################################################
# Avant de fermer la fenetre critère et de revenir à fenetre principale #
#########################################################################
$FIN_CRIT

Return



#########################################################################
##  Etiquettes masques CONSSSC1 & CONSSSC2 & CRITSSC                   ##
#########################################################################
Subprog AV_CPY(VALEUR)
Variable Char     VALEUR
If GNBAUZ=1 : Diszo [M]CPY, POHFCY : Endif

End

#-------------------------------#
# Contrôle de la société        #
#-------------------------------#
Subprog C_CPY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
    GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]POHFCY = ""
  GSOCIETE="" : GLOCALDEV=""
Endif
End

#-------------------------------#
# Après modif de la société     #
#-------------------------------#
Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
Affzo ZCPY                      : # Utilisé par 2 écrans
Raz [M]POHFCY, [M]ZPOHFCY
Affzo POHFCY, ZPOHFCY
If VALEUR<>""  GSOCIETE=VALEUR : Endif
End

#------------------------------------------------#
# Contrôle du site par defaut pour achat         #
# on regarde en fonction des autorisations sites #
# uniquement dans le cas site par defaut = ""    #
# complément de l'action VERIFCY en avant saisie #
#------------------------------------------------#
Subprog C_POHFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
  Call GETDEV(VALEUR) From DEVSUB
  [M]CPY = GSOCIETE
Elsif [M]CPY = ""
  GSOCIETE="" : GLOCALDEV=""
Else
  Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#-------------------------------#
# Après modif du site           #
#-------------------------------#
Subprog AM_POHFCY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Affzo CPY, ZCPY  : # Utilisé par 2 écrans
Endif
End

#-----------------#
# Init bouton     #
#-----------------#
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2
If [M:SSC2]NBLIG<>0
  If clalev([M:POH0])=0
    GBOUT1=mess(2,306,1) : # Commandes
  Endif
  If [M:SSC2]SOHNUM(nolign-1) <> ""
    GBOUT2 = mess(1,306,1)-[M]SOHNUM(nolign-1)
  Endif
Endif
End

$AB1_NBLIG
#------------------------------------------------------#
# Avant exécution du bouton Tunnel commandes, contrats #
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1(GLONPOH)
Local Char     WCLE2(GLONPOH)
If [M:SSC2]POHTYP(NOL) = 2
  WOBJET="POD"
  WCLE1 =num$(1)
  WCLE2 =[M:SSC2]POHNUM(NOL)
Else
  WOBJET="POH"
  WCLE1=[M:SSC2]POHNUM(NOL)
  WCLE2=""
Endif
Return

#-------------------------------------#
# Après modification de la date début #
#-------------------------------------#
Subprog AM_ORDDATDEB(VALEUR)
Variable Date     VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
If dim([M]PERCOD)>0
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]ORDDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]ORDDATFIN=WDATE : Affzo ORDDATFIN
  Endif
Elsif VALEUR>[M]ORDDATFIN
  [M]ORDDATFIN=VALEUR
Endif
End

#-----------------------------------#
# Après modification de la date fin #
#-----------------------------------#
Subprog AM_ORDDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)<1  End : Endif
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]ORDDATFIN,VALEUR,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]ORDDATDEB=WDATE : Affzo ORDDATDEB
Endif
#-----
End

