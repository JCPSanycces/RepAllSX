Subprog AS_VCRTYPORI(VALEUR)
Variable Integer VALEUR
  For I=1 To len(mess(0,725,1))
    If !find(I,1,11,37) #Issue 116424
        GMENLOC(I) = 1
    Endif
  Next
End

Subprog AM_VCRTYPORI(VALEUR)
Variable Integer VALEUR
  [M]VCRNUMORIDEB = ""
  [M]VCRNUMORIFIN = ""
  If VALEUR = 1 #Issue 116424
    #bornes grisées
    Diszo [M] VCRNUMORIDEB, VCRNUMORIFIN
  Else
    Actzo [M] VCRNUMORIDEB, VCRNUMORIFIN
  Endif
End

Subprog AM_VCRNUMORIDEB(VALEUR)
Variable Char    VALEUR()
  [M]VCRNUMORIFIN = VALEUR
End

