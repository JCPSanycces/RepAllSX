#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIWRKEPV 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBADR
mkstat = 0
zoncou = "NBADR"
indice = 0
status = 1
zoncou = "NBADR"
If varmode([M]NBADR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBADR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBADR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBADR = nolign
   status = 75
   Call SAI_NBADR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBVAT
mkstat = 0
zoncou = "NBVAT"
indice = 0
status = 1
zoncou = "NBVAT"
If varmode([M]NBVAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBVAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBVAT
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBVAT = nolign
   status = 75
   Call SAI_NBVAT(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone NBFAC
mkstat = 0
zoncou = "NBFAC"
indice = 0
status = 1
zoncou = "NBFAC"
If varmode([M]NBFAC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBFAC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBFAC
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBFAC = nolign
   status = 75
   Call SAI_NBFAC(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 5
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 6
####################################
IMPTBL = 1

## Zone NBEAV
mkstat = 0
zoncou = "NBEAV"
indice = 0
status = 1
zoncou = "NBEAV"
If varmode([M]NBEAV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBEAV" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBEAV
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBEAV = nolign
   status = 75
   Call SAI_NBEAV(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBADR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBADR
mkstat = 0
zoncou = "NBADR"

## Zone ADR1
mkstat = 0
zoncou = "ADR1"
SAVACT = GACTION : GACTION = "FMTADRPAY"
Call FMTADRPAY("") From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]ADR1(indice) : Endif

## Zone ADR2
mkstat = 0
zoncou = "ADR2"
SAVACT = GACTION : GACTION = "FMTADRPAY"
Call FMTADRPAY("") From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]ADR2(indice) : Endif

## Zone ADR3
mkstat = 0
zoncou = "ADR3"
SAVACT = GACTION : GACTION = "FMTADRPAY"
Call FMTADRPAY("") From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]ADR3(indice) : Endif

## Zone POSCOD
mkstat = 0
zoncou = "POSCOD"
WCHAR = [M]POSCOD(indice)
SAVACT = GACTION : GACTION = "FMTPOSPAY"
Call FMTPOSPAY(CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]POSCOD(indice) : Endif

## Zone CTY
mkstat = 0
zoncou = "CTY"
WCHAR = [M]CTY(indice)
SAVACT = GACTION : GACTION = "FMTCTYPAY"
Call FMTCTYPAY(CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]CTY(indice) : Endif

## Zone CRY
mkstat = 0
zoncou = "CRY"
If varinit([M]CRY,indice)=0
 [M]CRY(indice) = GPAYS
Endif

## Zone TEL
mkstat = 0
zoncou = "TEL"
WCHAR = [M]TEL(indice)
SAVACT = GACTION : GACTION = "FMTTELPAY"
Call FMTTELPAY(CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]TEL(indice) : Endif

## Zone FAX
mkstat = 0
zoncou = "FAX"
WCHAR = [M]FAX(indice)
SAVACT = GACTION : GACTION = "FMTTELPAY"
Call FMTTELPAY(CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]FAX(indice) : Endif

## Zone RAZCNT
mkstat = 0
zoncou = "RAZCNT"
IMPENT = [M]RAZCNT(indice)
If varinit([M]RAZCNT,indice)=0
 IMPENT = 1
Endif
[M]RAZCNT(indice) = IMPENT

## Zone NBADR
mkstat = 0
zoncou = "NBADR"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBVAT(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBVAT
mkstat = 0
zoncou = "NBVAT"

## Zone XVTYP
mkstat = 0
zoncou = "XVTYP"
IMPENT = [M]XVTYP(indice)
If varinit([M]XVTYP,indice)=0
 IMPENT = 1
Endif
[M]XVTYP(indice) = IMPENT

## Zone NBVAT
mkstat = 0
zoncou = "NBVAT"

End

####################################
## Bloc tableau 4
####################################
Subprog SAI_NBFAC(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBFAC
mkstat = 0
zoncou = "NBFAC"

## Zone INVDTATYP
mkstat = 0
zoncou = "INVDTATYP"
IMPENT = [M]INVDTATYP(indice)
If varinit([M]INVDTATYP,indice)=0
 IMPENT = 1
Endif
[M]INVDTATYP(indice) = IMPENT

## Zone INVDTACOD
mkstat = 0
zoncou = "INVDTACOD"
IMPENT = [M]INVDTACOD(indice)
If varinit([M]INVDTACOD,indice)=0
 IMPENT = 1
Endif
[M]INVDTACOD(indice) = IMPENT

## Zone SFICCE
mkstat = 0
zoncou = "SFICCE"
SAVACT = GACTION : GACTION = "INICCEFMT"
Call INICCEFMT(num$(GDIE(1))) From SETGLBDIE
GACTION = SAVACT
If mkstat=1 : Raz [M]SFICCE(indice) : Endif

## Zone NBFAC
mkstat = 0
zoncou = "NBFAC"

End

####################################
## Bloc tableau 5
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

####################################
## Bloc tableau 6
####################################
Subprog SAI_NBEAV(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBEAV
mkstat = 0
zoncou = "NBEAV"

## Zone NBEAV
mkstat = 0
zoncou = "NBEAV"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SIWRKEPV"
Return

