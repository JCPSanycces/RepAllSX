########################################
#14/06/12 - SEGAY - Display\Hide fields based on legislation
#     MABOS -  - 30/05/13 - FQ81084 - US1612 -
#                         - field hidden / LEG in creation
########################################
Subprog DISPLAY_HIDE()
Local Integer WNUMLIBEL
  Case GCURLEG
   When "FRA", ""
     If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
     Read [F:AMKW]CODMSK = "OFI1"
     # Show Block titles
     WNUMLIBEL=[F:AMKW]TITBLOC(1)
     Chgtbk [M:OFI1]10          With func AFNC.TEXTE(WNUMLIBEL)   #Formation
     Chgfmt [M:OFI1]NUMORG      With "K:35X"
   When Default
     Chgtbk [M:OFI1]10          With ""   #Formation
     #OFI1 - Hide of tab
     Chgfmt [M:OFI1]NUMORG      With "-K:35X" : Effzo [M:OFI1]NUMORG : # Raz-> Effzo :#MABOS-FQ81084-US1612
  Endcase
End

