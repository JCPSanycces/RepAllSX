#<AdxTL>@(#)3.0.0.0 $Revision$
###############################################################################################
# Structure BID

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_CONTROL_BEFORE"       : Gosub AINSERT_CONTROL_BEFORE
      When "AUPDATE_CONTROL_BEFORE"       : Gosub AUPDATE_CONTROL_BEFORE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "BIDNUM"       : Gosub BIDNUM
  When "CRY"          : Gosub CRY
  When "VLYSTR"       : Gosub VLYSTR
  When "VLYEND"       : Gosub VLYEND
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


###############################################################################################
$AINSERT_CONTROL_BEFORE
Gosub BID_CONTROL
Return

###############################################################################################
$AUPDATE_CONTROL_BEFORE
Gosub BID_CONTROL
Return

###############################################################################################
$BID_CONTROL
Local Instance ABANK Using C_ABANK
If this.CRY<>"" and this.BIDNUM<>""
  If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"BIDCTL") = [V]CST_AYES
    ABANK = NewInstance C_ABANK AllocGroup null
    [L]ASTATUS = [V]CST_AOK
    Gosub ABANK_GET
    [L]ASTATUS = [V]CST_AOK             # No error if ABANK not found
    FreeGroup ABANK
  Endif
Endif
Return





###############################################################################################
$BIDNUM
Case [L]ARULE
  When "CONTROL"            : Gosub BIDNUM_CONTROL
  When "PROPAGATE"          : Gosub BIDNUM_PROPAGATE
Endcase
Return

$BIDNUM_CONTROL
Local Instance ABANK Using C_ABANK
ABANK = NewInstance C_ABANK AllocGroup null
[L]ASTATUS = [V]CST_AOK
Gosub ABANK_GET
FreeGroup ABANK
Return

$BIDNUM_PROPAGATE
Local Instance ABANK Using C_ABANK
ABANK = NewInstance C_ABANK AllocGroup null
[L]ASTATUS = [V]CST_AOK
Gosub ABANK_GET
this.PAB1   = ABANK.PAB
this.BICCOD = ABANK.BIC
FreeGroup ABANK
Return

###############################################################################################
$CRY
Case [L]ARULE
  When "PROPAGATE"          : Gosub CRY_PROPAGATE
Endcase
Return

$CRY_PROPAGATE
Local Instance ABANK Using C_ABANK
ABANK = NewInstance C_ABANK AllocGroup null
[L]ASTATUS = [V]CST_AOK
Gosub ABANK_GET
If [L]ASTATUS = [V]CST_AOK and func ASYRFNC.ACTIVDOS(this.ACTX.AFOLDER,"RI1")>0
  If this.VLYSTR=AVOID.ADATE
    this.VLYSTR = ABANK.VLYSTR
  Elsif this.VLYSTR<ABANK.VLYSTR
    [L]ASTATUS = fmet this.ASETERROR("VLYSTR",mess(1,138,1)-"<"-mess(99,105,1),[V]CST_AERROR)
  Endif
  If this.VLYEND=AVOID.ADATE
    this.VLYEND = ABANK.VLYEND
  Elsif  this.VLYEND>ABANK.VLYEND
    [L]ASTATUS = fmet this.ASETERROR("VLYEND",mess(3,138,1)-">"-mess(99,105,1),[V]CST_AERROR)
  Endif
Endif
FreeGroup ABANK
Return

###############################################################################################
$VLYSTR
Case [L]ARULE
  When "CONTROL"              : Gosub VLYSTR_CONTROL
Endcase
Return

$VLYSTR_CONTROL
Local Instance ABANK Using C_ABANK
ABANK = NewInstance C_ABANK AllocGroup null
[L]ASTATUS = [V]CST_AOK
Gosub ABANK_GET
If [L]ASTATUS = [V]CST_AOK
  If this.VLYSTR<>AVOID.ADATE & this.VLYSTR<ABANK.VLYSTR
    [L]ASTATUS = fmet this.ASETERROR("VLYSTR",mess(1,138,1)-"<"-mess(99,105,1),[V]CST_AERROR)
  Endif
Endif
FreeGroup ABANK
Return

###############################################################################################
$VLYEND
Case [L]ARULE
  When "CONTROL"              : Gosub VLYEND_CONTROL
Endcase
Return

$VLYEND_CONTROL
Local Instance ABANK Using C_ABANK
ABANK = NewInstance C_ABANK AllocGroup null
[L]ASTATUS = [V]CST_AOK
Gosub ABANK_GET
If [L]ASTATUS = [V]CST_AOK
  If this.VLYEND<>AVOID.ADATE & this.VLYEND>ABANK.VLYEND
    [L]ASTATUS = fmet this.ASETERROR("VLYEND",mess(3,138,1)-">"-mess(99,105,1),[V]CST_AERROR)
  Endif
Endif
FreeGroup ABANK
Return

###############################################################################################
$ABANK_GET
Local Integer BANLNG

ABANK.PAB = AVOID.ACHAR
ABANK.BIC = AVOID.ACHAR
If  func ASYRFNC.ACTIVDOS(this.ACTX.AFOLDER,"RI1")>0
 ABANK.VLYSTR = AVOID.ADATE
 ABANK.VLYEND = AVOID.ADATE
Endif
[L]ASTATUS = [V]CST_AOK

If this.CRY<>""
  [L]BANLNG = fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"BANLNG")
  If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"BIDCTL") = [V]CST_AYES
    [L]ASTATUS = fmet ABANK.AREAD(this.CRY,left$(this.BIDNUM,[L]BANLNG))
    If [L]ASTATUS <> [V]CST_AOK
      # Bank does not exist
      [L]ASTATUS = fmet this.ASETERROR(CURPRO,left$(this.BIDNUM,[L]BANLNG)-mess(173,133,1),[V]CST_AERROR)
    Endif
  Endif
Endif

Return

###############################################################################################
Funprog CTRL_BID(COLBID,BID_INDEX)
Variable Instance COLBID (1..) Using C_BID
Variable Integer BID_INDEX

Local Integer I,FOUND,ASTATUS
BID_INDEX=0
[L]ASTATUS = [V]CST_AOK
FOUND=[V]CST_AFALSE
For I=1 To maxtab(COLBID)
  If find(COLBID(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
    If COLBID(I).BIDNUMFLG=[V]CST_AYES
      FOUND=[V]CST_ATRUE
      BID_INDEX = I
      Break
    Else
      If BID_INDEX=0
        BID_INDEX=I
      Endif
    Endif
  Endif
Next
If FOUND=[V]CST_ATRUE
  COLBID(BID_INDEX).BIDNUMFLG=[V]CST_AYES
Else
  If BID_INDEX>0
    BID_INDEX=1
    COLBID(BID_INDEX).BIDNUMFLG=[V]CST_AYES
  Else
    BID_INDEX=0
  Endif
Endif

End [L]ASTATUS
