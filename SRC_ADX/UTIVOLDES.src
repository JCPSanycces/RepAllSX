#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à en place du type de données AXX sur le champ DES
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update AVOLUME new DES field") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJVOL
End

#-------------------#
$MAJVOL

Local File =DOSSIER+".AVOLUME" [AVL]
Local File =DOSSIER+".ATABZON" [ATZ_U]

If dim([F:AVL]TITLE)<=0 : Goto FIN : Endif
Read [ATZ_U]CODZONE="AVOLUME";"DES"
If fstat : Goto FIN : Endif

Local File =DOSSIER+".ATEXTRA" [AXX]

# Mise à jour de la table AVOLUME
Call ECR_TRACE(mess(81,125,1)-"AVOLUME:"-time$,0) From GESECRAN

Trbegin [AVL]
 For [AVL] Where TITLE<>""
  Call MAJTEXTRA([F:AVL]TITLE,"AVOLUME","DES",[F:AVL]VOLUME,"") From ATEXTRA
  [F:AVL]TITLE = ""
  Rewrite [AVL]
  If fstat : Call ERREUR("AVOLUME"-[F:AVL]VOLUME,2) From DOSDIC : Endif   
 Next AVL
Commit

$FIN

Close Local File [AVL] , [ATZ_U]

Return
