#<AdxTL>@(#)0.0.0.0 $Revision$Class Spouses (>1)
# Supervisor
## CRUD-CLASSE ## EMPLOJNT
# 2018-11-06 07:06:06 716


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EMPLOJNT,ASTATUS)
Variable Instance EMPLOJNT Using C_EMPLOJNT
Variable Integer ASTATUS

If EMPLOJNT = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOJNT

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EMPLOJNT

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EMPLOJNT,ASTATUS)
Variable Instance EMPLOJNT Using C_EMPLOJNT
Variable Integer ASTATUS

If EMPLOJNT = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOJNT
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EMPLOJNT
Else
 Gosub ADELETE_EMPLOJNT
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EMPLOJNT,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EMPLOJNT.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOJNT.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EMPLOJNT
Trbegin [F:JNT]
 Gosub ADELETE_EMPLOJNT
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EMPLOJNT
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EMPLOJNT,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOJNT._MAJSQL_EMPLOJNT(EMPLOJNT))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EMPLOJNT.snapshotEnabled=1
 [L]A_RETIK = EMPLOJNT.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOJNT.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



