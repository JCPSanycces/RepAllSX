#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "OK"        : Gosub OK
 When "DEBUT"     : Gosub DEBUT
 When "FINSAI"    : Gosub FINSAI
Endcase
Return

$FINSAI
If ZONTXT="" : Return : Endif
# MAJ colone texte saisi oui/non
If FLG
 Assign ZONTXT With 2
Else
 Assign ZONTXT With 1
Endif
NBAFF=2
Return

$OUVRE
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
If clalev([F:BCB])=0 : Local File BCLOB    [BCB] : Endif
Local Char    SALARIE(GLONEML) , VARIA(GLONVRA)
Local Date    DATPAY
Local Char    ZONTXT (50)
Local Integer FLG
Local Char    BULLETIN(GLONVCR)
BULLETIN = PARAM(1)
VARIA    = PARAM(2)
ZONTXT   = PARAM(3)
Return

$DEBUT
Gosub CHARGE_TEXTE
Affzo [VTX]
Return

$CHARGE_TEXTE
Filter [BCB] Where CODBLB="VARTXT" & IDENT1=VARIA & IDENT2=BULLETIN
Read [BCB]BCB0 Last
Filter [BCB]
If !fstat
 [M]VARTXT    = [F:BCB]CLOB
 [M]SAVVARTXT = [F:BCB]CLOB
 FLG = 1
Else
 Raz[M]
Endif
Return

$OK
FLG=0
Delete [BCB] Where CODBLB="VARTXT" & IDENT1=VARIA & IDENT2=BULLETIN
If len([M]VARTXT)>0
 #Création des commentaires
 For [RUB]RUB0 Where LEG=GCURLEG and (TEXVRI(0)=VARIA or TEXVRI(1)=VARIA)
  Raz [F:BCB] : FLG=1
  [F:BCB]CLOB   = [M]VARTXT
  [F:BCB]CODBLB = "VARTXT"
  [F:BCB]IDENT1 = VARIA
  [F:BCB]IDENT2 = BULLETIN
  [F:BCB]IDENT3 = ""
  [F:BCB]IDENT4 = [F:RUB]COD
  If dim([F:BCB]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
  If dim([F:BCB]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
  If dim([F:BCB]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
  Write [BCB]
  If fstat : GOK = 0 : Call FSTA("BCB") From GLOCK : Break : Endif
 Next
 If FLG=0
 # Aucun texte de rubrique n'est associé à cette variable :
  GMESSAGE = mess(18,10703,1)-VARIA
  mkstat = 2 : Return
 Endif
Endif
Return

#DBA le 02/08/04 : Ajoute en fin de clob une chaine de caractères
Funprog CONCAT_CLOB(PCLOB,PTEXTE)
Value Clbfile PCLOB ()
Value Char PTEXTE ()
Local Char RESULTAT (250)(1..100)
Local Integer RESTE
#Chargement du clob dans la variable dimensionnée
Setlob RESULTAT With PCLOB
I=1
While len(RESULTAT(I))=250
 I+=1
Wend
RESTE=250-len(RESULTAT(I))
If RESTE<=len(PTEXTE)+1              :#+1 pour l'espace
 RESULTAT(I)-=left$(PTEXTE,RESTE-1) :#-1 pour l'espace
 RESULTAT(I+1)=seg$ (PTEXTE, RESTE, len(PTEXTE))
Else
 RESULTAT(I)-=PTEXTE
Endif
Setlob PCLOB With RESULTAT(1..I)
End PCLOB
