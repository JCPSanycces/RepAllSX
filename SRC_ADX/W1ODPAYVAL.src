Endif
If !mkstat
 ## Action STD
 Call C_ODPNUMFIN(VALEUR) From ODPAYVAL
 If mkstat : GERR = 1 : GZONE = "ODPNUMFIN" : GZNUM = 1001181 : Endif
Endif
