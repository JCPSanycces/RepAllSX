#<AdxTL>@(#)0.0.0.0 $Revision$Class Protocol
# Supervisor
## CRUD-CLASSE ## EDIPTC
# 2018-11-06 07:04:56 546


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EDIPTC,ASTATUS)
Variable Instance EDIPTC Using C_EDIPTC
Variable Integer ASTATUS

If EDIPTC = null : End : Endif

Gosub _AVARIABLES From WMC00EDIPTC

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EDIPTC

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EDIPTC,ASTATUS)
Variable Instance EDIPTC Using C_EDIPTC
Variable Integer ASTATUS

If EDIPTC = null : End : Endif

Gosub AVARIABLES From WMC00EDIPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EDIPTC
Else
 Gosub AINSERT_EDIPTC
Endif

Gosub _AINSERT_AFTER
[L]A_I = EDIPTC.freeSnapshot
EDIPTC.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EDIPTC._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EDIPTC._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EDIPTC._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EDIPTC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIPTC.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIPTC.EPTD) : # EDIPTCD -- 2
 If EDIPTC.EPTD(A_N2) <> null
& and !find(EDIPTC.EPTD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIPTC.EPTM) : # EDIPTCM -- 3
 If EDIPTC.EPTM(A_N2) <> null
& and !find(EDIPTC.EPTM(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER
For A_N2=1 To maxtab(EDIPTC.EPTD) : # EDIPTCD -- 2
 If EDIPTC.EPTD(A_N2) <> null
& and !find(EDIPTC.EPTD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIPTC.EPTM) : # EDIPTCM -- 3
 If EDIPTC.EPTM(A_N2) <> null
& and !find(EDIPTC.EPTM(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EDIPTC
Trbegin [F:EPT]
 Gosub AINSERT_EDIPTC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EDIPTC
Raz [F:EPT]
[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDIPTC._MAJSQL_EDIPTC(EDIPTC))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]A_TYPMAJ=[V]CST_ANEW

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIPTC.EPTD)
 If EDIPTC.EPTD(A_N2) <> null and
& (EDIPTC.EPTD(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIPTC.EPTD(A_N2).ASTALIN=[V]CST_ALL)
  If EDIPTC.EPTD(A_N2).ASTALIN=[L]A_TYPMAJ
   Raz [F:EPTD]
   [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION("AINSERT_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = func WMC00EDIPTC._MAJSQL_EDIPTCD(EDIPTC.EPTD(A_N2))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION("AINSERT_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIPTC.EPTM)
 If EDIPTC.EPTM(A_N2) <> null and
& (EDIPTC.EPTM(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIPTC.EPTM(A_N2).ASTALIN=[V]CST_ALL)
  If EDIPTC.EPTM(A_N2).ASTALIN=[L]A_TYPMAJ
   Raz [F:EPTM]
   [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION("AINSERT_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = func WMC00EDIPTC._MAJSQL_EDIPTCM(EDIPTC.EPTM(A_N2))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION("AINSERT_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EDIPTC.snapshotEnabled=1
 [L]A_RETIK = EDIPTC.revertUpdTick
Endif
[L]ASTATUS = max(fmet EDIPTC.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EDIPTC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EDIPTC.ASTALIN = [V]CST_ALL
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIPTC.EPTD)
 If EDIPTC.EPTD(A_N2) <> null
  If EDIPTC.EPTD(A_N2).ASTALIN=[V]CST_ADEL or EDIPTC.EPTD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIPTC.EPTD(A_N2)
   EDIPTC.EPTD(A_N2) = null
  Elsif EDIPTC.EPTD(A_N2).ASTALIN <> [V]CST_ALL
   EDIPTC.EPTD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIPTC.EPTM)
 If EDIPTC.EPTM(A_N2) <> null
  If EDIPTC.EPTM(A_N2).ASTALIN=[V]CST_ADEL or EDIPTC.EPTM(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIPTC.EPTM(A_N2)
   EDIPTC.EPTM(A_N2) = null
  Elsif EDIPTC.EPTM(A_N2).ASTALIN <> [V]CST_ALL
   EDIPTC.EPTM(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return



