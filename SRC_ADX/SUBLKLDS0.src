#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
# Gestion du masque LKLDS0
##########################################################################################################
Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR (30)

  SZVALEUR = VALEUR
  Gosub CHARGE_ADRESSE
End

##########################################################################################################
$CHARGE_ADRESSE

  If SZVALEUR = "" Then
    Return
  Endif

  Gosub RAZLKPST0
  If !clalev([F:BPA]) : Local File BPADDRESS[BPA] : Endif

Local Integer ILIGNE

  ILIGNE = 0
  For [BPA] Where [F:BPA]BPANUM=SZVALEUR and [F:BPA]BPATYP=1   
    [M:LLD0]CHOIX(ILIGNE)=1
    [M:LLD0]CODADR(ILIGNE)=[F:BPA]BPAADD
    [M:LLD0]BPADES(ILIGNE)=[F:BPA]BPADES
    [M:LLD0]ADDLIG1(ILIGNE)=[F:BPA]BPAADDLIG(0)
    [M:LLD0]POSCOD(ILIGNE)=[F:BPA]POSCOD
    [M:LLD0]CTY(ILIGNE)=[F:BPA]CTY
    [M:LLD0]BPACRY(ILIGNE)=[F:BPA]CRY
    [M:LLD0]ADDFLG(ILIGNE)=[F:BPA]BPAADDFLG
    [M:LLD0]EXISTE(ILIGNE)=1
    ILIGNE=ILIGNE+1
  Next
  If ILIGNE < dim([M:LLD0]CODADR) Then
    [M:LLD0]CHOIX(ILIGNE) = 1
    [M:LLD0]CODADR(ILIGNE) = ""
    [M:LLD0]BPADES(ILIGNE) = mess(469,177,1)
    [M:LLD0]ADDLIG1(ILIGNE) = ""
    [M:LLD0]POSCOD(ILIGNE) = ""
    [M:LLD0]CTY(ILIGNE) = ""
    [M:LLD0]BPACRY(ILIGNE) = ""
    [M:LLD0]ADDFLG(ILIGNE) = 1
    [M:LLD0]EXISTE(ILIGNE) = 0
    ILIGNE = ILIGNE + 1
  Endif
  [M:LLD0]NBBPA = ILIGNE
  Affzo [M:LLD0]
Return

##########################################################################################################
$RAZLKPST0
  Raz[M:LLD0]NBBPA
  Raz[M:LLD0]CHOIX
  Raz[M:LLD0]CODADR
  Raz[M:LLD0]BPADES
  Raz[M:LLD0]ADDLIG1
  Raz[M:LLD0]POSCOD
  Raz[M:LLD0]CTY
  Raz[M:LLD0]BPACRY
Return

##########################################################################################################
Subprog C_CHOIX(VALEUR)
Variable Integer VALEUR

  If VALEUR = 1 Then
    End
Endif

Local Integer NOLIGNSAVE
Local Integer ILIGNE

  NOLIGNSAVE = nolign
  ILIGNE = 0
  While ILIGNE< [M:LLD0]NBBPA
    If [M:LLD0]CHOIX(ILIGNE) = 2 and (ILIGNE <> (NOLIGNSAVE-1)) Then
      [M:LLD0]CHOIX(ILIGNE) = 1
      Affzo [M:LLD0]CHOIX(ILIGNE)
    Endif    
    ILIGNE=ILIGNE+1
  Wend
  nolign = NOLIGNSAVE
End

##########################################################################################################
Subprog AS_CODADR(VALEUR)
Variable Char    VALEUR()

  If [M:LLD0]EXISTE(nolign-1) = 1 Then
    mkstat = 2
  Endif
End

