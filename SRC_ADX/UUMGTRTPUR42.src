#<AdxTL>@(#)2.0.0.0 $Revision$
##################################################################################
# UUMGTRTPUR42   Reprise des signatures/Affectation utilisateur     Module Achats#
##################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
     Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR42") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR42(DOSSIER)
  Call MAJ_UUMGTRTPUR42(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


##########################################################################
Subprog RAZ_UUMGTRTPUR42(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Local Char WNAMPADM,WNAMPAPM,WNAMPACM
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPRECORD",WNAMPADM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPROVAL",WNAMPAPM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPCONF",WNAMPACM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPADM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMPAPM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMPACM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif

##2 - On vide les fichiers selon le cas
#######################################

Local File =DOSSIER+".AWRKREGVAL"  [AWV]
Trbegin [AWV]
Delete [AWV] Where REGLE="PSDSIG"
Commit
Trbegin [AWV]
Delete [AWV] Where REGLE="POHSIG"
Commit
Trbegin [AWV]
Delete [AWV] Where REGLE="POCSIG"
Commit

Local File =DOSSIER+".AWRKUSR"  [AWU]
# Issue 108760 - 2015-06-12 by SR : adaptation
If func DOSVUE.ISVIEW(DOSSIER,"AWRKUSR")<> 1
  Trbegin [AWU]
  Delete [AWU] Where NATURE=""
  Commit
Endif
# End issue 108760

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR42",ERR) From TRTMIG

End


##############################################################################################
##############################################################################################
Subprog MAJ_UUMGTRTPUR42(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR
Local Integer TOTNBR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR42",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR42",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMPADM,WNAMPAPM,WNAMPACM
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPRECORD",WNAMPADM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPROVAL",WNAMPAPM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPCONF",WNAMPACM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR42",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#

If filinfo(filpath("FIL",WNAMPADM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR42",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPAPM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR42",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPACM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR42",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################
Gosub MIG_OUVRE From TRTMIG

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR42",2,ERR) From TRTMIG : #2=En cours
Call MIGGETTOTNBR (DOSSIER,"PAPPROVAL",TOTNBR,ERR) From TRTMIG : #gerer nb lignes a traiter
Trbegin [AMY]
Call MIGSTKTOTNBR (DOSSIER,"UUMGTRTPUR42",TOTNBR,ERR) From TRTMIG
Commit

###################

Local Char WTAB_AWV (50) (adxwrb)
Local Char WTAB_AWU (50) (adxwrb)
Local Shortint WCPT_AWV,WCPT_AWU

Call ECR_TIME("UUMGTRTPUR42 tables Approval rule's values Process : Write AWRKREGVAL") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR42 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"AWRKREGVAL",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"AWRKUSR",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:AWV])  = 0 : Local File =DOSSIER+".AWRKREGVAL"    [AWV]  : Endif   # Fichier X3 "Vide"
If clalev([F:AWU])  = 0 : Local File =DOSSIER+".AWRKUSR"       [AWU]  : Endif   # Fichier X3 "Vide"
If clalev([F:AWR])  = 0 : Local File =DOSSIER+".AWRKREG"       [AWR]  : Endif   # Fichier X3 pour MAJ

If clalev([F:PAPM]) = 0 : Local File =DOSSIER+"."+WNAMPAPM   [PAPM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:PACM]) = 0 : Local File =DOSSIER+"."+WNAMPACM   [PACM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=6
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_PUR09AWV

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR42",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  FILTER -----#
Filter [PAPM] Order By Key CLE=[F:PAPM]CPY;[F:PAPM]APPRUL;[F:PAPM]APPCRI;[F:PAPM]MAXVAL;[F:PAPM]FBUFLG

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR42" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_PAP00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PAPM]CPY=TABMIGKEY(1) & [F:PAPM]APPRUL=val(TABMIGKEY(2)) & [F:PAPM]APPCRI=TABMIGKEY(3) & [F:PAPM]MAXVAL=val(TABMIGKEY(4)) & [F:PAPM]FBUFLG>val(TABMIGKEY(5))"
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:PAPM]CPY=TABMIGKEY(1) & [F:PAPM]APPRUL=val(TABMIGKEY(2)) & [F:PAPM]APPCRI=TABMIGKEY(3) & [F:PAPM]MAXVAL>val(TABMIGKEY(4))"
Elsif STOP=3
 STOP = 4
 CRITERE = "[F:PAPM]CPY=TABMIGKEY(1) & [F:PAPM]APPRUL=val(TABMIGKEY(2)) & [F:PAPM]APPCRI>TABMIGKEY(3)"
Elsif STOP=4
 STOP = 5
 CRITERE = "[F:PAPM]CPY=TABMIGKEY(1) & [F:PAPM]APPRUL>val(TABMIGKEY(2))"
Elsif STOP=5
 STOP = 0
 CRITERE = "[F:PAPM]CPY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [AWV]
GOK = 1

For [PAPM]CLE(2) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

  For [PAPM]CLE
    NBLUS+=1

    # PE pour exclure ligne
    If FILTRELIN
        FLUX="UUMGTRTPUR42" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
        If ISVALID=0 : Break : Endif
    Endif

    #Appel proc de migration
    #  version < V6, traitement v6
    If val(VERSION)<GMIGX3VER60
      Gosub MAJV6_AWV
      If GOK<1 : Break : Endif
    Endif
    #  version < V7, traitement v7
    If val(VERSION)<GMIGX3VER70
      Gosub MAJV7_AWV
      If GOK<1 : Break : Endif
    Endif

    # --- alimentation des champs et écriture enreg
# Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#    If NEWMOTEUR
#        Gosub AWV_STK : # pour stocker ref
#        WriteB [F:AWV]
#    Else
#        Write [F:AWV]
#    Endif
#    If fstat
#      If NEWMOTEUR & adxwrb>1
#        Call ECR_TRACE("File AWRKREGVAL, Error ="-num$(fstat),1) From GESECRAN
#        Gosub AWV_ERRTRA : # pour afficher les ref
#      Else
#        Call ECR_TRACE("File AWRKREGVAL(CPY/REGLE/NUMLIG)"-[F:AWV]CPY-[F:AWV]REGLE-num$([F:AWV]NUMLIG)+", Error ="-num$(fstat),1) From GESECRAN
#      Endif
#      GOK=0 : Break
#    Endif
     Gosub AWV_STK : # pour stocker ref
     WriteB [F:AWV]
     If fstat
        Call ECR_TRACE("File AWRKREGVAL, Error ="-num$(fstat),1) From GESECRAN
        Gosub AWV_ERRTRA : # pour afficher les ref
        GOK=0 : Break
     Endif
     # End issue 108760

    NB+=1
  Next
  If GOK<1 : Break : Endif
  If ISVALID=0 : Goto SUITE_BOUCLEAWV : Endif

  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:PAPM]CPY
    TABMIGKEY(2) = num$([F:PAPM]APPRUL)
    TABMIGKEY(3) = [F:PAPM]APPCRI
    TABMIGKEY(4) = num$([F:PAPM]MAXVAL)
    TABMIGKEY(5) = num$([F:PAPM]FBUFLG)
    STOP=1
    Break
  Endif
$SUITE_BOUCLEAWV
Next

$FIN_BOUCLEAWV
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR42",7,ERR) From TRTMIG : #7=Erreur
Else
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:AWV]
    If fstat
        Call ECR_TRACE("File AWRKREGVAL, Error ="-num$(fstat),1) From GESECRAN
        Gosub AWV_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEAWV : #on part sur rollback
    Endif
 # Endif
 # End issue 108760
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR42",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLEAWV
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR42",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_PAP00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [AWV]
Close Local File [PAPM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"AWRKREGVAL",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"AWRKUSR",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR42") From TRTMIG
Call ECR_TIME("UUMGTRTPUR42 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$OUVRE_PUR09AWV
Local Char     RUPTURE(GLONAWR+GLONCPY+1), WREGLE(GLONAWR), WCPY(GLONCPY)
Local Char     WUSER(GLONAUS), WUSRDEL(GLONAUS)
Local Integer  WNUMLIG, I, J, K, WNBUSR, WNBSBUSR
Return
################################################
$AWV_STK
Call STK (WTAB_AWV,WCPT_AWV,[F:AWV]REGLE+'/'+[F:AWV]CPY+'/'+num$([F:AWV]NUMLIG)) From TRTMIG
Return
$AWU_STK
Call STK (WTAB_AWU,WCPT_AWU,[F:AWU]USER+'/'+num$([F:AWU]NUMDEL)) From TRTMIG
Return
##############################################################################################
$AWV_ERRTRA
Call ERRTRA (WTAB_AWV,WCPT_AWV,"File AWRKREGVAL(REGLE/CPY/NUMLIG)=") From TRTMIG
Return
$AWU_ERRTRA
Call ERRTRA (WTAB_AWU,WCPT_AWU,"File AWRKUSR(USER/NUMDEL)=") From TRTMIG
Return

##############################################################################################
$MAJV6_AWV
    If [F:PACM]CPY<>[F:PAPM]CPY | [F:PACM]APPRUL<>[F:PAPM]APPRUL
      Read [PACM]PAC0=[F:PAPM]CPY;[F:PAPM]APPRUL
      If fstat  Raz [F:PACM] : Endif
    Endif

    Case [F:PAPM]APPRUL
      When 1 : WREGLE="PSDSIG"
      When 2 : WREGLE="POHSIG"
      When 3 : WREGLE="POCSIG"
    Endcase
    WCPY=[F:PAPM]CPY
    If RUPTURE=""
      RUPTURE=WREGLE+"~"+WCPY
    Endif
    If RUPTURE<>WREGLE+"~"+WCPY
      Raz WNUMLIG
    Endif
    WNUMLIG+=1

    If [F:AWR]CPY<>WCPY | [F:AWR]REGLE<>WREGLE
      Read [AWR]AWR0=WCPY;WREGLE
      If !fstat
        WNBUSR=0
        For I=0 To dim([F:AWV]USER)-1
          If evalue("[F:PAPM]APPUSR"+num$(I+1))<>""
            WNBUSR+=1
          Endif
        Next I
        WNBSBUSR=0
        For I=0 To dim([F:AWV]USER)-1
          If evalue("[F:PAPM]SBSAPPUSR"+num$(I+1))<>""
            WNBSBUSR+=1
          Endif
        Next I
        If WNBUSR<WNBSBUSR : WNBUSR=WNBSBUSR : Endif
        If [F:AWR]NBRUSR<WNBUSR
           [F:AWR]NBRUSR=WNBUSR
           Rewrite [F:AWR]
        Endif
      Endif
    Endif

    ##Look [AWV] AWV0=WREGLE;WCPY;WNUMLIG
    ##If fstat
      Raz [F:AWV]
      [F:AWV]REGLE =WREGLE
      [F:AWV]CPY   =WCPY
      [F:AWV]NUMLIG=WNUMLIG
      For I=0 To dim([F:AWV]USER)-1
        If evalue("[F:PAPM]SAPFLG"+num$(I+1))<>1
          WUSER  =evalue("[F:PAPM]APPUSR"+num$(I+1))
          WUSRDEL=evalue("[F:PAPM]SBSAPPUSR"+num$(I+1))
        Else
          WUSER  =evalue("[F:PAPM]SBSAPPUSR"+num$(I+1))
          WUSRDEL=evalue("[F:PAPM]APPUSR"+num$(I+1))
        Endif
        [F:AWV]USER(I)=WUSER
        # Issue 108760 - 2015-06-12 by SR : adaptation
        If func DOSVUE.ISVIEW(DOSSIER,"AWRKUSR")<> 1
          If WUSRDEL<>""
            Filter [AWU] Where USER=WUSER & USRDEL=WUSRDEL
            Read [AWU] AWU0 First
            If fstat
              Filter [AWU] Where USER=WUSER
              Read [AWU] AWU0 Last : If fstat  Raz [F:AWU] : Endif
              Filter [AWU]
              If [F:AWU]NUMDEL<99
                [F:AWU]USER=WUSER
                [F:AWU]NUMDEL+=1
                [F:AWU]USRDEL=WUSRDEL
                [F:AWU]TYPDEL=2
                Raz [F:AWU]NATURE, [F:AWU]VLYSTR, [F:AWU]VLYEND
                Write [AWU]
                If fstat
                  Call ECR_TRACE("File AWRKUSR"-WUSER+", ERROR ="-num$(fstat),1) From GESECRAN
                  GOK=0
                Endif
              Endif
            Else
              Filter [AWU]
            Endif
          Endif
        Endif
        # End issue 108760
      Next I
      I=1 : J=1 : K=0
      If [F:PACM]FIL(0)<>""
        While J>0
          J=instr(I,[F:PAPM]APPCRI,"~")
          If J>I
            [F:AWV]VALREG(K)=mid$([F:PAPM]APPCRI,I,J-I) : K+=1
          Else J=I
            [F:AWV]VALREG(K)="*" : K+=1
          Endif
          I=J+1
          If K>4 | [F:PACM]FIL(K)=""  J=0 : Endif
        Wend
      Endif
      [F:AWV]VALREG(K)=num$([F:PAPM]MAXVAL) : K+=1
      If [F:PAPM]FBUFLG>0
        [F:AWV]VALREG(K)=num$([F:PAPM]FBUFLG) : K+=1
      Endif
    ##Endif
    RUPTURE=WREGLE+"~"+WCPY
Return

##############################################################################################
$MAJV7_AWV
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR42(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR42(APPLI)
End

