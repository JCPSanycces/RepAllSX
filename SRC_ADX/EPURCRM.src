      Call ECR_TRACE(mess(901,182,1) - ":" - [F:F1]TSKNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [HD6] Where [F:HD6]NUM = [F:F1]TSKNUM and [F:HD6]TYP = "TSKOBJ"
      If ![L]SIMUL Then
        Raz [F:HD61]
        [F:HD61] = [F:HD6]
        If dim([F:HD61]CREHISDAT)>0 : [F:HD61]CREHISDAT = date$    : Endif
        If dim([F:HD61]CREHISUSR)>0 : [F:HD61]CREHISUSR = [V]GUSER : Endif
        Write [F:HD61]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$HD6CLOB" - [F:F1]TSKNUM - [F:HD61]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(902,182,1) - ":" - [F:F1]TSKNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [HD6] Where [F:HD6]NUM = [F:F1]TSKNUM and [F:HD6]TYP = "TSKOBJ"
    If fstat Then
      Call ECR_TRACE("$HD6CLOB" - [F:F1]TSKNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  #Compte-rendu
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(901,182,1) - ":" - [F:F1]TSKNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [HD4] Where [F:HD4]NUM = [F:F1]TSKNUM and [F:HD4]TYP = "TSKRPO"
      If ![L]SIMUL Then
        Raz [F:HD41]
        [F:HD41] = [F:HD4]
        If dim([F:HD41]CREHISDAT)>0 : [F:HD41]CREHISDAT = date$    : Endif
        If dim([F:HD41]CREHISUSR)>0 : [F:HD41]CREHISUSR = [V]GUSER : Endif
        Write [F:HD41]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$HD4CLOB" - [F:F1]TSKNUM - [F:HD41]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(902,182,1) - ":" - [F:F1]TSKNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [HD4] Where [F:HD4]NUM = [F:F1]TSKNUM and [F:HD4]TYP = "TSKRPO"
    If fstat Then
      Call ECR_TRACE("$HD4CLOB" - [F:F1]TSKNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
