##########################################################################################################
#    Epuration des scripts d'appels                                             #
# ------------------------------------------------------------------------------#
#    SCP : Actions liées à l'épuration des script d'appels                      #
##########################################################################################################
$OUVRE_SCP
  Gosub DECLARE_VARIABLES
  If HISTO Then
    If OKEPU = 0 Then
      If clalev([F:SCA]) = 0 : Local File =[L]APPLI + ".SCPASW"      [SCA]  : Endif
      TABLE = "SCPASW"
      Gosub CRETAB_HISTO
      If clalev([F:SCA1])= 0 : Local File =[L]HISAPL + ".SCPASW"     [SCA1] : Endif
    Else
      If clalev([F:SCA]) = 0 : Local File =[L]HISAPL + ".SCPASW"     [SCA]  : Endif
    Endif
  Else
    If clalev([F:SCA]) = 0 : Local File =[L]APPLI + ".SCPASW"        [SCA]  : Endif
  Endif
Return

##########################################################################################################
$FILTRE_SCP
Return

##########################################################################################################
$CONTROL_SCP
Return

##########################################################################################################
$HIS_EPU_SCP
  #CHECK FILE_DECLARE SCRIPT [F1]
  # -------------------------------------
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(1,13,1) - ":" - [F:F1]SCPNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
  Endif
  # -------------------------------------
  Gosub CONTROL_SCP
  If OKHIS = 0 and OKEPU = 0 Then
    Return
  Endif
  # -------------------------------------
  #Réponses
  If [L]OKHIS and [L]OKEPU = 0 Then
    For [SCA] Where [F:SCA]SCP = [F:F1]SCPNUM
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(762,182,1) - ":" - [F:SCA]CLL - [F:F1]SCPNUM - [F:SCA]QST - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      If ![L]SIMUL Then
        Raz [F:SCA1]
        [F:SCA1] = [F:SCA]
        If dim([F:SCA1]CREHISDAT)>0 : [F:SCA1]CREHISDAT = date$    : Endif
        If dim([F:SCA1]CREHISUSR)>0 : [F:SCA1]CREHISUSR = [V]GUSER : Endif
        Write [F:SCA1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$SCPASW" - [F:SCA]CLL - [F:F1]SCPNUM - [F:SCA]QST - mess(13,100,1),1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [SCA] Where [F:SCA]SCP = [F:F1]SCPNUM
      Call ECR_TRACE(mess(763,182,1) - ":" - [F:SCA]CLL - [F:F1]SCPNUM - [F:SCA]QST - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Next
  Endif
  If ![L]SIMUL Then
    Delete [SCA] Where [F:SCA]SCP = [F:F1]SCPNUM
    If fstat Then
      Call ECR_TRACE("$SCPASW" - [F:F1]SCPNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$FERME_SCP
  If clalev([F:SCA])  : Close Local File [SCA]  : Endif
  If clalev([F:SCA1]) : Close Local File [SCA1] : Endif
Return

