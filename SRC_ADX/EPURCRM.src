    Call ECR_TRACE(mess(1,13,1) - ":" - [F:F1]TSKNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
  Endif
  # -------------------------------------
  Gosub CONTROL_TSK
  If OKHIS = 0 and OKEPU = 0 Then
