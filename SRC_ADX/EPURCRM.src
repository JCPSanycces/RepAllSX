##########################################################################################################
$HIS_EPU_CLL
Local Char SF1CLLNUM(type([F:F1]CLLNUM)-10)
Local Char SF1MKTNUM(type([F:F1]CLLNUM)-10)
Local Char SF1TYPFULOBJ(GLONCLT)

  #CHECK FILE_DECLARE PHONECALL [F1]
  # ---------------------------
  SF1CLLNUM = [F:F1]CLLNUM
  SF1MKTNUM = [F:F1]CLLNUM
  SF1TYPFULOBJ = [F:F1]TYPFULOBJ
  # ---------------------------
  Gosub HIS_EPU_CLL_GENERIQUE
  If OKHIS = 0 and OKEPU = 0 Then
    Return
  Endif
  # ---------------------------
Return

##########################################################################################################
$HIS_EPU_CLL_GENERIQUE
  # -------------------------------------
  If SF1TYPFULOBJ <> "CLLOBJ" and SF1TYPFULOBJ <> "OMP" and SF1TYPFULOBJ <> "CMG" Then
    SF1TYPFULOBJ = "CLLOBJ"
  Endif
  # -------------------------------------
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(1,13,1) - ":" - SF1CLLNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
  Endif
  # -------------------------------------
  Gosub CONTROL_CLL
  If OKHIS = 0 and OKEPU = 0 Then
    Return
  Endif
  # -------------------------------------
  #Objet
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(901,182,1) - ":" - SF1CLLNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    Filter [HD5] Where [F:HD5]NUM = SF1MKTNUM and [F:HD5]TYP = SF1TYPFULOBJ
    For [HD5]
      If ![L]SIMUL Then
        Raz [F:HD51]
        [F:HD51] = [F:HD5]
        If dim([F:HD51]CREHISDAT)>0 : [F:HD51]CREHISDAT = date$    : Endif
        If dim([F:HD51]CREHISUSR)>0 : [F:HD51]CREHISUSR = [V]GUSER : Endif
        Write [F:HD51]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$HD5CLOB" - SF1CLLNUM - [F:HD51]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    Filter [HD5]
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(902,182,1) - ":" - SF1CLLNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [HD5] Where [F:HD5]NUM = SF1CLLNUM and [F:HD5]TYP = SF1TYPFULOBJ
    If fstat Then
      Call ECR_TRACE("$HD5CLOB" - SF1CLLNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  #Compte-rendu
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(901,182,1) - ":" - SF1CLLNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [HD4] Where [F:HD4]NUM = SF1CLLNUM and [F:HD4]TYP = "CLLRPO"
      If ![L]SIMUL Then
        Raz [F:HD41]
        [F:HD41] = [F:HD4]
        If dim([F:HD41]CREHISDAT)>0 : [F:HD41]CREHISDAT = date$    : Endif
        If dim([F:HD41]CREHISUSR)>0 : [F:HD41]CREHISUSR = [V]GUSER : Endif
        Write [F:HD41]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$HD4CLOB" - SF1CLLNUM - [F:HD41]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(902,182,1) - ":" - SF1CLLNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [HD4] Where [F:HD4]NUM = SF1CLLNUM and [F:HD4]TYP = "CLLRPO"
    If fstat Then
      Call ECR_TRACE("$HD4CLOB" - SF1CLLNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  #Tentatives d'appels
  If [L]OKHIS and [L]OKEPU = 0 Then
    For [CTT] Where [F:CTT]CLLNUM = SF1CLLNUM
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(747,182,1) - ":" - SF1CLLNUM - [F:CTT]CTTNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      If ![L]SIMUL Then
        Raz [F:CTT1]
        [F:CTT1] = [F:CTT]
        If dim([F:CTT1]CREHISDAT)>0 : [F:CTT1]CREHISDAT = date$    : Endif
        If dim([F:CTT1]CREHISUSR)>0 : [F:CTT1]CREHISUSR = [V]GUSER : Endif
        Write [F:CTT1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$CALLATTEMP" - [F:CTT1]CLLNUM - [F:CTT1]CTTNUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [CTT] Where [F:CTT]CLLNUM = SF1CLLNUM
      Call ECR_TRACE(mess(750,182,1) - ":" - SF1CLLNUM - [F:CTT]CTTNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Next
  Endif
  If ![L]SIMUL Then
    Delete [CTT] Where [F:CTT]CLLNUM = SF1CLLNUM
    If fstat Then
      Call ECR_TRACE("$CALLATTEMP" - SF1CLLNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$FERME_CLL
  If clalev([F:CTT])   Close Local File [CTT]  : Endif
  If clalev([F:CTT1])  Close Local File [CTT1] : Endif
  If clalev([F:HD4])   Close Local File [HD4]  : Endif
  If clalev([F:HD41])  Close Local File [HD41] : Endif
  If clalev([F:HD5])   Close Local File [HD5]  : Endif
  If clalev([F:HD51])  Close Local File [HD51] : Endif
Return

##########################################################################################################
#    Epuration des rendez-vous                                                  #
# ------------------------------------------------------------------------------#
#    BAP : Actions liées à l'épuration des rendez-vous                          #
##########################################################################################################
$OUVRE_BAP
  Gosub DECLARE_VARIABLES
  If HISTO Then
    If OKEPU = 0 Then
      If clalev([F:RRS]) = 0 : Local File =[L]APPLI + ".RESRES"      [RRS]  : Endif
      If clalev([F:HD4]) = 0 : Local File =[L]APPLI + ".HD4CLOB"     [HD4]  : Endif
      If clalev([F:HD6]) = 0 : Local File =[L]APPLI + ".HD6CLOB"     [HD6]  : Endif
      TABLE = "RESRES"
      Gosub CRETAB_HISTO
      If clalev([F:RRS1])= 0 : Local File =[L]HISAPL + ".RESRES"     [RRS1] : Endif
      TABLE = "HD4CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD41])= 0 : Local File =[L]HISAPL + ".HD4CLOB"    [HD41] : Endif
      TABLE = "HD6CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD61])= 0 : Local File =[L]HISAPL + ".HD6CLOB"    [HD61] : Endif
    Else
      If clalev([F:RRS]) = 0 : Local File =[L]HISAPL + ".RESRES"     [RRS]  : Endif
      If clalev([F:HD4]) = 0 : Local File =[L]HISAPL + ".HD4CLOB"    [HD4]  : Endif
      If clalev([F:HD6]) = 0 : Local File =[L]HISAPL + ".HD6CLOB"    [HD6]  : Endif
    Endif
  Else
    If clalev([F:RRS]) = 0 : Local File =[L]APPLI + ".RESRES"        [RRS]  : Endif
    If clalev([F:HD4]) = 0 : Local File =[L]APPLI + ".HD4CLOB"       [HD4]  : Endif
    If clalev([F:HD6]) = 0 : Local File =[L]APPLI + ".HD6CLOB"       [HD6]  : Endif
  Endif
Return

##########################################################################################################
$FILTRE_BAP
Return

##########################################################################################################
$CONTROL_BAP
Return

##########################################################################################################
$HIS_EPU_BAP
  #CHECK FILE_DECLARE BAPPOINT [F1]
  # -------------------------------------
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(1,13,1) - ":" - [F:F1]APTNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
  Endif
  # -------------------------------------
  Gosub CONTROL_BAP
  If OKHIS = 0 and OKEPU = 0 Then
    Return
  Endif
  # -------------------------------------
  #Objet
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(901,182,1) - ":" - [F:F1]APTNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [HD6] Where [F:HD6]NUM = [F:F1]APTNUM and [F:HD6]TYP = "BAPOBJ"
      If ![L]SIMUL Then
        Raz [F:HD61]
        [F:HD61] = [F:HD6]
        If dim([F:HD61]CREHISDAT)>0 : [F:HD61]CREHISDAT = date$    : Endif
        If dim([F:HD61]CREHISUSR)>0 : [F:HD61]CREHISUSR = [V]GUSER : Endif
        Write [F:HD61]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$HD6CLOB" - [F:F1]APTNUM - [F:HD61]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(902,182,1) - ":" - [F:F1]APTNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [HD6] Where [F:HD6]NUM = [F:F1]APTNUM and [F:HD6]TYP = "BAPOBJ"
    If fstat Then
      Call ECR_TRACE("$HD6CLOB" - [F:F1]APTNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  #Compte-rendu
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(901,182,1) - ":" - [F:F1]APTNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [HD4] Where [F:HD4]NUM = [F:F1]APTNUM and [F:HD4]TYP = "BAPRPO"
      If ![L]SIMUL Then
        Raz [F:HD41]
        [F:HD41] = [F:HD4]
        If dim([F:HD41]CREHISDAT)>0 : [F:HD41]CREHISDAT = date$    : Endif
        If dim([F:HD41]CREHISUSR)>0 : [F:HD41]CREHISUSR = [V]GUSER : Endif
        Write [F:HD41]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$HD4CLOB" - [F:F1]APTNUM - [F:HD41]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(902,182,1) - ":" - [F:F1]APTNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [HD4] Where [F:HD4]NUM = [F:F1]APTNUM and [F:HD4]TYP = "BAPRPO"
    If fstat Then
      Call ECR_TRACE("$HD4CLOB"- [F:F1]APTNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  # Réservation ressources
  If [L]OKHIS and [L]OKEPU = 0 Then
    For [RRS]RRS1 Where [F:RRS]RRSORI = 2 and [F:RRS]RRSORIVCR = [F:F1]APTNUM
      If [L]TRACEDET Then
        Call ECR_TRACE(mess(751,182,1) - ":" - [F:F1]APTNUM - [F:RRS]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
      Endif
      If ![L]SIMUL Then
        Raz [F:RRS1]
        [F:RRS1] = [F:RRS]
        If dim([F:RRS1]CREHISDAT)>0 : [F:RRS1]CREHISDAT = date$    : Endif
        If dim([F:RRS1]CREHISUSR)>0 : [F:RRS1]CREHISUSR = [V]GUSER : Endif
        Write [F:RRS1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$RESRES" - [F:F1]APTNUM - [F:RRS1]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [RRS]RRS1 Where [F:RRS]RRSORI = 2 and [F:RRS]RRSORIVCR = [F:F1]APTNUM
      Call ECR_TRACE(mess(754,182,1) - ":" - [F:RRS]NUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Next
  Endif
  If ![L]SIMUL Then
    Delete [RRS] Where [F:RRS]RRSORI = 2 and [F:RRS]RRSORIVCR = [F:F1]APTNUM
    If fstat Then
      Call ECR_TRACE("$RESRES" - [F:F1]APTNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$FERME_BAP
  If clalev([F:RRS])   Close Local File [RRS]  : Endif
  If clalev([F:RRS1])  Close Local File [RRS1] : Endif
  If clalev([F:HD4])   Close Local File [HD4]  : Endif
  If clalev([F:HD41])  Close Local File [HD41] : Endif
  If clalev([F:HD6])   Close Local File [HD6]  : Endif
  If clalev([F:HD61])  Close Local File [HD61] : Endif
Return

