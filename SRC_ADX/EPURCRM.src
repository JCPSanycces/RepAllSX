#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
#      TRAITEMENTS EPURATION Module CRM                26 novembre 2003                                  #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE_EPURE
    When "FILTRE"      : Gosub FILTRE
    When "HISTO"       : Gosub HISTO
    When "EPURE"       : Gosub EPURE
    When "FERME"       : Gosub FERME_EPURE
  Endcase
Return

##########################################################################################################
#    OUVRE_EPURE
##########################################################################################################
$OUVRE_EPURE
  Case [F:AHI]COD
    When "CLL"    :    Gosub OUVRE_CLL
    When "BAP"    :    Gosub OUVRE_BAP
    When "OPP"    :    Gosub OUVRE_OPP
    When "SCP"    :    Gosub OUVRE_SCP
    When "MQR"    :    Gosub OUVRE_MQR
    When "CMG"    :    Gosub OUVRE_CMG From EPURCRM1
    When "TSK"    :    Gosub OUVRE_TSK
    When "LDS"    :    Gosub OUVRE_LDS
  Endcase
Return

##########################################################################################################
#    FILTRE
##########################################################################################################
$FILTRE
  Case [F:AHI]COD
    When "CLL"    :    Gosub FILTRE_CLL
    When "BAP"    :    Gosub FILTRE_BAP
    When "OPP"    :    Gosub FILTRE_OPP
    When "SCP"    :    Gosub FILTRE_SCP
    When "MQR"    :    Gosub FILTRE_MQR
    When "CMG"    :    Gosub FILTRE_CMG From EPURCRM1
    When "TSK"    :    Gosub FILTRE_TSK
    When "LDS"    :    Gosub FILTRE_LDS
  Endcase
Return

##########################################################################################################
#    HISTO
##########################################################################################################
$HISTO
  Case [F:AHI]COD
    When "CLL"    :    Gosub HIS_EPU_CLL
    When "BAP"    :    Gosub HIS_EPU_BAP
    When "OPP"    :    Gosub HIS_EPU_OPP
    When "SCP"    :    Gosub HIS_EPU_SCP
    When "MQR"    :    Gosub HIS_EPU_MQR
    When "CMG"    :    Gosub HISTO_CMG From EPURCRM1
    When "TSK"    :    Gosub HIS_EPU_TSK
    When "LDS"    :    Gosub HIS_EPU_LDS
  Endcase
Return

##########################################################################################################
#    EPURE
##########################################################################################################
$EPURE
  Case [F:AHI]COD
    When "CLL"    :    Gosub HIS_EPU_CLL
    When "BAP"    :    Gosub HIS_EPU_BAP
    When "OPP"    :    Gosub HIS_EPU_OPP
    When "SCP"    :    Gosub HIS_EPU_SCP
    When "MQR"    :    Gosub HIS_EPU_MQR
    When "CMG"    :    Gosub EPURE_CMG From EPURCRM1
    When "TSK"    :    Gosub HIS_EPU_TSK
    When "LDS"    :    Gosub HIS_EPU_LDS
  Endcase
Return

##########################################################################################################
#    FERME_EPURE
##########################################################################################################
$FERME_EPURE
  Case [F:AHI]COD
    When "CLL"    :    Gosub FERME_CLL
    When "BAP"    :    Gosub FERME_BAP
    When "OPP"    :    Gosub FERME_OPP
    When "SCP"    :    Gosub FERME_SCP
    When "MQR"    :    Gosub FERME_MQR
    When "CMG"    :    Gosub FERME_CMG From EPURCRM1
    When "TSK"    :    Gosub FERME_TSK
    When "LDS"    :    Gosub FERME_LDS
  Endcase
Return

##########################################################################################################
# Création d'une table dans le dossier fille.
##########################################################################################################
$CRETAB_HISTO
  #--- Création des tables non liées
  OK = 0
  If filinfo(filpath("FIL",TABLE,"fde",HISAPL),0) < 0 Then
    OK = 1
  Else
    Call VUE_OK(TABLE, HISAPL, "FIL", OK) From DOSVUE
  Endif
  If OK Then
    NEWTAB = TABLE
    Call CRETABLE(APPLI, HISAPL, TYPDBA, NEWTAB, COEFF, 0) From CREHISTO
  Endif
  OK = 1
Return

##########################################################################################################
$DECLARE_VARIABLES
Local Integer IERRINF

  IERRINF = 0
Return

##########################################################################################################
#    Epuration des appels                                                       #
# ------------------------------------------------------------------------------#
#    CLL : Actions liées à l'épuration des appels                               #
##########################################################################################################
$OUVRE_CLL
  Gosub DECLARE_VARIABLES
  If HISTO Then
    If OKEPU = 0 Then
      If clalev([F:CTT]) = 0 : Local File =[L]APPLI + ".CALLATTEMP"  [CTT] : Endif
      If clalev([F:HD4]) = 0 : Local File =[L]APPLI + ".HD4CLOB"     [HD4] : Endif
      If clalev([F:HD5]) = 0 : Local File =[L]APPLI + ".HD5CLOB"     [HD5] : Endif
      TABLE = "CALLATTEMP"
      Gosub CRETAB_HISTO
      If clalev([F:CTT1])= 0 : Local File =[L]HISAPL + ".CALLATTEMP" [CTT1] : Endif
      TABLE = "HD4CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD41])= 0 : Local File =[L]HISAPL + ".HD4CLOB"    [HD41] : Endif
      TABLE = "HD5CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD51])= 0 : Local File =[L]HISAPL + ".HD5CLOB"    [HD51] : Endif
    Else
      If clalev([F:CTT]) = 0 : Local File =[L]HISAPL + ".CALLATTEMP" [CTT] : Endif
      If clalev([F:HD4]) = 0 : Local File =[L]HISAPL + ".HD4CLOB"    [HD4] : Endif
      If clalev([F:HD5]) = 0 : Local File =[L]HISAPL + ".HD5CLOB"    [HD5] : Endif
    Endif
  Else
    If clalev([F:CTT]) = 0 : Local File =[L]APPLI + ".CALLATTEMP"    [CTT] : Endif
    If clalev([F:HD4]) = 0 : Local File =[L]APPLI + ".HD4CLOB"       [HD4] : Endif
    If clalev([F:HD5]) = 0 : Local File =[L]APPLI + ".HD5CLOB"       [HD5] : Endif
  Endif
Return

##########################################################################################################
$FILTRE_CLL
Return

##########################################################################################################
$CONTROL_CLL
Return

