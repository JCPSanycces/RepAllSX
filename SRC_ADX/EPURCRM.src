##########################################################################################################
$OUVRE_TSK
  Gosub DECLARE_VARIABLES
  If HISTO Then
    If OKEPU = 0 Then
      If clalev([F:HD4]) = 0 : Local File =[L]APPLI + ".HD4CLOB"     [HD4]  : Endif
      If clalev([F:HD6]) = 0 : Local File =[L]APPLI + ".HD6CLOB"     [HD6]  : Endif
      TABLE = "HD4CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD41])= 0 : Local File =[L]HISAPL + ".HD4CLOB"    [HD41] : Endif
      TABLE = "HD6CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD61])= 0 : Local File =[L]HISAPL + ".HD6CLOB"    [HD61] : Endif
    Else
      If clalev([F:HD4]) = 0 : Local File =[L]HISAPL + ".HD4CLOB"    [HD4]  : Endif
      If clalev([F:HD6]) = 0 : Local File =[L]HISAPL + ".HD6CLOB"    [HD6]  : Endif
    Endif
  Else
    If clalev([F:HD4]) = 0 : Local File =[L]APPLI + ".HD4CLOB"       [HD4]  : Endif
    If clalev([F:HD6]) = 0 : Local File =[L]APPLI + ".HD6CLOB"       [HD6]  : Endif
  Endif
Return

##########################################################################################################
$FILTRE_TSK
Return

##########################################################################################################
$CONTROL_TSK
Return

##########################################################################################################
$HIS_EPU_TSK
