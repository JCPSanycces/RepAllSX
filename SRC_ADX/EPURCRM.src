  If clalev([F:HD41])  Close Local File [HD41] : Endif
  If clalev([F:HD6])   Close Local File [HD6]  : Endif
  If clalev([F:HD61])  Close Local File [HD61] : Endif
Return

##########################################################################################################
#    Epuration des leads                                                        #
# ------------------------------------------------------------------------------#
#    LDS : Actions liées à l'épuration des leads                                #
##########################################################################################################
$OUVRE_LDS
  Gosub DECLARE_VARIABLES
  If HISTO Then
    If OKEPU = 0 Then
      If clalev([F:HD8]) = 0 : Local File =[L]APPLI + ".HD8CLOB"     [HD8]  : Endif
      If clalev([F:BPA]) = 0 : Local File =[L]APPLI + ".BPADDRESS"   [BPA]  : Endif
      If clalev([F:AIN]) = 0 : Local File =[L]APPLI + ".CONTACTCRM"  [AIN]  : Endif
      TABLE = "HD8CLOB"
      Gosub CRETAB_HISTO
      If clalev([F:HD81])= 0 : Local File =[L]HISAPL + ".HD8CLOB"    [HD81] : Endif
      TABLE = "BPADDRESS"
      Gosub CRETAB_HISTO
      If clalev([F:BPA1])= 0 : Local File =[L]HISAPL + ".BPADDRESS"  [BPA1] : Endif
      TABLE = "CONTACTCRM"
      Gosub CRETAB_HISTO
      If clalev([F:AIN1])= 0 : Local File =[L]HISAPL + ".CONTACTCRM"  [AIN1] : Endif
    Else
      If clalev([F:HD8]) = 0 : Local File =[L]HISAPL + ".HD8CLOB"    [HD8]  : Endif
      If clalev([F:BPA]) = 0 : Local File =[L]HISAPL + ".BPADDRESS"  [BPA]  : Endif
      If clalev([F:AIN]) = 0 : Local File =[L]HISAPL + ".CONTACTCRM" [AIN]  : Endif
    Endif
  Else
    If clalev([F:HD8]) = 0 : Local File =[L]APPLI + ".HD8CLOB"       [HD8]  : Endif
    If clalev([F:BPA]) = 0 : Local File =[L]APPLI + ".BPADDRESS"     [BPA]  : Endif
    If clalev([F:AIN]) = 0 : Local File =[L]APPLI + ".CONTACTCRM"    [AIN]  : Endif
  Endif
Return

##########################################################################################################
$FILTRE_LDS
Return

##########################################################################################################
$CONTROL_LDS
Return

##########################################################################################################
$HIS_EPU_LDS
  #CHECK FILE_DECLARE LEAD [F1]
  # -------------------------------------
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(1,13,1) - ":" - [F:F1]PSTNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
  Endif
  # -------------------------------------
  Gosub CONTROL_LDS
  If OKHIS = 0 and OKEPU = 0 Then
    Return
  Endif
  # -------------------------------------
  # Adresses
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(1019,182,1) - ":" - [F:F1]PSTNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [BPA] Where [F:BPA]NUM = [F:F1]PSTNUM and [F:BPA]BPATYP = 6
      If ![L]SIMUL Then
        Raz [F:BPA1]
        [F:BPA1] = [F:BPA]
        If dim([F:BPA1]CREHISDAT)>0 : [F:BPA1]CREHISDAT = date$    : Endif
        If dim([F:BPA1]CREHISUSR)>0 : [F:BPA1]CREHISUSR = [V]GUSER : Endif
        Write [F:BPA1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$BPADDRESS" - [F:BPA1]BPANUM - [F:BPA1]BPAADD - num$([F:BPA1]BPATYP) - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(1020,182,1) - ":" - [F:F1]PSTNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [BPA] Where [F:BPA]NUM = [F:F1]PSTNUM and [F:BPA]BPATYP = 6
    If fstat Then
      Call ECR_TRACE("$BPADDRESS" - [F:F1]PSTNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  # CONTACTCRM historisé systématiquement. Mais purgé uniquement si PSTTYP <> 1
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(1021,182,1) - ":" - [F:F1]PSTNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [AIN] Where [F:AIN]CNTNUM = [F:F1]PSTNUM
      If ![L]SIMUL Then
        Raz [F:AIN1]
        [F:AIN1] = [F:AIN]
        If dim([F:AIN1]CREHISDAT)>0 : [F:AIN1]CREHISDAT = date$    : Endif
        If dim([F:AIN1]CREHISUSR)>0 : [F:AIN1]CREHISUSR = [V]GUSER : Endif
        Write [F:AIN1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$CONTACTCRM" - [F:AIN]CNTNUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [F:F1]PSTTYP <> 1 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(1022,182,1) - ":" - [F:F1]PSTNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Endif
    If ![L]SIMUL Then
      Delete [AIN] Where [F:AIN]CNTNUM = [F:F1]PSTNUM
      If fstat Then
        Call ECR_TRACE("$CONTACTCRM" - [F:F1]PSTNUM - mess(10,100,1), 1) From GESECRAN
        OKHIS = 0
        OKEPU = 0
        Return
      Endif
    Endif
  Endif
  # -------------------------------------
  #Objet
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(901,182,1) - ":" - [F:F1]PSTNUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [HD8] Where [F:HD8]NUM = [F:F1]PSTNUM and [F:HD8]TYP = "LDS"
      If ![L]SIMUL Then
        Raz [F:HD81]
        [F:HD81] = [F:HD8]
        If dim([F:HD81]CREHISDAT)>0 : [F:HD81]CREHISDAT = date$    : Endif
        If dim([F:HD81]CREHISUSR)>0 : [F:HD81]CREHISUSR = [V]GUSER : Endif
        Write [F:HD81]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$HD8CLOB" - [F:F1]PSTNUM - [F:HD81]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(902,182,1) - ":" - [F:F1]PSTNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [HD8] Where [F:HD8]NUM = [F:F1]PSTNUM and [F:HD8]TYP = "LDS"
    If fstat Then
      Call ECR_TRACE("$HD8CLOB" - [F:F1]PSTNUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$FERME_LDS
  If clalev([F:HD8])   Close Local File [HD8]  : Endif
  If clalev([F:HD81])  Close Local File [HD81] : Endif
  If clalev([F:BPA])   Close Local File [BPA]  : Endif
  If clalev([F:BPA1])  Close Local File [BPA1] : Endif
  If clalev([F:AIN])   Close Local File [AIN]  : Endif
  If clalev([F:AIN1])  Close Local File [AIN1] : Endif
Return
