K = 0
For [AFC]CODINT
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 If [F:AFC]CODACT<>"" & pat([F:AFC]CODACT,ACTIV)
  Call TEXTE([F:AFC]NOM,TEXTE) From OBJDIV
  Call ECR_TRACE([F:AFC]CODACT-":"-[F:AFC]CODINT-TEXTE,0) From GESECRAN
 Endif
 For I=0 To [F:AFC]NBOPT-1
  If [F:AFC]ACTOPT(I)<>"" & pat([F:AFC]ACTOPT(I),ACTIV)
   Call ECR_TRACE([F:AFC]ACTOPT(I)-":"-[F:AFC]CODINT-mess(168,124,1)-num$(I+1)-[F:AFC]FLAG(I),0) From GESECRAN
#  Option
  Endif
 Next I
 For I=0 To [F:AFC]NBVAR-1
  If [F:AFC]ACTVAR(I)<>"" & pat([F:AFC]ACTVAR(I),ACTIV)
   Call ECR_TRACE([F:AFC]ACTVAR(I)-":"-[F:AFC]CODINT-mess(142,105)-num$(I+1)-[F:AFC]VARIA(I),0) From GESECRAN
#  Variable
  Endif
 Next I
Next
Close Local File [AFC]
Call ECR_TRACE("",0) From GESECRAN
Return

