$AUTRES
Local File ATABLE [ATB] , ATABZON [ATZ] , ATABIND [ATI]
# Issue 84990 - 2012-10-08 by VPO : on cherche toutes les zones ACV
#For [ATZ]CODTYP(2) Where CODTYP="ACV" & CODZONE="CODACT"
For [ATZ]CODTYP(2) Where CODTYP="ACV"
 If !find([F:ATZ]CODFIC,"ATABLE","ATABZON","ATABIND","AMSK","AMSKZON","AWINDOW","AWINBRO"
&                      ,"AWINBOUT","AOBJET","AOBJTAB","ATYPE","ACTION","AFONCTION"
&                      ,"AREPORT","ATABTAB","AMENLOC","AMAINT","AHISTO","ADOPAR","ACTIV"
&                      ,"ADOSACT")
  [L]FIC = [F:ATZ]CODFIC
  Read [ATB]CODFIC = [L]FIC
  Read [ATI]NUMLIG(2) = [L]FIC;1
  Call TEXTE([F:ATB]INTITFIC,[L]TIT) From OBJDIV
  [L]NAM = [F:ATB]INTIT
#  [L]COD = [F:ATI]DESCRIPT
#  I = instr(1,[L]COD,"+")
#  J = instr(1,[L]COD,"-")
#  If    I & J  : I = min(I,J)
#  Elsif J & !I : I = J
#  Endif
#  If I
#   [L]COD = left$([L]COD,I-1)
#  Endif
  [L]COD=""
  [L]CODZON=[F:ATZ]CODZONE : Gosub ACTIV
 Endif
Next
Return

#####################################
## Cas général
#####################################
$ACTIV
If filinfo(filpath("FIL",[L]FIC,"fde"),0)<=0
 Return
Endif

Local Char PAR(GLONAAR) , TBPAR(30)(1..4) , DEFCLA(250)
Local Integer I
If clalev([F:AMP_])=0 : Local File AMSKPAR [AMP_] : Endif

Call ECR_TRACE([L]TIT-"("+[L]FIC+")"-[L]CODZON,0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
Local File =[L]FIC [FFF]
Call SET_BOITE([L]TIT,nbrecord([FFF])) From GESECRAN
K = 0
For [FFF]
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 # Issue 84990 - 2012-10-08 by VPO : on cherche toutes les zones ACV
 #If [F:FFF]CODACT<>"" & pat([F:FFF]CODACT,ACTIV)
 If evalue("[F:FFF]"+[L]CODZON)<>"" & pat(evalue("[F:FFF]"+[L]CODZON),ACTIV)
  Raz TEXTE
  If [L]NAM<>""
   If evalue("dim([F:FFF]"+[L]NAM+")")<=0
     # Issue 84990 - 2012-10-08 by VPO : recherche de texte si clé multiple
     #Call LECTEXTRA(TEXTE,FIC,NAM,num$(evalue("[F:FFF]"+COD)),"") From ATEXTRA
     Onerrgo RIEN
     DEFCLA = dbgstr(2)
     Default File [FFF]
     Default [F],[L],[S],[V],[M]
     I = 0
     For PAR="TABLE1","ZONE","CLECUR1","CLECUR2"
      I += 1
      Read [AMP_]CODPAR=2;[L]FIC;[L]NAM;PAR
      If !fstat
       TBPAR(I) = num$(evalue([F:AMP_]VALPAR))
      Else
       TBPAR(I) = ""
      Endif
     Next PAR
     Default [L],[S],[V],[M],[F]
     Default File DEFCLA
     Call LECTEXTRA(TEXTE,TBPAR(1),TBPAR(2),TBPAR(3),TBPAR(4)) From ATEXTRA
     Onerrgo
     # Issue 84990 - End
     Call ECR_TRACE(evalue("[F:FFF]"+[L]CODZON)-":"-TBPAR(3)-TBPAR(4)-TEXTE,0) From GESECRAN
   Else
    If evalue("type([F:FFF]"+[L]NAM+")")<10
      Call TEXTE(evalue("[F:FFF]"+[L]NAM),TEXTE) From OBJDIV
    Else
      TEXTE = evalue("[F:FFF]"+[L]NAM)
    Endif
    If [L]COD<>""
     Call ECR_TRACE(evalue("[F:FFF]"+[L]CODZON)-":"-num$(evalue("[F:FFF]"+[L]COD))-TEXTE,0) From GESECRAN
    Else
     Call ECR_TRACE(evalue("[F:FFF]"+[L]CODZON)-":"-func AFNC.CLETBL([L]FIC,"FFF")-TEXTE,0) From GESECRAN
    Endif
   Endif
  Else
   TEXTE = ""
   If [L]COD<>""
    Call ECR_TRACE(evalue("[F:FFF]"+[L]CODZON)-":"-num$(evalue("[F:FFF]"+[L]COD))-TEXTE,0) From GESECRAN
   Else
    Call ECR_TRACE(evalue("[F:FFF]"+[L]CODZON)-":"-func AFNC.CLETBL([L]FIC,"FFF")-TEXTE,0) From GESECRAN
   Endif
  Endif
  #Call ECR_TRACE([F:FFF]CODACT-":"-num$(evalue("[F:FFF]"+COD))-TEXTE,0) From GESECRAN
 Endif
Next
Close Local File [FFF]
Call ECR_TRACE("",0) From GESECRAN
Return

$RIEN
Resume

######################################################################################
Subprog C_ACTIV(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End
