#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECHACT","RECHACT",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return

$INIT
Local Integer I , J , K , INTE , OK
Local Char    ACTIV(GLONACV) , TEXTE(80)
#Local Char    FIC(GLONATB) , TIT(30) , COD(10) , NAM(10)
Local Char    FIC(GLONATB) , TIT(30) , COD(GLONAVA) , NAM(GLONAVA), CODZON(GLONAVA)
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Local Mask RECHACT [DIA]
Raz [M:DIA]
TRA = 1
Return

$EXEC
ACTIV = toupper([M:DIA]ACTIV)
Call OUVRE_BOITE(mess(13,115,1),100) From GESECRAN : # Recherche code activité
Call OUVRE_TRACE(mess(14,115,1)-ACTIV) From LECFIC : # Code activité
If [M:DIA]ATB=2 : : Gosub TABLES     : Endif
If [M:DIA]ACLA=2 : : Gosub CLASSES     : Endif
If [M:DIA]ASW=2 : : Gosub REPRESENTATIONS     : Endif
If [M:DIA]AMK=2 : Gosub ECRANS     : Endif
If [M:DIA]AWI=2 : Gosub FENETRES   : Endif
If [M:DIA]AOB=2 : Gosub OBJETS     : Endif
If [M:DIA]ATY=2 : Gosub TYPES      : Endif
If [M:DIA]ACT=2 : Gosub ACTIONS    : Endif
If [M:DIA]AFC=2 : Gosub FONCTIONS  : Endif
If [M:DIA]ARP=2 : Gosub ETATS      : Endif
If [M:DIA]ADI=2 : Gosub DIVERS     : Endif
If [M:DIA]AML=2 : Gosub MENUS      : Endif
If [M:DIA]AMA=2 : Gosub TRANSACS   : Endif
If [M:DIA]AEP=2 : Gosub EPURES     : Endif
If [M:DIA]ADP=2 : Gosub PARAMETRES : Endif
If [M:DIA]AUT=2 : Gosub AUTRES     : Endif
Call FERME_TRACE From LECFIC
Call FERME_BOITE From GESECRAN
Return


## Classses
$REPRESENTATIONS
Local File ASHW [ASW] , ASHWFLD [ASWF] , ASHWCOL [ASWC] , ASHWBLC [ASWB] , ASHWLNK [ASWK]
Local File ASHWEXPPRO [ASWR], ASHWMENU [ASWMN] , ASHWMET [ASWM] , ASHWOPT  [ASWO] , ASHWSEC [ASWS]
Call SET_BOITE(mess(23,140,1),nbrecord([F:ASW])) From GESECRAN
Call ECR_TRACE(mess(23,140,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ASW]ASW0
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 If [ASW]CODACT<>"" & pat([ASW]CODACT,ACTIV)
  Call TEXTE([ASW]INTREP,TEXTE) From OBJDIV
  Call ECR_TRACE([ASW]CODACT-":"-[ASW]CODREP-TEXTE,0) From GESECRAN
 Endif
 For [ASWF]ASWF0 Where CODREP=[F:ASW]CODREP
  If [ASWF]ACTFLD<>"" & pat([ASWF]ACTFLD,ACTIV)
   Call TEXTE([ASWF]INTFLD,TEXTE) From OBJDIV
   Call ECR_TRACE([ASWF]ACTFLD-":"-[F:ASW]CODREP-mess(34,140,1)-[ASWF]CODFLD-TEXTE,0) From GESECRAN
  Endif
 Next
 For [ASWR]ASWR0 Where CODREP=[F:ASW]CODREP
  If [ASWR]ACTPRO<>"" & pat([ASWR]ACTPRO,ACTIV)
   Call TEXTE([ASWR]INTPRO,TEXTE) From OBJDIV
   Call ECR_TRACE([ASWR]ACTPRO-":"-[F:ASW]CODREP-mess(35,140,1)-[ASWR]ALIAS-TEXTE,0) From GESECRAN
  Endif
 Next
 For [ASWC]ASWC0 Where CODREP=[F:ASW]CODREP
  If [ASWC]ACTCOL<>"" & pat([ASWC]ACTCOL,ACTIV)
   Call TEXTE([ASWC]INTCOL,TEXTE) From OBJDIV
   Call ECR_TRACE([ASWC]ACTCOL-":"-[F:ASW]CODREP-mess(3,297,1)-[ASWC]CODCOL-TEXTE,0) From GESECRAN
  Endif
 Next
 For [ASWK]ASWK0 Where CODREP=[F:ASW]CODREP
  If [ASWK]ACVLNK<>"" & pat([ASWK]ACVLNK,ACTIV)
   Call ECR_TRACE([ASWK]ACVLNK-":"-[F:ASW]CODREP-mess(45,75,1)-[ASWK]ACVLNK,0) From GESECRAN
  Endif
 Next
 For [ASWM]ASWM0 Where CODREP=[F:ASW]CODREP
  If [ASWM]ACTMET<>"" & pat([ASWM]ACTMET,ACTIV)
   Call TEXTE([ASWM]INTMET,TEXTE) From OBJDIV
   Call ECR_TRACE([ASWM]ACTMET-":"-[F:ASW]CODREP-mess(1,7845,1)-[ASWM]CODMET-TEXTE,0) From GESECRAN
  Endif
 Next
 For [ASWB]ASWB0 Where CODREP=[F:ASW]CODREP
  If [ASWB]ACTBLC<>"" & pat([ASWB]ACTBLC,ACTIV)
   Call TEXTE([ASWB]INTBLC,TEXTE) From OBJDIV
   Call ECR_TRACE([ASWB]ACTBLC-":"-[F:ASW]CODREP-"Bloc"-[ASWB]CODBLC-TEXTE,0) From GESECRAN
  Endif
 Next
 For [ASWS]ASWS0 Where CODREP=[F:ASW]CODREP
  If [ASWS]ACTSEC<>"" & pat([ASWS]ACTSEC,ACTIV)
   Call TEXTE([ASWS]INTSEC,TEXTE) From OBJDIV
   Call ECR_TRACE([ASWS]ACTSEC-":"-[F:ASW]CODREP-"Section"-[ASWS]CODSEC-TEXTE,0) From GESECRAN
  Endif
 Next
 For [ASWMN]ASWMN0 Where CODREP=[F:ASW]CODREP
  If [ASWMN]ACTMENU<>"" & pat([ASWMN]ACTMENU,ACTIV)
   Call TEXTE([ASWMN]LIBMENU,TEXTE) From OBJDIV
   Call ECR_TRACE([ASWMN]ACTMENU-":"-[F:ASW]CODREP-"Section"-[ASWMN]CODMENU-TEXTE,0) From GESECRAN
  Endif
 Next
Next
Close Local File [ASW] ,  [ASWF] ,  [ASWC] ,  [ASWB] ,  [ASWK]
Close Local File [ASWR],[ASWMN] ,  [ASWM] ,   [ASWO] ,  [ASWS]
Call ECR_TRACE("",0) From GESECRAN
Return

## Classses
$CLASSES
Local File ACLASSE [ACLA] , ACLAFLD [ACLAF] , ACLACOL [ACLAC] , ACLALNK [ACV] , ACLAMET [ACLAM]
Local File ACLAMETSTD [ACLAT] , ACLAOPT [ACLAO] , ACLALNK  [ACLAK]
Call SET_BOITE(mess(3,140,1),nbrecord([F:ACLA])) From GESECRAN : # Tables
Call ECR_TRACE(mess(3,140,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ACLA]ACLA0
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 If [F:ACLA]CODACT<>"" & pat([F:ACLA]CODACT,ACTIV)
  Call TEXTE([F:ACLA]INTCLA,TEXTE) From OBJDIV
  Call ECR_TRACE([F:ACLA]CODACT-":"-[F:ACLA]CODCLA-TEXTE,0) From GESECRAN
 Endif
 For [ACLAF]ACLAF0 Where CODCLA=[F:ACLA]CODCLA
  If [ACLAF]ACTFLD<>"" & pat([F:ACLAF]ACTFLD,ACTIV)
   Call TEXTE([ACLAF]INTFLD,TEXTE) From OBJDIV
   Call ECR_TRACE([ACLAF]ACTFLD-":"-[F:ACLA]CODCLA-mess(34,140,1)-[F:ACLAF]FLDCLA-TEXTE,0) From GESECRAN
  Endif
 Next
 For [ACLAC]ACLAC0 Where CODCLA=[F:ACLA]CODCLA
  If [ACLAC]ACTCOL<>"" & pat([ACLAC]ACTCOL,ACTIV)
   Call TEXTE([ACLAC]INTCOL,TEXTE) From OBJDIV
   Call ECR_TRACE([ACLAC]ACTCOL-":"-[F:ACLA]CODCLA-mess(3,297,1)-[ACLAC]CODCOL-TEXTE,0) From GESECRAN
  Endif
 Next
 For [ACLAK]ACLAK1 Where CODCLA=[F:ACLA]CODCLA
  If [ACLAK]ACVLNK<>"" & pat([ACLAK]ACVLNK,ACTIV)
   Call ECR_TRACE([ACLAK]ACVLNK-":"-[F:ACLA]CODCLA-mess(45,75,1)-[ACLAK]ACVLNK,0) From GESECRAN
  Endif
 Next
 For [ACLAM]ACLAM0 Where CODCLA=[F:ACLA]CODCLA
  If [ACLAM]ACTMET<>"" & pat([ACLAM]ACTMET,ACTIV)
   Call TEXTE([ACLAM]INTMET,TEXTE) From OBJDIV
   Call ECR_TRACE([ACLAM]ACTMET-":"-[F:ACLA]CODCLA-mess(1,7845,1)-[ACLAM]CODMET-TEXTE,0) From GESECRAN
  Endif
 Next
 For [ACLAT]ACLAT0 Where CODCLA=[F:ACLA]CODCLA
  If [ACLAT]ACTMETSTD<>"" & pat([ACLAT]ACTMETSTD,ACTIV)
   Call ECR_TRACE([ACLAT]ACTMETSTD-":"-[F:ACLA]CODCLA-mess(1,7845,1)-[ACLAT]CODMETSTD,0) From GESECRAN
  Endif
 Next
 For [ACLAO]ACLAO0 Where CODCLA=[F:ACLA]CODCLA
  If [ACLAO]OPTACT<>"" & pat([ACLAO]OPTACT,ACTIV)
   Call TEXTE([ACLAO]OPTLIB,TEXTE) From OBJDIV
   Call ECR_TRACE([ACLAO]OPTACT-":"-[F:ACLA]CODCLA-mess(1,7845,1)-[ACLAO]OPTCOD-TEXTE,0) From GESECRAN
  Endif
 Next
Next
Close Local File [ACLA] ,  [ACLAF] ,  [ACLAC] ,  [ACV] ,  [ACLAM], [ACLAT] ,  [ACLAO]
Call ECR_TRACE("",0) From GESECRAN
Return


## Tables
$TABLES
Local File ATABLE [ATB] , ATABZON [ATZ] , ATABIND [ATI]
Call SET_BOITE(mess(16,125,1),nbrecord([F:ATB])) From GESECRAN : # Tables
Call ECR_TRACE(mess(16,125,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ATB]CODFIC
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 If [F:ATB]CODACT<>"" & pat([F:ATB]CODACT,ACTIV)
  Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
  Call ECR_TRACE([F:ATB]CODACT-":"-[F:ATB]CODFIC-TEXTE,0) From GESECRAN
 Endif
 For [ATZ]NUMLIG Where CODFIC=[F:ATB]CODFIC
  If [F:ATZ]CODACT<>"" & pat([F:ATZ]CODACT,ACTIV)
   Call TEXTE([F:ATZ]NOCOURT,TEXTE) From OBJDIV
   Call ECR_TRACE([F:ATZ]CODACT-":"-[F:ATB]CODFIC-mess(36,124,1)-[F:ATZ]CODZONE-TEXTE,0) From GESECRAN
#  champ
  Endif
 Next
 For [ATI]NUMLIG Where CODFIC=[F:ATB]CODFIC
  If [F:ATI]CODACT<>"" & pat([F:ATI]CODACT,ACTIV)
   Call ECR_TRACE([F:ATI]CODACT-":"-[F:ATB]CODFIC-mess(10,176,1)-[F:ATI]CODIND-[F:ATI]DESCRIPT,0)
&  From GESECRAN
#  Index
  Endif
 Next
Next
Close Local File [ATB] , [ATZ] , [ATI]
Call ECR_TRACE("",0) From GESECRAN
Return

## Ecrans
$ECRANS
Local File AMSK [AMK] , AMSKZON [AMZ]
Call SET_BOITE(mess(17,125,1),nbrecord([AMK])) From GESECRAN : # Ecrans
Call ECR_TRACE(mess(17,125,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [AMK]CODMSK
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 If [F:AMK]CODACT<>"" & pat([F:AMK]CODACT,ACTIV)
  Call TEXTE([F:AMK]INTMSK,TEXTE) From OBJDIV
  Call ECR_TRACE([F:AMK]CODACT-":"-[F:AMK]CODMSK-TEXTE,0) From GESECRAN
 Endif
 For I=0 To [F:AMK]NBBLOC-1
  If [F:AMK]ACTBLOC(I)<>"" & pat([F:AMK]ACTBLOC(I),ACTIV)
   Call TEXTE([F:AMK]TITBLOC(I),TEXTE) From OBJDIV
   Call ECR_TRACE([F:AMK]ACTBLOC(I)-":"-[F:AMK]CODMSK-mess(15,115,1)-num$(I+1)-TEXTE,0) From GESECRAN
#  Bloc
  Endif
 Next I
 For [AMZ]CODE Where CODMSK=[F:AMK]CODMSK
  If [F:AMZ]CODACT<>"" & pat([F:AMZ]CODACT,ACTIV)
   Call TEXTE([F:AMZ]INTIT,TEXTE) From OBJDIV
   Call ECR_TRACE([F:AMZ]CODACT-":"-[F:AMK]CODMSK-mess(17,115,1)-[F:AMZ]CODZON-TEXTE,0) From GESECRAN
#  Zone
  Endif
 Next
Next
Close Local File [AMK] , [AMZ]
Call ECR_TRACE("",0) From GESECRAN
Return

## Fenêtres
$FENETRES
Local File AWINDOW [AWI] , AWINBOUT [AWT] , AWINBRO [AWB]
Call SET_BOITE(mess(82,125,1),nbrecord([AWI])) From GESECRAN : # Fenêtres
Call ECR_TRACE(mess(82,125,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [AWI]AWI0
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 If [F:AWI]CODACT<>"" & pat([F:AWI]CODACT,ACTIV)
  Call TEXTE([F:AWI]DES,TEXTE) From OBJDIV
  Call ECR_TRACE([F:AWI]CODACT-":"-[F:AWI]WIN-TEXTE,0) From GESECRAN
 Endif
 For I=0 To [F:AWI]NBMSK-1
  If [F:AWI]ACTMSK(I)<>"" & pat([F:AWI]ACTMSK(I),ACTIV)
   Call TEXTE([F:AWI]INTMSK(I),TEXTE) From OBJDIV
   Call ECR_TRACE([F:AWI]ACTMSK(I)-":"-[F:AWI]WIN-mess(16,115,1)-num$(I+1)-TEXTE,0) From GESECRAN
#  Onglet
  Endif
 Next I
 For [AWT]AWT0 Where WIN=[F:AWI]WIN
  If [F:AWT]CODACTBOUT<>"" & pat([F:AWT]CODACTBOUT,ACTIV)
   Call ECR_TRACE([F:AWT]CODACTBOUT-":"-[F:AWI]WIN-mess(206,123,1)-num$([F:AWT]NUM)-[F:AWT]CODBOUT,0)
&  From GESECRAN
#  Bouton
  Endif
 Next
 Read [AWB]AWB0 = [F:AWI]WIN
 For I=0 To [F:AWB]NBLIS-1
  If [F:AWB]ACTLIS(I)<>"" & pat([F:AWB]ACTLIS(I),ACTIV)
   Call ECR_TRACE([F:AWB]ACTLIS(I)-":"-[F:AWB]WIN-mess(4,29,1)-num$(I+1)-[F:AWB]OBJLIS(I),0) From GESECRAN
#  Browser
  Endif
 Next I
Next
Close Local File [AWI] , [AWT] , [AWB]
Call ECR_TRACE("",0) From GESECRAN
Return

## Objets
$OBJETS
Call ECR_TRACE(mess(18,125,1),0) From GESECRAN : # Objets
