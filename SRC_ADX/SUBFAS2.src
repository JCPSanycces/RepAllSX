#********************************************************************

#*********************************************************************
#   GESTION DE LA MODIFICATION REDUITE
#*********************************************************************

#-------------------------------------------------------------------------------
$MODIF_REDUITE

Local Integer I, PLIGNE

  Gosub ACTIVE_TOUTES_RUBRIQUES
  # Désactivation des rubriques déterminées (PDISZO=G_OUI) si ACTION="LIENS"
  If ( dim(ACTION) > 0 and ACTION = "LIENS" and [M:FAS0]ENAFAS = G_OUI ) Then
    Call  RUBRIQUES_DETERMINEES(GVML_OMBIEN, [M:FAS0]CPY, G_OUI) From TRTASSO
    # On doit désactiver le code comptable s'il a été activé via les associations
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ACCCOD", 0) = G_OUI ) Then : Diszo [M:FAS1]ACCCOD : Endif
    # FQ 54343O 0n doit désactiver le code actualisation et le flag OCR  s'ils ont été activés via les associations
    If ( G_ACTCCN =  G_OUI ) Then
      If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]CCNACTCOD", 0) = G_OUI ) Then : Diszo [M:FAS6]CCNACTCOD : Endif
      If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]OBYRNWCON", 0) = G_OUI ) Then : Diszo [M:FAS6]OBYRNWCON : Endif
    Endif
  Endif

  Gosub RUBRIQUES_IMMO_DEPENSE
  Gosub RUBRIQUES_AUTRES

  If ( GREP = "C" and GFLGASS= G_OUI ) Then
    #>>>>>>>>>>>>>>>>>
    For I = 1 To [M:FAS3]NBLIG1
      PLIGNE=I
      #*Fq-88454 Call  RUBRIQUES_DETERMINEES_PMR(GVML_OMBIEN, [M:FAS0]CPY, "FAM", [M:FAS3]DPRPLN(I-1), "FAS3", PLIGNE) From TRTASSO
      #*Fq-88454 Call  RUBRIQUES_DETERMINEES_PMR(GVML_OMBIEN, [M:FAS0]CPY, "COD", [M:FAS3]DPRPLN(I-1), "FAS3", PLIGNE) From TRTASSO
      Call  RUBRIQUES_DETERMINEES_PMR(GVML_OMBIEN, [M:FAS0]CPY, "FAM", [M:FAS3]DPRPLN(I-1), "FAS3", PLIGNE) From TRTASSO
      Call  RUBRIQUES_DETERMINEES_PMR(GVML_OMBIEN, [M:FAS0]CPY, "COD", [M:FAS3]DPRPLN(I-1), "FAS3", PLIGNE) From TRTASSO
    Next I
    #<<<<<<<<<<<<<<<<<
  Endif

Return

#-------------------------------------------------------------------------------
$ACTIVE_TOUTES_RUBRIQUES
Local Integer N_I

  # Activation de toutes les rubriques susceptibles d'être désactivé par la MODIF_REDUITE
  #-1 ---------------------------------------
  If ( GREP <> ""  and GREP <> "M" ) or ( [M:FAS0]ENAFAS = G_NON ) Then
    # Pour ces champs non modifiables un DISZO a été pratiqué dans $LIENS
    # Il faut les rendre accessible en création
    # ** FAS0 **
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS0]FCY", 0)        = G_NON Then : Actzo [M:FAS0]FCY        : Endif
    # ** FAS1 **
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ITSDAT", 0)     = G_NON Then : Actzo [M:FAS1]ITSDAT     : Endif  : # FQ63917
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]OWNTYP", 0)     = G_NON Then : Actzo [M:FAS1]OWNTYP     : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ACCCOD", 0)     = G_NON Then : Actzo [M:FAS1]ACCCOD     : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ACGGRP", 0)     = G_NON Then : Actzo [M:FAS1]ACGGRP     : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ACGETRNOT", 0)  = G_NON Then : Actzo [M:FAS1]ACGETRNOT  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IVCVATRAT", 0)  = G_NON Then : Actzo [M:FAS1]IVCVATRAT  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IVCVATFLG", 0)  = G_NON Then : Actzo [M:FAS1]IVCVATFLG  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IVCVATAMT", 0)  = G_NON Then : Actzo [M:FAS1]IVCVATAMT  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]DEDVATRAT", 0)  = G_NON Then : Actzo [M:FAS1]DEDVATRAT  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]DEDVATFLG", 0)  = G_NON Then : Actzo [M:FAS1]DEDVATFLG  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]DEDVATAMT", 0)  = G_NON Then : Actzo [M:FAS1]DEDVATAMT  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IASETRNOT", 0)  = G_NON Then : Actzo [M:FAS1]IASETRNOT  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IVCVATRATI", 0) = G_NON Then : Actzo [M:FAS1]IVCVATRATI : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IVCVATFLGI", 0) = G_NON Then : Actzo [M:FAS1]IVCVATFLGI : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IVCVATAMTI", 0) = G_NON Then : Actzo [M:FAS1]IVCVATAMTI : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]DEDVATFLGI", 0) = G_NON Then : Actzo [M:FAS1]DEDVATFLGI : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]DEDVATAMTI", 0) = G_NON Then : Actzo [M:FAS1]DEDVATAMTI : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IASCURTYP", 0)  = G_NON Then : Actzo [M:FAS1]IASCURTYP  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IASRATCUR", 0)  = G_NON Then : Actzo [M:FAS1]IASRATCUR  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]AASBUS", 0)     = G_NON Then : Actzo [M:FAS1]AASBUS     : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ASJCOE", 0)     = G_NON Then : Actzo [M:FAS1]ASJCOE     : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]TAXCOE", 0)     = G_NON Then : Actzo [M:FAS1]TAXCOE     : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ADMCOE", 0)     = G_NON Then : Actzo [M:FAS1]ADMCOE     : Endif

    # ** FAS2 **
    Call ACTION_BLOCK (ACB_ACTZO, "FAS2", "IASCGU") From GLOBIENS # imputations économiques
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]DSP", 0)        = G_NON Then : Actzo [M:FAS2]DSP        : Endif
    For N_I = 1 To GOPTCANA
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]CCE", N_I-1)  = G_NON Then : Actzo [M:FAS2]CCE(N_I-1) : Endif
    Next N_I
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]NBRCCE", 0)     = G_NON Then : Actzo [M:FAS2]NBRCCE     : Endif : # FQ101710
    # Affichage du bloc analytique rempli par la liste des axes
    Call ACTION_BLOCK (ACB_AFFZO, "FAS2", "NBRCCE") From GLOBIENS # Imputation analytiques
    If G_ACTKRU = G_OUI and func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]KPSEPLN", 0)  = G_NON Then : Actzo [M:FAS2]KPSEPLN  : Endif

    # ** FAS3 **
    Call ACTION_BLOCK (ACB_ACTZO, "FAS3", "NBLIG1") From GLOBIENS # méthodes d'amortissement
    # * Début Rustine *
    # Pour palier à des problèmes inexplicables en l'état
    # Exemple : Lorsque le mode saisi est "SA" DPRDUR et DPRRAT ne sont plus saisissables
    #           Si l'on change le mode en "LP' ces champs restent non saisissables alors qu'ils devrait l'être
    #           La solution est de désigner nommément les champs
    If ( GREP = "C" ) Then
      For N_I = 1 To [M:FAS3]NBLIG1
        Actzo [M:FAS3]DPRDUR   (N_I-1)
        Actzo [M:FAS3]DPRRAT   (N_I-1)
        Actzo [M:FAS3]DPRRATFLG(N_I-1)
        Actzo [M:FAS3]PRATYP(N_I-1)
        Actzo [M:FAS3]ACLCOE(N_I-1)
        Actzo [M:FAS3]ENDDPRDAT(N_I-1)
        # FQ84283
        Actzo [M:FAS3]DPRRAT2  (N_I-1)
      Next N_I
    Endif
    # * Fin Rustine *
    # FQ62386
    For N_I = 1 To [M:FAS3]NBLIG1
       If ( [M:FAS3]DPRPLN(N_I-1) = G301FIS )
          Actzo [M:FAS3]CRBVEHCOD   (N_I-1)
          Break
       Endif
    Next N_I   # FQ62386

    # ** FAS6 **
    If ([M:FAS1]OWNTYP = GVML_TDCONCE ) Then
      # FQ54343
      Call ACTION_BLOCK (ACB_ACTZO, "FAS6", "CCNREF")    From GLOBIENS
      If ( G_CCNRPR = G_OUI ) Then
        Call ACTION_BLOCK (ACB_ACTZO, "FAS6", "TPAFLG")    From GLOBIENS
        Call ACTION_BLOCK (ACB_ACTZO, "FAS6", "CCNACTCOD") From GLOBIENS
        If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]RNWDONFLG", 0) = G_NON Then : Actzo [M:FAS6]RNWDONFLG     : Endif

        If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]VISRPR"   , 0) = G_OUI Then : Diszo [M:FAS6]VISRPR        : Endif
        Chgtzn [M:FAS6]VISRPR  With ""
      Endif
    Endif

  Endif
  #-1 ---------------------------------------

  # ** FAS1 **
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]CMP",       0) = G_NON Then : Actzo [M:FAS1]CMP       : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]PURDAT",    0) = G_NON Then : Actzo [M:FAS1]PURDAT    : Endif
  # FQ91860
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ETRNAT",    0) = G_NON Then : Actzo [M:FAS1]ETRNAT    : Endif
  # FQ67615
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]CMPSTA",    0) = G_NON Then : Actzo [M:FAS1]CMPSTA    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]AASIPTDAT", 0) = G_NON Then : Actzo [M:FAS1]AASIPTDAT : Endif
  # FQ67255
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ITSDAT",    0) = G_NON Then : Actzo [M:FAS1]ITSDAT    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]AASUOM",    0) = G_NON Then : Actzo [M:FAS1]AASUOM    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]AASQTY",    0) = G_NON Then : Actzo [M:FAS1]AASQTY    : Endif
  # ** FAS2 **
  Call ACTION_BLOCK (ACB_ACTZO, "FAS2", "BUDFIY") From GLOBIENS # imputations budgétaires
  If ( G_ACTLEA = G_OUI ) Then
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]LEAREF", 0)  = G_NON Then : Actzo [M:FAS2]LEAREF : Endif
  Endif
  # ** FAS6 ** FQ54343
  If ( [M:FAS1]OWNTYP = GVML_TDCONCE ) Then
    If ( [M:FAS4]ISSDAT = [0/0/0] or [M:FAS4]EXTISSFLG = G_OUI ) Then
      If (G_CCNRPR = G_OUI ) Then
        If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]RNWVAL"   , 0) = G_NON ) Then : Actzo [M:FAS6]RNWVAL    : Endif
      Else
        Call ACTION_BLOCK (ACB_ACTZO, "FAS6", "CCNREF") From GLOBIENS
      Endif
    Endif
  Endif

Return

#-------------------------------------------------------------------------------
$RUBRIQUES_IMMO_DEPENSE
# Désactives toutes les rubriques alimentées par l'immobilisation des dépenses
# Rubriques standards, pas celles des zones libres
Local Integer N_I

  #-1 -----------------------
  If ( GNBDEPLIEES > 0 ) Then
    # Immobilisation à partir de dépenses

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]PURDAT" , 0)   = G_OUI Then : Diszo [M:FAS1]PURDAT : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE  ("[M:FAS2]ORDREF", 0)   = G_OUI Then : Diszo [M:FAS2]ORDREF : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE  ("[M:FAS2]BPR", 0)      = G_OUI Then : Diszo [M:FAS2]BPR    : Endif

    If ( [M:FAS1]IVCVATRAT = 0 ) Then : [M:FAS1]IVCVATFLG = G_OUI : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IVCVATRAT", 0) = G_OUI Then : Diszo [M:FAS1]IVCVATRAT : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IVCVATFLG", 0) = G_OUI Then : Diszo [M:FAS1]IVCVATFLG : Endif

    If [M:FAS1]IVCVATRATI = 0 : [M:FAS1]IVCVATFLGI=G_OUI : Endif

    #*  PCG valorisation
    Diszo [M:FAS1]ACGETRNOT
    Diszo [M:FAS1]IVCVATRAT
    Diszo [M:FAS1]IVCVATAMT
    Diszo [M:FAS1]DEDVATRAT
    Diszo [M:FAS1]DEDVATAMT
    #* IAS/IFRS valorisation
    Diszo [M:FAS1]IASETRNOT
    Diszo [M:FAS1]IVCVATRATI
    Diszo [M:FAS1]IVCVATAMTI
    Diszo [M:FAS1]DEDVATRATI
    Diszo [M:FAS1]DEDVATAMTI
    Diszo [M:FAS1]IASRATCUR
    #*FQ98116 END

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]AASBUS", 0)  = G_OUI and  [M:FAS1]AASBUS<>"" Then : Diszo [M:FAS1]AASBUS : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]INVPLN", 0)  = G_OUI Then : Diszo [M:FAS2]INVPLN : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]BUDREF", 0)  = G_OUI Then : Diszo [M:FAS2]BUDREF : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]BUDFIY", 0)  = G_OUI Then : Diszo [M:FAS2]BUDFIY : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]INVREQ", 0)  = G_OUI Then : Diszo [M:FAS2]INVREQ : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]CONNUM", 0)  = G_OUI Then : Diszo [M:FAS2]CONNUM : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]BPR", 0)     = G_OUI Then : Diszo [M:FAS2]BPR    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]ORDLIG", 0)  = G_OUI Then : Diszo [M:FAS2]ORDLIG : Endif
  Endif
  #-1 -----------------------

Return

#-------------------------------------------------------------------------------
$RUBRIQUES_AUTRES
Local Integer N_I
  #- FAS1 -----------------------------
  If ( [M:FAS1]CMP <> "") Then
    # Champs inaccessibles pour un bien composant car hérité du bien principal
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]AASBUS", 0)  = G_OUI Then : Diszo [M:FAS1]AASBUS : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ASJCOE", 0)  = G_OUI Then : Diszo [M:FAS1]ASJCOE : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]TAXCOE", 0)  = G_OUI Then : Diszo [M:FAS1]TAXCOE : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ADMCOE", 0)  = G_OUI Then : Diszo [M:FAS1]ADMCOE : Endif
    If ([M:FAS1]AASBUS = "" and [M:FAS1]ASJCOE = 0. ) Then
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]TAXCOE", 0) = G_OUI Then : Diszo [M:FAS1]TAXCOE : Endif
    Endif
    Call ACTION_BLOCK (ACB_DISZO, "FAS2", "IASCGU") From GLOBIENS
  Endif
  # Une nature d'entrée à "rachat crédit-bail" ne doit pas être modifiable
  If ( GREP <> "C" and [M:FAS1]ETRNAT = GVML_NERACHA ) Then
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ETRNAT", 0)    = G_OUI Then : Diszo [M:FAS1]ETRNAT   : Endif
  Endif
  # FQ 58095
  If ( GREP <> "C" and [M:FAS1]PURDAT < GDEBEXECPF ) Then
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ADMCOE", 0)  = G_OUI Then Diszo [M:FAS1]ADMCOE  : Endif
  Endif

  If ( GREP <> "C" and [M:FAS1]GACACN <> GVML_NIENCOU and [M:FAS1]GACACN <> 0 ) Then
    # FQ63917
    # If func TRTFAS.IS_CLOTURE_EXERCICE([M:FAS0]CPY, [M:FAS0]AASREF, 0) Then
    #   # Le bien a subi au moins une clôture exercice
    #   If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ITSDAT", 0) = G_OUI Then : Diszo [M:FAS1]ITSDAT    : Endif
    # Endif
    # FQ67255
    If ( func GLOBIENS.IS_FAS_COMPTABILISE ([M:FAS0]CPY, [M:FAS0]AASREF) ) Then
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ITSDAT", 0) = G_OUI Then : Diszo [M:FAS1]ITSDAT    : Endif
    Endif
    If not func TRTFAS.IS_SUPEG_EXC ([M:FAS0]CPY, [M:FAS1]AASIPTDAT, 0) Then
      # La date de comptabilisation est antérieure au début d'exercice courant d'au moins un contexte
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]PURDAT", 0) = G_OUI Then   : Diszo [M:FAS1]PURDAT  : Endif
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]AASIPTDAT", 0) = G_OUI Then: Diszo [M:FAS1]AASIPTDAT : Endif
    Endif
  Endif

  If ( GREP <> "C" and ( [M:FAS1]CMPSTA = GVML_SBPOOL or [M:FAS1]CMPSTA = GVML_SBLVA) ) Then
    # FQ67615 Si le bien est POOL ou LVA le statut n'est pas modifiable
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]CMPSTA", 0) = G_OUI Then   : Diszo [M:FAS1]CMPSTA  : Endif
  Endif

  If ( GREP <> "C" )
    # FQ67255 : date de comptabilisation non modifiable s'il y a du comptabilisé sur le bien ou si le bien est issu d'une dépense
    # FQ70461 ajout de ETRNAT / au comptabilisé
    If func GLOBIENS.IS_FAS_COMPTABILISE ([M:FAS0]CPY, [M:FAS0]AASREF)
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]AASIPTDAT", 0) = G_OUI Then : Diszo [M:FAS1]AASIPTDAT    : Endif
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ETRNAT", 0) = G_OUI Then : Diszo [M:FAS1]ETRNAT    : Endif
    Elsif  func GLOBIENS.GET_NB_LOF_ON_FAS([M:FAS0]AASREF)
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]AASIPTDAT", 0) = G_OUI Then : Diszo [M:FAS1]AASIPTDAT    : Endif
    Endif
  Endif
  If ( GREP = "C" and [M:FAS1]ASJCOE = 0.) Then
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]TAXCOE", 0) = G_OUI Then Diszo [M:FAS1]TAXCOE    : Endif
  Endif
  If ( [M:FAS1]DEDVATRAT = 100 or [M:FAS1]DEDVATRAT = 0 ) Then
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]DEDVATAMT", 0)  = G_OUI Then Diszo [M:FAS1]DEDVATAMT  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]DEDVATAMTI", 0) = G_OUI Then Diszo [M:FAS1]DEDVATAMTI : Endif
  Endif
  If ( GCNXPROIAS = G_OUI and GCNXCURIAS = GCNXCURCPF ) Then
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IASCURTYP", 0)  = G_OUI Then Diszo [M:FAS1]IASCURTYP  : Endif
  Endif

  If ([M:FAS1]CMPSTA <> GVML_SBCOMPO ) Then : # Bien principal
    # Si le statut n'est pas "Composant" ou "Composant compémentaire", Bien principal non saisissable
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]CMP", 0) = G_OUI Then : Diszo [M:FAS1]CMP : Endif
  Endif
  #- FAS2 -------------------------------
  # Si le plan IAS n'est pas géré, les champs relatifs à l'IAS ne sont pas accessibles.
  If !(G_PLNIAS)  Then
    Call ACTION_BLOCK (ACB_DISZO, "FAS1", "IASCUR") From GLOBIENS   # Rubriques Valorisation IAS
  Endif
  If ( [M:FAS2]DSP <> "" ) Then
    For N_I = 1 To GOPTCANA
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]CCE", N_I-1) = G_OUI Then: Diszo [M:FAS2]CCE(N_I-1): Endif
    Next N_I
  Endif
  If ( G_ACTLEA = G_OUI and [M:FAS1]OWNTYP <> GVML_TDCBAIL and [M:FAS1]OWNTYP <> GVML_TDLOCAT ) Then
    # Si le type de détention n'est pas "En crédit bail" ou "En location", Contrat n'est pas saisissable
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]LEAREF", 0) = G_OUI Then : Diszo [M:FAS2]LEAREF : Endif
  Endif
  # FQ105600
  If ([M:FAS2]PROPLN <> "") Then
    # Si le plan deproduction est renseigné il ne peut plus être modifié
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]PROPLN", 0) = G_OUI Then : Diszo [M:FAS2]PROPLN : Endif
  Endif

  #- FAS3 -------------------------------
  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
  For N_I = 1 To [M:FAS3]NBLIG1

    # Conditionnement TAUX
    # FQ55960 FQ59941 FQ77877 FQ84110 FQ84223 FQ84281 FQ105809
    If ( ([M:FAS3]DPM(N_I-1) = G_DPMLP and [M:FAS3]ALWCOD(N_I-1) = GVML_RPALOGI ) or
&        (func TRTFAS.GET_MODE_DPM ([M:FAS0]CPY, [M:FAS3]DPM(N_I-1)) = GVML_TMLIBRE) or
&        find( [M:FAS3]DPM(N_I-1), G_DPMUL, G_DPMCA, G_DPMDA, G_DPMUD, G_DPMTD, G_DPMDE, G_DPMDF,
&                                  G_DPMDX, G_DPMDP, G_DPMDI, G_DPMRE, G_DPMFM, G_DPMLG,
&                                  G_DPMPR, G_DPMSA, G_DPMSY, G_DPMUO, G_DPMDV, G_DPMRA,
&                                  G_DPMRX, G_DPMRD, G_DPM1P, G_DPMAL, G_DPMAD, G_DPMHL,
&                                  G_DPMDM, G_DPMLR, G_DPMCR, G_DPMDR, G_DPMSR, G_DPMUR ) <> 0 ) Then
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRRATFLG", N_I-1) = G_OUI Then : Diszo [M:FAS3]DPRRATFLG(N_I-1) : Endif
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRRAT", N_I-1)    = G_OUI Then : Diszo [M:FAS3]DPRRAT(N_I-1) : Endif
    Endif
    # Conditionnement champ TAUX2 d'amort
    If ([M:FAS3]DPM(N_I-1) = G_DPMIT ) Then
      # Mode "IT", le taux n'est pas saisissable au delà de la 3ème annuité ou de 1ère annuité.
      If not( func GLOBB8.TX_ANTICIPATO_PERMIS ( [M:FAS0]CPY, [M:FAS3]CNX(N_I-1), [M:FAS1]PURNAT,
&              [M:FAS3]STRDPRDAT(N_I-1), [M:FAS3]FIYSTRDAT(N_I-1), [M:FAS3]FIYENDDAT(N_I-1)) ) Then
        If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRRAT2", N_I-1) = G_OUI Then : Diszo [M:FAS3]DPRRAT2(N_I-1) : Endif
      Endif
    Elsif (find ([M:FAS3]DPM(N_I-1), G_DPMLR, G_DPMCR )  > 0 ) Then
      # Mode d'amortissement "LR", "CR"  FQ59941
      # le taux n'est pas saisissable si Règle particulière <> "Bonus".
      If ([M:FAS3]ALWCOD(N_I-1) <> GVML_RPBONUS) Then
        If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRRAT2", N_I-1) = G_OUI Then : Diszo [M:FAS3]DPRRAT2(N_I-1) : Endif
      Endif
    Elsif (find([M:FAS3]DPM(N_I-1), G_DPMAD, G_DPMAL) > 0 ) Then
      # Le taux est toujours saisissable FQ84283
#     If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRRAT2", N_I-1) = G_NON Then : Actzo [M:FAS3]DPRRAT2(N_I-1) : Endif
    Else
      # Dans les autres cas verrouillage.
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRRAT2", N_I-1) = G_OUI Then : Diszo [M:FAS3]DPRRAT2(N_I-1) : Endif
    Endif

    # Conditionnement DUREE
    # FQ54343 (ajout ENDDPRFLG + test suivant)
    # FQ59941 FQ84110
    If ( ( find([M:FAS3]DPM(N_I-1), G_DPMFM, G_DPMLG, G_DPMSA, G_DPMLV, G_DPMIT, G_DPM1P) <> 0 )  or
&        ( [M:FAS3]ENDDPRFLG(N_I-1) = G_OUI ) or
&        ( [M:FAS3]DPM(N_I-1) = G_DPMLP and [M:FAS3]ALWCOD(N_I-1) = GVML_RPALOGI       )   ) Then
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRDUR", N_I-1)  = G_OUI Then : Diszo [M:FAS3]DPRDUR(N_I-1) : Endif
    Endif
    If ( G_ACTCCN = G_OUI and G_CCNRPR = G_OUI and [M:FAS1]OWNTYP = GVML_TDCONCE and [M:FAS3]DPRPLN(N_I-1) = G_CCNPLNCAD ) Then
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRDUR", N_I-1)  = G_OUI Then : Diszo [M:FAS3]DPRDUR(N_I-1) : Endif
    Endif
    # Conditionnement base d'amortissement
    If ( [M:FAS3]DPRPLN(N_I-1) = G301SUB ) Then
      # Saisissable sauf pour le plan subvention
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRBAS", N_I-1) = G_OUI Then : Diszo [M:FAS3]DPRBAS(N_I-1) : Endif
    Endif
    # Conditionnement valeur résiduelle
    If ( [M:FAS3]DPRPLN(N_I-1) = G301SUB ) Then
      # Saisissable sauf pour le plan subvention
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]RSDVAL", N_I-1) = G_OUI Then : Diszo [M:FAS3]RSDVAL(N_I-1) : Endif
    Endif
    # Conditionnement VEHICULE
    If ( [M:FAS3]DPRPLN(N_I-1) <> G301FIS ) Then
      # non saisissable sauf pour le plan fiscal
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]CRBVEHCOD", N_I-1) = G_OUI Then : Diszo [M:FAS3]CRBVEHCOD(N_I-1) : Endif
      Affzo [M:FAS3]CRBVEHCOD(N_I-1)
    Else                               # FQ62386
      Actzo [M:FAS3]CRBVEHCOD(N_I-1)   # FQ62386
    Endif
    # Conditionnement TYPE de COURS et le COURS de CHANGE
    If ( find([M:FAS3]DPRPLN(N_I-1),  G301CPT, G301FIS, G301MIN, G301ORI, G301R76, G301SUB, G301IAS) <> 0 or
&        [M:FAS3]ORIBAS(N_I-1) = GVML_OBPCG ) Then
     # non saisissable pour les plans IAS & PCG & pour les plans alimentés à partir de la base PCG
     If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]CURTYP", N_I-1) = G_OUI Then : Diszo [M:FAS3]CURTYP(N_I-1) : Endif
     If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]RATCUR", N_I-1) = G_OUI Then : Diszo [M:FAS3]RATCUR(N_I-1) : Endif
    Else
     If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]CURTYP", N_I-1) = G_NON Then : Actzo [M:FAS3]CURTYP(N_I-1) : Endif
     If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]RATCUR", N_I-1) = G_NON Then : Actzo [M:FAS3]RATCUR(N_I-1) : Endif
    Endif
    # Conditionnement du champ CUMUL
    If ( [M:FAS0]PRVSITUPD = G_NON or
&        [M:FAS3]STRDPRDAT(N_I-1) >= [M:FAS3]FIYSTRDAT(N_I-1)   ) Then
      # non saisissable si la situation antérieure ne peut pas être remise en cause
      # ou si la date de début d'amortissement n'est pas antérieure à l'exercice courant
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRCUM", N_I-1) = G_OUI Then : Diszo [M:FAS3]DPRCUM(N_I-1) : Endif
    Endif
    # conditionnement du champ COEF ACCEL. FQ59941 FQ67577, FQ72372, FQ105809
    If ( find([M:FAS3]DPM(N_I-1), G_DPMUD, G_DPMTD, G_DPMDB, G_DPMLR, G_DPMDR, G_DPMCR, G_DPMML, G_DPMMD) = 0  ) Then
      # Le coefficient d'accélération n'est saissable que pour les modes ci-dessus
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]ACLCOE", N_I-1) = G_OUI Then : Diszo [M:FAS3]ACLCOE(N_I-1) : Endif
    Endif
    # conditionnement du champ PRORATA
    If ( find([M:FAS3]DPM(N_I-1), G_DPMUL, G_DPMUD, G_DPMTD, G_DPMRE, G_DPMHL, G_DPMHD, G_DPMTL) = 0  ) Then
      # Le type de prorata n'est saisissable que pour les modes ci-dessus FQ84281, FQ105809
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]PRATYP", N_I-1) = G_OUI Then : Diszo [M:FAS3]PRATYP(N_I-1) : Endif
    Endif
    # conditionnement du champ FIN AMORT
    # FQ54343 FQ59941
    # Issue 116168  If ( find([M:FAS3]DPM(N_I-1), G_DPMCA, G_DPMUO,  G_DPMUR)= 0 and [M:FAS3]DPM(N_I-1) <> G_DPMRA and
    # Issue 116168 &        ([M:FAS3]DPM(N_I-1) <> G_DPMRE or [M:FAS3]PRATYP(N_I-1) <> GVML_TPJOUR) ) Then
    If find([M:FAS3]DPM(N_I-1),G_DPMCA,G_DPMUO,G_DPMUR,G_DPMRA,G_DPMPC,G_DPMPD)= 0 and
&          ([M:FAS3]DPM(N_I-1) <> G_DPMRE or [M:FAS3]PRATYP(N_I-1) <> GVML_TPJOUR)
      # La date de fin d'amortissement n'est saisissable que pour les modes ci-dessus
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]ENDDPRDAT", N_I-1) = G_OUI Then : Diszo [M:FAS3]ENDDPRDAT(N_I-1) : Endif
    Endif
    # conditionnement du champ REGLE PARTICUL.
    # FQ59941 FQ82075 FQ84281 FQ105809
    If ( [M:FAS3]DPM(N_I-1) <> "" and
&        find([M:FAS3]DPM(N_I-1), G_DPMCA,G_DPMDF,G_DPMLP,G_DPMPC,G_DPMPD,
&                                 G_DPMLB,G_DPMLR,G_DPMCR,G_DPMSL,G_DPMHL,G_DPMHD,G_DPMTL)  = 0 ) Then
      # Règle particulière n'est saisissable que pour les modes ci-dessus
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]ALWCOD", N_I-1) = G_OUI Then : Diszo [M:FAS3]ALWCOD(N_I-1) : Endif
    Endif


  Next N_I
  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

  #- FAS6 -------------------------------
  If (G_ACTCCN = G_OUI) Then
    If( [M:FAS1]OWNTYP <> GVML_TDCONCE ) Then
      # Si le type de détention n'est pas "En concession",  les données de l'onglet "Concession" ne sont pas saisissables
      Chgtzn [M:FAS6]VISRPR  With ""
      Diszo [M:FAS6]1-99
    Else
      If ([M:FAS6]CCNETRNAT = GVML_NECONCD ) Then
        # Si la nature d'apport est concédant, le bien ne peut pas être remis contre indemnité
        If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]TPAFLG", 0) = G_OUI Then : Diszo [M:FAS6]TPAFLG : Endif
      Endif
    Endif
  Endif

Return


# FQ100398/13 MAJ_ELT_PHY repris et éclaté en 3 avec CRT_UN_ELT_PHYSIQUE et MAJ_UN_ELT_PHYSIQUE
#===========================================================================================================================
$MAJ_ELT_PHYSIQUE
#===========================================================================================================================
Local Integer WDIM_ELT_PHY, I
Local Integer WB_REWRITE # Boolean réécriture
Local Integer LCDRET

Local Char WMESS(250), LCTCOD_DEF(GLONLCT)
Local Integer STAT
Local Integer WNBPHYLNK  # Nbre d'élément rattaché

  WNBPHYLNK = 0
  WB_REWRITE = 0

  If [M:FAS8]NBPHY > 0
    G_NOUVEAU_BIEN = G_OUI

    For nolign = 1 To  [M:FAS8]NBPHY
      If [M:FAS8]RATTACHE(nolign-1) = G_OUI Then
        WNBPHYLNK += 1
        If WNBPHYLNK > GPHN
          GMESSAGE = mess(9,7775,1) - ":" - num$(GPHN)
          GOK = 0
          GMODOK = G_NON
          Return
        Endif
       Endif

      If [M:FAS8]IMP(nolign-1) = G_OUI Then
        Gosub CRT_UN_ELT_PHYSIQUE
      Else
        Gosub MAJ_UN_ELT_PHYSIQUE
      Endif
      If GOK = 0
        Break
      Endif
    Next
  Endif

  # Suppression de tous les verrous posés lors de la saisie des éléments physiques
  Call UNLOCK_SYMBOLE ("PHY", "", "") From GLOBIENS
    # Reinitialisation du FLGLOCK de FAS8
  If [M:FAS8]NBPHY > 0
    For nolign = 1 To [M:FAS8]NBPHY
      [M:FAS8]FLGLOCK(nolign-1) = G_NON
    Next nolign
  Endif

Return

$MAJ_UN_ELT_PHYSIQUE

  WB_REWRITE = 0

  Local Instance WCLASSE_OBJ Using C_PHYELT
  WCLASSE_OBJ = NewInstance  C_PHYELT AllocGroup null

  [L]RET = fmet WCLASSE_OBJ.AINIT()
  [L]RET = fmet WCLASSE_OBJ.AREAD([M:FAS8]PHYREF(nolign-1))

#  If [L]RET <> [V]CST_AOK  X3-54982
  If [L]RET >= [V]CST_AERROR # X3-54982
    GOK = 0
    GMODOK = G_NON
    GMESSAGE = func FXDFCT_SYRA.GET_MAXMSG(WCLASSE_OBJ)
    FreeGroup WCLASSE_OBJ
    Return
  Endif

  # Attacher l'élément physique du bien
  If [M:FAS8]RATTACHE(nolign-1) = G_OUI Then

    If WCLASSE_OBJ.AASREF <> [M:FAS0]AASREF Then
      WCLASSE_OBJ.AASREF = [M:FAS0]AASREF
      If WCLASSE_OBJ.BPS = "" Then
          WCLASSE_OBJ.BPS = [M:FAS2]BPR # Fournisseur
      Endif
      If WCLASSE_OBJ.ORDBUY = "" Then
        WCLASSE_OBJ.ORDBUY = [M:FAS2]ORDREF # Récupération du n° de commande du bien
      Endif

      WCLASSE_OBJ.ORIACT = [V]CST_OAFASLNKPHY
      WB_REWRITE = 1
    Endif

  Else

    # Détacher l'élément physique du bien
    If WCLASSE_OBJ.AASREF <> "" Then
      WCLASSE_OBJ.AASREF = ""
      WCLASSE_OBJ.ORIACT = [V]CST_OAFASULKPHY
      WB_REWRITE = 1
    Endif
  Endif


  # S i l'élément physique est rattaché au bien et si son flag actif est différent de celui du bien,
  # on met à jour le flag actif de l'élément avec celui du bien
  # MHB : plus la peine, car le champ ENAPHY n'existe plus : les éléments physiques se basent sur la valeur ENAFAS
  # If [F:PHYT]AASREF <> ""  and [M:FAS0]ENAFAS <> [F:PHYT]ENAPHY Then
  #    [F:PHYT]ENAPHY = [M:FAS0]ENAFAS
  #     WB_REWRITE = 1
  # Endif
  # Enlever toute l'attente de mouvement de l'élément physique

  If [M:FAS8]SUPATTENTE(nolign-1) = G_OUI Then
    [L]RET = fmet WCLASSE_OBJ._PHYELT_DEL_ALL_MVT()
    If [L]RET < [V]CST_AERROR
      WB_REWRITE = 1
    Endif
  Endif

  If WB_REWRITE

    GPOINT = "PHYCHGDATAS" : Gosub ENTREE From EXEFNC # Issue 118444

    [L]RET = fmet WCLASSE_OBJ.AUPDATE()

    If [L]RET = [V]CST_AOK
      [L]RET =  [V]CST_ATRUE
      WREF = WCLASSE_OBJ.PHYREF
    Else
      [L]RET =  [V]CST_AFALSE
      GMESSAGE = func FXDFCT_SYRA.GET_MAXMSG(WCLASSE_OBJ)
      GOK = 0
      GMODOK = G_NON
    Endif
  Endif

  FreeGroup WCLASSE_OBJ

Return

$CRT_UN_ELT_PHYSIQUE
Local Integer RET, ASTATUS

  # Création d'un élément physique
  # test sur IMP pour savoir si on vient d'un import de bien ou de création d'éléments physique ou non
  # Si On ne vient pas de l'import et que le code IMP (Création) est à Oui et que le code RATTACHE est à Non
  # on ne cree pas l'élément physique
  If GIMPORT = 0 and [M:FAS8]IMP(nolign-1)= G_OUI and [M:FAS8]RATTACHE(nolign-1) = G_NON Then
    Return
  Endif

  Local Instance WCLASSE_OBJ Using C_PHYELT
  WCLASSE_OBJ = NewInstance  C_PHYELT AllocGroup null

  [L]RET = fmet WCLASSE_OBJ.AINIT()

  WCLASSE_OBJ.CPY           = [M:FAS0]CPY
  WCLASSE_OBJ.FCY           = [M:FAS0]FCY
  WCLASSE_OBJ.PHYREF        = [M:FAS8]PHYREF(nolign-1)
  WCLASSE_OBJ.PHYDES1       = [M:FAS8]PHYDES1(nolign-1)
  WCLASSE_OBJ.PHYDES2       = [M:FAS8]PHYDES2(nolign-1)
  WCLASSE_OBJ.AASREF        = [M:FAS0]AASREF

  WCLASSE_OBJ.BAC           = [M:FAS8]BAC(nolign-1)
  WCLASSE_OBJ.SRLNBR        = [M:FAS8]SRLNBR(nolign-1)
  WCLASSE_OBJ.PHYCAT        = [M:FAS8]PHYCAT(nolign-1)
  WCLASSE_OBJ.NUMRECEP      = [M:FAS8]NUMRECEP(nolign-1)
  WCLASSE_OBJ.DNUMRECEP     = [M:FAS8]DNUMRECEP(nolign-1)

  If [M:FAS8]LCTCOD(nolign-1) = AVOID.ACHAR
    WCLASSE_OBJ.LCTCOD = func PHYLCT_CSTD.GET_DEFAULT_LOCATION([M:FAS0]FCY, STAT, GMESSAGE)
    If WCLASSE_OBJ.LCTCOD = AVOID.ACHAR
      GOK = 0
      GMODOK = G_NON
      FreeGroup WCLASSE_OBJ
      Return
    Endif
  Else
    WCLASSE_OBJ.LCTCOD     = [M:FAS8]LCTCOD(nolign-1)
  Endif

  WCLASSE_OBJ.BPS        = [M:FAS8]BPRPHY(nolign-1)
  WCLASSE_OBJ.ORDBUY = [M:FAS8]ORDBUY(nolign-1)
  WCLASSE_OBJ.DORDBUY     = [M:FAS8]DORDBUY(nolign-1)


  If GIMPORT and [M:FAS8]PHYREF(nolign-1) <> ""
     WCLASSE_OBJ.CREORI = GVML_COIMPOR # Origine de saisie IMPORT
  Else
    WCLASSE_OBJ.CREORI = GVML_COAUTCR # Origine de saisie CREATION AUTOMATIQUE
  Endif
  WCLASSE_OBJ.ENAFLG = [M:FAS0]ENAFAS # FQ110245

  GPOINT = "PHYADDDATAS" : Gosub ENTREE From EXEFNC # Issue 118444

  [L]RET = fmet WCLASSE_OBJ.AINSERT()

#  If [L]RET = [V]CST_AOK X3-54982
  If [L]RET < [V]CST_AERROR # X3-54982
    [L]RET =  [V]CST_ATRUE
    WREF = WCLASSE_OBJ.PHYREF
  Else
    [L]RET =  [V]CST_AFALSE
    GMESSAGE = func FXDFCT_SYRA.GET_MAXMSG(WCLASSE_OBJ)
    GOK = 0
    GMODOK = G_NON

  Endif

  FreeGroup WCLASSE_OBJ

Return

#===========================================================================================================================
# Création d'un élément physique
# Affichage de l'icone attachement
#===========================================================================================================================
$AFFICHE_ELT_PHY
  If GPHY = G_OUI Then
    If [M:FAS0]ENAFAS = G_NON Then
      If [M:FAS8]NBPHY > 0 and find(G_OUI, [M:FAS8]RATTACHE(0..[M:FAS8]NBPHY-1))Then
        Affzo [M:FAS0]FLGELT
      Endif
    Endif
  Endif
Return

#===========================================================================================================================
# FQ 49517 - Création automatique d'un élément physique
# Alimentation de l'écran FAS8 avec le nouvel élt physique
#===========================================================================================================================
$MAJ_CRE_AUTO_ELT_PHYSIQUE
Local Integer NBPHYCRE
Local Integer NB_ELT_PHY

  If GPHYAUTNUM = GVML_AUCUNE
     GMESSAGE = mess(126,7775,1)
     GOK = 0
     Return
  Endif

  # Issue 118444
  Local Integer PHY_COND
  PHY_COND = 1
  GPOINT = "PHYCREAUTO" : Gosub ENTREE From EXEFNC
  If PHY_COND = 0
    Return
  Endif
  # End Issue 118444

  # FQ109841
#  If GPHYNUMBCO = G_OUI and GPHYAUTNUM = GVML_OBLIG and vireblc([F:FAS]AASREF,4) <> "" Then
#    # Le paramètre PHYFMTCOU n'est pas renseigné : on ne va pas plus loin
#    If vireblc(GPHYFMTCOU,4) = "" Then
#       GMESSAGE = mess(101,7775,1)
#       GOK = 0
#       Return
#    Endif
#  Endif

  If [M:FAS8]NBPHY <> 0 or func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [F:FAS]AASREF + "'")
    Return
  Endif

  If [F:FAS]AASQTY-1 > GPHN Then
     NB_ELT_PHY = GPHN-1
  Else
     NB_ELT_PHY = [F:FAS]AASQTY-1
  Endif
  For NBPHYCRE=0 To NB_ELT_PHY
  # Numérotation des éléments physiques à partir du bien
  # La numérotation ce fera dans MAJ_ELT_PHYSIQUE
    [M:FAS8]PHYDES1(NBPHYCRE)    = [F:FAS]AASDES1
    [M:FAS8]PHYDES2(NBPHYCRE)    = [F:FAS]AASDES2
    [M:FAS8]BPRPHY(NBPHYCRE)     = [F:FAS]BPR
    # Récupération du n° de commande du bien
    [M:FAS8]ORDBUY(NBPHYCRE)     = [F:FAS]ORDREF
    [M:FAS8]IMP(NBPHYCRE)        = G_OUI
    [M:FAS8]MVT(NBPHYCRE)        = GVMLPMVNONE
    [M:FAS8]RATTACHE(NBPHYCRE)   = G_OUI
    [M:FAS8]SUPATTENTE(NBPHYCRE) = G_NON
    [M:FAS8]FLGMODIF(NBPHYCRE)   = G_NON
    [M:FAS8]FLGLOCK(NBPHYCRE)    = G_NON
  Next
  [M:FAS8]NBPHY = NB_ELT_PHY + 1
  [M:FAS0]FLGELT = GICOATTACHE

Return

#===========================================================================================================================
#  Création d'un élément physique
# Suppression des éléments physique ebn création de FAS8 si NOK
#===========================================================================================================================
$DEL_CRE_ELT
Local Integer NBPHYCRE
  If [M:FAS8]NBPHY > 0
    # FQ109840
    #If GPHYNUMBCO = G_OUI  Then
      Gosub RAZ_PHY_FAS8
      Effzo [M:FAS0]FLGELT
      Diszo [M:FAS0]FLGELT
    #Endif
  Endif

Return
#===========================================================================================================================
# Création d'un élément physique
# Suppression des éléments physique de FAS8
#===========================================================================================================================
$RAZ_PHY_FAS8
  Raz [M:FAS8]NBPHY,[M:FAS8]PHYREF,[M:FAS8]LCTCOD,[M:FAS8]MVT,[M:FAS8]MVTDATPHY,[M:FAS8]LOCATT,[M:FAS8]SUPATTENTE,[M:FAS8]RATTACHE,
&     [M:FAS8]FLGMODIF,[M:FAS8]FLGLOCK,[M:FAS8]PHYDES1,[M:FAS8]PHYDES2,[M:FAS8]BAC,[M:FAS8]SRLNBR,[M:FAS8]IVYDAT,[M:FAS8]IVYTIM,
&     [M:FAS8]CURCND,[M:FAS8]IVYRES,[M:FAS8]IMP,[M:FAS8]PHYCAT,[M:FAS8]ORDBUY,[M:FAS8]DORDBUY,[M:FAS8]NUMRECEP,[M:FAS8]DNUMRECEP,[M:FAS8]PHYREFOLD
Return

#####################################################################
# CREATION / MODIF / SUPRESSION
#####################################################################

#----------#
# CREATION #
#----------#

#=====================================================================
$VERIF_CRE

Local Integer WI
Local Integer N_I #Fq-89714

  #Fq-89714--------------------------
  # On vérifie que les dépenses sélectionnées n'ont pas déjà été rattachées à un autre bien comptable
  # ==> possible si 2 users immobilisent les mêmes dépenses au même moment
  If GNBDEPLIEES
     If !clalev([F:LOFR]) : Local File LAYOUTFAS [LOFR] : Endif
     For N_I = 1 To [M:LOF6]NBDEST
        Read [LOFR]LOF0= [M:LOF6]CODLOF(N_I-1);[M:LOF6]LINLOF(N_I-1)
        If [F:LOFR]AASREF <> ""
           # "Impossible de créer le bien car au moins une des dépenses choisies vient d'être rattachée à un autre bien"
           GERR=1 :  GMESSAGE = mess(904,GML_MSGFAS,1)
           Disable GSTACRE
           GOK=0 : OK=0
           Break
        Endif
      Next N_I
  Endif
  If  OK = 0  : Return : Endif
  #Fq-89714--------------------------


  If G_ACTCIG = G_OUI
    # Création impossible si la société est présente en tant que société source d'une CIG
    # dont le statut est différent de 'En préparation'  ET
    # dont le type est Fusion ou Scission
    Filter [F:CIG]
&   Where [F:CIG]CIGSTA <> GVML_CIGSTAP and ([F:CIG]CIGTYP =  GVML_TOFUSIO or [F:CIG]CIGTYP = GVML_TOSCISS)
    For [F:CIG]
      For WI= 0 To [F:CIG]NBCPY - 1
        If ( [F:CIG]CPYSRC (WI) = [M:FAS0]CPY ) Then
          GERR= 1 : GMESSAGE= mess(438,GML_MSGFAS, 1) + '\' + mess(439,GML_MSGFAS, 1) - [F:CIG]CIGCOD : OK = 0 : GOK = 0
          Break 2
        Endif
      Next
    Next
    Filter [F:CIG]
    If (GERR) Then : Return : Endif
  Endif
  If ( GCNXPROIAS = G_OUI ) #FQ-61084
     # Si bien en "Crédit bail" ou en "Location",
     # on doit avoir un compte PCG de charge et une valorisation PCG nulle
     If  ( [M:FAS1]OWNTYP = GVML_TDLOCAT  or
&          [M:FAS1]OWNTYP = GVML_TDCBAIL ) and
&          func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA"
#&      ( func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) # FQ57624
       If ( [M:FAS1]GACACN <> GVML_NICHARG or [M:FAS1]ACGETRNOT <> 0 ) Then
          [M:FAS1]ACGETRNOT = 0 : Affzo [M:FAS1]ACGETRNOT
          [M:FAS1]IVCVATAMT = 0 : Affzo [M:FAS1]IVCVATAMT
          [M:FAS1]DEDVATAMT = 0 : Affzo [M:FAS1]DEDVATAMT
          GERR= 1 : OK= 0 : GMESSAGE= mess(544,GML_MSGFAS, 1)  : mkstat=2 : Return : # FQ83750 : ajout de OK = 0
       Endif
     Endif
   Endif #FQ-61084
  #Fq-60551 Si bien en "Location" et que l'immatriculation véhicule renseignée
  # avertissement si les dates de début et de fin de location ne sont pas renseignées
  If  ( [M:FAS1]OWNTYP = GVML_TDLOCAT and [M:FAS8]NPL <> "" and [M:FAS8]RNTSTRDAT = [0/0/0] )
      Call AVERTIR(mess(797,GML_MSGFAS,1), OK) From GESECRAN
      If (OK = 1) Then
        GERR     = 1 : OK= 0 : mkstat= 2 : Return : # FQ83750 : ajout de OK = 0
      Endif
  Endif

  # Contrôle cohérence société/site
  OK = func GLOFCYCPY.IS_CPYFCY_OK([M:FAS0]CPY,[M:FAS0]FCY)
  # Site financier et société incompatibles
  If !(OK) Then : Return : Endif

  # Dans le cas d'une immobilisation de dépenses, il faut contrôler que
  # les codes comptable, compte PCG et IAS soient identiques sur FAS1 et LOF6.
  # Si ça n'est pas le cas, il faut remonter ces infos vers LOF6 et refaire les contrôles
  If ( [M:LOF6]NBDEST > 0 ) Then
    If ( [M:FAS1]ACCCOD <> [M:LOF6]ACCCODV or
&        [M:FAS1]GACACN <> [M:LOF6]GACACNV or [M:FAS1]GAC <> [M:LOF6]GACV or
&        ( G_PLNIAS and ([M:FAS1]IASACN <> [M:LOF6]IASACNV or [M:FAS1]IASACC <> [M:LOF6]IASACCV) )
&      ) Then
      [M:LOF6]ACCCODV = [M:FAS1]ACCCOD
      [M:LOF6]GACACNV = [M:FAS1]GACACN
      [M:LOF6]GACV    = [M:FAS1]GAC
      [M:LOF6]IASACNV = [M:FAS1]IASACN
      [M:LOF6]IASACCV = [M:FAS1]IASACC
      Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "ACCCODV") From GLOBIENS
      Gosub CTRL_LDAB_BIS From FUNLOFLDAB
      If ( GOK = 0 ) Then
        GERR = 1
        OK   = 0
      Endif
    Endif
  Endif

  # FQ64291 FQ70467
  # En norme française, si le mode est <> "SA" la durée du plan de subvention doit être égale à celle du plan fiscal
  If (func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA") Then
    Local Integer I_PLNFIS
    Local Integer I_PLNSUB
    I_PLNFIS = find(G301FIS, [M:FAS3]DPRPLN)
    I_PLNSUB = find(G301SUB, [M:FAS3]DPRPLN)
    If (I_PLNFIS > 0 and I_PLNSUB > 0 ) Then
      If ( [M:FAS3]DPM(I_PLNFIS-1)<> "SA" ) and ( [M:FAS3]DPM(I_PLNSUB-1)<> "SA" ) Then
        If ( [M:FAS3]DPRDUR(I_PLNSUB-1) <> [M:FAS3]DPRDUR(I_PLNFIS-1) ) Then
          GERR= 1 : OK= 0 : GMESSAGE= mess(818 ,GML_MSGFAS, 1)  : mkstat=2 : Return : # FQ83750 : ajout de OK = 0
        Endif
      Endif
    Endif
  Endif

  # FQ70462 Initialisation du champs FLGPRV "Bien de reprise"
  [M:FAS9]FLGPRV = G_NON

  #>>>>>>>>>>>>>>>>
  For nolign = 1 To [M:FAS3]NBLIG1

    # Si le bien est inactif et que le mode n'est pas alimenté, mode SA par défaut
    If ( [M:FAS3]DPM(nolign-1) = "" and [M:FAS0]ENAFAS <> G_OUI  ) Then
      If GIMPORT : Call ECR_TRACE(mess(259,7770,1)-mess([M:FAS3]DPRPLN(nolign-1),3101,1),-1) From GESECRAN : Endif : # FQ64491
      [M:FAS3]DPM(nolign-1) = G_DPMSA
    Elsif ( [M:FAS3]DPM(nolign-1) = "" and GIMPORT  )
      # FQ64491
      Local Integer K
      GMESSAGE = mess(260,7770,1)
      K = instr(1,GMESSAGE,"#")
      If K : GMESSAGE = left$(GMESSAGE,K-1)+mess([M:FAS3]DPRPLN(nolign-1),3101,1)+right$(GMESSAGE,K+1) : Endif
      GERR=1 : OK = 0
      Break
    Endif

    [M:METH] = [M:FAS0]
    [M:METH] = [M:FAS1]
    [M:METH] = [M:FAS2]
    [M:METH] = [M:FAS3]
    If ( G_ACTCCN =  G_OUI ) Then
      [M:METH] = [M:FAS6]
    Endif
    [M:METH]FLGBCO = G_OUI
    # Controle de la méthode pour chaque plan d'amortissement
    Call CONTROLE_METHODE () From TRTFAS
    If ( [M:METH]MSGERR) Then
      GERR=1 : OK = 0
      #*X3-61112 the 40% tax deduction on investement (Macron Law)
      If [M:METH]MSGERR <> 942
        GMESSAGE =  mess(124,GML_MSGFAS,1)- mess([M:FAS3]DPRPLN(nolign-1),3101,1)- '-->' - mess([M:METH]MSGERR,[M:METH]MSGFIL,1)
        Gosub MODIF_REDUITE From SUBFAS2
        zonsui = "[M:FAS3]DPM(nolign-1)"
      Else
        zonsui = "[M:FAS3]ALWCOD(nolign-1)"
      Endif  #*X3-61112 End
      Break
    Endif

    # FQ70462 Initialisation du champs FLGPRV "Bien de reprise"
    #If ([M:FAS1]AASIPTDAT<[M:FAS3]FIYSTRDAT(nolign-1)) or ([M:FAS3]DPRCUMFLG(nolign-1)=G_OUI) or ([M:FAS3]PERCLOCUM(nolign-1) <> 0)
    # FQ70462 FQ75616 Initialisation du champs FLGPRV "Bien de reprise"
    If ( [M:FAS3]BREPRISE(nolign-1) =G_OUI  or [M:FAS1]AASIPTDAT<[M:FAS3]FIYSTRDAT(nolign-1)) or
&       ([M:FAS3]DPRCUMFLG(nolign-1)=G_OUI) or ([M:FAS3]PERCLOCUM(nolign-1) <> 0)
      [M:FAS9]FLGPRV = G_OUI
    Endif
  Next nolign
  #<<<<<<<<<<<<<<<
  If ( OK = 0 ) Then : Return : Endif

  # FQ54343
  If ( G_ACTCCN =  G_OUI ) Then
    # Si gestion des concessions
    If ( [M:FAS1]OWNTYP = GVML_TDCONCE ) Then
      # S'il s'agit d'un bien "En concession"
      # FQ96953 : test sur CCNREF car si la ligne de type P n'est pas présente à l'import aucun contrôle n'est fait sur FAS6
      If [M:FAS6]CCNREF=""
        GERR=1 : OK = 0
        GMESSAGE = mess(17,115,1)-"CCNREF :"-mess(10,123,1) : # Zone CCNREF : Zone obligatoire
        zonsui = "[M:FAS6]CCNREF"
        Return
      Endif
      If ( G_CCNRPR = G_OUI ) Then
        # Si le type de gestion des concession est "transmis par renouvellement"
        Local Integer I_CAD  :  I_CAD= find ( G_CCNPLNCAD, [M:FAS3]DPRPLN )
        # Si le bien est remis contre indemnité le mode ne peut être que "SA"
        If ( [M:FAS6]TPAFLG = G_OUI and [M:FAS3]DPM(I_CAD-1) <> G_DPMSA ) Then
          GERR=1 : OK = 0
          GMESSAGE = mess(702,GML_MSGFAS,1)
          zonsui = "[M:FAS3]DPM(I_CAD-1)"
          Return
        Endif
      Endif
    Else
     [M:FAS6]CCNACTCOD= ""      #Fq-61676
    Endif
  Endif

  #<<<<<<<<<<<<<<<
  # FQ67615
  Local Integer L_LVATYP
  Call GET_LVATYP_FROM_GACCODE (GVML_COGIMMO, [M:FAS1]ACCCOD, GGACIMMO, L_LVATYP) From GLOBIENS
  If ( (L_LVATYP = GVML_GLVALVA  and [M:FAS1]CMPSTA <> GVML_SBLVA)  or
&      (L_LVATYP = GVML_GLVAPOOL and [M:FAS1]CMPSTA <> GVML_SBPOOL) or
&      (([M:FAS1]CMPSTA = GVML_SBPOOL or [M:FAS1]CMPSTA = GVML_SBLVA) and L_LVATYP = GVML_GLVAAUC) or
&      ((L_LVATYP = GVML_GLVALVA or L_LVATYP = GVML_GLVAPOOL ) and
&       [M:FAS1]CMPSTA <> GVML_SBPOOL and [M:FAS1]CMPSTA <> GVML_SBLVA) ) Then
    # Incohérence statut bien et indicateur compte
    GMESSAGE = mess(880,GML_MSGFAS,1)-mess([M:FAS1]CMPSTA,GML_STATUBCO,1)-"&"-mess(L_LVATYP,GML_GESLVA,1)
    GERR = 1 : OK = 0 : Return
  Endif

  Local Integer L_ETRLVL
  Call GET_FAS_ENTRY_LEVEL ([M:FAS3]FIYSTRDAT(0), [M:FAS3]FIYENDDAT(0), [M:FAS3]FIYENDDAT2(0),
&      [M:FAS1]AASIPTDAT, [M:FAS3]STRDPRDAT(0), [M:FAS3]DPRCUM(0), [M:FAS3]DPRCUMFLG(0), L_ETRLVL) From GLOBIENS
  If (L_ETRLVL = 2 and find([M:FAS1]CMPSTA, GVML_SBLVA, GVML_SBPOOL) <> 0) Then
    # Création d'un bien Pool ou LVA au delà de l'exercice suivant impossible
    GMESSAGE = mess(881,GML_MSGFAS,1)
    GERR = 1 : OK = 0 : Return
  Endif

  If ( L_ETRLVL <> -1 ) Then
    Local Date L_DEBETR, L_FINETR
    Local Integer L_FIYLVATYP
    If ( L_ETRLVL = 0 ) Then
      L_DEBETR = [M:FAS3]FIYSTRDAT(0)
      L_FINETR = [M:FAS3]FIYENDDAT(0)
    Endif
    If ( L_ETRLVL = 1 ) Then
      L_DEBETR = [M:FAS3]FIYENDDAT(0)+1
      L_FINETR = [M:FAS3]FIYENDDAT2(0)
    Endif

    Call GET_FIY_LVATYP( [M:FAS0]CPY, L_DEBETR, L_FINETR, L_FIYLVATYP) From GLOBIENS
    If ( ( [M:FAS1]CMPSTA = GVML_SBLVA  and L_FIYLVATYP <> GVML_GLVALVA  ) or
&        ( [M:FAS1]CMPSTA = GVML_SBPOOL and L_FIYLVATYP <> GVML_GLVAPOOL ) ) Then
      # Incohérence règle LVA contexte et statut bien
      GMESSAGE = mess(878,GML_MSGFAS,1)
      GERR = 1 : OK = 0 : Return
    Endif

    If ( [M:FAS1]CMPSTA = GVML_SBPOOL ) Then
      If (func GLOBIENS.EXISTEBIENLVA(GVML_SBPOOL, L_DEBETR, L_FINETR, [M:FAS0]CPY)) Then
        # Il existe déjà un bien "pool" dans l'exercice
        GMESSAGE = mess(879,GML_MSGFAS,1)
        GERR = 1 : OK = 0 : Return
      Endif
    Endif

    If ( [M:FAS1]CMPSTA = GVML_SBLVA ) Then
      Local Decimal L_FIYLVALIM
      Call GET_FIY_LVALIM( [M:FAS0]CPY, L_DEBETR, L_FINETR, L_FIYLVALIM) From GLOBIENS
      If ( [M:FAS3]DPRBAS(0) > L_FIYLVALIM ) Then
        # Valeur supérieure au seuil. Confirmez-vous ?
        If GIMPORT
          Call ECR_TRACE(mess(883,GML_MSGFAS,1),0) From GESECRAN
        Else
          Call OUINON(mess(883,GML_MSGFAS,1)-mess(682,GML_MSGFAS,1), OK) From GESECRAN
          If (OK = G_NON) Then
            GERR = 1
            OK = 0
            Return
          Endif
        Endif
      Endif
    Endif

  Endif

  # FQ67615
  If ( find(0, [M:FAS3]DPRBAS(0..[M:FAS3]NBLIG1-1)) and [M:FAS1]CMPSTA <> GVML_SBPOOL ) Then
    # "Au moins un plan a une valeur bilan égale à zéro. Confirmez-vous la création du bien ?"
    If GIMPORT
      Call ECR_TRACE(mess(681,GML_MSGFAS,1),0) From GESECRAN
    Else
      Call OUINON(mess(681,GML_MSGFAS,1)-mess(682,GML_MSGFAS,1), OK) From GESECRAN
      If (OK = G_NON) Then
        GERR = 1
        OK = 0
        Return
      Endif
    Endif
  Endif

  # Si Date début amort < Date début exercice courant et qu'il y a des dépenses subventionnées immobilisées
  # ET pas de remise en cause de la situation antérieure pour les biens subventionnés (paramètre GRTPRVUPD)
  # alors on interdit la création du bien
  Local Integer LPRVHUPD, N_I
  Local Char LPARAM
# FQ91644
#  Call PARAM("AAS" ,"GRTPRVUPD",LPARAM) From ADOVAL
  Local Integer LGRT : # X3-104535
  LGRT = func AFNC.ACTIV("GRT")
  If LGRT = G_OUI
    Local Integer LPRVUPD : # X3-104535
    Call PARAM([M:FAS0]FCY ,"GRTPRVUPD", LPARAM) From ADOVAL
    LPRVUPD = val(LPARAM)
    If ( [M:LOF6]NBDEST > 0 and LPRVUPD= G_NON and [M:FAS3]STRDPRDAT(0) <> [0/0/0] and
&        [M:FAS3]STRDPRDAT(0) < [M:FAS3]FIYSTRDAT(0) ) Then
      For N_I = 1 To [M:LOF6]NBDEST
        # Ici on va lire la dépense pour savoir si elle est subventionnée. L'idéal serait de stocker cette
        # information dans le tableau "Dépenses retenues" de l'écran LOFLDAB.
        Read [LOF]LOF0=[M:LOF6]CODLOF(N_I-1);[M:LOF6]LINLOF(N_I-1)
        If [F:LOF]FLGGRA=G_OUI
          GERR     = 1
          # L'immobilisation d'une dépense subventionnée
          # interdit la remise en cause de la situation antérieure de ce bien
          GMESSAGE = mess(566,GML_MSGFAS,1)
          OK       = 0
          Break
        Endif
      Next N_I
    Endif
  Endif # X3-104535

  If !OK : Return : Endif


  # FQ67615
  If ( GNBDEPLIEES = 0 and [M:FAS1]CMPSTA = GVML_SBPOOL and [M:FAS3]STRDPRDAT(0) >= [M:FAS3]FIYSTRDAT(0)) Then
    # Pas de valorisation lors de la création d'un bien "Pool" en direct
    # si le début d'amortissement de celui -ci n'est pas antérieur à l'exercice courant
    [M:FAS1]ACGETRNOT  = 0
    [M:FAS1]IASETRNOT  = 0
    [M:FAS1]ACGBSEVAL  = 0
    [M:FAS1]IASBSEVAL  = 0
    [M:FAS1]IVCVATAMT  = 0
    [M:FAS1]IVCVATFLG  = G_NON
    [M:FAS1]IVCVATAMTI = 0
    [M:FAS1]IVCVATFLGI = G_NON
    [M:FAS1]DEDVATAMT  = 0
    [M:FAS1]DEDVATFLG  = G_NON
    [M:FAS1]DEDVATAMTI = 0
    [M:FAS1]DEDVATFLGI = G_NON
    [M:FAS4]GALREFBAS  = 0
    [M:FAS2]TAXBAS     = 0

  Endif

  # FQ67615_8
  Local Integer B_CTLCCE : B_CTLCCE = 1
  If (  ([M:FAS1]CMPSTA = GVML_SBPOOL or [M:FAS1]CMPSTA = GVML_SBLVA) and
&       ( (GNBDEPLIEES = 0 and [M:FAS1]ACGETRNOT = 0) or GNBDEPLIEES <> 0 )   ) Then
    # S'il s'agit de la création d'un bien "Pool" ou "LVA", sans dépense et non valorisé alors pas d'analytique
    # L' analytique du bien se fera au travers de l'analytique des dépenses
    B_CTLCCE = 0
    [M:FAS2]DSP = ""
#   Local Integer N_S
#   For N_S = 1 To [M:FAS2]NBRCCE : CCE(N_S-1)= "" : Next
    Raz CCE
  Endif

  # Contrôle de validité des axes analytiques :
  # si clé de répartition non renseignée et que le bien n'est pas "composant"
  If [M:FAS1]CMP = ""
    # FQ67615_8
    If ( B_CTLCCE) Then
      Gosub CTRL_TAB_CCE From GLOBIENSANA
      #Fq-79815 ajout de l'alimentation des axes par défaut, si non-renseignés en Import
      If GIMPORT
         #FQ109789 If LERR
         If GERR=1
            Call  AS_NBRCCE() From SUBFAS
            GMESSAGE="" : OK=1
         Endif
      Endif  #Fq-79815
    Endif
  Endif

  Gosub VERIF_CRE_MOD

Return
########################################
$VERIF_CRE_MOD
Local Decimal WCUMIASBSE, WCUMRNT

  If ( ( (GREP = "M" and [M:LOF6]NBDEST > GNBDEPLIEES and GNBDEPLIEES > 0) or
&        (GREP = "C" and [M:LOF6]NBDEST > 0) ) and GLDABAPPL = G_NON  ) Then
    # Si on est en mode LDAB il faut avoir appliqué pour enregistrer
    # Normalement on ne devrait pas passer ici puisque des zones obligatoire existent et sont
    # à priori non renseignées si on n'a pas fait appliqué... mais prudence !
    GERR = 1
    GMESSAGE = mess(40,GML_MSGFAS,1)
    OK = 0
    Return
  Endif

  If G_ACTLEA = G_OUI : # FQ69678
    #Fq-64312
    If ( [M:FAS2]LEAREF  <> "")  and ( RATT_LEAREF = G_OUI or  MOD_LEAREF = G_OUI or DETA_LEAREF = G_OUI )
      Read[LEA]LEA0 = [M:FAS2]LEAREF
      WCUMIASBSE =  [F:LEA]CUMIASBSE + [M:FAS1]IASETRNOT
      WCUMRNT    =  [F:LEA]CUMRNTAMT
      #Fq-76672 Ctrl uniquement si FRADGI = "OUI" ==> si LEG ="FRA"
      If func GLOBIENS.FRADGI([F:CNX]CPY)
        If WCUMRNT <  WCUMIASBSE
           #Le cumul des bases des biens rattachés au contrat de location dépasse le cumul des redevances du contrat.
           GERR= 1: GMESSAGE = mess(806,GML_MSGFAS,1)
           OK = 0  : Return    #Fq-64312
        Endif
      Endif

      If [M:FAS1]PURDAT  <  [F:LEA]STRLEADAT   or  [M:FAS1]PURDAT   >  [F:LEA]ENDLEADAT
         Call OUINON(mess(420,GML_MSGFAS,1), OK) From GESECRAN
         If ( OK = 1)
           mkstat = 2 : Return
         Endif
      Endif
    Endif
  Endif
  #-1 --------------------------------
  # A revoir avec comme principe Pour CHAQUE PLAN
  # Lire la date de fin d'amortissmeent du bien principal
  # Déterminer la la date fin d'amortissement du bien composant (EXT_DATE_FIN_AMORT_SELON_MODE globi8)
  # La comparer et s'il elle dépasse celle du biien principal message de confirmation
  If ( [M:FAS1]CMP <> "" and 1 = 0 ) Then
    # S'il s'agit d'un bien composant

    # Calcul de la durée du plan fiscal pour un bien complémentaire (lecture du bien principal)
    # Vérification que le bien principal a bien été calculé
    Local Decimal L_DUREE
    Local Integer BERREUR
    Call CALCUL_DUREE_COMPL([M:FAS1]CMP, L_DUREE, BERREUR) From SUBFAS
    If ( ( L_DUREE <> 0 and [M:FAS3]DPRDUR([M:FAS0]FISLIG-1) <> L_DUREE ) or
&        ( GCPLDURPRC = 0 ) ) Then
      # Si aucun paramétrage n'a été défini pour les biens complémentaires ou
      # Si la durée ne correspond pas à la durée calculée selon paramétrage, demande de confirmation
      # l'utilisateur a-t'il vérifié la cohérence entre fin d'amortissement bien principal et bien composant
      # Fin d'amortissement du bien principal
      Read [DEPW] DEP0=[M:FAS1]CMP;G301FIS;GFINEXECPF;GFINPERCPF

      Call OUINON(mess(624,GML_MSGFAS,1)- num$([F:DEPW]ENDDPRDAT)-"\"-
&                 mess(625,GML_MSGFAS,1)- "\"- mess(626,GML_MSGFAS,1), OK) From GESECRAN
      If (OK = G_NON) Then :
        GERR = 1
        OK = 0
        Return
      Endif

    Endif
  Endif
  #-1 --------------------------------
  #Fq-87928   # Récupération du paramètre du Tronc Commun FRADGI au niveau société
  #*FQ-87928 indicateur "Règlementation DGI N° 13L-1-06" de la société
  If dim(GFRADGI) < 0 :     Global Integer  GFRADGI :   Endif
  If func AFNC.PARAM("FRADGI", [M:FAS0]CPY) = num$(G_OUI)
     GFRADGI = G_OUI
  Else
     GFRADGI = G_NON
  Endif
  #Fq-87928 'Attention, le plan Fiscal et le plan de Subvention doivent avoir les mêmes durées.'
  If GFRADGI=G_OUI
    Local Integer  I_SUB :  I_SUB=find(G301SUB,[M:FAS3]DPRPLN)
    If I_SUB > 0
#     If [M:FAS3]DPRDUR(I_SUB-1) <> [M:FAS3]DPRDUR([M:FAS0]FISLIG-1)
      #Fq-89463 Il ne faut contrôler les durées que si le plan de subvention a un mode <> "SA"
      #If ( [M:FAS3]DPM(I_SUB-1) <>  G_DPMSA ) and ([M:FAS3]DPRDUR(I_SUB-1) <> [M:FAS3]DPRDUR([M:FAS0]FISLIG-1) )
      # Issue 117273 et si le plan fiscal a un mode <> "SA"
      If ( [M:FAS3]DPM(I_SUB-1) <>  G_DPMSA ) and ( [M:FAS3]DPM([M:FAS0]FISLIG-1) <>  G_DPMSA ) and
&        ( [M:FAS3]DPRDUR(I_SUB-1) <> [M:FAS3]DPRDUR([M:FAS0]FISLIG-1) )
        GERR= 1: GMESSAGE = mess(819,GML_MSGFAS,1)
        OK = 0  : Return
      Endif
    Endif
  Endif

  # FQ95579 ajout du contrôle
  Call CTRL_AUT_OBJ("GAC", [M:FAS1]GAC, GFASLEDSOC, [M:FAS0]FCY, date$) From GLOBIENS
  If ( mkstat) Then
    GMESSAGE = mess(243,7773,1)-GMESSAGE
    GERR     = 1
    mkstat   = 2
    Return
  Endif
  If (G_PLNIAS) Then
    # FQ95579
    Call CTRL_AUT_OBJ("GAC", [M:FAS1]IASACC, GFASLEDIAS, [M:FAS0]FCY, date$) From GLOBIENS
    If mkstat Then
      GMESSAGE = mess(245,7773,1)-GMESSAGE
      GERR     = 1
      mkstat   = 2
      Return
    Endif
  Endif




Return
#=====================================================================
$INICRE
  # FQ66894
  Call INIFLGCNXFLX("[F:FAS]") From TRTFAS

  # Affectation de champ non renseigné
  If ([F:FAS]ISRTYP = 0) Then              : # Type assurance non assuré par defaut
    [F:FAS]ISRTYP = GVML_TAASSUR
  Endif
  [F:FAS]CREORI = GVML_COSAITR             : # Origine de saisie
  If (GIMPORT) Then
    [F:FAS]CREORI = GVML_COIMPOR
  Endif

  # Affectation des coefficients
  [F:FAS]ASJCOER = [F:FAS]ASJCOE
  [F:FAS]TAXCOER = [F:FAS]TAXCOE
  [F:FAS]ADMCOER = [F:FAS]ADMCOE
  [F:FAS]ASJCOEF = [F:FAS]ASJCOE
  [F:FAS]TAXCOEF = [F:FAS]TAXCOE
  [F:FAS]ADMCOEF = [F:FAS]ADMCOE
  [F:FAS]DEDCOE  = [F:FAS]DEDVATRAT / 100.
  [F:FAS]DEDCOER = [F:FAS]DEDCOE
  [F:FAS]DEDCOEF = [F:FAS]DEDCOE
  [F:FAS]ASJCOEFGLO = G_NON
  [F:FAS]TAXCOEFGLO = G_NON
  [F:FAS]ADMCOEFGLO = G_NON
  [F:FAS]VATYEAFLG  = G_NON
  If GKFR = G_OUI Then
    [F:FAS]VATRSD = func TRTFAS.TVA_GET_PERIODE_RESID( [M:FAS5]THESLI, [M:FAS5]VATREGDAT, GDEBEXECPF )
  Endif

  # FQ54343
  #-1 ----------------------
  If ( G_ACTCCN =  G_OUI ) Then
    #-2 ----------------------
    If ( [F:FAS]OWNTYP = GVML_TDCONCE ) Then
      # S'il s'agit d'un bien "En concession"
      #-3 ----------------------
      If ( G_CCNRPR = G_OUI ) Then
        # Si le type de gestion des concession est "transmis par renouvellement"
        Local Integer I_AMI  :  I_AMI= find ( G_CCNPLNIND, [M:FAS3]DPRPLN )
        Local Integer I_CAD  :  I_CAD= find ( G_CCNPLNCAD, [M:FAS3]DPRPLN )
        # Si le flag OCR est à "Non" et le mode d'amortissement du plan gérant la caducité est "RA" alors
        # La durée d'amortissement du plan gérant la caducité hérite de celle du plan gérant l'amortissement industriel.
        If ( [M:FAS6]OBYRNWCON <> G_OUI and [M:FAS3]DPM(I_CAD-1) = G_DPMRA ) Then
          [M:FAS3]DPRDUR(I_CAD-1) = [M:FAS3]DPRDUR(I_AMI-1)
          Affzo [M:FAS3]DPRDUR(I_CAD-1)
        Endif
      Endif
      #-3 ----------------------
    Else
    #-2 ----------------------
      # S'il ne s'agit pas d'un bien "En concession", nature et type d'entrée en concession à 0
      [F:FAS]CCNETRNAT= 0
      [F:FAS]CCNETRTYP= 0
    Endif
    #-2 ----------------------
  Endif
  #-1 ----------------------

  # Affectation plan d'amortissement
  Local Integer I_PLN
  #>>>>>>>>>>>>
  For I_PLN=1 To [M:FAS3]NBLIG1

    #  Si Mode "UO" et Début d'amt < Début d'Exercice alors le Cumul E-1 est forcé à 0
    If ( ([M:FAS3]DPM(I_PLN-1)=G_DPMUO) & ([M:FAS3]DPRCUM(I_PLN-1)=0) & ([M:FAS3]DPRCUMFLG(I_PLN-1)=G_NON)
&       &([M:FAS3]STRDPRDAT(I_PLN-1)<[M:FAS3]FIYSTRDAT(I_PLN-1)) )
     [M:FAS3]DPRCUMFLG(I_PLN-1)=G_OUI : Affzo [M:FAS3]DPRCUMFLG(I_PLN-1)
    Endif
    # FQ59941
    #  Si Mode "UR" et Début d'amt < Début d'Exercice alors le Cumul E-1 est forcé à 0
    If ( ([M:FAS3]DPM(I_PLN-1)=G_DPMUR) & ([M:FAS3]DPRCUM(I_PLN-1)=0) & ([M:FAS3]DPRCUMFLG(I_PLN-1)=G_NON)
&       &([M:FAS3]STRDPRDAT(I_PLN-1)<[M:FAS3]FIYSTRDAT(I_PLN-1)) )
     [M:FAS3]DPRCUMFLG(I_PLN-1)=G_OUI : Affzo [M:FAS3]DPRCUMFLG(I_PLN-1)
    Endif
    #  Si la remise en cause  de la situation après clôture est interdite
    #  et Début d'Amortissement < Début d'Exercice alors le Cumul E-1 est forcé à 0
    #  En import, il faut laisser la possibilité d'importer des biens avec un cumul forcé <> de 0
    If ( not GIMPORT and
&        [M:FAS0]PRVSITUPD <> G_OUI and [M:FAS3]STRDPRDAT(I_PLN-1) < [M:FAS3]FIYSTRDAT(I_PLN-1) ) Then
     [M:FAS3]DPRCUM(I_PLN-1)   =0.     : Affzo [M:FAS3]DPRCUM(I_PLN-1)
     [M:FAS3]DPRCUMFLG(I_PLN-1)=G_OUI  : Affzo [M:FAS3]DPRCUMFLG(I_PLN-1)
    Endif
    # le mode d'amortissement du bien est forcé à "SA" si nature charge
    If ( [M:FAS1]GACACN = GVML_NICHARG and [M:FAS3]ORIBAS(I_PLN-1) = GVML_OBPCG ) Then
      [M:FAS3]DPM(I_PLN-1)       = "SA"
      [M:FAS3]DPRDUR(I_PLN-1)    = 0
      [M:FAS3]DPRRAT(I_PLN-1)    = 0
      [M:FAS3]DPRRAT2(I_PLN-1)   = 0
      [M:FAS3]DPRRATFLG(I_PLN-1) = G_NON
      [M:FAS3]ENDDPRDAT(I_PLN-1) = [0/0/0]
      [M:FAS3]ACLCOE(I_PLN-1)    = 0
      [M:FAS3]PRATYP(I_PLN-1)    = 0
    Endif
    If ( [M:FAS1]IASACN = GVML_NICHARG and [M:FAS3]ORIBAS(I_PLN-1) = GVML_OBIAS ) Then
      [M:FAS3]DPM(I_PLN-1)       = "SA"
      [M:FAS3]DPRDUR(I_PLN-1)    = 0
      [M:FAS3]DPRRAT(I_PLN-1)    = 0
      [M:FAS3]DPRRAT2(I_PLN-1)   = 0
      [M:FAS3]DPRRATFLG(I_PLN-1) = G_NON
      [M:FAS3]ENDDPRDAT(I_PLN-1) = [0/0/0]
      [M:FAS3]ACLCOE(I_PLN-1)    = 0
      [M:FAS3]PRATYP(I_PLN-1)    = 0
    Endif
    # FQ59941
    If ( G_ACTKRU = G_OUI ) Then
      If ( [M:FAS3]DPRPLN(I_PLN-1) = G301FIS & [M:FAS3]ALWCOD(I_PLN-1) = GVML_RPBONUS  ) Then
        # Bonus
        Call CAL_EVALUE_BONUS ( [M:FAS3]DPRBAS(I_PLN-1), [M:FAS3]DPRRAT2(I_PLN-1), [M:FAS3]CUR(I_PLN-1), [F:FAS]KBONUS) From GLOBB4RU
      Endif
    Endif
    # FQ86558
    If ([M:FAS0]PRVSITUPD <> G_OUI)
      [M:FAS3]DPRCUMFLG(I_PLN-1)=G_OUI : Affzo [M:FAS3]DPRCUMFLG(I_PLN-1)
    Endif
  Next I_PLN
  #<<<<<<<<<<<<
  Gosub INI_CRE_MOD

  # Numérotation automatique
  If ( GAASAUTNUM = 2 or (GAASAUTNUM = 3 and [M:FAS0]AASREF="") ) Then
    Local Integer STAT
    # Appel du compteur de document FQ85464
    Call GET_NUMERO("FAS",GVML_NUMAAS-1,1,[M:FAS0]CPY,[M:FAS0]FCY,date$,[F:FAS]AASREF,STAT) From GLOBIENS
    If ( STAT ) Then : GOK = 0 : Return : Endif
    [M:FAS0]AASREF = [F:FAS]AASREF : Affzo [M:FAS0]AASREF
  Endif

  # Si Ensemble n'est pas renseigné
  If ( [M:FAS1]SET = "" ) Then
    [M:FAS1]SET =[M:FAS0]AASREF : Affzo [M:FAS1]SET
    Affzo [M:FAS1]SET
    [F:FAS]SET =[M:FAS0]AASREF
  Endif

  Local Integer I_PLN
  If ( ( [F:FAS]VATREGDAT >= GDEBEXECPF and [F:FAS]VATREGDAT <= GFINEXECPF ) or
&      ( [F:FAS]VATREGDAT <  GDEBEXECPF and
&        [M:FAS3]LSTCLODAT(find(G301CPT,[M:FAS3]DPRPLN)-1)= [0/0/0] ) ) Then
    # Affectation Taux récupération intiale Régularisation de TVA
    [F:FAS]INIDEDVAT = [F:FAS]DEDVATRAT
    # Ecriture dans HISVAT ( PCG )
    [F:HFAS] = [F:FAS]
    Local Integer L_ERROR
    Call TVA_ECR_HISTORIQUE
&   (GVML_TRCREAT,G301CPT,[M:FAS3]BSEVAL(find(G301CPT,[M:FAS3]DPRPLN)-1),
&                         [M:FAS3]BSEVAL(find(G301CPT,[M:FAS3]DPRPLN)-1),"",L_ERROR) From TRTFAS
  Endif
  If ( GCNXPROIAS = G_OUI ) Then
    If ( ( [F:FAS]VATREGDAT >= GDEBEXECPF and [F:FAS]VATREGDAT <= GFINEXECPF ) or
&        ( [F:FAS]VATREGDAT <  GDEBEXECPF and
&          [M:FAS3]LSTCLODAT(find(G301IAS,[M:FAS3]DPRPLN)-1)= [0/0/0] ) ) Then
      # Ecriture dans HISVAT ( IAS )
      Call TVA_ECR_HISTORIQUE
&     (GVML_TRCREAT,G301IAS,[M:FAS3]BSEVAL(find(G301IAS,[M:FAS3]DPRPLN)-1),
&                           [M:FAS3]BSEVAL(find(G301IAS,[M:FAS3]DPRPLN)-1),"",L_ERROR ) From TRTFAS
    Endif
  Endif
  # Affectation Taux récupération intiale Régularisation de TVA
  [F:FAS]INIDEDVAT = [F:FAS]DEDVATRAT

  # FQ100398/13 la gestion des elts phy est positionnée ds APRES_CRE


  # FQ56478 La génération d'un evt de sortie à l'import ne se fait plus dans SUBFAS
  # Le code a été enlevé pour gagner de la place

  Affzo [M:FAS3]
Return

########################################
$INI_CRE_MOD

  # Numérotation automatique du code à barres
  Local Integer    LOK
  # Fiche 48468

  # On utilise dans le masque FAS4 les mêmes champs ACGCPLDED et IASCPLDED pour stocker soit les montants
  # les déductions complémentaires de TVA ([F]ACGCPLDED et [F]IASCPLDED) si le taux de TVA due sur vente
  # est supérieur à zéro, soit les montants de reversement de TVA ([F]ACGREVVAT et [F]IASREVVAT) si
  # le taux de TVA due sur vente est égal à zéro, d'où la jonglerie suivante :
  If ( [M:FAS4]ISSVATRAT = 0 ) Then
    [F:FAS]ACGCPLDED = 0
    [F:FAS]IASCPLDED = 0
    [F:FAS]ACGREVVAT = [M:FAS4]ACGCPLDED
    [F:FAS]IASREVVAT = [M:FAS4]IASCPLDED
  Endif


  # Tableau des +/- values
  # Correspondance entre les indices de FXDASSETS et les indices du tableau
  # Attention : le Superviseur a fait avant un [F:FAS] = [M:FAS4], il y a donc des informations
  #             dont les indices sont mauvais. On les remet à 0.
  For I_PLN = 1 To G301MAX-1
    If find(I_PLN,[M:FAS4]DPRPLN)
      [F:FAS]ISSAMT   (I_PLN-1) = [M:FAS4]ISSAMT   (find(I_PLN,[M:FAS4]DPRPLN)-1)
      [F:FAS]GAL      (I_PLN-1) = [M:FAS4]GAL      (find(I_PLN,[M:FAS4]DPRPLN)-1)
      [F:FAS]SHOGAL   (I_PLN-1) = [M:FAS4]SHOGAL   (find(I_PLN,[M:FAS4]DPRPLN)-1)
      [F:FAS]LNGGAL   (I_PLN-1) = [M:FAS4]LNGGAL   (find(I_PLN,[M:FAS4]DPRPLN)-1)
      [F:FAS]IMLRVEISS(I_PLN-1) = [M:FAS4]IMLRVEISS(find(I_PLN,[M:FAS4]DPRPLN)-1)
    Else
      [F:FAS]ISSAMT   (I_PLN-1) = 0
      [F:FAS]GAL      (I_PLN-1) = 0
      [F:FAS]SHOGAL   (I_PLN-1) = 0
      [F:FAS]LNGGAL   (I_PLN-1) = 0
      [F:FAS]IMLRVEISS(I_PLN-1) = 0
    Endif

    #----------------
    If (G_ACTKRU = G_OUI) Then
      If find(I_PLN,[M:FAS3]DPRPLN) > 0
        # Autocorrection : La saisonnalité ne concerne que le mode LR, ML, MD  FQ72372
        If (  [M:FAS3]SESFLG(find(I_PLN,[M:FAS3]DPRPLN)-1) = G_OUI and
&           ( [M:FAS2]KPSEPLN = "" or
&             ( find([M:FAS3]DPM(find(I_PLN,[M:FAS3]DPRPLN)-1), G_DPMLR, G_DPMML, G_DPMMD) = 0) ) ) Then
          [M:FAS3]SESFLG(find(I_PLN,[M:FAS3]DPRPLN)-1) = G_NON
        Endif

        If ( I_PLN = 1 ) Then
          [F:FAS]KSESFLG  =  num$([M:FAS3]SESFLG (find(I_PLN,[M:FAS3]DPRPLN)-1))
        Else
          [F:FAS]KSESFLG +=  num$([M:FAS3]SESFLG (find(I_PLN,[M:FAS3]DPRPLN)-1))
        Endif
      Else
        If (I_PLN = 1) Then : [F:FAS]KSESFLG =  num$(G_NON) : Else : [F:FAS]KSESFLG +=  num$(G_NON) : Endif
      Endif
    Endif
    #------------------

  Next I_PLN
Return


#=====================================================================
$CREATION

  Gosub INSERT From SUBFAS2
  Gosub MARQUE_DEPENSE_LIEES From FUNLOFLDAB

Return

#=====================================================================
$APRES_CRE
Local Char GREPSAV

  # FQ100398/13 la gestion des elts phy est positionnée ici et plus dans INICRE
  If GPHY = G_OUI Then
    # FQ 49517 - Création automatique d'un élément physique
    # Alimentation de l'écran FAS8 avec le nouvel élt physique

    Local Char PHYAUTCRE_SOC(10)
    Call PARAM([M:FAS0]CPY, "PHYAUTCRE", PHYAUTCRE_SOC) From ADOVAL


    If GPHYAUTCRE = G_OUI or PHYAUTCRE_SOC = num$(G_OUI)
     # Sur un bien composant si le bien principal n'a pas de localisation et qu'il n'a pas d'élément rattaché : on ne fait pas de création auto
     # Sur un bien principal qui n'a pas de localisation et qui n'a pas d'élément rattaché et qui a des composants : on ne fait pas de création auto
# FQ100398/13
#&     or ([M:FAS1]CMPSTA = GVML_SBPRINC and [M:FAS8]NBPHY = 0 and func TRTPHYTOOL.RECH_COMP_FAS_PRINC([M:FAS0]AASREF)>0) Then
      If ([M:FAS1]CMP <> ""  and func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [M:FAS1]CMP +"'") = 0)
&     or ([M:FAS1]CMPSTA = GVML_SBPRINC and [M:FAS8]NBPHY = 0 and func TRTPHYTOOL.RECH_COMP_FAS_PRINC([M:FAS0]AASREF)>0) Then
      Else
        Gosub MAJ_CRE_AUTO_ELT_PHYSIQUE From SUBFAS2
        If GOK = 0
          Return
        Endif
      Endif
    Endif
    # FQ 49517

    # MAJ des éléments physiques avec la sauvegarde du tableau dans FAS8
    # Numérotation des éléments physiques à partir du bien
    Gosub MAJ_ELT_PHYSIQUE
#    If (GOK = 0) Then : Gosub DEL_CRE_ELT From SUBFAS2 : Return : Endif
    If (GOK = 0) Then  Return : Endif
  Endif

  # En import
  If ( GIMPORT ) Then : Return : Endif

  # Calcul du bien
  ACALCULER = ""
  Gosub CALCUL_BIEN From SUBFAS

  # Avant le réaffichage du bien créé, Diszo de certains champs inaccessibles en modification
  GREPSAV = GREP
  GREP = ""
  # FQ49517 Création d'un élément physique
  # On relit l'enregistrement, car sinon, si PHYAUTCRE à oui, l'icône d'élément physique
  # rattaché n'est pas affichée, et le n° de l'élément physique n'est pas rafraîchi
  # (si CALAUTVAL est à oui, le RELIT est fait CALCUL_BIEN appelé plus haut)
  If ( GIMPORT = 0 ) Then
    Gosub RELIT From GOBJSUB
  Endif
  # FQ49517  # Création d'un élément physique
  Gosub AFFICHE_ELT_PHY
  # FQ67255
  # Gosub MODIF_REDUITE From SUBFAS2
  GREP = GREPSAV
  Gosub INIT_LIENS From SUBFAS
  Gosub MODIF_REDUITE From SUBFAS2

  # FQ81975
  GLDABAPPL = G_NON
  # FQ84334
#  # FQ81977
#  # Réinitialisation des valeurs relatives à l'immobilisation des dépenses
#  Gosub RAZ_PICKING From FUNLOFLDAB
#  Gosub READ_DEP_PRINCIPALE From FUNLOFLDAB
Return

#FQ57407
########################################
$INSERT

# Evénement
Local Integer LCDRET
Local Char    LCDINT(10)


  For nolign = 1 To [M:FAS3]NBLIG1
    Raz  [F:DEP]
    [F:DEP]           = [M:FAS3]
    [F:DEP]CPY        = [M:FAS0]CPY
    [F:DEP]FCY        = [M:FAS0]FCY     : # FQ47879
    [F:DEP]AASREF     = [M:FAS0]AASREF
    [F:DEP]DEPSTA     = GVML_SCNOCAL

    # FQ75616
    If not [M:FAS3]BREPRISE(nolign-1) Then
      [F:DEP]DPMI       = [F:DEP]DPM
      [F:DEP]DPMT       = [F:DEP]DPM
    Endif

    # FQ80825
    [F:DEP]KSTPDEPSTA = GVML_SSNOSTP

    # FQ67615
    If ( GNBDEPLIEES = 0 and [M:FAS1]CMPSTA = GVML_SBPOOL and [M:FAS3]STRDPRDAT(0) >= [M:FAS3]FIYSTRDAT(0) ) Then
      # Pas de valorisation lors de la création d'un bien "Pool" en direct
    # si le début d'amortissement de celui -ci n'est pas antérieur à l'exercice courant
      [F:DEP]DPRBAS    = 0
      [F:DEP]RSDVAL    = 0
      [F:DEP]DPRCUM    = 0
      [F:DEP]DPRCUMFLG = G_NON
    Endif

    # FQ73777
    #[F:DEP]MTCTIATYP  = 0
    #[F:DEP]MTCDEVADJ  = 0
    [F:DEP]RVATIADAT  = 0  : # FQ75598
    # FQ75616
    If not [M:FAS3]BREPRISE(nolign-1) Then
      [F:DEP]PERREFCLC  = [M:FAS3]FIYSTRDAT(nolign-1)
      [F:DEP]PERREFCLCI = [M:FAS3]FIYSTRDAT(nolign-1)
      [F:DEP]PERREFCLCT = [M:FAS3]FIYSTRDAT(nolign-1)
    Endif

    # FQ73777
    If ( [M:FAS0]PRVSITUPD <> G_OUI and [M:FAS3]DPRCUM(nolign-1)=0 and [M:FAS3]DPRCUMFLG(nolign-1) = G_OUI and
&        [M:FAS3]STRDPRDAT(nolign-1) < [M:FAS3]FIYSTRDAT(nolign-1) and [M:FAS3]DPM(nolign-1) <> G_DPMSA ) Then
     [F:DEP]MTCDPEDAT = [M:FAS3]STRDPRDAT(nolign-1)
     [F:DEP]MTCTIADAT = [M:FAS3]STRDPRDAT(nolign-1)
     [F:DEP]MTCTIATYP = GVML_PEDBAM                    :# Prise d'effet Début d'amortissement
     [F:DEP]MTCDEVADJ = GVML_RDOTPER                   :# Rattrapage Dotation période
    Else
     [F:DEP]MTCDPEDAT= [0/0/0]
     [F:DEP]MTCTIADAT= [0/0/0]
     [F:DEP]MTCTIATYP= 0
     [F:DEP]MTCDEVADJ= 0
    Endif
    # FQ52886
    If ( [M:FAS3]DPRCUMFLG(nolign-1) = G_OUI ) Then
      # FQ75616
      If not [M:FAS3]BREPRISE(nolign-1) Then
        If ([M:FAS3]EXECLOCUMI(nolign-1) = 0.) Then
          [F:DEP]EXECLOCUMI = [M:FAS3]DPRCUM(nolign-1)
        Endif
        [F:DEP]EXECLOCUMT = [M:FAS3]DPRCUM(nolign-1)
      Endif
    Endif
    If ( [M:FAS1]OWNTYP = GVML_TDCONCE and G_CCNRPR = G_OUI and [M:FAS3]DPRPLN(nolign-1) = G_CCNPLNCAD ) Then
      # Si le bien est "En concession" et que le type de gestion est "Transmis par renouvellement" pour le plan de caducité
      # FQ75616
      If ( [M:FAS6]TRFCADCUM <> 0 ) Then
        [F:DEP]TRFCADCUM = [M:FAS6]TRFCADCUM
      Endif
      [F:DEP]P_1CADCRB = [M:FAS6]P_1CADCRB
    Endif
    # FQ59941 FQ77877 FQ80825
    If ( ([M:FPC]LEG = "RUS" or (G_ACTDRO = G_OUI and [M:FPC]LEG="RUM")) and
&         [F:DEP]DPRBAS <> 0 and [M:FAS0]ENAFAS <> G_NON ) Then
      # Valeur nette anniversaire
      [F:DEP]KBIRNBV  = [M:FAS3]DPRBAS(nolign-1)
      [F:DEP]KBIRNBVT = [M:FAS3]DPRBAS(nolign-1)
      [F:DEP]KBIRNBVI = [M:FAS3]DPRBAS(nolign-1)
    Endif

    # FQ75616
    If not [M:FAS3]BREPRISE(nolign-1) Then
      [F:DEP]PERTRFCUM = [M:FAS3]PERTRFCUM(nolign-1)
      [F:DEP]PERRVACUM = [M:FAS3]PERRVACUM(nolign-1)
    Endif

    Write [DEP]
    If ( fstat ) Then
      GOK = 0
      Call FSTA("DEP") From GLOCK
      Break
    Endif

    # Génération d'un évènement de type "Immobilisation" si le bien est sans dépense
    # et que la valeur bilan est non nulle et que le bien est actif

    #-1-------------------------
    If ( GNBDEPLIEES = 0 and [F:DEP]DPRBAS <> 0 and [M:FAS0]ENAFAS <> G_NON ) Then
      LCDINT= "FASCRT"+num$([M:FAS3]DPRPLN(nolign-1))
      Call GENER_EVE
&         (GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCDINT,[F:FAS]AASIPTDAT,[0/0/0],LCDRET)
&     From GENEVE
      If ( LCDRET > 20 ) Then
        GOK = 0
        Call FSTA("EFASCRT") From GLOCK
        Break
      Endif

      # FQ59941
      If ( G_ACTKRU = G_OUI ) Then
        If ( [F:DEP]DPRPLN = G301FIS & [F:DEP]ALWCOD= GVML_RPBONUS  ) Then
          # Bonus
          If ([F:FAS]KBONUS) Then
            LCDINT= "FASRUCRT"+num$([M:FAS3]DPRPLN(nolign-1))
            Call GENER_EVE (GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCDINT,[F:FAS]AASIPTDAT,[0/0/0],LCDRET) From GENEVE
            If (LCDRET > 20) Then
              GOK = 0
              Call FSTA("EFASRUCRT") From GLOCK
              Break
            Endif
          Endif
        Endif
      Endif

    Endif
    #-1-------------------------

    # Génération d'un flux sur la période précédente pour pouvoir constater une actualisation ou un transfert
    # dans la période de création (voir TRTFLUX)
    #-1------------------------- FQ75129
    If [M:FAS0]ENAFAS = G_OUI
      If  !((([F:FAS]AASIPTDAT >= [F:DEP]FIYSTRDAT) and (([F:DEP]STRDPRDAT >= [F:DEP]FIYSTRDAT) or ([F:DEP]DPRCUM =  0)))
&     or     ((find([F:FAS]ETRNAT,GVML_NEAPPOR,GVML_NEFUSIO,GVML_NESCISS,GVML_NEVTEIG)<>0)
&        and (([F:FAS]GRUEFFDAT>=[F:DEP]FIYSTRDAT) and ([F:FAS]GRUEFFDAT<=[F:DEP]FIYENDDAT)))) Then
        Local Integer RERROR
        Call CREAT_FLUX_INITIAL("[F:FAS]", "[F:DEP]", RERROR) From TRTFLUX
        If RERROR
          Call GERE_MSG_ERREUR_FLUX(RERROR, GMESSAGE) From TRTFLUX
          GOK = 0
          Break
        Endif
      Endif
    Endif
    #-1-------------------------

  Next nolign


  #FQ54343
  If ( [M:FAS1]OWNTYP = GVML_TDCONCE and G_CCNRPR = G_OUI ) Then
    # Si le bien est "En concession" et que le type de gestion est "Transmis par renouvellement"

    Local Integer I_AMI
    I_AMI= find ( G_CCNPLNIND, [M:FAS3]DPRPLN )
    # FQ 54343
    Raz [F:RPR]
    [F:RPR]CPY       = [M:FAS0]CPY
    [F:RPR]FCY       = [M:FAS0]FCY
    [F:RPR]AASREF    = [M:FAS0]AASREF
    [F:RPR]FIYSTRDAT = [M:FAS3]FIYSTRDAT(I_AMI-1)
    [F:RPR]FIYENDDAT = [M:FAS3]FIYENDDAT(I_AMI-1)
    [F:RPR]PERSTRDAT = [M:FAS3]PERSTRDAT(I_AMI-1)
    [F:RPR]PERENDDAT = [M:FAS3]PERENDDAT(I_AMI-1)
    [F:RPR]CCNREF    = [M:FAS6]CCNREF
    If ( [M:FAS6]STRRNWVAL = 0 ) Then
      [F:RPR]STRRNWVAL = [M:FAS3]DPRBAS(I_AMI-1)
    Else
      [F:RPR]STRRNWVAL = STRRNWVAL
    Endif
    If ([M:FAS6]RNWVALFLG = G_OUI) Then
      [F:RPR]ENDRNWVAL = [M:FAS6]RNWVAL
      [F:RPR]RNWVALFLG = G_OUI
    Else
      [F:RPR]RNWVALFLG = G_NON
    Endif

    # FQ75616
    [F:RPR]P_1ACGRPR = [M:FAS6]P_1ACGRPR
    [F:RPR]P_1FISRPR = [M:FAS6]P_1FISRPR
    [F:RPR]P_1RVERPR = [M:FAS6]P_1RVERPR
    [F:RPR]E_1SUPCAD = [M:FAS6]E_1SUPCAD
     [F:RPR]P_1SUPCAD = [M:FAS6]P_1SUPCAD

    [F:RPR]E_1ACGRPR = [M:FAS6]E_1ACGRPR
    [F:RPR]E_1FISRPR = [M:FAS6]E_1FISRPR
    [F:RPR]E_1RVERPR = [M:FAS6]E_1RVERPR

    Write [RPR]
    If ( fstat ) Then
      GOK = 0
      Call FSTA("RPR") From GLOCK
    Endif
  Endif

    #- FQ-64312  --------------------------
  If ( G_ACTLEA = G_OUI )
       If DETA_LEAREF= G_OUI and [M:FAS2]LEAREFORI <> ""
        Update [LEA]
&       Where LEAREF= [M:FAS2]LEAREFORI
&       With  CUMIASBSE -= [M:FAS1]IASETRNOT
        If ( fstat ) Then
          GOK = 0
          Call FSTA("RPR") From GLOCK
        Endif
     Endif
     If ( RATT_LEAREF = G_OUI ) or ( MOD_LEAREF = G_OUI )
        Update [LEA]
&       Where LEAREF= [M:FAS2]LEAREF
&       With  CUMIASBSE += [M:FAS1]IASETRNOT
        If ( fstat ) Then
           GOK = 0
           Call FSTA("LEA") From GLOCK
        Endif
     Endif

  Endif
  If GOK=0 : Return : Endif

Return

#----------#
#  MODIF   #
#----------#

#=====================================================================
$VERIF_MOD
Local Integer    LOK
Local Integer    N_I  #Fq-89714

  # FQ55719 : la classe [F:FAS] a pu être modifiée ou vidée par des actions métiers, on relit le bien
  Read [F:FAS]FAS0 = [M:FAS0]AASREF


  #Fq-89714--------------------------
  # On vérifie que les) dépenses que l'on veut rattacher n'ont pas déjà été rattachées à un autre bien comptable
  # ==> possible si 2 users immobilisent les mêmes dépenses au même moment
  If GNBDEPLIEES
     If !clalev([F:LOFR]) : Local File LAYOUTFAS [LOFR] : Endif
     For N_I = 1 To [M:LOF6]NBDEST
        Read [LOFR]LOF0= [M:LOF6]CODLOF(N_I-1);[M:LOF6]LINLOF(N_I-1)
        If ( [F:LOFR]AASREF <> "" )  and  ([F:LOFR]AASREF<> [M:FAS0]AASREF )
           #Impossible de rattacher les dépenses sélectionnées car elles viennent d'être rattachées à un autre bien
           GERR=1 :  GMESSAGE = mess(905,GML_MSGFAS,1)
           Disable GSTAENR : GMODOK = G_NON
           GOK=0 : Break
        Endif
     Next N_I
  Endif
  If GOK=0 : Return : Endif
  #Fq-89714--------------------------

  #Fq70466-Chgt Plan prod --> Génération d'un événement et archivage
  If [M:FPC]LEG="FRA" & [F:FAS]PROPLN<>[M:FAS2]PROPLN & find(G_DPMUO,[M:FAS3]DPM)
   Local Integer I_PLN, CODERR
   Local Char    LEVTINT
   For I_PLN=1 To [M:FAS3]NBLIG1
    If [M:FAS3]DPM(I_PLN-1)=G_DPMUO
     LEVTINT="FASCHGPPL"+num$([M:FAS3]DPRPLN(I_PLN-1))
     Call GENER_EVE(GVML_OMBIEN,
&                   [F:FAS]CPY,
&                   [F:FAS]FCY,
&                   [F:FAS]AASREF,
&                   0,
&                   LEVTINT,
&                   date$,
&                   date$,
&                   CODERR) From GENEVE
     If CODERR<>0
      GMESSAGE =  "Erreur lors de la création de l'événement de changement de plan de production"
      GERR     =  1
      OK       =  0
      GOK      = -1
     Endif
    Endif
   Next I_PLN
  Endif

  Gosub VERIF_CRE_MOD

  # Si module Contrat Financement est actif alors verrouillage des composants
  # pour report du nouveau contrat sur les composants dans $MODIF
  REPORT_LEAREF = G_NON
  If (G_ACTLEA = G_OUI) Then
    If ([F:FAS]LEAREF <> [M:FAS2]LEAREF and [M:FAS0]LIKCMPFLG = G_OUI) Then
      Call OUINON(mess(114,GML_MSGFAS,1), LOK) From GESECRAN
      If ( LOK = G_NON) Then : OK = 0 : Return : Endif
      # Lock des biens "composant"
      REPORT_LEAREF = G_OUI
      Gosub LOCK_COMPOSANT From SUBFAS
      If (OK = 0 ) Then
        # Unlock tout ce qui a été verrouillé
        REPORT_LEAREF = G_NON
        Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
        Return
      Endif
    Endif
  Endif

  # Modification du flag "Actif"
  If ( [M:FAS0]ENAFAS <> [F:FAS]ENAFAS ) Then
    If ( [M:FAS0]ENAFAS = G_OUI ) Then
      Call OUINON(mess(522,GML_MSGFAS,1)-mess(277,GML_MSGFAS,1), LOK) From GESECRAN
      If ( LOK = G_NON) Then : OK = 0 : Return : Endif
      GMODENAFAS = 1
    Else
      Call OUINON(mess(523,GML_MSGFAS,1)-mess(277,GML_MSGFAS,1), LOK) From GESECRAN
      If ( LOK = G_NON) Then : OK = 0 : Return : Endif
      GMODENAFAS = 2
    Endif
  Endif

  If ( ([M:FAS0]ENAFAS    <> [F:FAS]ENAFAS and [M:FAS0]ENAFAS = G_OUI)  or
&      ([M:FAS1]PURDAT    <> [F:FAS]PURDAT)                             or
&      ([M:FAS1]ITSDAT    <> [F:FAS]ITSDAT)                             or
&      ([M:FAS1]AASIPTDAT <> [F:FAS]AASIPTDAT)                          or
&      ([M:FAS2]PROPLN    <> [F:FAS]PROPLN)                             or
&      ([M:FAS1]AASTYP    <> [F:FAS]AASTYP)                             or
&      ([M:FAS1]PURNAT    <> [F:FAS]PURNAT)             ) Then
    #
    # Contrôle de la méthode quand le bien devient actif
    #                              après modif de la date de mise en service ou celle de comptabilisation
    #                              après modif de la nature du bien
    #

    #>>>>>>>>>>>>>>>>
    For nolign = 1 To [M:FAS3]NBLIG1

      # Si le bien est inactif et que le mode n'est pas alimenté, mode SA par défaut
      If ( [M:FAS3]DPM(nolign-1) = "" and [M:FAS0]ENAFAS <> G_OUI  ) Then
        [M:FAS3]DPM(nolign-1) = G_DPMSA
      Endif

      [M:METH] = [M:FAS0]
      [M:METH] = [M:FAS1]
      [M:METH] = [M:FAS2]
      [M:METH] = [M:FAS3]
      If ( G_ACTCCN =  G_OUI ) Then : [M:METH] = [M:FAS6] : Endif
      [M:METH]FLGBCO = G_OUI
      # Controle de la méthode pour chaque plan d'amortissement
      Call CONTROLE_METHODE () From TRTFAS
      If ( [M:METH]MSGERR) Then
        GERR=1 : OK = 0
        #*X3-61112 the 40% tax deduction on investement (Macron Law)
        If [M:METH]MSGERR <> 942
          GMESSAGE =  mess(124,GML_MSGFAS,1)- mess([M:FAS3]DPRPLN(nolign-1),3101,1)- '-->' - mess([M:METH]MSGERR,[M:METH]MSGFIL,1)
          Gosub MODIF_REDUITE From SUBFAS2
          zonsui = "[M:FAS3]DPM(nolign-1)"
        Else
          GMESSAGE = mess(124,GML_MSGFAS,1)- mess([M:FAS3]DPRPLN(nolign-1),3101,1)
          zonsui = "[M:FAS3]ALWCOD(nolign-1)"
          Disable GSTAENR : GMODOK = G_NON
        Endif  #*X3-61112 End
        Break
      Endif
    Next nolign
    #<<<<<<<<<<<<<<<
    If ( OK = 0 ) Then : Return : Endif
    G_ARECALCULER = G_OUI
  Endif

  If (G_ARECALCULER) Then
    [M:FAS0]FLGCLC = G_OUI
    # FQ54343
    If ( G_ACTCCN = G_OUI ) Then
      If ( G_CCNRPR = G_OUI ) Then
        [M:FAS0]FLGRPRCLC = G_OUI
      Else
        [M:FAS0]FLGRPRCLC = G_NON
      Endif
    Endif

    For nolign = 1 To [M:FAS3]NBLIG1
      # FQ68431
      [M:FAS0]FLGCNXCLC([M:FAS3]CNX(nolign-1)-1) = G_OUI
      [M:FAS3]DEPSTA(nolign-1)         = GVML_SCNOCAL
    Next nolign
  Endif

  # Contrôle de validité des axes analytiques
  # Si clé de répartition non renseignée ET que le bien n'est pas composant
  If ( [M:FAS2]DSP = "" & [M:FAS1]CMP = "" ) Then
    Local Integer I_AXE
    For I_AXE=1 To GOPTCANA
     #@DEV-Suprimmé pour pouvoir saisir un bien
#     If ( evalue("GANASAI"+num$(I_AXE)+"=2 & [M]CCE(I_AXE-1)=''") )
     #  GERR     = 1
     #  GMESSAGE = mess(46,106,1)-num$(I_AXE)-"("+mess(I_AXE,601,1)+")"
     #  OK       = 0
     #  zonsui   = "CCE("+num$(I_AXE-1)+")"
     #  Actzo  [M:FAS2]CCE(I_AXE-1)
     #  Break
#     Endif
    Next I_AXE
  Endif

Return

#=====================================================================
$AVANT_MODFIC
  # Gestion actions objets métiers
   Gosub ACTION From TRTOBJACT
  # Fiche 48468
  If GOK=0 Then
    Return
  Else
    Read [F:FAS]FAS0=[M:FAS0]AASREF  # pour se repositionner sur l'enregistrement courant, quand le compteur est dephasé.
  Endif

  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2
  # Fiche 48468
  If GOK=0 Then
    Return
  Endif
  # FQ100398/13 la gestion des elts phy est positionnée ds APRES_MOD et plus dans AVANT_MODFIC

  If ( [M:FAS1]OWNTYP = GVML_TDCONCE and G_CCNRPR = G_OUI ) Then
    Local Integer B_RNWVALFLG
    If ( [M:FAS6]RNWVALFLG <> [F:FAS]RNWVALFLG ) Then
      B_RNWVALFLG = 1
    Else
      B_RNWVALFLG = 0
    Endif
  Endif

  #Fq67577-Pologne
  If G_ACTKPL=G_OUI & dim(GFASMDRCCL)>0
   Gosub APPLIQUER_DDAB From TRTFASMDR
  Endif

Return

#=====================================================================
$INIMOD

  Gosub INI_CRE_MOD
  # Recalcul systématique du coefficient de déduction
  Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, [F:FAS]DEDCOE ) From TRTFAS

  # FQ59941  Bonus
  If ( G_ACTKRU = G_OUI ) Then
    Local Integer I_PLN
    #>>>>>>>>>>>>
    For I_PLN=1 To [M:FAS3]NBLIG1
      If ( [M:FAS3]DPRPLN(I_PLN-1) = G301FIS & [M:FAS3]ALWCOD(I_PLN-1) = GVML_RPBONUS  ) Then
        Call CAL_EVALUE_BONUS ( [M:FAS3]DPRBAS(I_PLN-1), [M:FAS3]DPRRAT2(I_PLN-1), [M:FAS3]CUR(I_PLN-1), [F:FAS]KBONUS) From GLOBB4RU
      Endif
    Next I_PLN
    #<<<<<<<<<<<<
  Endif

Return

#=====================================================================
$MODIF

# Evénement FQ80825
Local Integer NBENRDEL, LCDRET, LREVTCREE
Local Decimal LCUMIAS

  #  Par défaut : "Modification réussie"
  GMODOK = G_OUI

  # Annule et remplace  Paramétres des plans d'amortissement
  # >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
  For nolign = 1 To [M:FAS3]NBLIG1
    Read [DEP] DEP0=[M:FAS0]AASREF;[M:FAS3]DPRPLN(nolign-1);[M:FAS3]FIYENDDAT(nolign-1);
&                   [M:FAS3]PERENDDAT(nolign-1)
    If (fstat) Then
      GOK = 0 : GMODOK = G_NON
      Call RSTA("DEP",[M:FAS0]AASREF) From GLOCK
      Return
    Endif

    [F:DEP] = [M:FAS3]

    # FQ59941 FQ77877
    If ( find([M:FPC]LEG, "RUS") <> 0 and [M:FAS3]DPRBAS(nolign-1) <> 0 and [M:FAS0]ENAFAS <> G_NON ) Then
      # Valeur nette anniversaire
      [F:DEP]KBIRNBV  = [M:FAS3]DPRBAS(nolign-1)
      [F:DEP]KBIRNBVT = [M:FAS3]DPRBAS(nolign-1)
      [F:DEP]KBIRNBVI = [M:FAS3]DPRBAS(nolign-1)
    Endif

    # FQ80825
    If ( (G_ACTDRO = G_OUI and [M:FPC]LEG="RUM") and [M:FAS3]DPRBAS(nolign-1) <> 0 and [M:FAS0]ENAFAS <> G_NON and
&        [M:FAS3]LSTCLODAT(nolign-1) = [0/0/0] ) Then
      # Valeur nette anniversaire
      [F:DEP]KBIRNBV  = [M:FAS3]DPRBAS(nolign-1)
      [F:DEP]KBIRNBVT = [M:FAS3]DPRBAS(nolign-1)
      [F:DEP]KBIRNBVI = [M:FAS3]DPRBAS(nolign-1)
    Endif

    Rewrite [DEP]
    If (fstat) Then
      GOK = 0: GMODOK = G_NON
      Call RSTA("DEP",[M:FAS0]AASREF) From GLOCK
      Return
    Endif

    # Génération d'un évènement de type "Immobilisation" si le bien est sans dépense
    # et que la valeur bilan est non nulle et que le bien passe de "inactif" à "actif"
    #-1 -------------------------------
    If ( GNBDEPLIEES = 0 and [F:DEP]DPRBAS <> 0 and GMODENAFAS = 1 ) Then
     #If [M:FAS3]DPRPLN(nolign-1)=G301CPT |  [M:FAS3]DPRPLN(nolign-1)=G301IAS
       LCDINT= "FASCRT"+num$([M:FAS3]DPRPLN(nolign-1))
       Call GENER_EVE ( GVML_OMBIEN, [F:FAS]CPY, [F:FAS]FCY, [F:FAS]AASREF, 0,
&                       LCDINT, [F:FAS]AASIPTDAT, [0/0/0], LCDRET ) From GENEVE
       If (LCDRET > 20) Then
         GOK = 0
         Call FSTA("EFASCRT") From GLOCK
         Break
       Endif
     #Endif

      # FQ59941
      If ( G_ACTKRU = G_OUI ) Then
        If ( [F:DEP]DPRPLN = G301FIS & [F:DEP]ALWCOD= GVML_RPBONUS  ) Then
          # Bonus
          If ([F:FAS]KBONUS) Then
            LCDINT= "FASRUCRT"+num$([M:FAS3]DPRPLN(nolign-1))
            Call GENER_EVE (GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCDINT,[F:FAS]AASIPTDAT,[0/0/0],LCDRET) From GENEVE
            If (LCDRET > 20) Then
              GOK = 0
              Call FSTA("EFASRUCRT") From GLOCK
              Break
            Endif
          Endif
        Endif
      Endif
    Endif
    #-1 ------------------------------

    # Suppression de l'événement d'immobilisation lorsque le bien passe de "actif" à "inactif"
    #-1 -------------------------------
    If ( GNBDEPLIEES = 0 and [F:DEP]DPRBAS <> 0 and GMODENAFAS = 2 ) Then
      LCDINT= "FASCRT"+num$([M:FAS3]DPRPLN(nolign-1))
      Call SUPP_EVE ( GVML_OMBIEN, [F:FAS]CPY, [F:FAS]FCY, [F:FAS]AASREF, 0,"FASCRT",
&                     LCDINT, [F:FAS]AASIPTDAT, "", NBENRDEL, LCDRET ) From GENEVE
      If (LCDRET > 20) Then
        GOK = 0
        Call FSTA("EFASCRT") From GLOCK
        Break
      Endif
      # FQ59941
      If ( G_ACTKRU = G_OUI ) Then
        If ( [F:DEP]DPRPLN = G301FIS ) Then
          If ( [F:DEP]ALWCOD= GVML_RPBONUS  ) Then
            LCDINT= "FASRUCRT"+num$([M:FAS3]DPRPLN(nolign-1))
            Call SUPP_EVE ( GVML_OMBIEN, [F:FAS]CPY, [F:FAS]FCY, [F:FAS]AASREF, 0,"FASRUCRT",
&                           LCDINT, [F:FAS]AASIPTDAT, "", NBENRDEL, LCDRET ) From GENEVE
            If (LCDRET > 20) Then
              GOK = 0
              Call FSTA("EFASRUCRT") From GLOCK
              Break
            Endif
          Endif
        Endif
      Endif
    Endif
    #-1 -------------------------------
    # FQ59941 FQ80825
    If ( G_ACTKRU = G_OUI and find([M:FAS3]DPM(nolign-1), G_DPMLR, G_DPMCR, G_DPMSR, G_DPMDR) <> 0 ) Then
      If ( [F:DEP]CNX = G300CPFI & [M:FAS3]KSTPDEPSTA(nolign-1) <> G_STPDEPSTAO([M:FAS3]DPRPLN(nolign-1))  ) Then
        If ( find([M:FAS3]KSTPDEPSTA(nolign-1), GVML_SSMODER, GVML_SSCONSE, GVML_SSMOSTP, GVML_SSCOSTP  ) <> 0 ) Then
          # Arrêt
          LCDINT= "FASRUSTP"+num$([M:FAS3]DPRPLN(nolign-1))
          Call GENER_EVE (GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCDINT,[F:FAS]AASIPTDAT,[0/0/0],LCDRET) From GENEVE
          If (LCDRET > 20) Then
            GOK = 0
            Call FSTA("EFASRUSTP") From GLOCK
            Break
          Endif
        Endif
        # FQ80825
        If ( find([M:FAS3]KSTPDEPSTA(nolign-1), GVML_SSNOSTP, GVML_SSMORST, GVML_SSCORST ) <> 0 ) Then
          # Redémarrage
          LCDINT= "FASRURST"+num$([M:FAS3]DPRPLN(nolign-1))
          Call GENER_EVE (GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCDINT,[F:FAS]AASIPTDAT,[0/0/0],LCDRET) From GENEVE
          If (LCDRET > 20) Then
            GOK = 0
            Call FSTA("EFASRURST") From GLOCK
            Break
          Endif
        Endif
      Endif
    Endif
    # FQ80825
    If ( (G_ACTDRO = G_OUI and [M:FPC]LEG="RUM") and find([M:FAS3]DPM(nolign-1), G_DPMRL, G_DPMRX, G_DPMRD) <> 0 ) Then
      If ( [F:DEP]CNX = G300CPFI & [M:FAS3]KSTPDEPSTA(nolign-1) <> G_STPDEPSTAO([M:FAS3]DPRPLN(nolign-1))  ) Then
        # Arrêt
        If ( find([M:FAS3]KSTPDEPSTA(nolign-1), GVML_SSTOSTP, GVML_SSTSTPP) <> 0 ) Then
          LCDINT= "FASRUSTP"+num$([M:FAS3]DPRPLN(nolign-1))
          Call GENER_EVE (GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCDINT,[F:FAS]AASIPTDAT,[0/0/0],LCDRET) From GENEVE
          If (LCDRET > 20) Then : GOK = 0 : Call FSTA("EFASRUSTP") From GLOCK : Break : Endif
        Endif
        If ( (G_STPDEPSTAO([M:FAS3]DPRPLN(nolign-1)) = GVML_SSTOSTP and [M:FAS3]KSTPDEPSTA(nolign-1) = GVML_SSNOSTP) or
&            (G_STPDEPSTAO([M:FAS3]DPRPLN(nolign-1)) = GVML_SSTSTPP and [M:FAS3]KSTPDEPSTA(nolign-1) = GVML_SSNSTPP)  ) Then
          # Extourner Evénement d'arrêt
          LCDINT= "FASRUSTP"+num$([M:FAS3]DPRPLN(nolign-1))
          Call ANNULE_EVE(GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCDINT,[F:FAS]AASIPTDAT,LREVTCREE,LCDRET) From GENEVE
          If (LCDRET > 20) Then : GOK = 0 : Call FSTA("EFASRUSTP") From GLOCK : Break : Endif
        Endif

        # Redémarrage
        If ( find([M:FAS3]KSTPDEPSTA(nolign-1), GVML_SSRSTDI, GVML_SSRSTPR ) <> 0 ) Then
          LCDINT= "FASRURST"+num$([M:FAS3]DPRPLN(nolign-1))
          Call GENER_EVE (GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCDINT,[F:FAS]AASIPTDAT,[0/0/0],LCDRET) From GENEVE
          If (LCDRET > 20) Then : GOK = 0 : Call FSTA("EFASRURST") From GLOCK : Break : Endif
        Endif
        If ( (G_STPDEPSTAO([M:FAS3]DPRPLN(nolign-1)) = GVML_SSRSTDI and [M:FAS3]KSTPDEPSTA(nolign-1) = GVML_SSSTOPD) or
&            (G_STPDEPSTAO([M:FAS3]DPRPLN(nolign-1)) = GVML_SSRSTPR and [M:FAS3]KSTPDEPSTA(nolign-1) = GVML_SSSTOPD)  ) Then
          # Extourner Evénement de redémarrage
          LCDINT= "FASRURST"+num$([M:FAS3]DPRPLN(nolign-1))
          Call ANNULE_EVE(GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCDINT,[F:FAS]AASIPTDAT,LREVTCREE,LCDRET) From GENEVE
          If (LCDRET > 20) Then : GOK = 0 : Call FSTA("EFASRURST") From GLOCK : Break : Endif
        Endif
      Endif
    Endif

    # Création du flux spécial lorsque le bien passe de "inactif" à "actif"
    # Suppression des flux lorsque le bien passe de "actif" à "inactif"
    #-1 ------------------------------- FQ75129
    If GMODENAFAS = 1
      Local Integer RERROR
      Call CREAT_FLUX_INITIAL("[F:FAS]", "[F:DEP]", RERROR) From TRTFLUX
      If RERROR
        Call GERE_MSG_ERREUR_FLUX(RERROR, GMESSAGE) From TRTFLUX
        GOK = 0
        Break
      Endif
    Elsif GMODENAFAS = 2
      If !clalev([F:FLU]) : Local File FXDLIFL [FLU] : Endif
      Delete [F:FLU] Where AASREF = [F:FAS]AASREF
    Endif

    #Fq67577-Pologne
    If G_ACTKPL=G_OUI
     Gosub GEN_MDR_EVENT From TRTFASMDR
    Endif

  Next nolign
  # <<<<<<<<<<<<<<<<<<<<

  If GOK=0 : Return : Endif

    #- FQ-64312  --------------------------
  If ( G_ACTLEA = G_OUI )
       If DETA_LEAREF= G_OUI and [M:FAS2]LEAREFORI <> ""
        Update [LEA]
&       Where LEAREF= [M:FAS2]LEAREFORI
&       With  CUMIASBSE -= [M:FAS1]IASETRNOT
        If ( fstat ) Then
          GOK = 0
          Call FSTA("LEA") From GLOCK
        Endif
     Endif
     If ( RATT_LEAREF = G_OUI )
        Update [LEA]
&       Where LEAREF= [M:FAS2]LEAREF
&       With  CUMIASBSE += [M:FAS1]IASETRNOT
        If ( fstat ) Then
           GOK = 0
           Call FSTA("LEA") From GLOCK
        Endif
     Endif
     If MOD_LEAREF= G_OUI and [M:FAS2]LEAREFORI <> ""
        Update [LEA]
&       Where LEAREF= [M:FAS2]LEAREFORI
&       With  CUMIASBSE -= [M:FAS1]IASETRNOT
        If ( fstat ) Then
          GOK = 0
          Call FSTA("LEA") From GLOCK
        Endif
        Update [LEA]
&       Where LEAREF= [M:FAS2]LEAREF
&       With  CUMIASBSE += [M:FAS1]IASETRNOT
        If ( fstat ) Then
           GOK = 0
           Call FSTA("LEA") From GLOCK
         Endif
     Endif

    If GOK=0 : Return : Endif

    #- 1 --------------------------
    # Si le module Contrat Financement est actif et flag de report positionné
    # Report du contrat de location du bien principal
    # sur les biens composants ayant le même type de détention.
    If  ( REPORT_LEAREF = G_OUI) Then
        Update [FAS]
&       Where CMP= [M:FAS0]AASREF and OWNTYP= [M:FAS1]OWNTYP
&      With  LEAREF = [M:FAS2]LEAREF
        If ( fstat ) Then
          GOK = 0 : GMODOK = G_NON
          Return
        Endif
    Endif
 Endif

  If GOK=0 : Return : Endif

  # FQ54343
  #--1 -----------------------
  If ( [M:FAS1]OWNTYP = GVML_TDCONCE and G_CCNRPR = G_OUI ) Then
    #--2 -----------------------
    If ( B_RNWVALFLG ) Then
      Local Integer I_CPT
      I_CPT = find(G301CPT, [M:FAS3]DPRPLN)
      Local Integer I_AMI
      I_AMI= find ( G_CCNPLNIND, [M:FAS3]DPRPLN )
      # Si le bien est "En concession" et que le type de gestion est "Transmis par renouvellement"

      Local Decimal L_RNWVAL
      Local Integer L_RNWFLG
      LRNWFLG  = [M:FAS6]RNWVALFLG

      #--3 -----------------------
      If ([M:FAS6]RNWVALFLG = G_OUI) Then
        # Si la valeur de renouvellement a été forcée, on met à jour le flag et la val. rempl. fin forcée
        # Le calcul calculera le coefficient.
        LRNWVAL  = [M:FAS6]RNWVAL
        Update [RPR]
&       Where AASREF=[M:FAS0]AASREF and FIYENDDAT = [M:FAS3]FIYENDDAT(I_CPT-1) and PERENDDAT = [M:FAS3]PERENDDAT(I_CPT-1)
&       With  ENDRNWVAL = LRNWVAL , RNWVALFLG = LRNWFLG
        If ( fstat ) Then
          GOK = 0
          Call FSTA("RPR") From GLOCK
          Return
        Endif
      #--3 -----------------------
      Else
        # Si la val. rempl. fin a été déforcée, on met à jour le flag, la val. rempl. fin sera recalculée
        Update [RPR]
&       Where AASREF=[M:FAS0]AASREF and FIYENDDAT = [M:FAS3]FIYENDDAT(I_CPT-1) and PERENDDAT = [M:FAS3]PERENDDAT(I_CPT-1)
&       With  RNWVALFLG = LRNWFLG
        If ( fstat ) Then
          GOK = 0
          Call FSTA("RPR") From GLOCK
          Return
        Endif
      Endif
      #--3 -----------------------
    Endif
    #--2 -----------------------
  Endif
  #--1 -----------------------
  #FQ91070
  If dim(GFXDNBERR) < 0
    Gosub MARQUE_DEPENSE_LIEES From FUNLOFLDAB
  Endif

Return

#=====================================================================
$APRES_MOD

  # FQ100398/13 la gestion des elts phy est positionnée ici et plus dans AVANT_MODFIC
  If GPHY = G_OUI Then
    If dim([M:OCP1]NBLIG)<0 Then
      # MAJ des éléments physiques avec la sauvegarde du tableau dans FAS8
      Gosub MAJ_ELT_PHYSIQUE
      If GOK = 0
        Return
      Endif

      If GMODENAFAS = 1
        If func PHYELT_C_MPR._UPD_PHY_ENAFLG_FROM_FAS([M:FAS0]AASREF, [V]CST_AYES) = [V]CST_ATRUE
        Endif
      Elsif GMODENAFAS = 2
        If func PHYELT_C_MPR._UPD_PHY_ENAFLG_FROM_FAS([M:FAS0]AASREF, [V]CST_ANO) = [V]CST_ATRUE
        Endif
      Endif
    Endif
  Endif

  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT

  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2

  # En import - FQ49211
  If !GIMPORT
    # Recalcul forcé
    If  ( G_ARECALCULER = 1 ) Then
      G_ARECALCULER   = 0
      ACALCULER = num$(G_OUI)
    Endif
    Gosub CALCUL_BIEN From SUBFAS
    ACALCULER = ""
  Endif

  If (GMODENAFAS) Then : Gosub RELIT From GOBJSUB : Endif

# Fiche 48468
# apres un modification réussie, on ferme les masques de l'éclatement
  If clalev([M:OCP1]) : Close Mask [OCP1]: Endif
  If clalev([M:FASE]) : Close Mask [FASE]: Endif

  # FQ81975
  GLDABAPPL = G_NON
  # FQ81977
  # Réinitialisation des valeurs relatives à l'immobilisation des dépenses
  #FQ91070
  If dim(GFXDNBERR) < 0
    Gosub RAZ_PICKING From FUNLOFLDAB
    Gosub READ_DEP_PRINCIPALE From FUNLOFLDAB
  Endif
Return

#=====================================================================
$AB_MODIF

  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT
  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2

Return


#-------------#
# SUPRRESSION #
#-------------#

#=====================================================================
$VERF_ANU

  # Si la situation après clôture ne peut pas être remise en cause, ...
  If ( [M:FAS0]PRVSITUPD = G_NON ) Then
    # ... un bien dont le type de détention est "En propriété" ou "En concession" et dont la date de
    # comptabilisation est inférieure à la date de début de l'exercice courant du contexte Fiscal et
    # comptable ne peut pas être supprimé
    If  ( ([M:FAS1]OWNTYP = GVML_TDPROPR or [M:FAS1]OWNTYP = GVML_TDCONCE) and
&         [M:FAS1]AASIPTDAT < GDEBEXECPF ) Then
      GMESSAGE = mess(421,GML_MSGFAS,1) : # Bien antérieur à l'exercice courant, la suppression est interdite
      OK       = 0
      GERR     = 1
      Return
    Endif
    # ... un bien dont le type de détention est "En crédit bail" ou "En location" et dont la date de
    # comptabilisation est inférieure à la date de début de l'exercice courant du contexte IAS
    # ne peut pas être supprimé
    If  ( G_PLNIAS and ([M:FAS1]OWNTYP = GVML_TDCBAIL or [M:FAS1]OWNTYP = GVML_TDLOCAT) and
&         [M:FAS1]AASIPTDAT < GDEBEXEIAS ) Then
      GMESSAGE = mess(421,GML_MSGFAS,1) : # Bien antérieur à l'exercice courant, la suppression est interdite
      OK       = 0
      GERR     = 1
      Return
    Endif
  Endif

  # Issue X3-63786
  If (func GLOBIENS.IS_FAS_POSTED ([M:FAS0]CPY, [M:FAS0]AASREF) = G_OUI) Then
      GMESSAGE = mess(944,GML_MSGFAS,1) : # Le bien a été comptabilisé, la suppression est interdite
      OK       = 0
      GERR     = 1
      Return
  Endif

   # 67615_8
#  If ( [M:FAS1]CMPSTA = GVML_SBPOOL and GNBDEPLIEES > 0  ) Then
#    # Dépenses rattachées au bien pool : suppression interdite FQ67615
#    GMESSAGE = mess(885,GML_MSGFAS,1)
#    OK       = 0
#    GERR     = 1
#    Return
#  Endif

  #Fq 54343 - Gestion des concessions
  #---- Un bien dont le type de détention est "En concession" et présent dans une opération de préparation de renouvellement ne peut pas être supprimé ----*
  Gosub VERF_ANU_CCN From SUBFASCCN

  # Lock des biens de l'ensemble
  Local File FXDASSETS [FASW]
  For [FASW]FAS0 Hint Key FAS3 Where SET= [M:FAS0]AASREF
    #------------------------------
    LLOCK = func GLOBIENS.GET_KEY_FXDASSETS ([F:FASW]AASREF)
    If func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:FASW]CPY, LLOCK, 0) = 0 Then
      # l'enregistrement est locké ailleurs : on ne peut pas le choisir
      OK=0 : Break
    Endif
  Next
  If (OK = 0) Then
    # Unlock tout ce qui a été verrouillé
    Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
    Return
  Endif
  # Lock des biens composant
  Gosub LOCK_COMPOSANT From SUBFAS
  If (OK = 0 ) Then
    # Unlock tout ce qui a été verrouillé
    Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
    Return
  Endif

  Gosub AP_VERF_ANU_FASCNL From SUBFASCNL

Return


#=====================================================================
$AV_ANNULE

  If dim(FASCNLEND)>0 : Kill FASCNLEND : GOK=0 : Return : Endif
  If GOK=0 : Return : Endif

  If G_ACTCIG = G_OUI
    #---- Un bien présent dans une cession intra-groupe en cours ne peut pas être supprimé -----*
    Gosub TEST_BIEN_DS_CIG  From SUBFAS
    If ( GIBIENCIG = G_OUI ) Then
      Read [F:CIG]CIG0=[F:CIB]CIGCOD
      If fstat = 0 and [F:CIG]CIGSTA = GVML_CIGSTAS
        GERR= 1 : GMESSAGE= mess(437,GML_MSGFAS, 1) - [F:CIB]CIGCOD : OK = 0 : GOK = 0
        Return
      Endif
    Endif
  Endif

 Gosub AV_ANNULE_FASCNL From SUBFASCNL
 If GOK
  Local Integer LCDRET
  Local Integer NBEVESUP
  Call SUPP_EVE_OBJ(GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,[0/0/0],NBEVESUP,LCDRET) From GENEVE
  If LCDRET
   GOK=0
   Return
  Endif
 Endif

Return

#=====================================================================
$ANNULE

  If GOK=0 : Return : Endif

# Evénement
Local Integer LCDRET
#  Affichage conditionné de la jauge dans DETRICOTE_EVE(maj JDE 20004/01/28)
Local Integer LJAUGE


  #  Par défaut : "Suppression réussie"
  GSUPOK = G_OUI

  # En cas de suppression de bien annulation du lien "Ensemble"
  # pour tous les biens étant rattachés au bien supprimé
  Update [FAS] Where SET= [M:FAS0]AASREF With  SET= [F:FAS]AASREF
  If ( fstat ) Then
    GOK = 0 : GSUPOK = G_NON
    Return
  Endif

  # En cas de suppression de bien annulation du lien "Composant"
  # pour tous les biens étant rattachés au bien supprimé
  # Le statut de ces derniers passe à "Autonome".
  Update [FAS] Where CMP= [M:FAS0]AASREF With  CMP= "", CMPSTA = GVML_SBAUTON
  If ( fstat ) Then
    GOK = 0 : GSUPOK = G_NON
    Return
  Endif

  # Génération d'un évènement de type "Annulation" si le bien est sans dépense

  #------------------------
  If ( GNBDEPLIEES = 0 ) Then
    # -- Acquisition des informations nécessaires à la génération de l'événement
    If (  find( G301FIS, [M:FAS3]DPRPLN ) <> 0 and find(G301CPT, [M:FAS3]DPRPLN) <> 0 ) Then
      # Solde dérogatoire début exercice
      [M:FAS0]DERBLC = func TRTFAS.SOLDE_DEROG([M:FAS0]AASREF, GFINEXECPF, GFINPE1CPF, G_OUI )
      # Solde dérogatoire exercice courant période courante
      [M:FAS0]PERDERBLC  = func TRTFAS.SOLDE_DEROG([M:FAS0]AASREF, GFINEXECPF, GFINPERCPF, G_OUI )
      # Solde dérogatoire exercice suivante période courante
      [M:FAS0]PERDERBLC2 = func TRTFAS.SOLDE_DEROG([M:FAS0]AASREF, GFINEXSCPF, GFINPESCPF, G_OUI )
    Endif

    #>>>>>>>>
    For nolign = 1 To [M:FAS3]NBLIG1
      # Période courante exercice suivant
      Read [DEP]
&     DEP0=[M:FAS0]AASREF;[M:FAS3]DPRPLN(nolign-1);[M:FAS3]FIYENDDAT2(nolign-1);[M:FAS3]PERENDDAT2(nolign-1)
      If ( fstat) Then
        # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
        Filter [DEP] Where AASREF= [M:FAS0]AASREF and DPRPLN= [M:FAS3]DPRPLN(nolign-1)
        Read [DEP]DEP0 Last
        Filter [DEP]
      Endif
      [M:FAS3]PERCLOCUM2(nolign-1) =  [F:DEP]PERCLOCUM
      # Période courante exercice courant
      Read [DEP]
&     DEP0=[M:FAS0]AASREF;[M:FAS3]DPRPLN(nolign-1);[M:FAS3]FIYENDDAT(nolign-1);[M:FAS3]PERENDDAT(nolign-1)
      If ( fstat) Then
        # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
        Filter [DEP] Where AASREF= [M:FAS0]AASREF and DPRPLN= [M:FAS3]DPRPLN(nolign-1)
        Read [DEP]DEP0 Last
        Filter [DEP]
      Endif

    Next nolign
    #<<<<<<<<<<
  Endif
  #------------------------

Return

#=========================
$AP_ANNULE
 If !GIMPORT
  Global Integer GFASANNULE
 Endif
Return

#=========================
# recherche si les 2 dates sont toujours dans le même exercice
# sur les différents contextes de la société
Funprog DATEMEMEEXE(PCPY, POLDDATE, PNEWDATE)
Value Char PCPY()
Value Date POLDDATE, PNEWDATE

Local Integer L_OK
    L_OK = 1

    If POLDDATE = [0/0/0] or PNEWDATE = [0/0/0] or POLDDATE = PNEWDATE
        End L_OK
    Endif

    If !clalev([F:CNX])
        Local File CONTEXT  [CNX]
    Endif

    If !clalev([F:FIS])
        Local File FISCYEAR  [FIS]
    Endif

    For [CNX]CNX0 Where CPY = PCPY

        # contrôle par rapport à l'exercice de l'ancienne date
        Filter [FIS] Where CPY = PCPY and CNX = [F:CNX]CNX and
&                   DATSTRFIY <= POLDDATE and POLDDATE <= DATENDFIY
        Read [FIS]FIY0 First
        If fstat = 0
            If [F:FIS]DATSTRFIY > PNEWDATE or PNEWDATE > [F:FIS]DATENDFIY
                L_OK = 0
                Break
            Endif
        Else
            # contrôle par rapport à l'exercice courant du contexte
            Filter [FIS]
            Read [FIS]FIY1 = PCPY ; [F:CNX]CNX ; 2
            If fstat = 0
                If (POLDDATE < [F:FIS]DATSTRFIY and PNEWDATE >= [F:FIS]DATSTRFIY) or
&                (POLDDATE >= [F:FIS]DATSTRFIY and POLDDATE <= [F:FIS]DATENDFIY and
&                 (PNEWDATE < [F:FIS]DATSTRFIY or PNEWDATE > [F:FIS]DATENDFIY)) or
&                 (POLDDATE > [F:FIS]DATENDFIY and PNEWDATE <= [F:FIS]DATENDFIY)
                    L_OK = 0
                    Break
                Endif
            Endif
        Endif
    Next
    Filter [FIS]
End L_OK

