#<AdxTL>@(#)2.0.0.0 $Revision$
## Action SOLDSEC
Local Char PARBOUT(30)(1..10)
Local Char VALBOUT(30)
PARBOUT(1)  = "CCT"      :# Axe ana
PARBOUT(2)  = "DEVELPMT" :# Section ana
PARBOUT(3)  = "JHA"      :# Société
PARBOUT(4)  = "SOP"      :# Site
PARBOUT(5)  = "20060101" :# Date début
PARBOUT(6)  = "20061231" :# Date fin
PARBOUT(7)  = ""         :# Devise
PARBOUT(8)  = "2"        :# Type de référentiel
PARBOUT(9)  = ""         :# Filtre
PARBOUT(10) = ""         :# Optiona
Call SAISIE_CHAR(VALBOUT,PARBOUT,"DSOLDSEC","SOLDSEC","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE" : Gosub VERIF
 When "DEBUT" : Gosub SOLDE
Endcase
Return

$VERIF
Local Integer OK
Local Date    DATDEB, DATFIN
Local Char    CPY (GLONCPY)
Local Integer LEDTYP

CPY    = PARAM(3)
LEDTYP = val(PARAM(8))
DATDEB = PARAM(5)
DATFIN = PARAM(6)

Call CONTEXE(CPY,LEDTYP,DATDEB,DATFIN,OK) From CONSSUB
If !OK : # Période incompatibles sur la société
 GERR=1 : GMESSAGE = mess(11,101,1)-CPY : FIN=1 : Return
Endif

Onerrgo ERREUR From CONTROLE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:BAL])=0 : Local File BALANA     [BLA] : Endif
If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif

If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:CLS])=0 : Local File GACCCLS    [CLS] : Endif

Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Endif
Return

$SOLDE
Local Char    SEC(GLONCCE), CPY(GLONCPY), FCY(GLONFCY), DEVISE(GLONCUR)
Local Date    DATDEB, DATFIN,DDEB, DFIN
Local Integer EDEB, EFIN, NBSITE, OK, LEDTYP :# AXE
Local Char    AXE
Local Char    CODLED(GLONLED), DEVLED(GLONCUR)

Local Decimal EXERCICE, PERIODE
# GH 02/02/00 bug 4189
NBSITE = max(1,GNBSITE)
Local Char    TSITE(GLONFCY)(1..NBSITE)
NBSITE = 0

CPY    = PARAM(3)
FCY    = PARAM(4)
LEDTYP = val(PARAM(8))
AXE    = PARAM(1)
SEC    = PARAM(2)
DATDEB = PARAM(5)
DATFIN = PARAM(6)
DEVISE = PARAM(7)

Call LECTURE("CPY",[L]CPY,"") From CONTOBJ
Call LECLED(CPY,LEDTYP,CODLED,DEVLED) From CPTDIV
If [F:CPY]CPYLEGFLG=2 :#Société juridique
 Call GETPERSOC(CPY,LEDTYP,DATDEB,EXERCICE,PERIODE) From CPTSUB
 EDEB = EXERCICE
 Call GETPERSOC(CPY,LEDTYP,DATFIN,EXERCICE,PERIODE) From CPTSUB
 EFIN = EXERCICE
 Call SOLDSEC(AXE,SEC,CPY,FCY,LEDTYP,DEVLED,DEVISE,EDEB,EFIN,GERR)
Else
 For [FGR]FGR0 Where CPY = [L]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  Filter [FIY] Where CPY=[F:FCY]LEGCPY & LEDTYP=[L]LEDTYP
  Read [FIY]FIY0 First
  If DATDEB>=[F:FIY]FIYSTR : DDEB=DATDEB : Else DDEB=[F:FIY]FIYSTR : Endif
  Read [FIY]FIY0 Last
  If DATFIN<=[F:FIY]FIYEND : DFIN=DATFIN : Else DFIN=[F:FIY]FIYEND : Endif
  Filter [FIY]
  If DDEB<=DFIN
   NBSITE+=1
   TSITE(NBSITE) = [F:FGR]FCY
  Endif
 Next : # [FGR]
 Call SOLDSEC2(AXE,SEC,NBSITE,TSITE,LEDTYP,DEVLED,DEVISE,DATDEB,DATFIN,GERR)
Endif
Affzo
Return

Subprog SOLDSEC(AXE,SECTION,SOCIETE,SITE,LEDTYP,DEVLED,DEVSEL,EXEDEB,EXEFIN,ERR)
Value Char       AXE
Value Char       SECTION
Value Char       SOCIETE
Value Char       SITE
Value Integer    LEDTYP
Value Char       DEVLED
Value Char       DEVSEL
Value Integer    EXEDEB
Value Integer    EXEFIN
Variable Integer ERR

Local Integer II , REPONSE
Local Integer NUMAXE

Raz [M:SOL3]
Call GETNUMAXE(SOCIETE,LEDTYP,AXE,NUMAXE) From CPTDIV
If NUMAXE=0 : End : Endif
Gosub SOL_SEC
For II=0 To [M:SOL3]NBLIG-1
 [M:SOL3]SOLDEB(II) = SOL_DEB(II)
 [M:SOL3]SOLCRE(II) = SOL_CRE(II)
 [M:SOL3]TOTDEB(II) = TOT_DEB(II)
 [M:SOL3]TOTCRE(II) = TOT_CRE(II)
Next II
End

Subprog SOLDSEC2(AXE,SECTION,NBSITE,TSITE,LEDTYP,DEVLED,DEVSEL,DATDEB,DATFIN,ERR)
Value Char       AXE
Value Char       SECTION
Value Integer    NBSITE
Value Char       TSITE()(1..)
Value Integer    LEDTYP
Value Char       DEVLED
Value Char       DEVSEL
Value Date       DATDEB
Value Date       DATFIN
Variable Integer ERR
Local Char    SITE(GLONFCY), SOCIETE(GLONCPY)
Local Integer JJ, II , REPONSE
Local Decimal EXEDEB, EXEFIN
Local Decimal EXER, PERIO
Local Integer NUMAXE
Raz [M:SOL3]

For JJ=1 To NBSITE
 SITE = TSITE(JJ)
 Call LECTURE("FCY",SITE,"") From CONTOBJ
 SOCIETE = [F:FCY]LEGCPY
 Call GETNUMAXE(SOCIETE,LEDTYP,AXE,NUMAXE) From CPTDIV
 If NUMAXE=0 : End : Endif
 Call GETPERSOC(SOCIETE,LEDTYP,DATDEB,EXER,PERIO) From CPTSUB
 EXEDEB = EXER
 Call GETPERSOC(SOCIETE,LEDTYP,DATFIN,EXER,PERIO) From CPTSUB
 EXEFIN = EXER
 Gosub SOL_SEC
 For II=0 To [M:SOL3]NBLIG-1
  [M:SOL3]SOLDEB(II) += SOL_DEB(II)
  [M:SOL3]SOLCRE(II) += SOL_CRE(II)
  [M:SOL3]TOTDEB(II) += TOT_DEB(II)
  [M:SOL3]TOTCRE(II) += TOT_CRE(II)
 Next II
Next JJ
End

$SOL_SEC
Local Integer I , J , K , SPSTAT , REPONSE , EXERCICE , LIGDEB , GRP
Local Char    BALSIT(GLONFCY) , DEVLEC(GLONCUR)
Local Decimal SOLDINI
Local Decimal SOL_DEB(0..dim([M:SOL3]DAT)-1)
Local Decimal SOL_CRE(0..dim([M:SOL3]DAT)-1)
Local Decimal TOT_DEB(0..dim([M:SOL3]DAT)-1)
Local Decimal TOT_CRE(0..dim([M:SOL3]DAT)-1)
Local Integer PMAX
Local Char PLAN(GLONCOA)

If SITE=""
 BALSIT=""
Else
 BALSIT = SITE
Endif

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
DEVLEC = [F:CPY]ACCCUR
GRP=([F:CPY]CPYLEGFLG=1)

Filter [FIY] Where CPY=SOCIETE & LEDTYP=[L]LEDTYP & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
EDEB = [F:FIY]FIYNUM
If EXEDEB = 0 : EXEDEB = 1 : Endif : # PP 15/03/02 Idem bug 10413 sur la consultation des comptes
If EXEDEB<EDEB : EDEB = EXEDEB : Endif
EFIN = EXEFIN
PMAX = dim([F:BLA]DEB)-1

SOLDINI = 0
[M:SOL3]NBLIG = 0
Raz SOL_DEB, SOL_CRE, TOT_DEB, TOT_CRE

Call LECPLAN(SOCIETE,LEDTYP,PLAN) From CPTDIV
Call LEC_COA(PLAN) From CPTLEC
Call LEC_CCE(SECTION, AXE) From CPTLEC
For EXERCICE=EDEB To EFIN
 If EXERCICE>=EXEDEB
  LIGDEB = [M:SOL3]NBLIG
  For [PER]PER0 Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FIYNUM=EXERCICE
   [M:SOL3]DAT([M:SOL3]NBLIG)= [F:PER]PEREND
   [M:SOL3]NBLIG += 1
  Next
 Endif
 If EXERCICE>EXEDEB
  For I=LIGDEB To [M:SOL3]NBLIG-1
   SOL_DEB(I) = SOL_DEB(LIGDEB-1)
  Next I
 Elsif EXERCICE=EXEDEB
  For I=LIGDEB To [M:SOL3]NBLIG-1
   SOL_DEB(I) = SOLDINI
  Next I
 Endif
 If DEVSEL<>"" & !GRP
  Filter [BLA] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FCY=BALSIT & FIY=EXERCICE
&                  & evalue("CCE"+num$(NUMAXE))=SECTION & CUR=DEVSEL
 Else
  Filter [BLA] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FCY=BALSIT & FIY=EXERCICE
&                  & evalue("CCE"+num$(NUMAXE))=SECTION
 Endif
 For [BLA]BLA0
  Call LEC_GAC([F:BLA]ACC, [F:BLA]COA) From CPTLEC
  Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
  If ([F:CLS]ERA=2 & [F:CCE]FRW=2) or EXERCICE=EFIN
   Gosub CUMSOLDE
  Endif
 Next
Next EXERCICE

For I=0 To [M:SOL3]NBLIG-1
 If SOL_DEB(I)<0
  SOL_CRE(I) = -SOL_DEB(I) : SOL_DEB(I) = 0
 Endif
Next I

#Call LECTURE("TCU",DEVSEL,"") From CONTOBJ
#If DEVSEL<>DEVLEC
# If dim([L]COURTYP)<0
#  Local Char CHAINE(10)
#  Local Integer COURTYP
#  Call PARAM("","CNSTYPCUR",CHAINE) From ADOVAL
#  COURTYP = val(CHAINE)
#  If COURTYP=0 : COURTYP = 1 : Endif
# Endif
# For I=0 To [M:SOL3]NBLIG-1
#  Call CONVERT(DEVLEC,DEVSEL,DEVLEC,COURTYP,datesyst,SOL_DEB(I),SOL_DEB(I),SPSTAT) From TRTDEV
#  Call CONVERT(DEVLEC,DEVSEL,DEVLEC,COURTYP,datesyst,SOL_CRE(I),SOL_CRE(I),SPSTAT) From TRTDEV
#  Call CONVERT(DEVLEC,DEVSEL,DEVLEC,COURTYP,datesyst,TOT_DEB(I),TOT_DEB(I),SPSTAT) From TRTDEV
#  Call CONVERT(DEVLEC,DEVSEL,DEVLEC,COURTYP,datesyst,TOT_CRE(I),TOT_CRE(I),SPSTAT) From TRTDEV
# Next I
#Endif
Return

$CUMSOLDE
If EXERCICE<EXEDEB
 If EXERCICE=EDEB
  If DEVSEL<>"" & !GRP
   SOLDINI += sum([F:BLA]DEB(0..PMAX))-sum([F:BLA]CDT(0..PMAX))
  Else
   SOLDINI += sum([F:BLA]DEBLED(0..PMAX))-sum([F:BLA]CDTLED(0..PMAX))
  Endif
 Else
  If DEVSEL<>"" & !GRP
   SOLDINI += sum([F:BLA]DEB(1..PMAX))-sum([F:BLA]CDT(1..PMAX))
  Else
   SOLDINI += sum([F:BLA]DEBLED(1..PMAX))-sum([F:BLA]CDTLED(1..PMAX))
  Endif
 Endif
Else
 For I=LIGDEB To [M:SOL3]NBLIG-1
  J = I-LIGDEB+1
  If EXERCICE=EDEB
   If DEVSEL<>"" & !GRP
    SOL_DEB(I) += sum([F:BLA]DEB(0..J))-sum([F:BLA]CDT(0..J))
   Else
    SOL_DEB(I) += sum([F:BLA]DEBLED(0..J))-sum([F:BLA]CDTLED(0..J))
   Endif
  Else
   If DEVSEL<>"" & !GRP
    SOL_DEB(I) += sum([F:BLA]DEB(1..J))-sum([F:BLA]CDT(1..J))
   Else
    SOL_DEB(I) += sum([F:BLA]DEBLED(1..J))-sum([F:BLA]CDTLED(1..J))
   Endif
  Endif
  If DEVSEL<>"" & !GRP
   TOT_DEB(I) += [F:BLA]DEB(J)
   TOT_CRE(I) += [F:BLA]CDT(J)
  Else
   TOT_DEB(I) += [F:BLA]DEBLED(J)
   TOT_CRE(I) += [F:BLA]CDTLED(J)
  Endif
 Next I
Endif
Return

