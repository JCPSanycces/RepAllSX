#<AdxTL>@(#)0.0.0.0 $Revision$Class Degrees
# Supervisor
## CRUD-CLASSE ## EMPLOEXM
# 2018-11-06 07:06:13 811


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EMPLOEXM [HREXM_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EMPLOEXM") From ASYRCOM : Endif
Local Instance EMPLOEXM Using C_EMPLOEXM

If !SILENCE : Call TRACE("3 --> New Instance C_EMPLOEXM") From ASYRCOM : Endif
EMPLOEXM = NewInstance C_EMPLOEXM AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [HREXM_]EXM0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EMPLOEXM") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.AREAD([HREXM_]REFNUM,[HREXM_]NUMLIG))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EMPLOEXM.REFNUM ="-num$(EMPLOEXM.REFNUM)) From ASYRCOM
 Call TRACE("EMPLOEXM.NUMLIG ="-num$(EMPLOEXM.NUMLIG)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EMPLOEXM.AKEYS)
  Call TRACE("-"-num$(I)-":"-EMPLOEXM.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [HREXM_]
FreeGroup EMPLOEXM
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EMPLOEXM,ACLE,ASTATUS,_ETAG)
Variable Instance EMPLOEXM Using C_EMPLOEXM
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _REFNUM(15)
Local Shortint _NUMLIG
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_NUMLIG = val([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File EMPLOEXM [HREXM]
Default File [F:HREXM]
Read [F:HREXM]EXM0 = [L]_REFNUM;[L]_NUMLIG
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:HREXM]UPDTICK)>0
 [L]_ETAG = num$([F:HREXM]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EMPLOEXM,ACLE,ASTATUS)
Variable Instance EMPLOEXM Using C_EMPLOEXM
Value Char ACLE
Variable Integer ASTATUS
Local Char _REFNUM(15)
Local Shortint _NUMLIG
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_NUMLIG = val([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.AREAD([L]_REFNUM,[L]_NUMLIG))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EMPLOEXM,_REFNUM,_NUMLIG,ASTATUS)
Variable Instance EMPLOEXM Using C_EMPLOEXM
Value Char _REFNUM
Value Shortint _NUMLIG
Variable Integer ASTATUS

If EMPLOEXM = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOEXM
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EMPLOEXM.APARENT=null
 [L]A_I = EMPLOEXM.freeSnapshot
 EMPLOEXM.snapshotEnabled = 0
 EMPLOEXM.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EMPLOEXM.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EMPLOEXM.APARENT=null
 EMPLOEXM.snapshotEnabled = 1
 EMPLOEXM.setAccessorEnabled = 1
Endif
LogicClose File [HREXM]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM._ACTION_PARAM("AREAD_BEFORE",[L]_REFNUM,[L]_NUMLIG))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:HREXM]
Read [F:HREXM]EXM0 = [L]_REFNUM;[L]_NUMLIG
If fstat
[L]A_ERROR = [L]_REFNUM+"~"+num$([L]_NUMLIG)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EMPLOEXM,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:HREXM]AUUID)>0 & [F:HREXM]AUUID=NullUuid
 [F:HREXM]AUUID = getUuid
Endif
SetInstance EMPLOEXM With [F:HREXM]
EMPLOEXM.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



