#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ATSTSAV","ATSTSAV",3,"") From GTRAITE
End

#--------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#--------------------------------#
$INIT
Return

#--------------------------------#
$INIT_DIA
Raz [M:ATST]
[M:ATST]DOSSIER = nomap
Gosub SET_USER From ATRIFIL
[M:ATST]DATDEB = date$
[M:ATST]DATFIN = date$
Local File AUTILIS [AUS]
Case GPRODUIT
 When -1
  Read [AUS]CODUSR=TB_AUZ(1)
  If !fstat
   [M:ATST]USR = TB_AUZ(1)
  Endif
 When Default
  Read [AUS]CODUSR=TB_AUZ(2)
  If !fstat
   [M:ATST]USR = TB_AUZ(2)
  Endif
Endcase
Close Local File [AUS]
Return

#-------------------------------#
$CONTROLE
If [M:ATST]NBRTAB>0
 # Extraction des enregistrements contenus dans les tables définies dans le bloc "Sauvegarde"
 Call OUINON(mess(250,115,1),OK) From GESECRAN
 If OK<>2 : SAI = 1 : Return : Endif
Endif
Return

#--------------------------------#
$EXEC
Local Integer STAT , TRACE
Local Char    FICPATCH(255) , URL(50)
If [M:ATST]TYPEXP=1 : # Client
 Call SET_FICNAM([M:ATST]FICPAT,[L]FICPATCH,URL) From ORDSYS
Else
 [L]FICPATCH = [M:ATST]FICPAT
Endif
[L]TRACE = ([M:ATST]TRACE=2)
If !GSERVEUR
 Call TEMPON("V") From GESECRAN
 # Extraction des enregistrements créés dans $4$ par $1$ du $2$ au $3$
 Call OUVRE_TRACE(func AFNC.MES4(mess(249,115,1),[M:ATST]USR,format$(GFMD,[M:ATST]DATDEB),format$(GFMD,[M:ATST]DATFIN),[M:ATST]DOSSIER)) From LECFIC
Else
 Call ECR_TRACE(func AFNC.MES4(mess(249,115,1),[M:ATST]USR,format$(GFMD,[M:ATST]DATDEB),format$(GFMD,[M:ATST]DATFIN),[M:ATST]DOSSIER),0) From GESECRAN
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif
Call EXTRACT([M:ATST]DOSSIER,[L]FICPATCH,[M:ATST]DATDEB,[M:ATST]DATFIN,[M:ATST]USR,[M:ATST]TABLE,[M:ATST]NBRTAB,[L]TRACE)
If [M:ATST]TYPEXP=1
 Call TEMPON("E") From GESECRAN
 Call COPCLI([L]FICPATCH,[M:ATST]FICPAT,STAT) From ORDSYS
 Call TEMPOFF From GESECRAN
Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF From GESECRAN
Return

#------------------------------#
$TERMINE
If [M:ATST]TRACE=2
 TRA = 1
Endif
Return

#-----------------------#
$SAV_OPENO
Local Char     SAVIFS(10) , SAVIRS(10)
Local Integer  SAVIUM
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
Return

#-----------------------#
$REST_OPENO
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Openo FICPATCH
Return

#-----------------------------------------------------------------------#
Subprog EXTRACT(DOSSIER,FICPATCH,DATDEB,DATFIN,USR,TABLE,NBTAB,TRACE)
Value Char DOSSIER,FICPATCH
Value Date DATDEB,DATFIN
Value Char USR
Value Char TABLE()(1..)
Value Integer NBTAB , TRACE

Local Integer NBLAN , NBACT , TYPPTC
Local Char    CRITERE(250) , CHAINE(250)
Local Char    ACTIV(GLONACV)(1..200) , LANGUE(GLONLAN)(1..100) , PRODUIT(2)

Local Integer I , J , K , L , T , Z , P , ILAN , STAT , ER , NBRENR
Local Char    SAVIFS(2) , SAVIRS(2)
Local Integer SAVIUM
Local Char    FICHIER(GLONATB) , ABR(GLONABR+2) , VARIA(GLONAVA) , IDENT(250) , CHAINE(250) , CHAINE2(250)(1..10)
Local Integer TYP , IND , NBZONE
Local Integer NUMERO , CHAPITRE, PARAM
Local Libelle BUFFER(1..30)
Local Integer NB , COMPTE , NOCT , TYPENR
Local Datetime DATTIM1 , DATTIM2
Local Char    REP(10) , SREP(GLONLAN) , EXT(10) , NOMPROG(30)
Local Char    MODDON(GLONAWM) , TRANSAC(GLONATN) , CODLEG(GLONADI)
Local Char    ZFIC(GLONATB) , ZIDENT(80) , ZA(80) , ZPAR(GLONAVA) , ZVAL(250)(1..4)
Local Integer Z1 , Z2 , ZP
Local Char    TYPS(255) , CODS(255) , ACTIONX(10)
Local Char    FICBIN(255) , REPERT(255) , FIC(255) , SEP(1) , FICWEB(255) , FIC_TMP(GDIMFIC)
Local Clbfile CLOB(12)
Local Blbfile BLOB(12)
Local Char    ABROBJ(10) , CLEOBJ(255) , INTOBJ(80) , ME(80)
Local Char    MACHINE(GLONAMC) , APPLI(GLONADS) , DOSX3(GLONADD) , COMMENT(250)

Gosub SET_USER From ATRIFIL

If FICPATCH="" : End : Endif
If DOSSIER="" : DOSSIER = nomap : Endif

Local File ADOSSIER [ADS]
Read [ADS]DOSSIER=DOSSIER
If fstat : End : Endif

If USR=""
 K = 0
 Local File =DOSSIER+".AUTILIS" [AUS]
 For I=1 To NB_AUZ
  Read [AUS]CODUSR=TB_AUZ(I)
  If !fstat
   K = 1
   USR = TB_AUZ(I)
   Break
  Endif
 Next I
 Close Local File [AUS]
 If !K : End : Endif
Endif
If DATFIN=[0/0/0] : DATFIN = date$ : Endif

If DOSSIER=nomap
 Local File ATABLE [ATB] , ATABLE [ATB2] , ATABZON [ATZ_] , ATABIND [ATI_]
 Local File ATEXTE [ATX_] , ATEXTRA [AXX_] , ACTIV [ACV]
 Local File AMSKPAR [AMP_] , ATABZON [ATZ2] , ATYPE [ATY_]
Else
 Local File =DOSSIER+".ATABLE" [ATB] , =DOSSIER+".ATABLE" [ATB2] , =DOSSIER+".ATABZON" [ATZ_] , =DOSSIER+".ATABIND" [ATI_]
 Local File =DOSSIER+".ATEXTE" [ATX_] , =DOSSIER+".ATEXTRA" [AXX_] , =DOSSIER+".ACTIV" [ACV]
 Local File =DOSSIER+".AMSKPAR" [AMP_] , =DOSSIER+".ATABZON" [ATZ2] , =DOSSIER+".ATYPE" [ATY_]
Endif

TYPPTC   = 1  : # Standard
#106969
#VERSION  = GVERSION : # Code version
Local Char VERSION(30)
VERSION=func APRODUCT.AGETRELEASEABR(APPLI)
COMMENT  = [L]DOSSIER+" + "+format$(GFMD,[L]DATDEB)+" + "+format$(GFMD,[L]DATFIN)+" + "+[L]USR
CHAINE   = ""
For I=0 To [F:ADS]NBRLAN-1
 If [F:ADS]LAN(I)<>""
  NBLAN += 1
  LANGUE(NBLAN) = [F:ADS]LAN(I)
  If len(CHAINE)+len([F:ADS]LAN(I))+1>type(CHAINE)-20
   Break
  Endif
  If I>0 : CHAINE += "/" : Endif
  CHAINE += [F:ADS]LAN(I)
 Endif
Next I
CHAINE2 = ""
Case GPRODUIT
 When -1 : PRODUIT = "SU"
 When  0 : PRODUIT = "X3"
 When  1 : PRODUIT = "GX"
 When  2 : PRODUIT = "PA"
 When  3 : PRODUIT = "AB"
Endcase

Gosub SET_TABLE From ATRIFIL

DATTIM1  = gdatetime$(format$("D:YYYY[-]MM[-]DD",DATDEB))
DATTIM2  = gdatetime$(format$("D:YYYY[-]MM[-]DD",DATFIN+1))
CRITERE  = '(CREDATTIM>=gdatetime$("'+num$(DATTIM1)+'")&CREDATTIM<=gdatetime$("'+num$(DATTIM2)+'"))'
CRITERE += '&CREUSR="'+USR+'"'

Openo FICPATCH , 0
adxifs = ","
adxirs = chr$(10)
adxium = GUTF8
Wrseq '1';'"'+COMMENT+'"';'"'+CHAINE+'"';'"'+VERSION+'"';'"'+CHAINE2+'"';'"'+PRODUIT+'"';'"'+num$(TYPPTC)+'"'

If NBTAB>0
 For T=1 To NBTAB
  If !find(TABLE(T),[L]TB_VIR(1..[L]NB_VIR))
   Read [ATB2]CODFIC=[L]TABLE(T)
   If !fstat
    [L]ABROBJ = [F:ATB2]ABRFIC
    [L]CLEOBJ = CRITERE
    Gosub DIVERS
   Endif
  Endif
 Next T
Else
 For [ATB2] Where TYPFIC<>3
  If !find([F:ATB2]CODFIC,[L]TB_VIR(1..[L]NB_VIR))
   [L]ABROBJ = [F:ATB2]ABRFIC
   [L]CLEOBJ = CRITERE
   Gosub DIVERS
  Endif
 Next ATB2
Endif

# Fin fichier
Wrseq '8';'"'+COMMENT+'"'

Openo
End

#--------------------------------#
$DIVERS
ER = 0
Onerrgo ERRFIC From APATCH2
Read [ATB]ABRFIC = ABROBJ
If !fstat
 #114186
 Read [ATZ2]CODZONE=[F:ATB]CODFIC;"CREDATTIM"
 If fstat
  # Table non gérée
  ER=1
 Elsif [F:ATZ2]NUMLIG>254
  # Table non gérée
  ER=2
 Endif
 If !ER
  Read [ATZ2]CODZONE=[F:ATB]CODFIC;"CREUSR"
  If fstat
   # Table non gérée
   ER=1
  Elsif [F:ATZ2]NUMLIG>254
   # Table non gérée
   ER=2
  Endif
 Endif
 If !ER
  Local File =DOSSIER+"."+[F:ATB]CODFIC [DIV]
  If ER
   # Erreur d'accès sur un fichier
  Elsif dim([F:DIV]CREDATTIM)<=0 or dim([F:DIV]CREUSR)<=0
   # Horodatage non géré
   Close Local File [DIV]
  Else
   [L]NBRENR = 0
   FICHIER = [F:ATB]CODFIC
   ABR = "DIV"
   IDENT = ""
   For [F] Where evalue([L]CLEOBJ)
    If ![L]NBRENR
     Wrseq '2';'"~'+[L]ABROBJ+'"';'"'+CLEOBJ+'"';'"'+INTOBJ+'"' : # Entête objet
    Endif
    [L]NBRENR += 1
    Gosub FICHIER From APATCH2
    Case [L]ABROBJ
     When "AOS"
      If [F]ALL=2
       EXT = "glo"
      Else
       EXT = "sel"
      Endif
      FIC = [F]USR+"_"+[F]CODE+"_"+[F]MEMO+"."+EXT
      Wrseq '3';'"'+EXT+'"'
      Gosub MEMOS From APATCH2
      Wrseq '6';'"'+EXT+'"'
    Endcase
   Next
   If [L]NBRENR
    Wrseq '7';'"~'+ABROBJ+'"';'"'+CLEOBJ+'"';'"'+INTOBJ+'"' : # Fin objet
    If TRACE
     # Table
     Gosub SAV_OPENO
     Call ECR_TRACE(mess(56,123,1)-[F:ATB]CODFIC-":"-num$([L]NBRENR),0) From GESECRAN
     Gosub REST_OPENO
    Endif
   Endif
   If ER
    Gosub SAV_OPENO
    Call ECR_TRACE(mess(56,123,1)-[F:ATB]CODFIC-":"-ME-errmes$(ER),1) From GESECRAN
    Gosub REST_OPENO
   Endif
   Close Local File [DIV]
  Endif
 Elsif ER=2 & TRACE
   # 114186 Table non gérée
   Gosub SAV_OPENO
   Call ECR_TRACE(mess(251,115,1)-[F:ATB]CODFIC,0) From GESECRAN
   Gosub REST_OPENO
 Endif
Endif
Onerrgo
Return

#-----------------#
$ERRFIC
ER = errn
ME = errm
Resume

#--------------------------------#
Subprog AS_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]VOLFIL
 Grizo [M]VOLFIL
Else
 Actzo [M]VOLFIL
Endif
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
If VALEUR=1
 Raz [M]VOLFIL
 Grizo [M]VOLFIL
Else
 Actzo [M]VOLFIL
Endif
Affzo [M]VOLFIL
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, VALEUR,[M]FICPAT,E_TYPE_FILEOVERWRITE,GMESSAGE)
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(1,1,year(date$))
Endif
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]DATDEB
 mkstat = 1 : End
Endif
If VALEUR=[0/0/0]
 VALEUR = date$
Endif
End

Subprog AM_USR(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Gosub SET_USER From ATRIFIL
If !find(VALEUR,TB_AUZ(1..NB_AUZ))
 # Utilisateur non valide pour cette fonction
 Call ERREUR(mess(254,115,1)) From GESECRAN
 If OK<>2 : mkstat = 1 : End : Endif
Endif
End

Subprog C_USR(VALEUR)
Variable Char    VALEUR()
If [M]DOSSIER=""
 Local File AUTILIS [AUS2]
Else
 Local File =DOSSIER+".AUTILIS" [AUS2]
Endif
Read [AUS2]CODUSR=VALEUR
If fstat
 mkstat = 1 : End
Endif
Close Local File [AUS2]
End

Subprog C_TABLE(VALEUR)
Variable Char    VALEUR()
If [M]DOSSIER=""
 Local File ATABLE [ATB2]
 Local File ATABZON [ATZ2]
Else
 Local File =DOSSIER+".ATABLE" [ATB2]
 Local File =DOSSIER+".ATABZON" [ATZ2]
Endif
Gosub SET_TABLE From ATRIFIL
If find(VALEUR,TB_VIR(1..NB_VIR))
 mkstat = 1
 # Table non gérée
 Call ERREUR(mess(251,115,1)) From GESECRAN
 End
Else
 Read [ATB2]CODFIC=VALEUR
 If fstat or [F:ATB2]TYPFIC=3
  mkstat = 1
  # Table non gérée
  Call ERREUR(mess(251,115,1)) From GESECRAN
  End
 Endif
 #114186
 Read [ATZ2]CODZONE=VALEUR;"CREDATTIM"
 If fstat
  mkstat = 1
  # Table non gérée
  Call ERREUR(mess(251,115,1)) From GESECRAN
  End
 Elsif [F:ATZ2]NUMLIG>254
  mkstat = 1
  # Table non gérée
  Call ERREUR(mess(251,115,1)) From GESECRAN
  End
 Endif
 Read [ATZ2]CODZONE=VALEUR;"CREUSR"
 If fstat
  mkstat = 1
  # Table non gérée
  Call ERREUR(mess(251,115,1)) From GESECRAN
  End
 Elsif [F:ATZ2]NUMLIG>254
  mkstat = 1
  # Table non gérée
  Call ERREUR(mess(251,115,1)) From GESECRAN
  End
 Endif
Endif
Close Local File [ATB2],[ATZ2]
Call UNICITE(VALEUR,[M]TABLE) From OBJDIV
If mkstat : End : Endif
End

