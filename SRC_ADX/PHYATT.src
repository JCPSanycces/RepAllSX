#
#   TRAITEMENT PREPARATOIRE A L'ETAT DES MOUVEMENTS EN ATTENTE
#
#*********************************************************************
#    Création :    VPO
#*********************************************************************
#    Modification
#
#    CBO - 17.02.2015  FQ100398/13 : Liaison FXD PHY
#    MDJ - 09.02.2015  FQ100398 Suppression site géographique
#*********************************************************************
#*
#*!
$ACTION
  Gosub ACTION From CPTRPT
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char       PARAM(30)
Local Char       VALDEB(255)
Local Char       FCYDEB, FCYFIN, CPYDEB, CPYFIN
Local Char       CRITERE(255), WMESS(200)
Local Integer LCDRET


  If !clalev([FCY]) Then Local File FACILITY [FCY] Endif

  # Filtrer uniquement sur les sites d'inventaire
  #FQ104129 CRITERE = "IVYFLG = " + num$(G_OUI)
  CRITERE = "1=1"

  # Filtre supplémentaire sur le site financier
  Call GETPARAM("fcydeb",NBPAR,PARAMETRE,FCYDEB) From ETAT
  Call GETPARAM("fcyfin",NBPAR,PARAMETRE,FCYFIN) From ETAT
  If FCYDEB<>" " and vireblc(FCYDEB,0)<>"" Then
    CRITERE = CRITERE + " and FINRSPFCY>='" + FCYDEB + "' and FINRSPFCY<='" + FCYFIN + "'"
  Endif

  # Filtre supplémentaire sur la société
  Call GETPARAM("cpydeb",NBPAR,PARAMETRE,CPYDEB) From ETAT
  Call GETPARAM("cpyfin",NBPAR,PARAMETRE,CPYFIN) From ETAT
  If CPYDEB<>" "  and vireblc(CPYDEB,0)<>"" Then
    CRITERE = CRITERE + " and LEGCPY>='" + CPYDEB + "' and LEGCPY<='" + CPYFIN + "'"
  Endif

  Filter [FCY] Where evalue(CRITERE)

  # Constitution de la chaîne localisation par défaut
  VALDEB=""
  For [FCY]FCY0
    LOC_DEF = func PHYLCT_CSTD.GET_DEFAULT_LOCATION( [FCY]FCY, LCDRET, WMESS)
    If VALDEB="" Then
      VALDEB = "'" + LOC_DEF + "'"
    Else
      VALDEB = VALDEB+",'"+LOC_DEF + "'"
    Endif
  Next

  # Affectation du paramètre "locdeb" de l'état par les différentes localisations par défaut
  # Dans l'état, le paramètre locdeb filtre les enregistrements par un "{PHYELT.LOC_0} in ({?locdeb})"
  Call SETPARAM("locdeb",NBPAR,PARAMETRE,VALDEB) From ETAT

  If clalev([FCY]) Then Close Local File [FCY] Endif
End
