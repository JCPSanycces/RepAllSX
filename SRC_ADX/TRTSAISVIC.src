#<AdxTL>@(#)0.0.0.0 $Revision$

End
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management

#----- WARNING : Do not FreeGroup GSVCRINVCND instance (set it to null instead) ---
#----- this because it points to the GSOHSVCRINVCND(WNOL) instance handled in SOH masks
#-----/WARNING

$ACTION

#--- Actions liés au type fenêtre de saisie
  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "DEBUT"      : Gosub DEBUT
    When "OK"         : Gosub OK
    When "AVANT_ENR"  : Gosub AVANT_ENR
    When "ABANDON"    : Gosub ABANDON
    When "ABA"        : Gosub ABA
    When "APRES_MODIF": Gosub APRES_MODIF
    When "FIN"        : Gosub FIN
    When "FINSAI"     : Gosub FINSAI
    When "SETBOUT"    : Gosub SETBOUT
    When "BOUTON"     : Gosub BOUTON
  Endcase
Return
################################################################################
$SETBOUT
Local Integer WTEMPSIGMA

  Case PARAM(1)
    When "SOH4" :If val(PARAM(2))>0
                   If [M:SOH4]DINVCND(val(PARAM(2))-1)=""
                     Call VIREBOUT(CHMEN,"1") From GOBJET
                   Endif
                 Else
                   Call VIREBOUT(CHMEN,"1") From GOBJET
                 Endif
    When "SIH4"  : Call VIREBOUT(CHMEN,"13") From GOBJET
                   Call VIREBOUT(CHBOU,"O" ) From GOBJET #--No "Ok" menu entry
    When Default : Call VIREBOUT(CHMEN,"13") From GOBJET
  Endcase

  #--No re-generation of the scheduling lines if at least one has a status different then 'To be invoiced'
  If [M:SVIC1]NBLIG>0
      #--Does the schedule invoice have ohter lines than 'To be invoiced' ?
      WTEMPSIGMA = -1
      WTEMPSIGMA = sigma(0,[M:SVIC1]NBLIG-1, [M:SVIC1]INVCNDSTA(indcum)>1)
      If WTEMPSIGMA>0
        Call VIREBOUT(CHMEN,"3") From GOBJET
      Endif
  Endif

  #-- Active the button Remainder distribution only when we are in update mode
  If REP<>"M": Call VIREBOUT(CHMEN,"1") From GOBJET: Endif      # X3-25617

Return
################################################################################
$BOUTON

  #-------------------------------------------#
  # After execution toolbar buttons           #
  #-------------------------------------------#
  Case BOUT
    When "1"  : Gosub DISPATCH_DELTA_ON_LINES
                If GOK<1 or GERR>0
                  #--Need to reload previous values into class
                  Case PARAM(1)
                    When "SOH4" : Gosub ABA_SAISVIC_SOH From TRTSAISVIC
                    When "SIH4" : Gosub ABA_SAISVIC_SIH From TRTSAISVIC
                  Endcase
                  Return
                Endif
                REP = "M"
    When "2"  : #Gosub CHANGE_SCHEDULING_DATE         From SUBSVIC
                #If GOK<1 or GERR>0 : Return : Endif
                #REP = "M"
    When "3"  : Gosub AUTO_GENERATE_INVOICE_SCHEDULE_WITHOUT_FREEGROUP_WITHOUT_SET_CLS From SUBSVIC
                If GOK<1 or GERR>0
                  #--Need to reload previous values into class
                  Case PARAM(1)
                    When "SOH4" : Gosub ABA_SAISVIC_SOH From TRTSAISVIC
                    When "SIH4" : Gosub ABA_SAISVIC_SIH From TRTSAISVIC
                  Endcase
                  Return
                Else                                              #X3-25617
                 #--when clicking on it display a message to advise the user that the process is done
                 Local Integer OK: OK=0                           #X3-25617
                 Call MESSAGE(mess(278,191,1)) From GESECRAN  #X3-25617
                Endif
                REP = "M"
  Endcase

Return
################################################################################
$OUVRE

  If clalev([F:SVIC] )=0 : Local File SVCRINVCND  [SVIC]  : Endif
  If clalev([F:SVICD])=0 : Local File SVCRINVCNDD [SVICD] : Endif

  Local Mask SVIC1 [M:SVIC1_]

  If dim(GSVCRINVCND)>0
    If (GSVCRINVCND <> null)
      FreeGroup GSVCRINVCND
    Endif
    Kill GSVCRINVCND
  Endif
  #--As the ACTION "TRTSAISVIC" is defined on a window using the SVIC1 screen,
  #--We have to set up the right context, as the mask uses the "hybride" mode
  #--The mask uses a global instance GSVCRINVCND of the R_SVCRINVCND representation
  Global Instance GSVCRINVCND Using C_SVCRINVCND

Return
################################################################################
$FIN
Local Char SYMBOLE5(50)

  #--Unlocking SVIC : Example from Locked symbols : SVIC~CDE-2015-5103\10\1000\1000
  SYMBOLE5 = "SVIC"+"~"+[M:SVIC1]VCRNUMORI+"\"+num$([M:SVIC1]VCRTYP)+"\"+num$([M:SVIC1]VCRLINORI)+"\"+num$([M:SVIC1]VCRSEQORI)
  Unlock = SYMBOLE5

  #--Allowing back the propagate to execute
  GSVCRINVCND.DO_PROPAGATE=[V]CST_ANO
  #--Freeing/Killing the global instance used by hybride mode
  #--As the current GSVCRINVCND points to the document line's global instance
  #--We'll not do the freegroup
  #If (GSVCRINVCND <> null) : FreeGroup GSVCRINVCND : GSVCRINVCND=null : Endif
  Kill GSVCRINVCND

  Close Mask [M:SVIC1_]

Return
################################################################################
$FINSAI

Return
################################################################################
$DEBUT
  Case GACTION
    When "SAISVIC" :
                     Gosub DEB_SAISVIC
                     Affzo [M]1-99
  Endcase
Return
################################################################################
$OK
  Case GACTION
    When "SAISVIC" : Gosub OK_SAISVIC
  Endcase
Return
################################################################################
$AVANT_ENR

  Case GACTION
    When "SAISVIC" : Gosub AVANT_ENR_SAISVIC
  Endcase

Return
################################################################################
$ABA
  Case GACTION
    When "SAISVIC" : #Gosub ABA_SAISVIC => done in $ABANDON both in case of "Cancel" and "Quit" entry menu
  Endcase
Return
################################################################################
$ABANDON
  Case GACTION
    When "SAISVIC" : Gosub ABA_SAISVIC
  Endcase
Return
################################################################################
$APRES_MODIF

  Case GACTION
    When "SAISVIC" :
                      Case PARAM(1)
                        When "SOH4" : Gosub APRES_MODIF_SOH
                        When "SIH4" : Gosub APRES_MODIF_SIH
                      Endcase
  Endcase
Return
################################################################################
$APRES_MODIF_SOH
Local Char SYMBOLE5(50)

  #--Locking SVIC : Example from Locked symbols : SVIC~CDE-2015-5103\10\1000\1000
  SYMBOLE5 = "SVIC"+"~"+[M:SVIC1]VCRNUMORI+"\"+num$([M:SVIC1]VCRTYP)+"\"+num$([M:SVIC1]VCRLINORI)+"\"+num$([M:SVIC1]VCRSEQORI)
  Lock = SYMBOLE5
  If fstat
     # modification en cours sur un autre poste
     GERR=1 : GMESSAGE=mess(511,192,1)-mess([M:SVIC1]VCRTYP,476,1)+"~"+[M:SVIC1]VCRNUMORI+"~"+num$([M:SVIC1]VCRLINORI)-":"-mess(10,100,1)
     OK=0   : Return
  Endif
  REP = "M"

  Gosub APRES_MODIF From SUBSVIC # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification

Return
################################################################################
$APRES_MODIF_SIH

  Gosub APRES_MODIF From SUBSVIC # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification

Return
################################################################################
# DETAIL DES ACTIONS                                                           #
################################################################################
$DEB_SAISVIC
#----- Parameters of the SAISVIC action -----#
#PARAM(1) ABREV      => document line abreviation mask (exp. "SOH4")
#PARAM(2) NOLIGN     => nolign of the current line of the ABREV mask  (nolign)
#PARAM(3) VCRTYPORI  => original document type     (exp. for an order line 10)
#PARAM(4) VCRNUMORI  => original document number   (exp. for an order line SOHNUM)
#PARAM(5) VCRLINORI  => original document line     (exp. for an order line SOPLIN)
#PARAM(6) VCRSEQORI  => original document sequence (exp. for an order line SOQSEQ)
#PARAM(7) CLASSNAME  => class name of the global variable used (exp. C_SVCRINVCND)
#PARAM(8) OBJECTNAME => name of the instance variable using CLASSNAME (exp. GSOHVCRINVCND_UPD)

Local Char    WABREVMSK(GLONAMK)   : WABREVMSK   = PARAM(1)
Local Integer WNOL                 : WNOL        = val(PARAM(2))-1
Local Integer WVCRTYPORI           : WVCRTYPORI  = val(PARAM(3))
Local Char    WVCRNUMORI(GLONVCR)  : WVCRNUMORI  = PARAM(4)
Local Integer WVCRLINORI           : WVCRLINORI  = val(PARAM(5))
Local Integer WVCRSEQORI           : WVCRSEQORI  = val(PARAM(6))
Local Char    WCLASSNAME(GLONACLA) : WCLASSNAME  = PARAM(7)
Local Char    WOBJECTNAME(100)     : WOBJECTNAME = PARAM(8)

Local Integer WSAVE_NOLIGN : WSAVE_NOLIGN = nolign

  #--As the ACTION "TRTSAISVIC" is defined on a window using the SVIC1 screen,
  #--We have to set up the right context, as the mask uses the "hybride" mode
  #--The mask uses a global instance GSVCRINVCND of the C_SVCRINVCND class
  If (GSVCRINVCND <> null) : GSVCRINVCND=null : Endif #If (GSVCRINVCND <> null) : FreeGroup GSVCRINVCND : GSVCRINVCND=null : Endif

  Raz [M:SVIC1]

  Case PARAM(1)
    When "SOH4" : Gosub DEB_SAISVIC_SOH From TRTSAISVIC
    When "SIH4" : Gosub DEB_SAISVIC_SIH From TRTSAISVIC
  Endcase

  # Ctrl autorisation modification
  If !find (GREP, "C", "D")
    GBIDC2="M": Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2  Diszo [M:SVIC1] : Endif
  Endif

  #--Saving values (in case of a cancel)
  nolign=[M:SVIC1]NBLIG
  #(MGG 08/05/2017) X3-33114
  #[M:SVIC1_] = [M:SVIC1]
  Raz [M:SVIC1_]
  Transmask  [M:SVIC1] To [M:SVIC1_]
  #END (MGG 08/05/2017) X3-33114
  If GCONSULT>0
    Diszo [SVIC1]1-99 : FLGSAI=0
  Endif

Return
#------------------------------------------------------------------------------#
$DEB_SAISVIC_SOH
Local Integer MY_STATUS,WTOUPD,WRECALC_PERCENTAGE,WRET

  If [M:SOH4]DINVCND(WNOL)="" : Diszo [M:SVIC1]1-99 :  GERR=1 : Return : Endif
  #--A document line has an instance of the C_SVCRINVCND class assiated to
  #--If this instance is loaded, we point the actual GSVCRINVCND instance to the one from the mask
  If dim(GSOHVCRINVCND_UPD)<0 or GSOHVCRINVCND_UPD(WNOL)=null
    #--Load the class from SOH4 mask
    WRECALC_PERCENTAGE = [V]CST_ANO
    nolign = WNOL+1
    If find(GREP,"C","D")>0
      Gosub CREATE_VCRINVCND_FROM_CURR_LINE From LIBSAL_INVCND_SOH
      If GERR=1 : Return : Endif # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Else
      Gosub UPDATE_VCRINVCND_FROM_CURR_LINE From LIBSAL_INVCND_SOH
      If GERR=1 : Return : Endif # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    Endif
    #--No newinstance needed because we will point to the document's GSOHVCRINVCND_UPD(WNOL)
    #GSVCRINVCND = NewInstance C_SVCRINVCND AllocGroup null
  Else
    #--No newinstance needed because we will point to the document's GSOHVCRINVCND_UPD(WNOL)
    #GSVCRINVCND = NewInstance C_SVCRINVCND AllocGroup GSOHVCRINVCND_UPD(WNOL).AllocGrp
    WTOUPD=[V]CST_ANO
    If [M:SOH4]DINVCNDTOUPD(WNOL)=[V]CST_ANO
      If    GSOHVCRINVCND_UPD(WNOL).QTY    <> [M:SOH4]QTY(WNOL)
        WTOUPD=[V]CST_AYES
      Elsif GSOHVCRINVCND_UPD(WNOL).INVCND <> [M:SOH4]DINVCND(WNOL)
        WTOUPD=[V]CST_AYES
      Else

      Endif
      If GSOHVCRINVCND_UPD(WNOL).PRITYP<>2
        If    GSOHVCRINVCND_UPD(WNOL).NETPRINOT<>[M:SOH4]NETPRINOT(WNOL)
          WTOUPD=[V]CST_AYES
        Elsif GSOHVCRINVCND_UPD(WNOL).AMTNOT   <>arr([M:SOH4]QTY(WNOL)*[M:SOH4]NETPRINOT(WNOL),10^-GSOHVCRINVCND_UPD(WNOL).CUR_DECNBR)
          WTOUPD=[V]CST_AYES
        Else

        Endif
      Else
        If    GSOHVCRINVCND_UPD(WNOL).NETPRIATI<>[M:SOH4]NETPRIATI(WNOL)
          WTOUPD=[V]CST_AYES
        Elsif GSOHVCRINVCND_UPD(WNOL).AMTATI   <>arr([M:SOH4]QTY(WNOL)*[M:SOH4]NETPRIATI(WNOL),10^-GSOHVCRINVCND_UPD(WNOL).CUR_DECNBR)
          WTOUPD=[V]CST_AYES
        Else

        Endif
      Endif
    Endif
    If WTOUPD=[V]CST_AYES
      [M:SOH4]DINVCNDTOUPD(WNOL)=[V]CST_AYES
    Endif
    #--Taking new values
    #--In case of something changed, when calling the AUPDATE method, there will be errors raised if
    #--Header important properties were changed (especially those being dispatched on line level : qty/amt/ etc)
    #--Doing this, will allow to have on the scheduling invoice header, the actual properties of the curent eventually modified order line
    #--Hence, the AUPDATE/ACREATE method on the instance will do the controls and detect an error if something changed
    MY_STATUS = func LIBSAL_INVCND_SOH.INIT_SVCRINVCND_FROM_ORDER_M(WNOL,GSOHVCRINVCND_UPD(WNOL))
    If ([L]MY_STATUS > [V]CST_AOK)
      # Error management
      GMESSAGE  = mess(3,61,1)-num$(WNOL+1)-mess(162,154,1)-[M:SOH4]ITMREF(WNOL)-mess(483,192,1)-[M:SOH4]DINVCND(WNOL)-":"
      GMESSAGE += func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSOHVCRINVCND_UPD(WNOL))
      WRET      = func SUBINVCND.RAZMAXMSG(GSOHVCRINVCND_UPD(WNOL),"VCRINVCNDLIN")
      If ([L]MY_STATUS >= [V]CST_AERROR)
        GERR = 1
      Endif
      Return
    Endif
    #--If the instance were previously created but has no lines, we have to call the CREATE_DETAIL_SCHEDINV
    If sigma(1,maxtab(GSOHVCRINVCND_UPD(WNOL).VCRINVCNDLIN),
&            GSOHVCRINVCND_UPD(WNOL).VCRINVCNDLIN(indcum)<>null and
&            find(GSOHVCRINVCND_UPD(WNOL).VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)<1
      MY_STATUS = fmet GSOHVCRINVCND_UPD(WNOL).CREATE_DETAIL_SCHEDINV()
      If ([L]MY_STATUS > [V]CST_AERROR)
        # Error management
        GMESSAGE  = mess(3,61,1)-num$(WNOL+1)-mess(162,154,1)-[M:SOH4]ITMREF(WNOL)-mess(483,192,1)-[M:SOH4]DINVCND(WNOL)-":"
        GMESSAGE += func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSOHVCRINVCND_UPD(WNOL))
        WRET      = func SUBINVCND.RAZMAXMSG(GSOHVCRINVCND_UPD(WNOL),"VCRINVCNDLIN")
        If ([L]MY_STATUS >= [V]CST_AERROR)
          GERR = 1
        Endif
        FreeGroup GSOHVCRINVCND_UPD(WNOL)
        GSOHVCRINVCND_UPD(WNOL)=null
        Return
      Endif
      [M:SOH4]DINVCNDTOUPD(WNOL)=[V]CST_AYES
    Endif
  Endif
  GSVCRINVCND = GSOHVCRINVCND_UPD(WNOL)
  #--Enableling execution of propagate
  GSVCRINVCND.DO_PROPAGATE=[V]CST_AYES

  #--We start with no error on the instance...
#  GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
#  MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")

  #--Set SVIC1 mask with loaded values
  #--Loading mask properties into the screen, from the class
  Gosub LIENS_WITHOUT_FREEGROUP_AND_AREAD From SUBSVIC

  Diszo [M:SVIC1] 5
  Affzo [M:SVIC1]1-99

Return
#------------------------------------------------------------------------------#
$DEB_SAISVIC_SIH
Local Integer MY_STATUS,WTOUPD,WRECALC_PERCENTAGE

  GSVCRINVCND = evalue(PARAM(8))#GSIDHYBHANDLE.SIDTOSVIC(xx).SVCRINVCND(y)
  #--Enableling execution of propagate
  GSVCRINVCND.DO_PROPAGATE=[V]CST_AYES

  #--Set SVIC1 mask with loaded values
  #--Loading mask properties into the screen, from the class
  Gosub LIENS_WITHOUT_FREEGROUP_AND_AREAD From SUBSVIC

  Diszo [M:SVIC1] 5
  Affzo [M:SVIC1]1-99

Return
#------------------------------------------------------------------------------#
$AVANT_ENR_SAISVIC

Return
#------------------------------------------------------------------------------#
$OK_SAISVIC
Local Integer WMOD :    Raz WMOD

  If GSVCRINVCND=null : GERR=1 : Return : Endif
  # Chargement classe écran pour maj en sortie
  Case PARAM(1)
    When "SOH4" : Gosub OK_SAISVIC_SOH From TRTSAISVIC
    When "SIH4" : Gosub OK_SAISVIC_SIH From TRTSAISVIC
  Endcase

Return
#------------------------------------------------------------------------------#
$OK_SAISVIC_SOH
Local Integer MY_STATUS,WRET

  Raz [F:SVIC]
  [F:SVIC] = [M:SVIC1]
  Gosub SET_CLS_WITH_M From SUBSVIC

  If [M:SOH4]CREFLG(WNOL)=0
    #--To prevent doing the control on the existence of the original doc
    #--We are in creation mode
    GSVCRINVCND.NOCTL_NUMORI=[V]CST_AYES
  Endif

  WRET = fmet GSVCRINVCND.ACONTROL()

  GSVCRINVCND.NOCTL_NUMORI=[V]CST_ANO

  If (WRET > [V]CST_AOK)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
    MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
    If (WRET >= [V]CST_AERROR)
      GERR = 1
      FIN = 0
      Return
    Else
      GERR = 2
    Endif
  Endif
  #--Preventing propagate to execute
  GSVCRINVCND.DO_PROPAGATE   = [V]CST_ANO
  [M:SOH4]DINVCNDTOUPD(WNOL) = [V]CST_AYES
  # Il faut dégriser le bouton enregistrer pour enregistrer la modification
  mkstat=4

Return
#------------------------------------------------------------------------------#
$OK_SAISVIC_SIH
Local Integer MY_STATUS, WRET

  If GCONSULT>0 : Return : Endif

  Raz [F:SVIC]
  [F:SVIC] = [M:SVIC1]
  Gosub SET_CLS_WITH_M From SUBSVIC

  If [M:SIH4]CREFLG(WNOL)=0
    #--To prevent doing the control on the existence of the original doc
    #--We are in creation mode
    GSVCRINVCND.NOCTL_NUMORI=[V]CST_AYES
  Endif

  WRET = fmet GSVCRINVCND.ACONTROL()

  GSVCRINVCND.NOCTL_NUMORI=[V]CST_ANO

  If (WRET > [V]CST_AERROR)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
    MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
    If (WRET >= [V]CST_AERROR)
      GERR = 1
      FIN = 0
      Return
    Endif
  Endif
  #--Preventing propagate to execute
  GSVCRINVCND.DO_PROPAGATE   = [V]CST_ANO
  # Il faut dégriser le bouton enregistrer pour enregistrer la modification
  mkstat=4

Return
#------------------------------------------------------------------------------#
$ABA_SAISVIC
Local Integer WPREVENT_PROPAGATE_ON_LINES
Local Char    SYMBOLE5(50)

  If GSVCRINVCND=null : GERR=1 : Return : Endif
  # Abandon : Rechargement classe écran avec les anciennes valeurs
  nolign=[M:SVIC1_]NBLIG

  #(MGG 08/05/2017) X3-33114
  Raz [M:SVIC1]
  #[M:SVIC1] = [M:SVIC1_]
  Transmask  [M:SVIC1_] To [M:SVIC1]
  #END (MGG 08/05/2017) X3-33114

  Affzo [M:SVIC1]1-99
  # Chargement classe écran pour maj en sortie
  Case PARAM(1)
    When "SOH4" : Gosub ABA_SAISVIC_SOH From TRTSAISVIC
    When "SIH4" : Gosub ABA_SAISVIC_SIH From TRTSAISVIC
  Endcase

  #--Unlocking SVIC : Example from Locked symbols : SVIC~CDE-2015-5103\10\1000\1000
  SYMBOLE5 = "SVIC"+"~"+[M:SVIC1]VCRNUMORI+"\"+num$([M:SVIC1]VCRTYP)+"\"+num$([M:SVIC1]VCRLINORI)+"\"+num$([M:SVIC1]VCRSEQORI)
  Unlock = SYMBOLE5

  REP = ""

Return
#-------------------------------------------------------------------------------------
$ABA_SAISVIC_SOH
  Raz [F:SVIC]
  [F:SVIC] = [M:SVIC1]

  #--We want the previous exactly values. The setinstance could trigger propagates
  #--seting the WPREVENT_PROPAGATE_ON_LINES to CST_AYES will prevent this
  WPREVENT_PROPAGATE_ON_LINES = [V]CST_AYES

  Gosub SET_CLS_WITH_M From SUBSVIC

  WPREVENT_PROPAGATE_ON_LINES = [V]CST_ANO

  #--Preventing propagate to execute
  GSVCRINVCND.DO_PROPAGATE   = [V]CST_ANO
  #[M:SOH4]DINVCNDTOUPD(WNOL) = [V]CST_ANO #--Leave it as it was

Return
#-------------------------------------------------------------------------------------
$ABA_SAISVIC_SIH

  If GCONSULT>0 : Return : Endif

  Raz [F:SVIC]
  [F:SVIC] = [M:SVIC1]

  #--We want the previous exactly values. The setinstance could trigger propagates
  #--seting the WPREVENT_PROPAGATE_ON_LINES to CST_AYES will prevent this
  WPREVENT_PROPAGATE_ON_LINES = [V]CST_AYES

  Gosub SET_CLS_WITH_M From SUBSVIC

  WPREVENT_PROPAGATE_ON_LINES = [V]CST_ANO

  #--Preventing propagate to execute
  GSVCRINVCND.DO_PROPAGATE   = [V]CST_ANO
  #[M:SOH4]DINVCNDTOUPD(WNOL) = [V]CST_ANO #--Leave it as it was

Return
#-------------------------------------------------------------------------------------
#**
#* Label DISPATCH_DELTA_ON_LINES Is used to dispatch changes of scheduling invoice header to lines
#* It's interractive, giving the choice to the user to dispatch on all lines or only on the last line
#* Depending of the answer given, it calls C_SVCRINVCND class's methods DISPATCH_ON_ALL_LINES or DISPATCH_ON_LASTLINE
#* It returns GERR = 1 if an error occurs
#* @param GSVCRINVCND An instance  of C_SVCRINVCND class
#* @param [M:SVIC1] Used to fill the instance (so it have to be "online")
#*!
$DISPATCH_DELTA_ON_LINES
If GSVCRINVCND=null : GERR=1 : Return : Endif
Local Integer WRET,WOK,MY_STATUS

  Gosub SET_CLS_WITH_M From SUBSVIC
  If (GERR = 1) : Return : Endif
  #--Asking the user if he wants to re-dipatch on all lines or only on last line ?
  WOK=1
  Call OUINON(mess(482,192,1),WOK) From GESECRAN
  If WOK=2
    WRET = fmet GSVCRINVCND.DISPATCH_ON_ALL_LINES()
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
      If WRET>=[V]CST_AERROR
        GERR = 1
        Return
      Endif
    Endif
  Else
    WRET = fmet GSVCRINVCND.DISPATCH_ON_LASTLINE()
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
      If WRET>=[V]CST_AERROR
        GERR = 1
        Return
      Endif
    Endif
  Endif
  #--Refreshing SVIC1 mask with new values
  #--Loading mask properties into the screen, from the class
  Gosub LIENS_WITHOUT_FREEGROUP_AND_AREAD From SUBSVIC
  Affzo [M:SVIC1]1-99

Return
#-------------------------------------------------------------------------------------

