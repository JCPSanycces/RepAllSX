#<AdxTL>@(#)0.0.0.0 $Revision$Class XML files
# Supervisor
## ACLA-CLASSE ## EDIXMLFIL_EXFN
# 2018-11-06 07:05:16 773


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : COMTYP Type ( Field Local menu number 2019)
####################################################################

$SET_COMTYP
If [L]_AOLDVAL<>this.COMTYP
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_COMTYP
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.COMTYP
 Gosub PROPAGATE_COMTYP
Endif
Return

$INIT_COMTYP
Gosub DECLARE_VAR From WMC0EDIXMLFIL_EXFN
[L]CURPRO = "COMTYP"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.COMTYP=0 and fmet this.AGETATTRIBUTE("COMTYP","$isMandatory")="true"
 this.COMTYP = 1
Endif
Return
 
$CONTROL_COMTYP
Gosub DECLARE_VAR From WMC0EDIXMLFIL_EXFN
[L]CURPRO = "COMTYP"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_COMTYP                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_COMTYP                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_COMTYP
[L]CURPRO = "COMTYP"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.COMTYP=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_COMTYP
[L]CURPRO = "COMTYP"
If this.COMTYP<0 or this.COMTYP>len(mess(0,2019,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"2019 ->"-num$(this.COMTYP)-mess(99,123,1)):  Return : # Local menu "2019 -> Invalid option
Endif
Return

$_AOTHERS_COMTYP
[L]CURPRO = "COMTYP"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_COMTYP
[L]CURPRO = "COMTYP"
Return

$PROPAGATE_COMTYP
this.isReadonly = 0
[L]CURPRO = "COMTYP"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_COMTYP
Gosub DECLARE_VAR From WMC0EDIXMLFIL_EXFN
[L]CURPRO = "COMTYP"
$_LNKPRO_COMTYP
Return


