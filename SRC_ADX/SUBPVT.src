#-------------------------------------------------------------------------------------
Subprog VALIDATION(PEVT, PEVTINT, APPLI)
Value Char    PEVT(), PEVTINT()
Value Char    APPLI()

Local Char    NOMTRT(30)
Local Char    FICSRC(255)
Local Integer OK, I_EVTINT, I_CHEVT, REFOBJ
Local Char    EVTINT(10)(1..100)
Local Char    EVTNAM(30)

  # FQ100398/26
  Gosub SYRACUSED_OBJECT

  # X3-41592 Dossier d'indus correspondant au dossier de ref
  Local Char APPLI_INDUS(250)
  APPLI_INDUS = APPLI

  If APPLI = "X3REFCHALL"         # V11
    APPLI_INDUS = "X3INDCHALL"
  Elsif APPLI = "X3REFAMBAS"      # U9
    APPLI_INDUS = "X3INDAMBAS"
  Endif

  If find(left$(PEVT, 3), WT_SYR_OBJ)
    # evts Syracuse
    Call VALIDATION(PEVT, PEVTINT, APPLI, APPLI_INDUS) From GENEVETRT6
  Else
    # anciens evts
    Call VALIDATION(PEVT, PEVTINT, APPLI, APPLI_INDUS) From GENEVETRT5
  Endif

End

######################################################################################
# ACTIONS CHAMPS ECRAN PAREVT
######################################################################################

#-------------------------------------------------------------------------------------
Subprog AM_EVT(VALEUR)
Variable Char    VALEUR()

 #> Alimentation de la table événement associée

 If !clalev([F:ADI]) : Local File ATABDIV [F:ADI] : Endif
 Read [F:ADI]CODE=962;VALEUR
 If fstat
  Infbox "Erreur"
 Endif
 [M:PVT]TABEVT=[F:ADI]A2 : Affzo [M:PVT]TABEVT

 #> Alimentation du type d'objet métier

 [M:PVT]OBJTYP=[F:ADI]N2

 #> Vidage des zones

 Effzo [M]10
 Effzo [M]15
 Effzo [M]20
 Effzo [M]25

 #> Alimentation des champs à partir de ATABZON

 If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
 If !clalev([F:ATY]) : Local File ATYPE   [ATY] : Endif

 Gosub EXCLUSION
 For [ATZ] Where (CODFIC=[M:PVT]TABEVT)
  If !find([F:ATZ]CODZONE,EXCFLD)
   Read [ATY]CODTYP=[F:ATZ]CODTYP
   If [F:ATY]TYPTYP=4 |  [F:ATY]TYPTYP=5 | [F:ATY]TYPTYP=6
    [M]FLDACTN([M]NBCHN)=[F:ATZ]CODACT
    [M]FLDNAMN([M]NBCHN)=[F:ATZ]CODZONE : [M]NBCHN+=1
   Endif
   If [F:ATY]TYPTYP=1  | [F:ATY]TYPTYP=2
    [M]FLDACTM([M]NBCHM)=[F:ATZ]CODACT
    [M]FLDNAMM([M]NBCHM)=[F:ATZ]CODZONE : [M]NBCHM+=1
   Endif
   If [F:ATY]TYPTYP=7
    [M]FLDACTA([M]NBCHA) =[F:ATZ]CODACT
    [M]FLDNAMA([M]NBCHA)=[F:ATZ]CODZONE : [M]NBCHA+=1
   Endif
   If [F:ATY]TYPTYP=8
    [M]FLDACTD([M]NBCHD) =[F:ATZ]CODACT
    [M]FLDNAMD([M]NBCHD)=[F:ATZ]CODZONE : [M]NBCHD+=1
   Endif
  Endif
 Next

 #> Type d'événement tous plan ou par plan

 If [F:ADI]N1=G_NON
  [M]PLN=G301AUC : Grizo [M]PLN
 Else
  [M]PLN=G301CPT : Actzo [M]PLN
 Endif

 Affzo [M]

End

#-------------------------------------------------------------------------------------
Subprog AM_PLN(VALEUR)
Variable Integer VALEUR
End

#-------------------------------------------------------------------------------------
Subprog AV_EVTINT(VALEUR)
Variable Char    VALEUR()
 If GREP="D" | GREP="C"
  If [M]PLN=G301AUC
   VALEUR=[M]EVT
  Else
   VALEUR=[M]EVT+num$([M]PLN)
  Endif
 Endif
End

#-------------------------------------------------------------------------------------
Subprog C_EVTINT(VALEUR)
Variable Char    VALEUR()
 Local Char PEVTINT(30) : PEVTINT = VALEUR
 If 1=1
  If !clalev([F:PVD]) : Local File PAREVTD [PVD] : Endif
  If !clalev([F:PVT]) : Local File PAREVT  [PVT] : Endif
  Filter [PVD] Where EVTINT=PEVTINT
  Read [PVD] First
  If !fstat
   # Le code interne existe déjà dans PAREVTD : on vérifie si c'est pour une autre combinaison EVT+PLN
   #                                            si oui : on interdit
   #                                            si non : on ne fait rien
   Filter [F:PVT] Where EVTINT=PEVTINT
   Read [F:PVT] First
   # On ne trouve pas d'enregistrement dans PAREVT correspndant au code interne VALEUR, on vire les enregistrements
   # correspondant à VALEUR dans PAREVTD
   If fstat=4
    Trbegin [PVD]
    Delete [PVD] Where EVTINT=PEVTINT
    If adxdlrec
     Infbox "Suppression de"-num$(adxdlrec)-"enregistrements dans la table PAREVTD"
    Endif
    If fstat
     Rollback
    Else
     Commit
    Endif
   Endif
   # On trouve un enregistrement correspondant au code interne VALEUR :
   #     Si le couple EVT+PLN est le même, c'est normal
   #     Si le couple EVT+PLN est différent, erreur : Le code interne existe déjà
   If [F:PVT]EVT<>[M]EVT | [F:PVT]PLN<>[M]PLN
    GERR=1 : GMESSAGE = "Ce code interne existe déjà"
    mkstat=2
   Endif
  Endif
  Filter [PVD]
 Endif
End

#-------------------------------------------------------------------------------------
Subprog AV_FLDNAMA(VALEUR)
Variable Char    VALEUR()
 Local Char FLDACT(30) : FLDACT = [M]FLDACTA(nolign-1) : Gosub MEF_FLDACT
End

#-------------------------------------------------------------------------------------
Subprog AV_FLDNAMN(VALEUR)
Variable Char    VALEUR()
 Local Char FLDACT(30) : FLDACT = [M]FLDACTN(nolign-1) : Gosub MEF_FLDACT
End

#-------------------------------------------------------------------------------------
Subprog AV_FLDNAMM(VALEUR)
Variable Char    VALEUR()
 Local Char FLDACT(30) : FLDACT = [M]FLDACTM(nolign-1) : Gosub MEF_FLDACT
End

#-------------------------------------------------------------------------------------
Subprog AV_FLDNAMD(VALEUR)
Variable Char    VALEUR()
 Local Char FLDACT(30) : FLDACT = [M]FLDACTD(nolign-1) : Gosub MEF_FLDACT
End

#-------------------------------------------------------------------------------------
$MEF_FLDACT
 If FLDACT<>""
  If find(FLDACT,GCODACTABX3)
   pcolor = GCOUL(1)
  Else
   pcolor = GCOUL(3)
  Endif
 Else
  pcolor = GCOUL(0)
 Endif
Return

