#<AdxTL>@(#)2.0.0.0 $Revision$
 Call OBJET("PVT",GBIDC1,GBIDC2) From GOBJET
End


#########################################################################
#
# GESTION DE L'OUTIL DE PARAMETRAGE DE L'ALIMENTATION
# DES EVENEMENTS.
#
# Les types d'événements sont définis dans la table diverse 962
# Une table Exxxxx est définie par type d'événement
# La table EMODELE contient les champs communs à toutes les tables événement
#   Le traitement ZGB_REPEVT permet de mettre à jour les table Exxxxx
#   après une modification de la table EMODELE
#
# Issue X3-59028 - 2018-01-22 by CBO : Changes of accounting task for mindo
# FQ95898  Code activité CCN
# CBO   25.09.2017 X3-41592    : Dossier d'indus correspondant au dossier de ref
# CBO   26.06.2015 FQ107956    : La fct GET_CCE ne semble pas appelée (et utile) dans ce traitement
# CBO   17.02.2015 FQ100398/26 : Syracused event or not
#########################################################################

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "RAZDUP"    : Gosub RAZDUP
 When "LIENS"     : Gosub LIENS
 When "SETBOUT"   : Gosub SETBOUT
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "VERF_ANU"  : Gosub VERF_ANU
 When "AVANTBOUT" : Gosub AVANTBOUT
 When Default
Endcase
Return

#=========================================================
$OUVRE
 If !clalev([F:PVT]) : Local File PAREVT  [PVT] : Endif
 If !clalev([F:PVD]) : Local File PAREVTD [PVD] : Endif

 Global Integer GNBRACTABX3     : GNBRACTABX3 = 5
 Global Char    GCODACTABX3(GLONACT)(1..GNBRACTABX3)
 Global Char    GGLOACTABX3(13)(1..GNBRACTABX3)

  Gosub DECLAR_DOSSIER


 GCODACTABX3(1) = "IAS"
 GGLOACTABX3(1) = "G_ACTIAS"

 GCODACTABX3(2) = "LEA"
 GGLOACTABX3(2) = "G_ACTLEA"

 GCODACTABX3(3) = "GRT"
 GGLOACTABX3(3) = "G_ACTLEA"

 GCODACTABX3(4) = "KRU"
 GGLOACTABX3(4) = "G_ACTKRU"

 # FQ95898
 GCODACTABX3(5) = "CCN"
 GGLOACTABX3(5) = "G_ACTCCN"

Return

# FQ101811
$DECLAR_DOSSIER

#* GAPPLI_PARAM     appli ou se trouve le paramétrage
#* GAPPLI_TRT       appli ou se trouvent les sources et traitements générés
#*!
Global Char GAPPLI_PARAM(30), GAPPLI_TRT(30)

#  GAPPLI_PARAM = "GX3APP"
#  GAPPLI_TRT   = "GX3APP"

  GAPPLI_PARAM = nomap
  GAPPLI_TRT   = nomap

Return
#=========================================================
$RAZCRE
Return

#=========================================================
$RAZDUP
Return

#=========================================================
$LIENS

 Local Char LEVTINT(30) : LEVTINT=[M]EVTINT

  #> Alimentation des champs à partir de ATABZON / PAREVTD

  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:ATY]) : Local File ATYPE   [ATY] : Endif
  If !clalev([F:PVD]) : Local File PAREVTD [PVD] : Endif

  Gosub EXCLUSION

  For [ATZ] Where (CODFIC=[M:PVT]TABEVT)
    If find([F:ATZ]CODZONE,EXCFLD) = 0
      Read [ATY]CODTYP=[F:ATZ]CODTYP

      #> Champs de type numérique

      If [F:ATY]TYPTYP=4 or  [F:ATY]TYPTYP=5 or [F:ATY]TYPTYP=6
        [M]FLDNAMN([M]NBCHN)=[F:ATZ]CODZONE
        Read [PVD]PVD0=LEVTINT;[F:ATZ]CODZONE
        If fstat = 0
          [M]FLDFILN([M]NBCHN)  = [F:PVD]FLDFIL
          [M]FLDPRORAT([M]NBCHN)= [F:PVD]FLDPRORAT
          If [F:ATZ]CODACT <> [F:PVD]FLDACT
            [F:PVD]FLDACT = [F:ATZ]CODACT
          Endif
          [M]FLDACTN([M]NBCHN)  = [F:PVD]FLDACT
          [M]NUMLIGN([M]NBCHN)  = [F:ATZ]NUMLIG
          If !adxlog
            Trbegin [PVD]
            Local Integer LTRS
          Endif
          [F:PVD]FLGKEEP = 1
          Rewrite [F:PVD]
          If fstat
            GOK=0
            If dim(LTRS) > 0
              Rollback
              Kill LTRS
            Endif
          Else
            If dim(LTRS) > 0
              Commit
              Kill LTRS
            Endif
          Endif
        Endif

        If fstat=5 and [M]FLDNAMN([M]NBCHN)<>""
          If !adxlog
            Trbegin [PVD]
            Local Integer LTRS
          Endif
          [F:PVD]EVTINT    = LEVTINT
          [F:PVD]FLDNAM    = [F:ATZ]CODZONE
          [F:PVD]FLDTYP    = 4
          [F:PVD]FLDFIL    = ""
          [F:PVD]FLDPRORAT = G_NON
          [F:PVD]FLGKEEP   = 1
          [F:PVD]FLDACT    = [F:ATZ]CODACT
          [F:PVD]NUMLIG    = [F:ATZ]NUMLIG
          Write [F:PVD]
          If fstat
            GOK=0
            If dim(LTRS)>0
              Rollback
              Kill LTRS
            Endif
          Else
            If GTRACE<>""
              Call ECR_TRACE("    "+"Ajout du champ"-[F:PVD]FLDNAM,0) From GESECRAN
            Endif
            If dim(LTRS)>0
              Commit
              Kill LTRS
            Endif
          Endif
        Endif
        [M]NBCHN+=1
      Endif

      #> Champs de type menu local

      If [F:ATY]TYPTYP=1 | [F:ATY]TYPTYP=2
        [M]FLDNAMM([M]NBCHM)=[F:ATZ]CODZONE
        Read [PVD]PVD0=LEVTINT;[F:ATZ]CODZONE
        If fstat = 0
          [M]FLDFILM([M]NBCHM)=[F:PVD]FLDFIL
          If [F:ATZ]CODACT <> [F:PVD]FLDACT
            [F:PVD]FLDACT = [F:ATZ]CODACT
          Endif
          [M]FLDACTM([M]NBCHM)  = [F:PVD]FLDACT
          [M]NUMLIGM([M]NBCHM)  = [F:ATZ]NUMLIG
          If !adxlog
            Trbegin [PVD]
            Local Integer LTRS
          Endif
          [F:PVD]FLGKEEP = 1
          Rewrite [F:PVD]
          If fstat
            GOK=0
            If dim(LTRS)>0
              Rollback
              Kill LTRS
            Endif
          Else
            If dim(LTRS)>0
              Commit
              Kill LTRS
            Endif
          Endif
        Endif
        If fstat=5 and [M]FLDNAMM([M]NBCHM)<>""
          If !adxlog
            Trbegin [PVD]
            Local Integer LTRS
          Endif
          [F:PVD]EVTINT    = LEVTINT
          [F:PVD]FLDNAM    = [F:ATZ]CODZONE
          [F:PVD]FLDTYP    = 1
          [F:PVD]FLDFIL    = ""
          [F:PVD]FLGKEEP   = 1
          [F:PVD]FLDACT    = [F:ATZ]CODACT
          [F:PVD]NUMLIG    = [F:ATZ]NUMLIG
          Write [F:PVD]
          If fstat
            GOK=0
            If dim(LTRS)>0
              Rollback
              Kill LTRS
            Endif
          Else
            If GTRACE<>""
              Call ECR_TRACE("    "+"Ajout du champ"-[F:PVD]FLDNAM,0) From GESECRAN
            Endif
            If dim(LTRS)>0
              Commit
              Kill LTRS
            Endif
          Endif
        Endif
        [M]NBCHM+=1
      Endif

      #> Champs de type alphanumérique

      If [F:ATY]TYPTYP=7
        [M]FLDNAMA([M]NBCHA)=[F:ATZ]CODZONE
        Read [PVD]PVD0=LEVTINT;[F:ATZ]CODZONE
        If fstat = 0
          [M]FLDFILA([M]NBCHA)=[F:PVD]FLDFIL
          If [F:ATZ]CODACT<>[F:PVD]FLDACT
            [F:PVD]FLDACT = [F:ATZ]CODACT
          Endif
          [M]FLDACTA([M]NBCHA)  = [F:PVD]FLDACT
          [M]NUMLIGA([M]NBCHA)  = [F:ATZ]NUMLIG
          If !adxlog
            Trbegin [PVD]
            Local Integer LTRS
          Endif
          [F:PVD]FLGKEEP = 1
          Rewrite [F:PVD]
          If fstat
            GOK=0
            If dim(LTRS)>0
              Rollback
              Kill LTRS
            Endif
          Else
            If dim(LTRS)>0
              Commit
              Kill LTRS
            Endif
          Endif
        Endif

        If fstat=5 and [M]FLDNAMA([M]NBCHA)<>""
          If !adxlog
            Trbegin [PVD]
            Local Integer LTRS
          Endif
          [F:PVD]EVTINT    = LEVTINT
          [F:PVD]FLDNAM    = [F:ATZ]CODZONE
          [F:PVD]FLDTYP    = 7
          [F:PVD]FLDFIL    = ""
          [F:PVD]FLGKEEP   = 1
          [F:PVD]FLDACT    = [F:ATZ]CODACT
          [F:PVD]NUMLIG    = [F:ATZ]NUMLIG
          Write [F:PVD]
          If fstat
            GOK=0
            If dim(LTRS)>0
              Rollback
              Kill LTRS
            Endif
          Else
            If GTRACE<>""
              Call ECR_TRACE("    "+"Ajout du champ"-[F:PVD]FLDNAM,0) From GESECRAN
            Endif
            If dim(LTRS)>0
              Commit
              Kill LTRS
            Endif
          Endif
        Endif
        [M]NBCHA+=1
      Endif

      #> champs de type Date

      If [F:ATY]TYPTYP=8
        [M]FLDNAMD([M]NBCHD)=[F:ATZ]CODZONE
        Read [PVD]PVD0=LEVTINT;[F:ATZ]CODZONE
        If fstat = 0
          [M]FLDFILD([M]NBCHD)=[F:PVD]FLDFIL
          If [F:ATZ]CODACT<>[F:PVD]FLDACT
            [F:PVD]FLDACT = [F:ATZ]CODACT
          Endif
          [M]FLDACTD([M]NBCHD)  = [F:PVD]FLDACT
          [M]NUMLIGD([M]NBCHD)  = [F:ATZ]NUMLIG
          If !adxlog
            Trbegin [PVD]
            Local Integer  LTRS
          Endif
          [F:PVD]FLGKEEP = 1
          Rewrite [F:PVD]
          If fstat
            GOK=0
            If dim(LTRS)>0
              Rollback
              Kill LTRS
            Endif
          Else
            If dim(LTRS)>0
              Commit
              Kill LTRS
            Endif
          Endif
        Endif

        If fstat=5 and [M]FLDNAMD([M]NBCHD)<>""
          If !adxlog
            Trbegin [PVD]
            Local Integer LTRS
          Endif
          [F:PVD]EVTINT    = LEVTINT
          [F:PVD]FLDNAM    = [F:ATZ]CODZONE
          [F:PVD]FLDTYP    = 8
          [F:PVD]FLDFIL    = ""
          [F:PVD]FLGKEEP   = 1
          [F:PVD]FLDACT    = [F:ATZ]CODACT
          [F:PVD]NUMLIG    = [F:ATZ]NUMLIG
          Write [F:PVD]
          If fstat
            GOK
            If dim(LTRS)>0
              Rollback
              Kill LTRS
            Endif
          Else
            If GTRACE<>""
              Call ECR_TRACE("    "+"Ajout du champ"-[F:PVD]FLDNAM,0) From GESECRAN
            Endif
            If dim(LTRS)>0
              Commit
              Kill LTRS
            Endif
          Endif
        Endif
        [M]NBCHD+=1
      Endif
    Endif
  Next

  If LEVTINT<>""
    If !adxlog
      Trbegin [PVD]
      Local Integer LTRS
    Endif
    Delete [PVD] Where EVTINT=LEVTINT & FLGKEEP<>1
    If adxdlrec
      If GTRACE<>""
        Call ECR_TRACE("    "-num$(adxdlrec)-"Champs supprimés dans la table PAREVTD" ,0) From GESECRAN
      Else
        Infbox num$(adxdlrec)-"Champs supprimés dans la table PAREVTD"
      Endif
    Endif
    If fstat
      GOK=0
      If dim(LTRS)>0
        Rollback
        Kill LTRS
      Endif
    Else
      If dim(LTRS)>0
        Commit
        Kill LTRS
      Endif
    Endif
    If !adxlog
      Trbegin [PVD]
      Local Integer LTRS
    Endif
    Update [PVD] Where EVTINT=LEVTINT With FLGKEEP=0
    If fstat
      GOK=0
      If dim(LTRS)>0
        Rollback
        Kill LTRS
      Endif
    Else
      If dim(LTRS)>0
        Commit
        Kill  LTRS
      Endif
    Endif
  Endif

  If [M]PLN=G301AUC
    Grizo [M]PLN
  Else
    Actzo [M]PLN
  Endif

Return

#=========================================================
$SETBOUT
 CHAINE+="A"

 If GREP="C"
  Call VIREBOUT(CHAINE,"V") From GOBJET # Validation
  Call VIREBOUT(CHAINE,"B") From GOBJET # Alimentation table événement
  Call VIREBOUT(CHAINE,"G") From GOBJET # Editeur de traitement
 Endif

 If GREP=""
  If [M]EVTINT=""
   Call VIREBOUT(CHAINE,"B") From GOBJET
  Endif
 Endif

# Call EXISTE_ADX(adxmac(-1),adxmother,"GV"+[M]EVTINT,OK) From ORDSYS
#Call EXISTE_ADX("","","GV"+[M]EVTINT,OK) From ORDSYS
 If !OK
  Call VIREBOUT(CHAINE,"G") From GOBJET
 Endif

Return

#=========================================================
$AVANTBOUT
 Case BOUT
  When "B" : Gosub PRINT_EVTINT From SUBPVT
  When "V" : Gosub VALTRT       From SUBPVT
  When "G" : Gosub EDITION      From SUBPVT
 Endcase
Return

#=========================================================
$INICRE
 Local Integer LCREATION : LCREATION=1 : Gosub MAJ_PAREVTD
Return

#=========================================================
$INIMOD
 Local Integer LCREATION : LCREATION=0 : Gosub MAJ_PAREVTD
Return

#=========================================================
$VERF_ANU
 If !clalev([F:PVD]) : Local File PAREVTD [PVD] : Endif
# Call EXISTE_ADX("","","GV"+[M]EVTINT,OK) From ORDSYS
  Call EXISTE_ADX("", GAPPLI_TRT, "GV" + [M]EVTINT, OK) From ORDSYS
 If OK
  Call DELTRT("GV"+[M]EVTINT,nomap) From SUBADC
 Endif
 Delete [F:PVD] Where EVTINT=[M]EVTINT
 If fstat
  GOK=0
  Infbox "Suppression PVD fstat"-num$(fstat)
 Endif
Return

##########################################################################
## Routines diverses                                                     #
##########################################################################

#-------------------------------------------------------------------------------------
$EDITION
 Call EDITION("GV"+[M]EVTINT) From SUBADC
Return

#-------------------------------------------------------------------------------------
$VALTRT
 Local Integer EXISTE_ADX

 Call TEMPON("V") From GESECRAN
 Call VALIDATION([M]EVT, [M]EVTINT, GAPPLI_PARAM)
 Call TEMPOFF From GESECRAN
# issue X3-59028
# not useful when stop and start
# Call EXISTE_ADX("", "", "BATCHCPT", EXISTE_ADX) From ORDSYS
# If EXISTE_ADX Then
#  Call SETFLG From BATCHCPT : # Flag pour le batch
# Endif
# End issue X3-59028
Return

#-------------------------------------------------------------------------------------
$MAJ_PAREVTD

 Local Integer I

  #> Alphanumérique

  For I=1 To [M]NBCHA
    If !LCREATION
      Read [PVD]PVD0=[M]EVTINT;[M]FLDNAMA(I-1)
    Endif
    [F:PVD]FLGKEEP   = 0
    If LCREATION or fstat=5
      [F:PVD]EVTINT=[M]EVTINT
      [F:PVD]FLDNAM=[M]FLDNAMA(I-1)
      [F:PVD]FLDTYP=7
      [F:PVD]FLDFIL=[M]FLDFILA(I-1)
      [F:PVD]NUMLIG=[M]NUMLIGA(I-1)
      Write [F:PVD]
    Else
      If [F:PVD]FLDFIL<>[M]FLDFILA(I-1)
        [F:PVD]FLDFIL=[M]FLDFILA(I-1)
      Endif
      [F:PVD]NUMLIG=[M]NUMLIGA(I-1)
      Rewrite [F:PVD]
    Endif
  Next I

  #> Menu local
  For I=1 To [M]NBCHM
    If !LCREATION
      Read [PVD]PVD0=[M]EVTINT;[M]FLDNAMM(I-1)
    Endif
    [F:PVD]FLGKEEP   = 0
    If LCREATION or fstat=5
      [F:PVD]EVTINT=[M]EVTINT
      [F:PVD]FLDNAM=[M]FLDNAMM(I-1)
      [F:PVD]FLDTYP=1
      [F:PVD]FLDFIL=[M]FLDFILM(I-1)
      [F:PVD]NUMLIG=[M]NUMLIGM(I-1)
      Write [F:PVD]
    Else
      If [F:PVD]FLDFIL<>[M]FLDFILM(I-1)
        [F:PVD]FLDFIL=[M]FLDFILM(I-1)
      Endif
      [F:PVD]NUMLIG=[M]NUMLIGM(I-1)
      Rewrite [F:PVD]
    Endif
  Next I

  #> Dates

  For I=1 To [M]NBCHD
    If !LCREATION
      Read [PVD]PVD0=[M]EVTINT;[M]FLDNAMD(I-1)
    Endif
    [F:PVD]FLGKEEP   = 0
    If LCREATION or fstat=5
      [F:PVD]EVTINT=[M]EVTINT
      [F:PVD]FLDNAM=[M]FLDNAMD(I-1)
      [F:PVD]FLDTYP=8
      [F:PVD]FLDFIL=[M]FLDFILD(I-1)
      [F:PVD]NUMLIG=[M]NUMLIGD(I-1)
      Write [F:PVD]
    Else
      If [F:PVD]FLDFIL<>[M]FLDFILD(I-1)
        [F:PVD]FLDFIL=[M]FLDFILD(I-1)
      Endif
      [F:PVD]NUMLIG=[M]NUMLIGD(I-1)
      Rewrite [F:PVD]
    Endif
  Next I

  #> Numériques

  For I=1 To [M]NBCHN
    If !LCREATION
      Read [PVD]PVD0=[M]EVTINT;[M]FLDNAMN(I-1)
    Endif
    [F:PVD]FLGKEEP   = 0
    If LCREATION or fstat=5
      [F:PVD]EVTINT   = [M]EVTINT
      [F:PVD]FLDNAM   = [M]FLDNAMN(I-1)
      [F:PVD]FLDTYP   = 4
      [F:PVD]FLDFIL   = [M]FLDFILN(I-1)
      [F:PVD]FLDPRORAT= [M]FLDPRORAT(I-1)
      [F:PVD]NUMLIG   = [M]NUMLIGN(I-1)
      Write [F:PVD]
    Else
      If [F:PVD]FLDFIL   <>[M]FLDFILN(I-1)
        [F:PVD]FLDFIL   =[M]FLDFILN(I-1)
      Endif
      If [F:PVD]FLDPRORAT<>[M]FLDPRORAT(I-1)
        [F:PVD]FLDPRORAT=[M]FLDPRORAT(I-1)
      Endif
      [F:PVD]NUMLIG   = [M]NUMLIGN(I-1)
      Rewrite [F:PVD]
    Endif
  Next I

Return

#-------------------------------------------------------------------------------------
$EXCLUSION
 Local Char EXCFLD(10)(1..50)
 EXCFLD(01)  = "CPY"
 EXCFLD(02)  = "FCY"
 EXCFLD(03)  = "REF"
 EXCFLD(04)  = "LIN"
 EXCFLD(05)  = "DPRPLN"
 EXCFLD(06)  = "CNX"
 EXCFLD(07)  = "EVTINT"
 EXCFLD(08)  = "CREUSR"
 EXCFLD(09)  = "CREDAT"
 EXCFLD(10)  = "CRETIM"
 EXCFLD(11)  = "TIMSTP"
 EXCFLD(12)  = "EVTDAT"
 EXCFLD(13)  = "CPTDATINT"
 EXCFLD(14)  = "CPTFLG"
 EXCFLD(15)  = "SNSEVE"
 EXCFLD(16)  = "SNSCPT"
 EXCFLD(17)  = "CREUSRO"
 EXCFLD(18)  = "TIMSTPO"
 EXCFLD(19)  = "CPTDATINTO"
 EXCFLD(20)  = "CREORI"
 EXCFLD(21)  = "UPDUSR"
 EXCFLD(22)  = "UPDDAT"
 EXCFLD(23)  = "UPDTIM"
 # FQ101826
 EXCFLD(24)  = "CURPERSTR"
 EXCFLD(25)  = "CREDATTIM"
 EXCFLD(26)  = "UPDDATTIM"
 EXCFLD(27)  = "AUUID"

Return

#-------------------------------------------------------------------------------------
$PRINT_EVTINT

 If dim(PEVTINT)<0
  Local Char PEVTINT(30)
 Endif

 If PEVTINT="" & dim([M]EVTINT)>0
  If [M]EVTINT<>""
   PEVTINT = [M]EVTINT
  Endif
 Endif
 If PEVTINT<>"" & dim([M]EVTINT)>0
  PEVTINT = [M]EVTINT
 Endif

 If PEVTINT=""
  Infbox "Aucun code interne à imprimer"
  Return
 Endif

 If !clalev([F:PVD]) : Local File PAREVTD [PVD] : Endif

 Local Integer  LFLDTYP
 Local Char     LIGNE(110)

 If GTRACE=""
  Call OUVRE_TRACE("Contenu de la table PAREVTD code interne"-PEVTINT) From LECFIC
  Local Integer LOUVRETRC
 Endif

 LFLDTYP = 1 : Gosub PRINT_FLDTYP
 LFLDTYP = 4 : Gosub PRINT_FLDTYP
 LFLDTYP = 7 : Gosub PRINT_FLDTYP
 LFLDTYP = 8 : Gosub PRINT_FLDTYP

 If dim(LOUVRETRC)>0
  Call LEC_TRACE() From LECFIC
 Endif

Return

#-------------------------------------------------------------------------------------
$PRINT_FLDTYP
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE("Champs de type"-mess(LFLDTYP,30,1),0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 For [PVD] Where EVTINT=PEVTINT & FLDTYP=LFLDTYP
  LIGNE = space$(5)+[F:PVD]FLDACT+
&         space$(5-len([F:PVD]FLDACT))+
&         [F:PVD]FLDNAM+
&         space$(15-len([F:PVD]FLDNAM))+
&         [F:PVD]FLDFIL
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Next
 Call ECR_TRACE("",0) From GESECRAN
Return

#-------------------------------------------------------------------------------------
$MAJ_EVTINT

Local Integer NBFLD
  Gosub EXCLUSION

  For [PVT]
    Update [PVD] Where EVTINT=[F:PVT]EVTINT With FLGKEEP=0
    For NBFLD=1 To [M]NBZONE
      If !find([M:ATB2]CODZONE(NBFLD-1),EXCFLD)
        Read [PVD]PVD0=[F:PVT]EVTINT;[M:ATB2]CODZONE(NBFLD-1)
        If fstat
          [F:PVD]FLGKEEP=1
          Rewrite [F:PVD]
        Endif
        If fstat=5
          Raz [F:PVD]
          [F:PVD]EVTINT   = [F:PVT]EVTINT
          [F:PVD]FLDNAM   = [M:ATB2]CODZONE(NBFLD-1)
          Read [ATY]CODTYP=[M:ATB2]CODTYP(NBFLD-1)
          If [F:ATY]TYPTYP=4 or [F:ATY]TYPTYP=5 or [F:ATY]TYPTYP=6
            [F:PVD]FLDTYP=4
          Endif
          If [F:ATY]TYPTYP=1 or [F:ATY]TYPTYP=7 or [F:ATY]TYPTYP=8
            [F:PVD]FLDTYP=[F:ATY]TYPTYP
          Endif
          [F:PVD]FLDPRORAT= G_NON
          [F:PVD]FLGKEEP  = 1
          Write [F:PVD]
        Endif
      Endif
    Next
    Delete [PVD] Where EVTINT=[F:PVT]EVTINT & FLGKEEP<>1
  Next

Return

#-------------------------------------------------------------------------------------
# Routine appelé en cas de modification de la structure d'une table événement.
# Elle permet de mettre à jour l'ensemble des codes internes déjà définis
#    - Ajout de champ dans la table
#    - Suppression de champs
# Le nom de l'événement est donné dans la variable : LTYPEVT
#-------------------------------------------------------------------------------------
$MAJ_TAB_EVT

  If GTRACE=""
    Call OUVRE_TRACE("Modification de la table de stockage de l'événement "-LTYPEVT) From LECFIC
    Local Integer LTRC
  Endif
  If !clalev([M:PVT]) : Local Mask PAREVT [PVT]  : Endif
  Gosub OUVRE
  Filter [F:PVT] Where EVT=LTYPEVT
  Call TEMPON("E") From GESECRAN
  Call ECR_TRACE("MISE A JOUR DES CODES INTERNES DEFINIS POUR L'EVENEMENT"-LTYPEVT,0) From GESECRAN
  For [F:PVT]
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE([F:PVT]EVT-"/"-mess([F:PVT]PLN,301,1)-"/"-[F:PVT]EVTINT,0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
    Raz [M:PVT]
    [M:PVT]=[F:PVT]
    Gosub LIENS
  Next
  Filter [F:PVT]
  Call TEMPOFF() From GESECRAN
  If dim(LTRC)>0
    Call LEC_TRACE From LECFIC
    Kill LTRC
  Endif

Return

