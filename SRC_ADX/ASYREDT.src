#<AdxTL>@(#)4.0.0.0 $Revision$
End

#**
#* Funprog HANDLER_PUT()
#*!
Funprog HANDLER_PUT(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer ERROR : ERROR=[V]CST_AOK
Local Integer COUNT

ERROR = func ASYRDELSYS.SEARCH_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT)
If ERROR = [V]CST_AOK
 ERROR = func UPD(ACTX,ASWK(COUNT),ASWK(COUNT).METCLA,ASWK(COUNT).DATCLA,PSYR,ARCV,JSON,ASND)
Endif

End ERROR

#-------------------------------------------------------------------------------------------#
# Delta
#-------------------------------------------------------------------------------------------#

Funprog UPD(ACTX,ASWK,REP,WREP,PSYR,ARCV,NODE,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK Using C_ASYRWRK
Variable Instance REP  Using C_AREPENT
Variable Instance WREP Using OBJECT
Variable Instance PSYR Using C_ASYR
Variable Instance ARCV Using C_ASYRRCV
Variable Instance NODE Using C_ASYRJSO
Variable Instance ASND Using C_ASYRSND


Local Integer  I , J , K , NUMLIN , ASTATUS , COUNT , ASTACRUD , ASTAERR
Local Uuident  UIDINS , UIDPAR
Local Char     INSFAT(250)
Local Char     REPNAM(20) , GRPINS(20)
Local Char     PRGREP(30) , PRGEXE(30)
Local Char     WBUTCOD(50) , WMES(80)
Local Char     WNAME_INSTANCE(250)
Local Integer  WMETHOD
Local Char     WACTION_COL(1)
Local Char     WCOLLECTION(30)
Local Integer  WINDEX
Local Integer  WNUMBER_INSTANCE
Local Char     WCHAINE(250)
Local Datetime WTIME
Local Integer  MODPRO
Local Char     MET_KEYS(250) , MET_CODPAR(30)(1..30) , MET_VALPAR(250)(1..30)

Raz ASND.DATA , WMES , MODPRO

FreeInstance [ULN]

Local Instance UPD(1..)  Using C_ADELTA    : # Delta values of properties initialized
Local Instance BUT(1..)  Using C_ADELTABUT : # Delta button
Local Instance ULN(1..)  Using C_ADELTALIN : # Uncommitted lines of collection by the serveur

Local Char BUTTONS(250)

REPNAM = ASWK.REPNAM
GRPINS = REPNAM

#------------------------------------------#
# Datas returned by Syracuse
#------------------------------------------#
ASTATUS = func ASYRDEL.PARSEDELTA(ACTX,NODE,UPD)

If GTRASYR : Gosub TRACE_RECEIVE_DELTA : Endif

#---------------------------------------#
# Buttons (standard or method)
#---------------------------------------#
Call DELTA_BUTTON(UPD,WBUTCOD,UIDINS,UIDPAR,WCOLLECTION,WINDEX) From ASYRDELSYS
If GTRASYR : Call TRACE("button="+WBUTCOD-"uuid="+num$(UIDINS)) From ASYRCOM : Endif

WMETHOD = 0
Case WBUTCOD
 When "$abort"
 When "$duplicate"
 When "$save"
 When Default
  For I=1 To maxtab(REP.LNK)
   If REP.LNK(I)<>null & REP.LNK(I).TYP=2 & WBUTCOD=REP.LNK(I).COD : # Method
    Call DECODE_PARAM(UPD,WBUTCOD,MET_KEYS,MET_CODPAR,MET_VALPAR)
    For J=1 To dim(MET_CODPAR)
     If MET_CODPAR(J)<>""
      Call TRACE(MET_CODPAR(J)+"="+MET_VALPAR(J)) From ASYRCOM
     Endif
    Next J
    WMETHOD = I : Break
   Endif
  Next I
Endcase

#-------------------------------------------------------------------------#
# If a property is updated & button $save not disable -> enable buttons
#-------------------------------------------------------------------------#

If dim(WREP.ALINK)<=0
 MODPRO = 1
Else
 For I=1 To maxtab(UPD)
  If UPD(I)<>null & (left$(UPD(I).PRO,1)<>"$" & UPD(I).CAT<>3)
   For J=1 To maxtab(WREP.ALINK)
    If WREP.ALINK(J)<>null & WREP.ALINK(J).COD="$save"
     WCHAINE = func ASYRDELCLI.ATTRIBUTE(WREP.ALINK(J).ATT,func ASYRSUB.CODATT("G"))
     If WCHAINE=func ASYRSUB.BOOLEAN_TO_SYR(1)
      MODPRO = 1
      Break 2
     Endif
    Endif
   Next J
  Endif
 Next I
Endif

#--------------------------------------#
# Enable syssnapshot
#--------------------------------------#
WREP.setAccessorEnabled = 1
Call SET_SYSSNAPSHOT(WREP,1) From ASYRDELSYS

#------------------------------------------#
# Set class with datas of Syracuse
#------------------------------------------#

Call SET_REPRESENTATION(REP,WREP,UPD,ULN) From ASYRDELCLI

#--------------------------------------------#
# Execute method (trt WMR0*)
#--------------------------------------------#

If GTRASYR : Call TRACE("method="+num$(WMETHOD)-num$(UIDINS)) From ASYRCOM : Endif
If WMETHOD
 If UIDINS=NullUuid
  WNAME_INSTANCE = REP.ICL
 Else
  # find instance with uuid property
  Call FIND_UUID(WREP,UIDINS,WNAME_INSTANCE) From ASYRUID
  If WNAME_INSTANCE=REP.ICL & REP.LNK(WMETHOD).MET.INS=""
   WNAME_INSTANCE = ""
  Endif
 Endif
 If GTRASYR : Call TRACE("exe method="+REP.LNK(WMETHOD).MET.COD-"instance="+WNAME_INSTANCE-"prg="+PRGEXE) From ASYRCOM : Endif
 PRGEXE = func APREFIXTRT.GET_PREFIX_REP+"0"+REP.REP
 Call EXE_METHOD(WREP,REP.LNK(WMETHOD).MET.COD,WNAME_INSTANCE,MET_CODPAR,MET_VALPAR) From =PRGEXE
Endif

#--------------------------------------#
# Execute button $save -> CRUD
#--------------------------------------#
Case WBUTCOD
 When "$save"
  Case ASWK.REQUEST
   When "CREATE" : ASTACRUD = fmet WREP.AINSERT

   When "UPDATE" : ASTACRUD = fmet WREP.AUPDATE
  Endcase
Endcase

#------------------------------------------------------#
# Load delta class with sysnapshot of propagates
#------------------------------------------------------#

FreeInstance [UPD]
Local Instance  UPD(1..) Using C_ADELTA

Call LOAD_DELTA(WREP,REP,UPD,ULN) From ASYRDELSRV

If MODPRO
 Gosub ENABLE_BUTTONS
Endif

If GTRASYR : Gosub TRACE_SEND_DELTA : Endif

#--------------------------------------#
# Disable syssnapshot
#--------------------------------------#

Call SET_SYSSNAPSHOT(WREP,0) From ASYRDELSYS
WREP.setAccessorEnabled = 0

#-----------------------------------------#
# Execute other buttons
#-----------------------------------------#

Case WBUTCOD
 When "$abort"
  WMES = mess(297,123,1) : # Abandon de l'opération en cours
  ASTATUS = [V]CST_ASUCCESS
  BUTTONS="$save,$abort,*" : Gosub DISABLE_BUTTONS
 When "$save"
  Case ASWK.REQUEST
   When "CREATE"
    If ASTACRUD<=[V]CST_AWARNING
     WMES = mess(103,141,1) : # Enregistrements créés
     ASTATUS = fmet WREP.AGETMAXERROR("")
     If ASTATUS=CST_AOK
      ASTATUS = [V]CST_ASUCCESS
     Else
      ASTATUS = CST_AWARNING
     Endif
     BUTTONS="$save,$abort,*" : Gosub DISABLE_BUTTONS
     # If record is correctly created, the new facet is "update"
     ASWK.REQUEST = "UPDATE"
     # And ... disable key properties (isReadOnly=true)
     For I=1 To maxtab(REP.CLE)
      If REP.CLE(I).PRO<>""  : # and adxusr<>"ccl"
       Call MAJ_ATTRIBUT(UPD,1,0,UIDPAR,UIDINS,0,"",REP.CLE(I).PRO,func ASYRSUB.CODATT("R"),func ASYRSUB.BOOLEAN_TO_SYR(2))
&      From ASYRDELSYS
      Endif
     Next I
    Else
     BUTTONS="$save" : Gosub DISABLE_BUTTONS
    Endif
   When "UPDATE"
    If ASTACRUD<=[V]CST_AWARNING
     WMES = mess(192,124,1) : # Enregistrements mis à jour
     ASTATUS = fmet WREP.AGETMAXERROR("")
     If ASTATUS=CST_AOK
      ASTATUS = CST_ASUCCESS
     Else
      ASTATUS = CST_AWARNING
     Endif
     BUTTONS="$save,$abort,*" : Gosub DISABLE_BUTTONS
    Else
     ASTATUS = ASTACRUD
    Endif
   When Default
    WMES = WBUTCOD-"Invalid button"
    ASTATUS = [V]CST_AERROR
    Gosub ERRORS
  Endcase
 When "$duplicate"
  WMES = "Button"-WBUTCOD-"for"-ASWK.REQUEST-":"-"Action being developed"
  ASTATUS = [V]CST_AERROR
  Gosub ERRORS
 When Default
  If WBUTCOD<>"" & !WMETHOD
   WMES = WBUTCOD-"Invalid button"
   ASTATUS = [V]CST_AERROR
   Gosub ERRORS
  Endif
Endcase

#------------------------------------------#
# JSON generation delta
#------------------------------------------#

ASND.DATA = ""
ASWK.NUMWRK += 1
Call DETAIL_JSON(REP,WREP,ASWK,PSYR,UPD,ASND.DATA) From ASYRDATDEL

#------------------------------------------#
# Prepare response (OK)
#------------------------------------------#
ASND.URL      = PSYR.PREFIX+'/'+PSYR.URLUPD+"('"+num$(ASWK.TRCKID)+"')"+PSYR.URLREP+ASWK.REPRES+".$edit"
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+ASWK.REPRES+".$edit"

End ASTATUS

#----------------------------------------------------------------------------------------------------#
# Disable buttons standard ($save, $abort & method) & choices of buttons ($detail, $query, etc.)
#----------------------------------------------------------------------------------------------------#

# Where is the link ?
#--------------------------
# 1 Property
# 2 Line de collection
# 3 Collection
# 4 Page
# 5 Fiche/Enregistrement

# Links Type
#----------------------------#
# 1 Link
# 2 Method
# 3 Operation
# 4 Link X3

$DISABLE_BUTTONS
UIDINS = evalue("WREP."+REP.ICL+".AUUID")
UIDPAR = NullUuid
WTIME  = datetime$
For I=1 To maxtab(REP.LNK)
 # Method or $links with action=save,abort
 If REP.LNK(I)<>null & find(REP.LNK(I).AFF,4,5) & REP.LNK(I).EDT=2
&                    & (REP.LNK(I).TYP=2 or (REP.LNK(I).TYP=1 & find(REP.LNK(I).CMP,17,18)))
  If REP.LNK(I).COD = "$abort" & instr(1,BUTTONS,REP.LNK(I).COD)
   If WBUTCOD=REP.LNK(I).COD
    # Message
    Call MAJ_ERROR(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,WMES,WTIME,ASTATUS,0) From ASYRDELSYS
   Endif
   # isRequested/false
   If WBUTCOD=REP.LNK(I).COD : #105185
    Call MAJ_ATTRIBUT(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("r"),func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
   Endif
   # isDisable/true
   Call MAJ_ATTRIBUT(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(2)) From ASYRDELSYS
   # links
   For J=1 To maxtab(REP.LNK(I).LNK)
    If REP.LNK(I).LNK(J)<>null
     If ASWK.REQUEST="CREATE" & find(REP.LNK(I).LNK(J).COD,"$create","$details")
      # isHidden/true
      Call MAJ_ATTRIBUTLNK(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,REP.LNK(I).LNK(J).COD,func ASYRSUB.CODATT("H")
&     ,func ASYRSUB.BOOLEAN_TO_SYR(2)) From ASYRDELSYS
      Endif
     Endif
    Next J
  Elsif REP.LNK(I).COD = "$save" & instr(1,BUTTONS,REP.LNK(I).COD)
   # isRequested/false
   If WBUTCOD=REP.LNK(I).COD : #105185
    Call MAJ_ATTRIBUT(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("r"),func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
   Endif
   If WBUTCOD=REP.LNK(I).COD
    # Message
    Call MAJ_ERROR(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,WMES,WTIME,ASTATUS,0) From ASYRDELSYS
   Endif
   # links
   For J=1 To maxtab(REP.LNK(I).LNK)
    If REP.LNK(I).LNK(J)<>null
     If ASWK.REQUEST<>"UPDATE" or REP.LNK(I).LNK(J).COD<>"$create"
      # isHidden/false
      Call MAJ_ATTRIBUTLNK(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,REP.LNK(I).LNK(J).COD,func ASYRSUB.CODATT("H")
&     ,func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
      Endif
     Endif
    Next J
    # isDisable/true
   Call MAJ_ATTRIBUT(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(2)) From ASYRDELSYS
   Elsif instr(1,BUTTONS,"*")
    # isRequested/false
    If WBUTCOD=REP.LNK(I).COD : #105185
     Call MAJ_ATTRIBUT(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("r"),func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
    Endif
    # isDisable/true
    Call MAJ_ATTRIBUT(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(2)) From ASYRDELSYS
  Endif
 Endif
Next I
Return

#-----------------------------------------------------------------------------#
# Enable buttons before sequence of edit (to do -> attribute button in class)
#-----------------------------------------------------------------------------#

$ENABLE_BUTTONS
UIDINS = evalue("WREP."+REP.ICL+".AUUID")
UIDPAR = NullUuid
WTIME  = datetime$
For I=1 To maxtab(REP.LNK)
 # Method or $links with action=save,abort
 If REP.LNK(I)<>null & find(REP.LNK(I).AFF,4,5) & REP.LNK(I).EDT=2
&                    & (REP.LNK(I).TYP=2 or (REP.LNK(I).TYP=1 & find(REP.LNK(I).CMP,17,18)))
  Case REP.LNK(I).COD
   When "$abort"
    # isDisable/false
    Call MAJ_ATTRIBUT(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
   When "$save"
    # links
    For J=1 To maxtab(REP.LNK(I).LNK)
     If REP.LNK(I).LNK(J)<>null
      If ASWK.REQUEST<>"UPDATE" or REP.LNK(I).LNK(J).COD<>"$create"
       # isHidden/true
       Call MAJ_ATTRIBUTLNK(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,REP.LNK(I).LNK(J).COD,func ASYRSUB.CODATT("H")
&     ,func ASYRSUB.BOOLEAN_TO_SYR(2)) From ASYRDELSYS
      Endif
     Endif
    Next J
    # isDisable/false
    Call MAJ_ATTRIBUT(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
   When Default
    # isDisable/false
    Call MAJ_ATTRIBUT(UPD,3,0,UIDPAR,UIDINS,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
  Endcase
 Endif
Next I
Return

#------------------------------------------#
# Error response
#------------------------------------------#

$ERRORS
# Message
Call MAJ_ERROR(UPD,3,0,UIDPAR,UIDINS,0,"","",WMES,WTIME,ASTATUS,0) From ASYRDELSYS
Return

#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

Subprog DECODE_PARAM(UPD,WBUTCOD,KEYS,MET_CODPAR,MET_VALPAR)
Variable Instance UPD(1..) Using C_ADELTA
Variable Char WBUTCOD, KEYS, MET_CODPAR()(1..), MET_VALPAR()(1..)
Local Integer I , J , K , P , C
Raz KEYS , C
For I=1 To maxtab(UPD)
 If UPD(I)<>null
  K = find(func ASYRSUB.CODATT("r"),UPD(I).ATT(1..maxtab(UPD(I).ATT)).COD)
  If K & UPD(I).ATT(K).ATT=func ASYRSUB.BOOLEAN_TO_SYR(2)
   WBUTCOD = UPD(I).PRO
   P = 0
   For J=1 To maxtab(UPD(I).ATT)
    If UPD(I).ATT(J)<>null
     If left$(UPD(I).ATT(J).COD,3)="key"
      If C<>0
       KEYS += "~"
      Endif
      C += 1
      KEYS += func SQUIZ_GUIL(UPD(I).ATT(J).ATT)
     Elsif left$(UPD(I).ATT(J).COD,1)<>"$"
      P += 1
      MET_CODPAR(P) = UPD(I).ATT(J).COD
      MET_VALPAR(P) = func SQUIZ_GUIL(UPD(I).ATT(J).ATT)
     Endif
    Endif
   Next J
   Break
  Endif
 Endif
Next I
End

#---------------------------#
Funprog SQUIZ_GUIL(CHR)
Value Char CHR
Local Char CHAINE(250)
CHAINE = CHR
If left$(CHAINE,1)='"'
 CHAINE = seg$(CHAINE,2,len(CHAINE)-1)
Endif
End CHAINE

#--------------------------------#
$TRACE_RECEIVE_DELTA
Call TRACE("asyredt-receive-delta"-"MAXTAB(upd)="+num$(maxtab(UPD))) From ASYRCOM

$TRACE
For I=1 To maxtab(UPD)
 WCHAINE = "col="+UPD(I).COL-"pro="+UPD(I).PRO-"ind="+num$(UPD(I).IND)-"cat="+num$(UPD(I).CAT)
 WCHAINE -= "uuid="+num$(UPD(I).UID)-"uuif="+num$(UPD(I).UIDPAR)
 If UPD(I).CHR<>null : WCHAINE -= "value="+func ASYRSUB.AGETCHR(UPD(I).CHR) : Endif
 Call TRACE(WCHAINE) From ASYRCOM
 For J=1 To maxtab(UPD(I).ATT)
  Call TRACE("att"-UPD(I).ATT(J).COD-"value="+UPD(I).ATT(J).ATT) From ASYRCOM
 Next J
 For J=1 To maxtab(UPD(I).ERR)
  Call TRACE("err"-UPD(I).ERR(J).MES-"sta="+num$(UPD(I).ERR(J).STA)-"num="+num$(UPD(I).ERR(J).NUM)) From ASYRCOM
 Next J
Next I
Call TRACE("end data") From ASYRCOM
Return

#-----------------------------------------------#
$TRACE_SEND_DELTA
Call TRACE("asyredt-send-delta"-"MAXTAB(upd)="+num$(maxtab(UPD))) From ASYRCOM
Gosub TRACE
Return

#--------------------------------#
$TRACE_ZQLFPROC04
Call TRACE("test zqlfproc04") From ASYRCOM
For I=1 To maxtab(WREP.ZQPC04.COL)
 If WREP.ZQPC04.COL(I)<>null
  Call TRACE("i="+num$(I)-"reg="+WREP.ZQPC04.COL(I).C04P02-"order="+num$(WREP.ZQPC04.COL(I).AORDER)
& -"sta="+num$(WREP.ZQPC04.COL(I).ASTALIN)-"uuid="+left$(num$(WREP.ZQPC04.COL(I).AUUID),10)) From ASYRCOM
 Endif
Next I
Return

#----------------------------#
$TRACE_TESTMB_TABCOUNTRY
Call TRACE("test tableau region") From ASYRCOM
For I=1 To maxtab(WREP.REGION_MUL)
 If WREP.REGION_MUL(I)<>null
  Call TRACE("i="+num$(I)-"reg="+WREP.REGION_MUL(I).REG_REG-"nam="+WREP.REGION_MUL(I).REG_NAM-"order="+num$(WREP.REGION_MUL(I).AORDER)
& -"sta="+num$(WREP.REGION_MUL(I).ASTALIN)-"uuid="+left$(num$(WREP.REGION_MUL(I).AUUID),10)) From ASYRCOM
 Endif
Next I
Call TRACE("test tableau devise") From ASYRCOM
For I=1 To maxtab(WREP.DEVISE_UN)
 If WREP.DEVISE_UN(I)<>null
  Call TRACE("i="+num$(I)-"reg="+WREP.DEVISE_UN(I).DEV_DEV-"order="+num$(WREP.DEVISE_UN(I).AORDER)
& -"sta="+num$(WREP.DEVISE_UN(I).ASTALIN)-"uuid="+left$(num$(WREP.DEVISE_UN(I).AUUID),10)) From ASYRCOM
  For J=1 To maxtab(WREP.DEVISE_UN(I).AERROR)
   If WREP.DEVISE_UN(I).AERROR(J)<>null
    Call TRACE(" j="+num$(J)-"sta="+num$(WREP.DEVISE_UN(I).AERROR(J).STA)-"mes="+WREP.DEVISE_UN(I).AERROR(J).MES
& -"pro="+WREP.DEVISE_UN(I).AERROR(J).PRO-"del="+num$(WREP.DEVISE_UN(I).AERROR(J).DEL)) From ASYRCOM
   Endif
  Next J
 Endif
Next I
Call TRACE("test tableau adrnam") From ASYRCOM
For I=1 To maxtab(WREP.TCY.ADDRESS)
 If WREP.TCY.ADDRESS(I)<>null
  Call TRACE("i="+num$(I)-"adrnam="+WREP.TCY.ADDRESS(I).ADRNAM-"order="+num$(WREP.TCY.ADDRESS(I).AORDER)
& -"sta="+num$(WREP.TCY.ADDRESS(I).ASTALIN)-"uuid="+left$(num$(WREP.TCY.ADDRESS(I).AUUID),10)) From ASYRCOM
 Endif
Next I
Call TRACE("test tableau module") From ASYRCOM
For I=1 To maxtab(WREP.MODULE_UN)
 If WREP.MODULE_UN(I)<>null
  Call TRACE("i="+num$(I)-"module="+num$(WREP.MODULE_UN(I).MOD_MOD)-"order="+num$(WREP.MODULE_UN(I).AORDER)
& -"sta="+num$(WREP.MODULE_UN(I).ASTALIN)-"uuid="+left$(num$(WREP.MODULE_UN(I).AUUID),10)) From ASYRCOM
 Endif
Next I
Call TRACE("test tableau postaux") From ASYRCOM
For I=1 To maxtab(WREP.POSTAUX_MUL)
 If WREP.POSTAUX_MUL(I)<>null
  Call TRACE("i="+num$(I)-"codepostal="+num$(WREP.POSTAUX_MUL(I).POS_CODE)-"order="+num$(WREP.POSTAUX_MUL(I).AORDER)
& -"sta="+num$(WREP.POSTAUX_MUL(I).ASTALIN)-"uuid="+left$(num$(WREP.POSTAUX_MUL(I).AUUID),10)) From ASYRCOM
 Endif
Next I
If WREP.TCY<>null
 Call TRACE("Etatflg="+num$(WREP.TCY.ETATFLG)-"Etatflg2="+num$(WREP.TCY.ETATFLG2)-"Etat="+num$(WREP.TCY.ETAT)) From ASYRCOM
Endif
Return

#----------------------------#
$TRACE_TESTMB_ATABLE
Call TRACE("test tableau zones") From ASYRCOM
For I=1 To maxtab(WREP.ATB.ATZ)
 If WREP.ATB.ATZ(I)<>null
  Call TRACE("i="+num$(I)-"zon="+WREP.ATB.ATZ(I).CODZONE-"typ="+WREP.ATB.ATZ(I).CODTYP-"order="+num$(WREP.ATB.ATZ(I).AORDER)
& -"sta="+num$(WREP.ATB.ATZ(I).ASTALIN)) From ASYRCOM
  For J=1 To maxtab(WREP.ATB.ATZ(I).AMP)
   Call TRACE("  j="+num$(J)-"codpar="+WREP.ATB.ATZ(I).AMP(J).CODPAR-"valpar="+WREP.ATB.ATZ(I).AMP(J).VALPAR) From ASYRCOM
  Next J
 Endif
Next I
Return

#----------------------------#
$TRACE_TESTMB_YITEMX
Call TRACE("test tableau analytique") From ASYRCOM
If maxtab(WREP.YIX.YIXB)>0
 For I=1 To maxtab(WREP.YIX.YIXB.CDIE)
  If WREP.YIX.YIXB.CDIE(I)<>null
   Call TRACE("i="+num$(I)-"die="+WREP.YIX.YIXB.CDIE(I).DIE-"cce="+WREP.YIX.YIXB.CDIE(I).CCE-"order="+num$(WREP.YIX.YIXB.CDIE(I).AORDER)
& -"sta="+num$(WREP.YIX.YIXB.CDIE(I).ASTALIN)) From ASYRCOM
  Endif
 Next I
Endif
Return
