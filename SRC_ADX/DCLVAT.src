#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DCLVAT","DDCLVAT",4,"") From GTRAITE
End
 

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Raz [M:DIA]INI : Affzo [DIA]
Endcase
Return

 
$OUVRE 
Gosub OUVFIC

Local Char    TIT(30)
Local Char    OPT(1)              : # "1":on prend la date comptable "2":date document origine 
Local Char    OPTPAY(1)           : # Option => "1":TVA/d횄짤bits d'abord "2":Prorata
Local Char    TTYPDEB(GLONGTE)(1..100) : # Table types pi횄짢ces 횄  prendre en cpte pour d횄짤cl TVA/d횄짤bits 
Local Char    TTAX(GLONVAT)(1..100)     : # Table des codes taxes qui sont dues sur les d횄짤bits 
Local Char    TTYPPAY(GLONGTE)(1..100) : # Table types pi횄짢ces 횄  prendre en cpte pour d횄짤cl TVA/encaiss.  
Local Char    TCPTACPT(GLONGAC)(1..100): # Table des comptes d'acomptes (pour la TVA/encaissements) 
Local Char    SYMBOLE(30)         : # Pour lock...
Local Char    NUMIMP(8)           : # Num횄짤ro requ횄짧te
Local Char    COMPTEUR1(3)        : # Compteur utilis횄짤 pour g횄짤rer le no requ횄짧te pour TVA/d횄짤bits
Local Char    COMPTEUR2(3)        : # Compteur utilis횄짤 pour g횄짤rer le no requ횄짧te pour TVA/encaiss.
Local Char    CRITERE(250)        : # Variable disponible dans le point d'entr횄짤e FILTRE

Local Integer NBTYPDEB            : # Nombre de types de pi횄짢ces 
Local Integer NBTAX               : # Nombre de codes taxes dues sur les d횄짤bits
Local Integer NBTYPPAY            : # Nombre de types de pi횄짢ce 
Local Integer NBCPTACPT           : # Nombre de comptes d'acomptes
Local Integer DCLVAT              : # Si 1, la d횄짤cl. TVA/d횄짤bits a d횄짤j횄  횄짤t횄짤 effectu횄짤e pour la soci횄짤t횄짤
Local Integer DCLVATPAY           : # Si 1, la d횄짤cl. TVA/enc. a d횄짤j횄  횄짤t횄짤 effectu횄짤e pour la soci횄짤t횄짤
Local Integer OK, STAT            : # Variables diverses
Local Integer IMPUTACPT           : # Si vaut 1, on est sur pi횄짢ce d'imputation d'acompte (TVA/encais.)

Global Integer GNUMRPT            : # Num횄짤ro de requ횄짧te pour impression d횄짤claration TVA/d횄짤bits 
Global Integer GNUMRPT2           : # Num횄짤ro de requ횄짧te pour impression d횄짤claration TVA/encaissements

TIT = mess(71,107,1) : # D횄짤claration de TVA 

Local Mask DCLVAT [DIA]   
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","cpa") From GMEMO
Return


######################################################
## Ouverture des tables
######################################################
$OUVFIC
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif : # Soci횄짤t횄짤s
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif : # Sites
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif : # Comptes 
If clalev([F:DLV])=0 : Local File DCLVAT     [DLV] : Endif : # D횄짤claration de TVA sur d횄짤bits 
If clalev([F:DVP])=0 : Local File DCLVATPAY  [DVP] : Endif : # Fichier temp. pour d횄짤cl. TVA/enc 
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif : # Valeur des param횄짢tres
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif : # Types de pi횄짢ces
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif : # Codes taxes    
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif : # Table des devises 
Return


#######################################################
## Contr횄쨈le des param횄짢tres
#######################################################
$CONTROLE
If GOK<1
 FIN = 1 : Return
Endif
SYMBOLE = "DCLVAT"
Lock =SYMBOLE With lockwait=0
If fstat
 # Op횄짤ration en cours sur autre poste
 Call ERREUR(mess(30,100,1)) From GESECRAN
 GERR = 2 : FIN = 1 : Return
Endif
Gosub LECPARAM
If !OK
 GERR = 2 : SAI = 1 : Return
Endif
TMP = 1
Return

$LECPARAM
OK = 1
If [M:DIA]VAT = 2 : # On a demand횄짤 la TVA sur d횄짤bits
 # Table des types de pi횄짢ces qui doivent 횄짧tre pris en compte pour 
 # la d횄짤claration de TVA sur d횄짤bits 
 Raz NBTYPDEB, TTYPDEB 
 For [GTE]GTE0 Where VAT = 2 
  NBTYPDEB += 1 
  TTYPDEB(NBTYPDEB) = [F:GTE]TYP 
 Next 
 # Table des taxes qui sont dues sur les d횄짤bits 
 Raz NBTAX, TTAX 
 For [TVT]TVT0 Where VATPAY = 1 
  NBTAX += 1 
  TTAX(NBTAX) = [F:TVT]VAT 
 Next
 COMPTEUR1 = ""
 Call LECTURE("TCA","2","") From CONTOBJ
 If !fstat : COMPTEUR1 = [F:TCA]CODNUM(3) : Endif
 If COMPTEUR1="" : COMPTEUR1 = "DLV" : Endif
 Call NUMERO(COMPTEUR1,"",[0/0/0],"",NUMIMP,STAT) From SUBANM
 If STAT
  # Probl횄짢me lors de la r횄짤cup횄짤ration du compteur
  MESSA = COMPTEUR1
  OK = 0 : Call ERREUR(mess(60,199,1)-MESSA) From GESECRAN
 Endif
 GNUMRPT = val(NUMIMP)
Endif
If dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY = 2 : # On a demand횄짤 la TVA sur encaissements
 # Table des types de pi횄짢ces qui doivent 횄짧tre pris en compte pour  
 # la d횄짤claration de TVA sur encaissements  
 Raz NBTYPPAY, TTYPPAY  
 For [GTE]GTE0 Where VATPAI = 2  
  NBTYPPAY += 1  
  TTYPPAY(NBTYPPAY) = [F:GTE]TYP  
 Next
 Raz NBCPTACPT, TCPTACPT
 # Table des comptes d'acomptes (pour exclure les comptes d'acomptes
 # dans la TVA/encaissements)
 Raz NBCPTACPT, TCPTACPT
 For [GAC]GAC0 Where FLGVAT = 5
  NBCPTACPT += 1
  TCPTACPT(NBCPTACPT) = [F:GAC]ACC
 Next 
 COMPTEUR2 = ""
 Call LECTURE("TCA","2","") From CONTOBJ
 If !fstat : COMPTEUR2 = [F:TCA]CODNUM(4) : Endif
 If COMPTEUR2 = "" : COMPTEUR2 = "DVP" : Endif
 Call NUMERO(COMPTEUR2,"",[0/0/0],"",NUMIMP,STAT) From SUBANM
 If STAT
  # Probl횄짢me lors de la r횄짤cup횄짤ration du compteur
  MESSA = COMPTEUR2
  OK = 0 : Call ERREUR(mess(60,199,1)-MESSA) From GESECRAN
 Endif
 GNUMRPT2 = val(NUMIMP)
Endif
Return


#######################################################
## Ex횄짤cution silencieuse du traitement
#######################################################
$EXEC
If GSERVEUR 
 [M:DIA]TRACE = 2 
Endif
 
If !GSERVEUR & dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY=2 & [M:DIA]TRACE=2
 # Le fichier de trace a 횄짤t횄짤 fait pour la TVA/encaissements
 Call OUVRE_TRACE(TIT) From LECFIC
 Call ECR_TRACE(mess(89,107,1)+","-mess(38,114,1)-":"-num$(GNUMRPT2)+","
&              -mess(4,95,1)-tolower(mess(29,114,1))-":"-GTRACE,0) From GESECRAN
 Call ECR_TRACE(string$(120,"-"),0) From GESECRAN
Endif

Gosub DECLARATION
If !GSERVEUR & dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY=2 & [M:DIA]TRACE=2
 Call FERME_TRACE From LECFIC
Endif
Return


#######################################################
## Traitement de fin (lecture trace 횄짤ventuelle)
#######################################################
$FIN
## Demande 48603
#If [M:DIA]VAT = 2
# [M:DIA]NUMRPT = GNUMRPT
# Call IMPRIME("DCLVATDEB1","DCLVAT") From ETAT 
#Endif
#If dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY = 2
# [M:DIA]NUMRPT2 = GNUMRPT2
# Call IMPRIME("DCLVATENC1","DCLVAT") From ETAT
#Endif
Local Char ETAT_DEB(GLONACR)
Local Char ETAT_ENC(GLONACR)
ETAT_DEB = "DCLVATDEB1"
ETAT_ENC = "DCLVATENC1"
GPOINT = "NOM_ETAT" : Gosub ENTREE From EXEFNC
If [M:DIA]VAT = 2
 [M:DIA]NUMRPT = GNUMRPT
 Call IMPRIME([L]ETAT_DEB,"DCLVAT") From ETAT 
Endif
If dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY = 2
 [M:DIA]NUMRPT2 = GNUMRPT2
 Call IMPRIME([L]ETAT_ENC,"DCLVAT") From ETAT
Endif
## <Fin demande 48603>

Unlock =SYMBOLE
If !GSERVEUR & dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY=2 & [M:DIA]TRACE=2 
 TRA = 1
Else
 TRA = 0
Endif
Return


########################################################

$DECLARATION
GOK = 1
For [CPY]CPY0 Where ([M:DIA]ALLCPY=2 | CPY=[M:DIA]CPY) & CPYLEGFLG=2
 Call LECTURE("TCU",[F:CPY]ACCCUR,"") From CONTOBJ
 GARODEV = [F:TCU]CURRND
 Call PARAM([F:CPY]CPY,"DCLVATDAT",OPT) From ADOVAL

 # Point d'entr횄짤e FILTRE
 Raz [L]CRITERE
 GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
 If [L]CRITERE="" : [L]CRITERE="1=1" : Endif

 ###DBA le 24/07/03 : Sugg 11462 
 If [M:DIA]FCY<>"" : [L]CRITERE-='& [F:FCY]FCY = "'+[M:DIA]FCY+'"' : Endif

 For [FCY]FCY0 Where LEGCPY=[F:CPY]CPY & FINFLG=2 & evalue(CRITERE)
  If [M:DIA]VAT = 2 : # On a demand횄짤 la TVA sur d횄짤bits
   If !DCLVAT & NBTAX>0
    Call DCLVATDEB([F:CPY]CPY,[F:FCY]FCY,[M:DIA]STRDAT,[M:DIA]ENDDAT,[M:DIA]SIM,OPT,
&                  TTYPDEB,NBTYPDEB,TTAX,NBTAX)
   Else
    DCLVAT=0 : Break : # On change de soci횄짤t횄짤
   Endif
  Endif
  If GOK<1 : Break 2 : Endif
  If dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY = 2 : # On a demand횄짤 la TVA sur encaissements
   Call PARAM("","DCLOPTPAY",OPTPAY) From ADOVAL
   If !DCLVATPAY
    Call DCLVATPAY([F:CPY]CPY,[F:FCY]FCY,[M:DIA]STRDAT2,[M:DIA]ENDDAT2,[M:DIA]SIM,
&                  OPTPAY,TTYPPAY,NBTYPPAY,TCPTACPT,NBCPTACPT) 
   Else
    DCLVATPAY=0 : Break : # On change de soci횄짤t횄짤
   Endif
  Endif
  If GOK<1 : Break 2 : Endif
 Next
Next
If GOK<1 : Return : Endif

# S'il n'y a pas de TVA/d횄짤bits et/ou TVA/encaissements 횄  d횄짤clarer, on cr횄짤e
# quand m횄짧me un enregistrement dans les fichiers temporaires afin de pouvoir
# afficher les crit횄짢res s횄짤lectionn횄짤s (notamment dans une r횄짤impression)
If [M:DIA]VAT = 2
 Filter [DLV] Where NUMRPT = GNUMRPT
 Look [DLV]DLV0 First
 If fstat
  Call DEBTRANS From GLOCK
  Gosub TR_DLV0
  If GOK<1 : Return : Endif
 Endif
 Filter [DLV]
Endif
If dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY = 2
 Filter [DVP] Where NUMRPT = GNUMRPT2
 Look [DVP]DVP0 First
 If fstat
  Call DEBTRANS From GLOCK
  Gosub TR_DVP0
  If GOK<1 : Return : Endif
 Endif
 Filter [DVP]
Endif
Return

$TR_DLV0
Trbegin [DLV]
 Raz [F:DLV]
 [F:DLV]CPY = [M:DIA]CPY
 [F:DLV]STRDAT = [M:DIA]STRDAT
 [F:DLV]ENDDAT = [M:DIA]ENDDAT
 [F:DLV]SIM    = [M:DIA]SIM
 [F:DLV]OPTDAT = val(OPT)
 [F:DLV]NUMRPT = GNUMRPT
 Write [DLV]
 If fstat
  GOK=0 : Call FSTA("DLV") From GLOCK 
 Endif
 If GOK<0   : Goto ROLL_TR_DLV0 
 Elsif !GOK : Goto AB_TR_DLV0   
 Endif
Commit 
Return

$AB_TR_DLV0 
Rollback 
Return 
 
$ROLL_TR_DLV0 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_DLV0 : Endif 
  

$TR_DVP0
Trbegin [DVP]
 # On cr횄짤e cet enregistrement juste pour stocker les crit횄짢res s횄짤lectionn횄짤s 
 # dans le cas o횄쨔 il n'y a pas de TVA/encaissements 횄  d횄짤clarer (notamment dans le cas
 # d'une r횄짤impression)
 Raz [F:DVP]
 [F:DVP]CPY    = [M:DIA]CPY
 [F:DVP]STRDAT = [M:DIA]STRDAT2
 [F:DVP]ENDDAT = [M:DIA]ENDDAT2
 [F:DVP]DATMAX = [M:DIA]DATPCE
 [F:DVP]SIM    = [M:DIA]SIM
 [F:DVP]OPT    = val(OPTPAY)
 [F:DVP]NUMRPT = GNUMRPT2
 [F:DVP]TYPREC = 0
 Gosub POINT_ENTREE
 Write [DVP]
 If fstat
  GOK=0 : Call FSTA("DVP") From GLOCK 
 Endif
 If GOK<0   : Goto ROLL_TR_DVP0 
 Elsif !GOK : Goto AB_TR_DVP0   
 Endif
Commit
Return

$AB_TR_DVP0 
Rollback 
Return 
 
$ROLL_TR_DVP0 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_DVP0 : Endif 


########################### 
#  TVA SUR DEBITS         # 
########################### 
Subprog DCLVATDEB(SOC,SIT,DATDEB,DATFIN,SIMUL,OPT,TTYP,NBTYP,TTAX,NBTAX) 
Value Char    SOC()       : # Soci횄짤t횄짤 pour laquelle on fait la d횄짤claration de TVA 
Value Char    SIT()       : # Site pour lequel on fait la d횄짤claration 
Value Date    DATDEB      : # Date d횄짤but de la d횄짤claration de TVA 
Value Date    DATFIN      : # Date fin de la d횄짤claration de TVA
Value Integer SIMUL       : # Si <>2, on lance la d횄짤claration en r횄짤el (MAJ du montant TVA d횄짤clar횄짤e)
Value Char    OPT()       : # "1":on prend la date comptable "2":date document origine 
Value Char    TTYP()(1..) : # Table types pi횄짢ces 횄  prendre en cpte pour d횄짤cl TVA/d횄짤bits 
Value Integer NBTYP       : # Nombre de types de pi횄짢ces 
Value Char    TTAX()(1..) : # Table des codes taxes qui sont dues sur les d횄짤bits 
Value Integer NBTAX       : # Nombre de codes taxes dues sur les d횄짤bits
 
# NB : En France, la d횄짤claration de TVA se fait tous les mois. Par contre, 
# dans d'autres pays la p횄짤riodicit횄짤 n'est pas la m횄짧me : en Espagne, il y a une 
# d횄짤claration trimestrielle. 
# C'est pourquoi, on ne raisonne pas sur une p횄짤riode ou sur un mois mais 
# sur une date de d횄짤but et une date de fin de d횄짤claration.  
 
Local Integer SIGN               : # Signe 
Local Integer IND, I             : # Variables diverses 
Local Decimal TMONTANT(1..NBTAX) : # Table des montants de TVA par code taxe
Local Decimal TMONTRAT(1..NBTAX) : # Table des montants soumis 횄  la TVA par code taxe
Local Decimal MTTTC, MTTVA, VTRAT

If clalev([F:DLV])=0  : Local File DCLVAT     [DLV]  : Endif : # D횄짤claration de TVA sur d횄짤bits 
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif : # En-t횄짧te des pi횄짢ces comptables
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif : # Lignes des pi횄짢ces comptables
If clalev([F:DAE3])=0 : Local File GACCENTRYD [DAE3] : Endif : # Lignes des pi횄짢ces comptables 
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif : # Comptes 
If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif : # Comptes  
If clalev([F:TRA])=0  : Local File TABRATVAT  [TRA]  : Endif : # Taux de taxes 

# JFL - 19/04/07 - demande de point d'entr횄짤e 41014 - filtre sur les d횄짤bits (table d'ent횄짧te des pi횄짢ces)
Local Char CRITDEB(250)
# JFL - 04/10/07 - demande 43381 - ajout de la variable CRITDEB2 dans le cas o횄쨔 OPT=2 (filtre sur les lignes de pi횄짢ces)
Local Char CRITDEB2(250)

GPOINT = "FILTREDEB" : Gosub ENTREE From EXEFNC
If CRITDEB  = ""  : CRITDEB  = "1=1" : Endif
If CRITDEB2 = ""  : CRITDEB2 = "1=1" : Endif

If OPT = "1"  
 Filter [DAE] Where CPY=SOC & FCYLIN=SIT & find(TYP,TTYP(1..NBTYP))
&                 & ACCDAT>=DATDEB & ACCDAT<=DATFIN & evalue(CRITDEB2)
Else
 Filter [HAE] Where CPY=SOC & find(TYP,TTYP(1..NBTYP)) & (CAT=1)
&                 & ((BPRDATVCR>=DATDEB & BPRDATVCR<=DATFIN) | BPRDATVCR=[0/0/0]) & evalue(CRITDEB)
Endif 

Call DEBTRANS From GLOCK
Gosub TR_DELDLV 
If GOK<1
 End
Endif
Gosub TR_DLV 
End 

$TR_DLV 
Trbegin [DLV], [HAE], [DAE] 
 # On parcourt les comptes de TVA et ceux soumis 횄  la TVA
 For [GAC]GAC0 Where FLGVAT>1 & FLGVAT<=5 
  # On parcourt les lignes d'횄짤critures qui mouvementent le compte  
  # de TVA ou soumis 횄  la TVA 
  Raz TMONTANT, TMONTRAT
  If OPT = "1" 
   For [DAE]DAE1 Where ACC=[F:GAC]ACC & AMTVAT=0
    Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
    If [F:HAE]CAT=1
     TVADEC = 0
     Gosub MONTANT
     If GOK<1 : Break 2 : Endif
    Endif
   Next 
  Elsif OPT = "2"
   For [HAE]HAE0 With Nohint
    # Si la date de document d'origine est vide, c'est la date de pi횄짢ce qui est retenue
# JFL - 04/10/2007 - demande 43381 - ajout de la variable CRITDEB2
    For [DAE]DAE0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & ACC=[F:GAC]ACC & FCYLIN=SIT & AMTVAT=0
&                     & ([F:HAE]BPRDATVCR<>[0/0/0] | (ACCDAT>=DATDEB & ACCDAT<=DATFIN)) & evalue(CRITDEB2)
     Gosub MONTANT
     If GOK<1 : Break 3 : Endif
    Next 
   Next 
  Endif 
  For I=1 To NBTAX
   If TMONTANT(I)<>0 
    [F:DLV]CPY = SOC 
    [F:DLV]FCY = SIT 
    [F:DLV]STRDAT = DATDEB 
    [F:DLV]ENDDAT = DATFIN
    [F:DLV]SIM = SIMUL
    [F:DLV]ACC = [F:GAC]ACC 
    [F:DLV]VAT = TTAX(I)
    Case [F:GAC]FLGVAT 
     When 2, 5 : [F:DLV]TYPAMT = 1 : # Compte soumis 횄  TVA (base) 
     When 3, 4 : [F:DLV]TYPAMT = 2 : # Compte de TVA (montant) 
    Endcase  
    [F:DLV]FLGVAT = [F:GAC]FLGVAT 
    [F:DLV]VATIPT = [F:GAC]VATIPT 
    [F:DLV]AMT    = TMONTANT(I)
    [F:DLV]AMTTAX = TMONTRAT(I)
    [F:DLV]OPTDAT = val(OPT)
    [F:DLV]NUMRPT = GNUMRPT
    Write [DLV] 
    If fstat  
     GOK=0 : Call FSTA("DLV") From GLOCK : Break  
    Endif  
   Endif 
  Next
 Next
 If GOK<0   : Goto ROLL_TR_DLV 
 Elsif !GOK : Goto AB_TR_DLV   
 Endif
Commit 
End 

$AB_TR_DLV 
Rollback  
Return  
  
$ROLL_TR_DLV  
Rollback  
Call ROLL From GLOCK  
If GROLL : Return : Else : Goto TR_DLV : Endif  

$LECTAXD
VTRAT=99
Call LECTURE("TVT",[F:DAE]TAX,"") From CONTOBJ
Filter [TRA] Where VAT=[F:DAE]TAX & CPY=SOC & STRDAT<=[F:DAE]ACCDAT 
Read [TRA]TRA0 Last
If !fstat
 If [F:TRA]VATRAT*[F:TRA]DEDRAT=0 : VTRAT=0 : Endif
Else  
 Filter [TRA] Where VAT=[F:DAE]TAX & CPY="" & STRDAT<=[F:DAE]ACCDAT
 Read [TRA]TRA0 Last
 If !fstat
  If [F:TRA]VATRAT*[F:TRA]DEDRAT=0 : VTRAT=0 : Endif
 Endif 
Endif
Filter [TRA]
Return

$MONTANT 
# S'il y a un code taxe associ횄짤 횄  la ligne d'횄짤criture et que  
# cette taxe est due sur les d횄짤bits, on doit prendre en compte  
# la base TVA ou le montant de TVA
Gosub LECTAXD
If [F:GAC]FLGVAT<>5
 IND = find([F:DAE]TAX,TTAX(1..NBTAX))
 If IND 
  If [F:GAC]VATIPT <= 2 : # TVA collect횄짤e ventes ou collect횄짤e immos  
   SIGN=-1  
  Else  
   SIGN=1 : # TVA d횄짤ductible sur achats ou immos
  Endif
  # Pour la V130...
  Gosub MAJ_NUMDCL
  If GOK<1 : Return : Endif
  TMONTANT(IND) += SIGN*[F:DAE]SNS*[F:DAE]AMTLOC : # Compte soumis 횄  la TVA
  If VTRAT<>0 
   TMONTRAT(IND) += SIGN*[F:DAE]SNS*[F:DAE]AMTLOC
  Endif
  If SIMUL=1
   # On lance la d횄짤claration de TVA sur d횄짤bits en r횄짤el. On va donc
   # mettre 횄  jour le montant de TVA d횄짤clar횄짤e dans la ligne d'횄짤criture
   # (GACCENTRYD).
   Gosub MAJ_AMTVAT
   If GOK<1 : Return : Endif
  Endif
 Endif

## On traite les comptes d'acompte associ횄짤s 횄  un code taxe TVA/d횄짤bits : Demande 26642
Elsif [F:GAC]FLGVAT=5 : # Compte d'acompte
 IND = find([F:DAE]TAX,TTAX(1..NBTAX))
 If IND 
  If [F:GAC]VATIPT <= 2 : # TVA collect횄짤e ventes ou collect횄짤e immos  
   SIGN=-1  
  Else  
   SIGN=1 : # TVA d횄짤ductible sur achats ou immos
  Endif
  Raz MTTTC, MTTVA
  For [DAE3]DAE0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & AMTVAT=0
   If [DAE3]ACC=[F:GAC]ACC
    MTTTC += [F:DAE3]AMTLOC*[F:DAE3]SNS*SIGN
    If SIMUL = 1
     # On lance la d횄짤claration de TVA sur d횄짤bits en r횄짤el. On va donc
     # mettre 횄  jour le montant de TVA d횄짤clar횄짤e dans la ligne d'횄짤criture
     # (GACCENTRYD).
     Gosub MAJ_AMTVAT
     If GOK<1 : Return : Endif
    Endif
   Elsif [F:DAE3]TAX<>"" & [F:DAE3]AMTVAT=0
    Read [F:GAC2]GAC0 = [F:DAE3]ACC
    If !fstat & find([F:GAC2]FLGVAT,3,4) : # C'est un compte de TVA
     Call LECTURE("TVT",[F:DAE3]TAX,"") From CONTOBJ 
     If [F:TVT]VATPAY = 1 : # Taxe due sur les d횄짤bits
      If [F:GAC]VATIPT=1 | [F:GAC]VATIPT=2
       SIGN=-1
      Else
       SIGN=1
      Endif
      MTTVA += [F:DAE3]AMTLOC*[F:DAE3]SNS*SIGN
      ## On ne met pas 횄  jour le compte de TVA, c'est fait dans le parcours des comptes de TVA
     Endif
    Endif
   Endif
  Next
  If MTTVA<>0
   TMONTANT(IND) += MTTTC-MTTVA
   If VTRAT<>0 
    TMONTRAT(IND) += MTTTC-MTTVA
   Endif
   # Pour la V130...
   Gosub MAJ_NUMDCL
   If GOK<1 : Return : Endif  
  Endif
 Endif  
Endif 
Return

$MAJ_NUMDCL
If [F:HAE]NUMDCL<>GNUMRPT
 # on met 횄  jour le no de d횄짤claration dans l'en-t횄짧te de pi횄짢ce (on regarde si la MAJ
 # n'a pas 횄짤t횄짤 d횄짤j횄  faite en traitant une autre ligne de la pi횄짢ce)
 [F:HAE]NUMDCL = GNUMRPT
 Rewrite [HAE]
 If fstat
  GOK=0 : Call FSTA("HAE") From GLOCK
 Endif
Endif
Return

$MAJ_AMTVAT
If find([F:GAC]FLGVAT,2,3,4,5) : # Compte soumis 횄  TVA et compte de TVA et compte d'acompte ## <PP XXX>    
 [F:DAE]AMTVAT = SIGN*[F:DAE]SNS*[F:DAE]AMTLOC
 Rewrite [DAE]
 If fstat
  GOK=0 : Call FSTA("DAE") From GLOCK
 Endif
Endif
Return

# On commence par effacer les simulations...
$TR_DELDLV
GOK = 1 
Trbegin [DLV] 
 Delete [DLV] Where CPY=SOC & FCY=SIT & SIM=2 
 If fstat=1 | fstat>5 
  GOK=0 : Call RSTA("DLV",SOC-SIT) From GLOCK : Goto AB_TR_DELDLV 
 Endif 
 If   GOK<0 : Goto ROLL_TR_DELDLV 
 Elsif !GOK : Goto AB_TR_DELDLV 
 Endif 
Commit 
Return 
 
$AB_TR_DELDLV 
Rollback 
Return 
 
$ROLL_TR_DELDLV 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_DELDLV : Endif 
  


########################### 
#  TVA SUR ENCAISSEMENTS  # 
########################### 
#####################################################################
# Notes diverses :
# 1횂째) On met 횄  jour les montants d횄짤clar횄짤s ([DAE]AMTVAT) pour :
#    - Les comptes de TVA sur encaissements
#    - Les comptes soumis 횄  TVA sur encaissements
# 2횂째) Si une ligne d'횄짤criture ne contient pas de code taxe
# on consid횄짢re le compte comme non soumis.
# Il existe obligatoirement au moins un code taxe 'exon횄짤r횄짤' dans
# le param횄짤trage de codes de taxes. Une ligne peut contenir un
# compte de type 'soumis 횄  TVA' alors qu'il n'y a pas de code taxe
# associ횄짤. Dans ce cas, il ne faut pas la prendre en compte
#######################################################################

#############################################################################################
# Contraintes (r횄짢gles de gestion)
# 1횂째) Les comptes doivent 횄짧tre correctement param횄짤tr횄짤s en ce qui concerne les zones 'Gestion
# de TVA' (soumis, non soumis, compte de TVA) et 'Imputation taxe' (collect횄짤e ventes,
# collect횄짤e immos, d횄짤ductible achats, d횄짤ductible immos)
# 2횂째) Les types de pi횄짢ces "d횄짤clenchants" (r횄짢glements) doivent 횄짧tre correctement
# param횄짤tr횄짤s dans le param횄짤trage des types de pi횄짢ces
# 3횂째) La pi횄짢ce 횄  utiliser pour le versement ou la r횄짤ception d'un acompte  
# peut 횄짧tre non d횄짤clenchante ou d횄짤clenchante
# 4횂째) La pi횄짢ce 횄  utiliser pour l'imputation de l'acompte sur la facture doit 횄짧tre 
# d횄짤clenchante
# 5횂째) Dans le cas d'un versement ou de la r횄짤ception d'un acompte relatif 횄  une
# prestation de service, le compte de TVA 횄  r횄짤gulariser doit 횄짧tre param횄짤tr횄짤 comme
# compte non soumis
# 6횂째) Dans le cas o횄쨔 les pi횄짢ces ne sont pas g횄짤n횄짤r횄짤es automatiquement mais saisies
# diretement en comptabilit횄짤, les codes taxes au niveau des lignes d'횄짤critures
# doivent 횄짧tre correctement renseign횄짤s et le lettrage des 횄짤critures doit 횄짧tre correct
#######################################################################################

########################### 
#  TVA SUR ENCAISSEMENTS  # 
########################### 
Subprog DCLVATPAY(SOC,SIT,DATDEB,DATFIN,SIMUL,OPTPAY,TTYP,NBTYP,TACPT,NBACPT)  
Value Char    SOC()       : # Soci횄짤t횄짤 pour laquelle on fait la d횄짤claration de TVA  
Value Char    SIT()       : # Site pour lequel on fait la d횄짤claration  
Value Date    DATDEB      : # Date d횄짤but exploration pi횄짢ces
Value Date    DATFIN      : # Date fin exploration pi횄짢ces
Value Integer SIMUL       : # Si <>2, on lance la d횄짤claration en r횄짤el (MAJ du montant TVA d횄짤clar횄짤e)
Value Char    OPTPAY      : # Option => 1:TVA/d횄짤bits pay횄짤e d'abord  2:Prorata
Value Char    TTYP()(1..) : # Table types pi횄짢ces 횄  prendre en cpte pour d횄짤cl TVA/encaiss.  
Value Integer NBTYP       : # Nombre de types de pi횄짢ces
Value Char    TACPT()(1..): # Table des comptes d'acomptes
Value Integer NBACPT      : # Nombre de comptes d'acomptes

Local Integer NBMAXCODDEB : # Nombre de codes taxes TVA/d횄짤bits param횄짤tr횄짤s * 2
Local Integer NBMAXCODENC : # Nombre de codes taxes TVA/encaissements param횄짤tr횄짤s * 2

Local Integer NB_CODDEB : # Nombre de codes taxes TVA/d횄짤bits param횄짤tr횄짤s
Local Integer NB_CODENC : # Nombre de codes taxes TVA/encaissements param횄짤tr횄짤s


NBMAXCODDEB = 0 : NB_CODDEB = 0
NBMAXCODENC = 0 : NB_CODENC = 0
For [TVT]TVT0
 If [F:TVT]VATPAY = 1
  NBMAXCODDEB += 2
  NB_CODDEB += 1
 Else
  NBMAXCODENC += 2
  # +=2 car cette variable va nous servir 횄  dimensionner les tableaux tels que BASENC, TVAENC, ...
  # et ces tableaux contiennent les montants d'un groupe de lettrage par CATCOD (code taxe/
  # Imputation taxe). On consid횄짢re donc qu'on a pour un groupe de lettrage soit du collect횄짤e
  # (Ventes ou Immos), soit du d횄짤ductible (Achats ou Immos) (Donc 2 imputations de taxe possibles
  # par code taxe dans un groupe de lettrage)
  NB_CODENC += 1
 Endif
Next

If NBMAXCODENC=0 : End : Endif
If NBMAXCODDEB=0 : NBMAXCODDEB=1 : NB_CODDEB=1 : Endif

## Ces tableaux vont servir pour les contr횄쨈les effectu횄짤es dans dans $CONT_CODDEB et $CONT_CODENC
Local Char    T_CODDEB(10)(1..NB_CODDEB)  : # Table des codes taxes TVA sur d횄짤bits existants
Local Char    T_CODENC(10)(1..NB_CODENC)  : # Table des codes taxes TVA sur encaissements existants
Local Integer T_TYPREGDEB(1..NB_CODDEB)   : # Table des types r횄짤gime des codes taxes TVA/d횄짤bits 
Local Integer T_TYPREGENC(1..NB_CODENC)   : # Table des types r횄짤gime des codes taxes TVA/encaissements
Local Decimal T_RATDEB(1..NB_CODDEB)      : # Table des taux des codes taxes TVA/d횄짤bits 
Local Decimal T_RATENC(1..NB_CODENC)      : # Table des taux des codes taxes TVA/encaissements
If clalev([F:TRA])=0  : Local File TABRATVAT  [TRA]  : Endif : # Taux de taxes 
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif : # Tables diverses 

NB_CODDEB = 0 : NB_CODENC = 0
For [TVT]TVT0
 If [F:TVT]VATPAY = 1
  NB_CODDEB += 1
  T_CODDEB(NB_CODDEB) = [F:TVT]VAT
  Read [ADI]CODE = 1;[F:TVT]VATVAC
  If !fstat
   T_TYPREGDEB(NB_CODDEB) = [F:ADI]N1
  Endif
  Filter [TRA] Where CPY = SOC & VAT = [F:TVT]VAT
  Read [TRA]TRA0 Last
  If !fstat
   T_RATDEB(NB_CODDEB) = [F:TRA]VATRAT*[TRA]DEDRAT
  Else
   # On se rabat sur le code dossier
   Filter [TRA] Where CPY = "" & VAT = [F:TVT]VAT
   Read [TRA]TRA0 Last
   If !fstat
    T_RATDEB(NB_CODDEB) = [F:TRA]VATRAT*[TRA]DEDRAT
   Endif
  Endif 
  Filter [TRA]
 Else
  NB_CODENC += 1
  T_CODENC(NB_CODENC) = [F:TVT]VAT
  Read [ADI]CODE = 1;[F:TVT]VATVAC
  If !fstat
   T_TYPREGENC(NB_CODENC) = [F:ADI]N1
  Endif
  Filter [TRA] Where CPY = SOC & VAT = [F:TVT]VAT
  Read [TRA]TRA0 Last
  If !fstat
   T_RATENC(NB_CODENC) = [F:TRA]VATRAT*[TRA]DEDRAT
  Else
   # On se rabat sur le code dossier
   Filter [TRA] Where CPY = "" & VAT = [F:TVT]VAT
   Read [TRA]TRA0 Last
   If !fstat
    T_RATENC(NB_CODENC) = [F:TRA]VATRAT*[TRA]DEDRAT
   Endif
  Endif 
  Filter [TRA]
 Endif
Next

Local Integer MAXLIG , OKDIM
Local Char    PARAM(10)
Call PARAM("","MAXDCLVAT",PARAM) From ADOVAL
MAXLIG = max(val(PARAM),300)

Local Char    COMPTE(GLONGAC)
Local Char    TIERS(GLONBPR)
Local Char    LETTRE(5)
Local Char    TCODENC(15)(1..NBMAXCODENC)       : # Table codes taxes dues sur les encaissements 
Local Char    TCODDEB(15)(1..NBMAXCODDEB)       : # Table codes taxes dues sur les d횄짤bits
Local Char    TYPPCE(GLONGTE)                   : # Type de pi횄짢ce
Local Char    NUMPCE(GLONVCR)                   : # Num횄짤ro de pi횄짢ce
Local Char    DAEFILTRE(255)

Local Date    DATLET                            : # Date de lettrage

Local Integer NBCODENC                          : # Nb codes taxes dues sur les encaissements 
Local Integer NBCODDEB                          : # Nb codes taxes dues sur les d횄짤bits
Local Integer TBACCNUM(1..NBMAXCODENC,1..MAXLIG): # Table des lignes de pi횄짢ces ayant m횄짧me CATCOD et auquel
                                                : # est associ횄짤 un code taxe TVA sur encaissements
Local Integer NBACCNUM(1..NBMAXCODENC)          : # Nombre de lignes de pi횄짢ces ayant m횄짧me lettrage et m횄짧me CATCOD                

Local Integer NUMACPT                           : # Num횄짤ro chrono pour les acomptes
Local Integer SIGN, IND, IND2
Local Integer STAT

Local Integer LETTRAGE
Local Integer DELETTRAGE
Local Integer NBCPTLET                          : # Nb de comptes lettrables

Local Integer OKCODENC, OKCODDEB

Local Integer TYPREG

Local Decimal TAMTLOC(1..NBMAXCODENC,1..MAXLIG): # Table des montants (AMTLOC) des lignes de pi횄짢ces ayant m횄짧me
                                               : # CATCOD, auquel est associ횄짤 un code taxe TVA/encaissements

Local Decimal TAMTVAT(1..NBMAXCODENC,1..MAXLIG): # Table des montants d횄짤clar횄짤s (AMTVAT) des lignes de pi횄짢ces ayant
                                               : # CATCOD, auquel est associ횄짤 un code taxe TVA/encaissements


Local Decimal TOTREG               : # Montant des r횄짢glements (des pi횄짢ces d'un m횄짧me groupe de lettrage)
Local Decimal TOTAL
Local Decimal MTREG                : # Montant r횄짢glements trait횄짤s pour l'option TVA/d횄짤bits d'abord
Local Decimal TOTDEB               : # TVA+base TVA sur d횄짤bits d'un groupe de lettrage (montants d횄짤j횄  d횄짤clar횄짤s compris)
Local Decimal TOTENC               : # TVA+base TVA sur encaissements d'un groupe de lettrage (montants d횄짤j횄  d횄짤clar횄짤s compris)
Local Decimal TOTDECLAR            : # TVA+base TVA sur encaissements d'un groupe de lettrage d횄짤j횄  d횄짤clar횄짤

Local Decimal MTHT, MTTVA, MTTTC

Local Decimal VAT_RAT
Local Decimal BASENC(1..NBMAXCODENC)     : # Tableau des montants des bases de TVA sur encaissements 
Local Decimal TVAENC(1..NBMAXCODENC)     : # Tableau des montants de TVA sur encaissements 
Local Decimal AMTVAT_BASE(1..NBMAXCODENC): # Tableau des montants d횄짤clar횄짤s (base) pour la TVA/encaiss.
Local Decimal AMTVAT_TVA(1..NBMAXCODENC) : # Tableau des montants d횄짤clar횄짤s (montant TVA) pour la TVA/encaiss.
Local Decimal BASDEB(1..NBMAXCODDEB)     : # Tableau des montants des bases de TVA sur d횄짤bits 
Local Decimal TVADEB(1..NBMAXCODDEB)     : # Tableau des montants de TVA sur d횄짤bits
Local Decimal TOTREG_DEB                 : # TVA+base TVA sur d횄짤bits d'un grp de lettrage 횄  d횄짤clarer
Local Decimal TOTREG_ENC                 : # TVA+base TVA sur encaissements d'un grp de lettrage 횄  d횄짤clarer

Local Decimal BASVAT_PAY          : # Montant d횄짤clar횄짤 d'une 횄짤criture si compte soumis 횄  TVA
Local Decimal AMTVAT_PAY          : # Montant d횄짤clar횄짤 d'une 횄짤criture si compte de TVA

Local File GACCENTRYD [DAE]  Order By Key CLE = ACC;BPR;MTC;TYP;NUM;LIG
Local File GACCENTRYD [DAE1] Order By Key CLE = ACC;BPR;MTC;TYP;NUM;LIG

If clalev([F:DVP])=0  : Local File DCLVATPAY  [DVP]  : Endif : # Fichier temp. pour d횄짤cl. TVA/enc 
If clalev([F:DVP2])=0 : Local File DCLVATPAY  [DVP2] : Endif : # Fichier temp. pour d횄짤cl. TVA/enc 
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif : # En-t횄짧te de pi횄짢ces
If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif : # Lignes d'횄짤critures  
If clalev([F:DAE3])=0 : Local File GACCENTRYD [DAE3] : Endif : # Lignes d'횄짤critures
If clalev([F:DAE4])=0 : Local File GACCENTRYD [DAE4] : Endif : # Lignes d'횄짤critures
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif : # Comptes 
If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif : # Comptes 

Call DEBTRANS From GLOCK
Gosub TR_DELDVP
If GOK<1
 End
Endif
Gosub TR_DVP
End  
  

$TR_DVP
Trbegin [DVP]
 DELETTRAGE = 0
 If GTRACE<>""
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(mess(2,45,1)-":"-SOC-","-mess(3,45,1)-":"-SIT-":",0) From GESECRAN
  Call ECR_TRACE(string$(50,"-"),0) From GESECRAN
 Endif

 ## Demande PE 26583
 Raz [L]DAEFILTRE
 GPOINT = "DAEFILTRE" : Gosub ENTREE From EXEFNC
 If [L]DAEFILTRE="" : [L]DAEFILTRE = "1=1" : Endif

 ## <PP 13/09/04> Demande 22602
 #Filter [DAE] Where CPY=SOC & FCYLIN=SIT
 #&                  & MTCDAT>=DATDEB & MTCDAT<=DATFIN
 #&                  & find([F:DAE]TYP,TTYP(1..NBTYP))
 If [M]ECRAUX = 1 : # On prend toutes les 횄짤critures comment avant (auxiliaris횄짤es ou pas) 
  Filter [DAE] Where CPY=SOC & FCYLIN=SIT
&                  & MTCDAT>=DATDEB & MTCDAT<=DATFIN
&                  & find([F:DAE]TYP,TTYP(1..NBTYP)) & evalue([L]DAEFILTRE)
 Else
  Filter [DAE] Where CPY=SOC & FCYLIN=SIT
&                 & MTCDAT>=DATDEB & MTCDAT<=DATFIN & BPR<>""
&                 & find([F:DAE]TYP,TTYP(1..NBTYP)) & evalue([L]DAEFILTRE)
 Endif


 # Parcours des groupes de lettrage (compte,tiers,lettre)
 For [DAE]CLE(3) Where MTC<>"" With Nohint
  Raz NBCODDEB, NBCODENC, TCODDEB, TCODENC
  Raz BASDEB, TVADEB, BASENC,TVAENC
  Raz AMTVAT_BASE, AMTVAT_TVA
  Raz TOTREG_ENC, TOTREG_DEB
  Raz TBACCNUM, NBACCNUM
  Raz TAMTLOC, TAMTVAT
  Raz TOTREG
  COMPTE    = [F:DAE]ACC
  TIERS     = [F:DAE]BPR
  LETTRE    = [F:DAE]MTC
  DATLET    = [F:DAE]MTCDAT
  # Parcours des pi횄짢ces par groupe de lettrage. Les pi횄짢ces lettr횄짤es
  # ensemble peuvent 횄짧tre soit des factures, soit des pi횄짢ces de r횄짢glements
  # Les acomptes seront trait횄짤s plus loin...
  For [DAE1]CLE(5) Where ACC=COMPTE & BPR=TIERS & MTC=LETTRE
   IMPUTACPT = 0
   If !find([F:DAE1]ACC,TACPT(1..NBACPT)) : # C'est pas un compte d'acompte
    # Le compte du groupe de lettrage n'est pas un compte d'acompte mais il peut
    # y avoir dans la pi횄짢ce une ligne avec un compte d'acompte si on est sur une pi횄짢ce
    # d'imputation d'acompte. Dans ce cas, il ne faut pas prendre en compte cette pi횄짢ce
    # dans le calcul des bases et montants ($CALTVA) puisqu'on d횄짤clare cette pi횄짢ce
    # en sens inverse quand on traite le cas des acomptes. Cependant, on ne peut pas exclure
    # cette pi횄짢ce 횄  ce niveau car le montant du compte tiers contenu dans COMPTE doit 횄짧tre
    # cumul횄짤 횄  TOTREG
    If NBACPT>0
     Filter [DAE2] Where TYP = [F:DAE1]TYP & NUM = [F:DAE1]NUM & find([F:DAE2]ACC,TACPT(1..NBACPT))
     Read [DAE2]DAE0 First
     If fstat = 0 : # C'est une pi횄짢ce d'imputation d'acompte
      IMPUTACPT = 1
     Endif
     Filter [DAE2]
    Endif
    OKDIM = 1
    For [DAE2]DAE0 Where TYP = [F:DAE1]TYP & NUM = [F:DAE1]NUM
     # Parcours des lignes d'횄짤critures de la pi횄짢ce [F:DAE1]TYP-[F:DAE1]NUM
     # appartenant au groupe de lettrage.
     # On regarde si c'est une pi횄짢ce r횄짢glement pour MAJ le montant du r횄짢glement     
     #If find([F:DAE2]TYP,TTYP(1..NBTYP)) & [F:DAE2]MTC=LETTRE & (IMPUTACPT=0 | ([F:DAE2]ACC=COMPTE & [F:DAE2]BPR=TIERS))
     If find([F:DAE2]TYP,TTYP(1..NBTYP)) & [F:DAE2]MTC=LETTRE & [F:DAE2]ACC=COMPTE & [F:DAE2]BPR=TIERS
      # On ne d횄짤clare la TVA qu'횄  l'횄짤ch횄짤ance du r횄짢glement 
      Read [HAE]HAE0 = [F:DAE2]TYP ; [F:DAE2]NUM
      If fstat=0 & [F:HAE]DUDDAT<=[M]DATPCE
       TOTREG += [F:DAE2]SNS*[F:DAE2]AMTLOC
      Elsif fstat=0 & [F:HAE]DUDDAT>[M]DATPCE & GTRACE<>""
       # On mentionne les r횄짢glements lettr횄짤s mais non 횄짤chus dans le fichier de trace
       Call ECR_TRACE(mess(12,107,1)-[F:HAE]TYP-[F:HAE]NUM
&                     -","-mess(15,105,1)-format$("D:"+GFMDAT,[F:HAE]DUDDAT)
&                     -":"-mess(87,107,1),0) From GESECRAN
      Endif
      #Elsif [F:DAE2]MTC<>"" & [F:DAE2]MTC<>LETTRE
      # C'est pas une pi횄짢ce de r횄짢glement. Si on est sur une autre lettre, on est dans la
      # cas d'une facture multi-tiers.
      #Call ECR_TRACE(mess(12,107,1)-[F:DAE2]TYP-[F:DAE2]NUM-":"-"factures multi-tiers",1) From GESECRAN
     Endif
     # On va calculer ici les bases, montants de TVA, et les montants de TVA
     # d횄짤clar횄짤s par code TVA.
     # La TVA d횄짤clar횄짤e est mise 횄  jour pour les comptes de TVA et les comptes
     # soumis 횄  la TVA
     If !IMPUTACPT
      Gosub CALTVA
      If !OKDIM & GTRACE<>""
       # Groupe de lettrage non trait횄짤
       Call ECR_TRACE(COMPTE-TIERS-LETTRE-":"-mess(90,107,1)-"(>"+num$(MAXLIG)+")",1) From GESECRAN
       Break 2
      Endif
     Endif
    Next
    Gosub CONT_CODENC
    If !OKCODENC & GTRACE<>""
     Call ECR_TRACE(COMPTE-TIERS-LETTRE-mess(90,107,1)-":"-mess(93,107,1)-"("+mid$(TCODENC(I),2,3)+")",1) From GESECRAN 
     Break
    Endif
    Gosub CONT_CODDEB
    If !OKCODDEB
     If NBCODENC > 0 & GTRACE<>""
      Call ECR_TRACE(COMPTE-TIERS-LETTRE-mess(90,107,1)-":"-mess(93,107,1)-"("+mid$(TCODDEB(I),2,3)+")",1) From GESECRAN
      Break
     Endif
    Endif
   Endif
  Next
  # Demande 22603 : Cas de la facture CEE
  For IND=1 To NBCODENC
    If AMTVAT_BASE(IND)=0 and AMTVAT_TVA(IND)<>0
      # D횄짤termination du signe selon [GAC]VATIPT
      CAT= val(left$(TCODENC(IND),1))
      If CAT=1 | CAT=2: SIGN=-1 : Else : SIGN=1 : Endif 
      # D횄짤termination du type de r횄짤gime
      COD= mid$(TCODENC(IND),2,3)
      Read [TVT]TVT0 = COD
      Read [ADI]CODE = 1;[F:TVT]VATVAC
      If [F:ADI]N1=4
        AMTVAT_TVA(IND)=AMTVAT_TVA(IND)*SIGN
      Endif
    Endif
  Next
  #
  If OKDIM & OKCODENC & OKCODDEB
   TOTDEB = sum(BASDEB(1..NBCODDEB))+sum(TVADEB(1..NBCODDEB))
   TOTENC = sum(BASENC(1..NBCODENC))+sum(TVAENC(1..NBCODENC))
   TOTDECLAR = sum(AMTVAT_BASE(1..NBCODENC))+sum(AMTVAT_TVA(1..NBCODENC)) : # TOTDECLAR : montant d횄짤j횄  d횄짤clar횄짤 pr le grp lettrage
   Gosub CAL_DECLAR
  Endif
 Next 
 If GOK<0   : Goto ROLL_TR_DVP 
 Elsif !GOK : Goto AB_TR_DVP  
 Endif
 Filter [DAE]
 
 Gosub DELETTRAGE
 If GOK<0   : Goto ROLL_TR_DVP 
 Elsif !GOK : Goto AB_TR_DVP  
 Endif
 Filter [DAE]

 # On traite maintenant le cas des acomptes...
 Gosub ACOMPTES
 If GOK<0   : Goto ROLL_TR_DVP
 Elsif !GOK : Goto AB_TR_DVP
 Endif
 Filter [DAE]

 Gosub REG_NONLET

Commit
Return

$AB_TR_DVP 
Rollback  
Return  
  
$ROLL_TR_DVP  
Rollback  
Call ROLL From GLOCK  
If GROLL : Return : Else : Goto TR_DVP : Endif

      
$REG_NONLET
# On met dans le fichier de trace les r횄짢glements 횄짤chus et non lettr횄짤s
For [HAE]HAE0 Where [F:HAE]DUDDAT <= [M]DATPCE & find([F:HAE]TYP,TTYP(1..NBTYP)) & CPY=SOC & FCY=SIT
&                 & NUMDCL<>0 With Nohint
 # <PP 08/10/02> Bug 15959 : rajout crit횄짢re NUMDCL<>0  
 LETTRAGE = 0 : NBCPTLET = 0
 For [DAE4]DAE0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & BPR<>""
  Read [GAC]GAC0 = [F:DAE4]ACC
  ## <PP 02/03/04> Bug 21449
  If !fstat & [F:GAC]FLGVAT<>3 & [F:GAC]MTC=2 : NBCPTLET += 1 : Endif
  ## <Fin PP>
  If [F:DAE4]MTC<>"" : LETTRAGE = 1 : Break : Endif
 Next
 If !LETTRAGE & NBCPTLET>0 & GTRACE<>""
  # Le r횄짢glement est 횄짤chu et il n'y a aucune ligne d'횄짤criture
  # de la pi횄짢ce de r횄짢glement d횄짤clenchante lettr횄짤e ==> on affiche l'anomalie 
  Call ECR_TRACE(mess(12,107,1)-[F:HAE]TYP-[F:HAE]NUM
&                 -","-mess(15,105,1)-format$("D:"+GFMDAT,[F:HAE]DUDDAT)
&                 -":"-mess(88,107,1),0) From GESECRAN
 Endif
Next
Return


$CALTVA
# Calcul des bases et montants de TVA
If [F:DAE2]TAX<>""
 Read [GAC]GAC0 = [F:DAE2]ACC
 If !fstat
  CAT = [F:GAC]VATIPT : # TVA coll.ven/coll.immo/d횄짤duc.achats/d횄짤duc.immos
  NBBLC = 3-len([F:DAE2]TAX)
  COD = [F:DAE2]TAX+space$(NBBLC)
  Call LECTURE("TVT",[F:DAE2]TAX,"") From CONTOBJ
  Filter [TRA] Where VAT=[F:DAE2]TAX & CPY=SOC & STRDAT<=[F:DAE2]ACCDAT 
  Read [TRA]TRA0 Last
  If !fstat
   VAT_RAT = [F:TRA]VATRAT
  Else
   Filter [TRA] Where VAT=[F:DAE2]TAX & CPY="" & STRDAT<=[F:DAE2]ACCDAT
   Read [TRA]TRA0 Last
   If !fstat
    VAT_RAT = [F:TRA]VATRAT
   Endif 
  Endif
  Filter [TRA]
  CATCOD = num$(CAT)+COD+num$(VAT_RAT)
  If !DELETTRAGE
   If [F:TVT]VATPAY = 2 : # Taxe due sur les encaissements 
    IND = find(CATCOD,TCODENC(1..NBCODENC))
    If !IND 
     NBCODENC += 1 : IND = NBCODENC : TCODENC(IND) = CATCOD 
    Endif 
    Case [F:GAC]FLGVAT 
     When 2
      BASENC(IND)      += [F:DAE2]SNS*[F:DAE2]AMTLOC
      AMTVAT_BASE(IND) += [F:DAE2]AMTVAT
      #If [F:DAE2]AMTLOC<>[F:DAE2]AMTVAT : # car pour le cas des impay횄짤s, on veut d횄짤clarer en sens inverse !!! 
      If NBACCNUM(IND)>=MAXLIG
       OKDIM = 0 : Return        
      Endif
      NBACCNUM(IND)  += 1 : TBACCNUM(IND,NBACCNUM(IND)) = [F:DAE2]ACCNUM
      TAMTLOC(IND,NBACCNUM(IND)) = [F:DAE2]SNS*[F:DAE2]AMTLOC : # Montant de l'횄짤criture
      TAMTVAT(IND,NBACCNUM(IND)) = [F:DAE2]AMTVAT             : # Montant d횄짤j횄  d횄짤clar횄짤 de l'횄짤criture
      #Endif
     When 3, 4
      TVAENC(IND)     += [F:DAE2]SNS*[F:DAE2]AMTLOC
      AMTVAT_TVA(IND) += [F:DAE2]AMTVAT
      #If [F:DAE2]AMTLOC<>[F:DAE2]AMTVAT : # car pour le cas des impay횄짤s, on veut d횄짤clarer en sens inverse !!!
      If NBACCNUM(IND)>=MAXLIG
       OKDIM = 0 : Return        
      Endif
      NBACCNUM(IND)  += 1 : TBACCNUM(IND,NBACCNUM(IND)) = [F:DAE2]ACCNUM
      TAMTLOC(IND,NBACCNUM(IND)) = [F:DAE2]SNS*[F:DAE2]AMTLOC : # Montant de l'횄짤criture
      TAMTVAT(IND,NBACCNUM(IND)) = [F:DAE2]AMTVAT             : # Montant d횄짤j횄  d횄짤clar횄짤 de l'횄짤criture
      #Endif
    Endcase
   Else : # Taxe due sur les d횄짤bits
    IND = find(CATCOD,TCODDEB(1..NBCODDEB)) 
    If !IND 
     NBCODDEB += 1 : IND = NBCODDEB : TCODDEB(IND) = CATCOD 
    Endif 
    Case [F:GAC]FLGVAT 
     When 2
      BASDEB(IND)    += [F:DAE2]SNS*[F:DAE2]AMTLOC
     When 3, 4
      TVADEB(IND)    += [F:DAE2]SNS*[F:DAE2]AMTLOC
    Endcase 
   Endif
  Else : # On est dans le cas du d횄짤lettrage
   If [F:TVT]VATPAY = 2 : # Taxe due sur les encaissements 
    IND = find(CATCOD,TCODENC(1..NBCODENC))
    If !IND 
     NBCODENC += 1 : IND = NBCODENC : TCODENC(IND) = CATCOD 
    Endif 
    If NBACCNUM(IND)>=MAXLIG
     OKDIM = 0 : Return        
    Endif
    NBACCNUM(IND)  += 1 : TBACCNUM(IND,NBACCNUM(IND)) = [F:DAE2]ACCNUM
    TAMTVAT(IND,NBACCNUM(IND)) = [F:DAE2]AMTVAT : # Montant d횄짤j횄  d횄짤clar횄짤 de l'횄짤criture      
   Endif
  Endif
 Endif
Endif 
Return 
 

$CAL_DECLAR
TOTAL  = TOTDEB + TOTENC
If TOTREG<0 : # Le r횄짢glement est une recette
 TOTREG    = -TOTREG
 TOTDEB    = -TOTDEB
 TOTENC    = -TOTENC
 TOTAL     = -TOTAL
Endif
If TOTDECLAR<0
 TOTDECLAR = -TOTDECLAR
Endif
Case OPTPAY 
 When "1" 
  # On suppose que la TVA sur d횄짤bits est pay횄짤e en premier.
  # Par cons횄짤quence,  on diminue le r횄짢glement du montant sur d횄짤bits. 
  # Ex : Fact. 1000 Frs HT + 200 Frs TVA sur d횄짤bits 
  #            1000 Frs HT + 200 Frs TVA sur encaissements 
  #            Total = 2400 Frs TTC 
  # On a un r횄짢glement de 1500 Frs. Dans ce cas, le montant de
  # la TVA sur d횄짤bits sera de 1200 Frs et la TVA sur encaissements
  # sera de 300 Frs. 
  # En fait la TVA sur encaissements 횄  d횄짤clarer sera 횄짤gale 횄  :
  # (300/1200)*200 soit 50 Frs
  If TOTREG = 0
   TOTREG_ENC = -TOTDECLAR
  Else
   TOTREG_DEB = min(TOTREG,TOTDEB)
   TOTREG_ENC = TOTREG-TOTREG_DEB-TOTDECLAR
   If TOTREG_ENC>TOTENC-TOTDECLAR
    TOTREG_ENC = TOTENC-TOTDECLAR
   Endif
  Endif
 When "2" 
  # On suppose qu'on paye on prorata. On proratise le r횄짢glement
  # par rapport au rapport base+TVA sur encaissements/
  # Total base+TVA (TVAENC/TOTAL)
  If TOTREG = 0
   TOTREG_ENC = -TOTDECLAR
  Elsif TOTREG <= TOTAL & TOTAL<>0
   TOTREG_ENC = (TOTREG)*(TOTENC/TOTAL)-TOTDECLAR
  Elsif TOTAL>0
   # le montant du r횄짢glement est sup횄짤rieur au montant restant 횄  d횄짤clarer
   # (sur les factures lettr횄짤es avec le (ou les) r횄짤glement(s), il y a des comptes
   # non soumis 횄  la TVA...) 
   TOTREG_ENC = TOTENC-TOTDECLAR
  Endif
Endcase

If TOTREG_ENC<>0
 For IND=1 To NBCODENC
  CAT     = val(left$(TCODENC(IND),1))
  COD     = mid$(TCODENC(IND),2,3)
  VAT_RAT = val(right$(TCODENC(IND),5))
  If CAT=1 | CAT=2: SIGN=-1 : Else : SIGN=1 : Endif 
   If TVAENC(IND)<>0 | BASENC(IND)<>0
   MTHT       = SIGN*BASENC(IND) 
   MTTVA      = SIGN*TVAENC(IND)

   If TOTREG<>0
    MTTTC      = TOTENC
    If MTTTC>0
     MTPCE = min(TOTREG_ENC,MTTTC)
    Else
     MTPCE = max(TOTREG_ENC,MTTTC)
    Endif
    MONTANT    = arr(MTTVA*MTPCE/MTTTC,GARODEV)
    BASE       = arr(MTHT*MTPCE/MTTTC,GARODEV)
   Else
    # Montant r횄짢glement=0, on d횄짤clare en sens inverse !!! 
    MONTANT = -AMTVAT_TVA(IND)
    BASE    = -AMTVAT_BASE(IND) 
   Endif

   For I=1 To NBACCNUM(IND)
    Read [DAE3]DAE2 = TBACCNUM(IND,I)
    If !fstat
     Read [GAC]GAC0 = [F:DAE3]ACC
     If ([F:GAC]FLGVAT=2 & BASE<>0) | (find([F:GAC]FLGVAT,3,4) & MONTANT<>0)
      Raz [F:DVP]
      [F:DVP]CPY = SOC
      [F:DVP]FCY = SIT
      [F:DVP]STRDAT = DATDEB
      [F:DVP]ENDDAT = DATFIN
      [F:DVP]ACC    = COMPTE
      [F:DVP]BPR    = TIERS
      [F:DVP]MTC    = LETTRE
      [F:DVP]VATRAT = vireblc(COD,1)+" "+num$(VAT_RAT)
      [F:DVP]VAT    = vireblc(COD,1)
      [F:DVP]ACCNUM = TBACCNUM(IND,I)
      [F:DVP]VATIPT = [F:GAC]VATIPT : # Imputation taxe (LA609)
      [F:DVP]MTCDAT = DATLET
      [F:DVP]SIM    = SIMUL
      [F:DVP]AMTVCR = TOTREG
      [F:DVP]TOTAMTATI = SIGN*BASENC(IND)+MTTVA
      [F:DVP]TOTAMTVAT = MTTVA
      [F:DVP]OPT       = val(OPTPAY)
      # La date maximale d'횄짤ch횄짤ance est stock횄짤e dans le fichier pour pouvoir l'indiquer en
      # en-t횄짧te dans l'impression ou la r횄짤impression de l'횄짤tat (suggestion soumise)
      [F:DVP]DATMAX    = [M:DIA]DATPCE
      [F:DVP]TYPREC    = 1 : # sert 횄  diff횄짤rencier les diff cas : acomptes, pi횄짢ces d횄짤lettr횄짤es
      # On proratise les montants 횄  d횄짤clarer par rapport au montant total des pi횄짢ces
      # du m횄짧me groupe de lettrage
      If [F:GAC]FLGVAT = 2
       If BASENC(IND)<>0
        BASVAT_PAY = SIGN*TAMTLOC(IND,I)*((AMTVAT_BASE(IND)+BASE)/(SIGN*BASENC(IND)))
        [F:DVP]BASVATPAY = BASVAT_PAY-TAMTVAT(IND,I)
       Endif
      Elsif find([F:GAC]FLGVAT,3,4) & MONTANT<>0
       If TVAENC(IND)<>0
        AMTVAT_PAY = SIGN*TAMTLOC(IND,I)*((AMTVAT_TVA(IND)+MONTANT)/(SIGN*TVAENC(IND)))
        [F:DVP]AMTVATPAY = AMTVAT_PAY-TAMTVAT(IND,I)
       Endif
      Endif
      [F:DVP]NUMRPT = GNUMRPT2
      Gosub POINT_ENTREE
      Write [DVP]
      If fstat
       GOK = 0 : Call FSTA("DVP") From GLOCK : Break 2
      Endif
 
      If SIMUL = 1
       # On lance la d횄짤claration en r횄짤el ==> MAJ du montant de TVA d횄짤clar횄짤e
       If [F:GAC]FLGVAT = 2 : # Compte soumis 횄  TVA 
        [F:DAE3]AMTVAT = BASVAT_PAY
       Elsif find([F:GAC]FLGVAT,3,4) : # Compte de TVA
        [F:DAE3]AMTVAT = AMTVAT_PAY
       Endif
       Rewrite [DAE3]
       If fstat
        GOK = 0 : Call FSTA("DAE3") From GLOCK
       Endif
       If GOK<1 : Break 2 : Endif
      Endif
     Endif
    Endif
   Next
  Endif
 Next
 If GOK < 1 : Return : Endif 
Endif
Return

$DELETTRAGE
# On ne va trouver ici que des factures puisque les r횄짢glements ne comportent pas de TVA
# d횄짤clar횄짤e. On teste donc par rapport 횄  la date de pi횄짢ce et non par rapport 횄  la date
# d'횄짤ch횄짤ance
# NB : quand on d횄짤lettre une pi횄짢ce, seule la lettre est remise 횄  z횄짤ro. On conserve
# la date de lettrage de fa횄짠on 횄  pouvoir borner ici sur la date lettrage.
# Donc si une ligne d'횄짤criture a la zone MTC 횄  vide et la zone MTCDAT diff횄짤rente de vide,
# cela veut dire que le pi횄짢ce a 횄짤t횄짤 d횄짤lettr횄짤e
DELETTRAGE = 1
## <PP 30/12/03> Bug 20616 : rajout de la condition BPR<>"" dans le Filter
Filter [DAE3] Where CPY=SOC & FCYLIN=SIT & BPR<>""
&                 & MTCDAT>=DATDEB & MTCDAT<=DATFIN & MTC=""
&                 & ACCDAT<=[M]DATPCE
For [DAE3]DAE0(2) With Nohint
 MAJVAT = 0
 Raz NBCODENC, TCODENC
 Raz NBACCNUM, TBACCNUM
 Raz TAMTVAT
 For [DAE2]DAE0 Where TYP = [F:DAE3]TYP & NUM = [F:DAE3]NUM
  If [F:DAE2]AMTVAT<>0
   MAJVAT = 1
   Gosub CALTVA
  Endif
 Next
 If MAJVAT
  Gosub RAZAMTVAT
 Endif
Next
Filter [DAE3]
Return

$RAZAMTVAT
For IND=1 To NBCODENC
 CAT     = val(left$(TCODENC(IND),1))
 COD     = mid$(TCODENC(IND),2,3)
 VAT_RAT = val(right$(TCODENC(IND),5))
 If CAT=1 | CAT=2: SIGN=-1 : Else : SIGN=1 : Endif 
 For I=1 To NBACCNUM(IND)
  Read [DAE4]DAE2 = TBACCNUM(IND,I)
  If !fstat & TAMTVAT(IND,I)<>0
   Raz [F:DVP]
   [F:DVP]CPY = SOC
   [F:DVP]FCY = SIT
   [F:DVP]STRDAT = DATDEB
   [F:DVP]ENDDAT = DATFIN
   [F:DVP]ACC    = ""
   [F:DVP]BPR    = ""
   [F:DVP]MTC    = ""
   [F:DVP]VATRAT = vireblc(COD,1)+" "+num$(VAT_RAT)
   [F:DVP]VAT    = vireblc(COD,1)
   [F:DVP]ACCNUM = TBACCNUM(IND,I)
   [F:DVP]VATIPT = [F:GAC]VATIPT : # Imputation taxe (LA609)
   [F:DVP]MTCDAT = [0/0/0]
   [F:DVP]SIM    = SIMUL
   [F:DVP]AMTVCR = 0
   [F:DVP]TOTAMTATI = 0
   [F:DVP]TOTAMTVAT = 0
   [F:DVP]OPT       = val(OPTPAY)
   [F:DVP]DATMAX    = [M:DIA]DATPCE
   [F:DVP]TYPREC    = 2 : # Cas des pi횄짢ces d횄짤l횄짤ttr횄짤es
   Call LECTURE("GAC",[F:DAE4]ACC,"") From CONTOBJ
   If [F:GAC]FLGVAT = 2
    [F:DVP]BASVATPAY = TAMTVAT(IND,I)*-1
   Elsif find([F:GAC]FLGVAT,3,4)
    [F:DVP]AMTVATPAY = TAMTVAT(IND,I)*-1
   Endif
   [F:DVP]NUMRPT = GNUMRPT2
   Gosub POINT_ENTREE
   Write [DVP]
   If fstat
    GOK = 0 : Call FSTA("DVP") From GLOCK : Break 2
   Endif
   If SIMUL = 1
    # On lance la d횄짤claration en r횄짤el ==> RAZ du montant d횄짤clar횄짤
    [F:DAE4]AMTVAT = 0
    Rewrite [DAE4]
    If fstat
     GOK = 0 : Call FSTA("DAE4") From GLOCK
    Endif
    If GOK<1 : Break 2 : Endif
   Endif
  Endif
 Next
Next
Return

$ACOMPTES
## Cas des acomptes
# Lors d'un versement ou de la r횄짤ception d'un acompte relatif
# 횄  une prestation de service, l'acompte est consid횄짤r횄짤 comme
# porteur de TVA qu'il faut d횄짤clarer.
# Le compte d'acompte (409, 419) re횄짠u ou vers횄짤 relatif 횄  une prestation
# de service doit 횄짧tre param횄짤tr횄짤 en "Compte d'acompte".
# La pi횄짢ce constatant le r횄짢glement ou le versement d'un
# acompte peut 횄짧tre d횄짤clenchante ou non d횄짤clenchante.
# Par contre, la pi횄짢ce d'imputation d'acompte doit 횄짧tre
# d횄짤clenchante.
# On parcourt les comptes d'acompte (pour lesquels FLGVAT=5)
# pour traiter le cas des acomptes
Raz TYPPCE, NUMPCE, NUMACPT
Filter [DAE2] Where CPY=SOC & FCYLIN=SIT
For [GAC]GAC0 Where FLGVAT=5
 For [DAE2]DAE1 Where ACC=[F:GAC]ACC
  If !([F:DAE2]TYP=TYPPCE & [F:DAE2]NUM=NUMPCE)
   Read [HAE]HAE0 = [F:DAE2]TYP ; [F:DAE2]NUM

   # BY pour les acomptes il faut prendre la date maximum de pi횄짢ce
   # Ca pose un probl횄짢me pour la date mini

   # If fstat=0 & [F:HAE]DUDDAT>=DATDEB & [F:HAE]DUDDAT<=DATFIN

   ## <PP 26/02/04> Bug 21393 : rajout de la condition [F:HAE]FLGREP<>2 pour exclure les pi횄짢ces d'AN
   If fstat=0 & [F:HAE]DUDDAT>=DATDEB & [F:HAE]DUDDAT<=[M]DATPCE & [F:HAE]FLGREP<>2
    TYPPCE = [F:DAE2]TYP
    NUMPCE = [F:DAE2]NUM
    COMPTE = [F:DAE2]ACC
    TIERS  = [F:DAE2]BPR
    Raz MTTTC, MTTVA
    For [DAE3]DAE0 Where TYP=TYPPCE & NUM=NUMPCE & AMTVAT=0
     If [DAE3]ACC=[F:GAC]ACC
      MTTTC += [F:DAE3]AMTLOC*[F:DAE3]SNS
      If SIMUL = 1
       [F:DAE3]AMTVAT = [F:DAE3]AMTLOC
       Rewrite [DAE3] 
       If fstat
        GOK=0 : Call FSTA("DAE3") From GLOCK
       Endif
      Endif
     Elsif [F:DAE3]TAX<>"" & [F:DAE3]AMTVAT=0
      Read [F:GAC2]GAC0 = [F:DAE3]ACC
      If !fstat & find([F:GAC2]FLGVAT,3,4) : # C'est un compte de TVA
       Call LECTURE("TVT",[F:DAE3]TAX,"") From CONTOBJ 
       If [F:TVT]VATPAY = 2 : # Taxe due sur les encaissements
        If [F:GAC]VATIPT=1 | [F:GAC]VATIPT=2
         SIGN=-1
        Else
         SIGN=1
        Endif
        MTTVA += [F:DAE3]AMTLOC*[F:DAE3]SNS*SIGN
        If SIMUL = 1
         [F:DAE3]AMTVAT = [F:DAE3]AMTLOC
         Rewrite [DAE3] 
         If fstat
          GOK=0 : Call FSTA("DAE3") From GLOCK
         Endif
        Endif
       Endif
      Endif
     Endif
    Next
    If MTTVA<>0
     MTTTC = MTTTC*SIGN
     NUMACPT += 1           : # Juste pour l'횄짤tat Crystal Report...
     LETTRE = num$(NUMACPT)
     Raz [F:DVP]
     Gosub LECTAX
     [F:DVP]CPY       = SOC
     [F:DVP]FCY       = SIT
     [F:DVP]STRDAT    = DATDEB
     [F:DVP]ENDDAT    = DATFIN
     [F:DVP]ACC       = COMPTE
     [F:DVP]BPR       = TIERS
     [F:DVP]MTC       = LETTRE
     [F:DVP]VAT       = [F:DAE2]TAX
     [F:DVP]VATRAT    = [F:DAE2]TAX+" "+num$(VAT_RAT)
     [F:DVP]MTCDAT    = [F:DAE2]ACCDAT
     [F:DVP]ACCNUM    = [F:DAE2]ACCNUM
     [F:DVP]VATIPT    = [F:GAC]VATIPT : # Imputation taxe (LA609)
     [F:DVP]SIM       = SIMUL
     [F:DVP]AMTVCR    = abs(MTTTC)
     [F:DVP]BASVATPAY = MTTTC-MTTVA
     [F:DVP]AMTVATPAY = MTTVA
     [F:DVP]TOTAMTATI = MTTTC
     [F:DVP]TOTAMTVAT = MTTVA
     [F:DVP]TYPREC    = 3 : # Cas des acomptes
     [F:DVP]DATMAX    = [M:DIA]DATPCE
     [F:DVP]OPT       = val(OPTPAY)
     [F:DVP]NUMRPT    = GNUMRPT2
     Gosub POINT_ENTREE
     Write [DVP]
     If fstat   
      GOK=0 : Call FSTA("DVP") From GLOCK : Break 2 
     Endif
    Endif
   Endif
  Endif
 Next
Next
Filter [DAE2]
Return  


$LECTAX
NBBLC = 3-len([F:DAE2]TAX)
COD = [F:DAE2]TAX+space$(NBBLC)
Call LECTURE("TVT",[F:DAE2]TAX,"") From CONTOBJ
Filter [TRA] Where VAT=[F:DAE2]TAX & CPY=SOC & STRDAT<=[F:DAE2]ACCDAT 
Read [TRA]TRA0 Last
If !fstat
 VAT_RAT = [F:TRA]VATRAT
Else  
 Filter [TRA] Where VAT=[F:DAE2]TAX & CPY="" & STRDAT<=[F:DAE2]ACCDAT
 Read [TRA]TRA0 Last
 If !fstat
  VAT_RAT = [F:TRA]VATRAT
 Endif 
Endif
Filter [TRA]
Return


# On contr횄쨈le qu'on n'ait pas dans le groupe de lettrage une base = 0
# et un montant de TVA<>0 (ou le contraire) pour un code taxe.
# Exception 횄  cela : 
#   1횂째) Code taxe exon횄짤r횄짤 (taux=0) pour lequel on aura une base<>0 et un
#       montant de TVA=0
#   2횂째) Code taxe auquel correspond un r횄짤gime de taxe export (r횄짤gime de type 2)
#       pour lequel on aura une base<>0 et un montant de TVA=0
#   3횂째) Code taxe auquel correspond un r횄짤gime de taxe suspension de taxe (r횄짤gime de type 3)
#       pour lequel on aura une base<>0 et un montant de TVA=0
#   4횂째) Code taxe auquel correspond un r횄짤gime de taxe CEE (r횄짤gime de type 4)
#       pour lequel on aura une base=0 et un montant de TVA<>0
$CONT_CODENC
OKCODENC = 1
For I=1 To NBCODENC
 IND2 = find(mid$(TCODENC(I),2,3),T_CODENC(1..NB_CODENC))
 If IND2 & T_RATENC(IND2)<>0 & !find(T_TYPREGENC(IND2),2,3,4) & (BASENC(I)=0 | TVAENC(I)=0) & (BASENC(I)+TVAENC(I)<>0)
  OKCODENC = 0 : Break
 Endif
Next
Return


$CONT_CODDEB
OKCODDEB = 1
For I=1 To NBCODDEB
 IND2 = find(mid$(TCODDEB(I),2,3),T_CODDEB(1..NB_CODDEB))
 If IND2 & T_RATDEB(IND2)<>0 & !find(T_TYPREGDEB(IND2),2,3,4) & (BASDEB(I)=0 | TVADEB(I)=0) & (BASDEB(I)+TVADEB(I)<>0)
  OKCODDEB = 0 : Break
 Endif
Next
Return
      

# On commence par effacer les enregistrements pour la d횄짤claration
# de TVA sur encaissements qu'on est en train de lancer et pour
# lequels SIM=2 
$TR_DELDVP 
GOK = 1 
Trbegin [DVP] 
 Delete [DVP] Where CPY=SOC & FCY=SIT & SIM=2 
 If fstat=1 | fstat>5 
  GOK=0 : Call RSTA("DVP",SOC-SIT) From GLOCK : Goto AB_TR_DELDVP 
 Endif 
 If   GOK<0 : Goto ROLL_TR_DELDVP 
 Elsif !GOK : Goto AB_TR_DELDVP 
 Endif 
Commit 
Return 
 
$AB_TR_DELDVP 
Rollback 
Return 
 
$ROLL_TR_DELDVP 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_DELDVP : Endif 
   
$POINT_ENTREE
GPOINT = "AV_ECRDVP" : Gosub ENTREE From EXEFNC
Return


#################################
# Etiquettes du masque DCLVAT   # 
################################# 

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
#Call AS_ALLCPY(VALEUR) From CPTTRT
# bug 12539 (CP:22/01/02)
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Grizo ALLCPY
 Actzo CPY
 mkstat = 1 : End 
Endif
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY,FCY : Diszo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY : Diszo ALLFCY 
Else
 Actzo CPY,ALLFCY 
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Call AS_CPY(VALEUR) From CPTTRT
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
If [M]ALLCPY=2 : VALEUR = 2 : End : Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Effzo FCY : Diszo FCY : Else : Actzo FCY : Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
If [M]ALLFCY=2 : mkstat = 1 : End : Endif
End

###DBA le 24/07/03 : Sugg 11462
###Si on choisi un site en particulier c'est forcement une simulation !
Subprog AS_SIM(VALEUR)
Variable Integer VALEUR
If [M]ALLFCY<>2 : VALEUR=2 : mkstat = 2 : End : Endif
End


##########################################################################

########################################
# V140 : Suggestion 10822 (CP:07/11/02) 
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Local Char  PARAM(10)
Call PARAM(VALEUR,"DCLVATPAY",PARAM) From ADOVAL
If dim([M]VATPAY)>0
 If PARAM="2" : [M]VATPAY=2 : Else [M]VATPAY=1 : Endif
 Affzo [M]VATPAY
Endif
If dim([M]VATPAY)>0
 Call AP_VATPAY([M]VATPAY)
Endif
End

##########################################
# Etiquettes pour le bloc TVA sur d횄짤bits #
##########################################
Subprog AP_VAT(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 Grizo STRDAT, ENDDAT, DETVCR
Else
 Actzo STRDAT, ENDDAT, DETVCR
Endif
End

Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR 
VALEUR = gdat$(1,month(date$)-1,year(date$))
End
 
Subprog D_ENDDAT(VALEUR) 
Variable Date    VALEUR 
VALEUR = eomonth([M]STRDAT) 
End

Subprog AP_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK, SIMUL
OK=0 
If [M]VAT=2
 For [DLV]DLV0 Where ([M]CPY="" | CPY=[M]CPY) & STRDAT=[M]STRDAT & ENDDAT=VALEUR
  OK=1 : SIMUL = [F:DLV]SIM : Break
 Next
Endif
End

#################################################
# Etiquettes pour le bloc TVA sur encaissements #
#################################################
########################################
# V140 : Suggestion 10822 (CP:07/11/02)
Subprog D_VATPAY(VALEUR)
Variable Integer VALEUR
Local Char  PARAM(10)
Call PARAM([M]CPY,"DCLVATPAY",PARAM) From ADOVAL
If PARAM="2" : VALEUR=2 : Else VALEUR=1 : Endif
Call AP_VATPAY(VALEUR)
End

Subprog AP_VATPAY(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 Grizo STRDAT2, ENDDAT2, DATPCE, DETAIL, TRACE
Else
 Actzo STRDAT2, ENDDAT2, DATPCE, DETAIL, TRACE
Endif
End

Subprog D_STRDAT2(VALEUR)
Variable Date    VALEUR 
VALEUR = gdat$(1,month(date$)-1,year(date$))
End
 
Subprog D_ENDDAT2(VALEUR) 
Variable Date    VALEUR 
VALEUR = eomonth([M]STRDAT) 
End
Subprog D_DATPCE(VALEUR)
Variable Date     VALEUR
VALEUR = [M]ENDDAT2
End

## Ce qu'on faisait avant... 횄짤tiquettes 횄  virer apr횄짢s tests...
$ZZCONT_CODENC
OKCODENC = 1
For I=1 To NBCODENC
 Read [TVT]TVT0 = mid$(TCODENC(I),2,3)
 If !fstat
  Read [ADI]CODE = 1;[F:TVT]VATVAC
  If !fstat
   TYPREG = [F:ADI]N1
  Endif
 Endif
 Filter [TRA] Where CPY=SOC & VAT=mid$(TCODENC(I),2,3)
 Read [TRA]TRA0 Last
 If fstat>2
  # On se rabat sur le code dossier
  Filter [TRA] Where CPY="" & VAT=mid$(TCODENC(I),2,3)
  Read [TRA]TRA0 Last
  If fstat>2 : OKCODENC = 0 : Break : Endif
 Endif
 If [TRA]VATRAT<>0 & !find(TYPREG,2,3,4) & (BASENC(I)=0 | TVAENC(I)=0)
  OKCODENC = 0 : Break
 Endif
Next
Return
      
$ZZCONT_CODDEB
OKCODDEB = 1
For I=1 To NBCODDEB
 Read [TVT]TVT0 = mid$(TCODDEB(I),2,3)
 If !fstat
  Read [ADI]CODE = 1;[F:TVT]VATVAC
  If !fstat
   TYPREG = [F:ADI]N1
  Endif
 Endif
 Filter [TRA] Where CPY=SOC & VAT=mid$(TCODDEB(I),2,3)
 Read [TRA]TRA0 Last
 If fstat>2
  # On se rabat sur le code dossier
  Filter [TRA] Where CPY="" & VAT=mid$(TCODDEB(I),2,3)
  Read [TRA]TRA0 Last
  If fstat>2 : OKCODDEB = 0 : Return : Endif
 Endif
 If [TRA]VATRAT<>0 & !find(TYPREG,2,3,4) & (BASDEB(I)=0 | TVADEB(I)=0)
  OKCODDEB = 0 : Break
 Endif
Next
Return

########################################
Subprog AV_INI(VALEUR)
Variable Char    VALEUR()
#DdM39267
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 [M]ALLCPY = 1 : Affzo ALLCPY
Endif
If [M]ALLCPY=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY : Grizo ALLFCY 
Else
 Actzo CPY,ALLFCY 
Endif
If [M]VAT=1
 Grizo STRDAT, ENDDAT, DETVCR
Else
 Actzo STRDAT, ENDDAT, DETVCR
Endif
If dim([M]VATPAY)>0
 If [M]VATPAY = 1
  Grizo STRDAT2, ENDDAT2, DATPCE, DETAIL, TRACE
 Else
  Actzo STRDAT2, ENDDAT2, DATPCE, DETAIL, TRACE
 Endif
Endif
End


Funprog SITE(REQUETE)
Value Integer REQUETE
If clalev([F:DLV])=0 : Local File DCLVAT [DLV] : Endif
Filter [DLV] Where NUMRPT = REQUETE
Read [DLV] First
Filter [DLV]
If !fstat
 End [F:DLV]FCYDLV
Else
 End ""
Endif








