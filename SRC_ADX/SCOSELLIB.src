#<AdxTL>@(#)8.0.0.0 $Revision$
#                                                                 #
#        traitement de sélection sous-traitance                   #
#        selon extraits MFGSELLIB                                 #
###################################################################
# Actions :                                                       #
#                                                                 #
#  SCOSELSCI : sélection des articles ss-traités                  #
#  SCOSELSCS : sélection des articles ss-traitance                #
#  SCOSELSCM : sélection des composants                           #
#  SELSCONUM : sélection des réf EO                               #
#  SELSCONUM2: sélection des réf EO ferme /planif. / sugg.        #
#  SELSCONUM3: sélection des réf EO planif. / sugg.               #
#  SELPOHSCO : selection des n° de commande sur ordre de ss-trait.#
#  SELVCRNUM : sélection pièce                                    #  
#  SELSCONOM : sélection d'une nomenclature                       #
#  SELSCOLIN : sélection d'une ligne SCO                          #
#  SELEO     : sélection d'EO dont situation est au - en cours    #
#  SELPTE    : sélection des transaction EO auto                  #
#  SCOSELEOX : sélection besoin article ss-traité (Encours EOS)   #
#  SCOSELITP : sélection fournisseur pour l'article ss-traité     #
#  SCOSELBOS : sélection des services nomenclature de ss-traitance#
###################################################################
#  Sites:  [F:SCO]POHFCY => [F:ORD]ORIFCY Site de commande        #
#          [F:SCO]MFGFCY                  Site de production      #
#          [F:SCI]PRHFCY => [F:ORD]STOFCY Site de réception EOx   #
#          [F:SCS]PRHFCY => [F:ORD]STOFCY Site de réception SCx   #
#          [F:SCM]STOFCY => [F:ORD]STOFCY Site de stockage  MSx   #
###################################################################



$ACTION
Case ACTION
    When "SEL_TABLE"    : Gosub SEL_TABLE
    When "FIN_TABLE"    : Gosub FIN_TABLE
    When "SEL_LISTE"    : Gosub SEL_LISTE
Endcase
Return

###################################################################
#    Choix dans les tables                                        #
###################################################################

$SEL_TABLE
Case TABLE
    When "SCOSELSCI" : Gosub S_SCOITM
    When "SCOSELSCS" : Gosub S_SCOSRV
    When "SCOSELSCM" : Gosub S_SCOMAT
    When "SELSCONUM" : Gosub S_SCONUM
    When "SELSCONUM2": Gosub S_SCONUM2
    When "SELSCONUM3": Gosub S_SCONUM3
    When "SELPOHSCO" : Gosub S_POHSCO
    When "SELVCRNUM" : Gosub S_VCRNUM
    When "SELSCONOM" : Gosub S_SCONOM 
    When "SELEO"     : Gosub S_EO
    When "SELPTE"    : Gosub S_PTE
    When "SCOSELEOX" : Gosub S_SELEOX
    When "SCOSELITP" : Gosub S_SELITP
    When "SCOSELBOS" : Gosub S_SELBOS
Endcase
Return

$FIN_TABLE
Case TABLE
    When "SELVCRNUM" : Gosub FIN_VCRNUM
    When "SCOSELEOX" : Gosub FIN_SELEOX
Endcase
Return

$SEL_LISTE
#CHECK UNUSED_BEGIN
Case LISTE
    When "SELSCOLIN" : Gosub S_SCOLIN
Endcase
#CHECK UNUSED_END
Return

###################################################################
# sélection des articles ss-traités                               # 
###################################################################
$S_SCOITM

If clalev([F:ATZ])<=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ITM])<=0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:SCI])<=0 : Local File SCOITM    [SCI] : Endif

Link  [SCI] With [ITM]ITM0=[F:SCI]ITMREF As [NEW] Where [F:ITM]SCPFLG=2 Order By Key CLE=[F:SCI]SCONUM
Local Char CODFIC (GLONATB)  : CODFIC = "SCOITM"
Local Char WPRHFCY(GLONFCY)  : WPRHFCY  = PARAM(1)

Default File [NEW]
If WPRHFCY<>""    # site 
  CRITERE = 'PRHFCY=WPRHFCY'     
Endif

START = 'ITMREF'
ORDRE = 'SCONUM;SCILIN'

TIT(0) = mess(12,123,1)

NBCOL = 0
NBCOL += 1 : COL(NBCOL)="ITMREF"    : Gosub TEXTE
#NBCOL += 1 : COL(NBCOL)="ITMDES1"   : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="SCONUM"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="PRHFCY"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="POHNUM"    : Gosub TEXTE

Return

###################################################################
# sélection des articles ss-traitance                             # 
###################################################################
$S_SCOSRV

If clalev([F:ATZ])<=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ITM])<=0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:SCS])<=0 : Local File SCOSRV    [SCS] : Endif

Link  [SCS] With [ITM]ITM0=[F:SCS]SRVITMREF As [NEW] Where [F:ITM]SCSFLG=2 Order By Key CLE=[F:SCS]SCONUM
Local Char CODFIC (GLONATB)  : CODFIC = "SCOSRV"
Local Char WPRHFCY(GLONFCY)  : WPRHFCY  = PARAM(1)

Default File [NEW]
If WPRHFCY<>""    # site 
  CRITERE = 'PRHFCY=WPRHFCY'     
Endif

START = 'SRVITMREF'
ORDRE = 'SCONUM;SCILIN;SCSLIN'
TIT(0) = mess(12,123,1)

NBCOL = 0
NBCOL += 1 : COL(NBCOL)="SRVITMREF"    : Gosub TEXTE
#NBCOL += 1 : COL(NBCOL)="ITMDES1"   : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="SCONUM"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="PRHFCY"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="POHNUM"    : Gosub TEXTE

Return

###################################################################
# sélection des composants d'un EO                                # 
###################################################################
$S_SCOMAT

If clalev([F:ATZ])<=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ITM])<=0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:SCM])<=0 : Local File SCOMAT    [SCM] : Endif

Link  [SCM] With [ITM]ITM0=[F:SCM]CPNITMREF As [NEW] Order By Key CLE=[F:SCM]SCONUM
Local Char CODFIC (GLONATB)  : CODFIC = "SCOMAT"
Local Char WSTOFCY(GLONFCY)  : WSTOFCY  = PARAM(1)

Default File [NEW]
If WSTOFCY<>""    # site 
  CRITERE = 'STOFCY=WSTOFCY'     
Endif

START = 'CPNITMREF'
ORDRE = 'SCONUM;SCILIN;SCMLIN'
TIT(0) = mess(12,123,1)

NBCOL = 0
NBCOL += 1 : COL(NBCOL)="CPNITMREF"    : Gosub TEXTE
#NBCOL += 1 : COL(NBCOL)="ITMDES1"   : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="SCONUM"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="STOFCY"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="POHNUM"    : Gosub TEXTE

Return


###################################################################
# sélection des réf EO                                             #
###################################################################
$S_SCONUM
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:SCO])=0 : Local File SCOHEAD    : Endif

Local Char    WFCY(GLONFCY)   : WFCY    = PARAM(1)
Local Integer WSTA            : WSTA    = val(PARAM(2))
Local Char    CODFIC(GLONATB) : CODFIC  = "SCOHEAD"
Default File [SCO]

If WSTA <>0
   CRITERE = 'POHFCY = WFCY & SCOSTA<= WSTA'  
Else
   CRITERE = 'POHFCY = WFCY'
Endif


START='SCONUM'
ORDRE ='SCONUM'

TIT(0)= mess(12,123,1)-mess(641,197,1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="SCONUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="POHFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="mess([F:SCO]SCOSTA,317,1)" 
Call TEXTFIC(CODFIC ,  "SCOSTA", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="ORDDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="RETDAT" : Gosub TEXTE
 
Return

###################################################################
# sélection des réf EO ferme /planif. / sugg.                      #
###################################################################
$S_SCONUM2
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:ORD])=0 : Local File ORDERS    : Endif

Local Char    WFCY(GLONFCY) : WFCY = PARAM(1)
Local Integer EOSFLG   : EOSFLG= val(PARAM(2))
Local Integer EOPFLG   : EOPFLG= val(PARAM(3))
Local Integer EOFFLG   : EOFFLG= val(PARAM(4))
Local Char    CODFIC(GLONATB) : CODFIC = "ORDERS"
Local Integer I:  I=0
Default File [ORD]

CRITERE = 'POHFCY = WFCY'
CRITERE +='&(' 
If EOSFLG = 2
    CRITERE+='WIPSTA=3'
    I+=1
Endif
If EOPFLG = 2
    If I<>0 : CRITERE+='|' : Endif
    CRITERE+='WIPSTA=2'
    I+=1
Endif

If EOFFLG = 2
    If I<>0 : CRITERE+='|' : Endif
    CRITERE+='WIPSTA=1'
    I+=1
Endif
CRITERE +=')&' 

CRITERE+='WIPTYP=13'

START='VCRNUM'
ORDRE='WIPTYP;WIPNUM;ITMREF'

TIT(0)= mess(12,123,1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="mess([F:ORD]WIPSTA,317,1)" 
 Call TEXTFIC(CODFIC , "WIPSTA", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="VCRNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ORIFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="POHFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ENDDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="RMNEXTQTY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPRNUM" : Gosub TEXTE
Return

###################################################################
# sélection des réf EO planif. / sugg.                             #
###################################################################
$S_SCONUM3
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:ORD])=0 : Local File ORDERS    : Endif

Local Char    WFCY (GLONFCY) : WFCY = PARAM(1)
Local Integer WAVSTA  : WAVSTA= val(PARAM(2))
Local Char    CODFIC(GLONATB) : CODFIC = "ORDERS"
Default File [ORD]

CRITERE = 'POHFCY = WFCY'
If WAVSTA  =1 
   CRITERE+='& WIPSTA =3'
Elsif WAVSTA  =2 
   CRITERE+='& WIPSTA =2'
Endif
CRITERE+='& WIPTYP=13'

START='VCRNUM'
ORDRE='WIPTYP;WIPNUM;ITMREF'

TIT(0)= mess(12,123,1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="mess([F:ORD]WIPSTA,317,1)" 
 Call TEXTFIC(CODFIC , "WIPSTA", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="VCRNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ORIFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="POHFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ENDDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="RMNEXTQTY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPRNUM" : Gosub TEXTE

Return


###################################################################
# sélection des n° de commande                                    #
###################################################################
$S_POHSCO
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:POQ])=0 : Local File PORDERQ    : Endif
If clalev ([F:ITM])=0 : Local File ITMMASTER  : Endif
If clalev ([F:SCI])=0 : Local File SCOITM     : Endif   # FQ 66354 GA 07/2010

Link  [POQ] With [SCI]SCI0=[F:POQ]VCRNUMORI;[F:POQ]VCRLINORI As [NEW] Where [F:POQ]VCRTYPORI=36 Order By Key CLE=[F:POQ]POHNUM
Local Char CODFIC(GLONATB)   : CODFIC = "PORDERQ"
Local Char WBPSNUM1 (GLONBPR): WBPSNUM1 = PARAM(1)
Local Char WBPSNUM2 (GLONBPR): WBPSNUM2 = PARAM(2)
Local Date WORDDAT1          : WORDDAT1 = PARAM(3)
Local Date WORDDAT2          : WORDDAT2 = PARAM(4)
Local Char WPOHFCY  (GLONFCY): WPOHFCY  = PARAM(5)

Default File [NEW]

CRITERE="1=1"
If WBPSNUM1=WBPSNUM2 & WBPSNUM1<>""    # un seul fournisseur
   CRITERE+='& [F:POQ]BPSNUM="'+WBPSNUM1+'"'     
Else
   If WBPSNUM1<>""    
      CRITERE+='& [F:POQ]BPSNUM>="'+WBPSNUM1+'"'
   Endif     
   If WBPSNUM2<>""    
      CRITERE+='& [F:POQ]BPSNUM<="'+WBPSNUM2+'"'
   Endif     
Endif
# FQ 66354 GA 07/2010 incompatibilité de type CRITERE, ajout formattage des dates
If WORDDAT1 <>[0/0/0]    # dates de l'intervalle
   CRITERE+=' & [F:POQ]ORDDAT>=['+format$(GFMD,WORDDAT1)+']'
Endif
If WORDDAT2 <>[0/0/0]    # dates de l'intervalle
   CRITERE+=' & [F:POQ]ORDDAT<=['+format$(GFMD,WORDDAT2)+']'
Endif
If WPOHFCY<>""    # site 
   CRITERE+=' & [F:POQ]POHFCY="'+WPOHFCY+'"'
Endif

START = 'POHNUM'
ORDRE = 'POHNUM;POPLIN;POQSEQ'

TIT(0)= mess(12,123,1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="POHNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPSNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ORDDAT" : Gosub TEXTE

# FQ 66354 GA 07/2010 page suivante
DEFPAG=1

Return

###################################################################
# sélection pièce                                                 #
###################################################################
$S_VCRNUM
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:ORD])=0 : Local File ORDERS     : Endif

Local Integer WTYP            : WTYP = val(PARAM(1))
Local Integer WSTA            : WSTA = val(PARAM(2))
Local Char    WFCY(GLONFCY)   : WFCY = PARAM(3)
Local Char    CODFIC(GLONATB) : CODFIC = "ORDERS"
Local Integer NBCR
Default File [ORD]

NBCR = 0
If WFCY <> ""    :   CRITERE = 'STOFCY=WFCY'     : NBCR += 1 : Endif
If WTYP <> 0    
    If NBCR > 0 : CRITERE += '&' : Endif 
    CRITERE += 'WIPTYP=WTYP'
    NBCR += 1
Endif
If WSTA <> 0
    If NBCR > 0 : CRITERE += '&' : Endif 
    CRITERE += 'WIPSTA=WSTA'
Endif

START='VCRNUM'
ORDRE='WIPTYP;WIPNUM;ITMREF'

TIT(0)= mess(12,123,1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="mess([F:ORD]WIPSTA,317,1)" 
 Call TEXTFIC(CODFIC , "WIPSTA", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="VCRNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ORIFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="STOFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ENDDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="RMNEXTQTY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPRNUM" : Gosub TEXTE
SIZLIG = 90
SIZCOL = 330
Return

###################################################################
$FIN_VCRNUM
Case GFONCTION
    When "GESSCO":      [M:SCO1]VCRTYPORI(nolign-1) = [F:ORD]VCRTYP
                        [M:SCO1]VCRLINORI(nolign-1) = [F:ORD]VCRLIN
                        [M:SCO1]VCRSEQORI(nolign-1) = [F:ORD]VCRSEQ
    When "MULTIEOX":    [M]VCRTYPORI                = [F:ORD]VCRTYP
                        [M]VCRLINORI                = [F:ORD]VCRLIN
                        [M]VCRSEQORI                = [F:ORD]VCRSEQ
Endcase
Return

###################################################################
#  SELSCONOM    : sélection des nomenclatures                     #
###################################################################
$S_SCONOM
Local    Char    WFCY(GLONFCY)   : WFCY = PARAM(1)
Local    Char    WITM(GLONITM)   : WITM = PARAM(2)
Local    Char    CODFIC(GLONATB) : CODFIC = "BOM"

If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif    
If clalev([F:TBO]) = 0 : Local File TABBOMALT  [TBO] : Endif   
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif   
If clalev([F:AXX]) = 0 : Local File ATEXTRA    [AXX] : Endif  # FGR 02/10/2009 : X3SUIVI57935

# FGR 02/10/2009 : X3SUIVI57935

#Link [BOH] With [TBO]TBO0=3;BOMALT As [NEW]
# FQ 69633 GA 12/2010 il manque GLANGUE dans l'accès AXX0
  Link [BOH] With [TBO]TBO0=3;BOMALT,
&                 [AXX]AXX0="BOM";"BOMDESAXX";GLANGUE;[F:BOH]IDENT1;num$([F:BOH]BOMALTTYP)
&         As [NEW]

#MAE, bg 53819
#CRITERE= '[F:BOH]ITMREF = WITM  & BOMALTTYP = 3 & find([F:TBO]FCY,"",WFCY)' 
CRITERE= '[F:BOH]ITMREF = WITM  & BOMALTTYP = 3 ' 
If WFCY <> ""
    CRITERE += '& find([F:TBO]FCY,"",WFCY)'
Endif

Default File [NEW]

ORDRE='ITMREF;BOMALT'
TIT(0)= mess(153,198,1) 
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="BOMALT"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="[F:TBO]FCY": Call TEXTFIC("TABBOMALT", "FCY", 1, TIT(NBCOL) ) From OBJDIV
# FGR 02/10/2009 : X3SUIVI57935
#NBCOL +=1 : COL(NBCOL)="BOMDES"    : Gosub TEXTE
NBCOL +=1  : COL(NBCOL)="BOMDESAXX" : Gosub TEXTE : COL(NBCOL)="[F:AXX]TEXTE"  # FGR 02/10/2009 : X3SUIVI57935
NBCOL +=1 : COL(NBCOL)="BOHENDDAT" : Gosub TEXTE
 

Return

###################################################################
#  SELSCOLIN   : sélection d'une ligne SCO                         #
###################################################################
#CHECK UNUSED_BEGIN
$S_SCOLIN
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX, I
Local Char    TLIN(60)(99)
Local Char    TLIN1(60)(99)
Local Integer NLIN : NLIN = 0
Local Integer WLIN : WLIN = 0

NLIN = 0
For I=0 To [M:SCO1]NBLIG-1
    If [M:SCO1]ITMTYP <> 2
        TLIN(NLIN)    = format$("K:8X",num$([M:SCO1]SCOLIN(I)))+ 
&                       format$("K:20X", [M:SCO1]ITMREF(I))+
&                       format$("K:30X", [M:SCO1]ITMDES1(I))
        TLIN1(NLIN)   = num$([M:SCO1]SCOLIN(I))
        NLIN += 1
    Endif
Next 
If NLIN <> 0 
    For WLIN = 0 To NLIN-1
        NBTEX += 1 
        TEX(NBTEX)   = vireblc(left$(TLIN1(WLIN),8),1)
        TEXTE(NBTEX) = TLIN(WLIN)
    Next
Endif
Return
#CHECK UNUSED_END
###################################################################
$TEXTE
Call TEXTFIC(CODFIC ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
Return


###################################################################
#   sélection EO                                                  #
###################################################################
$S_EO
## GH 08/01/13 dm 77455 la sélection EO porte sur SCOHEAD et désormais aussi SCOITM
##                      elle est paramétrable pour ses colonnes/son titre via le browser SELEO
Local Integer I : I=0

# FQ 53744 GA 06/04/2009 avant MFGFCY => remplacé par POHFCY
If  PARAM(1)<>""
    Call ADDCRIT(CRITERE,I,"","[SCO]POHFCY='"+[L]PARAM(1)+"'","&") From GOBJSUB
Endif
Call ADDCRIT(CRITERE,I,"",PARAM(2),"&") From GOBJSUB

START='[SCO]SCONUM'
ORDRE='[SCO]SCONUM'
OBJET='SELEO'
Return

###################################################################
#  SELPTE    : sélection des transaction EO auto                  #
###################################################################
$S_PTE
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:PTR])=0 : Local File PURTRS     : Endif

OBJET="PTE"
ORDRE='PTRTYP;PTRNUM'
OPTIONS = 'A'

Return

###################################################################
# sélection des articles ss-traités EO ferme /planif. / sugg.     #
###################################################################
$S_SELEOX
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:ORD])=0 : Local File ORDERS    : Endif

Local Char    WFCY(GLONFCY)   : WFCY   = PARAM(1)
Local Integer WSTA            : WSTA   = val(PARAM(2))
Local Char    CODFIC(GLONATB) : CODFIC = "ORDERS"
Local Integer I:  I=0
Default File [ORD]

# FQ 63392 GA 03/2010 La liste n'est pas filtrée sur WFCY
#CRITERE  = 'POHFCY = WFCY'
CRITERE  = 'STOFCY = WFCY'
If find(WSTA,1,2,3)
   CRITERE +='& WIPSTA= WSTA'
Endif
CRITERE +='& WIPTYP= 13'    # Encours EOX - 1 seul statut ou tous

START='ITMREF'
ORDRE='ITMREF;WIPTYP;WIPNUM'

TIT(0)= mess(12,123,1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="mess([F:ORD]WIPSTA,317,1)" 
 Call TEXTFIC(CODFIC , "WIPSTA", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="VCRNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="POHFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ENDDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="RMNEXTQTY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BOMALT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPRNUM" : Gosub TEXTE
Return
###################################################################
$FIN_SELEOX
Case GFONCTION
    When "GESSCO":      
         [M:SCO0]ITMREF = [F:ORD]ITMREF
         [M:SCO0]BOMALT = [F:ORD]BOMALT 
         [M:SCO0]BPRNUM = [F:ORD]BPRNUM
         Affzo [M:SCO0]ITMREF,BOMALT,BPRNUM

         Local    Decimal  WCOEF,WQTYPUU
         Read [F:ITM]ITM0=[F:ORD]ITMREF
         If fstat Return Endif
         Call UPD_ITM_QTY(1,[F:ITM]STU,[F:ORD]RMNEXTQTY,[F:ITM]PUU,WQTYPUU,WCOEF,0) From SCOLIB
         [M:SCO1]STU    = [F:ITM]STU
         [M:SCO1]PUU    = [F:ITM]PUU
         [M:SCO1]EXTQTY = [F:ORD]RMNEXTQTY
         [M:SCO1]QTYPUU = WQTYPUU
         Affzo [M:SCO1]EXTQTY,QTYPUU,PUU,STU
Endcase
Return

###################################################################
# sélection des services nomenclature de ss-traitance             # 
###################################################################
$S_SELBOS

If clalev ([F:ATZ])=0 : Local File ATABZON : Endif
If clalev ([F:BOD])=0 : Local File BOMD    : Endif

Local Char CODFIC(GLONATB) : CODFIC = "BOMD"
Local Char WITM(GLONITM)   : WITM   = PARAM(1)
Local Integer WALT         : WALT   = val(PARAM(2))

Default File [BOD]
CRITERE ='ITMREF=WITM & BOMALT=WALT & BOMALTTYP=3 & CPNTYP=7'
START = 'CPNITMREF'
ORDRE = 'BOMSTRDAT;BOMENDDAT;CPNITMREF'
TIT(0)= mess(320,184,1)-WITM-"("-num$(WALT)-")"

NBCOL = 0
NBCOL += 1 : COL(NBCOL)="CPNITMREF" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ITMREF"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="BOMSTRDAT" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="BOMENDDAT" : Gosub TEXTE

Return

###################################################################
# sélection fournisseur pour l'article ss-traité                  # 
###################################################################
$S_SELITP

If clalev ([F:ATZ])=0 : Local File ATABZON : Endif
If clalev ([F:ITP])=0 : Local File ITMBPS  : Endif

Local Char CODFIC(GLONATB) : CODFIC = "ITMBPS"
Local Char WITM(GLONITM)   : WITM   = PARAM(1)

Default File [ITP]
CRITERE ='ITMREF=WITM'
START = 'BPSNUM'
ORDRE = 'BPSNUM'
TIT(0) = mess(12,123,1)

NBCOL = 0
NBCOL += 1 : COL(NBCOL)="BPSNUM"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ITMREF"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ITMREFBPS" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ITMDESBPS" : Gosub TEXTE

Return


