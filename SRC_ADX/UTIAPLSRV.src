#<AdxTL>@(#)4.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour APLI.ini du serveur batch
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update APL.ini batch server") From LECFIC
If nomap=GDOSX3
 Call PATCH(nomap)
Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub GESAPL
End

#-------------------#
$GESAPL

Local Char    NOMFIC(GDIMFIC) , NOMFIC2(GDIMFIC) , NOMFIC3(GDIMFIC)
Local Char    VALEUR(250) , VARIA(250) , LIGNE(250) , APPLI(GLONADS)
Local Integer K , TROUVE , STAT , NEWVAL , MODIF , OLDVAL

If DOSSIER<>GDOSX3 : Return : Endif

[L]APPLI = ""
Local File ABATPAR [ABP]
Read [ABP]SPOOL First
If !fstat
 [L]APPLI = [F:ABP]APPLI
Endif
Close Local File [ABP]

If [L]APPLI="" : Return : Endif

#109897
If filinfo(filpath("","","",[L]APPLI),0)<=0
 Return
Endif

# Fichier APL.ini
NOMFIC = filpath("","APL","ini",[L]APPLI)
If filinfo(NOMFIC,0)<=0
 Return
Endif

NOMFIC2 = filpath("","APL","new",[L]APPLI)

Openi NOMFIC Using [IN]
Openo NOMFIC2 , 0 Using [OUT]
Iomode adxifs ""       Using [IN]
Iomode adxirs chr$(10) Using [IN]
Iomode adxium GASCII   Using [IN]
Iomode adxifs ""       Using [OUT]
Iomode adxirs chr$(10) Using [OUT]
Iomode adxium GASCII   Using [OUT]

Raz fstat , TROUVE , MODIF , OLDVAL

NEWVAL = 8000 : # Nouvelle valeur

Repeat
 Rdseq LIGNE Using [IN]
 If !fstat
  K = instr(1,LIGNE,"=")
  If K
   VARIA = vireblc(left$(LIGNE,K-1),2)
   VALEUR = vireblc(right$(LIGNE,K+1),2)
   If VARIA="maxmem"
    TROUVE = 1
    OLDVAL = val(VALEUR)
    NEWVAL = max(NEWVAL,OLDVAL)
    If NEWVAL<>val(VALEUR)
     MODIF = 1
     LIGNE = "maxmem       = "+num$(NEWVAL)
    Endif
   Endif
  Endif
  Wrseq LIGNE Using [OUT]
 Endif
Until fstat
If !TROUVE
 Wrseq "maxmem       = "+num$(NEWVAL) Using [OUT]
 MODIF = 1
Endif

If MODIF
 Call ECR_TRACE("Server folder"-[L]APPLI-": maxmem"-num$(OLDVAL)-"->"-num$(NEWVAL),0) From GESECRAN
Else
 Call ECR_TRACE("Server folder"-[L]APPLI-": maxmem current value"-num$(OLDVAL),0) From GESECRAN
Endif

Openi Using [IN]
Openo Using [OUT]

If MODIF
 NOMFIC3 = filpath("","APL","old",[L]APPLI)
 Call MOVE(NOMFIC,NOMFIC3,STAT) From ORDSYS
 Call MOVE(NOMFIC2,NOMFIC,STAT) From ORDSYS
Else
 Call EFFACE(NOMFIC2,STAT) From ORDSYS
Endif

Return

