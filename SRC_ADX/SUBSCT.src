#<AdxTL>@(#)0.0.0.0 $Revision$ Transaction changement stock
# pour les contenants  faire une recherche "xxx"

#######################################################################
# SUBSCT : Transactions de saisie des changements de stock            #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SRT]STKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                                                                     #
# Génération de 1 écran de saisie à partir des écrans de base SCT     #
#                                                                     #
# Nom des écrans générés : WT3yyy                                     #
#                          yyy = nom de la transaction (SRTNUM)       #
#                                                                     #
#######################################################################
Call OBJET("SCT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SRT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=3
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:SCT0]SRTTYP = 3
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="STKTRS" & IDENT1=num$([F:SRT]SRTTYP) & IDENT2=[F:SRT]SRTNUM
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SRT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "FERME"       : Call IMPSCR        From ATRTX3
 When "FILGAUCHE"   : Gosub FILGAUCHE
 #                                                                                        # hcb X3-67989 deb
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 #                                                                                        # hcb X3-67989 end

 When Default
Endcase
Return

$PE_STKTRS
   Gosub PE_STKTRS From SUBSKX
Return

############################################################

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
Local Char     APPLI            : APPLI=nomap
Local Char     WMODU(3)         : WMODU="T"
Local Integer  WNUM             : WNUM = 3
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WENAFLG
Local Char     WABR(5)
 #                                                                                        # hcb X3-67989 deb
Global Integer WGESLPN
WGESLPN = 1
Read [ACV] CODACT = "LPN"
If !fstat WGESLPN=[F:ACV]FLACT Endif
 #                                                                                        # hcb X3-67989 fin


Return

#-----------------------------------------------------------#
#                                                           #
#-----------------------------------------------------------#
$FILTRE

    FILTSUP = "SRTTYP=3"

Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
    If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case BOUT
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#------------------------------------------------------------#
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
Local Integer I

#-- Positionnement des valeurs si non renseignées
#** Onglet entête
If [M:SCT0]ENAFLG=0 [M:SCT0]ENAFLG=2         : Endif

#** Onglet général
If [M:SCT1]SIHNUMCOD=0
  If [M:SCT1]BETFCYCOD=2
    [M:SCT1]SIHNUMCOD=2
    [M:SCT1]INVSGHCOD=1
  Else
    [M:SCT1]SIHNUMCOD=3
    [M:SCT1]INVSGHCOD=3
  Endif
Endif

If [M:SCT1]BETFCYCOD=2
   Actzo [M:DST]1-99               # ana
Else
   [M:DST]HEACCECOD=3
   [M:DST]DSPCOD   =3
   [M:DST]DSPSCR   =1
   [M:DST]STOCCECOD=3
   [M:DST]CCESCR   =1
   [M:DST]CCESCR2  =1
   [M:DST]CCESCR3  =1
                                # ana deb
   If GOPTCANA>0
      Raz [M:DST]NBDIE
      For [DIE] DIE0
          [M:DST]DIE    ([M:DST]NBDIE)=[F:DIE]DIE
          [M:DST]CCECOD ([M:DST]NBDIE)=3
          [M:DST]DIE2   ([M:DST]NBDIE)=[F:DIE]DIE
          [M:DST]CCECOD2([M:DST]NBDIE)=3
          [M:DST]DIE3   ([M:DST]NBDIE)=[F:DIE]DIE
          [M:DST]CCECOD3([M:DST]NBDIE)=3
          [M:DST]NBDIE+=1


          If [M:DST]NBDIE>=dim([M:DST]DIE)  Break : Endif
      Next
   Endif
   [M:DST]NBDIE2=[M:DST]NBDIE
   [M:DST]NBDIE3=[M:DST]NBDIE
   Affzo [M:DST]
   Grizo [M:DST]1-99
Endif                                  # ana fin




If [M:SCT1]PJTCOD=0  [M:SCT1]PJTCOD=1  : Endif : # Afaire
If [M:SCT1]PJTSCR=0  [M:SCT1]PJTSCR=1  : Endif : # Affaire
If [M:SCT1]TRSFAMCOD=0  [M:SCT1]TRSFAMCOD=1  : Endif : # Famille mouvement
If [M:SCT1]TRSFAMSCR=0  [M:SCT1]TRSFAMSCR=1  : Endif : # Famille mouvement

WMODU +=format$("N0:2",[M:SCT0]SRTTYP)


If [M:SCT2]UOMSAIFLG=0     [M:SCT2]UOMSAIFLG=1  : Endif : # Saisie UC
If [M:SCT2]STACOD=0        [M:SCT2]STACOD=3     : Endif : # Statut (invisible)
If dim([M:SCT2]WRHCOD)>0
    If [M:SCT2]WRHCOD=0    [M:SCT2]WRHCOD=3     : Endif : # Dépôt (invisible)
Endif
If dim([M:SCT2]LOCCOD)>0
    If [M:SCT2]LOCCOD=0    [M:SCT2]LOCCOD=3     : Endif : # Emplacement (invisible)
Endif
If [M:SCT2]MVTDESCOD=0     [M:SCT2]MVTDESCOD=3  : Endif   : # Désignation mouvement (invisible)

# hcb 100505 28601 deb
If dim([M:SCT2]IDEDSTCOD1)>0
    If [M:SCT2]IDEDSTCOD1=0    [M:SCT2]IDEDSTCOD1=3     : Endif : # Palnum destination (invisible)
Endif
If dim([M:SCT2]IDEDSTCOD2)>0
    If [M:SCT2]IDEDSTCOD2=0    [M:SCT2]IDEDSTCOD2=3     : Endif : # Ctrnum destination (invisible)
Endif
# hcb 100505 28601 fin


#----------- Affichage --------------#
If dim([M:SCT2]LOTCOD)>0
    If [M:SCT2]LOTCOD=0    [M:SCT2]LOTCOD=2 : [M:SCT2]LOTSCR=1  : Endif : # LOT
Endif

If dim([M:SCT2]SLOCOD)>0
    If [M:SCT2]SLOCOD=0    [M:SCT2]SLOCOD=2 : [M:SCT2]SLOSCR=1     : Endif : # SLO
Endif

#--- TS 106217
If dim([M:SCT2]ECCCOD)>0
    If [M:SCT2]ECCCOD=0    [M:SCT2]ECCCOD=2 : [M:SCT2]ECCSCR=1  : Endif : # ECCVALMAJ
Endif
#---

If dim([M:SCT2]SERCOD)>0
    If [M:SCT2]SERCOD=0    [M:SCT2]SERCOD=2 : [M:SCT2]SERSCR=1     : Endif : # SERNUM
Endif

If dim([M:SCT2]SERECOD)>0
    If [M:SCT2]SERECOD=0    [M:SCT2]SERECOD=2 : [M:SCT2]SERESCR=1     : Endif : # SERNUMF
Endif

If dim([M:SCT2]IDECOD1)>0
    If [M:SCT2]IDECOD1=0    [M:SCT2]IDECOD1=2 : [M:SCT2]IDESCR1=1     : Endif : # PALNUM
Endif

If dim([M:SCT2]IDECOD2)>0
    If [M:SCT2]IDECOD2=0    [M:SCT2]IDECOD2=2 : [M:SCT2]IDESCR2=1     : Endif : # CTRNUM
Endif
#                                                                                         # hcb x3-67989 deb
If dim([M:SCT2]LPNCOD)>0
    If [M:SCT2]LPNCOD=0    [M:SCT2]LPNCOD=2 : [M:SCT2]LPNSCR=1        : Endif : # CONTENANT
Endif
If dim([M:SCT1]CHGACC)>0
    If [M:SCT1]CHGACC=0    [M:SCT1]CHGACC=1        : Endif : # Changement par Ligne de stock
Endif
#                                                                                         # hcb x3-67989 fin


Gosub GRISAGE

Gosub PE_STKTRS
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
Actzo [M:SCT1]1-99
Local Integer I
[M:SCT0]ENAFLG=2
#** Onglet général

[M:SCT1]PJTCOD=3         : # Affaire (invisible)
[M:SCT1]PJTSCR=1
[M:SCT1]TRSFAMCOD=3      : # Famille du mouvement (invisible)
[M:SCT1]TRSFAMSCR=1

#** Onglet Lignes
[M:SCT2]PRNCOD1=1        : # Impression
[M:SCT2]PRNSCR1=1
[M:SCT2]PRNNBFLG1=1      : # Nombre de document
[M:SCT2]PRNNBSCR1=1
[M:SCT1]BETFCYCOD = 1
[M:SCT1]SIHNUMCOD = 3
[M:SCT1]INVSGHCOD = 3
#                                                                                         # hcb X3-67989 deb
If dim([M:SCT1]CHGACC)>0
   [M:SCT1]CHGACC = 1                # Changement par Ligne de stock
Endif
If dim([M:SCT2]LPNCOD)>0
   [M:SCT2]LPNCOD = 2                # Contenant
   [M:SCT2]LPNSCR = 1
Endif
#                                                                                         # hcb X3-67989 fin

WMODU += format$("N0:2",[M:SCT0]SRTTYP)

[M:SCT2]UOMSAIFLG=1      : # Saisie en UC

If dim([M:SCT2]WRHCOD)>0
  [M:SCT2]WRHCOD=3       : # Dépôt (invisible)
  [M:SCT2]WRHSCR=1
Endif
If dim([M:SCT2]LOCCOD)>0
  [M:SCT2]LOCCOD=3       : # Emplacement (invisible)
  [M:SCT2]LOCSCR=1
Endif

# hcb 100505 28601 deb
If dim([M:SCT2]IDEDSTCOD1)>0
  [M:SCT2]IDEDSTCOD1=3       : # Palnum destination (invisible)
  [M:SCT2]IDEDSTSCR1=1
Endif
If dim([M:SCT2]IDEDSTCOD2)>0
  [M:SCT2]IDEDSTCOD2=3       : # Ctrnum destination (invisible)
  [M:SCT2]IDEDSTSCR2=1
Endif
# hcb 100505 28601 fin


[M:SCT2]STACOD=3         : # Statut (invisible)
[M:SCT2]STASCR=1
[M:SCT2]MVTDESCOD=3      : # Désignation mouvement (invisible)
[M:SCT2]MVTDESSCR=1

Gosub GRISAGE
Grizo [M:DST]1-99      # hcb 120469
Gosub PE_STKTRS

Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Local Integer I
Case COUZON
  When "BETFCYCOD"
       [M:SCT1]BETFCYCOD=val(CZ)
       If val(CZ)>1
          [M:SCT1]CHGEMPTOT=1
          [M:SCT2]IDEDSTCOD1=3           # hcb 100505 28601
          [M:SCT2]IDEDSTCOD2=3           # hcb 100505 28601
          [M:SCT2]IDEDSTSCR1=1           # hcb 100505 28601
          [M:SCT2]IDEDSTSCR2=1           # hcb 100505 28601

          #MAE, RET_SSTRT
          #If val(CZ)=2
          If find(val(CZ),2,5)    #transfert inter-site et retour sous-traitant => changement d'emplacement
             [M:SCT1]CHGEMPCOD=2
             [M:SCT1]CHGSTACOD=2
             [M:SCT1]CHGPCUCOD=2
             [M:SCT1]PIOQTY   =2
          Else
             [M:SCT1]CHGEMPCOD=1
             If dim([M:SCT2]WRHCOD)>0
                [M:SCT2]WRHCOD   =3
                [M:SCT2]WRHSCR   =1
                Grizo [M:SCT2]WRHCOD
             Endif
             [M:SCT2]LOCCOD   =3
             [M:SCT2]LOCSCR   =1         # hcb 100505 28601
             Grizo [M:SCT2]LOCCOD
             [M:SCT1]CHGSTACOD=2
             [M:SCT1]CHGPCUCOD=2
             Effzo [M:SCT2]15
             [M:SCT1]PIOQTY   =1
          Endif
       Else
          Effzo [M:SCT2]15
          [M:SCT1]PIOQTY   =1
       Endif
       Gosub GRISAGE
  When "CHGEMPCOD"
       [M:SCT1]CHGEMPCOD=val(CZ)
       If val(CZ)<>2
         [M:SCT1]CHGEMPTOT=1
         If dim([M:SCT2]WRHCOD)>0
            [M:SCT2]WRHCOD=3
         Endif
         [M:SCT2]LOCCOD=3
         Gosub GRISAGE
         Grizo [M:SCT2]LOCCOD
         If dim([M:SCT2]WRHCOD)>0
            Grizo [M:SCT2]WRHCOD
         Endif
       Else
         If dim([M:SCT2]WRHCOD)>0
            [M:SCT2]WRHCOD=1
         Endif
         [M:SCT2]LOCCOD=1
         Gosub GRISAGE
         Actzo [M:SCT2]LOCCOD
         If dim([M:SCT2]WRHCOD)>0
            Actzo [M:SCT2]WRHCOD
         Endif
       Endif
  When "CHGSTACOD"
       If val(CZ)<>2
         [M:SCT2]STACOD=3
         Gosub GRISAGE
         Grizo [M:SCT2]STACOD
       Else
         [M:SCT2]STACOD=1
         Gosub GRISAGE
         Actzo [M:SCT2]STACOD
       Endif
  When "CHGPCUCOD"
       If val(CZ)<>2
         [M:SCT2]UOMSAIFLG=1
         Gosub GRISAGE
         Grizo [M:SCT2]UOMSAIFLG
       Else
         [M:SCT2]UOMSAIFLG=2
         Gosub GRISAGE
         Actzo [M:SCT2]UOMSAIFLG
       Endif
  When "PJTCOD"
       If val(CZ)=3
         [M:SCT1]PJTSCR=1
         If !GIMPORT Affzo [M:SCT1]PJTSCR  : Grizo [M:SCT1]PJTSCR    : Endif
       Elsif !GIMPORT
         Actzo [M:SCT1]PJTSCR
       Endif
  When "TRSFAMCOD"
       If val(CZ)=3
         [M:SCT1]TRSFAMSCR=1
         If !GIMPORT Affzo [M:SCT1]TRSFAMSCR  : Grizo [M:SCT1]TRSFAMSCR    : Endif
       Elsif !GIMPORT
         Actzo [M:SCT1]TRSFAMSCR
       Endif
  When "STACOD"                                   : # Statut destination
       If val(CZ)=3
         [M:SCT2]STASCR=1
         If !GIMPORT Affzo [SCT2]STASCR : Grizo [SCT2]STASCR : Endif
       Elsif !GIMPORT
         Actzo [SCT2]STASCR
       Endif
  When "WRHCOD"                                   : # Dépôt destination
       If val(CZ)=3
         [M:SCT2]WRHSCR=1
         If !GIMPORT Affzo [SCT2]WRHSCR : Grizo [SCT2]WRHSCR : Endif
       Elsif !GIMPORT
         Actzo [SCT2]WRHSCR
       Endif
  When "LOCCOD"                                   : # Emplacement destination
       If val(CZ)=3
         [M:SCT2]LOCSCR=1
         If !GIMPORT Affzo [SCT2]LOCSCR : Grizo [SCT2]LOCSCR : Endif
       Elsif !GIMPORT
         Actzo [SCT2]LOCSCR
       Endif

# hcb 100505 28601 deb
  When "IDEDSTCOD1"                                   : # Palnum destination
       If val(CZ)=3
         [M:SCT2]IDEDSTSCR1=1
         If !GIMPORT Affzo [SCT2]IDEDSTSCR1 : Grizo [SCT2]IDEDSTSCR1 : Endif
       Elsif !GIMPORT
         Actzo [SCT2]IDEDSTSCR1
       Endif
  When "IDEDSTCOD2"                                   : # Palnum destination
       If val(CZ)=3
         [M:SCT2]IDEDSTSCR2=1
         If !GIMPORT Affzo [SCT2]IDEDSTSCR2 : Grizo [SCT2]IDEDSTSCR2 : Endif
       Elsif !GIMPORT
         Actzo [SCT2]IDEDSTSCR2
       Endif
# hcb 100505 28601 fin


  When "MVTDESCOD"                                : # Des mouvement doc
       If val(CZ)=3
         [M:SCT2]MVTDESSCR=1
         If !GIMPORT Affzo [SCT2]MVTDESSCR : Grizo [SCT2]MVTDESSCR : Endif
       Elsif !GIMPORT
         Actzo [SCT2]MVTDESSCR
       Endif
  When "PRNCOD1"                                  : # Type Impression
       If val(CZ)=1
         [M:SCT2]PRNSCR1=1
         [M:SCT2]PRNNBFLG1=1
         [M:SCT2]PRNNBSCR1=1
         If !GIMPORT Affzo [SCT2]PRNSCR1    : Grizo [SCT2]PRNSCR1
                     Affzo [SCT2]PRNNBFLG1  : Grizo [SCT2]PRNNBFLG1
                     Affzo [SCT2]PRNNBSCR1  : Grizo [SCT2]PRNNBSCR1
         Endif
       Elsif !GIMPORT
         Actzo [SCT2]PRNSCR1
         Actzo [SCT2]PRNNBFLG1
         Actzo [SCT2]PRNNBSCR1
       Endif
  When "PRNNBFLG1"                                : # Nbre impression
       If val(CZ)=1
         [M:SCT2]PRNNBSCR1=1
         If !GIMPORT Affzo [SCT2]PRNNBSCR1: Grizo [SCT2]PRNNBSCR1 : Endif
       Elsif !GIMPORT
         Actzo [SCT2]PRNNBSCR1
       Endif
  When "LOTCOD"                                   : # LOT
       If val(CZ)=2
         [M:SCT2]LOTSCR=1
         If !GIMPORT Affzo [SCT2]LOTSCR : Grizo [SCT2]LOTSCR : Endif
       Elsif !GIMPORT
         Actzo [SCT2]LOTSCR
       Endif
  When "SLOCOD"                                   : # SLO
       If val(CZ)=2
         [M:SCT2]SLOSCR=1
         If !GIMPORT Affzo [SCT2]SLOSCR : Grizo [SCT2]SLOSCR : Endif
       Elsif !GIMPORT
         Actzo [SCT2]SLOSCR
       Endif
  When "ECCCOD"                                   : #--- TS 106217
       If val(CZ)=2
         [M:SCT2]ECCSCR=1
         If !GIMPORT Affzo [SCT2]ECCSCR : Grizo [SCT2]ECCSCR : Endif
       Elsif !GIMPORT
         Actzo [SCT2]ECCSCR
       Endif
  When "SERCOD"                                   : # SER
       If val(CZ)=2
         [M:SCT2]SERSCR=1
         If !GIMPORT Affzo [SCT2]SERSCR : Grizo [SCT2]SERSCR : Endif
       Elsif !GIMPORT
         Actzo [SCT2]SERSCR
       Endif
  When "SERECOD"                                   : # SERE
       If val(CZ)=2
         [M:SCT2]SERESCR=1
         If !GIMPORT Affzo [SCT2]SERESCR : Grizo [SCT2]SERESCR : Endif
       Elsif !GIMPORT
         Actzo [SCT2]SERESCR
       Endif
  When "IDECOD1"                                   : # IDE1
       If val(CZ)=2
         [M:SCT2]IDESCR1=1
         If !GIMPORT Affzo [SCT2]IDESCR1 : Grizo [SCT2]IDESCR1 : Endif
       Elsif !GIMPORT
         Actzo [SCT2]IDESCR1
       Endif
  When "IDECOD2"                                   : # IDE2
       If val(CZ)=2
         [M:SCT2]IDESCR2=1
         If !GIMPORT Affzo [SCT2]IDESCR2 : Grizo [SCT2]IDESCR2 : Endif
       Elsif !GIMPORT
         Actzo [SCT2]IDESCR2
       Endif
#                                                                                         # hcb x3-67989 deb
 When "LPNCOD"                                   : # CONTENANT
       If val(CZ)=2
         [M:SCT2]LPNSCR=1
         If !GIMPORT Affzo [SCT2]LPNSCR : Grizo [SCT2]LPNSCR : Endif
       Elsif !GIMPORT
         Actzo [SCT2]LPNSCR
       Endif
 When "CHGACC"                                   : # Accés
       [M:SCT1]CHGACC = val(CZ)
       Gosub GRISAGE
#                                                                                         # hcb x3-67989 fin
  When Default
       Gosub PE_STKTRS
 Endcase

Return

#                                                                                         # hcb x3-67989 deb
#Subprog C_CHGPCUCOD(VALEUR)
#Variable Integer VALEUR
#    If VALEUR<>2 & CHGSTACOD<>2 & CHGEMPCOD<>2
#        Call MESSAGE(mess(540,184,1)) From GESECRAN
#        mkstat=2
#    Endif
#End
#                                                                                         # hcb x3-67989 fin

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
WABR = "SCT0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
WABR = "SCT0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

$FILGAUCHE
    CRITERE = "SRTTYP=3"
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If dim(WMODU)<0 Local Char WMODU : Endif
If APPLI=""    APPLI=nomap      : Endif
If dim(OK)<0  : Local Integer OK : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     BOUTONS(10)(4)
Local Char     TEXTE(40), LISTE(3), REPONS(1)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK

If WMODU=""
    WMODU = "T"+format$("N0:2", [M:SCT0]SRTTYP)
Endif

#                                                                                         # hcb x3-67989 deb
If [M:SCT1]CHGACC = 0
   [M:SCT1]CHGACC = 1
Endif
If [M:SCT1]CHGACC = 1
#---------------- Noms fenêtres et traitement changement : Ligne stock
   Local Char      WINREF1(GLONFEN) : WINREF1="OSCS"
   Local Char      NOMWIN1(GLONFEN) : NOMWIN1="WOSCS"+[M:SCT0]SRTNUM
#Local Char     NOMTRT1(GLONADC) : NOMTRT1="WGOSCS"+[M:SCT0]SRTNUM
   Local Char      NOMMSKENT(GLONAMK)   # Nom du masque d'entête de la fenêtre
#-------------------------- 1er écran ---------------------------#
   MFROM="SCS1"
Else
#---------------- Noms fenêtres et traitement changement : Contenant
   Local Char      WINREF1(GLONFEN) : WINREF1="OSCSL"
   Local Char      NOMWIN1(GLONFEN) : NOMWIN1="WOSCSL"+[M:SCT0]SRTNUM
   Local Char      NOMMSKENT(GLONAMK)   # Nom du masque d'entête de la fenêtre
#-------------------------- 1er écran ---------------------------#
   MFROM="SCSL"
Endif
#                                                                                         # hcb x3-67989 fin

MTO="W"+WMODU+[M:SCT0]SRTNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
# 1 = Interne
# 2 = Inter-sites
# 4 = Transfert sous-traitant
# 5 = Retour sous traitant

   If [M:SCT1]CHGACC = 1                             : # X3-67989 TS
     Case [M:SCT1]BETFCYCOD
        When 1 :           TBLOC(1) = 1
                           TBLOC(2) = 1
                           If [M:SCT1]CHGEMPTOT<>2
                              TBLOC(5) = 1
                              TZONE(IZON)="LOCSEL"
                              TMOD(IZON)=3
                              IZON+=1
                           Endif

                           TZONE(IZON)="PRI"
                           TMOD(IZON)=3
                           IZON+=1

        When 2 :           TBLOC(2) = 1
                           TBLOC(4) = 1
                           TBLOC(5) = 1
                           TZONE(IZON)="LOCSEL"
                           TMOD(IZON)=3
                           IZON+=1
 # hcb 120505 28601 deb
                           TZONE(IZON)="PALNUMDES"
                           TMOD(IZON)=3
                           IZON+=1
                           TZONE(IZON)="CTRNUMDES"
                           TMOD(IZON)=3
                           IZON+=1
# hcb 120505 28601 fin
        When 4 :           TBLOC(1) = 1
                           TBLOC(4) = 1
                           TBLOC(5) = 1
                           TZONE(IZON)="LOCSEL"
                           TMOD(IZON)=3
                           IZON+=1
                           TZONE(IZON)="PRI"
                           TMOD(IZON)=3
                           IZON+=1
# hcb 120505 28601 deb
                           TZONE(IZON)="PALNUMDES"
                           TMOD(IZON)=3
                           IZON+=1
                           TZONE(IZON)="CTRNUMDES"
                           TMOD(IZON)=3
                           IZON+=1
# hcb 120505 28601 fin
#MAE, RET_SSTRT
        When 5 :           TBLOC(1) = 1
                           TBLOC(4) = 1
                           TBLOC(5) = 1
                           TZONE(IZON)="WRHSEL"
                           TMOD(IZON)=3
                           IZON+=1
                           TZONE(IZON)="LOCSEL"
                           TMOD(IZON)=3
                           IZON+=1
                           TZONE(IZON)="PRI"
                           TMOD(IZON)=3
                           IZON+=1
                           TZONE(IZON)="PALNUMDES"
                           TMOD(IZON)=3
                           IZON+=1
                           TZONE(IZON)="CTRNUMDES"
                           TMOD(IZON)=3
                           IZON+=1

     Endcase
   Endif                                             : # X3-67989 TS

   If [M:SCT1]CHGACC = 1                                                                # hcb x3-67989
#                                                                             par Ligne de stock
      If [M:SCT1]SIHNUMCOD>1  TZONE(IZON)="SIHNUM"              : # Numéro de facture
                              TMOD(IZON) =[M:SCT1]SIHNUMCOD
                              IZON+=1
      Endif
      If [M:SCT1]INVSGHCOD>1  TZONE(IZON)="INVSGH"              : # Flag à facturer
                              TMOD(IZON) =[M:SCT1]INVSGHCOD
                              IZON+=1
      Endif
      If [M:SCT1]PJTCOD>1     TZONE(IZON)="PJT"                : # Famille mouvement
                              TMOD(IZON) =[M:SCT1]PJTCOD
                              IZON+=1
      Endif
      If [M:SCT1]PJTSCR>1     TZONE(IZON)="PJT"                : # Présentation tableau
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SCT1]PJTSCR)
                              IZON+=1
      Endif

      If [M:SCT1]TRSFAMCOD>1  TZONE(IZON)="TRSFAM"                : # Famille mouvement
                              TMOD(IZON) =[M:SCT1]TRSFAMCOD
                              IZON+=1
      Endif
      If [M:SCT1]TRSFAMSCR>1  TZONE(IZON)="TRSFAM"                : # Présentation tableau
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SCT1]TRSFAMSCR)
                              IZON+=1
      Endif

      If [M:SCT2]STACOD>1     TZONE(IZON)="STADESH"            : # Statut
                              TMOD(IZON) =[M:SCT2]STACOD
                              IZON+=1
      Endif
      If dim([M:SCT2]WRHCOD)>0
         If [M:SCT2]WRHCOD>1  TZONE(IZON)="WRHDESH"            : # Dépôt
                              TMOD(IZON) =[M:SCT2]WRHCOD
                              IZON+=1
         Endif
   #MAE, bg 76696
      Else
         TZONE(IZON)="WRHDESH"            : # Dépôt
         TMOD(IZON) =3
         IZON+=1
      Endif
      If dim([M:SCT2]LOCCOD)>0
         If [M:SCT2]LOCCOD>1  TZONE(IZON)="LOCDESH"            : # Emplacement
                              TMOD(IZON) =[M:SCT2]LOCCOD
                              IZON+=1
         Endif
      Endif

      If [M:DST]CCESCR>1
         For I=0 To 19
             TZONE(IZON)="CCE"+num$(I+1)
             TMOD(IZON) =9
             TINT(IZON) =num$([M:DST]CCESCR)
             IZON+=1
         Next I
      Endif
      If [M:SCT2]UOMSAIFLG=1 TZONE(IZON)="PCUDES"             : # Unité destination
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="COEDES"             : # Coeff destination
                             TMOD(IZON) =3
                             IZON+=1
      Endif
      If [M:SCT2]STACOD>1    TZONE(IZON)="STADES"             : # Statut
                             TMOD(IZON) =[M:SCT2]STACOD
                             IZON+=1
      Endif
      If [M:SCT1]CHGSTACOD<>2 TZONE(IZON)="QLYCTLFLG"          : # Génération contrôle qualité
                             TMOD(IZON) =3
                             IZON+=1
      Endif
      If [M:SCT2]STASCR>1    TZONE(IZON)="STADES"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SCT2]STASCR)
                             IZON+=1
      Endif

      If dim([M:SCT2]WRHCOD)>0
        If [M:SCT2]WRHCOD>1  TZONE(IZON)="WRHDES"           : # Dépôt
                             TMOD(IZON) =[M:SCT2]WRHCOD
                             IZON+=1
        Endif
        If [M:SCT2]WRHSCR>1  TZONE(IZON)="WRHDES"           : # Dépôt
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SCT2]WRHSCR)
                             IZON+=1
        Endif
      Endif

      If dim([M:SCT2]LOCCOD)>0
        If [M:SCT2]LOCCOD>1  TZONE(IZON)="LOCTYPDES"        : # Type Emplacement
                             TMOD(IZON) =[M:SCT2]LOCCOD
                             IZON+=1

                             TZONE(IZON)="LOCDES"           : # Emplacement
                             TMOD(IZON) =[M:SCT2]LOCCOD
                             IZON+=1
        Endif
        If [M:SCT2]LOCSCR>1  TZONE(IZON)="LOCTYPDES"        : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SCT2]LOCSCR)
                             IZON+=1

                             TZONE(IZON)="LOCDES"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SCT2]LOCSCR)
                             IZON+=1
        Endif
      Endif
#                                                                                         # hcb x3-67989 fin
# les types de mvt "Interne" et "Transfert sous-traitant" n'ont pas de saisi du LPN destination
# les types de mvt "Inter-sites et "Retoursous-traitant"  ont la saisie du LPN destination liée à la saisie de l'emplacement
      If dim([M:SCT2]LPNCOD)>0
         If find([M:SCT1]BETFCYCOD,1,4)
                             TZONE(IZON)="LPNNUMDES"        : # Contenant destination
                             TMOD(IZON) =3
                             IZON+=1
         Endif
       Endif
  #                                                                                         # hcb x3-67989 fin
      If [M:SCT2]MVTDESCOD>1 TZONE(IZON)="MVTDES"           : # Désignation mouvement
                             TMOD(IZON) =[M:SCT2]MVTDESCOD
                             IZON+=1
      Endif
      If [M:SCT2]MVTDESSCR>1  TZONE(IZON)="MVTDES"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SCT2]MVTDESSCR)
                             IZON+=1
      Endif
# hcb 100505 28601 deb
      If dim([M:SCT2]IDEDSTCOD1)>0
        If [M:SCT2]IDEDSTCOD1>1  TZONE(IZON)="PALNUMDES"           : # Palnum destination
                                 TMOD(IZON) =[M:SCT2]IDEDSTCOD1
                                 IZON+=1
        Endif
        If [M:SCT2]IDEDSTSCR1>1  TZONE(IZON)="PALNUMDES"           : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]IDEDSTSCR1)
                                 IZON+=1
        Endif
      Endif
      If dim([M:SCT2]IDEDSTCOD2)>0
        If [M:SCT2]IDEDSTCOD2>1  TZONE(IZON)="CTRNUMDES"           : # Ctrnum destination
                                 TMOD(IZON) =[M:SCT2]IDEDSTCOD2
                                 IZON+=1
        Endif
        If [M:SCT2]IDEDSTSCR2>1  TZONE(IZON)="CTRNUMDES"           : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]IDEDSTSCR2)
                                 IZON+=1
        Endif
      Endif
# hcb 100505 28601 fin

      If [M:SCT2]PRNCOD1=1       TZONE(IZON)="LBEFMT"             : # Format étiquette
                                 TMOD(IZON) =3
                                 IZON+=1
      Endif
      If [M:SCT2]PRNSCR1>1       TZONE(IZON)="LBEFMT"             : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]PRNSCR1)
                                 IZON+=1
      Endif
      If [M:SCT2]PRNNBFLG1=1     TZONE(IZON)="LBENBR"             : # Nombre d'étiquettes
                                 TMOD(IZON) =3
                                 IZON+=1
      Endif
      If [M:SCT2]PRNNBSCR1>1     TZONE(IZON)="LBENBR"             : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]PRNNBSCR1)
                                 IZON+=1
      Endif
#                                                                                         # hcb x3-67989 deb
#                                                                             par Contenant
   Else
      If [M:SCT1]PJTCOD>1        TZONE(IZON)="PJT"                : # Affaire
                                 TMOD(IZON) =[M:SCT1]PJTCOD
                                 IZON+=1
      Endif
      If [M:SCT1]PJTSCR>1        TZONE(IZON)="PJT"                : # Présentation tableau
