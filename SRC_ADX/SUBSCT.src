                                 TMOD(IZON) =[M:SCT2]WRHCOD
                                 IZON+=1
        Endif
        If [M:SCT2]WRHSCR>1      TZONE(IZON)="WRHDES"           : # Dépôt
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]WRHSCR)
                                 IZON+=1
        Endif
      Endif

      If dim([M:SCT2]LOCCOD)>0
        If [M:SCT2]LOCCOD>1      TZONE(IZON)="LOCTYPDES"        : # Type Emplacement
                                 TMOD(IZON) =[M:SCT2]LOCCOD
                                 IZON+=1
                                 TZONE(IZON)="LOCDES"           : # Emplacement
                                 TMOD(IZON) =[M:SCT2]LOCCOD
                                 IZON+=1
        Endif
        If [M:SCT2]LOCSCR>1      TZONE(IZON)="LOCTYPDES"        : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]LOCSCR)
                                 IZON+=1
                                 TZONE(IZON)="LOCDES"           : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]LOCSCR)
                                 IZON+=1
        Endif
      Endif
      If [M:SCT2]MVTDESCOD>1     TZONE(IZON)="MVTDES"           : # Désignation mouvement
                                 TMOD(IZON) =[M:SCT2]MVTDESCOD
                                 IZON+=1
      Endif
      If [M:SCT2]MVTDESSCR>1     TZONE(IZON)="MVTDES"           : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]MVTDESSCR)
                                 IZON+=1
      Endif

   Endif
#                                                                                         # hcb x3-67989 fin

   Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
   If RETOUR<>0 GOK=0 : Return : Endif
   If [M:SCT1]CHGACC = 1                                                                # hcb x3-67989

#---------- Affichage ---------------#
      If dim([M:SCT2]LOTCOD)>0
         If [M:SCT2]LOTCOD>1     TZONE(IZON)="LOT"              : # Emplacement
                                 TMOD(IZON) =3
                                 IZON+=1
         Endif
         If [M:SCT2]LOTSCR>1     TZONE(IZON)="LOT"              : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]LOTSCR)
                                 IZON+=1
         Endif
      Endif
      If dim([M:SCT2]SLOCOD)>0
         If [M:SCT2]SLOCOD>1     TZONE(IZON)="SLO"              : # Emplacement
                                 TMOD(IZON) =3
                                 IZON+=1
         Endif
         If [M:SCT2]SLOSCR>1     TZONE(IZON)="SLO"              : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]SLOSCR)
                                 IZON+=1
         Endif
      Endif
   #--- 106217
      If dim([M:SCT2]ECCCOD)>0
         If [M:SCT2]ECCCOD>1     TZONE(IZON)="ECCVALMAJ"              : # Emplacement
                                 TMOD(IZON) =3
                                 IZON+=1
         Endif
         If [M:SCT2]ECCSCR>1     TZONE(IZON)="ECCVALMAJ"              : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SCT2]ECCSCR)
                             IZON+=1
         Endif
      Endif
   #---

      If dim([M:SCT2]SERCOD)>0
         If [M:SCT2]SERCOD>1     TZONE(IZON)="SERNUM"           : # Emplacement
                                 TMOD(IZON) =3
                                 IZON+=1
         Endif
         If [M:SCT2]SERSCR>1     TZONE(IZON)="SERNUM"           : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]SERSCR)
                                 IZON+=1
         Endif
         If [M:SCT2]SERECOD>1    TZONE(IZON)="SERNUMF"          : # Emplacement
                                 TMOD(IZON) =3
                                 IZON+=1
         Endif
         If [M:SCT2]SERESCR>1    TZONE(IZON)="SERNUMF"          : # Présentation tableau
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SCT2]SERESCR)
                                 IZON+=1
         Endif
      Endif
      If dim([M:SCT2]IDECOD1)>0               # hcb 100505 38601
         If [M:SCT2]IDECOD1>1    TZONE(IZON)="PALNUM"           : # Palnum
                                 TMOD(IZON) =3
                                 IZON+=1
         Endif
         If [M:SCT2]IDESCR1>1    TZONE(IZON)="PALNUM"           : # Présentation tableau
                                 TMOD(IZON) =9
                              # FGR 15/01/2010 : X3SUIVI60986
                              #TINT(IZON) =num$([M:SCT2]IDESCR)
                                 TINT(IZON) =num$([M:SCT2]IDESCR1)
                                 IZON+=1
         Endif
      Endif                                   # hcb 100505 38601
      If dim([M:SCT2]IDECOD2)>0               # hcb 100505 38601
         If [M:SCT2]IDECOD2>1    TZONE(IZON)="CTRNUM"           : # Ctrnum
                                 TMOD(IZON) =3
                                 IZON+=1
         Endif
         If [M:SCT2]IDESCR2>1    TZONE(IZON)="CTRNUM"           : # Présentation tableau
                                 TMOD(IZON) =9
                              # FGR 15/01/2010 : X3SUIVI60986
                              #TINT(IZON) =num$([M:SCT2]IDESCR)
                                 TINT(IZON) =num$([M:SCT2]IDESCR2)
                                 IZON+=1
         Endif
      Endif                                    # hcb 100505 38601
#                                                                                         # hcb x3-67989 deb
      If dim([M:SCT2]LPNCOD)>0
         If [M:SCT2]LPNCOD>1    TZONE(IZON)="LPNNUM"           : # Contenant
                                TMOD(IZON) =3
                                IZON+=1
         Endif
         If [M:SCT2]LPNSCR>1    TZONE(IZON)="LPNNUM"           : # Présentation tableau
                                TMOD(IZON) =9
                                TINT(IZON) =num$([M:SCT2]LPNSCR)
                                IZON+=1
         Endif
      Endif
   Endif                                                                                  # hcb x3-67989
   OPT1=2
   Gosub PE_STKTRS
Else
    OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif

If [M:SCT1]CHGACC = 1                                                                     # hcb x3-67989
#----------------------------------------------#
# Fenêtre de détail                            #
#----------------------------------------------#
   WINREF1="ISTOCHG"
   NOMWIN1="WQSCS"+[M:SCT0]SRTNUM+"S"
   Raz NOMMSKENT    # Nom du masque d'entête de la fenêtre
   MFROM="STOCHG"
   MTO="W"+WMODU+[M:SCT0]SRTNUM+"S"

   Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
   If ACTION<>"ANNULE"
      If [M:SCT1]BETFCYCOD<>2 TZONE(IZON)="FCYDES"   : # Type d'emplacement
                              TMOD(IZON) =3
                              IZON+=1
      Endif
# hcb 120505 28601 deb
      If [M:SCT1]BETFCYCOD<>1 TZONE(IZON)="PALNUMDES"   : # Palnum destination
                              TMOD(IZON) =3
                              IZON+=1
                              TZONE(IZON)="CTRNUMDES"   : # Ctrnum destination
                              TMOD(IZON) =3
                              IZON+=1
      Endif
# hcb 120505 28601 fin

      If [M:SCT1]CHGEMPCOD<>2 TZONE(IZON)="WRHDES"      : # Dépôt
                              TMOD(IZON) =3
                              IZON+=1
                              TZONE(IZON)="LOCTYPDES"   : # Type d'emplacement
                              TMOD(IZON) =3
                              IZON+=1
                              TZONE(IZON)="LOCDES"      : # Emplacement
                              TMOD(IZON) =3
                              IZON+=1
                              TZONE(IZON)="LPNNUMDES"   : # Contenant destination         # hcb x3-67989
                              TMOD(IZON) =3                                               # hcb x3-67989
                              IZON+=1                                                     # hcb x3-67989
      Endif
#                                                                                         # hcb x3-67989 deb
# les types de mvt "Interne" et "Transfert sous-traitant" n'ont pas de saisi du LPN destination
# les types de mvt "Inter-sites et "Retoursous-traitant"  ont la saisie du LPN destination liée à la saisie de l'emplacement
      If dim([M:SCT2]LPNCOD)>0
         If find([M:SCT1]BETFCYCOD,1,4)
                             TZONE(IZON)="LPNNUMDES"        : # Contenant destination
                             TMOD(IZON) =3
                             IZON+=1
         Endif
       Endif
  #                                                                                         # hcb x3-67989 fin

      If [M:SCT1]CHGSTACOD<>2 TZONE(IZON)="STADES"      : # Statut
                              TMOD(IZON) =3
                              IZON+=1
                              TZONE(IZON)="QLYCTLFLG"   : # Génération contrôle qualité si nouveau statut = Q
                              TMOD(IZON) =3
                              IZON+=1
      Endif
      If [M:SCT1]CHGPCUCOD<>2 TZONE(IZON)="PCUDES"      : # Unité destination
                              TMOD(IZON) =2
                              IZON+=1
                              TZONE(IZON)="COEDES"      : # Coefficient destination
                              TMOD(IZON) =2
                              IZON+=1
      Endif
      If [M:SCT2]MVTDESCOD>1  TZONE(IZON)="MVTDES"             : # Désignation mouvement
                              TMOD(IZON) =[M:SCT2]MVTDESCOD
                              IZON+=1
      Endif
      If [M:SCT2]MVTDESSCR>1  TZONE(IZON)="MVTDES"             : # Présentation tableau
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SCT2]MVTDESSCR)
                              IZON+=1
      Endif
# hcb 100505 28601 deb
      If dim([M:SCT2]IDEDSTCOD1)>0
         If [M:SCT2]IDEDSTCOD1>1  TZONE(IZON)="PALNUMDES"           : # Palnum destination
                                  TMOD(IZON) =[M:SCT2]IDEDSTCOD1
                                  IZON+=1
         Endif
         If [M:SCT2]IDEDSTSCR1>1  TZONE(IZON)="PALNUMDES"           : # Présentation tableau
                                  TMOD(IZON) =9
                                  TINT(IZON) =num$([M:SCT2]IDEDSTSCR1)
                                  IZON+=1
         Endif
      Endif
      If dim([M:SCT2]IDEDSTCOD2)>0
         If [M:SCT2]IDEDSTCOD2>1  TZONE(IZON)="CTRNUMDES"           : # Ctrnum destination
                                  TMOD(IZON) =[M:SCT2]IDEDSTCOD2
                                  IZON+=1
         Endif
         If [M:SCT2]IDEDSTSCR2>1  TZONE(IZON)="CTRNUMDES"           : # Présentation tableau
                                  TMOD(IZON) =9
                                  TINT(IZON) =num$([M:SCT2]IDEDSTSCR2)
                                  IZON+=1
         Endif
      Endif
# hcb 100505 28601 fin

   Else
       OPT1=9
   Endif


   Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
   If RETOUR<>0 GOK=0 : Return : Endif

   If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif
Endif                                                                                     # hcb x3-67989
Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW" [AWI] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR" [AWP] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS
#                                                                                         # hcb x3-67989 deb
If [M:SCT1]CHGACC = 0
   [M:SCT1]CHGACC = 1
Endif
#                                                                                         # hcb x3-67989 deb

#----- Suppression fenêtre -----#
Gosub TRT_SUP_FEN
If [M:SCT0]ENAFLG=1  : Return : Endif
#----- Génération fenêtre  transaction active -----#
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  [F:AWI]MSKENT    = NOMMSKENT
  WNOMMSK=MTO : Gosub ONGLET_INVISIBLE
  If [M:SCT1]CHGACC = 1                                                                   # hcb x3-67989
     I=find("SCS1",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
  Else                                                                                    # hcb x3-67989
     I=find("SCSL",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif                            # hcb x3-67989
  Endif                                                                                   # hcb x3-67989
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS       = [M:SCT0]ACSCOD
  [F:AWI]LIBEL     = [M:SCT0]DESAXX
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:SCT0]SRTNUM
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
   For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    If WINREF1="OSCS"
       If [M:SCT1]BETFCYCOD=2
          [F:AWB]OBJLIS(find("ST2",[F:AWB]OBJLIS)-1) = "STO"
       Elsif [M:SCT1]BETFCYCOD=1 & [M:SCT1]CHGEMPTOT=2
         [F:AWB]OBJLIS(find("ST2",[F:AWB]OBJLIS)-1) = "ST1"
       Endif
    Endif
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
Call VALID(NOMWIN1,APPLI,0,OK) From VALWIN
GOK = !!OK
Return



#---------------------------------------#
# Modification des écrans de base       #
# pour arranger l'esthétique si des     #
# blocs disparaissent                   #
#---------------------------------------#
$MODIF_ECRAN
Return

#---------------------------------------#
# Restauration des écrans de base       #
# suite à l'action MODIF_ECRAN          #
#---------------------------------------#
$RESTAUR_ECRAN
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0
    Local File =APPLI+".AMSK"    [AMK]
Endif
Read [AMK] CODMSK=WNOMMSK
If fstat
    Raz [F:AMK]
    WFLGMSK=2
    Return
Endif

WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
    If [F:AMK]TYPBLOC(I)<>5
        WFLGMSK=2
        Break
    Endif
Next I

Return

#-------------------------------------------#
$GRISAGE
#-- Grisage des zones si besoin
#                                                                                         # hcb X3-67989 deb

If WGESLPN = 1                             # gestion LPN 1 non 2 oui
   [M:SCT1]CHGACC    = 1
   Diszo [M:SCT1]CHGACC
Endif
#                                               # accès Contenant
If [M:SCT1]CHGACC    = 2
   [M:SCT1]BETFCYCOD = 1                   # Type Interne
   [M:SCT1]CHGEMPTOT = 2                   # En masse à oui
   [M:SCT1]CHGPCUCOD = 1                   # Changement unités à non
   [M:SCT1]PIOQTY    = 1                   # Filtre quantité pré-chargée
   [M:SCT2]UOMSAIFLG = 1                   # saisie unité de conditionement à non
   Grizo [M:SCT1]PIOQTY
   Grizo [M:SCT1]BETFCYCOD                 # Type Interne

   If dim([M:SCT2]IDEDSTCOD1)>0
      [M:SCT2]IDEDSTCOD1 = 3
      [M:SCT2]IDEDSTCOD2 = 3
      Grizo [M:SCT2]IDEDSTCOD1             # Identifiant dest 1 et 2
      Grizo [M:SCT2]IDEDSTCOD2
   Endif
   If dim([M:SCT2]LOTCOD)>0                # Lot
      [M:SCT2]LOTCOD = 2
      Grizo [M:SCT2]LOTCOD
   Endif
   If dim([M:SCT2]SLOCOD)>0                # Sous-lot
      [M:SCT2]SLOCOD = 2
      Grizo [M:SCT2]SLOCOD
   Endif
   If dim([M:SCT2]ECCCOD)>0                # Version majeure
      [M:SCT2]ECCCOD = 2
      Grizo [M:SCT2]ECCCOD
   Endif
   If dim([M:SCT2]SERCOD)>0                # Série début
      [M:SCT2]SERCOD = 2
      Grizo [M:SCT2]SERCOD
   Endif
   If dim([M:SCT2]SERECOD)>0               # Série fin
      [M:SCT2]SERECOD = 2
      Grizo [M:SCT2]SERECOD
   Endif
   If dim([M:SCT2]IDECOD1)>0               # Identifiant 1
      [M:SCT2]IDECOD1 = 2
      Grizo [M:SCT2]IDECOD1
   Endif
   If dim([M:SCT2]IDECOD2)>0               # Identifiant 2
      [M:SCT2]IDECOD2 = 2
      Grizo [M:SCT2]IDECOD2
   Endif
   If dim([M:SCT2]LPNCOD)>0                # N° Contenant
      [M:SCT2]LPNCOD = 2
      Grizo [M:SCT2]LPNCOD
   Endif
   Grizo [M:SCT1]CHGEMPTOT                 # En masse
   Grizo [M:SCT1]CHGPCUCOD                 # Changement unités
   Grizo [M:SCT2]UOMSAIFLG                 # saisie unité de conditionement
   Actzo [M:SCT1]CHGEMPCOD                 # Changement emplacement
   Actzo [M:SCT1]CHGSTACOD                 # Changement statut
#                                               # accès Ligne de stock
Else
   If [M:SCT1]CHGEMPCOD = 1
      [M:SCT1]CHGEMPTOT = 1
   Endif
   Actzo [M:SCT1]CHGEMPTOT
   Actzo [M:SCT1]CHGPCUCOD
   Actzo [M:SCT1]BETFCYCOD                 # Type Interne

   Actzo [M:SCT2]PRNCOD1
   If dim([M:SCT2]LOTCOD)>0                # Lot
      Actzo [M:SCT2]LOTCOD
   Endif
   If dim([M:SCT2]SLOCOD)>0                # Sous-lot
      Actzo [M:SCT2]SLOCOD
   Endif
   If dim([M:SCT2]ECCCOD)>0                # Version majeure
      Actzo [M:SCT2]ECCCOD
   Endif
   If dim([M:SCT2]SERCOD)>0                # Série début
      Actzo [M:SCT2]SERCOD
   Endif
   If dim([M:SCT2]SERECOD)>0               # Série fin
      Actzo [M:SCT2]SERECOD
   Endif
   If dim([M:SCT2]IDECOD1)>0               # Identifiant 1
      Actzo [M:SCT2]IDECOD1
   Endif
   If dim([M:SCT2]IDECOD2)>0               # Identifiant 2
      Actzo [M:SCT2]IDECOD2
   Endif
   If dim([M:SCT2]LPNCOD)>0                # N° Contenant
      Actzo [M:SCT2]LPNCOD
   Endif
Endif
#                                                                                         # hcb X3-67989 fin
#** Onglet Général
If [M:SCT1]BETFCYCOD>1
    Grizo [M:SCT1]CHGEMPCOD
    Grizo [M:SCT1]CHGEMPTOT
    If dim([M:SCT2]IDEDSTCOD1)>0
       Grizo [M:SCT2]IDEDSTCOD1                 # hcb 100505 28601
       Grizo [M:SCT2]IDEDSTCOD2                 # hcb 100505 28601
    Endif
    Grizo [M:SCT1]PIOQTY
    If [M:SCT1]BETFCYCOD>2                   # hcb 090505 29284
       Grizo [M:SCT1]CHGSTACOD               # hcb 090505 29284
       Grizo [M:SCT1]CHGPCUCOD               # hcb 090505 29284
    Else                                     # hcb 090505 29284
       Actzo [M:SCT1]CHGSTACOD               # hcb 090505 29284
       Actzo [M:SCT1]CHGPCUCOD               # hcb 090505 29284
    Endif                                    # hcb 090505 29284
Else
    If [M:SCT1]CHGACC    = 1                                                              # hcb X3-67989
       Actzo [M:SCT1]CHGEMPCOD
#       Actzo [M:SCT1]CHGSTACOD                                                           # hcb X3-67989
       Actzo [M:SCT1]CHGPCUCOD
    Endif                                                                                 # hcb X3-67989
    Actzo [M:SCT1]CHGSTACOD                                                               # hcb X3-67989
    If dim([M:SCT2]IDEDSTCOD1)>0 & [M:SCT1]CHGACC    = 1                                  # hcb X3-67989
       Actzo [M:SCT2]IDEDSTCOD1                 # hcb 100505 28601
       Actzo [M:SCT2]IDEDSTCOD2                 # hcb 100505 28601
    Endif
    If [M:SCT1]CHGEMPCOD<>2
       Grizo [M:SCT1]CHGEMPTOT
       Grizo [M:SCT1]PIOQTY
    Else
       If [M:SCT1]CHGACC    = 1                                                           # hcb X3-67989
          Actzo [M:SCT1]CHGEMPTOT
          Actzo [M:SCT1]PIOQTY
       Endif                                                                              # hcb X3-67989

    Endif
Endif
If [M:SCT1]BETFCYCOD=2
    Actzo [M:SCT1]SIHNUMCOD
    Actzo [M:SCT1]INVSGHCOD
    Actzo [M:SCT2]15-20
    #Actzo [M:SCT1]TRSCOD
Else
    Grizo [M:SCT1]SIHNUMCOD
    Grizo [M:SCT1]INVSGHCOD
    Grizo [M:SCT2]15-20
    #Grizo [M:SCT1]TRSCOD
Endif
If [M:SCT1]PJTCOD=3  Grizo [M:SCT1]PJTSCR  Else Actzo [M:SCT1]PJTSCR : Endif

If [M:SCT1]TRSFAMCOD=3  Grizo [M:SCT1]TRSFAMSCR  Else Actzo [M:SCT1]TRSFAMSCR : Endif

#** Onglet Lignes
If [M:SCT1]CHGPCUCOD<>2   Grizo [M:SCT2]UOMSAIFLG Else Actzo [M:SCT2]UOMSAIFLG : Endif
If dim([M:SCT2]LOCCOD)>0
  If [M:SCT1]CHGEMPCOD<>2 Grizo [M:SCT2]LOCCOD   Else Actzo [M:SCT2]LOCCOD  : Endif
  If [M:SCT2]LOCCOD=3     Grizo [M:SCT2]LOCSCR     Else Actzo [SCT2]LOCSCR    : Endif
Endif
If dim([M:SCT2]WRHCOD)>0
  If [M:SCT1]CHGEMPCOD<>2 Grizo [M:SCT2]WRHCOD   Else Actzo [M:SCT2]WRHCOD  : Endif
  If [M:SCT2]WRHCOD=3     Grizo [M:SCT2]WRHSCR     Else Actzo [SCT2]WRHSCR    : Endif
Endif
If [M:SCT1]CHGSTACOD<>2   Grizo [M:SCT2]STACOD   Else Actzo [M:SCT2]STACOD  : Endif
If [M:SCT2]STACOD=3       Grizo [M:SCT2]STASCR     Else Actzo [SCT2]STASCR    : Endif
If [M:SCT2]MVTDESCOD=3    Grizo [M:SCT2]MVTDESSCR  Else Actzo [SCT2]MVTDESSCR   : Endif
If [M:SCT2]PRNCOD1=1    Grizo [SCT2]PRNSCR1, PRNNBSCR1, PRNNBFLG1
  Else                  Actzo [SCT2]PRNSCR1, PRNNBSCR1, PRNNBFLG1
Endif
If [M:SCT2]PRNNBFLG1=1  Grizo [SCT2]PRNNBSCR1  Else Actzo [SCT2]PRNNBSCR1 : Endif

# hcb 100505 28601  deb
If dim([M:SCT2]IDEDSTCOD1)>0
  If [M:SCT2]IDEDSTCOD1=3     Grizo [M:SCT2]IDEDSTSCR1     Else Actzo [SCT2]IDEDSTSCR1    : Endif
Endif
If dim([M:SCT2]IDEDSTCOD2)>0
  If [M:SCT2]IDEDSTCOD2=3     Grizo [M:SCT2]IDEDSTSCR2     Else Actzo [SCT2]IDEDSTSCR2    : Endif
Endif
# hcb 100505 28601  fin



#------------------ Affichage ------------#
If dim([M:SCT2]LOTCOD)>0
  If [M:SCT2]LOTCOD=2     Grizo [M:SCT2]LOTSCR     Else Actzo [SCT2]LOTSCR    : Endif
Endif
If dim([M:SCT2]SLOCOD)>0
  If [M:SCT2]SLOCOD=2     Grizo [M:SCT2]SLOSCR     Else Actzo [SCT2]SLOSCR    : Endif
Endif
#--- TS 106217
If dim([M:SCT2]ECCCOD)>0
  If [M:SCT2]ECCCOD=2     Grizo [M:SCT2]ECCSCR     Else Actzo [SCT2]ECCSCR    : Endif
Endif
#---
If dim([M:SCT2]SERCOD)>0
  If [M:SCT2]SERCOD=2     Grizo [M:SCT2]SERSCR     Else Actzo [SCT2]SERSCR    : Endif
Endif
If dim([M:SCT2]SERECOD)>0
  If [M:SCT2]SERECOD=2     Grizo [M:SCT2]SERESCR     Else Actzo [SCT2]SERESCR    : Endif
Endif
If dim([M:SCT2]IDECOD1)>0
  If [M:SCT2]IDECOD1=2     Grizo [M:SCT2]IDESCR1     Else Actzo [SCT2]IDESCR1    : Endif
Endif
If dim([M:SCT2]IDECOD2)>0
  If [M:SCT2]IDECOD2=2     Grizo [M:SCT2]IDESCR2     Else Actzo [SCT2]IDESCR2    : Endif
Endif
#                                                                                         # hcb x3-67989 deb
If dim([M:SCT2]LPNCOD)>0
  If [M:SCT2]LPNCOD=2     Grizo [M:SCT2]LPNSCR     Else Actzo [SCT2]LPNSCR    : Endif
Endif
#                                                                                         # hcb x3-67989 fin
# Issue 110121 - 2015-08-10 by MUARN : ajout rang
Affzo [M:SCT0]1-99
Affzo [M:SCT1]1-99
Affzo [M:SCT2]1-99

Return

#########################################################################
#                   Actions sur champs écran [M:SRT1]                   #
#########################################################################

########################################
Subprog AS_SRTNUM(VALEUR)
Variable Char    VALEUR()
    [M:SCT0]SRTTYP = 3
End


########################################
Subprog AS_PRNCOD1(VALEUR)
Variable Integer VALEUR
    GMENLOC(3) = 1
    GMENLOC(4) = 1
    GMENLOC(5) = 1
    GMENLOC(6) = 1                     # hcb X3-92342
    GMENLOC(7) = 1                     # hcb X3-92342
End

########################################
Subprog AS_BETFCYCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1      # Client
#                                                                                         # hcb X3-67989 deb
If [M:SCT1]CHGACC = 2          # Accès Contenant
   GMENLOC(2) = 1   # Inter-sites
   GMENLOC(4) = 1   # Transfert sous-traitant
   GMENLOC(5) = 1   # Retour sous-traitant
Endif
#                                                                                         # hcb X3-67989 fin

End

########################################
Subprog AM_BETFCYCOD(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
#                                             Inter-sites
  Actzo [M:SCT1]SIHNUMCOD
  Actzo [M:SCT1]INVSGHCOD
  [M:SCT1]SIHNUMCOD=2
  [M:SCT1]INVSGHCOD=1
  Actzo [M:DST]1-99               # ana

Else
  Grizo [M:SCT1]SIHNUMCOD
  Grizo [M:SCT1]INVSGHCOD

  [M:SCT1]SIHNUMCOD=3
  [M:SCT1]INVSGHCOD=3
  [M:DST]HEACCECOD=3
  [M:DST]DSPCOD   =3
  [M:DST]DSPSCR   =1
  [M:DST]STOCCECOD=3
  [M:DST]CCESCR   =1
  [M:DST]CCESCR2  =1
  [M:DST]CCESCR3  =1
                                   # ana deb
  If GOPTCANA>0
     Raz [M:DST]NBDIE
     For [DIE] DIE0
         [M:DST]DIE    ([M:DST]NBDIE)=[F:DIE]DIE
         [M:DST]CCECOD ([M:DST]NBDIE)=3
         [M:DST]DIE2   ([M:DST]NBDIE)=[F:DIE]DIE
         [M:DST]CCECOD2([M:DST]NBDIE)=3
         [M:DST]DIE3   ([M:DST]NBDIE)=[F:DIE]DIE
         [M:DST]CCECOD3([M:DST]NBDIE)=3
         [M:DST]NBDIE+=1
         If [M:DST]NBDIE>=dim([M:DST]DIE)  Break : Endif
     Next
  Endif
  [M:DST]NBDIE2=[M:DST]NBDIE
  [M:DST]NBDIE3=[M:DST]NBDIE
  Affzo [M:DST]
  Grizo [M:DST]1-99
                                  # ana fin

Endif
End

########################################
Subprog AS_SIHNUMCOD(VALEUR)
Variable Integer  VALEUR
GMENLOC(1)=1
End


##########################################################################

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call GENPATCH(3,APPLI) From FUNSTKTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

Call GENDOS(3,APPLI) From FUNSTKTRS

End
##########################################################################


##########################################################################

#################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File STKTRS [SRT1]
Else
 Local File =[M]DOSORG+".STKTRS" [SRT1]
Endif
If [M]DOSDES=nomap
 Local File STKTRS [SRT2]
Else
 Local File =[M]DOSDES+".STKTRS" [SRT2]
Endif
OK = 1

If GTRACE=""
 Read [SRT2]SRT0 = 3;TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [SRT1], [SRT2]
Return

$TR_COP
GOK = 1
Trbegin [SRT2]
 Delete [SRT2] Where SRTTYP = 3 &
&                    SRTNUM = TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".STKTRS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SRT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [SRT1]SRT0=3;TABLE
 If !fstat
  [F:SRT2] = [F:SRT1]
  If dim([F:SRT2]UPDUSR)>0 : [F:SRT2]UPDUSR = GUSER : Endif
  If dim([F:SRT2]UPDDAT)>0 : [F:SRT2]UPDDAT = date$ : Endif
  If dim([F:SRT2]UPDTIM)>0 : [F:SRT2]UPDTIM = time  : Endif
  Write [SRT2]
  If fstat
   GOK=0 : Call FSTA("SRT2") From GLOCK
  Endif
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#                                                                                         # hcb X3-67989 deb
$VERIF
Case [M:SCT1]CHGACC
   When 1
      If [M:SCT1]CHGEMPCOD <> 2 & [M:SCT1]CHGSTACOD<>2 & [M:SCT1]CHGPCUCOD <> 2
         Call MESSAGE(mess(540,184,1)) From GESECRAN
         GERR = 1
         OK = 0
      Endif
   When 2
      If [M:SCT1]CHGEMPCOD <> 2 & [M:SCT1]CHGSTACOD<>2
         Call MESSAGE(mess(540,184,1)) From GESECRAN
         GERR = 1
         OK = 0
      Endif
   When Default
Endcase
Return

Subprog AP_CHGACC(VALEUR)
Variable Integer VALEUR
[M:SCT1]CHGACC = VALEUR     : # Ligne de stock / Contennant
Gosub GRISAGE
End


