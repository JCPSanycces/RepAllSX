#<AdxTL>@(#)6.0.0.0 $Revision$
Call OBJET("SMO", GBIDC1, GBIDC2) From GOBJET
End

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

#######################################################################
# Les etiquettes suivantes sont définies pour la gestion de l'objet   #
#######################################################################
$DEFTRANS
Local Shortint OUVFICFLG
If !clalev([F:SRT]) : Local File STKTRS [SRT] : Endif
If GFONC1 <> "GESSMO" Raz GFLAG Endif
If GFLAG<>""
  Read [F:SRT] SRT0=2;GFLAG
  If fstat | [F:SRT]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:SRT]ACSCOD<>"" & GPROFIL<>GSUPER
    If clalev ([F:ACC])=0
        Local File ACCES  [ACC]
        OUVFICFLG=1
    Endif
    Read [ACC] CODACC=GUSER;[F:SRT]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1 Close File [ACC] : Raz OUVFICFLG : Endif
Return

######################################################################
$VARIANTE
# La transaction lue est elle utilisable ?
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=2;[F:AWI]TRN
If fstat | [F:SRT]ENAFLG<>2
   OK = 0
Endif
Return

######################################################################
$SETTRANS
Global Integer  GCCECOD    : # Flag saisie des sections analytiques
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif

If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=2;GFLAG

#MAE, le 28/01/08, evol GRP_SITE
GGRPFCY = [SRT]GFY
GSMONUM = [SRT]SRTNUM              # hcb 50197

# Dépôt entête obligatoire ou non
If GWRHACT=2
  GWRHOBY = [F:SRT]WRHOBY
Else
  GWRHOBY = 1
Endif
GSVGWRHOBY = GWRHOBY

Return

######################################################################
$OUVRE
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif
Local  Integer  LRET

Raz GSOC_ACTIVE                                               # Ana

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

    Global Integer GRELITSMO
    Raz GRELITSMO
    GSRTNUM = GFLAG
    GSMONUM = GFLAG          # hcb 50197
$OUVRE_SUIT
GFCY=GFCYDEF(7)                                                # Ana
Gosub CHARG_PARAM                                              # Ana
If GMODU(2)=2 : # Si module compta actif                       # Ana
  If !clalev([F:GCM])   Local File GACM       [GCM] : Endif    # Ana
Endif                                                          # Ana
GORITITCOL=1                                                   # Ana


    #----- Initialisation des tables nécessaires à la gestion d'emplacements
    Gosub STK_INILOC From STKLOC

    #----- Ecran stockage mvt du document
    If clalev([M:SOW])=0
        Local Mask STOSORW   [SOW]
    Endif
    Raz [M:SOW]

    #----- Ecran de travail enreg mvt du document
    If clalev([M:STW])=0
        Local Mask STOWORK   [STW]
    Endif
    Raz [M:STW]

    #----- Ecran de travail valeurs des mouvements
    If clalev([M:SVW])=0
        Local Mask STOVALWORK [SVW]
    Endif
    Raz [M:SVW]

    #----- Ecran des paramètres d'allocations
    If clalev([M:ALP])=0
        Local Mask ALLPAR    [ALP]
    Endif

    If clalev([F:TRU])=0
        Local File TABALLRUL [TRU]
    Endif
    If clalev([F:SRU])=0
        Local File TABSTORUL [SRU]
    Endif
    #--- TS 106217
#   Local File ECCSTA [ECS]                                               # hcb 115060
    If !clalev([F:ECS])  : Local File ECCSTA      [ECS]  : Endif          # hcb 115060

    If !GVTMOD : Gosub DECLARE From TABLEAUX : Endif

Return

$FILTRE
    Default File [SMH]
    # Limite les enregistrement de la liste gauche
    # aux sorties diverses (m701-20)
    FILTSUP = "VCRTYP=20"
Return

$LIENS
Local Integer I

If GFCY<>[F:SMH]STOFCY GFCY=[F:SMH]STOFCY : Gosub CHARG_PARAM : Endif    # Ana
#----- Affichage entêtes de colonne variables -----#                     # Ana
Gosub AFF_TITCOL                                                         # Ana


# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATSMO) > 0
   Kill GCTRDATSMO
Endif

    Raz [M:SMO1]


    # TRSTYP = type de mouvement stock (menu local 704)
    # Sa valeur est utilisée en particulier pour le contrôle de statut
    [M:SMO0]VCRTYP = 20
    Actzo [M:SMO0]VCRNUM
    [M:SMO0]TRSTYP = 2

    Raz GRELITSMO

    Call RAZSTOSORW From STKSOR

    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    #----- Relecture transaction de saisie  -----#
    If [F:SRT]SRTTYP <> 2 | [F:SRT]SRTNUM <> GSMONUM                   # hcb 50197
       Read [SRT]SRT0=2;GSMONUM : If fstat Raz [F:SRT] : Endif
    Endif

    Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
    If fstat
       Raz [F:DTR]
    Endif

    [M:SMO0]STKFLG = [F:SRT]STKFLG                                     # hcb 50197

    Actzo [M:SMO1]
    Grizo [M:SMO0]STOFCY
    Grizo [M:SMO0]IPTDAT
    Grizo [M:SMO0]PJT
    Grizo [M:SMO0]TRSFAM
    Grizo [M:SMO0]ENTCOD
    Gosub LIENS From TABLEAUX

    [M:SMO0]CCECODS = [F:DTR]HEACCECOD   # L'action SAISTOANA utilise le champ CCECODS...

    For I=1 To  GNBDIE
        [M:SMO0]CCE(I-1) =  [F:SMH]CCE(I-1)
        #--- Bug 77750
        [M:SMO0]DIE(I-1) = GDIE(I)
    Next

    Call ETAZONSOR("SMO1") From STKECR
    # Ce qui suit ne fonctionne pas dans LIEN_LIG, càd que rien n'est grisé

    # Force l'affichage afin que les Diszo
    # appelés ensuite fonctionnent
    Affzo [M:SMO1]5
    Call STKCTRIPT( [M:SMO0]IPTDAT, [M:SMO0]STOFCY, "1") From STKLIB
    If GERR=1 | GERR=2
        Call MESSAGE(GMESSAGE) From GESECRAN
        Raz GERR
        Raz GMESSAGE
        Diszo [M:SMO1]5    # hcb 109353
    Else
        # Rend insaisissables toutes les colonnes, puis...
        # ( Diszo du tableau empêche la réactivation)
        # ...rend saisissable la dernière ligne (la ligne vide)
        # Car celle-ci peut avoir été rendue inactive
        # par le chargement précédent d'un document (comportant plus de lignes)
        Call STKDISCOL("SMO1",[M]NBLIG) From STKECR
        Diszo [M]ITMREF,ITMDES1
        Actzo [M]ITMREF([M]NBLIG),ITMDES1([M]NBLIG)
        If dim([M]PCU)>0
            Diszo [M]PCU,QTYPCU
            Actzo [M]PCU([M]NBLIG),QTYPCU([M]NBLIG)
        Endif
        If dim(PCUSTUCOE)>0
            Diszo [M]PCUSTUCOE
            Actzo [M]PCUSTUCOE([M]NBLIG)
        Endif
        If dim(STU)>0
            Diszo [M]STU,QTYSTU
            Actzo [M]STU([M]NBLIG),QTYSTU([M]NBLIG)
        Endif
    Endif

# Actzo ou Grizo des dépôts selon le site
GWRHOBY = GSVGWRHOBY
Gosub WRH_ETAT

Return


$DEFLIG
    Default Mask [SMO1]
    Default File [SMD]
    CRIT = 'VCRTYP='+num$([M:SMO0]VCRTYP)+' and VCRNUM="'+[M:SMO0]VCRNUM+'"'
    FICLIG="SMVTD"
    ABLIG="SMD"
    ZONLIG="VCRLIN"
Return

################
# Chargement de la ligne en cours
$LIENS_LIG
Local Integer WRET

    Gosub SET_NOL
    If [F:ITM]ITMREF<>[M:SMO1]ITMREF(NOL)
        Read [ITM]ITM0=[M:SMO1]ITMREF(NOL)
    Endif

    # Alimentation des zones stock de la ligne
    # à partir de STOJOU ou STOALL
    Call RECSTOSOR (!([M:SMO0]CFMFLG)+1, "SMO1",NOL,[M:SMO0]STOFCY,[M:SMO1]ITMREF(NOL),20,
&                   [M:SMO0]VCRNUM,[M:SMO1]VCRLIN(NOL),"",WRET) From STKECR

###############################                         # Ana   deb
Call CHARG_ACCCCE(NOL,"","","[M:SMO1]CCE",
&                "SMD",[F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"") From TRTX3CPT
###############################                         # Ana   fin



Return

$RAZCRE
Local Char LSEC
If GFCY<>GFCYDEF(7)                             # Ana
  GFCY=GFCYDEF(7) : Gosub CHARG_PARAM           # Ana
Endif                                           # Ana
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL                                # Ana

Local Integer I

    Call RAZSTOSORW From STKSOR

    If GSTKCPTMAN(10)<>2
        Effzo [M:SMO0]VCRNUM
        Diszo [M:SMO0]VCRNUM
    Endif
    Actzo [M:SMO0]STOFCY
    Actzo [M:SMO0]IPTDAT
    Actzo [M:SMO0]PJT
    Actzo [M:SMO0]TRSFAM
    [M:SMO0]VCRTYP = 20
    [M:SMO0]TRSTYP = 2
    [M:SMO0]CFMFLG = 1
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    #----- Relecture transaction de saisie  -----#
    If [F:SRT]SRTTYP <> 2 | [F:SRT]SRTNUM <> GSMONUM                   # hcb 50197
       Read [SRT]SRT0=2;GSMONUM : If fstat Raz [F:SRT] : Endif
    Endif
    Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
    If fstat
       Raz [F:DTR]
    Endif

    [M:SMO0]       = [F:SRT]

    [M:SMO0]TRSFAM = [F:SRT]TRSFAMDEF
    Call STKASFCY([M:SMO0]STOFCY) From STKACT
    [M:SMO0]CCECODS = [F:DTR]HEACCECOD   # L'action SAISTOANA utilise le champ CCECODS...
    #------- Initialisation des sections ana --------#
    # doit être fait en am_stofcy car des sections peuvent être fonction du site #

    For I=1 To GNBDIE
        If dim([M:SMO0]CCE)>0
            Call INISEC (LSEC, "STKSODH", I) From TRTX3CPT
            [M:SMO0]CCE(I-1) = LSEC
            #--- Bug 77750
            [M:SMO0]DIE(I-1) = GDIE(I)
        Else
            Break
        Endif
    Next
    Affzo [M:SMO0]TRSFAM
    Actzo [M:SMO1]

If dim([M:SMO0]WRHE)>0
   Call WRHINIT([M:SMO0]WRHE,[M:SMO0]STOFCY,10) From STKWRH
Endif
# Actzo ou Grizo des dépôts selon le site
Gosub WRH_ETAT
Raz GRELITSMO       # hcb 112106

Return

$RAZDUP
Local Integer  NOL    # !!!!! Utilisée dans ALI_ALP
#Local Shortint LRET

    Gosub RAZCRE
    GFCY = [M:SMO0]STOFCY                      # hcb 53363
    Gosub CHARG_PARAM                          # hcb 53363

    Raz [M:SMO1]VCRLIN
    Raz [M:SMO1]UPDFLG
    Raz [M:SMO1]CREFLG
    If dim([M:SMO1]LOT) > 0
       Raz [M:SMO1]LOT
    Endif
    If dim([M:SMO1]SLO) > 0
       Raz [M:SMO1]SLO
    Endif
    Raz [M:SMO1]STA
    If dim([M:SMO1]LOC) > 0
       Raz [M:SMO1]LOC
    Endif
    If dim([M:SMO1]SERNUM) > 0
       Raz [M:SMO1]SERNUM
    Endif
    If dim([M:SMO1]SERNUM) > 0
       Raz [M:SMO1]SERNUMF
    Endif
    Raz [M:SMO1]MVTDES


    For NOL=0 To [M:SMO1]NBLIG-1
        # Lecture article et règle de gestion
        Call INIZONSOR("SMO1",[M:SMO1]ITMREF(NOL),[M:SMO0]STOFCY,NOL,[M:SMO0]TRSTYP,[M:SMO0]TRSCOD,"") From STKECR
        # Si stock à sortir non encore déterminé, init emplacement par défaut
        If dim([M:SMO1]LOC) & [M:SMO1]WSTOSEQ(NOL)=0
           Call STKINIEMPS([M:SMO1]LOC(NOL)) From STKLOC
        Endif
        # Alimentation de [M:ALP]
        Gosub ALI_ALP From SUBSMOB
        # Détermination du stock à sortir (automatisme, saisie)
        Call OUVSOR("SMO1",NOL,[M:SMO1]NBLIG,[M:SMO1]WSTOSEQ(NOL),[M:SMO0]STKFLG,WRET) From STKSOR           # hcb 50197
    Next NOL
    Affzo [M:SMO1]
Return


#########################################################################
$AVANT_MOD
Return

#########################################################################
$SETBOUT
    If [M:SMO1]NBLIG>0
        Call VIREBOUT(CHAINE,"A") From GOBJET
    Endif
# Menu Options / Visu transaction
    CHMEN += "c"
# Menu Options / Sections analytiques
    If find([M:SMO0]CCECODS,1,2)
        CHMEN += "a"
    Endif
#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
Return

$STATUT
    If BOUT="a" & mkstat=4 & REP=""
        REP = "M"
    Endif
Return

$VERIF_CRE

    Call CTLSTOSOR( "SMO1", "QTYSTU", [M:SMO1]NBLIG, OK ) From STKECR
    OK = !OK
    If OK & !GIMPORT & !GWEBSERV
        Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
    Endif
Return

$VERIF_MOD

    Call CTLSTOSOR( "SMO1", "QTYSTU", [M:SMO1]NBLIG, OK ) From STKECR
    OK = !OK
    If OK & !GIMPORT & !GWEBSERV
        Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
    Endif
Return



$INICRE
Local Integer LSTAT
Local Char    LNUM
Local Integer I
    # Création du numéro de document si nécessaire
    If GSTKCPTMAN(10)<>2 | [M:SMO0]VCRNUM = ""
        Call NUMERO(GSTKCPT(10), [M:SMO0]STOFCY, [M:SMO0]IPTDAT,
&                   "", LNUM, LSTAT) From SUBANM
        If GOK<0 Return Endif
        If LSTAT=0
            [M:SMO0]VCRNUM = LNUM
            [F:SMH]VCRNUM  = LNUM
        Else
            GERR=1:GMESSAGE = mess(60,199,1)
            GOK=0
        Endif
    Endif

    [M:SMO0]CFMFLG = !([M:SMO0]CFMCOD-1)+1
    [F:SMH]CFMFLG =   [M:SMO0]CFMFLG
    For I=1 To GNBDIE                               # Ana
         [F:SMH]CCE(I-1) =  [M:SMO0]CCE(I-1)        # Ana
         [F:SMH]DIE(I-1) =  GDIE(I)                 # Ana
    Next
    # Alimentation dépôt entête si mono-dépôt
    If dim([M:SMO0]WRHE)>0 & GWRHOBY=2
      [F:SMH]WRHE = [M:SMO0]WRHE
    Else
      [F:SMH]WRHE = ""
    Endif
Return

$AVANT_MODFIC
# Réalimenter [M]WRHE avec [F]WRHE pour ne pas écraser le mono-dépôt
If dim([M:SMO0]WRHE)>0
   [M:SMO0]WRHE = [F:SMH]WRHE
Endif
Return

$INIMOD
Local Integer I
    For I=1 To GNBDIE                              # Ana
        [F:SMH]CCE(I-1) =  [M:SMO0]CCE(I-1)        # Ana
        [F:SMH]DIE(I-1) =  GDIE(I)                 # Ana
    Next
Return

$CREATION
    Gosub CREATION From TABLEAUX
Return

$MODIF
    Gosub MODIF From TABLEAUX
Return

$ANNULE
    Gosub ANNULE From TABLEAUX
Return

$INICRE_LIG
    [F:SMD]VCRTYP = [F:SMH]VCRTYP
    [F:SMD]VCRNUM = [F:SMH]VCRNUM
    # Alimentation dépôt ligne si renseigné
    If dim([M:SMO1]WRH)>0 & [M:SMO1]WRH(nolign-1)<>""
      [F:SMD]WRH = [M:SMO1]WRH(nolign-1)
    Else
      [F:SMD]WRH = ""
    Endif
Return

$VALLIG
Local Integer WRET
Gosub SET_NOL


    If [M:SMO0]CFMCOD=2
        Gosub ALI_ALP From SUBSMOB
        Call ENRSTOALL([M:SMO1]WSTOSEQ(NOL),0,WRET) From STKALL
        If WRET<>0
           Raz GOK : Return
        Endif
    Else
        Local Decimal LQTA
        Local Decimal LSHT
        Local Integer LRET
        Local Integer LNBR, LNBJ

        # Initialisation de l'en-tête
        [M:STW]STOFCY     = [M:SMO0]STOFCY      # Site
        [M:STW]TRSTYP     = [M:SMO0]TRSTYP      # Type mouvement (M.704)
        [M:STW]VCRTYP     = [M:SMO0]VCRTYP      # Type pièce (M.701)
        [M:STW]VCRNUM     = [F:SMH]VCRNUM       # Numéro pièce
        [M:STW]VCRLIN     = [F:SMD]VCRLIN       # Numero ligne pièce
        [M:STW]ITMREF     = [M:SMO1]ITMREF(NOL) # Article
        [M:STW]MVTDES     = [M:SMO1]MVTDES(NOL) # Désignation mouvement
        [M:STW]PRIORDH    = 0
        [M:STW]PJT        = [M:SMO0]PJT         # Affaire
        [M:STW]TRSFAM     = [M:SMO0]TRSFAM      # Famille mouvement
        [M:STW]ENTCOD     = [M:SMO0]ENTCOD      # Famille mouvement
        [M:STW]IPTDAT     = [M:SMO0]IPTDAT      # Date imputation
        [M:STW]TRSCOD     = [M:SMO0]TRSCOD      # Code mouvement
        [M:STW]CCECOD     = "STJSOR"
        [M:STW]CUR        = GLOCALDEV
        Call ALISTOWORK( 3, [M:SMO1]WSTOSEQ(NOL), LQTA, LSHT, LNBR, LNBJ, WRET ) From STKINT
        If WRET<>0
           Raz GOK : Return
        Endif

        Call MAJ_STOCK From STKMAJ

    Endif
    #----- Ecriture des sections analytiques dans la table CPTANALIN -----#
    Call ENREG_ACCCCE(nolign-1,"","","[M:SMO1]CCE","SMD",
&                     [F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"",TRTLIG) From TRTX3CPT
    If GOK<1  Return : Endif
    #-----
Return

$APRES_CRE
    If !GIMPORT & !GWEBSERV & GTRACE<>""
        If dim(GTRAVT)>0 GTRAVT=mess(39,7750,1)-[F:SMH]VCRNUM Endif
        Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
        If dim(GTRAVT)>0 Raz GTRAVT Endif
    Endif

    If !GVTMOD : Gosub LIENS : Endif
Return

$APRES_MOD
    If !GIMPORT & !GWEBSERV & GTRACE<>""
        Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
    Endif

    Gosub LIENS
Return

$AB_CREATION
    Effzo [M:SMO0]VCRNUM
    If !GIMPORT & !GWEBSERV & GTRACE<>""
        Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
    Endif
Return

$AB_MODIF
    If !GIMPORT & !GWEBSERV & GTRACE<>""
        Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
    Endif
Return


$APRES_MODIF
    If GRELITSMO
        Gosub RELIT From GOBJSUB
        Raz GRELITSMO
        OK=0
    Endif
Return

$ABANDON
Local Integer WRET
    Actzo [M:SMO0]VCRNUM
    Call DELSTOSORW(-1,-1,"SMO1",[M:SMO0]STOFCY,WRET) From STKSOR
Return

$FERME
# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATSMO) > 0
   Kill GCTRDATSMO
Endif
Raz GORITITCOL                                         # Ana

Kill GRELITSMO
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
Return


###############################                         # Ana   deb
$CHARG_PARAM
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"SRT",2,GSMONUM) From TRTX3CPT          # hcb 50197
# en import test il ne faut pas controler les compteurs   # hcb 090205 28275
If dim([M:IMP2]TEST)>0
   If [M:IMP2]TEST = 2
      Return
   Endif
Endif
Local Integer LRET
# Récupération des codes compteur et effacement fichier de travail
If clalev ([F:TCA])<=0
   Local File TABCOUAFF [TCA]
Endif
# Compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif
GSTKCPTMAN(10) = [F:TCA]MANCOU(10) # Cpt des sorties diverses
GSTKCPT   (10) = [F:TCA]CODNUM(10)
#Controle compteur pièce sortie diverse
Call CTRCPT(GSTKCPT(10),type([M:SMO0]VCRNUM), LRET) From STKLIB
If LRET<>0
   GMESSAGE = mess(242,199,1)
   GERR = 1
   GOK  = 0
   Return
Endif
Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & !GVTMOD & dim([M:SMO1]CCE1)>0
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT02"+GSMONUM+"1"                  # hcb 50197
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:SMO1]NBLIG=0
    [M:SMO1]NBLIG=1 : Affzo [SMO1]5 : Effzo [SMO1]5
  Endif
Endif
Raz GSOC_UPDFLG
Return

$GRISE
# Accès à un document créé en multi-dépôt avec une transaction mono-dépôt
# --> pas d'application du mono-dépôt
If [F:SMH]WRHE="" & GWRHOBY=2
   GWRHOBY=1
   #--- Bug 62402
   #Call MESSAGE(mess(351,184,1)) From GESECRAN
   If [M]STOFCY<>[F:FCY]FCY : Read [FCY]FCY0=[M]STOFCY : Endif
   If [F:FCY]WRHGES=2 : Call MESSAGE(mess(351,184,1)) From GESECRAN : Endif
   #---
Endif
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#

$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]STOFCY<>[F:FCY]FCY
   Read [FCY]FCY0=[M]STOFCY
Endif
If [F:FCY]WRHGES=2
   If find(GREP,"C","D")
      Actzo [M:SMO0]WRHE
      If GWRHOBY=2
         Diszo [M:SMO1]WRH
      Else
         Actzo [M:SMO1]WRH
      Endif
   Elsif [M:SMO0]WRHE<>""
      Diszo [M:SMO0]WRHE
      Diszo [M:SMO1]WRH
   Else
      Actzo [M:SMO0]WRHE
      Actzo [M:SMO1]WRH
   Endif
Else
  Raz   [M:SMO0]WRHE
  Grizo [M:SMO0]WRHE
  Grizo [M:SMO1]WRH
Endif
Return

