#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################################
# UUMGINISAL08  Moulinette de Migration des factures         Module Ventes #
#                                                                          #
# Migration en V6 :                                                        #
# ---------------                                                          #
# Validation des masques SIH et ouverture                                  #
#                                                                          #
# Pour toutes les versions                                                 #
# ------------------------                                                 #
# Détail devis : SINVOICED                                                 #
# --------------------------                                               #
# Alim. SALFCY à partir de l'entête si différence                          #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  #Call ORATRA From ORATRA
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGINISAL08") From LECFIC
  Endif

  #Call RAZ_UUMGINISAL08(DOSSIER)
  Call MAJ_UUMGINISAL08(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ORATRA From ORATRA
  #Call ARRET From TIMING
Endif
End


###################################################################################
Subprog MAJ_UUMGINISAL08(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer TOTNBR
Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N = no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION = val(CVERSION)
Endif

Local Char WNAMSIHM,WNAMSIDM,WNAMSIVM
Call MIGTABNAME (DOSSIER,"SINVOICE",WNAMSIHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SINVOICEV",WNAMSIVM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SINVOICED",WNAMSIDM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMSIHM,"fde",DOSSIER),0)<=0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSIDM,"fde",DOSSIER),0)<=0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSIVM,"fde",DOSSIER),0)<=0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",2,ERR) From TRTMIG : #2=En cours

###################

Call ECR_TIME("UUMGINISAL08 Sales Invoice Process : Update SINVOICE-V-D") From DOSSUB
Call ECR_TRACE("UUMGINISAL08 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG

#----- SINVOICEV => TOTNBR= Number of lines  -----#
Call MIGGETTOTNBR (DOSSIER,"SINVOICEV",TOTNBR,ERR) From TRTMIG
Trbegin [AMY]
Call MIGSTKTOTNBR (DOSSIER,"UUMGINISAL08",TOTNBR,ERR) From TRTMIG
Commit

#----- Ouverture des fichiers -----#
If clalev([F:SIHM]) = 0 : Local File =DOSSIER+"."+WNAMSIHM    [SIHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SIVM]) = 0 : Local File =DOSSIER+"."+WNAMSIVM    [SIVM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SIDM]) = 0 : Local File =DOSSIER+"."+WNAMSIDM    [SIDM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NBLUS, NBCOMMIT
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, NBCOMMIT

# Validation des écrans
# Issue 109695/109651 - 20150729 by LD : Error VALDOS for historical folder
Local Char WHISTFOLD(GLONADS)
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    WHISTFOLD=[F:ADS]DOSSIER
Else
    WHISTFOLD=[F:ADS]DOSREF
Endif

# Issue 106947 - 20150811 by LD : Migration of historic folder
# Passage en V6
If VERSION<GMIGX3VER60
    Local Char WHISTFOLD(GLONADS)
    If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
        WHISTFOLD=[F:ADS]DOSSIER
    Else
        WHISTFOLD=[F:ADS]DOSREF
    Endif

    #Call VALIDDIRECT ("SIH0",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SIH1",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SIH2",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SIH4",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SIHV",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Local Mask =[F:ADS]DOSSIER+".SIH0" [SIH0]
    #Local Mask =[F:ADS]DOSSIER+".SIH1" [SIH1]
    #Local Mask =[F:ADS]DOSSIER+".SIH2" [SIH2]
    #Local Mask =[F:ADS]DOSSIER+".SIH4" [SIH4]
    #Local Mask =[F:ADS]DOSSIER+".SIHV" [SIHV]

    Call VALIDDIRECT ("SIH0",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SIH1",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SIH2",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SIH4",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SIHV",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL08",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Local Mask =WHISTFOLD+".SIH0" [SIH0]
    Local Mask =WHISTFOLD+".SIH1" [SIH1]
    Local Mask =WHISTFOLD+".SIH2" [SIH2]
    Local Mask =WHISTFOLD+".SIH4" [SIH4]
    Local Mask =WHISTFOLD+".SIHV" [SIHV]
Endif
# Issue 106947 - 20150811 by LD

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGINISAL08",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG

If NBCOMMIT=0
  #----- Suppression des incohérences entre tables avant migration -----#
  Gosub TRT_SQL
  If GOK<1 : Goto FIN : Endif
  Trbegin [AMY]
  NBLUS=TOTNBR
  NBCOMMIT=TOTNBR
  Call MIGSTKKEY (DOSSIER,"UUMGINISAL08",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
  Commit
Endif

$FIN
Close Local File [SIVM], [SIDM], [SIHM]

Call ECR_TIME("UUMGINISAL08 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

Call MIGTRTEND (DOSSIER,"UUMGINISAL08") From TRTMIG
End

##########################################################################
Subprog RAZ_UUMGINISAL08(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : # N= no module
  End
Endif

Local Char WNAMSIHM,WNAMSIDM,WNAMSIVM
Call MIGTABNAME (DOSSIER,"SINVOICE",WNAMSIHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SINVOICEV",WNAMSIVM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SINVOICED",WNAMSIDM,ERR) From TRTMIG
If ERR : End : Endif

If filinfo(filpath("FIL",WNAMSIHM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSIDM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSIVM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGINISAL08",ERR) From TRTMIG

End
########################################################################
#----- Suppression des incohérences entre tables avant migration -----#
########################################################################
$TRT_SQL

 #-----  Déclaration des variables -----#

 Call DEBTRANS From GLOCK
 Gosub SET_FIRST From TRTFIRST

 Trbegin [SIDM]
 GOK = 1

 Gosub TRT_SQL1

 If GOK<1
  Rollback
 Else
  Commit
 Endif

Gosub UNSET_FIRST From TRTFIRST

Return

########################################################################
# Mise à jour SALFCY SINVOICED à partir de SALFCY SINVOICEV
########################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL

REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSIDM+" SET SALFCY_0="
REQSQL(1)="(SELECT SIV.SALFCY_0 FROM"-DOSSIER+"."+WNAMSIVM+" SIV Where SIV.NUM_0="+WNAMSIDM+".NUM_0)"
REQSQL(2)=" WHERE "+WNAMSIDM+".SALFCY_0<>(SELECT SIV.SALFCY_0 From"-DOSSIER+"."+WNAMSIVM+" SIV Where SIV.NUM_0="+WNAMSIDM+".NUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQSQL

Onerrgo
Return
###################################################################################################
$ERR_SQL
 GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 GOK=0
Resume
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGINISAL08(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGINISAL08(APPLI)
End

