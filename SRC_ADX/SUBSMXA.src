#<AdxTL>@(#)5.0.0.0 $Revision$
 #---------------------------------------------------------------------------#
# Actions de l'objet SMX > Modification caractéristiques d'un lot           #
#---------------------------------------------------------------------------#

######################################################################
$DEFTRANS
Local Shortint OUVFICFLG

If GFONC1 <> "GESSMX"  : Raz GFLAG  : Endif
If GFLAG  <> ""
    If clalev([F:SRT])=0 : Local File STKTRS [SRT] : Endif
    Read [F:SRT]SRT0=4;GFLAG
    If fstat | [F:SRT]ENAFLG = 1 | [F:SRT]CHANGECOD = 2  : Raz GFLAG : Goto FIN_DEFTRANS : Endif
    If [F:SRT]ACSCOD <> "" & GPROFIL <> GSUPER
        If clalev([F:ACC])=0
            Local File ACCES  [ACC]
            OUVFICFLG = 1
        Endif
        Read [ACC]CODACC=GUSER;[F:SRT]ACSCOD
        If fstat | [F:ACC]EXEC <> 2 : Raz GFLAG : Goto FIN_DEFTRANS : Endif
    Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG = 1 : Close File [ACC] : Raz OUVFICFLG : Endif
Return

######################################################################
$VARIANTE
If clalev([F:SRT])=0  : Local File STKTRS [SRT] : Endif
Read [SRT]SRT0=4;[F:AWI]TRN
If fstat | [F:SRT]ENAFLG <> 2 | [F:SRT]CHANGECOD = 2
    OK = 0
Endif
Return

######################################################################
$SETTRANS
If clalev([F:SRT])=0  : Local File STKTRS [SRT] : Endif
Read [SRT]SRT0=4;GFLAG

#MAE, le 29/01/08, GRP_SITE
GGRPFCY = [F:SRT]GFY
GSMXNUM = [F:SRT]SRTNUM                      # hcb 50197
Return


######################################################################
$OUVRE
Local Integer LRET
Local Char    XCRITERE(250)

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

Global Integer GSMXTRACE
Raz GSMXTRACE
GSMXTRACE = 4


Global Integer GWFEALOTLEV                          # hcb 71276
GWFEALOTLEV  = GFEALOTLEV                           # hcb 71276


GSRTNUM = GFLAG

If  clalev([ITFD])  <= 0 : Local File ITMFACILIT [ITFD] : Endif
If  clalev([M:STW]) <= 0 : Local Mask STOWORK    [STW]  : Endif
If  clalev([M:STWX])<= 0 : Local Mask STOWORK    [STWX] : Endif
If !clalev([M:SVW])      : Local Mask STOVALWORK [SVW]  : Endif
If !clalev([M:SDPA])     : Local Mask SAIDECPRI  [SDPA] : Endif
If !clalev([F:STO])      : Local File STOCK      [STO]  : Endif
If !clalev([F:STL])      : Local File STOLOT     [STL]  : Endif
If !clalev([ECS])        : Local File ECCSTA     [ECS]  : Endif   # hcb 71276
If !clalev([EVL])        : Local File ECCVAL     [EVL]  : Endif   # hcb 71276
If !clalev([STS])        : Local File STOSER     [STS]  : Endif                # hcb 110327

#--- TS Ety
If !clalev([F:STA])      : Local File STOALL     [STA]  : Endif

GFCY=GFCYDEF(7)                                                # Ana
Gosub CHARG_PARAM                                              # Ana

Return

######################################################################
$FILTRE
Default File [SLH]
FILTSUP = "[F]CHANGECOD=1"
Return

######################################################################
$LIENS

Local Integer I
Local Integer LRET

[M:SMX0]VCRTYP = 35

If [M:SMX1]REFPEROLD  <> [0/0/0] : [M:SMX1]XREFPEROLD  = [M:SMX1]REFPEROLD  : Endif
If [M:SMX1]SHLDATOLD  <> [0/0/0] : [M:SMX1]XSHLDATOLD  = [M:SMX1]SHLDATOLD  : Endif
If [M:SMX1]USRFLD4OLD <> [0/0/0] : [M:SMX1]USRFLD4OLX  = [M:SMX1]USRFLD4OLD : Endif
If [M:SMX1]DLUDATOLD  <> [0/0/0] : [M:SMX1]XDLUDATOLD  = [M:SMX1]DLUDATOLD  : Endif # v6per
If [M:SMX1]NEWLTIDATO <> [0/0/0] : [M:SMX1]XNEWLTIDAT  = [M:SMX1]NEWLTIDATO : Endif # v6per
#                                                                          # hcb dlu deb
Read [ITM]ITM0=[M:SMX0]ITMREF
If fstat
   Raz [F:ITM]
Endif
If [F:ITM]EXYMGTCOD = 1 | [F:ITM]EXYMGTCOD= 3 | [F:ITM]EXYMGTCOD= 4
    Raz [M:SMX1]DLULTIOLD
    Raz [M:SMX1]DLULTI
Else
    If [M:SMX1]DLUDATOLD <> [0/0/0]
       [M:SMX1]DLULTIOLD    =  nday([M:SMX1]XDLUDATOLD) -nday([M:SMX1]XREFPEROLD)
    Endif
    If [M:SMX1]DLUDAT <> [0/0/0]
       [M:SMX1]DLULTI       =  nday([M:SMX1]DLUDAT) -nday([M:SMX1]REFPER)
    Endif
Endif
#                                                                           # hcb dlu fin

Diszo [M:SMX0]5
Actzo [M:SMX0]VCRNUM
Diszo [M:SMX1]10-20

Affzo [M:SMX0]    # Issue 99277 - 2018-09-03 by MAE : Responsive UI
Affzo [M:SMX1]

If GFCY<>[M:SMX0]STOFCY GFCY=[M:SMX0]STOFCY: Gosub CHARG_PARAM : Endif    # Ana

Call STKCTRIPT( [M:SMX0]IPTDAT, [M:SMX0]STOFCY, "1") From STKLIB
If GERR=1
    Call ERREUR(GMESSAGE) From GESECRAN
    Raz GERR
    Raz GMESSAGE
    Grizo [M:SMX0]5
Elsif GERR=2
    Call MESSAGE(GMESSAGE) From GESECRAN
    Raz GERR
    Raz GMESSAGE
    Grizo [M:SMX0]5
Endif

If dim([M:SMX0]SLO)>0                                                       # hcb unicite
   If [F:ITM]ITMREF <> [M:SMX0]ITMREF
      Read [ITM]ITM0=  [M:SMX0]ITMREF
      If fstat
         Raz [ITM]
      Endif
   Endif
   If GFEALOTLEV = 2 | [F:ITM]LOTMGTCOD <> 4                                # hcb unicite
      Local Char WINVSLO                                                    # hcb unicite
      WINVSLO="-K:"+num$(GLONSLO)+"X"                                       # hcb unicite
      Chgfmt [M:SMX0]SLO  With WINVSLO                                      # hcb unicite
   Else
      Local Char WINVSLO                                                    # hcb unicite
      WINVSLO="K:"+num$(GLONSLO)+"X"                                        # hcb unicite
      Chgfmt [M:SMX0]SLO  With WINVSLO                                      # hcb unicite
   Endif                                                                    # hcb unicite
   Raz [M:SMX0]WFEALOTLEV                                                   # hcb unicite
   If [F:ITM]LOTMGTCOD=4                                                    # hcb unicite
      [M:SMX0]WFEALOTLEV = mess(90,187,1) + " : " + mess(GFEALOTLEV,2773,1) # hcb unicite
      Affzo [M:SMX0]WFEALOTLEV                                              # hcb unicite
   Endif                                                                    # hcb unicite
Endif                                                                       # hcb unicite
#                                                           # Hcb 71276 deb
If dim([M:SMX1]ECCVALMAJ)>0
   Local Char WINVECC
   If [F:ITM]ITMREF <> [M:SMX0]ITMREF
      Read [ITM]ITM0=  [M:SMX0]ITMREF
      If fstat
         Raz [ITM]
      Endif
   Endif
   If [M:SMX1]ECCVALMAJ <> ""
      Read [ECS]ECS0=[M:SMX0]ITMREF;[M:SMX1]ECCVALMAJ
      If fstat
         Raz [F:ECS]
      Endif
      [M:SMX1]ECCSTA       = [F:ECS]ECCSTA
      [M:SMX1]ECCSTAOLD    = [F:ECS]ECCSTA
   Endif
   Case [F:ITM]ECCSTO
      When 0,1
          Grizo [M:SMX1]ECCVALMAJ
          Grizo [M:SMX1]ECCVALMIN
      When  2
          Grizo [M:SMX1]ECCVALMIN
      When Default
   Endcase
Endif
#                                                           # Hcb 71276 fin


Return


######################################################################
$RAZCRE
If GFCY <> GFCYDEF(7)                               # Ana
   GFCY =  GFCYDEF(7) : Gosub CHARG_PARAM           # Ana
Endif                                               # Ana

Actzo [M:SMX0]5-10
If GSTKCPTMAN(5) <> 2
    Effzo [M:SMX0]VCRNUM
    Diszo [M:SMX0]VCRNUM
Endif
[M:SMX0]VCRTYP = 35
[M:SMX0]TRSFAM = [F:SRT]TRSFAMDEF
Affzo [M:SMX0]TRSFAM
Actzo [M:SMX1]10
Diszo [M:SMX1]15
[M:SMX0]CHANGECOD = 1

If GFEALOTLEV = 2                            # hcb unicite
   Local Char WINVSLO                        # hcb unicite
   WINVSLO="-K:"+num$(GLONSLO)+"X"           # hcb unicite
   Chgfmt [M:SMX0]SLO  With WINVSLO          # hcb unicite
Endif                                        # hcb unicite

Return


######################################################################
$SETBOUT
Call VIREBOUT(CHAINE,"A") From GOBJET
Call VIREBOUT(CHAINE,"D") From GOBJET
# Menu Options / Visu transaction
CHMEN += "t"

#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
Return

######################################################################
$EXEBOUT
Return

######################################################################
$VERIF_CRE
#                                                    # hcb 72276
# on vérifie si quelque chose à été modifié
If (dim([M:SMX1]POT) > 0 & [M:SMX1]POT = [M:SMX1]POTOLD) &
&  (dim([M:SMX1]ECCVALMAJ) > 0 & [M:SMX1]ECCVALMAJ = [M:SMX1]ECCVALMAJOLD) &
&  (dim([M:SMX1]ECCVALMIN) > 0 & [M:SMX1]ECCVALMIN = [M:SMX1]ECCVALMINOLD) &
&  [M:SMX1]BPSLOT    = [M:SMX1]BPSLOTOLD  &
&  [M:SMX1]REFPER    = [M:SMX1]REFPEROLD  &
&  [M:SMX1]SHL       = [M:SMX1]SHLOLD     &
&  [M:SMX1]SHLDAT    = [M:SMX1]SHLDATOLD  &
&  [M:SMX1]SHLUOM    = [M:SMX1]SHLUOMOLD  &
&  [M:SMX1]DLU       = [M:SMX1]DLUOLD     &
&  [M:SMX1]DLUDAT    = [M:SMX1]DLUDATOLD  &
&  [M:SMX1]SHLLTI    = [M:SMX1]SHLLTIOLD  &
&  [M:SMX1]SHLLTIUOM = [M:SMX1]SHLLTIUOMO &
&  [M:SMX1]NEWLTIDAT = [M:SMX1]NEWLTIDATO &
&  [M:SMX1]USRFLD1   = [M:SMX1]USRFLD1OLD &
&  [M:SMX1]USRFLD2   = [M:SMX1]USRFLD2OLD &
&  [M:SMX1]USRFLD3   = [M:SMX1]USRFLD3OLD &
&  [M:SMX1]USRFLD4   = [M:SMX1]USRFLD4OLD
    GMESSAGE = mess(371,197,1)
    OK = 0
Endif
Return

######################################################################
$VERIF_MOD
Return

######################################################################
$INICRE
Local Integer LSTAT
Local Char    LNUM

# Création du numéro de document si nécessaire
If GSTKCPTMAN(5) <> 2 | [M:SMX0]VCRNUM = ""
    Call NUMERO(GSTKCPT(5), [M:SMX0]STOFCY, [M:SMX0]IPTDAT, "", LNUM, LSTAT) From SUBANM
        If GOK<0 Return Endif
        If LSTAT=0
           [M:SMX0]VCRNUM = LNUM
           [F:SLH]VCRNUM  = LNUM
        Else
            GERR=1:GMESSAGE = mess(60,199,1)
            GOK=0
        Endif
Endif
Return

######################################################################
$CREATION
Gosub ALISTW
If !GOK : Return : Endif
Return

######################################################################
$MODIF
Return

######################################################################
$ANNULE
Return

######################################################################
$VALLIG
Return

######################################################################
$APRES_CRE
If dim(GSMXTRACE)>0 & GSMXTRACE
    Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
Endif

If [F:SRT]PRNCOD1 > 1
    Local Char WPARAM(GLONVCR)(1..3) , WVALEUR(10)
    WPARAM(1) = [M:SMX0]STOFCY
    WPARAM(2) = num$([M:SMX0]VCRTYP)
    WPARAM(3) = [M:SMX0]VCRNUM
    Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
Endif

If GFONCTION = "GESSMX"
     Gosub RELIT From GOBJSUB
Endif
Return

######################################################################
$APRES_MOD
Gosub APRES_CRE
Return

######################################################################
$APRES_MODIF
Return

######################################################################
$ABANDON
Local Integer LRET

# déverrouillage du lot
If [M:SMX0]LOT <> "" : Gosub DEVERROU From SUBSMXA : Endif

Actzo [M:SMX0]VCRNUM
Actzo [M:SMX0]10
Raz [M:SMX0]ITMREF
Return

######################################################################
$FERME
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
GFEALOTLEV  = GWFEALOTLEV                           # hcb 71276

#-----
Return

###############################################################################
# lecture lot
###############################################################################
$FILL_PAGE
If !fstat
    Effzo [M:SMX1]15-20
    [M:SMX0] = [F:STL]    # Issue 99277 - 2018-09-03 by MAE : Responsive UI
    [M:SMX1] = [F:STL]
    [M:SMX0]VCRTYP = 35
    If dim([M:SMX1]BPSLOT) > 0 : [M:SMX1]BPSLOTOLD = [M:SMX1]BPSLOT : Endif
#                                                              # hcb 71276 deb
    If dim([M:SMX1]ECCVALMAJ) > 0
       Read [ECS]ECS0=[M:SMX0]ITMREF;[M:SMX1]ECCVALMAJ
       If fstat
          Raz [F:ECS]
       Endif
       [M:SMX1]ECCSTA       = [F:ECS]ECCSTA
       [M:SMX1]ECCSTAOLD    = [F:ECS]ECCSTA
       [M:SMX1]ECCVALMAJOLD = [M:SMX1]ECCVALMAJ
       [M:SMX1]ECCVALMINOLD = [M:SMX1]ECCVALMIN
    Endif
#                                                              # hcb 71276 fin

    If dim([M:SMX1]POT) > 0 : [M:SMX1]POTOLD = [M:SMX1]POT : Endif
    If [M:SMX1]REFPER <> [0/0/0]
       [M:SMX1]REFPEROLD  = [M:SMX1]REFPER
       [M:SMX1]XREFPEROLD = [M:SMX1]REFPER
    Endif
    [M:SMX1]SHLOLD     = [M:SMX1]SHL
    If [M:SMX1]SHLDAT <> [0/0/0]
       [M:SMX1]SHLDATOLD  = [M:SMX1]SHLDAT
       [M:SMX1]XSHLDATOLD = [M:SMX1]SHLDAT
    Endif
#                                           v6per deb
    [M:SMX1]SHLUOMOLD  = [M:SMX1]SHLUOM
    [M:SMX1]DLUOLD     = [M:SMX1]DLU
    [M:SMX1]SHLLTIOLD  = [M:SMX1]SHLLTI
    [M:SMX1]SHLLTIUOMO = [M:SMX1]SHLLTIUOM
    [M:SMX1]NEWLTIDATO = [M:SMX1]NEWLTIDAT
    If [M:SMX1]DLUDAT <> [0/0/0]
       [M:SMX1]DLUDATOLD  = [M:SMX1]DLUDAT
       [M:SMX1]XDLUDATOLD = [M:SMX1]DLUDAT
    Endif
    If [M:SMX1]NEWLTIDAT <> [0/0/0]
       [M:SMX1]NEWLTIDATO = [M:SMX1]NEWLTIDAT
       [M:SMX1]XNEWLTIDAT = [M:SMX1]NEWLTIDAT
    Endif

#                                                                             # hcb dlu deb
    If [F:ITM]EXYMGTCOD = 1 | [F:ITM]EXYMGTCOD= 3 | [F:ITM]EXYMGTCOD= 4
        Raz [M:SMX1]DLULTIOLD
        Raz [M:SMX1]DLULTI
    Else
        If [M:SMX1]XDLUDATOLD <> [0/0/0]
           [M:SMX1]DLULTIOLD    =  nday([M:SMX1]XDLUDATOLD) -nday([M:SMX1]XREFPEROLD)
        Endif
        If [M:SMX1]DLUDAT     <> [0/0/0]
           [M:SMX1]DLULTI       =  nday([M:SMX1]DLUDAT)     -nday([M:SMX1]REFPER)
        Endif
    Endif
#                                                                             # hcb dlu fin

#                                           v6per fin

    [M:SMX1]USRFLD1OLD = [M:SMX1]USRFLD1
    [M:SMX1]USRFLD2OLD = [M:SMX1]USRFLD2
    [M:SMX1]USRFLD3OLD = [M:SMX1]USRFLD3
    If [M:SMX1]USRFLD4 <> [0/0/0]
       [M:SMX1]USRFLD4OLD = [M:SMX1]USRFLD4
       [M:SMX1]USRFLD4OLX = [M:SMX1]USRFLD4
    Endif
    Diszo [M:SMX0]10
    Affzo [M:SMX1]10-20
Else
    mkstat = 2
    GMESSAGE = mess(123,199,1)
Endif
Return

#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur lot/sous-lot                           #
#-----------------------------------------------------------------------#
$VERROU
Local Char MYSYMBOL(50)
If dim([M:SMX0]SLO) > 0 & GFEALOTLEV = 1                            # hcb unicite
    MYSYMBOL = "STL"+[M:SMX0]ITMREF+[M:SMX0]LOT + [M:SMX0]SLO
Else
    MYSYMBOL = "STL"+[M:SMX0]ITMREF+[M:SMX0]LOT
Endif
Lock = MYSYMBOL With lockwait = 0
If fstat
    GMESSAGE-=mess(43,197,1)-":"-[M:SMX0]LOT
    If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV = 1: GMESSAGE-=mess(456,197,1)-":"-[M:SMX0]SLO : Endif   # hcb unicite
    GMESSAGE+="\"+mess(10,100,1)
    mkstat = 2
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur lot/sous-lot                                #
#-----------------------------------------------------------------------#
$DEVERROU
Local Char MYSYMBOL(50)
If dim([M:SMX0]SLO) > 0 & GFEALOTLEV = 1
    MYSYMBOL = "STL"+[M:SMX0]ITMREF+[M:SMX0]LOT + [M:SMX0]SLO
Else
    MYSYMBOL = "STL"+[M:SMX0]ITMREF+[M:SMX0]LOT
Endif
Unlock=MYSYMBOL
Return


################################################
# Alimente le masque STOWORK
# Ce sous programme est à appeler sur l'action:
#    CREATION
################################################
$ALISTW

Local Integer I, LRET
Local Char LUSCAV
Local Char LFMT
Local Integer LMODIF
Local Decimal LCOE
Local Integer LRET
#--- Bug 77900
#--- Issue 113196
#Local Decimal WCUM(300,5)
Local Decimal WCUM(dim([M:STW]STOCOU),5)
#---

# Chargement des lignes à sortir
Raz [STW]
Raz [M:STW]NBLIG
Raz [STWX]
Raz [M:STWX]NBLIG

# lecture du stock
XCRITERE  = "STOFCY=[M:SMX0]STOFCY"
XCRITERE += "&ITMREF=[M:SMX0]ITMREF"
XCRITERE += "&LOT=[M:SMX0]LOT"
# si article géré avec s/lot
If [F:ITM]LOTMGTCOD = 4 & dim([M:SMX0]SLO) > 0 & GFEALOTLEV <> 2 : XCRITERE += "&SLO=[M:SMX0]SLO" : Endif   # hcb unicite

For [F:STO]STO3 Where evalue(XCRITERE)

    #--- Bug 77900
    WCUM(I,0) = [F:STO]CUMALLQTY
    WCUM(I,1) = [F:STO]CUMALLQTA
    WCUM(I,2) = [F:STO]CUMWIPQTY
    WCUM(I,3) = [F:STO]CUMWIPQTA
    WCUM(I,4) = [F:STO]STOCOU
    I+=1
    #--- Issue 113196
    #If I>299 : Raz GOK : Break : Endif
    If I>dim([M:STW]STOCOU)-1 : Raz GOK : Break : Endif
    #---
    #---
#                                                         # hcb 110327 deb
   If [F:ITM]SERMGTCOD = 4
      Gosub  RECH_SERIES_GLOBALE From SUBSMXA
   Else
   #                                                         # hcb 110327 fin
       Call ADDSTOWORKLIN("C", "S", [F:STO]STOFCY, [F:STO]STOCOU, [F:STO]QTYPCU, [F:STO]QTYSTU,"","",LRET) From STKINT  # hcb X3-46081
       If LRET <> 0 : Raz GOK : Break : Endif
   Endif                        # hcb 110327
Next
# FGR 09/02/2010 : X3SUIVI60986
If LRET <> 0 Then
  Return
Endif

# Initialisation de l'en-tête (apres l'ajout de ligne car le transclasse de STL vers STW surcharge la pièce)
[M:STW]STOFCY     = [M:SMX0]STOFCY      # Site
[M:STW]TRSTYP     = 2                   # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:SMX0]VCRTYP      # Type pièce (M.701)
[M:STW]VCRNUM     = [M:SMX0]VCRNUM      # Numéro pièce
[M:STW]VCRLIN     = 0                   # Numero ligne pièce
[M:STW]ITMREF     = [M:SMX0]ITMREF      # Article
[M:STW]MVTDES     = [M:SMX0]MVTDES      # Désignation mouvement
[M:STW]PJT        = [M:SMX0]PJT         # Affaire
[M:STW]TRSFAM     = [M:SMX0]TRSFAM      # Famille mouvement
[M:STW]IPTDAT     = [M:SMX0]IPTDAT      # Date imputation
[M:STW]TRAFLG     = 0

# sauvegarde STOWORK (on va repartir du même modèle pour les entrées)
Transmask [M:STW] To [M:STWX] # Issue 25606_Transmask [M:STWX] = [M:STW]

    Gosub ALIVALWORK From STKVALMAJ

# mise à jour des sorties
Call MAJ_STOCK From STKMAJ
If GOK = 0 : Return : Endif

# CCC (29/03/07) Bug 40553 (suite du 30922)
[M:STWX]PRIORDH = [M:STW]ISSAMTVAL/sum([M:STWX]QTYSTU)

# chargement des lignes à entrer, on repart du modèle sauvegardé
Raz [STW]
Raz [M:STW]NBLIG
Transmask [M:STWX] To [M:STW] # Issue 25606_Transmask [M:STW] = [M:STWX]

# seul le type de mouvement change dans l'entête
[M:STW]TRSTYP     = 1                   # Type mouvement (M.704)

# on applique les nouvelles caractéristiques
For I = 0 To [M:STWX]NBLIG - 1
    [M:STW]MAJTYP(I)       = "E"
    If dim([M:SMX1]POT) > 0
        [M:STW]POT(I) = [M:SMX1]POT
        [M:STW]QTYSTUACT(I)  = [M:STW]QTYSTU(I) * [M:STW]POT(I)/100
    Else
       [M:STW]QTYSTUACT(I)   = [M:STW]QTYSTU(I)
    Endif
   If dim([M:SMX1]ECCVALMAJ) > 0 : [M:STW]ECCVALMAJ (I) = [M:SMX1]ECCVALMAJ : Endif         # hcb 71276
   If dim([M:SMX1]ECCVALMIN) > 0 : [M:STW]ECCVALMIN (I) = [M:SMX1]ECCVALMIN : Endif         # hcb 71276
    [M:STW]BPSLOT   (I)      = [M:SMX1]BPSLOT
    [M:STW]REFPER   (I)      = [M:SMX1]REFPER
    [M:STW]SHL      (I)      = [M:SMX1]SHL
    [M:STW]SHLDAT   (I)      = [M:SMX1]SHLDAT
    [M:STW]SHLUOM   (I)      = [M:SMX1]SHLUOM     # v6per
    [M:STW]DLU      (I)      = [M:SMX1]DLU        # v6per
    [M:STW]DLUDAT   (I)      = [M:SMX1]DLUDAT     # v6per
    [M:STW]SHLLTI   (I)      = [M:SMX1]SHLLTI     # v6per
    [M:STW]SHLLTIUOM(I)      = [M:SMX1]SHLLTIUOM  # v6per
    [M:STW]NEWLTIDAT(I)      = [M:SMX1]NEWLTIDAT  # v6per
    [M:STW]USRFLD1  (I)      = [M:SMX1]USRFLD1
    [M:STW]USRFLD2  (I)      = [M:SMX1]USRFLD2
    [M:STW]USRFLD3  (I)      = [M:SMX1]USRFLD3
    [M:STW]USRFLD4  (I)      = [M:SMX1]USRFLD4
    If [F:SRT]PRNCOD1 = 2
        If [M:STW]PCU(I) = [F:ITM]STU
            Call CTLUOM ([M:SMX0]ITMREF, 3, "", [M:STW]STU(I), LCOE, LUSCAV, LFMT, LMODIF) From STKACT
        Else
            Call CTLUOM ([M:SMX0]ITMREF, 3, "", [M:STW]PCU(I), LCOE, LUSCAV, LFMT, LMODIF) From STKACT
        Endif
        #--- Bug 59444
        #[M:STW]LBENBR(I) = int([M:STW]QTYPCU(I))
        If int([M:STW]QTYPCU(I))=[M:STW]QTYPCU(I)
           [M:STW]LBENBR(I) = [M:STW]QTYPCU(I)
        Else
           [M:STW]LBENBR(I) = int([M:STW]QTYPCU(I))+1
        Endif
        #---
        [M:STW]LBEFMT(I) = LFMT
    Endif
Next I

Gosub ALIVALWORK From STKVALMAJ


# mise à jour des entrées
Call MAJ_STOCK From STKMAJ

#--- Bug 77900
For I=0 To dim([M:STW]STOCOU)-1
   If [M:STW]STOCOU(I)=0 : Break : Endif

   If WCUM(I,0)<>0 | WCUM(I,2)<>0
      Readlock [STO]STO0=[M:STW]STOFCY;[M:STW]STOCOU(I)
      If !fstat
         [F:STO]CUMALLQTY += WCUM(I,0)
         [F:STO]CUMALLQTA += WCUM(I,1)
         [F:STO]CUMWIPQTY += WCUM(I,2)
         [F:STO]CUMWIPQTA += WCUM(I,3)
         Rewrite [STO]
         If fstat
            GMESSAGE-=mess(50,176,1): GOK=0 : Break
         Elsif WCUM(I,0)<>0
            Update [STA] Where STOCOU=WCUM(I,4) With STOCOU=[F:STO]STOCOU
            If fstat
               GMESSAGE-=mess(50,176,1): GOK=0 : Break
            Endif
         Endif
      Endif
   Endif
Next I
Raz [M:STW]
#---

# controle que tous les lot/souslot soient correctes dans le cas "niveaux lot"   # hcb unicite
If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV = 2  & GOK                                                  # hcb unicite
   Local Decimal WPOT
   Raz WPOT
   If dim([M:SMX1]POT) > 0
      WPOT  = [M:SMX1]POT
   Endif
#                                                          # hcb 71276 deb
   Local Char    WMAJ(GLONECS)
   Local Char    WMIN(GLONEVL)
   Raz WMAJ
   Raz WMIN
   If dim([M:SMX1]ECCVALMAJ) > 0
      WMAJ = [M:SMX1]ECCVALMAJ
   Endif
   If dim([M:SMX1]ECCVALMIN) > 0
      WMIN = [M:SMX1]ECCVALMIN
   Endif
#                                                          # hcb 71276 fin plus lignes plus bas

   Update [STL] Where ITMREF = [M:SMX0]ITMREF & LOT = [M:SMX0]LOT  &
&         (POT     <> WPOT            | REFPER    <> [M:SMX1]REFPER    | SHL       <>[M:SMX1]SHL        | SHLDAT  <> [M:SMX1]SHLDAT |
&          SHLUOM  <> [M:SMX1]SHLUOM  | DLU       <> [M:SMX1]DLU       | DLUDAT    <> [M:SMX1]DLUDAT    |
&          SHLLTI  <> [M:SMX1]SHLLTI  | SHLLTIUOM <> [M:SMX1]SHLLTIUOM | NEWLTIDAT <> [M:SMX1]NEWLTIDAT |
&          ECCVALMAJ <> WMAJ            | ECCVALMIN <> WMIN |
&          USRFLD1 <> [M:SMX1]USRFLD1 | USRFLD2   <> [M:SMX1]USRFLD2   | USRFLD3   <> [M:SMX1]USRFLD3   | USRFLD4 <>[M:SMX1]USRFLD4)
&  With    USRFLD1   = [M:SMX1]USRFLD1,   USRFLD2 = [M:SMX1]USRFLD2, USRFLD3 = [M:SMX1]USRFLD3, USRFLD4   = [M:SMX1]USRFLD4,
&          REFPER    = [M:SMX1]REFPER,    SHL     = [M:SMX1]SHL,     SHLDAT  = [M:SMX1]SHLDAT,  SHLUOM    = [M:SMX1]SHLUOM,
&          DLU       = [M:SMX1]DLU,       DLUDAT  = [M:SMX1]DLUDAT,  SHLLTI  = [M:SMX1]SHLLTI,  SHLLTIUOM = [M:SMX1]SHLLTIUOM,
&          ECCVALMAJ = WMAJ,              ECCVALMIN  = WMIN,
&          NEWLTIDAT = [M:SMX1]NEWLTIDAT, POT     = WPOT
   If fstat
      GMESSAGE-=mess(50,176,1)
      mkstat = 2
   Endif
Endif

