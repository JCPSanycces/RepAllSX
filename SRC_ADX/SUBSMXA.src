$CHARG_PARAM
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
# récupération des codes compteur et effacement fichier de travail
If clalev ([F:TCA])<= 0 : Local File TABCOUAFF  [TCA]  : Endif
Local Integer LRET
# compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif
GSTKCPTMAN(5) = [F:TCA]MANCOU(5) # compteur modif lot
GSTKCPT   (5) = [F:TCA]CODNUM(5)
# controle compteur pièce modif lot
Call CTRCPT(GSTKCPT(5),type([M:SMX0]VCRNUM), LRET) From STKLIB
If LRET <> 0
    GMESSAGE = mess(242,199,1)
    GERR = 1
    GOK  = 0
    Return
Endif
GSTKCPTMAN(0)=[F:TCA]MANCOU(0)
GSTKCPT(0)   =[F:TCA]CODNUM(0)
GSTKCPTMAN(2)=[F:TCA]MANCOU(2)
GSTKCPT(2)   =[F:TCA]CODNUM(2)

Return

#                                                                              # hcb 110327 deb
$RECH_SERIES_GLOBALE
If clalev([F:STS])  = 0  Local File STOSER      [STS]  Endif
Local Char    WSERDEB(GLONSER)
Local Char    WSERFIN(GLONSER)
Local Char    WSER   (GLONSER)
Local Decimal WQTY
Raz WSERDEB
Raz WSERFIN
Raz WSER
Raz WQTY
Filter [STS] Where [F:STS]ITMREF = [F:STO]ITMREF &
&                  [F:STS]STOCOU = [F:STO]STOCOU
&               Order By Key STS3
   For [STS]
       If WSERDEB    = ""
          WSERDEB = [F:STS]SERNUM
          WSERFIN = [F:STS]SERNUM
          WQTY    = 1
       Else
          WSER = WSERFIN
          Call PLUS_UN(WSER,WSER,LRET) From STKLIB
          If WSER    =  [F:STS]SERNUM
             WSERFIN =  [F:STS]SERNUM
             WQTY    += 1
          Else
             Call ADDSTOWORKLIN("C", "S", [F:STO]STOFCY, [F:STO]STOCOU, WQTY, WQTY,WSERDEB,WSERFIN, LRET) From STKINT
             WSERDEB = [F:STS]SERNUM
             WSERFIN = [F:STS]SERNUM
             WQTY    = 1
          Endif
       Endif
   Next
   If WSERDEB <> ""
      Call ADDSTOWORKLIN("C", "S", [F:STO]STOFCY, [F:STO]STOCOU, WQTY, WQTY,WSERDEB,WSERFIN, LRET) From STKINT
      Raz WSERDEB
      Raz WSERFIN
      Raz WQTY
   Endif
Filter [STS]
Return

#                                                                              # hcb 110327 fin

