######################################################################################
Subprog C_ALLJOT(VALEUR)
Variable Integer VALEUR
################################################# TIVAN - 18/05/2017 - Start
  If VALEUR = 1 Then : Actzo [M]JOBPOTE : Else Effzo [M]JOBPOTE : Grizo [M]JOBPOTE : Endif
################################################# TIVAN - 18/05/2017 - Start
End


