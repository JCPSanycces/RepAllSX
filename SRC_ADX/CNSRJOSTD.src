#<AdxTL>@(#)0.0.0.0 $Revision$ 
################################################################################
#                                   CNSRJOSTD
#
#  MABOS - 27/06/13 - FQ90539 - US1737 - Référential standard jobs & positions
#  MABOS - 22/07/13 - FQ90539 - US1804 - Update inheritance by right clic
#  MABOS - 23/07/13 - FQ90539 - US1805 - Action call from GESJOT
#                                      - manage expand/collapse depending on the level of criteria
#  MABOS - 17/02/14 - FQ92896 -        - adapte to Convergence
################################################################################

$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub BOUTON
  When "APRES_MODIF": Gosub APRES_MODIF
  When Default
Endcase
Return

$OUVRE
If clalev([F:POT])=0    : Local File POSTE  [POT]   : Endif
If clalev([F:JOT])=0    : Local File JOBTYP  [JOT]   : Endif
If clalev([F:ADI])=0    : Local File ATABDIV  [ADI]   : Endif

GCHOIX = "RJO"
# Preloading - no
CHARGMT=1
Raz [M:RJO1]
# MABOS-FQ90539-US1805 - Action call from GESJOT
# call from another function, with parameters
#PARAM(1) : Group
#PARAM(2) : Profession
#PARAM(3) : Standard Job
#PARAM(4) : Legislation
If  PARAM(1) <> "" Then
  [M:RJO1]ALLUOM=1
  [M:RJO1]UOMGRPE=PARAM(1)
Endif
If PARAM(2) <> ""
  [M:RJO1]ALLGRP=1
  [M:RJO1]JOBGRPE=PARAM(2)
Endif
If PARAM(3) <> ""
  [M:RJO1]ALLJOT=1
  [M:RJO1]JOBPOTE=PARAM(3)
Endif
Gosub INI_LEG

If dim([M:RJO1]ALLLEG)>0

  If PARAM(4)<> "" Then
    [M:RJO1]LEG = PARAM(4)
    GCURLEG = [M:RJO1]LEG
  Endif

  If [M:RJO1]LEG <>""
    [M:RJO1]ALLLEG=1
  Else
    [M:RJO1]ALLLEG=2
  Endif
  [M:RJO1]WALLLEG=[M:RJO1]ALLLEG
Endif

Gosub INI_DATSTR

Return

$INI_LEG
# Init LEG by GLEGFIL - GDOSLEG
If dim([M:RJO1]LEG)>0 Then
  [M:RJO1]LEG = GLEGFIL
  GCURLEG = [M:RJO1]LEG
Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Return

$INI_DATSTR
# Init Date / GMOIPAY
If GMOIPAY=[0/0/0] Then
  [M:RJO1]DATSTR = date$
Else
  [M:RJO1]DATSTR = GMOIPAY
Endif
Return

$LECTURE
Local Char CRITERE1(250), CRITERE2(250),CRITERE3(250),CRITERE4(250)
Local Integer WI
Local Char WUOMGRP(GLONADI), WJOBGRP(GLONADI), WJOBPOT(20), WPOT(20)
Local Integer PASS, TSTFULL, WDIMTAB
Local Char WICOEMPTY(50), WICOREF(50), WICOUOMGRP(50), WICOJOBGRP(50), WICOJOT(50), WICOPOT(50)
Local Char WEMPTY(3), WLEV(1)

[L]WICOEMPTY="fantome.png"
[L]WICOREF="Book.gif"
[L]WICOUOMGRP="matierepremiere.png"
[L]WICOJOBGRP="operation.png"
[L]WICOJOT="mvt2.gif"
[L]WICOPOT=""

[L]WEMPTY="_|_" :# To order "... Not entered" at the end
[L]WDIMTAB=dim([M:RJO2]LEV)-4

Effzo [M:RJO2]

#MABOS-23/07/13-FQ90539-US1805
# manage expand/collapse depending on the level of criteria
[M:RJO1]RJOFLG=2
If [M:RJO1]ALLJOT=1 Then
  [M:RJO1]RJOFLG=6
Elsif [M:RJO1]ALLGRP=1 Then
  [M:RJO1]RJOFLG=4
Elsif [M:RJO1]ALLUOM=1 Then
  [M:RJO1]RJOFLG=3
Endif

# line Referential - starting point
nolign=1
[L]WLEV="1"
[M:RJO2]NBLIG=1
[M:RJO2]PARKEY(nolign-1)=""
[M:RJO2]KEYC(nolign-1)=[L]WLEV+"~"
Call TEXTE(51397,[M:RJO2]LIB(nolign-1)) From OBJDIV:#Référentiel des emplois
Call TEXTE(51397,[M:RJO2]LIBSH(nolign-1)) From OBJDIV:#Référentiel des emplois
Call EXPLEV(nolign-1)
[M:RJO2]ICO(nolign-1)=[L]WICOREF
[M:RJO2]LEG(nolign-1)=""
[M:RJO2]LEV(nolign-1)=[L]WLEV

Gosub LEC_JOT     :# create lines to all Standard jobs even without son
If [L]TSTFULL=0 Then Gosub LEC_POT  : Endif   :# create lines to positions

# Order
If [M:RJO2]NBLIG > 1
  Sorta [M:RJO2]NBLIG [M:RJO2]NBLIG Order By [M:RJO2]UOMGRP([S]indice),[M:RJO2]JOBGRP([S]indice),[M:RJO2]JOBPOT([S]indice),[M:RJO2]COD([S]indice)
  For WI=0 To [M:RJO2]NBLIG-1
    [M:RJO2]LIGNE(WI)= WI+1
  Next
Endif
If [L]TSTFULL=1 Then
  Call ERREUR(func AFNC.MES1(mess(131,10720,1),num$([L]WDIMTAB))) From GESECRAN
Endif
Return


$INI_CRIT
CRITERE1="1=1"
CRITERE2="1=1"
CRITERE3="1=1"
CRITERE4="1=1"
Return

$LEC_JOT
# reading all Standard jobs even without son
Gosub INI_CRIT

If [M:RJO1]ALLGRP=1 Then
  CRITERE1-="& ([F:JOT]JOBGRP=[M:RJO1]JOBGRPE)"
Endif
If [M:RJO1]ALLUOM=1 Then
  CRITERE1-="& ([F:JOT]UOMGRP=[M:RJO1]UOMGRPE)"
Endif
If [M:RJO1]ALLJOT=1 Then
  CRITERE1-="& ([F:JOT]COD=[M:RJO1]JOBPOTE)"
Endif
If [M:RJO1]DATSTR<>[0/0/0] Then
#DATENDVLY : End validity Date
#DATSTRVLY : Start validity Date
CRITERE2-="& ([F:JOT]DATSTRVLY<=[M:RJO1]DATSTR)"
CRITERE2-="& ([F:JOT]DATENDVLY=[0/0/0] | [F:JOT]DATENDVLY>=[M:RJO1]DATSTR)"
Endif

If dim([M:RJO1]ALLLEG)>0 & [M:RJO1]ALLLEG=1 Then
 # checkbox "All Leg.." exists & is unticked
  CRITERE4-="& ([F:JOT]LEG=[M:RJO1]LEG )"
Endif

Filter [F:JOT] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4)
For [F:JOT]
  [L]WUOMGRP = [F:JOT]UOMGRP
  [L]WJOBGRP = [F:JOT]JOBGRP
  [L]WJOBPOT = [F:JOT]COD
  [L]WPOT    = ""
  [L]PASS = 3
  Gosub LOA_LIGNE
  If [L]TSTFULL=1 Then Break : Endif
Next
Filter [F:JOT]
Return
#---------------------

$LEC_POT
# reading positions / postes
# Selection a standard job empty is possible to find poste without family.

Gosub INI_CRIT
[L]WI = 2 : # To know if at least a real criteria to close bracket at the end
# if one filter = value blank, WI=>1.  If no filter => WI=0

If [M:RJO1]ALLJOT=1 Then
  CRITERE1-="& (JOBPOT=[M:RJO1]JOBPOTE"
  If [M:RJO1]JOBPOTE="" Then [L]WI = 1 :Endif
Elsif [M:RJO1]ALLGRP=1 Then
  CRITERE1-="& ([F:JOT]JOBGRP=[M:RJO1]JOBGRPE"
  If [M:RJO1]JOBGRPE="" Then [L]WI = 1 :Endif
Elsif [M:RJO1]ALLUOM=1 Then
  CRITERE1-="& ([F:JOT]UOMGRP=[M:RJO1]UOMGRPE"
  If [M:RJO1]UOMGRPE="" Then [L]WI = 1 :Endif
Else
  [L]WI = 0
Endif

If [L]WI > 0
  If [L]WI = 1 : #  if one filter = value blank, link by JOBTYP not always possible
    CRITERE1-= " | [F:POT]JOBPOT=''" :  # so search positions / postes without standard job.
  Endif
  CRITERE1+=")"
Endif

If [M:RJO1]DATSTR<>[0/0/0] Then
  CRITERE2-="& ([F:POT]JOBPOT='' |"
  CRITERE2-="([F:JOT]COD<>'' &"
  #DATENDVLY : End validity Date
  #DATSTRVLY : Start validity Date
  CRITERE2-="([F:JOT]DATSTRVLY<=[M:RJO1]DATSTR)"
  CRITERE2-="&"
  CRITERE2-="([F:JOT]DATENDVLY=[0/0/0] | [F:JOT]DATENDVLY>=[M:RJO1]DATSTR)"
  CRITERE2+="))"

  CRITERE3-="& ("
  CRITERE3-="([F:POT]DATSTRVLY<=[M:RJO1]DATSTR)"
  CRITERE3-="&"
  CRITERE3-="([F:POT]DATENDVLY=[0/0/0] | [F:POT]DATENDVLY>=[M:RJO1]DATSTR) "
  CRITERE3+=")"
Endif

If dim([M:RJO1]ALLLEG)>0 & [M:RJO1]ALLLEG=1 Then
 # checkbox "All Leg.." exists & is unticked
  CRITERE4-="& ([F:POT]LEG=[M:RJO1]LEG)"
Endif

Link [POT] With [F:JOT]JOT0=[F:POT]JOBPOT
& As [POJO]
& Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4)
& Order By Key KEY1 = [F:JOT]UOMGRP ;[F:JOT]JOBGRP ;[F:POT]JOBPOT;[F:POT]COD

For [POJO]
  [L]WUOMGRP = [F:JOT]UOMGRP
  [L]WJOBGRP = [F:JOT]JOBGRP
  [L]WJOBPOT = [F:POT]JOBPOT
  [L]WPOT    = [F:POT]COD
  [L]PASS = 4
  Gosub LOA_LIGNE
  If [L]TSTFULL=1 Then Break : Endif
Next
Filter [F:POT]

Return

# ----------------------------------------------------------------------
$LOA_LIGNE
# Create a new line in the treeview

Local Integer L_IJ,WPARLIN
Local Char WPARKEY(250)

If [M:RJO2]NBLIG<[L]WDIMTAB

  If [L]WUOMGRP="" Then [L]WUOMGRP=[L]WEMPTY :Endif
  If [L]WJOBGRP="" Then [L]WJOBGRP=[L]WEMPTY :Endif
  If [L]WJOBPOT="" Then [L]WJOBPOT=[L]WEMPTY :Endif

  [L]WLEV= "2" : Gosub LOA_UOMGRP : # create line Group / Famille
  [L]WLEV= "3" : Gosub LOA_JOBGRP : # create line Profession / Métier
  [L]WLEV= "5" : Gosub LOA_JOT    : # create line Satndard Job / Emploi type
  If [L]PASS >3  Then
    [L]WLEV= "6" : Gosub LOA_POT :# create line Position / Poste
  Endif
Else
  [L]TSTFULL=1
Endif
Return

$LOA_UOMGRP
# search Group / Famille
[L]L_IJ = find([L]WLEV+"~"+[L]WUOMGRP+"~",[M:RJO2]KEYC(0..[M:RJO2]NBLIG-1))
If ![L]L_IJ Then
  # create line Group / Famille
  nolign+=1
  [M:RJO2]NBLIG=nolign
  [M:RJO2]LEV(nolign-1)=[L]WLEV
  [M:RJO2]UOMGRP(nolign-1)=  [L]WUOMGRP
  Call TEXTE(13912,[M:RJO2]LIBSH(nolign-1)) From OBJDIV :#"Famille"
  If [L]WUOMGRP <>[L]WEMPTY Then
    Call LECTEXTRA([M:RJO2]LIBLONG(nolign-1),"ATABDIV","LNGDES","10459",[L]WUOMGRP) From ATEXTRA
    Read [F:ADI]CODE=10459;[L]WUOMGRP
    If !fstat Then [M:RJO2]LEG(nolign-1)=[F:ADI]LEG :Endif
    [M:RJO2]LIB(nolign-1)=[L]WUOMGRP
    [M:RJO2]ICO(nolign-1)=[L]WICOUOMGRP
  Else
    [M:RJO2]LIB(nolign-1)=mess(136,10720,1) : #Famille non définie'
    [M:RJO2]ICO(nolign-1)=[L]WICOEMPTY
  Endif
  [M:RJO2]KEYC(nolign-1)=[L]WLEV+"~"+[L]WUOMGRP+"~"
  [M:RJO2]PARKEY(nolign-1)=[M:RJO2]KEYC(0)
  Call EXPLEV(nolign-1)
  [M:RJO2]LIGNE(nolign-1)=(nolign-1)
  [M:RJO2]PARLIN(nolign-1)=0

  [L]L_IJ=0 #  ->  # create line Profession / Métier
  [L]WPARKEY=[M:RJO2]KEYC(nolign-1)
  [L]WPARLIN=[M:RJO2]LIGNE(nolign-1)
Else
  [L]WPARKEY=[M:RJO2]KEYC([L]L_IJ-1)
  [L]WPARLIN=[M:RJO2]LIGNE([L]L_IJ-1)
  #  search Profession / Métier
  [L]L_IJ = find(num$(val([L]WLEV)+1)+"~"+[L]WUOMGRP+"~"+[L]WJOBGRP+"~",[M:RJO2]KEYC(0..[M:RJO2]NBLIG-1))
Endif
Return

$LOA_JOBGRP
If ![L]L_IJ Then
  # create line Profession / Métier
  nolign+=1
  [M:RJO2]NBLIG=nolign
  [M:RJO2]LEV(nolign-1)=[L]WLEV
  [M:RJO2]UOMGRP(nolign-1)=  [L]WUOMGRP
  [M:RJO2]JOBGRP(nolign-1)=  [L]WJOBGRP
  Call TEXTE(46541,[M:RJO2]LIBSH(nolign-1)) From OBJDIV :#   "Métier"
  If [L]WJOBGRP <>[L]WEMPTY Then
    Call LECTEXTRA([M:RJO2]LIBLONG(nolign-1),"ATABDIV","LNGDES","10460",[L]WJOBGRP) From ATEXTRA
    [M:RJO2]LIB(nolign-1)=[L]WJOBGRP
    Read [F:ADI]CODE=10460;[L]WJOBGRP
    If !fstat Then [M:RJO2]LEG(nolign-1)=[F:ADI]LEG :Endif
    [M:RJO2]ICO(nolign-1)=[L]WICOJOBGRP
  Else
    [M:RJO2]LIB(nolign-1)=mess(137,10720,1) : #Métier non défini'
    [M:RJO2]ICO(nolign-1)=[L]WICOEMPTY
  Endif
  [M:RJO2]KEYC(nolign-1)=[L]WLEV+"~"+[L]WUOMGRP+"~"+[L]WJOBGRP+"~"
  [M:RJO2]PARKEY(nolign-1)=[L]WPARKEY
  Call EXPLEV(nolign-1)
  [M:RJO2]LIGNE(nolign-1)=nolign-1
  [M:RJO2]PARLIN(nolign-1)=[L]WPARLIN

  [L]L_IJ=0 #  -> create line Standard Job / Emploi Type
  [L]WPARKEY=[M:RJO2]KEYC(nolign-1)
  [L]WPARLIN=[M:RJO2]LIGNE(nolign-1)
Else
  [L]WPARKEY=[M:RJO2]KEYC([L]L_IJ-1)
  [L]WPARLIN=[M:RJO2]LIGNE([L]L_IJ-1)
  #  search Standard Job / Emploi Type - level + 2 (because we don't manage level of Skill's group)
  [L]L_IJ = find(num$(val([L]WLEV)+2)+"~"+[L]WUOMGRP+"~"+[L]WJOBGRP+"~"+[L]WJOBPOT+"~",[M:RJO2]KEYC(0..[M:RJO2]NBLIG-1))
Endif
Return

$LOA_JOT
If ![L]L_IJ Then
  # create line Standard Job / Emploi Type
  nolign+=1
  [M:RJO2]NBLIG=nolign
  [M:RJO2]LEV(nolign-1)=[L]WLEV
  [M:RJO2]UOMGRP(nolign-1)=  [L]WUOMGRP
  [M:RJO2]JOBGRP(nolign-1)=  [L]WJOBGRP
  [M:RJO2]DATSTR(nolign-1)=  [F:JOT]DATSTRVLY
  [M:RJO2]DATEND(nolign-1)=  [F:JOT]DATENDVLY
  Gosub LIBDAT
  [M:RJO2]JOBGRP(nolign-1)=  [L]WJOBGRP
  [M:RJO2]JOBPOT(nolign-1)=  [L]WJOBPOT
  Call TEXTE(45853,[M:RJO2]LIBSH(nolign-1)) From OBJDIV :# "Emploi Type"
  If [L]WJOBPOT<>[L]WEMPTY Then
     Call LECTEXTRA([M:RJO2]LIBLONG(nolign-1),"JOBTYP","DES",[L]WJOBPOT,"") From ATEXTRA
     [M:RJO2]LIB(nolign-1)=[L]WJOBPOT
     [M:RJO2]LEG(nolign-1)=[F:JOT]LEG
     [M:RJO2]ICO(nolign-1)=[L]WICOJOT
  Else
     [M:RJO2]LIB(nolign-1)=mess(138,10720,1) : #'Emploi type non défini'
     [M:RJO2]ICO(nolign-1)=[L]WICOEMPTY
  Endif
  [M:RJO2]KEYC(nolign-1)=[L]WLEV+"~"+[L]WUOMGRP+"~"+[L]WJOBGRP+"~"+[L]WJOBPOT+"~"
  [M:RJO2]PARKEY(nolign-1)=[L]WPARKEY
  Call EXPLEV(nolign-1)
  [M:RJO2]LIGNE(nolign-1)=nolign-1
  [M:RJO2]PARLIN(nolign-1)=[L]WPARLIN

  [L]L_IJ=0 #  -> create line Position / poste
  [L]WPARKEY=[M:RJO2]KEYC(nolign-1)
  [L]WPARLIN=[M:RJO2]LIGNE(nolign-1)
Else
  [L]WPARKEY=[M:RJO2]KEYC([L]L_IJ-1)
  [L]WPARLIN=[M:RJO2]LIGNE([L]L_IJ-1)
Endif
Return

$LOA_POT
# create line Position / Poste
nolign+=1
[M:RJO2]NBLIG=nolign
[M:RJO2]LEV(nolign-1)=[L]WLEV
[M:RJO2]UOMGRP(nolign-1)=  [L]WUOMGRP
[M:RJO2]JOBGRP(nolign-1)=  [L]WJOBGRP
[M:RJO2]JOBPOT(nolign-1)=  [L]WJOBPOT
[M:RJO2]DATSTR(nolign-1)=  [F:POT]DATSTRVLY
[M:RJO2]DATEND(nolign-1)= [F:POT]DATENDVLY
Gosub LIBDAT
[M:RJO2]COD(nolign-1)=  [L]WPOT
Call TEXTE(22321,[M:RJO2]LIBSH(nolign-1)) From OBJDIV :# "Poste"
If [L]WPOT <>"" Then
  Call LECTEXTRA([M:RJO2]LIBLONG(nolign-1),"POSTE","DES",[L]WPOT ,"") From ATEXTRA
  [M:RJO2]LIB(nolign-1)=[L]WPOT
  [M:RJO2]LEG(nolign-1)=[F:POT]LEG
  [M:RJO2]ICO(nolign-1)=[L]WICOPOT
Endif
[M:RJO2]KEYC(nolign-1)=[L]WLEV+"~"+[L]WUOMGRP+"~"+[L]WJOBGRP+"~"+[L]WJOBPOT+"~"+[L]WPOT +"~"
[M:RJO2]PARKEY(nolign-1)=[L]WPARKEY
Call EXPLEV(nolign-1)
[M:RJO2]LIGNE(nolign-1)=nolign-1
[M:RJO2]PARLIN(nolign-1)=[L]WPARLIN
[L]L_IJ=0
Return

$LIBDAT
If [M:RJO2]DATSTR(nolign-1)<>[0/0/0] & [M:RJO2]DATEND(nolign-1)<>[0/0/0]
  [M:RJO2]LIBDATSTR(nolign-1)=mess(94,100,1) : #Du
  [M:RJO2]LIBDATEND(nolign-1)=mess(95,100,1) :# au
Elsif [M:RJO2]DATSTR(nolign-1)<>[0/0/0]
  [M:RJO2]LIBDATSTR(nolign-1)=mess(162,125,1) : #'Depuis le'
Elsif [M:RJO2]DATEND(nolign-1)<>[0/0/0]
  [M:RJO2]LIBDATEND(nolign-1)=mess(144,10720,1) :#  jusqu'au
Endif
Return

$SETBOUT
Case [M:RJO1]RJOFLG
 When 0,1
  Call VIREBOUT (CHAINE,"a") From GOBJET
  Call VIREBOUT (CHAINE,"b") From GOBJET
  Call VIREBOUT (CHAINE,"c") From GOBJET
  Call VIREBOUT (CHAINE,"d") From GOBJET
 When 2
  Call VIREBOUT (CHAINE,"a") From GOBJET
  Call VIREBOUT (CHAINE,"b") From GOBJET
 When 6
  Call VIREBOUT (CHAINE,"c") From GOBJET
  Call VIREBOUT (CHAINE,"d") From GOBJET
Endcase
Return

$APRES_MODIF
If [M]ALLUOM = 1 &  [M]ALLGRP = 2 Then Grizo [M]ALLJOT  Else Actzo [M]ALLJOT  : Endif
Return

######################################################################################
# Gestion du masque CONSRJO1
######################################################################################

Subprog C_ALLLEG(VALEUR)
Variable Integer VALEUR
# In fact, it is an After modif but with a checkbox when you don't use "TAB", After modif doesn't work,
# we have to use Control to do the action. It is why we have test "if VALEUR<>[M]ALLXXX"

#DIRAS - 12/4/2017 - X3-33009 - START
#If VALEUR = 1 Then
#  Actzo [M]LEG
#  Affzo [M]LEG
#  Infbox(num$(VALEUR)+ " C_ALLLEG")
#Else
#  Raz [M]LEG
#  Effzo [M]LEG
#  Infbox(num$(VALEUR)+ " C_ALLLEG")
#Endif
#DIRAS - 12/4/2017 - X3-33009 - END

#If [M]ALLLEG=2
# Effzo [M]LEG : Diszo [M]LEG
#Else
# Actzo [M]LEG
#Endif

If VALEUR<>[M]ALLLEG
  If VALEUR = 1 Then
################################################# TIVAN - 18/05/2017 - Start
    Actzo [M]LEG
################################################# TIVAN - 18/05/2017 - End
    Gosub INI_LEG
  Else
################################################# TIVAN - 18/05/2017 - Start
    Effzo [M]LEG : Grizo [M]LEG
################################################# TIVAN - 18/05/2017 - End
    Raz [M]LEG
  Endif
  Call INIT_BYLEG([M]LEG)
  [M]WALLLEG=VALEUR
Endif
End

Subprog INIT_BYLEG(VALEUR)
Value Char VALEUR
# call by DIVPAYE# Raz all fields after Leg, if leg is modified
GCURLEG=VALEUR
[M]ALLUOM=2
[M]ALLGRP=2
[M]ALLJOT=2
Gosub INI_DATSTR
################################################# TIVAN - 18/05/2017 - Start
    Effzo [M]UOMGRPE, JOBGRPE, JOBPOTE : Grizo [M]UOMGRPE, JOBGRPE, JOBPOTE
################################################# TIVAN - 18/05/2017 - End
Affzo [M:RJO1]ALLUOM, ALLGRP, ALLJOT
End

Subprog AV_LEG(VALEUR)
Variable Char    VALEUR()

#DIRAS - 12/4/2017 - X3-33009 - START
#If [M]ALLLEG = 2 Then
#  Raz VALEUR
#  Grizo [M]LEG
#  Infbox(num$(VALEUR)+ " AV_LEG")
#Else
#  Actzo [M]LEG
#Endif
#DIRAS - 12/4/2017 - X3-33009 - END

If [M]ALLLEG = 2 Then Raz VALEUR:  Grizo [M]LEG Else Actzo [M]LEG : Endif
End

Subprog C_ALLUOM(VALEUR)
Variable Integer    VALEUR()
# In fact, it is an After modif but with a checkbox when you don't use "TAB", After modif doesn't work,
# we have to use Control to do the action. It is why we have test "if VALEUR<>[M]ALLXXX"
If VALEUR<>[M]ALLUOM
################################################# TIVAN - 18/05/2017 - Start
  #Raz [M:RJO1]JOBGRPE, JOBPOTE
  Effzo [M:RJO1]JOBGRPE, JOBPOTE
  Grizo [M:RJO1]JOBGRPE, JOBPOTE
################################################# TIVAN - 18/05/2017 - End
  [M:RJO1]ALLGRP=2
  [M:RJO1]ALLJOT=2
  Affzo [M:RJO1]ALLGRP, ALLJOT
################################################# TIVAN - 18/05/2017 - Start
  If VALEUR = 1 Then : Actzo [M]UOMGRPE : Else Effzo [M]UOMGRPE : Grizo [M]UOMGRPE : Endif
################################################# TIVAN - 18/05/2017 - End
Endif
End

Subprog AV_UOMGRPE(VALEUR)
Variable Char    VALEUR()
If [M]ALLUOM = 2 Then Raz VALEUR:  Grizo [M:RJO1]UOMGRPE Else Actzo [M:RJO1]UOMGRPE : Endif
End

Subprog C_UOMGRPE(VALEUR)
Variable Char    VALEUR()
Gosub CONTADILEGB
End

$CONTADILEGB
If dim([M:RJO1]ALLLEG)>0
  # Checkbox "All Leg.." exists
  If [M:RJO1]ALLLEG=1 Then
    If [M:RJO1]LEG="" & VALEUR <> "" & [F:ADI]LEG <>""
      GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:ADI]LEG : # Réservé à la législation
      mkstat=2 :End
    Endif
  Endif
Endif
Return

Subprog AM_UOMGRPE(VALEUR)
Variable Char    VALEUR()
[M]ALLGRP=2
[M]ALLJOT=2
Affzo [M:RJO1]
End

Subprog C_ALLGRP(VALEUR)
Variable Integer VALEUR
# In fact, it is an After modif but with a checkbox when you don't use "TAB", After modif doesn't work,
# we have to use Control to do the action. It is why we have test "if VALEUR<>[M]ALLXXX"
If VALEUR<>[M]ALLGRP
  Raz [M:RJO1]JOBGRPE
  [M:RJO1]ALLJOT=2
################################################# TIVAN - 18/05/2017 - Start
  Effzo [M:RJO1]JOBPOTE
  Grizo [M:RJO1]JOBPOTE
################################################# TIVAN - 18/05/2017 - End
  Affzo [M:RJO1]ALLJOT
################################################# TIVAN - 18/05/2017 - Start
  If VALEUR = 1 Then : Actzo [M]JOBGRPE : Else Effzo [M]JOBGRPE : Grizo [M]JOBGRPE : Endif
################################################# TIVAN - 18/05/2017 - End
Endif
End

Subprog AV_JOBGRPE(VALEUR)
Variable Char    VALEUR()
If [M]ALLGRP = 2 Then Raz VALEUR:  Grizo [M]JOBGRPE Else Actzo [M]JOBGRPE : Endif
End

Subprog C_JOBGRPE(VALEUR)
Variable Char    VALEUR()
Gosub CONTADILEGB
If [M]ALLUOM<>2 Then
  If VALEUR ="" & [M:RJO1]UOMGRPE<>""
    GMESSAGE = mess(139,10720,1)+chr$(10):#'Vous avez demandé une famille'"
    GMESSAGE += mess(10,123,1):#Zone obligatoire'
    mkstat=2 : End
  Endif
  If VALEUR <>"" & [M:RJO1]UOMGRPE="" & [F:ADI]DEPCOD <>""
    GMESSAGE = mess(140,10720,1)+chr$(10) :#'Vous avez demandé un métier sans famille'
    GMESSAGE +=VALEUR -mess(141,10720,1)-[F:ADI]DEPCOD :# dépend de
    mkstat=2 : End
  Endif
  If VALEUR <>"" & [M:RJO1]UOMGRPE<>"" & [F:ADI]DEPCOD =""
    GMESSAGE = VALEUR -mess(99,133,1)- [M:RJO1]UOMGRPE : # ne dépend pas de
    mkstat=2 : End
  Endif
Endif
End

Subprog AM_JOBGRPE(VALEUR)
Variable Char    VALEUR()
[M:RJO1]ALLJOT=2
Affzo [M:RJO1]ALLJOT,JOBPOTE, ZJOBPOTE
End

Subprog AV_JOBPOTE(VALEUR)
Variable Char    VALEUR()
If [M]ALLJOT = 2 Then Raz VALEUR:  Grizo [M]JOBPOTE Else Actzo [M]JOBPOTE : Endif
End

Subprog C_JOBPOTE(VALEUR)
Variable Char    VALEUR()
If VALEUR <>""
  Call LECTURE("JOT",VALEUR,"") From CONTOBJ
  If fstat : mkstat=2 : End : Endif
Endif

If [M]ALLGRP<>2 Then
  If VALEUR ="" & [M:RJO1]JOBGRPE<>""
    GMESSAGE = mess(142,10720,1)+chr$(10):#'Vous avez demandé un métier'"
    GMESSAGE += mess(10,123,1):#Zone obligatoire'
    mkstat=2 : End
  Endif
  If VALEUR <>""
  # Ctrl / Profession / Métier
    If [M:RJO1]JOBGRPE="" & [F:JOT]JOBGRP<>""
      GMESSAGE = mess(143,10720,1)+chr$(10) :#'Vous avez demandé un emploi-type sans métier'
      GMESSAGE +=VALEUR -mess(141,10720,1)-[F:JOT]JOBGRP :# dépend de
      mkstat=2 : End
    Elsif [F:JOT]JOBGRP<>[M:RJO1]JOBGRPE
      GMESSAGE +=VALEUR -mess(99,133,1)-[M:RJO1]JOBGRPE  :# ne dépend pas de
      mkstat=2 : End
    Endif
  Endif
Endif

If VALEUR <>"" & dim([M:RJO1]ALLLEG)>0
  # Ctrl / LEG empty
  If [M:RJO1]ALLLEG=1 & [M:RJO1]LEG="" & [F:JOT]LEG <>""
    GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:JOT]LEG : # Réservé à la législation
    mkstat=2 :End
  Endif
Endif
End

######################################################################################
# Gestion du masque CONSRJO2
######################################################################################

Subprog IB_NBLIG
#MABOS-22/07/13-FQ90539-US1804
Local Char WEMPTY(3)
Local Integer IS_GRP
#Infbox( [M:RJO2]UOMGRP(nolign-1)-[M:RJO2]KEYC(nolign-1))
[L]WEMPTY="_|_"
Case val([M:RJO2]LEV(nolign-1))
  When  1 : Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT7, GBOUT10
  When  2 : Raz GBOUT2, GBOUT3, GBOUT4
            If [M:RJO2]UOMGRP(nolign-1)=[L]WEMPTY Then Raz GBOUT1, GBOUT7
            Else Gosub IS_GRPCPC : Endif

  When  3 : Raz GBOUT1, GBOUT3, GBOUT4, GBOUT10
            If [M:RJO2]JOBGRP(nolign-1)=[L]WEMPTY Then Raz GBOUT2, GBOUT7
            Else Gosub IS_GRPCPC : Endif

  When  5 : Raz GBOUT1, GBOUT2, GBOUT4, GBOUT10
            If [M:RJO2]JOBPOT(nolign-1)=[L]WEMPTY Then Raz GBOUT3, GBOUT7
            Elsif !find([M:RJO2]KEYC(nolign-1),[M:RJO2]PARKEY(0..[M:RJO2]NBLIG-1))
              Raz GBOUT7
            Endif
            GFLAG="5"
  When  6 : Raz GBOUT1, GBOUT2, GBOUT3,  GBOUT7, GBOUT10
 When Default
Endcase

End

$IS_GRPCPC
#No Skill Grp -> No skills group, No MAJ inheritance
Local Char L_FILTRE(250)

#MABOS-FQ90539-US1910
#If clalev([F:HRGC1])=0    : Local File GRPCPCD  [HRGC1]   : Endif
If clalev([F:HRGC1])=0    : Local File GRPCPC  [HRGC1]   : Endif

Case [M:RJO2]LEV(nolign-1)
  When "2" : # Famille
      [L]L_FILTRE = "[F:HRGC1]UOMGRP=[M:RJO2]UOMGRP(nolign-1)"
  When "3" : # Métier
      [L]L_FILTRE = "[F:HRGC1]JOBGRP=[M:RJO2]JOBGRP(nolign-1)"
Endcase

Filter [F:HRGC1] Where evalue([L]L_FILTRE)

#MABOS-FQ90539-US1910
#Read [F:HRGC1]GCD0 First
Read [F:HRGC1]GCP0 First

Filter [F:HRGC1]

If fstat Then

#MABOS-FQ90539-US1910
  Raz GBOUT1, GBOUT2, GBOUT7

Else
  GFLAG=[M:RJO2]LEV(nolign-1)
Endif
Return


Subprog B1_NBLIG
#MABOS-FQ90539-US1910
If !GWEBSERV
  Local Char WVAL(GLONADI)
  [L]WVAL=[M:RJO2]UOMGRP(nolign-1)
  Call OBJET("GC2",[L]WVAL,num$(2)+"~"+""+"~") From GOBJET
Endif
Gosub AFF From GSAISIE
#end MABOS-FQ90539-US1910
End

Subprog B2_NBLIG
#MABOS-FQ90539-US1910
If !GWEBSERV
  Local Char WVAL(GLONADI)
  Local Char    PARMSK(250)(1..20) , SAVACT(20), SAVFLAG(20)
  SAVACT = GACTION : GACTION = "GOBJETC0" : SAVFLAG = GFLAG
  Local Char    OBJCLE(30)
  GFLAG=[M:RJO2]LEV(nolign-1)
  [L]WVAL=[M:RJO2]JOBGRP(nolign-1)
  Call OBJET_CHAR(OBJCLE,"GCP",num$(3)+"~"+[L]WVAL+"~") From GOBJET
  GACTION = SAVACT : GFLAG = SAVFLAG
Endif
Gosub AFF From GSAISIE
#end MABOS-FQ90539-US1910
End

Subprog B10_NBLIG
Call EXPAND_LEV(nolign-1)
Affzo [M:RJO2]
End

$BOUTON
Case BOUT
  When "a" :
    [M:RJO1]RJOFLG=2:#FQ92896
    Gosub ALL_LEV
    [M:RJO1]RJOFLG=2
  When "b" :
    [M:RJO1]RJOFLG-=1
    If [M:RJO1]RJOFLG=5 Then
      If !find("6",[M:RJO2]LEV(0..[M:RJO2]NBLIG-1)) :# No position in the tree
        [M:RJO1]RJOFLG-=1
      Endif
      [M:RJO1]RJOFLG-=1
    Endif
    Gosub ALL_LEV
  When "c" :
    [M:RJO1]RJOFLG+=1
    If [M:RJO1]RJOFLG=4 Then
      If !find("6",[M:RJO2]LEV(0..[M:RJO2]NBLIG-1)) :# No position in the tree
        [M:RJO1]RJOFLG+=1
      Endif
      [M:RJO1]RJOFLG+=1
    Endif
    Gosub ALL_LEV
  When "d" :
    [M:RJO1]RJOFLG=6
    Gosub ALL_LEV
Endcase
Return

$ALL_LEV
# Expand / collapse tree
Local Integer K
If dim([M:RJO2]EXPFLG)>0
  Affzo [M:RJO1]RJOFLG
  For K=0 To [M:RJO2]NBLIG-1
    Call EXPLEV(K)
  Next
Endif
Affzo [M:RJO2]
Return

Subprog EXPAND_LEV(WLIGN)
Value Integer WLIGN
#Expand a branch of the tree
[M:RJO2]EXPFLG(WLIGN) = 2
For K=0 To [M:RJO2]NBLIG-1
  If [M:RJO2]PARKEY(K)=[M:RJO2]KEYC(WLIGN) Then
    [M:RJO2]EXPFLG(K) = 2
    If val([M:RJO2]LEV(K))<6
      Call EXPAND_LEV(K)
    Endif
  Endif
Next
End

Subprog EXPLEV(WLIG)
Value Integer WLIG
# expand or collapse according to the expected level
If val([M:RJO2]LEV(WLIG))<[M:RJO1]RJOFLG Then
  [M:RJO2]EXPFLG(WLIG) = 2  : # expand
Else
  [M:RJO2]EXPFLG(WLIG) = 1  : # collapse
Endif
End
