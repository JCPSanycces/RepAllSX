#<AdxTL>@(#)1.0.0.0 $Revision$
# Gestion du masque ACST0
Raz GPILCOD
Call OBJET("ACST",GBIDC1,GBIDC3) From GOBJET
End

#----------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "LIENS"         : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "ANNULE"      : Gosub ANNULE
 When "EXEBOUT"    : Gosub EXEBOUT
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MOD"   : Gosub APRES_MOD
 When "APRES_CRE"   : Gosub APRES_CRE
 When "SETBOUT"      : Gosub SETBOUT
Endcase
Return

#----------------------------------------------------------------------------#
Funprog PREFIX_ACST
End "CST_"

#----------------------------#
$LIENS
Local Integer K
[M:ACST0]ACONST = "[V]"+func PREFIX_ACST+[F:ACST]CODVAR

Call TEXTE([F:ACST]INTIT,[M:ACST0]AINTIT) From OBJDIV

Gosub GRISE_TYPVAR
Call LECTURE_DOC("ACST",[ACST0]CODVAR,[ACST1]TEXTE,K) From SUBADO
Return

#----------------------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET
Endif
If GADONIX<>2 & !find(left$(CODVAR,1),"X","Y","Z")
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
Return

#----------------------------------------------------------------------------#
$APRES_CRE
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("ACST",[M:ACST0]CODVAR,"C") From AGENLIBA


Call VALIDATION(nomap,0)
Return

$APRES_MOD
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("ACST",[M:ACST0]CODVAR,"M") From AGENLIBA

Call VALIDATION(nomap,0)
Return

#----------------------------------------------------------------------------#
$MODIF
$CREATION
Call ECRIRE_DOC("ACST",[M:ACST0]CODVAR,[ACST1]TEXTE,[ACST0]AINTIT,[ACST1]MODULE,"") From SUBADO
Return

#----------------------------------------------------------------------------#
$ANNULE
Call EFFACE_DOC("ACST",[L]CODE) From SUBADO
Return

#----------------------------------------------------------------------------#
$AP_ANNULE
Call VALIDATION(APPLI,0)
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("ACST",[L]CODE,"A") From AGENLIBA
Return

#----------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI
Call GENDOS(APPLI)
End

#----------------------------------------------------------------------------#
Subprog GENDOS(APPLI)
Value Char    APPLI
Local File =APPLI+".ACONSTANT" [ACST]
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".ATYPE"    [ATY]
Call ECR_TRACE(mess(62,140,1)-mess(178,126,1)-APPLI,0) From GESECRAN : # Validation des constantes/dans le dossier
Call VALIDATION(APPLI,1)
End

#----------------------------------------------------------------------------#
$EXEBOUT
Case BOUT
 When "V"
  Call OUVRE_VLC(mess(62,140,1),"","") From GESECRAN
  Call OUVRE_TRACE(mess(1,47,1)) From LECFIC
  Call VALIDATION(nomap,0)
  Call FERME_VLC From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endcase
Return

Subprog VALIDATION(DOSSIER,SILENCE)
Value Char    DOSSIER
Value Integer SILENCE
Local Char     NOMTRT(GLONADC)
Local Char    FICTRT(GDIMFIC) , FICOLD(GDIMFIC) , FICLCK(GDIMFIC) , FICNEW(GDIMFIC)
Local Char    TETADO(80) , TEXTE(250) , CHAINE(250)
Local Integer STAT , I , K, N , M
Local Char    LIGNE(250)(1..200)
Local Char    MACHINE(GDIMFIC) , APPLI(GDIMFIC)


Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:ACST])=0  : Local File =DOSSIER+".ACONSTANT" [ACST]  : Endif
If clalev([F:ATX])=0  : Local File =DOSSIER+".ATEXTE"   [ATX]  : Endif
If clalev([F:ADP])=0  : Local File =DOSSIER+".ADOPAR"   [ADP]  : Endif
If clalev([F:ATY])=0  : Local File =DOSSIER+".ATYPE"    [ATY]  : Endif


[L]NOMTRT = func APREFIXTRT.GET_NAME_ACST

FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)
FICOLD = filpath("TRT",NOMTRT,"old",APPLI,"",MACHINE)
FICNEW = filpath("TRT",NOMTRT,"new",APPLI,"",MACHINE)
FICLCK = filpath("TRT",NOMTRT,"LCKsrc",APPLI,"",MACHINE)

Local Integer ISLOCKED
Call VERROU(DOSSIER,func APREFIXTRT.GET_NAME_ACST,10) From GLOCK
If fstat
 [L]ISLOCKED=0
Else
 [L]ISLOCKED=1
Endif

If filinfo(FICLCK,0)>0 | [L]ISLOCKED=0
 If  !SILENCE
  Call ECR_TRACE(NOMTRT-":"-mess(13,139,1),1) From GESECRAN : # Traitement verrouillé
 Endif
 Goto FIN_VALID
Endif

If filinfo(FICNEW,0)>0
 Call EFFACE(FICNEW,STAT) From ORDSYS
Endif

Openo FICLCK,0 Using [ACSTLOCK]
Iomode adxifs "" Using [ACSTLOCK]
Iomode adxirs chr$(10) Using [ACSTLOCK]
Iomode adxium GUTF8 Using [ACSTLOCK]
Wrseq adxmac(-2) Using [ACSTLOCK]
Wrseq adxusr Using [ACSTLOCK]
Wrseq format$(GFMD,date$)-"-"-time$ Using [ACSTLOCK]
Openo Using [ACSTLOCK]

#101663
If filinfo(FICOLD,0)>0
 Call EFFACE(FICOLD,STAT) From ORDSYS
Endif
#101663
If filinfo(FICTRT,0)>0
 Call COPIE(FICTRT,FICOLD,STAT) From ORDSYS
Endif

Openo FICTRT,0 Using [ACSTFIC]
Iomode adxifs "" Using [ACSTFIC]
Iomode adxirs chr$(10) Using [ACSTFIC]
Iomode adxium GUTF8 Using [ACSTFIC]

TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq TETADO;" ";mess(1,47,1)  Using [ACSTFIC] : # Variables globales
Wrseq "Subprog DEFVAR" Using [ACSTFIC]
For [ACST]ACST1(1) Where FLGSUP<>2
 If !GSERVEUR & !SILENCE
  Call AFF_VLC([ACST]CATEG,mess(1,100,1)) From GESECRAN : # Validation en cours
 Endif
 Wrseq "#------------------------------------------------------------------#" Using [ACSTFIC]
 Wrseq "####"-mess(8,105,1)-[ACST]CATEG Using [ACSTFIC]
 For [ACST]ACST1
  Call TEXTE([F:ACST]INTIT,CHAINE) From OBJDIV
  Wrseq "#"-CHAINE Using [ACSTFIC]
  Case [ACST]TYPVAR
   When 1 :  TEXTE = "Global Char     "
   When 2 :  TEXTE = "Global Integer  "
   When 3 :  TEXTE = "Global Decimal  "
   When 4 :  TEXTE = "Global Date     "
  Endcase
  TEXTE += func PREFIX_ACST+[F:ACST]CODVAR
  Case [ACST]TYPVAR
   When 1 :  TEXTE += "("+num$(max(1,len([F:ACST]VALCHAR)))+")"
  Endcase
  TEXTE += " : [V]"+func PREFIX_ACST+[F:ACST]CODVAR-"="
  Case [ACST]TYPVAR
   When 1 :
    If instr(1,[F:ACST]VALCHAR,'"')>0
     TEXTE += "'"+[F:ACST]VALCHAR+"'"
    Else
     TEXTE += '"'+[F:ACST]VALCHAR+'"'
    Endif
   When 2 :  TEXTE += num$([F:ACST]VALINT)
   When 3 :  TEXTE += num$([F:ACST]VALDEC)
   When 4 :  TEXTE += "["+num$([F:ACST]VALDAT)+"]"
  Endcase
  Wrseq TEXTE Using [ACSTFIC]
 Next
 Wrseq "" Using [ACSTFIC]
Next

Wrseq "End" Using [ACSTFIC]
Openo Using [ACSTFIC]

If GTRACE<>"" & !SILENCE
 Call ECR_TRACE(mess(159,133,1)-NOMTRT,0) From GESECRAN : # Validation du traitement ...
Endif
Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
If !STAT
 Call COPIE(FICTRT,FICNEW,STAT) From ORDSYS
 If GTRACE<>"" & !SILENCE
  Call ECR_TRACE(mess(20,123,1)-"\|"+FICNEW+"|",0) From GESECRAN : # Erreur en validation du traitement
 Endif
 Call EFFACE(FICTRT,STAT) From ORDSYS
 #101663
 If filinfo(FICOLD,0)>0
  Call COPIE(FICOLD,FICTRT,STAT) From ORDSYS
  If GTRACE<>"" & !SILENCE
   Call ECR_TRACE(mess(226,133,1)-NOMTRT,0) From GESECRAN : # Validation de l'ancien traitement
  Endif
  Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
  Call EFFACE(FICOLD,STAT) From ORDSYS
 Endif
 Call EFFACE(FICLCK,STAT) From ORDSYS
 End
Elsif APPLI=nomap & MACHINE=adxmac(0)
 Call DEFVAR From ASYRCONST
Endif
Call EFFACE(FICOLD,STAT) From ORDSYS
Call EFFACE(FICLCK,STAT) From ORDSYS
Call DEVERROU(DOSSIER,func APREFIXTRT.GET_NAME_ACST) From GLOCK

$FIN_VALID
If nomap=DOSSIER
 Gosub EXEC_DEFVAR From SUBACST
Endif
End

$ACST_DEFVAR
Resume

$EXEC_DEFVAR
 Call VERROU(nomap,func APREFIXTRT.GET_NAME_ACST,10) From GLOCK
 If fstat
  Call DEVERROU(nomap,func APREFIXTRT.GET_NAME_ACST) From GLOCK
  Return
 Endif
 Onerrgo ACST_DEFVAR
 Call DEFVAR From =func APREFIXTRT.GET_NAME_ACST
 Onerrgo
 Call DEVERROU(nomap,func APREFIXTRT.GET_NAME_ACST) From GLOCK
Return
#----------------------------------------------------------------------------#

$TRTCOP
If [M]DOSORG=nomap
 Local File ACONSTANT  [ACST1]
 Local File ATEXTE    [ATX1]
 Local File ADOCUMENT [ADO1]
 Local File ADOCCLB   [ADH1]
Else
 Local File =[M]DOSORG+".ACONSTANT"  [ACST1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
 Local File =[M]DOSORG+".ADOCUMENT" [ADO1]
 Local File =[M]DOSORG+".ADOCCLB"   [ADH1]
Endif
If [M]DOSDES=nomap
 Local File ACONSTANT  [ACST2]
 Local File ATEXTE    [ATX2]
 Local File ADOCUMENT [ADO2]
 Local File ADOCCLB   [ADH2]
Else
 Local File =[M]DOSDES+".ACONSTANT"  [ACST2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
 Local File =[M]DOSDES+".ADOCUMENT" [ADO2]
 Local File =[M]DOSDES+".ADOCCLB"   [ADH2]
Endif
OK = 1
If GTRACE=""
 Read [ACST2]ACST0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [ACST1], [ATX1], [ACST2], [ATX2]
Close Local File [ADO1], [ADH1], [ADO2], [ADH2]
Return

$TR_COP
GOK = 1
Trbegin [ACST2] , [ATX2]
 Delete [ACST2] Where CODVAR=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACONSTANT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACST2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ACST1]ACST0 Where CODVAR=TABLE
  [F:ACST2] = [F:ACST1]
  Call COPTEXTE([F:ACST1]INTIT,[F:ACST2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:ACST2]UPDUSR)>0 : [F:ACST2]UPDUSR = GUSER : Endif
  If dim([F:ACST2]UPDDAT)>0 : [F:ACST2]UPDDAT = date$ : Endif
  If dim([F:ACST2]UPDTIM)>0 : [F:ACST2]UPDTIM = time  : Endif
  Write [ACST2]
  If fstat
   GOK=0 : Call FSTA("ACST2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Call COPIE_DOC("ACST",TABLE,[M]DOSORG,[M]DOSDES) From SUBADO
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

######################################################################################
## GESTION ECRAN
######################################################################################
Subprog C_CODVAR(VALEUR)
Variable Char    VALEUR()
#
End

Subprog AM_CODVAR(VALEUR)
Variable Char    VALEUR()
[M:ACST0]ACONST = "[V]"+func PREFIX_ACST+VALEUR
Affzo [M:ACST0]ACONST
End

Subprog AM_TEXTE(VALEUR)
Variable Clbfile VALEUR
End

Subprog C_CATEG(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If func AFNC.ACTIV("SUP")>0 & VALEUR<>""
  Call PLAGE(VALEUR,1) From CONTOBJ
  If mkstat : End : Endif
 Else
  If left$([M:ACST0]CODVAR,1)<>"A" & left$(VALEUR,1)="A"
   GMESSAGE = mess(214,133,1) : #  PARAMÉTRAGE INCORRECT
   mkstat = 2 : End
  Endif
 Endif
Endif
End



Subprog AS_CODACT(VALEUR)
Variable Char    VALEUR()
If [M]CODVAR<>"" & [M]CODVAR<"X"
 mkstat = 1  : ENDF
Endif
End


Subprog AM_TYPVAR(VALEUR)
Variable Integer VALEUR
[M]TYPVAR = VALEUR
Gosub GRISE_TYPVAR
End

$GRISE_TYPVAR
Case [ACST1]TYPVAR
 When 1
  Actzo [ACST1]VALCHAR : Raz [ACST1]VALINT   : Raz [ACST1]VALDEC : Raz [ACST1]VALDAT
  Affzo [ACST1]VALINT  : Affzo [ACST1]VALDEC : Affzo [ACST1]VALDAT
  Grizo [ACST1]VALINT  : Grizo [ACST1]VALDEC : Grizo [ACST1]VALDAT
 When 2
  Actzo [ACST1]VALINT : Raz [ACST1]VALCHAR : Raz [ACST1]VALDEC : Raz [ACST1]VALDAT
  Affzo [ACST1]VALCHAR : Affzo [ACST1]VALDEC : Affzo [ACST1]VALDAT
  Grizo [ACST1]VALCHAR : Grizo [ACST1]VALDEC : Grizo [ACST1]VALDAT
 When 3
  Actzo [ACST1]VALDEC : Raz [ACST1]VALCHAR : Raz [ACST1]VALINT : Raz [ACST1]VALDAT
  Affzo [ACST1]VALCHAR : Affzo [ACST1]VALINT : Affzo [ACST1]VALDAT
  Grizo [ACST1]VALCHAR: Grizo [ACST1]VALINT : Grizo [ACST1]VALDAT
 When 4
  Actzo [ACST1]VALDAT : Raz [ACST1]VALCHAR : Raz [ACST1]VALINT : Raz [ACST1]VALDEC
  Affzo [ACST1]VALCHAR : Affzo [ACST1]VALINT : Affzo [ACST1]VALDEC
  Grizo [ACST1]VALCHAR : Grizo [ACST1]VALINT : Grizo [ACST1]VALDEC
Endcase
Return

Subprog S_CATEG(VALEUR)
Variable Char    VALEUR()
Local Integer NBFLD, CHOI
Local Char    TEX(GLONDES)(1..500,1..1) , TIT(GLONDES)(0..1)
Local File ACONSTANT [ACST]
For [F:ACST]ACST0
 If !find([F:ACST]CATEG,TEX(1..NBFLD,1))
  NBFLD+= 1
  TEX(NBFLD,1) = [F:ACST]CATEG
 Endif
Next
CHOI = 0
TIT(0)=mess(8,31,1) # Sélection
TIT(1)=mess(8,105,1) # Catégorie
If NBFLD>1
 Call SAITEX_COL_MAX(NBFLD,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif
Elsif NBFLD=1
 VALEUR = TEX(1,1)
Endif
End

Subprog C_VALCHAR(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,'"')>0 & instr(1,VALEUR,"'")>0
 GMESSAGE = mess(105,75,1) : # Les caractères ' et " ne doivent pas être utilisés ensemble
 mkstat =2 : End
Endif
End


######################################################################################

