#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DLA3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone ACCTYP
mkstat = 0
zoncou = "ACCTYP"
indice = 0
IMPENT = [M]ACCTYP
If varinit([M]ACCTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]ACCTYP,indice)=0
 Call INICOMBO(10389) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_ACCTYP(IMPENT) From SUBDLA
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10389,1))))
 Endif
 [M]ACCTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACCTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ACCTYP(indice)
 Endif
 If !mkstat
  If IMPENT=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "ACCTYP" : GZNUM = 52295 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
    mkstat = 1 : GMESSAGE = mess(99,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "ACCTYP" : GZNUM = 52295 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]ACCTYP = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone HOU
mkstat = 0
zoncou = "HOU"
indice = 0
If varmode([M]HOU,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HOU" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone HOUSTR
mkstat = 0
zoncou = "HOUSTR"
For indice=0 To 1
 If varmode([M]HOUSTR,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "HOUSTR" : Gosub ACTION From =IMPTRT
  Endif
 Endif
 mkstat = 0
Next indice
If mkstat : End : Endif

## Zone HOUEND
mkstat = 0
zoncou = "HOUEND"
For indice=0 To 1
 If varmode([M]HOUEND,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "HOUEND" : Gosub ACTION From =IMPTRT
  Endif
 Endif
 mkstat = 0
Next indice
If mkstat : End : Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone TXT0
mkstat = 0
zoncou = "TXT0"
indice = 0
If varmode([M]TXT0,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TXT0" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ACCCRN
mkstat = 0
zoncou = "ACCCRN"
indice = 0
If varmode([M]ACCCRN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACCCRN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTSIRET"
 Call CONTSIRET([M]ACCCRN,"","") From CONTNUM
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ACCCRN" : GZNUM = 1424 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ACCPLA
mkstat = 0
zoncou = "ACCPLA"
indice = 0
IMPENT = [M]ACCPLA
If varinit([M]ACCPLA,indice)=0
 IMPENT = 1
Endif
If varmode([M]ACCPLA,indice)=0
 [M]ACCPLA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACCPLA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ACCPLA(indice)
 Endif
Endif
[M]ACCPLA = IMPENT

## Zone ACCTIM
mkstat = 0
zoncou = "ACCTIM"
indice = 0
IMPENT = [M]ACCTIM
If varinit([M]ACCTIM,indice)=0
 IMPENT = 1
Endif
If varmode([M]ACCTIM,indice)=0
 [M]ACCTIM(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACCTIM" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ACCTIM(indice)
 Endif
Endif
[M]ACCTIM = IMPENT

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone TXT1
mkstat = 0
zoncou = "TXT1"
For indice=0 To 5
 If varmode([M]TXT1,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "TXT1" : Gosub ACTION From =IMPTRT
  Endif
 Endif
 mkstat = 0
Next indice
If mkstat : End : Endif

## Zone TXT2
mkstat = 0
zoncou = "TXT2"
indice = 0
If varmode([M]TXT2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TXT2" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TXT3
mkstat = 0
zoncou = "TXT3"
indice = 0
If varmode([M]TXT3,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TXT3" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TXT4
mkstat = 0
zoncou = "TXT4"
indice = 0
If varmode([M]TXT4,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TXT4" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "DLA3"
Return

