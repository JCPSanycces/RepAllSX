#<AdxTL>@(#)0.0.0.0 $Revision$
#--Syracuse
#Subprog SAISFOOT (TRAIT,WABMSK,NBPOSTE,TYPCUR,CURORI,CURDES,ALIM)
#Value    Integer  TRAIT
#Value    Char     WABMSK
#Variable Integer  NBPOSTE
#Value    Libelle  TYPCUR
#Value    Char     CURORI,CURDES,ALIM
Subprog SAISFOOT (TRAIT,OBJGEN,OBJCODE,NBPOSTE,TYPCUR,CURORI,CURDES,ALIM)
Value    Integer  TRAIT
Variable Instance OBJGEN Using OBJECT
Value 	 Char	  	OBJCODE
Variable Integer  NBPOSTE
Value    Libelle  TYPCUR
Value    Char     CURORI,CURDES,ALIM

#--On sort si pas d'instance identifiable
If OBJGEN=null | OBJCODE="" : End : Endif

Local File SFOOTINV [SFI]
Local File COMPANY  [CPY]
Local File TABCUR   [TCU]

Local Instance DOC Using =OBJCODE

#--Cast - afin d'acceder aux propriétés de l'instance
DOC = cast(OBJGEN,=OBJCODE)

#--

Gosub STRUFOOT_E
NBPOSTE=POSTE

#------------------------------------------------------------------#
# Chargement des valeurs par défaut client en commande             #
#                                          en livraison            #
#                                          en facture              #
#------------------------------------------------------------------#
If TRAIT >= 3 & ALIM ="OUI"
   For I=0 To dim([F:BPC]INVDTA)-1
       If [F:BPC]INVDTA(I)=0 : Break : Endif
       For I2=1 To NBPOSTE
		 		If DOC.C_INVDTAAMT(I2)<>null and find(DOC.C_INVDTAAMT(I2).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
           If DOC.C_INVDTAAMT(I2).INVDTA=[F:BPC]INVDTA(I)
              MTBPR = [F:BPC]INVDTAAMT(I)
              If DOC.C_INVDTAAMT(I2).INVDTAAMTCOD = 2
                 Call CONVERT(DOC.ACTX,CURORI,CURDES,CTX_LOCALDEV,TYPCUR,CTX_HIDATE,
&                             [F:BPC]INVDTAAMT(I),MTBPR,SPSTAT) From TRTDEV_SYRA
              Endif
              If find(TRAIT,4,6,7)
                 Read [SFI]SFI0=[F:BPC]INVDTA(I)
                 If !fstat & ((find(TRAIT,4,7) & [F:SFI]DACORD<>0) | (TRAIT=6 & [F:SFI]DACDLV<>0))
                    Raz MTBPR
                 Endif
              Endif
              If MTBPR<>0
                 DOC.C_INVDTAAMT(I2).INVDTAAMT = MTBPR
              Endif
              Break
           Endif
         Endif
       Next I2
   Next I
Endif

End
###################################################################################################
$STRUFOOT_E
#If clalev([F:SFI])=0 : Local File SFOOTINV [SFI] : Endif

If NBPOSTE<nbrecord([F:SFI]) : NBPOSTE=nbrecord([F:SFI]) : Endif
Local Integer  MLXFINUM (NBPOSTE)
Local Char     MLSHO (12) (NBPOSTE)
Local Integer  MLTRI    (NBPOSTE)
Local Integer  MLAMTCOD (NBPOSTE)
Local Char     MLFORMAT (15) (NBPOSTE)
Local Integer  MLVAL    (NBPOSTE)
Local Decimal  MLDEFVAL (NBPOSTE)
Local Integer  MLVALTYP (NBPOSTE)
Local Decimal  MTBPR
Local Integer  MLINCDCR (NBPOSTE)

Gosub STRUFOOTE1
Gosub STRUFOOTE2

Return

###################################################################################################
$STRUFOOTE1
Local Char     PROGOBJX    : # pour appel à WOSFI
Local Char     WCRITERE(30)
Local Integer  POSTE       : # pour nbre de postes rééls triés
Local Integer  I, I2
Local Integer  CODTRT      : # code traitement interne
Local Integer  WMLTRI
Local Integer  WMLVAL      : # pour maj valeur par defaut
Local Decimal  COURS       : # pour conversion valeur par défaut
Local Integer  SPSTAT

#--Syracuse
#If clalev([F:CPY])=0 Local File COMPANY  [CPY]
#If clalev([F:SFI])=0 Local File SFOOTINV [SFI]
#If clalev([F:TCU])=0 Local File TABCUR   [TCU]

#--Variables locales chargées à partir du contexte (remplacement des globales)
Local Char 	  CTX_SYSCUR(GLONCUR)
Local Char 	  CTX_LOCALDEV(GLONCUR)
Local Integer CTX_DEPMGTMOD
Local Date 	  CTX_HIDATE

#--Init des variables liées au contexte
CTX_SYSCUR    = fmet DOC.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,DOC.ACTX.AFOLDER,"SYSCUR")
CTX_DEPMGTMOD = fmet DOC.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,DOC.ACTX.AFOLDER,"DEPMGTMOD")

CTX_HIDATE  	= gdat$(31,12,adxdcs+99)

If dim(DOC.CPY)>0
	If [F:CPY]CPY<>DOC.CPY
		Read [F:CPY]CPY0=DOC.CPY
		If fstat Raz [F:CPY] : Endif
	Endif
	CTX_LOCALDEV = [F:CPY]CUR
Endif
#--

#--Syracuse
#Call LECDEV (CURDES) From TRTDIV
If CURDES="" : CURDES = CTX_LOCALDEV : Endif
If CURDES<>[F:TCU]CUR
 Read [TCU]TCU0 = CURDES
 If fstat Raz [F:TCU] : Endif
Endif
#--

#-- Si Paramètre société Remise sur taxe à non, exclure les élts Remise sur taxe
WCRITERE = "1=1"
If CTX_DEPMGTMOD>1 : WCRITERE-="& MISRULSTD<>2" : Endif

# chgt des postes à partir des éléments de facturation
For [F:SFI] Where evalue(WCRITERE)
  WMLTRI = 0
  WMLVAL = 0
  Case TRAIT
   When 1 : WMLTRI = [F:SFI]DACBPC : WMLVAL = 0
   When 3 : WMLTRI = [F:SFI]DACORD : WMLVAL = [F:SFI]DACBPC
   When 4 : WMLTRI = [F:SFI]DACDLV : WMLVAL = [F:SFI]DACBPC+[F:SFI]DACORD
   When 5 : WMLTRI = [F:SFI]DACDLV : WMLVAL = [F:SFI]DACBPC
   When 6 : WMLTRI = [F:SFI]DACINV : WMLVAL = [F:SFI]DACBPC+[F:SFI]DACORD+[F:SFI]DACDLV
   When 7 : WMLTRI = [F:SFI]DACINV : WMLVAL = [F:SFI]DACBPC+[F:SFI]DACORD
   When 8 : WMLTRI = [F:SFI]DACINV : WMLVAL = [F:SFI]DACBPC
  Endcase

  If WMLTRI <> 0
    I += 1
    MLTRI (I-1)    = WMLTRI
    MLXFINUM (I-1) = [F:SFI]SFINUM
    #If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
		#--Syracuse
        #Call LECTEXTRA (MLSHO(I-1),"SFOOTINV","SHOAXX",num$([F:SFI]SFINUM),"") From ATEXTRA
		Call LECTEXTRA_SYR(DOC,"", MLSHO(I-1),"SFOOTINV","SHOAXX",num$([F:SFI]SFINUM),"")
    #Endif                        : # Dde 81811 : Optimisation
    MLAMTCOD (I-1)    = [F:SFI]AMTCOD
    If MLAMTCOD (I-1) = 1
      #MLFORMAT (I-1) = func TRTX3FNC.GETFMTREM(1)
	  MLFORMAT (I-1) = func GETFMTREM(1)
      If (find(TRAIT,4,7) & [F:SFI]DACORD<>0) | (TRAIT=6 & [F:SFI]DACDLV<>0)
         Raz MLDEFVAL (I-1)
      Else
         MLDEFVAL (I-1) = [F:SFI]DEFVAL
      Endif
    Else
      MLFORMAT (I-1) = "NZ:"+[F:TCU]CURFMT1
      If (find(TRAIT,4,7) & [F:SFI]DACORD<>0) | (TRAIT=6 & [F:SFI]DACDLV<>0) | [F:SFI]DEFVAL=0         : # Dde 81811 : Optimisation
         Raz MLDEFVAL (I-1)
      Else
         Call CONVERT(DOC.ACTX,CTX_SYSCUR,CURDES,CTX_LOCALDEV,TYPCUR,CTX_HIDATE,[F:SFI]DEFVAL,MLDEFVAL(I-1),SPSTAT) From TRTDEV_SYRA
      Endif
    Endif
    MLVALTYP (I-1) = [F:SFI]VALTYP
    MLVAL    (I-1) =  WMLVAL
    MLINCDCR (I-1) = [F:SFI]INCDCR
  Endif
Next

Sorta MLTRI , MLXFINUM , MLSHO , MLAMTCOD , MLFORMAT , MLVALTYP, MLVAL , MLDEFVAL, MLINCDCR

Return
###################################################################################################
$STRUFOOTE2
#--Syracuse
#--DOC -> réference sur l'instance appelante (passée en paramètre)
For I = 1 To NBPOSTE
  If MLTRI (I-1) <> 0
    POSTE += 1
    If POSTE > NBPOSTE : POSTE=NBPOSTE: Break : Endif
	  If DOC.C_INVDTAAMT(POSTE)<>null and find(DOC.C_INVDTAAMT(POSTE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
  		DOC.C_INVDTAAMT(POSTE).INVDTA  = MLXFINUM (I-1)
  		DOC.C_INVDTAAMT(POSTE).INVDTAAMTCOD  = MLAMTCOD (I-1)
  		#DOC.C_INVDTAAMT(POSTE).SHO    = MLSHO (I-1)
  		#DOC.C_INVDTAAMT(POSTE).FORMAT = MLFORMAT (I-1)
  		If DOC.C_INVDTAAMT(POSTE).INVDTATYP = 0
  		   DOC.C_INVDTAAMT(POSTE).INVDTATYP = MLVALTYP (I-1)
  		Endif
  		If ALIM = "OUI" & MLVAL (I-1) = 0
  		  DOC.C_INVDTAAMT(POSTE).INVDTAAMT = MLDEFVAL (I-1)
  		Endif
	  Endif
  Endif
Next I

Return

#################################################
Subprog LECTEXTRA_SYR(AINSTANCE,APRONAME, AVALUE,TABLE,CHAMP,CLE1,CLE2)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value    Char    TABLE, CHAMP, CLE1, CLE2

Local    Char    ACTION(20)
Local Integer    OK

OK = 1
#ACTION = "LECTEXTRA" : Gosub ACTIONB
If !OK : End : Endif

Local File ATEXTRA [AXX]

Read [AXX]AXX0 = TABLE;CHAMP;AINSTANCE.ACTX.LAN;CLE1;CLE2
If fstat=0
 AVALUE = [F:AXX]TEXTE
Else
 Read [AXX]AXX0 = TABLE;CHAMP;AINSTANCE.ACTX.AFOLD.ALANGDEF;CLE1;CLE2
 If fstat=0
  AVALUE = [F:AXX]TEXTE
 Else
  AVALUE = ""
 Endif
Endif
End
#################################################
Funprog GETFMTREM(WTYPREM)
Value Integer WTYPREM : # Type de remise
#-----
Local Char    WFMTREM(20)
Local Char    WCODTYP(GLONATY)
Local Integer I, J, K : # K = nbre de blancs à afficher après la remise
#----- Valeur par défaut du format des remises -----#
Case [L]WTYPREM
  When 1       : WFMTREM="NZ:3.2#[      ]" : K=6
  When Default : WFMTREM="NZ:3.2#"         : K=0
Endcase
#----- Récupération du format à partir du type de donnée -----#
Local File ATYPE [ATY]

Case [L]WTYPREM
  When 1       : [L]WCODTYP="RFI"
  When Default : [L]WCODTYP="RAT"
Endcase
Read [ATY] CODTYP=[L]WCODTYP
If !fstat
  If K & !instr(1,[F:ATY]FORTYP,"[")
    I=instr(1,[F:ATY]FORTYP,".")
    If I
      J =val(mid$([F:ATY]FORTYP,I-1,1)) : #   nbre chiffres entiers
      J+=val(mid$([F:ATY]FORTYP,I+1,1)) : # + nbre chiffres décimales
    Else
      J =val(left$([F:ATY]FORTYP,2))
    Endif
    If J>K+5  J=K+5 : Endif
    WFMTREM="NZ:"+[F:ATY]FORTYP+"["+space$(K+5-J)+"]"
  Else
    WFMTREM="NZ:"+[F:ATY]FORTYP
  Endif
Endif
#-----
End WFMTREM
