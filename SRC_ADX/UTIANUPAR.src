#<AdxTL>@(#)2.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Suppression d'une variable globale et d'un paramètre
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Delete global GAPSADX et APSADX parameter") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub ANU
End

#-------------------#
$ANU

Local File =DOSSIER+".ADOVAL" [ADW] , =DOSSIER+".ADOPAR" [ADP]
Local File =DOSSIER+".AGLOBVAR" [AGB]

Local Integer AGB , ADW

Trbegin [ADW]
 Read [AGB]AGB0="GAPSADX"
 If !fstat
  Delete [AGB] Curr
  If !fstat : AGB = 1 : Endif
 Endif
 Read [ADP]ADP1="APSADX"
 If !fstat
  Delete [ADP] Curr
  If !fstat : ADW = 1 : Endif
  Delete [ADW] Where PARAM="APSADX"
 Endif
Commit

If AGB
 Call ECR_TRACE("Delete global GAPSADX",0) From GESECRAN
Endif
If ADW
 Call ECR_TRACE("Delete APSADX parameter",0) From GESECRAN
Endif
 
Close Local File

Return

