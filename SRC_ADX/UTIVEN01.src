#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTIVEN01 - Utilitaire d'alimentation de [F:SOC]CUSORDREF  Module Vente #
##########################################################################

Subprog EXE_UTIVEN01(DOSSIER)
Value Char DOSSIER

If clalev([F:SOH])=0  Local File =DOSSIER+".SORDER"  [SOH] : Endif
If clalev([F:SOC])=0  Local File =DOSSIER+".SORDERC" [SOC] : Endif

Local Char     CLE1(GLONVCR)
Local Shortint STOP
Local Integer  COMPTEUR

Raz CLE1
Trbegin [SOH],[SOC]
$BOUCLE_SOC
Raz COMPTEUR
Raz STOP
For [SOH] Where SOHNUM>CLE1 & SOHCAT = 4
   For [SOC] Where SOHNUM=[F:SOH]SOHNUM
      [F:SOC]CUSORDREF = [F:SOH]CUSORDREF
      Rewrite [SOC]
      If !fstat COMPTEUR+=1 Endif
   Next 
   If COMPTEUR>GMAXUPDTRS 
      Commit
      Trbegin [SOH],[SOC]
      CLE1=[F:SOH]SOHNUM : STOP=1 : Break 
   Endif
Next
If STOP Goto BOUCLE_SOC : Endif
Commit
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(4)<>2 End : Endif
Call EXE_UTIVEN01(APPLI)
End


