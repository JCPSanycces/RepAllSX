#<AdxTL>@(#)6.0.0.0 $Revision$
# Gestion du masque CUTCAB1
######################################################################################
## Etiquette ajoutée par le superviseur (Objet CUT) 23/06/2010 15:36:05 (MM)
######################################################################################
$ACTION
Case ACTION
 When "AVANT_ACT"   : Gosub AVANT_ACT
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "RAZCRE"      : Gosub RAZCRE
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Call CHANGE_AXX ("TABCABCUT", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When "AVANT_ACT"   : Gosub AVANT_ACT
 When Default
Endcase
Return

######################################################################################
$RAZCRE
Actzo [M:CUT]15,20
Return

######################################################################################
$AVANT_ACT
If (BOUT ="C" | BOUT="E")
  If [M:CUT]TYPCAB=1
     If ![M:CUT]NUMITM & [M:CUT]ITMSET="" &
&    ![M:CUT]NUMLOT & [M:CUT]LOTSET="" &
&    ![M:CUT]NUMSLO & [M:CUT]SLOSET=""
      Call MESSAGE (mess(281,193,1)) From GESECRAN : OK =0
    Endif
  Elsif [M:CUT]TYPCAB=2
      If (![M:CUT]ITMLON & ![M:CUT]ITMDEB) &
&     (![M:CUT]LOTLON & ![M:CUT]LOTDEB) &
&     (![M:CUT]SLOLON & ![M:CUT]SLODEB)
       Call MESSAGE (mess(281,193,1)) From GESECRAN : OK =0
    Endif
  Endif
Endif
Return
######################################################################################
$LIENS
# chargement d'une nouvelle règle : on dégrise tous les blocs
Actzo [M:CUT]15,20

Case [M:CUT]TYPCAB
  When 1 : Grizo [M:CUT]20
           Case GITMCTL
             When 1 : # pas de recontrôle OF : griser l'ensemble des zones?
             When 2 : # lot recontrôlé
                      Grizo [M:CUT]15
                      Actzo [M:CUT]NUMLOT,LOTSET
             When 3 : # article + lot
                      Grizo [M:CUT]NUMSLO,SLOSET
             When 4 : # lot + slo
                      Grizo [M:CUT]NUMITM,ITMSET
           Endcase
  When 2 : Grizo [M:CUT]15
       Case GITMCTL
             When 1 :  # pas de recontrôle OF : griser l'ensemble des zones?
             When 2 :  # lot recontrôlé
                      Grizo [M:CUT]20
                      Actzo [M:CUT]LOTLON,LOTDEB,LOTFIN
             When 3 :  # article + lot
                      Grizo [M:CUT]SLOLON,SLODEB,SLOFIN
             When 4 : # lot + slo
                      Grizo [M:CUT]ITMLON,ITMDEB,ITMFIN
           Endcase

Endcase
Return

######################################################################################
$APRES_CHOI

If (REPONSE = GSTAENR | REPONSE = GSTACRE)
  If [M:CUT]TYPCAB=1
    If ![M:CUT]NUMITM & [M:CUT]ITMSET="" &
&    ![M:CUT]NUMLOT & [M:CUT]LOTSET=""   &
&    ![M:CUT]NUMSLO & [M:CUT]SLOSET=""
      Call MESSAGE (mess(281,193,1)) From GESECRAN : REPONSE =0
    Endif
  Elsif [M:CUT]TYPCAB=2
    If (![M:CUT]ITMLON & ![M:CUT]ITMDEB) &
&    (![M:CUT]LOTLON & ![M:CUT]LOTDEB)   &
&    (![M:CUT]SLOLON & ![M:CUT]SLODEB)
       Call MESSAGE (mess(281,193,1)) From GESECRAN : REPONSE =0
    Endif
    # interdire zones chevauchantes
    # entre l'article et le lot
    If find (GITMCTL,3,5)
      If [M:CUT]ITMDEB < [M:CUT]LOTDEB # 1er zone = article
          If [M:CUT]LOTDEB <= [M:CUT]ITMFIN
              Call MESSAGE (mess(285,193,1)) From GESECRAN : REPONSE =0
          Endif
      Else                             # 1er zone = lot
          If [M:CUT]ITMDEB <= [M:CUT]LOTFIN
              Call MESSAGE (mess(285,193,1)) From GESECRAN : REPONSE =0
          Endif
      Endif
   Endif
   # entre le lot et le sous-lot
   If find (GITMCTL,4,5)
      If [M:CUT]LOTDEB < [M:CUT]SLODEB
          If [M:CUT]SLODEB <= [M:CUT]LOTFIN
            Call MESSAGE (mess(285,193,1)) From GESECRAN : REPONSE =0
          Endif
      Else
          If [M:CUT]LOTDEB <= [M:CUT]SLOFIN
            Call MESSAGE (mess(285,193,1)) From GESECRAN : REPONSE =0
          Endif
      Endif
   Endif
 Endif

Endif
Return

######################################################################################
$CREATION
Call MAJTEXTRA([M]CUTAXX,"TABCABCUT","CUTAXX",[M]FCY,"") From ATEXTRA
Return
######################################################################################
$MODIF
Call MAJTEXTRA([M]CUTAXX,"TABCABCUT","CUTAXX",[M]FCY,"") From ATEXTRA

Return
######################################################################################
$ANNULE
Delete [AXX] Where CODFIC="TABCABCUT" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

######################################################################################
Subprog AM_TYPCAB(VALEUR)
Variable Integer VALEUR
If [M:CUT]TYPCAB <> VALEUR
  Effzo [M:CUT]15,20
  Actzo [M:CUT]15,20
Endif

Case VALEUR
  When 1 : Grizo [M]20
           Case GITMCTL
             When 1 : # pas de recontrôle OF : griser l'ensemble des zones?
             When 2 : # lot recontrôlé
                      Grizo [M:CUT]15
                      Actzo [M:CUT]NUMLOT,LOTSET
             When 3 : # article + lot
                      Grizo [M:CUT]NUMSLO,SLOSET
             When 4 : # lot + slo
                      Grizo [M:CUT]NUMITM,ITMSET
           Endcase
  When 2 : Grizo [M]15
  Case GITMCTL
             When 1 :  # pas de recontrôle OF : griser l'ensemble des zones?
             When 2 :  # lot recontrôlé
                      Grizo [M:CUT]20
                      Actzo [M:CUT]LOTLON,LOTDEB,LOTFIN
             When 3 :  # article + lot
                      Grizo [M:CUT]SLOLON,SLODEB,SLOFIN
             When 4 : # lot + slo
                      Grizo [M:CUT]ITMLON,ITMDEB,ITMFIN
           Endcase
Endcase

End

######################################################################################
Subprog AP_ITMDEB(VALEUR)
Variable Decimal VALEUR
[M:CUT]ITMFIN = VALEUR + [M:CUT]ITMLON -1
Affzo [M:CUT]ITMFIN
End

######################################################################################
Subprog AP_LOTDEB(VALEUR)
Variable Decimal VALEUR
[M:CUT]LOTFIN = VALEUR + [M:CUT]LOTLON -1
Affzo [M:CUT]LOTFIN
End

######################################################################################
Subprog AP_SLODEB(VALEUR)
Variable Decimal VALEUR
[M:CUT]SLOFIN = VALEUR + [M:CUT]SLOLON -1
Affzo [M:CUT]SLOFIN
End

Subprog C_NUMITM(VALEUR)
Variable Decimal VALEUR
If !VALEUR mkstat =2 Endif
End

Subprog C_NUMLOT(VALEUR)
Variable Decimal VALEUR
If !VALEUR mkstat =2 Endif
If VALEUR = [M:CUT]NUMITM
 Call ERREUR (mess(282,193,1)) From GESECRAN : mkstat= 2
Endif
End

Subprog C_LOTSET(VALEUR)
Variable Char    VALEUR()
If  VALEUR=""
 Call ERREUR (mess(283,193,1)) From GESECRAN : mkstat= 2
Endif
End

Subprog C_NUMSLO(VALEUR)
Variable Decimal VALEUR
If !VALEUR mkstat =2 Endif
If VALEUR = [M:CUT]NUMITM | VALEUR = [M:CUT]NUMLOT
 Call ERREUR (mess(304,193,1)) From GESECRAN : mkstat= 2
Endif
End


Subprog C_ITMLON(VALEUR)
Variable Decimal VALEUR
If !VALEUR mkstat =2 Endif
End

Subprog C_ITMDEB(VALEUR)
Variable Decimal VALEUR
If !VALEUR mkstat =2 Endif
End

Subprog C_LOTLON(VALEUR)
Variable Decimal VALEUR
If !VALEUR mkstat =2 Endif
End

Subprog C_LOTDEB(VALEUR)
Variable Decimal VALEUR
If !VALEUR mkstat =2 Endif
If VALEUR = [M:CUT]ITMDEB
    Call ERREUR (mess(284,193,1)) From GESECRAN : mkstat= 2
Endif
End

Subprog C_SLOLON(VALEUR)
Variable Decimal VALEUR
If !VALEUR mkstat =2 Endif
End

Subprog C_SLODEB(VALEUR)
Variable Decimal VALEUR
If !VALEUR mkstat =2 Endif
If VALEUR = [M:CUT]LOTEB
    Call ERREUR (mess(303,193,1)) From GESECRAN : mkstat= 2
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran CUTCAB1) 27/01/2015 15:54:09 (MM)
######################################################################################
Subprog C_ITMSET(VALEUR)
Variable Char    VALEUR()
If  VALEUR=""
 Call ERREUR (mess(283,193,1)) From GESECRAN : mkstat= 2
Endif
End

Subprog C_SLOSET(VALEUR)
Variable Char    VALEUR()
If  VALEUR=""
 Call ERREUR (mess(283,193,1)) From GESECRAN : mkstat= 2
Endif
End


######################################################################################
