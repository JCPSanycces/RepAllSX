#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMBUD1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIGNE
mkstat = 0
zoncou = "NBLIGNE"
indice = 0
status = 1
zoncou = "NBLIGNE"
If varmode([M]NBLIGNE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIGNE" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIGNE
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIGNE = nolign
   status = 75
   Call SAI_NBLIGNE(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIGNE(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIGNE
mkstat = 0
zoncou = "NBLIGNE"

## Zone BTBLIG
mkstat = 0
zoncou = "BTBLIG"
If varinit([M]BTBLIG,indice)=0
 [M]BTBLIG(indice) = "138"
Endif
If varmode([M]BTBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BTBLIG" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone BTNAFFECT
mkstat = 0
zoncou = "BTNAFFECT"
[M]BTNAFFECT(indice) = "167"
If varmode([M]BTNAFFECT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BTNAFFECT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PCCCOD
mkstat = 0
zoncou = "PCCCOD"
WCHAR = [M]PCCCOD(indice)
If varmode([M]PCCCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PCCCOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PCCCOD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PCCCOD" : GZNUM = 43998 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("PJCC","ACD",[M]PCCCOD(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "PCCCOD" : GZNUM = 43998 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]PCCCOD(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_PCCCOD([M]PCCCOD(indice)) From SUBPJBU
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PCCCOD" : GZNUM = 43998 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone PLBDESAXX
mkstat = 0
zoncou = "PLBDESAXX"
WCHAR = [M]PLBDESAXX(indice)
If varinit([M]PLBDESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]PLBDESAXX(indice),"PJMBUDLIG","PLBDESAXX",[M:PJBU0]OPPNUM + "~" + [M:PJBU0A]PBUCOD,num$([M:PJBU1]PLBSEQ(nolign-1))) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]PLBDESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PLBDESAXX" : Gosub ACTION From =IMPTRT
  Endif
  If WCHAR<>[M]PLBDESAXX(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_PLBDESAXX([M]PLBDESAXX(indice)) From SUBPJBU
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PLBDESAXX" : GZNUM = 282 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PCCENAFLG
mkstat = 0
zoncou = "PCCENAFLG"
IMPENT = [M]PCCENAFLG(indice)
If varinit([M]PCCENAFLG,indice)=0
 IMPENT = 1
Endif
[M]PCCENAFLG(indice) = IMPENT

## Zone PLBU
mkstat = 0
zoncou = "PLBU"
WCHAR = [M]PLBU(indice)
If varmode([M]PLBU,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PLBU" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TUN","!B",[M]PLBU(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PLBU" : GZNUM = 2685 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]PLBU(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_PLBU([M]PLBU(indice)) From SUBPJBU
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PLBU" : GZNUM = 2685 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PLBQTY
mkstat = 0
zoncou = "PLBQTY"
WNUM = [M]PLBQTY(indice)
If varmode([M]PLBQTY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PLBQTY" : Gosub ACTION From =IMPTRT
 Endif
 If [M]PLBQTY(indice)<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PLBQTY" : GZNUM = 271 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]PLBQTY(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_PLBQTY([M]PLBQTY(indice)) From SUBPJBU
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PLBQTY" : GZNUM = 271 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PLBPRI
mkstat = 0
zoncou = "PLBPRI"
WNUM = [M]PLBPRI(indice)
SAVACT = GACTION : GACTION = "FMTFM2DEV"
Call FMTFM2DEV([M:PJBU1]CUR(nolign-1)) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]PLBPRI(indice) : Endif
If !mkstat
 If varmode([M]PLBPRI,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PLBPRI" : Gosub ACTION From =IMPTRT
  Endif
  If [M]PLBPRI(indice)<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PLBPRI" : GZNUM = 10964 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]PLBPRI(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_PLBPRI([M]PLBPRI(indice)) From SUBPJBU
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PLBPRI" : GZNUM = 10964 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone PLBAMT
mkstat = 0
zoncou = "PLBAMT"
WNUM = [M]PLBAMT(indice)
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJBU1]CUR(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]PLBAMT(indice) : Endif
If !mkstat
 If varmode([M]PLBAMT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PLBAMT" : Gosub ACTION From =IMPTRT
  Endif
  If [M]PLBAMT(indice)<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PLBAMT" : GZNUM = 3603 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]PLBAMT(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_PLBAMT([M]PLBAMT(indice)) From SUBPJBU
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PLBAMT" : GZNUM = 3603 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone PLBDATBUD
mkstat = 0
zoncou = "PLBDATBUD"
If varmode([M]PLBDATBUD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PLBDATBUD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PLBPRIREM
mkstat = 0
zoncou = "PLBPRIREM"
SAVACT = GACTION : GACTION = "FMTFM2DEV"
Call FMTFM2DEV([M:PJBU1]CUR(nolign-1)) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]PLBPRIREM(indice) : Endif

## Zone PLBAMTREM
mkstat = 0
zoncou = "PLBAMTREM"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJBU1]CUR(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]PLBAMTREM(indice) : Endif

## Zone ORI
mkstat = 0
zoncou = "ORI"
IMPENT = [M]ORI(indice)
If varinit([M]ORI,indice)=0
 IMPENT = 1
Endif
[M]ORI(indice) = IMPENT

## Zone PLBFLGREM
mkstat = 0
zoncou = "PLBFLGREM"
IMPENT = [M]PLBFLGREM(indice)
If varinit([M]PLBFLGREM,indice)=0
 IMPENT = 1
Endif
[M]PLBFLGREM(indice) = IMPENT

## Zone PLBAMTEST
mkstat = 0
zoncou = "PLBAMTEST"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJBU1]CUR(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]PLBAMTEST(indice) : Endif

## Zone PLBAMTREC
mkstat = 0
zoncou = "PLBAMTREC"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJBU1]CUR(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]PLBAMTREC(indice) : Endif

## Zone NBLIGNE
mkstat = 0
zoncou = "NBLIGNE"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMBUD1"
Return

