#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PRF2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:05"
A_USER  = "DOC"
A_STAMP = "20181109230605"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "TBL"
  If [M]TBL=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PRF2 [PRF2]
Gosub HORODAT
Local Inpbox "PRF2" From GFONCTION At A_STAMP With A_WINDPREV Mask [PRF2] As [SIM_]
Grizo [PRF2]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PRF2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=24
Return

$ON_TBL
Onevent BEFORE_INPUT Call AS_TBL From W1PRF2
Return

Subprog AS_TBL
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45002,GBOUT1) From OBJDIV
Call TEXTE(47762,GBOUT2) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_TBL From W1PRF2
Onkey 130 Titled GBOUT2 Call B2_TBL From W1PRF2
Gosub _AFF
End

Subprog B1_TBL
Local Decimal BASPAG
If !GWEBSERV
 ## Action PRFRUB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PRFRUB"
 Call TRAITE_NUM(BASPAG,PARMSK,"","SUBPRF","PRFRUB",3,"SPEPRF") From GTRAITE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_TBL
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B2_TBL From SUBPRF
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CODE
Onevent CONTROL Call C_CODE(zc) From W1PRF2
Onevent BEFORE_INPUT Call AS_CODE(zc) From W1PRF2
Onevent AFTER_CHANGE Gosub AMM_CODE From W1PRF2
Return

Subprog AS_CODE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(18525,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CODE(zc) From W1PRF2
Onkey   2 Titled GBOUTS Call S_CODE(zc) From W1PRF2
Onkey 144 Titled GBOUTP Call P_CODE(zc) From W1PRF2
Onkey 146 Titled GBOUTA Call SA_CODE(zc) From W1PRF2
Gosub _AFF
End

Subprog C_CODE(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CODE" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTRUB
 Call CONTRUB(VALEUR) From SUBRUB
 If mkstat : GERR = 1 : GZONE = "CODE" : GZNUM = 5296 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODE" : GZNUM = 5296 : Endif
  If !mkstat
   ## Action STD
   Call C_CODE(VALEUR) From SUBPRF
   If mkstat : GERR = 1 : GZONE = "CODE" : GZNUM = 5296 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CODE
Call AM_CODE(zc)
If !mkstat & GOBJET
 zoncou = "CODE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODE(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCODE)")>indice
 [M]CODE(indice) = VALEUR
 Affzo ZCODE(indice)
Endif
Gosub _AFF
End

Subprog S_CODE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELRUB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELRUB"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELRUB","SUBRUB","SPERUB") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CODE(VALEUR)
Variable Char    VALEUR()
Call OBJET("RUB",VALEUR,num$(GCURLEG)) From GOBJET
Gosub _AFF
End

Subprog SA_CODE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "RUB"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("RUB",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCODE
Onevent BEFORE_AREA Gosub AV_ZCODE From W1PRF2
Return

$AV_ZCODE
Call LECTEXTRA(zc,"RUBRIQUE","DES",num$(GCURLEG),num$([M]CODE(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_TYPRUB
Onevent INIT_AREA Call D_TYPRUB(zc) From W1PRF2
Return

Subprog D_TYPRUB(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPRUB,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CALCUL
Onevent INIT_AREA Call D_CALCUL(zc) From W1PRF2
Onevent BEFORE_INPUT Call AS_CALCUL(zc) From W1PRF2
Return

Subprog D_CALCUL(VALEUR)
Variable Integer VALEUR
If varinit([M]CALCUL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CALCUL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47557,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CALCUL(zc) From W1PRF2
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog B1_CALCUL(VALEUR)
Variable Integer VALEUR
If !GWEBSERV
 ## Action STD
 Call B1_CALCUL(VALEUR) From SUBPRF
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


