#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque MAI4
##########################################################################################################
Subprog B1_NBQADD(VALEUR)
Variable Decimal VALEUR

  If !GINTRA Then
    Call TEMPON("A") From GESECRAN
  Endif
  Call DELEMPADD("ADD") From TRTMAI4
  If !GINTRA Then
    Call TEMPOFF From GESECRAN
  Endif
End

