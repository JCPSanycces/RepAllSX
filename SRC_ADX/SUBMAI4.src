##########################################################################################################
Subprog B1_NBCCN
Local Integer IOKREP

  IOKREP = 0
  #Confirmez-vous la suppression de la totalité des enregistrements composant l'échantillon actuel ?
  Call OUINON(mess(805,196,1), IOKREP) From GESECRAN
  If IOKREP = 2 Then
    If !GINTRA Then
      Call TEMPON("A") From GESECRAN
    Endif
    Call DELEMPADD("ALL") From TRTMAI4
    If !GINTRA Then
      Call TEMPOFF From GESECRAN
    Endif
  Endif
End

##########################################################################################################
Subprog IB_NBCCN
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESOMM" or GNAVIG(GPILNAV-1) = "GESOMP" Then
      Raz GBOUT1
    Else
      If nolign >= dim([M:MAI4]CNTFULNAM) Then
        Raz GBOUT1
      Else
        If [M:MAI4]CNTFULNAM(nolign-1) = "" Then
          Raz GBOUT1
        Else
          GBOUT1 = mess(412,196,1) #Vider la sélection
        Endif
      Endif
    Endif
  Else
    If nolign >= dim([M:MAI4]CNTFULNAM) Then
      Raz GBOUT1
    Else
      If [M:MAI4]CNTFULNAM(nolign-1) = "" Then
        Raz GBOUT1
      Else
        GBOUT1 = mess(412,196,1) #Vider la sélection
      Endif
    Endif
  Endif
  If GSZTYPSEA = "CCN" Then
    GBOUT2 = mess(803,196,1)   #Visualiser l'interlocuteur
    Raz GBOUT3
  Elsif GSZTYPSEA = "BPR" Then
    Raz GBOUT2
    GBOUT3 = mess(804,196,1)   #Visualiser le tiers
  Else
    Raz GBOUT2
    Raz GBOUT3
  Endif
End

##########################################################################################################
Subprog AS_NBCCN

  GIMAI4NOL = nolign-1
End

##########################################################################################################
Subprog IB_NBQADD

  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESOMM" or GNAVIG(GPILNAV-1) = "GESOMP" Then
      Raz GBOUT1
    Else
      #Retirer de la liste
      Call TEXTE(16744, GBOUT1) From OBJDIV
    Endif
  Else
    #Retirer de la liste
    Call TEXTE(16744, GBOUT1) From OBJDIV
  Endif
End

