#<AdxTL>@(#)0.0.0.0 $Revision$ Sage 50 payroll integration
###########################################################################################
# CUSTOM SUB ROUTINES
#
# $INTIT_ACC        = Define Account code column headers - details screen
# $INTIT_CCE        = Define Dimension code column headers - details screen
###########################################################################################
# CUSTOM SUB PROGRAMS
#
# LOAD_CCE_TBL_MSK   - Load values from table array into mask [F]CCE(20) to [M]CCE1..[M]CCE20
# LOAD_ACC_TBL_MSK   - Load values from table array into mask [F]ACC(10) to [M]ACC1..[M]ACC10
# DELETE_RECORD      - Remove current payroll transaction from database
# POST_JOURNAL       - Generate automatic journal for current payroll transaction
# DISPLAY_CR_DB_VAL  - Place AMTCUR value into the correct debit credit screen columns
# CALCULATE_TOTALS   - Calculate and display on screen total debit and credit values
# SCREEN_GRIZO       - Select which header summary & details fields are editable
# LOAD_DIE_TYPE      - Load Dimension types onto header screen
# LOAD_COA_CODE      - Load Charts of Account onto header screen
# LOAD_DIE_FMT       - Load Dimension type format string onto header screen
# LOAD_COA_FMT       - Load Chart of Account type format string onto header screen
# GET_ACC_COLUMN_HRR - set ACC1 to ACC10 column header titles
# GET_CCE_COLUMN_HDR - Set CCE1 to CCE20 column header titles
###########################################################################################
# SCREEN ACTIONS
#
# AM_ACC1           - After Change
# C_ACCDAT          - Control
###########################################################################################
# TODO LIST
# SEARCH FOR TODO in source file for any outstanding questions issues
###########################################################################################
# NOTE
# Record creation is handled exclusively by:-
# Import template – KPY
# Import process  - KPYIMPORT
###########################################################################################
#X3-39795  MDJ   Manage ORIGIN and ORICOD fields in GL Entry
# Last Update 19th Sept 2014

Raz GBIDC1
    Call OBJET("KPY",GBIDC1,"1") From GOBJET
End

$ACTION
    Case ACTION
        When "OUVRE"         : Gosub OUVRE                    : # After opening the tables and screens
        When "LIENS"         : Gosub LIENS                    : # After reading a record
        When "CREATION"      : Gosub CREATION From TABLEAUX   : # During the creation transaction
        When "MODIF"         : Gosub MODIF From TABLEAUX      : # During the modification transaction
        When "ANNULE"        : Gosub ANNULE From TABLEAUX     : # During record cancellation
        When "APRES_CRE"     : Gosub LIENS From TABLEAUX      : # At the end of creation (transaction over)
        When "APRES_MOD"     : Gosub LIENS From TABLEAUX      : # At the end of creation (transaction over)
        When "FILTRE"        : Gosub FILTRE                   : # Definition of the criteria used as filter on the main table
        When "INICRE_LIG"    : Gosub INICRE_LIG               : # Insert detail line
        When "DEFLIG"        : Gosub DEFLIG                   : # called by TABLEAUX process
        When "AVANTBOUT"     : Gosub AVANTBOUT                : # Before executing a button or menu declared in the window
        When "LIENS_LIG"     : Gosub LIENS_LIG                : # called by TABLEAUX process
        When "SETBOUT"       : Gosub SETBOUT                  : # Deactivation of the buttons and activation of the menus
        When "INIMOD_LIG"    : Gosub INIMOD_LIG               : # call for each modified detail line
        When "FERME"         : Gosub FERME                    : # Last executed action
        When "APRES_MODIF"   : Gosub APRES_MODIF
        When "FILGAUCHE"     : Gosub FILGAUCHE                : # Filter left list rows not last read list
     Endcase
Return


###########################################################################################
# OBJECT ACTION GOSUB's
###########################################################################################

$OUVRE
    Gosub DECLARE From TABLEAUX

    Global Integer ALLOW_TRANSCRIBE
    Global Integer GNBPLAN                                         # Number of charts of accounts managed by the company (max 10)
    Global Integer GNBAXE                                          # Number of dimensions managed by the company (max 20)
    Global Char    GPLAN(GLONCOA)(1..max(len(mess(0,2644,1)),10))  # Charts of accounts managed by the company
    Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))              # Dimensions types managed by the company
    Global Integer GOBLIG(1..max(GOPTCANA,20))                     # Mandatory (O/N) – perhaps you will not use, but the SETPLAN2 needs this parameter
    Global Integer GTYPLED(1..max(len(mess(0,2644,1)),10))         # Ledger Types managed by the company - perhaps you will not use, but the SETPLAN2 needs this parameter
    Global Char    GCODLED(GLONLED)(1..10)                         # Ledger code (LED)


    Local  Char    CODDIM(30)                                      # Holds name of default dimension code - GESCDE function
    Local  Integer IND
    Local  Integer AXI
    Local  Char    AUTOJNCODE(30)                                      # Automatic Journal Code

    If clalev([F:GAC])=0  : Local File GACCOUNT    [GAC]  : Endif    : # Accounts
    If clalev([F:KPT])=0  : Local File KPYIMPTRAN  [KPT]  : Endif    : # Sage 50 import transcribe

    # INI SAM 106404
    If func AFNC.ACTIV("MURAN")>0
      If clalev([F:KPA])=0  : Local File KPYIMPDTLA [KPA]  : Endif
      If clalev([M:VTL])=0  : Local Mask VENTILE    [VTL]  : Endif
      If clalev([M:VT2])=0  : Local Mask VENTILE2   [VT2]  : Endif
      If clalev([F:DSP])=0  : Local File CADSP      [DSP]  : Endif
      If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
      If clalev([F:TUN])=0  : Local File TABUNIT    [TUN]  : Endif
      If clalev([F:CAC])=0  : Local File GACCCODE   [CAC]  : Endif
      Local Integer LIGANA, DSPOK
    Endif
    # END SAM 106404

Return

$FILTRE
    Default File [KPH]                 : # Set header table [KPYIMPHDR]  as default
Return

$LIENS
    #Gosub LIENS From TABLEAUX
    ########################################
    # set environment global variable for
    # selected site value
    #
    Call GETSOC([F:KPH]FCY) From DEVSUB
    Read[CPY]CPY0 = GSOCIETE
    Call SETPLAN2([F:CPY]ACM,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV

    Call LOAD_DIE_TYPE          : # Load Dimension types onto header screen
    Call LOAD_COA_CODE          : # Load Charts of Account onto header screen
    Call LOAD_LED_CODE          : # Load Ledger codes onto header screen
    Call LOAD_DIE_FMT           : # Load Dimension type format string onto header screen
    Call LOAD_COA_FMT           : # Load Chart of Account type format string onto header screen
    Call GET_ACC_COLUMN_HRR     : # set ACC1 to ACC10 column header titles
    Call GET_CCE_COLUMN_HDR     : # Set CCE1 to CCE20 column header titles

    If GIMPORT = 0              : # call sub if in interactive mode
      If func AFNC.ACTIV("MURAN")>0  # INI SAM 106404
        Call LOAD_FLD_FMT     : # To hide or display colums in this detail
      Endif
      Call SCREEN_GRIZO
    Endif

    Gosub LIENS From TABLEAUX

    Call CALCULATE_TOTALS            : # Calculate on screen total debit and credit values

Return

DEFLIG
    Default Mask [KPYD]                : # Set detail [KPYDTL] screen as default screen
    Default File [KPD]                 : # Set detail [KPYIMPDTL] table as default
    CRIT='RECID="'+[M:KPYH]RECID+'"'   : # Primary key
    FICLIG="KPYIMPDTL"                 : # Detail table name
    ABLIG="KPD"                        : # Detail table alias
    ZONLIG="LINENO"                    : # Detail line identifier
Return

$INICRE_LIG
    # Map Primary key from header screen to detail table
    [F:KPD]RECID = [M:KPYH]RECID
    # Load Chart of Account codes into detail line array
    # Load values from screen ACC1 to ACC10 in to [F]ACC(10) array
    For COUNTER = 0 To GNBPLAN -1
        Assign "[F:KPD]COA("+num$(COUNTER)+")" With GPLAN(COUNTER+1)
        Assign "[F:KPD]ACC("+num$(COUNTER)+")" With evalue ("[M]ACC"+num$(COUNTER+1)+"("+num$(nolign-1)+")")
    Next COUNTER

    # Load Dimension type codes into detail line array
    # Load values from screen CCE1 to CCE20 in to [F]CCE(20) array
    For COUNTER = 0 To GNBAXE - 1
        Assign "[F:KPD]DIE("+num$(COUNTER)+")" With GAXE(COUNTER+1)
        Assign "[F:KPD]CCE("+num$(COUNTER)+")" With evalue ("[M]CCE"+num$(COUNTER+1)+"("+num$(nolign-1)+")")
    Next COUNTER
Return

$INIMOD_LIG
    # Load values from screen CCE1 to CCE20 in to [F]CCE(20) array
    For COUNTER = 0 To GNBAXE - 1
          Assign "[F:KPD]CCE("+num$(COUNTER)+")" With evalue ("[M]CCE"+num$(COUNTER+1)+"("+num$(nolign-1)+")")
    Next COUNTER

    # Load values from screen ACC1 to ACC10 in to [F]ACC(10) array
    For COUNTER = 0 To GNBPLAN -1
          Assign "[F:KPD]ACC("+num$(COUNTER)+")" With evalue ("[M]ACC"+num$(COUNTER+1)+"("+num$(nolign-1)+")")
    Next COUNTER

Return


$AVANTBOUT
    # y = delete button
    # z = post button
    Case BOUT
        When "Y"    : Call DELETE_RECORD
        When "Z"    : Call POST_JOURNAL
    Endcase
Return

$LIENS_LIG
    Call DISPLAY_CR_DB_VAL    : # Populate screen Debit / Credit using AMTCUR & SNS field values
    Call LOAD_CCE_TBL_MSK     : # Populate screen CCE1 to CCE20 fields with values from CCE(20) table array
    Call LOAD_ACC_TBL_MSK     : # Populate screen ACC1 to ACC10 fields with values from ACC(10) table array

    # Init SAM 106404
    If func AFNC.ACTIV("MURAN")>0
      If [M:KPYH]ORIPAY=2
        If GREP="M" and [M:KPYD]DSP(nolign-1)="$": Trbegin[KPD] : Raz [F:KPD]DSP: Rewrite: Commit : Raz [M:KPYD]DSP(nolign-1) : Endif
        Gosub LOAD_DSP_LIN
      Endif
    Endif
    # End SAM 106404

Return

$SETBOUT
    # AF = zoom to transcibe menu option
    # AE = zoom to journal menu option
    If func AFNC.ACTIV("MURAN")>0
      If [M:KPYH]ORIPAY<>2
        CHMEN += "AF"
      Endif
    Else
      CHMEN += "AF"
    Endif
    #CHMEN += "AE"
    # Deactivate POST button if:-
    #    transaction already posted to GL
    #    transaction in modification mode
    #    transaction in create mode
    #    transaction total credits not equal to total debits

    # Init SAM 106404
    If func AFNC.ACTIV("MURAN")>0
      If [M:KPYH]ORIPAY=2
        If [M:KPYM]STA = 2 or GREP = "M" or GREP = "C"
          Call VIREBOUT(CHAINE,"Z") From GOBJET
          Call VIREBOUT(CHAINE,"Y") From GOBJET
        Endif
      Else
        If [M:KPYM]STA = 2  or GREP = "M" or GREP = "C" or [M:KPYD]DBTOT <> [M:KPYD]CRTOT
          Call VIREBOUT(CHAINE,"Z") From GOBJET
          Call VIREBOUT(CHAINE,"Y") From GOBJET
        Endif
       Endif
    Else    # End SAM 106404
      If [M:KPYM]STA = 2  or GREP = "M" or GREP = "C" or [M:KPYD]DBTOT <> [M:KPYD]CRTOT
        Call VIREBOUT(CHAINE,"Z") From GOBJET
        Call VIREBOUT(CHAINE,"Y") From GOBJET
      Endif
    Endif

    If func AFNC.ACTIV("MURAN")>0 # SAM 106404
      If [M:KPYH]ORIPAY<>2 or [M:KPYH]FLGVAL=2 or [M:KPYM]NUM<>""
        Call VIREBOUT(CHAINE,"V") From GOBJET
      Endif
      # Daactivate POST button if ORIPAY is Murano and it is not valid # SAM 106404
      If [M:KPYH]ORIPAY=2 and [M:KPYH]FLGVAL=1
        Call VIREBOUT(CHAINE,"Z") From GOBJET
      Endif
    Endif

    # Deactivate DELETE button if transaction already posted to GL
    If [M:KPYM]STA = 2
        Call VIREBOUT(CHAINE,"Y") From GOBJET
    Endif

    # Active the show journal menu option if journal number is present ie posted
    If [M:KPYM]NUM <> ""
        CHMEN += "AE"
    Endif

    Call SCREEN_GRIZO
Return

$APRES_MODIF
    # Populate header Analysis field with values from current detail line
    [M:KPYH]ACC_CODE     =  [M:KPYD]ACC_CODE(nolign-1)     : Affzo  [M:KPYH]ACC_CODE
    [M:KPYH]DEPT         =  [M:KPYD]DEPT(nolign-1)         : Affzo  [M:KPYH]DEPT
    [M:KPYH]COSTCENTRE   =  [M:KPYD]COSTCENTRE(nolign-1)   : Affzo  [M:KPYH]COSTCENTRE
    [M:KPYH]EMPLOYEE     =  [M:KPYD]EMPLOYEE(nolign-1)     : Affzo  [M:KPYH]EMPLOYEE
    [M:KPYH]CCEACC_CODE  =  [M:KPYD]CCEACC_CODE(nolign-1)  : Affzo  [M:KPYH]CCEACC_CODE
    [M:KPYH]CCEDEPT      =  [M:KPYD]CCEDEPT(nolign-1)      : Affzo  [M:KPYH]CCEDEPT
    [M:KPYH]CCECOSTCENTR =  [M:KPYD]CCECOSTCENTR(nolign-1) : Affzo  [M:KPYH]CCECOSTCENTR
    [M:KPYH]CCEEMPLOYEE  =  [M:KPYD]CCEEMPLOYEE(nolign-1)  : Affzo  [M:KPYH]CCEEMPLOYEE
Return


$FILGAUCHE
    # CURRBOX = selected left list
    # filter data for selected left list
    Case currbox
        When "GAU_CHE1" : # Unposted transaction
#            FILGAUSUP(1) = "&STA=1"      #SAM 106404
            FILGAUSUP = "[F:KPH]STA=1"    #SAM 106404
    Endcase
Return

$FERME
    Close Local Mask
    Kill ALLOW_TRANSCRIBE
    Kill GNBPLAN
    Kill GNBAXE
    Kill GPLAN
    Kill GAXE
    Kill GOBLIG
    Kill GTYPLED
    Kill GCODLED
    ## TODO should I kill all local variable created? JAMCC

Return

###########################################################################################
# CUSTOM GOSUB's
# $INTIT_ACC = Define Account code column headers - details screen
# $INTIT_CCE = Define Dimension code column headers - details screen
###########################################################################################
$INTIT_ACC
    # Define Account code column headers - details screen
    Case COUNTER
        When 1  : Titcol [M:KPYD]NBLIG [M:KPYH]TITCOA(COUNTER-1) For ACC1
        When 2  : Titcol [M:KPYD]NBLIG [M:KPYH]TITCOA(COUNTER-1) For ACC2
        When 3  : Titcol [M:KPYD]NBLIG [M:KPYH]TITCOA(COUNTER-1) For ACC3
        When 4  : Titcol [M:KPYD]NBLIG [M:KPYH]TITCOA(COUNTER-1) For ACC4
        When 5  : Titcol [M:KPYD]NBLIG [M:KPYH]TITCOA(COUNTER-1) For ACC5
        When 6  : Titcol [M:KPYD]NBLIG [M:KPYH]TITCOA(COUNTER-1) For ACC6
        When 7  : Titcol [M:KPYD]NBLIG [M:KPYH]TITCOA(COUNTER-1) For ACC7
        When 8  : Titcol [M:KPYD]NBLIG [M:KPYH]TITCOA(COUNTER-1) For ACC8
        When 9  : Titcol [M:KPYD]NBLIG [M:KPYH]TITCOA(COUNTER-1) For ACC9
        When 10 : Titcol [M:KPYD]NBLIG [M:KPYH]TITCOA(COUNTER-1) For ACC10
    Endcase
Return

$INTIT_CCE
    # Define Dimension code code column headers - details screen
    Case COUNTER
        When 1  : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE1
        When 2  : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE2
        When 3  : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE3
        When 4  : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE4
        When 5  : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE5
        When 6  : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE6
        When 7  : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE7
        When 8  : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE8
        When 9  : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE9
        When 10 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE10
        When 11 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE11
        When 12 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE12
        When 13 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE13
        When 14 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE14
        When 15 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE15
        When 16 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE16
        When 17 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE17
        When 18 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE18
        When 19 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE19
        When 20 : Titcol [M]NBLIG [M:KPYH]TITCCE(COUNTER-1) For CCE20
    Endcase
Return

###########################################################################################
# SUBPROGRAMS
#
# LOAD_CCE_TBL_MSK   - Load values from table array into mask [F]CCE(20) to [M]CCE1..[M]CCE20
# LOAD_ACC_TBL_MSK   - Load values from table array into mask [F]ACC(10) to [M]ACC1..[M]ACC10
# DELETE_RECORD      - Remove current payroll transaction from database
# POST_JOURNAL       - Generate automatic journal for current payroll transaction
# DISPLAY_CR_DB_VAL  - Place AMTCUR value into the correct debit credit screen columns
# CALCULATE_TOTALS   - Calculate and display on screen total debit and credit values
# SCREEN_GRIZO       - Select which header summary & details fields are editable
# LOAD_DIE_TYPE      - Load Dimension types onto header screen
# LOAD_COA_CODE      - Load Charts of Account onto header screen
# LOAD_LED_CODE      - Load Ledger codes onto header screen
# LOAD_DIE_FMT       - Load Dimension type format string onto header screen
# LOAD_COA_FMT       - Load Chart of Account type format string onto header screen
# GET_ACC_COLUMN_HRR - set ACC1 to ACC10 column header titles
# GET_CCE_COLUMN_HDR - Set CCE1 to CCE20 column header titles
###########################################################################################

#########################################
# Load Dimension types onto header screen
#
Subprog LOAD_DIE_TYPE
    For COUNTER = 0 To GNBAXE-1
    [M:KPYH]DIE(COUNTER) = GAXE(COUNTER+1)
    Next COUNTER
End

#########################################
# Load Charts of Account onto
# header screen
#
Subprog LOAD_COA_CODE
  For COUNTER = 0 To GNBPLAN-1
        [M:KPYH]COA(COUNTER) = GPLAN(COUNTER+1)
  Next COUNTER
End

#########################################
# Load Dimension type  format string
# onto header screen
#
Subprog LOAD_DIE_FMT
  Call GLOBVAR    From SETGLBDIE
  Call INIGLBDIE  From SETGLBDIE
  For COUNTER = 0 To GNBAXE - 1
      Call INICCEFMT([M:KPYH]DIE(COUNTER)) From SETGLBDIE
      FMT = "K:"+GCCEFMT
      Assign "[M:KPYH]FMTCCE("+num$(COUNTER)+")" With FMT
  Next COUNTER
End

#########################################
# load Chart of Account format string
# onto header screen
#
Subprog LOAD_COA_FMT
    Call GLOBVAR    From SETGLBCOA
    Call INIGLBCOA  From SETGLBCOA
    For COUNTER = 0 To GNBPLAN - 1
        Call INIACCFMT([M:KPYH]COA(COUNTER)) From SETGLBCOA
        FMT = "K:"+GFMTACC
        Assign "[M:KPYH]FMTCOA("+num$(COUNTER)+")" With FMT
    Next COUNTER
End

#########################################
# set COA column header titles
#
Subprog GET_ACC_COLUMN_HRR
    For COUNTER = 1 To GNBPLAN
        Call LECTURE("COA",evalue("GPLAN("+num$(COUNTER)+")"),"") From CONTOBJ
        Call LECTEXTRA([M:KPYH]TITCOA(COUNTER-1),"GCOA","COLHEA",[M:KPYH]COA(COUNTER-1),"") From ATEXTRA
        Gosub INTIT_ACC
    Next COUNTER
End

#########################################
# Load format fields to show or hide fields in detail
# SAM 106404
Subprog LOAD_FLD_FMT
  Actzo [M:KPYH]FMTFLD
  If [M:KPYH]ORIPAY<>2
    Assign "[M:KPYH]FMTFLD(0)"  With ""
    Assign "[M:KPYH]FMTFLD(1)"  With "K:10X"
    Assign "[M:KPYH]FMTFLD(2)"  With "K:20X"
    Assign "[M:KPYH]FMTFLD(3)"  With "K:50X"
  Else
    Assign "[M:KPYH]FMTFLD(0)"  With "Kf:d9c"
    Assign "[M:KPYH]FMTFLD(1)"  With ""
    Assign "[M:KPYH]FMTFLD(2)"  With ""
    Assign "[M:KPYH]FMTFLD(3)"  With ""
  Endif

End

#########################################
# Load Ledger Codes onto header screen
#
Subprog LOAD_LED_CODE
    Local Char    MODELE(30)    : # Modèle comptable
    Local Char    CODLED(30)(1..)
    Local Integer NLED

    Call SETGCM([F:KPH]FCY,MODELE) From CPTDIV
    IMOD= find(MODELE,GGCM(1..GGCMNBR))
    If !IMOD
        Call GLOBVAR From SETGLBGCM
        IMOD = find(MODELE,GGCM(1..GGCMNBR))
    Endif
    If IMOD
        For IREF=1 To len(mess(0,2644,1))
            REF = evalue("GLED"+num$(IREF)+"("+num$(IMOD)+")")
            If REF<>"" & !find(REF,CODLED(1..10))
                NLED+=1
                CODLED(NLED) = REF
            Endif
        Next
    Endif

    For COUNTER = 0 To 9
        Assign "[M:KPYH]LED("+num$(COUNTER)+")" With CODLED(COUNTER+1)
    Next COUNTER
End

#########################################
# set CCE column header titles
#
Subprog GET_CCE_COLUMN_HDR
    For COUNTER = 1 To GNBAXE
        Call LECTURE("DIE",evalue("GAXE("+num$(COUNTER)+")"),"") From CONTOBJ
        Call LECTEXTRA([M:KPYH]TITCCE(COUNTER-1),"GDIE","COLHEA",[M:KPYH]DIE(COUNTER-1),"") From ATEXTRA
        Gosub INTIT_CCE
    Next COUNTER
End

##################################################
# Load values from table array into mask
# [F]CCE(20) to [M]CCE1 ... [M]CCE20
Subprog LOAD_CCE_TBL_MSK
    For AXE=1 To GNBAXE
        If [F:KPD]DIE(AXE-1)<>""
            Assign "[M]CCE"+num$(AXE)+"("+num$(nolign-1)+")" With [F:KPD]CCE(AXE-1)
        Endif
    Next AXE
End

##################################################
# Load values from table array into mask
# [F]ACC(10) to [M]ACC1 ... [M]ACC10
Subprog LOAD_ACC_TBL_MSK
    For PLAN=1 To GNBPLAN
        If [F:KPD]COA(PLAN-1)<>""
            Assign "[M]ACC"+num$(PLAN)+"("+num$(nolign-1)+")" With [F:KPD]ACC(PLAN-1)
        Endif
    Next PLAN
End


#####################################
# Place AMTCUR value into the correct
# debit credit screen columns
#
Subprog DISPLAY_CR_DB_VAL
    If [F:KPD]SNS = 1
        [M:KPYD]DEB(nolign-1) = [M:KPYD]AMTCUR(nolign-1)
        Affzo [M:KPYD]DEB(nolign-1)
    Endif

    If [F:KPD]SNS=-1
        [M:KPYD]CDT(nolign-1) = [M:KPYD]AMTCUR(nolign-1)
        Affzo [M:KPYD]CDT(nolign-1)
    Endif
End

#####################################
# Calculate on screen total debit
# and credit values
#
Subprog CALCULATE_TOTALS
    Local Decimal TCR
    Local Decimal TDB

    For COUNTER = 0 To [M:KPYD]NBLIG-1
        TDB = TDB + [M:KPYD]DEB(COUNTER)
        TCR = TCR + [M:KPYD]CDT(COUNTER)
    Next COUNTER

    [M:KPYD]DBTOT  = TDB           : Affzo [M:KPYD]DBTOT
    [M:KPYD]CRTOT  = TCR           : Affzo [M:KPYD]CRTOT
    [M:KPYD]CRCUR  = [M:KPYM]CUR   : Affzo [M:KPYD]CRCUR
    [M:KPYD]DBCUR  = [M:KPYM]CUR   : Affzo [M:KPYD]DBCUR
    [M:KPYD]TOTCUR = [M:KPYM]CUR   : Affzo [M:KPYD]TOTCUR
    [M:KPYD]SRCTOT = [M:KPYM]TOT   : Affzo [M:KPYD]SRCTOT
End

#####################################
# Remove Payroll record from database
#
Subprog DELETE_RECORD

# TODO Join header and details deletion so one not deleted without the other
    Local Integer YESNO : YESNO = 1

    # INI SAM 106404
    Local Char WMSG(100)
    WMSG=mess(8,3701,1)-[M]RECID

    If func AFNC.ACTIV("MURAN")>0
    # user to confirm if deletion to executed
      If [M:KPYM]STA=2: End: Endif
      If [M:KPYH]FLGVAL=2    #This payroll record is flagged as validated.Do you wish to continue?
        WMSG=mess(193,104,1)+"."-mess(205,100,1)
      Endif
    Endif

    Call OUINON (WMSG, YESNO) From GESECRAN
#      Call OUINON (mess(8,3701,1)-  [M]RECID , YESNO) From GESECRAN
    # END SAM 106404

    If YESNO = 2 : # 2 = YES
      Trbegin KPYIMPDTL [KPD]
        Delete [KPD] Where [F:KPD]RECID = [M:KPYH]RECID
        If fstat = 1
            GOK = 1
            Rollback
        Else
            GOK = 2
            Commit
        Endif

        If GOK = 2
            Trbegin KPYIMPHDR [KPH]
            Delete [KPH] Where [F:KPH]RECID = [M:KPYH]RECID
            If fstat = 1
                Infbox mess (9,3701,1) # num$(adxdlrec)
                Rollback
            Else
                Infbox mess(10,3701,1)# -num$(adxdlrec)
               Commit
            Endif

            ################ tidy screens
            Raz   [M:KPYH] : # Header screen
            Raz   [M:KPYD] : # Detail screen
            Raz   [M:KPYM] : # Summary screen
            Affzo [M:KPYH] : # Header screen
            Affzo [M:KPYD] : # Detail screen
            Affzo [M:KPYM] : # Summary screen
        Endif
    Endif
End

#####################################
# Read GAU to use from transcribe
# site record
# generate automatic journal
#
Subprog POST_JOURNAL

    Local Char    CRIT(250)            # record selection criteria
    Local Char    DKEY(30)             # source transation ID
    Local Char    MESSAGE(250)         # message returned by create auto journal process
    Local Integer STAT                 # status flag returned by create auto journal process

    # INI SAM 106404
    Local Char    AUTOJNCODE(GLONGAU)  # automatic journal
    Local Integer GROUP                # Global accounting
    Local Char    WMSG(250)            # Record or lot

    If func AFNC.ACTIV("MURAN")>0
       If [F:KPH]ORIPAY=2
        AUTOJNCODE= [F:KPH]COD
        If GCUR="": Call GET_CUR(GACTX,1,[F:KPH]CPY,GCUR,MESSAGE) From FINCUR_SYRA: Endif
      Endif
    Endif
    # END SAM 106404

    If AUTOJNCODE=""  # SAM 106404
      # Get automatic journal code from transcribe table store in AUTOJNCODE
      Read [KPT]KPYT0  = 1 ;  [F:KPH]TMPFCY
      AUTOJNCODE = [KPT]GAU
    Endif             # SAM 106404

    DBKEY = evalue("[F:KPH]RECID")
    CRIT = "[F]RECID = " + chr$(34) + DBKEY + chr$(34)

    # INI SAM 106404
    If func AFNC.ACTIV("MURAN")>0
      If [F:KPH]ORIPAY=2 and [F:KPH]FLGDET=1
        GROUP=1
      Endif
    Endif
    # END SAM 106404

    # Ask user to Confirm that journal posting should start
    Local Integer YESNO : YESNO = 1
    # INI SAM 106404
    If GROUP=0
      WMSG=mess (17,3701,1) - [M:KPYH]RECID
    Else
      WMSG=mess (199,104,1) - [M:KPYM]LOT
    Endif

    Call OUINON (WMSG, YESNO) From GESECRAN # Post Payroll File
#    Call OUINON (mess (17,3701,1) - [M]RECID , YESNO) From GESECRAN # Post Payroll File
    # END SAM 106404

    If YESNO  = 1:  End:   Endif

    If YESNO = 2
      # INI SAM 106404
      If GROUP=0
        WMSG=mess(19,3701,1) - num$([M:KPYH]RECID)
      Else
        WMSG=mess(154,105,1)  -  [M:KPYM]LOT
      Endif
      # END SAM 106404

      Call OUVRE_TRACE(mess (17,3701,1)) From LECFIC
      Call ECR_TRACE("",0) From GESECRAN
      Call ECR_TRACE(WMSG,0) From GESECRAN      #SAM 106404
      Call ECR_TRACE(" ",0) From GESECRAN

      # INI SAM 106404
      # Control over the number of the lines in global journal type
      If GROUP=1
        Local Char CRITCUR(80), GRPCUR(30)(1..)
        Local Integer I, NBCUR

        Gosub CHECK_CUR   #Split by currency

        For I=1 To NBCUR
          Call CTR_LINES(GRPCUR(I)) From TRTMURANO
        Next
      Endif
      # END SAM 106404
    Endif

    If GROUP=0    # SAM 106404
      # X3-39795 Start
      # Call VALPCE2(AUTOJNCODE,CRIT,STAT,MESSAGE) From CPTAUTO
      Local Char    TZONE(10)(1..10)           : # Table of the zones to be forced (Ex: ORICOD)
      Local Char    TVAL(30)(1..10)            : # Table of values for zones to be forced
      TZONE(5)="ORIGIN" : TVAL(5)="2"               : # X3-39795 Automatic loading
      TZONE(6)="ORICOD" : TVAL(6)= AUTOJNCODE       : # X3-39795
      Call VALPCE4(AUTOJNCODE,CRIT,STAT,MESSAGE,TZONE,TVAL) From CPTAUTO
      # X3-39795 End


      # If journal posted ok inform user and write journal no to Payroll record
      If STAT = 0 and MESSAGE <> ""
        Call ECR_TRACE(mess (20,3701,1) - MESSAGE - mess (21,3701,1) ,0) From GESECRAN
        Trbegin [KPH]
        [F:KPH]NUM = MESSAGE
        [F:KPH]STA = 2
        Rewrite [KPH]
        If STAT = 0
          Commit
        Else
          Rollback
        Endif
      Endif
    Else   # INI SAM 106404
      For I=1 To NBCUR

        CRITCUR= "[F]GRPGAS = " + chr$(34) + GRPCUR(I) + chr$(34)

        Call VALPCE2(AUTOJNCODE ,CRITCUR ,STAT,MESSAGE) From CPTAUTO

        If STAT<>0: Break
        Else
          If MESSAGE<>""
            [F:KPH]NUM = MESSAGE
            Call ECR_TRACE(mess (20,3701,1) - MESSAGE - mess (21,3701,1) ,0) From GESECRAN
            Local File KPYIMPHDR [KPHX]
            Filter [KPHX] Where GRPGAS=GRPCUR(I)
            For [KPHX]
              Gosub TR1
            Next
            Close File [KPHX]
          Endif
        Endif
      Next
    Endif   # END SAM 106404

    If STAT <> 0
        Call ECR_TRACE(MESSAGE ,1) From GESECRAN
    Else
        Actzo [M:KPYM]NUM, STA   #SAM 106404
        [M:KPYM]NUM = [F:KPH]NUM
        [M:KPYM]STA = 2
        Grizo [M:KPYM]NUM, STA   #SAM 106404
    Endif

   If func AFNC.ACTIV("MURAN")>0
     If [F:KPH]ORIPAY=2
       Raz MESSAGE  #SAM 106404
     Endif
   Endif

   Call ECR_TRACE(" ",0 )  From GESECRAN
   Call ECR_TRACE(mess (22,3701,1),0 )  From GESECRAN # Automatic Journal Creation completed
   Call LEC_TRACE From LECFIC

   # Refresh Display
   Affzo [M:KPYH] : # Header screen
   Affzo [M:KPYD] : # Detail screen
   Affzo [M:KPYM] : # Summary screen



End

#####################################
# Set which fields are enabled
# and not enabled
#
Subprog SCREEN_GRIZO
  # Default setting
  Grizo [M:KPYH]                # Header screen

  If func AFNC.ACTIV("MURAN")>0  # INI SAM 106404
    Local Integer I
    Local Char FMTINV(8)
    FMTINV="-K:1X"
    Call LECTURE("TCU",[M:KPYM]CUR,"") From CONTOBJ

    If [M:KPYH]ORIPAY<>2
      # Header fields
      Chgfmt [M:KPYH]DEPT         With "K:10X"
      Chgfmt [M:KPYH]ORIPAY       With FMTINV
      Chgfmt [M:KPYH]INTREF       With "K:8X"
      Chgfmt [M:KPYH]FLGDET       With FMTINV
      Chgfmt [M:KPYH]FLGVAL       With FMTINV
      Chgfmt [M:KPYH]ACC_CODE     With "K:20X"
      Chgfmt [M:KPYH]CCEACC_CODE  With "K:20X"
      Chgfmt [M:KPYH]EMPLOYEE     With "K:10X"
      Chgfmt [M:KPYH]CCEEMPLOYEE  With "K:15X"
      Chgfmt [M:KPYH]DEPT         With "K:10X"
      Chgfmt [M:KPYH]CCEDEPT      With "K:20X"
      Chgfmt [M:KPYH]COSTCENTRE   With "K:10X"
      Chgfmt [M:KPYH]CCECOSTCENTR With "K:20X"

      # Summary screen
      Chgfmt [M:KPYM]CPY          With FMTINV
      Chgfmt [M:KPYM]NUMMURANO    With FMTINV
      Chgfmt [M:KPYM]BPRMURANO    With FMTINV
      Chgfmt [M:KPYM]LOT          With FMTINV
      Chgfmt [M:KPYM]CUR          With FMTINV
      Chgfmt [M:KPYM]TOT          With "-N:X"
      Chgfmt [M:KPYM]RPOTIM       With "K:10X"
      Chgfmt [M:KPYM]SRCFIL       With "K:50X"
      Chgfmt [M:KPYM]STA          With "LA:1"
      Grizo [M:KPYH]DEPT

      Actzo [M:KPYD]                # Detail screen
      Chgfmt [M:KPYD]SRCTOT   With  "N:13.2"
      Chgfmt [M:KPYD]TOTCUR   With  "K:3X"
      Grizo [M:KPYD]SRC_LINE        # Detail screen
      Grizo [M:KPYD]EMPLOYEE        # Detail screen
      Grizo [M:KPYD]NARRATIVE       # Detail screen
      Grizo [M:KPYD]ACC_CODE        # Detail screen
      Grizo [M:KPYD]COSTCENTRE      # Detail screen
      Grizo [M:KPYD]DEPT            # Detail screen
      Grizo [M:KPYD]TMPACC1         # Detail screen
      Grizo [M:KPYD]SRCTOT          # Detail screen
      Grizo [M:KPYD]TOTCUR          # Detail screen

    Else
      # Header fields
      [M:KPYH]REF=[F:KPH]REF
      Actzo  [M:KPYH]FLGVAL, REF
      Diszo  [M:KPYH]REF
      Chgfmt [M:KPYH]DEPT         With FMTINV
      Chgfmt [M:KPYH]ORIPAY       With "LA:1"
      Chgfmt [M:KPYH]INTREF       With FMTINV
      Chgfmt [M:KPYH]FLGDET       With "LA:1"
      Chgfmt [M:KPYH]FLGVAL       With "LA:1"
      Chgfmt [M:KPYH]ACC_CODE     With FMTINV
      Chgfmt [M:KPYH]CCEACC_CODE  With FMTINV
      Chgfmt [M:KPYH]EMPLOYEE     With FMTINV
      Chgfmt [M:KPYH]CCEEMPLOYEE  With FMTINV
      Chgfmt [M:KPYH]DEPT         With FMTINV
      Chgfmt [M:KPYH]CCEDEPT      With FMTINV
      Chgfmt [M:KPYH]COSTCENTRE   With FMTINV
      Chgfmt [M:KPYH]CCECOSTCENTR With FMTINV

      # Summary screen
      Chgfmt [M:KPYM]CPY          With "K:5X"
      Chgfmt [M:KPYM]CUR          With "K:3X"
      Chgfmt [M:KPYM]LOT          With "K:20X"
      Chgfmt [M:KPYM]NUMMURANO    With "N:8"
      Chgfmt [M:KPYM]BPRMURANO    With "K:30X"
      Chgfmt [M:KPYM]TOT          With "N:13.2"
      Chgfmt [M:KPYM]RPOTIM       With FMTINV
      Chgfmt [M:KPYM]SRCFIL       With FMTINV
      Chgfmt [M:KPYM]STA          With FMTINV

      # Detail screen
      Actzo [M:KPYD]
      Chgfmt [M:KPYD]SRCTOT   With  "-N:13.2"
      Chgfmt [M:KPYD]TOTCUR   With  "-K:3X"
      Grizo [M:KPYD]EMPLOYEE
      Grizo [M:KPYD]NARRATIVE

      If [M:KPYH]FLGVAL=2
        Grizo  [M:KPYD]
      Endif

    Endif
    Grizo [M:KPYM]                # Summary screen
    # END SAM 106404
  Else
    # Default setting
    Grizo [M:KPYH]                # Header screen
    Grizo [M:KPYH]DEPT
    Grizo [M:KPYM]                # Summary screen
    Actzo [M:KPYD]                # Detail screen
    Grizo [M:KPYD]SRC_LINE        # Detail screen
    Grizo [M:KPYD]EMPLOYEE        # Detail screen
    Grizo [M:KPYD]NARRATIVE       # Detail screen
    Grizo [M:KPYD]ACC_CODE        # Detail screen
    Grizo [M:KPYD]COSTCENTRE      # Detail screen
    Grizo [M:KPYD]DEPT            # Detail screen
    Grizo [M:KPYD]TMPACC1         # Detail screen
  Endif

  # When Jpurnal Not Posted
  If [M:KPYM]STA = 1
    Actzo [M:KPYM]ACCDAT
  Endif

  # When Jpurnal Posted
  If [M:KPYM]STA = 2
    Grizo [M:KPYM]ACCDAT
    Grizo [M:KPYD]
  Endif

  #invisible
  Chgfmt [M:KPYH]TMPFCY With "-K:1X"

End

############################################################################################
# SCREEN ACTIONS
###########################################################################################

Subprog AM_ACC1(VALEUR)
Variable Char VALEUR()

    Local Char    ACCORG(GLONGAC)   : # Source account to lookyp
    Local Char    ACCDES(GLONGAC)   : # Account found Safe X3 structure
    Local Char    SCRACCDES(20)     : # Account found Syracuse structure ???
    Local Char    COAORG(3)         : # Source Chart of Account
    Local Char    COADES(3)         : # lookup Chart of Account
    Local Integer IND()
    Local Integer AXI()
    Local Char    DIMENSION(50)     : # GH 22/08/14 - Need to review size required
    Local Char    FIELD_NAME(50)    : # GH 22/08/14 - Need to review size required
    Local Integer LOOP_CNT          : # GH 22/08/14 - Used to refresh dimension screen fields
    Local Char    CURR_VALUE(50)    : # GH 02/09/14 - Need to review size required

    Local Integer MAN_ANA           : # Analytical management SAM 106404

    ACCORG = VALEUR
    COAORG = GPLAN(1)

    If func AFNC.ACTIV("MURAN")>0  # INI SAM 106404
      If [F:KPH]ORIPAY=1
        # Get code to use for GESCDE
        Read [KPT]KPYT0  = 1 ; [F:KPH]TMPFCY
        CODDIM = [F:KPT]CDE
      Else
        If VALEUR="" : GMESSAGE=mess(532,177,1): mkstat=2: End:  Endif # The field is mandatory
        CODDIM=[F:KPH]CDE
      Endif
    Endif
    # END SAM 106404

    For COUNTER = 2 To GNBPLAN
        COADES = GPLAN(COUNTER)
        Call INIACC(COAORG,ACCORG,COADES,ACCDES,SCRACCDES) From CPTINI

        If ACCDES = ""
            Assign "[M:KPYD]ACC"+num$(COUNTER)+"(nolign-1)" With SCRACCDES
        Else
            Assign "[M:KPYD]ACC"+num$(COUNTER)+"(nolign-1)" With ACCDES
        Endif

        ACCDES    = ""     : # reset
        SCRACCDES = ""     : # reset
    Next COUNTER

    Affzo [M:KPYD]ACC2
    Affzo [M:KPYD]ACC3
    Affzo [M:KPYD]ACC4
    Affzo [M:KPYD]ACC5
    Affzo [M:KPYD]ACC6
    Affzo [M:KPYD]ACC7
    Affzo [M:KPYD]ACC8
    Affzo [M:KPYD]ACC9
    Affzo [M:KPYD]ACC10

    # load dimension type codes into global variable GDIE
    # need for IDENT sub  call by Call INICCE(..) from CPTINI
    For COUNTER = 1 To 20
        GDIE(COUNTER) = [M:KPYH]DIE(COUNTER-1)
    Next COUNTER

    For AXE=1 To GNBAXE
        For NLED = 1 TGNBPLAN
            DIMENSION = ""
            GCODLED(NLED) = [M:KPYH]LED(NLED-1)
            Call INDLED(GCODLED(NLED),GAXE(AXE),IND,AXI) From CPTDIV
            If IND>0 & GLEDFLGANA(IND)=2 & AXI
                If (NLED <> 1)
                  ACCOUNT = evalue("[M:KPYD]ACC"+num$(NLED)+"("+num$(nolign-1)+")")
                Else
                  ACCOUNT = VALEUR
                Endif

              Call INICCE(DIMENSION,GAXE(AXE),GCODLED(NLED), [L]ACCOUNT,CODDIM) From CPTINI
              If DIMENSION <> ""
                  IND2 = find(GAXE(AXE),[F:KPD]DIE(0..dim([F:KPD]DIE)-1))
                  CURR_VALUE = evalue("[M:KPYD]CCE"+num$(IND2)+"("+num$(nolign-1)+")")
                  FIELD_NAME = "[M:KPYD]CCE"+num$(IND2)+"("+num$(nolign-1)+")"
                  If CURR_VALUE = ""
                      Assign FIELD_NAME With DIMENSION
                  Endif
              Endif
            Else
              Assign "[M:KPYD]CCE"+num$(AXE)+"("+num$(nolign-1)+")" With ""   #SAM 106404
            Endif
        Next
    Next

    Affzo [M:KPYD]CCE1(nolign-1)
    Affzo [M:KPYD]CCE2(nolign-1)
    Affzo [M:KPYD]CCE3(nolign-1)
    Affzo [M:KPYD]CCE4(nolign-1)
    Affzo [M:KPYD]CCE5(nolign-1)
    Affzo [M:KPYD]CCE6(nolign-1)
    Affzo [M:KPYD]CCE7(nolign-1)
    Affzo [M:KPYD]CCE8(nolign-1)
    Affzo [M:KPYD]CCE9(nolign-1)
    Affzo [M:KPYD]CCE10(nolign-1)
    Affzo [M:KPYD]CCE11(nolign-1)
    Affzo [M:KPYD]CCE12(nolign-1)
    Affzo [M:KPYD]CCE13(nolign-1)
    Affzo [M:KPYD]CCE14(nolign-1)
    Affzo [M:KPYD]CCE15(nolign-1)
    Affzo [M:KPYD]CCE16(nolign-1)
    Affzo [M:KPYD]CCE17(nolign-1)
    Affzo [M:KPYD]CCE18(nolign-1)
    Affzo [M:KPYD]CCE19(nolign-1)
    Affzo [M:KPYD]CCE20(nolign-1)

End



Subprog C_ACCDAT(VALEUR)
Variable Date    VALEUR

    # TODO not sure if this is required
    Local Decimal EXERCICE , PERIODE, OEXERCICE, OPERIODE
    If !clalev([F:ANM]) : Local File ACODNUM [ANM] : Endif
    If clalev([F:AOB])  = 0 : Local File AOBJET [AOB] : Endif
    Call LECTURE("AOB",GABREV,"") From CONTOBJ
    Local Integer MODULE
    MODULE = [F:AOB]MODULE
    Call CTLDATMOD(MODULE,VALEUR,GSOCIETE) From CPTSUB
    If mkstat : End : Endif

End


# INIT SAM 106404
######################################################################################
## Section automatically added (screen KPYDTL) 02/29/2016 12:31:57 (JUCON)
######################################################################################
Subprog D_DSP(VALEUR)
Variable Char    VALEUR()
Local Integer NOL: NOL = nolign-1

  Gosub RECH_ACC

  If COMPTE = "" and VALEUR=""
    [M]UOM(NOL) = ""
    mkstat = 1 : End
  Else
    If VALEUR="": VALEUR = [F:GAC]DSP: Endif
    [M]UOM(NOL) = [F:GAC]UOM
  Endif

End

Subprog AS_DSP(VALEUR)
Variable Char    VALEUR()
  Local Integer NOL: NOL = nolign-1

  Gosub RECH_ACC

  If COMPTE = "" and VALEUR=""
    mkstat=1 : End
  Endif
  If [M]STA=2
    mkstat = 2 : End
  Endif

  GBOUT1 = mess(23,106,1) : # Répartition ana
  GBOUT2 = mess(21,106,1) : # Pourcentage
  GBOUT3 = mess(22,106,1) : # Montant

  Gosub SETCHPLST


  If COMPTE = "" and VALEUR=""
    mkstat = 1 : End
    [M]UOM(NOL) = ""
  Else
    [M]UOM(NOL) = [F:GAC]UOM
  Endif
  If [M]STA=2 : mkstat = 2 : End : Endif

  If !mkstat & !GIMPORT & VALEUR<>""
    Call LECTURE("DSP",VALEUR,"") From CONTOBJ
  Endif

End

Subprog C_DSP(VALEUR)
Variable Char    VALEUR()
  Local Integer I, OK, LIGANA, CAS
  Local Integer NOL: NOL = nolign-1

  Call LECTURE("TUN",[M:KPYD]UOM(NOL),"") From CONTOBJ
  Read [KPD]KPYD0=[M:KPYH]RECID;[M:KPYD]LINENO(NOL)

  Case VALEUR
    When "":   End
    When "$"
      If !GIMPORT
        OK  = 1
        OK *= [M]AMTCUR(NOL)=sum([M:VT2]TBAMT([M:KPYD]PTV(NOL)..[M:KPYD]PTF(NOL)))
        OK *= [M]QTY(NOL)=sum([M:VT2]TBQTY([M:KPYD]PTV(NOL)..[M:KPYD]PTF(NOL)))
        If !OK
          GMESSAGE = mess(28,106,1)   #Unbalanced distribution
          mkstat = 2 : End
        Endif
      Endif
      Raz [F:KPD]DSP
      Gosub RAZCCE

      LIGANA = 0
      For I=[M]PTV(nolign-1) To [M]PTF(nolign-1)
        CAS = 1 : Gosub WRITE_ANA
        If GOK<1 : End : Endif
      Next I

    When Default
      Read [TCU]TCU0=[M:KPYM]CUR
      Call CONTDSP(VALEUR,[M:KPYM]FCY,[M:KPYM]ACCDAT) From SUBBIC3
      If mkstat : End : Endif
      [M:VTL]TOTREP = [M]AMTCUR(NOL): [M:VTL]QTOTREP=[F:KPD]QTY
      [F:KPD]DSP=VALEUR
      Raz [M]LSTAXE
      Gosub SETCHPLST
      Call CHARGE_VTE_STR(VALEUR,[M]UOM(NOL),[M]LSTLED,[M]LSTACC,[M]LSTAXE) From VENTILE
      Call CONTVENT([M:KPYM]FCY,[M:KPYM]ACCDAT) From SAIVENTILE
      If mkstat : End : Endif

      Gosub RAZCCE
      CAS = 3 : Gosub WRITE_ANA
  Endcase

  If !mkstat & !GIMPORT & VALEUR<>""
    Call LECTURE("DSP",VALEUR,"") From CONTOBJ
  Endif
End

