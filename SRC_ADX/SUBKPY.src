######################################################################################
$RAZCCE
  For I=1 To GNBAXE
    Assign "[M]CCE"+num$(I)+"("+num$(NOL)+")" With ""
  Next I
  Affzo [M:KPYD]NBLIG(NOL)

  #Deleting analytical detail
  GOK=1
  Local File KPYIMPDTLA [KPAX]
  Trbegin [KPAX]
    For [KPAX] Where RECID=[F:KPD]RECID and LINENO=[F:KPD]LINENO
      Delete [F:KPAX] Curr
    Next
  Commit
  Close Local File [KPAX]

Return

######################################################################################
$RECH_ACC
  Local Char CCEDET(GLONCCE)
  Local Char    PLAN(GLONCOA),COMPTE(GLONGAC)
  Local Integer TLED, STAT
  Local Integer INDLED
  Local Integer TYPACC: TYPACC = 2
  Local Integer NBLED: NBLED=find("",[M:KPYH]LED)-1
  Local Char LED(GLONLED)
  Local Char DEV(GLONCUR)

  If clalev([F:LED])=0 : Local File GLED [LED] : Endif

  If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS]  : Endif
  Read [BPS]BPS0=[M:KPYD]EMPLOYEE(NOL)
  If fstat=[V]CST_AOK and [F:BPS]BPRDSP<>""
    VALEUR=[F:BPS]BPRDSP
  Endif

  Raz COMPTE, PLAN, INDLED
  Case TYPACC
    When 1
      INDLED = find(GTYPGEN,GTYPLED(1..NBLED))
    When 2
      INDLED = find(GTYPANA,GTYPLED(1..NBLED))
  Endcase

  If INDLED
    COMPTE = evalue("[M]ACC"+num$(INDLED)+"("+num$(NOL)+")")
    PLAN  = evalue("GPLAN("+num$(INDLED)+")")
  Endif
  If COMPTE=""
    For INDLED=1 To NBLED
      Case TYPACC
        When 1
          If INDLED<>GTYPGEN
            [L]TLED = GTYPLED(INDLED)
            STAT = func FINACM_SYRA.GET_LEDCUR(GACTX, [M:KPYM]CPY, [L]TLED, LED, DEV, GMESSAGE)
            If STAT<>[V]CST_AOK : Return : Endif
          Endif
          Call LECTURE("LED",[L]LED,"") From CONTOBJ
          If [F:LED]GEN=2
            COMPTE = evalue("[M]ACC"+num$(INDLED)+"("+num$(NOL)+")")
            PLAN  = evalue("GPLAN("+num$(INDLED)+")")
          Endif
        When 2
          For INDLED=1 To NBLED
            If INDLED<>GTYPANA
              STAT = func FINACM_SYRA.GET_LEDCUR(GACTX, [M:KPYM]CPY, [L]TLED, LED, DEV, GMESSAGE)
              If STAT<>[V]CST_AOK : Return : Endif
              If [F:LED]ANA=2
                COMPTE = evalue("[M]ACC"+num$(INDLED)+"("+num$(NOL)+")")
                PLAN  = evalue("GPLAN("+num$(INDLED)+")")
              Endif
            Endif
          Next
      Endcase
    Next
  Endif
  If COMPTE<>""
    Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
  Endif

Return

######################################################################################
$SETCHPLST
  Raz [M]LSTLED, [M]LSTACC, [M]LSTAXE
  Local Integer I, NLED, TLED
  Local Integer NBLED: NBLED=find("",[M:KPYH]LED)-1

  For NLED=1 To NBLED
    Gosub SETCHPLED
  Next
  Gosub SETCHPAXE
Return

######################################################################################
$SETCHPLED
  If NOL>=0 & evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")<>""
    If NLED>1
      [M]LSTLED += ";" : [M]LSTACC += ";"
    Endif
    [M]LSTLED += [M:KPYH]LED(NLED-1)
    [M]LSTACC += evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
  Endif
Return

######################################################################################
$SETCHPAXE
  For I=1 To GNBAXE
    [M]LSTAXE += GAXE(I) : [M]LSTAXE+=";"
    Assign "[M:VT2]TBDIE("+num$(I-1)+")" With GAXE(I)
  Next
  If GNBAXE>0
    [M]LSTAXE = left$([M]LSTAXE,len([M]LSTAXE)-1)
  Endif
Return

######################################################################################
$SAIACC
Local Integer NOL: NOL = nolign-1
Local Integer TLED, SVG_MKSTAT

  [L]TLED = GTYPLED(NLED)
  If GTYPLED(NLED) = GTYPGEN
    Local Char COMPTE(GLONGAC)
    Local Char CODCPT(GLONCAC)

    If NOL=0 & VALEUR=""
      Read [CAC]CAC0 = 26;[F:KPH]COD;GPLAN(NLED)
      If fstat=[V]CST_AOK
        COMPTE = vireblc(ctrans([F:CAC]ACC(16),"xX","00"),2)
        Read [GAC]GAC0 = GPLAN(NLED);COMPTE
        If fstat=[V]CST_AOK: VALEUR = COMPTE: Endif
      Endif
    Endif
  Else
    If [M]ACC1(NOL)="" : mkstat=2 : End : Endif
  Endif

  If NLED>1
    Gosub INI_OTHACC
    If  VALEUR<>""
      SVG_MKSTAT = mkstat
      Raz mkstat
      Call CONTACC(NLED,VALEUR)
      If mkstat : Raz mkstat : End : Endif
      mkstat = SVG_MKSTAT
    Endif
  Endif

Return

######################################################################################
$INI_OTHACC
  If NLED>1
    Local Char    CRIBLE(20)
    Local Char    ACCORG(GLONGAC), ACCDES(GLONGAC)
    Local Integer INDLED, INDREF
    Local Char SVG_ACC(GLONGAC)
    SVG_ACC = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")

    For INDLED=1 To NLED-1
      [L]ACCORG = evalue("[M]ACC"+num$(INDLED)+"("+num$(NOL)+")")
      If [L]ACCORG<>""
        Call LECTURE("GAC",ACCORG,GPLAN(INDLED)) From CONTOBJ
        If find(GPLAN(NLED),[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
          Local Integer STAT
          STAT = func FINACC_SYRA.GET_DENACC(GACTX, GPLAN(INDLED), [L]ACCORG, GPLAN(NLED), ACCDES, [L]CRIBLE, GMESSAGE)
          If STAT<>[V]CST_AOK : Return : Endif
          If [L]ACCDES<>"":   INDREF = INDLED : Break:   Endif
        Elsif GPLAN(NLED)=GPLAN(INDLED)
          [L]ACCDES = [L]ACCORG
          INDREF = INDLED : Break
        Else
          mkstat = 1 : Break
        Endif
      Endif
    Next
    If mkstat : Return : Endif
    If ACCDES = "":      Return
    Elsif GPLAN(INDREF)<>GPLAN(NLED)
      If SVG_ACC="" | (SVG_ACC<>"" & SVG_ACC<>[L]ACCDES & [L]ACCDES = [L]CRIBLE)
        VALEUR = ACCDES
        If [L]ACCDES = [L]CRIBLE:    mkstat=2 : Return:    Endif
      Else
        VALEUR = SVG_ACC
      Endif
    Elsif GPLAN(NLED)=GPLAN(INDLED)
      VALEUR = ACCDES : mkstat = 2 : Return
    Endif
  Endif

Return

######################################################################################
$TR1
  Trbegin [KPHX]
 [F:KPHX]NUM = MESSAGE
 [F:KPHX]STA = 2
 Rewrite [KPHX]
 If STAT = 0
   Commit
 Else
   Rollback
 Endif

Return

######################################################################################
$CHECK_CUR
  Local File KPYIMPHDR [KPHX]
  Filter [KPHX] Where LOT=[F:KPH]LOT
  For [KPHX]
    I=find([F:KPHX]GRPGAS,GRPCUR)
    If I=0 : NBCUR+=1: GRPCUR(NBCUR)= [F:KPHX]GRPGAS: Endif
  Next
  Close File [KPHX]
Return

######################################################################################
Subprog CONTACC(NLED,VALEUR)
Value Integer NLED
Variable Char VALEUR()
  Local Char        CPT(GLONGAC), CRIBLE(30), LED(GLONLED), DEV(GLONCUR)
  Local Integer     I, OK
  Local Integer     TLED
  Local Integer NOL: NOL = nolign-1

  If VALEUR="" : GMESSAGE=mess(532,177,1): mkstat=2: End:  Endif # The field is mandatory
  If NLED=1 and VALEUR<>"" and [F:GAC]ACCSHO<>"" and [F:KPH]FLGDET=1
    GMESSAGE=mess(123,106,1) : mkstat=2: End     # Control account not authorized
  Endif


  [L]TLED = GTYPLED(NLED)

  STAT = func FINACM_SYRA.GET_LEDCUR(GACTX, [M]CPY, [L]TLED, LED, DEV, GMESSAGE)
  If STAT<>[V]CST_AOK : Return : Endif
  Call LECTURE("LED",[L]LED,"") From CONTOBJ

  If NLED>1
    Assign "[M]ACC"+num$(NLED)+"("+num$(NOL)+")" With VALEUR
    Local Char    TPLAN(GLONCOA)(1..NLED),TCOMPTE(GLONGAC)(1..NLED), MESSA(250)
    Local Integer I, STAT : STAT = 0
    For I=1 To NLED
      TPLAN(I)   = evalue("GPLAN("+num$(I)+")")
      TCOMPTE(I) = evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")")
    Next
    STAT = func FINACC_SYRA.CTL_IPTACC(GACTX, NLED, TPLAN, TCOMPTE, 0, GMESSAGE)
    If STAT<>[V]CST_AOK : mkstat = 2 : End : Endif
  Endif

  If VALEUR = "" : End : Endif
  CPT = VALEUR

  Read [GAC]GAC0 >= GPLAN(NLED);CPT
  If fstat>2 | left$([F:GAC]ACC,len(CPT))<>CPT
    GMESSAGE = CPT-mess(44,102,1)   # Nonexistent account
    mkstat = 2 : End
  Endif

  If func FINACC_SYRA.CTL_ACC(GACTX, GTYPLED(NLED), GPLAN(NLED), [F:GAC]ACC, [M:KPYM]FCY, [M:KPYM]CUR, [M:KPYM]ACCDAT, 0, 0, GMESSAGE)<>[V]CST_AOK
    mkstat = 2 : End
  Endif

End

######################################################################################
Subprog AS_CCE(AXE,VALEUR)
Value    Integer AXE
Variable Char    VALEUR()

  Local Integer NOL: NOL=nolign-1

  If [M:KPYD]DSP(NOL)<>"": mkstat=1 : End : Endif

  If GIMPORT | [M:KPYM]STA=2 : mkstat = 2 : End : Endif
  Local Char    COMPTE(GLONGAC), DEV(GLONCUR)
  Local Integer NLED, TLED
  Local Integer AXI, IND
  mkstat = 1
  GNBTYPLED=find("",[M:KPYH]LED)-1
  For NLED=1 To GNBTYPLED
    [L]TLED = GTYPLED(NLED)
    STAT = func FINACM_SYRA.GET_LEDCUR(GACTX, [M:KPYM]CPY, [L]TLED, LED, DEV, GMESSAGE)
    If STAT<>[V]CST_AOK : Return : Endif

    Call LECTURE("LED",[M:KPYH]LED(NLED),"") From CONTOBJ
    COMPTE = evalue("[M]ACC"+num$(NLED)+"("+num$(NLED)+")")
    If COMPTE<>""
      Call LECTURE("GAC",COMPTE,GPLAN(NLED)) From CONTOBJ
      If find(GAXE(AXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) : Raz mkstat : Break : Endif
    Endif
  Next
End

######################################################################################
Subprog C_CCE(AXE,VALEUR)
Value    Integer AXE
Variable Char    VALEUR()

  Local Integer NOL: NOL=nolign-1
  Local Integer CAS: CAS=3
  Local Char    COMPTE(GLONGAC), DEV(GLONCUR)
  Local Integer NLED, TLED

  #If VALEUR="": mkstat=1 : End : Endif

  GNBTYPLED=find("",[M:KPYH]LED)-1
  For NLED=1 To GNBTYPLED
    COMPTE = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
    If COMPTE<>""
      [L]TLED = GTYPLED(NLED)

      STAT = func FINACM_SYRA.GET_LEDCUR(GACTX, [M:KPYM]CPY, [L]TLED, [M:KPYH]LED(NLED), DEV, GMESSAGE)
      If STAT<>[V]CST_AOK : Return : Endif

      Call LECTURE("LED",[M:KPYH]LED(NLED),"") From CONTOBJ
      Call CONTCCE(VALEUR,[M:KPYH]LED(NLED),GAXE(AXE),[M:KPYM]FCY,[M]ACCDAT,COMPTE,[M:KPYH]DIE,"[M]CCE#",NOL) From CPTCNT
    Endif
  Next

  #Updating analytical detail
  Local File KPYIMPDTLA [KPAX]
  Read [KPAX]KPYA0=[F:KPD]RECID;[M:KPYD]LINENO(NOL);1
  If fstat=[V]CST_AOK
    If [F:KPAX]CCE(AXE-1) <> VALEUR
      Trbegin [KPAX]
        [F:KPAX]CCE(AXE-1) = VALEUR
        Rewrite
      Commit
    Endif
  Endif
  Close Local File [KPAX]

End

######################################################################################
$WRITE_ANA
  [F:KPA] = [F:KPD]
  Case CAS
    When 1 : # Répartition analytique manuelle
      Raz [F:KPA]DIE, [F:KPA]CCE
      LIGANA += 1
      [F:KPA]DSPLIN=2
      [F:KPA]AMTCUR = [M:VT2]TBAMT(I)
      [F:KPA]QTY = [M:VT2]TBQTY(I)
      For AXE=1 To GNBAXE
        If GAXE(AXE)<>""
          [F:KPA]DIE(AXE-1) = GAXE(AXE)
          [F:KPA]CCE(AXE-1) = evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(I)+")")
        Endif
      Next AXE
      If [F:KPD]DSP="$": Raz [F:KPD]DSP: Endif
    When 2 : # Répartition analytique standard
      Raz [F:KPA]DIE, [F:KPA]CCE
      LIGANA += 1
      [F:KPA]DSPLIN=2
      [F:KPA]AMTCUR = [M:VTL]AMT(I)
      [F:KPA]QTY = [M:VTL]QTY(I)
      For AXE=1 To GNBAXE
        If GAXE(AXE)<>""
          [F:KPA]DIE(AXE-1) = GAXE(AXE)
          [F:KPA]CCE(AXE-1) = evalue("[M:VTL]CCE"+num$(AXE)+"("+num$(I)+")")
        Endif
      Next
      If [F:KPD]DSP="$": Raz [F:KPD]DSP: Endif
    When 3: LIGANA=1: [F:KPA]DSPLIN=1
  Endcase

  If LIGANA
    Trbegin [KPA]
      [F:KPA]ANALIG = LIGANA
      Write [KPA]
      If fstat
        GOK = 0 : Rollback : Return
      Endif
    Commit
  Endif
Return

######################################################################################
$LOAD_DSP_LIN
 If [F:KPD]DSP=""
  DSPOK=0
  For [KPA]KPYA0 Where RECID=[F:KPD]RECID & LINENO=[F:KPD]LINENO & DSPLIN=2
   LIGANA += 1
   If !DSPOK : DSPOK = LIGANA : Endif
   [M:VT2]TBAMT(LIGANA) = [F:KPA]AMTCUR
   [M:VT2]TBQTY(LIGANA) = [F:KPA]QTY
   For AXE=1 To GNBAXE
    INDAXE = find(GAXE(AXE),[F:KPA]DIE(0..dim([F:KPA]DIE)-1))
    If INDAXE
     Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(LIGANA)+")" With [F:KPA]CCE(INDAXE-1)
    Endif
   Next AXE
  Next
  If DSPOK
   If DSPOK=LIGANA
    For I=1 To GNBAXE
     Assign "[M]CCE"+num$(I)+"("+num$(nolign-1)+")" With evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(LIGANA)+")")
     Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(LIGANA)+")" With ""
    Next I
    LIGANA -= 1
   Else
    [M]PTV(nolign-1) = DSPOK
    [M]PTF(nolign-1) = LIGANA
    [M]DSP(nolign-1) = "$"
    For I=1 To GNBAXE : # Pour initialiser les champs sections
     Assign "[M]CCE"+num$(I)+"("+num$(nolign-1)+")" With ""
    Next I
   Endif
  Endif
 Endif

Return

######################################################################################
#END SAM 106404

