$ON_TOTTYP
Onevent BEFORE_INPUT Call AS_TOTTYP(zc) From W1GENEMPEX
Onevent CONTROL Call C_TOTTYP(zc) From W1GENEMPEX
Onevent INIT_AREA Call D_TOTTYP(zc) From W1GENEMPEX
Return

Subprog D_TOTTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]TOTTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TOTTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10344) From COMBOS
## Action STD
Call AS_TOTTYP(VALEUR) From SUBSMH
If mkstat=2
 [M]TOTTYP(INDIC) = VALEUR
 Affzo TOTTYP(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10344,1))))
Endif
If !mkstat
 Discombo 0 From TOTTYP(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From TOTTYP(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_TOTTYP(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_TOTTYP(VALEUR) From SUBSMH
If mkstat : GERR = 1 : GZONE = "TOTTYP" : GZNUM = 680 : Endif
Gosub _AFF
End

