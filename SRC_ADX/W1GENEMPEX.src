$ON_TYPTPS
Onevent BEFORE_INPUT Call AS_TYPTPS(zc) From W1GENEMPEX
Onevent INIT_AREA Call D_TYPTPS(zc) From W1GENEMPEX
Onevent CONTROL Call C_TYPTPS(zc) From W1GENEMPEX
Return

Subprog D_TYPTPS(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPTPS,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYPTPS(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10408) From COMBOS
If !GWEBSERV
 ## Action STD
 Call AS_TYPTPS(VALEUR) From SUBSMH
 If mkstat=2
  [M]TYPTPS(INDIC) = VALEUR
  Affzo TYPTPS(INDIC) : mkstat = 2
 Endif
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10408,1))))
Endif
If !mkstat
 Discombo 0 From TYPTPS(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From TYPTPS(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_TYPTPS(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

