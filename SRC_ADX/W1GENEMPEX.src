Subprog AS_TOTTYPELM(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10355) From COMBOS
## Action STD
Call AS_TOTTYPELM(VALEUR) From SUBSMH
If mkstat=2
 [M]TOTTYPELM(INDIC) = VALEUR
 Affzo TOTTYPELM(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10355,1))))
Endif
If !mkstat
 Discombo 0 From TOTTYPELM(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From TOTTYPELM(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_TOTTYPELM(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_TOTTYPELM(VALEUR) From SUBSMH
If mkstat : GERR = 1 : GZONE = "TOTTYPELM" : GZNUM = 3603 : Endif
Gosub _AFF
End

$ON_TPS1
Onevent CONTROL Call C_TPS1(zc) From W1GENEMPEX
Onevent BEFORE_INPUT Call AS_TPS1(zc) From W1GENEMPEX
Return

Subprog AS_TPS1(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_TPS1(zc) From W1GENEMPEX
Gosub _AFF
End

Subprog C_TPS1(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TPS1" : GZNUM = 34399 : Endif
If !mkstat
 ## Action STD
 Call C_TPS1(VALEUR) From SUBSMH
 If mkstat : GERR = 1 : GZONE = "TPS1" : GZNUM = 34399 : Endif
Endif
Gosub _AFF
End

Subprog S_TPS1(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "TIM"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

