#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENEMPEX 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:24"
A_USER  = "DOC"
A_STAMP = "20181109230424"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask GENEMPEX [GEX]
Gosub HORODAT
Local Inpbox "GENEMPEX" From GFONCTION At A_STAMP With A_WINDPREV Mask [GEX] As [SIM_]
Grizo [GEX]10
Grizo [GEX]60
Grizo [GEX]50
Grizo [GEX]40
Grizo [GEX]20
Grizo [GEX]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [GEX]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=14 : X2(0)=34 : Y1(0)=6 : Y2(0)=11
X1(1)=14 : X2(1)=99 : Y1(1)=20 : Y2(1)=22
X1(2)=58 : X2(2)=99 : Y1(2)=12 : Y2(2)=19
X1(3)=14 : X2(3)=57 : Y1(3)=12 : Y2(3)=19
X1(4)=35 : X2(4)=57 : Y1(4)=6 : Y2(4)=11
X1(5)=58 : X2(5)=99 : Y1(5)=6 : Y2(5)=11
Return

$ON_INIT
Onevent BEFORE_AREA Gosub AV_INIT From W1GENEMPEX
Return

$AV_INIT
## Action STD
Call AV_INIT(zc) From SUBSMH
Gosub _AFF
Return

$ON_TYPFRM
Onevent CONTROL Call C_TYPFRM(zc) From W1GENEMPEX
Onevent INIT_AREA Call D_TYPFRM(zc) From W1GENEMPEX
Onevent BEFORE_INPUT Call AS_TYPFRM(zc) From W1GENEMPEX
Return

Subprog D_TYPFRM(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPFRM,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYPFRM(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_TYPFRM(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_TYPFRM(VALEUR) From SUBSMH
If mkstat : GERR = 1 : GZONE = "TYPFRM" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_EXPR
Onevent BEFORE_INPUT Call AS_EXPR(zc) From W1GENEMPEX
Onevent CONTROL Call C_EXPR(zc) From W1GENEMPEX
Return

Subprog IB_EXPR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call IB_EXPR From SUBSMH
Endif
Gosub _AFF
End

Subprog AS_EXPR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1484,GBOUT1) From OBJDIV
Call TEXTE(20397,GBOUT2) From OBJDIV
Call TEXTE(11260,GBOUT3) From OBJDIV
Call TEXTE(10567,GBOUT4) From OBJDIV
Call TEXTE(44957,GBOUT5) From OBJDIV
Call IB_EXPR(VALEUR)
If !GWEBSERV
 ## Action AFRIB
 Call IB_FORMULE From AFORMULE
 If mkstat=2
  [M]EXPR(INDIC) = VALEUR
  Affzo EXPR(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_EXPR(zc) From W1GENEMPEX
Onkey 130 Titled GBOUT2 Call B2_EXPR(zc) From W1GENEMPEX
Onkey 131 Titled GBOUT3 Call B3_EXPR(zc) From W1GENEMPEX
Onkey 132 Titled GBOUT4 Call B4_EXPR(zc) From W1GENEMPEX
Onkey 133 Titled GBOUT5 Call B5_EXPR(zc) From W1GENEMPEX
Gosub _AFF
End

Subprog C_EXPR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EXPR" : GZNUM = 843 : Endif
If !GWEBSERV
 If !mkstat
  ## Action AFRCONT
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "AFRCONT"
  PARMSK(1) = ""
  Call S_AFF_CHAR(VALEUR,PARMSK,"AFRCONT","AFORMULE","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "EXPR" : GZNUM = 843 : Endif
 Endif
Endif
If !mkstat
 ## Action STD
 Call C_EXPR(VALEUR) From SUBSMH
 If mkstat : GERR = 1 : GZONE = "EXPR" : GZNUM = 843 : Endif
Endif
Gosub _AFF
End

Subprog B1_EXPR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,[M]TBL(0),[M]TBL(1),[M]TBL(2),[M]TBL(3),[M]TBL(4)) From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_EXPR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action EXPRUB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "EXPRUB"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"EXPRUB","SELPLAN","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_EXPR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action EXPVRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "EXPVRA"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"EXPVRA","SELPLAN","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B4_EXPR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action EXPCUM
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "EXPCUM"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"EXPCUM","SELPLAN","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B5_EXPR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action EXPSAL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "EXPSAL"
 PARMSK(1) = "A"
 Call S_TAB_CHAR(VALEUR,PARMSK,"EXPSAL","SELPLAN","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_TYP
Onevent BEFORE_INPUT Call AS_TYP(zc) From W1GENEMPEX
Onevent CONTROL Call C_TYP(zc) From W1GENEMPEX
Onevent AFTER_CHANGE Gosub AMM_TYP From W1GENEMPEX
Return

Subprog AS_TYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_TYP(VALEUR) From SUBSMH
If mkstat=2
 [M]TYP(INDIC) = VALEUR
 Affzo TYP(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_TYP(zc) From W1GENEMPEX
Onkey 144 Titled GBOUTP Call P_TYP(zc) From W1GENEMPEX
Onkey 146 Titled GBOUTA Call SA_TYP(zc) From W1GENEMPEX
Gosub _AFF
End

Subprog C_TYP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TYP" : GZNUM = 15 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ATY","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TYP" : GZNUM = 15 : Endif
Endif
Gosub _AFF
End

$AMM_TYP
Call AM_TYP(zc)
If !mkstat & GOBJET
 zoncou = "TYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TYP(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZTYP)")>indice
 [M]TYP(indice) = VALEUR
 Affzo ZTYP(indice)
Endif
Gosub _AFF
End

Subprog S_TYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ATY"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_TYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ATY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TYP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ATY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZTYP
Onevent BEFORE_AREA Gosub AV_ZTYP From W1GENEMPEX
Return

$AV_ZTYP
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
Call LECTURE("ATY",[M]TYP(indice),"") From CONTOBJ
Call TEXTE([F:ATY]INTITTYP,zc) From OBJDIV
Gosub _AFF
Return

