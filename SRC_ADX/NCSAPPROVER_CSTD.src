#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: NCSAPPROVER_CSTD, Non-conformance - Approver Collection
###############################################################################
# Issue 110210/8 - 2015-12-14 by JUSYN : New labels for supervisor update
# Issue X3-105283 - 2018-08-29 by BAKHA : Authorisation check removed for NC approvers

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ADDLINE_AFTER"
          Gosub INCREMENT_LINE_NUMBER
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
  Endcase
Return

$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
    When "NCSAPPUSR"
      Case [L]ARULE
        When "CONTROL"
          Gosub VALIDATE_APPROVER
      Endcase
  Endcase

Return
###############################################################################

# --------------------------------------------------
# Increment collection row's line number (APPRLN)
# for subsequent database update.
$INCREMENT_LINE_NUMBER

      this.APPRLN = 1 + max (this.APARENT.NCSAPPROVER(1..maxtab(this.APARENT.NCSAPPROVER)).APPRLN)

Return

# --------------------------------------------------
# Validate Approver (NCSAPPUSR)
$VALIDATE_APPROVER

  Local Char NCSAPPROVE(30)
  Local Char MESSAGE(100)

  ASTATUS = fmet this.ADELETEERROR("NCSAPPUSR")

  Call PARAMUTIL("NCSAPPROVE", NCSAPPROVE, this.NCSAPPUSR, "") From SUBAUS
  If (NCSAPPROVE <> "2")
    MESSAGE = func ASYRFNC.MES1(mess(75,2038,1),this.NCSAPPUSR)
    ASTATUS = fmet this.ASETERROR("NCSAPPUSR", MESSAGE, CST_AERROR)
  Endif

Return

