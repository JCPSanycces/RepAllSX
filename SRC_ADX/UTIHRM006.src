#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA - 2018-03-03- US X3-75027- START
##########################################################################
# UTIHRM006 - Delete Tables(ATB), classes(ACL*) & representations(ASW*) linked to PAPI if PAPI is off      #
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIHRM006 - Delete Tables(ATB), classes(ACL*) & representations(ASW*) linked to PAPI if PAPI is off") From LECFIC
    Call PATCH(DOSSIER)
    #Call MAJ_UTIHRM006(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIHRM006(DOSSIER)
Value Char DOSSIER
Local Char CODREPDEL (GLONASW)
Local Char CODCLADEL (GLONACLA)
Local Char CODATBDEL (GLONATB)
Local Integer WRITEERROR

  # ------------------------------------
  Local File =DOSSIER+".ACTIV" [ACVHR]
  # ------------------------------------
  WRITEERROR = 0
  Read [ACVHR]CODACT = "PAPI"
  If fstat
    Call ECR_TRACE("UTIHRM006: Process aborted as activity code PAPI does not exist on : "+DOSSIER,0) From GESECRAN
    WRITEERROR = 1
  Else
    If [F:ACVHR]FLACT = 2 Then
      Call ECR_TRACE("UTIHRM006: Process aborted as activity code PAPI is active (No delete required) on : "+DOSSIER,0) From GESECRAN
      WRITEERROR = 1
    Endif
  Endif
  If WRITEERROR = 0 Then
    #REPRESENTATIONS
    Local File =DOSSIER+".ASHW"           [ASW]
    Local File =DOSSIER+".ASHWBLC"        [ASWB]
    Local File =DOSSIER+".ASHWCOL"        [ASWC]
    Local File =DOSSIER+".ASHWEXPPRO"     [ASWR]
    Local File =DOSSIER+".ASHWFLD"        [ASWF]
    Local File =DOSSIER+".ASHWLNK"        [ASWK]
    Local File =DOSSIER+".ASHWMENU"       [ASWMN]
    Local File =DOSSIER+".ASHWMET"        [ASWM]
    Local File =DOSSIER+".ASHWOPT"        [ASWO]
    Local File =DOSSIER+".ASHWPAR"        [ASWP]
    Local File =DOSSIER+".ASHWPARMET"     [ASWMP]
    Local File =DOSSIER+".ASHWSEC"        [ASWS]
    #CLASSES
    Local File =DOSSIER+".ACLASSE"      [ACLA]
    Local File =DOSSIER+".ACLACOL"      [ACLAC]
    Local File =DOSSIER+".ACLAFLD"      [ACLAF]
    Local File =DOSSIER+".ACLALNK"      [ACLAK]
    Local File =DOSSIER+".ACLAMAP"      [ACLAKP]
    Local File =DOSSIER+".ACLAMET"      [ACLAM]
    Local File =DOSSIER+".ACLAMETSTD"   [ACLAT]
    Local File =DOSSIER+".ACLAOPT"      [ACLAO]
    Local File =DOSSIER+".ACLAPARDEF"   [ACLPD]
    Local File =DOSSIER+".ACLAPARFLD"   [ACLFP]
    #TABLE
    Local File =DOSSIER+".ATABLE"       [ATB]
    Local File =DOSSIER+".ATABZON"      [ATZ]
    Local File =DOSSIER+".ATABIND"      [ATI]
    Local File =DOSSIER+".AMSKPAR"      [AMP]
    # ------------------------------------
    Trbegin [ASW]
    GOK = 1
    For [ASW] Where [F:ASW]CODACT = "PAPI"
      [L]CODREPDEL = [F:ASW]CODREP
      Gosub DEL_ASW
      If GOK <> 0 Then
        Call ECR_TRACE("UTIHRM006 : Representation "+[L]CODREPDEL+" deleted  : "+DOSSIER,0) From GESECRAN
      Endif
    Next
    # ------------------------------------
    If GOK = 1 Then
      For [ACLA] Where [F:ACLA]CODACT = "PAPI"
        [L]CODCLADEL = [F:ACLA]CODCLA
        Gosub DEL_ACL
        If GOK <> 0 Then
          Call ECR_TRACE("UTIHRM006 : Class "+[L]CODCLADEL+" deleted  : "+DOSSIER,0) From GESECRAN
        Endif
      Next
    Endif
    # ------------------------------------
    If GOK = 1 Then
      For [ATB] Where [F:ATB]CODACT = "PAPI"
        [L]CODATBDEL = [F:ATB]CODFIC
        Gosub DEL_ATB
        If GOK <> 0 Then
          Call ECR_TRACE("UTIHRM006 : Table "+[L]CODATBDEL+" deleted  : "+DOSSIER,0) From GESECRAN
        Endif
      Next
    Endif
    # ------------------------------------
    If !GOK
      Rollback
      Call ECR_TRACE("UTIHRM006: Process completed unsuccessfully (All changes reverted please see errors) on : "+DOSSIER,1) From GESECRAN
    Else
      Commit
      Call ECR_TRACE("UTIHRM006: Process completed successfully on : "+DOSSIER,0) From GESECRAN
    Endif
    # ------------------------------------

  Endif
End

##############################
$DEL_ASW
  Delete [ASW] Where [F:ASW]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASW  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWB] Where [F:ASWB]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWB  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWC] Where [F:ASWC]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWC  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWR] Where [F:ASWR]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWR  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWF] Where [F:ASWF]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWF  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWK] Where [F:ASWK]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWK  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWMN] Where [F:ASWMN]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWMN  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWM] Where [F:ASWM]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWM  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWO] Where [F:ASWO]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWO  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWP] Where [F:ASWP]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWP  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWMP] Where [F:ASWMP]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWMP  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif

  Delete [ASWS] Where [F:ASWS]CODREP = CODREPDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting representation "+[L]CODREPDEL+" from ASWS  : "+DOSSIER - CODREPDEL,1) From GESECRAN
    Return
  Endif
Return

##############################
$DEL_ACL

  Delete [ACLA] Where [F:ACLA]CODCLA = CODCLADEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting Deleted Class "+CODCLADEL+" from ACLA  : "+DOSSIER - CODCLADEL,1) From GESECRAN
    Return
  Endif

  Delete [ACLAC] Where [F:ACLAC]CODCLA = CODCLADEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting Deleted Class "+CODCLADEL+" from ACLAC  : "+DOSSIER - CODCLADEL,1) From GESECRAN
    Return
  Endif

  Delete [ACLAF] Where [F:ACLAF]CODCLA = CODCLADEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting Deleted Class "+CODCLADEL+" from ACLAF  : "+DOSSIER - CODCLADEL,1) From GESECRAN
    Return
  Endif

  Delete [ACLAK] Where [F:ACLAK]CODCLA = CODCLADEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting Deleted Class "+CODCLADEL+" from ACLAK  : "+DOSSIER - CODCLADEL,1) From GESECRAN
    Return
  Endif

  Delete [ACLAKP] Where [F:ACLAKP]CODCLA = CODCLADEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting Deleted Class "+CODCLADEL+" from ACLAKP  : "+DOSSIER - CODCLADEL,1) From GESECRAN
    Return
  Endif

  Delete [ACLAM] Where [F:ACLAM]CODCLA = CODCLADEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting Deleted Class "+CODCLADEL+" from ACLAM  : "+DOSSIER - CODCLADEL,1) From GESECRAN
    Return
  Endif

  Delete [ACLAT] Where [F:ACLAT]CODCLA = CODCLADEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting Deleted Class "+CODCLADEL+" from ACLAT  : "+DOSSIER - CODCLADEL,1) From GESECRAN
    Return
  Endif

  Delete [ACLAO] Where [F:ACLAO]CODCLA = CODCLADEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting Deleted Class "+CODCLADEL+" from ACLAO  : "+DOSSIER - CODCLADEL,1) From GESECRAN
    Return
  Endif

  Delete [ACLPD] Where [F:ACLPD]CODCLA = CODCLADEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting Deleted Class "+CODCLADEL+" from ACLPD  : "+DOSSIER - CODCLADEL,1) From GESECRAN
    Return
  Endif

  Delete [ACLFP] Where [F:ACLFP]CODCLA = CODCLADEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting Deleted Class "+CODCLADEL+" from ACLFP  : "+DOSSIER - CODCLADEL,1) From GESECRAN
    Return
  Endif
Return

##############################
$DEL_ATB
Local Char WDOS(GLONADS) : [L]WDOS = DOSSIER
Local Integer WSTAT
Local Char    WSUF(10) , WFICTRT(GDIMFIC) , DOSHISTO(GLONADS)

  Delete [ATB] Where [F:ATB]CODFIC=CODATBDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting table "+CODATBDEL+" from ATB  : "+DOSSIER - CODATBDEL,1) From GESECRAN
    Return
  Endif

  Delete [ATZ] Where [F:ATZ]CODFIC=CODATBDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting table "+CODATBDEL+" from ATZ  : "+DOSSIER - CODATBDEL,1) From GESECRAN
    Return
  Endif

  Delete [ATI] Where [F:ATI]CODFIC=CODATBDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting table "+CODATBDEL+" from ATI  : "+DOSSIER - CODATBDEL,1) From GESECRAN
    Return
  Endif

  Delete [AMP] Where [F:AMP]TYPAFF=2 & [F:AMP]CODAFF=CODATBDEL
  If fstat
    GOK = 0
    Call ECR_TRACE("UTIHRM006 : Error deleting table "+CODATBDEL+" from AMP  : "+DOSSIER - CODATBDEL,1) From GESECRAN
    Return
  Endif

  For WSUF = "srf", "fde", "dat", "idx" , "cfg"
    WFICTRT = filpath("FIL",CODATBDEL,WSUF,WDOS)
    If filinfo(WFICTRT,0)>=0
      WSTAT = Delfile(WFICTRT)
      If WSTAT
        Call ECR_TRACE("UTIHRM006 : Deleted file "+CODATBDEL+"."+WSUF+" in : "+WDOS,0) From GESECRAN
      Endif
    Endif
  Next WSUF

  ## FGR : Table is going to continue to exist in Database. Must be deleted in database too.
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  # Not in this case because root folder must be fixed too
  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ASHW","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHW") : End : Endif
  If filinfo(filpath("FIL","ASHWBLC","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWBLC") : End : Endif
  If filinfo(filpath("FIL","ASHWCOL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWCOL") : End : Endif
  If filinfo(filpath("FIL","ASHWEXPPRO","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWEXPPRO") : End : Endif
  If filinfo(filpath("FIL","ASHWFLD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWFLD") : End : Endif
  If filinfo(filpath("FIL","ASHWLNK","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWLNK") : End : Endif
  If filinfo(filpath("FIL","ASHWMENU","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWMENU") : End : Endif
  If filinfo(filpath("FIL","ASHWMET","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWMET") : End : Endif
  If filinfo(filpath("FIL","ASHWOPT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWOPT") : End : Endif
  If filinfo(filpath("FIL","ASHWPAR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWPAR") : End : Endif
  If filinfo(filpath("FIL","ASHWPARMET","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWPARMET") : End : Endif
  If filinfo(filpath("FIL","ASHWSEC","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ASHWSEC") : End : Endif
  If filinfo(filpath("FIL","ACLASSE","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACLASSE") : End : Endif
  If filinfo(filpath("FIL","ACLACOL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACLACOL") : End : Endif
  If filinfo(filpath("FIL","ACLAFLD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACLAFLD") : End : Endif
  If filinfo(filpath("FIL","ACLALNK","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACLALNK") : End : Endif
  If filinfo(filpath("FIL","ACLAMAP","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACLAMAP") : End : Endif
  If filinfo(filpath("FIL","ACLAMET","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACLAMET") : End : Endif
  If filinfo(filpath("FIL","ACLAMETSTD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACLAMETSTD") : End : Endif
  If filinfo(filpath("FIL","ACLAOPT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACLAOPT") : End : Endif
  If filinfo(filpath("FIL","ACLAPARDEF","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACLAPARDEF") : End : Endif
  If filinfo(filpath("FIL","ACLAPARFLD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACLAPARFLD") : End : Endif
  If filinfo(filpath("FIL","ATABLE","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATABLE") : End : Endif
  If filinfo(filpath("FIL","ATABZON","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATABZON") : End : Endif
  If filinfo(filpath("FIL","ATABIND","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATABIND") : End : Endif
  If filinfo(filpath("FIL","AMSKPAR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AMSKPAR") : End : Endif
  # -------------------------
  Call MAJ_UTIHRM006(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  # Not in this case because root folder must be fixed too
