#<AdxTL>@(#)0.0.0.0 $Revision$
#JOJAC - 2016-03-17 REQ114309 US87 - START
#FRLAA - 2015-03-13 - REQUIREMENT 104631 US 3195 - START
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "MODIF"     : Gosub MODIF
 When "CREATION"  : Gosub CREATION
 When "FILTRE"    : Gosub FILTRE
Endcase
Return

$OUVRE

If clalev([F:PSS])=0    : Local File POSTEKSA    [PSS]         : Endif
Return

$LIENS
Read [F:PSS]PSA0=[M:POT0]COD
If !fstat
  [M:POT3] = [F:PSS]
Endif

#RSA
If func AFNC.ACTIV("KZA")>0
  If [M:POT3]PDIFLG = 1
    Effzo [M:POT3]RCEGRP        : Grizo [M:POT3]RCEGRP
    Effzo [M:POT3]SEX           : Grizo [M:POT3]SEX
    Effzo [M:POT3]PDISTR        : Grizo [M:POT3]PDISTR
    Effzo [M:POT3]PDIEND        : Grizo [M:POT3]PDIEND
  Else
    Actzo [M:POT3]RCEGRP
    Actzo [M:POT3]SEX
    Actzo [M:POT3]PDISTR
    Actzo [M:POT3]PDIEND
  Endif

   If [M:POT3]HDCFLG = 1
    Effzo [M:POT3]HDCTYP        : Grizo [M:POT3]HDCTYP
    Effzo [M:POT3]HDCSTR        : Grizo [M:POT3]HDCSTR
    Effzo [M:POT3]HDCEND        : Grizo [M:POT3]HDCEND
  Else
    Actzo [M:POT3]HDCTYP
    Actzo [M:POT3]HDCSTR
    Actzo [M:POT3]HDCEND
  Endif
Endif
Return

$MODIF
$CREATION
  Delete [PSS] Where COD=[M:POT0]COD
    If fstat=1
     GOK = -1
     GLOCK = "$POSTEKSA"-[F:POT]COD
     Return
    Elsif fstat>5
     GOK = 0
     Call RSTA("PSA",[F:POT]COD) From GLOCK
     Return
    Endif
    [F:PSS]COD = [F:POT]COD
    [F:PSS]    = [M:POT3]
    Write [PSS]
    If fstat
      GOK=0 : Return
    Endif

Return


$FILTRE
  If clalev([F:PSS]) = 0 : Local File POSTEKSA    [PSS]         : Endif
    If [F:POT]COD <> [F:PSS]COD
      Read [PSS]PSA0 = [F:POT]COD
    Endif
  Return


Subprog AM_CCV(VALEUR)
Variable Char VALEUR()
If func AFNC.ACTIV("KZA")>0
  If clalev([F:CCV]) = 0    : Local File CLASSCONV    [CCV]         : Endif
  Read [F:CCV]CCV0 = VALEUR
  If !fstat
    [M:POT3] = [F:CCV] #also done in the main code - protecting for KSA
    Affzo [M:POT3]OCPLEV
  Endif
  [M:POT3]JOBGRA = VALEUR
  Affzo [M:POT3]JOBGRA
Endif
End

Subprog AM_PDIFLG(VALEUR)
Variable Integer VALEUR()
If func AFNC.ACTIV("KZA")>0
  If [L]VALEUR = 1
    Effzo [M:POT3]RCEGRP        : Grizo [M:POT3]RCEGRP
    Effzo [M:POT3]SEX           : Grizo [M:POT3]SEX
    Effzo [M:POT3]PDISTR        : Grizo [M:POT3]PDISTR
    Effzo [M:POT3]PDIEND        : Grizo [M:POT3]PDIEND
  Else
    Actzo [M:POT3]RCEGRP
    Actzo [M:POT3]SEX
    Actzo [M:POT3]PDISTR
    Actzo [M:POT3]PDIEND
  Endif
Endif
End

Subprog AM_HDCFLG(VALEUR)
Variable Integer VALEUR()
If func AFNC.ACTIV("KZA")>0
  If [L]VALEUR = 1
    Effzo [M:POT3]HDCTYP        : Grizo [M:POT3]HDCTYP
    Effzo [M:POT3]HDCSTR        : Grizo [M:POT3]HDCSTR
    Effzo [M:POT3]HDCEND        : Grizo [M:POT3]HDCEND
  Else
    Actzo [M:POT3]HDCTYP
    Actzo [M:POT3]HDCSTR
    Actzo [M:POT3]HDCEND
  Endif
Endif
End

#FRLAA - 2015-04-17 - REQUIREMENT 104631 US 3487 - START
Subprog AM_JOBPOT(VALEUR)
Variable Char VALEUR()
If func AFNC.ACTIV("KZA")>0
  If clalev([F:JSA1]) = 0    : Local File JOBTYPKSA    [JSA1]    : Endif
  Read [F:JSA1]JSA0 = VALEUR
  If !fstat
    [M:POT3] = [F:JSA1] #also done in the main code - protecting for KSA
    Affzo [M:POT3]
    Call AM_PDIFLG([M:POT3]PDIFLG)
    Call AM_HDCFLG([M:POT3]HDCFLG)
  Endif
Endif
End

#FRLAA - 2015-07-06 - REQUIREMENT 104631 US 3777 - START
Subprog S_OFOCOD(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("KZA")>0
  If clalev([F:CPYKSA])=0    : Local File HRCOMPANYKSA    [CPYKSA]         : Endif
  If clalev([F:HROFO])=0      : Local File HRSOFOCOD      [HROFO]          : Endif
  Filter [CPYKSA] Where CPY = [M:POT3]CPYPOT
  Read [CPYKSA] First
  If !fstat
    If [F:CPYKSA]SDLSETA = "" : End : Endif
  Else
    End
  Endif

  Filter [HROFO] Where SETACOD = [F:CPYKSA]SDLSETA

   ## Action SELOBJW
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "SELOBJW"
   PARMSK(1) = "HRSOFO1"
   PARMSK(2) = ""
   PARMSK(3) = ""
   Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
   GACTION = SAVACT
   Filter [HROFO]
   Gosub AFF From GSAISIE
Endif
End

#FRLAA - 2015-08-25 - REQUIREMENT 109427 US 3817 - START
Subprog AM_CPC(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("KZA")>0
  Call LECTURE("CPC",VALEUR,"") From CONTOBJ
  [M:POT4]CRSFLG(nolign-1)=[F:CPC]CRSFLG
  Affzo [M:POT4]CRSFLG(nolign-1)
Endif
End
#FRLAA - 2015-08-25 - REQUIREMENT 109427 US 3817 - END
