#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque PDSYPSH
##########################################################################
# SUBPDQ4 : Affichage de la situation de DA                 HN  31/03/00 #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p           #
# d'affichage "SITUATION_DA" et ne sert qu'à gérer le masque             #
# écran "PDSYPSH [PDQ4]".                                                #
##########################################################################

Subprog IB_NBLIG
#-------------------------------------#
# Avant zone : Activation bouton "DA" #
#-------------------------------------#
Raz GBOUT1
If nolign>[M:PDQ4]NBLIG & [M:PDQ4]NBLIG>0
  nolign=[M:PDQ4]NBLIG
Endif
If [M:PDQ4]PSHNUM(nolign-1)<>"" & GFONC1<>"GESPSH"
  GBOUT1=mess(61,198,1)-[M:PDQ4]PSHNUM(nolign-1)
Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran PDSYPSH) 12/01/2010 16:30:09 (MBT)
######################################################################################
Subprog IB_WQTYSTU
End


