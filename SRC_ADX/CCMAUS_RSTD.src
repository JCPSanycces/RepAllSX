#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CCMAUS_BIDCRY

$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
        When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
      Endcase
Endcase
Return

$AQUERY_TRANS_AFTER
  Local Char ROLE(30), DEPT(30)

  Call PARAMUTIL("CCMROLE", ROLE, this.AUS.USR, "") From SUBAUS
  Call PARAMUTIL("CCMDEPT", DEPT, this.AUS.USR, "") From SUBAUS
  If (ROLE <> "" & ROLE <> "1")
    this.ROLE = mess(val(ROLE), 2036, 1)
  Else
    this.ROLE = ""
  Endif
  If (DEPT <> "" & DEPT <> "1")
    this.DEPARTMENT = mess(val(DEPT), 2037, 1)
  Else
    this.DEPARTMENT = ""
  Endif
Return

$PROPERTIES
Case [L]CURPRO
Endcase
Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

