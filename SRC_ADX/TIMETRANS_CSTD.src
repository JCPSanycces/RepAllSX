# Class TIMETRANS


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
    When "GET_DATTIM" : Gosub GET_DATTIM
Endcase
Return

#**
#* GET_DATTIM : Return DateTime of transition
#* @param COD     = Code of the transition to use
#* @param PYEAR   = year for calculation
#* @param PDATTIM = date time of transition
#* @return error code
#*!
$GET_DATTIM
Local Instance TIMETRANS Using C_TIMETRANS
TIMETRANS  = NewInstance C_TIMETRANS AllocGroup TIMETRANS

ARET_VALUE = fmet TIMETRANS.AREAD([L]COD)
If ARET_VALUE=[V]CST_AOK
    If TIMETRANS.FXDFLG<2
        # Start calculation from 01/01/PYEAR
        DAT = gdat$(1,TIMETRANS.MON,PYEAR)

        # Look for date corresponding to 1st DAYWEE in the month
        If TIMETRANS.DAYWEE-dayn(DAT)<0
            DAT+=7
        Endif
        DAT += TIMETRANS.DAYWEE-dayn(DAT)

        # Add week number
        DAT += (TIMETRANS.WEE-1)*7

        If month(DAT)<>TIMETRANS.MON
            DAT-=7
        Endif

        ARET_VALUE = func TIMEZONE_CSTD.CONVERT_TO_DATETIME(day(DAT), month(DAT), year(DAT), fix(TIMETRANS.TIMDAY), fix((TIMETRANS.TIMDAY-fix(TIMETRANS.TIMDAY))*60), 0, PDATTIM)
    Else
        ARET_VALUE = func TIMEZONE_CSTD.CONVERT_TO_DATETIME(TIMETRANS.DDAY, TIMETRANS.MON, PYEAR, fix(TIMETRANS.TIMDAY), fix((TIMETRANS.TIMDAY-fix(TIMETRANS.TIMDAY))*60), 0, PDATTIM)
    Endif
Endif
FreeGroup TIMETRANS

Return

