#<AdxTL>@(#)0.0.0.0 $Revision$


###################
# CLASS PROPLNH
###################
$ACTION
  If (dim(TRACEUR_R) < 0) Then
    Global Integer TRACEUR_R
    Global Integer B_TRACE_R : B_TRACE_R = 1
    Global Integer B_TRACE : B_TRACE = 0
    GUSER = adxusr
    TRACEUR_R = 0
    Call TRACE_CLEAR From AXUNIT
    Call TRACE_LINE( "R_____" - "Trace reinitialisee______" - CURPRO ) From AXUNIT
  Endif


  If (B_TRACE_R) Then
    Call TRACE_LINE( " R===" - time$ - ACTION - "Curpro"- CURPRO ) From AXUNIT
  Endif
  Case CURPRO
    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is a hook called on properties
  Endcase

Return

###############
# METHODS
###############
$METHODS
  If (B_TRACE_R ) Then
    #Call TRACE_LINE(" R_____" - "Method : Action" - ACTION - "Curpro"- CURPRO -  "Curpth"-CURPTH) From AXUNIT
    Local Char LIGNE(200)
    LIGNE = " R_____" - "Method : Action" - ACTION - "Curpro"- CURPRO
    If (dim(CURPTH)>0) Then : LIGNE += " Curpth"-CURPTH : Else : LIGNE += "?????" :  Endif
    Call TRACE_LINE(LIGNE ) From AXUNIT
    Kill LIGNE
  Endif
  If (dim(CURPTH) > 0) Then
  Case CURPTH
    When ""
      Case ACTION
        When "CONSTRUCTOR"       : Gosub CONSTRUCTOR
        When "TRANS_QUERY"       : Gosub TRANS_QUERY
        When "CLOSE_QUERY"       : Gosub CLOSE_QUERY
        When "PROPERTIES_QUERY"  : Gosub PROPERTIES_QUERY
        When "AREAD_AFTER"       : Gosub AREAD_AFTER
        When "LOAD"              : Gosub LOAD
        When Default
      Endcase
    When "LINE"
    When "SUBLINE"
    When Default
  Endcase
  Endif
Return

###################################################################
#            METHODES DE LA CLASSE  -  LAYOUTFAS
###################################################################

$CONSTRUCTOR
  If (B_TRACE_R) Then
    Call TRACE_LINE(" R_CONSTRUCTOR" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return

$TRANS_QUERY
  If (B_TRACE_R) Then
    Call TRACE_LINE(" R_TRANS_QUERY" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return


$CLOSE_QUERY
  If (B_TRACE_R) Then
    Call TRACE_LINE(" R_CLOSE_QUERY" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return

$PROPERTIES_QUERY
  If (B_TRACE_R) Then
    Call TRACE_LINE(" R_PROPERTIES_QUERY" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Case CURPRO
  When "CUMQTY"     : Gosub CUMQTY : # Methods attached to property DEVTRA
Endcase
Return


$AREAD_AFTER
  If ( CURPTH = "" ) Then
    If (B_TRACE_R) Then
      Call TRACE_LINE(" R_AREAD_AFTER" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
    Endif
    Gosub GET_PROPLN_FXDASSETS

  Endif
Return

$LOAD
  If (B_TRACE_R) Then
    Call TRACE_LINE(" R_LOAD" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return

############################################################################################
### Subprog Biens du plan de production
############################################################################################
$GET_CURRENT_PERIOD
  Local File FISCALYEAR [FIY]
  Read [FIY]FIY1=this.PLH.CPY;this.PLH.CNX;2
  Close Local File [FIY]
Return

############################################################################################
### Subprog Biens du plan de production
############################################################################################
$GET_PROPLN_FXDASSETS

Local Integer I_F
Local Integer OK

  # Biens rattachés au plan de production
  # Chargement du tableau contenant les Biens rattachés au contrat
  Local File FXDASSETS [FAS]
  For [FAS]FAS0 Where PROPLN = this.PLH.PROPLN
    I_F = fmet this.ADDLINE("ASSETS",-1)
    this.AASREF   (I_F) = [F:FAS]AASREF
    this.AASDES1  (I_F) = [F:FAS]AASDES1
    this.PURDAT   (I_F) = [F:FAS]PURDAT
    this.ACGETRNOT(I_F) = [F:FAS]ACGETRNOT
  Next
  Close Local File [FAS]

Kill OK
Kill I_F
Return

###############
###############
# PROPERTY
###############
###############

$PROPERTIES
  If (B_TRACE_R) Then
    Call TRACE_LINE(" R_____" - "Property :" - CURPRO - "Action" - ACTION) From AXUNIT
  Endif
  Case CURPRO
    When "CUMQTY"    : Gosub CUMQTY
    When Default
    Endcase
  Return

###################################################################
#            METHODES SUR LA PROPRIETE  -  CUMQTY
###################################################################
$CUMQTY
Case ACTION
   When "INIT"      : Gosub INIT_CUMQTY      : # Init method attached to DEVTRA
   When "CONTROL"   : Gosub CONTROL_CUMQTY   : # Control method attached to DEVTRA
   When "PROPAGATE" : Gosub PROPAGATE_CUMQTY : # Propagate method attached to DEVTRA
   When "GET"       : Gosub GET_CUMQTY       : # Get method attached to DEVTRA
Endcase
Return
#---------------------
$INIT_CUMQTY
  If (B_TRACE_R) Then
    Call TRACE_LINE(" R_INIT" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return
#---------------------
$CONTROL_CUMQTY
  If (B_TRACE_R) Then
    Call TRACE_LINE(" R_CONTROL" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return
#---------------------
$PROPAGATE_CUMQTY
  If (B_TRACE_R) Then
    Call TRACE_LINE(" R_PROPAGATE" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return
#---------------------
$GET_CUMQTY
  If (B_TRACE_R) Then
    Call TRACE_LINE(" R_CUMQTY" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return
