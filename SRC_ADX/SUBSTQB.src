#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################
# RECSTJ_STQ_FSM
# Cherche pour ligne STQ1 le détail de l echantillonnage
#    - Le statut qualité est unique ou multiple
#    - Le type d'emplacement est unique ou multiple
#    - L'emplacement est unique ou multiple
#    - Désignation du mouvement unique.
# Cette fonction permet de faire apparaître un $ pour montrer la décomposition du champ
########################################################################
# Paramètres E : ABR  = Ecran "XYZ"
#              : FCY  = Site
#              : VCR  = Numéro document
#              : TYP  = Type de document
#              : NOL  = Indice de ligne dans le tableau du document (nolign-1)
#              : LSUP = Inutilisé (paramètre supplémentaire au cas où)
#              : LAAA = Quantité déjà en A
#              : LRRR = Quantité déjà en R
#
# Prérequis : Fichier STOJOU [STJ] ouvert
#             Fichier ITMMASTER [ITM] ouvert et positionné
#             Fichier ITMFACILIT [ITF] ouvert et positionné
########################################################################
Subprog RECSTJ_STQ_FSM (ABR,ITM,FCY,TYP,VCR,LLOT,NOL,LSUP,LAAA,LRRR)
Value Char    ABR
Value Char    ITM
Value Char    FCY
Value Integer TYP
Value Char    VCR
Value Char    LLOT
Value Integer NOL
Value Char    LSUP
Variable Decimal LAAA
Variable Decimal LRRR

Local Char    LMABR(10)
Local Char    PSTA(GLONSTA)
Local Char    PPCU(GLONUOM)
Local Decimal PCOE
Local Decimal PQTYPCU
Local Decimal PQTYSTU
Local Char    PLOCTYP(GLONEMP)
Local Char    PLOC(GLONEMP)
Local Char    PWRH(GLONWRH)
Local Char    PSER(GLONSER)
Local Char    PLPN(GLONLPN)                           # hcb X3-77043
Local Char LSER(GLONSER),LSERF(GLONSER)
Local Integer I
Local Integer LRET

Local Shortint CWRH    # 1=vérifie la décomposition en plusieurs depots
Local Shortint CLOC    # 1=vérifie la décomposition en plusieurs emplacements
Local Shortint CSER    # 1=vérifie la décomposition en n° série discontinus
Local Shortint CLPN    # 1=vérifie la décomposition en plusieurs contenants     # hcb X3-77043

Local Char CAR(1) : CAR = "$"
Local Char CRITERE(50)
############
# Init des variables locales
LMABR  = "[M:"+ABR+"]"

Raz I
Raz PSTA
Raz PPCU
Raz PCOE
Raz PQTYPCU
Raz PQTYSTU
Raz PLOC
Raz PLOCTYP
Raz PSER
Raz PLPN                          # hcb X3-77043


If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
If !clalev([F:STC]) : Local File STOLOC     [STC] : Endif

If !clalev([F:ITF])
    Local File ITMFACILIT [ITF]
    Read [ITF]ITF0=ITM;FCY
Elsif [F:ITF]ITMREF<>ITM |  [F:ITF]STOFCY<>FCY
    Read [ITF]ITF0=ITM;FCY
Endif
CLOC = evalue("dim("+LMABR+"LOC)")>0 & [F:ITF]LOCMGTCOD = 2
CLPN = evalue("dim("+LMABR+"LPNNUM)")>0 & [F:ITF]LPNMGTCOD = 2              # hcb X3-77043
CWRH = evalue("dim("+LMABR+"WRH)")>0 & [F:ITF]LOCMGTCOD = 2
If evalue("dim("+LMABR+"SERNUMDEP)")>0
    LSER  = evalue(LMABR+"SERNUMDEP(NOL)")
Endif
If evalue("dim("+LMABR+"SERNUMFDEP)")>0
    LSERF = evalue(LMABR+"SERNUMFDEP(NOL)")
Endif
If evalue("dim("+LMABR+"SERNUM)")>0
    CSER = evalue("dim("+LMABR+"SERNUM)")>0 & LSER<>""
Endif


################################
# Recherche pour STA, LOC et PCU
CRITERE  = "1=1"

If [F:ITF]SMPMOD = 2
   CRITERE = "LOT = LLOT"
Endif
Filter [STJ] Where STOFCY = FCY
&                & VCRTYP = TYP & VCRNUM = VCR
&                & evalue(CRITERE)
&                & REGFLG <> 2
&                & QTYSTU > 0
&                & pat(STA,"Q*")<>1
For [STJ] Hint Key STJ1
    I+=1
    PQTYPCU += [F:STJ]QTYPCU
    PQTYSTU += [F:STJ]QTYSTU
    If left$([F:STJ]STA,1)="A"
        LAAA += [F:STJ]QTYSTU
    Elsif left$([F:STJ]STA,1)="R"
        LRRR += [F:STJ]QTYSTU
    Endif
    # Au 1er tour on initialise les variables qui permettront les comparaisons
    If I=1
        PSTA = [F:STJ]STA
        PPCU = [F:STJ]PCU
        PCOE = [F:STJ]PCUSTUCOE
        If CLOC=1
            PLOC = [F:STJ]LOC
            Read [STC]STC0=FCY;PLOC
            If !fstat
                PLOCTYP = [F:STC]LOCTYP
            Endif
        Endif
        If CLPN=1                                                               # hcb X3-77043
            PLPN = [F:STJ]LPNNUM                                                # hcb X3-77043
        Endif                                                                   # hcb X3-77043
        If CSER=1
            Assign LMABR+"SERNUM(NOL)" With [F:STJ]SERNUM
            PSER = [F:STJ]SERNUM
        Endif
        If CWRH=1
            Assign LMABR+"WRH(NOL)" With [F:STJ]WRH
            PWRH = [F:STJ]WRH
        Endif

        If evalue("dim("+LMABR+"IPTDAT)")>0
            Assign LMABR+"IPTDAT(NOL)" With [F:STJ]IPTDAT
        Endif
        If evalue("dim("+LMABR+"MVTDES)")>0
            Assign LMABR+"MVTDES(NOL)" With [F:STJ]MVTDES
        Endif
    ###########
    # Aux tours suivants on regarde les différences
    Else
        If [F:STJ]STA <> PSTA
            PSTA = CAR
        Endif
        If [F:STJ]PCU <> PPCU
            PPCU = CAR
        Endif
        If [F:STJ]PCUSTUCOE <> PCOE
            PCOE = 0
        Endif
        If CLOC
            If [F:STJ]LOC <> PLOC
                PLOC = CAR
                Read [STC]STC0=FCY;[F:STJ]LOC
                If !fstat
                    If [F:STC]LOCTYP <> PLOCTYP
                        PLOCTYP = CAR
                    Endif
                Endif
            Endif
        Endif
        If CLPN                                                     # hcb X3-77043
            If [F:STJ]LPNNUM <> PLPN                              # hcb X3-77043
                PLPN = CAR                                        # hcb X3-77043
            Endif                                                 # hcb X3-77043
        Endif                                                     # hcb X3-77043
        If CWRH
            If [F:STJ]WRH <> PWRH
                PWRH = CAR
            Endif
        Endif
        If CSER & PSER<>CAR
            Call PLUS_UN(PSER,PSER,LRET) From STKLIB
            If PSER<>[F:STJ]SERNUM
                PSER = CAR
            Endif
        Endif
    Endif
Next

Filter [STJ]

Assign LMABR+"STADES(NOL)" With PSTA
If PQTYPCU<>0
    Assign LMABR+"PCUDES(NOL)" With PPCU
Endif
If PPCU=CAR | PCOE=0
    Assign LMABR+"QTYPCUDES(NOL)" With 0
    Assign LMABR+"COEDES(NOL)"    With 0
Else
    Assign LMABR+"COEDES(NOL)" With PCOE
    Assign LMABR+"QTYPCUDES(NOL)" With PQTYPCU
Endif
Assign LMABR+"QTYSTUDES(NOL)" With PQTYSTU
If CLOC=1 & evalue("dim("+LMABR+"LOCTYPDES)")>0
    Assign LMABR+"LOCTYPDES(NOL)" With PLOCTYP
    Assign LMABR+"LOCDES(NOL)" With PLOC
Endif
If CLPN=1 & evalue("dim("+LMABR+"LPNNUMDES)")>0                      # hcb X3-77043
    Assign LMABR+"LPNNUMDES(NOL)" With PLPN                         # hcb X3-77043
Endif                                                               # hcb X3-77043
If CSER=1 & evalue("dim("+LMABR+"SERNUMF)")>0
    Assign LMABR+"SERNUMF(NOL)" With PSER
Endif
If CWRH=1 & evalue("dim("+LMABR+"WRHDES)")>0
    Assign LMABR+"WRHDES(NOL)" With PWRH
Endif

End

#                                                   hcb V6CQ fin


########################################################################
# RECSTO_F
# Cherche pour une ligne de document donné si dans le détail de cette ligne:
#    - Le statut qualité est unique ou multiple
#    - Le type d'emplacement est unique ou multiple
#    - L'emplacement est unique ou multiple
#    - Désignation du mouvement unique.
# Cette fonction permet de faire apparaître un $ pour montrer la décomposition du champ
########################################################################
# Paramètres E : ABR  = Ecran "XYZ"
#              : FCY  = Site
#              : VCR  = Numéro document
#              : TYP  = Type de document
#              : NOL  = Indice de ligne dans le tableau du document (nolign-1)
#              : LSUP = Inutilisé (paramètre supplémentaire au cas où)
#              : LAAA = Quantité déjà en A
#              : LRRR = Quantité déjà en R
#
# Prérequis : Fichier STOJOU [STJ] ouvert
#             Fichier ITMMASTER [ITM] ouvert et positionné
#             Fichier ITMFACILIT [ITF] ouvert et positionné
########################################################################
Subprog RECSTO_F (ABR,ITM,FCY,TYP,VCR,LIN,NOL,LSUP,LAAA,LRRR)
Value Char    ABR
Value Char    ITM
Value Char    FCY
Value Integer TYP
Value Char    VCR
Value Integer LIN
Value Integer NOL
Value Char    LSUP
Variable Decimal LAAA
Variable Decimal LRRR

Local Char    LMABR(10)
Local Char    PSTA(GLONSTA)
Local Char    PPCU(GLONUOM)
Local Decimal PCOE
Local Decimal PQTYPCU
Local Decimal PQTYSTU
Local Char    PLOCTYP(GLONEMP)
Local Char    PLOC(GLONEMP)
Local Char    PWRH(GLONWRH)
Local Char    PSER(GLONSER)
Local Char    PLPN(GLONLPN)                  # hcb X3-77043
Local Char LSER(GLONSER),LSERF(GLONSER)
Local Integer I
Local Integer LRET

Local Shortint CWRH    # 1=vérifie la décomposition en plusieurs depots
Local Shortint CLOC    # 1=vérifie la décomposition en plusieurs emplacements
Local Shortint CSER    # 1=vérifie la décomposition en n° série discontinus
Local Shortint CLPN    # 1=vérifie la décomposition en plusieurs contenants                # hcb X3-77043

Local Char CAR(1) : CAR = "$"

############
# Init des variables locales
LMABR  = "[M:"+ABR+"]"

Raz I
Raz PSTA
Raz PPCU
Raz PCOE
Raz PQTYPCU
Raz PQTYSTU
Raz PLOC
Raz PWRH
Raz PLOCTYP
Raz PSER
Raz PLPN                                                           # hcb X3-77043

If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
If !clalev([F:STC]) : Local File STOLOC     [STC] : Endif

If !clalev([F:ITF])
    Local File ITMFACILIT [ITF]
    Read [ITF]ITF0=ITM;FCY
Elsif [F:ITF]ITMREF<>ITM |  [F:ITF]STOFCY<>FCY
    Read [ITF]ITF0=ITM;FCY
Endif
CLOC = evalue("dim("+LMABR+"LOC)")>0 & [F:ITF]LOCMGTCOD = 2
CLPN = evalue("dim("+LMABR+"LPNNUM)")>0 & [F:ITF]LPNMGTCOD = 2         # hcb X3-77043
CWRH = evalue("dim("+LMABR+"WRH)")>0 & [F:ITF]LOCMGTCOD = 2
If evalue("dim("+LMABR+"SERNUMDEP)")>0
    LSER  = evalue(LMABR+"SERNUMDEP(NOL)")
Endif
If evalue("dim("+LMABR+"SERNUMFDEP)")>0
    LSERF = evalue(LMABR+"SERNUMFDEP(NOL)")
Endif
If evalue("dim("+LMABR+"SERNUM)")>0
    CSER = evalue("dim("+LMABR+"SERNUM)")>0 & LSER<>""
Endif
################################
# Recherche pour STA, LOC et PCU

If LSER = LSERF
    Filter [STJ] Where STOFCY = FCY
&                    & VCRTYP = TYP & VCRNUM = VCR & VCRLIN = LIN
&                    & REGFLG <> 2
&                    & QTYSTU > 0
&                    & pat(STA,"Q*")<>1
Else
    Filter [STJ] Where STOFCY = FCY
&                    & VCRTYP = TYP & VCRNUM = VCR
&                    & REGFLG <> 2
&                    & QTYSTU > 0
&                    & pat(STA,"Q*")<>1
&                    & SERNUM  >= LSER
&                    & SERNUM  <= LSERF
&                    & len(SERNUM) = len(LSER)
&                Order By SERNUM
Endif
For [STJ] Hint Key STJ1
    I+=1
    PQTYPCU += [F:STJ]QTYPCU
    PQTYSTU += [F:STJ]QTYSTU
    If left$([F:STJ]STA,1)="A"
        LAAA += [F:STJ]QTYSTU
    Elsif left$([F:STJ]STA,1)="R"
        LRRR += [F:STJ]QTYSTU
    Endif
    # Au 1er tour on initialise les variables qui permettront les comparaisons
    If I=1
        PSTA = [F:STJ]STA
        PPCU = [F:STJ]PCU
        PCOE = [F:STJ]PCUSTUCOE
        If CLOC=1
            PLOC = [F:STJ]LOC
            Read [STC]STC0=FCY;PLOC
            If !fstat
                PLOCTYP = [F:STC]LOCTYP
            Endif
        Endif
        If CLPN=1                                             # hcb X3-77043
            PLPN = [F:STJ]LPNNUM                              # hcb X3-77043
        Endif                                                 # hcb X3-77043
        If CWRH=1
            PWRH = [F:STJ]WRH
        Endif
        If CSER=1
            Assign LMABR+"SERNUM(NOL)" With [F:STJ]SERNUM
            PSER = [F:STJ]SERNUM
        Endif

        If evalue("dim("+LMABR+"IPTDAT)")>0
            Assign LMABR+"IPTDAT(NOL)" With [F:STJ]IPTDAT
        Endif
        If evalue("dim("+LMABR+"MVTDES)")>0
            Assign LMABR+"MVTDES(NOL)" With [F:STJ]MVTDES
        Endif
    ###########
    # Aux tours suivants on regarde les différences
    Else
        If [F:STJ]STA <> PSTA
            PSTA = CAR
        Endif
        If [F:STJ]PCU <> PPCU
            PPCU = CAR
        Endif
        If [F:STJ]PCUSTUCOE <> PCOE
            PCOE = 0
        Endif
        If CLOC
            If [F:STJ]LOC <> PLOC
                PLOC = CAR
                Read [STC]STC0=FCY;[F:STJ]LOC
                If !fstat
                    If [F:STC]LOCTYP <> PLOCTYP
                        PLOCTYP = CAR
                    Endif
                Endif
            Endif
        Endif
       If CLPN                                          # hcb X3-77043
            If [F:STJ]LPNNUM <> PLPN                    # hcb X3-77043
                PLPN = CAR                              # hcb X3-77043
            Endif                                       # hcb X3-77043
        Endif                                           # hcb X3-77043
        If CWRH
            If [F:STJ]WRH <> PWRH
                PWRH = CAR
            Endif
        Endif
        If CSER & PSER<>CAR
            Call PLUS_UN(PSER,PSER,LRET) From STKLIB
            If PSER<>[F:STJ]SERNUM
                PSER = CAR
            Endif
        Endif
    Endif
Next

Filter [STJ]

Assign LMABR+"STADES(NOL)" With PSTA
If PQTYPCU<>0
    Assign LMABR+"PCUDES(NOL)" With PPCU
Endif
If PPCU=CAR | PCOE=0
    Assign LMABR+"QTYPCUDES(NOL)" With 0
    Assign LMABR+"COEDES(NOL)"    With 0
Else
    Assign LMABR+"COEDES(NOL)" With PCOE
    Assign LMABR+"QTYPCUDES(NOL)" With PQTYPCU
Endif
Assign LMABR+"QTYSTUDES(NOL)" With PQTYSTU
If CLOC=1 & evalue("dim("+LMABR+"LOCTYPDES)")>0
    Assign LMABR+"LOCTYPDES(NOL)" With PLOCTYP
    Assign LMABR+"LOCDES(NOL)" With PLOC
Endif
If CLPN=1 & evalue("dim("+LMABR+"LPNNUMDES)")>0                  # hcb X3-77073
    Assign LMABR+"LPNNUMDES(NOL)" With PLPN                      # hcb X3-77073
Endif                                                            # hcb X3-77073
If CWRH=1 & evalue("dim("+LMABR+"WRHDES)")>0
    Assign LMABR+"WRHDES(NOL)" With PWRH
Endif

If CSER=1 & evalue("dim("+LMABR+"SERNUMF)")>0
    Assign LMABR+"SERNUMF(NOL)" With PSER
Endif

End

#######################################################################
$LIENSLIG
Local Integer LLLRET
Local Char    LSER(GLONSER)
Local Char    LLOT(GLONLOT)                                                 # hcb V6CQ
Local Char    WLOT(GLONLOT)                                                 # hcb V6CQ
Local Integer LQLAEG

Local Integer WMAX
WMAX = dim([M:STQ1]MVTFLG)     # mémorisation nombre de ligne maxi
Raz nolign
Raz LSER
Raz LLOT                                                                    # hcb V6CQ
#
If [F:ITF]SMPTYP > 1
   [M:STQ1]WSMPTYP = mess(84,187,1) + " : " + mess([F:ITF]SMPMOD,2756,1)
   If [F:ITF]SMPMOD = 2
      Filter [QLD] Where VCRTYP    = [M:STQ1]VCRTYP
&                      & VCRNUM    = [M:STQ1]VCRNUM
&                  Order By Key QLD2
   Else
      Filter [QLD] Where VCRTYP    = [M:STQ1]VCRTYP
&                      & VCRNUM    = [M:STQ1]VCRNUM
&                  Order By Key QLD0
   Endif
   For [QLD]
       If nolign > WMAX -1
          Call ERREUR(mess(70,184,1)) From GESECRAN
          Raz [M:STQ1]
          Break
       Else
          If [M:STQ1]NBLIG = 0
             Gosub NEWLINE_SMP
          Else
             If [F:ITF]SMPMOD = 2 & WLOT <> [F:QLD]LOT
                Gosub NEWLINE_SMP
             Else
                [M:STQ1]NBVCRLIN        (nolign-1) += 1            # hcb V6CQ
                [M:STQ1]QTYSTU          (nolign-1) += [F:QLD]QTYSTU
                If dim([M:STQ1]LOT)>0
                   If [M:STQ1]LOT       (nolign-1) <> [F:QLD]LOT
                      [M:STQ1]LOT       (nolign-1) = "$"
                      If dim([M:STQ1]SLO)>0                     # hcb 80558
                         [M:STQ1]SLO       (nolign-1) = "$"
                      Endif                                     # hcb 80558
                      If dim([M:STQ1]REFPER)>0                  # hcb 80558
                         Raz [M:STQ1]REFPER(nolign-1)
                         Raz [M:STQ1]SHLDAT(nolign-1)
                      Endif                                     # hcb 80558
                   Else
                      If dim([M:STQ1]SLO)>0
                         If [M:STQ1]SLO (nolign-1) <> [F:QLD]SLO
                            [M:STQ1]SLO (nolign-1) = "$"
                            If dim([M:STQ1]REFPER)>0            # hcb 80558
                               Raz [M:STQ1]REFPER(nolign-1)
                               Raz [M:STQ1]SHLDAT(nolign-1)
                            Endif                               # hcb 80558
                         Endif
                      Endif
                   Endif
                Endif
                If [M:STQ1]PCU(nolign-1)  <> [F:QLD]PCU
                   [M:STQ1]PCU(nolign-1)  = "$"
                   Raz [M:STQ1]QTYPCU(nolign-1)
                   Raz [M:STQ1]PCUSTUCOE(nolign-1)
                Else
                   [M:STQ1]QTYPCU(nolign-1)  += [F:QLD]QTYPCU
                Endif
                If dim([M:STQ1]SERNUMDEP)>0
                   If  [M:STQ1]SERNUMDEP (nolign-1) <> [F:QLD]SERNUM
                       [M:STQ1]SERNUMDEP (nolign-1)  = "$"
                       [M:STQ1]SERNUMFDEP(nolign-1)  = "$"
                   Endif
                Endif
                If [M:STQ1]STA(nolign-1)  <> [F:QLD]STA
                   [M:STQ1]STA(nolign-1)  = "$"
                Endif
                If dim([M:STQ1]LOCTYP)>0
                   If [M:STQ1]LOCTYP(nolign-1) <> [F:QLD]LOCTYP
                      [M:STQ1]LOCTYP(nolign-1) = "$"
                      [M:STQ1]LOC   (nolign-1) = "$"
                   Else
                      If dim([M:STQ1]LOC)>0
                         If [M:STQ1]LOC(nolign-1) <> [F:QLD]LOC
                            [M:STQ1]LOC(nolign-1) = "$"
                         Endif
                      Endif
                   Endif
                Endif
                If dim([M:STQ1]LPNNUM)>0                                        # hcb X3-77073
                   If [M:STQ1]LPNNUM(nolign-1) <> [F:QLD]LPNNUM                 # hcb X3-77073
                      [M:STQ1]LPNNUM(nolign-1) = "$"                            # hcb X3-77073
                   Endif                                                        # hcb X3-77073
                Endif
                If dim([M:STQ1]PALNUM)>0
                   If [M:STQ1]PALNUM(nolign-1)<>[F:QLD]PALNUM
                      [M:STQ1]PALNUM(nolign-1) = "$"
                   Endif
                Endif
                If dim([M:STQ1]CTRNUM)>0
                   If [M:STQ1]CTRNUM(nolign-1)<>[F:QLD]CTRNUM
                      [M:STQ1]CTRNUM(nolign-1) = "$"
                   Endif
                Endif
                If [M:STQ1]OWNER(nolign-1) <> [F:QLD]OWNER
                   [M:STQ1]OWNER(nolign-1) = "$"
                Endif
                If dim([M:STQ1]WRH)>0
                   If [M:STQ1]WRH(nolign-1)<>[F:QLD]WRH
                      [M:STQ1]WRH(nolign-1) = "$"
                   Endif
                Endif
#                                                                                         # hcb 111781 deb
                If dim([M:STQ1]ECCVALMAJ)>0
                   If [M:STQ1]ECCVALMAJ(nolign-1)<>[F:QLD]ECCVALMAJ
                      [M:STQ1]ECCVALMAJ(nolign-1) = "$"
                   Endif
                Endif
                If dim([M:STQ1]ECCVALMIN)>0
                   If [M:STQ1]ECCVALMIN(nolign-1)<>[F:QLD]ECCVALMIN
                      [M:STQ1]ECCVALMIN(nolign-1) = "$"
                   Endif
                Endif
                If dim([M:STQ1]ECCSAIFLG)>0
                   [M:STQ1]ECCSAIFLG(nolign-1) = 1
                Endif
#                                                                                         # hcb 111781 deb
             Endif
          Endif
       Endif
   Next
   Filter [QLD]
Else
   Filter [QLD] Where VCRTYP    = [M:STQ1]VCRTYP
&                   & VCRNUM    = [M:STQ1]VCRNUM
&               Order By Key QLD3
   For [QLD]
#hc  39051
   If left$([F:QLD]STA,1)="A"
      [M:STQ1]AAAQTY+=[F:QLD]QTYSTU
   Elsif left$([F:QLD]STA,1)="R"
      [M:STQ1]RRRQTY+=[F:QLD]QTYSTU
   Else
#hc 39051
      If nolign > WMAX -1
         Call ERREUR(mess(70,184,1)) From GESECRAN
         Raz [M:STQ1]
         Break
      Else
         If LSER<>""
            Call PLUS_UN(LSER, LSER, LLLRET) From STKLIB
         Endif
         # CRDSEQ fait parti des discriminants
         # car si des lignes ont été ajoutées on ne peut leur attribuer de réponse automatiquement
# hcb                            hcb 95904    rajout vcrlinori
# hcb                            hcb X3-77043 rajout lpnnum
         If [M:STQ1]NBLIG = 0
&           | [F:SRT]SERCOD <> 2
&           | LSER = ""
&           | LSER                                        <> [F:QLD]SERNUM
&           | [M:STQ1]VCRLINORI(nolign-1)                 <> [F:QLD]VCRLINORI
&           | [M:STQ1]PCU(nolign-1)                       <> [F:QLD]PCU
&           | [M:STQ1]PCUSTUCOE(nolign-1)                 <> [F:QLD]PCUSTUCOE
&           | [M:STQ1]STA(nolign-1)                       <> [F:QLD]STA
&           | (dim([M:STQ1]LPNNUM)>0 & [M:STQ1]LPNNUM(nolign-1) <> [F:QLD]LPNNUM)
&           | (dim([M:STQ1]LOC)>0 & [M:STQ1]LOC(nolign-1) <> [F:QLD]LOC)
&           | (dim([M:STQ1]WRH)>0 & [M:STQ1]WRH(nolign-1) <> [F:QLD]WRH)
&           | (dim([M:STQ1]LOT)>0 & [M:STQ1]LOT(nolign-1) <> [F:QLD]LOT)
&           | (dim([M:STQ1]SLO)>0 & [M:STQ1]SLO(nolign-1) <> [F:QLD]SLO)
&           | [M:STQ1]CRDSEQ(nolign-1)    <> [F:QLD]CRDSEQ
&           | (dim([M:STQ1]PALNUM)>0 & [M:STQ1]PALNUM(nolign-1)<>[F:QLD]PALNUM) & [F:SRT]IDECOD1=1
&           | (dim([M:STQ1]CTRNUM)>0 & [M:STQ1]CTRNUM(nolign-1)<>[F:QLD]CTRNUM) & [F:SRT]IDECOD2=1
&           | [M:STQ1]OWNER(nolign-1)                     <> [F:QLD]OWNER
            Gosub NEWLINE
         Else
            LQLAEG = 1
            For [QLA] Where QLYCTLDEM=[M:STQ1]VCRNUM & VCRLIN=[M:STQ1]VCRLIN(nolign-1)
&                         & CRDSEQ=[M:STQ1]CRDSEQ(nolign-1)
                 Filter [QLA1] Where QLYCTLDEM=[M:STQ1]VCRNUM & VCRLIN=[F:QLD]VCRLIN & CRDSEQ=[F:QLD]CRDSEQ
&                                  & QSTNUM=[F:QLA]QSTNUM & ASW=[F:QLA]ASW
                 Look [QLA1] First
                 Filter [QLA1]
                 If fstat
                    LQLAEG = 0
                    Break
                 Endif
            Next
            If !LQLAEG
               Gosub NEWLINE
            Else
               [M:STQ1]QTYPCU(nolign-1) += 1
               [M:STQ1]QTYSTU(nolign-1) += 1
               [M:STQ1]SERNUMFDEP(nolign-1) = LSER
            Endif
         Endif
      Endif
#hcb 39051
   Endif
Next
Filter [QLD]
Endif                                # hcb V6CQ

Return


$NEWLINE

LSER = [F:QLD]SERNUM
nolign += 1
[M:STQ1]                     = [F:QLD]
#                                                                                         # hcb X3-77043 deb
# si la transaction ne permet pas la modification de l'emplacement la selection sur LPNNUMDES
# affiche les Contenants ayant le meme emplacement ou ceux n ayant pas d'emplacement
Raz [M:STQ1]LOCSELLPN(nolign-1)
If dim([M:STQ1]LPNNUM)>0 & [M:STQ1]LPNNUM(nolign-1) <> "" & [F:SRT]CHGEMPCOD <> 2
   [M:STQ1]LOCSELLPN(nolign-1) = [M:STQ1]LOC(nolign-1)
Endif
#                                                                                         # hcb X3-77043 fin

Raz [M:STQ1]NBVCRLIN (nolign-1)                      # hcb V6CQ
#                                                                                         # hcb 111781 deb
If dim([M:STQ1]ECCSAIFLG)>0
   [M:STQ1]ECCSAIFLG(nolign-1) = 1
Endif
#                                                                                         # hcb 111781 deb

[M:STQ1]MVTFLG(nolign-1)     = 1
If dim([M:STQ1]SERNUMDEP)>0
    [M:STQ1]SERNUMDEP(nolign-1)  = LSER
Endif
If dim([M:STQ1]SERNUMFDEP)>0
    [M:STQ1]SERNUMFDEP(nolign-1) = LSER
Endif
If [F:ITF]STOMGTCOD>1 | [F:ITM]EXYMGTCOD>1                     # hcb 61549
    If [F:STL]LOT<>[F:QLD]LOT | [F:STL]SLO<>[F:QLD]SLO
        Read [STL]STL0=[F:QLD]ITMREF;[F:QLD]LOT;[F:QLD]SLO
    Endif
    If [F:ITF]STOMGTCOD>2 & dim([M:STQ1]POT)>0
        [M:STQ1]POT(nolign-1) = ([F:ITF]STOMGTCOD=3)*[F:STL]POT/100+([F:ITF]STOMGTCOD=4)*[F:STL]ACT
    Elsif dim([M:STQ1]POT)>1
        [M:STQ1]POT(nolign-1) = 1
    Endif
    #-- Si géré avec péremption
    If [F:ITM]EXYMGTCOD>1
       If dim([M:STQ1]REFPER)>0
         [M:STQ1]REFPER(nolign-1)=[F:STL]REFPER
       Endif
       If dim([M:STQ1]SHLDAT)>0
         [M:STQ1]SHLDAT(nolign-1)=[F:STL]SHLDAT
       Endif
    Endif
    If dim([M:STQ1]BPSLOT)>0
      [M:STQ1]BPSLOT(nolign-1)=[F:STL]BPSLOT
    Endif
Endif
[M:STQ1]WSTOSEQ(nolign-1) = nolign

#   rajout LPNNUM   = [F:QLD]LPNNUM                               # hcb X3-77073
If LSER=""
    Columns [STO] (STOCOU)
    Raz [STO]
    Filter [STO] Where ITMREF   = [M:STQ1]ITMREF
&                    & STOFCY   = [M:STQ1]STOFCY
&                    & LOT      = [F:QLD]LOT
&                    & SLO      = [F:QLD]SLO
&                    & PALNUM   = [F:QLD]PALNUM
&                    & CTRNUM   = [F:QLD]CTRNUM
&                    & STA      = [F:QLD]STA
&                    & LOC      = [F:QLD]LOC
&                    & LPNNUM   = [F:QLD]LPNNUM
&                    & PCU      = [F:QLD]PCU
&                    & PCUSTUCOE= [F:QLD]PCUSTUCOE
&                    & SERNUM   = [F:QLD]SERNUM
&                    & OWNER    = [F:QLD]OWNER
&                    & QLYCTLDEM= [F:QLD]VCRNUM
&                    & STOFLD1  = [F:QLD]STOFLD1
&                    & STOFLD2  = [F:QLD]STOFLD2
    For [STO]STO3
       Break
    Next
    [M:STQ1]WSTOCOU(nolign-1) = [F:STO]STOCOU
    Filter [STO]
    Columns [STO]
Endif
[M:STQ1]NBLIG     += 1
Return


$NEWLINE_SMP
nolign += 1
WLOT = [F:QLD]LOT
If [F:ITF]SMPMOD = 2
   LLOT = [F:QLD]LOT
Else
   Raz LLOT
Endif
# lecture STOQLYSMP (resultat echantillonnage)
Read [SMP]SMP0=[M:STQ1]VCRTYP;[M:STQ1]VCRNUM;[M:STQ1]ITMREF;LLOT
If fstat
   Raz [F:SMP]
Endif
[M:STQ1]                     = [F:SMP]
[M:STQ1]                     = [F:QLD]
#                                                                                         # hcb 111781 deb
If dim([M:STQ1]ECCSAIFLG)>0
   [M:STQ1]ECCSAIFLG(nolign-1) = 1
Endif
#                                                                                         # hcb 111781 deb

[M:STQ1]NBVCRLIN (nolign-1)  = 1
[M:STQ1]MVTFLG(nolign-1)     = 1
[M:STQ1]IPTDAT(nolign-1)     = date$
If dim([M:STQ1]SERNUMDEP)>0
       [M:STQ1]SERNUMDEP(nolign-1)  = [F:QLD]SERNUM
Endif
If dim([M:STQ1]SERNUMFDEP)>0
       [M:STQ1]SERNUMFDEP(nolign-1) = [F:QLD]SERNUM
Endif
If [F:ITF]STOMGTCOD>1 | [F:ITM]EXYMGTCOD>1                  # hcb 61549
       If [F:STL]LOT<>[F:QLD]LOT | [F:STL]SLO<>[F:QLD]SLO
          Read [STL]STL0=[F:QLD]ITMREF;[F:QLD]LOT;[F:QLD]SLO
       Endif
       If [F:ITF]STOMGTCOD>2 & dim([M:STQ1]POT)>0
          [M:STQ1]POT(nolign-1) = ([F:ITF]STOMGTCOD=3)*[F:STL]POT/100+([F:ITF]STOMGTCOD=4)*[F:STL]ACT
       Elsif dim([M:STQ1]POT)>1
          [M:STQ1]POT(nolign-1) = 1
       Endif
       #-- Si géré avec péremption
       If [F:ITM]EXYMGTCOD>1
          If dim([M:STQ1]REFPER)>0
                 [M:STQ1]REFPER(nolign-1)=[F:STL]REFPER
          Endif
          If dim([M:STQ1]SHLDAT)>0
                 [M:STQ1]SHLDAT(nolign-1)=[F:STL]SHLDAT
          Endif
       Endif
       If dim([M:STQ1]BPSLOT)>0
              [M:STQ1]BPSLOT(nolign-1)=[F:STL]BPSLOT
       Endif
Endif
[M:STQ1]WSTOSEQ(nolign-1) = nolign
[M:STQ1]NBLIG     += 1

Return
#                                      hcb V6CQ

########################################################################
# RECSTO_MF
# Cherche pour une ligne de document donné si dans le détail de cette ligne:
#    - Le statut qualité est unique ou multiple
#    - Le type d'emplacement est unique ou multiple
#    - L'emplacement est unique ou multiple
#    - Désignation du mouvement unique.
# Cette fonction permet de faire apparaître un $ pour montrer la décomposition du champ
########################################################################
# Paramètres E : ABR  = Ecran "XYZ"
#              : FCY  = Site
#              : VCR  = Numéro document
#              : TYP  = Type de document
#              : NOL  = Indice de ligne dans le tableau du document (nolign-1)
#              : LSUP = Inutilisé (paramètre supplémentaire au cas où)
#
# Prérequis : Fichier STOJOU [STJ] ouvert
#             Fichier ITMMASTER [ITM] ouvert et positionné
#             Fichier ITMFACILIT [ITF] ouvert et positionné
########################################################################
Subprog RECSTO_MF (ABR,ITM,FCY,TYP,VCR,LIN,NOL,PSEQ,LSUP)
Value Char    ABR
Value Char    ITM
Value Char    FCY
Value Integer TYP
Value Char    VCR
Value Integer LIN
Value Integer NOL
Value Integer PSEQ
Value Char    LSUP

Local Char    LMABR(10)
Local Char    PSTA(GLONSTA)
Local Char    PPCU(GLONUOM)
Local Decimal PCOE
Local Decimal PQTYPCU
Local Decimal PQTYSTU
Local Char    PLOCTYP(GLONEMP)
Local Char    PLOC(GLONEMP)
Local Char    PWRH(GLONWRH)
Local Char    PSER(GLONSER)
Local Char    PSERF(GLONSER)
Local Char    PLPN                                       # hcb X3-77043
Local Char LSER(GLONSER),LSERF(GLONSER)

Local Integer I, J
Local Integer LRET
Local Integer LNBSTJ
Local Integer LNBDET, LNBEG

Local Shortint CWRH    # 1=vérifie la décomposition en plusieurs depots
Local Shortint CLOC    # 1=vérifie la décomposition en plusieurs emplacements
Local Shortint CLPN    # 1=vérifie la décomposition en plusieurs contenants                # hcb X3-77043
Local Shortint CSER    # 1=vérifie la décomposition en n° série discontinus

Local Char CAR(1) : CAR = "$"

############
# Init des variables locales
LMABR  = "[M:"+ABR+"]"

Raz I,J
Raz PSTA
Raz PPCU
Raz PCOE
Raz PQTYPCU
Raz PQTYSTU
Raz PLOC
Raz PWRH
Raz PLOCTYP
Raz PSER
Raz PLPN                                               # hcb X3-77043

I = find(PSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))
If I>0
    I-=1
    PPCU    = [M:SGW]WPCUDES(I)
    PCOE    = [M:SGW]WCOEDES(I)
    PSTA    = [M:SGW]WSTADES(I)
    PLOCTYP = [M:SGW]WLOCTYPDES(I)
    PLOC    = [M:SGW]WLOCDES(I)
    PLPN    = [M:SGW]WLPNNUMDES(I)                      # hcb X3-77073
    PWRH    = [M:SGW]WWRHDES(I)
    LNBDET = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ))
    LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WPCUDES(indcum)=PPCU) )
    If LNBEG<>LNBDET
        PPCU = CAR
    Endif
    LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WCOEDES(indcum)=PCOE) )
    If LNBEG<>LNBDET
        PCOE = 0
    Endif
    LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WSTADES(indcum)=PSTA) )
    If LNBEG<>LNBDET
        PSTA = CAR
    Endif
    If PLOCTYP<>""
        LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLOCTYPDES(indcum)=PLOCTYP) )
        If LNBEG<>LNBDET
            PLOCTYP = CAR
        Endif
        LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLOCDES(indcum)=PLOC) )
        If LNBEG<>LNBDET
            PLOC = CAR
        Endif
        LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLPNNUMDES(indcum)=PLPN) )    # hcb X3-77043
        If LNBEG<>LNBDET                                                                                     # hcb X3-77043
            PLPN = CAR                                                                                       # hcb X3-77043
        Endif                                                                                                # hcb X3-77043
        LNBEG  = sigma( I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WWRHDES(indcum)=PWRH) )
        If LNBEG<>LNBDET
            PWRH = CAR
        Endif
    Endif
Endif

If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
If !clalev([F:STC]) : Local File STOLOC     [STC] : Endif

If !clalev([F:ITF])
    Local File ITMFACILIT [ITF]
    Read [ITF]ITF0=ITM;FCY
Elsif [F:ITF]ITMREF<>ITM |  [F:ITF]STOFCY<>FCY
    Read [ITF]ITF0=ITM;FCY
Endif
CLOC = evalue("dim("+LMABR+"LOC)")>0 & [F:ITF]LOCMGTCOD = 2
CLPN = evalue("dim("+LMABR+"LPNNUM)")>0 & [F:ITF]LPNMGTCOD = 2                       # hcb X3-77073
CWRH = evalue("dim("+LMABR+"WRH)")>0 & [F:ITF]LOCMGTCOD = 2
If evalue("dim("+LMABR+"SERNUMDEP)")>0
    LSER  = evalue(LMABR+"SERNUMDEP(NOL)")
Endif
If evalue("dim("+LMABR+"SERNUMFDEP)")>0
    LSERF = evalue(LMABR+"SERNUMFDEP(NOL)")
Endif
CSER = evalue("dim("+LMABR+"SERNUM)")>0 & LSER<>""

################################
# Recherche pour STA, LOC et PCU
If evalue("dim("+LMABR+"SERNUM)")>0 & evalue(LMABR+"SERNUM(NOL)") = evalue(LMABR+"SERNUMF(NOL)")
    Filter [STJ] Where STOFCY = FCY
&                    & VCRTYP = TYP & VCRNUM = VCR & VCRLIN = LIN
&                    & REGFLG <> 2
&                    & QTYSTU > 0
&                    & pat(STA,"Q*")<>1
Else
    Filter [STJ] Where STOFCY = FCY
&                    & VCRTYP = TYP & VCRNUM = VCR
&                    & REGFLG <> 2
&                    & QTYSTU > 0
&                    & pat(STA,"Q*")<>1
&                    & SERNUM  >= LSER
&                    & SERNUM  <= LSERF
&                    & len(SERNUM) = len(LSER)
Endif
For [STJ] Hint Key STJ1
    PQTYPCU += [F:STJ]QTYPCU
    PQTYSTU += [F:STJ]QTYSTU
    If [F:STJ]STA <> PSTA
        PSTA = CAR
    Endif
    If [F:STJ]PCU <> PPCU
        PPCU = CAR
    Endif
    If [F:STJ]PCUSTUCOE <> PCOE
        PCOE = 0
    Endif
    If CLOC
        If [F:STJ]LOC <> PLOC
            PLOC = CAR
            If PLOCTYP<>CAR
                Read [STC]STC0=FCY;[F:STJ]LOC
                If !fstat
                    If [F:STC]LOCTYP <> PLOCTYP
                        PLOCTYP = CAR
                    Endif
                Endif
            Endif
        Endif
    Endif
    If CLPN                                                           # hcb X3-77073
       If [F:STJ]LPNNUM <> PLPN                                       # hcb X3-77073
          PLPN = CAR                                                  # hcb X3-77073
       Endif                                                          # hcb X3-77073
    Endif                                                             # hcb X3-77073
    If CWRH
        If [F:STJ]WRH <> PWRH
            PWRH = CAR
        Endif
    Endif
    If CSER & PSER<>CAR
        Call PLUS_UN(PSER,PSER,LRET) From STKLIB
        If PSER<>[F:STJ]SERNUM
            PSER = CAR
        Endif
    Endif
    LNBSTJ += 1
Next
If CSER & LNBDET>1
    Local Char LTABSER(GLONSER)(LNBDET+LNBSTJ)
    Local Char LTABSERF(GLONSER)(LNBDET+LNBSTJ)
    If [M:SGW]WSERNUM(I)<>""
        For J=0 To LNBDET-1
            LTABSER(J)  = [M:SGW]WSERNUM(I+J)
            LTABSERF(J) = [M:SGW]WSERNUMF(I+J)
        Next
    Endif
    For [STJ] Hint Key STJ1
        LTABSER(J)  = [F:STJ]SERNUM
        LTABSERF(J) = [F:STJ]SERNUM
        J+=1
    Next

    Sorta LTABSER, LTABSERF
    PSER  = LTABSER(0)
    PSERF = LTABSERF(0)
    For J=1 To LNBDET+LNBSTJ-1
        Call PLUS_UN(LTABSERF(J-1),LTABSERF(J-1), LRET) From STKLIB
        If LTABSER(J) <> LTABSERF(J-1)
            PSERF = CAR
            Break
        Else
            PSERF = LTABSERF(J)
        Endif
    Next
Endif

Filter [STJ]

Assign LMABR+"STADES(NOL)" With PSTA

Assign LMABR+"PCUDES(NOL)" With PPCU
If PPCU=CAR | PCOE=0
    Assign LMABR+"QTYPCUDES(NOL)" With 0
    Assign LMABR+"COEDES(NOL)"    With 0
Else
    Assign LMABR+"COEDES(NOL)" With PCOE
    Assign LMABR+"QTYPCUDES(NOL)" With PQTYPCU
Endif
Assign LMABR+"QTYSTUDES(NOL)" With PQTYSTU

If CLOC=1 & evalue("dim("+LMABR+"LOCTYPDES)")>0
    Assign LMABR+"LOCTYPDES(NOL)" With PLOCTYP
    Assign LMABR+"LOCDES(NOL)" With PLOC
Endif
If CLPN=1 & evalue("dim("+LMABR+"LPNNUMDES)")>0                           # hcb X3-77043
    Assign LMABR+"LPNNUMDES(NOL)" With PLPN                               # hcb X3-77043
Endif                                                                     # hcb X3-77043
If CWRH=1 & evalue("dim("+LMABR+"WRHDES)")>0
    Assign LMABR+"WRHDES(NOL)" With PWRH
Endif

If CSER=1 & evalue("dim("+LMABR+"SERNUM)")>0
    Assign LMABR+"SERNUM(NOL)" With PSER
    Assign LMABR+"SERNUMF(NOL)" With PSERF
Endif


End

###############################################################################
# ALISTW : Alimente le masque STOWORK et effectue la mise à jour des tables stock
###############################################################################
# Paramètres E : PNOL = indice de la ligne en cours d'enregistrement
###############################################################################
Subprog ALISTW( PNOL )
Value Integer PNOL

Local Decimal LQTA
Local Decimal LSHT
Local Integer LRET
Local Integer LNBR, LNBJ
Local Integer K                        # hcb 50343
Local Integer Y                        # hcb 50343
Local Integer WSTOSEQSTQ               # hcb 50343
Local Integer WSTOSEQSGW               # hcb 50343
WSTOSEQSTQ  = [M:STQ1]WSTOSEQ(PNOL)    # hcb 50343
Raz   WSTOSEQSGW                       # hcb 50343
If [F:ITF]SMPTYP > 1                   # hcb V6CQ
   LNB = [M:STQ1]NBVCRLIN(PNOL)        # hcb V6CQ
   Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]SAVWSTOSEQ(indice),[M:SGW]WSTOSEQ (indice)   # hcb 50343
Else                                    # hcb V6CQ
# hcb                                                                              # hcb  95904  deb
    LNB = (dim([M:STQ1]SERNUM)>0 & [M:STQ1]SERNUM(PNOL)<>"")*([M:STQ1]QTYSTUDES(PNOL)-[M:STQ1]WSTJQTY(PNOL))
&       +(dim([M:STQ1]SERNUM)<=0 | [M:STQ1]SERNUM(PNOL)="")
#   LNB = 1
# hcb                                                                              # hcb  95904  fin
Endif
                                # hcbV6CQ
LLIGW=find([M:STQ1]WSTOSEQ(PNOL),[M:SGW]SAVWSTOSEQ)-1
If LLIGW<0 : End : Endif
For I=0 To LNB-1
    Raz [STW]
    # Initialisation de l'en-tête
    [M:STW]STOFCY         = [M:STQ1]STOFCY          # Site
    [M:STW]TRSTYP         = [M:STQ1]TRSTYP          # Type mouvement (M.704)
    [M:STW]VCRTYP         = [M:STQ1]VCRTYP          # Type pièce (M.701)
    [M:STW]VCRNUM         = [M:STQ1]VCRNUM          # Numéro pièce
    [M:STW]ITMREF         = [M:STQ1]ITMREF          # Article
    [M:STW]TRSFAM         = [M:STQ1]TRSFAM          # Famille mouvement
    [M:STW]IPTDAT         = [M:STQ1]IPTDAT   (PNOL) # Date imputation
    [M:STW]TRSCOD         = [M:STQ1]TRSCOD          # Code mouvement
    [M:STW]VCRTYPORI      = [M:STQ1]VCRTYPORI
    [M:STW]VCRNUMORI      = [M:STQ1]VCRNUMORI
    [M:STW]VCRLINORI      = [M:STQ1]VCRLINORI(PNOL)
#                                                          hcb 50346 deb
    Raz Y
    Raz K
    If [F:ITF]SMPTYP > 1 & WSTOSEQSGW <> 0
       Y = sigma(0,[M:SGW]NBLIG-1,(indcum+1)*([M:SGW]SAVWSTOSEQ(indcum)=WSTOSEQSTQ & [M:SGW]WSTOSEQ(indcum)>WSTOSEQSGW & (K=0 & sigma(K=1,1,1))))
       If Y>0
          Y-=1
       Endif
       If Y >= I
          Y -= I
       Endif
       WSTOSEQSGW = [M:SGW]WSTOSEQ   (LLIGW+I+Y)
    Endif
    [M:STW]VCRLIN         = [M:SGW]WSTOSEQ   (LLIGW+I+Y)# Numero ligne pièce (c'est bien wstoseq de SGW qu'il faut prendre, Cf ruse SUBSTQA)
    [M:STQ1]WSTOSEQ(PNOL) = [M:SGW]WSTOSEQ   (LLIGW+I+Y)

    Call ALISTOWORK( 7, [M:SGW]WSTOSEQ(LLIGW+I+Y), LQTA, LSHT, LNBR, LNBJ, LRET ) From STKINT
#                                                          hcb 50346 fin

    If !LRET
        Call MAJ_STOCK From STKMAJ
        If GOK & find([M:STQ1]VCRTYPORI,10,15)
            Call MAJ_OF ([M:STW]AAAQTY,[M:STW]RRRQTY,[M:STQ1]VCRTYPORI,[M:STQ1]VCRNUMORI,[M:STQ1]VCRLINORI(PNOL)) From  MTKLIB
        Endif
    Else
        GOK = 0
    Endif

Next
[M:STQ1]WSTOSEQ(PNOL) = [M:SGW]SAVWSTOSEQ(LLIGW)


End


##################################################
# STKCOPLIN : Copie la valeur en cours (AZC) du champ en cours (NOMZON)
#             sur toutes les lignes qui suivent
##################################################
# Les champs PCUDES, STADES ou LOCDES peuvent être copiés
# La variable de bas de tableau s'appelle NBLIG
# Le type d'emplacement LOCTYPDES
##################################################
Subprog STKCOPLIN(AZC,NOMZON,NOLIG)
Value    Char    AZC
Value    Char    NOMZON
Value    Integer NOLIG

Local Integer I
Local Shortint LSRET, LCOPOK
Local Char     MSKCOU(10) : MSKCOU = func STKLIB.MSKDEF
Local Char     LABR(10)   : LABR = mid$(MSKCOU,2,len(MSKCOU)-2)
Local Decimal  LQTYSTU, LSAVQTYSTU, LCOE, LQTY
Local Char     PCU(GLONUOM), LSTA(GLONSTA), LLOC(GLONLOC), LLOCTYP(GLONTLO), LWRH(GLONWRH) ,LLPN(GLONLPN)    # hcb X3-77043

    For I=NOLIG+1 To [M]NBLIG-1
        Raz LCOPOK
        nolign = I+1
        Call C_NBLIG From SUBSTQ
        #--- On ne fait la copie que sur des lignes à 1 seul détail ---#
        If !mkstat & [M]WSTOSEQ(I)=0 | func SUBSCSB.CALCNBDET([M]WSTOSEQ(I))<=1
            LQTYSTU = [M]QTYSTUDES(I)+([M]QTYSTUDES(I)=0)*[M]QTYSTU(I)
            LPCU    = [M]PCUDES(I)
            LCOE    = [M]COEDES(I)+([M]COEDES(I)=0)
            LSTA    = [M]STADES(I)
            If evalue("dim("+MSKCOU+"LOCDES)")>0
                LLOC    = [M]LOCDES(I)
                If evalue("dim("+MSKCOU+"LOCDES)")>0
                    LLOCTYP = [M]LOCTYPDES(I)
                Endif
            Endif
            If evalue("dim("+MSKCOU+"LPNNUMDES)")>0                     # hcb X3-77043
                LLPN    = [M]LPNNUMDES(I)                               # hcb X3-77043
            Endif                                                       # hcb X3-77043
            If evalue("dim("+MSKCOU+"WRHDES)")>0
                LWRH    = [M]WRHDES(I)
            Endif
            Case NOMZON
                When "PCUDES" : LPCU = AZC
                When "COEDES" : LCOE = val(AZC)+(val(AZC)=0)
                When "STADES" : LSTA = AZC
                When "LOCDES" : LLOC = AZC
                When "LPNNUMDES" : LLPN = AZC                           # hcb X3-77043
                When "WRHDES" : LWRH = AZC
            Endcase
            LQTY = LQTYSTU/LCOE
            Gosub COP_CHP From SUBSQC
        Endif
    Next
nolign = NOLIG+1
End

############################################################
# Renseigne le complément lot dans le masque STOCHGW [SGW]
############################################################
Subprog SETCPTLOT(PABR, PITM, PLIG, PLIGW)
Value Char PABR
Value Char PITM      # FGR 18/01/2010 : X3SUIVI60986
Value Integer PLIG   # FGR 18/01/2010 : X3SUIVI60986
Value Integer PLIGW  # FGR 18/01/2010 : X3SUIVI60986

Local Char    LLOT(GLONLOT)
Local Char    LSLO(GLONSLO)
Local Integer I
Local Integer WCHARGE                        # hcb unicite
Local Integer Z                              # hcb unicite
#                                                          # hcb 110327 deb
Raz LLOT, LSLO
If PABR = "STQ1"
   If evalue("dim([M:"+PABR+"]LOT(PLIG))") > 0
      LLOT = evalue("[M:"+PABR+"]LOT(PLIG)")
      If evalue("dim([M:"+PABR+"]SLO(PLIG))") > 0
         LSLO = evalue("[M:"+PABR+"]SLO(PLIG)")
      Endif
   Endif
Else
   If evalue("dim([M:"+PABR+"]LOT)") > 0
      LLOT = evalue("[M:"+PABR+"]LOT")
      If evalue("dim([M:"+PABR+"]SLO)") > 0
         LSLO = evalue("[M:"+PABR+"]SLO")
      Endif
   Endif
Endif
#                                                          # hcb 110327 end

If evalue("dim([M:"+PABR+"]LOT(PLIG))") > 0
   LLOT = evalue("[M:"+PABR+"]LOT(PLIG)")
   If evalue("dim([M:"+PABR+"]SLO(PLIG))") > 0
      LSLO = evalue("[M:"+PABR+"]SLO(PLIG)")
   Else
      Raz LSLO
   Endif
Else
   Raz LLOT, LSLO
Endif
If LLOT=""    # Pas de complément lot pour le lot blanc
    [M:SGW]NUMLIGLOT(PLIGW) = -1
    End
Endif

If (PABR="SQD"  & [M:SQD]VALIDE=2)                       # hcb 60887

#--- Bug 28543 --- TS le 14.02.05

    LLIGW = sigma(0,[M:SGW]NBLIGLOT-1, (indcum+1)*(
&                                      I=0
&                                    & [M:SGW]LOT(indcum) = LLOT
&                                    & [M:SGW]SLO(indcum) = LSLO
&                                    & sigma(I=1,1,1)) )
    If LLIGW
        [M:SGW]NUMLIGLOT(PLIGW) = LLIGW-1
        [M:SGW]BPSLOT    (LLIGW-1)  = [M:SQD]BPSLOT
        [M:SGW]POT       (LLIGW-1)  = [M:SQD]POT
        [M:SGW]ACT       (LLIGW-1)  = [M:SQD]ACT
        [M:SGW]SHL       (LLIGW-1)  = [M:SQD]SHL
        [M:SGW]SHLDAT    (LLIGW-1)  = [M:SQD]SHLDAT
        [M:SGW]SHLUOM    (LLIGW-1)  = [M:SQD]SHLUOM             # hcb V6per
        [M:SGW]SHLLTI    (LLIGW-1)  = [M:SQD]SHLLTI             # hcb V6per
        [M:SGW]SHLLTIUOM (LLIGW-1)  = [M:SQD]SHLLTIUOM          # hcb V6per
        [M:SGW]NEWLTIDAT (LLIGW-1)  = [M:SQD]NEWLTIDAT          # hcb V6per
        [M:SGW]DLU       (LLIGW-1)  = [M:SQD]DLU                # hcb V6per
        [M:SGW]DLUDAT    (LLIGW-1)  = [M:SQD]DLUDAT             # hcb V6per
        [M:SGW]REFPER    (LLIGW-1)  = [M:SQD]REFPER
        [M:SGW]USRFLD1   (LLIGW-1)  = [M:SQD]USRFLD1
        [M:SGW]USRFLD2   (LLIGW-1)  = [M:SQD]USRFLD2
        [M:SGW]USRFLD3   (LLIGW-1)  = [M:SQD]USRFLD3
        [M:SGW]USRFLD4   (LLIGW-1)  = [M:SQD]USRFLD4
#                                                                                         # hcb 111781 deb
        If dim([M:SQD]ECCVALMAJ)>0                                       # hcb 117334
           [M:SGW]ECCVALMAJ(LLIGW-1)= [M:SQD]ECCVALMAJ
        Endif
        If dim([M:SQD]ECCVALMIN)>0                                       # hcb 117334
           [M:SGW]ECCVALMIN(LLIGW-1)= [M:SQD]ECCVALMIN
        Endif
        If dim([M:SGW]ECCSAIFLG)>0
           [M:SGW]ECCSAIFLG(LLIGW-1) = 1
        Endif
#                                                                                         # hcb 111781 deb
        [M:SGW]VALIDE(LLIGW-1)  = 2
        [M:SGW]MODIF(LLIGW-1)   = 2
    Else
        [M:SGW]LOT       ([M:SGW]NBLIGLOT)     = [M:SQD]LOT
        If LSLO<>""
           [M:SGW]SLO    ([M:SGW]NBLIGLOT) = [M:SQD]SLO
        Else
           [M:SGW]SLO    ([M:SGW]NBLIGLOT) = ""
        Endif
        [M:SGW]BPSLOT    ([M:SGW]NBLIGLOT) = [M:SQD]BPSLOT
        [M:SGW]POT       ([M:SGW]NBLIGLOT) = [M:SQD]POT
        [M:SGW]ACT       ([M:SGW]NBLIGLOT) = [M:SQD]ACT
        [M:SGW]SHL       ([M:SGW]NBLIGLOT) = [M:SQD]SHL
        [M:SGW]SHLDAT    ([M:SGW]NBLIGLOT) = [M:SQD]SHLDAT
        [M:SGW]SHLUOM    ([M:SGW]NBLIGLOT) = [M:SQD]SHLUOM             # hcb V6per
        [M:SGW]SHLLTI    ([M:SGW]NBLIGLOT) = [M:SQD]SHLLTI             # hcb V6per
        [M:SGW]SHLLTIUOM ([M:SGW]NBLIGLOT) = [M:SQD]SHLLTIUOM          # hcb V6per
        [M:SGW]NEWLTIDAT ([M:SGW]NBLIGLOT) = [M:SQD]NEWLTIDAT          # hcb V6per
        [M:SGW]DLU       ([M:SGW]NBLIGLOT) = [M:SQD]DLU                # hcb V6per
        [M:SGW]DLUDAT    ([M:SGW]NBLIGLOT) = [M:SQD]DLUDAT             # hcb V6per
        [M:SGW]REFPER    ([M:SGW]NBLIGLOT) = [M:SQD]REFPER
        [M:SGW]USRFLD1   ([M:SGW]NBLIGLOT) = [M:SQD]USRFLD1
        [M:SGW]USRFLD2   ([M:SGW]NBLIGLOT) = [M:SQD]USRFLD2
        [M:SGW]USRFLD3   ([M:SGW]NBLIGLOT) = [M:SQD]USRFLD3
        [M:SGW]USRFLD4   ([M:SGW]NBLIGLOT) = [M:SQD]USRFLD4
#                                                                                         # hcb 111781 deb
        If dim([M:SQD]ECCVALMAJ)>0                                 # hcb 117334
           [M:SGW]ECCVALMAJ([M:SGW]NBLIGLOT)= [M:SQD]ECCVALMAJ
        Endif
        If dim([M:SQD]ECCVALMIN)>0                                 # hcb 117334
           [M:SGW]ECCVALMIN([M:SGW]NBLIGLOT)= [M:SQD]ECCVALMIN
        Endif
        If dim([M:SGW]ECCSAIFLG)>0
           [M:SGW]ECCSAIFLG([M:SGW]NBLIGLOT) = 1
        Endif
#                                                                                         # hcb 111781 deb

        [M:SGW]VALIDE     ([M:SGW]NBLIGLOT)   = 2
        [M:SGW]MODIF      ([M:SGW]NBLIGLOT)   = 2
        [M:SGW]NUMLIGLOT  (PLIGW)             = [M:SGW]NBLIGLOT
        [M:SGW]NBLIGLOT   += 1
    Endif
Else
    LLIGW = sigma(0,[M:SGW]NBLIGLOT-1, (indcum+1)*(
&                                      I=0
&                                    & [M:SGW]LOT(indcum) = LLOT
&                                    & [M:SGW]SLO(indcum) = LSLO
&                                    & sigma(I=1,1,1)) )
    If LLIGW
        [M:SGW]NUMLIGLOT(PLIGW) = LLIGW-1
    Else
#                      hcb unicite deb
       Raz WCHARGE
       If dim([M:SGW]SLO)>0 & GFEALOTLEV = 2 & [F:ITM]LOTMGTCOD = 4
           Raz Z
           Z = sigma(0,[M:SGW]NBLIG-1,(indcum+1)*([M:SGW]WSTOSEQ(indcum)<>0 & [M:SGW]LOT(indcum) = LLOT &
&                    Z=0 & sigma(Z=1,1,1)))

           If Z <> 0
              Z  -=1
              [M:SGW]LOT       ([M:SGW]NBLIGLOT) = [M:SGW]LOT       (Z)
              [M:SGW]SLO       ([M:SGW]NBLIGLOT) = [M:SGW]SLO       (Z)
              [M:SGW]BPSLOT    ([M:SGW]NBLIGLOT) = [M:SGW]BPSLOT    (Z)
              [M:SGW]POT       ([M:SGW]NBLIGLOT) = [M:SGW]POT       (Z)
              [M:SGW]ACT       ([M:SGW]NBLIGLOT) = [M:SGW]ACT       (Z)
              [M:SGW]SHL       ([M:SGW]NBLIGLOT) = [M:SGW]SHL       (Z)
              [M:SGW]SHLDAT    ([M:SGW]NBLIGLOT) = [M:SGW]SHLDAT    (Z)
              [M:SGW]SHLUOM    ([M:SGW]NBLIGLOT) = [M:SGW]SHLUOM    (Z)
              [M:SGW]SHLLTI    ([M:SGW]NBLIGLOT) = [M:SGW]SHLLTI    (Z)
              [M:SGW]SHLLTIUOM ([M:SGW]NBLIGLOT) = [M:SGW]SHLLTIUOM (Z)
              [M:SGW]NEWLTIDAT ([M:SGW]NBLIGLOT) = [M:SGW]NEWLTIDAT (Z)
              [M:SGW]DLU       ([M:SGW]NBLIGLOT) = [M:SGW]DLU       (Z)
              [M:SGW]DLUDAT    ([M:SGW]NBLIGLOT) = [M:SGW]DLUDAT    (Z)
              [M:SGW]REFPER    ([M:SGW]NBLIGLOT) = [M:SGW]REFPER    (Z)
              [M:SGW]USRFLD1   ([M:SGW]NBLIGLOT) = [M:SGW]USRFLD1   (Z)
              [M:SGW]USRFLD2   ([M:SGW]NBLIGLOT) = [M:SGW]USRFLD2   (Z)
              [M:SGW]USRFLD3   ([M:SGW]NBLIGLOT) = [M:SGW]USRFLD3   (Z)
              [M:SGW]USRFLD4   ([M:SGW]NBLIGLOT) = [M:SGW]USRFLD4   (Z)
#                                                                                         # hcb 111781 deb
              If dim([M:SGW]ECCVALMAJ)>0
                 [M:SGW]ECCVALMAJ([M:SGW]NBLIGLOT)= [M:SGW]ECCVALMAJ(Z)
              Endif
              If dim([M:SGW]ECCVALMIN)>0
                 [M:SGW]ECCVALMIN([M:SGW]NBLIGLOT)= [M:SGW]ECCVALMIN(Z)
              Endif
              If dim([M:SGW]ECCSAIFLG)>0
                 [M:SGW]ECCSAIFLG([M:SGW]NBLIGLOT) = 1
              Endif
#                                                                                         # hcb 111781 deb

              [M:SGW]VALIDE    ([M:SGW]NBLIGLOT) = 2
              [M:SGW]MODIF     ([M:SGW]NBLIGLOT) = 2
              [M:SGW]NUMLIGLOT(PLIGW) = [M:SGW]NBLIGLOT
              [M:SGW]NBLIGLOT += 1
              WCHARGE = 1
           Endif
        Endif
        If WCHARGE = 0
#                      hcb unicite fin

           Read [STL]STL0=PITM;LLOT;LSLO
           If fstat
               Call FSTA("STL") From GLOCK
               [M:SGW]NUMLIGLOT(PLIGW) = -1
               End
           Endif
           [M:SGW]LOT       ([M:SGW]NBLIGLOT) = [F:STL]LOT
           [M:SGW]SLO       ([M:SGW]NBLIGLOT) = [F:STL]SLO
           [M:SGW]BPSLOT    ([M:SGW]NBLIGLOT) = [F:STL]BPSLOT
           [M:SGW]POT       ([M:SGW]NBLIGLOT) = [F:STL]POT
           [M:SGW]ACT       ([M:SGW]NBLIGLOT) = [F:STL]ACT
           [M:SGW]SHL       ([M:SGW]NBLIGLOT) = [F:STL]SHL
           [M:SGW]SHLDAT    ([M:SGW]NBLIGLOT) = [F:STL]SHLDAT
           [M:SGW]SHLUOM    ([M:SGW]NBLIGLOT) = [F:STL]SHLUOM             # hcb V6per
           [M:SGW]SHLLTI    ([M:SGW]NBLIGLOT) = [F:STL]SHLLTI             # hcb V6per
           [M:SGW]SHLLTIUOM ([M:SGW]NBLIGLOT) = [F:STL]SHLLTIUOM          # hcb V6per
           [M:SGW]NEWLTIDAT ([M:SGW]NBLIGLOT) = [F:STL]NEWLTIDAT          # hcb V6per
           [M:SGW]DLU       ([M:SGW]NBLIGLOT) = [F:STL]DLU                # hcb V6per
           [M:SGW]DLUDAT    ([M:SGW]NBLIGLOT) = [F:STL]DLUDAT             # hcb V6per
           [M:SGW]REFPER    ([M:SGW]NBLIGLOT) = [F:STL]REFPER
           [M:SGW]USRFLD1   ([M:SGW]NBLIGLOT) = [F:STL]USRFLD1
           [M:SGW]USRFLD2   ([M:SGW]NBLIGLOT) = [F:STL]USRFLD2
           [M:SGW]USRFLD3   ([M:SGW]NBLIGLOT) = [F:STL]USRFLD3
           [M:SGW]USRFLD4   ([M:SGW]NBLIGLOT) = [F:STL]USRFLD4
#                                                                                         # hcb 111781 deb
           If dim([F:STL]ECCVALMAJ)>0                                  # hcb 117334
              [M:SGW]ECCVALMAJ([M:SGW]NBLIGLOT)= [F:STL]ECCVALMAJ
           Endif
           If dim([F:STL]ECCVALMIN)>0                                  # hcb 117334
              [M:SGW]ECCVALMIN([M:SGW]NBLIGLOT)= [F:STL]ECCVALMIN
           Endif
           If dim([M:SGW]ECCSAIFLG)>0
              [M:SGW]ECCSAIFLG([M:SGW]NBLIGLOT) = 1
           Endif
#                                                                                         # hcb 111781 deb

           [M:SGW]VALIDE    ([M:SGW]NBLIGLOT) = 2
           [M:SGW]MODIF     ([M:SGW]NBLIGLOT) = 2
#  hcb  90247  deb
           If [F:ITM]ITMREF<>PITM
              Read [ITM]ITM0=PITM
              If fstat
                 Raz [F:ITM]
              Endif
           Endif
           If evalue("dim([M:"+PABR+"]IPTDAT(PLIG))") > 0
              [F:STL]LTIDAT = evalue("[M:"+PABR+"]IPTDAT(PLIG)")
           Else
              [F:STL]LTIDAT = date$
           Endif
         Call CALLTI([F:ITM]EXYMGTCOD,[F:STL]LTIDAT,[F:STL]SHLLTI ,[F:STL]SHLLTIUOM,"",[M:SGW]NEWLTIDAT ([M:SGW]NBLIGLOT)) From STKLIB
#        si date recontrole > date limite utilisation : date recontrole = date limite utilisation
         If [M:SGW]NEWLTIDAT ([M:SGW]NBLIGLOT) <> [31/12/2999]     # date recontrole
            If [M:SGW]NEWLTIDAT ([M:SGW]NBLIGLOT) > [F:STL]DLUDAT
               [M:SGW]NEWLTIDAT ([M:SGW]NBLIGLOT) = [F:STL]DLUDAT
            Endif
         Endif
#  hcb  90247  fin

           [M:SGW]NUMLIGLOT(PLIGW) = [M:SGW]NBLIGLOT
           [M:SGW]NBLIGLOT += 1
        Endif
    Endif
Endif

End

################################################################
# Met à jour CRDSEQ et CRDFLG dans STOQLYD
#---------------------------------------------------------------
# nolign doit être positionné sur la ligne concernée
################################################################
$MAJ_CRDQLD
#                                                           hcb V6CQ deb
Local Char    WLOT(GLONLOT)          # hcb 67198
Raz WLOT                             # hcb 67198
If dim([M:STQ1]LOT)>0                # hcb 67198
   WLOT = [M:STQ1]LOT(nolign-1)
Endif

If [F:ITF]SMPTYP > 1
   If [F:ITF]SMPMOD = 2
      Columns [QLD] (CRDSEQ,CRDFLG)
      Filter [QLD] Where VCRTYP    = [M:STQ1]VCRTYP
&                      & VCRNUM    = [M:STQ1]VCRNUM
&                      & LOT       = WLOT
&                  Order By Key QLD2
   Else
      Filter [QLD] Where VCRTYP    = [M:STQ1]VCRTYP
&                      & VCRNUM    = [M:STQ1]VCRNUM
&                  Order By Key QLD0
   Endif
   For [QLD]
       Readlock [QLD] Curr
       [F:QLD]CRDSEQ = [M:STQ1]CRDSEQ(nolign-1)
       [F:QLD]CRDFLG = [M:STQ1]CRDFLG(nolign-1)
       Rewrite [QLD]
       If fstat
          GOK = 0
          Call FSTA("QLD") From GLOCK
          Break
       Endif
   Next
   Columns [QLD]
   Filter [QLD]

Else
#                                                           hcb V6CQ fin
   If dim([M:STQ1]SERNUMDEP(nolign-1))>0 & [M:STQ1]SERNUMDEP(nolign-1)<>""
      Columns [QLD] (CRDSEQ,CRDFLG)
      Filter [QLD] Where VCRTYP      =  [M:STQ1]VCRTYP
&                      & VCRNUM      =  [M:STQ1]VCRNUM
&                      & SERNUM      >= [M:STQ1]SERNUMDEP    (nolign-1)
&                      & SERNUM      <= [M:STQ1]SERNUMFDEP   (nolign-1)
&                      & len(SERNUM) =  len([M:STQ1]SERNUMDEP(nolign-1))
      For [QLD]
          Readlock [QLD] Curr
          [F:QLD]CRDSEQ = [M:STQ1]CRDSEQ(nolign-1)
          [F:QLD]CRDFLG = [M:STQ1]CRDFLG(nolign-1)
          Rewrite [QLD]
          If fstat
             GOK = 0
             Call FSTA("QLD") From GLOCK
             Break
          Endif
      Next
      Columns [QLD]
      Filter [QLD]
   Else
      Readlock [QLD]QLD0 = [M:STQ1]VCRTYP;[M:STQ1]VCRNUM;[M:STQ1]VCRLIN(nolign-1)
      If fstat
         GOK=0
         Call FSTA("QLD") From GLOCK
         Return
      Endif
      [F:QLD]CRDSEQ = [M:STQ1]CRDSEQ(nolign-1)
      [F:QLD]CRDFLG = [M:STQ1]CRDFLG(nolign-1)
      Rewrite [QLD]
   Endif
Endif                                                         # hcb V6CQ
If GOK
  mkstat = 4
Endif
Return

################################################################
# Met à jour l'indicateur SAICOD
################################################################
Subprog MAJSAICOD(PNOL)
Value Integer PNOL
Local Char LCARCRD(1) : LCARCRD="F"    # Fiche qualité à renseigner
Local Char LCARSTJ(1) : LCARSTJ="+"    # Quantité restant à qualifier
Local Char LCARALL(1) : LCARALL="*"    # Tout a été renseigné
Local Char LCARBLO(1) : LCARBLO="R"    # Le statut ne peut être que R car blocage statut dû à une réponse hors standard
Local Char SVGSAICOD(1) : SVGSAICOD=[M:STQ1]SAICOD(PNOL)
If [F:ITF]SMPTYP > 1                                                        # hcb V6CQ
   LCARSTJ="E"                                                              # hcb V6CQ
Endif                                                                       # hcb V6CQ
Raz [M:STQ1]SAICOD(PNOL)
    Columns [QLA] (QSTNUM)
    GBLOSTA = 0
    #---- Recherche des réponses hors standard ----#
    Filter [QLA] Where QLYCTLDEM = [M:STQ1]VCRNUM
&                    & VCRLIN    = [M:STQ1]VCRLIN(PNOL)
&                    & CRDSEQ    = [M:STQ1]CRDSEQ(PNOL)
&                    & OSDASW    = 2
    Look [QLA]QLA0 First
    If !fstat
        For [QLA]
            For [QLQ] Where QSTNUM=[QLA]QSTNUM
                Case [F:QLQ]LOKTYP
                     When 3 : #--- Bloquage statut  => R obligatoire ----#
                             GBLOSTA = 1
                     When 4 : #--- Nouvelle fiche  => Création d'une nlle séquence de réponses ---#
                             GBLOSTA = 2 : Break 2
                Endcase
            Next
        Next
    Endif
    Filter [QLA]
    Columns [QLA]

    # Maj ecran STQ1  (hcb demande PE 37205)
    GPOINT="MAJ_STQ1" : Gosub ENTREE From EXEFNC

    If [M:STQ1]CRDFLG(PNOL) <> 2 & [M:STQ1]QLYCRD(PNOL)<>"" | GBLOSTA=2
        [M:STQ1]SAICOD(PNOL) = LCARCRD
    Else
# hcb V6CQ

        If (([F:ITF]SMPTYP > 1 & [M:STQ1]QTYSTUDES(PNOL) <> 0 ) |
&          ([M:STQ1]QTYSTU(PNOL) = [M:STQ1]QTYSTUDES(PNOL)) &
&          [M:STQ1]WSTOFLG(PNOL)=1) | [M:STQ1]WSTJQTY(PNOL)>=[M:STQ1]QTYSTU(PNOL)
           [M:STQ1]SAICOD(PNOL) = LCARALL
        Else
           [M:STQ1]SAICOD(PNOL) = LCARSTJ+string$(!!GBLOSTA,LCARBLO)
        Endif
    Endif
Affzo [M:STQ1]SAICOD(PNOL)
If [M:STQ1]WSTJQTY(PNOL)=[M:STQ1]QTYSTU(PNOL)
#    Diszo [M:STQ1]NBLIG(PNOL)                                          # hcb V6CQ
     Local Integer NOL
     NOL = PNOL
     Gosub DISZO_LIG From SUBSTQB
Endif
If [M:STQ1]UPDFLG(PNOL)=9
  [M:STQ1]UPDFLG(PNOL)=0
Else
    If [M:STQ1]SAICOD(PNOL)<>SVGSAICOD
      [M:STQ1]UPDFLG(PNOL)=1
    Endif
Endif
End

$DISZO_COL_AFF
    # Grisage des zones qui sont rendu visibles dynamiquement
    # et qui ne sont pas saisissables
    If dim([M:STQ1]LOT)>0
        Diszo [M:STQ1]LOT
    Endif
    If dim([M:STQ1]SLO)>0
        Diszo [M:STQ1]SLO
    Endif
    If dim([M:STQ1]REFPER)>0
        Diszo [M:STQ1]REFPER
    Endif
    If dim([M:STQ1]SHL)>0
        Diszo [M:STQ1]SHL
    Endif
    If dim([M:STQ1]SHLDAT)>0
        Diszo [M:STQ1]SHLDAT
    Endif
    If dim([M:STQ1]SERNUMDEP)>0
        Diszo [M:STQ1]SERNUMDEP
    Endif
    If dim([M:STQ1]SERNUMFDEP)>0    # Il faut faire Diszo, car s'il n'est pas rendu invisible ce champ devient saisissable à tort
        Diszo [M:STQ1]SERNUMFDEP
    Endif
    If dim([M:STQ1]SERNUMF)>0    # Il faut faire Diszo, car s'il n'est pas rendu invisible ce champ devient saisissable à tort
        Diszo [M:STQ1]SERNUMF
    Endif
    If dim([M:STQ1]LOCTYP)>0
        Diszo [M:STQ1]LOCTYP
    Endif
    If dim([M:STQ1]LOC)>0
        Diszo [M:STQ1]LOC
    Endif
    If dim([M:STQ1]LPNNUM)>0                               # hcb X3-77043
        Diszo [M:STQ1]LPNNUM                               # hcb X3-77043
    Endif                                                  # hcb X3-77043
    If dim([M:STQ1]WRH)>0
        Diszo [M:STQ1]WRH
    Endif
Return

Subprog DISZO_CHP_AFF( PNOL)
#----------------------------------------------------------------#
# Actzo ou diszo suivant présence du champs et autres conditions #
#----------------------------------------------------------------#
Value Integer PNOL
Local Integer LNBDET
#-- Recherche du nombre de détail
LNBDET = func SUBSCSB.CALCNBDET([M:STQ1]WSTOSEQ(PNOL))
#-- Si qté destination présente
If dim([M:STQ1]QTYSTUDES)>0
    #-- Si qté <>0 ou nbre détail >1
    If [M:STQ1]WSTJQTY(PNOL)<>0 | LNBDET>1
        Diszo [M:STQ1]QTYSTUDES(PNOL)
    Else
        Actzo [M:STQ1]QTYSTUDES(PNOL)
    Endif
Endif
#-- Si unité destination présente
If dim([M:STQ1]PCUDES)>0
    #-- Si qté <>0 ou nbre détail >1
    If [M:STQ1]WSTJQTY(PNOL)<>0 | LNBDET>1
        Diszo [M:STQ1]PCUDES(PNOL)
    Else
        Actzo [M:STQ1]PCUDES(PNOL)
    Endif
Endif
#-- Si coeff destination présent
If dim([M:STQ1]COEDES)>0
    #-- Si qté <>0 ou nbre détail >1
    If [M:STQ1]WSTJQTY(PNOL)<>0 | LNBDET>1
        Diszo [M:STQ1]COEDES(PNOL)
    Else
        Actzo [M:STQ1]COEDES(PNOL)
    Endif
Endif
#-- Si numéro série présent
If dim([M:STQ1]SERNUM)>0
    #-- Si qté <>0 ou nbre détail >1
    If [M:STQ1]WSTJQTY(PNOL)<>0 | LNBDET>1 | [M:STQ1]SERNUMDEP(PNOL)=""
        Diszo [M:STQ1]SERNUM(PNOL)
    Else
        Actzo [M:STQ1]SERNUM(PNOL)
    Endif
Endif
#-- Si statut destination présent
If dim([M:STQ1]STADES)>0
    #-- Si qté <>0 ou nbre détail >1
    If [M:STQ1]WSTJQTY(PNOL)<>0 | LNBDET>1
        Diszo [M:STQ1]STADES(PNOL)
    Else
        Actzo [M:STQ1]STADES(PNOL)
    Endif
Endif
#                                                            # hcb 77043 deb
#-- Si emplacement dest présent
If dim([M:STQ1]LPNNUMDES)>0
    #-- Si qté <>0 ou nbre détail >1
    If [M:STQ1]WSTJQTY(PNOL)<>0 | LNBDET>1
        Diszo [M:STQ1]LPNNUMDES(PNOL)
    Else
        Actzo [M:STQ1]LPNNUMDES(PNOL)
    Endif
Endif
#                                                            # hcb 77043 fin

#-- Si emplacement dest présent
If dim([M:STQ1]LOCDES)>0
    #-- Si qté <>0 ou nbre détail >1
    If [M:STQ1]WSTJQTY(PNOL)<>0 | LNBDET>1
        Diszo [M:STQ1]LOCDES(PNOL)
    Else
        Actzo [M:STQ1]LOCDES(PNOL)
    Endif
Endif
#-- Si depot dest présent
If dim([M:STQ1]WRHDES)>0
    #-- Si qté <>0 ou nbre détail >1
    If [M:STQ1]WSTJQTY(PNOL)<>0 | LNBDET>1
        Diszo [M:STQ1]WRHDES(PNOL)
    Else
        Actzo [M:STQ1]WRHDES(PNOL)
    Endif
Endif
#-- Si type d'emplacement dest présent
If dim([M:STQ1]LOCTYPDES)>0
    If [M:STQ1]WSTJQTY(PNOL)<>0 | LNBDET>1
        Diszo [M:STQ1]LOCTYPDES(PNOL)
    Else
        Actzo [M:STQ1]LOCTYPDES(PNOL)
    Endif
Endif
#-- Si date imputation présente
If dim([M:STQ1]IPTDAT)>0
#   If [M:STQ1]WSTJQTY(PNOL)<>0               # hcb 43378
    If [M:STQ1]VALFLG=2                       # hcb 43378
        Diszo [M:STQ1]IPTDAT(PNOL)
    Else
        Actzo [M:STQ1]IPTDAT(PNOL)
    Endif
Endif
#-- Si designation mouvement présent
If dim([M:STQ1]MVTDES)>0
    If [M:STQ1]WSTJQTY(PNOL)<>0
        Diszo [M:STQ1]MVTDES
    Else
        Actzo [M:STQ1]MVTDES
    Endif
Endif

End

###########################################################
# Recherche dans les réponses d'une fiche qualité
# si une réponse hors standard existe avec nécessité de saisir
# une nouvelle séquence de réponse (LOKTYP=4)
###########################################################
# Paramètres E : PQLYCRD = code fiche qualité
#                PVCRNUM = n° QC
#                PVCRLIN = n° ligne QC
#                PCRDSEQ = n° séquence de réponses
#            S :  0  = pas trouvé
#                >0  = trouvé
###########################################################
Funprog SEARCHOSDASW4(PQLYCRD, PVCRNUM, PVCRLIN, PCRDSEQ)
Value Char    PQLYCRD
Value Char    PVCRNUM
Value Integer PVCRLIN
Value Integer PCRDSEQ

Local Integer LFOUND : Raz LFOUND

#    #-- Il faut tester QSTNUM car il peut être vide (pour les textes)    # hcb V6CQ
#    Link [QLC] With [QLQ]QLQ0 = [QLC]QSTNUM                              # hcb V6CQ
#&              As [LNK]                                                  # hcb V6CQ
#&              Where [QLC]QLYCRD = PQLYCRD                               # hcb V6CQ
#&                  & [QLC]QSTNUM <> ""                                   # hcb V6CQ
#&                  & [QLQ]LOKTYP = 4                                     # hcb V6CQ
#    For [LNK]                                                            # hcb V6CQ
# QSTNUM    = [F:QLC]QSTNUM                                               # hcb V6CQ

Filter [QLA] Where QLYCTLDEM = PVCRNUM
&                & VCRLIN    = PVCRLIN
&                & CRDSEQ    = PCRDSEQ
&                & RPLQLYCRD <> ""
&                & OSDASW    = 2
Look [QLA]QLA0 First
Filter [QLA]
If !fstat
   LFOUND = 1
Endif
End LFOUND

###########################################################
# reecriture stoqlyd avec nouvelle fiche technique  hcb V6CQ
###########################################################
$NEW_QLYCRD
Local Char    WLOT(GLONLOT)          # hcb 67198
Raz WLOT                             # hcb 67198
If dim([M:STQ1]LOT)>0                # hcb 67198
   WLOT = [M:STQ1]LOT(NOL)
Endif



If [F:ITF]SMPTYP > 1
   If [F:ITF]SMPMOD = 2
      Filter [QLD] Where VCRTYP    = [M:STQ1]VCRTYP
&                      & VCRNUM    = [M:STQ1]VCRNUM
&                      & LOT       = WLOT
&                  Order By Key QLD2
   Else
      Filter [QLD] Where VCRTYP    = [M:STQ1]VCRTYP
&                      & VCRNUM    = [M:STQ1]VCRNUM
&                  Order By Key QLD0
   Endif
   Call DEBTRANS From GLOCK
   Trbegin [QLD]
   For [QLD]
#----  Enregistrement de la nouvelle fiche  ----#
       Readlock [QLD] Curr
       If fstat
          Call FSTA("QLD") From GLOCK
          GOK = 0
          Break
       Endif
       [F:QLD]QLYCRD = WQLYCRD
       Raz [F:QLD]CRDFLG
       Rewrite [QLD]
       If fstat
          Call FSTA("QLD") From GLOCK
          GOK = 0
          Break
       Endif
       [M:STQ1]SAICOD(NOL) = "F"
       [M:STQ1]QLYCRD(NOL) = WQLYCRD
       Affzo [M:STQ1]QLYCRD(NOL)
       Affzo [M:STQ1]SAICOD(NOL)
       Gosub DISZO_LIG From SUBSTQB
   Next
   Filter [QLD]
   If GOK
      Commit
   Else
      Rollback
   Endif
Else
   Call DEBTRANS From GLOCK
   Trbegin [QLD]
#---- Enregistrement de la nouvelle fiche  ----#
   Readlock [QLD]QLD0= [M:STQ1]VCRTYP;[M:STQ1]VCRNUM;[M:STQ1]VCRLIN(NOL)
   If fstat
      Call FSTA("QLD") From GLOCK
      GOK = 0
   Endif
   [F:QLD]QLYCRD = WQLYCRD
   Raz [F:QLD]CRDFLG
   Rewrite [QLD]
   If fstat
      Call FSTA("QLD") From GLOCK
      GOK = 0
   Endif
   [M:STQ1]SAICOD(NOL) = "F"
   [M:STQ1]QLYCRD(NOL) = WQLYCRD
   Affzo [M:STQ1]QLYCRD(NOL)
   Affzo [M:STQ1]SAICOD(NOL)
   Gosub DISZO_LIG From SUBSTQB
   If GOK
      Commit
   Else
      Rollback
   Endif
Endif

Return

$DISZO_LIG
Diszo [M:STQ1]QTYSTUDES    (NOL)
Diszo [M:STQ1]PCUDES       (NOL)
Diszo [M:STQ1]COEDES       (NOL)
If dim([M:STQ1]SERNUM) > 0
   Diszo [M:STQ1]SERNUM    (NOL)
   Diszo [M:STQ1]SERNUMF   (NOL)
   Diszo [M:STQ1]SERNUMDEP (NOL)
   Diszo [M:STQ1]SERNUMFDEP(NOL)
Endif
Diszo [M:STQ1]STADES       (NOL)
#                                                            # hcb 77043 deb
If dim([M:STQ1]LPNNUM) > 0
   Diszo [M:STQ1]LPNNUMDES (NOL)
   Diszo [M:STQ1]LPNNUM    (NOL)
Endif
#                                                            # hcb 77043 fin
If dim([M:STQ1]LOC) > 0
   Diszo [M:STQ1]LOCTYPDES (NOL)
   Diszo [M:STQ1]LOCDES    (NOL)
   Diszo [M:STQ1]LOCTYP    (NOL)
   Diszo [M:STQ1]LOC       (NOL)
Endif
Diszo [M:STQ1]IPTDAT       (NOL)
If dim([M:STQ1]LOT) > 0
   Diszo [M:STQ1]LOT       (NOL)
Endif
If dim([M:STQ1]SLO) > 0
   Diszo [M:STQ1]SLO       (NOL)
Endif
If dim([M:STQ1]WRH) > 0
   Diszo [M:STQ1]WRH       (NOL)
Endif
If dim([M:STQ1]PALNUM) > 0
   Diszo [M:STQ1]PALNUM    (NOL)
   Diszo [M:STQ1]CTRNUM    (NOL)
Endif
If dim([M:STQ1]STOFLD1) > 0
   Diszo [M:STQ1]STOFLD1   (NOL)
   Diszo [M:STQ1]STOFLD2   (NOL)
Endif
Return


########################################################################
# CTR_UNICITE_LOT        Controle unicité lot   (hcb unicite)
########################################################################
# Paramètres E : LITM = article
#                LLOT = lot
#                LTYP = type piece origine (701)
#                LVCR = piece origine
#                LSUP = parametre supplementaire (disponible)
#            S : LRET = Code retour : 0 unicité
#                                     1 non unicité
#
# Prérequis    : On doit être dans une transaction de mise à jour
#
########################################################################
Subprog CTR_UNICITE_LOT(LITM,LLOT,LTYP,LVCR,LSUP,LRET)
Value    Char    LITM
Value    Char    LLOT
Value    Integer LTYP
Value    Char    LVCR
Value    Char    LSUP
Variable Integer LRET
LRET = 0

Filter [STL1] Where  ITMREF    = LITM   &
&                    LOT       = LLOT   &
&                    (VCRTYP <> LTYP | VCRNUM <> LVCR)
&            Order By Key STL0
Read [STL1] First
If fstat = 0
   LRET = 1
Endif
Filter [STL1]

End

