#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTICRMMAC : Création des parcs clients manquant             Module CRM #
#                                                         (X3SUIVI70100) #  
# ---------------------------------------------------------------------- #
##########################################################################
  Call MAJ_UTICRMMAC
End

##################################
$ACTION
  Case ACTION
    When "DEBUT"       : Gosub DEBUT
    When "FIN"         : Gosub FIN
    When Default
  Endcase
Return

##################################
$DEBUT
  [M]WDAT = [0/0/0]
  [M]WSIMUL = 2
  Affzo [M]1,99
Return

$FIN
  PARAM(1) = [M]WDAT
  PARAM(2) = num$([M]WSIMUL)
Return

##################################
Subprog MAJ_UTICRMMAC
Local Char DOSSIER(30)

  DOSSIER = nomap
  If DOSSIER <> "" and DOSSIER <> "X3" Then
    Call EXE_UTICRMMAC(DOSSIER)
  Endif
End

##################################
Subprog EXE_UTICRMMAC(DOSSIER)
Value Char DOSSIER

Global Integer NBUTICRMMAC
Local Char PARAM(30)(1..2)
Local Date DATREF
Local Integer ISIMUL
Local Integer  WRET

  Call SAISIE_DAT(GBIDA1, PARAM, "UTICRMMAC", "UTICRMMAC", "XWUTICRMMAC") From GSAISIE
  DATREF = PARAM(1)
  If PARAM(2) = "2" Then
    INOSIMUL = 1
  Else
    INOSIMUL = 2
  Endif
  #----------------------------------
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTICRMMAC : Création des parcs clients manquants") From LECFIC
  Call ECR_TRACE("UTICRMMAC : Début traitement du dossier" - DOSSIER, 0) From GESECRAN
  If INOSIMUL = 1 Then
    Call ECR_TRACE("UTICRMMAC : Mode simulation", 0) From GESECRAN
  Endif
  Call ECR_TRACE("UTICRMMAC : Date de début :" - num$(DATREF), 0) From GESECRAN
  If DATREF = [0/0/0] Then
    Call ECR_TRACE("UTICRMMAC : Traitement abandonné par l'utilisateur", -1) From GESECRAN
    Goto FIN_UTICRMMAC
  Endif
  #----- Ouverture des fichiers -----#
  If !clalev ([F:SDH]) : Local File SDELIVERY  [SDH] : Endif 
  If !clalev ([F:SDD]) : Local File SDELIVERYD [SDD] : Endif 
  If !clalev ([F:SIH]) : Local File SINVOICE   [SIH] : Endif 
  If !clalev ([F:SIV]) : Local File SINVOICEV  [SIV] : Endif 
  If !clalev ([F:SID]) : Local File SINVOICED  [SID] : Endif 
  If !clalev ([F:ITM]) : Local File ITMMASTER  [ITM] : Endif  
  If !clalev ([F:STJ]) : Local File STOJOU     [STJ] : Endif
  #----------------------------------
  Call ECR_TRACE(string$(70,"="),0) From GESECRAN 
  Call ECR_TRACE("Parcs clients sur livraisons validées",0) From GESECRAN 
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
  #----------------------------------
  Raz NBUTICRMMAC
  For [SDH]SDH0 Where CFMFLG = 2 and SHIDAT >= DATREF
    GOK = 1
    Trbegin [SDH]
    Gosub TRT_MACRULE From TRTVENLIVV
    If GOK < 1 Then
      Rollback
      Call ECR_TRACE(mess(7,21,1) - mess(129,197,1) - ":" - [F:SDH]SDHNUM,1) From GESECRAN
    Else
      If INOSIMUL = 2 Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Next
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
  If NBUTICRMMAC = 0 Then
    Call ECR_TRACE("Aucun parc client créé",0) From GESECRAN
  Else
    Call ECR_TRACE(num$(NBUTICRMMAC) - "parc(s) client(s) créé(s)",0) From GESECRAN
  Endif
  #----------------------------------
  Call ECR_TRACE(string$(70,"="),0) From GESECRAN 
  Call ECR_TRACE("Parcs clients sur factures validées",0) From GESECRAN 
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
  #----------------------------------
  Raz NBUTICRMMAC
  For [SIH]SIH0 Where [F:SIV]INVSTA = 3 and [F:SIV]INVDAT >= DATREF
    Read [SIV]SIV0=[F:SIV]NUM
    If [F:SIV]INVTYP = 1 & ([F:SIV]SIHORI = 1 & [F:SIV]STOMVTFLG = 2) or [F:SIV]SIHORI = 2 or [F:SIV]SIHORI = 3 Then
      GOK = 1
      Trbegin [SDH]
      Gosub TRT_MACRULE From TRTVENFACV
      If GOK < 1 Then
        Rollback
        Call ECR_TRACE(mess(7,21,1) - mess(193,198,1) - ":" - [F:SIV]NUM,1) From GESECRAN
      Else
        If INOSIMUL = 2 Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Endif
    #
  Next
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
  If NBUTICRMMAC = 0 Then
    Call ECR_TRACE("Aucun parc client créé",0) From GESECRAN
  Else
    Call ECR_TRACE(num$(NBUTICRMMAC) - "parc(s) client(s) créé(s)",0) From GESECRAN
  Endif
  #----------------------------------
$FIN_UTICRMMAC
  Kill NBUTICRMMAC
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
End
