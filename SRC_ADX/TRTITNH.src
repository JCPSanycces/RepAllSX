##########################################################################################################
#   Traitement de gestion de la consultation          Module CRM                  4 mai 2009
#    de l'historique des interventions d'une demande de service
# FGR 04/05/2009 : X3SUIVI34174
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev ([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev ([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev ([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev ([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNITNH"
Return

##########################################################################################################
$DEBUT
  # PARAM(1) = Numéro de demande de service
  [M:ITNH]SRENUMORI = PARAM(1)
  Call B2_NBITN From SUBITNH
Return

##########################################################################################################
$FINSAI
  Raz [M:ITNH]
Return

##########################################################################################################
# Sous-programmes
#########################################################
Subprog LOADHISITN
Local Integer IZ
Local Char SWHERE(250)

  Effzo [M:ITNH]10
  SWHERE = ""
  Case [M:ITNH]FILTRE
    When "SRE"
      # Filtre sur le SRE d'appel
      SWHERE = "[F:ITN]SRVDEMNUM = [M:ITNH]VCRNUM"
    When "SCO"
      # Filtre sur le sous-traitant
      SWHERE = "[F:ITN]SCONUM = [M:ITNH]VCRNUM"
    When "AUS"
      # Filtre sur le représentant
      SWHERE = "[F:ITN]REP = [M:ITNH]VCRNUM"
    When "BPR"
      # Filtre sur le client
      SWHERE = "[F:ITN]BPC = [M:ITNH]VCRNUM"
    When "AIN"
      # Filtre sur Interlocuteur
      SWHERE = "[F:ITN]CCN = [M:ITNH]VCRNUM"
    When Default
      # Filtre sur rien : liste vide
      SWHERE = "0=1"
  Endcase
  IZ = 0
  nolign = 0
  Filter [ITN] Where evalue(SWHERE) Order By [F:ITN]DAT Desc; [F:ITN]HOU Desc
  For [ITN]
    If IZ >= dim([M:ITNH]NUM)-1 Then
      Break
    Endif
    nolign += 1
    [M:ITNH] = [F:ITN]
    If [M:ITNH]SCO = 2 Then
      # Sous-traitée
      [M:ITNH]ITNASS(nolign-1) = [F:ITN]SCONUM
    Else
      [M:ITNH]ITNASS(nolign-1) = [F:ITN]REP
    Endif
    [M:ITNH]ITNASSCLA(nolign-1) = func GET_NAM_ITNASS([M:ITNH]SCO, [M:ITNH]ITNASS(nolign-1))
    IZ += 1
  Next
  Filter [ITN]
  [M:ITNH]NBITN = IZ
  Affzo [M:ITNH]1-99
  nolign = 0
End

##########################################################################################################
Funprog GET_NAM_ITNASS(ISCO, SZITNASS)
Value Integer ISCO
Value Char SZITNASS

Local Char SZARENDRE(GLONNAM)

  SZARENDRE = ""
  If ISCO = 2 Then
    SZARENDRE = func GET_NAM_VCRNUM("SCO", SZITNASS)
  Else
    SZARENDRE = func GET_NAM_VCRNUM("AUS", SZITNASS)
  Endif
End SZARENDRE

##########################################################################################################
Funprog GET_NAM_VCRNUM(SZFILTRE, SZVCRNUM)
Value Char SZFILTRE
Value Char SZVCRNUM

Local Char SZARENDRE(GLONNAM)

  SZARENDRE = ""
  Case SZFILTRE
    When "SRE"
      # SRE d'appel
      Read [SRE]SRE0=SZVCRNUM
      If !fstat Then
        SZARENDRE = [F:SRE]SRETTR
      Endif
    When "BPR", "SCO"
      # Client ou sous-traitant
      Read [BPR]BPR0=SZVCRNUM
      If !fstat Then
        SZARENDRE = [F:BPR]BPRNAM
      Endif
    When "AUS"
      # Représentant
      Read [AUS]CODUSR=SZVCRNUM
      If !fstat Then
        SZARENDRE = [F:AUS]NOMUSR
      Endif
    When "AIN"
      # Interlocuteur
      Read [AIN]AIN0=SZVCRNUM
      If !fstat Then
        SZARENDRE = [F:AIN]CNTFULNAM
      Endif
    When Default
      SZARENDRE = ""
  Endcase
End SZARENDRE
