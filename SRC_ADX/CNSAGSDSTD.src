######################################################################################
Subprog B1_NBLIG

Local Integer I
Local Char CLE1(250), CLE2(250)

CLE1 = [M:AGSD2]VCRKEY(nolign-1)
I = instr(1,CLE1,"~")
If I>0
    CLE2=right$(CLE1,I+1)
Endif

Call OBJET([M:AGSD1]OBJET,CLE1,CLE2) From GOBJET

End


######################################################################################

