#<AdxTL>@(#)0.0.0.0 $Revision$ Consultation AGSD
# AGSD inquiry : List documents using
$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "LECTURE" : Gosub LECTURE
 When "FERME"   : Gosub FERME
 When Default
Endcase
Return

######################################################################################
$OUVRE
Global Char   GAGDPRKEY(50)(1..5)
Local Char    CRITENT(250) , CRITSUI(250)   # Filter used for inquiry
Local Char    FLDATY(GLONAVA)(1..)          # List of fields in the table CODFIC with data type CODATY
Local Integer FLDATYTYP(1..)                # Type of fields in FLDATY
Local Integer NBFLDATY
Local Char    FLDKEY(GLONAVA)(1..)          # List of fields in primary key
Local Integer FLDKEYTYP(1..)                # List of fields in primary key
Local Integer NBFLDKEY
Local Char    TYPLST(GLONATY)(1..1)         # used as parameter which is an array
Local Integer LADXUID(1..), LNBUID

Local File AGDPRVCR [AGVCR]     # Table used in this inquiry : filled when 1st used and deleted at the end

[M:AGSD1]DOSSIER = PARAM(1)
[M:AGSD1]CODE    = PARAM(2)
[M:AGSD1]CODSEA  = PARAM(3)
[M:AGSD1]CODFIC  = PARAM(4)

If [M:AGSD1]CODE<>""
    Read [AGS]AGS0=[M:AGSD1]CODE
    If fstat=[V]CST_AOK
        [M:AGSD1]CODATY=[F:AGS]CODATY
    Endif
Endif

# Clean table AGDPRVCR for interactive sessions (UID<>0)
Call LIST_UID_INT(LADXUID,LNBUID) From ASESSIONS
Trbegin [AGVCR]
Delete [AGVCR] Where UID<>0 & (UID=adxuid(1) | find(UID,LADXUID(1..LNBUID))=0)
If fstat=[V]CST_AOK
    Commit
Else
    Rollback
Endif

Return

$PREPARE_SEARCH
Local Integer I

If [M:AGSD1]DOSSIER=""
    [M:AGSD1]DOSSIER = nomap
Endif

Local File =[M:AGSD1]DOSSIER+".ATABZON" [AGATZ]
Local File =[M:AGSD1]DOSSIER+".ATEXTE"  [AGATX]

Raz NBFLDATY, FLDATY, FLDATYTYP
Raz NBFLDKEY, FLDKEY, FLDKEYTYP

If [M:AGSD1]CODFIC<>""
    If filinfo(filpath("FIL",[M:AGSD1]CODFIC,"fde",[M:AGSD1]DOSSIER),0)<0
        Call ERREUR(func AFNC.MES(mess(85,133,1),[M:AGSD1]DOSSIER+"."+[M:AGSD1]CODFIC)) From GESECRAN
    Else
        [M:AGSD1]OBJET = func GETOBJECT([M:AGSD1]DOSSIER, [M:AGSD1]CODFIC)
        Call GETFLDATY([M:AGSD1]DOSSIER, [M:AGSD1]CODATY, [M:AGSD1]CODFIC, NBFLDATY, FLDATY, FLDATYTYP)
        If [F:AGS]CODE<>[M:AGSD1]CODE
            Read [AGS]AGS0=[M:AGSD1]CODE
        Endif
        # If inquiry concerns reference table, we can also check into the field defined in the GDPR setting
        If [F:AGS]CODATB = [M:AGSD1]CODFIC
            If find([F:AGS]CODFLD,FLDATY)=0
                FLDATY(NBFLDATY+1) = [F:AGS]CODFLD
            Endif
        Endif
        Call GET_INDEX([M:AGSD1]DOSSIER,[M:AGSD1]CODFIC,0,NBFLDKEY,FLDKEY,FLDKEYTYP) From AFNC
    Endif
    Link [AGATZ] With [AGATX]DERNUM = [F:AGATZ]NOLONG;GLANGUE
&              As [LNK]
&              Where CODFIC=[M:AGSD1]CODFIC
    For I=1 To min(NBFLDKEY,5)
        Filter [LNK] Where CODZONE=FLDKEY(I)
        Read [LNK] First
        Filter [LNK]
        If fstat=[V]CST_AOK
            GAGDPRKEY(I) = [F:AGATX]TEXTE
        Else
            GAGDPRKEY(I) = "Key"+num$(I)
        Endif
    Next
    If NBFLDKEY<2 : Chgfmt [M:AGSD2]KEY2 With "-K:50" : Endif
    If NBFLDKEY<3 : Chgfmt [M:AGSD2]KEY3 With "-K:50" : Endif
    If NBFLDKEY<4 : Chgfmt [M:AGSD2]KEY4 With "-K:50" : Endif
    If NBFLDKEY<5 : Chgfmt [M:AGSD2]KEY5 With "-K:50" : Endif
    If NBFLDKEY<6 : Chgfmt [M:AGSD2]KEY6 With "-K:50" : Endif
Endif


#  Diszo instruction is not taken into account in actions OUVRE and TITRE
If PARAM(2)<>""
    Diszo [M:AGSD1]CODE
Endif
If PARAM(3)<>""
    Diszo [M:AGSD1]CODSEA
Endif
If PARAM(4)<>""
    Diszo [M:AGSD1]CODFIC
Endif

LogicClose File [AGATZ], [AGATX]
Return

######################################################################################
$FERME
    Trbegin [AGVCR]
    # Delete all records created by the current inquiry (VCRKEY<>"")
    Delete [AGVCR] Where [F:AGVCR]UID=adxuid(1) & VCRKEY<>""
    If fstat=[V]CST_AOK
        Commit
    Else
        Rollback
        Call FSTA("AGVCR") From GLOCK
    Endif
Return
######################################################################################
$LECTURE

NOL = 0
SUITE  = 1
RETOUR = 1

If CHGPAG=1
    Gosub PREPARE_SEARCH
Endif

If  [M:AGSD1]CODFIC=""
& | FLDATY(1)=""
& | [M:AGSD1]CODSEA=""
    Return
Endif

If CHGPAG=1
    TYPLST(1) = [M:AGSD1]CODE
    If func TRTAGSEA.SEARCH_CODE([M:AGSD1]DOSSIER, TYPLST, [M:AGSD1]CODSEA, [M:AGSD1]CODFIC, 4, GMESSAGE)=[V]CST_AERROR
        Call ERREUR(GMESSAGE) From GESECRAN
        Return
    Endif
Endif

#---------------------------------------------------------------#
Gosub LOAD_CRITENT
Gosub LOAD_CRITSUI

# CHGPAG = 1 : Search
# CHGPAG =-1 : Last
# CHGPAG = 2 : Next
# CHGPAG =-2 : Previous

If CHGPAG>0
    Filter [AGVCR] Where evalue(CRITENT) & evalue(CRITSUI)
&                 Order By Key AGVCR0 Asc
    NOL = 0
    For [AGVCR]
        If NOL>=MAXLIG
            SUITE = 2 : Break
        Else
            If CHGPAG=2 : RETOUR = 2 : Endif
            NOL += 1
            Gosub CHARGE
        Endif
    Next
    Filter [AGVCR]
    [M:AGSD2]NBLIG = NOL
Else
    Filter [AGVCR] Where evalue(CRITENT) & evalue(CRITSUI)
&                 Order By Key AGVCR0 Asc
    NOL = MAXLIG+1
    For [AGVCR]
        If NOL<=1
            RETOUR = 2 : Break
        Else
            If CHGPAG=-2 : SUITE = 2 : Endif
            NOL -= 1
            Gosub CHARGE
        Endif
    Next
    Filter [AGVCR]
    [M:AGSD2]NBLIG = NOL
Endif
NOL -= 1
Return

$CHARGE
If NBLU=1
 NBLU = 2
 If CHGPAG=2 or CHGPAG=-2 : Raz [M:AGSD2] : Endif
Endif
nolign = NOL
[M:AGSD2] = [F:AGVCR]

CLE=[M:AGSD2]VCRKEY(nolign-1)
For I=1 To 6
    J=instr(1,CLE,"~")
    If J>0 & I<6
        Assign "[M:AGSD2]KEY"+num$(I)+"(nolign-1)" With left$(CLE,J-1)
        CLE = right$(CLE,J+1)
    Else
        Assign "[M:AGSD2]KEY"+num$(I)+"(nolign-1)" With CLE
        Break
    Endif
Next
Return


$LOAD_CRITENT
CRITENT =   "UID="+num$(adxuid(1))
CRITENT+= "& CODATY='"+[M:AGSD1]CODATY+"'"
CRITENT+= "& CODFIC='"+[M:AGSD1]CODFIC+"'"
CRITENT+= "& CODE='"+[M:AGSD1]CODSEA+"'"
Return

$LOAD_CRITSUI
CRITSUI = ""
Case CHGPAG
 When 2
    If [M:AGSD2]NBLIG>0
       W_KEYVCR    = [M:AGSD2]VCRKEY([M:AGSD2]NBLIG-1)
       CRITSUI     = '[AGVCR]VCRKEY > "' +W_KEYVCR+ '"'
    Endif
 When -2
    If [M:AGSD2]NBLIG>0
        W_KEYVCR    = [M:AGSD2]VCRKEY(0)
        CRITSUI     = '[AGVCR]VCRKEY < "' +W_KEYVCR+ '"'
    Endif
Endcase
If CRITSUI=""
 CRITSUI = "1=1"
Endif
Return

#**
#* Get object which manage a table
#*
#* @param PDOSSIER : Folder (default=nomap)
#* @param PTABLE   : Table code
#*!
Funprog GETOBJECT(PDOSSIER, PTABLE)
Value Char PDOSSIER
Value Char PTABLE
Local Char LOBJ(GLONAOB)

If PDOSSIER=""
    PDOSSIER=nomap
Endif

Local File =PDOSSIER+".AOBJET"    [AOB]
Local File =PDOSSIER+".AFONCTION" [AFC]
Local File =PDOSSIER+".AWINDOW" [AWI]

For [AOB] Where NOMFIC=PTABLE
    Filter [AFC] Where ACTION="GOBJET"
&                    & VALPAR='"'+[F:AOB]ABREV+'"'
&                    & find(NAVIG,1,3)<>0
    Look [AFC] First
    Filter [AFC]
    If fstat=[V]CST_AOK
        LOBJ=[F:AOB]ABREV
        Break
    Endif
Next

LogicClose File [AOB], [AFC], [AWI]
End LOBJ

#**
#* Return list of fields in a table with a specific data type
#*
#* @param PDOSSIER   : Folder name
#* @param PCODATY    : Data type to search
#* @param PCODFIC    : Table name where to search
#* @param PNBFLDATY  : Number of fields with this data type
#* @param PFLDATY    : List of fields with this data type
#* @param PFLDATYTYP : "real" type of fields returned (see local menu 30)
#*!
Subprog GETFLDATY(PDOSSIER, PCODATY, PCODFIC, PNBFLDATY, PFLDATY, PFLDATYTYP)
Value Char PDOSSIER
Value Char PCODATY
Value Char PCODFIC
Variable Integer PNBFLDATY
Variable Char PFLDATY()(1..)
Variable Integer PFLDATYTYP(1..)
Local File =PDOSSIER+".ATABZON" [ATZ]
Local File =PDOSSIER+".ATYPE"   [ATY]
PNBFLDATY=0
Raz PFLDATY, PFLDATYTYP
For [ATZ] Where CODTYP=PCODATY
&             & CODFIC=PCODFIC
    Read [ATY]CODTYP=[F:ATZ]CODTYP
    If fstat=[V]CST_AOK
        PNBFLDATY+=1
        PFLDATYTYP(PNBFLDATY) = [F:ATY]TYPTYP
        PFLDATY(PNBFLDATY)    = [F:ATZ]CODZONE
    Endif
Next
LogicClose File [ATZ]
End


######################################################################################
