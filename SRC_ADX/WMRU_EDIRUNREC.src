#<AdxTL>@(#)0.0.0.0 $Revision$Class EDI inbound msg. generation
# Supervisor
## CRUD-CLASSE ## EDIRUNREC
# 2018-10-17 07:54:26 902


############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EDIRUNREC,ASTATUS)
Variable Instance EDIRUNREC Using R_EDIRUNREC
Variable Integer ASTATUS

If EDIRUNREC = null : End : Endif

Gosub AVARIABLES From WMR00EDIRUNREC
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If fmet EDIRUNREC.ACTX.AGETAFCRIGHT(EDIRUNREC,"EDIRUNREC",[V]CST_ATRUE)>=[V]CST_AERROR : [L]ASTATUS=[V]CST_AERROR : Goto AUPDATE_END : Endif
If fmet EDIRUNREC.ACTX.AGETAFCRIGHTU(EDIRUNREC,"EDIRUNREC",[L]A_STRSITE,[V]CST_ATRUE)>=[V]CST_AERROR
 [L]ASTATUS=[V]CST_AERROR : Goto AUPDATE_END
Endif

Gosub AREPCONTROL_AUPDATE
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EDIRUNREC
Else
 Gosub AUPDATE_EDIRUNREC
Endif
If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_END : Return : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EDIRUNREC.freeSnapshot
EDIRUNREC.snapshotEnabled = 1
$AUPDATE_END
End

#-----------------------------------------------------#
$AREPCONTROL_AUPDATE
EDIRUNREC.ASTALIN = [V]CST_AUPD
EDIRUNREC.EDR.ASTALIN = [V]CST_AUPD
[L]A_ASTALIN = EDIRUNREC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]A_ASTALIN = EDIRUNREC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUNREC._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUNREC._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUNREC._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EDIRUNREC.EDR.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIRUNREC.EDR.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EDIRUNREC.EDR.ASTALIN)<>""
 [L]A_ASTALIN = EDIRUNREC.EDR.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
For A_N2=1 To maxtab(EDIRUNREC.EDR.EDRD) : # EDIRUND -- 2
 If EDIRUNREC.EDR.EDRD(A_N2) <> null
& and EDIRUNREC.EDR.EDRD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIRUNREC.EDR.EDRD(A_N2).ASTALIN<>[V]CST_ANEW & EDIRUNREC.EDR.ASTALIN=[V]CST_ADEL
   EDIRUNREC.EDR.EDRD(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If EDIRUNREC.EDR.EDRD(A_N2).ASTALIN=[V]CST_ANEW & find(EDIRUNREC.EDR.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   EDIRUNREC.EDR.EDRD(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(EDIRUNREC.EDR.EDRD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIRUNREC.EDR.EDRD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.EDRD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER
For A_N2=1 To maxtab(EDIRUNREC.EDR.EDRD) : # EDIRUND -- 2
 If EDIRUNREC.EDR.EDRD(A_N2) <> null
& and EDIRUNREC.EDR.EDRD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(EDIRUNREC.EDR.EDRD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIRUNREC.EDR.EDRD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.EDRD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

If [V]CST_ASTALIN(EDIRUNREC.EDR.ASTALIN)<>""
 [L]A_ASTALIN = EDIRUNREC.EDR.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EDIRUNREC
Trbegin [F:EDR]
 Gosub AUPDATE_EDIRUNREC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EDIRUNREC.EDR.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EDIRUNREC.EDR.ASTALIN = [V]CST_ALL
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIRUNREC.EDR.EDRD)
 If EDIRUNREC.EDR.EDRD(A_N2) <> null
  If EDIRUNREC.EDR.EDRD(A_N2).ASTALIN=[V]CST_ADEL or EDIRUNREC.EDR.EDRD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIRUNREC.EDR.EDRD(A_N2)
   EDIRUNREC.EDR.EDRD(A_N2) = null
  Elsif EDIRUNREC.EDR.EDRD(A_N2).ASTALIN <> [V]CST_ALL
   EDIRUNREC.EDR.EDRD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return

#-----------------------------------------------------#
$AUPDATE_EDIRUNREC
[L]A_ASTALIN = EDIRUNREC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR._AUPDATE)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]A_ASTALIN = EDIRUNREC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EDIRUNREC.snapshotEnabled=1
 [L]A_RETIK = EDIRUNREC.revertUpdTick
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIRUNREC.EDR.EDRD)
 If EDIRUNREC.EDR.EDRD(A_N2) <> null
  If EDIRUNREC.EDR.EDRD(A_N2).ASTALIN=[V]CST_ANEWDEL
   EDIRUNREC.EDR.EDRD(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2

[L]ASTATUS = max(fmet EDIRUNREC.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#



