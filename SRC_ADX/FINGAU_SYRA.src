#<AdxTL>@(#)2.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT AUTOMATIC JOURNALS
##############################################################################################################
# GET_ACC : Returns the accounts initialized by the given automatic journal parameterization
#
# Private routines :
# EVAL_CHAR : Evaluates the given character formula
# EVAL_DATE : Evaluates the given numerical formula
# EVAL_INT  : Evaluates the given local menu formula
# EVAL_NUM  : Evaluates the given numerical formula
##############################################################################################################


########################################################################################################
## GET_ACC
########################################################################################################
#**
#* Returns the accounts initialized by the Automatic Journal Parameterization used as parameter (AUTJOUCOD).
#* For every account initialized, the chart of account and the corresponding ledger type are also returned.
#*
#* @param ACTX       Context
#* @param COMPANY    Company
#* @param AUTJOUCOD  Automatic Journal Code
#* @param AUTJOULIN  Automatic Journal Line
#* @param IDT1       Identifiers 1
#* @param IDT2       Identifiers 2
#* @param APPCASE    1:Identifiers are on line (loaded upstream) <>1:Identifiers are NOT on line
#* @param LEDTYP     Ledger Types
#* @param COA        Charts of accounts
#* @param ACC        Accounts
#* @param ERRMES     Error message
#*!
Funprog GET_ACC(ACTX,COMPANY,AUTJOUCOD,AUTJOULIN,IDT1,IDT2,APPCASE,LEDTYP,COA,ACC,ERRMES)
Variable Instance ACTX   Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY          : # Company
Value    Char     AUTJOUCOD        : # Automatic Journal Code
Value    Integer  AUTJOULIN        : # Automatic Journal Line
Value    Char     IDT1()(1..)      : # Identifiers 1
Value    Char     IDT2()(1..)      : # Identifiers 2
Value    Integer  APPCASE          : # 1:Identifiers are on line (loaded upstream) <>1:Identifiers are NOT on line
Variable Libelle  LEDTYP(1..)      : # Ledger Types
Variable Char     COA()(1..)       : # Charts of accounts
Variable Char     ACC()(1..)       : # Accounts
Variable Char     ERRMES()         : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If adxtyp=33 | !clalev([F:GAU]) : Local File GAUTACE  [GAU] : Endif
If adxtyp=33 | !clalev([F:GAD]) : Local File GAUTACED [GAD] : Endif
If adxtyp=33 | !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

Local Char    PRG(GLONADC)                        : # Sub program Name
Local Char    CLE(30)(1..16), CLE2(30)(1..16)     : # Key Elements (used in WMGAUx Processes)
Local Char    SIT(GLONFCY), DEFSIT(GLONFCY)       : # Site
Local Char    ACMCOD(GLONGCM)                     : # Accounting core model
Local Char    LEDCOD(GLONLED)(1..), LLED(GLONLED) : # Ledger Code
Local Char    BPR(GLONBPR)                        : # Business Partner
Local Char    CRIT(250)                           : # Criteria
Local Integer NBCLE, NBCLE2                       : # Number of Key Elements (used in WMGAUx Processes)
Local Integer NBRLED                              : # Number of ledgers
Local Integer I, ERR                              : # Miscellaneous Variables

Read [GAU]GAU0 = AUTJOUCOD
If fstat
 [L]ASTATUS = [V]CST_AERROR
 ERRMES = AUTJOUCOD-mess(39,114,1) : End [L]ASTATUS
Endif
Read [GAD]GAD0 = AUTJOUCOD;AUTJOULIN
If fstat
 [L]ASTATUS = [V]CST_AERROR
 ERRMES = AUTJOUCOD-num$(AUTJOULIN)-mess(39,114,1) : End [L]ASTATUS
Endif

PRG = "WMGAU"+AUTJOUCOD
Gosub OUVRE From =PRG

[L]ASTATUS = func FINACM_SYRA.GET_GCM(ACTX,COMPANY,ACMCOD,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

Raz LEDTYP, LEDCOD, NBRLED
For I=1 To [F:GAD]NBRLED
 LLED =  fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"LED"+num$([F:GAD]LEDTYP(I-1)))
 If LLED<>"" & !find(LLED,LEDCOD(1..NBRLED)) : # Allows to exclude the Automatic Ledger Types....
  NBRLED += 1
  LEDCOD(NBRLED) = LLED
  LEDTYP(NBRLED) = [F:GAD]LEDTYP(I-1)
 Endif
Next

Local Char SAC(GLONSAC)(1..NBRLED)


### Triggering Tables Reading : The readings are done only if APPCASE<>1 ###
## 1) Triggering Table (TB0)
If APPCASE<>1 & (adxtyp=33 | !clalev([F:TB0]))
 Onerrgo ERREUR
 Local File =[F:GAU]TBL [TB0]
 Onerrgo
 If ERR
  ## Nonexistent Triggering Table
  [L]ASTATUS = [V]CST_AERROR : ERRMES = [F:GAU]TBL-mess(4,114,1) : End [L]ASTATUS
 Endif

 Gosub CLE From =PRG
 If NBCLE>dim(IDT1)
  ## Incorrect number of arguments
  [L]ASTATUS = [V]CST_AERROR : ERRMES = [F:GAU]TBL-mess(5,114,1) : End [L]ASTATUS
 Endif
 CRIT = ""

 For I=1 To NBCLE
  If I>1 : CRIT += " & " : Endif
  Case evalue("type([F:TB0]"+CLE(I)+")")
   When 1,2,4,5,6,7,8,9
    CRIT += CLE(I)+'='+IDT1(I)
   When 3
    CRIT += CLE(I)+'=['+format$(GACTX.AINTL.SHORTDATE,gdat$(IDT1(I)))+']'
   When Default
    CRIT += CLE(I)+'="'+IDT1(I)+'"'
  Endcase
 Next I
 Default File [TB0]

 For [TB0] Where evalue(CRIT)
  Break
 Next
Endif


## 2) Secondary Triggering Table (TB1)
If APPCASE<>1 & [F:GAD]LINTBL1<>""
 If adxtyp=33 | !clalev([F:TB1])
  Onerrgo ERREUR
  Local File =[F:GAD]LINTBL1 [TB1]
  Onerrgo
  If ERR
   ## Nonexistent secondary Table
   [L]ASTATUS = [V]CST_AERROR : ERRMES = [F:GAD]LINTBL1-mess(4,114,1) : End [L]ASTATUS
  Endif
 Endif
 Default File [TB1]
 CRIT = ""
 For I=1 To NBCLE
  If I>1 : CRIT += " & " : Endif
  Case evalue("type([F:TB1]"+CLE(I)+")")
   When 1,2,4,5,6,7,8,9
    CRIT += CLE(I)+'='+IDT2(I)
   When 3
    CRIT += CLE(I)+'=['+format$(GACTX.AINTL.SHORTDATE,gdat$(IDT2(I)))+']'
   When Default
    CRIT += CLE(I)+'="'+IDT2(I)+'"'
  Endcase
 Next I
 For [TB1] Where evalue(CRIT)
  Break
 Next
 If fstat>2
  ## Incorrect Link
  [L]ASTATUS = [V]CST_AERROR : ERRMES = [F:GAD]LINTBL1-mess(162,115,1) : End [L]ASTATUS
 Endif
Endif

## 3) Analytical Triggering Table (TB2) - Reading done if an analytical link is defined on the line of Automatic Journal
If APPCASE<>1 & [F:GAD]LINTBL2<>"" & [F:GAD]LIKTBL2<>""
 If adxtyp=33 | !clalev([F:TB2])
  Onerrgo ERREUR
  Local File =[F:GAD]LINTBL2 [TB2]
  Onerrgo
  If ERR
   ## Nonexistent secondary Table
   [L]ASTATUS = [V]CST_AERROR : ERRMES = [F:GAD]LINTBL2-mess(4,114,1) : End [L]ASTATUS
  Endif
 Endif
 Default File [TB2]
 CRIT = ""
 Gosub CLE_X From =PRG
 Gosub ANA_IDT
 CRIT = "1=1"
 For I=1 To NBCLE2
  If ANAIDT(I)<>""
   CRIT += " & "+CLE2(I)+"="+ANAIDT(I)
  Endif
 Next
 For [TB2] Where evalue(CRIT)
  Break
 Next
 If fstat>2
  ## Incorrect Link
  [L]ASTATUS = [V]CST_AERROR : ERRMES = [F:GAD]LINTBL2-mess(162,115,1) : End [L]ASTATUS
 Endif
Endif

IDT = IDT1
[L]ASTATUS = func FINGAU2_SYRA._EVAL_ACC(ACTX,COMPANY,NBRLED,LEDTYP,IDT,datesyst,COA,ACC,SAC,BPR,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
End [L]ASTATUS


######################################################################
# Decoding of the Analytic Link Expression
$ANA_IDT
Local Char    ANALNKEXX(250)     : # Analytical Link Expression
Local Char    LANAIDT(50)        : # Analytial Identifier
Local Char    ANAIDT(50)(1..16)  : # Array of Analytical Identifiers
Local Integer NBRKEY             : # Number of Keys
Local Integer J
ANALNKEXX = [F:GAD]LIKTBL2
NBRKEY = 0
While ANALNKEXX<>""
 J = instr(1,ANALNKEXX,";")
 If J
  LANAIDT = left$(ANALNKEXX,J-1) : ANALNKEXX = right$(ANALNKEXX,J+1)
 Else
  LANAIDT = ANALNKEXX : ANALNKEXX = ""
 Endif
 NBRKEY += 1
 ANAIDT(NBRKEY) = LANAIDT
Wend
Return


########################################################################################################
## EVAL_CHAR
########################################################################################################
#**
#* Evaluates the Character Formula used as parameter
#*
#* @private
#* @param ACTX    Context
#* @param EXPR    Formula
#* @param CALCASE Call case (1:Header 2:Lines 3:Accounting Modifiers)
#* @param DEFVAL  Default Value
#* @param ZONE    Field to be initialized (Local Variable used in WMGAU# Processes)
#* @param ERRMES  Error message
#*!
Funprog EVAL_CHAR(ACTX,EXPR,CALCASE,DEFVAL,ZONE,ERRMES)
Variable Instance ACTX   Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     EXPR     : # Formula
Value    Integer  CALCASE  : # Call case (1:Header 2:Lines 3:Accounting Modifiers)
Value    Char     DEFVAL   : # Default Value
Variable Char     ZONE     : # Field to be initialized (Local Variable used in WMGAU# Processes)
Variable Char     ERRMES() : # Error message
ZONE = "" : Gosub EVALE
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
If ZONE="" : ZONE = DEFVAL : Endif
End [L]ASTATUS


########################################################################################################
## EVAL_NUM
########################################################################################################
#**
#* Evaluates the Numerical Formula used as parameter
#*
#* @private
#* @param ACTX    Context
#* @param EXPR    Formula
#* @param CALCASE Call case (1:Header 2:Lines 3:Accounting Modifiers)
#* @param DEFVAL  Default Value
#* @param ZONE    Field to be initialized (Local Variable used in WMGAU# Processes)
#* @param ERRMES  Error message
#*!
Subprog EVAL_NUM(ACTX,EXPR,CALCASE,DEFVAL,ZONE,ERRMES)
Variable Instance ACTX   Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     EXPR     : # Formula
Value    Integer  CALCASE  : # Call case (1:Header 2:Lines  3:)
Value    Char     DEFVAL   : # Default Value
Variable Decimal  ZONE     : # Field to be initiliazed (Local Variable used in WMGAU# Processes)
Variable Char     ERRMES() : # Error Message
ZONE = 0 : Gosub EVALE
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
If ZONE=0 : ZONE = DEFVAL : Endif
End [L]ASTATUS


########################################################################################################
## EVAL_DATE
########################################################################################################
#**
#* Evaluates the Date Formula used as parameter
#*
#* @private
#* @param ACTX    Context
#* @param EXPR    Formula
#* @param CALCASE Call case (1:Header 2:Lines 3:Accounting Modifiers)
#* @param DEFVAL  Default Value
#* @param ZONE    Field to be initialized (Local Variable used in WMGAU# Processes)
#* @param ERRMES  Error message
#*!
Subprog EVAL_DATE(ACTX,EXPR,CALCASE,DEFVAL,ZONE,ERRMES)
Variable Instance ACTX   Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     EXPR     : # Formula
Value    Integer  CALCASE  : # Call case (1:Header 2:Lines  3:)
Value    Char     DEFVAL   : # Default Value
Variable Date     ZONE     : # Field to be initiliazed (Local Variable used in WMGAU# Processes)
Variable Char     ERRMES() : # Error Message
ZONE = [0/0/0] : Gosub EVALE
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
If ZONE=[0/0/0] : ZONE = VALDEF : Endif
End [L]ASTATUS


########################################################################################################
## EVAL_INT
########################################################################################################
#**
#* Evaluates the Local Menu Formula used as parameter
#*
#* @private
#* @param ACTX    Context
#* @param EXPR    Formula
#* @param CALCASE Call case (1:Header 2:Lines 3:Accounting Modifiers)
#* @param DEFVAL  Default Value
#* @param ZONE    Field to be initialized (Local Variable used in WMGAU# Processes)
#* @param ERRMES  Error message
#*!
Subprog EVAL_INT(ACTX,EXPR,CALCASE,DEFVAL,ZONE,ERRMES)
Variable Instance ACTX   Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     EXPR     : # Formula
Value    Integer  CALCASE  : # Call case (1:Header 2:Lines  3:)
Value    Char     DEFVAL   : # Default Value
Variable Integer  ZONE     : # Field to be initiliazed (Local Variable used in WMGAU# Processes)
Variable Char     ERRMES() : # Error Message
ZONE = 0 : Gosub EVALE
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
If ZONE=0 : ZONE = DEFVAL : Endif
End [L]ASTATUS


######
$EVALE
Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Char    PRG(GLONADC) : # Sub program Name
Local Integer ERR
PRG = "WMGAU"+[F:GAU]COD
Onerrgo ERREUR
Case CALCASE
 When 1
  Gosub EVAL0 From =PRG
 When 2
  Gosub EVAL_X From =PRG
 When 3
  Gosub ACC_X From =PRG
Endcase
Onerrgo
If ERR
 Case CALCASE
  When 1
   If adxtyp=33 | !clalev([F:GAG]) : Local File GAUTACEF [GAG] : Endif
   Read [GAG]GAG0 = [F:GAU]COD;0;EXPR
   ## Error in field evaluation
   [L]ASTATUS = [V]CST_AERROR : ERRMES = vireblc(format$("KT:80X",[F:GAG]FORCLC),2)-mess(9,114,1)
  When 2
   If adxtyp=33 | !clalev([F:GAG]) : Local File GAUTACEF [GAG] : Endif
   Read [GAG]GAG0 = [F:GAU]COD;[F:GAD]LINNUM;EXPR
   ## Error in field evaluation
   [L]ASTATUS = [V]CST_AERROR : ERRMES = vireblc(format$("KT:80X",[F:GAG]FORCLC),2)-mess(9,114,1)
  When 3
   ## Error in field evaluation
   [L]ASTATUS = [V]CST_AERROR : ERRMES = vireblc(format$("KT:80X",[F:GAD]ACCKEY(val(EXPR))),2)-mess(9,114,1)
 Endcase
Endif
Return

$ERREUR
ERR = errn
Resume
