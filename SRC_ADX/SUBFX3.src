$ACTION
Case ACTION
 When "DEBUT"    : Gosub DEBUT
 When Default
Endcase
Return

$DEBUT
    # format de date et de séparateur decimal    
    Call PARAM("", "FMTFXMDAT", [M:FX3]CH1) From ADOVAL
    Call PARAM("", "FMTFXMDEC", [M:FX3]CH2) From ADOVAL

Return

