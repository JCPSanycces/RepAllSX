#<AdxTL>@(#)3.0.0.0 $Revision$

Call FIN

#    Suppression des fichiers "exportation de données"
  Local Char ARETOUR(100),ANOMF(200),DIRSEP
  Case GOS(1)
   When "dos"   : DIRSEP="\"
   When Default : DIRSEP="/"
  Endcase
  ANOMF = filpath(nomap+DIRSEP+"TMP","F"+num$(adxuid(1))+"*","","X3_PUB") 
  System ARETOUR = adxmac(0)+"@ae_rm "+ANOMF

# Suppression des fenêtres de prévisu
If dim(GVISUW)>0 
  Call SUPWINDIC(nomap,GVISUW) From INTRUTILB
  Kill GVISUW
Endif

End

Subprog FIN
Call WORKFLOW(1,"DEC","",GUSER) From AWRK : # Evènement déconnection
Call DECONNECT From GESUSER
End
