########################################
Subprog AM_VCRTYP(VALEUR)
Variable Integer VALEUR
# FQ 66483 GA 08/2010 utiliser Sélection F12 du type de données VCR, en renseignant WVCROBJ
Case VALEUR
     When 2   : [M]WVCROBJ="SOH"      : # Commandes Vente
     When 10  : [M]WVCROBJ="MFG"      : # OF
     When 36  : [M]WVCROBJ="SCO"      : # EO
Endcase
End

########################################
Subprog AM_PIOSTR(VALEUR)
Variable Integer    VALEUR()
If [M]PIOEND < VALEUR : [M]PIOEND = VALEUR : Endif
End

########################################
Subprog AM_STRDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]STRDATEND = eomonth(VALEUR) : Endif
End

########################################
Subprog C_STRDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]STRDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog C_PIOEND(VALEUR)
Variable Integer    VALEUR
If VALEUR < [M]PIOSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]VCRNUMSTR = ""     : [M]VCRNUMEND = VALEUR  : Endif
If [M]VCRNUMEND < VALEUR : [M]VCRNUMEND = VALEUR  : Endif
End
########################################
Subprog IB_VCRNUMSTR
# FQ 66483 GA 08/2010 utiliser Sélection F12 du type de données VCR au lieu de 4 boutons différents
### If [M]VCRTYP = 10 Raz GBOUT2 Endif
### If [M]VCRTYP =  2 Raz GBOUT1 Endif
### If [M]VCRTYP = 10 Raz GBOUT3 Endif
### If [M]VCRTYP =  2 Raz GBOUT4 Endif
  Gosub SELECTION_VCRNUM
End

########################################
Subprog IB_VCRNUMEND
# FQ 66483 GA 08/2010 utiliser Sélection F12 du type de données VCR au lieu de 4 boutons différents
### If [M]VCRTYP = 10 Raz GBOUT2 Endif
### If [M]VCRTYP =  2 Raz GBOUT1 Endif
### If [M]VCRTYP = 10 Raz GBOUT3 Endif
### If [M]VCRTYP =  2 Raz GBOUT4 Endif
  Gosub SELECTION_VCRNUM
End

$SELECTION_VCRNUM
# FQ 66483 GA 08/2010 GBIDC1=filtre selon site courant action SELOBJCRIT, GBIDC2=Option
Case [M:ALL1]VCRTYP
    When 2 : GBIDC1="[F:SOH]STOFCY=[M]STOFCY & [F:SOH]ORDSTA<>2 & [F:SOH]ALLSTA>1 & [F:SOH]DLVSTA<>3 & [F:SOH]INVSTA<>3" : GBIDC2=""
             GBOUT1=mess(391,198,1)

    When 4 : GBIDC1="[F:SDH]STOFCY=[M]STOFCY & [F:SDH]ALLSTA>1" : GBIDC2=""
             GBOUT1=mess(372,198,1)

    When 10: GBIDC1="[F:MFG]MFGFCY=[M]STOFCY & [F:MFG]MFGSTA=1 & [F:MFG]ALLSTA>1 & [F:MFG]MFGTRKFLG<5" : GBIDC2="A"
             GBOUT1=mess(1,344,1)

    When 36: GBIDC1="[F:SCO]POHFCY=[M]STOFCY & [F:SCO]SCOSTA=1 & [F:SCO]ALLSTA>1 & [F:SCO]SCOTRKFLG<5" : GBIDC2="A"
             GBOUT1=mess(643,197,1)

    When Default : Raz GBOUT1
Endcase
End

########################################
Subprog C_SHTD(VALEUR)
Variable Integer VALEUR
If [M:CRAL]ALLG <> 2 & [M:CRAL]ALLD <> 2 & [M:CRAL]SHTG <> 2 & VALEUR <> 2
   mkstat = 2 : # une case au moins doit être cochée  (16/02/00 TB)
Endif
End


########################################
Subprog AS_NBLIG
If [M]ALLTYP(nolign-1) <> 4 | !find([M]SERMGTCOD(nolign-1),2,3)
    GBOUT1 = ""
Endif
End

########################################
Subprog AS_TRI(VALEUR)
Variable Integer VALEUR
GMENLOC(2)=1
GMENLOC(4)=1
GMENLOC(5)=1
GMENLOC(6)=1
GMENLOC(7)=1
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSALL2) 18/01/2005 13:39:25 (TS)
######################################################################################
Subprog IB_NBLIG
If [M:ALL2]FLGERR(nolign-1)=0
   Raz GBOUT3
Endif
# FQ 66483 GA 08/2010 Bouton2 tunnel vers le document
Case [M:ALL2]VCRTYP(nolign-1)
    When  2  : GBOUT2=mess(391,198,1)-[M:ALL2]VCRNUM(nolign-1)
    When 4,5 : GBOUT2=mess(372,198,1)-[M:ALL2]VCRNUM(nolign-1)
    When 10  : GBOUT2=mess(1,344,1)  -[M:ALL2]VCRNUM(nolign-1)
    When 36  : GBOUT2=mess(643,197,1)-[M:ALL2]VCRNUM(nolign-1)
    When 33  :
    When Default : Raz GBOUT2
Endcase
End

Subprog B3_NBLIG
Raz GMESSAGE
If [M:ALL2]FLGERR(nolign-1)>=8
   GMESSAGE+=mess(378,199,1)-":"-mess(208,184,1)+"\"
   [M:ALL2]FLGERR(nolign-1)-=8
Endif
If [M:ALL2]FLGERR(nolign-1)>=4
   GMESSAGE+=mess(4,196,1)-":"-mess([M:ALL2]TRSTYP(nolign-1),704)+"\"
   [M:ALL2]FLGERR(nolign-1)-=4
Endif
If [M:ALL2]FLGERR(nolign-1)>=2
   GMESSAGE+=mess(460,199,1)+"\"
   [M:ALL2]FLGERR(nolign-1)-=2
Endif
If [M:ALL2]FLGERR(nolign-1)>=1
   GMESSAGE+=mess(126,184,1)
   [M:ALL2]FLGERR(nolign-1)-=1
Endif
Call MESSAGE(GMESSAGE) From GESECRAN
Raz GMESSAGE
End

