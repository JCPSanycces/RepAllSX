#<AdxTL>@(#)3.0.0.0 $Revision$ Consultation ALL
#############################################################################
#                        Consultation                                       #
#                        allocations                                        #
#############################################################################
# Paramètres de la consultation via PARAM()                                 #
# 1  = site                                                                 #
# 2  = code origine 1=OF,2=Commande vente,3=EO                              #
# 3  = article                                                              #
# 4  = Pièce                                                                #
# 5  = Date besoin                                                          #
# 6  = filtre        + 1 - allocations globales                             #
#                    + 2 - allocations détaillées                           #
#                    + 4 - ruptures    globales                             #
#                    + 8 - ruptures    détaillées                           #
# 7 = tri                                                                   #
#                      1 - date besoin                                      #
#                      2 - priorité                                         #
#                      3 - article                                          #
#                      4 - type rupture                                     #
#############################################################################
Local Char PARAM(15)(1..7)
PARAM(1) ="PAR"
PARAM(2) ="3"
PARAM(3) =""
PARAM(4) =""
PARAM(5) =""
PARAM(6) =""
PARAM(7) =""
Call GCONSULT("ALL","",PARAM) From GCONSULT
End


#############################################################################
$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "FERME"      : Gosub FERME
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When Default
Endcase
Return

#############################################################################
# pour gérer l'accès à la consultation
$AUTORIS
Return

#############################################################################
$FERME
Return

#############################################################################
# analyse paramères, initialisations, ouvertures et déclarations
$OUVRE
Local Integer WFLT
Local Integer WSRT
Local Integer I, J, WLEC,WDER, WPREM,WPOS                  # llc 09.02 15624

Local Date    DEBDAT, FINDAT
Local Char    DEBITM, FINITM

Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    CRITERE3(255)
Local Char    WCRITSTO(240)

Local Char    SSTOFCY
Local Char    SITMREF
Local Decimal SSTOCOU
Local Integer SSEQ

Local Integer LRET

NAVIG="CONSALL"

Default Mask [M:ALL1]
Gosub DEFCRIT

If clalev([F:SRU])=0  Local File TABSTORUL  [SRU]  Endif
If clalev([F:ITF])=0  Local File ITMFACILIT [ITF]  Endif

If [M:ALL1]VCRTYP=2 & GMODU(5)=2
  If clalev([F:SOH])=0  : Local File SORDER     [SOH]  : Endif
Endif

#
If [M:CRAL]ALLG <> 2 &
&  [M:CRAL]ALLD <> 2 &
&  [M:CRAL]SHTG <> 2 &
&  [M:CRAL]SHTD <> 2
    [M:CRAL]ALLG = 2
    [M:CRAL]ALLD = 2
Endif
If !find([M:CRAL]TRI,1,2,3,4,5,6,7) : [M:CRAL]TRI = 1 : Endif

SUITE = 1
RETOUR = 1

If [M]VCRTYP=2 GORDCAT=4 Endif
Return

#############################################################################
# analyse paramètres
$DEFCRIT
For I = 1 To dim(PARAM)
    Case I
        When 1 : # site
                 If PARAM(I) <> ""
                     Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                     # GA 09/2006 pb si site donneur d'ordre (achat de sous-traitance)
                     #If !fstat & [F:FCY]MFGFLG = 2 : [M:ALL1]STOFCY = PARAM(I) : Endif
                     If !fstat : [M:ALL1]STOFCY = PARAM(I) : Endif
                 Endif
        When 2 : # code origine
                 If PARAM(I) = "" : PARAM(I) = "1" : Endif
                 Case PARAM(I)
                     When "1": [M:ALL1]VCRTYP = 10
                     When "2": [M:ALL1]VCRTYP = 2
                     When "3": [M:ALL1]VCRTYP = 36   : # GA 07/09/2005 pour Ordre sous-traitance
                 Endcase
                 # FQ 66483 GA 08/2010 utiliser Sélection F12 du type de données VCR, en renseignant WVCROBJ
                 Call AM_VCRTYP([M:ALL1]VCRTYP)
        When 3 : # article
                 If PARAM(I) <> ""
                     Read [ITM]ITM0 = PARAM(I)
                     If !fstat
                         [M:ALL1]ITMREFSTR = PARAM(I)
                         [M:ALL1]ITMREFEND = PARAM(I)
                     Endif
                 Endif
        When 4 : # Pièce
                 If PARAM(I) <> ""
                     [M:ALL1]VCRNUMSTR = PARAM(I)
                     [M:ALL1]VCRNUMEND = PARAM(I)
                 Endif
        When 5 : # date début
                 If PARAM(I) <> ""
                     If instr(1,PARAM(I),"/")
                         [M:ALL1]STRDATSTR = "["+PARAM(I)+"]"
                         [M:ALL1]STRDATEND = "["+PARAM(I)+"]"
                     Else
                         [M:ALL1]STRDATSTR = PARAM(I)
                         [M:ALL1]STRDATEND = PARAM(I)
                     Endif
                 Endif
        When 6 : # filtre
                 If PARAM(I) <> ""
                     WFLT = val(PARAM(I))
                     If WFLT < 0 | WFLT > 15 : WFLT = 3 : Endif
                     If WFLT > 7 : [M:CRAL]SHTD = 2 : WFLT -= 8 : Endif
                     If WFLT > 3 : [M:CRAL]SHTG = 2 : WFLT -= 4 : Endif
                     If WFLT > 1 : [M:CRAL]ALLD = 2 : WFLT -= 2 : Endif
                     If WFLT > 0 : [M:CRAL]ALLG = 2 : WFLT -= 1 : Endif
                 Endif
        When 7 : # tri
                 If PARAM(I) <> ""
                     WSRT = val(PARAM(I))
                     If WSRT < 0 | WSRT > 7 : WSRT = 1 : Endif
                     [M:CRAL]TRI = WSRT
                 Endif
        When Default: Break
    Endcase
Next I
# copie de l'écran critères (Cral) vers le masque 0 (ALL1)
Gosub CRITENT From =PROGCNS
Return

#############################################################################
# chargement tableau
$LECTURE
Local Char SVBPRNUM(GLONBPR)   # FGR 27/06/2014 : X3SUIVI101011

# si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:ALL1]STOFCY = ""  : NBLU = 0 : Return : Endif
If PARAM(7) = "" : PARAM(7) = "1" : Endif
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

# filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
# application des Filtres

If CHGPAG > 0
    SUITE=1
#    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif   # hcb 110305 28506
    Case [M:CRAL]TRI
      When 1 : # tri par date
                Link [STA] With [ORD]ORD3=[F:STA]STOFCY;[F:STA]VCRTYP;[F:STA]VCRNUM;
&                                        [F:STA]VCRLIN;[F:STA]VCRSEQ,
&                               [ITM]ITM0=[F:STA]ITMREF
&                      As [ALL]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)
&                      Order By [F:STA]BESDAT;[F:STA]ITMREF            # llc 09.02 15624

      When 3 : # tri par article
                Link [STA] With [ORD]ORD3=[F:STA]STOFCY;[F:STA]VCRTYP;[F:STA]VCRNUM;
&                                        [F:STA]VCRLIN;[F:STA]VCRSEQ,
&                                        [ITM]ITM0=[F:STA]ITMREF
&                      As [ALL]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)
#&                      Order By [F:STA]ITMREF;[F:STA]STRDAT

    Endcase
Else
    RETOUR=1
#    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif    # hcb 110305 28506
    Case [M:CRAL]TRI
      When 1 : # tri par date
               Link [STA] With [ORD]ORD3=[F:STA]STOFCY;[F:STA]VCRTYP;[F:STA]VCRNUM;
&                                        [F:STA]VCRLIN;[F:STA]VCRSEQ,
&                              [ITM]ITM0=[F:STA]ITMREF
&                      As [ALL]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)
&                      Order By [F:STA]BESDAT Desc;[F:STA]ITMREF Desc

      When 3 : # tri par article
                Link [STA] With [ORD]ORD3=[F:STA]STOFCY;[F:STA]VCRTYP;[F:STA]VCRNUM;
&                                        [F:STA]VCRLIN;[F:STA]VCRSEQ,
&                               [ITM]ITM0=[F:STA]ITMREF
&                      As [ALL]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)
&                      Order By [F:STA]ITMREF Desc

    Endcase
Endif

# raz du masque
If CHGPAG <> 2 & CHGPAG <> -2 : Raz [M:ALL2] : Endif

# lecture
$BOUCLE
Raz SSTOFCY, SITMREF, SSTOCOU, SSEQ

For [ALL]
  # problème double affichage ...
  If SSTOFCY <> ""
      If [F:STA]STOFCY = SSTOFCY &
&        [F:STA]ITMREF = SITMREF &
&        [F:STA]STOCOU = SSTOCOU &
&        [F:STA]SEQ    = SSEQ
         Goto SUIV
      Endif
      # llc 09.02 15624
      J = 0
      For I = 0 To NOL
          If [M:ALL2]VCRNUM(I) = [F:STA]VCRNUM &
&             [M:ALL2]VCRLIN(I) = [F:STA]VCRLIN &
&             [M:ALL2]VCRSEQ(I) = [F:STA]VCRSEQ &
&             [M:ALL2]ITMREF(I) = [F:STA]ITMREF &
&             [M:ALL2]STOCOU(I) = [F:STA]STOCOU &
&             [M:ALL2]SEQ(I)    = [F:STA]SEQ
              J = 1
              Break
          Endif
      Next I
      If J : Goto SUIV : Endif
  Endif

  SSTOFCY = [F:STA]STOFCY
  SITMREF = [F:STA]ITMREF
  SSTOCOU = [F:STA]STOCOU
  SSEQ    = [F:STA]SEQ

# hcb 110305  28506    debut

 # If NBLU = 1
 #    If CHGPAG = 2 | CHGPAG = -2 : Raz [M:ALL2] : Endif
 #    NBLU = 2
 # Endif

 # If CHGPAG > 0
 #    If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
 #    NOL    += 1
 #    If NOL=0
 #        DEBDAT = [F:ORD]STRDAT
 #        DEBITM = [F:STA]ITMREF
 #    Endif
 #    FINDAT = [F:ORD]STRDAT
 #    FINITM = [F:STA]ITMREF
 # Else
 #    If NOL <= 0 : RETOUR = 2 : Break : Endif
 #    NOL    -= 1
 #    If NOL = MAXLIG-1
 #        FINDAT = [F:ORD]STRDAT
 #        FINITM = [F:STA]ITMREF
 #    Endif
 #    DEBDAT = [F:ORD]STRDAT
 #    DEBITM = [F:STA]ITMREF
 # Endif
#
# hcb 110305  28506    fin

   If NOL >= MAXLIG-1                     # hcb 110305  28506
      NBLU = 2                            # hcb 110305  28506
      Break                               # hcb 110305  28506
   Endif                                  # hcb 110305  28506
   NOL    += 1

  nolign = NOL+1
 [M:ALL2]NBLIG = nolign                   # hcb 110305  28506
  Gosub FILLTAB

$SUIV
Next

Return


#############################################################################
# Chargements spéciaux
$FILLTAB
SVBPRNUM = [F:ORD]BPRNUM     # FGR 27/06/2014 : X3SUIVI101011
[M:ALL2] = [F:ORD]
[M:ALL2] = [F:STA]

If [M:ALL2]BPRNUM(nolign-1) = "" and SVBPRNUM <> "" Then
  # FGR 27/06/2014 : X3SUIVI101011
  [M:ALL2]BPRNUM(nolign-1) = SVBPRNUM
Endif

[M:ALL2]STRDAT(nolign-1) = [F:STA]BESDAT
Case [F:STA]ALLTYP
    When 1: [M:ALL2]ALLTYP(nolign-1) = 2
    When 2: [M:ALL2]ALLTYP(nolign-1) = 4
    When 4: [M:ALL2]ALLTYP(nolign-1) = 3
    When 5: [M:ALL2]ALLTYP(nolign-1) = 1
Endcase
Read [ITM]ITM0 = [F:STA]ITMREF
If !fstat
    #[M:ALL2]ITMDES1(nolign-1)     = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:ALL2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [M:ALL2]STU(nolign-1)         = [F:ITM]STU
    [M:ALL2]SERMGTCOD(nolign-1)   = [F:ITM]SERMGTCOD
Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:STA]STOFCY | [F:ITF]ITMREF <> [F:STA]ITMREF
   Read [ITF]ITF0 = [F:STA]ITMREF;[F:STA]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif





# (titres llc v130)
If [F:ITF]STOMGTCOD = 3 & dim([M:ALL2]DEFPOT(nolign-1)) > 0
    [M:ALL2]DEFPOT(nolign-1) = [F:ITM]DEFPOT
Else
    If dim([M:ALL2]QTYSTU(nolign-1)) > 0 : [M:ALL2]QTYSTU(nolign-1) = 0 : Endif
    If dim([M:ALL2]DEFPOT(nolign-1)) > 0 : [M:ALL2]DEFPOT(nolign-1) = 0 : Endif
Endif

[M:ALL2]ALLQTY(nolign-1) = [F:STA]QTYSTUACT
# Issue 107513 GA 04/2015 + screen mask CONSALL2 + inquiry ALL/STD
If dim([F:STA]ECCVALMAJ)>0 & dim([M:ALL2]ECCVALMAJ)>0
   [M:ALL2]ECCVALMAJ(nolign-1)  = [F:STA]ECCVALMAJ
Endif
If dim([F:STA]ECCVALMIN)>0 & dim([M:ALL2]ECCVALMIN)>0
   [M:ALL2]ECCVALMIN(nolign-1)  = [F:STA]ECCVALMIN
Elsif dim([M:ALL2]ECCVALMIN)>0
   Chgfmt [M:ALL2]ECCVALMIN   With "-K:1X"
Endif
If [F:STA]ALLTYP = 2
    Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU
    If fstat = 0
        [M:ALL2]LOT(nolign-1)    = [F:STO]LOT
        [M:ALL2]SLO(nolign-1)    = [F:STO]SLO
        [M:ALL2]LOC(nolign-1)    = [F:STO]LOC
        [M:ALL2]STA(nolign-1)    = [F:STO]STA
        [M:ALL2]SERNUM(nolign-1) = [F:STO]SERNUM
        #MAE, bg68139
        If dim([M:ALL2]WRH) >0
            [M:ALL2]WRH(nolign-1) = [F:STO]WRH
        Endif
        # Issue 107513 GA 04/2015 + screen mask CONSALL2 + inquiry ALL/STD
        If dim([F:STO]ECCVALMAJ)>0 & dim([M:ALL2]ECCVALMAJ)>0
           [M:ALL2]ECCVALMAJ(nolign-1)  = [F:STO]ECCVALMAJ
        Endif
        If dim([F:STO]ECCVALMIN)>0 & dim([M:ALL2]ECCVALMIN)>0
           [M:ALL2]ECCVALMIN(nolign-1)  = [F:STO]ECCVALMIN
        Endif
    Endif
    If [F:ITF]STOMGTCOD = 3 & dim([M:ALL2]DEFPOT(nolign-1)) > 0
        Read [STL]STL0=[M:ALL2]ITMREF(nolign-1);[M:ALL2]LOT(nolign-1);[M:ALL2]SLO(nolign-1)
        If !fstat
            [M:ALL2]DEFPOT(nolign-1) = [F:STL]POT
        Endif
    Endif

    #----------------------------------------------------------
    # V150 : vérification que l'on peut consommer l'allocation
    #----------------------------------------------------------
    If [M:ALL1]VCRTYP=2
        Read [SOH]SOH0=[F:STA]VCRNUM
        If !fstat & [F:SOH]SOHCAT=2
            [M:ALL2]TRSTYP(nolign-1)=17
        Else
            [M:ALL2]TRSTYP(nolign-1)=4
        Endif
    Elsif [M:ALL1]VCRTYP=10
        [M:ALL2]TRSTYP(nolign-1)=6
    Elsif [M:ALL1]VCRTYP=36
        [M:ALL2]TRSTYP(nolign-1)=29
    Endif

    # Si la catégorie article est différente de celle de la dernière règle lue
    If nolign=1 | [F:ITM]TCLCOD<>[F:SRU]TCLCOD | [M:ALL2]TRSTYP(nolign-1)<>[M:ALL2]TRSTYP(nolign-2)
        Call LECSRU([M:ALL1]STOFCY,[F:ITM]TCLCOD,[M:ALL2]TRSTYP(nolign-1),"","",LRET) From STKLIB
        If LRET=1
            Raz [F:SRU]
            WCRITSTO = "1=1"
        Else
            # Stockage dans WCRITSTO des statuts/sous-statuts autorisés
            Call CTRL_STATUT("[F:STO]","",WCRITSTO) From STKALL
        Endif
    Endif

    Raz [M:ALL2]FLGERR(nolign-1)
    # Si inventaire en cours ou demande d'analyse ou statut interdit
    If [F:STO]CUNLOKFLG=2   [M:ALL2]FLGERR(nolign-1)+=1  Endif
    If [F:STO]QLYCTLDEM<>"" [M:ALL2]FLGERR(nolign-1)+=2  Endif
    If !evalue(WCRITSTO)    [M:ALL2]FLGERR(nolign-1)+=4  Endif
    # La ligne de stock en attente de rangement est-elle complète?
    If [F:STO]LOCCAT=2
        Raz LRET
        Call CTLPLFLOC([F:ITM]ITMREF,"[F:STO]",LRET) From STKSOR
        If LRET<>0  [M:ALL2]FLGERR(nolign-1)+=8  Endif
    Endif

Endif

If [F:STA]ALLTYP = 1
    If [F:ITF]STOMGTCOD = 3 & dim([M:ALL2]DEFPOT(nolign-1)) > 0
        [M:ALL2]QTYSTU(nolign-1) = ([M:ALL2]ALLQTY(nolign-1) * 100) / [M:ALL2]DEFPOT(nolign-1)
    Endif
Endif

Return

#############################################################################
# Préparation du filtre sur la table operations                             #
#############################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

If [M:CRAL]ALLG = 2
    CRITERE  = "[F:STA]ALLTYP=1"
    Gosub LOAD_CRITERE
Endif

If [M:CRAL]ALLD = 2
    CRITERE  = "[F:STA]ALLTYP=2"
    Gosub LOAD_CRITERE
Endif

If [M:CRAL]SHTG = 2
    CRITERE  = "[F:STA]ALLTYP=5"
    Gosub LOAD_CRITERE
Endif

If [M:CRAL]SHTD = 2
    CRITERE  = "[F:STA]ALLTYP=4"
    Gosub LOAD_CRITERE
Endif

If [M:CRAL]ALLG = 2 | [M:CRAL]ALLD = 2 | [M:CRAL]SHTG = 2 | [M:CRAL]SHTD = 2
# fin de la première partie
    CRITERE1 += ")"
Else
    CRITERE1 = "!find([F:STA]ALLTYP, 1,2,5,4)"
Endif

Case [M:ALL1]VCRTYP
    When 10: CRITERE  = "[F:STA]VCRTYP=10"
    When 2 : CRITERE  = "[F:STA]VCRTYP<3"
    When 36: CRITERE  = "[F:STA]VCRTYP=36"  : # GA 07/09/2005 pour Ordre sous-traitance
Endcase
Gosub LOAD_CRITERE2

# site
If [M:ALL1]STOFCY <> ""
   CRITERE = "[F:STA]STOFCY=[M:ALL1]STOFCY"
   Gosub LOAD_CRITERE2
Endif

# article
If [M:CRAL]ITMREFSTR <> ""
    CRITERE = "[F:STA]ITMREF>=[M:CRAL]ITMREFSTR"
    Gosub LOAD_CRITERE2
Endif
If [M:CRAL]ITMREFEND <> ""
    CRITERE = "[F:STA]ITMREF<=[M:CRAL]ITMREFEND"
    Gosub LOAD_CRITERE2
Endif

# pièce
If [M:CRAL]VCRNUMSTR <> ""
   CRITERE = "[F:STA]VCRNUM>=[M:CRAL]VCRNUMSTR"
   Gosub LOAD_CRITERE2
Endif
If [M:CRAL]VCRNUMEND <> ""
   CRITERE = "[F:STA]VCRNUM<=[M:CRAL]VCRNUMEND"
   Gosub LOAD_CRITERE2
Endif

# date
Raz CRITERE
If [M:CRAL]STRDATSTR <> [0/0/0]
   CRITERE = "([F:ORD]STRDAT>=[M:CRAL]STRDATSTR&[F:ORD]STRDAT<=[M:CRAL]STRDATEND)"
Endif
If [M:CRAL]STRDATEND <> [0/0/0]
   If CRITERE<>"" CRITERE += "|" Endif
   CRITERE+= "([F:ORD]ENDDAT>=[M:CRAL]STRDATSTR&[F:ORD]ENDDAT<=[M:CRAL]STRDATEND)"
Endif
If CRITERE<>""
   # FGR 11/08/2014 : X3SUIVI85588 : c'est pas find mais instr qu'il faut utiliser pour faire ça.
   #If find("|",CRITERE) CRITERE+="("+CRITERE+")" Endif
   If instr(0, CRITERE, "|") Then
    CRITERE ="("+CRITERE+")"
   Endif
   Gosub LOAD_CRITERE3
Endif

# date
If [M:CRAL]PIOSTR <> 0
    CRITERE = "[F:ORD]PIO>=[M:CRAL]PIOSTR"
    Gosub LOAD_CRITERE3
Endif
If [M:CRAL]PIOEND <> 0
    CRITERE = "[F:ORD]PIO<=[M:CRAL]PIOEND"
    Gosub LOAD_CRITERE3
Endif
Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CRAL]TRI
       When 1 : # tri par date
           CRITERE = "[F:ORD]STRDAT>=DEBDAT"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:STA]ITMREF>=DEBITM"
           Gosub LOAD_CRITERE3
     Endcase
   When 2 : # suite
     Case [M:CRAL]TRI
       When 1 : # tri par date
           CRITERE = "[F:ORD]STRDAT>FINDAT"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:STA]ITMREF>FINITM"
           Gosub LOAD_CRITERE3
     Endcase
   When -2 : # retour
     Case [M:CRAL]TRI
       When 1 : # tri par date
           CRITERE = "[F:ORD]STRDAT<DEBDAT"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:STA]ITMREF<DEBITM"
           Gosub LOAD_CRITERE3
     Endcase
Endcase
If CRITERE3 = "" : CRITERE3 = "1=1" : Endif
If CRITERE1 = "" : CRITERE1 = "1=1" : Endif
Return

#############################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE
Return

#############################################################################
$SETBOUT
Return

#############################################################################
$EXEBOUT
Return

#############################################################################
#    ETIQUETTES ECRAN
#############################################################################

########################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFSTR = ""     : [M]ITMREFEND = VALEUR : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Endif
End
