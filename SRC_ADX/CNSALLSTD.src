# FQ 57754 Module Stocks GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"ALL") From SUBGTC

End

# hcb 80546 deb
######################################################################################
Subprog B2_NBLIG
Local Integer NOL : NOL = nolign-1
Call LNK2VCR([M:ALL2]VCRTYP(NOL),[M:ALL2]VCRNUM(NOL))
End

######################################################################################
Subprog LNK2VCR(PTYP, PNUM)
Value Integer PTYP
Value Char    PNUM

GCONSULT = 2
Case PTYP
When 2   # commande vente
    Call OBJET("SOH",PNUM,num$(PTYP)) From GOBJET
When 4   # livraison
    Call OBJET("SDH",PNUM,num$(PTYP)) From GOBJET
When 5   # Facture vente
    Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
When 10  # ordre de fabrication
    Call OBJET("MFG",PNUM,num$(PTYP)) From GOBJET
When 36  # Ordre de sous-traitance
    Call OBJET("SCO",PNUM,num$(PTYP)) From GOBJET
Endcase
GCONSULT = 0
End
# hcb 80546 fin

