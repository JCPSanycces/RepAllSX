#<AdxTL>@(#)0.0.0.0 $Revision$Class Sequential file
# Supervisor
## CRUD-CLASSE ## EDISEQFIL
# 2018-11-06 07:05:06 546


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(EDISEQFIL,ASTATUS)
Variable Instance EDISEQFIL Using C_EDISEQFIL
Variable Integer ASTATUS

If EDISEQFIL = null : End : Endif

Gosub _AVARIABLES From WMC00EDISEQFIL

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_EDISEQFIL

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EDISEQFIL,ASTATUS)
Variable Instance EDISEQFIL Using C_EDISEQFIL
Variable Integer ASTATUS

If EDISEQFIL = null : End : Endif

Gosub AVARIABLES From WMC00EDISEQFIL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
EDISEQFIL.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EDISEQFIL
Else
 Gosub AUPDATE_EDISEQFIL
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EDISEQFIL.freeSnapshot
EDISEQFIL.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EDISEQFIL._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EDISEQFIL._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EDISEQFIL._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EDISEQFIL.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDISEQFIL.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EDISEQFIL.ASTALIN)<>""
 [L]A_ASTALIN = EDISEQFIL.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
For [L]A_I=1 To maxtab(EDISEQFIL.ESFN)
 If EDISEQFIL.ESFN([L]A_I)<>null
  [L]A_ASTALIN = EDISEQFIL.ESFN([L]A_I).ASTALIN
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFN([L]A_I).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDISEQFIL.ESFD) : # EDISEQFILD -- 2
 If EDISEQFIL.ESFD(A_N2) <> null
& and EDISEQFIL.ESFD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDISEQFIL.ESFD(A_N2).ASTALIN<>[V]CST_ANEW & EDISEQFIL.ASTALIN=[V]CST_ADEL
   EDISEQFIL.ESFD(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If EDISEQFIL.ESFD(A_N2).ASTALIN=[V]CST_ANEW & find(EDISEQFIL.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   EDISEQFIL.ESFD(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(EDISEQFIL.ESFD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDISEQFIL.ESFD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDISEQFIL.ESFF) : # EDISEQFILF -- 3
 If EDISEQFIL.ESFF(A_N2) <> null
& and EDISEQFIL.ESFF(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDISEQFIL.ESFF(A_N2).ASTALIN<>[V]CST_ANEW & EDISEQFIL.ASTALIN=[V]CST_ADEL
   EDISEQFIL.ESFF(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If EDISEQFIL.ESFF(A_N2).ASTALIN=[V]CST_ANEW & find(EDISEQFIL.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   EDISEQFIL.ESFF(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(EDISEQFIL.ESFF(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDISEQFIL.ESFF(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER
For A_N2=1 To maxtab(EDISEQFIL.ESFD) : # EDISEQFILD -- 2
 If EDISEQFIL.ESFD(A_N2) <> null
& and EDISEQFIL.ESFD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(EDISEQFIL.ESFD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDISEQFIL.ESFD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDISEQFIL.ESFF) : # EDISEQFILF -- 3
 If EDISEQFIL.ESFF(A_N2) <> null
& and EDISEQFIL.ESFF(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(EDISEQFIL.ESFF(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDISEQFIL.ESFF(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_I=1 To maxtab(EDISEQFIL.ESFN)
 If EDISEQFIL.ESFN([L]A_I)<>null
  [L]A_ASTALIN = EDISEQFIL.ESFN([L]A_I).ASTALIN
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFN([L]A_I).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [V]CST_ASTALIN(EDISEQFIL.ASTALIN)<>""
 [L]A_ASTALIN = EDISEQFIL.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EDISEQFIL
Trbegin [F:ESF]
 Gosub AUPDATE_EDISEQFIL
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_EDISEQFIL
[L]A_ASTALIN = EDISEQFIL.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDISEQFIL._MAJSQL_EDISEQFIL(EDISEQFIL))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_TYPMAJ=[V]CST_ADEL,[V]CST_AUPD,[V]CST_ANEW
 #-----------------------#
 For A_N2=1 To maxtab(EDISEQFIL.ESFD)
  If EDISEQFIL.ESFD(A_N2) <> null and
& (EDISEQFIL.ESFD(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDISEQFIL.ESFD(A_N2).ASTALIN=[V]CST_ALL)
   If EDISEQFIL.ESFD(A_N2).ASTALIN=[L]A_TYPMAJ
    If [V]CST_ASTALIN(EDISEQFIL.ESFD(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDISEQFIL.ESFD(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
    [L]ASTATUS = func WMC00EDISEQFIL._MAJSQL_EDISEQFILD(EDISEQFIL.ESFD(A_N2))
    If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    If [V]CST_ASTALIN(EDISEQFIL.ESFD(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDISEQFIL.ESFD(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
   Endif
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
 Next A_N2
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 #-----------------------#
 #-----------------------#
 For A_N2=1 To maxtab(EDISEQFIL.ESFF)
  If EDISEQFIL.ESFF(A_N2) <> null and
& (EDISEQFIL.ESFF(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDISEQFIL.ESFF(A_N2).ASTALIN=[V]CST_ALL)
   If EDISEQFIL.ESFF(A_N2).ASTALIN=[L]A_TYPMAJ
    If [V]CST_ASTALIN(EDISEQFIL.ESFF(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDISEQFIL.ESFF(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
    [L]ASTATUS = func WMC00EDISEQFIL._MAJSQL_EDISEQFILF(EDISEQFIL.ESFF(A_N2))
    If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    If [V]CST_ASTALIN(EDISEQFIL.ESFF(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDISEQFIL.ESFF(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
   Endif
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
 Next A_N2
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 #-----------------------#
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]A_ASTALIN = EDISEQFIL.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EDISEQFIL.snapshotEnabled=1
 [L]A_RETIK = EDISEQFIL.revertUpdTick
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDISEQFIL.ESFD)
 If EDISEQFIL.ESFD(A_N2) <> null
  If EDISEQFIL.ESFD(A_N2).ASTALIN=[V]CST_ANEWDEL
   EDISEQFIL.ESFD(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDISEQFIL.ESFF)
 If EDISEQFIL.ESFF(A_N2) <> null
  If EDISEQFIL.ESFF(A_N2).ASTALIN=[V]CST_ANEWDEL
   EDISEQFIL.ESFF(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2

[L]ASTATUS = max(fmet EDISEQFIL.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EDISEQFIL.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EDISEQFIL.ASTALIN = [V]CST_ALL
Endif
For [L]A_I=1 To maxtab(EDISEQFIL.ESFN)
 If EDISEQFIL.ESFN([L]A_I)<>null
  If EDISEQFIL.ESFN([L]A_I).ASTALIN=[V]CST_ADEL or EDISEQFIL.ESFN([L]A_I).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDISEQFIL.ESFN([L]A_I)
   EDISEQFIL.ESFN([L]A_I) = null
  Elsif EDISEQFIL.ESFN([L]A_I).ASTALIN <> [V]CST_ALL
   EDISEQFIL.ESFN([L]A_I).ASTALIN = [V]CST_ALL
  Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDISEQFIL.ESFD)
 If EDISEQFIL.ESFD(A_N2) <> null
  If EDISEQFIL.ESFD(A_N2).ASTALIN=[V]CST_ADEL or EDISEQFIL.ESFD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDISEQFIL.ESFD(A_N2)
   EDISEQFIL.ESFD(A_N2) = null
  Elsif EDISEQFIL.ESFD(A_N2).ASTALIN <> [V]CST_ALL
   EDISEQFIL.ESFD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDISEQFIL.ESFF)
 If EDISEQFIL.ESFF(A_N2) <> null
  If EDISEQFIL.ESFF(A_N2).ASTALIN=[V]CST_ADEL or EDISEQFIL.ESFF(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDISEQFIL.ESFF(A_N2)
   EDISEQFIL.ESFF(A_N2) = null
  Elsif EDISEQFIL.ESFF(A_N2).ASTALIN <> [V]CST_ALL
   EDISEQFIL.ESFF(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return



