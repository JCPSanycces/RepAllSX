#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DKK1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:57"
A_USER  = "DOC"
A_STAMP = "20181109230357"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask DKK1 [DKK1]
Gosub HORODAT
Local Inpbox "DKK1" From GFONCTION At A_STAMP With A_WINDPREV Mask [DKK1] As [SIM_]
Grizo [DKK1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DKK1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=28
Return

$ON_KEYDES
Onevent INIT_AREA Call D_KEYDES(zc) From W1DKK1
Onevent BEFORE_INPUT Call AS_KEYDES(zc) From W1DKK1
Return

Subprog IB_KEYDES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_KEYDES(VALEUR)
Variable Char    VALEUR()
If varinit([M]KEYDES,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"DKSKEY","KEYDES",[M]KEYCODE,num$([M]KEYVER)) From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_KEYDES(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_KEYDES(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_KEYDES(zc) From W1DKK1
Gosub _AFF
End

Subprog B1_KEYDES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_KEYDES" : PROGSUB = "SUBDKK" : PROGSPE = "SPEDKK" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "DKSKEY"
 PARMSK(2) = "KEYDES"
 PARMSK(3) = [M]KEYCODE
 PARMSK(4) = num$([M]KEYVER)
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_KEYDES" : PROGSUB = "SUBDKK" : PROGSPE = "SPEDKK" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_STRDAT
Onevent BEFORE_AREA Gosub AV_STRDAT From W1DKK1
Return

$AV_STRDAT
Chgfmt [M]STRDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_ANMCODE
Return

$ON_UPDUSR
Return

$ON_CREUSR
Return

$CHG_STY
Return


