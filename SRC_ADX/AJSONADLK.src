###########################################################################################
#  generation des json pour les kits
#  action a lancer en batch 
###########################################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AJSONADLK","",2,"") From GTRAITE

End
##################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "AVANT_PAR"   : TIT = mess(75,7999,1)
 When "EXEC"        : Gosub EXEC
Endcase
Return

##################################################################
$INIT
Return

##################################################################
$EXEC
Local Integer WOK
WOK = 0
Local Integer WTYPE
WTYPE = 2
# generation json tous kits actifs
# cg 24 fev 2014 : on ne genere plus ce fichier car on livre les tables
#Call JSON_ALL_ADLV (WOK,WTYPE) From SUBADLV
Return

