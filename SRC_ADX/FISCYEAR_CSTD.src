#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe FISCYEAR

$ACTION
  Case CURPRO
    When ""         : Gosub CLASS      : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is a hook called on properties
  Endcase
Return

###############
# CLASS
###############
$CLASS
  Case CURPTH
    When ""
      Case ACTION
        When "AREAD_AFTER" : Gosub AREAD_AFTER_FISCYEAR
      Endcase
  Endcase
Return

$AREAD_AFTER_FISCYEAR
  Local Integer I_PER : [L]I_PER = 1

  # Calcul des totaux mois/semaines/jours
  While this.PERIOD([L]I_PER) <> null
    this.TOTMON += this.PERIOD([L]I_PER).NBRMONPER
    this.TOTWEK += this.PERIOD([L]I_PER).NBRWEKPER
    this.TOTDAY += this.PERIOD([L]I_PER).NBRDAYPER
    I_PER += 1
  Wend
Return

###############
# PROPERTIES
###############
$PROPERTIES
  Case CURPRO
    When Default
  Endcase
Return

$METHODS
Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

