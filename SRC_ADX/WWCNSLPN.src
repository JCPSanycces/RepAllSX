#<AdxTL>@(#)%I%
# Supervisor
# Inquiry LPN

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:09"
A_USER  = "ADMIN"
A_STAMP = "20181109081109"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(1004088,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSLPNSTD"
PROGSPE    = "CNSLPNSPE"
CBOITE     = "DCNSLPN"
BOITE      = "FCNSLPN"
NOMMSK(0)  = "CONSLPN1"
ABMSK(0)   = "CLPN1"
NOMMSK(1)  = "CONSLPN2"
ABMSK(1)   = "CLPN2"
CMEMO      = "lpn"
CNOMMSK    = "CRITLPN"
CABMSK     = "CRLPN"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CRLPN]
 When  0 : Local Mask =NOMMSK(0) [CLPN1]
 When  1 : Local Mask =NOMMSK(1) [CLPN2]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CRLPN]
 When  0 : Grizo [CLPN1]
 When  1 : Grizo [CLPN2]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
If dim([M:CRLPN]LOCCAT001)>0
 Grizo [CRLPN]LOCCAT001
Endif
If dim([M:CRLPN]LOCCAT002)>0
 Grizo [CRLPN]LOCCAT002
Endif
If dim([M:CRLPN]CUMFLG)>0
 Grizo [CRLPN]CUMFLG
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CRLPN])>0 : Close Local Mask [CRLPN] : Endif
 When  0 : If clalev([M:CLPN1])>0 : Close Local Mask [CLPN1] : Endif
 When  1 : If clalev([M:CLPN2])>0 : Close Local Mask [CLPN2] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CRLPN]
 When  0 : Default Mask [CLPN1]
 When  1 : Default Mask [CLPN2]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CRLPN]
 When  0 : Raz [M:CLPN1]
 When  1 : Raz [M:CLPN2]
Endcase
Return

$CRITENT
If dim([M:CRLPN]LOCCAT001)>0 & dim([M:CLPN1]LOCCAT001)>0
 [M:CRLPN]LOCCAT001 = [M:CLPN1]LOCCAT001
Endif
If dim([M:CRLPN]LOCCAT002)>0 & dim([M:CLPN1]LOCCAT002)>0
 [M:CRLPN]LOCCAT002 = [M:CLPN1]LOCCAT002
Endif
If dim([M:CRLPN]CUMFLG)>0 & dim([M:CLPN1]CUMFLG)>0
 [M:CRLPN]CUMFLG = [M:CLPN1]CUMFLG
Endif
Return

$ENTCRIT
If dim([M:CRLPN]LOCCAT001)>0 & dim([M:CLPN1]LOCCAT001)>0
[M:CLPN1]LOCCAT001 = [M:CRLPN]LOCCAT001
Endif
If dim([M:CRLPN]LOCCAT002)>0 & dim([M:CLPN1]LOCCAT002)>0
[M:CLPN1]LOCCAT002 = [M:CRLPN]LOCCAT002
Endif
If dim([M:CRLPN]CUMFLG)>0 & dim([M:CLPN1]CUMFLG)>0
[M:CLPN1]CUMFLG = [M:CRLPN]CUMFLG
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
NBCA = 0
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSLPN2"
NBBOUT = 0
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "LPN"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M:CLPN1]FCY,"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M:CLPN2]ITMREF(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$([M:CLPN2]STOCOU(nolign-1)),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B1"
  Onerrgo RIEN
  Assign "[M:CLPN1]FCY" With ctrans(func AFNC.PART(INFO,4),"¨","~")
  Assign "[M:CLPN2]ITMREF(nolign-1)" With ctrans(func AFNC.PART(INFO,5),"¨","~")
  Assign "[M:CLPN2]STOCOU(nolign-1)" With val(ctrans(func AFNC.PART(INFO,12),"¨","~"))
  Onerrgo
  Call B1_NBLIG From ="W1CONSLPN2"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


