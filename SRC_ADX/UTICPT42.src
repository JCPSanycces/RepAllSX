#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################
# UTICPT42   Raz de la table GRPACEMTC pour le code STEP1   Module CPT   #
#                                                                        #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER = "X3"
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Reset tables GRPACEMTC & GRPAUTACE for the code 'STEP1'") From LECFIC

  Call MAJ_UTICPT42(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT42(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR, I
Local Char OLANGUE (GLONLAN)

Call ECR_TRACE("UTICPT42 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:GRM])=0 : Local File =DOSSIER+".GRPACEMTC"   [GRM] : Endif
If clalev([F:GRA])=0 : Local File =DOSSIER+".GRPAUTACE"   [GRA] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [GRM]
 Delete [GRM] Where COD="STEP1"
 If fstat=1
  # Erreur d'effacement
  Call ECR_TRACE("UTICPT42 : "+mess(28,125,1)-"GRPACEMTC",0) From GESECRAN
  Goto ABANDON
 Endif 
 Readlock [GRA]GRA0="STEP1"
 If fstat=1
  # Enregistrement verrouillé
  Call ECR_TRACE("UTICPT42 : "+mess(60,100,1)-"STEP1",0) From GESECRAN
  Goto ABANDON
 Elsif fstat
  Raz [GRA]
  [F:GRA]COD       = "STEP1"
  [F:GRA]DES       = "Première comptabilisation"
  [F:GRA]DESSHO    = "Etape 1"
  [F:GRA]CODACE(0) = "PRINC"
  [F:GRA]CODACE(1) = "PYODT"
  [F:GRA]CODACE(2) = "PYODH"
  [F:GRA]CODACE(3) = "PYODD"
  [F:GRA]CODACE(4) = "BKACC"
  [F:GRA]CODACE(5) = "ACCBP"
  [F:GRA]CREDAT    = date$
  [F:GRA]CREUSR    = GUSER
  Write [GRA]
  If fstat
   # Erreur d'écriture
   Call ECR_TRACE("UTICPT42 : "+mess(26,125,1)-"STEP1",0) From GESECRAN
   Goto ABANDON
  Endif 
 Else
  [F:GRA]DES       = "Première comptabilisation"
  [F:GRA]DESSHO    = "Etape 1"
  [F:GRA]CODACE(0) = "PRINC"
  [F:GRA]CODACE(1) = "PYODT"
  [F:GRA]CODACE(2) = "PYODH"
  [F:GRA]CODACE(3) = "PYODD"
  [F:GRA]CODACE(4) = "BKACC"
  [F:GRA]CODACE(5) = "ACCBP"
  [F:GRA]UPDDAT    = date$
  [F:GRA]UPDUSR    = GUSER
  Rewrite [GRA]
  If fstat
   # Erreur de réécriture
   Call ECR_TRACE("UTICPT42 : "+mess(27,125,1)-"STEP1",0) From GESECRAN
   Goto ABANDON
  Endif
 Endif

 OGLANGUE = GLANGUE
 For I=0 To dim([F:ADS]LAN)-1
  GLANGUE = [F:ADS]LAN(I)
  Case [F:ADS]LAN(I)
   When "FRA"
    Call MAJTEXTRA("Etape 1","GRPAUTACE","SHOTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
    Call MAJTEXTRA("Première comptabilisation","GRPAUTACE","DESTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
   When "ENG"
    Call MAJTEXTRA("Stage 1","GRPAUTACE","SHOTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
    Call MAJTEXTRA("First posting","GRPAUTACE","DESTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
   When "POR"
    Call MAJTEXTRA("Etapa1","GRPAUTACE","SHOTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
    Call MAJTEXTRA("Primeira contabilização","GRPAUTACE","DESTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
   When "ITA"
    Call MAJTEXTRA("Step 1","GRPAUTACE","SHOTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
    Call MAJTEXTRA("Prima contabilizzazione","GRPAUTACE","DESTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
   When "SPA"
    Call MAJTEXTRA("Etapa 1","GRPAUTACE","SHOTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
    Call MAJTEXTRA("Primera contabilización","GRPAUTACE","DESTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
   When "BRI"
    Call MAJTEXTRA("Step 1","GRPAUTACE","SHOTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
    Call MAJTEXTRA("First accounting postings","GRPAUTACE","DESTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
   When "CHI"
    Call MAJTEXTRA("Etape 1","GRPAUTACE","SHOTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
    Call MAJTEXTRA("Première comptabilisation","GRPAUTACE","DESTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
   When "GER"
    Call MAJTEXTRA("ZaBuStep1","GRPAUTACE","SHOTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
    Call MAJTEXTRA("Zahlbuchung Step 1","GRPAUTACE","DESTRA","STEP1","") From ATEXTRA
    If GOK<1 : Break : Endif
  Endcase
 Next
 GLANGUE = OGLANGUE
 
 If GOK<1 : Goto ABANDON : Endif

 Raz [F:GRM]
 [F:GRM]COD = "STEP1"
 Call WRITE_GRM(1,"PRINC",10,"","",2,0,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(2,"PRINC",11,"PYODT","",0,1,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(3,"PRINC",12,"PRINC","",0,52,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(4,"PRINC",12,"PRINC","",0,55,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(5,"PRINC",12,"PRINC","",0,58,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(6,"PRINC",12,"ACCBP","",0,52,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(7,"PRINC",12,"ACCBP","",0,55,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(8,"PRINC",12,"ACCBP","",0,58,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(9,"PRINC",19,"PYODD","",0,10,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(10,"PRINC",19,"PYODH","",0,10,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(11,"PRINC",20,"PYODH","",0,10,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(12,"PRINC",37,"PYODH","",0,30,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(13,"PRINC",40,"PYODH","",0,30,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(14,"PRINC",50,"","",2,0,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(15,"PRINC",53,"","",2,0,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(16,"PRINC",56,"","",2,0,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(17,"PRINC",51,"PYODT","",0,10,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(18,"PRINC",54,"PYODT","",0,10,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(19,"PRINC",57,"PYODT","",0,10,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(20,"PRINC",70,"PYODD","",0,30,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(21,"PYODT",2,"","",2,0,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(22,"PYODT",10,"ACCBP","",0,51,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(23,"PYODT",10,"ACCBP","",0,54,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(24,"PYODT",10,"ACCBP","",0,57,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(25,"PYODT",11,"","",2,0,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(26,"PYODD",20,"","",2,0,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(27,"PYODT",40,"","",2,0,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(28,"PYODD",30,"ACCBP","",0,70,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(29,"PYODH",30,"BKACC","",0,37,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(30,"PYODH",30,"BKACC","",0,40,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(31,"ACCBP",50,"","",2,0,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(32,"ACCBP",53,"","",2,0,0)
 If fstat : Goto ABANDON : Endif
 Call WRITE_GRM(33,"ACCBP",56,"","",2,0,0)
 If fstat : Goto ABANDON : Endif

Commit

Filter [GRM] Where COD="STEP1"
COMPTEUR = rowcount ([F:GRM])
Filter [GRM]

Close Local File [GRM], [GRA]

Call ECR_TRACE("UTICPT42 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

Subprog WRITE_GRM(NUMORD,CODACE1,LIG1,CODACE2,CODACE3,INVMTC,LIG2,LIG3)
Value Char    CODACE1, CODACE2, CODACE3
Value Integer NUMORD, LIG1, LIG2, LIG3, INVMTC
[F:GRM]NUMORD  = NUMORD
[F:GRM]CODACE1 = CODACE1
[F:GRM]LIG1    = LIG1
[F:GRM]CODACE2 = CODACE2
[F:GRM]LIG2    = LIG2
[F:GRM]CODACE3 = CODACE3
[F:GRM]LIG3    = LIG3
[F:GRM]INVMTC  = INVMTC
Write [GRM]
If fstat
 # Erreur d'écriture
 Call ECR_TRACE("UTICPT42 : "+mess(26,125,1)-"STEP1"-num$([L]NUMORD),0) From GESECRAN
Endif
End

$ABANDON
Close Local File [GRM], [GRA]
Rollback
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI<>"X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif 
If [F:ADS]MODULE(1)<>2 : End : Endif
If filinfo(filpath("FIL","GRPACEMTC","fde",APPLI),0)<=0 : End : Endif   
Call MAJ_UTICPT42(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI<>"X3" End : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif
If filinfo(filpath("FIL","GRPACEMTC","fde",APPLI),0)<=0 : End : Endif  
Call MAJ_UTICPT42(APPLI)
End
