#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Gestion du masque SHIPS
# Caution, this screen is manage with hybrid code
# Author : MAE
# Parameters : EXETYP   : 1 : close a shipment line
#                       : 2 : close a shipment
#                       : 3 : close a container
#              CTRNUM   : container num
#              CLSUNCLS : 1 : close
#                       : 2 : unclose
# Action : SHIPSOLD : solde d'une ligne d'expé ou de pré-reception
#          SHIPSOLDAL : solde d'une expédition compléte
#          SHIPSOLDCTR : solde d'un conteneneur
######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur
######################################################################################
$ACTION
Case ACTION
 When "INIT_DIA"            : Gosub INIT_DIA
 When "AVANT_PAR"       : Gosub AVANT_PAR
 When "EXEC"            : Gosub EXEC
 When "SORTIE"          : Gosub SORTIE
 When Default
Endcase
Return

######################################################################################
$INIT_DIA
[M:SHIPS]QTYEXPFLG = 2
Return
######################################################################################
$AVANT_PAR
Local Integer WTYPEXEC,WTYPCLOS
Local Char WCTRNUM(GLONVCR)

WTYPEXEC = val(PARAM(1))
WCTRNUM  = PARAM(2)
WTYPCLOS = val(PARAM(3))
If WTYPCLOS  = 2
  TYPPRG = 0
Endif
Return
######################################################################################
$EXEC
Case WTYPEXEC
  When 1  : Gosub SHIPSOLD      #solde d'une ligne d'expédition
  When 2  : Gosub SHIPSOLDAL    #solde d'une expédition
  When 3  : Gosub SHIPSOLDCTR   #solde d'un conteneur
  When Default
Endcase

Return
######################################################################################
$SHIPSOLD
Local Shortint NOL : NOL=nolign-1
Local Integer WPOS

GOK = 1
# Recherche de la ligne dans la collection
WPOS = find(toUuid([M:SHIP1]AUUID(NOL)), WSHIPMENT.SHD(1..maxtab(WSHIPMENT.SHD)).AUUID)
#TODO cfavre: Put a message in this case
If WPOS = 0
  GMESSAGE = "Position not found"
  GOK=0 : GERR=1
  Return
Endif
If GPILNAV>1
  If find (GNAVIG(GPILNAV-1), "GESSHIP") <>0  #ligne d'expédition
    If WTYPCLOS = 1
      If WSHIPMENT.SHD(WPOS).CLEFLG <> 2    #sold only if line isn't sold
        WSHIPMENT.SHD(WPOS).QTYEXPFLG = [M:SHIPS]QTYEXPFLG
        WSHIPMENT.SHD(WPOS).PRCPREN = [M:SHIPS]PRCPREN
        #solde de la ligne d'expédition
        If fmet WSHIPMENT.SHD(WPOS).SOLDSHIPLINE(WSHIPMENT.SHD(WPOS),1,1)<>CST_AOK
          Call GET_ERRORS(WSHIPMENT) From SUBSHIPA
          If GOK=0 : Return : Endif
        Endif
      Endif
    Else
      #désolde de la ligne d'expédition
      If fmet WSHIPMENT.SHD(WPOS).SOLDSHIPLINE(WSHIPMENT.SHD(WPOS),2,1)<>CST_AOK
          Call GET_ERRORS(WSHIPMENT) From SUBSHIPA
          If GOK=0 : Return : Endif
      Endif
     Endif
   Elsif find (GNAVIG(GPILNAV-1), "GESPPTS") <>0  #ligne de pré-réception
   If WTYPCLOS = 1
      If WSHIPMENT.SHD(WPOS).CLEFLG <> 2
        #solde de la ligne de pré-réception
        WSHIPMENT.SHD(WPOS).QTYEXPFLG = [M:SHIPS]QTYEXPFLG
        WSHIPMENT.SHD(WPOS).PRCPREN = [M:SHIPS]PRCPREN
        If fmet WSHIPMENT.SHD(WPOS).SOLDSHIPLINE(WSHIPMENT.SHD(WPOS),1,2)<>CST_AOK
          Call GET_ERRORS(WSHIPMENT) From SUBSHIPA
          If GOK=0 : Return : Endif
        Endif
      Endif
    Else
      #désolde de la ligne de pré-reception
      If fmet WSHIPMENT.SHD(WPOS).SOLDSHIPLINE(WSHIPMENT.SHD(WPOS),2,2)<>CST_AOK
          Call GET_ERRORS(WSHIPMENT) From SUBSHIPA
          If GOK=0 : Return : Endif
      Endif
     Endif
  Endif
Endif
# Remplissage de la ligne du tableau avec la classe
Call FILL_SCREEN(WSHIPMENT,NOL, WPOS) From SUBSHIPA

Return
######################################################################################
$SHIPSOLDAL
For I=0 To [M:SHIP1]NBLIG-1
  nolign = I+1
  Gosub SHIPSOLD
Next I

Return
######################################################################################
$SHIPSOLDCTR
For I=0 To [M:SHIP1]NBLIG-1
  nolign = I+1
  If [M:SHIP1]CTRNUM(I) = WCTRNUM
    Gosub SHIPSOLD
  Endif
Next I

Return

######################################################################################
$SORTIE
Affzo [M:SHIP1]
If GOK <> 0 mkstat = 4 : Endif

Return

