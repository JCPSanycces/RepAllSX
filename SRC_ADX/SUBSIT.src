#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FILTRE"      : Gosub FILTRE
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "STATUT"      : Gosub STATUT
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "APRES_MOD"   : Gosub APRES_MOD
 When "ABANDON"     : Gosub ABANDON
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FERME"       : Gosub FERME
 When Default
Endcase
Return


######################################################################################
$OUVRE
    If !clalev([F:SIW2]) : Local File SITRAWRK [SIW2] : Endif
    Local Integer LMODIF : Raz LMODIF
    If dim(GTXTSPC)<=0
        Global Char GTXTSPC : GTXTSPC = mess(6,9022,1)
    Endif
    If dim(GTXTVID)<=0
        Global Char GTXTVID : GTXTVID = "<"+toupper(mess(1,757,1))+">"
    Endif

    Gosub SI_CONTEXT From SIXFONCTION

    Trbegin [SIR]
    For [SIR]
#        Readlock [SIR] Curr
        If filinfo(filpath("FIL",[F:SIR]CODFIC,"fde",SI_DOSSIER),0) < 0
            [F:SIR]EXIFLG = 1
        Else
            [F:SIR]EXIFLG = 2
        Endif
        Rewrite [SIR]
    Next
    Commit

    If filinfo(filpath("FIL","XISOC","fde",SI_DOSSIER),0) < 0
        Return
    Endif
    If !clalev([F:XSOC]) : Local File XISOC [XSOC] : Endif
    Global Date GDATDEB, GDATFIN
    # lecture societe pour filtrer les mvts stock avec l etat des exercices N et N-1
    Read [XSOC]  First
    If !fstat
       GDATFIN = [F:XSOC]FINEXCN
       If [F:XSOC]ETAEXCN1 = "O"
          GDATDEB = [F:XSOC]DEBEXCN1
       Else
          GDATDEB = [F:XSOC]DEBEXCN
       Endif
    Endif
    GDATDEB=max([01/01/1980],GDATDEB)
    GDATFIN=max(GDATDEB,min(GDATFIN,date$))
    
Return

######################################################################################
$FILTRE
    FILTSUP="EXIFLG=2"
Return

######################################################################################
$LIENS
    [M:SITC]VALLNG(nolign-1) = evalue([M:SITC]LNG(nolign-1))
    [M:SITC]NBERR(nolign-1) = func SUBSIT.CPTERR([M:SITC]CODFIC(nolign-1),nolign-1)
    If [M:SITC]FMTCLE(nolign-1)=2
        Diszo [M:SITC]SPC(nolign-1),MAJ(nolign-1),ACCENT(nolign-1)
        Affzo [M:SITC]SPC(nolign-1),MAJ(nolign-1),ACCENT(nolign-1)
    Endif
    If [F]INTCND>0 & [F]INTCND<dim(SI_MES)
        [M:SITC]INTCNDA(nolign-1) = SI_MES([F]INTCND)
    Endif
    # Les tables avec plusieurs éléments de clé ne peuvent être transcodés automatiquement
    If [M:SITC]CODZONE2(nolign-1)<>""
        [M:SITC]VALID(nolign-1)=1
    Else
        [M:SITC]VALID(nolign-1)=2
    Endif
Return
######################################################################################
$LIENS2
[M:SITC]TRAFLG = 2
nolign = 0
For [SIC]
    nolign+=1
    [M:SITC] = [F:SIC]
    If [F:SIC]CAR1 = ""
        [M:SITC]CAR1(nolign-1)=GTXTSPC
    Endif
    If [F:SIC]CAR2 = ""
        [M:SITC]CAR2(nolign-1)="<"+toupper(mess(1,757,1))+">"
    Endif
Next
[M:SITC]NBCAR = nolign
Return

######################################################################################
$APRES_MODIF

Case COUZON
    When "VALID", "TRAFLG" :
        If LMODIF=0 & GREP="M"
            Raz GREP,REP
        Endif
        Assign "[M:SITC]"+COUZON+string$(evalue("dim([M:SITC]"+COUZON+")")>1,"(nolign-1)") With zc
        OK = -1
    When "NBLIG" :
        If !LMODIF
            OK = -1
        Endif
    When Default :
        LMODIF=1
Endcase
Return

######################################################################################
$STATUT
    If mkstat=4 & REP=""
        REP="M"
    Endif
Return
######################################################################################
$ABANDON
    Raz LMODIF
Return

######################################################################################
$CREATION
Return

######################################################################################
$MODIF
Local Integer I
Delete [F:SIC] Where 1=1
nolign = 0
For I=0 To [M:SITC]NBCAR-1
    nolign+=1
    [F:SIC] = [M:SITC]
    If [M:SITC]CAR1(nolign-1)=GTXTSPC
        [F:SIC]CAR1 = ""
    Endif
    If [M:SITC]CAR2(nolign-1)=GTXTVID
        [F:SIC]CAR2 = ""
    Endif
    Write [SIC]
Next
Return

######################################################################################
$APRES_MOD
Local Integer LORD
LORD=10
Trbegin [SIR]
For [SIR] With Stability
    Readlock [SIR] Curr
    [F:SIR]ORDRE = LORD
    LORD += 10
    Rewrite [SIR]
Next
Commit
Gosub RELIT From GOBJSUB
Return

######################################################################################
$EXEBOUT
Case BOUT
    When "1" : SI_SIMU=2 : Gosub SIT_VALID

    When "2" : SI_SIMU=1 : Gosub SIT_VALID
Endcase

If find(BOUT,"1","2") & GTRACE<>""
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif

Return


######################################################################################
$FERME
Return

######################################################################################
$SIT_VALID
Local Integer I, LERR
Local Char LCARO([M:SITC]NBCAR)
Local Char LCARD([M:SITC]NBCAR)

Call RPCCAR(LCARO,LCARD)

If !clalev([F:SIW]) : Local File SITRAWRK [SIW] : Endif
For I=0 To [M:SITC]NBLIG-1
    If [M:SITC]VALID(I)=2
        Call TRTFIC(1,I,LCARO,LCARD,1,LERR)
        [M:SITC]NBERR(I) = LERR
        Affzo [M:SITC]NBERR(I)
    Endif
Next

Return


######################################################################################
# PERR = Nombre d'erreur
#        -1 : fichier déjà en cours de traitement
######################################################################################
Subprog TRTFIC(PACT,PIND,PCARO,PCARD,PERRONLY,PERR)
Value Integer PACT
Value Integer PIND
Value Char    PCARO
Value Char    PCARD
Value Integer PERRONLY
Variable Integer PERR

Raz PERR
Lock ="SIT~"+[M]CODFIC(PIND)+"~"+[M]CODZONE(PIND)+"~"+num$([M]SEQ(PIND)) With lockwait = 0
If fstat
    PERR=-1
    End
Endif

Local Char LFIL(GLONATB)
Local Char LFLD(GLONAVA),LFLD2(GLONAVA)
Local Char LCND(220)
Local Integer I, J, STOP, NB, NBTOT, NBERR, NBMOD, NBDBL, ICRIT, LTIME
Local Char ERR_TRA(250)
Local Integer NBELTCLE
Local Char CLEA(30)(5)
Local Integer CLEI(5)
Local Date CLED(5)
Local Char NOMCLE(30)(5)
Local Char CRIT(250)
Local Char LVALFLD(50)    # Valeur du champ d'Intégrale à transcoder  = evalue("[F:XSMI]"+LFLD) ou evalue("num$([F:XSMI]"+LFLD+")")
Local Char LVALFLD2(50)   # Valeur du 2e champ de clé
Local Char LX3CLE(50)     # Valeur de X3CLE
Local Integer LTYPFLD, LTYPFLD2
Local Char REQ(255)(2)
Local Char LINT(30)
Local Integer LWRI
Local Integer LERRDBL    #1:doublon#erreur  2:doublon=erreur
Local Integer LNUMTAB

LFIL = [M]CODFIC(PIND)
LFLD = [M]CODZONE(PIND)
LFLD2= [M]CODZONE2(PIND)
LTYPFLD = evalue("type([F:XSMI]"+LFLD+")")
If LFLD2<>""
    LTYPFLD2 = evalue("type([F:XSMI]"+LFLD2+")")
Endif
LCND = [M]CND(PIND)
If LCND="" : LCND="1=1" : Endif
Local File =LFIL [XSMI]


If LFLD2<>"" & PACT=1    # Pas de transcodage automatique si plusieurs éléments de clé
    End
Endif

If !clalev([ATI]) : Local File ATABIND [ATI] : Endif
Filter [ATI] Where CODFIC=LFIL & NUMLIG=1
Read [ATI] First
Filter [ATI]
I=1
Repeat
    J = instr(I,[F:ATI]DESCRIPT,"+")
    If J>0
        NOMCLE(NBELTCLE) = seg$([F:ATI]DESCRIPT,I,J-1)
        I=J+1
        NBELTCLE += 1
    Endif
Until J<=0
NOMCLE(NBELTCLE) = right$([F:ATI]DESCRIPT,I)
NBELTCLE += 1
STOP = NBELTCLE+1

# PACT=3 ==> SIW-->XSMI ==> il ne faut pas effacer SIW
If PACT<>3
    Gosub DEL_OLDSIW
Endif

Raz [F:XSMI], [M]NBERR(PIND)

Call ECRTRACE("**********"-LFIL-LFLD-[M]INTCNDA(PIND)-"**********",-1)

#Call TEMPON(SI_MES(31)) From GESECRAN
Onerrgo ERR_FOR
#Filter [XSMI] Where evalue(LCND) & FLGREP<>2
#NBMAX = rowcount([XSMI])
NBMAX=nbrecord([XSMI])
#Filter [XSMI]
Onerrgo

Call OUVRE_BOITE(num$(NBMAX),NBMAX) From GESECRAN

If LFIL="XIMVTSRLOT"
    Close Local File [XSMI]
    Local File XIMVTSRLOT [XMSL], XIART [XART], XIMVTSKHIS [XHIS]
    If [M]LNG(PIND)="GLONLOT"    # Article géré en lot
        Link [XMSL] With [XART]IND0~=[XMSL]CODART, [XHIS]IND0~=[XMSL]PFX;[XMSL]NUMORD;[XMSL]LETRLQ;[XMSL]NUMLIG
&                   As [XSMI]
&                   Where [XART]GESNUMSER="O" & [XART]NUMSERLOT="L" & [XART]TYPMVTGES="T"
&                       & [XMSL]SENMVT="E" & [XMSL]SLDQTE=""
&                       & [XHIS]DATMVT  >= GDATDEB 
&                       & [XHIS]DATMVT  <= GDATFIN


    Else    # Article géré en série
        Link [XMSL] With [XART]IND0~=[XMSL]CODART, [XHIS]IND0~=[XMSL]PFX;[XMSL]NUMORD;[XMSL]LETRLQ;[XMSL]NUMLIG
&                   As [XSMI]
&                   Where [XART]GESNUMSER="O" & [XART]NUMSERLOT="S" & [XART]TYPMVTGES="T"
&                       & [XMSL]SENMVT="E" & [XMSL]SLDQTE=""
&                       & [XHIS]DATMVT  >= GDATDEB 
&                       & [XHIS]DATMVT  <= GDATFIN

    Endif
Endif

$LOOP_XSMI
Raz NB
Trbegin [SIW]
Gosub CRITERE
For [XSMI]  Where evalue(CRIT) & evalue(LCND) & FLGREP<2

    If LTYPFLD>10
        If left$(evalue("[F:XSMI]"+LFLD),2)="$$"
           Goto NEXT_SMI
        Endif
        LVALFLD = evalue("[F:XSMI]"+LFLD)
    Else
        LVALFLD = evalue("num$([F:XSMI]"+LFLD+")")
    Endif

    If LFLD2<>""
        If LTYPFLD2>10
            LVALFLD2 = evalue("[F:XSMI]"+LFLD2)
        Else
            LVALFLD2 = evalue("num$([F:XSMI]"+LFLD2+")")
        Endif
    Endif
    If time-LTIME>1 | time-LTIME<0    # S'il s'est écoulé au moins une seconde ou qu'on a changé de date
        LTIME=time
        Call AFF_BOITE(num$(NBTOT)-"/"-num$(NBMAX),NBTOT,I) From GESECRAN
    Endif

    Case PACT
        When 1 :
            Gosub TRASMI
        When 2 :
            Gosub SMI2SIW
        When 3 :
            Gosub SIW2SMI
    Endcase

    If NB>3000
        STOP=1
        Break
    Endif
$NEXT_SMI
Next
Commit
If STOP<=NBELTCLE
    Goto LOOP_XSMI
Endif

Call FERME_BOITE From GESECRAN
#Call TEMPOFF From GESECRAN


#---- Vérification des doublons ----#
Gosub SEADBL

Call ECRTRACE(LFIL-mess(451,197,1)-num$(NBTOT),-1)    # "Nbre d'enregistrements traités :"
If NBERR>0
    Call ECRTRACE(LFIL-mess(159,115,1)-num$(NBERR),-1) # "Nombre d'erreurs :"
    If NBDBL>0
        Call ECRTRACE(LFIL-mess(69,104,1)-":"-num$(NBDBL),-1)    # "Doublon"
    Endif
Endif
Call ECRTRACE(LFIL-SI_MES(6)-num$(NBMOD),-1)
Close Local File [XSMI]

PERR = NBERR

Unlock ="SIT~"+[M]CODFIC(PIND)+"~"+[M]CODZONE(PIND)+"~"+num$([M]SEQ(PIND))
End

######################################################################################
$ERR_FOR
    Call ECRTRACE(mess(65,106,1)+":"-"\"-LCND-"\"-errmes$(errn)-"/"-errm,1)
End

######################################################################################
$DEL_OLDSIW
    Trbegin [SIW]
    If dim([M:SITF]TRTERR)>0 & [M:SITF]TRTERR=2
        Delete [SIW] Where CODFIC=LFIL
&                        & CODZONE=LFLD
&                        & SEQ=[M:SITF]SEQ
&                        & ERR=2
    Else
        Delete [SIW] Where CODFIC=LFIL
&                        & CODZONE=LFLD
&                        & SEQ=[M]SEQ(PIND)
    Endif
    Commit
Return

######################################################################################
$CRITERE
Raz CRIT
For I=0 To NBELTCLE-1-STOP
    If evalue("type([F:XSMI]"+NOMCLE(I)+")")>10
        Call ADDCRIT(CRIT,ICRIT,"",NOMCLE(I)+"='"+evalue("[F:XSMI]"+NOMCLE(I))+"'","&")From GOBJSUB
    Else
        Call ADDCRIT(CRIT,ICRIT,"",NOMCLE(I)+"="+evalue("num$([F:XSMI]"+NOMCLE(I)+")"),"&")From GOBJSUB
    Endif
Next
If NBELTCLE>=STOP
    If evalue("type([F:XSMI]"+NOMCLE(NBELTCLE-STOP)+")")>10
        Call ADDCRIT(CRIT,ICRIT,"",NOMCLE(NBELTCLE-STOP)+">'"+evalue("[F:XSMI]"+NOMCLE(NBELTCLE-STOP))+"'","&")From GOBJSUB
    Else
        Call ADDCRIT(CRIT,ICRIT,"",NOMCLE(NBELTCLE-STOP)+">"+evalue("num$([F:XSMI]"+NOMCLE(NBELTCLE-STOP)+")"),"&")From GOBJSUB
    Endif
    STOP+=1
Else
    If CRIT=""
        CRIT="1=1"
    Endif
Endif
Return


######################################################################################
# Si SI_SIMU=2 => écriture dans SIW sinon écriture dans SMI
$TRASMI
    Raz LWRI
    # On fait le transcodage s'il n'a pas encore été fait, ou si on doit tout traiter ou s'il y a une erreur dans le transcodage
    If dim([M:SITF]TRTERR)>0 & [M:SITF]TRTERR=2
        Look [SIW]SIW0=LFIL;LFLD;[M]SEQ(PIND);LVALFLD
        If !fstat
            Goto NEXT_SMI
        Endif
    Endif
    LX3CLE = vireblc([F:XSMI]X3CLE,5)
    If vireblc([F:XSMI]X3CLE,4)=""
        LX3CLE = LVALFLD
    Else
        LX3CLE = [F:XSMI]X3CLE
    Endif
    LX3CLE = func TRACOD(LX3CLE,
&                        evalue([M]LNG(PIND)),
&                        [M]FMTCLE(PIND),
&                        [M]ACCENT(PIND),
&                        [M]MAJ(PIND),
&                        [M]SPC(PIND),
&                        [M]NUM(PIND),
&                        PCARO, PCARD)
    If func CTLTRACOD([M]OBJ(PIND),[M]CODFIC(PIND),[M]LNG(PIND),LX3CLE)
        LX3CLE=""
    Endif

    [F:SIW]ERR=1
    [F:SIW]DBL=1
    If vireblc(LX3CLE,4)=""
        Call ECRTRACE(LFIL-LVALFLD-SI_MES(3),1)
        [F:SIW]ERR=2
        NBERR+=1
    Endif

        [F:SIW]CODFIC=LFIL
        [F:SIW]CODZONE=LFLD
        [F:SIW]SEQ=[M]SEQ(PIND)
        [F:SIW]X3CLE = LX3CLE
        [F:SIW]COD = LVALFLD
        If LX3CLE<>""
            Filter [SIW2] Where CODFIC  = LFIL
&                             & CODZONE = LFLD
&                             & SEQ     = [M]SEQ(PIND)
&                             & X3CLE   = LX3CLE
&                             & COD    <> LVALFLD
            Look [SIW2] First
            If !fstat
                Update [SIW2] Where CODFIC=LFIL
&                                 & CODZONE=LFLD
&                                 & SEQ=[M]SEQ(PIND)
&                                 & X3CLE=LX3CLE
&                                 & DBL<>2
&                             With DBL=2, ERR=2
                If [F:SIW]ERR=1
                    [F:SIW]ERR=2
                    NBERR+=1
                Endif
                [F:SIW]DBL=2
                # Si doublon autorisé => msg avertissement, sinon msg erreur
                Call ECRTRACE(LFIL-LVALFLD-"-->"-LX3CLE-":"-mess(69,104,1),2*([M]AUZDBL(PIND)<>2)-1)

                # Le nombre de doublons est comptabilisé plus loin ($SEADBL)
            Endif
            Filter [SIW2]
        Endif
        If dim([M]INTZONE(PIND))>0 & [M]INTZONE(PIND)<>""
        #If [M]INTZONE(PIND)<>""
            If evalue("type([F:XSMI]"+[M]INTZONE(PIND)+")")<10
                LINT = evalue("num$([F:XSMI]"+[M]INTZONE(PIND)+")")
            Else
                LINT = evalue("[F:XSMI]"+[M]INTZONE(PIND)+"")
            Endif
            [F:SIW]INTITULE = LINT
        Endif
        Write [SIW]
        # L'écriture d'un doublon ne peut pas se faire, mais ce n'est pas une erreur
        # Ceci pour gérer le cas des sous-familles.
        # Des sous-familles de même code pour des familles différentes donnent un même X3CLE
        # Normalement on n'aura jamais fstat=3 dans les autres cas.
        If fstat=3
            Raz fstat
        Endif
    If fstat
        ERR_TRA = LFIL-"fstat="+num$(fstat)
        For I=0 To NBELTCLE-1
            ERR_TRA += evalue("[F:XSMI]"+NOMCLE(I))+";"
        Next
        Call ECRTRACE(ERR_TRA,1)
        NBERR+=1
    Endif
    # Transfert des valeurs de SIW dans XSMI
    If SI_SIMU=1
        If [M]AUZDBL(PIND)=2 | [F:SIW]DBL<>2
            [F:XSMI]X3CLE = LX3CLE
            Rewrite [XSMI]
            LWRI=1
        Endif
    Else
        LWRI=1
    Endif
    If LWRI
        NB+=1
        NBTOT+=1
        If [F:SIW]DBL=1 | [M]AUZDBL(PIND)=2
            Call ECRTRACE(LFIL-LVALFLD-"-->"-LX3CLE,0)
        Endif
        If LX3CLE<>LVALFLD
            NBMOD += 1
        Endif
    Endif
Return

######################################################################################
$SMI2SIW
    Raz [F:SIW]
    [F:SIW]CODFIC=LFIL
    [F:SIW]CODZONE=LFLD
    [F:SIW]SEQ=[M]SEQ(PIND)
    [F:SIW]COD  = LVALFLD
    [F:SIW]COD2 = LVALFLD2
    [F:SIW]MDF=1
    [F:SIW]ERR  = 1
    LX3CLE = vireblc([F:XSMI]X3CLE,4)
    If LX3CLE="" #& LFLD2=""
        LX3CLE = func SUBSIT.TRACOD([F:SIW]COD,
&                                   evalue([M]LNG(PIND)),
&                                   [M]FMTCLE(PIND),
&                                   [M]ACCENT(PIND),
&                                   [M]MAJ(PIND),
&                                   [M]SPC(PIND),
&                                   [M]NUM(PIND),
&                                   PCARO,PCARD)
        If LX3CLE<>""
            [F:SIW]MDF=2
        Endif
    Endif
    If LX3CLE=""
        [F:SIW]ERR  = 2
        NBERR+=1
    Elsif func CTLTRACOD([M]OBJ(PIND),[M]CODFIC(PIND),[M]LNG(PIND),LX3CLE)
        LX3CLE=""
        [F:SIW]ERR  = 2
        NBERR+=1
    Endif
    [F:SIW]DBL=1
    [F:SIW]X3CLE = LX3CLE
    If PERRONLY<>2 | [F:SIW]ERR=2 | [F:SIW]MDF=2
        If [M]INTZONE(PIND)<>""
            If evalue("type([F:XSMI]"+[M]INTZONE(PIND)+")")<10
                LINT = evalue("num$([F:XSMI]"+[M]INTZONE(PIND)+")")
            Else
                LINT = evalue("[F:XSMI]"+[M]INTZONE(PIND)+"")
            Endif
            [F:SIW]INTITULE = LINT
        Endif
        Write [SIW]
        If fstat=3
            Raz fstat
        Endif
        NB+=1
        NBTOT+=1
    Endif
Return

######################################################################################
# Recherche les doublons dans SIW et màj des champs DBL et ERR
######################################################################################
$SEADBL
    Trbegin [SIW]
    If PERRONLY=2
        LTYPFLD = evalue("type([F:XSMI]"+LFLD+")")
        If LFLD2<>""
            LTYPFLD2 = evalue("type([F:XSMI]"+LFLD2+")")
        Endif
        PERRONLY=1    # temporairement pour pouvoir écrire dans SMI2SIW

        # On rajoute dans [SIW] tous les enreg qui étaient bons
        # mais qui se retrouvent en doublons avec ceux qui ont été ajoutés dans SIW
        If LFIL="XIMVTSRLOT"
            If [M]LNG(PIND)="GLONLOT"    # Article géré en lot
                Link [XMSL] With [XART]IND0~=[XMSL]CODART,
&                                [XHIS]IND0~=[XMSL]PFX;[XMSL]NUMORD;[XMSL]LETRLQ;[XMSL]NUMLIG,
&                                [SIW]SIW1~=LFIL;LFLD;[M]SEQ(PIND);[XMSL]X3CLE
&                   As [LNK]
&                   Where [XART]GESNUMSER="O" & [XART]NUMSERLOT="L" & [XART]TYPMVTGES="T"
&                       & [XMSL]SENMVT="E" & [XMSL]SLDQTE=""
&                       & [XHIS]DATMVT  >= GDATDEB 
&                       & [XHIS]DATMVT  <= GDATFIN
&                       & [XMSL]X3CLE   <> ""

            Else    # Article géré en série
                Link [XMSL] With [XART]IND0~=[XMSL]CODART,
&                                [XHIS]IND0~=[XMSL]PFX;[XMSL]NUMORD;[XMSL]LETRLQ;[XMSL]NUMLIG,
&                                [SIW]SIW1~=LFIL;LFLD;[M]SEQ(PIND);[XMSL]X3CLE
&                   As [LNK]
&                   Where [XART]GESNUMSER="O" & [XART]NUMSERLOT="S" & [XART]TYPMVTGES="T"
&                       & [XMSL]SENMVT="E" & [XMSL]SLDQTE=""
&                       & [XHIS]DATMVT  >= GDATDEB 
&                       & [XHIS]DATMVT  <= GDATFIN
&                       & [XMSL]X3CLE   <> ""


            Endif
        Else
            If LTYPFLD>10
                Link [XSMI] With [SIW]SIW1~=LFIL;LFLD;[M]SEQ(PIND);[XSMI]X3CLE
&                           As [LNK]
&                           Where [SIW]COD<>evalue("[XSMI]"+LFLD) & [F:SIW]X3CLE<>""
            Else
                Link [XSMI] With [SIW]SIW1~=LFIL;LFLD;[M]SEQ(PIND);[XSMI]X3CLE
&                           As [LNK]
&                           Where [SIW]COD<>evalue(num$("[XSMI]"+LFLD)) & [F:SIW]X3CLE<>""
            Endif
        Endif
        For [LNK]
            If LTYPFLD>10
                LVALFLD = evalue("[F:XSMI]"+LFLD)
            Else
                LVALFLD = evalue("num$([F:XSMI]"+LFLD+")")
            Endif
        
            If LFLD2<>""
                If LTYPFLD2>10
                    LVALFLD2 = evalue("[F:XSMI]"+LFLD2)
                Else
                    LVALFLD2 = evalue("num$([F:XSMI]"+LFLD2+")")
                Endif
            Endif
            Gosub SMI2SIW
        Next
        PERRONLY=2    # temporairement pour pouvoir écrire dans SMI2SIW
    Endif

LERRDBL=1+([M]AUZDBL(PIND)<>2)
Raz REQ
If LFIL="XINMC"
    # Dans le cas des nomenclatures, ne sont considérés comme doublons
    # non pas les doublons sur X3CLE (ce qui est le cas des familles stat)
    # mais les doublons sur le couple (COD2,X3CLE)
    REQ(0) = "SELECT COUNT(X3CLE_0), X3CLE_0, CODFIC_0, CODZONE_0, SEQ_0, COD2_0"
&           +" From SITRAWRK"
&           +" Where X3CLE_0<>' ' AND CODFIC_0='"+LFIL+"' AND CODZONE_0='"+LFLD+"' AND SEQ_0="+num$([M]SEQ(PIND))
    REQ(1) = " GROUP BY X3CLE_0, CODFIC_0, CODZONE_0, SEQ_0, COD2_0"
&           +" HAVING COUNT(X3CLE_0)>1"
    For (Integer NUM, Char X3CLE, Char CODFIC, Char CODZONE, Integer SEQ, Char COD2) From num$(GTYPDBA*2+1) Sql REQ As [XXX]
        Update [SIW] Where [SIW]CODFIC  = [XXX]CODFIC
&                        & [SIW]CODZONE = [XXX]CODZONE
&                        & [SIW]SEQ     = [XXX]SEQ
&                        & [SIW]X3CLE   = [XXX]X3CLE
&                        & [SIW]COD2    = [XXX]COD2
&                    With DBL=2, ERR=LERRDBL
        NBDBL += adxuprec
        If LERRDBL = 2
            NBERR+=adxuprec
        Endif
    Next
Else
    REQ(0) = "SELECT COUNT(X3CLE_0), X3CLE_0, CODFIC_0, CODZONE_0, SEQ_0"
&           +" From SITRAWRK"
&           +" Where X3CLE_0<>' ' AND CODFIC_0='"+LFIL+"' AND CODZONE_0='"+LFLD+"' AND SEQ_0="+num$([M]SEQ(PIND))
    REQ(1) = " GROUP BY X3CLE_0, CODFIC_0, CODZONE_0, SEQ_0"
&           +" HAVING COUNT(X3CLE_0)>1"
    For (Integer NUM, Char X3CLE, Char CODFIC, Char CODZONE, Integer SEQ) From num$(GTYPDBA*2+1) Sql REQ As [XXX]
        Update [SIW] Where [SIW]CODFIC  = [XXX]CODFIC
&                        & [SIW]CODZONE = [XXX]CODZONE
&                        & [SIW]SEQ     = [XXX]SEQ
&                        & [SIW]X3CLE   = [XXX]X3CLE
&                    With DBL=2, ERR=LERRDBL
        NBDBL += adxuprec
        If LERRDBL = 2
            NBERR+=adxuprec
        Endif
    Next
Endif

Commit

Return

######################################################################################
$SIW2SMI
    Columns [SIW] (X3CLE)
    Read [SIW]SIW0=LFIL;LFLD;[M]SEQ(PIND);LVALFLD;LVALFLD2
    If !fstat & ([F:SIW]ERR<>2 | [F:SIW]DBL=2 & [M]AUZDBL(PIND)=2 | [F:SIW]X3CLE="")
        Readlock [XSMI] Curr
        [F:XSMI]X3CLE = [F:SIW]X3CLE
        Rewrite [XSMI]
        NB+=1
        NBTOT += 1
        If [F:SIW]X3CLE=""
            NBERR +=1
        Endif
    Elsif [XSMI]X3CLE = ""
        NBERR += 1
    Endif
    Columns [SIW]
Return

######################################################################################
Subprog ECRTRACE(PMES,PERR)
Value Char PMES
Value Integer PERR
If [M]TRAFLG=3 | PERR=1 & [M]TRAFLG=2
    If GTRACE=""
        Call OUVRE_TRACE("") From LECFIC
    Endif
    
    Call ECR_TRACE(PMES,PERR) From GESECRAN
Endif
End


######################################################################################
# Paramètres S : PCARO = liste des caractères à remplacer (ceux à supprimer sont mis à la fin)
#                PCARD = liste des caractères de remplacement
######################################################################################
Subprog RPCCAR(PCARO,PCARD)
Variable Char PCARO, PCARD
Local Integer I
Raz PCARO, PCARD
For I=0 To [M:SITC]NBCAR-1
    If [M:SITC]CAR2(I) = GTXTVID
        If [M:SITC]CAR1(I) <> GTXTSPC
            PCARO += [M:SITC]CAR1(I)
        Else
            PCARO += " "
        Endif
    Else
        If [M:SITC]CAR1(I) <> GTXTSPC
            PCARO = [M:SITC]CAR1(I)+PCARO
        Else
            PCARO = " "+PCARO
        Endif
        PCARD = [M:SITC]CAR2(I)+PCARD
    Endif
Next
End

######################################################################################
Funprog TRACOD(PCOD,PLNG,PCLE,PACC,PMAJ,PSPC,PNUM,PCARO,PCARD)
Value Char PCOD
Value Integer PLNG,PCLE,PACC,PMAJ,PSPC,PNUM
Value Char PCARO, PCARD

Local Char LRES(50)

    LRES = PCOD
    If PNUM=2
        If LRES<>num$(val(LRES))
            LRES=""
        Endif
        If len(LRES)>PLNG
            LRES=""
        Endif
    Else
    
        #----- 1: Application des règles générales -----#
        # On remplace d'abord les caractères "spéciaux".
        # Cela permet de remplacer les espaces par un caractère avant qu'ils ne soient supprimés.
        LRES = ctrans(LRES,PCARO,PCARD)

        #----- 2: application des règles liées au fichier -----#
        If PACC=2    # accents
            LRES = ctrans(LRES)
        Endif
        If PMAJ=2    # majuscules
            LRES = toupper(LRES)
        Endif
        If PSPC=2    # espaces
            LRES = vireblc(LRES,4)
        Endif

        If len(LRES)>PLNG
            Raz LRES
        Else
            #----- 3: Si format clé demandé => vérification ----#
            If PCLE=2
                # Format clé : majuscules + chiffres et sans espace
                LRES = format$("Kv4:"+num$(len(LRES))+"c",LRES)
            Endif
        Endif
    Endif

    GPOINT="SITRACOD"
    Gosub ENTREE From EXEFNC


End LRES

######################################################################################
# CPTERR: le nombre d'enregistrements n'ayant pas de X3CLE sur la table XI...
######################################################################################
# Paramètres E : PXIFIL = nom du fichier en cours "XI..."
#                PIND   = indice de la ligne où se trouve les info
#
# Renvoie le nombre d'enregistrements n'ayant pas de X3CLE
######################################################################################
Funprog CPTERR(PXIFIL,PIND)
Value Char PXIFIL    # Nom du fichier XI
Value Integer PIND

If !clalev([F:XSMI]) : Local File =PXIFIL  [XSMI] : Endif
If !clalev([F:SIR])  : Local File SITRACOD [SIR] : Raz [F:SIR] : Endif

Local Char LCRIT(250)(2)
Local Integer ICRIT, LNB, LRET

# Si le fichier [SIR] est ouvert et positionné, on calcule le nombre d'enreg selon les critère du [SIR] en cours
If [F:SIR]CODFIC<>""
    Call ADDCRIT(LCRIT,ICRIT,"",[F:SIR]CND,"|") From GOBJSUB
Else
    # Sinon on regarde globalement sur le fichier XI
    For [SIR] Where CODFIC=PXIFIL
        Call ADDCRIT(LCRIT,ICRIT,"",[F:SIR]CND,"|") From GOBJSUB
    Next
Endif
If LCRIT =""
    LCRIT="1=1"
Endif

Case PXIFIL 
    When  "XIMVTSRLOT" :
        Local Char REQ(250)(5)
        REQ(0)="SELECT"
        If GTYPDBA=1    # Oracle
            REQ(0) += " /*+ INDEX(M XIMVTSRLOT_IND12)*/"
        Endif
        REQ(0)+=" COUNT(*)"
        REQ(0)+=" From XIMVTSRLOT M"
        If GTYPDBA=2    # SQL Server
            REQ(0) += " WITH( INDEX(XIMVTSRLOT_IND12) )"
        Endif
        REQ(0)+=", XIART A, XIMVTSKHIS H"
        If [M]LNG(PIND)="GLONLOT"
            REQ(1)=" Where M.CODART_0=A.CODART_0 AND A.GESNUMSER_0='O' AND A.NUMSERLOT_0='L' AND M.NUMSERLOT_0<>' ' AND M.PFX_0 in ('ZS','ZF','ZC','ZP') and M.X3CLE_0=' '"
        Else
            REQ(1)=" WHERE M.CODART_0=A.CODART_0 AND A.GESNUMSER_0='O' AND A.NUMSERLOT_0='S' AND M.NUMSERLOT_0<>' ' AND M.PFX_0 in ('ZS','ZF','ZC','ZP') and M.X3CLE_0=' '"
        Endif
        REQ(2)=" and A.TYPMVTGES_0='T' and M.SENMVT_0='E' and M.SLDQTE_0=' '"
        REQ(3)=" AND H.LETMVT_0=M.PFX_0 AND H.NUMORD_0=M.NUMORD_0 AND H.LETRLQ_0=M.LETRLQ_0 AND H.NUMLIG_0=M.NUMLIG_0"
        Case GTYPDBA
            When 1 : REQ(4)=" and H.DATMVT_0>='"+format$("D:DD[/]MMM[/]YYYY",GDATDEB)+"' and H.DATMVT_0<='"+format$("D:DD[/]MMM[/]YYYY",GDATFIN)+"'"
            When 2 : REQ(4)=" and H.DATMVT_0>='"+format$("D:YYYYMMDD",GDATDEB)+"' and H.DATMVT_0<='"+format$("D:YYYYMMDD",GDATFIN)+"'"
        Endcase
    
        For (Integer N) From num$(GTYPDBA*2+1) Sql REQ As [XXX]
            LNB = [F:XXX]N
        Next

    # CCC (2010-02-22) Bug 58461 : Le contrôle ne doit pas se faire sur les codes commençant par "$$"
    When "XIART":
        Filter [XSMI] Where left$(CODART,2)<>"$$" & evalue(LCRIT) & X3CLE=""
        LNB = rowcount([F:XSMI])
        Filter [XSMI]
    When "XICLT":
        Filter [XSMI] Where left$(CODCLT,2)<>"$$" & evalue(LCRIT) & X3CLE=""
        LNB = rowcount([F:XSMI])
        Filter [XSMI]

    When Default:
        Filter [XSMI] Where evalue(LCRIT) & X3CLE=""
        LNB = rowcount([F:XSMI])
        Filter [XSMI]
Endcase

# Compte le nombre d'enregistrement dont X3CLE est renseigné
# mais dont la valeur ne correspond pas à une valeur existante dans la base
If [F:SIR]CODFIC<>"" & [F:SIR]OBJ<>"" 
    Columns [XSMI] (X3CLE)
    Filter [XSMI] Where evalue(LCRIT) & X3CLE<>""
    For [XSMI]
        Raz LRET, mkstat
        Call CONTROLE([F:SIR]OBJ,"",[F:XSMI]X3CLE,"",mkstat) From CONTOBJ
        Raz GMESSAGE
        LNB += (mkstat=2)
    Next
    Filter [XSMI]
    Columns [XSMI]
Endif

End LNB

######################################################################################
# CTLCOD: Contrôle que l'enregistrement en cours sur la table XI... peut être créé
#         et si oui, donne la valeur à mettre dans le champ X3CLE
######################################################################################
# Paramètres E : PXIFIL = nom du fichier en cours "XI..."
#                PABR   = abéviation du fichier XI. Ex: "XART"
#
#            S : PX3CLE = Code à mettre dans X3CLE
#
# Renvoie  : 1 si l'enregistrement doit être récupéré
#            0 si l'enregistrement n'a pas besoin d'être récupéré
######################################################################################
Funprog CTLCOD(PXIFIL,PABR,PX3CLE)
Value Char PXIFIL    # Nom du fichier XI
Value Char PABR      # son abréviation
Variable Char PX3CLE # Valeur à placer dans le champ X3CLE

If !clalev([F:SIR]) : Local File SITRACOD [SIR] : Endif
If clalev([F:XTBL]) : Default File [XTBL] : Endif

Local Integer LOK

LOK=1

# Pour les codes tournées, le transcodage est forcé pour avoir une suite de n° à partir de 1
If PXIFIL="XINUMTNCLT"
    Local Char REQ(250)
    REQ ="Select X3CLE_0"
    REQ+=" From XINUMTNCLT"
    REQ+=" Where X3CLE_0<>' '"
    REQ+=" ORDER BY cast(X3CLE_0 as integer) Desc"

    PX3CLE="1"
    For (Char X3CLE) From num$(GTYPDBA*2+1) Sql REQ As [XXX]
        PX3CLE= num$(val([F:XXX]X3CLE)+1)
        Break
    Next
    End LOK
Endif

For [SIR] Where CODFIC=PXIFIL
    # Si plusieurs éléments de clé => on ne récupère pas de valeur dans X3CLE
    If [F:SIR]CODZONE2<>""
        PX3CLE=""
        Break
    Endif
    If evalue("type([F:"+PABR+"]"+[F:SIR]CODZONE+")")>10
        PX3CLE = evalue("[F:"+PABR+"]"+[F:SIR]CODZONE)
    Else
        PX3CLE = evalue("num$([F:"+PABR+"]"+[F:SIR]CODZONE+")")
    Endif
    If left$(PX3CLE,2)="$$"    # Les codes avec "$$" ne seront pas repris
        LOK=0
        PX3CLE=""
        Break
    Elsif  ([F:SIR]CND="" | evalue([F:SIR]CND))
        LOK=1    # Peut avoir été mis à 0 au tour précédent de la boucle [SIR]
        #------ Si PAYS ou DEVISE --------#
        Case PXIFIL
            When "XIPAY" :
                If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
                Local Char LISOCRY(3)
                LISOCRY = evalue("[F:"+PABR+"]CODISO2")
                Raz PX3CLE
                For [TCY] Where ISO=LISOCRY
                    PX3CLE = [F:TCY]CRY
                    LOK=1
                    Break
                Next
                End LOK
            When "XIDVS" :
                If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
                Local Char LISOCUR(3)
                LISOCUR = evalue("[F:"+PABR+"]CODISO")
                Raz PX3CLE
                For [TCU] Where ISOCOD=LISOCUR
                    PX3CLE = [F:TCU]CUR
                    LOK=1
                    Break
                Next
                End LOK
        Endcase

        #------ Contrôles objet et divers ----------#
        If func CTLTRACOD([F:SIR]OBJ,PXIFIL,[F:SIR]LNG,PX3CLE)
            PX3CLE=""
            End LOK
        Endif


        #------- Autres cas ---------#
        If [F:SIR]NUM=2 & PX3CLE<>num$(val(PX3CLE))
            PX3CLE=""
            Break
        Else
            # Format clé : majuscules + chiffres et sans espace
            If [F:SIR]FMTCLE=2
                If PX3CLE <> format$("Kv4:"+num$(min(len(PX3CLE),evalue([F:SIR]LNG)))+"c",PX3CLE)
                    PX3CLE=""
                Endif
                Break    # S'il n'y a pas eu d'erreur, c'est que le reste est bon aussi
            Endif

            If [F:SIR]ACCENT=2 & PX3CLE<>ctrans(PX3CLE)    # accents
                PX3CLE=""
                Break
            Endif
            If [F:SIR]MAJ=2 & PX3CLE <> toupper(PX3CLE)    # majuscules
                PX3CLE=""
                Break
            Endif
            If [F:SIR]SPC=2 & PX3CLE <> vireblc(PX3CLE,4)    # espaces
                PX3CLE=""
                Break
            Endif
        
            If len(PX3CLE)>evalue([F:SIR]LNG)
                PX3CLE=""
                Break
            Endif
        Endif
        Break
    Else
        PX3CLE=""
        LOK = 0
    Endif
Next

# Cas particulier des mode de règlements Intégrale <=> Condition de paiement X3
If LOK & PXIFIL="XIMODRGL"
 For [SIR] Where CODFIC=PXIFIL
  If evalue("type([F:"+PABR+"]"+[F:SIR]CODZONE+")")>10
   PX3CLE = evalue("[F:"+PABR+"]"+[F:SIR]CODZONE)
  Else
   PX3CLE = evalue("num$([F:"+PABR+"]"+[F:SIR]CODZONE+")")
  Endif
  If evalue("type([F:"+PABR+"]"+[F:SIR]CODZONE2+")")>10
   PX3CLE += evalue("[F:"+PABR+"]"+[F:SIR]CODZONE2)
  Else
   PX3CLE += evalue("num$([F:"+PABR+"]"+[F:SIR]CODZONE2+")")
  Endif
  If PX3CLE <> format$("Kv4:"+num$(min(len(PX3CLE),evalue([F:SIR]LNG)))+"c",PX3CLE)
   PX3CLE=""
   LOK = 0
  Endif
  Break
 Next
Endif

# Cas particulier aux niveaux des journaux.
# Demande 43318 : Journaux X3 livrés et concervés et donc les journaux Intégrale ne peuvent possèder un X3CLE identique à un journal X3
If LOK & PXIFIL="XIJRN" & PX3CLE<>""
 If !clalev([F:JOU]) : Local File =SI_DOSSIER+".GJOURNAL"     [JOU] : Endif   # Journaux comptables
 Read [JOU]JOU0(1) = PX3CLE
 If !fstat : Raz PX3CLE : Endif
Endif

End LOK




########################################################
# Renvoie  : 0 si le transcodage est correct
#            1 ctrl objet incorrect 
#            2 ctrl format n° compte incorrect
#            3 ctrl journal incorrect
########################################################
Funprog CTLTRACOD(POBJ,PFIC,PLNG,PX3CLE)
Value Char POBJ
Value Char PFIC
Value Char PLNG
Variable Char PX3CLE

Local Integer LNUMTAB

#----- Controle format n° de compte
If PFIC="XIPLACBGNR"
 If len(PX3CLE)>evalue(PLNG)
  PX3CLE=left$(PX3CLE,evalue(PLNG))
 Endif
 # Le contrôle en V6 ne peut plus se faire <=> multi-plan.
 # Demande de Fabienne, dans le cas "SI ET SEULEMENT SI un seul modèle comptable est présent dans le dossier"
 If GGCMNBR=1
  Local Char    FMTACC(10)
  FMTACC =  num$(GLONGAC)+'c'
  If vireblc(format$("K:"+FMTACC,PX3CLE),2)<>PX3CLE
   End 2
  Endif
  If len(PX3CLE)<GLONGAC
   PX3CLE += string$(GLONGAC-len(PX3CLE),"0")
  Elsif len(PX3CLE)>GLONGAC
   PX3CLE = left$(PX3CLE,GLONGAC)
  Endif
 Endif
Endif 

#----- Controle sur l'objet
If POBJ<>""
    PX3CLE = format$("Kv4:"+num$(min(len(PX3CLE),evalue(PLNG)))+"c",PX3CLE)
    If PX3CLE=""
        End 1
    Else
        If POBJ="ADI" & PFIC="XIMODRGL"
            Call CONTROLE(POBJ,"",PX3CLE,"3",mkstat) From CONTOBJ
        Else
            Call CONTROLE(POBJ,"",PX3CLE,"",mkstat) From CONTOBJ
            Raz GMESSAGE
            If mkstat=2
                Raz mkstat
                End 1
            Endif
        Endif
    Endif
Endif

#----- Controle présente journal
If PFIC="XIJRN"
 If !clalev([F:JOU]) : Local File =SI_DOSSIER+".GJOURNAL"     [JOU] : Endif   # Journaux comptables
 Read [JOU]JOU0(1) = PX3CLE
 If !fstat : End 3  : Endif
Endif 

End 0

    
