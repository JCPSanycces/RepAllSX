#<AdxTL>@(#)4.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Initialisation champ LEG dans TABCOUAFF dans les dossiers mono
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update LEG in TABCOUAFF Tables for mono legislation folders") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTCA
End

#-------------------#
$MAJTCA

If DOSSIER=GDOSX3
 Return
Endif

Local Integer MONO , UPD

Local File ADOSSIER [ADS_U] , ADOSACT [ADA_U]
Read [ADS_U]DOSSIER = [L]DOSSIER
Read [ADA_U]ADA0 = [L]DOSSIER;"LEG"
If fstat or [F:ADA_U]FLACT<>2
 MONO = 1
Endif
If !MONO : Goto FIN : Endif

# Mise à jour de la table TABCOUAFF

Call ECR_TRACE(mess(81,125,1)-"TABCOUAFF :"-time$,0) From GESECRAN

Local File =DOSSIER+".TABCOUAFF" [TCA], =DOSSIER+".TABCOUAFF" [TCA2]

Trbegin [TCA]

 For [TCA] Where CPY=""
  If [F:TCA]LEG=""
   Look [TCA2]TCA0=[F:TCA]MODULE;[F:ADS_U]DOSLEG;""
   If !fstat
    Delete [TCA]TCA0 Curr
   Else
    [F:TCA]LEG = [F:ADS_U]DOSLEG
    Rewrite [TCA]
   Endif
   If fstat
    Call ERREUR("TABCOUAFF"-num$([F:TCA]MODULE),2) From DOSDIC
   Endif
  Endif
 Next TCA

Commit

#-----------------------#
$FIN

Close Local File

Return

