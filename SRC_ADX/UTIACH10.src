#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIACH10       Utilitaire de récupération du bug 20182    Module ACHAT #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Resynchroniser le nombre de lignes soldées d'une commande            #
#   ainsi que le flag de solde                                           #
##########################################################################

Call MAJ_UTIACH10
End

Subprog MAJ_UTIACH10
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH10") From SAIDOS
If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH10 : Utilitaire de màj flag de solde commande achat") From LECFIC
  Call EXE_UTIACH10(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End

Subprog EXE_UTIACH10(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(80), WMSG2(90), WNUM(GLONPOH), CLE1(GLONPOH), CRITERE(50)
Local Integer COMPTEUR, STOP
Local Integer  NBENR,    NBCOR,   WLIN,    WSEQ, WNBR
#-----
Call ECR_TRACE("UTIACH10 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:POH]) =0  Local File =DOSSIER+".PORDER"   [POH] : Endif
If clalev([F:POQ]) =0  Local File =DOSSIER+".PORDERQ"  [POQ] : Endif
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, NBENR, NBCOR, STOP
#-----
$BOUCLE_POH
If  STOP=1
  CRITERE = 'POHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
CRITERE+=' & POHTYP=1'
Raz COMPTEUR
Trbegin [POH]
  For [POH] POH0 Where evalue(CRITERE)
    WNUM=[F:POH]POHNUM
    Raz WNBR
    COMPTEUR+=1
    NBENR+=1
    For [POQ]POQ0 Where POHNUM=[F:POH]POHNUM
      If [F:POQ]LINCLEFLG=2 : WNBR+=1 : Endif   
    Next
    If WNBR<>[F:POH]CLELINNBR
      Gosub MAJ_POH
    Elsif [F:POH]CLELINNBR=[F:POH]LINNBR & [F:POH]CLEFLG<>2
      Gosub MAJ_POH
    Elsif [F:POH]CLELINNBR<>[F:POH]LINNBR & [F:POH]CLEFLG=2
      Gosub MAJ_POH
    Endif
    If COMPTEUR>GMAXUPDTRS : CLE1=[F:POH]POHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP  Goto BOUCLE_POH : Endif
#----- Fin du traitement -----#
$FIN_UTIACH10
WMSG ="UTIACH10 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Close Local File [POH]
Close Local File [POQ]
End


$MAJ_POH
Readlock [POH] Curr
If fstat
  Call ECR_TRACE("File PORDER"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
Else
  [F:POH]CLELINNBR=WNBR
  If [F:POH]CLELINNBR=[F:POH]LINNBR 
    [F:POH]CLEFLG=2
  Else
    [F:POH]CLEFLG=1
  Endif
  Rewrite [POH]
  If fstat
    Call ECR_TRACE("Erreur réécriture"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
  Else
    WMSG ="Commande"-WNUM-"corrigée"
    Call ECR_TRACE(WMSG,0) From GESECRAN
    NBCOR+=1
  Endif
Endif
Return
