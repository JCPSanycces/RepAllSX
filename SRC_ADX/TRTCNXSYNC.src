#<AdxTL>@(#)2.0.0.0 $Revision$
################################################################################
#    TRAITEMENT DE SYNCHRONISATION DES CONTEXTES AVEC LA COMPTA
#    GLE
#    Création le : 23/02/2011
#    Modification le : --/--/----
#-------------------------------------------------------------------------------
#    Modification
#    CBO - 11.10.2016 FQ118331 : Reprise générale du trt pour gérer les changements de date de fin d'exercice.
#                                LIMITE : non actif si plan de production
#    CBO - 11.09.2015 FQ110860 : exercice futur créé avec statut courant.
#    MWA - 03.02.2015 FQ105737 : Ne pas créer des lignes de plan de production au delà de la fin du plan de production
#    GLE - 09.05.2011 FQ73644  : Correction bug de synchronisation si désynchronisation période courante
################################################################################


# Limites connues

# LIMITE : non actif si plan de production

# les périodes compta et immos sont identiques mais les immos en ont plus (exercice en plus ou dernier plus long)
# Message indiquant que la période (immos) n'est pas trouvée.
# -> la solution est de créer un nouvel exercice côté compta.


######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION
  #Infbox "TRTCNXSYNC /"-ACTION
  Case ACTION
    When "EXEC" : Gosub EXEC
  Endcase
Return

$EXEC
  Gosub SYNC_CNX
Return

################################################################################
# TRAITEMENT METIER
################################################################################
$SYNC_CNX

  Local Char CPY_FILTER(255)
  Local Char CNX_FILTER(255)

  Local Date    TRTSTRPER, TRTENDPER : # dates de début et fin de la première période à redécouper
  Local Date    TRTSTRFIY, TRTENDFIY : # dates de début et fin du premier exercice à redécouper
  Local Integer TRTINDPER            : # indice de la première période à redécouper
  Local Integer TRTSTAFIY            : # statut du premier exercice à redécouper

# Issue 118331
  Local Date    NEW_STRDATFIY           : # nouvelle date de début de l'exercice redécoupé # Issue 118331
  Local Date    NEW_ENDDATFIY           : # nouvelle date de fin de l'exercice redécoupé
  Local Date    NEW_STRDATPER           : # nouvelle date de début de la première période redécoupée
  Local Date    NEW_ENDDATPER           : # nouvelle date de fin de la première période redécoupée

  # pour les datas (PPL DEPREC) < première période modifiée :
  # si changement date deb/fin exercice
  Local Date OLD_STRDATFIY_CHG
  Local Date OLD_ENDDATFIY_CHG
  Local Date NEW_STRDATFIY_CHG
  Local Date NEW_ENDDATFIY_CHG

  Local Date TRTSTRPER_COUR
  Local Date TRTSTRFIY_COUR

# End Issue 118331


  Local Integer RERROR               : # pas d'erreur si = 0, erreur sinon
  Local Integer WDETAIL # Issue 118331
  WDETAIL = 0
  If GUSER = "CBO"
    WDETAIL = 01
  Endif

  Gosub OUVERTURE_TABLES

  Call OUVRE_TRACE("TRTCNXSYNC") From LECFIC

  If [M:CNXS]FLGSIM = G_OUI
    Call ECR_TRACE(mess(27, 107, 1), 0) From GESECRAN
  Endif
  Call ECR_TRACE("", 0) From GESECRAN
  If [M:CNXS]FLGALLCPY = G_OUI
    Call ECR_TRACE("All companies", 0) From GESECRAN
  Else
    Call ECR_TRACE("Company :" - [M:CNXS]CPY, 0) From GESECRAN
  Endif
  If [M:CNXS]FLGALLCNX = G_OUI
    Call ECR_TRACE("All contexts", 0) From GESECRAN
  Else
    Call ECR_TRACE("Context :" - mess([M:CNXS]CNX, 3100, 1), 0) From GESECRAN
  Endif
  Call ECR_TRACE("", 0) From GESECRAN


  # Filtre société
  If [M:CNXS]FLGALLCPY = G_OUI
    CPY_FILTER = "1=1"
  Else
    CPY_FILTER = "CPY='"+[M:CNXS]CPY+"'"
  Endif

  # Filtre contexte
  If [M:CNXS]FLGALLCNX = G_OUI
    CNX_FILTER = "1=1"
  Else
    CNX_FILTER = "CNX="+num$([M:CNXS]CNX)
  Endif

  For [CPY]CPY0 Where evalue(CPY_FILTER)
    Filter [F:CNX] Where CPY=[F:CPY]CPY
    NBCNX = rowcount([F:CNX])
    Filter [F:CNX]
    If NBCNX > 0
      Gosub TRAIT_CPY
    Endif
  Next

  If [M:CNXS]FLGSIM = G_OUI
    Call ECR_TRACE("\" + mess(48,GML_MSGCAL,1) - ":" - mess(27, 107, 1),0) From GESECRAN
  Else
    Call ECR_TRACE("\"+mess(27,150,1),0) From GESECRAN
  Endif

  Gosub FERMETURE_TABLES

  Call LEC_TRACE() From LECFIC
Return

$TRAIT_CPY
  RERROR = 0

  Call ECR_TRACE("\"+[F:CPY]CPY-[F:CPY]CPYNAM,0) From GESECRAN
  Call ECR_TRACE(string$(len([F:CPY]CPY-[F:CPY]CPYNAM),"="),0) From GESECRAN

  Trbegin [FIS]

  If func GLOBIENS.LOCK_SYMBOLE ("CNX", [F:CPY]CPY, "", 0) = 0 Then
    Call ECR_TRACE("CNX ("+[F:CPY]CPY+") :"-G_MSGQUILOCK,1) From GESECRAN
    RERROR = -1
  Endif
  If !RERROR and func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:CPY]CPY, "", 0) = 0 Then
    Call ECR_TRACE("FAS ("+[F:CPY]CPY+") :"-G_MSGQUILOCK,1) From GESECRAN
    RERROR = -1
  Endif

  Read [PLH]PPH1(1) = [F:CPY]CPY
  If fstat = 0
    Call ECR_TRACE(mess(105, 7784, 1), 1) From GESECRAN
    RERROR = -1
  Endif

  If !RERROR
    For [CNX]CNX0 Where CPY=[F:CPY]CPY and evalue(CNX_FILTER)
      Call ECR_TRACE(mess(16,GML_MSGCAL,1) - mess([F:CNX]CNX, 3100, 1), 0) From GESECRAN
      Call ECR_TRACE(mess(00166,00105,1) - ":" - mess([F:CNX]LEDTYP(0), 2644, 1), 0) From GESECRAN
      Call ECR_TRACE("--------------------------------------", 0) From GESECRAN

      If func GLOBIENS.IS_DESYNC_CNX([F:CNX]CPY, [F:CNX]CNX) = G_OUI
        # Chargement des informations du contexte
        Gosub CHARGE_INFO_CONTEXTE
        If RERROR : Break : Endif

        # Redécoupage du contexte
        Gosub MAJ_CNX
        If RERROR : Break : Endif

        # Redécoupage des plans de production
        Gosub MAJ_PPL
        If RERROR : Break : Endif

        # Amortissements
        Gosub TRAITE_DEPREC
        If RERROR : Break : Endif

        # Flux
        Gosub TRAITE_FXDLIFL
        If RERROR : Break : Endif

        # le contexte n'est plus désynchronisé mais est à calculer
        Gosub CALC_CNX
        If RERROR : Break : Endif
      Else
        Call ECR_TRACE(mess(271,GML_MSGFASPR,1),0) From GESECRAN
      Endif
    Next
  Endif

  Call UNLOCK_SYMBOLE ("CNX", [F:CPY]CPY, "") From GLOBIENS
  Call UNLOCK_SYMBOLE ("FAS", [F:CPY]CPY, "") From GLOBIENS

  If [M:CNXS]FLGSIM = G_OUI or RERROR
    If RERROR
      Call ECR_TRACE("\"+mess(48,GML_MSGCAL,1),1) From GESECRAN
    Endif
    Rollback
  Else
    Commit
  Endif

# Issue 118331
  # Control if CNX is Ok on fixed assets
  If WDETAIL
    Local Char RSOCERR(GLONCPY), RMESS(250)
    Local Integer RCNXERR

    If [M:CNXS]FLGALLCNX = G_OUI
      Call CTRL_CNX ([F:CPY]CPY, 0, 0, RSOCERR, RCNXERR, RMESS) From SUBCNX2
    Else
      Call CTRL_CNX ([F:CPY]CPY, [M:CNXS]CNX, 0, RSOCERR, RCNXERR, RMESS) From SUBCNX2
    Endif
    If RMESS <> ""
      Call ECR_TRACE([F:CPY]CPY - mess(RCNXERR, 3100, 1) - ":" - RMESS, 1) From GESECRAN
    Endif
  Endif
# End Issue 118331
Return

########################################
# Ouverture des tables
$OUVERTURE_TABLES
  If !clalev([F:CPY])   : Local File COMPANY    [CPY] : Endif
  If !clalev([F:CNX])   : Local File CONTEXT    [CNX] : Endif
  If !clalev([F:FIS])   : Local File FISCYEAR   [FIS] : Endif
  If !clalev([F:DEP])   : Local File DEPREC     [DEP] : Endif
  If !clalev([F:FLU])   : Local File FXDLIFL    [FLU] : Endif
  If !clalev([F:PLH])   : Local File PROPLNH    [PLH] : Endif : # Plans de production - en-tête
  If !clalev([F:PLP])   : Local File PROPLN     [PLP] : Endif : # Plans de production - ligne
  If G_ACTCCN = G_OUI
    If !clalev([F:RPR]) : Local File CCNRPR     [RPR] : Endif
  Endif
  # Tables Tronc Commun
  If !clalev([F:FIY])   : Local File FISCALYEAR [FIY] : Endif : # Exercices compta
  If !clalev([F:PER])   : Local File PERIOD     [PER] : Endif : # Périodes compta
Return

########################################
# Fermeture des tables
$FERMETURE_TABLES
  If clalev([F:CPY])   : Close File [CPY] : Endif
  If clalev([F:CNX])   : Close File [CNX] : Endif
  If clalev([F:FIS])   : Close File [FIS] : Endif
  If clalev([F:DEP])   : Close File [DEP] : Endif
  If clalev([F:FLU])   : Close File [FLU] : Endif
  If clalev([F:PLH])   : Close File [PLH] : Endif
  If clalev([F:PLP])   : Close File [PLP] : Endif
  If G_ACTCCN = G_OUI
    If clalev([F:RPR]) : Close File [RPR] : Endif
  Endif
  # Tables Tronc Commun
  If clalev([F:FIY])   : Close File [FIY] : Endif
  If clalev([F:PER])   : Close File [PER] : Endif
Return

#################################################
# lecture des informations du contexte
$CHARGE_INFO_CONTEXTE
  Local Integer N_PER
  TRTINDPER = -1
  TRTSTAFIY = -1 # FQ110860

  OLD_STRDATFIY_CHG = [0/0/0]
  OLD_ENDDATFIY_CHG = [0/0/0]
  NEW_STRDATFIY_CHG = [0/0/0]
  NEW_ENDDATFIY_CHG = [0/0/0]
  TRTSTRPER_COUR = [0/0/0]
  TRTSTRFIY_COUR = [0/0/0]

  # Repérage de la première période désynchronisée à partir de l'exercice courant
  For [F:FIS]FIY0 Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY<>GVML_TEPREC

    # Mémo de la période courante de l'exercice courant
    If [F:FIS]STAFIY = GVML_TECOURA
      [L]TRTSTRPER_COUR = [F:FIS]DATSTRPER([F:FIS]INDCURPER - 1)
      [L]TRTSTRFIY_COUR = [F:FIS]DATSTRFIY
    Endif

    For N_PER = [F:FIS]INDCURPER-1 To [F:FIS]NBRPER-1
      Filter [F:PER] Where PERSTR=[F:FIS]DATSTRPER(N_PER) and PEREND=[F:FIS]DATENDPER(N_PER)
      Read [F:PER]PER0(2)=[F:CNX]CPY;[F:CNX]LEDTYP(0)
      Filter [F:PER]

# Issue 118331
      # mêmes dates de période, mais est-ce le même exercice ?
      If fstat = 0

        Read [F:FIY]FIY0 = [F:CNX]CPY; [F:CNX]LEDTYP(0); [F:PER]FIYNUM
        # Même période mais dans un exercice différent : c'est donc la première période différente

        # SI ON A ALLONGE la compta : on doit compléter sur FISCYEAR les périodes (clef = l'exe compta (inférieur))
        # ie l'exe fas est donc supérieur à celui de la compta

        # SI ON A DIMINUE la compta : on doit supprimer sur FISCYEAR les dernières périodes (clef = l'exe compta (inférieur))
        # ie l'exe fas est donc inférieur à celui de la compta
        # Il faut partir de la période précédente (qui est la dernière de la compta) pour maj cet exercice

        If fstat = 0
          If [F:FIS]DATSTRFIY = [F:FIY]FIYSTR
            If [F:FIS]DATENDFIY = [F:FIY]FIYEND
              NEW_ENDDATFIY_CHG = [F:FIY]FIYEND
              OLD_ENDDATFIY_CHG = [F:FIS]DATENDFIY
            Endif
          Else

            If [F:FIS]DATSTRFIY > [F:FIY]FIYSTR # Allonge
              TRTSTRFIY = [F:FIY]FIYSTR
              TRTENDFIY = [F:FIY]FIYEND
              NEW_STRDATFIY_CHG = [F:FIY]FIYSTR
              NEW_ENDDATFIY_CHG = [F:FIY]FIYEND

              TRTSTRPER = [F:FIS]DATSTRPER(N_PER)
              TRTENDPER = [F:FIS]DATENDPER(N_PER)

              # Lire l'exercice précédent Immos : c'est celui sur lequel on va travailler
              Read [F:FIS]FIY0 = [F:CNX]CPY; [F:CNX]CNX; TRTSTRFIY
              If fstat = 0
                TRTSTAFIY = [F:FIS]STAFIY
                TRTINDPER = [F:FIS]NBRPER # sert à PPL
                NPER = [F:FIS]NBRPER
                OLD_STRDATFIY_CHG = [F:FIS]DATSTRFIY
                OLD_ENDDATFIY_CHG = [F:FIS]DATENDFIY
              Endif

            Else                                # Diminue

              TRTSTRFIY = [F:FIS]DATSTRFIY
              TRTENDFIY = [F:FIS]DATENDFIY
              OLD_STRDATFIY_CHG = [F:FIS]DATSTRFIY
              OLD_ENDDATFIY_CHG = [F:FIS]DATENDFIY

              TRTSTAFIY = [F:FIS]STAFIY
#             TRTINDPER = [F:FIS]NBRPER # sert à PPL
              If N_PER
                TRTINDPER = N_PER - 1
              Else
                TRTINDPER = 0
              Endif

              # lecture des nouvelles dates de début fin de l'exe à diminuer
              Read [F:FIY]FIY0 = [F:CNX]CPY; [F:CNX]LEDTYP(0); ([F:PER]FIYNUM - 1)
              NEW_STRDATFIY_CHG = [F:FIY]FIYSTR
              NEW_ENDDATFIY_CHG = [F:FIY]FIYEND

              TRTSTRPER = [F:FIS]DATSTRPER(N_PER - 1)
              TRTENDPER = [F:FIS]DATENDPER(N_PER - 1)
            Endif

            If WDETAIL
              Call ECR_TRACE("(1) : first changed period" - [F:CNX]CPY - "Ledger" - num$([F:CNX]LEDTYP(0)), 0) From GESECRAN
              Call ECR_TRACE("(1) : financials   Year" - [F:FIY]FIYSTR - "Period" - TRTSTRPER, 0) From GESECRAN
              Call ECR_TRACE("(1) : fixed assets Year" - [F:FIS]DATSTRFIY - "Period" - [F:FIS]DATSTRPER(N_PER), 0) From GESECRAN
              Call ECR_TRACE("(1) : used         Year" - TRTSTRFIY - "Period" - TRTSTRPER, 0) From GESECRAN
            Endif

            # Lecture de première période redécoupée côté compta
            Filter [F:PER] Where PERSTR = TRTSTRPER
            Read [F:PER]PER0(2) = [F:CNX]CPY; [F:CNX]LEDTYP(0)
            Filter [F:PER]
            If fstat
              Call PER_NOT_FOUND("1", TRTSTRFIY, TRTSTRPER)
              RERROR = -1
            Else
              NEW_STRDATPER = [F:PER]PERSTR
              NEW_ENDDATPER = [F:PER]PEREND
            Endif
            Break 2

          Endif
        Endif
# End Issue 118331

      # dates de période différentes
      Else

        If [F:FIS]STAPER(N_PER)=GVML_SPFERME or (find([F:FIS]STAPER(N_PER),GVML_SPCOURA,GVML_SPOUVER) and [F:FIS]TYPPST(N_PER)=GVML_TPSTPRO)
          # Issue 118331

          # la date de début de période doit être identique : on lit dessus
          # pour aller sur la dernière periode de l'exercice précédent qui sera la base de départ
          Filter [F:PER] Where CPY = [F:CNX]CPY and LEDTYP = [F:CNX]LEDTYP(0) and PERSTR=[F:FIS]DATSTRPER(N_PER)
          Read [F:PER]PER0 First
          Filter [F:PER]
          If fstat = 0
            # mêmes dates de période, mais est-ce le même exercice ?
            Read [F:FIY]FIY0 = [F:CNX]CPY; [F:CNX]LEDTYP(0); [F:PER]FIYNUM

            # période différente et dans un exercice différent

            # SI ON A ALLONGE la compta : on doit compléter sur FISCYEAR les périodes (clef = l'exe compta (inférieur))
            # ie l'exe fas est donc supérieur à celui de la compta

            If fstat = 0
              If [F:FIS]DATENDFIY = [F:FIY]FIYEND
                NEW_ENDDATFIY_CHG = [F:FIY]FIYEND
                OLD_ENDDATFIY_CHG = [F:FIS]DATENDFIY

              Elsif [F:FIS]DATENDFIY < [F:FIY]FIYEND # Allonge

                TRTSTRFIY = [F:FIY]FIYSTR
                TRTENDFIY = [F:FIY]FIYEND
                NEW_STRDATFIY_CHG = [F:FIY]FIYSTR
                NEW_ENDDATFIY_CHG = [F:FIY]FIYEND

                TRTSTRPER = [F:PER]PERSTR
                TRTENDPER = [F:PER]PEREND

                # Lire l'exercice précédent Immos : c'est celui sur lequel on va travailler
                Read [F:FIS]FIY0 = [F:CNX]CPY; [F:CNX]CNX; TRTSTRFIY
                If fstat = 0
                  TRTSTAFIY = [F:FIS]STAFIY
                  TRTINDPER = [F:FIS]NBRPER # sert à PPL
                  NPER = [F:FIS]NBRPER
                  OLD_STRDATFIY_CHG = [F:FIS]DATSTRFIY
                  OLD_ENDDATFIY_CHG = [F:FIS]DATENDFIY
                Endif

                If WDETAIL
                  Call ECR_TRACE("(3) : first changed period" - [F:CNX]CPY - "Ledger" - num$([F:CNX]LEDTYP(0)), 0) From GESECRAN
                  Call ECR_TRACE("(3) : financials   Year" - [F:FIY]FIYSTR - "Period" - TRTSTRPER, 0) From GESECRAN
                  Call ECR_TRACE("(3) : fixed assets Year" - [F:FIS]DATSTRFIY - "Period" - [F:FIS]DATSTRPER(N_PER), 0) From GESECRAN
                  Call ECR_TRACE("(3) : used         Year" - TRTSTRFIY - "Period" - TRTSTRPER, 0) From GESECRAN
                Endif

                # Lecture de première période redécoupée côté compta
                Filter [F:PER] Where PERSTR = TRTSTRPER
                Read [F:PER]PER0(2) = [F:CNX]CPY; [F:CNX]LEDTYP(0)
                Filter [F:PER]
                If fstat
                  Call PER_NOT_FOUND("4", TRTSTRFIY, TRTSTRPER)
                  RERROR = -1
                Else
                  NEW_STRDATPER = [F:PER]PERSTR
                  NEW_ENDDATPER = [F:PER]PEREND
                Endif
                Break 2

              Else # on diminue

                TRTSTRFIY = [F:FIS]DATSTRFIY
                TRTENDFIY = [F:FIS]DATENDFIY
                OLD_STRDATFIY_CHG = [F:FIS]DATSTRFIY
                OLD_ENDDATFIY_CHG = [F:FIS]DATENDFIY

                TRTSTAFIY = [F:FIS]STAFIY
                If N_PER
                  TRTINDPER = N_PER - 1
                Else
                  TRTINDPER = 0
                Endif

                # lecture des nouvelles dates de début fin de l'exe à diminuer
                Read [F:FIY]FIY0 = [F:CNX]CPY; [F:CNX]LEDTYP(0); ([F:PER]FIYNUM - 1)
                NEW_STRDATFIY_CHG = [F:FIY]FIYSTR
                NEW_ENDDATFIY_CHG = [F:FIY]FIYEND

                TRTSTRPER = [F:FIS]DATSTRPER(N_PER - 1)
                TRTENDPER = [F:FIS]DATENDPER(N_PER - 1)

                If WDETAIL
                  Call ECR_TRACE("(4) : first changed period" - [F:CNX]CPY - "Ledger" - num$([F:CNX]LEDTYP(0)), 0) From GESECRAN
                  Call ECR_TRACE("(4) : financials   Year" - [F:FIY]FIYSTR - "Period" - TRTSTRPER, 0) From GESECRAN
                  Call ECR_TRACE("(4) : fixed assets Year" - [F:FIS]DATSTRFIY - "Period" - [F:FIS]DATSTRPER(N_PER), 0) From GESECRAN
                  Call ECR_TRACE("(4) : used         Year" - TRTSTRFIY - "Period" - TRTSTRPER, 0) From GESECRAN
                Endif

                # Lecture de première période redécoupée côté compta
                Filter [F:PER] Where PERSTR = TRTSTRPER
                Read [F:PER]PER0(2) = [F:CNX]CPY; [F:CNX]LEDTYP(0)
                Filter [F:PER]
                If fstat
                  Call PER_NOT_FOUND("1", TRTSTRFIY, TRTSTRPER)
                  RERROR = -1
                Else
                  NEW_STRDATPER = [F:PER]PERSTR
                  NEW_ENDDATPER = [F:PER]PEREND
                Endif
                Break 2
              Endif

            Else # on ne dvrait jamais passer ici !
              Call PER_NOT_FOUND("5", [F:FIS]DATSTRFIY, [F:FIS]DATSTRPER(N_PER))
              RERROR = -1
              Break 2

            Endif


          Endif
          # End Issue 118331

          TRTSTRFIY = [F:FIS]DATSTRFIY
          TRTENDFIY = [F:FIS]DATENDFIY
          TRTSTRPER = [F:FIS]DATSTRPER(N_PER)
          TRTENDPER = [F:FIS]DATENDPER(N_PER)
          TRTSTAFIY = [F:FIS]STAFIY
          TRTINDPER = N_PER

          If WDETAIL
            Call ECR_TRACE("(2) : first changed period" - [F:CNX]CPY - "Ledger" - num$([F:CNX]LEDTYP(0)), 0) From GESECRAN
            Call ECR_TRACE("(2) : fixed assets Year" - [F:FIS]DATSTRFIY - "Period" - [F:FIS]DATSTRPER(N_PER), 0) From GESECRAN
            Call ECR_TRACE("(2) : used         Year" - TRTSTRFIY - "Period" - TRTSTRPER, 0) From GESECRAN
          Endif

          # Lecture de première période redécoupée côté compta
          Filter [F:PER] Where PERSTR=[F:FIS]DATSTRPER(N_PER)
          Read [F:PER]PER0(2)=[F:CNX]CPY;[F:CNX]LEDTYP(0)
          Filter [F:PER]
          If fstat
            Call PER_NOT_FOUND("2", [F:FIS]DATSTRFIY, [F:FIS]DATSTRPER(N_PER))
            RERROR = -1
          Else
            NEW_STRDATPER = [F:PER]PERSTR
            NEW_ENDDATPER = [F:PER]PEREND
          Endif
          Break 2
        Else
          Call ECR_TRACE("Fixed assets : Period status => can't be changed" -
&              "Exe" - [F:FIS]DATSTRFIY -
&              "per" - [F:FIS]DATSTRPER(N_PER) - "status" - mess([F:FIS]STAPER(N_PER), 3161, 1) -
&              "posting type" - mess([F:FIS]TYPPST(N_PER), 3211, 1), 1) From GESECRAN
          RERROR = -1
          Break 2
        Endif
      Endif
    Next
  Next

  If !RERROR and TRTINDPER = -1
    # Cas où des exercices ont été ajoutés en compta. Il n'y a pas de décalage compta/immo pour les exercices déclarés
    # mais il faut ajouter les nouveaux exercices. On se positionne sur la dernière période du dernier exercice.
    TRTSTRFIY  = [F:FIS]DATSTRFIY
    TRTENDFIY  = [F:FIS]DATENDFIY
    TRTSTRPER  = [F:FIS]DATSTRPER([F:FIS]NBRPER-1)
    TRTENDPER  = [F:FIS]DATENDPER([F:FIS]NBRPER-1)
    TRTSTAFIY  = [F:FIS]STAFIY
    TRTINDPER  = [F:FIS]NBRPER-1
    NEW_STRDATPER = [F:FIS]DATSTRPER([F:FIS]NBRPER-1)
    NEW_ENDDATPER = [F:FIS]DATENDPER([F:FIS]NBRPER-1)

    # Issue 118331
    If WDETAIL
      Call ECR_TRACE("(3) : first changed period" - [F:CNX]CPY - "Ledger" - num$([F:CNX]LEDTYP(0)), 0) From GESECRAN
      Call ECR_TRACE("(3) : fixed assets Year" - [F:FIS]DATSTRFIY - [F:FIS]DATSTRPER(N_PER), 0) From GESECRAN
      Call ECR_TRACE("(3) : used         Year" - TRTSTRFIY - TRTSTRPER, 0) From GESECRAN
    Endif
    # End Issue 118331

  Endif
Return

#################################################
# Mise à jour des périodes à partir de la compta
$MAJ_CNX
  Local Shortint TO_WRITE : TO_WRITE = 0
  Local Date     CPTSTRFIY, CPTENDFIY
  Local Decimal  NB_YEAR
  Local Integer  NB_DAY, NB_MONTH, NB_WEEK

  # Ménage : suppression des exercices au-delà de l'exercice de découpage
  Delete [F:FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and DATSTRFIY>[L]TRTSTRFIY

  # Exercice dans la compta correspondant à l'exercice de découpage dans les immos
  Filter [F:FIY] Where [F:FIY]FIYSTR=[L]TRTSTRFIY
  Read [F:FIY]FIY1=[F:CNX]CPY;[F:CNX]LEDTYP(0)
  Filter [F:FIY]
  If fstat
    Call ECR_TRACE(mess(2,14,1)-":"-mess(124,GML_MSGFASPR,1)-"("+num$(fstat)+") :"-[F:CNX]CPY-num$([F:CNX]CNX)-[L]TRTSTRFIY,1) From GESECRAN
    RERROR = -1
    Return
  Endif

  # Exercice de découpage immo
  Read [F:FIS]FIY0=[F:CNX]CPY;[F:CNX]CNX;[L]TRTSTRFIY
  If fstat
    Call ECR_TRACE(mess(14,14,1)-":"-mess(124,GML_MSGFASPR,1)-"("+num$(fstat)+") :"-[F:CNX]CPY-num$([F:CNX]CNX)-[L]TRTSTRFIY,1) From GESECRAN
    RERROR = -1
    Return
  Endif

  # Mise à jour de l'exercice de découpage
  For [F:PER]PER0 Where CPY=[F:CNX]CPY and LEDTYP=[F:CNX]LEDTYP(0) and FIYNUM=[F:FIY]FIYNUM and [F:PER]PERSTR>=[L]TRTSTRPER
    Gosub CRE_PER
    [F:FIS]NBRPER = [F:PER]PERNUM
  Next
  [F:FIS]DATENDFIY = [F:FIS]DATENDPER([F:FIS]NBRPER-1)
  NEW_STRDATFIY       = [F:FIS]DATSTRFIY # Issue 118331
  NEW_ENDDATFIY       = [F:FIS]DATENDFIY

  # Issue 118331
  # Raz des dernières périodes (non utilisées dans la table)
  Local Integer PER_FIN
  For PER_FIN = [F:FIS]NBRPER To (dim([F:FIS]DATENDPER) - 1)

    [F:FIS]DATSTRPER(PER_FIN) = AVOID.ADATE
    [F:FIS]DATENDPER(PER_FIN) = AVOID.ADATE
    [F:FIS]LSTTYPPRO(PER_FIN) = 0
    [F:FIS]NBRDAYPER(PER_FIN) = 0
    [F:FIS]NBRMONPER(PER_FIN) = 0
    [F:FIS]NBRWEKPER(PER_FIN) = 0
    [F:FIS]STAPER(PER_FIN) = 0
    [F:FIS]TYPPST(PER_FIN) = 0
  Next PER_FIN
  # End Issue 118331

  Rewrite [F:FIS]
  If fstat
    Call ECR_TRACE("MAJ_CNX 1"-num$(fstat),1) From GESECRAN
    RERROR = -1
    Return
  Endif
  Call ECR_TRACE(mess(33,141,1)-"FISCYEAR"-[F:FIS]CPY-num$([F:FIS]CNX)-[F:FIS]DATSTRFIY-[F:FIS]DATENDFIY,0) From GESECRAN

  # Création des exercices suivants
  Local Integer CURFIYNUM : [L]CURFIYNUM = [F:FIY]FIYNUM
  For [F:FIY]FIY0 Where CPY=[F:CNX]CPY and LEDTYP=[F:CNX]LEDTYP(0) and FIYNUM>[L]CURFIYNUM
    Raz [F:FIS]
    For [F:PER]PER0 Where CPY=[F:FIY]CPY and LEDTYP=[F:FIY]LEDTYP(0) and FIYNUM=[F:FIY]FIYNUM
      Gosub CRE_PER
      [F:FIS]NBRPER = [F:PER]PERNUM
    Next
    [F:FIS]CPY       = [F:CNX]CPY
    [F:FIS]CNX       = [F:CNX]CNX
    [F:FIS]DATSTRFIY = [F:FIS]DATSTRPER(0)
    [F:FIS]DATENDFIY = [F:FIS]DATENDPER([F:FIS]NBRPER-1)
    [F:FIS]INDCURPER = 1

    # FQ110860 : ne pas recréer un 2° statut courant
    If TRTSTAFIY = -1
      # TRTSTAFIY = -1 aucun exe trouvé, on part de 0 et le delta des exe donne le bon statut (mais on ne devrait jamais passer dans ce cas)
      TRTSTAFIY = 0
      [F:FIS]STAFIY    = [F:FIY]FIYNUM - [L]CURFIYNUM
    Elsif TRTSTAFIY = 0
      # TRTSTAFIY = 0 correspond à un exercice > exe de statut (suivant + 1) -> cet exercice devra l'être aussi, on force à statut à 0
      [F:FIS]STAFIY = 0
    Else
      # Cas standard : dernier statut identique + écart d'exercices
      [F:FIS]STAFIY    = [L]TRTSTAFIY + [F:FIY]FIYNUM - [L]CURFIYNUM
    Endif

    # Il n'y a pas de statut > 4 donc ce sera = 0.
    If [F:FIS]STAFIY > 4
      [F:FIS]STAFIY  = 0
    Endif

    Write [F:FIS]
    If fstat
      Call ECR_TRACE("MAJ_CNX 2"-[F:FIS]CPY-num$([F:FIS]CNX)-[F:FIS]DATSTRFIY-[F:FIS]DATENDFIY-num$(fstat),1) From GESECRAN
      RERROR = -1
      Break
    Else
      Call ECR_TRACE(mess(59,123,1)-"FISCYEAR"-[F:FIS]CPY-num$([F:FIS]CNX)-[F:FIS]DATSTRFIY-[F:FIS]DATENDFIY,0) From GESECRAN
    Endif
  Next
  If RERROR : Return : Endif
Return

$CRE_PER
If [F:PER]PERNUM-1 = 23
Local Integer CCBBOO
CCBBOO = 1
Endif
  [F:FIS]DATSTRPER([F:PER]PERNUM-1) = [F:PER]PERSTR
  [F:FIS]DATENDPER([F:PER]PERNUM-1) = [F:PER]PEREND

  If [F:FIS]STAPER([F:PER]PERNUM-1) <> GVML_SPCOURA
    Case  [F:PER]PERSTA
       When 1 # ==> période non-ouverte
         [F:FIS]STAPER([F:PER]PERNUM-1) = GVML_SPFERME
         [F:FIS]TYPPST([F:PER]PERNUM-1) = GVML_TPSTPRO # Issue 118331
       When 2 # ==> période ouverte
         [F:FIS]STAPER([F:PER]PERNUM-1) = GVML_SPFERME : # FQ73644
         [F:FIS]TYPPST([F:PER]PERNUM-1) = GVML_TPSTPRO # Issue 118331
       When 3 # ==> période fermée (ce cas ne devrait pas arriver dans ce traitement)
         [F:FIS]STAPER([F:PER]PERNUM-1) = GVML_SPCLOSE
         [F:FIS]TYPPST([F:PER]PERNUM-1) = 0
    Endcase
  Endif

  Call CALCUL_NB_D_M_W_Y ([F:FIS]DATSTRPER([F:PER]PERNUM-1),
&                         [F:FIS]DATENDPER([F:PER]PERNUM-1),
&                         NB_DAY,
&                         NB_MONTH,
&                         NB_WEEK,
&                         NB_YEAR) From GLOBIENS
  [F:FIS]NBRDAYPER([F:PER]PERNUM-1) = NB_DAY
  [F:FIS]NBRMONPER([F:PER]PERNUM-1) = NB_MONTH
  [F:FIS]NBRWEKPER([F:PER]PERNUM-1) = NB_WEEK

  Call ECR_TRACE("  "+mess(156,GML_MSGFAS,1)-[F:FIS]DATSTRPER([F:PER]PERNUM-1)-[F:FIS]DATENDPER([F:PER]PERNUM-1),0) From GESECRAN
Return

#################################################
# Mise à jour des plans de production
$MAJ_PPL
  Local Integer N_I
  Local Decimal LRSDQTY, LEXTQTY

  For [PLH]PPH1 Where CPY=[F:CNX]CPY
    Call ECR_TRACE("Mise à jour du plan de production"-[F:PLH]PROPLN-[F:PLH]PLNDES1,0) From GESECRAN

    # Exercice de découpage
    Read [F:FIS]FIY0=[F:CNX]CPY;[F:CNX]CNX;[L]TRTSTRFIY

    # Suppression des lignes de plan au-delà de la période de découpage
    Delete [F:PLP] Where PROPLN = [F:PLH]PROPLN and PERSTRDAT > [L]TRTSTRPER
  # Issue 118331
  # Maj des PPL antérieurs à la 1° période modifiée quand il y a un changement de dates d'exercice
  If OLD_STRDATFIY_CHG <> [0/0/0]
    Update [F:PLP] Where PROPLN = [F:PLH]PROPLN and FIYSTRDAT = [L]OLD_STRDATFIY_CHG and PERSTRDAT < [L]TRTSTRPER
&                  With FIYSTRDAT = [L]NEW_STRDATFIY_CHG,
&                       FIYENDDAT = [L]NEW_ENDDATFIY_CHG
  Endif
  # End Issue 118331

    # Modification de la date de fin d'exercice pour les lignes de plans première période modifiée
    # Issue 118331
    Update [F:PLP] Where PROPLN = [F:PLH]PROPLN and  PERSTRDAT = [L]TRTSTRPER
&                   With FIYSTRDAT = [L]NEW_STRDATFIY_CHG,
&                        FIYENDDAT = [L]NEW_ENDDATFIY_CHG,
&                        PERENDDAT = [L]NEW_ENDDATPER
    If fstat
      Call ECR_TRACE("MAJ_PPL 1"-num$(fstat),1) From GESECRAN
      RERROR = -1
      Return #CHECK IGNORE_LINE
    Endif

    # Ligne de plan première période modifiée
    # Issue 118331
    Filter [F:PLP] Where PROPLN=[F:PLH]PROPLN and FIYENDDAT=[L]NEW_ENDDATFIY
    Read [PLP]PPL0 Last
    Filter [F:PLP]

    LRSDQTY = [F:PLP]RSDQTY
    LEXTQTY = [F:PLP]EXTQTY

    Local Shortint N_STR
    For N_PER = TRTINDPER To [F:FIS]NBRPER-1
      # FQ105737
      If([F:PLH]PPLENDDAT0 = [0/0/0] or ([F:PLH]PPLENDDAT0 >= [F:FIS]DATSTRPER(N_PER)))
        Gosub CRE_PPL
      Endif
    Next

    # Exercices suivants
    # Issue 118331
    For [F:FIS]FIY0 Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and DATSTRFIY > [L]NEW_ENDDATFIY
      For N_PER = 0 To [F:FIS]NBRPER-1
        # FQ105737
        If([F:PLH]PPLENDDAT0 = [0/0/0] or ([F:PLH]PPLENDDAT0 >= [F:FIS]DATSTRPER(N_PER)))
          Gosub CRE_PPL
        Endif
      Next
    Next
  Next
Return

$CRE_PPL
  [F:PLP]PROPLN    = [F:PLH]PROPLN
  [F:PLP]FIYSTRDAT = [F:FIS]DATSTRFIY
  [F:PLP]FIYENDDAT = [F:FIS]DATENDFIY
  [F:PLP]PERSTRDAT = [F:FIS]DATSTRPER(N_PER)
  [F:PLP]PERENDDAT = [F:FIS]DATENDPER(N_PER)
  [F:PLP]CPLQTY    = 0

  [F:PLP]RSDQTY    = LRSDQTY - LEXTQTY : # mise à jour du résiduel
  If [F:PLP]RSDQTY < 0 : [F:PLP]RSDQTY = 0 : Endif

  LRSDQTY          = [F:PLP]RSDQTY
  LEXTQTY          = [F:PLP]EXTQTY
  If [F:PLP]PERSTRDAT = [L]TRTSTRPER
    Onerrgo ERR_REWRITE # Issue 118331
    Rewrite [PLP]
    Onerrgo # Issue 118331
  Else
    Write [PLP]
  Endif

  If fstat
    Call ECR_TRACE("CRE_PPL 1"-[F:PLP]PROPLN-[F:PLP]FIYENDDAT-[F:PLP]PERENDDAT-num$(fstat), 1) From GESECRAN
    RERROR = -1
    Return
  Endif
  Call ECR_TRACE(mess(59,123,1)-"PROPLN"-[F:PLP]PROPLN-[F:PLP]FIYENDDAT-[F:PLP]PERENDDAT, 0) From GESECRAN
Return
# Issue 118331
$ERR_REWRITE
  Write [PLP]
Resume
# End Issue 118331
#################################################
# Amortissements
$TRAITE_DEPREC
  # Suppression des amortissements au-delà de la première période modifiée
  # Issue 118331
  If TRTSTRPER_COUR = [0/0/0]
    Delete [F:DEP] Where CPY = [F:CNX]CPY and CNX = [F:CNX]CNX and PERSTRDAT > [L]TRTSTRPER
  Else
    Delete [F:DEP] Where CPY = [F:CNX]CPY and CNX = [F:CNX]CNX and PERSTRDAT > [L]TRTSTRPER_COUR
  Endif

  Call ECR_TRACE("DEPREC :"-num$(adxdlrec)-mess(959,196,1) - ": PERSTRDAT >" - [L]TRTSTRPER, 0) From GESECRAN

  # Maj des deprec antérieurs à la 1° période modifiée quand il y a un changement de dates d'exercice
  # Issue 118331
  If OLD_STRDATFIY_CHG <> [0/0/0]
    Update [F:DEP] Where CPY = [F:CNX]CPY and CNX = [F:CNX]CNX and FIYSTRDAT = [L]OLD_STRDATFIY_CHG and PERSTRDAT < [L]TRTSTRPER
&                  With FIYSTRDAT = [L]NEW_STRDATFIY_CHG,
&                       FIYENDDAT = [L]NEW_ENDDATFIY_CHG
  Endif

  # Mise à jour de la date de fin d'exercice et de période de la première période modifiée
  # Issue 118331
  Update [F:DEP] Where CPY = [F:CNX]CPY and CNX = [F:CNX]CNX and FIYSTRDAT = [L]TRTSTRFIY and PERSTRDAT = [L]TRTSTRPER
&                 With FIYSTRDAT = [L]NEW_STRDATFIY,
&                      FIYENDDAT = [L]NEW_ENDDATFIY,
&                      PERENDDAT = [L]NEW_ENDDATPER

  # Mise à jour de la date de fin d'exercice des DEPREC de l'exercice redécoupé
  # Issue 118331
  If [L]NEW_ENDDATFIY <> [L]TRTENDFIY
    Update [F:DEP] Where CPY = [F:CNX]CPY and CNX = [F:CNX]CNX and FIYSTRDAT = [L]TRTSTRFIY and PERSTRDAT <> [L]TRTSTRPER
&                   With FIYSTRDAT = [L]NEW_STRDATFIY,
&                        FIYENDDAT = [L]NEW_ENDDATFIY
  Endif

  # Plans de renouvellement
  If G_ACTCCN = G_OUI and [F:CNX]CNX=G300CPFI
    Gosub TRAITE_CCNRPR
  Endif

Return

$TRAITE_CCNRPR

  If TRTSTRPER_COUR = [0/0/0]
    Delete [F:RPR] Where CPY = [F:CNX]CPY and CNX = [F:CNX]CNX and PERSTRDAT > [L]TRTENDPER
  Else
    Delete [F:RPR] Where CPY = [F:CNX]CPY and CNX = [F:CNX]CNX and PERSTRDAT > [L]TRTSTRPER_COUR
  Endif

  # Issue 118331
  # Maj des deprec antérieurs à la 1° période modifiée quand il y a un changement de dates d'exercice
  If OLD_STRDATFIY_CHG <> [0/0/0]
    Update [F:RPR] Where CPY = [F:CNX]CPY and CNX = [F:CNX]CNX and FIYSTRDAT = [L]OLD_STRDATFIY_CHG and PERSTRDAT < [L]TRTSTRPER
&                  With FIYSTRDAT = [L]NEW_STRDATFIY_CHG,
&                       FIYENDDAT = [L]NEW_ENDDATFIY_CHG
  Endif

  # Issue 118331
  Update [F:RPR] Where CPY = [F:CNX]CPY and CNX = [F:CNX]CNX and FIYSTRDAT = [L]TRTSTRFIY and PERSTRDAT = [L]TRTSTRPER
&                   With FIYSTRDAT = [L]NEW_STRDATFIY,
&                        FIYENDDAT = [L]NEW_ENDDATFIY,
&                        PERENDDAT = [L]NEW_ENDDATPER

  If [L]NEW_ENDDATFIY <> [L]TRTENDFIY
    Update [F:RPR] Where CPY = [F:CNX]CPY and CNX = [F:CNX]CNX and FIYSTRDAT = [L]TRTSTRFIY and PERSTRDAT <> [L]TRTSTRPER
&                     With FIYSTRDAT = [L]NEW_STRDATFIY,
&                          FIYENDDAT = [L]NEW_ENDDATFIY
  Endif

Return

#################################################
# Flux
$TRAITE_FXDLIFL
  # Suppression des flux provisoires
  # Issue 118331
  Delete [F:FLU] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and FLGSTATXS=GVML_TXSPRO
  Call ECR_TRACE("FXDLIFL :"-num$(adxdlrec)-mess(959,196,1), 0) From GESECRAN

  # Mise à jour de la date de fin d'exercice des FLUX de l'exercice redécoupé
  # Issue 118331
  If [L]NEW_ENDDATFIY <> [L]TRTENDFIY
    Update [F:FLU] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and FIYSTRDAT=[L]TRTSTRFIY
&                   With FIYENDDAT = [L]NEW_ENDDATFIY
  Endif
Return

#################################################
# Le contexte est à calculer
$CALC_CNX
  Local Integer RCOD
  Call RAZ_UPD_WAI_CNX([F:CNX]CPY, [F:CNX]CNX, RCOD) From UPDWAICNX
  Call ADD_UPD_WAI_CNX([F:CNX]CPY, [F:CNX]CNX, "CNX", "CALCNX", "", "", RCOD) From UPDWAICNX
Return

Subprog PER_NOT_FOUND(PINDICE, PSTRFIY, PSTRPER)
Value Char PINDICE()
Value Date PSTRFIY, PSTRPER

  Call ECR_TRACE("(" + PINDICE + ") : Period of Fixed assets not found in Financials" -
&                ": Start year" - format$("D:" + GFMDAT4, PSTRFIY) - "Start period" - format$("D:" + GFMDAT4, PSTRPER), 1) From GESECRAN

End

################################################################################
# ACTIONS CHAMPS
################################################################################
Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()
  If [M:CNXS]FLGALLCPY = G_OUI
    VALEUR = ""
    Grizo [M:CNXS]CPY
  Else
    Actzo [M:CNXS]CPY
  Endif
End

Subprog AV_CNX(VALEUR)
Variable Integer VALEUR
  If [M:CNXS]FLGALLCNX = G_OUI
    Grizo [M:CNXS]CNX
  Else
    Actzo [M:CNXS]CNX
  Endif
End

Subprog AS_CNX(VALEUR)
Variable Integer VALEUR
  If [M:CNXS]CPY <> ""
    Local Shortint N_CNX
    If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
    For N_CNX = 1 To G300MAX
      Look [F:CNX]CNX0=[M:CNXS]CPY;N_CNX
      If fstat
        GMENLOC(N_CNX)=1
      Endif
    Next
  Endif
End

