#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du fichier AOBJEXTR
Raz GBIDC1, GBIDC2
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AOR",GBIDC1,GBIDC2) From GOBJET
End
################################################################################################################
$ACTION
  Case ACTION
   When "OUVRE"      : Gosub OUVRE
   When "LIENS"      : Gosub LIENS
   When "INICRE"     : Gosub INICRE
   When "RAZCRE"     : Gosub RAZCRE
   When "DEBUT_MOD"  : Gosub SUP_TEXTE
   When "APRES_CRE"  : Gosub MAJ_TEXTE
   When "APRES_MOD"  : Gosub MAJ_TEXTE
   When "ANNULE"     : Gosub SUP_TEXTE
  Endcase
Return
##########################################
$OUVRE
If !clalev([F:AOR2])    Local File AOBJEXTR       [AOR2]  : Endif
Return

$LIENS
Call LECTEXTRA([M]CODINTIT([F]NUMLIG-1),"AOBJEXTR","CODINTIT",num$([M]NUMTAB),[F]CODLOC+"~"+[F]CODEXT) From ATEXTRA
Return


$INICRE
[F:AOR]NUMLIG = nolign
[F:AOR]NUMCAR = num$([M]NUMTAB)
Return

$RAZCRE
 Read[AOR]AOR0 Last
 If !fstat
  [M:AOR0]NUMTAB = [F:AOR]NUMTAB + 1
  Affzo NUMTAB
 Endif
Return

$MAJ_TEXTE
Local Integer I
Call MAJTEXTRA([M]INTIT,"AOBJEXTR","INTIT",num$([M]NUMTAB),"") From ATEXTRA
For I=0 To [M]NBLIG-1
 Call MAJTEXTRA([M]CODINTIT(I),"AOBJEXTR","CODINTIT",num$([M]NUMTAB),[M]CODLOC(I)+"~"+[M]CODEXT(I)) From ATEXTRA
Next I
Return

$SUP_TEXTE
Local Integer NOTAB : NOTAB=[M]NUMTAB
# Call SUPTEXTRA("AOBJEXTR","INTIT",num$(NOTAB),"") From ATEXTRA         # 119210 - Description field on transcoding table
Call SUPTEXLAN("AOBJEXTR","INTIT",GLANGUE,num$(NOTAB),"") From ATEXTRA   # 119210 - Description field on transcoding table
For [AOR2] Where [F:AOR2]NUMTAB=NOTAB
# Call SUPTEXTRA("AOBJEXTR","CODINTIT",num$([F:AOR2]NUMTAB),[F:AOR2]CODLOC+"~"+[F:AOR2]CODEXT) From ATEXTRA  # 119210 - Description field on transcoding table
 Call SUPTEXLAN("AOBJEXTR","CODINTIT",GLANGUE,num$([F:AOR2]NUMTAB),[F:AOR2]CODLOC+"~"+[F:AOR2]CODEXT) From ATEXTRA  # 119210 - Description field on transcoding table
Next AOR
Return

########################################
Subprog C_CODLOC(VALEUR)
Variable Char VALEUR()
 If VALEUR <> vireblc(VALEUR,4)
  Call ERREUR(mess(71,133,1)) From GESECRAN : # Code local et code externe identiques
  mkstat = 2
 Endif
End

########################################
Subprog C_CODEXT(VALEUR)
Variable Char    VALEUR()
If VALEUR <> vireblc(VALEUR,4)
 Call ERREUR(mess(71,133,1)) From GESECRAN : # Code local et code externe identiques
 mkstat = 2
 End
Endif
If VALEUR = [M]CODLOC(nolign-1)
 Call ERREUR(mess(191,126,1)) From GESECRAN : # Code local et code externe identiques
 mkstat = 2
 End
Endif
For I=1 To [M]NBLIG
 If [M]CODEXT(I-1)-[M]CODLOC(I-1) =  VALEUR-[M]CODLOC(nolign-1) & I<>nolign
  Call ERREUR(mess(24,123,1)-num$(I)) From GESECRAN : # Code déjà existant en ligne
  mkstat = 1 : Break
 Endif
Next
End



######################################################################################

