#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTIREPLAN       Utilitaire installation nouvelle replanification       #
#                                                                        #
# ---------------------------------------------------------------------- #
# Initialisation des nouvelles zones a partir des anciennes valeurs      #
##########################################################################

Call MAJ_UTIREPLAN
End


Subprog MAJ_UTIREPLAN
Local Char DOSSIER(30) : DOSSIER=nomap
Call OUVRE_TRACE("UTIREPLAN: New Replanning function setup") From LECFIC
Call TEMPON("O") From GESECRAN
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>"" Call EXE_UTIREPLAN(DOSSIER) : Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

Subprog EXE_UTIREPLAN(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIREPLAN: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:PCB])  =0  Local File =DOSSIER+".PARMRP"       [PCB] : Endif

Local Integer NBPCB : NBPCB = 0

Call DEBTRANS From GLOCK
Trbegin [PCB]

For [PCB]
       GOK = 1  
       Readlock [PCB]PCB0 Curr
       If fstat
           Call ECR_TRACE("File PARMRP, Error ="-num$(fstat),1) From GESECRAN
       Else
           #------------------- MRP
           If !find([F:PCB]RPLTYP(0),1,2,3,4)
               [F:PCB]RPLTYP(0)       = 1
               If dim([F:PCB]MRPWOFRPL) > 0 & dim([F:PCB]MRPWOFLTI) > 0
                   [F:PCB]RPLMOD(0)       = [F:PCB]MRPWOFRPL
                   [F:PCB]RPLBWDLTI(0)    = [F:PCB]MRPWOFLTI
                   [F:PCB]RPLFRWLTI(0)    = int([F:PCB]MRPWOFLTI / 4)
                   If [F:PCB]MRPWOFRPL > 1
                       [F:PCB]RPLUPDQTY(0)    = 4
                       [F:PCB]RPLUPDDAT(0)    = 4
                   Else
                       [F:PCB]RPLUPDQTY(0)    = 1
                       [F:PCB]RPLUPDDAT(0)    = 1
                   Endif
               Else
                   [F:PCB]RPLUPDQTY(0)    = 1
                   [F:PCB]RPLUPDDAT(0)    = 1
               Endif
           Endif
           If !find([F:PCB]RPLTYP(1),1,2,3,4)
               [F:PCB]RPLTYP(1)       = 2
               If dim([F:PCB]MRPWOPRPL) > 0 & dim([F:PCB]MRPWOPLTI) > 0
                   [F:PCB]RPLMOD(1)       = [F:PCB]MRPWOPRPL
                   [F:PCB]RPLBWDLTI(1)    = [F:PCB]MRPWOPLTI
                   [F:PCB]RPLFRWLTI(1)    = int([F:PCB]MRPWOPLTI / 4)
                   If [F:PCB]MRPWOPRPL > 1
                       [F:PCB]RPLUPDQTY(1)    = 4
                       [F:PCB]RPLUPDDAT(1)    = 4
                   Else
                       [F:PCB]RPLUPDQTY(1)    = 1
                       [F:PCB]RPLUPDDAT(1)    = 1
                   Endif
               Else
                   [F:PCB]RPLUPDQTY(1)    = 1
                   [F:PCB]RPLUPDDAT(1)    = 1
               Endif
           Endif
           If !find([F:PCB]RPLTYP(2),1,2,3,4)
               [F:PCB]RPLTYP(2)       = 3
               If dim([F:PCB]MRPPOFRPL) > 0 & dim([F:PCB]MRPPOFLTI) > 0
                   [F:PCB]RPLMOD(2)       = [F:PCB]MRPPOFRPL
                   [F:PCB]RPLBWDLTI(2)    = [F:PCB]MRPPOFLTI
                   [F:PCB]RPLFRWLTI(2)    = int([F:PCB]MRPPOFLTI / 4)
                   If [F:PCB]MRPPOFRPL > 1
                       [F:PCB]RPLUPDQTY(2)    = 4
                       [F:PCB]RPLUPDDAT(2)    = 4
                   Else
                       [F:PCB]RPLUPDQTY(2)    = 1
                       [F:PCB]RPLUPDDAT(2)    = 1
                   Endif
               Else
                   [F:PCB]RPLUPDQTY(2)    = 1
                   [F:PCB]RPLUPDDAT(2)    = 1
               Endif
           Endif
           If !find([F:PCB]RPLTYP(3),1,2,3,4)
               [F:PCB]RPLTYP(3)       = 4
               If dim([F:PCB]MRPPOPRPL) > 0 & dim([F:PCB]MRPPOPLTI) > 0
                   [F:PCB]RPLMOD(3)       = [F:PCB]MRPPOPRPL
                   [F:PCB]RPLBWDLTI(3)    = [F:PCB]MRPPOPLTI
                   [F:PCB]RPLFRWLTI(3)    = int([F:PCB]MRPPOPLTI / 4)
                   If [F:PCB]MRPPOPRPL > 1
                       [F:PCB]RPLUPDQTY(3)    = 4
                       [F:PCB]RPLUPDDAT(3)    = 4
                   Else
                       [F:PCB]RPLUPDQTY(3)    = 1
                       [F:PCB]RPLUPDDAT(3)    = 1
                   Endif
               Else
                   [F:PCB]RPLUPDQTY(3)    = 4
                   [F:PCB]RPLUPDDAT(3)    = 4
               Endif
           Endif               
           If !find([F:PCB]WIPPRO,1,2,3)    : [F:PCB]WIPPRO = 1 : Endif
           If !find([F:PCB]RESBLWLOT,1,2)   : [F:PCB]RESBLWLOT = 1 : Endif
           If !find([F:PCB]MRPSAFCOV,1,2)   : [F:PCB]MRPSAFCOV = 1 : Endif
           #------------------- MPS
           If !find([F:PCB]RPLTYPS(0),1,2,3,4)
               If dim([F:PCB]MPSWOFRPL) > 0 & dim([F:PCB]MPSWOFLTI) > 0
                   [F:PCB]RPLTYPS(0)       = 1
                   [F:PCB]RPLMODS(0)       = [F:PCB]MPSWOFRPL
                   [F:PCB]RPLBWDLTIS(0)    = [F:PCB]MPSWOFLTI
                   [F:PCB]RPLFRWLTIS(0)    = int([F:PCB]MPSWOFLTI / 4)
                   If [F:PCB]MPSWOFRPL > 1
                       [F:PCB]RPLUPDQTYS(0)    = 4
                       [F:PCB]RPLUPDDATS(0)    = 4
                   Else
                       [F:PCB]RPLUPDQTYS(0)    = 1
                       [F:PCB]RPLUPDDATS(0)    = 1
                   Endif
               Else
                   [F:PCB]RPLUPDQTYS(0)    = 1
                   [F:PCB]RPLUPDDATS(0)    = 1
               Endif
           Endif
           If !find([F:PCB]RPLTYPS(1),1,2,3,4)
               [F:PCB]RPLTYPS(1)       = 2
               If dim([F:PCB]MPSWOPRPL) > 0 & dim([F:PCB]MPSWOPLTI) > 0
                   [F:PCB]RPLMODS(1)       = [F:PCB]MPSWOPRPL
                   [F:PCB]RPLBWDLTIS(1)    = [F:PCB]MPSWOPLTI
                   [F:PCB]RPLFRWLTIS(1)    = int([F:PCB]MPSWOPLTI / 4)
                   If [F:PCB]MPSWOPRPL > 1
                       [F:PCB]RPLUPDQTYS(1)    = 4
                       [F:PCB]RPLUPDDATS(1)    = 4
                   Else
                       [F:PCB]RPLUPDQTYS(1)    = 1
                       [F:PCB]RPLUPDDATS(1)    = 1
                   Endif
               Else
                   [F:PCB]RPLUPDQTYS(1)    = 1
                   [F:PCB]RPLUPDDATS(1)    = 1
               Endif
           Endif
           If !find([F:PCB]RPLTYPS(2),1,2,3,4)
               [F:PCB]RPLTYPS(2)       = 3
               If dim([F:PCB]MPSPOFRPL) > 0 & dim([F:PCB]MPSPOFLTI) > 0
                   [F:PCB]RPLMODS(2)       = [F:PCB]MPSPOFRPL
                   [F:PCB]RPLBWDLTIS(2)    = [F:PCB]MPSPOFLTI
                   [F:PCB]RPLFRWLTIS(2)    = int([F:PCB]MPSPOFLTI / 4)
                   If [F:PCB]MPSPOFRPL > 1
                       [F:PCB]RPLUPDQTYS(2)    = 4
                       [F:PCB]RPLUPDDATS(2)    = 4
                   Else
                       [F:PCB]RPLUPDQTYS(2)    = 1
                       [F:PCB]RPLUPDDATS(2)    = 1
                   Endif
               Else
                   [F:PCB]RPLUPDQTYS(2)    = 1
                   [F:PCB]RPLUPDDATS(2)    = 1
               Endif
           Endif
           If !find([F:PCB]RPLTYPS(3),1,2,3,4)
               [F:PCB]RPLTYPS(3)       = 4
               If dim([F:PCB]MPSPOPRPL) > 0 & dim([F:PCB]MPSPOPLTI) > 0
                   [F:PCB]RPLMODS(3)       = [F:PCB]MPSPOPRPL
                   [F:PCB]RPLBWDLTIS(3)    = [F:PCB]MPSPOPLTI
                   [F:PCB]RPLFRWLTIS(3)    = int([F:PCB]MPSPOPLTI / 4)
                   If [F:PCB]MPSPOPRPL > 1
                       [F:PCB]RPLUPDQTYS(3)    = 4
                       [F:PCB]RPLUPDDATS(3)    = 4
                   Else
                       [F:PCB]RPLUPDQTYS(3)    = 1
                       [F:PCB]RPLUPDDATS(3)    = 1
                   Endif
               Else
                   [F:PCB]RPLUPDQTYS(3)    = 1
                   [F:PCB]RPLUPDDATS(3)    = 1
               Endif
           Endif               
           If !find([F:PCB]WIPPROS,1,2,3)   : [F:PCB]WIPPROS = 1 : Endif
           If !find([F:PCB]RESBLWLOTS,1,2)  : [F:PCB]RESBLWLOTS = 1 : Endif
           If !find([F:PCB]MPSSAFCOV,1,2)   : [F:PCB]MPSSAFCOV = 1 : Endif
           NBPCB += 1
           Rewrite [PCB]        
       Endif
$SUITE_UTIREPLAN
Next
Commit
Filter [PCB]
Close Local File [PCB]

Call ECR_TRACE("UTIREPLAN : "+num$(NBPCB)+" records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(6) <> 2 : End : Endif
Call EXE_UTIREPLAN(APPLI)        # llc 05.02 cohérence
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

# module 6 = stock
If [F:ADS]MODULE(6) <> 2 : End : Endif
Call EXE_UTIREPLAN(APPLI)      
End
