#<AdxTL>@(#)0.0.0.0 $Revision$Class ## ?IDENTQRY? SEARCH ##
# Supervisor
#WMSRHCACCEDEF CACCEDEF
# 2018-11-06 07:04:07 252

Funprog IS_IMPLEMENTED()
End 1
#---------------------------------------------------------------------------------------------------#
# List of tables to open
#---------------------------------------------------------------------------------------------------#
$ASEARCH_OPEN
If filinfo(filpath("FIL","CACCEDEF","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File CACCEDEF [CDE]
Local File CACCEDEF [CDE_]
Local File ATEXTRA [AXX_1]
Local File ATEXTRA [AXX_2]
Local Char KEY_CDE(120)(1..3)
ACTION = "ASEARCH_OPEN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to close
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CLOSE
LogicClose File [CDE]
LogicClose File [CDE_]
LogicClose File [AXX_1]
LogicClose File [AXX_2]
ACTION = "ASEARCH_CLOSE_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN
Link [CDE] With
& [CDE_]CDE0=[CDE]COD;[CDE]CPY,
& [F:AXX_1]AXX0 = "CACCEDEF";"DESTRA";GACTX.LAN;[F:CDE]COD;"",
& [F:AXX_2]AXX0 = "CACCEDEF";"SHOTRA";GACTX.LAN;[F:CDE]COD;""
& As [LNK_]
& Where (1=1
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN_INC
Link [CDE] With
& [CDE_]CDE0=[CDE]COD;[CDE]CPY,
& [F:AXX_1]AXX0 = "CACCEDEF";"DESTRA";GACTX.LAN;[F:CDE]COD;"",
& [F:AXX_2]AXX0 = "CACCEDEF";"SHOTRA";GACTX.LAN;[F:CDE]COD;""
& As [LNK_]
& Where (UPDDATTIM > gdatetime$(QUPDDATTIM)
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Create an instance of
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CREATEINSTANCE
Local Integer ASTATUS
Local Integer FINS
#Create a new instance
INS = NewInstance C_CACCEDEF(GACTX,UIDINS,NUMLIN,null,"") AllocGroup null
INS.setaccessorEnabled = 0
Local Integer CI1
Local Integer CJ1
Local Char    SEPINS1(2) : SEPINS1=""
Local Char IS1(1)

Local Integer DIMCEN_MAXI:DIMCEN_MAXI= 0
If dim([F:CDE]DIE)>0
    If DIMCEN_MAXI = 0
        DIMCEN_MAXI = dim([F:CDE]DIE)
    Else
        DIMCEN_MAXI = min(DIMCEN_MAXI,dim([F:CDE]DIE))
    Endif
Endif
CJ1=1
For CI1 = 0 To DIMCEN_MAXI-1
#Create a new instance
INS.DIMCEN(CJ1) = NewInstance C_CACCEDEF_DIMCEN(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
INS.DIMCEN(CJ1).setaccessorEnabled = 0
 CJ1+=1
Next CI1
Local Integer IDENT_MAXI:IDENT_MAXI= 0
If dim([F:CDE]FLD)>0
    If IDENT_MAXI = 0
        IDENT_MAXI = dim([F:CDE]FLD)
    Else
        IDENT_MAXI = min(IDENT_MAXI,dim([F:CDE]FLD))
    Endif
Endif
CJ1=1
For CI1 = 0 To IDENT_MAXI-1
#Create a new instance
INS.IDENT(CJ1) = NewInstance C_CACCEDEF_IDENT(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
INS.IDENT(CJ1).setaccessorEnabled = 0
 CJ1+=1
Next CI1
Return

#---------------------------------------------------------------------------------------------------#
# Set an instance
#---------------------------------------------------------------------------------------------------#
$ASEARCH_SETINSTANCE

SetInstance INS With [F:CDE]
FINS = 1
Call ASETTEXTRA(INS.AXX,INS.ALLOCGRP(),"DESTRA",[F:AXX_1]TEXTE,GACTX.LAN) From ASYRSUB
Call ASETTEXTRA(INS.AXX,INS.ALLOCGRP(),"SHOTRA",[F:AXX_2]TEXTE,GACTX.LAN) From ASYRSUB
Local Integer DIMCEN_MAXI:DIMCEN_MAXI= 0
Local Integer DIMCEN_MAX:DIMCEN_MAX=0
If dim([F:CDE]DIE)>0
    If DIMCEN_MAXI = 0
        DIMCEN_MAXI = dim([F:CDE]DIE)
    Else
        DIMCEN_MAXI = min(DIMCEN_MAXI,dim([F:CDE]DIE))
    Endif
Endif
CJ1=1
For CI1 = 0 To DIMCEN_MAXI-1
 Break ((CI1 > [F:CDE]NBRDIE) & (CJ1 >= 0))
 DIMCEN_MAX+=1
 INS.DIMCEN(CJ1).DIE=[F:CDE]DIE(CI1)
 CJ1+=1
Next CI1
Local Integer IDENT_MAXI:IDENT_MAXI= 0
Local Integer IDENT_MAX:IDENT_MAX=0
If dim([F:CDE]FLD)>0
    If IDENT_MAXI = 0
        IDENT_MAXI = dim([F:CDE]FLD)
    Else
        IDENT_MAXI = min(IDENT_MAXI,dim([F:CDE]FLD))
    Endif
Endif
CJ1=1
For CI1 = 0 To IDENT_MAXI-1
 Break ([F:CDE]FLD(CI1)="")
 IDENT_MAX+=1
 INS.IDENT(CJ1).FLD=[F:CDE]FLD(CI1)
 CJ1+=1
Next CI1
[L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")
Gosub ASEARCH_TO_JSON
Return

#---------------------------------------------------------------------------------------------------#
# Serialize the entity in a JSON format
#---------------------------------------------------------------------------------------------------#
$ASEARCH_TO_JSON
If FINS=0 : Return : Endif
QCOUNT += 1
Onerrgo ERROR_VALUE
Append ASND.DATA ,SEPINS1
SEPINS1 = ','+chr$(10)
Append ASND.DATA ,'{'
Append ASND.DATA ,'"COD":'             +'"'+escJson(INS.COD)+'"'
Append ASND.DATA ,',"CPY":'            +'"'+escJson(INS.CPY)+'"'
Append ASND.DATA ,',"DES":'            +'"'+escJson(INS.DES)+'"'
Append ASND.DATA ,',"DESSHO":'         +'"'+escJson(INS.DESSHO)+'"'
Append ASND.DATA ,',"DESTRA":'         
Append ASND.DATA ,'"'
Append ASND.DATA ,escJson(func ASYRSUB.AGETTEXTRA(INS.AXX,"DESTRA",GACTX.LAN))
Append ASND.DATA ,'"'
Append ASND.DATA ,',"SHOTRA":'         
Append ASND.DATA ,'"'
Append ASND.DATA ,escJson(func ASYRSUB.AGETTEXTRA(INS.AXX,"SHOTRA",GACTX.LAN))
Append ASND.DATA ,'"'
Append ASND.DATA ,',"CREUSR":'         +'"'+escJson(INS.CREUSR)+'"'
Append ASND.DATA ,',"UPDUSR":'         +'"'+escJson(INS.UPDUSR)+'"'
IS1=""
CJ1=1
Append ASND.DATA ,',"DIMCEN":['
For CI1=1 To DIMCEN_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"DIE":'             +'"'+escJson(INS.DIMCEN(CJ1).DIE)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
IS1=""
CJ1=1
Append ASND.DATA ,',"IDENT":['
For CI1=1 To IDENT_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"FLD":'             +'"'+escJson(INS.IDENT(CJ1).FLD)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
Append ASND.DATA ,'}'
Onerrgo
FINS = 0
Return

#---------------------------------------------------------------------------------------------------#
# Errors
#---------------------------------------------------------------------------------------------------#
$ERROR_VALUE
SVALUE ='"<error'-errmes$(errn)+'>"'
Resume
#---------------------------------------------------------------------------------------------------#
# Link standard key
#---------------------------------------------------------------------------------------------------#
$AQUERY_PRIMARYKEYS
Local Char ASTDKEY(250)
ASTDKEY = ""
ASTDKEY += "[F:CDE]COD"
ASTDKEY += ";[F:CDE]CPY"
ACTION = "ASEARCH_PRIMARYKEYS_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Actions
#---------------------------------------------------------------------------------------------------#
$ASEARCH_ACTION
Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)
[L]AEVENT = [L]ACTION
 Gosub METHODS From CACCEDEF_CSTD
 Gosub METHODS From CACCEDEF_CSTD
Gosub METHODS From CACCEDEF_CSTD
Return

#---------------------------------------------------------------------------------------------------#
# APPEND_PROTOTYPE
#---------------------------------------------------------------------------------------------------#
Funprog APPEND_PROTOTYPE(ACTX,WCLOB,PSYR)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Clbfile   WCLOB
Variable Instance  PSYR     Using C_ASYR
Local Integer ERROR : ERROR = 0
Local Integer IND   : IND = 0
Local Char TRTNAME(80)
Local Char REPRESENTATION(80)
Local File ASHW    [ASW]
Filter [ASW] Where CODCLA="CACCEDEF" & DEFREP=2
Read [ASW]ASW0 First
If !fstat
 If  [ASW]ENAFAC(0) = 2
  REPRESENTATION = [ASW]CODREP
 Else
  WCLOB ="{}"
  End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"CACCEDEF")) 
 Endif
Endif
Close Local File [ASW]
If len(REPRESENTATION)=0
 WCLOB ="{}"
 End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"CACCEDEF")) 
Endif
Append WCLOB,'{'
Append WCLOB,'"$baseUrl":"'+PSYR.PREFIX+'"'
Append WCLOB,',"$baseType":"'+PSYR.CNTPRE+"."+nomap+'"'
Append WCLOB,',"$classTitle":"'+func GET_RES_STRING(ACTX.LAN,19399)+'"'
Append WCLOB,',"$url":"{$baseUrl}/CACCEDEF'+PSYR.URLREP+''+REPRESENTATION+'.$search"'
Append WCLOB,',"$prototype":"{$baseUrl}/$prototypes('+"'"+'{$representation}.$thumb'+"'"+')"'
Append WCLOB,',"$type":"{$baseType}.'+REPRESENTATION+'.$search"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"$resources":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$item":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,19399)+' {$key}"'
Append WCLOB,',"$key":"{COD}~{CPY}"'
Append WCLOB,',"$url":"{$baseUrl}/CACCEDEF('+"'"+'{$key}'+"'"+')'+PSYR.URLREP+'CACCEDEF.searchItem"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"COD":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,5296)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":10'
Append WCLOB,"}"
Append WCLOB,',"CPY":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,1343)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":5'
Append WCLOB,"}"
Append WCLOB,',"DES":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,8)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":30'
Append WCLOB,"}"
Append WCLOB,',"DESSHO":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,4010)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":10'
Append WCLOB,"}"
Append WCLOB,',"DESTRA":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,8)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":30'
Append WCLOB,"}"
Append WCLOB,',"SHOTRA":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,4010)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":12'
Append WCLOB,"}"
Append WCLOB,',"CREUSR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,250)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":5'
Append WCLOB,"}"
Append WCLOB,',"UPDUSR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,250)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":5'
Append WCLOB,"}"
Append WCLOB,',"DIMCEN":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$minItems":0'
Append WCLOB,',"$maxItems":20'
Append WCLOB,',"$item":{'
Append WCLOB,'"$type":"application/json"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"DIE":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,29606)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":3'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,',"IDENT":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$minItems":1'
Append WCLOB,',"$maxItems":25'
Append WCLOB,',"$item":{'
Append WCLOB,'"$type":"application/json"'
Append WCLOB,',"$properties":{'
