Append WCLOB,',"$default":true'
Append WCLOB,',"$url":"{$baseUrl}/CACCEDEF('+"'"+'{$key}'+"'"+')?representation=CACCEDEF.$details"'
Append WCLOB,',"$devices":"desktop"'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
End ERROR
