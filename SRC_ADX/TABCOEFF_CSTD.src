#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################
# CLASS TABCOEFF


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#  When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "UOM1"     : Gosub UOM1
  When "UOM2"     : Gosub UOM2
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return





##############################################################################################
$UOM1
Case [L]ARULE
  When "CONTROL"      : Gosub UOM1_CONTROL
Endcase
Return

$UOM1_CONTROL
Gosub UOM_CONTROL
Return


##############################################################################################
$UOM2
Case [L]ARULE
    When "CONTROL"   : Gosub UOM2_CONTROL
    When "PROPAGATE" : Gosub UOM2_PROPAGATE
Endcase
Return

$UOM2_CONTROL
Gosub UOM_CONTROL
Return


##############################################################################################
$UOM_CONTROL
If this.UOM1 <> AVOID.ACHAR and this.UOM2<>AVOID.ACHAR
  If this.UOM1=this.UOM2
    # Invalid value
    [L]ASTATUS = fmet this.ASETERROR("UOM2",mess(83,123,1),[V]CST_AERROR)
  Endif
Endif
Return

##############################################################################################
$UOM2_PROPAGATE
Local Instance UOM1, UOM2 Using C_TABUNIT
UOM1 = NewInstance C_TABUNIT AllocGroup null
UOM2 = NewInstance C_TABUNIT AllocGroup null
[L]ASTATUS = fmet UOM1.AREAD(this.UOM1)
If [L]ASTATUS = [V]CST_AOK
  [L]ASTATUS = fmet UOM2.AREAD(this.UOM2)
  If [L]ASTATUS = [V]CST_AOK
    # Concatenate 2 labels from UOM1 and UOM2
    this.COEAX2 = fmet UOM1.AGETTEXTRA("DES")-"-"-fmet UOM2.AGETTEXTRA("DES")
    this.COEAX1 = fmet UOM1.AGETTEXTRA("DESSHO")-"-"-fmet UOM2.AGETTEXTRA("DESSHO")
  Else
    [L]ASTATUS = fmet this.ASETERROR(CURPRO,mess(6,123,1)-this.UOM2,[V]CST_AERROR)
  Endif
Else
  [L]ASTATUS = fmet this.ASETERROR(CURPRO,mess(6,123,1)-this.UOM1,[V]CST_AERROR)
Endif
If [L]ASTATUS = [V]CST_AOK
  # Concatenate 2 labels from UOM1 and UOM2
  this.COEAX2 = fmet UOM1.AGETTEXTRA("DES")-"-"-fmet UOM2.AGETTEXTRA("DES")
  this.COEAX1 = fmet UOM1.AGETTEXTRA("DESSHO")-"-"-fmet UOM2.AGETTEXTRA("DESSHO")
Else
  [L]ASTATUS = fmet this.ASETERROR(CURPRO,mess(6,123,1)-this.UOM1,[V]CST_AERROR)
Endif
FreeGroup UOM1
FreeGroup UOM2

Return

