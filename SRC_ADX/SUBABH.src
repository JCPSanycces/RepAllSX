#<AdxTL>@(#)2.0.0.0 $Revision$  Gestion objet ABH
$ACTION
Case ACTION
 When default
Endcase
Return

#############################################
Subprog C_STROPE(VALEUR)
Variable Char VALEUR
If nolign>1 & [M]ENDOPE(nolign-2)>=VALEUR
 Gosub ERRTIM
Endif
If nolign<dim([M]STROPE) & [M]STROPE(nolign)<>""  & [M]STROPE(nolign)<=VALEUR
 Gosub ERRTIM
Endif
End

Subprog C_ENDOPE(VALEUR)
Variable Char VALEUR
If nolign<dim([M]STROPE) & [M]STROPE(nolign)<>""  & [M]STROPE(nolign)<=VALEUR
 Gosub ERRTIM
Endif
End

Subprog C_STRCLO(VALEUR)
Variable Char VALEUR
If nolign>1 & [M]ENDCLO(nolign-2)>=VALEUR
 Gosub ERRTIM
Endif
If nolign<dim([M]STRCLO) & [M]STRCLO(nolign)<>""  & [M]STRCLO(nolign)<=VALEUR
 Gosub ERRTIM
Endif
End

Subprog C_ENDCLO(VALEUR)
Variable Char VALEUR
If nolign<dim([M]STRCLO) & [M]STRCLO(nolign)<>""  & [M]STRCLO(nolign)<=VALEUR
 Gosub ERRTIM
Endif
End

$ERRTIM
GMESSAGE = mess(110,133,1) : # Les heures doivent être dans l'ordre croissant
mkstat   = 1
Return


