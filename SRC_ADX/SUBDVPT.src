#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "SETBOUT"  : Gosub SETBOUT
Endcase

Return
######################################################################################
######################################################################################
$OUVRE

If !clalev ([F:CPY])  : Local File COMPANY    [CPY]  : Endif

Return
######################################################################################
######################################################################################
$SETBOUT

If GREP = "" & [F:DVPT]DCLTYP<>0
  CHAINE +="A"
Endif

Return
######################################################################################
######################################################################################
Subprog AS_DCLTYP(VALEUR)
Variable Integer VALEUR

GMENLOC(1) = 0
GMENLOC(2) = 0
GMENLOC(3) = 1
GMENLOC(4) = 1

End
######################################################################################
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

If func AFNC.PARAM("PORVAT",VALEUR)<>"2" & VALEUR <> ""
  mkstat = 2
  GMESSAGE = func AFNC.MES2(mess(00218,00125,1), "PORVAT", mess(00001,00001,1))
Endif

End
######################################################################################
######################################################################################
Subprog AV_NBLIG

If !([M:DVPT1]DCLFLD = "104" & [M:DVPT1]DCLTYP = 1 & [M:DVPT1]DCLPAG = 1) &
&  !([M:DVPT1]DCLFLD = "072"  & [M:DVPT1]DCLTYP = 1 & find([M:DVPT1]DCLPAG,2, 3))
  Chgfmt [M:DVPT1]GOODAQU With "-N:1"
  Chgfmt [M:DVPT1]SERVAQU With "-N:1"
Else
  Chgfmt [M:DVPT1]GOODAQU With "+N:1"
  Chgfmt [M:DVPT1]SERVAQU With "+N:1"
Endif

If !(([M:DVPT1]DCLFLD = "012" | [M:DVPT1]DCLFLD = "008") & [M:DVPT1]DCLTYP = 1)
  Chgfmt [M:DVPT1]TRIOPE With "-N:1"
Else
  Chgfmt [M:DVPT1]TRIOPE With "+N:1"
Endif

End
######################################################################################
######################################################################################
Subprog C_VAT(VALEUR)
Variable Char    VALEUR()

Gosub READ_CPY

Call CONTTVT(VALEUR,[F:CPY]LEG,"","","","",[F:CPY]CPY) From SUBTVT

End
######################################################################################
######################################################################################
######################################################################################
## Section automatically added (screen DVPT1) 14-06-2013 13:06:09 (RMA)
######################################################################################
Subprog S_VAT(VALEUR)
Variable Char    VALEUR()

Gosub READ_CPY

If !GWEBSERV
 ## Action SELTVTLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELTVTLEG"
 PARMSK(1) = [F:CPY]LEG
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = [F:CPY]CPY
 PARMSK(5) = ""
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELTVT","SUBTVT","") From GACTION
 GACTION = SAVACT
Endif

End
######################################################################################
######################################################################################
$READ_CPY

If [F:CPY]CPY <> [M:DVPT1]CPY
  Read [F:CPY]CPY0 = [M:DVPT1]CPY
  If fstat : Raz [F:CPY] : Endif
Endif

Return
######################################################################################
######################################################################################

