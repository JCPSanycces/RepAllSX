# Class AQCSFTPORT

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#  When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "KEY1"
    Case [L]ARULE
      When "PROPAGATE"  : If this.KEY1<>"" : Gosub REFRESH_ACTIVITIES : Endif
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return




$REFRESH_ACTIVITIES
Local Integer LINENUM
# remove old lines
 For LINENUM = 1 To maxtab(this.COLAQC)
   If ((this.COLAQC(LINENUM).ASTALIN <> CST_ADEL) & (this.COLAQC(LINENUM).ASTALIN <> CST_ANEWDEL))
     [L]ASTATUS = fmet this.ADELLINE("COLAQC", LINENUM)
     If [L]ASTATUS = [V]CST_ANOTDEFINED
        [L]ASTATUS = fmet this.ASETERROR ("", "Unable to delete the row.", [V]CST_AERROR)
        Return
     Endif
   Endif
 Next

# add new lines
  Local File AQCSFTPORT [AQCS1]
  Filter [AQCS1] Where KEY1=this.KEY1 Order By LINE;SEQ
  For [AQCS1]
      [L]LINENUM = fmet this.ADDLINE("COLAQC",[V]CST_ALASTPOS)
      this.COLAQC(LINENUM).LINE       = [F:AQCS1]LINE
      this.COLAQC(LINENUM).SEQ       = [F:AQCS1]SEQ
      this.COLAQC(LINENUM).TEXT       = [F:AQCS1]TEXT
  Next

  LogicClose File [AQCS1]
Return

