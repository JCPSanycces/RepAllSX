#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################
## Etat FICHEBUL
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    SOCIETE(GLONCPY) , SITEDEB(GLONFCY), SITEFIN(GLONFCY) , MATDEB(GLONEML) , MATFIN(GLONEML)
Local Date    DATEDEB , DATEFIN
Local Char    PARAM(20) , PROFIL(GLONPRF) , SERVICE(GLONSRV) , POPULATION(GLONPOP)
Local Char    CRITERE1(250) , CRITERE2(250)
Local Integer TYPMONT
Local Integer I , J , K , NBMOIS , GRP , NUMREQ , OK
Local Decimal MONT(1..120)

If clalev([F:HSP])=0    : Local File HISTOPAYE [HSP]  : Endif
If clalev([F:VEP])=0    : Local File VALEMP    [VEP]  : Endif
If clalev([F:ID])=0     : Local File EMPLOID   [ID]   : Endif
If clalev([F:HRPOA])=0    : Local File POPULA    [HRPOA]  : Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]  : Endif
If clalev([F:RUB])=0    : Local File RUBRIQUE  [RUB]  : Endif
If clalev([F:TMP])=0    : Local File TMPHISTO  [TMP]  : Endif
If clalev([F:ACC])=0    : Local File ACCES     [ACC]  : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]: Endif

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE)
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB)
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN)
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM) : DATEDEB = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM) : DATEFIN = PARAM
Call GETPARAM("profil",NBPAR,PARAMETRE,PROFIL)
Call GETPARAM("service",NBPAR,PARAMETRE,SERVICE)
Call GETPARAM("typmont",NBPAR,PARAMETRE,PARAM) : TYPMONT = val(PARAM)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Case TYPMONT
 When 1 : CRITERE1 = "([F:HSP]TYP=1 | [F:HSP]TYP=7)"
 When 2 : CRITERE1 = "([F:HSP]TYP=2 | [F:HSP]TYP=8)"
 When 3 : CRITERE1 = "([F:HSP]TYP=1 | [F:HSP]TYP=2 | [F:HSP]TYP=7 | [F:HSP]TYP=8)"
Endcase
If DATEDEB<>[0/0/0]
 CRITERE1 -= "& [F:HSP]DAT>=["+format$(GFMD,DATEDEB)+"]"
Endif
If DATEFIN<>[0/0/0]
 CRITERE1 -= "& [F:HSP]DAT<=["+format$(GFMD,DATEFIN)+"]"
Endif
If MATDEB<>""
 CRITERE1 -= '& [F:HSP]EMP>="'+MATDEB+'"'
Endif
If MATFIN<>""
 CRITERE1 -= '& [F:HSP]EMP<="'+MATFIN+'"'
Endif

CRITERE2 = '[F:FGR]CPY="'+SOCIETE+'"'
CRITERE2 -= "& [F:RUB]AMTPRN<>1"

If SITEDEB<>""
 CRITERE2 -= '& [F:VEP]FCY>="'+SITEDEB+'"'
Endif
If SITEFIN<>""
 CRITERE2 -= '& [F:VEP]FCY<="'+SITEFIN+'"'
Endif
If PROFIL<>""
 CRITERE2 -= '& [F:VEP]PRF="'+PROFIL+'"'
Endif
If SERVICE<>""
 CRITERE2 -= '& [F:VEP]SRV="'+SERVICE+'"'
Endif

If POPULATION<>""
 Link [HSP] With [RUB]RUB0=[F:HSP]RUB , [VEP]VEP5=[F:HSP]BUL
& , [FGR]FGR0=SOCIETE;[F:VEP]FCY
& , [HRPOA]POA0=POPULATION;[F:HSP]EMP
& As [LHSP]
& Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
& Order By Key CLE=[F:HSP]EMP;[F:HSP]CTRNUM;[F:HSP]RUB
Else
 Link [HSP] With [RUB]RUB0=[F:HSP]RUB , [VEP]VEP5=[F:HSP]BUL
& , [FGR]FGR0=SOCIETE;[F:VEP]FCY
& As [LHSP]
& Where evalue(CRITERE1) & evalue(CRITERE2)
& Order By Key CLE=[F:HSP]EMP;[F:HSP]CTRNUM;[F:HSP]RUB
Endif

NBMOIS = 12*year(DATEFIN)+month(DATEFIN)-(12*year(DATEDEB)+month(DATEDEB))+1
Call DEBTRANS From GLOCK
Gosub TR1
Call TEMPOFF From GESECRAN
End

$TR1
GOK = 1
Trbegin [TMP]
 Delete [TMP] Where USR=GUSER & DAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "TMPHISTO"-GUSER : Goto ROLL_TR1
 Endif
 K = 0
 For [LHSP]CLE(2)
  Read [ID]ID0=[F:HSP]EMP
  If !fstat
   Filter [HRCTR] Where REFNUM=[F:HSP]EMP & CTRNUM=[F:HSP]CTRNUM
   Read [HRCTR]CTR0 Last
   Filter [HRCTR]
   If !fstat
    Call CONTROLE([F:HSP]EMP,[F:HSP]DAT,[F:HSP]CTRNUM,"",OK,0) From DIVPAYE
   Else
    OK = 0
   Endif
  Else OK = 0
  Endif
  If OK
   For [LHSP]CLE(3)
    Raz MONT
    For [LHSP]CLE
     MOIS = 12*year([F:VEP]PYRMON)+month([F:VEP]PYRMON)-(12*year(DATEDEB)+month(DATEDEB))+1
     If MOIS>dim(MONT)
      # La période ne doit pas dépasser N mois
      Call ERREUR(mess(40,10708,1)-num$(dim(MONT))-mess(41,10708,1)) From GESECRAN
      GOK = 0
      Break 3
     Endif
     MONT(MOIS) += [F:HSP]AMT
    Next
    Raz [F:TMP]
    [F:TMP]USR    = GUSER
    [F:TMP]RQT    = [L]NUMREQ
    [F:TMP]EMP    = [F:HSP]EMP
    [F:TMP]CTRNUM = [F:HSP]CTRNUM
    [F:TMP]RUB    = [F:HSP]RUB
    [F:TMP]ROW    = [F:RUB]ROW
    [F:TMP]DAT    = date$
    For GRP=1 To int((NBMOIS-1)/6)+1
     [F:TMP]GRP   = GRP
     If sum(MONT(1..6*GRP))<>0
      For I=1 To 6
       ###DBA le 03/09/04 : Bug 24504
       [F:TMP]AMT(I-1)=0
       ###
       J = 6*(GRP-1)+I
       If J<=NBMOIS
        [F:TMP]AMT(I-1) = MONT(J)
       Endif
      Next I
      K += 1
      [F:TMP]MOI = addmonth(DATEDEB,6*(GRP-1))
      [F:TMP]LIG = K
      [F:TMP]TOT = sum(MONT(1..6*GRP))
      Write [TMP]
      If fstat
       GOK = 0 : Call FSTA("TMP") From GLOCK : Break 3
      Endif
     Endif
    Next GRP
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return


Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

