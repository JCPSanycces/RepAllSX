#<AdxTL>@(#)0.0.0.0 $Revision$Class Actions
# Supervisor
## ATY-ATYPE ## PLANACT
# 2018-11-09 07:14:54 426

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,ACTIONID,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char ACTIONID
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File PLANACT [PLAACT]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".PLANACT" [PLAACT]
Endif

Default File [F:PLAACT]
Read [F:PLAACT]PLAACT0 = [L]ACTIONID
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]ACTIONID)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]ACTIONID)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


