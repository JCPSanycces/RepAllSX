#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
## Object actions
######################################################################################
######################################################################################
$OUVRE

# Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
# Issue X3-3575
If clalev([M:ADR1])  = 0 : Local Mask SAIADR    [ADR1]   : Endif
If clalev([F:BPA2])  = 0 : Local File BPADDRESS [BPA2]   : Endif
# End issue X3-3575
# Issue 24522 - 2017-03-14 by MRDAB : GESTPM modification to include transport notes and move AP/AR to a new block
If clalev([F:BPS])   = 0 : Local File BPSUPPLIER [F:BPS] : Endif
If clalev([F:BPC])   = 0 : Local File BPCUSTOMER [F:BPC] : Endif
# End issue 24522
If clalev([M:ADB2])  = 0 : Local Mask ADRBPC    [ADB2]  : Endif
If clalev([F:BPA])   = 0 : Local File BPADDRESS [BPA]   : Endif
If clalev([F:FCY])   = 0 : Local File FACILITY  [FCY]   : Endif
If clalev([F:ITM])   = 0 : Local File ITMMASTER [ITM]   : Endif
If clalev([F:TND])   = 0 : Local File TRANNOTED [TND]   : Endif
If clalev([F:TTN])   = 0 : Local File TABTNHTYP [TTN]   : Endif
If clalev([F:BPD])   = 0 : Local File BPDLVCUST [BPD]   : Endif

If func AFNC.ACTIV("DKS")
  If clalev([F:DKS])   = 0 : Local File DKSDATA [DKS]   : Endif
  If clalev([F:PTDKD]) = 0 : Local File DKSDATA [PTDKD] : Endif
Endif

Gosub DECLARE From TABLEAUX

Local Integer STAT, NOL
Local Char    LNUM(GLONVCR)

Return
######################################################################################
######################################################################################
$FILTRE

Default File [TNH]

Return
######################################################################################
######################################################################################
$LIENS

# Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
# Issue X3-3575
Raz [M:ADR1]
# End issue X3-3575
Raz [M:ADB2]
Gosub LIENS From TABLEAUX

# BRBAN * 01/04/2015 * #107394
Diszo [M:TNH0]5
Actzo [M:TNH0]TNHNUM
Actzo [M:TNH0]TRNDAT
#-

GFCY = [M:TNH0]FCY
# Issue X3-65679 - 2018-01-17 By VAVIL : Transportation note and modification after validate
# Issue X3-65679
# If func PORLEGLIB.DIGSIGN([M:TNH0]FCY, "")
  If [F:TNH]CFMFLG = 2
    Diszo [M:TNH0]TRNDAT
    Diszo [M:TNH0]1-99
    Actzo [M:TNH0]TNHNUM
    Diszo [M:TNH1]1-99
    If func AFNC.ACTIV("DKS")
      Read [F:DKS]DKD0 = "SAFT-PT";[F:TNH]TNHTYP;[F:TNH]TNHNUM
      If !fstat & [F:DKS]ATDTCOD <> ""
        Diszo [M:TNH2]1-99
      Endif
    Endif
  Else
    Actzo [M:TNH1]1-99
  Endif
#Endif
#---------------------------#
# Alimentation des adresses #
#---------------------------#
# Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
# Issue X3-3575
[M:ADR1]BPANUM         = [F:TNH]FCY
[M:ADR1]BPAADD         = [F:TNH]SHIFRMADD
[M:ADR1]NAM(0)         = [F:TNH]SHIFRMNAM(0)
[M:ADR1]NAM(1)         = [F:TNH]SHIFRMNAM(1)
[M:ADR1]BPAADDLIG(0)   = [F:TNH]SHIFRMADDLIG(0)
[M:ADR1]BPAADDLIG(1)   = [F:TNH]SHIFRMADDLIG(1)
[M:ADR1]BPAADDLIG(2)   = [F:TNH]SHIFRMADDLIG(2)
[M:ADR1]POSCOD         = [F:TNH]SHIFRMPOSCOD
[M:ADR1]CTY            = [F:TNH]SHIFRMCTY
[M:ADR1]SAT            = [F:TNH]SHIFRMSAT
[M:ADR1]CRY            = [F:TNH]SHIFRMCRY
[M:ADR1]CRYNAM         = [F:TNH]SHIFRMCRYNAM

If [M:ADR1]NAM <> "" | [M:ADR1]BPAADDLIG <> "" |
&  [M:ADR1]POSCOD <> "" | [M:ADR1]CTY <> "" |
&  [M:ADR1]SAT    <> "" |
&  [M:ADR1]CRY    <> "" | [M:ADR1]CRYNAM <> ""
   [M:ADR1]ADBFLG = 3
Else
   [M:ADR1]ADBFLG = 0
Endif
# End issue X3-3575

[M:ADB2]ADBBPR       = [F:TNH]BPRNUM
[M:ADB2]BPAADD       = [F:TNH]BPAADD
[M:ADB2]BPRNAM(0)    = [F:TNH]BPDNAM(0)
[M:ADB2]BPRNAM(1)    = [F:TNH]BPDNAM(1)
[M:ADB2]BPAADDLIG(0) = [F:TNH]BPDADDLIG(0)
[M:ADB2]BPAADDLIG(1) = [F:TNH]BPDADDLIG(1)
[M:ADB2]BPAADDLIG(2) = [F:TNH]BPDADDLIG(2)
[M:ADB2]POSCOD       = [F:TNH]BPDPOSCOD
[M:ADB2]CTY          = [F:TNH]BPDCTY
[M:ADB2]SAT          = [F:TNH]BPDSAT
[M:ADB2]CRY          = [F:TNH]BPDCRY
[M:ADB2]CRYNAM       = [F:TNH]BPDCRYNAM
[M:ADB2]CNTNAM       = [F:TNH]CNDNAM

If [M:ADB2]BPRNAM <> "" | [M:ADB2]BPAADDLIG <> "" |
&  [M:ADB2]POSCOD <> "" | [M:ADB2]CTY <> "" |
&  [M:ADB2]SAT    <> "" |
&  [M:ADB2]CRY    <> "" | [M:ADB2]CRYNAM <> ""
    [M:ADB2]ADBFLG = 3
Else
    [M:ADB2]ADBFLG = 0
Endif

If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN([M:TNH0]FCY, "")=1
    Actzo [M:TNH2]ARVDAT,DPEDAT,ETD,ETA,LICPLATE,TRLLICPLATE
    Actzo [M:TNH2]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,MANDOC,GLBDOC
    Diszo [M:TNH2]ATDTCOD
    If func PORLEGLIB.DOCCTR(10,[F:TNH]BPRNUM ,[F:TNH]TNHTYP,[F:TNH]FCY)=1
      If [F:TNH]CFMFLG<>2
        Actzo [M:TNH2]ATDTCOD
      Else
        Read [F:PTDKD]DKD0 = "SAFT-PT";[F:TNH]TNHTYP;[F:TNH]TNHNUM
        If !fstat & [F:PTDKD]ATDTCOD<>''
          Diszo [M:TNH2]ARVDAT,DPEDAT,ETD,ETA,LICPLATE,TRLLICPLATE
          Diszo [M:TNH2]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,ATDTCOD,MANDOC,GLBDOC
          [M:TNH2]ATDTCOD= [F:PTDKD]ATDTCOD
          Affzo [M:TNH2]ATDTCOD
        Endif
      Endif
    Endif
    Call DIS_MANDOC(GFONCTION) From TRNDOC
    If [M:TNH2]GLBDOC = 2
      Diszo [M:TNH2]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP
    Endif
  Else
    Diszo [M:TNH2]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,MANDOC,ATDTCOD,GLBDOC
  Endif

  # Issue 24522 - 2017-03-14 by MRDAB : GESTPM modification to include transport notes and move AP/AR to a new block
  If [M:TNH0]BPCBPS =  1
    Read [F:BPC]BPC0 = [M:TNH0]BPRNUM
  Else
    Read [F:BPS]BPS0 = [M:TNH0]BPRNUM
  Endif
  If !fstat
    Call ALI_PRTMOD("TNH0",11) From TRTX3
    If [M:TNH0]COPNBR=0 [M:TNH0]COPNBR=1 Endif
  Endif
  # End issue 24522
Endif

Return
######################################################################################
######################################################################################
$CREATION

Gosub CREATION From TABLEAUX
If GOK < 1  Return  Endif

Return
######################################################################################
######################################################################################
$MODIF

Gosub MODIF From TABLEAUX
If GOK < 1  Return  Endif

Return
######################################################################################
######################################################################################
$ANNULE

Gosub ANNULE From TABLEAUX

If left$([F:TNH]TNHTEX1,3)="TNH"
   Call SUP_CLOB([F:TNH]TNHTEX1,STAT) From TRTX3TEX
Endif
If left$([F:TNH]TNHTEX2,3)="TNH"
   Call SUP_CLOB([F:TNH]TNHTEX2,STAT) From TRTX3TEX
Endif

Return
######################################################################################
######################################################################################
$APRES_CRE

Gosub LIENS From TABLEAUX

Return
######################################################################################
######################################################################################
$APRES_MOD

Gosub LIENS From TABLEAUX

Return
######################################################################################
######################################################################################
$INICRE_LIG

[F:TND]TNHNUM = [M:TNH0]TNHNUM

Return
######################################################################################
######################################################################################
$DEFLIG

Default Mask [TNH1]
Default File [TND]

#Filtering expression to read all detail lines related to one header
CRIT     = '[F:TND]TNHNUM="'+[M:TNH0]TNHNUM+'"'
FICLIG   = 'TRANNOTED'   #The name of the detail Table
ABLIG    = 'TND'         #Its abbreviation
ZONLIG   = 'TNDLIN'      #The line counter field

Return
######################################################################################
######################################################################################
$SETBOUT

If GREP="C" | GREP="D" | CLECUR
    # Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
    # Issue X3-3575
    CHMEN += "HJK2"
    # End issue X3-3575
Endif


If GREP<>"" | !CLECUR
  Call VIREBOUT(CHAINE,"A") From GOBJET
Endif

If [M:TNH1]CFMFLG = 2
  Call VIREBOUT(CHAINE,"1A") From GOBJET
Endif

If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:TNH0]FCY,'')=1
  If [M:TNH1]CFMFLG = 2 & GREP = "" & [M:TNH0]TNHNUM <> "" & func PORLEGLIB.DOCCTR(10,[F:BPR]BPRNUM,[F:TNH]TNHTYP,[F:TNH]FCY)=1
    Read [F:PTDKD]DKD0 = "SAFT-PT";[M:TNH0]TNHTYP;[M:TNH0]TNHNUM
    # BRBAN 24-03-2015 #106027
    If !fstat & [F:PTDKD]ATDTCOD = "" & func PORLEGLIB1.CTRL_COMDAT([F:TNH]FCY,[F:TNH]DPEDAT,[F:TNH]ETD)=1
      CHMEN+='Q'
    Endif
  Endif
Endif

Return
######################################################################################
######################################################################################
$RAZCRE
# BRBAN * 27-03-2015 * #107320
GFCY=GFCYDEF(9)
[M:TNH0]FCY = GFCY

Local Char WTNHTYP(GLONTPN)
Gosub TNHTYP From TRTTNH1
If WTNHTYP<>"" : [M:TNH0]TNHTYP=WTNHTYP : Affzo [M:TNH0]TNHTYP : Endif

[M:TNH1]CFMFLG = 1
[M:TNH0]TRNDAT = date$
Raz [M:TNH0]TNHTEX1, [M:TNH0]TNHTEX2

Gosub COMMON_ACTZO From SUBTNHB

Return
######################################################################################
######################################################################################
$RAZDUP

#If activated, implement abandon action
#If left$([M:TNH0]TNHTEX1,3)="TNH"
#   Call DUP_CLOB("TNH",[M:TNH0]TNHTEX1,STAT) From TRTX3TEX
#   If STAT<1 Raz [M:SDH0]TNHTEX1 Endif
#Endif
#If left$([M:TNH0]TNHTEX2,3)="TNH"
#   Call DUP_CLOB("TNH",[M:TNH0]TNHTEX2,STAT) From TRTX3TEX
#   If STAT<1 Raz [M:TNH0]TNHTEX2 Endif
#Endif
#
#For NOL=0 To [M]NBLIG-1
#   Raz [M:TNH1]UPDFLG(NOL), [M:TNH1]CREFLG(NOL)
#
#   If left$([M:TNH1]TNDTEX(NOL),3)="TND"
#       Call DUP_CLOB("TND",[M:TNH1]TNDTEX(NOL),STAT) From TRTX3TEX
#       If STAT<1 Raz [M:TNH1]SDDTEX(NOL) Endif
#   Endif
#Next
[M:TNH1]CFMFLG = 1
Gosub COMMON_ACTZO From SUBTNHB

If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN([F:TNH]FCY, '')=1
    Raz [M:TNH2]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,MANDOC,ATDTCOD
    Actzo [M:TNH2]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,MANDOC,ATDTCOD
    Call DIS_MANDOC(GFONCTION) From TRNDOC
  Endif
Endif
#-


Return
######################################################################################
######################################################################################
$INICRE

If [F:FCY]FCY <> [M:TNH0]FCY
Read [F:FCY]FCY0 = [M:TNH0]FCY
  If fstat : Raz [F:FCY] : Endif
Endif
[F:TNH]CPY = [F:FCY]LEGCPY

Call LEC_TTN_LEG([F:FCY]LEG,[M:TNH0]TNHTYP,STAT) From TRTLECLEG
GCPT = [F:TTN]CODNUM

Call NUMERO(GCPT,[M:TNH0]FCY,[M:TNH0]TRNDAT,"",LNUM,STAT) From SUBANM

If GOK<0 Return Endif

If GOK>0 & STAT=0
  [F:TNH]TNHNUM=LNUM
  [M:TNH0]TNHNUM=LNUM
  Affzo [M:TNH0]TNHNUM
Else
  Local Char MESSA(80)
  GMESSAGE=mess(60,199,1)-"("+GCPT+") : "
  Gosub MESSAGE From SUBANM
  GMESSAGE-=MESSA : GERR=1 : GOK=0 : Return
Endif

# Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
# Issue X3-3575
Gosub CHARGE_ADRSHIFR From SUBTNHB
# End issue X3-3575

Gosub CHARGE_ADRBPD From SUBTNHB

Gosub INITXC From SUBTNHB

Return
######################################################################################
######################################################################################
$INIMOD

# Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
# Issue X3-3575
Gosub CHARGE_ADRSHIFR From SUBTNHB
# End issue X3-3575

Gosub CHARGE_ADRBPD From SUBTNHB

Gosub INITXC From SUBTNHB

Return
######################################################################################
######################################################################################
$STATUT

Case BOUT
  When "H"
    If mkstat=4 & GREP=""                    : # Header text
      Gosub ENTRE_MODIF From GOBJSUB
    Endif
    If [M:TNH0]TNHTEX1 <> "" & !GIMPORT
      Call SET_IMAGE (4) From GESECRAN
    Elsif !GIMPORT
      Call RESET_IMAGE (4) From GESECRAN
    Endif
 When "J"
    If mkstat=4 & GREP=""            : # Footer text
      Gosub ENTRE_MODIF From GOBJSUB
    Endif
    If [M:TNH0]TNHTEX2 <> "" & !GIMPORT
      Call SET_IMAGE (4) From GESECRAN
    Elsif !GIMPORT
      Call RESET_IMAGE (4) From GESECRAN
    Endif
 When "2"
     # Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
     # Issue X3-3575
     If [M:ADR1]ADBFLG = 2
      If GREP <> "C" & GREP <> "M" & GREP <> "D"
        Gosub MAJADRESSE  From SUBTNHB
      Endif
      If [M:ADR1]NAM(0) <> ""
        [M:TNH0]BPDNAM = [M:ADR1]NAM(0)
        Affzo [M:TNH0]BPDNAM
      Endif
    Endif
    # End issue X3-3575
 When "K"
    If [M:ADB2]ADBFLG = 2 | [M]CNTNAM <> [M:ADB2]CNTNAM
      If GREP <> "C" & GREP <> "M" & GREP <> "D"
        Gosub MAJADRESSE  From SUBTNHB
      Endif
      If [M:ADB2]BPRNAM(0) <> ""
        [M:TNH0]BPDNAM = [M:ADB2]BPRNAM(0)
        Affzo [M:TNH0]BPDNAM
      Endif
    Endif
 When "Q"
   # BRBAN 25-07-2014 US2 - Update ATDTCOD
   Read [F:PTDKD]DKD0='SAFT-PT';[F:TNH]TNHTYP;[F:TNH]TNHNUM
   If !fstat & [F:PTDKD]ATDTCOD <> ''
    [M:TNH2]ATDTCOD = [F:PTDKD]ATDTCOD
    Affzo [M:TNH2]ATDTCOD
    Diszo [M:TNH2]
   Endif
Endcase

Return
######################################################################################
######################################################################################
$VALLIG

If TRTLIG = "A"
    If left$([F:TND]TNDTEX,3)="TND"
        Call SUP_CLOB([F:TND]TNDTEX,STAT) From TRTX3TEX
    Endif
Elsif TRTLIG="M" & SIGN=-1
    # Cas particulier où on modifie le texte en le supprimant
    If left$([F:TND]TNDTEX,3)="TND"
        Call SUP_CLOB([F:TND]TNDTEX,STAT) From TRTX3TEX
    Endif
Endif

Return
######################################################################################
######################################################################################
$EXEBOUT

Case BOUT
  When "1"
    CLECUR1 = [M:TNH0]TNHNUM : Gosub RELIT From GOBJSUB
Endcase
Return
######################################################################################
######################################################################################
$AVANTBOUT

Case BOUT
 When "1" : If [M:TNH0]TNHNUM = "" | [M:TNH0]FCY = ""
              OK = 0 : Return
            Endif
Endcase

Return
######################################################################################
######################################################################################
$VERIF_CRE
Gosub VERIF
Return
######################################################################################
######################################################################################
$VERIF_MOD
Gosub VERIF
Return
######################################################################################
######################################################################################
$VERIF
If [M:TNH1]NBLIG=0
  OK = 0
  GMESSAGE = mess(85,100,1)
Endif
If func AFNC.ACTIV("KPO")>0
  If func PORLEGLIB.CTLDOCTYP([M:TNH0]TNHTYP,"TNH",GMESSAGE) = 1
    OK = 0 : GERR = 1 : Return
  Endif
Endif
Return
######################################################################################
######################################################################################

