#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION

  Case ACTION
    When "INIT"    : Gosub INIT
    When "DEBUT"   : Gosub DEBUT
    When "TERMINE" : Gosub TERMINE
    When Default
  Endcase
Return

$INIT
Global Char PHYREFERR

  PHYREFERR=PARAM(1)
Return

$DEBUT
Local Integer I_ERR

  Raz nolign
  For I_ERR=1 To NBR_ERREUR 
    nolign+=1
    [M:PHYE]ZON(nolign-1)=TAB_ZONERR(I_ERR-1)
    [M:PHYE]ERR(nolign-1)=TAB_ERREUR(I_ERR-1)
  Next I_ERR
  [M:PHYE]NBERR=nolign
  Affzo [M:PHYE]
Return

$TERMINE
  Kill PHYREFERR
Return



