# Supervisor
## ACLA-CLASSE ## EMPLOCTRUKI
# 2018-11-06 07:05:28 902

####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 61 : OLDPAYDAT Old payroll ID date ( Field D)
####################################################################

$SET_OLDPAYDAT
If [L]_AOLDVAL<>this.OLDPAYDAT
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_OLDPAYDAT
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.OLDPAYDAT
 Gosub PROPAGATE_OLDPAYDAT
Endif
Return

$INIT_OLDPAYDAT
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "OLDPAYDAT"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_OLDPAYDAT
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "OLDPAYDAT"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_OLDPAYDAT             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_OLDPAYDAT             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_OLDPAYDAT
[L]CURPRO = "OLDPAYDAT"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.OLDPAYDAT=[0/0/0]
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_OLDPAYDAT
[L]CURPRO = "OLDPAYDAT"
Return

$_AOTHERS_OLDPAYDAT
[L]CURPRO = "OLDPAYDAT"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_OLDPAYDAT
[L]CURPRO = "OLDPAYDAT"
Return

$PROPAGATE_OLDPAYDAT
this.isReadonly = 0
[L]CURPRO = "OLDPAYDAT"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_OLDPAYDAT
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "OLDPAYDAT"
$_LNKPRO_OLDPAYDAT
Return


####################################################################
# 62 : IRRFLG Irregular flag ( Field Local menu number 1)
####################################################################

$SET_IRRFLG
If [L]_AOLDVAL<>this.IRRFLG
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_IRRFLG
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.IRRFLG
 Gosub PROPAGATE_IRRFLG
Endif
Return

$INIT_IRRFLG
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "IRRFLG"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.IRRFLG=0 and fmet this.AGETATTRIBUTE("IRRFLG","$isMandatory")="true"
 this.IRRFLG = 1
Endif
Return
 
$CONTROL_IRRFLG
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "IRRFLG"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_IRRFLG                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_IRRFLG                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_IRRFLG
[L]CURPRO = "IRRFLG"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.IRRFLG=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_IRRFLG
[L]CURPRO = "IRRFLG"
If this.IRRFLG<0 or this.IRRFLG>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.IRRFLG)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_IRRFLG
[L]CURPRO = "IRRFLG"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_IRRFLG
[L]CURPRO = "IRRFLG"
Return

$PROPAGATE_IRRFLG
this.isReadonly = 0
[L]CURPRO = "IRRFLG"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_IRRFLG
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "IRRFLG"
$_LNKPRO_IRRFLG
Return


