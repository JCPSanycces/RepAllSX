#<AdxTL>@(#)2.0.0.0 $Revision$

## Annulation de relevé

## Question en modification si on annulé des échéances

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
 When "SORTIE"  : Gosub SORTIE
Endcase
Return

$INIT
Case GACTION
 When "RELANU"
  Local Char NUMREL(GLONVCR) , SYMHAE(30)
  NUMREL   = PARAM(1)
  GOK = 0 : # On le mettra à 1 si on annule vraiment
 When "RELMOD"
  Local Char NUMREL(GLONVCR)
  Local Integer OK2
  NUMREL   = PARAM(1)
  ## Echéances annulées?
  [M:REL0]ANUREL=0
  Filter [F:DUD] Where SOINUM=NUMREL  Order By Key CLE=SOINUM
  For [F:DUD]CLE
   [L]OK2=0
   For I=0 To [M:REL0]DUDNBR-1
    If [F:DUD]ACCNUM=[M:REL0]ACCNUM(I) & [F:DUD]DUDLIG=[M:REL0]DUDLIG(I)
     [L]OK2=1 : Break 
    Endif 
   Next I
   If ![L]OK2 : [M:REL0]ANUREL=1 : Break : Endif 
  Next 
  Filter [F:DUD]
  If [M:REL0]ANUREL=0 : FIN = 1 : Endif : # Y'a rien à saisir
Endcase
Return

$SORTIE
Case GACTION
 When "RELANU"
  [M:REL0]ANUREL = [M:DIA]CHOIX
  PARAM(2) = "0" : # OK = 0 pour ne pas faire ANUCOD au retour
 When "RELMOD"
  If [M:REL0]ANUREL<>0
   [M:REL0]ANUREL = [M:DIA]CHOIX 
   PARAM(2) = num$((OK=2))
  Endif
Endcase
Return

$EXEC
Case GACTION
 When "RELANU"
  Call DEBTRANS From GLOCK
  Gosub TR1
Endcase
Return

$TR1
[M:REL0]ANUREL = [M:DIA]CHOIX
GOK = 1
Trbegin [DUD] , [SOI]
# Echéances
 Read [SOI]SOI0 = NUMREL
 If fstat
  GOK=0 : Call FSTA("SOI") From GLOCK : Goto AB_TR1
 Endif

 Filter [F:DUD] Where SOINUM=NUMREL
&               Order By Key CLE=SOINUM
 For [F:DUD]CLE
  ## Lock de la pièce
  SYMHAE = "HAE"+num$([F:DUD]NUM)+"\"+num$([F:DUD]TYP)
  Lock =SYMHAE
  If fstat : GOK=-1 : GLOCK="%"+SYMHAE : Break : Endif
  Gosub SUPP_ECHE From SUBREL
  If GOK<1 : Break : Endif
 Next
 Filter [F:DUD]
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

# Relevés reportés
 If [F:SOI]FLGFWDSOI=2
  Gosub SUPP_SOI From SUBREL
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif

# Effacement relevé
 Delete [SOI]
 If fstat=1
  GOK = -1 : GLOCK = "$SOI"-num$(NUMREL) : Goto AB_TR1
 Endif

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif



