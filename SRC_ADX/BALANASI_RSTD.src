#<AdxTL>@(#)0.0.0.0 $Revision$
# Class BALANASI

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CRITERIA_AFTER"  : Gosub AQUERY_CRITERIA_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

$AQUERY_CRITERIA_AFTER
  #Ensure we don't select records where site is blank
  If PQRY.QWHERE<>""
    PQRY.QWHERE="("+PQRY.QWHERE+") and ACA_STE ne '' and TECH_BPR eq ''"
  Else
    PQRY.QWHERE="ACA_STE ne '' and TECH_BPR eq ''"
  Endif
Return

$AQUERY_TRANS_AFTER
Local Integer I

  # Convert Ledger type to character
  this.BLA.LEDTYP_A = num$([F:BLA]LEDTYP)

  # Get the year for this Fiscal year
  this.BLA.FYR = year([F:FIY]FIYEND)

  # Split the Dimensions array out to individual fields
  this.BLA.DIE1 = [F:BLA]DIE(0)
  this.BLA.DIE2 = [F:BLA]DIE(1)
  this.BLA.DIE3 = [F:BLA]DIE(2)
  this.BLA.DIE4 = [F:BLA]DIE(3)
  this.BLA.DIE5 = [F:BLA]DIE(4)
  this.BLA.DIE6 = [F:BLA]DIE(5)
  this.BLA.DIE7 = [F:BLA]DIE(6)
  this.BLA.DIE8 = [F:BLA]DIE(7)
  this.BLA.DIE9 = [F:BLA]DIE(8)

  #Split out array fields into single fields
  For I = 0 To dim([F:BLA]DEB)

    # The fields only go to 13, break if more than that
    If I > 13 : Break : Endif

    Assign "this.BLA.DEB"+num$(I)     With [F:BLA]DEB(I)
    Assign "this.BLA.CDT"+num$(I)     With [F:BLA]CDT(I)
    Assign "this.BLA.DEBLED"+num$(I)  With [F:BLA]DEBLED(I)
    Assign "this.BLA.CDTLED"+num$(I)  With [F:BLA]CDTLED(I)

    # Calculate the balance in source currency for every period
    Assign "this.BLA.BALSRC"+num$(I)  With [F:BLA]DEB(I) - [F:BLA]CDT(I)

    # Calculate the balance in ledger currency for every period
    Assign "this.BLA.BALLED"+num$(I)  With [F:BLA]DEBLED(I) - [F:BLA]CDTLED(I)
  Next I

Return

