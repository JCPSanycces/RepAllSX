#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"UTIVATSAI","VATSAI","UTIVATDCL",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "SUI"         : Gosub SUI
 When "PRE"         : Gosub PRE
 When "ENR"         : Gosub ENR
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "CONTROLE"    : Gosub CONTROLE
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$OUVRE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:JOU])=0 : Local File GJOURNAL   [JOU] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS    [AUS] : Endif
If clalev([F:VAT])=0 : Local File TABVAT     [VAT] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:CPY2])=0 : Local File COMPANY   [CPY2] : Endif
Return

$INIT
Gosub OUVRE
Local Mask VATDCL [DIA]
Raz [M:DIA]
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif 
Return

$CONTROLE
Local Integer OK
If [M:DIA]ALLCPY=2 # toutes sociétés
 SOC=""
Else
 SOC=[M:DIA]CPY
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Return : Endif
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Call UNLOCKCPY() From AX3MONO
Return

$DEBUT
Local Integer OK , REPONSE , ETABOU(1..GNBBOU)
Local Integer I , J , K , PLEIN , SUITE , RETOUR , MODIF , NOL
Local Char    FILTRE(250) , TYPCUR(GLONGTE) , PCECUR(GLONVCR) , SYMBOLE(30) , FILTSPE(255)
Local Libelle TYPLEDGEN,TYPLEDANA

# Reinit de GCURLEG car qd on lance la validation on passe de GSAISE à GTRAITE et 
# on perd le GCURLEG initialisé par CPTTRT
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG=1 
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

FILTRE = ""

If [M:DIA]ALLCPY<>2
 Call ADDCRIT(FILTRE,'[F:DAE]CPY="'+[M:DIA]CPY+'"')
 Call SETMAINREF([M:DIA]CPY,TYPLEDGEN,TYPLEDANA) From CPTDIV
 Call ADDCRIT(FILTRE,'[F:DAE]LEDTYP='+num$(TYPLEDGEN))
Else
 Call ADDCRIT(FILTRE,'[F:CPY2]LEG="'+GCURLEG+'"')
Endif
If [M:DIA]ALLFCY<>2
 Call ADDCRIT(FILTRE,'[F:DAE]FCYLIN="'+[M:DIA]FCY+'"')
Endif
If [M:DIA]ALLTYP<>2
 Call ADDCRIT(FILTRE,'[F:DAE]TYP="'+[M:DIA]TYP+'"')
Endif
If [M:DIA]ALLJOU<>2
 Call ADDCRIT(FILTRE,'[F:HAE]JOU="'+[M:DIA]JOU+'"')
Endif
If [M:DIA]ALLUSR<>2
 Call ADDCRIT(FILTRE,'([F:HAE]UPDUSR="'+[M:DIA]USR+'" | ([F:HAE]UPDUSR="" & [F:HAE]CREUSR="'+[M:DIA]USR+'"))')
Endif
If [M:DIA]ALLVAT<>2
 Call ADDCRIT(FILTRE,'[F:DAE]TAX="'+[M:DIA]VAT+'"')
Else
 Call ADDCRIT(FILTRE,'[F:DAE]TAX<>""')
Endif
If [M:DIA]STRDAT<>[0/0/0]
 Call ADDCRIT(FILTRE,'[F:DAE]ACCDAT>=['+format$(GFMD,[M:DIA]STRDAT)+']')
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 Call ADDCRIT(FILTRE,'[F:DAE]ACCDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']')
Endif

Raz [L]FILTSPE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If [L]FILTSPE="" : [L]FILTSPE = "1=1" : Endif

If [M:DIA]ALLCPY<>2
 Link [DAE] With [HAE]HAE0 ~= [F:DAE]TYP;[F:DAE]NUM As [LNK]
Else
 Link [DAE] With [HAE]HAE0 ~= [F:DAE]TYP;[F:DAE]NUM, [CPY2]CPY0 ~= [F:DAE]CPY As [LNK]
Endif

Gosub LECTURE
If PLEIN : SUITE = 1 : Else : SUITE = 0 : Endif
Default Mask [VAT]
MODIF = 0
Affzo
Return

$SETBOUT
Raz ETABOU
ETABOU(GBFIN) = 1
If SUITE  : ETABOU(GSUIV) = 1 : Endif
If RETOUR : ETABOU(GPREC) = 1 : Endif
If MODIF  : ETABOU(GENRE) = 1 : Endif
Return

$SUI
Gosub SUIVANT
MODIF  = 0
RETOUR = 1
If PLEIN : SUITE = 1 : Else : SUITE = 0 : Endif
Return

$PRE
Gosub PRECEDENT
MODIF = 0
SUITE = 1
If PLEIN : RETOUR = 1 : Else : RETOUR = 0 : Endif
Return

$ENR
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 For NOL=0 To [M:VAT]NBLIG-1
  [M:VAT]OAMTVAT(NOL) = [M:VAT]AMTVAT(NOL)
 Next NOL
Endif
MODIF = 0
Return

$APRES_MODIF
If MODIF=0
 MODIF = 1
Endif
Return

$TR1
GOK = 1
Trbegin [DAE]
 For NOL=0 To [M:VAT]NBLIG-1
  If [M:VAT]AMTVAT(NOL)<>[M:VAT]OAMTVAT(NOL)
   SYMBOLE = "HAE"+[M:VAT]TYP(NOL)+"\"+[M:VAT]NUM(NOL)
   Lock =SYMBOLE
   If fstat=1
    Call MESSAGE([M:VAT]TYP(NOL)-[M:VAT]NUM(NOL)-":"-mess(10,100,1)) From GESECRAN
    [M:VAT]AMTVAT(NOL) = [M:VAT]OAMTVAT(NOL)
    Affzo AMTVAT(NOL)
   Else
    Readlock [DAE]DAE2 = [M:VAT]ACCNUM(NOL)
    If fstat=1
     GOK = -1 : GLOCK = "$GACCENTRYD"-[M:VAT]TYP(NOL)-[M:VAT]NUM(NOL) : Goto ROLL_TR1
    Elsif fstat
     GOK = 0 : Call RSTA("DAE",[M:VAT]TYP(NOL)-[M:VAT]NUM(NOL)) From GLOCK : Goto AB_TR1
    Else
     [F:DAE]AMTVAT = [M:VAT]AMTVAT(NOL)
     Rewrite [DAE]
     If fstat
      GOK = 0 : Call FSTA("DAE") From GLOCK : Goto AB_TR1
     Endif
    Endif
   Endif
   Unlock =SYMBOLE
  Endif
  GPOINT = "UPDDAE" : Gosub ENTREE From EXEFNC
 Next
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$LECTURE
Filter [LNK] Where evalue(FILTRE) & evalue([L]FILTSPE)
& Order By Key DAE0
nolign = 0
PLEIN  = 0

For [LNK]DAE0(2)
 Call SETMAINREF([F:DAE]CPY,TYPLEDGEN,TYPLEDANA) From CPTDIV
 K = nolign
 For [LNK]DAE0
  If [F:DAE]LEDTYP=TYPLEDGEN
   If nolign>=dim([M:VAT]NUM)
    nolign = K
    PLEIN  = 1
    Break 2
   Endif
   nolign += 1
   Gosub CHARGE
  Endif
 Next
Next
[M:VAT]NBLIG = nolign
Gosub AFFICHE
Return

$AFFICHE
Affzo [VAT]
Return

$CHARGE
[M:VAT] = [F:HAE]
[M:VAT] = [F:DAE]
[M:VAT]OAMTVAT(nolign-1) = [M:VAT]AMTVAT(nolign-1)
Return

$SUIVANT
TYPCUR = [M:VAT]TYP([M:VAT]NBLIG-1)
PCECUR = [M:VAT]NUM([M:VAT]NBLIG-1)


Filter [LNK] Where evalue(FILTRE) & evalue([L]FILTSPE) & ((TYP=TYPCUR & NUM>PCECUR) | TYP>TYPCUR)
& Order By Key DAE0
nolign = 0
PLEIN  = 0
For [LNK]DAE0(2)
 Call SETMAINREF([F:DAE]CPY,TYPLEDGEN,TYPLEDANA) From CPTDIV
 K = nolign
 For [LNK]DAE0
  If [F:DAE]LEDTYP=TYPLEDGEN
   If nolign>=dim([M:VAT]NUM)
    nolign = K
    PLEIN  = 1
    Break 2
   Endif
   nolign += 1
   Gosub CHARGE
  Endif
 Next
Next
[M:VAT]NBLIG = nolign
Gosub AFFICHE
Return

$PRECEDENT
TYPCUR = [M:VAT]TYP(0)
PCECUR = [M:VAT]NUM(0)
Filter [LNK] Where evalue(FILTRE) & evalue([L]FILTSPE) & ((TYP=TYPCUR & NUM<PCECUR) | TYP<TYPCUR)
& Order By Key DAE0 Desc
nolign = dim([M:VAT]NUM)+1
PLEIN  = 0
For [LNK]DAE0(2)
 Call SETMAINREF([F:DAE]CPY,TYPLEDGEN,TYPLEDANA) From CPTDIV
 K = nolign
 For [LNK]DAE0
  If [F:DAE]LEDTYP=TYPLEDGEN
   If nolign<=1
    nolign = K
    PLEIN  = 1
    Break 2
   Endif
   nolign -= 1
   Gosub CHARGE
  Endif
 Next
Next
[M:VAT]NBLIG = dim([M:VAT]NUM)
If nolign>1
 Dela 0,nolign-1,[M:VAT]NBLIG-1 [M:VAT]NBLIG
 [M:VAT]NBLIG -= (nolign-1)
Endif
Gosub AFFICHE
Return

Subprog ADDCRIT(FILTRE,CRITERE)
Variable Char FILTRE
Value    Char CRITERE
If FILTRE<>"" : FILTRE -= "&" : Endif
FILTRE -= CRITERE
End
