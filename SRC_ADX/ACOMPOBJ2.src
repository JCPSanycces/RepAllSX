#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(30)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOMPOBJ","ACOMPOBJ",3,"XYACOMPOBJ") From GTRAITE
End

######################################################################################
$COMP_AMK                                           #### ECRANS ########################
########################################################################################
## Entete de comparaison
If !EXCEL & GTRACE<>""
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-":"-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-":"-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(17,125,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_AMK)+")",0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_AMK
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
  Call TRACE("AMK","","","","","",mess(13,150,1),EXCEL,-1,DIF) : # Ecran inexistant
 Endif
 Return
Endif
## Traitement de la table ATABZON
Raz NBFIC
For COD="AMSK","AMSKZON","AMSKPAR","AMSKACT"
    Gosub TRT_ATABZON
    NBFIC += 1
Next
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]AMKDEB="" & [M:ACMP]AMKFIN="ZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& CODMSK<'X'"
 Endif
Else
 CRITERE += "& CODMSK>=[M:ACMP]AMKDEB & CODMSK<=[M:ACMP]AMKFIN"
Endif
If left$([M:ACMP]AMKDEB,1)<>"W" & left$([M:ACMP]AMKFIN,1)<>"W"
 CRITERE += "& left$(CODMSK,1)<>'W'"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

## Début de la comparaison
For [AMK1]CODMSK Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AMK1]MODULE-1,0)) = 2
      FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
      Gosub FILTRE_AMK From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
      If !OK Goto NEXT_AMK1: Endif        #X3PLAT-940 - Filter on activity code
        Read [F:AMK2]CODMSK=[F:AMK1]CODMSK
        If fstat
            DIF = 1
            # Ecran inexistant sous
            Call TRACE("AMK",[F:AMK1]CODMSK,"","","",mess(87,100,1),mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
        Else
            Raz OK_C
            OBJ=0 : Gosub TRT_MSK
            ## Traitement des champs de ORG --> DES
            For [AMZ1]CODE Where [F:AMZ1]CODMSK=[F:AMK1]CODMSK
                Read [AMZ2]CODE=[F:AMZ1]CODMSK;[F:AMZ1]CODZON
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [F:OATX]NUMERO=GLANGUE;[F:AMZ1]INTIT
                    If fstat : [F:OATX]TEXTE="" : Endif
                    Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),[F:AMZ1]CODZON,[F:OATX]TEXTE,mess(41,100,1)
&                   ,mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                    # Champs
                Else
                    OBJ=1 : Gosub TRT_MSK
                    For [AMP1]CODPAR Where [F:AMP1]TYPAFF = 1
&                                        & [F:AMP1]CODAFF = [F:AMK1]CODMSK
&                                        & [F:AMP1]CODZON = [F:AMZ1]CODZON
                        Read [F:AMP2]CODPAR=[F:AMP1]TYPAFF;[F:AMP1]CODAFF;[F:AMP1]CODZON;[F:AMP1]CODPAR
                        If fstat
                          Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),[F:AMZ1]CODZON,[F:AMP1]CODPAR,mess(11,133,1)
&                         ,mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                         # Ecran & Paramètre & inexistant sous
                        Else
                            OBJ = 2 : Gosub TRT_MSK
                        Endif
                    Next AMP1
                    For [AMA1]TYPAFF Where [F:AMA1]TYPAFF = 1
&                                        & [F:AMA1]CODAFF = [F:AMK1]CODMSK
&                                        & [F:AMA1]CODZON = [F:AMZ1]CODZON
                        Filter [F:AMA2]Where [F:AMA2]TYPAFF = [F:AMA1]TYPAFF
&                                          & [F:AMA2]CODAFF = [F:AMA1]CODAFF
&                                          & [F:AMA2]CODZON = [F:AMA1]CODZON
&                                          & [F:AMA2]TYPACT = [F:AMA1]TYPACT
&                                          & [F:AMA2]ACTION = [F:AMA1]ACTION
                        Read [F:AMA2]First
                        If fstat
                            OK_C = 1
                            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
                            Read [F:OATX]NUMERO=GLANGUE;[F:AMZ1]INTIT
                            If fstat : [F:OATX]TEXTE="" : Endif
                            Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),[F:AMZ1]CODZON,[F:OATX]TEXTE,mess(84,133,1)
&                           ,mess([F:AMA1]TYPACT,31,1)-[F:AMA1]ACTION-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                            # Action inexistante
                        Else
                            OBJ = 3 : Gosub TRT_MSK
                        Endif
                        Filter [AMA2]
                    Next AMA1
                Endif
            Next AMZ1
            ## Traitement des champs de DES --> ORG
            For [AMZ2]CODE Where [F:AMZ2]CODMSK=[F:AMK1]CODMSK
                Read [F:AMZ1]CODE = [F:AMZ2]CODMSK;[F:AMZ2]CODZON
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [DATX]NUMERO=GLANGUE;[F:AMZ2]INTIT
                    If fstat : [F:DATX]TEXTE="" : Endif
                    Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),[F:AMZ2]CODZON,[F:DATX]TEXTE,mess(41,100,1)
&                   ,mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                    # Champs
                Else
                    For [AMP2]CODPAR Where [F:AMP2]TYPAFF = 1
&                                        & [F:AMP2]CODAFF = [F:AMK1]CODMSK
&                                        & [F:AMP2]CODZON = [F:AMZ2]CODZON
                        Read [AMP1]CODPAR=[F:AMP2]TYPAFF;[F:AMP2]CODAFF;[F:AMP2]CODZON;[F:AMP2]CODPAR
                        If fstat
                          Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),[F:AMZ1]CODZON,[F:AMP1]CODPAR,mess(11,133,1)
&                         ,mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                         # Ecran & Paramètre & inexistant sous
                        Endif
                    Next AMP2
                    For [AMA2]TYPAFF Where [F:AMA2]TYPAFF = 1
&                                        & [F:AMA2]CODAFF = [F:AMK1]CODMSK
&                                        & [F:AMA2]CODZON = [F:AMZ2]CODZON
                        Filter [F:AMA1]Where [F:AMA1]TYPAFF = [F:AMA2]TYPAFF
&                                          & [F:AMA1]CODAFF = [F:AMA2]CODAFF
&                                          & [F:AMA1]CODZON = [F:AMA2]CODZON
&                                          & [F:AMA1]TYPACT = [F:AMA2]TYPACT
&                                          & [F:AMA1]ACTION = [F:AMA2]ACTION
                        Read [AMA1]First
                        If fstat
                            OK_C = 1
                            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
                            Read [DATX]NUMERO=GLANGUE;[F:AMZ2]INTIT
                            If fstat : [F:DATX]TEXTE="" : Endif
                            Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),[F:AMZ2]CODZON,[F:DATX]TEXTE,mess(84,133,1)
&                           ,mess([F:AMA2]TYPACT,31,1)-[F:AMA2]ACTION-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                            # Action inexistante
                        Endif
                        Filter [AMA1]
                    Next AMA2
                Endif
            Next AMZ2
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                    Call TRACE("AMK",[F:AMK1]CODMSK,"","","","",mess(77,126,1),EXCEL,0,DIF)
                    # Ecran identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("AMK",[F:AMK1]CODMSK,"","","",mess(49,124,1),"",EXCEL,-1,DIF)
                    # Différent
                    If PATCH : Call PATCH("AMK",[F:AMK1]CODMSK,"") : Endif
                Endif
            Endif
        Endif
    Endif
$NEXT_AMK1                    #X3PLAT-940 - Filter on activity code
Next AMK1
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [AMK2]CODMSK Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AMK2]MODULE-1,0)) = 2
        FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_AMK From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_AMK2: Endif        #X3PLAT-940 - Filter on activity code
        Read [F:AMK1]CODMSK=[F:AMK2]CODMSK
        If fstat
            OK_C = 1
            Call TRACE("AMK",[F:AMK2]CODMSK,"","","",mess(87,100,1),mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
            # Ecran inexistant sous
        Endif
    Endif
$NEXT_AMK2  # X3PLAT-940 - Filter on activity code
Next AMK2
Return

#############################
Funprog NOMDOS(DOS)
Value Char DOS
Local Integer K
K = instr(1,DOS,"@")
If K
 End right$(DOS,K+1)
Else
 End DOS
Endif
End

#############################
$TRT_MSK
If OBJ=3 : AOBJ="AMA" : Endif
If OBJ=2 : AOBJ="AMP" : Endif
If OBJ=1 : AOBJ="AMZ" : Endif
If OBJ=0
    AOBJ="AMK"
Else
    Read [F:OATX]NUMERO=GLANGUE;[F:AMZ1]INTIT
    If fstat : LIBEL="" Else LIBEL=[F:OATX]TEXTE : Endif
Endif

For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    If OBJ=3 and find(ZON(OBJ,I),"NOACT") : K=0 : Endif
    For J=1 To K
    If TYP(OBJ,I) = "ATX" & evalue("dim(["+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
        Read [OATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:OATX]TEXTE="" : Endif
        Read [DATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:DATX]TEXTE="" : Endif
        If [F:OATX]TEXTE <> [F:DATX]TEXTE
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
            If OBJ<>0
               Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),[F:AMZ1]CODZON,[F:OATX]TEXTE,mess(200,115,1)
&              ,MESSTECH-[F:OATX]TEXTE-"<>"-[F:DATX]TEXTE,EXCEL,-1,DIF)
               # Ecran & Champ & Intitulés différents
            Else
               Call TRACE("AMK",[F:AMK1]CODMSK,mess(82,123,1),"",[F:OATX]TEXTE,mess(200,115,1)
&              ,MESSTECH-[F:OATX]TEXTE-"<>"-[F:DATX]TEXTE,EXCEL,-1,DIF)
               # Ecran & Intitulés différents
            Endif
        Endif
    Else
        Raz INTERM1 , INTERM2
        If evalue("dim([F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
         INTERM1 = num$(evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        Endif
        If evalue("dim([F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
         INTERM2 = num$(evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        Endif
        If INTERM1 <> INTERM2
           OK_C = 1
           If [M:ACMP]DETAIL<>2 : Break 2 : Endif
           Gosub FORMAT_KT
           If OBJ = 0
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
              Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),ZON(OBJ,I),INTZON(OBJ,I),mess(201,115,1)
&            ,MESSTECH-INTERM1-"<>"-INTERM2-mess(81,126,1),EXCEL,-1,DIF)
              # Ecran & Champ & Différence
           Elsif OBJ = 1
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),[F:AMZ1]CODZON,INTZON(OBJ,I),mess(201,115,1)
&            ,MESSTECH-INTERM1-"<>"-INTERM2-mess(81,126,1),EXCEL,-1,DIF)
              # Ecran & Champ & Différence
           Elsif OBJ = 3
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),[F:AMZ1]CODZON,LIBEL,mess(202,115,1),[F:AMA1]ACTION
&             -mess([F:AMA1]TYPACT,31,1)-MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
              # Ecran & Champ & Action & Différence
           Else
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("AMK",[F:AMK1]CODMSK,mess(149,123,1),[F:AMZ1]CODZON,LIBEL,mess(203,115,1)
&             ,[F:AMP1]CODPAR-MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
              # Ecran & Champ & Paramètre & Différence
           Endif
        Endif
    Endif
    Next J
Next I
Return

########################################################################################
$COMP_WIN                                          #### FENETRE ########################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(11,42,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_AWI)+")",0) From GESECRAN    # Fenêtres
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_AWI
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
   Call TRACE("AWI","","","","","",mess(6,126,1),EXCEL,-1,DIF) : # Fenêtre inexistante
 Endif
 Return
Endif
Raz NBFIC
For COD="AWINDOW","AWINPAR","AWINBRO","AWINBOUT"
    Gosub TRT_ATABZON
    NBFIC +=1
Next
## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]AWIDEB="" & [M:ACMP]AWIFIN="ZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& WIN<'X' & !find(left$(WIN,2),'OX','OY','OZ')"
 Endif
Else
 CRITERE += "& WIN>=[M:ACMP]AWIDEB & WIN<=[M:ACMP]AWIFIN"
Endif
If left$([M:ACMP]AWIDEB,1)<>"W" & left$([M:ACMP]AWIFIN,1)<>"W"
 CRITERE += "& left$(WIN,1)<>'W'"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

For [F:AWI1]AWI0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AWI1]MODULE-1,0)) = 2
       FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
       Gosub FILTRE_WIN From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
       If !OK Goto NEXT_AWI1: Endif        #X3PLAT-940 - Filter on activity code

        Read [F:AWI2]AWI0=[F:AWI1]WIN
        If fstat
            Call TRACE("AWI",[F:AWI1]WIN,"","","",mess(87,100,1),mess(82,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
            # Fenêtre inexistante sous "
        Else
            Raz OK_C
            OBJ=0 : Gosub TRT_WIN
            ## Traitement des paramètres de ORG --> DES
            For [F:AWP1]AWP0 Where [F:AWP1]WIN=[F:AWI1]WIN
                Read [AWP2]AWP0=[F:AWP1]WIN;[F:AWP1]NUM;[F:AWP1]NOPAR;[F:AWP1]PARAM
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    If [F:AWP1]NUM<100
                        Call TRACE("AWI",[F:AWI1]WIN,mess(1,88,1),num$([F:AWP1]NUM),"",mess(11,133,1)
&                       ,[F:AWP1]PARAM-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                        # Fenêtre & Bouton & Paramètre & inexistant sous
                    Else
                        Call TRACE("AWI",[F:AWI1]WIN,mess(1,88,1),num$([F:AWP1]NUM-100),"",mess(11,133,1)
&                       ,[F:AWP1]PARAM-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                        # Fenêtre & Action & Paramètre & inexistant sous
                    Endif
                Else
                    If vireblc([F:AWP1]VALEUR,2) <> vireblc([F:AWP2]VALEUR,2)
                        OK_C = 1
                        If [M:ACMP]DETAIL<>2 : Break : Endif
                        If [F:AWP1]NUM<100
                            Call TRACE("AWI",[F:AWI1]WIN,mess(1,88,1),num$([F:AWP1]NUM),"",mess(203,115,1),[F:AWP1]PARAM-mess(81,126,1)
&                           -"'"+[F:AWP1]VALEUR+"'"-"'"+[F:AWP2]VALEUR+"'"-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                            # Fenêtre & Bouton & Paramètre & Différence
                        Else
                         Call TRACE("AWI",[F:AWI1]WIN,mess(1,88,1),num$([F:AWP1]NUM-100),"",mess(203,115,1),[F:AWP1]PARAM-mess(81,126,1)
&                        -"'"+[F:AWP1]VALEUR+"'"-"'"+[F:AWP2]VALEUR+"'"-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                            # Fenêtre & Action & Paramètre & Différence
                        Endif
                    Endif
                Endif
            Next
            For [F:AWB1]AWB0 Where [F:AWB1]WIN=[F:AWI1]WIN
             Read [AWB2]AWB0=[F:AWB1]WIN
             If fstat
              OK_C = 1
              Call TRACE("AWI",[F:AWI1]WIN,mess(8,38,1),[F:AWB1]WIN,"",mess(204,115,1)
&             ,mess(4,29,1)-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
              # Browser inexistant sous "
             Else
              OBJ=2 : Gosub TRT_WIN
             Endif
            Next
            For [F:AWT1]AWT0 Where [F:AWT1]WIN=[F:AWI1]WIN
             Read [AWT2]AWT0=[F:AWT1]WIN;[F:AWT1]NUM;[F:AWT1]CODBOUT
             If fstat
              OK_C = 1
              Call TRACE("AWI",[F:AWI1]WIN,mess(1,88,1),num$([F:AWT1]NUM),[F:AWT1]CODBOUT
&             ,mess(205,115,1),mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
              # Fenêtre & Bouton inexistant sous
             Else
              OBJ=3 : Gosub TRT_WIN
             Endif
            Next
            ## Traitement des paramètres de DES --> ORG
            For [F:AWP2]AWP0 Where [F:AWP2]WIN=[F:AWI1]WIN
                Read [AWP1]AWP0=[F:AWP2]WIN;[F:AWP2]NUM;[F:AWP2]NOPAR;[F:AWP2]PARAM
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    If [F:AWP2]NUM<100
                        Call TRACE("AWI",[F:AWI1]WIN,mess(1,88,1),num$([F:AWP2]NUM),"",mess(11,133,1)
&                      ,[F:AWP2]PARAM-mess(87,100,1)-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                        # Fenêtre & Bouton & Paramètre & inexistant sous
                    Else
                        Call TRACE("AWI",[F:AWI1]WIN,mess(1,88,1),num$([F:AWP2]NUM-100),"",mess(11,133,1)
&                      ,[F:AWP2]PARAM-mess(87,100,1)-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                        # Fenêtre & Bouton & Paramètre & inexistant sous
                    Endif
                Endif
            Next
            For [F:AWB2]AWB0 Where [F:AWB2]WIN=[F:AWI1]WIN
             Read [AWB1]AWB0=[F:AWB2]WIN
             If fstat
              OK_C = 1
              Call TRACE("AWI",[F:AWI1]WIN,mess(8,38,1),[F:AWB2]WIN,"",mess(205,115,1)
&            ,mess(4,29,1)-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
              # Browser inexistant sous "
             Else
              OBJ=2 : Gosub TRT_WIN
             Endif
            Next
            For [F:AWT2]AWT0 Where [F:AWT2]WIN=[F:AWI1]WIN
             Read [AWT1]AWT0=[F:AWT2]WIN;[F:AWT2]NUM;[F:AWT2]CODBOUT
             If fstat
              OK_C = 1
              Call TRACE("AWI",[F:AWI1]WIN,mess(1,88,1),num$([F:AWT2]NUM),[F:AWT2]CODBOUT
&             ,mess(205,115,1),mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
              # Fenêtre & Bouton inexistant sous
             Else
              OBJ=3 : Gosub TRT_WIN
             Endif
            Next
            If [M:ACMP]DETAIL=2 & !TOUT
                If !OK_C & !EXCEL
                     Call TRACE("AWI",[F:AWI1]WIN,"","","","",mess(88,126,1),EXCEL,0,DIF)
                     # Fenêtre identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("AWI",[F:AWI1]WIN,"","","",mess(49,124,1),mess(14,126,1)-mess(90,126,1),EXCEL,-1,DIF)
                    # Fenêtre différente
                    If PATCH : Call PATCH("AWI",[F:AWI1]WIN,"") : Endif
                Endif
            Endif
        Endif
    Endif
$NEXT_AWI1      # X3PLAT-940 - Filter on activity code
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:AWI2]AWI0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AWI2]MODULE-1,0)) = 2
        FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_WIN From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_AWI2: Endif        #X3PLAT-940 - Filter on activity code

        Read [F:AWI1]AWI0=[F:AWI2]WIN
        If fstat
            OK_C = 1
            Call TRACE("AWI",[F:AWI2]WIN,"","","",mess(87,100,1),mess(14,126,1)-mess(82,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
            # Fenêtre inexistante sous "
        Endif
    Endif
$NEXT_AWI2      # X3PLAT-940 - Filter on activity code
Next
Return

#############################
$TRT_WIN
If OBJ=0 : AOBJ="AWI" : Endif
If OBJ=1 : AOBJ="AWP" : Endif
If OBJ=2 : AOBJ="AWB" : Endif
If OBJ=3 : AOBJ="AWT" : Endif

For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    For J=1 To K
    If TYP(OBJ,I) = "ATX"
        Read [OATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:OATX]TEXTE="" : Endif
        Read [DATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:DATX]TEXTE="" : Endif
        If [F:OATX]TEXTE <> [F:DATX]TEXTE
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
            If K<>1
                Call TRACE("AWI",[F:AWI1]WIN,mess(149,123,1),ZON(OBJ,I)+"("+num$(J-1)+")"
&               ,[F:OATX]TEXTE,mess(200,115,1),MESSTECH-[F:DATX]TEXTE,EXCEL,-1,DIF)
                # Fenêtre & Champ & Intitulés différents
            Else
                Call TRACE("AWI",[F:AWI1]WIN,mess(149,123,1),ZON(OBJ,I),[F:OATX]TEXTE
&               ,mess(200,115,1),MESSTECH-[F:DATX]TEXTE,EXCEL,-1,DIF)
                # Fenêtre & Champ & Intitulés différents
            Endif
        Endif
    Else
        INTERM1 = num$(evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        INTERM2 = num$(evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        If INTERM1 <> INTERM2
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
            Gosub FORMAT_KT
            If K<>1
                Call TRACE("AWI",[F:AWI1]WIN,mess(149,123,1),ZON(OBJ,I)+"("+num$(J-1)+")"
&               ,INTZON(OBJ,I),mess(201,115,1),MESSTECH-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                # Fenêtre & Champ & Différence
            Else
                Call TRACE("AWI",[F:AWI1]WIN,mess(149,123,1),ZON(OBJ,I),INTZON(OBJ,I)
&               ,mess(201,115,1),MESSTECH-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                # Fenêtre & Champ & Différence
            Endif
        Endif
    Endif
    Next J
Next I
Return


########################################################################################
$COMP_OBJ                                           #### OBJETS ########################
########################################################################################
## Entete de comparaison
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(4,42,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_AOB)+")",0) From GESECRAN    # Objet
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_AOB
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
   Call TRACE("AOB","","","","","",mess(1,150,1),EXCEL,-1,DIF) : # Objet inexistant
 Endif
 Return
Endif
## Traitement de la table ATABZON
Raz NBFIC
For COD="AOBJET","AOBJLST","AOBJTAB"
    Gosub TRT_ATABZON
    NBFIC +=1
Next
## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]AOBDEB="" & [M:ACMP]AOBFIN="ZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& ABREV<'X'"
 Endif
Else
 CRITERE += "& ABREV>=[M:ACMP]AOBDEB & ABREV<=[M:ACMP]AOBFIN"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif
For [F:AOB1]ABREV Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AOB1]MODULE-1,0)) = 2
        FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_OBJ From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_AOB1: Endif        #X3PLAT-940 - Filter on activity code

        Read [F:AOB2]ABREV=[F:AOB1]ABREV
        If fstat
            Call TRACE("AOB",[F:AOB1]ABREV,"","","",mess(87,100,1),mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
            # "Objet inexistant sous "
        Else
            Raz OK_C
            OBJ = 0 : Gosub TRT_OBJ
            ## Traitement des champs de ORG --> DES
            For [F:AOL1]AOL0 Where [F:AOL1]ABREV=[F:AOB1]ABREV
                Read [F:AOL2]AOL0=[F:AOL1]ABREV
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("AOB",[F:AOB1]ABREV,mess(22,123,1),[F:AOL1]ABREV,"",mess(206,115,1)
&                   ,mess(8,31,1)-mess(82,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                    # Sélection inexistante sous
                Else
                    OBJ = 1 : Gosub TRT_OBJ
                Endif
            Next
            For [F:AOT1]ABREV Where [F:AOT1]ABREV=[F:AOB1]ABREV
                Read [F:AOT2]ABREV=[F:AOT1]ABREV;[F:AOT1]NUMLIG
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("AOB",[F:AOB1]ABREV,mess(56,123,1),[F:AOT1]TABFIC,num$([F:AOT1]NUMLIG),mess(124,124,1)
&                   ,mess(81,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                    # Table inexistante sous
                Else
                    OBJ = 2 : Gosub TRT_OBJ
                Endif
            Next

            ## Traitement des champs de DES --> ORG
            For [F:AOL2]AOL0 Where [F:AOL2]ABREV = [F:AOB1]ABREV
                Read [F:AOL1]AOL0 = [F:AOL2]ABREV
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("AOB",[F:AOB1]ABREV,mess(22,123,1),[F:AOL2]ABREV,"",mess(206,115,1)
&                   ,mess(82,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                    # Sélection inexistante sous
                Endif
            Next
            For [F:AOT2]ABREV Where [F:AOT2]ABREV = [F:AOB1]ABREV
                Read [F:AOT1]ABREV = [F:AOT2]ABREV;[F:AOT2]NUMLIG
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("AOB",[F:AOB1]ABREV,mess(56,123,1),[F:AOT2]TABFIC,num$([F:AOT2]NUMLIG),mess(124,124,1)
&                   ,mess(81,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                    # Table inexistante sous
                Endif
            Next
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                      Call TRACE("AOB",[F:AOB1]ABREV,"","","","",mess(78,126,1),EXCEL,0,DIF)
                      # Objet identique
                Endif
            Else
                If OK_C=1
                      Call TRACE("AOB",[F:AOB1]ABREV,"","","",mess(3,55,1),mess(33,115,1)-mess(3,55,1),EXCEL,-1,DIF)
                      # Objet différent
                      If PATCH : Call PATCH("AOB",[F:AOB1]ABREV,"") : Endif
                Endif
            Endif
        Endif
    Endif
$NEXT_AOB1                    #X3PLAT-940 - Filter on activity code
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:AOB2]ABREV Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AOB2]MODULE-1,0)) = 2
      FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
      Gosub FILTRE_OBJ From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
      If !OK Goto NEXT_AOB2 : Endif       #X3PLAT-940 - Filter on activity code

        Read [F:AOB1]ABREV=[F:AOB2]ABREV
        If fstat
            OK_C = 1
            Call TRACE("AOB",[F:AOB2]ABREV,"","","",mess(87,100,1),mess(33,115,1)-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
            # Objet inexistant sous
        Endif
    Endif
$NEXT_AOB2  # X3PLAT-940 - Filter on activity code
Next
Return

#############################
$TRT_OBJ
If OBJ=0 : AOBJ="AOB" : Endif
If OBJ=1 : AOBJ="AOL" : Endif
If OBJ=2 : AOBJ="AOT" : Endif

For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    For J=1 To K
    If TYP(OBJ,I) = "ATX"
        Read [OATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:OATX]TEXTE="" : Endif
        Read [DATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:DATX]TEXTE="" : Endif
        If [F:OATX]TEXTE <> [F:DATX]TEXTE
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
            Call TRACE("AOB",[F:AOB1]ABREV,mess(149,123,1),ZON(OBJ,I)
&           ,[F:OATX]TEXTE,mess(200,115,1),MESSTECH-[F:DATX]TEXTE,EXCEL,-1,DIF)
            # Objet & Champ & Intitulés différents
        Endif
    Else
        INTERM1 = num$(evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        INTERM2 = num$(evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        If INTERM1 <> INTERM2
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
            Gosub FORMAT_KT
            Call TRACE("AOB",[F:AOB1]ABREV,mess(149,123,1),ZON(OBJ,I)
&           ,INTZON(OBJ,I),mess(201,115,1),MESSTECH-mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
            # OBJET & Champ & Différence
        Endif
    Endif
    Next J
Next I
Return


########################################################################################
$COMP_AOC                         ####  PERSONNALISATION OBJETS ########################
########################################################################################
## Entete de comparaison
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(83,126,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_AOC)+")",0) From GESECRAN   # Personnalisation objets
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_AOC
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
   Call TRACE("AOC","","","","","",mess(1,150,1),EXCEL,-1,DIF) : # Objet inexistant
 Endif
 Return
Endif
## Traitement de la table ATABZON
Gosub TRT_ATABZON_PERS

## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]AOCDEB="" & [M:ACMP]AOCFIN="ZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& ABREV<'X'"
 Endif
Else
 CRITERE += "& ABREV>=[M:ACMP]AOCDEB & ABREV<=[M:ACMP]AOCFIN"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif
For [F:AOB1]ABREV Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AOB1]MODULE-1,0)) = 2
        FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_AOC From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_AOC1: Endif        #X3PLAT-940 - Filter on activity code

        Read [F:AOB2]ABREV=[F:AOB1]ABREV
        If fstat
            Call TRACE("AOC",[F:AOB1]ABREV,"","","",mess(87,100,1),mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
            # Objet inexistant sous
        Else
            Raz OK_C
            OBJ = 0 : Gosub TRT_OBJ
            ## Traitement des champs de ORG --> DES
            For [F:AOL1]AOL0 Where [F:AOL1]ABREV=[F:AOB1]ABREV
                Read [F:AOL2]AOL0=[F:AOL1]ABREV
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("AOC",[F:AOB1]ABREV,mess(8,31,1),[F:AOL1]ABREV,"",mess(206,115,1)
&                   ,mess(82,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                    # Sélection inexixtante sous
                Else
                    OBJ = 1 : Gosub TRT_OBJ
                Endif
            Next

            ## Traitement des champs de DES --> ORG
            For [F:AOL2]AOL0 Where [F:AOL2]ABREV = [F:AOB1]ABREV
                Read [F:AOL1]AOL0 = [F:AOL2]ABREV
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("AOC",[F:AOB1]ABREV,mess(8,31,1),[F:AOL2]ABREV,"",mess(206,115,1)
&                    ,mess(82,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                    # Sélection inexistante sous
                Endif
            Next
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                    Call TRACE("AOC",[F:AOB1]ABREV,"","","","",mess(78,126,1),EXCEL,0,DIF)
                    # Objet identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("AOC",[F:AOB1]ABREV,"","","",mess(3,55,1),mess(33,115,1)-mess(3,55,1),EXCEL,-1,DIF)
                    # Objet différent
                    If PATCH : Call PATCH("AOB",[F:AOB1]ABREV,"") : Endif
                Endif
            Endif
        Endif
    Endif
$NEXT_AOC1
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:AOB2]ABREV Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AOB2]MODULE-1,0)) = 2
      FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
      Gosub FILTRE_AOC From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
      If !OK Goto NEXT_AOC2 : Endif       #X3PLAT-940 - Filter on activity code

        Read [F:AOB1]ABREV=[F:AOB2]ABREV
        If fstat
            OK_C = 1
            Call TRACE("AOC",[F:AOB2]ABREV,"","","",mess(87,100,1),mess(33,115,1)-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
            # Objet inexistant sous
        Endif
    Endif
$NEXT_AOC2
Next
Return

########################################################################################
$COMP_AFC                                       #### FONCTIONS  ########################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(21,125,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_AFC)+")",0) From GESECRAN : # Fonctions
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_AFC
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
   # Fonction inexistante
   Call TRACE("AFC","","","","","",mess(162,123,1),EXCEL,-1,DIF)
 Endif
 Return
Endif
Raz NBFIC
For COD="AFONCTION"
    Gosub TRT_ATABZON
    NBFIC+=1
Next

## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]AFCDEB="" & [M:ACMP]AFCFIN="ZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& CODINT<'X' & !find(left$(CODINT,4),'GESX','GESY','GESZ')"
 Endif
Else
 CRITERE += "& CODINT>=[M:ACMP]AFCDEB & CODINT<=[M:ACMP]AFCFIN"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

For [F:AFC1]CODINT Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AFC1]MODULE-1,0)) = 2
        FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_AFC From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_AFC1: Endif        #X3PLAT-940 - Filter on activity code

        Filter [F:AFC2] Where [F:AFC2]CODINT=[F:AFC1]CODINT
        Read [F:AFC2] First
        If fstat
            Call TRACE("AFC",[F:AFC1]CODINT,"","","",mess(87,100,1),mess(33,124,1)-mess(82,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
            # Fonction inexistante sous
        Else
            Raz OK_C
            Gosub TRT_AFC
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                    Call TRACE("AFC",[F:AFC1]CODINT,"","","","",mess(125,126,1),EXCEL,0,DIF)
                    # Fonction identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("AFC",[F:AFC1]CODINT,"","","",mess(3,55,1),mess(33,124,1)-mess(90,126,1),EXCEL,-1,DIF)
                    # Fonction différente
                    If PATCH : Call PATCH("AFC",[F:AFC1]CODINT,"") : Endif
                Endif
            Endif
        Endif
        Filter [F:AFC2]
    Endif
$NEXT_AFC1                    #X3PLAT-940 - Filter on activity code
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:AFC2]CODINT Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AFC2]MODULE-1,0)) = 2
      FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
      Gosub FILTRE_AFC From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
      If !OK Goto NEXT_AFC2 : Endif       #X3PLAT-940 - Filter on activity code

        Read [F:AFC1]CODINT=[F:AFC2]CODINT
        If fstat
            OK_C = 1
            Call TRACE("AFC",[F:AFC2]CODINT,"","","",mess(87,100,1),mess(33,124,1)-mess(82,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
            # Fonction inexistante sous
        Endif
    Endif
$NEXT_AFC2  # X3PLAT-940 - Filter on activity code
Next
Return

#############################
$TRT_AFC
OBJ=0
For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    For J=1 To K
        If TYP(OBJ,I) = "ATX"
            Read [OATX]NUMERO=GLANGUE;evalue("[F:afc1]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:OATX]TEXTE="" : Endif
            Read [DATX]NUMERO=GLANGUE;evalue("[F:afc2]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:DATX]TEXTE="" : Endif
            If [F:OATX]TEXTE <> [F:DATX]TEXTE
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Call TRACE("AFC",[F:AFC1]CODINT,mess(149,123,1),ZON(OBJ,I),[F:OATX]TEXTE
&              ,mess(200,115,1),[F:DATX]TEXTE,EXCEL,-1,DIF)
                # Fonction & intitulés différents
            Endif
        Else
            INTERM1 = num$(evalue("[F:AFC1]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
            INTERM2 = num$(evalue("[F:AFC2]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
            If INTERM1 <> INTERM2
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Gosub FORMAT_KT
                If K<>1
                    Call TRACE("AFC",[F:AFC1]CODINT,mess(149,123,1),ZON(OBJ,I)+"("+num$(J-1)+")",INTZON(OBJ,I),
&                   mess(201,115,1),mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                    # Fonction & Champ & Différence
                Else
                    Call TRACE("AFC",[F:AFC1]CODINT,mess(149,123,1),ZON(OBJ,I),INTZON(OBJ,I)
&                   ,mess(201,115,1),mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                    # Fonction & Champ & Différence
                Endif
            Endif
        Endif
    Next J
Next I
Return


########################################################################################
$COMP_ATY                                     #### TYPES DE DONNEES ####################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(19,125,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_ATY)+")",0) From GESECRAN       # Types de données
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_ATY
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
   # Type de donées inexistant
   Call TRACE("ATY","","","","","",mess(7,150,1),EXCEL,-1,DIF)
 Endif
 Return
Endif
Raz NBFIC
For COD="ATYPE","ATYPERUL","ATYPERPAR"
    Gosub TRT_ATABZON
    NBFIC+=1
Next

## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]ATYDEB="" & [M:ACMP]ATYFIN="ZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& CODTYP<'X'"
 Endif
Else
 CRITERE += "& CODTYP>=[M:ACMP]ATYDEB & CODTYP<=[M:ACMP]ATYFIN"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

For [F:ATY1]CODTYP Where evalue(CRITERE)
  If [M:ACMP]COPMOD(max([F:ATY1]MODULE-1,0)) = 2
    FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
    Gosub FILTRE_ATY From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
    If !OK Goto NEXT_ATY1: Endif        #X3PLAT-940 - Filter on activity code
    Filter [F:ATY2] Where [F:ATY2]CODTYP=[F:ATY1]CODTYP
    Read [F:ATY2] First
    If fstat
        Call TRACE("ATY",[F:ATY1]CODTYP,"","","",mess(87,100,1),mess(164,124,1)-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
        # Type de données inexistant sous
    Else
        Raz OK_C
        OBJ = 0 : Gosub TRT_ATY From ACOMPOBJ3
        For [ATYR1]ATYR0 Where CODTYP=[ATY1]CODTYP
              Read [ATYR2]ATYR0=[ATY1]CODTYP;[ATYR1]TYPRUL;[ATYR1]TRTRUL;[ATYR1]PRGRUL
              If fstat
                 OK_C = 1
                  If [M:ACMP]DETAIL<>2 : Break : Endif
                  Call TRACE("ATY",[ATY1]CODTYP,mess(87,140,1),num$([ATYR1]TYPRUL)-[ATYR1]TRTRUL,[ATYR1]PRGRUL,mess(88,140,1)
&               ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                  # regle
              Else
                  OBJ=1 : Gosub TRT_ATY From ACOMPOBJ3
                  For [ATYRP1]ATYRP0 Where CODTYP=[ATY1]CODTYP & TYPRUL=[ATYR1]TYPRUL & TRTRUL=[ATYR1]TRTRUL & PRGRUL=[ATYR1]PRGRUL
                      Read [ATYRP2]ATYRP0=[ATYRP1]CODTYP;[ATYRP1]TYPRUL;[ATYRP1]TRTRUL;[ATYRP1]PRGRUL;[ATYRP1]PARCOD
                      If fstat
                        Call TRACE("ATY",[ATY1]CODTYP,mess(143,105,1),num$([ATYR1]TYPRUL)-[ATYR1]TRTRUL-[ATYR1]PRGRUL,[ATYRP1]PARCOD,mess(11,133,1)
&                       ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                       # aty & Paramètre & inexistant sous
                      Else
                          OBJ = 2 : Gosub TRT_ATY From ACOMPOBJ3
                      Endif
                 Next ATYRP1
             Endif
        Next ATYR1
      ################# DES ver ORG
        For [ATYR2]ATYR0 Where CODTYP=[ATY1]CODTYP
              Read [ATYR1]ATYR0=[ATY1]CODTYP;[ATYR2]TYPRUL;[ATYR2]TRTRUL;[ATYR2]PRGRUL
              If fstat
                 OK_C = 1
                  If [M:ACMP]DETAIL<>2 : Break : Endif
                  Call TRACE("ATY",[ATY1]CODTYP,mess(87,140,1),num$([ATYR2]TYPRUL)-[ATYR2]TRTRUL,[ATYR2]PRGRUL,mess(88,140,1)
&               ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                  # regle
              Else
                  For [ATYRP2]ATYRP0 Where CODTYP=[ATY1]CODTYP & TYPRUL=[ATYR2]TYPRUL & TRTRUL=[ATYR2]TRTRUL & PRGRUL=[ATYR2]PRGRUL
                      Read [ATYRP1]ATYRP0=[ATYRP1]CODTYP;[ATYRP2]TYPRUL;[ATYRP2]TRTRUL;[ATYRP2]PRGRUL;[ATYRP2]PARCOD
                      If fstat
                        Call TRACE("ATY",[ATY1]CODTYP,mess(143,105,1),[ATYR2]TRTRUL-[ATYR2]PRGRUL,[ATYRP2]PARCOD,mess(11,133,1)
&                       ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                       # aty & Paramètre & inexistant sous
                      Endif
                 Next ATYRP2
             Endif
        Next ATYR2
        If [M:ACMP]DETAIL=2
            If !OK_C & !TOUT & !EXCEL
                Call TRACE("ATY",[F:ATY1]CODTYP,"","","","",mess(127,126,1),EXCEL,0,DIF)
                # Type identique
            Endif
        Else
            If OK_C=1
                Call TRACE("ATY",[F:ATY1]CODTYP,"","","",mess(3,55,1),mess(164,124,1)-mess(3,55,1),EXCEL,-1,DIF)
                # Type de données différent
                If PATCH : Call PATCH("ATY",[F:ATY1]CODTYP,"") : Endif
            Endif
        Endif
    Endif
    Filter [F:ATY2]
  Endif
$NEXT_ATY1                    #X3PLAT-940 - Filter on activity code
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:ATY2]CODTYP Where evalue(CRITERE)
  If [M:ACMP]COPMOD(max([F:ATY2]MODULE-1,0)) = 2
    FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
    Gosub FILTRE_ATY From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
    If !OK Goto NEXT_ATY2 : Endif       #X3PLAT-940 - Filter on activity code

    Read [F:ATY1]CODTYP=[F:ATY2]CODTYP
    If fstat
        OK_C = 1
        Call TRACE("ATY",[F:ATY2]CODTYP,"","","",mess(87,100,1),mess(164,124,1)-mess(3,55,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
        # Type de données inexistant sous "
    Endif
  Endif
$NEXT_ATY2  # X3PLAT-940 - Filter on activity code
Next
Return

#############################
$TRT_ACT
If OBJ=0 : AOBJ="ACT" : Endif
If OBJ=1 : AOBJ="ATR" : Endif

For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    For J=1 To K
        If TYP(OBJ,I) = "ATX"
            Read [OATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:OATX]TEXTE="" : Endif
            Read [DATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:DATX]TEXTE="" : Endif
            If [F:OATX]TEXTE <> [F:DATX]TEXTE
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                If OBJ=0
                    If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
                    Call TRACE("ACT",[F:ACT1]ACTION,mess(149,123,1),ZON(OBJ,I),INTZON(OBJ,I),mess(200,115,1)
&                   ,MESSTECH-[F:OATX]TEXTE-[F:DATX]TEXTE,EXCEL,-1,DIF)
                    # Table & Champ & Différence
                Else
                    If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
                    Call TRACE("ACT",[F:ACT1]ACTION,mess(1,89,1),[F:ATR1]CODPAR,INTZON(OBJ,I),mess(200,115,1)
&                   ,MESSTECH-[F:OATX]TEXTE-[F:DATX]TEXTE,EXCEL,-1,DIF)
                    # Table & Champ & Différence
                Endif
            Endif
        Else
            INTERM1=num$(evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)))
            INTERM2=num$(evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)))
            If INTERM1 <> INTERM2
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Gosub FORMAT_KT
                If OBJ=0
                    If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
                    Call TRACE("ACT",[F:ACT1]ACTION,mess(149,123,1),ZON(OBJ,I),INTZON(OBJ,I),mess(201,115,1)
&                   ,MESSTECH-mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                    # Action & Champ & Différence
                Else
                    If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
                    Call TRACE("ACT",[F:ACT1]ACTION,mess(1,89,1),[F:ATR1]CODPAR,INTZON(OBJ,I),mess(201,115,1)
&                   ,mess(81,126,1)-MESSTECH-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                    # Action & Champ & Différence
                Endif
            Endif
        Endif
    Next J
Next I
Return

########################################################################################
$COMP_ATB                                         #### TABLES  ########################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(16,125,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_ATB)+")",0) From GESECRAN    # Tables
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_ATB
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
   # Table inexistante
   Call TRACE("ATB","","","","","",mess(124,124,1),EXCEL,-1,DIF)
 Endif
 Return
Endif
Raz NBFIC
For COD="ATABLE","ATABZON","ATABIND","AMSKACT","AMSKPAR"
    Gosub TRT_ATABZON
    NBFIC +=1
Next
## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]ATBDEB="" & [M:ACMP]ATBFIN="ZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& CODFIC<'X'"
 Endif
Else
 CRITERE += "& CODFIC>=[M:ACMP]ATBDEB & CODFIC<=[M:ACMP]ATBFIN"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif


For [F:ATB1]CODFIC Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ATB1]MODULE-1,0)) = 2
        FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_ATB From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_ATB1: Endif        #X3PLAT-940 - Filter on activity code
        Read [F:ATB2]CODFIC=[F:ATB1]CODFIC
        If fstat
            Call TRACE("ATB",[F:ATB1]CODFIC,"","","",mess(87,100,1),mess(56,123,1)-mess(82,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
            # Table inexistante sous
        Else
            Raz OK_C
            OBJ=0 : Gosub TRT_ATB
            ## Traitement des paramètres de ORG --> DES
            For [F:ATZ1]CODZONE Where [F:ATZ1]CODFIC=[F:ATB1]CODFIC
                Read [ATZ2]CODZONE=[F:ATZ1]CODFIC;[F:ATZ1]CODZONE
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [F:OATX]NUMERO=GLANGUE;[F:ATZ1]NOCOURT
                    If fstat : [F:OATX]TEXTE="" : Endif
                    Call TRACE("ATB",[F:ATB1]CODFIC,mess(149,123,1),[F:ATZ1]CODZONE,[F:OATX]TEXTE,mess(41,100,1)
&                   ,mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                    # Table & Champ & inexistant sous
                Else
                    OBJ=1 : Gosub TRT_ATB
                    For [AMP1]CODPAR Where [F:AMP1]TYPAFF = 2
&                                        & [F:AMP1]CODAFF = [F:ATB1]CODFIC
&                                        & [F:AMP1]CODZON = [F:ATZ1]CODZONE
                        Read [F:AMP2]CODPAR=[F:AMP1]TYPAFF;[F:AMP1]CODAFF;[F:AMP1]CODZON;[F:AMP1]CODPAR
                        If fstat
                          Call TRACE("ATB",[F:ATB1]CODFIC,mess(149,123,1),[F:ATZ1]CODZONE,[F:AMP1]CODPAR,mess(11,133,1)
&                         ,mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                         # Table & Paramètre & inexistant sous
                        Else
                            OBJ = 4 : Gosub TRT_ATB
                        Endif
                    Next AMP1
                    For [AMA1]TYPAFF Where [F:AMA1]TYPAFF = 2
&                                        & [F:AMA1]CODAFF = [F:ATB1]CODFIC
&                                        & [F:AMA1]CODZON = [F:ATZ1]CODZONE
                        Filter [F:AMA2]Where [F:AMA2]TYPAFF = [F:AMA1]TYPAFF
&                                          & [F:AMA2]CODAFF = [F:AMA1]CODAFF
&                                          & [F:AMA2]CODZON = [F:AMA1]CODZON
&                                          & [F:AMA2]TYPACT = [F:AMA1]TYPACT
&                                          & [F:AMA2]ACTION = [F:AMA1]ACTION
                        Read [F:AMA2]First
                        If fstat
                            OK_C = 1
                            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
                            Read [F:OATX]NUMERO=GLANGUE;[F:AMZ1]INTIT
                            If fstat : [F:OATX]TEXTE="" : Endif
                            Call TRACE("ATB",[F:ATB1]CODFIC,mess(149,123,1),[F:ATZ1]CODZONE,[F:OATX]TEXTE,mess(84,133,1)
&                           ,mess([F:AMA1]TYPACT,31,1)-[F:AMA1]ACTION-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                            # Action inexistante
                        Else
                            OBJ = 3 : Gosub TRT_ATB
                        Endif
                        Filter [AMA2]
                    Next AMA1
                Endif
            Next
            For [F:ATI1]CODIND Where [F:ATI1]CODFIC=[F:ATB1]CODFIC
               Read [ATI2]CODIND=[F:ATI1]CODFIC;[F:ATI1]CODIND
               If fstat
                   OK_C = 1
                   If [M:ACMP]DETAIL<>2 : Break : Endif
                   Call TRACE("ATB",[F:ATB1]CODFIC,mess(10,176,1),[F:ATI1]CODIND,"",mess(207,115,1)
&                  ,mess(10,176,1)-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                   # Table &  Index & inexistant sous
               Else
                   OBJ=2 : Gosub TRT_ATB
               Endif
            Next
            ## Traitement des paramètres de DES --> ORG
            For [F:ATZ2]CODZONE Where [F:ATZ2]CODFIC=[F:ATB1]CODFIC
                Read [ATZ1]CODZONE=[F:ATZ2]CODFIC;[F:ATZ2]CODZONE
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [F:DATX]NUMERO=GLANGUE;[F:ATZ2]NOCOURT
                    If fstat : [F:DATX]TEXTE="" : Endif
                    Call TRACE("ATB",[F:ATB1]CODFIC,mess(149,123,1),[F:ATZ2]CODZONE,[F:DATX]TEXTE,mess(41,100,1)
&                   ,mess(1,89,1)-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                    # Table & Champ & inexistant sous
                Else
                    For [AMP2]CODPAR Where [F:AMP2]TYPAFF = 2
&                                        & [F:AMP2]CODAFF = [F:ATB1]CODFIC
&                                        & [F:AMP2]CODZON = [F:ATZ2]CODZONE
                        Read [AMP1]CODPAR=[F:AMP2]TYPAFF;[F:AMP2]CODAFF;[F:AMP2]CODZON;[F:AMP2]CODPAR
                        If fstat
                          Call TRACE("ATB",[F:ATB1]CODFIC,mess(149,123,1),[F:ATZ2]CODZONE,[F:AMP2]CODPAR,mess(11,133,1)
&                         ,mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                         # Table & Paramètre & inexistant sous
                        Endif
                    Next AMP2
                    For [AMA2]TYPAFF Where [F:AMA2]TYPAFF = 2
&                                        & [F:AMA2]CODAFF = [F:ATB1]CODFIC
&                                        & [F:AMA2]CODZON = [F:ATZ2]CODZONE
                        Filter [F:AMA1]Where [F:AMA1]TYPAFF = [F:AMA2]TYPAFF
&                                          & [F:AMA1]CODAFF = [F:AMA2]CODAFF
&                                          & [F:AMA1]CODZON = [F:AMA2]CODZON
&                                          & [F:AMA1]TYPACT = [F:AMA2]TYPACT
&                                          & [F:AMA1]ACTION = [F:AMA2]ACTION
                        Read [AMA1]First
                        If fstat
                            OK_C = 1
                            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
                            Read [DATX]NUMERO=GLANGUE;[F:AMZ2]INTIT
                            If fstat : [F:DATX]TEXTE="" : Endif
                            Call TRACE("ATB",[F:ATB1]CODFIC,mess(149,123,1),[F:ATZ2]CODZONE,[F:DATX]TEXTE,mess(84,133,1)
&                           ,mess([F:AMA2]TYPACT,31,1)-[F:AMA2]ACTION-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                            # Action inexistante
                        Endif
                        Filter [AMA1]
                    Next AMA2
                Endif
            Next
            For [F:ATI2]CODIND Where [F:ATI2]CODFIC=[F:ATB1]CODFIC
               Read [ATI1]CODIND=[F:ATI2]CODFIC;[F:ATI2]CODIND
               If fstat
                   OK_C = 1
                   If [M:ACMP]DETAIL<>2 : Break : Endif
                   Call TRACE("ATB",[F:ATB1]CODFIC,mess(10,176,1),[F:ATI2]CODIND,"",mess(207,115,1)
&                  ,mess(10,176,1)-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                   # Table & Index & inexistant sous
               Endif
            Next
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                    Call TRACE("ATB",[F:ATB1]CODFIC,"","","","",mess(87,126,1),EXCEL,0,DIF)
                    # Table identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("ATB",[F:ATB1]CODFIC,"","","",mess(3,55,1),mess(56,123,1)-mess(90,126,1),EXCEL,-1,DIF)
                    # Table différente
                    If PATCH : Call PATCH("ATB",[F:ATB1]CODFIC,"") : Endif
                Endif
            Endif
        Endif
    Endif
$NEXT_ATB1                    #X3PLAT-940 - Filter on activity code
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:ATB2]CODFIC Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ATB2]MODULE-1,0)) = 2
      FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
      Gosub FILTRE_ATB From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
      If !OK Goto NEXT_ATB2 : Endif       #X3PLAT-940 - Filter on activity code

        Read [F:ATB1]CODFIC=[F:ATB2]CODFIC
        If fstat
            Call TRACE("ATB",[F:ATB2]CODFIC,"","","",mess(87,100,1),mess(56,123,1)-mess(82,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
            # Table inexistante sous
        Endif
    Endif
$NEXT_ATB2  # X3PLAT-940 - Filter on activity code
Next
Return

#############################
$TRT_ATB
If OBJ=4 : AOBJ="AMP" : Endif
If OBJ=3 : AOBJ="AMA" : Endif
If OBJ=0 : AOBJ="ATB" : Endif
If OBJ=2 : AOBJ="ATI" : Endif
If OBJ=1 : AOBJ="ATZ" : Endif
If OBJ<>0
    Read [F:OATX]NUMERO=GLANGUE;[F:ATZ1]NOLONG
    If fstat : LIBEL="" Else LIBEL=[F:OATX]TEXTE : Endif
Endif
For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    If OBJ=3 and find(ZON(OBJ,I),"NOACT") : K=0 : Endif
    For J=1 To K
    If TYP(OBJ,I) = "ATX" & evalue("dim(["+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
        Read [OATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:OATX]TEXTE="" : Endif
        Read [DATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:DATX]TEXTE="" : Endif
        If [F:OATX]TEXTE <> [F:DATX]TEXTE
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
            If OBJ<>0
               Call TRACE("ATB",[F:ATB1]CODFIC,mess(149,123,1),[F:ATZ1]CODZONE,[F:OATX]TEXTE,mess(200,115,1)
&              ,MESSTECH-[F:OATX]TEXTE-"<>"-[F:DATX]TEXTE,EXCEL,-1,DIF)
               # Table & Champ & Intitulés différents
            Else
               Call TRACE("ATB",[F:ATB1]CODFIC,mess(82,123,1),"",[F:OATX]TEXTE,mess(200,115,1)
&              ,MESSTECH-[F:OATX]TEXTE-"<>"-[F:DATX]TEXTE,EXCEL,-1,DIF)
               # Table & Intitulés différents
            Endif
        Endif
    Else
        Raz INTERM1 , INTERM2
        If evalue("dim([F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
         INTERM1 = num$(evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        Endif
        If evalue("dim([F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
         INTERM2 = num$(evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        Endif
        If INTERM1 <> INTERM2
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break : Endif
            Gosub FORMAT_KT
            If OBJ=0
                If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
                Call TRACE("ATB",[F:ATB1]CODFIC,mess(1,89,1),ZON(OBJ,I),INTZON(OBJ,I),mess(201,115,1)
&               ,MESSTECH-mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                # Table & Champ & Différence
            Elsif OBJ=1
                If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
                Call TRACE("ATB",[F:ATB1]CODFIC,mess(1,89,1),[F:ATZ1]CODZONE,[F:OATX]TEXTE,mess(201,115,1)
&               ,MESSTECH-mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                # Table & Champ & Différence
            Elsif OBJ=2
                If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
                Call TRACE("ATB",[F:ATB1]CODFIC,mess(10,176,1),[F:ATI1]CODIND,INTZON(OBJ,I),mess(201,115,1)
&               ,MESSTECH-mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                # Table & Index & Différence
            Elsif OBJ=3
               If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
               Call TRACE("ATB",[F:ATB1]CODFIC,mess(149,123,1),[F:ATZ1]CODZONE,LIBEL,mess(202,115,1),[F:AMA1]ACTION
&              -mess([F:AMA1]TYPACT,31,1)-MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
               # Ecran & Champ & Action & Différence
            Else
               If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
               Call TRACE("ATB",[F:ATB1]CODFIC,mess(149,123,1),[F:ATZ1]CODZONE,LIBEL,mess(203,115,1)
&              ,[F:AMP1]CODPAR-MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
               # Ecran & Champ & Paramètre & Différence
            Endif
        Endif
    Endif
    Next J
Next I
Return

########################################################################################
$COMP_ADI                                  #### TABLES DIVERSES ########################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(2,26,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_ADI)+")",0) From GESECRAN       # Tables diverses
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_ADI
   If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
    # Table inexistante
    Call TRACE("ADI","","","","","",mess(124,124,1),EXCEL,-1,DIF)
   Endif
   Return
Endif
Raz NBFIC
For COD="ATABDIV"
    Gosub TRT_ATABZON
    NBFIC+=1
Next
## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]ADIDEB=0 & [M:ACMP]ADIFIN=9999
 TOUT = 1
Else
 CRITERE += "& NUMTAB>=[M:ACMP]adideb & NUMTAB<=[M:ACMP]adifin"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

For [F:ADI1]CODE(1) Where evalue(CRITERE)
  Read [ADV1]CODE = [F:ADI1]NUMTAB
  If [M:ACMP]COPMOD(max([F:ADV1]MODULE-1,0)) = 2
    FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
    Gosub FILTRE_ADI From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
    If !OK Goto NEXT_ADI1: Endif        #X3PLAT-940 - Filter on activity code
    Filter [F:ADI2] Where [F:ADI2]NUMTAB=[F:ADI1]NUMTAB
    Read [F:ADI2] First
    If fstat
        Call TRACE("ADI",num$([F:ADI1]NUMTAB),"","","",mess(87,100,1),mess(56,123,1)-mess(82,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
        # Table inexistante sous
    Else
        Raz OK_C
        ## Traitement des paramètres de ORG --> DES
        For [F:ADI1]CODE(2)
            Read [F:ADI2]CODE=[F:ADI1]NUMTAB;[F:ADI1]CODE
            If fstat
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Call TRACE("ADI",num$([F:ADI1]NUMTAB),mess(37,100,1),[F:ADI1]CODE,"",mess(84,141,1)
&               ,mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                # Table Code inexistant sous
            Else
                Gosub TRT_ADI
            Endif
        Next
        ## Traitement des paramètres de DES --> ORG
        For [F:ADI2]CODE(2)
            Read [F:ADI3]CODE=[F:ADI2]NUMTAB;[F:ADI2]CODE
            If fstat
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Call TRACE("ADI",num$([F:ADI1]NUMTAB),mess(37,100,1),[F:ADI2]CODE,"",mess(84,141,1)
&               ,mess(37,100,1)-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                # Table Code inexistant sous
            Endif
        Next
        If [M:ACMP]DETAIL=2
            If !OK_C & !TOUT & !EXCEL
                Call TRACE("ADI",num$([F:ADI1]NUMTAB),"","","","",mess(87,126,1),EXCEL,0,DIF)
                # Table identique
            Endif
        Else
            If OK_C=1
                Call TRACE("ADI",num$([F:ADI1]NUMTAB),"","","",mess(3,55,1),mess(56,123,1)-mess(90,126,1),EXCEL,-1,DIF)
                # Table différente
                If PATCH : Call PATCH("ADI",num$([F:ADI1]NUMTAB),"") : Endif
            Endif
        Endif
    Endif
    Filter [F:ADI2]
  Endif
$NEXT_ADI1                    #X3PLAT-940 - Filter on activity code
Next
Filter [F:ADI1]
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
Filter [F:ADI2] Where [F:ADI2]NUMTAB>=[M:ACMP]ADIDEB & [F:ADI2]NUMTAB<=[M:ACMP]ADIFIN
For [F:ADI2]CODE(1)
  Read [ADV1]CODE = [F:ADI2]NUMTAB
  If [M:ACMP]COPMOD(max([F:ADV1]MODULE-1,0)) = 2
    FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
    Gosub FILTRE_ADI From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
    If !OK Goto NEXT_ADI2 : Endif       #X3PLAT-940 - Filter on activity code
    Read [F:ADI1]CODE(1)=[F:ADI2]NUMTAB
    If fstat
        Call TRACE("ADI",num$([F:ADI2]NUMTAB),"","","",mess(87,100,1),mess(56,123,1)-mess(82,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
        # Table inexistante sous
    Endif
  Endif
$NEXT_ADI2  # X3PLAT-940 - Filter on activity code
Next
Filter [F:ADI2]
Return

#############################
$TRT_ADI
OBJ=0
For I=1 To NBRZON(OBJ)
    If find(TYP(OBJ,I),"AXX","AX1","AX2","AX3")
        Read [OAXT]AXX0=COD;ZON(OBJ,I);GLANGUE;num$([F:ADI1]NUMTAB);[F:ADI1]CODE
        If fstat : [F:OAXT]TEXTE="" : Endif
        Read [DAXT]AXX0=COD;ZON(OBJ,I);GLANGUE;num$([F:ADI2]NUMTAB);[F:ADI2]CODE
        If fstat : [F:DAXT]TEXTE="" : Endif
        If [F:OAXT]TEXTE <> [F:DAXT]TEXTE
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break : Endif
            Call TRACE("ADI",num$([F:ADI1]NUMTAB),mess(37,100,1),[F:ADI1]CODE,[F:OAXT]TEXTE,mess(200,115,1)
&           ,mess(37,100,1)-mess(81,126,1)-[F:DAXT]TEXTE,EXCEL,-1,DIF)
            # Table & Code & Différence
        Endif
    Else
        If evalue("[F:ADI1]"+ZON(OBJ,I)) <> evalue("[F:ADI2]"+ZON(OBJ,I))
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break : Endif
            Call TRACE("ADI",num$([F:ADI1]NUMTAB),mess(37,100,1),[F:ADI1]CODE,num$(evalue("[F:ADI1]"+ZON(OBJ,I)))
&           -num$(evalue("[F:ADI2]"+ZON(OBJ,I))),mess(201,115,1),mess(81,126,1)-mess(17,115,1)-ZON(OBJ,I),EXCEL,-1,DIF)
            # Table & Champs différent & Différence
        Endif
    Endif
Next I
Return


########################################################################################
$COMP_AST                      #### MESSAGES AVEC SELECTION D'UNE LANGUE ###############
########################################################################################
## Entete de comparaison
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(201,124,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_AST)+")",0) From GESECRAN    # Messages
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_AST
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
   Call TRACE("AML","","","","","",mess(201,124,1)-mess(87,100,1),EXCEL,-1,DIF) :   # Message Inexistant
 Endif
 Return
Endif

Raz NBFIC
For COD="AMENLOC"
    Gosub TRT_ATABZON
    NBFIC+=1
Next

## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]ASTDEB=0 & [M:ACMP]ASTFIN=9999
 TOUT = 1
Else
 CRITERE += "& LANCHP>=[M:ACMP]ASTDEB & LANCHP<=[M:ACMP]ASTFIN"
Endif
CRITERE += "& LAN=[M:ACMP]LANGUE"
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

For [F:AST1]CLE(1) Where evalue(CRITERE)
  OK = 1
  If [F:AST1]LANCHP<>0 & [F:AST1]LANCHP<>200
   FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
   Gosub FILTRE_AST From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
   If !OK Goto NEXT_AST1: Endif        #X3PLAT-940 - Filter on activity code
   Read [AML1]MENLOC = [F:AST1]LANCHP
   If fstat
    Call TRACE("AML",num$([F:AST1]LANCHP),"","","",mess(208,115,1),"",EXCEL,-1,DIF)
    OK = 0
   Elsif [F:AML1]MODULE=0
    Call TRACE("AML",num$([F:AST1]LANCHP),"","","",mess(132,124,1),"",EXCEL,-1,DIF)
    # M module incorrect
   Elsif [M:ACMP]COPMOD(max([F:AML1]MODULE-1,0))<>2
    OK = 0
   Endif
  Endif
  If OK
    Read [AML2]MENLOC=[F:AST1]LANCHP
    If !fstat
     Gosub TRT_AST
    Endif
    Filter [F:AST2] Where [F:AST2]LANCHP=[F:AST1]LANCHP and [F:AST2]LAN=[F:AST1]LAN
    Read [F:AST2] First
    If fstat
        Call TRACE("AML",num$([F:AST1]LANCHP),mess(11,151,1),[F:AST1]LAN,[F:AST1]LANMES,mess(208,115,1)
&       ,mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
        # Langue & Chapitre inexistant sous
    Else
        Raz OK_C
        ## Traitement des paramètres de ORG --> DES
        For [F:AST1]CLE(2)
            Read [F:AST2]CLE = [F:AST1]LANCHP;[F:AST1]LANNUM;[F:AST1]LAN
            If fstat
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Call TRACE("AML",num$([F:AST1]LANCHP),mess(201,124,1),num$([F:AST1]LANNUM),[F:AST1]LANMES,mess(209,115,1)
&               ,[F:AST1]LAN-mess(201,124,1)-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                # Langue & Chapitre & Message inexistant sous
            Else
                If vireblc([F:AST1]LANMES,2) <> vireblc([F:AST2]LANMES,2)
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("AML",num$([F:AST1]LANCHP),mess(201,124,1),num$([F:AST1]LANNUM),[F:AST1]LANMES,mess(210,115,1)
&                   ,[F:AST1]LAN-mess(81,126,1)-[F:AST2]LANMES,EXCEL,-1,DIF)
                    # Langue & Chapitre & Message & Différence
                Endif
            Endif
        Next
        ## Traitement des paramètres de ORG --> DES
        For [F:AST2]CLE(2)
            Read [F:AST3]CLE = [F:AST2]LANCHP;[F:AST2]LANNUM;[F:AST2]LAN
            If fstat
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Call TRACE("AML",num$([F:AST1]LANCHP),mess(201,124,1),num$([F:AST2]LANNUM),[F:AST2]LANMES,mess(209,115,1)
&              ,[F:AST1]LAN-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                # Langue & Chapitre & Message inexistant sous
            Endif
        Next

        If [M:ACMP]DETAIL=2
            If !OK_C & !TOUT & !EXCEL
                Call TRACE("AML",num$([F:AST1]LANCHP),mess(11,151,1),[F:AST1]LAN,"","",mess(86,126,1),EXCEL,0,DIF)
                # Langue & Chapitre identique
            Endif
        Else
            If OK_C=1
                Call TRACE("AML",num$([F:AST1]LANCHP),mess(11,151,1),[F:AST1]LAN,"",mess(3,55,1)
&               ,mess(78,100,1)-mess(3,55,1),EXCEL,-1,DIF)
                # Langue & Chapitre différent
                If PATCH : Call PATCH("AML",num$([F:AST1]LANCHP),"") : Endif
            Endif
        Endif
    Endif
    Filter [F:AST2]
  Endif
$NEXT_AST1                    #X3PLAT-940 - Filter on activity code
Next

## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:AST2]CLE(1) Where evalue(CRITERE)
  If [F:AST2]LANCHP<>0 & [F:AST2]LANCHP<>200
    #X3PLAT-940 - Filter on activity code - AMENLOC has the activity code
    FILTRE_STEP=2
    Gosub FILTRE_AST From ACOMPOBJ3
    If !OK Goto NEXT_AST2 : Endif

    OK = 1
      Read [AML1]MENLOC = [F:AST2]LANCHP
    If fstat
     Call TRACE("AML",num$([F:AST1]LANCHP),"","","",mess(208,115,1),"",EXCEL,-1,DIF)
     OK = 0
    Elsif [F:AML1]MODULE=0
      Call TRACE("AML",num$([F:AST2]LANCHP),"","","","",mess(132,124,1),EXCEL,-1,DIF)
    Elsif [M:ACMP]COPMOD(max([F:AML1]MODULE-1,0))<>2
      OK = 0
    Endif
  Endif
  If OK
    Filter [F:AST1] Where [F:AST1]LANCHP=[F:AST2]LANCHP and [F:AST1]LAN=[F:AST2]LAN
    Read [F:AST1] First
    If fstat
        Call TRACE("AML",num$([F:AST2]LANCHP),mess(11,151,1),[F:AST2]LAN,"",mess(208,115,1)
&        ,mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
        # Langue & Chapitre inexistant sous
    Endif
  Endif
$NEXT_AST2  # X3PLAT-940 - Filter on activity code
Next
Return

#############################
$TRT_AST
OBJ=0
For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    For J=1 To K
            INTERM1 = num$(evalue("[F:AML1]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
            INTERM2 = num$(evalue("[F:AML2]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
            If INTERM1 <> INTERM2
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Gosub FORMAT_KT
                If K<>1
                    Call TRACE("AML",num$([F:AML1]MENLOC),mess(149,123,1),ZON(OBJ,I)+"("+num$(J-1)+")",INTZON(OBJ,I)
&                   ,mess(201,115,1),mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                    # Chapitre & Champ & Différence
                Else
                    Call TRACE("AML",num$([F:AML1]MENLOC),mess(149,123,1),ZON(OBJ,I),INTZON(OBJ,I)
&                   ,mess(201,115,1),mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                    # Chapitre & Champ & Différence
                Endif
            Endif
    Next J
Next I
Return

########################################################################################
$COMP_AST_TOT             #### TOTAL DES MESSAGES, PAS DE SELECTION D'UNE LANGUE #######
########################################################################################
## Entete de comparaison
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(201,124,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_AST)+")",0) From GESECRAN    # Messages
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_AST
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
  Call TRACE("AML","","","","","",mess(201,124,1)-mess(87,100,1),EXCEL,-1,DIF) :  # Message Inexistant
 Endif
 Return
Endif

Raz NBFIC
For COD="AMENLOC"
    Gosub TRT_ATABZON
    NBFIC+=1
Next

## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]ASTDEB=0 & [M:ACMP]ASTFIN=9999
 TOUT = 1
Else
 CRITERE += "& LANCHP>=[M:ACMP]ASTDEB & LANCHP<=[M:ACMP]ASTFIN"
Endif
For [F:AST1] Where evalue(CRITERE)
  FILTRE_STEP=1
  Gosub FILTRE_AST_TOT From ACOMPOBJ3
  If !OK Goto NEXT_AST1 : Endif

  Read [AML1]MENLOC = [F:AST1]LANCHP
  Read [AML2]MENLOC=[F:AST1]LANCHP
  If !fstat
   Gosub TRT_AST
  Endif
  If [M:ACMP]COPMOD(max([F:AML1]MODULE-1,0)) = 2
    Read [F:AST2]CLE = [F:AST1]LANCHP;[F:AST1]LANNUM;[F:AST1]LAN
    If fstat
        Call TRACE("AML",num$([F:AST1]LANCHP),mess(201,124,1),num$([F:AST1]LANNUM),"",mess(209,115,1)
&       ,[F:AST1]LAN-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
        # Langue & Chapitre & Message inexistant sous
    Else
       If vireblc([F:AST1]LANMES,2) <> vireblc([F:AST2]LANMES,2)
            Call TRACE("AML",num$([F:AST1]LANCHP),mess(201,124,1),num$([F:AST1]LANNUM),"",mess(210,115,1)
&           ,[F:AST1]LAN-mess(81,126,1)-[F:AST1]LANMES-[F:AST2]LANMES,EXCEL,-1,DIF)
            # Langue & Chapitre & Message & Différence
       Endif
    Endif
  Endif
Next
Return

########################################################################################
$COMP_ARP                                     #### ETATS            ####################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(1,92,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_ARP)+")",0) From GESECRAN       # Etats
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_ARP
  If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
    # Etat inexistant
    Call TRACE("ARP","","","","","",mess(163,123,1),EXCEL,-1,DIF)
  Endif
  Return
Endif
Raz NBFIC
For COD="AREPORT","AREPORTD"
    Gosub TRT_ATABZON
    NBFIC+=1
Next
## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]ARPDEB="" & [M:ACMP]ARPFIN="ZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& RPTCOD<'X'"
 Endif
Else
 CRITERE += "& RPTCOD>=[M:ACMP]ARPDEB & RPTCOD<=[M:ACMP]ARPFIN"
Endif
If [M:ACMP]LANGUE<>""
 CRITERE += "& LAN=[M:ACMP]LANGUE"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

For [F:ARP1]ARP0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ARP1]MODULE-1,0)) = 2
       FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
       Gosub FILTRE_ARP From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
       If !OK Goto NEXT_ARP1: Endif        #X3PLAT-940 - Filter on activity code
        Read [F:ARP2]ARP0=[F:ARP1]RPTCOD
        If fstat
            Call TRACE("ARP",[F:ARP1]RPTCOD,"","","",mess(87,100,1),mess(22,104,1)-mess(82,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
            # Etat inexistant sous "
        Else
            Raz OK_C
            OBJ=0 : Gosub TRT_ARP
            ## Traitement des lignes d'état de ORG --> DES
            For [F:ARD1]ARD0 Where [F:ARD1]RPTCOD=[F:ARP1]RPTCOD
                Read [ARD2]ARD0=[F:ARD1]RPTCOD;[F:ARD1]PARNUM
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("ARP",[F:ARP1]RPTCOD,mess(143,105,1),[F:ARD1]PARCOD,"",mess(11,133,1)
&                   ,mess(81,123,1)-mess(79,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
                    # état & parametre inexistant sous
                Else
                    OBJ=1 : Gosub TRT_ARP
                Endif
            Next
            ## Traitement des lignes d'état de DES --> ORG
            For [F:ARD2]ARD0 Where [F:ARD2]RPTCOD=[F:ARP1]RPTCOD
                Read [ARD1]ARD0=[F:ARD2]RPTCOD;[F:ARD2]PARNUM
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("ARP",[F:ARP1]RPTCOD,mess(143,105,1),[F:ARD2]PARCOD,"",mess(11,133,1)
&                   ,mess(81,123,1)-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
                    # état & parametre inexistant sous
                Else
                    OBJ=1 : Gosub TRT_ARP
                Endif
            Next
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                    Call TRACE("ARP",[F:ARP1]RPTCOD,"","","","",mess(205,126,1),EXCEL,0,DIF)
                    # Etat identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("ARP",[F:ARP1]RPTCOD,"","","",mess(3,55,1),mess(147,115,1),EXCEL,-1,DIF)
                    # Etat différent
                    If PATCH : Call PATCH("ARP",[F:ARP1]RPTCOD,"") : Endif
                Endif
            Endif
        Endif
    Endif
$NEXT_ARP1                    #X3PLAT-940 - Filter on activity code
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:ARP2]ARP0 Where evalue(CRITERE)
  If [M:ACMP]COPMOD(max([F:ARP2]MODULE-1,0)) = 2
    FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
    Gosub FILTRE_ARP From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
    If !OK Goto NEXT_ARP2 : Endif       #X3PLAT-940 - Filter on activity code

    Read [F:ARP1]ARP0=[F:ARP2]RPTCOD
    If fstat
        Call TRACE("ARP",[F:ARP2]RPTCOD,"","","",mess(87,100,1),mess(22,104,1)-mess(79,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
        # Etat inexistant sous
    Endif
  Endif
$NEXT_ARP2  # X3PLAT-940 - Filter on activity code
Next
Return

$TRT_ARP
If OBJ=0 : AOBJ="ARP" : Endif
If OBJ=1 : AOBJ="ARD" : Endif

For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    For J=1 To K
        If TYP(OBJ,I) = "ATX"
            Read [OATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:OATX]TEXTE="" : Endif
            Read [DATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:DATX]TEXTE="" : Endif
            If [F:OATX]TEXTE <> [F:DATX]TEXTE
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                If OBJ=0
                    If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
                    Call TRACE("ARP",[F:ARP1]RPTCOD,mess(1,89,1),ZON(OBJ,I),INTZON(OBJ,I)
&                   ,mess(200,115,1),MESSTECH-[F:OATX]TEXTE-"<>"-[F:DATX]TEXTE,EXCEL,-1,DIF)
                    # Etat & Champ & Différence
                Else
                    If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
                    Call TRACE("ARP",[F:ARP1]RPTCOD,mess(1,89,1),[F:ARD1]PARCOD,INTZON(OBJ,I)
&                   ,mess(200,115,1),MESSTECH-[F:OATX]TEXTE-"<>"-[F:DATX]TEXTE,EXCEL,-1,DIF)
                    # Etat & Champ & Différence
                Endif
            Endif
        Else
            INTERM1=num$(evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)))
            INTERM2=num$(evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)))
            If INTERM1 <> INTERM2
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Gosub FORMAT_KT
                If OBJ=0
                    If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
                    Call TRACE("ARP",[F:ARP1]RPTCOD,mess(1,89,1),ZON(OBJ,I),INTZON(OBJ,I)
&                   ,mess(201,115,1),MESSTECH-mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                    # Action & Champ & Différence
                Else
                    If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
                    Call TRACE("ARP",[F:ARP1]RPTCOD,mess(1,89,1),[F:ARD1]PARCOD,INTZON(OBJ,I)
&                   ,mess(201,115,1),MESSTECH-mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                    # Etat & Champ & Différence
                Endif
            Endif
        Endif
    Next J
Next I
Return

########################################################################################
$COMP_ACN                                   #### CONSULTATIONS  ########################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(15,126,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_ACN)+")",0) From GESECRAN       # Consultation
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_ACN
   # Consultation inexistante
   If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
    Call TRACE("ACN","","","","","",mess(149,115,1),EXCEL,-1,DIF)
   Endif
   Return
Endif
Raz NBFIC
For COD="ACONSULT"
    Gosub TRT_ATABZON
    NBFIC+=1
Next

## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]ACNDEB="" & [M:ACMP]ACNFIN="ZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& COD<'X'"
 Endif
Else
 CRITERE += "& COD>=[M:ACMP]ACNDEB & COD<=[M:ACMP]ACNFIN"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

For [F:ACN1]ACN0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ACN1]MODULE-1,0)) = 2
        FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_ACN From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_ACN1: Endif        #X3PLAT-940 - Filter on activity code

        Filter [F:ACN2] Where [F:ACN2]COD=[F:ACN1]COD
        Read [F:ACN2] First
        If fstat
            Call TRACE("ACN",[F:ACN1]COD,"","","",mess(87,100,1),mess(15,126,1)-mess(82,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
            # Consultation inexistante sous "
        Else
            Raz OK_C
            Gosub TRT_ACN
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                    Call TRACE("ACN",[F:ACN1]COD,"","","","",mess(150,115,1),EXCEL,0,DIF)
                    # consultation identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("ACN",[F:ACN1]COD,"","","",mess(3,55,1),mess(148,115,1),EXCEL,-1,DIF)
                    # Consultation différente
                    If PATCH : Call PATCH("ACN",[F:ACN1]COD,"") : Endif
                Endif
            Endif
        Endif
        Filter [F:ACN2]
    Endif
$NEXT_ACN1                    #X3PLAT-940 - Filter on activity code
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:ACN2]ACN0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ACN2]MODULE-1,0)) = 2
      FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
      Gosub FILTRE_ACN From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
      If !OK Goto NEXT_ACN2 : Endif       #X3PLAT-940 - Filter on activity code
        Read [F:ACN1]ACN0=[F:ACN2]COD
        If fstat
            Call TRACE("ACN",[F:ACN2]COD,"","","",mess(87,100,1),mess(15,126,1)-mess(82,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
            # Consultation inexistante sous
        Endif
    Endif
$NEXT_ACN2  # X3PLAT-940 - Filter on activity code
Next

Return

#############################
$TRT_ACN
OBJ=0
For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    For J=1 To K
        If TYP(OBJ,I) = "ATX"
            Read [OATX]NUMERO=GLANGUE;evalue("[F:ACN1]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:OATX]TEXTE="" : Endif
            Read [DATX]NUMERO=GLANGUE;evalue("[F:ACN2]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:DATX]TEXTE="" : Endif
            If [F:OATX]TEXTE <> [F:DATX]TEXTE
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Call TRACE("ACN",[F:ACN1]COD,mess(149,123,1),ZON(OBJ,I),[F:OATX]TEXTE,mess(200,115,1)
&               ,[F:DATX]TEXTE,EXCEL,-1,DIF)
                # Consultation & intitulés différents
            Endif
        Else
            INTERM1 = num$(evalue("[F:ACN1]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
            INTERM2 = num$(evalue("[F:ACN2]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
            If INTERM1 <> INTERM2
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Gosub FORMAT_KT
                If K<>1
                    Call TRACE("ACN",[F:ACN1]COD,mess(149,123,1),ZON(OBJ,I)+"("+num$(J-1)+")",INTZON(OBJ,I),mess(201,115,1)
&                   ,mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                    # Consultation & Champ & Différence
                Else
                    Call TRACE("ACN",[F:ACN1]COD,mess(149,123,1),ZON(OBJ,I),INTZON(OBJ,I),mess(201,115,1)
&                   ,mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)
                    # Consultation & Champ & Différence
                Endif
            Endif
        Endif
    Next J
Next I
Return

########################################################################################
$TRT_ATABZON                               ### TABLE DE COMPARAISON
########################################################################################
# Lecture du fichier ATABZON sur les deux dossiers (bug 8339 - 13/03/01)
# Comparaison possible entre deux versions (120 & 130)
#  qui n'ont pas la même structure au niveau des tables de référence
#  (contrôle sur l'existence du champ & dimension de champ)
Local Integer OREPET, DREPET, OK
NBRZON(NBFIC)=0
For [OATZ]NUMLIG Where CODFIC=COD
 OK = 1
 OREPET = [F:OATZ]DIME
 If [F:OATZ]CODACT<>""
  Read [OACV]CODACT = [F:OATZ]CODACT
  If !fstat & [F:OACV]FLACT=2
   If [F:OACV]DIMFIL>0 & [F:OACV]DIME>0 & [F:OACV]DIMMAX>0
    OREPET = min(max([F:OACV]DIMFIL,[F:OACV]DIME),[F:OACV]DIMMAX)
   Elsif ([F:DACV]DIMFIL<>0 | [F:OACV]DIME<>0)
    OREPET = max([F:OACV]DIMFIL,[F:OACV]DIME)
   Endif
  Else
   OK = 0
  Endif
 Endif
 If OK
& & !find([F:OATZ]CODZONE,"CREDAT","UPDDAT","CREUSR","UPDUSR","CRETIM","UPDTIM","NUMFNC","NUMLIG","UPDFLG","AUUID","CREDATTIM","UPDDATTIM")
& & !find([F:OATZ]CODZONE,"X1","X2","Y1","Y2")
  Read [DATZ]CODZONE = [OATZ]CODFIC;[OATZ]CODZONE
  If !fstat
   OK = 1
   DREPET = [F:DATZ]DIME
   If [F:DATZ]CODACT<>""
    Read [DACV]CODACT = [F:DATZ]CODACT
    If !fstat & [F:DACV]FLACT=2
     If [F:DACV]DIMFIL>0 & [F:DACV]DIME>0 & [F:DACV]DIMMAX>0
      DREPET = min(max([F:DACV]DIMFIL,[F:DACV]DIME),[F:DACV]DIMMAX)
     Elsif ([F:DACV]DIMFIL<>0 | [F:DACV]DIME<>0)
      DREPET = max([F:DACV]DIMFIL,[F:DACV]DIME)
     Endif
    Else
     OK = 0
    Endif
   Endif
   If OK
    NBRZON(NBFIC) += 1
    ZON(NBFIC,NBRZON(NBFIC))    = [F:OATZ]CODZONE
    DIMZON(NBFIC,NBRZON(NBFIC)) = min(max(OREPET,1),max(DREPET,1))
    TYP(NBFIC,NBRZON(NBFIC))    = [F:OATZ]CODTYP
    Read[OATX]NUMERO=GLANGUE;[F:OATZ]NOLONG
    INTZON(NBFIC,NBRZON(NBFIC))  =[F:OATX]TEXTE
   Endif
  Endif
 Endif
Next OATZ
Return

#############################
$TRT_ATABZON_PERS
#############################
# Lecture du fichier ATABZON sur les deux dossiers (bug 8339 - 13/03/01)
# Comparaison possible entre deux versions (120 & 130)
#  qui n'ont pas la même structure au niveau des tables de référence
#  (contrôle sur l'existence du champ & dimension de champ)

Local File AMSKZON [AMZ1]
Raz I
## Copie des champs à comparer (uniquement les champs saisi de l'écran AOC1)
For [F:AMZ1]CODE Where [F:AMZ1]CODMSK="AOC1"
    If SAIAFF=1
        I+=1
        INTERM(I) = [F:AMZ1]CODZON
    Endif
Next

## Trie des champs - recherche l'appartenance à la table
## Traitement de la table ATABZON
Raz NBFIC
For COD="AOBJET","AOBJLST"
    Raz NBRZON(NBFIC)
    For [OATZ]NUMLIG Where CODFIC=COD
        If find([F:OATZ]CODZONE,INTERM(1..25)) <> 0
            Read [DATZ]CODZONE = [OATZ]CODFIC;[OATZ]CODZONE
            If !fstat
                NBRZON(NBFIC) += 1
                ZON(NBFIC,NBRZON(NBFIC)) = [F:OATZ]CODZONE
                DIMZON(NBFIC,NBRZON(NBFIC)) = min([F:OATZ]DIME,[F:DATZ]DIME)
                TYP(NBFIC,NBRZON(NBFIC)) = [F:OATZ]CODTYP
                Read[OATX]NUMERO=GLANGUE;[F:OATZ]NOLONG
                INTZON(NBFIC,NBRZON(NBFIC))=[F:OATX]TEXTE
            Endif
        Endif
    Next
    NBFIC += 1
Next
Close Local File [AMZ1]
Return



#############################
$FORMAT_KT
#############################
If len(format$("KTv2:250X",INTERM1)) <> len(format$("Kv2:250X",INTERM1))
    INTERM1=format$("KTv2:250X",INTERM1)
    INTERM2=format$("KTv2:250X",INTERM2)
Else
    INTERM1=format$("Kv2:250X",INTERM1)
    INTERM2=format$("Kv2:250X",INTERM2)
Endif
Return

########################################################################################
$COMP_ADC                                     #### TRAITEMENTS  ########################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-":"-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-":"-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(1,20,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
Local Char    ORDRE(200)
Local Char    FICTRA(GDIMFIC) , LIGNE(200) , OS(10) , CRITERE(200)
Local Char    SAVIFS(5), SAVIRS(5)
Local Integer SAVIUM
Local Integer I , OK , CMPDIC , NBDIF , TOUT
DIF = 0
OK = 1
Call GET_OS(adxmac(0),OS) From ORDSYS
If OS<>"unix" : OK = 0 : Endif
If !OK
 Call TRACE("TRT","","","","","not unix",mess(127,100,1),EXCEL,-1,DIF) : # Fonction impossible dans le contexte
 Return
Endif

Raz NBFIC
For COD="ADICTRT"
    Gosub TRT_ATABZON
    NBFIC+=1
Next
TOUT = 0
CRITERE = "1=1"
If [M:ACMP]ADCDEB="" & [M:ACMP]ADCFIN="ZZZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& [F:TRT_]TRAIT<'X' & !find(left$([F:TRT_]TRAIT,4),'SUBX','SUBY','SUBZ')"
 Endif
Else
 CRITERE += "& [F:TRT_]TRAIT>=[M:ACMP]ADCDEB & [F:TRT_]TRAIT<=[M:ACMP]ADCFIN"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

If left$([M:ACMP]ADCDEB,1)<>"W" & left$([M:ACMP]ADCFIN,1)<>"W"
 CRITERE += '& left$([F:TRT_]TRAIT,1)<>"W"'
Endif

CMPDIC = (clalev([F:ADC1])>0)
Call MACHINE([M]DOSORG,MACHINE,APPLI) From ORDSYS
ORDRE = MACHINE+'@lsadx -a '+APPLI-' TRT src'
Local File (TRAIT(GLONADC)) From System ORDRE As [TRT_]
NBDIF = 0
For [TRT_]
 If [F:TRT_]TRAIT<>"" & evalue(CRITERE)
  NBDIF += 1
  OK = 1
  If CMPDIC
   Read [ADC1]ADC0 = [F:TRT_]TRAIT
   If fstat | [M:ACMP]COPMOD(max([F:ADC1]MODULE-1,0))<>2
     OK = 0
   Elsif [M:ACMP]CODACT<>""
    FILTRE_STEP=1
    Gosub FILTRE_ADC From ACOMPOBJ3
    If !OK Goto NEXT_TRT_ : Endif
    Filter [F:ADC2] Where CODTRT=[F:ADC1]CODTRT
    Read [F:ADC2]First
    Filter [F:ADC2]
    If fstat
      Call TRACE("ADC",[F:ADC1]CODTRT,"","","",mess(87,100,1),mess(2,20,1)-mess(82,126,1)-func NOMDOS([M]DOSDES),EXCEL,-1,DIF)
    Else
      Raz OK_C
      Gosub TRT_ADC From ACOMPOBJ3
      If [M:ACMP]DETAIL=2
          If !OK_C & !TOUT & !EXCEL
              Call TRACE("ADC",[F:ADC1]CODTRT,"","","","",mess(241,115,1),EXCEL,0,DIF)
          Endif
      Else
          If OK_C=1
              Call TRACE("ADC",[F:ADC1]CODTRT,"","","",mess(3,55,1),mess(2,20,1),EXCEL,-1,DIF)
              If PATCH : Call PATCH("ADC",[F:ADC1]COD,"") : Endif
          Endif
      Endif
    Endif
  Endif
 Endif
  If OK
   Call DIF("TRT",[F:TRT_]TRAIT,"src",EXCEL,DIF,TRACE,[M:ACMP]DETAIL)
   If !DIF & !TOUT
    # Traitement identique
    If !(TRACE<0)
     Call TRACE("TRT",[F:TRT_]TRAIT,"","","",mess(241,115,1),"",EXCEL,0,DIF) : # func NOMDOS([M]DOSORG)+"="+func NOMDOS([M]DOSDES)
    Endif
   Elsif DIF>0
    If ([M:ACMP]DETAIL<>2 and [M:ACMP]TECHNI<>2) or EXCEL
     If !(TRACE<0)
      Call TRACE("TRT",[F:TRT_]TRAIT,"","","",mess(242,115,1),"",EXCEL,-1,DIF) : # func NOMDOS([M]DOSORG)+"<>"+func NOMDOS([M]DOSDES)
     Endif
     If PATCH : Call PATCH("TRT",[F:TRT_]TRAIT,"") : Endif
    Elsif !(TRACE<0) & GTRACE<>""
     Call ECR_TRACE("",0) From GESECRAN
     Call ECR_TRACE(string$(100,"-"),0) From GESECRAN
     Call ECR_TRACE("Script TRT"-[F:TRT_]TRAIT-[M]DOSORG-"(<)"-[M]DOSDES-"(>)",0) From GESECRAN
     Call ECR_TRACE(string$(100,"-"),0) From GESECRAN
     SAVIFS = adxifs
     SAVIRS = adxirs
     SAVIUM = adxium
     adxifs = ""
     adxirs = chr$(10)
     adxium = GUTF8
     DIF = 0
     If instr(1,[M]DOSORG,"@")<>0
      FICTRA = filpath("TRA","dif"+GUSER,"tra",nomap)
     Else
      FICTRA = filpath("TRA","dif"+GUSER,"tra",func NOMDOS([M]DOSORG),"",MACHINE)
     Endif
     Openi FICTRA , 0
     Rdseq LIGNE
     While !fstat
      If left$(LIGNE,1)="<"
       Call ECR_TRACE("|"+LIGNE+"|",-1) From GESECRAN
      Elsif left$(LIGNE,1)=">"
       Call ECR_TRACE("|"+LIGNE+"|",1) From GESECRAN
       DIF += 1
      Else
       Call ECR_TRACE("|"+LIGNE+"|",0) From GESECRAN
      Endif
      Rdseq LIGNE
     Wend
     Openi
     adxifs = SAVIFS
     adxirs = SAVIRS
     adxium = SAVIUM
    Endif
   Endif
  Endif
 Endif
$NEXT_TRT_
Next TRT_
#X3PLAT-940 - Filter on activity code
# compare destination folder to source folder
For [F:ADC2]ADC0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ADC2]MODULE-1,0)) = 2
      FILTRE_STEP = 2
      Gosub FILTRE_ADC From ACOMPOBJ3
      If !OK Goto NEXT_ADC2 : Endif
        Read [F:ADC1]ADC0=[F:ADC2]CODTRT
        If fstat
            Call TRACE("ADC",[F:ADC2]CODTRT,"","","",mess(87,100,1),mess(2,20,1)-mess(82,126,1)-func NOMDOS([M]DOSORG),EXCEL,-1,DIF)
        Else
          Raz OK_C
          Gosub TRT_ADC From ACOMPOBJ3
          If [M:ACMP]DETAIL=2
              If !OK_C & !TOUT & !EXCEL
                  Call TRACE("ADC",[F:ADC1]CODTRT,"","","","",mess(241,115,1),EXCEL,0,DIF)
              Endif
          Else
              If OK_C=1
                  Call TRACE("ADC",[F:ADC1]CODTRT,"","","",mess(3,55,1),mess(2,20,1),EXCEL,-1,DIF)
                  If PATCH : Call PATCH("ADC",[F:ADC1]COD,"") : Endif
              Endif
          Endif
        Endif
     Endif
$NEXT_ADC2  # X3PLAT-940 - Filter on activity code
Next
If !NBDIF & [M:ACMP]ADCDEB<>"" & [M:ACMP]ADCDEB=[M:ACMP]ADCFIN & !(TRACE<0)
 Call TRACE("TRT","","","","","",func NOMDOS([M]DOSORG)+"."+[M:ACMP]ADCDEB-"Script inexistant",EXCEL,-1,DIF)
Endif
Return


################################################
Subprog DIF(REP,NOM,EXT,EXCEL,DIF,TRACE,DET)
################################################
Value    Char    REP,NOM,EXT
Value    Integer EXCEL
Variable Integer DIF
Value    Integer TRACE,DET

Local    Char    FICORG(GDIMFIC), FICDES(GDIMFIC), FICDIFDES(GDIMFIC),FICDIFORG(GDIMFIC)
Local    Char    MESSAGE(120)(1..10)
Local    Char    SAVIFS(5) , SAVIRS(5)
Local    Integer SAVIUM
Local    Char    FICTRA(GDIMFIC), ORDSYS(GDIMFIC)(1..2)
Local    Char    MACORG(GDIMFIC), APPORG(GDIMFIC)
Local    Char    MACDES(GDIMFIC), APPDES(GDIMFIC)
Local    Integer OK , STAT , OPT
Local    Char    SYMBOLEDES(20),SYMBOLEORG(20)

Raz DIF, MESSAGE

Call MACHINE([M]DOSDES,MACDES,APPDES) From ORDSYS
APPDES = toupper(APPDES)

FICDES = filpath(REP,NOM,EXT,APPDES,"",MACDES)
If filinfo(FICDES,0)<=0
 If !(TRACE<0)
  Call TRACE("TRT",NOM,"","","",mess(90,123,1),APPDES-"(DIF)",EXCEL,-1,DIF) : # Traitement inexistant
 Endif
 DIF=-1 : Goto FIN_DIF
Endif

Call MACHINE([M]DOSORG,MACORG,APPORG) From ORDSYS
APPORG = toupper(APPORG)

FICORG = filpath(REP,NOM,EXT,APPORG,"",MACORG)
If filinfo(FICORG,0)<=0
 If !(TRACE<0)
  Call TRACE("TRT",NOM,"","","",mess(90,123,1),APPORG-"(dif)",EXCEL,-1,DIF) : # Traitement inexistant
 Endif
 DIF=-1 : Goto FIN_DIF
Endif

If filinfo(filpath("tmp","","",nomap),0)<=0
 If !(TRACE<0)
  Call TRACE("TRT",NOM,"","","",mess(87,100,1),nomap+"/tmp"-"(dif)",EXCEL,-1,DIF)
 Endif
 DIF=-1 : Goto FIN_DIF
Endif

SYMBOLEORG = "DIFORG"+GUSER
Lock =SYMBOLEORG With lockwait=0
If fstat
 If !(TRACE<0)
  Call TRACE("TRT",NOM,"","","","Lock",GUSER-nomap,EXCEL,-1,DIF)
 Endif
 DIF=-1 : Goto FIN_DIF
Endif

SYMBOLEDES = "DIFDES"+GUSER
Lock =SYMBOLEDES With lockwait=0
If fstat
 If !(TRACE<0)
  Call TRACE("TRT",NOM,"","","","Lock",GUSER-APPDES,EXCEL,-1,DIF)
 Endif
 DIF=-1 : Goto FIN_DIF
Endif

FICDIFORG = filpath("tmp","diforg"+GUSER,EXT,nomap)
FICDIFDES = filpath("tmp","difdes"+GUSER,EXT,nomap)

If DET<>2 : # Pas de détail
 OPT = 3 : # On ne tient pas compte des lignes vides
Else
 OPT = 2 : # On en tient compte
Endif
Call COPIE(FICORG,FICDIFORG,OPT,STAT)
If STAT
 If !(TRACE<0)
  Call TRACE("TRT",NOM,"","","","Error copy","Stat="+num$(STAT),EXCEL,-1,DIF)
 Endif
 DIF=-1 : Goto FIN_DIF
Endif

Call COPIE(FICDES,FICDIFDES,OPT,STAT)
If STAT
 If !(TRACE<0)
  Call TRACE("TRT",NOM,"","","","Error copy","Stat="+num$(STAT),EXCEL,-1,DIF)
 Endif
 DIF=-1 : Goto FIN_DIF
Endif

FICTRA = filpath("TRA","dif"+GUSER,"tra",nomap)
If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA ,STAT) From ORDSYS
Endif

I = instr(1,FICDIFORG,"@") : If I : FICDIFORG = right$(FICDIFORG,I+1) : Endif
I = instr(1,FICDIFDES,"@") : If I : FICDIFDES = right$(FICDIFDES,I+1) : Endif
I = instr(1,FICTRA,"@")    : If I : FICTRA    = right$(FICTRA,I+1)    : Endif

ORDSYS(1) = "diff -b"-FICDIFORG-FICDIFDES
ORDSYS(2) = FICTRA

Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

DIF = filinfo(FICTRA,7)>0

$FIN_DIF
If SYMBOLEDES<>"" : Unlock =SYMBOLEDES : Endif
If SYMBOLEORG<>"" : Unlock =SYMBOLEORG : Endif
End

###########################################################################################
Subprog COPIE(FIC,FICDIF,OPTION,STAT)
Value Char FIC,FICDIF
Value Integer OPTION
Variable Integer STAT
Local Integer I , ER
Local Char    CHAINE(255)
Onerrgo ERCOP
If OPTION=2 & find(GPRODUIT,-1,2)
 OPTION = 4 : # Pour le superviseur et la paye, on veut garder la différence sur les commentaires
Endif
# Options de copie
# 1 copie tous les caractères
# 2 remplace les commentaires par une ligne vide
# 3 ne tient pas compte des lignes vides
# 4 on garde les commentaires
If OPTION=1
 Call COPIE(FIC,FICDIF,STAT) From ORDSYS
 End
Endif
Openi FIC Using [AINP]
Iomode adxifs "" Using [AINP]
Iomode adxirs chr$(10) Using [AINP]
Iomode adxium GUTF8 Using [AINP]
Openo FICDIF,0 Using [AOUT]
Iomode adxifs "" Using [AOUT]
Iomode adxirs chr$(10) Using [AOUT]
Iomode adxium GUTF8 Using [AOUT]
Rdseq CHAINE Using [AINP]
If !fstat & left$(CHAINE,6)="#<AdxT"
 Rdseq CHAINE Using [AINP]
Endif
While !fstat
 If left$(CHAINE,1)="#" & OPTION<>4
  CHAINE = ""
 Endif
 I = instr(1,CHAINE,"#")
 If I & !instr(I,CHAINE,"'") & !instr(I,CHAINE,'"') & OPTION<>4
  CHAINE = left$(CHAINE,I-1)
  CHAINE = vireblc(CHAINE,1)
  If right$(CHAINE,len(CHAINE))=":"
   CHAINE = left$(CHAINE,len(CHAINE)-1)
  Endif
 Endif
 If CHAINE<>"" or find(OPTION,2,4)
  Wrseq CHAINE Using [AOUT]
 Endif
 Rdseq CHAINE Using [AINP]
Wend
Openi Using [AINP]
Openo Using [AOUT]
Onerrgo
If ER : STAT = 1 : Endif
End

$ERCOP
ER = errn
Resume

###########################################################################################
Subprog TRACE(OBJET,CODE,TYPDIF,CODDIF,INTDIF,TYPMES,MESSA,EXCEL,TYPERR,DIF)
Value Char OBJET,CODE,TYPDIF,CODDIF,INTDIF,TYPMES,MESSA
Value    Integer EXCEL,TYPERR
Variable Integer DIF
Local    Integer EXISTE
Local    Char    TRACE(255)
If TYPERR : DIF += 1 : Endif
OBJET = vireblc(OBJET,2)
CODE = vireblc(CODE,2)
TYPDIF = vireblc(TYPDIF,2)
CODDIF = vireblc(CODDIF,2)
INTDIF = vireblc(INTDIF,2)
TYPMES = vireblc(TYPMES,2)
MESSA = vireblc(MESSA,2)
If EXCEL & TYPERR
 If GFICPATH="" or GNBIMP>65000 : # Limite d'un fichier csv
  GFICPATH = filpath("tmp","diff_"+GDOSSIER+"_"+format$("D:YYMMDD",date$)+"_"+left$(time$,2)+mid$(time$,4,2),"csv")
  GNBIMP = 0
  If GTRACE<>""
   # Nom du fichier des différences objets
   Call ECR_TRACE(mess(211,115,1)-":|"-GFICPATH,0) From GESECRAN
  Endif
 Else
  GNBIMP += 1
 Endif
 EXISTE = (filinfo(GFICPATH,0)>0)
 If !EXISTE & OBJET="" : End : Endif
 Openo GFICPATH Using [ADIF]
 Iomode adxifs ";" Using [ADIF]
 Iomode adxirs chr$(10) Using [ADIF]
 Case EXCEL
  When 2       : Iomode adxium GUTF8 Using [ADIF]
  When 3       : Iomode adxium GUCS2 Using [ADIF]
  When Default : Iomode adxium GASCII Using [ADIF]
 Endcase
 If !EXISTE
  # Type objet;Objet;Sous type objet 1;Code objet 1;Libellé objet 1;Type message;Description;
  Wrseq mess(167,125,1);mess(168,125,1);mess(169,125,1);mess(170,125,1);mess(171,125,1);mess(172,125,1);mess(173,125,1) Using [ADIF]
 Endif
 Wrseq OBJET;CODE;TYPDIF;CODDIF;INTDIF;TYPMES;MESSA Using [ADIF]
 Openo Using [ADIF]
Elsif !EXCEL & GTRACE<>""
 TRACE = format$("K:"+num$(GLONAOB)+"X",OBJET)
 Case OBJET
  When "TRT"   : TRACE += " "+format$("K:"+num$(GLONADC)+"X",CODE)
  When Default
   If evalue("dim(GLON"+OBJET+")")>0
    TRACE += " "+format$("K:"+num$(evalue("GLON"+OBJET))+"X",CODE)
   Else
    TRACE += " "+format$("K:"+num$(12)+"X",CODE)
   Endif
 Endcase
 TRACE += " "+format$("K:10X",TYPDIF)
 TRACE += " "+format$("K:"+num$(GLONAVA)+"X",CODDIF)
 TRACE += " "+format$("K:20X",INTDIF)
 TRACE += " "+format$("K:20X",TYPMES)
 TRACE += " "+MESSA
 Call ECR_TRACE(TRACE,TYPERR) From GESECRAN
Endif
End

###################################################################################
Subprog PATCH(OBJET,CODE,INTIT)
Value Char    OBJET , CODE , INTIT
Call PATCH(OBJET,CODE,INTIT) From ACOMPOBJ3
End

