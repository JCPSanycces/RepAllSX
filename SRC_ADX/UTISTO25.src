#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTISTO25   [F:STJ]VCRNUM and VCRNUMORI update                          #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap

Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS

If DOSSIER <> ""

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("[F:STJ]VCRNUM and VCRNUMORI update") From LECFIC

  Call MAJ_UTISTO25(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC

Endif

End
##########################################################################
##########################################################################
Subprog MAJ_UTISTO25(DOSSIER)
Value Char     DOSSIER

# If we have stock module
If [F:ADS]MODULE(6)<>2 : End : Endif

Call ECR_TRACE("UTISTO25: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Open tables -----#
If filinfo(filpath("FIL","SCHGH", "fde",DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL","STOJOU","fde",DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL","STOALL","fde",DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL","STOTRK","fde",DOSSIER),0) < 0 : End : Endif

If clalev([F:SGH]) = 0 : Local File =DOSSIER+".SCHGH"   [SGH] : Endif
If clalev([F:STA]) = 0 : Local File =DOSSIER+".STOALL"  [STA] : Endif
If clalev([F:STJ]) = 0 : Local File =DOSSIER+".STOJOU"  [STJ] : Endif
If clalev([F:STR]) = 0 : Local File =DOSSIER+".STOTRK"  [STR] : Endif

If dim([F:SGH]TMPSGHNUM)<=0 : End : Endif

For [F:SGH] Where [F:SGH]TMPSGHNUM<>""

  Update [F:STA] Where [F:STA]VCRTYP=29    & [F:STA]VCRNUM=[F:SGH]TMPSGHNUM    With [F:STA]VCRNUM=[F:SGH]VCRNUM
  Update [F:STJ] Where [F:STJ]VCRTYP=29    & [F:STJ]VCRNUM=[F:SGH]TMPSGHNUM    With [F:STJ]VCRNUM=[F:SGH]VCRNUM
  Update [F:STJ] Where [F:STJ]VCRTYPORI=29 & [F:STJ]VCRNUMORI=[F:SGH]TMPSGHNUM With [F:STJ]VCRNUMORI=[F:SGH]VCRNUM
  Update [F:STR] Where [F:STR]VCRTYP=29    & [F:STR]VCRNUM=[F:SGH]TMPSGHNUM    With [F:STR]VCRNUM=[F:SGH]VCRNUM
  Update [F:STR] Where [F:STR]VCRTYPORI=29 & [F:STR]VCRNUMORI=[F:SGH]TMPSGHNUM With [F:STR]VCRNUMORI=[F:SGH]VCRNUM

  If filinfo(filpath("FIL","CPTANALIN","fde",DOSSIER),0)>=0
    If clalev([F:CAL]) = 0 : Local File =DOSSIER+".CPTANALIN"  [CAL] : Endif
    Update [F:CAL] Where [F:CAL]ABRFIC="SGD" & [F:CAL]VCRTYP=29 & [F:CAL]VCRNUM=[F:SGH]TMPSGHNUM With [F:CAL]VCRNUM=[F:SGH]VCRNUM
  Endif

Next

Call ECR_TRACE("UTISTO25: Process End",0) From GESECRAN

End
########################################################################
# For execution upon patch integration                                 #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UTISTO25(APPLI)

End
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#--- Issue 108760 by TS
#If APPLI="X3" : End : Endif
If APPLI=GDOSX3 : End : Endif
#---
#--- Issue 108760 by TS
If filinfo(filpath("FIL","STOJOU","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"STOJOU") : End : Endif                  : # For Archive folder
#---
Call MAJ_UTISTO25(APPLI)
End

