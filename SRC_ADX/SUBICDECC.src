#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SEL_TABLE"        : Case COUZON
                             When "ECCVALMAJ","ECCVALMIN" : Gosub SELECCMAJ
                           Endcase
 When "VERF_TABLE"       : Case COUZON
                             When "ECCVALMAJ" : Gosub SELECCVALMIN
                           Endcase
Endcase

Return

######################################################################################
$APRES_MODIF
Case COUZON
    When "ECCVALMAJ", "ECCVALMIN" :
        Assign "[M]"+COUZON With CZ
        Case GCSTTYP
            When 1,3 :
                If !func SUBITCB.LOADITC([M]STOFCY,[M]ITMREF,GCSTTYP,[M]FIYNUM,[M]ECCVALMAJ,[M]ECCVALMIN)
                    # The cost for this version doesn't exist => duplication
                    [M]ITCSEQ = 0
                Endif
                COUZON = "ITCSEQ"
                CZ = num$([M]ITCSEQ)
                Affzo [M]ITCSEQ
            When 2,4 :

                Gosub READ_EVL
                If !mkstat
                    If [M]DATREF<[F:EVL]STRDAT
                        [M]DATREF = [F:EVL]STRDAT
                    Endif
                Else
                     Raz mkstat
                Endif

                Raz [F:ITC]ITCSEQ
                # Try to get the cost for the date set in [M]DATREF
                Call GETPRISTD([M]ITMREF,[M]ECCVALMAJ,[M]ECCVALMIN,[M]STOFCY,[M]DATREF,0,GCSTTYP,LPRI,LRET) From STKVAL
                # If no cost found => duplication
                [M]ITCSEQ = [F:ITC]ITCSEQ
                COUZON = "ITCSEQ"
                CZ = num$([M]ITCSEQ)
                Affzo [M]ITCSEQ

                Gosub CHANGE_DATE
        Endcase
    When "DATREF" :
        Case GCSTTYP :
            When 2,4 :
                Gosub READ_EVL
                If !mkstat
                    Gosub CHANGE_DATE
                Else
                    mkstat=0
                Endif
        Endcase
Endcase

Return

$CHANGE_DATE
    If [M]ITCSEQ=0 & [M]ITCSTRDAT<[F:EVL]STRDAT
        [M]ITCSTRDAT = [F:EVL]STRDAT
        Affzo [M]ITCSTRDAT
    Endif
    If [M]ITCENDDAT<[M]ITCSTRDAT
        [M]ITCENDDAT = [F:EVL]ENDDAT
        Affzo [M]ITCENDDAT
    Endif
Return

######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If dim([M]ECCVALMAJ)<0 : End : Endif

Case GCSTTYP
    When 1,3 : Call ECCAFF(VALEUR,"ICD0") From SUBICDECC
    When 2,4 : Call ECCAFF(VALEUR,"ICA0") From SUBICDECC
Endcase

End

######################################################################################
Subprog C_FIYNUM(VALEUR)
Variable Decimal VALEUR

If dim([M]ECCVALMAJ)<0 | !func ECCLIB.NBRCPNCST([M]ITMREF): End : Endif

Gosub READ_EVL
If mkstat : End : Endif

# Control has to be done on STRDAT only. We don't care ENDDAT
If [F:FIY]FIYEND<[F:EVL]STRDAT
    mkstat=2
    GMESSAGE=mess(216,187,1)    # This fiscal year is not available for this version
    End
Endif

If [M]ITCSTRDAT<[F:EVL]STRDAT
    mkstat=4    # run AM action
Endif
End

######################################################################################
Subprog AM_FIYNUM(VALEUR)
Variable Decimal VALEUR
If dim([M]ECCVALMAJ)<0  | !func ECCLIB.NBRCPNCST([M]ITMREF): End : Endif

# [F:FIY] & [F:EVL] are read in control action
[M]ITCSTRDAT = max([F:FIY]FIYSTR,[F:EVL]STRDAT)
Affzo [M]ITCSTRDAT

End

######################################################################################
Subprog C_ITCSTRDAT(VALEUR)
Variable Date VALEUR
If dim([M]ECCVALMAJ)<0 | !func ECCLIB.NBRCPNCST([M]ITMREF) : End : Endif

Gosub READ_EVL
If mkstat : End : Endif

If VALEUR<[F:EVL]STRDAT
    mkstat=2
    GMESSAGE = mess(219,187,1)  # The start date cannot be earlier to the period of validity of the version.
    End
Endif
End

######################################################################################
$READ_EVL
    Filter [EVL] Where ITMREF    = [M]ITMREF
&                    & ECCVALMAJ = [M]ECCVALMAJ
&                    & ECCVALMIN = [M]ECCVALMIN
&                Order By STRDAT;ECCTYP
    Read [EVL] First
    Filter [EVL]
    If fstat
# Issue 110802 - 2015-09-04 by CCC : Useless message (particularly while entering version number)
#        Call RSTA("EVL",[M]ITMREF+";"+[M]ECCVALMAJ+";"+[M]ECCVALMIN) From GLOCK
        mkstat=2
        Return
    Endif
Return

######################################################################################
# Display or hide version fields in standard cost context
Subprog ECCAFF(ITM, ABR)
Value Char ITM
Value Char ABR

If dim([M]ECCVALMAJ)<0 | GIMPORT : End : Endif

Local Integer I
I=func ECCLIB.NBRCPNCST(ITM)

If !I
    LACTMAJ = 0
    LACTMIN = 0
Else
    If I=1
        LACTMAJ = 1
        LACTMIN = 0
    Else
        LACTMAJ = 1
        LACTMIN = 1
    Endif
Endif

# It's necessary to define the mask (context of tunnel from GESITM for example)
Case ABR
    When "ICD0"
         If !LACTMAJ
             Effzo [M:ICD0]ECCVALMAJ
             Diszo [M:ICD0]ECCVALMAJ
         Else
             Actzo [M:ICD0]ECCVALMAJ
         Endif
         If !LACTMIN
             Effzo [M:ICD0]ECCVALMIN
             Diszo [M:ICD0]ECCVALMIN
         Else
             Actzo [M:ICD0]ECCVALMIN
         Endif
    When "ICA0"
         If !LACTMAJ
             Effzo [M:ICA0]ECCVALMAJ
             Diszo [M:ICA0]ECCVALMAJ
         Else
             Actzo [M:ICA0]ECCVALMAJ
         Endif
         If !LACTMIN
             Effzo [M:ICA0]ECCVALMIN
             Diszo [M:ICA0]ECCVALMIN
         Else
             Actzo [M:ICA0]ECCVALMIN
         Endif
    When "DIA"
         Affzo [M:DIA]ECCVALMAJ,ECCVALMIN
         If !LACTMAJ
             Effzo [M:DIA]ECCVALMAJ
             Grizo [M:DIA]ECCVALMAJ
         Else
             Actzo [M:DIA]ECCVALMAJ
         Endif
         If !LACTMIN
             Effzo [M:DIA]ECCVALMIN
             Grizo [M:DIA]ECCVALMIN
         Else
             Actzo [M:DIA]ECCVALMIN
         Endif
Endcase
End

#**----------------------------------------------------------------<br/>
#* ITCCTRECC : Version number control
#**<br/>----------------------------------------------------------------<br/>
#* ITMMASTER [F:ITM] should be loaded
#* @param PITM       = Item
#* @param PMAJ       = Major version number
#* @param PMIN       = Minor version number
#* @param PORI       = control origin :
#*         1 = from field ECCVALMAJ and it's mandatory
#*         2 = from field ECCVALMIN and it's mandatory
#*         3 = from field ECCVALMAJ and it's not mandatory
#*         4 = from field ECCVALMIN and it's not mandatory
#* @return mkstat (2=error) + GMESSAGE
#**<br/>----------------------------------------------------------------
#*!
Subprog ITCCTRECC(PITM,PMAJ,PMIN,PORI)
Value Char    PITM
Value Char    PMAJ
Value Char    PMIN
Value Integer PORI

If PORI = 3 & PMAJ = "" : End : Endif
If PORI = 4 & PMIN = "" : End : Endif

If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If [F:ITM]ITMREF<>PITM
    Read [F:ITM]ITM0=PITM
    If fstat
        mkstat=2
        GMESSAGE = mess(212,199,1)      # Non-existent Product!
        End
    Endif
Endif
If [F:ITM]ECCSTO = 2 & PMIN <> ""
   mkstat = 2
   End
Endif

# Major version number control
If !clalev([F:EVL3]) : Local File ECCVAL3 [EVL3] : Endif
Filter [EVL3] Where ITMREF=PITM & ECCVALMAJ=PMAJ & ECCSTA<>3
Read [EVL3] First
Filter [EVL3]
If fstat
   mkstat = 2
   GMESSAGE = mess(406,184,1) # Version does not exist  !
   End
Endif

# If no minor version : end
If [F:ITM]ECCSTO < 3
   End
Endif
# If field to control is ECCVALMAJ : end
If find(PORI,1,3)
   End
Endif

# Minor version control
Filter [EVL3] Where ITMREF=PITM & ECCVALMAJ=PMAJ & ECCVALMIN=PMIN & ECCSTA<>3
Read [EVL3] First
Filter [EVL3]
If fstat
   mkstat = 2
   GMESSAGE = mess(434,184,1) # Minor version does not exist.
Endif

End

######################################################
$SELECCMAJ
Gosub SELECCVAL3 From ECCLIB
If !PSTD : Return : Endif

CRITERE="[EVL3]ITMREF='"+[M]ITMREF+"'"
I=find("[F:EVL3]ITMREF",COL(1..NBCOL))
If I
   Dela I COL,TIT
   NBCOL-=1
   TIT(0)-=[M]ITMREF
Endif

# BOM can be in development => stock status = (not defined,Active,To be activated) displayed
CRITERE+=" & [EVL3]ECCSTA<>3"

Case COUZON
  When "ECCVALMAJ"
       EXPSTART="ECCVALMAJ='"+VALEUR+"' & ECCVALMIN='"+[M]ECCVALMIN+"'"
  When "ECCVALMIN"
       CRITERE-="& [EVL3]ECCVALMAJ='"+[M]ECCVALMAJ+"'"
       EXPSTART="ECCVALMAJ='"+[M]ECCVALMAJ+"' & ECCVALMIN='"+VALEUR+"'"
       START="ECCVALMIN"
Endcase

Default File [EVL3]     # security
Return

######################################################
$SELECCVALMIN
VALEUR = [F:EVL3]ECCVALMAJ
START=""

If [F:EVL3]ECCVALMIN<>[M]ECCVALMIN
   [M]ECCVALMIN = [F:EVL3]ECCVALMIN
   Affzo [M]ECCVALMIN
   mkstat=4
Endif
Return

