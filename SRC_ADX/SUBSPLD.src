    Endif
  Endif
End

##########################################################################################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()

Local Integer IRET
Local Integer ILINE

  If [M:SPLD1]LINTYP(nolign-1) = AVOID.ACHAR Then
    # PROJECT LEVEL
    ILINE = fmet GZINSPJM.PJM(1).ADDLINE("SPLD",[V]CST_ALASTPOS)
    If ILINE <> [V]CST_ANOTDEFINED Then
      [M:SPLD1]LINTYP(nolign-1) = func PJMACTSPLD.CALLER_PROJECT()
      Call SHOW_SPLD_LINE(ILINE, 0) From PJMACTSPLD
      Call DISPLAY_WITH_STYLE_LINE(nolign-1) From PJMACTSPLD
    Else
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
      GOK = 0
      GERR = 1
      mkstat = 2
      [L]IRET = fmet GZINSPJM.RESET_ERRORS()
      End
    Endif
    Affzo [M:SPLD1]10
  Endif
End

##########################################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

Local Integer ACTION_LIN

  Case [M:SPLD1]LINTYP(nolign-1)
    When func PJMACTSPLD.CALLER_PROJECT()
      GZINSPJM.PJM(1).SPLD([M:SPLD1]COLLIN(nolign-1)).ITMREF = VALEUR
      ACTION_LIN = 0
    When func PJMACTSPLD.CALLER_BUDGET()
      GZINSPJM.PJM(1).BUD([M:SPLD1]BUDLIN(nolign-1)).SPLD([M:SPLD1]COLLIN(nolign-1)).ITMREF = VALEUR
      ACTION_LIN = [M:SPLD1]BUDLIN(nolign-1)
    When func PJMACTSPLD.CALLER_TASK()
      GZINSPJM.PJM(1).TAS([M:SPLD1]TASLIN(nolign-1)).SPLD([M:SPLD1]COLLIN(nolign-1)).ITMREF = VALEUR
      ACTION_LIN = [M:SPLD1]TASLIN(nolign-1)
  Endcase
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_SPLD_LINE([M:SPLD1]COLLIN(nolign-1), ACTION_LIN) From PJMACTSPLD
    Affzo [M:SPLD1]1-99
  Endif
End

