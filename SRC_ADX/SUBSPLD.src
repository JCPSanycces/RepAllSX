#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Mask Management PJMSPLD0
##########################################################################################################
$ACTION

Return

##########################################################################################################
Subprog C_NBLIG
Local Integer IRET
Local Integer ILINE
Local Integer ACTION_LIN

  If status = 82 or status = 73 Then
    # Add a new line
    If [M:SPLD0]CALFRO <> func PJMACTSPLD.CALLER_PROJECT() Then
      If [M:SPLD1]SEQNUM(nolign-1) = 0 Then
        Case [M:SPLD0]CALFRO
          When func PJMACTSPLD.CALLER_BUDGET()
            ILINE = fmet GZINSPJM.PJM(1).BUD([M:SPLD0]BUD_LIN).ADDLINE("SPLD",[V]CST_ALASTPOS)
            ACTION_LIN = [M:SPLD0]BUD_LIN
          When func PJMACTSPLD.CALLER_TASK()
            ILINE = fmet GZINSPJM.PJM(1).TAS([M:SPLD0]TAS_LIN).ADDLINE("SPLD",[V]CST_ALASTPOS)
            ACTION_LIN = [M:SPLD0]TAS_LIN
        Endcase
      Endif
      If ILINE <> [V]CST_ANOTDEFINED Then
        [M:SPLD1]LINTYP(nolign-1) = [M:SPLD0]CALFRO
        Call SHOW_SPLD_LINE(ILINE, ACTION_LIN) From PJMACTSPLD
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
        GOK = 0
        GERR = 1
        mkstat = 2
        [L]IRET = fmet GZINSPJM.RESET_ERRORS()
        End
      Endif
      Affzo [M:SPLD1]10
    Endif
  Elsif status = 65 Then
    Case [M:SPLD1]LINTYP(nolign-1)
      When func PJMACTSPLD.CALLER_PROJECT()
        IRET = fmet GZINSPJM.PJM(1).ADELLINE("SPLD", GZINSPJM.PJM(1).SPLD([M:SPLD1]COLLIN(nolign-1)).AORDER)
      When func PJMACTSPLD.CALLER_BUDGET()
        IRET = fmet GZINSPJM.PJM(1).BUD([M:SPLD1]BUDLIN(nolign-1)).ADELLINE("SPLD", GZINSPJM.PJM(1).BUD([M:SPLD1]BUDLIN(nolign-1)).SPLD([M:SPLD1]COLLIN(nolign-1)).AORDER)
      When func PJMACTSPLD.CALLER_TASK()
        IRET = fmet GZINSPJM.PJM(1).TAS([M:SPLD1]TASLIN(nolign-1)).ADELLINE("SPLD", GZINSPJM.PJM(1).TAS([M:SPLD1]TASLIN(nolign-1)).SPLD([M:SPLD1]COLLIN(nolign-1)).AORDER)
    Endcase
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
      GOK = 0
      GERR = 1
      mkstat = 2
      [L]IRET = fmet GZINSPJM.RESET_ERRORS()
    Endif
  Endif
End

##########################################################################################################
Subprog AS_PBUCOD(VALEUR)
Variable Char    VALEUR()

  If [M:SPLD1]LINTYP(nolign-1) <> AVOID.ACHAR Then
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_PBUCOD(VALEUR)
Variable Char    VALEUR()

Local Integer IRET
Local Integer ILINE

  If VALEUR <> AVOID.ACHAR Then
    # BUDGET LEVEL
    [M:SPLD1]BUDLIN(nolign-1) = fmet GZINSPJM.PJM(1).BUD_GET_INDEX(VALEUR)
    If [M:SPLD1]BUDLIN(nolign-1) < 1 Then
      # Error
      GMESSAGE = func AFNC.MES1(mess(4,2260,1), VALEUR)
      GERR = 1
      mkstat = 2
      End
    Else
      ILINE = fmet GZINSPJM.PJM(1).BUD([M:SPLD1]BUDLIN(nolign-1)).ADDLINE("SPLD",[V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        [M:SPLD1]LINTYP(nolign-1) = func PJMACTSPLD.CALLER_BUDGET()
        Call SHOW_SPLD_LINE(ILINE, [M:SPLD1]BUDLIN(nolign-1)) From PJMACTSPLD
        Call DISPLAY_WITH_STYLE_LINE(nolign-1) From PJMACTSPLD
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
        GOK = 0
        GERR = 1
        mkstat = 2
        [L]IRET = fmet GZINSPJM.RESET_ERRORS()
        End
      Endif
      Affzo [M:SPLD1]10
    Endif
  Endif
End

