##########################################################################################################
Subprog AM_SAU(VALEUR)
Variable Char    VALEUR()

Local Integer ACTION_LIN
Local Integer IRET

  Case [M:SPLD1]LINTYP(nolign-1)
    When func PJMACTSPLD.CALLER_PROJECT()
      GZINSPJM.PJM(1).SPLD([M:SPLD1]COLLIN(nolign-1)).SAU = VALEUR
      IRET = fmet GZINSPJM.PJM(1).SPLD([M:SPLD1]COLLIN(nolign-1)).UOM_CONTROL()
      If IRET = [V]CST_AOK Then
        IRET = fmet GZINSPJM.PJM(1).SPLD([M:SPLD1]COLLIN(nolign-1)).QTY_CONVERT()
      Endif
      ACTION_LIN = 0
    When func PJMACTSPLD.CALLER_BUDGET()
      GZINSPJM.PJM(1).BUD([M:SPLD1]BUDLIN(nolign-1)).SPLD([M:SPLD1]COLLIN(nolign-1)).SAU = VALEUR
      IRET = fmet GZINSPJM.PJM(1).BUD([M:SPLD1]BUDLIN(nolign-1)).SPLD([M:SPLD1]COLLIN(nolign-1)).UOM_CONTROL()
      If IRET = [V]CST_AOK Then
        IRET = fmet GZINSPJM.PJM(1).BUD([M:SPLD1]BUDLIN(nolign-1)).SPLD([M:SPLD1]COLLIN(nolign-1)).QTY_CONVERT()
      Endif
      ACTION_LIN = [M:SPLD1]BUDLIN(nolign-1)
    When func PJMACTSPLD.CALLER_TASK()
      GZINSPJM.PJM(1).TAS([M:SPLD1]TASLIN(nolign-1)).SPLD([M:SPLD1]COLLIN(nolign-1)).SAU = VALEUR
      IRET = fmet GZINSPJM.PJM(1).TAS([M:SPLD1]TASLIN(nolign-1)).SPLD([M:SPLD1]COLLIN(nolign-1)).UOM_CONTROL()
      If IRET = [V]CST_AOK Then
        IRET = fmet GZINSPJM.PJM(1).TAS([M:SPLD1]TASLIN(nolign-1)).SPLD([M:SPLD1]COLLIN(nolign-1)).QTY_CONVERT()
      Endif
      ACTION_LIN = [M:SPLD1]TASLIN(nolign-1)
  Endcase
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_SPLD_LINE([M:SPLD1]COLLIN(nolign-1), ACTION_LIN) From PJMACTSPLD
    Affzo [M:SPLD1]1-99
  Endif
End

