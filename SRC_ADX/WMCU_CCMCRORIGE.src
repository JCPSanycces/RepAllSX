#<AdxTL>@(#)0.0.0.0 $Revision$Classe Initiateurs externes
# Superviseur
## CRUD-CLASSE ## CCMCRORIGE
# 2018-10-19 07:50:21 162


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(CCMCRORIGE,ASTATUS)
Variable Instance CCMCRORIGE Using C_CCMCRORIGE
Variable Integer ASTATUS

If CCMCRORIGE = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGE

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_CCMCRORIGE

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(CCMCRORIGE,ASTATUS)
Variable Instance CCMCRORIGE Using C_CCMCRORIGE
Variable Integer ASTATUS

If CCMCRORIGE = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGE
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
CCMCRORIGE.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_CCMCRORIGE
Else
 Gosub AUPDATE_CCMCRORIGE
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = CCMCRORIGE.freeSnapshot
CCMCRORIGE.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGE._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGE._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGE._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If CCMCRORIGE.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGE.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(CCMCRORIGE.ASTALIN)<>""
 [L]A_ASTALIN = CCMCRORIGE.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(CCMCRORIGE.ASTALIN)<>""
 [L]A_ASTALIN = CCMCRORIGE.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_CCMCRORIGE
Trbegin [F:CCMCROE]
 Gosub AUPDATE_CCMCRORIGE
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_CCMCRORIGE
[L]A_ASTALIN = CCMCRORIGE.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGE._MAJSQL_CCMCRORIGE(CCMCRORIGE))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = CCMCRORIGE.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If CCMCRORIGE.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGE.revertUpdTick
Endif

[L]ASTATUS = max(fmet CCMCRORIGE.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(CCMCRORIGE.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 CCMCRORIGE.ASTALIN = [V]CST_ALL
Endif
Return



