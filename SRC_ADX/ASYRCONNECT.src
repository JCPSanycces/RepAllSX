#<AdxTL>@(#)0.0.0.0 $Revision$
End

################################################################################################################
# AUDIT_CONNECT
################################################################################################################

Subprog AUDIT_CONNECT(CTX,ERRAUD,ERRMES)
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Integer ERRAUD
Value Char ERRMES

Local Integer TT , HH , MM , SS, STAT , OK, ASTATUS
Local Char    USRBDD(30) , USRSYS(80) , USRCLI(30) , MESSAGE(250)
Local Char    SID(20) , SADR(50) , SDOS(50) , SLOGIN(30) , SUSR(30)

#If CTX=null or CTX.AFOLD=null or dim(CTX.AFOLD.AUDIT)<0 or CTX.AFOLD.AUDIT<>2 or (dim(CTX.AFOLD.AUDIT)>0 and CTX.AFOLD.HISTO=2)
If CTX=null or func DOSSUB.ISHISTFOLD(CTX.AFOLDER)>0 or CTX.AFOLD=null or dim(CTX.AFOLD.AUDIT)<0 or CTX.AFOLD.AUDIT<>2 or (dim(CTX.AFOLD.AUDIT)>0 and CTX.AFOLD.HISTO=2)
 End
Endif

Local File ALOGIN   [ALO]
Local File ADOSSIER [ADS]
Local File ADOVAL   [ADW]
If [F:ADS]DOSSIER<>CTX.AFOLDER
 #Read [ADS]DOSSIER = nomap
 STAT=func DOSSUB.FILL_ADS(CTX.AFOLDER)
Endif
Gosub USER_BDD
Gosub USER_SYS
If !adxlog
 Gosub TR_AUD
Else
 Gosub MAJ_AUD
Endif
End

$TR_AUD
OK = 1
Trbegin [ALO]
 Gosub MAJ_AUD
 If OK=0 : Goto AB_AUD : Endif
Commit
Return

$MAJ_AUD
#
# Les autres sessions de même identifiant ne sont plus actives
#
Update [ALO] Where BDDID=USRBDD and FLG<>1 With FLG=1
If fstat
 OK = 0 : Call FSTA("ALO",0,MESSAGE) From GLOCK_SYRA : Return
Endif
Update [ALO] Where ADOID=num$(adxuid(1)) and FLG<>1 With FLG=1
If fstat
 OK = 0 : Call FSTA("ALO",0,MESSAGE) From GLOCK_SYRA : Return
Endif
#
# Création enreg dans ALOGIN
#
Raz [F:ALO]
[F:ALO]SEQ    = uniqid([ALO])
[F:ALO]ADOID  = num$(adxuid(1))
[F:ALO]BDDID  = USRBDD
[F:ALO]ADOLOG = adxusr
[F:ALO]ADOUSR = CTX.USER
[F:ALO]SYSUSR = USRSYS
[F:ALO]ADRCLI = USRCLI
[F:ALO]ADOTYP = mod(adxtyp,8)
[F:ALO]DATCNX = date$
TT = time
HH = int(TT/3600)
MM = int((TT-3600*HH)/60)
SS = TT-3600*HH-60*MM
[F:ALO]HOUCNX = format$("N0:2#",HH)+format$("N0:2#",MM)+format$("N0:2#",SS)
[F:ALO]AUUID = getUuid
[F:ALO]CREDATTIM =  datetime$
If ERRAUD
 [F:ALO]STA    = ERRAUD
 [F:ALO]MSG    = MESSAGE
 [F:ALO]DATDCX = [F:ALO]DATCNX
 [F:ALO]HOUDCX = [F:ALO]HOUCNX
 [F:ALO]FLG = 1 : # mb 10.6.13 bug 89549
Else
 [F:ALO]STA    = 0
 [F:ALO]MSG    = ""
 [F:ALO]FLG = 2
Endif
Write [ALO]
If fstat
 OK = 0 : Call FSTA("ALO",0,MESSAGE) From GLOCK_SYRA
Endif
Return

$AB_AUD
Rollback
Return

$USER_BDD
Case [F:ADS]TYPDBA
 When 1 : Gosub USER_ORA
 When 2 : Gosub USER_SQL
Endcase
Return

$USER_ORA
For (Integer ORASES) From '3' Sql
&   "Select userenv('SESSIONID') from dual"
&    As [ORA_]
 USRBDD = num$([ORA_]ORASES)
 Break
Next
Return

$USER_SQL
Execsql From '5'
& Sql "Update ADOVAL set VALEUR_0=convert(varchar,@@spid) where PARAM_0='TMPID' and CMP_0=' ' and FCY_0=' '"
Read [ADW]ADW0 = "";"";"TMPID"
USRBDD = [F:ADW]VALEUR
Return

$USER_SYS
If dim([S]adxcus)>0
 USRSYS = adxcus
 If instr(1,USRSYS,"\")
  USRSYS = right$(USRSYS,instr(1,USRSYS,"\")+1)
 Endif
 USRCLI = adxmac(-2)
Else
 If func ASESSIONS.ISMNGSESSIONS
  Call USER_SYS(USRSYS,USRCLI) From ASESSIONS
 Else
   Local File (SID,SADR,SDOS,SLOGIN,SUSR)
&          From System adxmac(0)+"@psadx -u"-CTX.LOGIN-"-b"-CTX.AFOLDER-"-n"  As [SYS_]
&          Where [SYS_]SID=num$(adxuid(1))
   For [SYS_]
    USRSYS = [F:SYS_]SLOGIN
    USRCLI = [F:SYS_]SADR
    Break
   Next
   Close Local File [SYS_]
  Endif
Endif
Return

################################################################################################################
# AUDIT_DECONNECT
################################################################################################################

Subprog AUDIT_DECONNECT(CTX)
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT

If CTX=null or CTX.AFOLD=null or dim(CTX.AFOLD.AUDIT)<0 or CTX.AFOLD.AUDIT<>2 or (dim(CTX.AFOLD.AUDIT)>0 and CTX.AFOLD.HISTO=2)
 End
Endif
Local Integer ERR , TT , HH , MM , SS,OK
Onerrgo ERRFIC
Local File ALOGIN [ALO]
If !ERR
 If !adxlog
  Gosub TR_DEC
 Else
  Gosub MAJ_DEC
 Endif
Endif
Onerrgo
End

$TR_DEC
OK = 1
Trbegin [ALO]
 Gosub MAJ_DEC
Commit
Return

$MAJ_DEC
Filter [ALO] Where ADOID=num$(adxuid(1)) and FLG=2
Readlock [ALO]ALO2 First
Filter [ALO]
If fstat<=2
 [F:ALO]DATDCX = date$
 TT = time
 HH = int(TT/3600)
 MM = int((TT-3600*HH)/60)
 SS = TT-3600*HH-60*MM
 [F:ALO]HOUDCX = format$("N0:2#",HH)+format$("N0:2#",MM)+format$("N0:2#",SS)
 [F:ALO]FLG    = 1
 Rewrite [ALO]
Endif
Return

################################################################################################################
# STATUS UPDATE IN DISCONNECTION ON BATCH REQUEST WHEN SOCKET HAS BEEN INTERRUPTED
################################################################################################################
#**
#* BATCH_FLAG_UPDATED_TO_KILLED ****** When Batch request socket is interrupted, the signal catched launches this function to update ABATRQT table
#*
#* @param
#*
#*!
Subprog BATCH_FLAG_UPDATED_TO_KILLED ()

Local Integer ERR,        SESSION_ID,     PREVFLAG
Local Char    MESSA(255), PROCESS_ID(50), FICTRA(GDIMFIC), FICTRQ(GDIMFIC), RQTID(50)
Local Char    FICTRATECH(GDIMFIC)    # Technical log (messages concerning only batch server, not requests)
Local Char    HH(10), HS(10)
Local Integer SS
Local Date    DD

  # initializations
  [L]SESSION_ID = adxuid(1)
  [L]PROCESS_ID = num$(adxpid)
  [L]FICTRA     = func SERVSYS.GET_FILE_SERVEUR("tra")      # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
  # Issue X3-70499 - 2018-03-05 by CCC : add technical log
  [L]FICTRATECH = func SERVSYS.GET_FILE_SERVEUR_TECH("tra")
  [L]ERR        = 0
  # X3-76574 JPGA - Using a delay to let ABATCH_MNGT_ALLERR request write log files before FIN_BATCH signal
  Sleep 1

  # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
  Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR

  # Preparing Transaction and Opening ABATRQT table
  Onerrgo ERRFIC
  Local File ABATRQT [ABR]
  If !ERR
    If !adxlog
      Gosub TR_BATCH_QUERY_UPDATE
    Else
      Gosub MAJ_BATCH_QUERY_UPDATE
    Endif
  Else
    [L]MESSA=mess (12,100,1)-"ABATRQT"  : # Access Error on file
    Call STRACE([L]FICTRA, 42000, 0, mess(89,9137,1) - [L]MESSA) From SERVEUR
  Endif
  Onerrgo
End

$TR_BATCH_QUERY_UPDATE
  Trbegin [ABR]
    Gosub MAJ_BATCH_QUERY_UPDATE
  Commit
Return

$MAJ_BATCH_QUERY_UPDATE
  # Updating Request status corresponding to Current SESSION and current PROCESS - New status : 6=Cancelled
  Filter [ABR] Where PROCESS=[L]PROCESS_ID and SESSIONID=[L]SESSION_ID and find(FLAG,2,5) : # We take only FLAG status : 2=In progress - 5=To kill
  If rowcount([ABR])=0
    # No request found in Status 2 or 5 - We canot update status of batch request.
    # Impossible to read on the TCP/IP socket. Connection closing. No Bacth request found for status update
# Comment this line to manage the log file correctly after 2018R02
#    Call STRACE([L]FICTRATECH, 30010, 0, mess(89,9137,1) - "PROCESS="+[L]PROCESS_ID-"and SESSIONID="+num$([L]SESSION_ID)-":"-mess(125,134,1)) From SERVEUR
  Else
    For [ABR]FLAG
      [L]PREVFLAG=[ABR]FLAG
      [ABR]FLAG = 6
      [ABR]DFIN = DD
      [ABR]HFIN = HS
      Rewrite [ABR]
      If fstat<>[V]CST_AOK
        [L]MESSA=mess(13,100,1)-"ABATRQT"  : # Write Error on file
        Call STRACE([L]FICTRA, 42000, [ABR]NUMREQ, mess(89,9137,1) - [L]MESSA) From SERVEUR
      Else
        # If Batch request has been found and updated : Server Trace files will be written
        # Impossible to read on the TCP/IP socket. Connection closing.
        Call STRACE([L]FICTRA, 30010, [ABR]NUMREQ, mess(89,9137,1) - "PROCESS="+[L]PROCESS_ID-"and SESSIONID="+num$([L]SESSION_ID)) From SERVEUR
        Gosub INTER_RQT From SERVEUR
      Endif
    Next
  Endif
  Filter [ABR]
Return

##########################
$ERRFIC
ERR = errn
Resume

