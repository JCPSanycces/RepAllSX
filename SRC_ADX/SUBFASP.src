#<AdxTL>@(#)0.0.0.0 $Revision$
#
#*********************************************************************
#
#             GESTION DES ELEMENTS PHYSIQUES DANS LES BIENS COMPTABLES
#
#*********************************************************************
#    Création
#    SEGAY - 03.09.2008
#
#    Modification
#
# MWA    17.02.2015 FQ109842   : Suppression du traitement lié à BACAUTNUM
# GLE    03.06.2015 FQ107982   : Error if activity code PHY is set to Yes and activity code CIG is set to No
# CBO    17.02.2015 FQ100398/13: Liaison FXD PHY
# MDJ    09.02.2015 FQ100398   : Suppression site géographique
# CBO    04.11.2014 FQ103454   : reprise de DISZO_CREATE_ELT_PHY en DISZO_ELT_PHY
# MDJ    06.05.2014 FQ99017    : Tableau des éléments physiques non grizé entièrement
# CBO    29.04.2014 FQ69690    : objet FAM + BACFLG
# CBO    28.02.2014 FQ97293    : disparition du BAC
# CBO    28.02.2014 FQ97291    : disparition du BAC
# MWA    31.10.2012 FQ85464    : Prise en compte de la legislation dans la numérotation automatique
# CBO    10.04.2012 FQ81493    : var NBOBJLCK non déclarée
# CBO    2012.01.27 FQ79681    : Plantage si click sur BAC en numérotation auto
# MDJ    27.12.2011 FQ78704    : Numérotation automatique des codes barres
# GLE    22.06.2009 FQ55485    : Un bien composant n'a plus obligatoirement la même localisation que son bien principal
# STANT  29.04.2009 FQ49517    : Création élément physique sur BCO non immatriculable.
# SEGAY  29.04.2009 FQ49517    : Création d'un élément physique
# SEGAY  11.05.2009 FQ55082    : Gestion du fournisseur dans les éléments physique
#*********************************************************************
$ACTION
        Case ACTION
    When "OUVRE"         : Gosub OUVRE
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "APRES_MODIF"   : Gosub APRES_MODIF
    When "ABANDON"       : Gosub ABANDON
    When "FIN"           : Gosub FIN
    When "OK"            : Gosub OK
    When Default
  Endcase
Return

#===========================================================================================================================
$OUVRE
#===========================================================================================================================
   # NAVIG="GESFAS"
   Gosub OUVRE_TABLES
Return

#===========================================================================================================================
$OUVRE_TABLES
#===========================================================================================================================
  Global Integer OPENFILE
  Global Integer OPENFILEFCY # FQ : 49517 Création élément physique lors de la création du bien comptable
  OPENFILE=0
  OPENFILEFCY=1 # FQ : 49517 Création élément physique lors de la création du bien comptable

  # Ouverture de tables liées à explorer ou à mettre à jour
  If !(clalev([F:PHY])) Then
    Local File PHYELT   [PHY]
    OPENFILE=1
  Endif
  If clalev([F:WFCY])=0    : Local File FACILITY      [WFCY]   : OPENFILEFCY=1 : Endif # FQ : 49517 Création élément physique lors de la création du bien comptable
Return

#===========================================================================================================================
$DEBUT
#===========================================================================================================================
  Local Integer WINDICE
  Global Char LREP   # FQ : 49517 Si le bien est non immatriculable, on ne prend que les Elt-Phy sans code à barre pour garder le statut du Grep du BCO
  Raz [M:FASP]  # raz à cause des icones qui ne sont pas dans FAS8
  # Référence du bien comptable
  [M:FASP]AASREF  = [M:FAS0]AASREF
  [M:FASP]AASDES1 = [M:FAS0]AASDES1 # FQ : 49517 Si le bien est non immatriculable, on ne prend que les Elt-Phy sans code à barre
  # FQ : 49517 Création élément physique lors de la création du bien comptable
  LREP = GREP  # FQ : 49517 Si le bien est non immatriculable, on ne prend que les Elt-Phy sans code à barre
  # Récupération des informations sur les éléments physiques stockées dans l'écran temporaire FAS8.
  [M:FASP] = [M:FAS8]

  # Alimentation des icônes et des cases à cocher Annulation attente et Attaché
  For nolign = 1 To [M:FASP]NBPHY
    If [M:FASP]MVT(nolign-1) > GVMLPMVNONE Then
      If [M:FASP]SUPATTENTE(nolign-1) = G_NON
        [M:FASP]ICOSUPATTE(nolign-1)= GICOMVT
      Else
        [M:FASP]ICOSUPATTE(nolign-1)= GICOANNULE
      Endif
    Else
      [M:FASP]ICOSUPATTE(nolign-1)= ""
    Endif

    If [M:FASP]RATTACHE(nolign-1) = G_NON
      [M:FASP]ICORATTACH(nolign-1)= GICODETACHE
    Else
      [M:FASP]ICORATTACH(nolign-1)= GICOATTACHE
    Endif
    [M:FASP]FLGLOCK(nolign-1) = G_NON
    If [M:FASP]IMP(nolign-1) <> G_OUI Then
      Call DISZO_ELT_PHY()
    Endif
  Next nolign

  # MABON - 29.04.2009 FQ49517 : Création élément physique lors de la création du bien comptable
  If GREP='C' Then
    Chgfmt [M:FASP]ICOSUPATTE With "-K:3X"
    Chgfmt [M:FASP]MVT        With "-K:10X"
    Chgfmt [M:FASP]MVTDATPHY  With "-D:10X"
    Chgfmt [M:FASP]LOCATT     With "-K:38X"
  Else
    Chgfmt [M:FASP]ICOSUPATTE With "KP:3X"
    Chgfmt [M:FASP]MVT        With "KP:10X"
    Chgfmt [M:FASP]MVTDATPHY  With "DP:10X"
    Chgfmt [M:FASP]LOCATT     With "KP:38X"
  Endif

  # FQ49517

  # affichage écran.
  Affzo [M:FASP]1-99
  # Quand un bien est sorti ou si le bien est inactif ou si l'on vient des éléments physiques par tunnel, on ne peut être qu'en consultation dizso
  If ([M:FAS4]ISSDAT > [00/00/00] and [M:FAS4]EXTISSFLG < G_OUI ) or  [M:FAS0]ENAFAS=G_NON or G_TUNNEL_PHY = G_OUI Then
     Grizo [M:FASP]1-99
  Endif

  # Un bien présent dans une cession intra-groupe ne peut pas être modifié, donc on ne peut pas modifier les éléments physiques
  If G_ACTCIG = G_OUI : # FQ107982
    Gosub TEST_BIEN_DS_CIG From SUBFAS
    If ( GIBIENCIG = G_OUI ) Then
       Grizo [M:FASP]1-99
    Endif
  Endif
Return
#===========================================================================================================================
$SETBOUT
#===========================================================================================================================
# Quand un bien est sortie ou si le bien est inactif ou si l'on vient des éléments physiques par tunnel on ne peut être qu'en consultation
  If ([M:FAS4]ISSDAT > [00/00/00] and [M:FAS4]EXTISSFLG < G_OUI ) or  [M:FAS0]ENAFAS=G_NON or G_TUNNEL_PHY = G_OUI Then
     Call VIREBOUT(CHBOU,"O") From GOBJET   # OK
     Call VIREBOUT(CHBOU,"A") From GOBJET   # OK
  Endif

Return

#===========================================================================================================================
# Pour l'élément physique en cours, récupération de la localisation et du premier élément en attente. Alimentation des
# icônes et des cases à cocher Annulation attente et Attaché.
# Traitement presque équivalent dans SUBFAS pour écran FAS8 (FAS8)
#===========================================================================================================================
$RECUP_ELT_ATTENTE
#===========================================================================================================================

  #FQ100398/13 (Que le 1° MVT)
  Read [PMVT]PMVT0(1) = [F:PHY]PHYREF

  If fstat = 0 and [F:PMVT]MVT > GVMLPMVNONE  Then
    [M:FASP]MVT(nolign-1) = [F:PMVT]MVT
    [M:FASP]MVTDATPHY(nolign-1) = [F:PMVT]MVTDAT
    [M:FASP]LOCATT(nolign-1) = [F:PMVT]MVTLCTCOD
  Else
    [M:FASP]MVT(nolign-1) = GVMLPMVNONE
  Endif

  [M:FASP]LCTCOD(nolign-1) = [F:PHY]LCTCOD # FQ100398/13
  # L'élément est attaché par défaut
  [M:FASP]RATTACHE(nolign-1)= G_OUI
  [M:FASP]ICORATTACH(nolign-1)= GICOATTACHE

  # L'élément ajouté n'est pas en attente de mouvement
  [M:FASP]SUPATTENTE(nolign-1)= G_NON
  [M:FASP]ICOSUPATTE(nolign-1) = ""
  If [M:FASP]MVT(nolign-1) > GVMLPMVNONE Then
    [M:FASP]ICOSUPATTE(nolign-1)= GICOMVT
  Endif

  # Flag indiquant que la ligne sera modifiable (remplacement de l'élément possible, sauf s'il est détaché)
  [M:FASP]FLGMODIF(nolign-1) = G_OUI
  [M:FASP]IMP(nolign-1)= G_NON
    # FQ100398/13
  [M:FASP]PHYDES1(nolign-1) = [F:PHY]PHYDES1
  [M:FASP]PHYDES2(nolign-1) = [F:PHY]PHYDES2

  [M:FASP]SRLNBR(nolign-1) = [F:PHY]SRLNBR
  [M:FASP]BPRPHY(nolign-1) = [F:PHY]BPS # FQ100398/13
# Gestion du fournisseur dans les éléments physique
  # Si le Fournisseur n'est pas renseigné on prend celui du bien
  If [M:FASP]BPRPHY(nolign-1) = "" Then
    [M:FASP]BPRPHY(nolign-1) = [M:FAS2]BPR
  Endif
  [M:FASP]PHYCAT(nolign-1) = [F:PHY]PHYCAT
  [M:FASP]ORDBUY(nolign-1) = [F:PHY]ORDBUY
  [M:FASP]DORDBUY(nolign-1) = [F:PHY]DORDBUY
  [M:FASP]NUMRECEP(nolign-1) = [F:PHY]NUMRECEP
  [M:FASP]DNUMRECEP(nolign-1) = [F:PHY]DNUMRECEP
  [M:FASP]BAC(nolign-1) = [F:PHY]BAC # FQ97291
  Affzo [M:FASP]BAC(nolign-1), PHYDES1(nolign-1), PHYDES2(nolign-1), SRLNBR(nolign-1), BPRPHY(nolign-1), PHYCAT(nolign-1), ORDBUY(nolign-1), DORDBUY(nolign-1), NUMRECEP(nolign-1), DNUMRECEP(nolign-1)
  Call DISZO_ELT_PHY()

Return

#===========================================================================================================================
$APRES_MODIF
#===========================================================================================================================
  REP="M"
  If [F:FAS]AASREF="" or [F:FAS]AASREF<>[M:FAS0]AASREF Then
    Read [F:FAS]FAS0=[M:FAS0]AASREF
  Endif
  # MABON - FQ55380
Return

#===========================================================================================================================
$ABANDON
#===========================================================================================================================

  Gosub DEBUT
  REP = ""

Return

#===========================================================================================================================
$FIN
#===========================================================================================================================
  If OPENFILE=1
    Close Local File [F:PHY]
  Endif
  If OPENFILEFCY=1
    Close Local File [F:WFCY]
  Endif
  If dim(LREP)>0 Then Kill LREP Endif
  If dim(GLSELPHY)   >0 Then Kill GLSELPHY    Endif
  If dim(OPENFILE)   >0 Then Kill OPENFILE    Endif
  If dim(OPENFILEFCY)>0 Then Kill OPENFILEFCY Endif
Return

#===========================================================================================================================
$OK
#===========================================================================================================================
  If REP = "M"
      # gestion de la quantité du bien comptable rattaché
      Call GERE_QTE_BCO

      # FQ100398/13
      If GOK = 0
        Return
      Endif
      Gosub RAZ_PHY_FAS8 From SUBFAS2

      # MABON - FQ55380 - Suppression de ligne vide (si elle reste...)
      Local Integer I
      If [M:FASP]PHYREF([M:FASP]NBPHY-1)="" and [M:FASP]PHYDES1 = ""
        # La ligne est vidée
        [M:FASP]ICORATTACH([M:FASP]NBPHY-1) = ""
        [M:FASP]RATTACHE([M:FASP]NBPHY-1)   = 0
        [M:FASP]PHYREF([M:FASP]NBPHY-1)     = ""
        [M:FASP]PHYDES1([M:FASP]NBPHY-1)    = ""
        [M:FASP]PHYDES2([M:FASP]NBPHY-1)    = ""
        [M:FASP]LCTCOD([M:FASP]NBPHY-1)     = ""
        [M:FASP]SUPATTENTE([M:FASP]NBPHY-1) = 0
        [M:FASP]ICOSUPATTE([M:FASP]NBPHY-1) = ""
        [M:FASP]MVT([M:FASP]NBPHY-1)        = 0
        [M:FASP]MVTDATPHY([M:FASP]NBPHY-1)  = [0/0/0]
        [M:FASP]LOCATT([M:FASP]NBPHY-1)     = ""
        [M:FASP]FLGMODIF([M:FASP]NBPHY-1)   = 0
        [M:FASP]FLGLOCK([M:FASP]NBPHY-1)    = 0
        [M:FASP]BAC([M:FASP]NBPHY-1)        = ""
        [M:FASP]SRLNBR([M:FASP]NBPHY-1)     = ""
        [M:FASP]BPRPHY([M:FASP]NBPHY-1)     = ""
        [M:FASP]PHYCAT([M:FASP]NBPHY-1)     = ""
        [M:FASP]ORDBUY([M:FASP]NBPHY-1)     = ""
        [M:FASP]DORDBUY([M:FASP]NBPHY-1)    = [0/0/0]
        [M:FASP]NUMRECEP([M:FASP]NBPHY-1)   = ""
        [M:FASP]DNUMRECEP([M:FASP]NBPHY-1)  = [0/0/0]
        [M:FASP]IMP([M:FASP]NBPHY-1)        = 0

        # Et le nombre de lignes est décrémenté.
        [M:FASP]NBPHY -= 1
      Endif

      [M:FAS8] = [M:FASP]
      [M:FAS8]NBPHY = [M:FASP]NBPHY
      mkstat = 4
  Endif
Return

#===========================================================================================================================
# Affectation de la localisation et du premier mouvement en attente
#===========================================================================================================================
$VERFSELPHY1
#===========================================================================================================================
  Gosub RECUP_ELT_ATTENTE
  Affzo [M:FASP]MVT(nolign-1),MVTDATPHY(nolign-1),LOCATT(nolign-1)
  mkstat = 4

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran FASPHY) 23/05/2008 10:37:12 (SYMEU)
######################################################################################
Subprog AP_PHYREF(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> "" Then
    Read [PHY] PHY0=VALEUR
    # SEGAY FQ49517 - Création d'un élément physique
    # si on est en création d'élément physiques, il n'existe pas et on n'appelle pas VERSELPHY1
    If !fstat
    # FQ49517
       Gosub VERFSELPHY1
    Endif
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran FASPHY) 23/05/2008 10:44:59 (SYMEU)
######################################################################################
## Contrôle del'élément physique
######################################################################################
Subprog C_PHYREF(VALEUR)
Variable Char    VALEUR()
Integer WINDICE
Local Char LLOCK(200)
# SEGAY FQ49517 - Création d'un élément physique
#Local Char LCTCOD
#Local Char FASLOC
# Fin FQ49517 - Création d'un élément physique
  If VALEUR <> "" Then
    # vérification de l'existence de l'élément physique
    Read [PHY] PHY0=VALEUR
    If fstat Then
    # SEGAY FQ49517
    # Si l'élément n'existe pas et que la nouvelle référence ne soit pas contenue dans le champ PHYREFOLD d'un autre élt physique
    # on peut créer l'élément physiqye en mettant [M:FASP]IMP à "Oui"
      If [M:FASP]IMP(nolign-1) <> G_OUI
         GERR= 1
         [V]GMESSAGE = mess(26,148,1)
         mkstat = 2
         End
      Endif
      Call CTR_CRE_ELT_PHY(VALEUR)
      If mkstat=2 Then
        End
      Endif
      End
    Endif

    [M:FASP]IMP(nolign-1) = G_NON
    Call DISZO_ELT_PHY()

    # FQ100398/13
    # l'élément doit appartenir au même site que le bien comptable
    If [PHY]FCY <> [M:FAS0]FCY Then
      [V]GMESSAGE=mess(14, GML_MSGPHY, 1)
      mkstat = 2
      End
    Endif

    # l'élément ne doit pas déjà être sorti
    If [PHY]ISSDAT <> [0/0/0] Then
      [V]GMESSAGE=mess(15, GML_MSGPHY, 1)
      mkstat = 2
      End
    Endif

    # l'élément ajouté ne doit pas déjà être rattaché à un autre bien comptable
    If ([PHY]AASREF <> "" & [PHY]AASREF <> [M:FASP]AASREF & [M:FASP]FLGMODIF(nolign-1) <> 1)  Then
      [V]GMESSAGE=mess(16, GML_MSGPHY, 1)
      mkstat = 2
      End
    Endif

    WINDICE = find(VALEUR, [M:FASP]PHYREF(0..[M:FASP]NBPHY-1))
    # on a trouvé l'élément physique sur une ligne différente de celle en cours
    If WINDICE <> 0 & WINDICE <> nolign Then
      [V]GMESSAGE=mess(45,GML_MSGREC,1)
      mkstat = 2
      End
    Endif

    # lock logique de l'élément physique
# FQ100398/13
#    Call VERROU_PHYREF(VALEUR,[M:FAS0]CPY)
#    If mkstat = 2
#       End
#    Endif

    # renseignement de l'icône de la ligne
    If [M:FASP]ICORATTACH(nolign-1) = "" Then
      [M:FASP]ICORATTACH(nolign-1) = GICOATTACHE
      Affzo [M:FASP]ICORATTACH(nolign-1)
    Endif

    # renseignement du flag Attaché et du flag Annulation en attente
    [M:FASP]RATTACHE(nolign-1) = G_OUI
    [M:FASP]SUPATTENTE(nolign-1) = G_NON
    [M:FASP]FLGMODIF(nolign-1) = G_OUI
    [M:FASP]FLGLOCK(nolign-1) = G_OUI
    Affzo [M:FASP]RATTACHE(nolign-1), SUPATTENTE(nolign-1), FLGMODIF(nolign-1)
  Else
   # SEGAY FQ49517
    If vireblc(VALEUR,2)="" and [M:FASP]IMP(nolign-1) <> G_OUI
       GERR=1
       If (dim(GLSELPHY)>0 and GLSELPHY=G_OUI) or dim(GLSELPHY)=0 Then
         [V]GMESSAGE = mess(10,123,1)
       Endif
       mkstat=2
       End
    Endif
    If [M:FASP]IMP(nolign-1) = G_OUI Then
       Call CTR_CRE_ELT_PHY(VALEUR)
       If mkstat=2 Then
          End
       Endif
    Endif
   # FQ 49517
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran FASPHY) 28/05/2008 10:59:08 (SEGAY)
######################################################################################
Subprog IB_NBPHY
  # Quand un bien est sortie ou si le bien est inactif, on ne peut être qu'en consultation dizso
  If ([M:FAS4]ISSDAT > [00/00/00] and [M:FAS4]EXTISSFLG < G_OUI ) or  [M:FAS0]ENAFAS=G_NON Then
     Raz [V]GBOUT10,[V]GBOUT11,[V]GBOUT12,[V]GBOUT13     # suppression "Attacher", "Détacher","Annuler attente","Remettre en attente"
  Endif

  If [M:FASP]ICORATTACH(nolign-1) = "" Then
    Raz [V]GBOUT10,[V]GBOUT11     # suppression "Attacher", "Détacher"
  Else
    If [M:FASP]ICORATTACH(nolign-1) = GICOATTACHE Then # Attaché
      Raz [V]GBOUT11             # suppression "Attacher"
    Else
      Raz [V]GBOUT10             # suppression "Détacher"
    Endif
  Endif
  # Si l'élément a un mouvement en attente, on ne peut pas le détacher
  If [M:FASP]MVT(nolign-1) > GVMLPMVNONE Then
    Raz [V]GBOUT10                 # suppression "Détacher"
  Endif

  If [M:FASP]ICOSUPATTE(nolign-1) = "" Then # Suppression Attente
    Raz [V]GBOUT12,[V]GBOUT13     # suppression "Annuler attente", "Remettre en attente"
  Else
    If [M:FASP]ICOSUPATTE(nolign-1) = GICOANNULE Then # Annuler Attente
      Raz [V]GBOUT12            # suppression "Annuler attente"
    Else
      Raz [V]GBOUT13            # suppression "Remettre en attente"
    Endif
  Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran FASPHY) 28/05/2008 11:36:39 (SEGAY)
######################################################################################
Subprog B10_NBPHY # Détacher
  # lock logique de l'élément physique
# FQ100398/13
#  If [M:FASP]FLGMODIF(nolign-1) = G_NON Then
#      Call VERROU_PHYREF([M:FASP]PHYREF(nolign-1),[M:FAS0]CPY)
#      If mkstat = 2
#         End
#      Endif
#  Endif

  [M:FASP]ICORATTACH(nolign-1)= GICODETACHE
  [M:FASP]RATTACHE(nolign-1)=G_NON
  [M:FASP]FLGLOCK(nolign-1) = G_OUI
  Gosub AFF_ICORATTACH
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran FASPHY) 28/05/2008 11:36:39 (SEGAY)
######################################################################################
Subprog B11_NBPHY # Attacher
  # lock logique de l'élément physique
# FQ100398/13
#  If [M:FASP]FLGMODIF(nolign-1) = G_NON Then
#      Call VERROU_PHYREF([M:FASP]PHYREF(nolign-1),[M:FAS0]CPY)
#      If mkstat = 2
#         End
#      Endif
#  Endif
  # Création d'un élément physique
  [M:FASP]ICORATTACH(nolign-1)= GICOATTACHE
  [M:FASP]RATTACHE(nolign-1)=G_OUI
  [M:FASP]FLGLOCK(nolign-1) = G_OUI
  Gosub AFF_ICORATTACH
End

######################################################################################
$AFF_ICORATTACH
  Affzo [M:FASP]ICORATTACH(nolign-1)
  mkstat = 4
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran FASPHY) 28/05/2008 16:10:28 (SEGAY)
######################################################################################
Subprog B12_NBPHY # Annuler l'attente
Local Integer OK
  # Contrôle le nombre d'attente d'un élément physique
#  If func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("PHYREF = '" + [M:FASP]PHYREF(nolign-1) +"'") > 1
  If func PHYELT_C_MPR._GET_SELECTED_MVT_PHY_NBR("PHYREF = '" + [M:FASP]PHYREF(nolign-1) +"'") >= 1
     Call OUINON(mess(86,GML_MSGPHY,1),OK) From GESECRAN
     If OK=1 Then
        End
     Endif
  Endif
  # lock logique de l'élément physique
# FQ100398/13
#  If [M:FASP]FLGMODIF(nolign-1) = G_NON Then
#      Call VERROU_PHYREF([M:FASP]PHYREF(nolign-1),[M:FAS0]CPY)
#      If mkstat = 2
#         End
#      Endif
#  Endif

  [M:FASP]ICOSUPATTE(nolign-1)= GICOANNULE
  [M:FASP]SUPATTENTE(nolign-1)=G_OUI
  [M:FASP]FLGLOCK(nolign-1) = G_OUI
  Gosub AFF_ICOSUPATTE
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran FASPHY) 28/05/2008 16:36:00 (SEGAY)
######################################################################################
Subprog B13_NBPHY # Remettre en attente
  [M:FASP]ICOSUPATTE(nolign-1)= GICOMVT
  [M:FASP]SUPATTENTE(nolign-1)=G_NON
  Gosub AFF_ICOSUPATTE
End

######################################################################################
$AFF_ICOSUPATTE
  Affzo [M:FASP]ICOSUPATTE(nolign-1)
  mkstat = 4
Return


######################################################################################
# gestion de la quantité du bien comptable rattaché
######################################################################################
Subprog GERE_QTE_BCO
 Local Integer CPT_TOT_ATTACHE
 Local Integer CPT_ANC_ATTACHE

 Local Integer WINDICE
 Local Char    RBAC
 Local Integer STAT

 CPT_ANC_ATTACHE = 0
 CPT_TOT_ATTACHE = 0

 If [M:FAS8]NBPHY > 0
   For WINDICE = 0 To [M:FAS8]NBPHY-1
      If ([M:FAS8]RATTACHE(WINDICE) = G_OUI) Then
         CPT_ANC_ATTACHE +=1
      Endif
   Next WINDICE
 Endif

 If [M:FASP]NBPHY > 0
   For WINDICE = 0 To [M:FASP]NBPHY-1
      If ([M:FASP]RATTACHE(WINDICE) = G_OUI) Then
         CPT_TOT_ATTACHE +=1
      Endif
   Next WINDICE
 Endif

 #Fq-78704 --> Détachement et raz du code barre
  If [M:FASP]NBPHY > 0
    For WINDICE = 0 To [M:FASP]NBPHY-1
      Read [PHY]PHY0=[M:FASP]PHYREF(WINDICE)
      # FQ100398/13 : ajout fstat = 0
      If fstat = 0
        # FQ97293 ne pas réinit le BAC
        If [M:FASP]RATTACHE(WINDICE) = G_OUI
          # FQ109842
#          If   ( GBACAUTNUM = GVML_OBLIG ) and  [M:FASP]BAC(WINDICE)=""
#          # FQ85464
#            Call GET_NUMERO("PHY",GBACAUTNUM,1,[M:FAS0]CPY,[M:FAS0]FCY,date$,RBAC,STAT) From GLOBIENS
#            If STAT
#              End
#            Endif :# CBO 2012.01.27 FQ79681
#            [M:FASP]BAC(WINDICE) = RBAC
#            Affzo [M:FASP]BAC(WINDICE)  : Diszo [M:FASP]BAC(WINDICE)
#            [F:PHY]BAC =  [M:FASP]BAC(WINDICE)
#          Else
#            [F:PHY]BAC =  [M:FASP]BAC(WINDICE)
#            Actzo [M:FASP]BAC(WINDICE)
#          Endif #*Fq-78704
            [F:PHY]BAC =  [M:FASP]BAC(WINDICE)
            Actzo [M:FASP]BAC(WINDICE)
        Endif
        Rewrite [PHY]
        If fstat Then
          GOK=0
#          Call FSTA("PHY") From GLOCK
        Endif
      Endif
    Next WINDICE
  Endif


  If [M:FAS1]AASQTY = CPT_ANC_ATTACHE or CPT_ANC_ATTACHE = 0 Then
    If CPT_TOT_ATTACHE = 0 Then
      [M:FAS1]AASQTY = 1
    Else
      [M:FAS1]AASQTY = CPT_TOT_ATTACHE
    Endif
    Affzo [M:FAS1]AASQTY
  Else
    If [M:FAS1]AASQTY = CPT_TOT_ATTACHE Then
      # FQ100398/13
      Local Integer OK
      # Quantité du bien comptable (n) devient dépendante du nombre d'éléments physiques (n)
      Call AVERTIR(mess(30,GML_MSGPHY,1)-" ("+num$([M:FAS1]AASQTY)+") "-mess(53,GML_MSGPHY,1)-" ("+num$(CPT_TOT_ATTACHE)+")", OK) From GESECRAN
      If (OK = 1) Then
        GERR = 1
        GOK = 0
        mkstat = 2
      Endif
    Else
      # Quantité du bien comptable (n) incohérente avec le nombre d'éléments physiques (n)
      GMESSAGE = mess(30,GML_MSGPHY,1)-" ("+num$([M:FAS1]AASQTY)+") "-mess(48,GML_MSGPHY,1)-" ("+num$(CPT_TOT_ATTACHE)+")"
      GERR = 1
      # FQ100398/13
      GOK = 0
      mkstat = 2
   Endif
 Endif

End
######################################################################################
# Recherche si la localisation des éléments physiques est la même
######################################################################################

# FQ100398/13 semnle non appelé
Funprog RECH_LOC_ELT_PHY_EQ_OBSO(LCTCODEQ)
Variable Char LCTCODEQ
Local Integer RETOUR
 RETOUR = G_NON
 Raz LCTCODEQ
 If ([M:FASP]NBPHY > 0) Then
    For I=0 To [M:FASP]NBPHY-1
    # Si la localisation des éléments rattachés est différente : on n'accepte pas que le bien soit Principal ou Composant
       If [M:FASP]RATTACHE(I)=G_OUI  Then
          If (LCTCODEQ <> "" and LCTCODEQ <>[M:FASP]LCTCOD(I) ) Then
              RETOUR = G_NON
              Break
          Endif
          LCTCODEQ = [M:FASP]LCTCOD(I)
          RETOUR = G_OUI
       Endif
    Next I
 Endif
End RETOUR

######################################################################################
# FQ49517 - Création d'un élément physique
######################################################################################
Subprog CREATE_ELT_PHY(VALEUR)
Variable Char    VALEUR()
Local Integer WINDICE
    # Si l'élément n'existe pas et que la nouvelle référence ne soit pas contenue dans le champ PHYREFOLD d'un autre élt physique
    # on peut créer l'élément physiqye en mettant [M:FASP]IMP à "Oui"
   Call CTR_CRE_ELT_PHY(VALEUR)
   If mkstat = 2 Then
      End
   Endif
   Call ALIM_CREATE_ELT_PHY
   Raz [V]GBOUT14     # suppression "Création"
   [M:FASP]ICORATTACH(nolign-1)= GICOATTACHE
   [M:FASP]RATTACHE(nolign-1)=G_OUI
   [M:FASP]FLGLOCK(nolign-1) = G_OUI
   Gosub AFF_ICORATTACH

End
######################################################################################
# FQ49517 - Controle d'un élément physique créé
######################################################################################
Subprog CTR_CRE_ELT_PHY(VALEUR)
Variable Char    VALEUR()
Local Integer WINDICE
   If VALEUR <> ""
      # Numérotation automatique de la référence de l'élément physique                     #
      If ( GPHYAUTNUM = GVML_AUCUNE or GPHYAUTNUM = GVML_FACUL ) Then
        WINDICE = find(VALEUR, [M:FASP]PHYREF(0..[M:FASP]NBPHY-1))
        # on a trouvé l'élément physique sur une ligne différente de celle en cours
        If WINDICE <> 0 & WINDICE <> nolign Then
          [V]GMESSAGE=mess(45,GML_MSGREC,1)
          mkstat = 2
          End
        Endif
      Else
        If ( GPHYAUTNUM <> GVML_OBLIG) Then
          mkstat = 2
          End
        Endif
      Endif
   Else
      # Numérotation automatique de la référence de l'élément physique                     #
      If GPHYAUTNUM = GVML_AUCUNE
  # Si pas de numérotation automatique, obligation de saisir manuellement la référence de l'élément physique
  # La zone devient obligatoire
        GERR= 1: GMESSAGE = mess(19,GML_MSGPHY,1)
        mkstat = 2
        End
      Endif
   Endif
End

End

######################################################################################
# FQ49517 - Création d'un élément physique
# Alimentaion des champs par défaut de la ligne élément physique
######################################################################################
Subprog ALIM_CREATE_ELT_PHY

Local Char    RBAC  #Fq-78704
Local Integer STAT  #Fq-78704
Local Char WMESS(30)
    [M:FASP]IMP(nolign-1)     = G_OUI
    [M:FASP]PHYDES1(nolign-1) = [M:FAS0]AASDES1
    [M:FASP]PHYDES2(nolign-1) = [M:FAS0]AASDES2

# --> FQ100398/13
#    [M:FASP]LCTCOD(nolign-1)  = [M:FAS2]LOC FQ100398/13
#    Call AFF_LOCPHY FQ100398/13

    [M:FASP]LCTCOD(nolign-1) = func PHYLCT_CSTD.GET_DEFAULT_LOCATION([M:FAS0]FCY, STAT, WMESS)

    [M:FASP]MVT(nolign-1)       = GVMLPMVNONE
    [M:FASP]RATTACHE(nolign-1)  = G_OUI
    [M:FASP]SUPATTENTE(nolign-1)= G_NON
    [M:FASP]FLGMODIF(nolign-1)  = G_OUI
    [M:FASP]FLGLOCK(nolign-1)   = G_NON
    [M:FASP]BPRPHY(nolign-1)    = [M:FAS2]BPR
    Affzo [M:FASP]PHYDES1(nolign-1), PHYDES2(nolign-1), LCTCOD(nolign-1), SRLNBR(nolign-1), BPRPHY(nolign-1), PHYCAT(nolign-1), ORDBUY(nolign-1), DORDBUY(nolign-1), NUMRECEP(nolign-
& 1), DNUMRECEP(nolign-1)
    Actzo [M:FASP]PHYDES1(nolign-1), PHYDES2(nolign-1), SRLNBR(nolign-1), BPRPHY(nolign-1), PHYCAT(nolign-1), ORDBUY(nolign-1), NUMRECEP(nolign-1)
    # FQ 49517
    # le bien est immatriculable l'élément peut avoir un code à barre
       #Fq-78704 FQ109842
#       If ( GBACAUTNUM = GVML_OBLIG and [M:FASP]BAC(nolign-1)="")
#          # FQ85464 FQ100398/13 : [M:FAS0]FCY au lieu de [M:FASP]FCY
#          Call GET_NUMERO("PHY",GBACAUTNUM,1,[M:FAS0]CPY,[M:FAS0]FCY,date$,RBAC,STAT) From GLOBIENS
#          If ( STAT ) : End : Endif
#          [M:FASP]BAC(nolign-1)=RBAC
#          Affzo [M:FASP]BAC(nolign-1)
#          Diszo [M:FASP]BAC(nolign-1)
#       Else
#           Affzo [M:FASP]BAC(nolign-1)
#           Actzo [M:FASP]BAC(nolign-1)
#       Endif
       Affzo [M:FASP]BAC(nolign-1)
       Actzo [M:FASP]BAC(nolign-1)
 End
######################################################################################
# FQ49517 qd on ne crée pas :
# mettre en diszo tous les champs (actifs en création élément physique)
######################################################################################
 Subprog DISZO_ELT_PHY

    Affzo [M:FASP]PHYREF(nolign-1) #*FQ99017
    Diszo [M:FASP]PHYREF(nolign-1) #*FQ99017
    Diszo  [M:FASP]PHYDES1(nolign-1), PHYDES2(nolign-1),BAC(nolign-1),
&         LCTCOD(nolign-1), SRLNBR(nolign-1),
&         BPRPHY(nolign-1), PHYCAT(nolign-1), ORDBUY(nolign-1),
&         DORDBUY(nolign-1), NUMRECEP(nolign-1), DNUMRECEP(nolign-1)

 End
######################################################################################
# FQ49517 - Création d'un élément physique
# Rendre saisissable la localisation
######################################################################################
 Subprog AFF_LOCPHY
    # FQ55485
    #If ([M:FAS1]CMPSTA = GVML_SBCOMPO or [M:FAS1]CMPSTA = GVML_SBPRINC) & [M:FASP]LCTCOD(nolign-1)<>"" Then
    #  Diszo [M:FASP]LCTCOD(nolign-1)
    #Else
    #  Actzo [M:FASP]LCTCOD(nolign-1)
    #Endif
    # FIN FQ55485
    Actzo [M:FASP]LCTCOD(nolign-1)
 End

######################################################################################
# FQ49517 - Création d'un élément physique
# Aprés modif sur Code à barre
######################################################################################
Subprog AM_BAC(VALEUR)
Variable Char    VALEUR()

  If (VALEUR <> "") Then
    If (GCPYBACUNY = G_OUI) Then
      Look [PHY]PHY3=VALEUR;[M:FAS0]CPY
    Else
      Look [PHY]PHY3=VALEUR
    Endif
    If !(fstat) or find(VALEUR,[M:FASP]BAC(0..[M:FASP]NBPHY-1))<>0 Then
      GERR= 1: GMESSAGE = mess(249,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif
  Endif

End
######################################################################################
# FQ49517 - Création d'un élément physique
# Aprés zone sur N° de commande
######################################################################################
Subprog AP_ORDBUY(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>"" Then
    Actzo [M:FASP]DORDBUY(nolign-1)
  Else
    [M:FASP]DORDBUY(nolign-1)=[0/0/0]
    Grizo [M:FASP]DORDBUY(nolign-1)
  Endif
End

######################################################################################
# FQ49517 - Création d'un élément physique
# Controle sur Date commande
######################################################################################
Subprog C_DORDBUY(VALEUR)
Variable Date    VALEUR

  If VALEUR=[0/0/0] Then
    GERR= 1: GMESSAGE = mess(21,GML_MSGPHY,1)
    mkstat = 2
    End
  Endif
End

######################################################################################
# FQ49517 - Création d'un élément physique
# Aprés zone sur N° de Réception
######################################################################################
Subprog AP_NUMRECEP(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>""  Then
    Actzo [M:FASP]DNUMRECEP(nolign-1)
  Else
  # FQ100398/13 manque nolign
    [M:FASP]DNUMRECEP(nolign-1)=[0/0/0]
    Grizo [M:FASP]DNUMRECEP(nolign-1)
  Endif
End

######################################################################################
# FQ49517 - Création d'un élément physique
# Controle sur Date réception
######################################################################################
Subprog C_DNUMRECEP(VALEUR)
Variable Date    VALEUR

  If VALEUR=[0/0/0] Then
    GERR= 1: GMESSAGE = mess(22,GML_MSGPHY,1)
    mkstat = 2
    End
  Endif
End

######################################################################################
# FQ49517 - Création d'un élément physique
# Avant NBPHY
######################################################################################
Subprog AVANT_NBPHY

Local Char    RBAC  # CBO 2012.01.27 FQ79681
Local Integer STAT  # CBO 2012.01.27 FQ79681

  If (dim(GLSELPHY)>0 and GLSELPHY=G_OUI) Then
    nolign = [M:FASP]NBPHY
  Endif
  If nolign=0 Then nolign=1 Endif

  # On ne peut pas changer de code d'élément physique s'il n'est pas modifiable : c'est
  # le cas pour les éléments physiques déjà rattachés au bien comptable au moment du
  # chargement du tableau des éléments physiques.
  # On ne peut pas non plus modifier un code d'élément physique s'il est détaché.
  If [M:FASP]FLGMODIF(nolign-1) = G_NON or
&   ([M:FASP]FLGMODIF(nolign-1) = G_OUI and [M:FASP]RATTACHE(nolign-1) = G_NON) Then
     Diszo [M:FASP]PHYREF(nolign-1)
  Endif

# CBO FQ103454 évite l'appel de DISZO_ELT_PHY qui boucle dans ce cas
If [M:FASP]IMP(nolign-1) = 0
  End
Endif
  # SEGAY - FQ49517
  If [M:FASP]IMP(nolign-1) <> G_OUI
    Call DISZO_ELT_PHY()
  Else
    Call AFF_LOCPHY
    Actzo [M:FASP]PHYDES1(nolign-1), PHYDES2(nolign-1),BAC(nolign-1), SRLNBR(nolign-1), BPRPHY(nolign-1), PHYCAT(nolign-1), ORDBUY(nolign-1), DORDBUY(nolign-1), NUMRECEP(nolign-1),
& DNUMRECEP(nolign-1)
    If ORDBUY(nolign-1) = "" Then
      Grizo [M:FASP]DORDBUY(nolign-1)
    Endif
    If NUMRECEP(nolign-1) = "" Then
      Grizo [M:FASP]DNUMRECEP(nolign-1)
    Endif
    # Issue 109842
#    If  GBACAUTNUM  = GVML_OBLIG
#       # FQ85464
#       Call GET_NUMERO("PHY",GBACAUTNUM,1,[M:FAS0]CPY,[M:FAS0]FCY,date$,RBAC,STAT) From GLOBIENS
#       If ( STAT ) : End : Endif :# CBO 2012.01.27 FQ79681
#       [M:FASP]BAC(nolign-1)= RBAC
#       Affzo [M:FASP]BAC(nolign-1) : Diszo [M:FASP]BAC(nolign-1)
#    Endif
    # End issue 109842
  Endif
  # FQ49517
End

######################################################################################
# FQ49517 - Création d'un élément physique
# Bouton 15 sur Localisation
######################################################################################
Subprog B15_LOCPHY(VALEUR)
Variable Char    VALEUR()

#FQ100398/13
#Local Char LOCDEF
Local Char WMESS(30)
Local Integer WNUM

  [M:FASP]LCTCOD(nolign-1) = func PHYLCT_CSTD.GET_DEFAULT_LOCATION([M:FAS0]FCY, WNUM, WMESS)
  Affzo[M:FASP]LCTCOD(nolign-1)

End

######################################################################################
# FQ49517 - Création d'un élément physique
# Init Bouton 15 sur Localisation
######################################################################################
Subprog IB_LOCPHY
  If [M:FASP]IMP(nolign-1)<>G_OUI Then
    Raz [V]GBOUT15
  Endif

End

######################################################################################
# FQ49517 - Création d'un élément physique
# Init Bouton 14 Création sur PHYREF
######################################################################################
Subprog IB_PHYREF
  # Création d'un élément physique
  If [M:FASP]PHYREF(nolign-1) <> ""  or [M:FASP]IMP(nolign-1) = G_OUI  Then
    Raz [V]GBOUT14     # suppression "Création"
  Endif

  # suppression "Sélection avancée"
  Raz [V]GBOUTA

  # suppression du menu contextuel "Eléments" si on est sur une ligne vide
  If [M:FASP]PHYREF(nolign-1)="" Then
    Raz [V]GBOUT1
  Endif
End
######################################################################################
# FQ49517 - Création d'un élément physique
# Bouton Création
#######################################################################################
Subprog B14_PHYREF(VALEUR)
Variable Char    VALEUR()
    # Création d'un élément physique
    # Si l'élément n'existe pas et que la nouvelle référence ne soit pas contenue dans le champ PHYREFOLD d'un autre élt physique
    # on peut créer l'élément physiqye en mettant [M:FASP]IMP à "Oui"
  Call CREATE_ELT_PHY(VALEUR)

End

######################################################################################

