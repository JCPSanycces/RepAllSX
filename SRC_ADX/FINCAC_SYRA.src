#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT ACCOUNTING CODES
##############################################################################################################
# GET_ACCCOD     : returns the accounting code attached to a key element (Product/Customer/Supplier...) depending on a given accounting code type
# GET_ACCCOD_BPR : returns the accounting code attached to a given business partner
##############################################################################################################

#####################################################################################################################
## GET_ACCCOD
#####################################################################################################################
#**
#* Returns the Accounting Code attached to a Key Element (Product/Customer/Supplier...) depending on the Accounting Type used as parameter
#*
#* @param ACTX      Context
#* @param COMPANY   Company
#* @param CPYLEG    Company's Legislation
#* @param ACCCODTYP Accounting code Type
#* @param MODKEY    Modifier Key
#*!
Funprog GET_ACCCOD(ACTX,COMPANY,CPYLEG,ACCCODTYP,MODKEY)
Variable Instance ACTX    Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY        : # Company
Value    Char     CPYLEG         : # Company's Legislation
Value    Tinyint  ACCCODTYP      : # Accounting code Type
Value    Char     MODKEY         : # Modifier Key

Local Char    ACCCOD(GLONCAC) : ACCCOD = ""  : # Accounting code
Local Integer L

Case ACCCODTYP
 When 1 : # Product
  If adxtyp=33 | !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  Call LEC_ITM(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:ITM]ACCCOD : Endif
 When 2 : # Customer
  If adxtyp=33 |  !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  ACCCOD = func FINCAC_SYRA.GET_ACCCOD_BPR(ACTX,COMPANY,MODKEY,"C")
 When 3 : # Supplier
  If adxtyp=33 | !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
  ACCCOD = func FINCAC_SYRA.GET_ACCCOD_BPR(ACTX,COMPANY,MODKEY,"F")
 When 4 : # Sales Rep
  If adxtyp=33 | !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  Call LEC_REP(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:REP]ACCCOD : Endif
 When 5 : # Users/Buyer
  If adxtyp=33 | !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  Call LEC_AUS(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:AUS]ACCCOD : Endif
 When 6 : # Journal
  If dim([F:TB1]ACCCOD)>0
   ACCCOD = [F:TB1]ACCCOD
  Elsif dim([F:TB0]ACCCOD)>0
   ACCCOD = [F:TB0]ACCCOD
  Endif
 When 7 : # Company
  If adxtyp=33 | !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  Call LEC_CPY(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:CPY]ACCCOD : Endif
 When 8 : # Site
  If adxtyp=33 | !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  Call LEC_FCY(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:FCY]ACCCOD : Endif
 When 9 : # Currency
  If adxtyp=33 | !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
  Call LEC_TCU(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:TCU]ACCCOD : Endif
 When 10 : # Tax
  If adxtyp=33 | !clalev([F:TVT]) : Local File TABVAT [TVT] : Endif
  Call LEC_TVT_LEG(CPYLEG,MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:TVT]ACCCOD : Endif
 When 11 : # Sales footer
  If adxtyp=33 | !clalev([F:SFI]) : Local File SFOOTINV [SFI] : Endif
  Call LEC_SFI(val(MODKEY)) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:SFI]ACCCOD : Endif
 When 12 : # Discount
  If adxtyp=33 | !clalev([F:TDA]) : Local File TABDEPAGIO [TDA] : Endif
  Call LEC_TDA(CPYLEG,MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:TDA]ACCCOD : Endif
 When 13 : # Bank
  If adxtyp=33 | !clalev([F:BAN]) : Local File BANK [BAN] : Endif
  Call LEC_BAN(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:BAN]ACCCOD : Endif
 When 14 : # Payment
  If adxtyp=33 | !clalev([F:CDA]) : Local File GACCDENCOD [CDA] : Endif
  Call LEC_CDA_LEG(CPYLEG,MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:CDA]ACCCOD : Endif
 When 15 : # Fixed assets
  If adxtyp=33 | !clalev([F:FAS]) : Local File FXDASSETS [FAS] : Endif
  Call LEC_FAS(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:FAS]ACCCOD : Endif
 When 16 : # Purchase footer
  If adxtyp=33 | !clalev([F:PFI]) : Local File PFOOTINV [PFI] : Endif
  Call LEC_PFI(val(MODKEY)) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:PFI]ACCCOD : Endif
 When 17 : # Miscellaneaous Business Partner
  If adxtyp=33 | !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  Call LEC_BPR(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:BPR]ACCCOD : Endif
 When 18 : # Cost center
  If adxtyp=33 | !clalev([F:MWC]): Local File WORKCOST [MWC] : Endif
  L = instr(1,MODKEY,"~")
  If L > 1
    MODKEY1 = evalue(left$(MODKEY,L-1))
    MODKEY2 = evalue(right$(MODKEY,L+1))
    Call LEC_MWC(MODKEY2,MODKEY1) From CPTLEC
    If fstat : ACCCOD = "" : Else : ACCCOD = [F:MWC]ACCCOD : Endif
  Else
   ACCCOD = ""
  Endif
 When 19 : # Overhead
  If adxtyp=33 | !clalev([F:ONA]) : Local File OVENAT [ONA] : Endif
  Call LEC_ONA(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:ONA]ACCCOD : Endif
 When 20 : # Expenses costs
  If adxtyp=33 | !clalev([F:TES]) : Local File TABEXPENS [TES] : Endif
  Call LEC_TES(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:TES]ACCCOD : Endif
 When 21 : # Factor
  If adxtyp=33 | !clalev([F:FCT]) : Local File FACTOR [FCT] : Endif
  Call LEC_FCT(MODKEY) From CPTLEC
  If fstat : ACCCOD = "" : Else : ACCCOD = [F:FCT]ACCCOD : Endif
 When 22 : # Lease contract
  ACCCOD = MODKEY
 When 23 : # Grant
  ACCCOD = MODKEY
 When 24 : # Concession agreement
  ACCCOD = MODKEY
Endcase
If adxtyp=33
 GPOINT = "INIACCCOD" : Gosub ENTREE From EXEFNC
Endif
End [L]ACCCOD


#####################################################################################################################
## GET_ACCCOD_BPR
#####################################################################################################################
#**
#* Returns the Accounting Code attached to a Business Partner used as parameter
#*
#* @param ACTX    Context
#* @param COMPANY Company
#* @param BPR     Business Partner
#* @param BPRTYP  Business Partner Type
#*!
Funprog GET_ACCCOD_BPR(ACTX,COMPANY,BPR,BPRTYP)
Variable Instance ACTX    Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY       : # Company
Value    Char     BPR           : # Business Partner
Value    Char     BPRTYP        : # Business Partner Type

Local Char ACCCOD(GLONCAC) : ACCCOD = ""  : # Accounting code

If adxtyp=33 | !clalev([F:CPY]) : Local File COMPANY     [CPY]     : Endif
If adxtyp=33 | !clalev([F:ACV]) : Local File ACTIV       [ACV]     : Endif
If adxtyp=33 | !clalev([F:BPC]) : Local File BPCUSTOMER  [BPC]     : Endif
If adxtyp=33 | !clalev([F:BPS]) : Local File BPSUPPLIER  [BPS]     : Endif

If BPR = "" | COMPANY="" : End [L]ACCCOD : Endif

Local Integer BPE_FOUND : BPE_FOUND = 0
If [F:ACV]CODACT<>"MUL"
 Read [ACV]CODACT="MUL"
 If fstat : Raz [F:ACV] : Endif
Endif
If [F:ACV]FLACT = 2
 If adxtyp=33 | !clalev([F:BPE]) : Local File BPEXCEPT   [BPE] : Endif
 If [F:BPE]BPRNUM<>BPR | [F:BPE]CPY<>COMPANY
  Read [BPE]BPE0=BPR;COMPANY
  If !fstat
   [L]BPE_FOUND = 1
  Endif
 Else
  [L]BPE_FOUND = 1
 Endif
Endif

Case BPRTYP
 When "C"
  If [L]BPE_FOUND  &  [F:BPE]ACCBPC<>""
   ACCCOD = [F:BPE]ACCBPC
  Else
   Call LEC_BPC(BPR) From CPTLEC
   If !fstat : ACCCOD = [F:BPC]ACCCOD : Endif
  Endif
 When "F"
  If [L]BPE_FOUND  &  [F:BPE]ACCBPS<>""
   ACCCOD = [F:BPE]ACCBPS
  Else
   Call LEC_BPS(BPR) From CPTLEC
   If !fstat : ACCCOD = [F:BPS]ACCCOD : Endif
  Endif
 When Default
Endcase
End [L]ACCCOD
