#<AdxTL>@(#)1.0.0.0 $Revision$
Subprog GLOBVAR
If clalev([F:GCM])=0 : Local File GACM [GCM] : Endif
Global Integer GGCMNBR : GGCMNBR = max(1,nbrecord([F:GCM]))

Global Char    GGCM(GLONGCM)(1..GGCMNBR)     : # Modèle comptable 
Global Libelle GLEDTYPGEN(1..GGCMNBR)        : # Type référentiel principal général/modèle comptable
Global Char    GLEDGEN(GLONLED)(1..GGCMNBR)  : # Code référentiel principal général/modèle comptable
Global Libelle GLEDTYPANA(1..GGCMNBR)        : # Type référentiel principal ana/modèle comptable
Global Char    GLEDANA(GLONLED)(1..GGCMNBR)  : # Code référentiel principal ana/modèle comptable
Global Char    GLED1(GLONLED)(1..GGCMNBR)    : # Code référentiel n°1 /modèle comptable
Global Char    GLED2(GLONLED)(1..GGCMNBR)    : # Code référentiel n°2 /modèle comptable
Global Char    GLED3(GLONLED)(1..GGCMNBR)    : # Code référentiel n°3 /modèle comptable
Global Char    GLED4(GLONLED)(1..GGCMNBR)    : # Code référentiel n°4 /modèle comptable
Global Char    GLED5(GLONLED)(1..GGCMNBR)    : # Code référentiel n°5 /modèle comptable
Global Char    GLED6(GLONLED)(1..GGCMNBR)    : # Code référentiel n°6 /modèle comptable
Global Char    GLED7(GLONLED)(1..GGCMNBR)    : # Code référentiel n°7 /modèle comptable
Global Char    GLED8(GLONLED)(1..GGCMNBR)    : # Code référentiel n°8 /modèle comptable
Global Char    GLED9(GLONLED)(1..GGCMNBR)    : # Code référentiel n°9 /modèle comptable
Global Char    GLED10(GLONLED)(1..GGCMNBR)   : # Code référentiel n°10/modèle comptable
Global Char    GGCMSOC(GLONGCM)(1..GDIMSOC)  : # Modèle comptable/société 
Call INIGLBGCM
End


Subprog INIGLBGCM
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM     [GCM] : Endif

Raz GGCMNBR
For [GCM]GCM0
 GGCMNBR += 1
 GGCM(GGCMNBR)       = [F:GCM]GCM
 GLEDTYPGEN(GGCMNBR) = [F:GCM]GENLEDTYP
 GLEDGEN(GGCMNBR)    = [F:GCM]LED([F:GCM]GENLEDTYP-1)
 GLEDTYPANA(GGCMNBR) = [F:GCM]ANALEDTYP
 GLEDANA(GGCMNBR)    = [F:GCM]LED([F:GCM]ANALEDTYP-1)
 GLED1(GGCMNBR)      = [F:GCM]LED(0)
 GLED2(GGCMNBR)      = [F:GCM]LED(1)
 GLED3(GGCMNBR)      = [F:GCM]LED(2)
 GLED4(GGCMNBR)      = [F:GCM]LED(3)
 GLED5(GGCMNBR)      = [F:GCM]LED(4)
 GLED6(GGCMNBR)      = [F:GCM]LED(5)
 GLED7(GGCMNBR)      = [F:GCM]LED(6)
 GLED8(GGCMNBR)      = [F:GCM]LED(7)
 GLED9(GGCMNBR)      = [F:GCM]LED(8)
 GLED10(GGCMNBR)     = [F:GCM]LED(9)
Next
Raz GNBSOC
For [CPY] : # Where CPYLEGFLG=2
 GNBSOC += 1
 GSOC(GNBSOC)    = [F:CPY]CPY
 GDEVSOC(GNBSOC) = [F:CPY]ACCCUR
 GLEGSOC(GNBSOC) = [F:CPY]LEG
 GGCMSOC(GNBSOC) = [F:CPY]ACM
Next
End
