#**
#*
#* @deprecated Use <b>GET_FIY From FINPER_SYRA</b> instead.
#*
#*!
Subprog GETEXE(ACTX,CPY,LEDTYP,DAT,FIY)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    CPY
Value    Integer LEDTYP
Value    Date    DAT
Variable Decimal FIY

Local Integer ASTATUS
Local Char    ERRMES(250)

Local Integer WFIY    : WFIY    = FIY
[L]ASTATUS = func FINPER_SYRA.GET_FIY(ACTX,CPY,LEDTYP,DAT,WFIY,ERRMES)
FIY    = WFIY
End

#################################################################
#**
#* @deprecated Use <b>GET_PER From FINPER_SYRA</b> instead.
#*
#*!
Subprog GETPERSOC(ACTX, CPY, LEDTYP, DAT, FIY, PER)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    CPY
Value    Integer LEDTYP
Value    Date    DAT
Variable Decimal FIY
Variable Decimal PER

Local Integer ASTATUS
Local Char    ERRMES(250)

Local Integer WFIY    : WFIY    = FIY
Local Integer WPER    : WPER    = PER

[L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX,CPY,LEDTYP,DAT,WFIY,WPER,ERRMES)

FIY    = WFIY
PER    = WPER
End
