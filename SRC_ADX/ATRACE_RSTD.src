#<AdxTL>@(#)7.0.0.0 $Revision$
# Classe ATRACE


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_OPEN_AFTER"             : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_TRANS_AFTER"            : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"            : Gosub AQUERY_CLOSE_AFTER
      When "AQUERY_PRIMARYKEYS_AFTER"      : Gosub AQUERY_PRIMARYKEYS_AFTER
      When "AQUERY_DECODE_CRITERIA_AFTER"  : Gosub AQUERY_DECODE_CRITERIA_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return





$AQUERY_OPEN_AFTER
Local Instance  IVOLUME Using C_AVOLUME
Local Char      FILES(255)(1..)
Local Char      VOLUME(GLONAVL)
Local Char      PATH(250)
Local Char      ASCDESC(20):ASCDESC="asc"
Local Integer   NBFILES,I,IROW,KEEP
Local Integer   NAMELENGTH : NAMELENGTH=250
Local Char      TCIN(20)(1..),TCOUT(20)(1..)
Local Integer   KEEP
Local Datetime  FTIMESTAMP
Local Integer   FSIZE
Local Char      FCOMMENT(100)
Local Char EXTEND(20)

Local Char      QWHERE1(250),QWHERE2(250)
Local Char      QWHERE3(30)(1..)
Local Integer   P1,P2
Local Char      NAMELIKE(50) : NAMELIKE="(NAME like '"

[L]VOLUME  = "TRA"
[L]EXTEND  = "tra"

IVOLUME = NewInstance C_AVOLUME AllocGroup null
ASTATUS = fmet IVOLUME.AREAD(VOLUME)

If ASTATUS = CST_AERROR
 IVOLUME.VOLUME = VOLUME
 IVOLUME.TITLE  = "Fichiers de trace"
 #IVOLUME.VOLTYP = 1
 IVOLUME.ROOT = filpath(VOLUME,"","",nomap,"","")
 ASTATUS = fmet IVOLUME.AINSERT()
Endif

If !ASTATUS
 If FIRSTPAGE
  NBFILES = PQRY.QCOUNT+1
 Endif

 Gosub AQUERY_PRIMARYKEYS_AFTER

 If instr(1,INDEXES(PQRY.QASCEND),ASTDKEY)
  ASCDESC = "TIMESTAMP desc"
 Elsif INDEXES(PQRY.QASCEND) = "asc"
  ASCDESC = "TIMESTAMP asc"
 Endif

 P1 = instr(1,PQRY.QWHERE,NAMELIKE)
 If P1
  P2 = instr(P1,PQRY.QWHERE,"')")
  If P2
   QWHERE1 = left$(PQRY.QWHERE ,P2+1)
   QWHERE2 = right$(PQRY.QWHERE,P2+2)
  Endif
 Else
  QWHERE1 = ""
  QWHERE2 = PQRY.QWHERE
 Endif

 ASTATUS = fmet IVOLUME.LS([L]PATH,"",ASCDESC,QWHERE1,NBFILES,FILES)

 If !ASTATUS
  Local Char      TNAME(NAMELENGTH)(1..max(1,NBFILES))
  Local Datetime  TTIMESTAMP(1..max(1,NBFILES))
  Local Integer   TSIZE(1..max(1,NBFILES))
  Local Char      TCOMMENT(100)(1..max(1,NBFILES))

  Local File    (Char NAME(30),Datetime TIMESTAMP, Integer SIZE, Char COMMENT(100))
&             From Variable TNAME, TTIMESTAMP, TSIZE, TCOMMENT As [LNK_]

  Call SPLIT_QWHERE(QWHERE2,QWHERE3) From ASYRQRY

  TCIN(1)  = "TIMESTAMP"
  TCOUT(1) = "num$(FTIMESTAMP)"

  For I=1 To NBFILES
   KEEP = 0
   ASTATUS = fmet IVOLUME.GETFILEDATETIME(FILES(I),FTIMESTAMP)
   If !ASTATUS & pat(FILES(I),"*."+[L]EXTEND)>0
    If FIRSTPAGE or len(QWHERE2)=0
     KEEP  = 1
    Else
     KEEP = evalue(func ASYRQRY.QWHERE_2_EVALUE(QWHERE3,TCIN,TCOUT))
    Endif
    If KEEP
     ASTATUS = fmet IVOLUME.GETFILEINFO(FILES(I),7,FSIZE)
     ASTATUS = fmet IVOLUME.GETFILECOM(FILES(I),FCOMMENT)

     IROW += 1
     TNAME(IROW)       = left$(FILES(I),len(FILES(I))-4)
     TTIMESTAMP(IROW)  = FTIMESTAMP
     TSIZE(IROW)       = FSIZE
     TCOMMENT(IROW)    = FCOMMENT
     If IROW = (PQRY.QCOUNT+1) : Break :Endif
    Endif
   Endif
  Next I
  PQRY.QWHERE = 'NAME gt ""'
 Endif

Endif
FreeGroup IVOLUME
Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return

$AQUERY_TRANS_AFTER
this.ATRACE.NAME       = [LNK_]NAME
this.ATRACE.TIMESTAMP  = [LNK_]TIMESTAMP
this.ATRACE.SIZE       = [LNK_]SIZE
this.ATRACE.COMMENT    = [LNK_]COMMENT
Return

$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1 : TBPRO(NBPRO) = "NAME"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ATRACE.NAME"
             TBFIL(NBPRO) = "[LNK_]NAME"
NBPRO += 1 : TBPRO(NBPRO) = "COMMENT"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ATRACE.COMMENT"
             TBFIL(NBPRO) = "[LNK_]COMMENT"
NBPRO += 1 : TBPRO(NBPRO) = "SIZE"
           : TBTYP(NBPRO) =27 : TBPTH(NBPRO) = "ATRACE.SIZE"
             TBFIL(NBPRO) = "[LNK_]SIZE"
NBPRO += 1 : TBPRO(NBPRO) = "TIMESTAMP"
           : TBTYP(NBPRO) = 11 : TBPTH(NBPRO) = "ATRACE.TIMESTAMP"
             TBFIL(NBPRO) = "[LNK_]TIMESTAMP"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]TIMESTAMP desc"
Return

