########################################
Subprog AS_REFSTR(VALEUR)
Variable Date    VALEUR
Local Char VALPAR (10)
If val(GFLAG)=2
 If VALEUR=[0/0/0] : VALEUR=GMOIPAY : Endif
 [M:DIA]YEA=num$(year(VALEUR))
 [M:DIA]REFEND=eomonth(VALEUR)
Else
 Call PARAM("","DADYEA",VALPAR) From ADOVAL
 [M:DIA]YEA= VALPAR
 If VALEUR=[0/0/0] : VALEUR=gdat$(01,01,val([M:DIA]YEA)) : Endif
 [M:DIA]REFEND=addmonth(VALEUR, 12)-1
Endif
End

########################################
Subprog AM_REFSTR(VALEUR)
Variable Date    VALEUR
Call AM_REFSTR(VALEUR) From TRTTDS
End

########################################
Subprog AS_REFEND(VALEUR)
Variable Date    VALEUR
Call AS_REFEND(VALEUR) From TRTTDS
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From DIVPAYE
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
End
