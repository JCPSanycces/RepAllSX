##########################################################################################################
#   Ajout d'un destinataire                                         Module CRM         01 décembre 2000 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIBMAX3MODIF

  GIBMAX3MODIF = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GIBMAX3MODIF = 1 Then
    Call LOADRESULT(1,1) From TRTMAI4
    Affzo [M:MAI4]1-99
  Endif
  #Nettoie l'écran avant de partir.
  Raz [M:MAX3]
  Kill GIBMAX3MODIF
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Local Integer ICURLIGNE

  ICURLIGNE = nolign-1
  Case BOUT
    When "A"
      Gosub ONCHECK
    When "C"
      Gosub ONLOAD From TRTMAX3
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONCHECK
Local Char SZMESS(250)
Local Integer IOKREP

  IOKREP = 0
  If ICURLIGNE < 0 Then
    Return
  Endif
  If [M:MAX3]CCNNUM(ICURLIGNE) = "" Then
    GMESSAGE = mess(806,196,1) #Aucun interlocuteur n'est sélectionné. Vérification abandonnée.
    GERR = 2
    Return
  Endif
  Read [SCL]SCL1=GSZOPGNUM;"CCN";[M:MAX3]CCNNUM(ICURLIGNE)
  If fstat Then
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "GESOMM" or GNAVIG(GPILNAV-1) = "GESOMP" Then
        #Cet interlocuteur n'est pas inclus dans l'échantillon composant l'opération marketing.
        GMESSAGE = mess(677,182,1)
        GERR = 2
      Else
        #Cet interlocuteur n'est pas inclus dans la sélection.
        #Souhaitez-vous l'ajouter à la sélection ?
        SZMESS = mess(797,196,1) - mess(799,196,1)
        Call OUINON(SZMESS, IOKREP) From GESECRAN
        If IOKREP = 2 Then
          Gosub ONADD
        Endif
      Endif
    Else
      #Cet interlocuteur n'est pas inclus dans la sélection.
      #Souhaitez-vous l'ajouter à la sélection ?
      SZMESS = mess(797,196,1) - mess(799,196,1)
      Call OUINON(SZMESS, IOKREP) From GESECRAN
      If IOKREP = 2 Then
        Gosub ONADD
      Endif
    Endif
  Else
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "GESOMM" or GNAVIG(GPILNAV-1) = "GESOMP" Then
        #Cet interlocuteur est inclus dans l'échantillon composant l'opération marketing.
        GMESSAGE = mess(678,182,1)
        GERR = 2
      Else
        #Cet interlocuteur est déjà inclus dans la sélection.
        #Souhaitez-vous le supprimer de la sélection ?
        SZMESS = mess(357,196,1) - mess(800,196,1)
        Call OUINON(SZMESS, IOKREP) From GESECRAN
        If IOKREP = 2 Then
          Gosub ONDEL
        Endif
      Endif
    Else
      #Cet interlocuteur est déjà inclus dans la sélection.
      #Souhaitez-vous le supprimer de la sélection ?
      SZMESS = mess(357,196,1) - mess(800,196,1)
      Call OUINON(SZMESS, IOKREP) From GESECRAN
      If IOKREP = 2 Then
        Gosub ONDEL
      Endif
    Endif
  Endif
Return

##########################################################################################################
$ONADD
Local Integer INOBPR
Local Integer IMSEL

  INOBPR = 1
  IMSEL = 0
  GIBMAX3MODIF = 1
  #Teste si une sélection maitre a été définie précédemment.
  Filter [SEC] Where [F:SEC]OPGNUM = GSZOPGNUM and [F:SEC]SELTBL <> "CCN"
  For [SEC]
    IMSEL = 1
    Break
  Next
  Filter [SEC]
  Filter [CNT] Where [F:CNT]CCNCRM = [M:MAX3]CCNNUM(ICURLIGNE)
  For [CNT] CNT2
    If [F:CNT]BPATYP = 1 Then
      Call DEBTRANS From GLOCK
      Trbegin [SCL]
      [F:SCL]OPGNUM = GSZOPGNUM
      [F:SCL]RECTYP = "CCN"
      [F:SCL]RECNUM = [M:MAX3]CCNNUM(ICURLIGNE)
      If IMSEL Then
        [F:SCL]BPRNUM = [F:CNT]BPANUM
      Else
        [F:SCL]BPRNUM = ""
      Endif
      If GIDEFADD = 2 Then
        [F:SCL]BPAADD = ""
      Else
        If IMSEL Then
          If [F:SCL]BPRNUM = "" Then
            [F:SCL]BPAADD = ""
          Else
            Read [BPR]BPR0=[F:SCL]BPRNUM
            If fstat Then
              [F:SCL]BPAADD = ""
            Else
              [F:SCL]BPAADD = [F:BPR]BPAADD
            Endif
          Endif
        Else
          [F:SCL]BPAADD = ""
        Endif
      Endif
      Write [SCL]
      If fstat Then
        GMESSAGE = mess(100,141,1) #Erreur création
        GERR = 1
        Rollback
      Else
        Commit
      Endif
      INOBPR = 0
    Endif
  Next
  Filter [CNT]
  #Aucun tiers associé à l'interlocuteur. Il faut l'ajouter avec son adresse perso.
  If INOBPR Then
    Call DEBTRANS From GLOCK
    Trbegin [SCL]
    [F:SCL]OPGNUM = GSZOPGNUM
    [F:SCL]RECTYP = "CCN"
    [F:SCL]RECNUM = [M:MAX3]CCNNUM(ICURLIGNE)
    [F:SCL]BPRNUM = ""
    [F:SCL]BPAADD = ""
    Write [SCL]
    If fstat Then
      GMESSAGE = mess(100,141,1) #Erreur création
      GERR = 1
      Rollback
    Else
      Commit
    Endif
  Endif
Return

##########################################################################################################
# Suppression d'un destinataire
###############################################################
$ONDEL
  GIBMAX3MODIF = 1
  If [M:MAX3]CCNNUM(ICURLIGNE) <> "" Then
    Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN" and [F:SCL]RECNUM = [M:MAX3]CCNNUM(ICURLIGNE)
    For [SCL] SCL1
      Call DEBTRANS From GLOCK
      Trbegin [SCL]
      Delete [SCL]Curr
      If fstat Then
        GMESSAGE = mess(425,196,1) #Erreur lors de la suppression du destinataire. Opération refusée.
        GERR = 1
        Unlock [SCL]
        Rollback 
        # FGR 09/02/2010 : X3SUIVI60986
        #Return
        Break
      Else
        Commit
        Unlock [SCL]
      Endif
    Next
    Filter [SCL]
    If GERR Then
      # FGR 09/02/2010 : X3SUIVI60986
      Return
    Endif
  Else
    GMESSAGE = mess(801,196,1) #Aucun interlocuteur n'est sélectionné. Suppression refusée.
    GERR = 2
    Return
  Endif
Return
