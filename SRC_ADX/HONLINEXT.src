#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","HONLINEXT","DHONLINEX",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

$OUVRE
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif
If clalev([F:DAE1])=0 : Local File GACCENTRYD [DAE1] : Endif
If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif
If clalev([F:DAE3])=0 : Local File GACCENTRYD [DAE3] : Endif
If clalev([F:BPS])=0  : Local File BPSUPPLIER [BPS]  : Endif
If clalev([F:PRV])=0  : Local File HONPRV     [PRV]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:HLN])=0  : Local File HONLIN     [HLN]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:PYD])=0  : Local File PAYMENTD   [PYD]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV      [ACV]  : Endif
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]  : Endif
Return

$INIT
Gosub OUVRE
TMP = 1 : TRA = 1
Return

$INIT_DIA
Return

$EXEC
Call HONLINEXT
Return

Subprog HONLINEXT
Gosub DECLARE
Gosub OUVRE
TIT = mess(14,122,1) : # Extraction des lignes d'honoraires

Call LECTURE("CPY",[M:DIA]CPY,"") From CONTOBJ
Call LECTURE("TCU",[F:CPY]ACCCUR,"") From CONTOBJ
NBDEC = 1/(10^[F:TCU]DECNBR)

# Pourcentage de retenue à la source pour la TVA nette s/droits auteur & inventeur
Call PARAM([M]CPY,"PRCRETVAT",PARAM) From ADOVAL
PTVA = val(PARAM)/100

If GSERVEUR
 [M:DIA]TRC = 2
Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

If [M:DIA]TRC=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(104,"-"),0) From GESECRAN
Endif

If [M]ALLFCY=2
 SYMBOLE = "HONLIN"+"\"+[M]CPY
Else
 SYMBOLE = "HONLIN"+"\"+[M]CPY+"\"+[M]FCY
Endif
Lock =SYMBOLE
If fstat
 # Opération en cours sur autre poste
 Call ECR_TRACE(mess(30,100,1),1) From GESECRAN : End
Endif

If func AFNC.PARAM("ITARTZ",[M]CPY)="2"
 FLGKIB = 1
Else
 FLGKIB = 0
Endif

Filter [GTE] Where LEG=[F:CPY]LEG| LEG="" Order By Key CLE=TYP Asc ; LEG Desc
Local Char    TTYPREG(GLONGTE)(1..rowcount([F:GTE])+1) : # Table types pièces de règlement
Local Char    TTYPDAS(GLONGTE)(1..rowcount([F:GTE])+1) : # Table types pièces DAS2

Raz NBTYPREG,TTYPREG,NBTYPDAS,TTYPDAS
For [GTE]CLE(1)
 If [F:GTE]DAS2=2
  NBTYPDAS += 1
  TTYPDAS(NBTYPDAS) = [F:GTE]TYP
 Endif
 If [F:GTE]VATPAI=2
  NBTYPREG += 1
  TTYPREG(NBTYPREG) = [F:GTE]TYP
 Endif
Next
Filter [GTE]

Gosub CRITERE
Call DEBTRANS From GLOCK
Gosub TR1

If GOK<1 & [M:DIA]TRC=2
 Call ECR_TRACE(mess(17,107,1),1) From GESECRAN : # Rollback
Endif

If !NBLIN
 Call ECR_TRACE(mess(15,122,1),0) From GESECRAN : # Aucune ligne d'honoraire à traiter
Endif
If !GSERVEUR & [M:DIA]TRC=2
 Call FERME_TRACE From LECFIC
Endif

Unlock =SYMBOLE
End

$DECLARE
Local Integer OK,NBLIN,N,I,AFF,OKLEC
Local Integer NBTYPREG           : # Nombre de types de pièces de règlement
Local Integer NBTYPDAS           : # Nombre de types de pièces DAS2
Local Char    CRITHLN(250),CRITDAE(250),CRITDAE1(250)
Local Char    SYMBOLE(30)
Local Char    TIT(70)
Local Char    PREST(GLONPRV)
Local Char    PARAM(GLONADW)
Local Decimal TTC                : # Total TTC d'une pièce
Local Decimal HT                 : # Total HT d'une pièce
Local Decimal MTREG              : # Montant du règlement
Local Decimal TOTFAC             : # Total des factures lettrées avec le règlement
N = len(mess(0,615,1))           : # 615 Types d'honoraires
Local Decimal HTDAS(1..N)        : # Montant HT par type d'honoraire d'une pièce
Local Decimal MTDAS(1..N)        : # Montant à déclarer par type d'honoraire
Local Decimal PTVA               : # % de retenue sur TVA nette (0.8=Frce,0.4=DOM)
Local Decimal TOTRET             : # Total TVA nette s/Droits pour 1 groupe lettrage
Local Decimal TOTRETSRC          : # Total retenue à la source pour 1 groupe de lettrage
Local Decimal TOTDTS(1..2)       : # Total /Droits pour 1 groupe lettrage
Local Decimal NBDEC              : # Nombre de décimales de la devise locale
Local Integer SNS(1..N)          : # Sens comptable des comptes DAS2
Local Decimal HTNONDAS           : # Montant HT sur compte non dassable
Local Decimal TTCNONDAS          : # Montant TTC sur compte non dassable
Local Decimal TVANONDAS          : # Montant TVA sur compte non dassable
Local Decimal TOTNONDAS
Local Decimal MT
Local Integer TYP_REG, STAT
Local Char    NUMREG(GLONVCR)
Local Decimal PRORATA
Local Decimal MTREGFAC
Local Integer FLGKIB
Local Decimal INDHTDAS(1..N)     : # Montant HT par type d'honoraire d'une pièce
Local Decimal INDTTCDAS(1..N)    : # Montant TTC par type d'honoraire d'une pièce
Local Char    SVGTAX(GLONVAT)    : # Svg d'un code taxe de la pièce
Local Integer FLGTAX             : # Indicateur si pièce est muti code taxe
Local Integer FLGNAT             : # Indicateur si pièce est muti compte de différentes natures de prestations
Local Integer OKREG
Return

$CRITERE
# Critère sur HONLIN pour faire la RAZ
CRITHLN = 'CPY = "'+[M:DIA]CPY+'"'
CRITHLN -= '& ACCNUM <> 0'
If [M:DIA]ALLFCY<>2
 CRITHLN -= '& FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLPRVNUM<>2
 CRITHLN -= '& PRVNUM = "'+[M:DIA]PRVNUM+'"'
Endif
If [M:DIA]ALLHON<>2
 CRITHLN -= '& HON = '+num$([M:DIA]HON)
Endif
If [M:DIA]STRDAT<>[0/0/0]
 CRITHLN -= '& DAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITHLN -= '& DAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
Endif

# Critère sur GACCENTRYD pour rechercher les règlements
Call SETMAINREF([M:DIA]CPY,GTYPGEN,GTYPANA) From CPTDIV
CRITDAE  = 'CPY = "'+[M:DIA]CPY+'"'
CRITDAE -= '& LEDTYP='+num$(GTYPGEN)
If [M:DIA]ALLFCY<>2
 CRITDAE -= '& FCYLIN = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]STRDAT<>[0/0/0]
 CRITDAE -= '& ACCDAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITDAE -= '& ACCDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
Endif
If [M:DIA]ALLPRVNUM<>2
 CRITDAE -= '& BPR = "'+[M:DIA]PRVNUM+'"'
Else
 CRITDAE -= '& BPR <>""'
Endif
CRITDAE -= '& MTC<>"" & find(TYP,TTYPREG(1..NBTYPREG))'

# Critère sur GACCENTRYD pour rechercher les factures
CRITDAE1  = 'CPY = "'+[M:DIA]CPY+'"'
CRITDAE1 -= '& LEDTYP='+num$(GTYPGEN)
# Si OPT ="2", on exploitera plus loin le flag DAS2 de la pièce correspondant à la facture....
CRITDAE1 -= "& find(TYP,TTYPDAS(1.."+num$(NBTYPDAS)+"))"
GPOINT = "CRITERE" :  Gosub ENTREE From EXEFNC
Return


$TR1
Trbegin [HLN]
 Gosub DEL_HONLIN
 If GOK<1 : Return : Endif
 # Recherche des règlements de factures d'honoraires
 Filter [DAE] Where evalue(CRITDAE) Order By Key CLE = BPR;FCYLIN;ACCDAT;ACC;MTC;NUM;ACCNUM
 For [DAE]CLE(1)
  Raz PREST
  For [DAE]CLE(6)
   Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
   NUMREG = vireblc(right$([F:DAE]REFINTLIN,4),2)
   If !fstat & ([F:HAE]STA=2 or [M:DIA]DASSTA=2) & ([F:HAE]DUDDAT<=[M:DIA]DATPCE or [M:DIA]DATPCE=[0/0/0])
    Call LEC_BPS([F:DAE]BPR) From CPTLEC
    If !fstat & [F:BPS]DADFLG=2
     If [F:BPS]PRVNUM=""
      If [M:DIA]TRC=2 & PREST<>[F:BPS]BPSNUM
       If AFF : Call ECR_TRACE("",0) From GESECRAN : Endif
       Call ECR_TRACE ([F:BPS]BPSNUM,0) From GESECRAN
       Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
       AFF =0
      Endif
      PREST = [F:BPS]BPSNUM
     Else
      If [M:DIA]TRC=2 & PREST<>[F:BPS]PRVNUM
       If AFF : Call ECR_TRACE("",0) From GESECRAN : Endif
       Call ECR_TRACE ([F:BPS]BPSNUM-mess(17,122,1)-[F:BPS]PRVNUM,0) From GESECRAN
       Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
       AFF = 0
      Endif
      PREST = [F:BPS]PRVNUM
     Endif
    Else : # Le prestataire peut être un actionnaire et non un fournisseur
     fstat = 0
     If [F:PRV]PRVNUM<>[F:DAE]BPR
      Read [F:PRV]PRV0 = [F:DAE]BPR
     Endif
     If !fstat
      If [M:DIA]TRC=2 & PREST<>[F:DAE]BPR
       If AFF : Call ECR_TRACE("",0) From GESECRAN : Endif
       Call ECR_TRACE ([F:PRV]PRVNUM-mess(17,122,1),0) From GESECRAN
       Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
       AFF = 0
      Endif
      PREST = [F:PRV]PRVNUM
     Else
      Raz PREST
     Endif
    Endif
    If PREST<>""
     Look [PRV]PRV0 = PREST
     If !fstat
      Gosub TR_FAC
      If GOK<1 : Break : Endif
     Else
      If [M:DIA]TRC=2
       Call ECR_TRACE(mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM-":"-mess(5,122,1)-PREST,1) From GESECRAN
       # Piece typ num : prestataire inexistant xxxxxx
      Endif
     Endif
    Endif : # PREST<>""
   Endif
  Next
 Next
 Filter [DAE]
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Return

$DEL_HONLIN
If [M:DIA]RAZDAS=2
 Delete [HLN] Where evalue(CRITHLN)
 If fstat=1
  GOK = -1 : GLOCK="$HONLIN" : Goto ROLL_TR1
 Elsif fstat>5
  GOK = 0 : Call RSTA("HLN","") From GLOCK : Goto AB_TR1
 Endif
Endif
Return

$TR_FAC
#Recherche des factures qui lettrent le règlement
Raz TOTRET,TOTRETSRC,TOTDTS,TOTFAC,SNS

## Demande 20401 : si KIB est actif (gestion 'ritenzione' retenue à la source,
## le compte de retenue à la source se trouve sur la pièce de règlement (pour les types de retenues sur règlement))
If FLGKIB
 Filter [DAE1] Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=GTYPGEN
 Link [DAE1] With [GAC]GAC0~=[F:DAE1]COA;[F:DAE1]ACC As [LNK]
&            Where [F:GAC]DASTYP=11 or [F:GAC]DASTYP=12
 For [LNK]
   Case [F:GAC]DASTYP
    When 11 : TOTRETSRC +=[F:DAE1]AMTLED*[F:DAE1]SNS
    When 12 : TOTRET +=[F:DAE1]AMTLED*[F:DAE1]SNS
              SNS(12) = [F:GAC]SNSBLC
              If [F:GAC]DASTYP=[M:DIA]HON | [M:DIA]ALLHON=2
               HTDAS(12) +=[F:DAE1]AMTLED*[F:DAE1]SNS
               SNS(12) = [F:GAC]SNSBLC
              Endif
   Endcase
 Next
 Filter [DAE1]
Endif

Raz TOTNONDAS
MTREG = 0
For [DAE3] Where TYP=[F:DAE]TYP & NUM=[DAE]NUM & ACC=[DAE]ACC & BPR=[DAE]BPR & MTC=[DAE]MTC & LEDTYP=GTYPGEN
 MTREG  += [F:DAE3]AMTLED*[F:DAE3]SNS
Next

GPE = 0
GPOINT = "TRTFAC" : Gosub ENTREE From EXEFNC
If GPE = 1 : Return : Endif

Link [DAE1] With [HAE]HAE0~=[F:DAE1]TYP;[F:DAE1]NUM As [LNK]
&           Where [F:DAE1]MTC=[F:DAE]MTC & [F:DAE1]BPR=[F:DAE]BPR & [F:DAE1]SAC=[F:DAE]SAC &
&                   [F:DAE1]ACC=[F:DAE]ACC & evalue(CRITDAE1) & [F:HAE]FLGDAS=2

# On calcule par groupe de lettrage
# Règle 1 : Un compte prestataire par pièce de facture
# Règle 2 : Les droits d'auteurs & inventeurs ne doivent pas être comptabilisés
# avec d'autres types d'honoraires
# Règle 3 : On ne lettre pas un règlement avec 2 factures de droits d'auteurs
# qui pour l'une applique la TVA nette s/droits et pour l'autre la retenue à la source

Columns [LNK] ([DAE1]TYP,[DAE1]NUM,[HAE]ACCDAT,[HAE]CUR)
For [LNK]
 OKREG = 0
 If NUMREG = ""
  OKREG = 1
 Else
  For [PYD]PYD0 Where NUM = NUMREG & (VCRNUM="" or (VCRTYP = [F:DAE1]TYP & VCRNUM = [F:DAE1]NUM))
   OKREG=1 : Break
  Next
 Endif
 If OKREG
   For [DAE2]DAE0 Where TYP=[F:DAE1]TYP & NUM=[F:DAE1]NUM & LEDTYP=GTYPGEN
    If [F:DAE2]MTC=[F:DAE]MTC & [F:DAE2]BPR=[F:DAE]BPR & [F:DAE2]SAC=[F:DAE]SAC &
&      [F:DAE2]ACC=[F:DAE]ACC
     TOTFAC +=[F:DAE2]AMTLED*[F:DAE2]SNS
    Else
     Call LEC_GAC([F:DAE2]ACC,[F:DAE2]COA) From CPTLEC
     If !fstat
      Case [F:GAC]DASTYP
       When 6  : TOTDTS(1) +=[F:DAE2]AMTLED*[F:DAE2]SNS
                 SNS(6) = [F:GAC]SNSBLC
       When 7  : TOTDTS(2) +=[F:DAE2]AMTLED*[F:DAE2]SNS
                 SNS(7) = [F:GAC]SNSBLC
       When 11 : TOTRETSRC +=[F:DAE2]AMTLED*[F:DAE2]SNS
       When 12 : TOTRET +=[F:DAE2]AMTLED*[F:DAE2]SNS
                 SNS(12) = [F:GAC]SNSBLC
      Endcase
     Endif
     If !fstat & find([F:GAC]FLGVAT,1,2) & [F:GAC]DAS<>2
      TOTNONDAS += [F:DAE2]AMTLED*[F:DAE2]SNS
     Endif
    Endif
   Next
  Endif
Next

# Il faut retrancher le montant de la retenue à la source au montant DAS des droits
# Il faut recalculer la part TVA pour l'ajouter au montant DAS des droits

If SNS(6)=2 : TOTDTS(1) = TOTDTS(1)*(-1) : Endif
If SNS(7)=2 : TOTDTS(2) = TOTDTS(2)*(-1) : Endif
If SNS(12)=2 : TOTRET = TOTRET*(-1) : Endif

If TOTRET<>0
 If TOTDTS(1)<>0 & ([F:GAC]DASTYP=6 | [M:DIA]ALLHON=2) & TOTFAC<>0 & (TOTDTS(1)+TOTDTS(2)<>0)
  MTDAS(6) = (TOTRET+(PTVA*(TOTDTS(1)+TOTDTS(2)))) * (TOTDTS(1)/(TOTDTS(1)+TOTDTS(2)))
&           * abs((MTREG/TOTFAC))
  I = 6
  Gosub MAJ_HONLIN
  If GOK<1 : Return : Endif
 Endif
 If TOTDTS(2)<>0 & ([F:GAC]DASTYP=7 | [M:DIA]ALLHON=2) & TOTFAC<>0  & (TOTDTS(1)+TOTDTS(2)<>0)
  MTDAS(7) = (TOTRET+(PTVA*(TOTDTS(1)+TOTDTS(2)))) * (TOTDTS(2)/(TOTDTS(1)+TOTDTS(2)))
&           * abs((MTREG/TOTFAC))
  I=7
  Gosub MAJ_HONLIN
  If GOK<1 : Return : Endif
 Endif
Elsif TOTRETSRC<>0
 If TOTDTS(1)<>0 & ([F:GAC]DASTYP=6 | [M:DIA]ALLHON=2) & TOTFAC<>0  & (TOTDTS(1)+TOTDTS(2)<>0)
  MTDAS(6) = TOTRETSRC * (TOTDTS(1)/(TOTDTS(1)+TOTDTS(2))) * abs((MTREG/TOTFAC))
  I = 6
  Gosub MAJ_HONLIN
  If GOK<1 : Return : Endif
 Endif
 If TOTDTS(2)<>0 & ([F:GAC]DASTYP=7 | [M:DIA]ALLHON=2) & TOTFAC<>0  & (TOTDTS(1)+TOTDTS(2)<>0)
  MTDAS(7) = TOTRETSRC * (TOTDTS(2)/(TOTDTS(1)+TOTDTS(2))) * abs((MTREG/TOTFAC))
  I = 7
  Gosub MAJ_HONLIN
  If GOK<1 : Return : Endif
 Endif
Endif

For [LNK]
 OKREG = 0
 If NUMREG = ""
  OKREG = 1
 Else
  For [PYD]PYD0 Where NUM = NUMREG & (VCRNUM="" or (VCRTYP = [F:DAE1]TYP & VCRNUM = [F:DAE1]NUM))
   OKREG=1 : Break
  Next
 Endif
 If OKREG

  Raz TTC,HT,HTDAS,MTDAS,OK,HTNONDAS,TTCNONDAS,TVANONDAS
  Raz INDHTDAS, INDTTCDAS, FLGTAX, FLGNAT, SVGTAX

   # Parcours des lignes des factures
   For [DAE2]DAE0 Where TYP=[F:DAE1]TYP & NUM=[F:DAE1]NUM & LEDTYP=GTYPGEN

    If [F:DAE2]MTC=[F:DAE]MTC & [F:DAE2]BPR=[F:DAE]BPR & [F:DAE2]SAC=[F:DAE]SAC &
&      [F:DAE2]ACC=[F:DAE]ACC
     TTC +=[F:DAE2]AMTLED*[F:DAE2]SNS
    Else
     Call LEC_GAC([F:DAE2]ACC,[F:DAE2]COA) From CPTLEC
     If !fstat & [F:GAC]DAS=2 & ([F:GAC]DASTYP=[M:DIA]HON | [M:DIA]ALLHON=2)
      HTDAS([F:GAC]DASTYP) +=[F:DAE2]AMTLED*[F:DAE2]SNS
      SNS([F:GAC]DASTYP) = [F:GAC]SNSBLC
      OK = 1
     Elsif !fstat & find([F:GAC]FLGVAT,1,2) :# LS 20/08/99 HT occultait les autres comptes débit de la pièce
      HT +=[F:DAE2]AMTLED*[F:DAE2]SNS
     Endif
     If !fstat & find([F:GAC]FLGVAT,1,2) & [F:GAC]DAS<>2
      HTNONDAS += [F:DAE2]AMTLED*[F:DAE2]SNS
      ## Difficile de retrouver le montant de TVA du compte non dassable... : on le recalcule...
      Call CALTAXE([F:DAE2]CPY,[F:HAE]ACCDAT,"",[F:HAE]CUR,1,[F:DAE2]TAX,1,[F:DAE2]AMTLED*[F:DAE2]SNS,
&                 TVANONDAS,MT,TYP_REG,STAT) From SUBTVT
      If TYP_REG<>1 & (dim([M]CEEFLG)<0 | TYP_REG<>4 | [M]CEEFLG<>2)
       Raz TVANONDAS, MT
      Endif
      TTCNONDAS += ([F:DAE2]AMTLED*[F:DAE2]SNS+TVANONDAS)*-1
     Endif
     Call LEC_GAC([F:DAE2]ACC,[F:DAE2]COA) From CPTLEC
     If !fstat  & [F:GAC]DAS=2
      INDHTDAS([F:GAC]DASTYP)+=[F:DAE2]AMTLED*[F:DAE2]SNS
      Call CALTAXE([F:DAE2]CPY,[F:HAE]ACCDAT,"",[F:HAE]CUR,1,[F:DAE2]TAX,1,[F:DAE2]AMTLED*[F:DAE2]SNS,
&                  TVANONDAS,MT,TYP_REG,STAT) From SUBTVT
      INDTTCDAS([F:GAC]DASTYP)+=([F:DAE2]AMTLED*[F:DAE2]SNS+MT)*-1
     Endif
     # Détection d'un pièce contenant plusieurs code taxe.
     If !FLGTAX & [F:DAE2]TAX<>""
      If SVGTAX=""
       SVGTAX=[F:DAE2]TAX
      Elsif SVGTAX<>[F:DAE2]TAX
       FLGTAX=1
      Endif
     Elsif !FLGTAX & [F:DAE2]TAX=""
      If SVGTAX<>""
       FLGTAX=1
      Endif
     Endif
    Endif
   Next

   MTREGFAC = 0 : OKLEC = 0
   If NUMREG<>""
    For [PYD]PYD0 Where NUM = NUMREG & VCRTYP = [F:DAE1]TYP & VCRNUM = [F:DAE1]NUM & ACCTYP=1
     MTREGFAC += [F:PYD]PAYLOCLIN : OKLEC = 1
    Next
   Endif
   PRORATA = 1
   If TTC<>0 & OKLEC
    PRORATA = abs(MTREGFAC)/abs(TTC)
   Endif

   ### Si l'avoir est lettré à la facture dès la comptabilisation de l'avoir,
   # le règlement est donc à la hauteur du solde entre la facture et son avoir
   # et l'avoir n'apparait donc pas dans le règlement
   # dans ce cas de figure, il ne faut pas prendre en compte l'avoir. (DdM40740)
   If !OKLEC
    Read [PIH]PIH0 = [F:DAE1]NUM
    If !fstat & [F:PIH]INVNUM<>""
     For [PYD]PYD0 Where NUM = NUMREG &  VCRNUM = [F:PIH]INVNUM & ACCTYP=1
      Raz OK : Break
     Next
    Endif
   Endif

   If OK : # La pièce comptabilise un compte de type DAS2
    HT += sigma(1,5,HTDAS(indcum))   : # Pas de droits ni de TVA s/droits
    HT += sigma(8,11,HTDAS(indcum))
    HT = arr(HT*PRORATA,NBDEC)
    TTC = arr(TTC*PRORATA,NBDEC)
    HTNONDAS = arr(HTNONDAS*PRORATA,NBDEC)
    TTCNONDAS = arr(TTCNONDAS*PRORATA,NBDEC)
    For I=1 To N
     INDHTDAS(I)  = arr(INDHTDAS(I)*PRORATA,NBDEC)
     INDTTCDAS(I) = arr(INDTTCDAS(I)*PRORATA,NBDEC)
     # Détection du nombre de nature de prestation pour une pièce.
     If HTDAS(I)<>0 : FLGNAT+=1 : Endif
    Next

    # Cas particulier si la pièce est multi_taxe (FLGTAX=1) et multi nature de prestation (FLGNAT>1)
    If FLGNAT>1 & FLGTAX
     For I=1 To N
      HTDAS(I) = arr(HTDAS(I)*PRORATA,NBDEC)
      # Droits auteurs & inventeurs, Retenue à la source, TVA nette s/droits auteurs
      If find(I,6,7,11,12) & max((TOTFAC-TOTNONDAS),MTREG)<>0
       MTDAS(I) = HTDAS(I)*(MTREG/max((TOTFAC-TOTNONDAS),MTREG))
      Elsif INDHTDAS(I)<>0
       If !OKLEC & max(abs(TOTFAC),abs(MTREG))<>0
        MTDAS(I) = HTDAS(I)*INDTTCDAS(I)/INDHTDAS(I)*(MTREG/max(abs(TOTFAC),abs(MTREG)))
       Elsif max((TOTFAC-TOTNONDAS),MTREG)<>0
        If TOTFAC>0 & MTREG<0
         MTDAS(I) = HTDAS(I)*INDTTCDAS(I)/INDHTDAS(I)*MTREG/min((TOTFAC-TOTNONDAS),MTREG)
        Else
         MTDAS(I) = HTDAS(I)*INDTTCDAS(I)/INDHTDAS(I)*MTREG/max((TOTFAC-TOTNONDAS),MTREG)
        Endif
       Endif
      Endif
      # MTDAS(I) prend le même signe que HTDAS(I)
      If (MTDAS(I)>0 & HTDAS(I)<0) |(MTDAS(I)<0 & HTDAS(I)>0)
       MTDAS(I) = MTDAS(I)*(-1)
      Endif
      # TVA nette s/droits
      If SNS(I)=2 : MTDAS(I) = MTDAS(I)*(-1) : Endif
      If MTDAS(I)<>0
       AFF = 1
       Gosub MAJ_HONLIN
       If GOK<1 : Break 2 : Endif
      Endif: # MTDAS(i)<>0
     Next I
    Else
     For I=1 To N
      HTDAS(I) = arr(HTDAS(I)*PRORATA,NBDEC)
      # Droits auteurs & inventeurs, Retenue à la source, TVA nette s/droits auteurs
      If find(I,6,7,11,12) & max((TOTFAC-TOTNONDAS),MTREG)<>0
       MTDAS(I) = HTDAS(I)*(MTREG/max((TOTFAC-TOTNONDAS),MTREG))
      Elsif HT-HTNONDAS<>0
       If !OKLEC & max(abs(TOTFAC),abs(MTREG))<>0
        MTDAS(I) = ((HTDAS(I)*(TTC-TTCNONDAS))/(HT-HTNONDAS))*(MTREG/max(abs(TOTFAC),abs(MTREG)))
       Elsif max((TOTFAC-TOTNONDAS),MTREG)<>0
        If TOTFAC>0 & MTREG<0
         MTDAS(I) = ((HTDAS(I)*(TTC-TTCNONDAS))/(HT-HTNONDAS))*(MTREG/min((TOTFAC-TOTNONDAS),MTREG))
        Else
         MTDAS(I) = ((HTDAS(I)*(TTC-TTCNONDAS))/(HT-HTNONDAS))*(MTREG/max((TOTFAC-TOTNONDAS),MTREG))
        Endif
       Endif
      Endif
      # MTDAS(I) prend le même signe que HTDAS(I)
      If (MTDAS(I)>0 & HTDAS(I)<0) |(MTDAS(I)<0 & HTDAS(I)>0)
       MTDAS(I) = MTDAS(I)*(-1)
      Endif
      # TVA nette s/droits
      If SNS(I)=2 : MTDAS(I) = MTDAS(I)*(-1) : Endif
      If MTDAS(I)<>0
       AFF = 1
       Gosub MAJ_HONLIN
       If GOK<1 : Break 2 : Endif
      Endif: # MTDAS(i)<>0
     Next I
    Endif
   Endif : # OK
  Endif
Next : # DAE1
Columns [LNK]
Filter [DAE1]
Return

$MAJ_HONLIN
Filter [HLN] Where FCY=[F:DAE]FCYLIN & PRVNUM=PREST & DAT=[F:DAE]ACCDAT & HON=I
Read [HLN]HLN0 Last
If !fstat
 LIN = [F:HLN]LINNUM + 1
Else
 LIN = 1
Endif
Filter [HLN]
Raz [F:HLN]
[F:HLN]CPY    = [M:DIA]CPY
[F:HLN]FCY    = [F:DAE]FCYLIN
[F:HLN]PRVNUM = PREST
[F:HLN]DAT    = [F:DAE]ACCDAT
[F:HLN]AMTLOC = arr(MTDAS(I),NBDEC)
[F:HLN]HON    = I
[F:HLN]LINNUM = LIN
[F:HLN]ACCNUM = [F:DAE]ACCNUM : # Règlement
[F:HLN]TYPINV = [F:DAE2]TYP   : # Facture
[F:HLN]NUMINV = [F:DAE2]NUM   : # Facture
Write [HLN]
If fstat
 GOK = 0 : Call FSTA("HLN") From GLOCK : Return
Endif
If [M:DIA]TRC=2
 Call ECR_TRACE (format$("D:"+GFMDAT,[F:DAE]ACCDAT)-[F:DAE]TYP-[F:DAE]NUM-mess(16,122,1)
& -[F:DAE2]TYP-[F:DAE2]NUM-mess(I,615,1)-num$([F:HLN]AMTLOC),0) From GESECRAN
Endif
NBLIN +=1
Return

