#<AdxTL>@(#)107.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"DEXPPAR","SAIEXPPAR","") From GSAISIE
End

###############################################################
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"DEXPPAR","SAIEXPPAR","") From GSAISIE
End

###############################################################
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "OK"           : Gosub ENREG
 When "FIN"          : Gosub FIN
 When Default
Endcase
Return

###############################################################
$OUVRE
Local File    APARIMPEXP [APX]
Return

###############################################################
$DEBUT
Local Integer LOK
Local Mask    IMPEXPPAR [DIA]

Gosub LIRE
If GPROFIL<>GSUPER
 Grizo
Else
 Lock EXPORT  With lockwait=0
 If fstat
  GERR = 1 : GMESSAGE = mess(10,100,1)
  Grizo
 Else
  LOK = 1
 Endif
Endif
Affzo
Return

###############################################################
$FIN
If LOK
 Unlock EXPORT
Endif
Return

###############################################################
$LIRE
Raz [M]
Call LECADO("REPEXPDEF",[M]REPEXPDEF)
Call LECADO("REPEXPTMP",[M]REPEXPTMP)
Call LECADO("REPIMPDEF",[M]REPIMPDEF)
Call LECADO("REPIMPTMP",[M]REPIMPTMP)
Call LECADO("REPIMPFIN",[M]REPIMPFIN)
Call LECADO("REPIMPERR",[M]REPIMPERR)
[M]EXPORT = [C]EXPORT
Return

Subprog LECADO(CODE,ZONE)
Value    Char    CODE
Variable Char    ZONE
ZONE = ""
Read [APX]APX0 = CODE
If !fstat
 ZONE = [F:APX]DIRECTORY
Endif
End

###############################################################
$ENREG
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK=1
Trbegin [APX]
 Call ECRADO("REPEXPDEF",[M]REPEXPDEF,mess(67,141,1))
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Call ECRADO("REPEXPTMP",[M]REPEXPTMP,mess(67,141,1))
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Call ECRADO("REPIMPDEF",[M]REPIMPDEF,mess(67,141,1))
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Call ECRADO("REPIMPTMP",[M]REPIMPTMP,mess(67,141,1))
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Call ECRADO("REPIMPFIN",[M]REPIMPFIN,mess(67,141,1))
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Call ECRADO("REPIMPERR",[M]REPIMPERR,mess(67,141,1))
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 [C]EXPORT = [M]EXPORT
 If fstat=1
  GOK=-1 : GLOCK="@EXPORT" : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call FSTA("@EXPORT") From GLOCK : Goto AB_TR1
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

Subprog ECRADO(CODE,ZONE,COMMENT)
Value    Char    CODE
Variable Char    ZONE
Value    Char    COMMENT
Local Char    TEMPO(80)
Local Integer IND
Readlock [APX]APX0 = CODE
If fstat=1
 GOK = -1 : GLOCK = "$APARIMPEXP"-CODE
 End
Elsif fstat
 Raz [F:APX]
 [F:APX]COD = CODE
 [F:APX]DIRECTORY = ZONE
 Write [APX]
Else
 [F:APX]DIRECTORY = ZONE
 Rewrite [APX]
Endif
If fstat
 GOK = 0 : Call FSTA("APX") From GLOCK
Endif
End

Subprog C_REPEXPDEF(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL(2, VALEUR,[M]REPEXPDEF,E_TYPE_FOLDER,GMESSAGE)
End

Subprog C_REPEXPTMP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL(2, VALEUR,[M]REPEXPTMP,E_TYPE_FOLDER,GMESSAGE)
End

Subprog C_REPIMPDEF(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local Char FULLPATH(250)
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL(2, VALEUR,[L]FULLPATH,E_TYPE_FOLDER,GMESSAGE)
End

