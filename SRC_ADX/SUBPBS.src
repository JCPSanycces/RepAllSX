#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
Call OBJET("PBS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LIENS2"     : Gosub LIENS
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "APRES_CHOI" : Gosub APRES_CHOI
Endcase
Return

$OUVRE
Local Integer NBBSE
Local Integer TTRI
TTRI = 1
If CLE2=""
 CLE2 = "1"
Endif
NBBSE = dim([F:GAC]BSECDT)
Return

$SETBOUT
Call VIREBOUT(CHAINE,"AH") From GOBJET
If REP<>""
 Call VIREBOUT(CHAINE,"UBO") From GOBJET
Else
 CHAINE+="<>"
Endif
Return

$EXEBOUT
Case REP
 When "B"
  Gosub TRTTRI
  Affzo [PBS1]
Endcase
Return

$APRES_CHOI
Case REPONSE
 When GSTASUI : Gosub SUIVANT   #: REPONSE = 0
 When GSTAPRE : Gosub PRECEDENT #: REPONSE = 0
Endcase
Return

$LIENS
[M:PBS1]CRIAFF = TTRI
Gosub TRTTRI
Return

$PRECEDENT
Gosub DEVERROU From GOBJET
ONUM = [M:PBS1]NUM
Raz [M:PBS1]
[M:PBS1]NUM = ONUM-1
If [M:PBS1]NUM=0 : [M:PBS1]NUM=NBBSE : Endif
Read [PBS]PBS0 = [M:PBS1]NUM
If fstat<=2
 CLE2 = num$([F:PBS]NUM)
 [M:PBS1]NUM = [F:PBS]NUM
 Gosub RELIT From GOBJET
 REPONSE= 0
Else
 [M:PBS1]CRIAFF = TTRI
 REPONSE=93 : REP="C"
 Affzo
Endif
Return

$SUIVANT
Gosub DEVERROU From GOBJET
ONUM = [M:PBS1]NUM
Raz [M:PBS1]
[M:PBS1]NUM = mod(ONUM,NBBSE)+1
Read [PBS]PBS0 = [M:PBS1]NUM
If fstat<=2
 [M:PBS1]NUM = [F:PBS]NUM
 CLE2 = num$([F:PBS]NUM)
 Gosub RELIT From GOBJET
 REPONSE= 0
Else
 [M:PBS1]CRIAFF = TTRI
 REPONSE=93 : REP="C"
 Affzo
Endif
Return

##########################################################################
$TRTTRI
Case [M:PBS1]CRIAFF
 When 1
  Sorta [M:PBS1]NBLIG [M:PBS1]NBLIG Order By [M:PBS1]ACCSTR([S]indice)
 When 2
  Sorta [M:PBS1]NBLIG [M:PBS1]NBLIG Order By [M:PBS1]BSEDEB([S]indice),[M:PBS1]ACCSTR([S]indice)
 When 3
  Sorta [M:PBS1]NBLIG [M:PBS1]NBLIG Order By [M:PBS1]BSECDT([S]indice),[M:PBS1]ACCSTR([S]indice)
Endcase
Return

############################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File GAPARBSE  [PBS1] 
Else 
 Local File =[M]DOSORG+".GAPARBSE"  [PBS1]
Endif 
If [M]DOSDES=nomap 
 Local File GAPARBSE  [PBS2] 
Else 
 Local File =[M]DOSDES+".GAPARBSE"  [PBS2]
Endif
OK = 1
If GTRACE=""
 Read [PBS2]PBS0(1) = val(TABLE)
 If !fstat
  Call AVERTIR([M]DOSDES-(TABLE)-mess(22,100,1),OK) From GESECRAN
  #### Fiche déjà existante
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call TEMPON("T") From GESECRAN
 Call DEBTRANS From GLOCK
 Gosub TR_COP
 Call TEMPOFF From GESECRAN
Endif
Close Local File [PBS1], [PBS2]
Return

$TR_COP
GOK = 1
GCLE = TABLE
Trbegin [PBS2]
 Delete [PBS2] Where NUM=val(TABLE)
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GAPARBSE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("PBS2",GCLE) From GLOCK : Goto AB_TR_COP
 Endif

 # La copie proprement dite...
 For [PBS1]PBS0 Where NUM=val(TABLE)
  Raz [F:PBS2]
  [F:PBS2] = [F:PBS1]
  Write [PBS2]
  If fstat
   GOK=0 : Call FSTA("PBS2") From GLOCK : Break
  Endif
 Next : # [PBS1]
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##########################################################################
# Etiquettes du masque [PBS1]
##########################################################################

Subprog C_ACCSTR(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M:PBS1]ACCSTR(0..[M:PBS1]NBLIG-1)) From OBJDIV
End

Subprog D_BSECDT(VALEUR)
Variable Char     VALEUR
If VALEUR=""
 VALEUR = [M:PBS1]BSEDEB(nolign-1)
Endif
End

