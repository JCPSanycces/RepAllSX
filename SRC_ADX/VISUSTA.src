#<AdxTL>@(#)9.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "DEBUT"       : Gosub DEBUT
 When "BOUTON"      : Gosub BOUTON
 When "TRT_DIV"     : Gosub TRT_DIV
Endcase
Return
############################################################
$OUVRE
If clalev([F:ITM])  = 0 Local File ITMMASTER  [ITM]  : Endif
If clalev([F:FCY])  = 0 Local File FACILITY   [FCY]  : Endif
If clalev([F:STL1]) = 0 Local File STOLOT     [STL1] : Endif
If clalev([F:STO1]) = 0 Local File STOCK      [STO1] : Endif
If clalev([F:TST])  = 0 Local File TABSTASTO  [TST]  : Endif
If clalev([F:ITF])  = 0 Local File ITMFACILIT [ITF]  : Endif

Return
############################################################
$SETBOUT
If find([M:VSTA]STASEL,"A","Q","R")  
  ETABOU(GSPE1) = 0
  ETABOU(GSPE2) = 0
  ETABOU(GSPE3) = 0
  ETABOU(GSPE4) = 0
Endif
Return
############################################################
$DEBUT
Local Integer I, J, K, L, M
Local Decimal WACT
Raz [M:VSTA]
#
Call LECTURE("FCY",PARAM(1),"") From CONTOBJ
If fstat 
  Raz [F:FCY]
Endif
[M:VSTA] = [F:FCY]
#
Call LECTURE("ITM",PARAM(2),"") From CONTOBJ
If fstat
  Raz [F:ITM]
Endif
[M:VSTA] = [F:ITM]


If [F:ITM]STOMGTCOD > 1
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
   If [F:ITF]STOFCY <> [F:FCY]FCY | [F:ITF]ITMREF <> [F:ITM]ITMREF 
      Read [ITF]ITF0 = [F:ITM]ITMREF;[F:FCY]FCY
      If fstat 
         Raz [F:ITF]
      Endif
   Endif
Else
   Raz [F:ITF]
Endif

# FGR 05/10/2009 : X3SUIVI58372
#Call GET_ATEXTRA("ITMMASTER","DES1AXX",GLANGUE,[M:VSTA]DES1AXX) From TRTX3TEX
Call CHARGE_DEFITMDES("DES1AXX", GLANGUE, [F:ITM]ITMREF, [M:VSTA]DES1AXX, "[F:ITM]") From TRTX3
#
If dim([M:VSTA]LOT) > 0
  [M:VSTA]LOT     = PARAM(3)
Endif
[M:VSTA]STASEL  = vireblc(PARAM(4),4)
[M:VSTA]LOCCAT001 = 2
[M:VSTA]LOCCAT002 = 2
[M:VSTA]LOCCAT003 = 2
[M:VSTA]LOCCAT004 = 2
Affzo [M:VSTA]5-10
Gosub TRT_AFFICHAGE
Return
############################################################
$TRT_AFFICHAGE
Local Char WFIL(250)
Local Char WCAT(20)
#
Effzo [M:VSTA]15
#
WFIL = "[F:STO1]ITMREF=[F:ITM]ITMREF"
If [F:FCY]FCY <> ""
  WFIL += "&[F:STO1]STOFCY=[F:FCY]FCY"
Endif
If  dim([M:VSTA]LOT) > 0 & [M:VSTA]LOT <> "" & PARAM(3) <> mess(142,124,1)
  WFIL += "&pat([F:STO1]LOT,[M:VSTA]LOT)"
Endif
If find([M:VSTA]STASEL,"A","Q","R")
  WFIL += "&left$([F:STO1]STA,1)=left$([M:VSTA]STASEL,1)"
Endif
WCAT = ""
If [M:VSTA]LOCCAT001 = 2
  WCAT += ",0,1"
Endif
If [M:VSTA]LOCCAT002 = 2
  WCAT += ",2"
Endif
If [M:VSTA]LOCCAT003= 2
  WCAT += ",3"
Endif
If [M:VSTA]LOCCAT004 = 2
  WCAT += ",4"
Endif
If WCAT <> ""
  WFIL += "&find([F:STO1]LOCCAT"+WCAT+")"
Endif
#
Filter [STO1] Where evalue(WFIL)
&            Order By Key STO3
#
For [STO1]
  Gosub CUM_STATUT   
Next
Filter [STO1]
# Calcul total
[M:VSTA]BASPAG += 1
[M:VSTA]STA([M:VSTA]BASPAG-1)       = "***"  
[M:VSTA]STAAXX([M:VSTA]BASPAG-1)    = mess(142,124,1)
[M:VSTA]STU([M:VSTA]BASPAG-1)       = [M:VSTA]STU(0)
[M:VSTA]QTYSTU([M:VSTA]BASPAG-1)    = sum([M:VSTA]QTYSTU(0..[M:VSTA]BASPAG-2))
[M:VSTA]QTYSTUAAA([M:VSTA]BASPAG-1) = sum([M:VSTA]QTYSTUAAA(0..[M:VSTA]BASPAG-2))
[M:VSTA]QTYSTUQQQ([M:VSTA]BASPAG-1) = sum([M:VSTA]QTYSTUQQQ(0..[M:VSTA]BASPAG-2))
[M:VSTA]QTYSTURRR([M:VSTA]BASPAG-1) = sum([M:VSTA]QTYSTURRR(0..[M:VSTA]BASPAG-2))
If dim([M:VSTA]QTYSTUACT) > 0
  [M:VSTA]QTYSTUACT([M:VSTA]BASPAG-1) = sum([M:VSTA]QTYSTUACT(0..[M:VSTA]BASPAG-2))
  [M:VSTA]QTYACTAAA([M:VSTA]BASPAG-1) = sum([M:VSTA]QTYACTAAA(0..[M:VSTA]BASPAG-2))
  [M:VSTA]QTYACTQQQ([M:VSTA]BASPAG-1) = sum([M:VSTA]QTYACTQQQ(0..[M:VSTA]BASPAG-2))
  [M:VSTA]QTYACTRRR([M:VSTA]BASPAG-1) = sum([M:VSTA]QTYACTRRR(0..[M:VSTA]BASPAG-2))
Endif
Affzo [M:VSTA]15
Return
############################################################
$APRES_MODIF
Case COUZON
  When "LOCCAT001" : 
    [M:VSTA]LOCCAT001 = val(CZ)
    Gosub TRT_AFFICHAGE
  When "LOCCAT002" : 
    [M:VSTA]LOCCAT002 = val(CZ)
    Gosub TRT_AFFICHAGE
  When "LOCCAT003" : 
    [M:VSTA]LOCCAT003 = val(CZ)
    Gosub TRT_AFFICHAGE
  When "LOCCAT004" : 
    [M:VSTA]LOCCAT004 = val(CZ)
    Gosub TRT_AFFICHAGE
Endcase
Return
############################################################
$BOUTON
Return
############################################################
$TRT_DIV
Return
###########################################################
$CUM_STATUT
WACT = 1
Read [STL1]STL0(2) = [F:STO1]ITMREF;[F:STO1]LOT
If fstat = 0
  Case [F:ITF]STOMGTCOD
    When 3 : WACT = ([F:STL1]POT/100)
    When 4 : WACT = [F:STL1]ACT
  Endcase
Endif 
# 
M =  find([F:STO1]STA,[M:VSTA]STA(0..[M:VSTA]BASPAG-1))
If M <>  0
  [M:VSTA]QTYSTU(M-1) += [F:STO1]QTYSTU
  If dim([M:VSTA]QTYSTUACT) > 0
    [M:VSTA]QTYSTUACT(M-1) += [F:STO1]QTYSTU*WACT
  Endif
  Case left$([F:STO1]STA,1)
    When "A" :
      [M:VSTA]QTYSTUAAA(M-1) += [F:STO1]QTYSTU
      [M:VSTA]QTYACTAAA(M-1) += [F:STO1]QTYSTU*WACT 
    When "Q" :
      [M:VSTA]QTYSTUQQQ(M-1) += [F:STO1]QTYSTU
      [M:VSTA]QTYACTQQQ(M-1) += [F:STO1]QTYSTU*WACT 
    When "R" :
      [M:VSTA]QTYSTURRR(M-1) += [F:STO1]QTYSTU
      [M:VSTA]QTYACTRRR(M-1) += [F:STO1]QTYSTU*WACT 
  Endcase
Else
  If [M:VSTA]BASPAG < dim([M:VSTA]STA)-2
    [M:VSTA]STA([M:VSTA]BASPAG)    = [F:STO1]STA
    Read [TST]TST0=[F:STO1]STA
    If fstat
      Raz [F:TST]
    Endif
    Call GET_ATEXTRA("TABSTASTO","STAAXX",GLANGUE,[M:VSTA]STAAXX([M:VSTA]BASPAG)) From TRTX3TEX
    [M:VSTA]STU([M:VSTA]BASPAG)    = [F:ITM]STU
    [M:VSTA]QTYSTU([M:VSTA]BASPAG) = [F:STO1]QTYSTU
    If dim([M:VSTA]QTYSTUACT) > 0
      [M:VSTA]QTYSTUACT([M:VSTA]BASPAG) = [F:STO1]QTYSTU*WACT
    Endif
    Case left$([F:STO1]STA,1)
      When "A" :
        [M:VSTA]QTYSTUAAA([M:VSTA]BASPAG) = [F:STO1]QTYSTU
        [M:VSTA]QTYACTAAA([M:VSTA]BASPAG) = [F:STO1]QTYSTU*WACT
      When "Q" :
        [M:VSTA]QTYSTUQQQ([M:VSTA]BASPAG) = [F:STO1]QTYSTU
        [M:VSTA]QTYACTQQQ([M:VSTA]BASPAG) = [F:STO1]QTYSTU*WACT
      When "R" :
        [M:VSTA]QTYSTURRR([M:VSTA]BASPAG) = [F:STO1]QTYSTU
        [M:VSTA]QTYACTRRR([M:VSTA]BASPAG) = [F:STO1]QTYSTU*WACT
    Endcase
    [M:VSTA]BASPAG += 1
  Endif
Endif
Return
############################################################
Subprog AV_STA(VALEUR)
Variable Char    VALEUR()
If nolign > 0 
  If VALEUR = "***"
    pcolor = GCOUL(3)
  Else 
    pcolor = GCOUL(0)
  Endif
Endif
End
############################################################
Subprog C_LOCCAT001(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M]LOCCAT002 = 1 & [M]LOCCAT003 = 1 & [M]LOCCAT004 = 1
  VALEUR = 2
  mkstat = 2
Endif
End
############################################################
Subprog C_LOCCAT002(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M]LOCCAT001 = 1 & [M]LOCCAT003 = 1 & [M]LOCCAT004 = 1
  VALEUR = 2
  mkstat = 2
Endif
End
############################################################
Subprog C_LOCCAT003(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M]LOCCAT001 = 1 & [M]LOCCAT002 = 1 & [M]LOCCAT004 = 1
  VALEUR = 2
  mkstat = 2
Endif
End
############################################################
Subprog C_LOCCAT004(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M]LOCCAT001 = 1 & [M]LOCCAT002 = 1 & [M]LOCCAT003 = 1
  VALEUR = 2
  mkstat = 2
Endif
End
