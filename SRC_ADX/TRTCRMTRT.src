#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################################################
#   Traitements GTRAITE pour le module CRM                           19 Juin 2000
#   
#   SETINTBPC  : Traitement de migration des clients en clients internes.           Copié dans DOSMAJ5
#   TRTMGGGEN  : Régénération des critères de ciblage
#   TRTPITGEN  : Régénération des points
#   TRTPBLGEN  : Régénération des stats sur compétence
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "EXEC" Gosub EXEC
    When Default
  Endcase
Return

##########################################################################################################
$EXEC
  Case GACTION
    When "TRTINTBPC"  : Gosub SETINTBPC
    When "TRTMGGGEN"  : Gosub ASKMGGGEN
    When "TRTPITGEN"  : Gosub ASKPITGEN
    When "TRTPBLGEN"  : Gosub ASKPBLGEN
    When Default
  Endcase
Return

##########################################################################################################
$ASKPBLGEN
Local Integer IASKOK
Local Integer IERR

  IERR = 0
  IASKOK = 0
  #Tous les utilisateurs doivent être déconnectés du système avant d'exécuter ce traitement. Souhaitez-vous continuer ?
  Call OUINON(mess(613,182,1), IASKOK) From GESECRAN
  If IASKOK = 2 Then
    IASKOK = 0
    #Confirmez-vous le lancement de la régénération des statistiques sur compétences ?
    Call OUINON(mess(719,182,1), IASKOK) From GESECRAN
    If IASKOK = 2 Then
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE(mess(1007,182,1)) From LECFIC
      Call GENPBLSTAT(nomap, IERR) From TRTPBLGEN
      Call TEMPOFF From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Endif
Return

##########################################################################################################
$ASKPITGEN
Local Integer IASKOK

  IASKOK = 0
  #Tous les utilisateurs doivent être déconnectés du système avant d'exécuter ce traitement. Souhaitez-vous continuer ?
  Call OUINON(mess(613,182,1), IASKOK) From GESECRAN
  If IASKOK = 2 Then
    IASKOK = 0
    #Confirmez-vous le lancement de la régénération des points ?
    Call OUINON(mess(614,182,1), IASKOK) From GESECRAN
    If IASKOK = 2 Then
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE(mess(1006,182,1)) From LECFIC
      Call GENPIT(nomap) From TRTPITGEN
      Call TEMPOFF From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Endif
Return

##########################################################################################################
$ASKMGGGEN
Local Integer ASKOK
Local Integer IERR

  IERR = 0
  ASKOK = 0
  #Lancer le traitement ???
  Call OUINON(mess(782,196,1), ASKOK) From GESECRAN #Voulez-vous lancer la régénération des critères de ciblage.
  If ASKOK = 2 Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE(mess(1008,182,1)) From LECFIC
    Call GENSUPPORT(nomap, IERR) From TRTMGGGEN
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Return

##########################################################################################################
$SETINTBPC
Local Integer CRMNBREC
Local Integer CRMOK
Local Integer INTBPCOK
Local Decimal CRMCOUNT
Local Char SZCLE2
Local Integer ICLECOUNT2
Local Integer ICUT2
Local Integer IERROR   # FGR 08/02/2010 : X3SUIVI60986

  SZCLE2 = ""
  ICUT2 = 2500
  ICLECOUNT2 = ICUT2
  INTBPCOK = 0
  CRMNBREC = 0
  CRMOK = 0
  CRMCOUNT = 0
  IERROR = 0   # FGR 08/02/2010 : X3SUIVI60986
  Call OUINON(mess(418,196,1), INTBPCOK) From GESECRAN
  If INTBPCOK <> 2 Then
    Return
  Endif
  If !clalev([F:DBI]) : Local File DOOBPCINT [DBI] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  #Vide tout d'abord la totalité de la table DBI
  Call TEMPON("F") From GESECRAN
  Lock [DBI]
  If fstat Then
    Close Local File [DBI]
    Close Local File [BPC]
    Call TEMPOFF From GESECRAN
    Return
  Else
    Delete [DBI] Where [F:DBI]BPCNUM >= ""
    If fstat Then
      Unlock [DBI]
      Return
    Else
      Unlock [DBI]
    Endif        
  Endif
  Call TEMPOFF From GESECRAN
  #Effectue la migration
  While ICLECOUNT2 >= ICUT2
    ICLECOUNT2 = 0
    Filter [BPC] Where [F:BPC]BPCNUM > SZCLE2  and [F:BPC]BPCTYP <> 4
    For [BPC]BPC0
      SZCLE2 = [F:BPC]BPCNUM
      CRMNBREC += 1
      ICLECOUNT2 += 1
      If ICLECOUNT2 >= ICUT2 Then
        Break
      Endif
    Next
    Filter [BPC]
  Wend
  SZCLE2 = ""
  ICUT2 = 2500
  ICLECOUNT2 = ICUT2
  Call OUVRE_BOITE(mess(196,196,1), CRMNBREC) From GESECRAN
  Call DEBTRANS From GLOCK
  While ICLECOUNT2 >= ICUT2
    ICLECOUNT2 = 0
    Filter [BPC] Where [F:BPC]BPCNUM > SZCLE2  and [F:BPC]BPCTYP <> 4
    For [BPC]BPC0
      SZCLE2 = [F:BPC]BPCNUM
      [F:DBI]BPCNUM = [F:BPC]BPCNUM
      [F:DBI]BPCNAM = [F:BPC]BPCNAM
      [F:DBI]BPCSHO = [F:BPC]BPCSHO
      [F:DBI]INTBPC = 2
      Trbegin [DBI]
      Write [DBI]
      If fstat Then
        Rollback
        # FGR 08/02/2010 : X3SUIVI60986
        #Return
        IERROR = 1
        Break
      Else
        Commit
      Endif
      CRMCOUNT += 1
      ICLECOUNT2 += 1
      If ICLECOUNT2 >= ICUT2 Then
        Break 
      Endif
      Call AFF_BOITE ([F:BPC]BPCNAM, CRMCOUNT, CRMOK) From GESECRAN
    Next
    Filter [BPC]
    If IERROR Then
      # FGR 08/02/2010 : X3SUIVI60986
      Break
    Endif
  Wend
  Call FERME_BOITE From GESECRAN
  Close Local File [DBI]
  Close Local File [BPC]
  If IERROR Then
    # FGR 08/02/2010 : X3SUIVI60986
    Return
  Endif
Return
