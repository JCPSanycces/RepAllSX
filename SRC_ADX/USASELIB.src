#<AdxTL>@(#)6.0.0.0 $Revision$
#########################################################################################
#  US Revisions                                                                         #
#                                                                                       #
#  Rev #  Log #        Rev Date     Who  Description                                    #
#  -----  ------------ ------------ ---  -----------------------------------------------#
#   001                21/11/2008   JPGA Inhibition ou non du bouton 11 de Sélection USA#
#                                        sur les types de données BPS / BPC / ITV       #
#########################################################################################
$ACTION
  Case ACTION
      When "TRT_DIV"   : Gosub TRT_DIV
  Endcase
Return


#########################################################################################
#TRT_DIV : Traitement d'inhibition ou non du bouton de Sélection n° 11
#########################################################################################
$TRT_DIV
  Local  Integer  WNUM_BOUT           : [L]WNUM_BOUT  = 11        # N° du bouton de sélection
  Local  Char     WPARAM_NIV(GLONCPY) : [L]WPARAM_NIV = GSOCIETE  # Input  : Périmètre (Société ou Site...)
  Local  Char     WPARAM_NOM(10)      : [L]WPARAM_NOM = "USASEL"  # Input  : Nom du parametre
  Local  Char     WPARAM_VAL(10)                                  # Output : Valeur du parametre
  
  # Recherche de la valeur du paramètre. Niveau de définition  : SOCIETE
  Call PARAM(WPARAM_NIV, WPARAM_NOM, WPARAM_VAL) From ADOVAL

  # Si Paramètre Actif, on laisse la sélection, sinon on inhibe le bouton 11 de sélection
  # Type du Paramètre : Menu local n°1
  If (WPARAM_VAL = "") | !(val(WPARAM_VAL) - 1)
      Assign ("[V]GBOUT" + num$([L]WNUM_BOUT)) With ""
  Endif
Return

