#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","UTIDEP","",2,"XYUTIDEP") From GTRAITE
End

#--------------------------------------------------------------------------------------------#
# Ce traitement permet de retrouver les incohérences sur les codes tables diverses
# avec des dépendances après une modif de paramètrage
# ou modif du contenu de ces tables
#--------------------------------------------------------------------------------------------#


$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return

#----------------------------------#
$INIT
Local Integer I , J , K , INTE , OK , N , NBERR
Local Char    TIT(30) , PARDEP(GLONAAR) , PARNUM(GLONAAR) , TABLE(GLONATB) , PARACT(250)
Local Char    VALDEP(250) , VALADI(250)
Local Char    CHAINE(250) , TEXTE(80) , MESSAGE(250)
Local Integer NBCLE , REPET , DIME
Local Char    CLE(10)(1..16)
Local Char    CODDEP(GLONADI) , CODADI(GLONADI)
Local Integer NUMADI
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:AMP])=0 : Local File AMSKPAR [AMP] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
TIT = mess(66,139,1) : # Contrôles des dépendances
If nomap=GDOSX3 & GADONIX<>2
 GMESSAGE = TIT-":\"+mess(112,125,1) : # Opération impossible sur ce dossier
 GERR = 1 : Return
Endif
TRA = 1
Return

#----------------------------------#
$EXEC
If !GSERVEUR
 Call OUVRE_BOITE(TIT,100) From GESECRAN
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Gosub CONTADI
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call FERME_BOITE From GESECRAN
Endif
Return

#----------------------------------#
$CONTADI
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif

PARDEP = "TABDIV"
PARNUM = "ADI"

Link    [ATZ]
& With  [AMP]CODPAR=2;[F:ATZ]CODFIC;[F:ATZ]CODZONE;[L]PARDEP
&    ,  [ACV]CODACT=[F:ATZ]CODACT
& As    [ATZ_]
& Where [F:ATZ]CODTYP="ADI"
&     & find([F:AMP]VALPAR,'""',"''","")=0
&     & ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)

Call SET_BOITE(mess(66,139,1),rowcount([F:ATZ_])) From GESECRAN : # Contrôles des tables diverses

Raz K , NBERR
For [ATZ_]
 K += 1
 Call AFF_BOITE(mess(56,123,1)-[F:ATB]CODFIC,K,INTE) From GESECRAN : # Table
 TABLE  = [F:ATZ]CODFIC
 ZONADI = [F:ATZ]CODZONE
 REPET  = [F:ATZ]DIME
 Call REPTAB([F:ATZ]CODACT,REPET) From DOSSUB
 Gosub GETPAR 
 VALDEP = PARACT
 Read [AMP]CODPAR=2;TABLE;ZONADI;[L]PARNUM
 Gosub GETPAR
 VALADI = PARACT
 If VALADI<>"" & VALDEP<>"" & REPET<>0
  Read [ATB]CODFIC = [F:ATZ]CODFIC
  Read [ATI]NUMLIG(2) = [F:ATZ]CODFIC;1
  CHAINE = [F:ATI]DESCRIPT
  NBCLE = 0
  While CHAINE<>""
   NBCLE += 1 
   I = instr(1,CHAINE,"+")
   J = instr(1,CHAINE,"-")
   If    I & J  : I = min(I,J)
   Elsif J & !I : I = J
   Endif
   If I
    CLE(NBCLE) = left$(CHAINE,I-1) : CHAINE = right$(CHAINE,I+1) 
   Else
    CLE(NBCLE) = CHAINE : CHAINE = ""
   Endif
  Wend
  Local File =TABLE [FFF]
  Raz N
  For [F:FFF]
   For DIME=0 To REPET-1
    Onerrgo RIEN
    CODDEP = evalue(VALDEP)
    NUMADI = val(num$(evalue(VALADI)))
    CODADI = evalue("[F:FFF]"+ZONADI+"("+num$(DIME)+")")
    Onerrgo
    If CODADI<>"" & CODDEP<>"" & NUMADI<>0
     Filter [ADI] Where NUMTAB=NUMADI & DEPCOD=CODDEP & CODE=CODADI
     Read [ADI]First
     Filter [ADI]
     If fstat
      If N=0
       Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
       MESSAGE = TEXTE-"("+[F:ATB]CODFIC+")"
       MESSAGE -= mess(63,139,1)-num$(NUMADI) : # Table diverse
       MESSAGE -= mess(149,123,1)-ZONADI      : # Champs
       Call ECR_TRACE(MESSAGE,0) From GESECRAN
       Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Endif
      N += 1
      NBERR += 1
      If [F:ATB]INTIT<>"" & evalue("type([F:FFF]"+[F:ATB]INTIT+")")>10
       TEXTE = evalue("[F:FFF]"+[F:ATB]INTIT)
      Else
       TEXTE = ""
      Endif
      GCLE = ""
      For I=1 To NBCLE
       GCLE -= num$(evalue("[F:FFF]"+CLE(I)))
      Next I
      Gosub MESSAGE
      Call ECR_TRACE(MESSAGE,0) From GESECRAN
     Endif
    Endif
   Next DIME
  Next FFF
  Close Local File [FFF]
  If N>0
   Call ECR_TRACE("",0) From GESECRAN
  Endif
 Endif
Next ATZ_
If NBERR=0
 Call ECR_TRACE(mess(164,115,1),0) From GESECRAN : # Aucune anomalie
Endif
Return

$GETPAR
PARACT = vireblc(format$("KT:80X",[F:AMP]VALPAR),2)    
If num$(val(PARACT))=PARACT : PARACT = '"'+PARACT+'"'
Elsif PARACT="" : PARACT = '""'
Elsif left$(PARACT,4)<>"num$" and left$(PARACT,1)<>'"' and left$(PARACT,1)<>"'"
 PARACT = "num$("+PARACT+")"
Endif
J = instr(1,PARACT,"indice")
While J<>0
 PARACT = left$(PARACT,J-1)+"DIME"+right$(PARACT,J+6)
 J = instr(1,PARACT,"indice")
Wend
Return

$RIEN
Resume

$MESSAGE
MESSAGE = mess(37,100,1)-CODADI  : # Code
MESSAGE -= mess(64,139,1)-CODDEP : # Incompatible avec la dépendance
MESSAGE -= ":"-GCLE-TEXTE
Return

