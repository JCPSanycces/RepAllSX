Raz GPILOBJ,GNBMASKOUV
Call OBJET("AJC",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## SDATA
##    Gestion des contrats
##    Version 008_S
#
# E62181 - Pb SADFSQ --> il faut modifier APLI.ini avec sadmem = 27 * 1024 =27648 
#          EXEACT: modif maxmem (ne marche pas si fait dans AV_VERF_ANU)
#          --> Suppression gérée en specifique
# 31/03/2011
#        Modif gestion table de type systeme
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "EXEACT"         : Gosub EXEACT
 When "CREATION"       : Gosub CREATION
 When "LIENS"          : Gosub LIENS
 When "MODIF"          : Gosub MODIF
 When "OUVRE"          : Gosub OUVRE
 When "SETBOUT"        : Gosub SETBOUT
 When default
Endcase
Return


######################################################################################

$OUVRE
#---------------------------------------------------------------#
If clalev([F:ATX])=0 : Local File ATEXTE     [ATX] : Endif

Local Integer WFLGMOD : WFLGMOD=0

#GADONIX=1 # Test
#If GUSER="JPJ" 
#    Local Integer WOLD, WNEW, CC_MAXMEM, WFREOLD, WFRENEW
#    WNEW=maxmem
#    WFRENEW=freemem
#    Infbox "OLD / New maxmem"-num$(WOLD) -num$(WNEW) 
#    Infbox "OLD / New freemem"-num$(WFREOLD) -num$(WFRENEW)  
#Endif
Return

#---------------------------------------------------------------#
$LIENS
Call TEXTE([F:AJC]AJCDES,[M]AJCDESZ) From OBJDIV
Return

#---------------------------------------------------------------#
$CREATION
$MODIF
Return

#---------------------------------------------------------------#
$ANNULE
Return

#---------------------------------------------------------------#
$EXEACT
If BOUT="S"
# Sequence pour augmenter la memoire adonix.exe
#   Ne suffit pas car le process de la base n'a pas assez de memoire (sadmem)
#    Local Integer WOLD, WNEW, CC_MAXMEM, WFREOLD, WFRENEW
#    WOLD=maxmem
#    WFREOLD=freemem
#    CC_MAXMEM = 60 * 1024000
#    If WOLD < CC_MAXMEM  
#     maxmem=CC_MAXMEM / 1000
#    Endif
#
#
    If(GADONIX<>2 and (!find(left$([M]CODACT,1),"X","Y","Z")))
        Call ERREUR(mess(76,143,1)) From GESECRAN : # Contrat SData standard Sage - Suppression interdite
    Endif

    If [M:AJC1]ENAFLG=2
        Call ERREUR(mess(75,143,1)) From GESECRAN : # Actif - sup interdite
        OK=0 : Return
    Endif
    If GCONF(1)=2
        OK = 2 : Call OUINON(mess(28,100,1),OK) From GESECRAN : # Confirmation d'annulation
        If OK<>2 : OK=0 : Return : Endif
    Endif
    
    If !GSERVEUR
      If !VERROU 
        Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
        OK=0
        Return
      Endif
      Gosub AJC_DELETE
      Effzo [M:AJC1]
      OK=0
    Endif
Endif
Return

# Suppression en remplacement sequence standard e62181
#---------------------------------------------------------------#
$AJC_DELETE
Call DEBTRANS From GLOCK
  
$TR1_DEL
Trbegin [AJC]
Delete [AJC]AJC0=[M:AJC1]AJCCOD
If fstat=1 | fstat>5
  GOK = -1 : 
  GLOCK = "$AJSCONT"-[M:AJC1]AJCCOD 
  Goto DEL_ROLL
Endif
Commit
Return

$DEL_AB
Rollback
Return

$DEL_ROLL      
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1_DEL : Return : Endif


$SETBOUT
#---------------------------------------------------------------#
If ((GADONIX<>2 and (!find(left$([M]CODACT,1),"X","Y","Z"))) or [M]ENAFLG=2)
    Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
If ((GADONIX<>2 and (!find(left$([M]CODACT,1),"X","Y","Z"))))
    If find(GREP,"","M")
        Diszo AJCDESZ, CODACT, MODULE, AJCXSD
    Else
        Actzo AJCDESZ, CODACT, MODULE, AJCXSD
    Endif
Else
    Actzo AJCDESZ, CODACT, MODULE, AJCXSD
Endif
Return

##################################
# Copie
$TRTCOP
If [M]DOSORG=nomap 
 Local File AJSCONT   [AJC1] 
 Local File ATEXTE    [ATX1] 
Else 
 Local File =[M]DOSORG+".AJSCONT"   [AJC1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1] 
Endif 
If [M]DOSDES=nomap 
 Local File AJSCONT   [AJC2] 
 Local File ATEXTE    [ATX2] 
Else 
 Local File =[M]DOSDES+".AJSCONT"   [AJC2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif
Local Integer I
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AJC1], [ATX1]
Close Local File [AJC2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [AJC2]
 Delete [AJC2] Where AJCCOD=TABLE 
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AJCCONT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AJC2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AJC1]AJC0 Where AJCCOD=TABLE
  [F:AJC2] = [F:AJC1]
  Call COPTEXTE([F:AJC1]AJCDES,[F:AJC2]AJCDES) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:AJC2]UPDUSR)>0 : [F:AJC2]UPDUSR = GUSER : Endif
  If dim([F:AJC2]UPDDAT)>0 : [F:AJC2]UPDDAT = date$ : Endif
  If dim([F:AJC2]UPDTIM)>0 : [F:AJC2]UPDTIM = time  : Endif
  Write [AJC2]
  If fstat
   GOK=0 : Call FSTA("AJC2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif





######################################################################################
## Etiquette ajoutée par le superviseur (écran AJC1) 31/03/2011 11:30:02 (JPJ)
######################################################################################
Subprog AM_AJCXSD(VALEUR)
Variable Clbfile VALEUR
    If(GADONIX<>2 and find(GREP,"","M")  and (!find(left$([M]CODACT,1),"X","Y","Z")))
        GMESSAGE=mess(77,143,1) # Contrat SData standard Sage - Modification interdite
        mkstat=2
    Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran AJC1) 31/03/2011 11:30:45 (JPJ)
######################################################################################
Subprog AM_CODACT(VALEUR)
Variable Char    VALEUR()
    If(GADONIX<>2 and find(GREP,"","M") and (!find(left$([M]CODACT,1),"X","Y","Z")))
        GMESSAGE=mess(77,143,1) # Contrat SData standard Sage - Modification interdite
        mkstat=2
    Elsif (GADONIX<>2 and find(GREP,"","M") and (find(left$([M]CODACT,1),"X","Y","Z")) and (!find(left$(VALEUR,1),"X","Y","Z")))
        GMESSAGE=mess(224,139,1) # Code activité incorrect
        mkstat=2
    Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran AJC1) 31/03/2011 11:51:34 (JPJ)
######################################################################################
Subprog C_CODACT(VALEUR)
Variable Char    VALEUR()
    If (GADONIX<>2 and find(GREP,"C", "D") and (!find(left$(VALEUR,1),"X","Y","Z")))
        GMESSAGE=mess(78,143,1) # Reservé Standard
        mkstat=2
    Endif
End


