#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTICPT43   Ré-initialisation du champ FLGCLE              Module CPT   #
#                                                                        #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTICPT43(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT43(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTICPT43 (DUD) : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:DUD])  =0  Local File =DOSSIER+".GACCDUDATE"   [DUD] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [DUD]
Filter [DUD] Where AMTCUR=0 & AMTLOC<>0
For [DUD]
 Readlock [DUD] Curr    
 If !fstat
  # --- alimentation des champs et réécriture enreg
  If [F:DUD]AMTLOC = [F:DUD]PAYLOC
   [F:DUD]FLGCLE = 2
  Elsif [F:DUD]AMTLOC = [F:DUD]PAYLOC+[F:DUD]TMPLOC
   [F:DUD]FLGCLE = 4
  Else
   [F:DUD]FLGCLE = 1
  Endif
  Rewrite [F:DUD]
  If !fstat COMPTEUR += 1 Endif
 Endif
Next
Commit
Close Local File [DUD]
Call ECR_TRACE("UTICPT43 (DUD) : "+num$(COMPTEUR)+" records processed",0) From GESECRAN


#-------------------------------------------------------------------------------------
# Historisation des échéances
#-------------------------------------------------------------------------------------
If filinfo(filpath("FIL","HISTODUD","fde",DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE("UTICPT43 (HDU) : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:DUD])  =0  Local File =DOSSIER+".HISTODUD"   [DUD] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [DUD]
Filter [DUD] Where AMTCUR=0 & AMTLOC<>0
For [DUD]
 Readlock [DUD] Curr    
 If !fstat
  # --- alimentation des champs et réécriture enreg
  If [F:DUD]AMTLOC = [F:DUD]PAYLOC
   [F:DUD]FLGCLE = 2
  Elsif [F:DUD]AMTLOC = [F:DUD]PAYLOC+[F:DUD]TMPLOC
   [F:DUD]FLGCLE = 4
  Else
   [F:DUD]FLGCLE = 1
  Endif
  Rewrite [F:DUD]
  If !fstat COMPTEUR += 1 Endif
 Endif
Next
Commit
Close Local File [DUD]
Call ECR_TRACE("UTICPT43 (HDU) : "+num$(COMPTEUR)+" records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : ENDIF
If filinfo(filpath("FIL","GACCDUDATE","fde",APPLI),0)<=0 : End : Endif   
Call MAJ_UTICPT43(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If filinfo(filpath("FIL","GACCDUDATE","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT43(APPLI)
End

