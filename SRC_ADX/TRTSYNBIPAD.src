#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
$ACTION
  Case ACTION
    When "OUVRE_FAT"      : Gosub OUVRE_FAT
    When "DEBUT_FAT"      : Gosub DEBUT_FAT # Issue 110958 - 2015-09-11 by CPO : GBICURFOLD non existent
    When "FILTRE_FAT_INC" : #Gosub FILTRE_FAT_INC
    When "FIN_FAT"        : Gosub FIN_FAT
    When Default
  Endcase
Return

###############################################################################
$OUVRE_FAT
  # ---------------------------
  # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  #--only needed from some designated synchronisation rules
  #Gosub TRIGGER_AUDIBI
  # End issue X3-38377

  # ---------------------------
  Gosub AVANT_FAT_COMMUN

  # Issue 110958 - 2015-09-11 by CPO : GBICURFOLD non existent
  #  Variable globale pour récupérer la devise dossier
  #If dim(GBICURFOLD)<=0 Then
  #  Global Char GBICURFOLD(GLONCUR)
  #Endif
  #GBICURFOLD = func TRTX3BI.GETSYSCUR()
  Gosub DEBUT_FAT
  # End issue 110958

	Case [L]TABLE
	  When "F_PADFACT"
      # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
      #--only needed from some designated synchronisation rules
      If find([F:ABV]CODREG,"PADPID","PADPND","PADPOQ","PADPSD","PADPSO","PADPTD")>0
        If dim(ZWTABAPPLIORI)<0 : Local Char ZWTABAPPLIORI(GLONATB) : Endif
        Raz ZWTABAPPLIORI
        Case [F:ABV]CODREG
          When "PADPID" : ZWTABAPPLIORI = "PINVOICE"
          When "PADPND" : ZWTABAPPLIORI = "PRETURN"
          When "PADPOQ" : ZWTABAPPLIORI = "PORDER"
          When "PADPSD" : ZWTABAPPLIORI = "PREQUIS"
          When "PADPSO" : ZWTABAPPLIORI = "PREQUISO"
          When "PADPTD" : ZWTABAPPLIORI = "PRECEIPT"
        Endcase
        Gosub TRIGGER_AUDIBI
      Endif
      # End issue X3-38377
	    # ----------------------------------------
	    Case [F:ABV]CODREG
	      When "PADPOQPOP"       : Gosub PADFACT_OUVRE_PADPOQPOP
	      When Default
	    Endcase
    When Default
	Endcase

  Case [F:ABV]CODREG
    When "PADPOQ"                 : Gosub AVANT_FAT_PADPOQ
    When "PADPOQPOP"              : Gosub AVANT_FAT_PADPOQ
    When "PADPTD"                 : Gosub AVANT_FAT_PADPTD
    When "PREQUIS", "PREQUISO"    : #Gosub AVANT_FAT_PREQUIS_PREQUISO
    When "PADPND"                 : Gosub AVANT_FAT_PADPND
    When "PADPID"                 : Gosub AVANT_FAT_PADPID
    When "PADPIDDUD"              : Gosub AVANT_FAT_PADPIDDUD
  Endcase
  # ---------------------------

Return
###############################################################################
$DEBUT_FAT
  # Issue 110958 - 2015-09-11 by CPO : GBICURFOLD non existent
  #  Variable globale pour récupérer la devise dossier
  If dim(GBICURFOLD)<=0 Then
    Global Char GBICURFOLD(GLONCUR)
  Endif
  GBICURFOLD = func TRTX3BI.GETSYSCUR()
  # End issue 110958

Return
###############################################################################
$FILTRE_FAT_INC
  Case TABLE
    When "F_PADFACT"     : #Gosub FILTRE_FAT_INC_PADFACT
  Endcase
Return

###############################################################################
$FILTRE_FAT_INC_PADFACT
	If [F:AUD]EVT = "UPDATE" Then
		[F:AUD]EVT = "DELETE"
	Endif
Return

###############################################################################
$TRIGGER_AUDIBI
  If [L]GEN = 2 Then
    Return    # En Synchro RAZ, pas la peine de faire ça
  Endif

  # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  #-- not good in case of multiple folder synchronization
  #If dim(IADBITRT) <= 0 Then
  #  Local Integer IADBITRT  # Pour ne faire le travail qu'une fois dans le process de synchro
  # End issue X3-38377
    Local Integer IONECHANGE

    # On boucle sur le S/P jusqu'à ce qu'il ne fasse plus rien (IONECHANGE = 0)
    # Pour traiter le cas où des utilisateurs travailleraient en même temps que la synchro est réalisée
    IONECHANGE = 0
    #Repeat
      Call MANAGE_AUDITBI([L]GEN, IONECHANGE, [L]TABORG, [L]CRITAUD, [L]DOSAUD, [L]MAXAUD, [L]NBDOSAUD,ZWTABAPPLIORI)
    #Until IONECHANGE = 0
  #Endif # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object - not good in case of multiple folder synchronization !!
Return
###############################################################################
# Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
#--Handle cases like : addresse modification on header (trigger on header not on lignes)
Subprog MANAGE_AUDITBI(IGEN, IONECHANGE, STABORG, SCRITAUD, SDOSAUD, NMAXAUD, INBDOSAUD, STABAPPLIORI)
Value Integer    IGEN
Variable Integer IONECHANGE
Value Char       STABORG
Value Char       SCRITAUD
Value Char       SDOSAUD
Variable Decimal NMAXAUD
Value Integer    INBDOSAUD
Variable Char    STABAPPLIORI

Local Integer IEXIST
Local Char    SADXTRP(type([S]adxtrp)-10)
Local Integer ITIMEBEG
Local Integer NB_TRT
Local Integer NI

  # ---------------------------------------
  If IGEN = 2 Then
    End    # En Synchro RAZ, pas la peine de faire ça
  Endif
  # ---------------------------------------
  If find(STABAPPLIORI,'PREQUIS','PORDER','PRECEIPT','PRETURN','PINVOICE') = 0 End Endif

  IONECHANGE = 0
  NB_TRT     = 0
  ITIMEBEG   = time

  # ---------------------------------------
  # Pour ne surtout pas déclencher l'ATRIFIL
  SADXTRP = [S]adxtrp
  [S]adxtrp = ""
  # ---------------------------------------
  Case STABAPPLIORI
    When "PREQUIS"
      Gosub MANAGE_AUDITBI_PREQUIS

    When "PORDER"
      Gosub MANAGE_AUDITBI_PORDER

    When "PRECEIPT"
      Gosub MANAGE_AUDITBI_PRECEIPT

    When "PRETURN"
      Gosub MANAGE_AUDITBI_PRETURN

    When "PINVOICE"
      Gosub MANAGE_AUDITBI_PINVOICE

    When Default
  Endcase
  # ---------------------------------------
  If NB_TRT > 0 Then
    #    Filter [AUD]
    #    For NI = 0 To INBDOSAUD-1
    #      If GDOSSIER = SDOSAUD(NI) Then
    #        Read [AUD_]AUD0 Last
    #        If !fstat Then
    #          MAXAUD(NI) = [F:AUD_]SEQ
    #          SCRITAUD = func ABIMAJBAS.CRITAUD(GDOSSIER, SDOSAUD, NMAXAUD, INBDOSAUD)
    #        Endif
    #        Break
    #      Endif
    #    Next
    #    Filter [AUD] Where TBL=STABORG & (STABI=2 or STABI=4) & evalue(SCRITAUD) : # A traiter
  Endif
  # ---------------------------------------
  [S]adxtrp = SADXTRP
  # ---------------------------------------

End
# Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
#--------------------------------------------------------------------------------------------------
$MANAGE_AUDITBI_PREQUIS

  If filinfo(filpath("FIL","PREQUIS" ,"fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","PREQUISD","fde",GDOSSIER),0) <= 0
    Return
  Endif

  Gosub DECL_VAR

  # Lecture de la règle de synchro PADPSD.
  # Si elle est désactivée : on n'exécute pas le traitement.
  CODE_SYNCRULE = "PADPSD"
  [L]DESFLG = func READ_SYNCRULE(CODE_SYNCRULE, GDOSSIER)
  If [L]DESFLG = 2 Then Return Endif

  Call ECR_TRACE("Rule : " - time$ -"Origin header table :"-STABAPPLIORI, 0) From GESECRAN

  # PREQUIS
  Local File =GDOSSIER+".PREQUISD" [PSD]

  Raz WREQ
  If clalev([F:RREQ_])>0 : Close File [F:RREQ_] : Endif

  # Requête de sélection des enregistrements
  WREQ(0) = "SELECT PSD.PSHNUM_0, PSD.PSDLIN_0 FROM PREQUISD PSD"
  WREQ(0)-= "INNER JOIN AUDITBI WAUH ON (WAUH.ID1_0=PSD.PSHNUM_0"
  WREQ(0)-= "AND WAUH.TBL_0='PREQUIS' AND WAUH.STABI_0 IN (2,4)"
  WREQ(1) = "AND WAUH.EVT_0='UPDATE') WHERE CAST(PSD.PSDLIN_0 AS VARCHAR(8)) NOT IN"
  WREQ(1)-= "(SELECT WAUD.ID2_0 FROM AUDITBI WAUD"
  WREQ(1)-= "WHERE WAUD.ID1_0=WAUH.ID1_0 AND WAUD.ID2_0<>' '"
  WREQ(2) = "AND WAUD.TBL_0='PREQUISD' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0<>'DELETE')"
  WREQ(2)-= "GROUP BY PSD.PSHNUM_0,PSD.PSDLIN_0"

  For (Char VCRNUM(GLONVCR), Integer VCRLIN)
&        From WBASE Sql WREQ(0..2) As [F:RREQ_]
    Read [F:PSD]PSD0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN
    If !fstat
      Rewrite [PSD]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
  Next

  LogicClose File [PSD]

  Call ECR_TRACE("End rule : records updated" - num$(NB_TRT) - time$ - "time elapsed : " - num$(time-ITIMEBEG) - "seconds", 0) From GESECRAN

Return
#--------------------------------------------------------------------------------------------------
$MANAGE_AUDITBI_PORDER

  If filinfo(filpath("FIL","PORDER" ,"fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","PORDERQ","fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","PORDERP","fde",GDOSSIER),0) <= 0
    Return
  Endif

  Gosub DECL_VAR

  # Lecture de la règle de synchro PADPOQ.
  # Si elle est désactivée : on n'exécute pas le traitement.
  CODE_SYNCRULE = "PADPOQ"
  [L]DESFLG = func READ_SYNCRULE(CODE_SYNCRULE, GDOSSIER)
  If [L]DESFLG = 2 Then Return : Endif

  Call ECR_TRACE("Rule : " - time$ -"Origin header table :"-STABAPPLIORI, 0) From GESECRAN

  # PORDER
  Local File =GDOSSIER+".PORDERQ" [POQ]
  Local File =GDOSSIER+".PORDERP" [POP]

  Raz WREQ
  If clalev([F:RREQ_])>0 : Close File [F:RREQ_] : Endif

  # Requête de sélection des enregistrements
  WREQ(0) = "SELECT POQ.SOHNUM_0, POQ.POPLIN_0, POQ.POQSEQ_0 FROM PORDERQ POQ"
  WREQ(0)-= "INNER JOIN AUDITBI WAUH ON (WAUH.ID1_0 = POQ.SOHNUM_0"
  WREQ(0)-= "AND WAUH.TBL_0 = 'PORDER' AND WAUH.STABI_0 IN (2,4)"
  WREQ(1) = "AND WAUH.EVT_0 = 'UPDATE') WHERE CONCAT(CONCAT(CAST(POQ.POPLIN_0 AS VARCHAR(8)),'~'),CAST(POQ.POQSEQ_0 AS VARCHAR(8))) NOT IN"
  WREQ(1)-= "(SELECT WAUD.ID2_0 FROM AUDITBI WAUD"
  WREQ(1)-= "WHERE WAUD.ID1_0 = WAUH.ID1_0 AND WAUD.ID2_0 <> ' '"
  WREQ(2) = "AND WAUD.TBL_0 = 'PORDERQ' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0<>'DELETE')"
  WREQ(2)-= "GROUP BY POQ.SOHNUM_0, POQ.POPLIN_0, POQ.POQSEQ_0"

  For (Char VCRNUM(GLONVCR), Integer VCRLIN, Integer VCRSEQ)
&        From WBASE Sql WREQ(0..2) As [F:RREQ_]
    Read [F:POQ]POQ0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN;[F:RREQ_]VCRSEQ
    If !fstat
      Rewrite [POQ]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
    Read [F:POP]POP0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN;[F:RREQ_]VCRSEQ
    If !fstat
      Rewrite [POP]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
  Next

  LogicClose File [POQ], [POP]

  Call ECR_TRACE("End rule : records updated" - num$(NB_TRT) - time$ - "time elapsed : " - num$(time-ITIMEBEG) - "seconds", 0) From GESECRAN

Return
#--------------------------------------------------------------------------------------------------
$MANAGE_AUDITBI_PRECEIPT

  If filinfo(filpath("FIL","PRECEIPT" ,"fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","PRECEIPTD","fde",GDOSSIER),0) <= 0
    Return
  Endif

  Gosub DECL_VAR

  # Lecture de la règle de synchro PADPTD.
  # Si elle est désactivée : on n'exécute pas le traitement.
  CODE_SYNCRULE = "PADPTD"
  [L]DESFLG = func READ_SYNCRULE(CODE_SYNCRULE, GDOSSIER)
  If [L]DESFLG = 2 Then Return : Endif

  Call ECR_TRACE("Rule : " - time$ -"Origin header table :"-STABAPPLIORI, 0) From GESECRAN

  # PRECEIPT
  Local File =GDOSSIER+".PRECEIPTD" [PTD]

  Raz WREQ
  If clalev([F:RREQ_])>0 : Close File [F:RREQ_] : Endif

  # Requête de sélection des enregistrements
  WREQ(0) = "SELECT PTD.PTHNUM_0, PTD.PTDLIN_0 FROM PRECEIPTD PTD"
  WREQ(0)-= "INNER JOIN AUDITBI WAUH ON (WAUH.ID1_0=PTD.PTHNUM_0"
  WREQ(0)-= "AND WAUH.TBL_0='PRECEIPT' AND WAUH.STABI_0 IN (2,4)"
  WREQ(1) = "AND WAUH.EVT_0='UPDATE') WHERE CAST(PTD.PTDLIN_0 AS VARCHAR(8)) NOT IN"
  WREQ(1)-= "(SELECT WAUD.ID2_0 FROM AUDITBI WAUD"
  WREQ(1)-= "WHERE WAUD.ID1_0=WAUH.ID1_0 AND WAUD.ID2_0<>' '"
  WREQ(2) = "AND WAUD.TBL_0='PRECEIPTD' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0<>'DELETE')"
  WREQ(2)-= "GROUP BY PTD.PTHNUM_0,PTD.PTDLIN_0"

  For (Char VCRNUM(GLONVCR), Integer VCRLIN)
&        From WBASE Sql WREQ(0..2) As [F:RREQ_]
    Read [F:PTD]PTD0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN
    If !fstat
      Rewrite [PTD]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
  Next

  LogicClose File [PTD]

  Call ECR_TRACE("End rule : records updated" - num$(NB_TRT) - time$ - "time elapsed : " - num$(time-ITIMEBEG) - "seconds", 0) From GESECRAN

Return
#--------------------------------------------------------------------------------------------------
$MANAGE_AUDITBI_PRETURN

  If filinfo(filpath("FIL","PRETURN" ,"fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","PRETURND","fde",GDOSSIER),0) <= 0
    Return
  Endif

  Gosub DECL_VAR

  # Lecture de la règle de synchro PADPND.
  # Si elle est désactivée : on n'exécute pas le traitement.
  CODE_SYNCRULE = "PADPND"
  [L]DESFLG = func READ_SYNCRULE(CODE_SYNCRULE, GDOSSIER)
  If [L]DESFLG = 2 Then Return : Endif

  Call ECR_TRACE("Rule : " - time$ -"Origin header table :"-STABAPPLIORI, 0) From GESECRAN

  # PRETURN
  Local File =GDOSSIER+".PRETURND" [PND]

  Raz WREQ
  If clalev([F:RREQ_])>0 : Close File [F:RREQ_] : Endif

  # Requête de sélection des enregistrements
  WREQ(0) = "SELECT PND.PNHNUM_0, PND.PNDLIN_0 FROM PRETURND PND"
  WREQ(0)-= "INNER JOIN AUDITBI WAUH ON (WAUH.ID1_0=PND.PNHNUM_0"
  WREQ(0)-= "AND WAUH.TBL_0='PRETURN' AND WAUH.STABI_0 IN (2,4)"
  WREQ(1) = "AND WAUH.EVT_0='UPDATE') WHERE CAST(PND.PNDLIN_0 AS VARCHAR(8)) NOT IN"
  WREQ(1)-= "(SELECT WAUD.ID2_0 FROM AUDITBI WAUD"
  WREQ(1)-= "WHERE WAUD.ID1_0=WAUH.ID1_0 AND WAUD.ID2_0<>' '"
  WREQ(2) = "AND WAUD.TBL_0='PRETURND' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0 <> 'DELETE')"
  WREQ(2)-= "GROUP BY PND.PNHNUM_0,PND.PNDLIN_0"

  For (Char VCRNUM(GLONVCR), Integer VCRLIN)
&        From WBASE Sql WREQ(0..2) As [F:RREQ_]
    Read [F:PND]PND0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN
    If !fstat
      Rewrite [PND]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
  Next

  LogicClose File [PND]

  Call ECR_TRACE("End rule : records updated" - num$(NB_TRT) - time$ - "time elapsed : " - num$(time-ITIMEBEG) - "seconds", 0) From GESECRAN

Return
#--------------------------------------------------------------------------------------------------
$MANAGE_AUDITBI_PINVOICE

  If filinfo(filpath("FIL","PINVOICE" ,"fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","PINVOICED","fde",GDOSSIER),0) <= 0
    Return
  Endif

  Gosub DECL_VAR

  # Lecture de la règle de synchro S.
  # Si elle est désactivée : on n'exécute pas le traitement.
  CODE_SYNCRULE = "PADPID"
  [L]DESFLG = func READ_SYNCRULE(CODE_SYNCRULE, GDOSSIER)
  If [L]DESFLG = 2 Then Return : Endif

  Call ECR_TRACE("Rule : " - time$ -"Origin header table :"-STABAPPLIORI, 0) From GESECRAN

  # PINVOICE
  Local File =GDOSSIER+".PINVOICED" [PID]

  Raz WREQ
  If clalev([F:RREQ_])>0 : Close File [F:RREQ_] : Endif

  # Requête de sélection des enregistrements
  WREQ(0) = "SELECT PIDD.NUM_0, PIDD.PIDLIN_0 FROM PINVOICED PIDD"
  WREQ(0)-= "INNER JOIN AUDITBI WAUH ON (WAUH.ID1_0=PIDD.NUM_0"
  WREQ(0)-= "AND WAUH.TBL_0='PINVOICE' AND WAUH.STABI_0 IN (2,4)"
  WREQ(1) = "AND WAUH.EVT_0='UPDATE') WHERE CAST(PIDD.PIDLIN_0 AS VARCHAR(8)) NOT IN"
  WREQ(1)-= "(SELECT WAUD.ID2_0 FROM AUDITBI WAUD"
  WREQ(1)-= "WHERE WAUD.ID1_0=WAUH.ID1_0 AND WAUD.ID2_0<>' '"
  WREQ(2) = "AND WAUD.TBL_0='PINVOICED' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0<>'DELETE')"
  WREQ(2)-= "GROUP BY PIDD.NUM_0,PIDD.PIDLIN_0"

  For (Char VCRNUM(GLONVCR), Integer VCRLIN)
&        From WBASE Sql WREQ(0..2) As [F:RREQ_]
    Read [F:PID]PID0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN
    If !fstat
      Rewrite [PID]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
  Next

  LogicClose File [PID]

  Call ECR_TRACE("End rule : records updated" - num$(NB_TRT) - time$ - "time elapsed : " - num$(time-ITIMEBEG) - "seconds", 0) From GESECRAN

Return
#--------------------------------------------------------------------------------------------------
# End issue X3-38377
#############################################################################
$AVANT_FAT_COMMUN
  #--- Méthode SETLEG de ADOVAL, TRTX3BI.SETACC, TRTX3BI.GETCUR
  If !clalev([F:CPY])   : Local File =GDOSSIER+".COMPANY"   [CPY] : Endif
  #--- Méthode TRTX3BI.GETSYSCUR
  If !clalev([F:ADW])   : Local File =GDOSSIER+".ADOVAL"    [ADW] : Endif
  If !clalev([F:ADP])   : Local File =GDOSSIER+".ADOPAR"    [ADP] : Endif
  #--- Méthode TRTX3BI.CNVAMT
  If !clalev([F:TCH])   : Local File =GDOSSIER+".TABCHANGE" [TCH] : Endif
  If dim([V]GEURODEV)<1 Then
    If !clalev([F:TCU]) : Local File =GDOSSIER+".TABCUR"    [TCU] : Endif
  Endif
  #--- Méthode TRTX3BI.GETCUR
  If !clalev([F:FCY])   : Local File =GDOSSIER+".FACILITY"  [FCY] : Endif
  #--- Méthode TRTX3BI.CNVQTY
  If !clalev([F:ITM])   : Local File =GDOSSIER+".ITMMASTER" [ITM] : Endif
  #--- Méthode TRTX3BI.SETCOA et SETACC
  If !clalev([F:GCM])   : Local File =GDOSSIER+".GACM"      [GCM] : Endif
  If !clalev([F:LED])   : Local File =GDOSSIER+".GLED"      [LED] : Endif
  #--- Méthode TRTX3BI.SETACC
  If !clalev([F:GAC])   : Local File =GDOSSIER+".GACCOUNT"  [GAC] : Endif

Return

#############################################################################
$AVANT_FAT_PADPOQ
  #--- Méthode TRTACHBI.GETPOHCPR, GETPURDCA, GETPFIDCA
  If !clalev([F:POH]) : Local File =GDOSSIER+".PORDER"     [POH] : Endif
  If !clalev([F:POQ]) : Local File =GDOSSIER+".PORDERQ"    [POQ] : Endif
  If !clalev([F:POP]) : Local File =GDOSSIER+".PORDERP"    [POP] : Endif
  If !clalev([F:BPS]) : Local File =GDOSSIER+".BPSUPPLIER" [BPS] : Endif
  If !clalev([F:PRS]) : Local File =GDOSSIER+".PRICSTRUCT" [PRS] : Endif
  If !clalev([F:PFI]) : Local File =GDOSSIER+".PFOOTINV"   [PFI] : Endif
Return

#############################################################################
$AVANT_FAT_PADPTD
  #--- Méthode TRTACHBI.GETPURDCA, GETPFICA
  If !clalev([F:PTH])  : Local File =GDOSSIER+".PRECEIPT"  [PTH]  : Endif
  If !clalev([F:PTD])  : Local File =GDOSSIER+".PRECEIPTD" [PTD]  : Endif
Return

#############################################################################
$AVANT_FAT_PREQUIS_PREQUISO
  #--- Méthode TRTACHBI.GETPURDCA
  If !clalev([F:PSH])  : Local File =GDOSSIER+".PREQUIS"   [PSH]   : Endif
  If !clalev([F:PSD])  : Local File =GDOSSIER+".PREQUISD"  [PSD]   : Endif
Return

#############################################################################
$AVANT_FAT_PADPND
  #--- Méthode TRTACHBI.GETPURDCA
  If !clalev([F:PNH])  : Local File =GDOSSIER+".PRETURN"    [PNH] : Endif
  If !clalev([F:PND])  : Local File =GDOSSIER+".PRETURND"   [PND] : Endif
  If !clalev([F:BPS])  : Local File =GDOSSIER+".BPSUPPLIER" [BPS] : Endif
Return

#############################################################################
$AVANT_FAT_PADPID
  #--- Méthode TRTACHBI.GETPIHFCY, GETPFIDCA
  If !clalev([F:PID])  : Local File =GDOSSIER+".PINVOICED" [PID]  : Endif
  If !clalev([F:PIDB]) : Local File =GDOSSIER+".PINVOICED" [PIDB] : Endif
  If !clalev([F:PID2]) : Local File =GDOSSIER+".PINVOICED" [PID2] : Endif
  If !clalev([F:POQ])  : Local File =GDOSSIER+".PORDERQ"   [POQ]  : Endif
  If !clalev([F:PTD])  : Local File =GDOSSIER+".PRECEIPTD" [PTD]  : Endif
  If !clalev([F:PND])  : Local File =GDOSSIER+".PRETURND"  [PND]  : Endif
  If !clalev([F:FCY2]) : Local File =GDOSSIER+".FACILITY"  [FCY2] : Endif
  #--- Méthode TRTACHBI.GETPURDCA, GETPFICA
  If !clalev([F:PIH])  : Local File =GDOSSIER+".PINVOICE"  [PIH]  : Endif
  #--- Méthode TRTACHBI.GETPFIDCA
  If !clalev([F:PIV])  : Local File =GDOSSIER+".PINVOICEV" [PIV]  : Endif
Return

#############################################################################
$AVANT_FAT_PADPIDDUD
  #--- Méthode TRTACHBI.GETPFIFCY
  If !clalev([F:PID])  : Local File =GDOSSIER+".PINVOICED" [PID]  : Endif
Return

###############################################################################
$FIN_FAT

  #If clalev([F:WAUJ_]) : Close Local File  [WAUJ_] : Endif
  #--- Méthode TRTX3BI.GETSYSCUR
  If clalev([F:ADW])   : Close Local File  [ADW]   : Endif
  If clalev([F:ADP])   : Close Local File  [ADP]   : Endif
  #--- Méthode TRTX3BI.CNVAMT
  If clalev([F:TCH])   : Close Local File  [TCH]   : Endif
  If clalev([F:TCU])   : Close Local File  [TCU]   : Endif
  #--- Méthode TRTX3BI.CNVQTY
  If clalev([F:ITM])   : Close Local File  [ITM]   : Endif
  #--- Méthode TRTX3BI.SETCOA et SETACC
  If clalev([F:GCM])   : Close Local File  [GCM]   : Endif
  If clalev([F:LED])   : Close Local File  [LED]   : Endif
  #--- Méthode TRTX3BI.SETACC
  If clalev([F:GAC])   : Close Local File  [GAC]   : Endif

#  If clalev([F:FCY])   : Close Local File  [FCY]   : Endif
#  If clalev([F:CPY])   : Close Local File  [CPY]   : Endif


  #--- Méthode TRTACHBI.GETPOHCPR, GETPURDCA, GETPFIDCA
  If clalev([F:POH])   : Close Local File  [POH]   : Endif
  If clalev([F:POQ])   : Close Local File  [POQ]   : Endif
  If clalev([F:POP])   : Close Local File  [POP]   : Endif
  If clalev([F:BPS])   : Close Local File  [BPS]   : Endif
  If clalev([F:PRS])   : Close Local File  [PRS]   : Endif
  If clalev([F:PFI])   : Close Local File  [PFI]   : Endif

  #--- Méthode TRTACHBI.GETPURDCA, GETPFICA
  If clalev([F:PTH])   : Close Local File  [PTH]   : Endif
  If clalev([F:PTD])   : Close Local File  [PTD]   : Endif

  #--- Méthode TRTACHBI.GETPURDCA
  If clalev([F:PSH])   : Close Local File  [PSH]   : Endif
  If clalev([F:PSD])   : Close Local File  [PSD]   : Endif

  #--- Méthode TRTACHBI.GETPURDCA
  If clalev([F:PNH])   : Close Local File  [PNH]   : Endif
  If clalev([F:PND])   : Close Local File  [PND]   : Endif

  #--- Méthode TRTACHBI.GETPIHFCY, GETPFIDCA
  If clalev([F:PID])   : Close Local File  [PID]   : Endif
  If clalev([F:PIDB])  : Close Local File  [PIDB]  : Endif
  If clalev([F:PID2])  : Close Local File  [PID2]  : Endif
  If clalev([F:FCY2])  : Close Local File  [FCY2]  : Endif

  #--- Méthode TRTACHBI.GETPURDCA, GETPFICA
  If clalev([F:PIH])   : Close Local File  [PIH]   : Endif

  #--- Méthode TRTACHBI.GETPFIDCA
  If clalev([F:PIV])   : Close Local File  [PIV]   : Endif

Return

###############################################################################
$PADFACT_OUVRE_PADPOQPOP
  #Gosub OUVRE_DIM_DETAIL

  #--Remplissage table temporaire paramétrée dans le link de la dimension
  Local File =GDOSSIER+".BITMPPORDERQ"                     [BIPOQ_]
  Local File =GDOSSIER+".AUDITBI"                          [WAUI_]

  Local File =GDOSSIER+".PORDERP"                          [WPOP_]
  Local File =GDOSSIER+".PORDERQ"                          [WPOQ_]

Local Char SWHERE(250)
Local Char SVID1(type([F:WAUI_]ID1)-10)
Local Char SVID2(type([F:WAUI_]ID1)-10)(1..2)
Local Integer IADXLOG

  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [BIPOQ_]
  Endif
  Delete [BIPOQ_] Where [BIPOQ_]BIPOQADXUID = adxuid(1)
	If [L]GEN <> 2 Then
		Raz SVID1
		Filter [WAUI_] Where (TBL = [F:ABV]TABORG) and (STABI = 2 or STABI = 4) and EVT <> "DELETE" Order By ID1;ID2;SEQ Desc
		For [WAUI_]
			If SVID1 <> ([F:WAUI_]ID1+"~"+[F:WAUI_]ID2) Then
				SWHERE = " (POHNUM ='" + [F:WAUI_]ID1 + "')"
				Call DECOUPE_TILDES([F:WAUI_]ID2, SVID2) From TRTDIMBIPAD
				If SVID2(1)<>"" and SVID2(2)<>""
				  SWHERE -= "& (POPLIN=" + SVID2(1) - "& POQSEQ=" + SVID2(2) + ")"
				  Gosub CREATE_BIPOQ_TRAVAIL
				  SVID1 = [F:WAUI_]ID1 + "~" + [F:WAUI_]ID2
				Endif
			Endif
		Next
		Filter [WAUI_]
	Else
		SWHERE = " (1=1)"
		Gosub CREATE_BIPOQ_TRAVAIL
	Endif
	If IADXLOG = 0 Then
    Commit
  Endif
  Close Local File [BIPOQ_]
  Close Local File [WAUI_]
  Close Local File [WPOP_]
  Close Local File [WPOQ_]
  #Call ECR_TIME("***********************************************OUVRE_DIM_PADPOQ Fin") From DOSSUB
Return

###############################################################################
$CREATE_BIPOQ_TRAVAIL
  #--open orders
  Filter [WPOQ_] Where POHTYP = 2 and evalue(SWHERE)
  For [WPOQ_]
    Raz [F:BIPOQ_]
    [F:BIPOQ_]BIPOQADXUID = adxuid(1)
    [F:BIPOQ_]POHNUM      = [WPOQ_]POHNUM
    [F:BIPOQ_]POPLIN      = [WPOQ_]POPLIN
    [F:BIPOQ_]POQSEQ      = [WPOQ_]POQSEQ
    [F:BIPOQ_]POPSEQ      = 0
    Filter [WPOP_] Where POHNUM=[WPOQ_]POHNUM and POPLIN=[WPOQ_]POPLIN and STRDAT<=[WPOQ_]DEMRCPDAT Order By STRDAT Desc
    For [WPOP_]
      [F:BIPOQ_]POPSEQ    = [WPOP_]POPSEQ
      Break
    Next
    Filter [WPOP_]
    #--If there is not a POP record with STRDAT<=[WPOQ_]DEMRCPDAT, then
    Write [F:BIPOQ_]
  Next
  Filter [WPOQ_]
Return

###############################################################################
# Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
#-------------------------------------------------------------------------------------------------------------------------
$DECL_VAR
Local Char    WREQ(255)(4) : Raz WREQ  # contains the SQL query
Local Integer D
Local Integer NB_ENREG     : NB_ENREG=0
Local Char    WBASE(1)     : WBASE=" "
Local Integer DESFLG
Local Char    CODE_SYNCRULE(GLONABV)
Local Integer ITIMEBEG     : ITIMEBEG = time  # time début

  #--getting the database type
  Gosub ALIM_WBASE

Return
#-------------------------------------------------------------------------------------------------------------------------
$ALIM_WBASE

  # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  WBASE = num$((fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, GACTX.AFOLDER, "TYPDBA") * 2) + 1)

Return
#-------------------------------------------------------------------------------------------------------------------------
Funprog READ_SYNCRULE(CODE_SYNCRULE, VFOLDER)
Variable Char CODE_SYNCRULE
Variable Char VFOLDER

Local Integer DESACT

  DESACT = 1
  If CODE_SYNCRULE <> "" Then
    If clalev([F:ABV]) = 0 : Local File =VFOLDER+".ABIREGORG" [ABV] : Endif
    Read [F:ABV]ABV0=CODE_SYNCRULE
    If !fstat and dim([F:ABV]DESFLG) > 0 Then
      DESACT = [F:ABV]DESFLG
    Endif
  Endif
End DESACT
# End issue X3-38377
#-------------------------------------------------------------------------------------------------------------------------

