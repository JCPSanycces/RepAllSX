## Bloc tableau 4
####################################
Subprog SAI_NBLIG2(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG2
mkstat = 0
zoncou = "NBLIG2"

## Zone LEVPAY
mkstat = 0
zoncou = "LEVPAY"
IMPENT = [M]LEVPAY(indice)
If varinit([M]LEVPAY,indice)=0
 IMPENT = 1
Endif
If varmode([M]LEVPAY,indice)=0
 Call INICOMBO(10506) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_LEVPAY(IMPENT) From SUBORA
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10506,1))))
 Endif
 [M]LEVPAY(indice) = IMPENT
