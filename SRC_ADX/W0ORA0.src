  IMPMOD = 0 : IMPZON = "BANFCY1" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]BANFCY1(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "BANFCY1" : GZNUM = 7475 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("BAN","",[M]BANFCY1(indice),"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "BANFCY1" : GZNUM = 7475 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_BANFCY1([M]BANFCY1(indice)) From SUBORA
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "BANFCY1" : GZNUM = 7475 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

