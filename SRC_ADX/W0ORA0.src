   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]LEVPAY(indice) = IMPENT

## Zone CPYPAY
mkstat = 0
zoncou = "CPYPAY"
If varmode([M]CPYPAY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CPYPAY([M]CPYPAY(indice)) From SUBORA
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CPYPAY(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPYPAY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]CPYPAY(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CPYPAY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTCPY"
   Call CONTSOC([M]CPYPAY(indice)) From SUBAGF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CPYPAY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("CPY","",[M]CPYPAY(indice),"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "CPYPAY" : GZNUM = 1343 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_CPYPAY([M]CPYPAY(indice)) From SUBORA
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CPYPAY" : GZNUM = 1343 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "CONTCPYLEG"
      Call CONTCPYLEG([M]CPYPAY(indice),GCURLEG) From TRTX3
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CPYPAY" : GZNUM = 1343 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone MODPAY
mkstat = 0
zoncou = "MODPAY"
If varinit([M]MODPAY,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]MODPAY(indice),"10471","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]MODPAY,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "MODPAY" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]MODPAY(indice),"10471","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MODPAY" : GZNUM = 7770 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]MODPAY(indice),"10471",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "MODPAY" : GZNUM = 7770 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone BANFCY1
mkstat = 0
zoncou = "BANFCY1"
