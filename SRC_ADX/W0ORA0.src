#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ORA0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]COD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 35085 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]COD
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]COD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 35085 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTORG"
   Call CONTORG([M]COD) From SUBORG
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 35085 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJW"
    PARAM(1) = "ORG"
    Local Char    VALEUR(250)
    VALEUR = [M]COD
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
    [M]COD = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 35085 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone TYPIRC
mkstat = 0
zoncou = "TYPIRC"
indice = 0
IMPENT = [M]TYPIRC
If varinit([M]TYPIRC,indice)=0
 IMPENT = 1
Endif
[M]TYPIRC = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBLIG From SUBORA
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBLIG : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone NBLIG2
mkstat = 0
zoncou = "NBLIG2"
indice = 0
status = 1
zoncou = "NBLIG2"
If varmode([M]NBLIG2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG2" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG2
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG2 = nolign
   status = 75
   Call SAI_NBLIG2(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone LEV
mkstat = 0
zoncou = "LEV"
IMPENT = [M]LEV(indice)
If varinit([M]LEV,indice)=0
 IMPENT = 1
Endif
If varmode([M]LEV,indice)=0
 Call INICOMBO(10506) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_LEV(IMPENT) From SUBORA
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10506,1))))
 Endif
 [M]LEV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LEV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LEV(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_LEV(IMPENT) From SUBORA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]LEV(indice) = IMPENT

## Zone POP
mkstat = 0
zoncou = "POP"
WCHAR = [M]POP(indice)
If varmode([M]POP,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_POP([M]POP(indice)) From SUBORA
 GACTION = SAVACT
