   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTPOP"
   Call CONTPOP([M]POP(indice),GCURLEG) From SUBPOP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("POP","",[M]POP(indice),"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_POP([M]POP(indice)) From SUBORA
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]POP(indice) or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_POP([M]POP(indice)) From SUBORA
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone CPY
mkstat = 0
zoncou = "CPY"
WCHAR = [M]CPY(indice)
If varmode([M]CPY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CPY([M]CPY(indice)) From SUBORA
