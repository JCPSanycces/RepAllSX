#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque RSAQ 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:15:40"
A_USER  = "DOC"
A_STAMP = "20181109231540"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask RSAQ [RSAQ]
Gosub HORODAT
Local Inpbox "RSAQ" From GFONCTION At A_STAMP With A_WINDPREV Mask [RSAQ] As [SIM_]
Grizo [RSAQ]5
Grizo [RSAQ]10
Grizo [RSAQ]15
Grizo [RSAQ]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [RSAQ]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=23 : X2(0)=60 : Y1(0)=9 : Y2(0)=11
X1(1)=61 : X2(1)=90 : Y1(1)=9 : Y2(1)=11
X1(2)=23 : X2(2)=90 : Y1(2)=12 : Y2(2)=16
X1(3)=23 : X2(3)=90 : Y1(3)=17 : Y2(3)=19
Return

$ON_CRN
Onevent CONTROL Call C_CRN(zc) From W1RSAQ
Return

Subprog C_CRN(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CRN" : GZNUM = 29314 : Endif
Gosub _AFF
End

$ON_CRN2
Onevent CONTROL Call C_CRN2(zc) From W1RSAQ
Return

Subprog C_CRN2(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CRN2" : GZNUM = 49207 : Endif
Gosub _AFF
End

$ON_DATDEB
Onevent BEFORE_AREA Gosub AV_DATDEB From W1RSAQ
Return

$AV_DATDEB
Chgfmt [M]DATDEB(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_DATFIN
Onevent BEFORE_AREA Gosub AV_DATFIN From W1RSAQ
Return

$AV_DATFIN
Chgfmt [M]DATFIN(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_FLGWDR
Onevent INIT_AREA Call D_FLGWDR(zc) From W1RSAQ
Onevent BEFORE_INPUT Call AS_FLGWDR(zc) From W1RSAQ
Onevent CONTROL Call C_FLGWDR(zc) From W1RSAQ
Return

Subprog D_FLGWDR(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGWDR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGWDR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_FLGWDR(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "FLGWDR" : GZNUM = 44204 : Endif
Gosub _AFF
End

$ON_NOPKG
Onevent CONTROL Call C_NOPKG(zc) From W1RSAQ
Onevent INIT_AREA Call D_NOPKG(zc) From W1RSAQ
Return

Subprog D_NOPKG(VALEUR)
Variable Char    VALEUR()
If varinit([M]NOPKG,indice)=0
 VALEUR = "1"
Endif
Gosub _AFF
End

Subprog C_NOPKG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NOPKG" : GZNUM = 3126 : Endif
If !mkstat
 ## Action STD
 Call C_NOPKG(VALEUR) From RSAQ
 If mkstat : GERR = 1 : GZONE = "NOPKG" : GZNUM = 3126 : Endif
Endif
Gosub _AFF
End

$ON_NOREC
Onevent CONTROL Call C_NOREC(zc) From W1RSAQ
Onevent INIT_AREA Call D_NOREC(zc) From W1RSAQ
Return

Subprog D_NOREC(VALEUR)
Variable Char    VALEUR()
If varinit([M]NOREC,indice)=0
 VALEUR = "1"
Endif
Gosub _AFF
End

Subprog C_NOREC(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NOREC" : GZNUM = 26811 : Endif
If !mkstat
 ## Action STD
 Call C_NOREC(VALEUR) From RSAQ
 If mkstat : GERR = 1 : GZONE = "NOREC" : GZNUM = 26811 : Endif
Endif
Gosub _AFF
End

$ON_TYPEXP
Onevent AFTER_CHANGE Gosub AMM_TYPEXP From W1RSAQ
Onevent INIT_AREA Call D_TYPEXP(zc) From W1RSAQ
Onevent BEFORE_INPUT Call AS_TYPEXP(zc) From W1RSAQ
Return

Subprog D_TYPEXP(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPEXP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYPEXP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_TYPEXP
Call AM_TYPEXP(zc)
If !mkstat & GOBJET
 zoncou = "TYPEXP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_TYPEXP(VALEUR) From RSAQ
If mkstat : GERR = 1 : GZONE = "TYPEXP" : GZNUM = 32516 : Endif
Gosub _AFF
End

$ON_VOLFIL
Onevent CONTROL Call C_VOLFIL(zc) From W1RSAQ
Onevent BEFORE_INPUT Call AS_VOLFIL(zc) From W1RSAQ
Return

Subprog AS_VOLFIL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_VOLFIL(zc) From W1RSAQ
Gosub _AFF
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_VOLFIL(VALEUR) From RSAQ
If mkstat : GERR = 1 : GZONE = "VOLFIL" : GZNUM = 15179 : Endif
Gosub _AFF
End

Subprog S_VOLFIL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELFICREP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELFICREP"
 PARMSK(1) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"DFICREP","SELFICREP","XWDFICREP") From GSAISIE
 GACTION = SAVACT
Endif
Gosub _AFF
End

$CHG_STY
Return


