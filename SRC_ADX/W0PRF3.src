#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PRF3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone TBL2
mkstat = 0
zoncou = "TBL2"
indice = 0
status = 1
zoncou = "TBL2"
If varmode([M]TBL2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TBL2" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]TBL2
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]TBL2 = nolign
   status = 75
   Call SAI_TBL2(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_TBL2(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone TBL2
mkstat = 0
zoncou = "TBL2"

## Zone CODVRA
mkstat = 0
zoncou = "CODVRA"
If varmode([M]CODVRA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODVRA" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CODVRA(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CODVRA" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTVRA"
  Call CONTVRA([M]CODVRA(indice)) From SUBVRA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODVRA" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]CODVRA(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]CODVRA(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CODVRA" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CODVRA([M]CODVRA(indice)) From SUBPRF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CODVRA" : GZNUM = 5296 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone ENAFLG3
mkstat = 0
zoncou = "ENAFLG3"
IMPENT = [M]ENAFLG3(indice)
If varinit([M]ENAFLG3,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENAFLG3,indice)=0
 [M]ENAFLG3(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG3" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG3(indice)
 Endif
Endif
[M]ENAFLG3(indice) = IMPENT

## Zone TBL2
mkstat = 0
zoncou = "TBL2"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PRF3"
Return

