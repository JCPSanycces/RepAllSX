#<AdxTL>@(#)0.0.0.0 $Revision$
#------------------------------------------------------------#
Funprog ISSCRIPTALLOWED(REPERT,CODE)
Value    Char     REPERT : #"STC" or "TRT"
Value    Char     CODE : #code without extension

Local Integer CUSTOM
If  ([L]REPERT="TRT" & func ADS_TOOL.ISTRUSTEDTRT([L]CODE)=[V]CST_AFALSE)
& | ([L]REPERT="STC" & func ADS_TOOL.ISTRUSTEDSTC([L]CODE)=[V]CST_AFALSE)
 [L]CUSTOM=1
Endif

End (find([L]REPERT,"STC","TRT")=0 | func ADS_TOOL.ISTRUSTEDENV=[V]CST_ATRUE | [L]CUSTOM=1)
#------------------------------------------------------------#
Subprog VALID_EXTERNAL(REPERT,CODE,DOSSIER,OK,TABMES)
Value    Char     REPERT : #"STC" or "TRT"
Value    Char     CODE : #code without extension
Value    Char     DOSSIER : #full folder server:port@@folder or folder for current app
Variable Integer OK
Variable Char     TABMES()(1..5)

Local Integer ISACTX,VALP
Local Integer ISTECH : ISTECH = 1

Gosub DEFVAR_CHECK From ASYRCONST # Issue 41442 - 2017-06-19 by eboyard :  It happens that CST global variables are not set
Onerrgo ABORT_VALID_EXTERNAL
Gosub TRT_VALID
End

# Issue 41442 - 2017-06-19 by eboyard :
$ABORT_VALID_EXTERNAL
OK = 0
TABMES(1) = errp+"("+num$(errl)+")"-num$(errn)+"\"+errmes$(errn)+"\"+errm
End
# End issue 41442

#------------------------------------------------------------#
Subprog VALID_TECH(REPERT,CODE,ISACTX,DOSSIER,VALP,TYPAGE,OK,MES)
Value    Char     REPERT : #"STC" or "TRT"
Value    Char     CODE : #code without extension
Value    Integer ISACTX : # 2 for context validation
Value    Char     DOSSIER : #full folder server:port@@folder or folder for current app
Value    Integer  VALP : # <>0 to get internal memory archive number in TYPAGE
Variable Integer TYPAGE
Variable Integer OK
Variable Char     MES

Local Integer ISTECH : ISTECH = 1

Gosub TRT_VALID
End

#------------------------------------------------------------#
Subprog VALID(REPERT,CODE,ISACTX,DOSSIER,VALP,TYPAGE,OK,AERR)
Value    Char     REPERT : #"STC" or "TRT"
Value    Char     CODE : #code without extension
Value    Integer ISACTX : # 2 for context validation
Value    Char     DOSSIER : #full folder server:port@@folder or folder for current app
Value    Integer  VALP : # <>0 to get internal memory archive number in TYPAGE
Variable Integer TYPAGE
Variable Integer  OK
Variable Instance AERR Using C_AERROR

Local Integer ISTECH : ISTECH = 0

Gosub TRT_VALID
End

#------------------------------------------------------------#
$TRT_VALID
Local Integer STAT , SAVSEEK
Local Char    FICTRA(GDIMFIC)
Local Char    WCMDE(250)(1..2)
Local Char    MESSAGE(80)(1..5) , MESSA(80)
Local Char    SAVIFS(20), SAVIRS(20)
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

Local Char VERSRUN(30)

If [L]CODE="OBJECT" : Return : Endif

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

Local Integer WLOCKSTC
If [L]REPERT="STC"
 #----- Contrôle lock logique -----#
 Call JELOCKEDOS([L]DOSSIER,"AVALSUPSTC",WLOCKSTC) From OBJDIV
 If WLOCKSTC=0
  WLOCKSTC=1
  Lock ="AVALSUPSTC" From =[L]DOSSIER With lockwait=-1
 Else
  WLOCKSTC=0
 Endif
Endif

If ISACTX<>2 & dim(GACTX.LAN)>0 & dim(GACTX.ASOL.OS)>0 & GACTX.LAN<>""
 VERSRUN=func ASYRSYS.VERSRUN(GACTX,MACHINE+string$(MACHINE="",adxmac(0)))
Else
 VERSRUN=func ASYRSYS._AVERSRUN(MACHINE+string$(MACHINE="",adxmac(0)))
Endif

SAVIFS = adxifs
SAVIRS = adxirs
Case [L]REPERT
 When "STC"
  WCMDE(1) = "valstc"
  If dim([L]VALP)>0 & [L]VALP>0 : WCMDE(1) -= "-p" : Endif
  #102739
  If func ADS_TOOL.ISTRUSTEDENV=[V]CST_AFALSE & func ADS_TOOL.ISTRUSTEDSTC([L]CODE)=[V]CST_AFALSE
   If VERSRUN>="17r.218"
     WCMDE(1) -='-t'
   Endif
  Endif
  MESSA = mess(2,140,1) : # Erreur en validation de la classe
 When Default
  WCMDE(1) = "valtrt"
  #102739
  If func ADS_TOOL.ISTRUSTEDENV=[V]CST_AFALSE & func ADS_TOOL.ISTRUSTEDTRT([L]CODE)=[V]CST_AFALSE
   If VERSRUN>="17r.218"
     WCMDE(1) -='-t'
   Endif
  Endif
  MESSA = mess(20,123,1) : # Erreur en validation du traitement
Endcase

If VERSRUN>="16r.216"
 WCMDE(1) -= "-l"
 If  ISACTX<>2 & dim(GACTX.LAN)>0 & GACTX.LAN<>""
  WCMDE(1) -= GACTX.LAN
 Else
  WCMDE(1) -=  "FRA"
 Endif
Endif

WCMDE(1) -= APPLI-[L]CODE
If dim([L]VALP)>0 & [L]VALP>0
 FICTRA = filpath("tmp",[L]CODE,"tra",APPLI,"",MACHINE)
 Openo FICTRA,0
 Openo
Elsif GTRACE<>""
 Call FLUSH_TRACE From GESECRAN
 FICTRA = filpath("TRA",GTRACE,"tra",nomap)
 Openo FICTRA,-1
 SAVSEEK = adxseek(1)
 Openo
Else
 FICTRA = filpath("tmp",[L]CODE,"tra",APPLI,"",MACHINE)
 Openo FICTRA,0
 Openo
Endif
WCMDE(2)  = FICTRA
If ISACTX<>2 & dim(GACTX.LAN)>0 & dim(GACTX.ASOL.OS)>0 & GACTX.LAN<>""
 Call SYSTEME(GACTX,MACHINE,WCMDE,"",STAT) From ASYRSYS
Else
 Call _ASYSTEME(MACHINE,WCMDE,"",STAT) From ASYRSYS
Endif
If STAT
 If !ISTECH
  AERR = NewInstance C_AERROR AllocGroup AERR
  AERR.STA = [V]CST_AERROR
  AERR.MES = mess(6,123,1)-num$(STAT)-"SYSTEME"+"\|"+WCMDE(1) : # Erreur
  AERR.NUM = 9101
 Elsif dim(TABMES)>0
  TABMES(1) = mess(6,123,1)-num$(STAT)-"SYSTEME" : # Erreur
 Else
  MES = mess(6,123,1)-num$(STAT)-"SYSTEME"+"\|"+WCMDE(1) : # Erreur
 Endif
 OK = 0
 Goto ENDVALID
Endif
If dim([L]VALP)<0 | [L]VALP=0
 If GTRACE=""
  Openi FICTRA Using [CLAVAL]
  Iomode adxifs "" Using [CLAVAL]
  Iomode adxirs chr$(10) Using [CLAVAL]
  Raz MESSAGE
  Rdseq MESSAGE(1) Using [CLAVAL]
  Rdseq MESSAGE(2) Using [CLAVAL]
  Rdseq MESSAGE(3) Using [CLAVAL]
  Rdseq MESSAGE(4) Using [CLAVAL]
  Rdseq MESSAGE(5) Using [CLAVAL]
  Openi Using [CLAVAL]
  If MESSAGE(1)<>""
   If !ISTECH
    AERR = NewInstance C_AERROR AllocGroup AERR
    AERR.STA = [V]CST_AERROR
    AERR.MES = MESSA-[L]CODE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3)+"|\|"+MESSAGE(4)
    AERR.NUM = 9101
   Elsif dim(TABMES)>0
    TABMES(1) = MESSAGE(1)
    TABMES(2) = MESSAGE(2)
    TABMES(3) = MESSAGE(3)
    TABMES(4) = MESSAGE(4)
   Else
    MES = MESSA-[L]CODE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3)+"|\|"+MESSAGE(4)
   Endif
   OK = 0
   Goto ENDVALID
  Else
   OK = 1
   Call _EFFACE(FICTRA,STAT) From ASYRSYS
   If STAT
    If !ISTECH
     AERR = NewInstance C_AERROR AllocGroup AERR
     AERR.STA = [V]CST_AERROR
     AERR.MES = mess(6,123,1)-num$(STAT)-"EFFACE"+"\|"+FICTRA
     AERR.NUM = 9101
    Elsif dim(TABMES)>0
     TABMES(1) = mess(6,123,1)-num$(STAT)-"EFFACE"
    Else
     MES = mess(6,123,1)-num$(STAT)-"EFFACE"+"\|"+FICTRA
    Endif
    OK = 0
    Goto ENDVALID
   Endif
  Endif
 Else
  Openo FICTRA,-1
  STAT = adxseek(1)
  Openo
  If STAT<>SAVSEEK
   If !ISTECH
    AERR = NewInstance C_AERROR AllocGroup AERR
    AERR.STA = [V]CST_AERROR
    AERR.MES = MESSA-[L]CODE
    AERR.NUM = 9101
   Elsif dim(TABMES)>0
    TABMES(1) = MESSA-[L]CODE
   Else
    MES =  MESSA-[L]CODE
   Endif
   OK = 0
   Call ECR_TRACE(MESSA-[L]CODE,1) From GESECRAN
   Gosub ECR_STACK
   Goto ENDVALID
  Else
   OK = 1
  Endif
 Endif
Else
 Openi FICTRA Using [CLAVAL]
 Iomode adxifs "" Using [CLAVAL]
 Iomode adxirs chr$(10) Using [CLAVAL]
 Raz MESSAGE
 Rdseq MESSAGE(1) Using [CLAVAL]
 Openi Using [CLAVAL]
 TYPAGE = val(MESSAGE(1))
 If TYPAGE=0
  OK = 0
  Goto ENDVALID
 Endif
Endif
If [L]REPERT<>"STC"
 Onerrgo RIEN
 STAT = pushScript([L]MACHINE,[L]DOSSIER,[L]CODE)
 Onerrgo
Endif
adxifs = SAVIFS
adxirs = SAVIRS
$ENDVALID
If WLOCKSTC
 Unlock ="AVALSUPSTC" From =[L]DOSSIER
Endif
Return

$RIEN
Resume

$ECR_STACK
Local Integer I_STACK
Local Char LINE_STACK(150)
I_STACK = 1
LINE_STACK = callstack(I_STACK)
While LINE_STACK <> "" & I_STACK<=20
    If I_STACK=1
    Call ECR_TRACE("Callstack:",1) From GESECRAN
    Endif
    Call ECR_TRACE(LINE_STACK,1) From GESECRAN
    I_STACK += 1
    LINE_STACK = callstack( I_STACK )
Wend
Return

