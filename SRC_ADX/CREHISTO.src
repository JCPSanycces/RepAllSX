#<AdxTL>@(#)0.0.0.0 $Revision$ Création dossier historique
GACTION = "CREHISTO"
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CREHISTO","CREHISTO",3,"") From GTRAITE
End

###################################################
$ACTION
If dim(PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","CREHISTOB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "EXEC"       : Gosub EXEC
Endcase
If PSUBB
 Gosub ACTION From CREHISTOB
Endif
Return

##################################################################
# Tables qui ne doivent pas être des vues
##################################################################

$SET_NOVIEW
Local Char TABNOVIEW(GLONATB)(1..70)
Local Integer NBNOVIEW
# Superviseur
NBNOVIEW = 1  : TABNOVIEW(NBNOVIEW) = "ATABLE"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "ATABZON"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "ATABIND"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "ADOVALHIS"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "AOBJSEL"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "APLLCK"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "ALSTRD"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "ACALCUL"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "AESPION"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "AREPORTM"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "ATMPTRA"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "ALISTER"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "AFCTEXE"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PRTSCRWRK"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "AWRKHISSUI"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "AWRKHISDES"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "AWRKHISJOI"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "AWRKHISMES"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "AVALNUM"
NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "AUDITH"
Case GPRODUIT
 When 0 : # X3
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PRTSCRWRK"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PWRKORDERS"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PWRKPND"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PWRKPNH"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PWRKPOC"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PWRKPOP"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PWRKPOQ"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PWRKPQF"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PWRKPTD"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PWRKPTH"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PWRKSTT"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "STOWIPW"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TABWIPSTO"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "SWRKDLV"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "SWRKINV"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "STOLOCRES"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "STOTRKWRK"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "WRKSTOCNS"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "BOMPRN"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "WSTANL"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPCNSBAN"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "PIWRK"  : #102632
 When 1 : # Géode
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "INPUTM"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "OUTPUTM"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TRANSFM"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "ADJUSTM"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "BOMMVT"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "SRTALLCRI"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TABVIEWTMP"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPLOADANY"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPLST"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPMAP"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPMERGE"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPPIN"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPOP"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPSEL"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPVAC"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPQAT"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPPRC"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPSKORPK"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPSHP"
 When 2 : # Paye
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPCONGE"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPLIVRE"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPREPOS"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPDCH1"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPDCH2"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPHISTO"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPMVT"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPSYNTPS"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPRECCAL"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPHRSSUP"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPPLN"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPPLNTYP"
  NBNOVIEW += 1 : TABNOVIEW(NBNOVIEW) = "TMPMOB"
Endcase
Return

###################################################
$INIT
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif

Local Char     HISDOS(10) , HISMEN(10) , DOSX3(10)
Local Decimal  COEFF
Local Integer  EXISTE
Local Char     FICORG(250) , FICDES(250) , SYMBOLE(30)
Local Integer  STAT

Read [ADS]DOSSIER = nomap
Read [ADW]ADW0 = "";"";"HISDOS"
If !fstat & [F:ADW]VALEUR<>""
 HISDOS = [F:ADW]VALEUR
 If filinfo(filpath("","","",HISDOS),0)>=0
  EXISTE = 1
 Endif
Endif
Read [ADW]ADW0 = "";"";"SUPDOS"
If !fstat
 DOSX3 = [F:ADW]VALEUR
Endif
If DOSX3="" : DOSX3 = "X3" : Endif
TMP = 1
Return

###################################################
$INIT_DIA
If !EXISTE
 [M:DIA]DOSSIER = "H"+nomap
 Local File APROFIL [A_]
 Read [A_]APF1(1)="HISTO"
 If !fstat
  [M:DIA]HISMEN = "HISTO"
 Endif
 Close Local File [A_]
Else
 [M:DIA]DOSSIER = HISDOS
 Read [ADW]ADW0 = "";"";"HISMEN"
 HISMEN = [F:ADW]VALEUR
 [M:DIA]HISMEN = [F:ADW]VALEUR
 Read [ADW]ADW0 = "";"";"HISCOE"
 [M:DIA]COEFF = val([F:ADW]VALEUR)
 Grizo 10
Endif
[M:DIA]EXISTE = EXISTE
Return

###################################################
$EXEC
Global Integer GERRDOS
If !EXISTE
 If adxmac(0)<>""
  Call ECR_TRACE(mess(128,125,1),1) From GESECRAN : # Création de dossier impossible sur machine distante
  GERRDOS = 1
 Else
  SYMBOLE = "ADS"+nomap
  Lock =SYMBOLE With lockwait=0
  If fstat
   # Fiche dossier verrouillée
   Call ECR_TRACE(nomap-":"-mess(204,125,1),1) From GESECRAN
   GERRDOS = 1
  Else
   Call CREHISTO(nomap,[M:DIA]DOSSIER,DOSX3,[M:DIA]HISMEN,[M:DIA]COEFF)
   Unlock = SYMBOLE
  Endif
 Endif
 TRA = 1
 If !GERRDOS
  Call INIVAR("HISDOS") From ADOVAL
 Endif
Else
 Trbegin [ADW]
  Update [ADW] Where PARAM="HISMEN" With VALEUR=[M:DIA]HISMEN
 Commit
 For I=0 To [F:ADS]NBRLAN-1
  FICORG = filpath("M"+[F:ADS]LAN(I),[M:DIA]HISMEN,"mnu",nomap)
  FICDES = filpath("M"+[F:ADS]LAN(I),[M:DIA]HISMEN,"mnu",HISDOS)
  Call COPIE(FICORG,FICDES,STAT) From ORDSYS
 Next I
Endif
Return

#############################################################
Subprog CREHISTO(APPLI,HISTO,DOSX3,HISMEN,COEFF)
Value Char    APPLI
Value Char    HISTO
Value Char    DOSX3
Value Char    HISMEN
Value Decimal COEFF

Local Char    TABLE(10)
Local Integer I , STAT , K , NBFIC , OK
Local Char    FICORG(GDIMFIC) , FICDES(GDIMFIC) , FIC(20)(1..500)
Local Char    LIGNE(250) , DBA(10) , INITIAL(20) , FNEXT(20) , PCTINC(20)
Local Decimal TAILLE
Local Char    MACHINE(GDIMFIC) , CHEMIN(GDIMFIC) , FICHIER(GDIMFIC) , ORDRE(250)

Read [ADS]DOSSIER = APPLI

Call OUVRE_TRACE(mess(234,133,1)-HISTO) From LECFIC : # Création du dossier historisé

## Création des répertoires

Call CREAPL(APPLI,HISTO)

## Création de la base de données

Call CREBASE(APPLI,HISTO,DOSX3,[F:ADS]TYPDBA,[M:DIA]SIZDAT,[M:DIA]SIZIDX,HISTO,[M:DIA]GRPFIL)
If GERRDOS : End : Endif

# Génération des droits pour la vue ADICADX

Call GENDROIT(APPLI)

Gosub SET_NOVIEW
## Création des tables sur lesquelles on peut faire des transactions
## Table AOBJSEL pour ne pas avoir de mémos hérités, APLLCK pour ne pas planter sous sql-server, etc.

For I=1 To NBNOVIEW
 If filinfo(filpath("FIL",TABNOVIEW(I),"fde",APPLI),0)>0
  Call CRETABLE(APPLI,HISTO,[F:ADS]TYPDBA,TABNOVIEW(I),COEFF,0)
  Call ECR_TRACE(mess(41,125,1)-HISTO+"."+TABNOVIEW(I),0) From GESECRAN
 Endif
Next I

For I=1 To NBNOVIEW
 Call TABLEHIS(APPLI,HISTO,0,0,TABNOVIEW(I)) From DOSTAB
Next I

Local File =APPLI+".ATABLE" [ATB]

#107271
For [ATB]CODFIC Where !find(CODFIC,TABNOVIEW(1..NBNOVIEW)) & TYPFIC=3
 Call TABLEHIS(APPLI,HISTO,0,1,[F:ATB]CODFIC) From DOSTAB :#TYPFIC=3
Next ATB


## Création de vues pour ne pas avoir de problème avec les états
## Sauf les tables qui ne doivent pas être des vues

For [ATB]CODFIC Where !find(CODFIC,TABNOVIEW(1..NBNOVIEW)) & TYPFIC<>3
 If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",APPLI),0)>0
  Call CREVUE(APPLI,HISTO,[F:ADS]TYPDBA,[F:ATB]CODFIC,OK)
  Call ECR_TRACE(mess(121,125,1)-HISTO+"."+[F:ATB]CODFIC,0) From GESECRAN : # Création de la vue
 Endif
Next ATB

## Création des vues du dossier principal

Call COPIE_VUE(APPLI,HISTO,[F:ADS]TYPDBA,[F:ADS]CODDBA)

## Menu de consultation
## Il faudra un autre menu que ADMIN

For I=0 To [F:ADS]NBRLAN-1
 FICORG = filpath("M"+[F:ADS]LAN(I),HISMEN,"mnu",APPLI)
 FICDES = filpath("M"+[F:ADS]LAN(I),HISMEN,"mnu",HISTO)
 Call COPIE(FICORG,FICDES,STAT) From ORDSYS
Next I

## Copie des fichiers menu* et textra*

CHEMIN = filpath("","","",APPLI)
Call MACHINE(CHEMIN,MACHINE,FICHIER) From ORDSYS
ORDRE = 'lsadx -a'-APPLI-FICHIER
Call SYSTEME2(MACHINE,ORDRE,'',NBFIC,FIC) From ORDSYS
NBFIC = min(NBFIC,dim(FIC))
For I=1 To NBFIC
 If left$(FIC(I),6)="textra" or left$(FIC(I),4)="menu"
  FICORG = filpath("",FIC(I),"",APPLI)
  FICDES = filpath("",FIC(I),"",HISTO)
  Call COPIE(FICORG,FICDES,STAT) From ORDSYS
 Endif
Next I

## Sauvegarde des paramètres

Trbegin [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 If fstat
  Raz [F:ADW]
  [F:ADW]PARAM  = "HISDOS"
  [F:ADW]VALEUR = HISTO
  Write [ADW]
 Else
  [F:ADW]VALEUR = HISTO
  Rewrite [ADW]
 Endif
 Read [ADW]ADW0 = "";"";"HISCOE"
 If fstat
  Raz [F:ADW]
  [F:ADW]PARAM  = "HISCOE"
  [F:ADW]VALEUR = num$(COEFF)
  Write [ADW]
 Else
  [F:ADW]VALEUR = num$(COEFF)
  Rewrite [ADW]
 Endif
 Read [ADW]ADW0 = "";"";"HISMEN"
 If fstat
  Raz [F:ADW]
  [F:ADW]PARAM  = "HISMEN"
  [F:ADW]VALEUR = HISMEN
  Write [ADW]
 Else
  [F:ADW]VALEUR = HISMEN
  Rewrite [ADW]
 Endif
 Readlock [ADS]DOSSIER = APPLI
 If fstat=1
  Call ECR_TRACE(APPLI-":"-mess(47,125,1),1) From GESECRAN : # Dossier en cours d'utilisation
 Elsif !fstat
  [F:ADS]DOSHIS = HISTO
  Rewrite [ADS]
  If fstat
   Call ECR_TRACE(mess(13,100,1)-"ADOSSIER",1) From GESECRAN : # Erreur d'écriture sur le fichier
  Else
   Call ECR_TRACE(mess(81,125,1)-"ADOSSIER",0) From GESECRAN : # Mise à jour de la table
  Endif
 Endif
Commit

## Création d'un fichier histo

FICDES = filpath("","histo","",HISTO)
Openo FICDES
Openo

# Création version de l'archive

If filinfo(filpath("","vers","atx",HISTO),0)<=0
 Call SYSTEME(MACHINE,'archive -n -f -d'-HISTO,"",STAT) From ORDSYS
Endif

# Création de la classe OBJECT

Call CRE_CLASS_OBJECT(HISTO) From DOSAPL

# Mise à jour du fichier de description des dossiers

Call CREFOLDERS From VALCSTWEB

#107271
#106969
Call MAJPARHIS(HISTO,"RELEASE",func APRODUCT.AGETRELEASE(APPLI)) From SUBADS
Call MAJPARHIS(HISTO,"RELABR",func APRODUCT.AGETRELEASEABR(APPLI)) From SUBADS
Call MAJPARHIS(HISTO,"MONO","0") From SUBADS

Call ECR_TRACE(mess(34,139,1),0) From GESECRAN : # Fin de création du dossier historisé

End

#--------------------------------------------------------------------------------#
# Affectation des droits sur la table ADICTRT après la création d'un nouvel user
# pour la création de la vue ADICADX
#--------------------------------------------------------------------------------#

Subprog GENDROIT(APPLI)
Value Char APPLI
Local Integer I , NBTAB
Local Char    COMMAND(250) , TBTAB(GLONATB)(1..10)
If APPLI="" : End : Endif
Gosub LEC_DOS
NBTAB = 1 : TBTAB(NBTAB) = "ADICTRT"
For J=1 To NBTAB
 For I=1 To NBDOS
  If GTRACE<>""
   # Table x/Mise à jour des droits dossier y
   Call ECR_TRACE(mess(106,142,1)-TBTAB(J)-":"-mess(191,139,1)-TBDOS(I),0) From GESECRAN
  Endif
  System COMMAND=adxmac(0)+'@valfil -r'-TBDOS(I)-TBTAB(J)
 Next I
Next J
End

#-------------------------------------------#
$LEC_DOS
Local Integer I , NBDOS
Local Char    FICAPL(250) , LIGNE(250) , TBDOS(GLONADS)(1..10)
FICAPL = filpath("","APL","ini",APPLI)
If filinfo(FICAPL,0)>=0
 Openi FICAPL Using [VUE]
 Rdseq LIGNE Using [VUE]
 While fstat=0
  LIGNE = vireblc(LIGNE,2)
  If left$(LIGNE,10)="adxmother("
   J = instr(1,LIGNE,"=")
   If J
    LIGNE = vireblc(right$(LIGNE,J+1),2)
    LIGNE = seg$(LIGNE,2,len(LIGNE)-1)
    If !find(LIGNE,TBDOS(1..NBDOS)) & filinfo(filpath("","","",LIGNE),0)>=0
     NBDOS += 1
     TBDOS(NBDOS) = LIGNE
    Endif
   Endif
  Endif
  Rdseq LIGNE Using [VUE]
 Wend
 Openi Using [VUE]
Endif
If !find(APPLI,TBDOS)
 NBDOS += 1
 TBDOS(NBDOS) = APPLI
Endif
Return

################################################################################
Subprog COPIE_VUE(APPLI,HISTO,TYPDBA,CDBA)
Value Char APPLI, HISTO
Value Integer TYPDBA , CDBA
Local Integer OK
Local File =APPLI+".AVIEW"   [AVW]
Local File =APPLI+".AVIEW"   [AVW2]
Local File =APPLI+".AVIEWD"  [AVD]
Local File =APPLI+".AVIEWC"  [AVC]
Local File =APPLI+".AVIEWB"  [AVB]
Local File =APPLI+".ATEXTE"  [ATX]
Local File =APPLI+".ATABZON" [ATZ]
Local File =APPLI+".ATYPE"   [ATY]
Local File =APPLI+".ACTIV"   [ACV]

For [AVW2]AVW0
 If filinfo(filpath("FIL",[F:AVW2]CODVUE,"viw",APPLI),0)>0
  Call CREVUE([F:AVW2]CODVUE,HISTO,TYPDBA,CDBA,OK) From DOSVUE
 Endif
Next AVW2

End

##############################################################################
## Création d'une vue dans le dossier historisé
##############################################################################
Subprog CREVUE(APPLI,HISTO,TYPDBA,TABLE,OK)
Value Char    APPLI
Value Char    HISTO
Value Integer TYPDBA
Value Char    TABLE
Variable Integer OK

Local Char    MESSA(250)

Local Char     FICSRF(GDIMFIC) , FICVUE(GDIMFIC) , FICVIW(GDIMFIC)
Local Integer  I , J , K , STAT
Local Shortint DIME : DIME = 500 : # 350  118785
Local Char     NAMZ(GLONAVA)(1..DIME) , TYPZ(3)(1..DIME) , LNGZ(10)(1..DIME)
Local Char     DIMZ(3)(1..DIME) , TITZ(30)(1..DIME) , NBZ(10) , NBI(10)
Local Char     MESSAGE(250) , LIGNE(250) , COL(250)
Local Char     FICTRA(GDIMFIC)
Local Char     ORDSYS(250)(1..2)

# Génération du srf pour la vue

FICSRF = filpath("FIL",TABLE,"srf",APPLI)
FICVUE = filpath("FIL",TABLE,"srf",HISTO)
If filinfo(FICSRF,0)<0
 Call ECR_TRACE("|"+FICSRF-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
 Return
Endif
Openi FICSRF Using [I]
Openo FICVUE,0 Using [N]
Iomode adxifs "" Using [I]
Iomode adxirs chr$(10) Using [I]
Iomode adxium GUTF8 Using [I]
Iomode adxifs "" Using [N]
Iomode adxirs chr$(10) Using [N]
Iomode adxium GUTF8 Using [N]
Rdseq LIGNE Using [I] : Wrseq LIGNE Using [N]
Rdseq LIGNE Using [I] : Wrseq LIGNE Using [N]
Rdseq LIGNE Using [I] : Wrseq '"#V"' Using [N]
Rdseq LIGNE Using [I] : Wrseq LIGNE Using [N]
Rdseq NBZ Using [I]
Wrseq NBZ Using [N]
Iomode adxifs chr$(9) Using [I]
Iomode adxifs chr$(9) Using [N]
For I=1 To val(NBZ)
 Rdseq NAMZ(I),TYPZ(I),LNGZ(I),DIMZ(I),TITZ(I) Using [I]
 Wrseq NAMZ(I),TYPZ(I),LNGZ(I),DIMZ(I),TITZ(I) Using [N]
Next I
Iomode adxifs "" Using [I]
Iomode adxifs "" Using [N]
Rdseq NBI Using [I]
Wrseq NBI Using [N]
For I=1 To val(NBI)
 Rdseq LIGNE Using [I]
 Wrseq LIGNE Using [N]
Next I
Openi Using [I]
Openo Using [N]

# Génération du .viw

FICVIW = filpath("FIL",TABLE,"viw",HISTO)
Openo FICVIW,0 Using [V]
Iomode adxifs ""       Using [V]
Iomode adxirs chr$(10) Using [V]
Iomode adxium GUTF8    Using [V]
Raz K , LIGNE
For I=1 To val(NBZ)
 For J=1 To val(DIMZ(I))
  If !K
   COL = " ( "
  Else
   COL = " , "
  Endif
  COL += NAMZ(I)+"_"+num$(J-1)
  Gosub INC
  K += 1
 Next J
Next I
If K>0
 If TYPDBA=1 & 1=0 : # mb 12.12.11 On ne le fait plus à cause du champ updtick
  COL = " ) As Select * From "+APPLI+"."+TABLE
 Else
  COL = " ) As Select "
  Gosub INC
  Raz K
  For I=1 To val(NBZ)
   For J=1 To val(DIMZ(I))
    If !K
     COL = ""
    Else
     COL = " , "
    Endif
    COL += NAMZ(I)+"_"+num$(J-1)
    Gosub INC
    K += 1
   Next J
  Next I
  COL = " From "+APPLI+"."+TABLE
 Endif
Endif
Gosub INC
If LIGNE<>""
 Wrseq LIGNE+" " Using [V]
Endif
Openo Using [V]

# Validation de la vue

FICTRA = filpath("tmp",TABLE,"tra",HISTO)
If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

# Génération du .fde
ORDSYS(1) = "valfil -s"-HISTO-TABLE
ORDSYS(2)  = FICTRA

Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
Openi FICTRA Using [L]
Iomode adxifs ""       Using [L]
Iomode adxirs chr$(10) Using [L]
Raz LIGNE , MESSAGE
Rdseq LIGNE Using [L]
If LIGNE<>""
 MESSAGE = mess(78,139,1) : # Erreur en validation de la vue
 MESSAGE += "\|"+LIGNE
 Rdseq LIGNE Using [L]
 MESSAGE += "|\|"+LIGNE
 Rdseq LIGNE Using [L]
 MESSAGE += "|\|"+LIGNE
Endif
Openi Using [L]
If MESSAGE<>""
 Call ECR_TRACE(mess(77,139,1)-HISTO+"."+TABLE-":\"+MESSAGE,1) From GESECRAN : # Vue
 OK = 0 : End
Endif

If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

#107271
Call TABLEHIS(APPLI,HISTO,0,1,TABLE) From DOSTAB :#CREVUE
End

####################################
$INC
If len(COL)+len(LIGNE)+1>80
 Wrseq LIGNE+" " Using [V]
 LIGNE = ""
Endif
LIGNE += COL
Return

##############################################################################
## Suppression d'une vue
##############################################################################
Subprog SUPVUE_SIL(APPLI,HISTO,TYPDBA,TABLE,OK)
Value Char    APPLI
Value Char    HISTO
Value Integer TYPDBA
Value Char    TABLE
Variable Integer OK
Local Integer SILENCE
Goto SUP_VUE

Subprog SUPVUE(APPLI,HISTO,TYPDBA,TABLE,OK)
Value Char    APPLI
Value Char    HISTO
Value Integer TYPDBA
Value Char    TABLE
Variable Integer OK

$SUP_VUE
Local Integer STAT
Local Char    MESSAGE(250) , LIGNE(250)
Local Char    FICTRA(GDIMFIC)
Local Char    ORDSYS(250)(1..2)
Local Char    SUF(10) , FICHIER(GDIMFIC)

FICTRA = filpath("tmp",TABLE,"tra",HISTO)
If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

# Si ce n'est pas une vue, on se casse
If filinfo(filpath("FIL",TABLE,"fde",HISTO),0)<=0
 STAT = 0
Else
 Call VUE_OK(TABLE,HISTO,"FIL",STAT) From DOSVUE
Endif
If !STAT : End : Endif

# Suppression de la vue
ORDSYS(1) = "valfil -s -d"-HISTO-TABLE
ORDSYS(2)  = FICTRA
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
Openi FICTRA Using [L]
Iomode adxifs ""       Using [L]
Iomode adxirs chr$(10) Using [L]
Raz LIGNE , MESSAGE
Rdseq LIGNE Using [L]
If LIGNE<>""
 MESSAGE = mess(185,125,1) : # Erreur en suppression de la vue
 MESSAGE += "\|"+LIGNE
 Rdseq LIGNE Using [L]
 MESSAGE += "|\|"+LIGNE
 Rdseq LIGNE Using [L]
 MESSAGE += "|\|"+LIGNE
Endif
Openi Using [L]
If MESSAGE<>"" & dim([L]SILENCE)<=0
 Call ECR_TRACE(mess(77,139,1)-HISTO+"."+TABLE-":\"+MESSAGE,1) From GESECRAN : # Vue
 End
Endif

# Suppression des fichiers adonix
For SUF = "srf", "fde", "viw"
 FICHIER = filpath("FIL",TABLE,SUF,HISTO)
 If filinfo(FICHIER,0)>=0
  Call EFFACE(FICHIER,STAT) From ORDSYS
 Endif
Next SUF
End

#######################################################################################
## Création des dico sur les tables du dossier historisé (appelé depuis la SUBADS2)
#######################################################################################
Subprog INSTALL_DICO(APPLI,HISTO,OK)
Value Char APPLI , HISTO
Variable Integer OK
Local Integer I , VUE , OKC
If HISTO="" : End : Endif
OK=1
Local File =APPLI+".ATABLE"  [RATB]
Local File =APPLI+".ATYPE"  [ATY]
Local File =HISTO+".ATABLE"  [ATB]
&         ,=HISTO+".ATABIND" [ATI]
&         ,=HISTO+".ATABZON" [ATZ]

Local File (FICHE(50)) From System 'lsadx -a '+HISTO+' FIL fde' As [SRF]
For [SRF] Where [SRF]FICHE<>""
 If find([SRF]FICHE,"ATABLE","ATABIND","ATABZON")=0
  Read [RATB]CODFIC=[F:SRF]FICHE
  If fstat=0 & [F:RATB]CODACT<>"MIG": #trouve
   Read [ATB]CODFIC=[F:SRF]FICHE
   If fstat : #non trouve
    Call VUE_OK([F:SRF]FICHE,HISTO,"FIL",VUE) From DOSVUE
     If !VUE
     Gosub TRT_ONE_SRF
     If OK=0 : Break : Endif
     Call ECR_TRACE(mess(15,125,1)-HISTO+"."+[F:SRF]FICHE,0) From GESECRAN : # Création de la vue
    Endif
   Endif
  Endif
 Endif
Next

Close Local File
End

$TRT_ONE_SRF
Local Integer ONZON, ONIND,I
Local Char    OBID(250) , OABR(GLONABR) , ODBA(5)
Local Integer CDBA , KDBA , TDBA , MEXT
Local Char    ONOM(GLONAVA)(1..600), OTYP(5)(1..600), OLNG(5)(1..600)
Local Char    OREPET(5)(1..600) , OVERFIC(1)
# Issue 85234 - 2013-01-07 by VPO : autoriser 19 index : 15 sur ATABIND [ATI] + 4 AINDEX [ANX]
Local Char    ONOMCLE(GLONANX)(1..19), OTYPCLE(2)(1..19), OINDEX(250)(1..19) , ODECLI(2)(1..19)
Local Char    NNOMCLE(GLONANX)(1..19), NTYPCLE(2)(1..19), NINDEX(250)(1..19) , NDECLI(2)(1..19)
Local Char    OCLUSTER(10)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = chr$(9)
adxirs = chr$(10)
adxium = GUTF8
#
Local Char    FICSRF(GDIMFIC) , FLAG(10)
FICSRF = filpath("FIL",[F:SRF]FICHE,"srf",HISTO)
If filinfo(FICSRF,0)>0
 Openi FICSRF Using [FSRF]
 Rdseq OBID Using [FSRF]  : # En-tête/Commentaire
 OVERFIC = mid$(OBID,7,1)
 Rdseq OABR Using [FSRF]  : # Abréviation
 Rdseq FLAG Using [FSRF]  : # Répertoire
 VUE = (FLAG='"#V"')
 adxifs = "" : # Suivant les versions our choix, le nb de paramètres peut être différent
 Rdseq OBID Using [FSRF] : # Infos base
 adxifs = chr$(9)
 Rdseq OBID Using [FSRF]  : # Nb zones
 ONZON = val(OBID)
 For I=1 To ONZON
  Rdseq ONOM(I) , OTYP(I) , OLNG(I) , OREPET(I) , OBID Using [FSRF]
 Next I
 adxifs = "" : # Index clusterisé possible
 Rdseq OBID Using [FSRF]
 I = instr(1,OBID,chr$(9))
 If I
  OCLUSTER = right$(OBID,I+1)
 Else
  OCLUSTER = ""
 Endif
 adxifs = chr$(9)
 ONIND = min(val(OBID),dim(ONOMCLE))
 For I=1 To ONIND
  Rdseq ONOMCLE(I),OTYPCLE(I),OINDEX(I),ODECLI(I) Using [FSRF]
 Next I
 Openi Using [FSRF]
 Onerrgo ERR_CREDICO
 Trbegin [ATB],[ATZ],[ATI]
  Delete [ATB] Where CODFIC=[F:SRF]FICHE
  Delete [ATZ] Where CODFIC=[F:SRF]FICHE
  Delete [ATI] Where CODFIC=[F:SRF]FICHE
  [F:ATB]=[F:RATB]
  [F:ATB]CODFIC=[F:SRF]FICHE
  [F:ATB]ABRFIC=OABR
  Write [F:ATB]
  If fstat
    OK=0 : Call FSTA("ATB") From GLOCK : Goto FIN_ERR_TRT_ONE_SRF
  Endif
  For I=1 To ONZON
   Raz [F:ATZ]
   [F:ATZ]NUMLIG=I
   [F:ATZ]CODFIC=[F:ATB]CODFIC
   [F:ATZ]CODZONE=ONOM(I)
   [F:ATZ]DIME=val(OREPET(I))
   Case val(OTYP(I))
    When 79,7:
       [F:ATZ]CODTYP="A"
       [F:ATZ]LONG=max(1,val(OLNG(I)))
    When 81:
       [F:ATZ]CODTYP="AB0"
       [F:ATZ]LONG=max(1,val(OLNG(I)))
    When 82:
       [F:ATZ]CODTYP="AC0"
       [F:ATZ]LONG=max(1,val(OLNG(I)))
    When 84:
       [F:ATZ]CODTYP="AUUID"
       [F:ATZ]LONG=0
    When 85:
       [F:ATZ]CODTYP="ADATIM"
       [F:ATZ]LONG=0
    When 1:
       [F:ATZ]CODTYP="M"
       [F:ATZ]NOLIB=1
       [F:ATZ]LONG=4
    When 2:
       [F:ATZ]CODTYP="C"
       [F:ATZ]LONG=5
    When 3:
       [F:ATZ]CODTYP="L"
       [F:ATZ]LONG=8
    When 4:
       [F:ATZ]CODTYP="DCB"
       [F:ATZ]LONG=max(1,val(OLNG(I)))
    When 5,6:
       [F:ATZ]CODTYP="DCB"
       [F:ATZ]LONG=max(1,val(OLNG(I)))
       For [ATY] Where TYPTYP=val(OTYP(I))
           [F:ATZ]CODTYP=[F:ATY]CODTYP
           [F:ATZ]LONG=0
           Break
       Next
    When 8:
       [F:ATZ]CODTYP="D"
       [F:ATZ]LONG=0
    When Default:
       [F:ATZ]CODTYP="A"
   Endcase
   Write [ATZ]
   If fstat
     OK=0 : Call FSTA("ATZ") From GLOCK : Goto FIN_ERR_TRT_ONE_SRF
   Endif
   If OK=0 : Break : Endif
  Next I
  If OK=0 : Goto FIN_ERR_TRT_ONE_SRF : Endif
  For I=1 To ONIND
   Raz [F:ATI]
   [F:ATI]NUMLIG=I
   [F:ATI]CODFIC=[F:ATB]CODFIC
   [F:ATI]CODIND=ONOMCLE(I)
   If val(OTYPCLE(I))=1
    [F:ATI]HOMONYM=2
   Else
    [F:ATI]HOMONYM=1
   Endif
   [F:ATI]DESCRIPT=OINDEX(I)
   Write [ATI]
   If fstat
     OK=0 : Call FSTA("ATI") From GLOCK : Goto FIN_ERR_TRT_ONE_SRF
   Endif
   If OK=0 : Break : Endif
  Next I
  If OK=0 : Goto FIN_ERR_TRT_ONE_SRF : Endif
 Commit
 If OK=0 : Goto FIN_TRT_ONE_SRF : Endif
Endif

$FIN_TRT_ONE_SRF
Onerrgo
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

$FIN_ERR_TRT_ONE_SRF
Rollback
Goto FIN_TRT_ONE_SRF

$ERR_CREDICO
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE([F:SRF]FICHE-"["+OABR+"]",1) From GESECRAN
OK=0
Resume

#######################################################################################
## Création des vues sur les tables du dossier normal (appelé depuis la console/SUBADS2)
#######################################################################################
Subprog INSTALL_VUE(APPLI,HISTO,OK)
Value Char APPLI , HISTO
Variable Integer OK
Local Integer I , VUE , OKC
If HISTO="" : End : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER = APPLI
If fstat
 Call ECR_TRACE(APPLI-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
 End
Endif
Gosub SET_NOVIEW
Call VUE_OK("ATABLE",HISTO,"FIL",VUE) From DOSVUE
If VUE
 Call SUPVUE_SIL(APPLI,HISTO,[F:ADS]TYPDBA,"ATABLE",OKC)
 Call CRETABLE(APPLI,HISTO,[F:ADS]TYPDBA,"ATABLE",1,0)
 Call ECR_TRACE(mess(41,125,1)-HISTO+"."+"ATABLE",0) From GESECRAN
Endif
Call VUE_OK("ATABZON",HISTO,"FIL",VUE) From DOSVUE
If VUE
 Call SUPVUE_SIL(APPLI,HISTO,[F:ADS]TYPDBA,"ATABZON",OKC)
 Call CRETABLE(APPLI,HISTO,[F:ADS]TYPDBA,"ATABZON",1,0)
 Call ECR_TRACE(mess(41,125,1)-HISTO+"."+"ATABZON",0) From GESECRAN
Endif
Call VUE_OK("ATABIND",HISTO,"FIL",VUE) From DOSVUE
If VUE
 Call SUPVUE_SIL(APPLI,HISTO,[F:ADS]TYPDBA,"ATABIND",OKC)
 Call CRETABLE(APPLI,HISTO,[F:ADS]TYPDBA,"ATABIND",1,0)
 Call ECR_TRACE(mess(41,125,1)-HISTO+"."+"ATABIND",0) From GESECRAN
Endif
Call TABLEHIS(APPLI,HISTO,0,0,"ATABLE") From DOSTAB
Call TABLEHIS(APPLI,HISTO,0,0,"ATABZON") From DOSTAB
Call TABLEHIS(APPLI,HISTO,0,0,"ATABIND") From DOSTAB

Local File =APPLI+".ATABLE" [ATB]
For [ATB]CODFIC Where !find(CODFIC,TABNOVIEW(1..NBNOVIEW)) & TYPFIC=3
 Call TABLEHIS(APPLI,HISTO,0,1,[F:ATB]CODFIC) From DOSTAB :#TYPFIC=3
Next ATB
#
OK = 1
For [ATB]CODFIC Where !find(CODFIC,TABNOVIEW(1..NBNOVIEW)) & TYPFIC<>3 & CODACT<>"MIG"
 If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",APPLI),0)>0
  Call VUE_OK([F:ATB]CODFIC,HISTO,"FIL",VUE) From DOSVUE
  If VUE
   Call SUPVUE_SIL(APPLI,HISTO,[F:ADS]TYPDBA,[F:ATB]CODFIC,OKC)
   OKC = 1
   Call CREVUE(APPLI,HISTO,[F:ADS]TYPDBA,[F:ATB]CODFIC,OKC)
   If OKC
    Call ECR_TRACE(mess(121,125,1)-HISTO+"."+[F:ATB]CODFIC,0) From GESECRAN : # Création de la vue
   Elsif OK
    OK = 0
   Endif
  Endif
 Endif
Next ATB
Close Local File
End

##############################################################################
## Création d'une table
##############################################################################
#107271
Subprog CRE_HISTAB(APPLI,HISAPL,TYPDBA,TABLE)
Value Char    APPLI
Value Char    HISAPL
Value Integer TYPDBA
Value Char    TABLE
Local Integer VUE,FORCE
Local Char WCHHISCOE(30)
FORCE=1
   # Tables qui ne doivent pas être des vues
   Gosub SET_NOVIEW From CREHISTO
   If find(TABLE,TABNOVIEW(1..NBNOVIEW))
    VUE = 0
   Else
    # VUE=1 si le .srf n'existe pas ou si le .srf contient "#V"
     VUE=func DOSVUE.ISVIEW(HISAPL,TABLE)
   Endif
   If VUE
    Local File =APPLI+".ADOVAL"   [ADW_]
    Read [ADW_]ADW0 = "";"";"HISCOE"
    WCHHISCOE=[F:ADW_]VALEUR
    Close Local File [ADW_]
    Call CRETABLE(APPLI,HISAPL,TYPDBA,TABLE,val(WCHHISCOE),FORCE) From CREHISTO :# creation table + dico
    Call TABLEHIS(APPLI,HISAPL,0,0,TABLE) From DOSTAB
   Endif
End

##############################################################################
## Création d'une table
##############################################################################
Subprog CRETABLE(APPLI,HISTO,TYPDBA,TABLE,COEFF,FORCE)
Value Char    APPLI
Value Char    HISTO
Value Integer TYPDBA
Value Char    TABLE
Value Decimal COEFF
Value Integer FORCE

Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer I , STAT , SAVIUM , OK , NBCHAMP , NBCLE , HISPTR
Local Char    FICORG(250) , FICDES(250) , FICTRA(250)
Local Char    LIGNE(250) , DBA(10) , INITIAL(20) , FNEXT(20) , PCTINC(20)
Local Char    SAVIFS(5) , SAVIRS(5) , CLUSTER(10)
Local Decimal TAILLE
Local Char    ORDSYS(250)(1..2)
Local Char    MESSAGE(250)(1..5)
Local Integer TYPCAR

Call SUPVUE(APPLI,HISTO,TYPDBA,TABLE,OK)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = chr$(9)
adxirs = chr$(10)
adxium = GUTF8
FICORG = filpath("FIL",TABLE,"srf",APPLI)
FICDES = filpath("FIL",TABLE,"srf",HISTO)
FICTRA = filpath("tmp",TABLE,"tra",APPLI)

If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

Openi FICORG   Using [AA1]
Openo FICDES,0 Using [AA2]
adxifs = ""
Rdseq LIGNE    Using [AA1] : # En-tête
Wrseq LIGNE    Using [AA2]
Rdseq LIGNE    Using [AA1] : # Abréviation
Wrseq LIGNE    Using [AA2]
Rdseq LIGNE    Using [AA1] : # Commentaire
Wrseq LIGNE    Using [AA2]
Rdseq LIGNE    Using [AA1] : # Infos base
Call PARBAS(LIGNE,DBA,INITIAL,FNEXT,PCTINC) From DOSTAB
adxifs = chr$(9)
If TYPDBA=1
 Case right$(INITIAL,len(INITIAL))
  When "K"     : TAILLE = 1024*val(INITIAL)
  When "M"     : TAILLE = 1024*1024*val(INITIAL)
  When Default : TAILLE = val(INITIAL)
 Endcase
 TAILLE = int(COEFF*TAILLE)
 If TAILLE > 10*1024*1024
  INITIAL = num$(min(1536,int(TAILLE/(1024*1024))+1))+"M" : # On limite à 1,5 G0
 Else
  INITIAL = num$(int(TAILLE/1024)+1)+"K"
 Endif
Endif
Wrseq DBA , INITIAL , FNEXT , PCTINC Using [AA2] : # Infos base
Rdseq LIGNE Using [AA1]
NBCHAMP = val(LIGNE)
If !find(TABLE,"APLLCK")
 Wrseq num$(NBCHAMP+2) Using [AA2]
Else
 Wrseq num$(NBCHAMP) Using [AA2]
Endif
adxifs = ""
For I=1 To NBCHAMP
 Rdseq LIGNE Using [AA1]
 If GPRODUIT=1 & left$(LIGNE,7)="HISPTR"+tab$ : HISPTR=1 : Endif : ## GEODE
 Wrseq LIGNE Using [AA2]
Next I
If !find(TABLE,"APLLCK")
 adxifs = tab$
 Wrseq "CREHISDAT";8;0;1;mess(36,133,1) Using [AA2] : # Date historisation
 Call SETTYP(APPLI,TABLE,TYPCAR)
 Wrseq "CREHISUSR";TYPCAR;GLONAUS;1;mess(37,133,1) Using [AA2] : # Utilisateur
 adxifs = ""
Endif
If HISPTR
 STAT = adxseek("AA1")
 Rdseq LIGNE Using [AA1]
 NBCLE = val(LIGNE)
 For I=1 To NBCLE
  Rdseq LIGNE Using [AA1]
  If right$(LIGNE,3+instr(1,LIGNE,tab$))="HISPTR" : HISPTR=0 : Break : Endif
 Next I
 Seek First+STAT Using [AA1]
Endif
Rdseq LIGNE Using [AA1]
I = instr(1,LIGNE,chr$(9))
If I
 CLUSTER = right$(LIGNE,I+1)
Else
 CLUSTER = ""
Endif
NBCLE = val(LIGNE)
If CLUSTER<>""
 adxifs = tab$
 Wrseq num$(NBCLE+HISPTR),CLUSTER Using [AA2]
 adxifs = ""
Else
 Wrseq num$(NBCLE+HISPTR) Using [AA2]
Endif
For I=1 To NBCLE
 Rdseq LIGNE Using [AA1]
 Wrseq LIGNE Using [AA2]
Next I
adxifs = tab$
If HISPTR
 Wrseq "HISPTR";1;"HISPTR"       Using [AA2]
Endif
adxifs = ""
Openo Using [AA2]
Openi Using [AA1]
ORDSYS(1) = "valfil -s" : # Silencieux
ORDSYS(1) -= "-x"       : # Optimisé
If FORCE
 ORDSYS(1) -= "-f"
Endif
ORDSYS(1) -= HISTO-TABLE
ORDSYS(2)  = FICTRA
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
adxifs = ""
adxirs = chr$(10)
Openi FICTRA Using [TR_]
Raz MESSAGE
Rdseq MESSAGE(1) Using [TR_]
Rdseq MESSAGE(2) Using [TR_]
Rdseq MESSAGE(3) Using [TR_]
Openi Using [TR_]
If MESSAGE(1)<>""
 # Erreur en validation de la table
 Call ECR_TRACE(mess(51,123,1)-HISTO+"."+TABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1)
& From GESECRAN
Else
 Call EFFACE(FICTRA ,STAT) From ORDSYS
Endif
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

$ERREUR
Call ECR_TRACE(mess(6,123,1)-num$(errn)-errmes$(errn)-errm-errp-mess(61,100,1)-num$(errl),1) From GESECRAN
# Erreur...ligne no...
Resume

######################################
Subprog SETTYP(APPLI,TABLE,TYPCAR)
Value    Char    APPLI , TABLE
Variable Integer TYPCAR
Local Integer CDBA , C130
Onerrgo RIEN
If APPLI=""
 APPLI = nomap
Endif
If clalev([F:ADS])>0
 CDBA = [F:ADS]CODDBA
Else
 Local File ADOSSIER [ADS_]
 Read [ADS_]DOSSIER=APPLI
 CDBA = [F:ADS_]CODDBA
 Close Local File [ADS_]
Endif
Local File =APPLI+".ATABLE" [ATB_]
Read [ATB_]CODFIC=TABLE
C130 = (dim([F:ATB_]FLG130)>0 & [F:ATB_]FLG130=2)
Close Local File [ATB_]
If CDBA=2 : # Unicode
 If C130
  TYPCAR = 7  : # Obligatoirement Ascii
 Else
  TYPCAR = 79 : # Unicode
 Endif
Else
 TYPCAR = 7  : # Ascii
Endif
Onerrgo
End

$RIEN
Resume

##############################################################################
## Création de l'arborescence des répertoires
##############################################################################
Subprog CREAPL(APPLI,HISTO)
Value Char APPLI
Value Char HISTO

Onerrgo ERREUR
Local Char    VOLUME(1)
Local Char    REPERT(GDIMFIC) , ORDSYS(250)
Local Char    MACHINE(GDIMFIC) , REP(GDIMFIC) , SREP(GDIMFIC), FICH(GDIMFIC)
Local Char    NOMFIC1(GDIMFIC) , NOMFIC2(GDIMFIC) , NOMFIC3(GDIMFIC)
Local Char    LIGNE(250) , VALEUR(80) , VARIA(80)
Local Char    DIRSEP(1) , SAVIFS(5) , SAVIRS(5)
Local Integer STAT , K , LANCUR , ERREUR , LIG , SAVIUM

MACHINE = adxmac(0)
VOLUME  = [F:ADS]VOLUME

Case GOS(1)
 When "unix" : DIRSEP="/"
 When "dos"  : DIRSEP="\"
Endcase

# Répertoire de base
ERREUR = 0
REPERT = filpath("","","",HISTO,VOLUME,MACHINE)
Gosub CREREP
If ERREUR : GERRDOS = 1 : End : Endif

Gosub SET_DIRECT_SYS From DOSAPL
Gosub SET_DIRECT_STO From DOSAPL
For I=1 To NBDIR
 REPERT = filpath(TBDIR(I),"","",HISTO,VOLUME,MACHINE)
 Gosub CREREP
Next I

# Sous-répertoires liés a la langue
For LANCUR=0 To [F:ADS]NBRLAN-1
 REP = "M"+[F:ADS]LAN(LANCUR)
 REPERT = filpath(REP,"","",HISTO,VOLUME,MACHINE)
 Gosub CREREP
 REPERT = filpath("REPORT",[F:ADS]LAN(LANCUR),"",HISTO,VOLUME,MACHINE)
 Gosub CREREP
Next LANCUR

# Sous-répertoires de publication
Local Char APPLI1(10) : APPLI1=HISTO
Gosub CREREP_PUB From INTRUTILC

If ERREUR : GERRDOS = 1 : End : Endif

# Fichiers .users et .passwd
For FICH = ".users",".passwd"
 NOMFIC1 = filpath("",FICH,"",HISTO,VOLUME,MACHINE)
 If filinfo(NOMFIC1,0)<0
  Call ECR_TRACE("|"+mess(12,125,1)-ctrans(NOMFIC1,"\","/"),0) From GESECRAN : # Création du fichier
  Openo NOMFIC1 , 0
  Openo
  If filinfo(NOMFIC1,0)<0
   Call ECR_TRACE(mess(184,124,1)+"\|"+ctrans(NOMFIC1,"\","/")+"|",1) From GESECRAN
   ERREUR = 1 : Break
  Endif
 Endif
Next FICH
If ERREUR : GERRDOS = 1 : End : Endif

# Fichier APL.ini
# 1 pour les adxmother (on repart toujours du parent)
# 2 pour le reste , on prend courant sinon parent
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Local Integer APLMOTH,APLOTHER
NOMFIC3 = filpath("","APL","new",HISTO,VOLUME,MACHINE)
NOMFIC1 = filpath("","APL","ini",HISTO,VOLUME,MACHINE)
If filinfo(NOMFIC1,0)<0
 Call ECR_TRACE("|"+mess(12,125,1)-"APL.ini",0) From GESECRAN : # Création du fichier
 NOMFIC2 = filpath("","APL","ini",APPLI)
 APLMOTH=1 : APLOTHER=1
 Gosub APLNEW
 Openi
 Openo
Else
 NOMFIC2 = filpath("","APL","ini",APPLI)
 APLMOTH=1 : APLOTHER=0
 Gosub APLNEW
 Openi
 NOMFIC2 = NOMFIC1
 Gosub APLNEXT
 Openi
 Openo
Endif
Call MOVE(NOMFIC3,NOMFIC1,STAT) From ORDSYS
Onerrgo

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

$APLNEW
Local Integer ISMOTH
Openi NOMFIC2
Openo NOMFIC3 , 0
fstat = 0
Rdseq LIGNE
Wrseq LIGNE
Wrseq 'adxmother(0) = "'+APPLI+'"'
Rdseq LIGNE
While fstat=0
 ISMOTH=0
 If left$(LIGNE,10)="adxmother("
  ISMOTH=1
  LIGNE = left$(LIGNE,10)+num$(val(mid$(LIGNE,11,1))+1)+right$(LIGNE,12)
 Endif
 If (ISMOTH & APLMOTH) | (!ISMOTH & APLOTHER)
 Wrseq LIGNE
 Endif
 Rdseq LIGNE
Wend
Return


$APLNEXT
Local Integer ISMOTH
Openi NOMFIC2
fstat = 0
Rdseq LIGNE
Rdseq LIGNE
While fstat=0
 ISMOTH=0
 If left$(LIGNE,10)="adxmother("
  ISMOTH=1
 Endif
 If !ISMOTH
 Wrseq LIGNE
 Endif
 Rdseq LIGNE
Wend
Return

$CREREP
If filinfo(REPERT,0)<0
 Call ECR_TRACE("|"+mess(11,125,1)-ctrans(REPERT,"\","/"),0) From GESECRAN : # Création du répertoire
 K = instr(1,REPERT,"@")
 If K
  ORDSYS = 'ae_mkdir'-'"'+right$(REPERT,K+1)+'"'
 Else
  ORDSYS = 'ae_mkdir'-'"'+REPERT+'"'
 Endif
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 If filinfo(REPERT,0)<0
  Call ECR_TRACE(mess(184,124,1)+"\|"+ctrans(REPERT,"\","/")+"|",1) From GESECRAN
  ERREUR = 1
 Endif
Endif
Return

##############################################################################
## Création base de données / user oracle
##############################################################################

Subprog CREBASE(APPLI,HISTO,DOSX3,TYPDBA,SIZDAT,SIZIDX,CODORA,GRPFIL)
Value Char    APPLI
Value Char    HISTO
Value Char    DOSX3
Value Integer TYPDBA
Value Integer SIZDAT
Value Integer SIZIDX
Value Char    CODORA
Value Integer GRPFIL

Onerrgo ERREUR

Local Char    ORDSYS(250)(1..2)
Local Integer STAT , I
Local Char    MESSAGE(255)(1..2) , FICHIERLOG(GDIMFIC) , LIGNE(255)
# jira X3-86047 86048 86049
Local Char    AUTHEN_LOGIN (100)
Local Char    AUTHEN_PWD (100)
Local Char    X3_PWD (100)


Local Integer ERR

#----- Pour NT
# les quatre variables suivantes devront être fournies par le programme de valid de dossier
# ces paramètres sont utilisés lors de l'appel de adcrapora.bat et adcrapdb2.bat
# et adcrapss7 lors de groupe de fichier
Local Integer INITINCDAT : # taille initiale DAT
Local Integer INITNXTDAT : # taille next     DAT
Local Integer INITINCIDX : # taille initiale IDX
Local Integer INITNXTIDX : # taille initiale IDX

#----- Pour Db2
# PC 16/12/99
# les variables suivantes seront renseignees afin de définir les chemins d'installations des conteneurs
# Pour l'instant ils sont definis par defaut
# mais on peut tres bien concevoir qu'un jour ils soient differents ! ! !
Local Char    CHMCONTDAT(100) : # chemin d'acces au conteneur de donnees
Local Char    CHMCONTIDX(100) : # chemin d'acces au conteneur des index

Case TYPDBA
 When 1 : Gosub ORACLE
 When 2 : Gosub SQLS7
 When 3 : Gosub CISAM
 When 4 : Gosub DB2
Endcase

MESSAGE(1) = "SPACE FOR STORAGE NOT FOUND"
MESSAGE(2) = "USER NOT FOUND"
FICHIERLOG = filpath(adxdir+"/tmp","show_user_"+HISTO,"log")
If filinfo(FICHIERLOG,0)>0
 Openi FICHIERLOG Using [LOG_]
 Iomode adxifs ""       Using [LOG_]
 Iomode adxirs chr$(10) Using [LOG_]
 Iomode adxium GASCII   Using [LOG_]
 Rdseq LIGNE Using [LOG_]
 While !fstat
  For I=1 To 2
   If instr(1,LIGNE,MESSAGE(I))<>0
    Call ECR_TRACE(MESSAGE(I),1) From GESECRAN
    GERRDOS = 1 : Break
   Endif
  Next I
  Rdseq LIGNE Using [LOG_]
 Wend
 Openi Using [LOG_]
Endif

Onerrgo

End

#------------------------------------------------------------------------------------#
#----- Pour Cisam
#------------------------------------------------------------------------------------#

$CISAM
# X3BY Pour les test en C-ISAM avec X3 Sous Oracle
ORDSYS(1) = "adxora -b"-getenv$("ORACLE_SID")-"-u"-APPLI-"-p tiger"-HISTO
Call ECR_TRACE(ORDSYS(1),0) From GESECRAN
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
ORDSYS(2) = filpath("TRA",GTRACE,"tra")
Return


#------------------------------------------------------------------------------------#
#----- Pour Sql server
#------------------------------------------------------------------------------------#

$SQLS7
If GOS(1)= "" : Return :  Endif

Call ECR_TIME(mess(80,125,1)) From DOSSUB : # Création user Sql-server

# Modifier les lignes suivantes :
INITINCDAT = 100
INITNXTDAT = 100
INITINCIDX = 100
INITNXTIDX = 100

#---- suite normale
CHEMINWRK = adxdir + "\tmp"

# Récupération du passwd sa
Call PASSWD("database.software.sqlinternalpwd",AUTHEN_PWD,GERRDOS) From DOSBASE
If GERRDOS : Return : Endif

# jira X3-86047 86048 86049
# recuperation du compte sa....AUTHEN_LOGIN
# si on trouve rien sa par défaut.....
Call PASSWD("database.software.sqlinternallogin",AUTHEN_LOGIN,GERRDOS) From DOSBASE
If GERRDOS : Return : Endif

#recuperation du password pour X3 tiger par example X3_PWD
# si on trouve rien tiger par defaut......
Call PASSWD("database.software.sqlfolderpwd",X3_PWD,GERRDOS) From DOSBASE
If GERRDOS : Return : Endif


Case GOS(1)
When "unix"
    #################################################################################################################################
    # usage : $1 -o folder-name -s db-name -p sa-password -r parent-folder [-x repartition-in-file-groups -d data-size -i index-size]
    #################################################################################################################################
    ORDSYS(1) = 'adcrapss7'
    ORDSYS(1) -= '-o'-HISTO
    ORDSYS(1) -= '-s'-right$(getenv$("CONNECTSTR"),instr(0,getenv$("CONNECTSTR"),"#")+1)
    ORDSYS(1) -= '-p'-AUTHEN_PWD
    ORDSYS(1) -= '-r'-APPLI
    If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        ORDSYS(1) -= '-u'-AUTHEN_LOGIN
        ORDSYS(1) -= '-P'-X3_PWD
    Endif
    If GRPFIL <>2
        ORDSYS(1) -= '-x NO'
    Else
        ORDSYS(1) -= '-x YES'
        ORDSYS(1) -= '-d'-num$(INITINCDAT)
        ORDSYS(1) -= '-i'-num$(INITINCIDX)
    Endif
    ORDSYS(2) = filpath("TRA",GTRACE,"tra")
    Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

 When "dos"
    ORDSYS(1) = adxdir+"\ebin\adcrapss7.bat"-HISTO-getenv$("SQLS7_SID")-CHEMINWRK
    If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        #################################################################################
        # p1 = Folder name (ex. DEMO)
        # p2 = Database name (ex. Adonix)
        # p3 = Working path (ADXDIR\tmp)
        # p4 = Parent Folder (parent folder for archive folder or folder name)
        # p5 = AUTHENTIFICATION LOGIN (EXAMPLE SA )
        # p6 = AUTHENTIFICATION password
        # p7 = X3 password For Folder 'ex. tiger'
        # p8 = Repartition in file groups YES/NO
        # p9 = Data file size if file groups
        # p10 = Index file size if file groups
        #################################################################################
        ORDSYS(1) -= APPLI-'"'+num$(AUTHEN_LOGIN)+'"'-'"'+num$(AUTHEN_PWD)+'"'-'"'+num$(X3_PWD)+'"'
    Else
        #################################################################################
        # p1 = Folder name (ex. DEMO)
        # p2 = Database name (ex. Adonix)
        # p3 = Working path (ADXDIR\tmp)
        # p4 = Parent Folder (parent folder for archive folder or folder name)
        # p5 = sa password
        # p6 = Repartition in file groups YES/NO
        # p7 = Data file size if file groups
        # p8 = Index file size if file groups
        #################################################################################
        ORDSYS(1) -= APPLI-'"'+num$(AUTHEN_PWD)+'"'
    Endif
    If GRPFIL <>2
        ORDSYS(1) -= "NO"-num$(INITINCDAT)-num$(INITINCIDX)
    Else
        ORDSYS(1) -= "YES"-num$(INITINCDAT)-num$(INITINCIDX)
    Endif
    ORDSYS(2) = filpath("TRA",GTRACE,"tra")
    Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

    #---- fichier adxodbc
    # on execute adxodbc pour creer le fichier adxodbc qui va bien ...
    # le 03/10/2000 pour les groupes de fichiers adxodbc doit donner le nom des groupes de fichier dat et idx
    If GRPFIL=2
      #################################################################################################
      # adxodbc -b databasename -u folder -p passwd -d DATASOURCE -t folder_DAT -i folfer_IDX folder
      #################################################################################################
        ORDSYS(1) = "adxodbc -b"-getenv$("SQLS7_SID")-"-u"-HISTO
        ORDSYS(1) -= "-p"-X3_PWD-"-d"-getenv$("DATASOURCE")- "-t" - HISTO + "_DAT" - "-i" - HISTO + "_IDX"
        ORDSYS(1) -= HISTO
        Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
    Endif
Endcase
Return

#------------------------------------------------------------------------------------#
#---- pour Oracle
#------------------------------------------------------------------------------------#

$ORACLE
Call ECR_TIME(mess(13,125,1)) From DOSSUB : # Création user Oracle

# recuperation du compte sa....AUTHEN_LOGIN
# si on trouve rien system par défaut.....
Call PASSWD("database.software.sqlsystemlogin",AUTHEN_LOGIN,GERRDOS) From DOSBASE
If GERRDOS : Return : Endif


# Récupération du passwd system
Call PASSWD("database.software.sqlsystempwd",AUTHEN_PWD,GERRDOS) From DOSBASE
If GERRDOS : Return : Endif

#recuperation du password pour X3 tiger par example X3_PWD
# si on trouve rien tiger par defaut......
Call PASSWD("database.software.sqlfolderpwd",X3_PWD,GERRDOS) From DOSBASE
If GERRDOS : Return : Endif


Case GOS(1)
 When "unix"
  #####################################################################################################
  # usage : $1 [-v] [-p syspas] -d sizdat -i sizidx -r appliref [-o dossier_origine] nomap idapl
  ##############################################################################################
  ORDSYS(1) = 'adcrap'
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        # password a passer
        ORDSYS(1) -= '-u'-num$(AUTHEN_LOGIN)
  Endif
  ORDSYS(1) -= '-p "'-num$(AUTHEN_PWD)+'"'
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        # password a passer
        ORDSYS(1) -= '-P'-num$(X3_PWD)
  Endif
  ORDSYS(1) -= '-d'-num$(SIZDAT)-'-i'-num$(SIZIDX)
  ORDSYS(1) -= '-r'-GDOSX3-'-o'-APPLI
  ORDSYS(1) -= HISTO-CODORA
  ORDSYS(2) = filpath("TRA",GTRACE,"tra")
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

  ############################################################
  # Windows NT (identifié comme Dos ! )
  # Attention : On utilise les variables ORACLE_SID et ORACLE_BASE
  # qui doivent donc être définies dans la base de registre ...
  ############################################################

 When "dos"
  # Modifier les lignes suivantes :
  INITINCDAT = 100
  INITNXTDAT = 100
  INITINCIDX = 100
  INITNXTIDX = 100

  # suite normale
  CHEMINWRK = adxdir + "\tmp"

  ORDSYS(1) = adxdir+"\ebin\adcrapora.bat"-num$(SIZDAT)-num$(SIZIDX)
  ORDSYS(1) -= HISTO-APPLI
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
    ###########################################################################################
    # Usage :
    # -------
    #   adcrapora p1 p2 p3 p4 p5 p6 p7
    #
    #   p1  = Data tablespace size
    #   p2  = Index tablespace size
    #   p3  = Folder name
    #   p4  = Parent Folder (parent folder for archive folder or folder name)
    #   p5  = system login like system
    #   p6  = system password
    #   p7  = Oracle file identifier
    #   p8  = Oracle SID
    #   p9  = working path : adxdir + tmp (ex. d:\x3\adox3\tmp) (%ADXDIR%\tmp)
    #   p10 = password x3 folder like tiger
    ###########################################################################################
    ORDSYS(1) -= num$(AUTHEN_LOGIN)-'"'+num$(AUTHEN_PWD)+'"'
    ORDSYS(1) -= CODORA-getenv$("ORACLE_SID")-'"'+CHEMINWRK+'"'
    ORDSYS(1) -= num$(X3_PWD)
  Else
    ###########################################################################################
    # Usage :
    # -------
    #   adcrapora p1 p2 p3 p4 p5 p6 p7
    #
    #   p1  = Data tablespace size
    #   p2  = Index tablespace size
    #   p3  = Folder name
    #   p4  = Parent Folder (parent folder for archive folder or folder name)
    #   p5  = system password
    #   p6  = Oracle file identifier
    #   p7  = Oracle SID
    #   p8  = working path : adxdir + tmp (ex. d:\x3\adox3\tmp) (%ADXDIR%\tmp)
    ###########################################################################################
    ORDSYS(1) -= '"'+num$(AUTHEN_PWD)+'"'
    ORDSYS(1) -= CODORA-getenv$("ORACLE_SID")-'"'+CHEMINWRK+'"'
 Endif
 ORDSYS(2) = filpath("TRA",GTRACE,"tra")
 Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

Endcase
# X3BY pas de user sous NT
Return

#------------------------------------------------------------------------------------#
#---- pour DB2
#------------------------------------------------------------------------------------#

##  PC 16/12/99
##  Modifications :
##  PC 11/05/00 prise en compte de DB2/unix

$DB2
Call ECR_TRACE("Création des tablespaces",0) From GESECRAN

# on recupere les tailles renseignees par l'utilisateur (en Mo), donnees et index,
# que l'on ramene en page de 4KB

INITINCDAT = int(SIZDAT *1000 / 4)
INITINCIDX = int(SIZIDX *1000 / 4)

Case GOS(1)
 When "unix"

  # preparation de l'ordre systeme pour la creation du dossier
  ORDSYS(1) = "adcrapdb2 -d" -num$(INITINCDAT) - "-x" -num$(INITINCIDX) - HISTO
  ORDSYS(2) = filpath("TRA",GTRACE,"tra")
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

  # adxdb2 est cree dans le adcrapdb2

 When "dos"

  # on defini le chemin ou sera cree le script DB2
  CHEMINWRK  = adxdir + "\tmp"
  CHMCONTDAT = getenv$("DB2_BASE") + "\data"
  CHMCONTIDX = getenv$("DB2_BASE") + "\Index"

  # p1 = Nom de la base de donnee          getenv$("DB2_SID") -- recupere dans l'editeur de registre
  # p2 = Nom du dossier                    DOSSIER
  # p3 = Chemin conteneur de donnees       CHMCONTDAT
  # p4 = Chemin conteneur des index        CHMCONTIDX
  # p5 = Taille des donnees                INITINCDAT
  # p6 = Taille des index                  INITINCIDX
  # p7 = Chemin du script genere           CHEMINWRK
  # p8 = dossier/application de reference(racine) (obligatoire: toujours renseigné)
  # p9 = dossier origine pour creation dossier histo (facultatif:renseigné uniquement sur creation dos hist)

  # preparation de l'ordre systeme pour la creation du dossier
  ORDSYS(1) = adxdir + "\ebin\adcrapdb2.bat" - getenv$("DB2_SID")
  ORDSYS(1) -= HISTO - CHMCONTDAT - CHMCONTIDX
  ORDSYS(1) -= num$(INITINCDAT) -num$(INITINCIDX) - CHEMINWRK
  ORDSYS(1) -= DOSX3 - APPLI
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

  # On execute adxdb2 pour creer le fichier adxdb2 qui va bien ...
  ORDSYS(1) = adxdir + "\bin\adxdb2.exe -u" - HISTO - "-p tiger -d"
  ORDSYS(1) -= getenv$("DB2_SID") - "-t" - HISTO + "_DAT"
  ORDSYS(1) -= "-i" - HISTO + "_IDX" - HISTO
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

Endcase

# Tempo necessaire à l'allocation et au catalogage des tablespaces dans DB2

Sleep(10)

Return

########################################
Subprog AV_DOSSIER(VALEUR)
Variable Char    VALEUR()
If [M:DIA]EXISTE
 Diszo 10
Else
 Read [ADS]DOSSIER = nomap
 Case [F:ADS]TYPDBA
  When 1 : # Oracle
   Grizo GRPFIL
  When 2 : # SQL
   Grizo COEFF
  When 3 : # CISAM
   Grizo
  When 4 : # DB2
   Grizo GRPFIL,COEFF
 Endcase
Endif
End

Subprog C_DOSSIER(VALEUR)
Variable Char VALEUR()
If filinfo(filpath("","","",VALEUR),0)>=0
 GMESSAGE = mess(33,133,1) : # Dossier déjà existant
 mkstat = 2 : End
Endif
End

Subprog C_HISMEN(VALEUR)
Variable Char VALEUR()
If filinfo(filpath("M"+GLANGUE,VALEUR,"mnu",0),0)<0
 GMESSAGE = mess(34,133,1) : # Profil menu inexistant
 mkstat = 2 : End
Endif
End

