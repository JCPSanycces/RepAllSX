#<AdxTL>@(#)4.0.0.0 $Revision$
####################################################################################
# Program Name: VXARCL
# Description : ADC Réconciliation
# Date        : Fev 09/07/2010
# Type        :
####################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"VXARCL","VXA","XVWXARCL") From GSAISIE
End

########################################################
# Production tracking
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
#
#
#
#
# Necessary value in Entry transaction
# ------------------------------------
########################################################
$ACTION
#--- Actions liées à la fenêtre de saisie
Case ACTION
    When "OUVRE"         : Gosub OUVRE
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "BOUTON"        : Gosub BOUTON
    When "ABANDON"       : Gosub ABANDON
    When "FINSAI"        : Gosub FINSAI
    When "FIN"           : Gosub FIN
Endcase
Return

########################################################
$OUVRE
Global Integer GHCBWCPT
Global Integer GHCBWCPTART
Global Char    GHCBIVALEUR (GLONVCR)
Global Char    GHCBLMFGNUM (GLONVCR)
Global Char    GHCBLITMREF (GLONITM)  # mm 05.08
Global Integer GHCBLBOMOPE
Global Integer GHCBLMFGLIN
Global Integer GHCBLBOMSEQ
Global Date    GHCBLCBTDAT
Global Integer GHCBLMVTSEQ
Global Integer GHCBWBOUT
Global Integer GHCBWCPTENR
Global Integer GHCBLWGGSTA
Global Char    GHCBLPESEE  (GLONVCR)
Global Integer GHCBLRECONCIL


# lreconcil = 0 pas de reconciliation de faite
# lwggsta = ancien code wggsta
GHCBLWGGSTA = 0
GHCBLRECONCIL = 0
GHCBLMFGNUM = ""
GHCBWBOUT = 5
GHCBWCPT = 0
GHCBWCPTENR = 0
GHCBLPESEE =""

# Ouverture des fichiers utilisés
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:WGG])  = 0 : Local File WEIGHING    [WGG]  : Endif
If clalev([F:WGG1]) = 0 : Local File WEIGHING    [WGG1] : Endif

Return


########################################################
$DEBUT
Local Integer WOK, WCPT
Global Char GTRAVT(250)

# Initialisation du site de stock
If GXAFCY="" GXAFCY=GFCYDEF(7) Endif
Call GETCPY(GXAFCY,"",0,"") From TRTX3CPT

# verify that the ADC site is set
If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 2 : Return
Endif

Gosub TRT_ORDRE

Return

########################################################

$SETBOUT

If GHCBWBOUT = 1
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 7
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 1
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 8
    ETABOU(GSPE1) = 1
    ETABOU(GSPE2) = 1
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 9
    ETABOU(GSPE1) = 1
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif

Return
##########################################################
$FINSAI
Kill GHCBWCPT
Kill GHCBWCPTART
Kill GHCBIVALEUR
Kill GHCBLMFGNUM
Kill GHCBLITMREF
Kill GHCBLBOMOPE
Kill GHCBLMFGLIN
Kill GHCBLBOMSEQ
Kill GHCBLCBTDAT
Kill GHCBLMVTSEQ
Kill GHCBWBOUT
Kill GHCBWCPTENR
Kill GHCBLWGGSTA
Kill GHCBLRECONCIL
Kill GHCBLPESEE

GBIDC1 = ""

#Nettoie l'écran avant de partir.
Raz [M:XRCL]

Return

#########################################################
$FIN
Gosub TRT_FIN
Return

#########################################################
$ABANDON
Return

##########################################################
$BOUTON

Case BOUT
     When "a" Gosub TRT_ENREGISTREMENT #Save
     When "b" Gosub TRT_SUPPRIMER #Delete
     When "c" Gosub TRT_ABANDON #Cancel
     When Default
Endcase
Return
##########################################################

#########################################################
# Sous-programmes bouton
#########################################################
$TRT_FIN

If GHCBLRECONCIL <> 0

    OK=1
    Call OUINON(mess(87,2324,1),OK) From GESECRAN # CATUA X3-96226 changed from 21
    If OK <> 2
        mkstat=2
    Else
        # suppression réconciliation
        Gosub TRT_SUPPRIME
    Endif
Endif

### Ordre bloqué en réconciliation
If [M:XRCL]MFGNUM<>""
    Read [F:MFG]MFG0= [M:XRCL]MFGNUM
    If !fstat
       If [F:MFG]WGGSTA = 10

        Call DEBTRANS From GLOCK
        Trbegin [MFG]
        # CATUA X3-96226 Do not set MFGHEAD.WGGSTA back to 1 (not weighed??)
        #Call MAJ_FICHIERS ("MFG",0,1,[M:XRCL]MFGNUM,"",0,0) From SCALEXCHAN : #0 On ne veut pas toucher
        Call MAJ_FICHIERS ("MFG",0,8,[M:XRCL]MFGNUM,"",0,0) From SCALEXCHAN
        If GOK = 1  : Commit
        Else        : Rollback
        Endif

       Endif
    Endif
Endif
Return
#########################################################
$TRT_ABANDON
If GHCBLRECONCIL <> 0
    OK=1
    Call OUINON(mess(87,2324,1),OK) From GESECRAN # CATUA X3-96226 changed from 21
    If OK <> 2 : mkstat=2 : Return : Endif
Endif
# suppression réconciliation
Gosub TRT_SUPPRIME
# retour saisie ordre
GHCBIVALEUR = ""
Gosub MAJ_MFGHEAD
Gosub TRT_ORDRE
GHCBWCPT = 0
ACTION = "ABANDON" : Gosub ACTION
Raz[M:XRCL]MFGNUM
Affzo[M:XRCL]MFGNUM

Return
##########################################################
$TRT_SUPPRIMER
# Confirmation de la suppression
OK=1

# CATUA X3-96226.sn
# Call OUINON(mess(20,2324,1),OK) From GESECRAN
If GRECONCIL=2 # Reconcile by phase
  Call OUINON(mess(84,2324,1),OK) From GESECRAN
Elsif GRECONCIL=3 # Reconcile by container
  Call OUINON(mess(85,2324,1),OK) From GESECRAN
Else
  Call OUINON(mess(86,2324,1),OK) From GESECRAN
Endif
# CATUA X3-96226.en

If OK <> 2 : mkstat=2 : Return : Endif
# suppression réconciliation
Gosub TRT_SUPPRIME
# retour saisie ordre
Gosub TRT_ORDRE

### Ordre bloqué en réconciliation
If [M:XRCL]MFGNUM <>""
    Read [F:MFG]MFG0= [M:XRCL]MFGNUM
    If !fstat
        If [F:MFG]WGGSTA = 10
        Call DEBTRANS From GLOCK
        Trbegin [MFG]
            # CATUA X3-96226 Do not set MFGHEAD.WGGSTA back to 1 (not weighed??)
            #Call MAJ_FICHIERS ("MFG",0,1,[M:XRCL]MFGNUM,"",0,0) From SCALEXCHAN : #0 On ne veut pas toucher
            Call MAJ_FICHIERS ("MFG",0,8,[M:XRCL]MFGNUM,"",0,0) From SCALEXCHAN
        If GOK = 1  : Commit
        Else        : Rollback
        Endif
        Endif
    Endif
Endif
Return
#########################################################
$TRT_ENREGISTREMENT #Save
Local Integer J
#  lecture historique


Call DEBTRANS From GLOCK
Trbegin [WGG]

Readlock [WGG]WGG0 = [M:XRCL]MFGNUM;[M:XRCL]BOMOPE;[M:XRCL]ITMREF;GHCBLMFGLIN;GHCBLBOMSEQ;GHCBLCBTDAT;GHCBLMVTSEQ
If fstat=1     GOK=-1 : GLOCK="$WEIGHING"-GHCBLMFGNUM : Gosub TRT_ROLL : Return
Elsif fstat GOK=0  : Call RSTA("WGG",GHCBLMFGNUM) From GLOCK :  Gosub TRT_ROLL : Return
Endif

[F:WGG]RCLCOD = 2
[F:WGG]RCLDAT = date$
# Issue number 82926- 2012-06-14 by SR
[F:WGG]RCLUSR = GUSER
[F:WGG]RCLTIM = mid$(time$,1,2)+mid$(time$,4,2)
GHCBLRECONCIL = 1
Rewrite [F:WGG]
If fstat
    GOK = 0 : Call FSTA("WGG") From GLOCK : Return
Endif
Commit

#DT-22/06/2010

Gosub CALCUL

If GHCBWCPTENR = 0
    OK=1

    # CATUA X3-96226.sn
    #Call OUINON(mess(18,2324,1),OK) From GESECRAN
    If GRECONCIL=2 # Reconcile by phase
      Call OUINON(mess(18,2324,1),OK) From GESECRAN
    Elsif GRECONCIL=3 # Reconcile by container
      Call OUINON(mess(83,2324,1),OK) From GESECRAN
    Else
      Call OUINON(mess(82,2324,1),OK) From GESECRAN
    Endif
    # CATUA X3-96226.en

    If OK <> 2
      Gosub TRT_SUPPRIME
    Else
      Gosub TRT_VALIDATION
      If WOK = 6
        GHCBIVALEUR = ""
        Gosub TRT_ORDRE
      Endif
    Endif
    GHCBWBOUT = 1 #CATUA X3-100033 Disable Save / Disable Delete
    Raz[M:XRCL]MFGTRKNUM,ITMREF,BOMOPE,LOT,WEIWEI,WEU
    Affzo[M:XRCL]MFGTRKNUM,ITMREF,BOMOPE,LOT,WEIWEI,WEU

    If GRECONCIL=2 # Reconcile by phase
      Raz[M:XRCL]BOMOPE0
      Affzo [M:XRCL]BOMOPE0
      zonsui = "BOMOPE0"
    Elsif GRECONCIL=3 # Reconcile by container
      Raz[M:XRCL]CTN
      Affzo [M:XRCL]CTN
      zonsui = "CTN"
    Endif
Else

    GHCBWBOUT = 1
    If [M:XRCL]WEU <> ""
        If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
            GHCBWBOUT = 9
        Endif
    Else
        If GHCBLRECONCIL = 1 GHCBWBOUT = 7 Endif
    Endif

    ACTION = "SETBOUT" : Gosub ACTION
    Call MESSAGE (mess(52,2324,1)-num$(GHCBWCPTENR)) From GESECRAN

    Raz[M:XRCL]MFGTRKNUM,ITMREF,BOMOPE,LOT,WEIWEI,WEU
    Affzo[M:XRCL]MFGTRKNUM,ITMREF,BOMOPE,LOT,WEIWEI,WEU
    zonsui = "MFGTRKNUM"

 Endif



Return

########################################################################
# sous programme :
########################################################################

$TRT_VALIDATION
# verification que la réconciliation soit faite sur toutes les matieres pesées
# sont exclu de la réconciliation les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)
# sr 03.02 ainsi que les mouvements de type "fin de contenant"
# sr 01.03 ainsi que les mouvements de type "Inventaire"
# sr 09.03 ainsi que les matières pesée en fabrication (code à servir 3,5,7)
#          En fait on garde les PCK : 2,4,6

#DT-22/06/2010

For [MFM]MFM0 Where MFGFCY = [M:XRCL]MFGFCY &
&                   MFGNUM = [M:XRCL]MFGNUM     &
&                   MATSTA <> 4                 &
&                   WGGSTA = 3                  &
&                   find([F:MFM]PKC,2,4,6)      &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:XRCL]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:XRCL]CTN)  ) # CATUA #X3-96226
#&    ([V]GRECONCIL<>2 | BOMOPE = [M:XRCL]BOMOPE0)  :#DT
         WOK = 0
         For [WGG]WGG0 Where MFGNUM = [M:XRCL]MFGNUM &
&                            MFGLIN = [F:MFM]MFGLIN      &
&                            ITMREF = [F:MFM]ITMREF      &
&                            BOMSEQ = [F:MFM]BOMSEQ      &
&                            BOMOPE = [F:MFM]BOMOPE      &
&                            WEIWEI <> 0                 &
&                            WEIFLG <> 4                 &
&                            WEIFLG <> 5

         If [F:WGG]RCLCOD <> 2 WOK = 9 : Break : Endif             # 04.02
         If [F:WGG]RCLCOD =  2 WOK = 1 : Endif                     # 04.02
         Next

        If WOK = 1
                  Call DEBTRANS From GLOCK
                  Trbegin [MFM]

                  Readlock [F:MFM] Curr
                  If fstat=1     GOK=-1 : GLOCK="$MFM"-GHCBLMFGNUM : Gosub  TRT_ROLL : Break    # mm 05.11 - Ctrl des sources avant Return
                  Elsif fstat GOK=0  : Call RSTA("MFM",GHCBLMFGNUM) From GLOCK : Gosub TRT_ROLL : Break  # mm 05.11 - Ctrl des sources avant Return
                  Endif

                  [F:MFM]WGGSTA = 5
                  Rewrite [F:MFM]
                  If fstat       GOK = 0 : Call FSTA("MFM") From GLOCK : Gosub TRT_ROLL : Break :  Endif  # mm 05.11 - Ctrl des sources avant Return
                  Commit
        Endif
Next
If GOK<= 0 Return Endif #  mm 05.11 -  Ctrl des sources Ligne ajoutée

# verification that all materials are reconciled (wggsta = 5)
# verification que toutes les matieres soient réconciliées (wggsta = 5)
# sont exclu de la réconciliation les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)
# sr 09.03 on ne traite que les PKC = 2,4,6

#    WOK = 6
# mm 05.11 - l'ensemble des matières doivent être réconciliées pour modifier le statut de l'entête.
For [MFM]MFM0 Where MFGFCY = [M:XRCL]MFGFCY         &
&                       MFGNUM = [M:XRCL]MFGNUM     &
&                       MATSTA <> 4                 &
&                      find([F:MFM]PKC,2,4,6)
                                                      #&   ([V]GRECONCIL<>2 | BOMOPE = [M:XRCL]BOMOPE0)  :#DT

    WOK = 6
    If [F:MFM]WGGSTA <> 5  WOK = 9 : Break : Endif
Next

  If WOK = 6
# If [V]GRECONCIL<>2
    GHCBLWGGSTA     = 8
    [M:XRCL]WGGSTA  = 8
    Call DEBTRANS From GLOCK
    Trbegin [MFG]

    Call MAJ_FICHIERS ("MFG",6,GHCBLWGGSTA,[M:XRCL]MFGNUM,"",0,0) From SCALEXCHAN : #(MFG.WGGFLG(6)-Reconciled, MFG.WGGSTA(8)-Total Weighing Completed)
    If GOK = 1  : Commit
    Else        : Rollback
    Endif

# CATUA X3-96226 Do not set MFGHEAD.WGGSTA back to 1 (not weighed??)
#  Else
#    GHCBLWGGSTA     = 1
#    [M:XRCL]WGGSTA  = 1
#    Call DEBTRANS From GLOCK
#    Trbegin [MFG]
#
#    Call MAJ_FICHIERS ("MFG",6,GHCBLWGGSTA,[M:XRCL]MFGNUM,"",0,0) From SCALEXCHAN : # 6 Réconcilié et 1 non pesée
#    If GOK = 1  : Commit
#    Else        : Rollback
#    Endif
#  Endif

    # CATUA X3-96226.sn
    #Call MESSAGE (mess(22,2324,1)) From GESECRAN
    If GRECONCIL=2 # Reconcile by phase
      Call MESSAGE (mess(22,2324,1)) From GESECRAN
    Elsif GRECONCIL=3 # Reconcile by container
      Call MESSAGE (mess(79,2324,1)) From GESECRAN
    Else
      Call MESSAGE (mess(81,2324,1)) From GESECRAN
    Endif
    # CATUA X3-96226.en

    # if there are still weighed materials in production not yet weighed,
    # we submit the OF in the weighing plan and "end of box weighing" status
    # si il reste des matières pesées en fabrication non encore pesées,
    # on remet l'OF dans le plan de pesée et statut "fin de pesée en box"

    For [F:MFM]MFM0 Where MFGFCY = [M:XRCL]MFGFCY     &
&                       MFGNUM = [M:XRCL]MFGNUM         &
&                       MATSTA <> 4                     &
&                       find([F:MFM]PKC,3,5,7)
#&     ([V]GRECONCIL<>2 | BOMOPE = [M:XRCL]BOMOPE0)    :#DT
               If [F:MFM]WGGSTA < 3
                    #DT=================
#                    If [V]GRECONCIL<>2
                       GHCBLWGGSTA    = 3
# CATUA X3-96226 Do not set MFGHEAD.WGGSTA back to 1 (not weighed??)
#                    Else
#                       GHCBLWGGSTA    = 1
#                    Endif
                Call DEBTRANS From GLOCK
                Trbegin [MFG]

                Call MAJ_FICHIERS ("MFG",3,GHCBLWGGSTA,[M:XRCL]MFGNUM,"",0,0) From SCALEXCHAN : # 3 plan de peser et 3 fin pesée en box ou 1 non pesée
                If GOK = 1  : Commit
                Else        : Rollback
                Endif

                    [M:XRCL]WGGSTA =GHCBLWGGSTA
                    #DT==================
                    Break
               Endif
    Next
  Endif

  # 104069 mm 03.2015 - Case of reconciliation by phases
  # Check that all materials from phases are reconciled
  If find ([V]GRECONCIL,2,3) & WOK = 9 # CATUA #X3-96226
    For [MFM]MFM0 Where MFGFCY = [M:XRCL]MFGFCY       &
&                       MFGNUM = [M:XRCL]MFGNUM     &
&                       MATSTA <> 4                 &
&                      find([F:MFM]PKC,2,4,6)       &
& (([V]GRECONCIL=2 & BOMOPE=[M:XRCL]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:XRCL]CTN)) # CATUA #X3-96226
# BOMOPE = [M:XRCL]BOMOPE0
      If [F:MFM]WGGSTA <> 5  WOK = 10 : Break : Endif
    Next
    If WOK =9 GHCBLRECONCIL = 0 Endif
  Endif

Return
#########################################################
$TRT_ROLL
Rollback
Return

#########################################################
$TRT_SUPPRIME

For [WGG]WGG0 Where MFGNUM = [M:XRCL]MFGNUM         &
&                   WEIWEI <> 0                     &
&                   CCLDAT = [0/0/0]                &
&                   RCLCOD =  2                     &
&                   WEIFLG <> 4                     &
&                   WEIFLG <> 5                     &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:XRCL]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:XRCL]CTN)  ) # CATUA #X3-96226
#&   ([V]GRECONCIL<>2 | BOMOPE = [M:XRCL]BOMOPE0)  :#DT

        Call DEBTRANS From GLOCK
        Trbegin [WGG]

        Readlock Curr
        If fstat=1     GOK=-1 : GLOCK="$WEIGHING"-GHCBLMFGNUM : Gosub TRT_ROLL : Break   # mm 06.11 74630 contrôle des sources
        Elsif fstat GOK=0  : Call RSTA("WGG",GHCBLMFGNUM) From GLOCK : Gosub TRT_ROLL : Break   # mm 06.11 74630 contrôle des sources
        Endif

        [F:WGG]RCLCOD = 1
        [F:WGG]RCLDAT = [0/0/0]
        # Issue number 82926- 2012-06-14 by SR
        [F:WGG]RCLUSR = ""
        Raz [F:WGG]RCLTIM
        Rewrite [F:WGG]
        If fstat       GOK = 0 : Call FSTA("WGG") From GLOCK : Gosub TRT_ROLL : Break   # mm 06.11 74630 contrôle des sources
        Endif
        Commit
Next
Return
#########################################################
$TRT_ORDRE

[M:XRCL]MFGFCY = GXAFCY
Actzo  [M:XRCL]MFGNUM
Actzo  [M:XRCL]BOMOPE0
Raz    [M:XRCL]BOMOPE0
# CATUA X3-96226.sn
Actzo  [M:XRCL]CTN
Raz    [M:XRCL]CTN
Actzo  [M:XRCL]WCPTENR
Raz    [M:XRCL]WCPTENR
# CATUA X3-96226.en
Raz    [M:XRCL]MFGSTA
Raz    [M:XRCL]MFGTRKNUM
Raz    [M:XRCL]ITMREF
Raz    [M:XRCL]BOMOPE
Raz    [M:XRCL]LOT
Raz    [M:XRCL]WEIWEI
Raz    [M:XRCL]WEU
Affzo  [M:XRCL]

GHCBLRECONCIL = 0
GHCBWBOUT     = 1
GHCBWCPT      = 0

#DT-22/06/2010
If [M:XRCL]MFGFCY<>""

    Gosub CHARGE_PARAM

    If [V]GRECONCIL=2 # Reconcile by phase
      Actzo[M:XRCL]BOMOPE0
    # CATUA X3-96226.sn
      Raz[M:XRCL]CTN
      Grizo[M:XRCL]CTN
    Elsif [V]GRECONCIL=3 # Reconcile by container
      Actzo[M:XRCL]CTN
      Raz[M:XRCL]BOMOPE0
      Grizo [M:XRCL]BOMOPE0
    # CATUA X3-96226.en
    Else
      Raz[M:XRCL]BOMOPE0
      Grizo [M:XRCL]BOMOPE0
      # CATUA X3-96226.sn
      Raz[M:XRCL]CTN
      Grizo[M:XRCL]CTN
      # CATUA X3-96226.en
    Endif
Endif
Return


#########################################################
$TRT_ITMREF
Actzo  [M:XRCL]ITMREF
Gosub TRT_RAZITMREF

GHCBLRECONCIL = 0
GHCBWBOUT     = 1

Return


#########################################################
$TRT_RAZITMREF

[M:XRCL]BOMOPE  = 0
[M:XRCL]LOT     = ""
[M:XRCL]WEU     = ""
[M:XRCL]WEIWEI  = 0

Affzo [M:XRCL]ITMREF
Affzo [M:XRCL]LOT
Affzo [M:XRCL]WEIWEI
Affzo [M:XRCL]WEU
Affzo [M:XRCL]BOMOPE
Return

#########################################################
$TRT_RAZORDRE
[M:XRCL]MFGNUM  = ""
[M:XRCL]WCPTENR = 0
Affzo [M:XRCL]MFGNUM
Affzo [M:XRCL]WCPTENR
Return


########################################################################
# calcul nombre de pesée à reconcilier pour un of
########################################################################
$CALCUL

GHCBWCPTENR = 0

Gosub CHARGE_PARAM

For [WGG]WGG0 Where MFGNUM = [M:XRCL]MFGNUM         &
&                   WEIWEI <> 0                     &
&                   CCLDAT = [0/0/0]                &
&                   RCLCOD <> 2                     &
&                   WEIFLG <> 4                     &
&                   WEIFLG <> 5                     &
&                   find([F:WGG]PKC,2,4,6)          &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:XRCL]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:XRCL]CTN)  ) # CATUA #X3-96226
#&    ([V]GRECONCIL=2 & (BOMOPE = [M:XRCL]BOMOPE0)|([V]GRECONCIL<>2 & [M:XRCL]BOMOPE0=0))  #DT - mm 05.11

    GHCBWCPTENR += 1
Next

[M:XRCL]WCPTENR = GHCBWCPTENR
Affzo  [M:XRCL]WCPTENR

Return

########################################################################
# recherche element article à réconcilier
########################################################################
$CRTHISTART
GHCBWCPTART = 0

For [WGG]WGG0 Where MFGNUM = [M:XRCL]MFGNUM     &
&                   BOMOPE = GHCBLBOMOPE        &
&                   ITMREF = GHCBLITMREF        &
&                   WEIWEI <> 0                 &
&                   CCLDAT = [0/0/0]            &
&                   RCLCOD <> 2                 &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5                 &
&                   find([F:WGG]PKC,2,4,6)

GHCBWCPTART += 1
Break
Next

Return

########################################################################
# recherche element à réconcilier N° pesée
########################################################################
$CRTHIST_PESEE
GHCBWCPT = 0
# mm 05.11 - RCLDAT peut être =2 si pesée annulée # RCLCOD    <> 2
For [WGG]WGG0 Where          MFGNUM    = [M:XRCL]MFGNUM      &
&                            MFGTRKNUM = VALEUR              &
&                            WEIWEI    <> 0                  &
&                            CCLDAT    = [0/0/0]             &
&                            WEIFLG    <> 4                  &
&                            WEIFLG    <> 5                  &
&                            find([F:WGG]PKC,2,4,6)          &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:XRCL]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:XRCL]CTN)  ) # CATUA #X3-96226
#&   ([V]GRECONCIL<>2 | BOMOPE = [M:XRCL]BOMOPE0)          :#DT

            GHCBWCPT += 1
            If GHCBWCPT > 1 Break : Endif
Next
Return

########################################################################
# recherche element à réconcilier lot
########################################################################
$CRTHISTLOT
GHCBWCPT = 0

#DT-21/06/2010

For [WGG]WGG0 Where MFGNUM = [M:XRCL]MFGNUM     &
&                   BOMOPE = [M:XRCL]BOMOPE     &
&                   WEIWEI <> 0                 &
&                   ITMREF = [M:XRCL]ITMREF     &
&                   LOT    = VALEUR             &
&                   CCLDAT = [0/0/0]            &
&                   RCLCOD <> 2                 &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5

    GHCBWCPT += 1
    If GHCBWCPT > 1 Break : Endif
Next

If GHCBWCPT = 1 GHCBLMFGLIN = [F:WGG]MFGLIN
                GHCBLBOMSEQ = [F:WGG]BOMSEQ
                GHCBLCBTDAT = [F:WGG]CBTDAT
                GHCBLMVTSEQ = [F:WGG]MVTSEQ
                GHCBLPESEE  = [F:WGG]MFGTRKNUM

Endif
Return

########################################################################
# recherche element à réconcilier lot + montant
########################################################################
$CRTHISTWEI

GHCBWCPT = 0

For [WGG]WGG0 Where MFGNUM = [M:XRCL]MFGNUM               &
&                   BOMOPE = [M:XRCL]BOMOPE               &
&                   WEIWEI <> 0                           &
&                   ITMREF = [M:XRCL]ITMREF               &
&                   LOT    = [M:XRCL]LOT                  &
&                   WEIWEI = VALEUR                       &
&                   CCLDAT = [0/0/0]                      &
&                   RCLCOD <> 2                           &
&                   WEIFLG <> 4                           &
&                   WEIFLG <> 5

    GHCBWCPT += 1

    If GHCBWCPT <>0 Break : Endif
Next

If GHCBWCPT <>0
    GHCBLMFGLIN = [F:WGG]MFGLIN
    GHCBLBOMSEQ = [F:WGG]BOMSEQ
    GHCBLCBTDAT = [F:WGG]CBTDAT
    GHCBLMVTSEQ = [F:WGG]MVTSEQ
    GHCBLPESEE  = [F:WGG]MFGTRKNUM
Endif

Return

########################################################################
# mise à jour MFGHEAD
########################################################################
$MAJ_MFGHEAD
If GHCBLMFGNUM <> ""
   Call DEBTRANS From GLOCK
   Trbegin [MFG]

   Call MAJ_FICHIERS ("MFG",0,GHCBLWGGSTA,GHCBLMFGNUM,"",0,0) From SCALEXCHAN : #0 On ne veut pas toucher
   If GOK = 1  : Commit
   Else        : Rollback
   Endif

Endif

If GHCBIVALEUR <> ""
   GHCBLMFGNUM = GHCBIVALEUR
   Call DEBTRANS From GLOCK
   Trbegin [MFG]

   Call MAJ_FICHIERS ("MFG",0,10,GHCBIVALEUR,"",0,0) From SCALEXCHAN : # 0 On ne veut pas toucher et 10 ordre bloquee en réconciliation
   If GOK = 1  : Commit
   Else        : Rollback
   Endif

   GHCBLWGGSTA = [M:XRCL]WGGSTA
Endif
Return

#########################################################################
$CHARGE_PARAM
Local Char VALPAR(20)
Call PARAM([M:XRCL]MFGFCY,"RECONCIL",[L]VALPAR) From ADOVAL
[V]GRECONCIL = val([L]VALPAR)

Call PARAM([M:XRCL]MFGFCY,"WEIVT",[L]VALPAR) From ADOVAL
[V]GWEIVT = val([L]VALPAR)

If [V]GWEIVT =1
    Raz[M:XRCL]ITMREF,BOMOPE,LOT,WEIWEI,WEU
    Actzo[M:XRCL]MFGTRKNUM
Else
    Raz[M:XRCL]MFGTRKNUM
#RDH18/02/2011
#    Diszo[M:XRCL]MFGTRKNUM
     Grizo [M:XRCL]MFGTRKNUM

    Actzo[M:XRCL]ITMREF,BOMOPE,LOT,WEIWEI,WEU
Endif

Return

#########################################################################
#       sous prog ETIQUETTES
#########################################################################


$ETI_MFGNUM

# Lecture MFGHEAD
# sr 01.03 faire un readlock ici (pour être sûr de pouvoir aller jusqu'à la fin sans qu'une
# autre session ne nous prenne l'entête ???

Read [MFG]MFG0 = VALEUR
If fstat :             GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If [F:MFG]WGGFLG <  3  GMESSAGE = mess(13,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If [F:MFG]WGGSTA =  10 GMESSAGE = mess(14,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If [F:MFG]WGGSTA =  9  GMESSAGE = mess(15,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
#If [F:MFG]WGGFLG =  6  GMESSAGE = mess(26,2324,1) : GERR =2 : mkstat = 2 : Return : Endif :# DT

# CATUA X3-96226.sn
#If [V]GRECONCIL<>2 & [F:MFG]WGGFLG =  6
#    GMESSAGE = mess(26,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
#Elsif [V]GRECONCIL=2 & [F:MFG]WGGFLG =7
#    GMESSAGE = mess(27,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
#Endif
If [V]GRECONCIL=2 # Reconcile by phase
  If [F:MFG]WGGFLG=7
    GMESSAGE = mess(27,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
  Endif
Elsif [V]GRECONCIL=3 # Reconcile by container
  If [F:MFG]WGGFLG=7
    GMESSAGE = mess(80,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
  Endif
Else
  If [F:MFG]WGGFLG=6
    GMESSAGE = mess(26,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
  Endif
Endif
# CATUA X3-96226.en

#MFGHEAD.WGGFLG
#1-NO
#2-TO WEIGH
#3-WEIGHING PLAN
#4-BEING WEIGHED
#5-WEIGHED
#6-RECONCILED
#7-COMMITTED
#8-WEIGHING UNDER PROGRESS BY PRODUCT

#MFGHEAD.WGGSTA
#1-NOT WEIGHED
#2-WEIGHING IN STATION UNDER PROGESS
#3-WEIGHING IN STATION COMPLETED
#4-WEIGHING IN PRODUCTION UNDER PROGESS
#5-IN PRODUCTION
#6-END OF PRODUCTION
#7-RECONCILIATION CONTROL
#8-TOTAL WEIGHING COMPLETED
#9-ORDER BLOCKED FOR WEIGHING
#10-ORDER BLOCKED FOR RECOCILIATION CONTROL
#11-ORDER BLOCKED FOR PROCESS START CONTROL

# sr 05.03
If [F:MFG]MFGSTA =  4  GMESSAGE = mess(114,193,1) : GERR =2 : mkstat = 2 : Return : Endif

# verification that all materials are weighed (wggsta = 3)
# are excluded from reconciliation rectification phases and QSPs

# verification que toutes les matieres soient pesées (wggsta = 3)
# sont exclu de la réconciliation les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)

WOK = 0
For [MFM]MFM0 Where MFGFCY = [M:XRCL]MFGFCY     &
&                   MFGNUM = VALEUR             &
&                   MATSTA <> 4                 &
&                   find([F:MFM]PKC,2,4,6)
    WOK = 1
    # CATUA X3-96226.sn
    If [V]GRECONCIL<2
      If [F:MFM]WGGSTA = 7 WOK = 7 : Break : Endif  # Already committed
      If [F:MFM]WGGSTA = 5 WOK = 8 : Break : Endif  # Already reconciled
      If [F:MFM]WGGSTA < 3 WOK = 9 : Break : Endif  # Some materials are not weighed
    Endif
    # CATUA X3-96226.en
Next

#MFGMAT.WGGSTA
#1-NOT WEIGHED
#2-IN WEIGHING PROCESS
#3-WEIGHING
#4-RECONCILIATION CONTROL
#5-RECONCILED
#6-PROCESS START CONTROL
#7-PROCESS STARTED
#8-CONSUMED

#WOK
#0-ELEMENT DOES NOT EXIST
#7-ALREADY COMMITTED
#8-ALREADY RECONCILED
#9-SOME MATERIALS ARE NOT WEIGHED

If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If WOK = 9  GMESSAGE = mess(17,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If WOK = 8  GMESSAGE = mess(26,2324,1) : GERR =2 : mkstat = 2 : Return : Endif # CATUA X3-96226 changed from 27
If WOK = 7  GMESSAGE = mess(45,2324,1) : GERR =2 : mkstat = 2 : Return : Endif # CATUA X3-96226 changed from 46

#Total number of weighing calculation
# mm 05.11 : calcul du nombre total de pesée à engager pour un of

If WOK = 1 & [V]GRECONCIL<2 # CATUA X3-96226
     [M:XRCL]MFGNUM = VALEUR
     Gosub CALCUL
     If GHCBWCPTENR = 0  GMESSAGE = mess(81,2324,1) : GERR =2 : mkstat = 2 : Raz [M:XRCL]MFGNUM # CATUA X3-96226 changed from 22
     Else
         Grizo  [M:XRCL]MFGFCY
         Grizo  [M:XRCL]MFGNUM
    Endif
Endif

Return

#########################################################
$ETI_BOMOPE
#DT-22/06/2010
# Lecture MFGMAT

If [V]GRECONCIL=2
    # Réconciliation par phase
    WOK = 0
    For [MFM]MFM0 Where MFGFCY = [M:XRCL]MFGFCY     &
&                       MFGNUM = [M:XRCL]MFGNUM     &
&                       BOMOPE = VALEUR             &
&                       MATSTA <> 4                 &
&                       find([F:MFM]PKC,2,4,6)
        WOK = 1
    If [F:MFM]WGGSTA =  5  WOK = 8 : Break : Endif
    If [F:MFM]WGGSTA  < 3  WOK = 9 : Break : Endif
    Next

    If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 9  GMESSAGE = mess(17,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 8  GMESSAGE = mess(27,2324,1) : GERR =2 : mkstat = 2 : Return : Endif

    If WOK = 1
         [M:XRCL]BOMOPE0 = VALEUR
         Gosub CALCUL
         If GHCBWCPTENR = 0  GMESSAGE = mess(22,2324,1) : GERR =2 : mkstat = 2 : Raz [M:XRCL]BOMOPE0 : Endif
    Endif
    Actzo[M:XRCL]BOMOPE0
Else
    Raz [M:XRCL]BOMOPE0
#RDH18/02/2011
#    Diszo[M:XRCL]BOMOPE0
     Grizo [M:XRCL]BOMOPE0

Endif
Return

# CATUA X3-96226.sn
# Add container field in ADC reconciliation
#########################################################
$ETI_CTN

  If [V]GRECONCIL=3
    # Reconciliation by container
    WOK = 0

    For [MFM]MFM0 Where [F:MFM]MFGFCY = [M:XRCL]MFGFCY     &
&                       [F:MFM]MFGNUM = [M:XRCL]MFGNUM     &
&                       [F:MFM]CTN = VALEUR                &
&                       [F:MFM]MATSTA <> 4                 &
&                       find([F:MFM]PKC,2,4,6)
        WOK = 1
        If [F:MFM]WGGSTA =  5  WOK = 8 : Break : Endif
        If [F:MFM]WGGSTA  < 3  WOK = 9 : Break : Endif
    Next

    If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 9  GMESSAGE = mess(17,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 8  GMESSAGE = mess(80,2324,1) : GERR =2 : mkstat = 2 : Return : Endif

    If WOK = 1
      [M:XRCL]CTN = VALEUR
      Gosub CALCUL
      If GHCBWCPTENR = 0  GMESSAGE = mess(79,2324,1) : GERR =2 : mkstat = 2 : Raz [M:XRCL]CTN

      Endif
    Endif
    Actzo [M:XRCL]CTN
  Else
    Raz [M:XRCL]CTN
    Grizo [M:XRCL]CTN
  Endif
Return
# CATUA X3-96226.en


#########################################################
$ETI_MFGTRKNUM
Local Char    ITM
Local Char    LOT
Local Char    WEU
Local Decimal OPE
Local Decimal WEI
Gosub CRTHIST_PESEE

If GHCBWCPT <>0
    Filter[F:WGG1] Where MFGNUM=[M:XRCL]MFGNUM & FCY=[M:XRCL]MFGFCY & MFGTRKNUM=VALEUR &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:XRCL]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:XRCL]CTN)  ) # CATUA #X3-96226
#&    ([V]GRECONCIL<>2|BOMOPE=[M:XRCL]BOMOPE0)
    Read[F:WGG1]WGG0 First
    If !fstat

        [L]ITM = [F:WGG1]ITMREF
        [L]OPE = [F:WGG1]BOMOPE
        [L]LOT = [F:WGG1]LOT
        [L]WEI = [F:WGG1]WEIWEI
        [L]WEU = [F:WGG1]WEU


        [M:XRCL]ITMREF = [F:WGG1]ITMREF
        [M:XRCL]BOMOPE = [F:WGG1]BOMOPE
        [M:XRCL]LOT    = [F:WGG1]LOT
        [M:XRCL]WEIWEI = [F:WGG1]WEIWEI
        [M:XRCL]WEU    = [F:WGG1]WEU
        Affzo[M:XRCL]ITMREF,BOMOPE,LOT,WEIWEI,WEU

        If mkstat = 0  Call C_ITMREF([L]ITM)     Endif
        If mkstat = 0  Call C_BOMOPE([L]OPE)     Endif
        If mkstat = 0  Call AM_BOMOPE([L]OPE)    Endif
        If mkstat = 0  Call C_LOT([L]LOT)        Endif
        If mkstat = 0  Call AM_LOT([L]LOT)       Endif
        If mkstat = 0  Call C_WEIWEI([L]WEI)     Endif
        If mkstat = 0  Call AM_WEIWEI([L]WEI)    Endif

        If mkstat=0
            [M:XRCL]WEIWEI = [F:WGG1]WEIWEI
            [M:XRCL]WEU    = [F:WGG1]WEU
#Diszo[M:XRCL]BOMOPE0

#            Diszo[M:XRCL]ITMREF,BOMOPE,LOT,WEIWEI,WEU
            Grizo[M:XRCL]ITMREF,BOMOPE,LOT,WEIWEI,WEU

        Else
            zonsui = "MFGTRKNUM"
            GMESSAGE = mess(89,2324,1) : GERR =2 : mkstat = 2
        Endif

    Else
        VALEUR =""
    Endif
    Filter[F:WGG1]
Else
    GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return

#########################################################
$ETI_LOT
#DT-21/06/2010
If [M:XRCL]SAISIE=1 : # Par pesée
   Return
Endif
#
Gosub CRTHISTLOT
[M:XRCL]WEIWEI = 0
[M:XRCL]WEU    = ""

# sr 09.03 mis en commentaire suite à demande de Céline Charron : ils doivent aussi confirmer la quantité même si une seule pesée
#If GHCBWCPT > 1 Actzo [M:XRCL]WEIWEI
#Else Grizo [M:XRCL]WEIWEI
#Endif

If GHCBWCPT = 1 [M:XRCL]WEU    = [F:WGG]WEU
Elsif GHCBWCPT = 0 : GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return

#########################################################
$ETI_WEIWEI
Gosub CRTHISTWEI
[M:XRCL]WEU    = ""
If GHCBWCPT = 1  [M:XRCL]WEU   = [F:WGG]WEU
Elsif GHCBWCPT = 0 GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return

#########################################################
$ETI_ITMREF
Gosub CRTHISTART
If GHCBWCPTART = 0 GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Endif
Return

###########################################################
$CTR_PESEE
Return


#########################################################################
#                     ETIQUETTES                                        #
#########################################################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
Gosub ETI_MFGNUM
End

########################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
# sr 01.03 y-a-t-il des matières exclues
# Si oui on propose d'anabndonner la réconciliation

Filter [F:MFM] Where MFGNUM = VALEUR & MATSTA = 4
Look [F:MFM]MFM0 First
If !fstat
    Filter [F:MFM]
    WOK=1
    Call OUINON(mess(39,2324,1),WOK) From GESECRAN
    If WOK <> 2 : mkstat=2 : End : Endif
Endif
Filter [F:MFM]

GHCBIVALEUR = VALEUR
[M:XRCL]WGGSTA = [F:MFG]WGGSTA
Affzo [M:XRCL]WGGSTA
Gosub MAJ_MFGHEAD
End

########################################
Subprog S_MFGNUM(VALEUR)
Variable Char    VALEUR()
########################################
#                              WGGFLG >2  > une peser doit etre faite
#                              WGGSTA <>7 > en reconciliation
#                              WGGSTA <>9 > bloqué en peser
#                              WGGFLG <>6 > reconcilié

Filter [F:MFG] Where MFGFCY = [M:XRCL]MFGFCY &  WGGFLG > 2 & WGGFLG < 6 & WGGSTA <> 9
Call SELECT("MFG","",VALEUR,"") From SELOBJ
Filter [F:MFG]

End

########################################
Subprog AS_BOMOPE(VALEUR)
Variable Decimal  VALEUR
If [M:XRCL]BOMOPE0 <> 0
    VALEUR=[M:XRCL]BOMOPE0
Endif
End

########################################
Subprog C_BOMOPE(VALEUR)
Variable Decimal VALEUR

#DT-21/06/2010
If [V]GRECONCIL=2 & VALEUR <> [M:XRCL]BOMOPE0
    GMESSAGE = mess(6,2324,1)  : GERR =2 : mkstat = 2
Else
    GHCBLBOMOPE = VALEUR
    Gosub ETI_ITMREF
Endif
End

########################################
Subprog AM_BOMOPE(VALEUR)
Variable Decimal VALEUR
GHCBLBOMOPE = VALEUR
End

########################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()

Gosub ETI_LOT

GHCBWBOUT = 1

If [M:XRCL]WEU <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End

########################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
LLOT = VALEUR
#Gosub ETI_LOT

Affzo  [M:XRCL]WEIWEI
Affzo  [M:XRCL]WEU

GHCBWBOUT = 1

If [M:XRCL]WEU <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
GHCBLITMREF = VALEUR
End
########################################
Subprog C_WEIWEI(VALEUR)
Variable Decimal VALEUR

Gosub ETI_WEIWEI
GHCBWBOUT = 1
#DT-21/06/2010
If [M:XRCL]WEU <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End

########################################
Subprog AM_WEIWEI(VALEUR)
Variable Decimal VALEUR

Affzo  [M:XRCL]WEU
GHCBWBOUT = 1

If [M:XRCL]WEU <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End

# CATUA X3-96226.sn
########################################
Subprog AV_BOMOPE0(VALEUR)
Variable Decimal VALEUR
  If [V]GRECONCIL=2 & [M:XRCL]MFGTRKNUM=""
    Actzo[M:XRCL]BOMOPE0
  Else
    Grizo[M:XRCL]BOMOPE0
  Endif
End
# CATUA X3-96226.en

########################################
Subprog C_BOMOPE0(VALEUR)
Variable Decimal  VALEUR
#DT-18/06/2010
If [V]GRECONCIL=2 & VALEUR=0
    GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
    End
Endif

Gosub ETI_BOMOPE
End

# CATUA X3-96226.sn
# Add container field in ADC reconciliation
#########################################
Subprog AV_CTN(VALEUR)
Variable Char    VALEUR()
  If [V]GRECONCIL=3 & [M:XRCL]MFGTRKNUM=""
    Actzo[M:XRCL]CTN
  Else
    Grizo[M:XRCL]CTN
  Endif
End

#########################################
Subprog C_CTN(VALEUR)
Variable Char    VALEUR()
  Gosub ETI_CTN
End
 # CATUA X3-96226.en

#########################################
Subprog AM_SAISIE(VALEUR)
Variable Integer  VALEUR

#DT-18/06/2010
If VALEUR=1
    Raz[M:XRCL]ITMREF,BOMOPE,LOT,WEIWEI,WEU
    #Diszo[M:XRCL]ITMREF,BOMOPE,LOT,WEIWEI,WEU
    Actzo[M:XRCL]MFGTRKNUM
    zonsui = "MFGTRKNUM"
Else
    Raz[M:XRCL]MFGTRKNUM
#RDH18022011
#    Diszo[M:XRCL]MFGTRKNUM
     Grizo [M:XRCL]MFGTRKNUM

    Actzo[M:XRCL]ITMREF,BOMOPE,LOT,WEIWEI,WEU
    zonsui = "ITMREF"
Endif
End

########################################
Subprog C_MFGTRKNUM(VALEUR)
Variable Char     VALEUR

If [M:XRCL]SAISIE=1 & VALEUR=""
    GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
Endif

If mkstat <> 2
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
     Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7 Endif
Endif
End

########################################
Subprog AM_MFGTRKNUM(VALEUR)
Variable Char VALEUR
Gosub ETI_MFGTRKNUM
If mkstat <> 2
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
     Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7 Endif
Endif
End

