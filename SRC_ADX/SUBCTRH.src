## Etiquette ajoutée par le superviseur (écran CTRH2) 27/03/2015 10:05:33 (MAE)
######################################################################################
Subprog AM_TCTRNUM(VALEUR)
Variable Char    VALEUR()
WCONTAINER.TCTRNUM = VALEUR
#On ne peut pas faire un setinstance avec l'écran car la classe n'est pas remplie avec les valeurs de l'écran
#a modifier et a mettre plus propre
#SetInstance [M:CTRH2] With WCONTAINER
[M:CTRH2]DSPWEU = WCONTAINER.DSPWEU
[M:CTRH2]DSPVOU = WCONTAINER.DSPVOU
[M:CTRH2]MAXWEI = [F:TCTR]MAXWEI
[M:CTRH2]USFVOL = [F:TCTR]USFVOL
#MAE,Fin Exi 110713
# Issue 111256 US2
[M:CTRH2]TCTRVOL = [F:TCTR]TCTRVOL
[M:CTRH2]TARWEI = [F:TCTR]TARWEI
Affzo [M:CTRH2]
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran CTRH1) 07/04/2015 10:33:12 (MAE)
######################################################################################
Subprog AM_QTYUOM(VALEUR)
Variable Decimal VALEUR
Local Shortint NOL : NOL=nolign-1

#Pour que la qté soit affectée si l'utilisateur lance un recalcul des cumuls
[M:CTRH1]QTYUOM(NOL) = VALEUR

#lecture de la commande pour réaffecter les poids et volume si ils ont été modifiés afinde les recalculer
# à partir des poids et volume de la commande
Read [POQ] POQ0=[M:CTRH1]POHNUM(NOL);[M:CTRH1]POPLIN(NOL);[M:CTRH1]POQSEQ(NOL)
  If fstat<>[V]CST_AOK  Raz [F:POQ] : Endif
#Recalcul des qtés en STU et un PUU à partir de l'UOM
If [F:POQ]QTYUOM <>0
  [M:CTRH1]QTYPUU(NOL) = [F:POQ]QTYPUU * VALEUR / [F:POQ]QTYUOM
  # Issue X3-82714 - 2018-03-30 by MAE : arrondi des qtés et recalcul de la qté US avec le coeff
  Call QTEARR([M:CTRH1]QTYPUU(NOL),[M:CTRH1]PUU) From TRTDIV
  #[M:CTRH1]QTYSTU(NOL) = [F:POQ]QTYSTU * VALEUR / [F:POQ]QTYUOM
  [M:CTRH1]QTYSTU(NOL) = VALEUR * [F:ITM]PUUSTUCOE
  Call QTEARR([M:CTRH1]QTYSTU(NOL),[M:CTRH1]STU) From TRTDIV
  # End issue X3-82714
  [M:CTRH1]LINAMT(NOL) = [F:POQ]LINAMT * VALEUR / [F:POQ]QTYUOM
  Call ARRDEV([M:CTRH1]LINAMT(NOL),[M:CTRH1]NETCUR(NOL)) From TRTDIV  # Issue X3-70790 - 2018-01-15 by MAE
Else
  [M:CTRH1]QTYPUU(NOL) = [F:POQ]QTYPUU
  [M:CTRH1]QTYSTU(NOL) = [F:POQ]QTYSTU
  [M:CTRH1]LINAMT(NOL) = [F:POQ]LINAMT
Endif
If [F:POQ]QTYSTU <> 0
  [M:CTRH1]QTYWEU(NOL)=[M:CTRH1]QTYSTU(NOL)*[F:POQ]QTYWEU/[F:POQ]QTYSTU
  [M:CTRH1]QTYVOU(NOL)=[M:CTRH1]QTYSTU(NOL)*[F:POQ]QTYVOU/[F:POQ]QTYSTU
Else
  [M:CTRH1]QTYWEU(NOL)=0
  [M:CTRH1]QTYVOU(NOL)=0
Endif
#Call CONVERT_VOUWEU("CTRH1",NOL,[M:CTRH1]LINWEU(NOL),[M:CTRH1]LINVOU(NOL),VALEUR,[M:CTRH1]QTYSTU(NOL)) From STCLIB
If !GIMPORT Affzo [CTRH1]QTYVOU(NOL),QTYWEU(NOL),LINAMT(NOL) : Endif

#CALCUL DU COEFFICIENT UOM/UA
If VALEUR <>0
   #----- Dans tous le cas calcul coefficient conversion UOM vers UA -----#
   [M:CTRH1]UOMPUUCOE(NOL) =arr([M:CTRH1]QTYPUU(NOL)/VALEUR,0.00000001)
Endif
If [M:CTRH1]UOMPUUCOE(NOL)=0 : [M:CTRH1]UOMPUUCOE(NOL)=1 : Endif


End



