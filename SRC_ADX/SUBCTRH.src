## Etiquette ajoutée par le superviseur (Objet CTRH) 12/03/2015 10:22:40 (MAE)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE           From SUBCTRHA
 When "RAZCRE"       : Gosub RAZCRE          From SUBCTRHA
 When "INICRE"       : Gosub INICRE          From SUBCTRHA
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE     From SUBCTRHA
 When "SETBOUT"      : Gosub SETBOUT         From SUBCTRHA
 When "FILGAUCHE"    : Gosub FILGAUCHE       From SUBCTRHA
 When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE    From SUBCTRHA
 When "TIROIR"       : Gosub TIROIR          From SUBCTRHA
 When "DEB_PICK"     : Gosub DEB_PICK        From SUBCTRHA
 When "PICKE"        : Gosub PICKE           From SUBCTRHA
 When "DEPICK"       : Gosub DEPICK          From SUBCTRHA
 When "FIN_PICK"     : Gosub FIN_PICK        From SUBCTRHA
 When "LIENS"        : Gosub LIENS           From SUBCTRHA
 When "APRES_MOD"    : Gosub APRES_MOD       From SUBCTRHA
 When "APRES_MODIF"  : Gosub APRES_MODIF     From SUBCTRHA
 When "APRES_CRE"    : Gosub APRES_CRE       From SUBCTRHA
 When "DEFLIG"       : Gosub DEFLIG          From SUBCTRHA
 When "AV_ANNULE"    : Gosub AV_ANNULE       From SUBCTRHA
 When "ANNULE"       : Gosub ANNULE          From SUBCTRHA
 When "ABANDON"      : Gosub ABANDON         From SUBCTRHA
 When "FILTRE"       : Gosub FILTRE          From SUBCTRHA
 When "EXEBOUT"      : Gosub EXEBOUT         From SUBCTRHA
 When "HINT"         : Gosub HINTCLE         From SUBCTRHA
 When "CREATION"     : Gosub CREATION        From SUBCTRHA
 When "MODIF"        : Gosub MODIF           From SUBCTRHA
 When "INICRE_LIG"   : Gosub INICRE_LIG      From SUBCTRHA
 When "LIENS_LIG"    : Gosub LIENS_LIG       From SUBCTRHA
 When "VALLIG"       : Gosub VALLIG          From SUBCTRHA
 When "FERME"        : Gosub FERME           From SUBCTRHA
 When Default
Endcase
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran CTRH1) 18/03/2015 09:12:55 (MAE)
######################################################################################
Subprog AVANT_NBLIG
Local Shortint NOL  : NOL=nolign-1
#----- Suppression ligne -----#
If status=65 | status=68 | status=83
  Local Char     SYMBOLE2(30)
  Local Char     NUMCDE(GLONPOH)
  Local Integer  NUMLIN
  Local Integer  NUMSEQ
  Local Shortint WLIG
  #----- Pour actualisation liste de gauche -----#
  If !GIMPORT & [M:CTRH1]CREFLG(NOL)=0
    Local Shortint WPICK, I
    WPICK=1 : I=nolign-1 : Gosub MARQUAGE_LIGNE From SUBCTRHA
  Endif
Endif
End


