#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################################################
#   Statistiques compétences                                      Module CRM          21 novembre 2003
#########################################################################################################
#########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

#########################################################################################################
$OUVRE
Global Integer GICXT1ATTOP
Global Char GSZCXT1BPC
Global Char GSZCXT1SELPBL

  GSZCXT1BPC = PARAM(1)
  GSZCXT1SELPBL = ""
  GICXT1ATTOP = 0
  If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
  If !clalev([F:PBR]) : Local File FAMPBREP [PBR] : Endif
  If !clalev([F:PBQ]) : Local File FAMPBQUE [PBQ] : Endif
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNCXT1"
Return

#########################################################################################################
$DEFBOUT
Return

#########################################################################################################
$SETBOUT
Return

#########################################################################################################
$OUVRE_BOITE
Return

#########################################################################################################
$DEBUT
  Gosub LOADCXT1
Return

#########################################################################################################
$AV_CHOIX
Return

#########################################################################################################
AP_CHOIX
Return

#########################################################################################################
$AVANT_BOUTON
Return

#########################################################################################################
$FINSAI
  Raz [M:CXT1]
  Kill GSZCXT1BPC
  Kill GSZCXT1SELPBL
  Kill GICXT1ATTOP
Return

#########################################################################################################
$FIN
Return

#########################################################################################################
$ABANDON
Return

#########################################################################################################
$APRES_MODIF
Return

#########################################################################################################
$BOUTON
Return

#########################################################################################################
$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################################################################
# Chargement des statistiques
########################################################
$RAZPBL
  Raz [M:CXT1]NBPBL
  Raz [M:CXT1]PBL
Return

#########################################################################################################
$LOADCXT1
  Gosub RAZPBL
  Filter [PBL] Where [F:PBL]PAEGRPNUM = "" and [F:PBL]PBLBPC = ""
  For [PBL]
    If [M:CXT1]NBPBL >= dim([M:CXT1]PBL) Then
      Break
    Endif
    [M:CXT1]PBL([M:CXT1]NBPBL) = [F:PBL]NUM
    [M:CXT1]NBPBL += 1
  Next
  Filter [PBL]
  If GSZCXT1BPC <> "" Then
    Filter [PBL] Where [F:PBL]PAEGRPNUM = "" and [F:PBL]PBLBPC = GSZCXT1BPC
    For [PBL]
      If [M:CXT1]NBPBL >= dim([M:CXT1]PBL) Then
        Break
      Endif
      [M:CXT1]PBL([M:CXT1]NBPBL) = [F:PBL]NUM
      [M:CXT1]NBPBL += 1
    Next
    Filter [PBL]
  Endif
  Call LOADREPSTAT([M:CXT1]PBL(0))
  Call LOADQUESTAT([M:CXT1]PBL(0))
  GICXT1ATTOP = 1
  Affzo [M:CXT1]
Return

#########################################################################################################
$LOADPAEPBL
#Affichage des familles parents.
Local Integer Z
Local Char SZPARENT

  SZPARENT = ""
  Z = 0
  Read [PBL]PBL0=GSZCXT1SELPBL
  If fstat Then
    GMESSAGE = mess(258,196,1) #La recherche de la famille parent a échouée.
    GERR = 1
    Return
  Else
    Gosub RAZPBL
    SZPARENT = [F:PBL]PAEGRPNUM
  Endif
  Read [PBL]PBL0=SZPARENT
  If fstat Then
    GMESSAGE = mess(258,196,1) #La recherche de la famille parent a échouée.
    GERR = 1
    Return
  Else
    If [F:PBL]PAEGRPNUM = "" Then
      #Il s'agit d'une famille racine
      Gosub LOADCXT1
      GICXT1ATTOP = 1
    Else
      #Il s'agit d'une sous-famille
      Gosub RAZPBL
      [M:CXT1]PBL(0) = SZPARENT
      [M:CXT1]NBPBL = 1
      GICXT1ATTOP = 0
    Endif
  Endif
  GSZCXT1SELPBL = [M:CXT1]PBL(0)
  Call LOADREPSTAT([M:CXT1]PBL(0))
  Call LOADQUESTAT([M:CXT1]PBL(0))
Return

#########################################################################################################
$LOADSUBPBL
#Affichage des familles filles.
Local Integer Z

  Z = 0
  Filter [PBL] Where [F:PBL]PAEGRPNUM = GSZCXT1SELPBL
  For [PBL]
    Z += 1
  Next
  If Z = 0 Then
    GMESSAGE = mess(263,196,1) #Il n'y a aucune sous-famille pour cette famille de compétence.
    GERR = 2
    Filter [PBL]
    Return
  Else
    Gosub RAZPBL
    Z = 0
    For [PBL]
      [M:CXT1]PBL(Z) = [F:PBL]NUM
      Z += 1
    Next
    [M:CXT1]NBPBL = Z
  Endif
  Filter [PBL]
  GICXT1ATTOP = 0
  GSZCXT1SELPBL = [M:CXT1]PBL(0)
  Call LOADREPSTAT([M:CXT1]PBL(0))
  Call LOADQUESTAT([M:CXT1]PBL(0))
Return

#########################################################################################################
Subprog LOADREPSTAT(SZPBL)
Value Char SZPBL

Local Char SZPBL2
Local Integer ISSBFLG

  ISSBFLG = 0
  SZPBL2 = ""
  Raz [M:CXT1]NBAUS
  Raz [M:CXT1]AUS
  Raz [M:CXT1]NBRAUS
  Raz [M:CXT1]PBLTOT
  Raz [M:CXT1]SSBPBLTOT
  If SZPBL = "" Then
    End
  Endif
  Filter [PBR] Where [F:PBR]GRPPBLNUM <> ""
  For [PBR]PBR1
    If [M:CXT1]NBAUS >= dim([M:CXT1]AUS) Then
      If [F:PBR]GRPPBLNUM = SZPBL Then
        [M:CXT1]PBLTOT += [F:PBR]SRECOU
        [M:CXT1]SSBPBLTOT += [F:PBR]SRECOU
      Else
        #Vérifie si la compétence est une sous-famille de SZPBL
        Gosub CHKSSBPBL
      Endif
    Else
      If [F:PBR]GRPPBLNUM = SZPBL Then
        If [F:PBR]SRECOU > 0 Then
          [M:CXT1]AUS([M:CXT1]NBAUS) = [F:PBR]REPNUM
          [M:CXT1]NBRAUS([M:CXT1]NBAUS) = [F:PBR]SRECOU
          If [F:PBR]STTFLG = 0 Then
            [M:CXT1]AUSSTTFLG([M:CXT1]NBAUS) = 2
          Else
            [M:CXT1]AUSSTTFLG([M:CXT1]NBAUS) = 1
          Endif
          [M:CXT1]PBLTOT += [F:PBR]SRECOU
          [M:CXT1]SSBPBLTOT += [F:PBR]SRECOU
          [M:CXT1]NBAUS += 1
        Endif
      Else
        #Vérifie si la compétence est une sous-famille de SZPBL
        Gosub CHKSSBPBL
      Endif
    Endif
  Next
  Filter [PBR]
End

#########################################################################################################
$CHKSSBPBL
  ISSBFLG = 0
  SZPBL2 = [F:PBR]GRPPBLNUM
  While 1
    Read [PBL]PBL0=SZPBL2
    If fstat Then
      Break
    Else
      If [F:PBL]PAEGRPNUM = "" Then
        Break
      Else
        If [F:PBL]PAEGRPNUM = SZPBL Then
          ISSBFLG = 1
          Break
        Else
          SZPBL2 = [F:PBL]PAEGRPNUM
        Endif
      Endif
    Endif
  Wend
  If ISSBFLG Then
    [M:CXT1]SSBPBLTOT += [F:PBR]SRECOU
  Endif
Return

#########################################################################################################
Subprog LOADQUESTAT(SZPBL)
Value Char SZPBL

Local Char SZPBL2
Local Integer ISSBFLG

  ISSBFLG = 0
  SZPBL2 = ""
  Raz [M:CXT1]NBQUE
  Raz [M:CXT1]QUE
  Raz [M:CXT1]NBRQUE
  If SZPBL = "" Then
    End
  Endif
  Filter [PBQ] Where [F:PBQ]GRPPBLNUM <> ""
  For [PBQ]PBQ1
    If [M:CXT1]NBQUE >= dim([M:CXT1]QUE) Then
      If [F:PBQ]GRPPBLNUM = SZPBL Then
        [M:CXT1]PBLTOT += [F:PBQ]SRECOU
        [M:CXT1]SSBPBLTOT += [F:PBQ]SRECOU
      Else
        #Vérifie si la compétence est une sous-famille de SZPBL
        Gosub CHK2SSBPBL
      Endif
    Else
      If [F:PBQ]GRPPBLNUM = SZPBL Then
        If [F:PBQ]SRECOU > 0 Then
          [M:CXT1]QUE([M:CXT1]NBQUE) = [F:PBQ]QUENUM
          [M:CXT1]NBRQUE([M:CXT1]NBQUE) = [F:PBQ]SRECOU
          [M:CXT1]PBLTOT += [F:PBQ]SRECOU
          [M:CXT1]SSBPBLTOT += [F:PBQ]SRECOU
          [M:CXT1]NBQUE += 1
        Endif
      Else
        #Vérifie si la compétence est une sous-famille de SZPBL
        Gosub CHK2SSBPBL
      Endif
    Endif
  Next
  Filter [PBQ]
End

#########################################################################################################
$CHK2SSBPBL
  ISSBFLG = 0
  SZPBL2 = [F:PBQ]GRPPBLNUM
  While 1
    Read [PBL]PBL0=SZPBL2
    If fstat Then
      Break
    Else
      If [F:PBL]PAEGRPNUM = "" Then
        Break
      Else
        If [F:PBL]PAEGRPNUM = SZPBL Then
          ISSBFLG = 1
          Break
        Else
          SZPBL2 = [F:PBL]PAEGRPNUM
        Endif
      Endif
    Endif
  Wend
  If ISSBFLG Then
    [M:CXT1]SSBPBLTOT += [F:PBQ]SRECOU
  Endif
Return
