#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet BCD
######################################################################################
## SUBBCD : Paramétrage inter-sociétés : correspondance des elements de facturation
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LIENS"    : Gosub LIENS
 When "INICRE"   : Gosub INICRE
 When "INIMOD"   : Gosub INICRE
 When default
Endcase
Return

#-------------------------------------------------------------------------------------
$OUVRE
#Gosub OPEN_SFI From TRTX3CPY
If clalev([F:SFI])=0 : Local File SFOOTINV [SFI] : Endif
If clalev([F:PFI])=0 : Local File PFOOTINV [PFI] : Endif
Return

#-------------------------------------------------------------------------------------
$LIENS
For JL=0 To dim([M]SFINUM)-1
    If [F:BCD]SFINUM(JL)=0 : Break : Endif
    [M]SFINUM(JL)=[F:BCD]SFINUM(JL)
    [M]PFINUM(JL)=[F:BCD]PFINUM(JL)
    [M]CORIDEM(JL)=num$([M]SFINUM(JL))+"~"+num$([M]PFINUM(JL))
    #Read [SFI] SFI0=[M]CPYSAL;[M]SFINUM(JL)
    Read [SFI] SFI0=[M]SFINUM(JL)
    [M]AMTCOD(JL)=[F:SFI]AMTCOD
    [M]NBCOR=JL+1    
Next JL
Return

#-------------------------------------------------------------------------------------
$INICRE
Raz [F:BCD]SFINUM, PFINUM
For JL=0 To dim([M]SFINUM)-1 
    If [M]SFINUM(JL)=0 : Break : Endif
    [F:BCD]SFINUM(JL)=[M]SFINUM(JL) : [F:BCD]PFINUM(JL)=[M]PFINUM(JL)
Next JL
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran BCH150B) 
######################################################################################

Subprog C_CPYPUR(VALEUR)
Variable Char    VALEUR()
If [M]CPYSAL=VALEUR : mkstat=1 : Endif
End


########################################

Subprog AM_SFINUM(VALEUR)
Variable Decimal VALEUR
#Read [SFI] SFI0=[M]CPYSAL;VALEUR
Read [SFI] SFI0=VALEUR
[M]AMTCOD(nolign-1)=[F:SFI]AMTCOD
Affzo [M]AMTCOD(nolign-1)
End

########################################

Subprog C_PFINUM(VALEUR)
Variable Decimal VALEUR
Variable Decimal VALEUR
Local Char IDEM (20)
IDEM=num$([M]SFINUM(nolign-1))+"~"+num$(VALEUR)
Call UNICITE(IDEM,[M]CORIDEM) From OBJDIV
If mkstat : End : Endif

#Read [SFI]SFI0=[M]CPYSAL;[M]SFINUM(nolign-1)
Read [SFI]SFI0=[M]SFINUM(nolign-1)
If fstat : End : Endif

#Read [PFI]SFI0=[M]CPYPUR;VALEUR
Read [PFI]PFI0=VALEUR
If fstat : End : Endif

Raz GMESSAGE
If [F:PFI]ENAFLG=1 
   GMESSAGE += mess(860,196,1)-num$([F:PFI]PFINUM)+" : "+mess(1,8,1) 
Endif   
If [F:SFI]PROCOD=3 
   If GMESSAGE<>"" : GMESSAGE += " \ " Endif
   GMESSAGE += mess(861,196,1)-num$([F:SFI]SFINUM)+" : "+mess(1,8,1)
Endif
If [F:PFI]AMTCOD<>[F:SFI]AMTCOD
   If GMESSAGE<>"" : GMESSAGE += " \ " Endif
   GMESSAGE += mess(860,196,1)-num$([F:PFI]PFINUM)+" : "+mess([F:PFI]AMTCOD,269,1)+"   "
   GMESSAGE += mess(861,196,1)-num$([F:SFI]SFINUM)+" : "+mess([F:SFI]AMTCOD,269,1) 
Endif
If [F:PFI]INCDCR<>[F:SFI]INCDCR
   If GMESSAGE<>"" : GMESSAGE += " \ " Endif
   GMESSAGE += mess(860,196,1)-num$([F:PFI]PFINUM)+" : "+mess([F:PFI]INCDCR,254,1)+"   "
   GMESSAGE += mess(861,196,1)-num$([F:SFI]SFINUM)+" : "+mess([F:SFI]INCDCR,254,1) 
Endif
If GMESSAGE<>"" : GERR=1 : mkstat=1 : Endif

End

########################################

Subprog APRES_NBCOR
#--- concatenation pour controle unicite
If [M]SFINUM(nolign-1)<>0
   [M]CORIDEM(nolign-1)=num$([M]SFINUM(nolign-1))+"~"+num$([M]PFINUM(nolign-1))
Endif
End

######################################################################################


######################################################################################
## Etiquette ajoutée par le superviseur (écran BCH150B) 15/05/2006 13:18:47 (JL)
######################################################################################
Subprog AS_SFINUM(VALEUR)
Variable Decimal VALEUR
GSOCIETE=[M]CPYSAL
End

Subprog AS_PFINUM(VALEUR)
Variable Decimal VALEUR
GSOCIETE=[M]CPYPUR
End


######################################################################################

