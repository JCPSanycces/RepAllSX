#<AdxTL>@(#)6.0.0.0 $Revision$
########################################################################################################
# Subprog LEC_BLA(LED,LEDTYP,SOCIETE,SITE,ACC,DIE1,DIE2,DIE3, DIE4, DIE5, DIE6, DIE7, DIE8, DIE9,
# &               CCE1, CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9,EXER,MNTREA,
#   &               QTEREA,MNTENG,QTEENG,MNTPREENG,QTEPREENG)
# Subprog CONVERT_ZON(LEDTYP,SOCIETE,SITE,MT)
# Subprog CONVERT(LEDTYP,SOCIETE,SITE,NBLIG,MNTREA,QTEREA,MNTENG,QTEENG,MNTPREENG,QTEPREENG)
#
########################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FBUD","BUDGET","DBUDCRI",4,"") From GTRAITE
End

########## Sous-programmes communs û  la saisie des budgets ###########

Subprog LEC_BLA(LED, LEDTYP, SOCIETE, SITE, ACC, DIE1, DIE2, DIE3, DIE4, DIE5, DIE6, DIE7, DIE8, DIE9,
&               CCE1, CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9,
&               EXER, MNTREA, QTEREA, MNTENG, QTEENG, MNTPREENG ,QTEPREENG)
Value    Char    LED()          : # Rûˋfûˋrentiel
Value    Integer LEDTYP()       : # Type rûˋfûˋrentiel
Value    Char    SOCIETE()      : # Sociûˋtûˋ
Value    Char    SITE()         : # Site
Value    Char    ACC()          : # Code du compte
Value    Char    DIE1()         : # Axe 1
Value    Char    DIE2()         : # Axe 2
Value    Char    DIE3()         : # Axe 3
Value    Char    DIE4()         : # Axe 4
Value    Char    DIE5()         : # Axe 5
Value    Char    DIE6()         : # Axe 6
Value    Char    DIE7()         : # Axe 7
Value    Char    DIE8()         : # Axe 8
Value    Char    DIE9()         : # Axe 9
Value    Char    CCE1()         : # Section axe 1
Value    Char    CCE2()         : # Section axe 2
Value    Char    CCE3()         : # Section axe 3
Value    Char    CCE4()         : # Section axe 4
Value    Char    CCE5()         : # Section axe 5
Value    Char    CCE6()         : # Section axe 6
Value    Char    CCE7()         : # Section axe 7
Value    Char    CCE8()         : # Section axe 8
Value    Char    CCE9()         : # Section axe 9
Value    Integer EXER           : # Exercice
Variable Decimal MNTREA(1..)    : # Montant rûˋel
Variable Decimal QTEREA(1..)    : # Quantitûˋ rûˋelle
Variable Decimal MNTENG(1..)    : # Montant engagûˋ
Variable Decimal QTEENG(1..)    : # Quantitûˋ engagûˋe
Variable Decimal MNTPREENG(1..) : # Montant prûˋ-engagûˋ
Variable Decimal QTEPREENG(1..) : # Quantitûˋ prûˋ-engagûˋ
Local Integer I, PFIN, STA
Local Char CCE(GLONCCE)(9)
Local Char CODLED(GLONLED), DEVLED(GLONCUR)
Local Integer IE1, IE2, IE3, IE4, IE5, IE6, IE7, IE8, IE9
Local Char FILTRE(250), ORDRE(100)
Local Char FILTRE2(250)
#68845
Local Char CHART(GLONCOA)
Call LECPLAN(SOCIETE,LEDTYP,CHART) From CPTDIV

# Indice de l'axe budget par rapport û  l'axe du rûˋfûˋrentiel
Call GET_LEDCUR(GACTX,SOCIETE,LEDTYP,CODLED,DEVLED,GMESSAGE) From FINACM_SYRA
Call LEC_LED(CODLED) From CPTLEC
Raz IE1, IE2, IE3, IE4, IE5, IE6, IE7, IE8, IE9
For I=0 To [F:LED]DIENBR-1
 If [F:LED]DIE(I) = DIE1
  IE1 = I+1
  CCE(0) = CCE1
 Elsif [F:LED]DIE(I) = DIE2
  IE2 = I+1
  CCE(1) = CCE2
 Elsif [F:LED]DIE(I) = DIE3
  IE3 = I+1
  CCE(2) = CCE3
 Elsif [F:LED]DIE(I) = DIE4
  IE4 = I+1
  CCE(3) = CCE4
 Elsif [F:LED]DIE(I) = DIE5
  IE5 = I+1
  CCE(4) = CCE5
 Elsif [F:LED]DIE(I) = DIE6
  IE6 = I+1
  CCE(5) = CCE6
 Elsif [F:LED]DIE(I) = DIE7
  IE7 = I+1
  CCE(6) = CCE7
 Elsif [F:LED]DIE(I) = DIE8
  IE8 = I+1
  CCE(7) = CCE8
 Elsif [F:LED]DIE(I) = DIE9
  IE9 = I+1
  CCE(8) = CCE9
 Endif
Next

# Crûˋation du filtre et du tri
FILTRE =  "LEDTYP="+num$(LEDTYP)+"& CPY='"+SOCIETE+"'& FCY='"+SITE+"'& FIY="+num$(EXER)+"& ACC='"+ACC+"'& BPR=''"
FILTRE2 ="1=1"
If IE9>0
 ORDRE =  "LEDTYP;CPY;FCY;FIY;ACC;BPR;CCE"+num$(IE1)+";CCE"+num$(IE2)+";CCE"+num$(IE3)+";CCE"+num$(IE4)
 ORDRE += ";CCE"+num$(IE5)+";CCE"+num$(IE6)+";CCE"+num$(IE7)+";CCE"+num$(IE8)+";CCE"+num$(IE9)
 FILTRE += "& CCE"+num$(IE1)+"='"+CCE(0)+"'& CCE"+num$(IE2)+"='"+CCE(1)+"'& CCE"+num$(IE3)+"='"+CCE(2)+"'"
 FILTRE += "& CCE"+num$(IE4)+"='"+CCE(3)+"'& CCE"+num$(IE5)+"='"+CCE(4)+"'& CCE"+num$(IE6)+"='"+CCE(5)+"'"
 FILTRE2 += "& CCE"+num$(IE7)+"='"+CCE(6)+"'& CCE"+num$(IE8)+"='"+CCE(7)+"'& CCE"+num$(IE9)+"='"+CCE(8)+"'"
Elsif IE8>0
 ORDRE =  "LEDTYP;CPY;FCY;FIY;ACC;BPR;CCE"+num$(IE1)+";CCE"+num$(IE2)+";CCE"+num$(IE3)+";CCE"+num$(IE4)
 ORDRE += ";CCE"+num$(IE5)+";CCE"+num$(IE6)+";CCE"+num$(IE7)+";CCE"+num$(IE8)
 FILTRE += "& CCE"+num$(IE1)+"='"+CCE(0)+"'& CCE"+num$(IE2)+"='"+CCE(1)+"'& CCE"+num$(IE3)+"='"+CCE(2)+"'"
 FILTRE += "& CCE"+num$(IE4)+"='"+CCE(3)+"'& CCE"+num$(IE5)+"='"+CCE(4)+"'& CCE"+num$(IE6)+"='"+CCE(5)+"'"
 FILTRE2 += "& CCE"+num$(IE7)+"='"+CCE(6)+"'& CCE"+num$(IE8)+"='"+CCE(7)+"'"
Elsif IE7>0
 ORDRE =  "LEDTYP;CPY;FCY;FIY;ACC;BPR;CCE"+num$(IE1)+";CCE"+num$(IE2)+";CCE"+num$(IE3)+";CCE"+num$(IE4)
 ORDRE += ";CCE"+num$(IE5)+";CCE"+num$(IE6)+";CCE"+num$(IE7)
 FILTRE += "& CCE"+num$(IE1)+"='"+CCE(0)+"'& CCE"+num$(IE2)+"='"+CCE(1)+"'& CCE"+num$(IE3)+"='"+CCE(2)+"'"
 FILTRE += "& CCE"+num$(IE4)+"='"+CCE(3)+"'& CCE"+num$(IE5)+"='"+CCE(4)+"'& CCE"+num$(IE6)+"='"+CCE(5)+"'"
 FILTRE2 += "& CCE"+num$(IE7)+"='"+CCE(6)+"'"
Elsif IE6>0
 ORDRE =  "LEDTYP;CPY;FCY;FIY;ACC;BPR;CCE"+num$(IE1)+";CCE"+num$(IE2)+";CCE"+num$(IE3)+";CCE"+num$(IE4)
 ORDRE += ";CCE"+num$(IE5)+";CCE"+num$(IE6)
 FILTRE += "& CCE"+num$(IE1)+"='"+CCE(0)+"'& CCE"+num$(IE2)+"='"+CCE(1)+"'& CCE"+num$(IE3)+"='"+CCE(2)+"'"
 FILTRE += "& CCE"+num$(IE4)+"='"+CCE(3)+"'& CCE"+num$(IE5)+"='"+CCE(4)+"'& CCE"+num$(IE6)+"='"+CCE(5)+"'"
Elsif IE5>0
 ORDRE =  "LEDTYP;CPY;FCY;FIY;ACC;BPR;CCE"+num$(IE1)+";CCE"+num$(IE2)+";CCE"+num$(IE3)+";CCE"+num$(IE4)
 ORDRE += ";CCE"+num$(IE5)
 FILTRE += "& CCE"+num$(IE1)+"='"+CCE(0)+"'& CCE"+num$(IE2)+"='"+CCE(1)+"'& CCE"+num$(IE3)+"='"+CCE(2)+"'"
 FILTRE += "& CCE"+num$(IE4)+"='"+CCE(3)+"'& CCE"+num$(IE5)+"='"+CCE(4)+"'"
Elsif IE4>0
 ORDRE =  "LEDTYP;CPY;FCY;FIY;ACC;BPR;CCE"+num$(IE1)+";CCE"+num$(IE2)+";CCE"+num$(IE3)+";CCE"+num$(IE4)
 FILTRE += "& CCE"+num$(IE1)+"='"+CCE(0)+"'& CCE"+num$(IE2)+"='"+CCE(1)+"'& CCE"+num$(IE3)+"='"+CCE(2)+"'"
 FILTRE += "& CCE"+num$(IE4)+"='"+CCE(3)+"'"
Elsif IE3>0
 ORDRE =  "LEDTYP;CPY;FCY;FIY;ACC;BPR;CCE"+num$(IE1)+";CCE"+num$(IE2)+";CCE"+num$(IE3)
 FILTRE += "& CCE"+num$(IE1)+"='"+CCE(0)+"'& CCE"+num$(IE2)+"='"+CCE(1)+"'& CCE"+num$(IE3)+"='"+CCE(2)+"'"
Elsif IE2>0
 ORDRE =  "LEDTYP;CPY;FCY;FIY;ACC;BPR;CCE"+num$(IE1)+";CCE"+num$(IE2)
 FILTRE += "& CCE"+num$(IE1)+"='"+CCE(0)+"'& CCE"+num$(IE2)+"='"+CCE(1)+"'"
Else
 ORDRE =  "LEDTYP;CPY;FCY;FIY;ACC;BPR;CCE"+num$(IE1)
 FILTRE += "& CCE"+num$(IE1)+"='"+CCE(0)+"'"
Endif

If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
If [F:PER]CPY<>SOCIETE & [F:PER]FIYNUM<>EXER & [F:PER]LEDTYP<>[L]LEDTYP
 Filter [PER] Where CPY=SOCIETE & FIYNUM=EXER & LEDTYP=[L]LEDTYP
 Read [PER]PER0 Last
 If !fstat
  PFIN = [F:PER]PERNUM
 Endif
 Filter [PER]
Else
 PFIN = [F:PER]PERNUM
Endif

Raz MNTREA, MNTENG, MNTPREENG
Raz QTEREA, QTEENG, QTEPREENG

Filter [BLA]Where evalue([L]FILTRE) & evalue([L]FILTRE2) Order With [L]ORDRE
For [BLA]
 # 65083 - on ne doit pas prendre en compte les reports û -nouveau
 For I=1 To PFIN
  MNTREA(I)    += ([F:BLA]DEBLED(I)-[F:BLA]CDTLED(I))/[F:BUP]DIVAMT
 Next
Next

Filter [BLM] Where evalue([L]FILTRE) & evalue([L]FILTRE2) Order With [L]ORDRE
For [BLM]
 # 65083 - on ne doit pas prendre en compte les reports û -nouveau
 For I=1 To PFIN
  MNTENG(I)    += [F:BLM]CMMLED(I)/[F:BUP]DIVAMT
  MNTPREENG(I) += [F:BLM]CMMPRPLED(I)/[F:BUP]DIVAMT
 Next
Next

Filter [BLQ] Where evalue([L]FILTRE) & evalue([L]FILTRE2) Order With [L]ORDRE
For [BLQ]
 # 65083 - on ne doit pas prendre en compte les reports û -nouveau
 For I=1 To PFIN
  QTEREA(I)    += [F:BLQ]QTY(I)
  QTEENG(I)    += [F:BLQ]QTYCMM(I)
  QTEPREENG(I) += [F:BLQ]QTYPRP(I)
 Next
Next

Call LEC_GAC(ACC,CHART) From CPTLEC
Call LEC_COA(CHART) From CPTLEC
If [F:CLS]LEG<>[F:COA]LEGCLS | [F:CLS]CLSCOD<>[F:GAC]CLSCOD
 Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
Endif
If [F:CLS]SNSANA=2
 For I=1 To PFIN
  MNTREA(I)    *= -1
  MNTENG(I)    *= -1
  MNTPREENG(I) *= -1
  QTEREA(I)    *= -1
  QTEENG(I)    *= -1
  QTEPREENG(I) *= -1
 Next
Endif



Filter [BLA]
Filter [BLM]
Filter [BLQ]
End

Subprog CONVERT_ZON(LEDTYP,SOCIETE,SITE,MT)
Value    Integer LEDTYP     : # Rûˋfûˋrentiel
Value    Char    SOCIETE()  : # Sociûˋtûˋ
Value    Char    SITE()     : # Site
Variable Decimal MT         : # Montant
Local Char    VALPAR(10)
Local Integer TYPCUR, STA
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
Call LEC_GCM([F:CPY]ACM) From CPTLEC
If [F:BUP]CUR<>[F:GCM]CUR(LEDTYP-1)
 # On a lu la balance sur le rûˋfûˋrentiel analytique manuel. Si la devise du budget
 # est diffûˋrente de la devise du rûˋfûˋrentiel, on va convertir les
 # montants lus en devise du budget
 If [F:BUP]LEV=1
  SITE = SOCIETE
 Endif
 Call PARAM(SITE,"BUDTYPCUR",VALPAR) From ADOVAL
 TYPCUR = val(VALPAR)
 If TYPCUR=0
  TYPCUR=1
 Endif
 Call LECTURE("TCU",[F:BUP]CUR,"") From CONTOBJ
 Call CONVERT([F:GCM]CUR(LEDTYP-1),[F:BUP]CUR,[F:CPY]ACCCUR,TYPCUR,datesyst,MT,MT,STA) From TRTDEV
 If STA
  Call ERREUR(mess(4,109,1)-[F:GCM]CUR(LEDTYP-1)-"=>"-[F:BUP]CUR) From GESECRAN
  GOK = 0
 Endif
Endif
End

Subprog CONVERT(LEDTYP,SOCIETE,SITE,NBLIG,MNTREA,QTEREA,MNTENG,QTEENG,MNTPREENG,QTEPREENG)
Value    Integer LEDTYP         : # Rûˋfûˋrentiel
Value    Char    SOCIETE()      : # Sociûˋtûˋ
Value    Char    SITE()         : # Site
Value    Integer NBLIG          : # Nombre de lignes du tableau
Variable Decimal MNTREA(0..)    : # Montant rûˋel
Variable Decimal QTEREA(0..)    : # Quantitûˋ rûˋelle
Variable Decimal MNTENG(0..)    : # Montant engagûˋ
Variable Decimal QTEENG(0..)    : # Quantitûˋ engagûˋe
Variable Decimal MNTPREENG(0..) : # Montant prûˋ-engagûˋ
Variable Decimal QTEPREENG(0..) : # Quantitûˋ prûˋ-engagûˋ
Local Char    VALPAR(10)
Local Integer TYPCUR, STA
Local Decimal COURS
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
Call LEC_GCM([F:CPY]ACM) From CPTLEC
If [F:BUP]CUR<>[F:GCM]CUR(LEDTYP-1)
 # On a lu la balance en devise du rûˋfûˋrentiel analytique manuel. Si la devise du budget
 # est diffûˋrente de la devise du rûˋfentiel, on va convertir les
 # montants lus en devise du budget
 If [F:BUP]LEV=1
  SITE = SOCIETE
 Endif
 Call PARAM(SITE,"BUDTYPCUR",VALPAR) From ADOVAL
 TYPCUR = val(VALPAR)
 If TYPCUR=0
  TYPCUR=1
 Endif
 Call LECTURE("TCU",[F:BUP]CUR,"") From CONTOBJ
 If [M]NBLIG>0
  Call CONVERT_TAB([F:GCM]CUR(LEDTYP-1),[F:BUP]CUR,[F:CPY]ACCCUR,TYPCUR,datesyst,MNTREA,MNTREA,STA) From TRTDEV
  Call CONVERT_TAB([F:GCM]CUR(LEDTYP-1),[F:BUP]CUR,[F:CPY]ACCCUR,TYPCUR,datesyst,MNTENG,MNTENG,STA) From TRTDEV
  Call CONVERT_TAB([F:GCM]CUR(LEDTYP-1),[F:BUP]CUR,[F:CPY]ACCCUR,TYPCUR,datesyst,MNTPREENG,MNTPREENG,STA) From TRTDEV
  If STA
   Call ERREUR(mess(4,109,1)-[F:GCM]CUR(LEDTYP-1)-"=>"-[F:BUP]CUR) From GESECRAN
   GOK = 0
   End
  Endif
 Endif
Endif
End

$AUTSECSEC
Local Integer OK
OK=1
# On contrûÇle les interdictions avec les autres sections
If [F:CCE]AUZ<>""
 If clalev([F:CCE2])=0 : Local File CACCE [CCE2] : Endif
 If clalev([F:AUZ])=0  : Local File CAAUZ [AUZ]  : Endif
 Local Integer SECTYP
 Local Char    DIE(GLONDIE)
 Local Char    SECTION(GLONCCE)
 For SECTYP=1 To [F:BUP]DIENBR
  If SECTYP<>IND
   SECTION = ""
   Case SECTYP
    When 1 : If dim([M]CCE1)=1 : SECTION = [M]CCE1 : DIE = [M]DIE1 : Endif
    When 2 : If dim([M]CCE2)=1 : SECTION = [M]CCE2 : DIE = [M]DIE2 : Endif
    When 3 : If dim([M]CCE3)=1 : SECTION = [M]CCE3 : DIE = [M]DIE3 : Endif
    When 4 : If dim([M]CCE4)=1 : SECTION = [M]CCE4 : DIE = [M]DIE4 : Endif
    When 5 : If dim([M]CCE5)=1 : SECTION = [M]CCE5 : DIE = [M]DIE5 : Endif
    When 6 : If dim([M]CCE6)=1 : SECTION = [M]CCE6 : DIE = [M]DIE6 : Endif
    When 7 : If dim([M]CCE7)=1 : SECTION = [M]CCE7 : DIE = [M]DIE7 : Endif
    When 8 : If dim([M]CCE8)=1 : SECTION = [M]CCE8 : DIE = [M]DIE8 : Endif
    When 9 : If dim([M]CCE9)=1 : SECTION = [M]CCE9 : DIE = [M]DIE9 : Endif
   Endcase
   If SECTION<>""
    Read [CCE2]CCE0 = DIE;SECTION
    If [F:CCE2]AUZ<>""
     Look [AUZ]CAZ0 = 1;[F:CCE]AUZ;[F:CCE2]AUZ
     If !fstat
      GMESSAGE = CCEACC-mess(26,106,1)-[F:CCE2]DIE-[F:CCE2]CCE
      # Interdit avec la section [F:CCE2]CCE
      OK = 0 : Break
     Endif
    Endif
   Endif
  Endif
 Next SECTYP
Endif
Return

$AUTCCEACC
# On contrûÇle si la section n'est pas interdite avec le compte
Local Integer OK
OK = 1
If !clalev([F:GAC])  : Local File GACCOUNT [GAC]  : Endif
If !clalev([F:CCE2]) : Local File CACCE [CCE2] : Endif
If !clalev([F:AUZ])  : Local File CAAUZ [AUZ]  : Endif
If IND<>0 & [F:CCE]AUZ<>"" & dim([M]ACC)=1 & [M]ACC<>""
 # On contrûÇle les interdictions compte/sections
 Call LECTURE("GAC",[M]ACC,[M]COA) From CONTOBJ
 If [F:GAC]AUZ<>""
  Look [AUZ]CAZ0 = 2;[F:GAC]AUZ;[F:CCE]AUZ
  If !fstat
   GMESSAGE = CCEACC-mess(27,106,1)-[F:GAC]COA-[F:GAC]ACC : # Interdit avec le compte
   OK = 0 : Return
  Endif
 Endif
Elsif IND=0 & [F:GAC]AUZ<>""
 # On est en saisie sur le compte
 Local Integer SECTYP
 Local Char    DIE(GLONDIE)
 Local Char    SECTION(GLONCCE)
 For SECTYP=1 To [F:BUP]DIENBR
  SECTION = ""
  Case SECTYP
   When 1 : If dim([M]CCE1)=1 : SECTION = [M]CCE1 : DIE = [M]DIE1 : Endif
   When 2 : If dim([M]CCE2)=1 : SECTION = [M]CCE2 : DIE = [M]DIE2 : Endif
   When 3 : If dim([M]CCE3)=1 : SECTION = [M]CCE3 : DIE = [M]DIE3 : Endif
   When 4 : If dim([M]CCE4)=1 : SECTION = [M]CCE4 : DIE = [M]DIE4 : Endif
   When 5 : If dim([M]CCE5)=1 : SECTION = [M]CCE5 : DIE = [M]DIE5 : Endif
   When 6 : If dim([M]CCE6)=1 : SECTION = [M]CCE6 : DIE = [M]DIE6 : Endif
   When 7 : If dim([M]CCE7)=1 : SECTION = [M]CCE7 : DIE = [M]DIE7 : Endif
   When 8 : If dim([M]CCE8)=1 : SECTION = [M]CCE8 : DIE = [M]DIE8 : Endif
   When 9 : If dim([M]CCE9)=1 : SECTION = [M]CCE9 : DIE = [M]DIE9 : Endif
  Endcase
  If SECTION<>""
   Read [CCE2]CCE0 = DIE;SECTION
   If [F:CCE2]AUZ<>""
    Look [AUZ]CAZ0 = 2;[F:GAC]AUZ;[F:CCE2]AUZ
    If !fstat
     GMESSAGE = CCEACC-mess(26,106,1)-[F:CCE2]DIE-[F:CCE2]CCE : # Interdit avec la section
     OK = 0 : Break
    Endif
   Endif
  Endif
 Next SECTYP
Endif
Return

$AXI
Case IND
 When 1 : DIE = [F:BUP]DIE(0)
 When 2 : DIE = [F:BUP]DIE(1)
 When 3 : DIE = [F:BUP]DIE(2)
 When 4 : DIE = [F:BUP]DIE(3)
 When 5 : DIE = [F:BUP]DIE(4)
 When 6 : DIE = [F:BUP]DIE(5)
 When 7 : DIE = [F:BUP]DIE(6)
 When 8 : DIE = [F:BUP]DIE(7)
 When 9 : DIE = [F:BUP]DIE(8)
Endcase
Return

$INDDIE
INDDIE=0
INDDIE = [F:BUP]DIENBR
Return

$LDIE
Raz LDIE1, LDIE2, LDIE3, LDIE4, LDIE5, LDIE6, LDIE7, LDIE8, LDIE9
If INDDIE>=1 : LDIE1=[M:BUD]DIE1 : Endif
If INDDIE>=2 : LDIE2=[M:BUD]DIE2 : Endif
If INDDIE>=3 : LDIE3=[M:BUD]DIE3 : Endif
If INDDIE>=4 : LDIE4=[M:BUD]DIE4 : Endif
If INDDIE>=5 : LDIE5=[M:BUD]DIE5 : Endif
If INDDIE>=6 : LDIE6=[M:BUD]DIE6 : Endif
If INDDIE>=7 : LDIE7=[M:BUD]DIE7 : Endif
If INDDIE>=8 : LDIE8=[M:BUD]DIE8 : Endif
If INDDIE>=9 : LDIE9=[M:BUD]DIE9 : Endif
Return

