$TIT_COL
Local Char TITCL(200)(1..6)
Raz TITCL
Case BASPAG
 When "NBRSAL"
  TITCL(1) = [M:CTR5]LIBSAL(0)
  TITCL(2) = [M:CTR5]LIBSAL(1)
  TITCL(3) = [M:CTR5]LIBSAL(2)
  TITCL(4) = [M:CTR5]LIBSAL(3)
  TITCL(5) = [M:CTR5]LIBSAL(4)
  TITCL(6) = [M:CTR5]LIBSAL(5)
  If !GORITITCOL
   Titcol [M]NBRSAL TITCL(1) For SALVAL
   Titcol [M]NBRSAL TITCL(2) For SALVAL1
   Titcol [M]NBRSAL TITCL(3) For SALVAL2
   Titcol [M]NBRSAL TITCL(4) For SALRUB
   Titcol [M]NBRSAL TITCL(5) For SALRUB1
   Titcol [M]NBRSAL TITCL(6) For SALRUB2
  Else
   Titcol [M:CTR5]NBRSAL TITCL(1) For SALVAL
   Titcol [M:CTR5]NBRSAL TITCL(2) For SALVAL1
   Titcol [M:CTR5]NBRSAL TITCL(3) For SALVAL2
   Titcol [M:CTR5]NBRSAL TITCL(4) For SALRUB
   Titcol [M:CTR5]NBRSAL TITCL(5) For SALRUB1
   Titcol [M:CTR5]NBRSAL TITCL(6) For SALRUB2
  Endif
Endcase
Return

