End

$ON_NICAT
Onevent CONTROL Call C_NICAT(zc) From W5CTR5
Onevent BEFORE_INPUT Call AS_NICAT(zc) From W5CTR5
Return

Subprog AS_NICAT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_NICAT(zc) From W5CTR5
Onkey 144 Titled GBOUTP Call P_NICAT(zc) From W5CTR5
Onkey 146 Titled GBOUTA Call SA_NICAT(zc) From W5CTR5
Gosub _AFF
End

Subprog C_NICAT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NICAT" : GZNUM = 1000625 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("NIC","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "NICAT" : GZNUM = 1000625 : Endif
 If !mkstat
  ## Action STD
  Call C_NICAT(VALEUR) From SUBCTR
  If mkstat : GERR = 1 : GZONE = "NICAT" : GZNUM = 1000625 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_NICAT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "NIC"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_NICAT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "NIC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NICAT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("NIC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

