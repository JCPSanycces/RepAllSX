#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR5 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_MANNIENT
Onevent INIT_AREA Call D_MANNIENT(zc) From W5CTR5
Onevent BEFORE_INPUT Call AS_MANNIENT(zc) From W5CTR5
Return

Subprog D_MANNIENT(VALEUR)
Variable Integer VALEUR
If varinit([M]MANNIENT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_MANNIENT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

