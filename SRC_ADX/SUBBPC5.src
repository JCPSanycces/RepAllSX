#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque BPC5
########################################
Subprog AS_REPNUM(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AS_MAIREP(VALEUR)
Variable Char    VALEUR()
If [M:BPC5]MAIREP <> ""
    mkstat = 2
Endif
End

########################################
Subprog AM_MAIREP(VALEUR)
Variable Char    VALEUR()
If [M:BPC5]MAIREP <> VALEUR
    REPUPD = 1
Endif
End

########################################
Subprog AS_TLS(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End

########################################
Subprog C_NBLIG
Local Integer NUMLIGNE
#Effacement d'une seule ligne
If status = 65
    Read [RSE] RSE0 = SZBPCNUM;[M:BPC5]REPNUM(nolign - 1)
    If fstat = 0
        Call DEBTRANS From GLOCK
        Trbegin [RSE]
        Delete [RSE] Curr
        If fstat
            Rollback
            Affzo [M:BPC5]
            End
        Endif
        Commit
    Endif
Endif

#Effacement d'un groupe de lignes
If status = 68 | status = 83
For NUMLIGNE = nolign - 1 To nolign1 - 1
    Read [RSE] RSE0 = SZBPCNUM;[M:BPC5]REPNUM(NUMLIGNE)
    If fstat = 0
        Call DEBTRANS From GLOCK
        Trbegin [RSE]
        Delete [RSE] Curr
        If fstat
            Rollback
            Affzo [M:BPC5]
            Break
        Endif
        Commit
    Endif
Next
Endif
End

########################################
Subprog AS_NBLIG
If [M:BPC5]MAIREP = ""
    GMESSAGE = mess(202, 196, 2) #Vous devez saisir au moins un représentant principal
    GERR = 3
    mkstat = 2
    zonsui = "[M:BPC5]MAIREP"
Endif
End

