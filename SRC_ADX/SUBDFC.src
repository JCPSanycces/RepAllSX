#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ
GFLAG="1"
Call OBJET("DFC",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "LIENS"  : Gosub LIENS
 When "INIMOD" : Gosub INIMOD
 When "INICRE" : Gosub INICRE
 When "ANNULE" : Gosub ANNULE
 When "FILTRE" : Gosub FILTRE
 When "RAZCRE" : Gosub RAZCRE
 When "SETBOUT" : Gosub SETBOUT
 When "OUVRE"  : Gosub OUVRE
Endcase
Return

###############################
$OUVRE
If clalev ([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

###############################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

###############################
$SETBOUT
#Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR & VERROU : CHAINE+="A" : Endif
Return

###############################
$LIENS
# Multi_leg & multi_société
Call LECTURE("FCY",[M:DFC0]FCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
If dim([F:CPY]LEG)>0
  GCURLEG=[F:CPY]LEG
Endif

Gosub CHARGE
Return

###############################
$RAZCRE
[M:DFC0]FLGDNA=val(GFLAG)
Return

###############################
$INICRE
$INIMOD
[M:DFC0]FLGDNA=val(GFLAG)
[F:DFY]FLGDNA=val(GFLAG)
Gosub SAUVE
Return

###################################
$FILTRE
FILTSUP = "FLGDNA=val(GFLAG)"
Return

###############################
$CHARGE
#Prévoyance
nolign=0
For [F:DFP]DFP0 Where FCY=[F:DFY]FCY & YEA=[F:DFY]YEA & STRDAT=[F:DFY]STRDAT & ENDDAT=[F:DFY]ENDDAT & FLGDNA=[F:DFY]FLGDNA
 nolign+=1
 [M:DFC4]=[F:DFP]
Next
[M:DFC4]NBRPRV=nolign

#V08R09
#Cotisations
nolign=0
For [F:DFQ]DFQ0 Where FCY=[F:DFY]FCY & YEA=[F:DFY]YEA & STRDAT=[F:DFY]STRDAT & ENDDAT=[F:DFY]ENDDAT & FLGDNA=[F:DFY]FLGDNA
 nolign+=1
 [M:DFC4]=[F:DFQ]
Next
[M:DFC4]NBRCOT=nolign

#Retraite complémentaire
nolign=0
For [F:DFR]DFR0 Where FCY=[F:DFY]FCY & YEA=[F:DFY]YEA & STRDAT=[F:DFY]STRDAT & ENDDAT=[F:DFY]ENDDAT & FLGDNA=[F:DFY]FLGDNA
 nolign+=1
 [M:DFC2]=[F:DFR]
Next
[M:DFC2]NBRRET=nolign

#V08R10
If [M:DFC3]FLGAPP<>2
 Grizo [M:DFC3]BASAPP,FLGAPPSUP : Effzo[M:DFC3]BASAPP,FLGAPPSUP
Else
 Actzo [M:DFC3]BASAPP,FLGAPPSUP
Endif

If [M:DFC3]FLGFOR<>2
 Grizo [M:DFC3]BASFOR1,BASFOR2 : Effzo[M:DFC3]BASFOR1,BASFOR2
Else
 #Base formation prof. continue
 Actzo [M:DFC3]BASFOR1,BASFOR2
Endif

#V08R10
If [M:DFC3]FLGAPPSUP<>2
 Grizo [M:DFC3]AMTAPPSUP : Effzo[M:DFC3]AMTAPPSUP
Else
 Actzo [M:DFC3]AMTAPPSUP
Endif

Return

###############################
$SAUVE
#Prévoyance
Delete [DFP] Where FCY=[F:DFY]FCY & YEA=[F:DFY]YEA & STRDAT=[F:DFY]STRDAT & ENDDAT=[F:DFY]ENDDAT & FLGDNA=[F:DFY]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADFCY2" : Return
Endif
For nolign=1 To [M:DFC4]NBRPRV
 [F:DFP]=[M:DFC4]
 [F:DFP]YEA=[F:DFY]YEA
 [F:DFP]FCY=[F:DFY]FCY
 [F:DFP]STRDAT=[F:DFY]STRDAT
 [F:DFP]ENDDAT=[F:DFY]ENDDAT
 [F:DFP]FLGDNA=[F:DFY]FLGDNA
 [F:DFP]NUMLIG=nolign
 Write [DFP]
 If fstat<>0
  GOK = 0 : Call FSTA("DFP") From GLOCK : Break
 Endif
Next

#V08R09
#Cotisations
Delete [DFQ] Where FCY=[F:DFY]FCY & YEA=[F:DFY]YEA & STRDAT=[F:DFY]STRDAT & ENDDAT=[F:DFY]ENDDAT & FLGDNA=[F:DFY]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADFCY4" : Return
Endif
For nolign=1 To [M:DFC4]NBRCOT
 [F:DFQ]=[M:DFC4]
 [F:DFQ]YEA=[F:DFY]YEA
 [F:DFQ]FCY=[F:DFY]FCY
 [F:DFQ]STRDAT=[F:DFY]STRDAT
 [F:DFQ]ENDDAT=[F:DFY]ENDDAT
 [F:DFQ]FLGDNA=[F:DFY]FLGDNA
 [F:DFQ]NUMLIG=nolign
 Write [DFQ]
 If fstat<>0
  GOK = 0 : Call FSTA("DFQ") From GLOCK : Break
 Endif
Next

#Retraite Complémentaire
Delete [DFR] Where FCY=[F:DFY]FCY & YEA=[F:DFY]YEA & STRDAT=[F:DFY]STRDAT & ENDDAT=[F:DFY]ENDDAT & FLGDNA=[F:DFY]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADFCY3" : Return
Endif
For nolign=1 To [M:DFC2]NBRRET
 [F:DFR]=[M:DFC2]
 [F:DFR]YEA=[F:DFY]YEA
 [F:DFR]FCY=[F:DFY]FCY
 [F:DFR]STRDAT=[F:DFY]STRDAT
 [F:DFR]ENDDAT=[F:DFY]ENDDAT
 [F:DFR]FLGDNA=[F:DFY]FLGDNA
 [F:DFR]NUMLIG=nolign
 Write [DFR]
 If fstat<>0
  GOK = 0 : Call FSTA("DFR") From GLOCK : Break
 Endif
Next

Return

###############################
$ANNULE
Delete [F:DFR] Where FCY=[M:DFC0]FCY & YEA=[M:DFC0]YEA & STRDAT=[M:DFC0]STRDAT & ENDDAT=[M:DFC0]ENDDAT & FLGDNA=[M:DFC0]FLGDNA
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$DADFCY2" : Return
Endif

Delete [F:DFP] Where FCY=[M:DFC0]FCY & YEA=[M:DFC0]YEA & STRDAT=[M:DFC0]STRDAT & ENDDAT=[M:DFC0]ENDDAT & FLGDNA=[M:DFC0]FLGDNA
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$DADFCY3": Return
Endif

#V08R09
Delete [F:DFQ] Where FCY=[M:DFC0]FCY & YEA=[M:DFC0]YEA & STRDAT=[M:DFC0]STRDAT & ENDDAT=[M:DFC0]ENDDAT & FLGDNA=[M:DFC0]FLGDNA
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$DADFCY4" : Return
Endif

Return

############################################################################################################################
# Prévoyance
############################################################################################################################
Subprog C_CODPRV(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call UNICITE(VALEUR,[M:DFC4]CODPRV(0..[M:DFC4]NBRPRV-1)) From OBJDIV
 If mkstat=2 : End : Endif

 Read[F:ADI]CODE=340;VALEUR
 If !fstat & [F:ADI]A1="90000"
  GMESSAGE=mess(1,702,1) : #Valeur incorrecte
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_REFCTRFCY(VALEUR)
Variable Char    VALEUR()
Local Char VNUMAFF (50)
Local Char VNUMCTR (50)
Filter [F:ORG] Where NUMDCS=[M:DFC4]CODPRV(nolign-1) & LEG=GCURLEG
Read [F:ORG]ORG0 First
Filter [F:ORG]
If !fstat
 Call ORGAFFIL ([F:ORG]COD,[M:DFC0]FCY,"","",VNUMAFF,VNUMCTR) From SUBORA
 VALEUR=VNUMCTR
Endif
End

#V08R09
Subprog C_CODPRVFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call UNICITE(VALEUR,[M:DFC4]CODPRVFCY(0..[M:DFC4]NBRCOT-1)) From OBJDIV
 If mkstat=2 : End : Endif
 Read[F:ADI]CODE=340;VALEUR
 If !fstat & [F:ADI]A1="90000"
  GMESSAGE=mess(1,702,1) : #Valeur incorrecte
  mkstat=2 : End
 Endif
Endif
End

############################################################################################################################
# Retraite + BTP+ CNBF
############################################################################################################################


Subprog C_CODRET(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call UNICITE(VALEUR,[M:DFC2]CODRET(0..[M:DFC2]NBRRET-1)) From OBJDIV
 If mkstat=2 : End : Endif

 Read[F:ADI]CODE=340;VALEUR
 If !fstat & [F:ADI]A1="90000"
  GMESSAGE=mess(1,702,1) : #Valeur incorrecte
  mkstat=2 : End
 Endif

Endif
End

Subprog AM_FCY (VALEUR)
Variable Char    VALEUR()
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif

# Multi_leg & multi_société
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
If dim([F:CPY]LEG)>0
  GCURLEG=[F:CPY]LEG
Endif

Read[FCY]FCY0=VALEUR
#N4DS : Tous les sites doivent désormais être déclarer en S80 (Dads-u ou pas !)
If !fstat #& [F:FCY]DADFLG =2
 [M:DFC1]DADCRN=[F:FCY]CRN
 [M:DFC1]DADNAF=[F:FCY]NAF
 [M:DFC1]REGPRH=[F:FCY]REGPRH
 [M:DFC1]SECPRH=[F:FCY]SECPRH
Endif
Affzo [M:DFC1]
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran DFC2) 19/09/2007 16:06:57 (DBA)
######################################################################################

#V08R10
Subprog AM_FLGAPP(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Grizo [M:DFC3]BASAPP,FLGAPPSUP,AMTAPPSUP : Effzo[M:DFC3]BASAPP,FLGAPPSUP,AMTAPPSUP
Else
 Actzo [M:DFC3]BASAPP,FLGAPPSUP
Endif
End

Subprog AM_FLGFOR(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Grizo [M:DFC3]BASFOR1,BASFOR2 : Effzo[M:DFC3]BASFOR1,BASFOR2
Else
 Actzo [M:DFC3]BASFOR1,BASFOR2
Endif
End

Subprog AS_CODCNBFCY(VALEUR)
Variable Integer VALEUR
If [M:DFC1]DADNAF<>"6910Z"
  mkstat=1 : End
Endif
End

#V08R10
Subprog AM_FLGAPPSUP(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Grizo [M:DFC3]AMTAPPSUP : Effzo[M:DFC3]AMTAPPSUP
Else
 Actzo [M:DFC3]AMTAPPSUP
Endif
End

