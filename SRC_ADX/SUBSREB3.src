##########################################################################################################
# Gestion des composants
# Restauration de l'état avant l'entrée en modification sur la base de la photo prise.
#######################################################################
Subprog CPNABANDON(SZSRENUM, IERRINF)
Value Char SZSRENUM
Variable Integer IERRINF

  #CHECK FILE_DECLARE SREMACCPN [SRN2]
  IERRINF = 0
  #Supprime les enregistrement créés à tord au cours de la modif.
  Call DEBTRANS From GLOCK
  Trbegin [SRN]
  Delete [SRN] Where [F:SRN]SRENUM = SZSRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
  If fstat Then
    #Erreur lors de la restauration du cache abandon relatif aux composants concernés.
    IERRINF = 584
    Rollback
    End
  Else
    Commit
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [SRN]
  Filter [SRN2] Where [F:SRN2]SRENUM = SZSRENUM and [F:SRN2]TPYFLG = 0 and [F:SRN2]FGVCAH = 1
  For [SRN2]
    Raz [F:SRN]
    [F:SRN] = [F:SRN2]
    [F:SRN]FGVCAH = 0
    Write [SRN]
    If fstat Then
      #Erreur lors de la restauration du cache abandon relatif aux composants concernés.
      IERRINF = 584
      Break
    Endif
  Next
  Filter [SRN2]
  If IERRINF Then
    Rollback
    End
  Else
    Commit
  Endif
  Call CPNAPRESMOD(SZSRENUM, IERRINF)
  If IERRINF Then
    End
  Endif
End

##########################################################################################################
# Vérifie s'il est possible de rentrer en modification sur une demande de service.
############################################################
Subprog VERFAVANTMOD(SZCONTEXT, IUPDFLG, SZSRENUM, SZITN, SZITNNUM, IERRINF)
Value Char SZCONTEXT
Variable Integer IUPDFLG
Variable Char SZSRENUM
Value Char SZITN
Variable Char SZITNNUM
Variable Integer IERRINF

Local Char SZDVAPARAM

  IUPDFLG = 1
  IERRINF = 0
  SZITNNUM = ""
  SZDVAPARAM = "SRE" + SZSRENUM
  Read [DVA]DVA0="LCK";SZDVAPARAM
  If !fstat Then
    SZITNNUM = [F:DVA]ALHX(1)
    IUPDFLG = 0
    End
  Endif
  #On enregistre le lock
  Call DEBTRANS From GLOCK
  Trbegin [DVA]
  Raz [F:DVA]
  [F:DVA]OBC = "LCK"
  [F:DVA]PARAM = SZDVAPARAM
  [F:DVA]ALHX(0) = SZSRENUM
  [F:DVA]ALHX(1) = SZITN
  Write [DVA]
  If fstat Then
    Rollback
    If SZCONTEXT = "SRE" Then
      #Erreur lors du verrouillage de la demande de service. Modification impossible.
      IERRINF = 588
    Elsif SZCONTEXT = "ITN" Then
      #Erreur lors du verrouillage de l'intervention. Modification impossible.
      IERRINF = 591
    Endif
  Else
    Commit
  Endif
End

##########################################################################################################
# Libère le verrouillage d'une demande de service et d'une intervention
############################################################
Subprog FREELOCK(SZCONTEXT, SZSRENUM, IERRINF)
Value Char SZCONTEXT
Value Char SZSRENUM
Variable Integer IERRINF

Local Integer INTRANS
Local Char SZDVAPARAM

  IERRINF = 0
  If adxlog Then
    INTRANS = 1
  Else
    INTRANS = 0
  Endif
  SZDVAPARAM = "SRE" + SZSRENUM
  #On supprime le lock
  If !INTRANS Then
    Call DEBTRANS From GLOCK
    Trbegin [DVA]
  Endif
  Delete [DVA] Where [F:DVA]OBC = "LCK" and [F:DVA]PARAM = SZDVAPARAM
  If fstat Then
    If SZCONTEXT = "SRE" Then
      #Le déverrouillage de la demande de service a échoué.
      IERRINF = 589
    Elsif SZCONTEXT = "ITN" Then
      #Le déverrouillage de l'intervention a échoué.
      IERRINF = 590
    Endif
    If !INTRANS Then
      Rollback
    Endif
  Else
    If !INTRANS Then
      Commit
    Endif
  Endif
End

##########################################################################################################
# Vérifie s'il est possible d'activer le bouton créer d'une intervention
############################################################
Subprog VERFLOCK(IUPDFLG, SZSRENUM)
Variable Integer IUPDFLG
Variable Char SZSRENUM
IUPDFLG = 1

Local Char SZDVAPARAM

  SZDVAPARAM = "SRE" + SZSRENUM
  Read [DVA]DVA0="LCK";SZDVAPARAM
  If !fstat Then
    IUPDFLG = 0
    End
  Endif
End

##########################################################################################################
# Enregistrement des valeurs de couvertures précédentes
#######################################################################
Subprog PRECRMSRE1(SZSRENUM)
Value Char SZSRENUM

Local Integer ITER

  [M:SRE0]CRMSRE1FLG = 0
  Raz [M:SRE7]PRECOVFLG
  Raz [M:SRE7]PRECOVSPT
  Raz [M:SRE7]PRECOVVCR
  Raz [M:SRE2]PREOVRCOV
  Raz [M:SRE2]PRECOVNUM
  If SZSRENUM = "" Then
    End
  Endif
  [M:SRE2]PREOVRCOV = [M:SRE2]OVRCOV
  [M:SRE2]PRECOVNUM = [M:SRE2]SRECOVNUM
  For ITER = 0 To [M:SRE7]NBMAC-1
    [M:SRE7]PRECOVFLG(ITER) = [M:SRE7]COVFLG(ITER)
    [M:SRE7]PRECOVSPT(ITER) = [M:SRE7]COVSPT(ITER)
    [M:SRE7]PRECOVVCR(ITER) = [M:SRE7]COVVCR(ITER)
  Next
End

##########################################################################################################
# Nettoie les enregistrement de contrôle d'exécution de la session
#####################################################################
Subprog RAZPRONUM
Local Integer ITRANSFLG

  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 10/04/2015 : X3SUIVI107588 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  # -----------------------------------
  If adxlog Then
    ITRANSFLG = 1
  Else
    ITRANSFLG = 0
  Endif
  If !ITRANSFLG Then
    Trbegin [DVA]
  Endif
  Delete [DVA] Where [F:DVA]OBC = "PIT" and [F:DVA]INTX(0) = adxuid(1)
  If fstat Then
    If ITRANSFLG Then
      #La suppression des éléments de contrôle de la session a échoué.
      GMESSAGE = mess(635,182,1)
      GERR = 2
      Call FSTA("DVA") From GLOCK
      GOK = 0
    Else
      #La suppression des éléments de contrôle de la session a échoué.
      GMESSAGE = mess(635,182,1)
      GERR = 2
      Rollback
    Endif
  Else
    If !ITRANSFLG Then
      Commit
    Endif
  Endif
End

##########################################################################################################
# Alimentation du masque de sortie de stock
#######################################################################
$CHARGE_STOSOR
  #-----------------------------------------------------------------------#
  # Chargement des paramètres dans masque STOSOR pour saisie des sorties  #
  # Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSORA       #
  #-----------------------------------------------------------------------#
  [M:SOR]WSTOSEQ   = [M:SRE9]WSTOSEQ(LNOL)
  [M:SOR]TRSTYP    = 24
  [M:SOR]TRSCOD    = [M:SRE0]TRSCOD
  [M:SOR]TRFFCY    = ""
  [M:SOR]VCRNUM    = [M:SRE9]HDTNUM(LNOL)
  [M:SOR]VCRLIN    = 0
  [M:SOR]MVTDES    = [M:SRE9]MVTDES(LNOL)
  [M:SOR]STU       = [M:SRE9]HDTSTU(LNOL)
  [M:SOR]PCU       = [M:SRE9]HDTUOM(LNOL)
  [M:SOR]PCUSTUCOE = [M:SRE9]SAUSTUCOE(LNOL)
  [M:SOR]SORQTY    = [M:SRE9]HDTISSQTY(LNOL)
  [M:SOR]SORQTYACT = [M:SRE9]HDTISSQTY(LNOL)
  [M:SOR]RETDAT    = [M:SRE9]HDTDONDAT(LNOL)
  [M:SOR]DLVDAT    = [M:SRE9]HDTDONDAT(LNOL)
  # FGR 04/05/2015 : X3SUIVI105605 (début)
  If dim([M:SRE9]ECCVALMAJ) >= 0 Then
    [M:SOR]WECCVALMAJ = [M:SRE9]ECCVALMAJ(LNOL)
  Endif
  # FGR 04/05/2015 : X3SUIVI105605 (fin)
  [M:SOR]PECINTLOC = 2
  [M:SOR]PECPLFLOC = 2
  [M:SOR]PECSCOLOC = 1
  [M:SOR]PECQLYCTL = 1
  [M:SOR]STOLOC    = ""
  [M:SOR]XLOT      = ""
  [M:SOR]XLOC      = ""
  [M:SOR]XSTA      = ""
  # FGR 30/04/2008 : Ce champs n'existe plus en V6 sur SRE0
  #[M:SOR]CCECODS   = [M:SRE0]CCECODS
  [M:SOR]BPRNUM    = [M:SRE0]SREBPC
  [M:SOR]CUR       = [M:SRE8]SRECUR
  [M:SOR]GLOALLQTY = 0
  If dim([M:SRE9]WRH)>0 [M:SOR]XWRH=[M:SRE9]WRH(LNOL) Endif
Return

##########################################################################################################
# Mise à jour complémentaires après enregistrement
#######################################################################
$APRES_STOSOR
  If WGENR > 0 Then
    [M:SRE9]HDTISSISS(LNOL) = [M:SOR]PECQTY
    GSRE9HDTISSISS(LNOL) = [M:SOR]PECQTY
    GSRE9DIRTYISSISS(LNOL) = 1
  Endif
Return

##########################################################################################################
# Alimentation du masque de sortie de stock
#######################################################################
$CHARGE_STOSOM
  #-----------------------------------------------------------------------#
  # Chargement des paramètres dans masque STOSOR pour saisie des sorties  #
  # Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSORA       #
  #-----------------------------------------------------------------------#
  [M:SOM]TRSTYP    = 24
  [M:SOM]TRSCOD    = [M:SRE0]TRSCOD
  [M:SOM]TRFFCY    = ""
  [M:SOM]VCRNUM    = [M:SRE9]HDTNUM(LNOL)
  [M:SOM]VCRLIN    = 0
  [M:SOM]STU       = [M:SRE9]HDTSTU(LNOL)
  [M:SOM]PCU       = [M:SRE9]HDTUOM(LNOL)
  [M:SOM]PCUSTUCOE = [M:SRE9]SAUSTUCOE(LNOL)
  [M:SOM]SORQTY    = [M:SRE9]HDTISSQTY(LNOL)
  [M:SOM]SORQTYACT = [M:SRE9]HDTISSQTY(LNOL)
  [M:SOM]DLVDAT    = [M:SRE9]HDTDONDAT(LNOL)
  # FGR 04/05/2015 : X3SUIVI105605 (début)
  If dim([M:SRE9]ECCVALMAJ) >= 0 Then
    [M:SOM]WECCVALMAJ = [M:SRE9]ECCVALMAJ(LNOL)
  Endif
  # FGR 04/05/2015 : X3SUIVI105605 (fin)
  [M:SOM]PECINTLOC = 2
  [M:SOM]PECPLFLOC = 2
  [M:SOM]PECSCOLOC = 1
  [M:SOM]PECQLYCTL = 1
  [M:SOM]STOLOC    = ""
  [M:SOM]XLOT      = ""
  [M:SOM]XLOC      = ""
  [M:SOM]XSTA      = ""
  If dim([M:SRE9]WRH)>0 [M:SOM]XWRH=[M:SRE9]WRH(LNOL) Endif
Return

##########################################################################################################
# Mise à jour complémentaires après enregistrement
#######################################################################
#######################################################################
$APRES_STOSOM
Local Integer IAVERR
Local Integer SAVNOLIGN
Local Integer IHDTDONHOU

  # FGR 03/01/2011 : X3SUIVI78440
  IAVERR = 2
  If WGENR > 0 Then
    GSRE9HDTISSISS(LNOL) = [M:SOM]PECQTY
    GSRE9DIRTYISSISS(LNOL) = 1
    #
    [M:SRE9]HDTISSISS(LNOL) = [M:SOM]PECQTY
    If [M:SRE9]HDTISSISS(LNOL) = 0 Then
      [M:SRE9]HDTSTOISS(LNOL) = 1
      [M:SRE9]HDTISSQTY(LNOL) = 0
    Else
      If [M:SRE9]HDTSTUQTY(LNOL) <> [M:SOM]SORQTYACT Then
        # Mise en adéquation la quantité a sortir avec la quantité sortie
        [M:SRE9]HDTISSQTY(LNOL) = [M:SRE9]HDTISSISS(LNOL)
        [M:SRE9]HDTQTY(LNOL) = [M:SRE9]HDTISSISS(LNOL) / [M:SRE9]SAUSTUCOE(LNOL)
        [M:SRE9]HDTSTUQTY(LNOL) = [M:SRE9]HDTISSISS(LNOL)
        SAVNOLIGN = nolign
        nolign = LNOL + 1
        Call AM_HDTQTY([M:SRE9]HDTQTY(LNOL)) From SUBSRE
        nolign = SAVNOLIGN
      Endif
    Endif
    [M:SRE9]HDTDONDAT(LNOL) = date$
    #
    Call HOUTOSEC(val(left$(time$,2)), val(mid$(time$,4,2)), IHDTDONHOU) From CRMUTIL140
    [M:SRE9]HDTDONHOU(LNOL) = IHDTDONHOU
    Call SECTOHOU([F:HDT]HDTDONHOU, [M:SRE9]BHDTDONHOU(LNOL)) From CRMUTIL140
    #
    Affzo [M:SRE9]1-99
    Call SAVEHDT([M:SRE0]SRENUM) From SUBSREB1
    Call LOADTOTHDT(1) From SUBSREB1
    Call LOADTOTPIT(1) From SUBSREB1
  Endif
Return

#######################################################################
$OLDAPRES_STOSOM
Local Integer IAVERR

  IAVERR = 2
  If WGENR > 0 Then
    # FGR 14/10/2010 : X3SUIVI68217 (début)
    #Avertissement. La nouvelle quantité de stock à sortir n'est plus le reflet de la consommation associée.
    #If [M:SRE9]HDTSTUQTY(LNOL) <> [M:SOM]SORQTYACT Then
    #  Call AVERTIR(mess(153,177,1), IAVERR) From GESECRAN
    #Endif
    # FGR 14/10/2010 : X3SUIVI68217 (fin)
    GSRE9HDTISSISS(LNOL) = [M:SOM]PECQTY
    GSRE9DIRTYISSISS(LNOL) = 1
    Readlock [HDT]HDT0=[M:SRE9]HDTNUM(LNOL)
    If fstat Then
      GOK =  0
      Call RSTA ("HDT",[M:SRE9]HDTNUM(LNOL)) From GLOCK
      Return
    Else
      [F:HDT]HDTISSISS = [M:SOM]PECQTY
      # FGR 14/10/2010 : X3SUIVI68217 (début)
      If [F:HDT]HDTISSISS = 0 Then
        [F:HDT]HDTSTOISS = 1
        [F:HDT]HDTISSQTY = 0
      Else
        If [M:SRE9]HDTSTUQTY(LNOL) <> [M:SOM]SORQTYACT Then
          # Mise en adéquation la quantité a sortir avec la quantité sortie
          [F:HDT]HDTISSQTY = [F:HDT]HDTISSISS
          [F:HDT]HDTQTY = [F:HDT]HDTISSISS / [F:HDT]SAUSTUCOE
          [F:HDT]HDTSTUQTY = [F:HDT]HDTISSISS
        Endif
      Endif
      [F:HDT]HDTDONDAT = date$
      Call HOUTOSEC(val(left$(time$,2)), val(mid$(time$,4,2)), [F:HDT]HDTDONHOU) From CRMUTIL140
      # FGR 14/10/2010 : X3SUIVI68217 (fin)
      Rewrite [HDT]
      If fstat Then
        GOK =  0
        Call RSTA("HDT",[M:SRE9]HDTNUM(LNOL)) From GLOCK
        Return
      Else
        # FGR 14/10/2010 : X3SUIVI68217 (début)
        [M:SRE9]HDTSTOISS(LNOL) = [F:HDT]HDTSTOISS
        [M:SRE9]HDTISSISS(LNOL) = [F:HDT]HDTISSISS
        [M:SRE9]HDTISSQTY(LNOL) = [F:HDT]HDTISSQTY
        [M:SRE9]HDTQTY(LNOL)    = [F:HDT]HDTQTY
        [M:SRE9]HDTSTUQTY(LNOL) = [F:HDT]HDTSTUQTY
        [M:SRE9]HDTDONDAT(LNOL) = [F:HDT]HDTDONDAT
        Call SECTOHOU([F:HDT]HDTDONHOU, [M:SRE9]BHDTDONHOU(LNOL)) From CRMUTIL140
        # FGR 14/10/2010 : X3SUIVI68217 (fin)
        Affzo [M:SRE9]1-99
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Affichage des icônes
######################################################
$DISPICON
  Gosub DEFICONNUM From CRMUTIL150
  #Etat de la demande
  If [M:SRE2]SRESAT = "" Then
    [M:SRE0]ICOSAT = ""
  Else
    Read [ADI]CODE=422;[M:SRE2]SRESAT
    If fstat Then
      [M:SRE0]ICOSAT = ""
    Else
      [M:SRE0]ICOSAT = [F:ADI]A1
    Endif
  Endif
  #Niveau de gravité
  If [M:SRE2]SREGRALEV = "" Then
    [M:SRE0]ICOGRALEV = ""
  Else
    Read [ADI]CODE=428;[M:SRE2]SREGRALEV
    If fstat Then
      [M:SRE0]ICOGRALEV = ""
    Else
      [M:SRE0]ICOGRALEV = [F:ADI]A1
    Endif
  Endif
  If len([M:SRE1]SREFULDES) > GLONCLE Then
    If [M:SRE1]SREDESFLG Then
      [M:SRE1]SREDESICO = SZICOSYNDON
    Else
      [M:SRE1]SREDESICO = SZICOSYN
    Endif
    Actzo [M:SRE1]SREDESICO
  Else
    [M:SRE1]SREDESICO="-1"
    Grizo  [M:SRE1]SREDESICO
  Endif
Return

##########################################################################################################
Subprog DISPICON_BPC(ISTCTL)
Value Integer ISTCTL

  # FGR 15/02/2010 : X3SUIVI62427
  If ISTCTL = 3 Then
    If [M:SRE2]SREASS <> 5 Then
      [M:SRE0]ICOBPC = "151"
    Else
      [M:SRE0]ICOBPC = ""
    Endif
  Else
    [M:SRE0]ICOBPC = ""
  Endif
End

##########################################################################################################
#Affichage de l'interlocuteur
######################################################
$DISPCCN
  If [M:SRE0]SRECCN = "" Then
    [M:SRE0]SRECCNCLA = ""
  Else
    Read [AIN]AIN0=[M:SRE0]SRECCN
    If fstat Then
      [M:SRE0]SRECCNCLA = ""
    Else
      Call BUILDFULNAM("AIN", [M:SRE0]SRECCNCLA) From CRMUTIL140
    Endif
  Endif
Return

##########################################################################################################
#Enregistrement du CLOB description complète
######################################################
$SAVEHD1
Local Char SZCTLCLOB(250)

  Gosub DELHD1
  If GOK < 1 Then
    Return
  Endif
  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:SRE1]SREFULDES
  If SZCTLCLOB = "" Then
    Return
  Endif
  Raz [F:HD1]
  [F:HD1]NUM = [M:SRE1]NUMFULDES
  [F:HD1]TYP = [M:SRE1]TYPFULDES
  [F:HD1]CLOB = [M:SRE1]SREFULDES
  Write [HD1]
  If fstat Then
    #Erreur lors de l'enregistrement de la description complète de la demande. Transaction abandonnée.
    GMESSAGE = mess(836,182,1)
    GERR = 1
    Call FSTA("HD1") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
#Suppression du CLOB description complète
######################################################
$DELHD1
  Delete [HD1] Where [F:HD1]NUM = [M:SRE1]NUMFULDES and [F:HD1]TYP = [M:SRE1]TYPFULDES
  If fstat Then
    #Erreur lors de la suppression de la description complète de la demande. Transaction abandonnée.
    GMESSAGE = mess(839,182,1)
    GERR = 1
    Call FSTA("HD1") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB description complète
######################################################
$LOADHD1
  If [M:SRE1]NUMFULDES = "" Then
    Raz [M:SRE1]SREFULDES
    Return
  Endif
  If [M:SRE1]TYPFULDES = "" Then
    Raz [M:SRE1]SREFULDES
    Return
  Endif
  Read [HD1]HD10=[M:SRE1]NUMFULDES;[M:SRE1]TYPFULDES
  If fstat Then
    Raz [M:SRE1]SREFULDES
  Else
    [M:SRE1]SREFULDES = [F:HD1]CLOB
  Endif
Return

##########################################################################################################
# Supprime les enregistrements résiduels de la table HD7 (Plantage ou sortie intempestive)
####################################################################
$CLEANHD7
Local Integer STAT, I, J
Local Integer WADXUID(1..1000)
Local Integer WDIM
Local Integer WTRBEGIN : Raz WTRBEGIN
Local Integer IERRINFHD7

  IERRINFHD7 = 0
  If GHISTO = 1 Then
    #On est dans le dossier historique
    Return
  Endif
  Call UIDADX(WADXUID,WDIM) From TRTX3
  Raz I, J
  # Si pas de transaction en cours
  If adxlog <> 1 Then
    Trbegin [HD7]
    WTRBEGIN = 1
  Endif
  Filter [HD7] Where [F:HD7]PRONUM <> 0
  For [HD7]
    If !find([F:HD7]PRONUM,WADXUID(1..WDIM)) Then
      Delete [HD7] Curr
      If fstat Then
        IERRINFHD7 = 1
        Break
      Endif
    Endif
  Next
  Filter [HD7]
  # Si on a ouvert une transaction
  If WTRBEGIN = 1 Then
    If IERRINFHD7 Then
      Rollback
      Return
    Endif
  Endif
  # Si on a ouvert une transaction
  Delete [HD7] Where [F:HD7]PRONUM = adxuid(1)
  If fstat Then
    If WTRBEGIN = 1 Then
      IERRINFHD7 = 1
      Rollback
    Endif
  Else
    If WTRBEGIN = 1 Then
      Commit
    Endif
  Endif
  Raz WTRBEGIN
Return

##########################################################################################################
# Suppression des CLOBs sur Consommation SAV
######################################################
$DELTXC
  Filter [HDT] Where [F:HDT]SRENUM = [M:SRE0]SRENUM and [F:HDT]HDTSALTEX <> ""
  For [HDT] HDT1
    Delete [TXC] Where [F:TXC]CODE = [F:HDT]HDTSALTEX
    If fstat Then
      #Erreur lors de la suppression des textes relatifs aux consommations. Transaction abandonnée.
      GMESSAGE = mess(911,182,1)
      GERR = 1
      Call FSTA("TXC") From GLOCK
      GOK = 0
      Break
    Endif
  Next
  Filter [HDT]
Return

##########################################################################################################
# Suppression des réservations de ressources des interventions
######################################################
$DELITNRRS
Local Integer ZB

  If !clalev([F:RRS]) : Local File RESRES [RRS] : Endif
  Filter [ITN] Where [F:ITN]SRVDEMNUM = [M:SRE0]SRENUM
  For [ITN]
    For ZB = 0 To dim([F:ITN]RER)-1
      If [F:ITN]RER(ZB) <> "" Then
        Delete [RRS] Where [F:RRS]NUM = [F:ITN]RER(ZB)
        If fstat Then
          #Erreur lors de la suppression des réservations de ressources relatives aux interventions associées.
          GMESSAGE = mess(913,182,1)
          GERR = 1
          Call FSTA("RRS") From GLOCK
          GOK = 0
          Break
        Endif
      Endif
    Next
  Next
  Filter [ITN]
Return

##########################################################################################################
# Suppression des interventions d'une demande de service
######################################################
$DELITN
  Delete [ITN] Where [F:ITN]SRVDEMNUM = [M:SRE0]SRENUM
  If fstat Then
    #Erreur lors de la suppression des interventions associées à la demande de service. Transaction abandonnée.
    GMESSAGE = mess(914,182,1)
    GERR = 1
    Call FSTA("ITN") From GLOCK
    GOK = 0
  Endif
Return

##########################################################################################################
# Calcul une clé pour la table TXCCODE
######################################################
Subprog CPTTXC2KEY(SZTXCCODE, IERR)
Variable Char SZTXCCODE
Variable Integer IERR

Local Integer ISUFFIX

  IERR = 0
  SZTXCCODE = ""
  ISUFFIX = 1
  While 1
    SZTXCCODE = "HDT~" + num$(ISUFFIX)
    Read [TXC]TXC0=SZTXCCODE
    If fstat Then
      Break
    Else
      ISUFFIX += 1
    Endif
  Wend
End

##########################################################################################################
# Calcul une clé pour la table TXCCODE
######################################################
Subprog CPTTXCKEY(SZTXCCODE, IERR)
Variable Char SZTXCCODE
Variable Integer IERR

Local Integer T_OK
Local Integer ISUFFIX

  IERR = 0
  SZTXCCODE = ""
  Call NUM_TXC("HDT", ISUFFIX, T_OK) From TRTX3TEX
  SZTXCCODE = "HDT~" + format$("N0:8#",num$(ISUFFIX))
End

##########################################################################################################
# Suppression d'une facture de demande de service
######################################################
Subprog INVDELSRE(SZSRENUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If SZSRENUM = "" Then
    GOK = 0
    IBRETOUR = 0
    End
  Endif
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  Read [SRE]SRE0=SZSRENUM
  If fstat Then
    GOK = 0
    IBRETOUR = 0
    End
  Endif
  Readlock [SRE]SRE0=SZSRENUM
  If fstat Then
    IBRETOUR = 0
    Call FSTA("SRE") From GLOCK
    GOK = 0
    End
  Endif
  [F:SRE]SREINVFLG = 2
  [F:SRE]SREASS = 5
  Rewrite [SRE]
  If fstat Then
    IBRETOUR = 0
    Call FSTA("SRE") From GLOCK
    GOK = 0
    End
  Endif
  #Régénération des consommations à facturer
  Call FEEDHDI(SZSRENUM, IERRINF,ICHAPTER,IBRETOUR) From TRTFSOL
  If IBRETOUR = 0 Then
    GOK = 0
    End
  Endif
End

##########################################################################################################
# Remise à zéro de la dernière escalade
##############################################################
$RAZESC
  Raz [M:SRE2]SREESCCOD
  Raz [M:SRE2]SREESCNUM
  Raz [M:SRE2]SREESCCAT
  Raz [M:SRE2]SREESCDAT
  Raz [M:SRE2]SREESCHOU
  Raz [M:SRE2]SREESCTYP
  Raz [M:SRE2]ESCTYPCLA
  Raz [M:SRE2]ECETIT
Return

##########################################################################################################
# Chargement de la dernière escalade
##############################################################
$LOADESC
  Gosub RAZESC
  Filter [ECE] Where [F:ECE]SRENUM = [M:SRE0]SRENUM Order By [F:ECE]ESCDAT Desc; [F:ECE]ESCHOU Desc
  For [ECE] Hint Key ECE1
    If [M:SRE2]ECETIT = 0 Then
      [M:SRE2]SREESCCOD = [F:ECE]ESCCOD
      [M:SRE2]SREESCNUM = [F:ECE]ESCNUM
      [M:SRE2]SREESCCAT = [F:ECE]ESCCAT
      [M:SRE2]SREESCDAT = [F:ECE]ESCDAT
      [M:SRE2]SREESCHOU = [F:ECE]ESCHOU
      [M:SRE2]SREESCTYP = [F:ECE]ESCTYP
      If [M:SRE2]SREESCTYP > 0 Then
        [M:SRE2]ESCTYPCLA = mess([M:SRE2]SREESCTYP,3028,1)
      Endif
    Endif
    [M:SRE2]ECETIT += 1
  Next
  Filter [ECE]
Return

##########################################################################################################
# Exécution des escalades
###########################################################
Subprog DOESC(SZSRENUM, SZECECAT, IESCFLG, SZMESSAGE, IBRETOUR)
Value Char SZSRENUM
Value Char SZECECAT
Variable Integer IESCFLG
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Integer IEXECESC
Local Integer ITER
Local Integer ISREASS
Local Char SZSREDET
Local Char SZSALFCY
Local Char SZECECPTNUM
Local Char SZESCCOD
Local Integer IBDEBTRANSFLG

  Raz SZMESSAGE
  IBRETOUR = 1
  IESCFLG = 0
  #Si escalade uniquement par serveur batch, on ne fait rien si on est pas en batch
  If !GSERVEUR Then
    If GESCCTLMOD <> 2 Then
      End
    Endif
  Endif
  If SZSRENUM = "" Then
    #L'exécution des escalades n'a pas pu être déclenchée. Code de la demande de service non communiqué.
    SZMESSAGE = mess(939,182,1)
    IBRETOUR = 0
    End
  Endif
  Read [SRE]SRE0=SZSRENUM
  If fstat Then
    #L'exécution des escalades n'a pas pu être déclenchée. La demande de service n'a pas pu être lue.
    SZMESSAGE = mess(940,182,1)
    IBRETOUR = 0
    End
  Endif
  #Si la demande est clôturée, il n'y a plus de gestion d'escalade
  If [F:SRE]SREASS = 5 Then
    End
  Endif
  #------------------------------------------------------------#
  # --> Récupération du code compteur Escalades                #
  #------------------------------------------------------------#
  Read [TCA]TCA0=12
  If fstat Then
    #L'exécution des escalades n'a pas pu être déclenchée. Le compteur des escalades n'a pas pu être obtenu.
    #IERR = 946
    SZMESSAGE = mess(946,182,1)
    IBRETOUR = 0
    End
  Endif
  IEXECESC = 0
  ITER = 0
  SZESCCOD = ""
  ISREASS = [F:SRE]SREASS
  SZSREDET = [F:SRE]SREDET
  SZSALFCY = [F:SRE]SALFCY
  GMANCOU = [F:TCA]MANCOU(1)
  SZECECPTNUM = [F:TCA]CODNUM(13)
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [ECE]
  Endif
  If SZECECAT = "" Then
    Gosub BLANKCAT
  Else
    Gosub FILLEDCAT
  Endif
  If IBRETOUR = 0 Then
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
    End
  Endif
  #Enregistrement du nombre d'escalades subies par une demande de service
  If IESCFLG Then
    Readlock [SRE]SRE0=SZSRENUM
    If fstat Then
      #Erreur lors de l'exécution des escalades. La demande de service n'a pas pu être verrouillée.
      SZMESSAGE = mess(947,182,1)
      IBRETOUR = 0
    Else
      [F:SRE]SREESC = 0
      [F:SRE]SREESC2 = 0
      [F:SRE]SREESC3 = 0
      Filter [ECE] Where [F:ECE]SRENUM = SZSRENUM
      For [ECE] ECE1
        [F:SRE]SREESC += 1
        If [F:ECE]ESCTYP = 2 Then
          [F:SRE]SREESC2 += 1
        Elsif [F:ECE]ESCTYP = 3 Then
          [F:SRE]SREESC3 += 1
        Endif
      Next
      Filter [ECE]
      If type([M:SRE2]SREESC) > 0 Then
        [M:SRE2]SREESC = [F:SRE]SREESC
        [M:SRE2]SREESC2 = [F:SRE]SREESC2
        [M:SRE2]SREESC3 = [F:SRE]SREESC3
      Endif
      Rewrite [F:SRE]
      If fstat <> 0 Then
        #Erreur lors de l'exécution des escalades.
        SZMESSAGE = mess(938,182,1)
        IBRETOUR = 0
      Endif
    Endif
  Endif
  If IBDEBTRANSFLG = 0 Then
    If IBRETOUR = 0 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
$BLANKCAT
  Filter [PEC] Where [F:PEC]ENAFLG = 2
  For [PEC] Hint Key PEC1
    Gosub DOSREESC
    If IBRETOUR = 0 Then
      Break
    Endif
  Next
Return

##########################################################################################################
$FILLEDCAT
  Filter [PEC] Where [F:PEC]ENAFLG = 2 and [F:PEC]ESCCAT = SZECECAT
  For [PEC] Hint Key PEC1
    Gosub DOSREESC
    If IBRETOUR = 0 Then
      Break
    Endif
  Next
  Filter [PEC]
Return

##########################################################################################################
$DOSREESC
  IEXECESC = 0
  If [F:PEC]ESCCND = "" Then
    IEXECESC = 1
  Else
    Gosub PE_ESCCND From TRTCRMPE
  Endif
  If IEXECESC = 0 Then
    Return
  Endif
  For ITER = 0 To dim([F:PEC]ESCACTNUM)-1
    If [F:PEC]ESCACTNUM(ITER) <> "" Then
      Gosub PE_ESCACT From TRTCRMPE
      If GOK = 0 Then
        #Erreur lors de l'exécution des escalades.
        SZMESSAGE = mess(938,182,1)
        IBRETOUR = 0
        Break
      Endif
    Endif
  Next
  If IBRETOUR = 0 Then
    Return
  Endif
  #Enregistrement de l'historique de l'escalade
  If [F:PEC]ESCTYP > 1 Then
    IESCFLG = 1
    Gosub SAVEESCHISTO
  Endif
Return

##########################################################################################################
#Enregistrement d'un historique d'escalade
###########################################################
$SAVEESCHISTO
  Call SETECENUM(SZSALFCY, SZECECPTNUM, SZESCCOD, SZMESSAGE, IBRETOUR)
  If IBRETOUR = 0 Then
    Return
  Endif
  Raz [F:ECE]
  [F:ECE] = [F:PEC]
  [F:ECE]ESCCOD = SZESCCOD
  [F:ECE]ESCDAT = date$
  [F:ECE]ESCHOU = left$(time$, 2) + mid$(time$, 4, 2)
  [F:ECE]SREASS = ISREASS
  [F:ECE]SREDET = SZSREDET
  [F:ECE]SRENUM = SZSRENUM
  [F:ECE]CREDAT = date$
  [F:ECE]CREUSR = GUSER
  Write [ECE]
  If fstat <> 0 Then
    #Erreur lors de la création d'un historique d'escalade.
    SZMESSAGE = mess(941,182,1)
    IBRETOUR = 0
  Endif
Return

##########################################################################################################
# Calcul un code chrono pour la création d'une escalade
################################################################
Subprog SETECENUM(SZSALFCY, SZECECPTNUM, SZECENUM, SZMESSAGE, IBRETOUR)
Value Char SZSALFCY
Value Char SZECECPTNUM
Variable Char SZECENUM
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Integer IERR

  Raz SZMESSAGE
  IBRETOUR = 1
  IERR = 0
  Call NUMERO(SZECECPTNUM, SZSALFCY, date$, "", SZECENUM, IERR) From SUBANM
  If IERR Then
    #Erreur lors de la génération du code chrono des escalades.
    SZMESSAGE = mess(945,182,1)
    IBRETOUR = 0
    GOK = 0
  Endif
End

##########################################################################################################
# Crée la tache batch d'exécution des escalades
###########################################################################
Subprog CREABTESC
  If !clalev([F:ABT]) : Local File ABATTAC [ABT] : Endif
  Read [ABT]CODTAC="CRMESC"
  If !fstat Then
    End
  Endif
  [F:ABT]CODTAC = "CRMESC"               #Code tâche
  [F:ABT]CREDAT = date$                  #Date de création
  [F:ABT]CREUSR = GUSER                  #Créé par
  [F:ABT]DES = 23985                     #Intitulé
  [F:ABT]DOSPAR = ""
  [F:ABT]ENAFLG = 2                      #Actif
  [F:ABT]FONCTION = "FUNPEC2"            #Fonction
  [F:ABT]MESSAGE = 1                     #Message utilisateur
  [F:ABT]MODULE = 12                     #Module Support client
  [F:ABT]MONO = 1                        #Mono-utilisateur
  [F:ABT]MULTIDOS = 1                    #Multi-dossier
  [F:ABT]NIVEAU = 0                      #Niveau autorisation
  [F:ABT]PARAM = ""                      #Paramètre
  [F:ABT]PRIO = 0                        #Priorité
  [F:ABT]PROGPAR = ""                    #Programme paramètre
  [F:ABT]SERVICE = ""                    #Service
  [F:ABT]TIMOUT = ""                     #Time-out
  [F:ABT]TRAIT = ""                      #Code traitement
  [F:ABT]TYPTAC = 1                      #Type de tâche
  Write [ABT]
  If fstat <> 0 Then
    #Erreur lors de la création de la tâche batch CRMESC
    GMESSAGE = mess(459,177,1)
    GERR = 1
    GOK = 0
  Endif
End

##########################################################################################################
# Gestion de la création des horodatages en action RAZCRE et LIENS
######################################################
$RESETSCH
  Raz [M:SCH0]
  Transmask [M:SRE0] To [M:SCH0]
  Raz [M:SCH2]
  Transmask [M:SRE2] To [M:SCH2]
  Raz [M:SCH7] # Issue X3-35454 - 2017-05-03 by FGR : Raz [M:SCH0] is wrong here
  Transmask [M:SRE7] To [M:SCH7]
  Raz [M:SCH9] # Issue X3-35454 - 2017-05-03 by FGR : Raz [M:SCH0] is wrong here
  Transmask [M:SRE9] To [M:SCH9]
Return

##########################################################################################################
# Défini le grisage des champs en fonction du statut clôturé d'une demande
########################################################
$SETGRAY
  If [M:SRE2]SREASS = 5 Then
    Grizo [M:SRE0]SRENUMBPC
    Grizo [M:SRE0]SALFCY
    Diszo [M:SRE0]SREBPC
    Grizo [M:SRE2]OVRCOV
    Grizo [M:SRE2]CONSPT
    Grizo [M:SRE2]TIMSPGDAY
    Grizo [M:SRE2]TIMSPGHOU
    Grizo [M:SRE2]TIMSPGMNT

    Grizo [M:SRE8]5
    Grizo [M:SRE8]10
    Grizo [M:SRE8]20

    Grizo [M:SRE7]

    Grizo [M:SRE9]5
    If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
      # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
      Grizo [M:SRE9]TOTPIT
    Endif
  Else
    If GSRENUMAUT = 2 Then
      Grizo [M:SRE0]SRENUMBPC
    Else
      Actzo [M:SRE0]SRENUMBPC
    Endif
    # FGR 16/01/2009 : X3SUIVI51728 : complément X3SUIVI46583
    # FGR 12/04/2011 : X3SUIVI71405 : Même chose s'il y a des parc ou des composants
    #If [M:SRE9]NBLIG > 0 Then
    If [M:SRE9]NBLIG > 0 or [M:SRE7]NBMAC > 0  or [M:SRE7]NBCPN > 0 Then
      Diszo [M:SRE0]SALFCY   # FGR 12/04/2011 : X3SUIVI71405 : Grizo
      # FGR 27/03/2008 : X3SUIVI46583 : S'il y a des consommation, le client ne peut être modifié
      Diszo [M:SRE0]SREBPC   # FGR 12/04/2011 : X3SUIVI71405 : Grizo
    Else
      Actzo [M:SRE0]SALFCY
      Actzo [M:SRE0]SREBPC
    Endif
    Actzo [M:SRE2]OVRCOV
    Actzo [M:SRE2]CONSPT
    If GISRE2TIMFLG Then
      Diszo [M:SRE2]TIMSPGDAY
      Diszo [M:SRE2]TIMSPGHOU
      Diszo [M:SRE2]TIMSPGMNT
    Else
      Actzo [M:SRE2]TIMSPGDAY
      Actzo [M:SRE2]TIMSPGHOU
      Actzo [M:SRE2]TIMSPGMNT
    Endif
    Actzo [M:SRE8]5
    Actzo [M:SRE8]10
    Actzo [M:SRE8]20
    If [M:SRE9]NBLIG > 0 Then
      # FGR 16/01/2009 : X3SUIVI51728 : complément X3SUIVI46583
      Grizo [M:SRE8]SRECUR
    Endif
    Actzo [M:SRE7]
    If [M:SRE7]TYPMAC = 1 Then
      [M:SRE7]MACFLT = ""
      [M:SRE7]MACFLTINT = 2
      Grizo [M:SRE7]MACFLT
      Grizo [M:SRE7]MACFLTINT
    Endif
    Actzo [M:SRE9]5
    If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
      # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
      Diszo [M:SRE9]TOTPIT
    Endif
  Endif
Return

##########################################################################################################
# Ouverture des ressources nécessaires à la gestion des sorties de stock
#######################################################################
$SETSTORES
  If !clalev([F:ITF])  Local File ITMFACILIT [ITF]   Endif
  If !clalev([F:TRU])  Local File TABALLRUL  [TRU]   Endif
  If !clalev([F:SRU])  Local File TABSTORUL  [SRU]   Endif
  If !clalev([F:SWW])  Local File STOWIPW    [SWW]   Endif
  If !clalev([M:ALP])  Local Mask ALLPAR     [ALP]   Endif
  If !clalev([M:SOW])  Local Mask STOSORW    [SOW]   Endif
  If !clalev([M:STW])  Local Mask STOWORK    [STW]   Endif
  If !clalev([M:SVW])  Local Mask STOVALWORK [SVW]   Endif
  If GWRHACT=2
    If !clalev([F:WRH])  Local File WAREHOUSE  [WRH]   Endif
    If !clalev([F:ITW])  Local File ITMWRH     [ITW]   Endif
  Endif
Return

##########################################################################################################
Subprog VERIF_SRE_COV(SSOHNUM, SMESSAGE)
Value Char SSOHNUM
Variable Char SMESSAGE

Local Char SSRELIST(250)
Local Integer ICOUNT

  # FGR 29/04/2013 : X3SUIVI89648
  If GMODU(12) = G_YES Then
    Raz SMESSAGE
    Raz SSRELIST
    ICOUNT = 0
    If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
    Filter [F:SRE] Where [F:SRE]OVRCOV = 5 and [F:SRE]SRECOVNUM = SSOHNUM
    For [F:SRE]
      If SSRELIST <> "" Then
        SSRELIST += ","
      Endif
      SSRELIST -= [F:SRE]SRENUM
      ICOUNT += 1
    Next
    Filter [F:SRE]
    If ICOUNT > 0 Then
      If ICOUNT = 1 Then
        SMESSAGE = mess(1136,196,1) - SSRELIST + "." - mess(1137,196,1)
      Else
        SMESSAGE = mess(1138,196,1) - SSRELIST + "." - mess(1139,196,1)
      Endif
    Endif
  Endif
End

##########################################################################################################
# Sélection d'une commande de vente pour assurer la couverture globale d'une demande de service
#########################################################################
$SELECTSOH
  If type(GSZSRECXT) > 0 Then
    If GSZSRECXT = "OVRCOVSOH" Then
      If type(GSZSRECON) > 0 Then
        If GSZSRECON <> [M:SOH0]SOHNUM Then
          If [M:SOH0]SOHNUM <> "" Then
            If [M:SRE2]SREASS < 4 Then
              If [M:SRE2]OVRCOV = 5 Then
                If [M:SRE0]SREGREP = "" and [M:SRE0]SRENUM = "" Then
                  Return
                Else
                  Gosub SLTSOH
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$SLTSOH
Local Integer ISREASK
Local Char SZGREP
Local Char SZSRENUM
Local Integer ICOVSPT
Local Char SZCOVVCR
Local Integer ISLOCKED

  ICOVSPT = 2
  SZCOVVCR = [M:SOH0]SOHNUM
  SZSRENUM = ""
  ISREASK = 0
  SZGREP = [M:SRE0]SREGREP
  #Demande si on doit modifier le contrat couvrant la demande.
  #Souhaitez-vous couvrir la demande de service avec la nouvelle commande sélectionnée ?
  Call OUINON(mess(333,182,1), ISREASK) From GESECRAN
  If ISREASK = 2 Then
    If GREP = "" Then
      #Vérification du lock superviseur
      ISLOCKED = 0
      Call ISAOBLOCKED([M:SRE0]SRESYM, ISLOCKED) From CRMUTIL140
      If ISLOCKED Then
        #Modification en cours sur un autre poste.
        GMESSAGE = mess(10,100,1)
        GERR = 2
        Return
      Endif
    Endif
    Gosub AVMCTLLOCKSRE From SUBSREA
    If !IUPDSRE Then
      Return
    Endif
    #On modifie la commande couvrant la demande.
    If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
    If !clalev([F:SRM]) : Local File SREMAC [SRM] : Endif
    If !clalev([F:SRN]) : Local File SREMACCPN [SRN] : Endif
    Call DEBTRANS From GLOCK
    If SZGREP = "C" Then
      Trbegin [SRN]
    Elsif SZGREP = "D"
      Trbegin [SRN]
    Else
      If SZGREP = "" Then
        Trbegin [SRE], [SRN], [SRM]
      Else
        Trbegin [SRN]
      Endif
    Endif
    #MAJ de la couverture globale
    If SZGREP = "C" Then
      Gosub SLTSOH4
    Elsif SZGREP = "D"
      Gosub SLTSOH4
    Else
      SZSRENUM = [M:SRE0]SRENUM
      If SZGREP = "" Then
        Gosub SLTSOH3
        Gosub SLTSOH4
      Else
        Gosub SLTSOH4
      Endif
    Endif
    If GERR Then
      Rollback
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Return
    Endif
    #MAJ de la couverture parc
    Gosub SLTSOH2
    If GERR Then
      Rollback
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Return
    Else
      Commit
    Endif
    GSZSRECXT = ""
    Gosub AFFSRE2MIS From SUBSREB2
    Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    Affzo [M:SRE2]1-99
  Endif
Return

##########################################################################################################
# Mise à jour de la demande depuis SELECTSOH
#########################################################################
$SLTSOH2
Local Integer IAFFSRE7
Local Integer ITERMAC

  IAFFSRE7 = 0
  #Couverture parc
  If [M:SRE7]NBMAC > 0 Then
    If SZGREP = "" Then
      IAFFSRE7 = 1
      ITERMAC = 0
      Filter [SRM] Where [F:SRM]SRENUM = [M:SRE0]SRENUM
      For [SRM]
        #Couverte par commande de vente
        [F:SRM]COVFLG = 1
        [F:SRM]COVSPT = 2
        [F:SRM]COVVCR = [M:SOH0]SOHNUM
        Rewrite [SRM]
        If fstat Then
          #Erreur lors de la mise à jour de la couverture sur le parc concerné.
          GMESSAGE = mess(566,182,1)
          GERR = 1
          Break
        Endif
        #Mise à jour de la couverture sur les composants
        Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM = [F:SRM]MACNUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
        For [SRN]
          #Couverte par commande de vente
          [F:SRN]CPNCOVFLG = 1
          [F:SRN]CPNCOVSPT = 2
          [F:SRN]CPNCOVVCR = [M:SOH0]SOHNUM
          Rewrite [SRN]
          If fstat Then
            #Erreur lors de la mise à jour de la couverture sur les composants concernés.
            GMESSAGE = mess(565,182,1)
            GERR = 1
            Break
          Endif
        Next
        Filter [SRN]
        If GERR Then
          Break
        Endif
      Next
      Filter [SRM]
    Else
      If SZGREP = "C" or SZGREP = "D" Then
        IAFFSRE7 = 1
        For ITERMAC = 0 To [M:SRE7]NBMAC-1
          #Couverte par commande de vente
          [M:SRE7]COVFLG(ITERMAC) = 1
          [M:SRE7]COVSPT(ITERMAC) = 2
          [M:SRE7]COVVCR(ITERMAC) = [M:SOH0]SOHNUM
          #Mise à jour de la couverture sur les composants
          Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]MACNUM = [M:SRE7]MAC(ITERMAC) and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
          For [SRN]
            #Couverte par commande de vente
            [F:SRN]CPNCOVFLG = 1
            [F:SRN]CPNCOVSPT = 2
            [F:SRN]CPNCOVVCR = [M:SOH0]SOHNUM
            Rewrite [SRN]
            If fstat Then
              #Erreur lors de la mise à jour de la couverture sur les composants concernés.
              GMESSAGE = mess(565,182,1)
              GERR = 1
              Break
            Endif
          Next
          Filter [SRN]
          If GERR Then
            Break
          Endif
        Next
      Else
        IAFFSRE7 = 1
        For ITERMAC = 0 To [M:SRE7]NBMAC-1
          #Couverte par commande de vente
          [M:SRE7]COVFLG(ITERMAC) = 1
          [M:SRE7]COVSPT(ITERMAC) = 2
          [M:SRE7]COVVCR(ITERMAC) = [M:SOH0]SOHNUM
          #Mise à jour de la couverture sur les composants
          Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM = [M:SRE7]MAC(ITERMAC) and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
          For [SRN]
            #Couverte par commande de vente
            [F:SRN]CPNCOVFLG = 1
            [F:SRN]CPNCOVSPT = 2
            [F:SRN]CPNCOVVCR = [M:SOH0]SOHNUM
            Rewrite [SRN]
            If fstat Then
              #Erreur lors de la mise à jour de la couverture sur les composants concernés.
              GMESSAGE = mess(565,182,1)
              GERR = 1
              Break
            Endif
          Next
          Filter [SRN]
          If GERR Then
            Break
          Endif
        Next
      Endif
    Endif
  Endif
  If GERR Then
    Return
  Endif
  If SZGREP = "" Then
    If IAFFSRE7 Then
      Gosub SRE7MAC From SUBSREB1
    Endif
  Else
    If SZGREP = "C" or SZGREP = "D" Then
      If IAFFSRE7 Then
        Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 1) From SUBSREB1
        Affzo [M:SRE7]1-99
      Endif
    Else
      If IAFFSRE7 Then
        Call LOADCPN([M:SRE0]SRENUM, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 0) From SUBSREB1
        Affzo [M:SRE7]1-99
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Mise à jour d'une demande de service déjà créée
#########################################################################
$SLTSOH3
  Read [SRE]SRE0=SZSRENUM
  If fstat Then
    #Erreur lors de la modification de la commande couvrant la demande de service.
    # Transaction abandonnée.
    GMESSAGE = mess(334,182,1)
    GERR = 1
    Return
  Endif
  [F:SRE]SRECOVNUM = [M:SOH0]SOHNUM
  [F:SRE]OVRCOVTYP = ""
  [F:SRE]CONSPT = ""
  [F:SRE]CONSPTTYP = ""
  [F:SRE]CONSPTFLG = 1
  [F:SRE]MANUPD = 2
  #Obtient le niveau de réactivité SAV.
  Call SETRESDAT([F:SRE]CREDAT, [F:SRE]CREHOU, [F:SRE]CONSPT, "", [F:SRE]SREGRALEV, 1, [F:SRE]SRERESDAT, [F:SRE]SRERESHOU) From TRTCOVER
  Rewrite [SRE]
  If fstat Then
    #Erreur lors de la modification de la commande couvrant la demande de service.
    GMESSAGE = mess(334,182,1)
    GERR = 1
    Return
  Endif
Return

##########################################################################################################
#Mise à jour d'une demande de service déjà en cours de création ou de modification
#########################################################################
$SLTSOH4
  [M:SRE2]SRECOVNUM = [M:SOH0]SOHNUM
  [M:SRE2]CONSPTCLA = ""
  [M:SRE2]CONSPT = ""
  [M:SRE2]CONSPTTYP = ""
  [M:SRE2]CONSPTFLG = 1
  [M:SRE2]MANUPD = 2
  #Obtient le niveau de réactivité SAV.
  Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, "", [M:SRE2]SREGRALEV, 1, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
Return

##########################################################################################################
# Sélection d'un contrat de service pour assurer la couverture globale d'une demande de service
#########################################################################
$SELECTCON
  If type(GSZSRECXT) > 0 Then
    If GSZSRECXT = "OVRCOVCON" Then
      If type(GSZSRECON) > 0 Then
        If GSZSRECON <> [M:CON0]CONNUM Then
          If [M:CON0]CONNUM <> "" Then
            If [M:SRE2]SREASS < 4 Then
              If [M:SRE2]OVRCOV = 4 Then
                If [M:SRE0]SREGREP = "" and [M:SRE0]SRENUM = "" Then
                  Return
                Else
                  Gosub SLTCON
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$SLTCON
Local Integer IERRINF
Local Integer ISREASK
Local Char SZGREP
Local Char SZSRENUM
Local Integer ICOVSPT
Local Char SZCOVVCR
Local Integer ISLOCKED

  ICOVSPT = 1
  SZCOVVCR = [M:CON0]CONNUM
  SZSRENUM = ""
  ISREASK = 0
  SZGREP = [M:SRE0]SREGREP
  #Demande si on doit modifier le contrat couvrant la demande.
  ISREASK = 0
  #Souhaitez-vous couvrir la demande de service avec le nouveau contrat sélectionné ?
  Call OUINON(mess(828,196,1), ISREASK) From GESECRAN
  If ISREASK = 2 Then
    If GREP = "" Then
      #Vérification du lock superviseur
      ISLOCKED = 0
      Call ISAOBLOCKED([M:SRE0]SRESYM, ISLOCKED) From CRMUTIL140
      If ISLOCKED Then
        #Modification en cours sur un autre poste.
        GMESSAGE = mess(10,100,1)
        GERR = 2
        Return
      Endif
    Endif
    Gosub AVMCTLLOCKSRE From SUBSREA
    If !IUPDSRE Then
      Return
    Endif
    #On modifie la commande couvrant la demande.
    If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
    If !clalev([F:SRM]) : Local File SREMAC [SRM] : Endif
    If !clalev([F:SRN]) : Local File SREMACCPN [SRN] : Endif
    If !clalev([F:HDT]) : Local File HDKTASK [HDT] : Endif
    Call DEBTRANS From GLOCK
    If SZGREP = "C" Then
      Trbegin [SRN]
    Elsif SZGREP = "D"
      Trbegin [SRN]
    Else
      If SZGREP = "" Then
        Trbegin [SRE], [SRN], [SRM], [HDT]
      Else
        Trbegin [SRN]
      Endif
    Endif
    #MAJ de la couverture globale
    If SZGREP = "C" Then
      Gosub SLTCON4
    Elsif SZGREP = "D"
      Gosub SLTCON4
    Else
      SZSRENUM = [M:SRE0]SRENUM
      If SZGREP = "" Then
        Gosub SLTCON3
        Gosub SLTCON4
      Else
        Gosub SLTCON4
      Endif
    Endif
    If GERR Then
      Rollback
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Return
    Endif
    #MAJ de la couverture parc
    Gosub SLTMAC
    If GERR Then
      Rollback
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Return
    Endif
    #MAJ des montants facturables
    Gosub SLTHDT
    If GERR Then
      Rollback
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Return
    Else
      Commit
    Endif
    GSZSRECXT = ""
    Gosub AFFSRE2MIS From SUBSREB2
    Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    Affzo [M:SRE2]1-99
  Endif
Return

##########################################################################################################
#Mise à jour d'une demande de service déjà en cours de création ou de modification
#########################################################################
$SLTCON4
  [M:SRE2]OVRCOVTYP = "CON"
  [M:SRE2]SRECOVNUM = [M:CON0]CONNUM
  [M:SRE2]SRECOVAUT = 0
  #Contrat défini manuellement.
  [M:SRE2]CONSPTCLA = mess(302,182,1)
  [M:SRE2]CONSPT = [M:CON0]CONNUM
  [M:SRE2]CONSPTTYP = "CON"
  [M:SRE2]CONSPTFLG = 1
  [M:SRE2]MANUPD = 2
  #Obtient le niveau de réactivité SAV.
  Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:CON0]CONNUM, "CON", [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
Return

##########################################################################################################
#Mise à jour d'une demande de service déjà créée
#########################################################################
$SLTCON3
  Read [SRE]SRE0=SZSRENUM
  If fstat Then
    #Erreur lors de la modification de la commande couvrant la demande de service.
    # Transaction abandonnée.
    GMESSAGE = mess(334,182,1)
    GERR = 1
    Return
  Endif
  [F:SRE]OVRCOVTYP = "CON"
  [F:SRE]SRECOVNUM = [M:CON0]CONNUM
  [F:SRE]SRECOVAUT = 0
  [F:SRE]CONSPT = [M:CON0]CONNUM
  [F:SRE]CONSPTTYP = "CON"
  [F:SRE]CONSPTFLG = 1
  [F:SRE]MANUPD = 2
  #Obtient le niveau de réactivité SAV.
  Call SETRESDAT([F:SRE]CREDAT, [F:SRE]CREHOU, [M:CON0]CONNUM, "CON", [F:SRE]SREGRALEV, 0, [F:SRE]SRERESDAT, [F:SRE]SRERESHOU) From TRTCOVER
  Rewrite [SRE]
  If fstat Then
    #Erreur lors de la modification de la commande couvrant la demande de service.
    GMESSAGE = mess(334,182,1)
    GERR = 1
    Return
  Endif
Return

##########################################################################################################
# Mise à jour de la couverture parc de la demande
#########################################################################
$SLTMAC
Local Integer IAFFSRE7
Local Integer ITERMAC
Local Integer ITERCPN
Local Integer ICOVFLG
Local Integer ICOVSPT
Local Char SZCOVVCR
Local Integer ISAVPRESRE7NOL

  IAFFSRE7 = 0
  ICOVFLG = 0
  ICOVSPT = 0
  SZCOVVCR = ""
  ISAVPRESRE7NOL = [M:SRE7]PRESRE7NOL
  IERRINF = 0
  #Couverture parc
  If [M:SRE7]NBMAC > 0 Then
    If SZGREP = "" Then
      IAFFSRE7 = 1
      For ITERMAC = 0 To [M:SRE7]NBMAC-1
        #Recalcul de la couverture sur la base du contrat sélectionné
        Call COVERMCON(ITERMAC, [M:SRE7]MAC(ITERMAC), [M:CON0]CONNUM, IERRINF) From TRTCOVER
        If IERRINF Then
          #Erreur lors de la mise à jour de la couverture sur le parc concerné.
          GMESSAGE = mess(566,182,1)
          GERR = 1
          Break
        Endif
        Readlock [SRM]SRM1=[M:SRE0]SRENUM;[M:SRE7]MAC(ITERMAC)
        If fstat Then
          #Erreur lors de la mise à jour de la couverture sur le parc concerné.
          GMESSAGE = mess(566,182,1)
          GERR = 1
          Break
        Else
          [F:SRM]COVFLG = [M:SRE7]COVFLG(ITERMAC)
          [F:SRM]COVSPT = [M:SRE7]COVSPT(ITERMAC)
          [F:SRM]COVVCR = [M:SRE7]COVVCR(ITERMAC)
          Rewrite [SRM]
          If fstat Then
            #Erreur lors de la mise à jour de la couverture sur le parc concerné.
            GMESSAGE = mess(566,182,1)
            GERR = 1
            Break
          Else
            Unlock [SRM]
          Endif
        Endif
        #Chargement des composant du parc modifié
        [M:SRE7]PRESRE7NOL = ITERMAC
        Call LOADCPN([M:SRE0]SRENUM, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 0) From SUBSREB1
        For ITERCPN = 0 To [M:SRE7]NBCPN-1
          Call COVERMCCON(ITERCPN, [M:SRE7]PRESRE7NOL, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), [M:SRE7]CPNITM(ITERCPN), [M:CON0]CONNUM, IERRINF) From TRTCOVER
          If IERRINF Then
            #Erreur lors de la mise à jour de la couverture sur le parc concerné.
            GMESSAGE = mess(566,182,1)
            GERR = 1
            Break
          Endif
          #Mise à jour de la couverture sur les composants
          Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 0
&                        and [F:SRN]FGVCAH = 0 and [F:SRN]CPNITM = [M:SRE7]CPNITM(ITERCPN)
          For [SRN]
            [F:SRN]CPNCOVFLG = [M:SRE7]CPNCOVFLG(ITERCPN)
            [F:SRN]CPNCOVSPT = [M:SRE7]CPNCOVSPT(ITERCPN)
            [F:SRN]CPNCOVVCR = [M:SRE7]CPNCOVVCR(ITERCPN)
            Rewrite [SRN]
            If fstat Then
              #Erreur lors de la mise à jour de la couverture sur les composants concernés.
              GMESSAGE = mess(565,182,1)
              GERR = 1
              Break
            Endif
          Next
          Filter [SRN]
          If GERR Then
            Break
          Endif
        Next
        If GERR Then
          Break
        Endif
      Next
    Else
      If SZGREP = "C" or SZGREP = "D" Then
        IAFFSRE7 = 1
        For ITERMAC = 0 To [M:SRE7]NBMAC-1
          #Recalcul de la couverture sur la base du contrat sélectionné
          Call COVERMCON(ITERMAC, [M:SRE7]MAC(ITERMAC), [M:CON0]CONNUM, IERRINF) From TRTCOVER
          If IERRINF Then
            #Erreur lors de la mise à jour de la couverture sur le parc concerné.
            GMESSAGE = mess(566,182,1)
            GERR = 1
            Break
          Endif
          #Chargement des composant du parc modifié
          [M:SRE7]PRESRE7NOL = ITERMAC
          Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 1) From SUBSREB1
          For ITERCPN = 0 To [M:SRE7]NBCPN-1
            Call COVERMCCON(ITERCPN, [M:SRE7]PRESRE7NOL, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), [M:SRE7]CPNITM(ITERCPN), [M:CON0]CONNUM, IERRINF) From TRTCOVER
            If IERRINF Then
              #Erreur lors de la mise à jour de la couverture sur le parc concerné.
              GMESSAGE = mess(566,182,1)
              GERR = 1
              Break
            Endif
            #Mise à jour de la couverture sur les composants
            Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]MACNUM = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 1
&                          and [F:SRN]FGVCAH = 0 and [F:SRN]CPNITM = [M:SRE7]CPNITM(ITERCPN)
            For [SRN]
              [F:SRN]CPNCOVFLG = [M:SRE7]CPNCOVFLG(ITERCPN)
              [F:SRN]CPNCOVSPT = [M:SRE7]CPNCOVSPT(ITERCPN)
              [F:SRN]CPNCOVVCR = [M:SRE7]CPNCOVVCR(ITERCPN)
              Rewrite [SRN]
              If fstat Then
                #Erreur lors de la mise à jour de la couverture sur les composants concernés.
                GMESSAGE = mess(565,182,1)
                GERR = 1
                Break
              Endif
            Next
            Filter [SRN]
            If GERR Then
              Break
            Endif
          Next
          If GERR Then
            Break
          Endif
        Next
      Else
        IAFFSRE7 = 1
        For ITERMAC = 0 To [M:SRE7]NBMAC-1
          Call COVERMCON(ITERMAC, [M:SRE7]MAC(ITERMAC), [M:CON0]CONNUM, IERRINF) From TRTCOVER
          If IERRINF Then
            #Erreur lors de la mise à jour de la couverture sur le parc concerné.
            GMESSAGE = mess(566,182,1)
            GERR = 1
            Break
          Endif
          #Chargement des composant du parc modifié
          [M:SRE7]PRESRE7NOL = ITERMAC
          Call LOADCPN([M:SRE0]SRENUM, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 0) From SUBSREB1
          For ITERCPN = 0 To [M:SRE7]NBCPN-1
            Call COVERMCCON(ITERCPN, [M:SRE7]PRESRE7NOL, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), [M:SRE7]CPNITM(ITERCPN), [M:CON0]CONNUM, IERRINF) From TRTCOVER
            If IERRINF Then
              #Erreur lors de la mise à jour de la couverture sur le parc concerné.
              GMESSAGE = mess(566,182,1)
              GERR = 1
              Break
            Endif
            #Mise à jour de la couverture sur les composants
            Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 0
&                          and [F:SRN]FGVCAH = 0
&                          and [F:SRN]CPNITM = [M:SRE7]CPNITM(ITERCPN)
            For [SRN]
              [F:SRN]CPNCOVFLG = [M:SRE7]CPNCOVFLG(ITERCPN)
              [F:SRN]CPNCOVSPT = [M:SRE7]CPNCOVSPT(ITERCPN)
              [F:SRN]CPNCOVVCR = [M:SRE7]CPNCOVVCR(ITERCPN)
              Rewrite [SRN]
              If fstat Then
                #Erreur lors de la mise à jour de la couverture sur les composants concernés.
                GMESSAGE = mess(565,182,1)
                GERR = 1
                Break
              Endif
            Next
            Filter [SRN]
            If GERR Then
              Break
            Endif
          Next
          If GERR Then
            Break
          Endif
        Next
      Endif
    Endif
  Endif
  [M:SRE7]PRESRE7NOL = ISAVPRESRE7NOL
  If GERR Then
    Return
  Endif
  If SZGREP = "" Then
    If IAFFSRE7 Then
      Gosub SRE7MAC From SUBSREB1
    Endif
  Else
    If SZGREP = "C" or SZGREP = "D" Then
      If IAFFSRE7 Then
        Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 1) From SUBSREB1
        Affzo [M:SRE7]1-99
      Endif
    Else
      If IAFFSRE7 Then
        Call LOADCPN([M:SRE0]SRENUM, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 0) From SUBSREB1
        Affzo [M:SRE7]1-99
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Mise à jour des montants facturables de la demande
#########################################################################
$SLTHDT
Local Integer ITER
Local Decimal IPITHDT
Local Decimal IINVPITFLG  # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal
Local Integer IHDTINV

  IERRINF = 0
  If [M:SRE9]NBLIG <= 0 Then
    Return
  Endif
  If SZGREP = "" Then
    Filter [HDT] Where [F:HDT]SRENUM = [M:SRE0]SRENUM and [F:HDT]TPL <> 2
    For [HDT] HDT1
      [F:HDT]MANAMTFLG = 1
      Call AMOUNT(1, "HDT", 0, [F:HDT]HDTAMT, IHDTINV, [F:HDT]HDTAMTINV, IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
      [F:HDT]INVPITFLG = IINVPITFLG
      [F:HDT]HDTINV = IHDTINV
      If IERRINF Then
        GMESSAGE = mess(IERRINF,182,1)
        GERR = 1
        Break
      Endif
      Rewrite [HDT]
      If fstat Then
        #Erreur lors du recalcul des montants facturables des consommations.
        GMESSAGE = mess(567,182,1)
        GERR = 1
        Break
      Endif
    Next
    Filter [HDT]
    If GERR Then
      Return
    Endif
    #Rechargement des consommations
    Call LOADHDT([M:SRE0]SRENUM) From SUBSREB1
    If [M:SRE9]NBLIG > 0 Then
      Grizo [M:SRE8]SRECUR
      Grizo [M:SRE0]SALFCY
      Gosub SETMACGRAY From SUBSREB4
    Endif
  Else
    For ITER = 0 To [M:SRE9]NBLIG-1
      #Détermination du montant facturable par défaut
      [M:SRE9]MANAMTFLG(ITER) = 1
      Call AMOUNT(1, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), [M:SRE9]PITHDT(ITER), [M:SRE9]INVPITFLG(ITER), IERRINF) From TRTAMOUNT
      If IERRINF Then
        GMESSAGE = mess(IERRINF,182,1)
        GERR = 1
        Break
      Endif
    Next
  Endif
  If GERR Then
    Return
  Endif
  Call LOADTOTHDT(0) From SUBSREB1
  Call LOADTOTPIT(0) From SUBSREB1
  Affzo [M:SRE9]1-99
Return

##########################################################################################################
# Recalcul complet de la couverture par défaut d'une demande de service.
################################################################
Subprog CPTDEFCOV(IERRINF)
Variable Integer IERRINF

Local Integer ISVGGERR
Local Char SZSVGGMESSAGE(250)
Local Integer IMESSREP
Local Integer ITERMAC
Local Char SZGREP
Local Integer ISLOCKED

  IERRINF = 0
  IMESSREP = 0
  SZGREP = ""
  ITERMAC = 0
  ISVGGERR = 0
  SZSVGGMESSAGE = ""
  #Confirmez-vous la réinitialisation des différentes couvertures de la demande et du montant facturable des consommations ?
  Call OUINON(mess(570,182,1), IMESSREP) From GESECRAN
  If IMESSREP <> 2 Then
    End
  Endif
  If GREP = "" Then
    #Vérification du lock superviseur
    ISLOCKED = 0
    Call ISAOBLOCKED([M:SRE0]SRESYM, ISLOCKED) From CRMUTIL140
    If ISLOCKED Then
      #Modification en cours sur un autre poste.
      GMESSAGE = mess(10,100,1)
      GERR = 2
      End
    Endif
  Endif
  Gosub AVMCTLLOCKSRE From SUBSREA
  If !IUPDSRE Then
    End
  Endif
  #Réinitialisation couverture
  Call TEMPON(mess(571,182,1)) From GESECRAN
  Call COVERM From TRTCOVER
  ISVGGERR = GERR
  SZSVGGMESSAGE = GMESSAGE
  GERR = 0
  GMESSAGE = ""
  Call DEBTRANS From GLOCK
  Trbegin [SRM], [SRE], [HDT]
  For ITERMAC = 0 To [M:SRE7]NBMAC-1
    Readlock [SRM]SRM1=[M:SRE0]SRENUM;[M:SRE7]MAC(ITERMAC)
    If fstat Then
      #Erreur lors de la mise à jour de la couverture sur le parc concerné.
      GMESSAGE = mess(566,182,1)
      GERR = 1
      Break
    Else
      [F:SRM]COVFLG = [M:SRE7]COVFLG(ITERMAC)
      [F:SRM]COVSPT = [M:SRE7]COVSPT(ITERMAC)
      [F:SRM]COVVCR = [M:SRE7]COVVCR(ITERMAC)
      Rewrite [SRM]
      If fstat Then
        #Erreur lors de la mise à jour de la couverture sur le parc concerné.
        GMESSAGE = mess(566,182,1)
        GERR = 1
        Break
      Else
        Unlock [SRM]
      Endif
    Endif
  Next
  If GERR Then
    Rollback
    Call TEMPOFF From GESECRAN
    Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    End
  Endif
  #Affichage du parc
  Gosub SRE7MAC From SUBSREB1
  #MAJ des consommations
  Gosub SLTHDT
  If GERR Then
    Rollback
    Call TEMPOFF From GESECRAN
    Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    End
  Endif
  #Mise à jour de la demande de service
  Readlock [SRE]SRE0=[M:SRE0]SRENUM
  If fstat Then
    #Erreur lors de la réinitialisation de la couverture globale de la demande de service.
    GMESSAGE = mess(573,182,1)
    GERR = 1
    Rollback
    Call TEMPOFF From GESECRAN
    Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    End
  Endif
  [F:SRE]OVRCOV = [M:SRE2]OVRCOV
  [F:SRE]OVRCOVTYP = [M:SRE2]OVRCOVTYP
  [F:SRE]OVRCOVREN = [M:SRE2]OVRCOVREN
  [F:SRE]SRECOVNUM = [M:SRE2]SRECOVNUM
  [F:SRE]SRECOVAUT = [M:SRE2]SRECOVAUT
  [F:SRE]SRECOVAUS = [M:SRE2]SRECOVAUS
  [F:SRE]COVAUSCLA = [M:SRE2]COVAUSCLA
  [F:SRE]SRECOVCTL = [M:SRE2]SRECOVCTL
  [F:SRE]CONSPT = [M:SRE2]CONSPT
  [F:SRE]CONSPTTYP = [M:SRE2]CONSPTTYP
  [F:SRE]CONSPTFLG = [M:SRE2]CONSPTFLG
  [F:SRE]MANUPD = [M:SRE2]MANUPD
  [F:SRE]SRERESDAT = [M:SRE2]SRERESDAT
  [F:SRE]SRERESHOU = [M:SRE2]SRERESHOU
  Rewrite [SRE]
  If fstat Then
    #Erreur lors de la réinitialisation de la couverture globale de la demande de service.
    GMESSAGE = mess(573,182,1)
    GERR = 1
    Rollback
    Call TEMPOFF From GESECRAN
    Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    End
  Else
    Commit
    Unlock [SRE]
  Endif
  Call TEMPOFF From GESECRAN
  Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
  GERR = ISVGGERR
  GMESSAGE = SZSVGGMESSAGE
  Affzo [M:SRE2]1-99
End

