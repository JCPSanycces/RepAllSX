#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des demandes de services  Module CRM
#
#CREABTESC
# Gestion des points
# PITAVANTMOD :      Enregistrement de la photo en entrée en modification.
# PITAPRESMOD : Suppression de la photo après modification.
# PITABANDON : Restauration de l'état avant l'entrée en modification sur la base de la photo prise.
#
# Gestion des composants
# CPNAVANTMOD : Enregistrement de la photo en entrée en modification.
# CPNAPRESMOD : Suppression de la photo après modification.
# CPNABANDON : Restauration de l'état avant l'entrée en modification sur la base de la photo prise.
#
# VERFAVANTMOD : Vérifie s'il est possible de rentrer en modification sur une demande de service.
# FREELOCK : Libère le verrouillage d'une demande de service et d'une intervention
# VERFLOCK : Vérifie s'il est possible d'activer le bouton créer d'une intervention
# PRECRMSRE1 : Enregistrement des valeurs de couvertures précédentes
# RAZPRONUM : Nettoie les enregistrement de contrôle d'exécution de la session
#
# CHARGE_STOSOR : Alimentation du masque de sortie de stock
# APRES_STOSOR : Mise à jour complémentaires après enregistrement
# CHARGE_STOSOM : Alimentation du masque de sortie de stock
# APRES_STOSOM : Mise à jour complémentaires après enregistrement
# SETSTORES : Ouverture des ressources nécessaires à la gestion des sorties de stock
#
# DISPICON : Affichage des icônes
# DISPCCN : Affichage de l'interlocuteur
#
# SAVEHD1 : Enregistrement du CLOB description complète
# DELHD1 : Suppression du CLOB description complète
# LOADHD1 : Chargement du CLOB description complète
# CLEANHD7 : Supprime les enregistrements résiduels de la table HD7 (Plantage ou sortie intempestive)
# DELTXC : Suppression des CLOBs sur Consommation SAV
# DELITNRRS : Suppression des réservations de ressources des interventions
# DELITN : Suppression des interventions d'une demande de service
#
# CPTTXC2KEY : Calcul une clé pour la table TXCCODE
# CPTTXCKEY : Calcul une clé pour la table TXCCODE
# INVDELSRE : Suppression d'une facture de demande de service
# RAZESC : Remise à zéro de la dernière escalade
#
# LOADESC : Chargement de la dernière escalade
# DOESC : Exécution des escalades
#
# BLANKCAT
# FILLEDCAT
# DOSREESC
#
# SAVEESCHISTO : Enregistrement d'un historique d'escalade
#
# SETECENUM : Calcul un code chrono pour la création d'une escalade
#
# CREABTESC : Crée la tache batch d'exécution des escalades
# RESETSCH : Gestion de la création des horodatages en action RAZCRE et LIENS
#
# SETGRAY : Défini le grisage des champs en fonction du statut clôturé d'une demande
#
# SELECTSOH : Sélection d'une commande de vente pour assurer la couverture globale d'une demande de service
# SLTSOH
# SLTSOH2 : Mise à jour de la demande depuis SELECTSOH
# SLTSOH3 : Mise à jour d'une demande de service déjà créée
# SLTSOH4 : Mise à jour d'une demande de service déjà en cours de création ou de modification
# SELECTCON : Sélection d'un contrat de service pour assurer la couverture globale d'une demande de service
# SLTCON
#
# SLTCON4 : Mise à jour d'une demande de service déjà en cours de création ou de modification
# SLTCON3 : Mise à jour d'une demande de service déjà créée
# SLTMAC : Mise à jour de la couverture parc de la demande
# SLTHDT : Mise à jour des montants facturables de la demande
# CPTDEFCOV : Recalcul complet de la couverture par défaut d'une demande de service.
# SOHSRENUM :Alimentation du champ demande de service sur les commandes de ventes.
# ALI_STW : Chargement du masque de paramétrage pour composants stock
# ALI_ALP : Chargement du masque de paramétrage pour composants stock             #
#
# SUBB1_SRENUMBPC : Propose un chrono client
##########################################################################################################
##########################################################################################################
# Gestion des points
# Enregistrement de la photo en entrée en modification.
#######################################################################
Subprog PITAVANTMOD(SZSRENUM, IERRINF)
Value Char SZSRENUM
Variable Integer IERRINF

Local Char SZLOOP(100)

  #CHECK FILE_DECLARE PITCOUNT [PCT2]
  IERRINF = 0
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  Call PITAPRESMOD(SZSRENUM, IERRINF)
  If IERRINF Then
    End
  Endif
  SZLOOP = ""
  Call DEBTRANS From GLOCK
  Trbegin [PCT]
  Filter [PCT2] Where [F:PCT2]SRENUM = SZSRENUM and [F:PCT2]TPYFLG = 0 and [F:PCT2]FGVCAH = 0
  For [PCT2]
    Raz [F:PCT]
    [F:PCT] = [F:PCT2]
    [F:PCT]FGVCAH = 1
    SZLOOP = [F:PCT]SRENUM + num$([F:PCT]TPYFLG) + num$([F:PCT]FGVCAH) + [F:PCT]BPC + [F:PCT]MAC + [F:PCT]PBL + [F:PCT]HDT + [F:PCT]HDTSEQ
    [F:PCT]LOO = SZLOOP
    Write [PCT]
    If fstat Then
      #Erreur lors de la génération du cache abandon relatifs aux points mobilisés.
      IERRINF = 580
      Break
    Endif
  Next
  Filter [PCT2]
  If IERRINF Then
    Rollback
    End
  Else
    Commit
  Endif
End

##########################################################################################################
# Gestion des points
# Suppression de la photo après modification.
#######################################################################
Subprog PITAPRESMOD(SZSRENUM, IERRINF)
Value Char SZSRENUM
Variable Integer IERRINF

Local Integer INTRANS

  IERRINF = 0
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  If adxlog Then
    INTRANS = 1
  Else
    INTRANS = 0
  Endif
  If !INTRANS Then
    Call DEBTRANS From GLOCK
    Trbegin [PCT]
  Endif
  Delete [PCT] Where [F:PCT]SRENUM = SZSRENUM and [F:PCT]TPYFLG = 0 and [F:PCT]FGVCAH = 1
  If fstat Then
    #Erreur lors de la suppression du cache abandon relatifs aux points mobilisés.
    IERRINF = 581
    If !INTRANS Then
      Rollback
    Endif
    End
  Else
    If !INTRANS Then
      Commit
    Endif
  Endif
End

##########################################################################################################
# Gestion des points
# Restauration de l'état avant l'entrée en modification sur la base de la photo prise.
#######################################################################
Subprog PITABANDON(SZSRENUM, IERRINF)
Value Char SZSRENUM
Variable Integer IERRINF

Local Char SZLOOP(100)

  #CHECK FILE_DECLARE PITCOUNT [PCT2]
  IERRINF = 0
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  SZLOOP = ""
  Call DEBTRANS From GLOCK
  Trbegin [PCT]
  Delete [PCT] Where [F:PCT]SRENUM = SZSRENUM and [F:PCT]TPYFLG = 0 and [F:PCT]FGVCAH = 0
  If fstat Then
    #Erreur lors de la restauration du cache abandon relatifs aux points mobilisés.
    IERRINF = 582
    Rollback
    End
  Else
    Commit
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [PCT]
  Filter [PCT2] Where [F:PCT2]SRENUM = SZSRENUM and [F:PCT2]TPYFLG = 0 and [F:PCT2]FGVCAH = 1
  For [PCT2]
    Raz [F:PCT]
    [F:PCT] = [F:PCT2]
    [F:PCT]FGVCAH = 0
    SZLOOP = [F:PCT]SRENUM + num$([F:PCT]TPYFLG) + num$([F:PCT]FGVCAH) + [F:PCT]BPC + [F:PCT]MAC + [F:PCT]PBL + [F:PCT]HDT + [F:PCT]HDTSEQ
    [F:PCT]LOO = SZLOOP
    Write [PCT]
    If fstat Then
      #Erreur lors de la restauration du cache abandon relatifs aux points mobilisés.
      IERRINF = 582
      Break
    Endif
  Next
  Filter [PCT2]
  If IERRINF Then
    Rollback
    End
  Else
    Commit
  Endif
  Call PITAPRESMOD(SZSRENUM, IERRINF)
  If IERRINF Then
    End
  Endif
End

##########################################################################################################
# Gestion des composants
# Enregistrement de la photo en entrée en modification.
#######################################################################
Subprog CPNAVANTMOD(SZSRENUM, IERRINF)
Value Char SZSRENUM
Variable Integer IERRINF

  #CHECK FILE_DECLARE SREMACCPN [SRN2]
  IERRINF = 0
  Call CPNAPRESMOD(SZSRENUM, IERRINF)
  If IERRINF Then
    End
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [SRN]
  Filter [SRN2] Where [F:SRN2]SRENUM = SZSRENUM and [F:SRN2]TPYFLG = 0 and [F:SRN2]FGVCAH = 0
  For [SRN2]
    Raz [F:SRN]
    [F:SRN] = [F:SRN2]
    [F:SRN]FGVCAH = 1
    Write [SRN]
    If fstat Then
      #Erreur lors de la génération du cache abandon relatif aux composants concernés.
      IERRINF = 580
      Break
    Endif
  Next
  Filter [SRN2]
  If IERRINF Then
    Rollback
    End
  Else
    Commit
  Endif
End

