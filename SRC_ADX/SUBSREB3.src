##########################################################################################################
# Chargement du masque de paramétrage pour composants stock             #
#########################################################################
$ALI_STW
  Raz [M:STW]
  [M:STW]STOFCY     = [M:SRE9]HDTSTOFCY(ITER)
  [M:STW]TRSTYP     = 24
  [M:STW]VCRTYP     = 33
  [M:STW]VCRNUM     = [M:SRE9]HDTNUM(ITER)
  [M:STW]VCRLIN     = 0
  [M:STW]ITMREF     = [M:SRE9]HDTITM(ITER)
  [M:STW]MVTDES     = [M:SRE9]MVTDES(ITER)
  [M:STW]BPRNUM     = [M:SRE0]SREBPC
  [M:STW]BPAADD     = [M:SRE0]SREBPAADD
  [M:STW]PJT        = [M:SRE8]SREPJT
  [M:STW]TRSCOD     = [M:SRE0]TRSCOD
  [M:STW]TRSFAM     = [M:SRE0]TRSFAM
  [M:STW]ENTCOD     = [M:SRE0]ENTCOD
  [M:STW]IPTDAT     = [M:SRE9]HDTDONDAT(ITER)
  [M:STW]CCECOD     = "STKHDT"
  [M:STW]BPRNUM     = [M:SRE0]SREBPC
  [M:STW]CUR        = [M:SRE8]SRECUR
  #LSE 02/05/2007 FQ 41178
  [M:STW]VCRTYPORI  = 33
  [M:STW]VCRNUMORI  = [M:SRE0]SRENUM
Return

##########################################################################################################
# Chargement du masque de paramétrage pour composants stock             #
#########################################################################
$ALI_ALP
  [M:ALP]TRSTYP     = 24
  [M:ALP]TRSCOD     = [M:SRE0]TRSCOD
  [M:ALP]VCRTYP     = 33
  [M:ALP]STOFCY     = [M:SRE9]HDTSTOFCY(NOL)
  [M:ALP]ITMREF     = [M:SRE9]HDTITM(NOL)
  # --------------------------------------
  # FGR 21/04/2015 : X3SUIVI105605 (début)
  If dim([M:SRE9]ECCVALMAJ) >= 0 Then
    [M:ALP]ECCVALMAJ    = [M:SRE9]ECCVALMAJ(NOL)
  Endif
  # FGR 21/04/2015 : X3SUIVI105605 (fin)
  # --------------------------------------
  [M:ALP]PCU        = [M:SRE9]HDTUOM(NOL)
  [M:ALP]PCUSTUCOE  = [M:SRE9]SAUSTUCOE(NOL)
  [M:ALP]QTY        = [M:SRE9]HDTISSQTY(NOL)
  [M:ALP]TYPQTY     = 1
  [M:ALP]BESDAT     = [M:SRE9]HDTDONDAT
  [M:ALP]DLVDAT     = [M:SRE9]HDTDONDAT
  Raz [M:ALP]ALLDAT
  Raz [M:ALP]STOLOC
  [M:ALP]PECINTLOC  = 2
  [M:ALP]PECSCOLOC  = 1
  [M:ALP]PECPLFLOC  = 1
  [M:ALP]PECCUNLOK  = 1
  [M:ALP]PECQLYCTL  = 1
  Raz [M:ALP]FILSTO
  [M:ALP]LOT        = ""
  [M:ALP]LOC        = ""
  [M:ALP]STA        = ""
  [M:ALP]VCRNUM     = [M:SRE9]HDTNUM(NOL)
  [M:ALP]VCRLIN     = 0
  Raz [M:ALP]VCRSEQ
  If dim([M:SRE9]WRH)>0 [M:ALP]WRH=[M:SRE9]WRH(NOL) Endif
Return

##########################################################################################################
#Propose un chrono client
$SUBB1_SRENUMBPC
Local Integer IFOUND
Local Integer ISUFFIX
Local Char SZPREFIX
Local Char SZCHRONO
Local Integer IERRSUFFIX
Local Integer ISUFSREBPC  # FGR 13/08/2012 : X3SUIVI84033

  # FGR 13/08/2012 : X3SUIVI84033 (début)
  If dim(GSUFSREBPC) < 0 Then
    ISUFSREBPC = 0
  Else
    ISUFSREBPC = GSUFSREBPC
  Endif
  If ISUFSREBPC+GCHRSREBPC > type([M:SRE0]SRENUMBPC)-10 Then
    GMESSAGE = mess(668,177,1) - "(" + num$(ISUFSREBPC+GCHRSREBPC) + ">" + num$(type([M:SRE0]SRENUMBPC)-10) + ")"
    GERR = 1
    [M:SRE0]SRENUMBPC = ""
    Return
  Endif
  # FGR 13/08/2012 : X3SUIVI84033 (fin)
  IERRSUFFIX = 0
  ISUFFIX = 0
  If GCHRSREBPC > 0 Then
    SZPREFIX = left$([M:SRE0]SREBPC, GCHRSREBPC)
  Else
    SZPREFIX = ""
  Endif
  #Obtention du dernier chrono client.
  Call GENSRENUMBPC("CCT", [M:SRE0]SREBPC, ISUFFIX, IERRSUFFIX) From SUBSREB4
  If IERRSUFFIX Then
    GMESSAGE = mess(IERRSUFFIX,177,1)
    GERR = 1
    [M:SRE0]SRENUMBPC = ""
    Return
  Endif
  SZCHRONO = SZPREFIX + func GET_CHRONO_SRENUMBPC (ISUFFIX, ISUFSREBPC)        # FGR 13/08/2012 : X3SUIVI84033
  #Contrôle de la non utilisation du chrono calculé
  While 1
    IFOUND = 0
    Filter [SRE] Where [F:SRE]SREBPC = [M:SRE0]SREBPC and [F:SRE]SRENUMBPC = SZCHRONO
    For [SRE] Hint Key SRE5
      IFOUND = 1
    Next
    Filter [SRE]
    If !IFOUND Then
      Break
    Endif
    If IFOUND Then
      ISUFFIX += 1
      SZCHRONO = SZPREFIX + func GET_CHRONO_SRENUMBPC (ISUFFIX, ISUFSREBPC)    # FGR 13/08/2012 : X3SUIVI84033
    Endif
  Wend
  [M:SRE0]SRENUMBPC = SZCHRONO
Return

##########################################################################################################
Funprog GET_CHRONO_SRENUMBPC (ISUFFIX, ISUFSREBPC)
Value Integer ISUFFIX
Value Integer ISUFSREBPC

Local Char SARENDRE(100)

  # FGR 13/08/2012 : X3SUIVI84033
  If ISUFSREBPC = 0 Then
    SARENDRE = num$(ISUFFIX)
  Else
    SARENDRE = string$(ISUFSREBPC, "0") + num$(ISUFFIX)
    SARENDRE = right$(SARENDRE, 1+len(SARENDRE)-ISUFSREBPC)
  Endif
End SARENDRE

