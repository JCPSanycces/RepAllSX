#<AdxTL>@(#)0.0.0.0 $Revision$Class Children
# Supervisor
## CRUD-CLASSE ## EMPLOCHD
# 2018-11-06 07:06:02 131


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EMPLOCHD [CHD_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EMPLOCHD") From ASYRCOM : Endif
Local Instance EMPLOCHD Using C_EMPLOCHD

If !SILENCE : Call TRACE("3 --> New Instance C_EMPLOCHD") From ASYRCOM : Endif
EMPLOCHD = NewInstance C_EMPLOCHD AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [CHD_]CHD0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EMPLOCHD") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.AREAD([CHD_]REFNUM,[CHD_]NUMLIG))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EMPLOCHD.REFNUM ="-num$(EMPLOCHD.REFNUM)) From ASYRCOM
 Call TRACE("EMPLOCHD.NUMLIG ="-num$(EMPLOCHD.NUMLIG)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EMPLOCHD.AKEYS)
  Call TRACE("-"-num$(I)-":"-EMPLOCHD.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [CHD_]
FreeGroup EMPLOCHD
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EMPLOCHD,ACLE,ASTATUS,_ETAG)
Variable Instance EMPLOCHD Using C_EMPLOCHD
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _REFNUM(15)
Local Shortint _NUMLIG
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_NUMLIG = val([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File EMPLOCHD [CHD]
Default File [F:CHD]
Read [F:CHD]CHD0 = [L]_REFNUM;[L]_NUMLIG
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:CHD]UPDTICK)>0
 [L]_ETAG = num$([F:CHD]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EMPLOCHD,ACLE,ASTATUS)
Variable Instance EMPLOCHD Using C_EMPLOCHD
Value Char ACLE
Variable Integer ASTATUS
Local Char _REFNUM(15)
Local Shortint _NUMLIG
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_NUMLIG = val([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.AREAD([L]_REFNUM,[L]_NUMLIG))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EMPLOCHD,_REFNUM,_NUMLIG,ASTATUS)
Variable Instance EMPLOCHD Using C_EMPLOCHD
Value Char _REFNUM
Value Shortint _NUMLIG
Variable Integer ASTATUS

If EMPLOCHD = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOCHD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EMPLOCHD.APARENT=null
 [L]A_I = EMPLOCHD.freeSnapshot
 EMPLOCHD.snapshotEnabled = 0
 EMPLOCHD.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EMPLOCHD.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EMPLOCHD.APARENT=null
 EMPLOCHD.snapshotEnabled = 1
 EMPLOCHD.setAccessorEnabled = 1
Endif
LogicClose File [CHD]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD._ACTION_PARAM("AREAD_BEFORE",[L]_REFNUM,[L]_NUMLIG))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:CHD]
Read [F:CHD]CHD0 = [L]_REFNUM;[L]_NUMLIG
If fstat
[L]A_ERROR = [L]_REFNUM+"~"+num$([L]_NUMLIG)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EMPLOCHD,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:CHD]AUUID)>0 & [F:CHD]AUUID=NullUuid
 [F:CHD]AUUID = getUuid
Endif
SetInstance EMPLOCHD With [F:CHD]
EMPLOCHD.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



