#    If LG2 > PLG
#        LG2 = PLG
#    Endif
#
#End string$(PLG - LG2, " ") + left$(PTXT, LG2)


Subprog DEB_TRACE(PCPY, PCNX, PFLGSIM, PTPLANS_SELEC, PSEL)
Value Char PCPY
Value Integer PCNX, PFLGSIM, PTPLANS_SELEC()
Value Char PSEL

Local Integer I

    Local Char WLIB(250)
#    Call OUVRE_TRACE(mess(71, 7784, 1)) From LECFIC
    Call OUVRE_TRACE("Synchronisation des suivis") From LECFIC

    Call ECR_SOUL(mess(71, 7784, 1), "_")
    Call ECR_TRACE("", 0) From GESECRAN

    Call ECR_SOUL(mess(4, 26, 1) - ":", "=")
    Call ECR_TRACE("", 0) From GESECRAN

    Call ECR_TRACE(mess(2, 72, 1) - ":" - GUSER, 0) From GESECRAN
    Call ECR_TRACE("Date :" - format$("D:DD[/]MM[/]YYYY", date$) - "-" - time$, 0) From GESECRAN
    Call ECR_TRACE(mess(815, 9913, 1), 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN

    If PCPY = ""
    Call ECR_TRACE(mess(444, 7773, 1) - ":" - mess(G_OUI, 1, 1), 0) From GESECRAN
    Else
    Call ECR_TRACE(mess(6, 47, 1)    - ":" - PCPY, 0) From GESECRAN
    Endif
    Call ECR_TRACE(mess(31, 15, 1)   - ":" - mess(PFLGSIM, 1, 1), 0) From GESECRAN
    Call ECR_TRACE(mess(28, 75, 1)   - mess(PCNX, 3100, 1), 0) From GESECRAN

#    If PSEL <> ""
#    Call ECR_TRACE("Selection +:" - PSEL, 0) From GESECRAN
#    Endif

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE(mess(72, 7784, 1) - ":", 0) From GESECRAN

    I = 0
    While I < G301MAX - 1
        If PTPLANS_SELEC(I) = 0
            Break
        Endif
        Call ECR_TRACE(mess(PTPLANS_SELEC(I), 3101, 1), 0) From GESECRAN
        I += 1
    Wend

    Call ECR_TRACE("", 0) From GESECRAN
#    Call ECR_TRACE("********************************************************", 0) From GESECRAN

    Call ECR_SOUL(mess(29, 7778, 1) - ":", "=")
    Call ECR_TRACE("", 0) From GESECRAN

End

Subprog FIN_TRACE(PNBTOT_PLANMAJ, PNBTOT_PLANERR, PNBTOT_BIENMAJ, PNBTOT_BIENERR)
Value Integer PNBTOT_PLANMAJ, PNBTOT_PLANERR, PNBTOT_BIENMAJ, PNBTOT_BIENERR

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE(num$(PNBTOT_BIENMAJ) - mess(73, 7784, 1), 0) From GESECRAN
    Call ECR_TRACE(num$(PNBTOT_BIENERR) - mess(74, 7784, 1), 0) From GESECRAN
    Call ECR_TRACE(num$(PNBTOT_PLANMAJ) - mess(75, 7784, 1), 0) From GESECRAN
    Call ECR_TRACE(num$(PNBTOT_PLANERR) - mess(76, 7784, 1), 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
Call ECR_SOUL(mess(18, 2, 1) - ":" - format$("D:DD[/]MM[/]YYYY", date$) - "-" - time$, "=")

    Call FERME_TRACE() From LECFIC

    If GSERVEUR = 0
        Call LEC_TRACE From LECFIC
    Endif

End

Subprog ECR_SOUL(PTXT, PSOUL)
Value Char PTXT, PSOUL

    Call ECR_TRACE(PTXT, 0) From GESECRAN
    Call ECR_TRACE(string$(len(PTXT), PSOUL), 0) From GESECRAN
End


#**
#* donne le libellé d'1 champ de masque
#*
#* @param PLANGUE
#* @param PMASQUE
#* @param PCHAMP
#* @param RLIBELLE
#*!
Subprog LIBCHPATZ(PLANGUE, PMASQUE, PCHAMP, RLIBELLE)
Value Char PLANGUE, PMASQUE, PCHAMP
Variable Char RLIBELLE

    If !clalev ([F:AMZ])
        Local File = "AMSKZON" [AMZ]
    Endif
    If !clalev ([F:ATX])
        Local File = "ATEXTE" [ATX]
    Endif


    Read [AMZ]CODE = PMASQUE ; PCHAMP
    If fstat
        RLIBELLE = ""
    Else
        Read [ATX]NUMERO =PLANGUE ; [F:AMZ]INTIT
        RLIBELLE = [F:ATX]TEXTE
    Endif
End

# fonctions recopiées de TRTFAS pour rendre le trt indépendant des patchs

Funprog IMPAIRED_ASSET_PLN()

# Objet : Retourne si le plan du bien a été déprécié au moins une fois
# PREREQUIS :  La classe [F:DEPC] doit être ouverte et alimentée en conséquence
# -> période courante
  # test de la moulinette MWA :
#          Filter [WDEP] Where AASREF=[F:FAS]AASREF & DPRPLN= TPLN(I_C,I_P) & FIYENDDAT<= TCURFIY(I_C) & PERENDDAT< TCURPER(I_C) & IML <> 0
#          Look [WDEP] First
#          If (fstat < 4) Then : B_IML = 1 : Endif

  If [F:DEP]EXEIMLCUM = 0 and
&    [F:DEP]EXERVECUM = 0 and
&    [F:DEP]PERIMLCUM = 0 and
&    [F:DEP]PERRVECUM = 0 and
&    [F:DEP]IMLBLC = 0

      End 0
  Endif
End 1

########################################################
Funprog REVALUED_ASSET_PLN()

# Objet : Retourne si le plan du bien a été réévalué au moins une fois
# PREREQUIS :  La classe [F:DEP] doit être ouverte et alimentée en conséquence
# -> période courante

  # test de la moulinette MWA :If ( ([F:DEP]RVACRB <> 0) or ([F:DEP]BSEVAL <> [F:DEP]DPRBAS) ) Then : B_RVA = 1  : Endif

  If [F:DEP]BSEVAL = [F:DEP]DPRBAS and
&    [F:DEP]EXERVADEV = 0 and
&    [F:DEP]PERRVADEV = 0

      End 0
  Endif
End 1
