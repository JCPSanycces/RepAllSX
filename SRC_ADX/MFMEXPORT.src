#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
    When "EXP_ZONE" :        Gosub EXP_ZONE
Endcase
Return


###################################################################################
$EXP_ZONE
If EXPFIC="MFG" & GACTION="MESINT" : #interface MES
    If EXPZON="[F:MFM]BOMSHO"
        If [F:MFM]BOMSHO=""
            Local Char WITMDES(GLONDES)                                                          # FGR 30/06/2009 : X3SUIVI56189
            Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:MFM]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
            [F:MFM]BOMSHO=WITMDES
        Endif
    Elsif EXPZON="[F:MFM]BOMOPE"
        If [F:MFM]BOMOPE=0
            If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
            Filter [MFO] Where MFGNUM=[F:MFM]MFGNUM
            Read [MFO]MFO0 First
            If !fstat
                [F:MFM]BOMOPE=[F:MFO]OPENUM
            Endif
            Filter [MFO]
        Endif
    Endif
Endif
Return



