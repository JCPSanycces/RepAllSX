#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre ONCSP

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:29"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"ONCSP",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="NCSP0;NCSP1;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "NCSP"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "PLANID"
OBJLIS(1) = "NCSP1"
CHGLIS(1) = 2
BROLIS(1) = 2
TRELIS(1) = 1
DESLIS(1) = "PLANID"
OBJLIS(2) = "NCSP2"
CHGLIS(2) = 2
BROLIS(2) = 2
TRELIS(2) = 1
DESLIS(2) = ""
If clalev([M:NCSP0])=0 : Local Mask NCSP0 [NCSP0] : Endif
If clalev([M:NCSP1])=0 : Local Mask NCSP1 [NCSP1] : Endif
Gosub TIT
nolign = 1
If clalev([F:NCSRC])=0 : Local file NCSRECENT [NCSRC] : Endif
If clalev([F:AXXM])=0 : Local file ATEXTRA [AXXM] : Endif
If clalev([F:AXXP])=0 : Local file ATEXTRA [AXXP] : Endif
Link [PLAHDR] With
& [NCSRC]NCSRC0=[F:PLAHDR]PLANID,
& [AXXM]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSMANAGER;"",
& [AXXP]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSPLANNER;""
& As [PLAHDR_]
If clalev([F:PLAHDR])=0 : Local file PLANHDR [PLAHDR] : Endif
If clalev([F:NCSRC])=0 : Local file NCSRECENT [NCSRC] : Endif
If clalev([F:AXXM])=0 : Local file ATEXTRA [AXXM] : Endif
If clalev([F:AXXP])=0 : Local file ATEXTRA [AXXP] : Endif
Link [PLAHDR] With
& [NCSRC]NCSRC0=[F:PLAHDR]PLANID,
& [AXXM]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSMANAGER;"",
& [AXXP]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSPLANNER;""
& As [PLAHDR_]
Return

$DEF_BOITE
Gosub HORODAT From WGONCSP
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "ONCSP" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSP0]
&   Folder Mask [NCSP1]
&  Listbox [PLAHDR_] GAU_CHE
&   [L]SAIRAP(1) = [F:PLAHDR]PLANID Using "K:20X" Titled TITSEL(1) ,
&   [L]SAIRAP(2) = mess([F:NCSRC]NCSSTA(0),2033,1) Using "" Titled TITSEL(2) ,
&   [L]SAIRAP(3) = [F:NCSRC]TITLE Using "K:70X" Titled TITSEL(3) ,
&   [L]SAIRAP(4) = [F:NCSRC]SITE Using "K:5c" Titled TITSEL(4) ,
&   [L]SAIRAP(5) = [F:NCSRC]PRODUCT Using "K:20c" Titled TITSEL(5) ,
&   [L]SAIRAP(6) = [F:NCSRC]ECCVALMAJ Using "K:10X" Titled TITSEL(6) ,
&   [L]SAIRAP(7) = [F:NCSRC]ECCVALMIN Using "K:10X" Titled TITSEL(7) ,
&   [L]SAIRAP(8) = [NCSRC]NCSMANAGER-[AXXM]TEXTE Using "K:10X" Titled TITSEL(8) ,
&   [L]SAIRAP(9) = [NCSRC]NCSPLANNER-[AXXP]TEXTE Using "K:10X" Titled TITSEL(9) ,
&   [L]SAIRAP(10) = mess([F:PLAHDR]PLANSTATUS(0),2045,1) Using "" Titled TITSEL(10)
&  Listbox [PLAHDR9] GAU_CHE9
&   [L]SAIRAP(1) = [F:PLAHDR9]A_TAB1 Using "K:20X" Titled TITSEL9(1)  ,
&   [L]SAIRAP(2) = mess([F:PLAHDR9]A_TAB2,2033,1) Using "" Titled TITSEL9(2) ,
&   [L]SAIRAP(3) = [F:PLAHDR9]A_TAB3 Using "K:70X" Titled TITSEL9(3)  ,
&   [L]SAIRAP(4) = [F:PLAHDR9]A_TAB4 Using "K:5c" Titled TITSEL9(4)  ,
&   [L]SAIRAP(5) = [F:PLAHDR9]A_TAB5 Using "K:20c" Titled TITSEL9(5)  ,
&   [L]SAIRAP(6) = [F:PLAHDR9]A_TAB6 Using "K:10X" Titled TITSEL9(6)  ,
&   [L]SAIRAP(7) = [F:PLAHDR9]A_TAB7 Using "K:10X" Titled TITSEL9(7)  ,
&   [L]SAIRAP(8) = [F:PLAHDR9]A_TAB8 Using "K:10X" Titled TITSEL9(8) ,
&   [L]SAIRAP(9) = [F:PLAHDR9]A_TAB9 Using "K:10X" Titled TITSEL9(9) ,
&   [L]SAIRAP(10) = mess([F:PLAHDR9]A_TAB10,2045,1) Using "" Titled TITSEL9(10)
&  Listbox [PLAHDR_] GAU_CHE1
&   [L]SAIRAP(1) = [F:PLAHDR]PLANID Using "K:20X" Titled TITSEL1(1) ,
&   [L]SAIRAP(2) = mess([F:NCSRC]NCSSTA(0),2033,1) Using "" Titled TITSEL1(2) ,
&   [L]SAIRAP(3) = [F:NCSRC]TITLE Using "K:70X" Titled TITSEL1(3) ,
&   [L]SAIRAP(4) = [F:NCSRC]SITE Using "K:5c" Titled TITSEL1(4) ,
&   [L]SAIRAP(5) = [F:NCSRC]PRODUCT Using "K:20c" Titled TITSEL1(5) ,
&   [L]SAIRAP(6) = [F:NCSRC]ECCVALMAJ Using "K:10X" Titled TITSEL1(6) ,
&   [L]SAIRAP(7) = [F:NCSRC]ECCVALMIN Using "K:10X" Titled TITSEL1(7) ,
&   [L]SAIRAP(8) = [NCSRC]NCSMANAGER-[AXXM]TEXTE Using "K:10X" Titled TITSEL1(8) ,
&   [L]SAIRAP(9) = [NCSRC]NCSPLANNER-[AXXP]TEXTE Using "K:10X" Titled TITSEL1(9) ,
&   [L]SAIRAP(10) = mess([F:PLAHDR]PLANSTATUS(0),2045,1) Using "" Titled TITSEL1(10)
&  Listbox [NCSPLN_] GAU_CHE2
&   [L]SAIRAP(1) = [NCSPLN]NCSID Using "" Titled TITSEL2(1) ,
&   [L]SAIRAP(2) = mess([NCSPLN]NCSSTA,2033,1) Using "" Titled TITSEL2(2) ,
&   [L]SAIRAP(3) = [NCSPLN]TITLE Using "" Titled TITSEL2(3) ,
&   [L]SAIRAP(4) = [NCSPLN]SITE Using "" Titled TITSEL2(4) ,
&   [L]SAIRAP(5) = [NCSPLN]PRODUCT Using "" Titled TITSEL2(5) ,
&   [L]SAIRAP(6) = [NCSPLN]ECCVALMAJ Using "" Titled TITSEL2(6) ,
&   [L]SAIRAP(7) = [NCSPLN]ECCVALMIN Using "" Titled TITSEL2(7) ,
&   [L]SAIRAP(8) = [NCSPLN]NCSMANAGER-[AXXM]TEXTE Using "K:10X" Titled TITSEL2(8) ,
&   [L]SAIRAP(9) = [NCSPLN]NCSPLANNER-[AXXP]TEXTE Using "K:10X" Titled TITSEL2(9) ,
&   [L]SAIRAP(10) = mess([NCSPLN]PLANSTATUS,2045,1) Using "" Titled TITSEL2(10)
& As [NCSP1]
Titled [NCSP1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGONCSP
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "ONCSP" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSP0]
&   Folder Mask [NCSP1]
& As [NCSP1]
Titled [NCSP1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [NCSP1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [NCSP1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [NCSP1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS(30)
Call TEXTE(1004471,TITLIS) From OBJDIV
Local Char TITLIS9(30)
TITLIS9 = mess(196,123,1)
Local Char TITLIS1(30)
Call TEXTE(54357,TITLIS1) From OBJDIV
Local Char TITLIS2(30)
Call TEXTE(1003776,TITLIS2) From OBJDIV
Local Char TITSEL(30)(1..10)
Call TEXTE(12966,TITSEL(1)) From OBJDIV
Call TEXTE(1179,TITSEL(2)) From OBJDIV
Call TEXTE(6468,TITSEL(3)) From OBJDIV
Call TEXTE(53310,TITSEL(4)) From OBJDIV
Call TEXTE(19528,TITSEL(5)) From OBJDIV
Call TEXTE(44206,TITSEL(6)) From OBJDIV
Call TEXTE(44208,TITSEL(7)) From OBJDIV
Call TEXTE(54345,TITSEL(8)) From OBJDIV
Call TEXTE(9996,TITSEL(9)) From OBJDIV
Call TEXTE(34228,TITSEL(10)) From OBJDIV
Local Char TITSEL9(30)(1..10)
Call TEXTE(12966,TITSEL9(1)) From OBJDIV
Call TEXTE(1179,TITSEL9(2)) From OBJDIV
Call TEXTE(6468,TITSEL9(3)) From OBJDIV
Call TEXTE(53310,TITSEL9(4)) From OBJDIV
Call TEXTE(19528,TITSEL9(5)) From OBJDIV
Call TEXTE(44206,TITSEL9(6)) From OBJDIV
Call TEXTE(44208,TITSEL9(7)) From OBJDIV
Call TEXTE(54345,TITSEL9(8)) From OBJDIV
Call TEXTE(9996,TITSEL9(9)) From OBJDIV
Call TEXTE(34228,TITSEL9(10)) From OBJDIV
Local Char TITSEL1(30)(1..10)
Call TEXTE(12966,TITSEL1(1)) From OBJDIV
Call TEXTE(1179,TITSEL1(2)) From OBJDIV
Call TEXTE(6468,TITSEL1(3)) From OBJDIV
Call TEXTE(53310,TITSEL1(4)) From OBJDIV
Call TEXTE(19528,TITSEL1(5)) From OBJDIV
Call TEXTE(44206,TITSEL1(6)) From OBJDIV
Call TEXTE(44208,TITSEL1(7)) From OBJDIV
Call TEXTE(54345,TITSEL1(8)) From OBJDIV
Call TEXTE(9996,TITSEL1(9)) From OBJDIV
Call TEXTE(34228,TITSEL1(10)) From OBJDIV
Local Char TITSEL2(30)(1..10)
Call TEXTE(54350,TITSEL2(1)) From OBJDIV
Call TEXTE(54421,TITSEL2(2)) From OBJDIV
Call TEXTE(6468,TITSEL2(3)) From OBJDIV
Call TEXTE(53310,TITSEL2(4)) From OBJDIV
Call TEXTE(19528,TITSEL2(5)) From OBJDIV
Call TEXTE(44206,TITSEL2(6)) From OBJDIV
Call TEXTE(44208,TITSEL2(7)) From OBJDIV
Call TEXTE(54345,TITSEL2(8)) From OBJDIV
Call TEXTE(9996,TITSEL2(9)) From OBJDIV
Call TEXTE(34228,TITSEL2(10)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(24289,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Gosub SETCLE_
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""  : CRITERE  = "1=1" : Endif
 If FILTSUP=""  : FILTSUP  = "1=1" : Endif
 If FILROLE=""  : FILROLE  = "1=1" : Endif
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [PLAHDR_] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(0)<>'' or NOHLIS(0)<>0
 Fillbox [NCSP1] GAU_CHE Hint Key =HINTLIS(0)
Else
 Gosub CALNOHOBJ From GOBJET
 If A_NOH
  Fillbox [NCSP1] GAU_CHE
 Else
  Fillbox [NCSP1] GAU_CHE Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [PLAHDR_]
Return

$REMPLIT_1
Gosub SETCLE_1
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [PLAHDR_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(1)<>'' or NOHLIS(1)<>0
 Fillbox [NCSP1] GAU_CHE1 Hint Key =HINTLIS(1)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [NCSP1] GAU_CHE1
 Else
  Fillbox [NCSP1] GAU_CHE1 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [PLAHDR_]
Return

$REMPLIT_2
Gosub SETCLE_2
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [NCSPLN_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(2)<>'' or NOHLIS(2)<>0
 Fillbox [NCSP1] GAU_CHE2 Hint Key =HINTLIS(2)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [NCSP1] GAU_CHE2
 Else
  Fillbox [NCSP1] GAU_CHE2 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [NCSPLN_]
Return

$SETCLE_
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 2
LENLIS = 1
GAUTRELIS = 1
CLELISTE = "PLANID Desc"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$SETCLE_1
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 2
LENLIS = 1
GAUTRELIS = 1
CLELISTE = "PLANID Desc"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$SETCLE_2
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 0 : Default file [PLAHDR_]
 When 1 : Default file [PLAHDR_]
 When 2 : Default file [NCSPLN_]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [PLAHDR_] Order With CLELISTE
  Setlbox [NCSP1] GAU_CHE
  Filter [PLAHDR_]
 When "GAU_CHE9"
  Gosub CLE_DERLU From =PROGOBJ
  Setlbox [NCSP1] GAU_CHE9
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [PLAHDR_] Order With CLELISTE
  Setlbox [NCSP1] GAU_CHE1
  Filter [PLAHDR_]
 When "GAU_CHE2"
  Setlbox [NCSP1] GAU_CHE2
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [PLAHDR_] Order With CLELISTE
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [PLAHDR_] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [PLAHDR_]
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [PLAHDR_]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "NCSP0"        : ABMSK(0)  = "NCSP0"    : AMA(0) = 1
NOMMSK(1) = "NCSP1"        : ABMSK(1)  = "NCSP1"    : AMA(1) = 1
NBMASK = 1
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:NCSP0])>0 : Default Mask [NCSP0] : Endif
 When 1 : If clalev([M:NCSP1])>0 : Default Mask [NCSP1] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:NCSP0])>0 : Gosub TITRES From W1NCSP0 : Endif
 When 1 : If clalev([M:NCSP1])>0 : Gosub TITRES From W1NCSP1 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:NCSP0])>0 : Close Local Mask [NCSP0] : Endif
If clalev([M:NCSP1])>0 : Close Local Mask [NCSP1] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:NCSP0])>0 : Raz [M:NCSP0] : Endif
 When 1 : If clalev([M:NCSP1])>0 : Raz [M:NCSP1] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:NCSP0])>0 : Affzo [M:NCSP0] : Endif
 When 1 : If clalev([M:NCSP1])>0 : Affzo [M:NCSP1] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 0 : If clalev([M:NCSP0])>0 : [F:PLAHDR] = [M:NCSP0] : Endif
 When 1 : If clalev([M:NCSP1])>0 : [F:PLAHDR] = [M:NCSP1] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 0 : If clalev([M:NCSP0])>0 : [M:NCSP0] = [F:PLAHDR] : Endif
 When 1 : If clalev([M:NCSP1])>0 : [M:NCSP1] = [F:PLAHDR] : Endif
Endcase
Return

$GRISE_CLE
If AMA(0)
 Grizo [NCSP0]PLANID
Else
 Grizo [NCSP1]PLANID
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [NCSP0]PLANID
Else
 Actzo [NCSP1]PLANID
Endif
Return

$BOUTON
STDBOUT = "EA09<>RHILJMP"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1101 : Call TEXTE(52727,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "2" : LBOUT(NBTEX) = 1102 : Call TEXTE(17052,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


