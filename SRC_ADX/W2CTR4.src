Subprog AS_WRKCODPOS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(750,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WRKCODPOS(zc) From W2CTR4
Onkey   2 Titled GBOUTS Call S_WRKCODPOS(zc) From W2CTR4
Gosub _AFF
End

Subprog C_WRKCODPOS(VALEUR)
Variable Char    VALEUR()
## Action POSCNTOBL
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "POSCNTOBL"
PARMSK(1) = [M]WRKCRY
PARMSK(2) = "0"
Call S_AFF_CHAR(VALEUR,PARMSK,"POSCNTOBL","SUBPOS","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "WRKCODPOS" : GZNUM = 210 : Endif
Gosub _AFF
End

$AMM_WRKCODPOS
Call AM_WRKCODPOS(zc)
If !mkstat & GOBJET
 zoncou = "WRKCODPOS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WRKCODPOS(VALEUR)
Variable Char    VALEUR()
## Action CPCONT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CPCONT"
PARMSK(1) = [M]WRKCRY
PARMSK(2) = [M]WRKCTY
PARMSK(3) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"CPCONT","SUBPOS","") From GACTION
[M]WRKCTY = PARMSK(2)
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "WRKCODPOS" : GZNUM = 210 : Endif
If !mkstat
 ## Action SELCTY2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTY2"
 PARMSK(1) = [M]WRKCRY
 PARMSK(2) = [M]WRKCTY
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTY2","SUBPOS","") From GACTION
 [M]WRKCTY = PARMSK(2)
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WRKCODPOS" : GZNUM = 210 : Endif
 If !mkstat
  ## Action STD
  Call AM_WRKCODPOS(VALEUR) From SUBCTR
  If mkstat : GERR = 1 : GZONE = "WRKCODPOS" : GZNUM = 210 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_WRKCODPOS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOS"
 PARMSK(1) = [M]WRKCRY
 PARMSK(2) = [M]WRKCTY
 PARMSK(3) = ""
 PARMSK(4) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOS","SUBPOS","") From GACTION
 [M]WRKCTY = PARMSK(2)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WRKCODPOS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATUNPOS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATUNPOS"
 PARMSK(1) = [M]WRKCRY
 PARMSK(2) = [M]WRKCTY
 PARMSK(3) = ""
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"ATUNPOS","SUBPOS","") From GACTION
 [M]WRKCTY = PARMSK(2)
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_WRKCTY
Onevent BEFORE_AREA Gosub AV_WRKCTY From W2CTR4
Onevent BEFORE_INPUT Call AS_WRKCTY(zc) From W2CTR4
Onevent CONTROL Call C_WRKCTY(zc) From W2CTR4
Onevent AFTER_CHANGE Gosub AMM_WRKCTY From W2CTR4
Return

Subprog IB_WRKCTY(VALEUR)
Variable Char    VALEUR()
## Action ABOUTPLAN
Call BOUTPLAN From AVISUPLAN
Gosub _AFF
End

$AV_WRKCTY
## Action FMTCTYPAY
Call FMTCTYPAY([M]WRKCRY) From TRTDIV
Gosub _AFF
Return

Subprog AS_WRKCTY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(36871,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_WRKCTY(VALEUR)
## Action VILINI
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VILINI"
Call S_AFF_CHAR(VALEUR,PARMSK,"INIVIL","SUBPOS","") From GACTION
GACTION = SAVACT
If mkstat=2
 [M]WRKCTY(INDIC) = VALEUR
 Affzo WRKCTY(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_WRKCTY(zc) From W2CTR4
Onkey   2 Titled GBOUTS Call S_WRKCTY(zc) From W2CTR4
Gosub _AFF
End

Subprog C_WRKCTY(VALEUR)
Variable Char    VALEUR()
## Action VILCNTOBL
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VILCNTOBL"
PARMSK(1) = [M]WRKCRY
PARMSK(2) = "0"
Call S_AFF_CHAR(VALEUR,PARMSK,"VILCNTOBL","SUBPOS","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "WRKCTY" : GZNUM = 251 : Endif
Gosub _AFF
End

$AMM_WRKCTY
Call AM_WRKCTY(zc)
If !mkstat & GOBJET
 zoncou = "WRKCTY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WRKCTY(VALEUR)
Variable Char    VALEUR()
## Action VILCONT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VILCONT"
PARMSK(1) = [M]WRKCRY
PARMSK(2) = [M]WRKCODPOS
PARMSK(3) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"VILCONT","SUBPOS","") From GACTION
[M]WRKCODPOS = PARMSK(2)
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "WRKCTY" : GZNUM = 251 : Endif
If !mkstat
 ## Action SELPOS2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOS2"
 PARMSK(1) = [M]WRKCRY
 PARMSK(2) = [M]WRKCODPOS
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOS2","SUBPOS","") From GACTION
 [M]WRKCODPOS = PARMSK(2)
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WRKCTY" : GZNUM = 251 : Endif
 If !mkstat
  ## Action AFFPOSCOD
  If !mkstat & !GIMPORT : Affzo [M]WRKCODPOS : Endif
  If mkstat : GERR = 1 : GZONE = "WRKCTY" : GZNUM = 251 : Endif
  If !mkstat
   ## Action STD
   Call AM_WRKCTY(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "WRKCTY" : GZNUM = 251 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_WRKCTY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCTY
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTY"
 PARMSK(1) = [M]WRKCRY
 PARMSK(2) = [M]WRKCODPOS
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTY","SUBPOS","") From GACTION
 [M]WRKCODPOS = PARMSK(2)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WRKCTY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AVISUPLAN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AVISUPLAN"
 PARMSK(1) = ""
 PARMSK(2) = [M]WRKCRY
 PARMSK(3) = [M]WRKCODPOS
 Call SAISIE_CHAR(VALEUR,PARMSK,"AVISUPLAN","AVISUPLAN","") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

