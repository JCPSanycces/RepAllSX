If mkstat : GERR = 1 : GZONE = "ADDPRI" : GZNUM = 1164 : Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTUNI
  Call UNICITE2(VALEUR,[M]NBRADD,[M]ADDPRI) From OBJDIV
  If mkstat : GERR = 1 : GZONE = "ADDPRI" : GZNUM = 1164 : Endif
 Endif
Endif
Gosub _AFF
End

