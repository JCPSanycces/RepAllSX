#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_WRKCRN
Onevent BEFORE_AREA Gosub AV_WRKCRN From W2CTR4
Onevent CONTROL Call C_WRKCRN(zc) From W2CTR4
Onevent AFTER_CHANGE Gosub AMM_WRKCRN From W2CTR4
Return

$AV_WRKCRN
If !GWEBSERV
 ## Action FMTCRTPAY
 Call FMTCRTPAY([M]WRKCRY) From TRTDIV
Endif
If !GWEBSERV
 ## Action ASAICRT
 If [F:TCY]CRTFMTFLG<>2 : Grizo =zoncou : mkstat = 1 : Else : Actzo =zoncou : Endif
Endif
## Action STD
Call AV_WRKCRN(zc) From SUBCTR
Gosub _AFF
Return

Subprog C_WRKCRN(VALEUR)
Variable Char    VALEUR()
## Action CONTSIRET
Call CONTSIRET(VALEUR,[M]WRKCRY,"") From CONTNUM
If mkstat : GERR = 1 : GZONE = "WRKCRN" : GZNUM = 26815 : Endif
Gosub _AFF
End

$AMM_WRKCRN
Call AM_WRKCRN(zc)
If !mkstat & GOBJET
 zoncou = "WRKCRN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WRKCRN(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WRKCRN(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "WRKCRN" : GZNUM = 26815 : Endif
Gosub _AFF
End

$ON_NAFWRK
Onevent BEFORE_AREA Gosub AV_NAFWRK From W2CTR4
Onevent BEFORE_INPUT Call AS_NAFWRK(zc) From W2CTR4
Return

$AV_NAFWRK
If !GWEBSERV
 ## Action FMTNAFPAY
 Call FMTNAFPAY([M]WRKCRY) From TRTDIV
Endif
If !GWEBSERV
 ## Action ASAINAF
 If [F:TCY]NAFFMTFLG<>2 : Grizo =zoncou  : mkstat = 1 : Else : Actzo =zoncou : Endif
Endif
## Action STD
Call AV_NAFWRK(zc) From SUBCTR
Gosub _AFF
Return

Subprog AS_NAFWRK(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NAFWRK(VALEUR) From SUBCTR
If mkstat=2
 [M]NAFWRK(INDIC) = VALEUR
 Affzo NAFWRK(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$ON_WRKNATLEG
Onevent INIT_AREA Call D_WRKNATLEG(zc) From W2CTR4
Onevent BEFORE_INPUT Call AS_WRKNATLEG(zc) From W2CTR4
Return

Subprog D_WRKNATLEG(VALEUR)
Variable Integer VALEUR
If varinit([M]WRKNATLEG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WRKNATLEG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_WRKCRY
Onevent CONTROL Call C_WRKCRY(zc) From W2CTR4
Onevent AFTER_CHANGE Gosub AMM_WRKCRY From W2CTR4
Onevent BEFORE_INPUT Call AS_WRKCRY(zc) From W2CTR4
Onevent INIT_AREA Call D_WRKCRY(zc) From W2CTR4
Return

Subprog D_WRKCRY(VALEUR)
Variable Char    VALEUR()
If varinit([M]WRKCRY,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_WRKCRY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_WRKCRY(zc) From W2CTR4
Onkey 144 Titled GBOUTP Call P_WRKCRY(zc) From W2CTR4
Onkey 146 Titled GBOUTA Call SA_WRKCRY(zc) From W2CTR4
Gosub _AFF
End

Subprog C_WRKCRY(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "WRKCRY" : GZNUM = 235 : Endif
If !mkstat
 ## Action STD
 Call C_WRKCRY(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "WRKCRY" : GZNUM = 235 : Endif
Endif
Gosub _AFF
End

$AMM_WRKCRY
Call AM_WRKCRY(zc)
If !mkstat & GOBJET
 zoncou = "WRKCRY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WRKCRY(VALEUR)
Variable Char    VALEUR()
## Action INIPAYS
Call INIPAYS(VALEUR,[M]WRKCRYNAM) From TRTDIV
If mkstat : GERR = 1 : GZONE = "WRKCRY" : GZNUM = 235 : Endif
If !mkstat
 ## Action STD
 Call AM_WRKCRY(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "WRKCRY" : GZNUM = 235 : Endif
Endif
Gosub _AFF
End

Subprog S_WRKCRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_WRKCRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WRKCRY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_WRKCRYNAM
Onevent BEFORE_INPUT Call AS_WRKCRYNAM(zc) From W2CTR4
Return

Subprog AS_WRKCRYNAM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
If !GWEBSERV
 ## Action SAIPAYS
 Call SAIPAYS([M]WRKCRY) From TRTDIV
 If mkstat=2
  [M]WRKCRYNAM(INDIC) = VALEUR
  Affzo WRKCRYNAM(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

