Onevent CONTROL Call C_ADDCNTCDE(zc) From W2CTR4
Onevent AFTER_CHANGE Gosub AMM_ADDCNTCDE From W2CTR4
Onevent INIT_AREA Call D_ADDCNTCDE(zc) From W2CTR4
Return

Subprog D_ADDCNTCDE(VALEUR)
Variable Char    VALEUR()
If varinit([M]ADDCNTCDE,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_ADDCNTCDE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_ADDCNTCDE(VALEUR) From SUBCTR
If mkstat=2
 [M]ADDCNTCDE(INDIC) = VALEUR
 Affzo ADDCNTCDE(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_ADDCNTCDE(zc) From W2CTR4
Onkey 144 Titled GBOUTP Call P_ADDCNTCDE(zc) From W2CTR4
Onkey 146 Titled GBOUTA Call SA_ADDCNTCDE(zc) From W2CTR4
Gosub _AFF
End

Subprog C_ADDCNTCDE(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "ADDCNTCDE" : GZNUM = 235 : Endif
Gosub _AFF
End

$AMM_ADDCNTCDE
Call AM_ADDCNTCDE(zc)
If !mkstat & GOBJET
 zoncou = "ADDCNTCDE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ADDCNTCDE(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZADDCNTCDE)")>indice
 [M]ADDCNTCDE(indice) = VALEUR
 Affzo ZADDCNTCDE(indice)
Endif
Gosub _AFF
End

Subprog S_ADDCNTCDE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_ADDCNTCDE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ADDCNTCDE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZADDCNTCDE
Onevent BEFORE_AREA Gosub AV_ZADDCNTCDE From W2CTR4
Return

$AV_ZADDCNTCDE
Call LECTEXTRA(zc,"TABCOUNTRY","CRYDES",num$([M]ADDCNTCDE(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_ADDPOSCDE
Onevent CONTROL Call C_ADDPOSCDE(zc) From W2CTR4
Return

Subprog C_ADDPOSCDE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_ADDPOSCDE(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "ADDPOSCDE" : GZNUM = 7627 : Endif
Gosub _AFF
End

$ON_ADDPRV
Onevent BEFORE_AREA Gosub AV_ADDPRV From W2CTR4
Onevent BEFORE_INPUT Call AS_ADDPRV(zc) From W2CTR4
Onevent CONTROL Call C_ADDPRV(zc) From W2CTR4
Return

Subprog IB_ADDPRV(VALEUR)
Variable Char    VALEUR()
## Action INISAT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "INISAT"
PARMSK(1) = ADDCNTCDE
PARMSK(2) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"INISAT","TRTDIV","") From GACTION
GACTION = SAVACT
Gosub _AFF
End

$AV_ADDPRV
If !GWEBSERV
 ## Action FMTSAT
 Call FMTSATPAY(ADDCNTCDE,"") From TRTDIV
Endif
If GFMT<>""
 Chgfmt [M]ADDPRV(indice) With "K:"+GFMT
Else
 Chgfmt [M]ADDPRV(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_ADDPRV(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(31745,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_ADDPRV(VALEUR)
If  GWEBSERV
 ## Action SAISAT
 Call SAISAT(ADDCNTCDE,"") From TRTDIV
 If mkstat=2
  [M]ADDPRV(INDIC) = VALEUR
  Affzo ADDPRV(INDIC) : mkstat = 2
 Endif
Endif
Onkey 130 Titled GBOUT2 Call B2_ADDPRV(zc) From W2CTR4
Onkey   2 Titled GBOUTS Call S_ADDPRV(zc) From W2CTR4
Gosub _AFF
End

Subprog C_ADDPRV(VALEUR)
Variable Char    VALEUR()
## Action CTLSAT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CTLSAT"
PARMSK(1) = ADDCNTCDE
PARMSK(2) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"CTLSAT","TRTDIV","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "ADDPRV" : GZNUM = 13511 : Endif
Gosub _AFF
End

Subprog S_ADDPRV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELSAT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSAT"
 PARMSK(1) = ADDCNTCDE
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELSAT","TRTDIV","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B2_ADDPRV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNSAT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "TUNSAT"
 PARMSK(1) = ADDCNTCDE
 PARMSK(2) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"TUNSAT","TRTDIV","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_ADDPOSCOF
Onevent AFTER_CHANGE Gosub AMM_ADDPOSCOF From W2CTR4
Onevent INIT_AREA Call D_ADDPOSCOF(zc) From W2CTR4
Onevent BEFORE_INPUT Call AS_ADDPOSCOF(zc) From W2CTR4
Return

Subprog D_ADDPOSCOF(VALEUR)
Variable Integer VALEUR
If varinit([M]ADDPOSCOF,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ADDPOSCOF(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_ADDPOSCOF
Call AM_ADDPOSCOF(zc)
If !mkstat & GOBJET
 zoncou = "ADDPOSCOF" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ADDPOSCOF(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_ADDPOSCOF(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "ADDPOSCOF" : GZNUM = 55125 : Endif
Gosub _AFF
End

$ON_ADDSTA
Onevent INIT_AREA Call D_ADDSTA(zc) From W2CTR4
Onevent BEFORE_INPUT Call AS_ADDSTA(zc) From W2CTR4
Return

Subprog D_ADDSTA(VALEUR)
Variable Integer VALEUR
If varinit([M]ADDSTA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ADDSTA(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
