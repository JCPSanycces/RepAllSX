#<AdxTL>@(#)12.0.0.0 $Revision$ Utilitaires pools
Local Char POOLALIAS(30)
Local Char INTITPOOL(30)
Local Char SOLUTION(30)
Local Char DOSSIER(30)
Local Char SWEBALIAS(30)
Local Char SERWEB(30)
Local Char SADDEXT(30)
Local Integer PORTWEBEXT
Local Integer PORTWEB
Local Integer PORTSSL
Local Integer SSLENABLED
Local Integer NBENTRY
Local Integer MAXENTRY
Local Char USR(30)
Local Char USRMDP(30)
Local Char USRLAN(30),MESSAG(250)
Local Integer CRET

POOLALIAS="SUPERV"
INTITPOOL="Pool ecintradon2"
SOLUTION="SOLSUPV6"
DOSSIER="SUPERV"
SWEBALIAS="ECINTRADONOEL52"
SERWEB="ecfdalbopro.sagefr.adinternal.com"
SADDEXT="ecfdalbopro.sagefr.adinternal.com"
PORTWEBEXT=20880
PORTWEB=20880
PORTSSL=0
SSLENABLED=0
NBENTRY=1
MAXENTRY=1
USR="FDB"
USRMDP=""
USRLAN="FRA"
#Call SUPPOOLWS(SOLUTION,DOSSIER,SWEBALIAS,POOLALIAS,MESSAG,CRET)
#Infbox MESSAG
#End

Call POOLWS(POOLALIAS,INTITPOOL,SOLUTION,DOSSIER,SWEBALIAS,SERWEB,SADDEXT,PORTWEBEXT,PORTWEB,NBENTRY,MAXENTRY,USR,USRMDP,USRLAN,PORTSSL,SSLENABLED)
End

Subprog POOLWS(POOLALIAS,INTITPOOL,SOLUTION,DOSSIER,SWEBALIAS,SERWEB,SADDEXT,PORTWEBEXT,PORTWEB,NBENTRY,MAXENTRY,USR,USRMDP,USRLAN,PORTSSL,SSLENABLED)
Value Char POOLALIAS
Value Char INTITPOOL
Value Char SOLUTION
Value Char DOSSIER
Value Char SWEBALIAS
Value Char SERWEB
Value Char SADDEXT
Value Integer PORTWEBEXT
Value Integer PORTWEB
Value Integer NBENTRY
Value Integer MAXENTRY
Value Char USR
Value Char USRMDP
Value Char USRLAN
Value Integer PORTSSL
Value Integer SSLENABLED

####
Local Integer PFIND,AYO
Local Char SEP(2)

## Tables
Local File APOOLWS [APW]
If filinfo(filpath("FIL","AYTPOOWEB","fde",[L]DOSSIER),0)>0
 Local File =DOSSIER+".AYTPOOWEB" [AYO]
 [L]AYO = 1
Endif

# SBA
If [L]SSLENABLED=0 :[L]SSLENABLED=1 : Endif

PFIND=2
SEP="_"
# recherche si ca existe
Filter [APW] Where POOLALIAS=[L]POOLALIAS and SOLUTION=[L]SOLUTION and DOSSIER=[L]DOSSIER and SWEBALIAS=[L]SWEBALIAS
For [APW]
  PFIND=1
Next
Trbegin [APW]
Case PFIND
  When 1 : Gosub MODIFYPOOL
  When 2 : Gosub CREATEPOOL
Endcase
If AYO : Gosub CREATE_ADEFAULT : Endif
Commit
End

$CREATE_ADEFAULT
AYO =0
For [F:AYO] Where POOCOD ="ADEFAULT"
 AYO = 1
 Break
Next
If !AYO
 [F:AYO]POOCOD    = "ADEFAULT"
 [F:AYO]POODES    = "Default"
 [F:AYO]POOX3     = [L]SOLUTION+SEP+[L]DOSSIER+SEP+[L]SWEBALIAS+SEP+[L]POOLALIAS
 [F:AYO]USR       = [L]USR
 [F:AYO]USRMDP    = [L]USRMDP
 [F:AYO]USRLAN    = [L]USRLAN
 [F:AYO]POOSEC    = 1
 [F:AYO]POOTIMOUT = 30000
 Write [F:AYO]
Endif
Return

$MODIFYPOOL
[F:APW]POOLALIAS=[L]POOLALIAS
[F:APW]INTITPOOL=[L]INTITPOOL
[F:APW]SOLUTION=[L]SOLUTION
[F:APW]DOSSIER=[L]DOSSIER
[F:APW]SWEBALIAS=[L]SWEBALIAS

#            La version actuelle de la console ne renvoit pas les bonnes valeurs pour le nom de serveur web
#            et le port. En modif on ne fait rien sur ces valeurs pour ne rien casser
#            On conditionne ce test par le fait que PORTWEB=0 ou 80

If [L]PORTWEB<>0 and [L]PORTWEB<>80
 [F:APW]SERWEB=[L]SERWEB
 [F:APW]SADDEXT=[L]SADDEXT
 [F:APW]PORTWEBEXT=[L]PORTWEBEXT
 [F:APW]PORTWEB=[L]PORTWEB
Endif

# SBA
If dim([F:APW]PORTSSL)<>-1
    If [L]PORTSSL<>0 and [L]PORTSSL<>43
         [F:APW]PORTSSL=[L]PORTSSL
    Endif
    [F:APW]SSLENABLED=[L]SSLENABLED
Endif


[F:APW]NBENTRY=[L]NBENTRY
[F:APW]MAXENTRY=[L]MAXENTRY
[F:APW]USR=[L]USR
[F:APW]USRMDP=[L]USRMDP
[F:APW]USRLAN=[L]USRLAN
#[F:APW]UPDUSR=GUSER
#[F:APW]UPDDAT=date$
#[F:APW]UPDTIM=time
Rewrite [APW]
Return


$CREATEPOOL
#            La version actuelle de la console ne renvoit pas les bonnes valeurs pour le nom de serveur web
#            et le port. Pour se dépanner on va chercher le nom du serveur Web dans le fichier solution.xml
#            et on prend le port 28880.
#            On conditionne ce test par le fait que PORTWEB=0 ou 80


[F:APW]POOLALIAS=[L]POOLALIAS
[F:APW]INTITPOOL=[L]INTITPOOL
[F:APW]SOLUTION=[L]SOLUTION
[F:APW]DOSSIER=[L]DOSSIER
[F:APW]SWEBALIAS=[L]SWEBALIAS
If [L]PORTWEB=80 or [L]PORTWEB=0
 Local Char PROPERTY(200)
 Local Char VPROP(200)
 Local Integer OK
 PROPERTY="component.web.servername"
 Call RECHPROP(PROPERTY,VPROP,OK) From INTRUTILA
 If OK=0
  [F:APW]SERWEB=VPROP
  [F:APW]SADDEXT=VPROP
 Endif
 [F:APW]PORTWEBEXT=28880
 [F:APW]PORTWEB=28880
Else
 [F:APW]SERWEB=[L]SERWEB
 [F:APW]SADDEXT=[L]SADDEXT
 [F:APW]PORTWEBEXT=[L]PORTWEBEXT
 [F:APW]PORTWEB=[L]PORTWEB
Endif

# SBA
If dim([F:APW]PORTSSL)<>-1
    If [L]PORTSSL=0 or [L]PORTSSL=43
         [F:APW]PORTSSL=28843
    Else
         [F:APW]PORTSSL=[L]PORTSSL
    Endif
    [F:APW]SSLENABLED=[L]SSLENABLED
Endif

[F:APW]NBENTRY=[L]NBENTRY
[F:APW]MAXENTRY=[L]MAXENTRY
[F:APW]USR=[L]USR
[F:APW]USRMDP=[L]USRMDP
[F:APW]USRLAN=[L]USRLAN
[F:APW]CLE=[L]SOLUTION+SEP+[L]DOSSIER+SEP+[L]SWEBALIAS+SEP+[L]POOLALIAS
#[F:APW]CREUSR=GUSER
#[F:APW]CREDAT=date$
Write [APW]
Return

# ----------------------------------------------------------------------------------

Subprog SUPPOOLWS(SOLUTION,DOSSIER,SWEBALIAS,POOLALIAS,MESSAG,CRET)
Value Char SOLUTION
Value Char DOSSIER
Value Char SWEBALIAS
Value Char POOLALIAS
Variable Char MESSAG
Variable Integer CRET,I

CRET=2

#   Suppression du pool POOLNAME
#   Si OK CRET=0 au retour
#   Sinon CRET=1 et MESSAG contient la cause du refus d'annulation

Local Integer ERRX,AYO,NBUSE
Onerrgo ERRPOOLXT

Local File APOOLWS[APW]
If ERRX<>0 : End : Endif
Read [APW]APW2=SOLUTION;DOSSIER;SWEBALIAS;POOLALIAS
If fstat<>0
  CRET=2 : # Pool n'existe pas dans X3 on suprimme quand même.
  End
Endif

#  Le pool est-il utilisé
If filinfo(filpath("FIL","AYTPOOWEB","fde",[L]DOSSIER),0)>0 & filinfo(filpath("FIL","AYTPOOWEB","fde",[L]DOSSIER),0)>0
 Local File =DOSSIER+".AYTPOOWEB" [AYO]
 Local File =DOSSIER+".AYTFCY"    [AYS]
 AYO =1
Endif
If ERRX<>0 : End : Endif
NBUSE = 0
If AYO
 Filter [AYO] Where POOX3=[F:APW]CLE
 For [AYO]
  For [F:AYS]
   For I=0 To [F:AYS]LNKNBR-1
    If [F:AYS]LNKADS(I)=[F:AYO]POOCOD
     If (!find([F:AYS]FCYCOD,"ASAMPLE","ATEMPLATE","ASHOP") & [F:AYO]POOCOD="ADEFAULT") or ([F:AYO]POOCOD<>"ADEFAULT")
      NBUSE = 1
      Break 3
     Endif
    Endif
   Next
  Next
 Next
 Filter [AYO]
Endif
If NBUSE<>0
  CRET=1
  MESSAG=mess(226,7900,1)-"("+SOLUTION+"~"+DOSSIER+"~"+SWEBALIAS+"~"+POOLALIAS+")"
  End
Endif

#  On peut supprimer
Trbegin [APW]
Delete [APW] Curr
If fstat
 CRET=1 : MESSAG=mess(28,125,1)-"("+SOLUTION+"~"+DOSSIER+"~"+SWEBALIAS+"~"+POOLALIAS+")"
 Rollback : End
Endif
Commit
Onerrgo
End

$ERRPOOLXT
ERRX=1
Resume
