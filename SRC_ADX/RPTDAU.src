#<AdxTL>@(#)0.0.0.0 $Revision$ 

#-------------------------------------------------------------------------------
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char PARAMR

#Report generation is only possible when 1/11 dialog is open
#otherwise => End
  If !clalev([M:TRG0]) or !clalev([M:PPG1]) or !clalev([M:TRGP])
     End
  Endif
###########################################################################
#begin angre: 22.11.2012
#set the calendar year from which the calculation has been done
PARAMR = num$(year([M:TRG0]DATDEB))
Call SETPARAM("preyear",NBPAR,PARAMETRE,PARAMR) From ETAT
#set the calendar year for the prepayment
PARAMR = num$(year([M:TRG0]DATDEB)+ 1)
Call SETPARAM("year",NBPAR,PARAMETRE,PARAMR) From ETAT
#end angre: 22.11.2012
##############################################################################

#Set the taxno parameter with the information from the header screen [M:TRG0]
PARAMR = [M:TRG0]CRN
Call SETPARAM("taxno",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the cpy (Company) parameter
PARAMR = func GETCOMPANY()
Call SETPARAM("cpy",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the bprnum(business partner number) parameter.
PARAMR = func GETBPRNUM()
Call SETPARAM("bprnum",NBPAR,PARAMETRE,PARAMR) From ETAT

If ([M:TRGP]DFV <> 2)
  If [M:PPG1]AMTVAT < 0
    PARAMR = "0"
  Else
    PARAMR = num$(fix([M:PPG1]AMTVAT))
  Endif
  Call SETPARAM("sum",NBPAR,PARAMETRE,PARAMR) From ETAT

  PARAMR = num$([M:PPG1]AMTPRT11)
  Call SETPARAM("38",NBPAR,PARAMETRE,PARAMR) From ETAT

  If [M:TRGP]KNZ10 = 2 Then
    PARAMR = "1"
  Else
    PARAMR = " "
  Endif
  Call SETPARAM("10",NBPAR,PARAMETRE,PARAMR) From ETAT

  If [M:TRGP]KNZ26 = 2 Then
    PARAMR = "1"
  Else
    PARAMR = " "
  Endif
  Call SETPARAM("26",NBPAR,PARAMETRE,PARAMR) From ETAT

  If [M:TRGP]KNZ29 = 2 Then
    PARAMR = "1"
  Else
    PARAMR = " "
  Endif
  Call SETPARAM("29",NBPAR,PARAMETRE,PARAMR) From ETAT
Else
  PARAMR = "0"
  Call SETPARAM("sum",NBPAR,PARAMETRE,PARAMR) From ETAT
  Call SETPARAM("38",NBPAR,PARAMETRE,PARAMR) From ETAT
  PARAMR = ""
  Call SETPARAM("10",NBPAR,PARAMETRE,PARAMR) From ETAT
  Call SETPARAM("26",NBPAR,PARAMETRE,PARAMR) From ETAT
  Call SETPARAM("29",NBPAR,PARAMETRE,PARAMR) From ETAT
Endif

If [M:TRGP]KNZ23 = 2 Then
  PARAMR = "1"
Else
  PARAMR = " "
Endif
Call SETPARAM("23",NBPAR,PARAMETRE,PARAMR) From ETAT
End

#-------------------------------------------------------------------------------
Funprog GETCOMPANY()
Local Char RESULT(30)
If [M:TRG0]GRP <>""  Then
   If clalev([F:CPY0])=0 : Local File COMPANY [CPY0] : Endif
   Read [F:CPY]CPY0 = [M:TRG0]GRP
   If fstat = 0
      RESULT = ""
    Endif
Else
   RESULT = [M:TRG0]CPY
Endif
End RESULT

#-------------------------------------------------------------------------------
Funprog GETBPRNUM()
  Local Char RESULT(30)
  If [M:TRG0]CRN <>""  Then
   Filter [F:CPY] Where GERTAXIDT = [M:TRG0]CRN
   For [CPY]
    RESULT = [CPY]GERTAXCEN
   Next
   Filter [F:CPY]
Endif
End RESULT




