#<AdxTL>@(#)0.0.0.0 $Revision$ 
#STCAH - 2017-03-20 - REQUIREMENT nnn - US nnn
#Handling all properties for EXPENSESESS_CSTD
############################################################################################################
$PROPERTIES
#Handling all the property code in EXPENSESESS_CSTD_PRO

Case [L]CURPRO
  When "DATEXS"            : Gosub EXPENSES_DATEXS
  When "CODEXP"            : Gosub EXPENSES_CODEXP
  When "CUR"               : Gosub EXPENSES_CUR
  When "VAT"               : Gosub EXPENSES_VAT
  When "QTY"               : Gosub EXPENSES_QTY
  When "PAYCUR"            : Gosub EXPENSES_PAYCUR
  When "VATCUR"            : Gosub EXPENSES_VATCUR
  When "RFUCUR"            : Gosub EXPENSES_RFUCUR
  When "BPCNUM"            : Gosub EXPENSES_BPCNUM
  When "SOHNUM"            : Gosub EXPENSES_SOHNUM
  When "SOHLIG"            : Gosub EXPENSES_SOHLIG
  When "INVFLG"            : Gosub EXPENSES_INVFLG
Endcase
Return


$EXPENSES_DATEXS
Case [L]ARULE
  When "INIT"
    Gosub EXPENSES_DATEXS_INIT
  When "CONTROL"
    Gosub EXPENSES_DATEXS_CONTROL
  When "PROPAGATE"
    Gosub EXPENSES_DATEXS_PROPAGATE
Endcase
Return
#---------------------------
$EXPENSES_DATEXS_INIT

Local Integer MAXL
Local Date PRVDATEXS
PRVDATEXS = this.APARENT.ENDDAT    # default to start date if previous line date not found


MAXL = maxtab(this.APARENT.HREXPENSES)
If MAXL > 1
   For I = 1 To MAXL
     If this.APARENT.HREXPENSES(I) <> null and find(this.APARENT.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
       If this.AORDER = this.APARENT.HREXPENSES(I).AORDER   # we are on the line
         If PRVDATEXS = AVOID.ADATE
           PRVDATEXS = this.APARENT.STRDAT
         Endif
         this.DATEXS = PRVDATEXS
         Break
       Else
         PRVDATEXS = this.APARENT.HREXPENSES(I).DATEXS
       Endif
     Endif
   Next
Endif
If this.DATEXS = AVOID.ADATE
  this.DATEXS = this.APARENT.ENDDAT
Endif

Return
#---------------------------
$EXPENSES_DATEXS_CONTROL

If this.snapshot.DATEXS <> this.DATEXS
  Gosub IS_LINE_MODIFIABLE
  If ASTATUS = [V]CST_AERROR
    Return
  Endif
Endif

If this.DATEXS<this.APARENT.STRDAT | this.DATEXS>this.APARENT.ENDDAT
#If this.DATEXS<this.APARENT.STRDAT | this.DATEXS>this.APARENT.ENDDAT
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(12,122,1),[V]CST_AERROR)
  Return
Endif

Local File EMPLOCTR [HRCTR2]
#Filter [CTR] Where REFNUM=this.APARENT.REFNUM & (CTRDAT<=this.DATEXS | (FLGRET=2 & RETDATEFF<=this.DATEXS))
#&                & (XITDAT>=this.DATEXS | XITDAT=[0/0/0])
# SOA - changed the above to filter by descending contract date
Filter [HRCTR2] Where REFNUM=this.APARENT.REFNUM & (CTRDAT<=this.DATEXS | (FLGRET=2 & RETDATEFF<=this.DATEXS))
&                & (XITDAT>=this.DATEXS | XITDAT=[0/0/0]) Order By CTRDAT Desc
#Look [CTR]CTR0 First
Look [HRCTR2] First
Filter [HRCTR2]
If fstat <> [V]CST_AOK
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(15,10718,1),[V]CST_AERROR)
  LogicClose File [HRCTR2]
  Return
Endif
LogicClose File [HRCTR2]

# add control code here to make take care of code that needs to run in propogate - this code is called from INIDEV
Local Char THIS_CUR(3)
Local Date THIS_DAT
Local Char SOA_ERRMSG(250)
THIS_CUR = this.CUR
THIS_DAT = this.DATEXS
If this.CODEXP <> AVOID.ACHAR & THIS_CUR <> AVOID.ACHAR
  Call INIDEV_CONTROL(THIS_CUR,THIS_DAT,this,SOA_ERRMSG,this.CODEXP)
  If SOA_ERRMSG <> AVOID.ACHAR
    ASTATUS=fmet this.ASETERROR([L]CURPRO,SOA_ERRMSG,[V]CST_AERROR)
  Endif
Endif

Return
#---------------------------
$EXPENSES_DATEXS_PROPAGATE
#
Local Char VCPY(GLONCPY)
Local File EMPLOCTR [HRCTR3]
Filter [HRCTR3] Where REFNUM=this.APARENT.REFNUM & CTRNUM=this.APARENT.CTRNUM & (CTRDAT<=this.DATEXS | (FLGRET=2 & RETDATEFF<=this.DATEXS))
&     Order By Key CLE=CTRDAT Desc
Read [HRCTR3] First
Filter [HRCTR3]
If !fstat
  this.APARENT.ETRFCY = [F:HRCTR3]ETRFCY
  #this.FCY            = this.APARENT.ETRFCY  # check this against SUBEXS ???? what happens if contract changes on header with differnet site ????
  this.APARENT.CTRDAT = [F:HRCTR3]CTRDAT
Endif
#???? should we update all FCY on HREXPENSES from here - could have changed if different contract
Gosub UPDATE_EXPENSES_FCY2

If this.CUR = AVOID.ACHAR
  #Call GET_CPY_CUR(this)
  THIS_FCY = this.APARENT.ETRFCY
  Gosub INICPY
  #this.CPY = [L]VCPY
  this.TCH_LEG = this.APARENT.LEG
  this.CUR = [F:CPY]ACCCUR
  LogicClose File [CPY]
Endif

#Call INIDEV(this.CUR,this.DATEXS)

Call INIDEV(this.CUR,this.DATEXS,this)

LogicClose File [F:HRCTR3]

Return
############################################################################################################
$EXPENSES_CODEXP
Case [L]ARULE
  When "CONTROL"
    Gosub EXPENSES_CODEXP_CONTROL
  When "PROPAGATE"
    Gosub EXPENSES_CODEXP_PROPAGATE
Endcase
Return
#---------------------------
$EXPENSES_CODEXP_CONTROL

If this.snapshot.CODEXP <> this.CODEXP
  Gosub IS_LINE_MODIFIABLE
  If ASTATUS = [V]CST_AERROR
    Return
  Endif
Endif

Local File HRTABEXPENS [HRTES]
Read [F:HRTES]HRTES0 = this.TCH_LEG;this.CODEXP
If fstat <> [V]CST_AOK
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(38,720,1),[V]CST_AERROR)
  LogicClose File [HRTES]
  Return
Endif

Local Char SOA_MSG(250)
Call CONTEXE([F:HRTES]ACS,SOA_MSG) From CPTSUB_SOA
#If mkstat : [V]GMESSAGE=[L]VALEUR-[V]GMESSAGE : End : Endif
If SOA_MSG <> AVOID.ACHAR
  #ASTATUS=fmet this.ASETERROR([L]CURPRO,this.CODEXP+mess(7,104,1),[V]CST_AERROR)  #???? review
  ASTATUS=fmet this.ASETERROR([L]CURPRO,this.CODEXP-SOA_MSG,[V]CST_AERROR)
  Return
Endif

SOA_MSG = ""
Call CTLVLYDAT(this.DATEXS,[F:HRTES]VLYSTR,[F:HRTES]VLYEND,SOA_MSG) From CPTSUB_SOA
#If mkstat : [V]GMESSAGE=[L]VALEUR-[V]GMESSAGE : End : Endif
If SOA_MSG <> AVOID.ACHAR
  #ASTATUS=fmet this.ASETERROR([L]CURPRO,this.CODEXP+mess(38,720,1),[V]CST_AERROR) #???? review
  ASTATUS=fmet this.ASETERROR([L]CURPRO,this.CODEXP+SOA_MSG,[V]CST_AERROR)
  Return
Endif

## fq 105501
Local File FACGROUP [XFGR]
If [F:HRTES]GRP<>""
   Read [XFGR]FGR0=[F:HRTES]GRP;this.FCY
   If fstat <> [V]CST_AOK
     ASTATUS=fmet this.ASETERROR([L]CURPRO,this.FCY-":"-mess(24,127,1)-[F:HRTES]GRP,[V]CST_AERROR)
     LogicClose File [XFGR]
     LogicClose File [HRTES]
     Return
   Endif
Endif

# check if any code in propogate is has an mkstat or any other error
# if yes then need to move some code to CONTROL

LogicClose File [XFGR]
LogicClose File [HRTES]

Return
#---------------------------
$EXPENSES_CODEXP_PROPAGATE

Local File HRTABEXPENS [HRTES]
Read [F:HRTES]HRTES0 = this.TCH_LEG;this.CODEXP
If fstat <> [V]CST_AOK
  #ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(38,720,1),[V]CST_AERROR)
  LogicClose File [HRTES]
  Return
Endif

this.TCH_UOMDES=func AFNC.TEXTRA("ATABDIV","LNGDES","10551",[F:HRTES]UOM)
#Local File ATEXTRA [AXX]
#Read [AXX]AXX0 = "ATABDIV";"LNGDES";this.ACTX.LAN;"10551";[F:HRTES]UOM
#If !fstat
#  this.TCH_UOMDES = [F:AXX]TEXTE
#Endif
#LogicClose File [AXX]

If [F:HRTES]DEB=2 : this.TCH_SNS="-" : Else this.TCH_SNS="+" : Endif
#Affzo [EXS0] UOMDES(nolign-1), SNS(nolign-1)

Call INIPAYE(this.DATEXS,this.CODEXP,this.CUR,this.QTY,this.PAYCUR, this)

#44925
If [F:HRTES]VAT>""
  this.VAT=[F:HRTES]VAT
Else
  Local Integer MAXL
  Local Char PRVVAT(5)   # alphanumeric
  MAXL = maxtab(this.APARENT.HREXPENSES)
  For I = 1 To MAXL
    If this.APARENT.HREXPENSES(I) <> null and find(this.APARENT.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
      If this.AORDER = this.APARENT.HREXPENSES(I).AORDER   # we are on the line
        If I > 1 & PRVVAT <> AVOID.ACHAR
          this.VAT = PRVVAT
        Endif
        Break
      Else
        PRVVAT = this.APARENT.HREXPENSES(I).VAT
      Endif
    Endif
  Next
Endif

Call INITVA( this.CUR,this.VAT,this.FCY,this.DATEXS,this.PAYCUR
&          , this.VATCUR
&          )
Call INITAX( this.CUR,this.VAT,this.FCY,this.DATEXS,this.PAYCUR
&          , this.VATCUR,this.RFUCUR,this
&          )
#&          ,this                                                           # add line of collection class
Return
#
############################################################################################################
$EXPENSES_CUR
Case [L]ARULE
  When "INIT"
    Gosub EXPENSES_CUR_INIT
  When "CONTROL"
    Gosub EXPENSES_CUR_CONTROL
  When "PROPAGATE"
    Gosub EXPENSES_CUR_PROPAGATE
Endcase
Return
#---------------------------
$EXPENSES_CUR_INIT

Local Char CPY(GLONCPY)


Local File HRTABEXPENS [HRTES]
Read [F:HRTES]HRTES0 = this.TCH_LEG;this.CODEXP
If fstat <> [V]CST_AOK
  #ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(38,720,1),[V]CST_AERROR)
  LogicClose File [HRTES]
  Return
Endif

Call GCURSHR(SOA_GCURSHR) From ESSGLOB_SOA

Case [F:HRTES]TYPVLT
  When 1,3                     # fixed/mileage
    Call GET_CPY_CUR(this)
    #mkstat   =2         # NB: we need to set the field to display only ????
  When 2                       # actual
    #If nolign=1 : [L]VALEUR=[V]GCURSHR : Else [L]VALEUR=[M:EXS0]CUR(nolign-2) : Endif
    Local Integer MAXL
    Local Char PRVCUR(GLONTCU)

    MAXL = maxtab(this.APARENT.HREXPENSES)
    If MAXL = 1
      this.CUR = SOA_GCURSHR
    Else
      For I = 1 To MAXL
        If this.APARENT.HREXPENSES(I) <> null and find(this.APARENT.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
          If this.AORDER = this.APARENT.HREXPENSES(I).AORDER   # we are on the line
            If PRVCUR = AVOID.ACHAR
              PRVCUR = SOA_GCURSHR
            Endif
            this.CUR = PRVCUR
            Break
          Else
            PRVCUR = this.APARENT.HREXPENSES(I).CUR
          Endif
        Endif
      Next
    Endif
Endcase

LogicClose File [HRTES]

Return
#---------------------------
$EXPENSES_CUR_CONTROL

If this.snapshot.CUR <> this.CUR
  Gosub IS_LINE_MODIFIABLE
  If ASTATUS = [V]CST_AERROR
    Return
  Endif
Endif

#Call CONTDEV(VALEUR,[M:EXS0]DATEXS(nolign-1)) From TRTDEV
Call CONTDEV(this.CUR,this.DATEXS) From TRTDEV_SOA             #???? not completed yet calls SUBAUS ????
If ASTATUS = [V]CST_AERROR                                     #make sure ASTATUS is returned from CONTDEV
  Return
Endif

# add control code here to make take care of code that needs to run in propogate - this code is called from INIDEV
Local Char THIS_CUR(3)
Local Date THIS_DAT
Local Char SOA_ERRMSG(250)
THIS_CUR = this.CUR
THIS_DAT = this.DATEXS
If this.CODEXP <> AVOID.ACHAR & THIS_CUR <> AVOID.ACHAR
  Call INIDEV_CONTROL(THIS_CUR,THIS_DAT,this,SOA_ERRMSG,this.CODEXP)
  If SOA_ERRMSG <> AVOID.ACHAR
    ASTATUS=fmet this.ASETERROR([L]CURPRO,SOA_ERRMSG,[V]CST_AERROR)
  Endif
Endif

Return
#---------------------------
$EXPENSES_CUR_PROPAGATE

Call INIDEV(this.CUR,this.DATEXS,this)

Return
############################################################################################################
$EXPENSES_VAT
Case [L]ARULE
  When "INIT"
