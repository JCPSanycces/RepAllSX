$EXPENSES_BPCNUM
Case [L]ARULE
  When "INIT"
#    Gosub EXPENSES_BPCNUM_INIT
  When "CONTROL"
    Gosub EXPENSES_BPCNUM_CONTROL
  When "PROPAGATE"
    Gosub EXPENSES_BPCNUM_PROPAGATE
Endcase
Return
#---------------------------
$EXPENSES_BPCNUM_INIT

Return # must check if this code is required

#If nolign>1 : [L]VALEUR=[M:EXS0]BPCNUM(nolign-2) : Endif

# get BPCNUM from previous line (if on line > 0)

Local Integer MAXL
Local Char PRVBPCNUM(GLONBPC)

MAXL = maxtab(this.APARENT.HREXPENSES)

For I = 1 To MAXL
  If this.APARENT.HREXPENSES(I) <> null and find(this.APARENT.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
    If this.AORDER = this.APARENT.HREXPENSES(I).AORDER   # we are on the line
      this.BPCNUM = PRVBPCNUM
      Break
    Else
      PRVBPCNUM = this.APARENT.HREXPENSES(I).BPCNUM
    Endif
  Endif
Next

Return
#---------------------------
$EXPENSES_BPCNUM_CONTROL

If this.snapshot.BPCNUM <> this.BPCNUM
  Gosub IS_LINE_MODIFIABLE
  If ASTATUS = [V]CST_AERROR
    Return
  Endif
Endif

Return
#---------------------------
$EXPENSES_BPCNUM_PROPAGATE

Return
############################################################################################################
$EXPENSES_SOHNUM
Case [L]ARULE
  When "INIT"
    Gosub EXPENSES_SOHNUM_INIT
  When "CONTROL"
    Gosub EXPENSES_SOHNUM_CONTROL
  When "PROPAGATE"
    Gosub EXPENSES_SOHNUM_PROPAGATE
Endcase
Return
#---------------------------
$EXPENSES_SOHNUM_INIT

#If nolign>1 & [M:EXS0]BPCNUM(nolign-1)=[M:EXS0]BPCNUM(nolign-2)
 #[L]VALEUR=[M:EXS0]SOHNUM(nolign-2)
#Endif

# get BPCNUM from previous line (if on line > 0) & the BPCNUM are the same

Local Integer MAXL
Local Char PRVSOHNUM(GLONVCR)
Local Char PRVBPCNUM(GLONBPR)

MAXL = maxtab(this.APARENT.HREXPENSES)
For I = 1 To MAXL
  If this.APARENT.HREXPENSES(I) <> null and find(this.APARENT.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
    If this.AORDER = this.APARENT.HREXPENSES(I).AORDER   # we are on the line
      If this.BPCNUM = PRVBPCNUM
        this.SOHNUM = PRVSOHNUM
      Endif
      Break
    Else
      PRVSOHNUM = this.APARENT.HREXPENSES(I).SOHNUM
      PRVBPBNUM = this.APARENT.HREXPENSES(I).BPCNUM
    Endif
  Endif
Next

Return
#---------------------------
$EXPENSES_SOHNUM_CONTROL
Return
#---------------------------
$EXPENSES_SOHNUM_PROPAGATE

Return
