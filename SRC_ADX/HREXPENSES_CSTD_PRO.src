#---------------------------
$EXPENSES_INVFLG_INIT

#If nolign>1 : [L]VALEUR=[M:EXS0]INVFLG(nolign-2) : Endif

Local Integer MAXL
Local Integer PRVINVFLG
MAXL = maxtab(this.APARENT.HREXPENSES)
For I = 1 To MAXL
  If this.APARENT.HREXPENSES(I) <> null and find(this.APARENT.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
    If this.AORDER = this.APARENT.HREXPENSES(I).AORDER   # we are on the line
      If I > 1 & PRVINVFLG <> AVOID.AINT
        this.INVFLG = PRVINVFLG
      Endif
      Break
    Else
      PRVINVFLG = this.APARENT.HREXPENSES(I).INVFLG
    Endif
  Endif
Next

Return
#---------------------------
$EXPENSES_INVFLG_CONTROL
Return
#---------------------------
$EXPENSES_INVFLG_PROPAGATE

Return


$IS_LINE_MODIFIABLE
If this.STA > 1
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(37,10718,1),[V]CST_AERROR)
Endif

Return


$GET_ISOLDE
Local Libelle ISOLDE
Local Char L_CHAINE(30)
Local File ATABDIV [ADI]

#Call PARAM("","EXSADV",L_CHAINE) From ADOVAL
L_CHAINE = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, AVOID.ACHAR, "EXSADV")
#Infbox num$(val(L_CHAINE))
If val(L_CHAINE) # param returned a string that can be converted into a numeric other than 0  e.g. 8
 [L]ISOLDE=val(L_CHAINE)
Elsif L_CHAINE>"" # param returned a string that cannot be converted into a numeric
 #Call LECTURE("ADI",L_CHAINE,"365") From CONTOBJ
 Read [F:ADI]CODE = 365;L_CHAINE
 If fstat = [V]CST_AOK | [F:ADI]N1>0 : [L]ISOLDE=[F:ADI]N1 : Endif
 #Infbox num$([F:ADI]N1)
Endif

If [L]ISOLDE <> 0
  CEXP_APARENT_TCH_ISOLDE = [L]ISOLDE
Endif

Return
############################################################################################################
Subprog GET_CPY_CUR(CEXP)
Variable Instance CEXP Using C_HREXPENSES

Local Char VCPY(GLONCPY)
Local Char THIS_FCY(GLONFCY)
If CEXP.CUR=AVOID.ACHAR
  THIS_FCY = CEXP.APARENT.ETRFCY
  Gosub INICPY
  CEXP.CPY = [L]VCPY
  # ADD fstat to make sure company can be read
  CEXP.CUR = [F:CPY]ACCCUR
Endif

LogicClose File [CPY]

End
#---------------------------
$GET_CPY_

Local File FACILITY [FCY]
Local Char VCPY(GLONCPY)
Local Char THIS_FCY(GLONFCY) : THIS_FCY = this.APARENT.ETRFCY
Gosub INICPY
this.CPY = [L]VCPY
If fstat <> [V]CST_AOK
  Raz [F:CPY]
  # ADD fstat to make sure company can be read
  # Read [F:CPY]CPY0 = [L]CPY
Endif

Return
############################################################################################################
$UPDATE_EXPENSES_FCY

If this.snapshot.ETRFCY <> this.ETRFCY
  For I = 1 To maxtab(this.HREXPENSES)
    If this.HREXPENSES(I) <> null and find(this.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
      this.HREXPENSES(I).FCY = this.ETRFCY
    Endif
  Next
Endif

Return
############################################################################################################
$UPDATE_EXPENSES_FCY2

If this.APARENT.snapshot.ETRFCY <> this.APARENT.ETRFCY
  For I = 1 To maxtab(this.APARENT.HREXPENSES)
    If this.APARENT.HREXPENSES(I) <> null and find(this.APARENT.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
      this.APARENT.HREXPENSES(I).FCY = this.APARENT.ETRFCY
    Endif
  Next
Endif

Return
############################################################################################################
$INICPY

Local File COMPANY [CPY]
[L]VCPY=func DIVPAYE_SOA.GETSOC(THIS_FCY)
Read [CPY]CPY0 = [L]VCPY
# handle blank in code later if cannot read ????

Return

Subprog INIDEV_CONTROL(CUR,DAT,CEXP,SOA_ERRMSG,VCODEXP)
Value Char CUR()
Value Date DAT
Value Char VCODEXP
Variable Instance CEXP Using C_HREXPENSES
Variable Char SOA_ERRMSG

Local Char SOA_GCURSHR(30)
#---------------------------
#Check for error occuring in ----> CONVERT3
#Make sure GCURSHR has a value

Call GCURSHR(SOA_GCURSHR) From ESSGLOB_SOA
If SOA_GCURSHR = AVOID.ACHAR
  SOA_ERRMSG = mess(36,10718,1)-SOA_GCURSHR
  #End  # do not exit - check next validation
Endif
#---------------------------
# validation/control occurs in ----> Call INIREMB
# we only need the piece of code where the failure may occur

Local Integer STAT, TROUVE  # 62198
Local Decimal SOA_VAL

#Local File COMPANY [CPY]
Local File HRTABEXPENS [HRTES]

Read [HRTES]HRTES0 = CEXP.TCH_LEG;CEXP.CODEXP #[L]TES
If fstat <> [V]CST_AOK
  #ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(25,718,1),[V]CST_AERROR)
  If SOA_ERRMSG <> AVOID.ACHAR
    SOA_ERRMSG = SOA_ERRMSG+".|"-mess(35,10718,1)-CEXP.CODEXP   #???? added to 718
  Else
    SOA_ERRMSG = mess(35,10718,1)-CEXP.CODEXP
  Endif
  If SOA_ERRMSG <> AVOID.ACHAR
    End
  Endif
Endif

If [F:HRTES]TYPVLT = 1
  SOA_VAL = func PARAM([F:HRTES]VLTDEFPAR,CEXP.FCY,CEXP.APARENT.REFNUM,[L]DAT,CEXP,TROUVE)
  If TROUVE=0
    # Forfait non défini dans la variable
    #Raz this.VATCUR  # must be set in propogate if anything
    If SOA_ERRMSG <> AVOID.ACHAR
      SOA_ERRMSG = SOA_ERRMSG+".|"-mess(28,10718,1)-[F:HRTES]VLTDEFPAR
    Else
      SOA_ERRMSG = mess(28,10718,1)-[F:HRTES]VLTDEFPAR
    Endif
    If SOA_ERRMSG <> AVOID.ACHAR
      End
    Endif
  Endif
Endif
#---------------------------

End


Subprog INIDEV(CUR,DAT,CEXP)
Value Char CUR()
Value Date DAT
Variable Instance CEXP Using C_HREXPENSES

# Convert Global variables to Local variables
Local Char      SOA_GEURO(30)           : # Euro code
Local Char      SOA_GDEVORI1(3)         : # Devise utilisée pour la conversion   - gets set to [L]CUR
Local Char      SOA_GDEVORI2(3)         : # Devise utilisée pour la conversion   - gets set to [L]CUR
Local Libelle   SOA_GCURFLG             : # Réservé X3 - ???? 0 LM
Local Char      SOA_GSYSCUR(30)         : # Inter-company currency
Local Libelle   SOA_GCPYFLG             : # Réservé X3 - ???? 0 LM
Local Libelle   SOA_GRPTFLG             : # Réservé X3 - ???? 0 LM
Local Char      SOA_GCURSHR(30)         : # Currency shared fields
Local Decimal   SOA_GDECRCU

Call GEURO(SOA_GEURO)             From ESSGLOB_SOA
Call GSYSCUR(SOA_GSYSCUR)         From ESSGLOB_SOA
Call GCURFLG(CUR,DAT,SOA_GCURFLG) From ESSGLOB_SOA
Call GRPTFLG(DAT,SOA_GRPTFLG)     From ESSGLOB_SOA
Call GDECRCU(SOA_GDECRCU)         From ESSGLOB_SOA

If [L]CUR=AVOID.ACHAR | [L]DAT=[0/0/0] : End : Endif

Local Char    CPYCUR(GLONCUR), RPTCUR(GLONCUR), VCPY(GLONCPY)
Local Decimal RATCUR, RATRPT
Local Integer STAT

Local Char THIS_FCY(GLONFCY) : THIS_FCY = CEXP.APARENT.ETRFCY
Gosub INICPY
#CEXP.CPY = [L]VCPY
#SH Initialize the Company Flag here becuase CPY is required as a parameters
Call GCPYFLG(VCPY,DAT,SOA_GCPYFLG) From ESSGLOB_SOA

Call SETFLGDEV([L]CUR,VCPY,[L]DAT) From CPTDIV_SOA

[L]SOA_GDEVORI1=[L]CUR            # [V]GDEVORI1
[L]SOA_GDEVORI2=[L]CUR            # [V]GDEVORI2

If [L]SOA_GCURFLG=2 & [L]CUR<>[L]SOA_GEURO
  If [L]SOA_GCPYFLG=1 : [L]SOA_GDEVORI1=[L]SOA_GEURO : Endif
  If [L]SOA_GRPTFLG=1 : [L]SOA_GDEVORI2=[L]SOA_GEURO : Endif
Endif

[L]CPYCUR=[F:CPY]ACCCUR
[L]RPTCUR=[L]SOA_GSYSCUR
If [L]SOA_GCURFLG=1
 If [L]SOA_GCPYFLG=2 & [L]SOA_GSYSCUR<>[L]SOA_GEURO : [L]CPYCUR=[L]SOA_GEURO : Endif
 If [L]SOA_GRPTFLG=2 & [L]CPYCUR <>[L]SOA_GEURO : [L]RPTCUR=[L]SOA_GEURO : Endif
Endif

## Calcul du taux théorique
Call CONVERT( [L]SOA_GDEVORI1,[L]CPYCUR,[F:CPY]ACCCUR,CEXP.TYPRAT
&           , [L]DAT,10^[L]SOA_GDECRCU,[L]RATCUR,[L]STAT
&           ) From TRTDEV_SOA
If ![L]STAT : [L]RATCUR=arr([L]RATCUR*10^-[L]SOA_GDECRCU,10^-[L]SOA_GDECRCU) : Endif
Call CONVERT( [L]SOA_GDEVORI2,[L]RPTCUR,[F:CPY]ACCCUR,CEXP.TYPRAT
&           , [L]DAT,10^[L]SOA_GDECRCU,[L]RATRPT,[L]STAT
&           ) From TRTDEV_SOA
If ![L]STAT : [L]RATRPT=arr([L]RATRPT*10^-[L]SOA_GDECRCU,10^-[L]SOA_GDECRCU) Endif

If [L]CUR=[L]CPYCUR : CEXP.RATCPY=1
Else                  CEXP.RATCPY=[L]RATCUR
Endif
Case [L]RPTCUR
 When [L]CUR    : CEXP.RATRPT=1
 When [L]CPYCUR : CEXP.RATRPT=[L]RATCUR
 When Default   : CEXP.RATRPT=[L]RATRPT
Endcase

Call INIPAYE( [L]DAT,CEXP.CODEXP,[L]CUR,CEXP.QTY
&           , CEXP.PAYCUR
&           , CEXP
&           )

LogicClose File [CPY]

End


Subprog INIPAYE(DAT,CODEEXP,CUR,QTY,PAYE,CEXP)
Value    Date    DAT
Value    Char    CODEEXP(), CUR()
Value    Decimal QTY
Variable Decimal PAYE
Variable Instance CEXP Using C_HREXPENSES

Local Char SOA_GCURSHR(30)         : # Currency shared fields
Call GCURSHR(SOA_GCURSHR) From ESSGLOB_SOA

If find("",[L]CODEEXP,[L]CUR) | [L]DAT=[0/0/0] | [L]QTY=0 : End : Endif

Local Libelle  CAT, BKT
Local Integer  STAT , TROUVE  # 62198
Local Decimal  CNS
Local Shortint I
Local Char VCPY(GLONCPY)

Local Char THIS_FCY(GLONFCY) : THIS_FCY = CEXP.APARENT.ETRFCY
Gosub INICPY
CEXP.CPY = [L]VCPY

Local File HRTABEXPENS [HRTES]
Read [HRTES]HRTES0 = CEXP.TCH_LEG;[L]CODEEXP    # review LECTURE - what if it cannot read
#Call LECTURE("TES",[L]TES,"") From CONTOBJ

# might not have access to the class in the Subprog
# to pass class - look in EVA_FUNCTIONS and see how this is done
# if lot of properties then pass class otherwise pass individual variable

If CEXP.APARENT.TCH_ISOLDE = AVOID.AINT
  Gosub GET_ISOLDE
Endif
If CEXP.APARENT.TCH_ISOLDE <> AVOID.AINT & [F:HRTES]PRO=2 & [F:HRTES]DEB=2 : # restitution d'avance
 If ![L]PAYE  #must be if zero
  Local File SOLDPAY [SDP]
  Read [SDP]SDP0=CEXP.APARENT.REFNUM;CEXP.APARENT.CTRNUM
  #If fstat = !fstat : [L]CNS=-func SUBSLD.GETSOLDE([M:EXS0]ISOLDE) : Endif
  If fstat = [V]CST_AOK
    [L]CNS=-func SUBSLD.GETSOLDE(CEXP.APARENT.TCH_ISOLDE)         # get value in field e.g. [F:SDP]EXSADV
  Endif
  If [L]CNS<=0
   [L]CNS=0
  Else
   Local File HREXPENSES[EXS]

   Link [EXS] With [HRTES]HRTES0~=CODEXP As [LNK]
   # Get linked file where (refnum = employee) & (HREXPENSES line not posted) & (tabexpens -> early=2 & debit=2)
   For [LNK]reckey Where REFNUM=CEXP.APARENT.REFNUM & STA<2 & [HRTES]PRO=2 & [HRTES]DEB=2
    If [F:EXS]DATEXS>=CEXP.APARENT.STRDAT & [F:EXS]DATEXS<=CEXP.APARENT.ENDDAT
     #I=find([F:EXS]LIN,[M:EXS0]LIN(0..[M:EXS0]NBLIG-1))
     #If !find(I,0,nolign) : [L]CNS-=[M:EXS0]RFUCUR(I-1) : Endif
     #If this.HREXPENSES(NI) <> null and find(this.HREXPENSES(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0

     I=find([F:EXS]LIN, CEXP.APARENT.HREXPENSES(1..maxtab(CEXP.APARENT.HREXPENSES)).LIN)  #???? check this
     If I > 0
       If CEXP.APARENT.HREXPENSES(I) <> null and find(CEXP.APARENT.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
         If CEXP.APARENT.HREXPENSES(I).LIN <> CEXP.LIN
           [L]CNS-=CEXP.RFUCUR  # amount reimbursed
         Endif
       Endif
     Endif
    Else
     [L]CNS-=[F:EXS]RFUCUR # amount reimbursed
    Endif
    If [L]CNS<=0 : [L]CNS=0 : Break : Endif
   Next
   If [L]CNS>0
    For [HRTES]reckey Where PRO=2 & DEB=2
     #For I=0 To [M:EXS0]NBLIG-1
      #If ![M:EXS0]LIN(I) & I<>nolign-1 & [M:EXS0]CODEXP(I)=[F:TES]CODEXP
       #[L]CNS-=[M:EXS0]RFUCUR(I)
       #If [L]CNS<=0 : [L]CNS=0 : Break 2 : Endif
      #Endif
     #Next
     For I = 1 To maxtab(CEXP.APARENT.HREXPENSES)
       #If this.APARENT.HREXPENSES(I) <> null and find(this.APARENT.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
       If CEXP.APARENT.HREXPENSES(I) <> null and find(CEXP.APARENT.HREXPENSES(I).ASTALIN,[V]CST_ANEW) = 1
         #If this.APARENT.HREXPENSES(I).LIN = AVOID.AINT  # must be a new line
           If CEXP.APARENT.HREXPENSES(I).LIN <> CEXP.LIN  # not current line
             If CEXP.APARENT.HREXPENSES(I).CODEEXP = [F:HRTES]CODEXP
               [L]CNS-=CEXP.APARENT.HREXPENSES(I).RFUCUR
               If [L]CNS<=0 : [L]CNS=0 : Break 2 : Endif
             Endif
           Endif
         #Endif
       Endif
     Next
    Next
   Endif
  Endif
 Endif

Else

 Local Char THIS_FCY(GLONFCY)    : THIS_FCY    = CEXP.APARENT.ETRFCY
 Local Char THIS_REFNUM(GLONMAT) : THIS_REFNUM = CEXP.APARENT.REFNUM

 Case [F:HRTES]TYPVLT
 When 1
  #56776
  #If [L]PAYE>0 : End : Endif
      [L]PAYE=func PARAM([F:HRTES]VLTDEFPAR,THIS_FCY,THIS_REFNUM,[L]DAT,CEXP,TROUVE)
 When 2
  [L]PAYE=func PARAM([F:HRTES]VLTDEFPAR,THIS_FCY,THIS_REFNUM,[L]DAT,CEXP,TROUVE)
 When 3
  [L]BKT=func PARAM("#10553",THIS_FCY,THIS_REFNUM,[L]DAT,CEXP,TROUVE)
  [L]CAT=func PARAM("#10554",THIS_FCY,THIS_REFNUM,[L]DAT,CEXP,TROUVE)
  Local File HREXSKMETRE [HREXK]
  Filter [HREXK] Where find(CPY,"",[L]VCPY)<>0 & DAT<=[L]DAT & BKT=[L]BKT & CAT=[L]CAT
&                  & find(FCY,"",THIS_FCY)<>0
&       Order By Key CLE=FCY Desc;CPY Desc;DAT Desc
  Read [HREXK] First
  Filter [HREXK]
   If fstat = [V]CST_AOK : [L]PAYE=[F:HREXK]RAT : Else [L]PAYE=0 : Endif
 Endcase
Endif

If SOA_GCURSHR<>[L]CUR & CEXP.RATRPT<>0  # make sure RATRPT is on the line ????
 Call CONVERT3( SOA_GCURSHR,[L]CUR,[F:CPY]ACCCUR,CEXP.TYPRAT
&             , [L]DAT,[L]PAYE,[L]PAYE,1/CEXP.RATRPT,[L]STAT
&             ) From CPTSUB_SOA
 Call CONVERT3( SOA_GCURSHR,[L]CUR,[F:CPY]ACCCUR,CEXP.TYPRAT
&             , [L]DAT,[L]CNS,[L]CNS,1/CEXP.RATRPT,[L]STAT
&             ) From CPTSUB_SOA
Endif

[L]PAYE=[L]PAYE*[L]QTY+[L]CNS

## fq 105501
Call INITVA([L]CUR,CEXP.VAT,CEXP.FCY,CEXP.DATEXS,[L]PAYE,CEXP.VATCUR)   # does not need CEXP class
Call INIREMB([L]DAT,CEXP.CODEXP,[L]CUR,[L]QTY,[L]PAYE,CEXP.RFUCUR,CEXP)      # needs CEXP class

#62198
#Note: mkstat is set in INIREMB if there is an error
#We are removing it from here and placing code in INIDEV_CONTROL to check for the error
#If mkstat=2 : End : Endif  #???? V6 this will cause the user to stay in the field - move some code to control ????

Call CONVERT3( [L]CUR,SOA_GCURSHR,[F:CPY]ACCCUR,CEXP.TYPRAT,[L]DAT
&            , [L]PAYE,CEXP.PAYSHR,CEXP.RATCPY,[L]STAT
&            ) From CPTSUB_SOA

#62220
#Call CONVERT3( [L]CUR,[L]CUR,[F:CPY]ACCCUR,[M:EXS0]TYPRAT(nolign-1),[L]DAT
#&            , [L]PAYE,[L]PAYE,[M:EXS0]RATCPY(nolign-1),[L]STAT
#&            ) From CPTSUB
# 67388, maj correction 62220 - il faut arrondir le montant payé et pas le reconvertir.
# sinon, pour les devises de cours <> 1 (à priori toutes sauf devise locale)
# on alimente à tort par le montant en devise locale au lieu de laisser le montant converti
Call CONVERT3( [L]CUR,[L]CUR,[F:CPY]ACCCUR,CEXP.TYPRAT,[L]DAT
&            , [L]PAYE,[L]PAYE,1,[L]STAT
&            ) From CPTSUB_SOA

LogicClose File [CPY]

End
############################################################################################################
Subprog INIREMB(DAT,TES,CUR,QTY,PAYE,REMB,CEXP)
Value    Date    DAT
Value    Char    TES(), CUR()
Value    Decimal QTY,PAYE
Variable Decimal REMB
Variable Instance CEXP Using C_HREXPENSES

Local Char SOA_GCURSHR(30)         : # Currency shared fields
#SOA_GCURSHR = func ADP_TOOL.GET_PARAM(this.ACTX.AFOLDER, 1,"", "CURSHRFLD")
Call GCURSHR(SOA_GCURSHR) From ESSGLOB_SOA

If find("",[L]TES,[L]CUR) | [L]DAT=[0/0/0] | find(0,[L]QTY,[L]PAYE)
 Raz [L]REMB, CEXP.RFUSHR
 End
Endif

Local Integer STAT, TROUVE  # 62198
Local Char VCPY(GLONCPY)
Local Char THIS_FCY(GLONFCY) : THIS_FCY = CEXP.APARENT.ETRFCY
Gosub INICPY
CEXP.CPY = [L]VCPY
#Call LECTURE("TES",[L]TES,"") From CONTOBJ
#Call LECTURE("CPY",[L]CPY,"") From CONTOBJ  # already done in INICPY
Local File HRTABEXPENS [HRTES]
Read [HRTES]HRTES0 = CEXP.TCH_LEG;[L]TES

Case [F:HRTES]TYPVLT
When 3
 [L]REMB     =[L]PAYE
 CEXP.RFUSHR =[L]PAYE
 #62220
 #Call INITAX([L]CUR,[M:EXS0]VAT(nolign-1),[L]PAYE,[M:EXS0]VATCUR(nolign-1),[L]REMB)
 #End
When 2
 [L]REMB=func PARAM([F:HRTES]VLTPFDPAR,CEXP.FCY,CEXP.APARENT.REFNUM,[L]DAT,CEXP,TROUVE)
 If SOA_GCURSHR=[L]CUR
  If [L]REMB>0 : [L]REMB=min([L]PAYE,[L]REMB*[L]QTY)
  Else           [L]REMB=[L]PAYE
  Endif
 Elsif [L]REMB=0 | CEXP.RATRPT=0
  [L]REMB=[L]PAYE
 Else
  Call CONVERT3( SOA_GCURSHR,[L]CUR,[F:CPY]ACCCUR,CEXP.TYPRAT
&              , [L]DAT,[L]REMB,[L]REMB,1/CEXP.RATRPT,[L]STAT
&              ) From CPTSUB_SOA
  [L]REMB=min([L]PAYE,[L]REMB*[L]QTY)
 Endif
When 1
 [L]REMB =[L]QTY
&       * func PARAM([F:HRTES]VLTDEFPAR,CEXP.FCY,CEXP.APARENT.REFNUM,[L]DAT,CEXP,TROUVE)

 # 62198
 # ???? this code cannot run in propogate - need it in control ????
 # move check to control - so when it comes to propogate we should not get this error
 If TROUVE=0
  # Forfait non défini dans la variable
  Raz CEXP.VATCUR
  #GMESSAGE = mess(28,718,1)-[F:TES]VLTDEFPAR    # see INIDEV_CONTROL
  #mkstat=2 : End
 Endif
 # fin 62198

 # 57160
 If SOA_GCURSHR<>[L]CUR
  Call CONVERT3( SOA_GCURSHR,[L]CUR,[F:CPY]ACCCUR,CEXP.TYPRAT
&              , [L]DAT,[L]REMB,[L]REMB,1/CEXP.RATRPT,[L]STAT
&              ) From CPTSUB_SOA
 Endif
 #
Endcase

## fq 1055501
Call INITAX([L]CUR,CEXP.VAT,CEXP.FCY,CEXP.DATEXS,[L]PAYE,CEXP.VATCUR,[L]REMB,CEXP)  # needs CEXP
Call CONVERT3( [L]CUR,SOA_GCURSHR,[F:CPY]ACCCUR,CEXP.TYPRAT,[L]DAT
&            , [L]REMB,CEXP.RFUSHR,CEXP.RATCPY,[L]STAT
&            ) From CPTSUB_SOA
#62220
#Call CONVERT3( [L]CUR,[L]CUR,[F:CPY]ACCCUR,[M:EXS0]TYPRAT(nolign-1),[L]DAT
#&             , [L]REMB,[L]REMB,[M:EXS0]RATCPY(nolign-1),[L]STAT
#&             ) From CPTSUB
# 67388, maj correction 62220 - il faut arrondir le montant payé et pas le reconvertir.
# sinon, pour les devises de cours <> 1 (à priori toutes sauf devise locale)
# on alimente à tort par le montant en devise locale au lieu de laisser le montant converti
Call CONVERT3( [L]CUR,[L]CUR,[F:CPY]ACCCUR,CEXP.TYPRAT,[L]DAT
&             , [L]REMB,[L]REMB,1,[L]STAT
&             ) From CPTSUB_SOA
# fin 62220

LogicClose File [CPY]

End
############################################################################################################
Subprog INITVA(CUR,TAX,FCY,DAT,PAYE,TVA)   ## Fq 105501
Value    Char    CUR(),TAX(), FCY()
Value    Date    DAT
Value    Decimal PAYE
Variable Decimal TVA

If find("",[L]CUR,[L]TAX) | [L]PAYE=0 : [L]TVA=0 : End : Endif

Local Char SOA_GTABCPT(80) : Call GTABCPT(SOA_GTABCPT) From ESSGLOB_SOA
##Call LECTURE("ADI",[L]TAX,"552") From CONTOBJ Fq 105501
#If !clalev([TRA]): Local File =GTABCPT+"TABRATVAT": Endif
Local File =SOA_GTABCPT+"TABRATVAT"

Local Char LEGCPY(GLONCPY)
[L]LEGCPY=func DIVPAYE_SOA.GETSOC(FCY)

Raz [TRA]
Filter [F:TRA] Where VAT=TAX & CPY=[L]LEGCPY & STRDAT<=DAT
Read [F:TRA]TRA1 Last
#If fstat
If fstat <> [V]CST_AOK
   Filter [F:TRA] Where VAT=TAX & CPY="" & STRDAT<=DAT
   Read [F:TRA]TRA1 Last
Endif
Filter [TRA]

##[L]TVA=[F:ADI]N1*0.01*[L]PAYE/(1+[F:ADI]N1*0.01) ##Fq 105501
[L]TVA=[F:TRA]VATRAT*0.01*[L]PAYE/(1+[F:TRA]VATRAT*0.01)  ##Fq 105501
Call ARRDEV([L]TVA,[L]CUR)From TRTDIV_SOA

End
############################################################################################################
Subprog INITAX(CUR,TAX,FCY,DAT,PAYE,TVA,REMB,CEXP)
Value Char    CUR(), TAX(), FCY()
Value Date    DAT
Value Decimal TVA, PAYE, REMB
Variable Instance CEXP Using C_HREXPENSES

If find("",[L]CUR,[L]TAX) | find(0,[L]REMB,[L]PAYE,[L]TVA)
 #Raz [M:EXS0]TAXCUR(nolign-1), [M:EXS0]DEDCUR(nolign-1)
 Raz CEXP.TAXCUR  #????  check that this is called from propogate & can we use Raz
 Raz CEXP.DEDCUR
 End
Endif

## Fq 105501
##Call LECTURE("ADI",[L]TAX,"552") From CONTOBJ

Local Char SOA_GTABCPT(80) : Call GTABCPT(SOA_GTABCPT) From ESSGLOB_SOA
#If !clalev([TRA]): Local File =GTABCPT+"TABRATVAT" : Endif
Local File =SOA_GTABCPT+"TABRATVAT"

Local Char LEGCPY(GLONCPY)
[L]LEGCPY=func DIVPAYE_SOA.GETSOC(FCY)

Local File FACILITY [FCY]
Call LEC_FCY([L]FCY) From CPTLEC_SOA
LogicClose File [FCY]
Raz [TRA]
Filter [F:TRA] Where VAT=TAX & CPY=[L]LEGCPY & STRDAT<=DAT
Read [F:TRA]TRA1 Last
#If fstat
If fstat <> [V]CST_AOK
   Filter [F:TRA] Where VAT=TAX & CPY="" & STRDAT<=DAT
   Read [F:TRA]TRA1 Last
Endif
Filter [TRA]

If [L]REMB<[L]PAYE : CEXP.TAXCUR=[L]TVA*[L]REMB/[L]PAYE
Else                 CEXP.TAXCUR=[L]TVA
Endif
Call ARRDEV(CEXP.TAXCUR,[L]CUR)From TRTDIV_SOA
##[M:EXS0]DEDCUR(nolign-1)=[F:ADI]N2*0.01*[M:EXS0]TAXCUR(nolign-1)  ## Fq 105501
CEXP.DEDCUR=[F:TRA]DEDRAT*0.01*CEXP.TAXCUR           #???? make sure we are in propogate
Call ARRDEV(CEXP.DEDCUR,[L]CUR) From TRTDIV_SOA

End
############################################################################################################
Funprog PARAM(PARAM,FCY,MAT,DAT,CEXP,TROUVE)
Value Char PARAM(), MAT(), FCY()
Value Date DAT
Value Instance CEXP Using C_HREXPENSES
Variable Integer TROUVE :  # 62198

# 62198
TROUVE = 1

#If !clalev([F:EXN]) : Local File EMPLOEXN [EXN] : Endif
Local File EMPLOEXN [EXN]
Local Char CPY(GLONCPY)

Filter [EXN] Where REFNUM=[L]MAT & EXSVAR=[L]PARAM & EXSDAT<=[L]DAT
&     Order By Key CLE=EXSDAT Desc
Read [EXN] First
Filter [EXN]
If fstat = [V]CST_AOK
 End [F:EXN]EXSAMT
Else

 Local File VALEUR [VLA]
 Local File VALFDR [VFD]
 Local File VALFCY [VFC]
 Local File VALCPY [VCP]

 Local Char VCPY(GLONCPY)
 #If [L]FCY>"" : [L]CPY=[V]GSOCSITE(find([L]FCY,[V]GSITE(1..[V]GNBSITE))) : Endif
 If [L]FCY>""
   Local Char THIS_FCY(GLONFCY) : THIS_FCY = CEXP.APARENT.ETRFCY
   Gosub INICPY
   CEXP.CPY = [L]VCPY
 Endif

 Filter [VFC] Where FCY=[L]FCY & DAT<=[L]DAT
 Read [VFC]VFC0 Last
 Filter [VFC]
 If fstat = [V]CST_AOK
  #62911
  #Read [F:VLA]VLA0=3;"";[L]FCY;"";[F:VFD]DAT;[L]PARAM;""
  Read [F:VLA]VLA0=1;CEXP.TCH_LEG;"";"";"";[F:VFC]DAT;[L]PARAM;""

  If fstat = [V]CST_AOK : End [F:VLA]VARVAL : Endif
 Endif

 Filter [VCP] Where CPY=[L]VCPY & DAT<=[L]DAT
 Read [VCP]VCP0 Last
 Filter [VCP]
 If fstat = [V]CST_AOK
  #62911
  #Read [F:VLA]VLA0=2;[L]CPY;"";"";[F:VFD]DAT;[L]PARAM;""
  Read [F:VLA]VLA0=2;CEXP.TCH_LEG;[L]VCPY;"";"";[F:VCP]DAT;[L]PARAM;""
  If fstat = [V]CST_AOK : End [F:VLA]VARVAL : Endif
 Endif

 Filter [VFD] Where DAT<=[L]DAT
 Read [VFD]VFD0 Last
 Filter [VFD]
 If fstat = [V]CST_AOK
  Read [F:VLA]VLA0=1;CEXP.TCH_LEG;"";"";"";[F:VFD]DAT;[L]PARAM;""
  If fstat = [V]CST_AOK : End [F:VLA]VARVAL : Endif
 Endif
 TROUVE = 0
 End 0
 # fin 62077
Endif

LogicClose File [CPY]

End
############################################################################################################
$GET_CTRDAT

# Note: this routine was added to the leave routines - propagate
# but is not necessary as the above have been changed to Order By CTRDAT Desc

Return

# this routine was added for SOA
# it will try to get the relevant contract in order to update the technical field for the contract date
# it is called from CTRNUM, STRDAT, ENDDAT
# it is only used in propagate as we are not trying to change any previous V6/classis logic

If this.REFNUM = AVOID.ACHAR
  Return
Endif
#
If this.STRDAT = AVOID.ADATE
  Return
Endif
#
If this.ENDDAT = AVOID.ADATE
  Return
Endif
#
If this.CTRNUM = AVOID.ACHAR
  Return
Endif

#Local File EMPLOID  [ID9]

# FLGMULCTR flag from employee
#Read [F:ID9]ID0 = this.REFNUM
#If fstat <> [V]CST_AOK
  #LogicClose File [ID9]
  #Return
#Endif

Local File EMPLOCTR [HRCTR9]
#
Filter [HRCTR9] Where REFNUM=this.REFNUM & CTRNUM=this.CTRNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&           & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT) Order By CTRDAT Desc
Read [HRCTR9] First
If fstat = [V]CST_AOK
  this.TCH_CTRDAT = [F:HRCTR9]CTRDAT
Endif
Filter [HRCTR9]

LogicClose File [HRCTR9]

Return
###########################################################################################################
$CALC_TOTALS_PRO

Local Shortint I, J

Raz this.APARENT.TCH_TOTPAY, this.APARENT.TCH_TOTRFU

For J = 1 To maxtab(this.APARENT.HREXPENSES)
  If this.APARENT.HREXPENSES(J) <> null and find(this.APARENT.HREXPENSES(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
    If this.APARENT.HREXPENSES(J).TCH_SNS="+"
      I=1
    Else
      I=-1
    Endif

    this.APARENT.TCH_TOTPAY+=I*this.APARENT.HREXPENSES(J).PAYSHR
    this.APARENT.TCH_TOTRFU+=I*this.APARENT.HREXPENSES(J).RFUSHR
  Endif
Next
Return
