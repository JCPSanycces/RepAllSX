  Endif
Endif

#???? see code below, which has mkstat - review to see if any needs to be placed here - Varshin doing review

Return
#---------------------------
$EXPENSES_PAYCUR_PROPAGATE

Local Integer STAT

Local Char SOA_GCURSHR(30)
Call GCURSHR(SOA_GCURSHR) From ESSGLOB_SOA

## fq 105501
Call INITVA(this.CUR,this.VAT,this.FCY,this.DATEXS,this.PAYCUR
&          , this.VATCUR
&          )
Call INIREMB( this.DATEXS,this.CODEXP
&           , this.CUR, this.QTY, this.PAYCUR
&           , this.RFUCUR, this
&           )
#&           , this                                   # needs class for line of collection
#62198
#If mkstat=2 : End : Endif   #???? this code means that somewhere above mkstat could be set and therefore some
                            # code needs to be moved to control

If this.CUR <> SOA_GCURSHR  : # 67388
 Gosub GET_CPY_
 Call CONVERT3( this.CUR,SOA_GCURSHR,[F:CPY]ACCCUR
&             , this.TYPRAT,this.DATEXS,this.PAYCUR
&             , this.PAYSHR,this.RATCPY,[L]STAT
&             ) From CPTSUB_SOA
Else
 this.PAYSHR = this.PAYCUR : # # 67388
Endif

Gosub CALC_TOTALS_PRO

Return
