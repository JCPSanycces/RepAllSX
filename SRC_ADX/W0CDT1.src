#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CDT1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]COD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]COD
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]COD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varmode([M]DES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]LEG,"909","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]LEG,"909",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]LEG or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_LEG([M]LEG) From SUBCDT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRDIE
mkstat = 0
zoncou = "NBRDIE"
indice = 0
status = 1
zoncou = "NBRDIE"
If varmode([M]NBRDIE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRDIE" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRDIE
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRDIE = nolign
   status = 75
   Call SAI_NBRDIE(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRDIE(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRDIE
mkstat = 0
zoncou = "NBRDIE"

## Zone DIE
mkstat = 0
zoncou = "DIE"
If varmode([M]DIE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DIE" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]DIE(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DIE" : GZNUM = 55843 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("DIE","",[M]DIE(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "DIE" : GZNUM = 55843 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_DIE([M]DIE(indice)) From SUBCDT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DIE" : GZNUM = 55843 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone OPT
mkstat = 0
zoncou = "OPT"
IMPENT = [M]OPT(indice)
If varinit([M]OPT,indice)=0
 IMPENT = 1
Endif
If varmode([M]OPT,indice)=0
 Call INICOMBO(35) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_OPT(IMPENT) From SUBCDT
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,35,1))))
 Endif
 [M]OPT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPT(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "OPT" : GZNUM = 662 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]OPT(indice) = IMPENT

## Zone OBG
mkstat = 0
zoncou = "OBG"
IMPENT = [M]OBG(indice)
If varinit([M]OBG,indice)=0
 IMPENT = 1
Endif
If varmode([M]OBG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_OBG(IMPENT) From SUBCDT
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]OBG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OBG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OBG(indice)
 Endif
Endif
[M]OBG(indice) = IMPENT

## Zone SOH
mkstat = 0
zoncou = "SOH"
IMPENT = [M]SOH(indice)
If varinit([M]SOH,indice)=0
 IMPENT = 1
Endif
If varmode([M]SOH,indice)=0
 [M]SOH(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SOH" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SOH(indice)
 Endif
Endif
[M]SOH(indice) = IMPENT

## Zone NBRDIE
mkstat = 0
zoncou = "NBRDIE"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CDT1"
Return

