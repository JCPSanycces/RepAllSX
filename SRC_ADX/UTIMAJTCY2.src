#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour Liste de gauche objet TCY
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Migration of the TABCOUNTRY table") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTCY # TOGAN: 2014-02-24
End

####################################################################################
##  TOGAN: 2014-02-24
####################################################################################
$MAJTCY
  # the source folder name
  Local Char DOSSRC(GLONADS)
  # the destination folder name
  Local Char DOSDST(GLONADS) : [L]DOSDST = DOSSIER
  # open the folders table
  Local File ADOSSIER [ADS_]
# 2014-12-01 DNE INSERT BEGIN (SAM #104174)
  # Parameter for ATEXTRA update
  Local Char ATEXTRA_ZONE(255)
# 2014-12-01 DNE INSERT END

  # read the record for current folder
  Read [F:ADS_]DOSSIER = [L]DOSDST
  If fstat <> 0 Then
    Close Local File [ADS_]
    # Error reading the file
    Call ECR_TRACE(mess(70,122,1)-"ADOSSIER:"-time$, 1) From GESECRAN
    Return
  Endif
  # obtain the reference folder
  [L]DOSSRC = [F:ADS_]DOSREF
  Close Local File [ADS_]

  # Table update
  Call ECR_TRACE( mess(81,125,1) - "TABCOUNTRY:" - time$, 0 ) From GESECRAN
  # open the TABCOUNTRY table in source folder
  Local File =[L]DOSSRC+".TABCOUNTRY" [TCYS]
  # open the TABCOUNTRY table in destination folder
  Local File =[L]DOSDST+".TABCOUNTRY" [TCYD]
# 2014-12-01 DNE INSERT BEGIN (SAM #104174)
  # Open ATEXTRA tables in source and destination folder for translateable texts.
  Local File =[L]DOSSRC+".ATEXTRA" [AXXS]
  Local File =[L]DOSDST+".ATEXTRA" [AXXD]
# 2014-12-01 DNE INSERT END

  # transaction begin on the destination table
  Trbegin [F:TCYD]

  # loop through the source table
  For [F:TCYS]TCY0
    # read source
    Read [F:TCYD]TCY0 = [F:TCYS]CRY
    # copy the whole record
    [F:TCYD] = [F:TCYS]
    # check the read operation
    If fstat = 0 Then
      # the record exists => update
      Rewrite [F:TCYD]
    Else
      # does not exist => create
      Write [F:TCYD]
    Endif

    # check re/write
    If fstat <> 0 Then
      Call ERREUR( "TABCOUNTRY" - [F:TCYD]CRY, 2 ) From DOSDIC
    Endif

# 2014-12-01 DNE INSERT BEGIN (SAM #104174)
# Reinitialize the translateable texts (CRYDES, ETATNAM, ETATNAM2)
    # Field CRYDES
    ATEXTRA_ZONE = 'CRYDES'
    Gosub UPDATE_ATEXTRA

    # Field ETANAM
    ATEXTRA_ZONE = 'ETANAM'
    Gosub UPDATE_ATEXTRA

    # Field ETANAM2
    ATEXTRA_ZONE = 'ETANAM2'
    Gosub UPDATE_ATEXTRA
# 2014-12-01 DNE INSERT END
  Next

  # Finalize database update
  Commit

# 2014-12-01 DNE INSERT BEGIN (SAM #104174)
  Close Local File [AXXD]
  Close Local File [AXXS]
# 2014-12-01 DNE INSERT END
  Close Local File [TCYD]
  Close Local File [TCYS]
Return


# 2014-12-01 DNE INSERT BEGIN (SAM #104174)
$UPDATE_ATEXTRA
    For [AXXS] Where CODFIC = "TABCOUNTRY" and ZONE = ATEXTRA_ZONE and IDENT1 = [F:TCYS]CRY
        Read [AXXD]AXX0 = [AXXS]CODFIC; [AXXS]ZONE; [AXXS]LANGUE; [AXXS]IDENT1; [AXXS]IDENT2
        [F:AXXD] = [F:AXXS]
        If fstat = 0 Then
            Rewrite [F:AXXD]
        Else
            Write [F:AXXD]
        Endif
        If fstat <> 0 Then
            Call ERREUR( "ATEXTRA" - [AXXS]CODFIC - [AXXS]ZONE - [AXXS]LANGUE - [AXXS]IDENT1 - [AXXS]IDENT2, 2 ) From DOSDIC
        Endif
    Next
Return
# 2014-12-01 DNE INSERT END
