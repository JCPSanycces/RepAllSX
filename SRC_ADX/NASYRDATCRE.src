#<AdxTL>@(#)3.0.0.0 $Revision$
Call TEST
End

Subprog TEST
FreeInstance [REP]
FreeInstance [JSO]
FreeInstance
adxmpr = adxmpr
Local UUIDENT UIDINS                  : # uuid instance
Local Integer NUMLIN                  : # Line number (array)
Local Char    INSFAT(250)             : # Original instance
Local Char    MODELE(30)
Local Clbfile WCLOB
Local Instance ARCV Using C_ASYRRCV
Local Instance ASND Using C_ASYRSND
ARCV = NewInstance With C_ASYRRCV
ASND = NewInstance With C_ASYRSND
Gosub SET_INTERNAL_PARAMETERS From ASYRMEN
Local Instance ACTX Using C_ACONTEXT
ACTX = NewInstance With C_ACONTEXT
ACTX.USER = GUSER
ACTX.LAN = "FRA"
ACTX.LEVWML = 99
Local Char REPRESENTATION
Case GUSER
 When "MBx"   : REPRESENTATION = "ATABLE"
 When Default : REPRESENTATION = "TABCOUNTRY"
Endcase
Gosub POST From ASYRCRE
If 1=1
 Call OUVRE_TRACE("test json post create") From LECFIC
 Openo filpath("TRA",GTRACE,"tra"), -1 Using [JSON]
 Wrseq chr$(10)+"*** Détails clob" Using [JSON]
Dbgaff
 Wrseq WCLOB Using [JSON]
 Wrseq "*** End clob" Using [JSON]
 Openo Using [JSON]
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

#----------------------------------------------------------------#
# JSON create generation    
#----------------------------------------------------------------#

Subprog DETAIL_JSON(REP,WREP,PSYR,UPD,WCLOB)
Variable Instance  REP       Using C_AREPENT
Variable Instance  WREP(1..) Using ="R_"+REP.REP
Variable Instance  PSYR      Using C_ASYR
Variable INSTANCE  UPD(1..)  Using C_ADELTA
Variable Clbfile   WCLOB

Local Instance  JSO(1..) Using C_ASYRJSO

Local Integer I , J , K
Local Integer E , P
Local Char    VRA(250) , VRB(250) , VRC(250) , VRP(250)
Local Integer VRI

Gosub INIVAR From ASYRJSO

Gosub LOAD_JSON_CLASS

If 1=1 & GUSER="MB"
 Call OUVRE_TRACE("test json post create") From LECFIC
 For I=1 To maxtab(JSO)
  Call ECR_TRACE(format$("N:####",JSO(I).S)+format$("N:####",JSO(I).N)+format$("N:####",JSO(I).O)+format$("N:####",JSO(I).F)
& +space$(JSO(I).O)+JSO(I).PRO-left$(JSO(I).CNT,50)-string$(I=1,"SouNexNivPèr"),0) From GESECRAN
 Next I
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif

Call GENERATE_JSON(JSO,WCLOB) From ASYRJSO

End

#---------------------------------#
$LOAD_JSON_CLASS

# Header

NIV = 1
Gosub ADDJSO From ASYRJSO
JSO(NBJ).PRO = ''
JSO(NBJ).CNT = ''

NIV += 1
Gosub ADDJSO From ASYRJSO
JSO(NBJ).PRO = '"$trackingId"'
JSO(NBJ).CNT = '"'+func ASYRSUB.STRING_TO_SYR(num$(PSYR.WRKUID))+'"'
Gosub ADDJSO From ASYRJSO
JSO(NBJ).PRO = '"$baseUrl"'
JSO(NBJ).CNT = '"'+PSYR.PREFIX+'"'
Gosub ADDJSO From ASYRJSO
JSO(NBJ).PRO = '"$url"'
JSO(NBJ).CNT = '"{$baseUrl}/'+PSYR.URLUPD+"('"+func ASYRSUB.STRING_TO_SYR(num$(PSYR.WRKUID))+"')"+PSYR.URLREP+REP.REP+'.$edit"'
Gosub ADDJSO From ASYRJSO
JSO(NBJ).PRO = '"$type"'
JSO(NBJ).CNT = '"'+PSYR.PRELNK+'"'

INSPAR = "WREP"
INSCLA = REP.NIV(1).ICL

# Header fields

TYP = 7
VRA = PROENT(1)
VRC = "uuid"
Gosub HEADER_PRO From ASYRDATDET

Gosub ADDJSO From ASYRJSO
JSO(NBJ).PRO = '"$etag"'
JSO(NBJ).CNT = "1"

# Errors and attributes of properties

K = 0
P = 0
For I=1 To MAXTAB(UPD)

 If UPD(I)<>NULL & left$(UPD(I).PRO,1)<>"$"

  # Attributes
  For J=1 To MAXTAB(UPD(I).ATT)
   If K=0
    K = 1
    Gosub ADDJSO From ASYRJSO
    JSO(NBJ).PRO = '"$"'
    JSO(NBJ).CNT = ""
    NIV += 1
   Endif
   If P=0
    P = 1
    Gosub ADDJSO From ASYRJSO
    JSO(NBJ).PRO = '"'+UPD(I).PRO+'"'
    JSO(NBJ).CNT = ""
    NIV += 1
   Endif
   Gosub ADDJSO From ASYRJSO
   JSO(NBJ).PRO = '"'+UPD(I).ATT(J).COD+'"'
   JSO(NBJ).CNT = UPD(I).ATT(J).ATT
  Next J

  # Diagnoses
  E = 0
  For J=1 To MAXTAB(UPD(I).ERR)
   If K=0
    K = 1
    Gosub ADDJSO From ASYRJSO
    JSO(NBJ).PRO = '"$"'
    JSO(NBJ).CNT = ""
    NIV += 1
   Endif
   If P=0
    P = 1
    Gosub ADDJSO From ASYRJSO
    JSO(NBJ).PRO = '"'+UPD(I).PRO+'"'
    JSO(NBJ).CNT = ""
    NIV += 1
   Endif
   If E=0
    E = 1
    Gosub ADDJSO From ASYRJSO
    JSO(NBJ).PRO = '"diagnoses"'
    JSO(NBJ).CNT = ""
    NIV += 1
    Gosub ADDENU From ASYRJSO
    JSO(NBJ).PRO = ''
    JSO(NBJ).CNT = ""
    NIV += 1
   Else
    Gosub ADDJSO From ASYRJSO
    JSO(NBJ).PRO = ''
    JSO(NBJ).CNT = ""
    NIV += 1
   Endif
   Gosub ADDJSO From ASYRJSO
   JSO(NBJ).PRO = '"severity"'
   JSO(NBJ).CNT = '"'+func ASYRSUB.ERROR(UPD(I).ERR(J).STA)+'"'
   Gosub ADDJSO From ASYRJSO
   JSO(NBJ).PRO = '"message"'
   JSO(NBJ).CNT = ""
   If JSO(NBJ).CNT="" : JSO(NBJ).CNT += '"' : Endif
   JSO(NBJ).CNT += func ASYRSUB.STRING_TO_SYR(UPD(I).ERR(J).MES)
   If UPD(I).ERR(J).NUM<>0 
    If JSO(NBJ).CNT="" : JSO(NBJ).CNT += '"' : Endif
    JSO(NBJ).CNT += ' ('+num$(UPD(I).ERR(J).NUM)+')'
   Endif
   If JSO(NBJ).CNT<>"" : JSO(NBJ).CNT += '"' : Endif
   Gosub ENDNIV From ASYRJSO
  Next J
  If E
   Gosub ENDNIV From ASYRJSO
  Endif
 
  If P
   Gosub ENDNIV From ASYRJSO
  Endif

 Endif

Next I

If K
 Gosub ENDNIV From ASYRJSO
Else
 Gosub ADDJSO From ASYRJSO
 JSO(NBJ).PRO = '"$"'
 JSO(NBJ).CNT = ""
 NIV += 1
 Gosub ADDJSO From ASYRJSO
 JSO(NBJ).PRO = '"diagnoses"'
 JSO(NBJ).CNT = "[]"
 Gosub ENDNIV From ASYRJSO
Endif

# Properties initialized

For I=1 To MAXTAB(UPD)
 If UPD(I)<>NULL & left$(UPD(I).PRO,1)<>"$"
  Gosub ADDJSO From ASYRJSO
  JSO(NBJ).PRO = '"'+UPD(I).PRO+'"'
  JSO(NBJ).CNT = UPD(I).CAR.CAR
 Endif
Next I

# Buttons

K = 0
For I=1 To MAXTAB(UPD)
 If UPD(I)<>NULL & left$(UPD(I).PRO,1)="$"
  If K=0
   K = 1
   Gosub ADDJSO From ASYRJSO
   JSO(NBJ).PRO = '"$actions"'
   JSO(NBJ).CNT = ""
   NIV += 1
  Endif
  Gosub ADDJSO From ASYRJSO
  JSO(NBJ).PRO = '"'+UPD(I).PRO+'"'
  JSO(NBJ).CNT = ""
  NIV += 1
  Gosub ADDJSO From ASYRJSO
  JSO(NBJ).PRO = '"$title"'
  JSO(NBJ).CNT = '"'+UPD(I).CAR.CAR+'"'
  For J=1 To MAXTAB(UPD(I).ATT)
   Gosub ADDJSO From ASYRJSO
   JSO(NBJ).PRO = '"'+UPD(I).ATT(J).COD+'"'
   JSO(NBJ).CNT = UPD(I).ATT(J).ATT
  Next J
  Gosub ENDNIV From ASYRJSO
 Endif
Next I
If K
 Gosub ENDNIV From ASYRJSO
Endif

Return

