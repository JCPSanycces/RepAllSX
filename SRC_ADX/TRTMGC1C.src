#<AdxTL>@(#)10.0.0.0 $Revision$
#######################################################################################################################
#  Gestion du ciblage marketing                                              Module CRM          26 juin 2002
#######################################################################################################################
#  Traitement de gestion des impressions des ciblages
#######################################################################################################################
# Liste des sous-programmes :
#   PRINTVISU     : Impression pour visualisation ou extraction
#######################################################################################################################
#####################################################################
# Impression pour visualisation
#####################################################################
Subprog PRINTVISU(SZQURNUM, IDISPPPL, ITOTPNL, IEXTRACT)
Value Char SZQURNUM
Value Integer IDISPPPL
Value Integer ITOTPNL
Value Integer IEXTRACT

Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
Local Char SZTGR
Local Char SZPRETAB
Local Char SZFIEZOOM
Local Char SZKEYLNK
Local Integer ITER
Local Integer ICRIFIETYP
Local Char SZQUITMASK(9)
Local Char SZTABSRT
Local Char SZABRSRT
Local Char SZFIESRT
Local Char SZABRTGR
Local Char SZSRTDICOTYP
Local Integer ISRTTYP
Local Integer ISRTMGC1
Local Integer ISRTDATATYP
Local Integer IONLY1KEY
Local Integer ILIBITER
Local Integer ITERCOL2
Local Integer IADISEPARATOR
Local Char SZADXIFS
Local Char SZADXIRS

#Variables traitement généré n°1
Local Char SZPROGNAME
Local Integer IPRGSUFIX
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer IEXIST

#Variables traitement généré n°2
Local Char SZPROG2NAME
Local Integer IPRG2SUFIX
Local Char SZFULL2SRC(250)
Local Char SZFULL2ADX(250)
Local Integer I2EXIST
Local Char SZTEXTE(GLONDCO)

  IADISEPARATOR = 0
  SZSRTDICOTYP = ""
  SZKEYLNK = ""
  SZFIEZOOM = ""
  SZTABSRT = ""
  SZABRSRT = ""
  SZFIESRT = ""
  SZABRTGR = ""
  ILIBITER = 0
  IONLY1KEY = 0
  ISRTTYP = 0
  ISRTMGC1 = 0
  ISRTDATATYP = 0
  ITERCOL2 = 0
  SZQUITMASK = "000000000"
  #Ouverture de la jauge de progression
  If !GINTRA Then
    Call OUVRE_BOITE(mess(392,196,1), [M:MGC1]TOTPNL) From GESECRAN   #Préparation des données.
  Else
    Call TEMPON("R") From GESECRAN
  Endif
  #Recalcul tout d'abord les titres des colonnes des champs.
  If [M:MGC1]TGRPNL <> "" Then
    If [M:MGC1]TGPNUMX <> "" Then
      Filter [TLF] Where [F:TLF]TGRTAB = [M:MGC1]TGRPNL and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX Order By [F:TLF]TGRFIEORD
      ITERCOL2 = 0
      For [TLF] Hint Key TLF0
        If ITERCOL2 >= dim(GMGCCOLX) Then
          Break
        Endif
        #On prend d'abord le nom du champ depuis la définition des critères de ciblage
        #Sinon depuis ATABZON
        Read [FDF]FDF0=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE;GAUSCRMI
        If fstat Then
          Read [FDF]FDF0=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE;""
          If fstat Then
            Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
            If fstat Then
              GMGCCOLX(ITERCOL2) = [F:TLF]TGRFIE
            Else
              Call TEXTE([F:ATZ]NOLONG, GMGCCOLX(ITERCOL2)) From OBJDIV
            Endif
          Else
            Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
            If SZTEXTE = "" Then
              Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
              If fstat Then
                GMGCCOLX(ITERCOL2) = [F:TLF]TGRFIE
              Else
                Call TEXTE([F:ATZ]NOLONG, GMGCCOLX(ITERCOL2)) From OBJDIV
              Endif
            Else
              GMGCCOLX(ITERCOL2) = SZTEXTE
            Endif
          Endif
        Else
          Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
          If SZTEXTE = "" Then
            Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
            If fstat Then
              GMGCCOLX(ITERCOL2) = [F:TLF]TGRFIE
            Else
              Call TEXTE([F:ATZ]NOLONG, GMGCCOLX(ITERCOL2)) From OBJDIV
            Endif
          Else
            GMGCCOLX(ITERCOL2) = SZTEXTE
          Endif
        Endif
        ITERCOL2 += 1
      Next
      Filter [TLF]
    Endif
  Endif
  #On sauvegarde les variables adxifs et adxirs
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  ################################
  #On génère un fichier de code d'exécution d'un affichage de ciblage
  Raz SZPROGNAME
  Raz SZFULLSRC
  Raz SZFULLADX
  Raz IEXIST
  IPRGSUFIX = 1
  While 1
    SZPROGNAME = "CRMRB" + num$(IPRGSUFIX)
    SZFULLSRC = filpath("TRT", SZPROGNAME, "src", nomap)
    SZFULLADX = filpath("TRT", SZPROGNAME, "adx", nomap)
    #Contrôle de l'existence du src
    IEXIST = 0
    Call EXISTE(SZFULLSRC,IEXIST) From ORDSYS
    If IEXIST Then
      #Calcul un nouveau suffixe pour le traitement
      IPRGSUFIX += 1
    Else
      #Contrôle de l'existence de l'adx
      IEXIST = 0
      Call EXISTE(SZFULLADX,IEXIST) From ORDSYS
      If IEXIST Then
        #Calcul un nouveau suffixe pour le traitement
        IPRGSUFIX += 1
      Else
        Break
      Endif
    Endif
  Wend
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [CRM3]
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [CRM3]
  Wrseq "#Traitement généré d'exécution de l'affichage du résultat d'un ciblage marketing" Using [CRM3]
  Wrseq "Subprog FILLQTX" Using [CRM3]
  #############################
  #On génére un sous-programme d'ouverture de tables pour effectuer des contrôles de types
  Raz SZPROG2NAME
  Raz SZFULL2SRC
  Raz SZFULL2ADX
  Raz I2EXIST
  IPRG2SUFIX = 1
  #Détermine un nom disponible pour le traitement
  While 1
    SZPROG2NAME = "CRMRC" + num$(IPRG2SUFIX)
    SZFULL2SRC = filpath("TRT", SZPROG2NAME, "src", nomap)
    SZFULL2ADX = filpath("TRT", SZPROG2NAME, "adx", nomap)
    #Contrôle de l'existence du src
    I2EXIST = 0
    Call EXISTE(SZFULL2SRC,I2EXIST) From ORDSYS
    If I2EXIST Then
      #Calcul un nouveau suffixe pour le traitement
      IPRG2SUFIX += 1
    Else
      #Contrôle de l'existence de l'adx
      I2EXIST = 0
      Call EXISTE(SZFULL2ADX,I2EXIST) From ORDSYS
      If I2EXIST Then
        #Calcul un nouveau suffixe pour le traitement
        IPRG2SUFIX += 1
      Else
        Break
      Endif
    Endif
  Wend
  #############################
  #Ouverture du traitement à générer
  Openo SZFULL2SRC, 0 Using [CRM4]
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [CRM4]

  Wrseq "#Traitement généré d'ouverture de tables pour contrôle de type" Using [CRM4]
  Wrseq "$OPENTAB" Using [CRM4]

  #Ouvre toutes les tables à utiliser
  #D'abord la table QURTMP
  Wrseq "If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif" Using [CRM3]

  #Ensuite la table cible
  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "111011011"
    Gosub QPRINTVISU
    End
  Endif
  SZTGR = [F:MQR]TGR
  Read [ATB]CODFIC=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "111011011"
    Gosub QPRINTVISU
    End
  Endif

  Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:MQR]TGR + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM3]
  Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:MQR]TGR + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM4]

  #Ensuite les tables de critères
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX
  SZPRETAB = ""
  For [TLF] TLF1
    If [F:TLF]TGRTABLNK <> "" Then
      If [F:TLF]TGRTABLNK <> SZTGR Then
        If [F:TLF]TGRTABLNK <> SZPRETAB
          SZPRETAB = [F:TLF]TGRTABLNK
          Read [ATB]CODFIC=SZPRETAB
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "111011011"
            Gosub QPRINTVISU
            Break
          Else
            Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + SZPRETAB + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM3]
            Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + SZPRETAB + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM4]
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [TLF]
  If GERR Then
    End
  Endif
  Wrseq "Return" Using [CRM4]

  #Génération du sous-programme de fermeture des tables utilisées pour le contrôle de type.
  #D'abord la table cible
  Wrseq "$CLOSETAB" Using [CRM4]
  Read [ATB]CODFIC=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "111011011"
    Gosub QPRINTVISU
    End
  Else
    Wrseq "Close Local File [" + [F:ATB]ABRFIC + ']' Using [CRM4]
  Endif

  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX
  SZPRETAB = ""
  For [TLF] TLF1
    If [F:TLF]TGRTABLNK <> "" Then
      If [F:TLF]TGRTABLNK <> SZTGR Then
        If [F:TLF]TGRTABLNK <> SZPRETAB Then
          SZPRETAB = [F:TLF]TGRTABLNK
          Read [ATB]CODFIC=SZPRETAB
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "111011011"
            Gosub QPRINTVISU
            Break
          Else
            Wrseq "Close Local File [" + [F:ATB]ABRFIC + ']' Using [CRM4]
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [TLF]
  If GERR Then
    End
  Endif
  Wrseq "Return" Using [CRM4]
  Wrseq "#Fin du traitement généré" Using [CRM4]

  #Fermeture du traitement généré
  Openo Using [CRM4]

  #Compilation du traitement généré
  Local Integer IVALIDOK

  IVALIDOK = 1
  Call VALID("TRT", SZPROG2NAME, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "111001111"
    Gosub QPRINTVISU
    End
  Endif
  If GMESSAGE <> "" Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "111001111"
    Gosub QPRINTVISU
    End
  Endif

  #Création du Link
  Read [ATB]CODFIC=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "111001111"
    Gosub QPRINTVISU
    End
  Else
    SZABRTGR = [F:ATB]ABRFIC
    Read [TGL]TGL0=SZTGR
    If fstat Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "111001111"
      Gosub QPRINTVISU
      End
    Else
      GSZMGCZOOM = [F:TGL]TGRAOB
      Read [TGP]TGP0=[M:MGC1]TGPNUMX
      If fstat Then
        #Erreur. Il faut nettoyer les ressources avant de dépiler.
        SZQUITMASK = "111001111"
        Gosub QPRINTVISU
        End
      Else
        SZTABSRT = [F:TGP]TABSRT
        SZFIESRT = [F:TGP]FIESRT
        ISRTTYP = [F:TGP]FIESRTTYP
        Wrseq "Link [" + [F:ATB]ABRFIC + "] With" Using [CRM3]
        #On link toujours avec QURTMP
        Wrseq "& [QTP]QTP2 = [F:" + [F:ATB]ABRFIC + ']' + [F:TGL]TGRMAIKEY Using [CRM3]
        SZFIEZOOM = "[F:" + [F:ATB]ABRFIC + ']' + [F:TGL]TGRMAIKEY
      Endif
    Endif
  Endif

  #Génération des expressions de lien
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX
  SZPRETAB = ""
  For [TLF] TLF1
    If [F:TLF]TGRTABLNK <> "" Then
      If [F:TLF]TGRTABLNK <> SZTGR Then
        If [F:TLF]TGRTABLNK <> SZPRETAB Then
          SZPRETAB = [F:TLF]TGRTABLNK
          Read [TLL]TLL0=SZTGR;[F:TLF]TGRTABLNK
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "111001111"
            Gosub QPRINTVISU
            Break
          Else
            Read [ATB]CODFIC=[F:TLL]TGRLNK
            If fstat Then
              #Erreur. Il faut nettoyer les ressources avant de dépiler.
              SZQUITMASK = "111001111"
              Gosub QPRINTVISU
              Break
            Else
              Wrseq "& ,[" + [F:ATB]ABRFIC + ']' + [F:TLL]TGRLNKIDX + ' = ' + [F:TLL]TGREXPLNK Using [CRM3]
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [TLF]
  If GERR Then
    End
  Endif

  Wrseq "& As [LNK]" Using [CRM3]
  #Définit l'ordre de tri pour l'affichage du résultat.
  Read [TGL]TGL0=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "111001111"
    Gosub QPRINTVISU
    End
  Else
    Read [ATB]CODFIC=SZTABSRT
    If fstat Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "111001111"
      Gosub QPRINTVISU
      End
    Else
      SZABRSRT = [F:ATB]ABRFIC
      SZKEYLNK = "[F:" + [F:ATB]ABRFIC + ']' + SZFIESRT
      If SZKEYLNK = SZFIEZOOM Then
        IONLY1KEY = 1
        If ISRTTYP = 1 Then
          #Tri ascendant
          Wrseq "& Order By Key KBID = " + SZKEYLNK + " Asc" Using [CRM3]
        Elsif ISRTTYP = 2 Then
          #Tri descendant
          Wrseq "& Order By Key KBID = " + SZKEYLNK + " Desc" Using [CRM3]
        Endif
      Else
        IONLY1KEY = 0
        If ISRTTYP = 1 Then
          #Tri ascendant
          Wrseq "& Order By Key KBID = " + SZKEYLNK + " Asc; " + SZFIEZOOM + " Asc" Using [CRM3]
        Elsif ISRTTYP = 2 Then
          #Tri descendant
          Wrseq "& Order By Key KBID = " + SZKEYLNK + " Desc; " + SZFIEZOOM + " Desc" Using [CRM3]
        Endif
      Endif
    Endif
  Endif

  #Détermine quelle est la colonne qui contient le champ de tri
  ITER = 1
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX Order By [F:TLF]TGRFIEORD Asc
  For [TLF] Hint Key TLF0
    #If ITER > 15 Then
    If ITER >= dim(GMGCCOLX) Then
      Break
    Endif
    If [F:TLF]TGRFIE = SZFIESRT Then
      If [F:TLF]TGRTABLNK = SZTABSRT Then
        ISRTMGC1 = ITER
        Break
      Endif
    Endif
    ITER += 1
  Next
  Filter [TLF]

  #On ouvre les tables nécessaires aux contrôles de type des champs
  Gosub OPENTAB From =SZPROG2NAME

  #Détermine le type du champ de tri
  ISRTDATATYP = evalue("Type([F:" + SZABRSRT + "]" + SZFIESRT + ")")

  #Détermine le type dictionnaire du champ de tri
  If ISRTDATATYP = 1 or ISRTDATATYP = 2 Then
    #Numérique
    Read [ATZ]CODZONE=SZTABSRT;SZFIESRT
    If fstat Then
      SZSRTDICOTYP = "L"
    Else
      If [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
        SZSRTDICOTYP = "M"
      Else
        SZSRTDICOTYP = "L"
      Endif
    Endif
  Elsif ISRTDATATYP >= 4 and ISRTDATATYP <= 9 Then
    #Numérique
    Read [ATZ]CODZONE=SZTABSRT;SZFIESRT
    If fstat Then
      SZSRTDICOTYP = "L"
    Else
      If [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
        SZSRTDICOTYP = "M"
      Else
        SZSRTDICOTYP = "L"
      Endif
    Endif
  Endif

  #Les liens sont posés
  #On place le filtre sur QURTMP
  If !IONLY1KEY Then
    If ISRTDATATYP = 1 or ISRTDATATYP = 2 Then
      #Numérique
      Wrseq "Local Integer UMGCLASF" Using [CRM3]
    Elsif ISRTDATATYP = 3 Then
      #Date
      Wrseq "Local Date UMGCLASF" Using [CRM3]
    Elsif ISRTDATATYP >= 4 and ISRTDATATYP <= 9 Then
      #Numérique
      Wrseq "Local Integer UMGCLASF" Using [CRM3]
    Elsif ISRTDATATYP >= 10 Then
      #Alpha
      Wrseq "Local Char UMGCLASF" Using [CRM3]
    Endif
  Endif

  Wrseq "Local Integer IPERF" Using [CRM3]
  Wrseq "Local Integer INTR" Using [CRM3]
  Wrseq "Local Integer IPBL" Using [CRM3]
  Wrseq "Local Char SZMGCLASK" Using [CRM3]
  Wrseq "Local Integer STOPLOOP" Using [CRM3]
  Wrseq "Local Integer ICUTCOUNT" Using [CRM3]
  Wrseq "Local Integer COK" Using [CRM3]
  Wrseq "Local Integer CCOUNT" Using [CRM3]
  Wrseq "IPERF = 0" Using [CRM3]
  Wrseq "INTR = 0" Using [CRM3]
  Wrseq "IPBL = 0" Using [CRM3]
  Wrseq "STOPLOOP = 0" Using [CRM3]
  Wrseq "ICUTCOUNT = 0" Using [CRM3]
  Wrseq "CCOUNT = 0" Using [CRM3]
  Wrseq "COK = 0" Using [CRM3]
  If IONLY1KEY Then
    Wrseq "$SNAPLOOP" Using [CRM3]
    Wrseq "If STOPLOOP = 1" Using [CRM3]
    Wrseq "STOPLOOP = 0" Using [CRM3]
    If ISRTTYP = 1 Then
      #Ascendant
      Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
      Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
      Wrseq "& and [F:QTP]KEYTGR > SZMGCLASK" Using [CRM3]
    Elsif ISRTTYP = 2 Then
      #Descendant
      Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
      Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
      Wrseq "& and [F:QTP]KEYTGR < SZMGCLASK" Using [CRM3]
    Endif
    Wrseq "Else" Using [CRM3]
    Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
    Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
    Wrseq "Endif" Using [CRM3]
  Else
    Wrseq "$SNAPLOOP" Using [CRM3]
    Wrseq "If STOPLOOP = 1" Using [CRM3]
    Wrseq "STOPLOOP = 2" Using [CRM3]
    If ISRTTYP = 1 Then
      #Ascendant
      Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
      Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
      Wrseq "& and [F:" + SZABRSRT + ']' + SZFIESRT + " = UMGCLASF" Using [CRM3]
      Wrseq "& and [F:QTP]KEYTGR > SZMGCLASK" Using [CRM3]
    Elsif ISRTTYP = 2 Then
      #Descendant
      Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
      Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
      Wrseq "& and [F:" + SZABRSRT + ']' + SZFIESRT + " = UMGCLASF" Using [CRM3]
      Wrseq "& and [F:QTP]KEYTGR < SZMGCLASK" Using [CRM3]
    Endif
    Wrseq "Elsif STOPLOOP = 2" Using [CRM3]
    Wrseq "STOPLOOP = 0" Using [CRM3]
    If ISRTTYP = 1 Then
      #Ascendant
      Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
      Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
      Wrseq "& and [F:" + SZABRSRT + ']' + SZFIESRT + " > UMGCLASF" Using [CRM3]
    Elsif ISRTTYP = 2 Then
      #Descendant
      Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
      Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
      Wrseq "& and [F:" + SZABRSRT + ']' + SZFIESRT + " < UMGCLASF" Using [CRM3]
    Endif
    Wrseq "Else" Using [CRM3]
    Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
    Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
    Wrseq "Endif" Using [CRM3]
  Endif
  Wrseq "ICUTCOUNT = 0" Using [CRM3]
  Wrseq "For [LNK] KBID" Using [CRM3]
  Wrseq "If IPERF = 0" Using [CRM3]
  Wrseq "Call DEBTRANS From GLOCK" Using [CRM3]
  Wrseq "Trbegin [QTX]" Using [CRM3]
  Wrseq "INTR = 1" Using [CRM3]
  Wrseq "Endif" Using [CRM3]
  Wrseq "Raz [F:QTX]" Using [CRM3]
  ITER = 1
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX Order By [F:TLF]TGRFIEORD Asc
  For [TLF]
    #If ITER > 15 Then
    If ITER >= dim(GMGCCOLX) Then
      Break
    Endif
    Read [ATB]CODFIC=[F:TLF]TGRTABLNK
    If fstat Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "111001111"
      Gosub QPRINTVISU
      Break
    Else
      ICRIFIETYP = evalue("Type([F:" + [F:ATB]ABRFIC + "]" + [F:TLF]TGRFIE + ")")
      If ICRIFIETYP = 1 or ICRIFIETYP = 2 Then
        If ITER = ISRTMGC1 Then
          If !IONLY1KEY Then
            Wrseq "UMGCLASF = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
          Endif
        Endif
        Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
        If fstat Then
          Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
          If ITER = ISRTMGC1 Then
            Wrseq "[F:QTX]MGCCOLSRTA = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
            Wrseq "[F:QTX]MGCCOLSRTL = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
          Endif
        Else
          If [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
            Wrseq "If [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + " = 0" Using [CRM3]
            Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = " + '"' + '"' Using [CRM3]
            If ITER = ISRTMGC1 Then
              Wrseq "[F:QTX]MGCCOLSRTA = " + '"' + '"' Using [CRM3]
            Endif
            Wrseq "Else" Using [CRM3]
            Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = mess([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + "," + num$([F:ATZ]NOLIB) + ",1)" Using [CRM3]
            If ITER = ISRTMGC1 Then
              Wrseq "[F:QTX]MGCCOLSRTA = mess([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + "," + num$([F:ATZ]NOLIB) + ",1)" Using [CRM3]
            Endif
            Wrseq "Endif" Using [CRM3]
          Else
            Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
            If ITER = ISRTMGC1 Then
              Wrseq "[F:QTX]MGCCOLSRTA = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
              Wrseq "[F:QTX]MGCCOLSRTL = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Endif
          Endif
        Endif
      Elsif ICRIFIETYP = 3 Then
        If ITER = ISRTMGC1 Then
          If !IONLY1KEY Then
            Wrseq "UMGCLASF = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
          Endif
        Endif
        Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = format$(GFMD,[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
        If ITER = ISRTMGC1 Then
          Wrseq "[F:QTX]MGCCOLSRTA = format$(GFMD,[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
          Wrseq "[F:QTX]MGCCOLSRTD = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
        Endif
      Elsif ICRIFIETYP >= 4 and ICRIFIETYP <= 9 Then
        If ITER = ISRTMGC1 Then
          If !IONLY1KEY Then
            Wrseq "UMGCLASF = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
          Endif
        Endif
        Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
        If fstat Then
          Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
          If ITER = ISRTMGC1 Then
            Wrseq "[F:QTX]MGCCOLSRTA = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
            Wrseq "[F:QTX]MGCCOLSRTL = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
          Endif
        Else
          If [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
            Wrseq "If [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + " = 0" Using [CRM3]
            Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = " + '"' + '"' Using [CRM3]
            If ITER = ISRTMGC1 Then
              Wrseq "[F:QTX]MGCCOLSRTA = " + '"' + '"' Using [CRM3]
            Endif
            Wrseq "Else" Using [CRM3]
            Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = mess([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + "," + num$([F:ATZ]NOLIB) + ",1)" Using [CRM3]
            If ITER = ISRTMGC1 Then
              Wrseq "[F:QTX]MGCCOLSRTA = mess([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + "," + num$([F:ATZ]NOLIB) + ",1)" Using [CRM3]
            Endif
            Wrseq "Endif" Using [CRM3]
          Else
            Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
            If ITER = ISRTMGC1 Then
              Wrseq "[F:QTX]MGCCOLSRTA = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
              Wrseq "[F:QTX]MGCCOLSRTL = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Endif
          Endif
        Endif
      Elsif ICRIFIETYP >= 10 and ICRIFIETYP < 500 Then  # FGR 04/02/20151 : X3SUIVI105938
        If ITER = ISRTMGC1 Then
          If !IONLY1KEY Then
            Wrseq "UMGCLASF = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
          Endif
        Endif
        Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
        If fstat Then
          Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
          If ITER = ISRTMGC1 Then
            Wrseq "[F:QTX]MGCCOLSRTA = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
          Endif
        Else
          If [F:ATZ]CODTYP = "ADI" Then
            IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
            IADISEPARATOR -= 1
            Wrseq "Read [ADI] CODE = " + left$([F:ATZ]EXPLIEN, IADISEPARATOR) + ";[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Wrseq "If fstat" Using [CRM3]
            Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            If ITER = ISRTMGC1 Then
              Wrseq "[F:QTX]MGCCOLSRTA = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Endif
            Wrseq "Else" Using [CRM3]
            Wrseq "Call GET_LIB(" + left$([F:ATZ]EXPLIEN, IADISEPARATOR) + ",[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ", [F:QTX]MGCCOL" + num$(ITER) + ") From CRM_UTIL" Using [CRM3]
            If ITER = ISRTMGC1 Then
              Wrseq "Call GET_LIB(" + left$([F:ATZ]EXPLIEN, IADISEPARATOR) + ",[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ", [F:QTX]MGCCOLSRTA) From CRM_UTIL" Using [CRM3]
            Endif
            Wrseq "Endif" Using [CRM3]
          Else
            Wrseq "[F:QTX]MGCCOL" + num$(ITER) + " = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            If ITER = ISRTMGC1 Then
              Wrseq "[F:QTX]MGCCOLSRTA = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Endif
          Endif
        Endif
      Endif
    Endif
    ITER += 1
  Next
  Filter [TLF]
  If GERR Then
    End
  Endif
  Wrseq "[F:QTX]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
  Wrseq "[F:QTX]MGCCOLSRTK = " + SZFIEZOOM Using [CRM3]
  For ILIBITER = 0 To dim(GMGCCOLX)-1
    If GMGCCOLX(ILIBITER) <> "" Then
      Wrseq "[F:QTX]MGCTIT" + num$(ILIBITER+1) + " = " + '"' + GMGCCOLX(ILIBITER) + '"' Using [CRM3]
    Endif
  Next
  Wrseq "Write [QTX]" Using [CRM3]
  Wrseq "If fstat" Using [CRM3]
  Wrseq "Rollback" Using [CRM3]
  Wrseq "GERR = 1" Using [CRM3]
  Wrseq "IPBL = 1" Using [CRM3]
  Wrseq "INTR = 0" Using [CRM3]
  Wrseq "STOPLOOP = 0" Using [CRM3]
  Wrseq "Break"  Using [CRM3]
  Wrseq "Else" Using [CRM3]
  Wrseq "If IPERF >= 500" Using [CRM3]
  Wrseq "Commit" Using [CRM3]
  Wrseq "IPERF = 0" Using [CRM3]
  Wrseq "INTR = 0" Using [CRM3]
  Wrseq "Else" Using [CRM3]
  Wrseq "IPERF += 1" Using [CRM3]
  Wrseq "Endif" Using [CRM3]
  Wrseq "ICUTCOUNT += 1" Using [CRM3]
  Wrseq "If ICUTCOUNT >= 5000" Using [CRM3]
  Wrseq "SZMGCLASK = [F:QTP]KEYTGR" Using [CRM3]
  Wrseq "STOPLOOP = 1" Using [CRM3]
  Wrseq "Break" Using [CRM3]
  Wrseq "Endif" Using [CRM3]
  Wrseq "Endif" Using [CRM3]
  If !GINTRA Then
    Wrseq "CCOUNT += 1" Using [CRM3]
    Wrseq "Call AFF_BOITE (mess(392,196,1), CCOUNT, COK) From GESECRAN" Using [CRM3]
  Endif
  Wrseq "Next" Using [CRM3]
  Wrseq "Filter [LNK]" Using [CRM3]
  Wrseq "If STOPLOOP" Using [CRM3]
  Wrseq "Goto SNAPLOOP" Using [CRM3]
  Wrseq "Endif" Using [CRM3]
  Wrseq "If INTR" Using [CRM3]
  Wrseq "If !IPBL" Using [CRM3]
  Wrseq "Commit" Using [CRM3]
  Wrseq "Endif" Using [CRM3]
  Wrseq "Endif" Using [CRM3]

  #On ferme les tables utilisées pour le contrôle de type
  Gosub CLOSETAB From =SZPROG2NAME

  #On supprime le traitement SZPROG2NAME
  I2EXIST = 1
  Call EFFACE(SZFULL2SRC, I2EXIST) From ORDSYS
  I2EXIST = 1
  Call EFFACE(SZFULL2ADX, I2EXIST) From ORDSYS

  #On termine le traitement SZPROGNAME
  Wrseq "End" Using [CRM3]
  Wrseq "#Fin du traitement généré" Using [CRM3]

  #Fermeture du traitement généré
  Openo Using [CRM3]

  #Compilation du traitement généré
  Local Integer IVALIDOK

  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "101101111"
    Gosub QPRINTVISU
    End
  Endif
  If GMESSAGE <> "" Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "101101111"
    Gosub QPRINTVISU
    End
  Endif

  #Nettoyage préalable de la table
  Call DEBTRANS From GLOCK
  Trbegin [QTX]
  Delete [QTX] Where [F:QTX]QURNUM = SZQURNUM
  If fstat Then
    Rollback
  Else
    Commit
  Endif

  #Exécution du traitement généré
  Call FILLQTX From =SZPROGNAME
  If GERR Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "101101111"
    Gosub QPRINTVISU
    End
  Endif

  #Suppression du traitement généré après service rendu
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS

  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  If !GINTRA Then
    Call FERME_BOITE From GESECRAN
  Else
    Call TEMPOFF From GESECRAN
  Endif
  #Les données sont prêtes. On imprime l'état
  [M:MGC1]FIESRTX = GMGCCOLX(ISRTMGC1-1)

  #LSE 23/03/2005 point entree MGGDEDIT
Local Char SZMGG1AASC
Local Char SZMGG1ADES
Local Char SZMGG2AASC
Local Char SZMGG2ADES
Local Char SZMGG2DASC
Local Char SZMGG2DDES
Local Char SZMGG2LASC
Local Char SZMGG2LDES
Local Char SZMGX1AASC
Local Char SZMGX1ADES
Local Char SZMGX2AASC
Local Char SZMGX2ADES
Local Char SZMGX2DASC
Local Char SZMGX2DDES
Local Char SZMGX2LASC
Local Char SZMGX2LDES

  SZMGG1AASC = "MGG1AASC"
  SZMGG1ADES = "MGG1ADES"
  SZMGG2AASC = "MGG2AASC"
  SZMGG2ADES = "MGG2ADES"
  SZMGG2DASC = "MGG2DASC"
  SZMGG2DDES = "MGG2DDES"
  SZMGG2LASC = "MGG2LASC"
  SZMGG2LDES = "MGG2LDES"
  SZMGX1AASC = "MGX1AASC"
  SZMGX1ADES = "MGX1ADES"
  SZMGX2AASC = "MGX2AASC"
  SZMGX2ADES = "MGX2ADES"
  SZMGX2DASC = "MGX2DASC"
  SZMGX2DDES = "MGX2DDES"
  SZMGX2LASC = "MGX2LASC"
  SZMGX2LDES = "MGX2LDES"
  #point entree
  Gosub PE_MGCDEDIT From TRTCRMPE

  #On détermine quelle est l'état à utiliser
  If IEXTRACT Then
    #Impression pour extraction
    If IONLY1KEY Then
      If ISRTTYP = 1 Then
        #Tri ascendant
        Call ETAT(SZMGX1AASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
      Elsif ISRTTYP = 2 Then
        #Tri descendant
        Call ETAT(SZMGX1ADES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
      Endif
    Else
      If ISRTDATATYP = 1 or ISRTDATATYP = 2 Then
        #Numérique
        If SZSRTDICOTYP = "L" Then
          If ISRTTYP = 1 Then
            #Tri ascendant
            Call ETAT(SZMGX2LASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Elsif ISRTTYP = 2 Then
             #Tri descendant
             Call ETAT(SZMGX2LDES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Endif
        Elsif SZSRTDICOTYP = "M" Then
          If ISRTTYP = 1 Then
            #Tri ascendant
            Call ETAT(SZMGX2AASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Call ETAT(SZMGX2ADES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Endif
        Endif
      Elsif ISRTDATATYP = 3 Then
        #Date
        If ISRTTYP = 1 Then
          #Tri ascendant
          Call ETAT(SZMGX2DASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
        Elsif ISRTTYP = 2 Then
          #Tri descendant
          Call ETAT(SZMGX2DDES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
        Endif
      Elsif ISRTDATATYP >= 4 and ISRTDATATYP <= 9 Then
        #Numérique
        If SZSRTDICOTYP = "L" Then
          If ISRTTYP = 1 Then
            #Tri ascendant
            Call ETAT(SZMGX2LASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Call ETAT(SZMGX2LDES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Endif
        Elsif SZSRTDICOTYP = "M" Then
          If ISRTTYP = 1 Then
            #Tri ascendant
            Call ETAT(SZMGX2AASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Call ETAT(SZMGX2ADES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Endif
        Endif
      Elsif ISRTDATATYP >= 10 Then
        #Alpha
        If ISRTTYP = 1 Then
          #Tri ascendant
          Call ETAT(SZMGX2AASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
        Elsif ISRTTYP = 2 Then
          #Tri descendant
          Call ETAT(SZMGX2ADES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
        Endif
      Endif
    Endif
  Else
    #Impression pour visualisation
    If IONLY1KEY Then
      If ISRTTYP = 1 Then
        #Tri ascendant
        Call ETAT(SZMGG1AASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
      Elsif ISRTTYP = 2 Then
        #Tri descendant
        Call ETAT(SZMGG1ADES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
      Endif
    Else
      If ISRTDATATYP = 1 or ISRTDATATYP = 2 Then
        #Numérique
        If SZSRTDICOTYP = "L" Then
          If ISRTTYP = 1 Then
            #Tri ascendant
            Call ETAT(SZMGG2LASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Call ETAT(SZMGG2LDES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Endif
        Elsif SZSRTDICOTYP = "M" Then
          If ISRTTYP = 1 Then
            #Tri ascendant
            Call ETAT(SZMGG2AASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Call ETAT(SZMGG2ADES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Endif
        Endif
      Elsif ISRTDATATYP = 3 Then
        #Date
        If ISRTTYP = 1 Then
          #Tri ascendant
          Call ETAT(SZMGG2DASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
        Elsif ISRTTYP = 2 Then
          #Tri descendant
          Call ETAT(SZMGG2DDES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
        Endif
      Elsif ISRTDATATYP >= 4 and ISRTDATATYP <= 9 Then
        #Numérique
        If SZSRTDICOTYP = "L" Then
          If ISRTTYP = 1 Then
            #Tri ascendant
            Call ETAT(SZMGG2LASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Call ETAT(SZMGG2LDES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Endif
        Elsif SZSRTDICOTYP = "M" Then
          If ISRTTYP = 1 Then
            #Tri ascendant
            Call ETAT(SZMGG2AASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Call ETAT(SZMGG2ADES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
          Endif
        Endif
      Elsif ISRTDATATYP >= 10 Then
        #Alpha
        If ISRTTYP = 1 Then
          #Tri ascendant
          Call ETAT(SZMGG2AASC, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
        Elsif ISRTTYP = 2 Then
          #Tri descendant
          Call ETAT(SZMGG2ADES, "PREVISU", "", 0, "", TBPAR,TBVAL) From AIMP3
        Endif
      Endif
    Endif
  Endif
End

##################################################################
# Programme de remise en état des ressources suite à une arrêt sur erreur dans DISPRESULT
##################################################################
$QPRINTVISU
  #####################################################################
  #Table des tâches de nettoyage :
  # 0 : On restaure les variables adxifs et adxirs
  # 1 : On ferme le fichier CRMRBXXX
  # 2 : Suppression physique du fichier CRMRBXXX.src
  # 3 : Suppression physique du fichier CRMRBXXX.adx
  # 4 : On ferme le fichier CRMRCNNN
  # 5 : Suppression physique du fichier CRMRCNNN.src
  # 6 : Suppression physique du fichier CRMRCNNN.adx
  # 7 : Suppression de toutes les populations du ciblage dans QURTMP
  # 8 : Fermeture de la jauge de progression
  ######################################################################
  #On signale toujours l'erreur
  GERR = 1
  #On restaure les variables adxifs et adxirs
  If val(mid$(SZQUITMASK, 1, 1)) Then
    adxifs = SZADXIFS
    adxirs = SZADXIRS
  Endif
  #On ferme le fichier CRMRBXXX
  If val(mid$(SZQUITMASK, 2, 1)) Then
    Openo Using [CRM3]
  Endif
  #Suppression physique du fichier CRMRBXXX.src
  If val(mid$(SZQUITMASK, 3, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  Endif
  #Suppression physique du fichier CRMRBXXX.adx
  If val(mid$(SZQUITMASK, 4, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
  Endif
  #On ferme le fichier CRMRCNNN
  If val(mid$(SZQUITMASK, 5, 1)) Then
    Openo Using [CRM4]
  Endif
  #Suppression physique du fichier CRMRCNNN.src
  If val(mid$(SZQUITMASK, 6, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULL2SRC, IEXIST) From ORDSYS
  Endif
  #Suppression physique du fichier CRMRCNNN.adx
  If val(mid$(SZQUITMASK, 7, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULL2ADX, IEXIST) From ORDSYS
  Endif
  #Suppression de toutes les populations du ciblage dans QURTMP
  If val(mid$(SZQUITMASK, 8, 1)) Then
    Call DEBTRANS From GLOCK
    Trbegin [QTX]
    Delete [QTX] Where [F:QTX]QURNUM = SZQURNUM
    If fstat Then
      Rollback
    Else
      Commit
    Endif
  Endif
  #Fermeture de la jauge de progression
  If val(mid$(SZQUITMASK, 9, 1)) Then
    If !GINTRA Then
      Call FERME_BOITE From GESECRAN
    Else
      Call TEMPOFF From GESECRAN
    Endif
  Endif
Return
