# TRT RELLCR
# JML 02/10/00 On vire la fonction et le masque PARFICBAN
#     Désormais, on ne dit plus si on veut générer sur
#     le client ou le serveur, on génère toujours sur 
#     le serveur, c'est le transfert ALMACOM qui se démerde 
#     pour savoir ou est le modem (Vu avec MB)
##########################################################
Subprog SETPARAM(DIR_FICBAN,MACHIN,IRS,OS,OK)
Variable Char DIR_FICBAN()
Variable Char MACHIN()
Variable Char IRS()
Variable Char OS()
Variable Integer OK
Local Integer I

OK=1
#Gosub SETFICPAR : # Résidu du 26/04/00

DIR_FICBAN = filpath("","","") : # Chemin de l'appli courante sur le serveur

I = instr(1,DIR_FICBAN,"@")
If I
 MACHIN = left$(DIR_FICBAN,I-1)
 DIR_FICBAN = right$(DIR_FICBAN,I+1)
Else
 MACHIN = ""
Endif

Call GET_OS(MACHIN,OS) From ORDSYS
Case OS
 When "unix"  : IRS = chr$(10)
 When Default : IRS = chr$(13)+chr$(10)
Endcase
End

#######################################################################################

## JML 02/10/00 Ne sert plus !
$SETFICPAR
# Forcément sur le poste du client qui demande cette fonction, dans répertoire X3
FICHIER = filpath("!",GMACADO+"_"+nomap,"PAR","","","#") : # No service ??
## "#@E:\X3_120\ficban.par"
I = instr(1,FICHIER,"\\")
If I
 FICHIER = left$(FICHIER,I-1)+right$(FICHIER,I+1)
Endif
adxifs = "" : adxirs = chr$(13)+chr$(10)
Return

$ERREUR
GERREUR = errn
Resume
