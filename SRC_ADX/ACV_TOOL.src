#<AdxTL>@(#)0.0.0.0 $Revision$
# Activity code functions

#**
#* ACTIV  Returns activity code active status as
#*        FLACT = [V]CST_AYES then active return value is [V]CST_ATRUE
#*        FLACT = [V]CST_ANO or activity code not found then active return value is [V]CST_AFALSE
#*
#*        No error message returned
#*
#* @param CODE - Code to be checked (char value, if message use num$(message number) )
#*!
Funprog ACTIV(CODE)
Value Char CODE
Local Instance MY_ACTIV Using C_ACTIV
Local Integer MY_STATUS

MY_ACTIV = NewInstance C_ACTIV AllocGroup null

[L]MY_STATUS = fmet MY_ACTIV.AREAD([L]CODE)
If [L]MY_STATUS<>[V]CST_AOK
  [L]MY_STATUS=[V]CST_AFALSE
Elsif this.FLACT<>[V]CST_AYES
  [L]MY_STATUS=[V]CST_AFALSE
Else
  [L]MY_STATUS=[V]CST_ATRUE
Endif
FreeGroup MY_ACTIV
End [L]MY_STATUS
