#<AdxTL>@(#)3.0.0.0 $Revision$
Funprog GETCEEFLG(LVCRNUM)
Value Char LVCRNUM()

If LVCRNUM="" : End 1 : Endif

# Supplier invoice Reading
If clalev([F:PIHZ])=0 : Local File PINVOICE [PIHZ] : Endif
If [F:PIHZ]NUM<>LVCRNUM : Read [PIHZ]PIH0=LVCRNUM : Endif
If fstat : End 1 : Endif

# Verfification that the document correspond to an invoice entered in Purchasing or AP Module
If clalev([F:HAEZ])=0 : Local File GACCENTRY [HAEZ] : Endif
If [F:HAEZ]NUM<>LVCRNUM : Read [HAEZ]HAE0=[PIHZ]GTE;LVCRNUM : Endif
If find([F:HAEZ]ORIMOD,6,3)=0 : End 1 : Endif

End [F:PIHZ]CEEFLG

# PRD04B & PRD05
###################################################################################
# SUBPROG DSCAMTCAL2(DEP,AMTPAY,REFDAT,DUDDAT,LTI,RATE,DSCAMT,ACCNUM,DUDLIG,DISDAT)
# Early Discount/Late Charge Amount Calculation
###################################################################################
Subprog DSCAMTCAL2(DEP,AMTPAY,DAT,DUDDAT,LTI,RATE,DSCAMT,ACCNUM,DUDLIG,DISDAT)
Value    Char    DEP       # Early Discount/Late Charge Code
Value    Decimal AMTPAY    # Open Item Amount paid or to pay
Value    Date    DAT       # Payment date in case of Payment Processes or a reference date that corresponds to the potentiel payment date
Value    Date    DUDDAT    # Open Item Due Date
Variable Integer LTI       # Lead Time
Variable Decimal RATE      # Early Discount/Late Charge Rate (Rate<0:Early Discount ; Rate>0:Late Charge)
Variable Decimal DSCAMT    # Early Discount/Late Charge Amount
Value    Integer ACCNUM    # ACCNUM + DUDLIG : allow to identify the Open Item if we need to read the invoice
Value    Integer DUDLIG    # ACCNUM + DUDLIG : allow to identify the Open Item if we need to read the invoice
Variable Date    DISDAT    # Discount Date

Local Integer GETDISDAT : GETDISDAT = 1
Goto DSCAMTCALC
End
# PRD04B & PRD05


###########################################################################
# SUBPROG DSCAMTCAL(DEP,AMTPAY,REFDAT,DUDDAT,LTI,RATE,DSCAMT,ACCNUM,DUDLIG)
# Early Discount/Late Charge Amount Calculation
###########################################################################
Subprog DSCAMTCAL(DEP,AMTPAY,DAT,DUDDAT,LTI,RATE,DSCAMT,ACCNUM,DUDLIG)
Value    Char    DEP       # Early Discount/Late Charge Code
Value    Decimal AMTPAY    # Open Item Amount paid or to pay
Value    Date    DAT       # Payment date in case of Payment Processes or a reference date that corresponds to the potentiel payment date
Value    Date    DUDDAT    # Open Item Due Date
Variable Integer LTI       # Lead Time
Variable Decimal RATE      # Early Discount/Late Charge Rate (Rate<0:Early Discount ; Rate>0:Late Charge)
Variable Decimal DSCAMT    # Early Discount/Late Charge Amount
Value    Integer ACCNUM    # ACCNUM + DUDLIG : allow to identify the Open Item if we need to read the invoice
Value    Integer DUDLIG    # ACCNUM + DUDLIG : allow to identify the Open Item if we need to read the invoice

# PRD04B & PRD05
Local Integer GETDISDAT: GETDISDAT = 0
Local Date    DISDAT

$DSCAMTCALC
# PRD04B & PRD05

If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif  : # Currencies
If !clalev([F:PIH]) : Local File PINVOICE   [PIH] : Endif  : # Supplier invoices
If !clalev([F:SIH]) : Local File SINVOICE   [SIH] : Endif  : # Customer invoices
If !clalev([F:DUD]) : Local File GACCDUDATE [DUD] : Endif  : # Open Items
If !clalev([F:TDA]) : Local File TABDEPAGIO [TDA] : Endif  : # Early discount / Late charge

Local Char    OPT(1)          : # Value of the DATDEP Parameter
Local Char    INVNUM(GLONVCR) : # Document No
Local Integer FLGDEP          : # Local Variable used in the 'Rebate on VAT' Mode
Local Decimal AMT             : # Amount - Local variable used to store the base fopr the calculation of the disiount/late charge

If DEP=""  : End : Endif

AMT = AMTPAY
Raz DSCAMT


########  SAM REF# 76609 added by angre 06/12/12 #############################
# In the payment proposal list we have to treat the additional allowance days
##############################################################################
If [V]GFONCTION = "PAYPROPAL"
 DAT = func PAYDEPLIB.DATEINCLALLOWANCEDAYS(DAT)
Endif

## Two cases :
## 1) The payment date (DAT) is <= to the Due Date (DUDDAT) that is to say : the payment is made on time => in that case,
##    the DATDEP Parameter is used to calculate the 'Lead Time' and deduct the eventual Early Discount rate regarding the 'Lead time' and
##    the Early Discount/Late Charge Code
## 2) The payment date (DAT) is > to the Due Date (DUDDAT) that is to say : the payment is delayed regarding the due date => in that
##    case, the DATDEP Parameter is NOT used to calculate the 'Lead Time'. This one is initialized by the number of days between the
##    Due Date (DUDDDAT) and the Paiement Date (DAT).

fstat = 0
If [F:DUD]ACCNUM<>[L]ACCNUM or [F:DUD]DUDLIG<>[L]DUDLIG
 Read [DUD]DUD1 = [L]ACCNUM;[L]DUDLIG
Endif

If DAT <= DUDDAT
 If !fstat & LTI=0
  # Issue X3-29143
  [L]OPT = num$(fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, [F:DUD]CPY, "DATDEP"))
  #  Call PARAML([F:DUD]CPY,"DATDEP",OPT) From ADOVAL
  # End Issue X3-29143
  REFDAT = func PAYDEPLIB3.GETREFERENCEDATE(DUDDAT,[F:DUD]BPRTYP,[F:DUD]TYP,[F:DUD]NUM,OPT)
  LTI = DAT - REFDAT
 Endif
Else
 # Number of days between the due date and the reference date
 LTI = DAT - DUDDAT
Endif

#If dim([F:TCR]PROCESS)>0 and [F:TCR]PROCESS = "NA-CSHREQ" # NA Cash requirements report
#[M:DIA]DISDAT = REFDAT + LTI # Discount date
#Endif

If RATE=0  : Call LITTABDEP(DEP,LTI,RATE) From TRTDIV : Endif

## If the early discount/late charge code is 'Restricted to reminder campaigns' the calculation of the late charge is triggered only
## in the campaign reminders
Call LEC_TDA(GCURLEG,DEP) From CPTLEC
If [F:TDA]RMDCMG = 2 & GFONCTION<>"GESFUP" & RATE>0 : RATE = 0 : End : Endif

# PRD04B & PRD05
If GETDISDAT
 DAYS = func CSHREQ.DISCDAY(DEP,LTI)
 If dim(REFDAT) <= 0                                 # 84833.sn

   # Issue X3-29143
   [L]OPT = num$(fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, [F:DUD]CPY, "DATDEP"))
#   Call PARAML([F:DUD]CPY,"DATDEP",OPT) From ADOVAL
   # End Issue X3-29143
   REFDAT = [F:PIH]BPRDAT # [TCR]BPRDAT              # 84833.en  # PRD04B TCR to PIH
 Endif
 If year(REFDAT) > 0
   DISDAT =  REFDAT + DAYS -1
 Endif
Endif
# PRD04B & PRD05

## If the Rate found is < 0 (=early discount) and the Open Item is due (Payment Date > Open Item Due Date), we reset the rate found but
## we continue the process because of the 'Always Discount' Option used just after....
If DAT > DUDDAT & RATE < 0 : RATE = 0 : Endif

## NB : The Late Charge is applied on the total Paid Open Item Amount (whatever the accounts). Consequently, the base is calculated only
##      if RATE<0 (early discount) or RATE=0 (because of the always Discount' Option...)
If RATE<=0


 ## Rebate on Tax Mode (Old BRIDSC Mode)
 ## #####################################
 ## If DEPMGTMOD is "1" (Rebate on VAT) and if the open item has been created before the migration V6 -> V7, the discountable base is not initialized. Consequently,
 ## the disountable amount is calculated with the BRIDSC V6 Mode (=If this is an Early Discount/Late Charge Code with the [TDA]PFINUM or [TDA]SFINUM Field not void,
 ## the amount of the discount has to be calculated on the net invoice amount)

 # X3-38657
 Local Char P_DEPMGTMOD(5) : Raz P_DEPMGTMOD
 [L]P_DEPMGTMOD = num$(fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, [F:DUD]CPY, "DEPMGTMOD"))

 If [L]P_DEPMGTMOD = "1" & dim(GLASINTNUM)>0 & GLASINTNUM>0 & [L]ACCNUM<=GLASINTNUM
  Call CALBASDEP_BRIMOD([F:DUD]CPY,[F:DUD]DEP,AMT)

 ## Breakdown by VAT / Account Level Mode (old GERDSC Mode)
 ## #######################################################
 Elsif [L]P_DEPMGTMOD = "4"
  ## Some of accounts are excluded in the early discount calculation (using of the FLGDEP Flag defined at the Account Level)
  Call CALBASDEP_GERMOD([F:DUD]BPRTYP,[F:DUD]TYP,[F:DUD]NUM,[F:DUD]ACCNUM,[F:DUD]CUR,AMT)

 ## The amount of the discount (only the discount) has to be calculated regarding the new field 'Discountable base'
 ## stored in the PINVOICE/SINVOICE
 ## It is the case with the following modes :
 ##   * DEPMGTMOD = "1" (Rebate on Tax) and if the open item has been created after the migration V6 -> V7
 ##   * DEPMGTMOD = "2" (Breakdown by VAT / Invoice Level) and if the open item has been created after the migration V6 -> V7
 ##   * DEPMGTMOD = "3" (GLobal Mode)
 ##   * DEPMGTMOD = "5" (Rebate on Tax/Global Mode)
 Elsif ( ([L]P_DEPMGTMOD="1" | [L]P_DEPMGTMOD="2") & dim(GLASINTNUM)>0 & GLASINTNUM>0 & [L]ACCNUM>GLASINTNUM )
&       | [L]P_DEPMGTMOD="3" | [L]P_DEPMGTMOD="5"
  Call CALBASDEP([F:DUD]BPRTYP,[F:DUD]NUM,[F:DUD]DEP,[F:DUD]CUR,AMTPAY,AMT)
 Endif

Endif

########  SAM REF# 76609 added by angre 06/12/12 ###############################
# In the payment proposal list we have to treat the option 'Always use discount'
################################################################################
If [V]GFONCTION = "PAYPROPAL"
 RATE = func PAYDEPLIB.ALWAYSUSEDISCOUNT(DEP,RATE,[M:DIA]ALWDISFLG)
Endif

If dim(GDISFLG)>=1 & GDISFLG=2 # NA Cash Requirements report
 RATE = func PAYDEPLIB.ALWAYSUSEDISCOUNT(DEP,RATE,GDISFLG)
Endif

If RATE < 0     # Early Discount
 DSCAMT = (AMT*RATE/100)
Elsif RATE > 0  # Late Charge
 DSCAMT = (AMT*RATE/100)*(LTI/365)
Endif

End

# PRD04B & PRD05
###########################################################################
# FUNPROG SETDISDAT(ACCTDAT)
# Calculate discount date
###########################################################################
Funprog SETDISDAT(ACCTDAT)
Value Date ACCTDAT

Local Integer DELAI
Local Decimal TAUX, MONT_ESC
Local Date DISCDATE, REFDAT # Issue X3-29143
Local Char OPT      : # 1:Open Item Due Date   2:Invoice date
Local Char DEP

  If clalev([F:DUD3])=0 : Local File GACCDUDATE [DUD3] : Endif : # Echéances

  Raz [L]DELAI, [L]TAUX, [L]MONT_ESC, [L]DISCDATE

  If [DUD]DEP = ''
    Filter [DUD3] Where [DUD3]NUM = [DUD]NUM and [DUD3]DEP <> ''
    Read [DUD3] First
    If fstat = 0
      [L]DEP = [DUD3]DEP
    Endif
    Filter [DUD3]
  Else
    [L]DEP = [F:DUD]DEP
  Endif

  Call LEC_TDA(GCURLEG, [L]DEP) From CPTLEC
  If !fstat # Discount term available

    # Issue X3-29143
    [L]OPT = num$(fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, [F:DUD]CPY, "DATDEP"))

    [L]REFDAT = func PAYDEPLIB3.GETREFERENCEDATE(ACCTDAT, [F:DUD]BPRTYP, [F:DUD]TYP, [F:DUD]NUM, [L]OPT)
    Call DSCAMTCAL2([L]DEP, 0, [L]REFDAT, [F:DUD]DUDDAT, [L]DELAI, [L]TAUX, [L]MONT_ESC, [F:DUD]ACCNUM, [F:DUD]DUDLIG, [L]DISCDATE)

    # Read Purchase invoices table [PIH]
#    Read [PIH]PIH0 = [F:DUD]NUM
#    Call PARAML([F:DUD]CPY, "DATDEP", OPT) From ADOVAL
#      If OPT = "1"  # Discount based on Accounting or Source Date
#        Call DSCAMTCAL2([L]DEP, 0, ACCTDAT, [F:DUD]DUDDAT, [L]DELAI, [L]TAUX, [L]MONT_ESC, [F:DUD]ACCNUM, [F:DUD]DUDLIG, [L]DISCDATE)
#      Elsif OPT = "2"  # Discount based on Invoice Date
#        Call DSCAMTCAL2([L]DEP, 0, [F:PIH]BPRDAT, [F:DUD]DUDDAT, [L]DELAI, [L]TAUX, [L]MONT_ESC, [F:DUD]ACCNUM, [F:DUD]DUDLIG, [L]DISCDATE)
#      Endif
# End Issue X3-29143
  Endif

End [L]DISCDATE
# PRD04B & PRD05


####################################################################################################
# This Function allows to return the real reference date to take into account in the calculation
# of the discount amount : 'Open Item Due Date' or 'Invoice Date'
# The 'Invoice Date' corresponds to
#   -> The 'Source date' for the Supplier Invoice
#   -> The 'Accounting date' for the Customer Invoice
####################################################################################################
Funprog GETREFERENCEDATE(DUEDATE,BPRTYP,TYP,NUM,OPT)
Value Date    DUEDATE  : # Open Item Due Date
Value Integer BPRTYP   : # BP Type
Value Char    TYP      : # Entry type
Value Char    NUM      : # Document
Value Char    OPT      : # 1:Open Item Due Date   2:Invoice date

If !clalev([F:SIH]) : Local File SINVOICE  [SIH] : Endif
If !clalev([F:PIH]) : Local File PINVOICE  [PIH] : Endif
If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
Local Date    RESULT
Local Char    INVNUM(GLONVCR) : # Document No

If OPT="1"
 RESULT = DUEDATE
Else
 INVNUM = NUM
 # Number of days between the due date and the invoice date
 If BPRTYP = 1 : # Customer
  Gosub READ_SIH
  If !fstat
   RESULT = [F:SIH]ACCDAT
  Else
   Gosub READ_HAE
   If !fstat
    RESULT = [F:HAE]ACCDAT
   Endif
  Endif
 Else : # Supplier
  Gosub READ_PIH
  If !fstat
   If [F:PIH]BPRDAT<>[0/0/0]
    RESULT = [F:PIH]BPRDAT
   Else
    RESULT = [F:PIH]ACCDAT
   Endif
  Else
   Gosub READ_HAE
   If !fstat
    If [F:HAE]BPRDATVCR<>[0/0/0]
     RESULT = [F:HAE]BPRDATVCR
    Else
     RESULT = [F:HAE]ACCDAT
    Endif
   Endif
  Endif
 Endif
Endif

End RESULT


$READ_HAE
fstat = 0
If [F:HAE]TYP<>[L]TYP or [F:HAE]NUM<>[L]NUM
 Read [F:HAE]HAE0 = [L]TYP ; [L]NUM
Endif
Return


$READ_PIH
fstat = 0
If [F:PIH]NUM<>[L]INVNUM
 Read [PIH]PIH0 = [L]INVNUM
Endif
Return

$READ_SIH
fstat = 0
If [F:SIH]NUM<>[L]INVNUM
 Read [SIH]SIH0 = [L]INVNUM
Endif
Return


###############################################################################################################################
# The calculation of of the discountable amount is made using the Discountable Base stored in the PINVOICE/SINVOICE Tables
###############################################################################################################################
Subprog CALBASDEP(INVTYP,NUM,DUDDEP,CUR,AMTPAY,DSCBAS)
Value    Integer INVTYP   : # Type of Invoice 1:Customer  2:supplier
Value    Char    NUM()    : # Document No
Value    Char    DUDDEP() : # Early Discount/Late Charge Code attached to the open item
Value    Char    CUR()    : # Currency
Value    Decimal AMTPAY   : # Open Item Amount Paid or to Pay
Variable Decimal DSCBAS   : # Discountable base for the calculation of the Early Discount

If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif  : # Currencies
If !clalev([F:PIH]) : Local File PINVOICE   [PIH] : Endif  : # Supplier invoices
If !clalev([F:SIH]) : Local File SINVOICE   [SIH] : Endif  : # Customer invoices

Local Char INVNUM(GLONVCR)
Local Char ABR(GLONABR)

INVNUM = NUM

Case INVTYP
 When 1
  Gosub READ_SIH
  If !fstat
   ABR = "SIH" : Gosub CALBASE
  Endif
 When 2
  Gosub READ_PIH
  If !fstat
   ABR = "PIH" : Gosub CALBASE
  Endif
Endcase
End

$CALBASE
Call LEC_TCU(CUR) From CPTLEC
If evalue("[F:"+ABR+"]AMTATI")<>0
 DSCBAS = arr(AMTPAY*(evalue("[F:"+ABR+"]BASDEP")/evalue("[F:"+ABR+"]AMTATI")),[F:TCU]CURRND)
Else
 DSCBAS = 0
Endif
## Special case : the discountable amount is equal to 0 because the early discount/late charge code has been added afterwards
## or changed afterwards in the GACCDUDATE (=the invoice contains a code with NO negative rate (=>so BASDEP is=0) while the open item
## contains a code with negative rates) => in that case, the discount amount will be calculated on the Open Item Amount Paid
If evalue("[F:"+ABR+"]BASDEP") = 0 & evalue("[F:"+ABR+"]DEP")<>DUDDEP
 Local Char    INVDEP(GLONTDA) : INVDEP = evalue("[F:"+ABR+"]DEP")
 Local Integer DSCFLG
 Call DEPTYP(INVDEP,DSCFLG)
 If INVDEP="" | DSCFLG=0
  DSCBAS = AMTPAY
 Endif
Endif
Return

#####################################################################################################################
# BRIDSC Mode
# The aim is to calculate the discount amount on the net invoice amount
# Pre-requisites : The PFINUM or SFINUM Fields (according to the type of invoice) has to be not void
#####################################################################################################################
Subprog CALBASDEP_BRIMOD(CPY,DUDDEP,DSCBAS)
Value    Char    CPY()       : # Company
Value    Char    DUDDEP()    : # Early Discount/Late Charge Code attached to the open item
Variable Decimal DSCBAS      : # Discountable base for the calculation of the Early Discount

Local Integer FLGDEP
FLGDEP = 0 : Call FLGDEP(CPY,DUDDEP,FLGDEP) From PAYDEPLIB2
If FLGDEP
 Call CALBASDEP(DSCBAS) From PAYDEPLIB2
Endif
End

#####################################################################################################################
# GERDSC Mode
# The aim is to exclude some of accounts in the discountable base (regarding the value of the FLGDEP Flag defined
# in the GACCOUNT Table) that will allow to calculate the discountable amount regarding the amount paid
# Prerequisites : the invoice has to be existing in the PINVOICE/SINVOICE Table
#####################################################################################################################
Subprog CALBASDEP_GERMOD(INVTYP,TYP,NUM,ACC_NUM,CUR,DSCBAS)
Value    Integer INVTYP         : # Type of Invoice 1:Customer  2:supplier
Value    Char    TYP            : # Document Type
Value    Char    NUM            : # Document No
Value    Integer ACC_NUM()      : # Internal Number of the Open Item to be paid
Value    Char    CUR()          : # Currency
Variable Decimal DSCBAS         : # Discountable base for the calculation of the Early Discount

If !clalev([F:PIH])  : Local File PINVOICE   [PIH]  : Endif  : # Suppliers invoices
If !clalev([F:SIH])  : Local File SINVOICE   [SIH]  : Endif  : # Customers Invoices
If !clalev([F:DAE4]) : Local File GACCENTRYD [DAE4] : Endif  : # Accounting entry lines
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif  : # Accounts
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif  : # Currencies

Local Char    COMPANY(GLONCPY) : # Company
Local Char    COACOD(GLONCOA)  : # Chart of account
Local Char    INVNUM(GLONVCR)  : # Invoice Number
Local Integer CEEFLG, INVFLG   : # Miscellaneaous Flag

Local Decimal BASE             : # Base for the calculation of the Final Discount Base
Local Decimal AMTATI           : # All taxes included amount

INVFLG = 0 : CEEFLG = 0

If !fstat
 INVNUM = NUM
 Case INVTYP
  When 1
   Gosub READ_SIH
   If !fstat
    INVFLG = 1 : COMPANY = [F:SIH]CPY
   Endif
  When 2
   Gosub READ_PIH
   If !fstat
    INVFLG = 2 : COMPANY = [F:PIH]CPY : [L]CEEFLG=[F:PIH]CEEFLG
   Endif
 Endcase
Endif
If INVFLG : # C'est une facture
 Call LEC_TCU(CUR) From CPTLEC
 ARD=[F:TCU]CURRND
 Gosub CALBASE_GER
Endif
End


$CALBASE_GER
Raz BASE, AMTATI
Call SETMAINREF(COMPANY,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN(COMPANY,GTYPGEN,COACOD) From CPTDIV
## Si la facture n'est pas validée en compta (=écritures inexistantes), le montant d'escompte sera calculé
## comme avant sur le montant total de l'échéance
For [DAE4]DAE0 Where TYP=[L]TYP & NUM=[L]NUM & LEDTYP=GTYPGEN
 If [F:DAE4]ACCNUM=[L]ACC_NUM
  AMTATI = [F:DAE4]AMTCUR
 Else
  Call LEC_GAC([F:DAE4]ACC,COACOD) From CPTLEC
  If !fstat & find([F:GAC]FLGVAT,1,2) & [F:GAC]FLGDEP=2
   BASE += [F:DAE4]AMTCUR*[F:DAE4]SNS
   If [F:DAE4]TAX<>""
    Gosub CAL_TAXE
    BASE += ([L]AMTTAX1+[L]AMTTAX2+[L]AMTVAT)*[F:DAE4]SNS
   Endif
  Endif
 Endif
Next
## Calculation of the final discountable base in proportion to the Open Item Amount Paid
## and to the total subjected to discount ([L]BASE/ATI)
If AMTATI
 DSCBAS = arr(DSCBAS*(abs([L]BASE)/AMTATI),ARD)
Endif
Return


$CAL_TAXE
Local Char    TAXES(GLONVAT)(1..3)
Local Integer TYPREG , STAT
Local Decimal MONTVAT(1..3), MONTDED(1..3)
Local Decimal AMTTAX1, AMTTAX2, AMTVAT
If dim([F:DAE4]TAX2)>0
 TAXES(1) = [F:DAE4]TAX2  : # Code taxe 1
Endif
If dim([F:DAE4]TAX3)>0
 TAXES(2) = [F:DAE4]TAX3  : # Code taxe 2
Endif
TAXES(3) = [F:DAE4]TAX    : # Code TVA
Call CALTAXE([F:DAE4]CPY,[F:DAE4]ACCDAT,"",[F:DAE4]CUR,3,TAXES,1,[F:DAE4]AMTCUR,MONTVAT,MONTDED,TYPREG,STAT) From SUBTVT
If INVFLG=1 & TYPREG<>1
 Raz MONTVAT, MONTDED
Elsif INVFLG=2 & TYPREG<>1 & (TYPREG<>4 | [L]CEEFLG)
 Raz MONTVAT, MONTDED
Endif
[L]AMTTAX1 = MONTVAT(1)
[L]AMTTAX2 = MONTVAT(2)
[L]AMTVAT  = MONTVAT(3)
Return


#####################################################################################################################
# This subprogram allows to define if the discount/late charge Code contains a negative rate
#####################################################################################################################
Subprog DEPTYP(COD,DSCFLG)
Value    Char    COD()    : # Early Discount / Late Charge Code
Variable Integer DSCFLG   : # 0: No negative rate   1: One negative rate (at least) is defined

If COD="" : End : Endif

If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
Local Integer I

Call LEC_TDA(GCURLEG,COD) From CPTLEC
If !fstat
 For I=0 To dim([F:TDA]DEPDAY)-1
  If [F:TDA]DEPRAT(I)<0 : DSCFLG=1 : Break : Endif
 Next I
Endif
End

#####################################################################################################################
# The ECLAT_VAT_HAE & ECLAT_VAT_INV Labels are called in the following functions :
#   - Automatic Proposal Process (PAYPROPAL Function)
#   - Manual Payment Management (GESPAY Funtion) when an Open Item is selected in the left box
# This subprogram allows to manage the 'Breakdown by VAT' in the generation of the early discount/late charge Lines
# requested when the DEPMGTMOD Parameter is equal to 1, 2 or 4
#####################################################################################################################
$ECLAT_VAT_HAE
Local Char    TCODTAX(GLONVAT)(1..99)
Local Integer ECLVAT
Local Integer NTAX, NBTAX
Local Decimal SOM_MONTANT, TTC, TBASTAX(1..99), TAMTTAX(1..99)
Local Decimal MONTANT
Local Decimal ARD

Local Integer DIMVTL                             : # Maximum number of allocation
Local Integer ICPY                               : # Miscellaneous
Local Integer NBRDIEMAX                          : # Maximum number of dimension type

DIMVTL    = min(100, func AFNC.ACTIV("VTL"))
ICPY      = fmet GACTX.ACACHE.ACPY.AGETINDEX([F:DUD]CPY)
NBRDIEMAX = fmet GACTX.ACACHE.ACPY.AGETVALNUM([F:DUD]CPY,"NBRDIE")

Local Char    TDIE(GLONDIE)(1..max(1,NBRDIEMAX)) : # Dimension Types
Local Char    TCCE1(GLONCCE)(1..99,1..DIMVTL)    : # Dimensions by tax code and analytical distribution line
If NBRDIEMAX<2  : Local Char TCCE2(GLONCCE)(1..99,1..1)  Else  Local Char TCCE2(GLONCCE)(1..99,1..DIMVTL)  : Endif
If NBRDIEMAX<3  : Local Char TCCE3(GLONCCE)(1..99,1..1)  Else  Local Char TCCE3(GLONCCE)(1..99,1..DIMVTL)  : Endif
If NBRDIEMAX<4  : Local Char TCCE4(GLONCCE)(1..99,1..1)  Else  Local Char TCCE4(GLONCCE)(1..99,1..DIMVTL)  : Endif
If NBRDIEMAX<5  : Local Char TCCE5(GLONCCE)(1..99,1..1)  Else  Local Char TCCE5(GLONCCE)(1..99,1..DIMVTL)  : Endif
If NBRDIEMAX<6  : Local Char TCCE6(GLONCCE)(1..99,1..1)  Else  Local Char TCCE6(GLONCCE)(1..99,1..DIMVTL)  : Endif
If NBRDIEMAX<7  : Local Char TCCE7(GLONCCE)(1..99,1..1)  Else  Local Char TCCE7(GLONCCE)(1..99,1..DIMVTL)  : Endif
If NBRDIEMAX<8  : Local Char TCCE8(GLONCCE)(1..99,1..1)  Else  Local Char TCCE8(GLONCCE)(1..99,1..DIMVTL)  : Endif
If NBRDIEMAX<9  : Local Char TCCE9(GLONCCE)(1..99,1..1)  Else  Local Char TCCE9(GLONCCE)(1..99,1..DIMVTL)  : Endif
If NBRDIEMAX<10 : Local Char TCCE10(GLONCCE)(1..99,1..1) Else  Local Char TCCE10(GLONCCE)(1..99,1..DIMVTL) : Endif
If NBRDIEMAX<11 : Local Char TCCE11(GLONCCE)(1..99,1..1) Else  Local Char TCCE11(GLONCCE)(1..99,1..DIMVTL) : Endif
If NBRDIEMAX<12 : Local Char TCCE12(GLONCCE)(1..99,1..1) Else  Local Char TCCE12(GLONCCE)(1..99,1..DIMVTL) : Endif
If NBRDIEMAX<13 : Local Char TCCE13(GLONCCE)(1..99,1..1) Else  Local Char TCCE13(GLONCCE)(1..99,1..DIMVTL) : Endif
If NBRDIEMAX<14 : Local Char TCCE14(GLONCCE)(1..99,1..1) Else  Local Char TCCE14(GLONCCE)(1..99,1..DIMVTL) : Endif
If NBRDIEMAX<15 : Local Char TCCE15(GLONCCE)(1..99,1..1) Else  Local Char TCCE15(GLONCCE)(1..99,1..DIMVTL) : Endif
If NBRDIEMAX<16 : Local Char TCCE16(GLONCCE)(1..99,1..1) Else  Local Char TCCE16(GLONCCE)(1..99,1..DIMVTL) : Endif
If NBRDIEMAX<17 : Local Char TCCE17(GLONCCE)(1..99,1..1) Else  Local Char TCCE17(GLONCCE)(1..99,1..DIMVTL) : Endif
If NBRDIEMAX<18 : Local Char TCCE18(GLONCCE)(1..99,1..1) Else  Local Char TCCE18(GLONCCE)(1..99,1..DIMVTL) : Endif
If NBRDIEMAX<19 : Local Char TCCE19(GLONCCE)(1..99,1..1) Else  Local Char TCCE19(GLONCCE)(1..99,1..DIMVTL) : Endif
If NBRDIEMAX<20 : Local Char TCCE20(GLONCCE)(1..99,1..1) Else  Local Char TCCE20(GLONCCE)(1..99,1..DIMVTL) : Endif

Local Decimal TRATDSP(1..99,1..DIMVTL)
Local Integer TNBRVTLTAX(1..99)

Local Integer NOL, DIE, ANA, STRLINANA
Local Decimal NBRRND, TMPMNTANA, TMPQTYANA, SUMQTYANA, TOTCOE

Global Char  GDEPVATLIN(GLONVAT) : GDEPVATLIN = ""

If GDEPMGTMOD = 4 | ((GDEPMGTMOD=1 | GDEPMGTMOD=2) & dim(GLASINTNUM)>0 & GLASINTNUM>0 & [F:DUD]ACCNUM<=GLASINTNUM)
 Local Decimal XMONTANT, XSNS
 Case GFONCTION
  When "GESPAY"
   [L]XMONTANT = -[L]MONT_ESC*[L]SIGN
   [L]XSNS = [M]SNS
  When "PAYPROPAL"
   [L]XMONTANT = [L]MONT_ESC
   [L]XSNS = [F:PYH]SNS
 Endcase
Else
 ## The XMONTANT & SXNS Variable have been already initialized in ECLAT_VAT_INV Label
Endif

Call LEC_TCU([F:DUD]CUR) From CPTLEC
ARD = [F:TCU]CURRND

If GDEPMGTMOD <> 4
 Call ECLAT_TVA([F:DUD]CPY,XSNS,[F:DUD]NUM,[F:DUD]ACCNUM,[F:DUD]DEP,TTC,NBTAX,TCODTAX,TBASTAX,TAMTTAX,ECLVAT) From SUBPAY4
Else
 Call BREAK_VAT([F:DUD]CPY,XSNS,[F:DUD]NUM,[F:DUD]ACCNUM,[F:DUD]DEP,TTC,NBTAX,TCODTAX,TBASTAX,TAMTTAX,TNBRVTLTAX,TDIE,
&                     TCCE1,TCCE2,TCCE3,TCCE4,TCCE5,TCCE6,TCCE7,TCCE8,TCCE9,TCCE10,TCCE11,TCCE12,TCCE13,TCCE14,TCCE15,
&                     TCCE16,TCCE17,TCCE18,TCCE19,TCCE20,TRATDSP,ECLVAT) From SUBPAY4
Endif

If !ECLVAT
 Case GFONCTION
  When "GESPAY"
   ## Une seule ligne d'escompte/agio associée au code taxe par défaut du compte d'escompte/agio
   [L]MONTANT = [L]XMONTANT
   Gosub CHARGE_DUD From SUBPAY2
   ## esc/agio UK. MAJ de l'indicateur EARDISFLG si on a généré une ligne d'escompte (cet indicateur
   ## est exploité dans les pièces automatiques pour ne pas générer des lignes de TVA quelle que soit la destination comptable
   ## (flagué ou non 'gestion de TVA') et d'associer un code taxe sur la ligne d'escompte
   If FLGDEP & dim([M]EARDISFLG)>0
    [M]EARDISFLG(nolign-1) = 2
   Endif
   Gosub INIT_CCE From SUBPAY4
  When "PAYPROPAL"
   Local Decimal XMONT_ESC
   [L]XMONT_ESC = [L]XMONTANT
   Gosub LIGNE_DEP From PAYPROPAL2
   If GOK<1 : Return : Endif
 Endcase
Else
 ## Autant de lignes d'escomptes/agios que de codes taxes trouvés et on associe à la (ou les) imputations
 ## d'escomptes/agios les codes taxes d'origine (ceux de la pièce comptable)
 Raz SOM_MONTANT
 For NTAX = 1 To NBTAX
  If NTAX=NBTAX
   [L]MONTANT = [L]XMONTANT - [L]SOM_MONTANT
  Else
   If !FLGDEP
    [L]MONTANT = arr([L]XMONTANT*((TBASTAX(NTAX)+TAMTTAX(NTAX))/(sum(TBASTAX(1..NBTAX))+sum(TAMTTAX(1..NBTAX)))),ARD)
   Else : # Early discount
    [L]MONTANT = arr([L]XMONTANT*(TBASTAX(NTAX)/(sum(TBASTAX(1..NBTAX)))),ARD)
   Endif
   [L]SOM_MONTANT += [L]MONTANT
  Endif

  Case GFONCTION
   When "GESPAY"
    If GDEPMGTMOD=4
     GDEPVATLIN = TCODTAX(NTAX)   # Use to pick
    Endif
    Gosub CHARGE_DUD From SUBPAY2
    nolign = [M]NBLIG
    # On force le code taxe de la ligne d'escompte/agio au code taxe d'origine (pièce facture)
    [M]VATLIN(nolign-1) = TCODTAX(NTAX)
    If dim([M:PAY1]VATLIN)>0
     Affzo [M:PAY1]VATLIN(nolign-1)
    Elsif dim([M:PAY2]VATLIN)>0
     Affzo [M:PAY2]VATLIN(nolign-1)
    Endif
    ## MAJ de l'indicateur EARDISFLG si on a généré une ligne d'escompte (cet indicateur
    ## est exploité dans les pièces automatiques pour ne pas générer des lignes de TVA quelle que soit la destination comptable
    ## (flagué ou non 'gestion de TVA') et d'associer un code taxe sur la ligne d'escompte
    If FLGDEP & dim([M]EARDISFLG)>0
     [M]EARDISFLG(nolign-1) = 2
    Endif
    If GDEPMGTMOD=4
     If dim([M]EARDISMGT)>0
      [M]EARDISMGT(nolign-1) = 4  # Use when the user update line after the pick
     Endif
     Gosub SET_COST_ALLOCATIONS
    Else
     Gosub INIT_CCE From SUBPAY4
    Endif
   When "PAYPROPAL"
    Local Decimal XMONT_ESC
    [L]XMONT_ESC = [L]MONTANT
    Gosub LIGNE_DEP From PAYPROPAL2
    If GOK<1 : Break : Endif
   Endcase
 Next
Endif
If dim(GDEPVATLIN)>0 : Kill GDEPVATLIN : Endif
If GOK<1 : Return : Endif
Return

$ECLAT_VAT_INV
If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:SIL])=0 : Local File BPCINVLIG  [SIL] : Endif
If clalev([F:PIL])=0 : Local File BPSINVLIG  [PIL] : Endif
If GMODU(5)=2 & clalev([F:SVV])=0 : Local File SVCRVAT [SVV] : Endif
If GMODU(6)=2 & clalev([F:PVV])=0 : Local File PVCRVAT [PVV] : Endif

Local Integer DIMTAB : DIMTAB = max(dim([F:SIH]TAX),dim([F:PIH]TAX),99)
Local Char    TCODTAX(GLONVAT)(1..DIMTAB)
Local Integer NTAX, NBTAX
Local Integer XSNS
Local Integer FLGFAC, ORIMOD
Local Integer DEP_TYP
Local Decimal SOM_MONTANT, TBASDEP(1..DIMTAB)
Local Decimal XMONTANT

Case GFONCTION
 When "GESPAY"
  [L]XMONTANT = -[L]MONT_ESC*[L]SIGN
  [L]XSNS = [M]SNS
 When "PAYPROPAL"
  [L]XMONTANT = [L]MONT_ESC
  [L]XSNS = [F:PYH]SNS
Endcase

FLGFAC = 0 : NBTAX = 0
Raz TCODTAX

If GDEPMGTMOD = 1
 DEP_TYP = 1
Else
 Call LEC_TDA(GCURLEG,[F:DUD]DEP) From CPTLEC
 DEP_TYP = [F:TDA]DEPTYP
Endif

If [M]SNS=1 : PRIO="FC" : Else PRIO="CF" : Endif
For I=1 To 2
 Case mid$(PRIO,I,1)
  When "C"
   Call LECTURE("BIC",[F:DUD]NUM,"") From CONTOBJ
   If fstat=0
    FLGFAC = 1 : ORIMOD=[F:SIH]ORIMOD : Break
   Endif
  When "F"
   Call LECTURE("BIS",[F:DUD]NUM,"") From CONTOBJ
   If fstat=0
    FLGFAC = 2 : ORIMOD=[F:PIH]ORIMOD : Break
   Endif
 Endcase
Next
If !FLGFAC
 ## The invoice doesn't exit in the PINVOICE/SINVOICE Tables => tHe breakdown by VAT will be done using the Accounting Journal
 Gosub ECLAT_VAT_HAE
Else
 Call LEC_TCU([F:DUD]CUR) From CPTLEC
 Case ORIMOD
  When 3
   NBTAX = 0
   Case [L]FLGFAC
    When 1
     For NTAX=1 To [F:SIH]NBRTAX
      For [SIL]SIL0 Where NUM = [F:SIH]NUM & [SIL]FLGDEP = 2 & VAT = [F:SIH]TAX(NTAX-1)
       NBTAX += 1
       TCODTAX(NBTAX) = [F:SIL]VAT
       If DEP_TYP = 1
        TBASDEP(NBTAX) = [F:SIL]AMTNOTLIN
       Else
        TBASDEP(NBTAX) = [F:SIL]AMTATILIN
       Endif
      Next
     Next
    When 2
     For NTAX=1 To [F:PIH]NBRTAX
      For [PIL]PIL0 Where NUM = [F:PIH]NUM & [PIL]FLGDEP = 2 & VAT = [F:PIH]TAX(NTAX-1)
       NBTAX += 1
       TCODTAX(NBTAX) = [F:PIL]VAT
       If DEP_TYP = 1
        TBASDEP(NBTAX) = [F:PIL]AMTNOTLIN
       Else
        TBASDEP(NBTAX) = [F:PIL]AMTATILIN
       Endif
      Next
     Next
    Endcase
    Gosub LIGDEPVAT
  When 5
   NBTAX = 0
   For NTAX=1 To [F:SIH]NBRTAX
    Read [SVV]SVV0 = 4 ; [F:SIH]NUM ; [F:SIH]TAX(NTAX-1)
    If !fstat & [F:SVV]BASDEPNOT<>0 | [F:SVV]BASDEPATI<>0
     NBTAX += 1
     TCODTAX(NBTAX) = [F:SVV]VAT
     TBASDEP(NBTAX) = [F:SVV]BASDEPNOT+[F:SVV]BASDEPATI
    Endif
   Next
   Gosub LIGDEPVAT
  When 6
   NBTAX = 0
   For [PVV]PVV0 Where VCRNUM=[F:PIH]NUM & VCRTYP=8
    If !find([F:PVV]TAX,TCODTAX(1..NBTAX))
     NBTAX += 1
     TCODTAX(NBTAX) = [F:PVV]TAX
     TBASDEP(NBTAX) = [F:PVV]BASDEPNOT+[F:PVV]BASDEPATI
    Endif
   Next
   Gosub LIGDEPVAT
 Endcase
Endif
Return

$LIGDEPVAT
Local Char    ABRFIC(GLONABR)
Local Decimal AMTBASDEP, MONTANT, XMONT_ESC
Case ORIMOD
 When 3
  If [L]FLGFAC = 1 : ABRFIC = "SIH" : Else : ABRFIC = "PIH" : Endif
 When 5
  ABRFIC = "SIH"
 When 6
  ABRFIC = "PIH"
Endcase
AMTBASDEP = evalue("[F:"+ABRFIC+"]BASDEP")
Raz SOM_MONTANT
For NTAX=1 To NBTAX
 If NTAX = NBTAX
  [L]MONTANT = [L]XMONTANT-[L]SOM_MONTANT
 Else
  [L]MONTANT = arr([L]XMONTANT*(TBASDEP(NTAX)/[L]AMTBASDEP),[F:TCU]CURRND)
  [L]SOM_MONTANT += [L]MONTANT
 Endif
 Case GFONCTION
  When "GESPAY"
   Gosub CHARGE_DUD From SUBPAY2
   nolign = [M]NBLIG
   [M]VATLIN(nolign-1) = TCODTAX(NTAX)
   If dim([M:PAY1]VATLIN)>0
    Affzo [M:PAY1]VATLIN(nolign-1)
   Elsif dim([M:PAY2]VATLIN)>0
    Affzo [M:PAY2]VATLIN(nolign-1)
   Endif
   If FLGDEP & dim([M]EARDISFLG)>0
    [M]EARDISFLG(nolign-1) = 2
   Endif
   Gosub INIT_CCE From SUBPAY4
  When "PAYPROPAL"
   Local Decimal XMONT_ESC
   Local Integer ECLVAT
   [L]XMONT_ESC = [L]MONTANT : ECLVAT = 1
   Gosub LIGNE_DEP From PAYPROPAL2
   If GOK<1 : Break : Endif
 Endcase
Next
If GOK<1 : Return : Endif
Return

$SET_COST_ALLOCATIONS
Gosub SETNOL From SUBPAY3
Gosub RECH_ACCANA From SUBPAY3

[M]DSP(NOL) = ""
For DIE=1 To 20
 Case DIE
  When 1 :  [M]CCE1(NOL)  = ""
  When 2 :  [M]CCE2(NOL)  = ""
  When 3 :  [M]CCE3(NOL)  = ""
  When 4 :  [M]CCE4(NOL)  = ""
  When 5 :  [M]CCE5(NOL)  = ""
  When 6 :  [M]CCE6(NOL)  = ""
  When 7 :  [M]CCE7(NOL)  = ""
  When 8 :  [M]CCE8(NOL)  = ""
  When 9 :  [M]CCE9(NOL)  = ""
  When 10 : [M]CCE10(NOL) = ""
  When 11 : [M]CCE11(NOL) = ""
  When 12 : [M]CCE12(NOL) = ""
  When 13 : [M]CCE13(NOL) = ""
  When 14 : [M]CCE14(NOL) = ""
  When 15 : [M]CCE15(NOL) = ""
  When 16 : [M]CCE16(NOL) = ""
  When 17 : [M]CCE17(NOL) = ""
  When 18 : [M]CCE18(NOL) = ""
  When 19 : [M]CCE19(NOL) = ""
  When 20 : [M]CCE20(NOL) = ""
 Endcase
Next DIE

If CPTANA<>"" & !instr(1,CPTANA,"x")
 Call LEC_GAC(CPTANA,PLANA) From CPTLEC
 If !fstat
  If [F:GAC]UOM<>""
   Call LEC_TUN(UOM) From CPTLEC
   If fstat | [F:TUN]UOMDEC=0
    NBRRND = 1
   Else
    NBRRND =  10^(-[F:TUN]UOMDEC)
   Endif
  Else
   NBRRND = 1
  Endif
  If TNBRVTLTAX(NTAX)=1
   ANA = 1
   For I=1 To GNBAXE
    DIE= find(GAXE(I),TDIE)
    Case DIE
     When 1 :  [M]CCE1(NOL)  = TCCE1(NTAX,ANA)
     When 2 :  [M]CCE2(NOL)  = TCCE2(NTAX,ANA)
     When 3 :  [M]CCE3(NOL)  = TCCE3(NTAX,ANA)
     When 4 :  [M]CCE4(NOL)  = TCCE4(NTAX,ANA)
     When 5 :  [M]CCE5(NOL)  = TCCE5(NTAX,ANA)
     When 6 :  [M]CCE6(NOL)  = TCCE6(NTAX,ANA)
     When 7 :  [M]CCE7(NOL)  = TCCE7(NTAX,ANA)
     When 8 :  [M]CCE8(NOL)  = TCCE8(NTAX,ANA)
     When 9 :  [M]CCE9(NOL)  = TCCE9(NTAX,ANA)
     When 10 : [M]CCE10(NOL) = TCCE10(NTAX,ANA)
     When 11 : [M]CCE11(NOL) = TCCE11(NTAX,ANA)
     When 12 : [M]CCE12(NOL) = TCCE12(NTAX,ANA)
     When 13 : [M]CCE13(NOL) = TCCE13(NTAX,ANA)
     When 14 : [M]CCE14(NOL) = TCCE14(NTAX,ANA)
     When 15 : [M]CCE15(NOL) = TCCE15(NTAX,ANA)
     When 16 : [M]CCE16(NOL) = TCCE16(NTAX,ANA)
     When 17 : [M]CCE17(NOL) = TCCE17(NTAX,ANA)
     When 18 : [M]CCE18(NOL) = TCCE18(NTAX,ANA)
     When 19 : [M]CCE19(NOL) = TCCE19(NTAX,ANA)
     When 20 : [M]CCE20(NOL) = TCCE20(NTAX,ANA)
    Endcase
   Next
  Else
   TMPMNTANA = 0
   TMPQTYANA = 0
   SUMQTYANA = 0
   TOTCOE = 0
   STRLINANA = 0
   If [M:VT2]PTVENT>0
    LINANA = [M:VT2]PTVENT-1
   Else
    LINANA = [M:VT2]PTVENT # =0
   Endif
   For ANA = 1 To TNBRVTLTAX(NTAX)
    LINANA+=1
    If LINANA>=dim([M:VT2]TBAMT)-1
     If STRLINANA>0
      LINANA-=1
      [M:VT2]TBAMT(LINANA)+=[L]MONTANT-TMPMNTANA
      [M:VT2]TBQTY(LINANA)+=[M]QTYLIN(nolign-1)-TMPQTYANA
     Endif
     GMESSAGE = mess(79,117,1)-"("+mess(240,117,1)-num$(dim([M:VT2]TBAMT))+")"
     Break
    Endif
    If STRLINANA=0 : STRLINANA=LINANA : Endif
    If ANA<>TNBRVTLTAX(NTAX)
     [M:VT2]TBAMT(LINANA) = arr([L]MONTANT*(TOTCOE+TRATDSP(NTAX,ANA))/sum(TRATDSP(NTAX,1..TNBRVTLTAX(NTAX))),ARD)
&                          -arr([L]MONTANT*TOTCOE/sum(TRATDSP(NTAX,1..TNBRVTLTAX(NTAX))),ARD)
     If [M]QTYLIN(nolign-1)<>0
      [M:VT2]TBQTY(LINANA) = arr([M]QTYLIN(nolign-1)*(TOTCOE+TRATDSP(NTAX,ANA))/sum(TRATDSP(NTAX,1..TNBRVTLTAX(NTAX))),NBRRND)
&                          -arr([M]QTYLIN(nolign-1)*TOTCOE/sum(TRATDSP(NTAX,1..TNBRVTLTAX(NTAX))),NBRRND)
     Endif
    Else
     [M:VT2]TBAMT(LINANA)=[L]MONTANT-TMPMNTANA
     [M:VT2]TBQTY(LINANA)=[M]QTYLIN(nolign-1)-TMPQTYANA
    Endif
    If [M:VT2]TBAMT(LINANA)<>0 | [M:VT2]TBQTY(LINANA)<>0
     TMPMNTANA+=[M:VT2]TBAMT(LINANA)
     TMPQTYANA+=[M:VT2]TBQTY(LINANA)
     TOTCOE += TRATDSP(NTAX,ANA)
     For I=1 To GNBAXE
      DIE= find(GAXE(I),TDIE)
      Case DIE
       When 1 :  [M:VT2]TBCCE1(LINANA)  = TCCE1(NTAX,ANA)
       When 2 :  [M:VT2]TBCCE2(LINANA)  = TCCE2(NTAX,ANA)
       When 3 :  [M:VT2]TBCCE3(LINANA)  = TCCE3(NTAX,ANA)
       When 4 :  [M:VT2]TBCCE4(LINANA)  = TCCE4(NTAX,ANA)
       When 5 :  [M:VT2]TBCCE5(LINANA)  = TCCE5(NTAX,ANA)
       When 6 :  [M:VT2]TBCCE6(LINANA)  = TCCE6(NTAX,ANA)
       When 7 :  [M:VT2]TBCCE7(LINANA)  = TCCE7(NTAX,ANA)
       When 8 :  [M:VT2]TBCCE8(LINANA)  = TCCE8(NTAX,ANA)
       When 9 :  [M:VT2]TBCCE9(LINANA)  = TCCE9(NTAX,ANA)
       When 10 : [M:VT2]TBCCE10(LINANA) = TCCE10(NTAX,ANA)
       When 11 : [M:VT2]TBCCE11(LINANA) = TCCE11(NTAX,ANA)
       When 12 : [M:VT2]TBCCE12(LINANA) = TCCE12(NTAX,ANA)
       When 13 : [M:VT2]TBCCE13(LINANA) = TCCE13(NTAX,ANA)
       When 14 : [M:VT2]TBCCE14(LINANA) = TCCE14(NTAX,ANA)
       When 15 : [M:VT2]TBCCE15(LINANA) = TCCE15(NTAX,ANA)
       When 16 : [M:VT2]TBCCE16(LINANA) = TCCE16(NTAX,ANA)
       When 17 : [M:VT2]TBCCE17(LINANA) = TCCE17(NTAX,ANA)
       When 18 : [M:VT2]TBCCE18(LINANA) = TCCE18(NTAX,ANA)
       When 19 : [M:VT2]TBCCE19(LINANA) = TCCE19(NTAX,ANA)
       When 20 : [M:VT2]TBCCE20(LINANA) = TCCE20(NTAX,ANA)
      Endcase
     Next I
    Else
     LINANA-=1
     If LINANA=0 : STRLINANA=0 :Endif
    Endif
   Next ANA
   If STRLINANA>0
    [M]PTV(nolign-1) = STRLINANA
    [M]PTF(nolign-1) = LINANA
    [M]DSP(nolign-1) = "$"
    [M:VT2]PTVENT = LINANA+1
   Endif
  Endif
 Endif
Endif
Return

