###################################################################
# chargement direct de la table AREPORTM en traitement auto
# gosub appelé du traitement ETAT 
###################################################################
$ALIMETAT

Local Integer WCOPNBR, DEST, NUMREQ
Default File [SDH]

# no requete
If [V]GWNUMREQ = 0 
   [V]GWNUMREQ = uniqid([ARP])
Endif
[L]NUMREQ  = [V]GWNUMREQ

# si plusieurs etats garnir la bonne classe [F]
If ETAT<>[F:ARP]RPTCOD 
  Read [ARP] ARP0=ETAT
Endif

# destination : imprimante
[L]DEST = 1

# création dans AREPORTM et maj flag édition dans MFGPRN
Call DEBTRANS From GLOCK 
WNUMLIG=NUMLIG
Gosub TR1
NUMLIG=WNUMLIG
Return


