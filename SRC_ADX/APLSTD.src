######################################################################################
## Etiquette ajoutée par le superviseur (écran AST1) 04/10/2017 16:27:04 (CCC)
######################################################################################
Subprog AM_AUZMOD(VALEUR)
Variable Integer VALEUR

# Issue 55535 - 2017-10-04 by CCC : A modifiable menu can't be for all products. It must be defined by product
If dim([M:AST1]FLGPRO)>0
    If VALEUR=2
        [M:AST1]FLGPRO = 2
        Grizo [M:AST1]FLGPRO
        Affzo [M:AST1]FLGPRO
    Else
        Actzo [M:AST1]FLGPRO
    Endif
Endif

End


