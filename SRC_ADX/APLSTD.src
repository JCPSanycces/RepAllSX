#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Call MESSAGE(GBIDI1)
End

#-------------------------------------------------------------------#
Subprog MESSAGE(VALEUR)
Variable Integer VALEUR
Local Char PARAM(30)(1..2)
Call SAISIE_LIB(VALEUR,PARAM,"FAPLSTD","APLSTD","XWAPLSTD") From GSAISIE
End

#-------------------------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer  PSUBB
 Call EXISTE_ADX("","","APLSTDB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "FIN"          : Gosub FIN
 When "NEW"          : Gosub NOUVEAU
 When "RAF"          : Gosub RAFFRAICHIR
 When "SUP"          : Gosub ANNULE : Gosub RELIT
 When "ENR"          : Gosub ENREGISTRE
 When "CRE"          : Gosub CREE
 When "FIR"          : Gosub PREMIER
 When "LAS"          : Gosub DERNIER
 When "SUI"          : Gosub SUIVANT
 When "PRE"          : Gosub PRECEDENT
 When "GAU"          : Gosub GAUCHE
 When "TIR"          : Gosub TIROIR
 When "ABA"          : Gosub ABANDON
 When "EDI"          : Gosub EDITION
 When "SEL"          : Gosub SELECTION
 When "SRA"          : Gosub SELRAP
 When "PRG"          : Gosub PRE_GAUCHE
 When "SVG"          : Gosub SUI_GAUCHE
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "SETBOUT"      : Gosub SETBOUT
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "SEL_TABLE"
  Case TABLE
   When "SELAST"     : Gosub S_SELAST
   When "SELASTMEN"  : Gosub S_SELASTMEN
  Endcase
 When "BOUT_TABLE"
  Case TABLE
   When "SELAST"     : Gosub B_SELAST
   When "SELASTMEN"  : Gosub B_SELASTMEN
  Endcase
 When "TRT_DIV"
  Case TRAIT
   When "CONTMNL"    : Gosub T_CONTMNL
  Endcase

 When Default
Endcase
If PSUBB
 Gosub ACTION From APLSTDB
Endif
Return

############################################################################
$OUVRE
If clalev([F:AML])=0  : Local File AMENLOC [AML]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV   [ACV]  : Endif
If clalev([F:AST])=0  : Local File APLSTD  [AST]  : Endif
If clalev([F:AST4])=0 : Local File APLSTD  [AST4] : Endif : # Intitulés Chapitres    100..
If clalev([F:AST5])=0 : Local File APLSTD  [AST5] : Endif : # Intitulés Menus locaux 1  .. 99
If clalev([F:AST6])=0 : Local File APLSTD  [AST6] : Endif : # Intitulés Menus locaux 201..
If clalev([F:AST7])=0 : Local File APLSTD  [AST7] : Endif
If clalev([F:ALI])=0  : Local File ALINK   [ALI]  : Endif
If clalev([F:ALS])=0  : Local File ALSTRD  [ALS]  : Endif

Link [AML]  With [AST4]CLE = [F:AML]MENLOC;0;GLANGUE
&              , [AST5]CLE = 0;[F:AML]MENLOC;GLANGUE
&              , [AST6]CLE = 200;([F:AML]MENLOC-200);GLANGUE
&              , [ACV]CODACT = [F:AML]CODACT
& As [AST_]
& Order By Key MENLOC

Local Mask AST1 [AST1]

Local Char  OGFONCTION(GLONAFC)
OGFONCTION = GFONCTION
GFONCTION = "TXT" : # Pour avoir l'aide sur fonction en cas de tunnel

#VPO 23/06/08 bug47297: menu documentation du messages et tables diverses
Local Integer OPTDOC
Call CONT_DOC(OPTDOC)
# Menus documentation
If OPTDOC : Gosub CHARGE_MENDOC : Endif

# Menu documentation
$CHARGE_MENDOC
Addmen GSTAMED+GPILOBJ Titled mess(108,139,1) To 307 At 102             : # Documentation
Additm GSTADOC1 Titled mess(109,139,1)        To GSTAMED+GPILOBJ At 10  : # Paragraphes
Additm GSTADOC2 Titled mess(130,133,1)        To GSTAMED+GPILOBJ At 11  : # Liens
If !GCONSULT
 Additm GSTADOC3 Titled mess(29,115,1)         To GSTAMED+GPILOBJ At 12 : # Génération
Endif

Return

###############################################################
Subprog CONT_DOC(OPTDOC)
Variable Integer OPTDOC
Local File ATABDIV   [AD__]
Look [AD__]CODE = 910;"AML"
OPTDOC = !fstat
End

############################################################################
$DEBUT
Local Integer CLECUR , CLECUR1, CHAPITRE , NUMERO, FLGMENLOC
Local Char    FILTRE(250)(1..2) , CHAINE(250) , CRITERE(250)(1..2) , SIGRAP(2) , REFRAP(50)
Local Integer NOCHP , NOLIB , MODMEN , INSMEN , SUITE , ICRITERE
Local Char    TITLIB(250) , BOXALI(20) , BOXDER(20) , BOXAST(20) , MESSA(250)
Local Integer FORCE
If find(type(VALEUR),1,2,4,5,6,7,8,9)
 NUMERO = VALEUR
Endif
Raz MODMEN , INSMEN
BOXAST = "GAU_CHE"+num$(find("AST",OBJLIS(1..dim(OBJLIS)-1)))
BOXALI = "GAU_CHE"+num$(find("ALI",OBJLIS(1..dim(OBJLIS)-1)))
BOXDER = "GAU_CHE"+num$(find("AS2",OBJLIS(1..dim(OBJLIS)-1)))
FILTRE = '([F:AML]CODACT="" | [F:ACV]FLACT=2)'
CRITERE = FILTRE
Gosub REMPLIT
REP = ""
Raz [M]
If NUMERO<>0
 CHAPITRE = NUMERO
Elsif GNBDERNIER
 Filter [ALS] Where USR=GUSER & OBJ="AST" Order By Key ALS0 Desc
 Read [ALS]ALS0 First
 Filter [ALS]
 If !fstat
  CHAPITRE = val([F:ALS]CLES)
 Endif
Endif
If CHAPITRE
 Filter [AST_] Where evalue(FILTRE)
 Read [AST_]MENLOC=CHAPITRE
 Filter [AST_]
 If !fstat
  Gosub LECTURE
 Else
  CHAPITRE = 0
 Endif
Endif
Return

###############################################
$SET_TBLAN
Local Char    TBLAN(GLONLAN)(1..50)
Local Integer NBLAN , NOLAN
Raz NBLAN , TBLAN
For [AST7]LAN(1) Where LAN<>"XXX" & LAN<>"" & LAN<>GLANGUE & LANCHP=101
 NBLAN += 1
 TBLAN(NBLAN) = [F:AST7]LAN
Next AST7
Return

############################################################################
$RAFFRAICHIR
CRITERE(1) = FILTRE(1)
CRITERE(2) = FILTRE(2)
Gosub REMPLIT
Return

$REMPLIT
Case currbox
 When BOXALI
  Raz CRITERE, ICRITERE
  CRITERE = '[F:ALI]USRCOD="'+GLIAISON+'" & [F:ALI]SRCOBJ="AML"'
  CRITERE -= '& [F:ALI]SRCKEY="'+num$(CLECUR1)+'" & [F:ALI]ENAFLG=2'
 When BOXAST
  Filter [AST_] Where evalue(CRITERE)
  adxmxl = GNBGAUCHE
  Raz I , SUITE
  For [AST_]
   I += 1 : If I>GNBGAUCHE : SUITE = 1 : Break : Endif
  Next AST_
  Fillbox [AST1]
  Filter [AST_]
  FOK = 0
 When BOXDER
  CRITERE = '[F:ALS]USR="'+GUSER+'" & [F:ALS]OBJ="AST"'
Endcase
Return

############################################################################
$FIN
Gosub DEVERROU
NUMERO = CHAPITRE
adxmbm = adxmbm
If MODMEN
 Call MENULOC From GENMENULOC
Endif
If INSMEN
 Call MESSAGE(mess(59,139,1)) From GESECRAN
 # Après une insertion de  lignes dans un menu local il faut revoir les traductions dans les autres langues
Endif
GFONCTION = OGFONCTION
Return

############################################################################
$AP_CHOIX
#VPO 23/06/08 bug47297: menu documentation du messages et tables diverses
If [M]MENLOCAL=2
Local Char    CLECHP1(GLONID1) , CLECHP2(GLONID2)(0..16)
Case REPONSE
 When GSTADOC1 : CLECHP1= format$('N0:4',[M]LANCHP) : CLECHP2=""
                 Call PARAGRAPHES("AML",CLECHP1,CLECHP2) From GOBJACT
 When GSTADOC2 : CLECHP1= format$('N0:4',[M]LANCHP) : CLECHP2=""
                 Call LIENS("AML",CLECHP1,CLECHP2) From GOBJACT
 When GSTADOC3 : CLECHP1= format$('N0:4',[M]LANCHP) : CLECHP2=""
                 Call GENDOC("AML",CLECHP1,CLECHP2) From GOBJACT
Endcase
Endif

If REPONSE=GSTACLK+3
 Gosub VERROU
 If VERROU
  REPONSE = 0
  Gosub LECTURE
 Endif
Endif
Return

############################################################################
$SETBOUT
#VPO 23/06/08 bug47297: menu documentation du messages et tables diverses
If [M]MENLOCAL=2
    Enable GSTADOC1,GSTADOC2
    If !GCONSULT
      Enable GSTADOC3
    Endif
Else
    Disable GSTADOC1,GSTADOC2
    If !GCONSULT
      Disable GSTADOC3
    Endif
Endif

If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHMEN,"2") From GOBJET
 Call VIREBOUT(CHBOU,"S") From GOBJET
Endif
If instr(1,CHBOU,"=")=0 : CHBOU += "="  : Endif
If !VERROU & CLECUR & !find(REP,"C","D") & !GCONSULT
 IMGFLG(3) = 1 : # Cadenas
Else
 IMGFLG(3) = 0
Endif
K = 1
If CLECUR & GCONSULT
 Call VIREBOUT(CHBOU,"MS") From GOBJET
 IMGFLG(5) = 1 : # Croix blanche
Else
 IMGFLG(5) = 0
Endif
If GCONSULT
 Call VIREBOUT(CHBOU,"N") From GOBJET : #Nouveau
Endif

Return

############################################################################
$EDITION
Call PRTSCR("AST1","","",0,0) From ATRTX3 : # <MG> 01/03/00
Call IMPSCR From ATRTX3                   : # <MG> 01/03/00
Return

############################################################################
$TIROIR
Raz [L]SAIRAP
If currbox<>BOXCURR
 If currbox=BOXAST
  CRITERE(1) = FILTRE(1)
  CRITERE(2) = FILTRE(2)
 Endif
 Gosub REMPLIT
Endif
Return

############################################################################
$GAUCHE
Case currbox
 When BOXALI
  Read [ALI]ALI0 =
  J = instr(1,[F:ALI]DSTXXX,"|")
  If J
   Local Char ABREV(GLONAOB) , CLE1(GLONID) , CLE2(GLONID)
   ABREV = left$([F:ALI]DSTXXX,J-1)
   CLE1  = right$([F:ALI]DSTXXX,J+1)
   If ABREV<>""
    Gosub SETCLE From ="WO"+ABREV
    If CLESEC(0)<>""
     K = instr(1,CLE1,"~")
     If K
      CLE2 = right$(CLE1,K+1)
      CLE1  = left$(CLE1,K-1)
     Else
      CLE2 = ""
     Endif
    Endif
    Call OBJET(ABREV,CLE1,CLE2) From GOBJET
   Endif
  Endif
 When BOXAST
  fstat = 0
  Goto SUIVPREC
 When BOXDER
  Read [AST_]MENLOC = val([F:ALS]CLES)
  If !fstat
   Goto SUIVPREC
  Endif
Endcase
Return

############################################################################
$PREMIER
Filter [AST_] Where MENLOC<>0 & MENLOC<>200 & MENLOC<30000 & evalue(FILTRE)
Read [AST_]MENLOC First
Goto SUIVPREC

############################################################################
$DERNIER
Filter [AST_] Where MENLOC<>0 & MENLOC<>200 & MENLOC<30000 & evalue(FILTRE)
Read [AST_]MENLOC Last
Goto SUIVPREC

############################################################################
$SUIVANT
Filter [AST_] Where MENLOC<>0 & MENLOC<>200 & MENLOC<30000 & evalue(FILTRE)
Read [AST_]MENLOC>CHAPITRE
Goto SUIVPREC

############################################################################
$PRECEDENT
Filter [AST_] Where MENLOC<>0 & MENLOC<>200 & MENLOC<30000 & evalue(FILTRE)
Read [AST_]MENLOC<CHAPITRE
Goto SUIVPREC

############################################################################
$SUIVPREC
Filter [AST_]
If fstat
 Call MESSAGE(mess(11,100,1)) From GESECRAN
 Return
Else
 Gosub DEVERROU
 CHAPITRE = [F:AST_]MENLOC
 Gosub LECTURE
 REP = ""
Endif
Gosub GRISEMEN
Return

####################################################################################################
$PRE_GAUCHE
Case currbox
 When BOXAST
  If [F:AST_]MENLOC
   K = [F:AST_]MENLOC
  Endif
  If K
   Filter [AST_] Where MENLOC<>0 & MENLOC<>200 & MENLOC<30000 & MENLOC<K
&              & evalue(FILTRE)
&                Order By MENLOC Desc
   I = GNBGAUCHE
   For [AST_]
    I -= 1 : If I=0 : Break : Endif
   Next
   Filter [AST_]
   K = [F:AST_]MENLOC
   Raz CRITERE , ICRITERE
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILTRE(1),"") From GOBJSUB
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILTRE(2),"") From GOBJSUB
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[F:AML]MENLOC>="+num$(K),"&") From GOBJSUB
   Gosub REMPLIT
  Endif
  FOK = 0
Endcase
Return

####################################################################################################
$SUI_GAUCHE
Case currbox
 When BOXAST
  If SUITE
   If [F:AST_]MENLOC
    K = [F:AST_]MENLOC
   Endif
   If K
    Raz CRITERE , ICRITERE
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILTRE(1),"") From GOBJSUB
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILTRE(2),"") From GOBJSUB
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[F:AML]MENLOC>"+num$(K),"&") From GOBJSUB
    Gosub REMPLIT
   Endif
  Endif
  FOK = 0
Endcase
Return

############################################################################
$SELRAP
Raz CRITERE , ICRITERE
CHAINE = '([F:AML]CODACT="" | [F:ACV]FLACT=2)'
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CHAINE,"&") From GOBJSUB
Gosub CRITRAP
If CRITERE<>""
 FILTRE(1) = CRITERE(1)
 FILTRE(2) = CRITERE(2)
 Gosub REMPLIT
Endif
FOK = 0
Return

$CRITRAP
# No de message/menu
If [L]SAIRAP(1)<>""
 SIGRAP = ""
 If find(left$(SAIRAP(1),2),"<=",">=","<>")
  SIGRAP = left$(SAIRAP(1),2)
  REFRAP = right$(SAIRAP(1),3)
 Elsif find(left$(SAIRAP(1),1),"<",">","=")
  SIGRAP = left$(SAIRAP(1),1)
  REFRAP = right$(SAIRAP(1),2)
 Endif
 If SIGRAP<>""
  CHAINE = '[F:AML]MENLOC'+SIGRAP+num$(val(REFRAP))
 Else
  CHAINE = '[F:AML]MENLOC>='+num$(val([L]SAIRAP(1)))
 Endif
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CHAINE,"&") From GOBJSUB
Endif
# Intitulé
If [L]SAIRAP(2)<>""
 If dim([V]GCASSE)>0 & GCASSE=1
  [L]SAIRAP(2) = toupper([L]SAIRAP(2))
  CHAINE = '(([F:AML]MENLOCAL<>2 & pat(toupper([F:AST4]LANMES),"'+[L]SAIRAP(2)+'")=1)'
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CHAINE,"&") From GOBJSUB
  CHAINE = '([F:AML]MENLOC<100 & [F:AML]MENLOCAL=2 & pat(toupper([F:AST5]LANMES),"'+[L]SAIRAP(2)+'")=1)'
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CHAINE,"|") From GOBJSUB
  CHAINE = '([F:AML]MENLOC>200 & [F:AML]MENLOCAL=2 & pat(toupper([F:AST6]LANMES),"'+[L]SAIRAP(2)+'")=1))'
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CHAINE,"|") From GOBJSUB
 Else
  CHAINE = '(([F:AML]MENLOCAL<>2 & pat([F:AST4]LANMES,"'+[L]SAIRAP(2)+'")=1)'
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CHAINE,"&") From GOBJSUB
  CHAINE = '([F:AML]MENLOC<100 & [F:AML]MENLOCAL=2 & pat([F:AST5]LANMES,"'+[L]SAIRAP(2)+'")=1)'
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CHAINE,"|") From GOBJSUB
  CHAINE = '([F:AML]MENLOC>200 & [F:AML]MENLOCAL=2 & pat([F:AST6]LANMES,"'+[L]SAIRAP(2)+'")=1))'
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CHAINE,"|") From GOBJSUB
 Endif
Endif
# Menu local (O/N)
If SAIRAP(3)<>""
 If left$(toupper(SAIRAP(3)),1)="N" or SAIRAP(3)="1"
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:AML]MENLOCAL=1',"&") From GOBJSUB
 Elsif left$(toupper(SAIRAP(3)),1)="O" or SAIRAP(3)="2"
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:AML]MENLOCAL=2',"&") From GOBJSUB
 Endif
Endif
# Module
If SAIRAP(4)<>""
 SIGRAP = ""
 If find(left$(SAIRAP(4),2),"<=",">=","<>")
  SIGRAP = left$(SAIRAP(4),2)
  REFRAP = right$(SAIRAP(4),3)
 Elsif find(left$(SAIRAP(4),1),"<",">","=")
  SIGRAP = left$(SAIRAP(4),1)
  REFRAP = right$(SAIRAP(4),2)
 Else
  REFRAP = SAIRAP(4)
 Endif
 If SIGRAP=""
  SIGRAP = "="
 Endif
 CHAINE = ""
 If num$(val(REFRAP))=REFRAP & REFRAP>="0" & REFRAP<="999"
  CHAINE = "[F:AML]MODULE"+SIGRAP+REFRAP
 Else
  For J=1 To len(mess(0,14,1))
   K = 0
   If instr(1,REFRAP,"*") or instr(1,REFRAP,"?")
    If pat(toupper(ctrans(mess(J,14,1))),toupper(ctrans(REFRAP)))
     K = 1
    Endif
   Else
    If evalue("left$(toupper(ctrans(mess(J,14,1))),len(REFRAP))"+SIGRAP+"toupper(ctrans(REFRAP))")
     K = 1
    Endif
   Endif
   If K & len(CHAINE)<200
    If CHAINE=""
     CHAINE = "("
    Else
     CHAINE += "|"
    Endif
    CHAINE += "[F:AML]MODULE"+"="+num$(J)
   Endif
  Next J
  If CHAINE<>""
   CHAINE += ")"
  Endif
 Endif
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CHAINE,"&") From GOBJSUB
Endif
# Code activité
If [L]SAIRAP(5)<>""
 SIGRAP = ""
 If find(left$(SAIRAP(5),2),"<=",">=","<>")
  SIGRAP = left$(SAIRAP(5),2)
  REFRAP = right$(SAIRAP(5),3)
 Elsif find(left$(SAIRAP(5),1),"<",">","=")
  SIGRAP = left$(SAIRAP(5),1)
  REFRAP = right$(SAIRAP(5),2)
 Else
  REFRAP = SAIRAP(5)
 Endif
 If SIGRAP<>""
  CHAINE = '[F:AML]CODACT'+SIGRAP+'"'+REFRAP+'"'
 Else
  CHAINE = '[F:AML]CODACT="'+REFRAP+'"'
 Endif
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CHAINE,"&") From GOBJSUB
Endif
Return

############################################################################
$SELECTION
Raz FILTRE , CRITERE
Call ACT_SELECT("AMENLOC",FILTRE,OK)
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILTRE,"&") From GOBJSUB
FILTRE = '([F:AML]CODACT="" | [F:ACV]FLACT=2)'
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILTRE,"&") From GOBJSUB
FILTRE = CRITERE
If OK
 Gosub REMPLIT
Endif
FOK = 0
Return

############################################################################
Subprog ACT_SELECT(TABLE,FILTRE,OK)
Value    Char    TABLE
Variable Char    FILTRE()
Variable Integer OK
Local    Char    PARBOUT(250)(1..4) , VALBOUT(30)
PARBOUT(4) = TABLE
Call SAISIE_CHAR(VALBOUT,PARBOUT,"ASELOBJ","ASELOBJ","XWASELOBJ") From GSAISIE
OK = val(PARBOUT(3))
If OK : FILTRE = PARBOUT(2) : Endif
End

############################################################################
$ABANDON
CHAPITRE = CLECUR1
Gosub RELIT
REP = ""
Return

############################################################################
$NOUVEAU
Gosub DEVERROU
REP = "C"
CHAPITRE = 0
Effzo
Gosub DEGRISEMEN
Gosub UNLOCK_TXT    # X3-9046
Raz GMODIF
Return

############################################################################
$APRES_MODIF
If COUZON="LANCHP"
 Read [AST_]MENLOC = zc
 If !fstat
  If FILTRE<>"" & evalue(FILTRE)=0
   Call ERREUR(mess(8,123,1)) From GESECRAN : # Accès impossible à cette fiche
   mkstat = 2 : Return
  Endif
  CHAPITRE = zc
  Gosub LECTURE
  Gosub SETBOUT
  REP = ""
 Elsif !GCONSULT
  Call PLAGE(num$(zc),2) From CONTOBJ : # Contrôle plages messages
  If mkstat : Return : Endif
  Gosub DEVERROU
  Gosub DEGRISE
  Gosub DEGRISEMEN
  Gosub UNLOCK_TXT  # X3-9046 : if it has been locked before
  REP = "C"
  If [M]LANCHP
   Look [AST_]MENLOC=[M]LANCHP
   If !fstat
    REP = "D"
   Endif
  Endif
  Gosub SETBOUT
 Else GCONSULT
  Call ERREUR(mess(7,123,1)) From GESECRAN : # Création impossible
  mkstat = 2 : Return
 Endif
Elsif COUZON="MENLOCAL"
 If zc=2
  Gosub DEGRISE
 Else
  Gosub GRISE
 Endif
Elsif REP=""
 If GCONSULT
  Call ERREUR(mess(9,123,1)) From GESECRAN : # Modification impossible
  mkstat = 2 : Return
 Elsif !VERROU
  Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
  mkstat = 2 : Return
 Endif
 REP = "M"
 Gosub SETBOUT
Endif
Return

############################################################################
$GRISE
Effzo MINI,MAXI,AUZMOD,LONG
Grizo MINI,MAXI,AUZMOD,LONG
Return

$DEGRISE
Actzo MINI,MAXI,AUZMOD,LONG
Return

$GRISEMEN
Grizo MENLOCAL
Return

$DEGRISEMEN
Actzo MENLOCAL
Return

############################################################################
$ENREGISTRE
If [M]LANCHP=0
 Call ERREUR("Error Item=0 during change") From GESECRAN
 Return
Elsif [M]MENLOCAL=2 & [M]NBLIG>0 & sum([M]CODE)=""
 Call ERREUR(mess(10,123,1)) From GESECRAN : # Zone obligatoire
 zonsui = "CODE(0)" : Return
Endif
If [M]NBLIG<[M]MINI
 GERR = 1 : GMESSAGE = mess(133,124,1)-num$([M]MINI) : # Nombre minimum de libellés
 zonsui = "CODE(0)" : Return
Endif
If [M]MAXI<>0 & [M]NBLIG>[M]MAXI
 GERR = 1 : GMESSAGE = mess(134,124,1)-num$([M]MAXI) : # Nombre maximum de libellés
 zonsui = "CODE(0)" : Return
Endif
# Issue 82923 - 2012-06-14 by VPO : AML97 nombre maximum
If [M]LANCHP=97 & [M]NBLIG>99
 GERR = 1 : GMESSAGE = mess(134,124,1)-num$(99) : # Nombre maximum de libellés
 zonsui = "CODE(0)" : Return
Endif
#
If GADONIX=2
 K = 1
 Call VERIF_GRP("AML",num$([M]LANCHP),"",K) From GOBJET
 If !K : : Return : Endif
Endif
FORCE = 0
If dim([M]NONTRA)>0 & [M]NONTRA<>2 & dim([F:AST]LANORI)>0
 K = 0
 For nolign=1 To [M]NBLIG
    If [M]LANNUM(nolign-1)<>0 # Skip new messages
        Read [AST]CLE = [M]LANCHP;[M]LANNUM(nolign-1);GLANGUE
        If !fstat & [F:AST]LANMES<>[M]LANMES(nolign-1)
         If dim(TBLAN)<0 : Gosub SET_TBLAN : Endif
         For NOLAN=1 To NBLAN
          Read [AST]CLE=[M]LANCHP;[M]LANNUM(nolign-1);TBLAN(NOLAN)
          If !fstat & [F:AST]LANORI=""
           K += 1 : Break
          Endif
         Next NOLAN
        Endif
    Endif
 Next nolign
 If K
  # Vous avez modifié $1$ textes qui ont déjà été traduits.\Si le sens a changé, il faut écraser ces traductions
  # Voulez-vous vraiment écraser ces traductions ?
  Call OUINON(func AFNC.MES1(mess(73,143,1)+"\"+mess(82,143,1),num$(K)),K) From GESECRAN
  If K=2 : FORCE = 1 : Endif
 Endif
Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK>=1
 If GADONIX=2 : Call TRACE_COR("AML",num$([M]LANCHP),"","M") From GOBJET : Endif
 If [M]MENLOCAL=2
  MODMEN = 1
 Endif
 REP = ""
 GMODIF=0
Endif
If GMODIF
 INSMEN = 1
Endif

If GMODIF=0 & GERR=0
  Gosub RELIT
Endif

Return

$TR1
GOK=1
Local Integer LSTATUS, LNUM
Local Char LERRMSG(250)
Trbegin [AST]

 # X3-9046 : Create enreg 0 in text server first
 Gosub TIT
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 For nolign=1 To [M]NBLIG
  K = 0
  Read [AST]CLE = [M]LANCHP;[M]LANNUM(nolign-1);GLANGUE
  If fstat | [M]LANNUM(nolign-1)=0  # With text server, LANNUM=0 for new lines
   Raz [F:AST]
   [F:AST] = [M]
   [F:AST]LAN = GLANGUE
   Call FLDCRE("AST") From OBJDIV
   If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
     LSTATUS = func  APLSTD.CREATE_MESSAGE([F:AST]LANCHP, LNUM, [F:AST]LAN,  [M:AST1]CODE(nolign-1), [M:AST1]LANMES(nolign-1), [F:AST]LANORI, LERRMSG)
     If LSTATUS<> CST_AOK
      GOK=0
      GERR=1
      GMESSAGE = LERRMSG
      Break
     Endif
     [M:AST1]LANNUM(nolign-1) = LNUM
     [F:AST]LANNUM = LNUM
   Endif
   Write [AST]
   If fstat
    GOK=0 : Call FSTA("AST") From GLOCK : Break
   Endif
   K = 1
  Elsif [F:AST]LANMES<>[M]LANMES(nolign-1)
   [F:AST] = [M]
   [F:AST]LAN = GLANGUE
   Call FLDUPD("AST") From OBJDIV
   Rewrite [AST]
   If fstat
    GOK=0 : Call FSTA("AST") From GLOCK : Break
   Endif
   If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
     LSTATUS= func APLSTD.UPDATE_MESSAGE([F:AST]LANCHP,[M:AST1]LANNUM(nolign-1), [F:AST]LAN, [M:AST1]CODE(nolign-1), [M:AST1]LANMES(nolign-1), [F:AST]LANORI, LERRMSG)
     If LSTATUS<> CST_AOK
         GOK=0
         GERR=1
         GMESSAGE=LERRMSG
         Break
     Endif
   Endif
   K = 1
  # Issue X3-76643 - 2018-02-12 by CCC : Check change of code to update texts server
  Elsif [M]MENLOCAL=2 & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
    # Get list of codes
    If [F:AST7]LANCHP<>[F:AST]LANCHP | [F:AST7]LANNUM<>0 | [F:AST7]LAN<>[F:AST]LAN
        Read [AST7]CLE = [F:AST]LANCHP;0;[F:AST]LAN
    Endif
    # If the code has been modified, it must be updated on texts server
    If mid$([F:AST7]LANMES,nolign,1)<>[M:AST1]CODE(nolign-1)
        LSTATUS= func APLSTD.UPDATE_MESSAGE([F:AST]LANCHP,[M:AST1]LANNUM(nolign-1), [F:AST]LAN, [M:AST1]CODE(nolign-1), [M:AST1]LANMES(nolign-1), [F:AST]LANORI, LERRMSG)
        If LSTATUS<> CST_AOK
            GOK=0
            GERR=1
            GMESSAGE=LERRMSG
            Break
        Endif
    Endif
  Endif
  # Issue 88823 - 2013-03-26 by VPO : on ne tient pas compte de NONTRA ici
  #If K & dim([M]NONTRA)>0 & [M]NONTRA<>2 & dim([F:AST]LANORI)>0
  If K & dim([F:AST]LANORI)>0
   If dim(TBLAN)<0 : Gosub SET_TBLAN : Endif
   For NOLAN=1 To NBLAN
    Readlock [AST]CLE=[M]LANCHP;[M]LANNUM(nolign-1);TBLAN(NOLAN)
    If fstat
     [F:AST] = [M]
     [F:AST]LAN = TBLAN(NOLAN)
     # Issue 88823 - 2013-05-02 by VPO : NONTRA=2 pas de LANORI
     If dim([M]NONTRA)>0 & [M]NONTRA=2
      [F:AST]LANORI = ""
     Else
      [F:AST]LANORI = GLANGUE
     Endif
     Call FLDCRE("AST") From OBJDIV
     Write [AST]
     If fstat
      GOK=0 : Call FSTA("AST") From GLOCK : Break 2
     Endif
     If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
      LSTATUS = func  APLSTD.UPDATE_MESSAGE([F:AST]LANCHP,[F:AST]LANNUM, [F:AST]LAN,  [M:AST1]CODE(nolign-1), [M:AST1]LANMES(nolign-1), [F:AST]LANORI, LERRMSG)
      If LSTATUS<> CST_AOK
        GOK=0
        GERR=1
        GMESSAGE=LERRMSG
        Break
      Endif
     Endif
    # Issue 88823 - 2013-05-02 by VPO : NONTRA=2 pas de LANORI, on ecrit toutes les langues
    Elsif !fstat & ([F:AST]LANORI<>"" or FORCE or (dim([M]NONTRA)>0 & [M]NONTRA=2))
     [F:AST] = [M]
     [F:AST]LAN = TBLAN(NOLAN)
     # Issue 88823 - 2013-05-02 by VPO : NONTRA=2 pas de LANORI
     If dim([M]NONTRA)>0 & [M]NONTRA=2
      [F:AST]LANORI = ""
     Else
      [F:AST]LANORI = GLANGUE
     Endif
     Call FLDUPD("AST") From OBJDIV
     Rewrite [AST]
     If fstat
      GOK=0 : Call FSTA("AST") From GLOCK : Break 2
     Endif
     If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
      LSTATUS= func APLSTD.UPDATE_MESSAGE([F:AST]LANCHP,[F:AST]LANNUM, [F:AST]LAN,[M:AST1]CODE(nolign-1), [M:AST1]LANMES(nolign-1),[F:AST]LANORI, LERRMSG)
      If LSTATUS<> CST_AOK
        GOK=0
        GERR=1
        GMESSAGE=LERRMSG
        Break
      Endif
     Endif
    Endif
   Next NOLAN
  Endif
 Next nolign
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 # Issue 88823 - 2013-03-26 by VPO : on ne tient pas compte de NONTRA ici
 #If dim([M]NONTRA)>0 & [M]NONTRA<>2 & dim([F:AST]LANORI)>0
 If dim([F:AST]LANORI)>0
  If dim(TBLAN)<0 : Gosub SET_TBLAN : Endif
  For [AST]CLE Where find(LAN,GLANGUE,TBLAN(1..NBLAN)) & LANCHP=[M]LANCHP & LANNUM<>0
   If !find([F:AST]LANNUM,[M]LANNUM(0..[M]NBLIG-1))
   If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
      LSTATUS= func APLSTD.DELETE_MESSAGE([F:AST]LANCHP,[F:AST]LANNUM, LERRMSG)
      If LSTATUS<> CST_AOK
        GOK=0
        GERR=1
        GMESSAGE=LERRMSG
        Break
      Endif
    Endif
    Delete [AST]
    If fstat=1
     GOK = -1 : GLOCK = "$APLSTD"-num$([M]LANCHP)-num$([F:AST]LANNUM) : Break
    Endif
   Endif
  Next AST
 Else
  For [AST]CLE Where LAN=GLANGUE & LANCHP=[M]LANCHP & LANNUM<>0
    If !find([F:AST]LANNUM,[M]LANNUM(0..[M]NBLIG-1))
      If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
      LSTATUS= func APLSTD.DELETE_MESSAGE([F:AST]LANCHP,[F:AST]LANNUM, LERRMSG)
      If LSTATUS<> CST_AOK
        GOK=0
        GERR=1
        GMESSAGE=LERRMSG
        Break
      Endif
    Endif
    Delete [AST]
    If fstat=1
     GOK = -1 : GLOCK = "$APLSTD"-num$([M]LANCHP)-num$([F:AST]LANNUM) : Break
    Endif
   Endif
  Next AST
 Endif
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
# X3-9046 Move this block to create record 0 in text server first
# Gosub TIT
# If GOK<0   : Goto ROLL_TR1
# Elsif !GOK : Goto AB_TR1
# Endif
 Gosub TITLIB
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub MENLOC
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$MENLOC
Readlock [AML]MENLOC = [M]LANCHP
If fstat=1
 GOK = -1 : GLOCK = "$AMENLOC" : Return
Elsif fstat
 Raz [F:AML]
 [F:AML] = [M]
 [F:AML]MENLOC = CHAPITRE
 Call FLDCRE("AML") From OBJDIV
 Write [AML]
Else
 [F:AML] = [M]
 Call FLDUPD("AML") From OBJDIV
 Rewrite [AML]
Endif
If fstat
 GOK = 0 : Call FSTA("AML") From GLOCK
Endif
Return

$TITLIB
If [M]MENLOCAL=2
 TITLIB = sum([M]CODE(0..[M]NBLIG-1))
 K = 0
 Readlock [AST]CLE = [M]LANCHP;0;GLANGUE
 If fstat=1
  GOK = -1 : GLOCK = "$APLSTD" : Return
 Elsif fstat
  Raz [F:AST]
  [F:AST]LANCHP = [M]LANCHP
  [F:AST]LANNUM = 0
  [F:AST]LANMES = TITLIB
  [F:AST]LAN    = GLANGUE
  Call FLDCRE("AST") From OBJDIV
  Write [AST]
  If fstat
   GOK=0 : Call FSTA("AST") From GLOCK : Return
  Endif
  K = 1
 Elsif [F:AST]LANMES<>TITLIB
  [F:AST]LANMES = TITLIB
  Call FLDUPD("AST") From OBJDIV
  Rewrite [AST]
  If fstat
   GOK=0 : Call FSTA("AST") From GLOCK : Return
  Endif
  K = 1
 Endif
 # Issue 88823 - 2013-03-26 by VPO : on ne tient pas compte de NONTRA ici
 #If K & dim([M]NONTRA)>0 & [M]NONTRA<>2 & dim([F:AST]LANORI)>0
 If K & dim([F:AST]LANORI)>0
  If dim(TBLAN)<0 : Gosub SET_TBLAN : Endif
  For NOLAN=1 To NBLAN
   Readlock [AST]CLE=[M]LANCHP;0;TBLAN(NOLAN)
   If fstat
    Raz [F:AST]
    [F:AST]LANCHP = [M]LANCHP
    [F:AST]LANNUM = 0
    [F:AST]LANMES = TITLIB
    [F:AST]LAN = TBLAN(NOLAN)
    # Issue X3-56893 - 2017-09-21 by CCC : LANORI doesn't need to be set for codes
    ## Issue 88823 - 2013-05-02 by VPO : NONTRA=2 pas de LANORI
    #If dim([M]NONTRA)>0 & [M]NONTRA=2
    #[F:AST]LANORI = ""
    #Else
    #[F:AST]LANORI = GLANGUE
    #Endif
    Call FLDCRE("AST") From OBJDIV
    Write [AST]
    If fstat
     GOK=0 : Call FSTA("AST") From GLOCK : Break
    Endif
   # mb 21.8.14 bug 102179
   #Elsif !fstat & [F:AST]LANORI<>"" or FORCE
   Elsif !fstat
    [F:AST]LANORI = ""  # Issue X3-56893 - 2017-09-21 by CCC : LANORI doesn't need to be set for codes
    If (dim([M]NONTRA)>0 & [M]NONTRA=2) or FORCE
     #[F:AST]LANORI = ""
     [F:AST]LANMES = TITLIB
    Else
     #[F:AST]LANORI = GLANGUE
     If len([F:AST]LANMES)<len(TITLIB)
      [F:AST]LANMES += right$(TITLIB,len([F:AST]LANMES)+1)
     Elsif len([F:AST]LANMES)>len(TITLIB)
      [F:AST]LANMES = left$([F:AST]LANMES,len(TITLIB))
     Endif
    Endif
    Call FLDUPD("AST") From OBJDIV
    Rewrite [AST]
    If fstat
     GOK=0 : Call FSTA("AST") From GLOCK : Break
    Endif
   Endif
  Next NOLAN
  If GOK=0 : Return : Endif
 Endif
Endif
Return

$TIT
Local Integer LSTATUS
Local Char LERRMSG (250)

If [M]MENLOCAL=2
 If    [M]LANCHP<100 : NOCHP = 0         : NOLIB = [M]LANCHP
 Elsif [M]LANCHP>200 : NOCHP = 200       : NOLIB = [M]LANCHP-200
 Endif
Else                 : NOCHP = [M]LANCHP : NOLIB = 0
Endif
K = 0
Readlock [AST]CLE = NOCHP;NOLIB;GLANGUE
If fstat=1
 GOK=-1 : GLOCK="$APLSTD" : Return
Elsif fstat
 Raz [F:AST]
 [F:AST]LANCHP = NOCHP
 [F:AST]LANNUM = NOLIB
 [F:AST]LANMES = [M]TITCHP
 [F:AST]LAN    = GLANGUE
 Call FLDCRE("AST") From OBJDIV
 Write [AST]
 If fstat
  GOK=0 : Call FSTA("AST") From GLOCK : Return
 Endif
 If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
    # In text server we store the designation in number 0
    LSTATUS = func APLSTD.UPDATE_MESSAGE([M]LANCHP, 0, [F:AST]LAN, "", [F:AST]LANMES, [F:AST]LANORI, LERRMSG)
    If LSTATUS<> CST_AOK
      GOK=0
      GERR = 1
      GMESSAGE=LERRMSG
      Return
    Endif
 Endif
 K = 1
Elsif [F:AST]LANMES<>[M]TITCHP
 [F:AST]LANMES = [M]TITCHP
 Call FLDUPD("AST") From OBJDIV
 Rewrite [AST]
 If fstat
  GOK=0 : Call FSTA("AST") From GLOCK : Return
 Endif
 If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
    LSTATUS= func APLSTD.UPDATE_MESSAGE([M]LANCHP, 0, [F:AST]LAN, "", [F:AST]LANMES, [F:AST]LANORI,LERRMSG)
    If LSTATUS<> CST_AOK
       GOK=0
       GERR = 1
       GMESSAGE=LERRMSG
       Return
    Endif
 Endif
 K = 1
Endif
# Issue 88823 - 2013-03-26 by VPO : on ne tient pas compte de NONTRA ici
#If K & dim([M]NONTRA)>0 & [M]NONTRA<>2 & dim([F:AST]LANORI)>0
If K & dim([F:AST]LANORI)>0
 If dim(TBLAN)<0 : Gosub SET_TBLAN : Endif
 For NOLAN=1 To NBLAN
  Readlock [AST]CLE=NOCHP;NOLIB;TBLAN(NOLAN)
  If fstat
   Raz [F:AST]
   [F:AST]LANCHP = NOCHP
   [F:AST]LANNUM = NOLIB
   [F:AST]LANMES = [M]TITCHP
   [F:AST]LAN    = TBLAN(NOLAN)
   [F:AST]LANORI = GLANGUE
   Call FLDCRE("AST") From OBJDIV
   Write [AST]
   If fstat
    GOK=0 : Call FSTA("AST") From GLOCK : Break
   Endif
   If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
      # In text server we store the designation in number 0
      LSTATUS = func APLSTD.UPDATE_MESSAGE([M]LANCHP, 0, [F:AST]LAN, "", [F:AST]LANMES, [F:AST]LANORI, LERRMSG)
      If LSTATUS<> CST_AOK
        GOK=0
        GERR = 1
        GMESSAGE=LERRMSG
        Return
      Endif
   Endif
  Elsif !fstat & [F:AST]LANORI<>"" or FORCE
   [F:AST]LANORI = GLANGUE
   [F:AST]LANMES = [M]TITCHP
   Call FLDUPD("AST") From OBJDIV
   Rewrite [AST]
   If fstat
    GOK=0 : Call FSTA("AST") From GLOCK : Break
   Endif
   If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
      # In text server we store the designation in number 0
      LSTATUS = func APLSTD.UPDATE_MESSAGE([M]LANCHP, 0, [F:AST]LAN, "", [F:AST]LANMES, [F:AST]LANORI, LERRMSG)
      If LSTATUS<> CST_AOK
        GOK=0
        GERR = 1
        GMESSAGE=LERRMSG
        Return
      Endif
   Endif
  Endif
 Next NOLAN
 If GOK=0 : Return : Endif
Endif
Return

############################################################################
$CREE
Call DEBTRANS From GLOCK
CHAPITRE = [M]LANCHP
FORCE = 1
Gosub TR2
If GOK>=1
 If GADONIX=2 : Call TRACE_COR("AML",num$([M]LANCHP),"","C") From GOBJET : Endif
 If [M]MENLOCAL=2
  MODMEN = 1
 Endif
 Gosub VERROU
 CLECUR = 1
 CLECUR1 = CHAPITRE
 REP = ""
 Gosub GRISEMEN
Endif
Return

$TR2
GOK = 1
Local Integer LSTATUS, LNUM
Local Char LERRMSG(250)

# X3-9046 : Check if the new local menu has already been created by someone else
If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
    LSTATUS = func APLSTD.GET_CODE_PRODUCT([M]LANCHP, "",LERRMSG)
    If LSTATUS=-100
        Raz LERRMSG
    Else
        GOK=0
        GERR=1
        GMESSAGE="This local menu already exists on texts server.\Please update X3 to get the definition of this local menu or choose another number."
        Return
    Endif
Endif

Trbegin [AST]

# X3-9046 : Create enreg 0 in text server first
 Gosub TIT
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 For nolign=1 To [M]NBLIG
  Raz [F:AST]
  [F:AST] = [M]
  [F:AST]LAN = GLANGUE
  Call FLDCRE("AST") From OBJDIV

  If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
     LSTATUS = func  APLSTD.CREATE_MESSAGE([F:AST]LANCHP, LNUM, [F:AST]LAN,  [M:AST1]CODE(nolign-1), [M:AST1]LANMES(nolign-1), [F:AST]LANORI, LERRMSG)
     If LSTATUS<> CST_AOK
      GOK=0
      GERR=1
      GMESSAGE = LERRMSG
      Break
     Endif
     [M:AST1]LANNUM(nolign-1) = LNUM
     [F:AST]LANNUM = LNUM
  Endif

  Write [AST]
  If fstat
   GOK = 0 : Call FSTA("AST") From GLOCK : Break
  Endif

  # Issue 88823 - 2013-03-26 by VPO : on ne tient pas compte de NONTRA ici
  #If dim([M]NONTRA)>0 & [M]NONTRA<>2 & dim([F:AST]LANORI)>0
  If dim([F:AST]LANORI)>0
   If dim(TBLAN)<0 : Gosub SET_TBLAN : Endif
   For NOLAN=1 To NBLAN
    Readlock [AST]CLE=[M]LANCHP;[M]LANNUM(nolign-1);TBLAN(NOLAN)
    If fstat
     Raz [F:AST]
     [F:AST] = [M]
     [F:AST]LAN = TBLAN(NOLAN)
     [F:AST]LANORI = GLANGUE
     Call FLDCRE("AST") From OBJDIV
     Write [AST]
     If fstat
      GOK=0 : Call FSTA("AST") From GLOCK : Break 2
     Endif
#CCC
     If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
      LSTATUS = func  APLSTD.UPDATE_MESSAGE([F:AST]LANCHP,[F:AST]LANNUM, [F:AST]LAN,  [M:AST1]CODE(nolign-1), [M:AST1]LANMES(nolign-1), [F:AST]LANORI, LERRMSG)
      If LSTATUS<> CST_AOK
        GOK=0
        GERR=1
        GMESSAGE=LERRMSG
        Break
      Endif
     Endif

    Elsif !fstat & [F:AST]LANORI<>""
     [F:AST] = [M]
     [F:AST]LAN = TBLAN(NOLAN)
     Call FLDUPD("AST") From OBJDIV
     Rewrite [AST]
     If fstat
      GOK=0 : Call FSTA("AST") From GLOCK : Break 2
     Endif
#CCC
     If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
      LSTATUS= func APLSTD.UPDATE_MESSAGE([F:AST]LANCHP,[F:AST]LANNUM, [F:AST]LAN,[M:AST1]CODE(nolign-1), [M:AST1]LANMES(nolign-1),[F:AST]LANORI, LERRMSG)
      If LSTATUS<> CST_AOK
        GOK=0
        GERR=1
        GMESSAGE=LERRMSG
        Break
      Endif
     Endif
    Endif
   Next NOLAN
  Endif
 Next nolign
 If GOK=0 : Goto AB_TR2 : Endif
 Gosub MENLOC
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
# X3-9046 Move this block to create record 0 in text server first
# Gosub TIT
# If GOK<0   : Goto ROLL_TR2
# Elsif !GOK : Goto AB_TR2
# Endif
 Gosub TITLIB
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

############################################################################
$ANNULE
OK = 1
If !VERROU
 Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
 OK = 0 : Return
Endif
If CHAPITRE=0
 Call ECR_TRACE("Error Item=0 during delete",1) From GESECRAN
 OK = 0 : Return
Endif
FLGMENLOC = 0
Read [AML]MENLOC=CHAPITRE
If fstat
 Call ECR_TRACE(mess(208,115,1),1) From GESECRAN : # Chapitre inexistant
 OK = 0 : Return
Endif
FLGMENLOC = [F:AML]MENLOCAL
If FLGMENLOC=2
 Call VERIF_MEN(CHAPITRE,OK,MESSA)
 If !OK
  Call ERREURT(mess(1,115,1)+"\"+MESSA,1) From GESECRAN : # Suppression impossible
  Return
 Endif
Endif
Call ANNU(CHAPITRE,FLGMENLOC)
If GOK>=1
 If GADONIX=2 : Call TRACE_COR("AML",num$(CHAPITRE),"","A") From GOBJET : Endif
 If FLGMENLOC=2
  MODMEN = 1
 Endif
 CLECUR = 0
 If !GIMPORT
  Call ECR_TRACE(mess(189,125,1)-num$(CHAPITRE),0) From GESECRAN : # Suppression du chapitre
 Endif
 If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
  Local Integer LASTATUS
  Local Char ERRMSG (250)
    LASTATUS= func APLSTD.DELETE_MESSAGES_CHAPTER([M:AST1]LANCHP, ERRMSG)
    If  LASTATUS<> CST_AOK
      Call ERREURT(ERRMSG,1) From GESECRAN
      OK=0
    Endif
  Endif
Endif
Return

##################################################################
Subprog ANNU(CHAPITRE,MENU)
Value Integer CHAPITRE , MENU
Call DEBTRANS From GLOCK
Gosub TR_ANNU
If GOK>=1
 If MENU=2
  Call SUPMENL(nomap,CHAPITRE) From INTRUTILB
 Endif
Endif
End

$TR_ANNU
GOK=1
Trbegin [AST],[AML]
 Delete [AST] Where LANCHP=CHAPITRE
 If fstat=1
  GOK=-1 : GLOCK = "$APLSTD" : Goto ROLL_TR_ANNU
 Elsif fstat>5
  GOK=0 : Call RSTA("AST","") From GLOCK : Goto AB_TR_ANNU
 Endif
 If MENU=2
  If CHAPITRE<100
   Delete [AST] Where LANCHP=0 & LANNUM=CHAPITRE
  Else
   Delete [AST] Where LANCHP=200 & LANNUM=CHAPITRE-200
  Endif
 Else
  Delete [AST] Where LANCHP=CHAPITRE & LANNUM=0
 Endif
 If fstat=1
  GOK=-1 : GLOCK = "$APLSTD" : Goto ROLL_TR_ANNU
 Elsif fstat>5
  GOK=0 : Call RSTA("AST","") From GLOCK : Goto AB_TR_ANNU
 Endif
 Delete [AML] Where MENLOC=CHAPITRE
 If fstat=1
  GOK=-1 : GLOCK = "$AMENLOC" : Goto ROLL_TR_ANNU
 Elsif fstat>5
  GOK=0 : Call RSTA("AML","") From GLOCK : Goto AB_TR_ANNU
 Endif
Commit
Return

$AB_TR_ANNU
Rollback
Return

$ROLL_TR_ANNU
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNU : Endif
Return

############################################################################
Subprog VERIF_MEN(NUMERO,OK,MESSA)
Value    Integer NUMERO
Variable Integer OK
Variable Char    MESSA()
Local Integer I , J , K , DIME
Local Char    CLE(GLONAVA)(1..16) , NOMCLE(250) , CODCLE(GLONID) , CHAINE(250)
Local Integer NBCLE , TROUVE , INTE
Local Char    TEXTE(250)
Local Char    TYPREC(GLONATY) , CODREC(50)

Local File ATABLE [ATB] , ATABZON [ATZ] , ATABZON [AT2] , ATABIND [ATI] , ATYPE [ATY]

CODREC = num$(NUMERO)
TYPREC = "MNL"
OK     = 1
K      = 0

Call OUVRE_BOITE(mess(43,100,1)-TYPREC-'"'+CODREC+'"',100) From GESECRAN : # Recherche
Call SET_BOITE("",nbrecord([F:ATB])) From GESECRAN

For [ATB]CODFIC
 K += 1
 Call AFF_BOITE([F:ATB]CODFIC,K,INTE) From GESECRAN
 Case [ATB]CODFIC
  When "AREPORTD"
   Local File =[F:ATB]CODFIC [AAA_]
   For [AAA_]
    Read [ATY]CODTYP=[F:AAA_]PARTYP
    If [F:ATY]TYPTYP=1 & [F:AAA_]PARNOLIB=NUMERO
     Call ERRCLE([F:ATB]CODFIC,"AAA_",MESSA) From ADELETE
     OK = 0 : Break 2
    Endif
   Next AAA_
   Close Local File [AAA_]
  When "AMAINT"
   Local File =[F:ATB]CODFIC [AAA_]
   For [AAA_]
    Read [ATY]CODTYP=[F:AAA_]VARTYP
    If [F:ATY]TYPTYP=1 & [F:AAA_]VARMEN=NUMERO
     Call ERRCLE([F:ATB]CODFIC,"AAA_",MESSA) From ADELETE
     OK = 0 : Break 2
    Endif
   Next AAA_
   Close Local File [AAA_]
  When Default
   For [ATZ]NUMLIG Where CODFIC=[F:ATB]CODFIC & [F:ATZ]CODTYP=TYPREC & !find([F:ATZ]CODFIC,"APLSTD","AMENLOC")
    If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",nomap),0)>0
     Local File =[F:ATB]CODFIC [AAA_]
     For [AAA_]
      DIME = evalue("dim([F:AAA_]"+[F:ATZ]CODZONE+")")
      TROUVE = 0
      If DIME=1
       Case evalue("type([F:AAA_]"+[F:ATZ]CODZONE+")")
        When 1,2,4,5,6,7 : TROUVE = (evalue("[F:AAA_]"+[F:ATZ]CODZONE) = val(CODREC))
        When Default     : TROUVE = (evalue("[F:AAA_]"+[F:ATZ]CODZONE) = CODREC)
       Endcase
      Elsif DIME>1
       For I=0 To DIME-1
        Case evalue("type([F:AAA_]"+[F:ATZ]CODZONE+")")
         When 1,2,4,5,6,7 : TROUVE = (evalue("[F:AAA_]"+[F:ATZ]CODZONE+"("+num$(I)+")") = val(CODREC))
         When Default     : TROUVE = (evalue("[F:AAA_]"+[F:ATZ]CODZONE+"("+num$(I)+")") = CODREC)
        Endcase
        If TROUVE : Break : Endif
       Next I
      Endif
      If TROUVE
       Call ERRCLE([F:ATB]CODFIC,"AAA_",MESSA) From ADELETE
       OK = 0 : Break 3
      Endif
     Next AAA_
     Close Local File [AAA_]
    Endif
   Next ATZ
 Endcase
Next ATB
Call FERME_BOITE From GESECRAN
End

############################################################################
$VERROU
SYMBOLE = "AST"+num$(CHAPITRE)
If GCONSULT
 VERROU = 0
Else
 Lock =SYMBOLE With lockwait=0
 If fstat
  VERROU = 0
 Else
  VERROU = 1
 Endif
Endif
Return

$DEVERROU
If VERROU
 Unlock =SYMBOLE
 VERROU = 0
Endif
Return

# Lock modification of texts if there is a problem with the text server
$LOCK_TXT
Grizo [M:AST1]20
Grizo [M:AST1]TITCHP
Return

# Unlock modification of texts
$UNLOCK_TXT
Actzo [M:AST1]20
Actzo [M:AST1]TITCHP
Return

############################################################################
$LECTURE

# X3-9046 : refresh data from text server every time it's read
If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
    If func SYNCCHAPITRE_SCREEN(CHAPITRE, GLANGUE)<>[V]CST_AOK
        Gosub LOCK_TXT
    Else
        Gosub UNLOCK_TXT
    Endif
Endif

Raz [M]
Read [AML]MENLOC = CHAPITRE
If fstat
 Return
Endif
[M] = [F:AML]
[M]LANCHP = CHAPITRE
Gosub DEVERROU
Gosub VERROU
Read [AST_]MENLOC = CHAPITRE
Setlbox [AST1]
nolign = 0
For [AST]CLE Where LAN=GLANGUE & LANCHP=CHAPITRE
 If nolign>0 | [F:AST]LANNUM>0
  nolign += 1
  [M] = [F:AST]
 Endif
Next
[M]NBLIG = nolign
CLECUR = 1
CLECUR1 = CHAPITRE
If [M]MENLOCAL=2
 If [M]LANCHP<100
  Read [AST7]CLE = 0;[M]LANCHP;GLANGUE
 Else
  Read [AST7]CLE = 200;[M]LANCHP-200;GLANGUE
 Endif
Else
 Read [AST7]CLE = [M]LANCHP;0;GLANGUE
Endif
If !fstat
 [M]TITCHP = [F:AST7]LANMES
Else
 Raz [M]TITCHP
Endif
Raz [M]CODE
If [M]MENLOCAL=2
 Read [AST7]CLE = [M]LANCHP;0;GLANGUE
 If !fstat
  TITLIB = [F:AST7]LANMES
  For I=0 To [M]NBLIG-1
   [M]CODE(I) = mid$(TITLIB,I+1,1)
  Next I
 Endif
Endif
Affzo
Gosub GRISEMEN
If [M]MENLOCAL=2
 Gosub DEGRISE
Else
 Gosub GRISE
Endif
# Issue 55535 - 2017-10-04 by CCC : A modifiable menu can't be for all products. It must be defined by product
If dim([M:AST1]FLGPRO)>0
    If [M:AST1]AUZMOD=2
        Grizo [M:AST1]FLGPRO
    Else
        Actzo [M:AST1]FLGPRO
    Endif
Endif
If GNBDERNIER
 Gosub SET_DERLU
Endif
If currbox=BOXALI
 Gosub REMPLIT
Endif
Raz GMODIF
Return

$SET_DERLU
Filter [ALS] Where USR=GUSER & OBJ="AST"
Read [ALS]ALS0 Last
If fstat<=2 : K = [F:ALS]LIG+1 : Else K = 1 : Endif
Raz I, J
For [ALS]ALS0
 If [F:ALS]CLES=num$(CHAPITRE) : J = 1 : Break : Endif
 I += 1
Next
Filter [ALS]
Trbegin [ALS]
 If J
  [F:ALS]LIG = K
  Rewrite [ALS]
 Else
  If I>=GNBDERNIER
   Read [ALS]ALS0(2) = GUSER ; "AST"
   If fstat<=2 : J = 1 : Endif
  Endif
  Raz [F:ALS]
  [F:ALS]USR  = GUSER
  [F:ALS]OBJ  = "AST"
  [F:ALS]LIG  = K
  [F:ALS]CLES = num$(CHAPITRE)
  If !J
   Write [ALS]
  Else
   Rewrite [ALS]
  Endif
 Endif
Commit
Return

$RELIT
If CLECUR<>0
 Gosub LECTURE
Else
 Effzo
 Gosub DEGRISE
 Gosub DEGRISEMEN
Endif
Return

###########################################################
Funprog LENMEN(DOSSIER,CHAPITRE)
Value Char DOSSIER
Value Integer CHAPITRE
Local Integer LONG
Local Char LANGUE(GLONLAN)
LANGUE = GLANGUE
If DOSSIER="" or DOSSIER=nomap
 Local File APLSTD [ASTX]
Else
 Local File =DOSSIER+".APLSTD" [ASTX]
Endif
LONG = 0
For [ASTX]CLE Where LAN=LANGUE & LANCHP=CHAPITRE
 If LONG>0 or [F:ASTX]LANNUM>0
  LONG += 1
 Endif
Next ASTX
Close Local File
End LONG

###########################################################
Funprog TITMEN(DOSSIER,CHAPITRE)
Value Char DOSSIER
Value Integer CHAPITRE
Local Char TITMEN(GLONDES) , LANGUE(GLONLAN)
LANGUE = GLANGUE
If DOSSIER="" or DOSSIER=nomap
 Local File APLSTD  [ASTX]
 Local File AMENLOC [AMLX]
Else
 Local File =DOSSIER+".APLSTD"  [ASTX]
 Local File =DOSSIER+".AMENLOC" [AMLX]
Endif
Read [AMLX]MENLOC=CHAPITRE
If !fstat
 If [F:AMLX]MENLOCAL=2
  If CHAPITRE<100
   Read [ASTX]CLE = 0;CHAPITRE;LANGUE
  Else
   Read [ASTX]CLE = 200;CHAPITRE-200;LANGUE
  Endif
 Else
  Read [ASTX]CLE = CHAPITRE;0;LANGUE
 Endif
 If !fstat
  TITMEN = [F:ASTX]LANMES
 Endif
Endif
End TITMEN

###########################################################
Funprog TEXMEN(DOSSIER,CHAPITRE,NUM,LANGUE)
Value Char DOSSIER
Value Integer CHAPITRE , NUM
Value Char LANGUE
Local Char TEXMEN(GLONDES)
If LANGUE=""
 LANGUE = GLANGUE
Endif
If DOSSIER="" or DOSSIER=nomap
 Local File APLSTD  [ASTX]
Else
 Local File =DOSSIER+".APLSTD"  [ASTX]
Endif
Read [ASTX]CLE = CHAPITRE;NUM;LANGUE
If !fstat
 TEXMEN = [F:ASTX]LANMES
Endif
End TEXMEN

###########################################################
$S_SELASTMEN
CRITERE = 'MENLOCAL=2'

$S_SELAST
If clalev([F:AML])=0  : Local File AMENLOC [AML]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV   [ACV]  : Endif
If clalev([F:AST4])=0 : Local File APLSTD  [AST4] : Endif
If clalev([F:AST5])=0 : Local File APLSTD  [AST5] : Endif
If clalev([F:AST6])=0 : Local File APLSTD  [AST6] : Endif
Link [AML]  With [AST4]CLE = [F:AML]MENLOC;0;GLANGUE
&              , [AST5]CLE = 0;[F:AML]MENLOC;GLANGUE
&              , [AST6]CLE = 200;([F:AML]MENLOC-200);GLANGUE
&              , [ACV]CODACT = [F:AML]CODACT
& As [AML_]
& Order By Key MENLOC
Default File [AML_]
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AML]CODACT="" | [F:ACV]FLACT=2)',"&") From GOBJSUB
OBJET = "AML"
ORDRE = "MENLOC"
Return

###########################################################
$B_SELAST
$B_SELASTMEN
CRITRAP = ""
Gosub CRITRAP
Return

#########################################################
$TRTCOP
Local Char WLAN(GLONLAN)
Local Integer CHAP , NUM
If [M]DOSORG=nomap
 Local File APLSTD  [AST1]
 Local File AMENLOC [AML1]
Else
 Local File =[M]DOSORG+".APLSTD"  [AST1]
 Local File =[M]DOSORG+".AMENLOC"  [AML1]
Endif
If [M]DOSDES=nomap
 Local File APLSTD  [AST2]
 Local File AMENLOC [AML2]
Else
 Local File =[M]DOSDES+".APLSTD"  [AST2]
 Local File =[M]DOSDES+".AMENLOC"  [AML2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AST1], [AST2], [AML1], [AML2]
Return

$TR_COP
If nomap="GX3APP" & dim([F:AST2]LANORI)<0
 Call ERREUR("you could not copy on this folder") From GESECRAN
 Return
Endif
GOK = 1
Trbegin [AST2]
 If GADONIX=2
  For WLAN=GLANGUE,"XXX"
   Gosub COP_AST
   If GOK<1 : Break : Endif
  Next WLAN
 Else
  For WLAN=GLANGUE
   Gosub COP_AST
   If GOK<1 : Break : Endif
  Next WLAN
 Endif
 If GOK=0 : Goto AB_TR_COP
 Elsif GOK<0 : Goto ROLL_TR_COP
 Endif
 Read [AML1]MENLOC = val(TABLE)
 If !fstat
  Readlock [AML2]MENLOC = val(TABLE)
  If fstat=1
   GOK=-1 : GLOCK = "$AMENLOC"-TABLE : Goto ROLL_TR_COP
  Elsif !fstat
   [F:AML2] = [F:AML1]
   Rewrite [AML2]
  Else
   [F:AML2] = [F:AML1]
   Write [AML2]
  Endif
  If fstat
   GOK=0 : Call FSTA("AML2") From GLOCK : Goto AB_TR_COP
  Endif
  # Issue 88823 - 2013-03-26 by VPO : on ne tient pas compte de NONTRA ici
  #If dim([F:AML2]NONTRA)>0 & [F:AML2]NONTRA<>2 & dim([F:AST2]LANORI)>0
  If dim([F:AST2]LANORI)>0
   Gosub COP_TRA
   If GOK<1 : Goto AB_TR_COP : Endif
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

################################################
$COP_AST
Delete [AST2] Where LANCHP=val(TABLE) and LAN=WLAN
If fstat=1
 GOK=-1 : GLOCK = "$"+[M]DOSDES+".APLSTD" : Return
Elsif fstat>5
 GOK = 0 : Call RSTA("AST2","") From GLOCK : Return
Endif
For [AST1]CLE Where LANCHP=val(TABLE) and LAN=WLAN
 [F:AST2] = [F:AST1]
 If GADONIX=2
  # mb 13.9.2
  # Dans le cas du transfert manuel de Sophia vers Gaillard, il faut que la date de création ou
  # modification soit celle du jour du transfert, le menu ayant pu être modifié bien avant.
  # Ceci pour permettre le filtrage des modifications menus entre deux traductions
  If instr(1,toupper([M]DOSORG),"X3BUG") & instr(1,toupper([M]DOSDES),"GX3APP")
   If [F:AST1]UPDUSR="" & (dim([F:AST1]UPDTIM)<=0 or [F:AST1]UPDTIM=0)& [F:AST1]UPDDAT=[0/0/0]
    If dim([F:AST2]UPDUSR)>0 : [F:AST2]UPDUSR = GUSER : Endif
    If dim([F:AST2]UPDDAT)>0 : [F:AST2]UPDDAT = date$ : Endif
    If dim([F:AST2]UPDTIM)>0 : [F:AST2]UPDTIM = time : Endif
   Else
    If dim([F:AST2]UPDUSR)>0 : [F:AST2]UPDUSR = GUSER : Endif
    If dim([F:AST2]UPDDAT)>0 : [F:AST2]UPDDAT = date$ : Endif
    If dim([F:AST2]UPDTIM)>0 : [F:AST2]UPDTIM = time : Endif
   Endif
  Else
   # Pas de modifs de date
  Endif
 Else
  If dim([F:AST2]UPDUSR)>0 : [F:AST2]UPDUSR = GUSER : Endif
  If dim([F:AST2]UPDDAT)>0 : [F:AST2]UPDDAT = date$ : Endif
  If dim([F:AST2]UPDTIM)>0 : [F:AST2]UPDTIM = time : Endif
 Endif
 Write [AST2]
 If fstat
  GOK=0 : Call FSTA("AST2") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif
If val(TABLE)>=1 & val(TABLE)<=99       : CHAP =   0 : NUM = val(TABLE)
#Elsif val(TABLE)>=201 & val(TABLE)<8900 : CHAP = 200 : NUM = val(TABLE)-200
Elsif val(TABLE)>=201                   : CHAP = 200 : NUM = val(TABLE)-200
Else                                    : CHAP =   0 : NUM = 0
Endif
If NUM
 Read [AST1]CLE = CHAP;NUM;WLAN
 If !fstat
  Readlock [AST2]CLE = CHAP;NUM;WLAN
  If fstat=1
   GOK=-1 : GLOCK = "$APLSTD"-num$(CHAP)-num$(NUM) : Return
  Elsif !fstat
   [F:AST2] = [F:AST1]
   Rewrite [AST2]
  Else
   [F:AST2] = [F:AST1]
   Write [AST2]
  Endif
  If fstat
   GOK=0 : Call FSTA("AST2") From GLOCK : Return
  Endif
 Endif
Endif
Return

######################################################
$COP_TRA
Gosub SET_TBLAN2
For [AST1]CLE Where LANCHP=val(TABLE) and LAN=GLANGUE
 For NOLAN=1 To NBLAN
  Readlock [AST2]CLE=[F:AST1]LANCHP;[F:AST1]LANNUM;TBLAN(NOLAN)
  If fstat
   [F:AST2] = [F:AST1]
   [F:AST2]LAN = TBLAN(NOLAN)
   [F:AST2]LANORI = GLANGUE
   Call FLDCRE("AST2") From OBJDIV
   Write [AST2]
   If fstat
    GOK=0 : Call FSTA("AST2") From GLOCK : Break 2
   Endif
  Elsif !fstat & [F:AST2]LANORI<>""
   [F:AST2]LANMES = [F:AST1]LANMES
   Call FLDUPD("AST2") From OBJDIV
   Rewrite [AST2]
   If fstat
    GOK=0 : Call FSTA("AST2") From GLOCK : Break 2
   Endif
  Endif
 Next NOLAN
Next AST1
If GOK<1 : Return : Endif
If val(TABLE)>=1 & val(TABLE)<=99       : CHAP =   0 : NUM = val(TABLE)
#Elsif val(TABLE)>=201 & val(TABLE)<8900 : CHAP = 200 : NUM = val(TABLE)-200
Elsif val(TABLE)>=201                   : CHAP = 200 : NUM = val(TABLE)-200
Else                                    : CHAP =   0 : NUM = 0
Endif
If NUM
 Read [AST1]CLE = CHAP;NUM;GLANGUE
 If !fstat
  For NOLAN=1 To NBLAN
   Readlock [AST2]CLE=CHAP;NUM;TBLAN(NOLAN)
   If fstat
    [F:AST2] = [F:AST1]
    [F:AST2]LAN    = TBLAN(NOLAN)
    [F:AST2]LANORI = GLANGUE
    Call FLDCRE("AST2") From OBJDIV
    Write [AST2]
    If fstat
     GOK=0 : Call FSTA("AST2") From GLOCK : Break
    Endif
   Elsif !fstat & [F:AST2]LANORI<>""
    [F:AST2]LANMES = [F:AST1]LANMES
    Call FLDUPD("AST2") From OBJDIV
    Rewrite [AST2]
    If fstat
     GOK=0 : Call FSTA("AST2") From GLOCK : Break
    Endif
   Endif
  Next NOLAN
  If GOK<1 : Return : Endif
 Endif
Endif
Return

#################
$SET_TBLAN2
Local Char    TBLAN(GLONLAN)(1..50)
Local Integer NBLAN , NOLAN
Raz NBLAN , TBLAN
For [AST2]LAN(1) Where LAN<>"XXX" & LAN<>"" & LAN<>GLANGUE & LANCHP=101
 NBLAN += 1
 TBLAN(NBLAN) = [F:AST2]LAN
Next AST2
Return

################################################################
# Action CONTMNL
################################################################
Subprog CONTMNL(VALEUR)
Value Decimal VALEUR
Gosub T_CONTMNL
End

Subprog CONTMNL_SYR(AINSTANCE,APRONAME, AVALUE)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Integer AVALUE

Local Integer MENU
Local Integer OK, L_STA
MENU = AVALUE
#If dim(GABREV)>0 & GABREV="ATY" & MENU=0
# Return : # Dans la gestion des types de données, on tolère un menu local à 0
#Endif
#If dim(PARAM)>0 & PARAM(1)="0"
# Return : # Ce contrôle est désactivé en création d'un menu/chapitre
#Endif
If clalev([F:AML])=0  : Local File AMENLOC [AML]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV   [ACV]  : Endif
Read [AML]MENLOC = MENU
If fstat or mess(0,MENU,1)=""
 L_STA = fmet AINSTANCE.ASETERROR(APRONAME,mess(98,123,1),CST_AERROR) # Menu local non défini
Elsif !fstat & [F:AML]MENLOCAL<>2
 L_STA = fmet AINSTANCE.ASETERROR(APRONAME,mess(5,176,1),CST_AERROR) # Numéro de menu local incorrect
Elsif !fstat & [F:AML]CODACT<>""
 OK = 1
 Read [ACV]CODACT=[F:AML]CODACT
 If fstat or [F:ACV]FLACT<>2
  OK = 0
 Endif
 If !OK
  L_STA = fmet AINSTANCE.ASETERROR(APRONAME,mess(33,139,1),CST_AERROR) # Numéro incorrect
 Endif
Endif

End

#############################
$T_CONTMNL
Local Integer MENU
Local Integer OK
MENU = VALEUR
If dim(GABREV)>0 & GABREV="ATY" & MENU=0
 Return : # Dans la gestion des types de données, on tolère un menu local à 0
Endif
If dim(PARAM)>0 & PARAM(1)="0"
 Return : # Ce contrôle est désactivé en création d'un menu/chapitre
Endif
If clalev([F:AML])=0  : Local File AMENLOC [AML]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV   [ACV]  : Endif
Read [AML]MENLOC = MENU
If fstat or mess(0,MENU,1)=""
 GMESSAGE = mess(98,123,1) : # Menu local non défini
 mkstat = 2
Elsif !fstat & [F:AML]MENLOCAL<>2
 GMESSAGE = mess(5,176,1) : # Numéro de menu local incorrect
 mkstat = 2
Elsif !fstat & [F:AML]CODACT<>""
 OK = 1
 Read [ACV]CODACT=[F:AML]CODACT
 If fstat or [F:ACV]FLACT<>2
  OK = 0
 Endif
 If !OK
  GMESSAGE = mess(33,139,1) : # Numéro incorrect
  mkstat = 2
 Endif
Endif
Return

################################################################
# Action BOUTMNL
################################################################
Subprog BOUTMNL(MENU)
Variable Decimal MENU
If dim(GFONCTION)>=0 & GFONCTION="TXT"
 GBOUT1 = mess(259,133,1) : # Liste des codes réservés
Else
 GBOUT1 = mess(23,125,1) : # Menus locaux
Endif
End

################################################################
# Chercher un message dans l'appli superviseur
################################################################
Funprog MESSUP(NUM,CHAP)
Value Integer NUM , CHAP
Local Integer ER
Local Char    APPLI(250) , MERE(250) , MACHINE(250) , DOSSIER(250) , LANGUE(30) , MESSAGE(250)
Call MOTHER(nomap,APPLI,MERE,MACHINE) From ATEXTRA
DOSSIER = MERE
If MACHINE<>""
 DOSSIER = MACHINE+"@"+MERE
Endif
Local Integer ER
LANGUE = messname(0)
If LANGUE=""
 LANGUE = "FRA"
Endif
Onerrgo ERFIC
Local File =DOSSIER+".APLSTD" [AST]
Read [AST]CLE=CHAP;NUM;LANGUE
If !fstat & !ER
 MESSAGE = [F:AST]LANMES
Endif
End MESSAGE

$ERFIC
ER = errn
Resume

################################################################
# Etiquettes du masque AST1
################################################################

Subprog C_LANCHP(VALEUR)
Variable Decimal  VALEUR
Local Integer MAXVAL
MAXVAL = 29999
If VALEUR=0
 mkstat = 2 : End
Elsif VALEUR=200
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Elsif VALEUR>MAXVAL
 GMESSAGE = func AFNC.MES(mess(115,75,1),num$(MAXVAL)) : # Valeur trop grande (maximum #)
 mkstat = 2 : End
Endif
If [M]LANCHP<>0 & [M]MENLOCAL=2
 Gosub DEGRISE
Else
 Gosub GRISE
Endif
End

Subprog AM_LANCHP(VALEUR)
Variable Decimal  VALEUR
Read [AML]MENLOC=VALEUR
If !fstat : End : Endif
End

Subprog IB_LANCHP
End

Subprog B1_LANCHP(VALEUR)
Variable Decimal VALEUR
End

Subprog D_LANNUM(NUM)
Variable Decimal NUM
Local Integer NUMMES
Local Integer RETOUR

If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" and [M]LANCHP<>0
    # With the text server:
    # - the number will be calculated at recording for new lines
    # - the number can't be modified if already existing
    End
Endif

NUM = nolign
While find(NUM,[M]LANNUM)
  NUM += 1
Wend
End

Subprog AS_LANNUM(NUM)
Variable Decimal NUM
 If [M]LANCHP<>0 & [M]MENLOCAL=2
    NUM = nolign : mkstat = 2 : End
 Endif
If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" and [M]LANCHP<>0
    # With the text server:
    # - the number will be calculated at recording for new lines
    # - the number can't be modified if already existing
    mkstat = 2 : End
Endif

End

Subprog C_LANNUM(VALEUR)
Variable Decimal  VALEUR

  If [M]LANCHP<>0 & [M]MENLOCAL=2
    GMESSAGE = mess(83,123,1) : # Valeur incorrecte
  mkstat = 2 : End

  # With text server, number is not entered => no control of unicity
  If func AFNC.PARAMDOS(nomap,"ATXTSRV")<>"2"
    Call UNICITE(VALEUR,[M]LANNUM) From OBJDIV
  Endif
Endif

End

Subprog AM_MODULE(VALEUR)
Variable Integer VALEUR
End

Subprog AS_CODE(CODE)
Variable Char CODE()
If [M]LANCHP=0 | [M]MENLOCAL<>2
 mkstat = 1 : End
Endif
End

Subprog C_NBLIG

Local Integer MAXI
MAXI = type([F:AST]LANMES)-10
If find(status,73,82) & [M]NBLIG>=MAXI & [M]MENLOCAL=2
 GMESSAGE = mess(21,139,1)-num$(MAXI) : # Le nombre de lignes d'un menu local est limité à
 mkstat = 2 : End
Endif

If status=73 & GMODIF=0 & [M]MENLOCAL=2
 Filter [AST] Where LANCHP=[M]LANCHP and LAN<>GLANGUE & LANNUM=1
 Read [AST] First
 Filter [AST]
 If !fstat
  GMODIF = 1
 Endif
Endif

If status=75 and func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
  GMODIF=1
Endif

If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
  If status=65
    If nolign <> [M]NBLIG
       #You can delete only the last record
       GMESSAGE=mess (276,133,1)
       mkstat = 2 : End
    Else
      GMODIF=1
    Endif
  Endif
Endif
End

Subprog C_MAXI(VALEUR)
Variable Decimal VALEUR
If VALEUR>0 & VALEUR<[M]MINI
 GMESSAGE = mess(8,133,1) : # Valeur trop petite
 mkstat = 2 : End
Endif
End



#**
#* Return the product code recorded in the text server for a chapter
#*
#* @param PNUMCHP = Local menu number
#* @param PLANREF = Reference language to check first. Set "" to check for all languages
#* @param PERRMSG = error message
#* @return Product code :
#* -100 : Product not found
#* -2 : PRODUCT = All products
#* -1 : PRODUCT = "SU"
#*  0 : PRODUCT = "X3"
#*  1 : PRODUCT = "GX"
#*  2 : PRODUCT = "PA"
#*  3 : PRODUCT = "AB"
#*!
Funprog GET_CODE_PRODUCT(PNUMCHP,PLANREF,PERRMSG)
Value Integer PNUMCHP
Value Char    PLANREF
Variable Char PERRMSG

Local Integer LNUMLIN
Local Integer LCODPRODUCT
Local Char    CODELIB(1)
Local Char    MESSAGELIB(250)
Local Char    LLANORI(GLONLAN)
Local Integer LASTATUS
Local Char    LLAN(GLONLAN)

Local Integer LCOUNT
Local Integer LTBNUM(1..)
Local Char LTBCODE(1)(1..)
Local Char LTBLANMES(123)(1..)
Local Char LTBLANORI (GLONLAN) (1..)

Raz PERRMSG

# For each case : defined for all products (-2) and for current product...
For [L]LCODPRODUCT = -2, GPRODUIT
    # ... look for record 0 (designation of local menu) if it exists for at least 1 language
    For LLAN=PLANREF
        Raz PERRMSG
        # GET_MESSAGE with line=0 returns all lines => use GET_MESSAGES from 0 to 0
        LASTATUS = func ATXTSVC.GET_MESSAGES(LCODPRODUCT, PNUMCHP, LLAN, 0, 0 ,LCOUNT, LTBNUM,LTBCODE, LTBLANMES,LTBLANORI, PERRMSG)
        If LASTATUS = [V]CST_AOK
            Break 2
        Endif
    Next
Next

If LASTATUS <> [V]CST_AOK
    LCODPRODUCT = -100
    PERRMSG = "Error when searching header record for chapter"-num$(PNUMCHP)+"\"+PERRMSG
Endif

End LCODPRODUCT


######################################################################################
#**
#* SYNCCHAPITRE_SCREEN : update data
#* @param PLANCHP: Local menu number to update
#* @param PLAN: Langue
#* @return [V]CST_AOK or [V]CST_AERROR
#*!
Funprog SYNCCHAPITRE_SCREEN(PLANCHP, PLAN)
Value Integer PLANCHP
Value Char    PLAN

Call TEMPON("Synchronisation"-PLAN) From GESECRAN
Local Integer LASTATUS
Local Char ERRMSG(250)
Local Integer CONTINUE

[L]CONTINUE = 0
LASTATUS= func APLSTD.SYNCCHAPITRE (PLANCHP, PLAN, [L]CONTINUE, ERRMSG)
Call TEMPOFF From GESECRAN
If LASTATUS<>CST_AOK
  Call ERREUR (ERRMSG) From GESECRAN
  End [V]CST_AERROR
Endif

End [V]CST_AOK


#Synchronize one chaptre for a given language from the text server to the data base
######################################################################################
Funprog SYNCCHAPITRE(NUMCHP, W_LAN, W_CONTINUE ,ERRMSG)
Value Integer NUMCHP
Value Char    W_LAN
Value Integer W_CONTINUE
Variable Char ERRMSG

Local File APLSTD  [AST]
Local File AMENLOC [AML]


Local Integer LASTATUS
Local Integer  LCODPRODUCT

Local Integer LERRSQL
Local Integer LCOUNT
Local Integer LTBNUM(1..)
Local Char LTBCODE(1)(1..)
Local Char LTBLANMES(123)(1..)
Local Char LTBLANORI (GLONLAN) (1..)
Local Char LLANORI(GLONLAN)
Local Char  LERRMSG (250)
Local Char  MENU0 (250)
Local Integer   MNGT0
Local Integer   LEXIST0
Local Integer LEXIST
Local Integer LNUMMAX

Local Integer LNUMCHPLIB
Local Integer LNUMLINLIB


Local Char CODELIB(1)
Local Char MESSAGELIB(250)

# Get product associated to the chapter
LCODPRODUCT = func APLSTD.GET_CODE_PRODUCT(NUMCHP, "",LERRMSG)
If LERRMSG<>""
    ERRMSG = mess(241,124,1) +"\"+LERRMSG
    End [V]CST_AERROR
Endif
LERRSQL=0
MNGT0=0
LEXIST=0
LEXIST0=0

# Get all messages contained in the chapter
# From 0 to get description => indice=1 corresponds to description
LASTATUS = func ATXTSVC.GET_MESSAGES(LCODPRODUCT, NUMCHP, W_LAN,0, 32760 ,LCOUNT, LTBNUM,LTBCODE, LTBLANMES,LTBLANORI, LERRMSG)
If LASTATUS <>[V]CST_AOK
  If LERRMSG ="Not found"
    LASTATUS= CST_AOK
    LCOUNT=0
  Else
    If ERRMSG=""
      ERRMSG = mess(241,124,1) +"\"+LERRMSG
    Endif
    End LASTATUS
  Endif
Endif

Read [AML]MENLOC=NUMCHP
If fstat<>CST_AOK
  ERRMSG=mess (12,100,1)  -"AMENLOC"-num$(NUMCHP)
  End CST_AERROR
Endif
If [F:AML]MENLOCAL =2
  MENU0=""
  MNGT0=1
  If NUMCHP<200
    LCHPLIB = 0
    LLINLIB = NUMCHP
  Elsif NUMCHP>200
    LCHPLIB = 200
    LLINLIB = NUMCHP-200
  Endif
Else
  LCHPLIB = NUMCHP
  LLINLIB = 0
Endif

Call DEBTRANS From GLOCK
Trbegin [F:AST]

# Issue X3-56893 - 2017-09-21 by CCC : LANORI doesn't need to be set for codes
If [F:AML]MENLOCAL=2
    Read [AST]CLE= NUMCHP;0;W_LAN
    If fstat=CST_AOK
        [F:AST]LANORI=""
        Rewrite [AST]
    Endif
Endif

If LCOUNT >1
  #synchronisation: from indice=2 as LTBLANMES(1) = description of local menu
  For LINDICE = 2 To LCOUNT
    Raz [F:AST]
    Read [AST]CLE= NUMCHP;LTBNUM(LINDICE);W_LAN
    If fstat =0
      LEXIST=1
    Else
      LEXIST=0
      Raz [F:AST]
    Endif
    [F:AST]LANCHP=NUMCHP
    [F:AST]LANMES=LTBLANMES(LINDICE)
    [F:AST]LANNUM=LTBNUM(LINDICE)
    LNUMMAX=LTBNUM(LINDICE)
    [F:AST]LAN=W_LAN
    [F:AST]LANORI= LTBLANORI(LINDICE)
    If MNGT0=1
      MENU0=MENU0+LTBCODE(LINDICE)
    Endif
    If LEXIST=0
      Write [AST]
    Else
      Rewrite [AST]
    Endif
    If fstat<>CST_AOK
      ERRMSG=mess (13,100,1)  -"APLSTD" - num$([F:AST]LANCHP)+"/"+num$([F:AST]LANNUM)+"/"+ W_LAN
      LERRSQL=1
      Break
    Endif
  Next
  If LERRSQL=0
    Delete [AST] Where [F:AST]LANCHP=NUMCHP and [F:AST]LANNUM >  LNUMMAX
    If fstat<>CST_AOK
        ERRMSG=mess (13,100,1)  -"APLSTD delete" - num$([F:AST]LANCHP)+"/>"+num$(LNUMMAX)
        LERRSQL=1
     Endif
  Endif
  If LERRSQL=0
    Read [AST]CLE= NUMCHP;0;W_LAN
    If fstat=CST_AOK
      LEXIST0=1
    Else
      LEXIST0=0
    Endif
    If LEXIST0=0
      Raz [F:AST]
      [F:AST]LANCHP=NUMCHP
      [F:AST]LANNUM=0
      [F:AST]LAN=W_LAN
    Endif
    If MNGT0= 1
      [F:AST]LANMES=MENU0
    Endif
    If LEXIST0=0
      Write [AST]
      If fstat<>CST_AOK
        ERRMSG=mess (13,100,1)  -"APLSTD" - num$(NUMCHP)+"/0/"+ W_LAN
        LERRSQL=1
      Endif
    Else
      If MNGT0= 1
        Rewrite [AST]
        If fstat<>CST_AOK
          ERRMSG=mess (13,100,1)  -"APLSTD" - num$(NUMCHP)+"/0/"+ W_LAN
          LERRSQL=1
        Endif
      Endif
    Endif
  Endif
Endif

Read [AST]CLE= LCHPLIB;LLINLIB;W_LAN
If fstat=CST_AOK
  [F:AST]LANORI = LTBLANORI(1)  # Issue X3-58457 - 2018-06-21 by CCC : Update LANORI also
  [F:AST]LANMES = LTBLANMES(1)
  Rewrite [AST]
  If fstat<>CST_AOK
    ERRMSG=mess (13,100,1)  -"APLSTD" - num$(LCHPLIB)+"/"+num$(LLINLIB)+"/"+ W_LAN
    LERRSQL=1
  Endif
Else
  Raz [F:AST]
  [F:AST]LANCHP = LCHPLIB
  [F:AST]LANNUM = LLINLIB
  [F:AST]LAN    = W_LAN
  [F:AST]LANORI = LTBLANORI(1)
  [F:AST]LANMES = LTBLANMES(1)
  Write [AST]
  If fstat<>[V]CST_AOK
    ERRMSG=mess (12,100,1)  -"APLSTD"-num$(LCHPLIB)+"/"+num$(LLINLIB)
    LERRSQL=1
  Endif
Endif

If   LERRSQL =0
  Commit
  LASTATUS=CST_AOK
Else
  Rollback
  LASTATUS=CST_AERROR
Endif


End LASTATUS


######################################################################################
Funprog GET_MESSAGE( CHP, NUM,LAN, CODE, MESSAGE, LANORI, ERRMSG)
Value Integer CHP
Value Integer NUM
Value Char LAN()
Variable Char CODE()
Variable Char MESSAGE()
Variable Char LANORI ()
Variable Char ERRMSG ()

Local Integer LASTATUS
Local Integer  LCODPRODUCT

LCODPRODUCT = func APLSTD.GET_CODE_PRODUCT(CHP, "",ERRMSG)
If ERRMSG<>""
    End [V]CST_AERROR
Endif

LASTATUS= func ATXTSVC.GET_MESSAGE(LCODPRODUCT, CHP, NUM, LAN,CODE,MESSAGE,LANORI, ERRMSG)

End LASTATUS


######################################################################################
Funprog CREATE_MESSAGE ( CHP, NUM,LAN, CODE, MESSAGE, LANORI,ERRMSG)
Value Integer CHP
Variable Integer NUM
Value Char LAN()
Value Char CODE()
Value Char MESSAGE()
Value Char LANORI()
Variable Char ERRMSG ()

Local Integer LASTATUS
Local Integer  LCODPRODUCT
Local Char LLANGS(GLONLAN)(0..)

LCODPRODUCT = func APLSTD.GET_CODE_PRODUCT(CHP, "",ERRMSG)
If ERRMSG<>""
    End [V]CST_AERROR
Endif

LLANGS(0)=LAN
LASTATUS= func ATXTSVC.CREATE_MESSAGE(LCODPRODUCT, LANORI, LLANGS, CHP, CODE, MESSAGE,NUM, ERRMSG)

End LASTATUS


######################################################################################
Funprog UPDATE_MESSAGE(CHP, NUM, LAN, CODE, MESSAGE, LANORI, ERRMSG)
Value Integer CHP
Value Integer  NUM
Value Char LAN ()
Value Char CODE()
Value Char  MESSAGE()
Value Char LANORI ()
Variable Char  ERRMSG()

Local Integer LASTATUS
Local Integer  LCODPRODUCT

# record of designation. Maybe doesn't exist yet
If NUM=0 & dim([M:AST1]FLGPRO)>0 & [M:AST1]FLGPRO<>2
    LCODPRODUCT = -2
Else
    LCODPRODUCT = func APLSTD.GET_CODE_PRODUCT(CHP, "",ERRMSG)
    If NUM=0 & [L]LCODPRODUCT=-100
        LCODPRODUCT = GPRODUIT
        Raz ERRMSG
    Endif
    If ERRMSG<>""
        End [V]CST_AERROR
    Endif
Endif

LASTATUS= func ATXTSVC.UPDATE_MESSAGE(LCODPRODUCT, CHP, NUM, LANORI, LAN, CODE, MESSAGE,ERRMSG)

End LASTATUS

