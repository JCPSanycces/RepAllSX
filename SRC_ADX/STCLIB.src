#<AdxTL>@(#)0.0.0.0 $Revision$
# Traitement STCLIB -  Landed Cost - Librairie composants divers    V7 #
########################################################################
#
###
### Faire un composant pour traiter l'éclatement d'une ligne de commande
###
#
# COSTSTCD_STCDW Lecture des charges d'une ligne de document (COSTSTCD)
#                pour stockage dans écran de travail STCDW
# COSTSTCL_STCDW Lecture des lignes structure de coût (COSTSTCL)
# (inutile)      pour stockage dans écran de travail STCDW
# COSTSTCD_STCD  Lecture des charges d'une ligne de document (COSTSTCD)
#                pour stockage     dans écran de saisie STCD
# COSTSTCL_STCD  Lecture des lignes structure de coût (COSTSTCL)
#                pour stockage dans écran de saisie STCD
# STCDW_STCD     Chargement de l'écran de saisie STCD à partir de l'écran
#                de travail STCDW pour une ligne de document
# STCD_STCDW     Chargement de l'écran de travail STCDW pour une ligne de
#                document à partir de l'écran de saisie STCD
# STCTRF_STCD    Lecture des charges d'une ligne de document (COSTSTCD)
#                pour stockage dans ecran de travail STCD d'un autre document
#                (cde --> réception)
# STCMAJ         Mise à jour des charges d'une ligne de document (COSTSTCD)
#                à partir de l'écran de travail STCDW
# RECH_COST      Recherche du coefficient frais approche
#                et coût achat forfaitaire ou structure de coût                                                   #
# WSTCSEQ        Calcule du numéro de séquence servant de lien entre
#                le document et le détail
# RAZSTCDW       Remise à zéro de l'écran de travail STCDW
#                Appelé dans les actions : LIENS, RAZCRE et RAZDUP
# DELSTCDW       Suite à abandon de la saisie (Action ABANDON)
#                ou à suppression d'une ligne document qui était en cours
#                de création, raz des charges de l'écran de travail STCDW
# CONVERT_VOUWEU Mise à jour volume et poids après changement d'une
#                données impactante comme quantité commande ou
#                quantité en stock ou coefficient...
# CSTDOC         Alimentation du masque CSTDOC dans les achats
#                commandes/réception/facture
# COST_ADDINV    Alimentation dans le bloc 4 de l'écran [CST2] des montants
#                de factures complémentaires entrant dans le coût d'une
#                ligne de document
#--- 111257
# CAL_LEADTIME   Recherche du délai d'acheminement entre deux lieux
#---
########################################################################

########################################################################
# COSTSTCD_STCDW : composant de chargement de l'écran de travail STCDW
#                  à partir de la table structure de coût document COSTSTCD
########################################################################
########################################################################
# Prérequis    : L'écran de travail STCDW [STCDW] doit être ouvert
#
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LNOL    = No ligne écran (nolign-1)
#                LVCRTYP = Type de pièce achats
#                LVCRNUM = N° de la pièce achats
#                LVCRLIN = N° de ligne de la pièce achats
#                LVCRSEQ = N° de séquence de la pièce achats
#                LICT    = code incoterm du document achat
#            S : LRET    = Code retour (0=OK / 1=Erreur)
########################################################################
Subprog COSTSTCD_STCDW(LABR,LNOL,LVCRTYP,LVCRNUM,LVCRLIN, LVCRSEQ,LICT,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Integer LVCRTYP
Value    Char    LVCRNUM
Value    Integer LVCRLIN
Value    Integer LVCRSEQ
Value    Char    LICT
Variable Integer LRET

Local    Integer J, NBFCS, WMAX, K

J = [M:STCDW]NBLIG

Filter [STCD] Where [F:STCD]VCRTYP=LVCRTYP & [F:STCD]VCRNUM=LVCRNUM & [F:STCD]VCRLIN=LVCRLIN &
&                   [F:STCD]VCRSEQ=LVCRSEQ

NBFCS= rowcount([STCD])
WMAX = dim([M:STCDW]WFCSCOD)

If (NBFCS + [M:STCDW]NBLIG) <= WMAX
  For [STCD]STCD0
    [M:STCDW]WNUMSEQ(J)    = [F:STCD]NUMSEQ
    [M:STCDW]WSTCSEQ(J)    = evalue("[M:"+LABR+"]WSTCSEQ(LNOL)")
    [M:STCDW]WSTCLIN(J)    = [F:STCD]STCLIN
    [M:STCDW]WFCSCOD(J)    = [F:STCD]FCSCOD
    [M:STCDW]WUNTPRI(J)    = [F:STCD]UNTPRI
    [M:STCDW]WCURIMP(J)    = [F:STCD]CUR
    [M:STCDW]WQTY(J)       = [F:STCD]QTY
    [M:STCDW]WBAS(J)       = [F:STCD]BAS
    [M:STCDW]WUOM(J)       = [F:STCD]UOM
    [M:STCDW]WPRINETPRC(J) = [F:STCD]PRINETPRC
    [M:STCDW]WWEIPRC(J)    = [F:STCD]WEIPRC
    [M:STCDW]WFCSAMTCLC(J) = [F:STCD]FCSAMTCLC
    [M:STCDW]WFCSAMT(J)    = [F:STCD]FCSAMT
    [M:STCDW]WFCSAMTORI(J) = 0
    [M:STCDW]WFCSAMTSOC(J) = [F:STCD]FCSAMTSOC
    [M:STCDW]WFORFCS(J)    = [F:STCD]FORFCS
    [M:STCDW]WPRCBUY(J)    = [F:STCD]PRCBUY
    [M:STCDW]WDOCCHGTYP(J) = [F:STCD]DOCCHGTYP
    [M:STCDW]WCHGTYP(J)    = [F:STCD]CHGTYP
    [M:STCDW]WCHGCOE(J)    = [F:STCD]CHGCOE
    [M:STCDW]WFCSNAT(J)    = [F:STCD]FCSNAT
    # Issue 89349-4 - 2013-12-17 by SR : Rapprochement
    [M:STCDW]STCRFLG(J)    = [F:STCD]STCRFLG
    If [M:STCDW]STCRFLG(J) = 0 : [M:STCDW]STCRFLG(J) = 1 : Endif

    #--- TS le 28/02/13 pour ajout charge
    #--- Lecture de la charge
    If [F:FCS]FCSCOD <> [F:STCD]FCSCOD
      Read [FCS]FCS0 = [F:STCD]FCSCOD
    Endif
    [M:STCDW]WSTKVLT(J)    = [F:FCS]STKVLT
    [M:STCDW]WDIRCLCMOD(J) = [F:FCS]DIRCLCMOD
    [M:STCDW]WLIMTYP(J)    = [F:FCS]LIMTYP
    #---


    #lecture de l'incoterm
    If LICT <> ""
      Read [ICTD] ICTD0 = LICT; [M:STCDW]WFCSNAT(J)
      If !fstat
        [M:STCDW]WCSTPYR(J) = [F:ICTD]CSTPYR
      Endif
    Endif

    #Lecture des axes analytiques
    For K=1 To GNBDIE
      Assign "[M:STCDW]CCE"+num$(K)+"("+num$(J)+")" With evalue("[F:STCD]CCE("+num$(K-1)+")")
    Next K

    [M:STCDW]NBLIG  += 1
    J=J+1
  Next
Else
  WMESSAGE = func AFNC.MES1(mess(608,199,1),"STCDW")
  Call MESSAGE(WMESSAGE) From GESECRAN
  LRET = 1
  Filter [STCD]
  End
Endif
Filter [STCD]
End

#########################################################################
# COSTSTCL_STCDW : composant de chargement de l'écran de travail STCDW
#                  à partir des tables structure de coût lignes COSTSTCL
########################################################################
########################################################################
# Prérequis    : L'écran de travail STCDW [STCDW] doit être ouvert
#
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LNOL    = No ligne écran (nolign-1)
#                LICT    = code incoterm du document achat
#                LDAT    = date du document
#                LCHGTYP = type de cours du document
#            S : LRET    = Code retour (0=OK / 1=Erreur)
########################################################################
Subprog COSTSTCL_STCDW(LABR,LNOL,LICT,LDAT,LCHGTYP,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Char    LICT
Value    Date    LDAT
Value    Integer LCHGTYP
Variable Integer LRET

Local    Integer J, NBFCS
Local    Integer STAT
Local    Integer WNUMSEQ

J = [M:STCDW]NBLIG

Filter [F:STCL] Where STCNUM=evalue("[M:"+LABR+"]STCNUM(LNOL)")

NBFCS= rowcount([F:STCL])
WMAX = dim([M:STCDW]WFCSCOD)

If (NBFCS + [M:STCDW]NBLIG) <= WMAX
  For [STCL]STCL0
    [M:STCDW]WSTCSEQ(J)    = evalue("[M:"+LABR+"]WSTCSEQ(LNOL)")
    WNUMSEQ+=1000
    [M:STCDW]WNUMSEQ(J)    = WNUMSEQ
    [M:STCDW]WSTCLIN(J)    = [F:STCL]STCLIN
    [M:STCDW]WFCSCOD(J)    = [F:STCL]FCSCOD
    [M:STCDW]WUNTPRI(J)    = [F:STCL]UNTPRI
    [M:STCDW]WCURIMP(J)    = [F:STCL]CUR
    [M:STCDW]WQTY(J)       = [F:STCL]QTY
    [M:STCDW]WBAS(J)       = [F:STCL]BAS
    [M:STCDW]WUOM(J)       = [F:STCL]UOM
    [M:STCDW]WPRINETPRC(J) = [F:STCL]PRINETPRC
    [M:STCDW]WWEIPRC(J)    = [F:STCL]WEIPRC
    [M:STCDW]WFORFCS(J)    = [F:STCL]FORFCS
    [M:STCDW]WDIRCLCMOD(J) = [F:STCL]DIRCLCMOD
    [M:STCDW]WSTKVLT(J)    = [F:STCL]STKVLT
    [M:STCDW]WLIMTYP(J)    = [F:STCL]LIMTYP
    [M:STCDW]WFCSAMTCLC(J) = 0
    [M:STCDW]WFCSAMT(J)    = 0
    [M:STCDW]WFCSAMTORI(J) = 0
    [M:STCDW]WFCSAMTSOC(J) = 0
    [M:STCDW]WFCSNAT(J)    = [F:STCL]FCSNAT
    [M:STCDW]WSTKVLT(J)    = [F:STCL]STKVLT
    [M:STCDW]WDIRCLCMOD(J) = [F:STCL]DIRCLCMOD
    [M:STCDW]WLIMTYP(J)    = [F:STCL]LIMTYP
    [M:STCDW]WDOCCHGTYP(J) = [F:STCL]DOCCHGTYP
    # Issue 89349-4 - 2013-12-17 by SR : Rapprochement
    [M:STCDW]STCRFLG(J)    = 1

    If [F:STCL]DOCCHGTYP = 1
      [M:STCDW]WCHGTYP(J)  = [F:STCL]CHGTYP
    Else
      [M:STCDW]WCHGTYP(J)   = LCHGTYP
    Endif
    # Si % prix net alors devise document
    If [M:STCDW]WDIRCLCMOD(J)=1
      [M:STCDW]WCURIMP (J) = [M:STCD]CURDOC
    # Si formule alors devise dossier
    Elsif [M:STCDW]WDIRCLCMOD(J)=7
      [M:STCDW]WCURIMP (J) = GSYSCUR
    Endif
    If [M:STCDW]WCURIMP(J) <> [M:STCD]CUR
      Call COURSITE([M:STCDW]WCURIMP(J),GFCY,[M:STCDW]WCHGTYP(J),LDAT,[M:STCDW]WCHGCOE(J),STAT) From TRTDEV
    Else
      [M:STCDW]WCHGCOE(J) = 1
    Endif

    #lecture de l'incoterm
    If LICT = ""
      [M:STCDW]WPRCBUY(J) = 100
    Else
      Read [ICTD] ICTD0 = LICT; [M:STCDW]WFCSNAT(J)
      If !fstat
        [M:STCDW]WCSTPYR(J) = [F:ICTD]CSTPYR
        If [M:STCDW]WCSTPYR(J)=1 | [M:STCDW]WCSTPYR(J)=3
          [M:STCDW]WPRCBUY(J) = 0
        Elsif [M:STCDW]WCSTPYR(J)=2
          [M:STCDW]WPRCBUY(J)=100
        Else
          [M:STCDW]WPRCBUY(J)=50
        Endif
      Else
        [M:STCDW]WPRCBUY(J)=100
      Endif
    Endif

    [M:STCDW]NBLIG  += 1
    J=J+1
  Next
Else
  WMESSAGE = func AFNC.MES1(mess(608,199,1),"STCDW")
  Call MESSAGE(WMESSAGE) From GESECRAN
  LRET = 1
  Filter [STCL]
  End
Endif
Filter [STCL]
End

########################################################################
# COSTSTCD_STCD : composant de chargement de l'écran de saisie STCD
#                 à partir de la table structure de coût document COSTSTCD
########################################################################
########################################################################
# Prérequis    : L'écran de saisie STCD [STCD] doit être ouvert
#
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LNOL    = No ligne écran (nolign-1)
#                LVCRTYP = Type de pièce achats
#                LVCRNUM = N° de la pièce achats
#                LVCRLIN = N° de ligne de la pièce achats
#                LVCRSEQ = N° de séquence de la pièce achats
#                LICT    = code incoterm du document achat
#                LCHGTYP = type de cours document
#            S : LRET    = Code retour (0=OK / 1=Erreur)
########################################################################
Subprog COSTSTCD_STCD(LABR,LNOL,LVCRTYP,LVCRNUM,LVCRLIN, LVCRSEQ,LICT,LCHGTYP,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Integer LVCRTYP
Value    Char    LVCRNUM
Value    Integer LVCRLIN
Value    Integer LVCRSEQ
Value    Char    LICT
Value    Integer LCHGTYP
Variable Integer LRET

Local    Integer J, NBFCS, WMAX,K

Filter [STCD] Where [F:STCD]VCRTYP=LVCRTYP & [F:STCD]VCRNUM=LVCRNUM & [F:STCD]VCRLIN=LVCRLIN &
&                   [F:STCD]VCRSEQ=LVCRSEQ

NBFCS= rowcount([STCD])
WMAX = dim([M:STCD]FCSCOD)

If (NBFCS) <= WMAX
  For [STCD]STCD0
    [M:STCD]WSTCSEQ      = evalue("[M:"+LABR+"]WSTCSEQ(LNOL)")
    [M:STCD]NUMSEQ(J)    = [F:STCD]NUMSEQ
    [M:STCD]STCLIN(J)    = [F:STCD]STCLIN
    [M:STCD]FCSCOD(J)    = [F:STCD]FCSCOD
    [M:STCD]UNTPRI(J)    = [F:STCD]UNTPRI
    [M:STCD]CURIMP(J)    = [F:STCD]CUR
    [M:STCD]CURIMP2(J)   = [F:STCD]CUR
    [M:STCD]QTY(J)       = [F:STCD]QTY
    [M:STCD]BAS(J)       = [F:STCD]BAS
    [M:STCD]UOM(J)       = [F:STCD]UOM
    [M:STCD]PRINETPRC(J) = [F:STCD]PRINETPRC
    [M:STCD]WEIPRC(J)    = [F:STCD]WEIPRC
    [M:STCD]FCSAMTCLC(J) = [F:STCD]FCSAMTCLC
    [M:STCD]FCSAMT(J)    = [F:STCD]FCSAMT
    [M:STCD]FCSAMTORI(J) = 0
    [M:STCD]FCSAMTSOC(J) = [F:STCD]FCSAMTSOC
    [M:STCD]CURSOC(J)    = [M:STCD]CUR
    [M:STCD]FORFCS(J)    = [F:STCD]FORFCS
    [M:STCD]PRCBUY(J)    = [F:STCD]PRCBUY
    [M:STCD]DOCCHGTYP(J) = [F:STCD]DOCCHGTYP
    [M:STCD]CHGTYP(J)    = [F:STCD]CHGTYP
    [M:STCD]CHGCOE(J)    = [F:STCD]CHGCOE
    [M:STCD]FCSNAT(J)    = [F:STCD]FCSNAT
    # Issue 89349-4 - 2013-12-17 by SR : Rapprochement
    [M:STCD]STCRFLG(J)   = [F:STCD]STCRFLG
    If [M:STCD]STCRFLG(J) = 0 : [M:STCD]STCRFLG(J) = 1 : Endif

    #Lecture des axes analytiques
    For K=1 To GNBDIE
      Assign "[M:STCD]CCE"+num$(K)With evalue("[F:STCD]CCE("+num$(K-1)+")")
    Next K

    #--- TS le 28/02/13 pour ajout charge
    #--- Lecture de la charge
    If [F:FCS]FCSCOD <> [F:STCD]FCSCOD
      Read [FCS]FCS0 = [F:STCD]FCSCOD
    Endif
    [M:STCD]STKVLT(J)    = [F:FCS]STKVLT
    [M:STCD]DIRCLCMOD(J) = [F:FCS]DIRCLCMOD
    [M:STCD]LIMTYP(J)    = [F:FCS]LIMTYP
    If [F:FCS]DOCCHGTYP = 1
      [M:STCD]CHGTYP(J) = [F:FCS]CHGTYP
    Else
      [M:STCD]CHGTYP(J) = LCHGTYP
    Endif
    #---

    # Si % prix net alors devise document
    If [M:STCD]DIRCLCMOD(J)=1
      [M:STCD]CURIMP(J)  = [M:STCD]CURDOC
      [M:STCD]CURIMP2(J) = [M:STCD]CURDOC
    # Si formule alors devise dossier
    Elsif [M:STCD]DIRCLCMOD(J)=7
      [M:STCD]CURIMP(J)  = GSYSCUR
      [M:STCD]CURIMP2(J) = GSYSCUR
    Endif

    #lecture de l'incoterm
    If LICT <> ""
      Read [ICTD] ICTD0 = LICT; [M:STCD]FCSNAT(J)
      If !fstat
        [M:STCD]CSTPYR(J) = [F:ICTD]CSTPYR
      Endif
    Endif

    [M:STCD]NBLIG  += 1
    J+=1
  Next
Else
  WMESSAGE = func AFNC.MES1(mess(608,199,1),"STCL")
  Call MESSAGE(WMESSAGE) From GESECRAN
  LRET = 1
  Filter [STCD]
  End
Endif
Filter [STCD]
End

#########################################################################
# COSTSTCL_STCD : composant de chargement de l'écran de saisie STCD
#                 à partir des tables structure de coût lignes COSTSTCL
########################################################################
########################################################################
# Prérequis    : L'écran de saisie STCD [STCD] doit être ouvert
#
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LNOL    = No ligne écran (nolign-1)
#                LICT    = code incoterm du document achat
#                LDAT    = date document
#                LCHGTYP = type de cours document
#            S : LRET    = Code retour (0=OK / 1=Erreur)
########################################################################
Subprog COSTSTCL_STCD(LABR,LNOL,LICT,LDAT,LCHGTYP,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Char    LICT
Value    Date    LDAT
Value    Integer LCHGTYP
Variable Integer LRET

Local    Integer J, K, NBFCS
Local    Integer STAT
Local    Integer WNUMSEQ
Local    Char    WANA, WSECTION

Global Integer GNOL : Raz GNOL

Case LABR
  When "POH2"   WANA="PCOSTPOH"
  When "PTH1"   WANA="PCOSTPTH"
  When "PIH3"   WANA="PCOSTPIH"
  When "SHIP1"  WANA=""             : # Issue 110325
  When Default  WANA = "PCOSTPOH"
Endcase

Filter [F:STCL] Where STCNUM=evalue("[M:"+LABR+"]STCNUM(LNOL)")

NBFCS= rowcount([F:STCL])
WMAX = dim([M:STCD]FCSCOD)

If (NBFCS) <= WMAX
  For [STCL]STCL0
    [M:STCD]WSTCSEQ      = evalue("[M:"+LABR+"]WSTCSEQ(LNOL)")
    WNUMSEQ += 1000
    [M:STCD]NUMSEQ(J)    = WNUMSEQ
    [M:STCD]STCLIN(J)    = [F:STCL]STCLIN
    [M:STCD]FCSCOD(J)    = [F:STCL]FCSCOD
    [M:STCD]UNTPRI(J)    = [F:STCL]UNTPRI
    [M:STCD]CURIMP(J)    = [F:STCL]CUR
    [M:STCD]CURIMP2(J)   = [F:STCL]CUR
    [M:STCD]QTY(J)       = [F:STCL]QTY
    [M:STCD]BAS(J)       = [F:STCL]BAS
    [M:STCD]UOM(J)       = [F:STCL]UOM
    [M:STCD]PRINETPRC(J) = [F:STCL]PRINETPRC
    [M:STCD]WEIPRC(J)    = [F:STCL]WEIPRC
    [M:STCD]FORFCS(J)    = [F:STCL]FORFCS
    [M:STCD]FCSAMTCLC(J) = 0
    [M:STCD]FCSAMT(J)    = 0
    [M:STCD]FCSAMTORI(J) = 0
    [M:STCD]FCSAMTSOC(J) = 0
    [M:STCD]CURSOC(J)    = [M:STCD]CUR
    [M:STCD]FCSNAT(J)    = [F:STCL]FCSNAT
    [M:STCD]STKVLT(J)    = [F:STCL]STKVLT
    [M:STCD]DIRCLCMOD(J) = [F:STCL]DIRCLCMOD
    [M:STCD]LIMTYP(J)    = [F:STCL]LIMTYP
    [M:STCD]DOCCHGTYP(J) = [F:STCL]DOCCHGTYP
    # Issue 89349-4 - 2013-12-17 by SR : Rapprochement
    [M:STCD]STCRFLG(J)   = 1

    If [F:STCL]DOCCHGTYP = 1
      [M:STCD]CHGTYP(J)  = [F:STCL]CHGTYP
    Else
      [M:STCD]CHGTYP(J)   = LCHGTYP
    Endif
    # Si % prix net alors devise document
    If [M:STCD]DIRCLCMOD(J)=1
      [M:STCD]CURIMP(J)  = [M:STCD]CURDOC
      [M:STCD]CURIMP2(J) = [M:STCD]CURDOC
    # Si formule alors devise dossier
    Elsif [M:STCD]DIRCLCMOD(J)=7
      [M:STCD]CURIMP(J)  = GSYSCUR
      [M:STCD]CURIMP2(J) = GSYSCUR
    Endif
    If [M:STCD]CURIMP(J) <> [M:STCD]CUR
      Call COURSITE([M:STCD]CURIMP(J),GFCY,[M:STCD]CHGTYP(J),LDAT,[M:STCD]CHGCOE(J),STAT) From TRTDEV
    Else
      [M:STCD]CHGCOE(J) = 1
    Endif

    #lecture de l'incoterm
    If LICT = ""
      [M:STCD]PRCBUY(J) = 100
    Else
      Read [ICTD] ICTD0 = LICT; [M:STCD]FCSNAT(J)
      If !fstat
        [M:STCD]CSTPYR(J) = [F:ICTD]CSTPYR
        If [M:STCD]CSTPYR(J)=1 | [M:STCD]CSTPYR(J)=3
          [M:STCD]PRCBUY(J) = 0
        Elsif [M:STCD]CSTPYR(J)=2
          [M:STCD]PRCBUY(J)=100
        Else
          [M:STCD]PRCBUY(J)=50
        Endif
      Else
        [M:STCD]PRCBUY(J)=100
      Endif
    Endif

    #--- Initialisation des axes analytiques
    Raz WSECTION
    #--- Issue 110325
    If WANA<>""
      For K=1 To GNBDIE
        GNOL = J
        Call INISEC(WSECTION,WANA,K) From TRTX3CPT
        Assign "[M:STCD]CCE"+num$(K)+"("+num$(J)+")" With WSECTION
      Next K
    #--- Issue 110325
    Endif

    [M:STCD]NBLIG  += 1
    J+=1
  Next
Else
  WMESSAGE = func AFNC.MES1(mess(608,199,1),"STCL")
  Call MESSAGE(WMESSAGE) From GESECRAN
  LRET = 1
  Filter [STCL]
  End
Endif
Filter [STCL]
End

########################################################################
# STCDW_STCD : composant chargement de l'écran de saisie STCD à partir
#              de l'écran de travail STCDW pour une ligne de document
########################################################################
########################################################################
# Prérequis    : L'écran de travail STCDW [STCDW] doit être ouvert
#
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LNOL    = No ligne écran (nolign-1)
#            S : LRET    = Code retour (0=OK / 1=Erreur)
########################################################################
Subprog STCDW_STCD(LABR,LNOL,LRET)
Value    Char    LABR
Value    Integer LNOL
Variable Integer LRET

Local    Integer J, K
Local Char WSECTION, WANA

Local Integer WMAX

Global Integer GNOL : Raz GNOL

# Nb de lignes maximum du tableau [STC]
WMAX = dim([M:STCD]FCSCOD)

Case LABR
  When "POH2"   WANA="PCOSTPOH"
  When "PTH1"   WANA="PCOSTPTH"
  When "PIH3"   WANA="PCOSTPIH"
  When "SHIP1"  WANA=""             : # Issue 110325
  When Default  WANA = "PCOSTPOH"
Endcase

NOL=0
If [M:STCDW]NBLIG<=0 Goto STCDW_STCD_FIN Endif
For I=0 To [M:STCDW]NBLIG-1
   # Nb max de lignes atteint
   If NOL>WMAX
      #ajout message d'erreur et sortir
      WMESSAGE = func AFNC.MES1(mess(608,199,1),"STCL")
      Call MESSAGE(WMESSAGE) From GESECRAN
      LRET = 1
      End
   Endif
   If [M:STCDW]WSTCSEQ(I)=evalue("[M:"+LABR+"]WSTCSEQ(LNOL)")
      [M:STCD]WSTCSEQ        = [M:STCDW]WSTCSEQ(I)
      [M:STCD]NUMSEQ(NOL)    = [M:STCDW]WNUMSEQ(I)
      [M:STCD]STCLIN(NOL)    = [M:STCDW]WSTCLIN(I)
      [M:STCD]FCSCOD(NOL)    = [M:STCDW]WFCSCOD(I)
      [M:STCD]FCSNAT(NOL)    = [M:STCDW]WFCSNAT(I)
      [M:STCD]DIRCLCMOD(NOL) = [M:STCDW]WDIRCLCMOD(I)
      [M:STCD]LIMTYP(NOL)    = [M:STCDW]WLIMTYP(I)
      [M:STCD]UNTPRI(NOL)    = [M:STCDW]WUNTPRI(I)
      [M:STCD]CURIMP(NOL)    = [M:STCDW]WCURIMP(I)
      [M:STCD]CURIMP2(NOL)   = [M:STCDW]WCURIMP(I)
      [M:STCD]QTY(NOL)       = [M:STCDW]WQTY(I)
      [M:STCD]BAS(NOL)       = [M:STCDW]WBAS(I)
      [M:STCD]UOM(NOL)       = [M:STCDW]WUOM(I)
      [M:STCD]PRINETPRC(NOL) = [M:STCDW]WPRINETPRC(I)
      [M:STCD]WEIPRC(NOL)    = [M:STCDW]WWEIPRC(I)
      [M:STCD]FCSAMTCLC(NOL) = [M:STCDW]WFCSAMTCLC(I)
      [M:STCD]FCSAMT(NOL)    = [M:STCDW]WFCSAMT(I)
      [M:STCD]FCSAMTORI(NOL) = [M:STCDW]WFCSAMTORI(I)
      [M:STCD]FCSAMTSOC(NOL) = [M:STCDW]WFCSAMTSOC(I)
      [M:STCD]CURSOC(NOL)    = [M:STCD]CUR
      [M:STCD]DOCCHGTYP(NOL) = [M:STCDW]WDOCCHGTYP(I)
      [M:STCD]CHGTYP(NOL)    = [M:STCDW]WCHGTYP(I)
      [M:STCD]CHGCOE(NOL)    = [M:STCDW]WCHGCOE(I)
      [M:STCD]STKVLT(NOL)    = [M:STCDW]WSTKVLT(I)
      [M:STCD]CSTPYR(NOL)    = [M:STCDW]WCSTPYR(I)
      [M:STCD]PRCBUY(NOL)    = [M:STCDW]WPRCBUY(I)
      [M:STCD]FORFCS(NOL)    = [M:STCDW]WFORFCS(I)
      [M:STCD]CSTPYR(NOL)    = [M:STCDW]WCSTPYR(I)
      # Issue 89349-4 - 2013-12-17 by SR : Rapprochement
      [M:STCD]STCRFLG(NOL)   = [M:STCDW]STCRFLG(I)

      #Lecture des axes analytiques
      Raz WSECTION
      For K=1 To GNBDIE
        Assign "[M:STCD]CCE"+num$(K)+"("+num$(NOL)+")" With evalue("[M:STCDW]CCE"+num$(K)+"("+num$(I)+")")
        If evalue("[M:STCD]CCE"+num$(K)+"("+num$(NOL)+")")=""
          GNOL = NOL
          #--- Issue 110325
          If WANA<>""
            Call INISEC(WSECTION,WANA,K) From TRTX3CPT
          #--- Issue 110325
          Endif
          Assign "[M:STCD]CCE"+num$(K)+"("+num$(NOL)+")" With WSECTION
        Endif
      Next K

      Goto STCDW_STCD_SUI
   Endif
   Goto NEXT_STCDW_STCD

$STCDW_STCD_SUI

   NOL += 1

$NEXT_STCDW_STCD
Next I

$STCDW_STCD_FIN
# Tableau chargé
If NOL<=WMAX
   [M:STCD]NBLIG = NOL
Endif

End

########################################################################
# STCD_STCDW : composant de chargement de l'écran de travail STCDW
#              à partir de l'écran de saisie STCD
########################################################################
########################################################################
# Prérequis    : L'écran de travail STCDW [STCDW] doit être ouvert
#
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LNOL    = No ligne écran (nolign-1)
#            S : LRET    = Code retour (0=OK / 1=Erreur)
########################################################################
Subprog STCD_STCDW(LABR,LNOL,LRET)
Value    Char    LABR
Value    Integer LNOL
Variable Integer LRET
Local Integer    WNBFCS, WMAX,K

# Nb de lignes maximum du tableau [STCD]
WNBFCS = dim([M:STCD]FCSCOD)
# Nb de lignes maximum du tableau [STCDW]
WMAX = dim([M:STCDW]WFCSCOD)
# Alimentation de l'écran de stockage STCDW
WNBLIG = [M:STCDW]NBLIG
J=find(evalue("[M:"+LABR+"]WSTCSEQ(LNOL)"), [M:STCDW]WSTCSEQ(0..[M:STCDW]NBLIG-1))-1
# premier chargement dans STCDW pour cette ligne
If J<0
  #Pourra-t-on tout mettre ?
  If [M:STCDW]NBLIG + WNBFCS >= WMAX
      WMESSAGE = func AFNC.MES1(mess(608,199,1),"STCDW")
      Call MESSAGE(WMESSAGE) From GESECRAN
      LRET = 1
      End
  Endif
  J = [M:STCDW]NBLIG
Endif
For I=0 To [M:STCD]NBLIG-1
  If [M:STCDW]WSTCSEQ(J) = 0
     [M:STCDW]WSTCSEQ(J)    = [M:STCD]WSTCSEQ
  Endif
  [M:STCDW]WNUMSEQ(J)    = [M:STCD]NUMSEQ(I)
  [M:STCDW]WSTCLIN(J)    = [M:STCD]STCLIN(I)
  [M:STCDW]WFCSCOD(J)    = [M:STCD]FCSCOD(I)
  [M:STCDW]WFCSNAT(J)    = [M:STCD]FCSNAT(I)
  [M:STCDW]WDIRCLCMOD(J) = [M:STCD]DIRCLCMOD(I)
  [M:STCDW]WLIMTYP(J)    = [M:STCD]LIMTYP(I)
  [M:STCDW]WUNTPRI(J)    = [M:STCD]UNTPRI(I)
  [M:STCDW]WCURIMP(J)    = [M:STCD]CURIMP(I)
  [M:STCDW]WQTY(J)       = [M:STCD]QTY(I)
  [M:STCDW]WBAS(J)       = [M:STCD]BAS(I)
  [M:STCDW]WUOM(J)       = [M:STCD]UOM(I)
  [M:STCDW]WPRINETPRC(J) = [M:STCD]PRINETPRC(I)
  [M:STCDW]WWEIPRC(J)    = [M:STCD]WEIPRC(I)
  [M:STCDW]WFCSAMTCLC(J) = [M:STCD]FCSAMTCLC(I)
  [M:STCDW]WFCSAMT(J)    = [M:STCD]FCSAMT(I)
  [M:STCDW]WFCSAMTORI(J) = [M:STCD]FCSAMTORI(I)
  [M:STCDW]WFCSAMTSOC(J) = [M:STCD]FCSAMTSOC(I)
  [M:STCDW]WDOCCHGTYP(J) = [M:STCD]DOCCHGTYP(I)
  [M:STCDW]WCHGTYP(J)    = [M:STCD]CHGTYP(I)
  [M:STCDW]WCHGCOE(J)    = [M:STCD]CHGCOE(I)
  [M:STCDW]WSTKVLT(J)    = [M:STCD]STKVLT(I)
  [M:STCDW]WCSTPYR(J)    = [M:STCD]CSTPYR(I)
  [M:STCDW]WPRCBUY(J)    = [M:STCD]PRCBUY(I)
  [M:STCDW]WFORFCS(J)    = [M:STCD]FORFCS(I)
  [M:STCDW]WCSTPYR(J)    = [M:STCD]CSTPYR(I)
  # Issue 89349-4 - 2013-12-17 by SR : Rapprochement
  [M:STCDW]STCRFLG(J)    = [M:STCD]STCRFLG(I)

  #Lecture des axes analytiques
  For K=1 To GNBDIE
   Assign "[M:STCDW]CCE"+num$(K)+"("+num$(J)+")" With evalue("[M:STCD]CCE"+num$(K)+"("+num$(I)+")")
  Next K

  J += 1

Next I

If J > [M:STCDW]NBLIG : [M:STCDW]NBLIG = J : Endif

#alimentation du WSTCSEQ de l'écran du document achat
Assign "[M:"+LABR+"]WSTCSEQ(LNOL)" With [M:STCD]WSTCSEQ

End

########################################################################
# STCTRF_STCD   Lecture des charges d'une ligne de document (COSTSTCD)
#                pour stockage dans ecran de saisie STCD d'un autre document
#                - réception d'une ligne de commande (PTH1)
#                #--- Issue 110325
#                - expédition d'une ligne de commande (SHIP1)
#                - réception d'une ligne d'expédition (PTH1)
#                #--- End issue 110325
########################################################################
########################################################################
# Prérequis    : L'écran de saisie STCD [STCD] doit être ouvert
#                La table COSTSTCD [STCD] doit être ouverte
#
########################################################################
# Paramètres E : LABR    = Abréviation écran (PTH1 ou SHIP1)
#                LNOL    = No ligne écran (nolign-1)
#                LVCRTYP = Type pièce de COSTSTCD (document origine)
#                LVCRNUM = N° pièce de COSTSTCD (document origine)
#                LVCRLIN = N° ligne de COSTSTCD (document origine)
#                LVCRSEQ = N° séquence de COSTSTCD (document origine)
#                LQTYPUU = Quantité UA ligne document origine
#                LICT    = code incoterm du document achat
#                LDAT    = date du document destination
#            S : LRET    = Code retour (0=OK / 1=Erreur)
########################################################################
Subprog STCTRF_STCD(LABR,LNOL,LVCRTYP,LVCRNUM,LVCRLIN,LVCRSEQ,LQTYPUU,LICT,LDAT,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Integer LVCRTYP
Value    Char    LVCRNUM
Value    Integer LVCRLIN
Value    Integer LVCRSEQ
Value    Decimal LQTYPUU
Value    Char    LICT
Value    Date    LDAT
Variable Integer LRET

Local    Integer J, NBFCS, WMAX, STAT,K

Raz LRET

If clalev([F:FCS]) =0  Local File FRECST    [FCS]   Endif
If clalev([F:ICTD])=0  Local File INCOTERMD [ICTD]  Endif
If clalev([F:PTD]) =0  Local File PRECEIPTD [PTD]   Endif

Filter [STCD] Where [F:STCD]VCRTYP=LVCRTYP & [F:STCD]VCRNUM=LVCRNUM & [F:STCD]VCRLIN=LVCRLIN &
&                   [F:STCD]VCRSEQ=LVCRSEQ
#--- Peut-on stocker les lignes dans [M:STCD] ?
NBFCS = rowcount([STCD])
WMAX  = dim([M:STCD]FCSCOD)
If NBFCS > WMAX
  WMESSAGE = func AFNC.MES1(mess(608,199,1),"STCL")
  Call MESSAGE(WMESSAGE) From GESECRAN
  LRET = 1
  Filter [STCD]
  End
Endif

# Alimentation des charges de la structure de coût à partir de la pièce origine
For [STCD]STCD0
  [M:STCD]WSTCSEQ      = evalue("[M:"+LABR+"]WSTCSEQ(LNOL)")
  # Alimentation des données de la charge
  Gosub ALIM_STCD

  #--- Issue 110325
  #--- Prorata sur les montants calculés et saisis
  #[M:STCD]FCSAMTCLC(J) = [F:STCD]FCSAMTCLC*evalue("[M:"+LABR+"]QTYPUU(LNOL)")/LQTYPUU
  #[M:STCD]FCSAMT(J)    = [F:STCD]FCSAMT*evalue("[M:"+LABR+"]QTYPUU(LNOL)")/LQTYPUU
  If LABR="SHIP1"
    If LQTYPUU >0
      [M:STCD]FCSAMTCLC(J) = [F:STCD]FCSAMTCLC*evalue("[M:"+LABR+"]SHIQTYPUU(LNOL)")/LQTYPUU
      [M:STCD]FCSAMT(J)    = [F:STCD]FCSAMT*evalue("[M:"+LABR+"]SHIQTYPUU(LNOL)")/LQTYPUU
    Endif
  Else
    # Issue 112232 - 2016-02-11 by MUARN : quantité à 0
    If LQTYPUU >0
      [M:STCD]FCSAMTCLC(J) = [F:STCD]FCSAMTCLC*evalue("[M:"+LABR+"]QTYPUU(LNOL)")/LQTYPUU
      [M:STCD]FCSAMT(J)    = [F:STCD]FCSAMT*evalue("[M:"+LABR+"]QTYPUU(LNOL)")/LQTYPUU
    Endif
  Endif
  #--- End Issue 110325

  # Lecture devise société pour traitement de l'arrondi
  If [F:TCU]CUR<>[M:STCD]CUR
    Read [TCU]TCU0=[M:STCD]CUR
    If fstat  Raz [F:TCU]  Endif
  Endif
  [M:STCD]FCSAMTSOC(J) = arr([M:STCD]FCSAMT(J)*[M:STCD]CHGCOE(J),[F:TCU]CURRND)
  #--- Stockage montant ajusté pièce origine pour proratisation
  [M:STCD]FCSAMTORI(J) = [F:STCD]FCSAMT
  J+=1
  [M:STCD]NBLIG+= 1
Next
Filter [STCD]

End

########################################################################
$ALIM_STCD
[M:STCD]NUMSEQ(J)    = [F:STCD]NUMSEQ
[M:STCD]STCLIN(J)    = [F:STCD]STCLIN
[M:STCD]FCSCOD(J)    = [F:STCD]FCSCOD
[M:STCD]UNTPRI(J)    = [F:STCD]UNTPRI
[M:STCD]CURIMP(J)    = [F:STCD]CUR
[M:STCD]QTY(J)       = [F:STCD]QTY
[M:STCD]BAS(J)       = [F:STCD]BAS
[M:STCD]UOM(J)       = [F:STCD]UOM
[M:STCD]PRINETPRC(J) = [F:STCD]PRINETPRC
[M:STCD]WEIPRC(J)    = [F:STCD]WEIPRC
[M:STCD]FORFCS(J)    = [F:STCD]FORFCS
[M:STCD]PRCBUY(J)    = [F:STCD]PRCBUY
[M:STCD]DOCCHGTYP(J) = [F:STCD]DOCCHGTYP
[M:STCD]CHGTYP(J)    = [F:STCD]CHGTYP
[M:STCD]FCSNAT(J)    = [F:STCD]FCSNAT
# Issue 89349-4 - 2013-12-17 by SR : Rapprochement
[M:STCD]STCRFLG(J)   = [F:STCD]STCRFLG
If [M:STCD]STCRFLG(J) = 0 : [M:STCD]STCRFLG(J) = 1 : Endif

If [M:STCD]CURIMP(J) <> [M:STCD]CUR
  Call COURSITE([M:STCD]CURIMP(J),GFCY,[M:STCD]CHGTYP(J),LDAT,[M:STCD]CHGCOE(J),STAT) From TRTDEV
Else
  [M:STCD]CHGCOE(J) = 1
Endif
# Lecture des axes analytiques
For K=1 To GNBDIE
  Assign "[M:STCD]CCE"+num$(K)+"("+num$(J)+")" With evalue("[F:STCD]CCE("+num$(K-1)+")")
Next K
# Lecture de la charge
If [F:FCS]FCSCOD <> [F:STCD]FCSCOD
  Read [FCS]FCS0 = [F:STCD]FCSCOD
Endif
[M:STCD]STKVLT(J)    = [F:FCS]STKVLT
[M:STCD]DIRCLCMOD(J) = [F:FCS]DIRCLCMOD
[M:STCD]LIMTYP(J)    = [F:FCS]LIMTYP
# Lecture de l'incoterm
If [F:ICTD]CSTNAT<> [M:STCD]FCSNAT(J) | [F:ICTD]ICTCOD<>LICT
  Read [ICTD] ICTD0 = LICT; [M:STCD]FCSNAT(J)
Endif
[M:STCD]CSTPYR(J) = [F:ICTD]CSTPYR

Return

########################################################################
# STCMAJ : composant de mise à jour de la table des charges à la ligne
#          du document COSTSTCD à partir de l'écran de travail STCDW
########################################################################
########################################################################
# Prérequis    : L'écran de travail STCDW [STCDW] doit être ouvert
#                La table COSTSTCD doit être ouverte
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LNOL    = No ligne écran (nolign-1)
#                LVCRTYP = Type de pièce achats
#                LVCRNUM = N° de la pièce achats
#                LVCRLIN = N° de ligne de la pièce achats
#                LVCRSEQ = N° de séquence de la pièce achats
#            S : LRET    = Code retour (0=OK / 1=Erreur)
########################################################################
Subprog STCMAJ(LABR,LNOL,LVCRTYP,LVCRNUM,LVCRLIN,LVCRSEQ,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Integer LVCRTYP
Value    Char    LVCRNUM
Value    Integer LVCRLIN
Value    Integer LVCRSEQ
Variable Integer LRET

Local Integer I,J,WCREFLG,WWSTCSEQ,K
Local Char WCLE(60)
Raz LRET
# On trie le tableau afin d'avoir en début toutes les lignes annulées et ensuite toutes les autres groupées par WSTCSEQ
Sorta [M:STCDW]NBLIG [M:STCDW]NBLIG Order By [M:STCDW]WSTCSEQ(indice), [M:STCDW]WNUMSEQ(indice)
# On se positionne sur la première ligne concernant la ligne du document
WWSTCSEQ = evalue("[M:"+LABR+"]WSTCSEQ(LNOL)")
J = find(WWSTCSEQ, [M:STCDW]WSTCSEQ(0..[M:STCDW]NBLIG-1))
If J
  For I=J-1 To [M:STCDW]NBLIG-1
        If [M:STCDW]WNUMSEQ(I)<>0
          #si on n'est plus sur les lignes concernée on part
          If WWSTCSEQ<>[M:STCDW]WSTCSEQ(I) : Break : Endif
          #Faut-il créer ou modifier l'enregistrement COSTSTCD ? WCREFLG =1 modif,  WCREFLG = 2 création
           Raz WCREFLG
           If find(GREP,"C","D")
              Raz [F:STCD]
              WCREFLG = 2
           Else
             Readlock [F:STCD]STCD0 = LVCRTYP;LVCRNUM;LVCRLIN;LVCRSEQ;[M:STCDW]WNUMSEQ(I)
             Case fstat
                  When 0
                    WCREFLG = 1
                  When 1
                    WCLE = num$(LVCRTYP)-LVCRNUM-num$(LVCRLIN)-num$(LVCRSEQ)-num$([M:STCDW]WNUMSEQ(I))
                    Call RSTA("STCD",WCLE) From GLOCK
                    GMESSAGE=mess(12,100,1)-"COSTSTCD"-[L]WCLE
                    GOK = 0
                    LRET = 1
                    End
                  When 4,5
                    Raz [F:STCD]
                    WCREFLG = 2
             Endcase
           Endif
          [F:STCD]PRINETPRC = [M:STCDW]WPRINETPRC(I)
          [F:STCD]UNTPRI    = [M:STCDW]WUNTPRI(I)
          [F:STCD]CUR       = [M:STCDW]WCURIMP(I)
          [F:STCD]QTY       = [M:STCDW]WQTY(I)
          [F:STCD]BAS       = [M:STCDW]WBAS(I)
          [F:STCD]UOM       = [M:STCDW]WUOM(I)
          [F:STCD]WEIPRC    = [M:STCDW]WWEIPRC(I)
          [F:STCD]PRCBUY    = [M:STCDW]WPRCBUY(I)
          [F:STCD]FCSAMTCLC = [M:STCDW]WFCSAMTCLC(I)
          [F:STCD]FCSAMT    = [M:STCDW]WFCSAMT(I)
          [F:STCD]FCSAMTSOC = [M:STCDW]WFCSAMTSOC(I)
          [F:STCD]FORFCS    = [M:STCDW]WFORFCS(I)
          [F:STCD]DOCCHGTYP = [M:STCDW]WDOCCHGTYP(I)
          [F:STCD]CHGTYP    = [M:STCDW]WCHGTYP(I)
          [F:STCD]CHGCOE    = [M:STCDW]WCHGCOE(I)

          #Mise à jour des axes analytiques
          For K=1 To GNBDIE
            Assign "[F:STCD]CCE("+num$(K-1)+")" With evalue("[M:STCDW]CCE"+num$(K)+"("+num$(I)+")")
           Next K
          If WCREFLG = 2
             [F:STCD]VCRTYP  = LVCRTYP
             [F:STCD]VCRNUM  = LVCRNUM
             [F:STCD]VCRLIN  = LVCRLIN
             [F:STCD]VCRSEQ  = LVCRSEQ
             [F:STCD]NUMSEQ  = [M:STCDW]WNUMSEQ(I)
             [F:STCD]STCLIN  = [M:STCDW]WSTCLIN(I)
             [F:STCD]FCSCOD  = [M:STCDW]WFCSCOD(I)
             [F:STCD]FCSNAT  = [M:STCDW]WFCSNAT(I)
             # Issue 89349-4 - 2013-12-17 by SR : Rapprochement
             [F:STCD]STCRFLG = 1
             [F:STCD]CREDAT  = date$
             [F:STCD]CREUSR  = GUSER
             Write [STCD]
             If fstat
                GOK = 0 : Call FSTA("STCD") From GLOCK
                GMESSAGE=mess(13,100,1)-"COSTSTCD"
                LRET = 1
             Endif
          Else
            [F:STCD]UPDDAT=date$
            [F:STCD]UPDUSR=GUSER
             Rewrite [STCD]
             If fstat
               GOK = 0 : Call FSTA("STCD") From GLOCK
               GMESSAGE=mess(13,100,1)-"COSTSTCD"
               LRET = 1
             Endif
          Endif
        Endif
  Next
Endif
End

#######################################################################
$AB_TRT
Rollback
Return


########################################################################
# CHARGE_PARAM   : composant de chargement des paramètres (entête) de
#                  l'écran de saisie STCD
#                  à partir de la ligne du document
########################################################################
########################################################################
# Prérequis    : L'écran de saisi STCD [STCD] doit être ouvert
#
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LNOL    = No ligne écran (nolign-1)
#                LICT    = Incoterm
#            S : LRET    = Code retour (0=OK / 1=Erreur)
########################################################################
Subprog CHARGE_PARAM (LABR,LNOL,LRET,LICT)
Value    Char    LABR
Value    Integer LNOL
Value    Char    LICT
Variable Integer LRET

  Raz LRET
  [M:STCD]ITMREF    = evalue("[M:"+LABR+"]ITMREF(LNOL)")
  [M:STCD]WSTCSEQ   = evalue("[M:"+LABR+"]WSTCSEQ(LNOL)")
  [M:STCD]CUR       = GLOCALDEV  # devise société
  #MAE, on utilise la devise de l'écran plutôt que GCUR
  #[M:STCD]CURDOC    = GCUR       # devise du document
  [M:STCD]CURDOC    = evalue("[M:"+LABR+"]NETCUR(LNOL)")
  [M:STCD]STCNUM    = evalue("[M:"+LABR+"]STCNUM(LNOL)")
  [M:STCD]EECICT2   = LICT
  Read [TCU]TCU0    = [M:STCD]CUR
  If fstat
    Call RSTA("TCU",[M:STCD]CUR) From GLOCK
    LRET=1
  Endif
End

############################################################################
# RECH_COST : S/P Recherche landed cost                   MUARN 17/02/2012 #
#   recherche du coefficient frais approche et coût achat forfaitaire      #
#   ou structure de coût                                                   #
#   sur la fiche article/fournisseur, si non renseignée, sur l'onglet appro#
# ------------------------------------------------------------------------ #
# Subprog RECH_COST(WFCY,WBPSNUM, WITMREF, WCPRCOE, WCPRAMT, WSTCNUM)      #
#   WFCY     : site réception                                              #
#   WBPSNUM  : numéro fournisseur                                          #
#   WITMREF  : numéro article                                              #
#   WCPRCOE  : coefficient frais d'approche                                #
#   WCPRAMT  : coût achat forfaitaire                                      #
#   WSTCNUM  : structure de coût                                           #
############################################################################
Subprog RECH_COST(WFCY,WBPSNUM, WITMREF, WCPRCOE, WCPRAMT, WSTCNUM)
Value Char       WFCY
Value Char       WBPSNUM
Value Char       WITMREF
Variable Decimal WCPRCOE
Variable Decimal WCPRAMT
Variable Char    WSTCNUM

# Issue 90991 - 2013-10-23 by MUARN : ajout données site
If [F:STCF]ITMREF=WITMREF & [F:STCF]BPSNUM=WBPSNUM & [F:STCF]STOFCY=WFCY
  WCPRCOE = [F:STCF]CPRCOE
  WCPRAMT = [F:STCF]CPRAMT
  WSTCNUM = [F:STCF]STCNUM
Else
  Read [STCF] STCF0=WITMREF;WBPSNUM;WFCY
  If !fstat
    WCPRCOE = [F:STCF]CPRCOE
    WCPRAMT = [F:STCF]CPRAMT
    WSTCNUM = [F:STCF]STCNUM
  Elsif [F:ITP]ITMREF=WITMREF & [F:ITP]BPSNUM=WBPSNUM
    WCPRCOE = [F:ITP]CPRCOE
    WCPRAMT = [F:ITP]CPRAMT
    WSTCNUM = [F:ITP]STCNUM
  Else
    Read [ITP] ITP0=WITMREF;WBPSNUM
    If !fstat
      WCPRCOE = [F:ITP]CPRCOE
      WCPRAMT = [F:ITP]CPRAMT
      WSTCNUM = [F:ITP]STCNUM
    Elsif [F:ITM]ITMREF=WITMREF
      WCPRCOE = [F:ITM]CPRCOE
      WCPRAMT = [F:ITM]CPRAMT
      WSTCNUM = [F:ITM]STCNUM
    Else
      Read [ITM] ITM0=WITMREF
      If !fstat
        WCPRCOE = [F:ITM]CPRCOE
        WCPRAMT = [F:ITM]CPRAMT
        WSTCNUM = [F:ITM]STCNUM
      Endif
    Endif
  Endif
Endif

GPOINT="RECH_COST" : Gosub ENTREE From EXEFNC

End

#########################################################################
# WSTCSEQ : Calcule le nouveau numéro de séquence servant de lien      #
#           entre le document et le détail                             #
#########################################################################
# Paramètres E : LABR   = Ecran origine
#                LNOL   = Indice de la ligne (nolign-1)
#                LNBLIG = Nb ligne écran origine
# Paramètres S : LRET   = Ecran faisant une insertion de ligne (0=OK, 1=Erreur)
#
# Prérequis    : Le masque STCDW doit être ouvert
#
########################################################################
Subprog WSTCSEQ (LABR,LNOL,LNBLIG,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Integer LNBLIG
Variable Integer LRET

Local Integer LSEQ

Raz LRET
If LNOL < 0
    Call ERREUR(mess(46,105,1)-"WSTCSEQ") From GESECRAN
    LRET=1
    End
Endif

LSEQ=0

If LNBLIG > 0
   LSEQ = evalue ("max([M:"+LABR+"]WSTCSEQ(0..LNBLIG-1))")
Endif
If evalue("[M:STCDW]NBLIG") > 0
   LSEQ = evalue ("max(LSEQ,[M:STCDW]WSTCSEQ(0..[M:STCDW]NBLIG-1))")
Endif

If evalue("[M:"+LABR+"]WSTCSEQ(LNOL)")=0
   Assign "[M:"+LABR+"]WSTCSEQ(LNOL)" With LSEQ+1
Endif

End

########################################################################
# RAZSTCDW : Remise à zéro de l'écran de travail STCDW
#            Appelé dans les actions : LIENS, RAZCRE et RAZDUP
########################################################################
########################################################################
# Prérequis    : L'écran de travail STCDW [STCDW] doit être ouvert
########################################################################
Subprog RAZSTCDW

Raz [M:STCDW]

End

########################################################################
# DELSTCDW : Suite à suppression d'une ligne document qui était en
#            cours de création, raz des charges de l'écran STCDW
########################################################################
########################################################################
# Prérequis    : L'écran de travail STCDW [STCDW] doit être ouvert
########################################################################
# Paramètres E : LLIG  = nolign-1  (indice ligne document début)
#                        Si LLIG=-1 traitement de toutes les lignes
#                LLIG1 = nolign1-1 (indice ligne document fin)
#                LABR  = abréviation masque origine
#            S : LRET  = Code retour (0=OK / 1=Erreur)
#                Attention si erreur, ne pas supprimer la ligne document
#
########################################################################
Subprog DELSTCDW(LLIG,LLIG1,LABR,LRET)
Value    Integer LLIG
Value    Integer LLIG1
Value    Char    LABR
Variable Integer LRET

Local Integer WTRBEGIN
Local Integer I
Local Decimal LSTOCOU
Local Decimal LWIPQTY
Raz WTRBEGIN, LRET

If [M:STCDW]NBLIG=0 End Endif

# Si traitement de toutes les lignes (abandon de la saisie document)
If LLIG=-1
   Raz [M:STCDW] : End
Endif

For I=0 To [M:STCDW]NBLIG-1
   If evalue("find([M:STCDW]WSTCSEQ(I),[M:"+LABR+"]WSTCSEQ(LLIG..LLIG1))")
      Raz [M:STCDW]WSTCSEQ(I),[M:STCDW]WNUMSEQ(I),[M:STCDW]WSTCLIN(I),[M:STCDW]WFCSCOD(I)
   Endif
Next I

End


########################################################################
# CONVERT_VOUWEU : Mise à jour volume et poids après changement d'une
#                  données impactante comme quantité commande ou
#                  quantité en stock ou coefficient...
#
########################################################################
# Prérequis    : la table [F:ITM] a été lue
########################################################################
# Paramètres E : LABR       = Abréviation masque origine
#                LNOL       = Indice de la ligne (nolign-1)
#                LWEU       = Volume de l'unité de poids
#                LVOU       = Volume de l'unité de stock
#                LQTYSTU    = Quantité US
#                LOLDQTYSTU = Ancienne quantité US
#######################################################################
Subprog CONVERT_VOUWEU(LABR,LNOL,LWEU,LVOU,LQTYSTU,LOLDQTYSTU)
Value    Char    LABR
Value    Integer LNOL
Value    Char    LWEU
Value    Char    LVOU
Value    Decimal LQTYSTU
Value    Decimal LOLDQTYSTU

Local    Decimal WWEI
Local    Decimal WVOU

# gestion du poids
If evalue("[M:"+LABR+"]QTYWEU(LNOL)") = 0 | LOLDQTYSTU=0
  WWEI = [F:ITM]ITMWEI*LQTYSTU
  Call CONVERT_QTY([F:ITM]WEU,LWEU,WWEI)From TRTX3
  Assign "[M:"+LABR+"]QTYWEU(LNOL)" With WWEI
Elsif LOLDQTYSTU<>0
  WWEI = evalue("[M:"+LABR+"]QTYWEU(LNOL)")*LQTYSTU/LOLDQTYSTU
  Assign "[M:"+LABR+"]QTYWEU(LNOL)" With WWEI
Endif

# gestion du volume
If evalue("[M:"+LABR+"]QTYVOU(LNOL)") = 0 | LOLDQTYSTU=0
  WVOU = [F:ITM]ITMVOU*LQTYSTU
  Call CONVERT_QTY([F:ITM]VOU,LVOU,WVOU)From TRTX3
  Assign "[M:"+LABR+"]QTYVOU(LNOL)" With WVOU
Elsif LOLDQTYSTU<>0
  WVOU = evalue("[M:"+LABR+"]QTYVOU(LNOL)")*LQTYSTU/LOLDQTYSTU
  Assign "[M:"+LABR+"]QTYVOU(LNOL)" With WVOU
Endif

End



########################################################################
# CSTDOC : Alimentation du masque CSTDOC dans les achats
#          commandes/réception/facture
#
########################################################################
# Prérequis    : la table [F:ITM] a été lue
########################################################################
# Paramètres E : LABR        = Abréviation masque origine/lignes document
#                LABINV      = Abréviation masque éléments facturation
#                LVCRNUM     = Numéro du document
#                LCOURDEVISE = Cours devise
#######################################################################
Subprog CSTDOC(LABR,LABINV,LVCRNUM,LVCRTYP, LCOURDEVISE)
Value Char     LABR
Value Char     LABINV
Value Char     LVCRNUM
Value Integer  LVCRTYP
Value Decimal  LCOURDEVISE

Local Char    WABREV
Local Integer I, WNBCST
Local Decimal TOTAMTDOC, FCSCSTPURDOC, NONDEDTAXDOC, DISCRGAMTDOC, TOTCPRDOC, DISCRGAMTMINDOC, AMTFCCDOC
Local Decimal TOTAMTSOC, FCSCSTPURSOC, NONDEDTAXSOC, DISCRGAMTSOC, TOTCPRSOC, DISCRGAMTMINSOC, AMTFCCSOC
Local Decimal NONDEDTAXLIN, REACSTPURDOC, REACSTPURSOC
Local Decimal WAMTTAX, WDEDTAX
Local Decimal ARODOC, AROSOC  #arrondi devise document et devise société
Local Integer LTYP, LSEQ, LRET, LLIN
# Issue X3-25003 - 2018-03-23 by SR : Pour message si document d'origine inexistant (ex : facture sur dossier historique mais commande non historisée)
Local Integer WRETOK
# Issue 105027 - 2015-01-02 by MUARN : pour intersite et intersoc
Local Integer WBETFCY, WBETCPY
If !clalev([F:PIH])   Local File PINVOICE  [PIH]   : Endif
If !clalev([F:PIHB])  Local File PINVOICE  [PIHB]  : Endif
If !clalev([F:PIDD])  Local File PINVOICED [PIDD]  : Endif
If !clalev([M:CST2])  Local Mask CSTLIN2   [CST2]  : Endif

Case LABR
    When "POH2"
         Raz [M:CSTO]
         WABREV = "CSTO"
         # Issue 105027 - 2015-01-02 by MUARN : intersite et intersoc
         WBETFCY = [M:POH0]BETFCY
         WBETCPY = [M:POH0]BETCPY
    When "PTH1"
         Raz [M:CSTT]
         WABREV = "CSTT"
         # Issue 105027 - 2015-01-02 by MUARN : intersite et intersoc
         WBETFCY = [M:PTH0]BETFCY
         WBETCPY = [M:PTH0]BETCPY
    When "PIH3"
         Raz [M:CSTI]
         WABREV = "CSTI"
         # Issue 105027 - 2015-01-02 by MUARN : intersite et intersoc
         WBETCPY = [M:PIH0]BETCPY
         If WBETCPY= 2
           WBETFCY = 2
         Else
           WBETFCY = 1
         Endif
    # Issue 110325 - 2015-10-27 by MAE : landed cost
    When "SHIP1"
         Raz [M:CSTS]
         WABREV = "CSTS"
         #pas d'expé sur les commandes intersoc et intersite
         WBETCPY = 1
         WBETFCY = 1

Endcase
Raz TOTAMTDOC, FCSCSTPURDOC, NONDEDTAXDOC, WAMTTAX, WDEDTAX, DISCRGAMTDOC, TOTCPRDOC, DISCRGAMTMINDOC, AMTFCCDOC
Raz TOTAMTSOC, FCSCSTPURSOC, NONDEDTAXSOC, WAMTTAX, WDEDTAX, DISCRGAMTSOC, TOTCPRSOC, DISCRGAMTMINSOC, AMTFCCSOC
Raz NONDEDTAXLIN, REACSTPURDOC, REACSTPURSOC

Assign  "[M:"+WABREV+"]CURSOC" With GLOCALDEV
Assign  "[M:"+WABREV+"]CURDOC" With GCUR

Assign  "[M:"+WABREV+"]WCHGCOE" With LCOURDEVISE
Assign  "[M:"+WABREV+"]WLABR"   With LABR
Assign  "[M:"+WABREV+"]WVCRNUM" With LVCRNUM
Assign  "[M:"+WABREV+"]WVCRTYP" With LVCRTYP

If [F:TCU]CUR<>evalue("[M:"+WABREV+"]CURSOC")
  Read [TCU]TCU0=evalue("[M:"+WABREV+"]CURSOC") : If fstat  Raz [F:TCU] : Endif
Endif
AROSOC = [F:TCU]CURRND
If [F:TCU]CUR<>evalue("[M:"+WABREV+"]CURDOC")
  Read [TCU]TCU0=evalue("[M:"+WABREV+"]CURDOC") : If fstat  Raz [F:TCU] : Endif
Endif
ARODOC = [F:TCU]CURRND

For I =0 To evalue("[M:"+LABR+"]NBLIG-1")
  # Montant des lignes
  If LABR <> "PIH3"
    TOTAMTDOC += evalue("[M:"+LABR+"]LINAMT(I)")
  Else
    TOTAMTDOC += evalue("[M:"+LABR+"]AMTNOTLIN(I)")
  Endif

  # Charges valorisées en stock
  FCSCSTPURSOC += evalue("[M:"+LABR+"]FCSCSTPUR(I)")

  # Cout achat réalisé
  If LABR = "POH2"
    REACSTPURSOC += evalue("[M:"+LABR+"]REACSTPUR(I)")
  Endif
  Raz NONDEDTAXLIN
  Raz DISCRGAMTDOC
  # Issue 110325 - 2015-10-27 by MAE : landed cost
  If LABR <> "SHIP1"
    # taxes non déductibles
    For J=1 To 3+4*(func TRTX3.ACTIV_PTX & evalue("dim([M:"+LABR+"]TAXRCP)")>0)
      Case J
        When 1
          WAMTTAX=evalue("[M:"+LABR+"]AMTTAXLIN1(I)")
          WDEDTAX=evalue("[M:"+LABR+"]DEDTAXLIN1(I)")
        When 2
          WAMTTAX=evalue("[M:"+LABR+"]AMTTAXLIN2(I)")
          WDEDTAX=evalue("[M:"+LABR+"]DEDTAXLIN2(I)")
        When 3
          WAMTTAX=evalue("[M:"+LABR+"]AMTTAXLIN3(I)")
          WDEDTAX=evalue("[M:"+LABR+"]DEDTAXLIN3(I)")
        When 4
          WAMTTAX=evalue("[M:"+LABR+"]AMTTAXRCP(I)")
          WDEDTAX=evalue("[M:"+LABR+"]DEDTAXRCP(I)")
        When 5
          WAMTTAX=evalue("[M:"+LABR+"]AMTTAXISS(I)")
          WDEDTAX=evalue("[M:"+LABR+"]DEDTAXISS(I)")
        When 6
          WAMTTAX=evalue("[M:"+LABR+"]AMTTAXOTH1(I)")
          WDEDTAX=evalue("[M:"+LABR+"]DEDTAXOTH1(I)")
        When 7
          WAMTTAX=evalue("[M:"+LABR+"]AMTTAXOTH2(I)")
          WDEDTAX=evalue("[M:"+LABR+"]DEDTAXOTH2(I)")
      Endcase
      NONDEDTAXDOC+=WAMTTAX-WDEDTAX
      NONDEDTAXLIN+=WAMTTAX-WDEDTAX
    Next J
 Endif

  # Montant frais  d'approche
  If evalue("[M:"+LABR+"]CPRCOE(I)") <> 1 | evalue("[M:"+LABR+"]CPRAMT(I)") <> 0
  # Issue 110325 - 2016-01-05 by MAE : Calcul du total de frais d'approche pour les expes sans éléments de facturation et sans taxes ded
  If LABR ="SHIP1"
    TOTCPRDOC += ([M:SHIP1]LINAMT(I) * [M:SHIP1]CPRCOE(I))-[M:SHIP1]LINAMT(I) + [M:SHIP1]CPRAMT(I) * [M:SHIP1]SHIQTYPUU(I)
  Else
    DISCRGAMTDOC+=evalue("[M:"+LABR+"]DISCRGAMT1(I)")
    DISCRGAMTDOC+=evalue("[M:"+LABR+"]DISCRGAMT2(I)")
    DISCRGAMTDOC+=evalue("[M:"+LABR+"]DISCRGAMT3(I)")
    DISCRGAMTDOC+=evalue("[M:"+LABR+"]DISCRGAMT4(I)")
    DISCRGAMTDOC+=evalue("[M:"+LABR+"]DISCRGAMT5(I)")
    DISCRGAMTDOC+=evalue("[M:"+LABR+"]DISCRGAMT6(I)")
    DISCRGAMTDOC+=evalue("[M:"+LABR+"]DISCRGAMT7(I)")
    DISCRGAMTDOC+=evalue("[M:"+LABR+"]DISCRGAMT8(I)")
    DISCRGAMTDOC+=evalue("[M:"+LABR+"]DISCRGAMT9(I)")

    If LABR <> "PIH3"
      # Issue 105027 - 2015-01-02 by MUARN : LINCSTPUR ne contient que la part coeff/cout ou SDC en intersite
      If WBETCPY=1 & WBETFCY=2
        If LCOURDEVISE = 1
          TOTCPRDOC += evalue("[M:"+LABR+"]LINCSTPUR(I)")
        Else
          TOTCPRDOC += evalue("[M:"+LABR+"]LINCSTPUR(I)")/LCOURDEVISE
        Endif
      Else
        If LCOURDEVISE = 1
          TOTCPRDOC += evalue("[M:"+LABR+"]LINCSTPUR(I)")-evalue("[M:"+LABR+"]LINAMT(I)")-DISCRGAMTDOC-NONDEDTAXLIN
        Else
          TOTCPRDOC += evalue("[M:"+LABR+"]LINCSTPUR(I)")/LCOURDEVISE-evalue("[M:"+LABR+"]LINAMT(I)")-DISCRGAMTDOC-NONDEDTAXLIN
        Endif
      Endif
    Else
      # Issue 105027 - 2015-01-02 by MUARN : LINCSTPUR ne contient que la part coeff/cout ou SDC en intersite
      If WBETCPY=1 & WBETFCY=2
        If LCOURDEVISE = 1
          TOTCPRDOC += evalue("[M:"+LABR+"]LINCSTPUR(I)")
        Else
          TOTCPRDOC += evalue("[M:"+LABR+"]LINCSTPUR(I)")/LCOURDEVISE
        Endif
      Else
        If LCOURDEVISE = 1
          TOTCPRDOC += evalue("[M:"+LABR+"]LINCSTPUR(I)")-evalue("[M:"+LABR+"]AMTNOTLIN(I)")-DISCRGAMTDOC-NONDEDTAXLIN
        Else
          TOTCPRDOC += evalue("[M:"+LABR+"]LINCSTPUR(I)")/LCOURDEVISE-evalue("[M:"+LABR+"]AMTNOTLIN(I)")-DISCRGAMTDOC-NONDEDTAXLIN
        Endif
      Endif
    Endif
   Endif # End issue 110325
  Endif

  # Factures complémentaires
  If LABR="POH2"
    LTYP =1
    LSEQ = 1
    LLIN = [M:POH2]POPLIN(I)
    LFCY = [M:POH0]POHFCY
    If [F:POQ]POHNUM <> LVCRNUM | [F:POQ]POPLIN <> LLIN | [F:POQ]POQSEQ <> LSEQ
      Read [POQ] POQ0=LVCRNUM;LLIN;LSEQ
    Endif
  Elsif LABR="PTH1"
    LTYP = 2
    LSEQ = 0
    LLIN = [M:PTH1]PTDLIN(I)
    LFCY = [M:PTH0]PRHFCY
    If [F:PTD]PTHNUM <> LVCRNUM | [F:PTD]PTDLIN <> LLIN
      Read [PTD] PTD0=LVCRNUM;LLIN
    Endif
  # Issue 110325 - 2015-10-28 by MAE : landed cost
  Elsif LABR="SHIP1"
    LTYP = 6
    LSEQ = 0
    LLIN = [M:SHIP1]SHIPLIN(I)
    If [F:POQ]POHNUM <> [F:SHD]POHNUM | [F:POQ]POPLIN <> [F:SHD]POPLIN | [F:POQ]POQSEQ <> [F:SHD]POQSEQ
      Read [POQ] POQ0=LVCRNUM;LLIN;LSEQ
    Endif
    LFCY = [F:POQ]PRHFCY
  Else
    LTYP=4
    LSEQ = 0
    LLIN = [M:PIH3]PIDLIN(I)
    LFCY = [M:PIH0]FCY
    If [F:PID]NUM <> LVCRNUM | [F:PID]PIDLIN <> LLIN
      Read [PID] PID0=LVCRNUM;LLIN
    Endif
  Endif
  If evalue("[M:"+LABR+"]LINTYP(I)")=1
    WRETOK = 0
    Call COST_ADDINV(LTYP,LVCRNUM,LLIN,LSEQ,LFCY,evalue("[M:"+LABR+"]ITMREF(I)"),LRET) From STCLIB
  Endif
  # Issue X3-25003 - 2018-03-26 by SR : si le document d'origine de la ligne de facture non présent sur le dossier
  If LRET = 99 & WRETOK = 0 : WRETOK = 1 : Endif
  AMTFCCSOC += sigma(J=0, [M:CST2]NBNONDET-1,[M:CST2]AMTNDTCPY(J))
Next
# Issue X3-25003 - 2018-03-26 by SR : si au moins un document d'origine non présent sur le dossier
If WRETOK = 1
   Local Integer OK
   Call MESSAGE(mess(587,194,1))From GESECRAN
Endif

# Issue 110325 - 2015-10-27 by MAE : landed cost
If LABR <> "SHIP1"
  # Eléments de facturation
  Raz DISCRGAMTSOC, DISCRGAMTDOC
  For I = 0 To evalue("[M:"+LABINV+"]NBFAC-1")
    Read [PFI] PFI0=evalue("[M:"+LABINV+"]INVDTA(I)") : If fstat Raz [F:PFI] : Endif
    If LABINV="POH3"
      If [F:PFI]INCDCR=1
        DISCRGAMTDOC +=evalue("[M:"+LABINV+"]INVORDAMT(I)")
      Else
        DISCRGAMTMINDOC +=evalue("[M:"+LABINV+"]INVORDAMT(I)")
      Endif
    Else
      If [F:PFI]INCDCR=1
        DISCRGAMTDOC +=evalue("[M:"+LABINV+"]INVDTAAMT(I)")
      Else
        DISCRGAMTMINDOC +=evalue("[M:"+LABINV+"]INVDTAAMT(I)")
      Endif
    Endif
  Next
Endif

# conversion devise société/devise document
TOTAMTSOC=TOTAMTDOC*LCOURDEVISE
FCSCSTPURDOC = FCSCSTPURSOC/LCOURDEVISE
DISCRGAMTSOC = DISCRGAMTDOC*LCOURDEVISE
DISCRGAMTMINSOC = DISCRGAMTMINDOC*LCOURDEVISE
TOTCPRSOC = TOTCPRDOC*LCOURDEVISE
NONDEDTAXSOC = NONDEDTAXDOC*LCOURDEVISE
AMTFCCDOC = AMTFCCSOC/LCOURDEVISE
REACSTPURDOC = REACSTPURSOC/LCOURDEVISE
WNBCST = evalue("[M:"+WABREV+"]NBCST")
# Montant ligne HT
Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(442,194,1)
# Issue 105027 - 2015-01-02 by MUARN : pas de montant ligne en inter-site
If WBETCPY = 1 & WBETFCY =2
  Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With 0
  Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With 0
Else
  Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With arr(TOTAMTDOC,ARODOC)
  Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With arr(TOTAMTSOC,AROSOC)
Endif
WNBCST+= 2
# Total charges directes
Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(443,194,1)
Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With arr(FCSCSTPURDOC,ARODOC)
Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With arr(FCSCSTPURSOC,AROSOC)
WNBCST+= 1
# Eléments de facturation en majoration
# Issue 110325 - 2015-10-30 by MAE : landed cost, pas d'éléments de facturation sur les expé
If LABR <> "SHIP1"
  Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(444,194,1)
  # Issue 105027 - 2015-01-02 by MUARN : pas d'élément de facturation en inter-site
  If WBETCPY = 1 & WBETFCY =2
    Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With 0
    Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With 0
  Else
    Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With arr(DISCRGAMTDOC,ARODOC)
    Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With arr(DISCRGAMTSOC,AROSOC)
  Endif
  WNBCST+= 1
Endif
# Montant frais d'approche
Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(445,194,1)
Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With arr(TOTCPRDOC,ARODOC)
Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With arr(TOTCPRSOC,AROSOC)
WNBCST+= 1
# Total facture complémentaires
Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(446,194,1)
Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With arr(AMTFCCDOC,ARODOC)
Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With arr(AMTFCCSOC,AROSOC)
WNBCST+= 1
# Total taxes non déductibles
# Issue 110325 - 2015-10-30 by MAE : landed cost, pas de taxes non déductibles sur les expé
If LABR <> "SHIP1"
  Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(447,194,1)
  # Issue 105027 - 2015-01-02 by MUARN : pas de taxes déductibles en inter-site
  If WBETCPY = 1 & WBETFCY =2
    Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With 0
    Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With 0
  Else
    Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With arr(NONDEDTAXDOC,ARODOC)
    Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With arr(NONDEDTAXSOC,AROSOC)
  Endif
  WNBCST+= 1
Endif
# Total des charges
Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(448,194,1)
# Issue 105027 - 2015-01-02 by MUARN : cas inter-site
# Issue 110325  en expé, on ne tient pas compte des éléments de facturation et des taxes non ded
If LABR = "SHIP1"
  Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")"
&        With arr(FCSCSTPURSOC + TOTCPRSOC + AMTFCCSOC,AROSOC)
Else
  If WBETCPY = 1 & WBETFCY =2
    Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")"
&        With arr(FCSCSTPURSOC + TOTCPRSOC + AMTFCCSOC,AROSOC)
    Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")"
&        With arr(FCSCSTPURDOC + TOTCPRDOC + AMTFCCDOC,ARODOC)
  Else
    Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")"
&        With arr(FCSCSTPURSOC + DISCRGAMTSOC + TOTCPRSOC + NONDEDTAXSOC + AMTFCCSOC,AROSOC)
    Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")"
&        With arr(FCSCSTPURDOC + DISCRGAMTDOC + TOTCPRDOC + NONDEDTAXDOC + AMTFCCDOC,ARODOC)
  Endif
Endif
# End issue 110325
WNBCST+= 2
# Total éléments de facturation minoration
# Issue 110325 - 2015-10-30 by MAE : landed cost, pas d'éléments de facturation sur les expé
If LABR <> "SHIP1"
  Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(450,194,1)
  # Issue 105027 - 2015-01-02 by MUARN : pas d'élément de facturation en inter-site
  If WBETCPY = 1 & WBETFCY =2
    Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With 0
    Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With 0
  Else
    Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With arr(DISCRGAMTMINSOC,AROSOC)
    Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With arr(DISCRGAMTMINDOC,ARODOC)
  Endif
  WNBCST+= 1
Endif
# Total coût achat
Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(449,194,1)
# Issue 105027 - 2015-01-02 by MUARN : cas inter-site
# Issue 110325 en expé, on ne tient pas compte des éléments de facturation et des taxes non ded
If LABR="SHIP1"
  Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(542,194,1)
  Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")"
&        With arr(TOTAMTSOC + FCSCSTPURSOC + TOTCPRSOC + AMTFCCSOC,AROSOC)
Else
  Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(449,194,1)
  If WBETCPY = 1 & WBETFCY =2
    Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")"
&        With arr(FCSCSTPURSOC + TOTCPRSOC + AMTFCCSOC,AROSOC)
    Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")"
&        With arr(FCSCSTPURDOC + TOTCPRDOC + AMTFCCDOC,ARODOC)
  Else
    Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")"
&        With arr(TOTAMTSOC + FCSCSTPURSOC + DISCRGAMTSOC + TOTCPRSOC + NONDEDTAXSOC + DISCRGAMTMINSOC + AMTFCCSOC,AROSOC)
    Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")"
&        With arr(TOTAMTDOC + FCSCSTPURDOC + DISCRGAMTDOC + TOTCPRDOC + NONDEDTAXDOC + DISCRGAMTMINDOC + AMTFCCDOC,ARODOC)
  Endif
Endif
# Issue 110325 end
WNBCST+= 2
If LABR ="POH2"
# Total coût achat réalisé
Assign  "[M:"+WABREV+"]LIB("+num$(WNBCST)+")" With mess(456,194,1)
Assign  "[M:"+WABREV+"]TOTSOC("+num$(WNBCST)+")" With arr(REACSTPURSOC,AROSOC)
Assign  "[M:"+WABREV+"]TOTDOC("+num$(WNBCST)+")" With arr(REACSTPURDOC,ARODOC)
WNBCST+= 2
Endif

Assign "[M:"+WABREV+"]NBCST" With WNBCST
Case WABREV
     When "CSTO"
           Affzo [M:CSTO]1-99
     When "CSTT"
           Affzo [M:CSTT]1-99
     When "CSTI"
           Affzo [M:CSTI]1-99
     When "CSTS"
           Affzo [M:CSTS]1-99
Endcase
End

#**------------------------------------------------------------------------<br/>
#* COST_ADDINV : Alimentation dans le bloc 4 de l'écran [CST2] des montants<br/>
#*               de factures complémentaires entrant dans le coût d'une<br/>
#*               ligne de document<br/>
#* Prérequis   : L'enregistrement de la ligne document à traiter est en ligne<br/>
#*               L'écran CSTLIN2 [CST2] est ouvert<br/>
#* Attention   : L'écran [CST2] est remis à zéro dans ce composant<br/>
#*               --> dans la visualisation des coûts à la ligne,<br/>
#*                   les frais d'approche et les éléments de facturation<br/>
#*                   doivent être alimentés après appel du composant<br/>
#* Paramètres :<br/>
#*   @param  LTYP  = Type document  1 = Commande<br/>
#*                                  2 = Réception<br/>
#*                                  4 = Facture<br/>
#*                                  6 = Expédition    : #--- Issue 110325<br/>
#*   @param  LNUM  = Numéro document<br/>
#*   @param  LLIN  = Ligne document<br/>
#*   @param  LLSEQ = Séquence document (uniquement si commande)<br/>
#*   @param  LFCY  = Site stock<br/>
#*   @param  LITM  = Article<br/>
#*   @param  LRET  = Code retour = 0 : OK<br/>
#*                               = 1 : Erreur écran CST2 non ouvert<br/>
#*                               = 2 : Erreur lecture enregistrement<br/>
#*                               = 3 : Tableau plein<br/>
#*   @param  Bloc4 de l'écran CSTLIN2 [CST2]<br/>
#*------------------------------------------------------------------------<br/>
#*!
Subprog COST_ADDINV(LTYP,LNUM,LLIN,LSEQ,LFCY,LITM,LRET)
Value    Integer LTYP
Value    Char    LNUM
Value    Integer LLIN
Value    Integer LSEQ
Value    Char    LFCY
Value    Char    LITM
Variable Integer LRET
#--- 110325
#------------------------------------------------------------------------
# Factures complémentaires prises en compte selon type document LTYP
#------------------------------------------------------------------------
# Ligne commande
#				FCC sur la commande
#				FCC sur les factures de la commande
# 			FCC sur les expéditions de la commande
#				FCC sur les réceptions de la commande
#				FCC sur les factures des réceptions de la commande
# Ligne expédition
#       FCC sur l'expédition
#       FCC sur les réceptions de l'expédition
#				FCC sur les factures des réceptions de l'expédition
#       FCC sur la commande à l'origine de l'expédition (avec proratisation)
#				FCC sur les factures de la commande à l'origine de l'expédition
#           (pour la qté non prise en compte par les factures des réceptions
#            de l'expédition et avec proratisation)
# Ligne réception
#       FCC sur la réception
#       FCC sur les facture de la réception
#       FCC sur l'expédition à l'origine de la réception (avec proratisation)
#       FCC sur la commande à l'origine de la réception (avec proratisation)
#       FCC sur les factures de la commande à l'origine de la réception
#           (pour la qté non prise en compte par les factures de la réception
#            et avec proratisation)
# Ligne facture de commande
#       FCC sur la facture
#       FCC sur la commande à l'origine de la facture (avec proratisation)
#       FCC sur les réceptions de la commande à l'origine de la facture
#           (couvertes par la facture de commande et avec proratisation)
#       FCC sur les expéditions de la commande à l'origine de la facture
#           (couvertes par la facture de commande et avec proratisation)
# Ligne facture de réception
#       FCC sur la facture
#       FCC sur la réception à l'origine de la facture (avec proratisation)
#       FCC sur l'expédition à l'origine de la réception à l'origine
#           de la facture (avec proratisation)
#       FCC sur la commande à l'origine de la facture (avec proratisation)
#------------------------------------------------------------------------
#--- End issue 110325
Local Integer I
Local Decimal WARR
# Quantité ligne de document origine
Local Decimal WQTYPUU
# Quantité facturée (factures de réception) de la ligne de réception origine
Local Decimal WPID_QTYPUU
# Quantité réceptionnée facturée à prendre en compte par une facture de cde
Local Decimal WQTYPUU_FAC
# Quantité facturées (facture de commande) restant à traiter
Local Decimal WQTYPUU_RES
#--- Issue 110325
# Quantité ligne document pour proratisation
Local Decimal WQTYPUUDIV
# Quantité facturée des lignes de réception de la ligne d'expédition origine
Local Decimal WPTD_INVQTYPUU
#--- End issue 110325

# Méthodes de proratisation des montants de factures complémentaires
Local Integer WCALC

LRET=0
If !clalev([M:CST2])
  LRET=1 : End
Endif

If !clalev([F:PIH])  Local File PINVOICE    [PIH]  : Endif
If !clalev([F:PIHA]) Local File PINVOICE    [PIHA] : Endif
If !clalev([F:PIHB]) Local File PINVOICE    [PIHB] : Endif
If !clalev([F:PID])  Local File PINVOICED   [PID]  : Endif
If !clalev([F:PIDA]) Local File PINVOICED   [PIDA] : Endif
If !clalev([F:PIDB]) Local File PINVOICED   [PIDB] : Endif
If !clalev([F:PIDC]) Local File PINVOICED   [PIDC] : Endif
If !clalev([F:POQ])  Local File PORDERQ     [POQ]  : Endif
If !clalev([F:PTD])  Local File PRECEIPTD   [PTD]  : Endif
If !clalev([F:TCU])  Local File TABCUR      [TCU]  : Endif
If !clalev([F:ITF])  Local File ITMFACILIT  [ITF]  : Endif
If !clalev([F:TCM])  Local File TABCOSTMET  [TCM]  : Endif
#--- Issue 110325
If !clalev([F:SHD])  Local File SHIPMENTD   [SHD]  : Endif

# Nb décimales devise société
If [F:TCU]CUR<>GLOCALDEV
  Read [TCU]TCU0=GLOCALDEV
  If fstat
    Call RSTA ("TCU",GLOCALDEV) From GLOCK
    LRET=2 : End
  Endif
Endif
WARR = [F:TCU]CURRND

# Si facture diverse pas de valorisation
If LTYP=4 & [F:PID]TYPORI=5
  [F:TCM]PRIREG=1
Else
  # Issue 121487 - 2017-02-17 by SR : Si on vient des réceptions, TCM déjà chargé, ne pas écraser la valeur de PRIREG
  #[F:TCM]PRIREG=1
  If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
    Read [ITF]ITF0=LITM;LFCY
    If fstat Raz [F:ITF] Endif
  Endif
  If [F:TCM]VLTCOD<>[F:ITF]VLTCOD
    Read [TCM] TCM0=[F:ITF]VLTCOD
    # Issue 121487 - 2017-02-17 by SR
    If fstat : [F:TCM]PRIREG=1 : Endif
  Endif
Endif

# Raz de l'écran de stockage des montants factures complémentaires
[M:CST2]NBNONDET=0
I=0

# Alimentation Quantité en UA ligne document origine
Case LTYP
 When 1 : WQTYPUU=[F:POQ]QTYPUU
 When 2 : WQTYPUU=[F:PTD]QTYPUU
 When 4 : WQTYPUU=[F:PID]QTYPUU
 When 6 : WQTYPUU=[F:SHD]SHIQTYPUU   : #--- Issue 110325
Endcase

# Traitement des factures complémentaires de la ligne de document
# et avoirs sur ces factures complémentaires
#   si LTYP=1 : factures complémentaires de la ligne de commande
#   si LTYP=2 : factures complémentaires de la ligne de réception
#   si LTYP=4 : factures complémentaires de la ligne de facture
#   si LTYP=6 : factures complémentaires de la ligne d'expédition  : #--- Issue 110325
Gosub FCC_POQPTDPID
If LRET>0 End Endif

# Traitement des factures complémentaires des factures de la ligne de document
# et avoirs sur ces factures complémentaires
#   si LTYP=1 : factures complémentaires des factures de la ligne de commande
#   si LTYP=2 : factures complémentaires des factures de la ligne de réception
If LTYP<3
  Gosub FCC_PID_POQPTD
  If LRET>0 End Endif
Endif

# Traitement des factures complémentaires de la ligne de document
Case LTYP
 When 1 : Gosub TRT_POQ
 When 2 : Gosub TRT_PTD
 When 4 : If [F:PID]TYPORI=1
            Gosub TRT_PID1
          Elsif [F:PID]TYPORI=2
            Gosub TRT_PID2
          Endif
 When 6 : Gosub TRT_SHD        : #--- Issue 110325
Endcase

If LRET>0 End Endif

End

#-----------------------------------------------------------------------------
# Factures complémentaires de la ligne de document et avoirs sur ces factures
#-----------------------------------------------------------------------------
$FCC_POQPTDPID
# Factures complémentaires de la ligne de document
Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
Filter [LNK] Where TYPORI=LTYP & NUMORI=LNUM & LINORI=LLIN & SEQORI=LSEQ & PIHTYP=2
&                & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
# Traitement des factures complémentaires et avoirs sur celles-ci
WCALC=0
Gosub FCCACC
Filter [LNK]

Return

#-----------------------------------------------------------------------------
# Factures complémentaires des factures de la ligne de document et avoirs
# sur ces factures
#-----------------------------------------------------------------------------
$FCC_PID_POQPTD
Raz WPID_QTYPUU
# Lignes factures de la ligne de document
Filter [PIDC] Where TYPORI=LTYP & NUMORI=LNUM & LINORI=LLIN & SEQORI=LSEQ & PIHTYP=1
&             Order By Key PID1
For [PIDC]
  # Si origine réception, cumul de la quantité facturée de la ligne de réception
  If LTYP=2 WPID_QTYPUU+=[F:PIDC]QTYPUU Endif
  # Factures complémentaires des lignes factures de la ligne document
  Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
  Filter [LNK] Where TYPORI=4 & NUMORI=[F:PIDC]NUM & LINORI=[F:PIDC]PIDLIN & PIHTYP=2
&                  & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
  # Traitement des factures complémentaires et avoirs sur celles-ci
  WCALC=0
  Gosub FCCACC
  Filter [LNK]
  If LRET>0 Break Endif
Next
Filter [PIDC]

Return

#-----------------------------------------------------------------------------
# L'origine est une ligne de commande
#-----------------------------------------------------------------------------
$TRT_POQ
#--- Issue 110325
#--- Lignes d'expéditions de la ligne de commande
Filter [SHD] Where POHNUM=LNUM & POPLIN=LLIN & POQSEQ=LSEQ Order By Key SHD2
For [SHD]
  # Factures complémentaires de la ligne d'expédition
  Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
  Filter [LNK] Where TYPORI=6 & NUMORI=[F:SHD]SHIPNUM & LINORI=[F:SHD]SHIPLIN & PIHTYP=2
&                  & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
  # Traitement des factures complémentaires et avoirs sur celles-ci
  WCALC=0
  Gosub FCCACC
  Filter [LNK]
  If LRET>0 Break Endif
Next
Filter [SHD]
#--- End issue 110325

#--- Lignes de réceptions de la ligne de commande
Filter [PTD] Where POHNUM=LNUM & POPLIN=LLIN & POQSEQ=LSEQ Order By Key PTD2
For [PTD]
  # Factures complémentaires de la ligne de réception
  Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
  Filter [LNK] Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN & PIHTYP=2
&                  & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
  # Traitement des factures complémentaires et avoirs sur celles-ci
  WCALC=0
  Gosub FCCACC
  Filter [LNK]
  If LRET>0 Break Endif

  #--- Lignes de factures de la ligne de réception
  Filter [PIDC] Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN & PIHTYP=1
&               Order By Key PID1
  For [PIDC]
    # Factures complémentaires de la ligne de facture
    Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
    Filter [LNK] Where TYPORI=4 & NUMORI=[F:PIDC]NUM & LINORI=[F:PIDC]PIDLIN & PIHTYP=2
&                    & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
    # Traitement des factures complémentaires et avoirs sur celles-ci
    WCALC=0
    Gosub FCCACC
    Filter [LNK]
    If LRET>0 Break Endif
  Next
  Filter [PIDC]
  If LRET>0 Break Endif
Next
Filter [PTD]

Return

#--- Issue 110325
#-----------------------------------------------------------------------------
# L'origine est une ligne d'expédition
#-----------------------------------------------------------------------------
$TRT_SHD
Raz WPID_QTYPUU, WPTD_INVQTYPUU
#--- Lignes de réceptions de la ligne d'expédition
Filter [PTD] Where SHIPNUM=LNUM & SHIPLIN=LLIN Order By SHIPNUM;SHIPLIN
For [PTD]
  WPTD_INVQTYPUU+=[F:PTD]INVQTYPUU
  # Factures complémentaires de la ligne de réception
  Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
  Filter [LNK] Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN & PIHTYP=2
&                  & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
  # Traitement des factures complémentaires et avoirs sur celles-ci
  WCALC=0
  Gosub FCCACC
  Filter [LNK]
  If LRET>0 Break Endif

  #--- Lignes de factures de la ligne de réception
  Filter [PIDC] Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN & PIHTYP=1
&               Order By Key PID1
  For [PIDC]
    WPID_QTYPUU+=[F:PIDC]QTYPUU
    # Factures complémentaires de la ligne de facture
    Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
    Filter [LNK] Where TYPORI=4 & NUMORI=[F:PIDC]NUM & LINORI=[F:PIDC]PIDLIN & PIHTYP=2
&                    & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
    # Traitement des factures complémentaires et avoirs sur celles-ci
    WCALC=0
    Gosub FCCACC
    Filter [LNK]
    If LRET>0 Break Endif
  Next
  Filter [PIDC]
  If LRET>0 Break Endif
Next
Filter [PTD]

If [F:SHD]POHNUM="" Return Endif
#--- Ligne de commande de la ligne d'expédition
Read [POQ]POQ0=[F:SHD]POHNUM;[F:SHD]POPLIN;[F:SHD]POQSEQ
If fstat
  # Issue X3-25003 - 2018-03-23 by SR : changer le message
  #Call RSTA ("POQ",[F:SHD]POHNUM-num$([F:SHD]POPLIN)-num$([F:SHD]POQSEQ)) From GLOCK
  #LRET=2 : Return
  LRET=99 : Return
Endif
# Factures complémentaires de la ligne de commande
Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
Filter [LNK] Where TYPORI=1 & NUMORI=[F:POQ]POHNUM & LINORI=[F:POQ]POPLIN &
&                  SEQORI=[F:POQ]POQSEQ & PIHTYP=2 & CSTMAJLIN=2 & [F:PIHA]STA=3
&                  Order By Key PID1
# Si la qté expédiée est < à la qté commandée, il y a proratisation
If WQTYPUU<[F:POQ]QTYPUU
  #--- Issue 110325
  WQTYPUUDIV=[F:POQ]QTYPUU
  WCALC=1
Else
  WCALC=0
Endif
# Traitement des factures complémentaires et avoirs sur celles-ci
Gosub FCCACC
Filter [LNK]
If LRET>0 Return Endif

# Quantité réceptionnée facturée restant à prendre en compte par les factures de la cde
WQTYPUU_FAC=max(0,WPTD_INVQTYPUU-WPID_QTYPUU)
# Toute la quantité facturée des réceptions de l'expédition l'a été
# par des factures de ces réceptions
If WQTYPUU_FAC=0 Return Endif
#--- Lignes de factures de la ligne de commande
Filter [PIDC] Where TYPORI=1 & NUMORI=[F:POQ]POHNUM & LINORI=[F:POQ]POPLIN &
&                   SEQORI=[F:POQ]POQSEQ & PIHTYP=1
&             Order By Key PID1
For [PIDC]
  # Factures complémentaires des lignes factures de la ligne document
  Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
  Filter [LNK] Where TYPORI=4 & NUMORI=[F:PIDC]NUM & LINORI=[F:PIDC]PIDLIN & PIHTYP=2
&                  & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
  # Traitement des factures complémentaires et avoirs sur celles-ci
  WCALC=2
  Gosub FCCACC
  Filter [LNK]
  If LRET>0 Break Endif

  # Maj de la quantité facturée restant à traiter
  If WQTYPUU_FAC<=[F:PIDC]QTYPUU
    WQTYPUU_FAC=0
  Else
    WQTYPUU_FAC-=[F:PIDC]QTYPUU
  Endif
  If WQTYPUU_FAC=0 Break Endif
Next
Filter [PIDC]

Return
#--- End issue 110325

#-----------------------------------------------------------------------------
# L'origine est une ligne de réception
#-----------------------------------------------------------------------------
$TRT_PTD
#--- Issue 110325
#--- Ligne d'expédition de la ligne de réception
If [F:PTD]SHIPNUM<>""
  Read [SHD]SHD0=[F:PTD]SHIPNUM;[F:PTD]SHIPLIN
  If fstat
    Call RSTA ("SHD",[F:PTD]SHIPNUM-num$([F:PTD]SHIPLIN)) From GLOCK
    LRET=2 : Return
  Endif
  # Factures complémentaires de la ligne d'expédition
  Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
  Filter [LNK] Where TYPORI=6 & NUMORI=[F:SHD]SHIPNUM & LINORI=[F:SHD]SHIPLIN &
&                    PIHTYP=2 & CSTMAJLIN=2 & [F:PIHA]STA=3
&                    Order By Key PID1
  # Si la qté réceptionnée est < à la qté expédiée, il y a proratisation
  If WQTYPUU<[F:SHD]SHIQTYPUU
    WQTYPUUDIV=[F:SHD]SHIQTYPUU
    WCALC=1
  Else
    WCALC=0
  Endif
  # Traitement des factures complémentaires et avoirs sur celles-ci
  Gosub FCCACC
  Filter [LNK]
  If LRET>0 Return Endif
Endif
#--- End issue 110325

If [F:PTD]POHNUM="" Return Endif
#--- Ligne de commande de la ligne de réception
Read [POQ]POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
If fstat
  # Issue X3-25003 - 2018-03-23 by SR : Changer le message
  #Call RSTA ("POQ",[F:PTD]POHNUM-num$([F:PTD]POPLIN)-num$([F:PTD]POQSEQ)) From GLOCK
  #LRET=2 : Return
  LRET=99 : Return
Endif
# Factures complémentaires de la ligne de commande
Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
Filter [LNK] Where TYPORI=1 & NUMORI=[F:POQ]POHNUM & LINORI=[F:POQ]POPLIN &
&                  SEQORI=[F:POQ]POQSEQ & PIHTYP=2 & CSTMAJLIN=2 & [F:PIHA]STA=3
&                  Order By Key PID1
# Si la qté réceptionnée est < à la qté commandée, il y a proratisation
If WQTYPUU<[F:POQ]QTYPUU
  #--- Issue 110325
  WQTYPUUDIV=[F:POQ]QTYPUU
  WCALC=1
Else
  WCALC=0
Endif
# Traitement des factures complémentaires et avoirs sur celles-ci
Gosub FCCACC
Filter [LNK]
If LRET>0 Return Endif

# Quantité réceptionnée facturée restant à prendre en compte par les factures de la cde
WQTYPUU_FAC=max(0,[F:PTD]INVQTYPUU-WPID_QTYPUU)
# Toute la quantité facturée de la réception l'a été par des factures de cette réception
If WQTYPUU_FAC=0 Return Endif
#--- Lignes de factures de la ligne de commande
Filter [PIDC] Where TYPORI=1 & NUMORI=[F:POQ]POHNUM & LINORI=[F:POQ]POPLIN &
&                   SEQORI=[F:POQ]POQSEQ & PIHTYP=1
&             Order By Key PID1
For [PIDC]
  # Factures complémentaires des lignes factures de la ligne document
  Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
  Filter [LNK] Where TYPORI=4 & NUMORI=[F:PIDC]NUM & LINORI=[F:PIDC]PIDLIN & PIHTYP=2
&                  & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
  # Traitement des factures complémentaires et avoirs sur celles-ci
  WCALC=2
  Gosub FCCACC
  Filter [LNK]
  If LRET>0 Break Endif

  # Maj de la quantité facturée restant à traiter
  If WQTYPUU_FAC<=[F:PIDC]QTYPUU
    WQTYPUU_FAC=0
  Else
    WQTYPUU_FAC-=[F:PIDC]QTYPUU
  Endif
  If WQTYPUU_FAC=0 Break Endif

Next
Filter [PIDC]

Return

#-----------------------------------------------------------------------------
# L'origine est une ligne de facture issue d'une ligne de commande
#-----------------------------------------------------------------------------
$TRT_PID1

WQTYPUU_RES = WQTYPUU
#--- Ligne de commande de la ligne de facture
Read [POQ]POQ0=[F:PID]POHNUM;[F:PID]POPLIN;[F:PID]POQSEQ
If fstat
  # Issue X3-25003 - 2018-03-23 by SR : Changer le message
  #Call RSTA ("POQ",[F:PID]POHNUM-num$([F:PID]POPLIN)-num$([F:PID]POQSEQ)) From GLOCK
  #LRET=2 : Return
  LRET=99 : Return
Endif
# Factures complémentaires de la ligne de commande
Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
Filter [LNK] Where TYPORI=1 & NUMORI=[F:POQ]POHNUM & LINORI=[F:POQ]POPLIN &
&                  SEQORI=[F:POQ]POQSEQ & PIHTYP=2 & CSTMAJLIN=2 & [F:PIHA]STA=3
&                  Order By Key PID1
# Si la qté facturée est < à la qté commandée, il y a proratisation
If WQTYPUU<[F:POQ]QTYPUU
  #--- Issue 110325
  WQTYPUUDIV=[F:POQ]QTYPUU
  WCALC=1
Else
  WCALC=0
Endif
# Traitement des factures complémentaires et avoirs sur celles-ci
Gosub FCCACC
Filter [LNK]
If LRET>0 Return Endif

#--- Lignes de réceptions de la ligne de commande
Filter [PTD] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
&            Order By Key PTD2
For [PTD]

  Raz WPID_QTYPUU
  # Lignes factures de la ligne de réception
  Filter [PIDC] Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN & PIHTYP=1
&               Order By Key PID1
  For [PIDC]
    # Cumul de la quantité facturée de la ligne de réception
    #--- Issue 95710
    #WPID_QTYPUU+=[F:PID]QTYPUU
    WPID_QTYPUU+=[F:PIDC]QTYPUU
    #---
  Next
  Filter [PIDC]

  # Quantité réceptionnée facturée restant à prendre en compte par les factures de la cde
  WQTYPUU_FAC=max(0,[F:PTD]INVQTYPUU-WPID_QTYPUU)
  # Il reste de la quantité facturée de la réception à prendre en compte par la facture
  If WQTYPUU_FAC>0
    WQTYPUU_FAC=min(WQTYPUU_RES,WQTYPUU_FAC)
    # Factures complémentaires de la ligne de réception
    Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
    Filter [LNK] Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN & PIHTYP=2
&                    & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
    #--- Issue 110325
    WQTYPUUDIV=[F:PTD]QTYPUU
    WCALC=4
    # Traitement des factures complémentaires et avoirs sur celles-ci
    Gosub FCCACC
    Filter [LNK]
    If LRET>0 Break Endif

		#--- Issue 110325
		# Ligne d'expédition à l'origine de la ligne de réception
		If [F:PTD]SHIPNUM<>""
  		Read [SHD]SHD0=[F:PTD]SHIPNUM;[F:PTD]SHIPLIN
  		If fstat
    		Call RSTA ("SHD",[F:PTD]SHIPNUM-num$([F:PTD]SHIPLIN)) From GLOCK
    		LRET=2 : Return
  		Endif
  		# Factures complémentaires de la ligne d'expédition
  		Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
  		Filter [LNK] Where TYPORI=6 & NUMORI=[F:SHD]SHIPNUM & LINORI=[F:SHD]SHIPLIN &
&     		               PIHTYP=2 & CSTMAJLIN=2 & [F:PIHA]STA=3
&         		           Order By Key PID1
      WQTYPUUDIV=[F:SHD]SHIQTYPUU
      WCALC=4
      # Traitement des factures complémentaires et avoirs sur celles-ci
      Gosub FCCACC
      Filter [LNK]
      If LRET>0 Break Endif
    Endif
    # Maj de la quantité facturée restant à traiter
    #If WQTYPUU_FAC<=[F:PTD]QTYPUU
    #  WQTYPUU_FAC=0
    #Else
    #  WQTYPUU_FAC-=[F:PTD]QTYPUU
    #Endif
    #If WQTYPUU_RES<=[F:PTD]QTYPUU
    #  WQTYPUU_RES=0
    #Else
    #  WQTYPUU_RES-=[F:PTD]QTYPUU
    #Endif
    If WQTYPUU_RES<=WQTYPUU_FAC
      WQTYPUU_RES = 0
    Else
      WQTYPUU_RES-= WQTYPUU_FAC
    Endif
    #--- End issue 110325

    #--- Issue 95710
    #If WQTYPUU_FAC=0 | WQTYPUU_RES=0 Break Endif
    If WQTYPUU_RES=0 Break Endif
    #---
  Endif
Next
Filter [PTD]

Return

#-----------------------------------------------------------------------------
# L'origine est une ligne de facture issue d'une ligne de réception
#-----------------------------------------------------------------------------
$TRT_PID2
#--- Ligne de réception de la ligne de facture
Read [PTD]PTD0=[F:PID]NUMORI;[F:PID]LINORI
If fstat
  # Issue X3-25003 - 2018-03-23 by SR : changer le message
  #Call RSTA ("PTD",[F:PID]NUMORI-num$([F:PID]LINORI)) From GLOCK
  #LRET=2 : Return
  LRET = 99
Endif
# Factures complémentaires de la ligne de réception
Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
Filter [LNK] Where TYPORI=2 & NUMORI=[F:PID]NUMORI & LINORI=[F:PID]LINORI & PIHTYP=2
&                & CSTMAJLIN=2 & [F:PIHA]STA=3 Order By Key PID1
# Si la qté facturée est < à la qté réceptionnée, il y a proratisation
If WQTYPUU<[F:PTD]QTYPUU
  #--- Issue 110325
  WQTYPUUDIV=[F:PTD]QTYPUU
  WCALC=1
  #WCALC=3
  #--- End issue 110325
Else
  WCALC=0
Endif
# Traitement des factures complémentaires et avoirs sur celles-ci
Gosub FCCACC
Filter [LNK]
If LRET>0 Return Endif

#--- Issue 110325
#--- Ligne d'expédition de la ligne de réception
If [F:PTD]SHIPNUM<>""
  Read [SHD]SHD0=[F:PTD]SHIPNUM;[F:PTD]SHIPLIN
  If fstat
    # Issue X3-25003 - 2018-03-23 by SR : Changer le message
    #Call RSTA ("SHD",[F:PTD]SHIPNUM-num$([F:PTD]SHIPLIN)) From GLOCK
    #LRET=2 : Return
    LRET=99 : Return
  Endif
  # Factures complémentaires de la ligne d'expédition
  Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
  Filter [LNK] Where TYPORI=6 & NUMORI=[F:SHD]SHIPNUM & LINORI=[F:SHD]SHIPLIN &
&                    PIHTYP=2 & CSTMAJLIN=2 & [F:PIHA]STA=3
&                    Order By Key PID1
  # Si la qté réceptionnée est < à la qté expédiée, il y a proratisation
  If WQTYPUU<[F:SHD]SHIQTYPUU
    WQTYPUUDIV=[F:SHD]SHIQTYPUU
    WCALC=1
  Else
    WCALC=0
  Endif
  # Traitement des factures complémentaires et avoirs sur celles-ci
  Gosub FCCACC
  Filter [LNK]
  If LRET>0 Return Endif
Endif
#--- End issue 110325

If [F:PTD]POHNUM="" Return Endif
#--- Ligne de commande de la ligne de réception
Read [POQ]POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
If fstat
  # Issue X3-25003 - 2018-03-23 by SR : Changer le message
  #Call RSTA ("POQ",[F:PTD]POHNUM-num$([F:PTD]POPLIN)-num$([F:PTD]POQSEQ)) From GLOCK
  #LRET=2 : Return
  LRET=99 : Return
Endif
# Factures complémentaires de la ligne de commande
Link [PIDA] With [PIHA]PIH0=[F:PIDA]NUM As [LNK]
Filter [LNK] Where TYPORI=1 & NUMORI=[F:POQ]POHNUM & LINORI=[F:POQ]POPLIN &
&                  SEQORI=[F:POQ]POQSEQ & PIHTYP=2 & CSTMAJLIN=2 & [F:PIHA]STA=3
&                  Order By Key PID1
# Si la qté facturée est < à la qté commandée, il y a proratisation
If WQTYPUU<[F:POQ]QTYPUU
  #--- Issue 110325
  WQTYPUUDIV=[F:POQ]QTYPUU
  WCALC=1
Else
  WCALC=0
Endif
# Traitement des factures complémentaires et avoirs sur celles-ci
Gosub FCCACC
Filter [LNK]

Return

#-----------------------------------------------------------------------------
# Gestion générique des factures complémentaires et avoirs sur celles-ci
#-----------------------------------------------------------------------------
$FCCACC
For [LNK]
  # Issue 121755 - 2017-03-16 by MUARN : indice incorrect
  If I>dim([M:CST2]NDTLOD)-1
    Call ERREUR(mess(26,100,1)) From GESECRAN : LRET=3 : Break
  Endif
  [M:CST2]NDTLOD(I)    = [F:PIDA]NUM
  [M:CST2]NDTLODTYP(I) = mess(2,533,1)
  [M:CST2]CURDOC3(I)   = [F:PIDA]NETCUR
  [M:CST2]CURCPY3(I)   = GLOCALDEV

  If WCALC=0
    # Pas de proratisation
    [M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN
  Elsif WCALC=1
    #--- Issue 110325
    # Proratisation de la qté de la pièce origine par rapport à la qté cdée, expé ou rcp
    #[M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN*WQTYPUU/[F:POQ]QTYPUU
    [M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN*WQTYPUU/WQTYPUUDIV
    #---
  Elsif WCALC=2
    # La quantité facturée restant à traiter est inférieure à la quantité facturée
    If WQTYPUU_FAC<=[F:PIDC]QTYPUU
      [M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN*WQTYPUU_FAC/[F:PIDC]QTYPUU
    Else
      [M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN
    Endif
  #--- Issue 110325
  #Elsif WCALC=3
  #  # Proratisation de la qté facturée par rapport à la qté réceptionnée
  #  [M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN*WQTYPUU/[F:PTD]QTYPUU
  #--- End issue 110325
  Elsif WCALC=4
    #--- Issue 110325
    # La quantité facturée restant à traiter est < à la quantité expédiée ou réceptionnée
    #If WQTYPUU_FAC<=[F:PTD]QTYPUU
    If WQTYPUU_FAC<=WQTYPUUDIV
      # Proratisation de la qté de la pièce origine par rapport à la qté cdée, expé ou rcp
      #[M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN*WQTYPUU_FAC/[F:PTD]QTYPUU
      [M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN*WQTYPUU/WQTYPUUDIV
    #--- End issue 110325
    Else
      [M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN
    Endif
  Endif

  # Si devise facture complémentaire et devise société identique
  If [F:PIDA]NETCUR=GLOCALDEV
    [M:CST2]AMTNDTCPY(I) = [M:CST2]AMTNDTDOC(I)
  Else
    [M:CST2]AMTNDTCPY(I) = arr([M:CST2]AMTNDTDOC(I)*[F:PIHA]RATMLT(GTYPGEN-1)/[F:PIHA]RATDIV(GTYPGEN-1),WARR)
  Endif
  [M:CST2]STKVLTNDT(I) = [F:TCM]PRIREG
  I+=1
  [M:CST2]NBNONDET+=1
  # Avoirs de la facture complémentaire
  Link [PIDB] With [PIHB]PIH0=[F:PIDB]NUM As [LNK2]
  Filter [LNK2] Where TYPORI=4 & NUMORI=[F:PIDA]NUM & LINORI=[F:PIDA]PIDLIN
&                   & PIHTYP=3 & [F:PIHB]STA=3 Order By Key PID1
  For [LNK2]
    # Issue 121755 - 2017-03-16 by MUARN : indice incorrect
    If I>dim([M:CST2]NDTLOD)-1
      Call ERREUR(mess(26,100,1)) From GESECRAN : LRET=3 : Break
    Endif
    [M:CST2]NDTLOD(I)    = [F:PIDB]NUM
    [M:CST2]NDTLODTYP(I) = mess(3,533,1)
    [M:CST2]CURDOC3(I)   = [F:PIDB]NETCUR
    [M:CST2]CURCPY3(I)   = GLOCALDEV

    If WCALC=0
      # Pas de proratisation
      [M:CST2]AMTNDTDOC(I) = [F:PIDB]AMTNOTLIN
    Elsif WCALC=1
      # Proratisation de la qté réceptionnée par rapport à la qté commandée ou expédiée
      #--- Issue 110325
      #[M:CST2]AMTNDTDOC(I) = [F:PIDB]AMTNOTLIN*WQTYPUU/[F:POQ]QTYPUU
      [M:CST2]AMTNDTDOC(I) = [F:PIDB]AMTNOTLIN*WQTYPUU/WQTYPUUDIV
      #---
    Elsif WCALC=2
      # La quantité facturée restant à traiter est inférieure à la quantité facturée
      If WQTYPUU_FAC<=[F:PIDC]QTYPUU
        [M:CST2]AMTNDTDOC(I) = [F:PIDB]AMTNOTLIN*WQTYPUU_FAC/[F:PIDC]QTYPUU
      Else
        [M:CST2]AMTNDTDOC(I) = [F:PIDB]AMTNOTLIN
      Endif
    #--- Issue 110325
    #Elsif WCALC=3
    #  # Proratisation de la qté facturée par rapport à la qté réceptionnée
    #  [M:CST2]AMTNDTDOC(I) = [F:PIDB]AMTNOTLIN*WQTYPUU/[F:PTD]QTYPUU
    #--- End issue 110325
    Elsif WCALC=4
      #--- Issue 110325
      # La quantité facturée restant à traiter est < à la quantité expédiée ou réceptionnée
      #If WQTYPUU_FAC<=[F:PTD]QTYPUU
      If WQTYPUU_FAC<=WQTYPUUDIV
        # Proratisation de la qté de la pièce origine par rapport à la qté cdée, expé ou rcp
        #[M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN*WQTYPUU_FAC/[F:PTD]QTYPUU
        [M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN*WQTYPUU/WQTYPUUDIV
      #---
      Else
        [M:CST2]AMTNDTDOC(I) = [F:PIDA]AMTNOTLIN
      Endif
    Endif

    #--- Issue 95710 (Avoir)
    [M:CST2]AMTNDTDOC(I)*=(-1)

    # Si devise avoir et devise société identique
    If [F:PIDB]NETCUR=GLOCALDEV
      [M:CST2]AMTNDTCPY(I) = [M:CST2]AMTNDTDOC(I)
    Else
      [M:CST2]AMTNDTCPY(I) = arr([M:CST2]AMTNDTDOC(I)*[F:PIHB]RATMLT(GTYPGEN-1)/[F:PIHB]RATDIV(GTYPGEN-1),WARR)
    Endif
    [M:CST2]STKVLTNDT(I) = [F:TCM]PRIREG
    I+=1
    [M:CST2]NBNONDET+=1
  Next
  Filter [LNK2]

  If LRET>0 Break Endif
Next

Return

#--- 111257
########################################################################
# CAL_LEADTIME : Recherche du délai à appliquer entre deux lieux pour
#                calcul date arrivée/réception du lieu destination
#                Le délai de libération est celui du lieu de destination
########################################################################
# Prérequis    :
########################################################################
# Paramètres E : LTYP  = Type de calcul : 1 = Arrivée prévue (expédition)
#                                         2 = Réception prévue (expédition)
#                LDPE  = Lieu départ
#                LARV  = Lieu arrivée
#                LBPT  = Transporteur
#                LTRN  = Mode transport
# Paramètres S : LLTI  = Délai acheminement
########################################################################
Subprog CAL_LEADTIME(LTYP,LDPE,LARV,LBPT,LTRN,LLTI)
Value    Integer LTYP
Value    Char    LDPE
Value    Char    LARV
Value    Char    LBPT
Value    Integer LTRN
Variable Integer LLTI

#--- Les délais de libération sont gérés avec TABPLACE et pas TABRELTIME (à confirmer)
Local File TABPLACETIME [TPCT]
Local File TABPLACE     [TPC]
LLTI=0

# Type de calcul nécessaire
If LTYP<>1 & LTYP<>2 End Endif
# Lieux départ et arrivée nécessaires
If LDPE="" | LARV="" End Endif

GPOINT="PARAM_LTI" : Gosub ENTREE From EXEFNC
#--- Recherche avec transporteur et mode de transport
Read [TPCT]TPCT0=LDPE;LARV;LTRN;LBPT
If !fstat
  LLTI = [F:TPCT]LTITPC
Else
  #--- Recherche avec transporteur
  Read [TPCT]TPCT0=LDPE;LARV;6;LBPT
  If !fstat
    LLTI = [F:TPCT]LTITPC
  Else
    #--- Recherche avec mode de transport
    Read [TPCT]TPCT0=LDPE;LARV;LTRN;""
    If !fstat
      LLTI = [F:TPCT]LTITPC
    Else
      #--- Recherche sans transporteur et sans mode de transport
      Read [TPCT]TPCT0=LDPE;LARV;6;""
      If !fstat
        LLTI = [F:TPCT]LTITPC
      Endif
    Endif
  Endif
Endif
# S'il existe, ajout du délai de libération du lieu de destination
Read [TPC]TPC0=LARV
If !fstat
  LLTI += [F:TPC]LTITPC
Endif

End
#---

