#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################
# Action SAIPREC             Saisie des critères du plan de préparation #
#########################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
Endcase
Return

#########################################################################
$DEBUT

Raz [M:PREC]

Transmask [M:PREP] To [M:PREC]# Issue 25606[M:PREC]=[M:PREP]

If [M:PREP]FLG1<>2 & [M:PREP]FLG2<>2
   Grizo [M:PREC]SOHNUMSTR,SOHNUMEND,DLVPIOSTR,DLVPIOEND,BPTSTR,BPTEND,FOR1
Endif
If [M:PREP]FLG3<>2
   Grizo [M:PREC]FOR2
Endif
If [M:PREP]FLG4<>2
   Grizo [M:PREC]FOR3
Endif

Affzo [M:PREC]1-99

Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return
#########################################################################
$ENR

[M:PREP]=[M:PREC]

GOK = 1
FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return

#########################################################################

Subprog AM_BPCORDSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If [M:PREC]BPCORDEND="" [M:PREC]BPCORDEND=VALEUR Endif
   Actzo [M:PREC]BPAADDSTR
Else
   Diszo [M:PREC]BPAADDSTR
Endif
End

Subprog AM_BPAADDSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If [M:PREC]BPAADDEND="" [M:PREC]BPAADDEND=VALEUR Endif
Endif
End

Subprog AP_BPCORDEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   Actzo [M:PREC]BPAADDEND
Else
   Diszo [M:PREC]BPAADDEND
Endif
End

Subprog C_BPAADDEND(VALEUR)
Variable Char    VALEUR()
If [M:PREC]BPCORDSTR=[M:PREC]BPCORDEND
   If VALEUR<>"" & VALEUR<[M:PREC]BPAADDSTR
      GMESSAGE=mess(44,199,1) : mkstat=2
   Endif
Endif
End

Subprog AM_DRNSTR(VALEUR)
Variable Integer VALEUR
If VALEUR<>0
   If [M:PREC]DRNEND=0 [M:PREC]DRNEND=VALEUR Endif
Endif
End

Subprog C_DRNEND(VALEUR)
Variable Integer VALEUR
If VALEUR<>0 & VALEUR<[M:PREC]DRNSTR
   GMESSAGE=mess(44,199,1) : mkstat=2
Endif
End

Subprog AM_BPTSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If [M:PREC]BPTEND="" [M:PREC]BPTEND=VALEUR Endif
Endif
End

Subprog AM_SOHNUMSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  If [M:PREC]SOHNUMEND="" [M:PREC]SOHNUMEND=VALEUR Endif
Endif
End

Subprog AM_DLVPIOSTR(VALEUR)
Variable Integer VALEUR
If VALEUR<>0
   If [M:PREC]DLVPIOEND=0 [M:PREC]DLVPIOEND=VALEUR Endif
Endif
End

Subprog C_DLVPIOEND(VALEUR)
Variable Integer VALEUR
If VALEUR<>0 & VALEUR<[M:PREC]DLVPIOSTR
   GMESSAGE=mess(44,199,1) : mkstat=2
Endif
End

Subprog AM_PRECODSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If [M:PREC]PRECODEND="" [M:PREC]PRECODEND=VALEUR Endif
Endif
End


######################################################################################

