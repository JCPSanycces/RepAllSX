#<AdxTL>@(#)0.0.0.0 $Revision$
Funprog GETSERVICEURL(SERVICE)
Value Char SERVICE

  Local Clbfile URL

  URL = func AFNC.PARAM(SERVICE,"")

End URL

#**
#* This Function performs an http request and returns the statuscode
#*
#* @param HEAD : Clbfile : The header of the request as a JSON string including "url", "method" etc.
#* @param DATA : Clbfile : The data that would be sent with 'POST' or 'PUT' methods.
#* @param RESHEAD : Clbfile : The response header.
#* @param RESBODY : Clbfile : The response body.
#*
#* @return ASTATUS : Integer : The status code returned by the Http request.
#*!
Funprog HTTP_EXEC(HEAD, DATA, RESHEAD, RESBODY)
Value Clbfile HEAD
Value Clbfile DATA
Variable Clbfile RESHEAD
Variable Clbfile RESBODY

  Local Integer ASTATUS
  Local Clbfile RES
  Local Integer I

  RES = Funciu "PROXY_DISPATCH" With (HEAD, DATA)

  If RES <> "": ASTATUS = func ASYRWEBSER.SPLITJSON(RES,RESHEAD,RESBODY): Endif
  If RESHEAD <> "": ASTATUS = val(func AJSONLIB.GET_PROP(RESHEAD,"statusCode")): Endif

End ASTATUS

#Local Integer I
#For I = 0 To len(RESHEAD) / 200
#  Infbox "HEAD (" + num$(I) + "): " + mid$(RESHEAD, I*200+1, 200)
#Next I

#**
#* This Function generates an FPS JSON Extract for the specified payroll company / pay period
#*
#* @param PCPY Payroll company
#* @param PPERYEA Pay period year
#* @param PPERCOD Pay period code
#* @param PSTRDAT Pay period start date
#* @param PENDDAT Pay period end date
#* @param PROCDAT FPS Processed date
#* @param ESUBUUID Esubmission record unique identifier
#*
#* @return EXPORTFILE : Clbfile : The generated clob file containing the FPS JSON file.
#*!
 #ALHAR - X3-68726 - 03/05/2018 - Start
#Funprog EXPORT_FPS(PCPY, PPERYEA, PPERCOD, PSTRDAT, PENDDAT, PROCDAT, ESUBUUID)
#Value Char PCPY, PPERCOD
#Value Date PSTRDAT, PENDDAT, PROCDAT
Funprog EXPORT_FPS(PCPY, PPERYEA, PPERCOD, PSTRDAT, PENDDAT, PROCDAT, ESUBUUID, CURDAT)
Value Char PCPY, PPERCOD
Value Date PSTRDAT, PENDDAT, PROCDAT, CURDAT
#ALHAR - X3-68726 - 03/05/2018 - End

Value Integer PPERYEA
  If clalev([F:ESUBREG])=0  : Local File HRESUBREG    [ESUBREG] : Endif
  If clalev([F:HRESUB])=0   : Local File HRESUB       [HRESUB]  : Endif
  If clalev([F:ID])=0       : Local File EMPLOID      [ID]      : Endif
#ANCOA - 2017-10-12 X3-59113 START
  If clalev([F:ID2])=0      : Local File EMPLOID      [ID2]     : Endif
#ANCOA - 2017-10-12 X3-59113 END
  If clalev([F:IDUKI])=0    : Local File EMPLOIDUKI   [IDUKI]   : Endif
  If clalev([F:CTR])=0      : Local File EMPLOCTR     [CTR]     : Endif
  If clalev([F:CTRUKI7])=0  : Local File EMPLOCTRUKI  [CTRUKI7] : Endif
#MASHI - 2017-10-10 X3-54387 START
  If clalev([F:CTRUKI8])=0  : Local File EMPLOCTRUKI  [CTRUKI8] : Endif
#MASHI - 2017-10-10 X3-54387 END
  If clalev([F:FCY])=0      : Local File FACILITY     [FCY]     : Endif
  If clalev([F:CPY])=0      : Local File COMPANY      [CPY]     : Endif
  If clalev([F:CPYUKI])=0   : Local File HRCOMPANYUKI [CPYUKI]  : Endif
  If clalev([F:TCA])=0      : Local File TABCOUAFF    [TCA]     : Endif
  If clalev([F:BUL])=0      : Local File BULCAL       [BUL]     : Endif
  If clalev([F:HSP])=0      : Local File HISTOPAYE    [HSP]     : Endif
#ALHAR - 2017-03-20 X3-83457 START
  If clalev([F:HSPAH])=0      : Local File HISTOPAYE    [HSPAH]     : Endif
#ALHAR - 2017-03-20 X3-83457 END
#MASHI - 2017-10-12 X3-59119 START
  If clalev([F:HSP9])=0      : Local File HISTOPAYE    [HSP9]     : Endif
#MASHI - 2017-10-12 X3-59119 END
  If clalev([F:VEP])=0      : Local File VALEMP       [VEP]     : Endif
#ALHAR - 2017-03-20 X3-83457 START
  If clalev([F:VEPAH])=0      : Local File VALEMP       [VEPAH]     : Endif
#ALHAR - 2017-03-20 X3-83457 END
#MASHI - 2017-10-13 X3-59268 START
  If clalev([F:VEP9])=0      : Local File VALEMP       [VEP9]     : Endif
#MASHI - 2017-10-13 X3-59268 END
  If clalev([F:CUCA])=0     : Local File HRCPYUKCAR   [CUCA]    : Endif
  If clalev([F:CTCA])=0     : Local File HRUKCTRCAR   [CTCA]    : Endif
  If clalev([F:HRPEOD])=0   : Local File HRPEODET     [HRPEOD]  : Endif
  If clalev([F:HRPEOH])=0   : Local File HRPEOHEA     [HRPEOH]  : Endif
  If clalev([F:BAN])=0      : Local File BANK [BAN]             : Endif

  Local Instance MYCOMPANY Using C_COMPANY
  Local Instance MYCONTRACT Using C_EMPLOCTR
  Local Instance MYEMPLOID Using C_EMPLOID

  Local Instance MYCOMPANYUKRTI Using C_COMPANYUKRTI
  Local Instance MYEMPLOIDUKRTI Using C_EMPLOIDUKRTI
  Local Instance MYEMPUKRTI Using C_EMPUKRTI

  Local Instance MYEMPCTRUKRTI Using C_EMPCTRUKRTI
  Local Instance MYEMPCTRUKRTI2 Using C_EMPCTRUKRTI2

  Local Clbfile OBJ_JSON, EXPORTFILE
  Local Integer ICNT
#MASHI - 2017-01-11 X3-70743 START
  Local Char CTAXCOD(10)
  Local Integer ITAXNUM
#MASHI - 2017-01-11 X3-70743 END
#MASHI - 2018-01-19 X3-71776 START
  Local Date VTAXYEASTR
#MASHI - 2018-01-19 X3-71776 END
  Local Char NICATEGORY(1)
  Local Char LAST_PAYSLIP

  # Get HRESUB record
  Read [HRESUB]HRESUB1 = ESUBUUID

  #ANCOA - X3-59030 - START
  #Read period details
  Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = PPERCOD and [F:HRPEOH]PERYEA = PPERYEA
  Read [F:HRPEOH] Last
  Filter [F:HRPEOH]
  #ANCOA - X3-59030 - END

### Select data to be exported ###
  Link [CTR]  With  [ID]ID0         ~= [F:CTR]REFNUM,
&                   [IDUKI]IDUKI0   ~= [F:CTR]REFNUM,
&                   [CTRUKI7]CTRUKI0 ~= [F:CTR]REFNUM; [F:CTR]CTRNUM; [F:CTR]CTRDAT,
&                   [FCY]FCY0       ~= [F:CTR]ETRFCY,
&                   [CPY]CPY0       ~= [FCY]LEGCPY,
&                   [CPYUKI]CPYUKI0 ~= [CPY]CPY
&            As     [LNK]
&            Where  [CPY]CPY        = PCPY and [F:CTR]PERCOD = PPERCOD
&            Order By [FCY]LEGCPY; [F:CTR]CTRNUM

  MYCOMPANY = NewInstance [CPY] With C_COMPANY
  MYCOMPANYUKRTI = NewInstance [CPYUKI] With C_COMPANYUKRTI

  OK=fmet MYCOMPANY.AREAD(PCPY)

  OK=fmet MYCOMPANYUKRTI.AREAD(PCPY)

  If OK <> [V]CST_AOK: End EXPORTFILE: Endif

  Read [F:ESUBREG]ESUBREG0 = PCPY
  If fstat: End EXPORTFILE: Endif

  Local Char TESTSUB(5)

  If [F:HRESUB]LIVESUB = 2
    TESTSUB = 'false'
  Else
    TESTSUB = 'true'
  Endif

  #Wrseq '{ "COMPANY" : ' Using [FIC]
  Append EXPORTFILE, '{ "FORM" : { '
  #ANCOA - X3-70250 - 05/01/2018 - Start
  Append EXPORTFILE, '"testSubmission" : ' + TESTSUB + ', '
  #ANCOA - X3-70250 - 05/01/2018 - End
  Append EXPORTFILE, '"processDate" : "' + format$("D:4Y[-]MM[-]DD",PROCDAT) + '", '

  #ALHAR - X3-68726 - 03/05/2018 - Start
  Append EXPORTFILE, '"currentDate" : "' + format$("D:4Y[-]MM[-]DD",CURDAT) + '", '
  #ALHAR - X3-68726 - 03/05/2018 - End

  Append EXPORTFILE, '"userId" : "' + [F:ESUBREG]USERID + '", '
  Append EXPORTFILE, '"password" : "' + [F:ESUBREG]PWD + '", '
  #ANCOA 03/01/2018 X3-69309 - START
  Append EXPORTFILE, '"email" : "' + [F:ESUBREG]EMAIL + '", '
  #ANCOA 03/01/2018 X3-69309 - END
  #ANCOA 04/01/2018 X3-69307 - START
  Append EXPORTFILE, '"title" : "' + mess([F:ESUBREG]CIV,11500,1) + '", '
  Append EXPORTFILE, '"forename1" : "' + [F:ESUBREG]SRN + '", '
  Append EXPORTFILE, '"forename2" : "' + [F:ESUBREG]FORNAM2 + '", '
  Append EXPORTFILE, '"surname" : "' + [F:ESUBREG]NAM + '", '
  Append EXPORTFILE, '"version" : "1.0.0", '
  #ANCOA 04/01/2018 X3-69307 - END
  Append EXPORTFILE, '"lateReason": "' + func GET_LATEREASON([F:HRESUB]LTEPAYREA) + '"'
  Append EXPORTFILE, '}, "COMPANY" : ' + chr$(13) + chr$(10)

  OBJ_JSON = func STRINGIFY(MYCOMPANYUKRTI)

  #Wrseq OBJ_JSON Using [FIC]
  Append EXPORTFILE, OBJ_JSON + chr$(13) + chr$(10)

  #Wrseq ', "Employees" : [' Using [FIC]
  Append EXPORTFILE, ', "Employees" : [' + chr$(13) + chr$(10)

  ICNT = 0
  For [LNK]

    #ANCOA 22/05/2018 X3-92238 - Start - exclude leavers from previous periods.
      #ANCOA 12/06/2018 X3-95305 - also exclude starters that started after the period end date
    If func EXCLUDE_EMPLOYEE(PSTRDAT, PENDDAT, [F:CTR]REFNUM, [F:CTR]CTRNUM, [F:CTR]CTRDAT ) <> 0
      Goto NEXT_EMPLOYEE
    Endif
    #ANCOA 22/05/2018 X3-92238 - End

    If func MULTI_CONTRACT_IN_PERIOD(PSTRDAT, PENDDAT, [F:CTR]REFNUM, [F:CTR]CTRNUM, [F:CTR]XITDAT) <> 0
      Goto NEXT_EMPLOYEE
    Endif

    #ALHAR - 2018-06-06 X3-94309 START
    #DEFINITION OF LEAVER (For SUBMISSION ON THE FPS):
    #not ALREADY SUBMITTED As A LEAVER (handled by the above check)
    #FINAL EXIT BOX TICKED
    #End Date POPULATED
    Local Integer FPSLEAVER
    FPSLEAVER=0
    If [F:CTR]XITFNL=2 & [F:CTR]XITDAT <> [00/00/0000]
      FPSLEAVER=1
    Endif
    #ALHAR - 2018-06-06 X3-94309 END

    MYCONTRACT = NewInstance [CTR] With C_EMPLOCTR
    OK=fmet MYCONTRACT.AREAD([F:CTR]REFNUM, [F:CTR]CTRNUM, [F:CTR]CTRDAT)
#MASHI 2018-01-12 X3-68610 START
#MASHI - 2017-10-13 X3-59268 START REMOVED X3-68731 2017-12-18
#   Checking current payslip
    Local Integer IRRFLG
    Filter [VEP9] Where EMP=[F:CTR]REFNUM & PYRDAT>=[F:CTR]CTRDAT & CTRNUM=[F:CTR]CTRNUM
    Read [VEP9]VEP0 First
    Filter [VEP9]
    If fstat
     IRRFLG = 3
    Else #ANCOA - X3-72899 - 22/01/2018
      Filter [VEP9] Where EMP=[F:CTR]REFNUM & PYRDAT=[M:ESUBUKI1]PYRDAT & CTRNUM=[F:CTR]CTRNUM
      Read [VEP9]VEP0 First
      Filter [VEP9]
      If fstat
        If [CTRUKI7]IRRFLG=2 & [CTRUKI7]IRRDAT <> [M:ESUBUKI1]PYRDAT
#          IRRFLG = 3 #MASHI - X3-72899 - 24/01/2018
          IRRFLG = 2
        Else
          IRRFLG = 2
        Endif
      Else
        IRRFLG = 1
      Endif
    Endif #ANCOA - X3-72899 - 22/01/2018

    If OK = [V]CST_AOK & IRRFLG<3

      Filter [F:CTRUKI8] Where REFNUM = [F:CTRUKI7]REFNUM and CTRNUM = [F:CTRUKI7]CTRNUM and CTRDAT = [F:CTRUKI7]CTRDAT
      Read [F:CTRUKI8] First
      [F:CTRUKI8]IRRFLG = IRRFLG
#MASHI 2018-01-12 X3-68610 START
      [CTRUKI8]IRRDAT = [M:ESUBUKI1]PYRDAT
#MASHI 2018-01-12 X3-68610 END
      Rewrite [F:CTRUKI8]
      If fstat
           GOK=0 : Call FSTA("HRESUB") From GLOCK
      Endif
      Filter [F:CTRUKI8]
#MASHI - 2017-10-13 X3-59268 END
#MASHI 2018-01-12 X3-68610 END

      # Create the RTI classes
      MYEMPLOID = NewInstance [ID] With C_EMPLOID
      MYEMPLOIDUKRTI = NewInstance [IDUKI] With C_EMPLOIDUKRTI
      MYEMPUKRTI = NewInstance [ID] With C_EMPUKRTI
      MYEMPCTRUKRTI = NewInstance [CTRUKI7] With C_EMPCTRUKRTI
      MYEMPCTRUKRTI2 = NewInstance [CTR] With C_EMPCTRUKRTI2

      # Load the RTI classes
      OK=fmet MYEMPLOID.AREAD([F:CTR]REFNUM)
      OK=fmet MYEMPUKRTI.AREAD([F:CTR]REFNUM)
      OK=fmet MYEMPLOIDUKRTI.AREAD([F:CTR]REFNUM)
      OK=fmet MYEMPCTRUKRTI.AREAD([F:CTR]REFNUM, [F:CTR]CTRNUM, [F:CTR]CTRDAT)
      OK=fmet MYEMPCTRUKRTI2.AREAD([F:CTR]REFNUM, [F:CTR]CTRNUM, [F:CTR]CTRDAT)

      #If final exit isn't ticked then the leaver isn't really a leaver X3-92782
      If [F:CTR]XITFNL <> 2
        MYEMPCTRUKRTI2.XITDAT = [00/00/0000]
      Endif

      # associate RTI classes containing additional information with the main class
      MYEMPLOIDUKRTI.EMPRTI2 = MYEMPUKRTI
      MYEMPLOIDUKRTI.CTRRTI = MYEMPCTRUKRTI
      MYEMPLOIDUKRTI.CTRRTI2 = MYEMPCTRUKRTI2

      If MYEMPCTRUKRTI.TAXLBE = ''
        MYEMPCTRUKRTI.TAXLBE = [F:CTRUKI7]TAXCOD
      Endif
      MYEMPLOIDUKRTI.SEXTIT = left$(mess([F:ID]SEX,10314,1),1)
      MYEMPLOIDUKRTI.CIVA = mess([F:ID]CIV,11500,1)

      If [F:CTRUKI7]STRDLC > 1
        MYEMPCTRUKRTI.STRDLCTIT = left$(mess([F:CTRUKI7]STRDLC,11816,1),1)
      Endif
      If [F:CTRUKI7]DIRSTA > 1
        If [F:CTRUKI7]DIRSTA = 2
         MYEMPCTRUKRTI.DIRSTATIT = "AA"
        Else
         MYEMPCTRUKRTI.DIRSTATIT = "AL"
        Endif
      Endif
      #ANCOA - 20/01/2018 X3-71636 Start
      MYEMPCTRUKRTI.TAXYEASTR = gdat$(06,04,PPERYEA)
      #ANCOA - 20/01/2018 X3-71636 End
#MASHI - 2017-10-10 X3-54387 START
#MASHI - 2017-12-13 X3-68549 START
      If [F:CTRUKI7]NEWSTRDAT = [0/0/0] or [F:CTRUKI7]NEWSTRDAT = [M:ESUBUKI1]PYRDAT and [F:CTRUKI7]PRVFRM > 1
#MASHI - 2017-12-13 X3-68549 END
         Filter [F:CTRUKI8] Where REFNUM = [F:CTRUKI7]REFNUM and CTRNUM = [F:CTRUKI7]CTRNUM and CTRDAT = [F:CTRUKI7]CTRDAT
         Read [F:CTRUKI8] First
         MYEMPCTRUKRTI.NEWSTRFLG = 2
         [F:CTRUKI8]NEWSTRDAT = [M:ESUBUKI1]PYRDAT
         Rewrite [F:CTRUKI8]
         If fstat
              GOK=0 : Call FSTA("HRESUB") From GLOCK
         Endif
         Filter [F:CTRUKI8]
      Else
         MYEMPCTRUKRTI.NEWSTRFLG = 1
      Endif
#MASHI - 2017-10-10 X3-54387 END
#MASHI - 2017-10-12 X3-59174 START
     MYEMPCTRUKRTI.OLDPAYFLG = 1
      If [F:CTRUKI7]OLDPAY <> "" and ( [F:CTRUKI7]OLDPAYDAT = [0/0/0] or [F:CTRUKI7]OLDPAYDAT = [M:ESUBUKI1]PYRDAT)
         Filter [F:CTRUKI8] Where REFNUM = [F:CTRUKI7]REFNUM and CTRNUM = [F:CTRUKI7]CTRNUM and CTRDAT = [F:CTRUKI7]CTRDAT
         Read [F:CTRUKI8] First
         MYEMPCTRUKRTI.OLDPAYFLG = 2
         [F:CTRUKI8]OLDPAYDAT = [M:ESUBUKI1]PYRDAT
         Rewrite [F:CTRUKI8]
         If fstat
              GOK=0 : Call FSTA("HRESUB") From GLOCK
         Endif
         Filter [F:CTRUKI8]
      Endif
#MASHI - 2017-10-12 X3-59174 END

#CHSUL - 2017-11-10 X3-60399 START
      # Populate the BACS hash field
      MYEMPUKRTI.BACSHASHVAL = func UK_FUNCTIONS.GET_BACS_HASH([F:CTR]REFNUM)
#CHSUL - 2017-11-10 X3-60399 END

#ANCOA - 2017-10-12 X3-59113 START
      MYEMPLOIDUKRTI.PASAMD = 1
      # Populate passport number, if it needs to be sent
      If maxtab([ID]PASNUM) > 0
        If ([F:ID]PASAMD = 2 and ([F:ID]PASDATAMD = [0/0/0] or [F:ID]PASDATAMD = [M:ESUBUKI1]PYRDAT )) or
&          (([F:ID]PASDATNEW = [0/0/0] and [F:ID]PASNUM <> '') or [F:ID]PASDATNEW = [M:ESUBUKI1]PYRDAT)
          MYEMPLOIDUKRTI.PASAMD = 2
          MYEMPLOIDUKRTI.PASNUM = [ID]PASNUM(0)
          Filter [F:ID2] Where REFNUM = [F:ID]REFNUM
          Read [F:ID2] First

          If [F:ID]PASDATNEW(0) = [0/0/0]
            [F:ID2]PASDATNEW(0) = [M:ESUBUKI1]PYRDAT
            Rewrite [F:ID2]
            If fstat
              GOK=0 : Call FSTA("HRESUB") From GLOCK
            Endif
          Elsif [F:ID]PASDATAMD(0) = [0/0/0] and [F:ID]PASDATNEW(0) <> [M:ESUBUKI1]PYRDAT
            #Infbox "update the amended date"
            [F:ID2]PASDATAMD(0) = [M:ESUBUKI1]PYRDAT
            Rewrite [F:ID2]
            If fstat
              GOK=0 : Call FSTA("HRESUB") From GLOCK
            Endif
          Endif
          Filter [F:ID2]
        Endif
      Endif
#ANCOA - 2017-10-12 X3-59113 START

      # Populate PAYFRQ - ANCOA - X3-81996 - 12/03/2018 - use core UK function to determine frequency
      MYEMPLOIDUKRTI.CTRRTI2.PAYFRQ = func UK_FUNCTIONS.GET_PAY_FREQUENCY(MYEMPLOIDUKRTI.CTRRTI2.PERCOD)
#MASHI - 2017-10-12 X3-59119 START
      MYEMPCTRUKRTI.SHPSTRFLG=1
#MASHI - 2017-10-12 X3-59119 END
#MASHI - 2017-01-11 X3-70743 START
      [L]CTAXCOD = ""
      [L]ITAXNUM = 0
#MASHI - 2017-01-11 X3-70743 END
#MASHI - 2018-01-19 X3-71776 START
     If IRRFLG > 1
          If [M:ESUBUKI1]PYRDAT < gdat$(06,04,year([M:ESUBUKI1]PYRDAT))
          VTAXYEASTR = gdat$(06,04,year([M:ESUBUKI1]PYRDAT) - 1)
          Else
          VTAXYEASTR = gdat$(06,04,year([M:ESUBUKI1]PYRDAT))
          Endif
          Filter [VEP] Where [VEP]EMP = [F:CTR]REFNUM and [VEP]PYRDAT >= VTAXYEASTR and [VEP]PYRDAT <= [M:ESUBUKI1]PYRDAT
          Read [F:VEP] Last
          If !fstat
            Filter [HSP] Where BUL = [F:VEP]BUL
            For [HSP]
              #ALHAR - 2018-04-03 X3-85037 START
              #MYEMPUKRTI.PAYDAT = [VEP]PAYDAT
              MYEMPUKRTI.PAYDAT = [VEP]PYRDAT
              #ALHAR - 2018-04-03 X3-85037 END
              MYEMPUKRTI.PER_COV = 1
              #evalue("MYEMPUKRTI." + [HSP]RUB + " = [HSP]AMT")
              Case [HSP]RUB
                When "TAXABLE_Y"     : MYEMPUKRTI.TAXABLE_Y  = [HSP]AMT
                #ANCOA - 20/01/2018 - X3-72896 - Start
                When "TAXABLE_P"     : MYEMPUKRTI.TAXABLE_P  = [HSP]AMT
                When "NAT_IN_MTD"    : MYEMPUKRTI.NAT_IN_MTD = [HSP]AMT
                When "NI_ER_PTD"     : MYEMPUKRTI.NI_ER_PTD  = [HSP]AMT
                When "NI_EE_PTD"     : MYEMPUKRTI.NI_EE_PTD  = [HSP]AMT
                #ANCOA - 20/01/2018 - X3-72896 - End
                #ANCOA - 22/01/2018 - X3-72896 - Start
                When "P_A_ST_DED"    : MYEMPUKRTI.P_A_ST_DED = [HSP]AMT
                #ANCOA - 22/01/2018 - X3-72896 - End
                When "TAX_PAID_P"    : MYEMPUKRTI.TAX_PAID_P = [HSP]AMT
                When "STU_LOAN_Y"    : MYEMPUKRTI.STU_LOAN_Y = [HSP]AMT
                When "BIK_YTD"       : MYEMPUKRTI.BIK_YTD    = [HSP]AMT
                When "PEN_EE_YTD"    : MYEMPUKRTI.PEN_EE_YTD = [HSP]AMT
      #MASHI - 2017-12-19 X3-67701 START
      #          When "TAX_MONTH"     : MYEMPUKRTI.TAX_MONTH  = [HSP]AMT
                When "TAX_MONTH"     :
                   If [HSP]TYP = 1
                     MYEMPUKRTI.TAX_MONTH  = [HSP]AMT
                   Endif
      #MASHI - 2017-12-19 X3-67701 END
                When "TAX_WEEK"      : MYEMPUKRTI.TAX_WEEK   = [HSP]AMT
                When "SMP_YTD"       : MYEMPUKRTI.SMP_YTD    = [HSP]AMT
                When "SPP_YTD"       : MYEMPUKRTI.SPP_YTD    = [HSP]AMT
                #ANCOA - 19-10-2017 X3-60382 - start
                When "SPPA_YTD"      : MYEMPUKRTI.SPP_YTD    = MYEMPUKRTI.SPP_YTD + [HSP]AMT
                #ANCOA - 19-10-2017 X3-60382 - end
                When "SAP_YTD"       : MYEMPUKRTI.SAP_YTD    = [HSP]AMT
      #MASHI - 2017-10-10 X3-54387 START
      #          When "SHPP_YTD"      : MYEMPUKRTI.SHPP_YTD   = [HSP]AMT
                When "SHPP_YTD"      :
                  MYEMPUKRTI.SHPP_YTD   = [HSP]AMT
                  Filter [HSP9] Where EMP = [F:HSP]EMP and RUB = 'SHPP_MTD' and TYP = 6 and DAT = [VEP]PAYDAT
                  Read [HSP9] First
                  If !fstat
                    If [HSP]AMT = [HSP9]AMT
                        MYEMPCTRUKRTI.SHPSTRFLG=2
                    Endif
                  Endif
                  Filter [HSP9]
      #MASHI - 2017-10-10 X3-54387 END
                When "NAT_IN_YTD"    : MYEMPUKRTI.NAT_IN_YTD = [HSP]AMT
      #MASHI - 2018-01-03 X3-69131 START
      #          When "TO_LEL_YTD"    : MYEMPUKRTI.TO_LEL_YTD = [HSP]AMT
                When "TO_LEL_YTD"    : MYEMPUKRTI.TO_LEL_YTD = fix([HSP]AMT)
      #MASHI - 2018-01-03 X3-69131 START
                When "LEL_PT_YTD"    : MYEMPUKRTI.LEL_PT_YTD = [HSP]AMT
                When "PT_UEL_YTD"    : MYEMPUKRTI.PT_UEL_YTD = [HSP]AMT
                When "NI_ER_YTD"     : MYEMPUKRTI.NI_ER_YTD  = [HSP]AMT
                When "NIC_GE_YTD"    : MYEMPUKRTI.NIC_GE_YTD = [HSP]AMT
               When "TCB_W1M1":
                 If  [HSP]AMT > 0
                   MYEMPCTRUKRTI.WK1MH1 =  2.
                 Else
                   MYEMPCTRUKRTI.WK1MH1 =  1.
                 Endif
               When "SRIT_CODE":
                 If  [HSP]AMT > 0
                   MYEMPCTRUKRTI.SCTTAX =  2.
                 Else
                   MYEMPCTRUKRTI.SCTTAX =  1.
                 Endif
               When "TAXCODELET":
                  If [HSP]AMT > 999
                   [L]CTAXCOD = chr$(fix([HSP]AMT/100)) + chr$([HSP]AMT - (fix([HSP]AMT/100) * 100 ))
                  Else
                   [L]CTAXCOD = chr$(fix([HSP]AMT/10))
                  Endif
               When "TAXCODENUM":
                  [L]ITAXNUM = [HSP]AMT
              Endcase

            Next
            # Check if the employee is a director
            If func GET_PAYSLIP_VALUE ([F:VEP]BUL, "EMP_STATUS",0) > 1
              # Determine the NI Cat
              [L]NICATEGORY = func HRESUB_FUNC.GET_NICATEGORY(func HRESUB_FUNC.GET_PAYSLIP_VALUE([F:VEP]BUL,"NI_CAT",0))
              MYEMPUKRTI.NI_ER_PTD = func GET_PAYSLIP_VALUE ([F:VEP]BUL, [L]NICATEGORY + "_NI_ER_P3",0)
              MYEMPUKRTI.NI_EE_PTD = func GET_PAYSLIP_VALUE ([F:VEP]BUL, [L]NICATEGORY + "_NI_EE_P3",0)
            Endif

            #ALHAR - 2018-06-06 X3-94309 START
          Else
            If FPSLEAVER=1
              # Need their last payment date
              MYEMPUKRTI.PAYDAT = VTAXYEASTR
              Filter [VEP] Where [VEP]EMP = [F:CTR]REFNUM and [VEP]PYRDAT >= VTAXYEASTR and [VEP]PYRDAT <= [M:ESUBUKI1]PYRDAT
              Read [F:VEP] Last
              If !fstat
                  MYEMPUKRTI.PAYDAT = [VEP]PYRDAT
              Endif
              Filter [VEP]
              If MYEMPLOIDUKRTI.CTRRTI2.PAYFRQ=1
                MYEMPUKRTI.TAX_WEEK = 52
              Elsif MYEMPLOIDUKRTI.CTRRTI2.PAYFRQ=6
                MYEMPUKRTI.TAX_MONTH  = 12
              Endif
              MYEMPCTRUKRTI.IRRFLG=1
            Endif
            #ALHAR - 2018-06-06 X3-94309 END

          Endif
          Filter [VEP]
      Else
#MASHI - 2018-01-19 X3-71776 END

        # Populate the employee totals attributes
#ALHAR - 2017-03-20 X3-83457 START
#       Link [HSP]  With  [VEP]VEP0       ~= [F:HSP]EMP; [F:HSP]DAT; [F:HSP]BUL
#&                   As [LNK2]
#&                Where [VEP]EMP = [F:CTR]REFNUM and [VEP]PYRDAT >= PSTRDAT and [VEP]PYRDAT <= PENDDAT
       LAST_PAYSLIP = func HRESUB_FUNC.GET_LAST_PAYSLIP([F:CTR]REFNUM, [F:CTR]CTRNUM, PSTRDAT, PENDDAT)
       Link [HSPAH]  With  [VEPAH]VEP0       ~= [F:HSPAH]EMP; [F:HSPAH]DAT; [F:HSPAH]BUL
&                   As [LNK2]
&                Where [VEPAH]EMP = [F:CTR]REFNUM and [VEPAH]PYRDAT >= PSTRDAT and [VEPAH]PYRDAT <= PENDDAT and [VEPAH]BUL = [L]LAST_PAYSLIP

       For [LNK2]
        #ALHAR - 2018-04-03 X3-85037 START
        #MYEMPUKRTI.PAYDAT = [VEPAH]PAYDAT
        MYEMPUKRTI.PAYDAT = [VEPAH]PYRDAT
        #ALHAR - 2018-04-03 X3-85037 END
        MYEMPUKRTI.PER_COV = 1
        #evalue("MYEMPUKRTI." + [HSPAH]RUB + " = [HSPAH]AMT")
        Case [HSPAH]RUB
          When "TAXABLE_Y"     : MYEMPUKRTI.TAXABLE_Y  = [HSPAH]AMT
          When "TAX_DUE"       : MYEMPUKRTI.TAX_DUE    = [HSPAH]AMT
          When "TAX_PAID_M"    : MYEMPUKRTI.TAX_PAID_M = [HSPAH]AMT
          #ANCOA - 12-12-2017 X3-60255 - start
          When "TAX_PAID_P"    : MYEMPUKRTI.TAX_PAID_P = [HSPAH]AMT
          #ANCOA - 12-12-2017 X3-60255 - end
          When "STU_LOAN_Y"    : MYEMPUKRTI.STU_LOAN_Y = [HSPAH]AMT
          When "BIK_YTD"       : MYEMPUKRTI.BIK_YTD    = [HSPAH]AMT
          When "BIK_PTD"       : MYEMPUKRTI.BIK_PTD    = [HSPAH]AMT
          When "BIK_MTD"       : MYEMPUKRTI.BIK_MTD    = [HSPAH]AMT
          When "PEN_EE_YTD"    : MYEMPUKRTI.PEN_EE_YTD = [HSPAH]AMT
#MASHI - 2017-12-19 X3-67701 START
#          When "TAX_MONTH"     : MYEMPUKRTI.TAX_MONTH  = [HSPAH]AMT
          When "TAX_MONTH"     :
             If [HSPAH]TYP = 1
               MYEMPUKRTI.TAX_MONTH  = [HSPAH]AMT
             Endif
#MASHI - 2017-12-19 X3-67701 END
          When "TAX_WEEK"      : MYEMPUKRTI.TAX_WEEK   = [HSPAH]AMT
          When "TAXABLE_M"     : MYEMPUKRTI.TAXABLE_M  = [HSPAH]AMT
          #CHSUL - 20-10-2017 X3-60592 - start
          When "TAXABLE_P"     : MYEMPUKRTI.TAXABLE_P  = [HSPAH]AMT
          #CHSUL - 20-10-2017 X3-60592 - end
          When "TAX_FREE"      : MYEMPUKRTI.TAX_FREE   = [HSPAH]AMT
          When "GROSS_MTD"     : MYEMPUKRTI.TOT_DEDNS  = MYEMPUKRTI.TOT_DEDNS + [HSPAH]AMT
          When "NETT_PAY"      : MYEMPUKRTI.TOT_DEDNS  = MYEMPUKRTI.TOT_DEDNS - [HSPAH]AMT
                                 MYEMPUKRTI.NETT_PAY   = [HSPAH]AMT
          When "STU_LOAN_M"    : MYEMPUKRTI.STU_LOAN_M = [HSPAH]AMT
          When "YTD_TAX_PD"    : MYEMPUKRTI.YTD_TAX_PD = [HSPAH]AMT
          When "SMP_YTD"       : MYEMPUKRTI.SMP_YTD    = [HSPAH]AMT
          When "SPP_YTD"       : MYEMPUKRTI.SPP_YTD    = [HSPAH]AMT
          #ANCOA - 19-10-2017 X3-60382 - start
          When "SPPA_YTD"      : MYEMPUKRTI.SPP_YTD    = MYEMPUKRTI.SPP_YTD + [HSPAH]AMT
          #ANCOA - 19-10-2017 X3-60382 - end
          When "SAP_YTD"       : MYEMPUKRTI.SAP_YTD    = [HSPAH]AMT
#MASHI - 2017-10-10 X3-54387 START
#          When "SHPP_YTD"      : MYEMPUKRTI.SHPP_YTD   = [HSPAH]AMT
          When "SHPP_YTD"      :
            MYEMPUKRTI.SHPP_YTD   = [HSPAH]AMT
            Filter [HSP9] Where EMP = [F:HSPAH]EMP and RUB = 'SHPP_MTD' and TYP = 6 and DAT = [VEPAH]PAYDAT
            Read [HSP9] First
            If !fstat
              If [HSPAH]AMT = [HSP9]AMT
                  MYEMPCTRUKRTI.SHPSTRFLG=2
              Endif
            Endif
            Filter [HSP9]
#MASHI - 2017-10-10 X3-54387 END
          When "NAT_IN_MTD"    : MYEMPUKRTI.NAT_IN_MTD = [HSPAH]AMT
          When "NAT_IN_YTD"    : MYEMPUKRTI.NAT_IN_YTD = [HSPAH]AMT
#MASHI - 2018-01-03 X3-69131 START
#          When "TO_LEL_YTD"    : MYEMPUKRTI.TO_LEL_YTD = [HSPAH]AMT
          When "TO_LEL_YTD"    : MYEMPUKRTI.TO_LEL_YTD = fix([HSPAH]AMT)
#MASHI - 2018-01-03 X3-69131 START
          When "LEL_PT_YTD"    : MYEMPUKRTI.LEL_PT_YTD = [HSPAH]AMT
          When "PT_UEL_YTD"    : MYEMPUKRTI.PT_UEL_YTD = [HSPAH]AMT
          When "NI_ER_YTD"     : MYEMPUKRTI.NI_ER_YTD  = [HSPAH]AMT
          When "NI_ER_MTD"     : MYEMPUKRTI.NI_ER_MTD  = [HSPAH]AMT
          When "NI_ER_PTD"     : MYEMPUKRTI.NI_ER_PTD  = [HSPAH]AMT
          When "NI_EE_MTD"     : MYEMPUKRTI.NI_EE_MTD  = [HSPAH]AMT
          When "NI_EE_PTD"     : MYEMPUKRTI.NI_EE_PTD  = [HSPAH]AMT
#CHSUL - 23-10-2017 X3-60362  - start
          When "NO_TAX_NI"     : MYEMPUKRTI.NO_TAX_NI  = [HSPAH]AMT
#CHSUL - 23-10-2017 X3-60362  - end
#CHSUL - 23-10-2017 X3-60364  - start
          When "DN_NET_PAY"    : MYEMPUKRTI.DN_NET_PAY = [HSPAH]AMT
#CHSUL - 23-10-2017 X3-60364  - end
#CHSUL - 23-10-2017 X3-60456  - start
          When "NIC_NO_TAX"    : MYEMPUKRTI.NIC_NO_TAX = [HSPAH]AMT
#CHSUL - 23-10-2017 X3-60456  - end
#CHSUL - 23-10-2017 X3-60463  - start
          When "NIC_GE_YTD"    : MYEMPUKRTI.NIC_GE_YTD = [HSPAH]AMT
#CHSUL - 23-10-2017 X3-60463  - end
#CHSUL - 23-10-2017 X3-60367  - start
          When "P_A_ST_DED"    : MYEMPUKRTI.P_A_ST_DED = [HSPAH]AMT
#CHSUL - 23-10-2017 X3-60367  - end
#MASHI - 24-10-2017 X3-58614  - start
#ALHAR - 19-01-2018 X3-71805 - start
          #When "PEN_NT_EX"    :
            #MYEMPUKRTI.FLX_NON_PAY = [HSPAH]AMT
            #MYEMPUKRTI.FLXPEN = 2
          #When "PEN_TX_EX"    :
            #MYEMPUKRTI.FLX_TAX_PAY = [HSPAH]AMT
            #MYEMPUKRTI.FLXPEN = 2
          #When "PEN_NT_DE"    :
            #MYEMPUKRTI.FLX_NON_PAY = [HSPAH]AMT
            #MYEMPUKRTI.PENDTHBEN = 2
          #When "PEN_TX_DE"    :
            #MYEMPUKRTI.FLX_TAX_PAY = [HSPAH]AMT
            #MYEMPUKRTI.PENDTHBEN = 2
          #When "PEN_NT_ILL"    :
            #MYEMPUKRTI.FLX_NON_PAY = [HSPAH]AMT
            #MYEMPUKRTI.SER_ILL_SUM = 2
          #When "PEN_TX_ILL"    :
            #MYEMPUKRTI.FLX_TAX_PAY = [HSPAH]AMT
            #MYEMPUKRTI.SER_ILL_SUM = 2
#ALHAR - 19-01-2018 X3-71805 - end
#MASHI - 24-10-2017 X3-58614  - end
#ANCOA - 31-10-2017 X3-60398 - start
          When "TR_COM_LS"     : MYEMPUKRTI.TR_COM_LS  = [HSPAH]AMT
          When "TR_COM_PPS"    : MYEMPUKRTI.TR_COM_PPS = [HSPAH]AMT
          When "TR_COM_WPS"    : MYEMPUKRTI.TR_COM_WPS = [HSPAH]AMT
#ANCOA - 31-10-2017 X3-60398 - end
#ANCOA - 19-12-2017 X3-58614 - start
          When "PEN_TX_EXT"    : MYEMPUKRTI.PEN_TX_EXT = [HSPAH]AMT
          When "PEN_NT_EXT"    : MYEMPUKRTI.PEN_NT_EXT = [HSPAH]AMT
          When "PEN_TX_DEC"    : MYEMPUKRTI.PEN_TX_DEC = [HSPAH]AMT
          When "PEN_NT_DEC"    : MYEMPUKRTI.PEN_NT_DEC = [HSPAH]AMT
          When "PEN_TX_ILL"    : MYEMPUKRTI.PEN_TX_ILL = [HSPAH]AMT
          When "PEN_NT_ILL"    : MYEMPUKRTI.PEN_NT_ILL = [HSPAH]AMT
#ANCOA - 19-12-2017 X3-58614 - end
#ALHAR - 06-02-2018 X3-73004 - start
          When "PEN_TX_IRR"    : MYEMPUKRTI.PEN_TX_IRR = [HSPAH]AMT
          When "PEN_NT_IRR"    : MYEMPUKRTI.PEN_NT_IRR = [HSPAH]AMT
#ALHAR - 06-02-2018 X3-73004 - end
#MASHI - 2017-12-18 X3-68731 START
          When "IRR_PAY":
            If [HSPAH]AMT > 0
             MYEMPCTRUKRTI.IRRFLG = 2
            Else
             MYEMPCTRUKRTI.IRRFLG = 1
            Endif
#MASHI - 2017-12-18 X3-68731 END
#MASHI - 2017-01-11 X3-70743 START
          When "TCB_W1M1":
           If  [HSPAH]AMT > 0
             MYEMPCTRUKRTI.WK1MH1 =  2.
           Else
             MYEMPCTRUKRTI.WK1MH1 =  1.
           Endif
          When "SRIT_CODE":
           If  [HSPAH]AMT > 0
             MYEMPCTRUKRTI.SCTTAX =  2.
           Else
             MYEMPCTRUKRTI.SCTTAX =  1.
           Endif
          When "TAXCODELET":
            If [HSPAH]AMT > 999
             [L]CTAXCOD = chr$(fix([HSPAH]AMT/100)) + chr$([HSPAH]AMT - (fix([HSPAH]AMT/100) * 100 ))
            Else
             [L]CTAXCOD = chr$(fix([HSPAH]AMT/10))
            Endif
          When "TAXCODENUM":
           [L]ITAXNUM = [HSPAH]AMT
#MASHI - 11-01-2018 X3-70933 - START
          When "NPA_EE_PER"    : MYEMPUKRTI.NPA_EE_PER = [HSPAH]AMT
          When "NOT_EE_PER"    : MYEMPUKRTI.NOT_EE_PER = [HSPAH]AMT
          When "PEN_EE_NPA"    : MYEMPUKRTI.PEN_EE_NPA = [HSPAH]AMT
          When "PEN_EE_NOT"    : MYEMPUKRTI.PEN_EE_NOT = [HSPAH]AMT
#MASHI - 11-01-2018 X3-70933 - END
        Endcase

       Next

       # Check if the employee is a director
       If func GET_PAYSLIP_VALUE ([F:VEPAH]BUL, "EMP_STATUS",0) > 1
         # Determine the NI Cat
         [L]NICATEGORY = func HRESUB_FUNC.GET_NICATEGORY(func HRESUB_FUNC.GET_PAYSLIP_VALUE([F:VEPAH]BUL,"NI_CAT",0))
         MYEMPUKRTI.NI_ER_PTD = func GET_PAYSLIP_VALUE ([F:VEPAH]BUL, [L]NICATEGORY + "_NI_ER_P3",0)
         MYEMPUKRTI.NI_EE_PTD = func GET_PAYSLIP_VALUE ([F:VEPAH]BUL, [L]NICATEGORY + "_NI_EE_P3",0)
       Endif

#MASHI - 2018-01-19 X3-71776 START
      Endif
#MASHI - 2018-01-19 X3-71776 END
      If [L]CTAXCOD<>""
         If [L]ITAXNUM > 0
          If [L]CTAXCOD = "K"
            MYEMPCTRUKRTI.TAXLBE = [L]CTAXCOD + num$([L]ITAXNUM)
          Else
            MYEMPCTRUKRTI.TAXLBE = num$([L]ITAXNUM) + [L]CTAXCOD
          Endif
         Else
          MYEMPCTRUKRTI.TAXLBE = [L]CTAXCOD
         Endif
       Endif
#MASHI - 2017-01-11 X3-70743 END

      # stringify and write the employee object to JSON
      If OK = [V]CST_AOK
        #Call ECR_TRACE("Employid.ID: " + MYEMPLOID.NAM ,0) From GESECRAN
        #Call ECR_TRACE("Employid.ID: " + MYEMPLOIDUKRTI.NAM ,0) From GESECRAN
        #Infbox "Employee: " + MYEMPLOIDUKRTI.NAM + '(' + num$(lobSize(EXPORTFILE)) + ')'

        OBJ_JSON = func STRINGIFY(MYEMPLOIDUKRTI)

        If ICNT > 0
          #Wrseq ',' Using [FIC]
          Append EXPORTFILE, ',' + chr$(13) + chr$(10)
        Endif
        #Wrseq OBJ_JSON Using [FIC]
        Append EXPORTFILE, OBJ_JSON + chr$(13) + chr$(10)
        ICNT += 1
      Endif

    # clear up the employee & contract classes
      FreeInstance MYCONTRACT
      FreeInstance MYEMPLOID
      FreeInstance MYEMPLOIDUKRTI
      FreeInstance MYEMPCTRUKRTI
      FreeInstance MYEMPCTRUKRTI2
      FreeInstance MYEMPUKRTI
    Endif

    $NEXT_EMPLOYEE
  Next

  # clear up the company classes and close the JSON file
  FreeInstance MYCOMPANY
  FreeInstance MYCOMPANYUKRTI
  #Wrseq "]}" Using [FIC] # close employees object

  #Infbox "End" + '(' + num$(lobSize(EXPORTFILE)) + ')'
  Append EXPORTFILE, "]}"

End EXPORTFILE

#########################################
Funprog STRINGIFY(STRUCTURE)
End func STRINGIFYL(STRUCTURE,0)

Funprog STRINGIFYL(STRUCTURE,LEVEL)
  Value Integer LEVEL
  Local Clbfile CHAINE,CHAINE1
  Local Char PROG(100)
  Local Integer I,J,K,L,N,P,Q

  PROG="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".STRINGIFYL"

  If dim(STRUCTURE,0)>1
    End "**Error too many dimensions**"
  Endif
  If dim(STRUCTURE)>1
    CHAINE="[ "
    If dim(STRUCTURE)=32767
      If type(STRUCTURE)=524
        L=0
      Else
        L=maxtab(STRUCTURE)
      Endif

      For I=0 To L
        If (type(STRUCTURE)=524 and STRUCTURE(I)<>null) or type(STRUCTURE)<>524 : Gosub ADD_MEMBER : Endif
        CHAINE+=string$(I<L,", ")
      Next I
    Else
      L=dim(STRUCTURE,-1)+dim(STRUCTURE,1)-1
      For I=dim(STRUCTURE,-1) To L
        Gosub ADD_MEMBER
        CHAINE+=string$(I<L,", ")
      Next I
    Endif
    CHAINE+=" ]"
  Else
    I=0
    Gosub ADD_MEMBER
  Endif
End CHAINE

$ADD_MEMBER
  Local Instance MYCPYCARUKRTI Using C_CPYCARUKRTI
  Local Instance MYCPYCARUKRTI2 Using C_CPYCARUKRTI2
  Local Integer NCARS

  Local Instance MYNICDATAUKRTI Using C_NICDATAUKRTI
  Local Char NICAT, EMPREFNUM, CTRNUM
  Local Integer NNICDATA, CAT_EXISTS, NICAT_NUM, EMPSTATUS, IADD
  Local Decimal EMP_TO_LEL_YTD, EMP_LEL_PT_YTD, EMP_PT_UEL_YTD, EMP_NIC_GE_YTD, EMP_NI_ER_YTD, EMP_NI_EE_YTD  #X3-92501
  Local Char LAST_PAYSLIP, CURRENT_NICAT
  Local Integer LAST_PAYSLIP_EMPSTATUS, LAST_PAYSLIP_FOR_TBL_DIR
  Local Integer STATUS_EMPLOYEE, STATUS_TBL_DIR, STATUS_DIR
  STATUS_EMPLOYEE = 1 : STATUS_TBL_DIR = 3 : STATUS_DIR = 2

  Local Clbfile TEMPSTR

  Case type(STRUCTURE)
    When 1,2,4,5,6,7 : CHAINE+=num$(STRUCTURE(I))
    When 3 : CHAINE+= '"'+format$("D:4Y[-]MM[-]DD",STRUCTURE(I))+'"'
    When 522 : K=b64Encode(STRUCTURE(I),CHAINE1) : CHAINE+= "'"+CHAINE1+"'"
    When 524 :
        If STRUCTURE(I) = null
          CHAINE+="null"
          Return
        Endif
        LEVEL+=1 : CHAINE+="{ "+chr$(10)+space$(3*LEVEL) : N=0
        K=STRUCTURE(I).ObjectNbs
        For J=1 To K

          If find(STRUCTURE(I).ObjectVar(J),"UKADD") = 1
            # Export only default address from UKADD collection
            For IADD = 1 To maxtab(STRUCTURE(I).UKADD)
              If STRUCTURE(I).UKADD(IADD).SETDEF = 2
                CHAINE += string$(N>0,","+chr$(10)+space$(3*LEVEL)) : N+=1
                CHAINE += '"'+STRUCTURE(I).ObjectVar(J)+'" :'+evalue(PROG+"(STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J)+"(" + num$(IADD) +"),LEVEL)")
              Endif
            Next I
          #ANCOA - Start Add Missing NICDATA
          # If the NICDATA element then export all the  NIDATA for the employee
          Elsif find(STRUCTURE(I).ObjectVar(J),"NICDATA") = 1
            CHAINE+=string$(N>0,","+chr$(10)+space$(3*LEVEL)) : N+=1
            CHAINE+= '"NICDATA" : [ '
            If clalev([F:HSP2])=0      : Local File HISTOPAYE    [HSP2]    : Endif
            If clalev([F:HSP3])=0      : Local File HISTOPAYE    [HSP3]    : Endif
            If clalev([F:HSP4])=0      : Local File HISTOPAYE    [HSP4]    : Endif
            If clalev([F:MULCTRVA]) = 0: Local File MLTCTRVALEMP [MULCTRVA] : Endif

            EMPREFNUM = STRUCTURE(I).REFNUM
            CURRENT_NICAT = num$(STRUCTURE(I).CTRRTI(1).NICAT)
            CTRNUM = STRUCTURE(I).CTRRTI(1).CTRNUM
            LAST_PAYSLIP = func HRESUB_FUNC.GET_LAST_PAYSLIP(EMPREFNUM,CTRNUM,[F:HRPEOH]CYCSTRDAT,[M:ESUBUKI1]ENDDAT)
            LAST_PAYSLIP_EMPSTATUS = func HRESUB_FUNC.GET_PAYSLIP_VALUE(LAST_PAYSLIP,"EMP_STATUS",0)
            If LAST_PAYSLIP_EMPSTATUS = STATUS_TBL_DIR
              LAST_PAYSLIP_FOR_TBL_DIR = func HRESUB_FUNC.GET_PAYSLIP_VALUE(LAST_PAYSLIP,"DIR_TABLE",0)
            Endif

            #Go through each NI Category and accumulate values for that category throughout the year
            For NICAT_NUM=1 To 8
              #ANCOA - X3-82036 - 12/03/2018 - remove the hard coded date checks and use the extraction period tax year start/end
              #ANCOA - X3-73271 - 14/03/2018 - Use the end date for current FPS month, so we don't include NI breakdown from future periods
              #ALHAR - X3-89389 - 17/05/2018 - start

              #ALHAR - X3-89389 - 17/05/2018 - end
              NICAT = func GET_NICATEGORY(NICAT_NUM)
              MYNICDATAUKRTI = NewInstance [IDUKI] With C_NICDATAUKRTI
              MYNICDATAUKRTI.NICAT = NICAT
              CAT_EXISTS = 0

              [L]EMP_TO_LEL_YTD=0 : [L]EMP_LEL_PT_YTD=0 : [L]EMP_PT_UEL_YTD=0   #X3-92501
              [L]EMP_NIC_GE_YTD=0 : [L]EMP_NI_ER_YTD=0 : [L]EMP_NI_EE_YTD=0     #X3-92501

              Filter [MULCTRVA] Where EMP=EMPREFNUM and PYRDAT >= [F:HRPEOH]CYCSTRDAT and PYRDAT <= [M:ESUBUKI1]ENDDAT Order By PYRDAT
              For [MULCTRVA]
                Filter [HSP2] Where BUL=[MULCTRVA]BUL and TYP=1 and RUB="NI_CAT" and AMT = NICAT_NUM Order By [HSP2]DAT

                #Go through all payslips with the current NI Category (NICAT_NUM)
                For [HSP2]
                  CAT_EXISTS = 1
                  OK=fmet MYNICDATAUKRTI.AREAD(STRUCTURE(I).REFNUM)
                  STRUCTURE(I).NICDATA = MYNICDATAUKRTI

                  # Check the employee status for this payslip (e.g. employee or  director)
                  Filter [HSP4] Where [HSP4]BUL = [HSP2]BUL and [HSP4]RUB = "EMP_STATUS"
                  For [HSP4]
                    EMPSTATUS = [HSP4]AMT
                  Next

                  #Accumulate all the NI values for this payslip
                  #Only care about the last HSP2 for a director
                  Filter [HSP3] Where BUL = [HSP2]BUL
                  For [HSP3]
                    If EMPSTATUS = STATUS_EMPLOYEE or EMPSTATUS = STATUS_TBL_DIR #Employee or Table director
                      Case [HSP3]RUB
                        When "TO_LEL_PER"    :
                          MYNICDATAUKRTI.TO_LEL_YTD = MYNICDATAUKRTI.TO_LEL_YTD + [HSP3]AMT
                          If EMPSTATUS =STATUS_EMPLOYEE
                            [L]EMP_TO_LEL_YTD = MYNICDATAUKRTI.TO_LEL_YTD
                          Endif
                        When "LEL_PT_PER"    :
                          MYNICDATAUKRTI.LEL_PT_YTD = MYNICDATAUKRTI.LEL_PT_YTD + [HSP3]AMT
                          If EMPSTATUS = STATUS_EMPLOYEE
                            [L]EMP_LEL_PT_YTD = MYNICDATAUKRTI.LEL_PT_YTD
                          Endif
                        When "PT_UEL_PER"    :
                          MYNICDATAUKRTI.PT_UEL_YTD = MYNICDATAUKRTI.PT_UEL_YTD + [HSP3]AMT
                          If EMPSTATUS = STATUS_EMPLOYEE
                            [L]EMP_PT_UEL_YTD = MYNICDATAUKRTI.PT_UEL_YTD
                          Endif
                        #ANCOA - X3-721113 - 19/01/2018 - Start
                        When "NI_ER_PTD"     :
                          MYNICDATAUKRTI.NI_ER_YTD = MYNICDATAUKRTI.NI_ER_YTD + [HSP3]AMT
                          If EMPSTATUS = STATUS_EMPLOYEE
                            [L]EMP_NI_ER_YTD = MYNICDATAUKRTI.NI_ER_YTD
                          Endif
                          If CURRENT_NICAT = NICAT
                            MYNICDATAUKRTI.NI_ER_MTD = [HSP3]AMT
                          Endif
                        When "NI_EE_PTD"     :
                          MYNICDATAUKRTI.NI_EE_YTD = MYNICDATAUKRTI.NI_EE_YTD + [HSP3]AMT
                          If EMPSTATUS = STATUS_EMPLOYEE
                            [L]EMP_NI_EE_YTD = MYNICDATAUKRTI.NI_EE_YTD
                          Endif
                          If CURRENT_NICAT = NICAT
                            MYNICDATAUKRTI.NI_EE_MTD = [HSP3]AMT
                          Endif
                        When "NAT_IN_MTD"    :
                          MYNICDATAUKRTI.NIC_GE_YTD = MYNICDATAUKRTI.NIC_GE_YTD + [HSP3]AMT
                          If EMPSTATUS = STATUS_EMPLOYEE
                            [L]EMP_NIC_GE_YTD = MYNICDATAUKRTI.NIC_GE_YTD
                          Endif
                        #ANCOA - X3-721113 - 19/01/2018 - End
                      Endcase
                    Endif
                  Next
                  #MASHI - 2018-01-03 X3-69131 START
                  MYNICDATAUKRTI.TO_LEL_YTD = fix(MYNICDATAUKRTI.TO_LEL_YTD)
                  #MASHI - 2018-01-03 X3-69131 END
                Next
              Next

              # Use the last payslip for: Cumulative directors; Table directors when last payslip of the year
              # Also if the employee was a  non-director during the year then add in the earnings as an employee
              If (LAST_PAYSLIP_EMPSTATUS = STATUS_DIR or LAST_PAYSLIP_FOR_TBL_DIR = 1) and CAT_EXISTS = 1
                MYNICDATAUKRTI.NIC_GE_YTD = [L]EMP_NIC_GE_YTD + func HRESUB_FUNC.GET_PAYSLIP_VALUE(LAST_PAYSLIP,NICAT + "_NAT_IN_Y",0)
                MYNICDATAUKRTI.TO_LEL_YTD = [L]EMP_TO_LEL_YTD + func HRESUB_FUNC.GET_PAYSLIP_VALUE(LAST_PAYSLIP,NICAT + "_TO_LEL_P",0)
                MYNICDATAUKRTI.TO_LEL_YTD = fix(MYNICDATAUKRTI.TO_LEL_YTD)
                MYNICDATAUKRTI.LEL_PT_YTD = [L]EMP_LEL_PT_YTD + func HRESUB_FUNC.GET_PAYSLIP_VALUE(LAST_PAYSLIP,NICAT + "_LEL_PT_P",0)
                MYNICDATAUKRTI.NI_ER_YTD  = [L]EMP_NI_ER_YTD + func HRESUB_FUNC.GET_PAYSLIP_VALUE(LAST_PAYSLIP,NICAT + "_NI_ER_Y",0)
                MYNICDATAUKRTI.NI_EE_YTD  = [L]EMP_NI_EE_YTD + func HRESUB_FUNC.GET_PAYSLIP_VALUE(LAST_PAYSLIP,NICAT + "_NI_EE_Y",0)
                MYNICDATAUKRTI.PT_UEL_YTD = [L]EMP_PT_UEL_YTD + func HRESUB_FUNC.GET_PAYSLIP_VALUE(LAST_PAYSLIP,NICAT + "_PT_UEL_P",0)
                MYNICDATAUKRTI.NI_EE_MTD  = func HRESUB_FUNC.GET_PAYSLIP_VALUE(LAST_PAYSLIP,NICAT + "_NI_EE_P3",0)
                MYNICDATAUKRTI.NI_ER_MTD  = func HRESUB_FUNC.GET_PAYSLIP_VALUE(LAST_PAYSLIP,NICAT + "_NI_ER_P3",0)
             Endif

              #If something was found for this NI Category then output an NICDATA entry
              If CAT_EXISTS = 1
                NNICDATA+=1
                If NNICDATA > 1
                  CHAINE+= ", "
                Endif
                CHAINE+= evalue(PROG+"(STRUCTURE(I).NICDATA(1),LEVEL)")
              Endif
              FreeInstance MYNICDATAUKRTI
            Next # NICAT_NUM=1 To 8

            CHAINE+= ' ]'
          #ANCOA - End Add missing NICDATA
          # If the CARRTI element then export all the car records for the employee
          Elsif find(STRUCTURE(I).ObjectVar(J),"CARRTI") = 1
            CHAINE+=string$(N>0,","+chr$(10)+space$(3*LEVEL)) : N+=1
            CHAINE+= '"CARRTI" : [ '

            MYCPYCARUKRTI = NewInstance [CUCA] With C_CPYCARUKRTI
            MYCPYCARUKRTI2 = NewInstance [CTCA] With C_CPYCARUKRTI2

            If clalev([F:CUCA])=0   : Local File HRCPYUKCAR   [CUCA]   : Endif
            If clalev([F:CTCA])=0   : Local File HRUKCTRCAR   [CTCA]   : Endif
            NCARS = 0

            Link [CTCA]  With [CUCA]CUCA1       ~= [F:CTCA]CPY; [F:CTCA]CARREG
&                          As [LNK3]
&                       Where [CTCA]REFNUM = STRUCTURE(I).REFNUM
            For [LNK3]

#  Infbox "[F:HRPEOH]PERCOD = " + [F:HRPEOH]PERCOD + " : [F:HRPEOH]PERYEA=" + num$([F:HRPEOH]PERYEA) + " : [F:HRPEOH]CYCSTRDAT = " + num$([F:HRPEOH]CYCSTRDAT) + " : [F:HRPEOH]CYCENDDAT=" + num$([F:
#& HRPEOH]CYCENDDAT)

              #ANCOA X3-59030 - START
              #Ignore the car record if it's from a different tax year
                #Car end date set and less than tax year start
                #Car start date after the tax year end
              If ([F:CTCA]DATAVAEND <> [0/0/0] and [F:CTCA]DATAVAEND < [F:HRPEOH]CYCSTRDAT) or
&                ([F:CTCA]DATAVA > [F:HRPEOH]CYCENDDAT)
                #do nothing
              #Only output the car details if this is a new car record, or the car record has been amended
              Elsif ([F:CTCA]CARAMD = 2 and ([F:CTCA]DATAMD = [0/0/0] or [F:CTCA]DATAMD = [M:ESUBUKI1]PYRDAT )) or
&                ([F:CTCA]DATNEW = [0/0/0] or [F:CTCA]DATNEW = [M:ESUBUKI1]PYRDAT)
                #Infbox [F:CTCA]CARREG + " : [F:CTCA]DATAMD=" + num$([F:CTCA]DATAMD) + " : [F:CTCA]DATNEW=" + num$([F:CTCA]DATNEW)
                #ANCOA X3-59030 - END

                OK=fmet MYCPYCARUKRTI.AREAD([F:CTCA]CPY, [F:CTCA]CARREG)
                OK=fmet MYCPYCARUKRTI2.AREAD([F:CTCA]REFNUM, [F:CTCA]CTRNUM, [F:CTCA]CTRDAT, [F:CTCA]CARREG, [F:CTCA]DATAVA)
                MYCPYCARUKRTI.CARRTI2 = MYCPYCARUKRTI2
                STRUCTURE(I).CARRTI = MYCPYCARUKRTI
                MYCPYCARUKRTI.FUETYPTIT=left$(mess(MYCPYCARUKRTI.FUETYP,11827,1),1)
                NCARS+=1
                If NCARS > 1
                  CHAINE+= ", "
                Endif
                CHAINE+= evalue(PROG+"(STRUCTURE(I).CARRTI(1),LEVEL)")

                #ANCOA X3-59030 - START
                # Update the New date of Amendment date fields if necessary
                If [F:CTCA]DATNEW = [0/0/0]
                  #Infbox "update the new date "
                  [F:CTCA]DATNEW = [M:ESUBUKI1]PYRDAT
                  Rewrite [F:CTCA]
                  If fstat
                    GOK=0 : Call FSTA("HRESUB") From GLOCK
                  Endif
                Elsif [F:CTCA]DATAMD = [0/0/0] and [F:CTCA]DATNEW <> [M:ESUBUKI1]PYRDAT
                  #Infbox "update the amended date"
                  [F:CTCA]DATAMD = [M:ESUBUKI1]PYRDAT
                  Rewrite [F:CTCA]
                  If fstat
                    GOK=0 : Call FSTA("HRESUB") From GLOCK
                  Endif
                Endif
              Endif
              #ANCOA X3-59030 - END

            Next

            CHAINE+= ' ]'
            FreeInstance MYCPYCARUKRTI2
            FreeInstance MYCPYCARUKRTI
          Elsif find(STRUCTURE(I).ObjectVar(J),"AATTRIBUTES","ACTX","AERROR","AINF","AKEYS","AORDER","APARENT","ASTALIN","AUUID")=0
&           and ((LEVEL=1) or find(STRUCTURE(I).ObjectVar(J),"CREDATTIM","UPDDATTIM","CREUSR","UPDUSR")=0)

            CHAINE+=string$(N>0,","+chr$(10)+space$(3*LEVEL)) : N+=1
            CHAINE+='"'+STRUCTURE(I).ObjectVar(J)+'" :'+evalue(PROG+"(STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J)+",LEVEL)")
          Endif
        Next J
        LEVEL=max(LEVEL-1,0)
        CHAINE+=chr$(10)+space$(3*LEVEL)+" }"
    When 525,526 : CHAINE+='"'+num$(STRUCTURE(I))+'"'
    When Default : CHAINE+= '"'+escJson(STRUCTURE(I))+'"'
  Endcase
Return

# ANCOA - Translate number to NI Category Letter
Funprog GET_NICATEGORY(NIC_NUM)
  Local Char NICAT

  Case NIC_NUM
    When 1 Then NICAT = "A"
    When 2 Then NICAT = "B"
    When 3 Then NICAT = "C"
    When 4 Then NICAT = "H"
    When 5 Then NICAT = "J"
    When 6 Then NICAT = "M"
    When 7 Then NICAT = "X"
    When 8 Then NICAT = "Z"
  Endcase
End NICAT

Funprog GET_LATEREASON(VALEUR)
  Value Integer VALEUR

  Local Char REASONCODE

  Case VALEUR
    When 1 Then REASONCODE = "X"
    When 2 Then REASONCODE = "G"
    When 3 Then REASONCODE = "H"
    When 4 Then REASONCODE = "F"
    When 5 Then REASONCODE = "D"
    When 6 Then REASONCODE = "F"
    When 7 Then REASONCODE = "A"
    When 8 Then REASONCODE = "B"
    When 9 Then REASONCODE = "C"
  Endcase
End REASONCODE

#**
#* This Function generates an EPS JSON Extract for the specified payroll company / pay period
#*
#* @param PCPY Payroll company
#* @param PPERYEA Pay period year
#* @param PPERCOD Pay period code
#* @param PPERNUM Pay Period number
#* @param PSTRDAT Pay period start date
#* @param PENDDAT Pay period end date
#* @param PROCDAT FPS Processed date
#* @param ESUBUUID Esubmission record unique identifier
#*
#* @return EXPORTFILE : Clbfile : The generated clob file containing the EPS JSON file.
#*!
Funprog EXPORT_EPS(PCPY, PPERYEA, PPERCOD, PPERNUM, PSTRDAT, PENDDAT, PROCDAT, ESUBUUID, CURDAT)
Value Char PCPY, PPERCOD
Value Date PSTRDAT, PENDDAT, PROCDAT, CURDAT

Value Integer PPERYEA, PPERNUM
Local Char TMP_APPANNALL
Local Decimal APPANNALL

  If clalev([F:ID])=0       : Local File EMPLOID      [ID]     : Endif
  If clalev([F:IDUKI])=0    : Local File EMPLOIDUKI   [IDUKI]  : Endif
  If clalev([F:CTR])=0      : Local File EMPLOCTR     [CTR]    : Endif
  If clalev([F:CTRUKI7])=0  : Local File EMPLOCTRUKI  [CTRUKI7] : Endif
  If clalev([F:FCY])=0      : Local File FACILITY     [FCY]    : Endif
  If clalev([F:CPY])=0      : Local File COMPANY      [CPY]    : Endif
  If clalev([F:CPYUKI])=0   : Local File HRCOMPANYUKI [CPYUKI] : Endif
  If clalev([F:TCA])=0      : Local File TABCOUAFF    [TCA]    : Endif
  If clalev([F:BUL])=0      : Local File BULCAL       [BUL]    : Endif
  If clalev([F:HSP])=0      : Local File HISTOPAYE    [HSP]    : Endif
  If clalev([F:VEP])=0      : Local File VALEMP       [VEP]    : Endif
  If clalev([F:CUCA])=0     : Local File HRCPYUKCAR   [CUCA]   : Endif
  If clalev([F:CTCA])=0     : Local File HRUKCTRCAR   [CTCA]   : Endif
  If clalev([F:HRPEOD])=0   : Local File HRPEODET     [HRPEOD] : Endif
  If clalev([F:HRPEOH])=0   : Local File HRPEOHEA     [HRPEOH] : Endif
  If clalev([F:BAN])=0      : Local File BANK [BAN]            : Endif
  If clalev([APPLEV])=0   : Local File UKAPPLEV [APPLEV]    : Endif
  If clalev([F:MULCTRVA]) = 0: Local File MLTCTRVALEMP [MULCTRVA] : Endif

  Local Instance MYUKRTIEPS Using C_UKRTIEPS
  Local Instance MYCOMPANYUKRTI Using C_COMPANYUKRTI
  Local Instance MYBANKUKRTI Using  C_BANKUKRTI

  Local Clbfile OBJ_JSON, EXPORTFILE
  Local Integer ICNT

  Link [F:HRPEOD]
&    With [F:HRPEOH]HRPEOH0 = [F:HRPEOD]PERYEA;[F:HRPEOD]PERCOD
&    As [LNK]
&    Where [F:HRPEOD]PERCOD=PPERCOD & [F:HRPEOH]FLGENA=2
&          & [F:HRPEOD]PERNUM=PPERNUM
  Read [LNK] First

  MYUKRTIEPS = NewInstance [HRPEOD] With C_UKRTIEPS
  MYCOMPANYUKRTI = NewInstance [CPY] With C_COMPANYUKRTI
  MYBANKUKRTI = NewInstance [BAN] With C_BANKUKRTI

  OK=fmet MYUKRTIEPS.AREAD([F:HRPEOD]PERCOD, [F:HRPEOD]PERYEA, [F:HRPEOD]PERNUM)

  If OK <> [V]CST_AOK: End EXPORTFILE: Endif

  If [F:HRESUB]LIVESUB = 2
    TESTSUB = 'false'
  Else
    TESTSUB = 'true'
  Endif

  Append EXPORTFILE, '{ "FORM" : { '
  Append EXPORTFILE, '"testSubmission" : ' + TESTSUB + ', '
  Append EXPORTFILE, '"processDate" : "' + format$("D:4Y[-]MM[-]DD",PROCDAT) + '", '
  Append EXPORTFILE, '"currentDate" : "' + format$("D:4Y[-]MM[-]DD",CURDAT) + '", '
  Append EXPORTFILE, '"userId" : "' + [F:ESUBREG]USERID + '", '
  Append EXPORTFILE, '"email" : "' + [F:ESUBREG]EMAIL + '", '
  Append EXPORTFILE, '"title" : "' + mess([F:ESUBREG]CIV,11500,1) + '", '
  Append EXPORTFILE, '"forename1" : "' + [F:ESUBREG]SRN + '", '
  Append EXPORTFILE, '"forename2" : "' + [F:ESUBREG]FORNAM2 + '", '
  Append EXPORTFILE, '"surname" : "' + [F:ESUBREG]NAM + '", '
  Append EXPORTFILE, '"password" : "' + [F:ESUBREG]PWD + '"'
  Append EXPORTFILE, '}, "EPS" : ' + chr$(13) + chr$(10)

  If OK = [V]CST_AOK
    MYUKRTIEPS.PERYEA    = PPERYEA
    MYUKRTIEPS.PERCOD    = PPERCOD
    MYUKRTIEPS.PERNUM    = [F:HRPEOD]TAXMON #PPERNUM #ANCOA X3-73275 24/01/2018

    # Load the company details
    Filter [CPYUKI] Where CPY=PCPY
    Read [CPYUKI]CPYUKI0 Last
    OK=fmet MYCOMPANYUKRTI.AREAD([CPYUKI]CPY)

    # Load the bank details
    Filter [BAN] Where CPY=PCPY and HMRC=2
    Read [BAN]BAN0 Last
    OK=fmet MYBANKUKRTI.AREAD([BAN]BAN)

    Read [HRESUB]HRESUB1 = ESUBUUID
    If !fstat
      MYCOMPANYUKRTI.SCHCEA = [F:HRESUB]CEASED
      MYCOMPANYUKRTI.DATSCHCEA = [F:HRESUB]CEASEDDAT
      MYCOMPANYUKRTI.FINSUB = [F:HRESUB]FINALSUB

      If [F:HRESUB]PERNONACT = 2
        MYUKRTIEPS.CYCSTRDAT = [F:HRESUB]PERNONACTSTR
        MYUKRTIEPS.CYCENDDAT = [F:HRESUB]PERNONACTEND
      Endif
      If [F:HRESUB]PAYNOTDUE = 2
        MYUKRTIEPS.STR2      = [F:HRESUB]PAYNOTDUESTR
        MYUKRTIEPS.END2      = [F:HRESUB]PAYNOTDUEEND
      Endif
    Endif

    If MYCOMPANYUKRTI.APPLEVAMT = 0
      Call PARAM(PCPY, "APPANNALL", TMP_APPANNALL) From ADOVAL
      If TMP_APPANNALL = "" Then : TMP_APPANNALL = "0" : Endif
      APPANNALL = val(TMP_APPANNALL)
      MYCOMPANYUKRTI.APPLEVAMT = APPANNALL
    Endif
    Filter [APPLEV] Where CPY=PCPY and DAT=[M:ESUBUKI1]DATPAI
    Read [F:APPLEV] First
    If !fstat
      MYCOMPANYUKRTI.LEVDUEYTD = [F:APPLEV]LEVDTD
    Endif
    Filter [APPLEV]

    MYUKRTIEPS.RTICOMPANY   = MYCOMPANYUKRTI
    MYUKRTIEPS.RTIBANK      = MYBANKUKRTI

    Local Integer TAX_MONTH
    Local Date PER_START, PER_END
    Local Decimal SMP_REC_TD(12), SPP_REC_TD(12), SAP_REC_TD(12), SHPP_REC_TD(12)


    ### Select data to be exported ###
    Link [CTR]  With  [ID]ID0         ~= [F:CTR]REFNUM,
&                     [IDUKI]IDUKI0   ~= [F:CTR]REFNUM,
&                     [CTRUKI7]CTRUKI0 ~= [F:CTR]REFNUM; [F:CTR]CTRNUM; [F:CTR]CTRDAT,
&                     [FCY]FCY0       ~= [F:CTR]ETRFCY,
&                     [CPY]CPY0       ~= [FCY]LEGCPY,
&                     [CPYUKI]CPYUKI0 ~= [CPY]CPY
&              As     [LNK]
&              Where  [CPY]CPY        = PCPY
&              Order By [FCY]LEGCPY; [F:CTR]CTRNUM
    For [LNK]

      For TAX_MONTH=1 To PPERNUM
        [L]PER_START = func GET_TAX_MONTH_DATE("START", TAX_MONTH, PPERYEA)
        [L]PER_END   = func GET_TAX_MONTH_DATE("END", TAX_MONTH, PPERYEA)

        Filter [MULCTRVA] Where EMP=[F:CTR]REFNUM and [MULCTRVA]CTRDAT = [F:CTR]CTRDAT and PYRDAT >= [L]PER_START and PYRDAT <= [L]PER_END Order By PYRDAT
        For [MULCTRVA]
          Link [HSP]  With  [VEP]VEP0       ~= [F:HSP]EMP; [F:HSP]DAT; [F:HSP]BUL
&                       As [LNK2]
&                    Where [VEP]BUL = [MULCTRVA]BUL
          For [LNK2]
            Case [HSP]RUB
              When "SMP_MTD"   : [L]SMP_REC_TD(TAX_MONTH-1)  += [HSP]AMT
              When "SPP_MTD"   : [L]SPP_REC_TD(TAX_MONTH-1)  += [HSP]AMT
              When "SPPA_MTD"  : [L]SPP_REC_TD(TAX_MONTH-1)  += [HSP]AMT
              When "SAP_MTD"   : [L]SAP_REC_TD(TAX_MONTH-1)  += [HSP]AMT
              When "SHPP_MTD"  : [L]SHPP_REC_TD(TAX_MONTH-1) += [HSP]AMT
            Endcase
          Next
        Next
        $NEXT_TAX_MONTH
      Next TAX_MONTH
    Next

    For TAX_MONTH=1 To 12
      MYUKRTIEPS.SMP_REC_TD   = MYUKRTIEPS.SMP_REC_TD + func UK_FUNCTIONS.ROUND_UP_PENNY([L]SMP_REC_TD(TAX_MONTH-1) * 0.92)
      MYUKRTIEPS.SPP_REC_TD   = MYUKRTIEPS.SPP_REC_TD + func UK_FUNCTIONS.ROUND_UP_PENNY([L]SPP_REC_TD(TAX_MONTH-1) * 0.92)
      MYUKRTIEPS.SAP_REC_TD   = MYUKRTIEPS.SAP_REC_TD + func UK_FUNCTIONS.ROUND_UP_PENNY([L]SAP_REC_TD(TAX_MONTH-1) * 0.92)
      MYUKRTIEPS.SHPP_REC_TD  = MYUKRTIEPS.SHPP_REC_TD + func UK_FUNCTIONS.ROUND_UP_PENNY([L]SHPP_REC_TD(TAX_MONTH-1) * 0.92)
    Next

    OBJ_JSON = func STRINGIFY(MYUKRTIEPS)

    Append EXPORTFILE, OBJ_JSON + chr$(13) + chr$(10) + "}"

    FreeInstance MYBANKUKRTI
    FreeInstance MYCOMPANYUKRTI
    FreeInstance MYUKRTIEPS
  Endif
End EXPORTFILE

#**
#* Function to find the start or end date for a given tax month
#* @param DATE_TO_FIND Either "START" or "END"
#* @param MONTH_NUMBER tax month number 1 to 12 to find the start/end date for
#* @param TAX_YEAR Tax year to find the month start/end date for
#* @return Returns the start or end date for the given tax month, e.g. "START", 1, 2017 returns 6th April 2017
#*!
Funprog GET_TAX_MONTH_DATE(DATE_TO_FIND, MONTH_NUMBER, TAX_YEAR)
  Value Char DATE_TO_FIND
  Value Integer MONTH_NUMBER, TAX_YEAR
  Local Date RETDATE, START_DATE, END_DATE

  Case MONTH_NUMBER
      When 1
        [L]START_DATE = gdat$(06,04,TAX_YEAR) : [L]END_DATE = gdat$(05,05,TAX_YEAR)
      When 2
        [L]START_DATE = gdat$(06,05,TAX_YEAR) : [L]END_DATE = gdat$(05,06,TAX_YEAR)
      When 3
        [L]START_DATE = gdat$(06,06,TAX_YEAR) : [L]END_DATE = gdat$(05,07,TAX_YEAR)
      When 4
        [L]START_DATE = gdat$(06,07,TAX_YEAR) : [L]END_DATE = gdat$(05,08,TAX_YEAR)
      When 5
        [L]START_DATE = gdat$(06,08,TAX_YEAR) : [L]END_DATE = gdat$(05,09,TAX_YEAR)
      When 6
        [L]START_DATE = gdat$(06,09,TAX_YEAR) : [L]END_DATE = gdat$(05,10,TAX_YEAR)
      When 7
        [L]START_DATE = gdat$(06,10,TAX_YEAR) : [L]END_DATE = gdat$(05,11,TAX_YEAR)
      When 8
        [L]START_DATE = gdat$(06,11,TAX_YEAR) : [L]END_DATE = gdat$(05,12,TAX_YEAR)
      When 9
        [L]START_DATE = gdat$(06,12,TAX_YEAR) : [L]END_DATE = gdat$(05,01,TAX_YEAR + 1)
      When 10
        [L]START_DATE = gdat$(06,01,TAX_YEAR + 1) : [L]END_DATE = gdat$(05,02,TAX_YEAR + 1)
      When 11
        [L]START_DATE = gdat$(06,02,TAX_YEAR + 1) : [L]END_DATE = gdat$(05,03,TAX_YEAR + 1)
      When 12
        [L]START_DATE = gdat$(06,03,TAX_YEAR + 1) : [L]END_DATE = gdat$(05,04,TAX_YEAR + 1)
  Endcase

  If DATE_TO_FIND = "START"
    [L]RETDATE = [L]START_DATE
  Elsif DATE_TO_FIND = "END"
    [L]RETDATE = [L]END_DATE
  Endif
End [L]RETDATE

#**
#* Determines the amount held against a given payslip total/heading
#*
#* @param PAYSLIP Unique payslip identifier
#* @param VALUE_TO_FIND Heading or total to find the value for
#* @param TYPE_OF_VALUE Type number of the value to find, if 0 is supplied then parameter is ignored
#* @return The amount held for the given payslip total/heading, returns 0 if payslip total/heading doesn't exist
#*!
Funprog GET_PAYSLIP_VALUE (PAYSLIP, VALUE_TO_FIND, TYPE_OF_VALUE)
  Value Char PAYSLIP, VALUE_TO_FIND
  Value Integer TYPE_OF_VALUE
  Local Decimal RETVAL
  If clalev([F:HSPVAL])=0      : Local File HISTOPAYE     [HSPVAL]    : Endif

  If TYPE_OF_VALUE = 0
    Filter [HSPVAL] Where [HSPVAL]BUL = PAYSLIP and [HSPVAL]RUB = VALUE_TO_FIND
  Else
    Filter [HSPVAL] Where [HSPVAL]BUL = PAYSLIP and [HSPVAL]TYP = TYPE_OF_VALUE and [HSPVAL]RUB = VALUE_TO_FIND
  Endif

  For [HSPVAL]
    [L]RETVAL = [HSPVAL]AMT
  Next
End [L]RETVAL

#**
#* Determine the last payslip for the employee
#*
#* @param EMPLOYEE Employee reference
#* @param CTRNUM Employee Contract Number
#* @param CYCLE_START Start of the tax year
#* @param END_DATE End of the current pay period
#* @return The unique payslip identifier for the last payslip within the pay period
#*!
Funprog GET_LAST_PAYSLIP (EMPLOYEE, CTRNUM, CYCLE_START, END_DATE)
  Value Char EMPLOYEE, CTRNUM
  Value Date CYCLE_START, END_DATE
  Local Char RETVAL

  If clalev([F:VEPLAST])=0: Local File VALEMP [VEPLAST]    : Endif
  Filter [VEPLAST] Where EMP=[L]EMPLOYEE and PAYDAT >= [L]CYCLE_START and PAYDAT <= [L]END_DATE and CTRNUM = [L]CTRNUM Order By STRDAT
  Read [VEPLAST] Last
  Filter [VEPLAST]
  If !fstat
    [L]RETVAL = [VEPLAST]BUL
  Endif

End [L]RETVAL

#**
#* Determines if the employee should be excluded from the FPS output
#*   e.g. they are a leaver from a prior pay period and no payslip to report this period
#*   e.g. They are a new starter starting after the end of the pay period
#*
#* @param PERIOD_START FPS Pay period start date
#* @param PERIOD_END FPS Pay period end date
#* @param EMPLOYEE_REF Employee Refnum
#* @param CONTRACT_NUM Contract number
#* @param CONTRACT_START Contract start date
#* @return Returns 1 if the employee should be excluded, 0 if not.
#*!
Funprog EXCLUDE_EMPLOYEE(PERIOD_START, PERIOD_END, EMPLOYEE_REF, CONTRACT_NUM, CONTRACT_START )
  Value Date PERIOD_START, PERIOD_END, CONTRACT_START
  Value Char EMPLOYEE_REF, CONTRACT_NUM
  Local Integer RETVAL

  If clalev([F:CTREX])=0      : Local File EMPLOCTR     [CTREX]    : Endif
  If clalev([F:VEPEX])=0      : Local File VALEMP    [VEPEX]    : Endif

  Filter [F:CTREX] Where [F:CTREX]REFNUM = EMPLOYEE_REF and [F:CTREX]CTRNUM = CONTRACT_NUM and [F:CTREX]CTRDAT = CONTRACT_START
  Read [F:CTREX] Last
  Filter [F:CTREX]

  # Check if the employee has left prior to the period start date
  If !fstat and [F:CTREX]XITDAT <> [00/00/0000] and [F:CTREX]XITDAT < PERIOD_START

    # Check if the employee has a payslip after the period start date
    Filter [F:VEPEX] Where [F:VEPEX]EMP = EMPLOYEE_REF and [F:VEPEX]CTRNUM = CONTRACT_NUM and [F:VEPEX]CTRDAT = CONTRACT_START and [F:VEPEX]PYRDAT >= PERIOD_START
    Read [F:VEPEX] Last
    Filter [F:VEPEX]

    # Employee left in a prior period and has no payslips in this period
    If fstat
      [L]RETVAL = 1
    Endif
  # check if the employee started after the end of the period end date
  Elsif !fstat and [F:CTREX]CTRDAT <> [00/00/00] and [F:CTREX]CTRDAT > PERIOD_END
    [L]RETVAL = 1
  Endif
End [L]RETVAL

#**
#* Determines if the current contract has an end date, if so looks for an open ended contract
#*
#* @param PERIOD_START FPS Pay period start date
#* @param PERIOD_END FPS Pay period end date
#* @param EMPLOYEE_REF Employee Refnum
#* @param CONTRACT_NUM Contract number
#* @param CONTRACT_END_DATE Contract end date
#* @return Returns 1 if the employee has another open ended contract, 0 if not.
#*!
Funprog MULTI_CONTRACT_IN_PERIOD(PERIOD_START, PERIOD_END, EMPLOYEE_REF, CONTRACT_NUM, CONTRACT_END_DATE)
  Value Date PERIOD_START, PERIOD_END, CONTRACT_END_DATE
  Value Char EMPLOYEE_REF, CONTRACT_NUM
  Local Integer RECORD_FOUND, RETVAL
  [L]RECORD_FOUND = 0
  [L]RETVAL = 0

  If CONTRACT_END_DATE <> [00/00/00]
    If CONTRACT_END_DATE >= PERIOD_START and CONTRACT_END_DATE < PERIOD_END
      If clalev([F:CTR9])=0: Local File EMPLOCTR [CTR9]: Endif
      # Assume only future dated opened ended contract permitted and that each contract date continues on from the last
      # i.e. no break in dates
      Filter [F:CTR9] Where REFNUM = [L]EMPLOYEE_REF and CTRNUM = [L]CONTRACT_NUM and (CTRDAT > [L]CONTRACT_END_DATE and CTRDAT >= PERIOD_START and CTRDAT <= PERIOD_END)
      Read [F:CTR9] First
      Filter [F:CTR9]
      [L]RETVAL = (fstat = [L]RECORD_FOUND)
    Endif
  Endif
End [L]RETVAL

