#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du masque RQW3
##########################################################################################################
Subprog C_GNRQTY(VALEUR)
Variable Decimal VALEUR

Local Integer INBLIG

  INBLIG = 999 - [M:RQW1]NBLIG
  If VALEUR > INBLIG Then
    #La quantité maximum saisissable est NNNN
    GMESSAGE = mess(86,182,1) - ":" - num$(INBLIG)
    GERR = 2
    mkstat = 2
  Endif
  If VALEUR < 2 Then
    #La quantité saisie doit être supérieure à 1.
    GMESSAGE = mess(87,182,1)
    GERR = 2
    mkstat = 2
  Endif
End

