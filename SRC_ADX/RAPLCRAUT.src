#<AdxTL>@(#)12.0.0.0 $Revision$ Rapprochement LCR automatique
## GH 05/01/2001 on ne pas utiliser cette fonction en batch
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
PARBOUT(1)="2" : # 0 : Saisie de critère auto sans trt, sinon saisie + trt
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"RAPLCRAUT"
 GFONCTION="RAPLCRAUT" : Call AUTORIS From EXEFNC
Endif
GACTION = "RAPLCRAUT" 
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","RAPLCRAUT","DLCRAUT",4,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#####
$INIT
#####
If !clalev([M:RLA]) : Local Mask RAPLCRAUT [RLA] : Endif
Return

############
$OUVRE_BOITE
############
If PARAM(1)<>"0"
 Call LECMEMO("STD","[M:RLA]","lcr") From GMEMO
Endif
Return

######
$DEBUT
######
Affzo [RLA]
If PARAM(1)="0"
 Grizo [RLA]BAN
 If dim([M:RLA]ZBAN)>0 : Grizo  [RLA] ZBAN : Endif
Endif
Onerrgo CHUT From CONTROLE
If PARAM(1)<>"0" & !clalev([F:BAN])  : Local File BANK  [BAN] : Endif
If !clalev([F:ATX])  : Local File ATEXTE  [ATX] : Endif
If !clalev([F:ATY])  : Local File ATYPE   [ATY] : Endif
If !clalev([F:ATZ])  : Local File ATABZON [ATZ] : Endif
Onerrgo
If GERREUR : GERREUR=0 : Endif
Return

#########
$CONTROLE
#########
If  PARAM(1)="0" | GSTATUT<>GSTAOK : FIN=1 : Endif
Return

########
$TERMINE
########
If clalev([M:RLA]) : Close Local Mask [RLA] : Endif
Return

#####
$EXEC 
#####
Onerrgo ERREUR From CONTROLE
If clalev([F:BES])=0  : Local File BILSTA    [BES]  : Endif 
If clalev([F:BES2])=0 : Local File BILSTA    [BES2] : Endif
If clalev([F:PYH])=0  : Local File PAYMENTH  [PYH]  : Endif 
If clalev([F:PYH2])=0 : Local File PAYMENTH  [PYH2] : Endif 
If clalev([F:TPY])=0  : Local File TABPAYTYP [TPY]  : Endif 
If clalev([F:BAN])=0  : Local File BANK      [BAN]  : Endif
If clalev([F:FRM])=0  : Local File PAYFRM    [FRM]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

Local Integer OK, TROUVE, STAT, I, NBEFFETS, NBRAPP
Local Decimal MNTEFFETS , MNTRAPP , MNT
Local Char    CRITERE(255), CRITERE2(255), CRITERE3(255)
Local Char    CLE(GLONVCR), CLE_SAV(GLONVCR), SYMBOLE(30), PAYTYP(GLONTPY), PAYTYP2(GLONTPY), OFONCTION(10)
Local Date    DATJ
Local Integer OK2

Local Char SUBCRIT(255)(1..4), SUBCRIT2(255)
Local Integer ICRIT

Gosub CRITTPY  
If [L]SUBCRIT="" 
 # Pas de type de règlement concerné par les domiciliations 
 GERR=1 : GMESSAGE=mess(183,117,1) : Return 
Endif 

If !GSERVEUR & GTRACE=""
 # Rapprochement automatique
 Call OUVRE_TRACE(mess(153,117,1)) From LECFIC
Endif
 
# Critères obligatoires   
[L]CRITERE = "STA<8 & FRMNUM='' & CPY=[F:BES]CPY & BAN=[F:BES]BAN & CUR=[F:BES]CUR"  
&            -"& AMTCUR=[F:BES]AMTCUR & DUDDAT=[F:BES]DUDDAT" 
OFONCTION = GFONCTION
GFONCTION = "GESPAY"
Call AUTORIS From EXEFNC
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 [L]CRITERE -= "& find(FCY,GUSRFCY(1..GNBAUZ))"
Endif
GFONCTION = OFONCTION
Call AUTORIS From EXEFNC

For I=0 To [M:RLA]NB-1
 If [M:RLA]FLG(I)=2   :# Critère obligatoire  
  If [M:RLA]TYPTYP(I)<>7   :# <> de chaine de caractère
   [L]CRITERE -= "&"-[M:RLA]FICPAY(I)+"=[F:BES]"+[M:RLA]FICBAN(I)
  Endif
 Endif 
Next I

Call LECTURE("BAN",[M:RLA]BAN,"") From CONTOBJ

# Relevés non exportés
CRITERE3 = "BAN='"+[M:RLA]BAN+"' & LIN=0 & FLGEXP=1"  
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 CRITERE3 -= "& find(FCY,GUSRFCY(1..GNBAUZ))"
Endif

For [BES2]BES0 Where evalue(CRITERE3)
 SYMBOLE = "FRM"+[F:BES2]FRMNUM+"\2"
 Lock =SYMBOLE With lockwait=0 
 If fstat 
  If GTRACE<>""
   # Modification en cours sur un autre poste 
   Call ECR_TRACE([F:BES2]FRMNUM-mess(10,100,1),1) From GESECRAN 
  Endif
 Else
  # Pour ne pas prendre les lignes de relevé qui ne sont pas rapprochées mais 
  # dont l'avis de domiciliation est validé.
  Read [FRM]FRM0 = 2;[F:BES2]FRMNUM
  If fstat | [F:FRM]STA<>9
   # Recherche type de règlement
   Raz [L]PAYTYP
   Read [PYH]PYH1(2) = 2;[F:BES2]FRMNUM
   If fstat<=2 : [L]PAYTYP = [F:PYH]PAYTYP : Endif
   For [BES]BES0 Hint Key BES1 Where FRMNUM=[F:BES2]FRMNUM & LIN>0 & PAYNUM="" & FLGANO=1
    [L]NBEFFETS += 1 
    Raz [L]MNT   
    If [F:BES]CUR<>[F:BAN]CUR 
     Call CONVERT([F:BES]CUR,[F:BAN]CUR,"",0,datesyst,[F:BES]AMTCUR,[L]MNT,STAT) From TRTDEV
    Else 
     [L]MNT = [F:BES]AMTCUR
    Endif 
    [L]MNTEFFETS += [L]MNT 
    If [L]PAYTYP<>""
     Filter [PYH] Where evalue([L]CRITERE) & evalue([L]SUBCRIT) & PAYTYP=[L]PAYTYP
    Else
     Filter [PYH] Where evalue([L]CRITERE) & evalue([L]SUBCRIT)
    Endif
    Gosub BOUCLE_PYH  
    Case J 
     When 0       :# Rien ne correspond -> on passe à la suite 
     When 1       :# 1 seul règlement -> on rapproche
      Call DEBTRANS From GLOCK
      Gosub RAPPROCH 
     When Default :# Plusieurs -> il faut d'autres critères  
      Gosub CRITERES 
    Endcase 
   Next 
  Endif
  Unlock =SYMBOLE 
 Endif
Next 
Filter [PYH]   

If [L]NBRAPP 
 Call ECR_TRACE(" ",0) From GESECRAN
Endif  
# ... effets traités Montant =
Call ECR_TRACE(num$([L]NBEFFETS)-mess(184,117,1)-num$([L]MNTEFFETS)-[F:BAN]CUR,0) From GESECRAN
# ... effets rapprochés Montant =  
Call ECR_TRACE(num$([L]NBRAPP)-mess(185,117,1)-num$([L]MNTRAPP)-[F:BAN]CUR,0) From GESECRAN 
If [L]NBEFFETS<>0 
 # % de réussite
 Call ECR_TRACE(num$(ar2([L]NBRAPP*100/[L]NBEFFETS))-mess(186,117,1),0) From GESECRAN 
Endif 

If !GSERVEUR & GTRACE<>"" 
 Call FERME_TRACE From LECFIC
 TRA=1
Endif
Return

########
$CRITTPY
########
Raz [L]SUBCRIT, [L]SUBCRIT2, ICRIT
For [F:TPY]TPY0 Where STA7=2 & ENAFLG=2
 If dim([F:TPY]ACS)>0
  Call CONTEXE([F:TPY]ACS) From CPTSUB
  If !mkstat : OK=1 : Else : mkstat=0 : OK=0 : GMESSAGE="" : Endif
 Else
  OK=1
 Endif
 If OK=1
  If SUBCRIT2="" : [L]SUBCRIT2="(" : Else : [L]SUBCRIT2="|" : Endif
  [L]SUBCRIT2 -= "(PAYTYP='"+[F:TPY]PAYTYP+"'"
  If [F:TPY]STA6=2    : [L]SUBCRIT2 -= "& STA>=6)"
  Elsif [F:TPY]STA5=2 : [L]SUBCRIT2 -= "& STA>=5)"
  Elsif [F:TPY]STA3=2 : [L]SUBCRIT2 -= "& STA>=3)"
  Elsif [F:TPY]STA2=2 : [L]SUBCRIT2 -= "& STA>=2)"
  Else                : [L]SUBCRIT2+=")"
  Endif
  Call ADDCRIT(SUBCRIT, ICRIT,"PAYTYP",[L]SUBCRIT2," ") From GOBJSUB
 Endif
Next
If SUBCRIT2<>""
 Call ADDCRIT(SUBCRIT,ICRIT,"PAYTYP",')',"") From GOBJSUB
Endif
Return

###########
$BOUCLE_PYH 
###########
J=0 : [L]CLE="" 
For [PYH]PYH0
 OK2 = 1
 For I=0 To [M:RLA]NB-1
  If [M:RLA]FLG(I)=2   :# Critère obligatoire  
   If [M:RLA]TYPTYP(I)=7   :# Chaine de caractère  
    If [M:RLA]NBRCAR(I)=0  
     If evalue("vireblc(toupper(ctrans([F:PYH]"+[M:RLA]FICPAY(I)+")),4)")
&     = evalue("vireblc(toupper(ctrans([F:BES]"+[M:RLA]FICBAN(I)+")),4)")
      OK2 = 1
     Else
      OK2 = 0 : Break
     Endif
    Else   :# [M:RLA]NBRCAR(I)<>0
     If evalue("left$(vireblc(toupper(ctrans([F:PYH]"+[M:RLA]FICPAY(I)+")),4),"+num$([M:RLA]NBRCAR(I))+")")
&     = evalue("left$(vireblc(toupper(ctrans([F:BES]"+[M:RLA]FICBAN(I)+")),4),"+num$([M:RLA]NBRCAR(I))+")")
      OK2 = 1
     Else
      OK2 = 0 : Break
     Endif
    Endif
   Endif
  Endif
 Next
 If OK2
  If [L]CLE="" : [L]CLE = [F:PYH]NUM : Endif
  J+=1 
 Endif
Next 
Return 

######### 
$CRITERES
######### 
# Recherche d'autres critères de rapprochement 
Raz [L]TROUVE, [L]CRITERE2 
[L]CLE_SAV = [L]CLE
For I=0 To [M:RLA]NB-1  
 If [M:RLA]FLG(I)=1   :# Critères facultatifs
  If [L]CRITERE2<>"" : [L]CRITERE2 -= "& " : Endif 
  If [M:RLA]TYPTYP(I)=7   :# Chaine de caractère 
   If [M:RLA]NBRCAR(I)=0
    CRITERE2 += "vireblc(toupper(ctrans("+[M:RLA]FICPAY(I)+")),4)" 
&            + "=vireblc(toupper(ctrans([F:BES]"+[M:RLA]FICBAN(I)+")),4)" 
   Endif 
  Else
   CRITERE2 += [M:RLA]FICPAY(I)+"=[F:BES]"+[M:RLA]FICBAN(I)
  Endif 
  If [L]PAYTYP<>""
   Filter [F:PYH] Where evalue([L]CRITERE) & evalue([L]SUBCRIT) & evalue([L]CRITERE2) & PAYTYP=[L]PAYTYP
  Else
   Filter [F:PYH] Where evalue([L]CRITERE) & evalue([L]SUBCRIT) & evalue([L]CRITERE2) 
  Endif
  Gosub BOUCLE_PYH 
  Case J 
   When 0  :# Rien ne correspond -> on prend le premier 
    [L]CLE = [L]CLE_SAV : 
    Call DEBTRANS From GLOCK
    Gosub RAPPROCH
    [L]TROUVE=1 
   When 1  :# 1 seul règlement -> on rapproche
    Call DEBTRANS From GLOCK
    Gosub RAPPROCH
    [L]TROUVE=1 
   When Default :# Plusieurs -> on passe au critère facultatif suivant 
    [L]CLE_SAV = [L]CLE 
  Endcase 
  If [L]TROUVE : break : Endif   
 Endif   
Next I
If ![L]TROUVE
 [L]CLE = [L]CLE_SAV
 Call DEBTRANS From GLOCK
 Gosub RAPPROCH 
Endif 
Return

#########
$RAPPROCH
######### 
# Rapprochement 
GOK=1 : [L]DATJ=date$
Trbegin [PYH2] , [BES] , [FRM]

 # MAJ de PAYMENTH
 Readlock [PYH2]PYH0=[L]CLE
 If fstat=1
  GOK=-1 : GLOCK="$PAYMENTH"-[L]CLE : Goto ROLL_TR
 Elsif fstat
  GOK=0 : Call RSTA("PYH2",[L]CLE) From GLOCK : Goto AB_TR
 Endif
 [L]PAYTYP2 = [F:PYH2]PAYTYP
 [F:PYH2]FRMNUM    = [F:BES]FRMNUM
 [F:PYH2]FRMLIN    = [F:BES]LIN 
 [F:PYH2]FRMFLG    = 2
 [F:PYH2]STA       = 7
 [F:PYH2]STAFLG(6) = 2 
 [F:PYH2]PABFLG    = 2 
 Raz [F:PYH2]PABREN, [F:PYH2]PABAMTPRT
 [F:PYH2]FRMDAT    = [L]DATJ 
 [F:PYH2]FRMUSR    = GUSER
 [F:PYH2]FRMFCY    = [F:BES]FCY
 If [F:PYH2]FRMTYP<1 : [F:PYH2]FRMTYP = 1 : Endif
 # Point d'entrée CRERAP : mise à jour des champs std ou spé du règlement (16060)
 GPOINT = "CRERAP" : Gosub ENTREE From EXEFNC

 Rewrite [PYH2]
 If fstat
  GOK=0 : Call FSTA("PYH2") From GLOCK : Goto AB_TR
 Endif

 # MAJ de BILSTA
 Readlock [BES] Curr
 If fstat=1
  GOK=-1 : GLOCK="$BILSTA"-[F:BES]FRMNUM-num$([F:BES]LIN) : Goto ROLL_TR
 Elsif fstat
  GOK=0 : Call RSTA("BES",[F:BES]FRMNUM-num$([F:BES]LIN)) From GLOCK : Goto AB_TR
 Endif
 [F:BES]PAYNUM = [L]CLE 
 Raz [F:BES]PABFLG 
 Raz [F:BES]PABREN 
 Raz [F:BES]PABAMTPRT
 Rewrite [BES]
 If fstat
  GOK=0 : Call FSTA("BES") From GLOCK : Goto AB_TR
 Endif
 
 Read [FRM]FRM0 = 2;[F:BES]FRMNUM
 If fstat>=2
  # Création de PAYFRM
  Raz [F:FRM]
  [F:FRM] = [F:PYH2]
  If dim([F:FRM]UPDDAT)>0 : Raz [F:FRM]UPDDAT : Endif
  If dim([F:FRM]UPDUSR)>0 : Raz [F:FRM]UPDUSR : Endif
  If dim([F:FRM]CREDAT)>0 : [F:FRM]CREDAT=[L]DATJ : Endif
  If dim([F:FRM]CREUSR)>0 : [F:FRM]CREUSR=GUSER   : Endif
  Write [FRM]
  If fstat
   GOK=0 : Call FSTA("FRM") From GLOCK : Goto AB_TR
  Endif
 Else
  If dim([F:FRM]UPDDAT)>0 : [F:FRM]UPDDAT=[L]DATJ : Endif
  If dim([F:FRM]UPDUSR)>0 : [F:FRM]UPDUSR=GUSER   : Endif
  Rewrite [FRM]
  If fstat
   GOK=0 : Call FSTA("FRM") From GLOCK : Goto AB_TR
  Endif
#  Update [PYH2] Where FRMTYP=2 & FRMNUM=[F:BES]FRMNUM & NUM<>[F:PYH2]NUM
#&               With  FRMDAT=[L]DATJ, FRMUSR=GUSER
#  If fstat=1
#   GOK = -1 : GLOCK = "$PAYMENTH"-"2"-[F:BES]FRMNUM : Goto ROLL_TR
#  Elsif fstat
#   GOK = 0 : Call RSTA("PYH2","2"-[F:BES]FRMNUM) From GLOCK : Goto AB_TR
#  Endif
  ## <PP 28/10/02> Bug 16332, on remplace ce qui est au dessus par : 
  Update [PYH2] Where FRMFLG=2 & FRMNUM=[F:BES]FRMNUM & NUM<>[L]CLE
&               With  FRMDAT=[L]DATJ, FRMUSR=GUSER
  If fstat=1
   GOK = -1 : GLOCK = "$PAYMENTH"-"2"-[F:BES]FRMNUM : Goto ROLL_TR
  Endif
  fstat = 0 : # Car le update renvoie un fstat à 4 s'il ne trouve rien... 
  ## <Fin PP> 
 Endif
Commit 
[L]NBRAPP  += 1 
[L]MNTRAPP += [L]MNT
If [L]PAYTYP="" : [L]PAYTYP = [L]PAYTYP2 : Endif
If GTRACE<>""
 # Avis de domiciliation FRMNUM <- Règlement NUM
 Call ECR_TRACE(mess(123,117,1)-[F:PYH2]FRMNUM-"<-"-mess(27,117,1)-[F:PYH2]NUM,0) From GESECRAN 
Endif
Return

$ROLL_TR
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto RAPPROCH : Endif

$AB_TR
Rollback
Return

####################################  
## Etiquette de l'écran RAPLCRAUT ##  
####################################  
  
Subprog C_FICPAY(VALEUR) 
Variable Char     VALEUR 
If find(VALEUR,"STA","BAN","CUR","AMTCUR","DUDDAT","PAYTYP") 
 # Critère obligatoire  
 GMESSAGE = mess(194,117,1) 
 mkstat=2 : End 
Endif
Local Integer I 
I=find(VALEUR,[M:RLA]FICPAY) 
If I & I<>nolign 
 # Code déjà saisi en ligne
 GMESSAGE = mess(29,100,1)-num$(I) 
 mkstat=2 : End 
Endif  
If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
If !clalev([F:ATY]) : Local File ATYPE   [ATY] : Endif
If !clalev([F:ATX]) : Local File ATEXTE  [ATX] : Endif
Read [ATZ]CODZONE="PAYMENTH";VALEUR 
If fstat  
 # Champ inexistant 
 GMESSAGE = mess(41,100,1) : mkstat=2 : End
Endif
# Affichage intitulé 
Read [ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT 
[M:RLA]PAYNAM(nolign-1) = [F:ATX]TEXTE     
# Type de la zone  
Read [ATY]CODTYP=[F:ATZ]CODTYP  
[M:RLA]TYPTYP(nolign-1) = [F:ATY]TYPTYP
End 
  
Subprog S_FICPAY(VALEUR)
Variable Char     VALEUR
Local Char ABREV(5) , FIC(10) 
[L]FIC = "PAYMENTH"
Call SELVAR([L]FIC,ABREV,VALEUR) From SELFIC
End 

Subprog C_FICBAN(VALEUR) 
Variable Char     VALEUR
Local Integer I 
I=find(VALEUR,[M:RLA]FICBAN)  
If I & I<>nolign  
 # Code déjà saisi en ligne
 GMESSAGE = mess(29,100,1)-num$(I)  
 mkstat=2 : End  
Endif   
If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
If !clalev([F:ATY]) : Local File ATYPE   [ATY] : Endif
If !clalev([F:ATX]) : Local File ATEXTE  [ATX] : Endif
Read [ATZ]CODZONE="BILSTA";VALEUR 
If fstat  
 # Champ inexistant
 GMESSAGE = mess(41,100,1) 
 mkstat=2 : End 
Endif
# Vérification du type  
Read [ATY]CODTYP=[F:ATZ]CODTYP 
If [F:ATY]TYPTYP<>[M:RLA]TYPTYP(nolign-1) 
 # Les zones doivent être de même type
 GMESSAGE = mess(195,117,1) 
 mkstat=2 : End 
Endif
Read [ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT 
[M]BANNAM(nolign-1) = [F:ATX]TEXTE  
End  

Subprog S_FICBAN(VALEUR) 
Variable Char     VALEUR 
Local Char ABREV(5) , FIC(10)  
[L]FIC = "BILSTA"  
Call SELVAR([L]FIC,ABREV,VALEUR) From SELFIC  
End 
   
Subprog AS_NBRCAR(VALEUR)
Variable Decimal  VALEUR
If [M]TYPTYP(nolign-1)<>7 : mkstat=1 : Endif
End

