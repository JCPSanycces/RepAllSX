#<AdxTL>@(#)3.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT GROUPS OF SITES
##############################################################################################################
# CTL_SITE     : Checks that a given site is correct compared to a site/company/group of sites
# CTL_FCYCPY   : Checks that a given site/company is correct compared to a site/company/group of sites
##############################################################################################################

#**
#* Checks that a site is correct compared to a site/company/group of sites
#*
#* @param ACTX    Context
#* @param CPYFCY  Site, company or group of sites
#* @param FCY     Site
#* @param VALEUR  Value to check (the account, the dimension, ...)
#* @param ERRMES  Error message
#*!

Funprog CTL_SITE(ACTX,CPYFCY,FCY,VALEUR,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    CPYFCY  : # Site, company or group of sites
Value    Char    FCY     : # Site
Value    Char    VALEUR  : # Value to check (the account, the dimension, ...)
Variable Char    ERRMES  : # Error message

Local Integer ASTATUS

[L]ASTATUS = [V]CST_AOK
If CPYFCY="" : End [L]ASTATUS : Endif

If adxtyp=33 | !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If adxtyp=33 | !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
If adxtyp=33 | !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif

Call LEC_FCY(CPYFCY) From CPTLEC
If fstat=[V]CST_AOK
 If CPYFCY<>FCY
  ERRMES = VALEUR-":"-mess(64,133,1)-CPYFCY
  [L]ASTATUS = [V]CST_AERROR
 Endif
Else
 Call LEC_CPY(CPYFCY) From CPTLEC
 If !fstat & [F:CPY]CPYLEGFLG=2
  Call LEC_FCY(FCY) From CPTLEC
  If  [F:FCY]LEGCPY<>CPYFCY
   ERRMES = VALEUR-":"-mess(65,133,1)-CPYFCY
   [L]ASTATUS = [V]CST_AERROR
  Endif
 Else
  Read [FGR]FGR0 = CPYFCY;FCY
  If fstat<>[V]CST_AOK
   ERRMES = VALEUR-":"-mess(66,133,1)-CPYFCY
   [L]ASTATUS = [V]CST_AERROR
  Endif
 Endif
Endif

End [L]ASTATUS

#ISSUE 85535 - 2018-05-08 by MNO
#**
#* Checks that a site/company is correct compared to a site/company/group of sites
#*
#* @param ACTX    Context
#* @param CPYFCY  Site, company or group of sites
#* @param CPYFCYTOCTL     Site
#* @param VALEUR  Value to check (the account, the dimension, ...)
#* @param ERRMES  Error message
#*
#*!
Funprog CTL_FCYCPY(ACTX,CPYFCY,CPYFCYTOCTL,VALEUR,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    CPYFCY       : # Site, company or group of sites
Value    Char    CPYFCYTOCTL  : # Site or company to control against CPYFCY. Has the first value, we just use on variable. We'll check if it's a company or site on the function itself
Value    Char    VALEUR       : # Value to check (the account, the dimension, ...)
Variable Char    ERRMES       : # Error message

Local Integer ASTATUS
[L]ASTATUS = [V]CST_AOK
If CPYFCY="" : End [L]ASTATUS : Endif

If adxtyp=33 | !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If adxtyp=33 | !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
If adxtyp=33 | !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
If adxtyp=33 | !clalev([F:AGC]) : Local File AGRPCPY  [AGC] : Endif #Company group. This has the companies that belong to a group (when we have no site)

Call LEC_FCY(CPYFCY) From CPTLEC
If fstat=[V]CST_AOK #CPYFCY is a site, so CPYFCYTOCTL only valid if: is a site and the same site
 If CPYFCY<>CPYFCYTOCTL
  ERRMES = VALEUR-":"-mess(64,133,1)-CPYFCY
  [L]ASTATUS = [V]CST_AERROR
 Endif
Else
 Call LEC_CPY(CPYFCY) From CPTLEC
 If !fstat & [F:CPY]CPYLEGFLG=2 #CPYFCY is a company, so CPYFCYTOCTL only valid if: is a company and the same company; or is a site of that company
  If CPYFCY<>CPYFCYTOCTL        #check if the same company. this will allows to call this funprog more safelly. today this is done on CNSCPTSTD (if the values are the same, we don't call the control)
   Call LEC_FCY(CPYFCYTOCTL) From CPTLEC #if not, check if is a site from that company
   If  [F:FCY]LEGCPY<>CPYFCY
    ERRMES = VALEUR-":"-mess(65,133,1)-CPYFCY
    [L]ASTATUS = [V]CST_AERROR
   Endif
  Endif
 Else                          #CPYFCY is a group, so CPYFCYTOCTL only valid if: is a group and the same group; or is a company from that group; or is a site of that group
  Read [AGC]AGC0 = CPYFCY;CPYFCYTOCTL #checking if it's a company of the group
  If fstat<>[V]CST_AOK
   Read [FGR]FGR0 = CPYFCY;CPYFCYTOCTL #checking if it's a site of the group
   If fstat<>[V]CST_AOK
    ERRMES = VALEUR-":"-mess(66,133,1)-CPYFCY
    [L]ASTATUS = [V]CST_AERROR
   Endif
  Endif
 Endif
Endif

End [L]ASTATUS
#END ISSUE 85535

