#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: CUSSEALIB
# Description : Customer Search Library
# Author      : GRNA
####################################################################################

# Called from CNSCSDSTD,CNSCSFSTD,CNSCSISTD,CNSCSLSTD,CNSCSNSTD,
#             CNSCSOSTD,CNSCSPSTD,CNSCSQSTD,CNSCSRSTD,CNSCSTSTD
####################################################################################
$LECTURE

# When coming from Customer Search, disable Sold-to
If find(GNAVIG(GPILNAV-1),"FUNCUSSEA") & [M:CSE]SELECT<>""
  Case CUSSEAORI
    When "CSD1" : Diszo [M:CSD1]BPCORD
    When "CSF1" : Diszo [M:CSF1]BPCORD
    When "CSI1" : Diszo [M:CSI1]BPCINV
    When "CSL1" : Diszo [M:CSL1]BPCORD
    When "CSN1" : Diszo [M:CSN1]BPCNUM
    When "CSO1" : Diszo [M:CSO1]BPCORD
    When "CSP1" : Diszo [M:CSP1]BPCORD
    When "CSQ1" : Diszo [M:CSQ1]BPCORD
    When "CSR1" : Diszo [M:CSR1]BPCNUM
    When "CST1" : Diszo [M:CST1]BPCINV
  Endcase
Endif

Return


# Called from FUNVENSPSI
####################################################################################
$DEBUT_SAISPSI

If dim([M:CSE]SELECT)<=0 : Return : Endif

If [M:CSE]SELECT<>""
    Read [BPC]BPC0=[M:CSE]SELECT
    If !fstat
        [M:SPM0]BPCORD = [M:CSE]SELECT
        Call AM_BPCORD([M:CSE]SELECT) From FUNVENSPSI
        [M:SPM0]LIBBPC = [F:BPC]BPCNAM
        [M:SPM0]CUR    = [F:BPC]CUR
        Diszo [M:SPM0]BPCORD
    Endif
    Read [BPR]BPR0=[M:CSE]SELECT
Endif

Return


# Called from SUBMAC,SUBSRHA
####################################################################################
$AVANT_CHOI

If GCREFONC=1
    REPONSE=GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    Case CUSSEAORI
      When "SRH0" : Diszo [M:SRH0]BPCORD
    Endcase
    GCREFONC=0
Endif

Return


# Called from SUBSOHA,SUBSQHA,SUBSRHA
# CUSSEAPAR = parameter (i.e. TRSCSORD,TRSCSQUO,TRSCSRET)
####################################################################################
$DEFTRANS

If GCREFONC<>1 | !find(GNAVIG(GPILNAV-1),"FUNCUSSEA") : Return : Endif

Call PARAMUTIL(CUSSEAPAR,GFLAG,"",GFCYDEF(5)) From SUBAUS

Return


# Called from SUBSOHA,SUBSQHA,SUBSIHA,SUBSRHA
####################################################################################
$RAZCRE

If GCREFONC<>1 | !find(GNAVIG(GPILNAV-1),"FUNCUSSEA") : Return : Endif

# After change
If CUSSEAORI="SRH0" & [M:SRH0]BPCORD<>""
    If [F:BPC]BPCNUM<>[M:SRH0]BPCORD  # 84991
        Read [BPC]BPC0=[M:SRH0]BPCORD
        If fstat : Return : Endif
    Endif
    Call AM_BPCORD([M:SRH0]BPCORD) From SUBSRH
Endif

Call SET_BPAADD(CUSSEAORI,[M:CSE]SBPAADD)

Return


####################################################################################
$AM_BPRNUM

If dim(GCUSSEAADD)<=0 | GCUSSEAADD="" : Return : Endif

Call SET_BPAADD(CUSSEAORI,GCUSSEAADD)

Kill GCUSSEAADD

Return


####################################################################################
Subprog SET_BPAADD(AMK,VALEUR)
Value    Char AMK
Variable Char VALEUR

If VALEUR=evalue("[M:"+AMK+"]BPAADD") : End : Endif

Case AMK
  When "SOH1" : Default Mask [SOH1]
  When "SQH1" : Default Mask [SQH1]
  When "SDH0" : Default Mask [SDH0]
  When "SIH1" : Default Mask [SIH1]
  When "SRH0" : Default Mask [SRH0]
Endcase

Local Char W1AMK : W1AMK = "W1"+AMK
Call C_BPAADD(VALEUR)  From =W1AMK : If mkstat : End : Endif
Call AP_BPAADD(VALEUR) From =W1AMK : If mkstat : End : Endif
Call AM_BPAADD(VALEUR) From =W1AMK : If mkstat : End : Endif

Assign "[M:"+AMK+"]BPAADD" With VALEUR

End
