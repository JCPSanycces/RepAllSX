####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0CONCESSION
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_CPY From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_CCNREF From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_FCY From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_CCNDES1 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_CCNDES2 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_STRCCNDAT From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_ENDCCNDAT From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REAENDCCN From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_DFTCCNFLG From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_CCNSTA From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_CCNUSR From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_ACCCOD From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_DSP From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REFTAB1 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REFTAB2 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REFTAB3 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REFTAB4 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REFTAB5 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REFTAB6 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REFTAB7 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REFTAB8 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REFTAB9 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_REFTAB10 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDA1 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDA2 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDA3 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDA4 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDA5 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDA6 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDA7 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDA8 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDA9 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDA10 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDD1 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDD2 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDD3 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDD4 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDM1 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDM2 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDM3 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDM4 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDM5 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDM6 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDC1 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_USRFLDC2 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_CREORI From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_CREDAT From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_UPDDAT From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub INIT_NBDIE From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub AINIT From WMC0CONCESSION : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0CONCESSION
Gosub _ALOADATTRIBUTE_CPY From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_CCNREF From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_FCY From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_CCNDES1 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_ENDCCNDAT From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_CCNUSR From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_CREORI From WMC2CONCESSION : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0CONCESSION
Gosub LNKPRO_CPY From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_CCNREF From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_FCY From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_CCNUSR From WMC1CONCESSION : Gosub TESTALLSTAT
For AINDCLA=1 To 20
 If this.DIES(AINDCLA)<>null& find(this.DIES(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.DIES(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_USRFLDA1 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDA2 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDA3 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDA4 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDA5 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDA6 From WMC1CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDA7 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDA8 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDA9 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDA10 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDM1 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDM2 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDM3 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDM4 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDM5 From WMC2CONCESSION : Gosub TESTALLSTAT
Gosub LNKPRO_USRFLDM6 From WMC2CONCESSION : Gosub TESTALLSTAT
For AINDCLA=1 To maxtab(this.E51)
 If this.E51(AINDCLA)<>null& find(this.E51(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.E51(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



