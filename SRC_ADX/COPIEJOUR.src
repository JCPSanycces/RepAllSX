#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modifications :
#     FRRIC- 09/12/2011 - FQ 78339
#     SEGAY- 17/12/2011 - FQ 80179
######################################################################################

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "DEBUT"    : Gosub DEBUT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When Default
Endcase
Return

$INIT
Local Mask COPIEJOUR [COPJ]
If clalev([F:AMZ])=0  : Local File AMSKZON  [AMZ]  : Endif
If clalev([F:AMZ2])=0 : Local File AMSKZON  [AMZ2] : Endif
#LIPET - 10-01-2017 - X3-18688 - START
#If clalev([F:CTR])=0  : Local File EMPLOCTR [CTR]  : Endif
#If clalev([F:PEOX])=0 : Local File PERIOD   [PEOX] : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR]  : Endif
If clalev([F:HRPEOD])=0  : Local File HRPEODET   [HRPEOD]  : Endif
If clalev([F:HRPEOH])=0  : Local File HRPEOHEA    [HRPEOH]  : Endif
#LIPET - 10-01-2017 - X3-18688 - END
If clalev([F:WTY])=0  : Local File TYPWEEK  [WTY]  : Endif
If clalev([F:TIP])=0  : Local File TIMEMP   [TIP]  : Endif
If clalev([F:HLY])=0  : Local File HLYDAY   [HLY]  : Endif
If clalev([F:PLN])=0  : Local File PLANTYP  [PLN]  : Endif
Local Date    DATCOP
Local Integer I, J, K, L, NOL, NBPLG
Local Integer SEMAINE, ANNEE
Local Char    MOIDEB(2), MOIFIN(2), PDEB(20), PFIN(20)
#SEGAY- 17/12/2011 - FQ 80179
#Local Char    LTIM1
Return

$DEBUT
Raz [M:COPJ]
Local Char CAR1,CAR2
Local Integer NUMDAT
Local Integer I, J, K, DEB, FIN, IND
# Initialisation de la date début avec la zone courante
[M:COPJ]TYP = PARAM(2)
Case [M:COPJ]TYP
 When "1" : # Planning opérationnel
  CAR1 = mid$(PARAM(1),len(PARAM(1))-1,1)
  CAR2 = right$(PARAM(1),len(PARAM(1)))
  NUMDAT = find(CAR1,"1","2","3","4","5","6","7")
  If NUMDAT=0
   NUMDAT = find(CAR2,"1","2","3","4","5","6","7")
  Endif
  If NUMDAT<>0
   # FQ92876 - 05/06/14 - On a maintenant un onglet par plage horaire
#   [M:COPJ]STRDAT = evalue("[M:PLE]DAT("+num$(NUMDAT-1)+")")
   [M:COPJ]STRDAT = evalue("[M:PLE0]DAT("+num$(NUMDAT-1)+")")
  Endif
#  [M:COPJ]ENDDAT = [M:PLE]DAT(6)
  [M:COPJ]ENDDAT = [M:PLE0]DAT(6)
 When "2" : # Feuille des temps
  If left$(PARAM(1),6)="STRTIM" | left$(PARAM(1),6)="ENDTIM"
   CAR2 = mid$(PARAM(1),len(PARAM(1))-1,1)
  Else
   CAR2 = right$(PARAM(1),len(PARAM(1)))
  Endif
  NUMDAT = find(CAR2,"1","2","3","4","5","6","7")
  If NUMDAT<>0
   [M:COPJ]STRDAT = evalue("[M:TPSJ]DAT("+num$(NUMDAT-1)+")")
  Endif
  [M:COPJ]ENDDAT = [M:TPSJ]DAT(6)
Endcase
Return

$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
Endif
Return

$EXEC
Case [M:COPJ]TYP
 When "1" : # Planning opérationnel
  Call DEBTRANS From GLOCK
  # FQ92876 - 05/06/14 - On a maintenant un onglet par plage horaire
#  I = find([M:COPJ]STRDAT,[M:PLE]DAT(0..6))
  I = find([M:COPJ]STRDAT,[M:PLE0]DAT(0..6))
  [L]DATCOP = [M:COPJ]STRDAT+1
  If GNBHOR=0
   NBPLG = 1
  Else
   NBPLG = GNBHOR
  Endif
  While [L]DATCOP<=[M:COPJ]ENDDAT
   If [M:COPJ]JDAY(dayn([L]DATCOP)-1)=2        : # Recopie sur un jour de semaine coché
    # FQ92876 - 05/06/14 - On a maintenant un onglet par plage horaire
#    Read [HLY]HLY0 = year([L]DATCOP);[M:PLE]FCY
    #ADNGO - 26-01-2017 - X3-18688 - START
    #Read [HLY]HLY0 = year([L]DATCOP);[M:PLE0]FCY
    Read [HLY]HLY0 = year([L]DATCOP);[M:PLE0]FCY;GCURLEG
    #ADNGO - 26-01-2017 - X3-18688 - END
    If fstat
    #ADNGO - 26-01-2017 - X3-18688 - START
     #Read [HLY]HLY0 = year([L]DATCOP);""
     Read [HLY]HLY0 = year([L]DATCOP);"";GCURLEG
    #ADNGO - 26-01-2017 - X3-18688 - END
    Endif
    If fstat or find([L]DATCOP,[F:HLY]HLYDAY)=0 : # Pas de recopie sur jour férié
     Gosub TRPLE
    Endif
   Endif
   [L]DATCOP +=1
  Wend
 When "2" : # Feuille des temps
  Call DEBTRANS From GLOCK
  I = find([M:COPJ]STRDAT,[M:TPSJ]DAT(0..6))
  I = I-1
  [L]DATCOP = [M:COPJ]STRDAT+1
  If GNBHOR=0
   NBPLG = 1
  Else
   NBPLG = GNBHOR
  Endif
  Call PARAM([M:TPSJ]FCY,"MTTPERDEB",MOIDEB) From ADOVAL
  Call PARAM([M:TPSJ]FCY,"MTTPERFIN",MOIFIN) From ADOVAL
  While [L]DATCOP<=[M:COPJ]ENDDAT
   If [M:COPJ]JDAY(dayn([L]DATCOP)-1)=2        : # Recopie sur un jour de semaine coché
    Read [HLY]HLY0 = year([L]DATCOP);[M:TPSJ]FCY
    If fstat
    #ADNGO - 26-01-2017 - X3-18688 - START
     #Read [HLY]HLY0 = year([L]DATCOP);""
     Read [HLY]HLY0 = year([L]DATCOP);"";GCURLEG
    #ADNGO - 26-01-2017 - X3-18688 - END
    Endif
    If fstat or find([L]DATCOP,[F:HLY]HLYDAY)=0 : # Pas de recopie sur jour férié
     #LIPET - 10-01-2017 - X3-18688 - START
#     Filter [CTR] Where REFNUM=[M:TPSJ]REFNUM & CTRNUM=[M:TPSJ]CTRNUM & CTRDAT<=[L]DATCOP
#     Read [CTR]CTR0 Last
#     Filter [CTR]
     Filter [HRCTR] Where REFNUM=[M:TPSJ]REFNUM & CTRNUM=[M:TPSJ]CTRNUM & CTRDAT<=[L]DATCOP
     Read [HRCTR]CTR0 Last
     Filter [HRCTR]
     #LIPET - 10-01-2017 - X3-18688 - END
     If [M:COPJ]TYPDAY=3
      Gosub TRTPS
     Else
      Read [PLE]PLE0=[M:TPSJ]REFNUM;[L]DATCOP;[M:TPSJ]CTRNUM
      If !fstat & [M:COPJ]TYPDAY = [F:PLE]TYPDAY
       Gosub TRTPS
      Elsif fstat
      #ADNGO - 26-01-2017 - X3-18688 - START
       #Read [PLN]PLN0=year([L]DATCOP);[F:CTR]PLNTYP
       Read [PLN]PLN0=year([L]DATCOP);[F:HRCTR]PLNTYP;GCURLEG
      #ADNGO - 26-01-2017 - X3-18688 - END
       If !fstat
        ANNEE = [M:TPSJ]YEA
#MIPEA - 2017-11-27- US X3-63170- START
        Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END
        Call DAT([L]DATCOP,ANNEE,SEMAINE) From SUBPLN
        #ADNGO - 26-01-2017 - X3-18688 - START
        #Call LECTURE("STY",[F:PLN]WEKTYP(SEMAINE-1),"") From CONTOBJ
        Call LECTURE("STY",[F:PLN]WEKTYP(SEMAINE-1),GCURLEG) From CONTOBJ
        #ADNGO - 26-01-2017 - X3-18688 - END
        If [M:COPJ]TYPDAY=[F:WTY]TYPDAY(dayn([L]DATCOP)-1)
         Gosub TRTPS
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
   [L]DATCOP +=1
  Wend
Endcase
Return

$TRPLE
GOK = 1
Trbegin [PLE]
 # FQ92876 - 05/06/14 - On a maintenant un onglet par plage horaire
# Readlock [PLE]PLE0=[M:PLE]REFNUM;[L]DATCOP;[M:PLE]CTRNUM
 Readlock [PLE]PLE0=[M:PLE0]REFNUM;[L]DATCOP;[M:PLE0]CTRNUM
 If fstat=1
#  GOK=-1 : GLOCK = "$PLANEMP"-[F:PLE]REFNUM-num$([F:PLE]DAT)-[M:PLE]CTRNUM
  GOK=-1 : GLOCK = "$PLANEMP"-[F:PLE]REFNUM-num$([F:PLE]DAT)-[M:PLE0]CTRNUM
  Goto ROLL_TRPLE
 Elsif fstat
  If [M:COPJ]TYPDAY<>3
#   Filter [CTR] Where REFNUM=[M:PLE]REFNUM & CTRNUM=[M:PLE]CTRNUM & CTRDAT<=[L]DATCOP
   #ADNGO - 26-01-2017 - X3-18688 - START
   #Filter [CTR] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=[M:PLE0]CTRNUM & CTRDAT<=[L]DATCOP
   #Read [CTR]CTR0 Last
   #Filter [CTR]
   #Read [PLN]PLN0=year([L]DATCOP);[F:CTR]PLNTYP
   Filter [HRCTR] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=[M:PLE0]CTRNUM & CTRDAT<=[L]DATCOP
   Read [HRCTR]CTR0 Last
   Filter [HRCTR]
   Read [PLN]PLN0=year([L]DATCOP);[F:HRCTR]PLNTYP;GCURLEG
   #ADNGO - 26-01-2017 - X3-18688 - END
   If !fstat
#    ANNEE = [M:PLE]YEA
    ANNEE = [M:PLE0]YEA
#MIPEA - 2017-11-27- US X3-63170- START
    Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END
    Call DAT([L]DATCOP,ANNEE,SEMAINE) From SUBPLN
    #ADNGO - 26-01-2017 - X3-18688 - START
    #Call LECTURE("STY",[F:PLN]WEKTYP(SEMAINE-1),"") From CONTOBJ
    Call LECTURE("STY",[F:PLN]WEKTYP(SEMAINE-1),GCURLEG) From CONTOBJ
    #ADNGO - 26-01-2017 - X3-18688 - END
   Else Raz [F:WTY]
   Endif
  Endif
  If [M:COPJ]TYPDAY=3 |[M:COPJ]TYPDAY=[F:WTY]TYPDAY(dayn([L]DATCOP)-1)
   Gosub REMPPLE
   [F:PLE]CREDAT = date$
   [F:PLE]CREUSR = GUSER
   [F:PLE]CRETIM = time
   Write [PLE]
   If fstat : GOK=0 : Goto AB_TRPLE : Endif
  Endif
 Else
  If [M:COPJ]TYPDAY=3 |[M:COPJ]TYPDAY=[F:PLE]TYPDAY
   Gosub REMPPLE
   [F:PLE]UPDDAT = date$
   [F:PLE]UPDUSR = GUSER
   [F:PLE]UPDTIM = time
   Rewrite [PLE]
   If fstat : GOK=0 : Goto AB_TRPLE : Endif
  Endif
 Endif
Commit
Return

$REMPPLE
Raz [F:PLE]
# FQ92876 - 05/06/14 - On a maintenant un onglet par plage horaire
#[F:PLE]REFNUM = [M:PLE]REFNUM
#[F:PLE]CTRNUM = [M:PLE]CTRNUM
#[F:PLE]YEA    = [M:PLE]YEA
#[F:PLE]DAT    = [L]DATCOP
#[F:PLE]TYPDAY = evalue("[M:PLE]TYPDAY"+num$(I))
#[F:PLE]NBRHOU = evalue("[M:PLE]NBRHOU"+num$(I))
#[F:PLE]NBRDAY = evalue("[M:PLE]NBRDAY"+num$(I))
#For K=1 To NBPLG
# [F:PLE]NATCOD(K-1) = evalue("[M:PLE]NATCOD"+num$(I)+num$(K))
# If GNBHOR>0
#  [F:PLE]STRTIM(K-1) = evalue("[M:PLE]STRTIM"+num$(I)+num$(K))
#  [F:PLE]ENDTIM(K-1) = evalue("[M:PLE]ENDTIM"+num$(I)+num$(K))
#  [F:PLE]BRKTIM(K-1) = evalue("[M:PLE]BRKTIM"+num$(I)+num$(K))
# Endif
# For J=1 To GOPTCANA
#  Assign "[F:PLE]CCE"+num$(J)+"("+num$(K-1)+")" With evalue("[M:PLE]CCE"+num$(J)+num$(I)+num$(K))
# Next
#Next
[F:PLE]REFNUM = [M:PLE0]REFNUM
[F:PLE]CTRNUM = [M:PLE0]CTRNUM
[F:PLE]YEA    = [M:PLE0]YEA
[F:PLE]DAT    = [L]DATCOP
[F:PLE]TYPDAY = evalue("[M:PLE1]TYPDAY"+num$(I))
[F:PLE]NBRHOU = evalue("[M:PLE1]NBRHOU"+num$(I))
[F:PLE]NBRDAY = evalue("[M:PLE1]NBRDAY"+num$(I))
For K=1 To NBPLG
 [F:PLE]NATCOD(K-1) = evalue("[M:PLE"+num$(K)+"]NATCOD"+num$(I)+num$(K))
 If GNBHOR>0
  [F:PLE]STRTIM(K-1) = evalue("[M:PLE"+num$(K)+"]STRTIM"+num$(I)+num$(K))
  [F:PLE]ENDTIM(K-1) = evalue("[M:PLE"+num$(K)+"]ENDTIM"+num$(I)+num$(K))
  [F:PLE]BRKTIM(K-1) = evalue("[M:PLE"+num$(K)+"]BRKTIM"+num$(I)+num$(K))
 Endif
 For J=1 To GOPTCANA
  # FQ92876 - 04/09/14 - Avant d'assigner les sections, il faut vérifier qu'elles existent
  If evalue("dim([M:PLE"+num$(K)+"]CCE"+num$(J)+num$(I)+num$(K)+")")>0 Then
    Assign "[F:PLE]CCE"+num$(J)+"("+num$(K-1)+")" With evalue("[M:PLE"+num$(K)+"]CCE"+num$(J)+num$(I)+num$(K))
    # FQ92876 - 03/06/14 - Ajout des axes
    [F:PLE]DIE(J-1)=[M:PLE0]DIE(J-1)
   Endif
 Next
Next
Return

$AB_TRPLE
Call FSTA("PLE") From GLOCK
Rollback
Return

$ROLL_TRPLE
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRPLE : Endif
Return


$TRTPS
GOK = 1

Trbegin [TIP]
 Filter [TIP] Where REFNUM=[M:TPSJ]REFNUM & CTRNUM=[M:TPSJ]CTRNUM & STRDAT<=[L]DATCOP & ENDDAT>=[L]DATCOP
 Read [TIP]TIP4 First
 Filter [TIP]
 If !fstat & [F:TIP]STRDAT<>[F:TIP]ENDDAT
 #LIPET - 10-01-2017 - X3-18688 - START
  # Recopie impossible car le jour est saisi sur la pèriode du ../../.. au ../../..
#  Call ECR_TRACE(format$("D:"+GFMDAT,[L]DATCOP)+" : "+mess(152,709,1)+space$(1)+format$("D:"+GFMDAT,[F:TIP]STRDAT)
#& +space$(1)+mess(95,100,1)+space$(1)+format$("D:"+GFMDAT,[F:TIP]ENDDAT),1) From GESECRAN
#  Goto AB_TRTPS
  Call ECR_TRACE(format$("D:"+GFMDAT,[L]DATCOP)+" : "+mess(152,10709,1)+space$(1)+format$("D:"+GFMDAT,[F:TIP]STRDAT)
& +space$(1)+mess(95,100,1)+space$(1)+format$("D:"+GFMDAT,[F:TIP]ENDDAT),1) From GESECRAN
  Goto AB_TRTPS
  #LIPET - 10-01-2017 - X3-18688 - END
 Elsif !fstat & [F:TIP]STRDAT=[F:TIP]ENDDAT
  Delete[TIP] Where REFNUM=[M:TPSJ]REFNUM & CTRNUM=[M:TPSJ]CTRNUM & STRDAT=[L]DATCOP & ENDDAT=[L]DATCOP
  If fstat=1
   Goto AB_TRTPS
  Endif
 Endif
 Gosub DATPYR
 If GOK=0 : Goto AB_TRTPS : Endif
 For J=1 To NBPLG
  Raz [F:TIP]
  [F:TIP]LIG     = uniqid([TIP])
  [F:TIP]REFNUM  = [M:TPSJ]REFNUM
  [F:TIP]CTRNUM  = [M:TPSJ]CTRNUM
  [F:TIP]STRDAT  = [L]DATCOP
  [F:TIP]ENDDAT  = [L]DATCOP
  #LIPET - 10-01-2017 - X3-18688 - START
  #[F:TIP]DATPYR  = [F:PEOX]PYRDAT
  [F:TIP]DATPYR  = [F:HRPEOD]PYRDAT
  #LIPET - 10-01-2017 - X3-18688 - END
  [F:TIP]FCY     = [M:TPSJ]FCY
  [F:TIP]SRV     = [M:TPSJ]SRV
  # FQ80179 - MABON 20/02/11 - Non, si on est en modif de zone, on perd la modification
#  #FQ 78339 -FRRIC- 09/12/2011
#  #[F:TIP]TIM     = evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(I)+")")
#  [F:TIP]TIM     = evalue("[M:TPSJ]TIM"+num$(J))
  [F:TIP]TIM     = evalue("[M:TPSI]KTIM"+num$(J)+"("+num$(I)+")")
  # Fin MABON

  [F:TIP]STRTIM  = evalue("[M:TPSI]KSTRTIM"+num$(J)+"("+num$(I)+")")
  [F:TIP]ENDTIM  = evalue("[M:TPSI]KENDTIM"+num$(J)+"("+num$(I)+")")
  [F:TIP]BRKTIM  = evalue("[M:TPSI]KBRKTIM"+num$(J)+"("+num$(I)+")")
  Case evalue("[M:TPSI]KLEADAY"+num$(J)+"("+num$(I)+")")
   When 1 : [F:TIP]STRDAY = 2 : [F:TIP]ENDDAY = 1 : # Matin
   When 2 : [F:TIP]STRDAY = 1 : [F:TIP]ENDDAY = 2 : # Apres-midi
   When 3 : [F:TIP]STRDAY = 1 : [F:TIP]ENDDAY = 1 : # Journée
  Endcase
  [F:TIP]NATCOD  = evalue("[M:TPSI]KNATCOD"+num$(J)+"("+num$(I)+")")
  [F:TIP]NBRDAY  = evalue("[M:TPSI]KNBRDAY"+num$(J)+"("+num$(I)+")")
  [F:TIP]NBRHOU  = evalue("[M:TPSI]KNBRHOU"+num$(J)+"("+num$(I)+")")
  [F:TIP]DAYNGT  = evalue("[M:TPSI]KDAYNGT"+num$(J)+"("+num$(I)+")")
  [F:TIP]TYPDAY  = evalue("[M:TPSI]KTYPDAY"+num$(J)+"("+num$(I)+")")
  [F:TIP]QTY1    = evalue("[M:TPSI]KQTY1"+num$(J)+"("+num$(I)+")")
  [F:TIP]QTY2    = evalue("[M:TPSI]KQTY2"+num$(J)+"("+num$(I)+")")
  [F:TIP]FLD1    = evalue("[M:TPSI]KFLD1"+num$(J)+"("+num$(I)+")")
  [F:TIP]FLD2    = evalue("[M:TPSI]KFLD2"+num$(J)+"("+num$(I)+")")
  [F:TIP]CPY     = evalue("[M:TPSI]KCPY"+num$(J)+"("+num$(I)+")")
  [F:TIP]BPCNUM  = evalue("[M:TPSI]KBPCNUM"+num$(J)+"("+num$(I)+")")
  [F:TIP]SOHNUM  = evalue("[M:TPSI]KSOHNUM"+num$(J)+"("+num$(I)+")")
  [F:TIP]SOHLIG  = evalue("[M:TPSI]KSOHLIG"+num$(J)+"("+num$(I)+")")
  [F:TIP]INVFLG  = evalue("[M:TPSI]KINVFLG"+num$(J)+"("+num$(I)+")")
  [F:TIP]CMT     = evalue("[M:TPSI]KCMT"+num$(J)+"("+num$(I)+")")
  [F:TIP]STAFLG  = evalue("[M:TPSI]KSTAFLG"+num$(J)+"("+num$(I)+")")
  [F:TIP]DSP     = evalue("[M:TPSI]KDSP"+num$(J)+"("+num$(I)+")")
  #CP PATHO
  [F:TIP]TYPPGN  = evalue("[M:TPSI]KTYPPGN"+num$(J)+"("+num$(I)+")")
  #105432
  [F:TIP]CTRDAT  = evalue("[M:TPSI]KCTRDAT"+num$(J)+"("+num$(I)+")")

  If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT = date$ : Endif
  If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR = GUSER : Endif
  If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM = time  : Endif

  #LIPET - 10-01-2017 - X3-18688 - START
  #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
  Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
  #LIPET - 10-01-2017 - X3-18688 - END
  If [F:TIM]CATTIM=3
   Call ADD_CPPRIS([F:TIP]NBRDAY) From TPSSTD1
   If GOK<1 : Break : Endif
  Endif

  Gosub ANA From TPSJOU
#  FRRIC- 09/12/2011 - FQ 78339
  If [F:TIP]NBRDAY <> 0 or [F:TIP]NBRHOU <> 0
# END - FQ 78339
   Write [TIP]
   If fstat
    GOK = 0 : Call FSTA("TIP") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK=0 : Goto AB_TRTPS : Endif
Commit
Return

$AB_TRTPS
Rollback
Return

$DATPYR
PDEB = "PERSTR(0)"
PFIN = "PEREND(0)"
#LIPET - 10-01-2017 - X3-18688 - START
#If [F:CTR]MODTPS=2 & val(MOIDEB)=month([L]DATCOP) : PDEB = "PERSTR(1)" : Endif
#If [F:CTR]MODTPS=2 & val(MOIFIN)=month([L]DATCOP) : PFIN = "PEREND(1)" : Endif
#Filter [PEOX] Where FCY=[M:TPSJ]FCY & [L]DATCOP>=evalue(PDEB) & [L]DATCOP<=evalue(PFIN)
#Read [PEOX]PEO0 First
#Filter [PEOX]
#If fstat
# Filter [PEOX] Where FCY="" & [L]DATCOP>=evalue(PDEB) & [L]DATCOP<=evalue(PFIN)
# Read [PEOX]PEO0 First
# Filter [PEOX]
# If fstat
#  GOK = 0
#  # Recopie impossible car aucune période d'extraction n'est accessible à cette date
#  Call ECR_TRACE(format$("D:"+GFMDAT,[L]DATCOP)+" : "+mess(154,709,1),1) From GESECRAN
# Endif
#Endif
If [F:HRCTR]MODTPS=2 & val(MOIDEB)=month([L]DATCOP) : PDEB = "PERSTR(1)" : Endif
If [F:HRCTR]MODTPS=2 & val(MOIFIN)=month([L]DATCOP) : PFIN = "PEREND(1)" : Endif
Filter [HRPEOH] Where FCY=[M:TPSJ]FCY & [L]DATCOP>=evalue(PDEB) & [L]DATCOP<=evalue(PFIN)
Read [HRPEOH]HRPEOH0 First
Filter [HRPEOH]
If fstat
 Filter [HRPEOH] Where FCY="" & [L]DATCOP>=evalue(PDEB) & [L]DATCOP<=evalue(PFIN)
 Read [HRPEOH]HRPEOH0 First
 Filter [HRPEOH]
 If fstat
  GOK = 0
  # Recopie impossible car aucune période d'extraction n'est accessible à cette date
  Call ECR_TRACE(format$("D:"+GFMDAT,[L]DATCOP)+" : "+mess(154,10709,1),1) From GESECRAN
 Endif
Endif
#LIPET - 10-01-2017 - X3-18688 - end
Return

######################################################################################
## Etiquette de l'écran COPIEJOUR
######################################################################################

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Gosub CTL_JOUR
If mkstat=2 : End : Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If [M]STRDAT>=VALEUR
 #LIPET - 10-01-2017 - X3-18688 - START
 # Date incorrecte par rapport au jour à recopier
 #GMESSAGE = mess(151,709,1)
 GMESSAGE = mess(151,10709,1)
 #LIPET - 10-01-2017 - X3-18688 - END
 mkstat = 2 : End
Endif
End

$CTL_JOUR
# Planning opérationnel
# FQ92876 - 05/06/14 - On a maintenant un onglet par plage horaire
#If [M:COPJ]TYP="1" & (VALEUR>[M:PLE]DAT(6) | VALEUR<[M:PLE]DAT(0))
If [M:COPJ]TYP="1" & (VALEUR>[M:PLE0]DAT(6) | VALEUR<[M:PLE0]DAT(0))
 #LIPET - 10-01-2017 - X3-18688 - START
 # Jour non inclu dans la semaine
 #GMESSAGE = mess(140,709,1)
 GMESSAGE = mess(140,10709,1)
 #LIPET - 10-01-2017 - X3-18688 - END
 mkstat = 2
Endif
# Feuille de temps
If [M:COPJ]TYP="2" & (VALEUR>[M:TPSJ]DAT(6) | VALEUR<[M:TPSJ]DAT(0))
 #LIPET - 10-01-2017 - X3-18688 - START
 # Jour non inclu dans la semaine
 #GMESSAGE = mess(140,709,1)
 GMESSAGE = mess(140,10709,1)
 #LIPET - 10-01-2017 - X3-18688 - END
 mkstat = 2
Endif
Return

