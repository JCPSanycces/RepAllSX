#<AdxTL>@(#)3.0.0.0 $Revision$
#######################################################
# Subprog SELMNL(MNL)
#######################################################
Local Decimal MNL
MNL=1000
Call SELMNL(MNL)
End

Subprog SELMNL(VALEUR)
Variable Decimal VALEUR

Local Integer DEB , FIN , NBTEX , MNL , MAXTEX
MAXTEX = 200
Local Char    TEX(40)(0..MAXTEX+50)

NBTEX = 0
If VALEUR>300
 DEB = VALEUR-100 : FIN = VALEUR+1000
Elsif VALEUR>=200
 DEB = max(1,VALEUR-200) : FIN = VALEUR+100
Else
 DEB = 1 : FIN = 300
Endif
While DEB<=FIN
 If DEB=100 : DEB = 201 : Endif
 If len(mess(0,DEB,1))
  NBTEX += 1
  If DEB=VALEUR : MNL = DEB : Endif
  TEX(NBTEX) = format$("N:5#",DEB)
  If DEB<100
   TEX(NBTEX) += " "+mess(DEB,0,1)
  Else
   TEX(NBTEX) += " "+mess(DEB-200,200,1)
  Endif
 Endif
 DEB += 1
 If NBTEX>=dim(TEX)-1 : Break : Endif
# If DEB>=9000 : Break : Endif
# 29/01 /2002 ajout des messages localisation à partir de 8900
 If DEB>=8900 : Break : Endif
Wend

Call SAITEX(NBTEX,TEX,MNL,mess(153,153,1)) From GESECRAN
# Choix d'un menu local

If status<>7 & MNL<>0
 VALEUR = val(left$(TEX(MNL),5))
Endif
mkstat=2
End


