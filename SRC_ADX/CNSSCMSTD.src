#<AdxTL>@(#)8.0.0.0 $Revision$
##################################################
#                                                #
#    Consultation SCM   (selon CNSSSCSTD)        #
#                                    GA 09/2006  #
##################################################


########################################################
#                                                      
# Parametres de consultation via PARAM()               
#                                                      
#
#1 = site
#
#2 = N° ordre de sous-traitance
#
#3 = Article sous-traitance
#
#4 = article sous traité
#
#5 = Date livraison
#
#6 = TRI
#  Menu local 2220
#       1- par N° ordre de sous-traitance
#       2- par article sous-traité
#       3- par service         (inutile ici)
#       4- par N° de commande  (inutile ici)
#       5- par date commande   (inutile ici)           
#       6- par fournisseur     (inutile ici)
#       7- par matière         
#       8- par date livraison 
#
########################################################

Local Char PARAM(20)(1..5)
PARAM(1)="ANY"
PARAM(2)=""
PARAM(3)=""
PARAM(4)=""
PARAM(5)=""

Call GCONSULT("SCM", "",PARAM) From GCONSULT
End


##################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "FERME"    : Gosub FERME
 When "LECTURE"  : Gosub LECTURE
 When Default
Endcase
Return


##################################################
$OUVRE
NAVIG="CONSSCM"
Integer I
Local Char CRITERE(255),CRITERE1(255), CRITERE2(255), CRITERE3(255)
Local Char DEBVCRNUM(GLONVCR) , FINVCRNUM(GLONVCR)
Local Char DEBITMREF(GLONITM) , FINITMREF(GLONITM)
Local Char DEBCPNITM(GLONITM) , FINCPNITM(GLONITM)
Local Date DEBDLVDAT, FINDLVDAT
Local Integer WSRT


Gosub DEFCRIT
If !find ([M:CSCM]TRI,1,2,7,8) : [M:CSCM]TRI=1 : Endif

Return

##################################################
$FERME
Return


##################################################
$DEFCRIT
#chargement par defaut : en fonction du site + date du jour

If   [M:SCM1]DLVDATDEB =[0/0/0]
     [M:SCM1]DLVDATDEB = gdat$(1,month(date$),year(date$)) : [M:SCM1]DLVDATFIN = date$
Endif
For I= 1 To dim(PARAM)
  Case I
    When 1 :     #site
            If  PARAM(I)<> ""   
                 Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                 If !fstat : [M:SCM1]POHFCY = PARAM(I): Endif
            Endif
    When 2 :     # N° ordre de sous-traitance
             If  PARAM(I)<> ""  
                    [M:SCM1]NUMDEB =  PARAM(I)
                    [M:SCM1]NUMFIN =  PARAM(I)
             Endif
    When 3 :     #  Matière
             If  PARAM(I)<> ""   
                [M:SCM1]CPNITMDEB = PARAM(I)
                [M:SCM1]CPNITMFIN = PARAM(I)
             Endif
    When 4 :     #  article sous traité
             If  PARAM(I)<> ""   
                [M:SCM1]ITMREFDEB = PARAM(I)
                [M:SCM1]ITMREFFIN = PARAM(I)
             Endif
    When 5 :    # date livraison
          If PARAM(I)<>""
                If instr(1, PARAM(I),"/")
                    [M:SCM1]DLVDATDEB = "["+PARAM(I)+"]"
                    [M:SCM1]DLVDATFIN = "["+PARAM(I)+"]"
                Else
                    [M:SCM1]DLVDATDEB = PARAM(I)
                    [M:SCM1]DLVDATFIN = PARAM(I)
                Endif
          Endif
    

   When Default : Break

  Endcase
Next I


# Copie de l'ecran d'entête / ecran de criteres
Gosub CRITENT From =PROGCNS

Return

##################################################
$LECTURE
#-- Changement d'écran paramétrable
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

#-- Positionnement des filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


#########################################################
#                                                       #
#    CHGPAG = 1  : Recherche                            #
#    ------ = 2  : Suite                                #
#    ------ = 3  : F5 (Rafraichissement page courante)  #
#                                                       #
#    CHGPAG = -1 : Dernier                              #
#    ------ = -2 : Retour (page precedente)             #
#                                                       #
#########################################################
#-- Application du filtre et positionnement des boutons, classé par N° ordre de sous-traitance
If CHGPAG >0
    SUITE = 1
    If CHGPAG = 1 : RETOUR =1       #recherche
    Elsif CHGPAG = 2 : RETOUR = 2   # suite
    Endif 

  Case [M:CSCM]TRI
    When 1:    # tri par N° ordre 
    Filter [SCM] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:SCM]SCONUM 

    When 2:    # tri par article sous-traité
    Filter [SCM] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:SCM]ITMREF

    When 7:    # tri par composant
    Filter [SCM] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:SCM]CPNITMREF

    When 8:    # tri par date livraison
    Filter [SCM] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:SCM]DLVDAT 

  Endcase
Else
    RETOUR = 1
    If CHGPAG = -1 : SUITE =1    #dernier
    Elsif CHGPAG =-2 : SUITE = 2 #retour
    Endif

  Case [M:CSCM]TRI
    When 1 :    # tri par N° ordre de sous-traitance
    Filter [SCM] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:SCM]SCONUM Desc 
 
    When 2:    # tri par article sous-traité
    Filter [SCM] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:SCM]ITMREF Desc

    When 7:    # tri par article sous-traitance
    Filter [SCM] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:SCM]CPNITMREF Desc

    When 8:   # tri par date livraison
    Filter [SCM] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:SCM]DLVDAT Desc 

  Endcase

Endif
 

# RAZ du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:SCM2] : Endif

For [SCM]
    If NBLU=1 
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:SCM2] : Endif
        NBLU =2
    Endif

    If CHGPAG >0
        If NOL>=MAXLIG-1 : SUITE=2 : Break : Endif
        NOL +=1
        If NOL = 0 
            DEBVCRNUM = [F:SCM]SCONUM
            DEBITMREF = [F:SCM]ITMREF
            DEBCPNITM = [F:SCM]CPNITMREF
            DEBDLVDAT = [F:SCM]DLVDAT
        Endif
        FINVCRNUM = [F:SCM]SCONUM
        FINITMREF = [F:SCM]ITMREF
        FINCPNITM = [F:SCM]CPNITMREF
        FINDLVDAT = [F:SCM]DLVDAT
    Else
        If NOL <=0 : RETOUR = 2 : Break : Endif
        NOL -=1
        If NOL = MAXLIG -1 
            FINVCRNUM = [F:SCM]SCONUM
            FINITMREF = [F:SCM]ITMREF
            FINCPNITM = [F:SCM]CPNITMREF
            FINDLVDAT = [F:SCM]DLVDAT
        Endif
        DEBVCRNUM = [F:SCM]SCONUM
        DEBITMREF = [F:SCM]ITMREF
        DEBCPNITM = [F:SCM]CPNITMREF
        DEBDLVDAT = [F:SCM]DLVDAT
    Endif

    nolign = NOL+1
    [M:SCM2] = [F:SCM]
    Read [SCO]SCO0=[F:SCM]SCONUM : If fstat : Raz [F:SCO] : Endif
    [M:SCM2]BPRNUM(nolign-1) = [F:SCO]BPRNUM
   # Qté dispo chez le sous-traitant (intersite: site courant propriétaire du stock)
    Gosub RECH_BPRQTYSTU
   # Qté conso par le sous-traitant (intersite: sorties diverses ?)
    Gosub RECH_BPRUSEQTY
Next 
Filter [SCM]

Return

##################################################
$LOAD_FILTER

Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

# Uniquement les Matières mises à dispo du sous-traitant
CRITERE = "[F:SCM]SCOFLG=2"
Gosub LOAD_CRITERE1

#site
If [M:SCM1]POHFCY <> ""
    CRITERE = "[F:SCM]STOFCY=[M:SCM1]POHFCY"
    Gosub LOAD_CRITERE1
Endif

#N°  ordre de sous-traitance
If [M:SCM1]NUMDEB <> ""
      CRITERE ="[F:SCM]SCONUM>=[M:SCM1]NUMDEB"
      Gosub LOAD_CRITERE1
Endif

If [M:SCM1]NUMFIN <> ""
    CRITERE ="[F:SCM]SCONUM <= [M:SCM1]NUMFIN"
    Gosub LOAD_CRITERE1
Endif

# Article ss-traité
If [M:SCM1]ITMREFDEB<>""
    CRITERE ="[F:SCM]ITMREF >= [M:SCM1]ITMREFDEB"
    Gosub LOAD_CRITERE1 
Endif

If [M:SCM1]ITMREFFIN<>""
    CRITERE = "[F:SCM]ITMREF <= [M:SCM1]ITMREFFIN"
    Gosub LOAD_CRITERE2 
Endif

# Article composant
If [M:SCM1]CPNITMDEB<>""
    CRITERE ="[F:SCM]CPNITMREF >= [M:SCM1]CPNITMDEB"
    Gosub LOAD_CRITERE1 
Endif

If [M:SCM1]CPNITMFIN<>""
    CRITERE = "[F:SCM]CPNITMREF <= [M:SCM1]CPNITMFIN"
   Gosub LOAD_CRITERE2 
Endif

# Date livraison
If [M:SCM1]DLVDATDEB<>[0/0/0]
   CRITERE = "[F:SCM]DLVDAT >= [M:SCM1]DLVDATDEB"
   Gosub LOAD_CRITERE2
Endif

If [M:SCM1]DLVDATFIN<>[0/0/0]
   CRITERE = "[F:SCM]DLVDAT <= [M:SCM1]DLVDATFIN"
   Gosub LOAD_CRITERE2
Endif

Case CHGPAG
    When 3 : # rafraichissement
        Case [M:CSCM]TRI
            When 1 :
                CRITERE = "[F:SCM]SCONUM >=DEBVCRNUM"
                Gosub LOAD_CRITERE3
            When 2 :
                CRITERE = "[F:SCM]ITMREF >= DEBITMREF" 
                Gosub LOAD_CRITERE3
            When 7 :
                CRITERE = "[F:SCM]CPNITMREF >= DEBCPNITM" 
                Gosub LOAD_CRITERE3
            When 8 :
                CRITERE= "[F:SCM]DLVDAT >= DEBDLVDAT"
                Gosub LOAD_CRITERE3
        Endcase
    When 2 : #suite
        Case [M:CSCM]TRI
            When 1 : 
                CRITERE = "[F:SCM]SCONUM >FINVCRNUM"
                Gosub LOAD_CRITERE3
            When 2 :
                CRITERE = "[F:SCM]ITMREF > FINITMREF" 
                Gosub LOAD_CRITERE3
            When 7 :
                CRITERE = "[F:SCM]CPNITMREF >FINCPNITM"
                Gosub LOAD_CRITERE3
            When 8 :
                CRITERE= "[F:SCM]DLVDAT > FINDLVDAT"
                Gosub LOAD_CRITERE3
            Endcase
    When -2: # retour
        Case [M:CSCM]TRI
            When 1: 
                CRITERE = "[F:SCM]SCONUM < DEBVCRNUM"
                Gosub LOAD_CRITERE3
            When 2 :
                CRITERE= "[F:SCM]ITMREF < DEBITMREF"
                Gosub LOAD_CRITERE3
            When 7 :
                CRITERE= "[F:SCM]CPNITMREF < DEBCPNITM"
                Gosub LOAD_CRITERE3
            When 8 :
                CRITERE="[F:SCM]DLVDAT < DEBDLVDAT"
                Gosub LOAD_CRITERE3
        Endcase
Endcase 

If CRITERE1 = "" : CRITERE1 ="1=1" : Endif
If CRITERE2 = "" : CRITERE2 ="1=1" : Endif
If CRITERE3 = "" : CRITERE3 ="1=1" : Endif

Return


#############################################################################
$LOAD_CRITERE1
If len(CRITERE1)<>0 : CRITERE1 += "&" : Endif
CRITERE1 += CRITERE 
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE  
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE  
Return



#############################################################################
# Recherche dans STOJOU stock dispo pour cet article et ce propriétaire
# Cette info ne peut être renseignée que si sous-traitance intersite
#############################################################################
$RECH_BPRQTYSTU
# si il existe une (des) livraison(s) intersite pour l'EO courant et la matière courante 
#    si une (des) réception(s) de matière pour sous-traitance (rattachées à ces livraisons)
#       si un  (des) retour(s) de matière pour sous-traitance (rattachées à ces réceptions)
#    recherche et totalisation des mvts STOJOU sur ces documents
# sinon (aucune livraison intersite pour l'EO courant)
#    recherche et totalisation des mvts STOJOU pour ce propriétaire et cette matière
#    et date entrée <= [F:SCM]DLVDAT ou date sortie >= [F:SCM]DLVDAT

   If clalev([F:STO1])=0 Local File STOCK  [STO1] Endif 

   # Calcul du stock disponible sur le site de production (chez le sous-traitant)
   For [STO1]STO3 Where [F:STO1]ITMREF=[F:SCM]CPNITMREF & [F:STO1]STOFCY=[F:SCO]MFGFCY
&                     & [F:STO1]OWNER =[F:SCM]STOFCY 
&                     & [F:STO1]LOCCAT=1 & [F:STO1]STA="A" 
       [M:SCM2]BPRQTYSTU(nolign-1) += [F:STO1]QTYSTUACT-[F:STO1]CUMALLQTA-[F:STO1]CUMWIPQTA
   Next
Return



#############################################################################
# Recherche dans STOJOU stock sorti pour cet article et ce propriétaire
# Cette info ne peut être renseignée que si sous-traitance intersite 
# et sorties saisies par le sous-traitant
#############################################################################
$RECH_BPRUSEQTY
# recherche et totalisation des mvts de sortie STOJOU pour ce propriétaire et cette matière
# avec date sortie >= [F:SCM]DLVDAT
Return


###################################################################################
#                                                                                 #
#    ETIQUETTES ECRAN                                                             #
#                                                                                 #
###################################################################################

#----------------------------------#
# Alimentation société : GSOCIETE  #
#              devise  : GLOCALDEV #
#----------------------------------#
Subprog AM_POHFCY(VALEUR)
Variable Char    VALEUR()
Call GETDEV(VALEUR) From DEVSUB
End



########################################
Subprog AM_NUMDEB(VALEUR)
Variable Char    VALEUR()
    If [M]NUMDEB= "": [M]NUMFIN = VALEUR: Endif
    If [M]NUMFIN < VALEUR :  [M]NUMFIN = VALEUR: Endif
End

########################################
Subprog C_NUMFIN(VALEUR)
Variable Char    VALEUR()
    If VALEUR < [M]NUMDEB: GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
    If [M]ITMREFDEB ="" : [M]ITMREFFIN = VALEUR : Endif    
    If [M]ITMREFFIN < VALEUR : [M]ITMREFFIN = VALEUR : Endif    
End

########################################
Subprog C_ITMREFFIN(VALEUR)
Variable Char    VALEUR()
    If VALEUR < [M]ITMREFDEB: GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif
End

########################################
Subprog AM_CPNITMDEB(VALEUR)
Variable Char    VALEUR()
    If [M]CPNITMDEB =""      : [M]CPNITMFIN = VALEUR : Endif    
    If [M]CPNITMFIN < VALEUR : [M]CPNITMFIN = VALEUR : Endif    
End

########################################
Subprog C_CPNITMFIN(VALEUR)
Variable Char    VALEUR()
    If VALEUR < [M]CPNITMDEB: GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif
End

########################################
Subprog AM_DLVDATDEB(VALEUR)
Variable Date    VALEUR
    If [M]DLVDATDEB =[0/0/0] : [M]DLVDATFIN = VALEUR : Endif
    If [M]DLVDATFIN < VALEUR : [M]DLVDATFIN = VALEUR : Endif
End

########################################
Subprog C_DLVDATFIN(VALEUR)
Variable Date    VALEUR
    If VALEUR <[M]DLVDATDEB : GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif

End

########################################
Subprog IB_NBLIG
GBOUT1=mess(473,198,1)-[M:SCM2]SCONUM(nolign-1)   # ordre de sous-traitance
End

########################################
Subprog AS_TRI(VALEUR)
Variable Integer  VALEUR
GMENLOC(3)=1
GMENLOC(4)=1
GMENLOC(5)=1
GMENLOC(6)=1
End


#########################################################################
# Pour exécution de la validation des consultations en gestion de patch #
#########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Call VALGTC(APPLI,"SCM") From SUBGTC
End
