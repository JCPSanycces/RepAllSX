###############################################################################
# Representation Class EDIRUN                                                 #
# Author : RBA + JUCON                                                        #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When "" : # If CURPTH is empty, we are on the main representation
      Case [L]AEVENT
        When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
      Endcase
    When "EDR" :
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EDR_AREAD_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "EDR.PARCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDR_PARCOD_PROPAGATE
      Endcase
    When "EDR.PARTYP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDR_PARTYP_PROPAGATE
      Endcase
    When "EDR.CATCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDR_CATCOD_PROPAGATE
      Endcase
    When "EDR.CATTYP"
      Case [L]ARULE
        When "INIT"      : Gosub EDR_CATTYP_INIT
        When "PROPAGATE" : Gosub EDR_CATTYP_PROPAGATE
      Endcase
    When "EDR.CATACT"
      Case [L]ARULE
        When "INIT"      : Gosub EDR_CATACT_INIT
        When "PROPAGATE" : Gosub EDR_CATACT_PROPAGATE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
      Endcase
    When Default
  Endcase
Return

###################################################################

$EDR_PARCOD_PROPAGATE
  Call EDR_DISPLAY(this)
Return

###################################################################

$EDR_PARTYP_INIT
Return

$EDR_PARTYP_PROPAGATE
  Call EDR_DISPLAY(this)
Return

###################################################################

$EDR_CATCOD_PROPAGATE
  Call EDR_DISPLAY(this)

  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.CATOPE = 2 #Create
  Else
    this.CATOPE = WCATOPE
  Endif
Return

###################################################################

$EDR_CATTYP_INIT
  this.CATTYP = 2
Return

$EDR_CATTYP_PROPAGATE
  Call EDR_DISPLAY(this)
Return

###################################################################

$EDR_CATACT_INIT
  this.CATACT = 2
Return

$EDR_CATACT_PROPAGATE
# Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  If this.CATACT <> 2 #RECEIVE
    ASTATUS = fmet this.ASETERROR("CATCOD",mess(8,2006,1),[V]CST_AERROR) #"Erreur type de catégorie interdit"
  Endif
Return

#####################################################################
# STANDARD METHODS
#####################################################################

#********************************************************************
# Method AQUERY_TRANS_AFTER
#********************************************************************
#*
#*!
$AQUERY_TRANS_AFTER
  this.EDR.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.EDR.CATCOD,"CATDES")
  this.EDR.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.EDR.PARCOD,"PARDES")

  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.EDR.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.EDR.CATOPE = 2 #Create
  Else
    this.EDR.CATOPE = WCATOPE
  Endif
Return

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#* Switch the display
#*!
$EDR_AREAD_AFTER
  Call EDR_DISPLAY(this)

  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.CATOPE = 2 #Create
  Else
    this.CATOPE = WCATOPE
  Endif
Return

#####################################################################
# USEFULL SUBS
#####################################################################

#********************************************************************
# Subprog EDR_DISPLAY
#********************************************************************
#
#* Switch the display according to CATTYP
#* @param WOBJECT --> OBJECT
#*!
Subprog EDR_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT

  Local Integer WOK
  Local Char WPROP(15)
  WPROP = "$isDisabled"
#WPROP = "$isHidden"

#Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
  WOK = fmet WOBJECT.ASETATTRIBUTE('FLOCOD', WPROP, 'false')
  WOK = fmet WOBJECT.ASETATTRIBUTE('FLOREL', WPROP, 'false')
  If WOBJECT.PARTYP = 1 or WOBJECT.PARTYP = 3
    WOK = fmet WOBJECT.ASETATTRIBUTE('ALLFLO', WPROP, 'true')
  Endif
#  If WOBJECT.CATTYP >= 1 and WOBJECT.CATTYP <= 5
#    If WOBJECT.PARTYP = 1 #"SAGE"
##      WOK = fmet WOBJECT.ASETATTRIBUTE('ALLFLO', WPROP, 'true')
#      WOK = fmet WOBJECT.ASETATTRIBUTE('FLOCOD', WPROP, 'false')
#      WOK = fmet WOBJECT.ASETATTRIBUTE('FLOREL', WPROP, 'false')
#    Else # "EDICOM" or "Misc"
#        WOK = fmet WOBJECT.ASETATTRIBUTE('FLOCOD', WPROP, 'false')
#        WOK = fmet WOBJECT.ASETATTRIBUTE('FLOREL', WPROP, 'false')
##      Endif
#    Endif
#  Else #documents
#      WOK = fmet WOBJECT.ASETATTRIBUTE('FLOCOD', WPROP, 'false')
#      WOK = fmet WOBJECT.ASETATTRIBUTE('FLOREL', WPROP, 'false')
#
#  Endif
End

