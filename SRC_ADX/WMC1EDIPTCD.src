####################################################################
# 7 : PTCLINVALDIR Value ( Field AVL 30)
####################################################################

$SET_PTCLINVALDIR
If [L]_AOLDVAL<>this.PTCLINVALDIR
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_PTCLINVALDIR
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.PTCLINVALDIR
 Gosub PROPAGATE_PTCLINVALDIR
Endif
Return

$INIT_PTCLINVALDIR
Gosub DECLARE_VAR From WMC0EDIPTCD
[L]CURPRO = "PTCLINVALDIR"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_PTCLINVALDIR
Gosub DECLARE_VAR From WMC0EDIPTCD
[L]CURPRO = "PTCLINVALDIR"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_PTCLINVALDIR          : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_PTCLINVALDIR          : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_PTCLINVALDIR
[L]CURPRO = "PTCLINVALDIR"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.PTCLINVALDIR,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_PTCLINVALDIR
[L]CURPRO = "PTCLINVALDIR"
If vireblc(this.PTCLINVALDIR,2)<>vireblc(format$("K:30X",this.PTCLINVALDIR),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_PTCLINVALDIR
[L]CURPRO = "PTCLINVALDIR"
If vireblc(this.PTCLINVALDIR,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPAVL.ACTRLREF(this,"PTCLINVALDIR",this.PTCLINVALDIR,this.PTCLINVALDIR,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.PTCLINVALDIR<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_PTCLINVALDIR
[L]CURPRO = "PTCLINVALDIR"
Return

$PROPAGATE_PTCLINVALDIR
this.isReadonly = 0
[L]CURPRO = "PTCLINVALDIR"
Gosub _LNKPRO_PTCLINVALDIR
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_PTCLINVALDIR
Gosub DECLARE_VAR From WMC0EDIPTCD
[L]CURPRO = "PTCLINVALDIR"
$_LNKPRO_PTCLINVALDIR
If vireblc(this.PTCLINVALDIR,2)<>""
 # Link AVOLUME
 Local File AVOLUME [WAVL]
 Read [F:WAVL]CODE = this.PTCLINVALDIR
 If !fstat
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="AVOLUME" & ZONE="DES" & IDENT1=[F:WAVL]VOLUME & IDENT2="" & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("PTCLINVALDIR","$description",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
 Endif
 LogicClose File [WAVL]
Endif
Return


