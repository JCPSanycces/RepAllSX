#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour Liste de gauche objet APR et APO
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update object APR & APO") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJAOB
End

#-------------------#
$MAJAOB

Local Integer I , VALMOD(20)
Local Char    OBJET(10)

If DOSSIER=GDOSX3
 Return
Endif
If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

For OBJET="APR","APO"

 # Mise à jour de la table AOBJET
 Call ECR_TRACE(mess(81,125,1)-"AOBJET:"-time$,0) From GESECRAN

 # Onglet Sélection
 Call MAJ_SEL(DOSSIER,OBJET) From PATCHAOB

 # Validation de l'objet

 Call VALID_TRT(DOSSIER,0,"","","","","","","","",OBJET,OBJET,"","","","","","","","","","",VALMOD) From VALDICO
 Call VALFEN(DOSSIER,OBJET) From SUBAOB

Next OBJET

Return
