#<AdxTL>@(#)0.0.0.0 $Revision$ Edition Balance analytique/bud
#**********************************************************************#
#    Modification                                                      #
# XXXXX XX.XX.XXXX xxxxxx_x : XXXXXXXXXXXXXXXXXXXXXXXXXXXX             #
# FPE     18.05.2018 X3-77154 : Use GBLAMAXCPY global variable         #
#                               (parameter) instead of a hard-coded    #
#                               value for MAXSOC.                      #
########################################################################
# Issue X3-101021 - 2018-09-05 by FHA : reading ATEXTRA using cache management

GFONCTION="EDITBLA"
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"EDITBLA","PRTBLA","",1,"") From GTRAITE
End
# Issue 84387 - 2018-04-16 by MDJ : PERF EXPORT CSV_XLS
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "INIPAR"    : Gosub INIPAR
 When "CONT1"     : Gosub CONT1
 When "CONT2"     : Gosub CONT2
Endcase
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Integer    MAXSEC : MAXSEC = 12   : # 12 niveaux de totaux
Local Integer    MAXCOL : MAXCOL = 6    : #  6 colonnes paramétrables
# Issue 77154
Local Integer    MAXSOC : MAXSOC = GBLAMAXCPY # max companies per group
                                              # limit is determined by a parameter (global variable).
If MAXSOC < 1
  MAXSOC = 50
Endif
# End issue 77154
Local Integer    MAXPER : MAXPER = 3    : #  3 périodes

Local Char       PARAM(30), ETAT(GLONARP), TYP_ETAT(GLONARP)
Local Char       SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY)
Local Integer    REFERENTIEL
Local Char       BUDGET(GLONBUP) , VERSION(20)
Local Date       DATDEB(1..MAXPER) , DATFIN(1..MAXPER)
Local Integer    TYPAXE(1..MAXSEC)
Local Char       AXE(GLONDIE)(1..MAXSEC)
Local Char       CPTDEB(GLONGAC) , CPTFIN(GLONGAC) , SECDEB(GLONCCE)(1..MAXSEC) , SECFIN(GLONCCE)(1..MAXSEC)
Local Char       PYRCPT(GLONGYM) , PYRSEC(GLONCYM)(1..MAXSEC)
Local Integer    NIVCPT , NIVSEC(1..MAXSEC)
Local Integer    RNGCPTDEB , RNGCPTFIN , RNGSECDEB(1..MAXSEC) , RNGSECFIN(1..MAXSEC)
Local Char       DEVORG(GLONCUR) , DEVIMP(GLONCUR)
Local Decimal    COURANA , COURBUD
Local Integer    TYPCOL(1..MAXCOL) , PERCOL(1..MAXCOL)
Local Integer    NBAXE , SENS , DETAIL_SITE , TOUTAXE , AUCAXE , ANOUVEAU , CLOTURE , INTCOURT
Local Char       PROFIL(GLONAPM) , FONCTION(GLONAFC) , USER(GLONAUS)
Local Integer    IPER , NPER
Local Integer    I , J , K , NUMREQ

Call TEMPON("O") From GESECRAN
Gosub OUVFIC

# Récup des paramètres

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
K = instr(1,ETAT,".")
If K : ETAT = left$(ETAT,K-1) : Endif
Call GETPARAM("typetat",NBPAR,PARAMETRE,TYP_ETAT) From ETAT
If TYP_ETAT="?????" : TYP_ETAT = ETAT : Endif

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
Call GETPARAM("referentiel",NBPAR,PARAMETRE,PARAM) From ETAT    : REFERENTIEL = val(PARAM)
Call GETPARAM("budget",NBPAR,PARAMETRE,BUDGET) From ETAT
Call GETPARAM("version",NBPAR,PARAMETRE,VERSION) From ETAT
Call GETPARCHAR("sitedeb",NBPAR,PARAMETRE,SITEDEB)
Call GETPARCHAR("sitefin",NBPAR,PARAMETRE,SITEFIN)
Call GETPARAM("nbper",NBPAR,PARAMETRE,PARAM) From ETAT    : NPER = val(PARAM)
For IPER=1 To NPER
 Call GETPARAM("dat"+num$(IPER)+"deb",NBPAR,PARAMETRE,PARAM) From ETAT : DATDEB(IPER) = PARAM
 Call GETPARAM("dat"+num$(IPER)+"fin",NBPAR,PARAMETRE,PARAM) From ETAT : DATFIN(IPER) = PARAM
Next IPER
Call GETPARAM("nbaxe",NBPAR,PARAMETRE,PARAM) From ETAT          : NBAXE     = val(PARAM)
If NBAXE>5
 NBAXE = 5 : # 5 niveaux de totaux sur l'état
Endif
For I=1 To NBAXE
 Call GETPARAM("typ"+num$(I),NBPAR,PARAMETRE,PARAM) From ETAT   : TYPAXE(I) = val(PARAM)
 Call GETPARAM("axe"+num$(I),NBPAR,PARAMETRE,AXE(I)) From ETAT
 Call GETPARCHAR("sec"+num$(I)+"deb",NBPAR,PARAMETRE,SECDEB(I))
 Call GETPARCHAR("sec"+num$(I)+"fin",NBPAR,PARAMETRE,SECFIN(I))
 Call GETPARAM("pyrsec"+num$(I),NBPAR,PARAMETRE,PYRSEC(I)) From ETAT
 Call GETPARAM("nivsec"+num$(I),NBPAR,PARAMETRE,PARAM) From ETAT         : NIVSEC(I)    = val(PARAM)
 Call GETPARINT("rngsec"+num$(I)+"deb",NBPAR,PARAMETRE,PARAM)            : RNGSECDEB(I) = val(PARAM)
 Call GETPARINT("rngsec"+num$(I)+"fin",NBPAR,PARAMETRE,PARAM)            : RNGSECFIN(I) = val(PARAM)
Next I
Call GETPARAM("devorg",NBPAR,PARAMETRE,DEVORG) From ETAT
Call GETPARAM("devimp",NBPAR,PARAMETRE,DEVIMP) From ETAT
Call GETPARAM("courana",NBPAR,PARAMETRE,PARAM) From ETAT        : COURANA = val(PARAM)
Call GETPARAM("courbud",NBPAR,PARAMETRE,PARAM) From ETAT        : COURBUD = val(PARAM)
For I=1 To MAXCOL
 Call GETPARAM("typcol"+num$(I),NBPAR,PARAMETRE,PARAM) From ETAT : TYPCOL(I) = val(PARAM)
Next I
Call GETPARAM("sens",NBPAR,PARAMETRE,PARAM) From ETAT           : SENS = val(PARAM)
Call GETPARAM("detail_site",NBPAR,PARAMETRE,PARAM) From ETAT    : DETAIL_SITE = val(PARAM)
Call GETPARAM("toutaxe",NBPAR,PARAMETRE,PARAM) From ETAT        : TOUTAXE  = val(PARAM)
Call GETPARAM("aucaxe",NBPAR,PARAMETRE,PARAM) From ETAT         : AUCAXE   = val(PARAM)
Call GETPARAM("anouveau",NBPAR,PARAMETRE,PARAM) From ETAT       : ANOUVEAU = val(PARAM)
Call GETPARAM("cloture",NBPAR,PARAMETRE,PARAM) From ETAT        : CLOTURE  = val(PARAM)
Call GETPARAM("intcourt",NBPAR,PARAMETRE,PARAM) From ETAT       : INTCOURT = val(PARAM)
Call GETPARAM("X3PRF",NBPAR,PARAMETRE,PROFIL) From ETAT
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,FONCTION) From ETAT
Call GETPARAM("X3USR",NBPAR,PARAMETRE,USER) From ETAT
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT      : NUMREQ = val(PARAM)
If NPER>1
 For I=1 To MAXCOL
  Call GETPARAM("percol"+num$(I),NBPAR,PARAMETRE,PARAM) From ETAT : PERCOL(I) = val(PARAM)
 Next I
Endif

Call GETPARAM("calcul",NBPAR,PARAMETRE,PARAM) From ETAT
If val(PARAM)=0
 # Il faut lancer l'extraction
 Call BALANA(ETAT,TYP_ETAT,SOCIETE,REFERENTIEL,BUDGET,VERSION,SITEDEB,SITEFIN,NPER,DATDEB,DATFIN
&           ,NBAXE,TYPAXE,AXE,SECDEB,SECFIN,PYRSEC,NIVSEC,RNGSECDEB,RNGSECFIN
&           ,DEVORG,DEVIMP,COURANA,COURBUD,TYPCOL,PERCOL,SENS
&           ,DETAIL_SITE,TOUTAXE,AUCAXE,ANOUVEAU,CLOTURE,INTCOURT,PROFIL,FONCTION,USER,NUMREQ)
Else
 # La table temporaire est déjà alimentée par la consultation
 NUMREQ = val(PARAM)
Endif

For IPER=1 To NPER
 PARAM = format$("D:YYYYMMDD",DATDEB(IPER))
 Call SETPARAM("dat"+num$(IPER)+"deb",NBPAR,PARAMETRE,PARAM) From ETAT
 PARAM = format$("D:YYYYMMDD",DATFIN(IPER))
 Call SETPARAM("dat"+num$(IPER)+"fin",NBPAR,PARAMETRE,PARAM) From ETAT
Next IPER

PARAM = num$(NUMREQ)
Call SETPARAM("numreq",NBPAR,PARAMETRE,PARAM) From ETAT
Read [CPY]CPY0 = SOCIETE
Call SETPARAM("libcpy",NBPAR,PARAMETRE,[F:CPY]CPYNAM) From ETAT
Call TEMPOFF From GESECRAN
End

###########################################################################################################
###########################################################################################################
Subprog BALANA(ETAT,TYP_ETAT,SOCIETE,REFERENTIEL,BUDGET,VERSION,SITEDEB,SITEFIN,NPER,DATDEB,DATFIN
&             ,NBAXE,TYPAXE,AXE,SECDEB,SECFIN,PYRSEC,NIVSEC,RNGSECDEB,RNGSECFIN
&             ,DEVORG,DEVIMP,COURANA,COURBUD,TYPCOL,PERCOL,SENS
&             ,DETAIL_SITE,TOUTAXE,AUCAXE,ANOUVEAU,CLOTURE,INTCOURT,PROFIL,FONCTION,USER,NUMREQ)
Value    Char    ETAT
Value    Char    TYP_ETAT
Value    Char    SOCIETE
Value    Integer REFERENTIEL
Value    Char    BUDGET
Value    Char    VERSION
Value    Char    SITEDEB
Value    Char    SITEFIN
Value    Integer NPER
Variable Date    DATDEB(1..)
Variable Date    DATFIN(1..)
Value    Integer NBAXE
Value    Integer TYPAXE(1..)
Value    Char    AXE()(1..)
Value    Char    SECDEB()(1..)
Value    Char    SECFIN()(1..)
Value    Char    PYRSEC()(1..)
Value    Integer NIVSEC(1..)
Value    Integer RNGSECDEB(1..)
Value    Integer RNGSECFIN(1..)
Value    Char    DEVORG
Value    Char    DEVIMP
Value    Decimal COURANA
Value    Decimal COURBUD
Value    Integer TYPCOL(1..)
Value    Integer PERCOL(1..)
Value    Integer SENS
Value    Integer DETAIL_SITE
Value    Integer TOUTAXE
Value    Integer AUCAXE
Value    Integer ANOUVEAU
Value    Integer CLOTURE
Value    Integer INTCOURT
Value    Char    PROFIL
Value    Char    FONCTION
Value    Char    USER
Value    Integer NUMREQ

# Déclarations

Local Integer    MAXSEC : MAXSEC = dim(AXE)
Local Integer    MAXCOL : MAXCOL = dim(TYPCOL)
Local Integer    MAXSOC : MAXSOC = GBLAMAXCPY # max companies per group # Issue 77154 - 2018-05-18 by FPE :
                                              # limit is determined by a parameter (global variable).
# Issue X3-77154
If MAXSOC < 1
  MAXSOC = 50
Endif
# End issue X3-77154

#Local Integer    MAXSIT : MAXSIT = 50           : # 50 sites par société
Local Integer    MAXPER : MAXPER = dim(DATDEB)

Local Char       REFER(GLONLED) , DEVREF(GLONCUR)
Local Integer    NUMAXE(1..MAXSEC,1..MAXSOC)
Local Integer    IPER , NBPER , NNPER
Local Integer    GROUPE , GRPSOC , ANA , QTE , BUD , ENG
Local Integer    I , J , K , LIGNE , PASSE , EFFACE
Local Integer    ICRIT
Local Char       CRITERE(250)(1..10) , CRITBUD(250)(1..10) , CRITSOC(250) , CLE(250)
Local Char       PROG(GLONADC) , FICSRC(250) , FICADX(250)
Local Integer    STAT , OK , OKAXE
Local Integer    BUDSIT , NUMBUD(1..MAXSEC)
Local Char       SECTION(20)
Local Integer    ISOC , NBSOC
Local Decimal    EDEB(1..MAXPER,1..MAXSOC) , EFIN(1..MAXPER,1..MAXSOC)
Local Decimal    PDEB(1..MAXPER,1..MAXSOC) , PFIN(1..MAXPER,1..MAXSOC)
Local Char       SOC(GLONCPY)(1..MAXSOC)
Local Date       TBPER(1..100) , FINPER
Local Integer    NIVPYR , OKBUD , OKSIT
Local Char       GROUPYR(max(GLONGRY,GLONCYR))
Local Char       DESIG(GLONAX3)
Local Char       DESTRA(10)
Local Integer    NBCLE , NBLNK , MAXCLE , MAXLNK
Local Char       CHIFFRES(20)

Global Integer GCALL_PT : Raz GCALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("EDITBLA",GENTSTD(1..GNBENTREE))
 GCALL_PT=1
Endif

CHIFFRES = "123456789ABC"
EFFACE = 1

# Issue X3-101021 ATEXTRA reading
Global Integer   WCACHETEX  : WCACHETEX    = 1      # 1 = use cache  0 = use classical LECATEXTRA     (delivered 1)
Local Integer    LOGCACHE   : [L]LOGCACHE  = 0      # 1 = log the atextra cache at the end 0 = no log (delivered 0)
# Cache for ATEXTRA reads
Global Integer   DIMCACHE                           # Cache dimension from folder parameter ATXCACHE
DIMCACHE = abs(val(func AFNC.PARAMDOS("","ATXCACHE")))
If DIMCACHE = 0 : DIMCACHE = 5000 : Endif
Global Char      CTEXKEY(187)(DIMCACHE)
Global Char      CTEXTEX(80) (DIMCACHE)
Global Integer   CTEXHIT     (DIMCACHE)
Global Integer   CTEXCUR
# End issue X3-101021

# Ouverture des tables

Gosub OUVFIC
For I=1 To NBAXE
 Case TYPAXE(I)
  When 1
   Case I
    When 1
     If clalev([F:GAC1])=0 : Local File GACCOUNT   [GAC1] : Endif
     If clalev([F:GYK1])=0 : Local File GACCPYMLIK [GYK1] : Endif
     If clalev([F:GRY1])=0 : Local File GACCGRUPYM [GRY1] : Endif
    When 2
     If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif
     If clalev([F:GYK2])=0 : Local File GACCPYMLIK [GYK2] : Endif
     If clalev([F:GRY2])=0 : Local File GACCGRUPYM [GRY2] : Endif
    When 3
     If clalev([F:GAC3])=0 : Local File GACCOUNT   [GAC3] : Endif
     If clalev([F:GYK3])=0 : Local File GACCPYMLIK [GYK3] : Endif
     If clalev([F:GRY3])=0 : Local File GACCGRUPYM [GRY3] : Endif
    When 4
     If clalev([F:GAC4])=0 : Local File GACCOUNT   [GAC4] : Endif
     If clalev([F:GYK4])=0 : Local File GACCPYMLIK [GYK4] : Endif
     If clalev([F:GRY4])=0 : Local File GACCGRUPYM [GRY4] : Endif
    When 5
     If clalev([F:GAC5])=0 : Local File GACCOUNT   [GAC5] : Endif
     If clalev([F:GYK5])=0 : Local File GACCPYMLIK [GYK5] : Endif
     If clalev([F:GRY5])=0 : Local File GACCGRUPYM [GRY5] : Endif
    When 6
     If clalev([F:GAC6])=0 : Local File GACCOUNT   [GAC6] : Endif
     If clalev([F:GYK6])=0 : Local File GACCPYMLIK [GYK6] : Endif
     If clalev([F:GRY6])=0 : Local File GACCGRUPYM [GRY6] : Endif
    When 7
     If clalev([F:GAC7])=0 : Local File GACCOUNT   [GAC7] : Endif
     If clalev([F:GYK7])=0 : Local File GACCPYMLIK [GYK7] : Endif
     If clalev([F:GRY7])=0 : Local File GACCGRUPYM [GRY7] : Endif
    When 8
     If clalev([F:GAC8])=0 : Local File GACCOUNT   [GAC8] : Endif
     If clalev([F:GYK8])=0 : Local File GACCPYMLIK [GYK8] : Endif
     If clalev([F:GRY8])=0 : Local File GACCGRUPYM [GRY8] : Endif
    When 9
     If clalev([F:GAC9])=0 : Local File GACCOUNT   [GAC9] : Endif
     If clalev([F:GYK9])=0 : Local File GACCPYMLIK [GYK9] : Endif
     If clalev([F:GRY9])=0 : Local File GACCGRUPYM [GRY9] : Endif
    When 10
     If clalev([F:GACA])=0 : Local File GACCOUNT   [GACA] : Endif
     If clalev([F:GYKA])=0 : Local File GACCPYMLIK [GYKA] : Endif
     If clalev([F:GRYA])=0 : Local File GACCGRUPYM [GRYA] : Endif
    When 11
     If clalev([F:GACB])=0 : Local File GACCOUNT   [GACB] : Endif
     If clalev([F:GYKB])=0 : Local File GACCPYMLIK [GYKB] : Endif
     If clalev([F:GRYB])=0 : Local File GACCGRUPYM [GRYB] : Endif
    When 12
     If clalev([F:GACC])=0 : Local File GACCOUNT   [GACC] : Endif
     If clalev([F:GYKC])=0 : Local File GACCPYMLIK [GYKC] : Endif
     If clalev([F:GRYC])=0 : Local File GACCGRUPYM [GRYC] : Endif
   Endcase
  When 2
   Case I
    When 1
     If clalev([F:CCE1])=0 : Local File CACCE      [CCE1] : Endif
     If clalev([F:CYK1])=0 : Local File GCCEPYMLIK [CYK1] : Endif
     If clalev([F:CRY1])=0 : Local File GCCEGRUPYM [CRY1] : Endif
    When 2
     If clalev([F:CCE2])=0 : Local File CACCE      [CCE2] : Endif
     If clalev([F:CYK2])=0 : Local File GCCEPYMLIK [CYK2] : Endif
     If clalev([F:CRY2])=0 : Local File GCCEGRUPYM [CRY2] : Endif
    When 3
     If clalev([F:CCE3])=0 : Local File CACCE      [CCE3] : Endif
     If clalev([F:CYK3])=0 : Local File GCCEPYMLIK [CYK3] : Endif
     If clalev([F:CRY3])=0 : Local File GCCEGRUPYM [CRY3] : Endif
    When 4
     If clalev([F:CCE4])=0 : Local File CACCE      [CCE4] : Endif
     If clalev([F:CYK4])=0 : Local File GCCEPYMLIK [CYK4] : Endif
     If clalev([F:CRY4])=0 : Local File GCCEGRUPYM [CRY4] : Endif
    When 5
     If clalev([F:CCE5])=0 : Local File CACCE      [CCE5] : Endif
     If clalev([F:CYK5])=0 : Local File GCCEPYMLIK [CYK5] : Endif
     If clalev([F:CRY5])=0 : Local File GCCEGRUPYM [CRY5] : Endif
    When 6
     If clalev([F:CCE6])=0 : Local File CACCE      [CCE6] : Endif
     If clalev([F:CYK6])=0 : Local File GCCEPYMLIK [CYK6] : Endif
     If clalev([F:CRY6])=0 : Local File GCCEGRUPYM [CRY6] : Endif
    When 7
     If clalev([F:CCE7])=0 : Local File CACCE      [CCE7] : Endif
     If clalev([F:CYK7])=0 : Local File GCCEPYMLIK [CYK7] : Endif
     If clalev([F:CRY7])=0 : Local File GCCEGRUPYM [CRY7] : Endif
    When 8
     If clalev([F:CCE8])=0 : Local File CACCE      [CCE8] : Endif
     If clalev([F:CYK8])=0 : Local File GCCEPYMLIK [CYK8] : Endif
     If clalev([F:CRY8])=0 : Local File GCCEGRUPYM [CRY8] : Endif
    When 9
     If clalev([F:CCE9])=0 : Local File CACCE      [CCE9] : Endif
     If clalev([F:CYK9])=0 : Local File GCCEPYMLIK [CYK9] : Endif
     If clalev([F:CRY9])=0 : Local File GCCEGRUPYM [CRY9] : Endif
    When 10
     If clalev([F:CCEA])=0 : Local File CACCE      [CCEA] : Endif
     If clalev([F:CYKA])=0 : Local File GCCEPYMLIK [CYKA] : Endif
     If clalev([F:CRYA])=0 : Local File GCCEGRUPYM [CRYA] : Endif
    When 11
     If clalev([F:CCEB])=0 : Local File CACCE      [CCEB] : Endif
     If clalev([F:CYKB])=0 : Local File GCCEPYMLIK [CYKB] : Endif
     If clalev([F:CRYB])=0 : Local File GCCEGRUPYM [CRYB] : Endif
    When 12
     If clalev([F:CCEC])=0 : Local File CACCE      [CCEC] : Endif
     If clalev([F:CYKC])=0 : Local File GCCEPYMLIK [CYKC] : Endif
     If clalev([F:CRYC])=0 : Local File GCCEGRUPYM [CRYC] : Endif
   Endcase
 Endcase
Next I
If clalev([F:GRYX])=0 : Local File GACCGRUPYM [GRYX] : Endif
If clalev([F:CRYX])=0 : Local File GCCEGRUPYM [CRYX] : Endif

GOK = 1

# Vérification des paramètres

GROUPE = 0
GRPSOC = 0
Read [CPY]CPY0    = SOCIETE
If [F:CPY]CPYLEGFLG=2
 NBSOC  = 1
 SOC(1) = SOCIETE
Else
 GROUPE = 1
 NBSOC  = 0
 Read [AGF]AGF0 = SOCIETE
 If [F:AGF]FLGCPY=2
  GRPSOC = 1
 Endif
 For [FGR]FGR0 Where CPY=SOCIETE
  Read [FCY]FCY0 = [F:FGR]FCY
  If !find([F:FCY]LEGCPY,SOC(1..NBSOC))
   If NBSOC>=MAXSOC
    GMESSAGE = mess(108,104,1)-"("+num$(MAXSOC)+")" : # Too many companies # Issue X3-77154 - 2018-05-18 by FPE :
                                                      # Correct message is 108
    GOK = 0 : Break
   Else
    NBSOC += 1
    SOC(NBSOC) = [F:FCY]LEGCPY
   Endif
  Endif
 Next
 If !GOK : Goto ERREUR : Endif
Endif

For IPER=1 To NPER
 Call CNTCOHPERV6(SOCIETE,REFERENTIEL,DATDEB(IPER),DATFIN(IPER),STAT,GMESSAGE) From CPTCNT
 If STAT=0 : GOK = 0 : Break : Endif
Next IPER
If !GOK : Goto ERREUR : Endif

For ISOC=1 To NBSOC
 SOCREF = SOC(ISOC)
 Read [CPY]CPY0 = SOCREF
 Read [GCM]GCM0 = [F:CPY]ACM
 If [F:GCM]LED(REFERENTIEL-1)=""
  GMESSAGE = mess(REFERENTIEL,2644,1)-":"-mess(105,104,1)-SOCREF : # Référentiel non défini pour la société
  GOK = 0 : Break
 Endif
 REFER  = [F:GCM]LED(REFERENTIEL-1)
 Read [LED]LED0 = REFER
 For I=1 To NBAXE
  If TYPAXE(I)=2
   K = find(AXE(I),[F:LED]DIE(0..[F:LED]DIENBR-1))
   If K
    NUMAXE(I,ISOC) = K
   Else
    GMESSAGE = AXE(I)-":"-mess(81,103,1)-REFER : # Axe inexistant dans le référentiel
    GOK = 0 : Break 2
   Endif
  Endif
 Next I

 If ISOC=1
  DEVREF = [F:GCM]CUR(REFERENTIEL-1)
 Else
#  If [F:GCM]LED(REFERENTIEL-1)<>REFER
#   GMESSAGE = SOCREF-":"-mess(82,103,1)-"("+[F:GCM]LED(REFERENTIEL-1)+")" : # Référentiel incompatible
#   GOK = 0 : Break
#  Endif
  If [F:GCM]CUR(REFERENTIEL-1)<>DEVREF & (DEVORG="" or DEVORG<>DEVIMP)
   GMESSAGE = SOCREF-":"-mess(90,103,1)-"("+[F:GCM]CUR(REFERENTIEL-1)+")" : # Devise incompatible
   GOK = 0 : Break
  Endif
 Endif

 For IPER=1 To NPER
  Filter [PER] Where CPY=SOCREF & LEDTYP=REFERENTIEL & PERSTR<=DATDEB(IPER) & PEREND>=DATDEB(IPER)
  Read [PER]PER0 First
  If fstat<=2
   EDEB(IPER,ISOC) = [F:PER]FIYNUM
   PDEB(IPER,ISOC) = [F:PER]PERNUM
   DATDEB(IPER)    = [F:PER]PERSTR
  Else
   Filter [PER] Where CPY=SOCREF & LEDTYP=REFERENTIEL
   Read [PER]PER0 First
   If fstat<=2 & [F:PER]PERSTR>=DATDEB(IPER) & [F:PER]PERSTR<=DATFIN(IPER)
    EDEB(IPER,ISOC) = [F:PER]FIYNUM
    PDEB(IPER,ISOC) = [F:PER]PERNUM
   Endif
  Endif
  Filter [PER] Where CPY=SOCREF & LEDTYP=REFERENTIEL & PERSTR<=DATFIN(IPER) & PEREND>=DATFIN(IPER)
  Read [PER]PER0 First
  If fstat<=2
   EFIN(IPER,ISOC) = [F:PER]FIYNUM
   PFIN(IPER,ISOC) = [F:PER]PERNUM
   DATFIN(IPER)    = [F:PER]PEREND
  Else
   Filter [PER] Where CPY=SOCREF & LEDTYP=REFERENTIEL
   Read [PER]PER0 Last
   If fstat<=2 & [F:PER]PEREND>=DATDEB(IPER) & [F:PER]PEREND<=DATFIN(IPER)
    EFIN(IPER,ISOC) = [F:PER]FIYNUM
    PFIN(IPER,ISOC) = [F:PER]PERNUM
   Endif
  Endif
  Filter [PER]

 Next ISOC
Next IPER
If !GOK : Goto ERREUR : Endif

If DEVIMP=""
 DEVIMP = DEVREF
Endif

ANA = 0
BUD = 0
QTE = 0
ENG = 0
For I=1 To MAXCOL
 If find(TYPCOL(I),2,3,4,5,8,9,17,18,19,23,24,25,29,30,31,35,36,37)
  ANA = 1
 Endif
 If TYPCOL(I)=10 or TYPCOL(I)>=16
  BUD = 1
 Endif
 If find(TYPCOL(I),11,12,13,14,15,20,21,22,26,27,28,32,33,34,38,39,40)
  QTE = 1
 Endif
 If find(TYPCOL(I),6,7,8,9,18,19,24,25,30,31,36,37)
  ENG = 1
 Endif
Next I

If INTCOURT
 DESTRA = "SHOTRA"
Else
 DESTRA = "DESTRA"
Endif

If BUD
 If BUDGET=""
  GMESSAGE = mess(25,108,1) : # Pas de budget défini
  Goto ERREUR
 Endif
 Read [BUP]BUP0 = BUDGET
 BUDSIT = ([F:BUP]LEV=2)
 If [F:BUP]COA<>[F:LED]COA
  GMESSAGE = BUDGET-":"-mess(83,103,1)-[F:BUP]COA-"("+[F:LED]COA+")" : # Budget sur le plan comptable
  Goto ERREUR
 Endif
 For I=1 To NBAXE
  If TYPAXE(I)=2
   K = find(AXE(I),[F:BUP]DIE(0..dim([F:BUP]DIE)-1))
   If K
    NUMBUD(I) = K
   Else
    GMESSAGE = AXE(I)-":"-mess(84,103,1)-BUDGET : # Axe non défini pour le budget
    GOK = 0 : Break
   Endif
  Endif
 Next I
 If !GOK : Goto ERREUR : Endif
 For I=1 To NBAXE
  If TYPAXE(I)=1
   If PYRSEC(I)<>"" & [F:BUP]PYMACC<>""
    If [F:BUP]PYMACC<>PYRSEC(I)
     GMESSAGE = BUDGET-":"-mess(85,103,1)-[F:BUP]PYMACC : # Budget défini sur la pyramide de comptes
     Goto ERREUR
    Elsif [F:BUP]PYMACCLEV<NIVSEC(I)
     GMESSAGE = BUDGET-":"-mess(89,103,1)-num$([F:BUP]PYMACCLEV)-"("+[F:BUP]PYMACC+")" : # Budget défini au niveau
     Goto ERREUR
    Endif
   Endif
  Else
   If PYRSEC(I)<>"" & [F:BUP]PYMCCE(NUMBUD(I)-1)<>""
    If [F:BUP]PYMCCE(NUMBUD(I)-1)<>PYRSEC(I)
     GMESSAGE = BUDGET-"("+AXE(I)+")"-":"-mess(86,103,1)-[F:BUP]PYMCCE(NUMBUD(I)-1) : # Budget défini sur la pyramide de sections
     GOK = 0 : Break
    Elsif [F:BUP]PYMCCELEV(NUMBUD(I)-1)<NIVSEC(I)
     GMESSAGE = BUDGET-"("+AXE(I)+")"-":"-mess(89,103,1)-num$([F:BUP]PYMCCELEV(NUMBUD(I)-1))-"("+[F:BUP]PYMCCE(NUMBUD(I)-1)+")"
     # Budget défini au niveau
     GOK = 0 : Break
    Endif
   Endif
  Endif
 Next I
 If !GOK : Goto ERREUR : Endif
 If GROUPE & !BUDSIT
  GMESSAGE = BUDGET-":"-mess(33,108,1) : # Budget défini au niveau société
  Goto ERREUR
 Endif
Endif

# Autorisations

If GUSRFCY(1)<>"\"
 OKSIT = 0
 If GROUPE=0
  For [FCY]FCY1 Where LEGCPY=SOCIETE
   If find([F:FCY]FCY,GUSRFCY(1..GNBAUZ))
    OKSIT = 1 : Break
   Endif
  Next
 Else
  For [FGR] Where CPY=SOCIETE
   If find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    OKSIT = 1 : Break
   Endif
  Next
 Endif
 If !OKSIT
  GMESSAGE = mess(26,135,1) : # You don't have the rights...
  Goto ERREUR
 Endif
Endif

# Génération du link qui va bien...

PROG   = "WW"+num$(adxuid(1))
FICSRC = filpath("TRT",PROG,"src",0)
FICADX = filpath("TRT",PROG,"adx",0)

Openo FICSRC,0
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq
Wrseq "$LIENS"
Wrseq "Case ISOC"

For ISOC=1 To NBSOC
 Wrseq " When "+num$(ISOC)
 Wrseq '  Link [BLA] With'
 Wrseq '&      [GAC]GAC0   ~= [F:BLA]COA;[F:BLA]ACC'
 Wrseq '&    , [ACC]CODACC ~= "'+USER+'";[F:GAC]ACS'
 Wrseq '&    , [AFF]AFF0   ~= [F:BLA]FCY;"'+PROFIL+'";"'+FONCTION+'"'
 If GROUPE & !GRPSOC
  Wrseq '&    , [FGR]FGR1   ~= [F:BLA]FCY;"'+SOCIETE+'"'
 Endif
 For I=1 To NBAXE
  If TYPAXE(I)=3
   Wrseq '&    , [BPR]BPR0 = [F:BLA]BPR'
  Elsif PYRSEC(I)<>""
   Case TYPAXE(I)
    When 1
     Wrseq '&    , [GYK'+mid$(CHIFFRES,I,1)+']GYK0  ~= "'+PYRSEC(I)+'";'+num$(NIVSEC(I))+';[F:BLA]ACC'
    When 2
     Wrseq '&    , [CYK'+mid$(CHIFFRES,I,1)+']CYK0  ~= "'+PYRSEC(I)+'";'+num$(NIVSEC(I))+';[F:BLA]CCE'+num$(NUMAXE(I,ISOC))
   Endcase
  Endif
 Next I
 Wrseq "&   As [LBLA]"
 CLE = ""
 Gosub TRISEC
 If CLE<>"" : CLE += ";" : Endif
 CLE += "[F:BLA]FCY;[F:BLA]CUR"
 Wrseq "&   Where evalue(CRITERE(1..5))"
 Wrseq "&   Order By Key CLE = ";CLE
Next ISOC
Wrseq "Endcase"

Wrseq "Return"
Wrseq

If BUD
 Wrseq "$LIENBUD"
 Wrseq "Case ISOC"
 For ISOC=1 To NBSOC
   Wrseq " When "+num$(ISOC)
   Wrseq '  Link [BUD] With'
   If [F:BUP]PYMACC=""
    Wrseq '&      [GAC]GAC0   ~= [F:BUD]COA;[F:BUD]ACC'
    Wrseq '&    , [ACC]CODACC ~= "'+USER+'";[F:GAC]ACS'
   Else
    Wrseq '&      [CPY]CPY0   ~= [F:BUD]CPY' : # Bidon pour la ,
   Endif
   If BUDSIT
    Wrseq '&    , [AFF]AFF0 ~= [F:BUD]FCY;"'+PROFIL+'";"'+FONCTION+'"'
   Endif
   If GROUPE & !GRPSOC
    Wrseq '&    , [FGR]FGR1   ~= [F:BUD]FCY;"'+SOCIETE+'"'
   Endif
   For I=1 To NBAXE
    If PYRSEC(I)<>""
     Case TYPAXE(I)
      When 1
       If [F:BUP]PYMACC=""
        Wrseq '&    , [GYK'+mid$(CHIFFRES,I,1)+']GYK0  ~= "'+PYRSEC(I)+'";'+num$(NIVSEC(I))+';[F:BUD]ACC'
       Else
        Wrseq '&    , [GRY'+mid$(CHIFFRES,I,1)+']GRY0  ~= "'+PYRSEC(I)+'";[F:BUD]ACC;1'
       Endif
      When 2
       If [F:BUP]PYMCCE(NUMBUD(I)-1)=""
        Wrseq '&    , [CYK'+mid$(CHIFFRES,I,1)+']CYK0  ~= "'+PYRSEC(I)+'";'+num$(NIVSEC(I))+';[F:BUD]CCE'+num$(NUMAXE(I,ISOC))
       Else
        Wrseq '&    , [CRY'+mid$(CHIFFRES,I,1)+']CRY0  ~= "'+PYRSEC(I)+'";[F:BUD]CCE'+num$(NUMAXE(I,ISOC))+';1'
       Endif
     Endcase
    Endif
   Next I
   Wrseq "&   As [LBUD]"
   CLE = ""
   Gosub TRIBUDSEC
   If CLE<>""
    CLE += ";[F:BUD]FCY"
   Else
    CLE += "[F:BUD]FCY"
   Endif
   Wrseq "&   Where evalue(CRITBUD(1..5))"
   Wrseq "&   Order By Key CLE = ";CLE
 Next ISOC
 Wrseq "Endcase"
 Wrseq "Return"
 Wrseq
Endif
Wrseq

Openo

# Validation du traitement

Call VALID("TRT",PROG,nomap,STAT) From VALMSKSUB

# Exécution

If EFFACE
 Gosub TR3
Endif

LIGNE = 0

If ANA
 PASSE = 1
 Local File BALANA [BLA]
 Call DEBTRANS From GLOCK
 Gosub TR1
 Close Local File [BLA]
Endif

If QTE
 PASSE = 2
 Local File BLAQTY [BLA]
 Call DEBTRANS From GLOCK
 Gosub TR1
 Close Local File [BLA]
Endif

If ENG
 PASSE = 3
 Local File BLACMM [BLA]
 Call DEBTRANS From GLOCK
 Gosub TR1
 Close Local File [BLA]
Endif

If BUD
 PASSE = 4
 Local File BUD [BUD]
 Call DEBTRANS From GLOCK
 Gosub TR2
 Close Local File [BUD]
Endif

# Impression
Call EFFACE(FICSRC,STAT) From ORDSYS
Call EFFACE(FICADX,STAT) From ORDSYS
Kill GCALL_PT

# Issue X3-101021
# logging the cache (internal test use)
If [L]LOGCACHE and GTRACE = ""
  Local Integer WI
  Call OUVRE_TRACE("ATEXTRA cache") From LECFIC
  Call ECR_TRACE("Buffer dim ="-num$(DIMCACHE),0) From GESECRAN
  For WI=0 To CTEXCUR-1
    Call ECR_TRACE( CTEXKEY(WI)-CTEXTEX(WI)-":"-num$(CTEXHIT(WI)),0) From GESECRAN
  Next
  Call FERME_TRACE From LECFIC
Endif
Gosub KILL_ATX_CACHE
# End issue X3-101021

End

$CRITERE
Raz CRITERE
ICRIT = 1
Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]LEDTYP='+num$(REFERENTIEL))
If SITEDEB<>"" & SITEDEB=SITEFIN
 Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]FCY="'+SITEDEB+'"')
Else
 If SITEDEB<>""
  Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]FCY>="'+SITEDEB+'"')
 Endif
 If SITEFIN<>""
  Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]FCY<="'+SITEFIN+'"')
 Endif
Endif
If DEVORG<>""
 Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]CUR="'+DEVORG+'"')
Endif
Call ADDCRIT(ICRIT,CRITERE,'[F:ACC]CONSUL=2')

If PASSE=1 | PASSE=2
 If !find(3,TYPAXE(1..NBAXE))
  Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]BPR=""')
 Else
  Call ADDCRIT(ICRIT,CRITERE,'([F:BLA]BPR<>"" | [F:GAC]SAC<>2)')
 Endif
Elsif PASSE=3
 If !find(3,TYPAXE(1..NBAXE))
  Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]BPR=""')
 Else
  Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]BPR<>""')
 Endif
Endif

For I=1 To NBAXE
 Case TYPAXE(I)
  When 1
   If PYRSEC(I)<>""
    If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
     Call ADDCRIT(ICRIT,CRITERE,'[F:GYK'+mid$(CHIFFRES,I,1)+']PRNROW='+num$(RNGSECDEB(I)))
    Else
     If RNGSECDEB(I)<>0
      Call ADDCRIT(ICRIT,CRITERE,'[F:GYK'+mid$(CHIFFRES,I,1)+']PRNROW>='+num$(RNGSECDEB(I)))
     Endif
     If RNGSECFIN(I)<>0
      Call ADDCRIT(ICRIT,CRITERE,'[F:GYK'+mid$(CHIFFRES,I,1)+']PRNROW<='+num$(RNGSECFIN(I)))
     Endif
    Endif
   Else
    If SECDEB(I)<>"" & SECDEB(I)=SECFIN(I)
     Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]ACC="'+SECDEB(I)+'"')
    Else
     If SECDEB(I)<>""
      Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]ACC>="'+SECDEB(I)+'"')
     Elsif I=1 or TOUTAXE
      Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]ACC<>""')
     Endif
     If SECFIN(I)<>""
      Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]ACC<="'+SECFIN(I)+'"')
     Endif
    Endif
   Endif
  When 2
   If PYRSEC(I)<>""
    If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
     Call ADDCRIT(ICRIT,CRITERE,'[F:CYK'+mid$(CHIFFRES,I,1)+']PRNROW='+num$(RNGSECDEB(I)))
    Else
     If RNGSECDEB(I)<>0
      Call ADDCRIT(ICRIT,CRITERE,'[F:CYK'+mid$(CHIFFRES,I,1)+']PRNROW>='+num$(RNGSECDEB(I)))
     Endif
     If RNGSECFIN(I)<>0
      Call ADDCRIT(ICRIT,CRITERE,'[F:CYK'+mid$(CHIFFRES,I,1)+']PRNROW<='+num$(RNGSECFIN(I)))
     Endif
    Endif
   Else
    If SECDEB(I)<>"" & SECDEB(I)=SECFIN(I)
     Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]CCE'+num$(NUMAXE(I,ISOC))+'="'+SECDEB(I)+'"')
    Else
     If SECDEB(I)<>""
      Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]CCE'+num$(NUMAXE(I,ISOC))+'>="'+SECDEB(I)+'"')
     Elsif I=1 or TOUTAXE
      Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]CCE'+num$(NUMAXE(I,ISOC))+'<>""')
     Endif
     If SECFIN(I)<>""
      Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]CCE'+num$(NUMAXE(I,ISOC))+'<="'+SECFIN(I)+'"')
     Endif
    Endif
   Endif
  When 3
   If SECDEB(I)<>"" & SECDEB(I)=SECFIN(I)
    Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]BPR="'+SECDEB(I)+'"')
   Else
    If SECDEB(I)<>""
     Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]BPR>="'+SECDEB(I)+'"')
    Endif
    If SECFIN(I)<>""
     Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]BPR<="'+SECFIN(I)+'"')
    Endif
   Endif
 Endcase
Next I
Return

$CRITBUD
Raz CRITBUD
ICRIT = 1
Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]BUD="'+BUDGET+'"')

#Entry point 66370
GPE = 1
If GCALL_PT : GPOINT="FILTRE_VERSION" : Gosub ENTREE From EXEFNC : Endif
If GPE=1
 Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]VER="'+VERSION+'"')
Endif

Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]LEDTYP='+num$(REFERENTIEL))
If BUDSIT
 If SITEDEB<>"" & SITEDEB=SITEFIN
  Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]FCY="'+SITEDEB+'"')
 Else
  If SITEDEB<>""
   Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]FCY>="'+SITEDEB+'"')
  Endif
  If SITEFIN<>""
   Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]FCY<="'+SITEFIN+'"')
  Endif
 Endif
Endif
If [F:BUP]PYMACC=""
 Call ADDCRIT(ICRIT,CRITBUD,'[F:ACC]CONSUL=2')
Endif
For I=1 To NBAXE
 Case TYPAXE(I)
  When 1
   If PYRSEC(I)<>""
    If [F:BUP]PYMACC=""
     If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
      Call ADDCRIT(ICRIT,CRITBUD,'[F:GYK'+mid$(CHIFFRES,I,1)+']PRNROW='+num$(RNGSECDEB(I)))
     Else
      If RNGSECDEB(I)<>0
       Call ADDCRIT(ICRIT,CRITBUD,'[F:GYK'+mid$(CHIFFRES,I,1)+']PRNROW>='+num$(RNGSECDEB(I)))
      Endif
      If RNGSECFIN(I)<>0
       Call ADDCRIT(ICRIT,CRITBUD,'[F:GYK'+mid$(CHIFFRES,I,1)+']PRNROW<='+num$(RNGSECFIN(I)))
      Endif
     Endif
    Else
     If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
      Call ADDCRIT(ICRIT,CRITBUD,'[F:GRY'+mid$(CHIFFRES,I,1)+']PRNROW='+num$(RNGSECDEB(I)))
     Else
      If RNGSECDEB(I)<>0
       Call ADDCRIT(ICRIT,CRITBUD,'[F:GRY'+mid$(CHIFFRES,I,1)+']PRNROW>='+num$(RNGSECDEB(I)))
      Endif
      If RNGSECFIN(I)<>0
       Call ADDCRIT(ICRIT,CRITBUD,'[F:GRY'+mid$(CHIFFRES,I,1)+']PRNROW<='+num$(RNGSECFIN(I)))
      Endif
     Endif
    Endif
   Else
    If SECDEB(I)<>"" & SECDEB(I)=SECFIN(I)
     Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]ACC="'+SECDEB(I)+'"')
    Else
     If SECDEB(I)<>""
      Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]ACC>="'+SECDEB(I)+'"')
     Endif
     If SECFIN(I)<>""
      Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]ACC<="'+SECFIN(I)+'"')
     Endif
    Endif
   Endif
  When 2
   If PYRSEC(I)<>""
    If [F:BUP]PYMCCE(NUMBUD(I)-1)=""
     If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
      Call ADDCRIT(ICRIT,CRITBUD,'[F:CYK'+mid$(CHIFFRES,I,1)+']PRNROW='+num$(RNGSECDEB(I)))
     Else
      If RNGSECDEB(I)<>0
       Call ADDCRIT(ICRIT,CRITBUD,'[F:CYK'+mid$(CHIFFRES,I,1)+']PRNROW>='+num$(RNGSECDEB(I)))
      Endif
      If RNGSECFIN(I)<>0
       Call ADDCRIT(ICRIT,CRITBUD,'[F:CYK'+mid$(CHIFFRES,I,1)+']PRNROW<='+num$(RNGSECFIN(I)))
      Endif
     Endif
    Else
     If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
      Call ADDCRIT(ICRIT,CRITBUD,'[F:CRY'+mid$(CHIFFRES,I,1)+']PRNROW='+num$(RNGSECDEB(I)))
     Else
      If RNGSECDEB(I)<>0
       Call ADDCRIT(ICRIT,CRITBUD,'[F:CRY'+mid$(CHIFFRES,I,1)+']PRNROW>='+num$(RNGSECDEB(I)))
      Endif
      If RNGSECFIN(I)<>0
       Call ADDCRIT(ICRIT,CRITBUD,'[F:CRY'+mid$(CHIFFRES,I,1)+']PRNROW<='+num$(RNGSECFIN(I)))
      Endif
     Endif
    Endif
   Else
    If SECDEB(I)<>"" & SECDEB(I)=SECFIN(I)
     Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]CCE'+num$(NUMAXE(I,ISOC))+'="'+SECDEB(I)+'"')
    Else
     If SECDEB(I)<>""
      Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]CCE'+num$(NUMAXE(I,ISOC))+'>="'+SECDEB(I)+'"')
     Endif
     If SECFIN(I)<>""
      Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]CCE'+num$(NUMAXE(I,ISOC))+'<="'+SECFIN(I)+'"')
     Endif
    Endif
   Endif
 Endcase
Next I
Return

$TR1
GOK = 1
Trbegin [ARM]
 For ISOC=1 To NBSOC
  Gosub CRITERE
  Gosub LIENS From =PROG
  CRITSOC = '[F:BLA]CPY="'+SOC(ISOC)+'" & [F:BLA]FCY<>""'
  EXEDEB = 9999
  EXEFIN = 0
  For IPER=1 To NPER
   If EDEB(IPER,ISOC)<>0 : EXEDEB = min(EXEDEB,EDEB(IPER,ISOC)) : Endif
   If EFIN(IPER,ISOC)<>0 : EXEFIN = max(EXEFIN,EFIN(IPER,ISOC)) : Endif
  Next IPER
  If EXEDEB=EXEFIN
   CRITSOC -= '& [F:BLA]FIY='+num$(EXEDEB)
  Else
   CRITSOC -= '& [F:BLA]FIY>='+num$(EXEDEB)
   CRITSOC -= '& [F:BLA]FIY<='+num$(EXEFIN)
  Endif
#CHECK FILE_DECLARE TMPBLA [ARM]
  For [LBLA]CLE Where evalue(CRITSOC)
   Raz [F:ARM]
   [F:ARM]RPTCOD = ETAT
   [F:ARM]USR    = GUSER
   [F:ARM]NUMREQ = NUMREQ
   [F:ARM]FCY    = [F:BLA]FCY
   For I=1 To NBAXE
    Case TYPAXE(I)
     When 1
      If PYRSEC(I)=""
       Case I
        When 1
         [F:ARM]CCE1    = [F:BLA]ACC
         [F:ARM]TRICCE1 = [F:BLA]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE1,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 2
         [F:ARM]CCE2    = [F:BLA]ACC
         [F:ARM]TRICCE2 = [F:BLA]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE2,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 3
         [F:ARM]CCE3    = [F:BLA]ACC
         [F:ARM]TRICCE3 = [F:BLA]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE3,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 4
         [F:ARM]CCE4    = [F:BLA]ACC
         [F:ARM]TRICCE4 = [F:BLA]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE4,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 5
         [F:ARM]CCE5    = [F:BLA]ACC
         [F:ARM]TRICCE5 = [F:BLA]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE5,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 6
         [F:ARM]CCE6    = [F:BLA]ACC
         [F:ARM]TRICCE6 = [F:BLA]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE6,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 7
         [F:ARM]CCE7    = [F:BLA]ACC
         [F:ARM]TRICCE7 = [F:BLA]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE7,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 8
         [F:ARM]CCE8    = [F:BLA]ACC
         [F:ARM]TRICCE8 = [F:BLA]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE8,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 9
         [F:ARM]CCE9    = [F:BLA]ACC
         [F:ARM]TRICCE9 = [F:BLA]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE9,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 10
         [F:ARM]CCEA    = [F:BLA]ACC
