       When 12 : [F:ARM]DETC = evalue("[F:BLA]CCE"+num$(NUMAXE(I,ISOC)))
      Endcase
     When 3
      Assign "[F:ARM]CCE"+mid$(CHIFFRES,I,1)    With [F:BLA]BPR
      Assign "[F:ARM]TRICCE"+mid$(CHIFFRES,I,1) With [F:BLA]BPR
      If INTCOURT
       Assign "[F:ARM]LIBCCE"+mid$(CHIFFRES,I,1) With [F:BPR]BPRSHO
      Else
       Assign "[F:ARM]LIBCCE"+mid$(CHIFFRES,I,1) With [F:BPR]BPRNAM
      Endif
      Case I
       When  1 : [F:ARM]DET1 = [F:BLA]BPR
       When  2 : [F:ARM]DET2 = [F:BLA]BPR
       When  3 : [F:ARM]DET3 = [F:BLA]BPR
       When  4 : [F:ARM]DET4 = [F:BLA]BPR
       When  5 : [F:ARM]DET5 = [F:BLA]BPR
       When  6 : [F:ARM]DET6 = [F:BLA]BPR
       When  7 : [F:ARM]DET7 = [F:BLA]BPR
       When  8 : [F:ARM]DET8 = [F:BLA]BPR
       When  9 : [F:ARM]DET9 = [F:BLA]BPR
       When 10 : [F:ARM]DETA = [F:BLA]BPR
       When 11 : [F:ARM]DETB = [F:BLA]BPR
       When 12 : [F:ARM]DETC = [F:BLA]BPR
      Endcase
    Endcase
   Next I
   Case PASSE
    When 1 : [F:ARM]CLEN1  = [F:BLA]ACCNUM
    When 2 : [F:ARM]CLEN2  = [F:BLA]ACCNUM
    When 3 : [F:ARM]CLEN3  = [F:BLA]ACCNUM
   Endcase
   [F:ARM]CLEN4 = -1
   If dim([F:BLA]UOM)>0 : [F:ARM]UOM = [F:BLA]UOM : Endif
   For IPER=1 To NPER
    If [F:BLA]FIY>=EDEB(IPER,ISOC) & [F:BLA]FIY<=EFIN(IPER,ISOC)
     If [F:BLA]FIY=EDEB(IPER,ISOC)
      If PDEB(IPER,ISOC)=1 & ANOUVEAU
       [F:ARM]PERSTR(IPER-1) = 1
      Else
       [F:ARM]PERSTR(IPER-1) = PDEB(IPER,ISOC)+1
      Endif
     Else
      [F:ARM]PERSTR(IPER-1) = 2 : # JHA/BY 130710 pour Dmd 65776
     Endif
     If [F:BLA]FIY=EFIN(IPER,ISOC)
      [F:ARM]PEREND(IPER-1) = PFIN(IPER,ISOC)+1
     Else
      [F:ARM]PEREND(IPER-1) = dim([F:BLN]CDT)
     Endif
    Endif
   Next IPER
   [F:ARM]CUR = DEVIMP
   If !AUCAXE
    OKAXE = 0
    For I=1 To NBAXE
     If TYPAXE(I)=2
      If evalue("[F:ARM]CCE"+mid$(CHIFFRES,I,1))<>""
       OKAXE = 1 : Break
      Endif
     Endif
    Next I
   Else
    OKAXE = 1
   Endif
   If OKAXE
    If [F:ARM]CCE1="" : [F:ARM]CCE1 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE1 = "" : Endif
    If [F:ARM]CCE2="" : [F:ARM]CCE2 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE2 = "" : Endif
    If [F:ARM]CCE3="" : [F:ARM]CCE3 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE3 = "" : Endif
    If [F:ARM]CCE4="" : [F:ARM]CCE4 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE4 = "" : Endif
    If [F:ARM]CCE5="" : [F:ARM]CCE5 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE5 = "" : Endif
    If [F:ARM]CCE6="" : [F:ARM]CCE6 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE6 = "" : Endif
    If [F:ARM]CCE7="" : [F:ARM]CCE7 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE7 = "" : Endif
    If [F:ARM]CCE8="" : [F:ARM]CCE8 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE8 = "" : Endif
    If [F:ARM]CCE9="" : [F:ARM]CCE9 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE9 = "" : Endif
    If [F:ARM]CCEA="" : [F:ARM]CCEA = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCEA = "" : Endif
    If [F:ARM]CCEB="" : [F:ARM]CCEB = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCEB = "" : Endif
    If [F:ARM]CCEB="" : [F:ARM]CCEC = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCEC = "" : Endif
    LIGNE += 1
    [F:ARM]NUMLIG = LIGNE
    #<om demande de point d'entrée 78984
    GPE = 1
    If GCALL_PT : GPOINT="BEFWRIARM" : Gosub ENTREE From EXEFNC : Endif
    If GPE=1
     #*X3_84387 Write [ARM]
     WriteB [ARM]
     If fstat
      GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
     Endif
    Endif
   Endif
  Next
 Next ISOC
 #*X3_84387
 Flush [F:ARM]
 If fstat
   Call ECR_TRACE("File [ARM], flush Error ="-num$(fstat),1) From GESECRAN
 Endif
 #*X3_84387
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$TR2
GOK = 1
Trbegin [ARM]
 For ISOC=1 To NBSOC
  Gosub CRITBUD
  Gosub LIENBUD From =PROG
  EXEDEB = 9999
  EXEFIN = 0
  For IPER=1 To NPER
   If EDEB(IPER,ISOC)<>0 : EXEDEB = min(EXEDEB,EDEB(IPER,ISOC)) : Endif
   If EFIN(IPER,ISOC)<>0 : EXEFIN = max(EXEFIN,EFIN(IPER,ISOC)) : Endif
  Next IPER
  CRITSOC = '[F:BUD]CPY="'+SOC(ISOC)+'"' : # & [F:BUD]FCY<>""'
  If EXEDEB=EXEFIN
   CRITSOC -= '& [F:BUD]FIY='+num$(EXEDEB)
  Else
   CRITSOC -= '& [F:BUD]FIY>='+num$(EXEDEB)
   CRITSOC -= '& [F:BUD]FIY<='+num$(EXEFIN)
  Endif
  For [LBUD]CLE Where evalue(CRITSOC)
   OKBUD = 1
   LIGNE += 1
   Raz [F:ARM]
   [F:ARM]RPTCOD = ETAT
   [F:ARM]USR    = GUSER
   [F:ARM]NUMREQ = NUMREQ
   [F:ARM]NUMLIG = LIGNE
   [F:ARM]FCY    = [F:BUD]FCY
   For I=1 To NBAXE
    Case TYPAXE(I)
     When 1
      If PYRSEC(I)=""
       Case I
        When 1
         [F:ARM]CCE1    = [F:BUD]ACC
         [F:ARM]TRICCE1 = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE1,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 2
         [F:ARM]CCE2    = [F:BUD]ACC
         [F:ARM]TRICCE2 = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE2,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 3
         [F:ARM]CCE3    = [F:BUD]ACC
         [F:ARM]TRICCE3 = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE3,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 4
         [F:ARM]CCE4    = [F:BUD]ACC
         [F:ARM]TRICCE4 = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE4,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 5
         [F:ARM]CCE5    = [F:BUD]ACC
         [F:ARM]TRICCE5 = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE5,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 6
         [F:ARM]CCE6    = [F:BUD]ACC
         [F:ARM]TRICCE6 = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE6,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 7
         [F:ARM]CCE7    = [F:BUD]ACC
         [F:ARM]TRICCE7 = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE7,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 8
         [F:ARM]CCE8    = [F:BUD]ACC
         [F:ARM]TRICCE8 = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE8,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 9
         [F:ARM]CCE9    = [F:BUD]ACC
         [F:ARM]TRICCE9 = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCE9,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 10
         [F:ARM]CCEA    = [F:BUD]ACC
         [F:ARM]TRICCEA = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCEA,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 11
         [F:ARM]CCEB    = [F:BUD]ACC
         [F:ARM]TRICCEB = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCEB,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
        When 12
         [F:ARM]CCEC    = [F:BUD]ACC
         [F:ARM]TRICCEC = [F:BUD]ACC
         Call LECTEXTRAC([F:ARM]LIBCCEC,"GACCOUNT",DESTRA,[F:GAC]COA,[F:GAC]ACC) :#From ATEXTRA    X3-101021
       Endcase
      Elsif [F:BUP]PYMACC=""
       Case I
        When 1
         [F:ARM]CCE1    = [F:GYK1]GRU
         [F:ARM]TRICCE1 = format$("N0:4#",[F:GYK1]PRNROW)+[F:GYK1]GRU
         If [F:GRY1]GRU<>[F:GYK1]GRU
          Read [GRY1]GRY0 = [F:GYK1]PYM;[F:GYK1]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE1,"GACCGRUPYM",DESTRA,[F:GRY1]PYM,[F:GRY1]GRU) :#From ATEXTRA    X3-101021
        When 2
         [F:ARM]CCE2    = [F:GYK2]GRU
         [F:ARM]TRICCE2 = format$("N0:4#",[F:GYK2]PRNROW)+[F:GYK2]GRU
         If [F:GRY2]GRU<>[F:GYK2]GRU
          Read [GRY2]GRY0 = [F:GYK2]PYM;[F:GYK2]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE2,"GACCGRUPYM",DESTRA,[F:GRY2]PYM,[F:GRY2]GRU) :#From ATEXTRA    X3-101021
        When 3
         [F:ARM]CCE3    = [F:GYK3]GRU
         [F:ARM]TRICCE3 = format$("N0:4#",[F:GYK3]PRNROW)+[F:GYK3]GRU
         If [F:GRY3]GRU<>[F:GYK3]GRU
          Read [GRY3]GRY0 = [F:GYK3]PYM;[F:GYK3]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE3,"GACCGRUPYM",DESTRA,[F:GRY3]PYM,[F:GRY3]GRU) :#From ATEXTRA    X3-101021
        When 4
         [F:ARM]CCE4    = [F:GYK4]GRU
         [F:ARM]TRICCE4 = format$("N0:4#",[F:GYK4]PRNROW)+[F:GYK4]GRU
         If [F:GRY4]GRU<>[F:GYK4]GRU
          Read [GRY4]GRY0 = [F:GYK4]PYM;[F:GYK4]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE4,"GACCGRUPYM",DESTRA,[F:GRY4]PYM,[F:GRY4]GRU) :#From ATEXTRA    X3-101021
        When 5
         [F:ARM]CCE5    = [F:GYK5]GRU
         [F:ARM]TRICCE5 = format$("N0:4#",[F:GYK5]PRNROW)+[F:GYK5]GRU
         If [F:GRY5]GRU<>[F:GYK5]GRU
          Read [GRY5]GRY0 = [F:GYK5]PYM;[F:GYK5]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE5,"GACCGRUPYM",DESTRA,[F:GRY5]PYM,[F:GRY5]GRU) :#From ATEXTRA    X3-101021
        When 6
         [F:ARM]CCE6    = [F:GYK6]GRU
         [F:ARM]TRICCE6 = format$("N0:4#",[F:GYK6]PRNROW)+[F:GYK6]GRU
         If [F:GRY6]GRU<>[F:GYK6]GRU
          Read [GRY6]GRY0 = [F:GYK6]PYM;[F:GYK6]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE6,"GACCGRUPYM",DESTRA,[F:GRY6]PYM,[F:GRY6]GRU) :#From ATEXTRA    X3-101021
        When 7
         [F:ARM]CCE7    = [F:GYK7]GRU
         [F:ARM]TRICCE7 = format$("N0:4#",[F:GYK7]PRNROW)+[F:GYK7]GRU
         If [F:GRY7]GRU<>[F:GYK7]GRU
          Read [GRY7]GRY0 = [F:GYK7]PYM;[F:GYK7]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE7,"GACCGRUPYM",DESTRA,[F:GRY7]PYM,[F:GRY7]GRU) :#From ATEXTRA    X3-101021
        When 8
         [F:ARM]CCE8    = [F:GYK8]GRU
         [F:ARM]TRICCE8 = format$("N0:4#",[F:GYK8]PRNROW)+[F:GYK8]GRU
         If [F:GRY8]GRU<>[F:GYK8]GRU
          Read [GRY8]GRY0 = [F:GYK8]PYM;[F:GYK8]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE8,"GACCGRUPYM",DESTRA,[F:GRY8]PYM,[F:GRY8]GRU) :#From ATEXTRA    X3-101021
        When 9
         [F:ARM]CCE9    = [F:GYK9]GRU
         [F:ARM]TRICCE9 = format$("N0:4#",[F:GYK9]PRNROW)+[F:GYK9]GRU
         If [F:GRY9]GRU<>[F:GYK9]GRU
          Read [GRY9]GRY0 = [F:GYK9]PYM;[F:GYK9]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE9,"GACCGRUPYM",DESTRA,[F:GRY9]PYM,[F:GRY9]GRU) :#From ATEXTRA    X3-101021
        When 10
         [F:ARM]CCEA    = [F:GYKA]GRU
         [F:ARM]TRICCEA = format$("N0:4#",[F:GYKA]PRNROW)+[F:GYKA]GRU
         If [F:GRYA]GRU<>[F:GYKA]GRU
          Read [GRYA]GRY0 = [F:GYKA]PYM;[F:GYKA]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCEA,"GACCGRUPYM",DESTRA,[F:GRYA]PYM,[F:GRYA]GRU) :#From ATEXTRA    X3-101021
        When 11
         [F:ARM]CCEB    = [F:GYKB]GRU
         [F:ARM]TRICCEB = format$("N0:4#",[F:GYKB]PRNROW)+[F:GYKB]GRU
         If [F:GRYB]GRU<>[F:GYKB]GRU
          Read [GRYB]GRY0 = [F:GYKB]PYM;[F:GYKB]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCEB,"GACCGRUPYM",DESTRA,[F:GRYB]PYM,[F:GRYB]GRU) :#From ATEXTRA    X3-101021
        When 12
         [F:ARM]CCEC    = [F:GYKC]GRU
         [F:ARM]TRICCEC = format$("N0:4#",[F:GYKC]PRNROW)+[F:GYKC]GRU
         If [F:GRYC]GRU<>[F:GYKC]GRU
          Read [GRYC]GRY0 = [F:GYKC]PYM;[F:GYKC]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCEC,"GACCGRUPYM",DESTRA,[F:GRYC]PYM,[F:GRYC]GRU) :#From ATEXTRA    X3-101021
       Endcase
      Else
       GROUPYR = evalue("[F:GRY"+mid$(CHIFFRES,I,1)+"]GRU")
       NIVPYR  = evalue("[F:GRY"+mid$(CHIFFRES,I,1)+"]LEV")
#   Cas du budget défini à un niveau supérieur
       While NIVPYR>NIVSEC(I)
        Filter [GRYX] Where PYM=PYRSEC(I) & SBBGRU=GROUPYR
        Read [GRYX]GRY2 First
        Filter [GRYX]
        If fstat<=2
         GROUPYR = [F:GRYX]GRU
         NIVPYR  = [F:GRYX]LEV
        Else
         OKBUD = 0 : Break
        Endif
       Wend
       If NIVPYR=NIVSEC(I)
        Assign "[F:ARM]CCE"+mid$(CHIFFRES,I,1) With GROUPYR
        If [F:GRYX]GRU<>GROUPYR
         Read [GRYX]GRY0 = PYRSEC(I);GROUPYR;1
        Endif
        Call LECTEXTRAC(DESIG,"GACCGRUPYM",DESTRA,[F:GRYX]PYM,[F:GRYX]GRU) :#From ATEXTRA    X3-101021
        Assign "[F:ARM]TRICCE"+mid$(CHIFFRES,I,1) With format$("N0:4#",[F:GRYX]PRNROW)+GROUPYR
        Assign "[F:ARM]LIBCCE"+mid$(CHIFFRES,I,1) With DESIG
       Else
        OKBUD = 0
       Endif
      Endif
      Case I
       When  1 : [F:ARM]DET1 = [F:BUD]ACC
       When  2 : [F:ARM]DET2 = [F:BUD]ACC
       When  3 : [F:ARM]DET3 = [F:BUD]ACC
       When  4 : [F:ARM]DET4 = [F:BUD]ACC
       When  5 : [F:ARM]DET5 = [F:BUD]ACC
       When  6 : [F:ARM]DET6 = [F:BUD]ACC
       When  7 : [F:ARM]DET7 = [F:BUD]ACC
       When  8 : [F:ARM]DET8 = [F:BUD]ACC
       When  9 : [F:ARM]DET9 = [F:BUD]ACC
       When 10 : [F:ARM]DETA = [F:BUD]ACC
       When 11 : [F:ARM]DETB = [F:BUD]ACC
       When 12 : [F:ARM]DETC = [F:BUD]ACC
      Endcase
     When 2
      If PYRSEC(I)=""
       SECTION = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       Case I
        When 1
         [F:ARM]CCE1    = SECTION
         [F:ARM]TRICCE1 = SECTION
         If SECTION<>[F:CCE1]CCE
          Read [CCE1]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE1,"CACCE",DESTRA,[F:CCE1]DIE,[F:CCE1]CCE) :#From ATEXTRA    X3-101021
        When 2
         [F:ARM]CCE2    = SECTION
         [F:ARM]TRICCE2 = SECTION
         If SECTION<>[F:CCE2]CCE
          Read [CCE2]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE2,"CACCE",DESTRA,[F:CCE2]DIE,[F:CCE2]CCE) :#From ATEXTRA    X3-101021
        When 3
         [F:ARM]CCE3    = SECTION
         [F:ARM]TRICCE3 = SECTION
         If SECTION<>[F:CCE3]CCE
          Read [CCE3]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE3,"CACCE",DESTRA,[F:CCE3]DIE,[F:CCE3]CCE) :#From ATEXTRA    X3-101021
        When 4
         [F:ARM]CCE4    = SECTION
         [F:ARM]TRICCE4 = SECTION
         If SECTION<>[F:CCE4]CCE
          Read [CCE4]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE4,"CACCE",DESTRA,[F:CCE4]DIE,[F:CCE4]CCE) :#From ATEXTRA    X3-101021
        When 5
         [F:ARM]CCE5    = SECTION
         [F:ARM]TRICCE5 = SECTION
         If SECTION<>[F:CCE5]CCE
          Read [CCE5]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE5,"CACCE",DESTRA,[F:CCE5]DIE,[F:CCE5]CCE) :#From ATEXTRA    X3-101021
        When 6
         [F:ARM]CCE6    = SECTION
         [F:ARM]TRICCE6 = SECTION
         If SECTION<>[F:CCE6]CCE
          Read [CCE6]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE6,"CACCE",DESTRA,[F:CCE6]DIE,[F:CCE6]CCE) :#From ATEXTRA    X3-101021
        When 7
         [F:ARM]CCE7    = SECTION
         [F:ARM]TRICCE7 = SECTION
         If SECTION<>[F:CCE7]CCE
          Read [CCE7]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE7,"CACCE",DESTRA,[F:CCE7]DIE,[F:CCE7]CCE) :#From ATEXTRA    X3-101021
        When 8
         [F:ARM]CCE8    = SECTION
         [F:ARM]TRICCE8 = SECTION
         If SECTION<>[F:CCE8]CCE
          Read [CCE8]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE8,"CACCE",DESTRA,[F:CCE8]DIE,[F:CCE8]CCE) :#From ATEXTRA    X3-101021
        When 9
         [F:ARM]CCE9    = SECTION
         [F:ARM]TRICCE9 = SECTION
         If SECTION<>[F:CCE9]CCE
          Read [CCE9]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE9,"CACCE",DESTRA,[F:CCE9]DIE,[F:CCE9]CCE) :#From ATEXTRA    X3-101021
        When 10
         [F:ARM]CCEA    = SECTION
         [F:ARM]TRICCEA = SECTION
         If SECTION<>[F:CCEA]CCE
          Read [CCEA]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCEA,"CACCE",DESTRA,[F:CCEA]DIE,[F:CCEA]CCE) :#From ATEXTRA    X3-101021
        When 11
         [F:ARM]CCEB    = SECTION
         [F:ARM]TRICCEB = SECTION
         If SECTION<>[F:CCEB]CCE
          Read [CCEB]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCEB,"CACCE",DESTRA,[F:CCEB]DIE,[F:CCEB]CCE) :#From ATEXTRA    X3-101021
        When 12
         [F:ARM]CCEC    = SECTION
         [F:ARM]TRICCEC = SECTION
         If SECTION<>[F:CCEC]CCE
          Read [CCEC]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCEC,"CACCE",DESTRA,[F:CCEC]DIE,[F:CCEC]CCE) :#From ATEXTRA    X3-101021
       Endcase
      Elsif [F:BUP]PYMCCE(NUMBUD(I)-1)=""
       SECTION = evalue("[F:CYK"+mid$(CHIFFRES,I,1)+"]GRU")
       Case I
        When 1
         [F:ARM]CCE1    = SECTION
         [F:ARM]TRICCE1 = format$("N0:4#",[F:CYK1]PRNROW)+SECTION
         If SECTION<>[F:CRY1]GRU
          Read [CRY1]CRY0 = [F:CYK1]PYM;[F:CYK1]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE1,"GCCEGRUPYM",DESTRA,[F:CRY1]PYM,[F:CRY1]GRU) :#From ATEXTRA    X3-101021
        When 2
         [F:ARM]CCE2    = SECTION
         [F:ARM]TRICCE2 = format$("N0:4#",[F:CYK2]PRNROW)+SECTION
         If SECTION<>[F:CRY2]GRU
          Read [CRY2]CRY0 = [F:CYK2]PYM;[F:CYK2]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE2,"GCCEGRUPYM",DESTRA,[F:CRY2]PYM,[F:CRY2]GRU) :#From ATEXTRA    X3-101021
        When 3
         [F:ARM]CCE3    = SECTION
         [F:ARM]TRICCE3 = format$("N0:4#",[F:CYK3]PRNROW)+SECTION
         If SECTION<>[F:CRY3]GRU
          Read [CRY3]CRY0 = [F:CYK3]PYM;[F:CYK3]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE3,"GCCEGRUPYM",DESTRA,[F:CRY3]PYM,[F:CRY3]GRU) :#From ATEXTRA    X3-101021
        When 4
         [F:ARM]CCE4    = SECTION
         [F:ARM]TRICCE4 = format$("N0:4#",[F:CYK4]PRNROW)+SECTION
         If SECTION<>[F:CRY4]GRU
          Read [CRY4]CRY0 = [F:CYK4]PYM;[F:CYK4]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE4,"GCCEGRUPYM",DESTRA,[F:CRY4]PYM,[F:CRY4]GRU) :#From ATEXTRA    X3-101021
        When 5
         [F:ARM]CCE5    = SECTION
         [F:ARM]TRICCE5 = format$("N0:4#",[F:CYK5]PRNROW)+SECTION
         If SECTION<>[F:CRY5]GRU
          Read [CRY5]CRY0 = [F:CYK5]PYM;[F:CYK5]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE5,"GCCEGRUPYM",DESTRA,[F:CRY5]PYM,[F:CRY5]GRU) :#From ATEXTRA    X3-101021
        When 6
         [F:ARM]CCE6    = SECTION
         [F:ARM]TRICCE6 = format$("N0:4#",[F:CYK6]PRNROW)+SECTION
         If SECTION<>[F:CRY6]GRU
          Read [CRY6]CRY0 = [F:CYK6]PYM;[F:CYK6]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE6,"GCCEGRUPYM",DESTRA,[F:CRY6]PYM,[F:CRY6]GRU) :#From ATEXTRA    X3-101021
        When 7
         [F:ARM]CCE7    = SECTION
         [F:ARM]TRICCE7 = format$("N0:4#",[F:CYK7]PRNROW)+SECTION
         If SECTION<>[F:CRY7]GRU
          Read [CRY7]CRY0 = [F:CYK7]PYM;[F:CYK7]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE7,"GCCEGRUPYM",DESTRA,[F:CRY7]PYM,[F:CRY7]GRU) :#From ATEXTRA    X3-101021
        When 8
         [F:ARM]CCE8    = SECTION
         [F:ARM]TRICCE8 = format$("N0:4#",[F:CYK8]PRNROW)+SECTION
         If SECTION<>[F:CRY8]GRU
          Read [CRY8]CRY0 = [F:CYK8]PYM;[F:CYK8]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE8,"GCCEGRUPYM",DESTRA,[F:CRY8]PYM,[F:CRY8]GRU) :#From ATEXTRA    X3-101021
        When 9
         [F:ARM]CCE9    = SECTION
         [F:ARM]TRICCE9 = format$("N0:4#",[F:CYK9]PRNROW)+SECTION
         If SECTION<>[F:CRY9]GRU
          Read [CRY9]CRY0 = [F:CYK9]PYM;[F:CYK9]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCE9,"GCCEGRUPYM",DESTRA,[F:CRY9]PYM,[F:CRY9]GRU) :#From ATEXTRA    X3-101021
        When 10
         [F:ARM]CCEA    = SECTION
         [F:ARM]TRICCEA = format$("N0:4#",[F:CYKA]PRNROW)+SECTION
         If SECTION<>[F:CRYA]GRU
          Read [CRYA]CRY0 = [F:CYKA]PYM;[F:CYKA]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCEA,"GCCEGRUPYM",DESTRA,[F:CRYA]PYM,[F:CRYA]GRU) :#From ATEXTRA    X3-101021
        When 11
         [F:ARM]CCEB    = SECTION
         [F:ARM]TRICCEB = format$("N0:4#",[F:CYKB]PRNROW)+SECTION
         If SECTION<>[F:CRYB]GRU
          Read [CRYB]CRY0 = [F:CYKB]PYM;[F:CYKB]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCEB,"GCCEGRUPYM",DESTRA,[F:CRYB]PYM,[F:CRYB]GRU) :#From ATEXTRA    X3-101021
        When 12
         [F:ARM]CCEC    = SECTION
         [F:ARM]TRICCEC = format$("N0:4#",[F:CYKC]PRNROW)+SECTION
         If SECTION<>[F:CRYC]GRU
          Read [CRYC]CRY0 = [F:CYKC]PYM;[F:CYKC]GRU;1
         Endif
         Call LECTEXTRAC([F:ARM]LIBCCEC,"GCCEGRUPYM",DESTRA,[F:CRYC]PYM,[F:CRYC]GRU) :#From ATEXTRA    X3-101021
       Endcase
      Else
       GROUPYR = evalue("[F:CRY"+mid$(CHIFFRES,I,1)+"]GRU")
       NIVPYR  = evalue("[F:CRY"+mid$(CHIFFRES,I,1)+"]LEV")
#   Cas du budget défini à un niveau supérieur
       While NIVPYR>NIVSEC(I)
        Filter [CRYX] Where PYM=PYRSEC(I) & SBBGRU=GROUPYR
        Read [CRYX]CRY2 First
        Filter [CRYX]
        If fstat<=2
         GROUPYR = [F:CRYX]GRU
         NIVPYR  = [F:CRYX]LEV
        Else
         OKBUD = 0 : Break
        Endif
       Wend
       If NIVPYR=NIVSEC(I)
        Assign "[F:ARM]CCE"+mid$(CHIFFRES,I,1) With GROUPYR
        If [F:CRYX]GRU<>GROUPYR
         Read [CRYX]CRY0 = PYRSEC(I);GROUPYR;1
        Endif
        Call LECTEXTRAC(DESIG,"GCCEGRUPYM",DESTRA,[F:CRYX]PYM,[F:CRYX]GRU) :#From ATEXTRA    X3-101021
        Assign "[F:ARM]LIBCCE"+mid$(CHIFFRES,I,1) With DESIG
        Assign "[F:ARM]TRICCE"+mid$(CHIFFRES,I,1) With format$("N0:4#",[F:CRYX]PRNROW)+GROUPYR
       Else
        OKBUD = 0
       Endif
      Endif
      Case I
       When  1 : [F:ARM]DET1 = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When  2 : [F:ARM]DET2 = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When  3 : [F:ARM]DET3 = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When  4 : [F:ARM]DET4 = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When  5 : [F:ARM]DET5 = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When  6 : [F:ARM]DET6 = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When  7 : [F:ARM]DET7 = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When  8 : [F:ARM]DET8 = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When  9 : [F:ARM]DET9 = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When 10 : [F:ARM]DETA = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When 11 : [F:ARM]DETB = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
       When 12 : [F:ARM]DETC = evalue("[F:BUD]CCE"+num$(NUMAXE(I,ISOC)))
      Endcase
    Endcase
   Next I
   [F:ARM]CLEN4 = [F:BUD]ACCNUM
   [F:ARM]UOM = [F:BUD]UOM
   For IPER=1 To NPER
    If [F:BUD]FIY>=EDEB(IPER,ISOC) & [F:BUD]FIY<=EFIN(IPER,ISOC)
     If [F:BUD]FIY=EDEB(IPER,ISOC)
      [F:ARM]PERSTR(IPER-1) = PDEB(IPER,ISOC)
     Else
      [F:ARM]PERSTR(IPER-1) = 1
     Endif
     If [F:BUD]FIY=EFIN(IPER,ISOC)
      [F:ARM]PEREND(IPER-1) = PFIN(IPER,ISOC)
     Else
      [F:ARM]PEREND(IPER-1) = dim([F:BUD]AMT)
     Endif
    Endif
   Next IPER
   [F:ARM]CUR = DEVIMP
   If OKBUD
    If [F:ARM]CCE1="" : [F:ARM]CCE1 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE1 = "" : Endif
    If [F:ARM]CCE2="" : [F:ARM]CCE2 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE2 = "" : Endif
    If [F:ARM]CCE3="" : [F:ARM]CCE3 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE3 = "" : Endif
    If [F:ARM]CCE4="" : [F:ARM]CCE4 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE4 = "" : Endif
    If [F:ARM]CCE5="" : [F:ARM]CCE5 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE5 = "" : Endif
    If [F:ARM]CCE6="" : [F:ARM]CCE6 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE6 = "" : Endif
    If [F:ARM]CCE7="" : [F:ARM]CCE7 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE7 = "" : Endif
    If [F:ARM]CCE8="" : [F:ARM]CCE8 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE8 = "" : Endif
    If [F:ARM]CCE9="" : [F:ARM]CCE9 = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCE9 = "" : Endif
    If [F:ARM]CCEA="" : [F:ARM]CCEA = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCEA = "" : Endif
    If [F:ARM]CCEB="" : [F:ARM]CCEB = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCEB = "" : Endif
    If [F:ARM]CCEC="" : [F:ARM]CCEC = "<"+mess(23,147,1)+">" : [F:ARM]LIBCCEC = "" : Endif
    #<om demande de point d'entrée 78984
    GPE = 1
    If GCALL_PT : GPOINT="BEFWRIARM" : Gosub ENTREE From EXEFNC : Endif
    If GPE=1
     #*X3_84387  Write [ARM]
     WriteB [ARM]
     If fstat
      GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
     Endif
    Endif
   Endif
  Next
 Next ISOC
 #*X3_84387
 Flush [F:ARM]
 If fstat
   Call ECR_TRACE("File [ARM], flush Error ="-num$(fstat),1) From GESECRAN
 Endif
 #*X3_84387 END
 If GOK<1 : Goto AB_TR2 : Endif
Commit
Return

$AB_TR2
Rollback
Return

$TR3
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=ETAT & USR=GUSER
Commit
Return

$TRISEC
For I=1 To NBAXE
 If CLE<>"" : CLE += ";" : Endif
 Case TYPAXE(I)
  When 1
   If PYRSEC(I)<>""
    CLE += "[F:GYK"+mid$(CHIFFRES,I,1)+"]PRNROW;[F:GYK"+mid$(CHIFFRES,I,1)+"]GRU"
#   CLE += 'num$([F:GYK'+mid$(CHIFFRES,I,1)+']PRNROW)+[F:GYK'+mid$(CHIFFRES,I,1)+']GRU'
   Else
    CLE += "[F:BLA]ACC"
#   CLE += "[F:BLA]COA;[F:BLA]ACC"
   Endif
  When 2
   If PYRSEC(I)<>""
    CLE += "[F:CYK"+mid$(CHIFFRES,I,1)+"]PRNROW;[F:CYK"+mid$(CHIFFRES,I,1)+"]GRU"
#   CLE += 'num$([F:CYK'+mid$(CHIFFRES,I,1)+']PRNROW)+[F:CYK'+mid$(CHIFFRES,I,1)+']GRU'
   Else
    CLE += "[F:BLA]CCE"+num$(NUMAXE(I,ISOC))
#   CLE += "[F:BLA]DIE("+num$(NUMAXE(I,ISOC)-1)+");[F:BLA]CCE"+num$(NUMAXE(I,ISOC))
   Endif
  When 3
   CLE += "[F:BLA]BPR"
 Endcase
Next I
Return

$TRIBUDSEC
For I=1 To NBAXE
 If CLE<>"" : CLE += ";" : Endif
 Case TYPAXE(I)
  When 1
   If PYRSEC(I)<>""
    If [F:BUP]PYMACC=""
     CLE += "[F:GYK"+mid$(CHIFFRES,I,1)+"]PRNROW;[F:GYK"+mid$(CHIFFRES,I,1)+"]GRU"
    Else
     CLE += "[F:GRY"+mid$(CHIFFRES,I,1)+"]PRNROW;[F:GRY"+mid$(CHIFFRES,I,1)+"]GRU"
    Endif
   Else
    CLE += "[F:BUD]ACC"
#   CLE += "[F:BUD]COA;[F:BUD]ACC"
   Endif
  When 2
   If PYRSEC(I)<>""
    If [F:BUP]PYMCCE(NUMBUD(I)-1)=""
     CLE += "[F:CYK"+mid$(CHIFFRES,I,1)+"]PRNROW;[F:CYK"+mid$(CHIFFRES,I,1)+"]GRU"
    Else
     CLE += "[F:CRY"+mid$(CHIFFRES,I,1)+"]PRNROW;[F:CRY"+mid$(CHIFFRES,I,1)+"]GRU"
    Endif
   Else
    CLE += "[F:BUD]CCE"+num$(NUMAXE(I,ISOC))
#   CLE += "[F:BUD]DIE"+num$(NUMBUD(I))+";[F:BUD]CCE"+num$(NUMBUD(I))
   Endif
 Endcase
Next I
Return

$OUVFIC
If clalev([F:ARM])=0 : Local File TMPBLA     [ARM] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif
