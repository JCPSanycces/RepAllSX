#<AdxTL>@(#)88.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"AFFMESS","RECHMESS","RECHMESS",3,"XYRECHMESS") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "DEBUT"   : Gosub DEBUT
 When "TITRE"   : Gosub TIT
 When "BOUTON"  : FIN = 1
 When "EXEC"    : If GSTATUT=GSTABOU2+1 :  SAI = 1 : Endif
Endcase
Return

$INIT
Local File =adxtms [STD]
Return

$TIT
TIT = mess(43,100,1)-'"'+toupper(ctrans([M:DIA]CHAINE))+'"' : # Recherche
Return

$DEBUT
Local Char    CHAINE(250)
Local Integer NB , MAXLIG
NB = 0
CHAINE = toupper(ctrans([M:DIA]CHAINE))
Raz [M:AFF]
MAXLIG = dim([M:AFF]TEXTE) 
For [STD]CLE Where LAN=GLANGUE & pat(toupper(ctrans([F:STD]LANMES)),"*"+CHAINE+"*")
 NB += 1
 [M:AFF]NBLIG = NB
 [M:AFF]TEXTE(NB-1) = 'mess('
 [M:AFF]TEXTE(NB-1) += format$('N0:5#',[F:STD]LANNUM)+','
 [M:AFF]TEXTE(NB-1) += format$('N0:5#',[F:STD]LANCHP)+',1) : '
 If [F:STD]LANNUM<0 or [F:STD]LANCHP<0
  [M:AFF]TEXTE(NB-1) += "Error"-mess(78,100,1)+"="+num$([F:STD]LANCHP)-"Number="+num$([F:STD]LANNUM)
 Else
  [M:AFF]TEXTE(NB-1) += mess([F:STD]LANNUM,[F:STD]LANCHP,1)
 Endif
 If NB<=20 : # mb pour optimiser l'affichage
  Affzo [AFF]TEXTE(NB-1)
 Endif
 If NB>=MAXLIG : Break : Endif
Next
Affzo
Return

