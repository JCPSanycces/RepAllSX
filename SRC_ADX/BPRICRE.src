#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################################
#
#    BPRICRE - Recurring invoice creation
#
# Issue X3-49974 - 2017-07-25 by BEFOU : Field All Compagnies - Functionnal profil
# Issue X3-45439 - 2017-07-24 by BEFOU : All user not re-initialized properly - Functionnal profil
######################################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","BPRICRE","BPRICRE",4,"") From GTRAITE
End
######################################################################################
$ACTION
Case ACTION
  When "DEBUT"       : Gosub DEBUT
  When "OUVRE_BATCH" : Gosub OUVRE
  When "INIT"        : Gosub OUVRE
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "TERMINE"     : Gosub FIN
  When "OK"          : FIN = 1 : GOK = 1
  When "END"         : FIN = 1 : GOK = 0
Endcase

Return
######################################################################################
$DEBUT
  Raz [M:DIA] : Affzo [DIA]
  # Issue X3-49974 - 2017-07-25 by BEFOU : Del the DEBUT From CPTTRT Cal Adding Focus on CPY ( zonsui )
  #Call DEBUT(GUSER) From CPTTRT
  zonsui="CPY"
  Setmok [DIA] With 0
Return
######################################################################################
$OUVRE

If (GTYPGEN = 0) Then : GTYPGEN = 1 : Endif

Gosub OPENTABLES

Gosub DECLARE_GLOBAL From SUBBICS
Gosub DECLARE_MASQUE From SUBBICS

If func AFNC.ACTIV("INTCO") : Gosub INTCPY_OUVRE From INTCPYLIB : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Local Integer III, STAT
Local Char    CRITERE(250), CRITEREJ(250), CRITSUP(250)
Local Integer NBPCE, NBCMP, NBERR
Local Integer STAT
Local Char    INVNUM(GLONVCR)
Local Integer OKTCA
Local Integer OKMESS
Local Char    TIT(50)
Local Char    MESSA(50)
Local Char    SOCIETE(GLONCPY)
Local Char    DEPMOD(10)
Local Char    OPTVAL(5)
Local Integer NUM_DATES
Local Date    GEN_DATES(999), THEACCDAT

TIT = mess(83,119,1)

If GSERVEUR
    Onerrgo ERRBATCH
Endif

Local Mask BPRICRE [DIA]
Raz [M:DIA]
[M]OPTVAL = GUSRAUZ(1)

Call LECMEMO("STD","[M:DIA]","ri1") From GMEMO
Return

######################################################################################
## Open Tables
######################################################################################
$OPENTABLES

Local File RCRINVOICE [RCR],  RCRINVOICE [RCR2]

Local File SINVOICE   [SIH],  BPCINVLIG [SIL], BPCINVLIGA [SIA]
Local File PINVOICE   [PIH],  BPSINVLIG [PIL], BPSINVLIGA [PIA]

# For the copies
Local File SINVOICE   [TSIH]
Local File BPCINVLIG  [TSIL]
Local File BPCINVLIGA [TSIA]
Local File PINVOICE   [TPIH]
Local File BPSINVLIG  [TPIL]
Local File BPSINVLIGA [TPIA]

Local File FACILITY   [FCY],  COMPANY    [CPY]

Local File TABCOUAFF  [TCA]   # Sequence number assignments
Local File GTYPACCENT [GTE]   # Document types
Local File FISCALYEAR [FIY]   # Fiscal years
Local File PERIOD     [PER]   # Fiscal periods
Local File TABPIVTYP  [TPV]   # Supplier invoice type
Local File TABSIVTYP  [TSV]   # Customer invoice type
Local File GACCDUDATE [DUD]   # Open items
Local File CACCE      [CCE]   # Dimensions
Local File GACCOUNT   [GAC]   # Account
Local File TABCUR     [TCU]   # Currency
Local File CADSP      [DSP]   # Allocations

Local File ATABDIV    [ADI]   # Miscellaneous tables

Return
######################################################################################
$CONTROLE

If GOK<1
  FIN = 1
Else
  TMP=1
Endif

If FIN : Return : Endif

Call AVERTDGI([M:DIA]ALLCPY,[M:DIA]CPY,1,FIN) From CPTDIV2

If FIN : Return : Endif

Return
######################################################################################
$EXEC

If GSERVEUR
  [M:DIA]TRC = 2
Endif

If !GSERVEUR & [M:DIA]TRC=2
  If [M:DIA]RCRTYP=1
    TIT = mess(43,109,1)-mess(51,197,1) # Customer Invoice Creation
  Else
    TIT = mess(44,109,1)-mess(51,197,1) # Supplier Invoice Creation
  Endif
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(mess(422,107,1),0) From GESECRAN
  Call ECR_TRACE(string$(50,"="),0) From GESECRAN
  Call ECR_TRACE(mess(67,200,1)-":"-mess([M:DIA]RCRTYP,2813,1),0) From GESECRAN
  If [M:DIA]ALLCPY= 2
    Call ECR_TRACE(mess(145,139,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(2,45,1)-":"-[M:DIA]CPY,0) From GESECRAN
  Endif
  If dim([M:DIA]LEG)>0
   Call ECR_TRACE(mess(218,107,1)-":"-[M:DIA]LEG,0) From GESECRAN
  Endif
  If [M:DIA]ALLFCY= 2
    Call ECR_TRACE(mess(4,116,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(12,105,1)-":"-[M:DIA]FCY,0) From GESECRAN
  Endif
  If [M:DIA]ALLUSR= 2
    Call ECR_TRACE(mess(151,100,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(37,133,1)-":"-[M:DIA]USR,0) From GESECRAN
  Endif
  If [M:DIA]ALLTYP= 2
    Call ECR_TRACE(mess(26,198,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(421,107,1)-":"-[M:DIA]INVTYP,0) From GESECRAN
  Endif
  If [M:DIA]ALLBP= 2
    Call ECR_TRACE(mess(419,107,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(31,105,1)-":"-[M:DIA]BPRNUM,0) From GESECRAN
  Endif
  If [M:DIA]ALLRCR= 2
    Call ECR_TRACE(mess(420,107,1),0) From GESECRAN
  Elsif([M:DIA]FRRCRNUM=[M:DIA]TORCRNUM)
    Call ECR_TRACE(mess(226,107,1)-":"-[M:DIA]FRRCRNUM,0) From GESECRAN
  Else
    Call ECR_TRACE(mess(226,107,1)-mess(144,141,1)-":"-[M:DIA]FRRCRNUM,0) From GESECRAN
    Call ECR_TRACE(mess(226,107,1)-mess( 64,151,1)-":"-[M:DIA]TORCRNUM,0) From GESECRAN
  Endif
  Call ECR_TRACE(mess(27,107,1)-":"-mess([M:DIA]SIM,1,1),0) From GESECRAN
  Call ECR_TRACE(mess(418,107,1)-format$("D:"+GFMDAT,[M:DIA]INVDAT),0) From GESECRAN
  Call ECR_TRACE(mess(14,105,1)-":"-format$("D:"+GFMDAT,[M:DIA]ACCDAT),0) From GESECRAN
  Call ECR_TRACE(string$(50,"="),0) From GESECRAN
Endif

If GNBLEG=1
  GCURLEG=GDOSLEG(1)
Else
  If dim([M:DIA]LEG)>0 : GCURLEG=[M:DIA]LEG : Endif  #98907
Endif

CRITERE = "1=1"
If [M:DIA]ALLCPY<>2
  CRITERE -= '& CPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
  CRITERE -= '& FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLRCR<>2
  CRITERE -= '& RCRNUM>= "'+[M:DIA]FRRCRNUM+'"'
  CRITERE -= '& RCRNUM<= "'+[M:DIA]TORCRNUM+'"'
Endif
If [M:DIA]ALLUSR<>2
  CRITERE -= '& (UPDUSR = "'+[M:DIA]USR+'"'
  CRITERE -= '| (UPDUSR = "" & CREUSR = "'+[M:DIA]USR+'"))'
Endif

CRITSUP = ""
GPOINT = "CRITERE" : Gosub ENTREE From EXEFNC
If CRITSUP="" : CRITSUP = "1=1" : Endif

NBPCE = 0
NBCMP = 0
NBERR = 0

# Create the Invoices
Gosub CREBPRI

# Report how many were generated
If [M:DIA]TRC=2 & [M:DIA]SIM <> 2
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(num$(NBPCE)-mess(87,121,1)-mess(2,3037,1),0) From GESECRAN : # Invoices Generated
Endif

# Report how many were updated to Complete
If NBCMP & [M:DIA]TRC=2
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(num$(NBCMP)-mess(1,3630,1)-mess(87,121,1)-mess(1061,196,1),0) From GESECRAN : # Recurring Invoices completed
Endif

If !GSERVEUR & [M:DIA]TRC=2
  Call FERME_TRACE From LECFIC
Endif

Raz GREP, GMESSAGE
Return
######################################################################################
$CREBPRI

If [M:DIA]SIM=2
  Call ECR_TRACE(mess(55,7778,1),0) From GESECRAN # Simulation of the generation
Endif

If [M:DIA]RCRTYP=1 : GABREV="BIC" : Else GABREV="BIS" : Endif
GTYPGEN = 1
THEACCDAT=[M:DIA]ACCDAT

Filter [F:RCR] Where RCRTYP=[M:DIA]RCRTYP & RCRSTA=2 & NUM <> "" & STRDAT<=[M:DIA]INVDAT & evalue(CRITERE) & evalue(CRITSUP)
For [F:RCR]

  Raz NUM_DATES, GEN_DATES, NBERR

  Read [F:FCY]FCY0=[F:RCR]FCY
  If fstat or ([F:FCY]LEG>"" and dim([M:DIA]LEG)>0 and [M:DIA]LEG>"" and [F:FCY]LEG<>[M:DIA]LEG) or ([M:DIA]ALLCPY=1 and [M:DIA]CPY<>[F:FCY]LEGCPY)
    Goto SKIP_RI
  Endif
  Call GETSOC([F:RCR]FCY) From DEVSUB

  Read [F:CPY]CPY0=[F:FCY]LEGCPY

  If GCURLEG=""
    If [F:FCY]LEG <> ""
      GCURLEG = [F:FCY]LEG
    Else
      GCURLEG=[F:CPY]LEG
    Endif
  Endif

  # Read the Reference invoice (from invoice)
  If [F:RCR]RCRTYP=1
    Read [F:SIH]SIH0=[F:RCR]NUM
  Else
    Read [F:PIH]PIH0=[F:RCR]NUM
  Endif
  If fstat
    GMESSAGE = func AFNC.MES2(mess(99,119,1),[F:RCR]NUM,[F:RCR]RCRNUM) # copy invoice XXXX does not exist for recurring invoice XXX
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Goto SKIP_RI
  Endif

  # Check Business partner
  If [M:DIA]ALLBP<>2
    If [F:RCR]RCRTYP=1 and [F:SIH]BPR <> [M:DIA]BPRNUM
      Goto SKIP_RI
    Elsif [F:RCR]RCRTYP=2 and [F:PIH]BPR <> [M:DIA]BPRNUM
      Goto SKIP_RI
    Endif
  Endif

  # Check invoice type
  If [M:DIA]ALLTYP<>2
    If [F:RCR]RCRTYP=1 and [F:SIH]SIVTYP <> [M:DIA]INVTYP
      Goto SKIP_RI
    Elsif [F:RCR]RCRTYP=2 and [F:PIH]PIVTYP <> [M:DIA]INVTYP
      Goto SKIP_RI
    Endif
  Endif

  Call DETERMINE_DATES([M:DIA]INVDAT,0,NUM_DATES,GEN_DATES) From TRTRILIB

  # Reread the invoice to copy
  If [F:RCR]RCRTYP=1
    Read [F:SIH]SIH0=[F:RCR]NUM
  Else
    Read [F:PIH]PIH0=[F:RCR]NUM
  Endif

  For III = 1 To NUM_DATES

    GOK = 1
    GMESSAGE=""
    mkstat = 0
    INVNUM = ""

    If [M:DIA]SIM=2
      GMESSAGE = func AFNC.MES2(mess(98,119,1),[F:RCR]RCRNUM,format$("DD2",GEN_DATES(III))) # recurring invoice XXX qualifies for generation on XXXXX
      Call ECR_TRACE(GMESSAGE,0) From GESECRAN
      NBPCE+=1
    Else

      #97052.sn
      # Entry point to allow users to change the generated invoice accounting date
      GPE=0
      GPOINT="CHGACCDAT" : Gosub ENTREE From EXEFNC
      If GPE=1 : Return : Endif
      #97052.en

      # Copy the template invoice
      If [F:RCR]RCRTYP = 1
        Gosub CPYBICINV From TRTRILIB
      Else
        Gosub CPYBISINV From TRTRILIB
      Endif

      If GOK
        NBPCE+=1
        If [M:DIA]TRC=2
          If [F:RCR]RCRTYP=1
            GMESSAGE=mess(43,109,1) # Customer invoice
          Else
            GMESSAGE=mess(44,109,1) # Supplier invoice
          Endif
          # Invoice XXXX was created on mm/dd/yyyy from recurring invoice XXXX.
          GMESSAGE = func AFNC.MES3(mess(103,119,1),INVNUM, format$("DD2",GEN_DATES(III)), [F:RCR]RCRNUM)
          Call ECR_TRACE(GMESSAGE,0) From GESECRAN

          If [F:RCR]RCRTYP=2
            #Localisation Australienne
            Local Integer RWRN
            Call AUSABNWRN([F:PIH]BPR,[F:PIH]CPY,RWRN) From SUBBIS
            If (RWRN)
              # Ce fournisseur n'a pas de numéro ABN. Merci de vérifier la fiche fournisseur avant de comptabiliser la facture
              Call ECR_TRACE(mess(73,198,1)-":"-[F:PIH]BPR-mess(106,119,1),-1) From GESECRAN
            Endif
          Endif

        Endif
      Else
        NBERR+=1
        If [M:DIA]TRC=2
          Call ECR_TRACE(mess(7,21,1)-mess(90,200,1)-mess(1,3630,1)-mess(193,198,1)-[F:RCR]RCRNUM-GMESSAGE,1) From GESECRAN # error processing recurring invoice
        Endif
      Endif

    Endif

  Next

  If [M:DIA]SIM<>2 and NBERR=0  : Gosub CHECK_COMPLETED : Endif

$SKIP_RI
Next
Filter [F:RCR]

Return
###############################################################################################
$CHECK_COMPLETED

Local Integer TOCMP

Read [F:RCR2]RCH0=[F:RCR]RCRNUM
If fstat = 0

  TOCMP=0
  # See if the recurring invoice should be Completed
  If [F:RCR2]ENDDAT <= [M:DIA]INVDAT
    TOCMP = 1
  Else
    # See if more pattern dates exist
    Raz NUM_DATES, GEN_DATES
    Call DETERMINE_DATES([F:RCR2]ENDDAT,1,NUM_DATES,GEN_DATES) From TRTRILIB
    If NUM_DATES = 0
      TOCMP = 1
    Endif
  Endif
  If TOCMP
    Trbegin [F:RCR2]
    [F:RCR2]RCRSTA=3
    Rewrite [F:RCR2]
    If fstat
      Rollback
    Else
      NBCMP += 1
      If [M:DIA]TRC=2
        Call ECR_TRACE(mess(1,3630,1)-mess(1016,182,1)-[F:RCR2]RCRNUM-mess(1061,196,1),0) From GESECRAN # Recurring Invoice no. XXXXXX  Completed
      Endif
      Commit
    Endif
  Endif
Endif
Return
######################################################################################
$FIN
If !GSERVEUR & [M:DIA]TRC=2
  TRA = 1
Else
  TRA = 0
Endif
Return
######################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
######################################################################################
# Mask Management BPRICRE
######################################################################################
######################################################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From CPTTRT
End
# Issue X3-49974
Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Diszo ALLCPY
 Actzo CPY,ALLFCY
 If dim([M]LEG)>0
  Effzo LEG : Diszo LEG
 Endif
 mkstat = 1 : End
Endif
End
# End issue X3-49974
######################################################################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If [M]ALLCPY=2 : mkstat = 1 : End : Endif
End
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char  VALEUR
Call AM_CPY(VALEUR) From CPTTRT
# Issue X3-45439
  Call CONTUSR(VALEUR,[M]FCY) From CPTSUB
  If mkstat
    [M:DIA]ALLUSR=1 : [M]USR=GUSER
    Affzo [M:DIA]ALLUSR : Affzo [M]USR
    Grizo [M:DIA]ALLUSR : Diszo [M]USR
    Raz mkstat
  Else
    Actzo [M:DIA]ALLUSR
  Endif
# End issue X3-45439
End
######################################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Call C_LEG(VALEUR) From CPTTRT
Else
  Raz GCURLEG
Endif
End
######################################################################################
Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
If [M]ALLCPY=2 : VALEUR = 2 : End : Endif
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
If VALEUR=2 : Effzo FCY : Grizo FCY : Else : Actzo FCY : Endif
End
######################################################################################
Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End
######################################################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M]ALLFCY=2 : mkstat = 1 : End : Endif
End
######################################################################################
Subprog AS_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Effzo INVTYP : Grizo INVTYP : Else : Actzo INVTYP : Endif
End
######################################################################################
Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Raz [M]INVTYP : Affzo INVTYP : Grizo INVTYP : Else : Actzo INVTYP : Endif
End
######################################################################################
Subprog AS_INVTYP(VALEUR)
Variable Char    VALEUR()
If [M]ALLTYP=2 : mkstat = 1 : End : Endif
End
######################################################################################
Subprog C_ALLUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]USR="" : Affzo USR : Grizo USR : Else : Actzo USR : Endif
End
######################################################################################
Subprog AS_USR(VALEUR)
Variable Char    VALEUR()
If [M]ALLUSR = 2 : mkstat = 1 : End : Endif
If VALEUR="" : VALEUR = GUSER : Endif
End
######################################################################################
Subprog C_ALLBP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz   [M]BPRNUM
  Affzo [M]BPRNUM
  Grizo [M]BPRNUM
Else
  Actzo [M]BPRNUM
Endif
End
######################################################################################
Subprog AS_BPRNUM(VALEUR)
Variable Char    VALEUR()
If [M]ALLBP = 2 : mkstat = 1 : End : Endif
End
######################################################################################
Subprog C_ALLRCR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz   [M]FRRCRNUM, TORCRNUM
  Affzo [M]FRRCRNUM, TORCRNUM
  Grizo [M]FRRCRNUM, TORCRNUM
Else
  Actzo [M]FRRCRNUM, TORCRNUM
Endif
End
######################################################################################
Subprog AS_FRRCRNUM(VALEUR)
Variable Char    VALEUR()
If [M]ALLRCR = 2 : mkstat = 1 : End : Endif
End
######################################################################################
Subprog AS_TORCRNUM(VALEUR)
Variable Char    VALEUR()
If [M]ALLRCR = 2 : mkstat = 1 : End : Endif
End
######################################################################################
Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE
End
######################################################################################
Subprog AM_SIM(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  [M]TRC=2
  Affzo [M]TRC
  Grizo [M]TRC
Else
  Actzo [M]TRC
Endif
End
######################################################################################
$GRISE

#
# Refine authorizations by using the function option to indicate which type of invoices can be generated
#
If [M]OPTVAL="C"                # Customer
  [M]RCRTYP=1
  Grizo [M]RCRTYP
Endif
If [M]OPTVAL="S"                # Supplier
  [M]RCRTYP=2
  Grizo [M]RCRTYP
Endif

If dim([M]ALLCPY)>0
  If [M]ALLCPY=2
    Grizo CPY,FCY
    [M]ALLFCY=2 : Affzo ALLFCY : Grizo ALLFCY
    If dim([M]LEG)>0 : Affzo LEG : Endif
  Else
    Actzo CPY,ALLFCY
    If dim([M]LEG)>0
      If [M]LEG = ""
        Effzo LEG : Diszo LEG
      Else
        Diszo LEG
      Endif
    Endif
  Endif
Endif

# All sites
If dim([M]ALLFCY)>0
  If [M]ALLFCY=2 : Grizo FCY : Else : Actzo FCY : Endif
Endif

# All Invoice types
If [M]ALLTYP=2
  Grizo INVTYP
Else
  Actzo INVTYP
Endif

# All BPs
If [M]ALLBP=2
  Grizo BPRNUM
Else
  Actzo BPRNUM
Endif

# All Recurring invoices
If [M]ALLRCR=2
  Grizo [M]FRRCRNUM, TORCRNUM
Else
  Actzo [M]FRRCRNUM, TORCRNUM
Endif

# All users
If dim([M]ALLUSR)>0
  If [M]ALLUSR=2 : [M]USR="" : Affzo USR : Grizo USR : Else : Actzo USR : Endif
Endif

# Simulation checkbox
If dim([M]SIM)>0
  If [M]SIM=2 : [M]TRC=2 : Affzo [M]TRC : Grizo [M]TRC : Else : Actzo [M]TRC : Endif
Endif

Return
######################################################################################
Subprog AM_FRRCRNUM(VALEUR)
Variable Char    VALEUR()
[M:DIA]TORCRNUM=VALEUR
Affzo [M:DIA]TORCRNUM
End
######################################################################################
Subprog C_TORCRNUM(VALEUR)
Variable Char    VALEUR()
If [M:DIA]FRRCRNUM<>"" and VALEUR <> ""
  If VALEUR < [M:DIA]FRRCRNUM
    GMESSAGE = mess(44,199,1) # End range is less than Start range
    mkstat = 2 : End
  Endif
Endif
End
######################################################################################
Subprog C_ACCDAT(VALEUR)
Variable Date    VALEUR

If [M]ALLCPY<>2 & [M]CPY <> ""
  # Check date entered against various restrictions/paramters/etc
  Local Decimal EXERCICE , PERIODE, OEXERCICE, OPERIODE
  If !clalev([F:ANM]) : Local File ACODNUM [ANM] : Endif
  If clalev([F:AOB])  = 0 : Local File AOBJET [AOB] : Endif

  Call GETSOC([M]FCY) From DEVSUB
  GSOCIETE=[M]CPY

  Call LECTURE("AOB",GABREV,"") From CONTOBJ
  Local Integer MODULE
  MODULE = [F:AOB]MODULE
  Call CTLDATMOD(MODULE,VALEUR,GSOCIETE) From CPTSUB
  If mkstat : End : Endif

  Call GETPERSOC(GSOCIETE,GTYPGEN,VALEUR,EXERCICE,PERIODE) From CPTSUB
  If EXERCICE=0 | PERIODE=0
    GMESSAGE = mess(1,104,1) : mkstat=2 : End
  Endif

  Read [FIY]FIY0 = GSOCIETE;GTYPGEN;EXERCICE
  If fstat | [F:FIY]FIYSTA<>2
    GMESSAGE = mess(20,101,1)     # Year not open
    mkstat=2 : End
  Endif
  If [F:PER]PERSTA<2
    GMESSAGE = mess(35,101,1)     # Period not open
    mkstat=2 : End
  Endif
  If [F:PER]PERSTA>2
    GMESSAGE = mess(36,101,1)     # Période closed
    mkstat=2 : End
  Endif

  # Contrôle période facture (demande certification, lié au paramètre CTLPERINV et FRADGI)
  Call CTLPERINV([M:DIA]RCRTYP,VALEUR) From CPTSUB
  If mkstat : End : Endif
Endif

End
######################################################################################
Subprog AM_RCRTYP(VALEUR)
Variable Integer VALEUR

Raz [M:DIA]FRRCRNUM, TORCRNUM, INVTYP
Affzo [M:DIA]FRRCRNUM, TORCRNUM, INVTYP

End
######################################################################################
Subprog AS_ALLBP(VALEUR)
Variable Integer VALEUR
End
######################################################################################
Subprog C_INVTYP(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
  If [M]RCRTYP=1
    If dim([M:DIA]LEG) <= 0 or [M:DIA]LEG=""  #98907
      Filter [F:TSV] Where SIVTYP=VALEUR
    Else
      Filter [F:TSV] Where SIVTYP=VALEUR and LEG = [M:DIA]LEG
    Endif
    Read [F:TSV] First
    Filter [F:TSV]
    If fstat or [F:TSV]INVTYP<>1
      GMESSAGE = mess(3,2243,1) # Invalid invoice type
      mkstat=2 : End
    Endif
  Else
    If dim([M:DIA]LEG) <= 0 or [M:DIA]LEG=""  #98907
      Filter [F:TPV] Where PIVTYP=VALEUR
    Else
      Filter [F:TPV] Where PIVTYP=VALEUR and LEG = [M:DIA]LEG
    Endif
    Read [F:TPV] First
    Filter [F:TPV]
    If fstat or [F:TPV]INVTYP<>1
      GMESSAGE = mess(3,2243,1) # Invalid invoice type
      mkstat=2 : End
    Endif
  Endif
Endif

End

