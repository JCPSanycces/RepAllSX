#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : articles/produits
#                             cf AML 2240 : 34/35/36
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables ITMWPIV    devient WK, 
#                                                   TCOITMWPIV devient TCOWK
#                                                   FCYITMWPIV devient FCYWK
#                                                   CRIITMWPIV devient CRIWK
############################################################
$OUVTAB_ITM
If !clalev([F:TFO]) Local File TABFOR    [TFO] Endif
If !clalev([F:AXX]) Local File ATEXTRA   [AXX] Endif
If !clalev([F:ITM]) Local File ITMMASTER [ITM] Endif
If !clalev([F:ITF]) Local File ITMFACILIT [ITF] Endif
If !clalev([F:ITG]) Local File ITMCATEG  [ITG] Endif
If !clalev([F:TCO]) Local File TABCOEFF  [TCO] Endif
If !clalev([F:TLP]) Local File TABLINCFG [TLP] Endif
If !clalev([F:AUS]) Local File AUTILIS   [AUS] Endif
Return

######################################################################
Subprog TRT_ITM(ID,CLETRT,PITITM,P_FORMULE,P_CRITERE,PITTCOITM,PITCRIITM,PITFCYITM,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITITM () 
Value Char P_FORMULE() 
Value Char P_CRITERE() 
Value Char PITTCOITM () 
Value Char PITCRIITM() 
Value Char PITFCYITM() 
Variable Integer OK

If PITITM="" & PITTCOITM="" & PITCRIITM="" & PITFCYITM="" : Return : Endif

Local Char     FORMULE1(255) : Raz FORMULE1

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
If ID="SCMA"
adxium = GASCII
Else
adxium = GUTF8
Endif
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs


Gosub OUVTAB_ITM
Gosub OUVREPIVOT From CONNECTFCT


If PITITM<>""
    Local Integer WNBITM : Raz WNBITM 
    Local Integer WPREITM : Raz WPREITM
    Local Char    OPTITM(GDIMFIC)
    OPTITM = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pititm")
    Local Integer WKNBZON : Raz WKNBZON
    Local Char WKNORECMES (50): Raz WKNORECMES 
    Local Integer WKHEATYP : Raz WKHEATYP 
    Local Char WKHEADMES (250): Raz WKHEADMES 
    
    Call READPIT(PITITM,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
    Local Char WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
    Local Char WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
    Local Char WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
    Local Char WKFRM(150)(1..WKNBZON) : Raz WKFRM
    Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
    Local Char WKVAL(255)(1..WKNBZON) : Raz WKVAL
    Local Char WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
    Call LOADPIVZON(PITITM,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITITM,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREITM,OPTITM) From CONNECTFCT
Endif
If PITTCOITM<>""
    Local Integer WNBTCOITM : Raz WNBTCOITM
    Local Integer WPRETCOITM : Raz WPRETCOITM
    Local Char    OPTTCOITM(GDIMFIC)
    OPTTCOITM = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pittcoitm")
    Local Integer TCOWKNBZON : Raz TCOWKNBZON
    Local Char TCOWKNORECMES (50): Raz TCOWKNORECMES 
    Local Integer TCOWKHEATYP : Raz TCOWKHEATYP 
    Local Char TCOWKHEADMES (250): Raz TCOWKHEADMES 
    
    Call READPIT(PITTCOITM,TCOWKNBZON,TCOWKNORECMES,TCOWKHEATYP ,TCOWKHEADMES ) From CONNECTFCT
    Local Char TCOWKTABZON(GLONATB+GLONAVA+2)(1..TCOWKNBZON) : Raz TCOWKTABZON
    Local Char TCOWKTABABR(GLONABR)(1..TCOWKNBZON) : Raz TCOWKTABABR
    Local Char TCOWKZON(GLONAVA)(1..TCOWKNBZON) : Raz TCOWKTABZON
    Local Char TCOWKFRM(150)(1..TCOWKNBZON) : Raz TCOWKFRM
    Local Integer TCOWKWRK(1..TCOWKNBZON) : Raz TCOWKWRK
    Local Char TCOWKVAL(255)(1..TCOWKNBZON) : Raz TCOWKVAL
    Local Char TCOWKVALFIC(GLONAVA)(1..TCOWKNBZON) : Raz TCOWKVALFIC
    Call LOADPIVZON(PITTCOITM,TCOWKNBZON,TCOWKTABZON,TCOWKTABABR,TCOWKZON,TCOWKFRM,TCOWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITTCOITM,TCOWKNBZON,TCOWKTABZON,TCOWKTABABR,TCOWKZON,TCOWKWRK,TCOWKHEATYP,TCOWKHEADMES,WPRETCOITM,OPTTCOITM) From CONNECTFCT
Endif
If PITFCYITM<>""
    Local Integer WNBFCYITM : Raz WNBFCYITM
    Local Integer WPREFCYITM : Raz WPREFCYITM
    Local Char    OPTFCYITM(GDIMFIC)
    OPTFCYITM = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitfcyitm")
    Local Integer FCYWKNBZON : Raz FCYWKNBZON
    Local Char FCYWKNORECMES (50): Raz FCYWKNORECMES 
    Local Integer FCYWKHEATYP : Raz FCYWKHEATYP 
    Local Char FCYWKHEADMES (250): Raz FCYWKHEADMES 
    
    Call READPIT(PITFCYITM,FCYWKNBZON,FCYWKNORECMES,FCYWKHEATYP ,FCYWKHEADMES ) From CONNECTFCT
    Local Char FCYWKTABZON(GLONATB+GLONAVA+2)(1..FCYWKNBZON) : Raz FCYWKTABZON
    Local Char FCYWKTABABR(GLONABR)(1..FCYWKNBZON) : Raz FCYWKTABABR
    Local Char FCYWKZON(GLONAVA)(1..FCYWKNBZON) : Raz FCYWKTABZON
    Local Char FCYWKFRM(150)(1..FCYWKNBZON) : Raz FCYWKFRM
    Local Integer FCYWKWRK(1..FCYWKNBZON) : Raz FCYWKWRK
    Local Char FCYWKVAL(255)(1..FCYWKNBZON) : Raz FCYWKVAL
    Local Char FCYWKVALFIC(GLONAVA)(1..FCYWKNBZON) : Raz FCYWKVALFIC
    Call LOADPIVZON(PITFCYITM,FCYWKNBZON,FCYWKTABZON,FCYWKTABABR,FCYWKZON,FCYWKFRM,FCYWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITFCYITM,FCYWKNBZON,FCYWKTABZON,FCYWKTABABR,FCYWKZON,FCYWKWRK,FCYWKHEATYP,FCYWKHEADMES,WPREFCYITM,OPTFCYITM) From CONNECTFCT
Endif
If PITCRIITM<>""
    Local Integer WNBCRIITM : Raz WNBCRIITM
    Local Integer WPRECRIITM : Raz WPRECRIITM
    Local Char    OPTCRIITM(GDIMFIC)
    OPTCRIITM = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitcriitm")
    Local Integer CRIWKNBZON : Raz CRIWKNBZON
    Local Char CRIWKNORECMES (50): Raz CRIWKNORECMES 
    Local Integer CRIWKHEATYP : Raz CRIWKHEATYP 
    Local Char CRIWKHEADMES (250): Raz CRIWKHEADMES 
    
    Call READPIT(PITCRIITM,CRIWKNBZON,CRIWKNORECMES,CRIWKHEATYP ,CRIWKHEADMES ) From CONNECTFCT
    Local Char CRIWKTABZON(GLONATB+GLONAVA+2)(1..CRIWKNBZON) : Raz CRIWKTABZON
    Local Char CRIWKTABABR(GLONABR)(1..CRIWKNBZON) : Raz CRIWKTABABR
    Local Char CRIWKZON(GLONAVA)(1..CRIWKNBZON) : Raz CRIWKTABZON
    Local Char CRIWKFRM(150)(1..CRIWKNBZON) : Raz CRIWKFRM
    Local Integer CRIWKWRK(1..CRIWKNBZON) : Raz CRIWKWRK
    Local Char CRIWKVAL(255)(1..CRIWKNBZON) : Raz CRIWKVAL
    Local Char CRIWKVALFIC(GLONAVA)(1..CRIWKNBZON) : Raz CRIWKVALFIC
    Call LOADPIVZON(PITCRIITM,CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKFRM,CRIWKWRK) From CONNECTFCT
    If ID="SCMA"
        If [M:DIA]TSICOD0FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("ITMMASTER"+"/"+"WTSICOD0",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSICOD1FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("ITMMASTER"+"/"+"WTSICOD1",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSICOD2FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("ITMMASTER"+"/"+"WTSICOD2",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSICOD3FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("ITMMASTER"+"/"+"WTSICOD3",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSICOD4FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("ITMMASTER"+"/"+"WTSICOD4",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TCLCODFLG  = 1 : # on doit enlever la colonne du pivot
            IPOS=find("ITMMASTER"+"/"+"TCLCOD",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]CFGLINFLG  = 1 : # on doit enlever la colonne du pivot
            IPOS=find("ITMMASTER"+"/"+"CFGLIN",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]PLANNERFLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("ITMMASTER"+"/"+"PLANNER",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
    Endif
    Call WRPIVOT_HEAD(PITCRIITM,CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKWRK,CRIWKHEATYP,CRIWKHEADMES,WPRECRIITM,OPTCRIITM) From CONNECTFCT
Endif
#######
Gosub TRT_FORMULE
If FORMULE1="" : FORMULE1="1=1" : Endif

Link [ITM] With [ITG]ITG1~=[F:ITM]TCLCOD
& As [LNK] 
& Order By Key KEY1=[ITM]ITMREF;[ITG]TCLCOD

For [LNK]KEY1(1) Where (evalue(FORMULE1)) & (evalue(P_CRITERE))
    Gosub WR_ITM

    If PITCRIITM<>""
        Gosub WR_CRIITM
    Endif

    If PITTCOITM<>""
        Call RAZVALPIVOT(PITTCOITM,TCOWKNBZON,TCOWKVAL,TCOWKVALFIC) From CONNECTFCT
        If ID="SCMA"
            # on ecrit la ligne UV-US
            Call SETVAL("ITMMASTER","WUOM1",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,[F:ITM]SAU) From CONNECTFCT
            Call SETVAL("ITMMASTER","WUOM2",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,[F:ITM]STU) From CONNECTFCT
            Call SETVAL("ITMMASTER","WCOEUOM",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,num$([F:ITM]SAUSTUCOE)) From CONNECTFCT
            Gosub WR_TCOITM
            
            If [M:DIA]PCU0FLG=2 & [F:ITM]PCU(0)<>""
            Call SETVAL("ITMMASTER","WUOM1",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,[F:ITM]PCU(0)) From CONNECTFCT
            Call SETVAL("ITMMASTER","WUOM2",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,[F:ITM]STU) From CONNECTFCT
            Call SETVAL("ITMMASTER","WCOEUOM",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,num$([F:ITM]PCUSTUCOE(0))) From CONNECTFCT
            Gosub WR_TCOITM
            Endif
            If [M:DIA]PCU1FLG=2 & [F:ITM]PCU(1)<>""
            Call SETVAL("ITMMASTER","WUOM1",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,[F:ITM]PCU(1)) From CONNECTFCT
            Call SETVAL("ITMMASTER","WUOM2",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,[F:ITM]STU) From CONNECTFCT
            Call SETVAL("ITMMASTER","WCOEUOM",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,num$([F:ITM]PCUSTUCOE(1))) From CONNECTFCT
            Gosub WR_TCOITM
            Endif
            If [M:DIA]PCU2FLG=2 & [F:ITM]PCU(2)<>""
            Call SETVAL("ITMMASTER","WUOM1",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,[F:ITM]PCU(2)) From CONNECTFCT
            Call SETVAL("ITMMASTER","WUOM2",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,[F:ITM]STU) From CONNECTFCT
            Call SETVAL("ITMMASTER","WCOEUOM",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,num$([F:ITM]PCUSTUCOE(2))) From CONNECTFCT
            Gosub WR_TCOITM
            Endif
            If [M:DIA]PCU3FLG=2 & [F:ITM]PCU(3)<>""
            Call SETVAL("ITMMASTER","WUOM1",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,[F:ITM]PCU(3)) From CONNECTFCT
            Call SETVAL("ITMMASTER","WUOM2",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,[F:ITM]STU) From CONNECTFCT
            Call SETVAL("ITMMASTER","WCOEUOM",TCOWKNBZON,TCOWKTABZON,TCOWKVAL,TCOWKVALFIC,num$([F:ITM]PCUSTUCOE(3))) From CONNECTFCT
            Gosub WR_TCOITM
            Endif
        Else
            Gosub WR_TCOITM
        Endif
    Endif

    If PITFCYITM<>""
        For [ITF]ITF0 Where ITMREF=[F:ITM]ITMREF
            Gosub WR_FCYITM
        Next
    Endif
Next
#######
If PITITM<>"" : Call WRPIVOT_END(PITITM ,WNBITM ,WKNORECMES ,WPREITM ,OPTITM) From CONNECTFCT : Endif
If PITTCOITM<>"" : Call WRPIVOT_END(PITTCOITM ,WNBTCOITM ,TCOWKNORECMES ,WPRETCOITM ,OPTTCOITM) From CONNECTFCT : Endif
If PITFCYITM<>"" : Call WRPIVOT_END(PITFCYITM ,WNBFCYITM ,FCYWKNORECMES ,WPREFCYITM ,OPTFCYITM) From CONNECTFCT : Endif
If PITCRIITM<>"" : Call WRPIVOT_END(PITCRIITM ,WNBCRIITM ,CRIWKNORECMES ,WPRECRIITM ,OPTCRIITM) From CONNECTFCT : Endif
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$TRT_FORMULE
If P_FORMULE <> ""
    # FQ 65180 GA 06/2010 éviter pb de migration on garde les memes types de formule en V5 et V6
    # Menu local 213 rectifié en V5
    #If pat(GVERSION,"1.5.*")
    #Read [F:TFO]TFO0=27;P_FORMULE
    #Else
    Read [F:TFO]TFO0=41;P_FORMULE
    #Endif
    If !fstat 
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif
Return
######################################################################
$WR_ITM
If PITITM<>""
    ################################
    # fichiers ITM
    ################################
    #     Ouverture du fichier OPTITM en écriture
    If WPREITM = 0
      Openo OPTITM,0 Using [FPIV]
      WPREITM = 1
    Else
      Openo OPTITM Using [FPIV]
    Endif
    WNBITM += 1
    Call RAZVALPIVOT(PITITM,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITITM,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
$WR_TCOITM
If PITTCOITM<>""
    ################################
    # fichiers TCOITM
    ################################
    #     Ouverture du fichier OPTTCOITM en écriture
    If WPRETCOITM = 0
      Openo OPTTCOITM,0 Using [FPIV]
      WPRETCOITM = 1
    Else
      Openo OPTTCOITM Using [FPIV]
    Endif
    WNBTCOITM += 1
    Call EVALPIVOT(PITTCOITM,TCOWKNBZON,TCOWKTABZON,TCOWKTABABR,TCOWKZON,TCOWKFRM,TCOWKWRK,TCOWKVAL,TCOWKVALFIC) From CONNECTFCT
    Call WRPIVOT(TCOWKNBZON,TCOWKTABZON,TCOWKTABABR,TCOWKZON,TCOWKFRM,TCOWKWRK,TCOWKVAL,TCOWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
$WR_CRIITM
If PITCRIITM<>""
    ################################
    # fichiers CRIITM
    ################################
    #     Ouverture du fichier OPTCRIITM en écriture
    If WPRECRIITM = 0
      Openo OPTCRIITM,0 Using [FPIV]
      WPRECRIITM = 1
    Else
      Openo OPTCRIITM Using [FPIV]
    Endif
    WNBCRIITM += 1
    Call RAZVALPIVOT(PITCRIITM,CRIWKNBZON,CRIWKVAL,CRIWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITCRIITM,CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKFRM,CRIWKWRK,CRIWKVAL,CRIWKVALFIC) From CONNECTFCT
    Call WRPIVOT(CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKFRM,CRIWKWRK,CRIWKVAL,CRIWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
$WR_FCYITM
If PITFCYITM<>""
    ################################
    # fichiers FCYITM
    ################################
    #     Ouverture du fichier OPTFCYITM en écriture
    If WPREFCYITM = 0
      Openo OPTFCYITM,0 Using [FPIV]
      WPREFCYITM = 1
    Else
      Openo OPTFCYITM Using [FPIV]
    Endif
    WNBFCYITM += 1
    Call RAZVALPIVOT(PITFCYITM,FCYWKNBZON,FCYWKVAL,FCYWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITFCYITM,FCYWKNBZON,FCYWKTABZON,FCYWKTABABR,FCYWKZON,FCYWKFRM,FCYWKWRK,FCYWKVAL,FCYWKVALFIC) From CONNECTFCT
    Call WRPIVOT(FCYWKNBZON,FCYWKTABZON,FCYWKTABABR,FCYWKZON,FCYWKFRM,FCYWKWRK,FCYWKVAL,FCYWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
#############################################################################

#############################################################################
Funprog ITM_GETDES(CHAMP)
Value Char CHAMP
If pat(GVERSION,"1.5.*")
    If !clalev([F:ITM]) Local File ITMMASTER [ITM] Endif
    If CHAMP="DES3AXX"
        End [F:ITM]ITMDES3
    Elsif CHAMP="DES2AXX"
        End [F:ITM]ITMDES2
    Else : ##"DES1AXX"
        End [F:ITM]ITMDES1
    Endif
Else
    #End [F:ITM]ITMDES1
         # FGR 30/06/2009 : X3SUIVI56189
    Local Char WITMDES(GLONDES)
         # FGR 30/06/2009 : X3SUIVI56189
    Call CHARGE_DEFITMDES(CHAMP,GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    End WITMDES
         # FGR 30/06/2009 : X3SUIVI56189
Endif
End ""

#############################################################################
Funprog ITM_GETITMDES(ITMREF,CHAMP)
Value Char ITMREF
Value Char CHAMP
If !clalev([F:ITM]) Local File ITMMASTER [ITM] Endif
If [F:ITM]ITMREF<>ITMREF
    Read [ITM]ITM0=ITMREF
    If fstat : End "" : Endif
Endif
If pat(GVERSION,"1.5.*")
    If CHAMP="DES3AXX"
        End [F:ITM]ITMDES3
    Elsif CHAMP="DES2AXX"
        End [F:ITM]ITMDES2
    Else : ##"DES1AXX"
        End [F:ITM]ITMDES1
    Endif
Else
    #End [F:ITM]ITMDES1
         # FGR 30/06/2009 : X3SUIVI56189
    Local Char WITMDES(GLONDES)
         # FGR 30/06/2009 : X3SUIVI56189
    Call CHARGE_DEFITMDES(CHAMP,GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    End WITMDES
         # FGR 30/06/2009 : X3SUIVI56189
Endif
End ""



#############################################################################
Funprog ITG_GETDES(TCLCOD,CHAMP)
Value Char TCLCOD
Value Char CHAMP
If pat(GVERSION,"1.5.*")
    If !clalev([F:ITG]) Local File ITMCATEG  [ITG] Endif
    If [F:ITG]TCLCOD <> TCLCOD
        Read [ITG]ITG1=TCLCOD;""
        If fstat : End "" : Endif
    Endif
    If CHAMP="TCLSHOAXX"
        End [F:ITG]TCLSHO
    Else : ##"TCLAXX"
        End [F:ITG]TCLDES
    Endif
Else
    End func AFNC.TEXTRA("ITMCATEG",CHAMP,TCLCOD,"")
Endif
End ""

#############################################################################
Funprog TLP_GETDES(CFGLIN)
Value Char CFGLIN
If pat(GVERSION,"1.5.*")
    If !clalev([F:TLP]) Local File TABLINCFG [TLP] Endif
    If [F:TLP]CFGLIN <> CFGLIN
        Read [TLP]TLP0=CFGLIN
        If fstat : End "" : Endif
    Endif
     End [F:TLP]CFGLINDES
Else
    End func AFNC.TEXTRA("TABLINCFG","CFGLINAXX",CFGLIN,"")
Endif
End ""

