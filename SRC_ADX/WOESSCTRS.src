Read [JOT]JOT0 = [F:HRCTR]JOBPOT
If fstat : Raz [F:JOT] : Endif
Read [POT]POT0 = [F:HRCTR]POT
If fstat : Raz [F:POT] : Endif
Read [ACC]CODACC = GUSER;[F:ID]CODACS
If fstat : Raz [F:ACC] : Endif
Read [SRV]SRV0 = [F:HRCTR]ETRSRV
If fstat : Raz [F:SRV] : Endif
Return

