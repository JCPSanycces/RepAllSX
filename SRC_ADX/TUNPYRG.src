#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
#PARAM(1) : Pyramide
#PARAM(2) : Niveau de définition
End

$ACTION
Case ACTION
 When "EXEC"        : Gosub EXEC
Endcase
Return

$EXEC
If clalev([F:CPH])=0 : Local File CPYRAMIDG[CPG] : Endif 
Filter [CPG] Where PYR=PARAM(1) & LEV=val(PARAM(2))
Read [F:CPG]CPG1 First 
Filter [CPG]
If fstat=0
 GBIDC1 =[F:CPG]GRP 
 GBIDC2 =num$([F:CPG]LIN)
Else
 Filter [CPG] Where PYR=PARAM(1)
 Read [F:CPG]CPG1 First 
 Filter [CPG]
 GBIDC1 =[F:CPG]GRP
 GBIDC2="0"
Endif
Return
