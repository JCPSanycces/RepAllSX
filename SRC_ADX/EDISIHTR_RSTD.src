#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation EDISIHFA JUCON 01/07/2016                                    #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"           : Gosub AREAD_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_AFTER_LOAD_REPRESENTATION" :  Gosub MET_AFTER_LOAD_REPRESENTATION
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

$AREAD_AFTER
  Gosub GETVALPARAMURL From TRTFUNEDI
Return

#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  Local Integer I, J
  Local Integer WOK, WOKK : WOK     = [V]CST_AOK
  Local Integer WSTATUS   : WSTATUS = [V]CST_AOK

  WOKK=func EDIRUN_CSTD.CHECK_AUTHORIZATION_SITE(this.ACTX.USER,WCATCOD,this.ETC.SIV.SALFCY,WCATACT)

  If WOKK=0
    WSTATUS = [V]CST_AERROR
    WERR = mess(74,100,1)    #Unauthorized Function
  Else
    Case WCATACT
      When 1 :
        Case WPARCOD
          When "FACTURAE" : Gosub FACTURAE_ISSUE
          When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
        Endcase
      When 2 :
        Case WPARCOD
          When "FACTURAE" : Gosub FACTURAE_RECEIPT
          When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
        Endcase
    Endcase
  Endif

  ARET_VALUE = WSTATUS
Return

################################################################################
$FACTURAE_ISSUE
  #####################################
  #####           HEAD          #######
  #####################################
  Local Char WCODE(20), WREP(20), WLEG(3), WLAN(3), WPROP(25)
  Local Integer WNB: WNB=1

#   Init Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
  Local Char NUMDOC(20)
  NUMDOC=this.ETC.SIV(WNB).NUM
#   End Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)

  WREP=right$(this.AINF.NAMCLA,3)
  WLEG=this.ETC.SIV(WNB).SIVTYP_LEG
  WLAN=this.ACTX.LAN
  Local Char WCPY(5) : WCPY=this.ETC.SIV(WNB).CPY

  Local Char WSEPDEC(1)

  WSEPDEC="."

  this.ETC.VERSION=this.ETC.MSGREL
  If this.ETC.VERSION="": this.ETC.VERSION="3.2": Endif   # Facturae 3.2. Default version
  this.ETC.MODALITY ="I"   # "L" when lot
  this.ETC.ISSUERTYPE="EM"

  ########################
  # Filling Batch values #
  ########################
  #this.BATCHID= this.ETC.NUMBATCH
  this.ETC.INVCOUNT="1"   # pending to count number into the batch if merge is possible
  Local Decimal RETEN, ANTIC, RETENF
  Local Integer K,OKTVT, OKTVB, DTARET(1..)
  this.ETC.EDICUR=this.ETC.SIV(WNB).SIH(WNB).CUR

  If WLEG=""
    Local File COMPANY [CPY]
    Read [CPY]CPY0=this.ETC.SIV(WNB).CPY
    If fstat=[V]CST_AOK
      WLEG=[F:CPY]LEG
    Endif
    LogicClose File [CPY]
  Endif

  For I=1 To maxtab(this.ETC.SIV(WNB).C_PAM)
    ANTIC+=this.ETC.SIV(WNB).C_PAM(I).INSATI
  Next

  Local File TABVAT [TVT]
  For I=1 To maxtab(this.ETC.SIV(WNB).SVV)
    Read [TVT]TVT0=this.ETC.SIV(WNB).SVV(I).VAT;WLEG
    If fstat<>[V]CST_AOK
      Read [TVT]TVT0=this.ETC.SIV(WNB).SVV(I).VAT;""
      If fstat=[V]CST_AOK : OKTVT=1 :Endif
    Else OKTVT=1
    Endif
    If OKTVT=1
      If [F:TVT]VATTYP=3
        K+=1
        DTARET(K)=I
        If this.ETC.SIV(WNB).SVV(I).CUR="EUR"
          RETEN+=abs(this.ETC.SIV(WNB).SVV(I).AMTTAX)
        Else
          RETEN+=abs(this.ETC.SIV(WNB).SV(I).AMTTAX)*this.ETC.SIV(WNB).SIH(WNB).C_RATCOL(1).RATMLT
        Endif
      Endif
    Endif
  Next
  LogicClose File [TVT]

  Local File SFOOTINV [SFI]
  For I=1 To maxtab(this.ETC.SIV(WNB).SVF)
    Read [SFI]SFI0= this.ETC.SIV(WNB).SVF(I).DTA
    If fstat=[V]CST_AOK
      If this.ETC.SIV(WNB).SIH(WNB).VAC<>[F:SFI]VACITM
        Local File TABVACBPR [TVB]
        Read [TVB]TVB0=[F:SFI]VACITM;WLEG
        If fstat<>[V]CST_AOK
          Read [TVB]TVB0=[F:SFI]VACITM;""
          If fstat=[V]CST_AOK : OKTVB=1 :Endif
        Else OKTVB=1
        Endif
        If OKTVB=1
          Local File TABVAT [TVT]
          Read [TVT]TVT0=[F:TVB]VAT;WLEG
          If fstat=[V]CST_AOK and [F:TVT]VATTYP=3: OKTVB=2
          Else
            Read [TVT]TVT0=[F:TVB]VAT;""
            If fstat=[V]CST_AOK and [F:TVT]VATTYP=3: OKTVB=2: Endif
          Endif
          If OKTVB=2
            If this.ETC.SIV(WNB).SVV(I).CUR="EUR"
              RETENF+=abs(this.ETC.SIV(WNB).SVF(I).DTAAMT)
            Else
              RETENF+=abs(this.ETC.SIV(WNB).SVF(I).DTAAMT)*this.ETC.SIV(WNB).SIH(WNB).C_RATCOL(1).RATMLT
            Endif
          Endif
          LogicClose File [TVB]
          LogicClose File [TVT]
        Endif
      Endif
    Endif
  Next
  LogicClose File [SFI]

  If RETEN <> 0 : Raz RETENF: Endif     # If witholding is indicated like a tax, we don´t have to use retention in the element foot

  If this.ETC.VERSION="3.2"
    WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).AMTATI)
    this.ETC.EDIAMTATI=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).AMTATI-ANTIC)
    this.ETC.EDIAMTNOT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).AMTATI-RETENF-ANTIC)
    this.ETC.EDIAMTEXE=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    If this.ETC.EDICUR<>"EUR"
      WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).AMTATIL)
      this.ETC.EDIAMTATIL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).AMTATIL-ANTIC)
      this.ETC.EDIAMTNOTL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).AMTATIL-RETENF-ANTIC)
      this.ETC.EDIAMTEXEL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Endif
  Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
    WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SIH(WNB).AMTATI)
    this.ETC.EDIAMTATI=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SIH(WNB).AMTATI-ANTIC)
    this.ETC.EDIAMTNOT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SIH(WNB).AMTATI-RETENF-ANTIC)
    this.ETC.EDIAMTEXE=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    If this.ETC.EDICUR<>"EUR"
      WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).AMTATIL)
      this.ETC.EDIAMTATIL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).AMTATIL-ANTIC)
      this.ETC.EDIAMTNOTL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).AMTATIL-RETENF-ANTIC)
      this.ETC.EDIAMTEXEL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Endif
  Endif

  Local File ASHWPAR [ASWP]   # Transcoding EDICUR (in STD table 223)
  Filter [ASWP] Where CODREP=WREP and CODLNK="EDICUR"
  Read First
  If fstat=[V]CST_AOK
    Local Char WNODE(20), WTYP(20)
    Local Integer WTAB
    WTYP=this.ETC.SIV(WNB).CUR
    WTAB=val([F:ASWP]VALEUR)
    WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
    this.ETC.EDICUR= left$(WNODE,3)
  Endif
  If this.ETC.EDICUR="": this.ETC.EDICUR=this.ETC.SIV(WNB).CUR: Endif
  LogicClose File [ASWP]

  ############################
  # Filling Factoring values #
  ############################
  If this.ETC.SIV(WNB).BPRFCT<>""
    Local File FACTOR [FCT]
    Read [FCT]FCT0= this.ETC.SIV(WNB).BPRFCT
    If fstat=[V]CST_AOK
      Local Char WFCTIBAN(34), WFCTCPTNUM(34), WFCTBANCOD(60), WFCTBRACOD(60), WFCTBANADD(80), WFCTBANCTY(50), WFCTBANSAT(20), WFCTBICCOD(11)
      Local Char WFCTCRY(3), WFCTBANPOS(5), WFCTBANCTYP(50), WFCTBANCRY(3)

      Local File BANK [BAN]

      If [F:FCT]FCTTYP>1
        Read [BAN]BAN0=[F:FCT]FCTBAN
        If fstat=[V]CST_AOK
          this.ETC.FACCRN=[F:BAN]CRN
        Endif
      Else
        If [F:FCT]BID<>""
          Filter [FCT] Where BID=[F:FCT]BID
          Read First
          If fstat=[V]CST_AOK
            this.ETC.FACCRN=[F:BAN]CRN
          Endif
        Endif
      Endif

      If this.ETC.FACCRN=""
        WSTATUS = [V]CST_AERROR
        WERR= toupper(mess(21,602,1))-[F:FCT]FCTCOD+"."-mess(192,2006,1) #  Bank tax ID number is empty
        Return
      Endif

      WTYP=mid$([F:BAN]CRN,1,1)
      If [F:BAN]CRY="ES"
        If (WTYP>="0" and WTYP<="9") or find(WTYP,"X","Y","K","L","M")
          this.ETC.FACPERTYP="F"
        Else
          this.ETC.FACPERTYP="J"
        Endif
      Else
        this.ETC.FACPERTYP="J"
      Endif

      If WTYP="X" or WTYP="N" or [F:BAN]CRY<>"ES"
        this.ETC.FACRESTYP="E"
      Else
        this.ETC.FACRESTYP="R"
      Endif

      WFCTIBAN  =[F:BAN]IBACOD
      WFCTCPTNUM=[F:BAN]BIDNUM
      WFCTBANCOD=left$([F:BAN]BIDNUM,4)
      WFCTBRACOD =mid$([F:BAN]BIDNUM,5,4)
      WFCTBANADD=vireblc([F:BAN]ADDLIG(0),5)-vireblc([F:BAN]ADDLIG(1),5)-vireblc([F:BAN]ADDLIG(2),5)
      WFCTBANCTY=[F:BAN]CTY
      WFCTBANSAT=[F:BAN]SAT
      WFCTBICCOD=[F:BAN]BICCOD
      If len(WFCTBICCOD)<>11: WFCTBICCOD="00000000000": Endif

      If [F:BAN]CRY="ES" or [F:BAN]CRY="ESP"
        WFCTBANCRY="ESP"
        WFCTBANPOS=[F:BAN]POSCOD
        If len(WFCTBANPOS)<>5: WFCTBANPOS="00000": Endif
      Else
        Local File TABCOUNTRY [TCY]
        Read [TCY]TCY0=[F:BAN]CRY
        If fstat=[V]CST_AOK
          If [F:TCY]ISOA3<>""
            WFCTBANCRY=[F:TCY]ISOA3
          Else
            WSTATUS = [V]CST_AERROR
            WERR=mess(1131,196,1) -[F:BAN]CRY+":"-mess(17,115,1)-"[F:TCY]ISOA3 ("-mess(1111,196,1)+")"- mess(23,147,1)     # Field [F:TCY]ISOA3 empty
            Return
          Endif
        Endif
        LogicClose File [TCY]
        WFCTBANCTYP= vireblc([F:BAN]POSCOD,5)-vireblc([F:BAN]CTY,5)
      Endif

      LogicClose File [BAN]
      this.ETC.FACNAM=[F:FCT]FCTNAM
      this.ETC.FACADDRES=vireblc([F:FCT]ADDFCT(0),5)-vireblc([F:FCT]ADDFCT(1),5)-vireblc([F:FCT]ADDFCT(2),5)
      this.ETC.FACCTY=[F:FCT]CTY
      this.ETC.FACSAT=[F:FCT]SAT
      WCRY=[F:FCT]CRY

      If [F:FCT]CRY="ES" or [F:FCT]CRY="ESP"
        this.ETC.FACPOSCOD=[F:FCT]POSCOD
        If len([F:FCT]POSCOD)<>5: this.ETC.FACPOSCOD="00000": Endif
        this.ETC.FACCRY="ESP"
      Else
        Local File TABCOUNTRY [TCY]
        Read [TCY]TCY0=[F:FCT]CRY
        If fstat=[V]CST_AOK
          If [F:TCY]ISOA3<>""
            this.ETC.FACCRY=[F:TCY]ISOA3
          Else
            WSTATUS = [V]CST_AERROR
            WERR=mess(1131,196,1) -[F:FCT]CRY+":"-mess(17,115,1)-"[F:TCY]ISOA3 ("-mess(1111,196,1)+")"- mess(23,147,1)     # Field [F:TCY]ISOA3 empty
            Return
          Endif
        Endif
        LogicClose File [TCY]
        this.ETC.FACCTYPOS= vireblc([F:FCT]POSCOD,5)-vireblc([F:FCT]CTY,5)
      Endif

      If this.ETC.FACPOSCOD<>""
        this.ETC.FACCNTCNAE=left$(this.ETC.FACPOSCOD,2)+"000"
      Else
        this.ETC.FACCNTCNAE=left$(this.ETC.FACCTYPOS,2)+"000"
      Endif
      If len(this.ETC.FACCNTCNAE)<>5: this.ETC.FACCNTCNAE="00000": Endif
      this.ETC.FACCNTTEL=[F:FCT]TEL
      this.ETC.FACCNTFAX=[F:FCT]FAX
      this.ETC.FACCNTWEB=[F:FCT]WEB
    Endif

    this.ETC.FACCLAUS=[F:FCT]TXTSBRGT-[F:FCT]TXTSBRGT(1)-[F:FCT]TXTSBRGT(2)-[F:FCT]TXTSBRGT(3)
    If vireblc(this.ETC.FACCLAUS,4)="" :this.ETC.FACCLAUS=mess(3,290,1) : Endif  #Factor

    LogicClose File [FCT]

    Local Char WFCTDAT (10)(30), WFCTPAM (5)(30), WFCTAMT (12)(30)
    Local Integer  WSTA (30)

    # Pending to review when we would trait more of one invoice by lot
    WSTA=func TRTFUNEDI.FACE_OPIT(this.ETC.SIV(WNB).NUM,WFCTDAT,1)
    WSTA=func TRTFUNEDI.FACE_OPIT(this.ETC.SIV(WNB).NUM,WFCTAMT,2)
    WSTA=func TRTFUNEDI.FACE_OPIT(this.ETC.SIV(WNB).NUM,WFCTPAM,3)

    Local File ASHWPAR [ASWP]   # Transcoding PAM (in STD table 233)
    Local Integer WFCSEQ
    For I=0 To 30
      If WFCTAMT(I)<>""
        WSEQ = fmet this.ETC.ADDLINE('C_FCT',[V]CST_ALASTPOS)
        this.ETC.C_FCT(WSEQ).FCTDAT =WFCTDAT(I)
        WPROP=format$("N:9.2#",WFCTAMT(I))
        this.ETC.C_FCT(WSEQ).FCTAMTCUR =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Filter [ASWP] Where CODREP=WREP and CODLNK="EDIPAM"
        Read First
        If fstat=[V]CST_AOK
          Local Char WTYP(20)
          Local Integer WTAB
          WTYP=WFCTPAM(I)
          WTAB=val([F:ASWP]VALEUR)
          this.ETC.C_FCT(WSEQ).FCTPAM=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
        Endif
        If this.ETC.C_FCT(WSEQ).FCTPAM="": this.ETC.C_FCT(WSEQ).FCTPAM="01" : Endif
        Filter [ASWP]

        this.ETC.C_FCT(WSEQ).FACIBAN   = WFCTIBAN
        this.ETC.C_FCT(WSEQ).FACCPTNUM = WFCTCPTNUM
        this.ETC.C_FCT(WSEQ).FACBANCOD = WFCTBANCOD
        this.ETC.C_FCT(WSEQ).FACBRACOD = WFCTBRACOD
        this.ETC.C_FCT(WSEQ).FACBANADD = WFCTBANADD
        this.ETC.C_FCT(WSEQ).FACBANCTY = WFCTBANCTY
        this.ETC.C_FCT(WSEQ).FACBANSAT = WFCTBANSAT
        this.ETC.C_FCT(WSEQ).FACBICCOD = WFCTBICCOD
        this.ETC.C_FCT(WSEQ).FACBANCRY = WFCTBANCRY
        this.ETC.C_FCT(WSEQ).FACBANPOS = WFCTBANPOS
        this.ETC.C_FCT(WSEQ).FACBANCTYP= WFCTBANCTYP
      Else
        Break
      Endif
    Next
    LogicClose File [ASWP]

  Endif

  ###############################
  # Filling Seller Party values #
  ###############################
  Local Char WCRYS(5), WCNT(15), WTYP(1)
  Local File COMPANY [CPY]
  Read [CPY]CPY0=this.ETC.SIV(WNB).CPY
  If fstat=[V]CST_AOK
    If [F:CPY]CRN=""
      WSTATUS = [V]CST_AERROR
      WERR= [F:CPY]CPY+"."-mess(153,2006,1) # Company tax ID number is empty
      Return
    Endif
    WCRY=[F:CPY]CRY

    Local File TABCOUNTRY [TCY]
    Read [TCY]TCY0=WCRY
    If fstat=[V]CST_AOK and [TCY]EECFLG=2
      WCRYS=WCRY
    Endif
    LogicClose File [TCY]

    WCNT=[F:CPY]CNTNAM
    this.ETC.CPYCRN =[F:CPY]CRN
    this.ETC.CPYNAME=[F:CPY]CPYNAM
    WTYP=mid$([F:CPY]CRN,1,1)
    If WCRY="ES"
      If (WTYP>="0" and WTYP<="9") or find(WTYP,"X","Y","K","L","M")
        this.ETC.PERSONTYPSE="F"
      Else
        this.ETC.PERSONTYPSE="J"
      Endif
    Else
      this.ETC.PERSONTYPSE="J"
    Endif
    If WTYP="X" or WTYP="N" or WCRY<>"ES"
      this.ETC.RESIDTYPSE="E"
    Else
      this.ETC.RESIDTYPSE="R"
    Endif
  Endif
  LogicClose File [CPY]

  Local File BPADDRESS [BPA]
  Filter [BPA] Where BPATYP=2 and BPANUM=this.ETC.SIV(WNB).CPY and BPAADDFLG=2
  Read First
  If fstat=[V]CST_AOK
    this.ETC.CPYADD   =vireblc([F:BPA]BPAADDLIG(0),5)-vireblc([F:BPA]BPAADDLIG(1),5)
    this.ETC.CPYCTY   =[F:BPA]CTY
    If WCRY="ES" or WCRY="ESP"
      this.ETC.CPYPOSCOD=[F:BPA]POSCOD
      If len([F:BPA]POSCOD)<>5: this.ETC.CPYPOSCOD="00000": Endif
      this.ETC.CPYCRY="ESP"
    Else
      this.ETC.CPYCTYPOS= vireblc([F:BPA]POSCOD,5)-vireblc([F:BPA]CTY,5)
      Local File TABCOUNTRY [TCY]
      Read [TCY]TCY0=WCRY
      If fstat=[V]CST_AOK
        If [F:TCY]ISOA3<>""
          this.ETC.CPYCRY=[F:TCY]ISOA3
        Else
          WSTATUS = [V]CST_AERROR
          WERR = mess(1131,196,1) -WCRY+":"-mess(17,115,1)-"[F:TCY]ISOA3 ("-mess(1111,196,1)+")"- mess(226,9151,1)     # Field [F:TCY]ISOA3. Incorrect value
          Return
        Endif
      Endif
      LogicClose File [TCY]
    Endif
    this.ETC.CPYSAT   =[F:BPA]SAT
    this.ETC.CPYTEL   =[F:BPA]TEL
    this.ETC.CPYFAX   =[F:BPA]FAX
    this.ETC.CPYWEB   =[F:BPA]FCYWEB
    this.ETC.CPYMAIL  =[F:BPA]WEB(0)

    Local File CONTACTCRM [AIN]
    Read[AIN]AIN0=WCNT
    If fstat=[V]CST_AOK
      this.ETC.CNTNAME  =[F:AIN]CNTFNA
      this.ETC.CNOCNAE  =left$(this.ETC.CPYPOSCOD,2)+"000"
      If len(this.ETC.CNOCNAE)<>5: this.ETC.CNOCNAE="00000": Endif
      this.ETC.CNTDETAIL=[F:AIN]CNTLNA
    Endif
  Endif
  LogicClose File [AIN], [BPA]

  ##############################
  # Filling Buyer Party values #
  ##############################
  Local Char WTYP(1)
  Local File BPARTNER [BPR]
  Read [BPR]BPR0=this.ETC.SIV(WNB).BPCORD
  If fstat=[V]CST_AOK
    If [F:BPR]CRN=""
      WSTATUS = [V]CST_AERROR
      WERR= [F:BPR]BPRNUM+"."-mess(193,2006,1) #  BP tax ID number is empty
      Return
    Endif

    this.ETC.BPRCRN =[F:BPR]CRN

    If WCRYS<>[F:BPR]CRY and WCRYS<>""
      Local File TABCOUNTRY [TCY]
      Read [TCY]TCY0=[F:BPR]CRY
      If fstat=[V]CST_AOK and [TCY]EECFLG=2
        this.ETC.BPRCRN =[F:BPR]CRY+[F:BPR]CRN
        this.ETC.CPYCRN =WCRYS+this.ETC.CPYCRN
      Endif
      LogicClose File [TCY]
    Endif

    WTYP=mid$([F:BPR]CRN,1,1)
    If [F:BPR]CRY="ES"
      If (WTYP>="0" and WTYP<="9") or find(WTYP,"X","Y","K","L","M")
        this.ETC.PERSONTYPBU="F"
      Else
        this.ETC.PERSONTYPBU="J"
      Endif
    Else
      this.ETC.PERSONTYPBU="J"
    Endif

    If WTYP="X" or WTYP="N" or [F:BPR]CRY<>"ES"
      this.ETC.RESIDTYPBU="E"
    Else
      this.ETC.RESIDTYPBU="R"
    Endif
  Endif
  LogicClose File [BPR]

  Local Integer WTAXID
  Local File EDIBPRPAR [EBP]    # Filling administrative centres collection
  Read [EBP]EBP0=1;this.ETC.SIV(WNB).BPCORD;this.ETC.SIV(WNB).BPAADD;WPARCOD
  If fstat=[V]CST_AOK
    Local Integer WCSEQ
    If val([F:EBP]EXCEDICOD)<>0 and len([F:EBP]EXCEDICOD)<11
      WTAXID=val([F:EBP]EXCEDICOD)
      If len(num$(WTAXID))=len([F:EBP]EXCEDICOD)
        this.ETC.BUYER=[F:EBP]EXCEDICOD
      Endif
    Endif

    For I=0 To 3
      If [F:EBP]CODE(I)<>""
        WCSEQ = fmet this.ETC.ADDLINE('C_EBPD',[V]CST_ALASTPOS)
        this.ETC.C_EBPD(WCSEQ).CENTROL ="0"+num$([F:EBP]CENROL(I))
        this.ETC.C_EBPD(WCSEQ).CENTCOD =[F:EBP]CODE(I)
        this.ETC.C_EBPD(WCSEQ).CENTDES =[F:EBP]DES(I)
        this.ETC.C_EBPD(WCSEQ).CENTPOSCOD = "00000"
        this.ETC.C_EBPD(WCSEQ).CENTADDRES = ""
        this.ETC.C_EBPD(WCSEQ).CENTCTY = ""
        this.ETC.C_EBPD(WCSEQ).CENTSAT = ""
        this.ETC.C_EBPD(WCSEQ).CENTCRY = "ESP"
       Endif
    Next
  Endif
  LogicClose File [EBP]

  If this.ETC.BUYER="" and val(this.ETC.SIV(WNB).BPCORD)<>0 and len(this.ETC.SIV(WNB).BPCORD)<11
    WTAXID=val(this.ETC.SIV(WNB).BPCORD)
    If len(num$(WTAXID))=len(this.ETC.SIV(WNB).BPCORD)
      this.ETC.BUYER=this.ETC.SIV(WNB).BPCORD
    Endif
  Endif

  Local File BPCUSTOMER [BPC]
  Read [BPC]BPC0=this.ETC.SIV(WNB).BPCORD
  If fstat=[V]CST_AOK
    WCNT=[F:BPC]CNTNAM
    If  this.ETC.PERSONTYPBU="J"
      this.ETC.BPCORDNAM =[F:BPC]BPCNAM
    Endif
  Endif
  LogicClose File [BPC]

  Local File BPADDRESS [BPA]
  Filter [BPA] Where BPATYP=1 and BPANUM=this.ETC.SIV(WNB).BPCORD and BPAADDFLG=2
  Read First
  If fstat=[V]CST_AOK
    this.ETC.BPCORDADD =vireblc([F:BPA]BPAADDLIG(0),5)-vireblc([F:BPA]BPAADDLIG(1),5)
    this.ETC.BPCORDCTY =[F:BPA]CTY
    WCRY =[F:BPA]CRY

    If WCRY="ES" or WCRY="ESP"
      this.ETC.BPCORDPOS=[F:BPA]POSCOD
      If len([F:BPA]POSCOD)<>5: this.ETC.BPCORDPOS="00000": Endif
      this.ETC.BPCORDCRY="ESP"
    Else
      this.ETC.BPCCTYPOS= vireblc([F:BPA]POSCOD,5)-vireblc([F:BPA]CTY,5)
      Local File TABCOUNTRY [TCY]
      Read [TCY]TCY0=WCRY
      If fstat=[V]CST_AOK
        If [F:TCY]ISOA3<>""
          this.ETC.BPCORDCRY=[F:TCY]ISOA3
        Else
          WSTATUS = [V]CST_AERROR
          WERR = mess(1131,196,1) -WCRY+":"-mess(17,115,1)-"[F:TCY]ISOA3 ("-mess(1111,196,1)+")"- mess(23,147,1)     # Field [F:TCY]ISOA3 empty
          Return
        Endif
      Endif
      LogicClose File [TCY]
    Endif
    this.ETC.BPCORDSAT =[F:BPA]SAT
    this.ETC.BPCTEL    =[F:BPA]TEL
    this.ETC.BPCFAX    =[F:BPA]FAX
    this.ETC.BPCWEB    =[F:BPA]FCYWEB
    this.ETC.BPCMAIL   =[F:BPA]WEB(0)
    this.ETC.BPCNOCNAE  =left$(this.ETC.BPCORDPOS,2)+"000"
    If len(this.ETC.BPCNOCNAE)<>5: this.ETC.BPCNOCNAE="00000": Endif

    Local File CONTACTCRM [AIN]
    Read[AIN]AIN0=WCNT
    If fstat=[V]CST_AOK
      If this.ETC.PERSONTYPBU="F"
        this.ETC.BPNAME   =[F:AIN]CNTFNA
        this.ETC.BPSURNAME=[F:AIN]CNTLNA
      Elsif this.ETC.PERSONTYPBU="J"
       this.ETC.BPCNAME  =vireblc([F:AIN]CNTFNA,5)-vireblc([F:AIN]CNTLNA,5)
      Endif
    Endif
    LogicClose File [AIN]
  Endif
  LogicClose File [BPA]

  ##########################
  # Filling Invoice values #
  ##########################
  Local Char TAXPER(10)
  Local Integer WMET
  Local Integer NBFAC: NBFAC=1    # For future use when a lot of invoices will be possible

  For WNB=1 To NBFAC
    this.ETC.SIV(WNB).INVTYPE="FC"
    If this.ETC.SIV(WNB).SIH(WNB).SNS=1
      this.ETC.SIV(WNB).INVSNS="OO"
      this.ETC.SENS=1       # It is used to apply the condition in XML file Validation (only work ok with properties in the head)
    Else
      this.ETC.SIV(WNB).INVSNS="OR"
      this.ETC.SENS=2       # It is used to apply the condition in XML file Validation (only work ok with properties in the head)
    Endif

    Local File ASHWPAR [ASWP]   # Transcoding EDICUR (in STD table 223)
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDICUR"
    Read First
    If fstat=[V]CST_AOK
      Local Char WNODE(20), WTYP(20)
      Local Integer WTAB
      WTYP=this.ETC.SIV(WNB).CUR
      WTAB=val([F:ASWP]VALEUR)
      WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
      this.ETC.SIV(WNB).EDISIVCUR= left$(WNODE,3)
    Endif
    If this.ETC.SIV(WNB).EDISIVCUR="": this.ETC.SIV(WNB).EDISIVCUR=this.ETC.SIV(WNB).CUR: Endif
    LogicClose File [ASWP]

    If this.ETC.SIV(WNB).INVSNS="OR"     # When credit memo
      Local File ASHWPAR [ASWP]
      # Transcoding RESCOD property (in STD table 232)
      Filter [ASWP] Where CODREP=WREP and CODLNK="RESCOD"
      Read First
      If fstat=[V]CST_AOK
        Local Char WNODE(20), WTYP(20)
        Local Integer WTAB
        WTYP=num$(this.ETC.SIV(WNB).CNOREN)
        If WTYP="": WTYP="010": Endif
        WTAB=val([F:ASWP]VALEUR)
        WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
        this.ETC.SIV(WNB).RESCOD= right$(WNODE,2)
      Endif
      LogicClose File [ASWP]

      If this.ETC.SIV(WNB).SIHORI=1: Raz this.ETC.SIV(WNB).RESCOD: this.ETC.SIV(WNB).SIH(WNB).METCOR=4: Endif

      If this.ETC.SIV(WNB).RESCOD="": this.ETC.SIV(WNB).RESCOD="10": Endif
      this.ETC.SIV(WNB).RESDES=func TRTFUNEDI.FACE_RESDES(this.ETC.SIV(WNB).RESCOD)

      If this.ETC.SIV(WNB).SIHORI=4
        Local File SINVOICE [SIH]
        Read [SIH]SIH0=this.ETC.SIV(WNB).SIHORINUM
        If fstat=[V]CST_AOK
          TAXPER=format$("D:YYYY[-]MM[-]DD",[F:SIH]ACCDAT)
        Endif
        LogicClose File [SIH]
      Endif
      If this.ETC.SIV(WNB).SIHORI=6
        Local File SRETURND [SRD]
        Filter [SRD] Where SRHNUM=this.ETC.SIV(WNB).SIHORINUM
        Read [SRD]SRD0 First
        If fstat=[V]CST_AOK
          Local File SDELIVERY [SDH]
          Read [SDH]SDH0=[F:SRD]SDHNUM
          If fstat=[V]CST_AOK
            Local File SINVOICE [SIH]
            Read [SIH]SIH0=[F:SDH]SIHNUM
            If fstat=[V]CST_AOK
              TAXPER=format$("D:YYYY[-]MM[-]DD",[F:SIH]ACCDAT)
            Else
              TAXPER=format$("D:YYYY[-]MM[-]DD",[F:SDH]DLVDAT)
            Endif
            LogicClose File [SIH]
          Endif
          LogicClose File [SDH]
          If TAXPER="":TAXPER=format$("D:YYYY[-]MM[-]DD",[F:SRD]RTNDAT): Endif
        Endif
      Endif

      If (this.ETC.SIV(WNB).RESDES="01" or this.ETC.SIV(WNB).RESDES="02") and this.ETC.SIV(WNB).SIHORINUM=""
        WERR = mess(9,119,1) # Credit memo without invoice number
      Endif

      this.ETC.SIV(WNB).SIVMETCOR="0"+num$(this.ETC.SIV(WNB).SIH(WNB).METCOR)
      WMET=val( this.ETC.SIV(WNB).SIVMETCOR)
      this.ETC.SIV(WNB).METCORDES= func TRTFUNEDI.FACE_TXTMETCOR(this.ETC.SIV(WNB).NUM,WMET,WLAN,WLEG)

      If (this.ETC.SIV(WNB).SIVMETCOR="01" or this.ETC.SIV(WNB).SIVMETCOR="02") and this.ETC.SIV(WNB).SIHORINUM=""
        WERR = mess(9,119,1) # Credit memo without invoice number
      Endif
      If WERR<>"": WSTATUS = [V]CST_AERROR: Return: Endif
    Endif

    this.ETC.SIV(WNB).ISSUEDAT=format$("D:YYYY[-]MM[-]DD",this.ETC.SIV(WNB).SIH(WNB).ACCDAT)

    If TAXPER="": TAXPER=format$("D:YYYY[-]MM[-]DD",this.ETC.SIV(WNB).SIH(WNB).ACCDAT): Endif
    this.ETC.SIV(WNB).STARTAXPER=TAXPER
    this.ETC.SIV(WNB).ENDTAXPER =TAXPER


    If this.ETC.SIV(WNB).SIHORI=3
      Local File SDELIVERY [SDH]
      Read [SDH]SDH0=this.ETC.SIV(WNB).SIHORINUM
      If fstat=[V]CST_AOK
        this.ETC.SIV(WNB).OPEDAT=format$("D:YYYY[-]MM[-]DD",[F:SDH]DLVDAT)
      Endif
      LogicClose File [SDH]
      If this.ETC.SIV(WNB).OPEDAT="": this.ETC.OPEDAT=this.ETC.ISSUEDAT: Endif
    Endif

    this.ETC.SIV(WNB).STARTINVPER=this.ETC.SIV(WNB).STARTAXPER
    this.ETC.SIV(WNB).ENDINVPER  =this.ETC.SIV(WNB).ENDTAXPER

    If maxtab(this.ETC.SIV(WNB).SIH(WNB).C_RATCOL)>0
      If this.ETC.VERSION="3.2"
        WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).C_RATCOL(1).RATMLT)
      Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SIH(WNB).C_RATCOL(1).RATMLT)
      Endif
      this.ETC.SIV(WNB).EDIRATMLT= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Else
      If this.ETC.VERSION="3.2" & WSEPDEC=","
        this.ETC.SIV(WNB).EDIRATMLT="1,00" Else this.ETC.SIV(WNB).EDIRATMLT="1.00"
      Endif
      If this.ETC.VERSION="3.2.1" & WSEPDEC=","
        this.ETC.SIV(WNB).EDIRATMLT="1,00" Else this.ETC.SIV(WNB).EDIRATMLT="1.00000000"
      Endif
      If this.ETC.VERSION="3.2.2" & WSEPDEC="," #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        this.ETC.SIV(WNB).EDIRATMLT="1,00" Else this.ETC.SIV(WNB).EDIRATMLT="1.00000000"
      Endif
    Endif
    this.ETC.SIV(WNB).EDIRATDAT=format$("D:YYYY[-]MM[-]DD",this.ETC.SIV(WNB).SIH(WNB).RATDAT)
    this.ETC.SIV(WNB).TAXCUR="EUR"
    this.ETC.SIV(WNB).LANDOC="es"

    Local Char WEXETAX(10), WIGIC(1)
    Local Decimal WPTAX
    Local Integer WTYPTAX, WSTATAX, WDIMSVV

    WEXETAX=fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY,this.ETC.SIV(WNB).SIH(WNB).FCY,"EXETAX")

    Local File FACILITY [FCY]
    Read [FCY]FCY0=this.ETC.SIV(WNB).SIH(WNB).FCY
    If fstat=[V]CST_AOK
      WIGIC=num$([F:FCY]SPAOPEIGIC)
    Endif
    LogicClose File [FCY]

    Local Decimal TOTBASTAX, TOTAMTTAX, TOTBASREQ, TOTAMTREQ, TOTAMTREQL
    Local Decimal TOTSPEBAS, TOTSPEAMT, TOTSPEBASL, TOTSPEAMTL, TOTGROAMT
    Local Decimal TOTWHGBAS, TOTWHGBASL, TOTWHGAMT, TOTWHGAMTL

    Local Integer WSVSEQ
    For I=1 To maxtab(this.ETC.SIV(WNB).SVV)
      Local File TABVAT [TVT]
      Read [TVT]TVT0=this.ETC.SIV(WNB).SVV(I).VAT;WLEG
      If fstat<>[V]CST_AOK
        Read [TVT]TVT0=this.ETC.SIV(WNB).SVV(I).VAT;""
        If fstat<>[V]CST_AOK
          Read [TVT]TVT0=WEXETAX
        Endif
      Endif

      WDIMSVV=maxtab(this.ETC.SIV(WNB).SVV)

      WTYPTAX=[F:TVT]VATTYP
      If WTYPTAX=2 and [F:TVT]VATVAC<>"REQ":  WTYPTAX=4:   Endif  # Special tax not equivalent surcharge
      LogicClose File [TVT]

      If this.ETC.SIV(WNB).SVV(I).VAT<> WEXETAX
        If this.ETC.SIV(WNB).SIH(WNB).CUR<>"EUR"
          If this.ETC.VERSION="3.2"
            WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).C_RATCOL(1).RATMLT)
          Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
            WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SIH(WNB).C_RATCOL(1).RATMLT)
          Endif
          this.ETC.SIV(WNB).EDIRATMLT= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Else
          If this.ETC.VERSION="3.2"
            WPROP=format$("N:9.2#",1)
          Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
            WPROP=format$("N:9.8#",1)
          Endif
          this.ETC.SIV(WNB).EDIRATMLT =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Endif

        If WTYPTAX=1 or WTYPTAX=4
          WSVSEQ = fmet this.ETC.SIV(WNB).ADDLINE('C_SVV',[V]CST_ALASTPOS)

          If WIGIC<>"2"
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).TAXTYP="01"
          Else
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).TAXTYP="03"
          Endif

          If this.ETC.VERSION="3.2"
            WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATNET)
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAX= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
              WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATNET*val(this.ETC.SIV(WNB).EDIRATMLT))
              this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAXL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            Endif
            WPROP=format$("N:3.2#", this.ETC.SIV(WNB).SVV(I).VATRAT)
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIVATRAT= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATAMT)
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAX    =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
              WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATAMT*val(this.ETC.SIV(WNB).EDIRATMLT))
              this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAXL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            Endif
          Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
            WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SVV(I).VATNET)
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAX= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
              WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATNET*val(this.ETC.SIV(WNB).EDIRATMLT))
              this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAXL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATAMT*val(this.ETC.SIV(WNB).EDIRATMLT))
              this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAXL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            Endif
            WPROP=format$("N:3.8#", this.ETC.SIV(WNB).SVV(I).VATRAT)
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIVATRAT= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SVV(I).VATAMT)
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAX    =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          Endif

          If WTYPTAX=1
            TOTBASTAX+=val(this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAX)
            TOTAMTTAX+=val(this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAX)
          Endif
        Endif

        If this.ETC.SIV(WNB).SVV(I).BASTAX<>this.ETC.SIV(WNB).SVV(I).VATNET and WTYPTAX=1
          WSVSEQ = fmet this.ETC.SIV(WNB).ADDLINE('C_SVV',[V]CST_ALASTPOS)
          this.ETC.SIV(WNB).C_SVV(WSVSEQ).TAXTYP    =this.ETC.SIV(WNB).C_SVV(WSVSEQ-1).TAXTYP
          this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIVATRAT= this.ETC.SIV(WNB).C_SVV(WSVSEQ-1).EDIVATRAT
          If this.ETC.VERSION="3.2"
            WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).BASTAX-this.ETC.SIV(WNB).SVV(I).VATNET)
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAX =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            WPROP=format$("N:9.2#", this.ETC.SIV(WNB).SVV(I).AMTTAX-this.ETC.SIV(WNB).SVV(I).VATAMT)
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAX    =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
              WPROP=format$("N:9.2#",val(this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAX)*val(this.ETC.SIV(WNB).EDIRATMLT))
              this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAXL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N:9.2#",val(this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAX)*val(this.ETC.SIV(WNB).EDIRATMLT))
              this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAXL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            Endif
          Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
            WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SVV(I).BASTAX-this.ETC.SIV(WNB).SVV(I).VATNET)
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAX= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SVV(I).AMTTAX-this.ETC.SIV(WNB).SVV(I).VATAMT)
            this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAX    =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
              WPROP=format$("N:9.2#",val(this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAX)*val(this.ETC.SIV(WNB).EDIRATMLT))
              this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAXL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATAMT*val(this.ETC.SIV(WNB).EDIRATMLT))
              this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAXL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            Endif
          Endif
          TOTBASTAX+=val(this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASTAX)
          TOTAMTTAX+=val(this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTTAX)
        Endif


        Case WTYPTAX
        When 2:
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATRAT)
                this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASREC= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATAMT)
                this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTREC= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              Elsif  this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATRAT)
                this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIBASREC= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SVV(I).VATAMT)
                this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTREC= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              Endif

#              TOTBASREQ+=this.ETC.SIV(WNB).SVV(I).VATNET
              TOTAMTREQ+=this.ETC.SIV(WNB).SVV(I).VATAMT
              TOTAMTREQL+=this.ETC.SIV(WNB).SVV(I).VATAMT*val(this.ETC.SIV(WNB).EDIRATMLT)

              If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
                WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).VATAMT*val(this.ETC.SIV(WNB).EDIRATMLT))
                this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDIAMTRECL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              Endif
        When 3:

        Local Integer WSWSEQ
        WSWSEQ = fmet this.ETC.SIV(WNB).ADDLINE('C_SVW',[V]CST_ALASTPOS)
        this.ETC.SIV(WNB).C_SVW(WSWSEQ).TAXTYPW="05"

        If this.ETC.VERSION="3.2"
          WPROP=format$("N:9.2#",abs(this.ETC.SIV(WNB).SVV(I).BASTAX))
          this.ETC.SIV(WNB).C_SVW(WSWSEQ).EDIBASRET= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          WPROP=format$("N:9.2#",abs(this.ETC.SIV(WNB).SVV(I).AMTTAX))
          this.ETC.SIV(WNB).C_SVW(WSWSEQ).EDIAMTRET= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          WPROP=format$("N:3.2#",abs(this.ETC.SIV(WNB).SVV(I).VATRAT))
          this.ETC.SIV(WNB).C_SVW(WSWSEQ).EDIVATRATW= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Elsif  this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
          WPROP=format$("N:9.8#",abs(this.ETC.SIV(WNB).SVV(I).BASTAX))
          this.ETC.SIV(WNB).C_SVW(WSWSEQ).EDIBASRET= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          WPROP=format$("N:9.8#",abs(this.ETC.SIV(WNB).SVV(I).AMTTAX))
          this.ETC.SIV(WNB).C_SVW(WSWSEQ).EDIAMTRET= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          WPROP=format$("N:3.8#",abs(this.ETC.SIV(WNB).SVV(I).VATRAT))
          this.ETC.SIV(WNB).C_SVW(WSWSEQ).EDIVATRATW= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Endif
        If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
          WPROP=format$("N:9.2#",abs(this.ETC.SIV(WNB).SVV(I).BASTAX)*val(this.ETC.SIV(WNB).EDIRATMLT))
          this.ETC.SIV(WNB).C_SVW(WSWSEQ).EDIBASRETL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          WPROP=format$("N:9.2#",abs(this.ETC.SIV(WNB).SVV(I).AMTTAX)*val(this.ETC.SIV(WNB).EDIRATMLT))
          this.ETC.SIV(WNB).C_SVW(WSWSEQ).EDIAMTRETL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Endif

        TOTWHGBAS+=abs(this.ETC.SIV(WNB).SVV(I).BASTAX)
        TOTWHGBASL+=abs(this.ETC.SIV(WNB).SVV(I).BASTAX)*val(this.ETC.SIV(WNB).EDIRATMLT)
        TOTWHGAMT+=abs(this.ETC.SIV(WNB).SVV(I).AMTTAX)
        TOTWHGAMTL+=abs(this.ETC.SIV(WNB).SVV(I).AMTTAX)*val(this.ETC.SIV(WNB).EDIRATMLT)

        When 4:
        If this.ETC.VERSION="3.2"
          WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).BASTAX)
          this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDISPEBAS= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).AMTTAX)
          this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDISPEAMT= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Elsif  this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
          WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SVV(I).BASTAX)
          this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDISPEBAS= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SVV(I).AMTTAX)
          this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDISPEAMT= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Endif
        If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
          WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).BASTAX*val(this.ETC.SIV(WNB).EDIRATMLT))
          this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDISPEBASL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SVV(I).AMTTAX*val(this.ETC.SIV(WNB).EDIRATMLT))
          this.ETC.SIV(WNB).C_SVV(WSVSEQ).EDISPEAMTL= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Endif

        TOTSPEBAS+=this.ETC.SIV(WNB).SVV(I).BAXTAX
        TOTSPEBASL+=this.ETC.SIV(WNB).SVV(I).BASTAX*val(this.ETC.SIV(WNB).EDIRATMLT)
        TOTSPEAMT+=this.ETC.SIV(WNB).SVV(I).AMTTAX
        TOTSPEAMTL+=this.ETC.SIV(WNB).SVV(I).AMTTAX*val(this.ETC.SIV(WNB).EDIRATMLT)
        Endcase

        TOTGROAMT+=this.ETC.SIV(WNB).SVV(I).VATGRO
      Endif

    Next

    If this.ETC.VERSION="3.2"
      WPROP=format$("N:9.2#",TOTGROAMT)
    Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
      WPROP=format$("N:9.8#",TOTGROAMT)
    Endif
    this.ETC.SIV(WNB).EDITOTGRO= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

    # Filling discounts
    Local File SFOOTINV [SFI]
    Local Decimal DISTOT
    Local Integer WSFSEQ

    For I=1 To maxtab(this.ETC.SIV(WNB).SVF)
      If (this.ETC.SIV(WNB).SVF(I).VCRTYP=4 or this.ETC.SIV(WNB).SVF(I).VCRTYP=18 or this.ETC.SIV(WNB).SVF(I).VCRTYP=19) and this.ETC.SIV(WNB).SVF(I).DTANOT<0
        Read [SFI]SFI0=this.ETC.SIV(WNB).SVF(I).DTA
        If fstat=[V]CST_AOK and this.ETC.SIV(WNB).SVF(I).DTANOT<0  and !find(I,DTARET())
          WSFSEQ = fmet this.ETC.SIV(WNB).ADDLINE('C_SVFD',[V]CST_ALASTPOS)
          Local File ATEXTRA [AXX]
          Read [AXX]AXX0="SFOOTINV";"DESAXX";WLAN;num$(this.ETC.SIV(WNB).SVF(I).DTA)
          If fstat=[V]CST_AOK
            this.ETC.SIV(WNB).C_SVFD(WSFSEQ).DISCRES=[F:AXX]TEXTE
          Endif
          LogicClose File [AXX]
          If this.ETC.SIV(WNB).SVF(I).AMTCOD=1
            If this.ETC.SIV(WNB).SVF(I).C_DTAVAT(1).DTAVAT<>WEXETAX
              WPROP=format$("N:2.4#",this.ETC.SIV(WNB).SVF(I).DTAAMT)
              this.ETC.SIV(WNB).C_SVFD(WSFSEQ).DISCRAT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            Endif
          Endif
          DISTOT+=-this.ETC.SIV(WNB).SVF(I).DTANOT
          If this.ETC.VERSION="3.2"
            WPROP=format$("N:9.6#",-this.ETC.SIV(WNB).SVF(I).DTANOT)
          Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
            WPROP=format$("N:9.8#",-this.ETC.SIV(WNB).SVF(I).DTANOT)
          Endif
          this.ETC.SIV(WNB).C_SVFD(WSFSEQ).DISCAMT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Endif
      Endif
    Next
    LogicClose File [SFI]

    WPROP=format$("N:9.2#",TOTWHGAMT)
    this.ETC.SIV(WNB).TOTRETAMTH= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

    DISTOT=DISTOT

    If DISTOT<>0
      If this.ETC.VERSION="3.2"
        WPROP=format$("N:9.2#",DISTOT)
      Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:9.8#",DISTOT)
      Endif
      this.ETC.SIV(WNB).DISCTOT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Endif


    # Filling charges
    Local File SFOOTINV [SFI]
    Local Decimal CHARTOT
    Raz WSFSEQ

    For I=1 To maxtab(this.ETC.SIV(WNB).SVF)
      If (this.ETC.SIV(WNB).SVF(I).VCRTYP=4 or this.ETC.SIV(WNB).SVF(I).VCRTYP=18 or this.ETC.SIV(WNB).SVF(I).VCRTYP=19) and this.ETC.SIV(WNB).SVF(I).DTANOT>0
        Read [SFI]SFI0=this.ETC.SIV(WNB).SVF(I).DTA
        If fstat=[V]CST_AOK and this.ETC.SIV(WNB).SVF(I).DTANOT>0 and !find(I,DTARET())
          WSFSEQ = fmet this.ETC.SIV(WNB).ADDLINE('C_SVF',[V]CST_ALASTPOS)
          Local File ATEXTRA [AXX]
          Read [AXX]AXX0="SFOOTINV";"DESAXX";WLAN;num$(this.ETC.SIV(WNB).SVF(I).DTA)
          If fstat=[V]CST_AOK
            this.ETC.SIV(WNB).C_SVF(WSFSEQ).CHARGRES=[F:AXX]TEXTE
          Endif
          LogicClose File [AXX]
          If this.ETC.SIV(WNB).SVF(I).AMTCOD=1
            If this.ETC.SIV(WNB).SVF(I).DTAAMT<>0
              WPROP=format$("N:2.4#",this.ETC.SIV(WNB).SVF(I).DTAAMT)
              this.ETC.SIV(WNB).C_SVF(WSFSEQ).CHARGRAT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
            Endif
          Endif
          CHARTOT+=this.ETC.SIV(WNB).SVF(I).DTANOT
          If this.ETC.VERSION="3.2"
            WPROP=format$("N:9.6#",this.ETC.SIV(WNB).SVF(I).DTANOT)
          Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
            WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SVF(I).DTANOT)
          Endif
          this.ETC.SIV(WNB).C_SVF(WSFSEQ).CHARGAMT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Endif
      Endif
    Next
    LogicClose File [SFI]

    If CHARTOT<>0
      If this.ETC.VERSION="3.2"
        WPROP=format$("N:9.2#",CHARTOT)
      Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:9.8#",CHARTOT)
      Endif
      this.ETC.SIV(WNB).CHARGTOT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Endif

    If this.ETC.VERSION="3.2"
      WPROP=format$("N:9.2#",num$(val(this.ETC.SIV(WNB).EDITOTGRO)-DISTOT+CHARTOT))
    Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
      WPROP=format$("N:9.8#",num$(val(this.ETC.SIV(WNB).EDITOTGRO)-DISTOT+CHARTOT))
    Endif
    this.ETC.SIV(WNB).TOTGROAMT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

    If this.ETC.VERSION="3.2"
      WPROP=format$("N:9.2#",TOTAMTTAX+TOTSPEAMT+TOTAMTREQ)
    Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
      WPROP=format$("N:9.8#",TOTAMTTAX+TOTSPEAMT+TOTAMTREQ)
    Endif

    this.ETC.SIV(WNB).TOTTAXAMT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

    If this.ETC.VERSION="3.2"
      WPROP=format$("N:9.2#",num$(val(this.ETC.SIV(WNB).TOTGROAMT)+TOTAMTTAX+TOTSPEAMT+TOTAMTREQ-TOTWHGAMT))
    Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
      WPROP=format$("N:9.8#",num$(val(this.ETC.SIV(WNB).TOTGROAMT)+TOTAMTTAX+TOTSPEAMT+TOTAMTREQ-TOTWHGAMT))
    Endif
    this.ETC.SIV(WNB).TOTNETAMT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

    #Filling Payments on account
    Local Decimal TOTPAYON

    For I=1 To maxtab(this.ETC.SIV(WNB).C_PAM)
      If this.ETC.SIV(WNB).C_PAM(I).INSATI=0: Break: Endif
      Local Integer WPSEQ
      WPSEQ = fmet this.ETC.SIV(WNB).ADDLINE('C_PAM',[V]CST_ALASTPOS)
      this.ETC.SIV(WNB).C_PAM(WPSEQ).INSATIDAT=format$("D:YYYY[-]MM[-]DD",this.ETC.SIV(WNB).SIH(WNB).ACCDAT)
      If this.ETC.VERSION="3.2" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:9.2#",this.ETC.SIV(WNB).C_PAM(I).INSATI)
      Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:9.8#",this.ETC.SIV(WNB).C_PAM(I).INSATI)
      Endif
      this.ETC.SIV(WNB).C_PAM(WPSEQ).INSATIAMT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      TOTPAYON+=this.ETC.SIV(WNB).C_PAM(I).INSATI
    Next

    If TOTPAYON<>0
      If this.ETC.VERSION="3.2"
        WPROP=format$("N:9.2#",TOTPAYON)
      Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:9.8#",TOTPAYON)
      Endif
      this.ETC.SIV(WNB).TOTINSAMT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Endif

    If this.ETC.VERSION="3.2"
      WPROP=format$("N:9.2#",num$(val(this.ETC.SIV(WNB).TOTNETAMT)-TOTPAYON))
    Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
      WPROP=format$("N:9.8#",num$(val(this.ETC.SIV(WNB).TOTNETAMT)-TOTPAYON))
    Endif
    this.ETC.SIV(WNB).TOTOUTAMT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

    #Filling Retentions
    If RETENF<>0
      this.ETC.SIV(WNB).RETDES=mess(3,232,1)  # Retentions

      If this.ETC.VERSION="3.2"
        WPROP=format$("N:9.2#",RETENF)
      Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:9.8#",RETENF)
      Endif
      this.ETC.SIV(WNB).TOTRETAMT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

      If val(this.ETC.SIV(WNB).TOTNETAMT)<>0
        If this.ETC.VERSION="3.2"
          WPROP=format$("N:9.4#",(RETENF*100)/val(this.ETC.SIV(WNB).TOTNETAMT))
        Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
          WPROP=format$("N:9.8#",(RETENF*100)/val(this.ETC.SIV(WNB).TOTNETAMT))
        Endif
      Endif
      this.ETC.SIV(WNB).RETPER=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Endif

    If this.ETC.VERSION="3.2"
      WPROP=format$("N:9.2#",num$(val(this.ETC.SIV(WNB).TOTOUTAMT)-RETENF))
#      WPROP=format$("N:9.2#",this.ETC.SIV(WNB).SIH(WNB).AMTATI)
    Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
      WPROP=format$("N:9.8#",num$(val(this.ETC.SIV(WNB).TOTOUTAMT)-RETENF))
#      WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SIH(WNB).AMTATI)
    Endif
    this.ETC.SIV(WNB).TOTEXEAMT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

    #####################################
    #####          LINES          #######
    #####################################
    # Filling Items values   #
    For I=1 To maxtab(this.ETC.SIV(WNB).SID)
      this.ETC.SIV(WNB).SID(I).EDISIDLIN=num$(I)
      If this.ETC.SIV(WNB).SID(I).SOHNUM<>""
        Local File SORDER [SOH]
        Read [SOH]SOH0=this.ETC.SIV(WNB).SID(I).SOHNUM
        If fstat=[V]CST_AOK
          this.ETC.SIV(WNB).SID(I).EDIORDCUS=[F:SOH]CUSORDREF
          this.ETC.SIV(WNB).SID(I).EDIORDDAT=format$("D:YYYY[-]MM[-]DD",[F:SOH]ORDDAT) #X3-62949
        Endif
        LogicClose File [SOH]
      Endif
      If this.ETC.SIV(WNB).SID(I).SDHNUM<>""
        Local File SDELIVERY [SDH]
        Read [SDH]SDH0=this.ETC.SIV(WNB).SID(I).SDHNUM
        If fstat=[V]CST_AOK
          Local Integer WNSDH
           WNSDH = fmet this.ETC.SIV(WNB).SID(I).ADDLINE('C_SDH',[V]CST_ALASTPOS)
           this.ETC.SIV(WNB).SID(I).C_SDH(WNSDH).EDISDHNUM=[F:SDH]SDHNUM
           this.ETC.SIV(WNB).SID(I).C_SDH(WNSDH).EDISDHDAT=format$("D:YYYY[-]MM[-]DD",[F:SDH]DLVDAT)
        Endif
        LogicClose File [SDH]
      Endif

      WPROP=format$("N:9.6#",this.ETC.SIV(WNB).SID(I).QTY)
      this.ETC.SIV(WNB).SID(I).EDIQTY=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

      # Transcoding EDISAU  properties (in STD table 228)
      Local File ASHWPAR [ASWP]
      Filter [ASWP] Where CODREP=WREP and CODLNK="EDISAU"
      Read First
      If fstat=[V]CST_AOK
        Local Char WNODE(20), WTYP(20)
        Local Integer WTAB
        WTYP=num$(this.ETC.SIV(WNB).SID(I).SAU)
        WTAB=val([F:ASWP]VALEUR)
        WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
        this.ETC.SIV(WNB).SID(I).EDISAU= left$(WNODE,3)
        If val(this.ETC.SIV(WNB).SID(I).EDISAU)=0 : this.ETC.SIV(WNB).SID(I).EDISAU="01" : Endif
      Endif
      LogicClose File [ASWP]

      If this.ETC.VERSION="3.2"
        WPROP=format$("N:9.6#",this.ETC.SIV(WNB).SID(I).GROPRI)
      Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SID(I).GROPRI)
      Endif
      this.ETC.SIV(WNB).SID(I).EDIGROPRI=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

      # Filling discounts lines
      Local Char WTDIS(80)(9), WTCHG(80)(9), WDIS(16)(9), WDISRAT(14)(9), WCHG(16)(9), WCHGRAT(14)(9)
      Local Decimal TOTALN
      Local Integer WNSEQ, WNCSEQ

      Gosub CALCULATE_DIS_CHAR_LINES

      For X=0 To 8
        If WDIS(X)="" and WCHG(X)="": Break: Endif
        If val(WDIS(X))<>0
          WNSEQ = fmet this.ETC.SIV(WNB).SID(I).ADDLINE('C_DTA',[V]CST_ALASTPOS)
          this.ETC.SIV(WNB).SID(I).C_DTA(WNSEQ).DISCDESL =WTDIS(X)
          this.ETC.SIV(WNB).SID(I).C_DTA(WNSEQ).DISCRATL =WDISRAT(X)
          If this.ETC.VERSION="3.2"
            WPROP=format$("N:9.6#",WDIS(X))
          Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
            WPROP=format$("N:9.8#",WDIS(X))
          Endif
          this.ETC.SIV(WNB).SID(I).C_DTA(WNSEQ).DISCAMTL =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Elsif val(WCHG(X))<>0
          WNCSEQ = fmet this.ETC.SIV(WNB).SID(I).ADDLINE('C_CDTA',[V]CST_ALASTPOS)
          this.ETC.SIV(WNB).SID(I).C_CDTA(WNCSEQ).CHARGDESL=WTCHG(X)
          this.ETC.SIV(WNB).SID(I).C_CDTA(WNCSEQ).CHARGRATL=WCHGRAT(X)
          If this.ETC.VERSION="3.2"
            WPROP=format$("N:9.6#",WCHG(X))
          Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
            WPROP=format$("N:9.8#",WCHG(X))
          Endif
          this.ETC.SIV(WNB).SID(I).C_CDTA(WNCSEQ).CHARGAMTL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        Endif
      Next

      If this.ETC.VERSION="3.2"
        WPROP=format$("N:9.6#",this.ETC.SIV(WNB).SID(I).AMTNOTLIN)
      Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:9.8#",this.ETC.SIV(WNB).SID(I).AMTNOTLIN)
      Endif
      this.ETC.SIV(WNB).SID(I).GROAMTLIN=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

      If val(this.ETC.SIV(WNB).SID(I).EDIGROPRI)=0 and val(this.ETC.SIV(WNB).SID(I).GROAMTLIN)<>0
        Local Decimal WRESUL, WTOTCOST
        WRESUL=val(this.ETC.SIV(WNB).SID(I).GROAMTLIN)/this.ETC.SIV(WNB).SID(I).QTY
        If this.ETC.VERSION="3.2"
          WPROP=format$("N:9.6#",WRESUL)
        Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
          WPROP=format$("N:9.8#",WRESUL)
        Endif
        this.ETC.SIV(WNB).SID(I).EDIGROPRI=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        WTOTCOST=val(this.ETC.SIV(WNB).SID(I).GROAMTLIN)
        If this.ETC.VERSION="3.2"
          WPROP=format$("N:9.6#",WTOTCOST)
        Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
          WPROP=format$("N:9.8#",WTOTCOST)
        Endif
        this.ETC.SIV(WNB).SID(I).TOTCOST=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      Endif

      Local Integer NBVATSQ
      NBVATSQ = fmet this.ETC.SIV(WNB).SID(I).ADDLINE('C_VATL',[V]CST_ALASTPOS)

      If WIGIC<>"2"
        this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).TAXTYPL="01"
      Else
        this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).TAXTYPL="03"
      Endif

      If this.ETC.VERSION="3.2"
        WPROP=format$("N:3.2#",arr(this.ETC.SIV(WNB).SID(I).RATTAXLIN,0.01))
      Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:3.8#",arr(this.ETC.SIV(WNB).SID(I).RATTAXLIN,0.0001))
      Endif
      this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIRATTAXL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

      If this.ETC.VERSION="3.2"
        WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).AMTNOTLIN,0.01))
      Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
        WPROP=format$("N:9.8#",arr(this.ETC.SIV(WNB).SID(I).AMTNOTLIN,0.0001))
      Endif
      this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIAMTNOTLIN=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
        WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).AMTNOTLIN*this.ETC.SIV(WNB).SID(I).RATTAXLIN,0.01))
        this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIAMTNOTLIL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      Endif

      If maxtab(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN)>0
        If this.ETC.VERSION="3.2"
          WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN.AMTTAXLIN,0.01))
        Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
          WPROP=format$("N:9.8#",arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN.AMTTAXLIN,0.0001))
        Endif
      Else
        If this.ETC.VERSION="3.2"
          WPROP=format$("N:9.2#",0)
        Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
          WPROP=format$("N:9.8#",0)
        Endif
      Endif
      this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIAMTTAXLIN=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

      If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
        WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN.AMTTAXLIN*this.ETC.SIV(WNB).SID(I).RATTAXLIN,0.01))
        this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIAMTTAXLIL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      Endif
      If maxtab(this.ETC.SIV(WNB).SID(I).C_VAT)>1
        For H=2 To maxtab(this.ETC.SIV(WNB).SID(I).C_VAT)
          Local Decimal BASREQ, AMTREQ
          If this.ETC.SIV(WNB).SID(I).C_VAT(H).VAT<>""
            Local File TABVAT [TVT]
            Read [TVT]TVT0=this.ETC.SIV(WNB).SID(I).C_VAT(H).VAT;WLEG
            If fstat=[V]CST_AOK
              WTYPTAX=[F:TVT]VATTYP
              If WTYPTAX=2 and [F:TVT]VATVAC<>"REQ": WTYPTAX=4: Endif
            Endif
            LogicClose File [TVT]

            Local File TABRATVAT  [TRA]
            Filter [TRA] Where VAT=this.ETC.SIV(WNB).SID(I).C_VAT(H).VAT and CPY=this.ETC.SIV(WNB).SIH(WNB).CPY and STRDAT<=this.ETC.SIV(WNB).SIH(WNB).ACCDAT
            Read [TRA]TRA0 Last
            If fstat<>[V]CST_AOK
              Filter [TRA] Where VAT=this.ETC.SIV(WNB).SID(I).C_VAT(H).VAT and CPY="" and STRDAT<=this.ETC.SIV(WNB).SIH(WNB).ACCDAT
              Read [TRA]TRA0 Last
              If fstat=[V]CST_AOK
                If this.ETC.VERSION="3.2"
                  WPROP=format$("N:9.2#",[F:TRA]VATRAT)
                Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                  WPROP=format$("N:9.8#",[F:TRA]VATRAT)
                Endif
                Case WTYPTAX
                When 2:
                  WPROP=format$("N:9.2#",[F:TRA]VATRAT)
                  this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIBRECTAXL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                When 3:
                  Local Decimal WRATTAXW
                  WRATTAXW=val(WPROP)
                When Default
                  this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIRATTAXL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Endcase
              Endif
            Endif
            LogicClose File [TRA]

            If this.ETC.SIV(WNB).SID(I).C_VAT(H).VAT<>"" and maxtab(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN)>1
              BASREQ+=this.ETC.SIV(WNB).SID(I).AMTNOTLIN
              AMTREQ+=this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN

              Case WTYPTAX
                When 2: # Equivalence surcharge
                If this.ETC.VERSION="3.2"
                  WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN,0.01))
                Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                  WPROP=format$("N:9.8#",arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN,0.0001))
                Endif
                this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIARECTAXL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
                  WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN*this.ETC.SIV(WNB).SID(I).RATTAXLIN,0.01))
                  this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIARECTAXLL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Endif

                When 3:  # Withheld Taxes
                Local Integer WSVWSEQ
                WSVWSEQ = fmet this.ETC.SIV(WNB).SID(I).ADDLINE('C_VATW',[V]CST_ALASTPOS)
                If WIGIC<>"2"
                  this.ETC.SIV(WNB).SID(I).C_VATW(WSVWSEQ).TAXTYPLW="05"
                Else
                  this.ETC.SIV(WNB).SID(I).C_VATW(WSVWSEQ).TAXTYPLW="03"
                Endif
                If this.ETC.VERSION="3.2"
                  WPROP=format$("N:3.2#",abs(WRATTAXW))
                Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                  WPROP=format$("N:3.8#",abs(WRATTAXW))
                Endif
                this.ETC.SIV(WNB).SID(I).C_VATW(WSVWSEQ).EDIRATTAXLW=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                If this.ETC.VERSION="3.2"
                  WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).AMTNOTLIN,0.01))
                Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                  WPROP=format$("N:9.8#",arr(this.ETC.SIV(WNB).SID(I).AMTNOTLIN,0.0001))
                Endif
                this.ETC.SIV(WNB).SID(I).C_VATW(WSVWSEQ).EDIBRETTAXL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
                  WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN*this.ETC.SIV(WNB).SID(I).RATTAXLIN,0.01))
                  this.ETC.SIV(WNB).SID(I).C_VATW(WSVWSEQ).EDIBRETTAXLL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Endif
                If this.ETC.VERSION="3.2"
                  WPROP=format$("N:9.2#",abs(arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN,0.01)))
                Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                  WPROP=format$("N:9.8#",abs(arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN,0.0001)))
                Endif

                this.ETC.SIV(WNB).SID(I).C_VATW(WSVWSEQ).EDIARETTAXL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
                  WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN*this.ETC.SIV(WNB).SID(I).RATTAXLIN,0.01))
                  this.ETC.SIV(WNB).SID(I).C_VATW(WSVWSEQ).EDIARETTAXLL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Endif

                When 4: # Special taxes

                If this.ETC.VERSION="3.2"
                  WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).AMTNOTLIN,0.01))
                Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                  WPROP=format$("N:9.8#",arr(this.ETC.SIV(WNB).SID(I).AMTNOTLIN,0.0001))
                Endif
                this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIBSPETAXL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
                  WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN*this.ETC.SIV(WNB).SID(I).RATTAXLIN,0.01))
                  this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIBSPETAXLL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Endif
                If this.ETC.VERSION="3.2"
                  WPROP=format$("N:9.2#",abs(arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN,0.01)))
                Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                  WPROP=format$("N:9.8#",abs(arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN,0.0001)))
                Endif
                this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIASPETAXL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                If this.ETC.SIV(WNB).TAXCUR<>this.ETC.SIV(WNB).SIH(WNB).CUR
                  WPROP=format$("N:9.2#",arr(this.ETC.SIV(WNB).SID(I).C_AMTTAXLIN(H).AMTTAXLIN*this.ETC.SIV(WNB).SID(I).RATTAXLIN,0.01))
                  this.ETC.SIV(WNB).SID(I).C_VATL(NBVATSQ).EDIASPETAXLL=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Endif
              Endcase
            Endif
          Endif
        Next
      Endif

      Local File ITMBPC [ITU]
      Read [ITU]ITU0=this.ETC.SIV(WNB).SID(I).ITMREF;this.ETC.SIV(WNB).SIH(WNB).BPR
      If fstat=[V]CST_AOK
        this.ETC.SIV(WNB).SID(I).REFITMBPC=mid$([F:ITU]ITMREFBPC,1,20)
      Else
        this.ETC.SIV(WNB).SID(I).REFITMBPC=mid$(this.ETC.SIV(WNB).SID(I).ITMREF,1,20)
      Endif
      LogicClose File [ITU]
    Next


    ###########################
    # Filling Payments values #
    ###########################
    Local Char WDUDDAT (10)(30), WDUDPAM (5)(30), WDUDAMT (12)(30)
    Local Integer  WSTA (30)

    WSTA=func TRTFUNEDI.FACE_OPIT(this.ETC.SIV(WNB).NUM,WDUDDAT,1)
    WSTA=func TRTFUNEDI.FACE_OPIT(this.ETC.SIV(WNB).NUM,WDUDAMT,2)
    WSTA=func TRTFUNEDI.FACE_OPIT(this.ETC.SIV(WNB).NUM,WDUDPAM,3)

    Local File ASHWPAR [ASWP]   # Transcoding PAM (in STD table 233)
    Local Integer WDSEQ

    For I=0 To 30
      If WDUDAMT(I)<>""
        WDSEQ = fmet this.ETC.SIV(WNB).ADDLINE('C_DUD',[V]CST_ALASTPOS)
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDDAT =WDUDDAT(I)
        WPROP=format$("N:9.2#",val(WDUDAMT(I)))
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDAMTCUR =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDPAM    =WDUDPAM(I)
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDPAYREF = mess(47,109,1) # Payment

        Filter [ASWP] Where CODREP=WREP and CODLNK="EDIPAM"
        Read [ASWP] First
        If fstat=[V]CST_AOK
          Local Char WTYP(20)
          Local Integer WTAB
          WTYP=WDUDPAM(I)
          WTAB=val([F:ASWP]VALEUR)
          this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDPAM=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
        Endif
        If this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDPAM="": this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDPAM="01" : Endif

        Filter [ASWP]

        Local File BID [BID]
        Local File BANK [BAN]
        Local Char WIBAN(20), WENT(4), WSUC(4), WCPT(10), WADD(80), WCTY(50), WSAT(20), WPOSCOD(5)
        Local Char WCRY(3), WBIC(11), WEXTPOSCOD(50)

        If this.ETC.SIV(WNB).SIH(WNB).SNS=1
          Filter [BID] Where BPATYP=2 and BIDNUMFLG=2 and BPANUM=this.ETC.SIV(WNB).CPY
        Else
          Filter [BID] Where BPATYP=1 and BIDNUMFLG=2 and BPANUM=this.ETC.SIV(WNB).BPRPAY
        Endif
        Read [BID]BID0 First
        If fstat=[V]CST_AOK
          WIBAN =[F:BID]IBAN+[F:BID]BIDNUM
          WENT  =left$([F:BID]BIDNUM,4)
          WSUC  =mid$([F:BID]BIDNUM,5,4)
          WCPT  =right$([F:BID]BIDNUM,9)
          Filter [BAN] Where BIDNUM=[F:BID]BIDNUM
          Read [BAN] First
          If fstat=[V]CST_AOK
            WADD=vireblc([F:BAN]ADDLIG(0),5)-vireblc([F:BAN]ADDLIG(1),5)-vireblc([F:BAN]ADDLIG(2),5)
            WCTY=[F:BAN]CTY
            WSAT=[F:BAN]SAT
            WBIC=[F:BAN]BICCOD
            If [F:BAN]CRY="ES" or [F:BAN]CRY="ESP"
              WCRY="ESP"
              WPOSCOD=[F:BAN]POSCOD
              If len(WPOSCOD)<>5 : WPOSCOD="00000": Endif
            Else
              Local File TABCOUNTRY [TCY]
              Read [TCY]TCY0=[F:BAN]CRY
              If fstat=[V]CST_AOK
                If [F:TCY]ISOA3<>""
                  WCRY=[F:TCY]ISOA3
                Else
                  WSTATUS = [V]CST_AERROR
                  WERR = mess(1131,196,1) -WCRY+":"-mess(17,115,1)-"[F:TCY]ISOA3 ("-mess(1111,196,1)+")"-  mess(23,147,1)     # Field [F:TCY]ISOA3 empty
                  Break
                Endif
              Endif
              LogicClose File [TCY]
              WEXTPOSCOD= vireblc([F:BAN]POSCOD,5)- vireblc([F:BAN]CTY,5)
            Endif
          Else
            If this.ETC.SIV(WNB).SIH(WNB).SNS=2
              WSTATUS = [V]CST_AERROR
              WERR=this.ETC.SIV(WNB).BPRPAY+"."+mess(192,2006,1) #  Bank tax ID number is empty
              Break
            Endif
            Local File BPCUSTOMER [BPC]
            Local Char WBANK(5)

            Read [BPC]BPC0=this.ETC.SIV(WNB).BPRPAY
            If fstat=[V]CST_AOK:  WBANK=[F:BPC]PAYBAN: Endif
            LogicClose File [BPC]

            If WBANK=""
              If maxtab(this.ETC.SIV(WNB).C_PAM)>0
                WBANK= fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVLEG ,this.ETC.SIV(WNB).C_PAM(I).PAM_LEG,"BANKDEF")
              Else
                WBANK= fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVLEG ,WLEG,"BANKDEF")
              Endif
            Endif

            If WBANK=""
              Filter [BAN] Where CPY=this.ETC.SIV(WNB).CPY
              Read [BAN]BAN0 First
              If fstat=[V]CST_AOK
                WBANK=[F:BAN]BAN
              Else
                WSTATUS = [V]CST_AERROR
                WERR=mess(154,121,1) #There are no bank details, impossible to generate file
                Break
              Endif
              Filter [BAN]
            Endif

            Read [BAN]BAN0=WBANK
            If fstat=[V]CST_AOK
              WIBAN  =[F:BAN]IBACOD
              WENT  =left$([F:BAN]BIDNUM,4)
              WSUC  =mid$([F:BAN]BIDNUM,5,4)
              WCPT  =right$([F:BAN]BIDNUM,9)
              WADD=vireblc([F:BAN]ADDLIG(0),5)-vireblc([F:BAN]ADDLIG(1),5)-vireblc([F:BAN]ADDLIG(2),5)
              WCTY=[F:BAN]CTY
              WSAT=[F:BAN]SAT
              WBIC=[F:BAN]BICCOD
              If [F:BAN]CRY="ES" or [F:BAN]CRY="ESP"
                WCRY="ESP"
                WPOSCOD=[F:BAN]POSCOD
                If len(WPOSCOD)<>5: WPOSCOD="00000": Endif
              Else
                Local File TABCOUNTRY [TCY]
                Read [TCY]TCY0=[F:BAN]CRY
                If fstat=[V]CST_AOK
                  If [F:TCY]ISOA3<>""
                    WCRY=[F:TCY]ISOA3
                  Else
                    WSTATUS = [V]CST_AERROR
                    WERR = mess(1131,196,1) -WCRY+":"-mess(17,115,1)-"[F:TCY]ISOA3 ("-mess(1111,196,1)+")"-  mess(23,147,1)     # Field [F:TCY]ISOA3 empty
                    Break
                  Endif
                Endif
                LogicClose File [TCY]
                WEXTPOSCOD= vireblc([F:BAN]POSCOD,5)-vireblc([F:BAN]CTY,5)
              Endif
            Endif
          Endif
        Endif

        ### To be sure in these mandatory fields
        If len(WPOSCOD)<>5: WPOSCOD="00000": Endif
        If WCRY="": WCRY="ESP": Endif
        If WCPT="": WCPT="000000000": Endif
        If len(WBIC)<>11: WBIC="00000000000": Endif

        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDIBAN   =WIBAN
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDBANCOD =WENT
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDBRACOD =WSUC
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDCPTNUM =WCPT
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDBANADD =WADD
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDBANCTY =WCTY
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDBANSAT =WSAT
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDBANBIC =WBIC
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDBANCRY =WCRY
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDBANPOS =WPOSCOD
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDBANCTYP=WEXTPOSCOD
        this.ETC.SIV(WNB).C_DUD(WDSEQ).DUDPAYREFD=mess(189,2006,1)    #Payment reference details

        LogicClose File [BAN], [BID]
      Else
        Break
      Endif
    Next
    LogicClose File [ASWP]
  Next  # For future use when a lot of invoices will be possible

  Local Char WREST(250)
  WREST=mess(280,143,1)+": OK" # Displayed properties updated
  Call ADDDIAGNOSE(this.ACTX,WREST,[V]CST_AINFO) From ASYRASYNC

  # Init Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
  WOK= func EDILIBPDF.GET_FLOW_PDF(NUMDOC)
  If WOK=0
    Gosub PRINT_CLASSIC From EDILIBPDF
    If WSTATUS<>[V]CST_AOK
      If WERR="": WERR=mess(207,2006,1): Endif # Error generating the attachment
    Else
      WSTATUS=[V]CST_AINFO
      WERR=mess(208,2006,1) # Attachment successfully generated
    Endif
    Call ADDDIAGNOSE(this.ACTX,WERR,WSTATUS) From ASYRASYNC
    If WTEST=2
      WSTATUS=[V]CST_AINFO
      WERR=mess(213,2006,1) # Email protocol is not managed in test mode
      Call ADDDIAGNOSE(this.ACTX,WERR,WSTATUS) From ASYRASYNC
    Endif
  Endif

  # End Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
  WSTATUS=[V]CST_AOK
Return

################################################################################
$CALCULATE_DIS_CHAR_LINES
Local Decimal TOTALB, TOTALN, TOTUNI, TOTUNIB, DESCT, WUNIT

  TOTALB=this.ETC.SIV(WNB).SID(I).GROPRI*this.ETC.SIV(WNB).SID(I).QTY
  TOTALN=TOTALB
  TOTUNI=this.ETC.SIV(WNB).SID(I).GROPRI
  TOTUNIB=TOTUNI

  If this.ETC.VERSION="3.2"
    WPROP=format$("N:9.6#",TOTALB)
  Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
    WPROP=format$("N:9.8#",TOTALB)
  Endif
  this.ETC.SIV(WNB).SID(I).TOTCOST=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

  If TOTALB=0: Return: Endif

  Local File PRICSTRUCT [PRS]
  Local File SINVOICED  [SID]
  Local File ATEXTRA    [AXX]

  Read [PRS]PRS0=1;this.ETC.SIV(WNB).PLISTC
  If fstat=[V]CST_AOK
    For X=0 To 8
      If [F:PRS]INCDCR(X)=0: Break: Endif
      If [F:PRS]NPRNOTFLG(X)=1: WDIS(X)="0": Endif
      If [F:PRS]INCDCR(X)=2 and [F:PRS]NPRNOTFLG(X)=2
        Read [AXX]AXX0="PRICSTRUCT";"DESAXX("+num$(X)+")";WLAN;"1";""
        If fstat=[V]CST_AOK
          WTDIS(X)=[F:AXX]TEXTE
        Endif
        Read [SID]SID0=this.ETC.SIV(WNB).NUM;this.ETC.SIV(WNB).SID(I).SIDLIN
        If fstat=[V]CST_AOK
          If [F:PRS]VALTYP(X)<>1
            If this.ETC.VERSION="3.2"
              WPROP=format$("N:9.4#",arr(evalue("[SID]DISCRGVAL"+num$(X+1)),0.0001))
            Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
              WPROP=format$("N:9.8#",arr(evalue("[SID]DISCRGVAL"+num$(X+1)),0.0001))
            Endif
            WDISRAT(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          Endif
          If [F:PRS]CLCRUL(X)=1: WUNIT=evalue("[SID]DISCRGVAL"+num$(X+1))*this.ETC.SIV(WNB).SID(I).QTY
          Else WUNIT=evalue("[SID]DISCRGVAL"+num$(X+1))
          Endif
          Case [F:PRS]VALTYP(X)
            When 1:
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.6#",arr(WUNIT,0.01))
              Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.8#",arr(WUNIT,0001))
              Endif
              WDIS(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              TOTALN-=WUNIT
              TOTUNI-=evalue("[SID]DISCRGVAL"+num$(X+1))
            When 2:
              DESCT=ar2(TOTUNIB*(evalue("[SID]DISCRGVAL"+num$(X+1))/100))
              TOTUNI-=DESCT
              DESCT=DESCT*this.ETC.SIV(WNB).SID(I).QTY
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.6#",arr(DESCT,0.01))
              Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.8#",arr(DESCT,0.0001))
              Endif
              WDIS(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.4#",arr(val(WDIS(X))*100/TOTALB,0.01))
              Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.8#",arr(val(WDIS(X))*100/TOTALB,0.01))
              Endif
              WDISRAT(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              TOTALN-=DESCT
            When 3:
              DESCT=ar2(TOTUNI*(evalue("[SID]DISCRGVAL"+num$(X+1))/100))
              TOTUNI-=DESCT
              DESCT=DESCT*this.ETC.SIV(WNB).SID(I).QTY
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.6#",arr(DESCT,0.01))
              Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.8#",arr(DESCT,0.0001))
              Endif
              WDIS(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.4#",arr(val(WDIS(X))*100/TOTALB,0.01))
              Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.8#",arr(val(WDIS(X))*100/TOTALB,0.01))
              Endif
              WDISRAT(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              TOTALN-=DESCT
            Endcase
        Endif
      Elsif [F:PRS]INCDCR(X)=1 and [F:PRS]NPRNOTFLG(X)=2
        Read [AXX]AXX0="PRICSTRUCT";"DESAXX("+num$(X)+")";WLAN;"1";""
        If fstat=[V]CST_AOK
          WTCHG(X)=[F:AXX]TEXTE
        Endif
        Read [SID]SID0=this.ETC.SIV(WNB).NUM;this.ETC.SIV(WNB).SID(I).SIDLIN
        If fstat=[V]CST_AOK
          If [F:PRS]VALTYP(X)<>1
            If this.ETC.VERSION="3.2"
              WPROP=format$("N:9.4#",arr(evalue("[SID]DISCRGVAL"+num$(X+1)),0.0001))
            Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
              WPROP=format$("N:9.8#",arr(evalue("[SID]DISCRGVAL"+num$(X+1)),0.0001))
            Endif
            WCHGRAT(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          Endif

          If [F:PRS]CLCRUL(X)=1: WUNIT=evalue("[SID]DISCRGVAL"+num$(X+1))*this.ETC.SIV(WNB).SID(I).QTY
          Else WUNIT=evalue("[SID]DISCRGVAL"+num$(X+1))
          Endif

          Case [F:PRS]VALTYP(X)
            When 1:
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.6#",arr(WUNIT,0.01))
              Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.8#",arr(WUNIT,0.0001))
              Endif
              WCHG(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              TOTALN+=WUNIT
              TOTUNI+=evalue("[SID]DISCRGVAL"+num$(X+1))
            When 2:
              DESCT=ar2(TOTUNIB*(evalue("[SID]DISCRGVAL"+num$(X+1))/100))
              TOTUNI+=DESCT
              DESCT=DESCT*this.ETC.SIV(WNB).SID(I).QTY
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.6#",arr(DESCT,0.01))
              Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.8#",arr(DESCT,0.0001))
              Endif
              WCHG(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.4#",arr(val(WCHG(X))*100/TOTALB,0.01))
              Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.8#",arr(val(WCHG(X))*100/TOTALB,0.01))
              Endif
              WCHGRAT(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              TOTALN+=DESCT
            When 3:
              DESCT=ar2(TOTUNI*(evalue("[SID]DISCRGVAL"+num$(X+1))/100))
              TOTUNI+=DESCT
              DESCT=DESCT*this.ETC.SIV(WNB).SID(I).QTY
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.6#",WUNIT*arr(DESCT,0.01))
              Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.8#",arr(DESCT,0.0001))
              Endif
              WCHG(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              If this.ETC.VERSION="3.2"
                WPROP=format$("N:9.4#",arr(val(WCHG(X))*100/TOTALB,0.01))
              Elsif this.ETC.VERSION="3.2.1" or this.ETC.VERSION="3.2.2" #X3-63921 New format Facturae 3.2.2 (JUCON 22/12/17)
                WPROP=format$("N:9.8#",arr(val(WCHG(X))*100/TOTALB,0.01))
              Endif
              WCHGRAT(X)=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              TOTALN+=DESCT
            Endcase
        Endif
      Endif
    Next

  Endif

  LogicClose File [AXX], [SID], [PRS]

Return

################################################################################
$FACTURAE_RECEIPT
Return

