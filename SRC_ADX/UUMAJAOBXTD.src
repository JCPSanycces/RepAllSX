#<AdxTL>@(#)8.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour table intitulé traduisibles sur table des codes d'accès
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise à jour table intitulé traduisibles sur table des codes d'accès") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##################################################

Subprog PATCH_X3(APPLI)
Value Char APPLI

If filinfo(filpath("FIL","AYTELTFLD","fde",APPLI),0) <0 or func AFNC.ACTIVDOS(APPLI,"AYT")<1
 End
Endif

Local File ADOSSIER [ADS2]
Read [ADS2]DOSSIER = APPLI
If fstat : End : Endif

Call AOBJLSTXTD([F:ADS2]DOSSIER,[F:ADS2]DOSREF)

Close Local File 
End
##################################################

Subprog PATCH(APPLI)
Value Char APPLI

If filinfo(filpath("FIL","AYTELTFLD","fde",APPLI),0) <0 or func AFNC.ACTIVDOS(APPLI,"AYT")<1
 End
Endif

Local File ADOSSIER [ADS2]
Read [ADS2]DOSSIER = APPLI
If fstat : End : Endif

Call AOBJLSTXTD([F:ADS2]DOSSIER,[F:ADS2]DOSREF)

Close Local File 

End 

#########################################################################################
# Mise à jour forcée de l'onglet sélection des objets Xtend
#########################################################################################
Subprog AOBJLSTXTD(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

Local Char WOBJET(GLONAOB)

Local File =DOSSIER+".AOBJLST" [AOL] , =DOSREF+".AOBJLST" [AOL2] , =DOSSIER+".ALSTRD" [ALS]
&        , =DOSSIER+".AOBJET"  [AOB] , =DOSREF+".AOBJET"  [AOB2]    

Call ECR_TRACE(mess(81,125,1)-": AOBJLST (Safe X3 WAS)"-time$,0) From GESECRAN : # maj table

Trbegin [AOL]
 
 # Onglet sélection

For [AOB2] Where CODACT ="AYT"
  WOBJET = [F:AOB2]ABREV
  Read [AOL]AOL0 = WOBJET
  If !fstat
   Read [AOL2]AOL0 = WOBJET
   If !fstat
    [F:AOL] = [F:AOL2]
    Rewrite [AOL]
    If fstat
     Call ERREUR("AOBJLST"-WOBJET,2) From DOSDIC
    Endif
   Endif
  Endif
  Delete [ALS] Where OBJ=WOBJET
 Next WOBJET

Commit
Close Local File

End

