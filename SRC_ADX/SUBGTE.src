#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("GTE",GBIDC1,GBIDC2) From GOBJET
End
# Issue X3-107197 - 2018-09-14 by CBO : PARAMETER AND ACTIVITY CODE

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "AFFMASK"     : Gosub AFFMASK
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "SETBOUT"     : Gosub SETBOUT
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "FERME"       : Gosub FERME
 When "CHGCOD"      : Gosub CHGCOD
 When "AS_TYP"      : Raz GCURLEG
Endcase
Return

$OUVRE
Local Integer CATEG, PERIOD
If GMODU(2)=2
 If clalev([F:JOU])=0 : Local File GJOURNAL [JOU] : Endif
Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$AFFMASK
Call FMTLEG From TRTX3
Gosub GRILEG
Return

$GRILEG
If func AFNC.ACTIV("LEG")=0
  Diszo [M:GTE1]LEG
  [M:GTE1]LEG=GDOSLEG(1)
  Affzo [M:GTE1]LEG
Endif
Return

$LIENS
PERIOD = [M]PER
Gosub TAB
Gosub TAB2
If dim([M:GTE1]LEG)>0 : Affzo [M:GTE1]LEG : Endif
GCURLEG = [F:GTE]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call LECTEXTRA([M:GTE1]DESTRA,"GTYPACCENT","DESTRA",[M:GTE1]TYP,GCURLEG) From ATEXTRA
Call LECTEXTRA([M:GTE1]SHOTRA,"GTYPACCENT","SHOTRA",[M:GTE1]TYP,GCURLEG) From ATEXTRA
Return

$RAZCRE
Gosub TAB2
Gosub GRILEG
Return

$TAB
Local Integer I
If GMODU(2)=2
 [M]NBRTYP = dim([M]AUZJOU)
Endif
For I=1 To dim([M]AUZJOU)
 If [M]AUZJOU(I-1)=0
  [M]AUZJOU(I-1) = 1
  Case I
   When 1, 2, 3, 4, 5, 6, 8, 9, 10
    If PERIOD=1
     [M]AUZJOU(I-1) = 2
    Endif
   When 7
    If PERIOD=2
     [M]AUZJOU(I-1) = 2
    Endif
  Endcase
 Endif
Next I
Affzo NBRTYP, NUMLIG, TYPJOU, AUZJOU
Return

$TAB2
Local Integer AUT, NBLED, TYPREF
For I=1 To len(mess(0,2644,1))
 Raz AUT
 For NBLED=1 To len(GLEDTYPAUT)
  TYPREF = val(mid$(GLEDTYPAUT,NBLED,1))
  # Gestion de la valeur 10
  If TYPREF=1 &  mid$(GLEDTYPAUT,NBLED+1,1)="0"
   If I=10 : AUT=1 : Break : Endif
  Else
   If TYPREF = I : AUT=1 : Break : Endif
  Endif
 Next
 If !AUT
  [M]LEDTYP([M]NBLIG) = I
  [M]AUZLED([M]NBLIG) = [F:GTE]AUZLED(I-1)
  [M]NBLIG+=1
 Endif
Next
Affzo NBLIG, LEDTYP, AUZLED
Return

$SETBOUT
Local Integer OKACC
Call LECACC([F:GTE]ACS,OKACC) From CPTSUB
If !OKACC
 Call VIREBOUT(CHAINE,"MAH") From GOBJET
Endif
Return

$VERIF_CRE
$VERIF_MOD
If GMODU(2)=2 & [M]DEFJOU<>""
 If dim([M:GTE1]LEG)>0
  Call LEC_JOU_LEG([M:GTE1]LEG,[M]DEFJOU) From CPTLEC
 Else
  Call LEC_JOU_LEG(GDOSLEG,[M]DEFJOU) From CPTLEC
 Endif
 If !fstat & [M]AUZJOU([F:JOU]TYP-1)<>2
  # Journal non autorisé
  GMESSAGE=mess(77,106,1)
  OK=0
 Endif
Endif
If !find(2,[M]AUZLED(0..dim([M]LEDTYP)-1)) & !find(3,[M]AUZLED(0..dim([M]LEDTYP)-1))
 # Au moins un type de référentiel doit être autorisé ou obligatoire
 GMESSAGE = mess(78,104,1)
 OK=0 : Return
Endif
Return

$INICRE
$INIMOD
If func AFNC.ACTIV("LEG")=0 : [F:GTE]LEG = GDOSLEG(1) : Endif
For I=1 To len(mess(0,2644,1))
 J = find(I,[M]LEDTYP(0..dim([M]LEDTYP)-1))
 If J
  [F]AUZLED(I-1) = [M]AUZLED(J-1)
 Else
  [F]AUZLED(I-1) = 1
 Endif
Next
If dim([F:GTE]DES)>0
 [F:GTE]DES = [M:GTE1]DESTRA
Endif
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GTYPACCENT","DESTRA",CLECUR2,CLECUR1,"GTYPACCENT","DESTRA",[F:GTE]TYP,[F:GTE]LEG)  From ATEXTRA
 Call DUPTEXTRA("GTYPACCENT","SHOTRA",CLECUR2,CLECUR1,"GTYPACCENT","SHOTRA",[F:GTE]TYP,[F:GTE]LEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M:GTE1]DESTRA,"GTYPACCENT","DESTRA",[F:GTE]TYP,[F:GTE]LEG) From ATEXTRA
Call MAJTEXTRA([M:GTE1]SHOTRA,"GTYPACCENT","SHOTRA",[F:GTE]TYP,[F:GTE]LEG) From ATEXTRA
Return

$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

$AP_CHANGE
Call CHGTEXTRA("GTYPACCENT","DESTRA",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("GTYPACCENT","SHOTRA",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("GTYPACCENT","DESTRA",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("GTYPACCENT","SHOTRA",SUPP,[L]CODE) From ATEXTRA
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONGTE) : Endif
VCOD = CLE2
Return

###############################################################################
##  Copie
###############################################################################
$TRTCOP
Local Char LEGDEST(250)

If [M]DOSORG=nomap
 Local File GTYPACCENT  [GTE1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".GTYPACCENT"  [GTE1]
 Local File =[M]DOSORG+".ATEXTRA"     [AXX1]
Endif
If [M]DOSDES=nomap
 Local File GTYPACCENT [GTE2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".GTYPACCENT"  [GTE2]
 Local File =[M]DOSDES+".ATEXTRA"     [AXX2]
Endif
Gosub OUVDOS From ATEXTRA

# Multi-Lég... Vérifier que la législation existe dans le dossier destination
# Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
If TABLE2<>"" & clalev([F:ADS2])>0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
 Call MESSAGE(TABLE2-":"-mess(249,133,1) ) From GESECRAN  # Législation non gérée par le dossier
 Return
Endif

# We can't copy an empty legislation to a single-legislation folder. We have to move the empty legislation
# to the legislation of the destination folder before the copy
LEGDEST = TABLE2
If LEGDEST="" & [F:ADS2]NBLEG=1
 LEGDEST = [F:ADS2]DOSLEG(0)
Endif

Call DEBTRANS From GLOCK
Gosub TR_COP

Close Local File [GTE1], [GTE2], [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [GTE2]
 Delete [GTE2] Where TYP=TABLE & LEG=LEGDEST
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GTYPACCENT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GTE2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [GTE1] Where TYP=TABLE & LEG=TABLE2
  [F:GTE2] = [F:GTE1]
  [F:GTE2]LEG = LEGDEST
  Call COPTEXTRALEG("GTYPACCENT","DESTRA",TABLE,TABLE2,LEGDEST) From CPTDIV
  Call COPTEXTRALEG("GTYPACCENT","SHOTRA",TABLE,TABLE2,LEGDEST) From CPTDIV
  If dim([F:GTE2]UPDUSR)>0 : [F:GTE2]UPDUSR = GUSER : Endif
  If dim([F:GTE2]UPDDAT)>0 : [F:GTE2]UPDDAT = date$ : Endif
  Write [GTE2]
  If fstat
   GOK = 0 : Call FSTA("GTE2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

############################################################################################
## Etiquettes du masque GTE1
############################################################################################

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR

#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If func AFNC.ACTIV("KPO")>0 & find(VALEUR,"POR","")
  Local Char WMESS(100) : WMESS = ""
  Call CTL_CODNUM_LEG(VALEUR,[M:GTE1]TYP,"GTE",WMESS) From PORLEGLIB
  If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
Endif
# Issue End

End

Subprog AS_AUZJOU(VALEUR)
Variable Integer  VALEUR
Case nolign
 When 1, 2, 3, 4, 5, 6, 8, 9, 10
  If [M]PER=2 : VALEUR = 1 : mkstat = 2 : End : Endif
 When 7
  If [M]PER<>2 : VALEUR = 1 : Else : VALEUR = 2 : Endif
  mkstat = 2 : End
Endcase
If VALEUR=0 : VALEUR = 2 : Endif
End

Subprog C_COU(VALEUR)
Variable Char     VALEUR

#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If func AFNC.ACTIV("KPO")>0 & find([M:GTE1]LEG,"POR","")
  Local Char WMESS(100) : WMESS = ""
  Call CTL_CODNUM_FINAL(VALEUR,[M:GTE1]LEG,[M:GTE1]TYP,"GTE",WMESS) From PORLEGLIB
  If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : End : Endif
Endif
# Issue End

If [M]MANNUM<>2 & VALEUR=""
 # Vous devez définir une numérotation
 GMESSAGE = mess(3,105,1)
 mkstat = 2 : End
Elsif VALEUR<>""
 Call LECTURE("ANM",VALEUR,"") From CONTOBJ
 If [F:ANM]LNG>GLONVCR
  # Compteur de longueur trop grande
  GMESSAGE = mess(51,105,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_COUVATCEE(VALEUR)
Variable Char    VALEUR()
If [M]COU<>'' & VALEUR = [M]COU
 # Ce code compteur doit être différent du compteur de pièce
 GMESSAGE = mess(14,131,1)
 mkstat = 2 : End
Endif
End

Subprog AM_PER(VALEUR)
Variable Integer VALEUR
PERIOD = VALEUR
Gosub TAB
End

Subprog AM_VAT(VALEUR)
Variable Integer VALEUR
# On met un message d'avertissement si on remet à 'non' le flag de TVA
# sur débits ou sur encaissements et qu'il y a de la TVA déclarée sur
# des pièces associées à ce type de pièce
If VALEUR <> 2
 Gosub CONTTVA
Endif
End

Subprog AM_VATPAI(VALEUR)
Variable Integer VALEUR
If VALEUR <> 2
 Gosub CONTTVA
Endif
End

## <DES>
Subprog D_ESDTRK(VALEUR)
Variable Integer VALEUR
If [M]FUP = 2
 VALEUR = 2 : End
Endif
End
## <Fin DES>

Subprog AS_PAM(VALEUR)
Variable Char    VALEUR()
If [M]DUDDATFLG<>2
 mkstat = 1 : End
Endif
End

$CONTTVA
Local Integer OK
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
Filter [DAE] Where TYP = [M]TYP & AMTVAT <> 0
Read [DAE]DAE0 First
Filter [DAE]
If !fstat
 # Attention, ce type de pièce comporte de la TVA déclarée
 OK = 2 : Call AVERTIR(mess(97,105,1),OK) From GESECRAN
 If OK<>2 : mkstat = 2 : Return : Endif
Endif
Return


Subprog C_TYP(VALEUR)
Variable Char    VALEUR()
Local Char TYPPCE(GLONGTE)
TYPPCE = VALEUR
Gosub CONT_TYP
End

$CONT_TYP
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Filter [ADW] Where [F:ADW]PARAM="BPCORDTYP" & [F:ADW]VALEUR=[L]TYPPCE
Read [ADW]ADW0 First
If !fstat
 # Type de pièce non autorisé. Commande client
 GMESSAGE = mess(43,106,1)-":"-[L]TYPPCE+" "+mess(1,659,1)
 mkstat = 2 : Return
Endif

Filter [ADW] Where [F:ADW]PARAM="BPSORDTYP" & [F:ADW]VALEUR=[L]TYPPCE
Read [ADW]ADW0 First
If !fstat
 # Type de pièce non autorisé. Commande fournisseur
 GMESSAGE = mess(43,106,1)-":"-[L]TYPPCE+" "+mess(2,659,1)
 mkstat = 2 : Return
Endif

If func AFNC.ACTIV("KIT")   # Issue X3-107197
  Filter [ADW] Where [F:ADW]PARAM="BPSPROTYP" & [F:ADW]VALEUR=[L]TYPPCE
  Read [ADW]ADW0 First
  If !fstat
   # Type de pièce non autorisé. Proforma fournisseur
   GMESSAGE = mess(43,106,1)-":"-[L]TYPPCE+" "+mess(4,659,1)
   mkstat = 2 : Return
  Endif
Endif   # Issue X3-107197

Filter [ADW]
End

Subprog AS_DUDTYP(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1
End

Subprog C_DEFJOU(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | find(GREP,"C","D") : End : Endif
If [M]AUZJOU([F:JOU]TYP-1)<>2
 # Journal non autorisé
 GMESSAGE=mess(77,106,1)
 mkstat=2 : End
Endif
End


Subprog AS_NBLIG
Local Integer I
For I=1 To [M:GTE1]NBLIG
 If [M:GTE1]AUZLED(I-1) = 0
  [M:GTE1]AUZLED(I-1) = 2
 Endif
Next
Affzo AUZLED
End

Subprog AS_AUZLED(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=2 : Endif
End


##################################################
## Data Type GTE  "Document Types"
##################################################

## Control of Data Type GTE  "Document Types"
Subprog CONTGTE(COD,LEG,GFY)
Value Char    COD()
Value Char    LEG()
Value Char    GFY()

Local Integer CAS

If GFONCTION = "GESGTE" | COD="" : End : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif

If GNBLEG=1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
 LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
 Read [GTE]GTE0=COD;LEG
 If fstat
  Read [GTE]GTE0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Filter [GTE] Where ENAFLG=2
 Read [GTE]GTE0(1)=[L]COD
 Filter [GTE]
 If !fstat
  LEG = [F:GTE]LEG
  CAS = 2
 Else
  # To display the right message : either the recording is disable either it doesn't exist
  Read [GTE]GTE0(1)=COD
 Endif
Endif

If !fstat & [F:GTE]ENAFLG<>2
 # Type de pièces : xxx Fiche inactive
 Gosub TIT From WOGTE
 GMESSAGE = TIT-":"-[L]COD
 GMESSAGE += "\"+mess(2,126,1)
 mkstat = 2 : End
Elsif fstat
 If LEG<>""
  # LEG=FRA and the recording exists for the ITA legislation.
  # The right message isn't "Fiche inexistante" but "Fiche inexistante pour la législation courante"
  Filter [GTE] Where TYP=[L]COD
  Look [GTE]GTE0 First
  Filter [GTE]
  If !fstat
   # Fiche inexistante pour la législation courante
   # Issue 109042 - 2015-07-01 by CPO : Having the same error message formatting
   #GMESSAGE += [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
   Gosub TIT From WOGTE
   GMESSAGE = TIT-":"-[L]COD
   GMESSAGE += "\"+mess(232,107,1)-"["+[L]LEG+"]"
   # End issue 109042
   mkstat = 2 : End
  Endif
 Endif
 # Fiche inexistante
 # Issue 109042 - 2015-07-01 by CPO : Having the same error message formatting
 #GMESSAGE = [L]COD-":"-mess(23,100,1)
 Gosub TIT From WOGTE
 GMESSAGE = TIT-":"-[L]COD
 GMESSAGE += "\"+mess(23,100,1)
 # End issue 109042
 mkstat = 2 : End
Endif

If [L]GFY<>"" & [F:GTE]GFY<>"" & [L]GFY<>[F:GTE]GFY
 Call COMPAT([L]GFY,[F:GTE]GFY,"") From CFYSUB
 If mkstat=2
   Gosub TIT From WOGTE
   GMESSAGE = TIT-":"-[L]COD-[F:GTE]LEG
   GMESSAGE += "\"+mess(23,127,1)-":"-[F:GTE]GFY
   End
 Endif
Endif

If CAS=2
 Call CONTROLE("GTE","",LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("GTE","","",COD,mkstat) From CONTOBJ
Endif

#  Call CONTSEL("GTE","",LEG,COD,,mkstat) From CONTOBJ
End

##################################################
## Selection from List GTE "Document Types"
##################################################

Subprog SELGTE(COD,LEG,LEDTYP,GFY)
Variable Char    COD()
Value    Char    LEG()
Value    Integer LEDTYP
Value    Char    GFY()
Local Char PARMSK(30)(1..10)
PARMSK(1)=[L]LEG
PARMSK(2)=num$([L]LEDTYP)
PARMSK(3)=[L]GFY
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
Call S_TAB_CHAR(COD,PARMSK,"SELGTE","SELGTE","") From GACTION
End

## Tunnel GTE "Document Types"
Subprog TUNGTE(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer O_GNBDERNIER, O_GNBDERCLE
Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONGTE)
 TOKILL = 1
Endif

If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif

VCOD = COD

If GNBLEG=1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
 LEG = GCURLEG
Elsif LEG="" :  ## If LEG="" then firstly we search a GTE record with LEG="" secondly a GTE record with LEG<>""
 Read [GTE]GTE0 = VCOD;LEG
 If fstat
  Read [GTE]GTE0(1)=VCOD
  If !fstat
   LEG = [F:GTE]LEG
  Endif
 Endif
Endif

Call LEC_GTE_LEG(LEG,VCOD) From CPTLEC
If !fstat
 LEG = [F:GTE]LEG
Else
 Raz VCOD,LEG
Endif

O_GNBDERNIER = GNBDERNIER
O_GNBDERCLE = GNBDERCLE
Raz GNBDERNIER, GNBDERCLE
Call OBJET("GTE",LEG,VCOD) From GOBJET
GNBDERNIER = O_GNBDERNIER
GNBDERCLE = O_GNBDERCLE

If VCOD<>"" : COD = VCOD : Endif
If TOKILL : Kill VCOD : Endif
End

##################################################
Subprog IB_TYP
If GFONCTION = "GESGTE" : GBOUT1="" : End : Endif
End

##################################################
Subprog C_GFY(VALEUR)
Variable Char    VALEUR()
Local Shortint STAT
Local Char MESSA(250)
Call CNTCOHGRPLEG(VALEUR,GCURLEG,STAT,MESSA) From CPTCNT
If !STAT
 GMESSAGE=MESSA
 mkstat=2 : End
Endif
End

