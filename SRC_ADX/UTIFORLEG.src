#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-112439 - 2018-10-15 by FAHAM : Migration from V6 monoleg formulas per leg not migrated
#----------------------------------------------------------------------------------------#
# Migration des formules des pièces automatiques dans la table TABFORLEG
#----------------------------------------------------------------------------------------#
Call OUVRE_TRACE("Migration new table TABFORLEG") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MIGTFO
End

#-------------------#
$MIGTFO

Local Integer I , MONO , PIECE
Local Integer AERROR
AERROR=0
Local Integer AEXIST

#SAM 122482
#no change for the root folder
If DOSSIER=GDOSX3
   Return
Endif

PIECE = 21
If filinfo(filpath("FIL","TABFORLEG","fde",DOSSIER),0)<=0
  Return
Endif

Local File =DOSSIER+".TABFOR"    [TFO]
Local File =DOSSIER+".TABFORLEG" [TFOLEG]

#SAM 122482
#If nbrecord([F:TFOLEG])>0
#  Goto FIN
#Endif

Local File ADOSSIER [ADS_U] , ADOSACT [ADA_U]
Read [ADS_U]DOSSIER = [L]DOSSIER
Read [ADA_U]ADA0 = [L]DOSSIER;"LEG"
If fstat or [F:ADA_U]FLACT<>2
 MONO = 1
Endif

Local File =DOSSIER+".ATEXTRA" [AXX_U]

# Mise à jour de la table
Call ECR_TRACE(mess(81,125,1)-"TABFORLEG:"-time$,0) From GESECRAN

Trbegin [TFOLEG]

#transfert to new structure

 For [TFO] Where FORTYP=PIECE
  AEXIST=0
  Call DUPTEXTRA("TABFOR","DES",[F:TFO]FORNUM,[F:TFO]FORCOD,"TABFORLEG","DES",[F:TFO]FORCOD,"")
  Call DUPTEXTRA("TABFOR","DESSHO",[F:TFO]FORNUM,[F:TFO]FORCOD,"TABFORLEG","DESSHO",[F:TFO]FORCOD,"")

  If MONO
    Read [TFOLEG]TFOLEG0=[F:TFO]FORCOD;[F:ADS_U]DOSLEG
    If fstat = 0
      AEXIST=1
    Endif
    If AEXIST=0
      Raz[TFOLEG]
    Endif
    [F:TFOLEG] = [F:TFO]
    [F:TFOLEG]LEG = [F:ADS_U]DOSLEG
    [F:TFOLEG]FORFOR = [F:TFO]FORFOR(0)   # Issue X3-112439
    If dim([F:TFOLEG]CREUSR)>0 : [F:TFOLEG]CREUSR = GUSER : Endif
    If dim([F:TFOLEG]CREDAT)>0 : [F:TFOLEG]CREDAT = date$ : Endif
    If dim([F:TFOLEG]CRETIM)>0 : [F:TFOLEG]CRETIM = time  : Endif
    If AEXIST=0
      Write [TFOLEG]
      If fstat
        Call ERREUR("TABFORLEG"-[F:TFO]FORCOD,1) From DOSDIC
        AERROR=1
      Endif
    Else
      Rewrite [TFOLEG]
      If fstat
        Call ERREUR("TABFORLEG"-[F:TFO]FORCOD,2) From DOSDIC
        AERROR=1
      Endif
    Endif
  Else
    For I=1 To dim([F:TFO]LEG)
      If [TFO]LEG(I-1)="" : Break : Endif
      Read [TFOLEG]TFOLEG0=[F:TFO]FORCOD;[F:TFO]LEG(I-1)
      If fstat=0
        AEXIST=1
      Endif
      If AEXIST=0
        Raz [TFOLEG]
      Endif
      [F:TFOLEG] = [F:TFO]
      [F:TFOLEG]LEG    = [F:TFO]LEG(I-1)
      [F:TFOLEG]FORFOR = [F:TFO]FORFOR(I-1)
      If dim([F:TFOLEG]CREUSR)>0 : [F:TFOLEG]CREUSR = GUSER : Endif
      If dim([F:TFOLEG]CREDAT)>0 : [F:TFOLEG]CREDAT = date$ : Endif
      If dim([F:TFOLEG]CRETIM)>0 : [F:TFOLEG]CRETIM = time  : Endif
      If AEXIST=0
        Write [TFOLEG]
        If fstat
          Call ERREUR("TABFORLEG"-[F:TFO]FORCOD-[F:TFO]LEG(I-1),1) From DOSDIC
          AERROR=1
        Endif
      Else
        Rewrite [TFOLEG]
        If fstat
          Call ERREUR("TABFORLEG"-[F:TFO]FORCOD-[F:TFO]LEG(I-1),1) From DOSDIC
          AERROR=1
        Endif
      Endif
    Next I
  Endif
  If AERROR=1
    Break
  Endif
 Next TFO
If AERROR=0
 For [TFO] Where FORTYP=PIECE
  Delete [AXX_U] Where CODFIC="TABFOR" & IDENT1=[F:TFO]FORNUM & IDENT2=[F:TFO]FORCOD
  If fstat <>0
    AERROR=1
    Break
  Endif
 Next TFO
Endif
If AERROR=0
  Delete [TFO] Where FORTYP=PIECE
  If fstat<>0
    AERROR=1
  Endif
Endif
If AERROR=0
  Commit
Else
  Rollback
Endif

Close Local File [ADS_U] , [ADA_U] , [AXX_U]

$FIN
Close Local File [TFO] , [TFOLEG]
Return

#-------------------------------------------------------------------------------------------#
Subprog DUPTEXTRA(TABORG,FLDORG,CLEORG1,CLEORG2,TABDES,FLDDES,CLEDES1,CLEDES2)
Value    Char    TABORG,FLDORG,CLEORG1,CLEORG2,TABDES,FLDDES,CLEDES1,CLEDES2
Delete [AXX_U] Where CODFIC=TABDES & ZONE=FLDDES & IDENT1=CLEDES1 & IDENT2=CLEDES2
For [AXX_U]AXX0 Where CODFIC=TABORG & ZONE=FLDORG & IDENT1=CLEORG1 & IDENT2=CLEORG2
 [F:AXX_U]CODFIC = TABDES
 [F:AXX_U]ZONE   = FLDDES
 [F:AXX_U]IDENT1 = CLEDES1
 [F:AXX_U]IDENT2 = CLEDES2
 Write [AXX_U]
 If fstat
  Call ERREUR("TABFORLEG"-TABDES-FLDDES-CLEDES1-CLEDES2,1) From DOSDIC
 Endif
Next AXX_U
End

