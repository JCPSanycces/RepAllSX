                             TMOD(IZON) =[M:PTR3]DISCRGCOD4
                             IZON+=1
     Endif
     If [M:PTR3]DISCRGSCR4>1 TZONE(IZON)="DISCRGVAL4"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR3]DISCRGSCR4)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTR3]DISCRGCOD5)>0
     If [M:PTR3]DISCRGCOD5>1 TZONE(IZON)="DISCRGVAL5"
                             TMOD(IZON) =[M:PTR3]DISCRGCOD5
                             IZON+=1
     Endif
     If [M:PTR3]DISCRGSCR5>1 TZONE(IZON)="DISCRGVAL5"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR3]DISCRGSCR5)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTR3]DISCRGCOD6)>0
     If [M:PTR3]DISCRGCOD6>1 TZONE(IZON)="DISCRGVAL6"
                             TMOD(IZON) =[M:PTR3]DISCRGCOD6
                             IZON+=1
     Endif
     If [M:PTR3]DISCRGSCR6>1 TZONE(IZON)="DISCRGVAL6"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR3]DISCRGSCR6)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTR3]DISCRGCOD7)>0
     If [M:PTR3]DISCRGCOD7>1 TZONE(IZON)="DISCRGVAL7"
                             TMOD(IZON) =[M:PTR3]DISCRGCOD7
                             IZON+=1
     Endif
     If [M:PTR3]DISCRGSCR7>1 TZONE(IZON)="DISCRGVAL7"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR3]DISCRGSCR7)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTR3]DISCRGCOD8)>0
     If [M:PTR3]DISCRGCOD8>1 TZONE(IZON)="DISCRGVAL8"
                             TMOD(IZON) =[M:PTR3]DISCRGCOD8
                             IZON+=1
     Endif
     If [M:PTR3]DISCRGSCR8>1 TZONE(IZON)="DISCRGVAL8"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR3]DISCRGSCR8)
