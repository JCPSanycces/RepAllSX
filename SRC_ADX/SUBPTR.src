       Elsif !GIMPORT
         Actzo [PTR3]QTYWEUSCR
       Endif

  When Default
       Gosub APRES_MODIF From SUBETR
       Gosub PE_PURTRS From SUBPTX
Endcase
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
Gosub CHARG_COMPLEMENT
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
Gosub CHARG_COMPLEMENT
Return

#---------------------------#
# Chargement complémentaire #
#---------------------------#
$CHARG_COMPLEMENT
[F:PTR]ITMDESCOD(1)=[M:PTR2]ITMDES1COD
[F:PTR]ITMDESSCR(1)=[M:PTR2]ITMDES1SCR
[F:PTR]VATCOD(0)   =[M:PTR2]VAT1COD
[F:PTR]VATSCR(0)   =[M:PTR2]VAT1SCR
[F:PTR]VATCOD(1)   =[M:PTR2]VAT2COD
[F:PTR]VATSCR(1)   =[M:PTR2]VAT2SCR
[F:PTR]VATCOD(2)   =[M:PTR2]VAT3COD
[F:PTR]VATSCR(2)   =[M:PTR2]VAT3SCR
If dim([M:PTR2]TAXRCPCOD)>0
  [F:PTR]VATCOD(3)   =[M:PTR2]TAXRCPCOD
  [F:PTR]VATSCR(3)   =[M:PTR2]TAXRCPSCR
  [F:PTR]VATCOD(4)   =[M:PTR2]TAXISSCOD
  [F:PTR]VATSCR(4)   =[M:PTR2]TAXISSSCR
  [F:PTR]VATCOD(5)   =[M:PTR2]TAXOTH1COD
  [F:PTR]VATSCR(5)   =[M:PTR2]TAXOTH1SCR
  [F:PTR]VATCOD(6)   =[M:PTR2]TAXOTH2COD
  [F:PTR]VATSCR(6)   =[M:PTR2]TAXOTH2SCR
Endif
If dim([M:PTR3]DISCRGCOD1)>0
  [F:PTR]DISCRGCOD(0)=[M:PTR3]DISCRGCOD1
  [F:PTR]DISCRGSCR(0)=[M:PTR3]DISCRGSCR1
Endif
If dim([M:PTR3]DISCRGCOD2)>0
  [F:PTR]DISCRGCOD(1)=[M:PTR3]DISCRGCOD2
  [F:PTR]DISCRGSCR(1)=[M:PTR3]DISCRGSCR2
Endif
If dim([M:PTR3]DISCRGCOD3)>0
  [F:PTR]DISCRGCOD(2)=[M:PTR3]DISCRGCOD3
  [F:PTR]DISCRGSCR(2)=[M:PTR3]DISCRGSCR3
Endif
If dim([M:PTR3]DISCRGCOD4)>0
  [F:PTR]DISCRGCOD(3)=[M:PTR3]DISCRGCOD4
  [F:PTR]DISCRGSCR(3)=[M:PTR3]DISCRGSCR4
Endif
If dim([M:PTR3]DISCRGCOD5)>0
  [F:PTR]DISCRGCOD(4)=[M:PTR3]DISCRGCOD5
  [F:PTR]DISCRGSCR(4)=[M:PTR3]DISCRGSCR5
Endif
If dim([M:PTR3]DISCRGCOD6)>0
  [F:PTR]DISCRGCOD(5)=[M:PTR3]DISCRGCOD6
  [F:PTR]DISCRGSCR(5)=[M:PTR3]DISCRGSCR6
Endif
If dim([M:PTR3]DISCRGCOD7)>0
  [F:PTR]DISCRGCOD(6)=[M:PTR3]DISCRGCOD7
  [F:PTR]DISCRGSCR(6)=[M:PTR3]DISCRGSCR7
Endif
If dim([M:PTR3]DISCRGCOD8)>0
  [F:PTR]DISCRGCOD(7)=[M:PTR3]DISCRGCOD8
  [F:PTR]DISCRGSCR(7)=[M:PTR3]DISCRGSCR8
Endif
If dim([M:PTR3]DISCRGCOD9)>0
  [F:PTR]DISCRGCOD(8)=[M:PTR3]DISCRGCOD9
  [F:PTR]DISCRGSCR(8)=[M:PTR3]DISCRGSCR9
Endif
#-----
[F:PTR]BPSLOTCOD(1)=[M:ETR2]BPSLOTCOD1
[F:PTR]MVTPRICOD(1)=[M:ETR2]MVTPRICOD1
[F:PTR]SERECOD  (1)=[M:ETR2]SERECOD1
[F:PTR]MVTDESCOD(1)=[M:ETR2]MVTDESCOD1
[F:PTR]BPSLOTSCR(1)=[M:ETR2]BPSLOTSCR1
[F:PTR]SERESCR  (1)=[M:ETR2]SERESCR1
#-----
Gosub CHARGE_ATEXTRA From SUBPTR
Gosub PE_PURTRS      From SUBPTX
Return

#----------------------------------------#
# Création ou modif du texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA
Call MAJTEXTRA([M:PTR0]DESAXX,"PURTRS","DESAXX",num$([M:PTR0]PTRTYP),[M:PTR0]PTRNUM) From ATEXTRA
[F:PTR]PTRDES   =GLANGUE+"~"+[M:PTR0]DESAXX
[F:PTR]PTRTYPCAR=num$([F:PTR]PTRTYP)
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char    APPLI : Endif
If dim(OK)<0    Local Integer OK    : Endif
If dim(WMODU)<0 Local Char    WMODU : Endif
If APPLI="" APPLI=nomap : Endif
If WMODU="" WMODU="E"+num$([M:PTR0]PTRTYP) : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO  (GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     WOPTION(15)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK
# Issue 84130 - 2013-02-25 by SR : Pour écran CSTPTH
Local Char     MABREV(GLONABR)
#----- Noms fenêtres et traitement réception -----#
Local Char     WINREF1(GLONFEN)  : WINREF1="OPTH"
Local Char     NOMWIN1(GLONFEN)  : NOMWIN1="WOPTH"+[M:PTR0]PTRNUM
#----- 1er écran -----#
MFROM="PTH0"
MTO="WE"+num$([M:PTR0]PTRTYP)+[M:PTR0]PTRNUM+"0"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:PTR1]SRGWAIFLG<>2 TZONE(IZON)="SRGLOCDEF"          : # Emplacement à quai
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If dim([M:PTR1]WRHCOD) >0
     If [M:PTR1]WRHCOD>1   TZONE(IZON)="WRHE"               : # Dépôt
                           TMOD(IZON) =[M:PTR1]WRHCOD
                           IZON+=1
     Endif
   Endif
   # Issue 71069 - 2013-07-30 by MAE : PJT en en-tête
   If [M:PTR1]PJTHCOD>1   TZONE(IZON)="PJTH"               : # Affaire :  revue de code (commentaire)
                           TMOD(IZON) =[M:PTR1]PJTHCOD
                           IZON+=1
   Endif
   #Fin MAE
   OPT1=2
   Gosub PE_PURTRS From SUBPTX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
#----- 1er écran -----#
MFROM="PTH1"
MTO="WE"+num$([M:PTR0]PTRTYP)+[M:PTR0]PTRNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   #------ Etat de la réception (facturée-comptabilisé-imprimée) -----#
   #------ Si non rendre le bloc invisible agrandir le tableau des lignes
   #------ Si numéro commande affiché en fin déplacer les zones en fin de lignes
   If [M:PTR1]STAFLG=1 | ([M:PTR2]POHNLCOD=2 & [M:PTR2]POHNLFLG=2)
      Gosub MODIF_ECRAN : If GOK<1 Return : Endif
   Endif
   If [M:PTR1]PRIFLG=1    TZONE(IZON)="NETPRI"              : # Prix net
                          TMOD(IZON) =3
                          IZON+=1
   Endif
   If [M:PTR1]PRISCR>1    TZONE(IZON)="NETPRI"
                          TMOD(IZON) =9
                          TINT(IZON) =num$([M:PTR1]PRISCR)
                          IZON+=1
   Endif
   If [M:PTR1]LINAMTFLG=1 TZONE(IZON)="LINAMT"              : # Montant lignes
                          TMOD(IZON) =3
                          IZON+=1
   Endif
   If [M:PTR1]LINAMTSCR>1 TZONE(IZON)="LINAMT"
                          TMOD(IZON) =9
                          # FGR 19/01/2010 : X3SUIVI60986
                          #TINT(IZON) =num$([M:PTR1]LINAMT)
                          TINT(IZON) =num$([M:PTR1]LINAMTSCR)
                          IZON+=1
   Endif
   If [M:PTR1]QUAFLG=1    TZONE(IZON)="QUAFLG"              : # Soumis à contrôle
                          TMOD(IZON) =3
                          IZON+=1
   Endif
   If [M:PTR1]QUASCR>1    TZONE(IZON)="QUAFLG"
                          TMOD(IZON) =9
                          TINT(IZON) =num$([M:PTR1]QUAFLG)
                          IZON+=1
   Endif
   If [M:PTR1]LININVFLG=1 TZONE(IZON)="LININVFLG"           : # Ligne facturée
                          TMOD(IZON) =3
                          IZON+=1
   Endif
   If [M:PTR1]LININVSCR>1 TZONE(IZON)="LININVFLG"
                          TMOD(IZON) =9
                          TINT(IZON) =num$([M:PTR1]LININVSCR)
                          IZON+=1
   Endif
   If [M:PTR1]MFGNUMFLG=1 TZONE(IZON)="VCRNUMORI"           : # No ordre fab/sst
                          TMOD(IZON) =3
                          IZON+=1
   Endif
   If [M:PTR1]MFGNUMSCR>1 TZONE(IZON)="VCRNUMORI"
                          TMOD(IZON) =9
                          TINT(IZON) =num$([M:PTR1]MFGNUMSCR)
                          IZON+=1
   Endif
   If [M:PTR1]PUUFLG<>2   TZONE(IZON)="PUU"                 : # Unité d'achat
                          TMOD(IZON) =3
                          IZON+=1
   Endif
   If [M:PTR1]PUUSCR>1    TZONE(IZON)="PUU"
                          TMOD(IZON) =9
                          TINT(IZON) =num$([M:PTR1]PUUSCR)
                          IZON+=1
   Endif
   If [M:PTR1]MATFLG<>2   TZONE(IZON)="MATEXP"                 : # Unité d'achat
                          TMOD(IZON) =3
                          IZON+=1
   Endif
   If [M:PTR1]MATFLG<>2   TZONE(IZON)="TWMSTA"                 : # GRNA Three Way Matching
                          TMOD(IZON) =3
                          IZON+=1
   Endif

   If [M:PTR2]POHNLCOD>1   TZONE(IZON)="POHNUM"             : # Numéro de commande
                           TMOD(IZON) =[M:PTR2]POHNLCOD
                           IZON+=1
                           TZONE(IZON)="POPLIN"             : # Numéro de ligne de commande
                           TMOD(IZON) =[M:PTR2]POHNLCOD
                           IZON+=1
   Endif
   If [M:PTR2]POHNLSCR>1   TZONE(IZON)="POHNUM"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]POHNLSCR)
                           IZON+=1
                           TZONE(IZON)="POPLIN"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]POHNLSCR)
                           IZON+=1
   Endif
   If [M:PTR2]ITMDESCOD>1  TZONE(IZON)="ITMDES"             : # Désignation traduite
                           TMOD(IZON) =[M:PTR2]ITMDESCOD
                           IZON+=1
   Endif
   If [M:PTR2]ITMDESSCR>1  TZONE(IZON)="ITMDES"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]ITMDESSCR)
                           IZON+=1
   Endif
   If [M:PTR2]ITMDES1COD>1 TZONE(IZON)="ITMDES1"            : # Désignation standard
                           TMOD(IZON) =[M:PTR2]ITMDES1COD
                           IZON+=1
   Endif
   If [M:PTR2]ITMDES1SCR>1 TZONE(IZON)="ITMDES1"            : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]ITMDES1SCR)
                           IZON+=1
   Endif
   # Issue 112754 - 2016-09-30 by MUARN : type d'article
   If [M:PTR2]ITMKNDCOD>1  TZONE(IZON)="ITMKND"          : # Type d'article
                           TMOD(IZON) =[M:PTR2]ITMKNDCOD
                           IZON+=1
   Endif
   If [M:PTR2]ITMKNDSCR>1  TZONE(IZON)="ITMKND"
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]ITMKNDSCR)
                           IZON+=1
   Endif
   # End issue 112754
   If [M:PTR2]TRSFAMCOD>1  TZONE(IZON)="TRSFAM"             : # Famille mouvement
                           TMOD(IZON) =[M:PTR2]TRSFAMCOD
                           IZON+=1
   Endif
   If [M:PTR2]TRSFAMSCR>1  TZONE(IZON)="TRSFAM"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]TRSFAMSCR)
                           IZON+=1
   Endif
   If [M:PTR2]PJTCOD>1     TZONE(IZON)="PJT"                : # Affaire
                           TMOD(IZON) =[M:PTR2]PJTCOD
                           IZON+=1
   Endif
   If [M:PTR2]PJTSCR>1     TZONE(IZON)="PJT"                : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]PJTSCR)
                           IZON+=1
   Endif
   If [M:PTR1]LEDTYPSCR>1
     For I=0 To 9
       TZONE(IZON)="LINACC"+num$(I+1)
       TMOD(IZON) =9
       TINT(IZON) =num$([M:PTR1]LEDTYPSCR)
       IZON+=1
     Next I
   Endif
   If [M:PTR2]PURTYPCOD>1  TZONE(IZON)="LINPURTYP"          : # Type achat
                           TMOD(IZON) =[M:PTR2]PURTYPCOD
                           IZON+=1
   Endif
   If [M:PTR2]PURTYPSCR>1  TZONE(IZON)="LINPURTYP"          : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]PURTYPSCR)
                           IZON+=1
   Endif
   If [M:DST]CCESCR>1
     For I=0 To 19
       TZONE(IZON)="CCE"+num$(I+1)
       TMOD(IZON) =9
       TINT(IZON) =num$([M:DST]CCESCR)
       IZON+=1
     Next I
   Endif
   If GACTDEB=2
     If dim([M:PTR2]EECINCCOD)>0
       If [M:PTR2]EECINCCOD>1  TZONE(IZON)="EECINCRAT"      : # Maj CEE
                               TMOD(IZON) =[M:PTR2]EECINCCOD
                               IZON+=1
       Endif
     Endif
     If dim([M:PTR2]EECINCSCR)>0
       If [M:PTR2]EECINCSCR>1  TZONE(IZON)="EECINCRAT"      : # Présentation tableau
                               TMOD(IZON) =9
                               TINT(IZON) =num$([M:PTR2]EECINCSCR)
                               IZON+=1
       Endif
     Endif
   Endif
   If [M:PTR2]ORICRYCOD>1  TZONE(IZON)="ORICRY"             : # Pays d'origine
                           TMOD(IZON) =[M:PTR2]ORICRYCOD
                           IZON+=1
   Endif
   If [M:PTR2]ORICRYSCR>1  TZONE(IZON)="ORICRY"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]ORICRYSCR)
                           IZON+=1
   Endif

   If [M:PTR2]MATTOLCOD>1  TZONE(IZON)="MATTOL"             : # Three way matching
                           TMOD(IZON) =[M:PTR2]MATTOLCOD
                           IZON+=1
   Endif
   If [M:PTR2]MATTOLSCR>1  TZONE(IZON)="MATTOL"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]MATTOLSCR)
                           IZON+=1
   Endif
   If [M:PTR2]VAT1COD>1    TZONE(IZON)="VAT1"               : # Code taxe 1
                           TMOD(IZON) =[M:PTR2]VAT1COD
                           IZON+=1
   Endif
   If [M:PTR2]VAT1SCR>1    TZONE(IZON)="VAT1"
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]VAT1SCR)
                           IZON+=1
   Endif
   If [M:PTR2]VAT2COD>1    TZONE(IZON)="VAT2"               : # Code taxe 2
                           TMOD(IZON) =[M:PTR2]VAT2COD
                           IZON+=1
   Endif
   If [M:PTR2]VAT2SCR>1    TZONE(IZON)="VAT2"
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]VAT2SCR)
                           IZON+=1
   Endif
   If [M:PTR2]VAT3COD>1    TZONE(IZON)="VAT3"               : # Code taxe 3
                           TMOD(IZON) =[M:PTR2]VAT3COD
                           IZON+=1
   Endif
   If [M:PTR2]VAT3SCR>1    TZONE(IZON)="VAT3"
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR2]VAT3SCR)
                           IZON+=1
   Endif
   If dim([M:PTR2]TAXRCPCOD)>0
     If [M:PTR2]TAXRCPCOD>1  TZONE(IZON)="TAXRCP"
                             TMOD(IZON) =[M:PTR2]TAXRCPCOD
                             IZON+=1
     Endif
     If [M:PTR2]TAXRCPSCR>1  TZONE(IZON)="TAXRCP"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR2]TAXRCPSCR)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTR2]TAXISSCOD)>0
     If [M:PTR2]TAXISSCOD>1  TZONE(IZON)="TAXISS"
                             TMOD(IZON) =[M:PTR2]TAXISSCOD
                             IZON+=1
     Endif
     If [M:PTR2]TAXISSSCR>1  TZONE(IZON)="TAXISS"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR2]TAXISSSCR)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTR2]TAXOTH1COD)>0
     If [M:PTR2]TAXOTH1COD>1 TZONE(IZON)="TAXOTH1"
                             TMOD(IZON) =[M:PTR2]TAXOTH1COD
                             IZON+=1
     Endif
     If [M:PTR2]TAXOTH1SCR>1 TZONE(IZON)="TAXOTH1"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR2]TAXOTH1SCR)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTR2]TAXOTH2COD)>0
     If [M:PTR2]TAXOTH2COD>1 TZONE(IZON)="TAXOTH2"
                             TMOD(IZON) =[M:PTR2]TAXOTH2COD
                             IZON+=1
     Endif
     If [M:PTR2]TAXOTH2SCR>1 TZONE(IZON)="TAXOTH2"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR2]TAXOTH2SCR)
                             IZON+=1
     Endif
   Endif
   If [M:PTR3]GROPRICOD>1  TZONE(IZON)="GROPRI"             : # Prix brut
                           TMOD(IZON) =[M:PTR3]GROPRICOD
                           IZON+=1
   Endif
   If [M:PTR3]GROPRISCR>1  TZONE(IZON)="GROPRI"             : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:PTR3]GROPRISCR)
                           IZON+=1
   Endif
   If dim([M:PTR3]DISCRGCOD1)>0
     If [M:PTR3]DISCRGCOD1>1 TZONE(IZON)="DISCRGVAL1"
                             TMOD(IZON) =[M:PTR3]DISCRGCOD1
                             IZON+=1
     Endif
     If [M:PTR3]DISCRGSCR1>1 TZONE(IZON)="DISCRGVAL1"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR3]DISCRGSCR1)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTR3]DISCRGCOD2)>0
     If [M:PTR3]DISCRGCOD2>1 TZONE(IZON)="DISCRGVAL2"
                             TMOD(IZON) =[M:PTR3]DISCRGCOD2
                             IZON+=1
     Endif
     If [M:PTR3]DISCRGSCR2>1 TZONE(IZON)="DISCRGVAL2"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTR3]DISCRGSCR2)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTR3]DISCRGCOD3)>0
     If [M:PTR3]DISCRGCOD3>1 TZONE(IZON)="DISCRGVAL3"
                             TMOD(IZON) =[M:PTR3]DISCRGCOD3
                             IZON+=1
     Endif
     If [M:PTR3]DISCRGSCR3>1 TZONE(IZON)="DISCRGVAL3"
                             TMOD(IZON) =9
