       Endif
  When "CPRCOD"
       If val(CZ)=3
         [M:PTR3]CPRSCR=1
         If !GIMPORT Affzo [PTR3]CPRSCR  : Grizo [PTR3]CPRSCR    : Endif
       Elsif !GIMPORT
