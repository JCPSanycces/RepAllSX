#<AdxTL>@(#)3.0.0.0 $Revision$ 
#######################################################################
# SUBPTR : Transactions de saisie des réceptions std                  #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:PTR]PURTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWB]AWINBRO  Table des browsers            #
#                       [F:AWT]AWINBOUT Table des boutons             #
#                                                                     #
# Génération de 1 écrans de saisie à partir des écrans de base PTH0   #
#                                                              PTH1   #
#                                                              PTH2   #
#                                                                     #
# Nom des écrans générés : WExyyyyyz                                  #
#                            x = 1 pour appels d'offre                #
#                                2 pour demandes d'achat              #
#                                3 pour commandes std et par article  #
#                                5 pour commandes ouvertes            #
#                                6 pour réceptions                    #
#                                8 pour factures / avoirs             #
#                                                                     #
#                        yyyyy = nom de la transaction (PTRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                0 et 1 pour appels d'offre           #
#                                1 pour demandes d'achat              #
#                                1 ,2 et 3 pour commandes standards   #
#                                9 pour commandes par article         #
#                                0, 1 et 2 pour commandes ouvertes    #
#                                0, 1, 2 et 3 pour réceptions         #
#                                0, 1, 2, 3 et 4 pour factures/avoirs #
#######################################################################

Call OBJET("PTR",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="PTR"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=6
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:PTR0]PTRTYP=6
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="PURTRS" & IDENT1=num$([F:PTR]PTRTYP) & IDENT2=[F:PTR]PTRNUM
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="PTR"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBETR : # Sélection sur code pièce auto
 When "FERME"       : Call IMPSCR      From ATRTX3
 When Default
Endcase
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto
Local Char APPLI    : APPLI=nomap
Local Char WMODU(2) : WMODU="E"
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WNUM
Local Shortint WENAFLG
Return

#---------------------------------------------------#
# Ne traiter que les transactions de type réception #
#---------------------------------------------------#
$FILTRE
FILTSUP="PTRTYP=6"
Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
If GREP<>"" | !CLECUR | GHISTO
  Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
#----- Suppression de l'option "Changement de clé" -----#
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case REP
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#----------------------------------------#
# Après lecture de chaque enregistrement #
#----------------------------------------#
$LIENS
If [M:PTR1]LEDTYPSCR=0  [M:PTR1]LEDTYPSCR=1  : Endif
#-----
If dim([M:PTR1]NBLEDTYP)>0 & len(mess(0,2644,1))>0
  If [M:PTR1]NBLEDTYP=0  [M:PTR1]NBLEDTYP=len(mess(0,2644,1)) : Affzo [PTR1]20 : Endif
  For nolign=1 To [M:PTR1]NBLEDTYP
    If [M:PTR1]LEDTYPCOD(nolign-1)=0  [M:PTR1]LEDTYPCOD(nolign-1)=1 : Endif
    If func TRTX3CPT.TYPLEDAUTO(nolign)
      [M:PTR1]LEDTYPCOD(nolign-1)=3
      Grizo  [PTR1]LEDTYPCOD(nolign-1)
      Chgstl [PTR1]LEDTYPCOD(nolign-1) With "ITALIQUE"
    Endif
  Next nolign
Endif
#-----
[M:PTR2]ITMDES1COD=[F:PTR]ITMDESCOD(1)
[M:PTR2]ITMDES1SCR=[F:PTR]ITMDESSCR(1)
[M:PTR2]VAT1COD   =[F:PTR]VATCOD(0)
[M:PTR2]VAT1SCR   =[F:PTR]VATSCR(0)
[M:PTR2]VAT2COD   =[F:PTR]VATCOD(1)
[M:PTR2]VAT2SCR   =[F:PTR]VATSCR(1)
[M:PTR2]VAT3COD   =[F:PTR]VATCOD(2)
[M:PTR2]VAT3SCR   =[F:PTR]VATSCR(2)
If dim([M:PTR3]TAXRCPCOD)>0
  [M:PTR2]TAXRCPCOD =[F:PTR]VATCOD(3)
  [M:PTR2]TAXRCPSCR =[F:PTR]VATSCR(3)
  [M:PTR2]TAXISSCOD =[F:PTR]VATCOD(4)
  [M:PTR2]TAXISSSCR =[F:PTR]VATSCR(4)
  [M:PTR2]TAXOTH1COD=[F:PTR]VATCOD(5)
  [M:PTR2]TAXOTH1SCR=[F:PTR]VATSCR(5)
  [M:PTR2]TAXOTH2COD=[F:PTR]VATCOD(6)
  [M:PTR2]TAXOTH2SCR=[F:PTR]VATSCR(6)
Endif
If dim([M:PTR3]DISCRGCOD1)>0
  [M:PTR3]DISCRGCOD1=[F:PTR]DISCRGCOD(0)
  [M:PTR3]DISCRGSCR1=[F:PTR]DISCRGSCR(0)
Endif
If dim([M:PTR3]DISCRGCOD2)>0
  [M:PTR3]DISCRGCOD2=[F:PTR]DISCRGCOD(1)
  [M:PTR3]DISCRGSCR2=[F:PTR]DISCRGSCR(1)
Endif
If dim([M:PTR3]DISCRGCOD3)>0
  [M:PTR3]DISCRGCOD3=[F:PTR]DISCRGCOD(2)
  [M:PTR3]DISCRGSCR3=[F:PTR]DISCRGSCR(2)
Endif
If dim([M:PTR3]DISCRGCOD4)>0
  [M:PTR3]DISCRGCOD4=[F:PTR]DISCRGCOD(3)
  [M:PTR3]DISCRGSCR4=[F:PTR]DISCRGSCR(3)
Endif
If dim([M:PTR3]DISCRGCOD5)>0
  [M:PTR3]DISCRGCOD5=[F:PTR]DISCRGCOD(4)
  [M:PTR3]DISCRGSCR5=[F:PTR]DISCRGSCR(4)
Endif
If dim([M:PTR3]DISCRGCOD6)>0
  [M:PTR3]DISCRGCOD6=[F:PTR]DISCRGCOD(5)
  [M:PTR3]DISCRGSCR6=[F:PTR]DISCRGSCR(5)
Endif
If dim([M:PTR3]DISCRGCOD7)>0
  [M:PTR3]DISCRGCOD7=[F:PTR]DISCRGCOD(6)
  [M:PTR3]DISCRGSCR7=[F:PTR]DISCRGSCR(6)
Endif
If dim([M:PTR3]DISCRGCOD8)>0
  [M:PTR3]DISCRGCOD8=[F:PTR]DISCRGCOD(7)
  [M:PTR3]DISCRGSCR8=[F:PTR]DISCRGSCR(7)
Endif
If dim([M:PTR3]DISCRGCOD9)>0
  [M:PTR3]DISCRGCOD9=[F:PTR]DISCRGCOD(8)
  [M:PTR3]DISCRGSCR9=[F:PTR]DISCRGSCR(8)
Endif
If dim([M:PTR2]MATTOLCOD)>0      # Three Way Matching
 If [M:PTR2]MATTOLCOD<1
  [M:PTR2]MATTOLCOD=3
  [M:PTR2]MATTOLSCR=1
 Endif
Endif
#-----
[M:ETR2]BPSLOTCOD1=[F:PTR]BPSLOTCOD(1)
[M:ETR2]MVTPRICOD1=[F:PTR]MVTPRICOD(1)
[M:ETR2]SERECOD1  =[F:PTR]SERECOD  (1)
[M:ETR2]MVTDESCOD1=[F:PTR]MVTDESCOD(1)
[M:ETR2]BPSLOTSCR1=[F:PTR]BPSLOTSCR(1)
[M:ETR2]SERESCR1  =[F:PTR]SERESCR  (1)
#-- Positionnement des valeurs si non renseignées
#** Onglet entête
If [M:PTR0]ENAFLG=0 [M:PTR0]ENAFLG=2         : Endif
#** Onglet général
If [M:PTR1]DOCFLG=0     [M:PTR1]DOCFLG=1     : Endif : # Impression auto (non)
If [M:PTR1]STAFLG=0     [M:PTR1]STAFLG=2     : Endif : # Etat de la réception (oui)
If [M:PTR1]PRIFLG=0     [M:PTR1]PRIFLG=1     : Endif : # Prix net (non)
If [M:PTR1]LINAMTFLG=0  [M:PTR1]LINAMTFLG=1  : Endif : # Montant ligne HT (non)
If [M:PTR1]QUAFLG=0     [M:PTR1]QUAFLG=1     : Endif : # Soumis QC (non)
If [M:PTR1]LININVFLG=0  [M:PTR1]LININVFLG=1  : Endif : # Lg facturée (non)
If [M:PTR1]MFGNUMFLG=0  [M:PTR1]MFGNUMFLG=1  : Endif : # No ordre fab/sst (non)
If [M:PTR1]MFGNUMSCR=0  [M:PTR1]MFGNUMSCR=1  : Endif
If [M:PTR1]SRGWAIFLG=0  [M:PTR1]SRGWAIFLG=1  : Endif : # A quai  (non)
If [M:PTR1]PUUFLG=0     [M:PTR1]PUUFLG=1     : Endif : # Affichage unité d'achat (non)
If [M:PTR1]PUUSCR=0     [M:PTR1]PUUSCR=1     : Endif
If [M:PTR1]MATFLG=0     [M:PTR1]MATFLG=1     : Endif : # Match explanation (non)
If [M:PTR1]VLTFDRCOD=0  [M:PTR1]VLTFDRCOD=2  : Endif : # Onglet de valorisation
# Issue 84130 - 2013-01-25 by MUARN : landed cost
If [M:PTR1]CSTCOD=0     [M:PTR1]CSTCOD=2     : Endif    : # Onglet coût

#** Onglet ligne1
If [M:PTR2]POHNLCOD=0   [M:PTR2]POHNLCOD=1   : Endif : # Numéro commande et ligne cde (saisie)
If [M:PTR2]POHNLFLG=0   [M:PTR2]POHNLFLG=1   : Endif : # Positionnement (début)
If [M:PTR2]ITMDESCOD=0  [M:PTR2]ITMDESCOD=2  : Endif : # Désignation traduite (affichée)
If [M:PTR2]ITMDES1COD=0 [M:PTR2]ITMDES1COD=3 : Endif : # Désignation standard (invisible)
# Issue 112754 - 2016-09-30 by MUARN : type d'article
If [M:PTR2]ITMKNDCOD=0  [M:PTR2]ITMKNDCOD=2  : Endif : # Type d'article
If [M:PTR2]ITMKNDSCR=0  [M:PTR2]ITMKNDSCR=1  : Endif
If [M:PTR2]TRSFAMCOD=0  [M:PTR2]TRSFAMCOD=3  : Endif : # Famille (invisible)
If [M:PTR2]PJTCOD=0     [M:PTR2]PJTCOD=3     : Endif : # Affaire (invisible)
If [M:PTR2]PURTYPCOD=0  [M:PTR2]PURTYPCOD=3  : Endif : # Type d'achat (invisible)
If GACTDEB=2 & dim([M:PTR2]EECINCCOD)>0
  If [M:PTR2]EECINCCOD=0 [M:PTR2]EECINCCOD=1 : Endif : # MAJ CEE (saisie)
Endif
If [M:PTR2]ORICRYCOD=0  [M:PTR2]ORICRYCOD=1  : Endif : # Pays d'origine (saisie)
If [M:PTR2]MATTOLCOD=0  [M:PTR2]MATTOLCOD=1  : Endif : # Matching Tolerance (saisie)
If [M:PTR2]VAT1COD=0    [M:PTR2]VAT1COD=1    : Endif : # Code taxe 1 (saisie)
If [M:PTR2]VAT1SCR=0    [M:PTR2]VAT1SCR=1    : Endif
If [M:PTR2]VAT2COD=0    [M:PTR2]VAT2COD=1    : Endif : # Code taxe 2 (saisie)
If [M:PTR2]VAT2SCR=0    [M:PTR2]VAT2SCR=1    : Endif
If [M:PTR2]VAT3COD=0    [M:PTR2]VAT3COD=1    : Endif : # Code taxe 3 (saisie)
If [M:PTR2]VAT3SCR=0    [M:PTR2]VAT3SCR=1    : Endif
If dim([M:PTR2]TAXRCPCOD)>0
  If [M:PTR2]TAXRCPCOD=0  [M:PTR2]TAXRCPCOD=3  : Endif : # Taxe entrée
  If [M:PTR2]TAXRCPSCR=0  [M:PTR2]TAXRCPSCR=1  : Endif
Endif
If dim([M:PTR2]TAXISSCOD)>0
  If [M:PTR2]TAXISSCOD=0  [M:PTR2]TAXISSCOD=3  : Endif : # Taxe sortie
  If [M:PTR2]TAXISSSCR=0  [M:PTR2]TAXISSSCR=1  : Endif
Endif
If dim([M:PTR2]TAXOTH1COD)>0
  If [M:PTR2]TAXOTH1COD=0 [M:PTR2]TAXOTH1COD=3 : Endif : # Autre taxe 1
  If [M:PTR2]TAXOTH1SCR=0 [M:PTR2]TAXOTH1SCR=1 : Endif
Endif
If dim([M:PTR2]TAXOTH2COD)>0
  If [M:PTR2]TAXOTH2COD=0 [M:PTR2]TAXOTH2COD=3 : Endif : # Autre taxe 2
  If [M:PTR2]TAXOTH2SCR=0 [M:PTR2]TAXOTH2SCR=1 : Endif
Endif
#** Onglet ligne2
If [M:PTR3]GROPRICOD=0  [M:PTR3]GROPRICOD=1  : Endif : # Prix brut (saisie)
If [M:PTR3]GROPRISCR=0  [M:PTR3]GROPRISCR=1  : Endif
If dim([M:PTR3]DISCRGCOD1)>0
  If [M:PTR3]DISCRGCOD1=0 [M:PTR3]DISCRGCOD1=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD2)>0
  If [M:PTR3]DISCRGCOD2=0 [M:PTR3]DISCRGCOD2=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD3)>0
  If [M:PTR3]DISCRGCOD3=0 [M:PTR3]DISCRGCOD3=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD4)>0
  If [M:PTR3]DISCRGCOD4=0 [M:PTR3]DISCRGCOD4=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD5)>0
  If [M:PTR3]DISCRGCOD5=0 [M:PTR3]DISCRGCOD5=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD6)>0
  If [M:PTR3]DISCRGCOD6=0 [M:PTR3]DISCRGCOD6=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD7)>0
  If [M:PTR3]DISCRGCOD7=0 [M:PTR3]DISCRGCOD7=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD8)>0
  If [M:PTR3]DISCRGCOD8=0 [M:PTR3]DISCRGCOD8=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD9)>0
  If [M:PTR3]DISCRGCOD9=0 [M:PTR3]DISCRGCOD9=1 : Endif
Endif

# Issue 84129 - 2012-10-25 by MUARN : landed cost
If [M:PTR3]CPRCOECOD=0  [M:PTR3]CPRCOECOD=3  : Endif : # Coeff approche et cout fixe unitaire (invisible)
If [M:PTR3]STCNUMCOD=0  [M:PTR3]STCNUMCOD=3  : Endif # structure (invisible)
If [M:PTR3]CSTPURCOD=0  [M:PTR3]CSTPURCOD=3  : Endif # coût achat (invisible)
If [M:PTR3]CPRCOD=0     [M:PTR3]CPRCOD=3     : Endif # cout stock (invisible)

#MAE, landed cost
If [M:PTR3]QTYVOUCOD=0  [M:PTR3]QTYVOUCOD=3  : Endif : # Volume(invisible)
If [M:PTR3]QTYWEUCOD=0  [M:PTR3]QTYWEUCOD=3  : Endif : # Poids(invisible)


#-- Grisage des zones si besoin
#** Onglet Général
If [M:PTR1]PRIFLG=1     Grizo [PTR1]PRISCR     Else Actzo [PTR1]PRISCR    : Endif
If [M:PTR1]LINAMTFLG=1  Grizo [PTR1]LINAMTSCR  Else Actzo [PTR1]LINAMTSCR : Endif
If [M:PTR1]QUAFLG=1     Grizo [PTR1]QUASCR     Else Actzo [PTR1]QUASCR    : Endif
If [M:PTR1]LININVFLG=1  Grizo [PTR1]LININVSCR  Else Actzo [PTR1]LININVSCR : Endif
If [M:PTR1]MFGNUMFLG=1  Grizo [PTR1]MFGNUMSCR  Else Actzo [PTR1]MFGNUMSCR : Endif
If [M:PTR1]PUUFLG=1     Grizo [PTR1]PUUSCR     Else Actzo [PTR1]PUUSCR    : Endif

#** Onglet ligne 1
If [M:PTR2]POHNLCOD=3 | [M:PTR2]POHNLCOD=1 Grizo [PTR2]POHNLSCR, POHNLFLG
  Else Actzo [PTR2]POHNLSCR,POHNLFLG
Endif
If [M:PTR2]ITMDESCOD=3  Grizo [PTR2]ITMDESSCR  Else Actzo [PTR2]ITMDESSCR : Endif
If [M:PTR2]ITMDES1COD=3 Grizo [PTR2]ITMDES1SCR Else Actzo [PTR2]ITMDES1SCR: Endif
# Issue 112754 - 2016-09-30 by MUARN : type d'article
If [PTR2]ITMKNDCOD=3    Grizo [PTR2]ITMKNDSCR  Else Actzo [PTR2]ITMKNDSCR  : Endif
If [M:PTR2]TRSFAMCOD=3  Grizo [PTR2]TRSFAMSCR  Else Actzo [PTR2]TRSFAMSCR : Endif
If [M:PTR2]PJTCOD=3     Grizo [PTR2]PJTSCR     Else Actzo [PTR2]PJTSCR    : Endif
If [M:PTR2]PURTYPCOD=3  Grizo [PTR2]PURTYPSCR  Else Actzo [PTR2]PURTYPSCR : Endif
If GACTDEB=2 & dim([M:PTR2]EECINCCOD)>0 & dim([M:PTR2]EECINCSCR)>0
  If [M:PTR2]EECINCCOD=3 Grizo [PTR2]EECINCSCR Else Actzo [PTR2]EECINCSCR : Endif
Endif
If [M:PTR2]ORICRYCOD=3  Grizo [PTR2]ORICRYSCR  Else Actzo [PTR2]ORICRYSCR : Endif
If [M:PTR2]MATTOLCOD=3  Grizo [PTR2]MATTOLSCR  Else Actzo [PTR2]MATTOLSCR : Endif
If [M:PTR2]VAT1COD=3    Grizo [PTR2]VAT1SCR    Else Actzo [PTR2]VAT1SCR   : Endif
If [M:PTR2]VAT2COD=3    Grizo [PTR2]VAT2SCR    Else Actzo [PTR2]VAT2SCR   : Endif
If [M:PTR2]VAT3COD=3    Grizo [PTR2]VAT3SCR    Else Actzo [PTR2]VAT3SCR   : Endif
If dim([M:PTR2]TAXRCPCOD)>0
  If [M:PTR2]TAXRCPCOD=3  Grizo [PTR2]TAXRCPSCR  Else Actzo [PTR2]TAXRCPSCR  : Endif
Endif
If dim([M:PTR2]TAXISSCOD)>0
  If [M:PTR2]TAXISSCOD=3  Grizo [PTR2]TAXISSSCR  Else Actzo [PTR2]TAXISSSCR  : Endif
Endif
If dim([M:PTR2]TAXOTH1COD)>0
  If [M:PTR2]TAXOTH1COD=3 Grizo [PTR2]TAXOTH1SCR Else Actzo [PTR2]TAXOTH1SCR : Endif
Endif
If dim([M:PTR2]TAXOTH2COD)>0
  If [M:PTR2]TAXOTH2COD=3 Grizo [PTR2]TAXOTH2SCR Else Actzo [PTR2]TAXOTH2SCR : Endif
Endif
#** Onglet ligne 2
If [M:PTR3]GROPRICOD=3  Grizo [PTR3]GROPRISCR  Else Actzo [PTR3]GROPRISCR : Endif
If dim([M:PTR3]DISCRGCOD1)>0
  If [M:PTR3]DISCRGCOD1=3 Grizo [PTR3]DISCRGSCR1 Else Actzo [PTR3]DISCRGSCR1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD2)>0
  If [M:PTR3]DISCRGCOD2=3 Grizo [PTR3]DISCRGSCR2 Else Actzo [PTR3]DISCRGSCR2 : Endif
Endif
If dim([M:PTR3]DISCRGCOD3)>0
  If [M:PTR3]DISCRGCOD3=3 Grizo [PTR3]DISCRGSCR3 Else Actzo [PTR3]DISCRGSCR3 : Endif
Endif
If dim([M:PTR3]DISCRGCOD4)>0
  If [M:PTR3]DISCRGCOD4=3 Grizo [PTR3]DISCRGSCR4 Else Actzo [PTR3]DISCRGSCR4 : Endif
Endif
If dim([M:PTR3]DISCRGCOD5)>0
  If [M:PTR3]DISCRGCOD5=3 Grizo [PTR3]DISCRGSCR5 Else Actzo [PTR3]DISCRGSCR5 : Endif
Endif
If dim([M:PTR3]DISCRGCOD6)>0
  If [M:PTR3]DISCRGCOD6=3 Grizo [PTR3]DISCRGSCR6 Else Actzo [PTR3]DISCRGSCR6 : Endif
Endif
If dim([M:PTR3]DISCRGCOD7)>0
  If [M:PTR3]DISCRGCOD7=3 Grizo [PTR3]DISCRGSCR7 Else Actzo [PTR3]DISCRGSCR7 : Endif
Endif
If dim([M:PTR3]DISCRGCOD8)>0
  If [M:PTR3]DISCRGCOD8=3 Grizo [PTR3]DISCRGSCR8 Else Actzo [PTR3]DISCRGSCR8 : Endif
Endif
If dim([M:PTR3]DISCRGCOD9)>0
  If [M:PTR3]DISCRGCOD9=3 Grizo [PTR3]DISCRGSCR9 Else Actzo [PTR3]DISCRGSCR9 : Endif
Endif

# Issue 84129 - 2012-10-25 by MUARN : landed cost
If [M:PTR3]CPRCOECOD=3  Grizo [PTR3]CPRCOESCR  Else Actzo [PTR3]CPRCOESCR : Endif
If [M:PTR3]STCNUMCOD=3  Grizo [PTR3]STCNUMSCR  Else Actzo [PTR3]STCNUMSCR Endif
If [M:PTR3]CSTPURCOD=3  Grizo [PTR3]CSTPURSCR  Else Actzo [PTR3]CSTPURSCR Endif
If [M:PTR3]CPRCOD=3     Grizo [PTR3]CPRSCR     Else Actzo [PTR3]CPRSCR Endif

#MAE, landed cost
If [M:PTR3]QTYVOUCOD=3  Grizo [PTR3]QTYVOUSCR  Else Actzo [PTR3]QTYVOUSCR : Endif
If [M:PTR3]QTYWEUCOD=3  Grizo [PTR3]QTYWEUSCR  Else Actzo [PTR3]QTYWEUSCR : Endif

If dim([M:PTR1]WRHCOD) >0
    If [M:PTR1]WRHCOD=0  [M:PTR1]WRHCOD=3  : Endif : # Dépôt
Endif
If dim([M:PTR1]WRHCOD) >0
  If [M:PTR1]WRHOBY = 2
    Grizo [M:PTR1]WRHCOD
  Else
    Actzo [M:PTR1]WRHCOD
  Endif
Endif
# Issue 71069 - 2013-07-30 by MAE : PJT en en-tête
If [M:PTR1]PJTHCOD=0  [M:PTR1]PJTHCOD=3  : Endif : # Affaire : sr revue de code (modif commentaire)
#fin MAE
If dim(WMODU)<1  Local Char WMODU(2) : WMODU="E" : Endif
WMODU+=num$([M:PTR0]PTRTYP)
Gosub LIENS From SUBETR
Gosub PE_PURTRS From SUBPTX
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
Actzo [PTR0]
Actzo [PTR1]
Actzo [PTR2]
Actzo [PTR3]
#** Onglet réception
[M:PTR0]PTRTYP=6
[M:PTR0]ENAFLG=2
#** Onglet général
[M:PTR1]LEDTYPSCR=1
If dim([M:PTR1]NBLEDTYP)>0
  [M:PTR1]NBLEDTYP=len(mess(0,2644,1)) : Affzo [PTR1]20
  For nolign=1 To [M:PTR1]NBLEDTYP
    [M:PTR1]LEDTYPINT(nolign-1)=nolign
    If func TRTX3CPT.TYPLEDAUTO(nolign)
      [M:PTR1]LEDTYPCOD(nolign-1)=3
      Grizo  [PTR1]LEDTYPCOD(nolign-1)
      Chgstl [PTR1]LEDTYPCOD(nolign-1) With "ITALIQUE"
    Else
      [M:PTR1]LEDTYPCOD(nolign-1)=1
    Endif
  Next nolign
Endif
#-----
[M:PTR1]DOCFLG=1
[M:PTR1]STAFLG=2
[M:PTR1]PRIFLG=1
[M:PTR1]LINAMTFLG=1
[M:PTR1]QUAFLG=1
[M:PTR1]LININVFLG=1
[M:PTR1]MFGNUMFLG=1
[M:PTR1]MFGNUMSCR=1
[M:PTR1]NBRCOL=2
[M:PTR1]SRGWAIFLG=1   : # A quai (non)
[M:PTR1]PUUFLG=1      : # Affichage UA (non)
[M:PTR1]PUUSCR=1
[M:PTR1]MATFLG=1      : # Match Explanation (non)
[M:PTR1]VLTFDRCOD=2   : # Onglet valorisation affiché
# Issue 84130 - 2013-01-25 by MUARN : landed cost
[M:PTR1]CSTCOD=2   : # Onglet coût affiché

# Issue 71069 - 2013-07-30 by MAE : PJT en en-tête
[M:PTR1]PJTHCOD=3

If dim([M:PTR1]WRHCOD)>0 [M:PTR1]WRHCOD=3 Endif
#** Onglet ligne1
[M:PTR2]POHNLCOD=1    : # Numéro commande et ligne cde (saisie)
[M:PTR2]POHNLSCR=1
[M:PTR2]POHNLFLG=1    : # Début de ligne
[M:PTR2]ITMDESCOD=2   : # Désignation traduite (affichée)
[M:PTR2]ITMDESSCR=1
[M:PTR2]ITMDES1COD=3  : # Désignation standard (invisible)
[M:PTR2]ITMDES1SCR=1
# Issue 112754 - 2016-09-30 by MUARN : type d'article
[M:PTR2]ITMKNDCOD=2
[M:PTR2]ITMKNDSCR=1
[M:PTR2]TRSFAMCOD=3   : # Famille mvt (invisible)
[M:PTR2]TRSFAMSCR=1
[M:PTR2]PJTCOD=3      : # Affaire (invisible)
[M:PTR2]PJTSCR=1
[M:PTR2]PURTYPCOD=3   : # Type d'achat (invisible)
[M:PTR2]PURTYPSCR=1
If GACTDEB=2
  If dim([M:PTR2]EECINCCOD)>0  [M:PTR2]EECINCCOD=1 : Endif : # Maj CEE (saisie)
  If dim([M:PTR2]EECINCSCR)>0  [M:PTR2]EECINCSCR=1 : Endif
Endif
[M:PTR2]ORICRYCOD=1   : # Pays d'origine
[M:PTR2]ORICRYSCR=1
[M:PTR2]MATTOLCOD=3   : # Matching Tolerance default
[M:PTR2]MATTOLSCR=1
[M:PTR2]VAT1COD=3 : [M:PTR2]VAT1SCR=1 : Grizo [PTR2]VAT1SCR : # Code taxe 1
[M:PTR2]VAT2COD=3 : [M:PTR2]VAT2SCR=1 : Grizo [PTR2]VAT2SCR : # Code taxe 2
[M:PTR2]VAT3COD=3 : [M:PTR2]VAT3SCR=1 : Grizo [PTR2]VAT3SCR : # Code taxe 3
If dim([M:PTR2]TAXRCPCOD)>0
  [M:PTR2]TAXRCPCOD=3
  [M:PTR2]TAXRCPSCR=1
Endif
If dim([M:PTR2]TAXISSCOD)>0
  [M:PTR2]TAXISSCOD=3
  [M:PTR2]TAXISSSCR=1
Endif
If dim([M:PTR2]TAXOTH1COD)>0
  [M:PTR2]TAXOTH1COD=3
  [M:PTR2]TAXOTH1SCR=1
Endif
If dim([M:PTR2]TAXOTH2COD)>0
  [M:PTR2]TAXOTH2COD=3
  [M:PTR2]TAXOTH2SCR=1
Endif
#** Onglet ligne2
[M:PTR3]GROPRICOD=1   : # Prix brut
If dim([M:PTR3]DISCRGCOD1)>0
  If [M:PTR3]DISCRGCOD1=0 [M:PTR3]DISCRGCOD1=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD2)>0
  If [M:PTR3]DISCRGCOD2=0 [M:PTR3]DISCRGCOD2=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD3)>0
  If [M:PTR3]DISCRGCOD3=0 [M:PTR3]DISCRGCOD3=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD4)>0
  If [M:PTR3]DISCRGCOD4=0 [M:PTR3]DISCRGCOD4=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD5)>0
  If [M:PTR3]DISCRGCOD5=0 [M:PTR3]DISCRGCOD5=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD6)>0
  If [M:PTR3]DISCRGCOD6=0 [M:PTR3]DISCRGCOD6=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD7)>0
  If [M:PTR3]DISCRGCOD7=0 [M:PTR3]DISCRGCOD7=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD8)>0
  If [M:PTR3]DISCRGCOD8=0 [M:PTR3]DISCRGCOD8=1 : Endif
Endif
If dim([M:PTR3]DISCRGCOD9)>0
  If [M:PTR3]DISCRGCOD9=0 [M:PTR3]DISCRGCOD9=1 : Endif
Endif


# Issue 84129 - 2012-10-25 by MUARN : landed cost
[M:PTR3]CPRCOECOD=3   : # Coeff approche et cout unitaire (invisible)
[M:PTR3]CPRCOESCR=1
[M:PTR3]STCNUMCOD=3   : #  (invisible)
[M:PTR3]STCNUMSCR=1
[M:PTR3]CSTPURCOD=3   : #  (invisible)
[M:PTR3]CSTPURSCR=1
[M:PTR3]CPRCOD=3   : #  (invisible)
[M:PTR3]CPRSCR=1

#MAE, landed cost
[M:PTR3]QTYVOUCOD=3   : # Volume (invisible)
[M:PTR3]QTYVOUSCR=1
[M:PTR3]QTYWEUCOD=3   : # Poids (invisible)
[M:PTR3]QTYWEUSCR=1

#-- Grisage des zones si besoin
#** Onglet Général
If [M:PTR1]PRIFLG=1     Grizo [PTR1]PRISCR     : Endif
If [M:PTR1]LINAMTFLG=1  Grizo [PTR1]LINAMTSCR  : Endif
If [M:PTR1]QUAFLG=1     Grizo [PTR1]QUASCR     : Endif
If [M:PTR1]LININVFLG=1  Grizo [PTR1]LININVSCR  : Endif
If [M:PTR1]MFGNUMFLG=1  Grizo [PTR1]MFGNUMSCR  : Endif
If [M:PTR1]PUUFLG=1     Grizo [PTR1]PUUSCR     : Endif

#** Onglet réception
If [M:PTR2]POHNLCOD=3 | [M:PTR2]POHNLCOD=1  Grizo [PTR2]POHNLSCR  : Endif
If [M:PTR2]POHNLCOD<>2  Grizo [PTR2]POHNLFLG   : Endif
If [M:PTR2]ITMDESCOD=3  Grizo [PTR2]ITMDESSCR  : Endif
If [M:PTR2]ITMDES1COD=3 Grizo [PTR2]ITMDES1SCR : Endif
If [M:PTR2]TRSFAMCOD=3  Grizo [PTR2]TRSFAMSCR  : Endif
If [M:PTR2]PJTCOD=3     Grizo [PTR2]PJTSCR     : Endif
If [M:PTR2]PURTYPCOD=3  Grizo [PTR2]PURTYPSCR  : Endif
If GACTDEB=2 & dim([M:PTR2]EECINCCOD)>0 & dim([M:PTR2]EECINCSCR)>0
  If [M:PTR2]EECINCCOD=3 Grizo [PTR2]EECINCSCR : Endif
Endif
If [M:PTR2]ORICRYCOD=3  Grizo [PTR2]ORICRYSCR  : Endif
If [M:PTR2]MATTOLCOD=3  Grizo [PTR2]MATTOLSCR  : Endif
Grizo [PTR2]VAT1SCR, VAT2SCR, VAT3SCR
If dim([M:PTR2]TAXRCPSCR)>0  Grizo [PTR2]TAXRCPSCR  : Endif
If dim([M:PTR2]TAXISSSCR)>0  Grizo [PTR2]TAXISSSCR  : Endif
If dim([M:PTR2]TAXOTH1SCR)>0 Grizo [PTR2]TAXOTH1SCR : Endif
If dim([M:PTR2]TAXOTH2SCR)>0 Grizo [PTR2]TAXOTH2SCR : Endif

# Issue 84129 - 2012-10-25 by MUARN : landed cost
If [M:PTR3]CPRCOECOD=3  Grizo [PTR3]CPRCOESCR Endif
If [M:PTR3]STCNUMCOD=3  Grizo [PTR3]STCNUMSCR Endif
If [M:PTR3]CSTPURCOD=3  Grizo [PTR3]CSTPURSCR Endif
If [M:PTR3]CPRCOD=3     Grizo [PTR3]CPRSCR    Endif

#MAE, landed cost
If [M:PTR3]QTYVOUCOD=3  Grizo [PTR3]QTYVOUSCR Endif
If [M:PTR3]QTYWEUCOD=3  Grizo [PTR3]QTYWEUSCR Endif

#-----
WMODU+=num$([M:PTR0]PTRTYP)
Gosub RAZCRE    From SUBETR
#-----
Gosub PE_PURTRS From SUBPTX
Affzo [PTR0]1-99
Affzo [PTR1]1-99
Affzo [PTR2]1-99
Affzo [PTR3]1-99
Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
  When "PRIFLG"
       If val(CZ)=1
         [M:PTR1]PRISCR=1
         If !GIMPORT Affzo [PTR1]PRISCR    : Grizo [PTR1]PRISCR        : Endif
       Elsif !GIMPORT
         Actzo [PTR1]PRISCR
       Endif
  When "LINAMTFLG"
       If val(CZ)=1
         [M:PTR1]LINAMTSCR=1
         If !GIMPORT Affzo [PTR1]LINAMTSCR : Grizo [PTR1]LINAMTSCR     : Endif
       Elsif !GIMPORT
         Actzo [PTR1]LINAMTSCR
       Endif
  When "QUAFLG"
       If val(CZ)=1
         [M:PTR1]QUASCR=1
         If !GIMPORT Affzo [PTR1]QUASCR    : Grizo [PTR1]QUASCR        : Endif
       Elsif !GIMPORT
         Actzo [PTR1]QUASCR
       Endif
  When "LININVFLG"
       If val(CZ)=1
         [M:PTR1]LININVSCR=1
         If !GIMPORT Affzo [PTR1]LININVSCR : Grizo [PTR1]LININVSCR     : Endif
       Elsif !GIMPORT
         Actzo [PTR1]LININVSCR
       Endif
  When "MFGNUMFLG"
       If val(CZ)=1
         [M:PTR1]MFGNUMSCR=1
         If !GIMPORT Affzo [PTR1]MFGNUMSCR : Grizo [PTR1]MFGNUMSCR     : Endif
       Elsif !GIMPORT
         Actzo [PTR1]MFGNUMSCR
       Endif
  When "PUUFLG"
       If val(CZ)=1
         [M:PTR1]PUUSCR=1
         If !GIMPORT Affzo [PTR1]PUUSCR    : Grizo [PTR1]PUUSCR        : Endif
       Elsif !GIMPORT
         Actzo [PTR1]PUUSCR
       Endif
  When "POHNLCOD"
       If val(CZ)=3
         [M:PTR2]POHNLSCR=1
         If !GIMPORT Affzo [PTR2]POHNLSCR  : Grizo [PTR2]POHNLSCR      : Endif
       Elsif !GIMPORT
         Actzo [PTR2]POHNLSCR
       Endif
       If val(CZ)=2
         Actzo [PTR2]POHNLFLG
         Actzo [PTR2]POHNLSCR
       Else
         [M:PTR2]POHNLSCR=1
         [M:PTR2]POHNLFLG=1
         Grizo [PTR2]POHNLSCR
         Grizo [PTR2]POHNLFLG
       Endif
  When "ITMDESCOD"
       If val(CZ)=3
         [M:PTR2]ITMDESSCR=1
         If !GIMPORT Affzo [PTR2]ITMDESSCR : Grizo [PTR2]ITMDESSCR     : Endif
       Elsif !GIMPORT
         Actzo [PTR2]ITMDESSCR
       Endif
  When "ITMDES1COD"
       If val(CZ)=3
         [M:PTR2]ITMDES1SCR=1
         If !GIMPORT Affzo [PTR2]ITMDES1SCR : Grizo [PTR2]ITMDES1SCR   : Endif
       Elsif !GIMPORT
         Actzo [PTR2]ITMDES1SCR
       Endif
 When "ITMKNDCOD" # Issue 112754 - 2016-09-30 by MUARN : Type d'article
       If val(CZ)=3
         [M:PTR2]ITMKNDSCR=1
         If !GIMPORT Affzo [PTR2]ITMKNDSCR : Grizo [PTR2]ITMKNDSCR : Endif
       Elsif !GIMPORT
         Actzo [PTR2]ITMKNDSCR
       Endif
  When "TRSFAMCOD"
       If val(CZ)=3
         [M:PTR2]TRSFAMSCR=1
         If !GIMPORT Affzo [PTR2]TRSFAMSCR     : Grizo [PTR2]TRSFAMSCR       : Endif
       Elsif !GIMPORT
         Actzo [PTR2]TRSFAMSCR
       Endif
  When "PJTCOD"
       If val(CZ)=3
         [M:PTR2]PJTSCR=1
         If !GIMPORT Affzo [PTR2]PJTSCR     : Grizo [PTR2]PJTSCR       : Endif
       Elsif !GIMPORT
         Actzo [PTR2]PJTSCR
       Endif
  When "PURTYPCOD"
       If val(CZ)=3
         [M:PTR2]PURTYPSCR=1
         If !GIMPORT Affzo [PTR2]PURTYPSCR  : Grizo [PTR2]PURTYPSCR    : Endif
       Elsif !GIMPORT
         Actzo [PTR2]PURTYPSCR
       Endif
  When "EECINCCOD"
       If GACTDEB=2 & dim([M:PTR2]EECINCSCR)>0
         If val(CZ)=3
           [M:PTR2]EECINCSCR=1
           If !GIMPORT Affzo [PTR2]EECINCSCR : Grizo [PTR2]EECINCSCR   : Endif
         Elsif !GIMPORT
           Actzo [PTR2]EECINCSCR
         Endif
       Endif
  When "ORICRYCOD"
       If val(CZ)=3
         [M:PTR2]ORICRYSCR=1
         If !GIMPORT Affzo [PTR2]ORICRYSCR : Grizo [PTR2]ORICRYSCR     : Endif
       Elsif !GIMPORT
         Actzo [PTR2]ORICRYSCR
       Endif
  When "MATTOLCOD"
       If val(CZ)=3
         [M:PTR2]MATTOLSCR=1
         If !GIMPORT Affzo [PTR2]MATTOLSCR : Grizo [PTR2]MATTOLSCR     : Endif
       Elsif !GIMPORT
         Actzo [PTR2]MATTOLSCR
       Endif
  When "VAT1COD"
       If val(CZ)=3
         [M:PTR2]VAT1SCR=1
         If !GIMPORT Affzo [PTR2]VAT1SCR : Grizo [PTR2]VAT1SCR     : Endif
       Elsif !GIMPORT
         Actzo [PTR2]VAT1SCR
       Endif
  When "VAT2COD"
       If val(CZ)=3
         [M:PTR2]VAT2SCR=1
         If !GIMPORT Affzo [PTR2]VAT2SCR : Grizo [PTR2]VAT2SCR     : Endif
       Elsif !GIMPORT
         Actzo [PTR2]VAT2SCR
       Endif
  When "VAT3COD"
       If val(CZ)=3
         [M:PTR2]VAT3SCR=1
         If !GIMPORT Affzo [PTR2]VAT3SCR : Grizo [PTR2]VAT3SCR     : Endif
       Elsif !GIMPORT
         Actzo [PTR2]VAT3SCR
       Endif
  When "TAXRCPCOD"
       If val(CZ)=3
         [M:PTR2]TAXRCPSCR=1
         If !GIMPORT Affzo [PTR2]TAXRCPSCR  : Grizo [PTR2]TAXRCPSCR  : Endif
       Elsif !GIMPORT
         Actzo [PTR2]TAXRCPSCR
       Endif
  When "TAXISSCOD"
       If val(CZ)=3
         [M:PTR2]TAXISSSCR=1
         If !GIMPORT Affzo [PTR2]TAXISSSCR  : Grizo [PTR2]TAXISSSCR  : Endif
       Elsif !GIMPORT
         Actzo [PTR2]TAXISSSCR
       Endif
  When "TAXOTH1COD"
       If val(CZ)=3
         [M:PTR2]TAXOTH1SCR=1
         If !GIMPORT Affzo [PTR2]TAXOTH1SCR : Grizo [PTR2]TAXOTH1SCR : Endif
       Elsif !GIMPORT
         Actzo [PTR2]TAXOTH1SCR
       Endif
  When "TAXOTH2COD"
       If val(CZ)=3
         [M:PTR2]TAXOTH2SCR=1
         If !GIMPORT Affzo [PTR2]TAXOTH2SCR : Grizo [PTR2]TAXOTH2SCR : Endif
       Elsif !GIMPORT
         Actzo [PTR2]TAXOTH2SCR
       Endif
  When "GROPRICOD"
       If val(CZ)=3
         [M:PTR3]GROPRISCR=1
         If !GIMPORT Affzo [PTR3]GROPRISCR  : Grizo [PTR3]GROPRISCR  : Endif
       Elsif !GIMPORT
         Actzo [PTR3]GROPRISCR
       Endif
  When "DISCRGCOD1"
       If val(CZ)=3
         [M:PTR3]DISCRGSCR1=1
         If !GIMPORT Affzo [PTR3]DISCRGSCR1 : Grizo [PTR3]DISCRGSCR1 : Endif
       Elsif !GIMPORT
         Actzo [PTR3]DISCRGSCR1
       Endif
  When "DISCRGCOD2"
       If val(CZ)=3
         [M:PTR3]DISCRGSCR2=1
         If !GIMPORT Affzo [PTR3]DISCRGSCR2 : Grizo [PTR3]DISCRGSCR2 : Endif
       Elsif !GIMPORT
         Actzo [PTR3]DISCRGSCR2
       Endif
  When "DISCRGCOD3"
       If val(CZ)=3
         [M:PTR3]DISCRGSCR3=1
         If !GIMPORT Affzo [PTR3]DISCRGSCR3 : Grizo [PTR3]DISCRGSCR3 : Endif
       Elsif !GIMPORT
         Actzo [PTR3]DISCRGSCR3
       Endif
  When "DISCRGCOD4"
       If val(CZ)=3
         [M:PTR3]DISCRGSCR4=1
         If !GIMPORT Affzo [PTR3]DISCRGSCR4 : Grizo [PTR3]DISCRGSCR4 : Endif
       Elsif !GIMPORT
         Actzo [PTR3]DISCRGSCR4
       Endif
  When "DISCRGCOD5"
       If val(CZ)=3
         [M:PTR3]DISCRGSCR5=1
         If !GIMPORT Affzo [PTR3]DISCRGSCR5 : Grizo [PTR3]DISCRGSCR5 : Endif
       Elsif !GIMPORT
         Actzo [PTR3]DISCRGSCR5
       Endif
  When "DISCRGCOD6"
       If val(CZ)=3
         [M:PTR3]DISCRGSCR6=1
         If !GIMPORT Affzo [PTR3]DISCRGSCR6 : Grizo [PTR3]DISCRGSCR6 : Endif
       Elsif !GIMPORT
         Actzo [PTR3]DISCRGSCR6
       Endif
  When "DISCRGCOD7"
       If val(CZ)=3
         [M:PTR3]DISCRGSCR7=1
         If !GIMPORT Affzo [PTR3]DISCRGSCR7 : Grizo [PTR3]DISCRGSCR7 : Endif
       Elsif !GIMPORT
         Actzo [PTR3]DISCRGSCR7
       Endif
  When "DISCRGCOD8"
       If val(CZ)=3
         [M:PTR3]DISCRGSCR8=1
         If !GIMPORT Affzo [PTR3]DISCRGSCR8 : Grizo [PTR3]DISCRGSCR8 : Endif
       Elsif !GIMPORT
         Actzo [PTR3]DISCRGSCR8
       Endif
  When "DISCRGCOD9"
       If val(CZ)=3
         [M:PTR3]DISCRGSCR9=1
         If !GIMPORT Affzo [PTR3]DISCRGSCR9 : Grizo [PTR3]DISCRGSCR9 : Endif
       Elsif !GIMPORT
         Actzo [PTR3]DISCRGSCR9
       Endif

  # Issue 84129 - 2012-10-25 by MUARN : landed cost
  When "CPRCOECOD"
       If val(CZ)=3
         [M:PTR3]CPRCOESCR=1
         If !GIMPORT Affzo [PTR3]CPRCOESCR  : Grizo [PTR3]CPRCOESCR    : Endif
       Elsif !GIMPORT
         Actzo [PTR3]CPRCOESCR
       Endif
  When "STCNUMCOD"
       If val(CZ)=3
         [M:PTR3]STCNUMSCR=1
         If !GIMPORT Affzo [PTR3]STCNUMSCR  : Grizo [PTR3]STCNUMSCR    : Endif
       Elsif !GIMPORT
         Actzo [PTR3]STCNUMSCR
       Endif
  When "CSTPURCOD"
       If val(CZ)=3
         [M:PTR3]CSTPURSCR=1
         If !GIMPORT Affzo [PTR3]CSTPURSCR  : Grizo [PTR3]CSTPURSCR    : Endif
       Elsif !GIMPORT
