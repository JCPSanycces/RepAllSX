#                   Actions sur champs écran [M:PTR0]                   #
#########################################################################

Subprog AS_PTRNUM(VALEUR)
#-----------------------#
# Avant saisie document #
#-----------------------#
Variable Char    VALEUR()
[M:PTR0]PTRTYP=6
End

#########################################################################
#                   Actions sur champs écran [M:PTR1]                   #
#########################################################################

Subprog AS_NBLEDTYP
#-----------------------#
# Avant saisie NBLEDTYP #
#-----------------------#
If [M:PTR1]NBLEDTYP=0
  Local Integer I
  [M:PTR1]NBLEDTYP=len(mess(0,2644,1)) : Affzo [PTR1]20
  For I=1 To [M:PTR1]NBLEDTYP
    If func TRTX3CPT.TYPLEDAUTO(I)
      [M:PTR1]LEDTYPCOD(I-1)=3
      Grizo  [PTR1]LEDTYPCOD(I-1)
      Chgstl [PTR1]LEDTYPCOD(I-1) With "ITALIQUE"
    Else
      [M:PTR1]LEDTYPCOD(I-1)=1
    Endif
  Next I
Endif
End

Subprog AM_LEDTYPCOD(VALEUR)
#----------------------------------------------------------#
# Après modification du mode saisie du type de référentiel #
#----------------------------------------------------------#
Variable Integer VALEUR
End

Subprog AM_WRHOBY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    [M:PTR1]WRHCOD = 1
    Grizo [M:PTR1]WRHCOD
Else
    Actzo [M:PTR1]WRHCOD
Endif
Affzo [M:PTR1]WRHCOD
End

