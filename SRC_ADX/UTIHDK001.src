#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIHDK001   Utilitaire de migration des transactions de     Module CRM #
#             saisie module Support client                               #
#              Initialisation des nouveaux champs suite                  #
#                au développement de l'exigence 105605                   #
#              Init. nouveau champs ECCCOD, ECCCODMIN de HDKTRS          #
# X3SUIVI105605                                                          #
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "UTIHDK001 - New sales transactions fields initialisation") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIHDK001 - New HDK transactions fields initialisation") From LECFIC
    Call MAJ_UTIHDK001(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIHDK001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTIHDK001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If filinfo(filpath("FIL", "INTERVEN", "fde", DOSSIER), 0) <= 0 Then
    End
  Endif
  #----- Début mise à jour HDKTRS -----#
  Gosub TRT_HDKTRS
  #----- Fin mise à jour HDKTRS   -----#
  Call ECR_TRACE("UTIHDK001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
End

#-------------------------------------------------------------------------------#
#   Initialisation des nouveaux champs dans les transactions support client     #
# ----------------------------------------------------------------------------- #
# Table HDKTRS - Transactions support client                                    #
#-------------------------------------------------------------------------------#
$TRT_HDKTRS
Local Shortint INDIC
Local Shortint NI

  If filinfo(filpath("FIL","HDKTRS","fde",DOSSIER),0) <= 0 Then
    Return
  Endif
  If filinfo(filpath("FIL","HDKTRSVAL","fde",DOSSIER),0) <= 0 Then
    Return
  Endif
  #-------------------------------------------------------------------------------#
  # Initialisation transactions ventes pour les nouvelles zones                   #
  #-------------------------------------------------------------------------------#
  Call ECR_TIME("UTIHDK001 Sales Transactions Process : Update HDKTRS") From DOSSUB
  Local File =DOSSIER+".HDKTRS"    [HTR]
  Local File =DOSSIER+".HDKTRSVAL" [HTV]
  Local File =DOSSIER+".HDKTASK"   [HDT]
  #
  Call ECR_TIME("UTIHDK001 Sales Transactions Process : --- Step 1 ") From DOSSUB
  Gosub TXNSRE
  #
  Call ECR_TIME("UTIHDK001 Sales Transactions Process : --- Step 2 ") From DOSSUB
  Gosub TXNITN
  #
  Close Local File [HTR]
  Close Local File [HTV]
Return

#-------------------------------------------------------------------------------#
# Transaction pour les demandes de service                                      #
#-------------------------------------------------------------------------------#
$TXNSRE
  Trbegin [HTR]
  For [HTR]HTR0 Where HTRTYP = 2
    # --------------------------
    Read [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
    # --------------------------
    Raz INDIC
    If dim([F:HTR]ECCCOD) > 0 Then
      If !find([F:HTR]ECCCOD,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:HTR]ECCCOD = 3
        For NI = 0 To dim([F:HTV]FIENAM)-1
          If [F:HTV]FIENAM(NI) = "" Then
            [F:HTV]FIENAM(NI) = "[SRE9]ECCVALMAJ"
            [F:HTV]FIEVAL(NI) = num$([F:HTR]ECCCOD)
            Break
          Endif
        Next NI
      Endif
    Endif
    If dim([F:HTR]ECCCODMIN) > 0 Then
      If !find([F:HTR]ECCCODMIN,1,2,3) Then
        # Version mineure (invisible)
        INDIC = 1
        [F:HTR]ECCCODMIN = 3
        For NI = 0 To dim([F:HTV]FIENAM)-1
          If [F:HTV]FIENAM(NI) = "" Then
            [F:HTV]FIENAM(NI) = "[SRE9]ECCVALMIN"
            [F:HTV]FIEVAL(NI) = num$([F:HTR]ECCCODMIN)
            Break
          Endif
        Next NI
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [HTR]
      If fstat Then
        Call ECR_TRACE("File HDKTRS, Error ="-num$(fstat),1) From GESECRAN
      Else
        Rewrite [HTV]
        If fstat Then
          Call ECR_TRACE("File HDKTRSVAL, Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Endif
  Next
  Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les demandes de service                                      #
#-------------------------------------------------------------------------------#
$TXNITN
  Trbegin [HTR]
  For [HTR]HTR0 Where HTRTYP = 3
    # --------------------------
    Read [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
    # --------------------------
    Raz INDIC
    If dim([F:HTR]ECCCOD) > 0 Then
      If !find([F:HTR]ECCCOD,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:HTR]ECCCOD = 3
        For NI = 0 To dim([F:HTV]FIENAM)-1
          If [F:HTV]FIENAM(NI) = "" Then
            [F:HTV]FIENAM(NI) = "[ITN8]ECCVALMAJ"
            [F:HTV]FIEVAL(NI) = num$([F:HTR]ECCCOD)
            Break
          Endif
        Next NI
      Endif
    Endif
    If dim([F:HTR]ECCCODMIN) > 0 Then
      If !find([F:HTR]ECCCODMIN,1,2,3) Then
        # Version mineure (invisible)
        INDIC = 1
        [F:HTR]ECCCODMIN = 3
        For NI = 0 To dim([F:HTV]FIENAM)-1
          If [F:HTV]FIENAM(NI) = "" Then
            [F:HTV]FIENAM(NI) = "[ITN8]ECCVALMIN"
            [F:HTV]FIEVAL(NI) = num$([F:HTR]ECCCODMIN)
            Break
          Endif
        Next NI
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [HTR]
      If fstat Then
        Call ECR_TRACE("File HDKTRS, Error ="-num$(fstat),1) From GESECRAN
      Else
        Rewrite [HTV]
        If fstat Then
          Call ECR_TRACE("File HDKTRSVAL, Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Endif
  Next
  Commit
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIHDK001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTIHDK001(APPLI)
End

