# Supervisor
## CRUD-CLASSE ## ESSWRKCHD
# 2018-10-23 06:53:16 073

Gosub TEST From WMCR_ESSWRKCHD : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,UID)
############################################################################################
# ESSWRKCHD : ESSWRKCHD
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet ESSWRKCHD._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = ESSWRKCHD.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(ESSWRKCHD.ACTX.AFOLDER,nomap,"")>0
 Local File ESSWRKCHD [EWCHD]
 Local File ESSWRKCHD [AAA_]
Else
 Local File =ESSWRKCHD.ACTX.AFOLDER+".ESSWRKCHD" [EWCHD]
 Local File =ESSWRKCHD.ACTX.AFOLDER+".ESSWRKCHD" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [EWCHD] With
& [AAA_]EWCHD0 = UID
& As [LNK_]
Return

############################################################################################
### ESSWRKCHD(WEWCHD)
############################################################################################
Funprog  _MAJSQL_ESSWRKCHD(WEWCHD)
Variable Instance WEWCHD Using C_ESSWRKCHD
Local Integer ASTATUS,A_I,A_J
Default File [F:EWCHD]
If WEWCHD.ASTALIN=[V]CST_ANEW
 Call INICRE(WEWCHD) From ASYRSUB
 SetInstance [F:EWCHD] With WEWCHD
 Write [F:EWCHD]
 If fstat
  Call FSTA("EWCHD",WEWCHD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEWCHD.updTick = [F:EWCHD]updTick
Elsif WEWCHD.ASTALIN=[V]CST_ALL or WEWCHD.ASTALIN=[V]CST_AUPD
 Call INIUPD(WEWCHD) From ASYRSUB
 SetInstance [F:EWCHD] With WEWCHD
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEWCHD,"ESSWRKCHD")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:EWCHD]EWCHD0 = [F:EWCHD]UID
 If fstat
  Call FSTA("EWCHD",WEWCHD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEWCHD.updTick = [F:EWCHD]updTick
Elsif WEWCHD.ASTALIN=[V]CST_ADEL
 SetInstance [F:EWCHD] With WEWCHD
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEWCHD,"ESSWRKCHD")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:EWCHD]EWCHD0 = [F:EWCHD]UID
 If fstat
  Call FSTA("EWCHD",WEWCHD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



