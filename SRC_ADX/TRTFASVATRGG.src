#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################
# TRTFASVATRGG - Régularisation TVA globale
#
# MODIF :
##    MWA : 10.09.2014 FQ95754_3 Classement pour vente (Sprint 38 - US 3) Opération interdite pour un bien classé pour vente
#
#*********************************************************************
######################################################################
End
######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION

  # -------------------------------------------
  If ( dim(ORIACT) > 0 and ORIACT <> "" ) Then
    Case ORIACT
      When "TRTOBJ"
        Case ACTION
        When "LIENS"        : Gosub MFS_LIENS
        When "LIENS2"       : Gosub MFS_LIENS2
        When "INICRE"       : Gosub MFS_MODIF
        When Default
      Endcase
      When Default
    Endcase
  # -------------------------------------------
  Else
    ##If (GUSER = "MWA") Then : Infbox "ACTION"-num$(ACTION) : Endif
    Case ACTION
      When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
      When "INIT_DIA"     : Gosub INIT_DIA
      When "INIT"         : Gosub INIT
      When "AVANT_PAR"    : Gosub AVANT_PAR
      When "CONTROLE"     : Gosub CONTROLE
      When "OUVRE"        : Gosub OUVRE
      When "DEBUT"        : Gosub DEBUT
      When "APRES_MODIF"  : Gosub APRES_MODIF
      When "SETBOUT"      : Gosub ACTION From =TRTMODACT
      When "AP_CHOIX"     : Gosub ACTION From =TRTMODACT
      When "BOUTON"       : Gosub BOUTON
      When "END"          : Gosub ACTION From =TRTMODACT
      When "OK"           : Gosub OK
      When "ABA"          : Gosub ABA
      When "EXEC"         : Gosub EXEC
      When "FIN"          : Gosub FIN
      When "TERMINE"      : Gosub TERMINE
      When "SORTIE"       : Gosub ACTION From =TRTMODACT
      When Default
    Endcase
  Endif
  # -------------------------------------------

Return

######################################################################
# Actions de l'objet "Contrôler"
######################################################################

#=====================================================================
$MFS_LIENS               # (Unitaire et Massif) - Action de l'objet de visu / contrôle
Return

#=====================================================================
MFS_LIENS2
Return

#=====================================================================
$MFS_MODIF
Return

######################################################################
# Actions de l'action FASVATRGG
######################################################################

$CONTROLE
  Gosub ACTION From =TRTMODACT

  If FIN = 1 : Return : Endif
Return

#=====================================================================
$OUVRE_BATCH
  Gosub OUVRE_TABLES
Return

#=====================================================================
$INIT_DIA                    # (Massif - Saisie des paramètres)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT
 Gosub INIT_WIN_FASVATRGG    #-> Initialisation de la fenêtre
Return

#=====================================================================
$INIT                    # (Unitaire et Massif - interactif et exécution batch)
  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT
  If (GSERVEUR) Then
    Gosub CRT_VARIABLES_GLOBALES
  Endif
Return

#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

##### Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
##### EXEC - Ouverture manuelle des masques de la fenêtre.
##### Nécessaire jusqu'à ce qu'une modif permette de lancer une action massive avec plus
##### d'un écran de critère.

  Local Char WINACT : WINACT="FASRGGM" : # En dur car ne respecte pas la norme
  Local Integer I_MSK
  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif
  Read [AWI]AWI0=WINACT
  If !(fstat) Then
    Local Mask =[F:AWI]MSKENT
    For I_MSK=0 To [F:AWI]NBMSK
      Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
      Local Mask =[F:AMK]CODMSK
    Next I_MSK
  Endif

##### Préparation et lancement de l'action en mode silencieux
  If (ACTSILENCE = G_OUI) Then
    Gosub CRT_VARIABLES_GLOBALES
  Endif

 If ( ACTSILENCE = G_OUI & TRTFILMSK <> "" ) Then
  TYPPRG=0
  Gosub INIT_WIN  From TRMPROACT
  Gosub ALIM_MASK From =TRTFILMSK
 Endif

Return

#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)

  Local Char OLDCPY(GLONCPY)

  If ( dim(TRTMODACT) < 0 ) Then
    Global Char TRTMODACT
    TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Endif
  Gosub ACTION From =TRTMODACT
  If !(GSERVEUR) Then
    Gosub CRT_VARIABLES_GLOBALES
  Endif

  #==> Ouverture des tables
  Gosub OUVRE_TABLES

Return

#=====================================================================
$DEBUT # (Massif interactif et Unitaire)

 ############
 # UNITAIRE #
 ############

 If ( ACTTYPGES = GTAMUNI ) Then
   #==> Contrôles pour autoriser ou non l'exécution de l'action en unitaire

   # Société qui n'est pas française
   If !(func GLOFCYCPY.GET_SOC_PAYS([F:FAS]CPY) ="FR" or func GLOFCYCPY.GET_SOC_LEG([F:FAS]CPY) ="FRA") Then
     GMESSAGE= mess(653,7773,1) :   # "Action réservée à la législation francaise"
     GERR=1 : FIN=1 : Return
   Endif

   # Impossible, le Bien ayant déjà subi une régularisation annuelle pour l'exercice
   If ([F:FAS]VATYEAFLG=G_OUI) Then
     GMESSAGE= mess(670,7773,1) :   # "Impossible, le Bien ayant déjà subi une régularisation annuelle pour l'exercice"
     GERR=1 : FIN=1 : Return
   Endif

   # Bien sorti
   If ( [F:FAS]EXTISSFLG=G_NON and [F:FAS]ISSDAT<>[0/0/0]   ) Then
     GMESSAGE= mess(286,7773,1)  # "Bien sorti"
     GERR=1 : FIN=1 : Return
   Endif

   # Le bien a fait l'objet d'un classement pour vente. FQ95754_3
   If ( [F:FAS]SALCLSDAT <> [0/0/0] )
     GMESSAGE = mess(931,GML_MSGFAS,1)
     GERR= 1: FIN=1 : Return
   Endif

   # Bien comptable dont type de détention : "En modèle" ou "Annulé"
   If ( [F:FAS]OWNTYP=GVML_TDMODEL or [F:FAS]OWNTYP=GVML_TDANNUL ) Then
     GMESSAGE = mess(61,7773,1)-":"-mess([F:FAS]OWNTYP,3171,1)-"."-mess(654,7773,1) :  # " action interdite"
     GERR=1 : FIN=1 : Return
   Endif

   # Bien comptable dont le coefficient d'assujettissement = 0
   If ( [F:FAS]ASJCOE = 0. ) Then
     GMESSAGE = mess(655,7773,1) :  # "Bien exclu du mécanisme de régularisation"
     GERR=1 : FIN=1 : Return
   Endif

   # Exclusion des biens qui sont hors période de régularisation
   If ( [F:FAS]THESLI <> 0 ) Then
     # FQ61480
     # Récupération date début Période courante Exercice courant du contexte Fiscal & Comptable
     Local Date    LDATE(1..5)
     Local Integer LRETOUR
     Call GET_CNX_DAT([F:FAS]CPY, G300CPFI, LDATE, LRETOUR) From GLOBIENS
     [M:FASR]MVTDAT = LDATE(3)
     # [M:FASR]MVTDAT = date$

     # Exclusion des biens qui sont hors période de régularisation
     If ( func TRTFAS.IS_HORS_PERIODE_REGUL( [F:FAS]THESLI, [F:FAS]VATREGDAT, [M:FASR]MVTDAT ) ) Then
       GMESSAGE = mess(656,7773,1) :  # "Bien hors période de régularisation"
       GERR=1 : FIN=1 : Return
     Endif
   Endif

   # Chargement des plans de la société
   Call INIT_PLAN_AMT([M:FAS0]CPY)
   # Récupération des paramètres liés à la TVA
   Call GET_ELEM_REG_TVA ([M:FAS0]CPY) From TRTFAS
 Endif

 ######################
 # MASSIF ET UNITAIRE #
 ######################

 Gosub ACTION From =TRTMODACT

 If !(GBATCH) Then
   Gosub INIT_WIN_FASVATRGG    #-> Initialisation de la fenêtre
 Endif
 Setmok [M:FASR] With 0

 If ( ACTSILENCE=G_OUI and TRTFILMSK <> "" ) Then
  TYPPRG=0
  Gosub ALIM_MASK From =TRTFILMSK
 Endif

Return

#=====================================================================
$BOUTON             # (Massif interactif et Unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$APRES_MODIF             # (Massif interactif et Unitaire)

  # A effectuer avant le traitement ci-dessous car ce qui suit altère la valeur de nolign...
  Gosub ACTION From =TRTMODACT

  Case COUZON
    When "FLGCPY"
      If ( val(CZ) = G_OUI ) Then
        # FQ61480
        # Récupération date début Période courante Exercice courant du contexte Fiscal & Comptable
        Local Date    LDATE(1..5)
        Local Integer LRETOUR
        Call GET_CNX_DAT([M:MHC]CPY(nolign-1), G300CPFI, LDATE, LRETOUR) From GLOBIENS
        [M:FASR]MVTDAT = LDATE(3) : Affzo [M:FASR]MVTDAT

        # Chargement des plans de la société
        Call INIT_PLAN_AMT([M:MHC]CPY(nolign-1))
        # Récupération des paramètres liés à la TVA
        Call GET_ELEM_REG_TVA ([M:MHC]CPY(nolign-1)) From TRTFAS
      Endif
    When "FLGFCY"
      If ( val(CZ) = G_OUI and OLDCPY <> [M:MHC]FCYCPY(nolign-1) ) Then
        # FQ61480
        # Récupération date début Période courante Exercice courant du contexte Fiscal & Comptable
        Local Date    LDATE(1..5)
        Local Integer LRETOUR
        Call GET_CNX_DAT([M:MHC]FCYCPY(nolign-1), G300CPFI, LDATE, LRETOUR) From GLOBIENS
        [M:FASR]MVTDAT = LDATE(3) : Affzo [M:FASR]MVTDAT

        OLDCPY = [M:MHC]FCYCPY(nolign-1)
        # Chargement des plans de la société
        Call INIT_PLAN_AMT([M:MHC]FCYCPY(nolign-1))
        # Récupération des paramètres liés à la TVA
        Call GET_ELEM_REG_TVA ([M:MHC]FCYCPY(nolign-1)) From TRTFAS
      Endif
    When Default
  Endcase
Return

#=====================================================================
$EXEC
 # Bouton FIN activée : on n'execute pas l'action $EXEC
 If (ABANDON_TRT) : Return : Endif

 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$OK
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$ABA
 Gosub INIT_WIN_FASVATRGG    #-> Initialisation de la fenêtre
 Gosub ACTION From =TRTMODACT
Return


#=====================================================================
$FIN
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$TERMINE
 Gosub ACTION From =TRTMODACT
Return

######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################
#
# Construction du nom des étiquettes :
#
# AAAA_BBBB_CCCCCC
#
# AAAA => Nom de la table origine (MAS1 / TMP1 / TPF1
# BBBB => Etape de l'action
# CCCC => Table destination ou Action ou Objet
#
######################################################################

$ACTMET
 Case ACTMET

  When  "SET_CRIT_FCY"      :   Gosub SET_CRIT_FCY         # M  - Filtre sur les sites non français

  When "CRITMEN"            :   Gosub CRITMEN              # U  - Activation menu ou bouton
  When "SET_PRECHARGE"      :   Gosub SET_PRECHARGE        # U  - A positionner à G_OUI s'il n'y a pas de bouton sélectionner
  When "SET_GLO_MAS"        :   Gosub SET_GLO_MAS          # M  - Définition paramétres en-tête

# Actions hors sous-programmes, communes au massif et à l'unitaire

  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critère de sélection particulier à l'action métier

# s/p "LOCKER"

  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # M  - Exclusion élément de la population à sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet lié à l'enr en ligne de la population
  When "CLOS_LOCK"          :   Gosub CLOS_LOCK            # UM -
  When "UNLOCK_AUTRE"       :   Gosub UNLOCK_AUTRE         # UM -

# s/p "CHARGER"

  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

# s/p "APPLIQUE_TEMP"

  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Traitement commun avant application des paramètres de l'action aux enr de la table
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale

# s/p "REPORT_MASK" Report objet principal dans les masques (unitaire uniquement)

  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

# s/p "APPLIQUE_DIRT" Mise à jour directe (massif uniquement)

  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à jour directe des tables de données avec les paramètres de l'action
  When "CLOS_APPL_DIRT"     :   Gosub CLOS_APPL_DIRT       # M  - Fin mise à jour directe

# s/p "REPORTER"

  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture de table annexes pour le report tmp -> données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> table de données
  When "CLOS_ALIM_TABLE"    :   Gosub CLOS_ALIM_TABLE      # UM - Traitement de fin de report

  When Default

 Endcase

Return

#=====================================================================
# Unitaire : critère désactivation / activation menu CRITMEN
$SET_CRIT_FCY
  # Société qui n'est pas française
  If !(func GLOFCYCPY.GET_SOC_PAYS([F:FCY]LEGCPY)="FR" or func GLOFCYCPY.GET_SOC_LEG([F:FCY]LEGCPY)="FRA") Then
     GOK= 0 : # " Action réservée à la législation francaise"
   Endif
Return

#=====================================================================
# Unitaire : critère désactivation / activation menu CRITMEN
$CRITMEN
 Local Integer ACCFCY
 Local Char AUZFCY (15)
 # Accès selon droit à l'option
 Call DROITSITE ( [M:FAS0]FCY, [L]AUZFCY, [L]ACCFCY ) From SUPCPT
 If ( not [L]ACCFCY or not instr(1, [L]AUZFCY, 'P') ) Then
   CRITMEN = "1=0"
 Else
   CRITMEN = "1=1"
 Endif
Return

#=====================================================================
# Unitaire : Modif de la variable déclenchant le préchargement de la population en unitaire PRECHARGE
$SET_PRECHARGE
 PRECHARGE=G_OUI
Return

#=====================================================================
# Massif : Differents paramètres peuvent être précisés si on est en Multi-société
$SET_GLO_MAS
  # Aucun bien susceptible de subir une régularisation de TVA
  GMSGNOOBJLCK= mess(468,7773,1)
Return

#=====================================================================
# Unitaire et massif : Modif de la variable contenant le critère de sélection propre à l'action
$SET_CRITACT
  CRITACT  = "OWNTYP <> GVML_TDMODEL and OWNTYP <> GVML_TDANNUL "
  # CRITACT += " and  (ISSDAT=[0/0/0] or (ISSDAT<>[0/0/0] and EXTISSFLG=G_OUI)) "  FQ95754_3
  CRITACT += " and SALCLSDAT = [0/0/0] and  (ISSDAT=[0/0/0] or (ISSDAT<>[0/0/0] and EXTISSFLG=G_OUI)) "
Return

#=====================================================================
# Unitaire et massif : Sert à ouvrir des tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK

  Gosub OUVRE_TABLES

  # Déverrouillage
  If ( G_SACKEY <> "") Then
    Local Char LLOCK(200)
    LLOCK = right$(G_SACKEY,instr(0,G_SACKEY,"/")+1)
    # Unlock du secteur d'activité
    Call UNLOCK_SYMBOLE( "SEA", left$(G_SACKEY,instr(0,G_SACKEY,"/")-1), LLOCK) From GLOBIENS
    G_SACKEY = ""
  Endif

  # Verrouillage du secteur d'activité 'Massif uniquement'
  Local Char LLOCK(200)
  G_SACLCK =G_NON
  If ( ACTTYPGES = GTAMMAS and [M:MHC]FLGSIM = G_NON ) Then
    # Pour interdire toute modification sur l'objet
    LLOCK = func GLOBIENS.GET_KEY_SECACT ([M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1))

    If ([M:FASR]AASBUS <> "" ) Then
      If ( func GLOBIENS.IS_SYMBOLE_LOCKED( "SEA", [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1), LLOCK) = 0 ) Then
        # Secteur déjà locké
        G_SACLCK = G_OUI
      Else
        # Lock du secteur d'activité
        If ( func GLOBIENS.LOCK_SYMBOLE( "SEA", [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1), LLOCK, 0) = 0 ) Then
          # Secteur déjà locké
          G_SACLCK = G_OUI
        Else
          G_SACKEY = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)+"/"+LLOCK
        Endif
      Endif
    Endif
  Endif
Return

#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE


  # Si le secteur d'activité est déjà locké on exclus tous les biens
  If ( ACTTYPGES = GTAMMAS and [M:MHC]FLGSIM = G_NON and G_SACLCK =  G_OUI ) Then :   GOK = 0 : Return :  Endif

  # Retrait des biens En cours selon paramétrage
  If ( G_TENCOURS = G_NON  and ( [F:MAS1]GACACN = GVML_NIENCOU or [F:MAS1]IASACN = GVML_NIENCOU)) Then : GOK = 0 : Return : Endif

  # Retrait des biens qui ont déjà subi un traitement de régularisaton annuelle dans l'exercice
  If ( [F:MAS1]VATYEAFLG = G_OUI ) Then : GOK = 0 : Return :  Endif

  # retrait des biens exclus du mécanisme de régularisation ( Coeff. Assuj. = 0 )
  If ( [F:MAS1]ASJCOE = 0. ) Then : GOK = 0 : Return :  Endif

  # Retrait des biens selon le type de régularisation globale
  If ( [M:FASR]VATADM = G_OUI ) Then
    # Exclusion des biens qui ont un coefficient d'admission futur équivalent à celui passé en paramètre
    If ( [F:MAS1]ADMCOEF = [M:FASR]ADMCOE ) Then : GOK = 0 : Return : Endif
  Endif
  If ( [M:FASR]VATOPN = G_OUI ) Then
    # Exclusion des biens qui n'appartiennent pas au secteur en paramètre
    If ( [F:MAS1]AASBUS <> [M:FASR]AASBUS ) Then : GOK = 0 : Return : Endif
    # Exclusion des biens en secteur mixte
    If ( [F:MAS1]TAXCOEFLG = G_OUI ) Then : GOK = 0 : Return : Endif
  Endif
  If ( [M:FASR]VATCLS = G_OUI ) Then
    # Exclusion des biens qui n'appartiennent pas au secteur en paramètre
    If ( [F:MAS1]AASBUS <> [M:FASR]AASBUS ) Then : GOK = 0 : Return : Endif
    # Exclusion des biens en secteur mixte
    If ( [F:MAS1]TAXCOEFLG = G_OUI ) Then : GOK = 0 : Return : Endif
  Endif
  If ( [M:FASR]VATDEF = G_OUI ) Then
    # Exclusion des biens qui n'appartiennent pas au secteur en paramètre
    If ( [F:MAS1]AASBUS <> [M:FASR]AASBUS ) Then : GOK = 0 : Return : Endif
    # Exclusion des biens en secteur mixte
    If ( [F:MAS1]TAXCOEFLG = G_OUI ) Then : GOK = 0 : Return : Endif
    # Exclusion des biens qui ont déjà le coefficient d'assujettisement à O.
    If ( [F:MAS1]ASJCOE = 0. ) Then : GOK = 0 : Return : Endif
  Endif

  # Retrait des biens qui sont hors période de régularisation
  If ( [F:MAS1]THESLI <> 0 ) Then
    If ( func TRTFAS.IS_HORS_PERIODE_REGUL( [F:MAS1]THESLI, [F:MAS1]VATREGDAT, [M:FASR]MVTDAT ) ) Then : GOK = 0 : Return : Endif
  Endif


Return

#=====================================================================
# Unitaire / massif : Lock des composants et/ou complémentaires
#                     des biens non exclus dans CONTROLE
#                     Alimenter RMES si un message doit apparaître
$MAS1_LOCK_AUTRE
Return

#=====================================================================
# Unitaire et massif :
#
$CLOS_LOCK

  # Verrouillage du secteur d'activité 'Massif uniquement'
  If (G_SACLCK = G_OUI  ) Then
    Call ECR_TRACE (G_MSGQUILOCK,1) From GESECRAN
  Endif
Return


#=====================================================================
# Unitaire / massif :
#
#
$UNLOCK_AUTRE

  If ( ACTTYPGES = GTAMMAS and [M:MHC]FLGSIM = G_NON and G_SACLCK = G_NON and [M:FASR]AASBUS <> "") Then
    Local Char LLOCK(200)
    LLOCK = func GLOBIENS.GET_KEY_SECACT([M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1))
    # Unlock du secteur d'activité
    Local Integer LRTRN
    Call UNLOCK_SYMBOLE( "SEA", [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1), LLOCK) From GLOBIENS
    G_SACKEY = ""
    G_SACLCK = G_NON
  Endif

  If dim([V]G_SACLCK)>0   : Kill [V]G_SACLCK        : Endif   : # Indicateur Secteur d'activité locké.

Return

#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1
If (1 = 1 ) Then : Return : Endif
 Local Char TABORI
 If !clalev([F:MAS2]) : Local File FXDASSETS [MAS2] : Endif
Return

#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
$MAS1_ALIM_TMP1

  Raz [F:TMP1]
  [F:TMP1] = [F:MAS1]

  #--------------------------------------------------------------#
  # Alimentation d'un enregistrement de TMP1                     #
  #--------------------------------------------------------------#

  [F:TMP1]TRTNUM     = NUMACT
  [F:TMP1]FLGERR     = G_NON
  [F:TMP1]FLGMOD     = G_OUI

  [F:TMP1]OBJREF     = [F:MAS1]AASREF

  [F:TMP1]ASJCOEFO   = [F:MAS1]ASJCOEF
  [F:TMP1]TAXCOEFO   = [F:MAS1]TAXCOEF
  [F:TMP1]ADMCOEFO   = [F:MAS1]ADMCOEF
  [F:TMP1]DEDCOEFO   = [F:MAS1]DEDCOEF

  Write [TMP1]
  If ( fstat ) Then
    Case fstat
      When 1
        RMES="TMPMASFAS"-mess(227,7773,1)  # "TMPMASFAS table verrouillée"
        GOK=-1
      When 3
        RMES=mess(129,7773,1)-num$([F:TMP1]TRTNUM)+"/"+[F:TMP1]OBJREF # "Tentative d'écriture en double de la clé"
        GOK=0
      When Default
    Endcase
  Else
    NBTMP+=1
  Endif


Return

######################


#=====================================================================
# Unitaire / massif : Traitements communs avant applications des paramètres sur la table temporaire
$OUVR_APPL_TMP1

  Gosub OUVRE_TABLES

Return

#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1

  # --- Code commun MAS1_APPL_DIRT ------
  #
  If ( [M:FASR]VATADM = G_OUI ) Then
    [F:TMP1]ADMCOEF = [M:FASR]ADMCOE
  Endif
  If ( [M:FASR]VATOPN = G_OUI ) Then
    [F:TMP1]TAXCOEF = [M:FASR]TAXCOE
  Endif
  If ( [M:FASR]VATCLS = G_OUI ) Then
    [F:TMP1]TAXCOEF = 0.
  Endif
  If ( [M:FASR]VATDEF = G_OUI ) Then
    [F:TMP1]ASJCOEF = 0.
  Endif
  # Calcul nouveau coefficient de déduction futur
  Call TVA_COE_DEDUCTION ( [F:TMP1]ASJCOEF, [F:TMP1]TAXCOEF, [F:TMP1]ADMCOEF, [F:TMP1]DEDCOEF ) From TRTFAS
  #
  # --- Code commun MAS1_APPL_DIRT ------

Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK


  # Ne rien faire si on est en erreur
  If ( [F:TMP1]FLGERR = G_OUI ) Then : Return : Endif

  Local Decimal LDURRES
  Local Integer RTRN

  # Calcul de la régularisation TVA
  CLASORI = "[F:TMP1]"
  Call TVA_REGUL_GLOBALE ( CLASORI, [M:FASR]MVTDAT, [F:TMP1]DEDCOEFO, G_REGUL, G_REGULI, G_FORM, G_FORMI, LDURRES , RTRN ) From TRTFAS

  #-- FAS5
  # Période de régularisation résiduelle
  [M:FAS5]VATRSD = LDURRES
  # Indicateur régularisation globale
  If      ( [M:FASR]VATADM = G_OUI ) Then
    [M:FAS5]ADMCOEFGLO = G_OUI
  Elsif   ( [M:FASR]VATOPN = G_OUI ) Then
    [M:FAS5]TAXCOEFGLO = G_OUI
  Elsif   ( [M:FASR]VATCLS = G_OUI ) Then
    [M:FAS5]TAXCOEFGLO = G_OUI
  Elsif   ( [M:FASR]VATDEF = G_OUI ) Then
    [M:FAS5]ASJCOEFGLO = G_OUI
  Endif
  # Coefficient de déduction futur
  [M:FAS5]ADMCOEF      = [F:TMP1]ADMCOEF
  [M:FAS5]TAXCOEF      = [F:TMP1]TAXCOEF
  [M:FAS5]ASJCOEF      = [F:TMP1]ASJCOEF
  [M:FAS5]DEDCOEF      = [F:TMP1]DEDCOEF

  # Déduction/Reversement PCG
  If (G_REGUL < 0 )  Then :  [M:FAS5]VATREGAMT += abs(G_REGUL)  : Else : [M:FAS5]VATREGDED += G_REGUL  : Endif
  # Déduction/Reversement IAS
  If (G_REGULI < 0 ) Then :  [M:FAS5]IASVATREG += abs(G_REGULI) : Else : [M:FAS5]VATREGDEDI += G_REGULI : Endif



  #> FAS3

  If ( G_IMPBASVT = G_OUI and ( G_REGUL <> 0 or G_REGULI <> 0 ) ) Then

    Local Integer L_CPT,   L_IAS
    Local Decimal SBSEVAL, SBSEVALI

    # Mise à jour des bases avec l'écart selon oribas PCG (avec conversion éventuelle)
    If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif

    # Lecture plan Comptable
    L_CPT = find(G301CPT, [M:FAS3]DPRPLN)
    Read [DEPX] DEP0=[M:FAS0]AASREF;[M:FAS3]DPRPLN(L_CPT-1);
&                    [M:FAS3]FIYENDDAT(L_CPT-1);[M:FAS3]PERENDDAT(L_CPT-1)
    # Sauvegarde Bases d'amortissement comptable
    SBSEVAL = [F:DEPX]BSEVAL
    SDPRBAS = [F:DEPX]DPRBAS

    If ( G_CNXPROIAS = G_OUI) Then
      # Lecture plan IAS
      L_IAS = find(G301IAS, [M:FAS3]DPRPLN)
      Read [DEPX] DEP0=[M:FAS0]AASREF;[M:FAS3]DPRPLN(L_IAS-1);
&                      [M:FAS3]FIYENDDAT(L_IAS-1);[M:FAS3]PERENDDAT(L_IAS-1)
      # Sauvegarde Bases d'amortissement comptable
      SBSEVALI = [F:DEPX]BSEVAL
      SDPRBASI = [F:DEPX]DPRBAS
    Endif

    # Les bases d'amortissements sont à mettre à jour
    #>>>>>>>>>>>>>>>>
    For nolign=1 To [M:FAS3]NBLIG1
      If ( [M:FAS3]ORIBAS(nolign-1) = GVML_OBPCG and G_REGUL <> 0 ) Then
        If ( [M:FAS3]CUR(L_CPT-1) = [M:FAS3]CUR(nolign-1) and
&            [M:FAS3]BSEVAL(nolign-1) = SBSEVAL  and
&            [M:FAS3]DPRBAS(nolign-1) = SDPRBAS  ) Then
          [M:FAS3]BSEVAL(nolign-1) -= G_REGUL
          [M:FAS3]DPRBAS(nolign-1) -= G_REGUL
        Endif
      Endif
      If ( [M:FAS3]ORIBAS(nolign-1) = GVML_OBIAS and G_REGULI <> 0 ) Then
        If ( [M:FAS3]CUR(L_IAS-1) = [M:FAS3]CUR(nolign-1) and
&            [M:FAS3]BSEVAL(nolign-1) = SBSEVALI  and
&            [M:FAS3]DPRBAS(nolign-1) = SDPRBASI  ) Then
          [M:FAS3]BSEVAL(nolign-1) -= G_REGULI
          [M:FAS3]DPRBAS(nolign-1) -= G_REGULI
        Endif
      Endif
      # Le bien est à recalculer
      [M:FAS3]DEPSTA(nolign-1)                   = GVML_SCNOCAL
      [M:FAS0]FLGCLC                             = G_OUI
      [M:FAS0]FLGCNXCLC([M:FAS3]CNX(nolign-1)-1) = G_OUI
    Next nolign
    #<<<<<<<<<<<<<<<<<<<

    [M:FAS2]TAXBAS    -= G_REGUL
    [M:FAS4]GALREFBAS -= G_REGUL

  Endif

  #> Mise à jour du témoin de modification
  ACTMODIF=1

Return

#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
REAF_ALIM_MASK
  Affzo [M:FAS1] : Affzo [M:FAS2] : Affzo [M:FAS3] : Affzo[M:FAS4] : Affzo [M:FAS5]
Return

#=====================================================================
# Massif : Déclaration et initialisation avant traitement de la population
#          en mise à jour directe. Valable uniquement en massif.
$OUVR_APPL_DIRT

  Gosub OUVRE_TABLES

  # Ouverture des classes de travail
  If !clalev([F:FASO]) : Local File FXDASSETS [FASO] : Endif  # Bien avant
  If !clalev([F:FASD]) : Local File FXDASSETS [FASD] : Endif  # Bien après
  If !clalev([F:DEPW]) : Local File DEPREC    [DEPW] : Endif  # Buffer de travail pour Deprec
  If !clalev([F:DEPZ]) : Local File DEPREC    [DEPZ] : Endif  # Buffer pour suppression Deprec ex. suivant

  # Société courante : rupture société pour émission en-tête trace
  Local Char    TRC_CPY

  Local Char    CLASDES                    # Classe de la classe destination des mises à jour
  Local Char    CLASORI                    # Classe de la classe origine des modifications
  Local Integer RETOUR                     # Code retour appel sous programme
  Local Integer LTYPREG                    # Type de régularisation globale
  Local Integer RTRN                       # Code retour de sous- programme

  Local Integer B_SACMAJ : B_SACMAJ = 0    # Indicateur Secteur d'action a été mis à jour


Return

#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à jour directe
$MAS1_APPL_DIRT


  #=> A rupture société : en-tête société dans la trace et chargement des dates des contextes
  If ( [F:MAS1]CPY<>TRC_CPY ) Then
    Call ECR_ENTETE([F:MAS1]CPY) From TRTFASVATRGG
    TRC_CPY=[F:MAS1]CPY
  Endif

  # Valeur d'origine pour écriture dans VATHIS
  G_AASBUSO      = [F:MAS1]AASBUS
  G_VATREGDATO   = [F:MAS1]VATREGDAT
  G_IVCVATAMTO   = [F:MAS1]IVCVATAMT
  G_DEDVATAMTO   = [F:MAS1]DEDVATAMT
  G_ASJCOERO     = [F:MAS1]ASJCOER
  G_TAXCOERO     = [F:MAS1]TAXCOER
  G_ADMCOERO     = [F:MAS1]ADMCOER
  G_DEDCOERO     = [F:MAS1]DEDCOER
  G_ASJCOEO      = [F:MAS1]ASJCOE
  G_TAXCOEO      = [F:MAS1]TAXCOE
  G_TAXCOEFLGO   = [F:MAS1]TAXCOEFLG
  G_ADMCOEO      = [F:MAS1]ADMCOE
  G_DEDCOEO      = [F:MAS1]DEDCOE
  G_ASJCOEFO     = [F:MAS1]ASJCOEF
  G_TAXCOEFO     = [F:MAS1]TAXCOEF
  G_ADMCOEFO     = [F:MAS1]ADMCOEF
  G_DEDCOEFO     = [F:MAS1]DEDCOEF

  # Sauvegarde des valeurs d'origine du bien comptable
  [F:FASO] = [F:MAS1]

  # --- Code commun TMP1_APPL_TMP1 ------
  #
  If ( [M:FASR]VATADM = G_OUI ) Then
    [F:MAS1]ADMCOEF = [M:FASR]ADMCOE
  Endif
  If ( [M:FASR]VATOPN = G_OUI ) Then
    [F:MAS1]TAXCOEF = [M:FASR]TAXCOE
  Endif
  If ( [M:FASR]VATCLS = G_OUI ) Then
    [F:MAS1]TAXCOEF = 0.
  Endif
  If ( [M:FASR]VATDEF = G_OUI ) Then
    [F:MAS1]ASJCOEF = 0.
  Endif
  # Calcul nouveau coefficient de déduction futur
  Call TVA_COE_DEDUCTION ( [F:MAS1]ASJCOEF, [F:MAS1]TAXCOEF, [F:MAS1]ADMCOEF, [F:MAS1]DEDCOEF ) From TRTFAS
  #
  # --- Code commun TMP1_APPL_TMP1 ------

  # --- Code commun TMP1_ALIM_TABLE ------

  #
  #     ******************
  Gosub REGUL_GLOBALE_MAS1
  #     ******************

  #
  # --- Code commun TMP1_ALIM_TABLE ------

  [F:FASD] = [F:MAS1]  # Sauvegarde des nouvelles valeurs du bien comptable


  If (RTRN > 0 ) Then
    # Erreur technique
    If (RTRN = 1 ) Then
      RMES= mess(294,7773,1)-[F:MAS1]AASREF- mess(295,7773,1)-[F:MAS1]AASBUS
    Endif
    If (RTRN = 2 ) Then
      RMES=mess(104,7773,1)-"DEPREC"-mess(105,7773,1)-" 02"-mess(106,7773,1)-[F:MAS1]AASREF+"/"+num$([F:DEPX]DPRPLN)
      GOK=0 : Return
    Endif
    If (RTRN = 3 ) Then
      RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(296,7773,1)
    Endif
    If (RTRN = 4 ) Then
      RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(297,7773,1)
    Endif
    If (RTRN = 5 ) Then
      RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(129,7774,1)
    Endif
    If (RTRN = 6 ) Then
      RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(131,7774,1)
    Endif
    If (RTRN = 7 ) Then
      RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(108,7774,1)
    Endif
    If (RTRN = 8 ) Then
      RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(645,7773,1)
    Endif

    NBCPYERR += 1 : GOK=0 : Return
  Endif

  # Ecriture dans trace
  Call ECR_LIGNE ([F:MAS1]CPY, [F:MAS1]AASREF,  [F:MAS1]AASDES1, [F:MAS1]AASBUS,  [F:MAS1]IVCVATAMT,
&                 G_DEDCOEFO,  [F:MAS1]DEDCOEF, [F:MAS1]THESLI,  [F:MAS1]VATRSD,  G_REGUL, G_REGULI, G_BASPCG, G_BASIAS)

  # Réécriture du Bien
  If ( [M:MHC]FLGSIM = G_NON ) Then
    Rewrite [MAS1]
    If fstat
      # Erreur technique
      RMES= mess(104,7773,1)+" FXDASSETS"+mess(105,7773,1)+" 01"+mess(106,7773,1)-[F:MAS1]AASREF
      NBCPYERR += 1 : GOK=0 : Return
    Else
      NBCPYMAJ += 1
    Endif
  Endif


  # Mise à jour du secteru d'activité selon paramétrage
  If ( [M:MHC]FLGSIM = G_NON and [M:FASR]AASBUS <> "" and not(B_SACMAJ) ) Then
    Gosub MAJ_SECACT
  Endif



Return

#--------------------------
$REGUL_GLOBALE_MAS1

  # Détermination du type de régularisation
  If      ( [M:FASR]VATADM = G_OUI ) Then
    LTYPREG = GVML_TRGLADM
    [F:MAS1]ADMCOEFGLO = G_OUI
  Elsif   ( [M:FASR]VATOPN = G_OUI ) Then
    LTYPREG = GVML_TRGLOPN
    [F:MAS1]TAXCOEFGLO = G_OUI
  Elsif   ( [M:FASR]VATCLS = G_OUI ) Then
    LTYPREG = GVML_TRGLCLS
    [F:MAS1]TAXCOEFGLO = G_OUI
  Elsif   ( [M:FASR]VATDEF = G_OUI ) Then
    LTYPREG = GVML_TRGLDEF
    [F:MAS1]ASJCOEFGLO = G_OUI
  Endif
  G_REGCOD = LTYPREG

  # Calcul de la régularisation TVA
  CLASORI = "[F:MAS1]"
  Call TVA_REGUL_GLOBALE ( CLASORI, [M:FASR]MVTDAT, G_DEDCOEFO, G_REGUL, G_REGULI, G_FORM, G_FORMI, [F:MAS1]VATRSD, RTRN ) From TRTFAS

  # - PCG
  If (G_REGUL < 0 ) Then
    [M:FASR]DEDVAT = 0 : [M:FASR]CRBVAT = abs(G_REGUL)             : # Evénement
    [F:MAS1]VATREGAMT += [M:FASR]CRBVAT                            : # Fichier
  Else
    [M:FASR]CRBVAT = 0 : [M:FASR]DEDVAT = G_REGUL                  : # Evénement
    [F:MAS1]VATREGDED += [M:FASR]DEDVAT                            : # Fichier
  Endif

  # -----------------------
  Call TVA_MAJ_PCG( LTYPREG, G_IMPBASVT, [M:MHC]FLGSIM, G_FORM, RTRN )
  If (RTRN) Then : Return : Endif

  # - IAS
  If (G_REGULI < 0 ) Then
    [M:FASR]DEDVATI = 0 : [M:FASR]CRBVATI = abs(G_REGULI)             : # Evénement
    [F:MAS1]IASVATREG  += [M:FASR]CRBVATI                             : # Fichier
  Else
    [M:FASR]CRBVATI = 0 : [M:FASR]DEDVATI = G_REGULI                  : # Evénement
    [F:MAS1]VATREGDEDI += [M:FASR]DEDVATI                             : # Fichier
  Endif
  # -----------------------
  If ( G_CNXPROIAS = G_OUI ) Then
    Call TVA_MAJ_IAS( LTYPREG, G_IMPBASVT, [M:MHC]FLGSIM, G_FORMI, RTRN )
    If (RTRN) Then : Return : Endif
  Endif

Return

######################



#=====================================================================
$CLOS_APPL_DIRT

  Gosub DEL_VARIABLES_GLOBALES

Return

#=====================================================================
$OUVR_ALIM_TABLE

  Gosub OUVRE_TABLES

  # Ouverture des classes de travail
  If !clalev([F:FASO]) : Local File FXDASSETS [FASO] : Endif  # Bien avant
  If !clalev([F:FASD]) : Local File FXDASSETS [FASD] : Endif  # Bien après
  If !clalev([F:DEPW]) : Local File DEPREC    [DEPW] : Endif  # Buffer de travail pour Deprec
  If !clalev([F:DEPZ]) : Local File DEPREC    [DEPZ] : Endif  # Buffer pour suppression Deprec ex. suivant

  # Société courante : rupture société pour émission en-tête trace
  Local Char TRC_CPY   : Raz TRC_CPY

  # Variables diverses
  Local Char    CLASDES                    # Classe de la classe destination des mises à jour
  Local Char    CLASORI                    # Classe de la classe origine des modifications
  Local Integer RETOUR                     # Code retour appel sous programme
  Local Integer LTYPREG                    # Type de régularisation globale
  Local Integer RTRN                       # Code retour de sous- programme

  Local Integer B_SACMAJ : B_SACMAJ = 0    # Indicateur Secteur d'action a été mis à jour

Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TMP1_ALIM_TABLE

  #*********************************************************************
  #  Fondamentale
  #  Surtout NE PAS FAIRE de transclasse de TMP1 vers MAS1
  #  car dans ce cas,  les champs que ne sont pas dans TMP1 (écran MFS) sont réinitalisés
  #  Mettre dans MSF en invisible tous les champs à mettre à jour et non affichés
  #  Procéder par affectation champ par champ de TMP1 vers MAS1
  #*********************************************************************
  #  Principe de base
  #  Mettre dans TMP1 (écran MFS) tous les champs modifiés par l'action
  #  Mettre en invisible tous les champs qui ne sont pas modifiables via contrôler
  #  Alimenter champ par champ ces différents champs à l'aller comme au retour
  #**********************************************************************

  #If (GUSER = "GBO" ) Then : Dbgaff : Endif
  #If (GUSER = "MWA" ) Then : Dbgaff : Endif

  # Valeur d'origine pour écriture dans VATHIS
  G_AASBUSO      = [F:MAS1]AASBUS
  G_VATREGDATO   = [F:MAS1]VATREGDAT
  G_IVCVATAMTO   = [F:MAS1]IVCVATAMT
  G_DEDVATAMTO   = [F:MAS1]DEDVATAMT
  G_ASJCOERO     = [F:MAS1]ASJCOER
  G_TAXCOERO     = [F:MAS1]TAXCOER
  G_ADMCOERO     = [F:MAS1]ADMCOER
  G_DEDCOERO     = [F:MAS1]DEDCOER
  G_ASJCOEO      = [F:MAS1]ASJCOE
  G_TAXCOEO      = [F:MAS1]TAXCOE
  G_TAXCOEFLGO   = [F:MAS1]TAXCOEFLG
  G_ADMCOEO      = [F:MAS1]ADMCOE
  G_DEDCOEO      = [F:MAS1]DEDCOE
  G_ASJCOEFO     = [F:MAS1]ASJCOEF
  G_TAXCOEFO     = [F:MAS1]TAXCOEF
  G_ADMCOEFO     = [F:MAS1]ADMCOEF
  G_DEDCOEFO     = [F:MAS1]DEDCOEF

  # A rupture société on émet un en-tête dans la trace uniquement en massif
  If ( [F:TMP1]CPY<>TRC_CPY ) Then
    If ( ACTTYPGES = GTAMMAS ) Then : Call ECR_ENTETE([F:TMP1]CPY) From TRTFASVATRGG : Endif
    TRC_CPY=[F:TMP1]CPY
  Endif

  #-> Report de l'enregistrement de TMP1 dans MAS1

  [F:FASO] = [F:MAS1]  # Sauvegarde des valeurs d'origine du bien comptable

  [F:MAS1]ASJCOEF = [F:TMP1]ASJCOEF
  [F:MAS1]TAXCOEF = [F:TMP1]TAXCOEF
  [F:MAS1]ADMCOEF = [F:TMP1]ADMCOEF
  [F:MAS1]DEDCOEF = [F:TMP1]DEDCOEF


  # --- Code commun MAS1_APPL_DIRT ------
  #
  #     ******************
  Gosub REGUL_GLOBALE_TMP1
  #     ******************

  If (ACTTYPGES = GTAMMAS) Then : # Massif uniquement
    If (RTRN > 0 ) Then
      # Erreur technique
      If (RTRN = 1 ) Then
        RMES= mess(294,7773,1)-[F:MAS1]AASREF- mess(295,7773,1)-[F:MAS1]AASBUS
      Endif
      If (RTRN = 2 ) Then
        RMES=mess(104,7773,1)-"DEPREC"-mess(105,7773,1)-" 02"-mess(106,7773,1)-[F:MAS1]AASREF+"/"+num$([F:DEPX]DPRPLN)
        GOK=0 : Return
      Endif
      If (RTRN = 3 ) Then
        RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(296,7773,1)
      Endif
      If (RTRN = 4 ) Then
        RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(297,7773,1)
      Endif
      If (RTRN = 5 ) Then
        RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(129,7774,1)
      Endif
      If (RTRN = 6 ) Then
        RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(131,7774,1)
      Endif
      If (RTRN = 7 ) Then
        RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(108,7774,1)
      Endif
      If (RTRN = 8 ) Then
        RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(645,7773,1)
      Endif
      NBCPYERR += 1 : GOK=0 : Return
    Endif
  Endif

  #-> En massif emission de message dans la trace

  If ( ACTTYPGES = GTAMMAS ) Then
    # Ecriture dans trace
    Call ECR_LIGNE ([F:MAS1]CPY, [F:MAS1]AASREF,  [F:MAS1]AASDES1, [F:MAS1]AASBUS,  [F:MAS1]IVCVATAMT,
&                    G_DEDCOEFO,  [F:MAS1]DEDCOEF, [F:MAS1]THESLI,  [F:MAS1]VATRSD,  G_REGUL, G_REGULI, G_BASPCG, G_BASIAS)
    NBCPYMAJ+=1
  Endif

  #
  # --- Code commun MAS1_APPL_DIRT ------

  [F:FASD] = [F:MAS1]  # Sauvegarde des nouvelles valeurs du bien comptable

  # Mise à jour du secteur d'activité selon paramétrage
  If ( ( ACTTYPGES = GTAMUNI or [M:MHC]FLGSIM = G_NON ) and [M:FASR]AASBUS <> "" and not(B_SACMAJ) ) Then
    Gosub MAJ_SECACT
  Endif



Return

#--------------------------
$REGUL_GLOBALE_TMP1


  # Détermination du type de régularisation
  If      ( [M:FASR]VATADM = G_OUI ) Then
    LTYPREG = GVML_TRGLADM
    [F:MAS1]ADMCOEFGLO = G_OUI
  Elsif   ( [M:FASR]VATOPN = G_OUI ) Then
    LTYPREG = GVML_TRGLOPN
    [F:MAS1]TAXCOEFGLO = G_OUI
  Elsif   ( [M:FASR]VATCLS = G_OUI ) Then
    LTYPREG = GVML_TRGLCLS
    [F:MAS1]TAXCOEFGLO = G_OUI
  Elsif   ( [M:FASR]VATDEF = G_OUI ) Then
    LTYPREG = GVML_TRGLDEF
    [F:MAS1]ASJCOEFGLO = G_OUI
  Endif
  G_REGCOD = LTYPREG

  # Calcul de la régularisation TVA
  CLASORI = "[F:TMP1]"
  Call TVA_REGUL_GLOBALE ( CLASORI, [M:FASR]MVTDAT, G_DEDCOEFO, G_REGUL, G_REGULI, G_FORM, G_FORMI, [F:MAS1]VATRSD, RTRN ) From TRTFAS

  # - PCG
  If (G_REGUL < 0 ) Then
    [M:FASR]DEDVAT = 0 : [M:FASR]CRBVAT = abs(G_REGUL)             : # Evénement
    [F:MAS1]VATREGAMT += [M:FASR]CRBVAT                            : # Fichier
  Else
    [M:FASR]CRBVAT = 0 : [M:FASR]DEDVAT = G_REGUL                  : # Evénement
    [F:MAS1]VATREGDED += [M:FASR]DEDVAT                            : # Fichier
  Endif

  # -----------------------
  If (ACTTYPGES = GTAMMAS ) Then
    Call TVA_MAJ_PCG( LTYPREG, G_IMPBASVT, [M:MHC]FLGSIM, G_FORM, RTRN )
    If (RTRN) Then : Return : Endif
  Else
    Call TVA_MAJ_PCG( LTYPREG, G_IMPBASVT, G_NON,  G_FORM, RTRN )
    If (RTRN) Then : Return : Endif
  Endif

  # - IAS
  If (G_REGULI < 0 ) Then
    [M:FASR]DEDVATI = 0 : [M:FASR]CRBVATI = abs(G_REGULI)             : # Evénement
    [F:MAS1]IASVATREG  += [M:FASR]CRBVATI                             : # Fichier
  Else
    [M:FASR]CRBVATI = 0 : [M:FASR]DEDVATI = G_REGULI                  : # Evénement
    [F:MAS1]VATREGDEDI += [M:FASR]DEDVATI                             : # Fichier
  Endif
  # -----------------------
  If ( G_CNXPROIAS = G_OUI ) Then
    If (ACTTYPGES = GTAMMAS ) Then
      Call TVA_MAJ_IAS( LTYPREG, G_IMPBASVT, [M:MHC]FLGSIM, G_FORMI, RTRN )
      If (RTRN) Then : Return : Endif
    Else
      Call TVA_MAJ_IAS( LTYPREG, G_IMPBASVT, G_NON,  G_FORMI, RTRN )
      If (RTRN) Then : Return : Endif
    Endif
  Endif

Return


#=====================================================================
# Unitaire / massif : Après report du contenu de la table temporaire principale dans la table de données principale
$CLOS_ALIM_TABLE
  Gosub DEL_VARIABLES_GLOBALES
Return

######################################################################
# Points d'entrée objet de reprise
######################################################################

#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================
$LIENS
Return

################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################
$GESTRACE

 # Classe [M:FASR] paramètre disponible

 Case TRTYP
  When 1         # Ouverture de la trace
   If ACTSILENCE=G_NON
    If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA] : Endif
    # "Régularisation globale de TVA"
    Call OUVRE_TRACE(mess(657,7773,1),1) From TRACEABX3
   Endif
  When 20        # Paramètres de l'action
   # Date du régularisation
   Call ECR_TRACE("",GTRC_PARAM,left$(mess(658,773,1)+space$(27),27)+":"-format$("D:DD[ ]MMMMMMMMMM4Y",[M:FASR]MVTDAT),0,1) From TRACEABX3
   # Modification Législative
   If ( [M:FASR]VATADM = G_OUI) Then
     # Modification legislative des règles d'exclusion du droit à déduction
     Call ECR_TRACE("",GTRC_PARAM,mess(659,7773,1),0,1) From TRACEABX3
     # Coefficient d'admission
     Call ECR_TRACE("",GTRC_PARAM,left$(mess(660,7773,1)+space$(27),27) +":"-format$("N:3.2",[M:FASR]ADMCOE),0,1) From TRACEABX3
   Endif
   # Bien devenant
   If ( [M:FASR]VATOPN = G_OUI) Then
     # Bien(s) devenant utilisé(s) pour la réalisation d'opérations ouvrant droit à déduction
     Call ECR_TRACE("",GTRC_PARAM,mess(661,7773,1),0,1) From TRACEABX3
     # Secteur TVA
     Call ECR_TRACE("",GTRC_PARAM,left$(mess(662,7773,1)+space$(27),27) +":"-[M:FASR]AASBUS-"/"-[M:FASR]SACDES,0,1) From TRACEABX3
     # Coefficient de taxation
     Call ECR_TRACE("",GTRC_PARAM,left$(mess(663,7773,1)+space$(27),27) +":"-format$("N:3.2",[M:FASR]TAXCOE),0,1) From TRACEABX3
   Endif
   # Bien cessant
   If ( [M:FASR]VATCLS = G_OUI) Then
     # Bien(s) cessant d'être utilisé(s) pour la réalisation d'opérations ouvrant droit à déduction
     Call ECR_TRACE("",GTRC_PARAM,mess(664,7773,1),0,1) From TRACEABX3
     # Secteur TVA
     Call ECR_TRACE("",GTRC_PARAM,left$(mess(662,7773,1)+space$(27),27) +":"-[M:FASR]AASBUS-"/"-[M:FASR]SACDES,0,1) From TRACEABX3
   Endif
   # Bien cessant définitivement
   If ( [M:FASR]VATDEF = G_OUI) Then
     # Bien(s) cessant DEFINITIVEMENT d'être utilisé(s) pour la réalisation d'opérations ouvrant droit à déduction
     Call ECR_TRACE("",GTRC_PARAM,mess(665,7773,1),0,1) From TRACEABX3
     # Secteur TVA
     Call ECR_TRACE("",GTRC_PARAM,left$(mess(662,7773,1)+space$(27),27) +":"-[M:FASR]AASBUS-"/"-[M:FASR]SACDES,0,1) From TRACEABX3
   Endif

  When Default
 Endcase
Return

#===============================
Subprog ECR_ENTETE (PCPY)
Value Char PCPY

Local    Char    LINE(115)

  If ( FLGDET = G_OUI and  ACTSILENCE <> G_OUI ) Then
    # Entête pour les biens ayant subi une régularisation globale

    LINE = ""
    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    # APPLICATION REGULARISATION GLOBALE DE TVA
    LINE = mess(666,7773,1)
    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE = ""
    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE = string$(115,"*")
    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE =      left$( mess(301,7773,1)      + string$(20,' '), 20)+"!"
    LINE +=     left$( mess(302,7773,1)      + string$(20,' '), 20)+"!"
    LINE +=     left$( mess(667,7773,1)      + string$(10,' '), 10)+"!"   : # Anc. Coef
    LINE +=     left$( mess(313,7773,1)      + string$(20,' '), 20)+'!'
    LINE +=     left$( mess(305,7773,1)      + string$(20,' '), 20)+'!'
    LINE +=     left$( mess(306,7773,1)      + string$(20,' '), 20)+'!'
    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE =      left$( " "                  + string$(41,' '), 41)+"!"
    LINE +=     left$( mess(668,7773,1)      + string$(10,' '), 10)+"!"   : # Nouv.Coef
    LINE +=     left$( mess(669,7773,1)      + string$(20,' '), 20)+'!'   : # Pér. Résid/Glob.
    If ( G_CNXPROIAS = G_OUI ) Then
      LINE +=     left$( mess(310,7773,1)      + string$(20,' '), 20)+'!'
      LINE +=     left$( mess(311,7773,1)      + string$(20,' '), 20)+'! '
    Else
      LINE +=     left$( " "                  + string$(20,' '), 20)+'!'
      LINE +=     left$( " "                  + string$(20,' '), 20)+'! '
    Endif
    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE = string$(115,"*")
    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
  Endif

End

#===============================
Subprog ECR_LIGNE (PCPY, PREF, PDES, PSAC, PIVCVATAMT, PDEDCOEFO, PDEDCOEF, PPERREG, PPERRES,  PREGUL, PREGULI, PPCGBAS, PIASBAS)

Value Char      PCPY
Value Char      PREF
Value Char      PDES
Value Char      PSAC
Value Decimal   PIVCVATAMT
Value Decimal   PDEDCOEFO
Value Decimal   PDEDCOEF
Value Integer   PPERREG
Value Integer   PPERRES
Value Decimal   PREGUL
Value Decimal   PREGULI
Value Decimal   PPCGBAS
Value Decimal   PIASBAS

Local    Char    LINE(115)

Local    Char    PROR (19)  : PROR = "        "+num$(PPERRES)-"/"-num$(PPERREG)

  #---------------------------------------
  If ( FLGDET = G_OUI and ACTSILENCE <> G_OUI) Then
    #  (ligne 1)
    LINE =  left$( PREF                                    + string$(20,' '), 20) +"!"
    LINE += left$( PSAC                                    + string$(20,' '), 20) +"!"
    LINE += left$( format$("N:3.2", PDEDCOEFO)             + string$(10,' '), 10) +"!"
    LINE += left$( format$('N:'+GFMT3, PIVCVATAMT)         + string$(20,' '), 20) +"!"
    LINE += left$( format$('N:'+GFMT3, PREGUL)             + string$(20,' '), 20) +"!"
    LINE += left$( format$('N:'+GFMT3, PPCGBAS)           + string$(20,' '), 20) +" "
    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    #  (ligne 2)
    LINE =  left$( PDES  + string$(41,' '), 41) +"!"
    LINE += left$( format$("N:3.2", PDEDCOEF)              + string$(10,' '), 10) +"!"
    LINE += left$( PROR                                    + string$(20,' '), 20) +"!"
    LINE += left$( format$('N:'+GFMT3, PREGULI)            + string$(20,' '), 20) +"!"
    LINE += left$( format$('N:'+GFMT3, PIASBAS)           + string$(20,' '), 20) +" "
    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE = ""
    Call ECR_TRACE(PCPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
  Endif
  #---------------------------------------

  If ( ACTSILENCE = G_OUI ) Then
    GT_OBJ_REF(I_OBJ)=PREF
    GT_OBJ_DES(I_OBJ)=PDES
    I_OBJ+=1
  Endif
End


