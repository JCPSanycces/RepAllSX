#--------------------------------------------------------------#
# Initialisation de la fenêtre paramètre des régul globales    #
#--------------------------------------------------------------#
$INIT_WIN_FASVATRGG

 Effzo [M:FASR]VATADM
 Effzo [M:FASR]VATOPN
 Effzo [M:FASR]VATCLS
 Effzo [M:FASR]VATDEF
 Effzo [M:FASR]ADMCOE
 Effzo [M:FASR]AASBUS
 Effzo [M:FASR]SACDES
 Effzo [M:FASR]TAXCOE
 If ( ACTTYPGES = GTAMMAS ) Then :  Effzo [M:ASL]10 : Effzo [M:ASL]15 : Endif

 #-> Initialisation générale (Massif/Unitaire)
 # FQ61480
 #[M:FASR]MVTDAT=date$

 If ( ACTTYPGES = GTAMUNI ) Then : [M:FASR]VATADM= G_OUI : Else : [M:FASR]VATADM= G_NON : Endif
 [M:FASR]VATOPN= G_NON
 [M:FASR]VATCLS= G_NON
 [M:FASR]VATDEF= G_NON
 [M:FASR]ADMCOE= 0.
 [M:FASR]AASBUS= ""
 [M:FASR]SACDES= ""
 [M:FASR]TAXCOE= 0.

 #--> En unitaire chargement des valeurs actuelles du bien comptable courant
 If ( ACTTYPGES = GTAMUNI ) Then
 Endif


 #--> Conditionnement des paramètres
 # Pas de sélection étendue
 If ( ACTTYPGES = GTAMUNI ) Then
   Actzo [M:FASR]ADMCOE
 Endif
 If ( ACTTYPGES = GTAMMAS ) Then
   Diszo [M:ASL]10
   Diszo [M:ASL]15
   Diszo [M:FASR]ADMCOE
   Diszo [M:FASR]AASBUS
   Diszo [M:FASR]TAXCOE
   Actzo [M:FASR]VATADM
   Actzo [M:FASR]VATOPN
   Actzo [M:FASR]VATCLS
   Actzo [M:FASR]VATDEF
 Endif

 #--> Réaffichage du masque paramètre et positionnement à non valide pour forcer tous les contrôles

 Affzo  [M:FASR]
 If ( ACTTYPGES = GTAMMAS ) Then :  Affzo  [M:ASL] : Endif
 Setmok [M:FASR] With 0

Return





