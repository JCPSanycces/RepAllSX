##########################################################################
## Gestion du masque FASVATRGGP [M:FASR]
##########################################################################


#==================================================================
#==================================================================
#----------------------------
Subprog AM_VATADM(VALEUR)
Variable Integer VALEUR

  Case VALEUR
    When G_OUI
      Actzo [M:FASR]ADMCOE
      If ( ACTTYPGES=GTAMMAS ) Then
        Diszo [M:FASR]VATOPN
        Diszo [M:FASR]VATCLS
        Diszo [M:FASR]VATDEF
        Diszo [M:FASR]TAXCOE
        Actzo [M:ASL]10  : Actzo [M:ASL]15 : Affzo [M:ASL]
      Endif
    When G_NON
      If ( ACTTYPGES=GTAMUNI ) Then
        [M:FASR]ADMCOE = 0. : Affzo [M:FASR]ADMCOE : Diszo [M:FASR]ADMCOE
      Endif
      If ( ACTTYPGES=GTAMMAS ) Then
        Gosub INIT_WIN_FASVATRGG
      Endif
  Endcase
End
#==================================================================
#----------------------------
Subprog AM_VATOPN(VALEUR)
Variable Integer VALEUR

  Case VALEUR
    When G_OUI
      If ( ACTTYPGES=GTAMMAS ) Then
        Actzo [M:FASR]AASBUS
        Diszo [M:FASR]VATADM
        Diszo [M:FASR]VATCLS
        Diszo [M:FASR]VATDEF
        Actzo [M:FASR]TAXCOE
      Endif
    When G_NON
      Gosub INIT_WIN_FASVATRGG
  Endcase
End

#==================================================================
#----------------------------
Subprog AM_VATCLS(VALEUR)
Variable Integer VALEUR

  Case VALEUR
    When G_OUI
      Actzo [M:FASR]AASBUS
      Diszo [M:FASR]VATADM
      Diszo [M:FASR]VATOPN
      Diszo [M:FASR]VATDEF
      Diszo [M:FASR]TAXCOE
    When G_NON
      Gosub INIT_WIN_FASVATRGG
  Endcase
End

#==================================================================
#----------------------------
Subprog AM_VATDEF(VALEUR)
Variable Integer VALEUR

  Case VALEUR
    When G_OUI
      If ( ACTTYPGES=GTAMMAS ) Then
        Actzo [M:FASR]AASBUS
        Diszo [M:FASR]VATADM
        Diszo [M:FASR]VATOPN
        Diszo [M:FASR]VATCLS
        Diszo [M:FASR]TAXCOE
      Endif
    When G_NON
      If ( ACTTYPGES=GTAMMAS ) Then
        Gosub INIT_WIN_FASVATRGG
      Endif
  Endcase
  Affzo [M:FASR]
End

#==================================================================
#----------------------------
Subprog AM_ADMCOE(VALEUR)
Variable Decimal VALEUR

  If ( VALEUR < 0. or VALEUR > 1. ) Then
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1) : mkstat = 2 : End
  Endif
End

#==================================================================
#----------------------------
Subprog AM_AASBUS(VALEUR)
Variable Char    VALEUR()


  If clalev([F:SEA]) =0  : Local File SECACT  [SEA]  : Endif  : # secteurs d'activité
  Read [F:SEA]SEA0=[M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1);VALEUR
  If (fstat) Then
    # Secteur d'activité invalide
    GERR=1 :  GMESSAGE = mess(636,7773,1) : mkstat = 2   :  End
  Endif

  If ( [M:FASR]VATOPN = G_OUI and [F:SEA]TAXCOEDEF <> 0 ) Then
    # Secteur d'activité invalide
    GERR=1 :  GMESSAGE = mess(636,7773,1) : mkstat = 2   :  End
  Endif
  If ( [M:FASR]VATCLS = G_OUI and [F:SEA]TAXCOEDEF = 0 ) Then
    # Secteur d'activité invalide
    GERR=1 :  GMESSAGE = mess(636,7773,1) : mkstat = 2   :  End
  Endif
  If ( [M:FASR]VATDEF = G_OUI and [F:SEA]TAXCOEDEF <> 0  ) Then
    # Secteur d'activité invalide (Il faut être d'abord passé par VATCLS avant de passer par VATDEF)
    GERR=1 :  GMESSAGE = mess(636,7773,1) : mkstat = 2   :  End
  Endif

  If (VALEUR = "") Then : [M:FASR]SACDES = "" :  Else : [M:FASR]SACDES = [F:SEA]SACDES :   Endif
  Affzo [M:FASR]SACDES

End

#==================================================================
#----------------------------
Subprog AM_TAXCOE(VALEUR)
Variable Decimal VALEUR

  If ( VALEUR < 0. or VALEUR > 1. ) Then
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1) : mkstat = 2 : End
  Endif
  If ( [M:FASR]VATOPN = G_OUI and VALEUR = 0.  ) Then
    # Bien devenant : La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(173, 7773, 1) : mkstat = 2 : End
  Endif
End

#----------------------------
Subprog C_TAXCOE(VALEUR)
Variable Decimal VALEUR

  If ( VALEUR < 0. or VALEUR > 1. ) Then
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1) : mkstat = 2 : End
  Endif
  If ( [M:FASR]VATOPN = G_OUI and VALEUR = 0.  ) Then
    # Bien devenant : La valeur du coefficient doit être > 0. et <= 1.
    GERR= 1 : GMESSAGE= mess(173, 7773, 1) : mkstat = 2 : End
  Endif
End


##########################################################################
## Gestion du masque MFASRGG [M:MFS0]
##########################################################################

#-> Avant zone sur la variable de bas de tableau

#===========================================
Subprog AV_NBOBJ


 # Gestion de l'option "Supprimer ligne" dans tableau du bouton "Contrôler"
 If ([M:MFS0]NBOBJ > 1) Then
   If ( [M:FASR]VATADM = G_OUI ) Then
     # La suppression de ligne n'est autorisé que pour l'option Modification législative des règles d'exclusion
     Enable GSTAANU
     Enable 65
     GBOUT1=""
   Else
     Disable GSTAANU
     Disable 65
     GBOUT1=""
   Endif
 Else
   Disable GSTAANU
   Disable 65
   GBOUT1=""
 Endif

End

#===========================================
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
End

#===========================================
Subprog AS_NBOBJ
 If [M:MFS0]FLGERR(nolign-1)=G_NON
  GBOUT1=""
 Endif
End

#===========================================
Subprog B1_NBOBJ
End

#===========================================
Subprog INIT_PLAN_AMT(PCPY)

Value Char    PCPY
Local Integer ORIBASCPFI, CURTYPCPFI, ORIBAS, I
Local Char    CURCPFI
Local Date    FIYENDCPFI, PERENDCPFI
#Local Integer GRTFLGCPFI : # FQ96429                 :
Local Date    FIYSTRCPFIS, FIYENDCPFIS    : # Dates de début et de fin de période exercice suivant
Local Integer INDCURPERCPFIS              : # Numéro de la période courante de l'exercice suivant


  If !(clalev([F:CNX]))   : Local File CONTEXT   [CNX]   : Endif
  If !(clalev([F:FIS]))   : Local File FISCYEAR  [FIS]   : Endif

  # Le tableau est préchargé à partir des contextes pour que l'on ait pour chaque plan géré
  # la date de début de l'exercice courant et de la période courante

  # Lecture contexte FISCAL & COMPTABLE
  Read [CNX] CNX0=PCPY;G300CPFI
  If (fstat) Then : Raz [F:CNX] : Endif
  ORIBASCPFI=[F:CNX]ORIBASDPR(G301CPT-1)
  CURCPFI   =[F:CNX]CUR
  CURTYPCPFI=[F:CNX]CURTYP
  # FQ96429
  # GRTFLGCPFI=[F:CNX]GRTFLG

  # Lecture exercice courant FISCAL & COMPTABLE
  Filter [FIS] Where CPY=PCPY and CNX = G300CPFI and STAFIY = GVML_TECOURA
  Read [FIS]First
  If (fstat) Then : Raz [F:FIS] : Endif
  Filter [FIS]
  FIYENDCPFI =[F:FIS]DATENDFIY
  PERENDCPFI  = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  G_FINPERCPF = [F:FIS]DATENDPER([F:FIS]INDCURPER-1) : # Pour événement

  # Lecture exercice suivant FISCAL & COMPTABLE
  Read [FIS]FIY1=PCPY;G300CPFI;GVML_TESUIV
  If (fstat) Then : Raz [F:FIS] : Endif
  FIYSTRCPFIS=[F:FIS]DATSTRFIY
  FIYENDCPFIS=[F:FIS]DATENDFIY
  INDCURPERCPFIS=[F:FIS]INDCURPER

  G_CNXPROIAS = G_NON

  nolign = 1
  # ====================
  For [CNX] Where CPY =PCPY
    # =============
    For I = 0 To [F:CNX]NBPLC-1
      [M:FASR]DPRPLN(nolign-1) = [F:CNX]PLNCAA(I)

      If ([F:CNX]PLNCAA(I)= G301CPT or [F:CNX]PLNCAA(I)= G301FIS or
&         [F:CNX]PLNCAA(I)= G301MIN or [F:CNX]PLNCAA(I)= G301ORI or
&         [F:CNX]PLNCAA(I)= G301R76 ) Then
        [M:FASR]ORIBAS(nolign-1)     = ORIBASCPFI
        [M:FASR]CUR(nolign-1)        = CURCPFI
        [M:FASR]CURTYP(nolign-1)     = CURTYPCPFI
        [M:FASR]FIYENDDAT(nolign-1)  = FIYENDCPFI
        [M:FASR]PERENDDAT(nolign-1)  = PERENDCPFI
        [M:FASR]FIYSTRDATS(nolign-1) = FIYSTRCPFIS
        [M:FASR]FIYENDDATS(nolign-1) = FIYENDCPFIS
        [M:FASR]INDCURPERS(nolign-1) = INDCURPERCPFIS
        # FQ96429
        #[M:FASR]GRTFLG(nolign-1)     = GRTFLGCPFI
      Else
        [M:FASR]ORIBAS(nolign-1)    =[F:CNX]ORIBASDPR(I)
        [M:FASR]CUR(nolign-1)       =[F:CNX]CUR
        [M:FASR]CURTYP(nolign-1)    =[F:CNX]CURTYP
        # FQ96429
        #[M:FASR]GRTFLG(nolign-1)    =[F:CNX]GRTFLG

        # Lecture exercice courant
        Filter [FIS] Where CPY=PCPY and CNX = [F:CNX]CNX and STAFIY = GVML_TECOURA
        Read [FIS]First
        If (fstat) Then : Raz [F:FIS] : Endif
        Filter [FIS]
        [M:FASR]FIYENDDAT(nolign-1) = [F:FIS]DATENDFIY
        [M:FASR]PERENDDAT(nolign-1) = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
        If ( [F:CNX]PLNCAA(I)= G301IAS ) Then
          G_FINPERIAS = [F:FIS]DATENDPER([F:FIS]INDCURPER-1) : # Pour événement
          G_CNXPROIAS = G_OUI
        Endif

        # Lecture exercice suivant
        Read [FIS]FIY1=PCPY;[F:CNX]CNX;GVML_TESUIV
        If (fstat) Then : Raz [F:FIS] : Endif
        [M:FASR]FIYSTRDATS(nolign-1)=[F:FIS]DATSTRFIY
        [M:FASR]FIYENDDATS(nolign-1)=[F:FIS]DATENDFIY
        [M:FASR]INDCURPERS(nolign-1) = [F:FIS]INDCURPER
        [M:FASR]PERENDDATS(nolign-1) = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
      Endif
      nolign += 1
    Next I
    # =============
  Next
  # ====================

  [M:FASR]NBLIG1 = nolign-1

End

#
#########################################################
Subprog TVA_MAJ_PCG( PTYPREG, PMAJBAS, PFLGSIM, PFORMULE, RERROR )
# - Objet  : Mise à jour
#
#
# - Entrée    :
#               PREGTVA     Régularisation TVA
#               PMAJBAS     Mise à jour des base
#               PFLGSIM     Indicateur traitement simulé
#
# - Sortie    : RERROR
#                   3 Erreur de conversion
#                   4 Erreur génération événement
#
# - Paramètres en variables globales :
#
#               G_REGUL
#               G_REGCOD
#

Value    Integer PTYPREG
Value    Integer PMAJBAS
Value    Integer PFLGSIM
Value    Char    PFORMULE
Variable Integer RERROR

Local Integer STAT
Local Decimal MTDES, MNTDES2
Local Integer LCDRET
Local Char    LMESSAGE

Local Decimal SBSEVAL
Local Decimal SDPRBAS
Local Integer L_CPT

  #If (GUSER = "MWA" ) Then : Dbgaff : Endif

  # Si la régularisation est égale à 0. On sort (n fois la même variation dans le temps)
  If ( G_REGUL = 0 ) Then : End : Endif

  # Actualisation informations du bien comptable
  #-0 ---------------------------
  If ( PMAJBAS = G_OUI ) Then
     # Mise à jour des bases  avec la régularisation
     [F:MAS1]GALREFBAS -= G_REGUL
     [F:MAS1]TAXBAS    -= G_REGUL
  Endif
  #-0 ---------------------------

  # Mise à jour des bases avec l'écart selon oribas PCG (avec conversion éventuelle)
  If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif

  L_CPT = find(G301CPT, [M:FASR]DPRPLN)
  Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(L_CPT-1);
&                  [M:FASR]FIYENDDAT(L_CPT-1);[M:FASR]PERENDDAT(L_CPT-1)
  # Sauvegarde Bases d'amortissement comptable
  SBSEVAL  = [F:DEPX]BSEVAL
  SDPRBAS  = [F:DEPX]DPRBAS
  G_BASPCG = [F:DEPX]DPRBAS - G_REGUL

  #>0 >>>>>>>>>>>>>>>>>>>>>>>>>>>
  For nolign = 1 To [M:FASR]NBLIG1
    #----1-------------------
    # FQ96429
    #If ( [M:FASR]ORIBAS(nolign-1) = GVML_OBPCG  and [M:FASR]GRTFLG(nolign-1) <> G_OUI ) Then
    If ( [M:FASR]ORIBAS(nolign-1) = GVML_OBPCG ) Then
      Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(nolign-1);
&                      [M:FASR]FIYENDDAT(nolign-1);[M:FASR]PERENDDAT(nolign-1)
      #----2-------------------
      If (PMAJBAS = G_OUI) Then
        # Mise à jour si même devise et même base d'amortissmeent
        If ( [M:FASR]CUR   (L_CPT-1) = [M:FASR]CUR   (nolign-1) and
&         [F:DEPX]BSEVAL = SBSEVAL  and
&         [F:DEPX]DPRBAS = SDPRBAS  ) Then
          [F:DEPX]BSEVAL -= G_REGUL
          [F:DEPX]DPRBAS -= G_REGUL
        Endif
      Endif
      #----2-------------------
      # Mise à jour
      #----2-------------------
      If ( PFLGSIM = G_NON ) Then
        If ( PMAJBAS = G_OUI ) Then
          [F:DEPX]DEPSTA                   = GVML_SCNOCAL
          [F:MAS1]FLGCLC                   = G_OUI
          [F:MAS1]FLGCNXCLC([F:DEPX]CNX-1) = G_OUI
          Rewrite [DEPX]
          If (fstat) Then : RTRN = 2 : End : Endif
        Endif
        # Plan comptable uniquement
        If ( [F:DEPX]DPRPLN = G301CPT  ) Then
          # --- Ecart sur base
          If ( PMAJBAS = G_OUI ) Then
            G_BASDEV = [F:DEPX]DPRBAS - SDPRBAS
          Else
            G_BASDEV = 0.
          Endif
          # --- Génération événement de régularisation de TVA
          LCDINT= "FASVATREG1"
          G_DEDVATAMT = [F:MAS1]DEDVATAMT
          Call GENER_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,
&                         [F:MAS1]AASREF,0,LCDINT, G_FINPERCPF,[0/0/0],LCDRET) From GENEVE
          If (LCDRET > 20 ) Then : RERROR = 4 : End : Endif :   # Erreur écriture génération évènement
          # --- Ecriture dans HISVAT ( PCG )
          [F:HFAS] = [F:MAS1]
          [F:HFAS]VATREGDAT = G_FINPERCPF
          MNTDES = SBSEVAL   : MNTDES2 = [F:DEPX]BSEVAL
          Call TVA_ECR_HISTORIQUE (PTYPREG, G301CPT, MNTDES, MNTDES2, PFORMULE, LCDRET) From TRTFAS
          If (LCDRET) Then : RERROR = 8 : End : Endif :   # Erreur écriture dans l'historique
        Endif
      Endif
      #----2-------------------

      # S'il y a mise à jour des bases d'amortissement pour un bien acquis dans l'exercice courant
      # et qu'on est dans le cas d'un recouvrement exercice courant/exercice suivant, il faut
      # extourner et supprimer le futur du bien
      #----2-------------------
      If ( PFLGSIM = G_NON  and PMAJBAS = G_OUI and [M:FASR]INDCURPERS(nolign-1) > 1 ) Then
        # extourne des événements
        Call EXTOURNE_FAS_GRP_EVE ([F:MAS1]CPY,[F:MAS1]AASREF,[M:FASR]DPRPLN(nolign-1),
&            [M:FASR]FIYSTRDATS(nolign-1),[0/0/0], 2,[M:FASR]PERENDDATS(nolign-1),LCDRET) From GENEVE
        If LCDRET Then : RTRN = 5 : End : Endif  # Erreur extourne des événements
        # suppression des DEPREC
        Delete [F:DEPX]DEP3(4)=[F:MAS1]CPY;[M:FASR]DPRPLN(nolign-1);[F:MAS1]AASREF;[M:FASR]FIYENDDATS(nolign-1)
        If ( fstat ) Then
          Call ECR_TRACE ("Delete DEPREC : "-num$(fstat),1) From GESECRAN
          RTRN = 6 : Return
        Endif
        # suppression des flux FQ64478
        # Call SUPP_FLUX([F:MAS1]AASREF, [M:FASR]DPRPLN(nolign-1), [M:FASR]FIYSTRDATS(nolign-1), LCDRET) From TRTFLUX
        # If LCDRET < 0
        #  Call GERE_MSG_ERREUR_FLUX(LCDRET , LMESSAGE) From TRTFLUX
        #  Call ECR_TRACE (LMESSAGE,1) From GESECRAN
        #  RTRN = 7 : Return
        # Endif
      Endif
      #----2-------------------
    Endif
    #----1-------------------
  Next nolign
  #<0 <<<<<<<<<<<<<<<<<<<

End



#
#########################################################
Subprog TVA_MAJ_IAS( PTYPREG, PMAJBAS, PFLGSIM, PFORMULE, RERROR )
# - Objet  : Mise à jour
#
#
# - Entrée    :
#               PTYPREG     Type de régularisation TVA
#               PREGTVA     Régularisation TVA
#               PMAJBAS     Mise à jour des base
#               PFLGSIM     Indicateur traitement simulé
#
# - Sortie    : RERROR
#                   3 Erreur de conversion
#                   4 Erreur génération événement
#
# - Prérequis : Ce sous-programme utilise la classe [F:MAS1] qui doit être ouverte et alimentée
#

Value    Integer PTYPREG
Value    Integer PMAJBAS
Value    Integer PFLGSIM
Value    Char    PFORMULE
Variable Integer RERROR

Local Integer STAT
Local Decimal MTDES, MNTDES2
Local Integer LCDRET
Local Char    LMESSAGE

Local Decimal SBSEVALI
Local Decimal SDPRBASI
Local Integer L_IAS

  # Si la régularisation est égale à 0. On sort (n fois la même variation dans le temps)
  If ( G_REGULI = 0 ) Then : End : Endif


  # Mise à jour des bases avec l'écart selon oribas PCG (avec conversion éventuelle)
  If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif

  # Lecture plan IAS
  L_IAS = find(G301IAS, [M:FASR]DPRPLN)
  Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(L_IAS-1);
&                  [M:FASR]FIYENDDAT(L_IAS-1);[M:FASR]PERENDDAT(L_IAS-1)
  # Sauvegarde Bases d'amortissement comptable
  SBSEVALI = [F:DEPX]BSEVAL
  SDPRBASI = [F:DEPX]DPRBAS
  G_BASIAS = [F:DEPX]DPRBAS - G_REGUL

  #>0 >>>>>>>>>>>>>>>>>>>>>>>>>>>
  For nolign = 1 To [M:FASR]NBLIG1
    #----1-------------------
    # FQ96429
    #If ( [M:FASR]ORIBAS(nolign-1) = GVML_OBIAS  and [M:FASR]GRTFLG(nolign-1) <> G_OUI ) Then
    If ( [M:FASR]ORIBAS(nolign-1) = GVML_OBIAS ) Then
      Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(nolign-1);
&                      [M:FASR]FIYENDDAT(nolign-1);[M:FASR]PERENDDAT(nolign-1)
      #----2-------------------
      If (PMAJBAS = G_OUI) Then
        # Mise à jour si même devise et même base d'amortissmeent
        If ( [M:FASR]CUR(L_IAS-1) = [M:FASR]CUR(nolign-1) and
&            [F:DEPX]BSEVAL = SBSEVALI  and
&            [F:DEPX]DPRBAS = SDPRBASI  ) Then
          [F:DEPX]BSEVAL -= G_REGULI
          [F:DEPX]DPRBAS -= G_REGULI
        Endif
      Endif
      #----2-------------------
      # Mise à jour
      #----2-------------------
      If ( PFLGSIM = G_NON ) Then
        If ( PMAJBAS = G_OUI ) Then
          [F:DEPX]DEPSTA                   = GVML_SCNOCAL
          [F:MAS1]FLGCLC                   = G_OUI
          [F:MAS1]FLGCNXCLC([F:DEPX]CNX-1) = G_OUI
          Rewrite [DEPX]
          If (fstat) Then : RTRN = 2 : End : Endif
        Endif
        # Plan IAS uniquement
        If ( [F:DEPX]DPRPLN = G301IAS  ) Then
          # --- Ecart sur base
          If ( PMAJBAS = G_OUI ) Then
            G_BASDEV = [F:DEPX]DPRBAS - SDPRBASI
          Else
            G_BASDEV = 0.
          Endif
          # --- Génération événement de régularisation de TVA
          LCDINT= "FASVATREG6"
          G_DEDVATAMTI = [F:MAS1]DEDVATAMTI
          Call GENER_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,
&                         [F:MAS1]AASREF,0,LCDINT,G_FINPERIAS,[0/0/0],LCDRET) From GENEVE
          If (LCDRET > 20 ) Then : RERROR = 4 : End : Endif :   # Erreur écriture génération évènement
          # --- Ecriture dans HISVAT ( IAS )
          [F:HFAS] = [F:MAS1]
          [F:HFAS]VATREGDAT = G_FINPERIAS
          MNTDES = SBSEVALI   : MNTDES2 = [F:DEPX]BSEVAL
          Call TVA_ECR_HISTORIQUE (PTYPREG, G301IAS, MNTDES, [F:DEPX]BSEVAL, PFORMULE, LCDRET) From TRTFAS
          If (LCDRET) Then : RERROR = 8 : End : Endif :   # Erreur écriture dans l'historique
        Endif
      Endif
      #----2-------------------
    Endif
    #----1-------------------
  Next nolign
  #<0 <<<<<<<<<<<<<<<<<<<

End


#===================
$OUVRE_TABLES
#===================
  If !(clalev([F:HFAS]))  : Local File FXDASSETS [HFAS]  : Endif
  If !(clalev([F:HIS]))   : Local File VATHIS    [HIS]   : Endif  : # historique Régul. TVA
Return


#=====================================================================
$CRT_VARIABLES_GLOBALES

  If dim([V]G_CNXPROIAS)<0    : Global Decimal G_CNXPROIAS   : Endif : # Plan IAS géré

  If dim([V]G_ECIMPBAS)<0    : Global Decimal G_ECIMPBAS     : Endif : # Ecart imputation bases fixation définitif
  If dim([V]G_ECVARPRO)<0    : Global Decimal G_ECVARPRO     : Endif : # Ecart variation du prorata dans le temps
  If dim([V]G_IMPBASVT)<0    : Global Decimal G_IMPBASVT     : Endif : # Indicateur imputation base si variation du prorata dans le temps
  If dim([V]G_TENCOURS)<0    : Global Decimal G_TENCOURS     : Endif : # Immobilisation En cours à régulariser
  If dim([V]G_REGULIAS)<0    : Global Decimal G_REGULIAS     : Endif : # Régularisation TVA applicable aux valorisations IAS/IFRS
  If dim([V]G_FINPERCPF) <0  : Global Date    G_FINPERCPF    : Endif : # Fin période/exercice pour événement
  If dim([V]G_FINPERIAS) <0  : Global Date    G_FINPERIAS    : Endif : # Fin période/exercice pour événement

  # Variables pour la régularisation de TVA.

  If dim([V]G_REGCOD)<0      : Global Decimal G_REGCOD       : Endif : # Type de régularisation
  If dim([V]G_REGUL)<0       : Global Decimal G_REGUL        : Endif : # Régul PCG
  If dim([V]G_REGULI)<0      : Global Decimal G_REGULI       : Endif : # Régul IAS
  If dim([V]G_FORM)<0        : Global Char    G_FORM(250)    : Endif : # Formule Régul PCG
  If dim([V]G_FORMI)<0       : Global Char    G_FORMI(255)   : Endif : # Formule Régul IAS
  If dim([V]G_MAJBAS)<0      : Global Integer G_MAJBAS       : Endif : # Indicateur base mise à jour par la régul.
  If dim([V]G_BASPCG)<0      : Global Decimal G_BASPCG       : Endif : # Base PCG
  If dim([V]G_BASIAS)<0      : Global Decimal G_BASIAS       : Endif : # Base IAS
  If dim([V]G_SACLCK)<0      : Global Integer G_SACLCK       : Endif : # Indicateur Secteur d'activité locké.
  If dim([V]G_SACKEY)<0      : Global Char    G_SACKEY       : Endif : # Indicateur Clé du Secteur d'activité locké.

  # Variables pour la régularisation de VATHIS.

  If dim([V]G_AASBUSO)<0     : Global Char    G_AASBUSO      : Endif
  If dim([V]G_ASJCOERO)<0    : Global Decimal G_ASJCOERO     : Endif
  If dim([V]G_TAXCOERO)<0    : Global Decimal G_TAXCOERO     : Endif
  If dim([V]G_ADMCOERO)<0    : Global Decimal G_ADMCOERO     : Endif
  If dim([V]G_DEDCOERO)<0    : Global Decimal G_DEDCOERO     : Endif
  If dim([V]G_ASJCOEO)<0     : Global Decimal G_ASJCOEO      : Endif
  If dim([V]G_TAXCOEO)<0     : Global Decimal G_TAXCOEO      : Endif
  If dim([V]G_TAXCOEFLGO)<0  : Global Integer G_TAXCOEFLGO   : Endif
  If dim([V]G_ADMCOEO)<0     : Global Decimal G_ADMCOEO      : Endif
  If dim([V]G_DEDCOEO)<0     : Global Decimal G_DEDCOEO      : Endif
  If dim([V]G_VATREGDATO)<0  : Global Date    G_VATREGDATO   : Endif
  If dim([V]G_IVCVATAMTO)<0  : Global Decimal G_IVCVATAMTO   : Endif
  If dim([V]G_IVCVATIASO)<0  : Global Decimal G_IVCVATIASO   : Endif
  If dim([V]G_DEDVATAMTO)<0  : Global Decimal G_DEDVATAMTO   : Endif
  If dim([V]G_DEDVATIASO)<0  : Global Decimal G_DEDVATIASO   : Endif
  If dim([V]G_ASJCOEFO)<0    : Global Decimal G_ASJCOEFO     : Endif
  If dim([V]G_TAXCOEFO)<0    : Global Decimal G_TAXCOEFO     : Endif
  If dim([V]G_ADMCOEFO)<0    : Global Decimal G_ADMCOEFO     : Endif
  If dim([V]G_DEDCOEFO)<0    : Global Decimal G_DEDCOEFO     : Endif

  If dim([V]G_BASDEV)<0      : Global Integer G_BASDEV       : Endif : # Ecart sur base
  If dim([V]G_DEDVATAMT)<0   : Global Integer G_DEDVATAMT    : Endif : # TVA récupérée PCG
  If dim([V]G_DEDVATAMTI)<0  : Global Integer G_DEDVATAMTI   : Endif : # TVA récupérée IAS

Return

#=====================================================================
$DEL_VARIABLES_GLOBALES

  If dim(G_CNXPROIAS)     >0 : Kill [V]G_CNXPROIAS    : Endif   : # Plan IAS géré

  If dim(G_ECIMPBAS)     >0  : Kill [V]G_ECIMPBAS     : Endif   : # Ecart imputation bases
  If dim(G_ECVARPRO)     >0  : Kill [V]G_ECVARPRO     : Endif   : # Ecart variation du prorata dans le temps
  If dim(G_IMPBASVT)     >0  : Kill [V]G_IMPBASVT     : Endif   : # Indicateur imputation base si variation du prorata dans le temps
  If dim(G_TENCOURS)     >0  : Kill [V]G_TENCOURS     : Endif   : # Immobilisation En cours à régulariser
  If dim(G_REGULIAS)     >0  : Kill [V]G_REGULIAS     : Endif   : # Régularisation TVA applicable aux valorisations IAS/IFRS
  If dim([V]G_FINPERCPF) <0  : Kill [V]G_FINPERCPF    : Endif   : # Fin période/exercice pour événement
  If dim([V]G_FINPERIAS) <0  : Kill [V]G_FINPERIAS    : Endif   : # Fin période/exercice pour événement

  # Variables pour la régularisation de TVA.

  If dim([V]G_REGCOD)>0   : Kill [V]G_REGCOD        : Endif   : # Type de regularisation
  If dim([V]G_REGUL)>0    : Kill [V]G_REGUL         : Endif   : # Régul PCG
  If dim([V]G_REGULI)>0   : Kill [V]G_REGULI        : Endif   : # Régul IAS
  If dim([V]G_FORM)>0     : Kill [V]G_FORM          : Endif   : # Formule Régul PCG
  If dim([V]G_FORMI)>0    : Kill [V]G_FORMI         : Endif   : # Formule Régul IAS
  If dim([V]G_MAJBAS)>0   : Kill [V]G_MAJBAS        : Endif   : # Indicateur base mise à jour par la régul.
  If dim([V]G_BASPCG)>0   : Kill [V]G_BASPCG        : Endif   : # Base PCG
  If dim([V]G_BASIAS)>0   : Kill [V]G_BASIAS        : Endif   : # Base IAS
  #If dim([V]G_SACLCK)>0   : Kill [V]G_SACLCK        : Endif   : # Indicateur Secteur d'activité locké.

  # Variables pour la régularisation de VATHIS.

  If dim([V]G_AASBUSO)>0    : Kill [V]G_AASBUSO     : Endif
  If dim([V]G_ASJCOERO)>0   : Kill [V]G_ASJCOERO    : Endif
  If dim([V]G_TAXCOERO)>0   : Kill [V]G_TAXCOERO    : Endif
  If dim([V]G_ADMCOERO)>0   : Kill [V]G_ADMCOERO    : Endif
  If dim([V]G_DEDCOERO)>0   : Kill [V]G_DEDCOERO    : Endif
  If dim([V]G_ASJCOEO)>0    : Kill [V]G_ASJCOEO     : Endif
  If dim([V]G_TAXCOEO)>0    : Kill [V]G_TAXCOEO     : Endif
  If dim([V]G_TAXCOEFLGO)>0 : Kill [V]G_TAXCOEFLGO  : Endif
  If dim([V]G_ADMCOEO)>0    : Kill [V]G_ADMCOEO     : Endif
  If dim([V]G_DEDCOEO)>0    : Kill [V]G_DEDCOEO     : Endif
  If dim([V]G_VATREGDATO)>0 : Kill [V]G_VATREGDATO  : Endif
  If dim([V]G_IVCVATAMTO)>0 : Kill [V]G_IVCVATAMTO  : Endif
  If dim([V]G_IVCVATIASO)>0 : Kill [V]G_IVCVATIASO  : Endif
  If dim([V]G_DEDVATAMTO)>0 : Kill [V]G_DEDVATAMTO  : Endif
  If dim([V]G_DEDVATIASO)>0 : Kill [V]G_DEDVATIASO  : Endif
  If dim([V]G_ASJCOEFO)>0   : Kill [V]G_ASJCOEFO    : Endif
  If dim([V]G_TAXCOEFO)>0   : Kill [V]G_TAXCOEFO    : Endif
  If dim([V]G_ADMCOEFO)>0   : Kill [V]G_ADMCOEFO    : Endif
  If dim([V]G_DEDCOEFO)>0   : Kill [V]G_DEDCOEFO    : Endif

  If dim([V]G_BASDEV)>0     : Kill [V]G_BASDEV      : Endif   : # Ecart sur base
  If dim([V]G_DEDVATAMT)>0  : Kill [V]G_DEDVATAMT   : Endif   : # TVA récupérée PCG
  If dim([V]G_DEDVATAMTI)>0 : Kill [V]G_DEDVATAMTI  : Endif   : # TVA récupérée IAS


Return


$MAJ_SECACT
#
# Mise à jour du secteur d'activité selon paramétrage

  If ( [M:FASR]VATADM <> G_OUI ) Then

    If clalev([F:SEA]) =0  : Local File SECACT  [SEA]  : Endif  : # secteurs d'activité

    Read [F:SEA]SEA0=[M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1);[M:FASR]AASBUS

    If ( [M:FASR]VATOPN = G_OUI ) Then
      # Biens devenant
      [F:SEA]TAXCOEINI = [M:FASR]TAXCOE
      [F:SEA]TAXCOEDEF = [M:FASR]TAXCOE
      [F:SEA]TAXCOEFLG = G_NON
    Endif
    If ( [M:FASR]VATCLS = G_OUI ) Then
      # Biens cessant
      [F:SEA]TAXCOEINI = 0.
      [F:SEA]TAXCOEDEF = 0.
      [F:SEA]TAXCOEFLG = G_OUI
    Endif
    If ( [M:FASR]VATDEF = G_OUI ) Then
      # Biens cessant DEFINITIVEMENT
      [F:SEA]ASJCOE    = 0.
    Endif

    Rewrite [F:SEA]
  Endif

  B_SACMAJ = 1


Return






