#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des campagne d'appels   Module CRM           15 Décembre 2003
#
#   DISPICON    : Affichage des icônes
#   SAVECLOB    : Enregistrement des CLOBs
#   DELCLOB     : Suppression des CLOBs
#   LOADCLOB    : Chargement du CLOB compte-rendu
#   LOADTSALES  : Chargement des téléacteurs participants
#   CHECKMODIF  : Contrôle de la modification d'une opération.
#
##########################################################################################################
##########################################################################################################
#Affichage des icônes
######################################################
$DISPICON
  Gosub DEFICONNUM From CRMUTIL150
  #Synthèse Objet de l'action
  If len([M:OMP1]FULOBJ) > GLONCLE Then
    If [M:OMP1]OBJFLG Then
      [M:OMP1]OBJICO = SZICOSYNDON
    Else
      [M:OMP1]OBJICO = SZICOSYN
    Endif
    Actzo [M:OMP1]OBJICO
  Else
    [M:OMP1]OBJICO = "-1"
    Grizo [M:OMP1]OBJICO
  Endif
Return

##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
Local Char SZCTLCLOB(250)

  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif
  #Objet de l'action
  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:OMP1]FULOBJ
  If SZCTLCLOB <> "" Then
    Raz [F:HD5]
    [F:HD5]NUM = [M:OMP1]NUMFULOBJ
    [F:HD5]TYP = [M:OMP1]TYPFULOBJ
    [F:HD5]CLOB = [M:OMP1]FULOBJ
    Write [HD5]
    If fstat Then
      #Erreur lors de l'enregistrement de la description de l'opération marketing. Transaction abandonnée.
      GMESSAGE = mess(880,182,1)
      GERR = 1
      Call FSTA("HD5") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD5] Where [F:HD5]NUM = [M:OMP1]NUMFULOBJ and [F:HD5]TYP = [M:OMP1]TYPFULOBJ
  If fstat Then
    #Erreur lors de la suppression de la description de l'opération marketing. Transaction abandonnée.
    GMESSAGE = mess(881,182,1)
    GERR = 1
    Call FSTA("HD5") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB2
  Delete [HD5] Where [F:HD5]NUM = GSZOPGNUM and [F:HD5]TYP = "OMP"
  If fstat Then
    #Erreur lors de la suppression de la description de l'opération marketing. Transaction abandonnée.
    GMESSAGE = mess(881,182,1)
    GERR = 1
    Call FSTA("HD5") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB compte-rendu
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:OMP1]NUMFULOBJ = "" Then
    Raz [M:OMP1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If [M:OMP1]TYPFULOBJ = "" Then
    Raz [M:OMP1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD5]HD50=[M:OMP1]NUMFULOBJ;[M:OMP1]TYPFULOBJ
    If fstat Then
      Raz [M:OMP1]FULOBJ
    Else
      [M:OMP1]FULOBJ = [F:HD5]CLOB
    Endif
  Endif
Return

##########################################################################################################
# Chargement des téléacteurs participants
######################################################
Subprog LOADTSALES(SZOPGNUM)
Value Char SZOPGNUM  # FGR 01/02/2010 : X3SUIVI60986

  [M:OMP2]NBREP = 0
  Raz [M:OMP2]OMPREP
  Raz [M:OMP2]OMPREPCLL
  If SZOPGNUM = "" Then
    End
  Endif
  Filter [DVA] Where [F:DVA]OBC = "OMP" and [F:DVA]ALHX(0) = SZOPGNUM
  For [DVA]
    [M:OMP2]OMPREP([M:OMP2]NBREP) = [F:DVA]ALHX(1)
    [M:OMP2]OMPREPCLL([M:OMP2]NBREP) = [F:DVA]INTX(0)
    [M:OMP2]NBREP += 1
  Next
  Filter [DVA]
End

##########################################################################################################
# Contrôle de la modification d'une opération.
######################################################
$CHECKDATA
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  #Synthèse Objet de l'action
  #  If [M:OMP1]FULOBJ = "" Then
  #    [M:OMP1]OBJ = ""
  #  Else
  #    [M:OMP1]OBJ = left$([M:OMP1]FULOBJ,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
  #Contrôle de la présence de dates
  If [M:OMP1]OMPSTR = [00/00/00] Then
    GMESSAGE = mess(107,177,1) #Une date de début et de fin de l'opération doivent être précisées.
    GERR = 2
    OK = 0
    Return
  Endif
  #Contrôle de la présence de dates
  If [M:OMP1]OMPEND = [00/00/00] Then
    GMESSAGE = mess(107,177,1) #Une date de début et de fin de l'opération doivent être précisées.
    GERR = 2
    OK = 0
    Return
  Endif
  #Contrôle de la cohérence des dates
  If [M:OMP1]OMPSTR > [M:OMP1]OMPEND Then
    GMESSAGE = mess(106,177,1) #La date de fin d'opération ne peut pas être inférieure à la date de début.
    GERR = 2
    OK = 0
    Return
  Endif
  Call CMGCTRLDATEDEB([M:OMP1]OMPSTR,[M:OMP0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 2
    OK = 0
    Return
  Endif
  Call CMGCTRLDATEFIN([M:OMP1]OMPEND,[M:OMP0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #La description doit être renseignée.
  If [M:OMP1]DES = "" Then
    GMESSAGE = mess(342,196,1) #Aucune description n'a été saisie. Cette information est obligatoire.
    GERR = 2
    OK = 0
    Return
  Endif
  #Devise obligatoire
  If [M:OMP1]CUR = "" Then
    GMESSAGE = mess(385,196,1) #Aucun code devise n'est renseigné. Modification refusée.
    GERR = 2
    OK = 0
    Return
  Endif
  Read [TCU]TCU0=[M:OMP1]CUR
  If fstat Then
    GMESSAGE = mess(84,116,1) #Devise incorrecte.
    GERR = 2
    OK = 0
    Return
  Else
    If [F:TCU]EURFLG = 2 Then
      If [F:TCU]CURENDDAT <> [00/00/00] Then
        If [F:TCU]CURENDDAT < date$ Then
          GMESSAGE = mess(84,116,1) #Devise incorrecte.
          GERR = 1
          OK = 0
          Return
        Endif
      Endif
    Endif
  Endif
Return
