#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du masque CTRTDS
Call CONTROLE
End

#Téléchargement du logiciel de pré-contrôle
$ACTION
Case ACTION
 When "INIT" : TIT = mess(12,10707,1)
 When "EXEC" : Call CONTROLE
Endcase
Return

######################################
Subprog CONTROLE
Local Char VALURL (250)

VALURL=func TRTCTR.PARAM("URLCTR","")
If VALURL<>""
 Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
& "UILocalDir="+ chr$(1) +"HTTP",
& "UILocalFile="+ chr$(1) + VALURL
Else
 #URL invalide
 Call ERREUR (mess(13,10707,1)) From GESECRAN
 End
Endif
End

#Redéfinition obligatoire car le Funprog superviseur correspondant déclare Valeur sur 30 caractères !
#Insuffisant pour une URL
######################################
Funprog PARAM(PARAM,SITE)
Value Char PARAM
Value Char SITE
Local Char VALEUR(250)
Call PARAM(SITE,PARAM,VALEUR) From ADOVAL
End VALEUR

