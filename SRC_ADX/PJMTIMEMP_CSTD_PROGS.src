# Classe PJMTIMEMP
###################################################################################################
# Issue X3-69372 - 2018-04-18 by SINGC : START
Funprog GET_KEYCONCAT_VARIABLES(SCLB, IPTESEQ)
Value Char SCLB
Value Integer IPTESEQ

Local Char SARENDRE(250)

  # Specially used for translated texts key
  SARENDRE = SCLB + "~" + num$(IPTESEQ)
End SARENDRE

