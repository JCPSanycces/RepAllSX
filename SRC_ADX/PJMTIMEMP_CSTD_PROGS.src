###################################################################################################
Funprog IS_PJMTEMEMP_FOR_BUD(SOPPNUM, SPBUCOD)
Value Char SOPPNUM
Value Char SPBUCOD

Local Integer IRET

  Local File PJMTIMEMP [PTED]
  Filter [PTED] Where OPPNUM = SOPPNUM and PBUCOD = SPBUCOD
  Read [PTED] First
  If fstat = 0 Then
    IRET = [V]CST_AYES
  Else
    IRET = [V]CST_ANO
  Endif
  Filter [PTED]
End IRET

###################################################################################################
Funprog IS_PJMTEMEMP_FOR_TAS(SOPPNUM, STASCOD)
Value Char SOPPNUM
Value Char STASCOD

Local Integer IRET

  Local File PJMTIMEMP [PTED]
  Filter [PTED] Where OPPNUM = SOPPNUM and TASCOD = STASCOD
  Read [PTED] First
  If fstat = 0 Then
    IRET = [V]CST_AYES
  Else
    IRET = [V]CST_ANO
  Endif
  Filter [PTED]
End IRET

###################################################################################################
Funprog PTEDESTEX_EXIST(ACTX, SIDENT2)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-14 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMTIMEMP", "PTEDESTEX", SIDENT2, AVOID.ACHAR, AVOID.ACHAR)
End IARENDRE

###################################################################################################
Funprog PTECOMTEX_EXIST(ACTX, SIDENT2)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-14 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMTIMEMP", "PTECOMTEX", SIDENT2, AVOID.ACHAR, AVOID.ACHAR)
End IARENDRE

###################################################################################################
Funprog GET_PTEDESAXX(CTX, SCLB, IPTESEQ)
Variable Instance CTX Using OBJECT
Value Char SCLB
Value Integer IPTESEQ

Local Char SARENDRE(GLONDCO)

  # Issue X3-66488 - 2018-05-17 by SINGC
  Raz SARENDRE
  Call LECTEXTRA_SYR(CTX, AVOID.ACHAR, SARENDRE, "PJMTIMEMP", "PTEDESAXX", func GET_KEYCONCAT_VARIABLES(SCLB, IPTESEQ), AVOID.ACHAR) From ATEXTRA
End SARENDRE

