#<AdxTL>@(#)10.0.0.0 $Revision$
#Call PYRAMPRT("","AA",nomap)
Call PYRAMPRT("BAL6N","SOC",nomap)
End

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","LIENPYRACC","",2,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT" : Gosub INIT
 When "EXEC" : Gosub EXEC
Endcase
Return

$INIT
TMP = 1
TRA = 1
TIT = mess(151,116,1) : # Resynchronisation des pyramides comptes
Return

$EXEC
Call OUVRE_TRACE(mess(151,116,1)) From LECFIC
Call MAJ_PYRAM(nomap)
Call FERME_TRACE From LECFIC
Return

#################################################################
## Mise à jour des liens pyramides
#################################################################
## Subprog MAJ_PYRAM(APPLI)           Les 2 tables pour l'appli
## Subprog MAJ_PLAN(PLAN,APPLI)       Les 2 tables pour un plan
## Subprog PYRAMPRT(PYR,PLAN,APPLI)   Maj GACCPYMPRT
## Subprog PYRAMLIK(PYR,PLAN,APPLI)   Maj GACCPYMLIK
#################################################################
## Subprog CRECPT(PLAN,COMPTE)        Création d'un compte
## Subprog DELCPT(PLAN,COMPTE)        Suppression d'un compte
#################################################################

#################################################################
## Mise à jour totale
#################################################################
Subprog MAJ_PYRAM(APPLI)
Value Char APPLI

Local Char PLAN(GLONCOA)

If clalev([F:COA])=0  : Local File =APPLI+".GCOA"       [COA]  : Endif
If clalev([F:GYP])=0  : Local File =APPLI+".GACCPYMPRT" [GYP]  : Endif
If clalev([F:GYK])=0  : Local File =APPLI+".GACCPYMLIK" [GYK]  : Endif
If clalev([F:GRY])=0  : Local File =APPLI+".GACCGRUPYM" [GRY]  : Endif
If clalev([F:GRY2])=0 : Local File =APPLI+".GACCGRUPYM" [GRY2] : Endif
If clalev([F:GYM])=0  : Local File =APPLI+".GACCPYM"    [GYM]  : Endif
If clalev([F:GAC])=0  : Local File =APPLI+".GACCOUNT"   [GAC]  : Endif

For [COA]COA0
 PLAN = [F:COA]COA
 Call MAJ_PLAN(PLAN,APPLI)
Next
End

#################################################################
## Mise à jour d'un plan de compte
#################################################################
Subprog MAJ_PLAN(PLAN,APPLI)
Value Char PLAN
Value Char APPLI

Local Char PYR(GLONGYM) , PYRDES(GLONDES)

If clalev([F:GYP])=0  : Local File =APPLI+".GACCPYMPRT" [GYP]  : Endif
If clalev([F:GYK])=0  : Local File =APPLI+".GACCPYMLIK" [GYK]  : Endif
If clalev([F:GRY])=0  : Local File =APPLI+".GACCGRUPYM" [GRY]  : Endif
If clalev([F:GRY2])=0 : Local File =APPLI+".GACCGRUPYM" [GRY2] : Endif
If clalev([F:GYM])=0  : Local File =APPLI+".GACCPYM"    [GYM]  : Endif
If clalev([F:GAC])=0  : Local File =APPLI+".GACCOUNT"   [GAC]  : Endif

For [GYM]GYM1 Where COA=PLAN
 PYR = [F:GYM]PYM
 If GTRACE<>""
  Call LECTEXTRA(PYRDES,"GACCPYM","DESTRA",PYR,"") From ATEXTRA
  Call ECR_TRACE(mess(50,103,1)-PYR-PYRDES-"("+PLAN+")",0) From GESECRAN
 Endif
 Call PYRAMPRT(PYR,PLAN,APPLI)
 Call PYRAMLIK(PYR,PLAN,APPLI)
Next
Call PYRAMPRT("",PLAN,APPLI)
End

#################################################################
## Mise à jour d'une pyramide (GACCPYMPRT)
#################################################################
Subprog PYRAMPRT(PYR,PLAN,APPLI)
Value Char PYR
Value Char PLAN
Value Char APPLI

If clalev([F:GYP])=0  : Local File =APPLI+".GACCPYMPRT" [GYP]  : Endif
If clalev([F:GRY])=0  : Local File =APPLI+".GACCGRUPYM" [GRY]  : Endif
If clalev([F:GRY2])=0 : Local File =APPLI+".GACCGRUPYM" [GRY2] : Endif
If clalev([F:GAC])=0  : Local File =APPLI+".GACCOUNT"   [GAC]  : Endif
If clalev([F:AXX])=0  : Local File =APPLI+".ATEXTRA"    [AXX]  : Endif

Gosub DEFVAR
NIVMAX = dim([F:GYP]GRU)

Call DEBTRANS From GLOCK
Gosub TR1
End

$DEFVAR
Local Integer MAXGRP : MAXGRP = 10000
Local Integer MAXCPT : MAXCPT = 10000
Local Integer NIVMAX : NIVMAX = 0

Local Integer NBGRP , IGRP , JGRP , KGRP , ICPT , NBCPT
Local Integer NBNIV , NIV , OKCPT
Local Char    GROUPE(GLONGRY)(1..MAXGRP) , GRPERE(GLONGRY)(1..MAXGRP)
Local Integer GRPNIV(1..MAXGRP) , GRPROW(1..MAXGRP) , GRPLEV(1..MAXGRP)
Local Char    CPT(GLONGAC)(1..MAXCPT)
Local Integer DEBCPT(1..MAXGRP) , FINCPT(1..MAXGRP)
Return

$TR1
GOK = 1
Trbegin [GYP]
 Delete [GYP] Where COA=PLAN & PYM=PYR
 If fstat=1
  GOK = -1 : GLOCK = "$GACCPYMPRT"-PLAN-PYR : Goto ROLL_TR1
 Endif
 If PYR<>""
  Gosub LECPYR
 Endif
 Gosub ECRPRT
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 # Pour crystal reports
 Call MAJTEXTRA("","GACCGRUPYM","DESTRA","","zzzzz") From ATEXTRA
 Call MAJTEXTRA("","GACCGRUPYM","DESTRA",PYR,"zzzzz") From ATEXTRA
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#################################################################
## Mise à jour d'une pyramide (GACCPYMLIK)
#################################################################
Subprog PYRAMLIK(PYR,PLAN,APPLI)
Value Char PYR
Value Char PLAN
Value Char APPLI

If clalev([F:GYK])=0  : Local File =APPLI+".GACCPYMLIK" [GYK]  : Endif
If clalev([F:GRY])=0  : Local File =APPLI+".GACCGRUPYM" [GRY]  : Endif
If clalev([F:GRY2])=0 : Local File =APPLI+".GACCGRUPYM" [GRY2] : Endif
If clalev([F:GAC])=0  : Local File =APPLI+".GACCOUNT"   [GAC]  : Endif

Gosub DEFVAR

Call DEBTRANS From GLOCK
Gosub TR2
End

$TR2
GOK = 1
Trbegin [GYK]
 Delete [GYK] Where PYM=PYR
 If fstat=1
  GOK = -1 : GLOCK = "$GACCPYMLIK"-PYR : Goto ROLL_TR2
 Endif
 Gosub LECPYR
 Gosub ECRLIK
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

####################################################################
## Chargement de la pyramide
####################################################################
$LECPYR
Filter [GRY] Where PYM=PYR Order By Key CLE=LEV;GRU;LIN
NBNIV = 0
Raz NBGRP,NBCPT
Raz DEBCPT,FINCPT
For [GRY]CLE(1)
 NBNIV += 1
 For [GRY]CLE(2)
  NBGRP += 1
  GROUPE(NBGRP) = [F:GRY]GRU
  GRPNIV(NBGRP) = NBNIV
  GRPLEV(NBGRP) = [F:GRY]LEV
  GRPROW(NBGRP) = [F:GRY]PRNROW
  GRPERE(NBGRP) = ""
  If NBNIV>1
   Read [GRY2]GRY2 = PYR;[F:GRY]GRU
   If !fstat
    GRPERE(NBGRP) = [F:GRY2]GRU
   Endif
  Endif 
  For [GRY]CLE
   If [F:GRY]ACC<>""
    If DEBCPT(NBGRP)=0
     DEBCPT(NBGRP) = NBCPT+1
    Endif
    NBCPT += 1
    CPT(NBCPT)    = [F:GRY]ACC
    FINCPT(NBGRP) = NBCPT
   Endif
  Next
 Next
Next
Filter [GRY]
Return

####################################################################
## Ecriture de la pyramide (GYP)
####################################################################
$ECRPRT
For [GAC]GAC0 Where COA=PLAN
 If PYR<>""
  OKCPT = 0
  For IGRP=1 To NBGRP
   JGRP = IGRP
   While JGRP<>0 & GRPNIV(JGRP)>NIVMAX & GRPERE(JGRP)<>""
    JGRP = find(GRPERE(JGRP),GROUPE(1..NBGRP))
   Wend
   If JGRP & DEBCPT(JGRP)>0
    For ICPT=DEBCPT(JGRP) To FINCPT(JGRP)
     If pat([F:GAC]ACC,CPT(ICPT))
      Raz [F:GYP]
      [F:GYP]COA = PLAN
      [F:GYP]PYM = PYR
      [F:GYP]ACC = [F:GAC]ACC
      NIV        = GRPNIV(JGRP)
      [F:GYP]LEV = NIV
      [F:GYP]LIE = 1
      [F:GYP]GRU(NIV-1) = GROUPE(JGRP)
      [F:GYP]ROW(NIV-1) = GRPROW(JGRP)
      For KGRP=NIV+1 To NIVMAX
       [F:GYP]GRU(KGRP-1) = "zzzzz"
       [F:GYP]ROW(KGRP-1) = 9999
      Next KGRP

      While JGRP<>0 & NIV>1
       JGRP = find(GRPERE(JGRP),GROUPE(1..NBGRP))
       If JGRP
        For KGRP=NIV-1 To GRPNIV(JGRP)+1 Step -1
         [F:GYP]GRU(KGRP-1) = "zzzzz"
         [F:GYP]ROW(KGRP-1) = 9999
        Next KGRP
        [F:GYP]GRU(GRPNIV(JGRP)-1) = GROUPE(JGRP)
        [F:GYP]ROW(GRPNIV(JGRP)-1) = GRPROW(JGRP)
        NIV = GRPNIV(JGRP)
       Endif
      Wend

      NIV -= 1
      While NIV>=1
       [F:GYP]GRU(NIV-1) = "zzzzz"
       [F:GYP]ROW(NIV-1) = 9999
       NIV -= 1
      Wend       

      Write [GYP]
      If fstat
       GOK = 0 : Call FSTA("GYP") From GLOCK : Break 3
      Endif

      OKCPT = 1 : Break 2
     Endif
    Next ICPT
   Endif
  Next IGRP
  If !OKCPT
#  Le compte n'y est pas... et alors!
  Endif
 Else
  Raz [F:GYP]
  [F:GYP]COA = PLAN
  [F:GYP]PYM = ""
  [F:GYP]ACC = [F:GAC]ACC
  [F:GYP]LEV = 1
  [F:GYP]LIE = 1
  For KGRP=1 To NIVMAX
   [F:GYP]GRU(KGRP-1) = "zzzzz"
  Next KGRP
  Write [GYP]
  If fstat
   GOK = 0 : Call FSTA("GYP") From GLOCK : Break
  Endif
 Endif
Next
Return

####################################################################
## Ecriture de la pyramide (GYK)
####################################################################
$ECRLIK
For [GAC]GAC0 Where COA=PLAN
 OKCPT = 0
 For NIV=NBNIV To 1 Step -1
  For IGRP=1 To NBGRP
   If GRPNIV(IGRP)=NIV & DEBCPT(IGRP)>0
    For ICPT=DEBCPT(IGRP) To FINCPT(IGRP)
     If pat([F:GAC]ACC,CPT(ICPT))
      Raz [F:GYK]
      [F:GYK]PYM    = PYR
      [F:GYK]LEV    = GRPLEV(IGRP)
      [F:GYK]COA    = PLAN
      [F:GYK]ACC    = [F:GAC]ACC
      [F:GYK]GRU    = GROUPE(IGRP)
      [F:GYK]PRNROW = GRPROW(IGRP)
      Write [GYK]
      If fstat
       GOK = 0 : Call FSTA("GYK") From GLOCK : Break 4
      Endif
      JGRP = IGRP
      While JGRP>0 & GRPERE(JGRP)<>""
       JGRP = find(GRPERE(JGRP),GROUPE(1..NBGRP))
       If JGRP
        Raz [F:GYK]
        [F:GYK]PYM    = PYR
        [F:GYK]LEV    = GRPLEV(JGRP)
        [F:GYK]COA    = PLAN
        [F:GYK]ACC    = [F:GAC]ACC
        [F:GYK]GRU    = GROUPE(JGRP)
        [F:GYK]PRNROW = GRPROW(JGRP)
        Write [GYK]
        If fstat
         GOK = 0 : Call FSTA("GYK") From GLOCK : Break 4
        Endif
       Endif
      Wend
      OKCPT = 1 : Break 3
     Endif
    Next ICPT
   Endif
  Next IGRP
 Next NIV
 If !OKCPT
#  Le compte n'y est pas... et alors!
 Endif
Next
Return

########################################################################
## Création d'un compte
########################################################################
Subprog CRECPT(PLAN,COMPTE)
Value Char PLAN
Value Char COMPTE
If clalev([F:GYM])=0 : Local File GACCPYM    [GYM] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:GYP])=0 : Local File GACCPYMPRT [GYP] : Endif
If clalev([F:GYK])=0 : Local File GACCPYMLIK [GYK] : Endif
Local Integer NIV , NBNIV , OKCPT
#Dmd 70000
Local Char    GROUPE(GLONGRY)(1..1000)
Local Integer GRPROW(1..1000) , NIVEAU(1..1000)

#
# Lien pyramide vide
#
[F:GYP]COA = PLAN
[F:GYP]PYM = ""
[F:GYP]ACC = COMPTE
[F:GYP]LEV = 1
[F:GYP]LIE = 1
For NIV=1 To dim([F:GYP]GRU)
 [F:GYP]GRU(NIV-1) = "zzzzz"
Next NIV
Write [GYP]
If fstat
 GOK = 0 : Call FSTA("GYP") From GLOCK : End
Endif
# Pour crystal reports
Call MAJTEXTRA("","GACCGRUPYM","DESTRA","","zzzzz") From ATEXTRA
#
# Parcours des pyramides
#
For [GYM]GYM1 Where COA=PLAN
 NIV   = 0
 OKCPT = 0
 For [GRY]GRY1(2) Where PYM=[F:GYM]PYM
  NIV += 1
  NIVEAU(NIV) = [F:GRY]LEV
  For [GRY]GRY1
   If pat(COMPTE,[F:GRY]ACC)<>0
    GROUPE(NIV) = [F:GRY]GRU
    GRPROW(NIV) = [F:GRY]PRNROW
    OKCPT = 1 : Break 2
   Endif
  Next
 Next
 If OKCPT
  NBNIV = NIV
  While NIV>1
   Read [GRY]GRY2(2) = [F:GYM]PYM;GROUPE(NIV)
   If !fstat
    Repeat
     NIV -= 1
    Until NIV<1 or [F:GRY]LEV=NIVEAU(NIV)
    If NIV
     GROUPE(NIV) = [F:GRY]GRU
     GRPROW(NIV) = [F:GRY]PRNROW
    Endif
   Else
    NIV = 0
   Endif
  Wend
  [F:GYP]COA = PLAN
  [F:GYP]PYM = [F:GYM]PYM
  [F:GYP]ACC = COMPTE
  [F:GYP]LEV = NBNIV
  [F:GYP]LIE = 1
  For NIV=1 To dim([F:GYP]GRU)
   If GROUPE(NIV)<>""
    [F:GYP]GRU(NIV-1) = GROUPE(NIV)
    [F:GYP]ROW(NIV-1) = GRPROW(NIV)
   Else
    [F:GYP]GRU(NIV-1) = "zzzzz"
    [F:GYP]ROW(NIV-1) = 9999
   Endif
  Next NIV
  Write [GYP]
  If fstat
   GOK = 0 : Call FSTA("GYP") From GLOCK : Break
  Endif
  For NIV=1 To NBNIV
   If GROUPE(NIV)<>""
    [F:GYK]PYM    = [F:GYM]PYM
    [F:GYK]LEV    = NIVEAU(NIV)
    [F:GYK]COA    = PLAN
    [F:GYK]ACC    = COMPTE
    [F:GYK]GRU    = GROUPE(NIV)
    [F:GYK]PRNROW = GRPROW(NIV)
    Write [GYK]
    If fstat
     GOK = 0 : Call FSTA("GYK") From GLOCK : Break 2
    Endif
   Endif
  Next NIV
 Endif
 # Pour crystal reports
 Call MAJTEXTRA("","GACCGRUPYM","DESTRA",[F:GYM]PYM,"zzzzz") From ATEXTRA
Next
End

########################################################################
## Suppression d'un compte
########################################################################
Subprog DELCPT(PLAN,COMPTE)
Value Char PLAN
Value Char COMPTE
If clalev([F:GYM])=0 : Local File GACCPYM    [GYM] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:GYP])=0 : Local File GACCPYMPRT [GYP] : Endif
If clalev([F:GYK])=0 : Local File GACCPYMLIK [GYK] : Endif
Delete [GYP] Where COA=PLAN & ACC=COMPTE
If fstat=1
 GOK = -1 : GLOCK = "$GACCPYMPRT"-COMPTE : End
Endif
For [GYM]GYM1 Where COA=PLAN
 Delete [GYK] Where PYM=[F:GYM]PYM & ACC=COMPTE
 If fstat=1
  GOK = -1 : GLOCK = "$GACCPYMLIK"-COMPTE : Break
 Endif
 Delete [GRY] Where PYM=[F:GYM]PYM & ACC=COMPTE
 If fstat=1
  GOK = -1 : GLOCK = "$GACCGRUPYM"-COMPTE : Break
 Endif
Next
End




