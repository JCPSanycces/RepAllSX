[M:ORDK]FMI        = 1
[M:ORDK]MRPMES     = 1
[M:ORDK]BOMALT     = [M:OPSS]BOMALT
[M:ORDK]BOMALTTYP  = 2                    # V6 Nomenclature de Production
Case [M:OPSS]OPSTYP
    When 1: [M:ORDK]ORI        = 6
