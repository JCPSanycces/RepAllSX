##################################################################
# Routine de mise à jour des données de jalonnement
##################################################################
Subprog GEN_JAL(LGAMME, LALT, LROUECCMAJ, LROUECCMIN)
Value     Char     LGAMME
Value     Integer  LALT
Value     Char     LROUECCMAJ    : # Issue 111414 - 2016-02-11 by CCC : route version number
Value     Char     LROUECCMIN    : # Issue 111414 - 2016-02-11 by CCC : route version number
#
Read [ROS]ROS0=[M:OPSK]MFGFCY;LGAMME;LALT;[M:OPSK]OPENUM
If fstat : [M:OPSS]CODRET = 1 : End : Endif

Raz [SCH]
[F:SCH]MFGNUM       = [M:OPSK]MFGNUM
[F:SCH]PLNFCY       = [M:OPSK]PLNFCY
[F:SCH]MFGFCY       = [M:OPSK]MFGFCY
[F:SCH]OPENUM       = [M:OPSK]OPENUM
[F:SCH]ROUNUM       = LGAMME
[F:SCH]ROUALT       = LALT
# Issue 111414 - 2016-02-11 by CCC : add route version number
[F:SCH]ROUECCMAJ    = LROUECCMAJ
[F:SCH]ROUECCMIN    = LROUECCMIN
[F:SCH]NEXOPENUM    = [F:ROS]NEXOPENUM
[F:SCH]SCDCOD       = [F:ROS]SCDCOD
[F:SCH]SCDTIM       = [F:ROS]SCDTIM
[F:SCH]SCDQTY       = [F:ROS]SCDQTY
[F:SCH]SCDLOT       = [F:ROS]SCDLOT
[F:SCH]DACMST       = [F:ROS]DACMST
[F:SCH]MFGMST       = [F:ROS]MFGMST
[F:SCH]INFCAPSTR    = [M:OPSK]OPESTR
[F:SCH]INFCAPEND    = [M:OPSK]OPEEND
#
[F:SCH]CREDAT=date$
[F:SCH]CREUSR=GUSER
If dim([F:SCH]CRETIM) > 0 : [F:SCH]CRETIM = time : Endif            # 01.05 27567
[F:SCH]EXPNUM=[C]EXPORT

Write [SCH]
If fstat : [M:OPSS]CODRET = 1 : Endif
#
End

##################################################################
# Routine de purge de la charge suggérée
##################################################################
Subprog PUR_LOA_SUG(LMFGFCY, LMFGNUM)
Value Char     LMFGFCY
Value Char     LMFGNUM
Local Integer  WJAL : WJAL = 0    # Ctrl des sources avant Value
#
If clalev([F:OPS]) = 0 : Local File OPERATIONS [OPS] : Endif  # encours opérations
If clalev([F:SCH]) = 0 : Local File SCHEDULING [SCH] : Endif  # encours jalonnements
If clalev([M:JALK]) = 0 : Local Mask JALK [JALK] : Endif
# test état jalonnement
For [SCH]SCH0 Where MFGNUM=LMFGNUM
    If [F:SCH]OPESTRDAT <> [0/0/0] : WJAL = 1 : Break : Endif
Next
If WJAL <> 0
# déjalonnement
    Raz [M:JALK]
    [M:JALK]CODORI = 2
    [M:JALK]CODMAJ = 0
    [M:JALK]CODTRS = 0
    [M:JALK]MFGFCY = LMFGFCY
    [M:JALK]MFGNUM = LMFGNUM
    [M:JALK]MFGSTA = 3
    Call DEJALONNE From JALLIBA
Endif

# purge des données de jalonnement
For [SCH]SCH0 Where MFGNUM=LMFGNUM
  Readlock [SCH] Curr
    If fstat : GOK = 0 : Call FSTA("SCH") From GLOCK : Break : Endif
  Delete [SCH]
    If fstat : GOK = 0 : Call FSTA("SCH") From GLOCK : Break : Endif
Next
# purge des données encours opérations
If GOK = 1
  For [OPS]OPS1 Where MFGNUM=LMFGNUM
    Readlock [OPS] Curr
      If fstat : GOK = 0 : Call FSTA("OPS") From GLOCK : Break : Endif
    Delete [OPS]
      If fstat : GOK = 0 : Call FSTA("OPS") From GLOCK : Break : Endif
  Next
Endif
#
End

####################################################################################
# Issue 105987 GA 02/2015                                                          #
# total du temps des opérations valides pour la gamme et la qté retenue            #
# Buffer déjà chargés: [F:ITM], [F:ITF], [F:ROH]                                   #
####################################################################################
Subprog CAL_ROH_LTI(LSTRDAT, LQTY, LLTI)
Value    Date     LSTRDAT
Value    Decimal  LQTY
Variable Decimal  LLTI

Local    Decimal  WLTI,WTIM,WTOTTIM
    Raz [M:JALK]
    [M:JALK]CODORI     = 2
    [M:JALK]CODMAJ     = 2
    [M:JALK]CODTRS     = 0
    [M:JALK]MFGFCY     = [F:ITF]STOFCY
    [M:JALK]ROUNUM     = [F:ROH]ITMREF
    [M:JALK]ROUALT     = [F:ROH]ROUALT
    If LQTY = 0
      [M:JALK]REOMINQTY  = [F:ITF]REOMINQTY
    Else
      [M:JALK]REOMINQTY  = LQTY
    Endif
    [M:JALK]TRTDAT     = LSTRDAT
    [M:JALK]STRDAT     = LSTRDAT
    [M:JALK]ENDDAT     = LSTRDAT
    [M:JALK]SCDMOD     = 2     # forward scheduling
    [M:JALK]JAVFLG     = 2
    If [F:PJA]MFGFCY <> [F:ITF]STOFCY
        Read [PJA]PJA0=[F:ITF]STOFCY
        If fstat : Raz [PJA] : Endif
    Endif
    Call JALONNE From JALLIB
    WLTI=([M:JALK]ENDDAT - [M:JALK]STRDAT)+1
    LLTI=WLTI

End


####################################################################################
# FQ 48636 GA 08/2008                                                              #
# total du temps des opérations valides pour la gamme et la qté retenue            #
# Buffer déjà chargés: [F:ITM], [F:ITF], [F:ROH]                                   #
####################################################################################
Subprog CAL_ROH_LTI_OLD(LSTRDAT, LQTY, LLTI)
Value    Date     LSTRDAT
Value    Decimal  LQTY
Variable Decimal  LLTI

If clalev([F:ROO]) = 0 : Local File ROUOPE     [ROO] : Endif  # opérations gamme
If clalev([F:WST]) = 0 : Local File WORKSTATIO [WST] : Endif  # poste de charge
Local    Decimal  WLTI,WTIM,WTOTTIM
Local    Integer  SVOPE

LLTI=0 : WLTI=0 : WTIM=0
WTOTTIM=0
# recherche des opérations valides pour la gamme courante
    SVOPE=0
    # FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT
    For [ROO]ROO0 Where FCY = [F:ROH]FCY & ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT
&                 & OPENUM <> SVOPE
&                 & (VALENDDAT=[0/0/0] | (VALENDDAT >= LSTRDAT & VALENDDAT<>[0/0/0]) )
&                 & (VALSTRDAT=[0/0/0] | (VALSTRDAT <= LSTRDAT & VALSTRDAT<>[0/0/0]) )
        If [F:ROO]OPENUM <> SVOPE
            SVOPE = [F:ROO]OPENUM
            Read [WST]WST0=[F:ROO]WST;[F:ITF]STOFCY
            If fstat Raz [F:WST] Endif
            If [F:WST]WSTTYP<>3  # Issue 105668 GA 01/2015 except when subcontract op
               Call CAL_OPE_TIME(LQTY, WTIM)
               # Issue 96370 GA 02/2015
               #Call CONV_TIME_LTI([F:ITF]STOFCY, WTIM,[F:ROH]TIMUOMCOD, WSTNBR, [F:WST]TWD, LSTRDAT, WLTI)
               WTOTTIM += WTIM
            Elsif [F:ROO]SCOITMREF<>""
               # Issue 105668 GA 01/2015
               Read [F:ITM]ITM0=[F:ROO]SCOITMREF : If fstat Raz [F:ITM] Endif
               WLTI=[F:ITM]OFS
               LLTI += WLTI
            Endif
          Endif
    Next
   # Issue 96370 GA 02/2015 time conversion after the loop
    If WTOTTIM>0
      Call CONV_TIME_LTI([F:ITF]STOFCY, WTOTTIM,[F:ROH]TIMUOMCOD, WSTNBR, [F:WST]TWD, LSTRDAT, WLTI)
      LLTI += WLTI
    Endif

#If GUSER="GA"
#    Call ECR_TRACE("CAL_ROH_LTI:"-[F:ROH]ITMREF-"["+num$([F:ROH]ROUALT)+"]"-"Twd="+[F:WST]TWD
#&                  -"Time="+num$(WTOTTIM)-mess([F:ROH]TIMUOMCOD,301,1)
#&                  -"Lti="+num$(WLTI),0 ) From GESECRAN
#Endif

End

####################################################################################
# FQ 48636 GA 08/2008                                        (selon MFGAUTLIB)     #
# calcul du temps d'opération à partir de la gamme et de la qté                    #
# Buffer déjà chargés: [F:ITM], [F:ITF], [F:ROH] , [F:ROO], [F:WST]                #
####################################################################################
Subprog CAL_OPE_TIME(LQTY, LTOTTIM)
Value    Decimal  LQTY
Variable Decimal  LTOTTIM

Local Decimal  WLTIRED
Local Decimal  WPRPTIM   , WPSPTIM   , WWAITIM
Local Decimal  WEXTSETTIM, WEXTOPETIM, WEXTUNTTIM

# initialisation temps fixes (appliqués 1 fois pour l'OF)
WPRPTIM     = [F:ROO]PRPTIM
WPSPTIM     = [F:ROO]PSPTIM
WEXTSETTIM  = [F:ROO]SETTIM
WWAITIM     = [F:ROO]WAITIM

# Issue 104765 GA 01/2015 idem MFGLIBO/CAL_OPE_TIME
Local    Decimal  WQTY : WQTY=LQTY
# calcul de la quantité de l'opération (quantité lancée / coeff US/UO)
# operation qty must be adjusted, may be different than product qty
If [F:ROO]OPESTUFOR <> ""
   Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
   If !fstat
       If evalue([F:TFO]FORFOR) <> 0
           WQTY = LQTY * evalue([F:TFO]FORFOR)
       Elsif [F:ROO]OPESTUCOE <> 0
           WQTY = LQTY *[F:ROO]OPESTUCOE
       Else
           WQTY = LQTY
       Endif
   Else
        WQTY = LQTY *[F:ROO]OPESTUCOE
   Endif
Elsif [F:ROO]OPESTUCOE<>0
  WQTY = LQTY * [F:ROO]OPESTUCOE
Endif

# application du taux de compression des temps morts
# si 1    <= % compression <= 100, on comprime les temps suivant le pourcentage
# si 101  <= % compression <= n  , on augmente les temps de (pourcentage - 100)
# exemple: compression = 40 %, temps passe de 1h à 0,6 h
#          compression = 120%, temps passe de 1h à 1,2 h
WLTIRED = GPERCOMP
If WLTIRED > 100
    WLTIRED -= 100
    WLTIRED *= -1
Endif

Case GTPSCOMP
    When 1:    # ben rien
    When 2:    # compression temps attente uniquement
               WWAITIM *= ((100 - WLTIRED) / 100)
    When 3:    # compression temps préparation + post-opératoire
               WPRPTIM *= ((100 - WLTIRED) / 100)
               WPSPTIM *= ((100 - WLTIRED) / 100)
    When 4:    # compression des 3 temps
               WWAITIM *= ((100 - WLTIRED) / 100)
               WPRPTIM *= ((100 - WLTIRED) / 100)
               WPSPTIM *= ((100 - WLTIRED) / 100)
    When 5:    # compresssion temps de préparation
               WPRPTIM *= ((100 - WLTIRED) / 100)
    When 6:    # compresssion temps post-opératoire
               WPSPTIM *= ((100 - WLTIRED) / 100)
    When 7:    # compression temps préparation + attente
               WPRPTIM *= ((100 - WLTIRED) / 100)
               WWAITIM *= ((100 - WLTIRED) / 100)
    When 8:    # compression temps post-opératoire + attente
               WPSPTIM *= ((100 - WLTIRED) / 100)
               WWAITIM *= ((100 - WLTIRED) / 100)
Endcase

# calcul temps variable (dépendant de la quantité)

# Issue 87635 GA 03/2013 New Entry point
Gosub PE_ROOTIMCOD From JALLIB
Case [F:ROO]ROOTIMCOD    # suivant type tps opératoire
    When 1: # proportionnel     (temps = quantité / quantité base * temps)
            If [F:ROO]BASQTY = 0 : [F:ROO]BASQTY = 1 : Endif
            WEXTOPETIM = WQTY *
&                              [F:ROO]OPETIM /
&                              [F:ROO]BASQTY

    When 2: # cadence          (temps = quantité / cadence)
            If [F:ROO]CAD > 0
                WEXTOPETIM  = WQTY /
&                                   [F:ROO]CAD
            Endif
    When 3: # forfaitaire
            WEXTOPETIM  = [F:ROO]OPETIM
Endcase

# application de l'efficience du poste de charge et de l'opération
# (l'efficience ne concerne que les temps de réglage et opératoire)
# temps = temps / efficience poste/100 / efficience opération/100
If [F:ROO]EFF = 0 [F:ROO]EFF=100 Endif
Case GWSTEFFINH
    When 1:
                       If GOPEEFFAPP = 1
                           WEXTSETTIM  = WEXTSETTIM /
&                                          ([F:ROO]EFF / 100)
                       Else
                           WEXTSETTIM  = WEXTSETTIM
                       Endif
                       WEXTOPETIM  = WEXTOPETIM /
&                                          ([F:ROO]EFF / 100)
    When Default:
                       If GOPEEFFAPP = 1
                           WEXTSETTIM  = WEXTSETTIM /
&                                          ([F:ROO]EFF / 100)
                       Else
                           WEXTSETTIM  = WEXTSETTIM
                       Endif
                       WEXTOPETIM  = WEXTOPETIM /
&                                          ([F:ROO]EFF / 100)
Endcase

# calcul du temps unitaire = temps opératoire calculé / quantité
If WQTY > 0
   WEXTUNTTIM  = WEXTOPETIM / WQTY
Endif

# arrondis
WWAITIM =  func TRTX3.ARRTYP("", "", "TIH", WWAITIM)
WPRPTIM =  func TRTX3.ARRTYP("", "", "TIH", WPRPTIM)
WPSPTIM =  func TRTX3.ARRTYP("", "", "TIH", WPSPTIM)
WEXTSETTIM =  func TRTX3.ARRTYP("", "", "TIH", WEXTSETTIM)
WEXTOPETIM =  func TRTX3.ARRTYP("", "", "TIH", WEXTOPETIM)
WEXTUNTTIM =  func TRTX3.ARRTYP("", "", "TIH", WEXTUNTTIM)

# Temps global pour la qté
LTOTTIM = WWAITIM+WPRPTIM+WPSPTIM + WEXTSETTIM+WEXTOPETIM

End

####################################################################################
# FQ 48636 GA 08/2008                                                              #
# Conversion du temps global en LTIMUOMCOD en un délai                             #
####################################################################################

####################################################################################
# FQ 48636 GA 08/2008                                                              #
# Recherche d'une alternative de gamme valide, selon [F:ITF]                       #
####################################################################################
Subprog FIND_ROUTING(LOPSTYP,LBOMALT,LSTRDAT,LQTY)
Value Integer  LOPSTYP
Value Integer  LBOMALT
Value Date     LSTRDAT
Value Decimal  LQTY

If clalev([F:TRO]) = 0 : Local File TABROUALT  [TRO] : Endif  # alternative gamme
If clalev([F:ROH]) = 0 : Local File ROUTING    [ROH] : Endif  # entête gamme

Local Char     GAMME(GLONITM),WFCY(GLONFCY)
Local Integer  WALT,ALT
Local Integer  TABTBO(3)

Raz ALT,WALT
# recherche gamme de fabrication valide
Case LOPSTYP
    When 1 : If [F:ITF]MFGROU = ""
                     GAMME = [F:ITF]ITMREF
             Else    GAMME = [F:ITF]MFGROU : Endif
             ALT = [F:ITF]MFGROUALT
    When 2 : If [F:ITF]RCCROU = ""
                     GAMME = [F:ITF]ITMREF
             Else    GAMME = [F:ITF]RCCROU : Endif
             ALT = [F:ITF]RCCROUALT
Endcase

If ALT <> 0
   Read [F:ROH]ROH0 = GAMME;ALT;[F:ITF]STOFCY         : # Beryl Site en fin de clé primaire
   If !fstat
      Read [F:TRO]TRO0 = ALT
         If !fstat
            Case LOPSTYP
                When 1: Call CONTMFGGAM([F:ITF]STOFCY, WALT, LSTRDAT, LQTY,[F:ITM]STU, 0) From MFGLIB
                When 2: Call CONTRCCGAM([F:ITF]STOFCY, WALT, LSTRDAT, LQTY,[F:ITM]STU, 0) From MFGLIB
            Endcase
            If WALT <> 0
                # Contrôle de cohérence de l'alternative de nomenclature
                TABTBO(0)=[F:TRO]BOMALT1
                TABTBO(1)=[F:TRO]BOMALT2
                TABTBO(2)=[F:TRO]BOMALT3
                If !find(LBOMALT, TABTBO) WALT = 0 : Endif
            Endif
         Endif
   Endif
Endif
If WALT = 0
    # recherche D'une alternative valide
    # lecture ROUTING
    # llc 10.02 Performances
    For [ROH]ROH0 Where [F:ROH]FCY = [F:ITF]STOFCY & [F:ROH]ITMREF = GAMME
        Read [TRO]TRO0 = [F:ROH]ROUALT
        If !fstat
            Case LOPSTYP
                When 1: Call CONTMFGGAM([F:ITF]STOFCY, WALT, LSTRDAT, LQTY, [F:ITM]STU, 0) From MFGLIB
                When 2: Call CONTRCCGAM([F:ITF]STOFCY, WALT, LSTRDAT, LQTY, [F:ITM]STU, 0) From MFGLIB
            Endcase
            If WALT <> 0
                # Contrôle de cohérence de l'alternative de nomenclature
                TABTBO(0)=[F:TRO]BOMALT1
                TABTBO(1)=[F:TRO]BOMALT2
                TABTBO(2)=[F:TRO]BOMALT3
                If find(LBOMALT, TABTBO) : Break : Else : WALT = 0 : Endif
            Endif
        Endif
    Next
Endif
# 56745
If WALT = 0 : [F:ROH]ROUALT = 0 : Endif
End

#**----------------------------------------------------------------<br/>
#* FIND_ROUTING2 : Look for a routing code
#**<br/>----------------------------------------------------------------<br/>
#* @param LOPSTYP = Charge type
#* @param LITM    = product
#* @param LROU    = routing to use (optional)
#* @param LFCY    = site
#* @param LBOMALT = BOM code
#* @param LSTRDAT = Date requested
#* @param LQTY    = quantity to produce
#* @return routing code (>0 if found or =0 if not found)
#**<br/>----------------------------------------------------------------
#*!
Funprog FIND_ROUTING2(LOPSTYP,LITM,LROU,LFCY,LBOMALT,LSTRDAT,LQTY)
Value Integer  LOPSTYP
Value Char     LITM
Value Char     LROU
Value Char     LFCY
Value Integer  LBOMALT
Value Date     LSTRDAT
Value Decimal  LQTY

If clalev([F:TRO]) = 0 : Local File TABROUALT  [TRO] : Endif  # alternative gamme
If clalev([F:ROH]) = 0 : Local File ROUTING    [ROH] : Endif  # entête gamme

Local Char     WFCY(GLONFCY)
Local Integer  WALT,ALT
Local Integer  TABTBO(3)

If [F:ITM]ITMREF<>LITM
    Read [ITM]ITM0=LITM
    If fstat : End 0 : Endif
Endif
# Get the routing number in the product-site
If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
    Read [ITF]ITF0=LITM;LFCY
    If fstat : End 0 : Endif
Endif
If LROU=""
    Case LOPSTYP
        When 1 : If [F:ITF]MFGROU = ""
                         LROU = [F:ITF]ITMREF
                 Else    LROU = [F:ITF]MFGROU : Endif
                 ALT = [F:ITF]MFGROUALT
        When 2 : If [F:ITF]RCCROU = ""
                         LROU = [F:ITF]ITMREF
                 Else    LROU = [F:ITF]RCCROU : Endif
                 ALT = [F:ITF]RCCROUALT
    Endcase
Endif
#
WDAT=LSTRDAT
WMSG=0
WFCY=LFCY

# Issue 111414 - 2015-12-16 by CCC : initialize version

# If a version of route exists then it must be used
WALT = func RVMLIB.GETRVMALT(LROU,LFCY,WDAT)
If WALT
    Read [ROH]ROH0=LROU;WALT;LFCY
    If !fstat
        Gosub CTL_ROUALT
    Endif
    Call ECR_DEBUG(LROU-"Route with version alt="+num$(WALT)) From FUNCBN
Else
    # Read the routing corresponding to the default routing code
    If [F:ITF]MFGROUALT <> 0
        Read [F:ROH]ROH0=LROU;ALT;LFCY
        If !fstat
            Gosub CTL_ROUALT
        Endif
    Endif
    If !WALT
        # If the default routing code is not good we look for another one
        For [ROH] Where [F:ROH]ITMREF=LROU & [F:ROH]FCY = LFCY
            Gosub CTL_ROUALT
            If WALT : Break : Endif
        Next
    Endif
    Call ECR_DEBUG(LROU-"Route without version alt="+num$(WALT)) From FUNCBN
Endif
End WALT

########################################
# Check if the routing code is suitable to BOM code
$CTL_ROUALT
Read [TRO]TRO0=[F:ROH]ROUALT
If !fstat
    Case LOPSTYP
        When 1: Call CONTMFGGAM(WFCY, WALT, WDAT, LQTY,[F:ITM]STU, 0) From MFGLIB
        When 2: Call CONTRCCGAM(WFCY, WALT, WDAT, LQTY,[F:ITM]STU, 0) From MFGLIB
    Endcase
    If WALT <> 0
        Raz TABTBO
        # Contrôle de cohérence de l'alternative de nomenclature
        TABTBO(0)=[F:TRO]BOMALT1
        TABTBO(1)=[F:TRO]BOMALT2
        TABTBO(2)=[F:TRO]BOMALT3
        If !find(LBOMALT, TABTBO) WALT = 0 : Endif
    Endif
Endif
Return

#########################################################################################
# FQ 48636 GA 08/2008                                        pour le calcul du CBN/PDP  #
# conversion temps opératoire en délai (exprimé en jours calendaires)                   #
# buffer déjà chargé [F:FCY], [F:ITF]                                                   #
#########################################################################################
Subprog CONV_TIME_LTI(LFCY, LTIME, LTIMUOM, LWSTNBR, LTWD, LDAT, LLTI)
Value     Char    LFCY    # site de production
Value     Decimal LTIME   # temps
Value     Integer LTIMUOM # unité temps (heures, minutes)
Value     Integer LWSTNBR # nombre de postes
Value     Char    LTWD    # schéma hebdomadaire
Value     Date    LDAT    # date de référence
Variable  Decimal LLTI    # délai calculé en jours calendaires

Local     Date    WDAT
Local     Decimal WLTI
Local     Decimal WTIME
Local     Integer  I, J, K, IDISP

Local Integer OFFSETCAL    : OFFSETCAL = 400  : # offset pour chargement table capacités    06.09 55554

If LDAT = [0/0/0] : LLTI = 0 : End : Endif
If LTIME = 0      : LLTI = 0 : End : Endif
#
If clalev ([F:TUV]) = 0 : Local File TABUNAVAIL [TUV] : Endif
If clalev ([F:TWD]) = 0 : Local File TABWEEDIA  [TWD]: Endif
#
WDAT = LDAT
WLTI = 0


# si plusieurs postes on répartit la charge
If LWSTNBR > 1
   WTIME = LTIME / LWSTNBR
Else
   WTIME = LTIME
Endif

# convertit en H si nécessaire
If LTIMUOM = 2
   WTIME /= 60
Endif
WTIME = func TRTX3.ARRTYP("", "", "TIH", WTIME)

# lecture indisponibilités
If  [F:TUV]UVYCOD <> [F:FCY]UVYCOD : Read [F:TUV]UVY0=[F:FCY]UVYCOD     : Endif
If fstat <> 0 : Raz [F:TUV] : Endif

# lecture schéma de référence
If  [F:TWD]TWD <> LTWD : Read [F:TWD]TWD0=LTWD     : Endif
If fstat <> 0 : End : Endif

# FQ 65789 GA 08/2010 éviter boucle infinie ?
Onerrgo ERROR_DAT
#While (WTIME > 0 )
While (WTIME > 0 & WDAT >= LDAT-OFFSETCAL )

    J = dayn(WDAT) - 1

    # si capacité non nulle pour le jour
    If [F:TWD]DAYCAP(J) <> 0
        IDISP = 1

        If [F:TUV]UVYNBR <> 0
            # indisponibilité ?
            For K = 0 To [F:TUV]UVYNBR - 1
                If WDAT >= [F:TUV]UVYSTRDAT(K) & WDAT <= [F:TUV]UVYENDDAT(K)
                    IDISP = 0
                    Break
                Endif
            Next
        Endif

        # jour OK, décrémentation du temps opératoire
        # 78898 DAYCAP et pas DAYCAPNOM sinon délai = nombre d'heure
        # délai incrémenté si utilisation > capacité (sinon délai surestimé)
        # Issue 83204  & 81906 GA 09/2012 remis code V5 sauf qu'on laisse DAYCAP auquel il vaut mieux ajouter (J)
        # If IDISP
        #     WTIME -= [F:TWD]DAYCAP
        #     If WTIME >=0 : WLTI += 1 : Endif
        # Endif
        If IDISP : WLTI += 1 : WTIME -= [F:TWD]DAYCAP(J) : Endif
    Endif
    # Cas du CBN/PDP: on cherche la date de début permettant de tenir compte du délai
    WDAT -= 1     : # on décrémente
Wend

LLTI = WLTI
#
Onerrgo
End
$ERROR_DAT  # FQ 65789 GA 07/2010
Onerrgo
# Erreur Article-Site YYY Schéma horaire ZZZ Temps opératoire YYY DD/MM/YYYY
Local Char WMESS(250)
WMESS=mess(207,111,1)-mess(4,198,1)-[F:ITF]ITMREF-[F:ITF]STOFCY-mess(362,182,1)-LTWD-mess(2,2375,1)-num$(LTIME)-num$(LDAT)
Call ECR_TRACE(WMESS,1) From GESECRAN
If errn
   WMESS="Erreur no"-errn-":"-errmes$(errn)-"Ligne"-errl
   Call ECR_TRACE(WMESS,1) From GESECRAN
Endif
End
Return

