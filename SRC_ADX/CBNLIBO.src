#<AdxTL>@(#)7.0.0.0 $Revision$
############################################################################################
# CBNLIBO                                                                                  #
# Librairie de sous-programme pour la gestion de la charge suggérée dans le CBN            #
# Paramètres passés par le masque OPSS                                                     #
# CODMAJ      : Code mise à jour pour le jalonnement                                       #
#               (0 = complète, 1 = partielle sans encours, 2 = Gamme , 3 = opération seule #
#               Avec le code = 1, les encours de type WOx et MWx ne sont pas mis à jour    #
#                            = 2, les résultats sont transmis via le masque JALK           #
#                                 le calcul est fait à partir de la gamme                  #
#                                 pas d'encours charge généré                              #
#                            = 3, génération opérations seules                             #
# OPSTYP      : Type charge (1 = CRP, 2 = RCCP)                                            #
# OPSSTA      : Statut (3 = suggéré)                                                       #
# PLNFCY      : Site de planification                                                      #
# MFGFCY      : Site de production                                                         #
# ITMREF      : Article lancé                                                              #
# BOMALT      : Alternative de nomenclature                                                #
# STRDAT      : Date début                                                                 #
# ENDDAT      : Date fin                                                                   #
# EXTQTY      : Quantité prévue                                                            #
# VCRNUM      : Numéro de pièce                                                            #
# PJT         : Affaire                                                                    #
# VCRTYPORI   : Type origine                                                               #
# VCRNUMORI   : Pièce origine                                                              #
# VCRLINORI   : Ligne origine                                                              #
############################################################################################
# Subprog GEN_LOA_SUG                                                                      #
# Subprog GEN_OPE_SUG(LGAMME, LALT)                                                        #
# Subprog CAL_TIME_SUG(WSTEFF)                                                             #
# Subprog GEN_OWX                                                                          #
# Subprog GEN_SCX                                                                          #
# Subprog GEN_JAL(LGAMME, LALT)                                                            #
# Subprog PUR_LOA_SUG(LMFGFCY, LMFGNUM)                                                    #
# Subprog CAL_ROH_LTI(LSTRDAT,LQTY,LLTI)                            - FQ 48636 GA 08/2008  #
# Subprog CAL_OPE_TIME(LQTY,LLTI)                                   - FQ 48636 GA 08/2008  #
# Subprog CONV_TIME_LTI(LFCY,LTIME,LTIMUOM,LWSTNBR,LTWD,LDAT, LLTI) - FQ 48636 GA 08/2008  #
# Subprog FIND_ROUTING(LOPSTYP,LBOMALT,LSTRDAT,LQTY)                - FQ 48636 GA 08/2008  #
############################################################################################
#Local Mask OPSS [OPSS]        # pour passage paramètre
#Local Mask OPSK [OPSK]        # pour générer encours opé
#Local Mask ORDK [ORDK]        # pour générer encours
#Local Mask JALK [JALK]        # pour jalonnement

#Global Char GSUG
#Global Char GWSP

#If clalev ([F:TCA])<=0 : Local File TABCOUAFF [TCA] : Endif
#Read [TCA] TCA0=8
#If fstat : Call ERREUR(mess(64,199,1)) From GESECRAN : OK=0 : Return : Endif

#GSUG    = [F:TCA]CODNUM(1)   # compteur suggestion fab.
#GWSP    = [F:TCA]CODNUM(5)   # compteur suggestion opérations

#[M:OPSS]CODMAJ = 2
#[M:OPSS]OPSTYP = 1
#[M:OPSS]OPSSTA = 3
#[M:OPSS]PLNFCY = "GAL"
#[M:OPSS]MFGFCY = "GAL"
#[M:OPSS]ITMREF = "ARTLLC"
#[M:OPSS]BOMALT = 3
#[M:OPSS]STRDAT = date$
#[M:OPSS]ENDDAT = date$
#[M:OPSS]EXTQTY = 31
#[M:OPSS]VCRNUM = "GALLLC"
#[M:OPSS]PJT    = "PROJECT"
#[M:OPSS]VCRTYPORI = 10
#[M:OPSS]VCRNUMORI = "GALLLCORI"
#[M:OPSS]VCRLINORI = 2000

#Call GEN_LOA_SUG
# Call PUR_LOA_SUG("GAL", "GALLLC")
End
############################################################################################
# Génération de la charge suggérée                                                         #
# il faut déclarer le compteur GWSP (chrono suggestion opération)                          #
# Le masque [M:OPSS] doit être déclaré et chargé                                           #
# [M:OPSS]CODRET = 0 si ok                                                                 #
#                = 1 si pb
# si les buffers article et article/site sont déjà chargés, à priori, il ne sont pas relus #
############################################################################################
Subprog GEN_LOA_SUG
#
# FQ 48636 Local Char     GAMME, WFCY
# FQ 48636 Local Integer  WALT,ALT
# FQ 48636 Local Integer  TABTBO(3)
Local Integer  VOPE
#
[M:OPSS]CODRET = 0
# ouverture tables si nécessaire
Local File ITMMASTER  [ITM]   # article
Local File ITMFACILIT [ITF]   # article/site
Local File ORDERS     [ORD]   # encours
If clalev([F:TRO]) = 0 : Local File TABROUALT  [TRO] : Endif  # alternative gamme
If clalev([F:ROH]) = 0 : Local File ROUTING    [ROH] : Endif  # entête gamme
If clalev([F:ROO]) = 0 : Local File ROUOPE     [ROO] : Endif  # opérations gamme
If clalev([F:ROS]) = 0 : Local File ROUSCD     [ROS] : Endif  # données std jalonnements
If clalev([F:OPS]) = 0 : Local File OPERATIONS [OPS] : Endif  # encours opérations
If clalev([F:SCH]) = 0 : Local File SCHEDULING [SCH] : Endif  # encours jalonnements
If clalev([F:MWS]) = 0 : Local File WORKSTATIO [MWS] : Endif  # postes de charge
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif  # table des formules sr 08.02 1.4.0

# lecture article si nécessaire
If [F:ITM]ITMREF <>  [M:OPSS]ITMREF
    Read [ITM]ITM0 = [M:OPSS]ITMREF
    If fstat : [M:OPSS]CODRET = 1 : End : Endif
Endif

# lecture article site si nécessaire
If [F:ITF]ITMREF <>  [M:OPSS]ITMREF | [F:ITF]STOFCY <> [M:OPSS]MFGFCY    # llc 05.02 US
    Read [ITF]ITF0 = [M:OPSS]ITMREF;[M:OPSS]MFGFCY                       # llc 05.02 US
    If fstat : [M:OPSS]CODRET = 1 : End : Endif
Endif

Local Integer LALT
Local Char LROUECCMAJ(GLONICVVAL), LROUECCMIN(GLONICVVAL)

# Issue 111414 - 2016-02-11 by CCC : Look for a valid route considering versioning
## Alternative de gamme valide FQ 48636 GA 08/2008
#Call FIND_ROUTING([M:OPSS]OPSTYP, [M:OPSS]BOMALT, [M:OPSS]STRDAT, [M:OPSS]EXTQTY) From CBNLIBO
#If [F:ROH]ROUALT = 0
If func FIND_ROUTING2([M:OPSS]OPSTYP, [M:OPSS]ITMREF, "", [M:OPSS]MFGFCY, [M:OPSS]BOMALT, [M:OPSS]STRDAT, [M:OPSS]EXTQTY) = 0
    [M:OPSS]CODRET = 1
    End
Endif

# si pas de mise à jour, appel jalonnement pour traitement gamme
If [M:OPSS]CODMAJ = 2
    Raz [M:JALK]
    [M:JALK]CODORI     = 2
    [M:JALK]CODMAJ     = [M:OPSS]CODMAJ
    [M:JALK]CODTRS     = 0
    [M:JALK]MFGFCY     = [M:OPSS]MFGFCY
    [M:JALK]ROUNUM     = [F:ROH]ITMREF
    [M:JALK]ROUALT     = [F:ROH]ROUALT
    If [M:OPSS]EXTQTY = 0
      [M:JALK]REOMINQTY  = [F:ITF]REOMINQTY
    Else
      [M:JALK]REOMINQTY  = [M:OPSS]EXTQTY
    Endif
    [M:JALK]TRTDAT     = [M:OPSS]TRTDAT
    [M:JALK]STRDAT     = [M:OPSS]STRDAT
    [M:JALK]ENDDAT     = [M:OPSS]ENDDAT
    If [F:PJA]MFGFCY <> [M:OPSS]MFGFCY
        Read [PJA]PJA0=[M:OPSS]MFGFCY
        If fstat : Raz [PJA] : Endif
    Endif
    [M:JALK]SCDMOD     = 1     # Issue 108418 08/2015 by GA backward scheduling
    [M:JALK]JAVFLG     = 2     # Issue 108418 08/2015 by GA reschedule forward if needed
    # Issue 111414/107 & 114689 - 2016-02 by CCC : Initialize route reading date only with versionning
    If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0
        [M:JALK]ROUDAT = [F:CBD]STRDAT
    Endif
    Call JALONNE From JALLIB

    If [M:JALK]CODRET=2     # Routing verion not available at start date calculated
        Call ECR_DEBUG("Routing version error => Forward scheduling from "+format$("D:"+GFMDAT,[F:CBD]STRDAT)) From FUNCBN
        Raz [M:JALK]
        [M:JALK]CODORI     = 2
        [M:JALK]CODMAJ     = [M:OPSS]CODMAJ
        [M:JALK]CODTRS     = 0
        [M:JALK]MFGFCY     = [M:OPSS]MFGFCY
        [M:JALK]ROUNUM     = [F:ROH]ITMREF
        [M:JALK]ROUALT     = [F:ROH]ROUALT
        If [M:OPSS]EXTQTY = 0
          [M:JALK]REOMINQTY  = [F:ITF]REOMINQTY
        Else
          [M:JALK]REOMINQTY  = [M:OPSS]EXTQTY
        Endif
        [M:JALK]TRTDAT     = [M:OPSS]TRTDAT
        [M:JALK]STRDAT     = [F:CBD]STRDAT
        [M:JALK]ENDDAT     = [M:OPSS]ENDDAT
        If [F:PJA]MFGFCY <> [M:OPSS]MFGFCY
            Read [PJA]PJA0=[M:OPSS]MFGFCY
            If fstat : Raz [PJA] : Endif
        Endif
        [M:JALK]SCDMOD     = 2
        [M:JALK]JAVFLG     = 2
        # Issue 111414/107 & 114689 - 2016-02 by CCC : Initialize route reading date only with versionning
        If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0
            [M:JALK]ROUDAT = [M:JALK]STRDAT
        Endif
        Call JALONNE From JALLIB
    Endif

    End
Else
# recherche des opérations valides
#If [M:OPSS]CODMAJ <> 2
    VOPE=0

    # Issue 111414 - 2016-02-11 by CCC : set the version number of the route
    If !clalev([F:RVV]) : Local File RVMVAL [RVV] : Endif
    Raz [F:RVV]
    Call INIECCROU([F:ROH]ITMREF,[F:ROH]FCY,[M:OPSS]STRDAT,[F:ROH]ROUALT,LROUECCMAJ,LROUECCMIN) From RVMLIB
    Call ECR_DEBUG("route version :'"+LROUECCMAJ+"';'"+LROUECCMIN+"' [opss]strdat="+num$([M:OPSS]STRDAT)-"[opss]enddat="+num$([M:OPSS]ENDDAT)) From FUNCBN
    # FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT # llc 10.02 Performances
    For [ROO]ROO0 Where FCY = [F:ROH]FCY &  ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT
&                 & OPENUM <> VOPE
&                 & (VALENDDAT=[0/0/0] | (VALENDDAT >= [M:OPSS]STRDAT & VALENDDAT<>[0/0/0]) )
&                 & (VALSTRDAT=[0/0/0] | (VALSTRDAT <= [M:OPSS]STRDAT & VALSTRDAT<>[0/0/0]) )
        If [F:ROO]OPENUM <> VOPE
            VOPE = [F:ROO]OPENUM
            # Issue 111414 - 2016-02-11 by CCC : add version number
            Call GEN_OPE_SUG([F:ROH]FCY,[F:ROH]ITMREF, [F:ROH]ROUALT, LROUECCMAJ, LROUECCMIN)
        Endif
    Next
#
    #
    # calcul du jalonnement et génération de la charge associée
    Raz [M:JALK]
    If [M:OPSS]CODMAJ < 2
        [M:JALK]CODORI = 2
        [M:JALK]CODMAJ = [M:OPSS]CODMAJ
        [M:JALK]CODTRS = 0
        [M:JALK]MFGFCY = [M:OPSS]MFGFCY
        [M:JALK]MFGNUM = [M:OPSS]VCRNUM
        [M:JALK]MFGSTA = 3
        [M:JALK]TRTDAT = [M:OPSS]TRTDAT
        If [F:PJA]MFGFCY <> [M:OPSS]MFGFCY
            Read [PJA]PJA0=[M:OPSS]MFGFCY
            If fstat : Raz [PJA] : Endif
        Endif
        [M:JALK]STRDAT     = [M:OPSS]STRDAT # Issue 108418 08/2015 by GA
        [M:JALK]ENDDAT     = [M:OPSS]ENDDAT # Issue 108418 08/2015 by GA
        [M:JALK]SCDMOD     = 1              # Issue 108418 08/2015 by GA backward scheduling
        [M:JALK]JAVFLG     = 2              # Issue 108418 08/2015 by GA reschedule forward if needed
        Call JALONNE From JALLIB
    Endif
Endif
#
End

#######################################################################
# Génération encours opération                                        #
#######################################################################
# llc 10.02
Subprog GEN_OPE_SUG(LFCY,LGAMME, LALT, LROUECCMAJ, LROUECCMIN)
Value Char    LFCY
Value Char    LGAMME
Value Integer LALT
Value Char    LROUECCMAJ    : # Issue 111414 - 2016-02-11 by CCC : route version number
Value Char    LROUECCMIN    : # Issue 111414 - 2016-02-11 by CCC : route version number

Local Decimal WWSTEFF : WWSTEFF = 100

Raz [M:OPSK]
[M:OPSK]          = [M:OPSS]
[M:OPSK]MFGNUM    = [M:OPSS]VCRNUM
#
[M:OPSK]OPENUM    = [F:ROO]OPENUM
[M:OPSK]EXTWST    = [F:ROO]WST
Read [MWS]WST0=[M:OPSK]EXTWST;[M:OPSS]MFGFCY
If !fstat
    WWSTEFF = [F:MWS]EFF
    [M:OPSK]EXTWSTTYP = [F:MWS]WSTTYP
Endif
[M:OPSK]EXTLAB    = [F:ROO]LABWST
[M:OPSK]OPEUOM    = [F:ROO]OPEUOM
[M:OPSK]TIMUOMCOD = [F:ROH]TIMUOMCOD
# sr 08.02 1.4.0 récup éventuelle de la formule
If [F:ROO]OPESTUFOR <> ""
   Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
   If !fstat
       # se repositionner éventuellement sur l'article produit
       If [F:ITM]ITMREF <> [M:OPSS]ITMREF
           Read [F:ITM]ITM0 = [M:OPSS]ITMREF
           If fstat : Raz [F:ITM] : Endif
       Endif
       If [F:ITF]ITMREF <> [M:OPSS]ITMREF | [F:ITF]STOFCY <> [M:OPSS]MFGFCY
           Read [F:ITF]ITF0 = [M:OPSS]ITMREF;[M:OPSS]MFGFCY
           If fstat : Raz [F:ITF] : Endif
       Endif
       Onerrgo ERR_TFO # FQ 71005 GA 01/2011
       If evalue([F:TFO]FORFOR) <> 0
             [M:OPSK]OPESTUCOE = evalue([F:TFO]FORFOR)
       Elsif [F:ROO]OPESTUCOE <> 0
             [M:OPSK]OPESTUCOE = [F:ROO]OPESTUCOE
       Else
             [M:OPSK]OPESTUCOE = 1
       Endif
       Onerrgo # FQ 71005 GA 01/2011
   Else
       [M:OPSK]OPESTUCOE = [F:ROO]OPESTUCOE
   Endif
Else
   [M:OPSK]OPESTUCOE = [F:ROO]OPESTUCOE
Endif

# llc 10.02 regroupement
[M:OPSK]SCHGRP    = [F:ROO]SCHGRP
If [F:ROO]SCHGRPFOR <> ""
   Read [F:TFO]TFO0=9;[F:ROO]SCHGRPFOR
   If !fstat
       # se repositionner éventuellement sur l'article produit
       If [F:ITM]ITMREF <> [M:OPSS]ITMREF
           Read [F:ITM]ITM0 = [M:OPSS]ITMREF
           If fstat : Raz [F:ITM] : Endif
       Endif
       If [F:ITF]ITMREF <> [M:OPSS]ITMREF | [F:ITF]STOFCY <> [M:OPSS]MFGFCY
           Read [F:ITF]ITF0 = [M:OPSS]ITMREF;[M:OPSS]MFGFCY
           If fstat : Raz [F:ITF] : Endif
       Endif
       If [F:MWS]WST <> [F:ROO]WST | [F:MWS]WCRFCY <> [M:OPSS]MFGFCY
           Read [MWS]WST0=[F:ROO]WST;[M:OPSS]MFGFCY
           If fstat : Raz [F:MWS] : Endif
       Endif
       Onerrgo ERR_TFO # FQ 71005 GA 01/2011
       If evalue([F:TFO]FORFOR) <> ""
           [M:OPSK]SCHGRP = evalue([F:TFO]FORFOR)
       Elsif [F:ROO]SCHGRP <> ""
           [M:OPSK]SCHGRP = [F:ROO]SCHGRP
       Endif
       Onerrgo # FQ 71005 GA 01/2011
   Endif
Endif

# 08.05 distinction des exemplaires
[M:OPSK]SCHSBB    = [F:ROO]SCHSBB
If [F:ROO]SCHSBBFOR <> ""
   Read [F:TFO]TFO0=9;[F:ROO]SCHSBBFOR
   If !fstat
       # se repositionner éventuellement sur l'article produit
       If [F:ITM]ITMREF <> [M:OPSS]ITMREF
           Read [F:ITM]ITM0 = [M:OPSS]ITMREF
           If fstat : Raz [F:ITM] : Endif
       Endif
       If [F:ITF]ITMREF <> [M:OPSS]ITMREF | [F:ITF]STOFCY <> [M:OPSS]MFGFCY
           Read [F:ITF]ITF0 = [M:OPSS]ITMREF;[M:OPSS]MFGFCY
           If fstat : Raz [F:ITF] : Endif
       Endif
       If [F:MWS]WST <> [F:ROO]WST | [F:MWS]WCRFCY <> [M:OPSS]MFGFCY
           Read [MWS]WST0=[F:ROO]WST;[M:OPSS]MFGFCY
           If fstat : Raz [F:MWS] : Endif
       Endif
       Onerrgo ERR_TFO # FQ 71005 GA 01/2011
       If evalue([F:TFO]FORFOR) <> ""
           [M:OPSK]SCHSBB = evalue([F:TFO]FORFOR)
       Elsif [F:ROO]SCHSBB <> ""
           [M:OPSK]SCHSBB = [F:ROO]SCHSBB
       Endif
       Onerrgo # FQ 71005 GA 01/2011
   Endif
Endif

[M:OPSK]EXTWSTNBR = [F:ROO]WSTNBR
[M:OPSK]EXTLABNBR = [F:ROO]LABNBR
[M:OPSK]SETLABCOE = [F:ROO]SETLABCOE
[M:OPSK]OPELABCOE = [F:ROO]OPELABCOE
[M:OPSK]SCOITMREF = [F:ROO]SCOITMREF
[M:OPSK]SCOWST    = [F:ROO]SCOWST                # 01.08
If [M:OPSK]SCOITMREF <> ""
    Read [ITM]ITM0=[M:OPSK]SCOITMREF
    If !fstat
        [M:OPSK]SCOLTI = [F:ITM]OFS
    Endif
Endif
[M:OPSK]OPESTA    = 1
[M:OPSK]ORI       = 3                 # Stock ou production ?????????????????????
[M:OPSK]ABBFIL    = "MFO"             # Ajouter valeur correcte ....
[M:OPSK]BPSNUM    = [F:ROO]BPRNUM

# 107310(55934) product-site supplier
If ([M:OPSK]BPSNUM = "" & [M:OPSK]SCOITMREF <> "")
  Local Integer ITMBPS
  Call DEFBPSNUM([M:OPSK]SCOITMREF,"",LFCY,"",1,[M:OPSK]BPSNUM,ITMBPS) From TRTACHDEF1
Endif

#
[M:OPSK]OPESTR    = [M:OPSS]STRDAT
[M:OPSK]OPEEND    = [M:OPSS]ENDDAT
[M:OPSK]INFCAPSTR = [M:OPSS]STRDAT
[M:OPSK]INFCAPEND = [M:OPSS]ENDDAT

# calcul des temps
Call CAL_TIME_SUG(WWSTEFF)

# création encours opération
Call GEN_OWX

# création données de jalonnement
Call GEN_JAL(LGAMME, LALT, LROUECCMAJ, LROUECCMIN)    : # Issue 111414 - 2016-02-11 by CCC : add route version number

#
End
$ERR_TFO  # FQ 71005 GA 01/2011
Call ECR_TRACE("GEN_OPE_SUG:"-mess(65,106,1) -num$([F:TFO]FORTYP)-[F:TFO]FORCOD-[F:TFO]FORFOR-[F:ITM]ITMREF,1) From GESECRAN
End

####################################################################################
# calcul des quantités et temps d'opération à partir de la gamme
Subprog CAL_TIME_SUG(WSTEFF)
Value Decimal WSTEFF    # efficience poste de charge

# Issue 105668 & 104765 GA 01/2015 idem MFGLIBO/CAL_OPE_TIME
# calcul de la quantité de l'opération (quantité lancée / coeff US/UO)
# dans la première version on ne gère pas de perte sur les opérations ...
#[M:OPSK]EXTQTY = [M:OPSS]EXTQTY * [M:OPSK]OPESTUCOE
Local    Decimal  WQTY : WQTY=[M:OPSS]EXTQTY
# calcul de la quantité de l'opération (quantité lancée / coeff US/UO)
# operation qty must be adjusted, may be different than product qty
If [F:ROO]OPESTUFOR <> ""
   Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
   If !fstat
       If evalue([F:TFO]FORFOR) <> 0
           WQTY = [M:OPSS]EXTQTY * evalue([F:TFO]FORFOR)
       Elsif [F:ROO]OPESTUCOE <> 0
           WQTY = [M:OPSS]EXTQTY *[F:ROO]OPESTUCOE
       Else
           WQTY = [M:OPSS]EXTQTY
       Endif
   Else
        WQTY = [M:OPSS]EXTQTY *[F:ROO]OPESTUCOE
   Endif
Elsif [F:ROO]OPESTUCOE<>0
  WQTY = [M:OPSS]EXTQTY * [F:ROO]OPESTUCOE
Endif
[M:OPSK]EXTQTY = WQTY

# application de la perte
If [F:ROO]SHR <> 0
   [M:OPSK]EXTQTY = [M:OPSK]EXTQTY * (1 + ([F:ROO]SHR / 100))
Endif

Call QTEARR([M:OPSK]EXTQTY,[M:OPSK]OPEUOM) From TRTDIV

# initialisation temps fixes (appliqués 1 fois pour l'OF)
[M:OPSK]PRPTIM    = [F:ROO]PRPTIM
[M:OPSK]PSPTIM    = [F:ROO]PSPTIM
[M:OPSK]EXTSETTIM = [F:ROO]SETTIM
[M:OPSK]WAITIM    = [F:ROO]WAITIM

# application du taux de compression par défaut des temps morts
# si 1    <= % compression <= 100, on comprime les temps suivant le pourcentage
# si 101  <= % compression <= n  , on augmente les temps de (100 - pourcentage)
# exemple: compression = 40 %, temps passe de 1h à 0,6 h
#          compression = 120%, temps passe de 1h à 1,2 h
If GPERCOMP > 100
    GPERCOMP -= 100
    GPERCOMP *= -1
Endif
# 04.05 22261
Case GTPSCOMP
    When 1:    # ben rien
    When 2:    # compression temps attente uniquement
               [M:OPSK]WAITIM = [M:OPSK]WAITIM *
&                               ((100 - GPERCOMP) / 100)
    When 3:    # compression temps préparation + post-opératoire
               [M:OPSK]PRPTIM = [M:OPSK]PRPTIM *
&                               ((100 - GPERCOMP) / 100)
               [M:OPSK]PSPTIM = [M:OPSK]PSPTIM *
&                               ((100 - GPERCOMP) / 100)
    When 4:    # compression des 3 temps
               [M:OPSK]WAITIM = [M:OPSK]WAITIM *
&                               ((100 - GPERCOMP) / 100)
               [M:OPSK]PRPTIM = [M:OPSK]PRPTIM *
&                               ((100 - GPERCOMP) / 100)
               [M:OPSK]PSPTIM = [M:OPSK]PSPTIM *
&                               ((100 - GPERCOMP) / 100)
    When 5:    # compresssion temps de préparation
               [M:OPSK]PRPTIM = [M:OPSK]PRPTIM    *
&                               ((100 - GPERCOMP) / 100)
    When 6:    # compresssion temps post-opératoire
               [M:OPSK]PSPTIM = [M:OPSK]PSPTIM    *
&                               ((100 - GPERCOMP) / 100)
    When 7:    # compression temps préparation + attente
               [M:OPSK]PRPTIM = [M:OPSK]PRPTIM    *
&                               ((100 - GPERCOMP) / 100)
               [M:OPSK]WAITIM = [M:OPSK]WAITIM    *
&                               ((100 - GPERCOMP) / 100)
    When 8:    # compression temps post-opératoire + attente
               [M:OPSK]PSPTIM = [M:OPSK]PSPTIM    *
&                               ((100 - GPERCOMP) / 100)
               [M:OPSK]WAITIM = [M:OPSK]WAITIM    *
&                               ((100 - GPERCOMP) / 100)
Endcase

# Issue 87635 GA 03/2013 New Entry point
Gosub PE_ROOTIMCOD From JALLIB
# calcul temps variable
Case [F:ROO]ROOTIMCOD    # suivant type tps opératoire
    When 1: # proportionnel     (temps = (quantité * temps) / quantité base)
            [M:OPSK]EXTOPETIM = ([M:OPSK]EXTQTY *
&                               [F:ROO]OPETIM) /
&                               [F:ROO]BASQTY
    When 2: # cadence          (temps = quantité / cadence)
            # llc 02.02 13175
            If [F:ROO]CAD <> 0
                [M:OPSK]EXTOPETIM = [M:OPSK]EXTQTY /
&                                   [F:ROO]CAD
            Endif
    When 3: # forfaitaire
            [M:OPSK]EXTOPETIM = [F:ROO]OPETIM
Endcase

# llc 03.01 multi-exemplaire
# si nombre de postes > 1, on divise le temps
# opératoire par le nombre de poste
#If [M:OPSK]EXTWSTNBR > 1
#    [M:OPSK]EXTOPETIM = [M:OPSK]EXTOPETIM /
#&                       [M:OPSK]EXTWSTNBR
#Endif

# application de l'efficience du poste de charge et de l'opération
# (l'efficience ne concerne que les temps de réglage et opératoire)
# temps = temps / efficience poste/100 / efficience opération/100
# suivi parmètrage général WSTEFFINH
Case GWSTEFFINH
    When 1:          # Issue 94895 - 2014-11-18 by CCC
                     If clalev([F:MWS])=0 : Local File WORKSTATIO [MWS] : Endif
                     Raz [F:MWS]
                     If [M:OPSK]EXTLAB<>""
                         Read [MWS]WST0=[M:OPSK]EXTLAB;[M:OPSK]MFGFCY
                     Endif
                     If [F:MWS]EFF=0 : [F:MWS]EFF=100 : Endif
                     # 04.05 13839
                     If GOPEEFFAPP = 1
                         [M:OPSK]EXTSETTIM = [M:OPSK]EXTSETTIM /
&                                            ([F:ROO]EFF / 100) /
&                                            (WSTEFF     / 100)
                         # Issue 94895 - 2014-11-18 by CCC
                         [M:OPSK]SETLABCOE        = [M:OPSK]SETLABCOE /
&                                                   ([F:MWS]EFF    / 100)
                     Endif
                     [M:OPSK]EXTOPETIM = [M:OPSK]EXTOPETIM /
&                                        ([F:ROO]EFF / 100) /
&                                        (WSTEFF     / 100)
                     # Issue 94895 - 2014-11-18 by CCC
                     [M:OPSK]OPELABCOE        = [M:OPSK]OPELABCOE /
&                                               ([F:MWS]EFF    / 100)
    When Default:    # 04.05 13839
                     If GOPEEFFAPP = 1
                         [M:OPSK]EXTSETTIM = [M:OPSK]EXTSETTIM /
&                                            ([F:ROO]EFF / 100)
                     Endif
                     [M:OPSK]EXTOPETIM = [M:OPSK]EXTOPETIM /
&                                        ([F:ROO]EFF / 100)
Endcase
#
[M:OPSK]ROOTIMCOD = [F:ROO]ROOTIMCOD
#
# arrondis
[M:OPSK]WAITIM =  func TRTX3.ARRTYP("", "", "TIH", [M:OPSK]WAITIM)
[M:OPSK]PRPTIM =  func TRTX3.ARRTYP("", "", "TIH", [M:OPSK]PRPTIM)
[M:OPSK]PSPTIM =  func TRTX3.ARRTYP("", "", "TIH", [M:OPSK]PSPTIM)
[M:OPSK]EXTSETTIM =  func TRTX3.ARRTYP("", "", "TIH", [M:OPSK]EXTSETTIM)
[M:OPSK]EXTOPETIM =  func TRTX3.ARRTYP("", "", "TIH", [M:OPSK]EXTOPETIM)

End


##################################################################
# Mise à de l'encours opération (création et suppression)
##################################################################
# mise à jour encours opération
Subprog GEN_OWX
Local Integer STAT
Local Date    TODAY : TODAY = date$
#
# Issue 96370 GA 02/2015
# si sous-traitance, mise à jour encours (SC-x)
#If [F:MWS]WST <> [M:OPSK]EXTWST
#    Read [F:MWS]WST0=[M:OPSK]EXTWST;[M:OPSS]MFGFCY
#    If fstat : End : Endif
#Endif
#If [F:MWS]WSTTYP = 3
If [M:OPSK]EXTWSTTYP = 3
    Call GEN_SCX
Endif
[M:OPSK]WIPNUM = [F:ORD]WIPNUM  # Suite Issue 105987 GA 03/2015 before [M:ORDK]WIPNUM
#
# création encours charge
Call NUMERO(GWSP,[M:OPSK]MFGFCY,TODAY,"",[M:OPSK]OPSNUM,STAT) From SUBANM
#MAE, bg 59141
#If STAT <> 0 : Call ERREUR("WOP"-mess(60,199,1)) From GESECRAN : Endif
If STAT <> 0 : Call ERREUR("WOP"-mess(60,199,1)-"("+GWSP-num$(STAT)+")") From GESECRAN : Endif
Call ENCOURS_OPE("C", [M:OPSK]OPSNUM) From TRTOPS

#
End

##################################################################
# Routine de mise à jour de l'encours service sous-traitance
##################################################################
Subprog GEN_SCX                         # Issue 105987 GA 02/2015
Local Integer STAT
Local Date    TODAY : TODAY = date$
#
#
[F:ORD]           = [M:OPSS]
[F:ORD]           = [M:OPSK]
# création encours
Call NUMERO(GSUG,[M:OPSK]MFGFCY,TODAY,"",[F:ORD]WIPNUM,STAT) From SUBANM
If STAT <> 0 : Call ERREUR("WOR"-mess(60,199,1)-"("+GSUG-num$(STAT)+")") From GESECRAN : Endif

[F:ORD]WIPTYP     = 4
[F:ORD]WIPSTA     = [M:OPSK]OPSSTA
[F:ORD]ITMREF     = [M:OPSK]SCOITMREF
[F:ORD]ORIFCY     = [M:OPSK]PLNFCY
[F:ORD]STOFCY     = [M:OPSK]MFGFCY
[F:ORD]BPRNUM     = [M:OPSK]BPSNUM
[F:ORD]STRDAT     = [M:OPSK]OPESTR
[F:ORD]ENDDAT     = [M:OPSK]OPEEND
[F:ORD]VCRTYP     = 11
[F:ORD]VCRNUM     = [M:OPSK]MFGNUM
[F:ORD]VCRLIN     = 0
[F:ORD]VCRSEQ     = 0
[F:ORD]EXTQTY     = [M:OPSK]EXTQTY
[F:ORD]CPLQTY     = 0
[F:ORD]ALLQTY     = 0
[F:ORD]SHTQTY     = 0
[F:ORD]FMI        = 1
[F:ORD]MRPMES     = 1
[F:ORD]BOMALT     = [M:OPSS]BOMALT
[F:ORD]BOMALTTYP  = 2                    # V6 Nomenclature de Production
Case [M:OPSS]OPSTYP
    When 1: [F:ORD]ORI        = 6
    When 2: [F:ORD]ORI        = 5
Endcase
# Issue 105987 GA 02/2015
[F:ORD]BOMOFS     = [M:OPSK]SCOLTI
If [F:ORD]BOMOFS>0
   [F:ORD]ENDDAT = [F:ORD]STRDAT + [F:ORD]BOMOFS
Endif
[F:ORD]CREDAT     = date$
[F:ORD]CREUSR     = GUSER
[F:ORD]ABBFIL     = "MFO"
GPOINT = "BEFWRIORD"
Gosub  ENTREE From EXEFNC
If GPOINT <> ""
   Call ECR_DEBUG("GEN_SCX Write ORD:"-[F:ORD]ITMREF-num$([F:ORD]STRDAT)-num$([F:ORD]ENDDAT)
&                                       -[F:ORD]WIPNUM-num$([F:ORD]WIPTYP)
&                                       -"BOMOFS="+num$([F:ORD]BOMOFS)-"BOMOPE="+num$([F:ORD]BOMOPE))  From FUNCBN
    Write [ORD]
    If fstat
      GOK = 0
      Call FSTA("ORD") From GLOCK
    Endif
Endif
#
End

