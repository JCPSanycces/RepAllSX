#<AdxTL>@(#)2.0.0.0 $Revision$

 #Gosub TEST_XSYRGBTEC
 #Gosub TEST_CRE_WIP_SYRA
 #Gosub TEST_MOD_WIP_SYRA
  Gosub TEST_DEL_WIP_SYRA

End

#==============================================================================
# Called from PJMTSKITM_CSTD_EVENTS
#==============================================================================
$MGT_ORDERS

 #Wip Management for MRP => Not delivered
 Return


  Local Char     WMESS(250)
  Local Instance WIP_PARAM Using C_ORDK
  WIP_PARAM = NewInstance C_ORDK AllocGroup null

  Case [L]AEVENT
   When "AINSERT_CONTROL_BEFORE"
     WIP_PARAM.MAJCOD    = "C"
   When "AUPDATE_AFTER"
     WIP_PARAM.MAJCOD    = "M"
     WIP_PARAM.WIPNUM    = this.WIPNUM
   When "ADELETE_CONTROL_BEFORE"
     WIP_PARAM.MAJCOD    = "A"
     WIP_PARAM.WIPNUM    = this.WIPNUM
  Endcase

  If WIP_PARAM.MAJCOD    = "C"
     WIP_PARAM.FMI      = 1
     WIP_PARAM.PIO      = 1
  Endif

  If WIP_PARAM.MAJCOD    = "C" | WIP_PARAM.MAJCOD    = "M"
     WIP_PARAM.STOFCY     = this.TASFCY             # Site de la tâche => TASFCY
     WIP_PARAM.ITMREF     = this.ITMREF             # ITMREF
     WIP_PARAM.WIPTYP     = 14                      # ML 306 - 14 = Demande affaire
     If this.APARENT.TASSTATE=1
      WIP_PARAM.WIPSTA     = 2                      # ML 317 - 1/2/3/4 = Firm/Planned/Suggested/Closed => 1 ou 2
     Else
      WIP_PARAM.WIPSTA     = 1                      # ML 317 - 1/2/3/4 = Firm/Planned/Suggested/Closed => 1 ou 2
     Endif
     WIP_PARAM.EXTQTY     = this.ITTQTY             # Quantité = ITTQTY
     WIP_PARAM.VCRTYP     = 40                      # ML 701 - 40 = Affaire
     WIP_PARAM.VCRNUM     = this.TASCOD             # Code tâche => TASCOD
     WIP_PARAM.VCRLIN     = this.ITTSEQ             # Ligne de tâche => ITTSEQ
     WIP_PARAM.VCRSEQ     = 0                       # 0
     WIP_PARAM.PJT        = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, this.OPPNUM, this.TASCOD)
     WIP_PARAM.STRDAT     = this.APARENT.TASSTARTDT # A prendre sur la tâche ? PJMTSK ?
     WIP_PARAM.ENDDAT     = this.APARENT.TASENDDT   # A prendre sur la tâche ? PJMTSK ?
  Endif

  [L]ASTATUS = func TRTWIP_SYRA.WIP(WIP_PARAM, WMESS)
  If [L]ASTATUS=[V]CST_AERROR
   [L]ASTATUS = fmet this.ASETERROR ("PJMTSKITM/GBN_TSTWIP_SYRA", WMESS, [V]CST_AERROR) #gbn-Should be taken in charge by the script calling this subprog
  Endif

  If (WIP_PARAM.MAJCOD    = "C" | this.WIPNUM="") & WIP_PARAM.WIPNUM    <> ""
   this.WIPNUM=WIP_PARAM.WIPNUM
  Endif

  FreeGroup WIP_PARAM
  WIP_PARAM = null

Return
#------------------------------------------------------------------------------

$TEST_XSYRGBTEC

 Local Instance CLASSTEC Using C_XSYRGBTEC
 CLASSTEC = NewInstance C_XSYRGBTEC AllocGroup null
 Local Integer ASTATUS
 ASTATUS = fmet CLASSTEC.TESTWIP()
 FreeGroup CLASSTEC
 CLASSTEC = null

Return

#-----------------------------------------------------------------------
$TEST_CRE_WIP_SYRA
 Call OUVRE_TRACE("TRTWIP_SYRA : creation test") From LECFIC

 Local Char     L_MESS(250)
 Local Instance WIP_PARAM Using C_ORDK
 WIP_PARAM = NewInstance C_ORDK AllocGroup null

 WIP_PARAM.MAJCOD="C"                         # Ok
 WIP_PARAM.STOFCY     = "GB1X1"               # Site de la tâche => TASFCY
 WIP_PARAM.WIPNUM     = "WIPGBN00001"         #
 WIP_PARAM.ITMREF     = "FIN_PROD1"           # ITMREF
 WIP_PARAM.WIPTYP     = 14                    # ML 306 - 14 = Demande affaire
 WIP_PARAM.WIPSTA     = 1                     # ML 317 - 1/2/3/4 = Firm/Planned/Suggested/Closed => 1 ou 2
 WIP_PARAM.EXTQTY     = 10                    # Quantité = ITTQTY
 WIP_PARAM.VCRTYP     = 40                    # ML 701 - 40 = Affaire
 WIP_PARAM.VCRNUM     = "Proj2000"            # Code tâche => TASCOD
 WIP_PARAM.VCRLIN     = 1                     # Ligne de tâche => ITTSEQ
 WIP_PARAM.VCRSEQ     = 0                     # 0
 WIP_PARAM.PJT        = "Proj200020"          # Code projet => OPPNUM
 WIP_PARAM.STRDAT     = [13/05/2016]          # A prendre sur la tâche ? PJMTSK ?
 WIP_PARAM.ENDDAT     = [13/05/2016]

 Gosub TEST_WIP_SYRA From GBN_TSTWIP_SYRA
 FreeGroup WIP_PARAM
 WIP_PARAM = null

 Call LEC_TRACE From LECFIC
Return

#-----------------------------------------------------------------------
$TEST_MOD_WIP_SYRA
 Call OUVRE_TRACE("TRTWIP_SYRA : modification test") From LECFIC

 Local Char     L_MESS(250)
 Local Instance WIP_PARAM Using C_ORDK
 WIP_PARAM = NewInstance C_ORDK AllocGroup null

 WIP_PARAM.MAJCOD     = "M"
 WIP_PARAM.WIPNUM     = "WIPGBN00001"
 WIP_PARAM.ITMREF     = "FIN_PROD1"
 WIP_PARAM.WIPTYP     = 14
 WIP_PARAM.EXTQTY     = 100

 Gosub TEST_WIP_SYRA From GBN_TSTWIP_SYRA

 FreeGroup WIP_PARAM
 WIP_PARAM = null
# Call LEC_TRACE From LECFIC
Return

#-----------------------------------------------------------------------
$TEST_DEL_WIP_SYRA
 Call OUVRE_TRACE("TRTWIP_SYRA : deletion test") From LECFIC

 Local Char     L_MESS(250)
 Local Instance WIP_PARAM Using C_ORDK
 WIP_PARAM = NewInstance C_ORDK AllocGroup null

 WIP_PARAM.MAJCOD     = "A"
 WIP_PARAM.WIPNUM     = "WIPGBN00001"
 WIP_PARAM.ITMREF     = "FIN_PROD1"
 WIP_PARAM.WIPTYP     = 14

 Gosub TEST_WIP_SYRA From GBN_TSTWIP_SYRA

 FreeGroup WIP_PARAM
 WIP_PARAM = null
 Call LEC_TRACE From LECFIC
Return

#-----------------------------------------------------------------------
$TEST_WIP_SYRA

 Local Integer ASTATUS

 [L]ASTATUS = func TRTWIP_SYRA.WIP(WIP_PARAM, L_MESS)

 If ASTATUS
  Call ECR_TRACE(L_MESS,1) From GESECRAN
 Else
  Call ECR_TRACE("Action ok",0) From GESECRAN
 Endif

Return

