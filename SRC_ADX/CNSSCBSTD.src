#<AdxTL>@(#)12.0.0.0 $Revision$ Consultation SCB
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Raz [M:CSCB] : Transmask [M:SCB1] To [M:CSCB] # Issue 25606 [M:CSCB] = [M:SCB1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "SEL_TABLE"  : Gosub SEL_TABLE
  When "TRT_DIV"    : Gosub TRT_DIV
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When "GRAPH"      : Gosub GRAPH
  When Default
Endcase
Return
############################################################
$SEL_TABLE
Case TABLE
  When "SELCBH" : Gosub SELCBH
Endcase
Return
############################################################
$TRT_DIV
Case TRAIT
  When "ASNBLIG" :  Gosub ASNBLIG
Endcase
Return
############################################################
$ASNBLIG
Case [M:SCB1]PROCOD
  When 1 :
    [M:SCB1]FLT = "[F:CBH]REOMGTCOD=3"
    Read [PCB]PCB0=[M:SCB1]FCY
    If fstat = 0 & [F:PCB]MPSITM = 2
      [M:SCB1]FLT = "find([F:CBH]REOMGTCOD,2,3)"
    Endif
  When Default :
    [M:SCB1]FLT = "[F:CBH]REOMGTCOD=2"
    Read [PCB]PCB0=[M:SCB1]FCY
    If fstat = 0 & [F:PCB]MRPITM = 2
      [M:SCB1]FLT = "find([F:CBH]REOMGTCOD,2,3)"
    Endif
Endcase
GBOUT1 = mess(4,198,1)
Return
############################################################
$AUTORIS
Local File ITMFACILIT [ITF]
Local File ITMMASTER  [ITM]
Local File PARMRP     [PCB]
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
Local File FACILITY   [FCY]
Local File TABREOPOL  [TRP]
If val(PARAM(3)) = 1
  Local File PDPHEA [CBH]
  Local File PDPDET [CBD]
Else
  Local File CBNHEA [CBH]
  Local File CBNDET [CBD]
Endif
If GMODU(8) = 2
    If clalev ([F:MFG]) <= 0 : Local File MFGHEAD   [MFG] : Endif
Endif
If GMODU(6) = 2
    If clalev ([F:POH]) <= 0 : Local File PORDER    [POH] : Endif
    If clalev ([F:SCO]) <= 0 : Local File SCOHEAD   [SCO] : Endif : # V6
Endif

Return
############################################################
$OUVRE
#
Local Char    WFILS(250)
Local Char    WFILSPE(250)
Local Char    WTITRE(60)
Local Decimal WSTO
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer I, J
Local Date    WDAT
Local Integer WGCONSULT : WGCONSULT = GCONSULT
#
If val(PARAM(3)) = 1
  WTITRE = mess(31,187,1)
Else
  WTITRE = mess(32,187,1)
Endif
TITT = WTITRE
Gosub LOAD_SCREEN
#
NAVIG="CONSSCB"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SCB1]FLG = 0
[M:SCB1]    = [M:CSCB]
Return
############################################################
$AP_MAGNETO
Read [CBH]CBH0=[M:SCB1]FCY;[M:SCB1]ITMREF     # llc 05.00
If fstat
   Raz [F:CBH]
Endif
[M:SCB1]FLG = 0
[M:SCB1] = [F:CBH]
Return
############################################################
$FERME
If clalev([F:CBH]) <> 0 : Filter [CBH] : Endif
If clalev([F:CBD]) <> 0 : Filter [CBD] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SCB1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      [M:SCB1]PROCOD = val(PARAM(I))
    When 4 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSCB]) <> 0 & [M:CSCB]MEMO = "STD"
  [M:SCB1] = [M:CSCB]
Endif
Return
############################################################
$LECTURE
SUITE  = 1
RETOUR = 1
NBLU   = 2
#
If [M:SCB1]ITMREF = ""
  NBLU = 0
  Return
Endif
#
Raz [M:SCB2]
Raz WSTO
nolign = 0
# Lecture parametres site
Read [PCB]PCB0=[M:SCB1]FCY
If fstat
  Goto LECTURE_FIN
Else
  If [M:SCB1]PROCOD = 1
    [M:SCB2]BOMALT = [F:PCB]MPSBOMALT
    [M:SCB1]DATREF = [F:PCB]MPSLASDAT
  Else
    [M:SCB2]BOMALT = [F:PCB]MRPBOMALT
    [M:SCB1]DATREF = [F:PCB]MRPLASDAT
  Endif
Endif
# Lecture entete CBH
Read [CBH]CBH0=[M:SCB1]FCY;[M:SCB1]ITMREF
If fstat
  Raz [F:CBH]
Endif
[M:SCB2] = [F:CBH]
[M:SCB2]STU0 = [F:CBH]STU
[M:SCB2]STU1 = [F:CBH]STU
[M:SCB2]STU2 = [F:CBH]STU
[M:SCB2]STU3 = [F:CBH]STU
[M:SCB2]STU4 = [F:CBH]STU
[M:SCB2]STU5 = [F:CBH]STU
# Issue 95551 GA 01/2014 display total allocated qty
If dim([M:SCB2]GLOSTO)<=0
   [M:SCB2]ALLSTO += [F:CBH]GLOALL
Else
# Issue 95567 GA 10/2014 4 new fields in screen CONSSCB2
   [M:SCB2]GLOSTO = [F:CBH]GLOALL
   [M:SCB2]DETSHT = [F:CBH]DETSHT
   [M:SCB2]GLOSHT = [F:CBH]GLOSHT
Endif
# Lecture article
Read [ITM]ITM0=[M:SCB1]ITMREF
If fstat
  Raz [F:ITM]
Endif
# Lecture site réapro
If [M:SCB2]REOFCY = ""
  [M:SCB2]FCYNAM = ""
Else
  Read [FCY]FCY0=[M:SCB2]REOFCY
  If fstat = 0
    [M:SCB2]FCYNAM = [F:FCY]FCYNAM
  Endif
Endif
# Lecture politique réapro
Read [TRP]TRP0=[F:CBH]REOPOL
If fstat = 0
  Call GET_ATEXTRA("TABREOPOL","TRPAXX",GLANGUE,[F:TRP]TRPDES) From TRTX3TEX
Endif
#
If [M:SCB1]DATREF <> [0/0/0]
  WDAT = [M:SCB1]DATREF - 1
  If [M:SCB2]PLHENDDAT = WDAT
    [M:SCB2]PLHENDDAT = [0/0/0]
  Endif
  If [M:SCB2]FOHENDDAT = WDAT
    [M:SCB2]FOHENDDAT = [0/0/0]
  Endif
Endif
#
WSTO = [F:CBH]STRSTO # <MG> 23/02/00
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
Filter [CBD] Where STOFCY = [F:CBH]STOFCY &
&                  ITMREF = [F:CBH]ITMREF &
&                  evalue(WFILS)          &
&                  evalue(WFILSPE)
&            Order By Key CBD0
J = 0
For [CBD]
  # FQ 69905 GA 12/2010 il manque la dernière ligne
  #If nolign < dim([M:SCB2]WIPNUM)-1
  If nolign < dim([M:SCB2]WIPNUM)
    nolign += 1
    NOL    += 1
    [M:SCB2] = [F:CBD]
    If (func CBNLIB.ISDEM ([F:CBD]WIPTYP))
      [M:SCB2]REQQTY(nolign-1) *= -1
      [M:SCB2]RMNEXTQTY(nolign-1) *= -1
    Endif
    [M:SCB2]WIPTYPSTA(nolign-1) = mess([M:SCB2]WIPTYP(nolign-1),341,1)+mess([M:SCB2]WIPSTA(nolign-1),342,1)
    If [F:CBD]REQDAT <= [M:SCB2]PLHENDDAT & [F:CBD]REQDAT <> [0/0/0]
      [M:SCB2]WIPTYPSTA(nolign-1) += "*"
    Endif
    If [F:CBD]WIPTYPORI <> 0
      [M:SCB2]WIPTYPSTAO(nolign-1) =
&         mess([F:CBD]WIPTYPORI,341,1)+mess([F:CBD]WIPSTAORI,342,1)
    Endif
    # affichage spécial ordres WOF en cours
    If [F:CBD]WIPTYP = 5 & [F:CBD]WIPSTA = 1 & GMODU(8) = 2
        Read [MFG]MFG0=[F:CBD]VCRNUM
        If fstat : Raz [MFG]
        Else
            If [F:MFG]MFGSTA = 1 & [F:MFG]MFGTRKFLG = 4 : [M:SCB2]WIPTYPSTA(nolign-1) += ">" : Endif
        Endif
    Endif
    # affichage spécial ordres EOF en cours
    If [F:CBD]WIPTYP = 13 & [F:CBD]WIPSTA = 1 & GMODU(6) = 2
        Read [SCO]SCO0=[F:CBD]VCRNUM
        If fstat : Raz [SCO]
        Else
            If [F:SCO]SCOSTA = 1 & [F:SCO]SCOTRKFLG = 4 : [M:SCB2]WIPTYPSTA(nolign-1) += ">" : Endif
        Endif
    Endif
    # affichage spécial ordres POF en cours
    If [F:CBD]WIPTYP = 2 & [F:CBD]WIPSTA = 1 & GMODU(6) = 2
        Read [POH]POH0=[F:CBD]VCRNUM
        If fstat : Raz [POH] : Endif
        If [F:POH]RCPFLG = 2 : [M:SCB2]WIPTYPSTA(nolign-1) += ">" : Endif
    Endif
    # Issue 108013 GA 07/2015 version in MRP can change BOMALT
    If dim([M:SCB2]WBOMALT)>0 & [F:CBD]ECCVALMAJ <> ""
       [M:SCB2]WBOMALT(nolign-1) = [F:CBD]BOMALT
    Endif
    [M:SCB2]NBLIG += 1 # Issue 86297 GA 08/2013
  Else
    J = 1
    Break
  Endif
Next
If J = 0
  For I = 0 To nolign-1
# Correction quantité restante par % perte
    If [M:SCB2]WIPTYP(I) = 5 & find([M:SCB2]WIPSTA(I),1,2,3) & [F:CBH]SHR > 0
      WSTO += arr(([M:SCB2]REQQTY(I)*100)/(100+[F:CBH]SHR),10^-[F:CBH]STUDEC)
    Else
      WSTO += [M:SCB2]REQQTY(I)
    Endif
    [M:SCB2]EXTSTO(I) = WSTO
  Next I
Endif
$LECTURE_FIN
# Issue 86297 GA 08/2013 pour spécifique nécessiant de rectifier le résultat affiché
GPOINT = "AFFICSCB" : Gosub ENTREE From EXEFNC
Return
############################################################
$GRAPH
Local Date    WDAT
Local Decimal WSTP
Local Integer WFLG(WROW)
Local Integer I, J, K, L
Local Char    WITMDES(GLONDES)  # FGR 30/06/2009 : X3SUIVI56189

WTIT = WTITRE-"("+[M:SCB1]FCY+")"

#WFOO = [F:ITM]ITMREF-[F:ITM]ITMDES1-"("-[F:ITM]STU+")"
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
WFOO = [F:ITM]ITMREF-WITMDES-"("-[F:ITM]STU+")"                                      # FGR 30/06/2009 : X3SUIVI56189

# Constitution table labels abscisses
WDAT = [M:SCB1]DATREF
For I = 0 To WROW-1
  If I = 0 | dayn(WDAT) = 1
    WABS(I) = format$("D:"+GFMDAT,WDAT)
  Else
    WABS(I) = " "
  Endif
  WDAT += 1
Next I
# Constitution table labels ordonnées
WORD(0) = mess(157,198,1)
Call TEXTFIC("ITMFACILIT","MAXSTO",2,WORD(1)) From OBJDIV
Call TEXTFIC("ITMFACILIT","SAFSTO",2,WORD(2)) From OBJDIV
# Constitution table des valeurs
WAMT(0,0) = [M:SCB2]STRSTO
I = 0
While I < [M:SCB2]NBLIG
  K = I
  WSTP = [M:SCB2]EXTSTO(I)
  While K < [M:SCB2]NBLIG & [M:SCB2]BUC(I) = [M:SCB2]BUC(K)
    WSTP = [M:SCB2]EXTSTO(K)
    K += 1
  Wend
  L = I
  While L < [M:SCB2]NBLIG & [M:SCB2]BUC(I) = [M:SCB2]BUC(L)
    J = [M:SCB2]REQDAT(L) - [M:SCB1]DATREF
    If J < WROW
      WFLG(J) = 1
      WAMT(J,0) = WSTP
    Else
      Break 2
    Endif
    L += 1
  Wend
  I = L
Wend
#
For I = 0 To WROW-1
  If  I > 0 & WFLG(I) = 0
    WAMT(I,0) = WAMT(I-1,0)
  Endif
  WAMT(I,1) = int([F:ITF]MAXSTO)
  WAMT(I,2) = int([F:ITF]SAFSTO)
Next I
Return

############################################################
# Fenetre de sélection des table CBH
$SELCBH
Local Char    WITM(GLONITM)   : WITM = VALEUR
Local Char    WFCY(GLONFCY)   : WFCY = PARAM(1)
Local Integer WPRO       : WPRO = val(PARAM(2))
Local Char    WFILX(250)
#
If PARAM(3) <> ""
  WFILX = evalue(PARAM(3))
Endif
#
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
#
If WPRO = 1
  If clalev([F:CBH])  = 0 : Local File PDPHEA   [CBH] : Endif
Else
  If clalev([F:CBH])  = 0 : Local File CBNHEA   [CBH] : Endif
Endif
#
TIT(0) = mess(22,123,1)
NBCOL  = 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC("CBNHEA","ITMREF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMDES1"
Call TEXTFIC("CBNHEA","ITMDES1",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:CBH]REOMGTCOD,727,1)"
Call TEXTFIC("CBNHEA","REOMGTCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LLC"
Call TEXTFIC("CBNHEA","LLC",2,TIT(NBCOL)) From OBJDIV
#
CRITERE = "[F:CBH]STOFCY=WFCY&[F:CBH]ITMREF>=WITM"
If WFILX <> ""
  CRITERE += "&"+WFILX
Endif
ORDRE   = "ITMREF"
START   = "ITMREF"
VALEUR  = WITM
SIZLIG  = 180
SIZCOL  = 200
Default File [CBH]
Return
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SCB1]FLG = 0
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SCB1]FLG = 0
[M:SCB1] = [F:CBH]
[M:SCB2] = [F:CBH]
[M:SCB2]STU0 = [F:CBH]STU
[M:SCB2]STU1 = [F:CBH]STU
[M:SCB2]STU2 = [F:CBH]STU
[M:SCB2]STU3 = [F:CBH]STU
[M:SCB2]STU4 = [F:CBH]STU
[M:SCB2]STU5 = [F:CBH]STU
Read [ITM]ITM0=VALEUR
If fstat : Raz [ITM] : Endif
[M:SCB1]TCLCOD = [F:ITM]TCLCOD
Affzo [M:SCB2]STU
Affzo [M:SCB2]STU0
Affzo [M:SCB2]STU1
Affzo [M:SCB2]STU2
Affzo [M:SCB2]STU3
Affzo [M:SCB2]STU4
Affzo [M:SCB2]STU5
End
############################################################
Subprog AV_STDFLGDES(VALEUR)
Variable Char    VALEUR()
If [M:SCB2]STDFLG <> 0 & [M:SCB1]ITMREF <> ""
  VALEUR = mess([M:SCB2]STDFLG,297,1)
Endif
End
############################################################
Subprog AV_REOCODDES(VALEUR)
Variable Char    VALEUR()
If [M:SCB2]REOCOD <> 0 & [M:SCB1]ITMREF <> ""
  VALEUR = mess([M:SCB2]REOCOD,250,1)
Endif
End
############################################################
Subprog AV_WIPTYPSTA(VALEUR)
Variable Char    VALEUR()
If nolign > 0
  If [M:SCB2]REQQTY(nolign-1) < 0
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End
############################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Read [CBH]CBH0=[M:SCB1]FCY;VALEUR
If fstat
   Raz [F:CBH]
   mkstat = 2
   GMESSAGE = mess(23,100,1)
Endif
End
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SCB") From SUBGTC

End

