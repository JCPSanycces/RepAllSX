Call C_SALCRENBE(VALEUR) From SUBTPM
If mkstat : GERR = 1 : GZONE = "SALCRENBE" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_BACK31
Onevent INIT_AREA Call D_BACK31(zc) From W2TPM
Return

Subprog D_BACK31(VALEUR)
Variable Char    VALEUR()
If varinit([M]BACK31,indice)=0
 VALEUR = mess(8,213,1)
Endif
Gosub _AFF
End

