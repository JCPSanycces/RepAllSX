#<AdxTL>@(#)4.0.0.0 $Revision$
GBIDI1 = 1
Call OBJET("PAH",GBIDC1,GBIDC2) From GOBJET
End
# Issue X3-107197 - 2018-09-14 by CBO : PARAMETER AND ACTIVITY CODE

$ACTION
Case ACTION
 When "OUVRE"           : Gosub OUVRE
 When "DEFTRANS"        : Gosub DEFTRANS
 When "AFFMASK"         : Gosub AFFMASK
 When "APRES_CHOI"      : Gosub APRES_CHOI
 When "FILTRE"          : Gosub FILTRE
 When "SETBOUT"         : Gosub SETBOUT
 When "LIENS"           : Gosub LIENS
 When "RAZCRE"          : Gosub RAZCRE
 When "RAZDUP"          : Gosub RAZDUP
 When "VERIF_CRE"       : Gosub VERIF_CRE
 When "VERIF_MOD"       : Gosub VERIF_MOD
 When "INICRE"          : Gosub INICRE
 When "CREATION"        : Gosub CREATION
 When "MODIF"           : Gosub MODIF
 When "AV_ANNULE"       : Gosub AV_ANNULE
 When "SEL_TABLE"       : Gosub SEL_TABLE
 When "SEL_LISTE"       : Gosub SEL_LISTE
 When "AVANT_SUITE"     : Gosub AVANT_SUITE
 When "AVANT_ACT"       : Gosub AVANT_ACT
 When "SELBPRPTH"       : Gosub S_BPRPTH : # Sélection Cobrador (spécial ARG)
 When "SELECH"          : Gosub SELECH
Endcase
Return

$AVANT_SUITE
If BOUT="1" :  # Règlement
 [L]VALC1="PAY" : [L]VALC2=VALBOUT
Endif
Return

$AVANT_ACT
If BOUT = "S" : # Suppression
 Filter [PYH2] Where NUMORD = [M:PAH0]NUM
 Read [PYH2]PYH0 First
 Filter [PYH2]
 If !fstat
  # Vous devez d'abord supprimer les règlements associés à cet ordre de paiement
  OK = 0 : GMESSAGE = mess(16,8890,1)
  Return
 Endif
Elsif BOUT = "A" : # Abandon
 Actzo [M:PAH0]NUM
Endif
Return



$OUVRE
Onerrgo ERREUR From CONTROLE
Gosub OUVRE_FIC
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif

Local Integer STAT, X
Local Integer VU
Local Integer OK2
Local Integer SIGN
Local Integer NOLI, NUMDOC, I
Local Integer RIT, RTZ, INDRIT
Local Integer OKTCA
Local Char    VALC1(30), VALC2(30)
Local Char    COMPTREG(GLONANM)
Local Char    VALC1(20)
Local Char    TYPDOC(GLONADI)
Local Char    OPT(10)
Local Char    LCK(30)
Local Char    DEVLED(GLONCUR)
Local Decimal MT
Local Decimal TOTDOC
Local Decimal TOTVCR
Local Decimal ARODEV, ARODEV2

Local Char TABRITCOD(GLONRTZ)(0..dim([M:PAH1]VCRNUM)-1)
Local Char TABRITNUM(GLONVCR)(0..dim([M:PAH1]VCRNUM)-1)

Local Char BPCTYP(max(GLONGTE,GLONTPV)) : # Pièce commandes clients      : Paramétrée dans le paramètre dossier BPCORDTYP
Local Char BPSTYP(max(GLONGTE,GLONTPV)) : # Pièce commandes fournisseurs : Paramétrée dans le paramètre dossier BPSORDTYP
Local Char PROTYP(max(GLONGTE,GLONTPV)) : # Pièce proformas fournisseurs : Paramétrée dans le paramètre dossier BPSPROTYP
Local Char PCETYP(max(GLONGTE,GLONTPV)) : # Pièce comptable (facture) : par défaut, on prend le type de pièce associée
                                          # au type de facture paramétré dans les paramètres dossier TYPINVCUS (clients)
                                          # ou TYPINVSUP (fournisseurs)

Local Char CODRTZ(GLONRTZ)
Local Char NUMRTZ(GLONVCR)

Global Integer GNBPLAN                               : # Nb de plans comptables (max 10)
Global Integer GNBAXE                                : # Nb d'axes à saisir (max 20)
Global Char    GPLAN(GLONCOA)(1..10)                 : # Plans (COA)
Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))    : # Axes (DIE)
Global Integer GOBLIG(1..max(GOPTCANA,20))           : # Obligatoire (O/N)
Global Integer GTYPLED(1..10)                        : # Types référentiels

If GFLAG = "ORD"
 [M:PAH0]TYP = 1
Elsif GFLAG = "REC"
 [M:PAH0]TYP = 2
Endif

# % variation montant devise
Call PARAM("","PRCAMTCNV",OPT) From ADOVAL : [M]PRCAMTCNV=val(OPT)
Return


$OUVRE_FIC
If clalev([F:PAH])=0  : Local File PAYPTH     [PAH] : Endif
If clalev([F:PAO])=0  : Local File PAYPTHDOC  [PAO] : Endif
If clalev([F:PAO2])=0 : Local File PAYPTHDOC  [PAO2]: Endif
If clalev([F:PYP])=0  : Local File PAYPTD     [PYP] : Endif
If clalev([F:PRI])=0  : Local File PAYPTHRIT  [PRI] : Endif
If clalev([F:PRI3])=0 : Local File PAYPTHRIT  [PRI3]: Endif
If clalev([F:RIU])=0  : Local File RITDUD     [RIU] : Endif
If clalev([F:RIU2])=0 : Local File RITDUD     [RIU2]: Endif
If clalev([F:RIU3])=0 : Local File RITDUD     [RIU3]: Endif
If clalev([F:RCU])=0  : Local File RITCUM     [RCU] : Endif
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPS])=0  : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:TCY])=0  : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS  [BPA] : Endif
If clalev([F:BIS])=0  : Local File BID        [BID] : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE] : Endif
If clalev([F:TPV])=0  : Local File TABPIVTYP  [TPV] : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD] : Endif
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI] : Endif
If clalev([F:TCA])=0  : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE] : Endif
If clalev([F:MTB])=0  : Local File MTCBATCH   [MTB] : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU] : Endif
If clalev([F:SIH])=0  : Local File SINVOICE   [SIH] : Endif
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH] : Endif
If clalev([F:TPY])=0  : Local File TABPAYTYP  [TPY] : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC] : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU] : Endif
If clalev([F:CDA])=0  : Local File GACCDENCOD [CDA] : Endif
If clalev([F:CAC])=0  : Local File GACCCODE   [CAC] : Endif
If clalev([F:BPC])=0  : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPS])=0  : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:PYH])=0  : Local File PAYMENTH   [PYH] : Endif
If clalev([F:PYH2])=0 : Local File PAYMENTH   [PYH2]: Endif
If clalev([F:PYD])=0  : Local File PAYMENTD   [PYD] : Endif
If clalev([F:PYA])=0  : Local File PAYMENTA   [PYA] : Endif
If clalev([F:RTZ])=0  : Local File RITENZIONE [RTZ] : Endif
If clalev([F:PIL])=0  : Local File BPSINVLIG  [PIL] : Endif
If clalev([F:TVT])=0  : Local File TABVAT     [TVT] : Endif
If func AFNC.ACTIV("KAG") <> 0
 If clalev([F:CHN])=0  : Local File CHQNUM     [CHN] : Endif
Endif
If GMODU(5)=2
 If clalev([F:SOH])=0 : Local File SORDER    [SOH] : Endif
 If clalev([F:PID])=0 : Local File PINVOICED [PID] : Endif
Endif
If GMODU(6)=2 & clalev([F:POH])=0 : Local File PORDER  [POH] : Endif
Return

$AFFMASK
Return

$DEFTRANS
Case GBIDI1
 When 1
  GFLAG = "ORD"
 When 2
  GFLAG = "REC"
Endcase
Return

$APRES_CHOI
Return

$FILTRE
If GFLAG = "ORD"
 FILTSUP = "[PAH]TYP="+num$(1)
Else
 FILTSUP = "[PAH]TYP="+num$(2)
Endif
Return

$SETBOUT
If [M:PAH0]STA=3 or REP<>"" or CLECUR=0 or !VERROU or [M:PAH1]NBLIG=0
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
If CLECUR & GREP="" & [M:PAH0]STA=3
 #If GTUNCPT(5)=0 : CHMEN += "1" : Endif : # Règlement
 CHMEN += "1"
Endif
If GFLAG = "ORD"
 CHMEN += "3"
Endif
If [M:PAH0]STA<3
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$LIENS
Grizo [M:PAH1]AMTRTZ
Call PARAM([M:PAH0]CPY,"BPCORDTYP",[M:PAH0]BPCTYP) From ADOVAL
If [M:PAH0]BPCTYP="" : [M:PAH0]BPCTYP="*SO" : Endif
Call PARAM([M:PAH0]CPY,"BPSORDTYP",[M:PAH0]BPSTYP) From ADOVAL
If [M:PAH0]BPSTYP="" : [M:PAH0]BPSTYP="*PO" : Endif
If func AFNC.ACTIV("KIT")   # Issue X3-107197
  Call PARAM([M:PAH0]CPY,"BPSPROTYP",[M:PAH0]PROTYP) From ADOVAL
Endif   # Issue X3-107197
Call LECTURE("CPY",[M:PAH0]CPY,"") From CONTOBJ
Call SETCUR(1,[F:CPY]CPY,[L]DEVLED) From CPTDIV
Call SETMAINREF([M:PAH0]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call SETPLAN([M:PAH0]CPY,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
[M:PAH1]CURCPY = [L]DEVLED
[M:PAH0]BPRNAM = [M:PAH2]BPANAM
If [M:PAH0]TYP = 1 : # Ordre de paiements
 Call PARAM([M:PAH0]CPY,"TYPINVSUP",[L]PCETYP) From ADOVAL
 Call LEC_TPV_LEG([F:CPY]LEG,[L]PCETYP) From CPTLEC
 [L]PCETYP = [F:TPV]GTE
Else : # Recibo
 Call PARAM([M:PAH0]CPY,"TYPINVCUS",[L]PCETYP) From ADOVAL
 Call LEC_TPV_LEG([F:CPY]LEG,[L]PCETYP) From CPTLEC
 [L]PCETYP = [F:TPV]GTE
Endif
[M:PAH0]PCETYP = [L]PCETYP
## Chargement documents appliqués...
Raz nolign : [M:PAH1]TOTPAY = 0
For [PAO]PAO0 Where TYP=[M:PAH0]TYP & NUM=[M:PAH0]NUM
 NOL=nolign : nolign += 1
 [M:PAH1] = [F:PAO]
 [M:PAH1]AMTRTZ(NOL) = sum([F:PAO]RITAMT(0..dim([F:PAO]RITAMT)-1))
 [M:PAH1]TOTPAY += [M:PAH1]AMTVCR(NOL)*[M:PAH1]SNSDUD(NOL)
 [M:PAH1]TOTPAY -= [M:PAH1]AMTDEP(NOL)*[M:PAH1]SNSDUD(NOL)
 If [M:PAH0]TYP = 1
  [M:PAH1]TOTPAY -= [M:PAH1]AMTRTZ(NOL) : # [M:PAH1]AMTRTZ() est déjà signé...
 Endif
Next
[M:PAH1]NBDOC = nolign

## Chargement règlements effectués...
Raz nolign : LIEN = 0
For [PYP]PYP0 Where TYP=[M:PAH0]TYP & NUM=[M:PAH0]NUM
 NOL=nolign : nolign += 1
 [M:PAH1] = [F:PYP]
 If [F:PYP]NUMREG<>""
  LIEN = 1
 Endif
Next
If [M:PAH0]STA = 3 & LIEN = 0
 ## il n'existe plus de règlements X3 pour cet ordre de paiements (les règlements X3 ont été supprimés), on repasse
 ## l'ordre 'En attente'
 [M:PAH0]STA = 1
Endif
[M:PAH1]NBLIG = nolign
Raz nolign : RIT = 0
For [PRI]PRI0 Where TYP=[M:PAH0]TYP & NUM=[M:PAH0]NUM
 RIT = nolign : nolign += 1
 [M:PAH3]RITNUM(RIT) = [F:PRI]RITNUM
 [M:PAH3]RITCOD(RIT) = [F:PRI]RITCOD
 [M:PAH3]DES(RIT)    = [F:PRI]DES
 Call LECTURE("TCU",[M:PAH1]CURVCR(0),"") From CONTOBJ
 ARODEV = [F:TCU]CURRND
 Call LECTURE("TCU",GCURSHR,"") From CONTOBJ
 ARODEV2 = [F:TCU]CURRND
 [M:PAH3]RITAMT(RIT) = [F:PRI]AMTRTZ : # Devise échéance
 [M:PAH3]CURVCR(0)   = [F:PRI]CUR
 If [M:PAH0]TYP = 1
  [M:PAH3]RITAMTRPT(RIT) = [F:PRI]AMTRTZRPT : # Devise reporting
  [M:PAH3]BASANTCUM(RIT) = [F:PRI]BASMONCUM : # Base imposable règlements antérieurs du mois (pour retenues Ganancias)
  [M:PAH3]RITANTCUM(RIT) = [F:PRI]AMTMONCUM : # Montants retenues règlements antérieurs du mois (pour retenues Ganancias)
 Endif
Next
[M:PAH3]NBRIT = nolign
Affzo [M:PAH3]

If [M:PAH0]TYP = 1
 [M:PAH1]TOTRTZ = sum([M:PAH3]RITAMT(0..[M:PAH3]NBRIT-1))
Else
 [M:PAH1]TOTPAY -= sum([M:PAH3]RITAMT(0..[M:PAH3]NBRIT-1))
 [M:PAH1]TOTRTZ = sum([M:PAH3]RITAMT(0..[M:PAH3]NBRIT-1))
Endif
Call GETSOC([M:PAH0]FCY) From DEVSUB
Affzo [M:PAH1]TOTPAY : Affzo [M:PAH1]TOTRTZ
Return

$SEL_TABLE
Case COUZON
 When "VCRNUM" : Gosub S_VCRNUM : # Numéro de pièce imputée
Endcase
Return

$SEL_LISTE
Case COUZON
 When "VCRTYP" : Gosub S_VCRTYP : # Type de pièce imputée
 When "BPRPTH" : Gosub S_BPRPTH : # Sélection cobrador
Endcase
Return

$RAZCRE
Grizo [M:PAH1]AMTRTZ
[M:PAH0]NUM=""
[M:PAH0]STA = 1
Gosub GRISE_CLE From =WINPROG
Raz TABRITNUM, TABRITCOD
Return

$RAZDUP
Gosub RAZCRE
If [M]NBDOC : Effzo [M:PAH1]10 : Endif
If [M]NBLIG : Effzo [M:PAH1]15 : Endif
Effzo [M:PAH1]20
Effzo [M:PAH3]
Return


$VERIF_CRE

Gosub VERIF
Return

$VERIF_MOD
Gosub VERIF
Return

$VERIF
TOTDOC = 0
Call LECTURE("TCU",[M:PAH1]CURVCR(0),"") From CONTOBJ
ARODEV = [F:TCU]CURRND
Call LECTURE("TCU",GCURSHR,"") From CONTOBJ
ARODEV2 = [F:TCU]CURRND
If [M:PAH0]TYP = 1
 TOTDOC = sigma(indice=0,[M]NBDOC,[M]AMTVCR(indice)*[M]SNSDUD(indice))
 TOTDOC -= sigma(indice=0,[M]NBDOC,[M]AMTDEP(indice)*[M]SNSDUD(indice))
 TOTDOC -= sigma(indice=0,[M]NBDOC,[M]AMTRTZ(indice)) : # [M]AMTRTZ est déjà signé....
 If sum([M:PAH1]AMTLIN2(0..[M:PAH1]NBLIG-1))<>TOTDOC
  # La somme des règlements n'est pas égale à la somme des échéances à règler
  Call AVERTIR(mess(7,8890,1),OK2) From GESECRAN
  If OK2<>2
   GERR = 1 : OK = 0
  Endif
 Endif
Elsif [M:PAH0]TYP = 2
 TOTDOC = sigma(indice=0,[M]NBDOC,[M]AMTVCR(indice)*[M]SNSDUD(indice))
 TOTDOC -= sigma(indice=0,[M]NBDOC,[M]AMTDEP(indice)*[M]SNSDUD(indice))
 TOTDOC -= arr(sum([M:PAH3]RITAMT(0..[M:PAH3]NBRIT-1)),ARODEV)
 If sum([M:PAH1]AMTLIN2(0..[M:PAH1]NBLIG-1))<>TOTDOC
  # La somme des règlements n'est pas égale à la somme des échéances à règler
  Call AVERTIR(mess(7,8890,1),OK2) From GESECRAN
  If OK2<>2
   GERR = 1 : OK = 0
  Endif
 Endif
Endif
Return

$INICRE
COMPTREG = ""
Call GETSOC([M]FCY) From DEVSUB
Call LECTCA(3,OKTCA) From SUBTCA
If OKTCA
 If [M:PAH0]TYP = 1
  COMPTREG = [F:TCA]CODNUM(9)  : # Ordres de paiements
 Else
  COMPTREG = [F:TCA]CODNUM(10) : # Recibo
 Endif
Endif
If COMPTREG=""
 If [M:PAH0]TYP = 1
  COMPTREG = "ORD"
 Else
  COMPTREG = "RCB"
 Endif
Endif

If [M:PAH0]TYP = 1 | func AFNC.ACTIV("KAA") = 0
 ## Pas de structure de numérotation particulière pour les ordres de paiements
 Call NUMERO(COMPTREG,[M:PAH0]FCY,[M:PAH0]DAT,"",[F:PAH]NUM,STAT) From SUBANM
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  GMESSAGE = mess(104,117,1)-"("+COMPTREG+") : "+MESSA
  Return
 Endif
Else
 Filter [ADI] Where NUMTAB = 362
 For [ADI]CODE
  VU = instr(1,[F:ADI]A1,num$(6)) : #  6:Recibo
  If VU
   TYPDOC = [F:ADI]CODE : Break
  Endif
 Next
 Filter [ADI]
 If !VU
  TYPDOC = "RC"
 Endif
 Call NUMEROARG(COMPTREG,[M:PAH0]FCY,TYPDOC,3,[M:PAH0]DAT,[M:PAH0]VAC,[F:PAH]NUM,[F:PAH]CAI,[F:PAH]DATVLYCAI,STAT) From SUBANMARG
 If STAT
  MESSA=mess(104,117,1)-"("+[F:GTE]COU+") : "
  Gosub MESSAGE From SUBANMARG
  GMESSAGE=MESSA
  Return
 Endif
Endif
[M:PAH0]NUM = [F:PAH]NUM
[F:PAH]STA=1 : # En attente
[F:PAH]SCU = [M:PAH0]SCU
Affzo [M:PAH0]NUM : Affzo [M:PAH0]STA
Actzo [M:PAH0]NUM : Affzo [M:PAH0]SCU
Return

$CREATION
Gosub CRELIG
If GOK<1 : Return : Endif
If [M:PAH0]TYP = 1
 Gosub WRITE_RITCUM
 If GOK<1 : Return : Endif
Endif
Return

$MODIF
Gosub DELLIG
If GOK<1 : Return : Endif
Gosub CRELIG
If GOK<1 : Return : Endif
If [M:PAH0]TYP = 1
 Gosub DEL_RITCUM
 If GOK<1 : Return : Endif
 Gosub WRITE_RITCUM
 If GOK<1 : Return : Endif
Endif
Return


$CRELIG
Call SETCUR(1,[M:PAH0]CPY,[L]DEVLED) From CPTDIV
If [M:PAH0]TYP = 1
 Gosub CHARGE_RETENUES
 ## On efface les montants réels de retenues précédemment chargés...
 For I = 0 To [M:PAH3]NBRIT-1
  [M:PAH3]RITAMT(I) = 0
  [M:PAH3]RITAMTRPT(I) = 0
 Next
 Gosub RAZ_TABRET
Endif

## 1ère passe : calcul retenues : chargement des tableaux
For nolign=1 To [M]NBDOC
 NOL=nolign-1
 If [M:PAH0]TYP = 1
  NBFAC = [M]NBDOC : Gosub CAL_RETENUES
 Endif
Next


For nolign=1 To [M]NBDOC
 NOL=nolign-1
 Raz [F:PAO]
 [F:PAO] = [F:PAH]
 [F:PAO] = [M:PAH1]
 [F:PAO]LIG = nolign
 If [M:PAH0]TYP = 1
  Filter [RIU] Where TYPREC = 1 & NUM = [F:PAO]VCRNUM & DUDNUM = [F:PAO]DUDNUM & DUDLIG = [F:PAO]DUDLIG
  Readlock [RIU]RIU0 First
  Filter [RIU]
  If fstat=1
   GOK=-1 : GLOCK="$RITDUD"-num$(TYPREC)-[F:PAO]VCRNUM-num$([F:PAO]DUDNUM)-num$([F:PAO]DUDLIG) : Break
  Endif
  Filter [RIU2] Where TYPREC = 0 & NUM = [F:PAO]VCRNUM & DUDNUM = [F:PAO]DUDNUM & DUDLIG = 1
  Readlock [RIU2]RIU0 First
  Filter [RIU2]
  If fstat=1
   GOK=-1 : GLOCK="$RITDUD"-num$(TYPREC)-[F:PAO]VCRNUM-num$([F:PAO]DUDNUM)-num$([F:PAO]DUDLIG) : Break
  Elsif !fstat
   For RTZ=0 To [M:PAH3]NBRIT-1
    ## Ecriture des montants retenues dans PAYPTHDOC (table des documents appliqués)
    ## Ecriture des montants retenues dans RITDUD (montants retenues par échéance) : sert essentiellement
    ## dans le cas où le code retenue est paramétré 'Paiement partiel = 'Sur premier règlement'
    If TABCODRTZ(NOL,RTZ)<>""
     [F:PAO]RITCOD(RTZ)     += TABCODRTZ(NOL,RTZ)
     [F:PAO]RITAMT(RTZ)     += TABAMT(NOL,RTZ)
     [F:PAO]RITAMTRPT(RTZ)  += TABAMTRPT(NOL,RTZ)
     [F:RIU]RITAMT(RTZ)     += TABAMT(NOL,RTZ)
     [F:RIU]RITAMTRPT(RTZ)  += TABAMTRPT(NOL,RTZ)
     [F:RIU2]RITAMT(RTZ)    += TABAMT(NOL,RTZ)
     [F:RIU2]RITAMTRPT(RTZ) += TABAMTRPT(NOL,RTZ)
    Endif
    [M:PAH1]AMTRTZ(NOL) = sum([F:PAO]RITAMT(0..dim([F:PAO]RITAMT)-1))
   Next
   Rewrite [RIU]
   If fstat
    GOK = 0 : Call FSTA("RIU") From GLOCK : Break
   Endif
   Rewrite [RIU2]
   If fstat
    GOK = 0 : Call FSTA("RIU2") From GLOCK : Break
   Endif
  Endif
 Else
  # Pour les récibos, on répartit les retenues proportionnellement aux montants des échéances type facture
  If [M:PAH1]SNSDUD(NOL) = 1 : Gosub REP_DOCRCB : Endif
 Endif
 Write [PAO]
 If fstat
  GOK = 0 : Call FSTA("PAO") From GLOCK : Break
 Endif

 If [F:PAO]VCRNUM<>"" & [F:PAO]IPTTYP<>4
  If [F:PAO]DUDNUM<>0
   Case [F:PAO]IPTTYP
    When 1       : LCK = "HAE"+num$([F:PAO]VCRNUM)+"\*SO"
    When 2       : LCK = "HAE"+num$([F:PAO]VCRNUM)+"\*PO"
    When 3       : LCK = "HAE"+num$([F:PAO]VCRNUM)+"\"+num$([F:PAO]VCRTYP)
   Endcase
   Lock =LCK
   If fstat : GOK=-1 : GLOCK="%"+LCK : Break : Endif
   Readlock [DUD]DUD1 = [F:PAO]DUDNUM;[F:PAO]DUDLIG
   If fstat=1
    GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:PAO]DUDNUM)-num$([F:PAO]DUDLIG) : Break
   Elsif fstat=0
    SIGN=1
    Gosub MAJ_MTDUD : If GOK<1 : Break : Endif
    Call SLDECH("DUD")From MODECHE
    Rewrite [DUD]
    If fstat : GOK=0 : Call FSTA("DUD") From GLOCK : Break : Endif
   Endif
  Endif
 Endif
Next
If GOK<1 : Return : Endif

For nolign=1 To [M]NBLIG
 ## Ecriture lignes ordres de paiements/récibos
 NOL=nolign-1
 Raz [F:PYP]
 [F:PYP] = [F:PAH]
 [F:PYP] = [M:PAH1]
 If [M:PAH1]BAN(NOL) = "" & [M:PAH1]CAISSE(NOL)<>""
  [F:PYP]BAN = [M:PAH1]CAISSE(NOL)
 Endif
 [F:PYP]LIG = nolign
 Write [PYP]
 If fstat
  GOK = 0 : Call FSTA("PYP") From GLOCK : Break
 Endif
 If [M:PAH1]BAN(NOL)<>"" & dim([M:PAH1]CHQNUM)>0 & [M:PAH1]CHQNUM(NOL)<>""
  Readlock [CHN]CHN0 = [M:PAH1]BAN(NOL);[M:PAH1]CHQNUM(NOL)
  If fstat=1
   GOK=-1 : GLOCK="$CHQNUM"-[M:PAH1]BAN(NOL)-[M:PAH1]CHQNUM(NOL) : Break
  Elsif !fstat
   [F:CHN]STA = 2 : # Théoriquement déjà mis à 'Utilisé' en saisie...
   [F:CHN]PAYORDNUM = [F:PAH]NUM
   Rewrite [CHN]
   If fstat
    GOK=0 : Call FSTA("CHN") From GLOCK : Break
   Endif
  Endif
 Endif
Next

## Ecriture dans la table PAYPTHRIT... (Table des montants retenues par ordre de paiements/récibos)
## => On efface tout puis on re-écrit...
Delete [PRI] Where TYP=[F:PAH]TYP & NUM=[F:PAH]NUM
If fstat=1
 GOK = -1 : Call RSTA("PRI",CLECUR1) From GLOCK : Return
Endif
For RIT = 0 To [M:PAH3]NBRIT-1
 Raz [F:PRI]
 If ([M:PAH0]TYP = 1 & [M:PAH3]RITCOD(RIT)<>"") | ([M:PAH0]TYP=2 & [M:PAH3]RITNUM(RIT)<>"")
  [F:PRI]TYP    = [M:PAH0]TYP
  [F:PRI]NUM    = [M:PAH0]NUM
  [F:PRI]DES    = [M:PAH3]DES(RIT)
  [F:PRI]CUR    = [M]CURVCR(0)
  If [M:PAH0]TYP = 1
   [F:PRI]RITCOD = [M:PAH3]RITCOD(RIT)
   VU = find([M:PAH3]RITCOD,TABRITCOD(0..[M:PAH3]NBRIT-1))
   If VU & TABRITNUM(VU-1)<>""
    [F:PRI]RITNUM = TABRITNUM(VU-1)
   Else
    CODRTZ = [F:PRI]RITCOD
    ## <Mail Flavio 24/08/05> On numérote les codes retenues uniquement lorsque le montant de retenues <> 0
    If [M:PAH3]RITAMT(RIT)<>0
     Gosub SEQ_NUM
     [F:PRI]RITNUM = NUMRTZ
     [M:PAH3]RITNUM = NUMRTZ
    Endif
   Endif
   [F:PRI]AMTRTZ = sum(TABAMT(0..[M:PAH1]NBDOC-1,RIT))
   [F:PRI]BASRTZ = sum(TABBAS(0..[M:PAH1]NBDOC-1,RIT))
   [F:PRI]AMTRTZRPT = sum(TABAMTRPT(0..[M:PAH1]NBDOC-1,RIT))
   [F:PRI]BASRTZRPT = sum(TABBASRPT(0..[M:PAH1]NBDOC-1,RIT))
   [F:PRI]BASMONCUM = TABBASCUM(RIT)
   [F:PRI]AMTMONCUM = TABRITCUM(RIT)
  Else
   [F:PRI]RITCOD = [M:PAH3]RITNUM(RIT) : # Pour les récibos, on met la même chose dans RITCOD et RITNUM
   [F:PRI]RITNUM = [M:PAH3]RITNUM(RIT)
   [F:PRI]AMTRTZ = [M:PAH3]RITAMT(RIT)
   If [M:PAH1]CURVCR(0)<>GCURSHR
    Call CONVERT([M:PAH1]CURVCR(0),GCURSHR,DEVLED,1,[M:PAH0]DAT,[M:PAH3]RITAMT(RIT),[F:PRI]AMTRTZRPT,STAT) From TRTDEV
    If STAT
     GOK=0 : GMESSAGE=mess(16,114,1)-GCURSHR-"->"-[M:PAH1]CURVCR(0)-"("+format$("D:"+GFMDAT,[M:PAH0]DAT)-")" : Break
    Endif
   Else
    [F:PRI]AMTRTZRPT = [M:PAH3]RITAMT(RIT)
   Endif
  Endif
  Write [PRI]
  If fstat
   GOK = 0 : Call FSTA("PRI") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Affzo [M:PAH1] : Affzo [M:PAH3]
Return


# On affecte un numéro de retenue à chaque retenue
$SEQ_NUM
Read [F:RTZ]RTZ0 = CODRTZ
Call NUMERO([F:RTZ]COU,[F:PAH]CPY,[F:PAH]DAT,CODRTZ,NUMRTZ,STAT) From SUBANM
If GOK<0 : Return
Elsif GOK<1 | STAT
 GOK=0
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  GMESSAGE = mess(104,117,1)-"("+[F:RTZ]COU+") : "+MESSA
 Endif
 Return
Endif
Return

$DEL_RITCUM
## On décrémente la table cumulée RITCUM et on l'incrémentera dans $WRITE_RITCUM
If !find(GREP,"C","D")
 ANNEE = year([M:PAH0]DAT)
 MOIS  = month([M:PAH0]DAT)
 For NUMRET = 0 To [M:PAH3]NBRIT-1
  Read [RTZ]RTZ0 = [M:PAH3]RITCOD(NUMRET)
  If !fstat & [F:RTZ]MET = 2
   Read [RCU]RCU0 = [M:PAH0]CPY ; [M:PAH0]BPR ; [L]ANNEE ; [L]MOIS ; [M:PAH3]RITCOD(NUMRET)
   If !fstat
    Read [PRI3]PRI1 = [M:PAH0]TYP ; [M:PAH0]NUM ; [M:PAH3]RITCOD(NUMRET)
    If !fstat
     [F:RCU]AMTMON -= [F:PRI3]AMTRTZRPT
     [F:RCU]BASMON -= [F:PRI3]BASRTZRPT
     Rewrite [RCU]
     If fstat
      GOK=0 : Call FSTA("RCU") From GLOCK : Break
     Endif
    Endif
   Endif
  Endif
 Next
 If GOK<1 : Return : Endif
Endif
Return

$WRITE_RITCUM
ANNEE = year([M:PAH0]DAT)
MOIS  = month([M:PAH0]DAT)
For NUMRET = 0 To [M:PAH3]NBRIT-1
 Read [RTZ]RTZ0 = [M:PAH3]RITCOD(NUMRET)
 If !fstat & [F:RTZ]MET = 2
  Read [RCU]RCU0 = [M:PAH0]CPY ; [M:PAH0]BPR ; [L]ANNEE ; [L]MOIS ; [M:PAH3]RITCOD(NUMRET)
  If !fstat
   [F:RCU]AMTMON += [M:PAH3]RITAMTRPT(NUMRET)
   [F:RCU]BASMON += [M:PAH3]RITBASRPT(NUMRET)
   Rewrite [RCU]
   If fstat
    GOK=0 : Call FSTA("RCU") From GLOCK : Break
   Endif
  Elsif fstat
   [F:RCU]CPY    = [M:PAH0]CPY
   [F:RCU]BPR    = [M:PAH0]BPR
   [F:RCU]YEA    = [L]ANNEE
   [F:RCU]MON    = [L]MOIS
   [F:RCU]RITCOD = [M:PAH3]RITCOD(NUMRET)
   [F:RCU]AMTMON = [M:PAH3]RITAMTRPT(NUMRET)
   [F:RCU]BASMON = [M:PAH3]RITBASRPT(NUMRET)
   Write [RCU]
   If fstat
    GOK=0 : Call FSTA("RCU") From GLOCK : Break
   Endif
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Return


$REP_DOCRCB
Local Decimal TABREPRTZ(0..99)
Local Decimal ARODEV, ARODEV2
Call LECTURE("TCU",[M:PAH1]CURVCR(0),"") From CONTOBJ
ARODEV = [F:TCU]CURRND
Call LECTURE("TCU",GCURSHR,"") From CONTOBJ
ARODEV2 = [F:TCU]CURRND
[M:PAH1]TOTRTZ = arr(sum([M:PAH3]RITAMT(0..[M:PAH3]NBRIT-1)),ARODEV)
TOTVCR = sigma(indice=0,[M:PAH1]NBDOC,[M:PAH1]AMTVCR(indice)*[M:PAH1]SNSDUD(indice))
[M:PAH1]AMTRTZ(NOL) = 0
For RIT = 0 To [M:PAH3]NBRIT-1
 If NOL+1<>[M:PAH1]NBDOC
  [F:PAO]RITCOD(RIT) = [M:PAH3]RITNUM(RIT)
  [F:PAO]RITAMT(RIT) = arr((([M:PAH1]AMTVCR(NOL)*[M:PAH1]SNSDUD(NOL))*sum([M:PAH3]RITAMT(RIT)))/[L]TOTVCR,ARODEV)
  [M:PAH1]AMTRTZ(NOL) += [F:PAO]RITAMT(RIT)
  TABREPRTZ(RIT) += [F:PAO]RITAMT(RIT)
 Else
  [F:PAO]RITCOD(RIT) = [M:PAH3]RITNUM(RIT)
  [F:PAO]RITAMT(RIT) = sum([M:PAH3]RITAMT(RIT))-TABREPRTZ(RIT)
  [M:PAH1]AMTRTZ(NOL) += [F:PAO]RITAMT(RIT)
 Endif
Next
Return

$DELLIG
For [PAO]PAO0 Where TYP=[F:PAH]TYP & NUM=[F:PAH]NUM
 If [F:PAO]DUDNUM<>0
  Case [F:PAO]IPTTYP
   When 1 : LCK = "HAE"+num$([F:PAO]VCRNUM)+"\*SO"
   When 2 : LCK = "HAE"+num$([F:PAO]VCRNUM)+"\*PO"
   When 3 : LCK = "HAE"+num$([F:PAO]VCRNUM)+"\"+num$([F:PAO]VCRTYP)
  Endcase
  Lock =LCK
  If fstat : GOK=-1 : GLOCK="%"+LCK : Break : Endif
  Readlock [DUD]DUD1 = [F:PAO]DUDNUM;[F:PAO]DUDLIG
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:PAO]DUDNUM)-num$([F:PAO]DUDLIG) : Break
  Else
   SIGN=-1
   Gosub MAJ_MTDUD : If GOK<1 : Break : Endif
   Call SLDECH("DUD")From MODECHE
   Rewrite [DUD]
   If fstat : GOK=0 : Call FSTA("DUD") From GLOCK : Break : Endif
  Endif
 Endif
 ## Avant d'effacer les lignes de documents appliqués, on décrémente les montants de retenues réel (champ RITAMT)
 ## dans la table RITDUD (ils seront incrémentés en $CRELIG)
 Filter [RIU] Where TYPREC = 1 & NUM = [F:PAO]VCRNUM & DUDNUM = [F:PAO]DUDNUM & DUDLIG = [F:PAO]DUDLIG
 Readlock [RIU]RIU0 First
 Filter [RIU]
 If fstat=1
  GOK=-1 : GLOCK="$RITDUD"-num$(TYPREC)-[F:PAO]VCRNUM-num$([F:PAO]DUDNUM)-num$([F:PAO]DUDLIG) : Break
 Endif
 Filter [RIU2] Where TYPREC = 0 & NUM = [F:PAO]VCRNUM & DUDNUM = [F:PAO]DUDNUM & DUDLIG = 1
 Readlock [RIU2]RIU0 First
 Filter [RIU2]
 If fstat=1
  GOK=-1 : GLOCK="$RITDUD"-num$(TYPREC)-[F:PAO]VCRNUM-num$([F:PAO]DUDNUM)-num$([F:PAO]DUDLIG) : Break
 Elsif fstat = 0
  For RTZ=0 To dim([F:PAO]RITCOD)-1
   If [F:PAO]RITCOD(RTZ)<>""
    [F:RIU]RITAMT(RTZ)     -= [F:PAO]RITAMT(RTZ)
    [F:RIU]RITAMTRPT(RTZ)  -= [F:PAO]RITAMTRPT(RTZ)
    [F:RIU2]RITAMT(RTZ)    -= [F:PAO]RITAMT(RTZ)
    [F:RIU2]RITAMTRPT(RTZ) -= [F:PAO]RITAMTRPT(RTZ)
   Endif
  Next
  Rewrite [RIU]
  If fstat
   GOK = 0 : Call FSTA("RIU") From GLOCK : Break
  Endif
  Rewrite [RIU2]
  If fstat
   GOK = 0 : Call FSTA("RIU2") From GLOCK : Break
  Endif
 Endif
Next : # [PAO]
If GOK<1 : Return : Endif
Delete [PAO] Where TYP=[F:PAH]TYP & NUM=[F:PAH]NUM
If fstat=1
 GOK = -1 : Call RSTA("PAO",CLECUR1) From GLOCK : Return
Endif

If GREP="A"
 For [PYP] Where TYP=[M:PAH0]TYP & NUM=[M:PAH0]NUM
  If [F:PYP]BAN<>"" & dim([M:PAH1]CHQNUM)>0 & [F:PYP]CHQNUM<>""
   Readlock [CHN]CHN0 = [F:PYP]BAN;[F:PYP]CHQNUM
   If fstat=1
    GOK=-1 : GLOCK="$CHQNUM"-[F:PYP]BAN-[F:PYP]CHQNUM : Break
   Elsif !fstat
    [F:CHN]STA = 3 : # On met le chèque à 'Annulé' en saisie...
    [F:CHN]PAYORDNUM = ""
    [F:CHN]PAYNUM = ""
    Rewrite [CHN]
    If fstat
     GOK=0 : Call FSTA("CHN") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
Endif

Delete [PYP] Where TYP=[F:PAH]TYP & NUM=[F:PAH]NUM
If fstat=1
 GOK = -1 : Call RSTA("PYP",CLECUR1) From GLOCK : Return
Endif
If [M:PAH0]TYP = 1
 RIT = 0
 For [PRI]PRI0 Where TYP=[F:PAH]TYP & NUM=[F:PAH]NUM
  ## On conserve les numéros de retenzione générés par une séquence numéro
  TABRITCOD(RIT) = [F:PRI]RITCOD
  TABRITNUM(RIT) = [F:PRI]RITNUM
  RIT += 1
 Next
Endif

Return


$MAJ_MTDUD
[F:DUD]TMPCUR+=SIGN*([F:PAO]AMTVCR-[F:PAO]AMTDEP)
[F:DUD]TMPLOC+=SIGN*([F:PAO]AMTLOC-[F:PAO]AMTLOCDEP)
If [F:DUD]PAMTYP=1 & find([F:DUD]TYP,"*SO","*PO")
 MT=[F:DUD]AMTCUR-[F:DUD]DINAMT-[F:DUD]IBDAMT
 [F:DUD]AMTCUR=[F:DUD]TMPCUR
 [F:DUD]AMTLOC=[F:DUD]TMPLOC
 [F:DUD]IBDAMT=[F:DUD]AMTCUR-[F:DUD]DINAMT-MT
Endif
Return

$AV_ANNULE
Gosub OUVRE
GREP="A" : Gosub DELLIG : GREP=""
If GOK<1 : Return : Endif
Return

$S_VCRTYP
Local Integer K, I : K=dim(TEX)-1
Local Char INTIT(GLONAX3)
Case [M]IPTTYP
 When 1 : # Commandes client
  If [M:PAH0]BPCTYP<>"" & NBTEX+1<=K & !find([M:PAH0]BPCTYP,TEX(1..NBTEX))
   NBTEX += 1
   TEXTE(NBTEX) = format$("K:5X",[M:PAH0]BPCTYP)+" "+mess(1,659,1) : # Commande client
   TEX(NBTEX)   = [M:PAH0]BPCTYP
   I=1
  Endif
 When 2 : # Commandes fournisseurs
  If [M:PAH0]BPSTYP<>"" & NBTEX+1<=K & !find([M:PAH0]BPSTYP,TEX(1..NBTEX))
   NBTEX += 1
   TEXTE(NBTEX) = format$("K:5X",[M:PAH0]BPSTYP)+" "+mess(2,659,1) : # Commande fourn.
   TEX(NBTEX)   = [M:PAH0]BPSTYP
   I=1
  Endif
 When 3 : # Pièces comptables
  PARAM(1) = [M:PAH0]FCY
  Gosub SELGTE2 From SELGTE
 When 4 : # Proforma fournisseurs
  If dim([M:PAH0]PROTYP)>0 & [M:PAH0]PROTYP<>"" & NBTEX+1<=K & !find([M:PAH0]PROTYP,TEX(1..NBTEX))
   NBTEX += 1
   TEXTE(NBTEX) = format$("K:5X",[M:PAH0]PROTYP)+" "+mess(4,659,1) : # Proforma fourn.
   TEX(NBTEX)   = [M:PAH0]PROTYP
   I=1
  Endif
Endcase
If I
 Sorta NBTEX+1 TEXTE, TEX Order By TEX(indice)
Endif
Call TITOBJ("GTE","",TIT) From CONTOBJ
Return


$S_VCRNUM
Case [M]IPTTYP(nolign-1)
 When 1 : # cde cli
  OBJET="SOH"
  OPTIONS="#"
  If [M:PAH0]BPR<>"" : CRITERE= "BPCPYR='"+[M:PAH0]BPR+"'" : Endif
 When 2 : # cde fou
  OBJET="POH"
  OPTIONS="#"
  If [M]BPR<>"" : CRITERE= "BPRPAY='"+[M]BPR+"'" : Endif
 When 4 : # proforma fou
  OBJET="PIH"
  OPTIONS="#"
  CRITERE="INVTYP=5 & CPY='"+[M]CPY+"'"
  If [M]NUM<>"" : CRITERE += " & (RITPAY='' | RITPAY='"+[M]NUM+"')"
  Else          : CRITERE += " & RITPAY=''"
  Endif
  If [M]BPR<>"" : CRITERE+= " & BPRPAY='"+[M]BPR+"'" : Endif
 When Default : # Pièce comptable
  Local File GACCDUDATE [DUD]
  If [M:PAH0]TYP = 1
   Filter [DUD] Where CPY=[M]CPY & TYP=[M]VCRTYP(nolign-1) & BPRTYP=2
&                   & FLGCLE=1 & BPRFCT=''
  Else
   Filter [DUD] Where CPY=[M]CPY & TYP=[M]VCRTYP(nolign-1) & BPRTYP=1
&                   & FLGCLE=1 & BPRFCT=''
  Endif
  Local Char SITE(GLONFCY), TIERS(GLONBPR)
  SITE=[M]FCY : TIERS=[M]BPR
  Gosub SEL_DUD From SELDUD1
Endcase
Return

$S_BPRPTH
Local Integer K, I : K=dim(TEX)-1
For [BPR]BPR0 Where PTHFLG  = 2
 If NBTEX+1>K : Break : Endif
 NBTEX += 1
 TEXTE(NBTEX) = format$("K:15X",[F:BPR]BPRNUM)+" "+[F:BPR]BPRNAM
 TEX(NBTEX)   = [F:BPR]BPRNUM
Next
Return


$SELECH
Gosub SELECH From SUBPAH2
Return




######################################################################################
## Etiquette ajoutée par le superviseur (écran PAYORD0) 07/01/2005 17:16:48 (PP)
######################################################################################
Subprog C_NUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Look [PAH]PAH0 = [M:PAH0]TYP ; VALEUR
 If fstat : VALEUR="" : Endif
Endif
End

Subprog AP_NUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : mkstat=4 : Endif
End

Subprog AV_STA2(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
Local Char SITE(GLONFCY)
SITE=VALEUR
Call INIFCY(SITE,[M]CPY) From CPTSUB
If mkstat
 mkstat=0 : Call AP_FCY(SITE)
 If mkstat : mkstat=0 : Else VALEUR=SITE : mkstat=2 : Endif
Elsif SITE<>""
 Call AP_FCY(SITE) : If !mkstat : VALEUR=SITE : Else mkstat=0 : Endif
Endif
End

Subprog AP_FCY(VALEUR)
Variable Char    VALEUR()
If clalev([F:TPV])=0  : Local File TABPIVTYP  [TPV] : Endif
Local Char OPT(10), DEVLED(GLONCUR)
Local Char PCETYP(max(GLONGTE,GLONTPV)) : # Pièce comptable (facture) : par défaut, on prend le type de pièce associée
                                          # au type de facture paramétré dans les paramètres dossier TYPINVCUS (clients)
                                          # ou TYPINVSUP (fournisseurs)
[M:PAH1]CURCPY=""
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
If fstat : [M]CPY=""
Else     : [M]CPY=[F:FCY]LEGCPY
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Call SETCUR(1,[F:CPY]CPY,DEVLED) From CPTDIV
 If fstat=0 : [M:PAH1]CURCPY=[L]DEVLED : Endif
Endif
Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call SETPLAN([M:PAH0]CPY,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
Call GETSOC(VALEUR) From DEVSUB

If (func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGREC",VALEUR)<>"2") or func AFNC.ACTIV("KAG") = 0  # Issue X3-107197
 ## Société XXX : fonction non autorisée
 GMESSAGE = mess(2,45,1)-GSOCIETE-":"-tolower(mess(74,100,1))
 mkstat = 2 : End
Endif
Call PARAM(VALEUR,"SEVFCYENT",OPT) From ADOVAL : [M]FCYOPT=val(OPT) : # OD inter-sites
Call PARAM(VALEUR,"SEVBPRENT",OPT) From ADOVAL : [M]BPROPT=val(OPT) : # OD inter-tiers
Call PARAM(VALEUR,"PRCAMTCNV",OPT) From ADOVAL : [M]PRCAMTCNV=val(OPT)
If [M:PAH0]TYP = 1 : # Ordre de paiements
 Call PARAM(VALEUR,"TYPINVSUP",[L]PCETYP) From ADOVAL
 Call LEC_TPV_LEG(GCURLEG,[L]PCETYP) From CPTLEC
 [L]PCETYP = [F:TPV]GTE
Else : # Recibo
 Call PARAM(VALEUR,"TYPINVCUS",[L]PCETYP) From ADOVAL
 Call LEC_TPV_LEG(GCURLEG,[L]PCETYP) From CPTLEC
 [L]PCETYP = [F:TPV]GTE
Endif
[M:PAH0]PCETYP = [L]PCETYP
Call PARAM([M]CPY,"BPCORDTYP",[M:PAH0]BPCTYP) From ADOVAL
If [M:PAH0]BPCTYP="" : [M:PAH0]BPCTYP="*SO" : Endif
Call PARAM([M]CPY,"BPSORDTYP",[M:PAH0]BPSTYP) From ADOVAL
If [M:PAH0]BPSTYP="" : [M:PAH0]BPSTYP="*PO" : Endif
If func AFNC.ACTIV("KIT") # Issue X3-107197
  Call PARAM([M]CPY,"BPSPROTYP",[M:PAH0]PROTYP) From ADOVAL
Endif # Issue X3-107197
Affzo [M:PAH1]CURCPY
End


Subprog AS_DAT(VALEUR)
Variable Date    VALEUR
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
End

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
Call CONTPER(VALEUR,GTYPGEN,[M:PAH0]FCY) From CPTSUB
If mkstat : End : Endif
End

Subprog AS_BPR(VALEUR)
Variable Char    VALEUR()
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
End

Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BPR",VALEUR,"") From CONTOBJ
## Ordres de paiements => Fournisseurs
If [M:PAH0]TYP=1
 If [F:BPR]BPSFLG<>2
  GMESSAGE = VALEUR-":"-mess(3,119,1) : # Ce tiers n'est pas un fournisseur
  mkstat = 2 : End
 Endif
 Call LECTURE("BPS",VALEUR,"") From CONTOBJ
 If dim([F:BPS]BPSSTA)>0 & [F:BPS]BPSSTA<>2
  GMESSAGE = mess(5,119,1) : # Fournisseur non actif
  mkstat = 2 : End
 Endif
 Call INIT_REGIME(VALEUR,[M:PAH0]FCY,"F",[M:PAH0]VAC) From CPTSUB
## Récibos => Clients
Elsif [M:PAH0]TYP=2
 If [F:BPR]BPCFLG<>2
  GMESSAGE = VALEUR-":"-mess(2,119,1) : # Ce tiers n'est pas un client
  mkstat = 2 : End
 Endif
 Call LECTURE("BPC",VALEUR,"") From CONTOBJ
 If dim([F:BPC]BPCSTA)>0 & [F:BPC]BPCSTA<>2
  GMESSAGE = mess(4,119,1) : # Client non actif
  mkstat = 2 : End
 Endif
 Call INIT_REGIME(VALEUR,[M:PAH0]FCY,"C",[M:PAH0]VAC) From CPTSUB
Endif
[M:PAH0]BPRNAM = [F:BPR]BPRNAM
[M:PAH0]CRY = [F:BPR]CRY
End



Subprog AS_IPTTYP(VALEUR)
Variable Integer VALEUR
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
If [M:PAH0]TYP = 1
 GMENLOC(1) = 1
Else
 GMENLOC(2) = 1
 GMENLOC(4) = 1
Endif
If GMODU(5)<>2 : # On n'a pas le module Ventes
 GMENLOC(1) = 1
Endif
If GMODU(6)<>2 : # On n'a pas le module Achats
 GMENLOC(2) = 1
 GMENLOC(4) = 1
Endif
End

Subprog AM_IPTTYP(VALEUR)
Variable Integer    VALEUR
Gosub SETNOL
Case VALEUR
 When 1 : [M]VCRTYP(NOL) = [M:PAH0]BPCTYP
 When 2 : [M]VCRTYP(NOL) = [M:PAH0]BPSTYP
 When 3 : [M]VCRTYP(NOL) = [M:PAH0]PCETYP
 When 4 : [M]VCRTYP(NOL) = [M:PAH0]PROTYP
Endcase
Affzo VCRTYP
If VALEUR = 5
 [M]SNSDUD(NOL) = 1
Endif
End


Subprog AS_VCRTYP(VALEUR)
Variable Char     VALEUR
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
If [M]IPTTYP(nolign-1) = 5 : # Non imputé
 mkstat = 1 : End
Endif
End

Subprog C_VCRTYP(VALEUR)
Variable Char     VALEUR
If [M]IPTTYP(nolign-1)<>5 & VALEUR=""
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Endif
Call LEC_GTE_LEG(GCURLEG,VALEUR) From CPTLEC
If fstat
 Case VALEUR
  When [M]BPCTYP : [M]IPTTYP(indice)=1
  When [M]BPSTYP : [M]IPTTYP(indice)=2
  When Default
   If dim([M]PROTYP)>0 & [M]PROTYP=VALEUR : [M]IPTTYP(indice)=4
   Else
    ## Type de pièce inexistant
    GMESSAGE=mess(17,114,1)
    mkstat=2 : End
   Endif
 Endcase
Endif
End


Subprog AS_VCRNUM(VALEUR)
Variable Char    VALEUR()
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
Gosub SETNOL
If [M]IPTTYP(NOL) = 5
 mkstat = 1 : End
Endif
If [M]DUDNUM(NOL)<>0 & find([M]IPTTYP(NOL),1,2)
 Call LECDUD([M]DUDNUM(NOL),[M]DUDLIG(NOL))
 If fstat=0 & [F:DUD]PAMTYP=1 & [F:DUD]DINAMT<>0 : mkstat=2 : End : Endif
Endif
# Facture/Commande
GBOUT3 = mess(4,413,1)+"/"+mess(2,413,1)
End

Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()
Local Char SITE(GLONFCY)
Local Char DEVISE(GLONCUR)
Gosub SETNOL
Case [M]IPTTYP(NOL)
 When 1 : # Cde cli
  Call LECTURE("SOH",VALEUR,"") From CONTOBJ
  If fstat=0 : [L]SITE=[F:SOH]SALFCY : Endif
  [L]DEVISE = [F:SOH]CUR
 When 2 : # Cde fou
  Call LECTURE("POH",VALEUR,"") From CONTOBJ
  If fstat=0
   If [F:POH]POHTYP<>1 : GMESSAGE=mess([F:POH]POHTYP,506,1) : mkstat=2 : End : Endif
   [L]SITE=[F:POH]POHFCY
  Endif
 When 4 : # Proforma fournisseur
  Read [PIH]PIH0 = VALEUR
  If fstat | [F:PIH]INVTYP<>5
   ## Proforma fournisseur inexistante
   GMESSAGE = mess(15,131,1)
   mkstat = 2 : End
  Elsif [F:PIH]CPY<>[M]CPY
   ## Facture passée sur la société
   GMESSAGE = mess(78,119,1)-[F:PIH]CPY
   mkstat = 2 : End
  Elsif [F:PIH]STA<>3
   ## Facture non validée
   GMESSAGE = mess(36,119,1)
   mkstat = 2 : End
  Elsif [F:PIH]RITPAY<>"" & [F:PIH]RITPAY<>[M]NUM
   ## Facture imputée sur le règlement
   GMESSAGE = mess(16,131,1)-[F:PIH]RITPAY
   mkstat=2 : End
  Endif
  [L]DEVISE = [F:PIH]CUR
 When Default : # Pièce comptable
  Onerrgo ERREUR From CONTROLE
  If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
  Onerrgo
  If GERREUR : GERREUR=0 : mkstat=2 : End : Endif
  Call LECTURE("GAS",VALEUR,[M]VCRTYP(NOL)) From CONTOBJ
  If fstat
   Read [DUD]DUD0(2) = [M]VCRTYP(NOL);VALEUR
   If fstat
    ## Pièce comptable inexistante
    GMESSAGE = mess(3,659,1)-mess(20,117,1)
    mkstat=2 : End
   Else
    [L]DEVISE = [F:DUD]CUR
    [L]SITE = [F:DUD]CPY
   Endif
  Else
   [L]DEVISE = [F:HAE]CUR
   [L]SITE=[F:HAE]CPY
  Endif
  If [L]SITE<>[M]CPY : # Pièce comptable de la societe
   GMESSAGE = mess(3,659,1)-mess(5,117,1)-[L]SITE : mkstat=2
  Endif
Endcase
If find([M]IPTTYP(NOL),1,2)
 If fstat : # Commande client/fournisseur inexistante
  GMESSAGE = mess([M]IPTTYP(NOL),659,1)-mess(20,117,1) : mkstat=2 : End
 Endif
 Call LECTURE("FCY",[L]SITE,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M]CPY
  ## Commande client/fournisseur de la société CPY
  GMESSAGE = mess([M]IPTTYP(NOL),659,1)-mess(5,117,1)-[F:FCY]LEGCPY
  mkstat = 2 : End
 Elsif ([M]FCYOPT=1  & [F:FCY]FINRSPFCY<>[M]FCY)
&    | ([M]FCYOPT=2 & GUSRFCY(1)<>"\" & !find([F:FCY]FINRSPFCY,GUSRFCY(1..GNBAUZ)))
  ## Commande client/fournisseur du site FCY
  GMESSAGE = mess([M]IPTTYP(NOL),659,1)-mess(4,117,1)-[F:FCY]FINRSPFCY
  mkstat = 2 : End
 Endif
Endif
If [M]IPTTYP(NOL)=3
 Call LECTURE("GAS",VALEUR,[M]VCRTYP(NOL)) From CONTOBJ
 If fstat=0 & [F:HAE]FLGREP=2
  ## Pièce de fin d'exercice
  GMESSAGE = mess(20,121,1)
  mkstat = 2 : End
 Endif
Endif
If NOL>0 & [L]DEVISE<>[M]CURVCR(NOL-1) | (NOL = 0 & [M]CURVCR(NOL+1)<>"" & [M]CURVCR(NOL+1)<>DEVISE)
 ## Tous les documents doivent être associés à la même devise"
 GMESSAGE = mess(6,8890,1)
 mkstat = 2 : End
Endif
End


Subprog AP_VCRNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M]DUDNUM(NOL)<>0
 # On vérifie que l'échéance n'est pas en cours de lettrage,
 # pour ne pas la régler une 2ème fois
 Filter [MTB] Where ACCNUM=[M]DUDNUM(NOL) & DUDLIG=[M]DUDLIG(NOL)
 Look [MTB]MTB0 First
 Filter [MTB]
 If !fstat
  ## Echéance en cours de lettrage
  GMESSAGE = mess(70,119,1) : mkstat = 2 : End
 Endif
Endif
End

Subprog B3_VCRNUM(VALEUR)
Variable Char    VALEUR()
Gosub B3_FACCDE
End

Subprog AS_FCYLIN(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND=indice
If VALEUR<>"" & [M]VCRNUM(IND)<>"" : mkstat = 2 : End : Endif
If VALEUR="" & [M]VCRNUM(IND)<>""
 Case [M]IPTTYP(IND)
  When 1 : # Cde cli
   Call LECTURE("SOH",[M]VCRNUM(IND),"") From CONTOBJ
   If fstat=0 : VALEUR=[F:SOH]SALFCY : Endif
  When 2 : # Cde fou
   Call LECTURE("POH",[M]VCRNUM(IND),"") From CONTOBJ
   If fstat=0 : VALEUR=[F:POH]POHFCY : Endif
  When 4 : # Proforma fou
   Call LECTURE("PIH",[M]VCRNUM(IND),"") From CONTOBJ
   If fstat=0 : VALEUR=[F:PIH]FCY : Endif
 Endcase
Elsif VALEUR=""
 VALEUR=[M]FCY
Endif
End

Subprog C_FCYLIN(VALEUR)
Variable Char     VALEUR
Local Integer OK, IND : IND=indice
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
If [F:FCY]LEGCPY<>[M]CPY : # Ce site est dans la société CPY
 GMESSAGE=mess(30,106,1)-[F:FCY]LEGCPY : mkstat=2
Elsif [M]FCYOPT=3 & VALEUR<>[M]FCY & VALEUR<>[M]FCYLIN(IND)
 OK=2 : Call AVERTIR(mess(18,117,1)-[M]FCY-"->"-VALEUR,OK) From GESECRAN
 If OK<>2 : mkstat=2 : Endif :  # Génération OD-sites
Endif
End

Subprog AS_CURVCR(VALEUR)
Variable Char    VALEUR()
Local Integer IND : IND=indice
If VALEUR<>"" & [M]VCRNUM(IND)<>"" : mkstat = 2 : End : Endif
If VALEUR="" & [M]VCRNUM(IND)<>""
 Case [M]IPTTYP(IND)
  When 1 : # Cde cli
   Call LECTURE("SOH",[M]VCRNUM(IND),"") From CONTOBJ
   If fstat=0 : VALEUR=[F:SOH]CUR : Endif
  When 2 : # Cde fou
   Call LECTURE("POH",[M]VCRNUM(IND),"") From CONTOBJ
   If fstat=0 : VALEUR=[F:POH]CUR : Endif
  When 4 : # Proforma tiers fournisseur
   Call LECTURE("PIH",[M]VCRNUM(IND),"") From CONTOBJ
   If fstat=0 : VALEUR=[F:PIH]CUR : Endif
 Endcase
Elsif IND>0 & VALEUR="" : # Toutes les échéances imputées doivent être sur la même devise
 VALEUR = [M]CURVCR(0)
 mkstat = 2
Elsif IND=0 & VALEUR="" & [M]CURVCR(IND+1)=""
 VALEUR = [M]CURCPY
Endif
End

Subprog AS_AMTVCR(VALEUR)
Variable Decimal VALEUR
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
End


Subprog AM_AMTVCR(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Local Integer STAT
Call CONVERT([M]CURVCR(NOL),[M]CURCPY,[M]CURCPY,1,[M]DAT,VALEUR,[M]AMTLOC(NOL),STAT) From TRTDEV
If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> [M]CURCPY (DAT)
 GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-[M]CURCPY-"("+format$("D:"+GFMDAT,[M]DAT)-")"
 mkstat=2 : End
 Endif
Call CONVERT([M]CURVCR(NOL),[M]CURCPY,[M]CURCPY,1,[M]DAT,[M]AMTDEP(NOL),[M]AMTLOCDEP(NOL),STAT) From TRTDEV
If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> [M]CURCPY (DAT)
 GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-[M]CURCPY-"("+format$("D:"+GFMDAT,[M]DAT)-")"
 mkstat=2 : End
Endif
Call CONVERT([M]CURVCR(NOL),GCURSHR,[M]CURCPY,1,[M]DAT,VALEUR,[M]AMTRPT(NOL),STAT) From TRTDEV
If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> GCURSHR (DAT)
 GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-GCURSHR-"("+format$("D:"+GFMDAT,[M]DAT)-")"
 mkstat=2 : End
 Endif
Call CONVERT([M]CURVCR(NOL),GCURSHR,[M]CURCPY,1,[M]DAT,[M]AMTDEP(NOL),[M]AMTRPTDEP(NOL),STAT) From TRTDEV
If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> GCURSHR (DAT)
 GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-GCURSHR-"("+format$("D:"+GFMDAT,[M]DAT)-")"
 mkstat=2 : End
Endif
[M]AMTLOCLIN(NOL) = [M]AMTLOC(NOL)-[M]AMTLOCDEP(NOL)
[M]AMTRPTLIN(NOL) = [M]AMTRPT(NOL)-[M]AMTRPTDEP(NOL)
[M]AMTVCR(NOL) = VALEUR
Affzo TOTPAY
End

Subprog AS_DEP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
If [M:PAH1]SNSDUD(NOL) = -1
 mkstat = 1 : End
Endif
End

Subprog AM_DEP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If VALEUR = ""
 [M]AMTDEP(NOL) = 0
 Local Integer STAT
 Call CONVERT([M]CURVCR(NOL),[M]CURCPY,[M]CURCPY,1,[M]DAT,[M]AMTVCR(NOL),[M]AMTLOC(NOL),STAT) From TRTDEV
 If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> [M]CURCPY (DAT)
  GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-[M]CURCPY-"("+format$("D:"+GFMDAT,[M]DAT)-")"
  mkstat=2 : End
 Endif
 Call CONVERT([M]CURVCR(NOL),[M]CURCPY,[M]CURCPY,1,[M]DAT,[M]AMTDEP(NOL),[M]AMTLOCDEP(NOL),STAT) From TRTDEV
 If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> [M]CURCPY (DAT)
  GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-[M]CURCPY-"("+format$("D:"+GFMDAT,[M]DAT)-")"
  mkstat=2 : End
 Endif
 Call CONVERT([M]CURVCR(NOL),GCURSHR,[M]CURCPY,1,[M]DAT,[M]AMTVCR(NOL),[M]AMTRPT(NOL),STAT) From TRTDEV
 If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> [M]CURCPY (DAT)
  GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-GCURSHR-"("+format$("D:"+GFMDAT,[M]DAT)-")"
  mkstat=2 : End
 Endif
 Call CONVERT([M]CURVCR(NOL),GCURSHR,[M]CURCPY,1,[M]DAT,[M]AMTDEP(NOL),AMTRPTDEP(NOL),STAT) From TRTDEV
 If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> GCURSHR (DAT)
  GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-GCURSHR-"("+format$("D:"+GFMDAT,[M]DAT)-")"
  mkstat=2 : End
 Endif
 [M]AMTLOCLIN(NOL) = [M]AMTLOC(NOL)-[M]AMTLOCDEP(NOL)
 [M]AMTRPTLIN(NOL) = [M]AMTRPT(NOL)-[M]AMTRPTDEP(NOL)
 Affzo TOTPAY
Endif
End

Subprog AS_AMTDEP(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
If [M:PAH1]SNSDUD(NOL) = -1
 mkstat = 1 : End
Endif
End

Subprog AM_AMTDEP(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Local Integer STAT
Call CONVERT([M]CURVCR(NOL),[M]CURCPY,[M]CURCPY,1,[M]DAT,[M]AMTVCR(NOL),[M]AMTLOC(NOL),STAT) From TRTDEV
If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> [M]CURCPY (DAT)
 GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-[M]CURCPY-"("+format$("D:"+GFMDAT,[M]DAT)-")"
 mkstat=2 : End
Endif
Call CONVERT([M]CURVCR(NOL),[M]CURCPY,[M]CURCPY,1,[M]DAT,VALEUR,[M]AMTLOCDEP(NOL),STAT) From TRTDEV
If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> [M]CURCPY (DAT)
 GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-[M]CURCPY-"("+format$("D:"+GFMDAT,[M]DAT)-")"
 mkstat=2 : End
Endif
Call CONVERT([M]CURVCR(NOL),GCURSHR,[M]CURCPY,1,[M]DAT,[M]AMTVCR(NOL),[M]AMTRPT(NOL),STAT) From TRTDEV
If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> [M]CURCPY (DAT)
 GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-GCURSHR-"("+format$("D:"+GFMDAT,[M]DAT)-")"
 mkstat=2 : End
Endif
Call CONVERT([M]CURVCR(NOL),GCURSHR,[M]CURCPY,1,[M]DAT,VALEUR,[M]AMTRPTDEP(NOL),STAT) From TRTDEV
If STAT : # Pas de cours de devises [M]CURVCR(NOL) -> GCURSHR (DAT)
 GMESSAGE=mess(16,114,1)-[M]CURVCR(NOL)-"->"-GCURSHR-"("+format$("D:"+GFMDAT,[M]DAT)-")"
 mkstat=2 : End
Endif
[M]AMTLOCLIN(NOL) = [M]AMTLOC(NOL)-[M]AMTLOCDEP(NOL)
[M]AMTRPTLIN(NOL) = [M]AMTRPT(NOL)-[M]AMTRPTDEP(NOL)
[M]AMTDEP(NOL) = VALEUR
Affzo TOTPAY
End

Subprog AS_RITCOD(VALEUR)
Variable Char    VALEUR()
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
End

Subprog AS_NBDOC
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
End

Subprog AVANT_NBDOC
If find(status,73,75,82) : # Ajout / Insertion / Modif d'une ligne
 [M]OD1=[M]DUDNUM(nolign-1)
 [M]OD2=[M]DUDLIG(nolign-1)
 [M]OVCR=[M]VCRTYP(nolign-1)+"\"+[M]VCRNUM(nolign-1)
Endif
Affzo TOTPAY : Affzo CURECH
End


Subprog APRES_NBDOC
Local Integer I, NOL, RTZ
Local Decimal ARODEV, ARODEV2
If [M:PAH0]TYP = 1
 Gosub CHARGE_RETENUES
 Gosub RAZ_TABRET
 For NOL=0 To NBFAC-1
  Gosub CAL_RETENUES
 Next
 Affzo [M:PAH3]

 ## 2ième passe pour alimenter le total retenues par document appliqué
 For NOL=0 To NBFAC-1
  [M:PAH1]AMTRTZ(NOL) = 0
  For RTZ=0 To [M:PAH3]NBRIT-1
   If TABCODRTZ(NOL,RTZ)<>""
    [M:PAH1]AMTRTZ(NOL) += arr(TABAMT(NOL,RTZ),ARODEV)
   Endif
  Next
 Next
 Affzo [M:PAH1]
 Call LECTURE("TCU",[M:PAH1]CURVCR(0),"") From CONTOBJ
 ARODEV = [F:TCU]CURRND
 Call LECTURE("TCU",GCURSHR,"") From CONTOBJ
 ARODEV2 = [F:TCU]CURRND
 [M:PAH1]TOTRTZ = sum([M:PAH3]RITAMT(0..[M:PAH3]NBRIT-1))
 [M:PAH1]TOTPAY = sigma(indice=0,[M]NBDOC,[M]AMTVCR(indice)*[M]SNSDUD(indice))
 [M:PAH1]TOTPAY -= sigma(indice=0,[M]NBDOC,[M]AMTDEP(indice)*[M]SNSDUD(indice))
 [M:PAH1]TOTPAY -= [M:PAH1]TOTRTZ
 Affzo TOTPAY, TOTRTZ

Else
 Call LECTURE("TCU",[M:PAH1]CURVCR(0),"") From CONTOBJ
 ARODEV = [F:TCU]CURRND
 Call LECTURE("TCU",GCURSHR,"") From CONTOBJ
 ARODEV2 = [F:TCU]CURRND
 [M:PAH1]TOTPAY = sigma(indice=0,[M]NBDOC,[M]AMTVCR(indice)*[M]SNSDUD(indice))
 [M:PAH1]TOTPAY -= sigma(indice=0,[M]NBDOC,[M]AMTDEP(indice)*[M]SNSDUD(indice))
 [M:PAH1]TOTPAY -= sum([M:PAH3]RITAMT(0..[M:PAH3]NBRIT-1))
 [M:PAH1]TOTRTZ = sum([M:PAH3]RITAMT(0..[M:PAH3]NBRIT-1))
 Affzo TOTPAY, TOTRTZ
Endif
End

$CHARGE_RETENUES
Call CHARGE_RETENUES(1,[M:PAH0]CPY,[M:PAH0]TYP,[M:PAH0]NUM,[M:PAH0]DAT,[M:PAH1]VCRNUM,[M:PAH1]DUDNUM,[M:PAH1]DUDLIG,[M:PAH1]NBDOC) From SUBPAHRTZ
Return


$RAZ_TABRET
Local Char    TABCODRTZ(GLONRTZ)(0..dim([M:PAH1]VCRNUM)-1,0..dim([M:PAH3]RITNUM)-1) : # Tableau des codes retenues/document
Local Decimal TABAMT(0..dim([M:PAH1]VCRNUM)-1,0..dim([M:PAH3]RITNUM)-1): # Tableau montants retenues par doc et code retenue
Local Decimal TABAMTRPT(0..dim([M:PAH1]VCRNUM)-1,0..dim([M:PAH3]RITNUM)-1): # Idem TABAMT mais en devise reporting
Local Decimal TABBAS(0..dim([M:PAH1]VCRNUM)-1,0..dim([M:PAH3]RITNUM)-1): # Tableau bases retenues par document et code retenue
Local Decimal TABBASRPT(0..dim([M:PAH1]VCRNUM)-1,0..dim([M:PAH3]RITNUM)-1): # Idem TABBAS mais en devise reporting

Local Decimal TABBASCUM(0..dim([M:PAH3]RITNUM)-1): # Base cumulée (pour retenues Ganancias)
Local Decimal TABRITCUM(0..dim([M:PAH3]RITNUM)-1): # montant retenue cumulée (pour retenues Ganancias)

Local Decimal TABREPRTZ(0..99)
Local Integer NBFAC
Raz TABCODRTZ, TABAMT, TABAMTRPT, TABBAS, TABBASRPT, TABREPRTZ, TABBASCUM, TABRITCUM

For I = 0 To [M:PAH3]NBRIT-1
 [M:PAH3]RITAMT(I)    = 0
 [M:PAH3]RITAMTRPT(I) = 0
 [M:PAH3]RITBAS(I)    = 0
 [M:PAH3]RITBASRPT(I) = 0
Next
NBFAC = find(0,[M:PAH1]IPTTYP(0..dim([M:PAH1]IPTTYP)-1))-1
Return


$CAL_RETENUES
Call CAL_RETENUES(1,[M:PAH0]TYP,[M:PAH0]NUM,[M:PAH0]DAT,[M:PAH0]CPY,[M:PAH0]BPR,NOL+1,[M:PAH1]VCRNUM(NOL),[M:PAH1]DUDNUM(NOL),[M:PAH1]DUDLIG(NOL),[M:PAH1]CURVCR(0),
&                 [M:PAH1]AMTVCR(NOL),NBFAC,TABCODRTZ,TABAMT,TABAMTRPT,TABBAS,TABBASRPT,TABBASCUM,TABRITCUM,TABREPRTZ) From SUBPAHRTZ
Return


Subprog AS_CUR(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
If [M:PAH1]PAM(NOL) = "" : mkstat = 1 : End : Endif
End

Subprog AS_AMTLIN(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M:PAH1]PAM = "" | [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
End

Subprog AM_AMTLIN(VALEUR)
Variable Decimal VALEUR
Local Decimal MT
Local Integer NOLI, STAT, I, INIT
Gosub SETNOL
INIT = 0
## - [M]CUR contient la devise de la ligne de règlement
## - [M]CURLIN2 contient la devise des échéances règlées : on s'est fixé la règle que toutes les échéances de l'ordre
## de paiement ou récibo devaient être associées à la même devise
If [M]CURVCR(0)<>"" : [M]CURLIN2(NOL) = [M]CURVCR(0) : Endif
If [M]CUR(NOL) = [M]CURLIN2(NOL)
 # Devise règlement=devise échéances... => les montants sont identiques(cas simple)
 [M]AMTLIN2(NOL) = VALEUR : INIT = 1
Elsif [M]CUR(NOL) = [M]CURCPY & find(VALEUR,[M]AMTLOCLIN(0..[M]NBDOC-1))
 # Devise règlement=devise société et montant règlement=montant d'une échéance en dev société
 # => Si le montant du règlement est égal au montant d'une ligne d'imputation des documents appliqués en devise société
 # (AMTLOCLIN = montant échéance +/- esc/agio) alors on peut initialiser le montant imputé tiers par le montant
 # de l'échéance +/- l'escompte
 NOLI = find(VALEUR,[M]AMTLOCLIN(0..[M]NBDOC-1))
 [M]AMTLIN2(NOL) = [M]AMTVCR(NOLI-1)-[M]AMTDEP(NOLI-1)
 INIT = 1
Elsif [M]CUR(NOL) = GCURSHR & find(VALEUR,[M]AMTRPTLIN(0..[M]NBDOC-1))
 # Devise règlement=devise reporting et montant règlement=montant d'une échéance en dev société
 NOLI = find(VALEUR,[M]AMTRPT(0..[M]NBDOC-1))
 [M]AMTLIN2(NOL) = [M]AMTVCR(NOLI-1)-[M]AMTDEP(NOLI-1)
 INIT = 1
Endif
If !INIT
 Call CONVERT([M]CUR(NOL),[M]CURLIN2(NOL),[M]CURCPY,1,[M]DAT,VALEUR,[M]AMTLIN2(NOL),STAT) From TRTDEV
 If STAT : # Pas de cours de devises CUR -> CURLIN2 (DAT)
  GMESSAGE=mess(16,114,1)-[M]CUR(NOL)-"->"-[M]CURLIN2(NOL)-"("+format$("D:"+GFMDAT,[M]DAT)-")"
  mkstat=2 : End
 Endif
Endif
End


Subprog AS_AMTLIN2(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M:PAH1]PAM = "" | [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
If [M]AMTLIN(NOL)=0
 VALEUR=0 : mkstat=2 : End
Elsif [M]CUR(NOL) = [M]CURLIN2(NOL)
 mkstat=2 : End
Endif
End

Subprog C_AMTLIN2(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : End : Endif
Gosub SETNOL
Local Decimal MTIPT
If [M]PRCAMTCNV>0
 Local Integer STAT
 Local Decimal MT
 Call CONVERT([M]CUR(NOL),[M]CURLIN2(NOL),[M]CURCPY,1,[M]DAT,[M]AMTLIN(NOL),MTIPT,STAT) From TRTDEV
 If !STAT & abs(VALEUR-MTIPT)>abs(MTIPT*[M]PRCAMTCNV/100)
  STAT=1 : # Ligne NOL : MT1 DEV1 -> MT2 DEV2
  Call AVERTIR(mess(47,116,1)-num$(NOL+1)-":"-num$([M]AMTLIN(NOL))-[M]CUR(NOL)-"->"-num$(MTIPT)-[M]CURLIN2(NOL),STAT) From GESECRAN
  If STAT<>2 : mkstat=2 : Endif
 Endif
Endif
End

Subprog AS_NBLIG
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
End

Subprog AS_PAM(VALEUR)
Variable Char    VALEUR()
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
End


######################################################################################
## Etiquette écran PAYORD2
######################################################################################
Subprog AS_BPAINV(VALEUR)
Variable Char    VALEUR()
Gosub AFFADR
End

Subprog D_BPAINV(VALEUR)
Variable Char    VALEUR()
## On initialisation l'adresse dans l'ordre de paiement de la même manière qu'en facture
## tiers fournisseurs
Call LECTURE("BPR",[M:PAH0]BPR,"") From CONTOBJ
#Recherche de l'adresse de facturation associée au rib de type "fournisseur"
#Bug 53090 : BIDSAC n'a plus d'utilité
#Filter [BID] Where [F:BID]BPATYP=1 & [F:BID]BPANUM=[M:PAH0]BPR & [F:BID]BIDSAC=1
Filter [BID] Where [F:BID]BPATYP=1 & [F:BID]BPANUM=[M:PAH0]BPR
Read [BID]BID0 First
Filter [BID]
If !fstat
 Read [BPA]BPA0 = 1;[M:PAH0]BPR;[F:BID]BPAADD
 If !fstat : VALEUR = [F:BID]BPAADD :  Gosub LECADR : End : Endif
Else
 #Recherche de l'adresse par défaut
 Read [BPA]BPA0 = 1;[M:PAH0]BPR;[F:BPR]BPAADD
 If !fstat : VALEUR = [F:BPR]BPAADD : Gosub LECADR : End : Endif
Endif
End

Subprog C_BPAINV(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<>[M]BPAINV
 Read [BPA]BPA0 = 1;[M:PAH0]BPR;VALEUR
 If fstat
  # Adresse inexistante
  GMESSAGE = mess(10,119,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_BPAINV(VALEUR)
Variable Char    VALEUR()
Gosub LECADR
Gosub AFFADR
End


Subprog AS_CRY(VALEUR)
Variable Char    VALEUR()
Gosub NOADD
End

Subprog AS_CRYNAM(VALEUR)
Variable Char    VALEUR()
Gosub NOADD
End

Subprog AS_POSCOD(VALEUR)
Variable Char    VALEUR()
Gosub NOADD
End

Subprog AS_CTY(VALEUR)
Variable Char    VALEUR()
Gosub NOADD
End

Subprog AS_SAT(VALEUR)
Variable Char    VALEUR()
Gosub NOADD
End

$NOADD
Local Integer I, J
For J=0 To dim([M:PAH2]BPAADDLIG)-1
 If vireblc([M:PAH2]BPAADDLIG(J),2)<>"" : I=1 : Break : Endif
Next J
If !I : mkstat=1 : Endif
Return


$LECADR
Raz [M:PAH2]BPANAM, [M:PAH2]BPAADDLIG
Read [BPA]BPA0 = 1;[M:PAH0]BPR;VALEUR
If !fstat
 Call LECTURE("BPR",[M:PAH0]BPR,"") From CONTOBJ
 For I=0 To min(dim([M:PAH2]BPANAM),dim([F:BPR]BPRNAM))-1
  [M:PAH2]BPANAM(I) = [F:BPR]BPRNAM(I)
 Next I
Endif
For I=0 To min(dim([M:PAH2]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
 [M:PAH2]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
Next I
[M:PAH2]POSCOD = [F:BPA]POSCOD
[M:PAH2]CTY    = [F:BPA]CTY
[M:PAH2]CRY    = [F:BPA]CRY
[M:PAH2]SAT    = [F:BPA]SAT
If [F:BPA]CRYNAM<>"" : [M:PAH2]CRYNAM = [F:BPA]CRYNAM
Else [M:PAH2]CRYNAM="" : Call INIPAYS([F:BPA]CRY,[M:PAH2]CRYNAM) From TRTDIV
Endif
Return

$AFFADR
If !GIMPORT
 Affzo BPANAM, BPAADDLIG, POSCOD, CTY, CRY, CRYNAM
Endif
Return

######################################################################################
## Etiquette écran PAYPTH3 : Champs saisissables uniquement dans les recibos
######################################################################################
Subprog AM_RITAMT(VALEUR)
Variable Decimal VALEUR
If [M:PAH0]TYP = 2
 Gosub SETNOL
 Call LECTURE("TCU",[M:PAH1]CURVCR(0),"") From CONTOBJ
 [M:PAH3]RITAMT(NOL) = VALEUR
 [M:PAH1]TOTRTZ = arr(sum([M:PAH3]RITAMT(0..[M:PAH3]NBRIT)),[F:TCU]CURRND)
 Affzo [M:PAH1]TOTRTZ
 [M:PAH1]TOTPAY = sigma(indice=0,[M:PAH1]NBDOC,[M:PAH1]AMTVCR(indice)*[M:PAH1]SNSDUD(indice))
 [M:PAH1]TOTPAY -= sigma(indice=0,[M:PAH1]NBDOC,[M:PAH1]AMTDEP(indice)*[M:PAH1]SNSDUD(indice))
 [M:PAH1]TOTPAY -= [M:PAH1]TOTRTZ
 Affzo [M:PAH1]TOTPAY
Endif
End



##########
$B3_FACCDE
##########
# Version client / serveur : on ferme et ré-ouvre les fichiers avant et après le tunnel
Local Char VALC2(20)
If zoncou="VCRNUM" : [L]VALC2=toupper(zc) : Else [L]VALC2=[M]VCRNUM(nolign-1) : Endif

Gosub AB3_FACCDE
Call OBJET([L]VALC1,[L]VALC2,[L]VALC3) From GOBJET
Gosub BB3_FACCDE
Return

$AB3_FACCDE
Local Integer K, I, NOL
Local Char    OPT(5), VALC1(20), VALC3(20)
If [L]VALC2="" : mkstat=2 : Return : Endif

NOL=nolign-1
If    [M]VCRTYP(NOL) = [M]BPSTYP : OPT="41235" : # Commandes fournisseurs
Elsif [M]VCRTYP(NOL) = [M]BPCTYP : OPT="31245" : # Commandes clients
Elsif [M]IPTTYP(NOL) = 4         : OPT="2"     : # Proforma
Elsif [M]TYP = 1                 : OPT="21435" : # Pièces comptables et Ordres de paiements
Else                             : OPT="12345" : # Pièces comptables et Recibo
Endif

For I=1 To 5
 Case mid$(OPT,I,1)
  When "1" : # Facture client
   Call LECTURE("BIC",[L]VALC2,"") From CONTOBJ
   If fstat=0 & [F:SIH]GTE=[M]VCRTYP(NOL)
    If [F:SIH]ORIMOD=3
     [L]VALC1 = "BIC"
    Else
     [L]VALC1 = "SIH" : # Tunnel Reglt -> SIH : GBIDC2 ne peut pas être affecté
    Endif
    Break
   Endif
  When "2" : # Facture fournisseur
   Call LECTURE("BIS",[L]VALC2,"") From CONTOBJ
   If fstat=0 & (([M]IPTTYP(NOL)=4 & [F:PIH]INVTYP=5) | ([M]IPTTYP(NOL)<>4 & [F:PIH]GTE=[M]VCRTYP(NOL)))
    If [F:PIH]ORIMOD=3
     [L]VALC1 = "BIS"
    Elsif [F:PIH]ORIMOD=6
     [L]VALC1 = "PIH"
    Endif
    Break
   Endif
  When "3" : # Commande client
   If [M]VCRTYP(NOL)=[M]BPCTYP
    Call LECTURE("SOH",[L]VALC2,"") From CONTOBJ
    If fstat=0
     [L]VALC1 = "SOH" : # Tunnel Reglt -> CCL : GBIDC2 ne peut pas être affecté
     Break
    Endif
   Endif
  When "4" : # Commande fournisseur
   If [M]VCRTYP(NOL)=[M]BPSTYP
    Call LECTURE("POH",[L]VALC2,"") From CONTOBJ
    If fstat=0 & [F:POH]POHTYP=1
     [L]VALC1 = "POH"
     Break
    Endif
   Endif
  When "5" : # Pièce comptable
   Onerrgo ERREUR From CONTROLE
   If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : K=1 : Endif
   Onerrgo
   If !GERREUR
    Call LECTURE("GAS",[L]VALC2,[M]VCRTYP(NOL)) From CONTOBJ
    If fstat=0 : [L]VALC1 = "GAS" :  [L]VALC3=[M]VCRTYP(NOL) : Endif
    If K : Close Local File [HAE] : K=0 : Endif
    If [L]VALC1<>"" : Break : Endif
   Else GERREUR=0
   Endif
 Endcase
Next I
If [L]VALC1<>""
 OFONC1= GFONC1 : GFONC1="GESPAY"
 Gosub AV_OBJET From SUBPAY2
Endif
Return

$BB3_FACCDE
If [L]VALC1<>""
 Gosub AP_OBJET
 GFONC1=OFONC1
 If dim([L]CLECUR)>0
  Gosub OUVRE From =PROGOBJ
  Gosub OUVRE_FIC From SUBPAY3
  Gosub OUVOBJ From GOBJET
  If [L]CLECUR1<>"" : Read [PYH]PYH0 = [L]CLECUR1 : Endif
  Call LEC_CPY([M]CPY) From CPTLEC
  Call LEC_TPY_LEG([F:CPY]LEG,GFONC1) From CPTLEC
 Endif
Endif
mkstat=2
Return

$AV_OBJET
# V140 (CP 20/06/03 ) lié 17966 & 18557
 If dim([L]CLECUR)>0 : Gosub FERME_FIC From SUBPAY3 : Endif
GCONSULT=2
Return

$AP_OBJET
GCONSULT=0
Return


#######################
Subprog LECDUD(NUM,LIG)
#######################
Value Integer NUM,LIG
If [F:DUD]ACCNUM<>NUM | [F:DUD]DUDLIG<>LIG
 Read [DUD]DUD1 = NUM;LIG
Else
 fstat=0
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign -1
Return

Subprog C_BPRPTH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [BPR]BPR0 = VALEUR
 If fstat or [F:BPR]PTHFLG<>2
  # Ce tiers n'est pas un cobrador
  GMESSAGE = mess(17,8890,1)
  mkstat = 2 : End
 Endif
Endif
End

