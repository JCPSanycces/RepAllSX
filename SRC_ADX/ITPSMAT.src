Call IMPRIME("TPSANA","") From ETAT
End

####################################################
## Etat des temps par section
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

#LIPET - 10-01-2017 - X3-18688 - START
#Local Char    PARAM(20) , MATRI(GLONMAT), SITE(GLONFCY), SERVICE(GLONSRV)
Local Char    PARAM(20) , MATRI(GLONEML), SITE(GLONFCY), SERVICE(GLONSRV)
#LIPET - 10-01-2017 - X3-18688 - END
Local Integer I

If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif

If evalue("dim([M:TPS]REFNUM)")>0  : MATRI = [M:TPS]REFNUM  : Endif
If evalue("dim([M:TPSJ]REFNUM)")>0 : MATRI = [M:TPSJ]REFNUM : Endif

If evalue("dim([M:TPS]CTRNUM)")>0  : SITE = [M:TPS]FCY  : Endif
If evalue("dim([M:TPSJ]CTRNUM)")>0 : SITE = [M:TPSJ]FCY : Endif

If evalue("dim([M:TPS]CTRNUM)")>0  : SERVICE = [M:TPS]SRV  : Endif
If evalue("dim([M:TPSJ]CTRNUM)")>0 : SERVICE = [M:TPSJ]SRV : Endif


Read [FCY]FCY0 = SITE
Call SETPARAM("matdeb",NBPAR,PARAMETRE,MATRI) From ETAT
Call SETPARAM("matfin",NBPAR,PARAMETRE,MATRI) From ETAT
Call SETPARAM("sitedeb",NBPAR,PARAMETRE,SITE) From ETAT
Call SETPARAM("sitefin",NBPAR,PARAMETRE,SITE) From ETAT
Call SETPARAM("service",NBPAR,PARAMETRE,SERVICE) From ETAT
Call SETPARAM("societe",NBPAR,PARAMETRE,[F:FCY]LEGCPY) From ETAT
PARAM = "0" : Call SETPARAM("regul",NBPAR,PARAMETRE,PARAM) From ETAT

Call IMPRIME(NBPAR,PARAMETRE) From ITPSSAL
End


Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

