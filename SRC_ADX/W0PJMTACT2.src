#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTACT2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBPJTAC2
mkstat = 0
zoncou = "NBPJTAC2"
indice = 0
status = 1
zoncou = "NBPJTAC2"
If varmode([M]NBPJTAC2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBPJTAC2" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBPJTAC2
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBPJTAC2 = nolign
   status = 75
   Call SAI_NBPJTAC2(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBPJTAC2 From SUBPJTAC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBPJTAC2" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBPJTAC2(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBPJTAC2
mkstat = 0
zoncou = "NBPJTAC2"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBPJTAC2 From SUBPJTAC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBPJTAC2" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone OPENUMLNK
mkstat = 0
zoncou = "OPENUMLNK"
WNUM = [M]OPENUMLNK(indice)
If varmode([M]OPENUMLNK,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPENUMLNK" : Gosub ACTION From =IMPTRT
 Endif
 If [M]OPENUMLNK(indice)=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "OPENUMLNK" : GZNUM = 1002420 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If [M]OPENUMLNK(indice)<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "OPENUMLNK" : GZNUM = 1002420 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]OPENUMLNK(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_OPENUMLNK([M]OPENUMLNK(indice)) From SUBPJTAC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "OPENUMLNK" : GZNUM = 1002420 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone OPELNKTYP
mkstat = 0
zoncou = "OPELNKTYP"
IMPENT = [M]OPELNKTYP(indice)
WNUM = IMPENT
If varinit([M]OPELNKTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]OPELNKTYP,indice)=0
 [M]OPELNKTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPELNKTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPELNKTYP(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "OPELNKTYP" : GZNUM = 10108 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_OPELNKTYP(IMPENT) From SUBPJTAC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "OPELNKTYP" : GZNUM = 10108 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]OPELNKTYP(indice) = IMPENT

## Zone OPELNKCSTR
mkstat = 0
zoncou = "OPELNKCSTR"
IMPENT = [M]OPELNKCSTR(indice)
WNUM = IMPENT
If varinit([M]OPELNKCSTR,indice)=0
 IMPENT = 1
Endif
If varmode([M]OPELNKCSTR,indice)=0
 [M]OPELNKCSTR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPELNKCSTR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPELNKCSTR(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "OPELNKCSTR" : GZNUM = 1002411 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_OPELNKCSTR(IMPENT) From SUBPJTAC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "OPELNKCSTR" : GZNUM = 1002411 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]OPELNKCSTR(indice) = IMPENT

## Zone OPELNKLAG
mkstat = 0
zoncou = "OPELNKLAG"
WNUM = [M]OPELNKLAG(indice)
If varmode([M]OPELNKLAG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPELNKLAG" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]OPELNKLAG(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_OPELNKLAG([M]OPELNKLAG(indice)) From SUBPJTAC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "OPELNKLAG" : GZNUM = 1003273 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone STRDAT
mkstat = 0
zoncou = "STRDAT"
WDATE = [M]STRDAT(indice)
If varmode([M]STRDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STRDAT" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]STRDAT(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_STRDAT([M]STRDAT(indice)) From SUBPJTAC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 1805 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ENDDAT
mkstat = 0
zoncou = "ENDDAT"
WDATE = [M]ENDDAT(indice)
If varmode([M]ENDDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENDDAT" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]ENDDAT(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_ENDDAT([M]ENDDAT(indice)) From SUBPJTAC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBPJTAC2
mkstat = 0
zoncou = "NBPJTAC2"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMTACT2"
Return

