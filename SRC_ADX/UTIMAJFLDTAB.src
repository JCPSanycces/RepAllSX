#<AdxTL>@(#)6.0.0.0 $Revision$
Call GENE
End

GBIDC1 = func SUBADC.CNVMIL("1283956090140")
Infbox GBIDC1
GBIDC2 = func CNVTIM([08/09/2010],(14*3600)+(28*60)+10)
Infbox GBIDC2
GBIDC1 = func SUBADC.CNVMIL(GBIDC2)
Infbox GBIDC1
End

#----------------------------------------------------------------------------------------#
# Mise à jour des champs timestamp et uid dans les tables
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Update supervisor field on file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2] Where DOSSIER=GDOSX3
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#Gosub MAJFLD
End

#-------------------#
$MAJFLD

Local Integer  I , K , T , UPD , TIM , ARRET , CD , CT , UD , UT , ID , CS , US , ER
Local Integer  NEWLIG , MAXFIL , NBTAB , UPDUID, NBTRT
Local Char     TABTAB(GLONATB)(1..3000) , DAT(30)
Local Char     OTRP(GLONADC) , OTRL(GLONASU)
Local Datetime DATTIM

Call ECR_TRACE("UTIMAJFLDTAB : Update new fields on folder"-DOSSIER,0) From GESECRAN

If DOSSIER=nomap
 Local File ATABLE [ATB] , ATABZON [ATZ] , ATYPE [ATY]
Else
 Local File =DOSSIER+".ATABLE" [ATB] , =DOSSIER+".ATABZON" [ATZ] , =DOSSIER+".ATYPE"  [ATY]
Endif

# New fields

Gosub SET_FLDSYS

# Repérage des tables avec les nouveaux champs

NBTAB = 0

For [ATB]CODFIC Where MODULE=1
& and find(CODFIC,"ADOCUMENT","ADOCFNC","ADOCFLD","ADOCCLB","ADOCBLB",
&          "ABATRQT","ABATRQTL","ACCES","ADOVALAUS",
&          "AELT","AELTLINK","AESPION","AFCTFCY",
&          "ALINK",
&          "ALISTEC","ALISTED","ALISTEH","ALISTEL","ALISTER","ALISTET",
&          "ALOGIN","ALSTRD",
&          "AMENUSER","AMSKACT","AMSKPAR","AMSKZON",
&          "AOBJEXTD","APLSTD","AREPORTM",
&          "ATABZON","ATEXTE","ATEXTRA","ATMPTRA",
&          "AUDITH","AUDITL","AUSRSTA",
&          "AWINBOUT","AWINPAR",
&          "AWRKHISDES","AWRKHISMES","AWRKHISSUI",
&          "POSCOD")=0
 Call AFF_BOITE([F:ATB]CODFIC,NBTAB,ARRET) From GESECRAN
 For I=1 To dim(FLDSYS)
  If FLDSYS(I)<>""
   Read [ATZ]CODZONE=[F:ATB]CODFIC;FLDSYS(I)
   If !fstat
    If [F:ATB]TYPFIC<>3 or DOSSIER=GDOSX3
     If !find([F:ATB]CODFIC,TABTAB) & filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",DOSSIER),0)>0
      NBTAB += 1
      TABTAB(NBTAB) = [F:ATB]CODFIC
     Endif
    Endif
   Endif
  Endif
 Next I
Next ATB

MAXFIL = NBTAB

Close Local File

# Mise à jour des champs time stamp à partir des CREDAT/UPDDAT

Call OUVRE_BOITE("Update new fields"-DOSSIER,0) From GESECRAN
Call SET_BOITE("",MAXFIL) From GESECRAN

NBTAB = 0

# Désactivation de la mise à jour automatique des champs "timestamp" par le moteur

If dim([S]adxtrp)>0 & [S]adxtrp<>""
 OTRP = [S]adxtrp
 OTRL = [S]adxtrl
 [S]adxtrp = ""
 [S]adxtrl = ""
Endif

If DOSSIER=nomap
 Local File ATABZON [ATZ]
Else
 Local File =DOSSIER+".ATABZON" [ATZ]
Endif

For I=1 To MAXFIL
 TABLE = TABTAB(I)
 NBTAB += 1
 Raz CS , US , CD , CT , UD , UT , ID
 Read [ATZ]CODZONE=TABLE;"CREDATTIM"
 If !fstat
  CS = 1
  Read [ATZ]CODZONE=TABLE;"UPDDATTIM"
  If !fstat
   US = 1
   Read [ATZ]CODZONE=TABLE;"CREDAT"
   If !fstat
    CD = 1
    Read [ATZ]CODZONE=TABLE;"CRETIM"
    If !fstat : CT = 1 : Endif
   Endif
   Read [ATZ]CODZONE=TABLE;"UPDDAT"
   If !fstat
    UD = 1
    Read [ATZ]CODZONE=TABLE;"UPDTIM"
    If !fstat : UT = 1 : Endif
   Endif
  Endif
 Endif
 Read [ATZ]CODZONE=TABLE;"AUUID"
 If !fstat : ID = 1 : Endif
 If CD or CT or UD or UT or ID
  Call AFF_BOITE(TABLE,NBTAB,ARRET) From GESECRAN
  If DOSSIER=nomap
   Local File =TABLE [AAA_]
  Else
   Local File =DOSSIER+"."+TABLE [AAA_]
  Endif
  NBTRT=0
  Trbegin [AAA_]
   For [AAA_]
    UPD = 0
    If (CD or (CD & CT)) & [F:AAA_]CREDAT>[01/01/1970]
     T = type([F:AAA_]CREDATTIM)
     If (T=526 & [F:AAA_]CREDATTIM=gdatetime$("")) or (T>0 & T<>526 & [F:AAA_]CREDATTIM="")
      If CT
       Onerrgo ER
       TIM = [F:AAA_]CRETIM
       ER = 0
       Onerrgo
       If ER : TIM = 0 : Endif
      Else
       TIM = 0
      Endif
      If T=526
       [F:AAA_]CREDATTIM = gdatetime$(func CNVDATTIM([F:AAA_]CREDAT,TIM))
      Else
       [F:AAA_]CREDATTIM = func CNVTIM([F:AAA_]CREDAT,TIM)
      Endif
      UPD = 1
     Endif
    Endif
    If (UD or (UD & UT)) & [F:AAA_]UPDDAT>[01/01/1970]
     T = type([F:AAA_]UPDDATTIM)
     If (T=526 & [F:AAA_]UPDDATTIM=gdatetime$("")) or (T>0 & T<>526 & [F:AAA_]UPDDATTIM="")
      If UT
       ER = 0
       Onerrgo ER
       TIM = [F:AAA_]UPDTIM
       Onerrgo
       If ER : TIM = 0 : Endif
      Else
       TIM = 0
      Endif
      If T=526
       [F:AAA_]UPDDATTIM = gdatetime$(func CNVDATTIM([F:AAA_]UPDDAT,TIM))
      Else
       [F:AAA_]UPDDATTIM = func CNVTIM([F:AAA_]UPDDAT,TIM)
      Endif
      UPD = 1
     Endif
    Endif
    If US
     T = type([F:AAA_]UPDDATTIM)
     If T>0
      If T=526
       If num$([F:AAA_]UPDDATTIM)=num$(gdatetime$("")) & num$([F:AAA_]CREDATTIM)<>num$(gdatetime$(""))
        [F:AAA_]UPDDATTIM = [F:AAA_]CREDATTIM
        UPD = 1
       Elsif [F:AAA_]UPDDATTIM<[F:AAA_]CREDATTIM
        DATTIM = [F:AAA_]CREDATTIM
        [F:AAA_]CREDATTIM = [F:AAA_]UPDDATTIM
        [F:AAA_]UPDDATTIM = DATTIM
        UPD = 1
       Endif
      Else
       If [F:AAA_]UPDDATTIM="" & [F:AAA_]CREDATTIM<>""
        [F:AAA_]UPDDATTIM = [F:AAA_]CREDATTIM
        UPD = 1
       Elsif [F:AAA_]UPDDATTIM<[F:AAA_]CREDATTIM
        DAT = [F:AAA_]CREDATTIM
        [F:AAA_]CREDATTIM = [F:AAA_]UPDDATTIM
        [F:AAA_]UPDDATTIM = DAT
        UPD = 1
       Endif
      Endif
     Endif
    Endif
    If ID & dim([F:AAA_]AUUID)>0
     If type([F:AAA_]AUUID)=525
      ER = 0
      K = 0
      Onerrgo ER
      If [F:AAA_]AUUID=NullUuid : # Uuident
       [F:AAA_]AUUID = getUuid
       K = 1
      Endif
      Onerrgo
      If !ER & K=1
       UPD = 1
      Elsif ER & num$([F:AAA_]AUUID)="00000000-0000-0000-0000-000000000000" : # Uuident
       [F:AAA_]AUUID = getUuid
       UPD = 1
      Endif
     Elsif [F:AAA_]AUUID=""
      [F:AAA_]AUUID = uuid$
      UPD = 1
     Endif
    Endif
    If UPD
     Rewrite [AAA_]
     If fstat
      Call ERREUR(TABLE,2) From DOSDIC
     Endif
     NBTRT+=1
    Endif
   Next AAA_
  Commit
  Close Local File [AAA_]
  Call ECR_TRACE(TABLE-": fields updated."-num$(NBTRT)+" records processed.",0) From GESECRAN
 Endif
Next I

If dim([S]adxtrp)>0 & OTRP<>""
 [S]adxtrp = OTRP
 [S]adxtrl = OTRL
Endif

Call FERME_BOITE From GESECRAN

Close Local File

Return

#----------------#
$ER
ER = errn
Resume

#----------------#
$SET_FLDSYS
Local Integer NBFLD , MAXFLD
MAXFLD = 3
Local Char    FLDSYS(GLONAVA)(1..MAXFLD) , TYPFLD(GLONATY)(1..MAXFLD)
Local Char    LNKFLD(GLONATB)(1..MAXFLD)
Local Integer INTFLD(1..MAXFLD) , NBFLD , ANUFLD(1..MAXFLD)
NBFLD = 0
While NBFLD<dim(FLDSYS)
 NBFLD += 1
 Case NBFLD
  When 1 : FLDSYS(NBFLD) = "CREDATTIM" : TYPFLD(NBFLD) = "ADATIM"
  When 2 : FLDSYS(NBFLD) = "UPDDATTIM" : TYPFLD(NBFLD) = "ADATIM"
  When 3 : FLDSYS(NBFLD) = "AUUID"     : TYPFLD(NBFLD) = "AUUID"
 Endcase
 If clalev([F:ATY])>0
  Call LECTURE("ATY",TYPFLD(NBFLD),"") From CONTOBJ
  INTFLD(NBFLD) = [F:ATY]INTITTYP
 Endif
Wend
Return

#------------------------------------------------#
# Conversion date$ et time -> timestamp
#------------------------------------------------#

Funprog CNVTIM(DAT,TIM)
Value Date    DAT
Value Integer TIM
Local Integer J
Local Decimal T
If DAT<[01/01/1970]
 End ""
Endif
J = DAT-[01/01/1970]
T = J*24*3600*1000
If TIM>0 & TIM<24*3600
 T += TIM*1000
Endif
End num$(T)

Funprog CNVDATTIM(DAT,TIM)
Value Date    DAT
Value Integer TIM
Local Char DT(30)
Local Integer H , M , S
If DAT<>[0/0/0]
 DT = format$("D:YYYY[-]MM[-]DD",DAT)
Else
 DT = "0000-00-00"
Endif
DT += "T"
If TIM<>0
 H = int(TIM/3600)
 M = int(mod(TIM,3600)/60)
 S = mod(TIM,60)
 DT += num$(H)+":"+num$(M)+":"+num$(S)
Else
 DT += "00:00:00"
Endif
DT += "Z"
End num$(DT)
