#-----------------------------------
# DIVFOR : Divers module Formation
#-----------------------------------
End

#**
#* Fonction qui indique si le stage reçu en paramètre est un stage fictif.
#* Elle renvoie 2 (Oui) si le stage est fictif, elle renvoie 1 (Non) si le stage
#* n'est pas fictif.
#*
#* @param P_STAGE
#*!
Funprog STAGE_NONDEF(P_STAGE)
Value Char P_STAGE
  If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
  Local Integer FLAG_NONDEF : FLAG_NONDEF = 1 # Non

  Read [F:STG]STG0 = P_STAGE
  If !fstat and [F:STG]FICTI = 2 Then
    FLAG_NONDEF = 2 # Oui
  Endif
End FLAG_NONDEF

#**
#* Fonction qui contrôle si le stage reçu en paramètre est un stage fictif.
#* Si oui, renseignement du message d'anomalie.
#*
#* @param P_STAGE
#*!
Subprog CTL_STG_NON_DEF(P_STAGE)
Value Char P_STAGE

  If func STAGE_NONDEF(P_STAGE) = 2 Then
    mkstat = 2
    # Vous ne pouvez pas saisir ce stage car il est fictif
    GMESSAGE = mess(164,10717,1)
  Endif
End

#**
#* Fonction qui renvoie le code du stage fictif
#*!
Funprog GET_STG_NON_DEF()
  Local Char L_STAGE_NON_DEF(GLONSTG)
  If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
  # Recherche s'il y a un stage fictif
  Filter [F:STG] Where FICTI=2
  Read [F:STG]STG0 First
  If !fstat Then
    L_STAGE_NON_DEF = [F:STG]COD
  Endif
  Filter [F:STG]
End L_STAGE_NON_DEF

#**
#* Fonction qui renvoie si une demande de formation DIF a fait l'objet d'un workflow
#*
#* @param P_DEMNUM : demande de formation recherchée
#* @param P_REFNUM : matricule recherché
#* @param P_CTRNUM : contrat recherché
#*!
Funprog NO_WKF(P_DEMNUM, P_REFNUM, P_CTRNUM)
Value Char P_DEMNUM, P_REFNUM, P_CTRNUM

  Local Integer NB_TROUVE
  If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif

  # Recherche des workflows de la gestion d'objet :
  # Type d'événement = Objet, Code événement = DEM, Code workflow = DEMDIF
  # pour la demande, le matricule et le contrat recherchés
  Filter [F:AWS] Where TYPEVT  = 2
&                  and CODEVT  = "DEM"
&                  and CODWRK  = "DEMDIF"
&                  and VALCTX1 = P_DEMNUM
&                  and VALCTX2 = P_REFNUM
&                  and VALCTX3 = P_CTRNUM
  NB_TROUVE = rowcount([F:AWS])
  Filter [F:AWS]

  If NB_TROUVE = 0 Then
    # Recherche des workflows manuels :
    # Type d'événement = Manuel, Code workflow = DEMDIFMAN
    # pour la demande, le matricule et le contrat recherchés
    Filter [F:AWS] Where TYPEVT  = 10
&                    and CODWRK  = "DEMDIFMAN"
&                    and VALCTX1 = P_DEMNUM
&                    and VALCTX2 = P_REFNUM
&                    and VALCTX3 = P_CTRNUM
    NB_TROUVE = rowcount([F:AWS])
    Filter [F:AWS]
  Endif

End (NB_TROUVE = 0)

