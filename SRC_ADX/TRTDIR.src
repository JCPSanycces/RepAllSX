################################################################################
## Routines TRTDIR2
################################################################################
$SAUVE_VALEURS
GOK=1
Trbegin [VLA]
#JOJAC - 2016-04-18 - REQ114309 US119 - START
 If func AFNC.ACTIV("KSA")>0
  Local Integer ISCUEAMT : ISCUEAMT = 0

  If dim([DIA]CUEAMT) > 0
   If [DIA]CUEAMT <> 2 : ISCUEAMT = 1 : Endif
  Endif

  If ISCUEAMT = 1
    For nolign=1 To [M:DIR]BPAG
   #LIPET - 2017-06-12 - X3-44477 - START
   #Readlock[VLA]VLA0= 4;"";"";"";[M:DIR]MAT(nolign-1);[M:DIR]PYRDAT(nolign-1);VALEUR;[M:DIR]BUL(nolign-1)
   Readlock[VLA]VLA0= 4;GCURLEG;"";"";[M:DIR]MAT(nolign-1);[M:DIR]PYRDAT(nolign-1);[M:DIR]VARCOD(nolign-1);[M:DIR]BUL(nolign-1)
   #LIPET - 2017-06-12 - X3-44477 - END
     If fstat=0
      Raz [F:VLA]VARVAL
      Rewrite [F:VLA]
     Endif
    Next
  Endif
 Else
 #91472 - Consolidation des bulletins
  For nolign=1 To [M:DIR]BPAG
   #LIPET - 2017-06-12 - X3-44477 - START
   #Readlock[VLA]VLA0= 4;"";"";"";[M:DIR]MAT(nolign-1);[M:DIR]PYRDAT(nolign-1);VALEUR;[M:DIR]BUL(nolign-1)
   Readlock[VLA]VLA0= 4;GCURLEG;"";"";[M:DIR]MAT(nolign-1);[M:DIR]PYRDAT(nolign-1);[M:DIR]VARCOD(nolign-1);[M:DIR]BUL(nolign-1)
   #LIPET - 2017-06-12 - X3-44477 - END
    If fstat=0
      Raz [F:VLA]VARVAL
      Rewrite [F:VLA]
    Endif
  Next
 Endif
#JOJAC - 2016-04-18 - REQ114309 US119 - END

 For nolign=1 To [M:DIR]BPAG
 #LIPET - 2017-06-12 - X3-44477 - START
 #Readlock[VLA]VLA0= 4;"";"";"";[M:DIR]MAT(nolign-1);[M:DIR]PYRDAT(nolign-1);VALEUR;[M:DIR]BUL(nolign-1)
 Readlock[VLA]VLA0= 4;GCURLEG;"";"";[M:DIR]MAT(nolign-1);[M:DIR]PYRDAT(nolign-1);[M:DIR]VARCOD(nolign-1);[M:DIR]BUL(nolign-1)
 #LIPET - 2017-06-12 - X3-44477 - END
  If fstat=0
  #JOJAC - 2016-04-18 - REQ114309 US119 - START
  # [F:VLA]VARVAL=[M:DIR]VALEUR(nolign-1)
  [F:VLA]VARVAL+=[M:DIR]VALEUR(nolign-1)
  #JOJAC - 2016-04-18 - REQ114309 US119 - END
   Rewrite [F:VLA]
  Else
   Raz [F:VLA]
   [F:VLA]TYP    = 4
   [F:VLA]BUL    = [M:DIR]BUL(nolign-1)
   [F:VLA]EMP    = [M:DIR]MAT(nolign-1)
   [F:VLA]DAT    = [M:DIR]PYRDAT(nolign-1)
   [F:VLA]VARCOD = [M:DIR]VARCOD(nolign-1)
   [F:VLA]VARVAL = [M:DIR]VALEUR(nolign-1)
   [F:VLA]BUL    = [M:DIR]BUL(nolign-1)
   Write [F:VLA]
  Endif
  If fstat<>0
   GOK = 0 : Call FSTA("VLA") From GLOCK : Break
  Endif
  Readlock [VEP]VEP5=[M:DIR]BUL(nolign-1)
  If !fstat
   [F:VEP]STA = 1
   Rewrite [F:VEP]
  Endif
  If fstat<>0
   GOK = 0 : Call FSTA("VEP") From GLOCK : Break
  Endif
 Next
 If GOK<1
  Goto AB_TR :  Return
 Endif
Commit
Return

$AB_TR
Rollback
Return

################################################################################
## Etiquettes TRTDIR2
################################################################################

Subprog D_MAT(VALEUR)
Variable Char    VALEUR()
 If nolign-1>0
  VALEUR=[M:DIR]MAT(nolign-2)
 Endif
 Effzo [M:DIR]STA(nolign-1)
End

Subprog C_MAT(VALEUR)
Variable Char    VALEUR()
Read [F:ID]ID0 = VALEUR
If !fstat
 [M:DIR]EMPDES(nolign-1)=[F:ID]NAM+" "+[F:ID]SRN
 Affzo [M:DIR]EMPDES(nolign-1)
Endif
End

Subprog AM_MAT(VALEUR)
Variable Char    VALEUR()
Local Char MATRI(GLONEML)
If clalev([F:VEP])=0 : Local File VALEMP [VEP] : Endif
If [F:ID]FLGMULCTR<>2
 Filter [VEP] Where EMP=VALEUR
 Read [VEP]VEP0 Last
 If fstat>2 or [F:VEP]PST>1 or [F:VEP]RVS=2
&  or [F:VEP]FLGLOCK=2 : # Verrouillé US 2022 65062
  Filter [VEP]
  GMESSAGE = mess(41,10702,1) : # Pas de paye en cours pour ce salarié
  mkstat = 2 : End
 Else
  MATRI = VALEUR
  Gosub CHARGE
  Filter [VEP]
  If mkstat=2 : End: Endif
 Endif
Endif
Call GRISE_CTRNUM([F:ID]FLGMULCTR)
End

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:DIR]CTR(nolign-1)
Else
 Diszo [M:DIR]CTR(nolign-1)
Endif
End

$CHARGE
Local Integer OK
Local Char    SYMBOLE (80)

## Contrôle des critères
If [M:DIA]ALLCPY<>2  #société
 Read [FCY]FCY0=[F:VEP]FCY
 If fstat | [F:FCY]LEGCPY<>[M:DIA]CPY
  # Salarié appartenant au site...
  GMESSAGE=mess(48,10702,1)-[F:VEP]FCY : mkstat=2 : Return
 Endif
Endif

If [M:DIA]ALLFCY<>2  #site
 If [F:VEP]FCY<>[M:DIA]FCY
  # Salarié appartenant au site...
  GMESSAGE=mess(48,10702,1)-[F:VEP]FCY : mkstat=2 : Return
 Endif
Endif

If [M:DIA]ALLSRV<>2  #service
 If [F:VEP]SRV<>[M:DIA]SRV
  # Salarié appartenant au service...
  GMESSAGE=mess(51,10702,1)-[F:VEP]SRV : mkstat=2 : Return
 Endif
Endif

If [M:DIA]ALLPRF<>2  #profil
 If [F:VEP]PRF<>[M:DIA]PRF
  # Salarié ayant pour profil...
  GMESSAGE=mess(52,10702,1)-[F:VEP]PRF : mkstat=2 : Return
 Endif
Endif

If [M:DIA]ALLPRF<>2  #profil
 If [F:VEP]PRF<>[M:DIA]PRF
  # Salarié ayant pour profil...
  GMESSAGE=mess(52,10702,1)-[F:VEP]PRF : mkstat=2 : Return
 Endif
Endif

#JOJAC - 2016-04-18 - REQ114309 US119 - START
#If [F:VEP]STA>1 : #Déjà calculé ou imprimé
# If nolign-1>0
#  If !find(MATRI,[M:DIR]MAT(0..nolign-2),[M:DIR]MAT(nolign..[M:DIR]BPAG-1))
[L]OK=0
If [F:VEP]STA>1  & [M:DIR]CTRDAT(nolign-1)<>[0/0/0]: #Déjà calculé ou imprimé & contrat ok
 If nolign-1>0
  If !find(MATRI,[M:DIR]MAT(0..[M:DIR]BPAG))
#JOJAC - 2016-04-18 - REQ114309 US119 - END
# Bulletin déjà calculé pour cette période, voulez-vous poursuivre ?
   OK=2 : Call OUINON(mess(15,10703,1),OK) From GESECRAN
  Else
   OK=2
  Endif
 Else
  OK=2 : Call OUINON(mess(15,10703,1),OK) From GESECRAN
 Endif
 If OK<>1 : #oui
  [M:DIR]PYRDAT(nolign-1) = [F:VEP]PYRDAT
  [M:DIR]BUL(nolign-1)    = [F:VEP]BUL
  [M:DIR]STA(nolign-1)    = [F:VEP]STA
  [M:DIR]CTR(nolign-1)    = [F:VEP]CTRNUM
  [M:DIR]CTRDAT(nolign-1) = [F:VEP]CTRDAT
  Affzo [M:DIR]STA(nolign-1)
  Affzo [M:DIR]CTR(nolign-1)
  Affzo [M:DIR]CTRDAT(nolign-1)
 Else
  Effzo [M:DIR]MAT(nolign-1)
  Effzo [M:DIR]EMPDES(nolign-1)
  Effzo [M:DIR]STA(nolign-1)
  Effzo [M:DIR]CTR(nolign-1)    :#DLE : fix pb payslip already calculated
  Effzo [M:DIR]CTRDAT(nolign-1) :#DLE : fix pb payslip already calculated
  Effzo [M:DIR]VARCOD(nolign-1) :#DLE : fix pb payslip already calculated
  Effzo [M:DIR]VALEUR(nolign-1) :#DLE : fix pb payslip already calculated
  mkstat=2
  SUIZON=[M:DIR]MAT(nolign-1)
  Return
 Endif
Else
 [M:DIR]PYRDAT(nolign-1) = [F:VEP]PYRDAT
 [M:DIR]BUL(nolign-1)    = [F:VEP]BUL
 [M:DIR]STA(nolign-1)    = [F:VEP]STA
 [M:DIR]CTR(nolign-1)    = [F:VEP]CTRNUM
 [M:DIR]CTRDAT(nolign-1) = [F:VEP]CTRDAT
 Affzo [M:DIR]STA(nolign-1)
 Affzo [M:DIR]CTR(nolign-1)
 Affzo [M:DIR]CTRDAT(nolign-1)
Endif
Filter [VEP]

## Verrou
Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE
Lock = SYMBOLE
If fstat
 GMESSAGE = mess(10,100,1) : # Modif en cours sur autre poste
 mkstat = 2 : Return
Endif

##Aide à la saisie
If ([M:DIR]VARCOD(nolign-1))=""
  If (nolign-1)=0
   Filter [VRA] Where FLGEMP=2 and LEG=GCURLEG:#Variable de type salarié
   Read [VRA]VRA0 First
   If fstat=0
    [M:DIR]VARCOD(nolign-1)=[F:VRA]COD
    Affzo [M:DIR]VARCOD(nolign-1)
   Endif
   Filter[VRA]
  Else
   If MATRI=[M:DIR]MAT(nolign-2)
    Filter [VRA] Where FLGEMP=2 and LEG=GCURLEG :#Variable de type salarié
    Read [VRA]VRA0 Next
    If fstat=0
     [M:DIR]VARCOD(nolign-1)=[F:VRA]COD
     Affzo [M:DIR]VARCOD(nolign-1)
    Endif
    Filter [VRA]
   Else
    [M:DIR]VARCOD(nolign-1)= [M:DIR]VARCOD(nolign-2)
    Affzo [M:DIR]VARCOD(nolign-1)
   Endif
  Endif
Endif
Return

Subprog D_CTR(VALEUR)
Variable Char    VALEUR()
If nolign-1>0 & [M:DIR]MAT(nolign-2)=[M:DIR]MAT(nolign-1)
 VALEUR=[M:DIR]CTR(nolign-2)
Endif
End

Subprog AS_CTR(VALEUR)
Variable Char    VALEUR()

If [M:DIR]CTR(nolign-1)=""
 #Sauvegarde de la leg avant appel à la sélection,
 #car si pas de contrat, la fonction de sélection la remet à vide.
 Gosub SAVE_GCURLEG From TOOLSHRLEG
 Call SELCTR([M]MAT(nolign-1),GMOIPAY,eomonth(GMOIPAY),VALEUR) From DIVPAYE
 #On restaure la leg.
 Gosub RESTAURE_GCURLEG From TOOLSHRLEG
Endif
End

Subprog C_CTR(VALEUR)
Variable Char    VALEUR()
Local Char MATRI(GLONEML)

Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
If [F:FCY]LEG<>GCURLEG Then
  GMESSAGE=mess(24,10715,1)-GCURLEG : # Le contrat doit appartenir à un site de la législation
  mkstat=2 : End
Endif

If clalev([F:VEP])=0 : Local File VALEMP [VEP] : Endif
MATRI = [M:DIR]MAT(nolign-1)
Filter [VEP] Where EMP=MATRI & CTRNUM=VALEUR
Read [VEP]VEP0 Last
If fstat>2 or [F:VEP]PST>1 or [F:VEP]RVS=2
&  or [F:VEP]FLGLOCK=2 : # Verrouillé US 2022 65062
 Filter [VEP]
 GMESSAGE = mess(41,10702,1) : # Pas de paye en cours pour ce salarié
 mkstat = 2 : End
Else
 Gosub CHARGE
 Filter [VEP]
 If mkstat=2 : End: Endif
Endif
End

Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
Local Shortint NUMLIGN
# 28071
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
# contrôle code d'accès
If VALEUR<>[M]VARCOD(nolign-1) & [F:VRA]CODACC<>"" & GUSRACS<>2
 # 28071
 Read [ACC]CODACC = GUSER;[F:VRA]CODACC
 If fstat or [F:ACC]EXEC<>2
  GMESSAGE = mess(41,10703,1)-VALEUR : # Accès interdit à la variable
  mkstat = 2 : End
 Endif
Endif
If [F:VRA]CODACT<>""
 Read [ACV]CODACT = [F:VRA]CODACT
 If fstat or [F:ACV]FLACT<>2
  GMESSAGE = VALEUR-":"-mess(42,10703,1) : # Variable inactive
  mkstat = 2 : End
 Endif
Endif

#Affectation du format
Read [VRA]VRA0 = GCURLEG;VALEUR
Read [ADI]CODE = 10337;[F:VRA]PAGEMP
[M:DIR]NBRDEC(nolign-1) = "9."+num$([F:ADI]N1)+"#"

NUMLIGN=nolign-1
#JOJAC - 2016-04-18 - REQ114309 US119 - START
NUMLIGN=nolign-1
If func AFNC.ACTIV("KSA")>0
  If dim([DIA]DUPFLG) > 0
    If [DIA]DUPFLG <> 2
      Gosub VERIF_DOUBLON
    Endif
  Endif
Else
#JOJAC - 2016-04-18 - REQ114309 US119 - END
  Gosub VERIF_DOUBLON
#JOJAC - 2016-04-18 - REQ114309 US119 - START
Endif
#JOJAC - 2016-04-18 - REQ114309 US119 - END

If GOK>0
 #LIPET - 2017-06-12 - X3-44477 - START
 #Readlock[VLA]VLA0= 4;"";"";"";[M:DIR]MAT(nolign-1);[M:DIR]PYRDAT(nolign-1);VALEUR;[M:DIR]BUL(nolign-1)
 Readlock[VLA]VLA0= 4;GCURLEG;"";"";[M:DIR]MAT(nolign-1);[M:DIR]PYRDAT(nolign-1);[M:DIR]VARCOD(nolign-1);[M:DIR]BUL(nolign-1)
 #LIPET - 2017-06-12 - X3-44477 - END
 If fstat=0
  [M:DIR]VALEUR(nolign-1)=[F:VLA]VARVAL
 Else
  [M:DIR]VALEUR(nolign-1)=0
 Endif
 Affzo [M:DIR]VALEUR(nolign-1)
Endif
End

########################################
$VERIF_DOUBLON
Local Integer IND, DOUBLON
DOUBLON=0
GOK=1
For IND=0 To [M:DIR]BPAG-1
 If IND<>NUMLIGN
  If [M:DIR]MAT(IND)=[M:DIR]MAT(NUMLIGN) & [M:DIR]CTR(IND)=[M:DIR]CTR(NUMLIGN) & [M:DIR]CTRDAT(IND)=[M:DIR]CTRDAT(NUMLIGN) & [M:DIR]VARCOD(IND)=VALEUR
   DOUBLON=1
   Break
  Endif
 Endif
Next
If DOUBLON=1
 #Variable déjà saisie pour ce bulletin
 #ligne n°
 GOK=0 : GMESSAGE= mess(49,10702,1)-"\"-mess(61,100,1)-num$(IND+1) : mkstat=2 : Return
Endif
Return

# MAT Précédent
########################################
Subprog B2_MAT(VALEUR)
Variable Char    VALEUR()
Local Char CRITERE (250)
Local Char CRITERE2 (250)
If VALEUR <>""
 Gosub FILTRE
 If [M:DIA]POP<>""
    Link [ECT] With
&       [ID]ID0   = [F:ECT]REFNUM
&     , [HRCTR]CTR2 = [F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
&     , [HRPOA]POA0(3)= [M:DIA]POP;[F:ECT]REFNUM;[F:ECT]CTRNUM
&     , [FCY]FCY0 = [F:HRCTR]ETRFCY
&     , [ACC]CODACC = GUSER;[F:ID]CODACS As [LNK2]
&   Where evalue(CRITERE) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
 Else
    Link [ECT] With
&       [ID]ID0   = [F:ECT]REFNUM
&     , [HRCTR]CTR2 = [F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
&     , [FCY]FCY0 = [F:HRCTR]ETRFCY
&     , [ACC]CODACC = GUSER;[F:ID]CODACS As [LNK2]
&   Where evalue(CRITERE) & evalue(CRITERE2)
 Endif
 For [LNK2] Where [F:ID]REFNUM<VALEUR
  OK = 1
  Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:DIA]CRI,OK,1) From DIVPAYE
  If OK
    #Test existence d'une paye
    Filter [VEP] Where EMP=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & PST<2 & FLGLOCK<>2 :# pas validée ni comptabilisée # pas Verrouillé US1918 65062
    Read [VEP]VEP0 Last
    Filter [VEP]
    If fstat=0
     VALEUR=[F:ID]REFNUM : Break
    Endif
  Endif
 Next
Else
 #Opération impossible : salarié de référence non saisi
 GMESSAGE=mess(53,10702,1): mkstat=2 : End
Endif
End

# MAT Suivant
########################################
Subprog B3_MAT(VALEUR)
Variable Char    VALEUR()
Local Char CRITERE (250)
Local Char CRITERE2 (250)
If VALEUR <>""
 Gosub FILTRE
 If [M:DIA]POP<>""
    Link [ECT] With
&       [ID]ID0   = [F:ECT]REFNUM
&     , [HRCTR]CTR2 = [F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
&     , [HRPOA]POA0(3)= [M:DIA]POP;[F:ECT]REFNUM;[F:ECT]CTRNUM
&     , [FCY]FCY0 = [F:HRCTR]ETRFCY
&     , [ACC]CODACC = GUSER;[F:ID]CODACS As [LNK3]
&   Where evalue(CRITERE) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
 Else
    Link [ECT] With
&       [ID]ID0   = [F:ECT]REFNUM
&     , [HRCTR]CTR2 = [F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
&     , [FCY]FCY0 = [F:HRCTR]ETRFCY
&     , [ACC]CODACC = GUSER;[F:ID]CODACS As [LNK3]
&   Where evalue(CRITERE) & evalue(CRITERE2)
 Endif
 For [LNK3] Where [F:ID]REFNUM>VALEUR
  OK = 1
  Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:DIA]CRI,OK,1) From DIVPAYE
  If OK
    #Test existence d'une paye
    Filter [VEP] Where EMP=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & PST<2 & FLGLOCK<>2 :# pas validée ni comptabilisée # pas Verrouillé US1918 65062
    Read [VEP]VEP0 Last
    Filter [VEP]
    If fstat=0
     VALEUR=[F:ID]REFNUM : Break
    Endif
  Endif
 Next
Else
 #Opération impossible : salarié de référence non saisi
 GMESSAGE=mess(53,10702,1): mkstat=2 : End
Endif
End

#################################################
$FILTRE
Local Integer I
CRITERE = "1=1"
CRITERE2 = "[F:ID]ENAFLG=2"

If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITERE -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLSRV<>2  #service
 CRITERE -= '& [F:HRCTR]ETRSRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2  #profil
 CRITERE -= '& [F:HRCTR]PROPRF = "'+[M:DIA]PRF+'"'
Endif

#Autorisation par site
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 CRITERE -= '& find([F:HRCTR]ETRFCY,GUSRFCY(1..GNBAUZ))'
Endif

#Droit d'accès
If GUSRACS<>2 :# pas le droit à tous les codes d'accès...
 CRITERE -= '& [F:ID]CODACS="" or [ACC]CODACC = "'+ GUSER+';'+[F:ID]CODACS+'"'
Endif

If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE2 -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE2 -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif
Return

# VARCOD Précédent
########################################
Subprog B2_VARCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR <>""
 Filter [F:VRA] Where FLGEMP=2
 Read [F:VRA]VRA0<GCURLEG;VALEUR
 If fstat=0
  VALEUR(nolign-1)=[F:VRA]COD
 Endif
 Filter [VRA]
Else
 #Opération impossible : variable de référence non saisie
 GMESSAGE=mess(54,10702,1): mkstat=2 : End   Endif
End

# VARCOD Suivant
########################################
Subprog B3_VARCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR <>""
 Filter [F:VRA] Where FLGEMP=2
 Read [F:VRA]VRA0>GCURLEG;VALEUR
 If fstat=0
  VALEUR=[F:VRA]COD
 Endif
 Filter [VRA]
Else
 #Opération impossible : variable de référence non saisie
 GMESSAGE=mess(54,10702,1): mkstat=2 : End
Endif
End

################################################################################
#Traitement pour filter la variable de type salarié
$S_VARCOD
Case ACTION
 When "SEL_TABLE"
  OBJET="VRA"
  CRITERE = "[F:VRA]FLGEMP=2"
 When "CHX_TABLE"
   Default File [VRA]
 Endcase
Return

$BOUTON
Case BOITE
When "TRTDIR1"
 Case BOUT
  When "R" :
    Gosub AFF_MEMO
  Endcase
Endcase
Return

$AFF_MEMO
  If dim([M:DIA]LEG)>0
   GCURLEG=[M:DIA]LEG
   If [M:DIA]CPY<>"" : Diszo [M:DIA]LEG : Else Actzo [M:DIA]LEG : Endif
  Endif
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
  If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif
Return

Subprog AS_CTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif

If nolign-1>0 & [M:DIR]MAT(nolign-2)=[M:DIR]MAT(nolign-1)
 VALEUR=[M:DIR]CTRDAT(nolign-2)
Else
 If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
 Filter [HRCTR] Where REFNUM=[M:DIR]MAT(nolign-1) & CTRNUM=[M:DIR]CTR(nolign-1) & CTRDAT<=eomonth(GMOIPAY)
&                   & (XITDAT=[0/0/0] | XITDAT>=GMOIPAY)
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If fstat >2
  Filter [HRCTR] Where REFNUM=[M:DIR]MAT(nolign-1) & CTRNUM=[M:DIR]CTR(nolign-1)
  Read [HRCTR]CTR0 Last
  Filter [HRCTR]
 Endif
 If !fstat
  VALEUR=[F:HRCTR]CTRDAT
 Endif
Endif
End

Subprog C_CTRDAT(VALEUR)
Variable Date    VALEUR
Local Char DERBUL (GLONVCR)
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
Look [F:HRCTR]CTR0=[M:DIR]MAT(nolign-1);[M:DIR]CTR(nolign-1);VALEUR
If fstat
 GMESSAGE=mess(26,10701,1) #: Contrat inexistant
 mkstat=2 : End
Endif
Local Char MATRI(GLONEML)
If clalev([F:VEP])=0 : Local File VALEMP [VEP] : Endif
MATRI = [M:DIR]MAT(nolign-1)
#JOJAC - 2016-04-18 - REQ114309 US119 - START
#Filter [VEP] Where EMP=MATRI & CTRNUM=[M:DIR]CTR(nolign-1) & CTRDAT=VALEUR
Filter [VEP] Where EMP=MATRI & CTRNUM=[M:DIR]CTR(nolign-1) & STRCTRDAT<=VALEUR & CTRDAT>=VALEUR
#JOJAC - 2016-04-18 - REQ114309 US119 - END
Read [VEP]VEP0 Last
If fstat>2 or [F:VEP]PST>1 or [F:VEP]RVS=2
&  or [F:VEP]FLGLOCK=2 : # Verrouillé US 2022 65062
 Filter [VEP]
 GMESSAGE = mess(41,10702,1) : # Pas de paye en cours pour ce salarié
 mkstat = 2 : End
Else
#JOJAC - 2016-04-18 - REQ114309 US119 - START
[M:DIR]CTRDAT(nolign-1)=VALEUR        :#91472 - Consolidation des bulletins
#JOJAC - 2016-04-18 - REQ114309 US119 - END
 Gosub CHARGE
 Filter [VEP]
 If mkstat=2 : Raz VALEUR : End: Endif
Endif
End

