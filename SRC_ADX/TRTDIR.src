#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du masque TRTDIR1
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"TRTDIR2","TRTDIR","TRTDIR1",4,"") From GTRAITE
End

#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
 When "OK"          : Gosub OK
 When "END"         : Gosub MYEND
 When "SEL_TABLE", "CHX_TABLE"
  If COUZON="VARCOD" : Gosub S_VARCOD : Endif
 When "BOUTON"      : Gosub BOUTON
Endcase
Return


#######################################################
$OUVRE
Local Char    VALPAR(10), SYMBOLE (80)
Gosub OUVFIC
Local Mask TRTDIR1 [DIA]
Local Mask TRTDIR2 [DIR]
Local Integer OK

If dim(GCURLEG)>0 :  Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif

Raz [M:DIA]
Raz [M:DIR]

Call LECMEMO("STD","[M:DIA]","dir") From GMEMO
Gosub AFF_MEMO
Raz [M:DIA]INI
Return

######################################################
## Ouverture des tables
######################################################
$OUVFIC
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:VEP])=0 : Local File VALEMP     [VEP] : Endif
If clalev([F:VLA])=0 : Local File VALEUR     [VLA] : Endif
If clalev([F:VRA])=0 : Local File VARIA      [VRA] : Endif
If clalev([F:HSP])=0 : Local File HISTOPAYE  [HSP] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If clalev([F:ECT])=0 : Local File EMPCTR     [ECT] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA    [HRPOA]  : Endif

Gosub OUVRE From WPDEFTABLE
Return

#######################################################
$DEBUT
Case BOITE
 When "TRTDIR1" :   Gosub AFF_MEMO : Affzo [DIA]  :#Indispensable pour le grisage de démarrage !!!
                    Setmok [DIA] With 0
Endcase
Return

################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

########################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Endif
Gosub AFF_MEMO
Return

########################################
$OK
Case BOITE
 When "TRTDIR2"
  Call DEBTRANS From GLOCK
  Gosub SAUVE_VALEURS
  Unlock = SYMBOLE
  Call DELOCK("VEP") From GLOCK
Endcase
FIN = 1  : GOK = 1
Return

########################################
$MYEND
Case BOITE
 When "TRTDIR2"
  Unlock = SYMBOLE
  Call DELOCK("VEP") From GLOCK
Endcase
FIN = 1
Return

#JOJAC - 2016-04-18 - REQ114309 US119 - START
