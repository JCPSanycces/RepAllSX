Funprog SETVARIABLE(VCOD,VSTRDAT)
Value Char VCOD
Value Date VSTRDAT
Local Decimal RETVAL : RETVAL = 0

  If clalev([F:VLA1])=0 : Local File VALEUR     [VLA1]  : Endif

#ALHAR - 07-02-2018 X3-75768 - start
  #Filter [VLA1] Where VARCOD = VCOD & DAT <= VSTRDAT & LEG = GCURLEG
  #Read [VLA1] First
  Filter [VLA1] Where VARCOD = VCOD & DAT <= VSTRDAT & LEG = GCURLEG Order By DAT
  Read [VLA1] Last
#ALHAR - 07-02-2018 X3-75768 - end

  Filter [VLA1]
  If !fstat
    RETVAL = [VLA1]VARVAL
  Endif

End RETVAL

Subprog C_NBLIG

If status = 65
Endif

End

#MASHI - 2017-09-08 X3-54387 START

Funprog AVERAGE_EARNING(EMPID,SMPPRPSTR,SMPPRPEND)
Value Char EMPID
Value Date SMPPRPSTR,SMPPRPEND
Local Decimal AMOUNT : AMOUNT = 0
Local Integer WEEKCOUNT
Local Integer PAYFRQ
Local Char EMPREF(20)
Local Char VPERCOD

  If clalev([HSP])=0 : Local File HISTOPAYE [HSP]  : Endif
  If clalev([HRCTR9])= 0  : Local File EMPLOCTR[HRCTR9] : Endif
  If clalev([F:HRPEOD9])=0 : Local File HRPEODET[HRPEOD9] : Endif
  If clalev([HRPEOH])= 0  : Local File HRPEOHEA[HRPEOH] : Endif
  For [F:HSP] Where EMP = EMPID and RUB = 'NAT_IN_MTD' and TYP = 6 and DAT >= SMPPRPSTR and DAT <= SMPPRPEND
     Filter [HRCTR9] Where CTRNUM = [F:HSP]CTRNUM
    # testing
    #  Filter [HRCTR9] Where [HRCTR9]REFNUM = EMPID
      Read [HRCTR9] First
      Filter [HRCTR9]
      If !fstat
        [L]VPERCOD = [F:HRCTR9]PERCOD
        Filter [HRPEOH] Where PERCOD = [HRCTR9]PERCOD and FLGENA = 2
        Read [HRPEOH] First
        If !fstat
            [L]PAYFRQ = [HRPEOH]PAYFRQ
        Endif
        Filter [HRPEOH]
        #Infbox num$([L]PAYFRQ)
        Case  [L]PAYFRQ
         When 1  # Weekly
           AMOUNT += [F:HSP]AMT
         When 2 # Bi-monthly
           AMOUNT += ([F:HSP]AMT * 6) / 13
         When 3 # Fortnightly
           AMOUNT += [F:HSP]AMT
         When 4 # 4 week
          AMOUNT += [F:HSP]AMT
         When 5 # Quarterly
           AMOUNT += ([F:HSP]AMT * 4) / 13 / 2
         When 6 # Monthly
           AMOUNT += ([F:HSP]AMT * 12) / 13
         When 7 # Annual
           AMOUNT += ([F:HSP]AMT * 4) / 13 / 6
         Endcase
      Endif
    Next

   AMOUNT = AMOUNT / 8
   AMOUNT = fix((AMOUNT * 100000 + 0.99))   / 100000
End AMOUNT
#MASHI - 2017-09-08 X3-54387 END

