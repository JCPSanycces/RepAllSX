#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA SOURCE REMERGE
$ACTION

  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "LIENS"        : Gosub LIENS
    When "STYLE"        : Gosub STYLE
    When "APRES_MODIF"  : Gosub APRES_MODIF
  Endcase

Return

$OUVRE
Return

$LIENS
Return

$APRES_MODIF
  #ANCOA - 08/11/2017 - X3-54377 - START
  #Delete of a line
  If status = 65
    Gosub CLR_MSK_SMP From SUBDCGSMP
  Endif
  #ANCOA - 08/11/2017 - X3-54377 - END
Return


$STYLE

  Gosub HIDE_FIELDS_SXP

  If GCURLEG = 'BRI'
    If dim([M:DCG1]CMT)>0     : Chgfmt [M:DCG1]CMT     With '-K:50'     : Endif
    If dim([M:DCG1]RPL)>0     : Chgfmt [M:DCG1]RPL     With '-K:15'     : Endif
    If dim([M:DCG1]RPLNAM)>0  : Chgfmt [M:DCG1]RPLNAM  With '-K:40'     : Endif
    If dim([M:DCG1]TYPPGN)>0  : Chgfmt [M:DCG1]TYPPGN  With '-LA:10945' : Endif
    If dim([M:DCG1]CMT2)>0    : Chgfmt [M:DCG1]CMT2    With '-K:50'     : Endif
    If dim([M:DCG1]LVESEQ)>0  : Chgfmt [M:DCG1]LVESEQ  With '-K:20'     : Endif
    If dim([M:DCG1]LVENOT)>0  : Chgfmt [M:DCG1]LVENOT  With '-LA:1'     : Endif
    If dim([M:DCG1]DRNAM)>0   : Chgfmt [M:DCG1]DRNAM   With '-K:50'     : Endif
    If dim([M:DCG1]PRTNAM)>0  : Chgfmt [M:DCG1]PRTNAM  With '-K:50'     : Endif
    If dim([M:DCG1]WNBRHOU)>0 : Chgfmt [M:DCG1]WNBRHOU With '-N:9.4'    : Endif
  Endif

Return

Subprog SHOWHIDE(LIGNUM)
Value Integer LIGNUM

  If GCURLEG = "BRI"
    If [M:DCG1]SXPCAT(LIGNUM) <> ""
      If [M:DCG1]SXPCAT(LIGNUM) = "SSP"
        Call SHOWHIDESSP("") From SUBDCGSSP
        Call SHOWHIDESMP("-") From SUBDCGSMP
        Call SHOWHIDESPP("-") From SUBDCGSPP
      Else
        Call SHOWHIDESSP("-") From SUBDCGSSP
      Endif
    Endif
  Else
    Call SHOWHIDESSP("-") From SUBDCGSSP
  Endif

  If GCURLEG = "BRI"
    If [M:DCG1]SXPCAT(LIGNUM) <> ""
      If [M:DCG1]SXPCAT(LIGNUM) = "SMP"
        Call SHOWHIDESMP("") From SUBDCGSMP
        Call SHOWHIDESSP("-") From SUBDCGSSP
        Call SHOWHIDESPP("-") From SUBDCGSPP
      Else
        Call SHOWHIDESMP("-") From SUBDCGSMP
      Endif
    Endif
  Else
    Call SHOWHIDESMP("-") From SUBDCGSMP
  Endif

  If GCURLEG = "BRI"
    If [M:DCG1]SXPCAT(LIGNUM) <> ""
      If [M:DCG1]SXPCAT(LIGNUM) = "SPP"
        Call SHOWHIDESPP("") From SUBDCGSPP
        Call SHOWHIDESMP("-") From SUBDCGSMP
        Call SHOWHIDESSP("-") From SUBDCGSSP
      Else
        Call SHOWHIDESPP("-") From SUBDCGSPP
      Endif
    Endif
  Else
    Call SHOWHIDESPP("-") From SUBDCGSPP
  Endif

  ##PEVAN - 2017-12-13 - X3-68365 - START
  If GCURLEG = "BRI"
    If [M:DCG1]SXPCAT(LIGNUM) = ""
      Call SHOWHIDESPP("-") From SUBDCGSPP
      Call SHOWHIDESMP("-") From SUBDCGSMP
      Call SHOWHIDESSP("-") From SUBDCGSSP
    Endif
  Endif
  ##PEVAN - 2017-12-13 - X3-68365 - END
End

Subprog SHOWHIDESXP(WSIGN)
Value Char WSIGN

  Chgfmt [M:DCG1]SSPSTA         With WSIGN+"LA:1"

End

Subprog AM_TIM(VALEUR)
Variable Char    VALEUR()

  Raz [M:DCG1]SSPSTAREA(nolign-1)   : Affzo [M:DCG1]SSPSTAREA(nolign-1)

  If [M:DCG1]SXPCAT <> "SSP"
    Grizo  [M:DCG1]SSPSTAREA(nolign-1)
  Endif

  #SXP Category
  Gosub SXPCATEGORY
  #Show/Hide UK spesific fields
  Gosub DISPLAY_HIDE From SUBDCGLEG
  Call SHOWHIDE(nolign-1)
  #Gosub STYLE

  #JOJAC - 2017-10-12 -X3-15908 - START
  If [M:DCG1]SXPCAT(nolign-1) = "SSP"
    Call AM_TIM(VALEUR) From SUBDCGSSP
  Endif
  If [M:DCG1]SXPCAT(nolign-1) = "SMP"
    Call AM_TIM(VALEUR) From SUBDCGSMP
  Endif
  If [M:DCG1]SXPCAT(nolign-1) = "SPP"
    Call AM_TIM(VALEUR) From SUBDCGSPP
  Endif
  #JOJAC - 2017-10-12 X3-15908 - END

  If [M:DCG1]SXPCAT(nolign-1) = "SMP"
    If clalev([ID1])= 0  : Local File EMPLOID [ID1] : Endif
    Read [ID1]ID0 = [M:DCG1]REFNUM
    If [ID]SEX <> 2
      GMESSAGE = mess(16,11828,1)
      mkstat = 2
    Endif
  Endif

#ALHAR - 14-02-2018 X3-77326 - start - removed as not a valid test
#  If [M:DCG1]SXPCAT(nolign-1) = "SPP"
#    If [ID]SEX <> 1
#      GMESSAGE = mess(19,11828,1)
#      mkstat = 2
#    Endif
#  Endif
#ALHAR - 14-02-2018 X3-77326 - end

End





Subprog AVANT_NBLIG
Local Char CHAINE

  DCGUKINBLIG = nolign-1

  #JOJAC - 2017-10-02 - X3-15908 - START
  If [M:DCG1]TIM(nolign-1) = 'SSP'
    Call VIREBOUT(CHAINE,"G") From GOBJET
  Else
    CHAINE +="G"
  Endif
  #JOJAC - 2017-10-02 - X3-15908 - END

  If [M:DCG1]SXPCAT(nolign-1) <> ""
    If [M:DCG1]SXPCAT(nolign-1) = "SSP"
      Call AVANT_NBLIG From SUBDCGSSP
    Endif
    If [M:DCG1]SXPCAT(nolign-1) = "SMP"
      #MASHI - 2017-09-06 X3-54202 START
      Call AVANT_NBLIG From SUBDCGSMP
      #MASHI - 2017-09-06 X3-54202 END
      Gosub LOADSMP From SUBDCGSMP
      Gosub LOADKIT From SUBDCGSMP
    Endif
    #MASHI - 2017-09-06 X3-54202 START
    If [M:DCG1]SXPCAT(nolign-1) = "SPP"
      Call AVANT_NBLIG From SUBDCGSPP
      #ALHAR - 08-02-2018 X3-76140 - start
      #Gosub LOADSPP From SUBDCGSPP
      #ALHAR - 08-02-2018 X3-76140 - end
      Gosub LOADKIT From SUBDCGSMP
    Endif
    #MASHI - 2017-09-06 X3-54202 END
  Endif

End

$SXPCATEGORY
If clalev([F:TIM3])=0 : Local File TIMCOD  [TIM3] : Endif

Read [TIM3]TIM0=GCURLEG;VALEUR
If !fstat
  [M:DCG1]SXPCAT(nolign-1)=[F:TIM3]SXPCAT
  Affzo [M:DCG1]SXPCAT(nolign-1)
Endif

Return

######################################################################################
## Section automatically added (screen DCG1) 07/20/2017 13:51:03 (JOJAC)
######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
Local Date SSPSTR
Local Date SSPEND

  If [M:DCG1]SXPCAT(nolign-1) = "SSP"
    [M:DCG1]STRDAT(nolign-1) = VALEUR
    Gosub AM_STRDAT_ENDDAT
  Endif

  #JOJAC - 2017-11-14 - X3-63780 - START
  If [M:DCG1]SXPCAT(nolign-1) = "SMP" and [M:DCG1]SMPEXPDOB <> [0/0/0]  and [M:DCG1]SMPAWE <> 0.00
    Call SMPCAL([M:DCG1]SMPLEADAT,[M:DCG1]SMPAWE) From SUBDCGSMP
  Endif
  #JOJAC - 2017-11-14 - X3-63780 - END


End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Date SSPSTR
Local Date SSPEND

  If [M:DCG1]SXPCAT(nolign-1) = "SSP"
    [M:DCG1]ENDDAT(nolign-1) = VALEUR
    Gosub AM_STRDAT_ENDDAT
  Endif

  #JOJAC - 2017-11-14 - X3-63780 - START
  If [M:DCG1]SXPCAT(nolign-1) = "SMP"
    SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(nolign-1))
    If [M:DCG1]SMPLEADAT <> [0/0/0] and [M:DCG1]SMPAWE <> 0.00 and [M:DCG1]SMPAWE > [L]SMP_MAWE
      Call SMPCAL([M:DCG1]SMPLEADAT ,[M:DCG1]SMPAWE) From SUBDCGSMP
    Endif
  Endif
  #JOJAC - 2017-11-14 - X3-63780 - END


End

$AM_STRDAT_ENDDAT
Local Integer SSPSTA

  Effzo [M:DCG1]SSPSTA(nolign-1)
  Effzo [M:DCG1]SSPSTAREA(nolign-1)
  Effzo [M:DCG1]AVEERN(nolign-1)

  Gosub SSPWAIDAY From SUBDCGSSP
  Gosub SSPQUADAY From SUBDCGSSP     #SSP Qualyfying days
  Gosub SSPPIW From SUBDCGSSP        #SSP PIW
  Gosub SSPLNKPIW From SUBDCGSSP     #SSP Link PIW
  Gosub SSPRELPER From SUBDCGSSP     #SSP Relevant Period
  Gosub SSPELI_AWE From SUBDCGSSP

  Affzo [M:DCG1]SSPWAIDAY(nolign-1)
  Affzo [M:DCG1]SSPQUADAY(nolign-1)
  Affzo [M:DCG1]SSPPAIDAY(nolign-1)
  #Affzo [M:DCG1]30

End

Subprog AV_PRODAT(VALEUR)
Variable Date    VALEUR
  If GCURLEG<>"BRI"
    If dim([M:DIA]PRODAT)>0 : Chgfmt [M:DIA]PRODAT  With "-D:"+GFMDAT4  : Raz [M:DIA]PRODAT : Endif
  Else
  Endif
End

