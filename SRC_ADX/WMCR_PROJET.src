#<AdxTL>@(#)0.0.0.0 $Revision$Class Project  
# Supervisor
## CRUD-CLASSE ## PROJET
# 2018-11-06 07:13:51 152


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File PROJET [PRJ_]

If !SILENCE : Call TRACE("2 --> Local Instance C_PROJET") From ASYRCOM : Endif
Local Instance PROJET Using C_PROJET

If !SILENCE : Call TRACE("3 --> New Instance C_PROJET") From ASYRCOM : Endif
PROJET = NewInstance C_PROJET AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [PRJ_]PRJ0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of PROJET") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet PROJET.AREAD([PRJ_]PRJ))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("PROJET.PRJ ="-num$(PROJET.PRJ)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(PROJET.AKEYS)
  Call TRACE("-"-num$(I)-":"-PROJET.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [PRJ_]
FreeGroup PROJET
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(PROJET,ACLE,ASTATUS,_ETAG)
Variable Instance PROJET Using C_PROJET
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _PRJ(15)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_PRJ = num$([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File PROJET [PRJ]
Default File [F:PRJ]
Read [F:PRJ]PRJ0 = [L]_PRJ
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:PRJ]UPDTICK)>0
 [L]_ETAG = num$([F:PRJ]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(PROJET,ACLE,ASTATUS)
Variable Instance PROJET Using C_PROJET
Value Char ACLE
Variable Integer ASTATUS
Local Char _PRJ(15)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_PRJ = num$([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet PROJET.AREAD([L]_PRJ))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(PROJET,_PRJ,ASTATUS)
Variable Instance PROJET Using C_PROJET
Value Char _PRJ
Variable Integer ASTATUS

If PROJET = null : End : Endif

Gosub AVARIABLES From WMC00PROJET
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If PROJET.APARENT=null
 [L]A_I = PROJET.freeSnapshot
 PROJET.snapshotEnabled = 0
 PROJET.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & PROJET.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet PROJET._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If PROJET.APARENT=null
 PROJET.snapshotEnabled = 1
 PROJET.setAccessorEnabled = 1
Endif
LogicClose File [PRJ] ,[PJL] ,[PJF]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet PROJET._ACTION_PARAM("AREAD_BEFORE",[L]_PRJ))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:PRJ]
Read [F:PRJ]PRJ0 = [L]_PRJ
If fstat
[L]A_ERROR = [L]_PRJ
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(PROJET,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = [F:PRJ]ACS
If dim([F:PRJ]AUUID)>0 & [F:PRJ]AUUID=NullUuid
 [F:PRJ]AUUID = getUuid
Endif
If dim([F:PRJ]DESLNG)>0: Raz [F:PRJ]DESLNG: Endif
SetInstance PROJET With [F:PRJ]
PROJET.ASTALIN = [V]CST_ALL

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:PJL]
 [L]A_N2=0
 For [F:PJL]PJL0 Where PRJ=[F:PRJ]PRJ
  [L]A_N2 +=1
  PROJET.LOT(A_N2) = NewInstance  C_PRJLOT(PROJET.ACTX,NullUuid,[L]A_N2,PROJET,"LOT") AllocGroup PROJET
  [L]ASTATUS = max([L]ASTATUS,fmet PROJET.LOT(A_N2).ADDINSTANCE_BOUND)
  If dim([F:PJL]AUUID)>0 & [F:PJL]AUUID=NullUuid
   [F:PJL]AUUID = getUuid
  Endif
  SetInstance PROJET.LOT(A_N2) With [F:PJL]
  [L]ASTATUS = max([L]ASTATUS,fmet PROJET.LOT(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  PROJET.LOT(A_N2).ASTALIN = [V]CST_ALL
 Next PJL
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:PJF]
 [L]A_N2=0
 For [F:PJF]PJF0 Where PRJ=[F:PRJ]PRJ
  [L]A_N2 +=1
  PROJET.FAS(A_N2) = NewInstance  C_PRJFAS(PROJET.ACTX,NullUuid,[L]A_N2,PROJET,"FAS") AllocGroup PROJET
  [L]ASTATUS = max([L]ASTATUS,fmet PROJET.FAS(A_N2).ADDINSTANCE_BOUND)
  If dim([F:PJF]AUUID)>0 & [F:PJF]AUUID=NullUuid
   [F:PJF]AUUID = getUuid
  Endif
  SetInstance PROJET.FAS(A_N2) With [F:PJF]
  [L]ASTATUS = max([L]ASTATUS,fmet PROJET.FAS(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  PROJET.FAS(A_N2).ASTALIN = [V]CST_ALL
 Next PJF
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

[L]A_NEWCOL = 0
For [L]A_I=1 To 10
 If ([F:PRJ]BPRFIN([L]A_I-1)<>"" or [F:PRJ]AMTFIN([L]A_I-1)<>0)
  [L]A_NEWCOL += 1
  PROJET.COLBPRFIN(A_NEWCOL) = NewInstance  C_PROJET_COLBPRFIN(PROJET.ACTX,NullUuid,[L]A_I,PROJET,"COLBPRFIN") AllocGroup PROJET
  PROJET.COLBPRFIN(A_NEWCOL).BPRFIN = [F:PRJ]BPRFIN([L]A_I-1)
  PROJET.COLBPRFIN(A_NEWCOL).AMTFIN = [F:PRJ]AMTFIN([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet PROJET.COLBPRFIN(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]A_NEWCOL = 0
For [L]A_I=1 To 24
 If ([F:PRJ]PERSTR([L]A_I-1)<>[00/00/0000] or [F:PRJ]PEREND([L]A_I-1)<>[00/00/0000] or [F:PRJ]AMTPRV([L]A_I-1)<>0)
  [L]A_NEWCOL += 1
  PROJET.COLPER(A_NEWCOL) = NewInstance  C_PROJET_COLPER(PROJET.ACTX,NullUuid,[L]A_I,PROJET,"COLPER") AllocGroup PROJET
  PROJET.COLPER(A_NEWCOL).PERSTR = [F:PRJ]PERSTR([L]A_I-1)
  PROJET.COLPER(A_NEWCOL).PEREND = [F:PRJ]PEREND([L]A_I-1)
  PROJET.COLPER(A_NEWCOL).AMTPRV = [F:PRJ]AMTPRV([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet PROJET.COLPER(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]ASTATUS = max([L]ASTATUS,fmet PROJET.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [AXX] Where CODFIC="PROJET" & ZONE="DESTRA" & IDENT1=PROJET.PRJ & IDENT2=""
 Call ASETTEXTRA(PROJET.AXX,PROJET.AllocGrp(),"DESTRA",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
 PROJET.AXX(maxtab(PROJET.AXX)).FLG = 0
Next AXX
If !len(fmet PROJET.AGETTEXTRA("DESTRA"))
 Call ASETTEXTRA(PROJET.AXX,PROJET.AllocGrp(),"DESTRA",
& fmet PROJET.AGETTEXTRALAN("DESTRA",PROJET.ACTX.AFOLD.ALANGDEF),
& PROJET.ACTX.LAN) From ASYRSUB
Endif
For [AXX] Where CODFIC="PROJET" & ZONE="SHOTRA" & IDENT1=PROJET.PRJ & IDENT2=""
 Call ASETTEXTRA(PROJET.AXX,PROJET.AllocGrp(),"SHOTRA",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
 PROJET.AXX(maxtab(PROJET.AXX)).FLG = 0
Next AXX
If !len(fmet PROJET.AGETTEXTRA("SHOTRA"))
 Call ASETTEXTRA(PROJET.AXX,PROJET.AllocGrp(),"SHOTRA",
& fmet PROJET.AGETTEXTRALAN("SHOTRA",PROJET.ACTX.AFOLD.ALANGDEF),
& PROJET.ACTX.LAN) From ASYRSUB
Endif

Return



