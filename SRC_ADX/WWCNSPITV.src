#<AdxTL>@(#)%I%
# Supervisor
# Inquiry PITV

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:15"
A_USER  = "ADMIN"
A_STAMP = "20181109081115"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(1002930,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSPITVSTD"
PROGSPE    = "CNSPITVSPE"
CBOITE     = "DCNSPITV"
BOITE      = "FCNSPITV"
NOMMSK(0)  = "CONSPITV1"
ABMSK(0)   = "PITV1"
NOMMSK(1)  = "CONSPITV2"
ABMSK(1)   = "PITV2"
CMEMO      = "PITV"
CNOMMSK    = "CRITPITV"
CABMSK     = "CPITV"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
If clalev([F:ITVP])=0 : Local File ITMMVTPIT    [ITVP] : Endif
If clalev([F:SLFP])=0 : Local File STOLOTFCYPIT [SLFP] : Endif
If clalev([F:STPP])=0 : Local File STOCOSTPIT   [STPP] : Endif
If clalev([F:ITCP])=0 : Local File ITMCOSTPIT   [ITCP] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CPITV]
 When  0 : Local Mask =NOMMSK(0) [PITV1]
 When  1 : Local Mask =NOMMSK(1) [PITV2]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CPITV]
 When  0 : Grizo [PITV1]
 When  1 : Grizo [PITV2]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
If dim([M:CPITV]ITMREF)>0
 Grizo [CPITV]ITMREF
Endif
If dim([M:CPITV]STOFCY)>0
 Grizo [CPITV]STOFCY
Endif
If dim([M:CPITV]VLTCOD)>0
 Grizo [CPITV]VLTCOD
Endif
If dim([M:CPITV]CUR)>0
 Grizo [CPITV]CUR
Endif
If dim([M:CPITV]LOTF)>0
 Grizo [CPITV]LOTF
Endif
If dim([M:CPITV]LOTT)>0
 Grizo [CPITV]LOTT
Endif
If dim([M:CPITV]FIYNUM)>0
 Grizo [CPITV]FIYNUM
Endif
If dim([M:CPITV]PERF)>0
 Grizo [CPITV]PERF
Endif
If dim([M:CPITV]PERT)>0
 Grizo [CPITV]PERT
Endif
If dim([M:CPITV]VLTNUM)>0
 Grizo [CPITV]VLTNUM
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CPITV])>0 : Close Local Mask [CPITV] : Endif
 When  0 : If clalev([M:PITV1])>0 : Close Local Mask [PITV1] : Endif
 When  1 : If clalev([M:PITV2])>0 : Close Local Mask [PITV2] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CPITV]
 When  0 : Default Mask [PITV1]
 When  1 : Default Mask [PITV2]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CPITV]
 When  0 : Raz [M:PITV1]
 When  1 : Raz [M:PITV2]
Endcase
Return

$CRITENT
If dim([M:CPITV]ITMREF)>0 & dim([M:PITV1]ITMREF)>0
 [M:CPITV]ITMREF = [M:PITV1]ITMREF
Endif
If dim([M:CPITV]STOFCY)>0 & dim([M:PITV1]STOFCY)>0
 [M:CPITV]STOFCY = [M:PITV1]STOFCY
Endif
If dim([M:CPITV]VLTCOD)>0 & dim([M:PITV1]VLTCOD)>0
 [M:CPITV]VLTCOD = [M:PITV1]VLTCOD
Endif
If dim([M:CPITV]CUR)>0 & dim([M:PITV1]CUR)>0
 [M:CPITV]CUR = [M:PITV1]CUR
Endif
If dim([M:CPITV]LOTF)>0 & dim([M:PITV1]LOTF)>0
 [M:CPITV]LOTF = [M:PITV1]LOTF
Endif
If dim([M:CPITV]LOTT)>0 & dim([M:PITV1]LOTT)>0
 [M:CPITV]LOTT = [M:PITV1]LOTT
Endif
If dim([M:CPITV]FIYNUM)>0 & dim([M:PITV1]FIYNUM)>0
 [M:CPITV]FIYNUM = [M:PITV1]FIYNUM
Endif
If dim([M:CPITV]PERF)>0 & dim([M:PITV1]PERF)>0
 [M:CPITV]PERF = [M:PITV1]PERF
Endif
If dim([M:CPITV]PERT)>0 & dim([M:PITV1]PERT)>0
 [M:CPITV]PERT = [M:PITV1]PERT
Endif
If dim([M:CPITV]VLTNUM)>0 & dim([M:PITV1]VLTNUM)>0
 [M:CPITV]VLTNUM = [M:PITV1]VLTNUM
Endif
Return

$ENTCRIT
If dim([M:CPITV]ITMREF)>0 & dim([M:PITV1]ITMREF)>0
[M:PITV1]ITMREF = [M:CPITV]ITMREF
Endif
If dim([M:CPITV]STOFCY)>0 & dim([M:PITV1]STOFCY)>0
[M:PITV1]STOFCY = [M:CPITV]STOFCY
Endif
If dim([M:CPITV]VLTCOD)>0 & dim([M:PITV1]VLTCOD)>0
[M:PITV1]VLTCOD = [M:CPITV]VLTCOD
Endif
If dim([M:CPITV]CUR)>0 & dim([M:PITV1]CUR)>0
[M:PITV1]CUR = [M:CPITV]CUR
Endif
If dim([M:CPITV]LOTF)>0 & dim([M:PITV1]LOTF)>0
[M:PITV1]LOTF = [M:CPITV]LOTF
Endif
If dim([M:CPITV]LOTT)>0 & dim([M:PITV1]LOTT)>0
[M:PITV1]LOTT = [M:CPITV]LOTT
Endif
If dim([M:CPITV]FIYNUM)>0 & dim([M:PITV1]FIYNUM)>0
[M:PITV1]FIYNUM = [M:CPITV]FIYNUM
Endif
If dim([M:CPITV]PERF)>0 & dim([M:PITV1]PERF)>0
[M:PITV1]PERF = [M:CPITV]PERF
Endif
If dim([M:CPITV]PERT)>0 & dim([M:PITV1]PERT)>0
[M:PITV1]PERT = [M:CPITV]PERT
Endif
If dim([M:CPITV]VLTNUM)>0 & dim([M:PITV1]VLTNUM)>0
[M:PITV1]VLTNUM = [M:CPITV]VLTNUM
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..10) , CRITAFF2(10)(1..10)
CRITAFF(1) = "ITMREF" : CRITAFF2(1) = "ITMREF"
CRITAFF(2) = "STOFCY" : CRITAFF2(2) = "STOFCY"
CRITAFF(3) = "VLTCOD" : CRITAFF2(3) = "VLTCOD"
CRITAFF(4) = "CUR" : CRITAFF2(4) = "CUR"
CRITAFF(5) = "LOTF" : CRITAFF2(5) = "LOTF"
CRITAFF(6) = "LOTT" : CRITAFF2(6) = "LOTT"
CRITAFF(7) = "FIYNUM" : CRITAFF2(7) = "FIYNUM"
CRITAFF(8) = "PERF" : CRITAFF2(8) = "PERF"
CRITAFF(9) = "PERT" : CRITAFF2(9) = "PERT"
CRITAFF(10) = "VLTNUM" : CRITAFF2(10) = "VLTNUM"
NBCA = 10
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
NBBOUT = 0
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Case BOUT
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


