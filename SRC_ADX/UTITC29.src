#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################
# UTITC29   Moulinette pour recopier les modèles import/export Module TC #
#           quand ils ne sont pas protégés                               #
##########################################################################
# FGR 16/12/2009 : X3SUIVI60425
##########################################################################
Local Char DOSSIER(30)

  If 1=1 Then
    DOSSIER = nomap
    # Issue 108760 - 2015-08-07 by MAE :
    #Call SAIDOS(DOSSIER,"") From SAIDOS
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      # Issue 108760 - 2015-08-07 by MAE :
      #Read [ADS]DOSSIER=[L]DOSSIER
      #If fstat THEN
      #  Raz [F:ADS]
      #Endif
      If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITC29(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" and [F:ADS]DOSSIER <> "DEMOAVV" and [F:ADS]DOSSIER <> "DEMOFRA" and [F:ADS]DOSSIER <> "DEMOTEST" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTITC29(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC29(DOSSIER)
Value Char DOSSIER

  Call ECR_TRACE("UTITC29: Process Start on :" - DOSSIER, 0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File ADOSSIER [ADS9]
  Read [ADS9]DOSSIER=DOSSIER
  Call IMPORTEXPORT([F:ADS9]DOSSIER, [F:ADS9]DOSREF) From TRC1MAJ30
  Close Local File [ADS9]
  #-----
  Call ECR_TRACE("UTITC29 records procecessed", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"AOBJEXT") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC29(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"AOBJEXT") : End : Endif
  Call MAJ_UTITC29(APPLI)
End

