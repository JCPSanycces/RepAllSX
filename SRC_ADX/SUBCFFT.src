#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque CFGFRT
$ACTION
Case ACTION
  When "INIT"        : Gosub INIT_BORNES
  When "DEBUT"       : Gosub DEBUT_BORNES
  When "SETBOUT"     : Gosub SETBOUT_BORNES
  When "OK"          : Gosub OK_BORNES
  When "FIN"         : Gosub FIN_BORNES
Endcase
Return
############################################################
$INIT_BORNES
If dim(S_WINAUT) > 0
  If S_WINAUT <> 2 
    FIN = 1
  Else
    Read [CQU]CQU0=PARAM(1)
    If fstat 
      FIN = 1
    Endif
  Endif
Else 
  FIN = 1
Endif
Return
############################################################
$SETBOUT_BORNES
ETABOU(GENRE) = 1
Return
############################################################
$DEBUT_BORNES
Case [F:CQU]ASWTYP
  When 1 : [M:CFFT]INPVAL = VALEUR
           [M:CFFT]ALPVAL = VALEUR 
           [M:CFFT]STRVAL = [F:CQU]ALPSTRVAL
           [M:CFFT]ENDVAL = [F:CQU]ALPENDVAL
  When 2 : [M:CFFT]INPVAL = num$(VALEUR)
           [M:CFFT]NUMVAL = VALEUR 
           [M:CFFT]STRVAL = num$([F:CQU]NUMSTRVAL)
           [M:CFFT]ENDVAL = num$([F:CQU]NUMENDVAL)
  When 3 : [M:CFFT]INPVAL = num$(VALEUR)
           [M:CFFT]DATVAL = VALEUR 
           [M:CFFT]STRVAL = num$([F:CQU]DATSTRVAL)
           [M:CFFT]ENDVAL = num$([F:CQU]DATENDVAL)
Endcase
Affzo [M:CFFT]
Return
############################################################
$OK_BORNES
Case [F:CQU]ASWTYP
  When 1 : VALEUR = [M:CFFT]ALPVAL
  When 2 : VALEUR = [M:CFFT]NUMVAL
  When 3 : VALEUR = [M:CFFT]DATVAL
Endcase
FIN = 1
Return
############################################################
$FIN_BORNES
Return
############################################################
Subprog C_INPVAL(VALEUR)
Variable Char    VALEUR()
Call SAI_VARIABLE(VALEUR,[F:CQU]ASWTYP,[F:CQU]ASWCHA,[M:CFFT]ALPVAL,[M:CFFT]NUMVAL,[M:CFFT]DATVAL,mkstat)
&    From CFGLIBD
If mkstat = 0
  Case [F:CQU]ASWTYP
    When 1 : Call CFGCTRALP([M:CFFT]ALPVAL,[F:CQU]QSTNUM) From CFGLIB
    When 2 : Call CFGCTRNUM([M:CFFT]NUMVAL,[F:CQU]QSTNUM) From CFGLIB
    When 3 : Call CFGCTRDAT([M:CFFT]DATVAL,[F:CQU]QSTNUM) From CFGLIB
  Endcase
Endif
End


