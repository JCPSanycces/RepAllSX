#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################################
# Tables
#   CSFRES(clé NUMRPT;CODANY;LIG;CPY;FCY)       : Résultat d'extraction
# 
# Ecran            Intitulé         Fenetre   Fonction    Traitement    Objet
# CSFRES  | Résultat d'extraction |  OCWR   |  GESCWR  |   SUBCWR    |   CWR
#
################################################################################
Raz GPILCOD, GBIDC1, GBIDC2
Call OBJET("CWR",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FILTRE"      : Gosub FILTRE
 When "LIENS"       : Gosub LIENS
 When "ANNULE"      : Gosub ANNULE
 When "SETBOUT"     : Gosub SETBOUT
 When Default
Endcase
Return

$FILTRE
FILTSUP='[F:CWR]LIG=0'
Return

$OUVRE
If clalev([F:CWR])=0 : Local File CSFRES [CWR] : Endif
Local Mask CSFRES [CWR]
Return

$LIENS
Local Integer I
I=0
For [CWR] Where NUMRPT=[M]NUMRPT & LIG<>0
 [M]CODANY(I) = [F:CWR]CODANY
 [M]CPY(I)    = [F:CWR]CPY
 [M]FCY(I)    = [F:CWR]FCY
 [M]COD1(I)   = [F:CWR]COD1
 [M]COD2(I)   = [F:CWR]COD2 
 [M]LIBEL(I)  = [F:CWR]LIBEL
 [M]AMTLED(I) = [F:CWR]AMTLED
 [M]CURLED(I) = [F:CWR]CURLED
 [M]NBLIG += 1
 I +=1
 If I=300
  GMESSAGE = mess(170,107,1) # Tous les enregistrements n'ont pas été chargés
  Break
 Endif
Next
Return

$SETBOUT
#O bjet à plusieurs elements de clé, rajout du bouton supprimer apres que GOBJET l'a viré
If CLECUR & VERROU : CHAINE+="A" : Endif
Return

$ANNULE
Delete [CWR] Where NUMRPT=[M]NUMRPT
If fstat=1  : GOK=-1 : Call RSTA("CWR",[M]NUMRPT) From GLOCK : Return : Endif
Return
