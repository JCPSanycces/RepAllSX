#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPORTATION("EMPLOCTRUK") From GIMPOBJ
End

###################################################################################
$ACTION
  Case ACTION
    When "OUVRE"     : Gosub OUVRE
    When "RAZCRE"    : Gosub RAZCRE
    When "SAIMSK"    : Gosub SAIMSK
    When "VALID"     : Gosub VALID
  Endcase

Return

###################################################################################
$OUVRE
  Local Mask CTR0 [CTR0], CTR1 [CTR1], CTR2  [CTR2], CTR4  [CTR4], CTR5  [CTR5], CTR6  [CTR6]
  Local Mask CTR8 [CTR8], CTR9 [CTR9], CTR10 [CTRA]

  If clalev([F:HRCTR])=0  : Local File EMPLOCTR     [HRCTR] : Endif
  If clalev([F:CTRSA])=0  : Local File EMPLOCTRSA   [CTRSA] : Endif
  If clalev([F:CPR])=0    : Local File EMPLOCTRCPT  [CPR]   : Endif
  If clalev([F:ECT])=0    : Local File EMPCTR       [ECT]   : Endif
#JASMI - 2017-08-30 - SMOLLEN take-on - START
  If clalev([F:ETR])=0    : Local File EMPLOTAXREC  [ETR]   : Endif
#JASMI - 2017-08-30 - SMOLLEN take-on - END

  nolign=0

Return

###################################################################################
$RAZCRE
  Raz [CTR0], [CTR1], [CTR2], [CTR4], [CTR5], [CTR6], [CTR8], [CTR9], [CTRA]

  nolign=0

Return

###################################################################################
$SAIMSK
Local Integer I
  Case IMPFIC
    When "HRCTR"
      nolign=1
    #employee key
      [M:CTR0]=[F:HRCTR]

      [M:CTR1]=[F:HRCTR] : [M:CTR2]=[F:HRCTR] : [M:CTR4]=[F:HRCTR] : [M:CTR5]=[F:HRCTR]
      [M:CTR6]=[F:HRCTR] : [M:CTR8]=[F:HRCTR] : [M:CTR9]=[F:HRCTR] : [M:CTRA]=[F:HRCTR]
    When "CTRSA"
      [M:CTR1]=[F:CTRSA] : [M:CTR2]=[F:CTRSA] : [M:CTR4]=[F:CTRSA] : [M:CTR5]=[F:CTRSA]
      [M:CTR6]=[F:CTRSA] : [M:CTR8]=[F:CTRSA] : [M:CTR9]=[F:CTRSA] : [M:CTRA]=[F:CTRSA]
    When "CPR"
      [M:CTR1]=[F:CPR] : [M:CTR2]=[F:CPR] : [M:CTR4]=[F:CPR] : [M:CTR5]=[F:CPR]
      [M:CTR6]=[F:CPR] : [M:CTR8]=[F:CPR] : [M:CTR9]=[F:CPR] : [M:CTRA]=[F:CPR]
  Endcase

Return

###################################################################################
$VALID
  GOK=1
  If nolign=0 : Return : Endif
  If GOK=0 : GERREUR=1 : Return : Endif

  Call DEBTRANS From GLOCK

  Gosub TR1
  If GOK=0 : GERREUR=1 : Goto AB_TR1 : Endif

Return

#######################################################################################
#                ENREGISTREMENT DES DONNEES DANS LES TABLES
#######################################################################################
$TR1
#JASMI - 2017-09-14 - SMOLLEN take-on - START
#  Trbegin [F:HRCTR], [F:CTRSA], [F:CPR]
  Trbegin [F:HRCTR], [F:CTRSA], [F:CPR], [F:ECT], [F:ETR]
#JASMI - 2017-09-14 - SMOLLEN take-on - END

  Raz [F:HRCTR]
  Read [F:HRCTR]CTR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT
  [F:HRCTR]=[M:CTR0] : [F:HRCTR]=[M:CTR1] : [F:HRCTR]=[M:CTR2] : [F:HRCTR]=[M:CTR4]
  [F:HRCTR]=[M:CTR5] : [F:HRCTR]=[M:CTR6] : [F:HRCTR]=[M:CTR8] : [F:HRCTR]=[M:CTR9]
  [F:HRCTR]=[M:CTRA]
#JASMI - 2017-07-26 - SMOLLEN take-on - START
  [F:HRCTR]STACTR=2
#JASMI - 2017-07-26 - SMOLLEN take-on - END
  If fstat
    Write [F:HRCTR]
  Else
    Rewrite [F:HRCTR]
  Endif
  If fstat
    GOK=0 : Call FSTA("HRCTR") From GLOCK : Return
  Endif


  Raz [F:CTRSA]
  Read [F:CTRSA]CTRSA0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT
  [F:CTRSA]=[M:CTR0] : [F:CTRSA]=[M:CTR1] : [F:CTRSA]=[M:CTR2] : [F:CTRSA]=[M:CTR4]
  [F:CTRSA]=[M:CTR5] : [F:CTRSA]=[M:CTR6] : [F:CTRSA]=[M:CTR8] : [F:CTRSA]=[M:CTR9]
  [F:CTRSA]=[M:CTRA]
  If fstat
    Write [F:CTRSA]
  Else
    Rewrite [F:CTRSA]
  Endif
  If fstat
    GOK=0 : Call FSTA("CTRSA") From GLOCK : Return
  Endif

#JASMI - 2017-08-30 - SMOLLEN take-on - START
  If [M:CTR5]IRPSTRDAT<>[0/0/0]
    Raz [F:ETR]
    If month([M:CTR5]IRPSTRDAT)>2
      Read [F:ETR]ETR0 = [M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT;(year([M:CTR5]IRPSTRDAT)+1)
    Else
      Read [F:ETR]ETR0 = [M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT;(year([M:CTR5]IRPSTRDAT))
    Endif
    [F:ETR]=[M:CTR0] : [F:ETR]=[M:CTR1] : [F:ETR]=[M:CTR2] : [F:ETR]=[M:CTR4]
    [F:ETR]=[M:CTR5] : [F:ETR]=[M:CTR6] : [F:ETR]=[M:CTR8] : [F:ETR]=[M:CTR9]
    [F:ETR]=[M:CTRA]
    If fstat
      Write [F:ETR]
    Else
      Rewrite [F:ETR]
    Endif
    If fstat
      GOK=0 : Call FSTA("ETR") From GLOCK : Return
    Endif
  Endif
#JASMI - 2017-08-30 - SMOLLEN take-on - END

  Raz [F:CPR]
  Read [F:CPR]CPR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT
  [F:CPR]=[M:CTR0] : [F:CPR]=[M:CTR1] : [F:CPR]=[M:CTR2] : [F:CPR]=[M:CTR4]
  [F:CPR]=[M:CTR5] : [F:CPR]=[M:CTR6] : [F:CPR]=[M:CTR8] : [F:CPR]=[M:CTR9]
  [F:CPR]=[M:CTRA]
  If fstat
    Write [F:CPR]
  Else
    Rewrite [F:CPR]
  Endif
  If fstat
    GOK=0 : Call FSTA("CPR") From GLOCK : Return
  Endif


  Raz [F:ECT]
  Read [F:ECT]ECT0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM
  [F:ECT]=[M:CTR0]
  [F:ECT]NBRCTR=1
  [F:ECT]FCY=[F:HRCTR]ETRFCY
  [F:ECT]SRV=[F:HRCTR]ETRSRV
  [F:ECT]PRF=[F:HRCTR]PROPRF
  If fstat
    Write [F:ECT]
  Else
    Rewrite [F:ECT]
  Endif
  If fstat
    GOK=0 : Call FSTA("ECT") From GLOCK : Return
  Endif


  Commit

Return


#########################
$AB_TR1
  Rollback
  Call TRACE(2,mess(17,107,1)) From SUBIMPOBJ

Return

