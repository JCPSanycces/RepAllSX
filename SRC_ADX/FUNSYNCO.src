#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
# Etiquettes                                                            #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTSYNCO   : Action resynchronisation encours charge       #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
Endcase
Return

#########################################################################
$INIT
# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub OUVRE
Return

#########################################################################
$INIT_DIA
# 33679 mm 12.05
Local    Char    LFCY : LFCY = PARAM(1)
Local    Integer LCOR : LCOR = val(PARAM(2))

Raz [M:DIA]
If LFCY <> "" : [M:DIA]MFGFCY = LFCY Else [M:DIA]MFGFCY = GFCY : Endif
If LCOR <> 0  : [M:DIA]AUTCOR = LCOR : Endif
Return

#########################################################################
$CONTROLE
TIT=" "
TMP=1
Return

#########################################################################
$EXEC
If !GSERVEUR
    # titre de la boîte
    TIT = mess(205,195,1)
    TRA=1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("SYNCO","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# traitement des encours
Gosub TRT_OPS
If [M]AUTWST = 2 : Gosub TRT_MWS : Endif
Return

#########################################################################
$TERMINE
If !GSERVEUR
    # fermeture trace
    Call FERME_TRACE From LECFIC
    If !NBOPS
         ERR=2 : GMESSAGE = mess(264,199,1)
    Endif
    # lecture trace
Endif
Return


########################################################################
$OUVRE
Local Integer  MODE
Local Integer  OK,I
Local Integer  NBOPS,NBMAJ,NBANA, NBMWS
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Integer  WRET
Local Char     WTRTLIG(1)
Local Char     WTRT(1)
Local Decimal  WEXTQTY
Local Decimal  WCPLQTY
Local Decimal  WWRK, WCUM, WCMP
Local Decimal  WEXTQTY
Local Decimal  WCPLQTY
Local Decimal  WPRPTIM
Local Decimal  WWAITIM
Local Decimal  WPSPTIM
Local Decimal  WEXTSETTIM
Local Decimal  WCPLSETTIM
Local Decimal  WEXTOPETIM
Local Decimal  WCPLOPETIM
Local Integer  WEXTWSTTYP
Local Integer  WOPSTYP
Local Integer  WOPSSTA
Local Char     WABBFIL
Local Integer  WORI
Local Char     WPJT
Local Char     WWST(GLONWST)
Local Char     WFCY(GLONFCY)
Local Integer  WSCOFLG

Gosub CHARG_PARAM

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:MKO])  = 0 : Local File MFGOPETRK   [MKO]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO  [MWS]  : Endif

## GH 26/04/2013 bug 88897
If clalev([F:OPS3]) = 0 : Local File OPERATIONS  [OPS3] : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif

Local Mask OPSK  [OPSK]

# titre de la boîte
TIT = mess(205,195,1)

Return

########################################################################
# Préparation du filtre sur la table encours                           #
########################################################################
$SEL_OPS

CRITERE  = 'MFGFCY ="'+[M:DIA]MFGFCY+'"'              # site de production

Return

$TRT_OPS
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(351,197,1),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

Gosub SEL_OPS
Gosub LOOP_OPS

If NBANA
    WMESS2 = num$(NBANA)+" "+mess(265,197,1)
    Call ECR_TRACE(WMESS2,0) From GESECRAN
    If NBOPS
        WMESS2 = "        "+num$(NBOPS)+" "+mess(266,197,1)
        Call ECR_TRACE(WMESS2,0) From GESECRAN
    Endif
Endif
If NBMAJ
    WMESS2 = "        "+num$(NBMAJ)-mess(260,197,1)
    Call ECR_TRACE(WMESS2,0) From GESECRAN
Endif
If !NBOPS
    WMESS2 = "        "+mess(264,199,1)
    Call ECR_TRACE(WMESS2,0) From GESECRAN
Endif

Return

#---------------------------------------------------------------------#
# Traitement des encours                                              #
#---------------------------------------------------------------------#
$LOOP_OPS
Filter [OPS] Where evalue(CRITERE) & OPSSTA<>3
# boucle de lecture
For  [OPS]
      NBANA  += 1
      WEXTWSTTYP = [F:OPS]EXTWSTTYP
      WOPSTYP    = [F:OPS]OPSTYP
      WOPSSTA    = [F:OPS]OPSSTA
      WABBFIL    = [F:OPS]ABBFIL
      WORI       = [F:OPS]ORI
      WSCOFLG    = [F:OPS]SCOFLG
      WPJT       = [F:OPS]PJT
      Gosub CHK_OPS
      If OK = 9 : Goto NXT1 : Endif
      Gosub TRTOPS
$NXT1
Next
#
Filter [OPS]

## GH 26/04/2013 bug 88897
Filter [OPS3] Where evalue(CRITERE) & OPSSTA=3
For [OPS3]OPS1(1)
       NBANA  += 1
       OK = 9
       Filter [ORD] Where STOFCY=[F:OPS3]MFGFCY & WIPTYP = 5 & VCRTYP = 11 & VCRNUM=[F:OPS3]MFGNUM
       Look [ORD]ORD3 First
       If fstat>2
           OK = 3
           WMESS1 = "        "+mess(800,197,1)
       Endif
       If OK = 9 : Goto NXT2 : Endif
       [F:OPS] = [F:OPS3]
       Gosub TRTOPS
$NXT2
Next
#
Filter [OPS3]
Return

#-----------------------------------------------------------------------#
# Vérification encours                                                  #
#-----------------------------------------------------------------------#
$CHK_OPS
OK = 9
Read [MFG]MFG0=[F:OPS]MFGNUM
If fstat
    OK = 1
    WMESS1 = "        "+mess(261,197,1)
    Goto OPS_NXT
Endif
If [F:MFG]MFGSTA > 2
    OK = 1
    WMESS1 = "        "+mess(253,197,1)
    Goto OPS_NXT
Endif
Read [MFO]MFO0 = [F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
If fstat
    OK = 1
    WMESS1 = "        "+mess(302,197,1)
    Goto OPS_NXT
Endif
Case [F:MFO]OPESTA
    When 5:   # opération soldée
              OK = 1
              WMESS1 = "        "+mess(303,197,1)
              Goto OPS_NXT
    When 6:   # opération exclue
              OK = 1
              WMESS1 = "        "+mess(304,197,1)
              Goto OPS_NXT
    When Default: # on continue ...
Endcase
If [F:OPS]EXTQTY <> [F:MFO]EXTQTY
    OK = 2
    WMESS1 = "        "+mess(255,197,1)
    Goto OPS_NXT
Endif
If [F:OPS]CPLQTY <> [F:MFO]CPLQTY
    OK = 2
    WMESS1 = "        "+mess(256,197,1)
    Goto OPS_NXT
Endif
If [F:OPS]PRPTIM <> [F:MFO]PRPTIM |
&  [F:OPS]WAITIM <> [F:MFO]WAITIM |
&  [F:OPS]PSPTIM <> [F:MFO]PSPTIM |
&  [F:OPS]EXTSETTIM <> [F:MFO]EXTSETTIM |
&  [F:OPS]CPLSETTIM <> [F:MFO]CPLSETTIM |
&  [F:OPS]EXTOPETIM <> [F:MFO]EXTOPETIM |
&  [F:OPS]CPLOPETIM <> [F:MFO]CPLOPETIM
    OK = 2
    WMESS1 = "        "+mess(305,197,1)
    Goto OPS_NXT
Endif
$OPS_NXT
If OK = 2
    WEXTQTY     = [F:MFO]EXTQTY
    WCPLQTY     = [F:MFO]CPLQTY
    WPRPTIM     = [F:MFO]PRPTIM
    WWAITIM     = [F:MFO]WAITIM
    WPSPTIM     = [F:MFO]PSPTIM
    WEXTSETTIM  = [F:MFO]EXTSETTIM
    WCPLSETTIM  = [F:MFO]CPLSETTIM
    WEXTOPETIM  = [F:MFO]EXTOPETIM
    WCPLOPETIM  = [F:MFO]CPLOPETIM
Endif
Return

#-----------------------------------------------------------------------#
# Traitement d'un encours                                               #
#-----------------------------------------------------------------------#
$TRTOPS
Gosub MAJOPS
Return

#-----------------------------------------------------------------------#
# Mise à jour des encours                                               #
#-----------------------------------------------------------------------#
$MAJOPS
#
WMESS = mess([F:OPS]OPSTYP,350,1)+" "+[F:OPS]MFGNUM+"/"+num$([F:OPS]OPENUM)
If [M:DIA]AUTCOR = 1 : Goto FINMAJ : Endif
Call DEBTRANS From GLOCK
Trbegin [OPS]
        Case OK
            When 1:    Raz [M:OPSK]
                       [M:OPSK]MFGNUM     = [F:OPS]MFGNUM
                       [M:OPSK]OPENUM     = [F:OPS]OPENUM
                       [M:OPSK]OPESPLNUM  = [F:OPS]OPESPLNUM
                       Call ENCOURS_OPE("A", [F:MFO]OPSNUM) From TRTOPS
                       If GOK < 1 : Goto AB_TRTOPS : Endif
            When 2:    Raz [M:OPSK]
                       [M:OPSK]          = [F:MFO]
                       [M:OPSK]EXTWSTTYP = WEXTWSTTYP
                       [M:OPSK]OPSTYP    = WOPSTYP
                       [M:OPSK]OPSSTA    = WOPSSTA
                       [M:OPSK]ABBFIL    = WABBFIL
                       [M:OPSK]ORI       = WORI
                       [M:OPSK]SCOFLG    = WSCOFLG
                       [M:OPSK]PJT       = WPJT
                       Call ENCOURS_OPE("M", [F:MFO]OPSNUM) From TRTOPS
                       If GOK < 1 : Goto AB_TRTOPS : Endif
            When 3:    ## GH 26/04/2013 bug 88897
                       Call PUR_LOA_SUG([F:OPS3]MFGFCY, [F:OPS3]MFGNUM) From CBNLIBO
                       If GOK < 1 : Goto AB_TRTOPS : Endif
        Endcase
 NBMAJ += 1
Commit
#
$FINMAJ
Call ECR_TRACE(WMESS,0) From GESECRAN
Call ECR_TRACE(WMESS1,0) From GESECRAN
Raz WMESS, WMESS1
NBOPS += 1
Return

$ROL_TRTOPS
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else
     Goto MAJOPS
Endif
Return

$AB_TRTOPS
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return


########################################################################
# Préparation du filtre                                                #
########################################################################
$SEL_MWS

WFCY = [M:DIA]MFGFCY
CRITERE  = 'MFGFCY ="'+[M:DIA]MFGFCY+'"'              # site de production

Return

$TRT_MWS
Gosub SEL_MWS
Gosub LOOP_MWS

Return

#---------------------------------------------------------------------#
# Traitement des cumuls postes                                        #
#---------------------------------------------------------------------#
$LOOP_MWS

Raz NBANA, NBMAJ, NBMWS
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(352,197,1),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

# recalcul des temps prévus
Filter [MFO] Where evalue(CRITERE)
&            Order By Key CLE=[F:MFO]EXTWST

# boucle de lecture
WCUM = 0
WWST = ""
MODE = 1
For  [MFO]
      If WWST <> "" & WWST <> [F:MFO]EXTWST : Gosub TRTMWS :  WCUM = 0 : Endif
      WWST = [F:MFO]EXTWST
      If [F:MFO]TIMUOMCOD = 2
# llc 03.01 multi-exemplaire
#        WWRK  = ([F:MFO]EXTOPETIM * [F:MFO]EXTWSTNBR) / 60         # llc 12.00 6966
         WWRK  = [F:MFO]EXTOPETIM / 60
         WWRK  = func TRTX3.ARRTYP("", "", "TIH", WWRK   )
         WCUM += WWRK
      Else
# llc 03.01 multi-exemplaire
#        WWRK = [F:MFO]EXTOPETIM * [F:MFO]EXTWSTNBR                 # llc 12.00 6966
         WWRK = [F:MFO]EXTOPETIM
         WCUM += func TRTX3.ARRTYP("", "", "TIH", WWRK)
      Endif
Next

Filter [MFO]

If NBANA
    WMESS2 = num$(NBANA)+" "+mess(350,197,1)
    Call ECR_TRACE(WMESS2,0) From GESECRAN
    If NBMWS
        WMESS2 = "        "+num$(NBMWS)+" "+mess(266,197,1)
        Call ECR_TRACE(WMESS2,0) From GESECRAN
    Endif
Endif
If NBMAJ
    WMESS2 = "        "+num$(NBMAJ)-mess(260,197,1)
    Call ECR_TRACE(WMESS2,0) From GESECRAN
Endif
If !NBMWS
     WMESS2 = "        "+mess(264,199,1)
     Call ECR_TRACE(WMESS2,0) From GESECRAN
Endif
NBOPS += NBMWS

Raz NBANA, NBMAJ, NBMWS
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(353,197,1),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

# recalcul des temps réalisés
Filter [MKO] Where evalue(CRITERE)
&            Order By Key CLE=[F:MKO]CPLWST

# boucle de lecture
WCUM = 0
WWST = ""
MODE = 2
For  [MKO]
      If WWST <> "" & WWST <> [F:MKO]CPLWST : Gosub TRTMWS :  WCUM = 0 : Endif
      WWST = [F:MKO]CPLWST
      If [F:MKO]TIMUOMCOD = 2
         WWRK  = [F:MKO]CPLOPETIM / 60
         WWRK  = func TRTX3.ARRTYP("", "", "TIH", WWRK   )
         WCUM += WWRK
      Else
         WCUM += func TRTX3.ARRTYP("", "", "TIH", [F:MKO]CPLOPETIM)
      Endif
Next
Filter [MKO]

If NBANA
    WMESS2 = num$(NBANA)+" "+mess(350,197,1)
    Call ECR_TRACE(WMESS2,0) From GESECRAN
    If NBMWS
        WMESS2 = "        "+num$(NBMWS)+" "+mess(266,197,1)
        Call ECR_TRACE(WMESS2,0) From GESECRAN
    Endif
Endif
If NBMAJ
    WMESS2 = "        "+num$(NBMAJ)-mess(260,197,1)
    Call ECR_TRACE(WMESS2,0) From GESECRAN
Endif
If !NBMWS
     WMESS2 = "        "+mess(264,199,1)
     Call ECR_TRACE(WMESS2,0) From GESECRAN
Endif
NBOPS += NBMWS

Return


#-----------------------------------------------------------------------#
# Traitement d'un poste                                                 #
#-----------------------------------------------------------------------#
$TRTMWS
Gosub MAJMWS
Return

#-----------------------------------------------------------------------#
# Mise à jour poste                                                     #
#-----------------------------------------------------------------------#
$MAJMWS
#

WMESS = WWST
NBANA += 1

Read [MWS]WST0=WWST;WFCY
If fstat
    WMESS1 = WWST - mess(17,107,1)
    Call ECR_TRACE(WMESS1,1) From GESECRAN
    Return
Endif

Case MODE
    When 1:    WCMP = func TRTX3.ARRTYP("", "", "TIH", [F:MWS]EXTHOUTIM)
               If WCUM = WCMP
                    Return
               Else
                    WMESS -= mess(349,197,1)
               Endif
    When 2:    WCMP = func TRTX3.ARRTYP("", "", "TIH", [F:MWS]CPLHOUTIM)
               If WCUM = WCMP
                    Return
               Else
                    WMESS -= mess(349,197,1)
               Endif
Endcase
If [M:DIA]AUTCOR = 1 : Goto FINMAJ2 : Endif
Call DEBTRANS From GLOCK
Trbegin [MWS]
    Readlock [F:MWS]WST0 = WWST;WFCY
    If fstat : Goto AB_TRTMWS : Endif

    Case MODE
        When 1: [F:MWS]EXTHOUTIM = func TRTX3.ARRTYP("", "", "TIH", WCUM   )
        When 2: [F:MWS]CPLHOUTIM = func TRTX3.ARRTYP("", "", "TIH", WCUM   )
    Endcase

Rewrite [MWS]
Commit
NBMAJ += 1


$FINMAJ2
Call ECR_TRACE(WMESS,0) From GESECRAN
Raz WMESS, WMESS1
NBMWS += 1
Return

$ROL_TRTMWS
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else
     Goto MAJMWS
Endif
Return

$AB_TRTMWS
Rollback
WMESS1 = WWST - mess(17,107,1)
Call ECR_TRACE(WMESS1,1) From GESECRAN
Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
Return

#######################################################################
#                     ETIQUETTES                                      #
#######################################################################

##########################################################################
# pour les batchs                                                        #
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK)
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..)
Variable Integer OK

Gosub OUVRE

Local Char    WIN (GLONFEN)
WIN="DSYNCO"
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT


End
###########################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

