#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation AMENLOC

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_JOIN_AFTER"            : Gosub AQUERY_JOIN_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
    Endcase
  When "AML"
    Case [L]AEVENT
      When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "AML.MENLOC"              : Gosub AML_MENLOC
  When "AML.MENLOCAL"            : Gosub AML_MENLOCAL
  When "AML.NONTRA"              : Gosub AML_NONTRA
  When "AML.FORCE"               : Gosub AML_FORCE
  When "AML.AST.LANNUM"          : Gosub AML_AST_LANNUM
  When "AML.AST.CODE"            : Gosub AML_AST_CODE
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return



############################################################################################################
$AQUERY_JOIN_AFTER
Local File APLSTD [AST]             # Local menu descriptions when chapter is under 100
Local File APLSTD [AST1]            # Local menu descriptions when chapter is 100 or above
Local File APLSTD [AST2]            # Non-local menu descriptions (MENLOCAL<>yes)
Link [AML] With
& [F:AST]CLE = 0;[F:AML]MENLOC;GACTX.LAN
& ,[F:AST1]CLE = 200;([F:AML]MENLOC-200);GACTX.LAN
& ,[F:AST2]CLE =[F:AML]MENLOC;0;GACTX.LAN
& As [LNK_]
& Where ( (1=1)
&  )
Return

############################################################################################################
$AQUERY_TRANS_AFTER
# Display local menu title in query facet
If this.AML.MENLOCAL = [V]CST_AYES
  If this.AML.MENLOC<100
    this.AML.TITCHP = [F:AST]LANMES
  Else
    this.AML.TITCHP = [F:AST1]LANMES
  Endif
Else
  this.AML.TITCHP = [F:AST2]LANMES
Endif

Return

#####################################################################################################
$AREAD_AFTER
Local Integer MY_STATUS
[L]MY_STATUS = fmet this.ASETATTRIBUTE("MENLOCAL", "$isDisabled", "true")
Gosub MINI_DISPLAY
Gosub MAXI_DISPLAY
Gosub AUZMOD_DISPLAY
Gosub LONG_DISPLAY
Gosub NONTRA_DISPLAY
Gosub AST_CODE_DISPLAY
Gosub AST_LANNUM_DISPLAY
Return

#####################################################################################################
$MINI_DISPLAY
Local Integer MY_STATUS
If this.MENLOCAL=[V]CST_AYES
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("MINI","$isDisabled","false")
Else
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("MINI","$isDisabled","true")
Endif
Return

#####################################################################################################
$MAXI_DISPLAY
Local Integer MY_STATUS
If this.MENLOCAL=[V]CST_AYES
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("MAXI","$isDisabled","false")
Else
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("MAXI","$isDisabled","true")
Endif
Return

#####################################################################################################
$AUZMOD_DISPLAY
Local Integer MY_STATUS
If this.MENLOCAL=[V]CST_AYES
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("AUZMOD","$isDisabled","false")
Else
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("AUZMOD","$isDisabled","true")
Endif
Return

#####################################################################################################
$LONG_DISPLAY
Local Integer MY_STATUS
If this.MENLOCAL=[V]CST_AYES
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("LONG","$isDisabled","false")
Else
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("LONG","$isDisabled","true")
Endif
Return

#####################################################################################################
$NONTRA_DISPLAY
Local Integer MY_STATUS
If this.NONTRA=[V]CST_AYES
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("FORCE","$isDisabled","true")
Else
  [L]MY_STATUS=fmet this.ASETATTRIBUTE("FORCE","$isDisabled","false")
Endif
Return

#####################################################################################################
$AST_CODE_DISPLAY
Local Integer I,MY_STATUS
# Enable CODE column if a local menu otherwise disable CODE column
For I=1 To maxtab(this.AST)
  If  this.MENLOCAL = [V]CST_AYES
     [L]MY_STATUS = fmet this.AST(I).ASETATTRIBUTE("CODE", "$isDisabled", "false")
  Else
     [L]MY_STATUS = fmet this.AST(I).ASETATTRIBUTE("CODE", "$isDisabled", "true")
  Endif
Next
Return

#####################################################################################################
$AST_LANNUM_DISPLAY
Local Integer I,MY_STATUS
# Enable CODE column if a local menu otherwise disable CODE column
For I=1 To maxtab(this.AST)
  If  this.MENLOCAL = [V]CST_AYES
     [L]MY_STATUS = fmet this.AST(I).ASETATTRIBUTE("LANNUM", "$isDisabled", "true")
  Else
     [L]MY_STATUS = fmet this.AST(I).ASETATTRIBUTE("LANNUM", "$isDisabled", "false")
  Endif
Next
Return


######################################################################################################
$AML_FORCE
Case [L]ARULE
  When "INIT"                    : Gosub FORCE_INIT
  When Default:
Endcase
Return

$FORCE_INIT
Local Integer MY_STATUS
MY_STATUS = fmet this.ASETATTRIBUTE("FORCE","$isDisabled","true")
Return

######################################################################################################
$AML_MENLOC
Case [L]ARULE
  When "PROPAGATE"                      : Gosub MENLOC_PROPAGATE
  When Default:
Endcase
Return

$MENLOC_PROPAGATE
Local Integer MY_STATUS
If this.MENLOC>=100 & this.MENLOC<=200
   [L]MY_STATUS = fmet this.ASETATTRIBUTE("MENLOCAL", "$isDisabled", "true")
Else
   [L]MY_STATUS = fmet this.ASETATTRIBUTE("MENLOCAL", "$isDisabled", "false")
Endif
Gosub MINI_DISPLAY
Gosub MAXI_DISPLAY
Gosub AUZMOD_DISPLAY
Gosub LONG_DISPLAY
Return

######################################################################################################
$AML_MENLOCAL
Case [L]ARULE
  When "INIT"                        : Gosub MENLOCAL_INIT
  When "PROPAGATE"                   : Gosub MENLOCAL_PROPAGATE
  When Default:
Endcase
Return

$MENLOCAL_INIT
Gosub MINI_DISPLAY
Gosub MAXI_DISPLAY
Gosub AUZMOD_DISPLAY
Gosub LONG_DISPLAY
Return

$MENLOCAL_PROPAGATE
Gosub MINI_DISPLAY
Gosub MAXI_DISPLAY
Gosub AUZMOD_DISPLAY
Gosub LONG_DISPLAY
Gosub AST_CODE_DISPLAY
Return

######################################################################################################
$AML_NONTRA
Case [L]ARULE
  When "PROPAGATE"                  : Gosub NONTRA_PROPAGATE
Endcase
Return

$NONTRA_PROPAGATE
Gosub NONTRA_DISPLAY
Return

######################################################################################################
$AML_AST_CODE
Case [L]ARULE
  When "INIT"                       : Gosub AST_CODE_INIT
  When Default:
Endcase
Return

$AST_CODE_INIT
Local Integer MY_STATUS
If  this.APARENT.MENLOCAL = [V]CST_AYES
   [L]MY_STATUS = fmet this.ASETATTRIBUTE("CODE", "$isDisabled", "false")
Else
   [L]MY_STATUS = fmet this.ASETATTRIBUTE("CODE", "$isDisabled", "true")
Endif
Return

######################################################################################################
$AML_AST_LANNUM
Case [L]ARULE
  When "INIT"                       : Gosub AST_LANNUM_INIT
Endcase
Return

$AST_LANNUM_INIT
Local Integer MY_STATUS
If  this.APARENT.MENLOCAL = [V]CST_AYES
   [L]MY_STATUS = fmet this.ASETATTRIBUTE("LANNUM", "$isDisabled", "true")
Else
   [L]MY_STATUS = fmet this.ASETATTRIBUTE("LANNUM", "$isDisabled", "false")
Endif
Return

