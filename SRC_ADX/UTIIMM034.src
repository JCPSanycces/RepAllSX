#<AdxTL>@(#)2.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GLE
# LE          : 15 février 2012
# Moulinette pour alimenter LEG dans la table RVACOEH
# FQ79483
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM034: Initialisation LEG dans RVACOEH") From LECFIC
  Call EXE_UTIIMM034(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM034(APPLI)
 Value Char APPLI

  If clalev([F:COH]) : Close Local File [COH]  : Endif        : # Coefficients de réévaluation
  Local File =APPLI+".RVACOEH" [COH]
  If clalev([F:CPY]) : Close Local File [CPY]  : Endif        : # Sociétés
  Local File =APPLI+".COMPANY" [CPY]
       
  Call ECR_TRACE("UTIIMM034: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM034
  Call ECR_TRACE("UTIIMM034: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM034 
  Local Integer NBENR

  Trbegin [COH]
  
  # Contextes
  For [COH]COH0 Where LEG = ""
    If [F:COH]CPY <> [F:CPY]CPY
      Read [F:CPY]CPY0=[F:COH]CPY
    Endif
    [F:COH]LEG = [F:CPY]LEG
    Rewrite [COH]
    If (fstat) Then
      GOK=0
      Call ECR_TRACE("UTIIMM034 - RVACOEH"-[F:COH]CPY-[F:COH]RVACOEREF-"=> Rewrite Error - FSTAT="-num$(fstat), 1) From GESECRAN
      Break
    Endif
    NBENR += 1      
  Next

  If !GOK Then
    Goto AB_UTIIMM034
  Else
    Commit
    Call ECR_TRACE("UTIIMM034: updated records : "-num$(NBENR),0) From GESECRAN
  Endif
Return

$AB_UTIIMM034
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","RVACOEH","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM034(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","RVACOEH","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM034(APPLI)
End


