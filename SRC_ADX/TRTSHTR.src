#<AdxTL>@(#)4.0.0.0 $Revision$
#CHECK UNUSED_BEGIN
GPROG    = "TRTSHTS"
GTYPPROG = 3
GWINDOW  = "ISHTS"
GWINCRIT = "ISHTCRIT"
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG) From GTRAITE
End
#CHECK UNUSED_END

##################################################################################
##################################################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "AVANT_ENR": Gosub AVANT_ENR
 When "ENR"      : Gosub ENR
 When "SETBOUT"  : Gosub SETBOUT
 When "AVANT_BOUTON":
    Case BOUT
     When "1", "3" : #--- Avant proposition ou Raz ---#
                WPICK = 1
                Gosub RAFFRAICHI From TRTSHTRP
    Endcase
 When "BOUTON"        : Gosub BOUTON
 When "TIR"           : WAFFPICK=1
 When "FILGAUCHE"     : Gosub FILGAUCHE    From TRTSHTRP
 When "AP_FILGAUCHE"  : Gosub AP_FILGAUCHE From TRTSHTRP
 When "CLE_GAUCHE"    : Gosub CLE_GAUCHE   From TRTSHTRP
 When "HINT"          : Gosub HINT_KEY     From TRTSHTRP
 When "DEB_PIC"       : Gosub DEB_PIC      From TRTSHTRP
 When "CRE_PIC"       : Gosub CRE_PIC      From TRTSHTRP
 When "ANU_PIC"       : Gosub ANU_PIC      From TRTSHTRP
 When "FIN_PIC"       : Gosub FIN_PIC      From TRTSHTRP
Endcase

Return

##################################################################################
# Déclaration des variables, masques ou tables nécessaires
$OUVRE
Global Char    GSTOLOC(GLONLOC)
Global Char    GDEFLOC(GLONLOC), GDEFLOC2(GLONLOC), GDEFLOC3(GLONLOC)
Global Char    GDEFLOCTYP(GLONTLO), GDEFLOCTYP2(GLONTLO), GDEFLOCTYP3(GLONTLO)

Local Integer LRET
Local Integer WAFFPICK        : # 0=pas d'alimentation picking
Local Char    WTRUCOD         : # Règle d'allocation
Local Char    WCRIT(80)
Local Char    WCRITPIC(250)   : # Critère pour contrôle ligne stock pickée
Local Char    WCRITSTO(250)   : # Critère pour chargement picking ligne stock
Local Char    WCRITSTO1(60)   : # Critère article et site
Local Char    WCRITSTO2(40)   : # Critère lot
Local Char    WCRITSTO3(70)   : # Critère péremption
Local Char    WCRITSTO31(80)  : # Critère DLU                   # hcb V6percri
Local Char    WCRITSTO4(90)   : # Critère statuts
#--- TS 106217
Local Char    WCRITSTO41(40)  : # Critère version
Local Char    WCRITSTO5(120)  : # Critère catégorie emplacements
Local Char    WCRITSTO6(60)   : # Critère propriétaire du stock
Local Char    WPICKSTO(2)
Local Char    PADMIN
Local Integer WA, WQ, WR
Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WQTY, WQTYSTUACT
Local Integer LMODALL

# Récupération paramètre administrateur stock
Call PARAMUTIL("STOADMIN",PADMIN,"","") From SUBAUS
GSTOADMIN = val(PADMIN)


    If dim(GOUVSHTREG)>=0 & GOUVSHTREG=1
        FIN = 1
        Return
    Endif

    Local Integer LLIGSEL    # Indice de la ligne de STKSHTSEL sélectionnée
    LLIGSEL = val(PARAM(1))

    Call LECITM2([M:SHTS]STOFCY,[M:SHTS]ITMREF(LLIGSEL),"",LRET) From STKLIB
    If LRET
        FIN=1
    Endif

    #desactivation des rubriques ecrans suivant le contexte
    Gosub FORMAT_INV     From STKLIB

    #--- Nécessaire pour l'intitulé évalué ----#
    [M:SHTR]VCRTYP = [M:SHTS]VCRTYP(LLIGSEL)




Return

##################################################################################
$DEBUT
Local Integer DEB_RET

    #------------------------------------------------#
    # Chargement de l'en-tête
    #------------------------------------------------#
    Call ALIM_SHTR(LLIGSEL, DEB_RET) From TRTSHTRA
    If DEB_RET
        Call ERREUR( GMESSAGE ) From GESECRAN
        FIN=1
        Return
    Endif
    Affzo [M:SHTR]

    #------------------------------------------------#
    # Alimentation du masque ALLPAR
    #------------------------------------------------#
    #--- Bug 72943
    #Call ALIM_ALP(LLIGSEL, LMODALL) From TRTSHTCOM
    Call ALIM_ALP(LLIGSEL, LMODALL,DEB_RET) From TRTSHTCOM
    If DEB_RET : FIN=1 : Return : Endif
    #---
    [M:SHTR]XLOT = [M:ALP]LOT
    [M:SHTR]XLOC = [M:ALP]LOC
    [M:SHTR]XSTA = [M:ALP]STA
    [M:SHTR]XWRH = [M:ALP]WRH
    #--- TS 106217
    [M:SHTR]WECCVALMAJ = [M:ALP]ECCVALMAJ

    # Si non renseigné car ajouté 05.08
    If [M:ALP]PECINTLOC=0 [M:ALP]PECINTLOC=2 Endif
    [M:SHTR]PECINTLOC = [M:ALP]PECINTLOC
    [M:SHTR]PECPLFLOC = [M:ALP]PECPLFLOC
    [M:SHTR]PECSCOLOC = [M:ALP]PECSCOLOC
    [M:SHTR]PECOWNER  = [M:ALP]PECOWNER
    [M:SHTR]BPRNUM    = [M:ALP]BPRNUM
    [M:SHTR]BPAADD    = [M:ALP]BPAADD

    #------------------------------------------------#
    # Positionnement sur les tables
    #------------------------------------------------#
    If [F:ITM]ITMREF<>[M:SHTR]ITMREF
        Read [ITM]ITM0 = [M:SHTR]ITMREF
    Endif
    If [F:ITG]TCLCOD<>[F:ITM]TCLCOD | [F:ITG]STOFCY<>[M:SHTR]STOFCY
        Read [ITG]ITG0=[M:SHTR]STOFCY;[F:ITM]TCLCOD
        If fstat
            Read [ITG]ITG0="";[F:ITM]TCLCOD
            If fstat
                Call ERREUR(mess(338,199,1)-":"-[F:ITM]TCLCOD) From GESECRAN
                FIN=1
            Endif
        Endif
    Endif

    Gosub DEBUT_PICKING From TRTSHTRA

Return

##################################################################################
$AVANT_ENR
Local Integer AENR_RET
    #---- Vérifie qu'il n'y a pas trop de quantité régularisante -----#
    If [M:SHTR]PECQTYACT>[M:SHTR]QTYACT
        Call ERREUR( mess( 19, 180, 1) ) From GESECRAN
        FOK = 0
        Return
    Endif
    #---- Vérifie que tout est régularisé, sinon msg d'avertissement -----#
    If [M:SHTR]PECQTYACT<[M:SHTR]QTYACT
        Call AVERTIR( mess( 18, 180, 1), AENR_RET ) From GESECRAN
        If AENR_RET<>2
            FOK = 0
            Return
        Endif
    Endif
Return

##################################################################################
$ENR
Call OUVRE_TRACE("Régul de mouvement") From LECFIC
    Case [M:SHTR]TYPREG
        When 2 : #--- Mouvement en attente
            Trbegin [STJ]
            Call DEBTRANS From GLOCK
            Call SAVE_REGSTJ From TRTSHTCOM

        When 3,4 : #--- Manquant et rupture
            Trbegin [STA]
            Call DEBTRANS From GLOCK
            Call SAVE_REGALL(LMODALL) From TRTSHTCOM
    Endcase

    #---- Gestion des erreurs
    If !GOK | GMESSAGE <> ""
        Rollback
        FIN=0
        If GMESSAGE<>""
            Call ERREUR( GMESSAGE ) From GESECRAN
        Endif
    Else
        Commit
        FIN=1
        Call LOADSHTS(1) From TRTSHTA
    Endif
Call LEC_TRACE From LECFIC
Call FERME_TRACE From LECFIC
Return

##################################################################################
$SETBOUT
    If [M:SHTR]NBLIG=0
        Raz REP, GREP
        Call VIREBOUT(CHBOU,"E") From GOBJET
    Elsif !find("E",CHBOU)
        CHBOU+="E"
    Endif
Return

##################################################################################
$BOUTON


#------ Mise à jour de l'écran ------------#
Case BOUT
 When "1" : # apres action proposition
            Local Integer I
            For I=0 To [M:SHTR]NBLIG-1
                Call MAJLIGNE(I) From TRTSHTRA
            Next
            Affzo [M:SHTR]20
            If [M:SHTR]NBLIG>0
                REP="M" : GREP="M"
            Endif

 When "3" : Effzo [M:SHTR]20
            Gosub MAJQTYTOT  From TRTSHTRA
Endcase

#----------- Mise à jour du tiroir ----------------#
Case BOUT
 When "1","2" : Raz WCRITSTO2, WCRITSTO4, WCRIT
                If dim([M:SHTR]XLOT)>0 & !find([M:SHTR]XLOT,"","*")
                   WCRITSTO2 = 'pat([F:STO]LOT,[M:SHTR]XLOT)=1'
                Endif
                #--- TS 106217
                If dim([M:SHTR]WECCVALMAJ)>0 & [M:SHTR]WECCVALMAJ<>""
                   WCRITSTO41 = '[F:STO]ECCVALMAJ=[M:SHTR]WECCVALMAJ'
                Endif
                #---
                [M:SHTR]XSTA=vireblc([M:SHTR]XSTA,4)
                # Si statuts renseignés dans filtre allocation
                If !find([M:SHTR]XSTA,"","*")
                   # Décodage de la liste de statuts --> transformation en
                   # une formule contenant des 'pat(%,statut)'
                   Call DECODE_STAT([M:SHTR]XSTA,WCRIT) From TRTCATEG
                   # Remplacement des '%' par la variable à tester
                   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
                # Sinon prise en compte des sous-statuts autorisés
                Elsif !find([M:SHTR]AUZSST,"","*")
                   # Décodage de la liste de statuts --> transformation en
                   # une formule contenant des 'pat(%,statut)'
                   Call DECODE_STAT([M:SHTR]AUZSST,WCRIT) From TRTCATEG
                   # Remplacement des '%' par la variable à tester
                   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
                Endif

                If BOUT="2"
                   If [M:SHTR]PECINTLOC=2
                      If [M:SHTR]PECPLFLOC=2
                         #--- Issue 91187 by TS
                         #WCRITSTO5 = 'find([F:STO]LOCCAT,1,2)<>0'
                         WCRITSTO5 = '(find([F:STO]LOCCAT,1,2)<>0'
                         #---
                         #--- Issue 48800
                         If !find([M:SHTR]XLOC,"","*") WCRITSTO5 += '&pat([F:STO]LOC,[M:SHTR]XLOC)<>0' Endif
                         If [M:SHTR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SHTR]XWRH)<>0' Endif
                      Else
                         #--- Issue 91187 by TS
                         #WCRITSTO5 = '[F:STO]LOCCAT=1'
                         WCRITSTO5 = '([F:STO]LOCCAT=1'
                         #---
                         #--- Issue 48800
                         If !find([M:SHTR]XLOC,"","*") WCRITSTO5 += '&pat([F:STO]LOC,[M:SHTR]XLOC)<>0' Endif
                         If [M:SHTR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SHTR]XWRH)<>0' Endif
                      Endif
                   #--- Bug 58838
                   #Elsif [M:SOR]PECPLFLOC=2
                   Elsif [M:SHTR]PECPLFLOC=2
                      #--- Issue 91187 by TS
                      #WCRITSTO5 = '[F:STO]LOCCAT=2'
                      WCRITSTO5 = '([F:STO]LOCCAT=2'
                      #---
                      #--- Issue 48800
                      If !find([M:SHTR]XLOC,"","*") WCRITSTO5 += '&pat([F:STO]LOC,[M:SHTR]XLOC)<>0' Endif
                      If [M:SHTR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SHTR]XWRH)<>0' Endif
                   Endif
                   #--- Bug 58838
                   #If [M:SOR]PECSCOLOC=2
                   If [M:SHTR]PECSCOLOC=2
                      If WCRITSTO5=""
                         #--- Issue 91187 by TS
                         #WCRITSTO5  = '[F:STO]LOCCAT=4'
                         WCRITSTO5  = '([F:STO]LOCCAT=4'
                         #---
                         #--- Issue 48800
                         If !find([M:SHTR]XLOC,"","*") WCRITSTO5 += '&pat([F:STO]LOC,[M:SHTR]XLOC)<>0' Endif
                      Else
                         WCRITSTO5 += '|[F:STO]LOCCAT=4'
                      Endif
                   Elsif WCRITSTO5=""
                      # Pour ne rien avoir (paramétrage incohérent)
                      #--- Issue 91187 by TS
                      #WCRITSTO5 = '[F:STO]LOCCAT=9'
                      WCRITSTO5 = '([F:STO]LOCCAT=9'
                      #---
                   Endif
                   #--- Issue 91187 by TS
                   If WCRITSTO5<>'' WCRITSTO5+=')' Endif

                   # Propriétaire
                   If [M:SHTR]OWNFLG=2
                      If [M:SHTR]NOTOWNFLG=2
                         If [M:SHTR]PECOWNER=""
                            WCRITSTO6 = '1=1'
                         Else
                            WCRITSTO6 = 'find([F:STO]OWNER,[F:STO]STOFCY,[M:SHTR]PECOWNER)'
                         Endif
                      Else
                         WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
                      Endif
                   Else
                      If [M:SHTR]NOTOWNFLG=2
                         If [M:SHTR]PECOWNER=""
                            WCRITSTO6 = '[F:STO]OWNER<>[F:STO]STOFCY'
                         Else
                            WCRITSTO6 = '[F:STO]OWNER=[M:SHTR]PECOWNER'
                         Endif
                      Else
                         # Si rien de coché, on force : 'stock propriétaire'
                         [M:SHTR]OWNFLG=2
                         WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
                      Endif
                   Endif
                Endif
                WAFFPICK=1
                Gosub TIROIR From TRTSHTRP
 When "3"     : WPICK=1
                Gosub RAFFRAICHI From TRTSHTRP
Endcase

Return

#-----------------------------------------------------------------------------#
#                           ACTIONS CHAMPS                                    #
#-----------------------------------------------------------------------------#
########################################
Subprog C_NBLIG
If find(status,65,68,83)
   For I=nolign-1 To max(nolign1,nolign)-1
       [M:SHTR]QTYSTU(I)    =0
       [M:SHTR]QTYSTUACT(I) =0
   Next I
Endif
Gosub MAJQTYTOT From TRTSHTRA
End


########################################
Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local Decimal LTOTPHY, LTOTACT
Local Integer I, LOK
    LTOTPHY = sigma(I=0,[M:SHTR]NBLIG-1, [M:SHTR]QTYSTU(I)*(I<>nolign-1))+VALEUR
    LTOTACT = sigma(I=0,[M:SHTR]NBLIG-1, [M:SHTR]QTYSTUACT(I)*(I<>nolign-1))+VALEUR*([M:SHTR]POT(I)+([F:ITF]STOMGTCOD<3))/(100^([F:ITF]STOMGTCOD=3))
    If LTOTACT > [M:SHTR]QTYACT
        Call AVERTIR( mess( 19, 180, 1), LOK ) From GESECRAN
        If LOK<>2
            mkstat=2
            End
        Endif
    Endif
    [M:SHTR]QTYSTUACT(nolign-1) = VALEUR*([M:SHTR]POT(nolign-1)+([F:ITF]STOMGTCOD<3))/(100^([F:ITF]STOMGTCOD=3))
    [M:SHTR]PECQTYPHY = LTOTPHY
    [M:SHTR]PECQTYACT = LTOTACT
    If  [M:SHTR]PCUSTUCOE(nolign-1) = 0
        [M:SHTR]PCUSTUCOE(nolign-1) = 1
    Endif
    [M:SHTR]QTYPCU(nolign-1) = VALEUR/[M:SHTR]PCUSTUCOE(nolign-1)
    Affzo [M:SHTR]PECQTYPHY,PECQTYACT,QTYSTUACT(nolign-1),QTYPCU(nolign-1)
End

