Subprog C_UIFRGTNUM(VALEUR)
Variable Decimal VALEUR
Local Char       RETURN_MESSAGE(100)

  RETURN_MESSAGE=func SAFUNCTIONS.MODULUS_10_STATUTORY_NUMBERS(format$("N0:8",VALEUR),'UIFREG')
  If RETURN_MESSAGE<>""
    mkstat=2 : GMESSAGE=RETURN_MESSAGE
  Endif

End

