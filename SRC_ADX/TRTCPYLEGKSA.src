Subprog C_PAYREFNUM(VALEUR)
Variable Char    VALEUR()
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - call function - START
Local Char       RETURN_MESSAGE(100)

  RETURN_MESSAGE=func SAFUNCTIONS.MODULUS_10_STATUTORY_NUMBERS(VALEUR,'PAYE')
  If RETURN_MESSAGE<>""
    mkstat=2 : GMESSAGE=RETURN_MESSAGE
  Endif
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - call function - END

End

