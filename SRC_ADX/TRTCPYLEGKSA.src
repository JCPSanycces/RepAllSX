#<AdxTL>@(#)0.0.0.0 $Revision$

#FRLAA - 2015/04/31 - Requirement 108198 US 3580  START
# Mask Management CPYLEGKSA

$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "OK"           : Gosub OK
  Endcase
Return

$OUVRE
  If clalev([F:CPYKSA])=0 : Local File HRCOMPANYKSA [CPYKSA]  : Endif
  If clalev([F:CPY])=0    : Local File COMPANY [CPY]          : Endif
#JASMI - 2015-06-05 - Requirement 104630 US 3682 - START
  If clalev([F:HRCTC])=0  : Local File HRCPYTAXCERI [HRCTC]   : Endif
#JASMI - 2015-06-05 - Requirement 104630 US 3682 - END
Call MANAGE_LOCALISATION("CPYLEGKSA") From DIVPAYE #FRLAA - 2016-06-24 - REQUIREMENT 114309 US 271
Return

$DEBUT
  Raz [M:CLKSA]
  [M]CPY = [M:CPY0]CPY
  Read [F:CPYKSA]CPYKSA0 = [M:CPY0]CPY
  If !fstat
    [M:CLKSA] = [F:CPYKSA]
  Else
    Return
  Endif

#JASMI - 2015-06-08 - Requirement 104630 US 3682 - START
  nolign = 0
  For [F:HRCTC]HRCTC0 Where [F:HRCTC]CPY=[M:CPY0]CPY
    nolign += 1
    [M:CLKSA]TAXYEA(nolign-1)     = [F:HRCTC]TAXYEA
    [M:CLKSA]TAXEXRTEP(nolign-1)  = [F:HRCTC]EXRTEP
    [M:CLKSA]TAXRUNDAT(nolign-1)  = [F:HRCTC]RUNDAT
    [M:CLKSA]TAXRUNTIM(nolign-1)  = [F:HRCTC]RUNTIM
    [M:CLKSA]TAXLIVIND(nolign-1)  = [F:HRCTC]LIVIND
    [M:CLKSA]TAXCERSTR(nolign-1)  = [F:HRCTC]TAXCERSTR
    [M:CLKSA]TAXCEREND(nolign-1)  = [F:HRCTC]TAXCEREND
    [M:CLKSA]TAXCERCOU(nolign-1)  = [F:HRCTC]TAXCERCOU
  Next
  Assign "[M:CLKSA]NBRTAXCER" With nolign

  #Grizo [M:CLKSA]20

#JASMI - 2015-06-08 - Requirement 104630 US 3682 - END
  Affzo [M:CLKSA]
Return

$OK
Trbegin [F:CPYKSA]
Read [F:CPYKSA]CPYKSA0 = [M:CPY0]CPY
If fstat
  [F:CPYKSA]    = [M:CLKSA]
  [F:CPYKSA]CPY = [M:CPY0]CPY
  Write [F:CPYKSA]
  Commit
Else
  [F:CPYKSA] = [M:CLKSA]
  Rewrite [F:CPYKSA]
  Commit
Endif
If fstat
  GOK=0 : Call FSTA("CPYKSA ") From GLOCK
Endif

If !GOK : Goto AB_TR1 : Return
Endif

Return

$AB_TR1
Rollback
Call ERREUR(mess (17,107,1)) From GESECRAN :#Rollback suite à une erreur dans la transaction

Return

