#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry DMWD
######################################################################################################
# Project       : Waste disposal management
# File          : CNSDMWDSTD
# Version       : 1.0
# Authors       : U. Bader
# Creation Date : 2017-01-26
######################################################################################################
# Module        : Common data
# Description   : Waste disposal management: Detailed inquiry on waste disposal data
######################################################################################################
# Updates       :
# Date          | Author | Version | Description
# 2017-01-31    | Bader  | U11_03  | replace local menu 156 by 176
# 2017-02-03    | Bader  | U11_03  | Adaptions for Germany: hide fields PKGSIZ and TAFCAT
######################################################################################################

$ACTION
Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "DEB_CRIT"   : Gosub DEB_CRIT
    When Default
Endcase
Return

############################################################
##
############################################################
$AUTORIS
Return


############################################################
##
############################################################
$DEB_CRIT
If [M:DMWCD]SCMCOD <> ""
    If [F:DMWSC]CRY = 1         # Germany -> hide fields PKGSIZ and TAFCAT
        Chgfmt [M:DMWCD]TAFCAT With "-K:30"
        Chgfmt [M:DMWCD]PKGSIZ With "-K:30"
    Else                        # Austria -> show fields PKGSIZ and TAFCAT
        Chgfmt [M:DMWCD]TAFCAT With "K:30"
        Chgfmt [M:DMWCD]PKGSIZ With "K:30"
    Endif
Endif
Return


############################################################
#
############################################################
$OUVRE
Local Char    FILTCPT(250)(1..4)
Local Integer IFILT : IFILT = 1

If !clalev ([F:DMWSC])    : Local File DMWSCHEME [DMWSC]      : Endif
If !clalev ([F:DMWWEI])   : Local File DMWWEIGHT [DMWWEI]     : Endif
If !clalev ([F:DMWPAOR])  : Local File DMWPAORD [DMWPAOR]     : Endif
Return

############################################################
## called when we have to search
############################################################
$LECTURE

  # disable "NEXT" and "BACK" Buttons. We do not have them here! We have no appropiate key for selecting part data
  SUITE   = 1
  RETOUR  = 1

  # in this inquiry we need a scheme
  If [M:DMWD0]SCMCOD = "" : Return : Endif

  # create the filter ranges from the header data
  Gosub CREATE_FILTER

  Filter [F:DMWWEI] Where evalue(FILTCPT) Order By [F:DMWWEI]SCMCOD;[F:DMWWEI]PKGMAT;[F:DMWWEI]TAFCAT;[F:DMWWEI]PKGSIZ;[F:DMWWEI]ITMREF;
& [F:DMWWEI]WEU;[F:DMWWEI]VCRNUM;[F:DMWWEI]VCRNUMRET

  #delete all entries from the mask
  Raz [M:DMWD1]

  For [F:DMWWEI] With Nohint
    # fill data from file into mask in the right order (we may start from the last position or from the first one)
    Gosub FILL_CNS
  Next


Return


########################################################################################################################
$CREATE_FILTER
  Raz FILTCPT, IFILT

  # waste management scheme
  If [M:DMWD0]SCMCOD <> ""
    Call ADDCRIT(FILTCPT,IFILT,"SCMCOD",'[F:DMWWEI]SCMCOD=[M:DMWD0]SCMCOD'," & ") From GOBJSUB
  Endif

  # date range
  If [M:DMWD0]STRDAT <> [0/0/0]
    Call ADDCRIT(FILTCPT,IFILT,"STRDAT",'[F:DMWWEI]IPTDAT>=[M:DMWD0]STRDAT'," & ") From GOBJSUB
  Endif
  If [M:DMWD0]ENDDAT <> [0/0/0]
    Call ADDCRIT(FILTCPT,IFILT,"ENDDAT",'[F:DMWWEI]IPTDAT<=[M:DMWD0]ENDDAT'," & ") From GOBJSUB
  Endif

  # product
  If [M:DMWD0]ITMREF <> ""
    Call ADDCRIT(FILTCPT,IFILT,"ITMREF",'[F:DMWWEI]ITMREF=[M:DMWD0]ITMREF'," & ") From GOBJSUB
  Endif

  # package material
  If [M:DMWD0]PKGMAT <> ""
    Call ADDCRIT(FILTCPT,IFILT,"PKGMAT",'[F:DMWWEI]PKGMAT=[M:DMWD0]PKGMAT'," & ") From GOBJSUB
  Endif

  If [F:DMWSC]CRY = 2         # Austria
      # tariff category
      If [M:DMWD0]TAFCAT <> ""
        Call ADDCRIT(FILTCPT,IFILT,"TAFCAT",'[F:DMWWEI]TAFCAT=[M:DMWD0]TAFCAT'," & ") From GOBJSUB
      Endif

      # package size
      If [M:DMWD0]PKGSIZ <> ""
        Call ADDCRIT(FILTCPT,IFILT,"PKGSIZ",'[F:DMWWEI]PKGSIZ=[M:DMWD0]PKGSIZ'," & ") From GOBJSUB
      Endif
  Endif

  # cutomer
  If [M:DMWD0]BPR <> ""
    Call ADDCRIT(FILTCPT,IFILT,"BPR",'[F:DMWWEI]BPR=[M:DMWD0]BPR'," & ") From GOBJSUB
  Endif

  # shipment
  If [M:DMWD0]VCRNUM <> ""
    Call ADDCRIT(FILTCPT,IFILT,"VCRNUM",'[F:DMWWEI]VCRNUM=[M:DMWD0]VCRNUM'," & ") From GOBJSUB
  Endif

  If FILTCPT = "" : FILTCPT = "1=1" : Endif
Return


############################################################
## Fill data from file into mask in the right order
############################################################
$FILL_CNS
  If NOL >= MAXLIG-1
    Call ERREND(mess(56,176,1)-num$(MAXLIG)) From GESECRAN
    Return
  Endif

  NOL    += 1
  nolign = NOL+1
  [M:DMWD1] = [F:DMWWEI]

  [M:DMWD1]PKGMATDES(nolign-1)  = func GET_DES([F:DMWWEI]SCMCOD, 2, [M:DMWD1]PKGMAT(nolign-1))
  If [F:DMWSC]CRY = 2         # Austria
      [M:DMWD1]PKGSIZDES(nolign-1)  = func GET_DES([F:DMWWEI]SCMCOD, 3, [M:DMWD1]PKGSIZ(nolign-1))
      [M:DMWD1]TAFCATDES(nolign-1)  = func GET_DES([F:DMWWEI]SCMCOD, 5, [M:DMWD1]TAFCAT(nolign-1))
  Endif

  NBLIG=nolign
Return


Funprog GET_DES(SCMCOD, CTYP, TYPID)
  Value Char SCMCOD
  Value Integer CTYP
  Value Char TYPID
  Local Char LDES(GLONAX3)
  If !clalev([F:DMWPAOR]) : Local File DMWPAORD [DMWPAOR] : Endif
  Read [F:DMWPAOR]DMWPAORD0 = SCMCOD;CTYP;TYPID
  If !fstat
      Call LECTEXTRA(LDES,"DMWPAORD","DES",SCMCOD,num$(CTYP) +"~"+ TYPID) From ATEXTRA
  Endif
End LDES





######################################################################################
## Section automatically added (screen DMWCRIDET) 01/26/2017 09:18:20 (UBA)
######################################################################################
Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR
VALEUR = gdat$(1,month(date$),year(date$))
End

Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
VALEUR = eomonth([M]STRDAT)
End



######################################################################################

######################################################################################
## Section automatically added (screen DMWDET0) 02/03/2017 09:58:18 (UBA)
######################################################################################
Subprog AM_SCMCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR <> [M]SCMCOD
    Read [F:DMWSC]DMWSC0 = VALEUR   # read scheme
    If !fstat
        If [F:DMWSC]CRY = 1         # Germany -> hide fields PKGSIZ and TAFCAT
            Chgfmt [M:DMWD0]TAFCAT With "-K:30"
            Chgfmt [M:DMWD0]PKGSIZ With "-K:30"
            Chgfmt [M:DMWCD]TAFCAT With "-K:30"
            Chgfmt [M:DMWCD]PKGSIZ With "-K:30"
            Chgfmt [M:DMWD1]TAFCAT With "-K:30"
            Chgfmt [M:DMWD1]TAFCATDES With "-K:30"
            Chgfmt [M:DMWD1]PKGSIZ With "-K:30"
            Chgfmt [M:DMWD1]PKGSIZDES With "-K:30"
        Else                        # Austria -> show fields PKGSIZ and TAFCAT
            Chgfmt [M:DMWD0]TAFCAT With "K:30"
            Chgfmt [M:DMWD0]PKGSIZ With "K:30"
            Chgfmt [M:DMWCD]TAFCAT With "K:30"
            Chgfmt [M:DMWCD]PKGSIZ With "K:30"
            Chgfmt [M:DMWD1]TAFCAT With "K:30"
            Chgfmt [M:DMWD1]TAFCATDES With "K:30"
            Chgfmt [M:DMWD1]PKGSIZ With "K:30"
            Chgfmt [M:DMWD1]PKGSIZDES With "K:30"
        Endif
    Endif
Endif
End


######################################################################################

