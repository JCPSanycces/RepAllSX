#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Integer NUMREQ, WNUMLIG,J,WI
Local Decimal TOTCOE
Local Char    CRITERE(255),CRITERE2(255),PARAM(30)
Local Char    CRITERE1(255),CRITERE3(255),CRITERE4(255),CRITERE5(255),CRITERE6(255)
Local Date    DATEDEB, DATEFIN
#LIPET - 2017-05-09 - START
#Local Char    MATDEB(GLONMAT), MATFIN(GLONMAT), SITEDEB(GLONFCY), SITEFIN(GLONFCY)
Local Char    MATDEB(GLONEML), MATFIN(GLONEML), SITEDEB(GLONFCY), SITEFIN(GLONFCY)
#LIPET - 2017-05-09 - END
Local Char    CPYDEB(GLONCPY), CPYFIN(GLONCPY), PROFIL(GLONPRF), SERVICE(GLONSRV), POPULATION(GLONPOP)
Local Char    ODPDEB(GLONVCR), ODPFIN(GLONVCR), ETAT(GLONARP)
Local Char    SEC1DEB(GLONCCE), SEC1FIN(GLONCCE)
Local Char    SEC2DEB(GLONCCE), SEC2FIN(GLONCCE)
Local Char    SEC3DEB(GLONCCE), SEC3FIN(GLONCCE)
Local Char    SEC4DEB(GLONCCE), SEC4FIN(GLONCCE)
Local Char    SEC5DEB(GLONCCE), SEC5FIN(GLONCCE)
Local Char    SEC6DEB(GLONCCE), SEC6FIN(GLONCCE)
Local Char    SEC7DEB(GLONCCE), SEC7FIN(GLONCCE)
Local Char    SEC8DEB(GLONCCE), SEC8FIN(GLONCCE)
Local Char    SEC9DEB(GLONCCE), SEC9FIN(GLONCCE)
Local Char    DIE1DEB(GLONCCE)
Local Char    DIE2DEB(GLONCCE)
Local Char    DIE3DEB(GLONCCE)
Local Char    DIE4DEB(GLONCCE)
Local Char    DIE5DEB(GLONCCE)
Local Char    DIE6DEB(GLONCCE)
Local Char    DIE7DEB(GLONCCE)
Local Char    DIE8DEB(GLONCCE)
Local Char    DIE9DEB(GLONCCE)
Local Char    PROG(10)
Local Char    WSAVGSOC(GLONCPY) #FQ92876-US2715

If clalev([F:DSP])=0  : Local File =GTABCPT+"CADSP"         [DSP] : Endif
If clalev([F:ODP])=0  : Local File ODPAY                    [ODP] : Endif
If clalev([F:ARM])=0  : Local File AREPORTM                 [ARM] : Endif
If clalev([F:TOR])=0  : Local File TMPODPREP                [TOR] : Endif : # FQ89155
If clalev([F:ID])=0   : Local File EMPLOID                  [ID]  : Endif
If clalev([F:POA])=0  : Local File POPULA                   [POA] : Endif
#If clalev([F:CNA])=0  : Local File =GTABCPT+"CACNA"         [CNA] : Endif : #FQ92876-US2715  CNA no exist in V7
If clalev([F:GAC])=0  : Local File =GTABCPT+"GACCOUNT"      [GAC] : Endif
If clalev([F:CCE])=0  : Local File =GTABCPT+"CACCE"         [CCE] : Endif

If clalev([F:GAU])=0  : Local File GAUTACE                  [GAU] : Endif
If clalev([F:GAD])=0  : Local File GAUTACED                 [GAD] : Endif
If clalev([F:TB0])=0  : Local File ODPAYE                   [TB0] : Endif
If clalev([F:TB1])=0  : Local File ODPAY                    [TB1] : Endif
If GCOMPTA<>3
  If clalev([F:GTE])=0  : Local File =GTABCPT+"GTYPACCENT"  [GTE] : Endif
Endif
# FQ112015 - 27/10/15 - Ouverture de la table FACILITY
If clalev([F:FCY])=0  : Local File FACILITY                 [FCY] : Endif

CRITERE  = "1=1" : CRITERE2 = "1=1"
CRITERE1 = "1=1" : CRITERE3 = "1=1" : CRITERE4 = "1=1" : CRITERE5 = "1=1" : CRITERE6 = "1=1"

Call GETPARAM("cpydeb",NBPAR,PARAMETRE,CPYDEB) From ETAT
Call GETPARAM("cpyfin",NBPAR,PARAMETRE,CPYFIN) From ETAT
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB) From ETAT
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN) From ETAT
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM) From ETAT : DATEDEB = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM) From ETAT : DATEFIN = PARAM
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB) From ETAT
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN) From ETAT
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION) From ETAT
Call GETPARAM("profil",NBPAR,PARAMETRE,PROFIL) From ETAT
Call GETPARAM("service",NBPAR,PARAMETRE,SERVICE) From ETAT
Call GETPARAM("odpaynumdeb",NBPAR,PARAMETRE,ODPDEB) From ETAT
Call GETPARAM("odpaynumfin",NBPAR,PARAMETRE,ODPFIN) From ETAT
Call GETPARAM("sec1deb",NBPAR,PARAMETRE,SEC1DEB) From ODPAYIMP
Call GETPARAM("sec1fin",NBPAR,PARAMETRE,SEC1FIN) From ODPAYIMP
Call GETPARAM("sec2deb",NBPAR,PARAMETRE,SEC2DEB) From ODPAYIMP
Call GETPARAM("sec2fin",NBPAR,PARAMETRE,SEC2FIN) From ODPAYIMP
Call GETPARAM("sec3deb",NBPAR,PARAMETRE,SEC3DEB) From ODPAYIMP
Call GETPARAM("sec3fin",NBPAR,PARAMETRE,SEC3FIN) From ODPAYIMP
Call GETPARAM("sec4deb",NBPAR,PARAMETRE,SEC4DEB) From ODPAYIMP
Call GETPARAM("sec4fin",NBPAR,PARAMETRE,SEC4FIN) From ODPAYIMP
Call GETPARAM("sec5deb",NBPAR,PARAMETRE,SEC5DEB) From ODPAYIMP
Call GETPARAM("sec5fin",NBPAR,PARAMETRE,SEC5FIN) From ODPAYIMP
Call GETPARAM("sec6deb",NBPAR,PARAMETRE,SEC6DEB) From ODPAYIMP
Call GETPARAM("sec6fin",NBPAR,PARAMETRE,SEC6FIN) From ODPAYIMP
Call GETPARAM("sec7deb",NBPAR,PARAMETRE,SEC7DEB) From ODPAYIMP
Call GETPARAM("sec7fin",NBPAR,PARAMETRE,SEC7FIN) From ODPAYIMP
Call GETPARAM("sec8deb",NBPAR,PARAMETRE,SEC8DEB) From ODPAYIMP
Call GETPARAM("sec8fin",NBPAR,PARAMETRE,SEC8FIN) From ODPAYIMP
Call GETPARAM("sec9deb",NBPAR,PARAMETRE,SEC9DEB) From ODPAYIMP
Call GETPARAM("sec9fin",NBPAR,PARAMETRE,SEC9FIN) From ODPAYIMP

Call GETPARAM("axe1",NBPAR,PARAMETRE,DIE1DEB) From ODPAYIMP
Call GETPARAM("axe2",NBPAR,PARAMETRE,DIE2DEB) From ODPAYIMP
Call GETPARAM("axe3",NBPAR,PARAMETRE,DIE3DEB) From ODPAYIMP
Call GETPARAM("axe4",NBPAR,PARAMETRE,DIE4DEB) From ODPAYIMP
Call GETPARAM("axe5",NBPAR,PARAMETRE,DIE5DEB) From ODPAYIMP
Call GETPARAM("axe6",NBPAR,PARAMETRE,DIE6DEB) From ODPAYIMP
Call GETPARAM("axe7",NBPAR,PARAMETRE,DIE7DEB) From ODPAYIMP
Call GETPARAM("axe8",NBPAR,PARAMETRE,DIE8DEB) From ODPAYIMP
Call GETPARAM("axe9",NBPAR,PARAMETRE,DIE9DEB) From ODPAYIMP

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,[L]ETAT) From ETAT
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
[L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

If MATDEB<>""       : CRITERE  -= '& [F:ODP]EMP>="'+MATDEB+'"'                   : Endif
If MATFIN<>""       : CRITERE  -= '& [F:ODP]EMP<="'+MATFIN+'"'                   : Endif
If CPYDEB<>""       : CRITERE  -= '& [F:ODP]CPY>="'+CPYDEB+'"'                   : Endif
If CPYFIN<>""       : CRITERE  -= '& [F:ODP]CPY<="'+CPYFIN+'"'                   : Endif
If SITEDEB<>""      : CRITERE  -= '& [F:ODP]FCY>="'+SITEDEB+'"'                  : Endif
If SITEFIN<>""      : CRITERE  -= '& [F:ODP]FCY<="'+SITEFIN+'"'                  : Endif
If DATEDEB<>[0/0/0] : CRITERE1 -= '& [F:ODP]PYRDAT>=['+format$(GFMD,DATEDEB)+']' : Endif
If DATEFIN<>[0/0/0] : CRITERE1 -= '& [F:ODP]PYRDAT<=['+format$(GFMD,DATEFIN)+']' : Endif
If ODPDEB<>""       : CRITERE1 -= '& [F:ODP]ODPNUM>="'+ODPDEB+'"'                : Endif
If ODPFIN<>""       : CRITERE1 -= '& [F:ODP]ODPNUM<="'+ODPFIN+'"'                : Endif
If SERVICE<>""      : CRITERE2 -= '& [F:ODP]SRV="'+SERVICE+'"'                   : Endif
If PROFIL<>""       : CRITERE2 -= '& [F:ODP]PRF="'+PROFIL+'"'                    : Endif
If SEC1DEB<>""      : CRITERE3 -= '& [F:DSP]CCE1>="'+SEC1DEB+'"'                 : Endif
If SEC1FIN<>""      : CRITERE3 -= '& [F:DSP]CCE1<="'+SEC1FIN+'"'                 : Endif
If SEC2DEB<>""      : CRITERE3 -= '& [F:DSP]CCE2>="'+SEC2DEB+'"'                 : Endif
If SEC2FIN<>""      : CRITERE3 -= '& [F:DSP]CCE2<="'+SEC2FIN+'"'                 : Endif
If SEC3DEB<>""      : CRITERE3 -= '& [F:DSP]CCE3>="'+SEC3DEB+'"'                 : Endif
If SEC3FIN<>""      : CRITERE3 -= '& [F:DSP]CCE3<="'+SEC3FIN+'"'                 : Endif
If SEC4DEB<>""      : CRITERE3 -= '& [F:DSP]CCE4>="'+SEC4DEB+'"'                 : Endif
If SEC4FIN<>""      : CRITERE3 -= '& [F:DSP]CCE4<="'+SEC4FIN+'"'                 : Endif
If SEC5DEB<>""      : CRITERE4 -= '& [F:DSP]CCE5>="'+SEC5DEB+'"'                 : Endif
If SEC5FIN<>""      : CRITERE4 -= '& [F:DSP]CCE5<="'+SEC5FIN+'"'                 : Endif
If SEC6DEB<>""      : CRITERE4 -= '& [F:DSP]CCE6>="'+SEC6DEB+'"'                 : Endif
If SEC6FIN<>""      : CRITERE4 -= '& [F:DSP]CCE6<="'+SEC6FIN+'"'                 : Endif
If SEC7DEB<>""      : CRITERE4 -= '& [F:DSP]CCE7>="'+SEC7DEB+'"'                 : Endif
If SEC7FIN<>""      : CRITERE4 -= '& [F:DSP]CCE7<="'+SEC7FIN+'"'                 : Endif
If SEC8DEB<>""      : CRITERE5 -= '& [F:DSP]CCE8>="'+SEC8DEB+'"'                 : Endif
If SEC8FIN<>""      : CRITERE5 -= '& [F:DSP]CCE8<="'+SEC8FIN+'"'                 : Endif
If SEC9DEB<>""      : CRITERE5 -= '& [F:DSP]CCE9>="'+SEC9DEB+'"'                 : Endif
If SEC9FIN<>""      : CRITERE5 -= '& [F:DSP]CCE9<="'+SEC9FIN+'"'                 : Endif

If DIE1DEB<>""      : CRITERE6 -= '& [F:DSP]DIE(0)="'+DIE1DEB+'"'                 : Endif
If DIE2DEB<>""      : CRITERE6 -= '& [F:DSP]DIE(1)="'+DIE2DEB+'"'                 : Endif
If DIE3DEB<>""      : CRITERE6 -= '& [F:DSP]DIE(2)="'+DIE3DEB+'"'                 : Endif
If DIE4DEB<>""      : CRITERE6 -= '& [F:DSP]DIE(3)="'+DIE4DEB+'"'                 : Endif
If DIE5DEB<>""      : CRITERE6 -= '& [F:DSP]DIE(4)="'+DIE5DEB+'"'                 : Endif
If DIE6DEB<>""      : CRITERE6 -= '& [F:DSP]DIE(5)="'+DIE6DEB+'"'                 : Endif
If DIE7DEB<>""      : CRITERE6 -= '& [F:DSP]DIE(6)="'+DIE7DEB+'"'                 : Endif
If DIE8DEB<>""      : CRITERE6 -= '& [F:DSP]DIE(7)="'+DIE8DEB+'"'                 : Endif
If DIE9DEB<>""      : CRITERE6 -= '& [F:DSP]DIE(8)="'+DIE9DEB+'"'                 : Endif

Call DEBTRANS From GLOCK
Gosub TR1

# FQ98828 - 08/04/14 - Je profite de cette fiche pour ajouter le filtre sur CRITERE1 qui avait été oublié
If [L]POPULATION<>""
 Link [ID] With [POA]POA0=[L]POPULATION;[F:ID]REFNUM
&             , [ODP]ODP1(1)=[F:ID]REFNUM
& As [LID]
& Where evalue(CRITERE2) & [F:POA]REFNUM<>"" & evalue(CRITERE) & evalue(CRITERE1) & [F:ODP]DSP<>""
& Order By Key CLE1=[ODP]DSP

 Link [ID] With [POA]POA0=[L]POPULATION;[F:ID]REFNUM
&             , [ODP]ODP1(1)=[F:ID]REFNUM
& As [LID2]
& Where evalue(CRITERE2) & [F:POA]REFNUM<>"" & evalue(CRITERE) & evalue(CRITERE1)
& Order By Key CLE1=[ODP]ODPNUM;[ODP]ODPLIG
Else
 Link [ID] With [ODP]ODP1(1)=[F:ID]REFNUM
& As [LID]
& Where evalue(CRITERE2) & evalue(CRITERE) & evalue(CRITERE1) & [F:ODP]DSP<>""
& Order By Key CLE1=[ODP]DSP

 Link [ID] With [ODP]ODP1(1)=[F:ID]REFNUM
& As [LID2]
& Where evalue(CRITERE2) & evalue(CRITERE) & evalue(CRITERE1)
& Order By Key CLE1=[ODP]ODPNUM;[ODP]ODPLIG
Endif

Raz WNUMLIG

Local Char    PCEAUTO(10), MESSA(80), HAETYP(5)
Call PARAM("","ODPAY",PCEAUTO) From ADOVAL
If [L]PCEAUTO="" : [L]PCEAUTO="ODPAY" : Endif
Read [GAU]GAU0 = [L]PCEAUTO
#JASMI - 2017-05-15 - START
#If clalev([M:HAE0])=0 : Local Mask GACCENT0 [HAE0] : Endif
If !clalev([M:HAE0]) : Local Mask HRGACCENT0 [HAE0] : Endif
#JASMI - 2017-05-15 - END
If fstat : MESSA = [L]PCEAUTO : STAT = 1 : Endif
PROG = "WMGAU"+[L]PCEAUTO

For [LID]CLE1(1)
 Gosub TR2
Next

Raz WNUMLIG
For [LID2]
 Gosub TR3
Next

End

$TR1
GOK = 1
Trbegin [ARM],[TOR]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
 Delete [TOR] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
Commit
Return


$TR2

GOK=1
Trbegin [TOR]
 Raz [L]TOTCOE, J, WI
 For [DSP] Where DSP=[F:ODP]DSP
  [L]TOTCOE     += [F:DSP]COE
  If evalue(CRITERE3) & evalue(CRITERE4)  & evalue(CRITERE5) & evalue(CRITERE6)
    J -=1
    [F:TOR]CREDAT  = date$
    [F:TOR]USR     = GUSER
    [F:TOR]RPTCOD  = [L]ETAT
    [F:TOR]NUMREQ  = [L]NUMREQ
    [F:TOR]NUMLIG  = J
    [F:TOR]CLEA1   = "DSP"
    [F:TOR]CLEA2   = [F:DSP]DSP
    #92876 US2715
    [F:TOR]CLEN4   = [F:DSP]NBRDIE
    For WI=0 To [F:DSP]NBRDIE
      [F:TOR]CLEAD(WI)   = [F:DSP]DIE(WI)
    Next
    #END 92876 US2715
    [F:TOR]CLEA3   = [F:DSP]CCE1
    [F:TOR]CLEA4   = [F:DSP]CCE2
    [F:TOR]CLEA5   = [F:DSP]CCE3
    [F:TOR]CLEA6   = [F:DSP]CCE4
    [F:TOR]CLEA7   = [F:DSP]CCE5
    [F:TOR]CLEA8   = [F:DSP]CCE6
    [F:TOR]CLEA9   = [F:DSP]CCE7
    [F:TOR]CLEA10  = [F:DSP]CCE8
    [F:TOR]CLEA11  = [F:DSP]CCE9
    [F:TOR]CLEMD1  = [F:DSP]COE
    Write [F:TOR]
    If fstat : GOK = 0 : Call FSTA("TOR") From GLOCK : Goto AB_TR : Endif
  Endif
 Next
 For [TOR] Where NUMLIG<0 & USR=GUSER & RPTCOD=[L]ETAT & NUMREQ=[L]NUMREQ
  [L]WNUMLIG +=1
  [F:TOR]NUMLIG = [L]WNUMLIG
  [F:TOR]CLEMD2  = [L]TOTCOE
  Rewrite [F:TOR]
  If fstat
   GOK = 0 : Call FSTA("TOR") From GLOCK : Goto AB_TR
  Endif
 Next

Commit
Return

$TR3
#92876 US2715 CNA no exist in V7
#Local Char    COLLEC(GLONSAC),COMPTE(GLONGAC),TIERS(GLONBPR),NATURE(GLONCNA),MESSA(80),HAETYP(GLONGTE),HAENUM(GLONVCR),REPART(10)
Local Char    COLLEC(GLONSAC),COMPTE(GLONGAC),TIERS(GLONBPR),MESSA(80),HAETYP(GLONGTE),HAENUM(GLONVCR),REPART(10)

Local Integer STAT,OK,ERR
Local Date    ACCDAT,DUDDAT

#92876 US2715
Gosub INIVARLOC
Gosub INIMSK
#END 92876 US2715
  GOK=1
  Trbegin [ARM]
  Raz [F:ARM]
  [L]WNUMLIG +=1
  [F:ARM]CREDAT  = date$
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [L]ETAT
  [F:ARM]NUMREQ  = [L]NUMREQ
  [F:ARM]NUMLIG  = [L]WNUMLIG
  [F:ARM]CLEA1   = [F:ODP]ODPNUM
  [F:ARM]CLEN1   = [F:ODP]ODPLIG
  If [L]ETAT="SIMBULODPAY" Then
    [F:ARM]CLEA2 = [F:ODP]RUB
  Endif
  #Lecture type de pièce "GTE" dans la pièce auto ODPAY
  Call EVAL_CHAR(HAETYP,"GTE",1,0,"",STAT) From CPTAUTO
  If dim([F:GTE]TYP)>0
    Read [GTE]GTE0 = HAETYP
  Endif
  #92876 US2715 plus dans CPTBATCH écran [HAE0] GACCENT0
#  If dim([F:GTE]CAT)>0 & [F:GTE]CAT=2
#    [M]ANA = 2           : # Pièce analytique = Oui
#  Else
#    [M]ANA = 1
#  Endif
  #END 92876 US2715
  Call EVAL_CHAR(HAENUM,"NUM",1,0,"",STAT) From CPTAUTO
  Call EVAL_DATE(ACCDAT,"DAT",1,0,datesyst,STAT) From CPTAUTO
  Call EVAL_DATE(DUDDAT,"DUD",1,0,ACCDAT,STAT) From CPTAUTO
  Read [F:TB1]ODP0=[F:ODP]ODPNUM;[F:ODP]ODPLIG

#92876 US2715
# Récupération de la Transaction DACDIA dans la pièce auto
  Call EVAL_CHAR([L]DACDIA,"DIA",1,0,"",STAT) From CPTAUTO
# Maj des Globales lié à la Société
# Initialisation masque de référence [HAEF]
  Gosub INIPCE2
#END 92876 US2715

  STAT=0
  For [GAD]GAD0 Where COD=[L]PCEAUTO
    ## Dans [M:HAEF]LEDTYP, on a les types de référentiels potentiellement saisissables (ce qui ne veut
    ## pas forcément dire tous les types référentiels associés à la transaction car le type de pièce peut
    ## en interdire certains...)
    ## Dans le tableau TLEDTYP, on remplit les types de référentiels à gérer pour la ligne de pièce auto
    ## compte tenu des types de référentiels paramétrés au niveau de la ligne de pièce auto et compte tenu
    ## des types référentiels potentiellement saisissables
    #92876 US2715
    Raz TLEDTYP, NBLEDTYP
    For I=1 To [F:GAD]NBRLED
     If find([F:GAD]LEDTYP(I-1),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
      NBLEDTYP += 1
      TLEDTYP(NBLEDTYP) = [F:GAD]LEDTYP(I-1)
     Endif
    Next
    #END 92876 US2715
    # FQ98828 - 08/04/14 - Lecture des tables liées pour pouvoir vérifier les conditions et récupérer les bons codes comptables
    Gosub LIENS_LIG From CPTAUTO
    # Fin FQ98828
#    Gosub TSTLIG From CPTAUTO : If STAT Then GOK = 0 : Goto AB_TR : Endif
    Gosub TSTLIG From CPTAUTO : If STAT Then  OK = 0 :  Endif
    If OK Then
#      Raz STAT, COLLEC, COMPTE, TIERS, NATURE
#      Call CPTNAT(COLLEC,COMPTE,TIERS,NATURE,1,HAETYP-HAENUM,DUDDAT,STAT,MESSA) From TRTPCE
#      [F:ARM]CLEA3 = COMPTE
#      [F:ARM]CLEA4 = NATURE
#      If NATURE<>""
#        [F:ARM]CLEA5 = [F:ODP]DSP
#      Else
#        [F:ARM]CLEA5 = ""
#      Endif
#92876 US2715
      Raz TPLAN, TCOMPTE, TSAC, TIERS, PLGEN, PLANA, CPTGEN, CPTANA
## Plans de comptes et axes à saisir pour une société et une liste de référentiels passée en paramètres
## sasie en amont.
      Call SETPLANAXE([F:ODP]CPY,NBLEDTYP,TLEDTYP,NBPLAN,TPLAN,NBDIE,TDIE,TOBLIG) From CPTDIV
##########################################################
# Initialisation comptes des NBREF types référentiels
##########################################################
## Pré-requis : on cherche à initialiser le compte du type référentiel TYPREF ssi les comptes des types
## référentiels précédemment initialisés peuvent avoir une imputation sur le plan de compte associé
## au type référentiel TYPREF
## EX : on a renseigné les types référentiels suivants sur la ligne de pièce auto : social (plan SOC)
##      IAS (plan IAS), analytique (plan ANA) => on initialisera le compte analytique ssi les comptes
##      social et IAS peuvent avoir une imputation sur le plan de compte ANA (=le plan de compte ANA
##      est référencé dans le tableau des comptes par défaut pour le compte social et le compte IAS)

## Pour chaque type de référentiel, on initialise le compte du réferentiel
## 1°) en évaluant ce qui a été paramétré dans la formule compte, en appliquant éventuellement les
##     modificateurs mois/quinzaine
## 2°) si pas de compte trouvé, on applique les codes comptables
## 3°) si pas de compte trouvé, on essaye d'initialiser le compte du référentiel TYPREF par rapport aux comptes
##     des référentiels précédemment initialisés (application des comptes par défaut)
##     EX : on a renseigné les types référentiels suivants sur la ligne de pièce auto : social, ias, analytique
##     => lorsqu'on cherchera à initialiser le compte analytique, si celui ci n'a pas été initialisé en 1°)
##     et 2°), on va chercher à l'initialiser en prenant :
##        a) le compte par défaut type 'Analytique' du compte social
##        b) si pas de compte analytique trouvé, le compte par défaut type 'Analytique' du compte IAS
## 4°) si pas de compte trouvé, on prend le compte par défaut du code plan du référentiel TYPREF
## 5°) si pas de compte trouvé, on renvoie un message d'erreur compte inexistant

## NB : dans la formule ACC1 de la ligne de pièce auto, on a paramétré le compte du 1er type de référentiel
## ASSOCIE A LA LIGNE DE PIECE AUTOMATIQUE.
## Par contre, plus tard dans le masque [M:HAE2], dans [M:HAE2]ACC1 on aura le compte du 1er type de référentiel
## du menu local 2644 (c'est le seul moyen qu'on a pour que tous les comptes contenus dans [M:HAE2]ACCx
## correspondent au même type de référentiel (et il le faut pour pouvoir faire des regroupements de lignes...)
      WSAVGSOC=GSOCIETE
      GSOCIETE=[F:ODP]CPY
      Call CPTNAT([L]NBLEDTYP,[L]TLEDTYP,[L]TPLAN,[L]TCOMPTE,[L]TSAC,[L]TIERS,1,[L]HAETYP-[L]HAENUM,[L]DUDDAT,STAT,MESSA) From TRTPCE
      GSOCIETE=WSAVGSOC
      Call RECH_ACC(1,[F:ODP]CPY,[L]TLEDTYP,[L]NBLEDTYP,[L]TPLAN,[L]TCOMPTE,[L]PLGEN,[L]CPTGEN) From CPTDIV
      Call RECH_ACC(2,[F:ODP]CPY,[L]TLEDTYP,[L]NBLEDTYP,[L]TPLAN,[L]TCOMPTE,[L]PLANA,[L]CPTANA) From CPTDIV
      Call SUIVI_ANA([F:ODP]CPY,[L]TLEDTYP,[L]NBLEDTYP,[L]TPLAN,[L]TCOMPTE,[M:HAEF]DIE,[M:HAEF]NBRAXI,SUIVI) From CPTDIV
      If !SUIVI : Raz CPTANA : Endif
      Call LEC_GAC([L]CPTGEN,[L]PLGEN) From CPTLEC
      [F:ARM]CLEA3 = [L]CPTGEN
      If [L]CPTANA<>""
        [F:ARM]CLEA4 = [L]CPTANA
        [F:ARM]CLEA5 = [F:ODP]DSP
        [F:ARM]CLEA7 = [L]PLANA
      Else
        [F:ARM]CLEA4 = ""
        [F:ARM]CLEA5 = ""
        [F:ARM]CLEA7 = ""
      Endif
      [F:ARM]CLEA6 = [L]PLGEN
      #END 92876 US2715

      Write [F:ARM]
      If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR : Endif
    Endif
  Next

  Commit
Return

$AB_TR
Rollback
Return

# Initialisaion des masques pour le référentiel comptable
$INIMSK
#JASMI - 2017-05-17 - X3-36911 - START
#If clalev([M:HAEF])=0 : Local Mask GACCENTFMT [HAEF] : Endif
#If clalev([M:HAE1])=0 : Local Mask GACCENT1   [HAE1] : Endif
#If clalev([M:HAE2])=0 : Local Mask GACCENT2   [HAE2] : Endif
If !clalev([M:HAEF]) : Local Mask HRGACCENTFMT [HAEF] : Endif
If !clalev([M:HAE1]) : Local Mask HRGACCENT1 [HAE1] : Endif
If !clalev([M:HAE2]) : Local Mask HRGACCENT2 [HAE2] : Endif
#JASMI - 2017-05-17 - X3-36911 - END
#If clalev([M:HAEW])=0 : Local Mask GACCENTW   [HAEW] : Endif
#If clalev([M:VTL])=0  : Local Mask VENTILE    [VTL]  : Endif
If clalev([M:VT2])=0  : Local Mask VENTILE2   [VT2]  : Endif
Default Mask [VT2]
#Default Mask [VTL]
Default Mask [HAEF]
#Default Mask [HAEW]
Default Mask [HAE2]
Default Mask [HAE1]
#Default Mask [HAE0]
Return
# Initialisaion des variables pour le référentiel comptable
$INIVARLOC
Local Char    DACDIA(30)
Local Integer NBPLAN
Local Integer NBDIE                                : # Nb d'axes à saisir (max 20)
Local Integer TLEDTYP(1..len(mess(0,2644,1)))
Local Integer NBLEDTYP
#Local Char    PCEMTE(GLONGAU) : ## Code de la pièce d'écart de change extournée  (standard : MTE)
Local Char    TCOMPTE(GLONGAC)(1..len(mess(0,2644,1))), TPLAN(GLONCOA)(1..len(mess(0,2644,1)))
Local Char    TSAC(GLONSAC)(1..len(mess(0,2644,1)))
Local Char    TDIE(GLONDIE)(1..max(GOPTCANA,20))   : # Axes (DIE)
Local Integer TOBLIG(1..max(GOPTCANA,20))          : # Axes obligatoires (O/N)
Local Char    PLGEN(GLONCOA), PLANA(GLONCOA)
Local Char    CPTGEN(GLONGAC), CPTANA(GLONGAC)
Local Integer SUIVI
Return

# Maj des Globales lié à la Société
# Initialisation masque de référence [HAEF]
$INIPCE2
# Maj des Globales
# GNBSOC    = Nb de sociétés
# GSOC      = Table des sociétés
# GDEVSOC   = Table des devises/sociétés
# GISOC     = Indice société
# GNBSITE   = Nb de sites
# GSITE     = Table des sites
# GSOCSITE  = Tables des sociétés/site
# GFINSITE  = Table des responsabilités financières/site
# GSOCIETE  = Société courante
# GLOCALDEV = Devise courante
# GFINRSP   = Responsablilité financière courante
# GANASAI  = Paramètres de saisie analytique
Call GETSOC([F:ODP]FCY) From DEVSUB

#--- Est-ce la pièce MTC extournée ?
#PCEMTE=""
#If left$([M]REFINT,3)="MTC"
# Call PARAM([M]FCY,"GAUMTE",PCEMTE) From ADOVAL
# If PCEMTE="" : PCEMTE = "MTE" : Endif
#Endif

## Initialisation masque de référence [HAEF]
# 92876 US2690 GSCHSTDC table GDIAENTRY Transaction de saisie non défini dans HR)
#Call LEC_GDE([M]DACDIA) From CPTLEC
#If [M]AUTACE=PCEMTE
# Call INIMSKFMT3([M]FCY,2,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
#Else
 Call INIMSKFMT3([F:ODP]FCY,1,[L]DACDIA,[L]HAETYP,[L]ACCDAT,STAT) From SUBGASA
#Endif
For I=1 To [M:HAEF]NBRLED
 Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
 Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
Next
Return

