#<AdxTL>@(#)0.0.0.0 $Revision$
# Class PREQUIS_RSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ADDLINE_AFTER"           : Gosub ADDLINE_AFTER  From PREQUIS_RMET
        When "ADELLINE_AFTER"          : Gosub ADELLINE_AFTER From PREQUIS_RMET
      Endcase
    When "PSD"
      Case [L]AEVENT
        When "AREAD_AFTER"             :   Gosub PSD_AREAD_AFTER From PREQUIS_RMET
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "PSH.PSD.ITMREF" :
      Case [L]ARULE
        When "CONTROL"     : Gosub PSH_PSD_ITMREF_CONTROL    From PREQUIS_RPRO
        When "PROPAGATE"   : Gosub PSH_PSD_ITMREF_PROPAGATE  From PREQUIS_RPRO
      Endcase
    When "PSH.PSD.BPSNUM" :
      Case [L]ARULE
        When "PROPAGATE"   : Gosub PSH_PSD_BPSNUM_PROPAGATE  From PREQUIS_RPRO
      Endcase
    When "PSH.PSD.EXTRCPDAT" :
      Case [L]ARULE
        When "CONTROL"     : Gosub PSH_PSD_EXTRCPDAT_CONTROL From PREQUIS_RPRO
      Endcase
    When "PSH.PSD_EXTORDDAT" :
      Case [L]ARULE
        When "CONTROL"     : Gosub PSH_PSD_EXTORDDAT_CONTROL From PREQUIS_RPRO
      Endcase
    When "PSH.PSD.NETPRI" :
      Case [L]ARULE
        When "PROPAGATE"   : Gosub PSH_PSD_NETPRI_PROPAGATE  From PREQUIS_RPRO
      Endcase
    When "PSH.PSD.QTYPUU" :
      Case [L]ARULE
        When "PROPAGATE"   : Gosub PSH_PSD_QTYPUU_PROPAGATE  From PREQUIS_RPRO
      Endcase
  Endcase
Return

