#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################
# UTITRS006   Mise à jour de la valeur du code activité CHQ     Module TRS #
#             d'après la formule                                           #                     
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update the activity code CHQ") From LECFIC

  Call MAJ_UTITRS006(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITRS006(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTITRS006 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ACV])  =0  Local File =DOSSIER+".ACTIV"   [ACV]  : Endif
If clalev([F:ACV2]) =0  Local File =DOSSIER+".ACTIV"   [ACV2] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [ACV2]
 Readlock [ACV2]CODACT="CHQ"    
 If !fstat
  If func AFNC.ACTIV("CHQMG") | func AFNC.ACTIV("KAG")
   [F:ACV2]FLACT=2
  Else
   [F:ACV2]FLACT=1
  Endif
  Rewrite [ACV2]
  If !fstat : COMPTEUR +=1 : Endif
 Endif
Commit

Close Local File [ACV], [ACV2]

Call ECR_TRACE("UTITRS006 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif  
Call MAJ_UTITRS006(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif  
Call MAJ_UTITRS006(APPLI)
End

