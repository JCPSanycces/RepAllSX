$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(15)(0..GNBDERNIER)
Local Char     A_BUF2(40)(0..GNBDERNIER)
Local Char     A_BUF3(40)(0..GNBDERNIER)
Local Char     A_BUF4(5)(0..GNBDERNIER)
Local Char     A_BUF5(5)(0..GNBDERNIER)
Local Char     A_BUF6(5)(0..GNBDERNIER)
Local Char     A_BUF7(3)(0..GNBDERNIER)
If clalev([F:ID9])>0 : Close Local File [ID9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(15),
& Char     A_TAB2(40),
& Char     A_TAB3(40),
& Char     A_TAB4(5),
& Char     A_TAB5(5),
& Char     A_TAB6(5),
& Char     A_TAB7(3)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6,A_BUF7
& As [ID9]
Return

$LEC_DERLU
Read [ACC]CODACC = GUSER ; [F:ID]CODACS
If fstat : Raz [F:ACC] : Endif
Read [AFF]AFF0 = [F:ID]FCYORI;GPROFIL;GUSRFCT
If fstat : Raz [F:AFF] : Endif
Read [AD]AD0=[F:ID]REFNUM
If fstat : Raz [F:AD] : Endif
Read [CHD]CHD0=[F:ID]REFNUM;[F:ID]NBRCHD
If fstat : Raz [F:CHD] : Endif
Read [FCY]FCY0=[F:ID]FCYORI
If fstat : Raz [F:FCY] : Endif
Read [SRV]SRV0=[F:ID]SRV
If fstat : Raz [F:SRV] : Endif
Return

$CHARGE_DERLU
If clalev([F:ID9])>0
 Read [ID9] = [F:ID9]A_TABI
 [L]CLE = [F:ID9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:ID9])>0
 Filter [ID9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [EMP1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:ID9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:ID]REFNUM+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:ID9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:ID9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:ID]REFNUM"
Call TEXTE(10793,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:15X"
SELFOR(NBSEL) = "K:15c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]REFNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]NAM"
Call TEXTE(55,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]NAM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]SRN"
Call TEXTE(1825,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]SRN"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(4)"
SELEXP(NBSEL) = "[F:FCY]LEGCPY"
Call TEXTE(1343,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:ID]FCYORI"
Call TEXTE(9711,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]FCYORI"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]SRV"
Call TEXTE(18735,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]SRV"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]PRF"
Call TEXTE(8750,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:3X"
SELFOR(NBSEL) = "K:3X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]PRF"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:ID_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:AD])=0 : Local file EMPLOAD [AD] : Endif
If clalev([F:CHD])=0 : Local file EMPLOCHD [CHD] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:SRV])=0 : Local file SERVICE [SRV] : Endif
Link [ID] With
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [AFF]AFF0~=[F:ID]FCYORI;GPROFIL;GUSRFCT,
& [AD]AD0=[F:ID]REFNUM,
& [CHD]CHD0=[F:ID]REFNUM;[F:ID]NBRCHD,
& [FCY]FCY0=[F:ID]FCYORI,
& [SRV]SRV0=[F:ID]SRV
& As [ID_]
Return

$DEFAUT_LISTE
Default file [ID_]
Return

