Read [CHD]CHD0 = [F:ID]REFNUM;[F:ID]NBRCHD
If fstat : Raz [F:CHD] : Endif
Read [FCY]FCY0 = [F:ID]FCYORI
If fstat : Raz [F:FCY] : Endif
Read [SRV]SRV0 = [F:ID]SRV
If fstat : Raz [F:SRV] : Endif
Return

