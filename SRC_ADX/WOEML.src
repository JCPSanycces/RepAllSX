$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
NBCOND += 1
OPT(NBCOND)    = 'P'
CONDIT(NBCOND) = "FLGPAY=2"
Call TEXTE(46644,LIBOPT(NBCOND)) From OBJDIV
Call TEXTE(47969,MESSAG(NBCOND)) From OBJDIV
NBCOND += 1
OPT(NBCOND)    = 'T'
CONDIT(NBCOND) = "FLGTPS=2"
Call TEXTE(46645,LIBOPT(NBCOND)) From OBJDIV
Call TEXTE(47970,MESSAG(NBCOND)) From OBJDIV
NBCOND += 1
OPT(NBCOND)    = 'I'
CONDIT(NBCOND) = "FLGINT=2"
Call TEXTE(45114,LIBOPT(NBCOND)) From OBJDIV
Call TEXTE(47971,MESSAG(NBCOND)) From OBJDIV
OPTSEL = ''
Return

$LIBPAR
