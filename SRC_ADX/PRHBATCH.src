#<AdxTL>@(#)3.0.0.0 $Revision$  Generation liste de valeurs
######################################################################################
##  Génère les menu devise et pays
#    
#   vers:20100915 
#
###################################################################################### 

$ACTION
   Case ACTION
   When "INIT"         : Gosub XMLBATCH_INI
   When "INIT_DIA"     : Gosub XMLBATCH_DIA
   When "EXEC"         : Gosub XMLBATCH_EXECTEST
  Endcase
Return
#-----------------------------
# initialisation
#-----------------------------

$XMLBATCH_INI
Local Char FCYORG(GLONAYS)
Local Char DOSORG(GDIMFIC), MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000@XTEND ; sodaix01:5000 ; XTEND
Local Char WSTR1(200), WDES(50), WTIT(100)

Local Integer RET, WI
DOSORG = PARAM(1)
FCYORG = PARAM(2) 
Return
#-----------------------------
#Initialisation des valeurs...
#-----------------------------

$XMLBATCH_DIA
If DOSORG <> "" : [M:ZBA]DOSORG=DOSORG : Endif
If FCYORG <> "" : [M:ZBA]FCYORG=FCYORG  : Endif
Return

#-----------------------------
#Début du traitement
#-----------------------------

$XMLBATCH_EXECTEST
Local Char STRCODE(30)

If [M:ZBA]DEVISE1=2 Then
    STRCODE="PRSDEVISE"
    Call XMLGENMENU([M:ZBA]DOSORG,[M:ZBA]FCYORG,STRCODE)    
Endif

If [M:ZBA]PAYS1=2 Then
    STRCODE="PRSPAYS"
    Call XMLGENMENU([M:ZBA]DOSORG,[M:ZBA]FCYORG,STRCODE)
Endif

End


Subprog XMLGENMENU(DOSORG, FCYORG, STRCODE)       
Value Char DOSORG              # sodaix01:5000@XTEND
Value Char FCYORG              # Site Xtend
Value Char STRCODE     
Local Char STRNOMPATH(GDIMFIC)
Local Char STRNOMFICHIER(GDIMFIC)
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)
Local Char CHPCLECODE(20)
Local Char CHPCLEVALEUR(20), STRNOMTABLE(20), STRCLE1(20),STRCLE2(20)
Local Char STRIDELEM(20)
Local Char U_HEXTOTXT(250)
If clalev([F:AYC])=0 : Local File AYTMEN [AYC] : Endif

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS
Call TROUVEREP(DOSORG, FCYORG, MACORG, STRCODE, STRNOMPATH, STRNOMFICHIER)
If STRNOMPATH<>"" Then
# on récupère le fichier....
    Case STRCODE
        When "TABPAYS","PRSPAYS"
            Local File TABCOUNTRY [FMEM] 
            CHPCLECODE="CRY"
            CHPCLEVALEUR="CRYDES"
            STRNOMTABLE="TABCOUNTRY"
            STRCLE1=""
            STRCLE2=""
        When"DEVISE","PRSDEVISE" 
             Local File TABCUR [FMEM] 
            CHPCLECODE="CUR"
            CHPCLEVALEUR="INTDES"
            STRNOMTABLE="TABCUR"
            STRCLE1=""
            STRCLE2=""

    Endcase

Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=""
XT_XMLID=""
Call CREATEDIR(STRNOMPATH,STRNOMFICHIER)
 Openo STRNOMPATH+STRNOMFICHIER,0 Using [XTS]
 Iomode adxifs ""  Using [XTS]
 Iomode adxirs chr$(13)+chr$(10)  Using [XTS]
 Iomode adxium GUTF8  Using [XTS]
  
 # Génération de l'entête

 Wrseq '<?xml version="1.0" encoding="utf-8" standalone="yes" ?> ' Using [XTS]
 # Génération début  

    Local Integer WI, WNBLANFCY
    Local File AYTFCY    [AYS1] 
   
    Local Char WTABLAN(GLONLAN) (1..dim([F:AYS1]LANADS))    # Tableau des langues Xtend
    Local Char WLANDEF(GLONLAN) : WLANDEF=GLANDEF           # Langue par défaut
    Read [AYS1]AYS0 = [L]FCYORG
    For WI=0 To [F:AYS1]LANNBR-1
       If !find([F:AYS1]LANCOD(WI),WTABLAN)
           WNBLANFCY+=1
           WTABLAN(WNBLANFCY) = [F:AYS1]LANCOD(WI)
           If [F:AYS1]LANDEF=2 : WLANDEF=[F:AYS1]LANADS : Endif
       Endif
    Next


    Read [AYC]AYC0=FCYORG;STRCODE
    # ligne elmt
    XT_TY="ELMT"  : XT_ID=STRCODE
    Call LECTEXTRA(XT_VAL,"AYTMEN","INTIT",[F:AYC]FCYCOD,[F:AYC]MENCOD) From ATEXTRA : Gosub XMLF_ADD From AYTGEN

 # Champs liés par défaut
    XT_TY="TAB"   : XT_ID="FIENBR"                                            : Gosub XMLF_ADD From AYTGEN
    For WI=0 To [F:AYC]FIENBR-1
      XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
      XT_TY="COL"  : XT_ID="FIECOD"     : XT_VAL=[F:AYC]FIECOD(WI)              : Gosub XMLF_ADD From AYTGEN
    Next
    
 # Champs Code
    XT_TY="TAB"   : XT_ID="NUM10"    :  XT_VAL="Lines"                 : Gosub XMLF_ADD From AYTGEN
 # on récupère les codes...
    WC_COD=1
    For [FMEM] 
    WC_COD+=1
    WC_CODPAR= 1
    WC_VALEUR= evalue("[F:FMEM]"+CHPCLECODE)
    WC_DLKCOD="" 
    WC_FIECOD=""
    Gosub ECR_LIN From SUBAYCGEN
    Next

# Libellés
XT_TY="TAB"   : XT_ID="NUM10LAB"    :  XT_VAL="Labels"             : Gosub XMLF_ADD From AYTGEN
 WC_COD=1
Local Integer WTMPERRFLG
For [FMEM]
    WC_COD       += 1
    For WI=1 To WNBLANFCY
        WC_LIB = func MYLECTEXTRA(STRNOMTABLE,CHPCLEVALEUR,evalue("[F:FMEM]"+CHPCLECODE),STRCLE2,WTABLAN(WI),WLANDEF)
        Gosub ECRLIBS_LIN 
      
    Next
Next
Gosub $XML_TAG_CL
Wrseq XT_XML  Using [XTS]
Openo Using [XTS]
Close Local File [FMEM],[AYS1],[AYC]

Endif

End



$XML_TAG_CL         # Close TAG
Local Char XT_XML(250) 
# Modification car on ne part pas de elments mais elemt level=2
XT_J=find("",XT_TABEND(2..10))
If XT_J
 For XT_I=XT_J To 2 Step -1
    XT_XML+=XT_TABEND(XT_I)
    If XT_I<>2 : XT_XML+=chr$(13)+chr$(10) : Endif 
    XT_TABEND(XT_I)=""
 Next
Endif
Return




$ECRLIBS_LIN
    XT_TY="LIN"                                                      : Gosub XMLF_ADD From AYTGEN
    XT_TY="COL"  : XT_ID="MENCOD"     : XT_VAL=num$(WC_COD)              : Gosub XMLF_ADD From AYTGEN
    XT_TY="COL"  : XT_ID="LANCOD"     : XT_VAL=WTABLAN(WI)               : Gosub XMLF_ADD From AYTGEN
    XT_TY="COL"  : XT_ID="LANFMT" 
           U_HEXTOTXT=WC_LIB : Gosub U_TXTTOHEX From SUBAPSUTI
                                                XT_VAL=U_TXTTOHEX        : Gosub XMLF_ADD From AYTGEN
Return 


Funprog MYLECTEXTRA(TABLE,CHAMP,CLE1,CLE2,MYLANG,DEFLANG)

Value    Char    TABLE, CHAMP, CLE1, CLE2,MYLANG,DEFLANG
Local Char    VALEUR(80)
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
Read [AXX]AXX0 = TABLE;CHAMP;MYLANG;CLE1;CLE2
If fstat=0
 VALEUR = [F:AXX]TEXTE
Else 
 Read [AXX]AXX0 = TABLE;CHAMP;DEFLANG;CLE1;CLE2
 If fstat=0 
  VALEUR = [F:AXX]TEXTE 
 Else
  VALEUR = "" 
 Endif
Endif
End VALEUR


Subprog TROUVEREP(DOSORG, FCYORG, MACORG, STRCODE, STRNOMPATH, STRNOMFICHIER) 

Value Char DOSORG              # sodaix01:5000@XTEND
Value Char FCYORG              # Site Xtend
Value Char MACORG
Value Char STRCODE  
Variable Char STRNOMPATH()
Variable Char STRNOMFICHIER() 
# -------------------------------------------------------
Local Integer INTTYPE 
Local Char LANG(GLONLAN) :LANG= func SUBAYS.LANDEF(FCYORG)
If clalev([F:AYC])=0 : Local File AYTMEN [AYC] : Endif
Read [AYC]AYC0=FCYORG;STRCODE
If fstat = 0
    STRNOMFICHIER=[F:AYC]RESSUBFIC
    INTTYPE=[F:AYC]RESRAC
    STRNOMPATH=func AYTUTIA.MNL7937REP(FCYORG, LANG, INTTYPE)
Endif

End 

Subprog CREATEDIR(PATH,FIC)
Variable Char PATH
Variable Char FIC
Local Integer ERR
Local Char DIRSEP
If GOS ="dos"
  DIRSEP="\"
Else
  DIRSEP="/"
Endif
Local Char DIRUT:DIRUT=""
Local Integer WI : WI=0
If instr(1,FIC,"/")>0:DIRUT="/":Endif
If instr(1,FIC,"\")>0:DIRUT="\":Endif
If DIRUT = "" : End:Endif
Repeat
WI=instr(1,FIC,DIRUT)
If WI
  If WI<>1
    PATH+=left$(FIC,WI-1)
    PATH=filpath(PATH,"","","") 
    If filinfo(PATH,7)<0
       Call CREREP(PATH,ERR) From DOSAPL
    Endif
PATH+=DIRSEP
 Endif
 FIC=right$(FIC,WI+1)
Endif
Until WI=0
End

