#    # Si la gestion à l'affaire n'est pas active on dépositionne tout ce qui la concerne
#    # pour optimiser la suite
#    BOOPRP = [V]CST_ANO
#    BOOPRPBUD = [V]CST_ANO
#    BOOPRPTAC5 = [V]CST_ANO
#    BOOPRPTAC6 = [V]CST_ANO
#    BOOPRPTAC7 = [V]CST_ANO
