  #
  Gosub SEL_CONSTRUCT_LISTE
Return

####################################################################################################
$SEL_CONSTRUCT_LISTE
Local Integer ICRITERE
Local Char SOR(4)
Local Char SAND(5)
Local Char SOPPNUM(GLONOPP)
Local Char SPIMFCY(GLONFCY)

  Raz SAND
  ICRITERE = 1
  # ----------------------
  Gosub OPEN_TABLE
  # ----------------------
  If TABLE = "SELPJTBUD" or TABLE = "SELPJTTAC" Then
    If VALEUR <> "" Then
      SOPPNUM = func GET_OPPNUM_FROM_PIMNUM(VALEUR)
      If SOPPNUM <> "" Then
        CRITERE(ICRITERE) += SAND + "[F:PIM]OPPNUM='" + SOPPNUM + "'"
        ICRITERE += 1
        SAND = "&"
      Endif
    Endif
  Endif
  # ----------------------
  # Mail CH 12/04/2016 : on ne contrôle plus que par rapport à la société dans tous les cas
  #If MODULE = 5 or MODULE = 12 or MODULE = 13 Then
  #  Read [FCY]FCY0=SITE
  #  SPIMFCY = [F:FCY]FINRSPFCY
  #Endif
  # ----------------------
  # Issue X3-5055-119743 - 2016-11-14 by FGR : BEGIN
#  Link [PIM] With [F:OPP]OPP0=[F:PIM]OPPNUM,
#&                 [F:AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;"",
#&                 [F:FCY]FCY0=[F:PIM]FCY
#&              As [PIMX]
  If func ASYRFNC.ACTIV("PJM") Then
    Link [PIM] With [F:OPP]OPP0=[F:PIM]OPPNUM,
&                   [F:AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;"",
&                   [F:FCY]FCY0=[F:PIM]FCY,
&                   [F:PIMI]PIMI0~=[F:PIM]PIMNUM
&                As [PIMX]
  Else
    Link [PIM] With [F:OPP]OPP0=[F:PIM]OPPNUM,
&                   [F:AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;"",
&                   [F:FCY]FCY0=[F:PIM]FCY
&                As [PIMX]
  Endif
  # Issue X3-5055-119743 - 2016-11-14 by FGR : END
  # ----------------------
  Default File [PIMX]
  # --------------------------------------------
  # Mail CH 12/04/2016 : on ne contrôle plus que par rapport à la société dans tous les cas
  #If MODULE = 5 or MODULE = 12 or MODULE = 13 Then
  #  # "Ventes", "Support client", "Action commerciale"
  #  If SITE <> "" Then
  #    #CRITERE(ICRITERE) = SAND + "[F:PIM]FCY='" + SITE + "'"
  #    CRITERE(ICRITERE) += SAND + "[F:FCY]FINRSPFCY='" + SPIMFCY + "'"          # Toutes les affaires qui sont sur le même site financier
  #    SAND = "&"
  #  Endif
  #  If SOCIETE <> "" Then
  #    CRITERE(ICRITERE) += SAND + "[F:PIM]CPY='" + SOCIETE + "'"
  #    SAND = "&"
  #  Endif
  #  If SOCIETE = "" and SITE = "" Then
  #    CRITERE(ICRITERE) += SAND + "1=1"
  #    SAND = "&"
  #  Endif
  #Else
  #  # Autres modules
    If SOCIETE <> "" Then
      CRITERE(ICRITERE) = SAND + "[F:PIM]CPY='" + SOCIETE + "'"
    Else
      CRITERE(ICRITERE) = SAND + "1=1"
    Endif
  #Endif
  SAND = "&"
  # ----------------------
  If VALEUR <> AVOID.ACHAR Then
    ICRITERE += 1
    CRITERE(ICRITERE) += SAND + "[F:PIM]PIMNUM >='" + toupper(VALEUR) + "'"
  Endif
  # ----------------------
  Read [BPR]BPR0=BPR
  If [F:BPR]BETFCY <> [V]CST_AYES Then
    # Control a ne pas faire si c'est un client intersite (mail CH 12/04/2016)
    If BPR <> "" Then
      #CRITERE(ICRITERE) += SAND + "([F:OPP]OPPCMP='" + BPR + "' or [F:OPP]OPPCMP='')"
      # Issue X3-53308 - 2017-08-24 by FGR : BEGIN
      #CRITERE(ICRITERE) += SAND + "find([F:OPP]OPPCMP,'" + BPR + "','')<>0"
      Read [F:BPC]BPC0=BPR
      CRITERE(ICRITERE) += SAND + "find([F:OPP]OPPCMP,'" + BPR + "','" + [F:BPC]BPCGRU + "','')<>0"
      # Issue X3-53308 - 2017-08-24 by FGR : END
      SAND = "&"
    Endif
  Endif
  # ----------------------
  If INTERLOC <> "" Then
    #CRITERE(ICRITERE) += SAND + "([F:OPP]OPPMCN='" + INTERLOC + "' or [F:OPP]OPPMCN='')"
    CRITERE(ICRITERE) += SAND + "find([F:OPP]OPPMCN,'" + INTERLOC + "','')<>0"
    SAND = "&"
  Endif
  # ----------------------
  If BOOCRM = [V]CST_ANO and BOOPRP = [V]CST_ANO and BOOPRPBUD = [V]CST_ANO and BOOPRPTAC5 = [V]CST_ANO and BOOPRPTAC6 = [V]CST_ANO and BOOPRPTAC7 = [V]CST_ANO Then
    # Si on demande rien, on ne rend rien !
    CRITERE(ICRITERE) = SAND + "(0=1)"
    SAND = "&"
  Else
    Raz SOR
    ICRITERE += 1
    # ------------------------------------------
    # Issue X3-92891 - 2018-05-30 by FGR : BEGIN : For the next line supervisor is going to add "&" at the begining => & (& (
    #CRITERE(ICRITERE) = SAND + "("
    SOR = SAND + "("
    # Issue X3-92891 - 2018-05-30 by FGR : END
    # ------------------------------------------
    If BOOCRM = [V]CST_AYES Then
      CRITERE(ICRITERE) += SOR + "[F:PIM]PIMTYP=1"
      SOR = "|"
    Endif
    If BOOPRP = [V]CST_AYES Then
      If USEDISPRP = [V]CST_ANO Then
        CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=2 and [F:PIM]PIMSTA=2)"
      Else
        # Issue X3-5055-119743 - 2016-11-14 by FGR : BEGIN
        #CRITERE(ICRITERE) += SOR + "[F:PIM]PIMTYP=2"
        If FROMSQHSOH = [V]CST_ANO and FROMSIH = [V]CST_ANO Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=2)"
        Elsif FROMSQHSOH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=2 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]OPPSTATE<>4 and [F:PIM]OPPSTATE<>9)))"
        #Elsif FROMSIH = [V]CST_AYES Then
        # FGR 15/11/2016 : Cas impossible. Je le laisse en commentaire pour m'en souvenir. Une affaire clôturée ne peut plus être facturée
        #  CRITERE(ICRITERE) += SOR + "[F:PIM]PIMTYP=2 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]OPPSTATE=4))"
        Endif
      Endif
      SOR = "|"
    Endif
    If BOOCRM = [V]CST_AYES or BOOPRP = [V]CST_AYES Then
      #ICRITERE += 1  # Issue X3-5055-119743 - 2016-11-14 by FGR
      If USEDISPRP = [V]CST_ANO and BOOPRP = [V]CST_AYES Then
        CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=3 and [F:PIM]PIMSTA=2)"
      Else
        # Issue X3-5055-119743 - 2016-11-14 by FGR : BEGIN
        #CRITERE(ICRITERE) += SOR + "[F:PIM]PIMTYP=3"
        If FROMSQHSOH = [V]CST_ANO and FROMSIH = [V]CST_ANO Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=3)"
        Elsif FROMSQHSOH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=3 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]OPPSTATE<>4 and [F:PIM]OPPSTATE<>9)))"
        Elsif FROMSIH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=3 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]OPPSTATE=4)))"
        Endif
        # Issue X3-5055-119743 - 2016-11-14 by FGR : END
      Endif
      SOR = "|"
    Endif
    If BOOPRPBUD = [V]CST_AYES Then
      ICRITERE += 1  # Issue X3-5055-119743 - 2016-11-14 by FGR
      If USEDISBUD = [V]CST_ANO Then
        CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=4 and [F:PIM]PIMSTA=2)"
      Else
        # Issue X3-5055-119743 - 2016-11-14 by FGR : BEGIN
        #CRITERE(ICRITERE) += SOR + "[F:PIM]PIMTYP=4"
        If FROMSQHSOH = [V]CST_ANO and FROMSIH = [V]CST_ANO Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=4)"
        Elsif FROMSQHSOH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=4 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]PBUSTATE<>4 and [F:PIM]PBUSTATE<>9 and [F:PIM]OPPSTATE<>4)))"
        Elsif FROMSIH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=4 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]PBUSTATE=4 and [F:PIM]OPPSTATE<>4)))"
        Endif
        # Issue X3-5055-119743 - 2016-11-14 by FGR : END
      Endif
      SOR = "|"
    Endif
    # ----------------------------------------------------------------------
    If BOOPRPTAC5 = [V]CST_AYES Then
      ICRITERE += 1  # Issue X3-5055-119743 - 2016-11-14 by FGR
      If USEDISTAC = [V]CST_ANO Then
        CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=5 and [F:PIM]PIMSTA=2)"
      Else
        # Issue X3-5055-119743 - 2016-11-14 by FGR : BEGIN
        #CRITERE(ICRITERE) += SOR + "[F:PIM]PIMTYP=5"
        If FROMSQHSOH = [V]CST_ANO and FROMSIH = [V]CST_ANO Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=5)"
        Elsif FROMSQHSOH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=5 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]TASSTATE<>4 and [F:PIM]TASSTATE<>9 and [F:PIM]OPPSTATE<>4)))"
        Elsif FROMSIH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=5 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]TASSTATE=4 and [F:PIM]OPPSTATE<>4)))"
        Endif
        # Issue X3-5055-119743 - 2016-11-14 by FGR : END
      Endif
      SOR = "|"
    Endif
    If BOOPRPTAC6 = [V]CST_AYES Then
      ICRITERE += 1  # Issue X3-5055-119743 - 2016-11-14 by FGR
      If USEDISTAC = [V]CST_ANO Then
        CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=6 and [F:PIM]PIMSTA=2)"
      Else
        # Issue X3-5055-119743 - 2016-11-14 by FGR : BEGIN
        #CRITERE(ICRITERE) += SOR + "[F:PIM]PIMTYP=6"
        If FROMSQHSOH = [V]CST_ANO and FROMSIH = [V]CST_ANO Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=6)"
        Elsif FROMSQHSOH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=6 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]TASSTATE<>4 and [F:PIM]TASSTATE<>9 and [F:PIM]OPPSTATE<>4)))"
        Elsif FROMSIH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=6 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]TASSTATE=4 and [F:PIM]OPPSTATE<>4)))"
        Endif
        # Issue X3-5055-119743 - 2016-11-14 by FGR : END
      Endif
      SOR = "|"
    Endif
    If BOOPRPTAC7 = [V]CST_AYES Then
      ICRITERE += 1  # Issue X3-5055-119743 - 2016-11-14 by FGR
      If USEDISTAC = [V]CST_ANO Then
        CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=7 and [F:PIM]PIMSTA=2)"
      Else
        # Issue X3-5055-119743 - 2016-11-14 by FGR : BEGIN
        #CRITERE(ICRITERE) += SOR + "[F:PIM]PIMTYP=7"
        If FROMSQHSOH = [V]CST_ANO and FROMSIH = [V]CST_ANO Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=7)"
        Elsif FROMSQHSOH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=7 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]TASSTATE<>4 and [F:PIM]TASSTATE<>9 and [F:PIM]OPPSTATE<>4)))"
        Elsif FROMSIH = [V]CST_AYES Then
          CRITERE(ICRITERE) += SOR + "([F:PIM]PIMTYP=7 and (([F:PIM]PIMSTA=2) or ([F:PIM]PIMSTA=1 and [F:PIM]TASSTATE=4 and [F:PIM]OPPSTATE<>4)))"
        Endif
        # Issue X3-5055-119743 - 2016-11-14 by FGR : END
      Endif
      SOR = "|"
    Endif
    # ----------------------------------------------------------------------
    CRITERE(ICRITERE) += ")"
    SAND = "&"
  Endif
  # ----------------------
  DEFPAG = 1
  START = "[F:PIM]PIMNUM"
  ORDRE = "[F:PIM]PIMNUM"
  # ----------------------
  TIT(0) = mess(1025,196,1)
  OBJET = ""
  NBCOL = 0
  # ----------------------
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPNUM"                                 : Call TEXTFIC("PIMPL",  "OPPNUM",   1, TIT(NBCOL)) From OBJDIV
  If BOOPRPTAC5 = [V]CST_AYES or BOOPRPTAC6 = [V]CST_AYES or BOOPRPTAC7 = [V]CST_AYES Then
    NBCOL += 1 : COL(NBCOL) = "[F:PIM]TASCOD"                               : Call TEXTFIC("PJMTSK", "TASCOD",   1, TIT(NBCOL)) From OBJDIV
  Endif
  If BOOPRPBUD = [V]CST_AYES or BOOPRPTAC5 = [V]CST_AYES or BOOPRPTAC6 = [V]CST_AYES or BOOPRPTAC7 = [V]CST_AYES Then
    NBCOL += 1 : COL(NBCOL) = "[F:PIM]PBUCOD"                               : Call TEXTFIC("PJMBUD", "PBUCOD",   1, TIT(NBCOL)) From OBJDIV
  Endif
  NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"                                  : Call TEXTFIC("PIMPL",  "PIMDESAXX", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PIM]PIMTYP,2254,1)"                    : Call TEXTFIC("PIMPL",  "PIMTYP",    1, TIT(NBCOL)) From OBJDIV
  If SITE = "" Then
    # Si le site est vide, on a la société. On l'affiche
    NBCOL += 1 : COL(NBCOL) = "[F:PIM]CPY"                                  : Call TEXTFIC("PIMPL",  "CPY",       1, TIT(NBCOL)) From OBJDIV
  Endif
  If SITE <> "" Then
    # Si le site n'est pas vide, on l'affiche
    NBCOL += 1 : COL(NBCOL) = "[F:PIM]FCY"                                  : Call TEXTFIC("PIMPL",  "FCY",       1, TIT(NBCOL)) From OBJDIV
  Endif
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPCMP"                                 : Call TEXTFIC("OPPOR",  "OPPCMP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPREP"                                 : Call TEXTFIC("OPPOR",  "OPPREP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "string$([F:PIM]PIMTYP=1,'') + string$([F:PIM]PIMTYP<>1,mess([F:PIM]PIMSTA,1,1))" : Call TEXTFIC("PIMPL",  "PIMSTA",    1, TIT(NBCOL)) From OBJDIV
  #
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PIMNUM"                                 : Call TEXTFIC("PIMPL",  "PIMNUM",    1, TIT(NBCOL)) From OBJDIV
  # ----------------------
  SIZLIG = 120
  SIZCOL = 400
  # ----------------------
Return

####################################################################################################
Funprog GET_PIMSTA(NPIMTYP, NPIMSTA)
Value Decimal NPIMTYP
Value Decimal NPIMSTA

Local Char SARENDRE(GLONDES)

  Raz SARENDRE
  SARENDRE = num$(NPIMTYP) + "/" + num$(NPIMSTA) + "-"
  Case NPIMTYP
    When 2, 4, 5, 6, 7
      SARENDRE += mess(NPIMSTA,1,1)
    When 1, 3
      Raz SARENDRE
    When Default
      SARENDRE += mess(NPIMSTA,1,1)
  Endcase
End SARENDRE

####################################################################################################
$VERF_SELPJT
  # Sélection des affaires
  VALEUR = [F:PIM]PIMNUM
Return

####################################################################################################
$VERF_SELPJTBPR
$VERF_SELPJTAIN
$VERF_SELPJTBCRM
$VERF_SELPJTBPRP
$VERF_SELPJTBBUD
$VERF_SELPJTBTAC
  # Sélection des affaires
  VALEUR = [F:PIM]PIMNUM
  mkstat = 99
Return

####################################################################################################
Subprog PJT_INIT_BUTTON(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
Variable Char    AZC()
Value    Char    CODMSK
Value    Char    FLDNAM
Value    Integer NOLIG
Value    Integer MODULE
Value    Integer BOOCRM
Value    Integer BOOPRP
Value    Integer BOOPRPBUD
Value    Integer BOOPRPTAC5
Value    Integer BOOPRPTAC6
Value    Integer BOOPRPTAC7
Value    Integer USEDISPRP
Value    Integer USEDISBUD
Value    Integer USEDISTAC
Value    Char    SITE
Value    Char    BPR
Value    Char    INTERLOC
Value    Char    ZONHEAD
Value    Char    ZONDET
Value    Char    SOCIETE

Local Char SPJT(GLONPJT)
Local Char SZONPJT(GLONABR+GLONAVA+GLONAVA+4)
Local Char SZONPJTVM(GLONABR+GLONAVA+GLONAVA+4)  # Issue X3-38345 - 2017-07-28 by FGR

  Gosub OPEN_TABLE
  Gosub TRT_PJM_INACTIVE
  # -----------------
  SZONPJT = "[M:" + CODMSK + "]" + FLDNAM
  SZONPJTVM = SZONPJT                            # Issue X3-38345 - 2017-07-28 by FGR
  If func GET_BAS_TABLEAU(SZONPJT) <> "" Then
    # Si je suis dans un tableau j'ajoute l'indice
    SZONPJT += "(" + num$(NOLIG) + ")"
  Endif
  SPJT = AZC
  # -----------------
  If BOOCRM = [V]CST_ANO Then
    Raz GBOUT1
    Raz GBOUT15
  Endif
  If BOOPRP = [V]CST_ANO Then
    Raz GBOUT2
    Raz GBOUT16
  Endif
  If BOOPRPBUD = [V]CST_ANO Then
    Raz GBOUT3
    Raz GBOUT17
  Endif
  If BOOPRPTAC5 = [V]CST_ANO and BOOPRPTAC7 = [V]CST_ANO and BOOPRPTAC6 = [V]CST_ANO Then
    Raz GBOUT4
    Raz GBOUT18
  Endif
  # -------------------
  If AZC = "" Then
    # Comme les "lots budgétaires" et les "tâches affaires" sont des sous-éléments de "affaire PRP", le tunnel
    # n'est pas autorisé s'il n'y a pas de valeur dans la rubrique.
    # Lam ne saurait pas ou arriver pour afficher les fenêtres.
    Raz GBOUT3
    Raz GBOUT4
    #
    #If evalue("varmode(" + SZONPJT + ")") <> 0 Then                           # Issue X3-38345 - 2017-07-28 by FGR
    If evalue("varmode(" + SZONPJTVM + "," + num$(NOLIG) + ")") <> 0 Then      # Issue X3-38345 - 2017-07-28 by FGR
      # Comme la zone est vide :
      # Si SZONPJT n'est pas saisissable : on désactive les sélections et les tunnels
      Raz GBOUTS
      Raz GBOUT1
      Raz GBOUT2
      Raz GBOUT3
      Raz GBOUT4
      Raz GBOUT15
      Raz GBOUT16
      Raz GBOUT17
      Raz GBOUT18
      Raz GBOUT19
      Raz GBOUT20
    Endif
  Else
    #If evalue("varmode(" + SZONPJT + ")") <> 0 Then                           # Issue X3-38345 - 2017-07-28 by FGR
    If evalue("varmode(" + SZONPJTVM + "," + num$(NOLIG) + ")") <> 0 Then      # Issue X3-38345 - 2017-07-28 by FGR
      # Si SZONPJT n'est pas saisissable : on désactive les sélections
      Raz GBOUTS
      Raz GBOUT15
      Raz GBOUT16
      Raz GBOUT17
      Raz GBOUT18
      Raz GBOUT19
      Raz GBOUT20
    Endif
  Endif
  # -------------------
  If BPR = "" Then
    Raz GBOUT19
  Endif
  If INTERLOC = "" Then
    Raz GBOUT20
  Endif
  # -------------------
  # FGR 31/08/2015 : X3SUIVI110626 (début)
  #  If SPJT <> "" Then
  #    # Si le PJT est alimenté, on limite des tunnels aux enregistrements de même nature
  #    Read [PIM]PIM0=SPJT
  #    If !fstat Then
  #      If [F:PIM]PIMTYP = 1 Then
  #        Raz GBOUT2
  #        Raz GBOUT3
  #        Raz GBOUT4
  #        Raz GBOUT16
  #        Raz GBOUT17
  #        Raz GBOUT18
  #      Elsif [F:PIM]PIMTYP = 2 Then
  #        Raz GBOUT1
  #        Raz GBOUT3
  #        Raz GBOUT4
  #        Raz GBOUT15
  #        Raz GBOUT17
  #        Raz GBOUT18
  #      Elsif [F:PIM]PIMTYP = 3 Then
  #        Raz GBOUT3
  #        Raz GBOUT4
  #        Raz GBOUT17
  #        Raz GBOUT18
  #      Elsif [F:PIM]PIMTYP = 4 Then
  #        Raz GBOUT1
  #        Raz GBOUT2
  #        Raz GBOUT4
  #        Raz GBOUT15
  #        Raz GBOUT16
  #        Raz GBOUT18
  #      Elsif [F:PIM]PIMTYP = 5 or [F:PIM]PIMTYP = 6 or [F:PIM]PIMTYP = 7 Then
  #        Raz GBOUT1
  #        Raz GBOUT2
  #        Raz GBOUT3
  #        Raz GBOUT15
  #        Raz GBOUT16
  #        Raz GBOUT17
  #      Endif
  #    Endif
  #  Endif
  # FGR 31/08/2015 : X3SUIVI110626 (fin)
  If SPJT <> "" Then
      Read [PIM]PIM0=SPJT
      If !fstat Then
        If [F:PIM]PIMTYP = 1 Then
          # CRM
          Raz GBOUT2  # Tunnel GESPJM
          Raz GBOUT3  # Tunnel PJMACTBUD
          Raz GBOUT4  # Tunnel PJMACTTAS
        Elsif [F:PIM]PIMTYP = 2 Then
          # PJM
          Raz GBOUT1  # Tunnel GESOPP (CRM)
          Raz GBOUT3  # Tunnel PJMACTBUD
          Raz GBOUT4  # Tunnel PJMACTTAS
        Elsif [F:PIM]PIMTYP = 3 Then
          # MIXTE
          Raz GBOUT3  # Tunnel PJMACTBUD
          Raz GBOUT4  # Tunnel PJMACTTAS
        Elsif [F:PIM]PIMTYP = 4 Then
          # BUDGET
          Raz GBOUT1  # Tunnel GESOPP (CRM)
          Raz GBOUT4  # Tunnel PJMACTTAS         # Issue X3-106111 - 2018-08-30 by FGR
        Elsif [F:PIM]PIMTYP = 5 or [F:PIM]PIMTYP = 6 or [F:PIM]PIMTYP = 7 Then
          # TASKS
          Raz GBOUT1  # Tunnel GESOPP (CRM)
          Raz GBOUT3  # Tunnel PJMACTBUD
        Endif
      Endif
  Endif
End

####################################################################################################
Subprog PJT_CONTROL(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
Variable Char    AZC()
Value    Char    CODMSK
Value    Char    FLDNAM
Value    Integer NOLIG
Value    Integer MODULE
Value    Integer BOOCRM
Value    Integer BOOPRP
Value    Integer BOOPRPBUD
Value    Integer BOOPRPTAC5
Value    Integer BOOPRPTAC6
Value    Integer BOOPRPTAC7
Value    Integer USEDISPRP
Value    Integer USEDISBUD
Value    Integer USEDISTAC
Value    Char    SITE
Value    Char    BPR
Value    Char    INTERLOC
Value    Char    ZONHEAD
Value    Char    ZONDET
Value    Char    SOCIETE

Local Char SPJT(GLONPJT)
Local Char SCPYFCY(GLONCPY)
Local Char SCPYSITE(GLONCPY)
Local Integer ICONTROLE   # =[V]CST_ANO : SPJT inexistant => considéré comme zone texte, on ne s'en occupe pas.
                          # =[V]CST_AYES : SPJT inexistant => erreur bloquante.
                          # Par contre tous les deux cas, s'il existe, il doit respecter les règles
Local Char SPIMFCY(GLONFCY)
Local Integer ISNGDOC

  # -----------------
  Gosub OPEN_TABLE
  Gosub TRT_PJM_INACTIVE
  # -----------------
  If SOCIETE = "" and SITE <> "" Then
    SOCIETE = func GET_CPY_FROM_FCY(SITE)
  Elsif SOCIETE <> "" and SITE <> "" Then
    # Contrôle que le site est sur la bonne société
    If SOCIETE <> func GET_CPY_FROM_FCY(SITE) Then
      mkstat = 1
      GMESSAGE = mess(1073,196,1) - "'" + SITE + "'" - mess(1074,196,1) - "'" + SOCIETE + "'"
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
  Endif
  # -----------------
  If AZC = "" Then
    # Si on est en détail et que PJTSNGDOC=[V]CST_AYES, ZONDET doit être égal à ZONHEAD
    If ZONHEAD <> "" Then
      If func GET_PARAM_SOC_PJTSNGDOC(SOCIETE) = [V]CST_AYES Then
        #If evalue(ZONHEAD) <> "" Then
        If evalue("dim(" + ZONHEAD + ")") >= 0 and evalue(ZONHEAD) <> "" Then
          mkstat = 1
          GMESSAGE = mess(1047,196,1)
          GERR = 1
          GZONE = FLDNAM
          End
        Endif
      Endif
    Endif
    End  # Dans tous les cas pas la peine de faire la suite puisque AZC est vide
  Endif
  # -----------------
  SPJT = AZC
  # -----------------
  # Si on est en détail et que PJTSNGDOC=[V]CST_AYES, ZONDET doit être égal à ZONHEAD (dans tous les cas)
  If ZONHEAD <> "" Then
    If func GET_PARAM_SOC_PJTSNGDOC(SOCIETE) = [V]CST_AYES Then
      If evalue("dim(" + ZONHEAD + ")") >= 0 Then
        If evalue(ZONHEAD) <> SPJT Then
          mkstat = 1
          GMESSAGE = mess(1047,196,1) - ": '" + SPJT + "' <> '" + evalue(ZONHEAD) + "'"
          GERR = 1
          GZONE = FLDNAM
          End
        Endif
      Endif
    Endif
  Endif
  # -----------------
  ICONTROLE = [V]CST_ANO
  If MODULE = 12 or MODULE = 13 Then
    # Support client ou Action commerciale
    ICONTROLE = [V]CST_AYES  # Toujours bloquant
  Elsif MODULE = 5 Then
    # Ventes
    If GCTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif MODULE = 6 Then
    # Achats
    If GCTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif MODULE = 7 Then
    # Stock
    If GCTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif MODULE = 8 Then
    # GPAO
    If GCTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif MODULE = 9 Then
    # Tronc commun
    If GCTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif MODULE = 2 Then
    # Comptabilité
    If GCTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif MODULE = 3 Then
    # Compta tiers
    If GCTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Else
    # Ailleurs pour le moment on ne controle pas
    ICONTROLE = [V]CST_ANO
  Endif
  # -----------------
  # Issue X3-5055-119743 - 2016-11-14 by FGR : BEGIN
  #Read [PIM]PIM0=SPJT
  If func ASYRFNC.ACTIV("PJM") Then
    # Issue X3-54290 - 2017-10-04 by FGR : BEGIN
    #    Link [PIM] With [F:PIMI]PIMI0~=[F:PIM]PIMNUM
    #&                As [PIMX]
    #&              Order By Key KEY1=[F:PIM]PIMNUM
    Link [PIM] With [F:PIMI]PIMI0=[F:PIM]PIMNUM
&                As [PIMX]
&              Order By Key KEY1=[F:PIM]PIMNUM
    Read [PIMX]KEY1=SPJT
    #If [F:PIMI]PIMNUM = AVOID.ACHAR Then                            # Issue X3-82047 - 2018-03-21 by FGR
    If fstat = [V]CST_AOK and [F:PIMI]PIMNUM = AVOID.ACHAR Then      # Issue X3-82047 - 2018-03-21 by FGR
      mkstat = 1
      GMESSAGE = SPJT - ":" - mess(1023,196,1)
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
    # Issue X3-54290 - 2017-10-04 by FGR : END
  Else
    Read [PIM]PIM0=SPJT
  Endif
  # Issue X3-5055-119743 - 2016-11-14 by FGR : END
  # -----------------
  If fstat Then
    If ICONTROLE = [V]CST_AYES Then
      mkstat = 1
      GMESSAGE = SPJT - ":" - mess(1189,196,1)
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
    # -----------------
    End
  Else
    # -------------------------------------------------------------------------------------
    # Par contre à partir du moment où il existe, il doit respecter les règles.
    # -------------------------------------------------------------------------------------
    # 1°) Test si le type de [F:PIM] fait parti de ce qui est demandé
    If BOOCRM = [V]CST_ANO and [F:PIM]PIMTYP = 1 Then
      mkstat = 1
      GMESSAGE = SPJT - ":" - mess(1023,196,1)
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
    If BOOPRP = [V]CST_ANO and [F:PIM]PIMTYP = 2 Then
      mkstat = 1
      GMESSAGE = SPJT - ":" - mess(1023,196,1)
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
    If BOOCRM = [V]CST_ANO and BOOPRP = [V]CST_ANO and [F:PIM]PIMTYP = 3 Then
      mkstat = 1
      GMESSAGE = SPJT - ":" - mess(1023,196,1)
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
    If BOOPRPBUD = [V]CST_ANO and [F:PIM]PIMTYP = 4 Then
      mkstat = 1
      GMESSAGE = SPJT - ":" - mess(1023,196,1)
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
    If BOOPRPTAC5 = [V]CST_ANO and [F:PIM]PIMTYP = 5 Then
      mkstat = 1
      GMESSAGE = SPJT - ":" - mess(1023,196,1)
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
    If BOOPRPTAC6 = [V]CST_ANO and [F:PIM]PIMTYP = 6 Then
      mkstat = 1
      GMESSAGE = SPJT - ":" - mess(1023,196,1)
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
    If BOOPRPTAC7 = [V]CST_ANO and [F:PIM]PIMTYP = 7 Then
      mkstat = 1
      GMESSAGE = SPJT - ":" - mess(1023,196,1)
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
    # Issue X3-54290 - 2017-08-31 by FGR : BEGIN
    If [F:PIM]PIMTYP = 8 Then
      mkstat = 1
      GMESSAGE = SPJT - ":" - mess(1023,196,1)
      GERR = 1
      GZONE = FLDNAM
      End
    Endif
    # Issue X3-54290 - 2017-08-31 by FGR : END
    # -------------------------------------------------------------------------------------
    # 2°) Test si ce qui est inactif est autorisé
    If [F:PIM]PIMSTA = [V]CST_ANO Then
      # Issue X3-5055/119743 - 2016-11-14 by FGR : BEGIN
      #If USEDISPRP = [V]CST_ANO and ([F:PIM]PIMTYP = 2 or (BOOPRP = [V]CST_AYES and [F:PIM]PIMTYP = 3)) Then
      #  mkstat = 1
      #  GMESSAGE = SPJT - ":" - mess(1026,196,1)
      #  GERR = 1
      #  GZONE = FLDNAM
      #  End
      #Elsif USEDISBUD = [V]CST_ANO and [F:PIM]PIMTYP = 4 Then
      #  mkstat = 1
      #  GMESSAGE = SPJT - ":" - mess(1027,196,1)
      #  GERR = 1
      #  GZONE = FLDNAM
      #  End
      #Elsif USEDISTAC = [V]CST_ANO and ([F:PIM]PIMTYP = 5 or [F:PIM]PIMTYP = 6 or [F:PIM]PIMTYP = 7) Then
      #  mkstat = 1
      #  GMESSAGE = SPJT - ":" - mess(1028,196,1)
      #  GERR = 1
      #  GZONE = FLDNAM
      #  End
      #Endif
      If ([F:PIM]PIMTYP = 2 or [F:PIM]PIMTYP = 3) and
&       ((USEDISPRP = [V]CST_ANO) or
&        (USEDISPRP = [V]CST_AYES and
&          (FROMSQHSOH = [V]CST_AYES and ([F:PIM]OPPSTATE=4 or [F:PIM]OPPSTATE=9)) or
&          (FROMSIH = [V]CST_AYES and ([F:PIM]OPPSTATE<>4))
&       ))
&     Then
        mkstat = 1
        GMESSAGE = SPJT - ":" - mess(1026,196,1)
        GERR = 1
        GZONE = FLDNAM
        End
      Elsif [F:PIM]PIMTYP = 4 and
&       ((USEDISPRP = [V]CST_ANO) or
&        (USEDISPRP = [V]CST_AYES and
&          (FROMSQHSOH = [V]CST_AYES and ([F:PIM]PBUSTATE=4 or [F:PIM]PBUSTATE=9 or [F:PIM]OPPSTATE=4)) or
&          (FROMSIH = [V]CST_AYES and ([F:PIM]PBUSTATE<>4 or [F:PIM]OPPSTATE=4))
&       ))
&     Then
        mkstat = 1
        GMESSAGE = SPJT - ":" - mess(1027,196,1)
        GERR = 1
        GZONE = FLDNAM
        End
      Elsif ([F:PIM]PIMTYP = 5 or [F:PIM]PIMTYP = 6 or [F:PIM]PIMTYP = 7) and
&       ((USEDISTAC = [V]CST_ANO) or
&        (USEDISTAC = [V]CST_AYES and
&          (FROMSQHSOH = [V]CST_AYES and ([F:PIM]TASSTATE=4 or [F:PIM]TASSTATE=9 or [F:PIM]OPPSTATE=4)) or
&          (FROMSIH = [V]CST_AYES and ([F:PIM]TASSTATE<>4 or [F:PIM]OPPSTATE=4))
&       ))
&     Then
        mkstat = 1
        GMESSAGE = SPJT - ":" - mess(1028,196,1)
        GERR = 1
        GZONE = FLDNAM
        End
      Endif
      # Issue X3-5055/119743 - 2016-11-14 by FGR : END
    Endif
    # -------------------------------------------------------------------------------------
    # Mail CH 12/04/2016 : on ne contrôle plus que par rapport à la société dans tous les cas
    # 3°) Test si le site est compatible avec celui passé
    #If MODULE = 5 or MODULE = 12 or MODULE = 13 Then
    #  # On va tester uniquement le site est "site de vente"
    #  If SITE <> "" Then
    #    If [F:PIM]FCY <> SITE Then
    #      # -----------------------------------------------
    #      # Doivent être sur le même site financier
    #      Local File FACILITY [FIFCY]
    #      Read [FIFCY]FCY0=[F:PIM]FCY
    #      SPIMFCY = [F:FIFCY]FINRSPFCY
    #      Read [FIFCY]FCY0=SITE
    #      If SPIMFCY <> [F:FIFCY]FINRSPFCY Then
    #        mkstat = 1
    #        Case [F:PIM]PIMTYP
    #          When 1,2,3
    #            GMESSAGE = SITE - ":" - mess(1024,196,1)
    #          When 4
    #            GMESSAGE = SITE - ":" - mess(1030,196,1)
    #          When Default
    #            GMESSAGE = SITE - ":" - mess(1031,196,1)
    #        Endcase
    #        GERR = 1
    #        GZONE = FLDNAM
    #        End
    #      Endif
    #      # -----------------------------------------------
    #    Endif
    #  Endif
    #Endif
    # -------------------------------------------------------------------------------------
    # 4°) Test si la société est compatible avec celle passée
    If SOCIETE <> "" Then
      If [F:PIM]CPY <> SOCIETE Then
        mkstat = 1
        Case [F:PIM]PIMTYP
          When 1,2,3
            GMESSAGE = SOCIETE - ":" - mess(1078,196,1)
          When 4
            GMESSAGE = SOCIETE - ":" - mess(1079,196,1)
          When Default
            GMESSAGE = SOCIETE - ":" - mess(1080,196,1)
        Endcase
        GERR = 1
        GZONE = FLDNAM
        End
      Endif
    Endif
    # -------------------------------------------------------------------------------------
    # 5°) Test de la compatibilité avec le tiers
    If BPR <> "" Then
      Read [BPR]BPR0=BPR
      If [F:BPR]BETFCY <> [V]CST_AYES Then
        # Control a ne pas faire si c'est un client intersite (mail CH 12/04/2016)
        Read [OPP]OPP0=[F:PIM]OPPNUM
        If !fstat Then
          Read [F:BPC]BPC0=BPR                                                                     # Issue X3-53308 - 2017-08-24 by FGR
          #If [F:OPP]OPPCMP <> '' and [F:OPP]OPPCMP <> BPR Then                                    # Issue X3-53308 - 2017-08-24 by FGR
          If [F:OPP]OPPCMP <> '' and [F:OPP]OPPCMP <> BPR and [F:OPP]OPPCMP <> [F:BPC]BPCGRU Then  # Issue X3-53308 - 2017-08-24 by FGR
            mkstat = 1
            Case [F:PIM]PIMTYP
              When 1,2,3
                GMESSAGE = BPR - ":" - mess(1038,196,1)
              When 4
                GMESSAGE = BPR - ":" - mess(1039,196,1)
              When Default
                GMESSAGE = BPR - ":" - mess(1040,196,1)
            Endcase
            GERR = 1
            GZONE = FLDNAM
          Endif
        Endif
      Endif
    Endif
    # -------------------------------------------------------------------------------------
    # 6°)
    If MODULE = 6 or MODULE = 7 Then
      # Modules "Achats" ou "Stocks"
      If [F:PIM]PIMTYP = 1 Then
        # Si l'affaire n'est pas gagnée on n'a pas le droit de la prendre
        Read [OPP]OPP0=[F:PIM]OPPNUM
        Read [OPPCRM]OPPCRM0=[F:PIM]OPPNUM
        If [F:OPPCRM]OPPSTEADI = 421 Then
          # Si la table des "étapes en cours" est la 421, c'est qu'on est déjà en après-vente.
          # Donc tout va bien on peut prendre l'affaire
        Elsif [F:OPPCRM]OPPSTEADI = 400 Then
          # Si la table des "étapes en cours" est la 420, c'est pas sur qu'on est en après-vente.
          If [F:OPPCRM]OPPSTE <> "" Then
            # Si l'étape en cours à le statut N2:"5-Affaire gagnée" on peut prendre l'affaire
            Local File ATABDIV [ADI]
            Read [ADI]CODE=[F:OPPCRM]OPPSTEADI;[F:OPPCRM]OPPSTE
            If !fstat Then
              If [F:ADI]N2 <> 5 and [F:ADI]N2 <> 0 Then
                mkstat = 1
                If MODULE = 6 Then
                  GMESSAGE = mess(1075,196,1) - "'" + mess([F:ADI]N2,2973,1) + "'" - mess(1076,196,1)
                Else
                  GMESSAGE = mess(1075,196,1) - "'" + mess([F:ADI]N2,2973,1) + "'" - mess(1077,196,1)
                Endif
                GERR = 1
                GZONE = FLDNAM
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
End

####################################################################################################
Subprog PJT_BUT1_CRM(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
Variable Char    AZC()
Value    Char    CODMSK
Value    Char    FLDNAM
Value    Integer NOLIG
Value    Integer MODULE
Value    Integer BOOCRM
Value    Integer BOOPRP
Value    Integer BOOPRPBUD
Value    Integer BOOPRPTAC5
Value    Integer BOOPRPTAC6
Value    Integer BOOPRPTAC7
Value    Integer USEDISPRP
Value    Integer USEDISBUD
Value    Integer USEDISTAC
Value    Char    SITE
Value    Char    BPR
Value    Char    INTERLOC
Value    Char    ZONHEAD
Value    Char    ZONDET
Value    Char    SOCIETE

  Call OBJET("OPP", AZC, "") From GOBJET
  Gosub AFF From GSAISIE
End

####################################################################################################
Subprog PJT_BUT2_PRP(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
Variable Char    AZC()
Value    Char    CODMSK
Value    Char    FLDNAM
Value    Integer NOLIG
Value    Integer MODULE
Value    Integer BOOCRM
Value    Integer BOOPRP
Value    Integer BOOPRPBUD
Value    Integer BOOPRPTAC5
Value    Integer BOOPRPTAC6
Value    Integer BOOPRPTAC7
Value    Integer USEDISPRP
Value    Integer USEDISBUD
Value    Integer USEDISTAC
Value    Char    SITE
Value    Char    BPR
Value    Char    INTERLOC
Value    Char    ZONHEAD
Value    Char    ZONDET
Value    Char    SOCIETE

Local Instance GZINSPJM Using C_OPPOR
Local Integer MY_STATUS
Local Char SPROJECT(GLONOPP)
If dim(GLONPBU) > 0 Then     # Issue X3-52214 - 2017-08-28 by FGR
  Local Char SBUDGET(GLONPBU)
Else
  Local Char SBUDGET(GLONVCR)
Endif
If dim(GLONTAC) > 0 Then     # Issue X3-52214 - 2017-08-28 by FGR
  Local Char STASK(GLONTAC)
Else
  Local Char STASK(GLONVCR)
Endif

  GZINSPJM = NewInstance C_OPPOR AllocGroup null
  GZINSPJM.TCHTOREAD = "PJM"
  # 3°) Split AZC key received
  [L]MY_STATUS = fmet GZINSPJM.PJM_KEY_SPLIT("", AZC, SPROJECT, SBUDGET, STASK)
  # --------------------------------------------
  Call OBJET("PJM", SPROJECT, "") From GOBJET
  Gosub AFF From GSAISIE
  # --------------------------------------------
  If GZINSPJM <> null Then
    FreeGroup GZINSPJM
  Endif
  # --------------------------------------------
End

####################################################################################################
Subprog PJT_BUT3_PRPBUD(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
Variable Char    AZC()
Value    Char    CODMSK
Value    Char    FLDNAM
Value    Integer NOLIG
Value    Integer MODULE
Value    Integer BOOCRM
Value    Integer BOOPRP
Value    Integer BOOPRPBUD
Value    Integer BOOPRPTAC5
Value    Integer BOOPRPTAC6
Value    Integer BOOPRPTAC7
Value    Integer USEDISPRP
Value    Integer USEDISBUD
Value    Integer USEDISTAC
Value    Char    SITE
Value    Char    BPR
Value    Char    INTERLOC
Value    Char    ZONHEAD
Value    Char    ZONDET
Value    Char    SOCIETE

Local Char VALBOUT(250), PARBOUT(250)(1..20)
Local Integer MY_STATUS
Local Char SPROJECT(GLONOPP)
If dim(GLONPBU) > 0 Then     # Issue X3-52214 - 2017-08-28 by FGR
  Local Char SBUDGET(GLONPBU)
Else
  Local Char SBUDGET(GLONVCR)
Endif
If dim(GLONTAC) > 0 Then     # Issue X3-52214 - 2017-08-28 by FGR
  Local Char STASK(GLONTAC)
Else
  Local Char STASK(GLONVCR)
Endif

  #  PARBOUT(1) = AZC
  #  PARBOUT(2) = SITE
  #  PARBOUT(3) = "0"
  #  PARBOUT(4) = "0"
  #  PARBOUT(5) = "TRTBOPBU"
  #  FLGEXE = 1
  #  GACTION = "PRPACTBUD"
  #  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPRPACTBUD","PRPACTBUD","") From GSAISIE
  #  AZC = PARBOUT(1)
  # --------------------------------------------
  # 1°) Check that we are not in GESPJM function
  If dim(GZINSPJM) >= 0 Then
    GMESSAGE = mess(116,126,1)
    GOK = 1
    GERR = 1
    End
  Endif
  # --------------------------------------------
  # 2°) Global declaration and Read the project
Global Instance GZINSPJM Using C_OPPOR

  GZINSPJM = NewInstance C_OPPOR AllocGroup null
  GZINSPJM.TCHTOREAD = "PJM"
  # 3°) Split AZC key received
  [L]MY_STATUS = fmet GZINSPJM.PJM_KEY_SPLIT("", AZC, SPROJECT, SBUDGET, STASK)
  #
  [L]MY_STATUS = fmet GZINSPJM.AREAD(SPROJECT)
  If [L]MY_STATUS >= [V]CST_AERROR Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
    GOK = 0
    GERR = 1
    # -------------------
    If GZINSPJM <> null Then
      FreeGroup GZINSPJM
    Endif
    Kill GZINSPJM
    # -------------------
    End
  Endif
  # --------------------------------------------
  # 4°) Tunnel to the windows
  PARBOUT(1) = AZC
  PARBOUT(2) = SBUDGET
  FLGEXE = 1
  GACTION = "PJMACTBUD"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMACTBUD","PJMACTBUD","") From GSAISIE
  AZC = PARBOUT(1)
  # --------------------------------------------
  # 5°) Freegroup and kill the global
  If GZINSPJM <> null Then
    FreeGroup GZINSPJM
  Endif
  Kill GZINSPJM
  # --------------------------------------------
End

####################################################################################################
Subprog PJT_BUT4_PRPTAC(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
Variable Char    AZC()
Value    Char    CODMSK
Value    Char    FLDNAM
Value    Integer NOLIG
Value    Integer MODULE
Value    Integer BOOCRM
Value    Integer BOOPRP
Value    Integer BOOPRPBUD
Value    Integer BOOPRPTAC5
Value    Integer BOOPRPTAC6
Value    Integer BOOPRPTAC7
Value    Integer USEDISPRP
Value    Integer USEDISBUD
Value    Integer USEDISTAC
Value    Char    SITE
Value    Char    BPR
Value    Char    INTERLOC
Value    Char    ZONHEAD
Value    Char    ZONDET
Value    Char    SOCIETE

Local Char VALBOUT(250), PARBOUT(250)(1..20)
Local Integer MY_STATUS
Local Char SPROJECT(GLONOPP)
If dim(GLONPBU) > 0 Then     # Issue X3-52214 - 2017-08-28 by FGR
  Local Char SBUDGET(GLONPBU)
Else
  Local Char SBUDGET(GLONVCR)
Endif
If dim(GLONTAC) > 0 Then     # Issue X3-52214 - 2017-08-28 by FGR
  Local Char STASK(GLONTAC)
Else
  Local Char STASK(GLONVCR)
Endif

  #  PARBOUT(1) = AZC
  #  PARBOUT(2) = SITE
  #  PARBOUT(3) = "0"
  #  PARBOUT(4) = "0"
  #  PARBOUT(5) = "TRTBOTAC"
  #  FLGEXE = 1
  #  GACTION = "OACTTAS"
  #  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OACTTAS","OACTTAS","") From GSAISIE
  #  AZC = PARBOUT(1)
  # --------------------------------------------
  # 1°) Check that we are not in GESPJM function
  If dim(GZINSPJM) >= 0 Then
    GMESSAGE = mess(116,126,1)
    GOK = 1
    GERR = 1
    End
  Endif
  # --------------------------------------------
  # 2°) Global declaration and Read the project
Global Instance GZINSPJM Using C_OPPOR

  GZINSPJM = NewInstance C_OPPOR AllocGroup null
  GZINSPJM.TCHTOREAD = "PJM"
  # 3°) Split AZC key received
  [L]MY_STATUS = fmet GZINSPJM.PJM_KEY_SPLIT("", AZC, SPROJECT, SBUDGET, STASK)
  #
  [L]MY_STATUS = fmet GZINSPJM.AREAD(SPROJECT)
  If [L]MY_STATUS >= [V]CST_AERROR Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
    GOK = 0
    GERR = 1
    # -------------------
    If GZINSPJM <> null Then
      FreeGroup GZINSPJM
    Endif
    Kill GZINSPJM
    # -------------------
    End
  Endif
  # --------------------------------------------
  # 4°) Tunnel to the windows
  PARBOUT(1) = AZC
  PARBOUT(2) = STASK
  FLGEXE = 1
  GACTION = "PJMACTTAS"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMACTTAS","PJMACTTAS","") From GSAISIE
  AZC = PARBOUT(1)
  # --------------------------------------------
  # 5°) Freegroup and kill the global
  If GZINSPJM <> null Then
    FreeGroup GZINSPJM
  Endif
  Kill GZINSPJM
  # --------------------------------------------
End

##################################################
Subprog PJT_BEFORE_ZONE(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
Variable Char    AZC()
Value    Char    CODMSK
Value    Char    FLDNAM
Value    Integer NOLIG
Value    Integer MODULE
Value    Integer BOOCRM
Value    Integer BOOPRP
Value    Integer BOOPRPBUD
Value    Integer BOOPRPTAC5
Value    Integer BOOPRPTAC6
Value    Integer BOOPRPTAC7
Value    Integer USEDISPRP
Value    Integer USEDISBUD
Value    Integer USEDISTAC
Value    Char    SITE
Value    Char    BPR
Value    Char    INTERLOC
Value    Char    ZONHEAD
Value    Char    ZONDET
Value    Char    SOCIETE

  If ZONHEAD <> "" or ZONDET <> "" Then
    # Ces deux paramètres ne peuvent être alimentés en même temps
    If ZONHEAD <> "" and ZONDET <> "" Then
      GMESSAGE = mess(1034,196,1)
      GOK = 1
      GERR = 1
      End
    Endif
    # ZONHEAD doit correspondre à une rubrique qui existe
    If ZONHEAD <> "" Then
      If evalue("dim(" + ZONHEAD + ")") < 0 Then
        GMESSAGE = mess(1035,196,1)
        GOK = 1
        GERR = 1
        End
      Endif
    Endif
    # ZONDET doit correspondre à une rubrique qui existe
    If ZONDET <> "" Then
      If evalue("dim(" + ZONDET + ")") < 0 Then
        GMESSAGE = mess(1036,196,1)
        GOK = 1
        GERR = 1
        End
      Endif
    Endif
  Endif
End

####################################################################################################
Subprog PJT_AFTER_MODIFY(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
Variable Char    AZC()
Value    Char    CODMSK
Value    Char    FLDNAM
Value    Integer NOLIG
Value    Integer MODULE
Value    Integer BOOCRM
Value    Integer BOOPRP
Value    Integer BOOPRPBUD
Value    Integer BOOPRPTAC5
Value    Integer BOOPRPTAC6
Value    Integer BOOPRPTAC7
Value    Integer USEDISPRP
Value    Integer USEDISBUD
Value    Integer USEDISTAC
Value    Char    SITE
Value    Char    BPR
Value    Char    INTERLOC
Value    Char    ZONHEAD
Value    Char    ZONDET
Value    Char    SOCIETE

Local Char SBASTAB(GLONABR+GLONAVA+4)
Local Char STRTMODULE(GLONADC)
Local Integer ITRTMODULE
Local Char PJTACTION(GLONDCO)
# Issue X3-66544 - 2017-11-29 by FGR : BEGIN
Local Char    WCCEMSK(GLONABR)              # Nom de l'écran des sections à initialiser/Dimension screen name
Local Char    WCCEZON(GLONABR+GLONAVA+4)    # Nom du champ de la section à initialiser/Dimension field name
Local Integer WNOLIGN                       # Indice de la ligne/ line indice
Local Char    WVALPJT(GLONPJT)
# Issue X3-66544 - 2017-11-29 by FGR : END

  # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)
  # Nécessaire dès le début/Necessary from the beginning
  Call TRAITEMENT_MODULE(MODULE, STRTMODULE, ITRTMODULE)
  # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)
  If ZONDET <> "" Then
    # Si ZONDET est alimenté : c'est qu'on est sur l'entête.
    # Appliquer les règles de report de modifications sur les détail
    # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)
    # Initialisation de la section anaylitique de l'entête d'un document
    # Dimension initialization for the header document
    Gosub PJT_INIT_CCEH
    # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)
    SBASTAB = func GET_BAS_TABLEAU(ZONDET)
    # FGR 19/08/2013 : test avec Sylvie (début)
    If SITE = "" Then
      SITE = GFCY
    Endif
    # FGR 19/08/2013 : test avec Sylvie (fin)
    If func GET_PARAM_PJTSNGDOC(SITE) = [V]CST_AYES Then
      # Si ZONDET n'est pas saisissable, il reçoit la valeur AZC (qu'elle soit vide ou non : elle a pu en avoir un puis ne plus l'avoir)
      # Comme il n'est pas saisissable, il a forcément toujours eu la même valeur que l'entête

      # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/29/17)
      # Le sous-pro EXEC_PJTREPEAT_OUI utilise ces globales déclarées ds l'action PJTREPEAT (qui appelle le sous-pro EXEC_PJTREPEAT_OUI)
      # Si appel direct du sous-pro il faut les déclarer
      # The sub-prog EXEC_PJTREPEAT_OUI uses these globals declared in the action PJTREPEAT (which calls the sub-prog EXEC_PJTREPEAT_OUI)
      # If direct call it is necessary to declare them
      Global Char GSTRTMODULE(GLONADC)
      Global Integer GITRTMODULE
      GSTRTMODULE = STRTMODULE
      GITRTMODULE = ITRTMODULE
      # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/29/17)
      Call EXEC_PJTREPEAT_OUI(SBASTAB, ZONDET, AZC) From TRTPJTREP
      # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/29/17)
      # L'action PJTREPEAT (qui appelle le sous-pro EXEC_PJTREPEAT_OUI) fait le kill
      # Si appel direct du sous-pro il faut les killer
      # The action PJTREPEAT (which calls the sub-prog EXEC_PJTREPEAT_OUI) does the kill
      # If direct call it is necessary to kill them
      Kill GSTRTMODULE
      Kill GITRTMODULE
      # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/29/17)
    Else
      # Si ZONDET est saisissable, il faut poser la question sur la façon de reporter la modification sur les lignes.
      # Attention : Il peut ne pas encore y avoir de ligne. Ne poser la question que s'il y en a.
      If SBASTAB <> "" Then
        If evalue(SBASTAB) > 0 Then
          # Il y a des lignes dans le tableau : on va proposer le report de l'entête
          Call ACTION_PJTREPEAT(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
        Endif
      Else
        # Cas où le détail n'est pas dans un tableau.
        Call ACTION_PJTREPEAT(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
      Endif
    Endif
  Endif
  # ----------------------------------------------------
  If ZONHEAD <> "" Then
    # Si ZONHEAD est alimenté : c'est qu'on est sur le détail
    # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)
    # Code activité PJM actif et il existe un axe géré à l'affaire
    # Active activity code PJM and a dimension type is managed by project
    If func ASYRFNC.ACTIV("PJM") & GPJMDIE <> "" Then
        # Alimenter [M]DPJT avec la nouvelle valeur zc car l'initialisation des sections INIT_CCE utilise [M]DPJT
        # [M]DPJT is loaded with the new value zc because dimension initialization INIT_CCE uses [M]DPJT
        #WVALPJT = evalue ("[M:"+CODMSK+"]"+FLDNAM)+"(nolign-1)"     # Issue X3-66544 - 2017-11-29 by FGR
        WVALPJT = evalue("[M:"+CODMSK+"]"+FLDNAM+"(nolign-1)")       # Issue X3-66544 - 2017-11-29 by FGR
        Assign "[M:"+CODMSK+"]"+FLDNAM+"(nolign-1)" With AZC
        WNOLIGN = nolign
        WCCEMSK = CODMSK
        # Initialisation de la section anaylitique d'une ligne de document /Dimension initialization for the line document
        Gosub PJT_INIT_CCED
        If WCCEZON <> "" Then
            # Le nom du champ a été initialisé dans PJT_INIT_CCED car il existe bien un n° d'axe correspondant à l'axe géré à l'affaire
            # Field name has been initialized in PJT_INIT_CCED because there is a dimension type number tied to the dimension managed by projetc
            # Seul moyen que j'ai trouvé pour faire l'affzo ...
            # Only mean found to do the affzo ...
            Gosub OPEN_FILE From TRTPJTREP
            Wrseq "Affzo " + WCCEZON + "(" + num$([L]WNOLIGN-1) + ")" Using [FPJT]
            Gosub CLOSE_FILE From TRTPJTREP
        Endif
        # Réalimenter [M]DPJT avec l'ancienne valeur
        # [M]DPJT is reloaded with the old value
        Assign "[M:"+CODMSK+"]"+FLDNAM+"(nolign-1)" With WVALPJT
    Endif
    # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)
  Endif
  # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
  If ZONDET = "" and ZONHEAD = "" Then
    # Cas particuliers / Particular cases
    # Cas où on est pas sur un document classique avec PJT sur entête/ligne / Case we are not on a classic document with PJT on header and lines
    # Initialisation de la section anaylitique / Dimension initialization
    Gosub PJT_INIT_CCEH
    # Code activité PJM actif et il existe un axe géré à l'affaire
    # Active activity code PJM and a dimension type is managed by project
    If func ASYRFNC.ACTIV("PJM") & GPJMDIE <> "" Then
      # On veut initialiser les sections sur les lignes/We want to initialize dimensions on the lines
      # WPJT_INIT_CCED doit être renseigné dans GET_PARAM_CCEH appelé dans PJT_INIT_CCEH
      # WPJT_INIT_CCED has to be initialized in GET_PARAM_CCEH called in PJT_INIT_CCEH
      If WPJT_INIT_CCED = 2 Then
        If SITE = "" Then
          SITE = GFCY
        Endif
        # Le sous-pro EXEC_PJTREPEAT_INIT_CCED utilise ces globales comme le sous-pro EXEC_PJTREPEAT_OUI
        # The sub-prog EXEC_PJTREPEAT_INIT_CCED uses these globals like the sub-prog EXEC_PJTREPEAT_OUI
        Global Char GSTRTMODULE(GLONADC)
        Global Integer GITRTMODULE
        GSTRTMODULE = STRTMODULE
        GITRTMODULE = ITRTMODULE
        # Alimenter [M]DPJT avec la nouvelle valeur zc car l'initialisation des sections INIT_CCE utilise [M]DPJT
        # [M]DPJT is loaded with the new value zc because dimension initialization INIT_CCE uses [M]DPJT
        WVALPJT = evalue ("[M:"+CODMSK+"]"+FLDNAM)
        Assign "[M:"+CODMSK+"]"+FLDNAM With AZC
        If SBASTAB <> "" Then
          Call EXEC_PJTREPEAT_INIT_CCED(SBASTAB, ZONDET, AZC) From TRTPJTREP
        Endif
        # End issue X3-3808
        # Réalimenter [M]DPJT avec l'ancienne valeur
        # [M]DPJT is reloaded with the old value
        Assign "[M:"+CODMSK+"]"+FLDNAM With WVALPJT
        # L'action PJTREPEAT (qui appelle le sous-pro EXEC_PJTREPEAT_OUI) fait le kill
        # Si appel direct du sous-pro il faut les killer
        # The action PJTREPEAT (which calls the sub-prog EXEC_PJTREPEAT_OUI) does the kill
        # If direct call it is necessary to kill them
        Kill GSTRTMODULE
        Kill GITRTMODULE
      Endif
    Endif
  Endif
  # X3-3808  : Update project dimension on sales documents / X3-53490 (LD 09/01/17)
  # ----------------------------------------------------
  # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)
  # As été déplacé au début/Has been moved at the beginning
  #Call TRAITEMENT_MODULE(MODULE, STRTMODULE, ITRTMODULE)
  # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)
  If ITRTMODULE = [V]CST_AYES Then
    PJTACTION = "PJT_AFTER_MODIFY"
    Gosub ACTION From =STRTMODULE
  Endif
End

####################################################################################################
# X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)
# ---------------------------------------------------------------------------------------------
# Initialisation de la section anaylitique de l'entête d'un document
# Dimension initialization for a header document
# ---------------------------------------------------------------------------------------------
$PJT_INIT_CCEH
Local Integer WPJT_INIT_CCEH                 : # Flag init section à l'entête (1 Non/2 Oui)/Flag for init header dimension (1 No/2 Yes)
Local Integer WPJT_INIT_CCED                 : # Flag init section à la ligne (1 Non/2 Oui)/Flag for init line dimension (1 No/2 Yes)
Local Char    WCCEBASTAB(GLONABR+GLONAVA+4)  : # Nom de la variable bas de tableau des sections/Grid variable dimension name
Local Char    WCCEMSK(GLONABR)               : # Nom de l'écran des sections/Dimension screen name
Local Char    WCCEFIC(GLONABR)               : # Nom du fichier des sections/Dimension file screen name
Local Char    WCCEZON(GLONABR+GLONAVA+4)     : # Nom du champ section/Dimension field name
Local Char    WCCESECDEF(GLONCDE)            : # Section par défaut/Default dimension
Local Integer WNBAXE
Local Char    WSECTION(GLONCCE)
Local Char    WVALPJT(GLONPJT)

  WPJT_INIT_CCEH = 1
  WPJT_INIT_CCED = 1
  # Code activité PJM actif/Active activity code PJM
  If !func ASYRFNC.ACTIV("PJM") Then
    Return
  Endif
  # Il existe un axe géré à l'affaire/A dimension type is managed by project
  If GPJMDIE = "" Then
    Return
  Endif
  # Alimentation des paramètres nécessaires/Supply of necessary parameters
  If dim(ITRTMODULE) > 0 and ITRTMODULE = [V]CST_AYES and dim(STRTMODULE) > 0 Then
    Gosub GET_PARAM_CCEH From =STRTMODULE
  Endif
  If WPJT_INIT_CCEH = 1 Then
    Return
  Endif
  # On veut initialiser les sections sur l'entête/We want to initialize dimensions on the header
  # WPJT_INIT_CCEH doit être renseigné dans GET_PARAM_CCEH
  # WPJT_INIT_CCEH has to be initialized in GET_PARAM_CCEH
  If WCCEBASTAB <> "" Then
    # Le nom de la variable de bas de tableau est bien alimenté/The grid variable dimension name is well supplied
    If evalue ("dim(" + WCCEBASTAB + ")") > 0 Then
      WCCEMSK = func TRTPJT.GET_ABRMSK(WCCEBASTAB)
      WNBAXE = evalue (WCCEBASTAB)
      If WNBAXE > 0 Then
        # Il y a des axes / Dimension types exist
        Local Char WDIE(GLONDIE)(1..WNBAXE)
        # Retrouver l'indice de l'axe / It is necessary to find the dimension type indice
        #WI=find(GPJMDIE,evalue("[M:"+[L]WCCEMSK+"]DIE(0..WNBAXE-1)"))
        #WI=find(GPJMDIE,[M:SOH3]DIE(0..WNBAXE-1))
        WI = evalue("find(GPJMDIE, [M:"+[L]WCCEMSK+"]DIE(0..WNBAXE-1))")
        If WI > 0 Then
          # Alimenter [M]PJT avec la nouvelle valeur zc car l'initialisation des sections INISEC utilise [M]PJT
          # [M]PJT is loaded with the new value zc because dimension initialization INISEC uses [M]PJT
          WVALPJT = evalue ("[M:"+CODMSK+"]"+FLDNAM)
          Assign "[M:"+CODMSK+"]"+FLDNAM With AZC
          WCCEZON = "[M:"+[L]WCCEMSK+"]CCE"+"([L]WI-1)"
          Assign WCCEZON With ""
          Call INISEC([L]WSECTION,WCCESECDEF,GPJMDIE) From SUBCDE
          Assign WCCEZON With [L]WSECTION
          WCCEZON = "[M:"+[L]WCCEMSK+"]CCE"
          # Seul moyen que j'ai trouvé pour faire l'affzo ...
          # Only mean I found to do the affzo
          Gosub OPEN_FILE From TRTPJTREP
          Wrseq "Affzo " + WCCEZON + "(" + num$([L]WI-1) + ")" Using [FPJT]
          Gosub CLOSE_FILE From TRTPJTREP
          # Réalimenter [M]PJT avec l'ancienne valeur pour que le répercussion entête ligne fonctionne
          # [M]PJT is reloaded with the old value in order that repercussion header line works
          Assign "[M:"+CODMSK+"]"+FLDNAM With WVALPJT
        Endif
      Endif
    Endif
  # Issue X3-3807 - 2017-12-04 by MUARN : lignes tarifaires commande ouverte achats / Open order, for Price lines From Open order
  Elsif CODMSK = "POC2PWP"
    WPJMDIENUM = find(GPJMDIE,GDIE(1..GNBDIE))
    If WPJMDIENUM = 0 | WPJMDIENUM > GNBDIE
      Return
    Endif
    WCCEZON = "[F:PWP]CCE"+num$(WPJMDIENUM)
    Assign WCCEZON With ""
    Call INIT_CCE(WSECTION,WPJMDIENUM,WCCESECDEF,"",0) From TRTX3CPT
    Assign WCCEZON With [L]WSECTION
  Elsif WCCEFIC <> "" Then
    # Travail avec une classe [F]/Work with [F]
    # Le nom de la classe [F] est bien alimenté/The file name is well supplied
    WNBAXE = evalue("dim(" + WCCEFIC + "CCE)")
    If WNBAXE > 0 Then
      # Il y a des axes / Dimension types exist
      Local Char WDIE(GLONDIE)(1..WNBAXE)
      # Retrouver l'indice de l'axe / It is necessary to find the dimension type indice
      # Issue 75435
      #WI = find(GPJMDIE,evalue([L]WCCEFIC+"DIE(0..WNBAXE-1)"))
      WI = evalue("find(GPJMDIE,"+[L]WCCEFIC+"DIE(0..WNBAXE-1))")
      # End issue 75435
      If WI > 0 Then
        WCCEZON = [L]WCCEFIC+"CCE"+"([L]WI-1)"
        Assign WCCEZON With ""
        Call INISEC([L]WSECTION,WCCESECDEF,GPJMDIE) From SUBCDE
        Assign WCCEZON With [L]WSECTION
      Endif
    Endif
  Endif
Return
# X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/02/17)

####################################################################################################
# X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)
# ---------------------------------------------------------------------------------------------
# Initialisation de la section anaylitique d'une ligne de document
# Dimension initialization for a line document
# ---------------------------------------------------------------------------------------------
$PJT_INIT_CCED
Local Integer WPJT_INIT_CCED                 : # Flag init section à la ligne (1 Non/2 Oui)/Flag for init line dimension (1 No/2 Yes)
Local Char    WCCESECDEF(GLONCDE)            : # Section par défaut/Default dimension
Local Char    WSECTION(GLONCCE)
Local Integer WPJMDIENUM                     : # N° de l'axe géré à l'affaire/Number of dimension type managed by project
Local Integer WSVGNOLIGN : WSVGNOLIGN=nolign

  # Ctrl Code activité PJM actif déjà vérifié dans l'étiquette appelante
  # Active activity code PJM already verified in the calling label
  # Existence de l'axe géré à l'affaire déjà vérifié dans l'étiquette appelante
  # Existence of the dimension type managed by project already verified in the calling label
  WPJT_INIT_CCED = 1
  # Alimentation des paramètres nécessaires/Supply of necessary parameters
  If dim(ITRTMODULE) > 0 and ITRTMODULE = [V]CST_AYES and dim(STRTMODULE) > 0 Then
    Gosub GET_PARAM_CCED From =STRTMODULE
  Endif
  If WPJT_INIT_CCED = 1 Then
    Return
  Endif
  # On veut initialiser les sections sur les lignes/We want to initialize dimensions on the lines
  # WPJT_INIT_CCED doit être renseigné dans GET_PARAM_CCED appelé
  # WPJT_INIT_CCED has to be initialized in GET_PARAM_CCED called
  # Récupérer le n° de l'axe/Search for the dimension type number
  WPJMDIENUM = find(GPJMDIE,GDIE(1..GNBDIE))
  If WPJMDIENUM = 0 or WPJMDIENUM > GNBDIE Then
    Return
  Endif
  # Alimentation de nolign car l'initialisation des sections INIT_CCE travaille avec nolign
  # nolign is loaded because dimension initialization INIT_CCE works with nolign
  nolign = [L]WNOLIGN
  WCCEZON = "[M:" + [L]WCCEMSK + "]CCE" + num$(WPJMDIENUM) + "(" + num$([L]WNOLIGN-1) + ")"
  Assign WCCEZON With ""
  Call INIT_CCE(WSECTION, WPJMDIENUM, WCCESECDEF, "", 0) From TRTX3CPT
  Assign WCCEZON With [L]WSECTION
  WCCEZON = "[M:" + [L]WCCEMSK + "]CCE" + num$(WPJMDIENUM)
 nolign = WSVGNOLIGN
Return
# X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)

####################################################################################################
Subprog ACTION_PJTREPEAT(AZC,CODMSK,FLDNAM,NOLIG,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
Variable Char    AZC()
Value    Char    CODMSK
Value    Char    FLDNAM
Value    Integer NOLIG
Value    Integer MODULE
Value    Integer BOOCRM
Value    Integer BOOPRP
Value    Integer BOOPRPBUD
Value    Integer BOOPRPTAC5
Value    Integer BOOPRPTAC6
Value    Integer BOOPRPTAC7
Value    Integer USEDISPRP
Value    Integer USEDISBUD
Value    Integer USEDISTAC
Value    Char    SITE
Value    Char    BPR
Value    Char    INTERLOC
Value    Char    ZONHEAD
Value    Char    ZONDET
Value    Char    SOCIETE

  If !GWEBSERV Then
    ## Action PJTREPEAT
    Local Char PARMSK(250)(1..20), SAVACT(20)

    SAVACT = GACTION
    GACTION = "PJTREPEAT"
    # --------------------------
    PARMSK(1) = CODMSK
    PARMSK(2) = FLDNAM
    PARMSK(3) = num$(NOLIG)
    PARMSK(4) = num$(MODULE)
    PARMSK(5) = num$(BOOCRM)
    PARMSK(6) = num$(BOOPRP)
    PARMSK(7) = num$(BOOPRPBUD)
    PARMSK(8) = num$(BOOPRPTAC5)
    PARMSK(9) = num$(BOOPRPTAC6)
    PARMSK(10) = num$(BOOPRPTAC7)
    PARMSK(11) = num$(USEDISPRP)
    PARMSK(12) = num$(USEDISBUD)
    PARMSK(13) = num$(USEDISTAC)
    PARMSK(14) = SITE
    PARMSK(15) = BPR
    PARMSK(16) = INTERLOC
    PARMSK(17) = ZONHEAD
    PARMSK(18) = ZONDET
    # --------------------------
    Call TRAITE_CHAR(AZC, PARMSK, "", "TRTPJTREP", "DPJTREPEAT", 4, "") From GTRAITE
    GACTION = SAVACT
    If mkstat Then
      GERR = 1
      GZONE = FLDNAM
      #GZNUM = 3676
    Endif
  Endif
  Gosub AFF From GSAISIE
End

####################################################################################################
Subprog ACTION_PJTQUESTIO(ACTION, MODULE)
Variable Char    ACTION()
Value    Integer MODULE

  If !GWEBSERV Then
    ## Action PJTREPEAT
    Local Char PARMSK(250)(1..20), SAVACT(20)
    Local Char AZC(250)

    SAVACT = GACTION
    GACTION = "PJTQUESTIO"
    # --------------------------
    PARMSK(1) = ACTION
    PARMSK(2) = num$(MODULE)
    Call TRAITE_CHAR(AZC, PARMSK, "", "TRTPJTREP", "DPJTREPEAT", 4, "") From GTRAITE
    GACTION = SAVACT
    If mkstat Then
      GERR = 1
      GZONE = FLDNAM
      #GZNUM = 3676
    Else
      ACTION = PARMSK(1)
    Endif
  Endif
  Gosub AFF From GSAISIE
End

####################################################################################################
Subprog PJT_MODFCY(AZC,ZONDET)
Variable Char    AZC()
Value    Char    ZONDET

Local Integer IPJTSNGDOC
Local Char PARAM2(GLONADP)
Local Char SOBJET(GLONAOB)
Local Char SABRMSK(GLONABR)
Local Char SCODZON(GLONAVA)
Local Integer NI
Local Integer NTROUVE

  If !GIMPORT Then
    IPJTSNGDOC = func GET_PARAM_PJTSNGDOC(AZC)
    If IPJTSNGDOC = [V]CST_AYES Then
      # On n'autorise pas d'avoir des affaires différentes sur la même pièce...
      If evalue("varmode(" + ZONDET + ")") = 0 Then
        # ...Donc si le PJT détail est saisissable : on le rend non saisissable
        # -----------------------------------------------------------------------
        Gosub OPEN_FILE From TRTPJTREP
        Wrseq "Grizo " + ZONDET Using [FPJT]
        Gosub CLOSE_FILE From TRTPJTREP
      Endif
    Else
      # On autorise d'avoir des affaires différentes sur la même pièces...
      If evalue("varmode(" + ZONDET + ")") <> 0 and evalue("varmode(" + ZONDET + ")") <> 3 Then
        #... Donc si le PJT détail n'est pas saisissable : on le rend saisissable
        # A CONDITION QU'IL N'AIT PAS ETE GRISE PAR UNE TRANSACTION DE SAISIE.
        # C'est ça qui est compliqué !
        # Si varmode vaut 3, c'est qu'il a été dessiné comme ça : On ne change rien
        # -------------------------------------------------------------------------
        If GFLAG <> "" Then
          # On est dans une transaction de saisie
          # -------------------------------------
          NTROUVE = -1
          SOBJET = seg$(GFONCTION, 4, len(GFONCTION))  # Forme du type "GESxxx"
          SABRMSK = seg$(ZONDET, instr(0, ZONDET, ":")+1, instr(0, ZONDET, "]")-1)
          SCODZON = seg$(ZONDET, instr(0, ZONDET, "]")+1, len(ZONDET))
          If SOBJET = "GAS" Then
            Gosub DEFVAR From ="WGWO" + "GG" + GFLAG
          Else
            Gosub DEFVAR From ="WGWO" + SOBJET + GFLAG
          Endif
          For NI = 0 To dim(ABMSK)
            If ABMSK(NI) = SABRMSK Then
              NTROUVE = NI
              Break
            Endif
          Next NI
          If NTROUVE > -1 Then
            Local File AMSKZON [AMZ]
            Read [AMZ]CODE=NOMMSK(NTROUVE);SCODZON
            If [F:AMZ]SAIAFF = 1 Then
              # Si par transaction le champ est saisissable, on le rend de nouveau saisissable
              Gosub ACTZO_DYNAMIQUE
            Endif
          Else
            # La fenêtre n'est pas là : on ne fait rien ??
          Endif
        Else
          # On n'est pas dans une transaction de saisie
          Gosub ACTZO_DYNAMIQUE
        Endif
      Endif
    Endif
  Endif
End

####################################################################################################
$ACTZO_DYNAMIQUE
  Gosub OPEN_FILE From TRTPJTREP
  Wrseq "Actzo " + ZONDET Using [FPJT]
  Gosub CLOSE_FILE From TRTPJTREP
Return

####################################################################################################
Subprog PJT_INIBATA(NOLIG,ZONHEAD,ZONDET)
Value    Integer NOLIG
Value    Char    ZONHEAD
Value    Char    ZONDET

Local Char SBASTAB(GLONABR+GLONAVA+4)
Local Char SDETAIL(GLONABR+GLONAVA+GLONAVA+4)

  # ---------------------------------------------------
  # Sur l'INIT bas de tableau, on a besoin d'avoir en même temps ZONHEAD et ZONDET, ou aucun des deux
  If (ZONHEAD <> "" and ZONDET = "") or (ZONHEAD = "" and ZONDET <> "") Then
    GMESSAGE = mess(1037,196,1)
    GOK = 1
    GERR = 1
    End
  Endif
  # ZONHEAD doit correspondre à une rubrique qui existe
  If ZONHEAD <> "" Then
    If evalue("dim(" + ZONHEAD + ")") < 0 Then
      GMESSAGE = mess(1035,196,1)
      GOK = 1
      GERR = 1
      End
    Endif
  Endif
  # ZONDET doit correspondre à une rubrique qui existe
  If ZONDET <> "" Then
    If evalue("dim(" + ZONDET + ")") < 0 Then
      GMESSAGE = mess(1036,196,1)
      GOK = 1
      GERR = 1
      End
    Endif
  Endif
  # ---------------------------------------------------
  # On affecte le ZONDET(NOLIG) avec la valeur de ZONHEAD
  If evalue(ZONHEAD) <> "" Then
    SBASTAB = func GET_BAS_TABLEAU(ZONDET)
    If SBASTAB <> "" Then
      # Cas où le détail est dans un tableau.
      SDETAIL = ZONDET + "(" + num$(NOLIG) + ")"
      If evalue(SDETAIL) = "" Then
        Assign (SDETAIL) With evalue(ZONHEAD)
        Affzo =SDETAIL
      Endif
    Else
      # Cas où le détail n'est pas dans un tableau.
      SDETAIL = ZONDET
      If evalue(SDETAIL) = "" Then
        Assign (SDETAIL) With evalue(ZONHEAD)
        Affzo =SDETAIL
      Endif
    Endif
  Endif
  # ---------------------------------------------------
End

####################################################################################################
####################################################################################################
########################################## OUTILS DIVERS ###########################################
Funprog GET_BAS_TABLEAU(SCHAMP)
Value Char SCHAMP

Local Char SARENDRE(GLONABR+GLONAVA+4)
Local Char SABRMSK(GLONABR)
Local Char SCODMSK(GLONAMK)
Local Char SCODZON(GLONAVA)
Local Integer INUMBLOC

  # SARENDRE est formaté style [M:xxx]yyyyyyy s'il a une valeur
  Local File AMSKZON [AMZ]
  Raz SARENDRE
  Raz SCODMSK
  Raz INUMBLOC
  SABRMSK = func GET_ABRMSK(SCHAMP)
  SCODZON = func GET_CODZON(SCHAMP)
  SCODMSK = func GET_CODMSK(SABRMSK, SCODZON)
  #
  If SCODMSK <> "" Then
    Read [AMZ]CODE=SCODMSK;SCODZON
    If fstat = 0 Then
      INUMBLOC = [F:AMZ]NUMBLOC
    Endif
    For [AMZ]CODZON Where [F:AMZ]CODMSK = SCODMSK and [F:AMZ]NUMBLOC = INUMBLOC and [F:AMZ]CODTYP = "ABS"
      SARENDRE = "[M:" + SABRMSK + "]" + [F:AMZ]CODZON
      Break # Le premier suffit
    Next
  Endif
End SARENDRE

####################################################################################################
Funprog GET_ABRMSK(SCHAMP)
Value Char SCHAMP

Local Char SARENDRE(GLONABR)

  SARENDRE = seg$(SCHAMP, instr(0, SCHAMP, ":")+1, instr(0, SCHAMP, "]")-1)
End SARENDRE

####################################################################################################
Funprog GET_CODZON(SCHAMP)
Value Char SCHAMP

Local Char SARENDRE(GLONAVA)

  SARENDRE = seg$(SCHAMP, instr(0, SCHAMP, "]")+1, len(SCHAMP))
  If right$(SARENDRE, len(SARENDRE)) = '"' or right$(SARENDRE, len(SARENDRE)) = "'" Then
    SARENDRE = left$(SARENDRE, len(SARENDRE)-1)
  Endif
End SARENDRE

####################################################################################################
Funprog GET_CODMSK(SABRMSK, SCODZON)
Value Char SABRMSK
Value Char SCODZON

Local Char SARENDRE(GLONAMK)

  Raz SARENDRE
  #Local File AMSK [AMK]
  # For [AMK]ABRMSK Where [F:AMK]ABRMSK = SABRMSK and [F:AMK]CODMSK < "W"
  #  SARENDRE = [F:AMK]CODMSK
  #  Break # Le premier suffit
  #Next
  #
  Local File AMSK [AMK]
  Local File AMSKZON [AMZ]
  Link [F:AMZ] With [F:AMK]CODMSK = [F:AMZ]CODMSK
&               As [LAMKZ]
&               Where [F:AMK]ABRMSK = SABRMSK  and [F:AMK]CODMSK < "W" and [F:AMZ]CODZON = SCODZON
  #
  For [LAMKZ]
    SARENDRE = [F:AMK]CODMSK
    Break # Le premier suffit
  Next
End SARENDRE

####################################################################################################
Funprog GET_CPY_FROM_FCY(SITE)
Value Char SITE

Local Char SARENDRE(GLONCPY)

  Local File FACILITY [FCY]
  Raz SARENDRE
  Read [F:FCY]FCY0=SITE
  If fstat Then
    Raz [F:FCY]
  Endif
  SARENDRE = [F:FCY]LEGCPY
End SARENDRE

####################################################################################################
Subprog TRAITEMENT_MODULE(MODULE, STRTMODULE, ITRTMODULE)
Value Integer MODULE
Variable Char STRTMODULE
Variable Integer ITRTMODULE

Local Integer PSUBB

  Case MODULE
    When 5
      # Vente
      STRTMODULE = "TRTPJTSAL"
    When 6
      # Achat
      STRTMODULE = "TRTPJTPUR"
    When 7
      # Stock
      STRTMODULE = "TRTPJTSTK"
    When 8
      # GPAO
      STRTMODULE = "TRTPJTGPAO"
    When 9
      # Tronc commun
      STRTMODULE = "TRTPJTTC"
    When 12
      # Support client
      STRTMODULE = "TRTPJTHDK"
    When 13
      # Action commerciale
      STRTMODULE = "TRTPJTCRM"
    When Default
      Raz STRTMODULE
  Endcase
  #
  ITRTMODULE = [V]CST_ANO
  If STRTMODULE <> "" Then
    Call EXISTE_ADX("", "", STRTMODULE, PSUBB) From ORDSYS
    If PSUBB Then
      ITRTMODULE = [V]CST_AYES
    Endif
  Endif
End

####################################################################################################
####################################################################################################
####################################################################################################
# PARTIE 2
####################################################################################################
####################################################################################################
Funprog GET_PARAM_PJTSNGDOC(SFCY)
Value Char SFCY

Local Char SCPY(GLONCPY)
Local Integer IPJTSNGDOC

  SCPY = fmet GACTX.ACACHE.AFCY.AGETVALCHAR(SFCY, "LEGCPY")
  IPJTSNGDOC = func GET_PARAM_SOC_PJTSNGDOC(SCPY)
End IPJTSNGDOC

####################################################################################################
Funprog GET_PARAM_SOC_PJTSNGDOC(SCPY)
Value Char SCPY

Local Integer IPJTSNGDOC
Local Char STRTMODULE(GLONADC)
Local Integer ITRTMODULE
Local Char PJTACTION(GLONDCO)

  IPJTSNGDOC = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, SCPY, "PJTSNGDOC")
  # ------------------------------------------------------------
  If dim(GUPDPJTSNGDOC) >= 0 Then
    Call TRAITEMENT_MODULE(GUPDPJTSNGDOC, STRTMODULE, ITRTMODULE)
    If ITRTMODULE = [V]CST_AYES Then
      PJTACTION = "PJTSNGDOC"
      Gosub ACTION From =STRTMODULE
    Endif
  Endif
  # ------------------------------------------------------------
  If IPJTSNGDOC <> [V]CST_AYES and IPJTSNGDOC <> [V]CST_ANO Then
    IPJTSNGDOC = [V]CST_AYES  # Par défaut, document mono-affaire.
  Endif
End IPJTSNGDOC

####################################################################################################
Funprog GET_OPPNUM_FROM_PIMNUM(SPIMPL)
Value Char SPIMPL

Local Char SARENDRE(GLONOPP)

  Raz SARENDRE
  Gosub OPEN_TABLE
  Read [F:PIM]PIM0=SPIMPL
  If !fstat Then
    SARENDRE = [F:PIM]OPPNUM
  Endif
End SARENDRE

####################################################################################################
Subprog TRAITE_DUPLICATION(SCHAMP)
Value Char SCHAMP

Local Char SPJT(GLONPJT)
Local Char SBASTAB(GLONABR+GLONAVA+4)

  SPJT = evalue(SCHAMP)
  Gosub RECUPERE_PARAM
  If func GET_PARAM_PJTSNGDOC(SITE) = [V]CST_AYES Then
    SBASTAB = func GET_BAS_TABLEAU(ZONDET)

    # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/29/17)
    # Le sous-pro EXEC_PJTREPEAT_OUI utilise ces globales déclarées ds l'action PJTREPEAT (qui appelle le sous-pro EXEC_PJTREPEAT_OUI)
    # Si appel direct du sous-pro il faut les déclarer et les charger
    # The sub-prog EXEC_PJTREPEAT_OUI uses these globals declared in the action PJTREPEAT (which calls the sub-prog EXEC_PJTREPEAT_OUI)
    # If direct call it is necessary to declare and charge them
    Global Char GSTRTMODULE(GLONADC)
    Global Integer GITRTMODULE
    Call TRAITEMENT_MODULE(MODULE, GSTRTMODULE, GITRTMODULE)

    Call EXEC_PJTREPEAT_OUI(SBASTAB, ZONDET, SPJT) From TRTPJTREP

    # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/29/17)
    # L'action PJTREPEAT (qui appelle le sous-pro EXEC_PJTREPEAT_OUI) fait le kill
    # Si appel direct du sous-pro il faut les killer
    # The action PJTREPEAT (which calls the sub-prog EXEC_PJTREPEAT_OUI) does the kill
    # If direct call it is necessary to kill them
    Kill GSTRTMODULE
    Kill GITRTMODULE
    # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/29/17)

  Endif
End

####################################################################################################
Subprog PJT_CONTROL_FROM_CHAMP(SPJT, SCHAMP)
Value Char SPJT
Value Char SCHAMP

  # Permet de contrôler une valeur de PJT en appliquant les règles relatives à un champ
  #If SPJT <> "" Then   # FGR 15/06/2015 : X3SUIVI91515 : toujours tester pour la compatibilité entête/lignes quand valeur vide.
    Gosub RECUPERE_PARAM
    If SCODMSK <> "" Then
      Call PJT_CONTROL(SPJT,CODMSK,FLDNAM,0,MODULE,BOOCRM,BOOPRP,BOOPRPBUD,BOOPRPTAC5,BOOPRPTAC6,BOOPRPTAC7,USEDISPRP,USEDISBUD,USEDISTAC,SITE,BPR,INTERLOC,ZONHEAD,ZONDET,SOCIETE)
    Endif
  #Endif
End

####################################################################################################
$RECUPERE_PARAM
Local Char SABRMSK(GLONABR)
Local Char SCODMSK(GLONAMK)
Local Char SCODZON(GLONAVA)

  Gosub LOCAL_VARIABLES
  # -------------------
  Local File AMSKPAR [AMP]
  SABRMSK = func GET_ABRMSK(SCHAMP)
  SCODZON = func GET_CODZON(SCHAMP)
  SCODMSK = func GET_CODMSK(SABRMSK, SCODZON)
  # -------------------
  If SCODMSK <> "" Then
    For [AMP]CODAFF Where [F:AMP]CODAFF = SCODMSK and [F:AMP]CODZON = SCODZON
      Case [F:AMP]CODPAR
        When "FLDNAM"
          FLDNAM = [F:AMP]VALPAR
        When "NOLIG"
          NOLIG = 0 #evalue([F:AMP]VALPAR)
        When "MODULE"
          MODULE = evalue([F:AMP]VALPAR)
        When "BOOCRM"
          BOOCRM = evalue([F:AMP]VALPAR)
        When "BOOPRP"
          BOOPRP = evalue([F:AMP]VALPAR)
        When ""
          BOOPRPBUD = evalue([F:AMP]VALPAR)
        When "BOOPRPTAC5"
          BOOPRPTAC5 = evalue([F:AMP]VALPAR)
        When "BOOPRPTAC6"
          BOOPRPTAC6 = evalue([F:AMP]VALPAR)
        When "BOOPRPTAC7"
          BOOPRPTAC7 = evalue([F:AMP]VALPAR)
        When "USEDISPRP"
          USEDISPRP = evalue([F:AMP]VALPAR)
        When "USEDISBUD"
          USEDISBUD = evalue([F:AMP]VALPAR)
        When "USEDISTAC"
          USEDISTAC = evalue([F:AMP]VALPAR)
        When "SITE"
          If [F:AMP]VALPAR <> '""' Then
            If left$([F:AMP]VALPAR, 5) = "func " Then
              SITE = evalue([F:AMP]VALPAR)
            Elsif evalue("dim(" + [F:AMP]VALPAR + ")") < 0 Then
              SITE = GFCY
            Else
              If evalue([F:AMP]VALPAR) = "" Then
                SITE = GFCY
              Else
                SITE = evalue([F:AMP]VALPAR)
              Endif
            Endif
          Else
            SITE = GFCY
          Endif
        When "BPR"
          If [F:AMP]VALPAR <> '""' Then
            If left$([F:AMP]VALPAR, 5) = "func " Then
              BPR = evalue([F:AMP]VALPAR)
            Elsif evalue("dim(" + [F:AMP]VALPAR + ")") < 0 Then
              BPR = ""
            Else
              BPR = evalue([F:AMP]VALPAR)
            Endif
          Else
            BPR = ""
          Endif
        When "INTERLOC"
          If [F:AMP]VALPAR <> '""' Then
            If left$([F:AMP]VALPAR, 5) = "func " Then
              INTERLOC = evalue([F:AMP]VALPAR)
            Elsif evalue("dim(" + [F:AMP]VALPAR + ")") < 0 Then
              INTERLOC = ""
            Else
              INTERLOC = evalue([F:AMP]VALPAR)
            Endif
          Else
            INTERLOC = ""
          Endif
        When "ZONHEAD"
          If left$([F:AMP]VALPAR, 5) = "func " Then
            ZONHEAD = evalue([F:AMP]VALPAR)
          Else
            ZONHEAD = ctrans([F:AMP]VALPAR, "'", "")
            ZONHEAD = ctrans(ZONHEAD, '"', "")
          Endif
        When "ZONDET"
          If left$([F:AMP]VALPAR, 5) = "func " Then
            ZONDET = evalue([F:AMP]VALPAR)
          Else
            ZONDET = ctrans([F:AMP]VALPAR, "'", "")
            ZONDET = ctrans(ZONDET, '"', "")
          Endif
        When "CODMSK"
          CODMSK = [F:AMP]VALPAR
        When "SOCIETE"
          If left$([F:AMP]VALPAR, 5) = "func " or left$([F:AMP]VALPAR, 1) = "[" Then
            SOCIETE = evalue([F:AMP]VALPAR)
          Else
            SOCIETE = ctrans([F:AMP]VALPAR, "'", "")
            SOCIETE = ctrans(SOCIETE, '"', "")
          Endif
          If SOCIETE = "" and SITE <> "" Then
            SOCIETE = func GET_CPY_FROM_FCY(SITE)
          Endif
        When Default
      Endcase
    Next
  Endif
Return

####################################################################################################
Subprog PJT_CONTROLE_HEAD_DETAIL(SHEAD, SDETAIL)
Value Char SHEAD
Value Char SDETAIL

Local Char SPJT(GLONPJT)
Local Char SBASTAB(GLONABR+GLONAVA+4)
Local Integer NI
Local Integer NBLIG

  #If GREP <> "C" and GREP <> "D" Then
  #  End
  #Else
    # -------------------
    If SHEAD <> "" Then
      If evalue("dim(" + SHEAD + ")") >= 0 Then
        # Le champ existe
        SPJT = evalue(SHEAD)
        If SPJT <> "" Then
          Call PJT_CONTROL_FROM_CHAMP(SPJT, SHEAD)
          If GERR <> 0 Then
            # Erreur : on part
            End
          Endif
        Endif
      Endif
    Endif
    # -------------------
    If SDETAIL <> "" Then
      If evalue("dim(" + SDETAIL + ")") >= 0 Then
        SBASTAB = func GET_BAS_TABLEAU(SDETAIL)
        If SBASTAB <> "" Then
          NBLIG = evalue(SBASTAB)
          For NI = 0 To NBLIG-1
            SPJT = evalue(SDETAIL+"("+num$(NI)+")")
            If SPJT <> "" Then
              Call PJT_CONTROL_FROM_CHAMP(SPJT, SDETAIL)
              If GERR <> 0 Then
                # Erreur : on part
                GMESSAGE = mess(3,40,1) - num$(NI+1) - ":" - GMESSAGE
                Break
              Endif
            Endif
          Next NI
          If GERR <> 0 Then
            # Erreur : on part
            End
          Endif
        Else
          SPJT = evalue(SDETAIL)
          If SPJT <> "" Then
            Call PJT_CONTROL_FROM_CHAMP(SPJT, SDETAIL)
            If GERR <> 0 Then
              # Erreur : on part
              End
            Endif
          Endif
        Endif
      Endif
    Endif
    # -------------------
  #Endif
End

####################################################################################################
Funprog IS_PJT_AVAILABLE(SPJT, SCHAMP, SMESSAGE)
Value Char SPJT
Value Char SCHAMP
Variable Char SMESSAGE

Local Integer IARENDRE
Local Integer SVMKSTAT
Local Char SVMESSAGE(type(GMESSAGE)-10)
Local Char SVGZONE(type(GZONE)-10)
Local Integer SVERR

  IARENDRE = [V]CST_AYES
  # Sauvegarde des globales
  SVMKSTAT = mkstat
  SVMESSAGE = GMESSAGE
  SVERR = GERR
  SVGZONE = GZONE
  #
  mkstat = 0
  Raz GMESSAGE
  Raz GERR
  Raz GZONE
  #
  Call PJT_CONTROL_FROM_CHAMP(SPJT, SCHAMP)
  If GERR <> 0 Then
    IARENDRE = [V]CST_ANO
    SMESSAGE = GMESSAGE
  Endif
  # Restauration des globales
  mkstat = SVMKSTAT
  GMESSAGE = SVMESSAGE
  GERR = SVERR
  GZONE = SVGZONE
End IARENDRE

####################################################################################################
Subprog PJT_ADD_MSG(SPJT, SMSG)
Value Char SPJT
Value Char SMSG

  # Stock dans des tableaux les affaires non utilisables pour ne rendre le message qu'une fois par affaire
Local Integer RANG
Local Integer NI
Local Char SPJTVAL(type(SPJT)-10)

  If dim(GPJTMSG) < 0 Then
    Global Char GPJTCOD(GLONPJT)(1..)
    Global Char GPJTMSG(type(GMESSAGE)-10)(1..)
    Global Integer GPJTNBR
    GPJTNBR = 0
    Raz GPJTCOD
    Raz GPJTMSG
  Endif
  #
  If SPJT = "" Then
    SPJTVAL = "~"
  Else
    SPJTVAL = SPJT
  Endif
  RANG = find(SPJTVAL, GPJTCOD)
  If RANG = 0 Then
    GPJTNBR += 1
    GPJTCOD(GPJTNBR) = SPJTVAL
    GPJTMSG(GPJTNBR) = SMSG
  Endif
End

####################################################################################################
Subprog PJT_WRITE_MSG()
Local Integer NI
Local Char SMESSAGE(type(GMESSAGE)-10)

  # Ecrit dans les trace toutes les affaires non utilisables
  If dim(GPJTMSG) >= 0 Then
    For NI = 1 To GPJTNBR
      If GPJTMSG(NI) <> "" Then
        SMESSAGE = GPJTMSG(NI)
        Call ECR_TRACE(SMESSAGE, -1) From GESECRAN
      Endif
    Next NI
    Kill GPJTMSG
    Kill GPJTCOD
    Kill GPJTNBR
  Endif
End

####################################################################################################
Subprog PJT_INFO_MSG()
Local Integer OK

  If not GIMPORT Then
    # Affiche un message pour chacune des affaires non utilisables
    If dim(GPJTMSG) >= 0 Then
      Call AVERTIR(GPJTMSG, OK) From GESECRAN
      Kill GPJTMSG
      Kill GPJTCOD
      Kill GPJTNBR
    Endif
  Else
    Call PJT_WRITE_MSG()
  Endif
End

