#<AdxTL>@(#)3.0.0.0 $Revision$
####################################################################################################
# La première partie du traitement sont les lignes de code qui correspondent aux actions
# Le seconde partie, met à disposition des outils utilisables dans le code :
# --------------------------------------------------------------------------------------------------
# Les deux sousp-programme suivants sont à la frontière :
#      - PJT_MODFCY
#      - PJT_INIBATA
#   Ils sont utilisés à la fois dans une action et sont appelables directement dans le code
# --------------------------------------------------------------------------------------------------
# ------------
#  * Function : GET_PARAM_PJTSNGDOC(SFCY)
#                 Récupère la valeur du paramètre PJTSNGDOC pour le site SFCY
# ------------
#  * Subprog :  TRAITE_DUPLICATION(SCHAMP)
#                 SCHAMP contient le champ détail au format [M:xxx]yyyyyy
#                 Si le paramètre PJTSNGDOC=[V]CST_AYES, ce sous-programme répète la valeur de l'entête
#                 sur chacune des lignes de détail
# ------------
#  * Subprog :  PJT_CONTROL_FROM_CHAMP(SPJT, SCHAMP)
#                 SPJT contient la valeur de l'affaire
#                 SCHAMP le champ qui est susceptible de recevoir SPJT (au format [M:xxx]yyyyyy)
#                 Ce sous-programme déclenche les contrôles fonctionnels relatifs au PJT comme
#                 s'il avait été saisi.
#                 Si une erreur est détecté le variables suivantes sont impactées :
#                         mkstat = 1
#                         GMESSAGE = SPJT - ":" - 'Texte de l'erreur'
#                         GERR = 1
#                         GZONE = FLDNAM
# ------------
#  * Subprog :  PJT_CONTROLE_HEAD_DETAIL(SHEAD, SDETAIL)
#                 SHEAD le champ entête (au format [M:xxx]yyyyyy)
#                 SDETAIL le champ détail (au format [M:xxx]yyyyyy)
#                 Ce sous-programme est utilisé notamment lors de la duplication pour enchaîner
#                 les contrôles de cohérences qui ne le seraient pas autrement
# ------------
#  * Function : IS_PJT_AVAILABLE(SPJT, SCHAMP, SMESSAGE)
#                 SPJT contient la valeur de l'affaire
#                 SCHAMP le champ qui est susceptible de recevoir SPJT (au format [M:xxx]yyyyyy)
#                 Cette fonction déclenche les contrôles fonctionnels relatifs au PJT comme
#                 s'il avait été saisi.
#                 Elle rend [V]CST_AYES si le PJT est valide
#                 Elle rend [V]CST_ANO si le PJT n'est pas valide. SMESSAGE rend le texte de l'erreur
# ------------
#  * Subprog :  PJT_ADD_MSG(SPJT, SMSG)
#                 Ce sous-programme est utilisé en liaison avec la fonction IS_PJT_AVAILABLE.
#
#                 Il permet d'empiler les erreurs sur des PJT successifs en ne faisant apparaitre
#                 un même PJT qu'une seule fois.
#                 SPJT contient la valeur de l'affaire
#                 SMSG contient le message rendu dans SMESSAGE
# ------------
#  * Subprog :  PJT_WRITE_MSG()
#                 Ce sous-programme est utilisé en liaison avec la fonction IS_PJT_AVAILABLE.
#
#                 Il permet d'écrire dans une trace (sous la forme de warnings)la liste des erreurs
#                 mémorisées par le sous-programme PJT_ADD_MSG.
#                 Il est a utiliser lors de traitements automatiques.
#                 Il n'est pas nécessaire de se demander s'il y a des messages, le sous-programme
#                 vérifie tout seul et surtout détruit les variables globales.
#                 Il doit donc toujours être appelé au moins une fois.
# ------------
#  * Subprog :  PJT_INFO_MSG()
#                 Ce sous-programme est utilisé en liaison avec la fonction IS_PJT_AVAILABLE.
#
#                 Il permet d'afficher un message pour chaque élément de la liste des erreurs
#                 mémorisées par le sous-programme PJT_ADD_MSG.
#                 Il est a utiliser lors de traitements manuels (Picking, boutons).
#                 Il n'est pas nécessaire de se demander s'il y a des messages, le sous-programme
#                 vérifie tout seul et surtout détruit les variables globales.
#                 Il doit donc toujours être appelé au moins une fois.
####################################################################################################
# Issue 75435 - 20180409 by LD : Sales open order projet dimension type

####################################################################################################
# PARTIE 1
####################################################################################################
####################################################################################################
$ACTION
  Case ACTION
    When "SEL_TABLE"      : Gosub SEL_TABLE
    When "VERF_TABLE"     : Gosub VERF_TABLE
    When Default
  Endcase
Return

####################################################################################################
$SEL_TABLE
  Case TABLE
    When "SELPJT"       : Gosub SEL_SELPJT
    When "SELPJTBPR"    : Gosub SEL_SELPJTBPR
    When "SELPJTAIN"    : Gosub SEL_SELPJTAIN
    When "SELPJTCRM"    : Gosub SEL_SELPJTBCRM
    When "SELPJTPRP"    : Gosub SEL_SELPJTBPRP
    When "SELPJTBUD"    : Gosub SEL_SELPJTBBUD
    When "SELPJTTAC"    : Gosub SEL_SELPJTBTAC
    When Default
  Endcase
Return

####################################################################################################
$VERF_TABLE
  Case TABLE
    When "SELPJT"       : Gosub VERF_SELPJT
    When "SELPJTBPR"    : Gosub VERF_SELPJTBPR
    When "SELPJTAIN"    : Gosub VERF_SELPJTAIN
    When "PJTSELCRM"    : Gosub VERF_SELPJTBCRM
    When "PJTSELPRP"    : Gosub VERF_SELPJTBPRP
    When "PJTSELBUD"    : Gosub VERF_SELPJTBBUD
    When "PJTSELTAC"    : Gosub VERF_SELPJTBTAC
    When Default
  Endcase
Return

####################################################################################################
$OPEN_TABLE
  Local File FACILITY [FCY]
  Local File OPPOR [OPP]
  Local File OPPORCRM [OPPCRM]
  Local File PIMPL [PIM]
  Local File ATEXTRA [AXX]
  Local File BPARTNER [BPR]
  Local File BPCUSTOMER [BPC]          # Issue X3-53308 - 2017-08-24 by FGR
  #
  # Issue X3-5055/119743 - 2016-11-14 by FGR : BEGIN
  If func ASYRFNC.ACTIV("PJM") Then
    Local File PIMPLIMP [PIMI]
  Endif
  # Issue X3-5055/119743 - 2016-11-14 by FGR : END
Return

####################################################################################################
# FGR 20/01/2016 : X3SUIVI71065/12/SALAVG07 : Based on activity code not on a parameter
$TRT_PJM_INACTIVE
Local Integer IPJMAVAILABLE

  # Voir pour remplacer la lecture par l'accès à une classe an cache (Demande de modif SAM113867)
  IPJMAVAILABLE = func ASYRFNC.ACTIV("PJM")
  # -------------------
  If IPJMAVAILABLE = [V]CST_AFALSE Then
    # Si le code activité PJM n'est pas actif, faire comme si tous les paramètres relatifs à PJM
    # étaient à NON ([V]CST_ANO)
    BOOPRP = [V]CST_ANO
    BOOPRPBUD = [V]CST_ANO
    BOOPRPTAC5 = [V]CST_ANO
    BOOPRPTAC6 = [V]CST_ANO
    BOOPRPTAC7 = [V]CST_ANO
    USEDISPRP = [V]CST_ANO
    USEDISBUD = [V]CST_ANO
    USEDISTAC = [V]CST_ANO
  Else
    # Issue X3-5055/119743 - 2016-11-14 by FGR : BEGIN
    #If (instr(0, CODMSK,"SQH") > 0  or instr(0, CODMSK,"SOH") > 0) and USEDISTAC = [V]CST_ANO Then
    #  # Un devis où une commande peut être fait sur une tâche non active
    #  USEDISTAC = [V]CST_AYES
    #Endif
    FROMSQHSOH = [V]CST_ANO
    If (instr(0, CODMSK,"SQH") > 0 or instr(0, CODMSK,"SOH") > 0) Then
      FROMSQHSOH = [V]CST_AYES
      If USEDISPRP = [V]CST_ANO Then
        # Un devis où une commande peut être fait sur une affaire non active
        USEDISPRP = [V]CST_AYES
      Endif
      If USEDISBUD = [V]CST_ANO Then
        # Un devis où une commande peut être fait sur un budget non actif
        USEDISBUD = [V]CST_AYES
      Endif
      If USEDISTAC = [V]CST_ANO Then
        # Un devis où une commande peut être fait sur une tâche non active
        USEDISTAC = [V]CST_AYES
      Endif
    Endif
    FROMSIH = [V]CST_ANO
    If (instr(0, CODMSK,"SIH") > 0) Then
      FROMSIH = [V]CST_AYES
      If USEDISPRP = [V]CST_AYES Then
        # ATTENTION : Une facture peut jamais être faite sur une affaire clôturée. Là c'est la fin
        USEDISPRP = [V]CST_ANO
      Endif
      If USEDISBUD = [V]CST_ANO Then
        # Une facture peut être faite sur un budget clôturé
        USEDISBUD = [V]CST_AYES
      Endif
      If USEDISTAC = [V]CST_ANO Then
        # Une facture peut être faite sur une tâche clôturée
        USEDISTAC = [V]CST_AYES
      Endif
    Endif
    # Issue X3-5055/119743 - 2016-11-14 by FGR : END
  Endif
  #
  If GACTX.AFOLD.AMODULE(13) = [V]CST_ANO Then
    # S'il n'y a pas le module "Action commerciale", il ne peut pas y avoir d'affaire CRM.
    # Je désactive les paramètres CRM.
    BOOCRM = [V]CST_ANO
  Endif
  # -------------------
Return

#$TRT_PJM_INACTIVE
