####################################################################################################
$LOCAL_VARIABLES
Local Char    CODMSK(GLONABR)
Local Char    FLDNAM(GLONAVA)
Local Integer NOLIG
Local Integer MODULE
Local Integer BOOCRM
Local Integer BOOPRP
Local Integer BOOPRPBUD
Local Integer BOOPRPTAC5
Local Integer BOOPRPTAC6
Local Integer BOOPRPTAC7
Local Integer USEDISPRP
Local Integer USEDISBUD
Local Integer USEDISTAC
Local Integer FROMSQHSOH  # Issue X3-5055/119743 - 2016-11-14 by FGR
Local Integer FROMSIH     # Issue X3-5055/119743 - 2016-11-14 by FGR
Local Char    SITE(GLONFCY)
Local Char    BPR(GLONBPR)
Local Char    INTERLOC(GLONAIN)
Local Char    ZONHEAD(250)
Local Char    ZONDET(250)
Local Char    SOCIETE(GLONFCY)
Return

####################################################################################################
$DECLARE_VARIABLES
  Gosub LOCAL_VARIABLES
  #
  CODMSK = PARAM(1)
  FLDNAM = PARAM(2)
  NOLIG = val(PARAM(3))
  MODULE = val(PARAM(4))
  BOOCRM = val(PARAM(5))
  BOOPRP = val(PARAM(6))
  BOOPRPBUD = val(PARAM(7))
  BOOPRPTAC5 = val(PARAM(8))
  BOOPRPTAC6 = val(PARAM(9))
  BOOPRPTAC7 = val(PARAM(10))
  USEDISPRP = val(PARAM(11))
  USEDISBUD = val(PARAM(12))
  USEDISTAC = val(PARAM(13))
  SITE = PARAM(14)
  BPR = PARAM(15)
  INTERLOC = PARAM(16)
  ZONHEAD = PARAM(17)
  ZONDET = PARAM(18)
  SOCIETE = PARAM(19)
  If SOCIETE = "" and SITE <> "" Then
    SOCIETE = func GET_CPY_FROM_FCY(SITE)
  Endif
Return

####################################################################################################
$DECLOAD_VAL_SEL
  Gosub DECLARE_VARIABLES
  Gosub TRT_PJM_INACTIVE
Return

####################################################################################################
$SEL_SELPJT
  Gosub DECLOAD_VAL_SEL
