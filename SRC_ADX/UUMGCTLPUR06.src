#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGCTLPUR06   Contrﾃｴle Pre-migration Rﾃｩceptions           Module Achats #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-06-12 by SR : adaptation
  # Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLPUR06") From LECFIC
  Endif

  Call MAJ_UUMGCTLPUR06(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGCTLPUR06(DOSSIER)
Value Char DOSSIER

If [F:ADS]MODULE(5)<>2 : End : Endif                                  : # N= no module

Call ECR_TIME("UUMGCTLPUR06 Purchase Receipts Process : PRECEIPT-D") From DOSSUB
Call ECR_TRACE("UUMGCTLPUR06 : Process Start on : "+DOSSIER,0) From GESECRAN

Local Integer ERR,COMPTEUR

Gosub CTL1
Gosub CTL2

$FIN
Call ECR_TIME("UUMGCTLPUR06 : Purchase Receipts Process END.")  From DOSSUB
End


###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
$CTL1
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PRECEIPT")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PRECEIPTD") : Return : Endif


REQSQL(0)="SELECT PTH.PTHNUM_0 FROM "-DOSSIER+".PRECEIPT PTH "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PRECEIPTD PTD WHERE PTH.PTHNUM_0=PTD.PTHNUM_0) "
REQSQL(2)="ORDER BY PTH.PTHNUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PRECEIPT without PRECEIPTD",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPTHNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"PTHNUM="-[BXX]VPTHNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################


###################################################################################
$CTL2
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PRECEIPT")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PRECEIPTD") : Return : Endif

REQSQL(0)="SELECT PTD.PTHNUM_0,PTD.PTDLIN_0 FROM "-DOSSIER+".PRECEIPTD PTD "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PRECEIPT PTH WHERE PTH.PTHNUM_0=PTD.PTHNUM_0) "
REQSQL(2)="ORDER BY PTD.PTHNUM_0,PTD.PTDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PRECEIPTD without PRECEIPT",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPTHNUM(50),Integer VPTDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"PTHNUM/PTDLIN="-[BXX]VPTHNUM+'/'+num$([BXX]VPTDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################

