#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("MOE",GBIDC1,"") From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE" : Infbox "Fonction Obsolète - Obsolete function"
 When "LIENS"  : Gosub LIENS
 When Default
Endcase
Return

$LIENS
Call GRISE_XIT([M]CTRXITAUT)
Return


Subprog GRISE_XIT(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo CTRXITGRD
Else
 Effzo CTRXITGRD
 Grizo CTRXITGRD
Endif
Affzo CTRXITGRD
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran MOE0) 26/11/2009 15:00:39 (LS)
######################################################################################

Subprog C_CTRXITAUT(VALEUR)
Variable Integer  VALEUR
Call GRISE_XIT(VALEUR)
End

Subprog AS_CTRXITGRD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
Read [ADI]CODE=10359;[M]COD
If !fstat
 VALEUR = [M]COD
Endif
End

Subprog C_CTRXITGRD(VALEUR)
Variable Char    VALEUR()
If [M]CTRXITAUT=2 & VALEUR=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
End


######################################################################################

#JOJAC - 2016-07-20 - REQ114309 - START
Subprog GET_FLGCREBUL (VALFLG,COD)
Variable Integer VALFLG
Value Char COD ()

  If !GPAYE : End : Endif

  #Always checked by default
  VALFLG=2
#JOJAC - 2016-07-28 - REQ114309 - START
#  If clalev([F:MOE])=0  : Local File MOTENT   [MOE]  : Endif
#  If COD="" | dim([F:MOE]FLGCREBUL)<0 : End : Endif
#  #Else depending of the entry reason
#  Read [F:MOE]MOE0=COD
#  If !fstat :  VALFLG=[F:MOE]FLGCREBUL : Endif

  If clalev ([F:HRCGD])=0 : Local File HRCTRGRD [HRCGD] : Endif
  If COD="" | dim([F:HRCGD]FLGCREBUL)<0 : End : Endif
  #Else depending of the entry reason
  Read [F:HRCGD]HRCGD0=COD;GCURLEG
  If !fstat :  VALFLG=[F:HRCGD]FLGCREBUL : Endif
#JOJAC - 2016-07-28 - REQ114309 - END
End
#JOJAC - 2016-07-20 - REQ114309 - END

