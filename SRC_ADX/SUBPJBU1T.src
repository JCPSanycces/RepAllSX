#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# PJMBUD1T
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    When "END"                         : Gosub DOEND
    When "FIN"                         : Gosub FIN
    When "APRES_MODIF"                 : Gosub APRES_MODIF
    When "ENR"                         : Gosub ENR
    When "ABA"                         : Gosub ABANDON
    When "SUI"                         : Gosub SUI
    When "PRE"                         : Gosub PRE
    When "FIR"                         : Gosub FIR
    When "LAS"                         : Gosub LAS
    When Default
  Endcase
Return

###################################################################################################
$OUVRE
Local Integer ITECFINOVEEXIST

  If dim(TECFINOVE) >= 0 Then
    ITECFINOVEEXIST = [V]CST_AYES
  Else
    ITECFINOVEEXIST = [V]CST_ANO
    Global Instance TECFINOVE Using C_TECFINOVE
  Endif
Global Integer GIPBUIDX

Local Char SPBUCOD(GLONPBU)
Local Integer IPLBSEQ

  # -----------------------------
  If dim(GZINSPJM) <= 0 Then
    GMESSAGE = mess(186,123,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  SPBUCOD = PARAM(1)
  GIPBUIDX = fmet GZINSPJM.PJM(1).BUD_GET_INDEX(SPBUCOD)
  # -----------------------------
  Call EXTRACT_ALL()
  # -----------------------------
  NAVIG = GACTION
  GOK = 1
  # -----------------------------
Return

###################################################################################################
$DEBUT
  # -----------------------------
  # Issue X3-106367 - 2018-08-28 by FGR : BEGIN
  #If !clalev([F:PJC]) : Local File PJMSC [PJC] : Endif
  #If !clalev([F:PJLB]) : Local File PJMBUDLIG [PJLB] : Endif
  Local File PJMSC [PJC]
  Local File PJMBUDLIG [PJLB]
  # Issue X3-106367 - 2018-08-28 by FGR : END
  # -----------------------------
  [M:PJBU10]OPPNUM = GZINSPJM.OPPNUM
  [M:PJBU10]CUR    = GZINSPJM.CUR
  Call SHOW_BUDGET_LINES(SPBUCOD)
Return

###################################################################################################
$DOEND
  If REP <> "" Then
    GMESSAGE = mess(162,2260,1)
    GERR = 1
    FIN = 0
    Return
  Endif
Return

###################################################################################################
$FIN
Local Integer IRET

  If ITECFINOVEEXIST = [V]CST_ANO Then
    If TECFINOVE <> null Then
      IRET = fmet TECFINOVE.DELETE_ALL()
      FreeGroup TECFINOVE
      Raz TECFINOVE
    Endif
    Kill TECFINOVE
  Endif
  Kill GIPBUIDX
Return

###################################################################################################
$APRES_MODIF
  If REP = "" Then
    REP = "M"
  Endif
Return

###################################################################################################
$ENR
Local Integer MY_STATUS                          # Hybrid part

  [L]MY_STATUS = fmet GZINSPJM.AUPDATE()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(159,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  Gosub RELIT_GZINSPJM From SUBPJMA
  Call EXTRACT_ALL()                    # Refresh suivi financier
  Call SHOW_BUDGET_LINES(GZINSPJM.PJM(1).BUD(GIPBUIDX).PBUCOD)
  REP = ""
Return

###################################################################################################
$ABANDON
  Gosub RELIT_GZINSPJM From SUBPJMA
  Call SHOW_BUDGET_LINES(GZINSPJM.PJM(1).BUD(GIPBUIDX).PBUCOD)
  REP = ""
Return

###################################################################################################
$SUI
Local Integer NI
Local Integer NISTART

  # --------------------------------
  NISTART = GIPBUIDX + 1
  If NISTART > maxtab(GZINSPJM.PJM(1).BUD) Then
    NISTART = 1
  Endif
  # --------------------------------
  For NI = NISTART To maxtab(GZINSPJM.PJM(1).BUD)
    If GZINSPJM.PJM(1).BUD(NI) <> null and find(GZINSPJM.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If GZINSPJM.PJM(1).BUD(NI).PBUIMP= [V]CST_AYES Then
        GIPBUIDX = NI
        Break
      Endif
    Endif
  Next NI
  Call SHOW_BUDGET_LINES(GZINSPJM.PJM(1).BUD(GIPBUIDX).PBUCOD)
Return

###################################################################################################
$PRE
Local Integer NI
Local Integer NISTART

  # --------------------------------
  NISTART = GIPBUIDX - 1
  If NISTART < 1 Then
    NISTART = maxtab(GZINSPJM.PJM(1).BUD)
  Endif
  # --------------------------------
  For NI = NISTART To 1 Step -1
    If GZINSPJM.PJM(1).BUD(NI) <> null and find(GZINSPJM.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If GZINSPJM.PJM(1).BUD(NI).PBUIMP= [V]CST_AYES Then
        GIPBUIDX = NI
        Break
      Endif
    Endif
  Next NI
  Call SHOW_BUDGET_LINES(GZINSPJM.PJM(1).BUD(GIPBUIDX).PBUCOD)
Return

###################################################################################################
$FIR
Local Integer NI
Local Integer NISTART

  # --------------------------------
  NISTART = 1
  # --------------------------------
  For NI = NISTART To maxtab(GZINSPJM.PJM(1).BUD)
    If GZINSPJM.PJM(1).BUD(NI) <> null and find(GZINSPJM.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If GZINSPJM.PJM(1).BUD(NI).PBUIMP= [V]CST_AYES Then
        GIPBUIDX = NI
        Break
      Endif
    Endif
  Next NI
  Call SHOW_BUDGET_LINES(GZINSPJM.PJM(1).BUD(GIPBUIDX).PBUCOD)
Return

###################################################################################################
$LAS
Local Integer NI
Local Integer NISTART

  # --------------------------------
  NISTART = maxtab(GZINSPJM.PJM(1).BUD)
  # --------------------------------
  For NI = NISTART To 1 Step -1
    If GZINSPJM.PJM(1).BUD(NI) <> null and find(GZINSPJM.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If GZINSPJM.PJM(1).BUD(NI).PBUIMP= [V]CST_AYES Then
        GIPBUIDX = NI
        Break
      Endif
    Endif
  Next NI
  Call SHOW_BUDGET_LINES(GZINSPJM.PJM(1).BUD(GIPBUIDX).PBUCOD)
Return

###################################################################################################
# Screens fields
###################################################################################################
# PJBU1T
###################################################################################################
Subprog C_NBLIG

Local Integer IRET
Local Integer IBUDLIN

  # ---------------------------------------------------------------------------------
  If status = 82 or status = 73 Then
    # Add a new line
    If [M:PJBU1T]PLBSEQ(nolign-1) = 0 Then
      IBUDLIN = fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).ADDLINE("BUDLIG", [V]CST_ALASTPOS)
      If IBUDLIN <> [V]CST_ANOTDEFINED Then
        [M:PJBU1T]COLLIN(nolign-1) = IBUDLIN
        Call SHOW_DISPLAY_BUDGET_LINE()
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:PJBU1T]20
    Endif
  Elsif status = 65 Then
    # Delete a line
    If [M:PJBU1T]COLLIN(nolign-1) > 0 Then
      IRET = fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).ADELLINE("BUDLIG", GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG([M:PJBU1T]COLLIN(nolign-1)).AORDER)
      If IRET = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
        GOK = 0
        GERR = 1
        mkstat = 2
      Endif
    Else
      GMESSAGE = mess(375,2260,1)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

###################################################################################################
Subprog AM_PLBDESAXX(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG([M:PJBU1T]COLLIN(nolign-1)).PLBDESAXX = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG([M:PJBU1T]COLLIN(nolign-1)).PLBDESAXX = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG([M:PJBU1T]COLLIN(nolign-1)).snapshot.PLBDESAXX
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_DISPLAY_BUDGET_LINE()
  Endif
End

