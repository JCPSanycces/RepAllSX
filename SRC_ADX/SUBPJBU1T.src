###################################################################################################
# Subroutines and function
###################################################################################################
Subprog EXTRACT_ALL()
Local Integer IRET

  # -----------------------------
  If TECFINOVE <> null Then
    FreeGroup TECFINOVE
    Raz TECFINOVE
  Endif
  TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  # -----------------------------
  IRET = fmet TECFINOVE._GET_DEFAULT_GRP()
  # -----------------------------
  #TECFINOVE.PROJECT = GZINSPJM                  # Issue X3-82778 - 2018-06-18 by FGR : not necessary # Note FGR : optimisation for financial overview loading.
  TECFINOVE.ISBUDUPD = [V]CST_AYES
  TECFINOVE.OPPNUM = GZINSPJM.PJM(1).BUD(GIPBUIDX).OPPNUM
  TECFINOVE.CUR = GZINSPJM.PJM(1).BUD(GIPBUIDX).CUR
  TECFINOVE.UOM = fmet GZINSPJM.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, GZINSPJM.PJM(1).BUD(GIPBUIDX).PBUFCY, "UNITWORK")
  # -----------------------------
  IRET = fmet TECFINOVE.EXTRACT_ALL()
  # -----------------------------
End

###################################################################################################
Subprog SHOW_BUDGET_LINES(SPBUCOD)
Value Char SPBUCOD

Local Integer NI

  [M:PJBU10]PBUCOD = GZINSPJM.PJM(1).BUD(GIPBUIDX).PBUCOD
  [M:PJBU10]PBUDESAXX = GZINSPJM.PJM(1).BUD(GIPBUIDX).PIMPL.PIMDESAXX
  # -----------------------------
  [M:PJBU10]UOM = TECFINOVE.UOM
  If [M:PJBU10]UOM = AVOID.ACHAR Then
    Call MESSAGE(func AFNC.MES1(mess(514,2260,1), GZINSPJM.PJM(1).BUD(GIPBUIDX).PBUFCY)) From GESECRAN
  Endif
  # -----------------------------
  Effzo [M:PJBU1T]20
  Call CHGSTL_PJBU1T()       # Issue X3-106367 - 2018-08-28 by FGR
  Call LOAD_PJMSC_BUD(SPBUCOD)
  # -----------------------------
  nolign = 0
  For NI = 1 To maxtab(GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG)
    If GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI) <> null and find(GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      # -----------------------------
      nolign += 1
      [M:PJBU1T]COLLIN(nolign-1) = NI
      [M:PJBU1T]COLLINBUD(nolign-1) = GIPBUIDX
      # -----------------------------
      Call SHOW_BUDGET_LINE()
      # -----------------------------
      GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI).TCHFINOVSESS = TECFINOVE.SESSION
      # -----------------------------
    Endif
  Next NI
  [M:PJBU1T]NBLIG = nolign
  # -----------------------------
  Call SET_STYLES()
  Affzo [M:PJBU1T]1-99
  Affzo [M:PJBU10]1-99
  # -----------------------------
End

###################################################################################################
Subprog SHOW_BUDGET_LINE()

  Call LOAD_PJMSC()
  #Note FGR : mandatory after LOAD_PJMSC, because in PJMSC table there are fields with the same name than in the screen.
  SetInstance [M:PJBU1T]20 With GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG([M:PJBU1T]COLLIN(nolign-1))
End

###################################################################################################
Subprog SHOW_DISPLAY_BUDGET_LINE()
  Call SHOW_BUDGET_LINE()
  Affzo [M:PJBU1T]1-99
End

###################################################################################################
Subprog LOAD_PJMSC()

  Local File PJMSC [PJC]
  If  GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG([M:PJBU1T]COLLIN(nolign-1)).ASTALIN <> [V]CST_ANEW Then
    Filter [F:PJC] Where PSCSSS = TECFINOVE.SESSION
&                    and PBUCOD = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG([M:PJBU1T]COLLIN(nolign-1)).PBUCOD
&                    and PCCCOD = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG([M:PJBU1T]COLLIN(nolign-1)).PCCCOD
    For [F:PJC]
      [M:PJBU1T] = [F:PJC]
      Break
    Next
    Filter [F:PJC]
  Endif
End

###################################################################################################
Subprog LOAD_PJMSC_BUD(SPBUCOD)
Value Char SPBUCOD

  Local File PJMSC [PJC]
  Filter [F:PJC] Where PSCSSS = TECFINOVE.SESSION and PBUCOD = SPBUCOD and PCCCOD = AVOID.ACHAR
  For [F:PJC]
    [M:PJBUTT] = [F:PJC]
    Break
  Next
  Filter [F:PJC]
  Affzo [M:PJBUTT]
End

###################################################################################################
Funprog COLGETFMT(INDEX)
Value Integer INDEX

Local Char SARENDRE(250)

  SARENDRE = func TECFINOVE_CSTD_PROGS.GET_FMT_DYN(TECFINOVE, INDEX, [V]CST_AYES, [M:PJBU10]CUR, [V]CST_AYES, [M:PJBU1T]PLBU(nolign-1))
End SARENDRE

###################################################################################################
Funprog TOTGETFMT(INDEX)
Value Integer INDEX

Local Char SARENDRE(250)

  SARENDRE = func TECFINOVE_CSTD_PROGS.GET_FMT_DYN(TECFINOVE, INDEX, [V]CST_AYES, [M:PJBU10]CUR, [V]CST_AYES, TECFINOVE.UOM)
End SARENDRE

###################################################################################################
Subprog SET_STYLES()
  # PJMEXPENSE (vert)
  Chgstl [M:PJBU1T]PSCBUDQTY   With "PJMBUD"
  Chgstl [M:PJBU1T]PSCBUDAMT   With "PJMBUD"
  Chgstl [M:PJBU1T]PSCQTY1     With "PJMEXPENSE"
  Chgstl [M:PJBU1T]PSCAMT1     With "PJMEXPENSE"
  Chgstl [M:PJBU1T]PSCQTY2     With "PJMEXPENSE"
  Chgstl [M:PJBU1T]PSCAMT2     With "PJMEXPENSE"
  Chgstl [M:PJBU1T]PSCQTY3     With "PJMEXPENSE"
  Chgstl [M:PJBU1T]PSCAMT3     With "PJMEXPENSE"
  Chgstl [M:PJBU1T]PSCQTY4     With "PJMEXPENSE"
  Chgstl [M:PJBU1T]PSCAMT4     With "PJMEXPENSE"
  Chgstl [M:PJBU1T]PSCQTY5     With "PJMEXPENSE"
  Chgstl [M:PJBU1T]PSCAMT5     With "PJMEXPENSE"
