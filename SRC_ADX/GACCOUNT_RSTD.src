# Représentation GACCOUNT

###########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
        When "AREAD_AFTER" : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


##########################################################################################################
$AREAD_AFTER
Local Integer I
# Currency of the Defauklt value in the Ana tab
this.CURUOM  = fmet this.ACTX.APARAM.AGETVALCHAR(1,"","CURSHRFLD")

# Title of Company/site/group in the General tab
If this.GAC.FCY<>""
 Local File FACILITY [FCY]
 Call LEC_FCY(this.GAC.FCY) From CPTLEC
 If !fstat
  this.LIBFCY=[F:FCY]FCYNAM
 Else
  Local File COMPANY [CPY]
  Call LEC_CPY(this.GAC.FCY) From CPTLEC
  If !fstat
   this.LIBFCY=[F:CPY]CPYNAM
  Endif
 Endif
Endif

# Title of the classification
Local File GCOA [COA]
Read [COA]COA0=this.GAC.COA
Local Instance CLS Using C_GACCCLS
CLS = NewInstance [CLS] With C_GACCCLS
If fmet CLS.AREAD([F:COA]LEGCLS,this.GAC.CLSCOD)= [V]CST_AOK
 this.CLSNAM = CLS.AXX.TEX
Endif
FreeInstance [CLS]

# LVA management
If dim(this.GAC.FLGABL)>0
  If find([F:COA]LEG,"GER","AUT")
 ASTATUS = fmet this.GAC.ASETATTRIBUTE('LVATYP','$isHidden','false')
  Else
 ASTATUS = fmet this.GAC.ASETATTRIBUTE('LVATYP','$isHidden','true')
  Endif
Endif

# Load the pyramids tab
Local File GACCGRUPYM [GRY]
Local File GACCPYM [GYM]
Local File ATEXTRA [AXX]
Local Integer NUMCUR
For [GRY] Where  pat(this.GAC.ACC,[F:GRY]ACC)<>0
 fstat = 0
 If [F:GRY]PYM<>[F:GYM]PYM
  Read [GYM]GYM0=[F:GRY]PYM
 Endif
 If !fstat & [F:GYM]COA=this.GAC.COA
  NUMCUR = fmet this.ADDLINE("PYRAMID",[V]CST_ALASTPOS)
  this.PYRAMID(NUMCUR).PYM    = [F:GRY]PYM
  this.PYRAMID(NUMCUR).GRU    = [F:GRY]GRU
  this.PYRAMID(NUMCUR).LEV    = [F:GRY]LEV
  this.PYRAMID(NUMCUR).PRNROW = [F:GRY]PRNROW
  Read [AXX]AXX0 = "GACCPYM";"DESTRA";this.ACTX.LAN;[F:GRY]PYM;""
  If fstat=0
   this.PYRAMID(NUMCUR).LIBPYM = [F:AXX]TEXTE
  Endif
  Read [AXX]AXX0 = "GACCGRUPYM";"DESTRA";this.ACTX.LAN;[F:GRY]PYM;[F:GRY]GRU
  If fstat=0
   this.PYRAMID(NUMCUR).LIBGRU = [F:AXX]TEXTE
  Endif
  If this.GAC.ACC<>[F:GRY]ACC
   this.PYRAMID(NUMCUR).CRI   = [F:GRY]ACC
  Endif
 Endif
Next

Return

