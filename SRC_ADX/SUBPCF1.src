#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
# SUBPCF1 : Saisie des critères pour filtre des pickings   MBT 18/09/08 #
#           sur factures et réceptions pour préchargement               #
#           des lignes d'une facture complémentaire                     #
# --------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par l'action de     #
#        saisie des critères "SAICRITFCC" et ne sert qu'à gérer le      #
#        masque écran "PCRITFCC [PCF1]".                                #
#########################################################################


$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "OUVRE_BOITE" : Gosub OUVRE_BOITE
  When "TITRE"       : Gosub TITRE_FEN
  When "DEBUT"       : Gosub DEBUT
  When "OK"          : Gosub OK
  When "ABA"         : Gosub ABA
  When "APRES_MODIF" : Gosub APRES_MODIF
  When "FINSAI"      : Gosub FINSAI
Endcase
Return

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE
Local  Integer  SAVNOLIGN   : SAVNOLIGN=nolign
Return

#-------------------------------#
# Après ouverture de la fenêtre #
#-------------------------------#
$OUVRE_BOITE
Return

#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_FEN
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT
Raz [M:PCF1]
[M:PCF1]=[M:PPI3]
Affzo [PCF1]1-99
If !clalev([F:BPT])  Local File BPCARRIER [BPT] : Endif
Return

#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK
[M:PPI3]=[M:PCF1]
FIN=1
Return

#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA
REP=""
[M:PCF1]=[M:PPI3]
Affzo [PCF1]1-99
Return

#------------------------------------#
# Après chaque modification de champ #
#------------------------------------#
APRES_MODIF
REP="M"
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI
nolign=SAVNOLIGN
Return


#################################################
# Actions sur champs de l'écran PCRITFCC [PCF1] #
#################################################
# Issue 82703 - 2012-10-04 by SR
######################################################################################
#------------------------------#
# Contrôle numéro de commande #
#------------------------------#
Subprog C_WPOHNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" End : Endif
#----- Contrôle d'existence et appartenance à la même société -----#
Read [POH] POH0=VALEUR : If fstat Raz [F:POH] :  Goto ERR_WPIHNUM2 : Endif
If [F:POH]CPY<>GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=1 : End  : Endif
#-----
End

Subprog C_WPIHNUM(VALEUR)
#----------------------------#
# Contrôle numéro de facture #
#----------------------------#
Variable Char    VALEUR()
If VALEUR="" End : Endif
#----- Contrôle d'existence et appartenance à la même société -----#
Read [PIHB] PIH0=VALEUR : If fstat Raz [F:PIHB] :  Goto ERR_WPIHNUM : Endif
If [F:PIHB]CPY<>GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=1 : End : Endif
#----- Date document d'origine pas supérieure à date document en cours -----#
If GCTLDATORI=2 & [F:PIHB]ACCDAT>[M:PIH0]ACCDAT
  GMESSAGE=mess(55,198,1)-VALEUR-"("+num$([F:PIHB]ACCDAT)+")\"-mess(408,194,1)
  mkstat=1 : End
Endif
#-----
End
#------ L'enregistrement n'existe pas ------#
$ERR_WPIHNUM
# GMESSAGE=mess(23,100,1) : mkstat=1
End

Subprog AM_WPIHNUM(VALEUR)
#----------------------------------#
# Après modif du numéro de facture #
#----------------------------------#
Variable Char    VALEUR()
End

Subprog C_WPTHNUM(VALEUR)
#------------------------------#
# Contrôle numéro de réception #
#------------------------------#
Variable Char    VALEUR()
If VALEUR="" End : Endif
#----- Contrôle d'existence et appartenance à la même société -----#
Read [PTH] PTH0=VALEUR : If fstat Raz [F:PTH] :  Goto ERR_WPIHNUM2 : Endif
If [F:PTH]CPY<>GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=1 : End  : Endif
#----- Date document d'origine pas supérieure à date document en cours -----#
#VPO 21/04/11 73382 ajout ctl DATORI aussi avec date BL
If GCTLDATORI=2
  If [F:PTH]NDEDAT=[0/0/0]
    If [F:PTH]RCPDAT>[M:PIH0]ACCDAT
      GMESSAGE=mess(117,198,1)-VALEUR-"("+format$(GFMD,[F:PTH]RCPDAT)+")\"-mess(410,194,1)
      mkstat=1 : End
    Endif
  Else
    If min([F:PTH]NDEDAT,[F:PTH]RCPDAT)>[M:PIH0]ACCDAT
      GMESSAGE=mess(117,198,1)-VALEUR-"("+format$(GFMD,min([F:PTH]NDEDAT,[F:PTH]RCPDAT))+")\"-mess(420,194,1)
      mkstat=1 : End
    Endif
  Endif
Endif
#-----
End

# Issue 110325 - 2016-01-05 by SR : FCC sur expé
######################################################################################
Subprog C_WSHIPNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" End : Endif
#----- Contrôle d'existence et appartenance à la même société -----#
# pas de société à l'entête d'expédition, on cherche donc au moins une ligne sur la bonne société
Filter [F:SHD] Where SHIPNUM = VALEUR & LEGCPY = GSOCIETE
Look [F:SHD]SHD0 First
Filter [F:SHD]
If fstat : GMESSAGE=mess(2,194,1) : mkstat=1 : End  : Endif
#Read [SHH] SHH0=VALEUR : If fstat Raz [F:SHH] :  Goto ERR_WPIHNUM2 : Endif
#If [F:SHH]LEGCPY<>GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=1 : End  : Endif
#-----
End

#------ L'enregistrement n'existe pas ------#
$ERR_WPIHNUM2
# GMESSAGE=mess(23,100,1) : mkstat=1
End

Subprog AM_WPTHNUM(VALEUR)
#------------------------------------#
# Après modif du numéro de réception #
#------------------------------------#
Variable Char    VALEUR()
End

Subprog IB_WBPSNUM
#-----------------------------------#
# Init bouton sur champ fournisseur #
#-----------------------------------#
GBOUT1=mess(457,198,1) : # Fournisseurs
End

Subprog AM_WBPSNUM(VALEUR)
#----------------------------#
# Après modif du fournisseur #
#----------------------------#
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR<>""
  If !instr(1,VALEUR,'*') &
&    !instr(1,VALEUR,'?') &
&    !instr(1,VALEUR,'#')
    If VALEUR<>[F:BPS]BPSNUM
      Read [BPS] BPS0=VALEUR : If fstat  Raz [F:BPS] : mkstat=1 : Endif
    Endif
    If [F:BPS]BPSNUM<>""  [M:PCF1]WBPSNAM=[F:BPS]BPSNAM : Endif
  Else
    Filter [BPS] Where pat(BPSNUM,VALEUR)
    Read [BPS] BPS0 First
    Filter [BPS]
    If fstat  Raz [F:BPS] : mkstat=2 : Endif
    If [F:BPS]BPSNUM<>""  Raz [M:PCF1]WBPSNAM : Endif
  Endif
Endif
Case mkstat
  When 1 : Call ERREUR(VALEUR-mess(541,199,1)) From GESECRAN : End  # Issue 108839 - 2015-06-23 by MUARN : erreur message
  When 2 : Call ERREUR(VALEUR-mess(314,194,1)) From GESECRAN : End
Endcase
Affzo [PCF1]WBPSNAM
End

