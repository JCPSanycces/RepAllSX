Subprog IB_WITMREF
#-----------------------------------------#
# Init bouton sur champ référence article #
#-----------------------------------------#
GBOUT1=mess(22,198,1) : # Articles
End

Subprog AM_WITMREF(VALEUR)
#--------------------------#
# Après modif de l'article #
#--------------------------#
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR<>""
  If !instr(1,VALEUR,'*') &
&    !instr(1,VALEUR,'?') &
&    !instr(1,VALEUR,'#')
    If VALEUR<>[F:ITM]ITMREF
      Read [ITM] ITM0=VALEUR : If fstat  Raz [F:ITM] : mkstat=1 : Endif
    Endif
    #If [F:ITM]ITMREF<>""  [M:PCF1]WITMDES=[F:ITM]ITMDES1 : Endif
    Local Char WITMDES(GLONDES)                                                          # FGR 30/06/2009 : X3SUIVI56189
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    If WITMDES<>""  [M:PCF1]WITMDES=WITMDES : Endif                                      # FGR 30/06/2009 : X3SUIVI56189
  Else
    Filter [ITM] Where pat(ITMREF,VALEUR)
    Read [ITM] ITM0 First
    Filter [ITM]
    If fstat  Raz [F:ITM] : mkstat=2 : Endif
    #If [F:ITM]ITMREF<>""  Raz [M:PCF1]WITMDES : Endif                                   # FGR 30/06/2009 : X3SUIVI56189
    Local Char WITMDES(GLONDES)                                                          # FGR 30/06/2009 : X3SUIVI56189
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    If WITMDES<>""  Raz [M:PCF1]WITMDES : Endif                                          # FGR 30/06/2009 : X3SUIVI56189
  Endif
Endif
Case mkstat
  When 1 : Call ERREUR(VALEUR-mess(212,199,1)) From GESECRAN : End
  When 2 : Call ERREUR(VALEUR-mess(314,194,1)) From GESECRAN : End
Endcase
Affzo [PCF1]WITMDES
End

