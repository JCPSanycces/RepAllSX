#<AdxTL>@(#)9.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# ASHW deferred validation
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("ASHW deferred validation") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
Local File ASHW    [AS3]
Else
Local File =DOSSIER+".ASHW"    [AS3]
Endif

Gosub MAJ_ASW

Close Local File [AS3]
End


#----------------------------------------------------------------------------------------#
$MAJ_ASW
Local Integer STAT
#Validation différée (à la volée)
Local Integer SAVGVALID
If dim(GVALIDDIFF)<=0 : Global Integer GVALIDDIFF : Endif
SAVGVALID=GVALIDDIFF
GVALIDDIFF=3

For [AS3]
 #97530 synchronisation
 STAT=0
 Call _TRTMAJ_ASWFLD(0,1,DOSSIER,[AS3]CODREP,STAT) From SUBASW_TOOL
 Call VALIDATION(0,DOSSIER,[AS3]CODREP) From SUBASW
Next

GVALIDDIFF=SAVGVALID
Return

#-----------------------------------------------------#

