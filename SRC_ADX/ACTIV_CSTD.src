#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure ACTIV

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_CONTROL_BEFORE"       : Gosub AINSERT_CONTROL_BEFORE
      When "AINSERT_BEFORE"               : Gosub AINSERT_BEFORE
      When "AINSERT_AFTER"                : Gosub AINSERT_AFTER
      When "AUPDATE_CONTROL_BEFORE"       : Gosub AUPDATE_CONTROL_BEFORE
      When "AUPDATE_BEFORE"               : Gosub AUPDATE_BEFORE
      When "AUPDATE_AFTER"                : Gosub AUPDATE_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "CODACT" : Gosub CODACT
  When "ACTSUP"   : Gosub ACTSUP
  When "DIMFIL"   : Gosub DIMFIL
  When "DIMMAX"   : Gosub DIMMAX
  When "DIME"     : Gosub DIME
  When "ACTDEP"   : Gosub ACTDEP
  When "RANG"     : Gosub RANG
  When "FLGSUP"   : Gosub FLGSUP
  When "DEP"      : Gosub DEP
  When "TYP"      : Gosub TYP
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return






#############################################################################################
$CODACT
Return

$ACTSUP
Case [L]ARULE
    When "CONTROL"          : Gosub ACTSUP_CONTROL
Endcase
Return

$ACTSUP_CONTROL
  Local Instance ACV2 Using C_ACTIV
  ACV2 = NewInstance C_ACTIV AllocGroup null
  If this.ACTSUP <> ""
    [L]ASTATUS = fmet ACV2.AREAD(this.ACTSUP)
    If [L]ASTATUS = [V]CST_AOK | ACV2.FLGSUP<>2
     [L]ASTATUS = fmet this.ASETERROR("ACTSUP","Code activité non superviseur",[V]CST_AERROR)
    Endif
  Endif
  FreeGroup ACV2
Return

#############################################################################################
$DIMFIL
Case [L]ARULE
    When "CONTROL"          : Gosub DIMFIL_CONTROL
Endcase
Return

$DIMFIL_CONTROL
  If this.DIMFIL > 32767
    #Value too large (maximum #)
    [L]ASTATUS = fmet this.ASETERROR("DIMFIL",mess(115,75,1),[V]CST_AERROR)
  Endif
  If this.DIMFIL < 0
    #Invalid value
    [L]ASTATUS = fmet this.ASETERROR("DIMFIL",mess(126,143,1),[V]CST_AERROR)
  Endif
Return

#############################################################################################
$DIMMAX
Case [L]ARULE
    When "CONTROL"          : Gosub DIMMAX_CONTROL
Endcase
Return

$DIMMAX_CONTROL
  If this.DIMMAX > 32767
    #Value too large (maximum #)
    [L]ASTATUS = fmet this.ASETERROR("DIMMAX",mess(115,75,1),[V]CST_AERROR)
  Endif
  If this.DIMMAX < 0
    #Invalid value
    [L]ASTATUS = fmet this.ASETERROR("DIMMAX",mess(126,143,1),[V]CST_AERROR)
  Endif
  If this.DIMMAX <> 0 & this.DIMMAX < this.DIMFIL
    #Invalid value
    [L]ASTATUS = fmet this.ASETERROR("DIMMAX",mess(126,143,1),[V]CST_AERROR)
  Endif
Return

#############################################################################################
$DIME
Case [L]ARULE
    When "CONTROL"          : Gosub DIME_CONTROL
Endcase
Return

$DIME_CONTROL
Local Integer MY_STATUS : [L]MY_STATUS=[V]CST_AOK
  If this.DIME > 32767
    # Value too large (maximum #)
    [L]MY_STATUS = fmet this.ASETERROR("DIME",mess(115,75,1),[V]CST_AERROR)  #Value too large (maximum #)
  Elsif this.DIME < 0
    # Invalid value
    [L]MY_STATUS = fmet this.ASETERROR("DIME",mess(126,143,1),[V]CST_AERROR)  #Invalid value
  Endif
  If this.DIMMAX <> 0
    If this.DIME<>0 & this.DIME>this.DIMMAX
      # Invalid value
      [L]MY_STATUS = fmet this.ASETERROR("DIME",mess(126,143,1),[V]CST_AERROR)  #Invalid value
      [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
    Endif
    # Statistical criteria
    If this.CODACT="STT" & this.DIME<this.DIMFIL
      # Invalid value
      [L]MY_STATUS = fmet this.ASETERROR("DIME",mess(126,143,1),[V]CST_AERROR)  #Invalid value
      [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
    Endif
  Endif
Return
#############################################################################################
$ACTDEP
Case [L]ARULE
    When "CONTROL"          : Gosub ACTDEP_CONTROL
Endcase
Return

$ACTDEP_CONTROL
  Local Instance ACV2 Using C_ACTIV
  ACV2 = NewInstance C_ACTIV AllocGroup null
  If this.ACTDEP <> ""
    [L]ASTATUS = fmet ACV2.AREAD(this.ACTDEP)
    If [L]ASTATUS = [V]CST_AOK
      If ACV2.DEP<>1
        #Activity code depending on ...
        [L]ASTATUS = fmet this.ASETERROR("ACTDEP",mess(55,126,1)-[F:ACV2]ACTDEP,[V]CST_AERROR)
      Endif
    Endif
  Endif
  FreeGroup ACV2
Return

#############################################################################################
$RANG
Case [L]ARULE
    When "CONTROL"          : Gosub RANG_CONTROL
Endcase
Return

$RANG_CONTROL
  If this.RANG < 0
    # Invalid value
    [L]ASTATUS = fmet this.ASETERROR("RANG",mess(126,143,1),[V]CST_AERROR)  #Invalid value
  Endif
Return

#############################################################################################
$FLGSUP
Case [L]ARULE
    When "PROPAGATE"        : Gosub FLGSUP_PROPAGATE
Endcase
Return


$FLGSUP_PROPAGATE
  If this.FLGSUP = [V]CST_AYES
    this.ACTSUP = AVOID.ACHAR
  Endif
Return

#############################################################################################
$DEP
Case [L]ARULE
    When "PROPAGATE"        : Gosub DEP_PROPAGATE
Endcase
Return

$DEP_PROPAGATE
  Case this.DEP
    When 2,3
      # When reverse or sizing
      this.ACTFOR = AVOID.ACHAR
    When 4
      # When formula
      this.ACTDEP = AVOID.ACHAR
    When Default
      # When none
      this.ACTFOR = AVOID.ACHAR
      this.ACTDEP = AVOID.ACHAR
  Endcase
  Gosub TYP_PROPAGATE
Return

#############################################################################################
$TYP
Case [L]ARULE
    When "PROPAGATE"        : Gosub TYP_PROPAGATE
Endcase
Return

$TYP_PROPAGATE
  #Enable sizing dimensions if type is Sizing
  If this.TYP = 2
    # Sizing based on formula
    If this.DEP = 4
      this.DIME = AVOID.AINT
    Else
      # Sizing based on dependency activity code
      If this.DEP = 3 & this.ACTDEP<>""
        Local File ACTIV [ACV]
        Read [ACV]CODACT = this.ACTDEP
        If fstat
          # Record does not exist
          [L]ASTATUS=fmet this.ASETERROR("ACTDEP",mess(23,100,1),[V]CST_AERROR)
          Return
        Endif
        # Sizing type
        If [F:ACV]TYP=2
         this.DIME = AVOID.AINT
        Endif
      Endif
    Endif
  Else
    # Not a sizing activity code
    this.DIMFIL = AVOID.AINT
    this.DIMMAX = AVOID.AINT
    this.DIME   = AVOID.AINT
  Endif
Return

#############################################################################################
$AUPDATE_CONTROL_BEFORE
Gosub CONTROL_BEFORE
Return

#############################################################################################
$AINSERT_CONTROL_BEFORE
Gosub CONTROL_BEFORE
Return

#############################################################################################
$CONTROL_BEFORE
If this.TYP=2 & this.DIME=0 & this.FLACT=[V]CST_AYES
 this.FLACT = [V]CST_ANO
 # Sizing type and dimension of 0
 # Screen dimension not defined - Activity code de-activated
 [L]ASTATUS = fmet this.ASETERROR("DIME",mess(155,125,1)+"\"+mess(62,139,1),[V]CST_AERROR)
Endif

# Set Order based on module and sequence
Case this.MODULE
 When 1       : this.ORDRE = 0
 When 9       : this.ORDRE = 1000
 When 2       : this.ORDRE = 2000
 When 3       : this.ORDRE = 3000
 When 4       : this.ORDRE = 4000
 When 7       : this.ORDRE = 5000
 When 5       : this.ORDRE = 6000
 When 6       : this.ORDRE = 7000
 When 8       : this.ORDRE = 8000
 When 10      : this.ORDRE = 9000
 When Default : this.ORDRE = 10000
Endcase
this.ORDRE += this.RANG

If [L]ASTATUS = [V]CST_AOK & this.ASTALIN=[V]CST_AUPD
  # Activivty code modification must be followed by a dictionary validation
  [L]ASTATUS = fmet this.ASETERROR("UPDATE",mess(187,125,1),[V]CST_AWARNING)
Endif
Return

#############################################################################################
$AINSERT_AFTER
  Gosub PROPERTY_DEPENDENCY
Return

#############################################################################################
$AUPDATE_AFTER
  Gosub PROPERTY_DEPENDENCY
Return

#############################################################################################
$PROPERTY_DEPENDENCY
# Update dependency activity codes
Local File ACTIV   [ACV2]
Local File ADOSACT [ADA2]
Local Integer RESULT,OK,MY_STATUS

# Reverse and sizing update dependency
For [ACV2] Where CODACT=this.ACTDEP & DEP>=2
  Case [F:ACV2]DEP
    When 2          : If this.FLACT=[V]CST_AYES : [F:ACV2]FLACT=[V]CST_ANO : Else [F:ACV2]FLACT=[V]CST_AYES : Endif
    When 3          : Gosub DEP_DEPENDENCY
  Endcase
  Gosub REWRITE_ACV2
  [L]MY_STATUS = fmet this.ASETERROR("DEP",mess(68,139,1)-[F:ACV2]CODACT,[V]CST_AINFO)
Next

# Formula dependency
For [ACV2] Where DEP=4 and instr(1,ACTFOR,this.CODACT)<>0
  Call FORMULE([F:ACV2]ACTFOR,RESULT,OK)
  If OK=[V]CST_ATRUE
    If RESULT>0
      [F:ACV2]FLACT = [V]CST_AYES
      If [F:ACV2]TYP=2
        [F:ACV2]DIME = min(max([F:ACV2]DIMFIL,RESULT),[F:ACV2]DIMMAX)
      Else
        [F:ACV2]DIME = 0
      Endif
    Else
      [F:ACV2]FLACT = [V]CST_ANO
    Endif
  Endif
  Gosub REWRITE_ACV2
  [L]MY_STATUS = fmet this.ASETERROR("DEP",mess(5,142,1)-[F:ACV2]CODACT,[V]CST_AINFO)
  [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
Next
Return

$REWRITE_ACV2
Local Integer MY_STATUS
# Rewrite dependency activity code
Rewrite [ACV2]
If fstat<>[V]CST_AOK
  [L]MY_STATUS = fmet this.ASETERROR("ACV2",mess(6,123,1)-[F:ACV2]CODACT,[V]CST_AERROR)
  [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
Endif

# Rewrite ADOSACT
Readlock [ADA2]ADA0 = this.ACTX.AFOLDER;[F:ACV2]CODACT
If fstat=[V]CST_AOK
  [F:ADA2]FLACT = [F:ACV2]FLACT
  [F:ADA2]DIME  = [F:ACV2]DIME
  Rewrite [ADA2]
  If fstat <> [V]CST_AOK
    [L]MY_STATUS = fmet this.ASETERROR("ADA2",mess(6,123,1)-[F:ACV2]CODACT,[V]CST_AERROR)
    [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
  Endif
Else
  [L]MY_STATUS = fmet this.ASETERROR("ACV2",mess(6,123,1)-[F:ACV2]CODACT,[V]CST_AERROR)
  [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
Endif
Return

#############################################################################################
$AINSERT_BEFORE
  Gosub PROPERTY_BEFORE
Return

#############################################################################################
$AUPDATE_BEFORE
  Gosub PROPERTY_BEFORE
Return

#############################################################################################
$PROPERTY_BEFORE
Local Integer RESULT,OK
# Formula dependency on current activity code
If this.DEP=4 & this.ACTFOR<>""
  Call FORMULE(this.ACTFOR,RESULT,OK)
  If OK=[V]CST_ATRUE
    If RESULT>0
      this.FLACT = [V]CST_AYES
      If this.TYP=2
        this.DIME = min(max(this.DIMFIL,RESULT),this.DIMMAX)
      Else
        this.DIME = 0
      Endif
    Else
      this.FLACT = [V]CST_ANO
    Endif
  Else
    this.FLACT = [V]CST_ANO
  Endif
Endif

# Reverse or sizing dependency
If this.DEP>=2 & this.DEP<4 & this.ACTDEP<>AVOID.ACHAR
  Read [F:ACV2]CODACT = this.ACTDEP
  If fstat=[V]CST_AOK
    Case this.DEP
      When 2 : If [F:ACV2]FLACT=2 : this.FLACT = 1 : Else : this.FLACT = 2 : Endif
      When 3 : Gosub DEP_DEPENDENCY
    Endcase
  Else
    [L]MY_STATUS = fmet this.ASETERROR("ACV2",mess(6,123,1)-[F:ACV2]CODACT,[V]CST_AERROR)
    [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
  Endif
Endif

# Update ADOSACT collection
this.ADA.INTIT = this.INTIT
this.ADA.FLACT = this.FLACT
this.ADA.DIME  = this.DIME

Return

################################################################################################
$DEP_DEPENDENCY
Local Integer TMP_DIME
Local Char CC(1)
# Sizing type
If this.TYP<>2
 CC = right$(this.CODACT,len(this.CODACT))
 If CC>="1" & CC<="9"
  TMP_DIME = val(CC)
 Elsif CC>="A" & CC<="Z"
  TMP_DIME = ascii(CC)-55
 Else
  TMP_DIME = 0
 Endif
 If TMP_DIME<=[F:ACV2]DIME : this.FLACT = [V]CST_AYES : Else : this.FLACT = [V]CST_ANO : Endif
Else
 this.FLACT = [F:ACV2]FLACT
 this.DIME  = min(max(this.DIMFIL,[F:ACV2]DIME),this.DIMMAX)
Endif
Return

###########################################################
Subprog FORMULE(EXPR,RESULT,OK)
Value    Char    EXPR
Variable Integer RESULT, OK
Local Integer I_ , DEB_ , FIN_ , RES_ , ASTATUS
Local Char    ACT_(30) , CAR_(1) , EXP_(250) , MES_(250)

EXP_ = format$("KTv2:250X",EXPR)
DEB_ = 0
I_ = 1
While 1=1
 CAR_ = mid$(EXP_,I_,1)
 If (CAR_>="A" & CAR_<="Z") | (CAR_>="0" & CAR_<="9" & DEB_>0)
  If DEB_=0 : DEB_ = I_ : Endif
  FIN_ = I_
 Elsif DEB_
  Gosub REMP
 Endif
 I_ += 1
 If I_>len(EXP_) : Break : Endif
Wend
If DEB_
 Gosub REMP
Endif
OK = [V]CST_ATRUE
Onerrgo ERRACT
RESULT = evalue(EXP_)
Onerrgo

End

$ERRACT
# Error in formula evaluation
MES_ = mess(65,106,1)-"("+EXP_+") : "+errmes$(errn)-errm :
[L]ASTATUS = fmet this.ASETERROR("ACTIV",MES_,[V]CST_AERROR)
OK=[V]CST_AFALSE
Resume

$REMP
Local Integer MY_STATUS
ACT_ = seg$(EXP_,DEB_,FIN_)
Local Instance TMP_ADOSACT Using C_ADOSACT
TMP_ADOSACT=NewInstance C_ADOSACT AllocGroup null
[L]MY_STATUS=fmet TMP_ADOSACT.AREAD(TMP_ADOSACT.ACTX.AFOLDER,ACT_)
If [L]MY_STATUS=[V]CST_AOK
   If TMP_ADOSACT.FLACT<>[V]CST_AYES
    RES_ = 0
   Elsif TMP_ADOSACT.DIME>0
    RES_ = TMP_ADOSACT.DIME
   Else
    RES_ = 1
   Endif
   EXP_ = left$(EXP_,DEB_-1)+num$(RES_)+right$(EXP_,FIN_+1)
   I_ = DEB_-1+len(num$(RES_))
Endif
DEB_=0
FreeGroup TMP_ADOSACT
Return

