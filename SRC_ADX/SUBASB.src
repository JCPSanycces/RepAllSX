#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet ASB
Raz GPILOBJ
Call OBJET("ASB",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "SETBOUT"  : Gosub SETBOUT
 When "LIENS"    : Gosub LIENS
 When "INICRE"   : Gosub INICRE
 When "INIMOD"   : Gosub INIMOD
 When "CREATION" : Gosub CREATION
 When "MODIF"    : Gosub MODIF
Endcase
Return

######################################################################################


$OUVRE
Local Char DOSX3(GLONADS)
Call PARAM("","SUPDOS",DOSX3) From ADOVAL
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU or nomap<>DOSX3
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Call VIREBOUT(CHAINE,"H") From GOBJET
If nomap<>GDOSX3
  Call VIREBOUT(CHAINE,"AMC") From GOBJET  : # On interdit les mise à jour si on n'est pas sur le dossier mère
Endif
Return

$LIENS
Call TEXTE([M]INTIT1,[M]ZINTIT) From OBJDIV
Case [M]TYPFIC
 When 2 : # Texte
  Read [ASA]ASA0=[M]CAT;[M]CODFIC
  If !fstat
   [M]TEXTE = [F:ASA]CLOB
  Endif
 When 3 : # Image
  [M]PHOTO = [F:ASB]BLOB
 When Default
  #TODO [M]BUREAU = [F:ASB]BLOB
Endcase
Gosub GRISE_BLOB

Return

$GRISE_BLOB
Case [M]TYPFIC
 When 2 : # Texte
  Effzo PHOTO :#TODO , BUREAU
  Grizo PHOTO :#TODO , BUREAU
  Actzo TEXTE
 When 3 : # Image
  Effzo TEXTE :#TODO , BUREAU
  Grizo TEXTE :#TODO , BUREAU
  Actzo PHOTO
 When Default : # Bureautique
  Effzo PHOTO , TEXTE
  Grizo PHOTO , TEXTE
  :#TODO , Actzo BUREAU
Endcase
Return

$INICRE
$INIMOD
Case [M]TYPFIC
 When 3       : [F:ASB]BLOB = [M]PHOTO
 :#TODO ,When Default : [F:ASB]BLOB = [M]BUREAU
Endcase
Return

$CREATION
If [M:ASB1]TYPFIC=2
 Raz [F:ASA]
 [F:ASA] = [M:ASB1]
 [F:ASA]CLOB = [M:ASB1]TEXTE
 Write [ASA]
 If fstat
  GOK=0 : Call FSTA("ASA") From GLOCK : Return
 Endif
Endif
Return

$MODIF
Delete [ASA] Where CAT=[M]CAT & CODFIC=[M]CODFIC
Goto CREATION
Return

######################################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File ABLBSYS  [ASB1]
 Local File ACLBSYS  [ASA1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".ABLBSYS"  [ASB1]
 Local File =[M]DOSORG+".ACLBSYS"  [ASA1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ABLBSYS  [ASB2]
 Local File ACLBSYS  [ASA2]
 Local File ATEXTE  [ATX2]
Else
 Local File =[M]DOSDES+".ABLBSYS"  [ASB2]
 Local File =[M]DOSDES+".ACLBSYS"  [ASA2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ASB1], [ASA1], [ASB2], [ASA2], [ATX1], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ASB2] , [ASA2], [ATX2]
 Delete [ASB2] Where CAT=TABLE & CODFIC=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASB2" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASB2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASA2] Where CAT=TABLE & CODFIC=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASA2" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASA2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ASB1]ASB0  Where CAT=TABLE & CODFIC=TABLE2
  [F:ASB2] = [F:ASB1]
  Call COPTEXTE([F:ASB1]INTIT1,[F:ASB2]INTIT1) From OBJDIV
  If dim([F:ASB2]UPDUSR)>0 : [F:ASB1]UPDUSR = GUSER : Endif
  If dim([F:ASB2]UPDDAT)>0 : [F:ASB1]UPDDAT = date$ : Endif
  If dim([F:ASB2]UPDTIM)>0 : [F:ASB1]UPDTIM = time : Endif
  Write [ASB2]
  If fstat
   GOK=0 : Call FSTA("ASB2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ASA1]ASA0  Where CAT=TABLE & CODFIC=TABLE2
  [F:ASA2] = [F:ASA1]
  If dim([F:ASA2]UPDUSR)>0 : [F:ASA1]UPDUSR = GUSER : Endif
  If dim([F:ASA2]UPDDAT)>0 : [F:ASA1]UPDDAT = date$ : Endif
  If dim([F:ASA2]UPDTIM)>0 : [F:ASA1]UPDTIM = time : Endif
  Write [ASA2]
  If fstat
   GOK=0 : Call FSTA("ASA2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

######################################################################################
Subprog AS_TYPFIC(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1
GMENLOC(4) = 1
End

Subprog C_TYPFIC(VALEUR)
Variable Integer VALEUR
[M]TYPFIC = VALEUR
Gosub GRISE_BLOB
End

Subprog C_NAMFIC(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,1)="#"
 GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
 mkstat = 2 : End
Endif
End
