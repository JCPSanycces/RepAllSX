#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGPREPUR06   Pre-migration Réceptions                    Module Achats #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPREPUR06") From LECFIC
  Endif

  Call MAJ_UUMGPREPUR06(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


###################################################################################
Subprog MAJ_UUMGPREPUR06(DOSSIER)
Value Char DOSSIER

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif

Call ECR_TIME("UUMGPREPUR06 Purchase Receipts Process : Update PRECEIPT") From DOSSUB
Call ECR_TRACE("UUMGPREPUR06 : Process Start on : "+DOSSIER,0) From GESECRAN
# Issue 386 - 2013-04-29 by MAE : prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call VERSION (DOSSIER,VERSION) From DOSSUB
If val(VERSION)=0
  # N° de version incorrecte
  Call ECR_TRACE("UUMGPREPUR06 : Error on release number : "+VERSION,0) From GESECRAN
  End
Endif
#----- Avoir les globales pour tester les versions
Gosub DEF_VERSIONSX3 From TRTMIGTABX3
#fin MAE 386

Local Integer ERR
If val(VERSION)<GMIGX3VER60
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table POH
  # ----------------------------------------
  Gosub ADDCOLV6
  If ERR : Goto FIN : Endif

  Gosub TRT_X3_V6
  #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"PRECEIPT",ERR) From TRTMIG
  If ERR : Goto FIN : Endif

Endif
# Passage en V7
If val(VERSION)<GMIGX3VER70
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table POH
  # ----------------------------------------
  Gosub ADDCOLV7
  If ERR : Goto FIN : Endif

  Gosub TRT_X3_V7

  #--------------- Suppression index ----------#
  #Call MIGINDDEL (DOSSIER,"PORDER",ERR) From TRTMIG
  #If ERR : Goto FIN : Endif
Endif
#Fin MAE 386
$FIN
Call ECR_TIME("UUMGPREPUR06 : Purchase Orders Process END.")  From DOSSUB
End

############################################################
$ADDCOLV6

  #1- ajouter la colonne dans la table POH
  Call MIGADDCOL (DOSSIER,"PRECEIPT","FFWADD","A",5,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"PRECEIPT","BPAINV","A",5,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"PRECEIPT","EECNUM","A",20,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

  #2- ajouter un index unique
  #--------------- INDEX ADDITION  ----------#
  Call MIGINDCRE (DOSSIER,"PRECEIPT","BPSNUM+PTHNUM","","",0,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

Return
############################################################
# Issue 386 - 2013-04-29 by MAE : prise en compte des versions
$ADDCOLV7
Return
############################################################
$TRT_X3_V7
Return
############################################################
$TRT_X3_V6
Local Integer COMPTEUR


#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:PTH]) : Close File [PTH] : Endif
Local File =DOSSIER+".PRECEIPT"   [PTH]
Local File =DOSSIER+".PRECEIPTD"  [PTD]
Local File =DOSSIER+".BPARTNER"   [BPR]
Local File =DOSSIER+".BPSUPPLIER" [BPS]
Local File =DOSSIER+".BPADDRESS"  [BPA]
Local File =DOSSIER+".ACTIV"      [ACV]

If dim(GACTDEB)<1  Global Libelle  GACTDEB : Endif
#----- Code activité "DEB" Déclaration échange de biens CEE -----#
Read [ACV] CODACT="DEB"
If !fstat
  GACTDEB=[F:ACV]FLACT
Else
  GACTDEB=2
Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1, ACLE2
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST
Link [PTH] With [BPS]BPS0=[F:PTH]BPSNUM As [LNK] Order By Key CLE=[F:PTH]BPSNUM;[F:PTH]PTHNUM

$LOOP_PUR04
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:PTH]BPSNUM=ACLE1 & [F:PTH]PTHNUM>ACLE2"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:PTH]BPSNUM>ACLE1"
Else
 CRITERE = "1=1"
Endif

Trbegin [PTH]
GOK = 1

For [LNK]CLE Where evalue(CRITERE)

  # --- alimentation des champs et écriture enreg
  Gosub MAJ30_PTH
  If GOK<1 : Break : Endif

  Rewrite [F:PTH]
  If fstat
    Call ECR_TRACE("File PRECEIPT(PTHNUM)"-[F:PTH]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:PTH]BPSNUM
    ACLE2 = [F:PTH]PTHNUM
    STOP=1
    Break
  Endif
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_PUR04
  Endif
Endif

$FIN_1
Gosub UNSET_FIRST From TRTFIRST
Close Local File [PTH],[PTD],[ACV],[BPS],[BPR],[BPA]
Call ECR_TIME("UUMGPREPUR06 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB
Return

###################################################################################
$MAJ30_PTH
    #----- Alimentation code adresse transitaire -----#
    If [F:PTH]FFWNUM<>"" & [F:PTH]FFWADD=""
      Gosub LECT_BPRFFW
      [F:PTH]FFWADD=[F:BPR]BPAADD
    Endif
    #----- Alimentation code adresse fournisseur facturant -----#
    If [F:PTH]BPAINV=""
      Gosub LECT_BPSI
      If [F:BPR]BPRNUM<>[F:BPS]BPSNUM
        Read [BPR] BPR0=[F:BPS]BPSNUM : If fstat  Raz [F:BPR] : Endif
      Endif
      [F:PTH]BPAINV=[F:BPR]BPAADD
    Endif
    #----- Alimentation de l'identification CEE -----#
    If GACTDEB=2 & [F:PTH]EECNUM=""
      Gosub LECT_BPRI
      [F:PTH]EECNUM=[F:BPR]EECNUM
    Endif
Return


################################################
$LECT_BPSPTH
  If [F:BPS]BPSNUM<>[F:PTH]BPSNUM
    WBPS=[F:PTH]BPSNUM
    Gosub LECT_BPS
  Endif
Return

$LECT_BPSI
  If [F:BPS]BPSNUM<>[F:PTH]BPSINV
    WBPS=[F:PTH]BPSINV
    Gosub LECT_BPS
  Endif
Return

$LECT_BPS
    Read [BPS] BPS0=WBPS : If fstat  Raz [F:BPS] : Endif
Return
################################################
$LECT_BPRI
  If [F:BPR]BPRNUM<>[F:PTH]BPSINV
    WBPR=[F:PTH]BPSINV
    Gosub LECT_BPR
  Endif
Return

$LECT_BPRFFW
  If [F:BPR]BPRNUM<>[F:PTH]FFWNUM
    WBPR=[F:PTH]FFWNUM
    Gosub LECT_BPR
  Endif
Return

$LECT_BPR
    Read [BPR] BPR0=WBPR : If fstat  Raz [F:BPR] : Endif
Return

