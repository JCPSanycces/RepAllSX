#<AdxTL>@(#)10.0.0.0 $Revision$
#############################################################################
# TRTX3BI    Fonctions pour la Business Intelligence    Module Tronc commun #
# ------------------------------------------------------------------------- #
# GETEXE    : Détermination no exercice d'une société d'après une date      #
# GETPER    : Détermination no période  d'une société d'après une date      #
# GETCPY    : Détermination de la société d'un site                         #
# GETFINRSP : Détermination du site financier d'un site                     #
# GETSYSCUR : Détermination de la devise dossier (GDOSSIER)                 #
# GETCUR    : Détermination de la devise société d'un site ou d'une société #
# GETRATCUR : Récupération cours devise société d'un document               #
# GETRATRPT : Récupération cours devise dossier d'un document               #
# GETADD    : Détermination des caractéristiques d'une adresse              #
# GETLASTLIN: Détermination du dernier numéro de ligne utilisé + 1000       #
#                                                                           #
# CNVQTYTCO : Conversion d'une quantité avec arrondi avec la table TCO      #
# CNVQTY    : Conversion d'une quantité avec arrondi                        #
# CNVAMT    : Conversion d'un montant dans une devise                       #
# CNVCPYRPT : Conversion d'un montant devise société vers devise dossier    #
# CNVAMTRPT : Conversion d'un montant en devise dossier                     #
# CNVCPY    : Conversion d'un montant dans la devise de la société          #
#                                                                           #
# BPRNAM    : Récupération raison sociale business partner                  #
# BPSNAM    : Récupération raison sociale fournisseur                       #
# BPCNAM    : Récupération raison sociale client                            #
#                                                                           #
# SETCOA    : Recup. plan de compte du type référentiel et de la société    #
# SETACC    : Recup. compte correspondant au type référenciel et à la soc.  #
# *** Immobilisations ***                                                   #
# GETCOA    : Recup. plan de compte du contexte d'amortissement             #
# ------------------------------------------------------------------------- #
# Nota : Les globales ne sont pas forcément significatives                  #
#        Dans la déclaration des variables, les GLONxxx ont été remplacés   #
#        par des valeurs "en dures"                                         #
#        La globale GDOSSIER est significative, elle contient le nom du     #
#        dossier en cours de traitement et sert pour l'ouverture des tables #
#############################################################################
 
###################################################################
# GETEXE Détermination no exercice d'une société d'après une date #
# Get exercice                                                    #
###################################################################
Funprog GETEXE(SITE,DAT)
Value    Char    SITE     : # Site ou société
Value    Date    DAT      : # Date
#-----
Local    Decimal EXE      : # No exercice en DCB pour le Call
Local    Integer EXERCICE : # No exercice
Local    Char    SOCIETE(10)
Local    Integer TYPGEN
#-----
If !clalev([F:FIY])  Local File =GDOSSIER+".FISCALYEAR" [FIY] : Endif
#-----
SOCIETE=func GETCPY(SITE)
If SOCIETE=""  SOCIETE=SITE : Endif
#-----
#----- Pour la V6, il faut récupérer le type référenciel général principal -----#
TYPGEN=1
If !clalev([F:CPY])  Local File =GDOSSIER+".COMPANY" [CPY] : Endif
Read [CPY] CPY0=SOCIETE
If !fstat
  If !clalev([F:GCM])  Local File =GDOSSIER+".GACM" [GCM] : Endif
  Read [GCM] GCM0=[F:CPY]ACM
  If !fstat
    TYPGEN=[F:GCM]GENLEDTYP
  Endif
Endif
#-----
Call GETEXE(SOCIETE,TYPGEN,DAT,EXE) From CPTSUB
EXERCICE=EXE
#-----
End EXERCICE


##################################################################
# GETPER Détermination no période d'une société d'après une date #
# Get periode                                                    #
##################################################################
Funprog GETPER(SITE,DAT)
Value    Char    SITE    : # Site ou société
Value    Date    DAT     : # Date
#-----
Local    Decimal EXE     : # No exercice en DCB pour le Call
Local    Decimal PER     : # No période  en DCB pour le Call
Local    Integer PERIODE : # No période
Local    Char    SOCIETE(10)
Local    Integer TYPGEN
#-----
If !clalev([F:PER])  Local File =GDOSSIER+".PERIOD" [PER] : Endif
#-----
SOCIETE=func GETCPY(SITE)
If SOCIETE=""  SOCIETE=SITE : Endif
#----- Pour la V6, il faut récupérer le type référenciel général principal -----#
TYPGEN=1
If !clalev([F:CPY])  Local File =GDOSSIER+".COMPANY" [CPY] : Endif
Read [CPY] CPY0=SOCIETE
If !fstat
  If !clalev([F:GCM])  Local File =GDOSSIER+".GACM" [GCM] : Endif
  Read [GCM] GCM0=[F:CPY]ACM
  If !fstat
    TYPGEN=[F:GCM]GENLEDTYP
  Endif
Endif
#-----
Call GETPERSOC(SOCIETE,TYPGEN,DAT,EXE,PER) From CPTSUB
PERIODE=PER
#-----
End PERIODE


################################################
# GETCPY Détermination de la société d'un site #
# Get company                                  #
################################################
Funprog GETCPY(SITE)
Value    Char    SITE
#-----
If !clalev([F:FCY])  Local File =GDOSSIER+".FACILITY" [FCY] : Endif
#----- Lecture du site si nécessaire -----#
If [F:FCY]FCY<>SITE
  Read [FCY] FCY0=SITE : If fstat  Raz [F:FCY] : Endif
Endif
#-----
End [F:FCY]LEGCPY


#######################################################
# GETFINRSP Détermination du site financier d'un site #
# Get financial response facility                     #
#######################################################
Funprog GETFINRSP(SITE)
Value    Char    SITE
#-----
If !clalev([F:FCY])  Local File =GDOSSIER+".FACILITY" [FCY] : Endif
#----- Lecture du site si nécessaire -----#
If [F:FCY]FCY<>SITE
  Read [FCY] FCY0=SITE : If fstat  Raz [F:FCY] : Endif
Endif
#----- Par défaut le site financier est le site lui-même -----€
If [F:FCY]FINRSPFCY=""  [F:FCY]FINRSPFCY=[F:FCY]FCY : Endif
#-----
End [F:FCY]FINRSPFCY


#############################################################
# GETSYSCUR : Détermination de la devise dossier (GDOSSIER) #
# Get system currency                                       #
#############################################################
Funprog GETSYSCUR
#-----
Local Char DEVISE(10)
#-----
If !clalev([F:ADW])  Local File =GDOSSIER+".ADOVAL" [ADW] : Endif
If !clalev([F:ADP])  Local File =GDOSSIER+".ADOPAR" [ADP] : Endif
#-----
Call PARAML("","SYSCUR",DEVISE) From ADOVAL
#-----
End DEVISE


########################################################################
# GETCUR Détermination de la devise société d'un site ou d'une société #
# Get currency                                                         #
########################################################################
Funprog GETCUR(SITE)
Value    Char    SITE
#-----
If !clalev([F:CPY])  Local File =GDOSSIER+".COMPANY"  [CPY] : Endif
If !clalev([F:FCY])  Local File =GDOSSIER+".FACILITY" [FCY] : Endif
#----- Lecture du site si nécessaire -----#
If [F:FCY]FCY<>SITE
  Read [FCY] FCY0=SITE : If fstat  Raz [F:FCY] : Endif
Endif
#----- Si le paramètre passé n'est pas un site alors c'est une société ! -----#
If [F:FCY]LEGCPY=""  [F:FCY]LEGCPY=SITE : Endif
#----- Lecture de la société si nécessaire -----#
If [F:CPY]CPY<>[F:FCY]LEGCPY
  Read [CPY] CPY0=[F:FCY]LEGCPY : If fstat  Raz [F:CPY] : Endif
Endif
#-----
End [F:CPY]ACCCUR


#############################################################
# GETRATCUR Récupération cours devise société d'un document #
# Get rate currency                                         #
#############################################################
#Funprog GETRATCUR(ABREV)
#Value    Char    ABREV  : # Abréviation table du document
##-----
#Local    Decimal WCOURS
#Local    Char    WDEVISE(GLONCUR)
#Local    Integer WI
##-----
#Case ABREV
#  When "PIH"
#    WDEVISE=func TRTX3BI.GETCUR([F:PIH]FCY)
#    WI=find(WDEVISE,[F:PIH]CURLED)
#    If WI
#      WCOURS=arr([F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1),10^-6)
#    Else
#      WCOURS =0
#    Endif
#  When "SIH"
#    WDEVISE=func TRTX3BI.GETCUR([F:SIH]FCY)
#    WI=find(WDEVISE,[F:SIH]CURLED)
#    If WI
#      WCOURS=arr([F:SIH]RATMLT(WI-1)/[F:SIH]RATDIV(WI-1),10^-6)
#    Else
#      WCOURS =0
#    Endif
#Endcase
##-----
#End WCOURS

Funprog GETRATCUR(ABREV)
Value    Char    ABREV  : # Abréviation table du document
#-----
Local    Decimal WCOURS
Local    Char    WDEVISE(GLONCUR), WFCY(GLONFCY), WCURLED(GLONCUR)
Local    Integer WI
#-----
If ABREV="" End Endif

WFCY=evalue("[F:"+ABREV+"]FCY")
WCURLED=evalue("[F:"+ABREV+"]CURLED")

WDEVISE=func TRTX3BI.GETCUR(WFCY)
WI=find(WDEVISE,WCURLED)
If WI & evalue("[F:"+ABREV+"]RATDIV("+num$(WI-1)+")")<>0
    WCOURS=arr(evalue("[F:"+ABREV+"]RATMLT("+num$(WI-1)+")")/evalue("[F:"+ABREV+"]RATDIV("+num$(WI-1)+")"),10^-6)
Else
    WCOURS =0
Endif
#-----
End WCOURS

#############################################################
# GETRATRPT Récupération cours devise dossier d'un document #
# Get rate reporting currency                               #
#############################################################
Funprog GETRATRPT(ABREV,NUMDOC)
Value    Char    ABREV  : # Abréviation table du document
Value    Char    NUMDOC : # Numéro du document (clé)
#-----
Local    Decimal WCOURS
Local    Char    WDEVISE(GLONCUR)
Local    Integer WI
#-----
WDEVISE=func TRTX3BI.GETSYSCUR
Case ABREV
  When "PIH"
    If !clalev([F:PIH])  Local File =GDOSSIER+".PINVOICE"  [PIH] : Endif
    WI=find(WDEVISE,[F:PIH]CURLED)
    If WI
      WCOURS=arr([F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1),10^-6)
    Else
      WCOURS =0
    Endif
  When "SIH"
    If !clalev([F:SIH])  Local File =GDOSSIER+".SINVOICE"  [SIH] : Endif
    WI=find(WDEVISE,[F:SIH]CURLED)
    If WI
      WCOURS=arr([F:SIH]RATMLT(WI-1)/[F:SIH]RATDIV(WI-1),10^-6)
    Else
      WCOURS =0
    Endif
Endcase
#-----
End WCOURS


###########################################################
# GETADD Détermination des caractéristiques d'une adresse #
# Get address caracteristic                               #
###########################################################
Funprog GETADD(TYP,COD,ADR,FLDTYP)
Value    Integer  TYP    : # Type entité (1=Tiers, 2=Sté, 3=Site, 4=Utilisateur, 5=Compte)
Value    Char     COD    : # Code entité
Value    Char     ADR    : # Code adresse
Value    Integer  FLDTYP : # Type de champ à récupérer (1=Pays, 2=Code postal, 3=Ville)
#-----
Local    Char     VALEUR(50)
#-----
If !clalev([F:BPA])  Local File =GDOSSIER+".BPADDRESS" : Endif
#-----
If TYP<1    | TYP>5     TYP=1    : Endif
If FLDTYP<1 | FLDTYP>3  FLDTYP=1 : Endif
#-----
If [F:BPA]BPATYP<>TYP | [F:BPA]BPANUM<>COD | [F:BPA]BPAADD<>ADR
  Read [BPA] BPA0=TYP;COD;ADR : If fstat  Raz [F:BPA] : Endif
Endif
#-----
Case FLDTYP
  When 1 : VALEUR=[F:BPA]CRY
  When 2 : VALEUR=[F:BPA]POSCOD
  When 3 : VALEUR=[F:BPA]CTY
Endcase
#-----
End VALEUR


#######################################################################
# GETLASTLIN: Détermination du dernier numéro de ligne utilisé + 1000 #
# Get last line number + 1000                                         #
#######################################################################
Funprog GETLASTLIN(TABDOC,NUMDOC)
Value    Char     TABDOC  : # Nom de la table des lignes du document
Value    Char     NUMDOC  : # Numéro du document
#-----
Local    Integer  LASTLIN : # Dernier numéro de ligne utilisé
#-----
LASTLIN=0
Case TABDOC
  When "PREQUISD"
    #----- Dernière ligne demande d'achat -----#
    If !clalev([F:PSD])  Local File =GDOSSIER+".PREQUISD" [PSD] : Endif
    Filter [PSD] Where PSHNUM=NUMDOC
    Read [PSD] PSD0 Last
    If !fstat  LASTLIN=[F:PSD]PSDLIN : Endif
    Filter [PSD]
  When "PORDERQ"
    #----- Dernière ligne commande d'achat (qté) -----#
    If !clalev([F:POQ])  Local File =GDOSSIER+".PORDERQ" [POQ] : Endif
    Filter [POQ] Where POHNUM=NUMDOC
    Read [POQ] POQ0 Last
    If !fstat  LASTLIN=[F:POQ]POPLIN : Endif
    Filter [POQ]
  When "PORDERP"
    #----- Dernière ligne commande d'achat (prix) -----#
    If !clalev([F:POP])  Local File =GDOSSIER+".PORDERP" [POP] : Endif
    Filter [POP] Where POHNUM=NUMDOC
    Read [POP] POP0 Last
    If !fstat  LASTLIN=[F:POP]POPLIN : Endif
    Filter [POP]
  When "PORDERC"
    #----- Dernière ligne article commande ouverte d'achat -----#
    If !clalev([F:POC])  Local File =GDOSSIER+".PORDERC" [POC] : Endif
    Filter [POC] Where POHNUM=NUMDOC
    Read [POC] POC0 Last
    If !fstat  LASTLIN=[F:POC]POPLIN : Endif
    Filter [POC]
  When "PRECEIPTD"
    #----- Dernière ligne réception d'achat -----#
    If !clalev([F:PTD])  Local File =GDOSSIER+".PRECEIPTD" [PTD] : Endif
    Filter [PTD] Where PTHNUM=NUMDOC
    Read [PTD] PTD0 Last
    If !fstat  LASTLIN=[F:PTD]PTDLIN : Endif
    Filter [PTD]
  When "PRETURND"
    #----- Dernière ligne retour fournisseur  -----#
    If !clalev([F:PND])  Local File =GDOSSIER+".PRETURND" [PND] : Endif
    Filter [PND] Where PNHNUM=NUMDOC
    Read [PND] PND0 Last
    If !fstat  LASTLIN=[F:PND]PNDLIN : Endif
    Filter [PND]
  When "PINVOICED"
    #----- Dernière ligne facture d'achat -----#
    If !clalev([F:PID])  Local File =GDOSSIER+".PINVOICED" [PID] : Endif
    Filter [PID] Where NUM=NUMDOC
    Read [PID] PID0 Last
    If !fstat  LASTLIN=[F:PID]PIDLIN : Endif
    Filter [PID]
  When "SQUOTED"
    #----- Dernière ligne devis  -----#
    If !clalev([F:SQD])  Local File =GDOSSIER+".SQUOTED" [SQD] : Endif
    Filter [SQD] Where SQHNUM=NUMDOC
    Read [SQD] SQD0 Last
    If !fstat  LASTLIN=[F:SQD]SQDLIN : Endif
    Filter [SQD]
  When "SORDERQ"
    #----- Dernière ligne commande de vente (qté) -----#
    If !clalev([F:SOQ])  Local File =GDOSSIER+".SORDERQ" [SOQ] : Endif
    Filter [SOQ] Where SOHNUM=NUMDOC
    Read [SOQ] SOQ0 Last
    If !fstat  LASTLIN=[F:SOQ]SOPLIN : Endif
    Filter [SOQ]
  When "SORDERP"
    #----- Dernière ligne commande de vente (prix) -----#
    If !clalev([F:SOP])  Local File =GDOSSIER+".SORDERP" [SOP] : Endif
    Filter [SOP] Where SOHNUM=NUMDOC
    Read [SOP] SOP0 Last
    If !fstat  LASTLIN=[F:SOP]SOPLIN : Endif
    Filter [SOP]
  When "SORDERC"
    #----- Dernière ligne article commande ouverte d'achat -----#
    If !clalev([F:SOC])  Local File =GDOSSIER+".SORDERC" [SOC] : Endif
    Filter [SOC] Where SOHNUM=NUMDOC
    Read [SOC] SOC0 Last
    If !fstat  LASTLIN=[F:SOC]SOPLIN : Endif
    Filter [SOC]
  When "SDELIVERYD"
    #----- Dernière ligne de livraison -----#
    If !clalev([F:SDD])  Local File =GDOSSIER+".SDELIVERYD" [SDD] : Endif
    Filter [SDD] Where SDHNUM=NUMDOC
    Read [SDD] SDD0 Last
    If !fstat  LASTLIN=[F:SDD]SDDLIN : Endif
    Filter [SDD]
  When "SRETURND"
    #----- Dernière ligne de retour client -----#
    If !clalev([F:SRD])  Local File =GDOSSIER+".SRETURND" [SRD] : Endif
    Filter [SRD] Where SRHNUM=NUMDOC
    Read [SRD] SRD0 Last
    If !fstat  LASTLIN=[F:SRD]SRDLIN : Endif
    Filter [SRD]
  When "SINVOICED"
    #----- Dernière ligne facture de vente -----#
    If !clalev([F:SID])  Local File =GDOSSIER+".SINVOICED" [SID] : Endif
    Filter [SID] Where NUM=NUMDOC
    Read [SID] SID0 Last
    If !fstat  LASTLIN=[F:SID]SIDLIN : Endif
    Filter [SID]
Endcase
#-----
End LASTLIN+1000


##############################################################
# CNVQTYTCO Conversion d'une quantité en précisant l'arrondi #
# Quantity conversion                                        #
##############################################################
#Funprog CNVQTYTCO(QTEORI,UNIORI,UNIDES,RNDFLG,NBRDEC)
Funprog CNVQTYTCO(QTEORG,UNIORG,UNIDES,RNDFLG,NBRDEC)   # FGR 01/02/2010 : X3SUIVI60986
Value    Decimal QTEORG      : # Quantité à convertir
Value    Char    UNIORG      : # Unité d'origine
Value    Char    UNIDES      : # Unité destination
Value    Integer RNDFLG      : # Code arrondi (0=aucun, 1=selon unité, 2=selon NBRDEC)
Value    Integer NBRDEC      : # Nombre de décimales si RNDFLG=2
#-----
Local    Decimal QTEDES      : # Quantitée convertie et arrondie
Local    Decimal COEFFICIENT : # Coefficient de convesion
#-----
If !clalev([F:TCO])  Local File =GDOSSIER+".TABCOEFF" [TCO] : Endif
#-----
Read [TCO] TCO0=UNIORG;UNIDES
If !fstat
  COEFFICIENT=[F:TCO]COEUOM
Else
  Read [TCO] TCO0=UNIDES;UNIORG
  If fstat
    Raz [F:TCO] : COEFFICIENT=1
  Elsif [F:TCO]COEUOM=0
    COEFFICIENT=1
  Else
    COEFFICIENT=1/[F:TCO]COEUOM
  Endif
Endif
#-----
QTEDES=QTEORG*COEFFICIENT
#-----
If RNDFLG=1
  Call QTEARR(QTEDES,UNIDES) From TRTDIV
Elsif RNDFLG=2
  QTEDES=arr(QTEDES,10^-NBRDEC)
Endif
#-----
End QTEDES

###########################################################
# CNVQTY Conversion d'une quantité en précisant l'arrondi #
# Quantity conversion                                     #
###########################################################
Funprog CNVQTY(QTEORI,UNIORI,UNIDES,ITMREF,ABRFIC,NUMDOC,LINDOC,SEQDOC,RNDFLG,NBRDEC)
Value    Decimal QTEORI      : # Quantité à convertir
Value    Char    UNIORI      : # Unité d'origine
Value    Char    UNIDES      : # Unité destination
Value    Char    ITMREF      : # Référence article
Value    Char    ABRFIC      : # Abréviation du fichier
Value    Char    NUMDOC      : # No document
Value    Integer LINDOC      : # No ligne document
Value    Integer SEQDOC      : # No sous-ligne document (sequence)
Value    Integer RNDFLG      : # Code arrondi (0=aucun, 1=selon unité, 2=selon NBRDEC)
Value    Integer NBRDEC      : # Nombre de décimales si RNDFLG=2
#-----
Local    Decimal QTEDES      : # Quantitée convertie et arrondie
Local    Decimal COEFFICIENT : # Coefficient de convesion

#-----
# Sous-pro A compléter
# Pour l'instant, convertit une qté de l'US vers l'unité de statistique
#-----
If ITMREF<>""
  If !clalev([F:ITM])  Local File =GDOSSIER+".ITMMASTER" [ITM] : Endif
  #-----
  Read [ITM] ITM0=ITMREF
  If fstat Raz [F:ITM] : COEFFICIENT=1 : Endif
  If UNIORI=[F:ITM]STU & UNIDES=[F:ITM]SSU & [F:ITM]SSUSTUCOE <> 0
    COEFFICIENT=1/[F:ITM]SSUSTUCOE
  Else
    COEFFICIENT=1
  Endif
Else
  Case ABRFIC
    When  "SQD" Gosub MSK_SQD
    When  "SOQ" Gosub MSK_SOQ
    When  "SDD" Gosub MSK_SDD
    When  "SRD" Gosub MSK_SRD
    When  "SID" Gosub MSK_SID
    When  "POQ" Gosub MSK_POQ
    When  "PTD" Gosub MSK_PTD
    When  "PRD" Gosub MSK_PRD
    When  "PID" Gosub MSK_PID
  Endcase
  #If UNIORG=evalue("[F:"-ABRFIC-"]STU") & UNIDES=evalue("[F:"-ABRFIC-"]SAU")
  #  COEFFICIENT=1/evalue("[F:"-ABRFIC-"]SAUSTUCOE")
  #Endif
Endif
#-----
QTEDES=QTEORI*COEFFICIENT
#-----
If RNDFLG=1
  Call QTEARR(QTEDES,UNIDES) From TRTDIV
Elsif RNDFLG=2
  QTEDES=arr(QTEDES,10^-NBRDEC)
Endif
#-----
End QTEDES

#--- Pour un devis vente  ----------------------------------------------------------
$MSK_SQD
If clalev([F:SQD])=0 : Local File =GDOSSIER+".SQUOTED"    [SQD] : Endif
If [F:SQD]SQHNUM<>NUMDOC | [F:SQD]SQDLIN<>LINDOC
  Read [SQD] SQD0=NUMDOC;LINDOC : If fstat  Raz [F:SQD] : Endif
Endif
Return
#--- Pour une commande vente  ----------------------------------------------------------
$MSK_SOQ
Return
#--- Pour une livraison vente  ----------------------------------------------------------
$MSK_SDD
Return
#--- Pour un retour  vente  ----------------------------------------------------------
$MSK_SRD
Return
#--- Pour une facture vente  ----------------------------------------------------------
$MSK_SID
Return
#--- Pour une commande achat  ----------------------------------------------------------
$MSK_POQ
Return
#--- Pour une réception achat  ----------------------------------------------------------
$MSK_PTD
Return
#--- Pour un retour  achat  ----------------------------------------------------------
$MSK_PRD
Return
#--- Pour une facture achat  ----------------------------------------------------------
$MSK_PID
Return

##################################################
# CNVAMT Conversion d'un montant dans une devise #
# Amount conversion                              #
##################################################
Funprog CNVAMT(DEVORG,DEVDES,DEVSOC,RATMLT,RATDIV,TYPCOURS,DATCOURS,MTORG)
Value    Char    DEVORG    : # Devise d'origine
Value    Char    DEVDES    : # Devise destination
Value    Char    DEVSOC    : # Devise de la société
Value    Integer TYPCOURS  : # Type de cours (si cours = 0)
Value    Decimal RATMLT    : # Cours multiplicateur
Value    Decimal RATDIV    : # Cours diviseur
Value    Date    DATCOURS  : # Date du cours (si cours = 0)
Value    Decimal MTORG     : # Montant origine
#-----
Local    Decimal MTDES     : # Montant destination
Local    Integer STAT      : # Status de retour (0=OK)
Local    Decimal COURS     : # Cours calculé
#-----
If DEVORG=DEVDES or DEVDES="" or DEVORG=""
    MTDES=MTORG
Else
    Gosub PREP_CONVERSION
    If GBICHGTYP=1 & GBITYPCUR<>0 TYPCOURS=GBITYPCUR Endif
    COURS=0 : If RATDIV<>0 COURS=arr(RATMLT/RATDIV, 10^-GDECRCU) Endif
    Call COURMNT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,1,MTORG,MTDES,COURS,STAT) From TRTDEV
    If STAT  MTDES=MTORG : Endif
Endif
#-----
End MTDES

####################################################################################
# CNVCPYRPT Conversion d'un montant devise société vers devise dossier (reporting) #
# Amount conversion from company currency to reporting currency                    #
####################################################################################
Funprog CNVCPYRPT(SITE,DATCOURS,MTORG)
Value    Char    SITE       : # Site ou société
Value    Date    DATCOURS   : # Date du cours
Value    Decimal MTORG      : # Montant origine
#-----
Local    Char    DEVSOC(10) : # Devise société
Local    Char    DEVRPT(10) : # Devise dossier ou reporting
Local    Decimal MTDES      : # Montant destination
Local    Integer STAT       : # Status de retour (0=OK)
#-----
DEVSOC=func GETCUR(SITE)
DEVRPT=func GETSYSCUR
#-----
Gosub PREP_CONVERSION
Call CONVERT(DEVSOC,DEVSOC,DEVRPT,1,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
If STAT  MTDES=MTORG : Endif
#-----
End MTDES


#########################################################
# CNVAMTRPT : Conversion d'un montant en devise dossier #
# Amount conversion to reporting currency               #
#########################################################
Funprog CNVAMTRPT(SITE,DEVORG,DATCOURS,MTORG)
Value    Char    SITE       : # Site ou société
Value    Char    DEVORG     : # Devise d'origine
Value    Date    DATCOURS   : # Date du cours
Value    Decimal MTORG      : # Montant origine
#-----
Local    Char    DEVSOC(10) : # Devise société
Local    Char    DEVRPT(10) : # Devise dossier ou reporting
Local    Decimal MTDES      : # Montant destination
Local    Integer STAT       : # Status de retour (0=OK)
#-----
DEVSOC=func GETCUR(SITE)
DEVRPT=func GETSYSCUR
#-----
Gosub PREP_CONVERSION
Call CONVERT(DEVORG,DEVSOC,DEVRPT,1,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
If STAT  MTDES=MTORG : Endif
#-----
End MTDES


###############################################################
# CNVCPY Conversion d'un montant dans la devise de la société #
# Amount conversion to company currency                       #
###############################################################
Funprog CNVCPY(SITE,DEVORG,TYPCOURS,DATCOURS,MTORG)
Value    Char    SITE         : # Site
Value    Char    DEVORG       : # Devise d'origine
Value    Integer TYPCOURS     : # Type de cours
Value    Date    DATCOURS     : # Date du cours
Value    Decimal MTORG        : # Montant origine
#-----
Local    Char    DEVSOC(20)   : # Devise société (GLONCUR non significatif)
Local    Decimal MTDES        : # Montant destination
Local    Integer STAT         : # Status de retour (0=OK)
#-----
DEVSOC=func GETCUR(SITE)
Gosub PREP_CONVERSION
Call CONVERT(DEVORG,DEVSOC,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
If STAT  MTDES=MTORG : Endif
#-----
End MTDES


