#--------------------------------------------#
# Préparation du contexte pour la conversion #
#--------------------------------------------#
$PREP_CONVERSION
If !clalev([F:TCH])  Local File =GDOSSIER+".TABCHANGE" [TCH] : Endif
#-----
If dim([V]GEURO)<1
  Global Char    GEURO(30)
  Local  Char    WPARAM(30)
  Call PARAML("","EURO",WPARAM)    From ADOVAL
  If WPARAM<>""
    [V]GEURO=WPARAM
  Else
    [V]GEURO="EUR"
  Endif
Endif
#-----
If dim([V]GEURODEV)<1
  If !clalev([F:TCU])  Local File =GDOSSIER+".TABCUR"    [TCU] : Endif
  Global Decimal GEURODEV
  If [F:TCU]CUR<>GEURO
    Read [TCU] TCU0=GEURO : If fstat  Raz [F:TCU] : Endif
  Endif
  If [F:TCU]CURRND<>0
    [V]GEURODEV=[F:TCU]CURRND
  Else
    [V]GEURODEV=0.01
  Endif
Endif
#-----
If dim([V]GAROEURO)<1
  Global Decimal GAROEURO
  Call PARAML("","EURORND",WPARAM) From ADOVAL
  [V]GAROEURO=val(WPARAM)
Endif
#-----
Return

#############################################################################
# SETCOA : Recup. du plan de compte du type référentiel et de la société    #
#############################################################################
Funprog SETCOA(LEDTYP,CPY)
Value    Integer LEDTYP           : # Type de référentiel
Value    Char    CPY              : # Société
#-----
Local    Char    COA              : # Plan de compte
#-----
Local    Char    APPEL (25) : APPEL="SETCOA"
Local    Char    LED (10)
#-----
If LEDTYP=0 | LEDTYP >len(mess(0,2644,1))End Endif

If clalev([F:CPY])  = 0 Local File =GDOSSIER+".COMPANY" [CPY] Endif
If clalev([F:GCM])  = 0 Local File =GDOSSIER+".GACM"    [GCM] Endif
If clalev([F:LED])  = 0 Local File =GDOSSIER+".GLED"    [LED] Endif

# Lecture de la société pour récupérer le modèle comptable
Read [CPY] CPY0=CPY : If fstat  Raz [F:CPY] : Endif

# Lecture du modèle comptable pour récupérer le référentiel correspondant au type
Read [GCM] GCM0=[F:CPY]ACM : If fstat  Raz [F:GCM] : Endif
LED=evalue("[F:GCM]LED"+"("+num$(LEDTYP-1)+")")

# Lecture du référentiel pour récupérer le plan de compte
Read [LED] LED0=LED : If fstat  Raz [F:LED] : Endif
COA=[F:LED]COA

End COA


##################################################################################
# SETACC : Recup. du compte correspondant au type de référenciel et à la société #
#          Le compte est récupéré de la table CPTANALIN qui doit être en ligne   #
##################################################################################
Funprog SETACC(LEDTYP,CPY)
Value    Integer LEDTYP           : # Type de référentiel
Value    Char    CPY              : # Société

Local    Char    APPEL (25) : APPEL="SETCOA"
Local    Char    LED (10), ACC(20)
Local    Integer J
#-----
If LEDTYP=0 | LEDTYP >len(mess(0,2644,1))End Endif

If clalev([F:CPY])  = 0 Local File =GDOSSIER+".COMPANY"  [CPY] Endif
If clalev([F:GCM])  = 0 Local File =GDOSSIER+".GACM"     [GCM] Endif
If clalev([F:LED])  = 0 Local File =GDOSSIER+".GLED"     [LED] Endif
If clalev([F:GAC])  = 0 Local File =GDOSSIER+".GACCOUNT" [GAC] Endif

# Lecture de la société pour récupérer le modèle comptable
Read [CPY] CPY0=CPY : If fstat  Raz [F:CPY] : Endif

# Lecture du modèle comptable pour récupérer le référentiel correspondant au type
Read [GCM] GCM0=[F:CPY]ACM : If fstat  Raz [F:GCM] : Endif
LED=evalue("[F:GCM]LED"+"("+num$(LEDTYP-1)+")")

# Récupération du compte correspond au référentiel
J=find(LED, [CAL]LED(0..dim([CAL]LED)-1))
If J
    # Vérification que compte existe bien pour le plan de compte
    Read [GAC] GAC0=[CAL]COA(J-1);[CAL]ACC(J-1)
    If !fstat  ACC=[CAL]ACC(J-1) : Endif
Endif

End ACC
########################################################################################
# GETCOA : Immo : Recup. du plan de compte du plan d'amortissement passé en paramètre  #
########################################################################################
Funprog GETCOA(CPY, CNX, PLN)

Value    Char    CPY           : # Société
Value    Integer CNX           : # Contexte d'amortissement
Value    Integer PLN           : # Plan d'amortissement

#-----
Local    Char    COA              : # Plan de compte
#-----
Local    Char    APPEL (25) : APPEL="GETCOA"
Local    Char    LED (10)
Local Integer    I_PLN
#-----

If clalev([F:CPY])  = 0 Local File =GDOSSIER+".COMPANY"     [CPY] Endif
If clalev([F:CNX])  = 0 Local File =GDOSSIER+".CONTEXT"    [CNX] Endif
If clalev([F:LED])  = 0 Local File =GDOSSIER+".GLED"        [LED] Endif

# Lecture de la société pour récupérer le modèle comptable
Read [CPY] CPY0=CPY : If fstat  Raz [F:CPY] : Endif

Read [CNX]CNX0=CPY;CNX : If fstat  Raz [F:CNX] : Endif
  I_PLN= find (PLN, [F:CNX]PLNCAA(0..[F:CNX]NBPLC-1) )
  If I_PLN > 0
    COA=[F:CNX]COA(I_PLN-1)
  Endif

End COA
