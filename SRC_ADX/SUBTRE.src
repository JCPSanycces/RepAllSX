#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################
# SUBTRE                                                   Mars  2012  #
#    TYPES DE RETOURS VENTES                                           #
########################################################################

$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "AFFMASK"       : Gosub AFFMASK
 When "RAZCRE"        : Gosub RAZCRE
 When "RAZDUP"        : Gosub RAZDUP
 When "INICRE"        : Gosub INICRE
 When "INIMOD"        : Gosub INICRE
 When "ANNULE"        : Gosub ANNULE
 When "AP_CHANGE"     : Gosub AP_CHANGE
 When "LIENS"         : Gosub LIENS
 When "FERME"         : Gosub FERME
 When "SEL_TABLE"
   Case TABLE
     When "SELTRE"    : Gosub SELTRE
   Endcase
 When "CHGCOD"        : Gosub CHGCOD
 When "SETBOUT" 			: Gosub SETBOUT
 When "VERIF_CRE"     : Gosub VERIF
 When "VERIF_MOD"     : Gosub VERIF
 When Default
Endcase

Return
######################################################################################
$OUVRE
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB

#--Lors d'un tunnel depuis un document (exemple : livraison)
Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes

#BRBAN 08/10/2014 - Document types control
If !clalev([F:TRE3]) : Local File TABSRHTYP [TRE3] : Endif
#-

Return
######################################################################################
$VERIF
#BRBAN 08/10/2014 - Document types control
Case [M:TRE1]LEG
  When ""
    Read [F:TRE3]TRE0=[M:TRE1]SRHTYP;"POR"
    If !fstat
      If [M:TRE1]RECTYP <> [F:TRE3]RECTYP
        Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TRE3]SRHTYP,[F:TRE3]LEG),2) From GESECRAN
        OK = 0 : Return
      Endif
      If [M:TRE1]SAFTTRNTYP <> [F:TRE3]SAFTTRNTYP
        Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TRE3]SRHTYP,[F:TRE3]LEG),2) From GESECRAN
        OK = 0 : Return
      Endif
    Endif
  When "POR"
    Read [F:TRE3]TRE0=[M:TRE1]SRHTYP;""
    If !fstat
      If [M:TRE1]RECTYP <> [F:TRE3]RECTYP
        Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TRE3]SRHTYP,mess(59,151,1)),2) From GESECRAN
        OK = 0 : Return
      Endif
      If [M:TRE1]SAFTTRNTYP <> [F:TRE3]SAFTTRNTYP
        Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TRE3]SRHTYP,mess(59,151,1)),2) From GESECRAN
        OK = 0 : Return
      Endif
    Endif
Endcase
#-
Return
######################################################################
$INICRE

Gosub MAJ_ATEXTRA

Return

$MAJ_ATEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("TABSRHTYP","DESAXX",CLECUR1,"","TABSRHTYP","SHOAXX",[F:TRE]SRHTYP,[F:TRE]LEG)  From ATEXTRA
 Call DUPTEXTRA("TABSRHTYP","SHOAXX",CLECUR1,"","TABSRHTYP","SHOAXX",[F:TRE]SRHTYP,[F:TRE]LEG)  From ATEXTRA
Endif
#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:TRE1]DESAXX,"TABSRHTYP","DESAXX",[M:TRE1]SRHTYP,[M:TRE1]LEG) From ATEXTRA
Call MAJTEXTRA ([M:TRE1]SHOAXX,"TABSRHTYP","SHOAXX",[M:TRE1]SRHTYP,[M:TRE1]LEG) From ATEXTRA

#    SOS libellés
If dim([F:TRE]LANDESSHO)>0
   [F:TRE]LANDESSHO=GLANGUE+"~"+[M:TRE1]DESAXX+"~"+[M:TRE1]SHOAXX
Endif

Return
######################################################################
$AFFMASK
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG

Return

$CHGCOD
  #-- X3Suivi 71937
  Call CHGCOD(ABREV, CLECUR1, CLECUR2, OK) From CHGCLELEG
Return

######################################################################
$RAZCRE
Gosub GRILEG

#RMA * 85785
If func AFNC.ACTIV("KPO")
  Call SHOW_HIDE_TRE([M:TRE1]LEG) From PORLEGLIB
Endif

Return
######################################################################
$RAZDUP

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TRE([M:TRE1]LEG) From PORLEGLIB
Endif

Return
######################################################################
$LIENS

GCURLEG = [F:TRE]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
GGRPFCY = [F:TRE]GFY
#--Le champ "Compteur définitf" est visible si code activité DKS actif et LEG="POR"
Call SHOWHIDE_COUNT_DEF([F:TRE]LEG)
Call SHOWHIDE_COUNT_SRHCAT([F:TRE]SRHCAT) # FGR 27/05/2013

#RMA * 85785
If func AFNC.ACTIV("KPO")
  Call SHOW_HIDE_TRE([M:TRE1]LEG) From PORLEGLIB
Endif

# Issue X3-143 - 2016-10-03 by RICAR : 107966 - Change the field actions on RECTYP, SAFTTRNTYP and COMAT
# Issue X3-143
If func AFNC.ACTIV("KPO") > 0
  Gosub DISABLE_TRE_FIELDS From PORLEGLIB
Endif
# End issue X3-143

Return
######################################################################
$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [M:TRE1]LEG
  [M:TRE1]LEG=GDOSLEG(1)
  Affzo [M:TRE1]LEG : If dim([M:TRE1]ZLEG)>0  Affzo [TRE1]ZLEG : Endif
Endif

Return
######################################################################
$ANNULE
Delete [AXX] Where CODFIC="TABSRHTYP" & IDENT1=[F:TRE]SRHTYP & IDENT2=[F:TRE]LEG

Return
######################################################################
$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONTRE) : Endif

VCOD = CLE2

Return
#########################################################################
$AP_CHANGE
Call CHGTEXTRA("TABSRHTYP","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("TABSRHTYP","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA

Return

######################################################################################
