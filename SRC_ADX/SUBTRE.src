Gosub CTL_CODNUM

End
######################################################################################
# Contrôle de la longueur du compteur
######################################################################################
$CTL_CODNUM
If [F:ANM]CODNUM <> VALEUR
   Read [ANM]ANM0 = VALEUR
   If fstat Raz [F:ANM] Endif
Endif

# Contrôle de la cohérence de la législation entre le type de livraison et le compteur
## SAM 121563 JUCON 20/02/2017) wrong control by legislation
#If [F:ANM]LEG<>"" & [F:ANM]LEG<>[M:TRE1]LEG
#    GMESSAGE=mess(184,100,1)-VALEUR-mess(74,127,1)-"("
#    If [M:TRE1]LEG<>""
#      GMESSAGE+=[F:ANM]LEG-"<>"-[M:TRE1]LEG+")"
#    Else
#      GMESSAGE+=[F:ANM]LEG-"<>"-mess(91,187,1)+")"
#    Endif
#    mkstat=1 : End
#Endif
If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > GLONVCR
   GERR=1
   GMESSAGE = mess(223,199,1)
   mkstat = 1
Endif

Return
###############################################################################
##  Copie
###############################################################################
$TRTCOP

If [M]DOSORG=nomap
 Local File TABSRHTYP [TRE1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[M]DOSORG+".TABSRHTYP" [TRE1]
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
 Local File TABSRHTYP [TRE2]
 Local File ATEXTRA   [AXX2]
 Local File ACTIV     [ACV2]
Else
 Local File =[M]DOSDES+".TABSRHTYP" [TRE2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
 Local File =[M]DOSDES+".ATABDIV"   [ADI2]
 Local File =[M]DOSDES+".ACTIV"     [ACV2]
 Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
Endif
Gosub OUVDOS From ATEXTRA
# Multi-Lég... Vérifier que la législation existe dans le dossier destination
# Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
#If TABLE2<>"" & clalev([F:ADS2])>0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
# Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #:--CPO 71937 -- Législation non gérée par ce dossier --#
#   Return
#Endif

Call DEBTRANS From GLOCK
Gosub TR_COP

Close Local File [TRE1], [TRE2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return

$TR_COP
#--------------------------------------------------#
# Transaction de copie d'un type de retour         #
#--------------------------------------------------#
Local Char    LEGDES
Local Integer WMONOLEGDES
# Par défaut : Leg destination=leg de l'enregistrement à copier
LEGDES=TABLE2
GOK = 1
#--Quelques vérifications...
#If TABLE2<>''
# If [M]DOSDES<>nomap
#  Local Char SZDOSSIER(GLONADS)
#  Local Integer LG
#  Read [ADI2]CODE=909; TABLE2
#  If fstat
#   Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
#   Return
#  Endif
# Endif
#Endif

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Pb lecture dossier
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Pas de législation pour le dossier
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
            Return
        Endif
        If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
            Return
        Elsif TABLE2=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE2<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE2
          If fstat
           Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

Read [TRE2]TRE0=TABLE ;LEGDES
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

Trbegin [TRE2]
 Delete [TRE2] Where SRHTYP=TABLE & LEG=LEGDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABSRHTYP"-TABLE : Goto ROLL_TR_COP
 Elsif fstat
  GOK = 0 : Call RSTA("TRE2",TABLE) From GLOCK : Goto AB_TR_COP
 Endif
 If !fstat
   #--- copie des données
   For [TRE1]TRE0 Where SRHTYP=TABLE & LEG = TABLE2
      [F:TRE2] = [F:TRE1]
      [F:TRE2]LEG = LEGDES
      If TABLE2=LEGDES
          Call COPTEXTRA("TABSRHTYP","DESAXX",TABLE,TABLE2) From ATEXTRA
          Call COPTEXTRA("TABSRHTYP","SHOAXX",TABLE,TABLE2) From ATEXTRA
      Else
          Call COPTEXTRA1("TABSRHTYP","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
          Call COPTEXTRA1("TABSRHTYP","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
      Endif
      If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
      If dim([F:TRE2]UPDUSR)>0 : [F:TRE2]UPDUSR = GUSER : Endif
      If dim([F:TRE2]UPDDAT)>0 : [F:TRE2]UPDDAT = date$ : Endif
      Write [TRE2]
      If fstat
       GOK = 0 : Call FSTA("TRE2") From GLOCK : Break
      Endif
     Next
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit

Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

Return
#-----------------------------------------------------------------------------
Subprog CONTTRE(COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,PSRHCAT,CPY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Integer PSRHCAT
Value    Char    CPY


Local    Integer CAS
Local    Char    OPTIONS(30)

If GFONCTION = "GESTRE" | COD="" : End : Endif

If clalev([F:TRE]) =0 : Local File TABSRHTYP [TRE] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--for the selection options of the object

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : #--GCURLEG online
 LEG = GCURLEG
Endif

CAS = 1 : #--Legislation is empty

#--CPO 71937
#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif :#--CPO 71937
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif :#--CPO 71937
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
	If [L]FCY<>""
		If [F:FCY]FCY<>[L]FCY
			Read [F:FCY]FCY0=[L]FCY
			If fstat : Raz [F:FCY] Endif
		Endif
		If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
	Endif
	If [L]CPY<>""
		If [F:CPY]CPY<>[L]CPY
			Read [F:CPY]CPY0=[L]CPY
			If fstat : Raz [F:CPY] Endif
		Endif
		[L]LEG=[F:CPY]LEG
	Endif
Endif
#--/CPO

If LEG<>""
 Read [TRE]TRE0=[L]COD;[L]LEG
 If fstat
  Read [TRE]TRE0=[L]COD;""
 Else
  CAS = 2 : #--Legislation isn't empty
 Endif
Else
 Read [TRE]TRE0(1)=[L]COD
 If !fstat
  LEG = [F:TRE]LEG
  CAS = 2
 Endif
Endif
If fstat
 Filter [TRE] Where SRHTYP=[L]COD
 Look [TRE]TRE0 First
 If !fstat
  # "Fiche inexistante pour la législation courante"
  # "No existing record for the curent legislation"
  GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # "Fiche inexistante"
  # "Record does not exist"
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [TRE]
 mkstat = 2 : End
Endif

#--Contrôle par catégorie
If PSRHCAT<4 and PSRHCAT<>[F:TRE]SRHCAT
  GMESSAGE = [L]COD-":"-mess(249,191,1)- mess(PSRHCAT,493,1)  # FGR 03/03/2015 : X3SUIVI106635 ajout de '[L]COD-":"'
  mkstat = 2 : End
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GFY de TABSRHTYP, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TRE]GFY<>""
  	#--CPO 71937
  	If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
		Read [AGF]AGF0=[F:TRE]GFY
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TRE]GFY<>[L]CPY
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TRE]GFY : # Réservé au groupe de société
          mkstat = 2 : End
				Endif
  		Elsif [F:AGF]FLGCPY=2
  	#--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TRE]GFY;[L]CPY
        If fstat
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TRE]GFY : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TRE]GFY<>"" and LEG<>""
	Call CTLGFYLEG([F:TRE]GFY,LEG,"","") From TRTVENCTL
	If mkstat : End : Endif
Endif
#--Contrôle de cohérence entre le groupe passé en paramètre et la législation du type de livraison à contrôler
If GROUPE<>"" and [F:TRE]LEG<>""
	Call CTLGFYLEG(GROUPE,[F:TRE]LEG,"","") From TRTVENCTL
	If mkstat : End : Endif
Endif
#--Contrôle de la cohérence entre le groupe passé en param et celui du type de livraison courant
#--uniquement si le groupe passé est renseigné
#--uniquement si pas de contexte site ou société !
#--Il faut que le groupe de la taxes et celui du paramétrage aient au moins une soc en commun
If GROUPE<>""
	If CPY="" & FCY="" & [F:TRE]GFY<>"" & [F:TRE]GFY<>GROUPE
  	#--Les groupes doivent avoir au moins une société en commun
  	Gosub CTLGFYGRP
		If mkstat : End : Endif
	Endif
Endif

#--On charge les options définies sur le type de données du champ du masque
#--Findig Object options defined on the data type of the field in the screen
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=[L]CODMSK;[L]CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
 Call CONTROLE("TRE",OPTIONS,LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("TRE",OPTIONS,"",COD,mkstat) From CONTOBJ
Endif

End
##################################################################################
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TRE]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTREZGRP"
    Local File =SZVIEW [TREZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TREZ]TREZ0 = [L]GROUPE;[F:TRE]SRHTYP;[F:TRE]GFY;[F:TRE]LEG
  If fstat
  	GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TRE]GFY-":"-mess(178,187,1)
  	mkstat=1
  	Return
  Endif
Else
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTREYGRP"
    Local File =SZVIEW [TREY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TREY]TREZ0 = [L]GROUPE;[F:TRE]SRHTYP;[F:TRE]GFY;[F:TRE]LEG
  If fstat
  	GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TRE]GFY-":"-mess(178,187,1)
  	mkstat=1
  	Return
  Endif
Endif
Return
##################################################################################
#--------------------------------------------------------------------------------
#Called from Action "TUNTRE"
#IMPORTANT : in order to pass here, one must set to "No"
#            the value in the Tunnel column for this field in the screen definition
#            il faut mettre à "Non" le tunnel dans la définition de l'écran pour ce champ
#--------------------------------------------------------------------------------
Subprog TUNTRE(COD,LEG)
Variable Char    COD()
Value    Char    LEG()

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
  Global Char VCOD(GLONTRE)
  TOKILL = 1
Endif

If clalev([F:TRE])=0 : Local File TABSRHTYP [TRE] : Endif

VCOD = COD

If GNBLEG=1
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
  LEG = GCURLEG
#--If LEG="" then firstly we search a TRE record with LEG="" secondly a TRE record with TRE<>""
Elsif LEG=""
  Read [TRE]TRE0 = VCOD;[L]LEG
  If fstat
    Read [TRE]TRE0(1)=VCOD
    If !fstat
      LEG = [F:TRE]LEG
    Endif
  Endif
Endif

Read [TRE]TRE0 = [L]COD;[L]LEG
If fstat : LEG = "" : Endif

Call OBJET("TRE",[L]LEG,VCOD) From GOBJET

COD = VCOD
If TOKILL : Kill VCOD : Endif

End
#-----------------------------------------------------------------------------
#Called from ADPVAL Fonction, for control purpose
#-----------------------------------------------------------------------------
Subprog VERF_PARAM(PPARAM,PVALEUR,POK)
Value Char PPARAM       # Parameter which value is controled
Value Char PVALEUR      # Parameter value to control
Variable Integer POK    # 1 if OK, 0 if NOK

If PVALEUR="" End Endif

If clalev([F:TRE])=0 : Local File TABSRHTYP [TRE] : Endif

Local Char    FCY(GLONFCY),SAVE_GCURFCY( GLONFCY)
Local Char    CPY(GLONCPY),SAVE_GSOCIETE(GLONCPY)
Local Char    LEG(GLONADI)
Local Integer CAT
Local Integer WNOL
Local Integer ERR

[L]SAVE_GCURFCY = GCURFCY
[L]SAVE_GSOCIETE= GSOCIETE

If GFONCTION="ADPVAL"   :#--"Parameter values". Data type = ???
  FCY  = [M:ADWP]FCY : GCURFCY = FCY
  CPY  = [M:ADWP]CMP : GSOCIETE= CPY
 If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Else
    LEG = GDOSLEG
  Endif
  #--Sales Return categories from parameter's name
  WNOL = nolign-1
  CAT  = 4
  If WNOL>=0
    Case [M:ADWP]PARAM(WNOL)
      When "SRHTYPNOR" : CAT=1
      When "SRHTYPLND" : CAT=2
      When "SRHTYPSCO" : CAT=3
      When Default     : CAT=4   :#--All categories
    Endcase
  Endif
  #--Init. of legislation
  If [L]LEG=""
    If [L]FCY<>""
      Call LEC_FCY([L]FCY) From CPTLEC
      Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
      GSOCIETE = [F:FCY]LEGCPY
      [L]LEG = [F:CPY]LEG
    Elsif [L]CPY<>""
      Call LEC_CPY([L]CPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Endif
  Endif
  If [L]LEG=""
    [L]LEG = GCURLEG
  Endif
  #--Reading
  Local Integer WERR
  Call LEC_TRE_LEG(LEG,PVALEUR,WERR) From TRTLECLEG
  If WERR : Call RSTA("TRE", PVALEUR) From GLOCK : mkstat = 2 : Goto $END_VERF : Endif
  #--Control by sales return category
  If CAT<4 and CAT<>[F:TRE]SRHCAT
    GMESSAGE = [L]COD-":"-mess(249,191,1)- mess(CAT,490,1)  # FGR 03/03/2015 : X3SUIVI106635 ajout de '[L]COD-":"'
    mkstat = 2 : Goto $END_VERF
  Endif
  #--Filter by group of companies
  #--When we only have the CPY online (for exp. parameters at company level)
  #--Due to the data type AGF of th GFY field in the TABSRHTYP table,
  #--the CONTROL from CONTOBJ does only a factory group filtering (according to the GCURFCY value)
  If [L]CPY<>""
    Local Integer WERR
    Call LEC_TRE_LEG(LEG,PVALEUR,WERR) From TRTLECLEG
    If WERR : Call RSTA("TRE", PVALEUR) From GLOCK : mkstat = 2 : Goto $END_VERF : Endif
    If [F:TRE]GFY<>""
      If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
      Look [AGC]AGC0 = [F:TRE]GFY;[L]CPY
      If fstat
        GMESSAGE += PVALEUR+"\"+mess(63,127,1)-":"-[F:TRE]GFY : #--Only for the company group XXX
        mkstat = 2 : Goto $END_VERF
      Endif
    Endif
  Endif
  #--
  Call CONTTRE(PVALEUR,LEG,"","")
  If mkstat : POK=0 : Endif
Endif

$END_VERF
GCURFCY = [L]SAVE_GCURFCY
GSOCIETE= [L]SAVE_GSOCIETE

End
#--------------------------------------------------------------------------------
#--Called from ADPVAL fonction "Parameter values"
#--Also called from the SELTRE selection action (Throughout the SELTREA subprog)
#--------------------------------------------------------------------------------
$SELTRE
If clalev([F:TRE])=0  : Local File TABSRHTYP  [TRE] : Endif

If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection
If clalev([F:AGF])=0  : Local File AGRPFCY 	  [AGF] : Endif :#--CPO 71937

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)
Local Char    GRP(GLONAGF)
Local Integer CAT
Local Integer WNOL
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

#--CPO 71937 Pour déterminer les options de sélection
If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif
Local Char CODMSK   (GLONAMK)
Local Char CHAMPCOD (GLONAVA)
CODMSK  =PARAM(6)
CHAMPCOD=PARAM(7)

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=[L]CODMSK;[L]CHAMPCOD
  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
Endif

#--/CPO
#--------------------------------------------------------------------------------------------------
If GFONCTION = "GESTRE" Then
  # Si on est sur l'objet de paramétrage, pas de filtre on part sur la sélection standard
  OBJET = "TRE"
  Return
Endif

#--------------------------------------------------------------------------------------------------
# Identifying the parameters
#--------------------------------------------------------------------------------------------------
If GFONCTION="ADPVAL"     :#--"Parameter values". Data type = ???
  FCY  = [M:ADWP]FCY
  CPY  = [M:ADWP]CMP
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Endif

  #--Sales Return categories from parameter's name
  WNOL = nolign-1
  CAT  = 4
  If WNOL>=0
    Case [M:ADWP]PARAM(WNOL)
      When "SRHTYPNOR" : CAT=1
      When "SRHTYPLND" : CAT=2
      When "SRHTYPSCO" : CAT=3
      When Default     : CAT=4   :#--All categories
    Endcase
  Endif
Else
  LEG  = PARAM(1)
  FCY  = PARAM(2)
  GRP  = PARAM(3)
  CAT  = val(PARAM(4))
  CPY  = PARAM(5)
Endif

#--Init. of legislation
If func AFNC.ACTIV("LEG")=0
 [L]LEG = GDOSLEG
Endif

If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

If [L]LEG=""
 [L]LEG = GCURLEG
Endif
#--------------------------------------------------------------------------------------------------
## Position and dimension of the window
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOTRE
For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I)  = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I
NBCOL   = NBSEL
SIZCOL  = 240
SIZLIG  = 100
TIT(0)  = mess(12,123,1)
Call TITOBJ("TRE","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START   = "[F:TRE]SRHTYP"
ORDRE   = "[F:TRE]SRHTYP;[F:TRE]LEG"
OBJET   = ""

#--------------------------------------------------------------------------------------------------
## Standard selection criteria
#--------------------------------------------------------------------------------------------------

CRITERE(1) = '1=1'
#--Groupe de soc/sites
If [L]FCY="" & [L]CPY="" & [L]GRP<>""
	#--Cas du groupe étant une société
 	Read [F:AGF]AGF0=[L]GRP
 	If !fstat
 		If [F:AGF]FLGLEG=2 : [L]CPY=[L]GRP : Endif
 	Endif
 	#--Le filtrage sur les groupes sites/sociétés sont fait dans le link directement
Endif
#--Facility
If    [L]FCY<>""
  CRITERE(1) -= '& ([F:TRE]GFY="" | ([F:TRE]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
#--Company
Elsif [L]CPY<>""
  CRITERE(1) -= '& ([F:TRE]GFY="" | ([F:TRE]GFY<>"" & [F:TREC]LEGCPY="'+[L]CPY+'"))'
Endif
#--Legislation
If [L]LEG<>""
  CRITERE(2) -= '& ([F:TRE]LEG="'+[L]LEG+'" | [F:TRE]LEG="")'
Endif
#--Sales return category
If CAT>0 and CAT<4
  CRITERE(2) -= '& ([F:TRE]SRHCAT='+num$(CAT)+')'
Endif
#--First selection character
If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(2) -= '& left$([F:TRE]SRHTYP,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 3

# MGG X3-38593 Row level permission
#Call FILROLE(OBJET,FILROLE) From SUBARL
Call FILROLE("TRE",FILROLE) From SUBARL
#END MGG X3-38593 Row level permission

If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
#--Views calls
#--------------------------------------------------------------------------------------------------
If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
	If [L]LEG<>""
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTREYGRP"
      Local File =SZVIEW [TREY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TRE"
      Return
    Endif
	Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTREZGRP"
      Local File =SZVIEW [TREZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TRE"
      Return
    Endif
	Endif
Endif
ERR = 0
Repeat
  # -----------------------------------------------------------------------------------------------
  # ERR=0  : Pas d'erreur, on sort
  # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
  # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
  # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
  # -----------------------------------------------------------------------------------------------
  Onerrgo ERRVUE
  SZVIEW = "LEGTRECPY"
  Local File =SZVIEW [TREC]
  Onerrgo
Until ERR <> -1
If ERR Then
  # Si problème, on se déroute sur le select standard
  OBJET = "TRE"
  Return
Endif

If [L]LEG<>""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTRESEL"
    Local File =SZVIEW [TRES]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, on se déroute sur le select standard
    OBJET = "TRE"
    Return
  Endif
  If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
  	Link [TRE] With [F:AXX]AXX0    = "TABSRHTYP";"DESAXX";GLANGUE;[F:TRE]SRHTYP;[F:TRE]LEG,
&                		[F:TREY]TREZ0 ~= [L]GRP;[F:TRE]SRHTYP;[F:TRE]GFY;[F:TRE]LEG,
&              			[F:TRES]TRE0  ~= [F:TRE]SRHTYP;[F:TRE]LEG;[L]LEG
&            		 As [LTRE]
	Else
 		Link [TRE] With [F:AXX]AXX0    = "TABSRHTYP";"DESAXX";GLANGUE;[F:TRE]SRHTYP;[F:TRE]LEG,
&               		[F:FGR]FGR1    = [L]FCY;[F:TRE]GFY,
&		                [F:TREC]TRE0   = [F:TRE]SRHTYP;[F:TRE]LEG;[F:TRE]GFY;[L]CPY,
&   	              [F:TRES]TRE0  ~= [F:TRE]SRHTYP;[F:TRE]LEG;[L]LEG
&   						 As [LTRE]
	Endif
Else
 #--View without legislation
 ERR = 0
 Repeat
   # -----------------------------------------------------------------------------------------------
   # ERR=0  : Pas d'erreur, on sort
   # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
   # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
   # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
   # -----------------------------------------------------------------------------------------------
   Onerrgo ERRVUE
   SZVIEW = "LEGTREPAR"
   Local File =SZVIEW [TREP]
   Onerrgo
 Until ERR <> -1
 If ERR Then
   # Si problème, on se déroute sur le select standard
   OBJET = "TRE"
   Return
 Endif
  If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
  	Link [TRE] With [F:AXX]AXX0    = "TABSRHTYP";"DESAXX";GLANGUE;[F:TRE]SRHTYP;[F:TRE]LEG,
&                		[F:TREY]TREZ0 ~= [L]GRP;[F:TRE]SRHTYP;[F:TRE]GFY;[F:TRE]LEG
&            		 As [LTRE]
	Else
 		Link [TRE] With [F:AXX]AXX0    = "TABSRHTYP";"DESAXX";GLANGUE;[F:TRE]SRHTYP;[F:TRE]LEG,
&                		[F:FGR]FGR1    = [L]FCY;[F:TRE]GFY,
&                		[F:TREC]TRE0   = [F:TRE]SRHTYP;[F:TRE]LEG;[F:TRE]GFY;[L]CPY,
&                		[F:TREP]TRE0  ~= [F:TRE]SRHTYP;[F:TRE]LEG
&   						 As [LTRE]
	Endif
Endif

# Options de sélection
If OPTIONS<>""
  Gosub OPTIONS From WOTRE
  ICRITERE=2
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
Endif

Default File [LTRE]
DEFPAG = 1

Return

$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume
#--------------------------------------------------------------------------------
#--Call from SELTRE Action
#--------------------------------------------------------------------------------
Subprog SELTREA(SRHTYP,LEG,FCY,GROUPE,PSRHCAT,CPY)
Variable Char    SRHTYP()
Value    Char    LEG
Value    Char    FCY
Value    Char    GROUPE
Value    Integer PSRHCAT
Value    Char    CPY
Local Char PARMSK(30)(1..10)
PARMSK(1)=[L]LEG
PARMSK(2)=[L]FCY
PARMSK(3)=[L]GROUPE
PARMSK(4)=num$([L]PSRHCAT)
PARMSK(5)=[L]CPY

If clalev([F:TRE])=0 : Local File TABSRHTYP [TRE] : Endif
Call S_TAB_CHAR(SRHTYP,PARMSK,"SELTRE","SUBTRE","") From GACTION

End
#################################################################################
######################################################################
$SETBOUT
If CLECUR=0 | GREP<>""
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

Return
