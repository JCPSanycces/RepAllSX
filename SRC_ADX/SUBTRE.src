    Local Char WMESS(100) : WMESS = ""
    If find(VALEUR,[M:TRE1]CODNUMEND,[M:TRE1]CODNUMFCYD,[M:TRE1]CODNUMCPYD) : GMESSAGE = mess(142,7711,1) : mkstat = 2 : End : Endif
    Call CTL_CODNUM_NORMAL(VALEUR,[M:TRE1]LEG,[M:TRE1]SRHTYP,"TRE",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
Endif
