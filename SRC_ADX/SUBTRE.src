#########################################################################
Subprog SHOWHIDE_COUNT_SRHCAT(ISRHCAT)
Value Integer ISRHCAT

  # FGR 15/04/2013 : Mail Cyrille 03/05/2013 (DKS US 428) : disponible pour tout le monde
  # Les champs inter-site et inter-société ne sont pas disponibles pour la catégorie "Prêt"
  If ISRHCAT = 2 Then
    # Prêt
    Chgfmt [M:TRE1]CODNUMFCY With "-K:"+num$(GLONANM)+"B"
    If dim([M:TRE1]ZCODNUMFCY)>0
      Chgfmt [M:TRE1]ZCODNUMFCY With "-K:"+num$(type([M:TRE1]ZCODNUMFCY)-10)+"X"
    Endif
    If func AFNC.ACTIV("DKS") Then
      Chgfmt [M:TRE1]CODNUMFCYD With "-K:"+num$(GLONANM)+"B"
      If dim([M:TRE1]ZCODNUMFCYD)>0
        Chgfmt [M:TRE1]ZCODNUMFCYD With "-K:"+num$(type([M:TRE1]ZCODNUMFCYD)-10)+"X"
      Endif
    Endif
    #
    Chgfmt [M:TRE1]CODNUMCPY With "-K:"+num$(GLONANM)+"B"
    If dim([M:TRE1]ZCODNUMCPY)>0
      Chgfmt [M:TRE1]ZCODNUMCPY With "-K:"+num$(type([M:TRE1]ZCODNUMCPY)-10)+"X"
    Endif
    If func AFNC.ACTIV("DKS") Then
      Chgfmt [M:TRE1]CODNUMCPYD With "-K:"+num$(GLONANM)+"B"
      If dim([M:TRE1]ZCODNUMCPYD)>0
        Chgfmt [M:TRE1]ZCODNUMCPYD With "-K:"+num$(type([M:TRE1]ZCODNUMCPYD)-10)+"X"
      Endif
    Endif
  Else
    # Les autres
    Chgfmt [M:TRE1]CODNUMFCY With "K:"+num$(GLONANM)+"B"
    If dim([M:TRE1]ZCODNUMFCY)>0
      Chgfmt [M:TRE1]ZCODNUMFCY With "KP:"+num$(type([M:TRE1]ZCODNUMFCY)-10)+"X"
    Endif
    If func AFNC.ACTIV("DKS") Then
      Chgfmt [M:TRE1]CODNUMFCYD With "K:"+num$(GLONANM)+"B"
      If dim([M:TRE1]ZCODNUMFCYD)>0
        Chgfmt [M:TRE1]ZCODNUMFCYD With "KP:"+num$(type([M:TRE1]ZCODNUMFCYD)-10)+"X"
      Endif
    Endif
    #
    Chgfmt [M:TRE1]CODNUMCPY With "K:"+num$(GLONANM)+"B"
    If dim([M:TRE1]ZCODNUMCPY)>0
      Chgfmt [M:TRE1]ZCODNUMCPY With "KP:"+num$(type([M:TRE1]ZCODNUMCPY)-10)+"X"
    Endif
    If func AFNC.ACTIV("DKS") Then
      Chgfmt [M:TRE1]CODNUMCPYD With "K:"+num$(GLONANM)+"B"
      If dim([M:TRE1]ZCODNUMCPYD)>0
        Chgfmt [M:TRE1]ZCODNUMCPYD With "KP:"+num$(type([M:TRE1]ZCODNUMCPYD)-10)+"X"
      Endif
    Endif
  Endif
End

#########################################################################
#    Détail des actions : Classées par champs dans l'ordre des écrans   #
#########################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

Call SHOWHIDE_COUNT_DEF(VALEUR)

#RMA * 85785
If func AFNC.ACTIV("KPO")
  Call SHOW_HIDE_TRE(VALEUR) From PORLEGLIB
Endif

End
######################################################################################
Subprog AS_SRHCAT(VALEUR)
Variable Integer VALEUR

If !func AFNC.ACTIV("LST") GMENLOC(3)=1 Endif

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran TRE1) 20/04/2012 10:51:24 (CPO)
######################################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR

#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If func AFNC.ACTIV("KPO")>0 & find(VALEUR,"POR","")
  Local Char WMESS(100) : WMESS = ""
  Call CTL_CODNUM_LEG(VALEUR,[M:TRE1]SRHTYP,"TRE",WMESS)    From PORLEGLIB
  If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
Endif
# Issue End

End
######################################################################################
Subprog C_CODNUM(VALEUR)
Variable Char    VALEUR()
#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If VALEUR<>''
  If func AFNC.ACTIV("KPO")>0 & find([M:TRE1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    If find(VALEUR,[M:TRE1]CODNUMEND,[M:TRE1]CODNUMFCYD,[M:TRE1]CODNUMCPYD) : GMESSAGE = mess(142,7711,1) : mkstat = 2 : End : Endif
    Call CTL_CODNUM_NORMAL(VALEUR,[M:TRE1]LEG,[M:TRE1]SRHTYP,"TRE",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
Endif
# Issue End

##--CPO 17.05.2013 Suite mail Filipa M
##--Le champs CODNUMEND est soumis au code acitivié DKS
#If func AFNC.ACTIV("DKS")>0
##--/
#  #--Le compteur définitif doit être différent de celui normal
#  If [M:TRE1]CODNUMEND<>"" and [M:TRE1]CODNUMEND=VALEUR
#    GMESSAGE= mess(248,191,1)
#    mkstat = 2
#  Endif
#Endif

Gosub CTL_CODNUM

End
######################################################################################
Subprog C_CODNUMEND(VALEUR)
Variable Char    VALEUR()
#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If VALEUR<>''
  If find([M:TRE1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    If find(VALEUR,[M:TRE1]CODNUMFCYD,[M:TRE1]CODNUMCPYD,[M:TRE1]CODNUM,[M:TRE1]CODNUMFCY,[M:TRE1]CODNUMCPY) : GMESSAGE = mess(142,7711,1) : mkstat = 2 : End : Endif
    Call CTL_CODNUM_FINAL(VALEUR,[M:TRE1]LEG,[M:TRE1]SRHTYP,"TRE",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
Endif
# Issue End

#--Le compteur définitif doit être différent de celui normal
If [M:TRE1]CODNUM<>"" and [M:TRE1]CODNUM=VALEUR
  GMESSAGE= mess(248,191,1)
  mkstat = 2
Endif
Gosub CTL_CODNUM

End
######################################################################################
