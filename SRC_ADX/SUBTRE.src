######################################################################################
Subprog C_CODNUMCPY(VALEUR)
Variable Char    VALEUR()
#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If VALEUR<>''
  If func AFNC.ACTIV("KPO")>0 & find([M:TRE1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    If find(VALEUR,[M:TRE1]CODNUMFCYD,[M:TRE1]CODNUMCPYD,[M:TRE1]CODNUMEND) : GMESSAGE = mess(142,7711,1) : : mkstat = 2 : End : Endif
    Call CTL_CODNUM_NORMAL(VALEUR,[M:TRE1]LEG,[M:TRE1]SRHTYP,"TRE",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
