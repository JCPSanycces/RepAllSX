###############################################################################
# Classe EDISORDER                                                            #
# Author : RBA                                                                #
###############################################################################
End

###############################################################################
$EVENTS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AINIT"           : Gosub AINIT             From SORDER_METHODS
        When "AREAD_AFTER"     : Gosub AREAD_AFTER       From SORDER_METHODS
        When "AINSERT_BEFORE"  : #Gosub AINSERT_BEFORE   From SORDER_METHODS
        When "AUPDATE_BEFORE"  : #Gosub AUPDATE_BEFORE   From SORDER_METHODS
      Endcase
#    When "SOP"
#      Case[L]AEVENT
#        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SOP  From SORDERP_CSTD
#        When Default
#      Endcase
#    When "SOP.C_VACITM"
#      Case [L]AEVENT
#        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SOP_C_VACITM  From SORDERP_CSTD
#        When Default
#      Endcase
#    When "SOP.C_VAT"
#      Case [L]AEVENT
#        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SOP_C_VAT  From SORDERP_CSTD
#        When Default
#      Endcase
#    When "SOQ"
#      Case [L]AEVENT
#        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SOQ  From SORDERQ_CSTD
#        When Default
#      Endcase
    When "SVV"
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVV  From SVCRVAT_CSTD
      Endcase
    When "SVF"
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVF  From SVCRFOOT_CSTD
      Endcase
    When "SVF.C_DTAVAT"
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVF_C_DTAVAT  From SVCRFOOT_CSTD
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
    When "LOAD_ADDBPC"     : Gosub LOAD_ADDBPC       From SORDER_METHODS
    When "UNLOAD_ADDBPC"   : Gosub UNLOAD_ADDBPC     From SORDER_METHODS
    When "LOAD_ADDBPD"     : Gosub LOAD_ADDBPD       From SORDER_METHODS
    When "UNLOAD_ADDBPD"   : Gosub UNLOAD_ADDBPD     From SORDER_METHODS
    When "LOAD_ADDBPI"     : Gosub LOAD_ADDBPI       From SORDER_METHODS
    When "UNLOAD_ADDBPI"   : Gosub UNLOAD_ADDBPI     From SORDER_METHODS
    When "INIT_TSCCODADI"  : Gosub INIT_TSCCODADI    From SORDER_METHODS
  Endcase
Return

$OPERATIONS
  Case [L]AOPERATION
    When "LOCK_UNLOCK"     : Gosub LOCK_UNLOCK       From SORDER_METHODS
  Endcase
Return

#######################################################################################
$PROPERTIES
  Case [L]CURPRO
    When "CPY"          # : Gosub CPY
      Case [L]ARULE
        When "PROPAGATE"      :  Gosub CPY_PROPAGATE          #   From SORDER_PROPERTIES
      Endcase
    When "LEG"                      : #Gosub LEG            From SORDER_PROPERTIES :#--CPO 16/10/2013
    When "CPYCUR"                   : #Gosub CPYCUR         From SORDER_PROPERTIES :#--CPO 16/10/2013
    When "SOHTYP_LEG"               : #Gosub SOHTYP_LEG     From SORDER_PROPERTIES
    When "VACBPR_LEG"               : #Gosub VACBPR_LEG     From SORDER_PROPERTIES
    When "PTE_LEG"                  : #Gosub PTE_LEG        From SORDER_PROPERTIES
    When "DEP_LEG"                  : #Gosub DEP_LEG        From SORDER_PROPERTIES
    When "SDHTYP_LEG"               : #Gosub SDHTYP_LEG     From SORDER_PROPERTIES
    When "INVCDTA"                  : #--CPO 14.08.2013 Revue code classes Gosub INVCDTA        From SORDER_PROPERTIES
    When "SVV.VAT_LEG"              : #If [L]ARULE="GET" : Gosub LOAD_VAT_LEG        From SVCRVAT_CSTD  : Endif
    When "SVF.C_DTAVAT.DTAVAT_LEG"  : #If [L]ARULE="GET" : Gosub LOAD_DTAVAT_LEG     From SVCRFOOT_CSTD : Endif
    When "SVF.SUMDTAVAT_LE"         : #If [L]ARULE="GET" : Gosub LOAD_SUMDTAVAT_LEG  From SVCRFOOT_CSTD : Endif
    When Default
  Endcase
Return


# ----------------------- CPY --------------------------------------
$CPY_PROPAGATE
Local Integer WI
  If this.CPY<>""
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0=this.CPY
    If fstat Raz [F:CPY] : Endif
    this.LEG = [F:CPY]LEG
    this.CPYCUR = [F:CPY]ACCCUR
  Endif
Return

