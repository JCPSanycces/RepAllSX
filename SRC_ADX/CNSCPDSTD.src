#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# CNSCPDSTD : Consultation des lignes de demandes d'achat SEGAY 26/11/08#
# ECRAN 1   : CONSCPD1                                                  #
# ECRAN 2   : CONSCPD2                                                  #
# ECRAN CRIT: CRITCPD                                                   #
#########################################################################
Local Char PARAM(20)(1..2)
PARAM(1) = "2204"
PARAM(2) = "GAL"
Call GCONSULT("CPD","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  #---------------------------#
  # Actions champs modèlisées #
  #---------------------------#
  When "AB1_NBLIG"    : Gosub AB1_NBLIG
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
NAVIG="CONSCPD"
# Issue 90496 - 2013-06-17 by SR
Local Char    WFIL(250),WFIL1(250),WFIL2(250), WFIL3(250), WFILF(250)
Local Char    DEBNUM(GLONPSH), FINNUM(GLONPSH)
Local Date    DEBDAT, FINDAT
Local Integer DEBLIN, FINLIN :# 69747

Gosub DEFCRIT
Return


# --------------------------------------------------------------------------#
# Analyse paramètres, initialisations                                       #
# --------------------------------------------------------------------------#
$DEFCRIT
# Issue 81125 - 2012-03-29 by MUARN : consultation lignes
#If GNBAUZ=1 : PARAM(2)=GUSRFCY(1) : Endif
If GNBAUZ=1 : PARAM(3)=GUSRFCY(1) : Endif
For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Article
      If PARAM(I) <> ""
        If [F:ITM]ITMREF <> PARAM(I) Read [ITM]ITM0 = PARAM(I)
                                     If fstat  Raz [F:ITM], PARAM(I) : Endif
        Endif
        [M:CPD1]ITMREF = PARAM(I)
      Endif

    When 2 :    : # Parametre Fournisseur
      If PARAM(I) <> ""
        If [F:BPS]BPSNUM <> PARAM(I) Read [BPS] BPS0 = PARAM(I)
                                     If fstat  Raz [F:BPS], PARAM(I) : Endif
        Endif
#US 71069/138  by RBA
#        [M:CPD1]BPSNUM = PARAM(I)
        [M:CPD1]BPSNUMDEB = PARAM(I)
        [M:CPD1]BPSNUMFIN = PARAM(I)
#/US 71069/138  by RBA
      Endif
    When 3 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [FCY] FCY0 = PARAM(I)
                                     If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif

        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
          [M:CPD1]PSHFCY = PARAM(I)
          [M:CPD1]CPY = GSOCIETE
        Endif
      Endif
    When 4 :    : # Parametre PJT
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> "" Then
        [M:CPD1]PJTDEB = PARAM(I)
        [M:CPD1]PJTFIN = PARAM(I)
        If find(GNAVIG(GPILNAV-0),"GESPJM") Then   # Note FGR : '-0' is not an error. This is true in this case.
          [M:CPD1]PJTDSPALL = [V]CST_AYES
        Endif
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
    When 5 :    : # Parametre DATBEG
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> "" and PARAM(I) <> "000000" Then
        [M:CPD1]PRQDATDEB = PARAM(I)
        [M:CPD1]PRQDATDEB = gdat$(01,month([M:CPD1]PRQDATDEB),year([M:CPD1]PRQDATDEB))
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
  Endcase
Next I

# soldée oui
If !find([M:CPD1]CLEFLGO,1,2) : [M:CPD1]CLEFLGO= 1 : Endif
# non soldée
If !find([M:CPD1]CLEFLGN,1,2) : [M:CPD1]CLEFLGN= 2 : Endif
# signée oui
If !find([M:CPD1]APPFLGO,1,2) : [M:CPD1]APPFLGO= 2 : Endif
# signée non
If !find([M:CPD1]APPFLGN,1,2) : [M:CPD1]APPFLGN= 2 : Endif
# commandée oui
If !find([M:CPD1]ORDFLGO,1,2) : [M:CPD1]ORDFLGO= 2 : Endif
# commandée non
If !find([M:CPD1]ORDFLGN,1,2) : [M:CPD1]ORDFLGN= 2 : Endif
# soldée oui
If !find([M:CCPD]CLEFLGO,1,2) : [M:CCPD]CLEFLGO= 1 : Endif
# non soldée
If !find([M:CCPD]CLEFLGN,1,2) : [M:CCPD]CLEFLGN= 2 : Endif
# signée oui
If !find([M:CCPD]APPFLGO,1,2) : [M:CCPD]APPFLGO= 2 : Endif
# signée non
If !find([M:CCPD]APPFLGN,1,2) : [M:CCPD]APPFLGN= 2 : Endif
# commandée oui
If !find([M:CCPD]ORDFLGO,1,2) : [M:CCPD]ORDFLGO= 2 : Endif
# commandée non
If !find([M:CCPD]ORDFLGN,1,2) : [M:CCPD]ORDFLGN= 2 : Endif
# imprimée oui
If !find([M:CCPD]PRNFLGO,1,2) : [M:CCPD]PRNFLGO= 2 : Endif
# imprimée non
If !find([M:CCPD]PRNFLGN,1,2) : [M:CCPD]PRNFLGN= 2 : Endif
If !find([M:CCPD]TRI,1,2)     : [M:CCPD]TRI = 1   : Endif

#----- Initialisation dates début et fin -----#
Gosub INIT_DATES From TRTACHGRH1
# Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
#[M:CPD1]PRQDATDEB=WDATDEB
If [M:CPD1]PRQDATDEB = [0/0/0] Then
  [M:CPD1]PRQDATDEB=WDATDEB
Endif
# Issue Issue X3-15598 - 2017-02-23 by FGR : END
[M:CPD1]PRQDATFIN=WDATFIN

#----- Copie du masque 1 (CPD1) vers l'écran critères (CCPD) -----#
Gosub CRITENT From =PROGCNS
Return

############################################################
$DEB_CRIT
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            Diszo [M:CCPD]ITMREF
        Elsif find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:CCPD]ITMREF
            Diszo [M:CCPD]PSHFCY
            Diszo [M:CCPD]CPY
        Endif
        If dim([M:CCPD]TSICOD) > 0
          For I = 0 To dim([M:CCPD]TSICOD)-1
            Diszo [M:CCPD]TSICOD(I)
          Next I
        Endif
    Endif
    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
#        Diszo [M:CCPD]BPSNUM
        Diszo [M:CCPD]BPSNUMDEB : Diszo [M:CCPD]BPSNUMFIN
        If dim([M:CCPD]TSSCOD) > 0
          For I = 0 To dim([M:CCPD]TSSCOD)-1
            Diszo [M:CCPD]TSSCOD(I)
          Next I
        Endif
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CCPD]PJTDEB
      Diszo [M:CCPD]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END
Endif

Return

############################################################
$LECTURE
Local   Decimal  WMNTORG(0..1), WMNTDES(0..1)
Local   Integer  SPSTAT

#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:CPD1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:CPD1]ITMREF
        Diszo [M:CPD1]PSHFCY
        Diszo [M:CPD1]CPY
    Endif

    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
#        Diszo [M:CPD1]BPSNUM
        Diszo [M:CPD1]BPSNUMDEB : Diszo [M:CPD1]BPSNUMFIN
    Endif
Endif

    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CPD1]PJTDEB
      Diszo [M:CPD1]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [PSD] With [PSH]PSH0=[PSD]PSHNUM,
&               [ITM]ITM0=[PSD]ITMREF,
&               [BPS]BPS0=[PSD]BPSNUM
&          As [LNK]



# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
# Issue 90496 - 2013-06-17 by SR
#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCPD]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)  & evalue(WFILF) Order By Key PSD0
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFILF)
&                     Order By Key CLE=[F:PSH]PRQDAT;[F:PSD]PSHNUM;[F:PSD]PSDLIN :# 69747
#&                     Order By Key CLE=[F:PSH]PRQDAT;[F:PSD]PSHNUM
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCPD]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFILF) Order By Key PSD0 Desc
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFILF)
&                     Order By [F:PSH]PRQDAT Desc ;[F:PSD]PSHNUM Desc;[F:PSD]PSDLIN Desc:# 69747
#&                     Order By [F:PSH]PRQDAT Desc ;[F:PSD]PSHNUM Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CPD2] : Endif

#-- lecture
$BOUCLE
For [LNK]

# Filtre sur la société
  If [M:CPD1]CPY <> ""
      If [F:FCY]FCY <> [F:PSH]PSHFCY Then
        Read [FCY] FCY0 = [F:PSH]PSHFCY
        If fstat  Raz [F:FCY] : Endif
      Endif
      If [F:FCY]LEGCPY <> [M:CPD1]CPY Goto SUIV : Endif
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CPD2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         #69747
         If CHGPAG=2
           If [F:PSD]PSHNUM=FINNUM and [F:PSD]PSDLIN<=FINLIN : NOL-=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         DEBNUM = [F:PSH]PSHNUM
         DEBDAT = [F:PSH]PRQDAT
         DEBLIN = [F:PSD]PSDLIN :# 69747
     Endif
     FINNUM = [F:PSH]PSHNUM
     FINDAT = [F:PSH]PRQDAT
     FINLIN = [F:PSD]PSDLIN :# 69747
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         #69747
         If CHGPAG=-2
           If [F:PSD]PSHNUM=DEBNUM and [F:PSD]PSDLIN>=DEBLIN : NOL+=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         FINNUM = [F:PSH]PSHNUM
         FINDAT = [F:PSH]PRQDAT
         FINLIN = [F:PSD]PSDLIN :# 69747
     Endif
     DEBNUM = [F:PSH]PSHNUM
     DEBDAT = [F:PSH]PRQDAT
     DEBLIN = [F:PSD]PSDLIN :# 69747
  Endif
  nolign = NOL+1

  [M:CPD2]=[F:PSH] : # trans classe sur PREQUIS
  [M:CPD2]=[F:PSD] : # trans classe sur PREQUISD

  #US 71069/15  PJT by RBA
  [M:CPD2]PJT(nolign-1)       = [F:PSD]PJT
  #/US 71069/15  PJT by RBA

  # Raison sociale du fournisseur
  Filter [BPS] Where BPSNUM=[F:PSD]BPSNUM
     For [BPS]
         [M:CPD2]BPSNAM(nolign-1)=[F:BPS]BPSNAM # raison sociale
     Next
  Filter [BPS]
   # Récupération du 1er numéro de commande dans la table de demandes liens
#  Filter [PSO] Where PSHNUM=[F:PSD]PSHNUM AND POHNUM<>"" AND PSDLIN=[F:PSD]PSDLIN
#    Link [PSO] With [POQ]POQ0=[F:PSO]POHNUM;[F:PSO]POPLIN;[F:PSO]POQSEQ
#&            As [LN1]
#&            Order By Key KEY1 = [F:PSO]POHNUM;[F:PSO]POPLIN;[F:PSO]POQSEQ
#      Read [LN1]KEY1 First
#
#      If !fstat Then
#         [M:CPD2]POHNUM(nolign-1) = "*"
#         [M:CPD2]POPLIN(nolign-1) = [F:PSO]POPLIN
#         [M:CPD2]POQSEQ(nolign-1) = [F:PSO]POQSEQ
#         [M:CPD2]POHTYP(nolign-1) = [F:POQ]POHTYP
#      Endif
#    Filter [LN1]
#  Filter [PSO]

  Integer NBPOHLIG
  NBPOHLIG = 0
  Filter [PSO] Where PSHNUM=[F:PSD]PSHNUM and POHNUM<>"" and PSDLIN=[F:PSD]PSDLIN
    Link [PSO] With [POQ]POQ0=[F:PSO]POHNUM;[F:PSO]POPLIN;[F:PSO]POQSEQ
&            As [LN1]
&            Order By Key KEY1 = [F:PSO]POHNUM;[F:PSO]POPLIN;[F:PSO]POQSEQ
      For [LN1]
         If NBPOHLIG = 0 Then
           [M:CPD2]POHNUM(nolign-1) = [F:PSO]POHNUM
           [M:CPD2]POPLIN(nolign-1) = [F:PSO]POPLIN
           [M:CPD2]POQSEQ(nolign-1) = [F:PSO]POQSEQ
           [M:CPD2]POHTYP(nolign-1) = [F:POQ]POHTYP
         Else
           [M:CPD2]POHNUM(nolign-1) = "*"
         Endif
         NBPOHLIG +=1

      Next
      Filter [LN1]
  Filter [PSO]

$SUIV
Next
Filter [LNK]

Return
############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFIL3 = "1=1"
# Issue 90496 - 2013-06-17 by SR
WFILF = "1=1"

# Site de demande
If [M:CPD1]PSHFCY <> ""
   WFIL += "&[F:PSH]PSHFCY=[M:CPD1]PSHFCY"
Endif
# Autorisation site
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   WFIL += "& find([F:PSH]PSHFCY,GUSRFCY(1..GNBAUZ))"
Endif
## Numéro de fournisseur
#If [M:CPD1]BPSNUM <> ""
#   WFIL += "&[F:PSD]BPSNUM =[M:CPD1]BPSNUM"
#Endif

# Numéro de fournisseur
If [M:CPD1]BPSNUMDEB <> ""
   WFIL3 += "&[F:PSD]BPSNUM >=[M:CPD1]BPSNUMDEB"
Endif
If [M:CPD1]BPSNUMFIN <> ""
   WFIL3 += "&[F:PSD]BPSNUM <=[M:CPD1]BPSNUMFIN"
Endif

# Article
If [M:CPD1]ITMREF <> ""
   WFIL += "&[F:PSD]ITMREF =[M:CPD1]ITMREF"
Endif
# Demandeur
If [M:CPD1]REQUSR <> ""
   WFIL += "&[F:PSH]REQUSR =[M:CPD1]REQUSR"
Endif

#    Prise en compte des demandes soldées
#    si la demande est soldée CLEFLG = 2
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPD1]CLEFLGO = 1
   WFIL1 += "&[F:PSH]CLEFLG<>2"
Endif

#    Prise en compte des demandes non soldées
#    si la demande n'est pas soldée CLEFLG = 1
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPD1]CLEFLGN = 1
   WFIL1 += "&[F:PSH]CLEFLG=2"
Endif

#    Prise en compte des demandes signées
#    si la demande est totalement signée APPFLG > 2
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPD1]APPFLGO = 1
   WFIL1 += "&[F:PSH]APPFLG<3"
Endif

#    Prise en compte des demandes non signées
#    si la demande n'est pas totalement signée APPFLG <3
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPD1]APPFLGN = 1
   WFIL1 += "&[F:PSH]APPFLG>2"
Endif


#    Prise en compte des demandes commandées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPD1]ORDFLGO= 1
   WFIL1 += "&[F:PSH]ORDFLG<>2"
Endif

#    Prise en compte des demandes non commandées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPD1]ORDFLGN= 1
   WFIL1 += "&[F:PSH]ORDFLG=2"
Endif


#    Prise en compte des demandes imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPD]PRNFLGO= 1
   WFIL1 += "&[F:PSH]PRNFLG<>2"
Endif

#    Prise en compte des demandes non imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPD]PRNFLGN= 1
   WFIL1 += "&[F:PSH]PRNFLG=2"
Endif

# Numéro de pièce de demande
If [M:CCPD]PSHNUMDEB <> ""
   WFIL += "&[F:PSH]PSHNUM>=[M:CCPD]PSHNUMDEB"
Endif
If [M:CCPD]PSHNUMFIN <> ""
   WFIL += "&[F:PSH]PSHNUM<=[M:CCPD]PSHNUMFIN"
Endif
# Date de demande
If [M:CCPD]PRQDATDEB <> [0/0/0]
   WFIL += "&[F:PSH]PRQDAT>=[M:CCPD]PRQDATDEB"
Endif
If [M:CCPD]PRQDATFIN <> [0/0/0]
   WFIL += "&[F:PSH]PRQDAT<=[M:CCPD]PRQDATFIN"
Endif

# SUR L'ARTICLE ITMMASTER
If dim([M:CCPD]TSICOD) > 0
  For I = 0 To dim([M:CCPD]TSICOD)-1
    If [M:CCPD]TSICOD(I) <> ""
      If len(WFIL) > 200
        WFIL2 += "&[F:ITM]TSICOD("+num$(I)+")='"+[M:CCPD]TSICOD(I)+"'"
      Else
        WFIL += "&[F:ITM]TSICOD("+num$(I)+")='"+[M:CCPD]TSICOD(I)+"'"
      Endif
    Endif
  Next I
Endif
# SUR LE FOURNISSEUR BPSUPPLIER
If dim([M:CCPD]TSSCOD) > 0
  For I = 0 To dim([M:CCPD]TSSCOD)-1
    If [M:CCPD]TSSCOD(I) <> ""
      If len(WFIL) > 200
        WFIL2 += "&[F:BPS]TSSCOD("+num$(I)+")='"+[M:CCPD]TSSCOD(I)+"'"
      Else
        WFIL += "&[F:BPS]TSSCOD("+num$(I)+")='"+[M:CCPD]TSSCOD(I)+"'"
      Endif
    Endif
  Next I
Endif

# Issue X3-25731 - 2017-02-24 by FGR : BEGIN
##US 71069/15  PJT by RBA
#If [M:CCPD]PJTDEB <> ""
#   WFIL3 += "&[F:PSD]PJT>=[M:CCPD]PJTDEB"
#Endif
#If [M:CCPD]PJTFIN <> ""
#   WFIL3 += "&[F:PSD]PJT<=[M:CCPD]PJTFIN"
#Endif
##/US 71069/15  PJT by RBA
If dim([M:CCPD]PJTDSPALL) >= 0 and [M:CCPD]PJTDSPALL = [V]CST_AYES and [M:CCPD]PJTDEB <> "" Then
  Local Char SPJT(GLONPIM)
  Local Char SBUDGET(GLONTAC)
  Local Char STASK(GLONPBU)
  Local Integer IRET

  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CCPD]PJTDEB, SPJT, SBUDGET, STASK)
  WFIL1 += "&pat([F:PSD]PJT,'" + SPJT + "*')<>0"
Else
  If [M:CCPD]PJTDEB <> "" Then
     WFIL3 += "&[F:PSD]PJT>=[M:CCPD]PJTDEB"
  Endif
  If [M:CCPD]PJTFIN <> ""
     WFIL3 += "&[F:PSD]PJT<=[M:CCPD]PJTFIN"
  Endif
Endif
# Issue X3-25731 - 2017-02-24 by FGR : END

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCPD]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PSH]PSHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:PSH]PRQDAT>DEBDAT | ([F:PSH]PRQDAT=DEBDAT & [F:PSH]PSHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCPD]TRI
       When 1 : # tri par numéro
           #WFIL += "&[F:PSH]PSHNUM>FINNUM"
           WFIL += "&[F:PSH]PSHNUM>=FINNUM" :# 69747
       When 2 : # tri par date
           #WFIL += "&([F:PSH]PRQDAT>FINDAT | ([F:PSH]PRQDAT=FINDAT & [F:PSH]PSHNUM>FINNUM))"
           WFIL += "&([F:PSH]PRQDAT>FINDAT | ([F:PSH]PRQDAT=FINDAT & [F:PSH]PSHNUM>=FINNUM))" :# 69747
     Endcase
   When -2 : # retour
     Case [M:CCPD]TRI
       When 1 : # tri par numéro
           #WFIL += "&[F:PSH]PSHNUM<DEBNUM"
           WFIL += "&[F:PSH]PSHNUM<=DEBNUM" :# 69747
       When 2 : # tri par date
           #WFIL += "&([F:PSH]PRQDAT<DEBDAT | ([F:PSH]PRQDAT=DEBDAT & [F:PSH]PSHNUM<DEBNUM))"
           WFIL += "&([F:PSH]PRQDAT<DEBDAT | ([F:PSH]PRQDAT=DEBDAT & [F:PSH]PSHNUM<=DEBNUM))" :# 69747
     Endcase
Endcase
# Formule supplémentaire
If [M:CCPD]SELFOR <> "" Then
  Read [TFO]TFO0=35;[M:CCPD]SELFOR  # 35 = "Sélections achats" du chapitre 213
  If fstat = 0
    WFILF = [F:TFO]FORFOR
  Endif
Endif
Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT

Return

$AB1_NBLIG
#------------------------------------------------------#
# Avant exécution du bouton Tunnel livraisons, contrats #
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1(GLONPOH)
Local Char     WCLE2(GLONPOH)

If [M:CPD2]POHTYP(NOL) = 2 # Commande ouverte
  WOBJET="POD"
  WCLE1 =num$(1)
  WCLE2 =[M:CPD2]POHNUM(NOL)
Else
  WOBJET="POH"
  WCLE1=[M:CPD2]POHNUM(NOL)
  WCLE2=""
Endif
Return

# Gestion du masque CRITCPD

######################################################################################
## Etiquette ajoutée par le superviseur (écran CRITCPD) 25/11/2008 15:24:56 (SEGAY)
######################################################################################
Subprog AV_CPY(VALEUR)
Variable Char    VALEUR
If GNBAUZ=1 : Diszo [M]CPY, PSHFCY : Endif
End
#-------------------------------#
# Contrôle de la société        #
#-------------------------------#
Subprog C_CPY(VALEUR)
Variable Char    VALEUR
If VALEUR <> ""
    GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]PSHFCY = ""
  GSOCIETE="" : GLOCALDEV=""
Endif
End
#-------------------------------#
# Après modif de la société     #
#-------------------------------#
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR
Affzo ZCPY                      : # Utilisé par 2 écrans on ne précise pas la classe
Raz [M]PSHFCY, [M]ZPSHFCY
Affzo PSHFCY, ZPSHFCY           : # Utilisé par 2 écrans on ne précise pas la classe
If VALEUR<>""  GSOCIETE=VALEUR : Endif
End
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CRITCPD) 25/11/2008 15:34:01 (SEGAY)
######################################################################################
#------------------------------------------------#
# Contrôle du site par defaut pour achat         #
# on regarde en fonction des autorisations sites #
# uniquement dans le cas site par defaut = ""    #
# complément de l'action VERIFCY en avant saisie #
#------------------------------------------------#
Subprog C_PSHFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
Elsif [M]CPY = ""
    GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End
#-------------------------------#
# Après modif du site           #
#-------------------------------#
Subprog AM_PSHFCY(VALEUR)
Variable Char    VALEUR
If VALEUR <> ""
  Affzo CPY, ZCPY : # Utilisé par 2 ecrans
Endif
End

Subprog AS_BPSNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]BPSNUMDEB
Endif
End

Subprog C_BPSNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]BPSNUMDEB
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End

#---------------------------------------------------#
#      Controle du numéro de commande fin           #
# ------------------------------------------------- #
Subprog AS_PSHNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]PSHNUMDEB
Endif
End

Subprog C_PSHNUMFIN(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]PSHNUMDEB : mkstat = 1 : End : Endif
End

#-------------------------------------#
# Après modification de la date début #
#-------------------------------------#
Subprog AM_PRQDATDEB(VALEUR)
Variable Date     VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
If dim([M]PERCOD)>0
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]PRQDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]PRQDATFIN=WDATE : Affzo PRQDATFIN
  Endif
Elsif VALEUR>[M]PRQDATFIN
  [M]PRQDATFIN=VALEUR
Endif
End

#-----------------------------------#
# Après modification de la date fin #
#-----------------------------------#
Subprog AM_PRQDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)<1  End : Endif
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]PRQDATFIN,VALEUR,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]PRQDATDEB=WDATE : Affzo PRQDATDEB
Endif
#-----
End

