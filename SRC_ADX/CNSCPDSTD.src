#-----------------#
# Init bouton     #
#-----------------#
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2, GBOUT3
If [M:CPD2]NBLIG<>0
   If clalev([M:PSH1])=0
      GBOUT2=mess(2,517,1)-[M]PSHNUM(nolign-1) : # Demande d'achat
      If [M:CPD2]PQHNUM(nolign-1)<>"" Then
         GBOUT3=mess(1,517,1)-[M]PQHNUM(nolign-1) # Appel d'offre
      Endif
      If [M:CPD2]POHNUM(nolign-1) <> "" and [M:CPD2]POHNUM(nolign-1) <> "*" # Une seule Commande
         If [M:CPD2]POHTYP(nolign-1) <> 2 # Commande standard
            GBOUT1 = mess(1,506,1)
         Else
            GBOUT1 = mess(2,506,1)
         Endif
      Endif
      If [M:CPD2]POHNUM(nolign-1) <> "*"
         Raz GBOUT4
      Endif
   Endif
 Endif
End


#########################################################################
# Pour exécution de la validation des consultations en gestion de patch #
#########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Call VALGTC(APPLI,"CPD") From SUBGTC
End

