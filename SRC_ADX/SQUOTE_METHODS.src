#######################################################################################
# METHODS                                                                             #
#######################################################################################
$AREAD_AFTER
Local Integer IRET
Local Integer NUML
  # -----------------------------------
  #--CPO 14.08.2013 Revue code
  #--Chargement de la LEG et de la devise société du document
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - LEG property filled below
  If this.CPY<>""
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0=this.CPY
    If fstat Raz [F:CPY] : Endif
    this.CPYCUR = [F:CPY]ACCCUR
  Endif

  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation
  #--VACBPR, DEP, PTE, SQHTYP, SOHTYP
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.SALFCY, this.LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SQHTYP_LEG(this, this.SQHTYP, this.CPY, this.SALFCY, this.LEG, this.SQHTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SOHTYP_LEG(this, this.SOHTYP, this.CPY, this.SALFCY, this.LEG, this.SOHTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_DEP_LEG(this, this.DEP, this.CPY, this.SALFCY, this.LEG, this.DEP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_PTE_LEG(this, this.PTE, this.CPY, this.SALFCY, this.LEG, this.PTE_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACBPR_LEG(this, this.VACBPR, this.CPY, this.SALFCY, this.LEG, this.VACBPR_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  #--CPO 14.08.2013 Revue code
  For NUML=1 To maxtab(this.C_BPCADDLIG)
    If  this.C_BPCADDLIG(NUML)<>null & find(this.C_BPCADDLIG(NUML).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      Case NUML
         When 1
          this.BPCADDLIG1 = this.C_BPCADDLIG(NUML).BPCADDLIG
        When 2
          this.BPCADDLIG2 = this.C_BPCADDLIG(NUML).BPCADDLIG
        When 3
          this.BPCADDLIG3 = this.C_BPCADDLIG(NUML).BPCADDLIG
        When Default
      Endcase
    Endif
  Next NUML

  For NUML=1 To maxtab(this.C_BPDADDLIG)
    If  this.C_BPDADDLIG(NUML)<>null & find(this.C_BPDADDLIG(NUML).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      Case NUML
         When 1
          this.BPDADDLIG1 = this.C_BPDADDLIG(NUML).BPDADDLIG
        When 2
          this.BPDADDLIG2 = this.C_BPDADDLIG(NUML).BPDADDLIG
        When 3
          this.BPDADDLIG3 = this.C_BPDADDLIG(NUML).BPDADDLIG
        When Default
      Endcase
    Endif
  Next NUML

  For NUML=1 To maxtab(this.C_BPCNAM)
    If  this.C_BPCNAM(NUML)<>null & find(this.C_BPCNAM(NUML).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      Case NUML
         When 1
          this.BPCNAM1 = this.C_BPCNAM(NUML).BPCNAM
        When 2
          this.BPCNAM2 = this.C_BPCNAM(NUML).BPCNAM
        When Default
      Endcase
    Endif
  Next NUML

  For NUML=1 To maxtab(this.C_BPDNAM)
    If  this.C_BPDNAM(NUML)<>null & find(this.C_BPDNAM(NUML).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      Case NUML
         When 1
          this.BPDNAM1 = this.C_BPDNAM(NUML).BPDNAM
        When 2
          this.BPDNAM2 = this.C_BPDNAM(NUML).BPDNAM
        When Default
      Endcase
    Endif
  Next NUML

  For NUML=1 To maxtab(this.C_REP)
    If  this.C_REP(NUML)<>null & find(this.C_REP(NUML).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      Case NUML
         When 1
          this.REP1 = this.C_REP(NUML).REP
        When 2
          this.REP2 = this.C_REP(NUML).REP
        When Default
      Endcase
    Endif
  Next NUML
  #--/
  # -----------------------------------
  # -----------------------------------
  If this.BPCADD(1) = null Then
    [L]ASTATUS = fmet this.ADDLINE("BPCADD",[V]CST_AFIRSTPOS)
  Endif
  If this.BPDADD(1) = null Then
    [L]ASTATUS = fmet this.ADDLINE("BPDADD",[V]CST_AFIRSTPOS)
  Endif
  # -----------------------------------
  [L]ASTATUS = fmet this.BPCADD(1).INIT_SALADDRESS("SQHBPC", this.BPCORD, this.BPAORD, this.CNCNAM)
  [L]ASTATUS = fmet this.BPDADD(1).INIT_SALADDRESS("SQHBPD", this.BPCORD, this.BPAADD, this.CNDNAM)
  # -----------------------------------

Return
########################################################################################
