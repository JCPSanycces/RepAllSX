#--CPO 14.08.2013 Revue code
#--Pour respecter les bonnes pratiques
#######################################################################################
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
$AREAD_BEFORE_SQD

  If this.APARENT<>null
    this.LEG = this.APARENT.LEG
  Endif

  If this.APARENT <> null Then
    this.CURVCR = this.APARENT.CUR
  Endif

Return
#######################################################################################
#--CPO 14.08.2013 Revue code classes
$AREAD_AFTER_SQD_C_VACITM

	# -----------------------------------
  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.APARENT.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.APARENT.APARENT.CPY, this.APARENT.APARENT.SALFCY, this.APARENT.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACITM_LEG(this, this.VACITM, this.APARENT.APARENT.CPY, this.APARENT.APARENT.SALFCY, this.APARENT.APARENT.LEG, this.VACITM_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this, this.VAT, this.APARENT.APARENT.CPY, this.APARENT.APARENT.SALFCY, this.APARENT.APARENT.LEG, this.VAT_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
#######################################################################################
$AREAD_BEFORE_SVV
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif
  this.LEG = this.APARENT.LEG

Return
#######################################################################################
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
$AREAD_AFTER_SVV

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  #--everything that concern SIH.C_TAX must be done at SIH.C_TAX level for CURPTH="SIH.C_TAX"
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this.APARENT, this.VAT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG, this.VAT_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
#######################################################################################
$AREAD_BEFORE_SVF

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - added LEG property to SINVOICEV class
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif
  this.LEG = this.APARENT.LEG

Return
#######################################################################################
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
$AREAD_AFTER_SVF

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  #--everything that concern SIH.C_TAX must be done at SIH.C_TAX level for CURPTH="SIH.C_TAX"
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this.APARENT, this.SUMDTAVAT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG, this.SUMDTAVAT_LE)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
#######################################################################################
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
$AREAD_AFTER_SVF_C_DTAVAT

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  #--everything that concern SIH.C_TAX must be done at SIH.C_TAX level for CURPTH="SIH.C_TAX"
  If this.APARENT.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT.APARENT, this.APARENT.APARENT.CPY, this.APARENT.APARENT.SALFCY, this.APARENT.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this.APARENT.APARENT, this.DTAVAT, this.APARENT.APARENT.CPY, this.APARENT.APARENT.SALFCY, this.APARENT.APARENT.LEG, this.DTAVAT_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
#######################################################################################
$LOAD_ADDBPC
#Value Instance ADDCLA Using C_SALADDRESS
Local Integer NI

  For NI = 1 To maxtab(this.C_BPCADDLIG)
    If this.C_BPCADDLIG(NI) <> null Then
      If evalue("dim(ADDCLA.ADDLIG" + num$(NI) + ")") >= 0 Then
        Assign "ADDCLA.ADDLIG" + num$(NI) With this.C_BPCADDLIG(NI).BPCADDLIG
      Endif
    Endif
  Next NI
  ADDCLA.POSCOD = this.BPCPOSCOD
  ADDCLA.CTY = this.BPCCTY
  ADDCLA.SAT = this.BPCSAT
  ADDCLA.CRY = this.BPCCRY
  ADDCLA.CRYNAM = this.BPCCRYNAM
  #
  For NI = 1 To maxtab(this.C_BPCNAM)
    If this.C_BPCNAM(NI) <> null Then
      If evalue("dim(ADDCLA.BPRNAM" + num$(NI) + ")") >= 0 Then
        Assign "ADDCLA.BPRNAM" + num$(NI) With this.C_BPCNAM(NI).BPCNAM
      Endif
    Endif
  Next NI

Return
#######################################################################################
$UNLOAD_ADDBPC
#Value Instance ADDCLA Using C_SALADDRESS
Local Integer NI

  this.BPAORD = ADDCLA.BPAADD
  this.BPCCRY = ADDCLA.CRY
  For NI = 1 To 10
    If evalue("dim(ADDCLA.ADDLIG" + num$(NI) + ")") < 0 Then
      Break
    Else
      If this.C_BPCADDLIG(NI) = null Then
        NLINE = fmet this.ADDLINE("C_BPCADDLIG", NI)
      Endif
      this.C_BPCADDLIG(NI).BPCADDLIG = evalue("ADDCLA.ADDLIG" + num$(NI))
    Endif
  Next NI
  this.BPCPOSCOD = ADDCLA.POSCOD
  this.BPCCTY = ADDCLA.CTY
  this.BPCSAT = ADDCLA.SAT
  this.BPCCRYNAM = ADDCLA.CRYNAM
  #
  For NI = 1 To 10
    If evalue("dim(ADDCLA.BPRNAM" + num$(NI) + ")") < 0 Then
      Break
    Else
      If this.C_BPCNAM(NI) = null Then
        NLINE = fmet this.ADDLINE("C_BPCNAM", NI)
      Endif
      this.C_BPCNAM(NI).BPCNAM = evalue("ADDCLA.BPRNAM" + num$(NI))
    Endif
  Next NI
  #
  this.CNCNAM = ADDCLA.CNTNAM

Return
#######################################################################################
$LOAD_ADDBPD
#Value Instance ADDCLA Using C_SALADDRESS
Local Integer NI

  For NI = 1 To maxtab(this.C_BPDADDLIG)
    If this.C_BPDADDLIG(NI) <> null Then
      If evalue("dim(ADDCLA.ADDLIG" + num$(NI) + ")") >= 0 Then
        Assign "ADDCLA.ADDLIG" + num$(NI) With this.C_BPDADDLIG(NI).BPDADDLIG
      Endif
    Endif
  Next NI
  ADDCLA.POSCOD = this.BPDPOSCOD
  ADDCLA.CTY = this.BPDCTY
  ADDCLA.SAT = this.BPDSAT
  ADDCLA.CRY = this.BPDCRY
  ADDCLA.CRYNAM = this.BPDCRYNAM
  #
  For NI = 1 To maxtab(this.C_BPDNAM)
    If this.C_BPDNAM(NI) <> null Then
      If evalue("dim(ADDCLA.BPRNAM" + num$(NI) + ")") >= 0 Then
        Assign "ADDCLA.BPRNAM" + num$(NI) With this.C_BPDNAM(NI).BPDNAM
      Endif
    Endif
  Next NI

Return
#######################################################################################
$UNLOAD_ADDBPD
#Value Instance ADDCLA Using C_SALADDRESS
Local Integer NI

  this.BPAADD = ADDCLA.BPAADD
  this.BPDCRY = ADDCLA.CRY
  For NI = 1 To 10
    If evalue("dim(ADDCLA.ADDLIG" + num$(NI) + ")") < 0 Then
      Break
    Else
      If this.C_BPDADDLIG(NI) = null Then
        NLINE = fmet this.ADDLINE("C_BPDADDLIG", NI)
      Endif
      this.C_BPDADDLIG(NI).BPDADDLIG = evalue("ADDCLA.ADDLIG" + num$(NI))
    Endif
  Next NI
  this.BPDPOSCOD = ADDCLA.POSCOD
  this.BPDCTY = ADDCLA.CTY
  this.BPDSAT = ADDCLA.SAT
  this.BPDCRYNAM = ADDCLA.CRYNAM
  #
  For NI = 1 To 10
    If evalue("dim(ADDCLA.BPRNAM" + num$(NI) + ")") < 0 Then
      Break
    Else
      If this.C_BPDNAM(NI) = null Then
        NLINE = fmet this.ADDLINE("C_BPDNAM", NI)
      Endif
      this.C_BPDNAM(NI).BPDNAM = evalue("ADDCLA.BPRNAM" + num$(NI))
    Endif
  Next NI
  #
  this.CNDNAM = ADDCLA.CNTNAM
Return
