$ON_TFNNUM
Onevent CONTROL Call C_TFNNUM(zc) From W2HRMAT5
Onevent AFTER_CHANGE Gosub AMM_TFNNUM From W2HRMAT5
Return

Subprog C_TFNNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_TFNNUM(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "TFNNUM" : GZNUM = 55107 : Endif
Gosub _AFF
End

$AMM_TFNNUM
Call AM_TFNNUM(zc)
If !mkstat & GOBJET
 zoncou = "TFNNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TFNNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TFNNUM(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "TFNNUM" : GZNUM = 55107 : Endif
Gosub _AFF
End

$ON_TFNREN
Onevent CONTROL Call C_TFNREN(zc) From W2HRMAT5
Onevent INIT_AREA Call D_TFNREN(zc) From W2HRMAT5
Onevent BEFORE_INPUT Call AS_TFNREN(zc) From W2HRMAT5
Return

Subprog D_TFNREN(VALEUR)
Variable Integer VALEUR
If varinit([M]TFNREN,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TFNREN(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_TFNREN(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_TFNREN(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "TFNREN" : GZNUM = 2675 : Endif
Gosub _AFF
End

