#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT5 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_EMPPOS
Onevent INIT_AREA Call D_EMPPOS(zc) From W2HRMAT5
Return

Subprog D_EMPPOS(VALEUR)
Variable Integer VALEUR
If varinit([M]EMPPOS,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_HOUOCCDAT
Onevent BEFORE_AREA Gosub AV_HOUOCCDAT From W2HRMAT5
Return

$AV_HOUOCCDAT
Chgfmt [M]HOUOCCDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_HOUREGDAT
Onevent BEFORE_AREA Gosub AV_HOUREGDAT From W2HRMAT5
Return

$AV_HOUREGDAT
