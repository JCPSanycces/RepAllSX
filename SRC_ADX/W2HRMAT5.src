$ON_SSCSIT
Onevent INIT_AREA Call D_SSCSIT(zc) From W2HRMAT5
Onevent CONTROL Call C_SSCSIT(zc) From W2HRMAT5
Onevent BEFORE_INPUT Call AS_SSCSIT(zc) From W2HRMAT5
Onevent AFTER_CHANGE Gosub AMM_SSCSIT From W2HRMAT5
Return

Subprog D_SSCSIT(VALEUR)
Variable Char    VALEUR()
If varinit([M]SSCSIT,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11705","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_SSCSIT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11705") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SSCSIT(zc) From W2HRMAT5
Onkey   2 Titled GBOUTS Call S_SSCSIT(zc) From W2HRMAT5
Onkey 144 Titled GBOUTP Call P_SSCSIT(zc) From W2HRMAT5
Onkey 146 Titled GBOUTA Call SA_SSCSIT(zc) From W2HRMAT5
Gosub _AFF
End

Subprog C_SSCSIT(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"11705","") From SUBADI
If mkstat : GERR = 1 : GZONE = "SSCSIT" : GZNUM = 1002843 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"11705",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SSCSIT" : GZNUM = 1002843 : Endif
Endif
Gosub _AFF
End

$AMM_SSCSIT
Call AM_SSCSIT(zc)
If !mkstat & GOBJET
 zoncou = "SSCSIT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SSCSIT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZSSCSIT)")>indice
 [M]SSCSIT(indice) = VALEUR
 Affzo ZSSCSIT(indice)
Endif
Gosub _AFF
End

Subprog S_SSCSIT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11705"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SSCSIT(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11705") From GOBJET
Gosub _AFF
End

Subprog SA_SSCSIT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11705"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_SSCSIT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11705"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZSSCSIT
Onevent BEFORE_AREA Gosub AV_ZSSCSIT From W2HRMAT5
Return

$AV_ZSSCSIT
Call LECTEXTRA(zc,"ATABDIV","LNGDES","11705",num$([M]SSCSIT(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_SSCDAT
Onevent BEFORE_INPUT Call AS_SSCDAT(zc) From W2HRMAT5
Onevent BEFORE_AREA Gosub AV_SSCDAT From W2HRMAT5
Return

$AV_SSCDAT
Chgfmt [M]SSCDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_SSCDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_SSCDAT(VALEUR) From SUBEML2
If mkstat=2
 [M]SSCDAT(INDIC) = VALEUR
 Affzo SSCDAT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

