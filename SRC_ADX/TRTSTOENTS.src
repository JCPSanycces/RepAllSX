#<AdxTL>@(#)0.0.0.0 $Revision$ $Revision:   1.5  $
########################################################################
# Traitement TRTSTOENTS - Selectiob detail stock                  V140 #
#                                                                      #
########################################################################
# Action SAISTOENTS
########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
# When "ENR"         : Gosub ENR
# When "ABA"         : Gosub ABA
 When "FINSAI"      : Gosub FINSAI
 When "BOUTON":
    Case BOUT
     When "E"         : Gosub ENR
     When "A"         : Gosub ABA
 Endcase

Endcase

Return

##########################################################################
$OUVRE
# Récupération des paramètres
Return
##########################################################################
$OUVRE_BOITE
# Récupération des paramètres
Local Integer LTYP
LTYP              = [M:ENT]VCRTYPORI
GBIDC1            = mess(LTYP,701,1)

Return

##########################################################################
$DEBUT

Local Integer LLIG
Local Integer I
Raz LLIG
Raz I
If dim(GISTOENTS) > 0
   Affzo [M]1-99
   Return
Endif

Raz [M:ENTS]

[M:ENTS]STOFCY    = [M:ENT]STOFCY
[M:ENTS]ITMREF    = [M:ENT]ITMREF
[M:ENTS]STU       = [M:ENT]STU
[M:ENTS]SRTFLG    = 1
[M:ENTS]VCRNUMORI = [M:ENT]VCRNUMORI

I=find([M:ENT]WSTOSEQ,[M:ENTW]WSTOSEQ)-1
If I<0 : Return : Endif

While [M:ENTW]WSTOSEQ(I)=[M:ENT]WSTOSEQ

      [M:ENTS]LIGENTW      (LLIG)     = (I)
      [M:ENTS]PCU          (LLIG)     = [M:ENTW]PCU                  (I)
      [M:ENTS]QTYPCU       (LLIG)     = [M:ENTW]QTYPCU               (I)
      [M:ENTS]QTYSTU       (LLIG)     = [M:ENTW]QTYSTU               (I)
      [M:ENTS]PCUSTUCOE    (LLIG)     = [M:ENTW]PCUSTUCOE            (I)
      [M:ENTS]STA          (LLIG)     = [M:ENTW]STA                  (I)
      If [M:ENTW]NUMLIGLOT (I)>=0
         If dim([M:ENTS]LOT) > 0
            [M:ENTS]LOT    (LLIG)     = [M:ENTW]LOT([M:ENTW]NUMLIGLOT(I))
         Endif
         If dim([M:ENTS]SLO) > 0
            [M:ENTS]SLO    (LLIG)     = [M:ENTW]SLO([M:ENTW]NUMLIGLOT(I))
         Endif
      Endif
      If dim([M:ENTS]SERNUM) > 0
         [M:ENTS]SERNUM    (LLIG)     = [M:ENTW]SERNUM               (I)
      Endif
      If dim([M:ENTS]PALNUM)>0
         [M:ENTS]PALNUM    (LLIG)     = [M:ENTW]PALNUM               (I)
      Endif
      If dim([M:ENTS]CTRNUM)>0
         [M:ENTS]CTRNUM    (LLIG)     = [M:ENTW]CTRNUM               (I)
      Endif
      If dim([M:ENTS]STOFLD1)>0
         [M:ENTS]STOFLD1   (LLIG)     = [M:ENTW]STOFLD1              (I)
      Endif
      If dim([M:ENTS]STOFLD2)>0
         [M:ENTS]STOFLD2   (LLIG)     = [M:ENTW]STOFLD2              (I)
      Endif

     [M:ENTS]NBLIGS                   = LLIG+1
     LLIG += 1
     I+=1
Wend

Global Integer GISTOENTS # Indique un chargement ISTOENTS

Affzo [M]1-99

Return

#########################################################################
$SETBOUT
# ------------------------------------------------------------------------------------- #
# Suppression des boutons                                                               #
# ------------------------------------------------------------------------------------- #
#     A : Abandon                                                                   #
#     I : Tout inclure                                                                  #
#     J : Tout exclure                                                                  #
#     E : Enregistrement                                                                #
#     K : Tri                                                                           #
# ------------------------------------------------------------------------------------- #
Local Integer NOL
Local Integer WLISTE
Raz WLISTE
Raz NOL
REP = GREP


# Pas de bouton Tout exclure par defaut
Call VIREBOUT(CHMEN,"J") From GOBJET

If REP = "M"
   CHMEN += "E"
Endif

# Bouton "Tout exclure "  si cochage
For NOL = 0 To [M:ENTS]NBLIGS-1
    If [M:ENTS]COCHAGE(NOL) = 2
       WLISTE = 1
       Break
    Endif
Next
If WLISTE >  0
   CHMEN += "J"
Endif

Return
##########################################################################
$ENR

Effzo [M:ENT]10
Effzo [M:ENT]20

# Chargement des lignes à partir des mouvements de stock du document origine
Local Integer  NOL
Local Integer  LLIG
Local Integer  I
Local Integer CPTRET
Integer PECC              # hcb 120607
Local Char    PMAJ(GLONECS)     # hcb 120607
Local Char    PMIN(GLONICVVAL)  # hcb 120607
Raz   PECC                      # hcb 120607
Raz   PMAJ                      # hcb 120607
Raz   PMIN                      # hcb 120607
Raz CPTRET
Raz NOL
For NOL = 0 To [M:ENTS]NBLIGS-1
    If [M:ENTS]COCHAGE(NOL)                    =  2
       I                                       = [M:ENTS]LIGENTW   (NOL)
       [M:ENT]ORILIG                   (LLIG)  = [M:ENTW]ORILIG    (I)
       [M:ENT]PCU                      (LLIG)  = [M:ENTW]PCU       (I)
       [M:ENT]QTYPCU                   (LLIG)  = [M:ENTW]QTYPCU    (I)
       [M:ENT]QTYPCUO                  (LLIG)  = [M:ENTW]QTYPCU    (I)
       [M:ENT]QTYSTU                   (LLIG)  = [M:ENTW]QTYSTU    (I)
       [M:ENT]PCUSTUCOE                (LLIG)  = [M:ENTW]PCUSTUCOE (I)
       If [M:ENTW]NUMLIGLOT(I)>=0
          [M:ENT]BPSLOTO               (LLIG)  = [M:ENTW]BPSLOT([M:ENTW]NUMLIGLOT   (I))
          If dim([M:ENT]BPSLOTAFF) > 0
             [M:ENT]BPSLOTAFF          (LLIG)  = [M:ENTW]BPSLOT([M:ENTW]NUMLIGLOT   (I))
          Endif
          If dim([M:ENT]LOTAFF) > 0
             [M:ENT]LOTAFF             (LLIG)  = [M:ENTW]LOT([M:ENTW]NUMLIGLOT      (I))
          Endif
          If dim([M:ENT]SLOAFF) > 0
             [M:ENT]SLOAFF             (LLIG)  = [M:ENTW]SLO([M:ENTW]NUMLIGLOT      (I))
          Endif
          [M:ENT]GESLOTAFF             (LLIG)  = [M:ENTW]GESLOT   ([M:ENTW]NUMLIGLOT(I))
 #                                                                                       # hcb 120607 deb
         If dim([M:ENT]ECCVALMAJAFF) > 0
             [M:ENT]ECCVALMAJAFF       (LLIG)  = [M:ENTW]ECCVALMAJ([M:ENTW]NUMLIGLOT      (I))
             PMAJ                              = [M:ENTW]ECCVALMAJ([M:ENTW]NUMLIGLOT      (I))
          Endif
          If dim([M:ENT]ECCVALMINAFF) > 0
             [M:ENT]ECCVALMINAFF       (LLIG)  = [M:ENTW]ECCVALMIN([M:ENTW]NUMLIGLOT      (I))
             PMIN                              = [M:ENTW]ECCVALMIN([M:ENTW]NUMLIGLOT      (I))
          Endif
          If dim([M:ENT]ECCSAIFLG) > 0
             [M:ENT]ECCSAIFLG          (LLIG)  = [M:ENTW]ECCSAIFLG([M:ENTW]NUMLIGLOT      (I))
             PECC                              = [M:ENTW]ECCSAIFLG([M:ENTW]NUMLIGLOT      (I))
          Endif
#                                                                                            # hcb 120607 fin
       Endif
       Call SETCPTLOTAUTO( [M:ENT]ITMREF, "ENT", LLIG, string$(dim([M:ENT]LOTAFF)>0,sigma(1,dim([M:ENT]LOTAFF)>0,[M:ENT]LOTAFF(LLIG))),
&                         string$(dim([M:ENT]SLOAFF)>0,sigma(1,dim([M:ENT]SLOAFF)>0,[M:ENT]SLOAFF(LLIG))),
&                         string$(dim([M:ENT]BPSLOTAFF)>0,sigma(1,dim([M:ENT]BPSLOTAFF)>0,[M:ENT]BPSLOTAFF(LLIG))),
&                         [M:ENT]GESLOTAFF(LLIG), 
&                         PMAJ,
&                         PMIN,
&                         PECC,
&                         CPTRET ) From STKENT



       [M:ENT]STOCOU              (LLIG)        = [M:ENTW]STOCOU   (I)
       If dim([M:ENT]SERNUM) > 0
          [M:ENT]SERNUM           (LLIG)        = [M:ENTW]SERNUM   (I)
       Endif
       If dim([M:ENT]SERNUMF) > 0
          [M:ENT]SERNUMF          (LLIG)        = [M:ENTW]SERNUMF  (I)
       Endif
       If dim([M:ENT]STUDIS) > 0
          [M:ENT]STUDIS           (LLIG)        = [M:ENTW]STUDIS   (I)
       Endif
       [M:ENT]STA                 (LLIG)        = [M:ENTW]STA      (I)
       If dim([M:ENT]LOCTYP)>0
          [M:ENT]LOCTYP           (LLIG)        = [M:ENTW]LOCTYP   (I)
       Endif
       If dim([M:ENT]LOC)>0
          [M:ENT]LOC              (LLIG)        = [M:ENTW]LOC      (I)
       Endif
       [M:ENT]WLOCSEQ             (LLIG)        = [M:ENTW]WLOCSEQ  (I)
       [M:ENT]LBEFMT              (LLIG)        = [M:ENTW]LBEFMT   (I)
       [M:ENT]LBENBR              (LLIG)        = [M:ENTW]LBENBR   (I)
       If dim([M:ENT]PALNUM)>0
         [M:ENT]PALNUM            (LLIG)        = [M:ENTW]PALNUM   (I)
       Endif
       If dim([M:ENT]CTRNUM)>0
          [M:ENT]CTRNUM           (LLIG)        = [M:ENTW]CTRNUM   (I)
       Endif
       If dim([M:ENT]STOFLD1)>0
          [M:ENT]STOFLD1          (LLIG)        = [M:ENTW]STOFLD1  (I)
       Endif
       If dim([M:ENT]STOFLD2)>0
          [M:ENT]STOFLD2          (LLIG)        = [M:ENTW]STOFLD2  (I)
       Endif

       [M:ENT]LBEFMT              (LLIG)        = [M:ENTW]LBEFMT   (I)
       [M:ENT]STOCOU              (LLIG)        = [M:ENTW]STOCOU   (I)
       [M:ENT]STOCOUALL           (LLIG)        = [M:ENTW]STOCOUALL(I)

       If dim([M:ENT]SAIACTFLG)>0
         [M:ENT]SAIACTFLG                       = [M:ENTW]SAIACTFLG(I)
       Endif
       [M:ENT]WFLG                (LLIG)        = 2


       [M:ENT]NBLIG                             = LLIG+1
       LLIG += 1
    Endif

Next
Default Mask [ENT]
Gosub GESSELECTION From TRTSTOENTB
Default Mask [ENTS]


Affzo [M:ENT]10
Affzo [M:ENT]PECQTY


FIN = 1
Return

##########################################################################
$FINSAI

mkstat = 4

Return

##########################################################################
$ABA

Call ACT_EXCENTS From TRTSTOENTS

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran STOENTS) 06/04/2006 16:46:07 (HCB)
######################################################################################
Subprog APRES_NBLIGS
End

Subprog AM_COCHAGE(VALEUR)
Variable Integer VALEUR
GREP = "M"

[M]COCHAGE  (nolign-1) = VALEUR
Gosub GESSELECTION
Affzo [M]PECQTY
End

######################################################################################
#   A C T I O N S
######################################################################################

########################################################################
# ACT_INCENTS  bouton TOUT INCLURE
########################################################################
Subprog ACT_INCENTS
Local Integer  NOL
Local Shortint WAFF
Raz WAFF
Raz NOL
For NOL = 0 To [M:ENTS]NBLIGS-1
    If [M:ENTS]COCHAGE(NOL) <> 2
       WAFF = 1
       [M:ENTS]COCHAGE  (NOL) = 2
       GREP = "M"
    Endif
Next
If WAFF = 1
   Gosub GESSELECTION
   Affzo [M:ENTS]10
   Affzo [M]PECQTY
Endif

End

########################################################################
# ACT_EXCENTS  bouton TOUT EXCLURE
########################################################################
Subprog ACT_EXCENTS
Local Integer  NOL
Local Shortint WAFF
Raz WAFF
Raz NOL
For NOL = 0 To [M:ENTS]NBLIGS-1
    If [M:ENTS]COCHAGE(NOL) =  2
       WAFF = 1
       [M:ENTS]COCHAGE  (NOL) = 1
       GREP = "M"
    Endif
Next
If WAFF = 1
   Affzo [M:ENTS]10
   Raz   [M]PECQTY
   Affzo [M]PECQTY
Endif

End


########################################################################
# ACT_TRIENTS  bouton CLASSEMENT
########################################################################
Subprog ACT_TRIENTS
If [M:ENTS]NBLIGS <> 0
    Case [M:ENTS]SRTFLG
        When 1 : Sorta [M:ENTS]NBLIGS [M:ENTS]NBLIGS Order By [M:ENTS]LOT(indice),[M:ENTS]SLO(indice),
&                                                             [M:ENTS]SERNUM(indice),[M:ENTS]PALNUM(indice),
&                                                             [M:ENTS]CTRNUM(indice)

        When 2 : Sorta [M:ENTS]NBLIGS [M:ENTS]NBLIGS Order By [M:ENTS]SERNUM(indice)
        When 3 : Sorta [M:ENTS]NBLIGS [M:ENTS]NBLIGS Order By [M:ENTS]PCU(indice),[M:ENTS]QTYPCU(indice)

    Endcase
    Affzo [M:ENTS]10
Endif

End


########################################################################
# GESSELECTION : Met à jour le champ PECQTY
########################################################################
$GESSELECTION
Local Integer I

[M]PECQTY = sigma (I=0,max([M]NBLIGS-1,nolign-1),[M]QTYSTU(I)*([M]COCHAGE(I)= 2))
Affzo     [M]PECQTY

Return




