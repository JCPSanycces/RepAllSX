#<AdxTL>@(#)8.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "SETBOUT"    : Gosub SETBOUT 
Endcase
Return
############################################################
$OUVRE
If PARAM(1) = ""
  FIN = 1
Else
  If clalev([F:QLQ1]) = 0 : Local File QLYCRDQST   [QLQ1] : Endif
  If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif    # hcb V6CQ

Endif
Return
############################################################
$DEBUT
Raz [M:VQST]
#
Read [QLQ1]QLQ0=PARAM(1)
If fstat
  FIN = 1
Else
  [M:VQST] = [F:QLQ1]
  If [F:QLQ1]DEMASWTYP=1                                # hcb 48280
     [M:VQST]DEFASW=[F:QLQ1]ALPDEFASW                   # hcb 48280
  Else                                                  # hcb 48280
     [M:VQST]DEFASW=num$([F:QLQ1]NUMDEFASW)             # hcb 48280
  Endif                                                 # hcb 48280
  If [F:QLQ1]DEMCTLTYP=2
    If [F:QLQ1]DEMASWTYP=1
        [M:VQST]STRVAL=[F:QLQ1]ALPSTRVAL
        [M:VQST]ENDVAL=[F:QLQ1]ALPENDVAL
        [M:VQST]NMNVAL=[F:QLQ1]ALPNMNVAL                   # hcb V6CQ
        If  [F:QLQ1]STRVALFOR <> ""  
            Call VALTFO_CHAR(32,[F:QLQ1]STRVALFOR,[M:VQST]STRVAL) From SUBTFO
        Endif
        If  [F:QLQ1]ENDVALFOR <> ""  
            Call VALTFO_CHAR(32,[F:QLQ1]ENDVALFOR,[M:VQST]ENDVAL) From SUBTFO
        Endif
    Else
        [M:VQST]STRVAL=num$([F:QLQ1]NUMSTRVAL)
        [M:VQST]ENDVAL=num$([F:QLQ1]NUMENDVAL)
        [M:VQST]NMNVAL=num$([F:QLQ1]NUMNMNVAL)             # hcb V6CQ
        Local Decimal STRVAL 
        If  [F:QLQ1]STRVALFOR <> ""  
            Call VALTFO_NUM(32,[F:QLQ1]STRVALFOR,STRVAL) From SUBTFO
            [M:VQST]STRVAL = num$(STRVAL)
        Endif
        If  [F:QLQ1]ENDVALFOR <> ""  
            Raz STRVAL
            Call VALTFO_NUM(32,[F:QLQ1]ENDVALFOR,STRVAL) From SUBTFO
            [M:VQST]ENDVAL = num$(STRVAL)
        Endif
    Endif
  Endif
  Affzo [M:VQST]
Endif
Return
############################################################
$SETBOUT
If [M:VQST]TCT = ""
  ETABOU(GSPE1) = 0
Else
  ETABOU(GSPE1) = 1
Endif 
Return




######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUQST) 31/10/2007 16:17:45 (HCB)
######################################################################################
Subprog IB_UOM
End


