#<AdxTL>@(#)3.0.0.0 $Revision$ Copie d'un objet
Local Char PARAM(30)(1..4) , VALEUR(10)
PARAM(1) = "PBS"
PARAM(2) = "1"
PARAM(3) = ""
PARAM(4) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOPIE","ACOPIE",3,"XYACOPIE") From GTRAITE
End

$ACTION
Case BCRIT
 When "ACOPIE"
  Case ACTION
   When "INIT"
    Local Char    OBJET(250) , TABLE(250), TABLE2(250), TABLE3(250) , TABLE4(250)
    Local Integer I , J , R , ERN , NBCLE , ERF
    Local Char    PRGCOP(GLONADC) , PRGOBJ(GLONADC) , PRGWIN(GLONADC) , ERM(250)
    Local Integer ACOPMARQFLG : # Issue 86303 - 2012-12-07 by VPO
    OBJET = PARAM(1)
    TABLE = PARAM(2)
    For I=3 To dim(PARAM)
     If evalue("dim(TABLE"+num$(I-1)+")")>0
      Assign "TABLE"+num$(I-1) With PARAM(I)
     Endif
    Next I
    Call EXISTE_ADX("","","SUB"+[L]OBJET,R) From ORDSYS
    If R>0
     PRGCOP = "SUB"+[L]OBJET
     Call EXISTE_ADX("","","WO"+[L]OBJET,R) From ORDSYS
     If R>0 : PRGOBJ = "WO"+[L]OBJET : Endif
     If GBOITE<>""
      Call NOMTRTWIN(GBOITE,PRGWIN) From MSKDIV
      Call EXISTE_ADX("","",PRGWIN,R) From ORDSYS
      If R<=0 : PRGWIN = "" : Endif
     Endif
    Else
     Call EXISTE_ADX("","",[L]OBJET,R) From ORDSYS
     If R>0
      PRGCOP =[L]OBJET
     Else
      GERR = 1 : GMESSAGE = mess(12,139,1) : # Copie non réalisée
     Endif
    Endif
   When "INIT_DIA"
    Call TITOBJ([L]OBJET,"",[M]OBJET) From CONTOBJ
    If [M]OBJET=""
     [M]AUTOR = 0
    Else
     [M]AUTOR = 1
    Endif
    [M]OBJET = mess(91,123,1)-[M]OBJET : # Copie
    If dim([M]CLES)>0
     [M]CLES = TABLE
     For I=3 To dim(PARAM)
      If PARAM(I)<>"" & evalue("dim(TABLE"+num$(I-1)+")")>0
       [M]CLES += "~"+PARAM(I)
      Endif
     Next I
    Else
     [M]OBJET -= TABLE
     For I=3 To dim(PARAM)
      If evalue("dim(TABLE"+num$(I-1)+")")>0
       [M]OBJET -= PARAM(I)
      Endif
     Next I
    Endif
    If dim([M]OBJ)>0 : [M]OBJ = OBJET : Endif
    If dim([M]CLE)>0 : [M]CLE = TABLE : Endif
   When "CONTROLE"
    TMP = 1
    TIT = mess(91,123,1)-[M]DOSORG : # Copie
    If [M]TOUDOS<>2 : TIT -= mess(167,115,1)-[M]DOSDES : Endif : # vers
   When "EXEC"
    TRA = 1
    [M]AUTOR = 0
    Raz ERN , ERF , GERR , GCLE , NBCLE
    If PRGOBJ<>"" & [M]DOSORG<>nomap & PRGWIN<>""
     Gosub NOMFIC From =PRGOBJ
     If find(TYPGES,1,3)
      Onerrgo ERF
      Gosub SETCLE From =PRGOBJ
      Gosub DEFVAR From =PRGWIN
      Local File =[M]DOSORG+"."+NOMFIC [BBB_]
      If !ERF
       OK = 0
       For J=0 To NBMASK
        If ABMSK(J)<>"" & evalue("dim([M:"+ABMSK(J)+"]"+CLEPRIM+")")
         Assign "[F:BBB_]"+CLEPRIM With evalue("[M:"+ABMSK(J)+"]"+CLEPRIM)
         GCLE = num$(evalue("[M:"+ABMSK(J)+"]"+CLEPRIM))
         NBCLE += 1 : OK = 1 : Break
        Endif
       Next J
       If OK
        For I=1 To dim(CLESEC)
         If CLESEC(I-1)<>""
          If TYPGES=3 & CLESEC(I-1)=CLELIG
           Break
          Else
           OK = 0
           For J=0 To NBMASK
            If ABMSK(J)<>"" & evalue("dim([M:"+ABMSK(J)+"]"+CLESEC(I-1)+")")
             Assign "[F:BBB_]"+CLESEC(I-1) With evalue("[M:"+ABMSK(J)+"]"+CLESEC(I-1))
             GCLE += "~"+num$(evalue("[M:"+ABMSK(J)+"]"+CLESEC(I-1)))
             NBCLE += 1 : OK = 1 : Break
            Endif
           Next J
           If OK=0 : Break : Endif
          Endif
         Endif
        Next I
       Endif
       If !OK : ERF = 1 : Endif
      Endif
      If !ERF
       [G:BBB_]currlen = NBCLE
       Read [F:BBB_] =
       If fstat
        GERR = 1
        GMESSAGE = mess(85,115,1)-[M]DOSORG : # Dossier
        GMESSAGE += "\"+GCLE-":"-mess(23,100,1) : # Fiche inexistante
       Endif
      Endif
      Close Local File [BBB_]
      Onerrgo
     Endif
    Endif
    If !ERF & GERR
     FIN = 1
    Elsif [M]TOUDOS=2
     If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
     For [ADS]DOSSIER Where DOSSIER<>[M]DOSORG
      If filinfo(filpath("FIL","AOBJET","fde",[F:ADS]DOSSIER),0)>0
       Onerrgo ERF
       ERF = 0
       Local File =[F:ADS]DOSSIER+".AOBJET" [BBB_]
       Read [BBB_]ABREV = [L]OBJET
       If !fstat & [F:BBB_]NOMFIC<>"" & filinfo(filpath("FIL",[F:BBB_]NOMFIC,"fde",[F:ADS]DOSSIER),0)>0
        Local File =[F:ADS]DOSSIER+"."+[F:BBB_]NOMFIC [AAA_]
        Read [AAA_] First
       Else
        ERF = 1
       Endif
       Onerrgo
       If clalev([F:BBB_])>0 : Close Local File [BBB_] : Endif
       If clalev([F:AAA_])>0 : Close Local File [AAA_] : Endif
       If ERF=0
        [M]DOSDES = [F:ADS]DOSSIER
        Call TRTCOP([L]OBJET,TABLE,TABLE2,TABLE3,TABLE4)
       Endif
      Endif
     Next ADS
    Else
     Onerrgo ERR
     ACOPMARQFLG = 1 : # Issue 86303 - 2012-12-07 by VPO
     Gosub TRTCOP From =PRGCOP
     Gosub MARQUE_DOSS
     Onerrgo
    Endif
  Endcase
Endcase
Return

$ERF
ERF = errn
Resume

$ERR
ERN = errn
ERM = "|"+errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(ERN)-errm+"|"
If ERN=75
 # Droit d'accès à ce dossier insuffisant
 If dim([M]DOSDES)>0
  ERM = [M]DOSDES-":"-mess(149,125,1)+"\"+ERM
 Else
  ERM = mess(149,125,1)+"\"+ERM
 Endif
Endif
Call ECR_TRACE(ERM,-1) From GESECRAN
fstat = 6 : # Pour le message GLOCK
Resume

Subprog COPOBJ(DOSORG,DOSDES,OBJET,TABLE,TABLE2,TABLE3,TABLE4)
Value Char DOSORG
Value Char DOSDES
Value Char OBJET
Value Char TABLE
Value Char TABLE2
Value Char TABLE3
Value Char TABLE4
Local Mask ACOPIE [DIA_]
[M:DIA_]DOSORG = DOSORG
[M:DIA_]DOSDES = DOSDES
Call TRTCOP(OBJET,TABLE,TABLE2,TABLE3,TABLE4)
Close Local Mask [DIA_]
End

Subprog TRTCOP(OBJET,TABLE,TABLE2,TABLE3,TABLE4)
Value Char OBJET
Value Char TABLE
Value Char TABLE2
Value Char TABLE3
Value Char TABLE4
Local Integer I , J , K , R , OK , ERN
Local Char    ERM(250)
Local Integer ACOPMARQFLG : # Issue 86303 - 2012-12-07 by VPO
Call EXISTE_ADX("","","SUB"+[L]OBJET,R) From ORDSYS
If R>0
 ACOPMARQFLG = 1 : # Issue 86303 - 2012-12-07 by VPO
 Onerrgo ERR
 Gosub TRTCOP From ="SUB"+OBJET
 Gosub MARQUE_DOSS
 Onerrgo
Else
 Call EXISTE_ADX("","",[L]OBJET,R) From ORDSYS
 If R>0
  ACOPMARQFLG = 1 : # Issue 86303 - 2012-12-07 by VPO
  Onerrgo ERR
  Gosub TRTCOP From =[L]OBJET
  Gosub MARQUE_DOSS
  Onerrgo
 Else
  Call ECR_TRACE(mess(12,139,1),1) From GESECRAN : # Copie non réalisée
 Endif
Endif
End

$MARQUE_DOSS
#CHECK UNUSED_BEGIN
  # Issue 75246/10 - 2012-10-22 by VPO : marquage lors de la copie vers un dossier
  #If GSOPHIA
  # Issue 86303 - 2012-12-03 by VPO : pouvoir inhiber marquage automatique lors de la copie
  #If GSOPHIA & GOK>0 & GERR<>99
  # Issue 86303 - 2012-12-07 by VPO : ACOPMARQFLG indique si copie
  If GSOPHIA & GOK>0 & GERR<>99 & ACOPMARQFLG
   Local Char CLE1(80), CLE2(80)(0..16)
   If TABLE2<>""
     CLE1=TABLE2
     CLE2(0)=TABLE
     CLE2(1)=TABLE3
     CLE2(2)=TABLE4
   Else
     CLE1=TABLE
   Endif
   If dim([M]DOSDES)<=0 & dim([L]DOS_DES)>0
     # Issue 86825 - 2012-12-20 by VPO
     #Call TRACE_COR_DOSS([L]DOS_DES,[L]OBJET,CLE1,CLE2,"M") From SUBXCB
     Call TRACE_COR_DOSS([L]DOS_DES,[L]OBJET,CLE1,CLE2,"M")
   Else
     # Issue 86825 - 2012-12-20 by VPO
     #Call TRACE_COR_DOSS([M]DOSDES,[L]OBJET,CLE1,CLE2,"M") From SUBXCB
     Call TRACE_COR_DOSS([M]DOSDES,[L]OBJET,CLE1,CLE2,"M")
   Endif
  Endif
#CHECK UNUSED_END
Return

#################################################################################
# Issue 75246/10 - 2012-10-22 by VPO : marquage lors de la copie vers un dossier
# (peut-être autre version)
#################################################################################
Subprog TRACE_COR_DOSS(DOSDES,OBJET,CLE1,CLE2,MAJ)
Value Char DOSDES
Value Char OBJET
Value Char CLE1
Value Char CLE2()(0..)
Value Char MAJ

#If GSOPHIA
# Issue 86303 - 2012-12-03 by VPO : pouvoir inhiber marquage automatique lors de la copie
If GSOPHIA & GOK>0 & GERR<>99

  If !func OKOBJMARQUAGE(OBJET,CLE1)
   End
  Endif


  Local Char MAC1(GDIMFIC), APP1(GDIMFIC),VOL1(20)
  Call MACHINE(DOSDES,MAC1,APP1) From ORDSYS
  Call VOLUME(MAC1,DOSDES,VOL1) From ORDSYS

  If !func OKMARQUAGE(APP1)
   End
  Endif


  If filinfo(filpath("FIL","XXCORT","fde",APP1,VOL1,MAC1),0)<=0
   End
  Endif

  Gosub MARQUAGE_EXT

Endif

End

#######################################################################
Funprog OKMARQUAGE(DOSS)
Value Char DOSS
If find(DOSS,"GX3APP","PAIEV6","GXDEV","X3DEV","X3DEVV7","FOLDEV")
 End 1
Endif
End 0

#######################################################################
Funprog OKOBJMARQUAGE(OBJET,CODE)
Value Char OBJET,CODE
Local Integer NOK
# JML 07/12/2000, on ne marque plus le dictionnaire commençant par W,Y,Z !
NOK  = find(left$(CODE,1),"Y","Z")
NOK += left$(CODE,1)="W" & find(OBJET,"AWI","AMK")
NOK += (OBJET="AWI" & find(left$(CODE,2),"OY","OZ"))
NOK += (OBJET="ADC" & find(CODE,"XXVALDICO","XVALDICO","YVALDICO","ZVALDICO"))
End !NOK

###########################################################################
### Procédure de Lancement du Marquage dans dossier destination (peut-être autre version)
###########################################################################
$MARQUAGE_EXT
    #VPO 04/10/13
    #Local Char    DES_USR (GLONAUS), DES_PASS(50), DES_LAN(GLONLAN), OPADXD_MESS (250)
    Local Char    DES_USR (GLONALO), DES_PASS(50), DES_LAN(GLONLAN), OPADXD_MESS (250)
    Local Integer DES_TYPDOS, OPADXD_OPEN, I

    If [L]DOSDES=nomap
      Local File AUTILIS   [AUSZ]
    Else
      Local File =[L]DOSDES+".AUTILIS"   [AUSZ]
    Endif
    #VPO 04/10/13
    #[L]DES_USR=GUSER
    [L]DES_USR=adxusr
    [L]DES_LAN=GLANGUE

    # Lecture de l'utilisateur courant dans le dossier DESTINATION afin de récupérer son mot de passe
    #VPO 04/10/13
    #Read [AUSZ]CODUSR=[L]DES_USR
    Read [AUSZ]LOGIN=toupper([L]DES_USR)
    If fstat
      Call ERREUR(func AFNC.MES1 (mess(106,176,1), DOSDES)+"\"+func AFNC.MES1 (mess(107,176,1), [L]DES_USR)) From GESECRAN
      End
    Endif
    If dim([F:AUSZ]NEWPAS)>0 : # nouveau cryptage
      [L]DES_PASS=[F:AUSZ]NEWPAS
      # Issue 86058 - 2012-11-20 by VPO
      If [L]DES_PASS<>""
        Call VARPSE([L]DES_PASS) From GESUSER
      Endif
    Else
      Call DECRYPTO("CRYPT:"+[F:AUSZ]PASSE,[L]DES_PASS) From GESUSER
    Endif

    # Ouverture du Canal de communication vers le Dossier Destination
    If [L]DOSDES=nomap
     Call TRACE_COR(OBJET,CLE1,CLE2,[L]MAJ) From SUBXCB
    Else
    Gosub OPADXD_SUPERV_OPEN
    If GERR     :  Call ERREUR (func AFNC.MES1 (mess(106,176,1), DOSDES)+"\"+mess(108,176,1)-[L]OPADXD_MESS) From GESECRAN : End : Endif
    Gosub OPADXD_MARQUAGE
    If GERR : Call ERREUR (func AFNC.MES1 (mess(106,176,1), DOSDES)+"\"+mess(109,176,1)-[L]OPADXD_MESS)  From GESECRAN : Endif
    Gosub OPADXD_CLOSE
    Endif
Return

$OPADXD_SUPERV_OPEN
  [L]OPADXD_OPEN=0
  Gosub    OPADXD_OPEN
  If GERR & [L]OPADXD_OPEN
    Gosub OPADXD_CLOSE
    Gosub OPADXD_OPEN
  Endif
Return

$OPADXD_OPEN
  Raz GERR :  Raz [L]OPADXD_MESS : # Issue 86303 - 2012-12-03 by VPO
  Onerrgo  ERR_OPADXD
  Opadxd [L]MAC1 With [L]APP1, [L]DES_LAN, [L]DES_USR, [L]DES_PASS Using [EXT]
  Onerrgo
Return

$OPADXD_MARQUAGE
  Onerrgo  ERR_OPADXD
  Calliu "SUBXCB:TRACE_COR"  With OBJET,CLE1,CLE2,[L]MAJ  Using [EXT]
  Onerrgo
Return

$OPADXD_CLOSE
  Opadxd Using [EXT]
Return

$ERR_OPADXD
  # erreur 126 : canal en cours utilisation il faut fermer avant
  If errn=126 & ![L]OPADXD_OPEN : # Canal en cours d'utilisation (consécutif à un plantage précédent du TRT...)
    GERR = 1  :  [L]OPADXD_OPEN=1
  Else
    GERR = 1  :  [L]OPADXD_MESS=errmes$(errn)-string$(errm<>errmes$(errn),errm)+"\"+errp+"("+num$(errl)+")"
  Endif
Resume

Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
End

Subprog AV_DOSORG(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = nomap
 GMODIF = 0
 [M]DOSORG = VALEUR
Endif
Gosub GRISE_TOUDOS
Gosub GRISE_DOSDES
End

$GRISE_TOUDOS
If dim([M]TOUDOS)>0
 If [M]AUTOR<>1 or instr(1,[M]DOSORG,"@")>0
  [M]TOUDOS = 1
  Affzo TOUDOS
  Grizo TOUDOS
 Else
  Actzo TOUDOS
 Endif
Endif
Return

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

Subprog AM_DOSORG(VALEUR)
Variable Char  VALEUR
[M]DOSORG = VALEUR
Gosub GRISE_TOUDOS
Gosub GRISE_DOSDES
End

$GRISE_DOSDES
If dim([M]TOUDOS)>0 & [M]TOUDOS=2
 [M]DOSDES = ""
 Affzo DOSDES
 Diszo DOSDES
Else
 Actzo DOSDES
Endif
Return

Subprog AS_TOUDOS(VALEUR)
Variable Integer VALEUR
End

Subprog AM_TOUDOS(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Local File ADOSSIER [ADSX]
 For [ADSX] Where DOSSIER<>[M]DOSORG
  Call CTL_DROIT_DOSSIER([F:ADSX]DOSSIER,"E") From DOSCONT
  If mkstat
   GMESSAGE = [F:ADSX]DOSSIER+"\"+GMESSAGE
   Break
  Endif
 Next ADSX
 Close Local File
 If mkstat : End : Endif
Endif
[M]TOUDOS = VALEUR
Gosub GRISE_DOSDES
End

Subprog IB_DOSDES
Raz GBOUT2
If dim([M]OBJ)>0
&& find([M]OBJ,"AMK","AWI","AOB","AOC","AFC","ACT","ATY","ATB","ADI","AST","ARP","ACN","ADC","TRT","AML")
 GBOUT2 = mess(81,126,1) : # Différence
Endif
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
If dim([M]TOUDOS)>0 & [M]TOUDOS=2 : mkstat = 1 : End : Endif
If GDOSPATH="" : End : Endif
Call C_DOSSIER(GDOSPATH) From DOSCONT
If mkstat
 mkstat = 0
Else
 VALEUR = GDOSPATH
Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call DOSORGDES([M]DOSORG,VALEUR) From DOSCONT
If mkstat : End : Endif
Gosub CTL_COP_FILIALES
If mkstat : End : Endif
GDOSPATH = VALEUR
End

$CTL_COP_FILIALES
# interdire le bouton copie pour les filiales
# sur les dossiers autre que demo et ref

If GSOPHIA
   Gosub DEFVAR From AGLOBTRAD
   Local Shortint ILAN
   Local Shortint WINDICE
   For ILAN=1 To GNBLANSTD
      If GUSER=GUSRLAN(ILAN)
        If GUSER = GUSRLAN (1)
            # on autorise la copie de reffra sur les refspa et tstlan
            If nomap = GREFFRA (ILAN)
                WINDICE = find (VALEUR, GDEMOF(2..GNBLANSTD))
                If WINDICE = 0
                    WINDICE = find (VALEUR, GREFER(2..GNBLANSTD))
                    If WINDICE = 0
                            mkstat =2
                    Endif
                Endif
            Endif
        Else
            If  nomap=GREFER(ILAN)
                If VALEUR <> GDEMOF(ILAN)
                    mkstat = 2
                Endif
            Elsif nomap=GDEMOF(ILAN)
                If VALEUR <> GREFER(ILAN)
                    mkstat = 2
                Endif
            Endif
          Endif
        Endif
   Next ILAN
   If mkstat
             GMESSAGE = "you could not copy on this folder"
             Return
   Endif

Endif
Return

