#<AdxTL>@(#)0.0.0.0 $Revision$Class Protocol
# Supervisor
## ACLA-CLASSE ## EDIPTC
# 2018-11-06 07:04:56 452


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : PTCCOD Protocol ( Field PTC 20)
####################################################################

$SET_PTCCOD
If [L]_AOLDVAL<>this.PTCCOD
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_PTCCOD
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.PTCCOD
 Gosub PROPAGATE_PTCCOD
Endif
Return

$INIT_PTCCOD
Gosub DECLARE_VAR From WMC0EDIPTC
[L]CURPRO = "PTCCOD"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_PTCCOD
Gosub DECLARE_VAR From WMC0EDIPTC
[L]CURPRO = "PTCCOD"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_PTCCOD                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_PTCCOD                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_PTCCOD
[L]CURPRO = "PTCCOD"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.PTCCOD,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_PTCCOD
[L]CURPRO = "PTCCOD"
If vireblc(this.PTCCOD,2)<>vireblc(format$("K:20c",this.PTCCOD),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_PTCCOD
[L]CURPRO = "PTCCOD"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_PTCCOD
[L]CURPRO = "PTCCOD"
Return

$PROPAGATE_PTCCOD
this.isReadonly = 0
[L]CURPRO = "PTCCOD"
Gosub _LNKPRO_PTCCOD
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_PTCCOD
Gosub DECLARE_VAR From WMC0EDIPTC
[L]CURPRO = "PTCCOD"
$_LNKPRO_PTCCOD
If vireblc(this.PTCCOD,2)<>""
 # Link EDIPTC
 Local File EDIPTC [WEPT]
 Read [F:WEPT]EPT0 = this.PTCCOD
 If !fstat
  [L]ASTATUS = fmet this.ASETATTRIBUTE("PTCCOD","$title",[F:WEPT]PTCDES)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("PTCCOD","$description",[F:WEPT]PTCDES)
 Endif
 LogicClose File [WEPT]
Endif
Return

$_ALOADATTRIBUTE_PTCCOD
[L]ASTATUS = fmet this.ASETATTRIBUTE("PTCCOD","$isMandatory","true")
Return


####################################################################
# 2 : PTCTYP Protocol type ( Field Local menu number 2008)
####################################################################

$SET_PTCTYP
If [L]_AOLDVAL<>this.PTCTYP
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_PTCTYP
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.PTCTYP
 Gosub PROPAGATE_PTCTYP
Endif
Return

$INIT_PTCTYP
Gosub DECLARE_VAR From WMC0EDIPTC
[L]CURPRO = "PTCTYP"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.PTCTYP=0 and fmet this.AGETATTRIBUTE("PTCTYP","$isMandatory")="true"
 this.PTCTYP = 1
Endif
Return
 
$CONTROL_PTCTYP
Gosub DECLARE_VAR From WMC0EDIPTC
[L]CURPRO = "PTCTYP"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_PTCTYP                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_PTCTYP                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_PTCTYP
[L]CURPRO = "PTCTYP"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.PTCTYP=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_PTCTYP
[L]CURPRO = "PTCTYP"
If this.PTCTYP<0 or this.PTCTYP>len(mess(0,2008,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"2008 ->"-num$(this.PTCTYP)-mess(99,123,1)):  Return : # Local menu "2008 -> Invalid option
Endif
Return

$_AOTHERS_PTCTYP
[L]CURPRO = "PTCTYP"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_PTCTYP
[L]CURPRO = "PTCTYP"
Return

$PROPAGATE_PTCTYP
this.isReadonly = 0
[L]CURPRO = "PTCTYP"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_PTCTYP
Gosub DECLARE_VAR From WMC0EDIPTC
[L]CURPRO = "PTCTYP"
$_LNKPRO_PTCTYP
Return

$_ALOADATTRIBUTE_PTCTYP
[L]ASTATUS = fmet this.ASETATTRIBUTE("PTCTYP","$isMandatory","true")
Return


