If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.VALID=0 and fmet this.AGETATTRIBUTE("VALID","$isMandatory")="true"
 this.VALID = 1
Endif
Return
 
$CONTROL_VALID
Gosub DECLARE_VAR From WMC0EDIPTC
[L]CURPRO = "VALID"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_VALID                 : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_VALID                 : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_VALID
[L]CURPRO = "VALID"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.VALID=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_VALID
[L]CURPRO = "VALID"
If this.VALID<0 or this.VALID>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.VALID)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_VALID
[L]CURPRO = "VALID"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_VALID
