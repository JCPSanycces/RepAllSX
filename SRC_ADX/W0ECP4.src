# Gestion du masque ECP4 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBREVA
mkstat = 0
zoncou = "NBREVA"
indice = 0
status = 1
zoncou = "NBREVA"
If varmode([M]NBREVA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBREVA" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBREVA
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBREVA = nolign
   status = 75
   Call SAI_NBREVA(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone WEVATYP
mkstat = 0
zoncou = "WEVATYP"
indice = 0
If varinit([M]WEVATYP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]WEVATYP,"10360","") From SUBADI
 GACTION = SAVACT
Endif

## Zone WFLGYEA
mkstat = 0
zoncou = "WFLGYEA"
indice = 0
IMPENT = [M]WFLGYEA
If varinit([M]WFLGYEA,indice)=0
 IMPENT = 1
Endif
[M]WFLGYEA = IMPENT

## Zone WFLGPRO
mkstat = 0
zoncou = "WFLGPRO"
indice = 0
IMPENT = [M]WFLGPRO
If varinit([M]WFLGPRO,indice)=0
 IMPENT = 1
Endif
[M]WFLGPRO = IMPENT

## Zone WFLGBIL
mkstat = 0
zoncou = "WFLGBIL"
indice = 0
IMPENT = [M]WFLGBIL
If varinit([M]WFLGBIL,indice)=0
 IMPENT = 1
Endif
[M]WFLGBIL = IMPENT

## Zone WNEXEVA
mkstat = 0
zoncou = "WNEXEVA"
indice = 0
If varmode([M]WNEXEVA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WNEXEVA" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone WEVAMAT
mkstat = 0
zoncou = "WEVAMAT"
indice = 0
WCHAR = [M]WEVAMAT
If varmode([M]WEVAMAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEVAMAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DROITEMP"
 Call DROIT([M]WEVAMAT,"","","") From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WEVAMAT" : GZNUM = 1001508 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EML","!",[M]WEVAMAT,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "WEVAMAT" : GZNUM = 1001508 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]WEVAMAT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_WEVAMAT([M]WEVAMAT) From SUBECP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WEVAMAT" : GZNUM = 1001508 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone WEVAMATLIB
mkstat = 0
zoncou = "WEVAMATLIB"
indice = 0
If varmode([M]WEVAMATLIB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEVAMATLIB" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone WEVAPOT
mkstat = 0
zoncou = "WEVAPOT"
indice = 0
If varmode([M]WEVAPOT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEVAPOT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("POT","!",[M]WEVAPOT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "WEVAPOT" : GZNUM = 22321 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone WEVAJOB
mkstat = 0
zoncou = "WEVAJOB"
indice = 0
If varmode([M]WEVAJOB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEVAJOB" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("JOT","!",[M]WEVAJOB,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "WEVAJOB" : GZNUM = 45853 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone WEVAJOBGRP
mkstat = 0
zoncou = "WEVAJOBGRP"
indice = 0
If varinit([M]WEVAJOBGRP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]WEVAJOBGRP,"10460","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]WEVAJOBGRP,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "WEVAJOBGRP" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]WEVAJOBGRP,"10460","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WEVAJOBGRP" : GZNUM = 11105 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]WEVAJOBGRP,"10460",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "WEVAJOBGRP" : GZNUM = 11105 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone WEVAJOBGRPDA
mkstat = 0
zoncou = "WEVAJOBGRPDA"
indice = 0
If varmode([M]WEVAJOBGRPDA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEVAJOBGRPDA" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone WFLGMOB
mkstat = 0
zoncou = "WFLGMOB"
indice = 0
IMPENT = [M]WFLGMOB
WNUM = IMPENT
If varinit([M]WFLGMOB,indice)=0
 IMPENT = 1
Endif
If varmode([M]WFLGMOB,indice)=0
 [M]WFLGMOB(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WFLGMOB" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WFLGMOB(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_WFLGMOB(IMPENT) From SUBECP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WFLGMOB" : GZNUM = 47503 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]WFLGMOB = IMPENT

## Zone WEVAFCY
mkstat = 0
zoncou = "WEVAFCY"
indice = 0
If varmode([M]WEVAFCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEVAFCY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]WEVAFCY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WEVAFCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!",[M]WEVAFCY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "WEVAFCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone WARE
mkstat = 0
zoncou = "WARE"
indice = 0
If varinit([M]WARE,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]WARE,"10465","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]WARE,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "WARE" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]WARE,"10465","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WARE" : GZNUM = 1812 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]WARE,"10465",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "WARE" : GZNUM = 1812 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone WAREDAT
mkstat = 0
zoncou = "WAREDAT"
indice = 0
If varmode([M]WAREDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WAREDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone WFLGACTFOR
mkstat = 0
zoncou = "WFLGACTFOR"
indice = 0
IMPENT = [M]WFLGACTFOR
If varinit([M]WFLGACTFOR,indice)=0
 IMPENT = 1
Endif
If varmode([M]WFLGACTFOR,indice)=0
 [M]WFLGACTFOR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WFLGACTFOR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WFLGACTFOR(indice)
 Endif
Endif
[M]WFLGACTFOR = IMPENT

## Zone WFLGCERTIF
mkstat = 0
zoncou = "WFLGCERTIF"
indice = 0
IMPENT = [M]WFLGCERTIF
If varinit([M]WFLGCERTIF,indice)=0
 IMPENT = 1
Endif
If varmode([M]WFLGCERTIF,indice)=0
 [M]WFLGCERTIF(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WFLGCERTIF" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WFLGCERTIF(indice)
 Endif
Endif
[M]WFLGCERTIF = IMPENT

## Zone WFLGEVO
mkstat = 0
zoncou = "WFLGEVO"
indice = 0
IMPENT = [M]WFLGEVO
If varinit([M]WFLGEVO,indice)=0
 IMPENT = 1
Endif
If varmode([M]WFLGEVO,indice)=0
 [M]WFLGEVO(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WFLGEVO" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WFLGEVO(indice)
 Endif
Endif
[M]WFLGEVO = IMPENT

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

indice = 0
status = 1
zoncou = "NBREVAD"
If !mkstat
 NBLIG = [M]NBREVAD
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBREVAD = nolign
  status = 75
  Call SAI_NBREVAD(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBREVA(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBREVA
mkstat = 0
zoncou = "NBREVA"

## Zone EVATYP
mkstat = 0
zoncou = "EVATYP"
WCHAR = [M]EVATYP(indice)
If varinit([M]EVATYP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]EVATYP(indice),"10360","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]EVATYP,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "EVATYP" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]EVATYP(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]EVATYP(indice),"10360","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]EVATYP(indice),"10360",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]EVATYP(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_EVATYP([M]EVATYP(indice)) From SUBECP
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone EVADATSTR
mkstat = 0
zoncou = "EVADATSTR"
WDATE = [M]EVADATSTR(indice)
If varmode([M]EVADATSTR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EVADATSTR" : Gosub ACTION From =IMPTRT
 Endif
 If [M]EVADATSTR(indice)=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "EVADATSTR" : GZNUM = 51967 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WDATE<>[M]EVADATSTR(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_EVADATSTR([M]EVADATSTR(indice)) From SUBECP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "EVADATSTR" : GZNUM = 51967 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone EVADATEND
mkstat = 0
zoncou = "EVADATEND"
WDATE = [M]EVADATEND(indice)
If varmode([M]EVADATEND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EVADATEND" : Gosub ACTION From =IMPTRT
 Endif
 If [M]EVADATEND(indice)=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "EVADATEND" : GZNUM = 51970 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DATDEBFIN"
  Call DATDEBFIN([M]EVADATEND(indice),[M]EVADATSTR(nolign-1)) From EXEFNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "EVADATEND" : GZNUM = 51970 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WDATE<>[M]EVADATEND(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_EVADATEND([M]EVADATEND(indice)) From SUBECP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "EVADATEND" : GZNUM = 51970 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone FLGYEA
mkstat = 0
zoncou = "FLGYEA"
IMPENT = [M]FLGYEA(indice)
If varinit([M]FLGYEA,indice)=0
 IMPENT = 1
Endif
[M]FLGYEA(indice) = IMPENT

## Zone FLGPRO
mkstat = 0
zoncou = "FLGPRO"
IMPENT = [M]FLGPRO(indice)
If varinit([M]FLGPRO,indice)=0
 IMPENT = 1
Endif
[M]FLGPRO(indice) = IMPENT

## Zone FLGBIL
mkstat = 0
zoncou = "FLGBIL"
IMPENT = [M]FLGBIL(indice)
If varinit([M]FLGBIL,indice)=0
 IMPENT = 1
Endif
[M]FLGBIL(indice) = IMPENT

## Zone NEXEVA
mkstat = 0
zoncou = "NEXEVA"
If varmode([M]NEXEVA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NEXEVA" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone EVAJOBGRP
mkstat = 0
zoncou = "EVAJOBGRP"
If varinit([M]EVAJOBGRP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]EVAJOBGRP(indice),"10460","") From SUBADI
 GACTION = SAVACT
Endif

## Zone FLGMOB
mkstat = 0
zoncou = "FLGMOB"
IMPENT = [M]FLGMOB(indice)
If varinit([M]FLGMOB,indice)=0
 IMPENT = 1
Endif
[M]FLGMOB(indice) = IMPENT

## Zone ARE
mkstat = 0
zoncou = "ARE"
If varinit([M]ARE,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]ARE(indice),"10465","") From SUBADI
 GACTION = SAVACT
Endif

## Zone EVAVAL
mkstat = 0
zoncou = "EVAVAL"
IMPENT = [M]EVAVAL(indice)
If varinit([M]EVAVAL,indice)=0
 IMPENT = 1
Endif
[M]EVAVAL(indice) = IMPENT

## Zone FLGACTFOR
mkstat = 0
zoncou = "FLGACTFOR"
IMPENT = [M]FLGACTFOR(indice)
If varinit([M]FLGACTFOR,indice)=0
 IMPENT = 1
Endif
[M]FLGACTFOR(indice) = IMPENT

## Zone FLGCERTIF
mkstat = 0
zoncou = "FLGCERTIF"
IMPENT = [M]FLGCERTIF(indice)
If varinit([M]FLGCERTIF,indice)=0
 IMPENT = 1
Endif
[M]FLGCERTIF(indice) = IMPENT

## Zone FLGEVO
mkstat = 0
zoncou = "FLGEVO"
IMPENT = [M]FLGEVO(indice)
If varinit([M]FLGEVO,indice)=0
 IMPENT = 1
Endif
[M]FLGEVO(indice) = IMPENT

## Zone NBREVA
mkstat = 0
zoncou = "NBREVA"

End

