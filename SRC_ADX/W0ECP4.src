Subprog SAI_NBREVAD(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1


## Zone DEVATYP
mkstat = 0
zoncou = "DEVATYP"
If varmode([M]DEVATYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DEVATYP" : Gosub ACTION From =IMPTRT
 Endif
