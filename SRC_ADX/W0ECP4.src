## Zone DEVADATEND
mkstat = 0
zoncou = "DEVADATEND"
If varmode([M]DEVADATEND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DEVADATEND" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DEVADAT
mkstat = 0
zoncou = "DEVADAT"
If varmode([M]DEVADAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DEVADAT" : Gosub ACTION From =IMPTRT
 Endif
Endif


End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ECP4"
Return

