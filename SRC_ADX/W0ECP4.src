## Zone DEVADATSTR
mkstat = 0
zoncou = "DEVADATSTR"
If varmode([M]DEVADATSTR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DEVADATSTR" : Gosub ACTION From =IMPTRT
