#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modification :
#     SEGAY - 20/03/12 - FQ80844 -
#       Sous programme GETLSTCCG problème d'initialisation de mkstat
#     SEGAY - 03/04/12 - FQ81317 -
#      Critere sur TIM NOK
#      Manque le link sur CODACC
#      On ne fait pas de test sur TYPCP car coté X3 on peut saisir les deux CPA et CPE
#     FQ85820 - 12/11/12 - prise en compte date d'effet + fiches de rétroactivité
#     SEGAY - 23/04/13 - FQ88082 - Test ACS de TIM
#     SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
######################################################################################

###############################################################
## Solde des congés avec les demandes de congés non validées
###############################################################

Subprog SUICNG(MATRICULE,CONTRAT,CTRNUM,TIM,LIBEL,YEA,ACQ,PRI,SLD,DATDEB,DATFIN,ATT,DATSEL,VLD,CTRDAT)
Value    Char    MATRICULE(), CONTRAT()
Variable Date    DATSEL
Variable Char    CTRNUM()(0..), TIM()(0..), LIBEL()(0..)
Variable Decimal ACQ(0..), PRI(0..), SLD(0..), ATT(0..), VLD(0..)
Variable Integer YEA(0..)
Variable Date    DATDEB(0..), DATFIN(0..)
Variable Date    CTRDAT(0..) : # FQ89905 - SEGAY 23/05/13 Test sur date contrat

Local    Date    DT
Local    Date    WDATDEB : # FQ89905 - SEGAY 23/05/13 Test sur date contrat
Local    Char    CPY(GLONCPY),CODCUM(GLONCUM),TIM_CNG(GLONTPS)(0..dim(TIM))
Local    Decimal ATT_EXCED(0..dim(ATT)) , VLD_EXCED(0..dim(ATT))
Local    Decimal ATT_TOLER(0..dim(ATT)) , VLD_TOLER(0..dim(ATT))
Local    Decimal SLD_TMP

Local    Integer WYEA(0..10)
Local    Decimal WACQ(0..10), WPRI(0..10), WVLD(0..10), WATT(0..10), WSLD(0..10)
Local    Decimal WSLDMIN   : # 66076

Local    Integer I,N,XD

# FQ88082 - SEGAY 23/04/13 test ACS de TIM
Local Char     CRITERE1  (250)
Local Integer  STAT
# END FQ88082

# FQ76178 - SEGAY 18/09/13 - Test sur TYPCP
Local Integer WOK
Local Char WTIM(GLONTPS),WCPA(GLONTPS),WCPE(GLONTPS)
Call PARAM("","CPA",WCPA) From ADOVAL
Call PARAM("","CPE",WCPE) From ADOVAL
[L]WTIM =[L]TIM
# END 76178

Raz GMESSAGE

If [V]GFONCTION<>"CONSCNG"
 [V]GFONCTION="CONSCNG"
 Call AUTORIS From EXEFNC
Endif

Onerrgo ERREUR : # 67776

If !clalev([F:CNG])  : Local File CNGCPY    [CNG]  : Endif
If !clalev([F:DCG])  : Local File DEMCONGE  [DCG]  : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRCTR])  : Local File EMPLOCTR  [HRCTR]  : Endif
If !clalev([F:HRCTRG]) : Local File EMPLOCTR  [HRCTRG] : Endif
#If !clalev([F:CTR])  : Local File EMPLOCTR  [CTR]  : Endif
#If !clalev([F:CTRG]) : Local File EMPLOCTR  [CTRG] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If !clalev([F:TIM])  : Local File TIMCOD    [TIM]  : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRPEOD])  : Local File HRPEODET    [HRPEOD]  : Endif
#If !clalev([F:PEO])  : Local File PERIOD    [PEO]  : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If !clalev([F:FCY])  : Local File FACILITY  [FCY]  : Endif
If !clalev([F:HSP])  : Local File HISTOPAYE [HSP]  : Endif
If !clalev([F:TIP])  : Local File TIMEMP    [TIP] : Endif
If !clalev([F:TIG])  : Local File TIMREGUL  [TIG] : Endif

#JASMI - 2014-09-22 - US2983 - START
#MIPEA - 2017-06-07- US X3-43919- START
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2017-06-07- US X3-43919- END
  If !clalev([F:CNE])  : Local File CNGEMP    [CNE]  : Endif
Endif
#JASMI - 2014-09-22 - US2983 - END

# FQ88082 - SEGAY 23/04/13 test ACS de TIM
#Link [CNG] With [TIM]TIM0=TIM As [LNK] Order By Key CNG0
If !clalev([F:ACC])  : Local File ACCES  [ACC] : Endif
CRITERE1  = "1=1"
If GUSRACS<>2
    CRITERE1 -= '& ([F:TIM]ACS="" | [F:ACC]CONSUL=2 | [F:ACC]EXEC=2)'
Endif
#MIPEA - 2017-06-07- US X3-43919- START
Link [CNG] With [TIM]TIM0=GCURLEG;TIM
&   , [F:ACC]CODACC   = GUSER;[F:TIM]ACS
&    As [LNK]
&    Where evalue (CRITERE1)
&    Order By Key CNG0
#Link [CNG] With [TIM]TIM0=TIM
#&   , [F:ACC]CODACC   = GUSER;[F:TIM]ACS
#&    As [LNK]
#&    Where evalue (CRITERE1)
#&    Order By Key CNG0
#MIPEA - 2017-06-07- US X3-43919- END
# END FQ88082

Call GETDATPAY(MATRICULE,CONTRAT,DT) From PORDCG  : # init GMOIPAY (ici DT ne sert pas)

# FQ89905 - SEGAY 23/05/13 Test sur date contrat
#If DATSEL = [00/00/0000] or DATSEL > GMOIPAY  : # pas le futur
# DATSEL = GMOIPAY
#Endif
If DATSEL = [00/00/0000] or DATSEL > eomonth(GMOIPAY)  : # Fin de mois de GMOIPAY pour être en phase avec contrôle back office
 DATSEL =  eomonth(GMOIPAY)
Endif
DT=DATSEL
# FQ82413 - MABON 04/06/12 - Calcul de DATSEL avant de faire la boucle For sur LNK
I=0
# FQ87044 - SEGAY 07/01/13 - [F:CTR] alimenté par GETDATPAY
#Call CADRE_PYRDAT(DATSEL,[F:CTRG]ETRFCY) From TPSSUB
#While DATSEL > DT & !mkstat
# # On cherche la plus proche date de paie antérieure à la date sélectionnée
# I+=1
# DATSEL = DT - I
# Call CADRE_PYRDAT(DATSEL,[F:CTRG]ETRFCY) From TPSSUB
#Wend
mkstat=0
#MIPEA - 2017-06-07- US X3-43919- START
Call CADRE_PYRDAT(DATSEL,[F:HRCTR]PERCOD) From TPSSUB
#Call CADRE_PYRDAT(DATSEL,[F:CTR]ETRFCY) From TPSSUB
#MIPEA - 2017-06-07- US X3-43919- END
While DATSEL > DT & !mkstat
 # On cherche la plus proche date de paie antérieure à la date sélectionnée
 I+=1
 DATSEL = DT - I
#MIPEA - 2017-06-07- US X3-43919- START
 Call CADRE_PYRDAT(DATSEL,[F:HRCTR]PERCOD) From TPSSUB
# Call CADRE_PYRDAT(DATSEL,[F:CTR]ETRFCY) From TPSSUB
#MIPEA - 2017-06-07- US X3-43919- END
Wend
#MIPEA - 2017-06-07- US X3-43919- START
WDATDEB = [F:HRPEOD]PERSTR(0)
#WDATDEB = [F:PEO]PERSTR(0) : # FQ89905 - date debut de période. A utiliser dans criteres de sélection des contrats
#MIPEA - 2017-06-07- US X3-43919- END
Raz mkstat
# Fin MABON

Local Integer CREAGLOB
Gosub INIT_CHECK_SUBORD From DIVPAYE


I=0

#For [CTRG]CTR0(2) Where REFNUM=[L]MATRICULE & (CTRNUM=[L]CONTRAT | [L]CONTRAT="")
# FQ89905 - SEGAY 23/05/13 Test sur date contrat
#MIPEA - 2017-06-07- US X3-43919- START
For [HRCTRG]CTR0 Where REFNUM=[L]MATRICULE & (CTRNUM=[L]CONTRAT | [L]CONTRAT="")

 If [F:FCY]FCY <> [F:HRCTRG]ETRFCY
  Call LECTURE("FCY",[F:HRCTRG]ETRFCY,"") From CONTOBJ : # recherche société
 Endif
 # FQ89905 - SEGAY 23/05/13 Test sur date contrat
 If ([F:HRCTRG]CTRDAT<= [L]DATSEL | ([F:HRCTRG]FLGRET=2 & [F:HRCTRG]RETDATEFF<=[L]DATSEL))
&   & ([F:HRCTRG]XITDAT=[0/0/0] | [F:HRCTRG]XITDAT>= [L]WDATDEB) Then

#Périodes congés évt dont la date reçue en critère est
# dans la période d'acquisition (N-1) ou de tolérance (N) et choix 'Affichage solde' sur evt

#JASMI - 2014-09-26 - US2983 - START
 If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
  Link [CNG]  With  [TIM]TIM0      =  GCURLEG;[F:CNG]TIM
&                 , [F:ACC]CODACC  =  GUSER; [F:TIM]ACS
&                 , [F:CNE]CNE0    ~= [F:CNG]YEA; [F:HRCTRG]REFNUM;[F:HRCTRG]CTRNUM ; [F:CNG]TIM
&             As    [LNK]
&             Where evalue (CRITERE1)
&             Order By Key CNG0
 Endif
#For [CTRG]CTR0 Where REFNUM=[L]MATRICULE & (CTRNUM=[L]CONTRAT | [L]CONTRAT="")
#
# If [F:FCY]FCY <> [F:CTRG]ETRFCY
#  Call LECTURE("FCY",[F:CTRG]ETRFCY,"") From CONTOBJ : # recherche société
# Endif
# # FQ89905 - SEGAY 23/05/13 Test sur date contrat
# If ([F:CTRG]CTRDAT<= [L]DATSEL | ([F:CTRG]FLGRET=2 & [F:CTRG]RETDATEFF<=[L]DATSEL))
#&   & ([F:CTRG]XITDAT=[0/0/0] | [F:CTRG]XITDAT>= [L]WDATDEB) Then
#
##Périodes congés évt dont la date reçue en critère est
## dans la période d'acquisition (N-1) ou de tolérance (N) et choix 'Affichage solde' sur evt
#
##JASMI - 2014-09-26 - US2983 - START
# If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#  Link [CNG]  With  [TIM]TIM0      =  [F:CNG]TIM
#&                 , [F:ACC]CODACC  =  GUSER; [F:TIM]ACS
#&                 , [F:CNE]CNE0    ~= [F:CNG]YEA; [F:CTRG]REFNUM;[F:CTRG]CTRNUM ; [F:CNG]TIM
#&             As    [LNK]
#&             Where evalue (CRITERE1)
#&             Order By Key CNG0
# Endif
#MIPEA - 2017-06-07- US X3-43919- END
#JASMI - 2014-09-26 - US2983 - END

#JASMI - 2014-09-22 - US2983 - START
# For [LNK]    Where   [F:CNG]CPY = [F:FCY]LEGCPY
#&                & (( [F:CNG]STRPER <= DATSEL & DATSEL <= [F:CNG]ENDPER )
#&                 | ( [F:CNG]DEBDAT <= DATSEL & DATSEL <= [F:CNG]FINDAT ))
#&                &    [F:TIM]DSPSLD = 2
 Local Char     CRITERIA(150)
#MIPEA - 2017-06-07- US X3-43919- START
 If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
# If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2017-06-07- US X3-43919- END
  CRITERIA = '([F:CNE]EMPLEASTR <= DATSEL & DATSEL <= [F:CNE]EMPLEAEND)'
 Else
  CRITERIA = '(( [F:CNG]STRPER <= DATSEL & DATSEL <= [F:CNG]ENDPER ) | ( [F:CNG]DEBDAT <= DATSEL & DATSEL <= [F:CNG]FINDAT ))'
 Endif
 For [LNK]    Where [F:CNG]CPY = [F:FCY]LEGCPY
&                 & evalue(CRITERIA)
&                 & [F:TIM]DSPSLD = 2
#JASMI - 2014-09-22 - US2983 - END
  # FQ88082 - SEGAY 23/04/13 test ACS de TIM
  STAT=0
  If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
    Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[L]MATRICULE,[L]CONTRAT,STAT) From DIVPAYE
  Endif
  # FQ76178 US1931 - SEGAY 18/09/12 - On fait le test sur TYPCP pour CPE et CPA idem dans CNSCNGSTD, CNSCCSTD et GETLSTCCG de PORTPS
  If !STAT
    If [L]WTIM = "CP"        : # transcription du code CP en dur
#MIPEA - 2017-06-07- US X3-43919- START
      Call VERIF_TYPCP([F:HRCTRG]ETRFCY,[L]WCPA,[L]WCPE,[F:CNG]TIM,[L]WOK) From CNSCNGSTD
#      Call VERIF_TYPCP([F:CTRG]ETRFCY,[L]WCPA,[L]WCPE,[F:CNG]TIM,[L]WOK) From CNSCNGSTD
#MIPEA - 2017-06-07- US X3-43919- END
      If ![L]WOK
         [L]STAT=1
      Endif
    Endif
  Endif
  # END FQ76178

  # FQ89905 - Test des subordonnées
  If !STAT
    mkstat=0
#MIPEA - 2017-06-07- US X3-43919- START
    Call CHECK_SUBORD([F:HRCTRG]REFNUM,"",[V]GFLXPORTPS,[31/12/9999])From DIVPAYE
#    Call CHECK_SUBORD([F:CTRG]REFNUM,"",[V]GFLXPORTPS,[31/12/9999])From DIVPAYE
#MIPEA - 2017-06-07- US X3-43919- END
    If mkstat : STAT=1 : Endif
  Endif
  # END FQ89905 - Test des subordonnées

  If !STAT  : # Si STAT=1 pas d'accès
  # END FQ88082

   If N>=dim([L]CTRNUM)
    GERR=1
    Break 2
   Endif

#MIPEA - 2017-06-07- US X3-43919- START
  [L]CTRNUM(N) = [F:HRCTRG]CTRNUM
  [L]CTRDAT(N) = [F:HRCTRG]CTRDAT
#  [L]CTRNUM(N) = [F:CTRG]CTRNUM
#  [L]CTRDAT(N) = [F:CTRG]CTRDAT : # FQ89905 - SEGAY 23/05/13 Test sur date contrat
#MIPEA - 2017-06-07- US X3-43919- END
  [L]TIM(N) = [F:CNG]TIM
  TIM_CNG(N)= [F:CNG]TIM     : # sauvegarde du code evt exact
  LIBEL (N) = [F:TIM]DES
  YEA   (N) = [F:CNG]YEA
#JASMI - 2014-09-22 - US2983 - START
#  DATDEB(N) = [F:CNG]DEBDAT : # Période de tolérance
#  DATFIN(N) = [F:CNG]FINDAT : #
#MIPEA - 2017-06-07- US X3-43919- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2017-06-07- US X3-43919- END
    DATDEB(N) = [F:CNE]EMPLEASTR : # Période de tolérance
    DATFIN(N) = [F:CNE]EMPLEAEND : #
  Else
    DATDEB(N) = [F:CNG]DEBDAT : # Période de tolérance
    DATFIN(N) = [F:CNG]FINDAT : #
  Endif
#JASMI - 2014-09-22 - US2983 - END

# Appel à la fonction de consultation
#MIPEA - 2017-06-07- US X3-43919- START
  Call CNG_ACCOUNT([F:HRCTRG]REFNUM,[F:HRCTRG]CTRNUM,[F:HRCTRG]CTRDAT,[F:CNG]TIM,[F:HRCTRG]PERCOD,DATSEL
&               ,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN)
& From CNSCNGSTD
#  Call CNG_ACCOUNT([F:CTRG]REFNUM,[F:CTRG]CTRNUM,[F:CTRG]CTRDAT,[F:CNG]TIM,[F:CTRG]ETRFCY,DATSEL
#&               ,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN)
#& From CNSCNGSTD
#MIPEA - 2017-06-07- US X3-43919- END
# On recupère un tableau des années concernées par DATSEL, on ne garde que celle courante
  I=0
  While I<dim(WYEA)-1 & WYEA(I) <> [F:CNG]YEA
  I+=1
  Wend
  If WYEA(I) = [F:CNG]YEA
   ACQ(N)   = WACQ(I)
   PRI(N)   = WPRI(I)
   VLD(N)   = WVLD(I)
   ATT(N)   = WATT(I)
   SLD(N)   = WSLD(I)

   N+=1
  Endif
  Endif # FILTSUP_EVT_TIM
 Next
 Endif # FQ89905 - SEGAY 23/05/13 Test sur date contrat
Next

If CREAGLOB :  Kill GDONOTCLOSE , GSVFLUX , GTTYPMGR : Endif : # FQ89905 - Test des subordonnées

#62491
Sorta    N   CTRNUM,TIM,LIBEL,YEA,ACQ,PRI,SLD,DATDEB,DATFIN,ATT,VLD,CTRDAT
&  Order By CTRNUM(indice),-val(CTRDAT(indice)),-YEA(indice),TIM(indice)


If GERR & GMESSAGE = ""
#MIPEA - 2017-06-07- US X3-43919- START
 GMESSAGE="SUICNG :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# GMESSAGE="SUICNG :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
 #           Dimension des variables inférieure à $1$
Endif

Onerrgo

End

###############################################################
## Détail solde des congés pour un évènement et un type donnés
## TYP - 1 : PRIS
##     - 2 : POSES VALIDES
##     - 3 : ATTENTE
###############################################################

Subprog DETSUICNG(MATRICULE,CONTRAT,DATSEL,YEA,TIM,LIBEL,TYP,DATDEB,DATFIN,CMT,QTY,STOT,TOT)

Value    Char    MATRICULE(), CONTRAT()
Value    Date    DATSEL
Value    Integer YEA
Value    Char    TIM()
Value    Integer TYP
Value    Char    LIBEL()
Variable Decimal QTY(0..), STOT(0..),TOT
Variable Date    DATDEB(0..), DATFIN(0..)
Variable Char    CMT()(0..)

Local    Date    CTRDATE

Raz GMESSAGE

If [V]GFONCTION<>"CONSCNG"
 [V]GFONCTION="CONSCNG"
 Call AUTORIS From EXEFNC
Endif

Onerrgo ERREUR : # 67776

 Call CNG_DETAIL([L]MATRICULE,[L]CONTRAT,[L]CTRDATE,[L]DATSEL,[L]YEA
&               ,[L]TIM,[L]TYP
&               ,[L]DATDEB,[L]DATFIN,[L]CMT
&               ,[L]QTY,[L]STOT
&               ,[L]TOT)
&     From CNSCNGSTD

Onerrgo
End

$ERREUR
GERR = 1 : # 67776
End
###############################################################
## Détail de la saisie des congés
###############################################################

Subprog DETCNG( MATRICULE,CONTRAT,EVENEMENT,ANNEE,CTRNUM,STRDAT,ENDDAT,NBRDAY,CUMDAY
&             , ACQ,PRI,SOL
&             )
Value    Char    MATRICULE, EVENEMENT, CONTRAT
Value    Integer ANNEE
Variable Date    STRDAT(0..), ENDDAT(0..)
Variable Decimal NBRDAY(0..), CUMDAY(0..)
Variable Decimal ACQ(0..), PRI(0..), SOL(0..)
Variable Char    CTRNUM()(0..)

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
#If !clalev([F:CTR2]) : Local File EMPLOCTR [CTR2] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If !clalev([M:DIA])  : Local Mask DETCP    [DIA]  : Endif
If !clalev([F:TIM])  : Local File TIMCOD   [TIM]  : Endif

Local Char    PARAM(250)(1..20), CPA([V]GLONTPS), CPE([V]GLONTPS)
Local Integer I, N
Local Libelle CP

Call PARAM("","CPA",[L]CPA) From ADOVAL
Call PARAM("","CPE",[L]CPE) From ADOVAL

[L]PARAM(1)=[L]MATRICULE
[L]PARAM(3)=num$([L]ANNEE)

#MIPEA - 2017-06-07- US X3-43919- START
Read [TIM]TIM0=GCURLEG;[L]EVENEMENT
#Read [TIM]TIM0=[L]EVENEMENT
#MIPEA - 2017-06-07- US X3-43919- END

#SBA à changer
# US-2832
If [F:TIM]VLTEVT=2 & [F:TIM]CATTIM=3 & func DIVPAYE.IS_CP([F:TIM]COD,CPA,CPE)
  [L]CP=1
Endif

# FQ76186 - MABON 19/09/11 - Ajout test sur XITFNL
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#For [CTR2] Where REFNUM=[L]MATRICULE & CTRDAT<=gdat$(31,12,[L]ANNEE)
#&              & (XITDAT=[0/0/0] | XITDAT>=gdat$(1,1,[L]ANNEE) | XITFNL<>2)
#&              & ([L]CONTRAT="" | CTRNUM=[L]CONTRAT)
#MIPEA - 2017-06-07- US X3-43919- START
For [HRCTR2] Where REFNUM=[L]MATRICULE & (CTRDAT<=gdat$(31,12,[L]ANNEE) | (FLGRET=2 & RETDATEFF<=gdat$(31,12,[L]ANNEE)))
&              & (XITDAT=[0/0/0] | XITDAT>=gdat$(1,1,[L]ANNEE) | XITFNL<>2)
&              & ([L]CONTRAT="" | CTRNUM=[L]CONTRAT)
# Fin MABON
 If    ![L]CP
  [L]PARAM(2)=[L]EVENEMENT
 Elsif func AFNC.PARAM("TYPCP",[HRCTR2]ETRFCY)  = "2"  : # WGA- prise en cpte param site TYPCP
  [L]PARAM(2)=[L]CPE
 Else
  [L]PARAM(2)=[L]CPA
 Endif
 [L]PARAM(4)=[F:HRCTR2]CTRNUM
 Gosub DEBUT_DETAIL From TPSCP

 For I=0 To [M:DIA]NBRLIG-1
  If N>=dim([L]CTRNUM)
   [V]GERR=1
  Else
   [L]CTRNUM(N)=[FHR:CTR2]CTRNUM
   [L]STRDAT(N)=[M:DIA]STRDAT(I)
   [L]ENDDAT(N)=[M:DIA]ENDDAT(I)
   [L]NBRDAY(N)=[M:DIA]NBRDAY(I)
   [L]CUMDAY(N)=[M:DIA]CUMDAY(I)
   [L]ACQ   (N)=[M:DIA]ACQ
   [L]PRI   (N)=[M:DIA]PRI
   [L]SOL   (N)=[M:DIA]SOL
  Endif
  N+=1
 Next
Next
#For [CTR2] Where REFNUM=[L]MATRICULE & (CTRDAT<=gdat$(31,12,[L]ANNEE) | (FLGRET=2 & RETDATEFF<=gdat$(31,12,[L]ANNEE)))
#&              & (XITDAT=[0/0/0] | XITDAT>=gdat$(1,1,[L]ANNEE) | XITFNL<>2)
#&              & ([L]CONTRAT="" | CTRNUM=[L]CONTRAT)
## Fin MABON
# If    ![L]CP
#  [L]PARAM(2)=[L]EVENEMENT
# Elsif func AFNC.PARAM("TYPCP",[CTR2]ETRFCY)  = "2"  : # WGA- prise en cpte param site TYPCP
#  [L]PARAM(2)=[L]CPE
# Else
#  [L]PARAM(2)=[L]CPA
# Endif
# [L]PARAM(4)=[F:CTR2]CTRNUM
# Gosub DEBUT_DETAIL From TPSCP
#
# For I=0 To [M:DIA]NBRLIG-1
#  If N>=dim([L]CTRNUM)
#   [V]GERR=1
#  Else
#   [L]CTRNUM(N)=[F:CTR2]CTRNUM
#   [L]STRDAT(N)=[M:DIA]STRDAT(I)
#   [L]ENDDAT(N)=[M:DIA]ENDDAT(I)
#   [L]NBRDAY(N)=[M:DIA]NBRDAY(I)
#   [L]CUMDAY(N)=[M:DIA]CUMDAY(I)
#   [L]ACQ   (N)=[M:DIA]ACQ
#   [L]PRI   (N)=[M:DIA]PRI
#   [L]SOL   (N)=[M:DIA]SOL
#  Endif
#  N+=1
# Next
#Next
#MIPEA - 2017-06-07- US X3-43919- END

If [V]GERR
#MIPEA - 2017-06-07- US X3-43919- START
 [V]GMESSAGE="DETCNG :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# [V]GMESSAGE="DETCNG :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
 #           Dimension des variables inférieure à $1$
Endif

End

###############################################################
## Planning service
###############################################################

Subprog PLNSRV(CPY,FCY,SRV,GROUPE,DATDEB,DATFIN,REFNUM,STRDAT,DUREE,TYPJOU)
Value    Char    CPY, FCY, SRV
Value    Date    DATDEB, DATFIN
Variable Char    REFNUM()(0..), GROUPE()(0..)
Variable Date    STRDAT(0..)
Variable Decimal DUREE(0..)
Variable Integer TYPJOU(0..)

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

Local Integer I,J

If clalev([M:VCO])=0 : Local Mask VCONGE [VCO] : Endif
Raz [M:VCO]
[M:VCO]CPY    = [L]CPY
[M:VCO]FCY    = [L]FCY
[M:VCO]SRV    = [L]SRV
[M:VCO]DATDEB = [L]DATDEB
[M:VCO]DATFIN = [L]DATFIN

Gosub DECLARE From VCONGE
#Gosub INIT_CONGES From VCONGE   : 65775 Etiquette inexistante
Gosub REMPLIT From VCONGE
J = 0
For I=1 To [M:VCO]NBLIG
 If [M:VCO]DAT(I)<>[0/0/0]
  [L]REFNUM(J) = [M:VCO]MATRI(I)
  [L]STRDAT(J) = [M:VCO]DAT(I)
  [L]DUREE(J)  = [M:VCO]DUREE(I)
  [L]TYPJOU(J) = [M:VCO]TYPJOU(I)
  J +=1
 Endif
Next
End

###############################################################
## Planning individuel
## Jusqu'à 3 plages horaires=>Variables terminées par 1 2 ou 3
## Encore utilisée ? a priori non
###############################################################


Subprog PLNIND( REFNUM,DATDEB,DATFIN,DAT,STRTIM1,ENDTIM1,BRKTIM1,STRTIM2,ENDTIM2,BRKTIM2
&             , STRTIM3,ENDTIM3,BRKTIM3,NAT1,NAT2,NAT3,CCE11,CCE12,CCE13,CCE14,CCE15
&             , CCE16,CCE17,CCE18,CCE19,CCE21,CCE22,CCE23,CCE24,CCE25,CCE26,CCE27,CCE28
&             , CCE29,CCE31,CCE32,CCE33,CCE34,CCE35,CCE36,CCE37,CCE38,CCE39,TYPJOU,NBJOU
&             , NBHRE
&             )
Value    Char    REFNUM()
Value    Date    DATDEB, DATFIN
Variable Date    DAT(0..)
Variable Decimal BRKTIM1(0..), BRKTIM2(0..), BRKTIM3(0..)
Variable Char    STRTIM1()(0..), ENDTIM1()(0..), STRTIM2()(0..), ENDTIM2()(0..), STRTIM3()(0..), ENDTIM3()(0..)
Variable Integer TYPJOU(0..), NBJOU(0..), NBHRE(0..)
Variable Char    NAT1()(0..), NAT2()(0..), NAT3()(0..)
Variable Char    CCE11()(0..),  CCE12()(0..), CCE13()(0..), CCE14()(0..), CCE15()(0..), CCE16()(0..), CCE17()(0..), CCE18()(0..), CCE19()(0..)
Variable Char    CCE21()(0..),  CCE22()(0..), CCE23()(0..), CCE24()(0..), CCE25()(0..), CCE26()(0..), CCE27()(0..), CCE28()(0..), CCE29()(0..)
Variable Char    CCE31()(0..),  CCE32()(0..), CCE33()(0..), CCE34()(0..), CCE35()(0..), CCE36()(0..), CCE37()(0..), CCE38()(0..), CCE39()(0..)

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

#MIPEA - 2017-06-07- US X3-43919- START
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If clalev([F:NAT])=0 : Local File NATACTIV [NAT] : Endif

Local Integer I, J, INITSEC, JNUIT
Local Char CCE(GLONCCE)(1..9), HREDEB(GLONHM), HREFIN(GLONHM), NATU(GLONNAT)
Local Decimal  JOUR(1..2), HEURE(1..2), TPSBRK

For I=0 To ([L]DATFIN-[L]DATDEB)
 [L]DAT(I) = [L]DATDEB+I
 # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
# Filter [CTR] Where CTRDAT<[L]DAT(I)
#MIPEA - 2017-06-07- US X3-43919- START
 Filter [HRCTR] Where (CTRDAT<[L]DAT(I) | (FLGRET=2 & RETDATEFF<=[L]DAT(I)))
 # Fin MABON
 Read [HRCTR]CTR1 Last
 Filter [HRCTR]
 For J=1 To GNBHOR
  If J=1
    Call JOUR([L]REFNUM,[L]DAT(I),TYPJOU(I),JOUR,HEURE,JNUIT,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,J,HREDEB,HREFIN,TPSBRK,NATU,CCE,INITSEC) From SUBPLN
    STRTIM1(I) = HREDEB : ENDTIM1(I) = HREFIN
    BRKTIM1(I) = TPSBRK : NAT1(I)    = NATU
    [L]CCE11(I)=CCE(1) : [L]CCE12(I)=CCE(2) : [L]CCE13(I)=CCE(3) : [L]CCE14(I)=CCE(4) : [L]CCE15(I)=CCE(5)
    [L]CCE16(I)=CCE(6) : [L]CCE17(I)=CCE(7) : [L]CCE18(I)=CCE(8) : [L]CCE19(I)=CCE(9)
    NBJOU(I) = JOUR(2)
    NBHRE(I) = HEURE(2)
  Elsif J=2
    Call JOUR([L]REFNUM,[L]DAT(I),TYPJOU(I),JOUR,HEURE,JNUIT,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,J,HREDEB,HREFIN,TPSBRK,NATU,CCE,INITSEC) From SUBPLN
    STRTIM2(I) = HREDEB : ENDTIM2(I) = HREFIN
    BRKTIM2(I) = TPSBRK : NAT2(I)    = NATU
    [L]CCE21(I)=CCE(1) : [L]CCE22(I)=CCE(2) : [L]CCE23(I)=CCE(3) : [L]CCE24(I)=CCE(4) : [L]CCE25(I)=CCE(5)
    [L]CCE26(I)=CCE(6) : [L]CCE27(I)=CCE(7) : [L]CCE28(I)=CCE(8) : [L]CCE29(I)=CCE(9)
  Elsif J=3
    Call JOUR([L]REFNUM,[L]DAT(I),TYPJOU(I),JOUR,HEURE,JNUIT,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,J,HREDEB,HREFIN,TPSBRK,NATU,CCE,INITSEC) From SUBPLN
    STRTIM3(I) = HREDEB : ENDTIM3(I) = HREFIN
    BRKTIM3(I) = TPSBRK : NAT3(I)    = NATU
    [L]CCE31(I)=CCE(1) : [L]CCE32(I)=CCE(2) : [L]CCE33(I)=CCE(3) : [L]CCE34(I)=CCE(4) : [L]CCE35(I)=CCE(5)
    [L]CCE36(I)=CCE(6) : [L]CCE37(I)=CCE(7) : [L]CCE38(I)=CCE(8) : [L]CCE39(I)=CCE(9)
  Endif
 Next
 If GNBHOR=0
  Call JOUR([L]REFNUM,[L]DAT(I),TYPJOU(I),JOUR,HEURE,JNUIT,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,0,HREDEB,HREFIN,TPSBRK,NATU,CCE,INITSEC) From SUBPLN
  STRTIM1(I) = HREDEB : ENDTIM1(I) = HREFIN
  BRKTIM1(I) = TPSBRK : NAT1(I)    = NATU
  [L]CCE11(I)=CCE(1) : [L]CCE12(I)=CCE(2) : [L]CCE13(I)=CCE(3) : [L]CCE14(I)=CCE(4) : [L]CCE15(I)=CCE(5)
  [L]CCE16(I)=CCE(6) : [L]CCE17(I)=CCE(7) : [L]CCE18(I)=CCE(8) : [L]CCE19(I)=CCE(9)
  NBJOU(I) = JOUR(2)
  NBHRE(I) = HEURE(2)
 Endif
Next
# Filter [CTR] Where (CTRDAT<[L]DAT(I) | (FLGRET=2 & RETDATEFF<=[L]DAT(I)))
# # Fin MABON
# Read [CTR]CTR1 Last
# Filter [CTR]
# For J=1 To GNBHOR
#  If J=1
#    Call JOUR([L]REFNUM,[L]DAT(I),TYPJOU(I),JOUR,HEURE,JNUIT,[F:CTR]ETRFCY,[F:CTR]CTRNUM,J,HREDEB,HREFIN,TPSBRK,NATU,CCE,INITSEC) From SUBPLN
#    STRTIM1(I) = HREDEB : ENDTIM1(I) = HREFIN
#    BRKTIM1(I) = TPSBRK : NAT1(I)    = NATU
#    [L]CCE11(I)=CCE(1) : [L]CCE12(I)=CCE(2) : [L]CCE13(I)=CCE(3) : [L]CCE14(I)=CCE(4) : [L]CCE15(I)=CCE(5)
#    [L]CCE16(I)=CCE(6) : [L]CCE17(I)=CCE(7) : [L]CCE18(I)=CCE(8) : [L]CCE19(I)=CCE(9)
#    NBJOU(I) = JOUR(2)
#    NBHRE(I) = HEURE(2)
#  Elsif J=2
#    Call JOUR([L]REFNUM,[L]DAT(I),TYPJOU(I),JOUR,HEURE,JNUIT,[F:CTR]ETRFCY,[F:CTR]CTRNUM,J,HREDEB,HREFIN,TPSBRK,NATU,CCE,INITSEC) From SUBPLN
#    STRTIM2(I) = HREDEB : ENDTIM2(I) = HREFIN
#    BRKTIM2(I) = TPSBRK : NAT2(I)    = NATU
#    [L]CCE21(I)=CCE(1) : [L]CCE22(I)=CCE(2) : [L]CCE23(I)=CCE(3) : [L]CCE24(I)=CCE(4) : [L]CCE25(I)=CCE(5)
#    [L]CCE26(I)=CCE(6) : [L]CCE27(I)=CCE(7) : [L]CCE28(I)=CCE(8) : [L]CCE29(I)=CCE(9)
#  Elsif J=3
#    Call JOUR([L]REFNUM,[L]DAT(I),TYPJOU(I),JOUR,HEURE,JNUIT,[F:CTR]ETRFCY,[F:CTR]CTRNUM,J,HREDEB,HREFIN,TPSBRK,NATU,CCE,INITSEC) From SUBPLN
#    STRTIM3(I) = HREDEB : ENDTIM3(I) = HREFIN
#    BRKTIM3(I) = TPSBRK : NAT3(I)    = NATU
#    [L]CCE31(I)=CCE(1) : [L]CCE32(I)=CCE(2) : [L]CCE33(I)=CCE(3) : [L]CCE34(I)=CCE(4) : [L]CCE35(I)=CCE(5)
#    [L]CCE36(I)=CCE(6) : [L]CCE37(I)=CCE(7) : [L]CCE38(I)=CCE(8) : [L]CCE39(I)=CCE(9)
#  Endif
# Next
# If GNBHOR=0
#  Call JOUR([L]REFNUM,[L]DAT(I),TYPJOU(I),JOUR,HEURE,JNUIT,[F:CTR]ETRFCY,[F:CTR]CTRNUM,0,HREDEB,HREFIN,TPSBRK,NATU,CCE,INITSEC) From SUBPLN
#  STRTIM1(I) = HREDEB : ENDTIM1(I) = HREFIN
#  BRKTIM1(I) = TPSBRK : NAT1(I)    = NATU
#  [L]CCE11(I)=CCE(1) : [L]CCE12(I)=CCE(2) : [L]CCE13(I)=CCE(3) : [L]CCE14(I)=CCE(4) : [L]CCE15(I)=CCE(5)
#  [L]CCE16(I)=CCE(6) : [L]CCE17(I)=CCE(7) : [L]CCE18(I)=CCE(8) : [L]CCE19(I)=CCE(9)
#  NBJOU(I) = JOUR(2)
#  NBHRE(I) = HEURE(2)
# Endif
#Next
#MIPEA - 2017-06-07- US X3-43919- END
End

################################################################################
# renvoie les jours fériés entre deux dates
Subprog GETJOURFERIE(SITE,DATDEB,DATFIN,HLYDAY)
Value    Char    SITE()
Value    Date    DATDEB, DATFIN
Variable Date    HLYDAY(0..)

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

If !clalev([F:HLY]) : Local File HLYDAY [HLY] : Endif

Local Shortint N, I

Filter [HLY] Order By Key CLE=YEA;FCY Desc
For [HLY]CLE(1) Where YEA<=year([L]DATFIN) & YEA>=year([L]DATDEB)
&                   & find(FCY,[L]SITE,"")<>0
 For I=0 To [F:HLY]NBRDAY-1
  If [F:HLY]HLYDAY(I)>=[L]DATDEB & [F:HLY]HLYDAY(I)<=[L]DATFIN
   If N>=dim([L]HLYDAY) : [V]GERR=1
   Else                   [L]HLYDAY(N)=[F:HLY]HLYDAY(I)
   Endif
   N+=1
  Endif
 Next
Next
Filter [HLY]

If [V]GERR
#MIPEA - 2017-06-07- US X3-43919- START
 [V]GMESSAGE="GETJOURFERIE :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# [V]GMESSAGE="GETJOURFERIE :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
 #           Dimension des variables inférieure à $1$
Endif

End

################################################################################
# Renvoie le produit du planning type par les semaines types
##########
# 1- Avec gestion des temps : RAS
#
# 2- 69243 Contexte mini GTA
#    . l'appel depuis SUBDCG est conditionné par GTPS=1 : RAS
#    . l'appel depuis DETAILCP de PORDCG idem
#    . l'appel depuis GETALLCNG : pour [TIP] & [TIP] pas possible de savoir
#      si 0,5j est matin ou ap.midi (GETALLCNG traduit matin)
#    .
#
##########
Subprog GETSEMTYP( PLANNING,MATRICULE,CONTRAT,DATDEB,DATFIN,CTRNUM,DAT,WTY,TYPDAY,NBRDAY
&                , STRTIM0,ENDTIM0,STRTIM1,ENDTIM1,STRTIM2,ENDTIM2
&                )
Value    Char    PLANNING(), MATRICULE(), CONTRAT()
Value    Date    DATDEB, DATFIN
Variable Char    CTRNUM()(0..), WTY()(0..), STRTIM0()(0..), ENDTIM0()(0..), STRTIM1()(0..)
Variable Char    ENDTIM1()(0..), STRTIM2()(0..), ENDTIM2()(0..)
Variable Date    DAT(0..)
Variable Integer TYPDAY(0..)
Variable Decimal NBRDAY(0..)

#If [V]GFONCTION<>"GESEML"  !appellé par SUBDCG, il ne faut pas changer les habilitations
# [V]GFONCTION="GESEML"
# Call AUTORIS From EXEFNC
#Endif

If !clalev([F:WTY])  : Local File TYPWEEK  [WTY]  : Endif
If !clalev([F:PLN])  : Local File PLANTYP  [PLN]  : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRCTRP]) : Local File EMPLOCTR [HRCTRP] : Endif  : # 62965
#If !clalev([F:CTRP]) : Local File EMPLOCTR [CTRP] : Endif  : # 62965
#MIPEA - 2017-06-07- US X3-43919- END

Local Date    DEB, FIN, SEM0
Local Integer AN, SEM, N, I
Local Char    PLNTYP([V]GLONPLN)

#MIPEA - 2017-11-26- US X3-63170- START
If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = MATRICULE & [F:HRCTR8]CTRNUM = CONTRAT
Read [F:HRCTR8] Last
Filter [F:HRCTR8]
Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-26- US X3-63170- END

Call SEMAINE(year([L]DATDEB),0,[L]SEM0,[L]FIN) From SUBPLN

If [L]PLANNING>""
 [L]PLNTYP=[L]PLANNING
 [L]DEB   =[L]DATDEB
 [L]FIN   =[L]DATFIN
 Gosub SEMTYP

Else
 # FQ76186 - MABON 19/09/11 - Ajout test sur XITFNL
 # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
 Local Date DATDEBCTR
# For [CTRP]CTR0 Where REFNUM=[L]MATRICULE & (CTRNUM=[L]CONTRAT | [L]CONTRAT="")
#&                  & CTRDAT<=[L]DATFIN & (XITDAT=[0/0/0] | XITDAT>=[L]DATDEB | XITFNL<>2)
#MIPEA - 2017-06-07- US X3-43919- START
 For [HRCTRP]CTR0 Where REFNUM=[L]MATRICULE & (CTRNUM=[L]CONTRAT | [L]CONTRAT="")
&                  & (CTRDAT<=[L]DATFIN | (FLGRET=2 & RETDATEFF<=[L]DATFIN)) & (XITDAT=[0/0/0] | XITDAT>=[L]DATDEB | XITFNL<>2)
  DATDEBCTR=[F:HRCTRP]CTRDAT
  If [F:HRCTRP]FLGRET=2 & [F:HRCTRP]RETDATEFF<>[0/0/0] Then
    DATDEBCTR=[F:HRCTRP]RETDATEFF
  Endif
#  [L]DEB=max([L]DATDEB,[F:CTRP]CTRDAT)
  [L]DEB=max([L]DATDEB,DATDEBCTR)
  # Fin MABON
  If [F:HRCTRP]XITDAT=[0/0/0] : [L]FIN=[L]DATFIN
  Else                       [L]FIN=min([L]DATFIN,[F:CTRP]XITDAT)
  Endif
  If [F:HRCTRP]PLNTYP="" : [L]PLNTYP=[V]GPLANNING : Else [L]PLNTYP=[F:HRCTRP]PLNTYP : Endif
  # FQ89588 - 23/04/13 - Si sortie avant la date de fin, on ne va pas dans SEMTYP
  If [L]FIN>=[L]DEB Then
    Gosub SEMTYP
  Endif
 Next
# For [CTRP]CTR0 Where REFNUM=[L]MATRICULE & (CTRNUM=[L]CONTRAT | [L]CONTRAT="")
#&                  & (CTRDAT<=[L]DATFIN | (FLGRET=2 & RETDATEFF<=[L]DATFIN)) & (XITDAT=[0/0/0] | XITDAT>=[L]DATDEB | XITFNL<>2)
#  DATDEBCTR=[F:CTRP]CTRDAT
#  If [F:CTRP]FLGRET=2 & [F:CTRP]RETDATEFF<>[0/0/0] Then
#    DATDEBCTR=[F:CTRP]RETDATEFF
#  Endif
##  [L]DEB=max([L]DATDEB,[F:CTRP]CTRDAT)
#  [L]DEB=max([L]DATDEB,DATDEBCTR)
#  # Fin MABON
#  If [F:CTRP]XITDAT=[0/0/0] : [L]FIN=[L]DATFIN
#  Else                       [L]FIN=min([L]DATFIN,[F:CTRP]XITDAT)
#  Endif
#  If [F:CTRP]PLNTYP="" : [L]PLNTYP=[V]GPLANNING : Else [L]PLNTYP=[F:CTRP]PLNTYP : Endif
#  # FQ89588 - 23/04/13 - Si sortie avant la date de fin, on ne va pas dans SEMTYP
#  If [L]FIN>=[L]DEB Then
#    Gosub SEMTYP
#  Endif
# Next
#MIPEA - 2017-06-07- US X3-43919- END
Endif

If [V]GERR
#MIPEA - 2017-06-07- US X3-43919- START
 [V]GMESSAGE="GETSEMTYP :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# [V]GMESSAGE="GETSEMTYP :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2017-06-07- US X3-43919- END
 #           Dimension des variables inférieure à $1$
Endif

End

$SEMTYP
fstat=0 : # 67779
Repeat
 Call DAT([L]DEB,[L]AN,[L]SEM) From SUBPLN
 I=mod([L]DEB-[L]SEM0,7)
 If [F:PLN]YEA<>[L]AN | [F:PLN]COD<>[L]PLNTYP
#MIPEA - 2017-06-07- US X3-43919- START
  Read [PLN]PLN0=[L]AN;[L]PLNTYP;GCURLEG
#  Read [PLN]PLN0=[L]AN;[L]PLNTYP
#MIPEA - 2017-06-07- US X3-43919- END
 Endif
# If [F:WTY]COD<>[F:PLN]WEKTYP([L]SEM-1)
 If !fstat & [F:WTY]COD<>[F:PLN]WEKTYP([L]SEM-1)  : # 66093
#MIPEA - 2017-06-07- US X3-43919- START
  Read [WTY]WTY0=GCURLEG;[F:PLN]WEKTYP([L]SEM-1)
#  Read [WTY]WTY0=[F:PLN]WEKTYP([L]SEM-1)
#MIPEA - 2017-06-07- US X3-43919- END
 Endif

 If !fstat                                        : # 66093
  If N>=dim([L]CTRNUM)
   [V]GERR=1
  Else
#MIPEA - 2017-06-07- US X3-43919- START
   [L]CTRNUM (N)=[F:HRCTRP]CTRNUM
#   [L]CTRNUM (N)=[F:CTRP]CTRNUM
#MIPEA - 2017-06-07- US X3-43919- END
   [L]DAT    (N)=[L]DEB
   [L]WTY    (N)=[F:WTY]COD
   [L]TYPDAY (N)=[F:WTY]TYPDAY (I)
   [L]NBRDAY (N)=[F:WTY]NBRDAY1(I)
   [L]STRTIM0(N)=[F:WTY]STRTIM0(I)
   [L]ENDTIM0(N)=[F:WTY]ENDTIM0(I)
   If !GTPS : # 69243
    [L]STRTIM1(N) = "12"
   Endif
   If [V]GNBHOR>1
    [L]STRTIM1(N)=[F:WTY]STRTIM1(I)
    [L]ENDTIM1(N)=[F:WTY]ENDTIM1(I)
    If [V]GNBHOR>2
     [L]STRTIM2(N)=[F:WTY]STRTIM2(I)
     [L]ENDTIM2(N)=[F:WTY]ENDTIM2(I)
    Endif
   Endif
  Endif
  N     +=1
 Endif
 [L]DEB+=1
Until [L]DEB>[L]FIN
Return

################################################################################
# Liste des périodes - pour une intervalle de temps donnée
# renvoie les calendriers avec les plages de dates associées
Subprog GETLSTPERIOD(STRPER,ENDPER,TYPCAL,PERIOD,PERLIB,DESIGN,STRDAT,ENDDAT)
Value    Date    STRPER, ENDPER
Variable Integer TYPCAL(0..)
Variable Char    PERIOD()(0..), PERLIB()(0..) , DESIGN()(0..)
Variable Date    STRDAT(0..), ENDDAT(0..)

Local Char       CRITERE(250)
Local Integer    N,I

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

If !clalev([F:CLD]) : Local File CALENDAR [CLD] : Endif

If TYPCAL(0) <> 0
 CRITERE = "[F:CLD]TYPCLD = "+num$(TYPCAL(0))
Else
 CRITERE = "1=1"
Endif

N=0
Filter [F:CLD] Where evalue(CRITERE)
For [F:CLD]
 For I=0 To [F:CLD]NBRDAT-1
  If N  > dim([L]PERIOD)
   GERR = 1
   Break 2
  Endif
  If [F:CLD]STRDAT(I) <= ENDPER & [F:CLD]ENDDAT(I) >= STRPER : # on renvoie ce qui tient dans les dates en critère
   [L]TYPCAL(N) = [F:CLD]TYPCLD
   [L]PERIOD(N) = [F:CLD]PERIOD
#MIPEA - 2017-06-07- US X3-43919- START
   [L]PERLIB(N) = func AFNC.TEXTRA('ATABDIV','LNGDES','10702',[F:CLD]PERIOD)
#MIPEA - 2017-06-07- US X3-43919- SEND
   [L]DESIGN(N) = [F:CLD]DESIGN
   [L]STRDAT(N) = [F:CLD]STRDAT(I)
   [L]ENDDAT(N) = [F:CLD]ENDDAT(I)
   N+=1
  Endif
 Next
Next
Filter [CLD]

If GERR
 GMESSAGE="GETLSTPERIOD :"-func AFNC.MES1(mess(318,199,1),num$(N))
 #           Zone d'échange pleine  ( $1$ )
Endif

End

################################################################################
# calendriers par salarié - renvoie les calendriers affectés à un contrat salarié
Subprog GETLNKPERIOD(MATRICULE,CONTRAT,TYPCAL,PERIOD)
Value    Char    MATRICULE,CONTRAT
Variable Integer TYPCAL(0..)
Variable Char    PERIOD()(0..)

Local Char       CRITERE(250)
Local Integer    N, OK

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRCTR]) : Local File EMPLOCTR  [HRCTR] : Endif
#If !clalev([F:CTR]) : Local File EMPLOCTR  [CTR] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If !clalev([F:CLF]) : Local File CALENDAFF [CLF] : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If !clalev([F:HRPOA]) : Local File POPULA    [HRPOA] : Endif
#If !clalev([F:POA]) : Local File POPULA    [POA] : Endif
#MIPEA - 2017-06-07- US X3-43919- END

#MIPEA - 2017-06-07- US X3-43919- START
Filter [F:HRCTR] Where CTRNUM=CONTRAT & REFNUM=MATRICULE Order By Key CTR0
Read [F:HRCTR] Last
Filter [F:HRCTR]
Read [F:FCY]FCY0 = [F:HRCTR]ETRFCY
#Filter [F:CTR] Where CTRNUM=CONTRAT & REFNUM=MATRICULE Order By Key CTR0
#Read [F:CTR] Last
#Filter [F:CTR]
#Read [F:FCY]FCY0 = [F:CTR]ETRFCY
#MIPEA - 2017-06-07- US X3-43919- END
If fstat : End : Endif

N=0
#MIPEA - 2017-06-07- US X3-43919- START
For [F:CLF] Where
&            [F:CLF]LEV = 1
&          | [F:CLF]CPY = [F:FCY]LEGCPY
&          | [F:CLF]FCY = [F:HRCTR]ETRFCY
&          | [F:CLF]SRV = [F:HRCTR]ETRSRV
&          | [F:CLF]EMP = MATRICULE
&          | [F:CLF]CTR = CONTRAT
&          | [F:CLF]POP <> ""
#For [F:CLF] Where
#&            [F:CLF]LEV = 1
#&          | [F:CLF]CPY = [F:FCY]LEGCPY
#&          | [F:CLF]FCY = [F:CTR]ETRFCY
#&          | [F:CLF]SRV = [F:CTR]ETRSRV
#&          | [F:CLF]EMP = MATRICULE
#&          | [F:CLF]CTR = CONTRAT
#&          | [F:CLF]POP <> ""
#MIPEA - 2017-06-07- US X3-43919- END

 OK = 1
 If [F:CLF]POP <> ""
#MIPEA - 2017-06-07- US X3-43919- START
  Read [HRPOA]POA0 = [F:CLF]POP;MATRICULE;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
#  Read [POA]POA0 = [F:CLF]POP;MATRICULE
#MIPEA - 2017-06-07- US X3-43919- END
  If fstat
   OK = 0
  Endif
 Endif

 If OK & N  > dim([L]PERIOD)
  GERR = 1
  Break
 Endif

 If OK
  [L]TYPCAL(N) = [F:CLF]TYPCLD
  [L]PERIOD(N) = [F:CLF]PERIOD
  N+=1
 Endif

Next

If GERR
 GMESSAGE="GETLNKPERIOD :"-func AFNC.MES1(mess(318,199,1),num$(N))
 #           Zone d'échange pleine  ( $1$ )
Endif

End

#72629
#-------------------------------------------------------------------------------
# Consultation collective des congés
#-------------------------------------------------------------------------------
Subprog GETLSTCCG(PTIM,DATPYR,MATRICULES,CPY,FCY,SRV,POP,CNGYEA,REFNUM
&                ,CTRNUM,DEBDAT,FINDAT,ACQ,PRI,VLD,ATT,SLD,TIM,NAME,DATPAY,CTRDAT)

Value Char PTIM(), CPY(), FCY(), SRV(), POP()
Value Char MATRICULES()(0..)
Variable Date DATPYR
Variable Char CNGYEA()(0..), REFNUM()(0..), CTRNUM()(0..)
Variable Date DEBDAT(0..), FINDAT(0..)
Variable Decimal ACQ(0..), PRI(0..), VLD(0..), ATT(0..), SLD(0..)
Variable Char TIM()(0..), NAME()(0..)
Variable Date DATPAY(0..)
Variable Date CTRDAT(0..) : # FQ89905 - SEGAY 23/05/13 Test sur date contrat
Local Integer I, J
Local Char PTIM2(GLONTPS)
Local Date DATSEL, SAU_DATPYR
Local Char CRITERE(250)
Local Char CRITERE0(250)
Local Char CRITERE1(250)
Local Char CRITERE2(250) # FQ88082 - SEGAY 23/04/13 test ACS de TIM
Local Integer  STAT      # FQ88082 - SEGAY 23/04/13 test ACS de TIM

Local Integer WYEA(0..10)
Local Decimal WACQ(0..10), WPRI(0..10), WVLD(0..10), WATT(0..10), WSLD(0..10)
Local Decimal WSLDMIN
Local Date    WDATDEB : # FQ89905 - SEGAY 23/05/13 Test sur date contrat
# FQ81317 FQ76178 - SEGAY 18/09/13 - Test sur TYPCP
Local Char WTIM(GLONTPS),WCPA(GLONTPS),WCPE(GLONTPS)
Local Integer WOK

Call PARAM("","CPA",WCPA) From ADOVAL
Call PARAM("","CPE",WCPE) From ADOVAL
[L]WOK = 1
[L]WTIM =[L]PTIM
# END 76178
  If [V]GFONCTION<>"CONSCCG"
   [V]GFONCTION="CONSCCG"
   Call AUTORIS From EXEFNC
  Endif
  If [V]GNBAUZ = 0
    [V]GMESSAGE = mess(74,100,1)-"("+GFONCTION+")" # Fonction non autorisée
    [V]GERR = 1 : End
  Endif

  If [L]PTIM = ""
    [V]GMESSAGE="GETLSTCCG :"-mess(160,123,1)
    [V]GERR=1 : End
  Endif

  Call AUTSRV From GLOBPAY
#MIPEA - 2017-06-07- US X3-43919- START
  If !clalev([F:HRCTRP]) : Local File EMPLOCTR [HRCTRP] : Endif
#  If !clalev([F:CTRP]) : Local File EMPLOCTR [CTRP] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
  If !clalev([F:CNG]) : Local File CNGCPY [CNG] : Endif
#MIPEA - 2017-06-07- US X3-43919- START
  If !clalev([F:HRPOA]) : Local File POPULA [HRPOA] : Endif
#  If !clalev([F:POA]) : Local File POPULA [POA] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:IDP])  : Local File EMPLOID [IDP] : Endif
  If !clalev([F:ACC]) : Local File ACCES [ACC] :Endif
  If clalev([F:HSP])=0 : Local File HISTOPAYE [HSP] : Endif
# FQ88082 - SEGAY 23/04/13 test ACS de TIM
  If !clalev([F:TIM])  : Local File TIMCOD    [TIM]  : Endif
  If !clalev([F:ACC1]) : Local File ACCES     [ACC1] :Endif
# FQ89905 - SEGAY 23/05/13 Test sur date contrat
#MIPEA - 2017-06-07- US X3-43919- START
  If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
#  If clalev([F:PEO])=0 : Local File PERIOD [PEO] : Endif
#MIPEA - 2017-06-07- US X3-43919- END

#JASMI - 2014-09-22 - US2983 - START
#MIPEA - 2017-06-07- US X3-43919- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2017-06-07- US X3-43919- END
    If !clalev([F:CNE])  : Local File CNGEMP    [CNE]  : Endif
  Endif
#JASMI - 2014-09-22 - US2983 - END

  SAU_DATPYR=[L]DATPYR
  If [L]DATPYR = [0/0/0] or [L]DATPYR > eomonth(GMOIPAY)
    [L]DATPYR = eomonth([V]GMOIPAY)
  Endif
#75233
  [L]DATSEL = [L]DATPYR
  # FQ89905 - SEGAY 23/05/13 Test sur date contrat
  #[L]WDATDEB = [L]DATSEL
  #SBA
  #If [L]FCY<>""
    # On cherche la plus proche date de paie antérieure à la date sélectionnée
    mkstat = 0
#MIPEA - 2017-06-07- US X3-43919- START
    Call CADRE_PYRDAT([L]DATSEL,[F:HRCTR]PERCOD) From TPSSUB
#    Call CADRE_PYRDAT([L]DATSEL,[L]FCY) From TPSSUB
#MIPEA - 2017-06-07- US X3-43919- END
    While [L]DATSEL > [L]DATPYR & !mkstat
     I+=1
     [L]DATSEL = [L]DATPYR - I
#MIPEA - 2017-06-07- US X3-43919- START
     Call CADRE_PYRDAT([L]DATSEL,[F:HRCTR]PERCOD) From TPSSUB
#     Call CADRE_PYRDAT([L]DATSEL,[L]FCY) From TPSSUB
#MIPEA - 2017-06-07- US X3-43919- END
    Wend
    If mkstat
     [L]DATSEL = [L]DATPYR
    Endif
    # FQ89905 - SEGAY 23/05/13 Test sur date contrat
    # Date debut de période. A utiliser dans criteres de sélection des contrats
#MIPEA - 2017-06-07- US X3-43919- START
    WDATDEB = [F:HRPEOD]PERSTR(0)
#    WDATDEB = [F:PEO]PERSTR(0)
#MIPEA - 2017-06-07- US X3-43919- END

  #Endif
  #fin sba
  # FQ77390 - MABON 25/10/11 - Il faut réinitialiser mkstat, qui peut maintenant être égal à 3 après CADRE_PYRDAT
  Raz mkstat
#end 75233
  Raz [L]PTIM2

  If ([L]PTIM ="CP")
    # FQ81317 FQ76178 - SEGAY 18/09/13 - Test sur TYPCP
#    Call PARAM("","CPA",[L]PTIM) From ADOVAL
#    Call PARAM("","CPE",[L]PTIM2) From ADOVAL
    [L]PTIM=[L]WCPA
    [L]PTIM2=[L]WCPE
  Endif

  #Contrats courants
  # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#  [L]CRITERE  = '[F:CTRP]CTRDAT<=['+num$([L]DATSEL)+']'
#MIPEA - 2017-06-07- US X3-43919- START
  [L]CRITERE  = '([F:HRCTRP]CTRDAT<=['+num$([L]DATSEL)+'] | ([F:HRCTRP]FLGRET=2 & [F:HRCTRP]RETDATEFF<=['+num$([L]DATSEL)+']))'
#  [L]CRITERE  = '([F:CTRP]CTRDAT<=['+num$([L]DATSEL)+'] | ([F:CTRP]FLGRET=2 & [F:CTRP]RETDATEFF<=['+num$([L]DATSEL)+']))'
#MIPEA - 2017-06-07- US X3-43919- END
  # Fin MABON
  # FQ76186 - MABON 19/09/11 - Ajout test sur XITFNL
#  [L]CRITERE -= '& ([F:CTRP]XITDAT=[0/0/0] | [F:CTRP]XITDAT>=['+num$([L]DATSEL)+'] | [F:CTRP]XITFNL<>2)'
  # FQ89905 - SEGAY 23/05/13 Test sur date contrat

#MIPEA - 2017-06-07- US X3-43919- START
  [L]CRITERE -= '& ([F:HRCTRP]XITDAT=[0/0/0] | [F:HRCTRP]XITDAT>=['+num$([L]WDATDEB)+'])'
#  [L]CRITERE -= '& ([F:CTRP]XITDAT=[0/0/0] | [F:CTRP]XITDAT>=['+num$([L]WDATDEB)+'])'
#MIPEA - 2017-06-07- US X3-43919- SEND

  #Périodes de congés
#  [L]CRITERE0  = '[F:CNG]TIM ="'+[L]PTIM+'"'
#  If([L]PTIM2<>"") : [L]CRITERE0  -= '| [F:CNG]TIM ="'+[L]PTIM2+'"' : Endif
  # FQ81317 - SEGAY 03/04/12 - Critere sur TIM NOK
  If([L]PTIM2<>"")
    [L]CRITERE0  = '([F:CNG]TIM ="'+[L]PTIM+'" | [F:CNG]TIM ="'+[L]PTIM2+'")'
  Else
   [L]CRITERE0  = '[F:CNG]TIM ="'+[L]PTIM+'"'
  Endif

#JASMI - 2014-09-22 - US2983 - START
#  [L]CRITERE0 -= '& (([F:CNG]STRPER <=[L]DATSEL & [L]DATSEL <= [F:CNG]ENDPER)'
#  [L]CRITERE0 -= '| ([F:CNG]DEBDAT <= [L]DATSEL & [L]DATSEL <= [F:CNG]FINDAT ))'
#MIPEA - 2017-06-07- US X3-43919- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2017-06-07- US X3-43919- END
    [L]CRITERE0 -= '& ([F:CNE]EMPLEASTR <=[L]DATSEL & [L]DATSEL <= [F:CNE]EMPLEAEND)'
  Else
    [L]CRITERE0 -= '& (([F:CNG]STRPER <=[L]DATSEL & [L]DATSEL <= [F:CNG]ENDPER)'
    [L]CRITERE0 -= '| ([F:CNG]DEBDAT <= [L]DATSEL & [L]DATSEL <= [F:CNG]FINDAT ))'
  Endif
#JASMI - 2014-09-22 - US2983 - END

  #Droits
#MIPEA - 2017-06-07- US X3-43919- START
  [L]CRITERE1  = '([F:IDP]CODACS="" | [F:ACC]CONSUL=2)'
  [L]CRITERE1 -= '& find([F:HRCTRP]ETRFCY,[V]GUSRFCY)'
  [L]CRITERE1 -= '& find([F:HRCTRP]ETRSRV,[V]GAUTSRV)'

  If [L]MATRICULES > ""
    [L]CRITERE -= '& find([HRCTRP]REFNUM,[L]MATRICULES)'
  Else
    If [L]CPY <> "" : CRITERE -= '& [CNG]CPY="'+[L]CPY+'"' : Endif
    If [L]FCY <> "" : CRITERE -= '& [HRCTRP]ETRFCY="'+[L]FCY+'"' : Endif
    If [L]SRV <> "" : CRITERE -= '& [HRCTRP]ETRSRV="'+[L]SRV+'"' : Endif
  Endif
#  [L]CRITERE1  = '([F:IDP]CODACS="" | [F:ACC]CONSUL=2)'
#  [L]CRITERE1 -= '& find([F:CTRP]ETRFCY,[V]GUSRFCY)'
#  [L]CRITERE1 -= '& find([F:CTRP]ETRSRV,[V]GAUTSRV)'
#
#  If [L]MATRICULES > ""
#    [L]CRITERE -= '& find([CTRP]REFNUM,[L]MATRICULES)'
#  Else
#    If [L]CPY <> "" : CRITERE -= '& [CNG]CPY="'+[L]CPY+'"' : Endif
#    If [L]FCY <> "" : CRITERE -= '& [CTRP]ETRFCY="'+[L]FCY+'"' : Endif
#    If [L]SRV <> "" : CRITERE -= '& [CTRP]ETRSRV="'+[L]SRV+'"' : Endif
#  Endif
#MIPEA - 2017-06-07- US X3-43919- END
# FQ88082 - SEGAY 23/04/13 test ACS de TIM
  CRITERE2  = "1=1"
  If GUSRACS<>2
      CRITERE2 -= '& ([F:TIM]ACS="" | [F:ACC1]CONSUL=2 | [F:ACC1]EXEC=2)'
  Endif
# END FQ88082

  Columns [F:IDP] (REFNUM,CODACS,NAM,SRN)
#JASMI - 2014-09-22 - US2983 - START
#  If [L]POP<>""
#    Link [F:CTRP] With
#&     [F:POA]POA0     = [L]POP;[F:CTRP]REFNUM
#&   , [F:FCY]FCY0     = [F:CTRP]ETRFCY
#&   , [F:CNG]CNG0(1)  = [F:FCY]LEGCPY
#&   , [F:IDP]ID0       = [F:CTRP]REFNUM
#&   , [F:ACC]CODACC   = GUSER;[F:IDP]CODACS
#&   , [F:TIM]TIM0     = [F:CNG]TIM
#&   , [F:ACC1]CODACC  = GUSER;[F:TIM]ACS
#&   As [LNK]
#&   Where [F:POA]REFNUM<>""
#  Else
#  # FQ81317 - SEGAY 03/04/12 - Manque le link sur CODACC
#    Link [F:CTRP] With
#&     [F:FCY]FCY0     = [F:CTRP]ETRFCY
#&   , [F:CNG]CNG0(1)  = [F:FCY]LEGCPY
#&   , [F:IDP]ID0       = [F:CTRP]REFNUM
#&   , [F:ACC]CODACC   = GUSER;[F:IDP]CODACS
#&   , [F:TIM]TIM0     = [F:CNG]TIM
#&   , [F:ACC1]CODACC  = GUSER;[F:TIM]ACS
#&   As [LNK]
#  Endif
#MIPEA - 2017-06-07- US X3-43919- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2017-06-07- US X3-43919- END
    If [L]POP<>"" Then
#MIPEA - 2017-06-07- US X3-43919- START
      Link  [F:HRCTRP]  With  [F:HRPOA]POA0     =  [L]POP;[F:HRCTRP]REFNUM;[F:HRCTRP]CTRNUM;[F:HRCTRP]CTRDAT
&                           , [F:FCY]FCY0     =  [F:HRCTRP]ETRFCY
&                           , [F:CNG]CNG0(1)  =  [F:FCY]LEGCPY
&                           , [F:IDP]ID0      =  [F:HRCTRP]REFNUM
&                           , [F:ACC]CODACC   =  GUSER;[F:IDP]CODACS
&                           , [F:TIM]TIM0     =  GCURLEG;[F:CNG]TIM
&                           , [F:ACC1]CODACC  =  GUSER;[F:TIM]ACS
&                           , [F:CNE]CNE0     ~= [F:CNG]YEA; [F:HRCTRP]REFNUM; [F:HRCTRP]CTRNUM; [F:CNG]TIM
&                       As    [LNK]
&                       Where [F:HRPOA]REFNUM<>""
    Else
    # FQ81317 - SEGAY 03/04/12 - Manque le link sur CODACC
      Link [F:HRCTRP]   With  [F:FCY]FCY0     =  [F:HRCTRP]ETRFCY
&                           , [F:CNG]CNG0(1)  =  [F:FCY]LEGCPY
&                           , [F:IDP]ID0      =  [F:HRCTRP]REFNUM
&                           , [F:ACC]CODACC   =  GUSER;[F:IDP]CODACS
&                           , [F:TIM]TIM0     =  GCURLEG;[F:CNG]TIM
&                           , [F:ACC1]CODACC  =  GUSER;[F:TIM]ACS
&                           , [F:CNE]CNE0     ~= [F:CNG]YEA; [F:HRCTRP]REFNUM; [F:HRCTRP]CTRNUM; [F:CNG]TIM
&                       As    [LNK]
    Endif
  Else
    If [L]POP<>"" Then
       Link [F:HRCTRP] With
&      [F:HRPOA]POA0    = [L]POP;[F:HRCTRP]REFNUM;[F:HRCTRP]CTRNUM;[F:HRCTRP]CTRDAT
&    , [F:FCY]FCY0      = [F:HRCTRP]ETRFCY
&    , [F:CNG]CNG0(1)   = [F:FCY]LEGCPY
&    , [F:IDP]ID0       = [F:HRCTRP]REFNUM
&    , [F:ACC]CODACC    = GUSER;[F:IDP]CODACS
&    , [F:TIM]TIM0      = GCURLEG;[F:CNG]TIM
&    , [F:ACC1]CODACC   = GUSER;[F:TIM]ACS
&   As [LNK]
&   Where [F:HRPOA]REFNUM<>""
    Else
    # FQ81317 - SEGAY 03/04/12 - Manque le link sur CODACC
      Link [F:HRCTRP] With
&     [F:FCY]FCY0      = [F:HRCTRP]ETRFCY
&   , [F:CNG]CNG0(1)   = [F:FCY]LEGCPY
&   , [F:IDP]ID0       = [F:HRCTRP]REFNUM
&   , [F:ACC]CODACC    = GUSER;[F:IDP]CODACS
&   , [F:TIM]TIM0      = GCURLEG;[F:CNG]TIM
&   , [F:ACC1]CODACC   = GUSER;[F:TIM]ACS
&   As [LNK]
    Endif
  Endif
#      Link  [F:CTRP]  With  [F:POA]POA0     =  [L]POP;[F:CTRP]REFNUM
#&                         , [F:FCY]FCY0     =  [F:CTRP]ETRFCY
#&                         , [F:CNG]CNG0(1)  =  [F:FCY]LEGCPY
#&                         , [F:IDP]ID0      =  [F:CTRP]REFNUM
#&                         , [F:ACC]CODACC   =  GUSER;[F:IDP]CODACS
#&                         , [F:TIM]TIM0     =  [F:CNG]TIM
#&                         , [F:ACC1]CODACC  =  GUSER;[F:TIM]ACS
#&                         , [F:CNE]CNE0     ~= [F:CNG]YEA; [F:CTRP]REFNUM; [F:CTRP]CTRNUM; [F:CNG]TIM
#&                     As    [LNK]
#&                     Where [F:POA]REFNUM<>""
#    Else
#    # FQ81317 - SEGAY 03/04/12 - Manque le link sur CODACC
#      Link [F:CTRP]   With  [F:FCY]FCY0     =  [F:CTRP]ETRFCY
#&                         , [F:CNG]CNG0(1)  =  [F:FCY]LEGCPY
#&                         , [F:IDP]ID0      =  [F:CTRP]REFNUM
#&                         , [F:ACC]CODACC   =  GUSER;[F:IDP]CODACS
#&                         , [F:TIM]TIM0     =  [F:CNG]TIM
#&                         , [F:ACC1]CODACC  =  GUSER;[F:TIM]ACS
#&                         , [F:CNE]CNE0     ~= [F:CNG]YEA; [F:CTRP]REFNUM; [F:CTRP]CTRNUM; [F:CNG]TIM
#&                     As    [LNK]
#    Endif
#  Else
#    If [L]POP<>"" Then
#      Link [F:CTRP] With
#&     [F:POA]POA0     = [L]POP;[F:CTRP]REFNUM
#&   , [F:FCY]FCY0     = [F:CTRP]ETRFCY
#&   , [F:CNG]CNG0(1)  = [F:FCY]LEGCPY
#&   , [F:IDP]ID0       = [F:CTRP]REFNUM
#&   , [F:ACC]CODACC   = GUSER;[F:IDP]CODACS
#&   , [F:TIM]TIM0     = [F:CNG]TIM
#&   , [F:ACC1]CODACC  = GUSER;[F:TIM]ACS
#&   As [LNK]
#&   Where [F:POA]REFNUM<>""
#    Else
#    # FQ81317 - SEGAY 03/04/12 - Manque le link sur CODACC
#      Link [F:CTRP] With
#&     [F:FCY]FCY0     = [F:CTRP]ETRFCY
#&   , [F:CNG]CNG0(1)  = [F:FCY]LEGCPY
#&   , [F:IDP]ID0       = [F:CTRP]REFNUM
#&   , [F:ACC]CODACC   = GUSER;[F:IDP]CODACS
#&   , [F:TIM]TIM0     = [F:CNG]TIM
#&   , [F:ACC1]CODACC  = GUSER;[F:TIM]ACS
#&   As [LNK]
#    Endif
#  Endif
#MIPEA - 2017-06-07- US X3-43919- END
#JASMI - 2014-09-22 - US2983 - END

#MIPEA - 2017-06-07- US X3-43919- START
  Filter [F:LNK] Where evalue ([L]CRITERE) & evalue([L]CRITERE0) & evalue([L]CRITERE1)
&                & evalue([L]CRITERE2)
&                Order By Key CLE = [F:CNG]YEA Desc;[F:HRCTRP]REFNUM;[F:HRCTRP]CTRNUM
#  Filter [F:LNK] Where evalue ([L]CRITERE) & evalue([L]CRITERE0) & evalue([L]CRITERE1)
#&                & evalue([L]CRITERE2)
#&                Order By Key CLE = [F:CNG]YEA Desc;[F:CTRP]REFNUM;[F:CTRP]CTRNUM
#MIPEA - 2017-06-07- US X3-43919- END

  Raz I
  Local Integer CREAGLOB
  Gosub INIT_CHECK_SUBORD From DIVPAYE
  For [LNK]
    If(I>=dim([L]REFNUM)) : Break : Endif
    # SEGAY 19/03/12 80844 problème d'initialisation de mkstat
  # FQ81317 - SEGAY 03/04/12 - On ne fait pas de test sur TYPCP car coté X3 on peut saisir les deux CPA et CPE
    [L]WOK = 1
 # FQ76178 US1931 - SEGAY 18/09/12 - On fait le test sur TYPCP pour CPE et CPA idem dans CNSCNGSTD, CNSCCSTD et GETLSTCCG de PORTPS
    If [L]WTIM = "CP"        : # transcription du code CP en dur
#MIPEA - 2017-06-07- US X3-43919- START
      Call VERIF_TYPCP([F:HRCTRP]ETRFCY,[L]WCPA,[L]WCPE,[F:CNG]TIM,[L]WOK) From CNSCNGSTD
#      Call VERIF_TYPCP([F:CTRP]ETRFCY,[L]WCPA,[L]WCPE,[F:CNG]TIM,[L]WOK) From CNSCNGSTD
#MIPEA - 2017-06-07- US X3-43919- END
    Endif
    If [L]WOK
 # END FQ76178
      # FQ88082 - SEGAY 23/04/13 test ACS de TIM
      If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
#MIPEA - 2017-06-07- US X3-43919- START
        Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[F:HRCTRP]REFNUM,[F:HRCTRP]CTRNUM,STAT) From DIVPAYE
#        Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[F:CTRP]REFNUM,[F:CTRP]CTRNUM,STAT) From DIVPAYE
#MIPEA - 2017-06-07- US X3-43919- END
        If STAT  : # Si STAT=1 pas d'accès
           [L]WOK=0
        Endif
      Endif
      mkstat=0
      # END FQ88082
    Endif : # FQ76178
    If [L]WOK
      # FQ89905 - modification GFLXPORTPS par GFLXPORCCG
#MIPEA - 2017-06-07- US X3-43919- START
      Call CHECK_SUBORD([F:HRCTRP]REFNUM,"",[V]GFLXPORCCG,[31/12/9999])From DIVPAYE
#      Call CHECK_SUBORD([F:CTRP]REFNUM,"",[V]GFLXPORCCG,[31/12/9999])From DIVPAYE
#MIPEA - 2017-06-07- US X3-43919- END
      If !mkstat
#MIPEA - 2017-06-07- US X3-43919- START
        [L]CNGYEA(I) = num$([F:CNG]YEA)
        [L]REFNUM(I) = [F:HRCTRP]REFNUM
        [L]CTRNUM(I) = [F:HRCTRP]CTRNUM
        [L]CTRDAT(I) = [F:HRCTRP]CTRDAT : # FQ89905 - SEGAY 23/05/13 Test sur date contrat
#        [L]CNGYEA(I) = num$([F:CNG]YEA)
#        [L]REFNUM(I) = [F:CTRP]REFNUM
#        [L]CTRNUM(I) = [F:CTRP]CTRNUM
#        [L]CTRDAT(I) = [F:CTRP]CTRDAT : # FQ89905 - SEGAY 23/05/13 Test sur date contrat
#MIPEA - 2017-06-07- US X3-43919- END
#JASMI - 2014-09-22 - US2983 - START
#        [L]DEBDAT(I) = [F:CNG]DEBDAT
#        [L]FINDAT(I) = [F:CNG]FINDAT
#MIPEA - 2017-06-07- US X3-43919- START
        If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#        If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2017-06-07- US X3-43919- END
          [L]DEBDAT(I) = [F:CNE]EMPLEASTR
          [L]FINDAT(I) = [F:CNE]EMPLEAEND
        Else
          [L]DEBDAT(I) = [F:CNG]DEBDAT
          [L]FINDAT(I) = [F:CNG]FINDAT
        Endif
#JASMI - 2014-09-22 - US2983 - END
        [L]TIM(I)    = [F:CNG]TIM
        [L]NAME(I)   = [F:IDP]NAM-[F:IDP]SRN

#MIPEA - 2017-06-07- US X3-43919- START
        Call CNG_ACCOUNT([F:HRCTRP]REFNUM,[F:HRCTRP]CTRNUM,[F:HRCTRP]CTRDAT,[F:CNG]TIM,[F:HRCTRP]ETRFCY,[L]DATPYR
&                     ,[L]WYEA,[L]WACQ,[L]WPRI,[L]WVLD,[L]WATT,[L]WSLD,[L]WSLDMIN) From CNSCNGSTD

        # FQ76186 - MABON 19/09/11 - On retourne la date de paie du dernier bulletin du salarié répondant aux critètes
        Filter [HSP] Where [HSP]EMP    =  [F:HRCTRP]REFNUM
&                      & [HSP]DAT    <= [L]DATPYR
&                      & [HSP]DAT    >= [F:HRCTRP]CTRDAT
&                      & [HSP]TYP    =  6
&                      & [HSP]CTRNUM =  [F:HRCTRP]CTRNUM
&                  Order By Key HSP1
#        Call CNG_ACCOUNT([F:CTRP]REFNUM,[F:CTRP]CTRNUM,[F:CTRP]CTRDAT,[F:CNG]TIM,[F:CTRP]ETRFCY,[L]DATPYR
#&                     ,[L]WYEA,[L]WACQ,[L]WPRI,[L]WVLD,[L]WATT,[L]WSLD,[L]WSLDMIN) From CNSCNGSTD
#
#        # FQ76186 - MABON 19/09/11 - On retourne la date de paie du dernier bulletin du salarié répondant aux critètes
#        Filter [HSP] Where [HSP]EMP    =  [F:CTRP]REFNUM
#&                      & [HSP]DAT    <= [L]DATPYR
#&                      & [HSP]DAT    >= [F:CTRP]CTRDAT
#&                      & [HSP]TYP    =  6
#&                      & [HSP]CTRNUM =  [F:CTRP]CTRNUM
#&                  Order By Key HSP1
#MIPEA - 2017-06-07- US X3-43919- END
        Read [HSP] Last
        [L]DATPAY(I)=[F:HSP]DAT
        Filter [F:HSP]
        # Fin MABON
        [L]DATPYR=[L]DATSEL : # FQ76186 - MABON 12/09/11 - La date trouvée pour le 1er salarié ne doit pas servir de référence pour les autres salariés
        # On recupère un tableau des années concernées par DATSEL, on ne garde que celle courante
        For J=0 To dim(WYEA)-1
          If WYEA(J) = [F:CNG]YEA
            [L]ACQ(I) = WACQ(J)
            [L]PRI(I) = WPRI(J)
            [L]VLD(I) = WVLD(J)
            [L]ATT(I) = WATT(J)
            [L]SLD(I) = WSLD(J)
            Break
          Endif
        Next J
        I+=1
      Endif
    Endif
  Next
  [L]DATPYR=SAU_DATPYR : # FQ76186 - MABON 20/09/11 - Pour ressortir avec la date de départ
  If CREAGLOB :  Kill GDONOTCLOSE , GSVFLUX , GTTYPMGR : Endif
  Filter [F:LNK]
  Columns [F:IDP]

End
#end 72629
