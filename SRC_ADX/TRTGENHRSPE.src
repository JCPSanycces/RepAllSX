$ACTION
  Case ACTION
    When "INIT"      :    Gosub INIT
    When "OK"        :    Gosub EXEC
    When "END"       :    Gosub END_DEC
    When "TERMINE"   :    Gosub TERMINE
    When "DEBUT"     :    Gosub DEBUT
    #When "EXEC"      :    Gosub EXEC
    When Default
  Endcase

Return

$DEBUT
  [M:HRSPE0]ALLCPY = 2
  [M:HRSPE0]ALLFCY = 2
  If !GIMPORT Then Affzo [M:HRSPE0]ALLCPY,ALLFCY : Endif
  Grizo [M:HRSPE0]CPY,FCY
Return


$INIT
  Call LECMEMO("STD","[M:HRSPE0]","xgme") From GMEMO
Return

$TERMINE
  End

Return

$EXEC

Local Mask GENHRSPE0 [M:HRSPE0]
#######################
Local Integer A,B,C,D,E
Local Char ENREG(19)
Local Char ENREG1(241)
Local Char TYP
Local Char CNSSPLA
Local Char CNSSSAL
Local Char CNSSJRS
Local Date XDATPAY
Local Integer LPERIODE
Local Integer LNUMAFFIL
Local Integer I
Local Integer MM
Local Integer AAAA
Local Decimal REVERS ,REL , PLAF  ########variable  bloc B02
Local Char PATH (250)
Local Char MOI
Local Char ANN
Local Date DENT
Local Integer OK
Local Char MATRICULE
Local Integer YEXIT : Raz YEXIT
Local Char XCRIT(250)
Local Char XCRIT1(250)
Local Char XSALREEL,XSALPLAF

Gosub OPEN_FILE
#Période

  LPERIODE=val(format$("N0:6X",format$("D:YYYYMM", [M:HRSPE0]ENDDAT)))

#LIPET - 2018-03-26 - X3-84020 - START
  # Codes cumul CNSS
#  CNSSPLA=func AFNC.PARAM("CNSSPLA","")
#  CNSSSAL=func AFNC.PARAM("CNSSSAL","")
#  CNSSJRS=func AFNC.PARAM("CNSSJRS","")
  CNSSPLA=func AFNC.PARAM("CNSSPLA","MAR")
  CNSSSAL=func AFNC.PARAM("CNSSSAL","MAR")
  CNSSJRS=func AFNC.PARAM("CNSSJRS","MAR")
#LIPET - 2018-03-26 - X3-84020 - END
  If CNSSPLA="" or CNSSSAL="" or CNSSJRS="" Then
    GMESSAGE = mess(47,11706,1) #DEHEN - 2016-08-22 : Text replaced with message
    mkstat = 2 : End
  Endif

  ################ALIMENTATION DU FICHIER SORTIE ######### / POWER OUTPUT FILE
  Update[HRSDM1] Where PER=[L]LPERIODE With RECTYP="B00", CAT="B0"

  If [M:HRSPE0]CPY <> "" Then
    Read [CPY]CPYAFR0 =[M:HRSPE0]CPY
    If !fstat Then
       #LNUMAFFIL=val([CPY]RETFDSNUM)
       LNUMAFFIL=val([CPY]SOCSCTNUM) #DEHEN - Replaced RETFDSNUM with SOCSCTNUM of Company
    Endif
    Read [HRSSA1]HRSSA0=LNUMAFFIL;[L]LPERIODE
    If !fstat Then
      Update[HRSSA1] Where PER=[L]LPERIODE With RGTTYP="B01"
    Endif
  Else
    Update[HRSSA1] Where PER=[L]LPERIODE With RGTTYP="B01"
    Read[HRSSA1]Last
    #LPERIODE=[HRSSA1]LPERIOD   #correction richbond 26/05/2015
    LNUMAFFIL=[HRSSA1]CPYAFFNUM
 Endif

  Filter [CPY]
  MM = val(right$(num$([HRSSA1]PER), 5))
  AAAA=val(left$(num$([HRSSA1]PER), 4))

  XCRIT="1=1"
  If [M:HRSPE0]CPY<>""
     XCRIT +="& [ID]CPY=[M:HRSPE0]CPY"
  Endif
  If [M:HRSPE0]FCY<>""
     XCRIT +="& [ID]FCY=[M:HRSPE0]FCY"
  Endif
  If [M:HRSPE0]CRI <> "" Then
   XCRIT1 =[M:HRSPE0]CRI
  Else
    XCRIT1 ="1=1"
  Endif
  #----------------DEBUT--BLOC02

  For[HRSSC1] Where [HRSSC1]PER=[L]LPERIODE and [HRSSC1]CPYAFFNUM=[L]LNUMAFFIL

    [HRSSC1]NUMDAY=0
    [HRSSC1]ACTSAL=0
    [HRSSC1]SALCLG =0
    Local Decimal FALLOC
    FALLOC=0
    OKB=0
    Raz[HRSSC1]STA
    [HRSSC1]RGTTYP="B02"
  ###[HRSSC1]REVSER=[HRSSC1]NETPAY
  ##Read[ID]ID99=num$([HRSSC1]SSCNUM)

    Raz MATRICULE
    Filter [F:ID]
    For [ID] Where  [ID]NUMSSC = num$([HRSSC1]SSCNUM) & evalue(XCRIT) & evalue(XCRIT1)
      [HRSSC1]CPY=[ID]CPY
      [HRSSC1]FCY=[ID]FCY
      For [VEP] Where EMP= [ID]REFNUM and  PYRDAT<=eomonth(gdat$(1,MM,AAAA)) and PYRDAT >=(gdat$(1,MM,AAAA))
        MATRICULE=[VEP]EMP
        Break 2
      Next
    Next
    Filter [HSP] Where EMP= MATRICULE and  DAT<=eomonth(gdat$(1,MM,AAAA)) and DAT >=(gdat$(1,MM,AAAA))
    For[HSP]
      [HRSSC1]REVSER=0
      XDATPAY=[HSP]DAT
      Break
    Next
    For[HSP] Where TYP=6
      Case [HSP]RUB
      When CNSSPLA : [HRSSC1]SALCLG +=[HSP]AMT#[HSP]AMT*100 : ### SAL PLAF
      When CNSSSAL : [HRSSC1]ACTSAL +=[HSP]AMT#[HSP]AMT*100 : ### IDEM SAL BRUT
      When CNSSJRS : [HRSSC1]NUMDAY +=[HSP]AMT  : ### A MODIFIER DEMANDER ISSAM NBJ FISCAUX
      When Default
      Endcase
    Next

    ###If[HRSSC1]NETPAY>=FALLOC   : [HRSSC1]REVSER+=([HRSSC1]NETPAY-FALLOC)  : endif
    If [HRSSC1]ACTSAL<50000 :  [HRSSC1]REVSER=[HRSSC1]NETPAY
    #########elsif [HRSSC1]STA="XX" : [HRSSC1]STAHRSSC1: [HRSSC1]REVSER=[HRSSC1]NETPAY
    #########elsif [HRSSC1]STA<>""  : [HRSSC1]REVSER=[HRSSC1]NETPAY  :
    #########else : [HRSSC1]REVSER=0
    Endif

  #If [HRSSC1]SALCLG > 0 and [HRSSC1]STA ='' Then
  #      [HRSSC1]STA="  "
  #  Elsif [HRSSC1]SALCLG = 0 and [HRSSC1]STA =''
  #      [HRSSC1]STA="SO" #SO automatiquement pour les salariÃ©s qui n'ont pas de salaire, risque ?????
  #  Endif
   #Endif
    Filter [F:ID]
  #JASMI
    For  [ID] Where  [ID]NUMSSC = num$([HRSSC1]SSCNUM) & evalue(XCRIT) & evalue(XCRIT1)
      Read [ID2]EAF0 = [ID]REFNUM
  #JASMI
      If [ID2]SSCSIT <>'' and  [HRSSC1]SALCLG = 0 Then
        [HRSSC1]STA=[ID2]SSCSIT
        Break
      Endif
      If  [ID2]SSCSIT='' and [HRSSC1]SALCLG > 0 Then
      #JASMI - 2016-10-11 - JIRA 2595 - START
#        [HRSSC1]STA="  " : Break
        [HRSSC1]STA="" : Break
      #JASMI - 2016-10-11 - JIRA 2595 - END
      Endif
    Next

    #####conversion lsituation#######
    Local Integer SIT
    Case [HRSSC1]STA
    When "  " : SIT=0
    When "SO" : SIT=1
    When "DE" : SIT=2
    When "IT" : SIT=3
    When "IL" : SIT=4
    When "AT" : SIT=5
    When "CS" : SIT=6
    When "MS" : SIT=7
    When "MP" : SIT=8
    When Default
    Endcase

    ##################################"
    If [HRSSC1]NUMDAY>26 :[HRSSC1]NUMDAY=26 : Endif

    Raz XSALREEL,XSALPLAF
    XSALREEL=num$([HRSSC1]ACTSAL)
    XSALPLAF=num$([HRSSC1]SALCLG)
#DEHEN - XCALC_SAL placed into code - START
    #Call XCALC_SAL(XSALREEL) From XGXMJ
    #Call XCALC_SAL(XSALPLAF) From XGXMJ

    Call XCALC_SAL(XSALREEL)
    Call XCALC_SAL(XSALPLAF)
#DEHEN - XCALC_SAL placed into code - END

    ##[HRSSC1]CTLFLD= [HRSSC1]SSCNUM + [HRSSC1]REVSER+[HRSSC1]TOTDAY+[HRSSC1]ACTSAL+[HRSSC1]SALCLG+SIT
    [HRSSC1]CTLFLD = [HRSSC1]SSCNUM + [HRSSC1]REVSER+[HRSSC1]NUMDAY+val(XSALREEL)+val(XSALPLAF)+SIT

    [HRSSC1]RSVFLD=space$(104)
    Filter
    Rewrite[HRSSC1]
    If fstat Then
      Call FSTA("HRSSC1") From GLOCK
      GOK=0  :  Break
    Endif
    Filter [HSP]
  Next
  #----------------DEBUT BLOC  B03

    For[HRSSB1] Where PER=[L]LPERIODE and [HRSSB1]CPYAFFNUM=[L]LNUMAFFIL #correction 26/05 richbond
        Raz[HRSSB1]TOTREV
        Raz[HRSSB1]TOTDAY
        Raz[HRSSB1]TOTWAG
        Raz[HRSSB1]TOTSALCLG
        Raz[HRSSB1]NUMEMP
        Raz[HRSSB1]CTLFLD
        Raz[HRSSB1]NUMMAT
        Raz [HRSSB1]NUMEMP  #correction 26/05/2015 richbond
        For[HRSSC1] Where PER=[L]LPERIODE and [HRSSC1]CPYAFFNUM=[L]LNUMAFFIL #(filter sur NUMAFFIL :correction 26/05/2015 richbond)
            [HRSSB1]TOTREV+=[HRSSC1]REVSER
            [HRSSB1]TOTDAY+=[HRSSC1]NUMDAY
            [HRSSB1]TOTWAG+=[HRSSC1]ACTSAL
            [HRSSB1]TOTSALCLG+=[HRSSC1]SALCLG
            [HRSSB1]NUMEMP+=[HRSSC1]NUMCHD
            [HRSSB1]CTLFLD +=[HRSSC1]CTLFLD
            [HRSSB1]NUMMAT+=[HRSSC1]SSCNUM
            [HRSSB1]NUMEMP+=1
        Next
       [HRSSB1]RGTTYP="B03"
       [HRSSC1]RSVFLD=space$(116)
       Rewrite [HRSSB1]
       If fstat Then
         Call FSTA("HRSSB1") From GLOCK
         GOK=0  :  Break
       Endif
    Next
    #---------------DEBUT BLOC B04

Local Char MOI
Local Char ANN
Local Date DENT
Local Integer OK
Local Integer YEXIT : Raz YEXIT
OK4=0
 ANN=left$( num$(LPERIODE), 4 )
 MOI= right$( num$(LPERIODE), 5 )
If val(ANN) <> 0 and val(MOI) <> 0 Then
    DENT =gdat$(1,val(MOI),val(ANN))
Endif
Filter[CPY] Where SOCSCTNUM=LNUMAFFIL

Filter [F:ID]
#JASM
#For[ID]EAF0 Where evalue(XCRIT) & evalue(XCRIT1) and SSCFDS =2 # MODIF 31/12/2014
  Link [ID] With [ID2]EAF0 = [ID]REFNUM As [LNK]
  Filter [LNK] Where evalue(XCRIT) & evalue(XCRIT1) and [ID2]SSCFDS =2 # MODIF 31/12/2014
  For [LNK]
#JASM
  YEXIT=0
  For[HRSSC1]Where SSCNUM=val([ID]NUMSSC)
     YEXIT=1 :  Break
  Next
  If YEXIT=0 Then
    #Read [CTR]CT99=[AD]REFNUM
    Filter [CTR] Where REFNUM=[ID]REFNUM Order By CTRDAT Desc
    Read  [CTR]First
    If fstat=0 and  [CTR]CTRDAT<= eomonth(DENT)
     #Read [CTR]CT99= [ID]REFNUM
       Filter [CTR] Where REFNUM=[ID]REFNUM Order By CTRDAT Desc
       Read  [CTR]First
         If fstat=0
             If 1=1
                [HRSIB1]SSCNUM=val([ID]NUMSSC)
                #Read[HRSSC1]HRSSC0=[HRSIB1]SSCNUM  Z.Meryame 20/10/2014
                #For [HRSSC1] Where [HRSSC1]SSCNUM=[HRSIB1]SSCNUM and [HRSSC1]CPY=[M:HRSPE0]CPY and [HRSSC1]FCY=[M:HRSPE0]FCY #modif 31/12/14

                #If fstat Then  Z.Meryame 20/10/2014
#JASMI
#                 Read[ID]EAF0=[ID]REFNUM
#                 If fstat=0
#JASMI
                     [HRSIB1]SSCNUM = 0
#JASMI
#                     [HRSIB1]FULNAM=[ID]NAM+" "+[ID]SRN #EMPLOID = NAM & SRN
                     [HRSIB1]NAM=[ID]NAM+" "+[ID]SRN #EMPLOID = NAM & SRN
#JASMI
                     #If [AD]XNUMCNSS<>0 & [AD]SSCFDS=1 : :  Endif
                     [HRSIB1]SSCNUM =val([ID]NUMSSC)
                     [HRSIB1]TPYSOCNUM =[ID2]TPYSOCNUM #EMPLOID = ID Number
#JASMI
#                  Endif
#JASMI
                [HRSIB1]NUMDAY=0
                [HRSIB1]SAL=0
                [HRSIB1]SALCLG=0
                [HRSIB1]PER=LPERIODE
                [HRSIB1]CPYAFFNUM=LNUMAFFIL
                #Filter [HSP] Where EMP= [ID]REFNUM  and  DAT<=eomonth(DENT) and DAT>=DENT
                #Read[HSP]HSP0 First
                #XDATPAY=[HSP]DAT
                  Filter [HSP]
                  For[HSP] Where EMP= [ID]REFNUM  and  DAT<=eomonth(DENT) and DAT>=DENT and  TYP=6
                  ####OK4=1
                  Case [HSP]RUB

                       When CNSSPLA : [HRSIB1]SALCLG  +=[HSP]AMT#[HSP]AMT*100 : ### SAL PLAF
                       When CNSSSAL : [HRSIB1]SAL   +=[HSP]AMT#[HSP]AMT*100 : ### SAL BRUT
                       When CNSSJRS : [HRSIB1]NUMDAY +=[HSP]AMT  : ### NOMBRE JOURS CNSS
                       When Default
                  Endcase
                 Next
                   Filter [HSP] Where EMP= [ID]REFNUM  and  DAT<=eomonth(DENT) and DAT>=DENT

                   Read[HSP]HSP0 First
                   XDATPAY=[HSP]DAT
                   Filter[HSP]

                    Raz XSALREEL,XSALPLAF
                    XSALREEL=num$([HRSIB1]SAL)
                    XSALPLAF=num$([HRSIB1]SALCLG)
                    #Call XCALC_SAL(XSALREEL) From XGXMJ
                    #Call XCALC_SAL(XSALPLAF) From XGXMJ

                    Call XCALC_SAL(XSALREEL)
                    Call XCALC_SAL(XSALPLAF)

                    ##[HRSIB1]SCTR= [HRSIB1]SSCNUM +[HRSIB1]NUMDAY+[HRSIB1]SAL+[HRSIB1]SALCLG
                    [HRSIB1]CTLFLD = [HRSIB1]SSCNUM +[HRSIB1]NUMDAY+val(XSALREEL)+val(XSALPLAF) #need to revise

                    [HRSIB1]RSVFLD=space$(124)
                    If  [HRSIB1]NUMDAY<>0
                        Read [HRSSC1]HRSSC0=[HRSIB1]SSCNUM;[L]LPERIODE
                         If fstat Then   #Entrants
                            Write[HRSIB1]
                            OK4=1
                        Endif
                    Endif

            #Next
Endif
Endif
Endif
Endif
Next

Filter [AD]

    #----------------------------BLOC B05
    Local Integer J
    J=0

    Raz[HRSIA1]

#DEHEN - Code was comment out in VM, duplicate key errors  - START
    For[HRSIA1]
      Delete[HRSIA1] Where PER=[L]LPERIODE
    Next
#DEHEN - Code was comment out in VM, duplicate key errors  - END
#DEHEN - Code not in source, but placed in to clear table for duplicate key error - START
    Raz[HRSSS1]

    For[HRSSS1]
      Delete[HRSSS1] Where PER=[L]LPERIODE
    Next
#DEHEN - Code not in source - END
    For[HRSIB1]  Where PER=[L]LPERIODE and [HRSIB1]CPYAFFNUM=[L]LNUMAFFIL #correction 26/04 richbond
        J+=1
        ###
        [HRSIA1]TOTDAY+=[HRSIB1]NUMDAY
        [HRSIA1]TOTWAG+=[HRSIB1]SAL
        [HRSIA1]TOTSALCLG+=[HRSIB1]SALCLG
        [HRSIA1]CTLFLD +=[HRSIB1]CTLFLD
        [HRSIA1]NUMMAT +=[HRSIB1]SSCNUM
    Next
        [HRSIA1]NUMEMP=J
        [HRSIA1]PER=LPERIODE
        [HRSIA1]CPYAFFNUM=LNUMAFFIL
        [HRSIA1]RGTTYP="B05"
        [HRSIA1]RSVFLD=space$(170)
    Write [HRSIA1]
    If fstat Then
         Call FSTA("HRSIA1") From GLOCK
         GOK=0
    Endif

    #--------------------------------BLOC B06
    Read[HRSSB1]HRSSB0=LNUMAFFIL;[L]LPERIODE
    #Read[HRSIA1]HRSIA0=LNUMAFFIL;[L]LPERIODE
    [HRSSS1]TOTDAY=[HRSSB1]TOTDAY+[HRSIA1]TOTDAY
    [HRSSS1]TOTWAG=[HRSSB1]TOTWAG+[HRSIA1]TOTWAG
    [HRSSS1]TOTSALCLG=[HRSSB1]TOTSALCLG+[HRSIA1]TOTSALCLG
    [HRSSS1]CTLFLD =[HRSSB1]CTLFLD + [HRSIA1]CTLFLD
    [HRSSS1]NUMMAT =[HRSSB1]NUMMAT+[HRSIA1]NUMMAT
    [HRSSS1]NUMEMP=[HRSSB1]NUMEMP +[HRSIA1]NUMMAT
    [HRSSS1]PER=LPERIODE
    [HRSSS1]CPYAFFNUM=LNUMAFFIL
    [HRSSS1]RGTTYP="B06"
    [HRSSS1]RSVFLD=space$(170)
    Write [HRSSS1]
    If fstat Then
         Call FSTA("HRSSS1") From GLOCK
         GOK=0
    Endif


Filter [AD] Where evalue ("1=1")

Return

$OK_DEC
  FIN=1
Return
################################################################################
$END_DEC
Raz [M:HRSPE0]
  FIN=1
Return


$OPEN_FILE

  If clalev([F:HRSDM1])=0 : Local File HRSTADLM [HRSDM1] : Endif
  If clalev([F:HRSSA1])=0 : Local File HRSOCSECSET1 [HRSSA1] : Endif
  If clalev([F:HRSSC1])=0 : Local File HRSOCSECSET3 [HRSSC1] : Endif
  If clalev([F:HRSSB1])=0 : Local File HRSOCSECSET2 [HRSSB1] : Endif
  If clalev([F:HRSIB1])=0 : Local File HRSOCSECINC2 [HRSIB1] : Endif
  If clalev([F:HRSIA1])=0 : Local File HRSOCSECINC1 [HRSIA1] : Endif
  If clalev([F:HRSSS1])=0 : Local File HRSOCSECSETS [HRSSS1] : Endif
  If clalev([F:AD])=0  : Local File EMPLOAD [AD]       : Endif
  If clalev([F:HSP])=0 : Local File HISTOPAYE [HSP]    : Endif
  If clalev([F:CTR])=0 : Local File EMPLOCTRAFR [CTR]  : Endif
#JASMI
  If clalev([F:ID])=0  : Local File EMPLOID [ID]    : Endif
  If clalev([F:ID2])=0 : Local File EMPLOIDAFR [ID2]      : Endif
#  If clalev([F:ID])=0  : Local File EMPLOIDAFR [ID]    : Endif
#  If clalev([F:ID2])=0 : Local File EMPLOID [ID2]      : Endif
#JASMI
  If clalev([F:CPY])=0 : Local File HRCOMPANYAFR [CPY] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY [FCY]     : Endif
  If clalev([F:VEP])=0 : Local File VALEMP [VEP]       : Endif

Return

#DEHEN - Renaming required - START
Subprog XCALC_SAL(XSALR)
Variable Char XSALR
If val(XSALR)<>0 Then

    Local Integer XI,XU : Raz XI,XU
    Local Char XDCM  : Raz XDCM
    For XI=1  To len(XSALR)
       If mid$(XSALR,XI,1)="." Then
          XU=XI
          XDCM=mid$(XSALR,XI+1,2) : Break
       Endif
    Next
    If val(XDCM)=0 Then
       XDCM="00"
    Else
      If len(XDCM)=1 Then
         XDCM=XDCM+"0"
      Elsif len(XDCM)>2 Then
         XDCM=mid$(XDCM,1,2)
      Endif
    Endif

    If XU>0 Then
       XSALR=mid$(XSALR,1,XU-1)+XDCM
    Else
       XSALR=XSALR+XDCM
    Endif
Else
    XSALR="0"
Endif
End
#DEHEN - Renaming required - END
