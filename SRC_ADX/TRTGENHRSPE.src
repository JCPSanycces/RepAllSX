Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
   Raz [M:HRSPE0]CPY
   Grizo [M:HRSPE0]CPY
  Else
   Actzo [M:HRSPE0]CPY
  Endif
End

Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
   Raz [M:HRSPE0]FCY
   Grizo [M:HRSPE0]FCY
  Else
   Actzo [M:HRSPE0]FCY
  Endif
End


