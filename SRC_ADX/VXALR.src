#<AdxTL>@(#)1.0.0.0 $Revision$
####################################################################################
# Program Name: VXALR
# Description : ADC Location Replenishment Putaway
# Author      : TS/ HCB
# Date        : March, 2007 , 2013
####################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)

Call SAISIE_CHAR(VALEUR,PARAM,"VXALR","VXALR","XWVXALR") From GSAISIE
End

########################################################
# Location Replenishment Putaway
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# STOFCY, ITMREF,
# PCU, QTYPCU, STU, QTYSTU, PCUSTUCOE
# STA, LOC, LOT, SLO, PALNUM, CTRNUM, SERNUM, SERNUMF
#
# VXALR is the VT screen
#
########################################################

########################################################
$ACTION

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "BOUTON"        : Gosub BOUTON
 When "AVANT_OK"      : Gosub AVANT_OK
 When "OK"            : Gosub OK
 When "FIN"           : Gosub FIN
Endcase

Return

########################################################
# Actions liées à la fenètre de saisie
########################################################

########################################################
$OUVRE

GVTMOD=1

If clalev([M:ASYW])=0  Local Mask VXASYW [ASYW]  Endif
If clalev([M:REO1])=0  Local Mask REO1   [REO1]  Endif
If clalev([M:SRO1])=0  Local Mask SRO1   [SRO1] Endif  # ecran parametrage pour calcul de l origine
If clalev([M:ALP]) =0  Local Mask ALLPAR [ALP]   Endif   # hcb 101608

# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC

Gosub OUVRE From TRTREOA
OK=1

Return

########################################################
$DEBUT
Local  Integer INOL, LRET, LNBR, LNBJ
Local  Integer WRESTSTA
Local  Decimal LQTA, LSHT
Local  Char    WVCRNUM(GLONVCR)
Local  Integer WVCRLIN


Global Char    SYMBOLREA

If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN=1 : Return
Endif
GFLAG = func ENVADC.SETTRANS(9)

[M:XALR]SRTNUM = GFLAG

Gosub INIT_SCREEN

GSRTNUM = GFLAG
GREONUM = GFLAG

[M:SRO1]LOCREO    = [F:SRT]LOCREO
[M:SRO1]CSMREO    = [F:SRT]CSMREO
[M:SRO1]SHTREO    = [F:SRT]SHTREO
Gosub ANA_ORIGINE From SUBSRO

Return

########################################################
$SETBOUT

If !find("O",CHBOU) CHBOU+="O" Endif
If !find("2",CHBOU) CHBOU+="2" Endif

Gosub SET_BOUT_SPE From GSAISIE

Return

#########################################################
$APRES_MODIF

If find(COUZON,"VCRNUM")

   Raz [M:ASYW]
   # Chargement de l'écran de travail VXASYW
   Gosub ALI_ASYW

   INOL=0
   # Chargement de l'écran de saisie VXALR
   Gosub ALI_XALR
   If OK=0
      mkstat=2 : Return
   Endif
   zonsui="QTYPCU"
Endif

Return


########################################################
$AVANT_OK
Return

########################################################
$OK
# Pour interdire la navigation
GREP="C"
FIN = 0
Call DEBTRANS From GLOCK
Trbegin [REO]

Case [M:ASYW]ORIREO(INOL)
   When 1,2,3
      # Si la quantité a été modifiée, réécriture de l'allocation
      If [M:XALR1]QTYSTU<>[M:XALR1]QTYSTUORI
         LQTA=[M:XALR1]QTYSTU-[M:XALR1]QTYSTUORI
         Call MODALL([M:XALR]STOFCY,[M:XALR1]ITMREF,[M:ASYW]STOCOU(INOL),
&                    [M:ASYW]SRGSEQ(INOL),LQTA,LRET) From STKALL
         If LRET<>0
            Rollback
            GERR=1 : Return
         Endif
      Endif
   When Default
Endcase

# Numero document réappro zone consommation
Call NUMERO(GSTKCPT(19),[M:XALR]STOFCY,date$,[M:XALR1]ITMREF,WVCRNUM,LRET) From SUBANM
If LRET<>0
   GERR=1
   If LRET=1
      Call ERREUR(mess(842,196,1)) From GESECRAN
   Elsif LRET=2
      Call ERREUR(mess(30,196,1))  From GESECRAN
   Endif
   Rollback : Return
Endif

# Initialisation de l'en-tête
Raz [M:STW]
[M:STW]STOFCY    = [M:XALR]STOFCY
[M:STW]TRSTYP    = 25
[M:STW]VCRTYP    = 34
[M:STW]VCRNUM    = [M:XALR]VCRNUM
[M:STW]VCRLIN    = [M:XALR1]VCRLIN
[M:STW]ITMREF    = [M:XALR1]ITMREF
[M:STW]LOCENT    = [M:XALR1]LOCORI
[M:STW]MVTDES    = [M:XALR1]MVTDES
[M:STW]BPRNUM    = [M:XALR1]BPRNUM
[M:STW]CUR       = GLOCALDEV
[M:STW]IPTDAT    = date$
[M:STW]PRIORDH   = 0
[M:STW]PJT       = ""
[M:STW]ENTCOD    = ""
[M:STW]CCECOD    = ""
[M:STW]TRSCOD    = ""
[M:STW]TRSFAM    = ""
[M:STW]TRSCOD    = [F:SRT]TRSCOD
[M:STW]TRSFAM    = [F:SRT]TRSFAMDEF
[M:STW]ENTCOD    = [F:SRT]ENTCOD

# Pour ne traiter que cette allocation
[M:STW]STOCOU(0) = [M:ASYW]STOCOU(INOL)
[M:STW]SEQ       = [M:ASYW]SRGSEQ(INOL)
Call ALISTOWORK(11,0,LQTA,LSHT,LNBR,LNBJ,LRET ) From STKINT

[M:STW]VCRTYP  = 34
[M:STW]VCRNUM  = WVCRNUM
[M:STW]VCRLIN  = 100
WVCRLIN        = 100
# Mise à jour des stock
If LRET=0
   Call MAJ_STOCK From STKMAJ
Endif
If LRET<>0 | GOK<1
   LRET=1 : Rollback : Return
Endif
Case [M:ASYW]ORIREO(INOL)
   When 1

      Readlock [F:REO]REO0=[M:XALR]STOFCY;[M:XALR1]LOCORI;[M:XALR1]ITMREF
      If fstat
         Call RSTA("REO",[M:XALR]STOFCY-[M:XALR1]LOCORI-[M:XALR1]ITMREF) From GLOCK
         LRET=1 : Rollback : Return
      Endif

# Reste t-il des allocations sur ce besoin de réappro ?
      Filter [STA] Where VCRTYP=34 & VCRNUM=[M:XALR]VCRNUM & VCRLIN=[M:XALR1]VCRLIN
      Read [STA]First
      If fstat
         WRESTSTA=0
      Else
         WRESTSTA=1
      Endif
      Filter [STA]

# Il reste des allocations ou pas de solde --> calcul des qtés restantes
      If WRESTSTA<>0 | [M:XALR1]CLEFLG<>2
         [F:REO]QTYSTUORIA -= [M:XALR1]QTYSTUORI
         [F:REO]QTYSTUACT  -= [M:XALR1]QTYSTU
         If [F:REO]DEFPOT<>0
            [F:REO]QTYSTU   = ([F:REO]QTYSTUACT*100)/[F:REO]DEFPOT
            Call QTEARR([F:REO]QTYSTU,[F:REO]STU) From TRTDIV
         Else
            [F:REO]QTYSTU    = [F:REO]QTYSTUACT
         Endif
         [F:REO]QTYPCU = [F:REO]QTYSTU
         [F:REO]PCU    = [F:REO]STU
         [F:REO]STAFLG = 1
         [F:REO]PCUSTUCOE = 1
         [F:REO]UPDDAT = date$
         [F:REO]UPDUSR = GUSER

      Endif
      If WRESTSTA = 0
         Raz [F:REO]VCRLIN
         Raz [F:REO]VCRNUM
         Raz [F:REO]VCRTYP
      Endif

# Plus d'allocation et (solde demandé ou toute la qté a été traitée)
      If WRESTSTA=0 & ([M:XALR1]CLEFLG=2 | [F:REO]QTYSTUACT<=0)
         Delete  [F:REO]
      Else
         Rewrite [F:REO]
      Endif
      If fstat
         Call RSTA("REO",[M:XALR]STOFCY-[M:XALR1]LOCORI-[M:XALR1]ITMREF) From GLOCK
         LRET=1 : Rollback : Return
      Endif
   When 3

      Local Decimal WQTYSTUORI
      Local Decimal WQTYSTUORIA
      Local Integer WRET
      Local Integer LMODALL

      Local Decimal WQTYSTU
      Local Decimal WQTYSTUACT
      Local Decimal WQTYSTUALL
      Raz WQTYSTU
      Raz WQTYSTUACT
      Raz WQTYSTUORI
      Raz WQTYSTUALL
      WRET=0
#                                                             hcb 101608  deb
      Local Decimal LSTOCOU
      Local Date    WDAT
#                                                             hcb 101608  end


# lecture rupture
      Read [STA]STA0=[M:XALR]STOFCY;[M:XALR1]ITMREF;
&                    [M:ASYW]STOCOUSTA(INOL);[M:ASYW]SEQSTA(INOL)
      If !fstat
         WQTYSTUORI     = [F:STA]QTYSTUACT

#                                                             hcb 101608  deb
         [M:ALP]VCRTYP = [F:STA]VCRTYP
         [M:ALP]VCRNUM = [F:STA]VCRNUM
         [M:ALP]VCRLIN = [F:STA]VCRLIN
         [M:ALP]VCRSEQ = [F:STA]VCRSEQ
         [M:ALP]BESDAT = [F:STA]BESDAT
         [M:ALP]ITMREF = [M:XALR1]ITMREF

         WDAT          = [F:STA]ALLDAT
                  # Boucle sur les changements d'emplacements (mvt +)
                  For [STJ]STJ1 Where STOFCY=GXAFCY & VCRTYP=34
&                                   & VCRNUM=WVCRNUM & VCRLIN=WVCRLIN & ACTQTY>0
                     #--- Issue X3-53322 : ajout LPN
                     # Recherche du chrono stock correspondant au mvt
                     Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,
&                                [F:STJ]BPSLOT,[F:STJ]PALNUM,[F:STJ]CTRNUM,
&                                [F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,[F:STJ]PCUSTUCOE,
&                                [F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                                [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,LSTOCOU)
&                                From STKLIB
                     # Création de l'allocation
                     If LSTOCOU<>0
                        If [F:STJ]QTYSTU > [M:XALR1]QTYSTUORI
                            WQTYSTUORI  =  [M:XALR1]QTYSTUORI
                            WQTYSTUORIA =  [M:XALR1]QTYSTUORIA
                        Else
                            WQTYSTUORI  = [F:STJ]QTYSTU
                            WQTYSTUORIA = [F:STJ]ACTQTY
                        Endif
                        #--- TS 106217 ajout paramètre LECC (avant dernier)
                        Call CREALL(2,[F:STJ]STOFCY,[F:STJ]ITMREF,LSTOCOU,WDAT,
&                                   WQTYSTUORI,WQTYSTUORIA,[M:ALP]VCRTYP,
&                                   [M:ALP]VCRNUM,[M:ALP]VCRLIN,[M:ALP]VCRSEQ,
&                                   "",[M:ALP]BESDAT,"","","","","",
&                                   "",0,0,"","","","",1,"",WRET) From STKALL
                        If WRET=0 [M:ALP]ALLQTY += WQTYSTUORIA Endif
                     Endif
                  Next

#                                                             hcb 101608  end



# Reste t-il des allocations sur cette rupture ?
         Filter [STA] Where STOFCY=GXAFCY & VCRTYP=34 &  ALLTYP=2  & SRGNUM =[M:XALR]VCRNUM & SRGLIN=[M:XALR1]VCRLIN
&           Order By [F:STA]VCRTYP Asc;[F:STA]ALLTYP Asc;[F:STA]SRGNUM Asc;[F:STA]SRGLIN Asc
            For [STA]
                WQTYSTU    += [F:STA]QTYSTU
                WQTYSTUACT += [F:STA]QTYSTUACT
            Next
         Filter [STA]

         If WQTYSTU = 0
         # Suppression de la rupture
             Call SUPALL([M:XALR]STOFCY,[M:XALR1]ITMREF,[M:ASYW]STOCOUSTA(INOL),
&                                [M:ASYW]SEQSTA(INOL),WRET) From STKALL
         Else
         # Diminution de la rupture (stoall 4)
            WQTYSTUALL = WQTYSTUORI
            WQTYSTUALL -= WQTYSTUACT
            WQTYSTUALL -=([M:XALR1]QTYSTUORI - [M:XALR1]QTYSTU)
            Call MODALL([M:XALR]STOFCY,[M:XALR1]ITMREF,[M:ASYW]STOCOUSTA(INOL),
&                       [M:ASYW]SEQSTA(INOL),[M:XALR1]QTYSTUORIA*-1,WRET) From STKALL

#  il ni avait plus d alloction on supprime la liste à ranger (stoall 4)
            If WRET = 0 & WQTYSTU = 0
                Readlock [STA]STA0=[M:XALR]STOFCY;[M:XALR1]ITMREF;
&                        [M:ASYW]STOCOUSTA(INOL);[M:ASYW]SEQSTA(INOL)
                If fstat
                   Call RSTA("STA",[M:XALR]STOFCY-[M:XALR1]ITMREF) From GLOCK
                   LRET=1 : Rollback : Return
                Endif
                Raz [F:STA]SRGNUM
                Raz [F:STA]SRGQTYSTU
                Raz [F:STA]SRGLIN
                Rewrite [F:STA]
                If fstat
                   Call RSTA("STA",[M:XALR]STOFCY-[M:XALR1]ITMREF) From GLOCK
                        LRET=1 : Rollback : Return
                Endif
            Endif
         Endif
      # Maj du document origine
         LMODALL=2
         Gosub MAJ_DOC From TRTSHTCOM
      Endif
   When Default
   Endcase
[M:ASYW]TRTFLG(INOL) = 2
Commit
#---- Régularisation des mouvements et alloc -----#
#--- Issue 113088 by TS
#Call REGFROMENT( 0, "XALR", "", "ITMREF", [M:XALR]STOFCY ) From TRTSHTCOM
Call REGFROMENT( 0, "XALR1", "", "ITMREF", [M:XALR]STOFCY ) From TRTSHTCOM
#---
# Passage à la ligne à ranger suivante
INOL+=1
While [M:ASYW]TRTFLG(INOL)=2
   INOL+=1
Wend

If INOL>[M:ASYW]NBLIG-1
   INOL=0
   If sum([M:ASYW]TRTFLG) >= [M:ASYW]NBLIG*2
      Call MESSAGE(mess(22,7750,1)) From GESECRAN
      Gosub INIT_SCREEN
      zonsui="VCRNUM"
      Return
   Else
      Call MESSAGE(mess(23,7750,1)) From GESECRAN
      While [M:ASYW]TRTFLG(INOL)=2
         INOL+=1
      Wend
      Gosub ALI_XALR
      If OK=0
         Gosub INIT_SCREEN
         zonsui="VCRNUM"
         Return
      Endif
      zonsui="QTYPCU"
   Endif
Else
   Gosub ALI_XALR
   If OK=0
      Gosub INIT_SCREEN
      zonsui="VCRNUM"
      Return
   Endif
   zonsui="QTYPCU"
Endif

[M:XALR]SRTNUM = GFLAG

Return

########################################################
$FIN

If SYMBOLREA<>""
   Unlock = SYMBOLREA
Endif

GVTMOD=0
GREP=""

Return

########################################################
$BOUTON

Case BOUT
 When "2" : If [M:ASYW]NBLIG=0 Return Endif
            INOL+=1
            While [M:ASYW]TRTFLG(INOL)=2
               INOL+=1
            Wend
            If INOL>[M:ASYW]NBLIG-1
               INOL=0
               If sum([M:ASYW]TRTFLG) >= [M:ASYW]NBLIG*2
                  Call MESSAGE(mess(22,7750,1)) From GESECRAN
                  Gosub INIT_SCREEN
                  zonsui="VCRNUM"
                  Return
               Else
                  Call MESSAGE(mess(23,7750,1)) From GESECRAN
                  While [M:ASYW]TRTFLG(INOL)=2
                     INOL+=1
                  Wend
                  Gosub ALI_XALR
                  If OK=0
                     Gosub INIT_SCREEN
                     zonsui="VCRNUM"
                     Return
                  Endif
                  zonsui="QTYPCU"
               Endif
            Else
               Gosub ALI_XALR
               If OK=0
                  Gosub INIT_SCREEN
                  zonsui="VCRNUM"
                  Return
               Endif
               zonsui="QTYPCU"
            Endif
Endcase

Return

########################################################
$INIT_SCREEN

# Remise à zero du masque STOSORW
Call DELSTOSORW(-1,0,"XALR",GXAFCY,LRET) From STKSOR

Raz [M:REO1]
[M:REO1]STOFCY = GXAFCY

Raz [M:XALR]
[M:XALR]STOFCY = [M:REO1]STOFCY
[M:XALR]SRTNUM = GFLAG

Affzo [M:XALR]1-99

Return

########################################################
# Chargement de l'écran de travail VXASYW
# avec les enregistrements STOALL de la liste à réappro
########################################################
$ALI_ASYW
Local Integer WORI
nolign=1
Filter [STA] Where STOFCY=GXAFCY & [F:STA]ALLTYP = 2 & [F:STA]SRGNUM=[M:XALR]VCRNUM
&  Order By [F:STA]ITMREF Asc;[F:STA]STOCOU Asc;[F:STA]SRGLIN Asc
For [STA]
   Raz WORI
# recherche si Reapprovision  orireo = 1
   Filter [REO] Where [F:REO]STOFCY = GXAFCY & [F:REO]VCRNUM =[F:STA]SRGNUM & [F:REO]VCRLIN =[F:STA]SRGLIN
&  Order By [F:REO]VCRLIN Asc
   For [REO]
       WORI = 1
       If GLOCREO = 2
          If nolign >= dim([M:ASYW]STOCOU)
             Call ERREUR(mess(53,184,1)-mess(232,184,1)) From GESECRAN
             Break
          Endif
          [M:ASYW] = [F:STA]
          [M:ASYW]SRGSEQ(nolign-1) = [F:STA]SEQ
          [M:ASYW]TRTFLG(nolign-1) = 1
          [M:ASYW]ORIREO(nolign-1) = 1
          nolign += 1
          Break
       Endif
   Next
   Filter [REO]
   If WORI = 0
# recherche si Rupture  orireo = 3
      Filter [STA1]Where [F:STA1]STOFCY = GXAFCY & [F:STA1]ALLTYP = 4 &[F:STA1]SRGNUM =[F:STA]SRGNUM & [F:STA1]SRGLIN =[F:STA]SRGLIN
&     Order By [F:STA1]SRGLIN Asc
      For [STA1]
          WORI = 1
          If GSHTREO = 2
             If nolign >= dim([M:ASYW]STOCOU)
                Call ERREUR(mess(53,184,1)-mess(232,184,1)) From GESECRAN
                Break
             Endif
             [M:ASYW] = [F:STA]
             [M:ASYW]SRGSEQ   (nolign-1) = [F:STA]SEQ
             [M:ASYW]STOCOUSTA(nolign-1) = [F:STA1]STOCOU
             [M:ASYW]SEQSTA   (nolign-1) = [F:STA1]SEQ
             [M:ASYW]TRTFLG   (nolign-1) = 1
             [M:ASYW]ORIREO   (nolign-1) = 3
             nolign += 1
             Break
       Endif
      Next
      Filter [STA1]
   Endif
   If GCSMREO = 2 & WORI = 0
# Consommation orireo = 2

       If nolign >= dim([M:ASYW]STOCOU)
          Call ERREUR(mess(53,184,1)-mess(232,184,1)) From GESECRAN
          Break
       Endif
       [M:ASYW] = [F:STA]
       [M:ASYW]SRGSEQ(nolign-1) = [F:STA]SEQ
       [M:ASYW]TRTFLG(nolign-1) = 1
       [M:ASYW]ORIREO(nolign-1) = 2
       nolign += 1
   Endif
Next
Filter [STA]
[M:ASYW]NBLIG = nolign-1
Return

########################################################
# Chargement de l'écran de saisie VXALR
# avec un élément de la liste à réappro ([M:ASYW] indicé par INOL)
########################################################
$ALI_XALR
OK=1
Read [STA]STA0=GXAFCY;[M:ASYW]ITMREF(INOL);[M:ASYW]STOCOU(INOL);[M:ASYW]SRGSEQ(INOL)
If fstat
   Call RSTA("STA",GXAFCY-[M:ASYW]ITMREF(INOL)-num$([M:ASYW]STOCOU(INOL))) From GLOCK
   OK=0 : Return
Endif
Read [STO]STO0=GXAFCY;[M:ASYW]STOCOU(INOL)
If fstat
   Call RSTA("STO",GXAFCY-num$([M:ASYW]STOCOU(INOL))) From GLOCK
   OK=0 : Return
Endif
Read [ITM]ITM0=[F:STO]ITMREF
If fstat
   Call RSTA("ITM",[F:STO]ITMREF) From GLOCK
   OK=0 : Return
Endif
[M:XALR1]          = [F:STO]
# Issue 110327 : numéro de série de l'écran de travail
If [F:ITM]SERMGTCOD = 4
  [M:XALR1]SERNUM = [M:ASYW]SERNUM(INOL)
Endif
# End issue 110327

Case [M:ASYW]ORIREO(INOL)
   When 1
      Filter [REO] Where STOFCY=[F:STO]STOFCY & ITMREF=[F:STO]ITMREF &
&                  VCRNUM=[F:STA]VCRNUM & VCRLIN=[F:STA]VCRLIN
      Read [REO]First
      Filter [REO]
      If fstat
         Call RSTA("REO",[F:STO]STOFCY-[F:STO]ITMREF-[F:STA]VCRNUM) From GLOCK
         OK=0 : Return
      Endif
      [M:XALR1]LOCORI    = [F:REO]LOC
      [M:XALR1]STU       = [F:REO]STU
      [M:XALR1]BPRNUM    = [F:REO]BPRNUM
      [M:XALR1]CLEFLG    = [F:REO]CLEFLG
      [M:XALR1]VCRLIN    = [F:STA]VCRLIN
      [M:XALR1]WITMREF  = mess(80,197,1) + "  (" + mess(1,2750,1) + ")"

   When 2
      [M:XALR1]LOCORI    = [F:STA]SRGLOC
      [M:XALR1]STU       = [F:ITM]STU
      Raz [M:XALR1]BPRNUM
      Raz [M:XALR1]CLEFLG
      [M:XALR1]WITMREF  = mess(80,197,1) + "  (" + mess(2,2750,1) + ")"
      [M:XALR1]VCRLIN    = [F:STA]SRGLIN
   When 3
      Filter [STA1] Where STOFCY=[F:STA]STOFCY & ITMREF=[F:STA]ITMREF & ALLTYP = 4 &
&                   SRGNUM=[F:STA]SRGNUM & SRGLIN=[F:STA]SRGLIN
      Read [STA1]First
      Filter [STA1]
      If fstat
         Call RSTA("STA1",[F:STA]STOFCY-[F:STA]ITMREF-[F:STA]VCRNUM) From GLOCK
         OK=0 : Return
      Endif
      [M:XALR1]LOCORI    = [F:STA1]LOC
      [M:XALR1]STU       = [F:ITM]STU
      [M:XALR1]VCRLIN    = [F:STA]VCRLIN
      Raz [M:XALR1]BPRNUM
      Raz [M:XALR1]CLEFLG
      [M:XALR1]WITMREF  = mess(80,197,1) + "  (" + mess(3,2750,1) + ")"
   When Default
Endcase

[M:XALR1]QTYSTU    = [F:STA]QTYSTU
[M:XALR1]QTYPCU    = [F:STA]QTYSTU/[F:STO]PCUSTUCOE
[M:XALR1]QTYSTUORI = [M:XALR1]QTYSTU
[M:XALR1]QTYPCUORI = [M:XALR1]QTYPCU
#[M:XALR1]VCRLIN    = [F:STA]VCRLIN
[M:XALR1]QTYSTUORIA= [F:STA]QTYSTUACT
[M:REO1]VCRTYP     = 34          #  Plan réappro zones consommation
[M:REO1]TRSTYP     = 25          #  Réappro zones de consommation

Affzo [M:XALR1]1-99
Return




########################################################
# Actions champs
########################################################

########################################################
Subprog C_VCRNUM(VALEUR)
Variable Char     VALEUR

If VALEUR="" mkstat=2 : End Endif

Call CTRPPSREO([M:XALR]STOFCY,VALEUR) From TRTREOA

End

########################################################
Subprog AM_VCRNUM(VALEUR)
Variable Char     VALEUR

If [M:XALR]VCRNUM<>""
   Unlock = SYMBOLREA
Endif

[M:XALR]VCRNUM = VALEUR

SYMBOLREA = "REALIS"+[M:XALR]VCRNUM
Lock = SYMBOLREA
If fstat
   GERR=1
   Call ERREUR([M:XALR]VCRNUM-":"-mess(10,100,1)) From GESECRAN
   mkstat=2 : End
Endif

End

########################################################
Subprog AP_QTYPCU(VALEUR)
Variable Decimal VALEUR

Local    Decimal WPCUDIS, WSTUDIS, WSTUACTDIS

If VALEUR<=0 mkstat=2 : End Endif

If VALEUR<>[M:XALR1]QTYPCU
   [M:XALR1]QTYSTU = VALEUR*[M:XALR1]PCUSTUCOE
   Call QTEARR([M:XALR1]QTYSTU,[M:XALR1]STU) From TRTDIV

   If VALEUR>[M:XALR1]QTYPCU
      # Calcul du disponible pour sortie sur la ligne de stock
      Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
      # On rajoute la quantité sortie de la ligne au disponible
      WSTUDIS += [M:XALR1]QTYSTUORI
      WPCUDIS += [M:XALR1]QTYPCUORI
      # Quantité > au disponible ?
      If VALEUR>WPCUDIS
         mkstat=2 : End
      Endif
   Endif
Endif

End

