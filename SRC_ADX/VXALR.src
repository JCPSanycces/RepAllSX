[M:REO1]CSMREO    = [F:SRT]CSMREO
[M:REO1]SHTREO    = [F:SRT]SHTREO
[M:REO1]SRGWAIFLG = [F:SRT]SRGWAIFLG
[M:REO1]STKFLG    = [F:SRT]STKFLG
[M:REO1]TRSCOD    = [F:SRT]TRSCOD
[M:REO1]SRGPPSCOD = [F:SRT]SRGPPSCOD

# calcul du poid de l origine  : GORIGINE

# GORIGINE = 2  6 10 14   locreo à oui
# GORIGINE = 4  6 12 14   csmreo à oui
# GORIGINE = 8 10 12 14   shtreo à oui
