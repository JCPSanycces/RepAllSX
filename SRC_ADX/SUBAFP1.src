#<AdxTL>@(#)11.0.0.0 $Revision$
###########################################################
#  * Modification d'un regroupement                       #
#  * Mise à jour de la Table AFF/AFP                      #
#  * Mise à jour de la Table AFF/AFT                      #
#  * sous programme de création de site                   #
#  * sous programme de suppression de site                #
#  * PICKING /INIT                                        #
###########################################################
###########################################################
#  Subprog COMPATIBILITE(FLAG)
#  Subprog SUPPRGMT(FCYGRU)
#
#  Subprog MAJAFF
#  Subprog MAJAFF2
#
#  Subprog CREATIONSITE(FCY,FCYGRU)
#  Subprog SUPPSITE(FCY)
#
#  Subprog SAIGRP
#  Subprog INIT
###########################################################

##-------------------------------------------------------##
#                   1er utilitaire                        #
#            Modification d'un regroupement               #
#---------------------------------------------------------#
#  1er  cas : ajout d'un site dans un regroupement        #
#  2ème cas : suppression d'un site dans un regroupement  #
#  3ème cas : création d'un nouveau regroupement          #
#  4ème cas : suppression d'un regroupement               #
##-------------------------------------------------------##


##-------------------------------------------------------##
#  1er  cas : ajout d'un site dans un regroupement        #
#      --> vérification de la compatibilité  des accès    #
#      --> mise à jour de la table AFF (2ème utilitaire)  #
#      --> aucune modification dans la table AFP          #
##-------------------------------------------------------##
Subprog COMPATIBILITE_OLD(FLAG)
Variable Integer FLAG

If clalev([F:AFP1]) = 0 : Local File AFCTPRF   [AFP1] : Endif
If clalev([F:AFP2]) = 0 : Local File AFCTPRF   [AFP2] : Endif
If clalev([F:FGR1]) = 0 : Local File FACGROUP  [FGR1] : Endif
If clalev([F:FGR2]) = 0 : Local File FACGROUP  [FGR2] : Endif

For [F:AFP1]AFP0(1)                #clé : PRFCOD
    For [F:AFP1]AFP0(2)               #clé : FNC
        For [F:AFP1]AFP0(3)              #clé : FCYGRU
            If [F:AFP1]FCYGRU <> ""
                ## parcourir l'ensemble des regmt de sites d'un même prf&fnc
                For [F:AFP2]AFP0 Where [F:AFP2]PRFCOD =  [F:AFP1]PRFCOD and
&                                      [F:AFP2]FNC    =  [F:AFP1]FNC    and
&                                      [F:AFP2]FCYGRU >  [F:AFP1]FCYGRU

                    ## 1er element de la comparaison, un regroupement
                    If [F:AFP1]FCYGRUCOD <> 2
                        For [FGR1]FGR0 Where [FGR1]CPY = [F:AFP1]FCYGRU
                            ## 2ème element de la comparaison, un regroupement
                            If [F:AFP2]FCYGRUCOD <> 2
                                For [FGR2]FGR0 Where [FGR2]CPY = [F:AFP2]FCYGRU
                                    If [F:FGR1]FCY =  [F:FGR2]FCY and
&                                     ([F:AFP1]ACS <> [F:AFP2]ACS or
&                                      [F:AFP1]OPT <> [F:AFP2]OPT)
                                        FLAG = 0
                                        Call ECR_TRACE(mess(3,45,1)-" : "-[F:FGR2]FCY-" "-
&                                       mess(68,104,1)-" : "-[F:AFP1]FCYGRU-" & "-[F:AFP2]FCYGRU-" "-
&                                       mess(9,123,1)-", "-
&                                       mess(20,130,1)-" : "-[F:AFP1]PRFCOD-" & "-[F:AFP1]FNC,0) From GESECRAN
                                        # site // Regoupement // Modification impossible // Profil fonction
                                    Endif
                                Next [FGR2]FGR0
                            Else
                                ## 2ème element de la comparaison, un site
                                If [F:FGR1]FCY =  [F:AFP2]FCYGRU and
&                                 ([F:AFP1]ACS <> [F:AFP2]ACS or
&                                  [F:AFP1]OPT <> [F:AFP2]OPT)
                                    FLAG = 0
                                    Call ECR_TRACE(mess(3,45,1)-" : "-[F:FGR1]FCY-" "-
&                                   mess(68,104,1)-" : "-[F:AFP1]FCYGRU-" & "-[F:AFP2]FCYGRU-" "-
&                                   mess(9,123,1)-", "-
&                                   mess(20,130,1)-" : "-[F:AFP1]PRFCOD-" & "-[F:AFP1]FNC,0) From GESECRAN
                                    ## site // Regoupement // Modification impossible // Profil fonction
                                Endif
                            Endif
                        Next [FGR1]FGR0
                    Else
                        ## 1er element de la comparaison, un site
                        ## 2ème element de la comparaison, un regroupement
                        If [F:AFP2]FCYGRUCOD <> 2
                            For [FGR2]FGR0 Where [FGR2]CPY = [F:AFP2]FCYGRU
                                If [F:AFP1]FCYGRU = [F:FGR2]FCY  and
&                                 ([F:AFP1]ACS   <> [F:AFP2]ACS or
&                                  [F:AFP1]OPT   <> [F:AFP2]OPT)
                                    FLAG = 0
                                    Call ECR_TRACE(mess(3,45,1)-" : "-[F:FGR2]FCY-" "-
&                                   mess(68,104,1)-" : "-[F:AFP1]FCYGRU-" & "-[F:AFP2]FCYGRU-" "-
&                                   mess(9,123,1)-", "-
&                                   mess(20,130,1)-" : "-[F:AFP1]PRFCOD-" & "-[F:AFP1]FNC,0) From GESECRAN
                                    ## site // Regoupement // Modification impossible // Profil fonction
                                Endif
                            Next [FGR2]FGR0
                        Else
                            ## 2ème element de la comparaison, un site (cas impossible)
                            If [F:AFP1]FCYGRU =  [F:AFP2]FCYGRU  and
&                             ([F:AFP1]ACS   <>  [F:AFP2]ACS or
&                              [F:AFP1]OPT   <>  [F:AFP2]OPT)
                                FLAG = 0
                                Call ECR_TRACE(mess(3,45,1)-" : "-[F:FGR2]FCY-" "-
&                               mess(68,104,1)-" : "-[F:AFP1]FCYGRU-" & "-[F:AFP2]FCYGRU-" "-
&                               mess(9,123,1)-", "-
&                               mess(20,130,1)-" : "-[F:AFP1]PRFCOD-" & "-[F:AFP1]FNC,0) From GESECRAN
                                ## site // Regoupement // Modification impossible // Profil fonction

                            Endif
                        Endif
                    Endif
                Next
            Endif
        Next
    Next
Next
End
#SAM92367
Subprog COMPATIBILITE(FLAG)
Variable Integer FLAG

If clalev([F:AFP1]) = 0 : Local File AFCTPRF   [AFP1] : Endif
If clalev([F:AFP2]) = 0 : Local File AFCTPRF   [AFP2] : Endif
If clalev([F:FGR1]) = 0 : Local File FACGROUP  [FGR1] : Endif
If clalev([F:FGR2]) = 0 : Local File FACGROUP  [FGR2] : Endif

For [F:AFP1]AFP0  Where FCYGRU <> "" :             #clé : PRFCOD,FNC ,FCYGRU
     ## parcourir l'ensemble des regmt de sites d'un même prf&fnc
     For [F:AFP2]AFP0 Where [F:AFP2]PRFCOD =  [F:AFP1]PRFCOD and
&                           [F:AFP2]FNC    =  [F:AFP1]FNC    and
&                           [F:AFP2]FCYGRU >  [F:AFP1]FCYGRU and
&                 ([F:AFP1]ACS <> [F:AFP2]ACS or [F:AFP1]OPT <> [F:AFP2]OPT)

         ## 1er element de la comparaison, un regroupement
         If [F:AFP1]FCYGRUCOD <> 2
             For [FGR1]FGR0 Where [FGR1]CPY = [F:AFP1]FCYGRU
                 ## 2ème element de la comparaison, un regroupement
                 If [F:AFP2]FCYGRUCOD <> 2
                     For [FGR2]FGR0 Where [FGR2]CPY = [F:AFP2]FCYGRU and
&                                         [F:FGR1]FCY =  [FGR2]FCY
                          FLAG = 0
                          Call ECR_TRACE(mess(3,45,1)-" : "-[F:FGR2]FCY-" "-
&                              mess(68,104,1)-" : "-[F:AFP1]FCYGRU-" & "-[F:AFP2]FCYGRU-" "-
&                              mess(9,123,1)-", "-
&                              mess(20,130,1)-" : "-[F:AFP1]PRFCOD-" & "-[F:AFP1]FNC,0) From GESECRAN
                          # site // Regoupement // Modification impossible // Profil fonction
                     Next [FGR2]FGR0
                 Else
                     ## 2ème element de la comparaison, un site
                     If [F:FGR1]FCY =  [F:AFP2]FCYGRU
                         FLAG = 0
                         Call ECR_TRACE(mess(3,45,1)-" : "-[F:FGR1]FCY-" "-
&                                   mess(68,104,1)-" : "-[F:AFP1]FCYGRU-" & "-[F:AFP2]FCYGRU-" "-
&                                   mess(9,123,1)-", "-
&                                   mess(20,130,1)-" : "-[F:AFP1]PRFCOD-" & "-[F:AFP1]FNC,0) From GESECRAN
                         ## site // Regoupement // Modification impossible // Profil fonction
                     Endif
                 Endif
             Next [FGR1]FGR0
         Else
             ## 1er element de la comparaison, un site
             ## 2ème element de la comparaison, un regroupement
             If [F:AFP2]FCYGRUCOD <> 2
                 For [FGR2]FGR0 Where [FGR2]CPY = [F:AFP2]FCYGRU and
&                                     [F:AFP1]FCYGRU = [FGR2]FCY
                     FLAG = 0
                     Call ECR_TRACE(mess(3,45,1)-" : "-[F:FGR2]FCY-" "-
&                         mess(68,104,1)-" : "-[F:AFP1]FCYGRU-" & "-[F:AFP2]FCYGRU-" "-
&                         mess(9,123,1)-", "-
&                         mess(20,130,1)-" : "-[F:AFP1]PRFCOD-" & "-[F:AFP1]FNC,0) From GESECRAN
                         ## site // Regoupement // Modification impossible // Profil fonction
                 Next [FGR2]FGR0
             Else
                 ## 2ème element de la comparaison, un site (cas impossible)
                 If [F:AFP1]FCYGRU =  [F:AFP2]FCYGRU
                     FLAG = 0
                     Call ECR_TRACE(mess(3,45,1)-" : "-[F:FGR2]FCY-" "-
&                               mess(68,104,1)-" : "-[F:AFP1]FCYGRU-" & "-[F:AFP2]FCYGRU-" "-
&                               mess(9,123,1)-", "-
&                               mess(20,130,1)-" : "-[F:AFP1]PRFCOD-" & "-[F:AFP1]FNC,0) From GESECRAN
                     ## site // Regoupement // Modification impossible // Profil fonction

                 Endif
             Endif
         Endif
     Next
Next
End

##-------------------------------------------------------##
# 2ème cas : suppression d'un site dans un regroupement   #
#      --> aucune modification dans la table AFP          #
#      --> suppression du site dans la table AFF (auto)   #
##-------------------------------------------------------##
##-------------------------------------------------------##
# 3ème cas : création d'un nouveau regroupement           #
##-------------------------------------------------------##
## appel du programme COMPATIBILITE (étiquette MODIF) FGR
##-------------------------------------------------------##
# 4ème cas : suppression d'un regroupement                #
#      --> suppression du regroupement dans AFP           #
##-------------------------------------------------------##
Subprog SUPPRGMT(FCYGRU)
Value Char FCYGRU

If clalev([F:AFP2])=0 : Local File AFCTPRF   [AFP2] : Endif

Delete [AFP2] Where [F:AFP2]FCYGRU = [L]FCYGRU
If fstat = 1
    GOK = -1 : Call RSTA("AFP","") From GLOCK
Elsif fstat
    GOK = 0  : Call FSTA("AFP") From GLOCK
Endif

Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC

End
##------------------------------------------------------##
##                  2éme utilitaire                     ##
##           Mise à jour de la Table AFF/AFP            ##
##------------------------------------------------------##
##------------------------------------------------------##
## Génération  des données de la table AFF              ##
## Suppression des données en rapport avec AFP          ##
## Tous les profils dont le flag ALLACS est décoché     ##
##------------------------------------------------------##
Subprog MAJAFF(PRFCOD)
Value Char PRFCOD
Local Char LOK(30)
Local Integer OK_LOK

If !GSERVEUR & !GINFO
 # Mise à jour des fonctions ; Profil fonction ; Fonction
 Call OUVRE_VLC(mess(87,115,1),mess(20,130,1),mess(14,7,1)) From GESECRAN
Endif

If clalev([F:AFT])   = 0 : Local File AFCTFCT   [AFT]  : Endif
If clalev([F:AFF])   = 0 : Local File AFCTFCY   [AFF]  : Endif
If clalev([F:AFC])   = 0 : Local File AFONCTION [AFC]  : Endif
If clalev([F:AFP1])  = 0 : Local File AFCTPRF   [AFP1] : Endif
If clalev([F:FCY])   = 0 : Local File FACILITY  [FCY]  : Endif
If clalev([F:FGRA])  = 0 : Local File FACGROUP  [FGRA] : Endif

Call DEBTRANS From GLOCK
For [AFT] Where [F:AFT]ALLFCT <> 2 and ([L]PRFCOD = "" or [L]PRFCOD = [F:AFT]PRFCOD)
 LOK = "AFP"+[F:AFT]PRFCOD
 Gosub LOK
 If OK_LOK
  Gosub TR_MAJAFF
  Unlock =LOK
  If GOK<1 : Break : Endif
 Endif
Next AFT

Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC

If !GSERVEUR & !GINFO
 Call FERME_VLC From GESECRAN
Endif
End

$LOK
OK_LOK = 0
Lock =LOK With lockwait=0
If fstat
 GLOCK = "%"+LOK
 Call ROLL From GLOCK
 If GROLL : Return : Else : Goto LOK : Endif
Endif
OK_LOK = 1
Return

########################
$TR_MAJAFF
Trbegin [AFF]

    If !GSERVEUR
     Call AFF_VLC([F:AFT]PRFCOD,mess(149,124,1)) From GESECRAN : # Remise à zéro en cours
    Endif

    Delete [AFF] Where [F:AFF]PRFCOD = [F:AFT]PRFCOD
    If fstat = 1
       GOK = -1 : Call RSTA("AFF","") From GLOCK : Goto ROLL_MAJAFF
    Elsif fstat
       GOK = 0  : Call FSTA("AFF") From GLOCK : Goto AB_MAJAFF
    Endif

    If !GSERVEUR
     Call AFF_VLC([F:AFT]PRFCOD,"") From GESECRAN
    Endif

    ## Mise à jour des données par rapport à AFP
    For [F:AFP1] Where [F:AFP1]PRFCOD = [F:AFT]PRFCOD
        Read [F:AFC]CODINT = [F:AFP1]FNC
        If !GSERVEUR
         Call AFF_VLC([F:AFT]PRFCOD,[F:AFC]CODINT) From GESECRAN
        Endif
        If [F:AFC]FCYAUZ = 2
            ## Traitement du Regmt de site "VIDE" avec condition sur accés
            If [F:AFP1]FCYGRU = ""
               If [F:AFP1]ACS = 1
                    Call DELT([F:AFP1]PRFCOD,[F:AFP1]FNC) From SUBAFP
               Else
                    Call MAJT([F:AFP1]PRFCOD,[F:AFP1]FNC,[F:AFP1]OPT) From SUBAFP
               Endif
               ## Traitement selon regroupement ou site avec condition sur accés
            Else
                If ([F:AFP1]FCYGRUCOD <> 2)     # Regroupement
                    If [F:AFP1]ACS = 1
                         Call DELP([F:AFP1]FCYGRU,[F:AFP1]PRFCOD,[F:AFP1]FNC) From SUBAFP
                    Else
                         Call MAJP([F:AFP1]FCYGRU,[F:AFP1]PRFCOD,[F:AFP1]FNC,[F:AFP1]OPT)From SUBAFP
                    Endif
                Else                            # Site
                    If [F:AFP1]ACS = 1
                         Call DELS([F:AFP1]FCYGRU,[F:AFP1]PRFCOD,[F:AFP1]FNC)From SUBAFP
                    Else
                         Call MAJS([F:AFP1]FCYGRU,[F:AFP1]PRFCOD,[F:AFP1]FNC,[F:AFP1]OPT)From SUBAFP
                    Endif
                Endif
            Endif
            If GOK<1 : Break : Endif

        Endif

        ## Création site vide pour la fonction

        Look [AFF]AFF0 = "";[F:AFT]PRFCOD;[F:AFC]CODINT
        If fstat
            Raz [F:AFF]
            [F:AFF]PRFCOD = [F:AFT]PRFCOD
            [F:AFF]FCY    = ""
            [F:AFF]FNC    = [F:AFC]CODINT
            [F:AFF]OPT    = ""
            Write [AFF]
            If fstat
               GOK = 0  : Call FSTA("AFF") From GLOCK : Break
            Endif
         Endif

    Next AFP

    If GOK=-1   : Goto ROLL_MAJAFF
    Elsif GOK<1 : Goto AB_MAJAFF : Endif

    # Création fonction vide et site vide
    Call FCY_FCT_NUL([F:AFT]PRFCOD)
    If GOK=-1   : Goto ROLL_MAJAFF
    Elsif GOK<1 : Goto AB_MAJAFF : Endif

Commit
Return

$AB_MAJAFF
Rollback
Return

$ROLL_MAJAFF
Rollback
Call ROLL From GLOCK
If GROLL : Return  : Else : Goto TR_MAJAFF : Endif

##------------------------------------------------------##
##                  3éme utilitaire                     ##
##           Mise à jour de la Table AFF/AFT            ##
##------------------------------------------------------##
##------------------------------------------------------##
## Génération  des données de la table AFF              ##
## Suppression des données en rapport avec AFT          ##
## Tous les profils dont le flag ALLACS est coché       ##
##------------------------------------------------------##
Subprog MAJAFF2(PRFCOD)
Value Char PRFCOD
Local Integer ACS, OK, WOK , OK_LOK
Local Char OPT(23), LOK(30)

If !GSERVEUR & !GINFO
 # Mise à jour de ; Profil fonction ; Fonction
 Call OUVRE_VLC(mess(33,141,1)-"AFCTFCY/AFCTFCT",mess(20,130,1),mess(14,7,1)) From GESECRAN
Endif

If clalev([F:AFF])   = 0 : Local File AFCTFCY   [AFF]  : Endif
If clalev([F:AFT])   = 0 : Local File AFCTFCT   [AFT]  : Endif
If clalev([F:AFC])   = 0 : Local File AFONCTION [AFC]  : Endif
If clalev([F:FCY])   = 0 : Local File FACILITY  [FCY]  : Endif
If clalev([F:AFP1])  = 0 : Local File AFCTPRF   [AFP1] : Endif

Call DEBTRANS From GLOCK
For [AFT] Where [F:AFT]ALLFCT = 2 and ([L]PRFCOD = "" or [L]PRFCOD = [F:AFT]PRFCOD)
 LOK = "AFP"+[F:AFT]PRFCOD
 Gosub LOK
 If OK_LOK
  Gosub TR_MAJAFF2
  Unlock =LOK
  If GOK<1 : Break : Endif
 Endif
Next AFT

Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC

If !GSERVEUR & !GINFO
 Call FERME_VLC From GESECRAN
Endif
End

#############################
$TR_MAJAFF2
Trbegin [AFF]

    If !GSERVEUR
     Call AFF_VLC([F:AFT]PRFCOD,mess(149,124,1)) From GESECRAN : # Remise à zéro en cours
    Endif

    ## Suppression
    Delete [AFP1] Where [F:AFP1]PRFCOD = [F:AFT]PRFCOD
    If fstat = 1
        GOK = -1 : Call RSTA("AFP","") From GLOCK : Goto ROLL_MAJAFF2
    Elsif fstat
        GOK = 0  : Call FSTA("AFP") From GLOCK : Goto AB_MAJAFF2
    Endif

    Delete [AFF] Where [F:AFF]PRFCOD = [F:AFT]PRFCOD
    If fstat = 1
        GOK = -1 : Call RSTA("AFF","") From GLOCK : Goto ROLL_MAJAFF2
    Elsif fstat
        GOK = 0  : Call FSTA("AFF") From GLOCK : Goto AB_MAJAFF2
    Endif

    ## Mise à jour
    For [AFC]CODINT Where [F:AFC]FCYAUZ = 2 and [F:AFC]TYPTRAIT <> 2
        If !GSERVEUR
         Call AFF_VLC([F:AFT]PRFCOD,[F:AFC]CODINT) From GESECRAN
        Endif
        [L]OPT = ""
        If [F:AFC]TYP = 2
         [L]OPT="CMS"
         If func SUBAFP.OPT([F:AFC]CODINT)
          [L]OPT += "N"
         Endif
        Endif
        For J = 0 To min([F:AFC]NBOPT-1,dim([F:AFC]FLAG)-1)
            [L]OPT = [L]OPT  + [F:AFC]FLAG(J)
        Next J
        Call TRI([L]OPT) From SUBAFP2

        GPE = 0 : GPOINT = "MAJAFF2" : Gosub ENTREE From EXEFNC
        If GPE=0
          For [F:FCY]FCY0
              Raz [F:AFF]
              [F:AFF]PRFCOD = [F:AFT]PRFCOD
              [F:AFF]FCY    = [F:FCY]FCY
              [F:AFF]FNC    = [F:AFC]CODINT
              [F:AFF]OPT    = [L]OPT

              Write [AFF]
              If fstat
                 GOK = 0  : Call FSTA("AFF") From GLOCK : Break 2
              Endif
          Next
        Endif

        ## Création site vide pour la fonction
        Look [AFF]AFF0 = "";[F:AFT]PRFCOD;[F:AFC]CODINT
        If fstat
            Raz [F:AFF]
            [F:AFF]PRFCOD = [F:AFT]PRFCOD
            [F:AFF]FCY    = ""
            [F:AFF]FNC    = [F:AFC]CODINT
            [F:AFF]OPT    = [L]OPT
            Write [AFF]
            If fstat
               GOK = 0  : Call FSTA("AFF") From GLOCK : Break
            Endif
        Endif

    Next AFC

    If GOK=-1   : Goto ROLL_MAJAFF2
    Elsif GOK<1 : Goto AB_MAJAFF2 : Endif

    # Création fonction vide et site vide
    Call FCY_FCT_NUL([F:AFT]PRFCOD)
    If GOK=-1   : Goto ROLL_MAJAFF2
    Elsif GOK<1 : Goto AB_MAJAFF2 : Endif

Commit
Return

$AB_MAJAFF2
Rollback
Return

$ROLL_MAJAFF2
Rollback
Call ROLL From GLOCK
If GROLL : Return  : Else : Goto TR_MAJAFF2 : Endif

#######################################################
# Création fonction et sites vides pour un profil
#######################################################

Subprog FCY_FCT_NUL(PRFCOD)
Value Char PRFCOD

# Création fonction vide
For [F:FCY]FCY0
 Look [AFF]AFF0 = [F:FCY]FCY;[L]PRFCOD;""
 If fstat
  Raz [F:AFF]
  [F:AFF]PRFCOD = [L]PRFCOD
  [F:AFF]FCY    = [F:FCY]FCY
  [F:AFF]FNC    = ""
  [F:AFF]OPT    = ""
  Write [AFF]
  If fstat
   GOK = 0  : Call FSTA("AFF") From GLOCK
  Endif
 Endif
Next FCY

# Création fonction vide & site vide
Look [AFF]AFF0 = "";[L]PRFCOD;""
If fstat
 Raz [F:AFF]
 [F:AFF]PRFCOD = [F:AFT]PRFCOD
 [F:AFF]FCY    = ""
 [F:AFF]FNC    = ""
 [F:AFF]OPT    = ""
 Write [AFF]
 If fstat
  GOK = 0  : Call FSTA("AFF") From GLOCK
 Endif
Endif

End

##------------------------------------------------------##
##           Sous programme : Création de site          ##
##------------------------------------------------------##
##           --> Mise à jour de la table AFF            ##
##------------------------------------------------------##
##-----------------------------------------------------------##
## MAJ par rapport à AFT (ALLACS coché)                      ##
## MAJ pour droit sur prof&fct à regroupement vide (FCYGRU)  ##
## MAJ du regrmt de site lié à la société juridique (FCY)    ##
##-----------------------------------------------------------##
Subprog CREATIONSITE(FCY,FCYGRU)
Variable Char FCY, FCYGRU
Local Integer OK , WOK , OK_LOK
Local Char OPT(23) , LOK(30)

If clalev([F:AFP1]) = 0 : Local File AFCTPRF   [AFP1] : Endif
If clalev([F:AFF])  = 0 : Local File AFCTFCY   [AFF]  : Endif
If clalev([F:AFC])  = 0 : Local File AFONCTION [AFC]  : Endif
If clalev([F:AFT])  = 0 : Local File AFCTFCT   [AFT]  : Endif
#  Issue X3-55870 11-09-2018 by MGO : Incomplete update of AFCTFCY when adding new site within a site/company group
If !clalev([AGF]): Local File AGRPFCY [AGF] : Endif
If !clalev([AGC]): Local File AGRPCPY [AGC] : Endif
#  Issue X3-55870 11-09-2018 by MGO : Incomplete update of AFCTFCY when adding new site within a site/company group

Call DEBTRANS From GLOCK
For [AFT]
 LOK = "AFP"+[F:AFT]PRFCOD
 Gosub LOK
 If OK_LOK
  Gosub TR_CREAT
  Unlock =LOK
  If GOK<1 : Break : Endif
 Endif
Next AFT

Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC


End

$TR_CREAT
Trbegin [AFF]

    If [F:AFT]ALLFCT = 2
        For [F:AFC] Where [F:AFC]FCYAUZ = 2 and [F:AFC]TYPTRAIT <> 2
            [L]OPT = ""
            If [F:AFC]TYP = 2
             [L]OPT="CMS"
             If func SUBAFP.OPT([F:AFC]CODINT)
              [L]OPT += "N"
             Endif
            Endif
            For J = 0 To min([F:AFC]NBOPT-1,dim([F:AFC]FLAG)-1)
                [L]OPT = [L]OPT  + [F:AFC]FLAG(J)
            Next J
            Call TRI([L]OPT) From SUBAFP2
            Call MAJS([L]FCY,[F:AFT]PRFCOD,[F:AFC]CODINT,[L]OPT)From SUBAFP
            If GOK<1 : Break : Endif
        Next
    Else
        For [AFP1] Where [F:AFP1]PRFCOD = [F:AFT]PRFCOD and [F:AFP1]ACS = 2
            Read [F:AFC]CODINT = [F:AFP1]FNC
# Issue X3-55870 11-09-2018 by MGO : Incomplete update of AFCTFCY when adding new site within a site/company group
#            If [F:AFC]FCYAUZ = 2 and ([F:AFP1]FCYGRU = "" or [F:AFP1]FCYGRU = [L]FCYGRU)
#                Read [F:AFF]AFF0 = [L]FCY;[F:AFP1]PRFCOD;[F:AFP1]FNC
#                Raz [F:AFF]
#                [F:AFF]PRFCOD = [F:AFP1]PRFCOD
#                [F:AFF]FCY    = [L]FCY
#                [F:AFF]FNC    = [F:AFP1]FNC
#                [F:AFF]OPT    = [F:AFP1]OPT
#
#                If fstat = 0
#                    Rewrite [AFF]
#                    If fstat = 1
#                        GOK = -1 : Call RSTA("AFF","") From GLOCK : Break
#                    Elsif fstat
#                        GOK = 0  : Call FSTA("AFF") From GLOCK : Break
#                    Endif
#                Else
#                    Write [AFF]
#                    If fstat
#                       GOK = 0  : Call FSTA("AFF") From GLOCK : Break
#                    Endif
#                Endif
#            Endif
            Local Integer CRT
            S_OK = CST_AFALSE
            If [F:AFC]FCYAUZ = 2
              If [F:AFP1]FCYGRU = ""
                S_OK = CST_ATRUE
              Else
                # Checking [F:AFP1]FCYGRU is Legal Company
                Read [AGF]AGF0 = [F:AFP1]FCYGRU
                If !fstat
                  If [F:AGF]FLGLEG = 2 and [F:AFP1]FCYGRU = [L]FCYGRU
                    S_OK = CST_ATRUE
                  Else
                    # Checking [L]FCYGRU is in company group
                    Look [F:AGC]AGC0 = [F:AFP1]FCYGRU;[L]FCYGRU
                    If !fstat
                      S_OK = CST_ATRUE
                    Endif
                  Endif
                Endif
              Endif

              If S_OK = CST_ATRUE
                Read [F:AFF]AFF0 = [L]FCY;[F:AFP1]PRFCOD;[F:AFP1]FNC
                Raz [F:AFF]
                [F:AFF]PRFCOD = [F:AFP1]PRFCOD
                [F:AFF]FCY    = [L]FCY
                [F:AFF]FNC    = [F:AFP1]FNC
                [F:AFF]OPT    = [F:AFP1]OPT

                If fstat = 0
                    Rewrite [AFF]
                    If fstat = 1
                        GOK = -1 : Call RSTA("AFF","") From GLOCK : Break
                    Elsif fstat
                        GOK = 0  : Call FSTA("AFF") From GLOCK : Break
                    Endif
                Else
                    Write [AFF]
                    If fstat
                       GOK = 0  : Call FSTA("AFF") From GLOCK : Break
                    Endif
                Endif
              Endif
            Endif
# Issue X3-55870 11-09-2018 by MGO : Incomplete update of AFCTFCY when adding new site within a site/company group
        Next
    Endif

    If GOK<0 : Goto ROLL_CREAT
    Elsif GOK<1 : Goto AB_CREAT
    Endif

    # Création site sur fonction vide
    Read [AFF]AFF0 = [L]FCY;[F:AFT]PRFCOD;""
    If fstat
     Raz [F:AFF]
     [F:AFF]PRFCOD = [F:AFT]PRFCOD
     [F:AFF]FCY    = [L]FCY
     [F:AFF]FNC    = ""
     [F:AFF]OPT    = ""
     Write [AFF]
     If fstat
      GOK = 0  : Call FSTA("AFF") From GLOCK : Goto AB_CREAT
     Endif
    Endif

Commit
Return

$AB_CREAT
Rollback
Return

$ROLL_CREAT
Rollback
Call ROLL From GLOCK
If GROLL : Return  : Else : Goto TR_CREAT : Endif

##------------------------------------------------------##
##        Sous programme : Suppression d'un site        ##
##------------------------------------------------------##
##  MAJ automatique FGR & AFF                           ##
##  MAJ AFP                                             ##
##      --> suppression du site                         ##
##      --> suppression du regroupement                 ##
##            si site supprimé = dernier                ##
##------------------------------------------------------##
Subprog SUPPSITE(FCY)
Variable Char FCY

If clalev([F:AFP1]) = 0 : Local File AFCTPRF  [AFP1] : Endif
If clalev([F:FGR1]) = 0 : Local File FACGROUP [FGR1]  : Endif

## suppression du site
Delete [F:AFP1] Where ([F:AFP1]FCYGRUCOD = 2) and ([F:AFP1]FCYGRU = [L]FCY)
If fstat = 1
   GOK = -1 : Call RSTA("AFP","") From GLOCK : End
Elsif fstat
   GOK = 0  : Call FSTA("AFP") From GLOCK : End
Endif

## suppression du regroupement
For [AFP1] Where [F:AFP1]FCYGRUCOD = 1 and [F:AFP1]FCYGRU<>""
    Look [FGR1]FGR0(1) = [F:AFP1]FCYGRU
    If fstat
     Call SUPPRGMT([F:AFP1]FCYGRU)
     If GOK<1 : Break : Endif
    Endif
Next

Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
End


##############################
## Bouton init
##############################
$INIT
Local Integer CONTROLE,TESTEXIT
Local Char LOK(30),OPT(23)
Local Integer OK_LOCK

OK=1

If clalev([F:AFP1]) = 0 : Local File AFCTPRF   [AFP1] : Endif
If clalev([F:AFP2]) = 0 : Local File AFCTPRF   [AFP2] : Endif
If clalev([F:AFC])  = 0 : Local File AFONCTION [AFC]  : Endif
If clalev([F:FGR1]) = 0 : Local File FACGROUP  [FGR1] : Endif
If clalev([F:FGR2]) = 0 : Local File FACGROUP  [FGR2] : Endif

Call DEBTRANS From GLOCK
LOK = "AFP"+[M:AFP1]PRFCOD
Gosub LOK
If OK_LOK
 Gosub TR_INIT
 Unlock =LOK
 If GOK<1 : OK = 0 : Endif
Endif
Return

$TR_INIT
Trbegin [AFP2], [AFF]

## Raz des fonctions sélectionnées si Annule et remplace
  If dim([M:AFP1]ANN1)>0 & [M:AFP1]ANN1=2
      For I=0 To [M:AFP1]NBLIG-1
        Delete [AFP2] Where PRFCOD=[M:AFP1]PRFCOD & FNC=[M:AFP1]FNC1(I)
        If fstat = 1
            GOK = -1 : Call RSTA("AFP","") From GLOCK : Goto ROLL_INIT
        Endif
      Next I
  Endif

## MAJ de la table AFP avec les données du picking
  For I=0 To [M:AFP1]NBLIG-1

    CONTROLE = 0
    ## Affectation spécifique : contôle du flag "autorisation/site" pour chaque fonction
    Read [F:AFC]CODINT = [M:AFP1]FNC1(I)
    If [F:AFC]FCYAUZ <> 2

        ## contole d'existence
        Read [AFP2]AFP0 = [M:AFP1]PRFCOD;[M:AFP1]FNC1(I);""
        TESTEXIT = fstat

        Raz [F:AFP2]
        [F:AFP2]PRFCOD    = [M:AFP1]PRFCOD
        [F:AFP2]FNC       = [M:AFP1]FNC1(I)
        [F:AFP2]FCYGRUCOD = 0
        [F:AFP2]FCYGRU    = ""
        [F:AFP2]ACS       = [M:AFP1]ACS1

        [L]OPT = ""
        If [M:AFP1]OPT1 = 2
# Issue X3-74666 - 2018-01-31 by CCC : Adapt options to the current profile
#            Read [F:AFC]CODINT = [M:AFP1]FNC1(I)
#            If [F:AFC]TYP = 2
#             [L]OPT="CMS"
#             If func SUBAFP.OPT([F:AFC]CODINT)
#              [L]OPT += "N"
#             Endif
#            Endif
#            For J = 0 To min([F:AFC]NBOPT-1,dim([F:AFC]FLAG)-1)
#                [L]OPT = [L]OPT  + [F:AFC]FLAG(J)
#            Next J
             J=func SUBAFP.GET_FUNCTION_OPTIONS_FOR_PROFILE(GPROFIL,[M:AFP1]FNC1(I),[L]OPT)
        Endif
        Call TRI([L]OPT) From SUBAFP2
        [F:AFP2]OPT = [L]OPT

    Else
        ## contole d'existence
        Read [AFP2]AFP0 = [M:AFP1]PRFCOD;[M:AFP1]FNC1(I);[M:AFP1]FCYGRU1
        TESTEXIT = fstat

        Raz [F:AFP2]
        [F:AFP2]PRFCOD    = [M:AFP1]PRFCOD
        [F:AFP2]FNC       = [M:AFP1]FNC1(I)
        [F:AFP2]FCYGRU    = [M:AFP1]FCYGRU1
        [F:AFP2]ACS       = [M:AFP1]ACS1

        [L]OPT = ""
        If [M:AFP1]OPT1 = 2
            Read [F:AFC]CODINT = [M:AFP1]FNC1(I)
            If [F:AFC]TYP = 2
             [L]OPT="CMS"
             If func SUBAFP.OPT([F:AFC]CODINT)
              [L]OPT += "N"
             Endif
            Endif
            For J = 0 To min([F:AFC]NBOPT-1,dim([F:AFC]FLAG)-1)
                [L]OPT = [L]OPT  + [F:AFC]FLAG(J)
            Next J
        Endif
        Call TRI([L]OPT) From SUBAFP2
        [F:AFP2]OPT = [L]OPT

        If [M:AFP1]FCYGRU1 = ""
#             [F:AFP2]FCYGRUCOD = 0     # CP 30/05/01
             [F:AFP2]FCYGRUCOD = 1
        Else [F:AFP2]FCYGRUCOD = [M:AFP1]FCYGRUCOD1

          ## Vérification de la compatibilité des données déjà existente dans la table
          For [AFP1]AFP0 Where [F:AFP1]PRFCOD = [M:AFP1]PRFCOD
&                          and [F:AFP1]FNC    = [M:AFP1]FNC1(I)

            If [M:AFP1]FCYGRU1 <> [F:AFP1]FCYGRU
                ## 1er element de la comparaison, le regroupement (ecran)
                If [M:AFP1]FCYGRUCOD1 <> 2
                    For [FGR2]FGR0 Where [FGR2]CPY = [M:AFP1]FCYGRU1
                        ## 2ème element de la comparaison, un regroupement (fichier)
                        If [F:AFP1]FCYGRUCOD <> 2
                            For [FGR1]FGR0 Where [FGR1]CPY = [F:AFP1]FCYGRU
                                If [F:FGR2]FCY =  [F:FGR1]FCY  and
&                                 ([F:AFP1]ACS <> [M:AFP1]ACS1 or
&                                  [F:AFP1]OPT <> [L]OPT)
                                    Call ECR_TRACE(mess(79,123,1)-" : "-[M:AFP1]PRFCOD-" , "-
&                                   mess(14,7,1)-" : "-[F:AFP1]FNC-" ,"-
&                                   mess(66,104,1)-" : "-[M:AFP1]FCYGRU1-" & "-[FGR1]FCY,0) From GESECRAN
                                    # Profil // Fonctions // sites imcompatibles
                                    CONTROLE = 1
                                    Break 1
                                Endif
                            Next [FGR1]FGR0
                        Else
                            ## 2ème element de la comparaison, un site (fichier)
                            If [F:FGR2]FCY =  [F:AFP1]FCYGRU   and
&                             ([F:AFP1]ACS <> [M:AFP1]ACS1 or
&                              [F:AFP1]OPT <> [L]OPT)
&                               Call ECR_TRACE(mess(79,123,1)-" : "-[M:AFP1]PRFCOD-" , "-
&                               mess(14,7,1)-" : "-[F:AFP1]FNC-" ,"-
&                               mess(66,104,1)-" : "-[M:AFP1]FCYGRU1-" & "-[F:AFP1]FCYGRU,0) From GESECRAN
                                # PROFIL // Fonctions // sites imcompatibles
                                CONTROLE = 1
                                Break 1
                            Endif
                        Endif
                    Next [FGR2]FGR0
                Else
                    ## 1er element de la comparaison, un site (saisi à l'écran)
                    ## 2ème element de la comparaison, un regroupement (fichier)
                    If [F:AFP1]FCYGRUCOD <> 2
                        For [FGR1]FGR0 Where [FGR1]CPY = [F:AFP1]FCYGRU
                            If [M:AFP1]FCYGRU1 =  [F:FGR1]FCY  and
&                             ([F:AFP1]ACS <> [M:AFP1]ACS1 or
&                              [F:AFP1]OPT <> [L]OPT)
                                Call ECR_TRACE(mess(79,123,1)-" : "-[M:AFP1]PRFCOD-" , "-
&                               mess(14,7,1)-" : "-[F:AFP1]FNC-" ,"-
&                               mess(66,104,1)-" : "-[M:AFP1]FCYGRU1-" & "-[F:AFP1]FCYGRU,0) From GESECRAN
                                # Profil // Fonctions // sites imcompatibles
                                CONTROLE = 1
                                Break 1
                            Endif
                        Next [FGR1]FGR0
                    Else
                        ## 2ème element de la comparaison, un site (fichier)
                        ## (non traite : écrasement des données)
                        If [M:AFP1]FCYGRU1 =  [F:AFP1]FCYGRU  and
&                         ([F:AFP1]ACS <> [M:AFP1]ACS1 or
&                          [F:AFP1]OPT <> [L]OPT)
                            Call ECR_TRACE(mess(79,123,1)-" : "-[M:AFP1]PRFCOD-" , "-
&                           mess(14,7,1)-" : "-[F:AFP1]FNC-" ,"-
&                           mess(66,104,1)-" : "-[M:AFP1]FCYGRU1-" & "-[F:AFP1]FCYGRU,0) From GESECRAN
                            # Profil // Fonctions // sites imcompatibles
                            CONTROLE = 1
                        Endif
                    Endif
                Endif
            Endif
          Next AFP1
        Endif
    Endif

    # Ecriture de l'enregistrement
    If CONTROLE = 0
        If TESTEXIT = 0
            Rewrite [AFP2]
            If fstat = 1 :
                GOK = -1 : Call RSTA("AFP","") From GLOCK : Break
            Elsif fstat
                GOK =  0 : Call FSTA("AFP") From GLOCK  : Break
            Endif
        Else
            Write [AFP2]
            If fstat = 1 :
                GOK = -1 : Call RSTA("AFP","") From GLOCK : Break
            Elsif fstat
                GOK =  0 : Call FSTA("AFP") From GLOCK  : Break
            Endif
        Endif
    Endif
  Next I

  If GOK=-1   : Goto ROLL_INIT
  Elsif GOK<1 : Goto AB_INIT : Endif

  If dim([M:AFP1]ANN1)<0 or [M:AFP1]ANN1<>2
   Call MAJAFCTFCY("INIT") From SUBAFP
  Endif
  If GOK=-1   : Goto ROLL_INIT
  Elsif GOK<1 : Goto AB_INIT : Endif

Commit

If dim([M:AFP1]ANN1)>0 and [M:AFP1]ANN1=2
    Call MAJAFF([M:AFP1]PRFCOD)
Endif

Return

$AB_INIT
Rollback
Return

$ROLL_INIT
Rollback
Call ROLL From GLOCK
If GROLL : Return  : Else : Goto TR_INIT : Endif

