Subprog MAJ
#** Appelé depuis DOSMAJ80
#*!
# Issue X3-51971 - LOWMTCGEN
  Call PATCH  ([F:ADS]DOSSIER) From UTICPT92
# End issue X3-51971 - LOWMTCGEN

# Issue X3-59287 - 2017-11-08 by FHA : ST1 ST2 ST3 records replicated in GDD as STT1 STT2 STT3
Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT94

Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT97 # Issue X3-83028 - 2018-05-18 by CBO : Add a parameter to modify or not purchase order

#-- MAJ CACCEDEF -
Gosub CACCEDEF

End
##########################################################################################################
##########################################################################################################
##########################################################################################################



##--------------------------------------------------------------------------------------------------------------------
$CACCEDEF
If filinfo(filpath("FIL","CACCEDEF","fde",[F:ADS]DOSSIER),0)>0 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"CACCEDEF")=0
 Local File =[F:ADS]DOSSIER+".CACCEDEF"  [CDE]

 Local Integer STOP, NB
 Local Char CRITERE(250)
 Local Char ACLE1(30), ACLE2(30)

 Call ECR_TIME(mess(81,125,1)-": CACCEDEF") From DOSSUB : # maj table

 Gosub SET_FIRST From TRTFIRST
 Raz STOP
 $LOOP_CDE
 Raz NB
 If STOP = 1
  STOP = 2
  CRITERE = "[F:CDE]COD='"+ACLE1+"' & [F:CDE]CPY>'"+ACLE2+"'"
 Elsif STOP = 2
  STOP = 0
  CRITERE = "[F:CDE]COD>'"+ACLE1+"'"
 Else
  CRITERE = "1=1"
 Endif

 Trbegin [CDE]
 GOK = 1
 For [CDE]CDE0 Where evalue(CRITERE)
  For AXE=1 To 20
    For IND=0 To dim([F:CDE]CCE1)-1
     If evalue("[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")") = 24
      Assign "[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")" With 26
     Endif
    Next
  Next

  Rewrite [CDE]
  If fstat
   GOK = 0 : Call ERREUR("CACCEDEF"-[F:CDE]COD,1) From DOSDIC
  Endif
  NB+=1
  If NB>GMAXUPDTRS
   ACLE1 = [F:CDE]COD
   ACLE2 = [F:CDE]CPY
   STOP=1
   Break
  Endif

 Next

 Commit
 If STOP
  Goto LOOP_CDE
 Endif
 Gosub UNSET_FIRST From TRTFIRST

 Close Local File [CDE]
Endif
Return

