#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Class BANKCASHREG
######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                : Gosub ACONTROL                    From BANKCASHREG_CSTD
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE      From BANKCASHREG_CSTD
        When "AUPDATE_BEFORE"          : Gosub AUPDATE_BEFORE              From BANKCASHREG_CSTD
        When "AUPDATE_AFTER"           : Gosub AUPDATE_AFTER               From BANKCASHREG_CSTD
        When "AINSERT_BEFORE"          : Gosub AINSERT_BEFORE              From BANKCASHREG_CSTD
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE      From BANKCASHREG_CSTD
      Endcase
  Endcase
Return
######################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "FCY"
   Case [L]ARULE
    When "CONTROL"    : Gosub FCY_CONTROL
    When "PROPAGATE"  : Gosub FCY_PROPAGATE
   Endcase
  When "REGCOD"
   Case [L]ARULE
    When "PROPAGATE"  : Gosub REGCOD_PROPAGATE
    Endcase
  When "STARTDAT"
   Case [L]ARULE
    When "PROPAGATE"  : Gosub STARTDAT_PROPAGATE
    Endcase
  When "OPENBAL"
   Case [L]ARULE
    When "PROPAGATE"  : Gosub OPENBAL_PROPAGATE
    Endcase
Endcase
Return
######################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
    When "CLOSE_REGISTER"                 : Gosub CLOSE_REGISTER
    When "OPEN_REGISTER"                  : Gosub OPEN_REGISTER
    When "UPDATE_CLOSING_BALANCE"         : Gosub UPDATE_CLOSING_BALANCE
    When "REGCOD_VALIDATE"                : Gosub REGCOD_VALIDATE
    When "STARTDAT_VALIDATE"              : Gosub STARTDAT_VALIDATE
    When "STARTDAT_INITIALIZE"            : Gosub STARTDAT_INITIALIZE
    When "FINDAT_VALIDATE"                : Gosub FINDAT_VALIDATE
    When "OPENBAL_INITIALIZE"             : Gosub OPENBAL_INITIALIZE
    When "PERIOD_CLOSED"                  : Gosub PERIOD_CLOSED
Endcase
Return
######################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
######################################################################################
######################################################################################
######################################################################################
######################################################################################
#
#                                     CLASS EVENTS
#
######################################################################################
######################################################################################
######################################################################################
######################################################################################
$ACONTROL

    [L]ASTATUS = fmet this.REGCOD_VALIDATE(this.REGNUM, this.REGCOD, this.REGTYP, this.CPY, this.FCY, this.STARTDAT, this.FINDAT)
    If [L]ASTATUS < [V]CST_AERROR
        [L]ASTATUS = fmet this.STARTDAT_VALIDATE(this.REGNUM, this.REGCOD, this.CPY, this.FCY, this.STARTDAT, this.FINDAT)
    Endif
    If [L]ASTATUS < [V]CST_AERROR
        [L]ASTATUS = fmet this.FINDAT_VALIDATE(this.REGNUM, this.REGCOD, this.CPY, this.FCY, this.STARTDAT, this.FINDAT)
    Endif

Return
######################################################################################
$AUPDATE_CONTROL_BEFORE

  #-- 1) Can't update a closed Bank\Cash register
  If this.snapshot.STA = 2 & this.STA = 2 # ISSUE 58984 by MRDAB 2017-10-21 - we could open register
    [L]ASTATUS = fmet this.ASETERROR("", mess(33,7702,1), [V]CST_AERROR)
  Endif

  #-- 2) If it's a cash register, we can only have one open cash register
  If this.REGTYP = 2 and func OPENED_BC_REGISTERS(this.REGNUM, this.REGCOD, this.FCY, [0/0/0]) = 1
      [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(6,83,1) - mess(368,177,1) - mess(31,7702,1), [V]CST_AERROR)
  Endif

  #-- 3) Can't modify a site on already created Bank\Cash register
  If this.snapshot.FCY <> AVOID.ACHAR & this.snapshot.FCY <> this.FCY
    [L]ASTATUS = fmet this.ASETERROR("", mess(32,7702,1), [V]CST_AERROR)
  Endif

  #-- 4) Can't modify the type on already created Bank\Cash register
  If this.snapshot.REGTYP <> AVOID.AINT & this.snapshot.REGTYP <> this.REGTYP
    [L]ASTATUS = fmet this.ASETERROR("", mess(35,7702,1), [V]CST_AERROR)
  Endif

  #-- 5) Can't modify the code on already created Bank\Cash register
  If this.snapshot.REGCOD <> AVOID.ACHAR & this.snapshot.REGCOD <> this.REGCOD
    [L]ASTATUS = fmet this.ASETERROR("", mess(36,7702,1), [V]CST_AERROR)
  Endif

  # ISSUE 58984 by MRDAB 2017-10-22
  #-- 6) Can't open Bank\Cash register if another closed Bank/Cash register exists for the same code and site
  If this.snapshot.STA = 2 & this.STA = 1 & func CLOSED_FURTHER_BC_REGISTERS(this.REGNUM, this.REGCOD, this.FCY, this.FINDAT) = 1
    [L]ASTATUS = fmet this.ASETERROR("", mess(38,7702,1), [V]CST_AERROR)
  Endif

  #-- 7) Can't open Bank\Cash register if the corresponding period is already closed
  If this.snapshot.STA = 2 & this.STA = 1 & fmet this.PERIOD_CLOSED() = 1
    [L]ASTATUS = fmet this.ASETERROR("", mess(39,7702,1), [V]CST_AERROR)
  Endif
  # ISSUE END
Return
######################################################################################
$AUPDATE_BEFORE

#Before updating database we recalculate the closing balance
Callmet this.UPDATE_CLOSING_BALANCE

Return
######################################################################################
#
# 1) After updating a Bank and Cash register record, if we updated the opening or
#    closing balance, we'll update the opening and closing balances for the next
#    Bank and Cash register records.
#    REMARK: this is not on the update transaction so, if it fails, we still update
#            the original record
#
######################################################################################
$AUPDATE_AFTER

#-- 1) Recalculating next records opening balance. This will trigger also
#      the closing balance update when we update the record
Local Decimal DIFFCLOSEB
Local Integer WRET

this.snapshotEnabled = 1
[L]DIFFCLOSEB = this.CLOSEBAL - this.snapshot.CLOSEBAL
this.snapshotEnabled = 0

If [L]DIFFCLOSEB <> 0

  Local File BANKCASHREG  [BCREG2]

  Filter [F:BCREG2] Where [F:BCREG2]REGCOD = this.REGCOD  & [F:BCREG2]REGNUM <> this.REGNUM & [F:BCREG2]FCY = this.FCY &
&                         [F:BCREG2]STARTDAT > this.FINDAT Order By [F:BCREG2]STARTDAT Asc
  Read [F:BCREG2] First
  Filter [F:BCREG2]
  If !fstat
    Local Instance WBANKCASHREG_SUB Using C_BANKCASHREG
    WBANKCASHREG_SUB = NewInstance C_BANKCASHREG AllocGroup null
    [L]WRET = fmet WBANKCASHREG_SUB.AREAD([F:BCREG2]REGNUM)
    [L]ASTATUS = max([L]ASTATUS, [L]WRET)
    WBANKCASHREG_SUB.OPENBAL += [L]DIFFCLOSEB
    [L]WRET = fmet WBANKCASHREG_SUB.AUPDATE()
    [L]ASTATUS = max([L]ASTATUS, [L]WRET)
  Endif

  LogicClose File [BCREG2]

Endif

Return
######################################################################################
#
# 1) Get the Bank and Cash register record sequence number
#
######################################################################################
$AINSERT_BEFORE

Local Char WSEQ_CODE(20)
Local Integer WMANUAL
Local Char WMESSAGE(250)
Local Char WCOMP(250)

WCOMP = ""

If this.REGNUM = AVOID.ACHAR
  #-- 1) Get sequence number code to use
  If this.REGTYP = 1 #-- in case of Bank register
    If func TCA_TOOL.LECTCA(this.ACTX,3,fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEGCPY"),
&         fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY, "LEG"),21,WSEQ_CODE,WMANUAL,WMESSAGE) = [V]CST_AFALSE
      [L]ASTATUS = fmet this.ASETERROR("",mess(64,199,1),[V]CST_AERROR)
      Return
    Endif
    WCOMP = this.REGCOD
  Elsif this.REGTYP = 2 #-- in case of Cash register
    If func TCA_TOOL.LECTCA(this.ACTX,3,fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEGCPY"),
&         fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY, "LEG"),20,WSEQ_CODE,WMANUAL,WMESSAGE) = [V]CST_AFALSE
      [L]ASTATUS = fmet this.ASETERROR("",mess(64,199,1),[V]CST_AERROR)
      Return
    Endif
  Else
    [L]ASTATUS = fmet this.ASETERROR("",mess(64,199,1),[V]CST_AERROR)
    Return
  Endif

  #-- 2) Get sequence number
  [L]ASTATUS = func ANM_TOOL.NUMERO(this.ACTX,WSEQ_CODE,this.FCY,date$,WCOMP,this.REGNUM,WMESSAGE)
  If [L]ASTATUS = [V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR("",WMESSAGE,[V]CST_AERROR)
  Endif

  #Before updating database we recalculate the closing balance
  Callmet this.UPDATE_CLOSING_BALANCE

Endif

Return
######################################################################################
######################################################################################
$ADELETE_CONTROL_BEFORE
  Local Char    ERROR_MESSAGE(100)
  If func BANKCASHREG_CSTD.REGISTER_HAS_PAYMENT_ASSIGNED(this.REGNUM)
    ERROR_MESSAGE = mess(34,7702,1)
    [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, ERROR_MESSAGE, [V]CST_AERROR)
  Endif
Return
######################################################################################
######################################################################################
######################################################################################
######################################################################################
#
#                                   PROPERTY EVENTS
#
######################################################################################
######################################################################################
######################################################################################
######################################################################################
$FCY_CONTROL

#-- 1) Site must have the BCREG parameter active

Local Char ERROR_MESSAGE(100)

If func AFNC.PARAM("BCREG", this.FCY) <> "2"
    ERROR_MESSAGE = func AFNC.MES2(mess(218,125,1), "BCREG", mess(1,1,1))
    [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, ERROR_MESSAGE, [V]CST_AERROR)
Endif

Return
######################################################################################
$FCY_PROPAGATE

#-- 1) Get the site Company

this.CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEGCPY")

Return
######################################################################################
$REGCOD_PROPAGATE

  Local File BANK [BAN]

  Read [F:BAN]BAN0 = this.REGCOD
  If !fstat
    this.CUR = [F:BAN]CUR
  Endif

  LogicClose File [BAN]

Return
######################################################################################
$STARTDAT_PROPAGATE

  If this.STARTDAT > this.FINDAT
    this.FINDAT = this.STARTDAT
  Endif

Return
######################################################################################
$OPENBAL_PROPAGATE

Callmet this.UPDATE_CLOSING_BALANCE

Return
######################################################################################
######################################################################################
######################################################################################
######################################################################################
#
#                                     METHODS
#
######################################################################################
######################################################################################
######################################################################################
######################################################################################
$CLOSE_REGISTER
Local Char LOCKED_SYMBOLS (50)(0..)
Local Integer SYMBOL_INDEX
Local Char ERROR_MESSAGE (100)

Local File PAYMENTH [PYH]

[L]ARET_VALUE = [V]CST_AOK
SYMBOL_INDEX = 0

#-- 1) Check if we really have a current Bank\Cash register
If this.REGNUM = AVOID.ACHAR
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(5,7702,1), [V]CST_AERROR)
    Return
Endif

#-- 2) Check if it's already closed
If this.STA = 2
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(29,7702,1), [V]CST_AERROR)
    Return
Endif

#-- 3) Check if we have Bank\Cash register open
If func OPENED_BC_REGISTERS(this.REGNUM, this.REGCOD, this.FCY, this.STARTDAT) = 1
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(4,7702,1), [V]CST_AERROR)
    Return
Endif

#-- 4) Lock all payments from this Bank\Cash register
For [PYH] Where [F:PYH]REGNUM = this.REGNUM

    LOCKED_SYMBOLS(SYMBOL_INDEX) = "PYH" + num$([F:PYH]NUM)

    Lock = LOCKED_SYMBOLS(SYMBOL_INDEX)
    If fstat #-- If can't lock set error
      ERROR_MESSAGE = mess(47,109,1) - num$([F:PYH]NUM) + ":" - mess(186,187,1)
      [L]ARET_VALUE = fmet this.ASETERROR("", ERROR_MESSAGE, [V]CST_AERROR)
      Break
    Endif

    #-- In this point we were able to lock the record, so we increase the SYMBOL_INDEX
    SYMBOL_INDEX += 1

    If [F:PYH]STA <> 9 #-- If payment is not 'In the Bank' status set error
      [L]ARET_VALUE = fmet this.ASETERROR("", mess(28,7702,1), [V]CST_AERROR)
      Break
    Endif

Next

#-- If we have no errors, close the Bank\Cash register
If SYMBOL_INDEX <> 0
    If [L]ARET_VALUE < [V]CST_AERROR
      this.STA = 2
      [L]ARET_VALUE = fmet this.AUPDATE()
    Endif

    #-- Unlock symbols
    Call UNLOCK_SYMBOLS(LOCKED_SYMBOLS, SYMBOL_INDEX)
Else
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(30,7702,1), [V]CST_AERROR)

Endif

LogicClose File [PYH]

Return
######################################################################################
######################################################################################
# ISSUE 58984 by MRDAB 2017-10-21
$OPEN_REGISTER
Local Char LOCKED_SYMBOLS (50)(0..)
Local Integer SYMBOL_INDEX
Local Char ERROR_MESSAGE (100)

Local File    BANKCASHREG  [BCREG2]

[L]ARET_VALUE = [V]CST_AOK
SYMBOL_INDEX = 0

# Check if we really have a current Bank\Cash register
If this.REGNUM = AVOID.ACHAR
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(5,7702,1), [V]CST_AERROR)
    Return
Endif

# Check if it's already opened
If this.STA = 1
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(37,7702,1), [V]CST_AERROR)
    Return
Endif

# Check if we have later Bank\Cash register closed
If func CLOSED_FURTHER_BC_REGISTERS(this.REGNUM, this.REGCOD, this.FCY, this.FINDAT) = 1
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(38,7702,1), [V]CST_AERROR)
    Return
Endif

# Lock all bank cash records with the same Bank\Cash register code and site
For [F:BCREG2] Where [F:BCREG2]REGCOD = this.REGCOD and [F:BCREG2]FCY = this.FCY and [F:BCREG2]REGNUM <> this.REGNUM and [F:BCREG2]STARTDAT >= this.FINDAT

    LOCKED_SYMBOLS(SYMBOL_INDEX) = "BCREG~" + num$([F:BCREG2]REGNUM)

    Lock = LOCKED_SYMBOLS(SYMBOL_INDEX)
    If fstat #-- If can't lock set error
      ERROR_MESSAGE = mess(0,7702,1) - num$([F:BCREG2]REGNUM) + ":" - mess(186,187,1)
      [L]ARET_VALUE = fmet this.ASETERROR("", ERROR_MESSAGE, [V]CST_AERROR)
      Break
    Endif

    #-- In this point we were able to lock the record, so we increase the SYMBOL_INDEX
    SYMBOL_INDEX += 1

Next

#-- If no errors, open the Bank\Cash register
If [L]ARET_VALUE < [V]CST_AERROR
  this.STA = 1
  [L]ARET_VALUE = fmet this.AUPDATE()
Endif

#-- Unlock symbols
Call UNLOCK_SYMBOLS(LOCKED_SYMBOLS, SYMBOL_INDEX)

LogicClose File  [BCREG2]

Return
# ISSUE END
######################################################################################
######################################################################################
# ISSUE 58984 by MRDAB 2017-10-21
$PERIOD_CLOSED

Local Tinyint LEDT
Local Char COMPANY(GLONCPY)
Local Decimal FISCALYEAR, PERIOD

Local File COMPANY  [CPY]
Local File FACILITY [FCY]
Local File GACM     [GCM]
Local File PERIOD   [PER]

# get site and ledger type
Read [F:FCY]FCY0 = this.FCY
If fstat > 1 : Raz [F:FCY] : Endif
Read [F:CPY]CPY0 = [FCY]LEGCPY
If fstat > 1 : Raz [F:CPY] : Endif
[L]COMPANY = [F:CPY]CPY
Read [F:GCM]GCM0 = [F:CPY]ACM
If fstat > 1 : Raz [F:GCM] : Endif
[L]LEDT = [F:GCM]GENLEDTYP

# get fiscal year and period for the end date of bank/cash register
Call GETPERSOC([L]COMPANY,[L]LEDT,this.FINDAT,[L]FISCALYEAR,[L]PERIOD) From CPTSUB

[L]ARET_VALUE = 0

Read [F:PER]PER0 = [L]COMPANY;[L]LEDT;[L]FISCALYEAR;[L]PERIOD
If !fstat
  If [F:PER]PERSTA = 3
    [L]ARET_VALUE = 1
  Endif
Endif

LogicClose File [CPY]
LogicClose File [FCY]
LogicClose File [GCM]
LogicClose File [PER]

Return
# ISSUE END
######################################################################################
######################################################################################
$UPDATE_CLOSING_BALANCE

  If this.REGNUM <> AVOID.ACHAR
    Local Decimal CLOSEBAL

    Local File PAYMENTH  [PYH]

    [L]CLOSEBAL = 0
    For [F:PYH] Where [F:PYH]REGNUM = this.REGNUM & this.REGNUM <> ""
      [L]CLOSEBAL += [F:PYH]BANPAYTPY
    Next
    this.CLOSEBAL = this.OPENBAL + [L]CLOSEBAL

    LogicClose File [PYH]

  Endif

Return
######################################################################################
######################################################################################
$STARTDAT_INITIALIZE
#P_ variables are method parameters

Local File    BANKCASHREG  [BCREG2]

Filter [F:BCREG2] Where [F:BCREG2]REGCOD = [L]P_REGCOD &
&                       [F:BCREG2]REGNUM <> [L]P_REGNUM & [F:BCREG2]FCY = [L]P_FCY
&                             Order By [F:BCREG2]FINDAT Desc
Read [F:BCREG2] First
Filter [F:BCREG2]
If !fstat
  [L]ARET_VALUE = [F:BCREG2]FINDAT + 1
Else
  [L]ARET_VALUE = date$
Endif

LogicClose File  [BCREG2]

Return
######################################################################################
######################################################################################
$OPENBAL_INITIALIZE
#P_ variables are method parameters

Local File    BANKCASHREG  [BCREG2]

Filter [F:BCREG2] Where [F:BCREG2]REGCOD = [L]P_REGCOD &
&                       [F:BCREG2]REGNUM <> [L]P_REGNUM & [F:BCREG2]FCY = [L]P_FCY
&                             Order By [F:BCREG2]FINDAT Desc
Read [F:BCREG2] First
Filter [F:BCREG2]
If !fstat
  [L]ARET_VALUE = [F:BCREG2]CLOSEBAL
Else
  Call GET_INITIAL_BALANCE([L]P_FCY, [L]P_STRDAT, [L]P_REGCOD, [L]ARET_VALUE)
Endif

LogicClose File  [BCREG2]

Return
######################################################################################
######################################################################################
$STARTDAT_VALIDATE
#P_ variables are method parameters

Local Char    ERROR_MESSAGE(100), RETURNED_REGNUM(GLONVCR)
Local File    BANKCASHREG  [BCREG2]

[L]ARET_VALUE = [V]CST_AOK

If [L]P_STRDAT <> AVOID.ADATE

  #-- 1) Date range conflict with other Bank\Cash register
  If func VERIFY_DATE_CONFLICTS([L]P_STRDAT, [L]P_ENDDAT, [L]P_REGNUM, [L]P_REGCOD, [L]P_FCY, [L]RETURNED_REGNUM) = 0
    [L]ARET_VALUE = fmet this.ASETERROR([L]CURPRO, mess(16,7702,1) - [L]RETURNED_REGNUM, [V]CST_AERROR)
  Endif

  #-- 2) New Bank\Cash register. Check if there's already a Bank\Cash register
  #      for the given Bank\Cash for dates > then this date
  If [L]P_REGNUM = AVOID.ACHAR
    Filter [F:BCREG2] Where [F:BCREG2]REGCOD = [L]P_REGCOD & [F:BCREG2]FCY = [L]P_FCY & [F:BCREG2]REGNUM <> [L]P_REGNUM
&                     Order By [F:BCREG2]FINDAT Desc
    Read [F:BCREG2] First
    If !fstat
      If [F:BCREG2]FINDAT >= [L]P_STRDAT
        ERROR_MESSAGE = [L]P_STRDAT - '=<' - [F:BCREG2]FINDAT - mess(153,111,1) - [F:BCREG2]REGNUM
        [L]ARET_VALUE = fmet this.ASETERROR("STARTDAT", ERROR_MESSAGE, [V]CST_AERROR)
      Endif
    Endif
    Filter [F:BCREG2]
  Else
  #-- 3) Check if with the new dates for the current Bank\Cash register
  #      will not set already payments out of the date range
    If func PAYMENTS_OUT_OF_RANGE([L]P_STRDAT, [L]P_ENDDAT, [L]P_REGNUM) = 0
      [L]ARET_VALUE = fmet this.ASETERROR("STARTDAT", mess(15,7702,1), [V]CST_AERROR)
    Endif
  Endif

  If func FINPER_SYRA.CTRL_DATE_PER([L]P_STRDAT,0,[L]P_CPY,ERROR_MESSAGE) = [V]CST_AERROR
    [L]ARET_VALUE = fmet this.ASETERROR("STARTDAT", ERROR_MESSAGE, [V]CST_AERROR)
  Endif

Endif

LogicClose File  [BCREG2]

Return
######################################################################################
######################################################################################
$FINDAT_VALIDATE
Local Date    EMPTYDATE
Local Char    ERROR_MESSAGE(100), RETURNED_REGNUM(GLONVCR)

[L]ARET_VALUE = [V]CST_AOK
#-- 1) Final date cannot be less then initial date
If [L]P_ENDDAT < [L]P_STRDAT and [L]P_ENDDAT <> EMPTYDATE
  ERROR_MESSAGE = mess(1,104,1) - num$([L]P_ENDDAT) + ' < ' + num$([L]P_STRDAT)
  [L]ARET_VALUE = fmet this.ASETERROR("FINDAT", ERROR_MESSAGE, [V]CST_AERROR)
Endif

#-- 2) Date range conflict with other Bank\Cash register
If func VERIFY_DATE_CONFLICTS([L]P_STRDAT, [L]P_ENDDAT, [L]P_REGNUM, [L]P_REGCOD, [L]P_FCY, [L]RETURNED_REGNUM) = 0
  [L]ARET_VALUE = fmet this.ASETERROR("FINDAT", mess(16,7702,1) - [L]RETURNED_REGNUM, [V]CST_AERROR)
Endif

If [L]P_REGNUM <> AVOID.ACHAR
  #-- 3) Check if there's already a Bank\Cash register for the given
  #      Bank\Cash for dates > then this date
  If func PAYMENTS_OUT_OF_RANGE([L]P_STRDAT, [L]P_ENDDAT, [L]P_REGNUM) = 0
    [L]ARET_VALUE = fmet this.ASETERROR("FINDAT", mess(15,7702,1), [V]CST_AERROR)
  Endif
Endif

#-- 4) Checks the exercise and period
If func FINPER_SYRA.CTRL_DATE_PER([L]P_ENDDAT,0,[L]P_CPY,ERROR_MESSAGE) = [V]CST_AERROR
  [L]ARET_VALUE = fmet this.ASETERROR("FINDAT", ERROR_MESSAGE, [V]CST_AERROR)
Endif

Return
######################################################################################
######################################################################################
$REGCOD_VALIDATE
#P_ variables are method parameters

Local File BANK         [BAN]
Local File BANKCASHREG  [BCREG2]

If [L]P_REGCOD <> AVOID.ACHAR
  #-- 1) Check if Bank\Cash exists
  Read [F:BAN]BAN0 = [L]P_REGCOD
  If !fstat
    #-- 2) Check not belongs to the current site or company
    If (([F:BAN]FCY = "" and [F:BAN]CPY <> [L]P_CPY) or ([F:BAN]FCY <> [L]P_FCY and [F:BAN]FCY <> ""))
      [L]ARET_VALUE = fmet this.ASETERROR("REGCOD", mess(6,83,1) - mess(368,177,1), [V]CST_AERROR)
    Endif
    #-- 3) Payment entry type set on Bank must match with the one on this Bank and Cash register record
    If [F:BAN]BANCSH <> [L]P_REGTYP
      [L]ARET_VALUE = fmet this.ASETERROR("REGCOD", mess(264,142,1) - mess(368,177,1), [V]CST_AERROR)
    Endif
  Else
    [L]ARET_VALUE = fmet this.ASETERROR("REGCOD", mess(6,83,1) - mess(368,177,1), [V]CST_AERROR)
  Endif

  #-- 4) If it's a cash register, we can only have one open cash register
  If [L]P_REGTYP = 2 and func OPENED_BC_REGISTERS([L]P_REGNUM, [L]P_REGCOD, [L]P_FCY, [0/0/0]) = 1
    [L]ARET_VALUE = fmet this.ASETERROR("REGCOD", mess(6,83,1) - mess(368,177,1) - mess(31,7702,1), [V]CST_AERROR)
  Endif
Else
    [L]ARET_VALUE = [V]CST_AERROR
Endif

LogicClose File [BAN]
LogicClose File [BCREG2]

Return
######################################################################################
######################################################################################
######################################################################################
######################################################################################
#
#                       Miscellaneous internal functions
#
######################################################################################
######################################################################################
######################################################################################
######################################################################################
### Get's the initial opening balance for the first record on a given Bank\Cash
### Value is read from BALANCE table
######################################################################################
Subprog GET_INITIAL_BALANCE(SITE, STARTDATE, REGCODE, INIT_BALANCE)
Value Char SITE, REGCODE
Value Date STARTDATE
Variable Decimal INIT_BALANCE

Local Tinyint LEDT
Local Char BANKACCOUNT(GLONGAC), COMPANY(GLONCPY), CURRENCY(GLONCUR)
Local Date STARTDATEDAY, PRVSTARTDATEDAY
Local Decimal FISCALYEAR, PRVPERFISCALYEAR, PERIOD, PREVPERIOD, OPENINGBALANCE

Local File BALANCE      [BAL]
Local File BANK         [BAN]
Local File COMPANY      [CPY]
Local File FACILITY     [FCY]
Local File GACM         [GCM]

# get site
[L]OPENINGBALANCE = 0
[L]STARTDATEDAY = STARTDATE
[L]PRVSTARTDATEDAY = [L]STARTDATEDAY - 1

Read [F:BAN]BAN0 = REGCODE
If !fstat
  [L]BANKACCOUNT = [F:BAN]BANACC
  [L]CURRENCY = [F:BAN]CUR
Endif

Read [F:FCY]FCY0 = SITE
If fstat > 1 : Raz [F:FCY] : Endif
Read [F:CPY]CPY0 = [FCY]LEGCPY
If fstat > 1 : Raz [F:CPY] : Endif
[L]COMPANY = [F:CPY]CPY
Read [F:GCM]GCM0 = [F:CPY]ACM
If fstat > 1 : Raz [F:GCM] : Endif
[L]LEDT = [F:GCM]GENLEDTYP

# get fiscal year and period for the start date of bank/cash register
Call GETPERSOC([L]COMPANY,[L]LEDT,[L]STARTDATEDAY,[L]FISCALYEAR,[L]PERIOD) From CPTSUB
# get fiscal year and period for the previous day to the start date of bank/cash register
Call GETPERSOC([L]COMPANY,[L]LEDT,[L]PRVSTARTDATEDAY,[L]PRVPERFISCALYEAR,[L]PREVPERIOD) From CPTSUB

For [F:BAL] Where [F:BAL]LEDTYP = [L]LEDT & [F:BAL]CPY = [L]COMPANY & [F:BAL]FCY = SITE &
&                 [F:BAL]FIY = [L]FISCALYEAR & [F:BAL]ACC = [L]BANKACCOUNT &
&                 [F:BAL]BPR = "" & [F:BAL]CUR = [L]CURRENCY

  If [L]PERIOD >= [L]PREVPERIOD
    For I=0 To [L]PERIOD - 1
      [L]OPENINGBALANCE += [F:BAL]DEB(I)
      [L]OPENINGBALANCE -= [F:BAL]CDT(I)
    Next
  Else
    [L]OPENINGBALANCE += [F:BAL]DEB(0)
    [L]OPENINGBALANCE -= [F:BAL]CDT(0)
  Endif
Next
INIT_BALANCE = [L]OPENINGBALANCE

LogicClose File [BAL]
LogicClose File [BAN]
LogicClose File [CPY]
LogicClose File [FCY]
LogicClose File [GCM]

End
######################################################################################
### Checks if there's any payment for the given bank\cash register out of the
### given date range
######################################################################################
Funprog PAYMENTS_OUT_OF_RANGE(STARTDATE, FINDATE, REGNUMBER)
Value Date STARTDATE, FINDATE
Value Char REGNUMBER

Local Integer RET_VAL : [L]RET_VAL = 1

Local File PAYMENTH     [PYH]

Filter [F:PYH] Where [F:PYH]REGNUM <> "" & [F:PYH]REGNUM = REGNUMBER &
&                     (STARTDATE > [F:PYH]ACCDAT | [F:PYH]ACCDAT > FINDATE)
Look [F:PYH] First
If !fstat : [L]RET_VAL = 0 : Endif
Filter [F:PYH]

LogicClose File [PYH]

End [L]RET_VAL
######################################################################################
Funprog VERIFY_DATE_CONFLICTS(STARTDATE, FINDATE, REGNUMBER, REGCODE, SITE, RETURN_REGNUM)
Value Date STARTDATE, FINDATE
Value Char REGNUMBER, REGCODE, SITE
Variable Char RETURN_REGNUM

Local Date EMPTYDATE
Local Integer RET_VAL : [L]RET_VAL = 1

Local File BANKCASHREG  [BCREG2]

If !(STARTDATE = EMPTYDATE | FINDATE = EMPTYDATE)
  Filter [F:BCREG2] Where [F:BCREG2]REGCOD = REGCODE & [F:BCREG2]REGNUM <> REGNUMBER & [F:BCREG2]FCY = SITE &
&                         [F:BCREG2]FINDAT >= STARTDATE & [F:BCREG2]STARTDAT <= FINDATE
  Read [F:BCREG2] First
  If !fstat : [L]RET_VAL = 0: RETURN_REGNUM = [F:BCREG2]REGNUM : Endif
  Filter [F:BCREG2]
Endif

LogicClose File [BCREG2]

End [L]RET_VAL
######################################################################################
### Unlocks an array of symbols
### Used by the CLOSE_REGISTER method to unlock the payments locked by the method
######################################################################################
Subprog UNLOCK_SYMBOLS(LOCKED_SYMBOLS, SYMBOL_INDEX)
Variable Char LOCKED_SYMBOLS
Variable Integer SYMBOL_INDEX

Local Integer I

If SYMBOL_INDEX > 0
  For I = 0 To SYMBOL_INDEX - 1
    Unlock = LOCKED_SYMBOLS(I)
  Next
Endif

End
######################################################################################
### Checks if there's any other opened Bank\Cash register for the given Bank\Cash.
### If a date is supplied, search will be done only on records previous to that date
######################################################################################
Funprog OPENED_BC_REGISTERS(REGNUMBER, REGCODE, SITE, CRITDATE)
Value Char    REGNUMBER, REGCODE, SITE
Value Date    CRITDATE

#-- 1) Check if there's any open Bank\Cash register for the given Bank\Cash
Local Integer RET_VAL : [L]RET_VAL = 0
Local Char SEARCH_CRITERIA(250)

Local File BANKCASHREG  [BCREG2]

SEARCH_CRITERIA = "[F:BCREG2]REGCOD = '" + REGCODE + "'" +
&                 " & [F:BCREG2]REGNUM <> '" + REGNUMBER + "'" +
&                 " & [F:BCREG2]STA = 1" +
&                 " & [F:BCREG2]FCY = '" + SITE + "'"

If CRITDATE <> [0/0/0]
  SEARCH_CRITERIA += " & [F:BCREG2]FINDAT <= CRITDATE"
Endif

Filter [F:BCREG2] Where evalue(SEARCH_CRITERIA)
Read [F:BCREG2] First
If !fstat : [L]RET_VAL = 1 : Endif
Filter [F:BCREG2]

LogicClose File  [BCREG2]

End [L]RET_VAL
######################################################################################
### Checks if there's any other later closed Bank\Cash register for the given Bank\Cash.
### If a date is supplied, search will be done only on records later to that date
######################################################################################
# ISSUE 58984 by MRDAB 2017-10-21
Funprog CLOSED_FURTHER_BC_REGISTERS(REGNUMBER, REGCODE, SITE, CRITDATE)
Value Char    REGNUMBER, REGCODE, SITE
Value Date    CRITDATE

# Check if there's any later closed Bank\Cash register for the given Bank\Cash
Local Integer RET_VAL : [L]RET_VAL = 0
Local Char SEARCH_CRITERIA(250)

Local File BANKCASHREG  [BCREG2]

SEARCH_CRITERIA = "[F:BCREG2]REGCOD = '" + REGCODE + "'" +
&                 " & [F:BCREG2]REGNUM <> '" + REGNUMBER + "'" +
&                 " & [F:BCREG2]STA = 2" +
&                 " & [F:BCREG2]FCY = '" + SITE + "'"

If CRITDATE <> [0/0/0]
  SEARCH_CRITERIA += " & [F:BCREG2]FINDAT >= CRITDATE"
Endif

Filter [F:BCREG2] Where evalue(SEARCH_CRITERIA)
Read [F:BCREG2] First
If !fstat : [L]RET_VAL = 1 : Endif
Filter [F:BCREG2]

LogicClose File  [BCREG2]

End [L]RET_VAL
# ISSUE END
######################################################################################
######################################################################################
Funprog REGISTER_HAS_PAYMENT_ASSIGNED(SREGNUM)
Value Char    SREGNUM
Variable Char STAT
Local File    PAYMENTH [PYH3]
STAT = [V]CST_AFALSE

Filter [F:PYH3] Where [F:PYH3]REGNUM = SREGNUM
Read [F:PYH3] First
If fstat = [V]CST_AOK
  STAT = [V]CST_ATRUE
Endif
Filter [F:PYH3]
LogicClose File [PYH3]
End STAT
