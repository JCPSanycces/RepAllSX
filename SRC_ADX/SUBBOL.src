#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management BOL0 (Bill of lading header)
######################################################################################
######################################################################################
#    Process Name:    SUBBOL - Bill of lading entry  SAM #101090
#
#    Authors:         BeSpr   Oct, 2014
#
#    Modifications:
#                     BeSpr   Oct xx, 2014   xxxx
######################################################################################
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANTBOUT"    : Gosub AVANTBOUT
 When "STATUT"       : Gosub STATUT
 When "AVANT_CHOI"   : Gosub AVANT_CHOI
 When "VERF_ANU"     : Gosub VERF_ANU
 When "VERF_CHG"     : Gosub VERF_CHG
 When "ANNULE"       : Gosub ANNULE
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "ABANDON"      : Gosub ABANDON
 When "FERME"        : Gosub FERME
 When "SEL_TABLE"    : Gosub SEL_TABLE
 # Print button
 When "AP_IMPRIME"   : Gosub RELIT From GOBJSUB
 When Default
Endcase
Return

######################################################################################
$OUVRE

If !clalev([F:ANM])  : Local File ACODNUM     [ANM]  : Endif  # Sequence numbers
If !clalev([F:BPA])  : Local File BPADDRESS   [BPA]  : Endif  # BP Address
If !clalev([F:FCC])  : Local File FRTCOMCOD   [FCC]  : Endif  # Freight commodity code

If !clalev([M:ADBB]) : Local Mask ADRBPR      [ADBB] : Endif  # Mask for Ship-to address

Local Integer J,K,NOL
Local Integer SAV_GCONSULT
Local Char BLANKDOC(20)
Local Integer WRET
Local Integer REGOK

Local Char TMPFRT(5), TMPPCK(5), LINPCK(5), TPAVOU(30), TPAWEU(30), TMPNMFC(9)
Local Decimal TPAPCKWEI, TPAVOL, TMPDEC
#121926.sn - JOBRO
Local Integer SAV_GCONSDIA
SAV_GCONSDIA = GCONSDIA
GCONSDIA = 0
#121926.en - JOBRO
Return

######################################################################################
$LIENS

Call LEC_FCY([F:BOLH]FCY) From CPTLEC
Call LEC_CPY([F:BOLH]CPY) From CPTLEC
Call LEC_BPR([F:BOLH]BPR) From CPTLEC
Call GETSOC([F:BOLH]FCY) From DEVSUB
GFCY = [F:BOLH]FCY
# Set Global parameters
Call GLOBVAR(GFCY,"VEN") From TRTX3

# Set name
If [F:BOLH]BPRNAM(0)<>""
 [M:BOL0]BPNAM = [F:BOLH]BPRNAM(0)
 For J=0 To min(dim([M:BOL0]BPRNAM),dim([F:BOLH]BPRNAM))-1
  [M:BOL0]BPRNAM(J) = [F:BOLH]BPRNAM(J)
 Next J
Else
 [M:BOL0]BPNAM = [F:BPR]BPRNAM
 For K=0 To min(dim([M:BOL0]BPRNAM),dim([F:BPR]BPRNAM))-1
  [M:BOL0]BPRNAM(K) = [F:BPR]BPRNAM(K)
 Next K
Endif

# Address setup
If [M:BOL0]BOLNUM = ""
  Read [BPA]BPA0 = 1;[F:BOLH]BPR;[F:BOLH]BPRADD
  If !fstat
   For I=0 To min(dim([M:BOL0]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
    [M:BOL0]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
   Next I
   [M:BOL0]POSCOD = [F:BPA]POSCOD
   [M:BOL0]CTY    = [F:BPA]CTY
   [M:BOL0]CRY    = [F:BPA]CRY
   [M:BOL0]SAT    = [F:BPA]SAT
  Endif
# Existing address in BILLLADH
Else
  For I=0 To min(dim([M:BOL0]BPAADDLIG),dim([F:BOLH]BPAADDLIG))-1
   [M:BOL0]BPAADDLIG(I) = [F:BOLH]BPAADDLIG(I)
  Next I
  [M:BOL0]POSCOD = [F:BOLH]POSCOD
  [M:BOL0]CTY    = [F:BOLH]CTY
  [M:BOL0]CRY    = [F:BOLH]CRY
  [M:BOL0]SAT    = [F:BOLH]SAT
Endif

# Address menu mask
[M:ADBB]ADBBPR       = [F:BOLH]BPR
[M:ADBB]BPAADD       = [F:BOLH]BPRADD
[M:ADBB]BPRNAM(0)    = [F:BOLH]BPRNAM(0)
[M:ADBB]BPRNAM(1)    = [F:BOLH]BPRNAM(1)
[M:ADBB]BPAADDLIG(0) = [F:BOLH]BPAADDLIG(0)
[M:ADBB]BPAADDLIG(1) = [F:BOLH]BPAADDLIG(1)
[M:ADBB]BPAADDLIG(2) = [F:BOLH]BPAADDLIG(2)
[M:ADBB]POSCOD       = [F:BOLH]POSCOD
[M:ADBB]CTY          = [F:BOLH]CTY
[M:ADBB]SAT          = [F:BOLH]SAT
[M:ADBB]CRY          = [F:BOLH]CRY
[M:ADBB]CRYNAM       = [F:BOLH]CRYNAM
If [M:ADBB]BPRNAM <> "" | [M:ADBB]BPAADDLIG <> "" |
&  [M:ADBB]POSCOD <> "" | [M:ADBB]CTY <> "" |
&  [M:ADBB]SAT    <> "" |
&  [M:ADBB]CRY    <> "" | [M:ADBB]CRYNAM <> ""
    [M:ADBB]ADBFLG = 3
Else
    [M:ADBB]ADBFLG = 0
Endif

Gosub LIENS_LIG
[M:BOL1]DSPWEU = GSALDSPWEU
[M:BOL1]DSPVOU = GSALDSPVOU

# Only enable SCAC and Pro number fields if KUS is activated and USABOL is Yes
Gosub SET_USABOL_FIELDS

# Enable and Disable fields
Gosub SET_FIELDS

# Display Text icon
If !GIMPORT
    If [M:BOL0]BLHTEX <> "" | [M:BOL0]BLFTEX <> ""
        Call SET_IMAGE (4) From GESECRAN
    Else
        Call RESET_IMAGE (4) From GESECRAN
    Endif
Endif

#Gosub REMPLIT From GOBJSUB #SAM MJH 01/05/16

Return

######################################################################################
# Disable / enable fields on an existing entry or BOL type
$SET_FIELDS

Actzo [M:BOL0]FCY,BOLTYP,DOCNUM,BPR,BPRADD,BPTNUM,MDL

If [M:BOL0]BOLNUM <> ""
  Diszo [M:BOL0]FCY,BOLTYP,DOCNUM
  If [M:BOL0]BOLTYP <> 3
    Diszo [M:BOL0]BPR,BPRADD,BPTNUM,MDL
  Endif
Else
  If [M:BOL0]BOLTYP <> 3
    Diszo [M:BOL0]BPR,BPRADD,BPTNUM,MDL
  Endif
Endif

Return

######################################################################################
$SET_USABOL_FIELDS

# Hide fields as needed
# Use KP for display fields; use K for enterable fields; X any character
If func AFNC.ACTIV("KUS")
  If func AFNC.PARAM("USABOL",[M:BOL0]FCY)="2"
    Chgfmt [M:BOL0]SCAC    With "K:" + num$(type([M:BOL0]SCAC)-10) + "X"  # Show enterable
    Chgfmt [M:BOL0]PRONUM  With "K:" + num$(type([M:BOL0]PRONUM)-10) + "X"  # Show enterable
    Chgfmt [M:BOL1]NMFC    With "K:" + num$(type([M:BOL1]NMFC)-10) + "X"  # Show enterable
  Else
    Chgfmt [M:BOL0]SCAC    With "-K:" + num$(type([M:BOL0]SCAC)-10) + "X"  # Hide enterable
    Chgfmt [M:BOL0]PRONUM  With "-K:" + num$(type([M:BOL0]PRONUM)-10) + "X"  # Hide enterable
    Chgfmt [M:BOL1]NMFC    With "-K:" + num$(type([M:BOL1]NMFC)-10) + "X"  # Hide enterable
  Endif
Else
  # This field does not have KUS on the screen do to the summarization logic, so I must hide it here
  Chgfmt [M:BOL1]NMFC    With "-K:" + num$(type([M:BOL1]NMFC)-10) + "X"  # Hide enterable
Endif

Return

######################################################################################
# Lines
$LIENS_LIG

# Need to do Contents tab first due to nolign issues
If [M:BOL0]BOLTYP <> 3
  Raz nolign
  Raz NOL
  Raz [M:BOL2]
  # Contents tab
  For [F:BOLC]BOLC0 Where BOLNUM=[F:BOLH]BOLNUM
    [M:BOL2] = [F:BOLH]
    [M:BOL2] = [F:BOLC]
    [M:BOL2]DOCNUMCON(NOL) = [F:BOLC]DOCNUMCON
    Case [M:BOL0]BOLTYP
      When 1 # Customer
        Read [F:SDH]SDH0 = [F:BOLC]DOCNUMCON
        If !fstat
          Gosub BOL2_SET_DLINS
        Endif
      When 2 # Supplier
        Read [F:PNH]PNH0 = [F:BOLC]DOCNUMCON
        If !fstat
          Gosub BOL2_SET_RLINS
        Endif
    Endcase
    NOL += 1
  Next
  [M:BOL2]NBLIGC = NOL
  [M:BOL1]BOL2LINS = [M:BOL2]NBLIGC
  Actzo [M:BOL2]
Else
  Grizo [M:BOL2]
Endif

Raz nolign
Raz [M:BOL1]
# Detail tab
For [F:BOLD]BOLD0 Where BOLNUM=[F:BOLH]BOLNUM
  nolign += 1
  [M:BOL1] = [F:BOLH]
  [M:BOL1] = [F:BOLD]
  NOL = nolign-1 : Gosub BOL1_TOTALS
Next
[M:BOL1]NBLIG = nolign
Affzo [M:BOL1]
[M:BOL1]BOL1LINS = [M:BOL1]NBLIG-1

Return

######################################################################################
$SETBOUT

# Creation or Duplication
If GREP="C" | GREP="D" | CLECUR
   CHMEN += "123"
Endif

If [M:BOL0]BOLTYP<>3 & [M:BOL0]DOCNUM<>""
   CHMEN += "4"
Endif

Gosub SET_BOUT_SPE From GSAISIE

Return

######################################################################################
# Press button, before execution
$AVANTBOUT
Case BOUT
  When "3"  # Address
    SAV_GCONSULT=GCONSULT
    If [M:BOL0]BOLTYP = 3
      GCONSULT = 0   # Can only change the address info for a Misc. entry
    Else
      GCONSULT = 1   # Cannot change the address info for Customers and Suppliers
    Endif
    Gosub SET_ADBB
  When "4"  # Deliveries
    # Need to save original lines variables in case the user says No to regenerate all lines
    [M:BOL1]BOL2LINS = [M:BOL2]NBLIGC
Endcase

Return

######################################################################################
# In creation operation screen from Customer delivery or SUpplier return via BOL navigation
$AVANT_CHOI
  If GCREFONC = 1
    Local Char VALEUR (20)
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GCREFONC = 2
    #Setup the new record with data from the source
    # GFONCTION is set to GESBOL already, so check where we are coming from with GFONC1
    Case GFONC1
      When "GESSDH","GESSOH","GESPRH"
          # If in Delivery, GFONC1 will be GESSDH or the function that launched GESSDH
          If [F:SDH]SDHNUM<>[M:SDH0]SDHNUM
            Read [F:SDH]SDH0 = [M:SDH0]SDHNUM
            If fstat : Return : Endif
          Endif
          [M:BOL0]FCY     = [M:SDH0]SALFCY
          [M:BOL0]BOLTYP  = 1
          [M:BOL0]DOCNUM  = [M:SDH0]SDHNUM
          Call AM_DOCNUM([M:SDH0]SDHNUM)
      When "GESPNH"
          If [F:PNH]PNHNUM<>[M:PNH1]PNHNUM
            Read [F:PNH]PNH0 = [M:PNH1]PNHNUM
            If fstat : Return : Endif
          Endif
          [M:BOL0]FCY     = [M:PNH1]PNHFCY
          [M:BOL0]BOLTYP  = 2
          [M:BOL0]DOCNUM  = [M:PNH1]PNHNUM
          Call AM_DOCNUM([M:PNH1]PNHNUM)
    Endcase
    Affzo [M:BOL0]
  Endif
Return

######################################################################################
# After menu button action is executed
$STATUT

REGOK = 0

Case BOUT
  When "1"  # BOL Header Text
    If mkstat=4 & GREP=""
        Gosub ENTRE_MODIF From GOBJSUB
    Endif
    If [M:BOL0]BLHTEX<>"" & !GIMPORT
        Call SET_IMAGE (4) From GESECRAN
    Elsif !GIMPORT
        Call RESET_IMAGE (4) From GESECRAN
    Endif
  When "2"  # BOL Footer Text
    If mkstat=4 & GREP=""
        Gosub ENTRE_MODIF From GOBJSUB
    Endif
    If [M:BOL0]BLFTEX<>"" & !GIMPORT
        Call SET_IMAGE (4) From GESECRAN
    Elsif !GIMPORT
        Call RESET_IMAGE (4) From GESECRAN
    Endif
  When "3"  # Address
    GCONSULT = SAV_GCONSULT
    [M:BOL0]BPRADD = [M:ADBB]BPAADD : Affzo [BOL0]BPRADD
    If GOK = 1 & [M:ADBB]ADBFLG = 2
      Gosub SET_ADR
      # This enables the SAVE button
      Gosub ENTRE_MODIF From GOBJSUB
    Endif
  When "4"  # Deliveries
    If mkstat = 4  # Lines added
      [M:BOL1]BOL1LINS = [M:BOL1]NBLIG-1
      If [M:BOL0]ADJFLG = 2
        Call OUINON(mess(6,2086,1), REGOK) From GESECRAN
      Endif
      # If Yes then regenerate ALL summary lines OR if not manually adjusted then always regenerate ALL summary lines
      If [M:BOL0]ADJFLG <> 2 | ([M:BOL0]ADJFLG = 2 & REGOK = 2)
        [M:BOL0]ADJFLG = 1 : Affzo [M:BOL0]ADJFLG
        Raz [M:BOL1]
        # Reset and display the Global variables after the Raz
        GFCY = [M:BOL0]FCY
        # Set Global parameters
        Call GLOBVAR(GFCY,"VEN") From TRTX3
        [M:BOL1]DSPWEU = GSALDSPWEU
        [M:BOL1]DSPVOU = GSALDSPVOU
        Affzo [M:BOL1]DSPWEU, DSPVOU
      Endif
      Call GEN_SUMM_LINES From SUBBOL
      # This enables the SAVE button
      Gosub ENTRE_MODIF From GOBJSUB
    Endif
Endcase

Return

####################################################################################
$VERF_CHG
$VERF_ANU
# User presses DELETE and before transaction start and after standard controls

Local Integer VALD_NOK : VALD_NOK = 0
Local Integer DELOK : DELOK = 0

# Display a Warning if the BOL has been printed or a linked delivery / return has been validated
Call CHECK_FOR_VALD (VALD_NOK)
If [M:BOL0]PRNFLG=2 | VALD_NOK
    Call OUINON(mess(4,2086,1), DELOK) From GESECRAN
    # If NO then do not delete the BOL
    If DELOK = 1 : GERR = 1 : OK = 0 : Endif
Endif

Return

####################################################################################
Subprog CHECK_FOR_VALD (VALD_NOK)
Variable Integer VALD_NOK

For NOL=0 To [M:BOL2]NBLIGC-1
  Case [M:BOL0]BOLTYP
    When 1 # Customer
      Read [F:SDH]SDH0 = [M:BOL2]DOCNUMCON(NOL)
      If !fstat
        If [F:SDH]CFMFLG = 2 : VALD_NOK = 1 : Break : End : Endif
      Endif
    When 2 # Supplier
      Read [F:PNH]PNH0 = [M:BOL2]DOCNUMCON(NOL)
      If !fstat
        If [F:PNH]CFMFLG = 2 : VALD_NOK = 1 : Break : End : Endif
      Endif
  Endcase
Next

End

####################################################################################
$ANNULE
# Before delete statement and after VERF_ANU
Local Char BLANKDOC(20)
Local Integer WRET

# Remove the links to the delivery or return documents
For NOL=0 To [M:BOL2]NBLIGC-1
  Case [M:BOL0]BOLTYP
    When 1 # Customer
    Read [F:SDH]SDH0 = [M:BOL2]DOCNUMCON(NOL)
      If !fstat
        Call UPDATE_SDH([M:BOL2]DOCNUMCON(NOL),BLANKDOC)
      Endif
    When 2 # Supplier
      Read [F:PNH]PNH0 = [M:BOL2]DOCNUMCON(NOL)
      If !fstat
        Call UPDATE_PNH([M:BOL2]DOCNUMCON(NOL),BLANKDOC)
      Endif
  Endcase
Next

# Delete associated Text
# BOL Header Text
If left$([F:BOLH]BLHTEX,3)="BOL"
   Call SUP_CLOB([F:BOLH]BLHTEX,WRET) From TRTX3TEX
Endif
# BOL Footer Text
If left$([F:BOLH]BLFTEX,3)="BOL"
   Call SUP_CLOB([F:BOLH]BLFTEX,WRET) From TRTX3TEX
Endif

Return

####################################################################################
$RAZCRE
# User clicks the New button.  Fields are erased and before field entry.

Call RAZ_CLOB From ACLOB
Raz [M:BOL0]BLHTEX
Raz [M:BOL0]BLFTEX
# Address
Raz [M:ADBB]

# Enable and Disable fields
Gosub SET_FIELDS

Return

####################################################################################
$RAZDUP
# User modified the key.  Screens are reset (erased) and before user entry.
Local Integer WRET

Raz [M:BOL0]BOLNUM

Call RAZ_CLOB From ACLOB
If [M:BOL0]BLHTEX="" & left$([F:BOLH]BLHTEX,3)="BOL"
    Call DUP_CLOB([F:BOLH]BLHTEX,WRET) From TRTX3TEX
Endif
If [M:BOL0]BLFTEX="" & left$([F:BOLH]BLFTEX,3)="BOL"
    Call DUP_CLOB([F:BOLH]BLFTEX,WRET) From TRTX3TEX
Endif

# Enable and Disable fields
Gosub SET_FIELDS

Return

####################################################################################
$GRISE_CLE

Gosub GRISE_CLE From =WINPROG

Return

####################################################################################
$VERIF_CRE
# User modified screen fields and presses CREATE button, called before transaction started

# SAM 109283.sn MJH 8/7/2015
#For [F:BOLH] Where DOCNUM = [M:BOL0]DOCNUM #SAM 111961.o MJH 10/23/2015
For [F:BOLH] Where DOCNUM = [M:BOL0]DOCNUM and [F:BOLH]BOLTYP <> 3 #SAM 111961.n MJH 10/23/2015
  GMESSAGE=func AFNC.MES1(mess(11,2086,1),[F:BOLH]BOLNUM)  # This document is tied to BOL xxx
  Raz [M:BOL0]DOCNUM
  Affzo [M:BOL0]DOCNUM
  Break
  Return
Next
# SAM 109283.en MJH 8/7/2015

Gosub $VERIF
Return

$VERIF_MOD
# User presses SAVE button, called before transaction started

$VERIF

If [M:BOL1]NBLIG=0
 GMESSAGE = mess(17,106,1)  # There is no line entered
 OK = 0 : Return
Endif

# Cannot have a line with a blank Freight class or Package
Local Integer TMPLIN
For TMPLIN = 0 To [M:BOL1]NBLIG-1
  If vireblc([M:BOL1]FRTCLS(TMPLIN),2) = "" | vireblc([M:BOL1]PCK(TMPLIN),2) = ""
    GMESSAGE = mess(9,2086,1)
    OK = 0
    Break
    Return
  Endif
Next

Return

######################################################################################
# NEW button pressed; After [F] class is populated with data BEFORE rewrite statement
# Default sequence counter is 'BOL' and set up in Sequence assignments which sets the sequence counter to use
$INICRE

Local Integer STAT,CHKD,OKTCA
Local Char BNUM(20), BOLCPT(30)

BOLCPT = ""
# Read TCA module (local menu 14) which Common data is 9
Call LECTCA(9,OKTCA) From SUBTCA
# On Dec. 18, 2014, the Sequence assignment line for BOL is now 5 / COD(4) in X3DEV / AKIRA / REF but GX3APP is incorrect
# On Jan. 7, 2015, per SAM 105235, the sequence number for BOL internally is still COD(9)
#If OKTCA : BOLCPT = [F:TCA]CODNUM(4) : Endif # 105235.o
If OKTCA : BOLCPT = [F:TCA]CODNUM(9) : Endif # 105235.n
If BOLCPT="" : BOLCPT = "BOL" : Endif
# Need to add Check digit if USABOL parameter is Yes
Call NUMERO(BOLCPT,[M:BOL0]FCY,datesyst,"",BNUM,STAT) From SUBANM
If GOK<0 : Return : Endif
If STAT=0
  [F:BOLH]BOLNUM = BNUM
  [M:BOL0]BOLNUM = BNUM
  Affzo [M:BOL0]BOLNUM
Else
  GERR=1 : GMESSAGE = mess(60,199,1)-" (BOL)" : GOK=0 : Return
Endif

# Manage Text
Gosub INITXC

Return

######################################################################################
# SAVE button pressed; After [F] class is populated with data BEFORE rewrite statement
$INIMOD

[F:BOLH]BOLNUM = [M:BOL0]BOLNUM

# Manage Text
Gosub INITXC

Return

######################################################################################
$INITXC

# BOL Header Text
If [M:BOL0]BLHTEX<>""
   If left$([M:BOL0]BLHTEX,3)="BOL"
     Call CRE_CLOB([M:BOL0]BLHTEX,GOK) From TRTX3TEX
     If GOK<1 Return Endif
   Endif
   [F:BOLH]BLHTEX = [M:BOL0]BLHTEX
Endif

# BOL Footer Text
If [M:BOL0]BLFTEX<>""
   If left$([M:BOL0]BLFTEX,3)="BOL"
     Call CRE_CLOB([M:BOL0]BLFTEX,GOK) From TRTX3TEX
     If GOK<1 Return Endif
   Endif
   [F:BOLH]BLFTEX = [M:BOL0]BLFTEX
Endif

Return

######################################################################################
$CREATION
# NEW button pressed; after everything is entered and after [F] class is written to the database

Local Integer NOL

Delete [BOLD] Where BOLNUM=[M:BOL0]BOLNUM
Delete [BOLC] Where BOLNUM=[M:BOL0]BOLNUM

# Detail tab (Summary lines)
For nolign=1 To [M:BOL1]NBLIG
  Raz [F:BOLD]
  [F:BOLD] = [F:BOLH]
  [F:BOLD] = [M:BOL0]
  [F:BOLD] = [M:BOL1]
  [F:BOLD]BOLLIN = nolign
  [F:BOLD]BOLNUM = [F:BOLH]BOLNUM
  Write [BOLD]
  If fstat
    GOK = 0 : Call FSTA("BOLD") From GLOCK : Break
  Endif
Next

# Contents tab
For nolign=1 To [M:BOL2]NBLIGC
  Raz [F:BOLC]
  [F:BOLC] = [F:BOLH]
  [F:BOLC] = [M:BOL0]
  [F:BOLC] = [M:BOL2]
  [F:BOLC]BOLLIN = nolign
  [F:BOLC]BOLNUM = [F:BOLH]BOLNUM
  Write [BOLC]
  If fstat
    GOK = 0 : Call FSTA("BOLC") From GLOCK : Break
  Endif
  If GOK & [M:BOL0]BOLTYP=1 : Call UPDATE_SDH([F:BOLC]DOCNUMCON,[F:BOLH]BOLNUM) : Endif
  If GOK & [M:BOL0]BOLTYP=2 : Call UPDATE_PNH([F:BOLC]DOCNUMCON,[F:BOLH]BOLNUM) : Endif
  If GOK = 0 : Break : Endif
Next

Return

######################################################################################
Subprog UPDATE_SDH(DOCNUMCON,BOLNUM)
Variable Char DOCNUMCON,BOLNUM

# Update customer delivery with bol number
Read [F:SDH]SDH0=DOCNUMCON
If !fstat
  [F:SDH]BOLNUM = BOLNUM
  Rewrite [SDH]
  If fstat
    GOK = 0 : Call FSTA("SDH") From GLOCK
  Endif
Endif

End

######################################################################################
Subprog UPDATE_PNH(DOCNUMCON,BOLNUM)
Variable Char DOCNUMCON,BOLNUM

# Update supplier return with bol number
Read [F:PNH]PNH0=DOCNUMCON
If !fstat
  [F:PNH]BOLNUM = BOLNUM
  Rewrite [PNH]
  If fstat
    GOK = 0 : Call FSTA("PNH") From GLOCK
  Endif
Endif

End

######################################################################################
$MODIF
# SAVE button pressed / modification mode - After re-write statement BEFORE commit

Gosub CREATION

Return

####################################################################################
$AVANT_MODFIC
# SAVE button pressed before APRES_MOD
Local Integer WRET

# When text is removed
If [M:BOL0]BLHTEX="" & left$([F:BOLH]BLHTEX,3)="BOL"
    Call SUP_CLOB([F:BOLH]BLHTEX,WRET) From TRTX3TEX
Endif
If [M:BOL0]BLFTEX="" & left$([F:BOLH]BLFTEX,3)="BOL"
    Call SUP_CLOB([F:BOLH]BLFTEX,WRET) From TRTX3TEX
Endif

Return

####################################################################################
$ABANDON
# CANCEL button pressed
Local Integer WRET

If GREP="D"
    If left$([M:BOL0]BLHTEX,3)="BOL"
        Call SUP_CLOB([M:BOL0]BLHTEX,WRET) From TRTX3TEX
    Endif
    If left$([M:BOL0]BLFTEX,3)="BOL"
        Call SUP_CLOB([M:BOL0]BLFTEX,WRET) From TRTX3TEX
    Endif
Endif

# Enable and Disable fields
Gosub SET_FIELDS

Return

######################################################################################
$FERME
# End
If clalev([M:ADBB])  Close Local Mask [ADBB] : Endif
GCONSDIA = SAV_GCONSDIA #121926 JOBRO
Return

######################################################################################
$SEL_TABLE

Case COUZON
 When "DOCNUM","DOCNUMCON"
  Case BOLTYP
    When 1 # Customer
      CRITERE = "STOFCY='"+[M]FCY+"'"
      OBJET="SDH"
      START="SDHNUM"
    When 2 # Supplier
      CRITERE = "PNHFCY='"+[M]FCY+"'"
      OBJET="PNH"
      START="PNHNUM"
    When 3 # Misc
      CRITERE = ""
      OBJET=""
      START=""
  Endcase
 When "FRTCLS"
   CRITERE = "LEG='"+""+"' | LEG='"+GCURLEG+"'"
   OBJET="FRT"
   START="FRTCLS"
Endcase

Return

######################################################################################
$SET_ADR
 [M:BOL0]BPNAM        = [ADBB]BPRNAM(0)
 [M:BOL0]BPRNAM(0)    = [ADBB]BPRNAM(0)
 [M:BOL0]BPRNAM(1)    = [ADBB]BPRNAM(1)
 [M:BOL0]BPAADDLIG(0) = [ADBB]BPAADDLIG(0)
 [M:BOL0]BPAADDLIG(1) = [ADBB]BPAADDLIG(1)
 [M:BOL0]BPAADDLIG(2) = [ADBB]BPAADDLIG(2)
 [M:BOL0]CRY          = [ADBB]CRY
 [M:BOL0]CRYNAM       = [ADBB]CRYNAM
 [M:BOL0]SAT          = [ADBB]SAT
 [M:BOL0]POSCOD       = [ADBB]POSCOD
 [M:BOL0]CTY          = [ADBB]CTY
 Affzo [M:BOL0]BPNAM

Return

######################################################################################
$SET_ADBB
 [ADBB]BPAADD       = [M:BOL0]BPRADD
 [ADBB]BPRNAM(0)    = [M:BOL0]BPRNAM(0)
 [ADBB]BPRNAM(1)    = [M:BOL0]BPRNAM(1)
 [ADBB]BPAADDLIG(0) = [M:BOL0]BPAADDLIG(0)
 [ADBB]BPAADDLIG(1) = [M:BOL0]BPAADDLIG(1)
 [ADBB]BPAADDLIG(2) = [M:BOL0]BPAADDLIG(2)
 [ADBB]CRY          = [M:BOL0]CRY
 [ADBB]CRYNAM       = [M:BOL0]CRYNAM
 [ADBB]SAT          = [M:BOL0]SAT
 [ADBB]POSCOD       = [M:BOL0]POSCOD
 [ADBB]CTY          = [M:BOL0]CTY

Return
######################################################################################
Subprog CHECKSUM_CALC (BNUM)
Variable Char BNUM
Local Integer CHKD,CHKD2
Local Integer TOTEVN : TOTEVN=0
Local Integer TOTODD : TOTODD=0
Local Integer TST2
Local Char TST (1)
Local Char NBNUM (20)

# The last character in the Sequence counter is a constant of 0, to be used for the check sum digit
For J = 1 To (len(BNUM) - 1)
# Total digits
  TST = mid$(BNUM,J,1)
  If TST>="1" & TST<="9"
    TST2 = val(mid$(BNUM,J,1))
    Case TST
      When "1", "3", "5", "7", "9"
        TOTODD += TST2
      When "2", "4", "6", "8"
        TOTEVN += (TST2 * 3)
    Endcase
  Endif
Next J
CHKD = 10 - mod((TOTODD+TOTEVN),10)
If CHKD <> 10 : NBNUM = mid$(BNUM,1,J-1) + num$(CHKD) : Endif
BNUM = NBNUM

End

######################################################################################
# Screen Field Actions for BOL0
# Section automatically added (screen BOL0) 10/02/2014 00:32:05 (BESPR)
######################################################################################
# Order of field actions
# IB (init button), AV (before field), D (initialization), AS (before entry)
# C  (control), AP (after field), AM (after change)

Subprog C_BOLNUM(VALEUR)
Variable Char    VALEUR()
# Sequence counter BOL is (9 - Common data) / line 10
If !GIMPORT
 If VALEUR<>""
  Look [F:BOLH]BOLH0 = VALEUR
  If fstat
    If [M:BOL0]BOLTYP = 3
      Raz VALEUR
    Else
      # Cannot copy a Customer or Supplier entry
      VALEUR = [M:BOL0]BOLNUM #  : Affzo VALEUR
    Endif
  Endif
 Elsif [M:BOL0]BOLNUM<>"" & [M:BOL0]BOLTYP<>3
  # Cannot copy a Customer or Supplier entry
  VALEUR = [M:BOL0]BOLNUM #  : Affzo VALEUR
 Endif
Else
 If VALEUR<>""
  If clalev([F:BOLH2])=0 : Local File =GTABCPT+"BILLLADH" [BOLH2] : Endif
  Look [BOLH2]BOLH0 = VALEUR
  If fstat : Raz VALEUR : Endif
 Endif
Endif
End

# AP is After field
Subprog AP_BOLNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : If !GIMPORT : mkstat = 4 : Endif : Endif
End

######################################################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" or [M]CPY=""
  Call INIFCY(VALEUR,[M]CPY) From CPTSUB
  If VALEUR<>""
    Call LECTURE("FCY",VALEUR,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    [M]CPY  = [F:FCY]LEGCPY
    # GCURLEG needed for Freight class
    Call GETSOC(VALEUR) From DEVSUB
    Affzo CPY
  Endif
Elsif [M]BOLNUM<>"" or [M]NBLIG<>0
  # Skip on an existing entry
  mkstat = 2 : End
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
# Set GSALDSPWEU and GSALDSPVOU
GFCY = VALEUR
Call GLOBVAR(GFCY,"VEN") From TRTX3
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
[M]CPY  = [F:FCY]LEGCPY
Affzo CPY
# Only enable SCAC and Pro number fields if KUS is activated and USABOL is Yes
[M:BOL0]FCY = VALEUR : Gosub SET_USABOL_FIELDS
# GCURLEG needed for Freight class
Call GETSOC(VALEUR) From DEVSUB
# Set GSALDSPWEU and GSALDSPVOU
GFCY = VALEUR
Call GLOBVAR(GFCY,"VEN") From TRTX3
[M:BOL1]DSPWEU = GSALDSPWEU
[M:BOL1]DSPVOU = GSALDSPVOU
Affzo [M:BOL1]DSPWEU,DSPVOU
End

######################################################################################
# AM is After change
Subprog AM_BOLTYP(VALEUR)
Variable Integer VALEUR
# Setup for other fields based upon BOLTYP, BPRTYP is used for BP Selection
Case VALEUR
  When 1 # Customer
    [M:BOL0]BPRTYP = "C"
  When 2 # Supplier
    [M:BOL0]BPRTYP = "S"
  When 3 # Misc
    [M:BOL0]BPRTYP = ""
    Grizo [M:BOL2]
Endcase

[M:BOL0]BOLTYP = VALEUR : Gosub SET_FIELDS
[M:BOL0]DOCNUM = "" : Affzo [M:BOL0]DOCNUM

End

######################################################################################
Subprog AS_DOCNUM(VALEUR)
Variable Char    VALEUR()
# Skip on an existing entry
If VALEUR<>"" & [M:BOL0]BOLTYP<>3 : mkstat = 2 : Endif
End

Subprog C_DOCNUM(VALEUR)
Variable Char    VALEUR()
If [M:BOL0]BOLTYP<>3
  If VALEUR = ""
    GMESSAGE = mess(5,211,1)  # Mandatory entry
    mkstat = 2 : End
  Elsif VALEUR<>[M:BOL0]DOCNUM
    Case [M:BOL0]BOLTYP
      When 1 # Customer
        Read [F:SDH]SDH0 = VALEUR
        If fstat
          GMESSAGE = mess(1,2086,1)   # Non-existent customer delivery
          mkstat = 2 : End
        Elsif [F:SDH]BPTNUM="" | [F:SDH]MDL=""
          GMESSAGE = mess(3,2086,1)   # The carrier and/or delivery method are blank
          mkstat = 2 : End
        Elsif [F:SDH]STOFCY <> [M:BOL0]FCY
          GMESSAGE = mess(47,102,1)   # Incompatible sites
          mkstat = 2 : End
        Elsif [F:SDH]BOLNUM <> ""
          GMESSAGE=func AFNC.MES1(mess(11,2086,1),[F:SDH]BOLNUM)  # This document is tied to BOL xxx
          mkstat = 2 : End
        Elsif find(VALEUR,[M:BOL2]DOCNUMCON(0..[M:BOL2]NBLIGC-1))
          GMESSAGE = mess(19,113,1)   # The combination already exists on the line
          mkstat = 2 : End
        Endif
      When 2 # Supplier
        Read [F:PNH]PNH0 = VALEUR
        If fstat
          GMESSAGE = mess(2,2086,1)   # Non-existent supplier return
          mkstat = 2 : End
        Elsif [F:PNH]BPTNUM="" | [F:PNH]MDL=""
          GMESSAGE = mess(3,2086,1)   # The carrier and/or delivery method are blank
          mkstat = 2 : End
        Elsif [F:PNH]PNHFCY <> [M:BOL0]FCY
          GMESSAGE = mess(47,102,1)   # Incompatible sites
          mkstat = 2 : End
        Elsif [F:PNH]BOLNUM <> ""
          GMESSAGE=func AFNC.MES1(mess(11,2086,1),[F:PNH]BOLNUM)  # This document is tied to BOL xx
          mkstat = 2 : End
        Elsif find(VALEUR,[M:BOL2]DOCNUMCON(0..[M:BOL2]NBLIGC-1))
          GMESSAGE = mess(19,113,1)   # The combination already exists on the line
          mkstat = 2 : End
        Endif
    Endcase
  Endif
Endif
End

# AM is After change
Subprog AM_DOCNUM(VALEUR)
Variable Char    VALEUR()
# Default fields based upon Document and BOLTYP, nothing to default for Misc types
If [M:BOL0]BOLTYP = 3 : End : Endif
[M:BOL2]NBLIGC = 1

# 105761.sn
# If coming from Deliveries then we need to set GCURLEG properly for the Freight class read
If GFONC1 = "GESSDH"
  If [F:SDH]STOFCY <> ""
    Call LECTURE("FCY",[F:SDH]STOFCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    [M:BOL0]FCY = [F:SDH]STOFCY
    [M:BOL0]CPY = [F:FCY]LEGCPY
    # GCURLEG needed for Freight class
    Call GETSOC([F:SDH]STOFCY) From DEVSUB
    GFCY = [F:SDH]STOFCY
    # 112444.so - need to call these few lines always
    # Set Global parameters
    #Call GLOBVAR(GFCY,"VEN") From TRTX3
    #[M:BOL1]DSPWEU = GSALDSPWEU
    #[M:BOL1]DSPVOU = GSALDSPVOU
    #Gosub SET_USABOL_FIELDS
    # 112444.eo
  Endif
Endif
# 105761.en

# 112444.sn
# Set Global parameters
Call GLOBVAR(GFCY,"VEN") From TRTX3
[M:BOL1]DSPWEU = GSALDSPWEU
[M:BOL1]DSPVOU = GSALDSPVOU
Gosub SET_USABOL_FIELDS
# 112444.en

Case [M:BOL0]BOLTYP
  When 1 # Customer
    [M:BOL0]BPR          = [F:SDH]BPCORD
    [M:BOL0]BPNAM        = [F:SDH]BPDNAM(0)
    [M:BOL0]BPRNAM(0)    = [F:SDH]BPDNAM(0)
    [M:BOL0]BPRNAM(1)    = [F:SDH]BPDNAM(1)
    [M:BOL0]BPRADD       = [F:SDH]BPAADD
    [M:BOL0]BPAADDLIG(0) = [F:SDH]BPDADDLIG(0)
    [M:BOL0]BPAADDLIG(1) = [F:SDH]BPDADDLIG(1)
    [M:BOL0]BPAADDLIG(2) = [F:SDH]BPDADDLIG(2)
    [M:BOL0]CTY          = [F:SDH]BPDCTY
    [M:BOL0]SAT          = [F:SDH]BPDSAT
    [M:BOL0]POSCOD       = [F:SDH]BPDPOSCOD
    [M:BOL0]CRY          = [F:SDH]BPDCRY
    [M:BOL0]CRYNAM       = [F:SDH]BPDCRYNAM
    [M:BOL0]BPTNUM       = [F:SDH]BPTNUM
    [M:BOL0]MDL          = [F:SDH]MDL
    Read [F:BPT]BPT0 = [M:BOL0]BPTNUM
    If !fstat & func AFNC.ACTIV("KUS") & func AFNC.PARAM("USABOL",[M:BOL0]FCY)="2" : [M:BOL0]SCAC = [F:BPT]SCAC : Endif
    [M:BOL2]DOCNUMCON(0) = VALEUR
    Call GEN_SUMM_LINES From SUBBOL
  When 2 # Supplier
    [M:BOL0]BPR          = [F:PNH]BPSNUM
    [M:BOL0]BPNAM        = [F:PNH]BPRNAM(0)
    [M:BOL0]BPRNAM(0)    = [F:PNH]BPRNAM(0)
    [M:BOL0]BPRNAM(1)    = [F:PNH]BPRNAM(1)
    [M:BOL0]BPRADD       = [F:PNH]BPAADD
    [M:BOL0]BPAADDLIG(0) = [F:PNH]BPAADDLIG(0)
    [M:BOL0]BPAADDLIG(1) = [F:PNH]BPAADDLIG(1)
    [M:BOL0]BPAADDLIG(2) = [F:PNH]BPAADDLIG(2)
    [M:BOL0]CTY          = [F:PNH]CTY
    [M:BOL0]SAT          = [F:PNH]SAT
    [M:BOL0]POSCOD       = [F:PNH]POSCOD
    [M:BOL0]CRY          = [F:PNH]CRY
    [M:BOL0]CRYNAM       = [F:PNH]CRYNAM
    [M:BOL0]BPTNUM       = [F:PNH]BPTNUM
    [M:BOL0]MDL          = [F:PNH]MDL
    Read [F:BPT]BPT0 = [M:BOL0]BPTNUM
    If !fstat & func AFNC.ACTIV("KUS") & func AFNC.PARAM("USABOL",[M:BOL0]FCY)="2" : [M:BOL0]SCAC = [F:BPT]SCAC : Endif
    [M:BOL2]DOCNUMCON(0) = VALEUR
    Call GEN_SUMM_LINES From SUBBOL
Endcase

Affzo [M:BOL0]

End

######################################################################################
Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BPR",VALEUR,"") From CONTOBJ
Case [M:BOL0]BOLTYP
  When 1 # Customer
    If [F:BPR]BPCFLG <> 2
      GMESSAGE = VALEUR-":"-mess(2,119,1)
      mkstat = 2 : End
    Endif
  When 2 # Supplier
    If [F:BPR]BPSFLG <> 2
      GMESSAGE = VALEUR-":"-mess(3,119,1)
      mkstat = 2 : End
    Endif
  When 3 # Misc
Endcase
# Issue number 121508.so - 2017-03-17 by BODEL
# This code can fire and revert the BPNAM and BPRNAM fields back to the original name.
# Instead, B2_BPRADD will fire, call SET_ADR and run the same exact code, allowing
# the field to show properly
#[M:BOL0]BPNAM     = [F:BPR]BPRNAM(0)
#[M:BOL0]BPRNAM(0) = [F:BPR]BPRNAM(0)
#[M:BOL0]BPRNAM(1) = [F:BPR]BPRNAM(1)
#Affzo BPNAM
# End issue number 121508.eo
End

Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()
# Get the default address code and default address code name - only allowed for Misc. types
Case BOLTYP
  When 3 # Misc
    [M:BOL0]BPRADD = [F:BPR]BPAADD

    # Issue number 121508.sn - 2017-03-17 by BODEL
    # Changing the BPR should update the BPRNAM
    [M:BOL0]BPNAM     = [F:BPR]BPRNAM(0)
    [M:BOL0]BPRNAM(0) = [F:BPR]BPRNAM(0)
    [M:BOL0]BPRNAM(1) = [F:BPR]BPRNAM(1)
    Affzo BPNAM
    # Issue number 121508.en - 2017-03-17 by BODEL

Endcase
Affzo [M:BOL0]BPRADD
If [M:BOL0]BPRADD <> ""
 Read [BPA]BPA0=1;VALEUR;[M:BOL0]BPRADD
 Gosub LECADR
 Gosub SET_ADBB  # In case tunnel into Address button
Endif
End

$LECADR
  If !fstat
    [M:BOL0]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
    [M:BOL0]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
    [M:BOL0]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
    [M:BOL0]CTY          = [F:BPA]CTY
    [M:BOL0]SAT          = [F:BPA]SAT
    [M:BOL0]POSCOD       = [F:BPA]POSCOD
    [M:BOL0]CRY          = [F:BPA]CRY
    [M:BOL0]CRYNAM       = [F:BPA]CRYNAM
  Endif
Return

######################################################################################
Subprog IB_BPRADD
# Do no allow Address entry if BP blank or not a misc. entry
If [M:BOL0]BPR = "" | [M:BOL0]BOLTYP <> 3
  Raz GBOUT2
Else
  GBOUT = mess(4,195,1)
Endif
End

Subprog AS_BPRADD(VALEUR)
Variable Char    VALEUR()
# BP must be entered
If [M:BOL0]BPR = "" : mkstat=2 : End : Endif
End

Subprog C_BPRADD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<>[M:BOL0]BPRADD
  Read [BPA]BPA0 = 1;[M:BOL0]BPR;VALEUR
  If fstat
    # Address does not exist
    GMESSAGE = mess(10,119,1)
    mkstat = 2 : End
  Endif
Endif
End

Subprog AM_BPRADD(VALEUR)
Variable Char    VALEUR()
# If using the address button, this routine does not execute, but the AP routine does
If !GIMPORT & VALEUR = [M:BOL0]BPRADD : End : Endif
Gosub LECADR
[M:BOL0]BPRADD = VALEUR
Gosub SET_ADBB  # In case tunnel into Address button
End

Subprog B2_BPRADD(VALEUR)
Variable Char    VALEUR()
If GOK & mkstat = 4
  # Must reset mkstat to 4 to enable the SAVE button because the Affzo below clears it when sent from the Address entry
  VALEUR = [M:ADBB]BPAADD
  [M:BOL0]BPRADD = [M:ADBB]BPAADD
  Affzo [M:BOL0]BPRADD
  Gosub SET_ADR
  mkstat = 4
Endif
End

######################################################################################
Subprog AM_BPTNUM(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("KUS") & func AFNC.PARAM("USABOL",[M:BOL0]FCY)="2"
  [M:BOL0]SCAC = [F:BPT]SCAC
  Affzo [M:BOL0]SCAC
Endif
End

######################################################################################
Subprog AS_SCAC(VALEUR)
Variable Char    VALEUR()
# Skip if USABOL parameter is No
If func AFNC.PARAM("USABOL",[M:BOL0]FCY)<>"2" : mkstat = 2 : Endif
End

Subprog AM_SCAC(VALEUR)
Variable Char    VALEUR()
Local Integer VALLEN
# Fill in the length with "-" to get to 4 characters long per VICS standards.
If VALEUR<>""
  VALEUR = toupper(ctrans(VALEUR))
  VALLEN = len(VALEUR)
  If VALLEN<4
    VALEUR = VALEUR+string$(4-VALLEN,"-")
  Endif
Endif
End

######################################################################################
Subprog AS_PRONUM(VALEUR)
Variable Char    VALEUR()
# Skip if USABOL parameter is No
If func AFNC.PARAM("USABOL",[M:BOL0]FCY)<>"2" : mkstat = 2 : Endif
End

######################################################################################
Subprog AS_NMFC(VALEUR)
Variable Char    VALEUR()
# Skip if USABOL parameter is No
If func AFNC.PARAM("USABOL",[M:BOL0]FCY)<>"2" : mkstat = 2 : Endif
End

Subprog AM_NMFC(VALEUR)
Variable Char    VALEUR()
Gosub UPDATE_FLAGS
End

######################################################################################
# Screen Field Actions for BOL1
# Section automatically added (screen BOL1) 10/02/2014 00:32:05 (BESPR)
######################################################################################
Subprog C_NBLIG
Local Integer VALD_NOK : VALD_NOK = 0
Local Integer DELOK : DELOK = 0

# If deleting a line(s) check for possible message
If find(status,65,68)

  # Display a Warning if the BOL has been printed or the delivery / return has been validated
  Call CHECK_FOR_VALD (VALD_NOK)
  If [M:BOL0]PRNFLG=2 | VALD_NOK
    Call OUINON(mess(5,2086,1), DELOK) From GESECRAN
  Endif
  # If NO then do not delete the line
  If DELOK = 1 : mkstat = 2 : End : Endif

  If [M:BOL0]ADJFLG = 1 : [M:BOL0]ADJFLG = 2 : Affzo [M:BOL0]ADJFLG : Endif
  If [M:BOL0]PRNFLG = 2 : [M:BOL0]PRNFLG = 1 : Affzo [M:BOL0]PRNFLG : Endif

  [M:BOL1]DSPTOTWEI -= [M:BOL1]GROWEI(nolign-1)  # Subtract out the old weight
  [M:BOL1]DSPTOTVOL -= [M:BOL1]VOL(nolign-1)     # Subtract out the old volume
  [M:BOL1]DSPTOTQTY -= [M:BOL1]NBRPCK(nolign-1)  # Subtract out the old qty
  Affzo [M:BOL1]DSPTOTWEI,DSPTOTVOL,DSPTOTQTY

Endif
End

######################################################################################
Subprog AS_FRTCLS(VALEUR)
Variable Char    VALEUR()
# Allow FRTCLS to always be overridden
End

Subprog C_FRTCLS(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  GMESSAGE = mess(5,211,1)  # Mandatory entry
  mkstat = 2 : End
Endif
End

Subprog AM_FRTCLS(VALEUR)
Variable Char    VALEUR()
Gosub UPDATE_FLAGS
End

######################################################################################
Subprog AM_PCK(VALEUR)
Variable Char    VALEUR()

# Default package info on any package entry / change and convert to Global UOMs
LINPCK = VALEUR : Gosub READ_PCK
# Weight calculations
  [M:BOL1]DSPTOTWEI -= [M:BOL1]PACWEI(nolign-1)  # Subtract out the old weight
  [M:BOL1]PACWEI(nolign-1) = TPAPCKWEI * max(1,[M:BOL1]NBRPCK(nolign-1))
  [M:BOL1]GROWEI(nolign-1) = [M:BOL1]NETWEI(nolign-1) + [M:BOL1]PACWEI(nolign-1)
  Affzo [M:BOL1]PACWEI(nolign-1),GROWEI(nolign-1)
  [M:BOL1]DSPTOTWEI += [M:BOL1]PACWEI(nolign-1)  # Add in the new weight
  Affzo [M:BOL1]DSPTOTWEI
# Volume calculations
  [M:BOL1]DSPTOTVOL -= [M:BOL1]VOL(nolign-1)  # Subtract out the old volume
  [M:BOL1]VOL(nolign-1) = TPAVOL * max(1,[M:BOL1]NBRPCK(nolign-1))
  [M:BOL1]VOU(nolign-1) = GSALDSPVOU
  Affzo [M:BOL1]VOU(nolign-1),VOL(nolign-1)
  [M:BOL1]DSPTOTVOL += [M:BOL1]VOL(nolign-1)  # Add in the new volume
  Affzo [M:BOL1]DSPTOTVOL

Gosub UPDATE_FLAGS
End

######################################################################################
Subprog AM_NBRPCK(VALEUR)
Variable Decimal VALEUR
Local Decimal NEWPACWEI, ORGPACWEI
Local Decimal NEWVOL, ORGVOL

[M:BOL1]DSPTOTQTY -= [M:BOL1]NBRPCK(nolign-1)
[M:BOL1]DSPTOTQTY += VALEUR
Affzo [M:BOL1]DSPTOTQTY

ORGPACWEI = [M:BOL1]PACWEI(nolign-1) / max(1,[M:BOL1]NBRPCK(nolign-1))
NEWPACWEI = ORGPACWEI * VALEUR
[M:BOL1]DSPTOTWEI += NEWPACWEI  # Add in the new weight
[M:BOL1]DSPTOTWEI -= [M:BOL1]PACWEI(nolign-1)  # Subtract out the old weight
Affzo [M:BOL1]DSPTOTWEI

[M:BOL1]GROWEI(nolign-1) = NEWPACWEI + [M:BOL1]NETWEI(nolign-1)
[M:BOL1]PACWEI(nolign-1) = NEWPACWEI
Affzo [M:BOL1]PACWEI(nolign-1),GROWEI(nolign-1)

ORGVOL = [M:BOL1]VOL(nolign-1) / max(1,[M:BOL1]NBRPCK(nolign-1))
NEWVOL = ORGVOL * VALEUR
[M:BOL1]DSPTOTVOL += NEWVOL  # Add in the new volume
[M:BOL1]DSPTOTVOL -= [M:BOL1]VOL(nolign-1)  # Subtract out the old volume
Affzo [M:BOL1]DSPTOTVOL
[M:BOL1]VOL(nolign-1) = NEWVOL
Affzo [M:BOL1]VOL(nolign-1)

Gosub UPDATE_FLAGS
End

######################################################################################
Subprog AM_PACWEI(VALEUR)
Variable Decimal VALEUR
Local Decimal NEWPACWEI

# Do not recalculate the package weight by the NBRPCK if PACWEI is overridden
NEWPACWEI = VALEUR

[M:BOL1]DSPTOTWEI -= [M:BOL1]PACWEI(nolign-1)
[M:BOL1]DSPTOTWEI += NEWPACWEI
Affzo [M:BOL1]DSPTOTWEI

[M:BOL1]GROWEI(nolign-1) = NEWPACWEI + [M:BOL1]NETWEI(nolign-1)
[M:BOL1]PACWEI(nolign-1) = NEWPACWEI
Affzo [M:BOL1]PACWEI(nolign-1),GROWEI(nolign-1)

Gosub UPDATE_FLAGS
End

######################################################################################
Subprog AM_NETWEI(VALEUR)
Variable Decimal VALEUR
[M:BOL1]DSPTOTWEI -= [M:BOL1]NETWEI(nolign-1)
[M:BOL1]DSPTOTWEI += VALEUR
Affzo [M:BOL1]DSPTOTWEI

[M:BOL1]GROWEI(nolign-1) = VALEUR + [M:BOL1]PACWEI(nolign-1)
Affzo [M:BOL1]GROWEI(nolign-1)

Gosub UPDATE_FLAGS
End

######################################################################################
Subprog D_WEU(VALEUR)
Variable Char VALEUR()
If VALEUR = ""
  VALEUR = GSALDSPWEU  # Weight parameter
Endif
End

######################################################################################
Subprog AM_VOL(VALEUR)
Variable Decimal VALEUR
[M:BOL1]DSPTOTVOL -= [M:BOL1]VOL(nolign-1)
[M:BOL1]DSPTOTVOL += VALEUR
Affzo [M:BOL1]DSPTOTVOL
Gosub UPDATE_FLAGS
End

######################################################################################
Subprog D_VOU(VALEUR)
Variable Char VALEUR()
If VALEUR = ""
  VALEUR = GSALDSPVOU # Volume parameter
Endif
End

######################################################################################
$UPDATE_FLAGS
# When a grid field has changed update the flags
If [M:BOL0]ADJFLG = 1 : [M:BOL0]ADJFLG = 2 : Affzo [M:BOL0]ADJFLG : Endif
# If the BOL has been printed, but then lines are added / changed then change the Printed flag back to No
If [M:BOL0]PRNFLG = 2
  Local Integer DELOK : DELOK = 0
  Call OUINON(mess(12,2086,1), DELOK) From GESECRAN  # BOL has been printed
  If DELOK = 2
    [M:BOL0]PRNFLG = 1
    Affzo [M:BOL0]PRNFLG
  Else
    mkstat = 2
  Endif
Endif
Return

######################################################################################
# Screen Field Actions for BOL2
# Section automatically added (screen BOL2) 10/10/2014 00:32:05 (BESPR)
######################################################################################
Subprog C_NBLIGC
Local Integer VALD_NOK : VALD_NOK = 0
Local Integer DELOK : DELOK = 0
Local Char BLANKDOC(20)
[M:BOL2]REGENOK = 0

If find(status,65,68) # Only delete line or delete multiple lines

  # Do not allow Delete for the Main reference document
  If [M:BOL2]DOCNUMCON(nolign-1) = [M:BOL0]DOCNUM
    GMESSAGE = mess(13,2086,1)  # Mandatory entry
    mkstat = 2: End
  Endif

  Case [M:BOL0]BOLTYP
    When 1 # Customer
      Read [F:SDH]SDH0 = [M:BOL2]DOCNUMCON(nolign-1)
      If !fstat
        If [F:SDH]CFMFLG = 2 : VALD_NOK = 1 : Endif
      Endif
    When 2 # Supplier
      Read [F:PNH]PNH0 = [M:BOL2]DOCNUMCON(nolign-1)
      If !fstat
        If [F:PNH]CFMFLG = 2 : VALD_NOK = 1 : Endif
      Endif
  Endcase

  # Display a Warning if the BOL has been printed or the delivery / return has been validated
  If [M:BOL0]PRNFLG=2 | VALD_NOK
    Call OUINON(mess(5,2086,1), DELOK) From GESECRAN
  Endif
  # If NO then do not delete the Content line
  If DELOK = 1 : mkstat = 2 : End : Endif

  DELOK = 0
  # Now if lines have been manually adjusted, ask if they want the lines regenerated
  If [M:BOL0]ADJFLG = 2
    Call OUINON(mess(6,2086,1), DELOK) From GESECRAN
  Endif
  If DELOK = 2 : [M:BOL2]REGENOK = 2 : Endif

  # Remove the BOL link on the delivery / return
  Case [M:BOL0]BOLTYP
    When 1 # Customer
    Read [F:SDH]SDH0 = [M:BOL2]DOCNUMCON(nolign-1)
      If !fstat
        Call UPDATE_SDH([M:BOL2]DOCNUMCON(nolign-1),BLANKDOC)
      Endif
    When 2 # Supplier
      Read [F:PNH]PNH0 = [M:BOL2]DOCNUMCON(nolign-1)
      If !fstat
        Call UPDATE_PNH([M:BOL2]DOCNUMCON(nolign-1),BLANKDOC)
      Endif
  Endcase

Endif

End

Subprog APRES_NBLIGC
If find(status,65,68) # Only delete line or delete multiple lines
  # If Yes then regenerate ALL summary lines (from C_NBLIGC)
  # OR if not manually adjusted then always regenerate ALL summary lines
  If [M:BOL0]ADJFLG <> 2 | ([M:BOL0]ADJFLG = 2 & [M:BOL2]REGENOK = 2)
    [M:BOL0]ADJFLG = 1 : Affzo [M:BOL0]ADJFLG
    Raz [M:BOL1]
    Call GEN_SUMM_LINES From SUBBOL
    # Reset and display the Global variables after the Raz
    GFCY = [M:BOL0]FCY
    # Set Global parameters
    Call GLOBVAR(GFCY,"VEN") From TRTX3
    [M:BOL1]DSPWEU = GSALDSPWEU
    [M:BOL1]DSPVOU = GSALDSPVOU
    Affzo [M:BOL1]DSPWEU, DSPVOU
  Endif
Endif
End

######################################################################################
Subprog AS_DOCNUMCON(VALEUR)
Variable Char    VALEUR()
# Skip but still allow Delete line
mkstat = 2
End

######################################################################################
# Default delivery info
$BOL2_SET_DLINS
  [M:BOL2]DOCDAT(NOL) = [F:SDH]SHIDAT
  [M:BOL2]DLVDAT(NOL) = [F:SDH]DLVDAT
  [M:BOL2]CFMFLG(NOL) = [F:SDH]CFMFLG
Return

# Default return info
$BOL2_SET_RLINS
  [M:BOL2]DOCDAT(NOL) = [F:PNH]RTNDAT
  [M:BOL2]CFMFLG(NOL) = [F:PNH]CFMFLG
Return

# Calculate the totals - all weights and volume have been previously converted to the global UOMs
$BOL1_TOTALS
  [M:BOL1]DSPTOTQTY  += [M:BOL1]NBRPCK(NOL)
  # Convert to global volume so totals are correct
  TMPDEC = [M:BOL1]VOL(NOL)
  If [M:BOL1]VOU(NOL) <> GSALDSPVOU : Call CONVERT_QTY ([M:BOL1]VOU(NOL),GSALDSPVOU,TMPDEC) From TRTX3 : Endif
  [M:BOL1]DSPTOTVOL += TMPDEC
  # Convert to global weight so totals are correct
  TMPDEC = [M:BOL1]PACWEI(NOL)
  If [M:BOL1]WEU(NOL) <> GSALDSPWEU : Call CONVERT_QTY ([M:BOL1]WEU(NOL),GSALDSPWEU,TMPDEC) From TRTX3 : Endif
  [M:BOL1]DSPTOTWEI += TMPDEC
  TMPDEC = [M:BOL1]NETWEI(NOL)
  If [M:BOL1]WEU(NOL) <> GSALDSPWEU : Call CONVERT_QTY ([M:BOL1]WEU(NOL),GSALDSPWEU,TMPDEC) From TRTX3 : Endif
  [M:BOL1]DSPTOTWEI += TMPDEC
Return

######################################################################################
Subprog GEN_SUMM_LINES
Local Shortint NOLB, STRTNOLB, NOSPDLINS, TMPCONV
Local Integer FRTLIN,LSTFRTLIN
Local Char LSTPACNUM(30)
Local Char LSTFRTCLS(5), LSTPCK(5)

# If the BOL has been printed, but then lines are added / changed then change the Printed flag back to No
If [M:BOL0]PRNFLG = 2 : [M:BOL0]PRNFLG = 1 : Affzo [M:BOL0]PRNFLG : Endif

# The totals will be recalculated in the routine below
[M:BOL1]DSPTOTQTY = 0
[M:BOL1]DSPTOTVOL = 0
[M:BOL1]DSPTOTWEI = 0

STRTNOLB = 0
# If not regenerating ALL lines, start with the new BOL2 lines
If [M:BOL0]ADJFLG = 2 : STRTNOLB = [M:BOL1]BOL2LINS : Endif
If STRTNOLB > [M:BOL2]NBLIGC-1 : End : Endif

# Summarize and generate lines
For NOLB=STRTNOLB To [M:BOL2]NBLIGC-1
 If [M:BOL2]DOCNUMCON(NOLB)<>""
 Case [M:BOL0]BOLTYP
  When 1 # Customer
    # Create the BOL2 lines from the header
    Read [F:SDH]SDH0 = [M:BOL2]DOCNUMCON(NOLB)
    NOL = NOLB : Gosub BOL2_SET_DLINS
    # First read for Packed lines for the Delivery
    Filter [F:SPD]
    For [F:SPD]SPD0 Where VCRTYP=4 & VCRNUM=[M:BOL2]DOCNUMCON(NOLB)
      TMPFRT = "" :  TMPPCK = "" : LINPCK = "" : TMPNMFC=""
      TPAVOL = 0 : TPAVOU = "" : TPAWEU = ""
      Read [F:ITF]ITF0 = [F:SPD]ITMREF; [F:SPD]STOFCY
      If !fstat : Gosub READ_FRTCLS : Endif
      If [F:SPD]PCK <> ""
        LINPCK = [F:SPD]PCK
      Endif
      If LSTPACNUM = [F:SPD]PACNUM & LSTFRTCLS <> TMPFRT
        # If there are multiple Freight classes in the same Package then create 1 line with a blank FRTCLS
        TMPFRT = ""
        TMPPCK = LSTPCK
        FRTLIN = LSTFRTLIN
      Else
        FRTLIN = 0 : Gosub FIND_FRT_LIN
      Endif
      [M:BOL1]FRTCLS(FRTLIN) = TMPFRT
      [M:BOL1]PCK(FRTLIN)    = TMPPCK
      [M:BOL1]NMFC(FRTLIN)   = TMPNMFC
      If LSTPACNUM <> [F:SPD]PACNUM : [M:BOL1]NBRPCK(FRTLIN) += 1 : Endif
      # Convert the line weight to the Global weight UOM if needed
      TMPDEC = [F:SPD]NETWEI
      If [F:SPD]WEU <> GSALDSPWEU : Call CONVERT_QTY ([F:SPD]WEU,GSALDSPWEU,TMPDEC) From TRTX3 : Endif
      If TMPDEC = 0 and [F:SPD]NETWEI <> 0 : TMPCONV = 1 : Endif
      [M:BOL1]WEU(FRTLIN)    = GSALDSPWEU
      [M:BOL1]NETWEI(FRTLIN) += TMPDEC
      [M:BOL1]GROWEI(FRTLIN) += TMPDEC
      If LSTPACNUM <> [F:SPD]PACNUM : [M:BOL1]PACWEI(FRTLIN) += TPAPCKWEI : Endif
      If LSTPACNUM <> [F:SPD]PACNUM : [M:BOL1]GROWEI(FRTLIN) += TPAPCKWEI : Endif
      If LSTPACNUM <> [F:SPD]PACNUM : [M:BOL1]VOL(FRTLIN)    += TPAVOL : Endif
      [M:BOL1]VOU(FRTLIN) = GSALDSPVOU
      LSTPACNUM = [F:SPD]PACNUM : LSTPCK = TMPPCK : LSTFRTCLS = TMPFRT : LSTFRTLIN = FRTLIN
    Next
    # Then read the Delivery line table for lines that are not Packed, PACQTYSTU = 0
    Filter [F:SDD]
    For [F:SDD]SDD0 Where SDHNUM = [M:BOL2]DOCNUMCON(NOLB) & [F:SDD]PACQTYSTU = 0
      TMPFRT = "" :  TMPPCK = "" : LINPCK = "" : TMPNMFC=""
      TPAVOL = 0 : TPAVOU = "" : TPAWEU = ""
      Read [F:ITF]ITF0 = [F:SDD]ITMREF; [F:SDD]STOFCY
      If !fstat : Gosub READ_FRTCLS : Endif
      If [F:SDD]PCK <> ""
        LINPCK = [F:SDD]PCK
      Endif
      FRTLIN = 0 : Gosub FIND_FRT_LIN
      [M:BOL1]FRTCLS(FRTLIN) = TMPFRT
      [M:BOL1]PCK(FRTLIN)    = TMPPCK
      [M:BOL1]NMFC(FRTLIN)   = TMPNMFC
      [M:BOL1]NBRPCK(FRTLIN) += 1
      # Convert the line weight to the Global weight UOM if needed
      TMPDEC = ([F:SDD]QTY * [F:SDD]UNTWEI)
      If [F:SDD]WEU <> GSALDSPWEU : Call CONVERT_QTY ([F:SDD]WEU,GSALDSPWEU,TMPDEC) From TRTX3 : Endif
      If TMPDEC = 0 and ([F:SDD]QTY * [F:SDD]UNTWEI) <> 0 : TMPCONV = 1 : Endif
      [M:BOL1]NETWEI(FRTLIN) += TMPDEC
      [M:BOL1]PACWEI(FRTLIN) += TPAPCKWEI
      [M:BOL1]GROWEI(FRTLIN) += (TPAPCKWEI + TMPDEC)
      [M:BOL1]WEU(FRTLIN)    = GSALDSPWEU
      [M:BOL1]VOL(FRTLIN)    += TPAVOL
      [M:BOL1]VOU(FRTLIN)    = GSALDSPVOU
    Next
  When 2 # Supplier
    # Create the BOL2 lines from the header
    Read [F:PNH]PNH0 = [M:BOL2]DOCNUMCON(NOLB)
    NOL = NOLB : Gosub BOL2_SET_RLINS
    Filter [F:PND]
    For [F:PND]PND0 Where PNHNUM = [M:BOL2]DOCNUMCON(NOLB)
      TMPFRT = "" :  TMPPCK = "" : LINPCK = "" : TMPNMFC=""
      TPAVOL = 0 : TPAVOU = "" : TPAWEU = ""
      Read [F:ITF]ITF0 = [F:PND]ITMREF; [F:PND]PNHFCY
      If !fstat : Gosub READ_FRTCLS : Endif
      FRTLIN = 0 : Gosub FIND_FRT_LIN
      [M:BOL1]NBRPCK(FRTLIN) += 1
      [M:BOL1]FRTCLS(FRTLIN) = TMPFRT
      [M:BOL1]PCK(FRTLIN)    = TMPPCK
      [M:BOL1]NMFC(FRTLIN)   = TMPNMFC
      # For Supplier package weight comes from Item PCK info
      [M:BOL1]PACWEI(FRTLIN) += TPAPCKWEI
      # Convert the line weight to the Global weight UOM if needed
      TMPDEC = ([F:PND]QTYUOM * [F:PND]UNTWEI)
      If [F:PND]WEU <> GSALDSPWEU : Call CONVERT_QTY ([F:PND]WEU,GSALDSPWEU,TMPDEC) From TRTX3 : Endif
      If TMPDEC = 0 and ([F:PND]QTYUOM * [F:PND]UNTWEI) <> 0 : TMPCONV = 1 : Endif
      [M:BOL1]NETWEI(FRTLIN) += TMPDEC
      [M:BOL1]GROWEI(FRTLIN) += (TPAPCKWEI +TMPDEC)
      [M:BOL1]WEU(FRTLIN)    = GSALDSPWEU
      [M:BOL1]VOL(FRTLIN)    += TPAVOL
      [M:BOL1]VOU(FRTLIN)    = GSALDSPVOU
    Next
 Endcase
 Endif
Next

# Must recalc totals separately because we do not know how many BOL1 lines were added
For NOL = 0 To [M:BOL1]NBLIG-1
  Gosub BOL1_TOTALS
Next

Affzo [M:BOL2]
Affzo [M:BOL1]

If TMPCONV <> 0 : GMESSAGE = mess (182,190,1) : Endif

End

######################################################################################
$FIND_FRT_LIN

Local Integer TMPLIN, FOUNDLIN, XTMPLIN, XFOUNDLIN
FOUNDLIN = 0
TPAPCKWEI = 0

Gosub READ_PCK

TMPPCK = LINPCK
For TMPLIN = 0 To [M:BOL1]NBLIG-1
  If TMPFRT=[M:BOL1]FRTCLS(TMPLIN) & TMPPCK=[M:BOL1]PCK(TMPLIN) & TMPNMFC=[M:BOL1]NMFC(TMPLIN)
    FRTLIN = TMPLIN
    FOUNDLIN = 1
    Break
  Endif
Next

# If manual adj = Yes and FRTCLS + PCK + NMFC combination exists then we possibly need to create a new FRTCLS + PCK line instead
If FOUNDLIN
  # Now we are going to allow duplicate lines of FRTCLS + PCK + NMFC, so do not clear out TMPFRT and TMPPCK
  If [M:BOL0]ADJFLG=2 & TMPLIN <= [M:BOL1]BOL1LINS
    # But first check to see if it also match a new line added (>BOL1LINS), if yes then add to that line instead of creating a new line
    If [M:BOL1]NBLIG-1 > [M:BOL1]BOL1LINS
      For XTMPLIN = [M:BOL1]BOL1LINS+1 To [M:BOL1]NBLIG-1
        If TMPFRT=[M:BOL1]FRTCLS(XTMPLIN) & TMPPCK=[M:BOL1]PCK(XTMPLIN) & TMPNMFC=[M:BOL1]NMFC(XTMPLIN)
          FRTLIN = XTMPLIN
          XFOUNDLIN = 1
          Break
        Endif
      Next
      If !XFOUNDLIN
        # Create a new line - the FRTCLS + PCK combination was not found in the newly added lines
        [M:BOL1]NBLIG += 1
        FRTLIN = [M:BOL1]NBLIG-1
      Endif
    Else
      # Create a new line - no additional lines have been added yet
      [M:BOL1]NBLIG += 1
      FRTLIN = [M:BOL1]NBLIG-1
    Endif
  Endif
Else
  # Create a new line - the FRTCLS + PCK combination was not found
  [M:BOL1]NBLIG += 1
  FRTLIN = [M:BOL1]NBLIG-1
Endif

Return

######################################################################################
$READ_FRTCLS

# Setting the Product site fields here as well
TMPFRT = [F:ITF]FRTCLS
LINPCK = [F:ITF]PCK
If dim([F:ITF]NMFC)>0 : TMPNMFC = [F:ITF]NMFC : Endif

# Read the Freight class table
Read [F:FRT]FRT0 = TMPFRT; GCURLEG
If fstat
  Read [F:FRT]FRT0 = TMPFRT; ""
Endif
# If there is a valid record, now check if its active
If !fstat
  If [F:FRT]ENAFLG <> 2
    TMPFRT = ""
  Endif
Else
  TMPFRT = ""
Endif

# Read the NMFC table
Read [F:FCC]FCC0 = 1;TMPNMFC
# If there is a valid record, now check if its active
If !fstat
  If [F:FCC]ENAFLG <> 2
    TMPNMFC = ""
  Endif
Else
  TMPNMFC = ""
Endif

Return

######################################################################################
$READ_PCK

Read [F:TPA]TPA0 = LINPCK
If !fstat
  TPAPCKWEI = [F:TPA]PCKWEI
  # Convert the package weight to the Global weight UOM if needed
  If [F:TPA]WEU <> GSALDSPWEU : Call CONVERT_QTY ([F:TPA]WEU,GSALDSPWEU,TPAPCKWEI) From TRTX3 : Endif
  # Volume information comes from the packing table and convert VOL to the Global volume UOM if needed
  TPAVOL    = [F:TPA]VOL
  TPAVOU    = [F:TPA]VOU
  If TPAVOU <> GSALDSPVOU : Call CONVERT_QTY (TPAVOU,GSALDSPVOU,TPAVOL) From TRTX3 : Endif
Endif

Return

######################################################################################
# Set the button text and call the correct action to drill into the document number
# Has to be on NBLIGC since entry to the DOCNUMCON field is disabled via mkstat=2
######################################################################################
Subprog IB_NBLIGC
Raz GBIDC1, GBOUT1

Case [M:BOL0]BOLTYP
When 1
  Call TEXTE (10991,GBOUT1) From OBJDIV
When 2
  Call TEXTE (11008,GBOUT1) From OBJDIV
Endcase

End


Subprog B1_NBLIGC
Local Char SAVFONC(20)
Local Char PARMSK(250)(1..20) , SAVACT(20)

SAVACT = GACTION : GACTION = "GOBJET"
SAVFONC = GFONC1

Case [M:BOL0]BOLTYP
When 1        : GBIDC1="SDH" : GFONC1="GESSDH"
When 2        : GBIDC1="PNH" : GFONC1="GESPNH"
When Default  : End
Endcase

Call OBJET_CHAR([M:BOL2]DOCNUMCON(nolign-1),GBIDC1,"") From GOBJET
GACTION = SAVACT
GFONC1  = SAVFONC

End

######################################################################################

