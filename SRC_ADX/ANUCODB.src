#<AdxTL>@(#)4.0.0.0 $Revision$
End

$ACTION
Case ACTION
 When "ANUDEB" : Gosub ANUDEB
 When "ANULNK" : Gosub ANULNK
 When "ANUEND" : Gosub ANUEND
 When "ANUCTL" : Gosub ANUCTL
 When "ANUEXE" : Gosub ANUEXE
Endcase
Return


$ANUDEB
# EMERAUDE - Feature MULTILEG- Requirement 71216
# Nb record for the same "CODE"


Local Integer NBROTHLEG                      # Number of records for the same "CODE"
Local Char    OTHLEG(GLONADI)(1..GNBLEG+1)   # List of legislation

Local Integer FLGLEGCPY                      # FLGLEGCPY = 1 (Field of Data Type = ADI;909 = Legislation)
                                             # FLGLEGCPY = 2 (Field of Data Type = CPY)
                                             # FLGLEGCPY = 3 (Field of Data Type = FCY)

Local Char  NAMFLD(50)                       # If FLGLEGCPY = 1, NAMFLG = Name of Field of Data Type = ADI;909)
                                             # If FLGLEGCPY = 2, NAMFLG = Name of Field of Data Type = CPY)
                                             # If FLGLEGCPY = 3, NAMFLD = Name of Field of Data Type = FCY)

Local Char  VALFLD(50)                       # If FLGLEGCPY = 2, VALFLD = Value of NAMFLD = Company
                                             # If FLGLEGCPY = 3, VALFLD = Value of NAMFLD = Facility

Local Integer INDCPY, INDFCY                 # Variables' work
#
If nomap=APPLI or filinfo(filpath("FIL",NOMFIC,"fde",APPLI),0)<0
 Local File =NOMFIC [AR__]
Else
 Local File =APPLI+"."+NOMFIC [AR__]
Endif

NBROTHLEG = 0
Onerrgo NOTHING
For I1=1 To NBCLE
 If SUBCLE(I1)="LEG"
  SUBCRIT =SUBCLE(1)+"='"+SUPP+"'"
  Filter [AR__] Where evalue(SUBCRIT)
  For [F:AR__]
   NBROTHLEG +=1
   OTHLEG(NBROTHLEG) = [F:AR__]LEG
  Next
  Filter [AR__]
  Raz SUBCRIT
  Break
 Endif
Next
Onerrgo

#----- AT2 est ouvert sous VERIFICATION (ANNUL=1) mais non ouvert pour ANNULATION (ANNUL=2 ou ANNUL=3)
#-----  Peut-être plus simple de le mettre sous ANUCOD ?

If clalev([F:AT2_]) : Close File [AT2_] : Endif

If nomap=APPLI or filinfo(filpath("FIL","ATABLE","fde",APPLI),0)<0
 Local File ATABZON [AT2_]
Else
 Local File =APPLI+".ATABZON" [AT2_]
Endif
Return

#---- Initialization NAMFLD & FLGLEGCPY if NBROTHLERG>1
$ANULNK
[L]NAMFLD = ""
If NBROTHLEG<=1 : Return : Endif
If [F:A_TZ]EXPLIEN="" or NOLIEN=1 : Return : Endif

For I1=1 To NBCLE
 Read [AT2_]CODZONE = FICHIER;SZONE(NBZ,I1)
 If fstat
  # FGR 22/04/2013 : X3SUIVI71937
  #If SZONE(NBZ,I1)="[V]GSUPCLE" & SUBCLE(I1)="LEG"
  If (SZONE(NBZ,I1)="[V]GSUPCLE" | SZONE(NBZ,I1)="[V]GCURLEG") & SUBCLE(I1)="LEG"
   Filter [AT2_] Where CODFIC=FICHIER &
&   ( (CODTYP="ADI" & instr(1,EXPLIEN,"909")) | CODTYP="CPY" | CODTYP="FCY")
&  Order By CODTYP;NUMLIG
   Read [AT2_] First
   Filter [AT2_]
   If !fstat
    Case [F:AT2_]CODTYP
     When "ADI"    : FLGLEGCPY = 1 : NAMFLD = [F:AT2_]CODZONE
     When "CPY"    : FLGLEGCPY = 2 : NAMFLD = [F:AT2_]CODZONE
     When "FCY"    : FLGLEGCPY = 3 : NAMFLD = [F:AT2_]CODZONE
    Endcase
   Endif
   Filter [AT2_]
   Break
  Endif
 Endif
Next I1
Return


$ANUCTL

# On ANUCOD, Initialization OK = 1.
#   If OK=1 => Record will not be deleted
#   If OK=0 => Record will be deleted

If NBROTHLEG>1 & SUBCLE(K)="LEG"
 If NAMFLD<>"" & evalue("[F:LIE_]"+NAMFLD)<>""
  VALFLD = evalue("[F:LIE_]"+NAMFLD)
  If FLGLEGCPY=1
   If evalue("[F:AN__]"+SUBCLE(K))<>""
    # Record with legislation (FRA, USA, POL, ITA,...)
    If find("",OTHLEG(1..NBROTHLEG))  :  OK = 0 : Endif
    If VALFLD<>evalue("[F:AN__]"+SUBCLE(K)) : OK = 0 : Endif
   Else
    # Record with legislation empty
    #If find(GLEGSOC(INDCPY),OTHLEG(1..NBROTHLEG))  :  OK = 0 : Endif
    OK = 0
   Endif
   Return
  Elsif FLGLEGCPY=2
   INDCPY = find(VALFLD,GSOC(1..GNBSOC))
  Elsif FLGLEGCPY=3
   INDFCY = find(VALFLD,GSITE(1..GNBSITE))
   If INDFCY
    INCPY = find(GSOCSITE(INDFCY),GSOC(1..GNBSOC))
   Else
    INDCPY = 0
   Endif
  Endif
  If INDCPY
   If evalue("[F:AN__]"+SUBCLE(K))<>""
    # Record with legislation (FRA, USA, POL, ITA,...)
    If GLEGSOC(INDCPY)<>evalue("[F:AN__]"+SUBCLE(K)) : OK = 0 : : Endif
   Else
    # Record with legislation empty
    If find(GLEGSOC(INDCPY),OTHLEG(1..NBROTHLEG))  :  OK = 0 : : Endif
   Endif
  Endif
 Else
  OK = 0
 Endif
Endif
Return

$ANUEXE
# On ANUCOD, Initialization OK = 1.
#   If OK=1 => Record or Value of field will be deleted/RTZ
#   If OK=0 => Record or Value of field not will be deleted/RTZ
If SUBCLE(K)="LEG"
 If NAMFLD<>"" & evalue("[F:"+[F:A_TB]ABRFIC+"]"+NAMFLD)<>""
  VALFLD=evalue("[F:"+[F:A_TB]ABRFIC+"]"+NAMFLD)
  If FLGLEGCPY=1
   If evalue("[F:AN__]"+SUBCLE(K))<>""
    # Record with legislation (FRA, USA, POL, ITA,...)
    If find("",OTHLEG(1..NBROTHLEG))  :  OK = 0 : Endif
    If VALFLD<>evalue("[F:AN__]"+SUBCLE(K)) : OK = 0 : Endif
   Else
    # Record with legislation empty
    #If find(GLEGSOC(INDCPY),OTHLEG(1..NBROTHLEG))  :  OK = 0 : Endif
    If NBROTHLEG>1 : OK = 0 : Endif
   Endif
   Return
  Elsif FLGLEGCPY=2
   INDCPY = find(VALFLD,GSOC(1..GNBSOC))
  Elsif FLGLEGCPY=3
   INDFCY = find(VALFLD,GSITE(1..GNBSITE))
   If INDFCY
    INCPY = find(GSOCSITE(INDFCY),GSOC(1..GNBSOC))
   Else
    INDCPY = 0
   Endif
  Endif
  If INDCPY & GLEGSOC(INDCPY)<>""
   If evalue("[F:AN__]"+SUBCLE(K))<>""
    # Record with legislation (FRA, USA, POL, ITA,...)
    If find("",OTHLEG(1..NBROTHLEG))  :  OK = 0 : Endif
    If GLEGSOC(INDCPY)<>evalue("[F:AN__]"+SUBCLE(K)) : OK = 0 : Endif
   Else
    # Record with legislation empty
    If find(GLEGSOC(INDCPY),OTHLEG(1..NBROTHLEG))  :  OK = 0 : Endif
   Endif
  Else
   If NBROTHLEG>1 : OK = 0 : Endif
  Endif
 Else
  If NBROTHLEG>1 : OK = 0 : Endif
 Endif
Endif
Return


$ANUEND
If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 or APPLI=GDOSH
 Return
Endif

If SUPP="" : Return : Endif

# If OK=1 => Record will not be deleted
# If OK=0 => Record will be deleted

OK = 0
For [ADP] Where TRAIT="SUB"+ABREV
 For [LIE_] Where PARAM=[F:ADP]PARAM & VALEUR=SUPP
  If NBROTHLEG>1
   # Legislation
   If [F:LIE_]CMP="*"
    If CODE<>""
     # Record with legislation (FRA, USA, POL, ITA,...)
     If [F:LIE_]FCY=CODE : OK = 1 : Break 2 : Endif
    Else
     # Record with legislation empty
     If !find([F:LIE_]FCY,OTHLEG(1..NBROTHLEG))  :  OK = 1 : Break 2 : Endif
    Endif
   Else
    INDCPY = 0
    If [F:LIE_]CMP<>""
     # Société
     VALFLD = [F:LIE_]CMP
     INDCPY = find(VALFLD,GSOC(1..GNBSOC))
    Elsif [F:LIE_]FCY<>""
     # Site
     VALFLD = [F:LIE_]FCY
     INDFCY = find(VALFLD,GSITE(1..GNBSITE))
     If INDFCY
      INDCPY = find(GSOCSITE(INDFCY),GSOC(1..GNBSOC))
     Else
      INDCPY = 0
     Endif
    Endif
    If INDCPY
     If CODE<>""
      # Record with legislation (FRA, USA, POL, ITA,...)
      If GLEGSOC(INDCPY)=CODE : OK = 1 : Break 2 : Endif
     Else
      # Record with legislation empty
      If !find(GLEGSOC(INDCPY),OTHLEG(1..NBROTHLEG))  :  OK = 1 : Break 2: Endif
     Endif
    Endif
   Endif
  Else
   OK = 1 : Break 2
  Endif
 Next LIE_
Next ADP
If OK
 FICHIER = "ADOVAL"
 Gosub ERREUR From ANUCOD
 OKANU = 0
Endif
Return

$NOTHING
Resume
