#<AdxTL>@(#)8.0.0.0 $Revision$
######################################################################
# IMPROT : Import / Export Operation standard                        #
######################################################################

$ACTION
Case ACTION
    When "IMP_OUVRE" :     Gosub OUVRE
    When "IMPORT" :        Gosub IMPORT
    When "EXP_OUVRE"       Gosub EXP_OUVRE 
    When "EXPORT"          Gosub EXPORT 
Endcase
Return

######################################################################
$OUVRE
Local Integer  OKCHAMP
Gosub OUVRE_TEXTE
Return

#---------------------------------------------------------------------
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
  When "IMP_OUVRE"    : G_IMPORT=1 
  When "EXP_OUVRE"    : G_EXPORT=1 
Endcase

#   textes ROUOPESTD : Operation standard    ( texte *71 à *78 )
TSTCHAMP(1) ="ROT*71" : TSTCHAMP(2) ="ROT*72" : TSTCHAMP(3)="ROT*73" : TSTCHAMP(4) ="ROT*74"
TSTCHAMP(5) ="ROT*75" : TSTCHAMP(6) ="ROT*76" : TSTCHAMP(7)="ROT*77" : TSTCHAMP(8) ="ROT*78"

Gosub OUVRE_TEXTE From TRTX3IMP
Return

######################################################################
$IMPORT

Gosub IMPORT_TEXTE

Return

#---------------------------------------------------------------------
$IMPORT_TEXTE

If IMPFIC="ROT" & G_ENT
   Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP 
   If G_CLE_CLOB<>"" : [M:ROT0]OPETEXNUM=G_CLE_CLOB : Endif
Endif

Return

#######################################################################

$EXP_OUVRE
Gosub OUVRE_TEXTE
Return

$EXPORT
Raz G_CLE_CLOB, G_ZON_CLOB
If EXPFIC="ROT" 
  If G_ENT
     Gosub EXP_RAZ_T1 From TRTX3IMP
     If dim([F:ROT]OPETEXNUM)>0 & [F:ROT]OPETEXNUM<>""
        G_CLE_CLOB=[F:ROT]OPETEXNUM : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
     Endif
  Endif
Endif 

Return

#######################################################################




