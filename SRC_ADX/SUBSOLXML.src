#<AdxTL>@(#)9.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML d'une Solution                                                        Version 140
#   Module CRM                             
#
#   XXXINXML    : Objet unique avec ses tables liées en multi-niveaux.
#   XXXLISTXML  : Liste filtrée de la table objet.
#   
###############################################################################################################

Subprog SOLINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZRECNUM = "" : End : Endif

Gosub XMLPART1 From CRMXML140

Call TEXTE(14610, SZHTMLTITLE) From OBJDIV      #Solution
SZSUBPROG = "SOLINXML"
SZAOBABREV = "SOL"

Gosub XMLPART2 From CRMXML140
If IERRINF : End : Endif

Gosub DOCOREXML

Gosub XMLPART3 From CRMXML140

End

#########################################################################################################################
Subprog SOLLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZCUSTFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFILTER
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZFILTER = ""
    SZFILTER = "1=1"
Endif

Gosub XMLPART1 From CRMXML140

Call TEXTE(14576, SZHTMLTITLE) From OBJDIV      #Solutions
SZSUBPROG = "SOLLISTXML"
SZAOBABREV = "SOL"

Gosub XMLPART2B From CRMXML140
If IERRINF : End : Endif

Gosub DOLISTXML

Gosub XMLPART3 From CRMXML140

End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOLISTXML

Gosub SETSOLEXCEPT From CRMEXCEPT

#On extrait
Filter [SOL] Where evalue(SZFILTER)

For [SOL]
    SZCTAOB = "SOL"
    SZCTAOBNUM = [F:SOL]NUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLSOL From CRMEXCEPT
Next

Filter [SOL]
Return

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREXML

Gosub SETSOLEXCEPT From CRMEXCEPT

########################################################
#Variable particulière pour solution associée
Local Integer IDIMCODSOL
IDIMCODSOL = dim([F:SOL]CODSOL)
Local Char SZCODSOL(30)(IDIMCODSOL)
Local Integer ITERCODSOL
ITERCODSOL = 0
Raz SZCODSOL
########################################################

#On extrait
Filter [SOL] Where [F:SOL]NUM = SZRECNUM

For [SOL]
    SZCTAOB = "SOL"
    SZCTAOBNUM = [F:SOL]NUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLSOL From CRMEXCEPT

    ITERCODSOL = 0
    For ITERCODSOL = 0 To dim([F:SOL]CODSOL) - 1
        SZCODSOL(ITERCODSOL) = [F:SOL]CODSOL(ITERCODSOL)
    Next
Next

Filter [SOL]

If IDISPLAYSOL
    ITERCODSOL = 0
    For ITERCODSOL = 0 To dim(SZCODSOL) - 1
        If SZCODSOL(ITERCODSOL) <> ""
            Read [SOL] SOL0 = SZCODSOL(ITERCODSOL)
            If !fstat
                SZCTAOB = "SOL"
                SZCTAOBNUM = [F:SOL]NUM
                SZCTLEVEL = "1"
                SZCTPARENTAOB = "SOL"
                SZCTPARENTNUM = SZRECNUM
                Gosub XMLSOL2 From CRMEXCEPT
            Endif
        Endif
    Next
Endif

Return




