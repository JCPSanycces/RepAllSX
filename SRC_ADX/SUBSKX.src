#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# SUBSKX : Points d'entrée des gestions de transaction     HCB 19/10/04 #
#          de saisie stock                                              #
# --------------------------------------------------------------------- #
# Ce traitement est commun à toutes les gestions des transactions de    #
# saisie du module stock il est appelé depuis les traitements :         #
#    - SUBPBY : Assemblage/Désassemblage                                #
#    - SUBSCT : Changement stock                                        #
#    - SUBSLT : Modification lot                                        #
#    - SUBSNP : Inventaire                                              #
#    - SUBSOT : Sortie diverse                                          #
#    - SUBSQT : Controle qualité                                        #
#    - SUBSRG : Plan de rangement                                       #
#    - SUBSRO : Plan de réapprovisionnement                             #
#    - SUBSRT : Entrée diverse                                          #
#    - SUBPRE : Plan préparation d'expéditions                          #
#    - SUBPRT : Bon de préparation                                      #
#########################################################################

$PE_STKTRS

#-----------------------------------------------------------#
# Point d'entrée STKTRS permet de gérer la présence et le   #
#        mode de saisie des champs spécifiques              #
# --------------------------------------------------------- #
# Variables utilisables par le point d'entrée :             #
#   FJL      : Type de transaction en cours de gestion      #
#    - "PBY" : Assemblage/Désassemblage                     #
#    - "SCT" : Changement stock                             #
#    - "SLT" : Modification lot                             #
#    - "SNP" : Inventaire                                   #
#    - "SOT" : Sortie diverse                               #
#    - "SQT" : Controle qualité                             #
#    - "SRG" : Plan de rangement                            #
#    - "SRO" : Plan de réappro zone consommation            #
#    - "SRT" : Entrée diverse                               #
#    - "PRE" : Plan préparation d'expéditions               #
#   PACTION  : Action du GOBJET                             #
#     "APRES_MODIF" Après saisie de chaque champ            #
#     "RAZCRE"      Initialisation après entrée en création #
#     "INICRE"      Avant l'écriture de l'enregistrement    #
#     "CREATION"    Après l'écriture de l'enregistrement    #
#     "LIENS"       Après lecture de chaque enregistrement  #
#     "INIMOD"      Avant la réécriture de l'enregistrement #
#     "MODIF"       Après la réécriture de l'enregistrement #
#   PVERSION : Numéro de version                            #
#-----------------------------------------------------------#
If dim(FJL)<0      Local Char    FJL(3)      : Endif
If dim(PACTION)<0  Local Char    PACTION(20) : Endif
If dim(PVERSION)<0 Local Integer PVERSION    : Endif
FJL       =mid$(GFONCTION,4,3)
PACTION   =ACTION
PVERSION  =val(ctrans(GVERSION,".",""))
GPOINT    ="MAJTRS" : Gosub ENTREE From EXEFNC
Return

#--- Issue 92563
$PE_STKTRSWIN
#----------------------------------------------#
# Point d'entrée STKTRSWIN permet d'intervenir #
# sur la fenêtre générée avant le Write        #
# -------------------------------------------- #
# Le buffer [F:AWI] est chargé                 #
#----------------------------------------------#
GPOINT="STKTRSWIN" : Gosub ENTREE From EXEFNC
Return

$PE_STKTRSAWB
#-------------------------------------------------------------#
# Point d'entrée STKTRSAWB permet d'intervenir                #
# sur les browser de la fenêtre générée avant le Write        #
# ----------------------------------------------------------- #
# Le buffer [F:AWB] est chargé                                #
# ----------------------------------------------------------- #
GPOINT="STKTRSAWB" : Gosub ENTREE From EXEFNC
Return
#---
