Subprog C_NBLIG
Local Integer NOL
NOL = nolign-1
If (find(status,65,68,83) | adxgtb=1) & !GIMPORT
  If ([M:PRH1]LINTYP(NOL)>2 & [M:PRH1]LINTYP(NOL)<6)
    GMESSAGE = mess(26,192,1) : mkstat = 2
  Endif
Endif
End
