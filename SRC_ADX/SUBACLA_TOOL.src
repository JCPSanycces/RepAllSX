#<AdxTL>@(#)0.0.0.0 $Revision$


Subprog SEL_METHOD(CLA_COD, SEL_MOD, VALEUR)
Value Char CLA_COD
Value Integer SEL_MOD # 1:all  2:without operation   3:operation only
Variable Char    VALEUR()

 Gosub DEFLIST_METH
 Gosub LIST_METH

 CHOI = 0
 TIT(0)=mess(8,31,1) # Sélection
 TIT(1)=func AMK_TOOL.GET_FIELD_LABEL("ACLA2", "CODMET") # Code
 TIT(2)=func AMK_TOOL.GET_FIELD_LABEL("ACLA2", "INTITMET") # Libellé
 TIT(3)=func AMK_TOOL.GET_FIELD_LABEL("ACLA2", "DONMET") # Retour
 TIT(4)=func AMK_TOOL.GET_FIELD_LABEL("ACLA2", "FLGOPE") # Operation

 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0 : VALEUR = TEX(CHOI,1) : Endif
End

$DEFLIST_METH
 Local Char    TEX(GLONDES)(1..500,1..4) , TIT(GLONDES)(0..4) , CRITERE(250)
Return

$LIST_METH
 Local Integer NBTEX, CHOI,WMETHOK

 If CLA_COD="" or !find(SEL_MOD, 1,2,3) : End : Endif

 CRITERE = 'CODCLA="'+[L]CLA_COD+'"'
 Case SEL_MOD
  When 2 :  # without operation
   CRITERE += " & FLGOPE <> 2"
  When 3 : # Operatin only
   CRITERE += " & FLGOPE = 2"
 Endcase

 For [ACLAM] Where evalue(CRITERE)
  WMETHOK=1
  For [ACLPD] Where CODCLA=[L]CLA_COD & CODE=[F:ACLAM]CODMET & TYPINTPAR=13
    WMETHOK=0
  Next
  If WMETHOK=1
    NBTEX+= 1
    TEX(NBTEX,1) = [F:ACLAM]CODMET
    Call TEXTE([F:ACLAM]INTMET,TEX(NBTEX,2)) From OBJDIV
    TEX(NBTEX,3) = mess([F:ACLAM]DONMET,7843,1)
    TEX(NBTEX,4) = mess([F:ACLAM]FLGOPE,1,1)
  Endif
 Next
Return


#-------------------------------------------------------------------#
# Properties synchronization
#-------------------------------------------------------------------#
Subprog TRTMAJ_ALL_ACLAFLD(PDOSSIER,PVALDIF)
Value Char PDOSSIER
Value Integer PVALDIF
Local Char DEBACLA(30),FINACLA(30)
Gosub _TRTMAJ_ALL_ACLAFLD
End

#-------------------------------------------------------------------#
Subprog TRTMAJ_FILTER_ACLAFLD(PDOSSIER,PVALDIF,DEBACLA,FINACLA)
Value Char PDOSSIER
Value Integer PVALDIF
Value Char DEBACLA,FINACLA
Gosub _TRTMAJ_ALL_ACLAFLD
End

$_TRTMAJ_ALL_ACLAFLD
Local Integer ERR,SAVGVALID,INTERRUPT,COUNT,N
Local Char CRITERE(250)

#Validation différée (à la volée)
[L]SAVGVALID=GVALIDDIFF
If [L]PVALDIF=2
  GVALIDDIFF=3
Else
  GVALIDDIFF=1
Endif

If GTRACE<>"" & ([L]DEBACLA="" | [L]FINACLA="")
 Call ECR_TIME(mess(276,143,1)-"-"-mess(3,23,1)-[L]PDOSSIER) From DOSSUB
Endif

Local File =[L]PDOSSIER+".ACLASSE" [ACLAZ]

DEBDEB = DEBACLA
FINFIN = FINACLA
If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif

Raz [L]CRITERE
If [L]DEBACLA<>""
 [L]CRITERE = 'CODCLA>="'+[L]DEBACLA+'"'
Endif
If [L]FINACLA<>""
 If [L]CRITERE<>"" : [L]CRITERE -= '&' : Endif
 [L]CRITERE -= 'CODCLA<="'+[L]FINACLA+'"'
Endif
If CRITERE<>""
 Filter [ACLAZ] Where evalue([L]CRITERE)
Endif
COUNT=rowcount([F:ACLAZ])

If !GSERVEUR
 Call OUVRE_BOITE(mess(276,143,1),COUNT) From GESECRAN
Endif
N=0
For [ACLAZ]
  If !GSERVEUR
   Call AFF_BOITE(mess(3,140,1)-[F:ACLAZ]CODCLA,N,INTERRUPT) From GESECRAN
  Endif
  If GTRACE<>"" & ([L]DEBACLA<>"" | [L]FINACLA<>"")
    Call ECR_TRACE(mess(291,123,1)-':'-mess(3,140,1)-[F:ACLAZ]CODCLA,0) From GESECRAN
  Endif
  Call _TRTMAJ_ACLAFLD(0,1,[L]PDOSSIER,[F:ACLAZ]CODCLA,ERR)
  N+=1
Next

Filter [ACLAZ]
If !GSERVEUR
 Call FERME_BOITE From GESECRAN
Endif

GVALIDDIFF=[L]SAVGVALID

Return

#----------------------------------------------------------#
Subprog _TRTMAJ_ACLAFLD(TEST,SILENCE,DOSSIER,CODCLA,ERR)
Value Integer TEST,SILENCE
Value Char    DOSSIER
Value Char    CODCLA
Variable    Integer  ERR

Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Local Integer OK, ISACLALOCK : [L]ISACLALOCK=1
Local Integer I,MAJPAR
Gosub OPEN_FILE  From ACLAVALLEC
Global Integer GMODIFPAR
GMODIFPAR = 0

If TEST : Call ECR_TRACE("-"-mess(3,140,1)-[L]CODCLA,0) From GESECRAN : Endif

If [L]DOSSIER=nomap
 Lock ="ACLA~"+[L]CODCLA With lockwait=0
Else
 Lock ="ACLA~"+[L]CODCLA From =[L]DOSSIER With lockwait=0
Endif
If fstat
 [L]ISACLALOCK=0
 If GTRACE<>""
  Call ECR_TRACE([L]CODCLA-mess(10,100,1)-":"-mess(278,143,1),-1) From GESECRAN
 Endif
 Goto FIN_TRTMAJ_ACLA
Else
 [L]ISACLALOCK=1
Endif

Read [ACLA]ACLA0=[L]CODCLA
If fstat
 If GTRACE<>"" : Call ECR_TRACE([L]CODCLA-mess(4,140,1),1) From GESECRAN : Endif
 Goto FIN_TRTMAJ_ACLA
Endif

If filinfo(filpath("ECR","ACLA0","msk",DOSSIER),7)<=0
  If dim(GACTX.LAN)>0 & GACTX.LAN<>""
  Call VALIDDIRECT ("ACLA0",DOSSIER,1,GACTX.LAN,1,OK) From VALMSK
  Elsif dim(GLANGUE)>0 & GLANGUE<>""
  Call VALIDDIRECT ("ACLA0",DOSSIER,1,GLANGUE,1,OK) From VALMSK
  Else
  Call VALIDDIRECT ("ACLA0",DOSSIER,1,"FRA",1,OK) From VALMSK
  Endif
Endif
If filinfo(filpath("ECR","ACLA1","msk",DOSSIER),7)<=0
  If dim(GACTX.LAN)>0 & GACTX.LAN<>""
  Call VALIDDIRECT ("ACLA1",DOSSIER,1,GACTX.LAN,1,OK) From VALMSK
  Elsif dim(GLANGUE)>0 & GLANGUE<>""
  Call VALIDDIRECT ("ACLA1",DOSSIER,1,GLANGUE,1,OK) From VALMSK
  Else
  Call VALIDDIRECT ("ACLA1",DOSSIER,1,"FRA",1,OK) From VALMSK
  Endif
Endif
If filinfo(filpath("ECR","ACLA6","msk",DOSSIER),7)<=0
  If dim(GACTX.LAN)>0 & GACTX.LAN<>""
  Call VALIDDIRECT ("ACLA6",DOSSIER,1,GACTX.LAN,1,OK) From VALMSK
  Elsif dim(GLANGUE)>0 & GLANGUE<>""
  Call VALIDDIRECT ("ACLA6",DOSSIER,1,GLANGUE,1,OK) From VALMSK
  Else
  Call VALIDDIRECT ("ACLA6",DOSSIER,1,"FRA",1,OK) From VALMSK
  Endif
Endif
If filinfo(filpath("ECR","ACLA8","msk",DOSSIER),7)<=0
  If dim(GACTX.LAN)>0 & GACTX.LAN<>""
  Call VALIDDIRECT ("ACLA8",DOSSIER,1,GACTX.LAN,1,OK) From VALMSK
  Elsif dim(GLANGUE)>0 & GLANGUE<>""
  Call VALIDDIRECT ("ACLA8",DOSSIER,1,GLANGUE,1,OK) From VALMSK
  Else
  Call VALIDDIRECT ("ACLA8",DOSSIER,1,"FRA",1,OK) From VALMSK
  Endif
Endif

Local Mask =[L]DOSSIER+".ACLA0" [ACLA0]
Local Mask =[L]DOSSIER+".ACLA1" [ACLA1]
Local Mask =[L]DOSSIER+".ACLA6" [ACLA6]
Local Mask =[L]DOSSIER+".ACLA8" [ACLA8]
Raz [M:ACLA0]
Raz [M:ACLA1]
Raz [M:ACLA6]
Raz [M:ACLA8]

GMODIFPAR=0
#Mise a jour des param + write/rewrite des parametres
[M:ACLA0]=[F:ACLA]
[M:ACLA1]=[F:ACLA]
Gosub LOAD_ACLAF

ERR=0
Onerrgo ERR_TRTMAJ_ACLAFLD
Trbegin [ACLFP]

MAJPAR=GMODIFPAR
If TEST : Call ECR_TRACE("              MAJPAR  :"-num$([L]MAJPAR),0) From GESECRAN : Endif
If MAJPAR & [L]ISACLALOCK=1
 Gosub SAVE_ACLAF
Endif


If ERR | [L]ISACLALOCK<>1 | MAJPAR=0
Rollback
Else
Commit
Endif

If !ERR & MAJPAR & [L]ISACLALOCK<>1
  If GTRACE<>""
   Call ECR_TRACE([L]CODCLA-mess(10,100,1)-":"-mess(278,143,1),-1) From GESECRAN
  Endif
Elsif !ERR & MAJPAR
  If GTRACE<>""
    Call ECR_TRACE("-"-mess(3,140,1)-[L]CODCLA,0) From GESECRAN
  Endif
  If MAJPAR
    Call ECR_TRACE(mess(208,143,1),0) From GESECRAN
  Endif
  Call VALIDATION(0,[L]DOSSIER,[L]CODCLA) From SUBACLA
  If nomap=[L]DOSSIER : Call TRACE_COR("ACLA", [L]CODCLA,"","m") From GOBJET :  Endif : # X3PLAT-2115
Endif

Onerrgo

Close Local Mask

$FIN_TRTMAJ_ACLA
If [L]DOSSIER=nomap
 Unlock ="ACLA~"+[L]CODCLA With lockwait=0
Else
 Unlock ="ACLA~"+[L]CODCLA From =[L]DOSSIER With lockwait=0
Endif
Gosub CLOSE_FILE From ACLAVALLEC
If TEST : Call ECR_TRACE("              ERR  :"-num$([L]ERR),0) From GESECRAN : Endif
nolign=SAVNOLIGN
End

$ERR_TRTMAJ_ACLAFLD
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
ERR=1
Resume

#------------------------------#
$LOAD_ACLAF
Local Integer I,J,K,L,M,N
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
nolign = 0
[M:ACLA8]WNBRPARALL = 0
For [ACLAF]ACLAF2 Where CODCLA=[M:ACLA0]CODCLA
 nolign += 1
 [M:ACLA6] = [F:ACLAF]
# Call TEXTE([F:ACLAF]INTFLD,[M:ACLA6]ZINTFLD(nolign-1)) From OBJDIV
# Call TEXTE([F:ACLAF]INTSHTFLD,[M:ACLA6]ZINTSHTFLD(nolign-1)) From OBJDIV
 Read [ATY]CODTYP = [F:ACLAF]CODTYP
 If !fstat & [F:ATY]TYPSELSYR=2
  [M:ACLA6]FLDCUR = [ACLAF]FLDCLA
  If [ACLAF]LOBTAB=""
   [M:ACLA6]CODTYPCUR = [ACLAF]CODTYP
  Else
   [M:ACLA6]CODTYPCUR  = [ACLAF]CODTYP + "." +[ACLAF]LOBTAB+"."+[ACLAF]LOBFLD
  Endif
  For [ACLFP] Where CODCLA=[M:ACLA0]CODCLA & TYPPAR=2 & TYPKEY=1 & FLDCLA=[F:ACLAF]FLDCLA
   [M:ACLA8]WCODTYP([M:ACLA8]WNBRPARALL)    = [F:ACLAF]CODTYP
   [M:ACLA8]WCODPAR([M:ACLA8]WNBRPARALL)    = [F:ACLFP]CODPAR
   [M:ACLA8]WFLDCLA([M:ACLA8]WNBRPARALL)    = [F:ACLFP]FLDCLA
   [M:ACLA8]WTYPINTPAR([M:ACLA8]WNBRPARALL) = [F:ACLFP]TYPINT
   [M:ACLA8]WTYPKEY([M:ACLA8]WNBRPARALL)    = [F:ACLFP]TYPKEY
   [M:ACLA8]WNUMPAR([M:ACLA8]WNBRPARALL)    = [F:ACLFP]NUMPAR
   [M:ACLA8]WTYPPAR([M:ACLA8]WNBRPARALL)    = [F:ACLFP]TYPPAR
   [M:ACLA8]WVALEUR([M:ACLA8]WNBRPARALL)    = [F:ACLFP]VALEUR
   [M:ACLA8]WISKEY([M:ACLA8]WNBRPARALL)     = 1
   [M:ACLA8]WNBRPARALL += 1
  Next
  Call L_LOAD_PARAM_ATY(nomap, [M:ACLA0]CODCLA, [F:ATY]CODTYP, [M:ACLA6]FLDCUR, 1, 1) From SUBACLA2
  If [ATY]CODCLA<>""
   Gosub L_LOAD_KEY From SUBACLA2
  Endif
  #97530
  J=0
  For I=0 To [M:ACLA8]WNBRPARALL-1
   If [M:ACLA8]WFLDCLA(I)=[M:ACLA6]FLDCUR & [M:ACLA8]WTYPKEY(I)=2  & [M:ACLA8]WCODTYP(I)=[M:ACLA6]CODTYPCUR
    J+=1
    K=I
   Endif
  Next
  If J=1 & [M:ACLA8]WVALEUR(K)=""
   [M:ACLA8]WVALEUR(K)= [M:ACLA6]FLDGRP(nolign-1)+string$([M:ACLA6]FLDGRP(nolign-1)<>"",".")+[M:ACLA6]FLDCUR
#    [M:ACLA6]VALCLE(0)=[M:ACLA8]WVALEUR(K)
#    Affzo [M:ACLA6]VALCLE(0)
  Endif
  #
  If [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2
   Gosub L_LOAD_MEDIA From SUBACLA2
  Endif
  [M:ACLA6]FLDCUR=""
  [M:ACLA6]CODTYPCUR=""
 Endif
Next
[M:ACLA6]NBRFLD = nolign
nolign=SAVNOLIGN
Return


#------------------------------#
$SAVE_ACLAF
Local Integer I,J,K,L,M,N
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Local Integer OKLIS
For nolign=1 To [M:ACLA6]NBRFLD
 Raz [ACLAF]
 [F:ACLAF]CODCLA  = [M:ACLA0]CODCLA
 [F:ACLAF]NUMLIG = nolign
 [F:ACLAF]        = [M:ACLA6]
# Write [ACLAF]
# If fstat
#  GOK = 0 : Call FSTA("ACLAF") From GLOCK : Break
# Endif
 J=0
 [L]OKLIS=0
 Read [ATY]CODTYP=[F:ACLAF]CODTYP
 If !fstat & [F:ATY]TYPSELSYR=2
  If !fstat & [F:ATY]TYPPROSYR<>""
   Read [ATYP]ATYP0=[F:ATY]TYPPROSYR
   If !fstat & [F:ATYP]LISFLG=2
    [L]OKLIS=1
   Endif
  Endif
  ####
  Delete [ACLFP] Where CODCLA=[F:ACLAF]CODCLA & FLDCLA=[F:ACLAF]FLDCLA
  ####
  For I=0 To [M:ACLA8]WNBRPARALL-1
   If [M:ACLA8]WTYPPAR(I)=1 & [F:ACLAF]FLDCLA = [M:ACLA8]WFLDCLA(I) & [M:ACLA8]WISKEY(I)<>2
    J+=1
    Raz [F:ACLFP]
    [F:ACLFP]CODCLA = [M:ACLA0]CODCLA
    [F:ACLFP]FLDCLA = [F:ACLAF]FLDCLA
    [F:ACLFP]NUMPAR = J
    [F:ACLFP]CODPAR = [M:ACLA8]WCODPAR(I)
    [F:ACLFP]TYPKEY = [M:ACLA8]WTYPKEY(I)
    [F:ACLFP]VALEUR = [M:ACLA8]WVALEUR(I)
    [F:ACLFP]TYPPAR = [M:ACLA8]WTYPPAR(I)
    [F:ACLFP]TYPINT = [M:ACLA8]WTYPINTPAR(I)
    [F:ACLFP]ADRVAL = [M:ACLA8]WADRVAL(I)
    Write [ACLFP]
    If fstat
     GOK = 0 : Call FSTA("ACLFP") From GLOCK : Break 2
    Endif
   Elsif [L]OKLIS & [M:ACLA8]WTYPPAR(I)=2 & [F:ACLAF]FLDCLA = [M:ACLA8]WFLDCLA(I) & [M:ACLA8]WCODTYP(I)=[F:ACLAF]CODTYP
    Raz [F:ACLFP]
    [F:ACLFP]CODCLA = [M:ACLA0]CODCLA
    [F:ACLFP]FLDCLA = [F:ACLAF]FLDCLA
    [F:ACLFP]NUMPAR = [M:ACLA8]WNUMPAR(I)
    [F:ACLFP]CODPAR = [M:ACLA8]WCODPAR(I)
    [F:ACLFP]TYPKEY = [M:ACLA8]WTYPKEY(I)
    [F:ACLFP]VALEUR = [M:ACLA8]WVALEUR(I)
    [F:ACLFP]TYPPAR = [M:ACLA8]WTYPPAR(I)
    [F:ACLFP]TYPINT = [M:ACLA8]WTYPINTPAR(I)
    Write [ACLFP]
    If fstat
     GOK = 0 : Call FSTA("ACLFP") From GLOCK : Break 2
    Endif
   Endif
  Next
  For I=0 To [M:ACLA8]WNBRPARALL-1
   If [M:ACLA8]WTYPPAR(I)=1 & [F:ACLAF]FLDCLA = [M:ACLA8]WFLDCLA(I) & [M:ACLA8]WISKEY(I)=2
    Raz N
    For M=0 To [M:ACLA8]WNBRPARALL-1
     If [F:ACLAF]FLDCLA = [M:ACLA8]WFLDCLA(M) & [M:ACLA8]WTYPKEY(M)=2 &  [M:ACLA8]WCODPAR(I) = [M:ACLA8]WCODPAR(M)
      N = M
     Endif
    Next
    If N>0
     J+=1
     Raz [F:ACLFP]
     [F:ACLFP]CODCLA = [M:ACLA0]CODCLA
     [F:ACLFP]FLDCLA = [F:ACLAF]FLDCLA
     [F:ACLFP]NUMPAR = J
     [F:ACLFP]CODPAR = [M:ACLA8]WCODPAR(N)
     [F:ACLFP]TYPKEY = 1
     [F:ACLFP]VALEUR = [M:ACLA8]WVALEUR(N)
     [F:ACLFP]TYPPAR = [M:ACLA8]WTYPPAR(N)
     [F:ACLFP]TYPINT = [M:ACLA8]WTYPINTPAR(N)
     [F:ACLFP]ADRVAL = [M:ACLA8]WADRVAL(N)
     Write [ACLFP]
     If fstat
      GOK = 0 : Call FSTA("ACLFP") From GLOCK : Break 2
     Endif
    Endif
   Endif
  Next
 Endif
Next nolign
nolign=SAVNOLIGN
Return

