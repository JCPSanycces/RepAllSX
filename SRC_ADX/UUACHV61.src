#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# UUACHV61     Utilitaire de migration du module achats     Module ACHAT #
#              d'une version 6.0 vers  une version 6.1                   #
##########################################################################


Call MAJ_UUACHV61
End


Subprog MAJ_UUACHV61
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UUACHV61 - Migration achats Béryl 6.0 vers 6.1") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UUACHV61 : Utilitaire de migration achats 6.0 vers 6.1") From LECFIC
  Call EXE_UUACHV61(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UUACHV61(DOSSIER)
Value Char    DOSSIER
#----- Test dossier mère et module achat -----#
If DOSSIER=GDOSX3  End : Endif
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2  End : Endif
#-----
Call ECR_TIME("UUACHV61 : Start folder's process"-DOSSIER) From DOSSUB
Call ECR_TRACE("---------- Update purchasing module release 6.0 to 6.1 ----------",0) From GESECRAN
#----- Chargement globale GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =DOSSIER+".ADOVAL" [ADW] 
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]
#----- Variable locales communes -----#
Local Integer  WNBR, WNBRCOR
#----- Début du traitement -----#
Gosub TRT_PSH : # Traitement des demandes d'achat
Call ECR_TRACE("-----",0) From GESECRAN
Gosub TRT_POH : # Traitement des commandes d'achat
Call ECR_TRACE("-----",0) From GESECRAN
Gosub TRT_PNH : # Traitement des retours fournisseurs
#----- Fin du traitement -----#
$FIN_UUACHV61
Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Call ECR_TIME("UUACHV61 : End folder's process"-DOSSIER) From DOSSUB
End


#----------------------------------------------------------------#
#   Alimentation des nouveaux champs dans les demandes d'achat   #
# -------------------------------------------------------------- #
# Table PREQUISD - Lignes demande d'achat                        #
#   VACBPR       Régime de taxe                                  #
#   VACTYP       Type de régime                                  #
#   VAT1         Code taxe 1                                     #
#   VAT2         Code taxe 2                                     #
#   VAT3         Code taxe 3                                     #
#   CMMPRPTAX    Type de pré-engagement (HT/HTND/TTC)            #
#   CLCAMT1-2    Base 1-2 calcul taxe                            #
#   BASTAXLIN1   Base taxe ligne                                 #
#   AMTTAXLIN1-3 Montant taxe 1-3                                #
#   DEDTAXLIN1-3 Montant taxe 1-3 déductible                     #
#   LINATIAMT    Montant TTC ligne                               #
#----------------------------------------------------------------#
$TRT_PSH
#----- Test existence des fichiers -----#
If filinfo(filpath("FIL","PREQUIS" ,"fde",DOSSIER),0)<0  Return : Endif
If filinfo(filpath("FIL","PREQUISD","fde",DOSSIER),0)<0  Return : Endif
#-----
Call ECR_TIME("UUACHV61 : Purchase Request Process : Update PREQUISD") From DOSSUB
#----- Ouverture des fichiers -----#
Local File =DOSSIER+".PREQUIS"    [PSH]
Local File =DOSSIER+".PREQUISD"   [PSD]
Local File =DOSSIER+".BPARTNER"   [BPR]
Local File =DOSSIER+".BPSUPPLIER" [BPS]
Local File =DOSSIER+".BPCUSTOMER" [BPC]
Local File =DOSSIER+".BPADDRESS"  [BPA]
Local File =DOSSIER+".ITMMASTER"  [ITM]
Local File =DOSSIER+".PFOOTINV"   [PFI]
Local File =DOSSIER+".COMPANY"    [CPY]
Local File =DOSSIER+".FACILITY"   [FCY]
Local File =DOSSIER+".AGRPCPY"    [AGC]
Local File =DOSSIER+".TABVAC"     [TVC]
Local File =DOSSIER+".TABVAT"     [TVT]
Local File =DOSSIER+".TABRATVAT"  [TRA]
Local File =DOSSIER+".TABCUR"     [TCU]
Local File =DOSSIER+".TABCHANGE"  [TCH]
Local File =DOSSIER+".ATABDIV"    [ADI]
Local File =DOSSIER+".ACTIV"      [ACV]
Local File =DOSSIER+".TAXLINK"    [TLK]
If func AFNC.ACTIV("MUL")
  Local File =DOSSIER+".BPEXCEPT"   [BPE]
Endif
#----- Variables locales -----#
Local Integer  COMPTEUR, STOP
Local Char     CLE1(GLONPSH), CRITERE(90), WPARAM(10)
Local Integer  I
#-----
Local Char     WELT_VAC(GLONADI+GLONADI+1)
Local Char     WTAB_VAC(GLONADI+GLONADI+1)(100)
Local Integer  WTAB_NBR
#----- Variables locales pour calcul TVA -----#
Local Integer  STAT, TYPREG
Local Decimal  BASE, MONTANT(1..3), MONTDED(1..3)
Local Char     TAXE(GLONVAT)(1..3)
Local Decimal  WRND
#-----
Raz CLE1, STOP, WNBR, WNBRCOR
$BOUCLE_PSH
If  STOP=1
  CRITERE='PSHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR, GSOCIETE
Trbegin [PSD]
  For [PSH] PSH0 Where evalue(CRITERE)
    #-----
    If GSOCIETE<>[F:PSH]CPY
      Call GETDEV(DOSSIER,[F:PSH]PSHFCY) From TRTX3CPT
    Endif
    #-----
    For [PSD] PSD0 Where PSHNUM=[F:PSH]PSHNUM
      If [F:PSD]VACBPR="" | [F:PSD]VAT(0)="" | [F:PSD]CMMPRPTAX=0
        Readlock [PSD] Curr
        If fstat
          Call ECR_TRACE("File PREQUISD"-[F:PSH]PSHNUM+", Error ="-num$(fstat),1) From GESECRAN
        Else
          #----- Alimentation du régime de taxe -----#
          If [F:PSD]VACBPR=""
            If [F:PSD]BPSNUM<>""
              If [F:BPS]BPSNUM<>[F:PSD]BPSNUM
                Read [BPS] BPS0=[F:PSD]BPSNUM : If fstat  Raz [F:BPS] : Endif
              Endif
              [F:PSD]CHGTYP=[F:BPS]CHGTYP
              [F:PSD]VACBPR=[F:BPS]VACBPR
              Call INIT_REGIME([F:PSD]BPSNUM,[F:PSH]PSHFCY,"F",[F:PSD]VACBPR) From CPTSUB
            Else
              Call PARAM([F:PSH]PSHFCY,"PURVACBPR",WPARAM) From ADOVAL
              If WPARAM<>""
                [F:PSD]VACBPR=WPARAM
              Else
                Filter [ADI] Where NUMTAB=1 & DEFVAL=2
                Read [ADI] CODE First
                Filter [ADI]
                If !fstat
                  [F:PSD]VACBPR=[F:ADI]CODE
                Else
                  Filter [ADI] Where NUMTAB=1 & LEG=GCURLEG & N1=1
                  Read [ADI] CODE First
                  Filter [ADI]
                  If !fstat
                    [F:PSD]VACBPR=[F:ADI]CODE
                  Else
                    Filter [ADI] Where NUMTAB=1 & LEG="" & N1=1
                    Read [ADI] CODE First
                    Filter [ADI]
                    If !fstat
                      [F:PSD]VACBPR=[F:ADI]CODE
                    Endif
                  Endif
                Endif
              Endif
            Endif
            If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PSD]VACBPR
              Read [ADI] CODE=1;[F:PSD]VACBPR : If fstat Raz [F:ADI] : Endif
            Endif
            [F:PSD]VACTYP=[F:ADI]N1
          Endif
          #----- Alimentation des codes taxe et calcul bases et taxes de la ligne de DA -----#
          If [F:PSD]VAT(0)=""
            Call ALIVATCOD(2,[F:PSD]BPSNUM,[F:PSD]ITMREF,"PSD",0) From TRTX3
            Call MAJ_CALTAX_LIG("PSD",0) From TRTACHDIV1
            If [F:PSD]VAT(0)=""
              If [F:ITM]ITMREF<>[F:PSD]ITMREF
                Read [ITM] ITM0=[F:PSD]ITMREF : If fstat  Raz [F:ITM] : Endif
              Endif
              WELT_VAC=[F:PSD]VACBPR+"-"+[F:ITM]VACITM(0)
              If WTAB_NBR=0 | !find(WELT_VAC,WTAB_VAC(0..WTAB_NBR-1))
                Call ECR_TRACE(WELT_VAC-"Tax rule-level without tax determination !",1) From GESECRAN
                If WTAB_NBR<100
                  WTAB_VAC(WTAB_NBR)=WELT_VAC
                  WTAB_NBR+=1
                Endif
              Endif
            Endif
          Endif
          #-----
          If [F:PSD]CMMPRPTAX=0  [F:PSD]CMMPRPTAX=1 : Endif
          #-----
          COMPTEUR+=1 : WNBRCOR+=1
          Rewrite [PSD]
          If fstat
            Call ECR_TRACE("File PREQUISD"-[F:PSD]PSHNUM+", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Endif
      Endif
      WNBR+=1
    Next
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PSH]PSHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PSH : Endif
If func AFNC.ACTIV("MUL")  Close Local File [BPE] : Endif
Close Local File [PSH], [PSD], [BPR], [BPS], [BPC], [BPA], [ITM], [PFI], [CPY],
&                [FCY], [AGC], [TVC], [TVT], [TRA], [TCU], [TCH], [ADI], [ACV], [TLK]
Call ECR_TIME("UUACHV61 : Purchase Request Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return


#---------------------------------------------------------------#
#  Alimentation des nouveaux champs dans les commandes d'achat  #
# ------------------------------------------------------------- #
# Table PORDERQ  - Lignes commandes d'achat                     #
#   CMMTAX       Type d'engagement (HT/HTND/TTC)                #
# Table UPORDERQ - Historique lignes commandes d'achat          #
#   CMMTAX       Type d'engagement (HT/HTND/TTC)                #
#---------------------------------------------------------------#
$TRT_POH
#----- Test existence des fichiers -----#
If filinfo(filpath("FIL","PORDERQ" ,"fde",DOSSIER),0)<0  Return : Endif
#-----
Call ECR_TIME("UUACHV61 : Purchase Order Process : Update PORDERQ") From DOSSUB
#-----
Local File =DOSSIER+".PORDERQ"    [POQ]
WNBR=rowcount([POQ])
Trbegin [POQ]
Update [POQ] Where CMMTAX=0 With CMMTAX=1
If fstat
  Call ECR_TRACE("File PORDERQ, Error ="-num$(fstat),1) From GESECRAN
  WNBRCOR=0
  Rollback
Else
  WNBRCOR=adxuprec
  Commit
Endif
Close Local File [POQ]
Call ECR_TIME("UUACHV61 : Purchase Order Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
#-----
Call ECR_TRACE("-----",0) From GESECRAN
#-----
Call ECR_TIME("UUACHV61 : History Purchase Order Process : Update UPORDERQ") From DOSSUB
Local File =DOSSIER+".UPORDERQ"   [UOQ]
WNBR=rowcount([UOQ])
Trbegin [UOQ]
Update [UOQ] Where CMMTAX=0 With CMMTAX=1
If fstat
  Call ECR_TRACE("File UPORDERQ, Error ="-num$(fstat),1) From GESECRAN
  WNBRCOR=0
  Rollback
Else
  WNBRCOR=adxuprec
  Commit
Endif
Close Local File [UOQ]
Call ECR_TIME("UUACHV61 : History Purchase Order Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return


#----------------------------------------------------------------#
# Alimentation des nouveaux champs dans les retours fournisseurs #
# -------------------------------------------------------------- #
# Table PRETURND - Lignes de retour                              #
#   BASTAXLIN1   Base taxe ligne                                 #
#   AMTTAXLIN1-3 Montant taxe 1-3                                #
#   DEDTAXLIN1-3 Montant taxe 1-3 déductible                     #
#----------------------------------------------------------------#
$TRT_PNH
#----- Test existence des fichiers -----#
If filinfo(filpath("FIL","PRETURN" ,"fde",DOSSIER),0)<0  Return : Endif
If filinfo(filpath("FIL","PRETURND","fde",DOSSIER),0)<0  Return : Endif
#-----
Call ECR_TIME("UUACHV61 : Purchase Return Process : Update PRETURND") From DOSSUB
#----- Ouverture des fichiers -----#
Local File =DOSSIER+".PRETURN"    [PNH]
Local File =DOSSIER+".PRETURND"   [PND]
Local File =DOSSIER+".BPARTNER"   [BPR]
Local File =DOSSIER+".BPSUPPLIER" [BPS]
Local File =DOSSIER+".BPCUSTOMER" [BPC]
Local File =DOSSIER+".BPADDRESS"  [BPA]
Local File =DOSSIER+".ITMMASTER"  [ITM]
Local File =DOSSIER+".PFOOTINV"   [PFI]
Local File =DOSSIER+".COMPANY"    [CPY]
Local File =DOSSIER+".FACILITY"   [FCY]
Local File =DOSSIER+".AGRPCPY"    [AGC]
Local File =DOSSIER+".TABVAC"     [TVC]
Local File =DOSSIER+".TABVAT"     [TVT]
Local File =DOSSIER+".TABRATVAT"  [TRA]
Local File =DOSSIER+".TABCUR"     [TCU]
Local File =DOSSIER+".TABCHANGE"  [TCH]
Local File =DOSSIER+".ATABDIV"    [ADI]
Local File =DOSSIER+".ACTIV"      [ACV]
Local File =DOSSIER+".TAXLINK"    [TLK]
If func AFNC.ACTIV("MUL")
  Local File =DOSSIER+".BPEXCEPT"   [BPE]
Endif
#----- Variables locales -----#
Local Integer  COMPTEUR, STOP
Local Char     CLE1(GLONPNH), CRITERE(90), WPARAM(10)
Local Integer  I
#----- Variables locales pour calcul TVA -----#
Local Integer  STAT, TYPREG
Local Decimal  BASE, MONTANT(1..3), MONTDED(1..3)
Local Char     TAXE(GLONVAT)(1..3)
Local Decimal  WRND
#-----
Raz CLE1, STOP, WNBR, WNBRCOR
$BOUCLE_PNH
If  STOP=1
  CRITERE='PNHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR, GSOCIETE
Trbegin [PND]
  For [PNH] PNH0 Where evalue(CRITERE)
    #-----
    If GSOCIETE<>[F:PNH]CPY
      Call GETDEV(DOSSIER,[F:PNH]PNHFCY) From TRTX3CPT
    Endif
    #-----
    For [PND] PND0 Where PNHNUM=[F:PNH]PNHNUM
      If [F:PND]BASTAXLIN1=0 & [F:PND]AMTTAXLIN1=0 & [F:PND]AMTTAXLIN2=0 & [F:PND]AMTTAXLIN3=0 &
&       ([F:PND]LINAMT<>0 | [F:PND]CLCAMT1<>0 | [F:PND]CLCAMT2<>0)
        Readlock [PND] Curr
        If fstat
          Call ECR_TRACE("File PRETURND"-[F:PNH]PNHNUM+", Error ="-num$(fstat),1) From GESECRAN
        Else
          #----- Calcul bases et taxes de la ligne de retour -----#
          Call MAJ_CALTAX_LIG("PND",0) From TRTACHDIV1
          #-----
          COMPTEUR+=1 : WNBRCOR+=1
          Rewrite [PND]
          If fstat
            Call ECR_TRACE("File PRETURND"-[F:PND]PNHNUM+", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Endif
      Endif
      WNBR+=1
    Next
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PNH]PNHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PNH : Endif
If func AFNC.ACTIV("MUL")  Close Local File [BPE] : Endif
Close Local File [PNH], [PND], [BPR], [BPS], [BPC], [BPA], [ITM], [PFI], [CPY],
&                [FCY], [AGC], [TVC], [TVT], [TRA], [TCU], [TCH], [ADI], [ACV], [TLK]
Call ECR_TIME("UUACHV61 : Purchase Return Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return


####################
# Appel par un EXE #
####################
Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_UUACHV61(APPLI)
End

####################
# Appel par validation dosssier #
####################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI
If [F:ADS]MODULE(5)<>2  End : Endif
Call EXE_UUACHV61(APPLI)
End

