#<AdxTL>@(#)3.0.0.0 $Revision$
####################################################################################
# Program Name: NATRLBAL
# Description : Trial balance w/dimensions option
# Author      : NA Development
# Date        : 3 Dec 2012
##################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End
####################################################################################
$ACTION

Case ACTION
 When "CONT1"
  If [M]PARCOD(nolign-1)="export"
     Local Integer P3
     P3=nolign
     If VALINT1(nolign-1)="2"
      Raz [M]VALEUR1 (P3), [M]VALEUR1 (P3+1) # To clear dim or dim type when all dimensions selected
      Call CHARGE([M]VALEUR1(P3+1),[M]PARTYP(P3+1),[M]NOLIB(P3+1),[M]LONG(P3+1),[M]VALINT1(P3+1)) From FMTVAR
      Call CHARGE([M]VALEUR1(P3),[M]PARTYP(P3),[M]NOLIB(P3),[M]LONG(P3),[M]VALINT1(P3)) From FMTVAR
      Grizo [M]VALEUR1 (P3)
      Grizo [M]VALEUR1 (P3+1)
     Else
      Actzo [M]VALEUR1 (P3)
      Actzo [M]VALEUR1 (P3+1) # To set Dimension type and dimension fields
      Call CHARGE([M]VALEUR1(P3+1),[M]PARTYP(P3+1),[M]NOLIB(P3+1),[M]LONG(P3+1),[M]VALINT1(P3+1)) From FMTVAR
      Call CHARGE([M]VALEUR1(P3),[M]PARTYP(P3),[M]NOLIB(P3),[M]LONG(P3),[M]VALINT1(P3)) From FMTVAR
      Affzo[M]1-99
      zonsui = "[M]VALINT1(nolign)"
     Endif
  Endif
  When Default :
 Endcase
 Return
#####################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

[L]CRITERE = "1=1"
[L]CRITEREA = "1=1"
[L]CRITEREB = "1=1"
[L]CRITERE1 = "1=1"

For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   When "export"
     If [L]VALEUR="1"
       WEXPORT=1
     Endif
    When "devise"       # 90393.n
      XDEVISE = [L]VALEUR
#   When  "devorg"      # 90393.so
#    [L]CRITERE -= "& [BAL]CUR='"+[L]VALEUR+"'"
#    [L]CRITEREA -= "& [BAL]CUR='"+[L]VALEUR+"'"
#    [L]CRITEREB -= "& [BLA]CUR='"+[L]VALEUR+"'"  # 90393.eo
   When "cours"         # 90393.sn
 #    If val([L]VALEUR) = 1
 #       [L]CRITERE -= "& find('"+XDEVISE+"',[CPY]ACCCUR,[BAL]CUR)"
 #       [L]CRITEREA -= "& find('"+XDEVISE+"',[CPY]ACCCUR,[BAL]CUR)"
 #       [L]CRITEREB -= "& find('"+XDEVISE+"',[CPY]ACCCUR,[BLA]CUR)"
 #    Endif
      XCOURS=val([L]VALEUR)  # 90393.en
   When "company"
#    [L]CRITERE -= "& [BAL]CPY='"+[L]VALEUR+"'"  # 102227.o
#    [L]CRITEREA -= "& [BAL]CPY='"+[L]VALEUR+"'" # 102227.o
#    [L]CRITEREB -= "& [BLA]CPY='"+[L]VALEUR+"'" # 102227.o
    COMPANY = [L]VALEUR # 102227.n
    Gosub GRPSOC        # 102227.n
   When "fisyear"
    [L]CRITERE -= "& [BAL]FIY="+[L]VALEUR
    [L]CRITEREA -= "& [BAL]FIY="+[L]VALEUR
    [L]CRITEREB -= "& [BLA]FIY="+[L]VALEUR
   When "perdeb"  # 90393.n
    PERDEB = val([L]VALEUR)
   When "perfin"  # 90393.n
    PERFIN = val([L]VALEUR)
   When "ledger"
    [L]CRITERE -= "& [BAL]LEDTYP="+[L]VALEUR
    [L]CRITEREA -= "& [BAL]LEDTYP="+[L]VALEUR
    [L]CRITEREB -= "& [BLA]LEDTYP="+[L]VALEUR
   When "dimtypdeb"
     If [L]VALEUR<>""
        VALSTR = vireblc([L]VALEUR,4)
     Endif
   When "accdeb"
    [L]CRITERE -= "& [BLA]ACC>='"+[L]VALEUR+"'"
    [L]CRITEREA -=  "& [BAL]ACC>='"+[L]VALEUR+"'"
    [L]CRITEREB -= "& [BLA]ACC>='"+[L]VALEUR+"'"
   When "accfin"
    [L]CRITERE -= "& [BLA]ACC<='"+[L]VALEUR+"'"
    [L]CRITEREA -= "& [BAL]ACC<='"+[L]VALEUR+"'"
    [L]CRITEREB -= "& [BLA]ACC<='"+[L]VALEUR+"'"
   When "dimval"
    If [L]VALEUR<>""
      VALDIM=1
      [L]DIMVAL=[L]VALEUR
    Endif
   When "numedt"
    [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "usr"
    [L]PARAMETRE(I) = "usr="+GUSER
    [L]USR=GUSER
   When "etat"
    [L]PARAMETRE(I) = "etat="+[L]ETAT
 Endcase
 Endif
Next

[L]CRITERE -= "& [BAL]FCY='' & [BAL]BPR=''"
[L]CRITEREA -= "& [BAL]FCY='' & [BAL]BPR=''"
[L]CRITEREB -= "& [BLA]FCY='' & [BLA]BPR=''"

If WEXPORT | [L]DIMVAL <> "" | VALSTR <> ""
  #116098.sn
  WDETAILDIM = 1
#  [L]CRITERE1 -= "& ([BLA]CCE1='"+[L]DIMVAL+"' | [BLA]CCE2='"+[L]DIMVAL+"' | [BLA]CCE3='"+[L]DIMVAL+ "' | [BLA]CCE4='"+[L]DIMVAL+"' | [BLA]CCE5='"+[L]DIMVAL+"' | [BLA]CCE6='"+[L]DIMVAL+
#& "' | [BLA]CCE7='"+[L]DIMVAL+"' | [BLA]CCE8='"+[L]DIMVAL+"' | [BLA]CCE9='"+[L]DIMVAL+"')"
  #116098.en
Else
  WDETAILDIM = 0 #116098.n
  [L]CRITERE -= "& ([BLA]CCE1='"+[L]DIMVAL+"' | [BLA]CCE2='"+[L]DIMVAL+"' | [BLA]CCE3='"+[L]DIMVAL+"')"
  [L]CRITEREB -= "& ([BLA]CCE1='"+[L]DIMVAL+"' | [BLA]CCE2='"+[L]DIMVAL+"' | [BLA]CCE3='"+[L]DIMVAL+"')"
Endif

# 102227.sn   For site authorizations

# Autorisations

Read [CPY]CPY0 = COMPANY
If GUSRFCY(1)<>"\"
 OKSIT = 0
 If GROUPE=0
  For [FCY]FCY1 Where LEGCPY=COMPANY
   If find([F:FCY]FCY,GUSRFCY(1..GNBAUZ))
    OKSIT = 1 : Break
   Endif
  Next
 Else
  For [FGR] Where CPY=COMPANY
   If find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    OKSIT = 1 : Break
   Endif
  Next
 Endif
 If !OKSIT
  GMESSAGE = mess(26,135,1) : # Vous n'avez pas les droits...
  Goto ERREUR
 Endif
Endif


If COMPANY<>"" # Find ledger for company
    K = find("ledger",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
     REFERENTIEL = val([M:RPT]VALINT1(K-1)) ## Ledger
     WLEDGER = val([M:RPT]VALINT1(K-1)) ## Ledger Type
     Read [GCM]GCM0 = [F:CPY]ACM
     Read [LED]LED0 = [F:GCM]LED(REFERENTIEL-1)
Endif

If [F:CPY]CPYLEGFLG<>2 # site/company grouping

Filter [FGR] Where CPY=COMPANY
Read [FGR] Last ## Last from first
If !fstat
  Read [FCY2]FCY0=[FGR]FCY
  If !fstat
    Filter [FIY] Where CPY=[FCY2]LEGCPY & LEDTYP=WLEDGER & FIYNUM=val([M:RPT]VALINT1(K))   # & [F:FIY]FIYEND>DATDEB & [F:FIY]FIYSTR<=DATDEB
    Read [FIY]FIY0 First
    If !fstat
       DATDEB = format$("D:YYYYMMDD",[F:FIY]FIYSTR)
       DATFIN = format$("D:YYYYMMDD",[F:FIY]FIYEND)
    Endif
    Filter [FIY]
  Endif
Endif
Filter [FGR]

  Raz DDEB,EDEB,DFIN,EFIN
  For [FGR]FGR0 Where CPY=COMPANY
  Read [FCY]FCY0 = [F:FGR]FCY
  If EDEB=0
   Call GETPERSOC([F:FCY]LEGCPY,REFERENTIEL,DATDEB,EXE,PER) From CPTSUB
   If EXE<>0 & PER<>0
    DDEB = [F:PER]PERSTR
    EDEB = [F:PER]FIYNUM
   Endif
  Endif
  If EFIN=0
   Call GETPERSOC([F:FCY]LEGCPY,REFERENTIEL,DATFIN,EXE,PER) From CPTSUB
   If EXE<>0 & PER<>0
    DFIN = [F:PER]PEREND
    EFIN = [F:PER]FIYNUM
   Endif
  Endif
  #If EDEB<>0 & EFIN<>0 : Break : Endif
  #Next
  If EDEB=0 or EFIN=0
    Call ECR_TRACE(COMPANY-":"-mess(183,107,1),1) From GESECRAN : # Periods incompatible between companies
    Goto ERREUR ###: Return #GOK = 0 : Return
  Endif
  Next # from above
Endif

# 102227.en

Lock [TBL]
   Delete[TBL] Where [TBL]NUMREQ=[L]NUMREQ | CREDAT<date$-7 | ([TBL]CREUSR=GUSER & [TBL]RPTCOD = "NA-TRLBAL")
Unlock [TBL]

# Write the TBL Records
Gosub CACCE_LOOP

End
####################################################################################
$OUVRE

If !clalev([F:TBL])  : Local File TMPBLA      [TBL]  : Endif
If !clalev([F:CCE])  : Local File CACCE       [CCE]  : Endif
If !clalev([F:BLA])  : Local File BALANA      [BLA]  : Endif
If !clalev([F:BAL])  : Local File BALANCE     [BAL]  : Endif
If !clalev([F:CPY])  : Local File COMPANY     [CPY]  : Endif
If !clalev([F:FGR])  : Local File FACGROUP    [FGR]  : Endif # 102227.n
If !clalev([F:PER])  : Local File PERIOD      [PER]  : Endif # 102227.n
If !clalev([F:AGF])  : Local File AGRPFCY     [AGF]  : Endif # 102227.n
If !clalev([F:FCY])  : Local File FACILITY    [FCY]  : Endif # 102227.n
If !clalev([F:FCY2]) : Local File FACILITY    [FCY2] : Endif # 102227.n
If !clalev([F:LED])  : Local File GLED        [LED]  : Endif # 102227.n
If !clalev([F:GCM])  : Local File GACM        [GCM]  : Endif # 102227.n
If !clalev([F:FIY])  : Local File FISCALYEAR  [FIY]  : Endif # 102227.n
If !clalev([F:FIY2]) : Local File FISCALYEAR  [FIY2] : Endif # 102227.n
If !clalev([F:GAC])  : Local File GACCOUNT    [GAC]  : Endif # 117392.n

Local Char    LTYP(3)

Return
####################################################################################
$DECLARE

Local Char    CRITERE(255),CRITEREA(255),CRITEREB(255),CRITERE1(255),PARAM(30),VALEUR(30),ETAT(15),USR(15)
Local Char    VALSTR, DIMVAL
Local Date    DTEDEB,DTEFIN
Local Date    DDEB,DFIN,DATDEB,DATFIN  # 102227.n
Local Integer EDEB,EFIN,REFERENTIEL, NODATE  # 102227.n
Local Decimal EXE,PER  # 102227.n
Local Integer NUMREQ,RFLAG,WNUMLIG,WEXPORT,VALDIM,XBLA,WBLA,PERDEB,PERFIN,WACCNUM, WNOCCE, WDETAILDIM # 91808.n
Local Decimal XCOURS,WAMT1,WAMT2,WAMT3,XBAL # 91808.n
Local Decimal BLADRAMT,BLACRAMT,BLAOAMT # 91808.n
# 102227.sn authorizations
Local Integer    MAXSOC : MAXSOC = 50     # 50 sociétés par regroupement
Local Integer    MAXSIT : MAXSIT = 50     # 50 sites par société
Local Integer OKSIT, GROUPE, GRPSOC, NBSOC
Local Decimal WDRAMT, WCRAMT,BLAOAMT,WOAMT # 102227.n
Local Char    SOC(GLONCPY)(1..MAXSOC), COMPANY(8), TYP_ETAT(GLONARP)
# 102227.en

Return
####################################################################################
# 102227.sn
$ERREUR
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK = 0
End
# 102227.en
###################################################################################
# 102227.sn
$GRPSOC

# Vérification des paramètres

GROUPE = 0
GRPSOC = 0
Read [CPY]CPY0    = COMPANY
If [F:CPY]CPYLEGFLG=2
 NBSOC  = 1
 SOC(1) = COMPANY
 [L]CRITERE -= "& [BAL]CPY='"+[L]VALEUR+"'"
 [L]CRITEREA -= "& [BAL]CPY='"+[L]VALEUR+"'"
 [L]CRITEREB -= "& [BLA]CPY='"+[L]VALEUR+"'"
Else
 GROUPE = 1
 NBSOC  = 0
 Read [AGF]AGF0 = COMPANY
 If [F:AGF]FLGCPY=2
  GRPSOC = 1
 Endif
 For [FGR]FGR0 Where CPY=COMPANY
  Read [FCY]FCY0 = [F:FGR]FCY
  If !find([F:FCY]LEGCPY,SOC(1..NBSOC))
   If NBSOC>=MAXSOC
    GMESSAGE = mess(107,104,1)-"("+num$(MAXSOC)+")" : # Trop de sociétés
    GOK = 0 : Break
   Else
    NBSOC += 1
    SOC(NBSOC) = [F:FCY]LEGCPY
    If NBSOC =1
      [L]CRITERE  -= "& ([BAL]CPY='"+[F:FCY]LEGCPY +"'"
      [L]CRITEREA -= "& ([BAL]CPY='"+[F:FCY]LEGCPY +"'"
      [L]CRITEREB -= "& ([BLA]CPY='"+[F:FCY]LEGCPY +"'"
    Else # NBSOC > 1
      [L]CRITERE  -= "| [BAL]CPY='"+[F:FCY]LEGCPY +"'"
      [L]CRITEREA -= "| [BAL]CPY='"+[F:FCY]LEGCPY +"'"
      [L]CRITEREB -= "| [BLA]CPY='"+[F:FCY]LEGCPY +"'"
    Endif
   Endif
  Endif
 Next
 If NBSOC >0 :  [L]CRITERE  -= ")" :  [L]CRITEREA -= ")" :  [L]CRITEREB -= ")" : Else
   [L]CRITERE -= "& [BAL]CPY='"+[L]VALEUR+"'"
   [L]CRITEREA -= "& [BAL]CPY='"+[L]VALEUR+"'"
   [L]CRITEREB -= "& [BLA]CPY='"+[L]VALEUR+"'"
 Endif
 If !GOK : Goto ERREUR : Endif
Endif


Return
# 102227.en
#####################################################################################
$CACCE_LOOP

Filter [BAL] Where evalue([L]CRITEREA)

If WEXPORT | [L]DIMVAL <> "" | VALSTR <> "" : Goto EXPORT_FILE : Return : Endif # All dimensions or direct call for a dim or dim type

For [BAL]
 #If [BAL]ACC<>XACC : Raz WBAL : Endif # 90393.n
 Filter [BLA] Where evalue([L]CRITEREB) & evalue([L]CRITERE1) &
& [BAL]LEDTYP=[F:BLA]LEDTYP & [BAL]CPY=[F:BLA]CPY & [BAL]FCY=[F:BLA]FCY & [BAL]ACC=[F:BLA]ACC &
& [BAL]BPR=[F:BLA]BPR & [BAL]CUR=[F:BLA]CUR & [BAL]FIY=[F:BLA]FIY Order By [BLA]ACCNUM

 Raz XBLA

 For [BLA]
  For I=0 To 2
   If [F:BLA]DIE(I)<>"" & evalue("[F:BLA]CCE"+num$(I+1))<>"" & (VALSTR="" | VALSTR=[F:BLA]DIE(I))
    Read [CCE]CCE0=[F:BLA]DIE(I); evalue("[F:BLA]CCE"+num$(I+1))
    If !fstat
     Gosub WRITE_RECORD
     XBLA=1  # BALANA record found
    Endif
   Endif
  Next
 Next # BLA

 Filter [BLA]
 If !XBLA and VALSTR = "" and VALDIM=0
  Gosub WRITE_RECORD  # No dimension Balance record
  #WBAL=1  # 90393.n
  #XACC=[BAL]ACC # 90393.n
 Endif

 Gosub DRCR_CALC # 90393.n

Next # BAL

Return
####################################################################################
$EXPORT_FILE

#116098.n
#EXPORT_FILE will execute for the following scenarios (Display all dimension = Yes (WEXPORT=1)) OR (Display all dimension = No & Dimension Type = Non-blanK ([L]DIMVAL<>""|VALSTR<>""))
# In both cases, the data resultset in table TMPBLA will be EXACTLY THE SAME and the report handles the variance in subtotals.

For [BAL]
 Filter [BLA] Where evalue([L]CRITEREB) & evalue([L]CRITERE1) &
& [BAL]LEDTYP=[F:BLA]LEDTYP & [BAL]CPY=[F:BLA]CPY & [BAL]FCY=[F:BLA]FCY & [BAL]ACC=[F:BLA]ACC &
& [BAL]BPR=[F:BLA]BPR & [BAL]CUR=[F:BLA]CUR & [BAL]FIY=[F:BLA]FIY Order By [BLA]ACCNUM

 Raz XBLA

 For [BLA]
  For I=0 To dim([F:BLA]DIE)-1
    #If [F:BLA]DIE(I)<>"" & evalue("[F:BLA]CCE"+num$(I+1))<>"" & (VALSTR="" | VALSTR=[F:BLA]DIE(I)) #116098.o
    If [F:BLA]DIE(I)<>"" & evalue("[F:BLA]CCE"+num$(I+1))<>"" #116098.n
      Read [CCE]CCE0=[F:BLA]DIE(I); evalue("[F:BLA]CCE"+num$(I+1))
      If !fstat
        Gosub WRITE_RECORD
        XBLA=1  # BALANA record found
      Endif
    Endif
  Next

  #91808.sn for BALANA records with No dimensions values
#  If (dim(VALSTR)<=0 | VALSTR="") & [BLA]CCE1='' & [BLA]CCE2='' & [BLA]CCE3='' & [BLA]CCE4='' & [BLA]CCE5=''
#&& [BLA]CCE6='' & [BLA]CCE7='' & [BLA]CCE8='' & [BLA]CCE9='' #116098.o
  If [BLA]CCE1='' & [BLA]CCE2='' & [BLA]CCE3='' & [BLA]CCE4='' & [BLA]CCE5=''
&& [BLA]CCE6='' & [BLA]CCE7='' & [BLA]CCE8='' & [BLA]CCE9='' #116098.n
   WNOCCE=1
   Gosub WRITE_RECORD
   XBLA=1
   Raz WNOCCE
  Endif
  # 91808.en

  Raz [CCE]
  Gosub DRCR_BLACALC # 90393_A.n
 Next # BLA
 Filter [BLA]

 #  Check to see if some BAL value is not coverered by BLA records  91808.sn
 #If WEXPORT and XBLA=1 # 'dimensions only' option and at least 1 BLA record #116098.o
 If WDETAILDIM and XBLA=1 #116098.n
  Local Decimal WCRAMT, WDRAMT, WOAMT
  For I=PERDEB To PERFIN
   WCRAMT+= [BAL]CDTLED(I)
   WDRAMT+= [BAL]DEBLED(I)
  Next
  For I=0 To PERDEB-1
   WOAMT+= ([BAL]DEBLED(I)-[BAL]CDTLED(I)) # opening balance check
  Next
  If WCRAMT <> BLACRAMT | WDRAMT <> BLADRAMT | BLAOAMT <> WOAMT # Orphaned amounts on BAL
   XBAL=1
   Gosub WRITE_RECORD
   Gosub DRCR_CALC
   Raz XBAL
  Endif
 Endif # 91808.en
 Raz BLADRAMT, BLACRAMT, BLAOAMT # 91808.n

 #If !XBLA and VALSTR = "" and VALDIM=0 #116098.o
 If !XBLA #116098.n
  Gosub WRITE_RECORD  # No dimension Balance record
  Gosub DRCR_CALC # 90393_A.n
 Endif
 # Gosub DRCR_CALC # 90393_A.o
Next # BAL

Return
####################################################################################
$WRITE_RECORD

#116098.so
#If !WEXPORT and [L]DIMVAL <> "" # Direct dimension call
#  If [L]DIMVAL <> [CCE]CCE : Return :  Endif
#Elsif !WEXPORT and VALSTR <> "" # Direct Dim Type call
#  If [L]VALSTR <> [CCE]DIE : Return :  Endif
#Endif
#116098.eo

Filter [TBL] Where [TBL]CCEA=[BAL]ACC

#If [L]DIMVAL <> "" | VALSTR <> ""  # Direct calls - always force new record
#If [L]DIMVAL <> "" | VALSTR <> "" | (WEXPORT and [BLA]ACCNUM <> WACCNUM) # Direct calls - always force new record # WEXPORT & ACCNUM # 90393_A.n 91808.o
#If [L]DIMVAL <> "" | VALSTR <> "" | (WEXPORT and ([BLA]ACCNUM <> WACCNUM | XBAL)) # Direct calls - always force new record # WEXPORT & ACCNUM # 90393_A.n 91808.n
If (WDETAILDIM and ([BLA]ACCNUM <> WACCNUM | XBAL)) #116098.n
  Readlock [TBL]ARM0=[L]NUMREQ;GUSER;[L]ETAT;[L]WNUMLIG + 1
Else
  # Readlock [TBL]ARM0(3)=[L]NUMREQ;GUSER;[L]ETAT  # 90393_A.o
  Readlock [TBL]ARM0=[L]NUMREQ;GUSER;[L]ETAT;[L]WNUMLIG # 90393_A.n
Endif

WACCNUM=[BLA]ACCNUM # 90393_A.n
If fstat # New record

GOK = 1
Trbegin [TBL]
  WNUMLIG += 1
  Raz [F:TBL]
  #Read [GAC]GAC0=[BAL]COA;[BAL]ACC                                # Issue 108800  N/A
  #If !fstat : Read [CLS]CLS0=[CPY]LEG;[GAC]CLSCOD  : Endif        # Issue 108800  N/A
  #If !fstat : [F:TBL]CLEN3=[CLS]SNSANA : Endif # Issue 108800  revenue=2 or expense=1 N/A
  # 117392.sn
  If [L]DIMVAL <> "" | VALSTR <> ""
    Read [GAC]GAC0=[BAL]COA;[BAL]ACC
    If !fstat
      [F:TBL]DET8  = [GAC]DES
    Endif
  Endif
  # 117392.en
  [F:TBL]USR     = GUSER
  [F:TBL]RPTCOD  = [L]ETAT
  [F:TBL]NUMREQ  = [L]NUMREQ
  [F:TBL]NUMLIG  = [L]WNUMLIG
  [F:TBL]CCEA = num$([BAL]ACC)
  [F:TBL]DET1  = [BAL]CPY
  [F:TBL]CLEN1 = [BAL]FIY
  [F:TBL]CLEN2 = [BAL]LEDTYP
  [F:TBL]DET5  = [BAL]CUR
  [F:TBL]CUR    = XDEVISE  # Printing currency 90393.n
  #[F:TBL]ACCNUM = [BLA]ACCNUM # 91808.o
  # 91808.sn
  If XBAL | [BLA]ACCNUM=0
    [F:TBL]ACCNUM = [BAL]ACCNUM
  Else
    [F:TBL]ACCNUM = [BLA]ACCNUM
  Endif
  [F:TBL]DET9  = "0" #116098.n

  If !WNOCCE
    #116098.sn
    If !WEXPORT
      If [L]DIMVAL <> "" & [L]VALSTR <> ""
        If [L]DIMVAL = [CCE]CCE & [L]VALSTR = [CCE]DIE
          [F:TBL]CCE1    = [F:CCE]DIE
          [F:TBL]TRICCE1 = [F:CCE]CCE
          [F:TBL]DET9  = "1"
        Endif
        Goto SKIP_DIM1
      Elsif [L]DIMVAL <> ""
        If [L]DIMVAL = [CCE]CCE
          [F:TBL]CCE1    = [F:CCE]DIE
          [F:TBL]TRICCE1 = [F:CCE]CCE
          [F:TBL]DET9  = "1"
        Endif
        Goto SKIP_DIM1
      Elsif [L]VALSTR <> ""
        If [L]VALSTR = [CCE]DIE
          [F:TBL]CCE1    = [F:CCE]DIE
          [F:TBL]TRICCE1 = [F:CCE]CCE
          [F:TBL]DET9  = "1"
        Endif
        Goto SKIP_DIM1
      Endif
    Endif
    #116098.en

    If [F:TBL]TRICCE1 = ""
      [F:TBL]CCE1    = [F:CCE]DIE
      [F:TBL]TRICCE1 = [F:CCE]CCE
    Elsif [F:TBL]TRICCE2 = ""
      [F:TBL]CCE2    = [F:CCE]DIE
      [F:TBL]TRICCE2 = [F:CCE]CCE
    Elsif [F:TBL]TRICCE3 = ""
      [F:TBL]CCE3    = [F:CCE]DIE
      [F:TBL]TRICCE3 = [F:CCE]CCE
    Elsif [F:TBL]TRICCE4 = ""
      [F:TBL]CCE4    = [F:CCE]DIE
      [F:TBL]TRICCE4 = [F:CCE]CCE
    Elsif [F:TBL]TRICCE5 = ""
      [F:TBL]CCE5    = [F:CCE]DIE
      [F:TBL]TRICCE5 = [F:CCE]CCE
    Elsif [F:TBL]TRICCE6 = ""
      [F:TBL]CCE6    = [F:CCE]DIE
      [F:TBL]TRICCE6 = [F:CCE]CCE
    Elsif [F:TBL]TRICCE7 = ""
      [F:TBL]CCE7    = [F:CCE]DIE
      [F:TBL]TRICCE7 = [F:CCE]CCE
    Elsif [F:TBL]TRICCE8 = ""
      [F:TBL]CCE8    = [F:CCE]DIE
      [F:TBL]TRICCE8 = [F:CCE]CCE
    Else
      [F:TBL]CCE9    = [F:CCE]DIE
      [F:TBL]TRICCE9 = [F:CCE]CCE
  Endif

SKIP_DIM1:
  Endif # 91808.n  WNOCCE

  [F:TBL]CREDAT  = date$
  Write [TBL]
  If fstat : GOK = 0 : Call FSTA("TBL") From GLOCK : Rollback : Endif
Else # add to existing record

  Trbegin [TBL]

  #116098.sn
  [F:TBL]DET9  = "0"
  If !WEXPORT
    If [L]DIMVAL <> "" & [L]VALSTR <> ""
      If [L]DIMVAL = [CCE]CCE & [L]VALSTR = [CCE]DIE
        [F:TBL]CCE1    = [F:CCE]DIE
        [F:TBL]TRICCE1 = [F:CCE]CCE
        [F:TBL]DET9  = "1"
      Endif
      Goto SKIP_DIM2
    Elsif [L]DIMVAL <> ""
      If [L]DIMVAL = [CCE]CCE
        [F:TBL]CCE1    = [F:CCE]DIE
        [F:TBL]TRICCE1 = [F:CCE]CCE
        [F:TBL]DET9  = "1"
      Endif
      Goto SKIP_DIM2
    Elsif [L]VALSTR <> ""
      If [L]VALSTR = [CCE]DIE
        [F:TBL]CCE1    = [F:CCE]DIE
        [F:TBL]TRICCE1 = [F:CCE]CCE
        [F:TBL]DET9  = "1"
      Endif
      Goto SKIP_DIM2
    Endif
  Endif
  #116098.en

  If [F:TBL]TRICCE1 = ""
    [F:TBL]CCE1    = [F:CCE]DIE
    [F:TBL]TRICCE1 = [F:CCE]CCE
  Elsif [F:TBL]TRICCE2 = ""
    [F:TBL]CCE2    = [F:CCE]DIE
    [F:TBL]TRICCE2 = [F:CCE]CCE
  Elsif [F:TBL]TRICCE3 = ""
    [F:TBL]CCE3    = [F:CCE]DIE
    [F:TBL]TRICCE3 = [F:CCE]CCE
  Elsif [F:TBL]TRICCE4 = ""
    [F:TBL]CCE4    = [F:CCE]DIE
    [F:TBL]TRICCE4 = [F:CCE]CCE
  Elsif [F:TBL]TRICCE5 = ""
    [F:TBL]CCE5    = [F:CCE]DIE
    [F:TBL]TRICCE5 = [F:CCE]CCE
  Elsif [F:TBL]TRICCE6 = ""
    [F:TBL]CCE6    = [F:CCE]DIE
    [F:TBL]TRICCE6 = [F:CCE]CCE
  Elsif [F:TBL]TRICCE7 = ""
    [F:TBL]CCE7    = [F:CCE]DIE
    [F:TBL]TRICCE7 = [F:CCE]CCE
  Elsif [F:TBL]TRICCE8 = ""
    [F:TBL]CCE8    = [F:CCE]DIE
    [F:TBL]TRICCE8 = [F:CCE]CCE
  Elsif [F:TBL]TRICCE9 = ""
    [F:TBL]CCE9    = [F:CCE]DIE
    [F:TBL]TRICCE9 = [F:CCE]CCE
  Endif

SKIP_DIM2:
  Rewrite [TBL]
  If fstat : GOK = 0 : Call FSTA("TBL") From GLOCK : Rollback : Endif
Endif

If fstat
  Rollback
Else
  Commit
Endif

Filter [TBL]
Return
#########################################################################################################
$DRCR_CALC
#90393.sn
Raz WAMT1, WAMT2, WAMT3

If [BAL]CUR = [CPY]ACCCUR # Print curr = company curr
For I=PERDEB To PERFIN
  WAMT2+=[BAL]DEBLED(I)
  WAMT3+=[BAL]CDTLED(I)
Next
For I=0 To PERDEB-1
  WAMT1+=([BAL]DEBLED(I)-[BAL]CDTLED(I))
Next
Elsif [BAL]CUR = XDEVISE # Print curr = Balance curr
For I=PERDEB To PERFIN
  WAMT2+=[BAL]DEB(I)
  WAMT3+=[BAL]CDT(I)
Next
For I=0 To PERDEB-1
  WAMT1+=([BAL]DEB(I)-[BAL]CDT(I))
Next
Else
For I=PERDEB To PERFIN
  WAMT2+=[BAL]DEBLED(I)
  WAMT3+=[BAL]CDTLED(I)
Next
For I=0 To PERDEB-1
  WAMT1+=([BAL]DEBLED(I)-[BAL]CDTLED(I))
Next
Endif


# 91808.sn
If XBAL
  Filter [TBL] Where [TBL]CCEA=[BAL]ACC & [TBL]USR=GUSER & [TBL]RPTCOD=[L]ETAT
  Readlock [TBL] Last
  If !fstat
  Trbegin [TBL]
    [F:TBL]AMT2=abs(BLADRAMT-WDRAMT)
    [F:TBL]AMT3=abs(BLACRAMT-WCRAMT)
    [F:TBL]AMT1=(BLAOAMT-WOAMT) # opening balance
    If XDEVISE<>[BAL]CUR and XCOURS <> 1
      [F:TBL]AMT2=([F:TBL]AMT2*XCOURS)
      [F:TBL]AMT3=([F:TBL]AMT3*XCOURS)
      [F:TBL]AMT1=([F:TBL]AMT1*XCOURS)
    Endif
  Rewrite [TBL]
  If fstat : GOK = 0 : Call FSTA("TBL") From GLOCK : Rollback : Endif
If fstat
  Rollback
Else
  Commit
Endif
  Endif
Else
# 91808.en


Filter [TBL] Where [TBL]CCEA=[BAL]ACC
Readlock [TBL]ARM0(3)=[L]NUMREQ;GUSER;[L]ETAT
If !fstat
Trbegin [TBL]
# Apply conver rate as needed
If XDEVISE<>[BAL]CUR and XCOURS <> 1
  [F:TBL]AMT1+=(WAMT1*XCOURS)
  [F:TBL]AMT2+=(WAMT2*XCOURS)
  [F:TBL]AMT3+=(WAMT3*XCOURS)
Else
  [F:TBL]AMT1+=WAMT1
  [F:TBL]AMT2+=WAMT2
  [F:TBL]AMT3+=WAMT3
Endif
Rewrite [TBL]
  If fstat : GOK = 0 : Call FSTA("TBL") From GLOCK : Rollback : Endif

If fstat
  Rollback
Else
  Commit
Endif
Endif # fstat readlock

Endif # 91808.n

# 90393.en
Return
##########################################################################################################
$DRCR_BLACALC
#90393_A.sn
Raz WAMT1, WAMT2, WAMT3

If [BLA]CUR = [CPY]ACCCUR # Print curr = company curr
For I=PERDEB To PERFIN
  WAMT2+=[BLA]DEBLED(I)
  WAMT3+=[BLA]CDTLED(I)
Next
For I=0 To PERDEB-1
  WAMT1+=([BLA]DEBLED(I)-[BLA]CDTLED(I))
Next
Elsif [BLA]CUR = XDEVISE # Print curr = Balance curr
For I=PERDEB To PERFIN
  WAMT2+=[BLA]DEB(I)
  WAMT3+=[BLA]CDT(I)
Next
For I=0 To PERDEB-1
  WAMT1+=([BLA]DEB(I)-[BLA]CDT(I))
Next
Else
For I=PERDEB To PERFIN
  WAMT2+=[BLA]DEBLED(I)
  WAMT3+=[BLA]CDTLED(I)
Next
For I=0 To PERDEB-1
  WAMT1+=([BLA]DEBLED(I)-[BLA]CDTLED(I))
Next
Endif

# 91808.sn
#  Accumulate BLA CR and DR and then compare with total BAL values
#If WEXPORT # All dimensions only #116098.o
If WDETAILDIM #116098.n
  For I=PERDEB To PERFIN
    BLACRAMT+= [BLA]CDTLED(I)  # Assumes CUR is same on BAL and all related BAL records, ok ?
    BLADRAMT+= [BLA]DEBLED(I)
  Next
  For I=0 To PERDEB-1
    BLAOAMT+=([BLA]DEBLED(I)-[BLA]CDTLED(I))
  Next
Endif
# 91808.en

Filter [TBL] Where [TBL]CCEA=[BLA]ACC
Readlock [TBL]ARM0=[L]NUMREQ;GUSER;[L]ETAT;[L]WNUMLIG  # Add numlig, removed (3) # 90393_A.n
If !fstat
Trbegin [TBL]
# Apply conver rate as needed
If XDEVISE<>[BLA]CUR and XCOURS <> 1
  [F:TBL]AMT1+=(WAMT1*XCOURS)
  [F:TBL]AMT2+=(WAMT2*XCOURS)
  [F:TBL]AMT3+=(WAMT3*XCOURS)
  # 91808.sn
  #If WEXPORT # All dimensions only #116098.o
  If WDETAILDIM #116098.n
    BLACRAMT=(BLACRAMT*XCOURS)
    BLADRAMT=(BLADRAMT*XCOURS)
    BLAOAMT =(BLAOAMT*XCOURS)
  Endif
# 91808.en
Else
  [F:TBL]AMT1+=WAMT1
  [F:TBL]AMT2+=WAMT2
  [F:TBL]AMT3+=WAMT3
Endif
Rewrite [TBL]
  If fstat : GOK = 0 : Call FSTA("TBL") From GLOCK : Rollback : Endif

If fstat
  Rollback
Else
  Commit
Endif
Endif # fstat readlock

# 90393_A.en
Return
##########################################################################################################

