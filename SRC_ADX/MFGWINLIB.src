#<AdxTL>@(#)4.0.0.0 $Revision$
#######################################################################
#                                                                     #
#    TRAITEMENTS de SAISIE ou VISU en FENETRE dans la GPAO            #
#                                                                     #
#######################################################################
#                                                                     #
# ACTION MODELISATION E-COMMERCE : GACTION                            #
#---------------------------------------------------------------------#
# ROURPL      : Renumérotation d'une opération en gestion des gammes  #
# ROURPL1     : Renumérotation globale en gestion des gammes          #
# ROUFICH     : Gestion des gammes :Mode fiche sur une ligne opé      #
# JALFICH     : Gestion des gammes :Mode fiche sur une ligne jal      #
# MFIFICH     : visu en mode fiche d'une ligne article produit (OF)   #
# MFISUBFICH  : Ajout d'un sous-produit                        (OF)   #
# MFMFICH     : visu en mode fiche d'une ligne composant       (OF)   #
# MFOFICH     : visu en mode fiche d'une ligne opération       (OF)   #
# MFIFICHMTK  : visu en mode fiche d'une ligne article produit (Suivi)#
# MFITRKSTA   : Etat de suivi d'une ligne article produit             #
# MFOTRKSTA   : Etat de suivi d'une ligne opératoire                  #
# MFOTRKSTAB  : Etat de suivi d'une ligne opératoire  poste de SST    #
# MFOTRKFICH  : Suivi en mode fiche d'une ligne opération             #
# MFOFICHMTK  : visu en mode fiche d'une opération d'OF (Suivi)       #
# MKOREBUT    : Saisie/visu des codes rebut                           #
# MTKCALTPS   : Calcul d'un temps passé par saisie des heures déb/fin #
# MFMTRKSTA   : Etat de suivi d'une ligne matière                     #
# MFMFICHMTK  : Suivi en mode fiche d'une ligne composant             #
# MFMFAN      : Ajouter sous-ensemble (fantôme)                       #
# CALQTEPROD  : Calcul d'une quantité productible                     #
#######################################################################
# Issue X3-6311 - 2017-06-22 by BAKHA : if versiond product, ask before adding component/assembly
# Issue X3-25054 - when adding a component, copy revreason to WO component line for auditing
# Issue X3-48941 - 2017-08-01 by BAKHA : Check new GMFGREV parameter for audit
# Issue X3-55832 - 2017-09-13 by BAKHA : before checking versioning fields, make sure Versioning is in use

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "SETBOUT"    : Gosub SETBOUT
    When "DEBUT"      : Gosub DEBUT
    When "ENR"        : Gosub ENR
    When "AVANT_OK"   : Gosub AVANT_OK
    When "OK"         : Gosub OK
    When "ABA"        : Gosub ABA
    When "END"        : Gosub ENDF
    When "APRES_MODIF": Gosub APRES_MODIF
    When "BOUTON"     : Gosub BOUTON
    When "FIN"        : Gosub FIN
    When "FINSAI"     : Gosub FINSAI
Endcase
#--- Actions liés au type traitement standard
Case ACTION
    When "INIT"       : Gosub INIT
    When "INIT_DIA"   : Gosub INIT_DIA
    When "CONTROLE"   : Gosub CONTROLE
    When "EXEC"       : Gosub EXEC
    When "TERMINE"    : Gosub TERMINE
Endcase
Return

#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
$OUVRE
Case GACTION
    When "ROUFICH"      : Gosub OUV_ROUFICH
    When "JALFICH"      : Gosub OUV_JALFICH
    When "MFIFICH"      : Gosub OUV_MFIFICH
    When "MFISUBFICH"   : Gosub OUV_MFISUBFICH
    When "MFMFICH"      : Gosub OUV_MFMFICH
    When "MFOFICH"      : Gosub OUV_MFOFICH
    When "MFIFICHMTK"   : Gosub OUV_MFIFICHMTK
    When "MFITRKSTA"    : Gosub OUV_MFITRKSTA
    When "MFOTRKSTA"    : Gosub OUV_MFOTRKSTA
    When "MFOTRKSTAB"   : Gosub OUV_MFOTRKSTAB
    When "MFOTRKFICH"   : Gosub OUV_MFOTRKFICH
    When "MFOFICHMTK"   : Gosub OUV_MFOFICHMTK
    When "MKOREBUT"     : Gosub OUV_MKOREBUT
    When "MFMFICHMTK"   : Gosub OUV_MFMFICHMTK
    When "MFMTRKSTA"    : Gosub OUV_MFMTRKSTA
    When "MFMFAN"       : Gosub OUV_MFMFAN
    When "MFOFRC"       : Gosub OUV_MFOFRC
Endcase
Return

#-------------------------------------------------
$SETBOUT
Case GACTION
    When "MFISUBFICH"   : Gosub SETBOUT_MFISUBFICH
    When "MFMFICH"      : Gosub SETBOUT_MFMFICH
    When "MFOFICH"      : Gosub SETBOUT_MFOFICH
    When "MFMTRKSTA"    : Gosub SETBOUT_MFMTRKSTA
    When "MFMFICHMTK"   : Gosub SETBOUT_MFMFICHMTK
    When "MFOFICHMTK"   : Gosub SETBOUT_MFOFICHMTK
    When "MFOTRKFICH"   : Gosub SETBOUT_MFOTRKFICH
    When "MFOTRKSTAB"   : Gosub SETBOUT_MFOTRKSTAB
    When "JALFICH"      : Gosub SETBOUT_JALFICH
Endcase
Return

#-------------------------------------------------
$DEBUT
Case GACTION
    When "ROUFICH"    : Gosub DEB_ROUFICH
                        Affzo [M:ROF0]1-99
                        Affzo [M:ROF1]1-99
                        Affzo [M:ROF2]1-99
                        Affzo [M:ROF3]1-99
                        If OMODIF = 9
                            Diszo [M:ROF0]
                            Diszo [M:ROF1]
                            Diszo [M:ROF2]
                            Diszo [M:ROF3]
                        Endif
    When "JALFICH"    : Gosub DEB_JALFICH
                        Affzo [M:ROF4]1-99
    When "MFIFICH"    : Gosub DEB_MFIFICH
    When "MFISUBFICH" : Gosub DEB_MFISUBFICH
    When "MFMFICH"    : Gosub DEB_MFMFICH
    When "MFOFICH"    : Gosub DEB_MFOFICH
    When "MFIFICHMTK" : Gosub DEB_MFIFICHMTK
                        Diszo [M:MFIW]1-99
    When "MFITRKSTA"  : Gosub DEB_MFITRKSTA
                        Diszo [M:MFIQ]1-99
    When "MFOTRKSTA"  : Gosub DEB_MFOTRKSTA
                        Diszo [M:MTKX]1-99
    When "MFOTRKSTAB" : Gosub DEB_MFOTRKSTAB
                        Diszo [M:MTKW]1-99
    When "MFOTRKFICH" : Gosub DEB_MFOTRKFICH
                        Affzo [M:MTO1]1-99
    When "MFOFICHMTK" : Gosub DEB_MFOFICHMTK
                        Affzo [M:MFO0]1-99
                        Affzo [M:MFO1]1-99
                        Affzo [M:MFO2]1-99
                        Affzo [M:MFO3]1-99
    When "MKOREBUT"   : Gosub DEB_MKOREBUT
                        Affzo [M:MTO3]1-99
    When "MFMFICHMTK" : Gosub DEB_MFMFICHMTK
                        Affzo [M:MFMW]1-99
    When "MFMTRKSTA"  : Gosub DEB_MFMTRKSTA
                        Diszo [M:MTKM]1-99
    When "MFMFAN"     : Gosub DEB_MFMFAN
    When "MFOFRC"     : Gosub DEB_MFOFRC
Endcase
Return

#-------------------------------------------------
$ENR
Case GACTION
Endcase
Return

#-------------------------------------------------
$AVANT_OK
Case GACTION
    When "MKOREBUT"     : Gosub AVANT_OK_MKOREBUT
Endcase
Return

#-------------------------------------------------
$OK
Case GACTION
    When "ROUFICH"      : Gosub OK_ROUFICH
    When "JALFICH"      : Gosub OK_JALFICH
    When "MFISUBFICH"   : Gosub OK_MFISUBFICH
    When "MFMFICH"      : Gosub OK_MFMFICH
    When "MFOFICH"      : Gosub OK_MFOFICH
    When "MFOTRKFICH"   : Gosub OK_MFOTRKFICH
    When "MKOREBUT"     : Gosub OK_MKOREBUT
    When "MFMFAN"       : Gosub OK_MFMFAN
    When "MFOFRC"       : Gosub OK_MFOFRC
Endcase
Return

#-------------------------------------------------
$ABA
Case GACTION
    When "ROUFICH"     : Gosub DEB_ROUFICH
                         REP = ""
                         Affzo [M:ROF0]1-99
                         Affzo [M:ROF1]1-99
                         Affzo [M:ROF2]1-99
                         Affzo [M:ROF3]1-99
    When "JALFICH"     : Gosub DEB_JALFICH
                         REP = ""
                         Affzo [M:ROF4]1-99
    When "MFOTRKFICH"  : OK=1
                         If WGREP = "C" & LNEW <> 3 & GCONF(3) <> 1
                             Call ABANDON(LOK) From GESECRAN
                             If LOK=1
                                 Gosub DEB_MFOTRKFICH
                                 Affzo [M:MTO1]1-99
                             Endif
                         Endif
Endcase
Return

#-------------------------------------------------
$ENDF
Case GACTION
Endcase
Return

#-------------------------------------------------
$APRES_MODIF
Case GACTION
    When "ROUFICH"    : REP = "M"
    When "JALFICH"    : REP = "M"
    When "MFISUBFICH" : REP = "M"
    When "MFMFICH"    : REP = "M"
    When "MFOFICH"    : REP = "M"
Endcase
Return

#-------------------------------------------------
$BOUTON
Case GACTION
    When "MFISUBFICH": Gosub BOUT_MFISUBFICH
    When "MFMFICH"   : Gosub BOUT_MFMFICH
    When "MFOFICH"   : Gosub BOUT_MFOFICH
Endcase
Return

#-------------------------------------------------
$FIN
Case GACTION
    When "MFISUBFICH": Gosub FIN_MFISUBFICH
    When "MFMFICH"   : Gosub FIN_MFMFICH
    When "MFOFICH"   : Gosub FIN_MFOFICH
Endcase
Return

#-------------------------------------------------
$FINSAI
Case GACTION
Endcase
Return

################################################################################
# ROUFICH : Gestion en fiche d'une ligne de gamme                              #
################################################################################
$OUV_ROUFICH
Local Char    WABMSK   : WABMSK = PARAM(1)
Local Integer WLIG     : WLIG   = val(PARAM(2))

If OMODIF <> 9 : OMODIF = 0 : Endif
Local Integer LCAP : LCAP = 1
Return

#-------------------------------------------------
$DEB_ROUFICH
nolign = WLIG + 1
If [M:ROU1]OPENUM(WLIG)<>0 & [M:ROU1]WST(WLIG)<>''
   # 46079 02.08 On désactive la saisie de l'opération une fois dasn la fiche
   Grizo [ROF0]OPENUM
   Raz [M:ROF0], [M:ROF1], [M:ROF2]
   [M:ROF0]=[M:ROU1]
   [M:ROF1]=[M:ROU1]
   [M:ROF2]=[M:ROU1]
   [M:ROF3]=[M:ROU1]
   [M:ROF5]=[M:ROU1]
   # Issue 112851 - 2015-11-30 by GH : text management correction
   Call LEC_TEX(WLIG) : Affzo [ROF5]1-99 : #Gosub LEC_TEX : # MHB 16/10/08 : lecture du texte ligne
   # 17809 MM 07.05
   Grizo [ROF1]CTIMCOE, HCTIMCOE
   If [M:ROF2]SCOCOD = 1 : Grizo [M:ROF2]30 : Actzo [M:ROF2]SCOCOD : Else : Actzo [M:ROF2]30 : Endif
   #
   OINSERT = 1
Else
   Gosub MAJ_FENETRE From SUBROUA
   # Issue 112851 - 2015-11-30 by GH : text management correction
   #Gosub INI_TEX : # MHB 16/10/08 : initialisation pour lecture texte
   OINSERT = 0
Endif

# 12.03 MM : Multi-emplacement,la notion de tiers remplace celle de fournisseur.
GBPCNUM = [M:ROF2]BPRNUM
Return

#-------------------------------------------------
$OK_ROUFICH
# 46079 02.08 Pour éviter la création de la ligne 0
Local Integer NBLIGROU1 : NBLIGROU1= [M:ROU1]NBLIG

# Issue 112689 - 2015-11-23 by GH : increment lines number before setting values to the line and displaying it
If [M:ROU1]CREFLG(WLIG)=0 & WLIG=NBLIGROU1 & OINSERT=0
   [M:ROU1]NBLIG+=1
Endif

nolign = WLIG + 1
[M:ROU1]=[M:ROF2] : [M:ROU1]=[M:ROF1] : [M:ROU1]=[M:ROF0] : [M:ROU1]=[M:ROF3] : [M:ROU1]=[M:ROF5]
# Issue 112851 - 2015-11-30 by GH : text management corrected
Call VERIF_TEX(WLIG) : #Gosub VERIF_TEX : # MHB 16/10/08 : vérification modif sur texte ligne

## 46079 02.08 Afficher les valeurs au retour de la fiche
#Affzo[M:ROU1]1-99
#Affzo [M:ROU1]NBLIG(WLIG) : # Issue 88276 - 2013-03-08 by CCC : N'afficher que la ligne concernée (sinon AV_xx déclenchés sur les autres lignes)
Call AFFLIG("ROU1","ROU1","NBLIG",WLIG) From OBJSIM : # Issue 112678 - 2015-11-20 by GH : values were not displayed for an inserted line

# 03.06 demande 35393
If [M:ROF2]OPETEXNUM <> "" & [M:ROU1]ROOTEX(WLIG) = ""
     [M:ROU1]ROOTEX(WLIG) = [M:ROF2]OPETEXNUM    # 30951 MM 06.05
Endif

# Issue 112689 - 2015-11-23 by GH : not cancel changes entered but not registered on tab Scheduling
# Attribution  de l'indice de la variante d'opération
# # If [M:ROU1]CREFLG(WLIG)=0
#If [M:ROU1]CREFLG(WLIG)=0 & [M:ROU1]INDEXIST(WLIG)<>2 # Issue 112674 - 2015-11-20 by GH : optimsation
#    Gosub ATTRIBUE_IND From SUBROU
#    # INDEXIST=2 : # Issue 112674 - 2015-11-20 by GH : index not calculated
#Endif
#
#[M:ROU1]CONCATKEY(WLIG)=num$([M:ROF0]OPENUM)+num$([M:ROF0]RPLIND)
#[M:ROU1]UPDFLG(WLIG)=1
## si création en mode fiche : incrémenter nb lignes tableau
#If [M:ROU1]CREFLG(WLIG)=0 & WLIG=NBLIGROU1
#   If OINSERT = 0 : [M:ROU1]NBLIG+=1 : Endif
#   Gosub LIENS From SUBROU3
#Endif
nolign = WLIG + 1 : # by security
Call APRES_NBLIG From SUBROU

If OMODIF = 1 : mkstat=4 : Endif
If OINSERT = 1
    VALEUR  = [M:ROU1]OPENUM(WLIG)
Endif
Return

#####################################################################
# Gestion du clob dans les fiches gammes                            #
#####################################################################

## MHB 16/10/08 : lecture du texte ligne
#$INI_TEX
#Local Integer STAT
#
#If !clalev([M:ACL]) Then Local Mask ACLOB [ACL] Endif
#Return

## MHB 16/10/08 : lecture du texte ligne
#$LEC_TEX
#Local Integer STAT
#Local Char    SAVACTION
#
#  If !clalev([M:ACL]) Then Local Mask ACLOB [ACL] Endif
#
#  PARAM(1) = [M:ROU1]ROOTEX(nolign-1)
#  PARAM(2) = "ROO"
#  PARAM(3) = "TRTX3TEX"
#  PARAM(4) = "ROU1"
#  PARAM(5) = num$(nolign)
#  PARAM(6) = num$(GINTTEX)
#  SAVACTION=ACTION
#  ACTION = "INIT_DIA"
#  Gosub ACTION From ACLOB
#  ACTION = SAVACTION
#  [M:ROF5]CLOB = [M:ACL]CLOB
#  Affzo [M:ROF5]
#Return

Subprog LEC_TEX(NOL)
Value Integer NOL
Local Integer STAT
Local Char PARAM(20)(1..6)
Local Char ACTION(20)
If !clalev([M:ACL]) : Local Mask ACLOB   [ACL] : Endif
If !clalev([F:TXC]) : Local File TEXCLOB [TXC] : Endif

PARAM(1) = [M:ROU1]ROOTEX(NOL)
PARAM(2) = "ROO"
PARAM(3) = "TRTX3TEX"
PARAM(4) = "ROF5"
PARAM(5) = num$(NOL+1)
PARAM(6) = num$(GINTTEX)
ACTION = "INIT_DIA"
Gosub ACTION From ACLOB
[M:ROF5]CLOB = [M:ACL]CLOB
End

## MHB 16/10/08 : vérification modif sur texte ligne
#$VERIF_TEX
#Local Char SAVACTION
#
#  SAVACTION = ACTION
#  ACTION = "EXEC"
#  If [M:ACL]CLOB <> [M:ROF5]CLOB Then
#    OMODIF=1
#    [M:ACL]CLOB = [M:ROF5]CLOB
#  Endif
#  Gosub ACTION From ACLOB
#  [M:ROU1]ROOTEX(WLIG) = PARAM(1)
#  ACTION = SAVACTION
#  If clalev([M:ACL]) Then Close Local Mask [M:ACL] Endif
#Return

Subprog VERIF_TEX(NOL)
Value Integer NOL
Local Integer STAT
Local Char PARAM(20)(1..6)
Local Char ACTION(20)
# variable pour les action dans TRTX3TEX
Local Integer WEXIST
Local Integer WDBASE
WDBASE = 1  # Texte 'donnée de base'

If !clalev([M:ACL]) : Local Mask ACLOB   [ACL] : Endif
If !clalev([F:TXC]) : Local File TEXCLOB [TXC] : Endif

PARAM(1) = [M:ROU1]ROOTEX(NOL)
PARAM(2) = "ROO"
PARAM(3) = "TRTX3TEX"
PARAM(4) = "ROF5"
PARAM(5) = num$(NOL+1)
PARAM(6) = num$(GINTTEX)

ACTION = "EXEC"
If [M:ACL]CLOB <> [M:ROF5]CLOB
   OMODIF=1
   [M:ACL]CLOB = [M:ROF5]CLOB
Endif
Gosub ACTION From ACLOB
[M:ROU1]ROOTEX(NOL) = PARAM(1)
If clalev([M:ACL]) : Close Local Mask [M:ACL] : Endif
End

################################################################################
# JALFICH : Gestion en fiche d'une ligne de jalonnement gamme                  #
################################################################################
$OUV_JALFICH
Local Char    WABMSK   : WABMSK = PARAM(1)
Local Integer WLIG     : WLIG   = val(PARAM(2))

# Issue 104937 - 2015-11 by GH : versioning
Local Integer WMOD     : WMOD   = 2
If clalev([M:ROU1]) & clalev([M:ROU0])
   Local Integer VOPE
   VOPE = [M:ROU3]OPENUM(WLIG)
   mkstat=0 : Gosub MOD_ROU3 From ECCROU
   If mkstat : WMOD = 1 : mkstat=0 : Endif
Endif
Return

#-------------------------------------------------
$DEB_JALFICH
Raz [M:ROF4]
nolign = WLIG + 1
[M:ROF4]=[M:ROU3]
[M:ROF4]XWSTTYP = mess([M:ROF4]WSTTYP, 343, 1)
Boxact [ROF4]
If WMOD<>2 : Diszo [ROF4] : Endif
Return

#-------------------------------------------------
# Issue 104937 - 2015-11 by GH : versioning
$SETBOUT_JALFICH
If WMOD<>2 : CHBOU="" : Endif
Return

#-------------------------------------------------
$OK_JALFICH
[M:ROU3]=[M:ROF4]
Affzo [M:ROU3]1-99
If OMODIF = 1 : mkstat=4 : Endif
Return

################################################################################
# MFISUBFICH : Ajout d'un sous-produit             OF                          #
################################################################################
$OUV_MFISUBFICH
Local    Integer    WLIG   : WLIG = val(PARAM(1))
Local    Integer    WNEW
Local    Integer    WOK, I
Local    Integer    SLIG, J
Local    Char       WCCE(20)
Local    Date       WORIDAT
Local    Char       WORIFCY
Local    Integer    WLTI
Local    Date       WDSTDAT
Local    Integer    WRET
Return

#-------------------------------------------------
$DEB_MFISUBFICH
MMODIF = 0
GMODITM = 0
WNEW = 0
nolign = WLIG + 1
Raz [M:MFMW]
[M:MFMW]RETDAT=[M:MFG1]STRDAT
[M:MFMW]CPNTYP    = 4
If dim([M:MFMW]PKC)>0        # 47226 mm 05.08
    [M:MFMW]PKC       = 1 : Grizo [M:MFMW]PKC
Endif
[M:MFMW]MFGLINK   = 2 : Grizo [M:MFMW]MFGLINK
# Issue 80199 - 2012-02-17 by CCC : init MFGLIN
#If [M:MFG1]NBLIG = 1 : [M:MFMW]MFGLIN = [M:MFG1]MFGLIN(0) :  mkstat = 2 : Endif
# Issue 104862 - 2015-01-23 by FRHOL : init MFGLIN not only if the grid has one line
If [M:MFG1]NBLIG >= 1
   Local Integer IPRD : IPRD = [M:MFG1]NBLIG - 1
   While IPRD >= 0
      If  [M:MFG1]ITMTYP(IPRD) = 1 | IPRD = 0
          [M:MFMW]MFGLIN = [M:MFG1]MFGLIN(IPRD) :  mkstat = 2 : Break
      Endif
      IPRD -= 1
   Wend
Endif

[M:MFMW]RELSCATIA = 1 : Grizo [M:MFMW]RELSCATIA

Grizo [M:MFMW]SCA
Grizo [M:MFMW]PICPRN
Grizo [M:MFMW]CUMFLG
Grizo [M:MFMW]CUMFXDQTY

If dim([M:MFMW]RETQTY2) > 0 : Diszo [M:MFMW]RETQTY2 : Endif
If dim([M:MFMW]XTYPQTY2) > 0 : Diszo [M:MFMW]XTYPQTY2 : Endif

# Issue 110957 - 2015-09-17 by CCC
If dim([M:MFMW]CRID)>0
    If [F:MTS]CRAFF=1
        Diszo [M:MFMW]CRID
        If dim([M:MFMW]CRFLG)>0
            [M:MFMW]CRFLG = string$([M:MFMW]CRID<>"","151")
        Endif
    Else
        Chgfmt [M:MFMW]CRID With "-K:1X"
        If dim([M:MFMW]CRFLG)>0
            Chgfmt [M:MFMW]CRFLG With "-K:1X"
        Endif
    Endif
Endif

Affzo [M:MFMW]
Return

#-------------------------------------------------
$SETBOUT_MFISUBFICH
ETABOU(GVALI)=1
ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
ETABOU(GSPE1)=0

If GCONSLCT = 1
    ETABOU(GSPE1) = 0
    Diszo [M:MFMW]
Endif
Return

#-------------------------------------------------
$BOUT_MFISUBFICH
Return

#-------------------------------------------------
$OK_MFISUBFICH
nolign = WLIG + 1
[M:MFG1] = [M:MFMW]
[M:MFG1]UOM(WLIG)        = [M:MFG1]STU(WLIG)
[M:MFG1]EXTQTY(WLIG)     = [M:MFMW]RETQTY
[M:MFG1]UOMEXTQTY(WLIG)  = [M:MFMW]RETQTY
[M:MFG1]UOMSTUCOE(WLIG)  = 1
[M:MFG1]ITMTYP(WLIG)     = 2
[M:MFG1]XMFGLIN(WLIG)    = [M:MFMW]MFGLIN
[M:MFG1]CPLQTY(WLIG)     = 0
[M:MFG1]SPOPE(WLIG)      = [M:MFMW]BOMOPE
[M:MFG1]SPOFS(WLIG)      = [M:MFMW]BOMOFS
For I = 0 To [M:MFG1]NBLIG-1
    If [M:MFG1]MFGLIN(I)       = [M:MFG1]XMFGLIN(WLIG)
       [M:MFG1]MFGLIN(WLIG)    = [M:MFG1]MFGLIN(I) + WLIG
       [M:MFG1]PJT(WLIG)       = [M:MFG1]PJT(I)
       [M:MFG1]VCRTYPORI(WLIG) = [M:MFG1]VCRTYPORI(I)
       [M:MFG1]VCRNUMORI(WLIG) = [M:MFG1]VCRNUMORI(I)
       [M:MFG1]VCRLINORI(WLIG) = [M:MFG1]VCRLINORI(I)
       [M:MFG1]VCRSEQORI(WLIG) = [M:MFG1]VCRSEQORI(I)
       [M:MFG1]MFGDES(WLIG)    = [M:MFG1]MFGDES(I)
        Break
    Endif
Next I

If [F:ITM]LOTMGTCOD > 1

    If clalev([F:SRU])<=0 : Local File TABSTORUL  [SRU] : Endif

    # Lecture de la règle de gestion à utiliser
    Call LECSRU([M:MFG0]MFGFCY,[F:ITM]TCLCOD, 5, "", "", WRET)
&           From STKLIB

    # 10.05 32769
    If [F:ITM]LOTCOU = ""
       If !WRET & [F:SRU]LOTSUPINH=3
          [M:MFG1]GESLOT(WLIG)    = "V"
       Endif
    Else
      [M:MFG1]GESLOT(WLIG)       = "C"
    Endif
    If [F:MTS]LOTAFF > 1 | find([M:MFG1]GESLOT(WLIG),"C","V"): [M:MFG1]LOT(WLIG) = mess(62,193,1) : Endif
Endif

[M:MFG1]BPCTYPDEN(WLIG) = 1
[M:MFG1]BPCNUM(WLIG)    = [M:MFG0]MFGFCY
If [F:FCY]FCY <> [M:MFG0]MFGFCY
    Read [FCY]FCY0=[M:MFG0]MFGFCY
    If fstat : Raz [F:FCY] : Endif
Endif
[M:MFG1]BPCDES(WLIG)  = [F:FCY]FCYSHO
[M:MFG1]TCLCOD(WLIG)  = [F:ITM]TCLCOD
[M:MFG1]ABCCLS(WLIG)  = [F:ITF]ABCCLS
If dim([M:MFG1]TSICOD1(WLIG))>0 [M:MFG1]TSICOD1(WLIG)=[F:ITM]TSICOD(0) : Endif
If dim([M:MFG1]TSICOD2(WLIG))>0 [M:MFG1]TSICOD2(WLIG)=[F:ITM]TSICOD(1) : Endif
If dim([M:MFG1]TSICOD3(WLIG))>0 [M:MFG1]TSICOD3(WLIG)=[F:ITM]TSICOD(2) : Endif
If dim([M:MFG1]TSICOD4(WLIG))>0 [M:MFG1]TSICOD4(WLIG)=[F:ITM]TSICOD(3) : Endif
If dim([M:MFG1]TSICOD5(WLIG))>0 [M:MFG1]TSICOD5(WLIG)=[F:ITM]TSICOD(4) : Endif

[M:MFG1]PTOCOD(WLIG) = func ITMLIB.GET_PTOCOD([M:MFG1]ITMREF(WLIG),[M:MFG0]MFGFCY) : # GH 09/01/2015 bug 105215

If [M:MFG1]SPOPE(WLIG) = 0 & [M:MFG1]SPOFS(WLIG) = 0
    [M:MFG1]SPDAT(WLIG) = [M:MFG1]ENDDAT
Else
    WORIDAT    = [M:MFG1]STRDAT
    WORIFCY    = [M:MFG0]MFGFCY
    WLTI       = [M:MFG1]SPOFS(WLIG)
    If [M:MFG3]NBLIG <> 0 & [M:MFG3]SCDFLG > 1 & [M:MFG1]SPOPE(WLIG) <> 0
        For  I=0 To [M:MFG3]NBLIG-1
            If [M:MFG3]OPENUM(I) = [M:MFG1]SPOPE(WLIG)
                WORIDAT = [M:MFG3]OPESTR(I)
                Break
            Endif
        Next I
    Endif

    # révision calendriers
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB

    [M:MFG1]SPDAT(WLIG)  = WDSTDAT
Endif

# chargement des sections analytiques
SLIG = nolign
nolign = WLIG + 1
For J = 1 To GNBDIE
    Call INISEC(WCCE,"MFI",J) From TRTX3CPT
    Assign "[M:MFG1]CCE"+num$(J)+"("+num$(WLIG)+")" With WCCE
Next
nolign = SLIG
[M:MFG1]NBLIG     += 1
Boxclr [MFMW]
Affzo [M:MFG1]
MMODIF = 1
Call HIGHLIGHT("MFG1", WLIG) From ECCLIB    # 107513
mkstat = 4
Return

#-------------------------------------------------
$FIN_MFISUBFICH
Return


################################################################################
# MFMFICH : Gestion en fiche d'une ligne composant OF                          #
################################################################################
$OUV_MFMFICH
Local    Integer    WLIG   : WLIG = val(PARAM(1))
Local    Integer    WNEW
Local    Integer    WOK, I
Local    Integer    SLIG, J
Local    Char       WCCE(20)
# Issue X3-6311 - if versiond product, ask before adding component
If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
  If !GREVMESSC
    WOK=0
    For I=0 To [M:MFG1]NBLIG-1
      If ([M:MFG1]ITMTYP(I)=1 & [M:MFG1]ECCVALMAJ(I)<>"" )
        WOK=1
        Break
      Endif
    Next I

    If WOK=1
      GREVMESSC = 1
      GERR = 2
      GMESSAGE = mess(401,193,1) # You are about to do critical changes on a versioned product's components
    Endif
  Endif
Endif # Issue X3-55832
# End issue X3-6311

Return

#-------------------------------------------------
$DEB_MFMFICH
MMODIF = 0
GMODMAT = 0
WNEW = 0

If [M:MFG2]ITMREF(WLIG) = "" & [M:MFG2]CPNTYP(WLIG) <> 5                        # si ajout matière non prévue
    WNEW = 1
Else
    # FQ 56476 si matière non prévue et soldée, on passe en mode visu: cas déplacé après le test du solde
    #If [M:MFG2]BOMSEQ(WLIG) = 0 : WNEW = 2 : Goto FIN_ANA : Endif             # si modif matière non prévue
    If [M:MFG2]MATSTA(WLIG) > 2 : WNEW = 3 : Goto FIN_ANA : Endif              # si matière exclue ou soldée
    If [M:MFG2]BOMSEQ(WLIG) = 0 : WNEW = 2 : Goto FIN_ANA : Endif  # FQ 56476  # si modif matière non prévue et non exclue ou soldée
    If [M:MFG2]MATSTA(WLIG) = 2 : WNEW = 4 : Goto FIN_ANA : Endif              # si matière en cours
    If [M:MFG2]CUMFLG(WLIG) = 2 & [M:MFG2]MFGLIN(WLIG) = 0                     # si matière cumulée + groupage
        WNEW = 5
        Goto FIN_ANA
    Endif
Endif
If [M:MFG1]MFGTRKFLG = 2 : WNEW = 3 : Endif

$FIN_ANA
nolign = WLIG + 1
Case WNEW
    When 0: # accès en fiche d'une matière existante
            GMODMAT     = 1
            [M:MFMW] = [M:MFG2]
            Diszo[M:MFMW]5
            Diszo [M:MFMW]10
            Diszo [M:MFMW]STU
            Diszo [M:MFMW]LIKQTY
            Diszo [M:MFMW]LIKQTYCOD
            Diszo [M:MFMW]QTYRND
            Diszo [M:MFMW]BOMSHO
            If [M:MFMW]CPNTYP = 5
                Diszo [M:MFMW]PICPRN
                Diszo [M:MFMW]RETQTY
                Diszo [M:MFMW]BOMOFS
            Endif
    When 1: # ajout nouvelle matière
            Raz [M:MFMW]
            [M:MFMW]RETDAT=[M:MFG1]STRDAT
    When 2: # accès en fiche d'une matière non prévue existante
            GMODMAT     = 0
            [M:MFMW] = [M:MFG2]
            Diszo [M:MFMW]ITMREF
            Diszo [M:MFMW]ITMDES1
            Diszo [M:MFMW]STU
            If dim([M:MFMW]DEFPOT) > 0 : Grizo [M:MFMW]DEFPOT : Endif
            J = 0
            For I = 0 To [M:MFG1]NBLIG - 1
                If [M:MFG1]ITMTYP(I) = 1 : J += 1 : Endif
            Next I
            If J = 1 : Diszo [M:MFMW]MFGLINK : Diszo [M:MFMW]MFGLIN : Endif
    When 3: # accès en fiche d'une matière exclue (visu uniquement)
            GMODMAT     = 1
            [M:MFMW] = [M:MFG2]
            Diszo [M:MFMW]5
            Diszo [M:MFMW]10
            Diszo [M:MFMW]20
            Diszo [M:MFMW]25
            Diszo [M:MFMW]30
    When 4: # accès en fiche d'une matière en cours
            GMODMAT     = 1
            [M:MFMW] = [M:MFG2]
            Diszo [M:MFMW]
            Actzo [M:MFMW]RETQTY
    When 5: # accès en fiche d'une matière cumulée
            Local Mask MFMW
            [M:MFMW] = [M:MFG2]
            Diszo [M:MFMW]ITMREF
            Diszo [M:MFMW]ITMDES1
Endcase
Diszo [M:MFMW]CSTFLG
Diszo [M:MFMW]SCOFLG
Diszo [M:MFMW]CUMFLG
Diszo [M:MFMW]CUMFXDQTY

If WNEW <> 1
    If dim([M:MFMW]XTYPQTY) > 0
        If [M:MFG2]TYPQTY(nolign-1) <> 0
            [M:MFMW]XTYPQTY  = mess([M:MFG2]TYPQTY(nolign-1), 2311, 1)
        Else
            Raz [M:MFMW]XTYPQTY
        Endif
    Endif
    If dim([M:MFMW]XTYPQTY2) > 0
        If [M:MFG2]TYPQTY2(nolign-1) <> 0
            [M:MFMW]XTYPQTY2 = mess([M:MFG2]TYPQTY2(nolign-1), 2311, 1)
        Else
            Raz [M:MFMW]XTYPQTY2
        Endif
    Endif
Endif
If dim([M:MFMW]RETQTY2) > 0 : Diszo [M:MFMW]RETQTY2 : Endif
If dim([M:MFMW]XTYPQTY2) > 0 : Diszo [M:MFMW]XTYPQTY2 : Endif

# Issue 111417 - 2015-10-02 by CCC
Call ECCAFF([M:MFMW]ITMREF, "MFMW") From SUBMFGECC

# Issue 110957 - 2015-09-17 by CCC
If dim([M:MFMW]CRID)>0
    If [F:MTS]CRAFF=1
        Diszo [M:MFMW]CRID
        If dim([M:MFMW]CRFLG)>0
            [M:MFMW]CRFLG = string$([M:MFMW]CRID<>"","151")
        Endif
    Else
        Chgfmt [M:MFMW]CRID With "-K:1X"
        If dim([M:MFMW]CRFLG)>0
            Chgfmt [M:MFMW]CRFLG With "-K:1X"
        Endif
    Endif
Endif

Affzo [M:MFMW]
Return

#-------------------------------------------------
$SETBOUT_MFMFICH
ETABOU(GVALI)=1
ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
ETABOU(GSPE1)=0

Case WNEW
    When 1  :        If [M:MFMW]CPNTYP = 5
                        ETABOU(GSPE1)=0
                     Endif
    When 0,2:        If [M:MFG2]ALLSTA(WLIG) > 1
                        ETABOU(GSPE1)=0
                     Else
                        If find([M:MFG1]WORTYP,2,4)
                            ETABOU(GSPE1)=1
                        Else
                            ETABOU(GSPE1)=0
                        Endif
                     Endif
                     If [M:MFMW]CPNTYP = 5
                        ETABOU(GSPE1)=0
                     Endif
Endcase
If GCONSLCT = 1
    ETABOU(GSPE1) = 0
    Diszo [M:MFMW]
Endif
Return

#-------------------------------------------------
$BOUT_MFMFICH
Case BOUT
    When "1":    # remplacer
                 Read [ITM]ITM0=[M:MFMW]ITMREF
                 If !fstat
                     # récupération article remplacant par défaut
                     If [F:ITM]RPLITM <> ""
                         [M:MFMW]ITMREF = [F:ITM]RPLITM
                         Read [ITM]ITM0=[M:MFMW]ITMREF
                         If !fstat : Call AM_ITMREF([M:MFMW]ITMREF) From SUBMFG2 : Endif
                     Endif
                 Endif
                 GMODMAT=2
                 Actzo [M:MFMW]ITMREF
                 Actzo [M:MFMW]ITMDES1
                 MMODIF = 1
Endcase
Return

#-------------------------------------------------
$OK_MFMFICH
nolign = WLIG + 1

# GH 19/06/13 bug 90478 Chgt d'article => recalcul de la qté dispo de la ligne composant de l'OF
If [M:MFG2]ITMREF(WLIG)<>[M:MFMW]ITMREF
   If [F:ITF]STOMGTCOD=2
      Local Decimal WDIS
      Local Integer WRET
      #--- Issue 115110 & 120426 : Added LECCVAL parameter in 10th position
      #Call STODISALL([M:MFG0]MFGFCY,[M:MFMW]ITMREF,10,1,2,1,2,"","",WDIS,WRET) From STKALL
      Call STODISALL([M:MFG0]MFGFCY,[M:MFMW]ITMREF,func TRTX3FNC.VALFLD_C("[M:MFMW]ECCVALMAJ"),WDIS) From MFGLIBM
      [M:MFG2]AVAQTY(WLIG) = WDIS
   Else
      [M:MFG2]AVAQTY(WLIG) = 0
   Endif
Endif

Case WNEW
    When 0,2,3,4,5: [M:MFG2] = [M:MFMW]
                    If GMODMAT = 2 : [M:MFG2]WIPNUM(WLIG) = "" : Endif
                    Boxclr [MFMW]
                    Affzo [M:MFG2]10
                    If MMODIF = 1 :
                        # 107513 : to do before setting mkstat=4
                        Call HIGHLIGHT("MFG2", WLIG) From ECCLIB
                        mkstat = 4
                    Endif : # pour passer en mode Modif
                    # Issue X3-48941 - 2017-08-25 by JUSYN : Set revision reason and revision code
                    If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
                      If (GMFGREV=2 & [M:MFMW]CPNTYP = 1 & [M:MFMW]REVREASON<>"")
                        [M:MFG2]REVREASON(WLIG) = [M:MFMW]REVREASON
                        [M:MFG2]REVCOD(WLIG)    = 2  # = Modify
                      Endif
                    Endif # Issue X3-55832

    When 1        : [M:MFG2]CPNTYP(WLIG)    = [M:MFMW]CPNTYP
                    [M:MFG2]ITMREF(WLIG)    = [M:MFMW]ITMREF
                    # Issue 119212 GH 28/10/2016 - if screen field not exists, dim(screen field) returns -1
                    #If dim([M:MFMW]ECCVALMAJ)    # 107513
                    If dim([M:MFMW]ECCVALMAJ)>0
                        [M:MFG2]ECCVALMAJ(WLIG)    = [M:MFMW]ECCVALMAJ
                        [M:MFG2]ECCVALMIN(WLIG)    = [M:MFMW]ECCVALMIN
                        [M:MFG2]ECCERRCOD(WLIG)    = [M:MFMW]ECCERRCOD
                        [M:MFG2]ECCERRMSG(WLIG)    = [M:MFMW]ECCERRMSG
                    Endif
                    # Issue 110957 - 2015-09-30 by CCC : add CRID
                    #If dim([M:MFMW]CRID) : [M:MFG2]CRID(WLIG) = [M:MFMW]CRID : Endif
                    #If dim([M:MFMW]CRFLG) : [M:MFG2]CRFLG(WLIG) = [M:MFMW]CRFLG : Endif
                    # Issue 119212 GH 28/10/2016 - if screen field not exists, dim(screen field) returns -1
                    If dim([M:MFMW]CRID)>0 : [M:MFG2]CRID(WLIG) = [M:MFMW]CRID : Endif
                    If dim([M:MFMW]CRFLG)>0 : [M:MFG2]CRFLG(WLIG) = [M:MFMW]CRFLG : Endif
                    [M:MFG2]ITMDES1(WLIG)   = [M:MFMW]ITMDES1
                    [M:MFG2]MFGLIN(WLIG)    = [M:MFMW]MFGLIN
                    [M:MFG2]MFGLINK(WLIG)   = [M:MFMW]MFGLINK
                    [M:MFG2]QTYCOD(WLIG)    = [M:MFMW]QTYCOD
                    [M:MFG2]CUMFLG(WLIG)    = 1
                    [M:MFG2]CUMFXDQTY(WLIG) = [M:MFMW]CUMFXDQTY
                    [M:MFG2]BASQTY(WLIG)    = [M:MFMW]BASQTY
                    [M:MFG2]BOMOPE(WLIG)    = [M:MFMW]BOMOPE
                    [M:MFG2]BOMOFS(WLIG)    = [M:MFMW]BOMOFS
                    [M:MFG2]STU(WLIG)       = [M:MFMW]STU
                    If dim([M:MFMW]BOMUOM)>0
                        [M:MFG2]BOMUOM(WLIG)    = [M:MFMW]BOMUOM
                        [M:MFG2]BOMSTUCOE(WLIG) = [M:MFMW]BOMSTUCOE
                        [M:MFG2]BOMQTY(WLIG)    = [M:MFMW]BOMQTY
                    Endif
                    [M:MFG2]LIKQTY(WLIG)    = [M:MFMW]LIKQTY
                    [M:MFG2]LIKQTYCOD(WLIG) = [M:MFMW]LIKQTYCOD
                    [M:MFG2]QTYRND(WLIG)    = [M:MFMW]QTYRND
                    [M:MFG2]SCA(WLIG)       = [M:MFMW]SCA
                    [M:MFG2]BOMSHO(WLIG)    = [M:MFMW]BOMSHO
                    [M:MFG2]PICPRN(WLIG)    = [M:MFMW]PICPRN
                    [M:MFG2]RETQTY(WLIG)    = [M:MFMW]RETQTY
                    [M:MFG2]RETDAT(WLIG)    = [M:MFMW]RETDAT
                    [M:MFG2]USEQTY(WLIG)    = 0
                    [M:MFG2]ALLQTY(WLIG)    = 0
                    [M:MFG2]ALLSTA(WLIG)    = 1
                    [M:MFG2]SHTQTY(WLIG)    = 0
#                    [M:MFG2]AVAQTY(WLIG)    = 0 : # GH 19/06/13 bug 90478
                    [M:MFG2]BOMSEQ(WLIG)    = 0
#                    [M:MFG2]CSTFLG(WLIG)    = [M:MFMW]CSTFLG
                    [M:MFG2]STOMGTCOD(WLIG) = [M:MFMW]STOMGTCOD
                    [M:MFG2]PLANNER(WLIG)   = [F:ITF]PLANNER
                    [M:MFG2]SCOFLG(WLIG)    = [M:MFMW]SCOFLG
                    [M:MFG2]LOC(WLIG)       = [M:MFMW]LOC
                    [M:MFG2]RELSCATIA(WLIG) = [M:MFMW]RELSCATIA        # 47579 mm 09.09
                    If dim([M:MFMW]PKC)>0        # 47226 mm 05.08
                        [M:MFG2]PKC(WLIG)       = [M:MFMW]PKC    # 43424 mm 01.08
                    Endif
                    If [M:MFMW]STOMGTCOD = 3
                        If dim([M:MFMW]DEFPOT) > 0
                            If [M:MFMW]DEFPOT <> 0
                                [M:MFG2]DEFPOT(WLIG) = [M:MFMW]DEFPOT
                                [M:MFG2]TYPQTY(WLIG) = 1
                                [M:MFG2]RETQTY2(WLIG) = [M:MFMW]RETQTY2
                                [M:MFG2]TYPQTY2(WLIG) = 2
                            Else
                                [M:MFG2]TYPQTY(WLIG) = 2
                            Endif
                        Endif
                    Else
                        If dim([M:MFG2]TYPQTY(WLIG)) > 0 : [M:MFG2]TYPQTY(WLIG) = 2 : Endif
                    Endif
                    If [M:MFG1]NBLIG = 1
                        [M:MFG2]PJT(WLIG) = [M:MFG1]PJT(0)
                    Else
                        If [M:MFG2]MFGLIN(WLIG) = 0
                            LITM = [M:MFG1]PJT(0)
                        Else
                            For I = 0 To [M:MFG1]NBLIG-1
                                If [M:MFG1]MFGLIN(I) = [M:MFG2]MFGLIN(WLIG)
                                    [M:MFG2]PJT(WLIG) = [M:MFG1]PJT(I)
                                    Break
                                Endif
                            Next I
                        Endif
                    Endif

                    [M:MFG2]PTOCOD(WLIG) = func ITMLIB.GET_PTOCOD([M:MFG2]ITMREF(WLIG),[M:MFG0]MFGFCY) : # GH 09/01/2015 bug 105215
                    # Issue X3-25054 - set revision reason
                    # Issue X3-48941 - check audit parameter
                    If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
                      If (GMFGREV=2 & [M:MFMW]CPNTYP = 1 & [M:MFMW]REVREASON<>"")
                        [M:MFG2]REVREASON(WLIG) = [M:MFMW]REVREASON
                        [M:MFG2]REVCOD(WLIG)    = 1  # = Add
                      Endif
                    Endif  # Issue X3-55832

                    #If [F:ITF]PTOCOD <> ""
                    #   [M:MFG2]PTOCOD(WLIG) = [F:ITF]PTOCOD
                    #Else
                    #   Call PARAM([M:MFG0]MFGFCY,"DEFPTO",[M:MFG2]PTOCOD(WLIG)) From ADOVAL : #  GDEFPTO : # GH 20/11/13 bug 94608
                    #Endif

                    # chargement des sections analytiques
                    SLIG = nolign
                    nolign = WLIG + 1
                    For J = 1 To GNBDIE
                        Call INISEC(WCCE,"MFM",J) From TRTX3CPT
                        Assign "[M:MFG2]CCE"+num$(J)+"("+num$(WLIG)+")" With WCCE
                    Next
                    nolign = SLIG
                    [M:MFG2]MATSTA(WLIG)    = 1
                    [M:MFG2]XMATSTA(WLIG) = mess([M:MFG2]MATSTA(WLIG),363,1)
                    [M:MFG2]NBLIG     += 1
                    [M:MFG1]DMATNBR   += 1
                    Boxclr [MFMW]
                    Affzo [M:MFG2]
                    MMODIF = 1
                    # 107513 : to do before setting mkstat=4
                    Call HIGHLIGHT("MFG2", WLIG) From ECCLIB
                    mkstat = 4
Endcase

Return

#-------------------------------------------------
$FIN_MFMFICH
Return

################################################################################
# MFOFICH : Gestion en fiche d'une ligne opération OF                          #
################################################################################
$OUV_MFOFICH
Local    Integer    WLIG   : WLIG = val(PARAM(1))
Local    Integer    WNEW
Local    Integer    WOK, I
Local    Integer    WOPE
Local    Integer    WK
Local    Integer    WREP
Local    Char       WWST (GLONWST)
Local    Integer    WSTR
Local    Integer    WRET
Local    Integer    SLIG, J
Local    Char       WCCE(20)
Local    Integer    WSTAT : WSTAT = 0

# si ajout
If [M:MFG3]OPENUM(WLIG) = 0
    # OF jalonné ?
    Call TST_JAL(WRET) From MFGLIBO
    If WRET = 1 : FIN = 1 : Return : Endif
Endif

# Issue X3-6312 - 2017-09-08 by JUSYN : Message for critical change
# Issue X3-55362 - 2017-09-18 by JUSYN : only if activity code "RVM" set; check for routing version
If dim([M:MFG1]ROUECCMAJ) > 0
    If !GREVMESSC & [M:MFG1]ROUECCMAJ <> "" & GOPECRICHG
        # X3-57646 Check for existing operation that still can be changed or for additional unexpected operation
        If ([M:MFG3]OPENUM(WLIG) > 0 & [M:MFG3]OPESTA(WLIG) < 5 & GBOUT1 = mess(99,195,1)) | (GBOUT1 = mess(244,198,1))
            GREVMESSC = 1
            GERR = 2
            GMESSAGE = mess(401,193,1) # You are about to make critical changes to a work order for a versioned product
        Endif
    Endif
Endif
# Issue X3-6312 - 2017-09-08 by JUSYN - End
Return

#-------------------------------------------------
$DEB_MFOFICH
OMODIF = 0
GMODOPE = 0
WNEW   = 0
WOPE   = 0
WCAP = 0

## 12.03 MM : Multi-emplacement,la notion de tiers remplace celle de fournisseur.
GBPCNUM=[M:MFG3]BPRNUM(WLIG)

If [M:MFG3]OPENUM(WLIG) = 0                            # si ajout opération non prévue
    WNEW = 1
Else
    If [M:MFG3]ROUOPENUM(WLIG) = 0 : WNEW = 2 : Endif     # si modif opération non prévue
    If [M:MFG3]OPESTA(WLIG)    > 4 : WNEW = 3 : Endif     # si opération soldée
    If [M:MFG3]OPESTA(WLIG)    = 4 : WNEW = 4 : Endif     # si opération en, cours
Endif
If [M:MFG1]MFGTRKFLG = 2 : WNEW = 3 : Endif

nolign = WLIG + 1
Case WNEW
    When 0,4: # visu en fiche d'une opération existante
              GMODOPE     = 1
              Raz [MFO0] : Raz [MFO1] : Raz [MFO2] : Raz [MFO3]
              [M:MFO0]       = [M:MFG3]
              [M:MFO1]       = [M:MFG3]
              [M:MFO2]       = [M:MFG3]
              [M:MFO3]       = [M:MFG3]
              [M:MFO0]MFGFCY = [M:MFG0]MFGFCY
    When 1:   # ajout nouvelle opération
              Raz [MFO0] : Raz [MFO1] : Raz [MFO2] : Raz [MFO3]
              [M:MFO0]OPESTA    = 1
              [M:MFO1]JOUR1     = 1
              [M:MFO0]MFGFCY    = [M:MFG0]MFGFCY
              [M:MFO1]OPEUOM    = [M:MFG1]MFGSTU
              [M:MFO1]EXTQTY    = [M:MFG1]MFGEXTQTY
              [M:MFO1]OPESTUCOE = 1
              [M:MFO2]SCOCOD    = 1
              If [M:MFG3]NBLIG = 0
                  [M:MFO1]TIMUOMCOD  = 1
                  [M:MFO0]TIMUOMCOD  = 1
                  [M:MFO1]XTIMUOMCOD = 1
              Else
                  [M:MFO1]TIMUOMCOD  = [M:MFG3]TIMUOMCOD(0)
                  [M:MFO0]TIMUOMCOD  = [M:MFG3]TIMUOMCOD(0)
                  [M:MFO1]XTIMUOMCOD = [M:MFG3]TIMUOMCOD(0)
              Endif
              [M:MFO1]OPESTR    = [M:MFG1]STRDAT
              [M:MFO1]OPEEND    = [M:MFG1]ENDDAT
    When 2:   # accès en fiche d'une opération non prévue existante
              GMODOPE     = 1
              Raz [MFO0] : Raz [MFO1] : Raz [MFO2] : Raz [MFO3]
              [M:MFO0]          = [M:MFG3]
              [M:MFO1]          = [M:MFG3]
              [M:MFO2]          = [M:MFG3]
              [M:MFO3]          = [M:MFG3]
              [M:MFO0]MFGFCY    = [M:MFG0]MFGFCY
    When 3:   # accès en fiche d'une opération exclue (visu uniquement)
              GMODOPE     = 1
              Raz [MFO0] : Raz [MFO1] : Raz [MFO2] : Raz [MFO3]
              [M:MFO0]          = [M:MFG3]
              [M:MFO1]          = [M:MFG3]
              [M:MFO2]          = [M:MFG3]
              [M:MFO3]          = [M:MFG3]
              [M:MFO0]MFGFCY    = [M:MFG0]MFGFCY
Endcase
[M:MFO0]XOPESTA = mess([M:MFO0]OPESTA,308,1)

# gestion des grisages
Case WNEW
    When 0:    Diszo [M:MFO0]5
               Diszo [M:MFO1]20
               Actzo [M:MFO1]CAD
    When 2:    Diszo [M:MFO0]5
    When 3:    Diszo [M:MFO0]5
               Diszo [M:MFO1]15
               Diszo [M:MFO1]20
               Diszo [M:MFO1]25
               Diszo [M:MFO1]30
               Diszo [M:MFO1]35
               Diszo [M:MFO1]40
               Diszo [M:MFO1]45
               Diszo [M:MFO2]15
               Diszo [M:MFO2]20
               Diszo [M:MFO2]25
               Diszo [M:MFO3]15
               Diszo [M:MFO3]20
    When 4:    Diszo [M:MFO0]5
               Diszo [M:MFO1]15
               Diszo [M:MFO1]20
               Diszo [M:MFO1]30
               Diszo [M:MFO1]35
               Diszo [M:MFO1]40
               Diszo [M:MFO2]15
               Diszo [M:MFO2]20
               Diszo [M:MFO2]25
               Diszo [M:MFO3]15
               Diszo [M:MFO3]20
Endcase
# 17809 MM 07.05
Grizo [M:MFO1]CTIMCOE,HCTIMCOE
#
Case [M:MFO0]TIMUOMCOD
    When 1: [M:MFO1]TIMUOM1 = mess(30,197,1)
            [M:MFO1]TIMUOM2 = mess(30,197,1)
            [M:MFO1]TIMUOM3 = mess(30,197,1)
            [M:MFO1]TIMUOM8 = mess(30,197,1)
    When 2: [M:MFO1]TIMUOM1 = mess(32,197,1)
            [M:MFO1]TIMUOM2 = mess(32,197,1)
            [M:MFO1]TIMUOM3 = mess(32,197,1)
            [M:MFO1]TIMUOM8 = mess(32,197,1)
Endcase
[M:MFO1]TIMUOM4 = mess(30,197,1)
[M:MFO1]TIMUOM5 = mess(30,197,1)
[M:MFO1]TIMUOM6 = mess(30,197,1)
[M:MFO1]XJOUR1  = mess([M:MFO1]JOUR1,291,1)

If [M:MFO2]SCOCOD = 1 : Grizo [M:MFO2]30 : Else : Actzo [M:MFO2]30 : Endif

Affzo [M:MFO0]1-99
Affzo [M:MFO1]1-99
Affzo [M:MFO2]1-99
Affzo [M:MFO3]1-99
Return

#-------------------------------------------------
$SETBOUT_MFOFICH
ETABOU(GVALI)=1
ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
ETABOU(GSPE1)=0
ETABOU(GSPE2)=0

Case WNEW
     When 0,2:  Case [M:MFO1]WSTTYP
                    When 1,2:    If [M:MFO2]SCOCOD = 3 : ETABOU(GSPE1) = 1 : Else : ETABOU(GSPE1) = 0 : Endif
                                 ETABOU(GSPE2) = 0
                    When 3:      ETABOU(GSPE1) = 0
                                 If [M:MFO2]SCOCOD = 3 : ETABOU(GSPE2) = 1 : Else : ETABOU(GSPE2) = 0 : Endif
                Endcase
    When Default:
Endcase
If find(WNEW,0,2,4) & [M:MFO1]ROUOPENUM = 0 & [M:MFO0]STDOPENUM = 0 : ETABOU(GSPE2) = 0 : Endif

If GCONSLCT=1
    Diszo [M:MFO0]
    Diszo [M:MFO1]
    Diszo [M:MFO2]
    Diszo [M:MFO3]
    ETABOU(GSPE2)=0
Endif
Return

#-------------------------------------------------
$BOUT_MFOFICH
Case BOUT
    When "1":    # sous-traiter
                 Call TST_JAL(WRET) From MFGLIBO
                 If WRET = 1 : FIN = 0 : Return : Endif
                 If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif
                 Call SUB_CONTRACT("MFO", WLIG, WWST) From MFGLIBO
                 OMODIF = 1
    When "2":    # réaliser
                 Call TST_JAL(WRET) From MFGLIBO
                 If WRET = 1 : FIN = 0 : Return : Endif
                 If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif
                 Call ASUB_CONTRACT("MFO", WLIG, WWST) From MFGLIBO
                 OMODIF = 1
Endcase
Affzo [M:MFO1]1-99
Affzo [M:MFO2]1-99
Affzo [M:MFO3]1-99

FIN = 0
Return

#-------------------------------------------------
$OK_MFOFICH
nolign = WLIG + 1
Case WNEW
    When 0,2,3,4:  If [M:MFO1]WSTTYP = 3 & [M:MFG3]WSTTYP(WLIG) <> 3 : WSTR = 1 : Else : WSTR = 0 : Endif
                   If [M:MFO2]SCOITMREF <> [M:MFG3]SCOITMREF(WLIG)   : [M:MFG3]WIPNUM(WLIG) = "" : Endif
                   [M:MFG3]=[M:MFO0] : [M:MFG3]=[M:MFO1]
                   [M:MFG3]=[M:MFO2] : [M:MFG3]=[M:MFO3]
                   # code jalonnement devient "successeur"
                   If WSTR = 1
                       [M:MFG3]SCDCOD(WLIG) = 1
                       [M:MFG3]SCDTIM(WLIG)=0
                       [M:MFG3]SCDQTY(WLIG)=0
                       [M:MFG3]SCDLOT(WLIG)=0
                   Endif
                   Call ANALYSE_OPELOC([M:MFO0]OPENUM, WLIG, [M:MFO1]EXTWST,[M:MFG0]MFGFCY) From MFGLIBO
                   Call ANALYSE_OPESTR("MFO",[M:MFO0]OPENUM, WLIG, [M:MFO1]EXTWST,[M:MFG0]MFGFCY) From MFGLIBO

                   [M:MFG3]XWSTTYP(WLIG)   = format$("K:2X",mess([M:MFO1]WSTTYP,313,1))
                   # relecture poste principal
                   ## GH 28/02/2014 bug 95952
                   #Read [MWS]WST0=[M:MFO1]EXTWST;[M:MFG0]MFGFCY
                   #If !fstat : [M:MFG3]EXTWSTSHO(WLIG) = [F:MWS]WSTSHO : Endif
                   Call LECTEXTRA([M:MFG3]EXTWSTSHO(WLIG),"WORKSTATIO","WSTSHOAXX",[M:MFO1]EXTWST,[M:MFG0]MFGFCY) From ATEXTRA
                   ##

                   # relecture poste STR
                   If [M:MFO2]SCOWST <> ""
                       ## GH 28/02/2014 bug 95952
                       #Read [MWS]WST0=[M:MFO2]SCOWST;[M:MFG0]MFGFCY
                       #If !fstat : [M:MFG3]SCOWCR(WLIG) = [F:MWS]WSTSHO : Endif
                       Call LECTEXTRA([M:MFG3]SCOWCR(WLIG),"WORKSTATIO","WSTSHOAXX",[M:MFO2]SCOWST,[M:MFG0]MFGFCY) From ATEXTRA
                   Else
                       [M:MFG3]SCOWCR(WLIG) = ""
                   Endif

                   # relecture poste MO
                   If [M:MFO1]EXTLAB <> ""
                       ## GH 28/02/2014 bug 95952
                       #Read [MWS]WST0=[M:MFO1]EXTLAB;[M:MFG0]MFGFCY
                       #If !fstat : [M:MFG3]EXTLABSHO(WLIG) = [F:MWS]WSTSHO : Endif
                       Call LECTEXTRA([M:MFG3]EXTLABSHO(WLIG),"WORKSTATIO","WSTSHOAXX",[M:MFO1]EXTLAB,[M:MFG0]MFGFCY) From ATEXTRA
                   Else
                       [M:MFG3]EXTLABSHO(WLIG) = ""
                   Endif

                   # incrémentation nombre d'opérations soldées si nécessaire
                   If OSOLDE = 1
                       [M:MFG1]DOPECLENBR += 1
                       OSOLDE = 0
                   Endif
                   If GMODOPE = 2 : [M:MFG3]OPSNUM(WLIG) = "" : Endif
                   # Issue X3-28791 - 2017-09-04 by JUSYN : Set revision reason and revision code
                   # Issue X3-55362 - 2017-09-18 by JUSYN : only if activity code "RVM" set; check for routing version
                   If dim([M:MFG1]ROUECCMAJ) > 0
                       If (GMFGREV=2 & [M:MFO2]REVREASON <> "")
                           [M:MFG3]REVREASON(WLIG) = [M:MFO2]REVREASON
                           [M:MFG3]REVCOD(WLIG)    = 2  # = Modify
                       Endif
                   Endif
                   # End issue X3-55362
                   # Issue X3-28791 - 2017-09-04 by JUSYN
                   Affzo [M:MFG3]10
                   If OMODIF = 1 : mkstat = 4 : Endif
    When 1    :    If find([M:MFG3]SCDFLG,2,4) : Call MOD_JAL From MFGLIBO : Endif
                   [M:MFG3]OPENUM(WLIG)    = [M:MFO0]OPENUM
                   [M:MFG3]ROUOPENUM(WLIG) = 0
                   [M:MFG3]OPESPLNUM(WLIG) = 0
                   [M:MFG3]STDOPENUM(WLIG) = [M:MFO0]STDOPENUM
                   [M:MFG3]RPLIND(WLIG)    = 0
                   [M:MFG3]OPESTA(WLIG)    = [M:MFO0]OPESTA
                   [M:MFG3]EXTWST(WLIG)    = [M:MFO1]EXTWST
                   [M:MFG3]WCR(WLIG)       = [M:MFO1]WCR
                   [M:MFG3]WSTTYP(WLIG)    = [M:MFO1]WSTTYP
                   [M:MFG3]XWSTTYP(WLIG)   = format$("K:2X",mess([M:MFO1]WSTTYP,313,1))
                   ## GH 28/02/2014 bug 95952
                   #Read [MWS]WST0=[M:MFO1]EXTWST;[M:MFG0]MFGFCY
                   #If !fstat : [M:MFG3]EXTWSTSHO(WLIG) = [F:MWS]WSTSHO : Endif
                   Call LECTEXTRA([M:MFG3]EXTWSTSHO(WLIG),"WORKSTATIO","WSTSHOAXX",[M:MFO1]EXTWST,[M:MFG0]MFGFCY) From ATEXTRA
                   ##
                   [M:MFG3]WSTEFF(WLIG)    = [M:MFO1]WSTEFF
                   [M:MFG3]OPESTR(WLIG)    = [M:MFG1]STRDAT
                   [M:MFG3]OPEEND(WLIG)    = [M:MFG1]ENDDAT
                   [M:MFG3]ROODES(WLIG)    = [M:MFO0]ROODES
                   [M:MFG3]TIMUOMCOD(WLIG) = [M:MFO1]TIMUOMCOD
                   [M:MFG3]EXTSETTIM(WLIG) = [M:MFO1]EXTSETTIM
                   [M:MFG3]EXTUNTTIM(WLIG) = [M:MFO1]EXTUNTTIM
                   [M:MFG3]EXTOPETIM(WLIG) = [M:MFO1]EXTOPETIM
                   [M:MFG3]EXTQTY(WLIG)    = [M:MFO1]EXTQTY
                   [M:MFG3]EXTSTUQTY(WLIG) = [M:MFO1]EXTSTUQTY
                   [M:MFG3]EXTSTRQTY(WLIG) = [M:MFO1]EXTSTRQTY
                   [M:MFG3]OPEUOM(WLIG)    = [M:MFO1]OPEUOM
                   [M:MFG3]SCOCOD(WLIG)    = [M:MFO2]SCOCOD
                   [M:MFG3]SCOWST(WLIG)    = [M:MFO2]SCOWST
                   ## GH 28/02/2014 bug 95952
                   #Read [MWS]WST0=[M:MFO2]SCOWST;[M:MFG0]MFGFCY
                   #If !fstat : [M:MFG3]SCOWCR(WLIG) = [F:MWS]WSTSHO : Endif
                   Call LECTEXTRA([M:MFG3]SCOWCR(WLIG),"WORKSTATIO","WSTSHOAXX",[M:MFO2]SCOWST,[M:MFG0]MFGFCY) From ATEXTRA
                   ##
                   [M:MFG3]SCOITMREF(WLIG) = [M:MFO2]SCOITMREF
                   [M:MFG3]BPRNUM(WLIG)    = [M:MFO2]BPRNUM  # 12.03 MM : multi-emplacement
                   [M:MFG3]BPAADD(WLIG)    = [M:MFO2]BPAADD  # 12.03 MM : multi-emplacement
                   [M:MFG3]REFPRI(WLIG)    = [M:MFO2]REFPRI
                   [M:MFG3]SCOLTI(WLIG)    = [M:MFO1]SCOLTI
                   [M:MFG3]SCOPUU(WLIG)    = [M:MFO1]SCOPUU
                   [M:MFG3]EXTLAB(WLIG)    = [M:MFO1]EXTLAB
                   [M:MFG3]LABWCR(WLIG)    = [M:MFO1]LABWCR
                   ## GH 28/02/2014 bug 95952
                   #Read [MWS]WST0=[M:MFO1]EXTLAB;[M:MFG0]MFGFCY
                   #If !fstat : [M:MFG3]EXTLABSHO(WLIG) = [F:MWS]WSTSHO : Endif
                   Call LECTEXTRA([M:MFG3]EXTLABSHO(WLIG),"WORKSTATIO","WSTSHOAXX",[M:MFO1]EXTLAB,[M:MFG0]MFGFCY) From ATEXTRA
                   ##
                   [M:MFG3]SETLABCOE(WLIG) = [M:MFO1]SETLABCOE
                   [M:MFG3]OPELABCOE(WLIG) = [M:MFO1]OPELABCOE
                   [M:MFG3]OPESTUCOE(WLIG) = [M:MFO1]OPESTUCOE
                   [M:MFG3]OPESTRCOE(WLIG) = [M:MFO2]OPESTRCOE
                   [M:MFG3]ROOTIMCOD(WLIG) = [M:MFO1]ROOTIMCOD
                   [M:MFG3]TIMCOD(WLIG)    = [M:MFO1]TIMCOD
                   [M:MFG3]BASQTY(WLIG)    = [M:MFO1]BASQTY
                   [M:MFG3]CAD(WLIG)       = [M:MFO1]CAD
                   [M:MFG3]EFF(WLIG)       = [M:MFO1]EFF
                   [M:MFG3]WAITIM(WLIG)    = [M:MFO1]WAITIM
                   [M:MFG3]PSPTIM(WLIG)    = [M:MFO1]PSPTIM
                   [M:MFG3]EXTWSTNBR(WLIG) = [M:MFO1]EXTWSTNBR
                   [M:MFG3]EXTLABNBR(WLIG) = [M:MFO1]EXTLABNBR
                   [M:MFG3]PRPTIM(WLIG)    = [M:MFO1]PRPTIM
                   [M:MFG3]OPEROUPCT(WLIG) = [M:MFO2]OPEROUPCT
                   [M:MFG3]OPEPLNNUM(WLIG) = [M:MFO2]OPEPLNNUM
                   [M:MFG3]TECCRD(WLIG)    = [M:MFO2]TECCRD
                   [M:MFG3]EQUNUM(WLIG)    = [M:MFO2]EQUNUM
                   [M:MFG3]FXGNUM(WLIG)    = [M:MFO2]FXGNUM
                   [M:MFG3]PRGNUM(WLIG)    = [M:MFO2]PRGNUM
                   [M:MFG3]SHR(WLIG)       = [M:MFO1]SHR
                   [M:MFG3]MFOTEX(WLIG)    = [M:MFO0]MFOTEX    # 40323 mm 03.07
                    # données capacité finie
                   If dim([M:MFG3]OPENUMLEV(WLIG)) > 0 : [M:MFG3]OPENUMLEV(WLIG) = [M:MFO3]OPENUMLEV : Endif
                   If dim([M:MFG3]ALTOPECOD(WLIG)) > 0 : [M:MFG3]ALTOPECOD(WLIG) = [M:MFO3]ALTOPECOD : Endif
                   If dim([M:MFG3]SPLCOD(WLIG))    > 0 : [M:MFG3]SPLCOD(WLIG)    = [M:MFO3]SPLCOD    : Endif
                   If dim([M:MFG3]SPLMAXNBR(WLIG)) > 0 : [M:MFG3]SPLMAXNBR(WLIG) = [M:MFO3]SPLMAXNBR : Endif
                   If dim([M:MFG3]RSTMAC(WLIG))    > 0 : [M:MFG3]RSTMAC(WLIG)    = [M:MFO3]RSTMAC    : Endif
                   If dim([M:MFG3]SCHGRP(WLIG))    > 0 : [M:MFG3]SCHGRP(WLIG)    = [M:MFO3]SCHGRP    : Endif
                   # 08.05 distinction des exemplaires
                   If dim([M:MFG3]SCHSBB(WLIG))    > 0 : [M:MFG3]SCHSBB(WLIG)    = [M:MFO3]SCHSBB    : Endif
                   If dim([M:MFG3]GRPSETTIM(WLIG)) > 0 : [M:MFG3]GRPSETTIM(WLIG) = [M:MFO3]GRPSETTIM : Endif
                   [M:MFG3]MFOTRKFLG(WLIG) = 1
                   [M:MFG3]ITMLINNBR(WLIG) = [M:MFG1]NBLIG
                   [M:MFG3]FXDTIM(WLIG)    = [M:MFO1]FXDTIM
                   [M:MFG3]VARTIM(WLIG)    = [M:MFO1]VARTIM
                   [M:MFG3]NBLIG          += 1
                   [M:MFG1]DOPENBR        += 1
                   # Issue X3-6312 - 2017-09-08 by JUSYN : Revreason and Revcod for main screen
                   # Issue X3-55362 - 2017-09-18 by JUSYN : only if activity code "RVM" set; check for routing version
                   If dim([M:MFG1]ROUECCMAJ) > 0
                      If (GMFGREV=2 & [M:MFO2]REVREASON<>"")
                          [M:MFG3]REVREASON(WLIG) = [M:MFO2]REVREASON
                          [M:MFG3]REVCOD(WLIG)    = 1  # = Add
                      Endif
                   Endif
                   # End issue X3-55362
                   # Issue X3-6312 - 2017-09-08 by JUSYN End
                   # chargement des sections analytiques (machine et m-o)
                   SLIG = nolign
                   nolign = WLIG + 1 : # pour que le parametrage section par défaut marche
                   If [F:MWS]WST <> [M:MFG3]EXTWST(WLIG)
                       Read [MWS]WST0=[M:MFG3]EXTWST(WLIG);[M:MFG0]MFGFCY
                   Endif
                   For J = 1 To GNBDIE
                       Call INISEC(WCCE,"MFO",J) From TRTX3CPT
                       Assign "[M:MFG3]CCE"+num$(J)+"("+num$(WLIG)+")" With WCCE
                   Next
                   If [M:MFG3]EXTLAB(WLIG) <> ""
                       Read [MWS]WST0=[M:MFG3]EXTLAB(WLIG);[M:MFG0]MFGFCY
                       If !fstat
                           For J = 1 To GNBDIE
                                Call INISEC(WCCE,"MFO",J) From TRTX3CPT
                                Assign "[M:MFG3]LABCCE"+num$(J)+"("+num$(WLIG)+")" With WCCE
                            Next
                       Endif
                   Endif
                   nolign = SLIG

                   WOPE = [M:MFO0]OPENUM
                   Sorta [M:MFG3]NBLIG [M:MFG3]NBLIG Order By [M:MFG3]OPENUM(indice),
&                        [M:MFG3]OPESPLNUM(indice)
                   Affzo [M:MFG3]10
                   mkstat = 4
Endcase
If WNEW = 1 & WOPE <> 0 : WSTAT = 4 : Endif
If WSTAT = 4
    Call ANALYSE_OPELOC([M:MFG3]OPENUM(WLIG), WLIG, [M:MFG3]EXTWST(WLIG),[M:MFG0]MFGFCY) From MFGLIBO
    Call ANALYSE_OPESTR("MFG3", [M:MFG3]OPENUM(WLIG), WLIG, [M:MFG3]EXTWST(WLIG),[M:MFG0]MFGFCY) From MFGLIBO
Endif
If WNEW <> 1 : Return : Endif
Call CAL_JAL_SUG(1, WOPE) From MFGSCD
Call RESEQ_JAL From MFGSCD
# FQ 70653 GA 04/2011 ajout PE
# mettre GPE=0 pour court-circuiter le message standard
GPE=1: GPOINT ="DELMESS" : Gosub ENTREE From EXEFNC
If GPE<>0
   Call MESSAGE(mess(29,190,1)) From GESECRAN
Endif
mkstat = WSTAT
Return

#-------------------------------------------------
$FIN_MFOFICH
Return

################################################################################
# MFIFICH  : visu en mode fiche  d'une ligne article produit                   #
################################################################################
$OUV_MFIFICH
Local Integer WLIG     : WLIG   = val(PARAM(1))
Return

#-------------------------------------------------
$DEB_MFIFICH
nolign = WLIG + 1
[M:MFIW] = [M:MFG1]

# Issue 110957 - 2015-09-17 by CCC
If dim([M:MFIW]CRID)>0 & [F:MTS]CRAFF<>1
    Chgfmt [M:MFIW]CRID With "-K:1X"
Endif

Return

################################################################################
# MFIFICHMTK  : visu en mode fiche  d'une ligne article produit depuis le suivi#
################################################################################
$OUV_MFIFICHMTK
Local Integer WLIG            : WLIG    = val(PARAM(1))
Local Char    WMFGNUM(GLONVCR): WMFGNUM = PARAM(2)
Local Integer WMFGLIN         : WMFGLIN = val(PARAM(3))
# CCC (2009-10-27) Bug 59210 : Déclaration de GMODMAT, utilisée dans les actions d'avant saisie
If dim([V]GMODMAT)<=0 : Global Integer  GMODMAT : Endif
GMODMAT = 1
Return

#-------------------------------------------------
$DEB_MFIFICHMTK
Read [F:MFI]MFI0 =WMFGNUM;WMFGLIN
If fstat : Return : Endif
[M:MFIW] = [F:MFI]
If [F:ITM]ITMREF <> [M:MFIW]ITMREF
   Read [F:ITM]ITM0 = [M:MFIW]ITMREF
   If fstat : Raz [F:ITM] : Endif
Endif
#[M:MFIW]ITMDES1 = [F:ITM]ITMDES1
#LECTURE du libellé traduisible
#Call LECTEXTRA([M:MFIW]ITMDES1,"ITMMASTER","DES1AXX",[F:ITM]ITMREF,"") From ATEXTRA
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFIW]ITMDES1, "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296

If clalev([F:TBO]) <= 0 : Local File TABBOMALT [TBO] : Endif
Read [F:TBO]TBO0 = 2;[M:MFIW]BOMALT
# FGR 16/09/2009 : X3SUIVI57824 + 58644
If fstat
  Raz [F:TBO]
  [M:MFIW]TBOSHO = ""
Else
  #[M:MFIW]TBOSHO = [F:TBO]TBOSHO
  Call LECTEXTRA([M:MFIW]TBOSHO,"TABBOMALT","TBOSHOAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
Endif

Case [M:MFIW]BPCTYPDEN
     When 1 : Local File FACILITY [XCY]
              Read [F:XCY]FCY0 = [M:MFIW]BPCNUM
              If fstat : Raz [F:XCY] : Endif
              [M:MFIW]BPCDES = [F:XCY]FCYSHO
              Close Local File [XCY]
     When Default
              Local File BPARTNER [BPR]
              Read [F:BPR]BPR0 = [M:MFIW]BPCNUM
              If fstat : Raz [F:BPR] : Endif
              [M:MFIW]BPCDES = [F:BPR]BPRSHO
              Close Local File [F:BPR]
Endcase

# Issue 110957 - 2015-09-17 by CCC
If dim([M:MFIW]CRID)>0
    Chgfmt [M:MFIW]CRID With "-K:1X"
Endif

Diszo [M:MFIW]
Return

################################################################################
# MFITRKSTA : Etat du suivi d'une ligne article produit                        #
################################################################################
$OUV_MFITRKSTA
Local Integer WLIG     : WLIG   = val(PARAM(1))
Local Char    WABREV   : WABREV = PARAM(2)
Local Integer NEWLINE : NEWLINE=0

If clalev ([F:MFG]) <= 0 Local File MFGHEAD [MFG] : Endif
If clalev ([F:MFI]) <= 0 Local File MFGITM  [MFI] : Endif

Return

#-------------------------------------------------
$DEB_MFITRKSTA
Raz [M:MFIQ]
Case WABREV :
    When "MFG1":
            Read [MFI]MFI0=[M:MFG0]MFGNUM;[M:MFG1]MFGLIN(WLIG)
            If fstat : NEWLINE=1 : Endif
            [M:MFIQ]STU       = [M:MFG1]STU(WLIG)
            [M:MFIQ]EXTQTY    = [M:MFG1]EXTQTY(WLIG)
            [M:MFIQ]TOTCPLQTY = [M:MFG1]CPLQTY(WLIG)
            [M:MFIQ]RMNEXTQTY = [M:MFG1]EXTQTY(WLIG) - [M:MFG1]CPLQTY(WLIG)
    When "MTK2":
            Read [MFG]MFG0=[M:MTK2]MFGNUMIT(WLIG)
            If fstat
                NEWLINE=1
            Else
                Read [MFI]MFI0=[M:MTK2]MFGNUMIT(WLIG);[M:MTK2]MFGLIN(WLIG)
            Endif
            [M:MFIQ]STU       = [M:MTK2]STU(WLIG)
            [M:MFIQ]EXTQTY    = [M:MTK2]MFIEXTQTY(WLIG)
    When "MBI" :
            Read [MFG]MFG0=[M:MBI]MFGNUM(WLIG)
            If fstat
                NEWLINE=1
            Else
                Read [MFI]MFI0=[M:MBI]MFGNUM(WLIG);[M:MBI]MFGLIN(WLIG)
            Endif
            [M:MFIQ]STU       = [M:MBI]STU(WLIG)
            [M:MFIQ]EXTQTY    = [M:MBI]MFIEXTQTY(WLIG)
Endcase
If NEWLINE = 0
    [M:MFIQ]CPLQTY      = [F:MFI]CPLQTY - [F:MFI]REJCPLQTY - [F:MFI]QUACPLQTY
    [M:MFIQ]REJCPLQTY   = [F:MFI]REJCPLQTY
    [M:MFIQ]QUACPLQTY   = [F:MFI]QUACPLQTY
    [M:MFIQ]RMNEXTQTY   = [F:MFI]RMNEXTQTY
Else
    [M:MFIQ]CPLQTY      = 0
    [M:MFIQ]REJCPLQTY   = 0
    [M:MFIQ]QUACPLQTY   = 0
    [M:MFIQ]RMNEXTQTY   = [M:MFIQ]EXTQTY
Endif
[M:MFIQ]TOTCPLQTY   = [F:MFI]CPLQTY
Return

################################################################################
# MFOTRKSTA : Etat du suivi d'une ligne opération                              #
################################################################################
$OUV_MFOTRKSTA
Local Integer WLIG     : WLIG     = val(PARAM(1))
Local Char    WABMSK   : WABMSK   = PARAM(2)
Return

#-------------------------------------------------
$DEB_MFOTRKSTA
nolign = WLIG + 1
Raz [M:MTKX]
Case WABMSK :
    When "MTK1" : [M:MTKX] = [M:MTK1]
                  [M:MTKX]OPEUOM = [M:MTK1]XOPEUOM(WLIG)
    When "MBO"  : [M:MTKX] = [M:MBO]
                  [M:MTKX]OPEUOM = [M:MBO]XOPEUOM(WLIG)
    When "MFG3" : [M:MTKX] = [M:MFG3]
                  [M:MTKX]MFOEXTQTY  = [M:MFG3]EXTQTY(WLIG)
                  [M:MTKX]MFOCPLQTY  = [M:MFG3]CPLQTY(WLIG)
                  [M:MTKX]MFOREJQTY  = [M:MFG3]REJCPLQTY(WLIG)
                  [M:MTKX]MFOOKQTY   = [M:MFG3]CPLQTY(WLIG) - [M:MFG3]REJCPLQTY(WLIG) - [M:MFG3]QUACPLQTY(WLIG)
                  [M:MTKX]MFOCQQTY   = [M:MFG3]QUACPLQTY(WLIG)
                  [M:MTKX]TIMUOMCOD  = [M:MFG3]TIMUOMCOD(WLIG)
                  [M:MTKX]MFOESETTIM = [M:MFG3]EXTSETTIM(WLIG)
                  [M:MTKX]MFOCSETTIM = [M:MFG3]CPLSETTIM(WLIG)
                  [M:MTKX]MFOEOPETIM = [M:MFG3]EXTOPETIM(WLIG)
                  [M:MTKX]MFOCOPETIM = [M:MFG3]CPLOPETIM(WLIG)
Endcase
Return

################################################################################
# MFOTRKSTAB : Etat du suivi d'une ligne opération de sous-traitance           #
################################################################################
$OUV_MFOTRKSTAB
Local Integer WLIG     : WLIG   = val(PARAM(1))
Local Char    WABMSK   : WABMSK   = PARAM(2)
Return

#-------------------------------------------------
$SETBOUT_MFOTRKSTAB
If [M:MTKW]MFOPOHNUM = "" : ETABOU(GSPE1)=0  : Else : ETABOU(GSPE1) = 1 : Endif
Return

#-------------------------------------------------
$DEB_MFOTRKSTAB
If clalev([F:BPR]) <= 0 : Local File BPARTNER [BPR] : Endif
Raz [M:MTKW]
nolign = WLIG + 1
Case WABMSK
    When "MTK1" : [M:MTKW] = [M:MTK1]
                  [M:MTKW]OPEUOM = [M:MTK1]XOPEUOM(WLIG)
                  [M:MTKW]MFOOPESTA = [M:MTK1]MFOTRKFLG(WLIG)
                  [M:MTKW]MFOBPSNUM = [M:MTK1]BPSNUM(WLIG)
                  If [M:MTKW]MFOBPSNUM <> ""
                      Read [BPR]BPR0=[M:MTKW]MFOBPSNUM
                      If !fstat
                          [M:MTKW]MFOBPSNAM = [F:BPR]BPRNAM
                      Else
                          [M:MTKW]MFOBPSNAM = ""
                      Endif
                  Else
                      [M:MTKW]MFOBPSNAM = ""
                  Endif
                  [M:MTKW]MFOPOHNUM = [M:MTK1]POHNUM(WLIG)
                  [M:MTKW]MFOPOPLIN = [M:MTK1]POPLIN(WLIG)
                  [M:MTKW]MFOPOPSEQ = [M:MTK1]POPSEQ(WLIG)
    When "MFG3":  [M:MTKW] = [M:MFG3]
                  [M:MTKW]MFOOPESTA  = [M:MFG3]OPESTA(WLIG)
                  [M:MTKW]MFOEXTQTY  = [M:MFG3]EXTQTY(WLIG)
                  [M:MTKW]MFOCPLQTY  = [M:MFG3]CPLQTY(WLIG)
                  [M:MTKW]MFOREJQTY  = [M:MFG3]REJCPLQTY(WLIG)
                  [M:MTKW]MFOOKQTY   = [M:MFG3]CPLQTY(WLIG) - [M:MFG3]REJCPLQTY(WLIG) - [M:MFG3]QUACPLQTY(WLIG)
                  [M:MTKW]TIMUOMCOD  = [M:MFG3]TIMUOMCOD(WLIG)
                  [M:MTKW]MFOESETTIM = [M:MFG3]EXTSETTIM(WLIG)
                  [M:MTKW]MFOCSETTIM = [M:MFG3]CPLSETTIM(WLIG)
                  [M:MTKW]MFOEOPETIM = [M:MFG3]EXTOPETIM(WLIG)
                  [M:MTKW]MFOCOPETIM = [M:MFG3]CPLOPETIM(WLIG)
                  [M:MTKW]MFOBPSNUM  = [M:MFG3]BPRNUM(WLIG)     # 12.03 : multi-emplacement
                  If [M:MTKW]MFOBPSNUM <> ""
                      Read [BPR]BPR0=[M:MTKW]MFOBPSNUM
                      If !fstat
                          [M:MTKW]MFOBPSNAM = [F:BPR]BPRNAM
                      Else
                          [M:MTKW]MFOBPSNAM = ""
                      Endif
                  Else
                      [M:MTKW]MFOBPSNAM = ""
                  Endif
                  [M:MTKW]MFOPOHNUM  = [M:MFG3]POHNUM(WLIG)
                  [M:MTKW]MFOPOPLIN  = [M:MFG3]POPLIN(WLIG)
                  [M:MTKW]MFOPOPSEQ  = [M:MFG3]POPSEQ(WLIG)
Endcase
Return



################################################################################
# MFOTRKFICH : Gestion en fiche d'une ligne suivi opération                    #
################################################################################
$OUV_MFOTRKFICH
Local     Integer    LLIG     : LLIG   = val(PARAM(1))
Local     Integer    LMOD     : LMOD   = val(PARAM(2))
Local Integer J, WOK
Local Char    WGREP(1)        : WGREP = GREP

# X3-80367 - STWIL - Create a global flag so that we do not prompt for every receipt line
If dim (GNCSLINFLG) < 0 Global Integer GNCSLINFLG Endif
GNCSLINFLG = 0

# Issue 110979/2 - 2016-03-25 by CCC : Warning message when routing is versioned (warning on the first add)
If [F:MFG]MFGNUM<>[M:MTK0]MFGNUM
    Read [F:MFG]MFG0 = [M:MTK0]MFGNUM
Endif
If nolign>[M:MTK1]NBOPE & [F:MFG]ROUECCMAJ <> "" & !find(0,[M:MTK1]ROUOPENUM(0..[M:MTK1]NBOPE-1))
    OK=1
    Call AVERTIR(mess(345,193,1),OK) From GESECRAN
    If OK = 1 : FIN=1 : Return : Endif # Cancel
Endif

If WGREP = "C" & GCTLOPEPRE <> 1 & [M:MTK1]OPEPREC(LLIG) <> 0 & LMOD = 0
    Filter [MFO] Where MFGNUM = [M:MTK1]MFGNUMOP(LLIG) & OPENUM = [M:MTK1]OPEPREC(LLIG)
    Read [MFO]MFO0 First
    If fstat : Raz [F:MFO] : Endif
    Filter [MFO]
    If [F:MFO]TRKFIRST <> [0/0/0]  | [F:MFO]OPESTA = 6 : Return : Endif
    # GH 05/12/2013 bug 90095 test que l'opération précédente peut être suivie
    Read [SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
    If fstat : Raz [F:SCH] : Endif
    If [F:SCH]DACMST = 1 : Return : Endif
    #
    If LLIG <> 0
        J = find ([M:MTK1]OPEPREC(LLIG),[M:MTK1]OPENUM(0..LLIG-1))
    Endif
    If !J | [M:MTK1]MODIFLG(LLIG-1) = 1 | LLIG = 0 |
&          ([M:MTK1]CPLQTY(LLIG-1) = 0 & [M:MTK1]CPLOPETIM(LLIG-1) = 0 & [M:MTK1]CPLSETTIM(LLIG-1) = 0)
        Case GCTLOPEPRE :
             When 2 : Call AVERTIR(mess(82,193,1)-num$([M:MTK1]OPENUM(LLIG)),WOK) From GESECRAN
                      If WOK = 1 : FIN = 1  : Endif
             When 3 : Call ERREUR(mess(22,190,1)-num$([M:MTK1]OPENUM(LLIG))) From GESECRAN
                      FIN = 1
        Endcase
    Endif
Endif
Return

#-------------------------------------------------
$SETBOUT_MFOTRKFICH
If LMOD <> 1 : Call VIREBOUT(CHMEN, "AS") From GOBJET : Endif
If (WGREP = "C" & LNEW <> 3) | LMOD = 1 : ETABOU(GVALI)=1
Else                     : ETABOU(GVALI)=0
Endif
ETABOU(GABAN)=1
ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0

Return

#-------------------------------------------------
$DEB_MFOTRKFICH
Local     Integer    LNEW
Local     Integer    LOK
Local     Decimal    WCOEFF, WCOEFF1
Local     Integer    WREP
Local     Shortint   SAVNOLIGN
Local     Integer    ETABOU(1..GNBBOU), SAVGOBJET
Local     Integer       J
Local     Char          WCCE(15) : # sections analytiques

If clalev ([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif  # FGR 18/09/2009 : X3SUIVI57908

nolign = LLIG+1
LNEW = 0
OMODIF = 0
If WGREP = "C"
    If [M:MTK1]OPENUM(LLIG) = 0                                  # si ajout opération non prévue
        LNEW = 1
    Elsif [M:MTK1]ROUOPENUM(LLIG) = 0 & [M:MTK1]OPENUM(LLIG) <> 0 # si modif opération non prévue
        LNEW = 2
    Elsif [M:MTK1]MODIFLG(LLIG) = 1  | [M:MTK1]DACMST(LLIG) = 1
        LNEW = 3                                                # si opération exclue ou  suivie auto
    Endif
Elsif   LMOD = 1
        LNEW = 4                                                # si correction d'un suivi
Endif

Case LNEW
    When 0,4 : # visu en fiche d'une opération existante
            MODOPE     = 1
            Raz [M:MTO1]
            [M:MTO1] = [M:MTK1]
            Gosub INIT_MTO1_SCANUM
            [M:MTO1]SCANUM1 = [M:MTO1]SCANUM(0)
            [M:MTO1]MFGFCY  = [M:MTK0]MFGFCY
            [M:MTO1]EXTWST  = [M:MTO1]CPLWST
            [M:MTO1]EXTLAB  = [M:MTO1]CPLLAB
            If [M:MTO1]EMPNUM <> 0
                Read [F:TMA]TMA0 = [M:MTO1]EMPNUM
                If fstat : Raz [F:TMA] : Endif
                [M:MTO1]EMPDES = [F:TMA]EMPDES
            Endif
            If [M:MTO1]SCANUM1 <> 0
                Read [F:TSR]TSR0 = [M:MTO1]SCANUM1
                # FGR 18/09/2009 : X3SUIVI57920
                #If fstat : Raz [F:TSR] : Endif
                #[M:MTO1]SCADES = [F:TSR]SCADES
                If fstat Then
                  Raz [F:TSR]
                  [M:MTO1]SCADES = ""
                Else
                  Call LECTEXTRA([M:MTO1]SCADES,"TABSCA","SCADESAXX",num$([F:TSR]SCANUM),"") From ATEXTRA
                Endif
            Endif
            If [M:MTO1]MSGNUM <> 0
                Read [F:TMS]TMS0 = [M:MTO1]MSGNUM
                # FGR 18/09/2009 : X3SUIVI57908
                #If fstat : Raz [F:TMS] : Endif
                #[M:MTO1]MSGDES = [F:TMS]MSGDES
                If fstat Then
                  Raz [F:TMS]
                  [M:MTO1]MSGDES = ""
                Else
                  Call LECTEXTRA([M:MTO1]MSGDES,"TABMSG","MSGDESAXX",num$([F:TMS]MSGNUM),"") From ATEXTRA
                Endif
            Endif
            # sr 06.02 ne plus griser le bloc des coeff. demande 14504
            Diszo [M:MTO1]5,10,15,30,32,40
            If WGREP <> "C"
               If LMOD = 0 | [M:MTO1]TIMTYP = 3 : Diszo 20,25,35,45,50
               Else : Grizo 20
               Endif
               If [M:MTO1]TIMTYP = 2 : Grizo [M:MTO1]CLEFLG  : Endif
               If [M:MTO1]TIMTYP = 3 & LMOD = 1 : Actzo [M:MTO1]CPLOPETIM, EMPNUM : Endif
            Else
               If [F:MTS]OPEUOMMOD = 2 : Actzo [M:MTO1]OPEUOM : Endif
            Endif
    When 1: # ajout nouvelle opération
            Raz [M:MTO1]
            [M:MTO1]TIMTYP    = 1
            [M:MTO1]MFGNUMOP  = [M:MTK0]MFGNUM
            [M:MTO1]MFGFCY    = [M:MTK0]MFGFCY
            [M:MTO1]OPESTUCOE = 1
            [M:MTO1]OPEWORCOE = 1
            [M:MTO1]TIMUOMCOD = [M:MTK0]TIMUOMCOD(0) : # GH 28/02/2014 bug 91718
            Grizo [M:MTO1]10,15,40,OPESPLNUM,EXTQTY,OKQTY
    When 2: # accès en fiche d'une opération non prévue existante
            MODOPE     = 1
            Raz [M:MTO1]
            [M:MTO1] = [M:MTK1]
            Gosub INIT_MTO1_SCANUM
            [M:MTO1]SCANUM1 = [M:MTO1]SCANUM(0)
            If [M:MTO1]EMPNUM <> 0
                Read [F:TMA]TMA0 = [M:MTO1]EMPNUM
                If fstat : Raz [F:TMA] : Endif
                [M:MTO1]EMPDES = [F:TMA]EMPDES
            Endif
            If [M:MTO1]SCANUM1 <> 0
                Read [F:TSR]TSR0 = [M:MTO1]SCANUM1
                # FGR 18/09/2009 : X3SUIVI57920
                #If fstat : Raz [F:TSR] : Endif
                #[M:MTO1]SCADES = [F:TSR]SCADES
                If fstat Then
                  Raz [F:TSR]
                  [M:MTO1]SCADES = ""
                Else
                  Call LECTEXTRA([M:MTO1]SCADES,"TABSCA","SCADESAXX",num$([F:TSR]SCANUM),"") From ATEXTRA
                Endif
            Endif
            If [M:MTO1]MSGNUM <> 0
                Read [F:TMS]TMS0 = [M:MTO1]MSGNUM
                # FGR 18/09/2009 : X3SUIVI57908
                #If fstat : Raz [F:TMS] : Endif
                #[M:MTO1]MSGDES = [F:TMS]MSGDES
                If fstat Then
                  Raz [F:TMS]
                  [M:MTO1]MSGDES = ""
                Else
                  Call LECTEXTRA([M:MTO1]MSGDES,"TABMSG","MSGDESAXX",num$([F:TMS]MSGNUM),"") From ATEXTRA
                Endif
            Endif
            Grizo [M:MTO1]5,10,15,25,30,32,40
            If [F:MTS]OPEUOMMOD = 2 : Actzo [M:MTO1]OPEUOM : Endif
            If WGREP <> "C": Grizo [M:MTO1]5,10,15,20,25,30,35,40,45,50 : Endif
    When 3: # accès en fiche d'une opération exclue (visu uniquement)
            MODOPE     = 1
            Raz [M:MTO1]
            [M:MTO1] = [M:MTK1]
            Gosub INIT_MTO1_SCANUM
            [M:MTO1]SCANUM1 = [M:MTO1]SCANUM(0)
            [M:MTO1]EXTWST = [M:MTO1]CPLWST
            [M:MTO1]EXTLAB = [M:MTO1]CPLLAB
            If [M:MTO1]EMPNUM <> 0
                Read [F:TMA]TMA0 = [M:MTO1]EMPNUM
                If fstat : Raz [F:TMA] : Endif
                [M:MTO1]EMPDES = [F:TMA]EMPDES
            Endif
            If [M:MTO1]SCANUM1 <> 0
                Read [F:TSR]TSR0 = [M:MTO1]SCANUM1
                # FGR 18/09/2009 : X3SUIVI57920
                #If fstat : Raz [F:TSR] : Endif
                #[M:MTO1]SCADES = [F:TSR]SCADES
                If fstat Then
                  Raz [F:TSR]
                  [M:MTO1]SCADES = ""
                Else
                  Call LECTEXTRA([M:MTO1]SCADES,"TABSCA","SCADESAXX",num$([F:TSR]SCANUM),"") From ATEXTRA
                Endif
            Endif
            If [M:MTO1]MSGNUM <> 0
                Read [F:TMS]TMS0 = [M:MTO1]MSGNUM
                # FGR 18/09/2009 : X3SUIVI57908
                #If fstat : Raz [F:TMS] : Endif
                #[M:MTO1]MSGDES = [F:TMS]MSGDES
                If fstat Then
                  Raz [F:TMS]
                  [M:MTO1]MSGDES = ""
                Else
                  Call LECTEXTRA([M:MTO1]MSGDES,"TABMSG","MSGDESAXX",num$([F:TMS]MSGNUM),"") From ATEXTRA
                Endif
            Endif
            Grizo [M:MTO1]5,10,15,20,25,30,32,35,40,45,50
Endcase
If GCONSULT Grizo [M:MTO1] : Endif
Return

#-------------------------------------------------
$OK_MFOTRKFICH
    Case LNEW
          When 0,2,3: nolign = LLIG+1
                      Raz WCOEFF
                      Raz WCOEFF1
                      If [M:MTK1]MFOEXTQTY(LLIG) <> 0
                           WCOEFF  = [M:MTO1]CPLQTY / ([M:MTK1]MFOEXTQTY(LLIG) / [M:MTK1]OPEWORCOE(LLIG))
                           WCOEFF1 = [M:MTO1]REJCPLQTY / ([M:MTK1]MFOEXTQTY(LLIG) / [M:MTK1]OPEWORCOE(LLIG))
                           # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
                           # Ce sont les quantités qui sont arrondies
                           #WCOEFF = arr(WCOEFF,0.00000001)
                           #WCOEFF1 = arr(WCOEFF1,0.00000001)
                      Endif
                      [M:MTK1]=[M:MTO1]
                      Gosub INIT_MTK1_SCANUM

                      If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
                          I = LLIG+1
                          Gosub REAJUST_OPEMAT From SUBMTKB
                      Endif
                      If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2 & [M:MTO1]MFGMST = 2
                          Gosub REAJUST_ITM From SUBMTKB
                      Endif
                 #   si opération borne calcul des qtés réalisées et tps pour toutes les opérations
                 #    à suivre en auto.
                      If [M:MTO1]DACMST = 3 : Gosub CALC_QTYB From SUBMTKB : Endif
                      Boxclr [MTO1]
          When 1    : nolign = LLIG+1
                      [M:MTK1] = [M:MTO1]
                      Gosub INIT_MTK1_SCANUM
                      [M:MTK1]TIMTYP(LLIG)    = 1
                      [M:MTK1]OPETRKLIN(LLIG) = LLIG+1
                      [M:MTK1]CLEFLG(LLIG)    = 2
                      [M:MTK1]DACMST(LLIG)    = 2
                      [M:MTK1]XOPEUOM(LLIG)   = [M:MTK1]OPEUOM(LLIG)
                      [M:MTK1]MFGNUMOP(LLIG)  = [M:MTK0]MFGNUM
                      [M:MTK1]NBOPE += 1
                      Boxclr [MTO1]
          When 4    : nolign = LLIG+1
                      [M:MTK1] = [M:MTO1]
                      Gosub INIT_MTK1_SCANUM
                      Gosub MAJ_MODIF From MTKWIN
                      Boxclr [MTO1]
       Endcase
           Sorta [M:MTK1]NBOPE [M:MTK1]NBOPE Order By [M:MTK1]OPENUM(indice)
           Affzo [M:MTK1]10
Return

#-------------------------------------------------
$INIT_MTO1_SCANUM
Local Integer I
For I = 1 To 15
    [M:MTO1]SCANUM(I-1)    = evalue("[M:MTK1]SCANUM"+num$(I)+"(LLIG)")
    [M:MTO1]TABREJQTY(I-1) = evalue("[M:MTK1]TAREJQTY"+num$(I)+"(LLIG)")
Next
Return

#-------------------------------------------------
$INIT_MTK1_SCANUM
Local Integer I
If [M:MTO1]SCANUM1 <> 0 & [M:MTO1]SCANUM(0) = 0
   [M:MTO1]SCANUM(0) =  [M:MTO1]SCANUM1
Endif
If [M:MTO1]TABREJQTY(0)  = 0 & [M:MTO1]REJCPLQTY<> 0
    [M:MTO1]TABREJQTY(0) =     [M:MTO1]REJCPLQTY
Endif
For I = 1 To 15
     Assign "[M:MTK1]SCANUM"+num$(I)+"(LLIG)" With [M:MTO1]SCANUM(I-1)
     Assign "[M:MTK1]TAREJQTY"+num$(I)+"(LLIG)" With [M:MTO1]TABREJQTY(I-1)
Next
Return


################################################################################
# MFOFICHMTK  : visu en mode fiche  d'une opération d'OF depuis le suivi       #
################################################################################
$OUV_MFOFICHMTK
Local Char    WMFGNUM(GLONVCR): WMFGNUM    = PARAM(1)
Local Integer WOPENUM         : WOPENUM    = val(PARAM(2))
Local Integer WOPESPLNUM      : WOPESPLNUM = val(PARAM(3))
Return

#-------------------------------------------------
$DEB_MFOFICHMTK
If clalev ([F:MFO]) <= 0 : Local File MFGOPE [MFO] : Endif
Read [MFO]MFO0=WMFGNUM;WOPENUM;WOPESPLNUM
If fstat : End : Endif
Raz [MFO0] : Raz [MFO1] : Raz [MFO2]
[M:MFO0] = [F:MFO]
[M:MFO1] = [F:MFO]
[M:MFO2] = [F:MFO]
[M:MFO3] = [F:MFO]
Grizo [M:MFO0]
Grizo [M:MFO1]
Grizo [M:MFO2]
Grizo [M:MFO3]
Return

#---------------------------
$SETBOUT_MFOFICHMTK
ETABOU(GABAN)=1
ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
#
Return

################################################################################
# MKOREBUT : Saisie/visu des codes rebut                                       #
################################################################################
$OUV_MKOREBUT
Local     Char       LABMSK   : LABMSK = PARAM(1)
Local     Integer    LLIG     : LLIG    = val(PARAM(2))
Local     Integer    LTRT     : LTRT    = val(PARAM(3))
Local     Integer    I
Return

#-------------------------------------------------
$DEB_MKOREBUT
Raz [MTO3]
Case LABMSK : When "MTO1" : [M:MTO3]REJCPLQTY = [M:MTO1]REJCPLQTY
                           [M:MTO3]OPEUOM    = [M:MTO1]OPEUOM
                           [M:MTO3]CPLQTY    = [M:MTO1]CPLQTY
                           [M:MTO3]OKQTY     = [M:MTO1]OKQTY
                           For I = 0 To 14
                              If [M:MTO1]SCANUM(I) = 0 : Break : Endif
                              [M:MTO3]SCANUM(I) = [M:MTO1]SCANUM(I)
                              If [M:MTO3]SCANUM(I) <> 0
                                  Read [F:TSR]TSR0 = [M:MTO3]SCANUM(I)
                                  # FGR 18/09/2009 : X3SUIVI57920
                                  #If !fstat : [M:MTO3]SCADES(I) = [F:TSR]SCADES : Endif
                                  If !fstat Then
                                    Call LECTEXTRA([M:MTO3]SCADES(I),"TABSCA","SCADESAXX",num$([F:TSR]SCANUM),"") From ATEXTRA
                                  Endif
                              Endif
                              [M:MTO3]TABREJQTY(I) = [M:MTO1]TABREJQTY(I)
                           Next
                           [M:MTO3]NBLIG = I
              When "MTK1" : [M:MTO3]REJCPLQTY = [M:MTK1]REJCPLQTY(LLIG)
                           [M:MTO3]OPEUOM    = [M:MTK1]OPEUOM(LLIG)
                           [M:MTO3]CPLQTY    = [M:MTK1]CPLQTY(LLIG)
                           For I = 0 To 14
                              If evalue("[M:MTK1]SCANUM"+num$(I+1)+"(LLIG)") = 0 : Break : Endif
                              [M:MTO3]SCANUM(I) = evalue("[M:MTK1]SCANUM"+num$(I+1)+"(LLIG)")
                              If [M:MTO3]SCANUM(I) <> 0
                                  Read [F:TSR]TSR0 = [M:MTO3]SCANUM(I)
                                  # FGR 18/09/2009 : X3SUIVI57920
                                  #If !fstat : [M:MTO3]SCADES(I) = [F:TSR]SCADES : Endif
                                  If !fstat Then
                                    Call LECTEXTRA([M:MTO3]SCADES(I),"TABSCA","SCADESAXX",num$([F:TSR]SCANUM),"") From ATEXTRA
                                  Endif
                              Endif
                              [M:MTO3]TABREJQTY(I) = evalue("[M:MTK1]TAREJQTY"+num$(I+1)+"(LLIG)")
                           Next
                           [M:MTO3]NBLIG = I
              When "MBO"  : [M:MTO3]REJCPLQTY = [M:MBO]REJCPLQTY(LLIG)
                           [M:MTO3]OPEUOM    = [M:MBO]OPEUOM(LLIG)
                           [M:MTO3]CPLQTY    = [M:MBO]CPLQTY(LLIG)
                           For I = 0 To 14
                              If evalue("[M:MBO]SCANUM"+num$(I+1)+"(LLIG)") = 0 : Break : Endif
                              [M:MTO3]SCANUM(I) = evalue("[M:MBO]SCANUM"+num$(I+1)+"(LLIG)")
                              If [M:MTO3]SCANUM(I) <> 0
                                  Read [F:TSR]TSR0 = [M:MTO3]SCANUM(I)
                                  # FGR 18/09/2009 : X3SUIVI57920
                                  #If !fstat : [M:MTO3]SCADES(I) = [F:TSR]SCADES : Endif
                                  If !fstat Then
                                    Call LECTEXTRA([M:MTO3]SCADES(I),"TABSCA","SCADESAXX",num$([F:TSR]SCANUM),"") From ATEXTRA
                                  Endif
                              Endif
                              [M:MTO3]TABREJQTY(I) = evalue("[M:MBO]TAREJQTY"+num$(I+1)+"(LLIG)")
                           Next
                           [M:MTO3]NBLIG = I
             When Default :
Endcase

Affzo [M:MTO3]1-99
Grizo [M:MTO3]5
If LTRT = 2 Grizo [M:MTO3]10 : Endif
If LTRT = 0 : Actzo [M:MTO3]REJCPLQTY : Endif
If LTRT <> 2 : ETABOU(GVALI)=1 : Endif
ETABOU(GABAN)=1
Call SETBOUT(ETABOU) From GESECRAN
Return

#-------------------------------------------------
$AVANT_OK_MKOREBUT
If [M:MTO3]NBLIG <> 0
   If sum([M:MTO3]TABREJQTY(0..14)) <> [M:MTO3]REJCPLQTY
         Call ERREUR(mess(37,190,1)+num$([M:MTO3]REJCPLQTY)) From GESECRAN
         FOK = 0 : FIN=0
   Endif
Endif
Return

#-------------------------------------------------
$OK_MKOREBUT
Case LABMSK
    When "MTO1" : For I = 0 To 14
                    [M:MTO1]SCANUM(I)    = [M:MTO3]SCANUM(I)
                    [M:MTO1]TABREJQTY(I) = [M:MTO3]TABREJQTY(I)
                  Next I
                  If LTRT = 0 : VALEUR = [M:MTO3]REJCPLQTY
                  Elsif LTRT = 1
                                VALEUR = [M:MTO3]SCANUM(0)
                  Endif
    When "MTK1" : For I = 0 To 14
                    Assign "[M:MTK1]SCANUM"+num$(I+1)+"(LLIG)"    With [M:MTO3]SCANUM(I)
                    Assign "[M:MTK1]TAREJQTY"+num$(I+1)+"(LLIG)"  With [M:MTO3]TABREJQTY(I)
                  Next I
                  If LTRT = 0 : VALEUR = [M:MTO3]REJCPLQTY
                  Elsif LTRT = 1
                                VALEUR = [M:MTO3]SCANUM(0)
                  Endif
    When "MBO"  : For I = 0 To 14
                    Assign "[M:MBO]SCANUM"+num$(I+1)+"(LLIG)"    With [M:MTO3]SCANUM(I)
                    Assign "[M:MBO]TAREJQTY"+num$(I+1)+"(LLIG)"  With [M:MTO3]TABREJQTY(I)
                  Next I
                  If LTRT = 0 : VALEUR = [M:MTO3]REJCPLQTY
                  Elsif LTRT = 1
                                VALEUR = [M:MTO3]SCANUM(0)
                  Endif
    When Default :
Endcase
Return

################################################################################
# MFMFICHMTK  : visu en mode fiche  d'une ligne composant depuis le suivi      #
################################################################################
$OUV_MFMFICHMTK
Local    Char       LMFGNUM(GLONVCR) : LMFGNUM = PARAM(1)
Local    Integer    LMFGLIN          : LMFGLIN = val(PARAM(2))
Local    Integer    LBOMSEQ          : LBOMSEQ = val(PARAM(3))
Local    Char       LITMREF(GLONITM) : LITMREF = PARAM(4)

# Issue 119394 GH 23/12/2016 - Declaration and initialization of GMODMAT, it is used in before entry actions
If dim([V]GMODMAT)<=0 : Global Integer  GMODMAT : Endif
GMODMAT = 1
Return

#-------------------------------------------------
$DEB_MFMFICHMTK

If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif
If clalev ([F:MFM]) <= 0 : Local File MFGMAT [MFM] : Endif
Read [MFM]MFM0=LMFGNUM;LMFGLIN;LBOMSEQ;LITMREF
If fstat : Return : Endif

Raz [M:MFMW]
[M:MFMW] = [F:MFM]
# process 03.04 MM
If dim([M:MFMW]BOMUOM)>0
    If [M:MFMW]BOMUOM=""
        [M:MFMW]BOMUOM =[F:MFM]STU
        [M:MFMW]BOMSTUCOE =1
        [M:MFMW]BOMQTY =[F:MFM]LIKQTY
    Endif
Endif
# Fin process 03.04 MM

If [F:ITM]ITMREF <> [F:MFM]ITMREF
    Read [F:ITM]ITM0 = [F:MFM]ITMREF
    If fstat : Raz [F:ITM] : Endif
Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:MFM]MFGFCY| [F:ITF]ITMREF <> [F:MFM]ITMREF
   Read [ITF]ITF0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif


#[M:MFMW]ITMDES1 = [F:ITM]ITMDES1
#LECTURE du libellé traduisible
#Call LECTEXTRA([M:MFMW]ITMDES1,"ITMMASTER","DES1AXX",[F:ITM]ITMREF,"") From ATEXTRA
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFMW]ITMDES1, "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296

If dim([M:MFMW]XTYPQTY) > 0
   If [F:ITF]STOMGTCOD = 3
      [M:MFMW]XTYPQTY  = mess(1, 2311, 1)
   Else
      [M:MFMW]XTYPQTY  = mess(2, 2311, 1)
   Endif
Endif

Diszo [M:MFMW]
Affzo [M:MFMW]
Return

#-------------------------------------------------
$SETBOUT_MFMFICHMTK
ETABOU(GVALI)=1
ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
ETABOU(GSPE1)=0
Return

################################################################################
# MFMTRKSTA  : Etat du suivi d'une ligne composant depuis le suivi             #
################################################################################
$OUV_MFMTRKSTA
Local Integer WLIG     : WLIG     = val(PARAM(1))
Local Char    WABMSK   : WABMSK   = PARAM(2)
Return

#-------------------------------------------------
$DEB_MFMTRKSTA
Local Integer WNOLIGN : WNOLIGN = nolign
nolign = WLIG+1

Case WABMSK :
    When "MTK3" :   Raz [M:MTKM]
                    [M:MTKM]            = [M:MTK3]
                    [M:MTKM]MFGFCY      = [M:MTK0]MFGFCY
                    [M:MTKM]MFGNUM      = [M:MTK0]MFGNUM
                    If [M:MTKM]MFMTRKFLG = 5 : [M:MTKM]MFMRESQTY = 0
                    Else [M:MTKM]MFMRESQTY   = [M:MTKM]MFMEXTQTY - [M:MTKM]MFMUSEQTY
                    Endif
                    If [M:MTKM]MFMRESQTY < 0 : [M:MTKM]MFMRESQTY = 0 : Endif
                    If [F:ITM]ITMREF    <>[M:MTK3]MATITMREF(WLIG)
                        Read [F:ITM]ITM0 = [M:MTK3]MATITMREF(WLIG)
                       If fstat Raz [F:ITM] : Endif
                    Endif
                    [M:MTKM]NEGSTO = [F:ITM]NEGSTO
    When "MBM" :    Raz [M:MTKM]
                    [M:MTKM]            = [M:MBM]
                    [M:MTKM]MFGFCY      = [M:MBM]FCY
                    [M:MTKM]MFGNUM      = [M:MBM]MFGNUM(WLIG)
                    [M:MTKM]MATITMREF   = [M:MBM]ITMREF(WLIG)
                    If [M:MTKM]MFMTRKFLG = 5 : [M:MTKM]MFMRESQTY = 0
                    Else [M:MTKM]MFMRESQTY   = [M:MTKM]MFMEXTQTY - [M:MTKM]MFMUSEQTY
                    Endif
                    If [M:MTKM]MFMRESQTY < 0 : [M:MTKM]MFMRESQTY = 0 : Endif
                    If [F:ITM]ITMREF    <>[M:MBM]ITMREF(WLIG)
                       Read [F:ITM]ITM0 = [M:MBM]ITMREF(WLIG)
                       If fstat Raz [F:ITM] : Endif
                    Endif
                    [M:MTKM]NEGSTO = [F:ITM]NEGSTO
    When "MBR" :    Raz [M:MTKM]
                    [M:MTKM]            = [M:MBR]
                    [M:MTKM]MFGFCY      = [M:MBR]FCY
                    [M:MTKM]MFGNUM      = [M:MBR]MFGNUM(WLIG)
                    [M:MTKM]MATITMREF   = [M:MBR]ITMREF(WLIG)
                    If [M:MTKM]MFMTRKFLG = 5 : [M:MTKM]MFMRESQTY = 0
                    Else [M:MTKM]MFMRESQTY   = [M:MTKM]MFMEXTQTY - [M:MTKM]MFMUSEQTY
                    Endif
                    If [M:MTKM]MFMRESQTY < 0 : [M:MTKM]MFMRESQTY = 0 : Endif
                    If [F:ITM]ITMREF    <>[M:MBR]ITMREF(WLIG)
                       Read [F:ITM]ITM0 = [M:MBR]ITMREF(WLIG)
                       If fstat Raz [F:ITM] : Endif
                    Endif
                    [M:MTKM]NEGSTO = [F:ITM]NEGSTO

    When "MFG2" :   Raz [MTKM]
                    [M:MTKM]MFGFCY      = [M:MFG0]MFGFCY
                    [M:MTKM]MFGNUM      = [M:MFG0]MFGNUM
                    [M:MTKM]MATITMREF   = [M:MFG2]ITMREF(WLIG)
                    [M:MTKM]STU         = [M:MFG2]STU(WLIG)
                    [M:MTKM]MFMTRKFLG   = [M:MFG2]MFMTRKFLG(WLIG)
                    [M:MTKM]MFMEXTQTY   = [M:MFG2]RETQTY(WLIG)
                    [M:MTKM]MFMUSEQTY   = [M:MFG2]USEQTY(WLIG)
                    [M:MTKM]MFMALLQTY   = [M:MFG2]ALLQTY(WLIG)
                    [M:MTKM]MFMSHTQTY   = [M:MFG2]SHTQTY(WLIG)
                    If [M:MTKM]MFMTRKFLG = 5
                        [M:MTKM]MFMRESQTY = 0
                    Else
                        [M:MTKM]MFMRESQTY   = [M:MTKM]MFMEXTQTY - [M:MTKM]MFMUSEQTY
                        If [M:MTKM]MFMRESQTY < 0 : [M:MTKM]MFMRESQTY = 0 : Endif
                    Endif
                    [M:MTKM]ALLSTA      = [M:MFG2]ALLSTA(WLIG)
                    If [F:ITM]ITMREF <> [M:MFG2]ITMREF(WLIG)
                       Read [F:ITM]ITM0 = [M:MFG2]ITMREF(WLIG)
                       If fstat : Raz [F:ITM] : Endif
                    Endif
                    [M:MTKM]NEGSTO = [F:ITM]NEGSTO

Endcase
nolign = WNOLIGN
Return


#-------------------------------------------------
$SETBOUT_MFMTRKSTA
ETABOU(GSPE1) = 0
If [M:MTKM]ALLSTA > 1
   ETABOU(GSPE1)=1
Endif
If GCONSLCT = 1
    ETABOU(GSPE1) = 0
    Diszo [MTKM] : # Diszo [M:MTMK] : # GH 16/10/13 bug 93562
Endif
Return


################################################################################
# MFMFAN      : Ajouter sous-ensemble (fantôme)                                #
################################################################################
$OUV_MFMFAN
Local Integer     WLIG     : WLIG     = val(PARAM(1))
Local Integer     WNBLIG   : WNBLIG   = [M:MFG2]NBLIG
Local Decimal     WQTY
Local Integer     WGHOST   : WGHOST = 9
Local Integer     WRET
# Issue X3-6311 - if versiond product, ask before adding assembly
Local Integer I
If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
  I= sigma(0,[M:MFG1]NBLIG-1,(indcum+1)*([M:MFG1]ECCVALMAJ(indcum)="" & [M:MFG1]ITMTYP(indcum)=1))
  If !I
    If !GREVMESSC
      GREVMESSC = 1
      GERR = 2
      GMESSAGE = mess(401,193,1) # You are about to do critical changes on a versioned product's components
    Endif
  Endif
Endif # Issue X3-55832
# End issue X3-6311
Return

#-------------------------------------------------
$DEB_MFMFAN
nolign = WLIG + 1
Raz [MFMF]

[M:MFMF]MFGSTU = [M:MFG1]MFGSTU
[M:MFMF]EXTQTY = [M:MFG1]MFGEXTQTY
Return

#-------------------------------------------------
$OK_MFMFAN
If [M:MFMF]NBLIG <> 0
    Local    Integer  WLIKQTYCOD     : WLIKQTYCOD = 1   # FQ 73109 GA 05/2011 appel de CREMAT
    Local    Decimal  WLIK           : WLIK = 1         # FQ 73109 GA 05/2011
    Local    Decimal  WSCA           : WSCA = 1         # FQ 73109 GA 05/2011
    Local    Decimal  WBAS           : WBAS = 1         # FQ 73109 GA 05/2011
    Local    Date     WDAT           : WDAT = [M:MFG1]STRDAT

    Case [M:MFMF]LIKQTYCODG
        When 1: WQTY = [M:MFMF]LIKQTYG * [M:MFMF]EXTQTY
        When 2: WQTY = [M:MFMF]LIKQTYG
    Endcase

    # Issue 113561 - 2016-01 by GH : Material load for a version in derogation
    If dim([M:MFMF]GHTECCMAJ)>0 & [M:MFMF]GHTECCMAJ<>""
       Call CORDAT([M:MFMF]GHOST,[M:MFMF]GHTECCMAJ,[M:MFMF]GHTECCMIN,2,WDAT) From ECCLIB
    Endif

    # Issue 79800 - GA 02/2012 avant WLIKQTY au lieu de WLIK
    # FQ 73109 GA 05/2011 + param WLIKQTYCOD appel de CREMAT
    Call CREMAT(0,WNBLIG,[M:MFG0]MFGFCY,[M:MFMF]GHOST,[M:MFMF]GHOSTALT,
&               WDAT, WQTY, "",0,0,WLIKQTYCOD, WLIK, WSCA, 0, WBAS, WGHOST,WRET) From MFGLIBM     # 38064 mm 11.06
    # Issue 119469 GH 04/11/16 - display lines with their style
    #Affzo [M:MFG2]10
    Call HIGHLIGHT("MFG2",-1) From ECCLIB
    mkstat = 4
Endif

Return

################################################################################
# MFOFRC      : Date forcée                                                    #
################################################################################
$OUV_MFOFRC
Local Integer     WLIG     : WLIG     = val(PARAM(1))
Local Char        WABMSK   : WABMSK   = PARAM(2)

If clalev([F:FCY]) = 0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:TUV]) = 0  : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:CPV]) = 0  : Local File CAPVAR     [CPV]  : Endif
If clalev([F:TWD]) = 0  : Local File TABWEEDIA  [TWD]  : Endif

Return

#-------------------------------------------------
$DEB_MFOFRC
nolign = WLIG + 1

# lecture site
Call LECTURE ("FCY", [M:MFG0]MFGFCY, "") From CONTOBJ

# lecture indisponibilités
Read [F:TUV]UVY0=[F:FCY]UVYCOD
If fstat : Raz [F:TUV] : Endif

If [M:MFG3]FRCSTRDAT(WLIG) = [0/0/0]
    [M:MFRC]AVDATE = [M:MFG3]OPESTR(WLIG)
Else
    [M:MFRC]AVDATE = [M:MFG3]FRCSTRDAT(WLIG)
Endif

[M:MFRC]APDATE     = [M:MFRC]AVDATE
[M:MFRC]XTRT       = 0
Diszo [M:MFRC]10
Affzo [M:MFRC]
Return

#-------------------------------------------------
$OK_MFOFRC
# 12.05 33765
VALEUR = [M:MFRC]APDATE
If dim(OJAL) > 0
    If OJAL = 0 : OJAL = 1 : Endif
Endif
Return


#########################################################################
#    Actions liés au type traitement standard                           #
#########################################################################
$INIT
Case GACTION
 When "CALQTEPROD" : Gosub INI_CALQTEPROD
Endcase
Return

#-------------------------------------------------
$INIT_DIA
Case GACTION
 When "ROURPL"     : Gosub INI_ROURPL
 When "MTKCALTPS"  : Gosub INI_MTKCALTPS
 When "CALQTEPROD" : Gosub INID_CALQTEPROD
Endcase
Return

#-------------------------------------------------
$CONTROLE
Case GACTION
Endcase
Return

#-------------------------------------------------
$EXEC
Case GACTION
 When "ROURPL"      : Gosub EXEC_ROURPL
 When "ROURPL1"     : Gosub EXEC_ROURPL1
 When "MTKCALTPS"   : Gosub EXEC_MTKCALTPS
Endcase
Return

#-------------------------------------------------
$TERMINE
Case GACTION
 When "CALQTEPROD"  : Gosub TERMINE_CALQTEPROD
Endcase
Return

################################################################################
# DETAIL DES ACTIONS                                                           #
################################################################################

################################################################################
# ROURPL : Renumérotation d'une opération de gamme                             #
################################################################################
$INI_ROURPL
[M:DIA]NOL       = nolign-1 : # Issue 88670 - 2015-12-04 by GH : renumbering of one routing operation
[M:DIA]OPENUM    = [M:ROU1]OPENUM(nolign-1)
[M:DIA]VALSTRDAT = [M:ROU1]VALSTRDAT(nolign-1)
[M:DIA]VALENDDAT = [M:ROU1]VALENDDAT(nolign-1)
Return

#-------------------------------------------------
$EXEC_ROURPL
Call ROURPL([M:DIA]OPENUM,[M:DIA]NEWOPENUM) From SUBROUA
Return

################################################################################
# ROURPL1 : Renumérotation globale                                             #
################################################################################

$EXEC_ROURPL1
If [M:DIA]OPEINC = 0 : FIN=1 : Return : Endif

Call ROURPL1([M:DIA]OPEINC) From SUBROUA
Return

################################################################################
# MTKCALTPS : Renumérotation globale des opérations de gamme                   #
################################################################################
$INI_MTKCALTPS
Local Char     WABR      : WABR    = PARAM(1)
Local Char     WZONE     : WZONE   = PARAM(2)

Case WABR :
    When "MTO1", "MTK1"
            [M:DIA]JDEB = [M:MTK0]MFGTRKDAT
            [M:DIA]JFIN = [M:MTK0]MFGTRKDAT
    When "MBO":
            [M:DIA]JDEB = [M:MBO]IPTDAT(nolign-1)
            [M:DIA]JFIN = [M:MBO]IPTDAT(nolign-1)
Endcase
Return

#-------------------------------------------------
$EXEC_MTKCALTPS
Local Integer HHD,MMD,HHF,MMF,WDEB,WFIN,WRESULT,WNBJ,OK
Local Char WMANIP
WMANIP = [M:DIA]HDEB
HHD = val(left$(WMANIP,2)) * 60
MMD = val(right$(WMANIP,3))
WMANIP = [M:DIA]HFIN
HHF = val(left$(WMANIP,2)) * 60
MMF = val(right$(WMANIP,3))
WDEB = sum(HHD,MMD)
WFIN = sum(HHF,MMF)
#
If [M:DIA]JFIN > [M:DIA]JDEB
   WNBJ = [M:DIA]JFIN - [M:DIA]JDEB
   WFIN = WFIN + (1440 * WNBJ)
Endif
#
WRESULT = WFIN - WDEB
If WRESULT < 0 : Raz WRESULT : Endif
Case WABR :
     When "MTO1" :
            Case [M:MTO1]TIMUOMCOD
                 When 1 :
                          Case WZONE :
                               When "CPLOPETIM" : [M:MTO1]CPLOPETIM =  ar2(WRESULT / 60)
                               VALEUR = [M:MTO1]CPLOPETIM
                               When "CPLSETTIM" : [M:MTO1]CPLSETTIM =  ar2(WRESULT / 60)
                               VALEUR = [M:MTO1]CPLSETTIM
                          Endcase
                 When 2 :
                          Case WZONE :
                               When "CPLOPETIM" : [M:MTO1]CPLOPETIM = ar2(WRESULT)
                               VALEUR =  [M:MTO1]CPLOPETIM
                               When "CPLSETTIM" : [M:MTO1]CPLSETTIM = ar2(WRESULT)
                               VALEUR = [M:MTO1]CPLSETTIM
                          Endcase

            Endcase
     When "MTK1" :
            Case [M:MTK1]TIMUOMCOD(nolign-1)
                 When 1 :
                          Case WZONE :
                               When "CPLOPETIM" : [M:MTK1]CPLOPETIM(nolign-1) = ar2(WRESULT / 60)
                               VALEUR =  [M:MTK1]CPLOPETIM(nolign-1)
                               When "CPLSETTIM" : [M:MTK1]CPLSETTIM(nolign-1) = ar2(WRESULT / 60)
                               VALEUR =  [M:MTK1]CPLSETTIM(nolign-1)
                          Endcase
                 When 2 :
                          Case WZONE :
                               When "CPLOPETIM" : [M:MTK1]CPLOPETIM(nolign-1) = ar2(WRESULT)
                               VALEUR = [M:MTK1]CPLOPETIM(nolign-1)
                               When "CPLSETTIM" : [M:MTK1]CPLSETTIM(nolign-1) = ar2(WRESULT)
                               VALEUR = [M:MTK1]CPLSETTIM(nolign-1)
                          Endcase
            Endcase
     When "MBO" :
            Case [M:MBO]TIMUOMCOD(nolign-1)
                 When 1 :
                          Case WZONE :
                               When "CPLOPETIM" : [M:MBO]CPLOPETIM(nolign-1) = ar2(WRESULT / 60)
                               VALEUR =  [M:MBO]CPLOPETIM(nolign-1)
                               When "CPLSETTIM" : [M:MBO]CPLSETTIM(nolign-1) = ar2(WRESULT / 60)
                               VALEUR =  [M:MBO]CPLSETTIM(nolign-1)
                          Endcase
                 When 2 :
                          Case WZONE :
                               When "CPLOPETIM" : [M:MBO]CPLOPETIM(nolign-1) = ar2(WRESULT)
                               VALEUR = [M:MBO]CPLOPETIM(nolign-1)
                               When "CPLSETTIM" : [M:MBO]CPLSETTIM(nolign-1) = ar2(WRESULT)
                               VALEUR = [M:MBO]CPLSETTIM(nolign-1)
                          Endcase
            Endcase
Endcase
Return

################################################################################
# CALQTEPROD : Calcul d'une quantité productible                               #
################################################################################
$INI_CALQTEPROD
Local Char     WVCRNUM   : WVCRNUM  = PARAM(1)

If WVCRNUM = ""  : FIN = 1 : Return : Endif
Read [F:MFG]MFG0 = WVCRNUM
If fstat : Raz [F:MFG] : FIN = 1 : Return : Endif
#cela ne fonctionne pas si multi article lancé
If [F:MFG]ITMLINNBR > 1 : FIN = 1 : Return : Endif
Return

################################################################################
$INID_CALQTEPROD
Local Char     WVCRNUM   : WVCRNUM  = PARAM(1)
Global Decimal GAVAMFG : GAVAMFG = 9999999999

Raz [M:MTI2]
For [F:MFM]MFM0 Where MFGNUM = [M:MTK0]MFGNUM & [F:MFM]MATSTA <> 4
        Call CAL_AVAMFGQTY From MTKLIB
Next
[M:MTI2]STU = [F:MFG]STU
Call QTEARR([M:MTI2]AVAMFGQTY,[M:MTI2]STU) From TRTDIV
If [M:MTI2]AVAMFGQTY < 0 : [M:MTI2]AVAMFGQTY = 0 : Endif
Affzo [M:MTI2]AVAMFGQTY
Return

#-------------------------------------------------
$TERMINE_CALQTEPROD
If  [F:MFG]RMNEXTQTY > 0
    Call OUINON(mess(50,190,1),OK) From GESECRAN
    If OK = 2 : Gosub REAJUST_TOUT From MTKLIB
    Endif
Endif
Return

