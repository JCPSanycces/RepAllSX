#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation EDISDHTR                                                     #
# Author : JUCON                                                              #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"           : Gosub AREAD_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


$AREAD_AFTER
  Gosub GETVALPARAMURL From TRTFUNEDI
Return

#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC #114721
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  Local Integer I, J
 #110811_US9 SITE AUTHORIZATION
  Local Integer WOK, WOKK : WOK     = [V]CST_AOK
  Local Integer WSTATUS   : WSTATUS = [V]CST_AERROR

  WOKK=func EDIRUN_CSTD.CHECK_AUTHORIZATION_SITE(this.ACTX.USER,WCATCOD,this.SDH.SALFCY,WCATACT)

  If WOKK=0
    WERR=mess(63,133,1)  #Site not authorized
    WSTATUS = [V]CST_AERROR
  Else
    Case WCATACT
      When 1 :
        Case WPARCOD
          When "TENOR" : Gosub TENOR_ISSUE
          When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
        Endcase
      When 2 :
        Case WPARCOD
          When "TENOR" : Gosub TENOR_RECEIPT
          When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
        Endcase
    Endcase
  Endif
#/110811_US9
  ARET_VALUE = WSTATUS
Return



################################################################################
$TENOR_ISSUE
  Local Char WCODE(20), WREP(20), WPROP(25) # 114721
  WREP=right$(this.AINF.NAMCLA,3)

  #Filling E property (Identifier of head record)
  this.ET="ET"

#   Init Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
  Local Char NUMDOC(20)
  NUMDOC=this.SDH.SDHNUM
#   End Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)


  # Searching EDITENOR code from Sales site (EDISALFCY)
  #WCODE=func TRTFUNEDI.INV_EDICODE_FCY(this.SDH.SALFCY,WPARCOD) # 110811_US8
  #this.EDISALFCY=left$(WCODE,17)
  WCODE=func TRTFUNEDI.INV_EDICODE_SE(this.SDH.SALFCY,this.SDH.CPY,WPARCOD,this.SDH.BPCORD) # 110811_US8 : EDI code researsh algo
  this.IDSELLER=left$(WCODE,17)# 110811_US8 : EDI code researsh algo

  Local File FACILITY [FCY]

  Read [FCY]FCY0=this.SDH.SALFCY
  If fstat=[V]CST_AOK
    this.FCYNAME=[F:FCY]FCYNAM
  Endif

  LogicClose File [FCY]

  # Searching EDITENOR code from Stock site (EDISTOFCY)
  #WCODE=func TRTFUNEDI.INV_EDICODE_FCY(this.SDH.STOFCY,WPARCOD)
  WCODE=func TRTFUNEDI.INV_EDICODE_SE(this.SDH.STOFCY,this.SDH.CPY,WPARCOD,this.SDH.BPCORD) # 110811_US8 : EDI code researsh algo
  this.EDISTOFCY=left$(WCODE,17)

  # Searching EDIBPCCOD property
  Local File EDIBPRPAR [EBP]
  Read [EBP]EBP0=1;this.SDH.BPCORD;this.SDH.BPAADD;WPARCOD
  If fstat=[V]CST_AOK
   # this.EDIBPCCOD=[F:EBP]EXCEDICOD
#    this.IDBUYER=[F:EBP]EXCEDICOD # 110811_US8
    If [F:EBP]EDIORDCOD<>"" #X3-67105 Operational points (JUCON 19/12/17)
      this.IDBUYER=[F:EBP]EDIORDCOD
    Else
      this.IDBUYER=[F:EBP]EXCEDICOD
    Endif
  Endif
   # Searching EDIBPTCOD property
  Filter [EBP] Where BPANUM=this.SDH.BPTNUM and PARCOD=WPARCOD
  Read First
  If fstat=[V]CST_AOK
    this.EDIBPTCOD=[F:EBP]EXCEDICOD
  Endif

  LogicClose File [EBP]

  #Formating EDISHIDAT property
  this.EDISHIDAT=format$("D:YYYYMMDD",this.SDH.SHIDAT)

  #Formating EDIDLVDAT property
  this.EDIDLVDAT=format$("D:YYYYMMDD",this.SDH.DLVDAT)

  #Searching EDICPY code
  Local File EDICPYPAR [ECP]

  Read [ECP]ECP0=this.SDH.CPY;WPARCOD
  If fstat=[V]CST_AOK
    this.EDICPY=[F:ECP]EXCEDICOD
  Endif

  LogicClose File [ECP]

 #Filling CPYNAME & CPYCRN properties
  Local File COMPANY [CPY]

  Read [CPY]CPY0=this.SDH.CPY
  If fstat=[V]CST_AOK
    this.CPYNAME=[F:CPY]CPYNAM
    this.CPYCRN=[F:CPY]CRN

  Endif
  LogicClose File [CPY]

  #Filling EDIBPCNAME property
  If maxtab(this.SDH.C_BPDNAM)>0
    If this.SDH.C_BPDNAM(1).BPDNAM<>""
      this.EDIBPCNAME=this.SDH.C_BPDNAM(1).BPDNAM
    Endif
  Endif
  If this.EDIBPCNAME=""
    Local File BPDLVCUST [BPD]
    Read [BPD]BPD0=this.SDH.BPCORD;this.SDH.BPAADD
    If fstat=[V]CST_AOK
      this.EDIBPCNAME=[F:BPD]BPDNAM(0)
    Endif
    LogicClose File [BPD]
  Endif

  #Searching BPTNAME property
  Local File BPCARRIER [BPT]

  Read [BPT]BPT0=this.SDH.BPTNUM
  If fstat=[V]CST_AOK
    this.BPTNAME=[F:BPT]BPTNAM
  Endif

  LogicClose File [BPT]

  #Filling Address properties
  Local File BPADDRESS [BPA]
  #company
  Filter [BPA] Where BPATYP=2 and BPANUM=this.SDH.CPY and BPAADDFLG=2
  Read First
  If fstat=[V]CST_AOK
      this.CPYSAT     =[F:BPA]SAT
      this.CPYCITY    =[F:BPA]CTY
      this.CPYPOSCOD  =[F:BPA]POSCOD
      this.CPYADDLIG  =[F:BPA]BPAADDLIG(0)
  Endif
  Filter [BPA]

  #Mail site
  Filter [BPA] Where BPATYP=3 and BPANUM=this.SDH.SALFCY and BPAADDFLG=2
  Read First
  If fstat=[V]CST_AOK
    this.EDIFCYMAIL=[F:BPA]WEB(0)
  Endif
  Filter [BPA]

  #Mail BPCORD
  Read [BPA]BPA0=1;this.SDH.BPCORD;this.SDH.BPAADD
  If fstat=[V]CST_AOK
    this.EDIBPCMAIL   =[F:BPA]WEB(0)
  Endif

  # delivery
  If maxtab(this.SDH.C_BPDADDLIG)>0
    this.EDIBPDSAT    =this.SDH.BPDSAT
    this.EDIBPDCITY   =this.SDH.BPDCTY
    this.EDIBPDPOSCOD =this.SDH.BPDPOSCOD
    Case maxtab(this.SDH.C_BPDADDLIG)
      When 1: this.EDIBPDADDLIG =this.SDH.C_BPDADDLIG(1).BPDADDLIG
      When 2: this.EDIBPDADDLIG =this.SDH.C_BPDADDLIG(1).BPDADDLIG
              this.EDIBPDADLIG1 =this.SDH.C_BPDADDLIG(2).BPDADDLIG    #111374 EDI manual QA review
      When 3: this.EDIBPDADDLIG =this.SDH.C_BPDADDLIG(1).BPDADDLIG
              this.EDIBPDADLIG1 =this.SDH.C_BPDADDLIG(2).BPDADDLIG    #111374
              this.EDIBPDADLIG2 =this.SDH.C_BPDADDLIG(3).BPDADDLIG    #111374
    Endcase
  Else
    Read [BPA]BPA0=1;this.SDH.BPCORD;this.SDH.BPAADD
    If fstat=[V]CST_AOK
      this.EDIBPDSAT    =[F:BPA]SAT
      this.EDIBPDCITY   =[F:BPA]CTY
      this.EDIBPDPOSCOD =[F:BPA]POSCOD
      this.EDIBPDADDLIG =[F:BPA]BPAADDLIG(0)
      this.EDIBPDADLIG1 =[F:BPA]BPAADDLIG(1)
      this.EDIBPDADLIG2 =[F:BPA]BPAADDLIG(2)
    Endif
  Endif

  #invoice
  If maxtab(this.SDH.C_BPIADDLIG)>0
    this.EDIBPISAT    =this.SDH.BPISAT
    this.EDIBPICITY   =this.SDH.BPICTY    # SAM 111252
    this.EDIBPIPOSCOD =this.SDH.BPIPOSCOD
    this.EDIBPIADDLIG =this.SDH.C_BPIADDLIG(1).BPIADDLIG
  Else
    Read [BPA]BPA0=1;this.SDH.BPCINV;this.SDH.BPAINV
    If fstat=[V]CST_AOK
      this.EDIBPISAT    =[F:BPA]SAT
      this.EDIBPICITY   =[F:BPA]CTY
      this.EDIBPIPOSCOD =[F:BPA]POSCOD
      this.EDIBPIADDLIG =[F:BPA]BPAADDLIG(0)
    Endif
  Endif
  LogicClose File [BPA]

  #Searching EDIORDNUM property
  Local Char WSOHNUM(20)
  Local Date WSOHDAT

  If this.SDH.SOHNUM<>"": WSOHNUM=this.SDH.SOHNUM: Endif
  this.EDIORDNUM= WSOHNUM
  If WSOHNUM=""
    For I=1 To maxtab(this.SDH.SDD)
      If this.SDH.SDD(I).SOHNUM<>"": WSOHNUM=this.SDH.SDD(I).SOHNUM: Break: Endif
    Next
  Endif

  If WSOHNUM<>""
    this.EDIORDCUS= func TRTFUNEDI.SDH_ORDNUM(WSOHNUM,1)
    this.EDIORDDAT= func TRTFUNEDI.SDH_ORDNUM(WSOHNUM,2)
  Endif


#####################################
#####      TEXT OF HEAD       #######
#####################################
#Filling properties for Notes file
Local Integer WNHSEQ, WOKK
Local Char WNOTES(100)

If this.SDH.SDHTEX1<>"" or this.SDH.SDHTEX2<>""
  For N=1 To 8
    Raz WNOTES
    WOKK=func TRTFUNEDI.SDH_NUMOBS(this.SDH.SDHNUM,N,WNOTES)
    If WOKK=1
      this.TX="TX"
      Assign ("this.NOTE"+num$(N))With WNOTES
    Endif
  Next
Endif

#####################################
#####          LINES          #######
#####################################
  #Filling R_SDD collection
  Local Integer I, K, WSEQ, WPCK, WNSSEQ
  For I=1 To maxtab(this.SDH.SDD)
    WSEQ = fmet this.ADDLINE('R_SDD',[V]CST_ALASTPOS)
    Raz WPCK
#       # identifier property (constant in the lines)
    this.R_SDD(WSEQ).LI="LI"

    this.R_SDD(WSEQ).EDITYPUC="BOX" # Issue 114721
    this.R_SDD(WSEQ).EDINUMUC="1"   # Issue 114721
    this.R_SDD(WSEQ).EDINOMUC= num$(this.SDH.PACNBR)   # Issue 114721
    this.R_SDD(WSEQ).BLANKLIN=this.BLANK
    If this.SDH.SDD(I).SOHNUM<>""
      this.R_SDD(WSEQ).CUSORDNUM= func TRTFUNEDI.SDH_ORDNUM(this.SDH.SDD(I).SOHNUM,1)
 # Issue 106776 New EDI field LINORDNUM
 #     this.R_SDD(WSEQ).LINORDNUM= this.SDH.SDD(I).SOHNUM
      this.R_SDD(WSEQ).LINORDNUM= func TRTFUNEDI.SDH_SOHLINORI(this.SDH.SDD(I).SOHNUM,I,WSEQ)
      this.R_SDD(WSEQ).EDISOPNUM=this.SDH.SDD(I).SOHNUM
 #/ 106776
    Endif

    #Filling EDINETWEI property
    Local Decimal WLINWEI
    If toupper(this.SDH.SDD(I).WEU)<>"KG"
      Local File TABCOEFF [TCO]
      Read [TCO]TCO0="KG";this.SDH.SDD(I).WEU
      If fstat=[V]CST_AOK:
        WLINWEI=ar2((this.SDH.SDD(I).UNTWEI*[F:TCO]COEUOM)*this.SDH.SDD(I).QTY)
      Endif
      LogicClose File [TCO]
    Else
      WLINWEI=ar2(this.SDH.SDD(I).UNTWEI*this.SDH.SDD(I).QTY)
    Endif
    this.R_SDD(WSEQ).EDINETWEI= num$(WLINWEI)

    #Filling GROLINWEI property
    Local Decimal WPACKWEI
    Local Shortint WNBPACK
    Local File TABPACKAGE [TPA]

    If this.SDH.SDD(I).PCKCAP<>0
      WNBPACK=this.SDH.SDD(I).QTY/this.SDH.SDD(I).PCKCAP
    Else
      WNBPACK=1
    Endif

    If this.SDH.SDD(I).PCK<>""
      Read [TPA]TPA0=this.SDH.SDD(I).PCK
      If fstat=[V]CST_AOK
        If toupper([F:TPA]WEU)="KG"
          WPACKWEI=[F:TPA]PCKWEI*WNBPACK
        Else
          Local File TABCOEFF [TCO]
          Read [TCO]TCO0="KG";[F:TPA]WEU
          If fstat=[V]CST_AOK
            WPACKWEI = ar2(([F:TPA]PCKWEI*[F:TCO]COEUOM)*WNBPACK)
          Endif
          LogicClose File [TCO]
        Endif
      Endif
    Endif
    this.R_SDD(WSEQ).GROLINWEI= val(this.R_SDD(WSEQ).EDINETWEI)+WPACKWEI

    LogicClose File [TPA]

    this.R_SDD(WSEQ).EDISOPLIN=num$(this.SDH.SDD(I).SOPLIN)
    this.R_SDD(WSEQ).EDIITMDES=this.SDH.SDD(I).ITMDES
    #this.R_SDD(WSEQ).SDDQTY   =num$(this.SDH.SDD(I).QTY)
    this.R_SDD(WSEQ).EDISAU   =this.SDH.SDD(I).SAU # 106776
    this.R_SDD(WSEQ).EDIITMREF=this.SDH.SDD(I).ITMREF
    this.R_SDD(WSEQ).EDILOT   =this.SDH.SDD(I).LOT
    this.R_SDD(WSEQ).EDIWEI   =this.SDH.SDD(I).WEU

     # Transcoding EDISAU  properties (in STD table 228) # Init SAM 106776
      Local File ASHWPAR [ASWP]
      Filter [ASWP] Where CODREP=WREP and CODLNK="EDISAU"
      Read First
      If fstat=[V]CST_AOK
        Local Char WNODE(20), WTYP(20)
        Local Integer WTAB
       WTYP=num$(this.SDH.SDD(I).SAU)
       WTAB=val([F:ASWP]VALEUR)
       WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
       this.R_SDD(WSEQ).EDISAU= left$(WNODE,3)
       If this.R_SDD(WSEQ).EDISAU="": this.R_SDD(WSEQ).EDISAU=this.SDH.SDD(I).SAU : Endif
      Endif
      LogicClose File [ASWP]
#/106776
    Local File ITMMASTER [ITM]
    Read [ITM]ITM0=this.SDH.SDD(I).ITMREF
    If fstat= [V]CST_AOK
      this.R_SDD(WSEQ).EANCOD=[F:ITM]EANCOD                           ####R_SDD.EANCOD
      this.R_SDD(WSEQ).REFITMBPC=func TRTFUNEDI.INV_REFCLI(this.SDH.BPCORD, this.SDH.SDD(I).ITMREF) ####R_SDD.REFITMBPC
    Endif
    LogicClose File [ITM]
    Local File SPACKD [SPD]
    Filter [SPD] Where VCRNUM=this.SDH.SDHNUM and VCRLIN=this.SDH.SDD(I).SDDLIN
    If rowcount([SPD])>0: WPCK=1: Endif
    K=I
    If WPCK=1                ### generation of lines according to SPACKD
      For [SPD]
        If K>WSEQ: K= fmet this.ADDLINE('R_SDD',[V]CST_ALASTPOS) :Else K=WSEQ: Endif
        this.R_SDD(K).LI        = this.R_SDD(WSEQ).LI
        this.R_SDD(K).BLANKLIN  = this.R_SDD(WSEQ).BLANKLIN
        this.R_SDD(K).LINORDNUM = this.R_SDD(WSEQ).LINORDNUM
        this.R_SDD(K).CUSORDNUM = this.R_SDD(WSEQ).CUSORDNUM
        this.R_SDD(K).EDISOPLIN = this.R_SDD(WSEQ).EDISOPLIN
        this.R_SDD(K).REFITMBPC = this.R_SDD(WSEQ).REFITMBPC
        this.R_SDD(K).EDIITMDES = this.R_SDD(WSEQ).EDIITMDES
# ISSUE 114721 Decimal separator in generated File
        WPROP=format$("N0:12.2#",abs([F:SPD]QTYPCU))
        this.R_SDD(K).SDDQTY = func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#       this.R_SDD(K).SDDQTY    = num$(abs([F:SPD]QTYPCU))
        this.R_SDD(K).EDISAU    = this.R_SDD(WSEQ).EDISAU # SAM 106776
        this.R_SDD(K).EANCOD    = this.R_SDD(WSEQ).EANCOD
        this.R_SDD(K).EDIITMREF = this.R_SDD(WSEQ).EDIITMREF
        this.R_SDD(K).EDILOT    = [F:SPD]LOT
        this.R_SDD(K).EDINETWEI = num$([F:SPD]NETWEI)
        this.R_SDD(K).EDIWEI    = [F:SPD]WEU

        Local File TABPACKAGE [TPA]

        If [F:SPD]PCK<>"" and WNBPACK<>0
          Read [TPA]TPA0=[F:SPD]PCK
          If toupper([F:TPA]WEU)="KG"
            WPACKWEI=[F:TPA]PCKWEI
          Else
            Local File TABCOEFF [TCO]
            Read [TCO]TCO0="KG";[F:TPA]WEU
            If fstat=[V]CST_AOK
              WPACKWEI = ar2(([F:TPA]PCKWEI*[F:TCO]COEUOM))
            Endif
            LogicClose File [TCO]
          Endif
        Endif
        this.R_SDD(K).GROLINWEI=val(this.R_SDD(K).EDINETWEI)+WPACKWEI
        LogicClose File [TPA]
# ISSUE 114721 Decimal separator in generated File
#       WPROP=format$("N0:12.2#",abs([F:SPD]QTYPCU))
#       this.R_SDD(K).EDIQTYPCU = func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        this.R_SDD(K).EDIQTYPCU = num$(abs([F:SPD]QTYPCU))
#        this.R_SDD(K).EDIPCU    = [F:SPD]PCU # 106776
        this.R_SDD(K).EDIPACNUM = [F:SPD]PACNUM

        # Transcoding EDIPCU  properties (in STD table 228) # Init SAM 106776
        Local File ASHWPAR [ASWP]
        Filter [ASWP] Where CODREP=WREP and CODLNK="EDISAU"
        Read First
        If fstat=[V]CST_AOK
          Local Char WNODE(20), WTYP(20)
          Local Integer WTAB
         WTYP=num$([F:SPD]PCU)
         WTAB=val([F:ASWP]VALEUR)
         WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
         this.R_SDD(K).EDIPCU= left$(WNODE,3)
         If this.R_SDD(K).EDIPCU="": this.R_SDD(K).EDIPCU=[F:SPD]PCU : Endif
        Endif
        LogicClose File [ASWP]

        #Writing stock line
        Local File STOJOU [STJ]
        Read [STJ]STJ1=this.SDH.SDD(I).STOFCY;4;this.SDH.SDHNUM;this.SDH.SDD(I).SDDLIN
        If fstat=[V]CST_AOK
          WNSSEQ = fmet this.ADDLINE('R_STO',[V]CST_ALASTPOS)
          this.R_STO(WNSSEQ).ST="ST"
          If format$("D:YYYYMMDD",[F:STJ]SHLDAT)<> "29991231"
            this.R_STO(WNSSEQ).STOSHLDAT = format$("D:YYYYMMDD",[F:STJ]SHLDAT)
          Else
            this.R_STO(WNSSEQ).STOSHLDAT ="00000000"
          Endif

# ISSUE 114721 Decimal separator in generated File
         WPROP=format$("N0:12.2#",abs([F:SPD]QTYPCU))
         this.R_STO(WNSSEQ).STOQTY = func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#          this.R_STO(WNSSEQ).STOQTY = abs([F:SPD]QTYPCU)
#          this.R_STO(WNSSEQ).STOSAU = [F:SPD]SAU # 106776
          this.R_STO(WNSSEQ).STOLOT = [F:SPD]LOT
          this.R_STO(WNSSEQ).STOSER = [F:SPD]SERNUM
          LogicClose File [STJ]

         # Transcoding STOSAU  properties (in STD table 228) # Init SAM 106776
          Local File ASHWPAR [ASWP]
          Filter [ASWP] Where CODREP=WREP and CODLNK="EDISAU"
          Read First
          If fstat=[V]CST_AOK
            Local Char WNODE(20), WTYP(20)
            Local Integer WTAB
           WTYP=num$([F:SPD]SAU)
           WTAB=val([F:ASWP]VALEUR)
           WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
           this.R_STO(WNSSEQ).STOSAU= left$(WNODE,3)
           If this.R_STO(WNSSEQ).STOSAU="": this.R_STO(WNSSEQ).STOSAU=[F:SPD]SAU : Endif
         Endif
         LogicClose File [ASWP]
         # End SAM 106776
        Endif

        Gosub WRI_LINTEX

        K+=1
      Next

    Else
      Local File STOJOU [STJ]

      Filter [STJ] Where STOFCY=this.SDH.SDD(I).STOFCY and VCRTYP=4 and VCRNUM=this.SDH.SDHNUM and VCRLIN=this.SDH.SDD(I).SDDLIN
      For [STJ]
        If K>WSEQ: K= fmet this.ADDLINE('R_SDD',[V]CST_ALASTPOS) :Else K=WSEQ: Endif
        this.R_SDD(K).LI        = this.R_SDD(WSEQ).LI
        this.R_SDD(K).BLANKLIN  = this.R_SDD(WSEQ).BLANKLIN
        this.R_SDD(K).LINORDNUM = this.R_SDD(WSEQ).LINORDNUM
        this.R_SDD(K).CUSORDNUM = this.R_SDD(WSEQ).CUSORDNUM
        this.R_SDD(K).EDISOPLIN = this.R_SDD(WSEQ).EDISOPLIN
        this.R_SDD(K).REFITMBPC = this.R_SDD(WSEQ).REFITMBPC
        this.R_SDD(K).EDIITMDES = this.R_SDD(WSEQ).EDIITMDES
# ISSUE 114721 Decimal separator in generated File
        WPROP=format$("N0:12.2#",abs([F:STJ]QTYSTU))
        this.R_SDD(K).SDDQTY = func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#        this.R_SDD(K).SDDQTY    = num$(abs([F:STJ]QTYSTU))
        this.R_SDD(K).EDISAU    = this.R_SDD(WSEQ).EDISAU # 106776
        this.R_SDD(K).EANCOD    = this.R_SDD(WSEQ).EANCOD
        this.R_SDD(K).EDIITMREF = this.R_SDD(WSEQ).EDIITMREF
        this.R_SDD(K).EDILOT    = [F:STJ]LOT
        this.R_SDD(K).EDINETWEI = num$([F:SPD]NETWEI)
        this.R_SDD(K).EDIWEI    = [F:SPD]WEU

        Local File TABPACKAGE [TPA]

        If [F:SPD]PCK<>"" and WNBPACK<>0
          Read [TPA]TPA0=[F:SPD]PCK
          If toupper([F:TPA]WEU)="KG"
            WPACKWEI=[F:TPA]PCKWEI
          Else
            Local File TABCOEFF [TCO]
            Read [TCO]TCO0="KG";[F:TPA]WEU
            If fstat=[V]CST_AOK
              WPACKWEI = ar2(([F:TPA]PCKWEI*[F:TCO]COEUOM))
            Endif
            LogicClose File [TCO]
          Endif
        Endif
        this.R_SDD(K).GROLINWEI=val(this.R_SDD(K).EDINETWEI)+WPACKWEI
        LogicClose File [TPA]
# ISSUE 114721 Decimal separator in generated File
       WPROP=format$("N0:12.2#",abs([F:STJ]QTYSTU))
       this.R_SDD(K).EDIQTYPCU = func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#        this.R_SDD(K).EDIQTYPCU = num$(abs([F:STJ]QTYSTU))
#        this.R_SDD(K).EDIPCU    = [F:STJ]PCU # 106776
        this.R_SDD(K).EDIPACNUM = ""

     # Transcoding EDIPCU  properties (in STD table 228) # Init SAM 106776
        Local File ASHWPAR [ASWP]
        Filter [ASWP] Where CODREP=WREP and CODLNK="EDISAU"
        Read First
        If fstat=[V]CST_AOK
          Local Char WNODE(20), WTYP(20)
          Local Integer WTAB
         WTYP=num$([F:STJ]PCU)
         WTAB=val([F:ASWP]VALEUR)
         WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
         this.R_SDD(K).EDIPCU= left$(WNODE,3)
         If this.R_SDD(K).EDIPCU="": this.R_SDD(K).EDIPCU=[F:STJ]PCU : Endif
        Endif
        LogicClose File [ASWP]

        #Writing stock line in SDDSTO collection
        WNSSEQ = fmet this.ADDLINE('R_STO',[V]CST_ALASTPOS)
        # identifier property (constant in stock lines)
        this.R_STO(WNSSEQ).ST="ST"
        If format$("D:YYYYMMDD",[F:STJ]SHLDAT)<> "29991231"
          this.R_STO(WNSSEQ).STOSHLDAT = format$("D:YYYYMMDD",[F:STJ]SHLDAT)
        Else
          this.R_STO(WNSSEQ).STOSHLDAT ="00000000"
        Endif
# ISSUE 114721 Decimal separator in generated File
    WPROP=format$("N0:12.2#",abs([F:STJ]QTYSTU))
    this.R_STO(WNSSEQ).STOQTY =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#        this.R_STO(WNSSEQ).STOQTY = abs([F:STJ]QTYSTU) # 114721
#        this.R_STO(WNSSEQ).STOSAU = [F:STJ]STU # 106776
        this.R_STO(WNSSEQ).STOLOT = [F:STJ]LOT
        this.R_STO(WNSSEQ).STOSER = [F:STJ]SERNUM

        # Transcoding STOSAU  properties (in STD table 228) # Init SAM 106776
        Local File ASHWPAR [ASWP]
        Filter [ASWP] Where CODREP=WREP and CODLNK="EDISAU"
        Read First
        If fstat=[V]CST_AOK
          Local Char WNODE(20), WTYP(20)
          Local Integer WTAB
          WTYP=num$([F:STJ]STU)
          WTAB=val([F:ASWP]VALEUR)
          WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
          this.R_STO(WNSSEQ).STOSAU= left$(WNODE,3)
          If this.R_STO(WNSSEQ).STOSAU="": this.R_STO(WNSSEQ).STOSAU=[F:STJ]STU : Endif
        Endif
        LogicClose File [ASWP]
        # End SAM 106776

        Gosub WRI_LINTEX

        K+=1
      Next
      LogicClose File [STJ]
    Endif
    LogicClose File [SPD]
  Next

  # Ini 112148
  Local Char WREST(250)
  WREST=mess(280,143,1)+": OK" # Displayed properties updated
  Call ADDDIAGNOSE(this.ACTX,WREST,[V]CST_AINFO) From ASYRASYNC
  # End 112148

  # Init Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
  WOK= func EDILIBPDF.GET_FLOW_PDF(NUMDOC)
  If WOK=0
    Gosub PRINT_CLASSIC From EDILIBPDF
    If WSTATUS<>[V]CST_AOK
      If WERR="": WERR=mess(207,2006,1): Endif # Error generating the attachment
    Else
      WSTATUS=[V]CST_AINFO
      WERR=mess(208,2006,1) # Attachment successfully generated
    Endif
    Call ADDDIAGNOSE(this.ACTX,WERR,WSTATUS) From ASYRASYNC
    If WTEST=2
      WSTATUS=[V]CST_AINFO
      WERR=mess(213,2006,1) # Email protocol is not managed in test mode
      Call ADDDIAGNOSE(this.ACTX,WERR,WSTATUS) From ASYRASYNC
    Endif
  Endif

  # End Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
  WSTATUS=[V]CST_AOK
Return

################################################################################
$TENOR_RECEIPT
Return

################################################################################
$WRI_LINTEX
  #Filling text of line
  Local Char WTEXLIN (100)(8), WPACNUM(20)
  Local Integer WOK, WNBL

  WOK=func TRTFUNEDI.SDH_TENOR_NUMOBSL(this.SDH.SDHNUM,this.SDH.SDD(I).SDDLIN,WPACNUM,WTEXLIN())

  If WOK=1
    Local Integer WNLSEQ, L
    this.R_STO(WNSSEQ).TL="TL"
    For L=0 To 3
      If WTEXLIN(L)<>""
         Assign ("this.R_STO("+num$(WNSSEQ)+").NOTLIN"+num$(L+1))With WTEXLIN(L)
      Endif
    Next
  Endif

  Raz WOK

  WPACNUM=this.R_SDD(K).EDIPACNUM

  If WPACNUM<>""
    WOK=func TRTFUNEDI.SDH_TENOR_NUMOBSL(this.SDH.SDHNUM,this.SDH.SDD(I).SDDLIN,WPACNUM,WTEXLIN())
  Endif

  If WOK=1
    this.R_STO(WNSSEQ).TL="TL"
    For L=4 To 7
      If WTEXLIN(L)<>""
        Assign ("this.R_STO("+num$(WNSSEQ)+").NOTLIN"+num$(L+1))With WTEXLIN(L)
      Endif
    Next
  Endif

Return

