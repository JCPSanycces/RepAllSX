#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque VCONGE 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone DATDEB
mkstat = 0
zoncou = "DATDEB"
indice = 0
If varmode([M]DATDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATDEB" : Gosub ACTION From =IMPTRT
 Endif
 If [M]DATDEB=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DATDEB" : GZNUM = 55304 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_DATDEB([M]DATDEB) From VCONGE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DATDEB" : GZNUM = 55304 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone DATFIN
mkstat = 0
zoncou = "DATFIN"
indice = 0
If varmode([M]DATFIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATFIN" : Gosub ACTION From =IMPTRT
 Endif
 If [M]DATFIN=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DATFIN" : GZNUM = 55305 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_DATFIN([M]DATFIN) From VCONGE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DATFIN" : GZNUM = 55305 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTCPY"
 Call CONTSOC([M]CPY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CPY","!",[M]CPY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CPY([M]CPY) From VCONGE
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone FCY
mkstat = 0
zoncou = "FCY"
indice = 0
If varmode([M]FCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]FCY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!",[M]FCY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_FCY([M]FCY) From VCONGE
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone SRV
mkstat = 0
zoncou = "SRV"
indice = 0
If varmode([M]SRV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SRV" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("SRV","!",[M]SRV,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SRV" : GZNUM = 18735 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_SRV([M]SRV) From VCONGE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SRV" : GZNUM = 18735 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone POP
mkstat = 0
zoncou = "POP"
indice = 0
If varmode([M]POP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POP" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTPOP"
 Call CONTPOP([M]POP,GCURLEG) From SUBPOP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("POP","!",[M]POP,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_POP([M]POP) From VCONGE
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone MATRI
mkstat = 0
zoncou = "MATRI"
If varmode([M]MATRI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MATRI" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DROITEMP"
 Call DROIT([M]MATRI(indice),"","","") From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MATRI" : GZNUM = 10793 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EML","!",[M]MATRI(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "MATRI" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NOM
mkstat = 0
zoncou = "NOM"
If varmode([M]NOM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NOM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DAT
mkstat = 0
zoncou = "DAT"
If varmode([M]DAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DATI
mkstat = 0
zoncou = "DATI"
If varmode([M]DATI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATI" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DUREE
mkstat = 0
zoncou = "DUREE"
If varmode([M]DUREE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DUREE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TYPJOU
mkstat = 0
zoncou = "TYPJOU"
IMPENT = [M]TYPJOU(indice)
If varinit([M]TYPJOU,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPJOU,indice)=0
 [M]TYPJOU(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPJOU" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPJOU(indice)
 Endif
Endif
[M]TYPJOU(indice) = IMPENT

## Zone DURAFF
mkstat = 0
zoncou = "DURAFF"
If varmode([M]DURAFF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DURAFF" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "VCONGE"
Return

