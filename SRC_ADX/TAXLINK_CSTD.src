#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe TAXLINK
#######################################################################################
End

#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AREAD_AFTER"             : Gosub AREAD_AFTER
          When "AINIT"                   : Gosub AINIT
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
        When "LOAD_TO_TLK_FILE"        : Gosub LOAD_TO_TLK_FILE
        When "INIT_TSCCODADI"          : Gosub INIT_TSICODADI
  Endcase
Return
#--------------------------------------
#######################################################################################
$PROPERTIES
#  Case [L]CURPRO
#  Endcase
Return

#######################################################################################
$AREAD_AFTER
Local Integer IRET

  IRET = fmet this.INIT_TSICODADI()
Return

#######################################################################################
$AINIT
Local Integer IRET

  IRET = fmet this.INIT_TSICODADI()
Return

#-------------------------------------------------------
#--Method used to load properties from class TAXLINK to [F:TLK]
$LOAD_TO_TLK_FILE
Local Integer IJ

  If dim([F:TLK]CPY)<1
    [L]ASTATUS = fmet this.ASETERROR ("", "Data Class TAXLINK : Method call LOAD_TO_SPK_FILE no [F:TLK] file opened", [V]CST_AERROR)
    Return
  Endif

  SetInstance [F:TLK] With this
  #--Parcours des collections
  #--C_GRP
  For IJ=1 To maxtab(this.C_GRP)
    If dim([F:TLK]GRP(IJ-1))<1 : Break : Endif

    [F:TLK]GRP(IJ-1) = "" #AVOID.ACHAR

    If this.C_GRP(IJ)<>null
      [F:TLK]GRP(IJ-1) = this.C_GRP(IJ).GRP
    Endif

  Next IJ

  #--C_SATTAX
  For IJ=1 To maxtab(this.C_SATTAX)
    If dim([F:TLK]SATTAX(IJ-1))<1 : Break : Endif

    [F:TLK]SATTAX(IJ-1)    = "" #AVOID.ACHAR
    [F:TLK]FLGSATTAX(IJ-1) = [V]CST_ANO

    If this.C_SATTAX(IJ)<>null
      [F:TLK]SATTAX(IJ-1)    = this.C_SATTAX(IJ).SATTAX
      [F:TLK]FLGSATTAX(IJ-1) = this.C_SATTAX(IJ).FLGSATTAX
    Endif

  Next IJ

  #--C_TSICOD
  For IJ=1 To maxtab(this.C_TSICOD)
    If dim([F:TLK]TSICOD(IJ-1))<1 : Break : Endif

    [F:TLK]TSICOD(IJ-1) = "" #AVOID.ACHAR

    If this.C_TSICOD(IJ)<>null
      [F:TLK]TSICOD(IJ-1) = this.C_TSICOD(IJ).TSICOD
    Endif

  Next IJ

Return

#######################################################################################
$INIT_TSICODADI
Local Integer DIM_STI
Local Integer NI

  DIM_STI = func ASYRFNC.ACTIV("STI")
  # -------------------
  For NI = 1 To DIM_STI
    this.C_TSCCOD(NI).TSCCODADI = NI + 20
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

