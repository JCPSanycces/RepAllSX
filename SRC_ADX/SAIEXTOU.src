#<AdxTL>@(#)1.0.0.0 $Revision$
$ACTION
Case ACTION
 When "DEBUT"   : Gosub DEBUT
 When "OK"      : Gosub OK   
 When "END"     : Gosub FIN   
 When Default
Endcase
Return

$DEBUT
## initialisation du masque
Raz [M]
[M]RVSDAT = PARAM(1)
[M]RVSDES = PARAM(2)
Affzo [M]
Return

$OK
PARAM(1) = [M]RVSDAT
PARAM(2) = [M]RVSDES
PARAM(3) = num$(2)
PARAM(4) = num$([M]RVSSNS)
Return

$FIN
PARAM(3) = num$(1)
Return
