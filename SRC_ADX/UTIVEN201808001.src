#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIVEN201808001
# Issue X3-86334 - 2018-05-10 by USA
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIVEN201808001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIVEN201808001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR
Local Integer ISALREV
Local Integer IFOUND   # Issue X3-113667 - 2018-10-24 by USA

  Call ECR_TRACE("UTIVEN201808001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".FACILITY" [FCY]
  Local File =DOSSIER + ".VSORDER"  [VOH]
  Local File =DOSSIER + ".SORDER"   [SOH]
  # -----------------
  Raz COMPTEUR
  Raz NCOUNTERROR
  Raz IERR
  # -----------------
  If dim([F:VOH]CURREVFLG) > 0 Then
    Trbegin [VOH]
    # -----------------
    # I explained that an UTI must be executable many times, without corrupt existing data.
    # This is the case here, by the where condition : we are going to do something only if line with "[F:VOH]CURREVFLG = 0" are existing
    Update [VOH] Where [F:VOH]CURREVFLG = 0 With [F:VOH]CURREVFLG = 1
    If fstat Then
      # Error
      Call ECR_TRACE("File VSORDER error during [F:VOH]CURREVFLG initialization" + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Else
      # Success
      COMPTEUR = adxuprec    # adxuprec return number of line updated by "Update"
    Endif
    # -----------------
    If IERR = 0 Then
      Delete [VOH] Where [F:VOH]CURREVFLG = 2
      Filter [FCY] Where [F:FCY]SALFLG = [V]CST_AYES
      For [FCY]
        ISALREV = val(func ADP_TOOL.GET_PARAM([L]DOSSIER, 3, [F:FCY]FCY, "SALREV"))  # To get a parameter value in an UTI
        If ISALREV = 2 or ISALREV = 3 Then
          For [SOH] Where [F:SOH]SALFCY = [F:FCY]FCY
            # Issue X3-113667 - 2018-10-24 by USA: Begin
              Repeat
                IFOUND = 1
                Filter [VOH] Where [F:VOH]SOHNUM = [F:SOH]SOHNUM and [F:VOH]REVNUM = [F:SOH]REVNUM
                For [VOH]
                  IFOUND = 2
                  Break
                Next
                Filter [VOH]
                If IFOUND = 2 Then
                  Filter [VOH] Where [F:VOH]SOHNUM = [F:SOH]SOHNUM Order By Key KEY1=[F:VOH]REVNUM Desc
                  For [VOH]KEY1
                    [F:VOH]REVNUM = [F:VOH]REVNUM + 1
                    Rewrite [VOH]
                    If fstat Then
                      Call ECR_TRACE("File VSORDER(rewrite)" - [F:VOH]SOHNUM - num$([F:VOH]REVNUM) + ", Error =" - num$(fstat), 1) From GESECRAN
                      GOK = 1
                      IERR = 1
                      NCOUNTERROR += 1
                      Break
                    Endif
                  Next
                  Filter [VOH]
                  If IERR = 1 Then
                    Break
                  Endif
                Endif
              Until IFOUND = 1
            # Issue X3-113667 - 2018-10-24 by USA: End

            If IERR = 0 Then   # Issue X3-113667 - 2018-10-24 by USA
              Raz [F:VOH]
              [F:VOH]SOHNUM = [F:SOH]SOHNUM
              [F:VOH]REVNUM = [F:SOH]REVNUM
              [F:VOH]SALFCY = [F:SOH]SALFCY
              [F:VOH]CURREVFLG = 2
              Write [VOH]
              COMPTEUR += 1
              If fstat Then
                Call ECR_TRACE("File VSORDER" - [F:VOH]SOHNUM - num$([F:VOH]REVNUM) + ", Error =" - num$(fstat), 1) From GESECRAN
                GOK = 1
                IERR = 1
                NCOUNTERROR += 1
              Endif
            Endif

          Next
        Endif
      Next
      Filter [FCY]
    Endif
    # -----------------
    If IERR = 0 Then
      Commit
      Call ECR_TRACE("UTIVEN201808001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("UTIVEN201808001 : records processed with error(s).", 0) From GESECRAN
    Endif
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","VSORDER","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "VSORDER") : End : Endif
  If filinfo(filpath("FIL","SORDER","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "SORDER") : End : Endif
  # -------------------------
  Call MAJ_UTIVEN201808001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","VSORDER","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "VSORDER") : End : Endif
  If filinfo(filpath("FIL","SORDER","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "SORDER") : End : Endif
  # -------------------------
  Call MAJ_UTIVEN201808001(APPLI)
End

