#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA SOURCE REMERGE
Subprog LVE_ENG_FCST(NEVENT,CTRNUMBER,LVESUBTYPE,FILTERDATE,FUTBALS)
Value Char NEVENT,CTRNUMBER,LVESUBTYPE
Value Date FILTERDATE
Variable Char FUTBALS()(0..,0..10)
Global Integer Z
Z=0
  If clalev([TIM]) = 0      : Local File TIMCOD [TIM] Endif
  If clalev([HRLSTD]) = 0      : Local File HRLVESUBDET [HRLSTD] Endif
  If clalev([HRLSTH]) = 0      : Local File HRLVESUBHEA [HRLSTH] Endif
  If clalev([HRLSTH1]) = 0      : Local File HRLVESUBHEA [HRLSTH1] Endif
  If clalev([HRCTR]) = 0    : Local File EMPLOCTR [HRCTR] Endif
  If clalev ([ID]) = 0      : Local File EMPLOID [ID] Endif
  If clalev ([FCY]) = 0     : Local File FACILITY [FCY] Endif
  If clalev ([CPY]) = 0     : Local File COMPANY [CPY] Endif
  If clalev ([HRPOA]) = 0   : Local File POPULA [HRPOA] Endif
  If clalev ([HRACCR]) = 0   : Local File HRLVEACCRU [HRACCR] Endif
  If clalev ([HRACCR1]) = 0   : Local File HRLVEACCRU [HRACCR1] Endif
  If clalev([F:HRPEOD])=0 : Local File HRPEODET   [HRPEOD] : Endif
  If clalev([F:VEP2])=0   : Local File VALEMP     [VEP2]  : Endif
  If clalev([F:DCG])=0 : Local File DEMCONGE   [DCG] : Endif

  Local Integer S,F
  Local Char CRITACC(250),CRITACCCHK(250)
  Local Integer CRFCHK,RCOUNTACCR,ARRNEXT
  Local Date CARDATOVER
  Filter [TIM] Where [TIM]COD=NEVENT
#Looping 1. HRTIM 2. HRLST 3.HRCTR/HRMAT
  For [TIM]
    For S=1 To dim([TIM]LVESUBTYP)
         If [TIM]LVESUBTYP(S-1)<>""
          Filter [HRCTR] Where CTRNUM = CTRNUMBER
          Read [HRCTR] First
          Filter [HRCTR]
          #Call ECR_TRACE("Employee  " - [HRCTR]REFNUM - "   Contract " - [HRCTR]CTRNUM - " Leave sub type " - [TIM]LVESUBTYP(S-1),0) From GESECRAN
          Filter [HRLSTH] Where COD = [TIM]LVESUBTYP(S-1) and LEG = GCURLEG
          Read [HRLSTH] First
#          Call DEBUG_TRACE(1, "SUBHRLTA", [TIM]LVESUBTYP(S-1) - "[HRLSTH]LVEACCOPT " - num$([HRLSTH]LVEACCOPT))From DEBUGTRACE
          If [HRLSTH]LVEACCOPT <> 1
            Filter [HRACCR] Where [F:HRACCR]CTR = [HRCTR]CTRNUM and [F:HRACCR]LVEACCLST = [TIM]LVESUBTYP(S-1) and [F:HRACCR]LVEACCTYP = "Accrual" Order By [HRACCR]LVEACCDAT #and [F:HRACCR]LVEACCTYP =
            Read [HRACCR] Last
              RCOUNTACCR=rowcount([HRACCR])
            Filter [HRACCR]
            Local Date VARDAT
            If parse(evalue([F:HRLSTH]CYCSTRCAL),0)<>10 & parse(evalue([F:HRLSTH]CYCSTRCAL),0)<>0
              VARDAT = [HRCTR]DATANC
            Else
              VARDAT = evalue([F:HRLSTH]CYCSTRCAL)
            Endif
            If ([HRLSTH]LVEACCOPT = 2 | [HRLSTH]LVEACCOPT = 7) # | [HRLSTH]LVEACCOPT = 6) #Calc based on date specified on field : LVEACCCAL
              CHECKD = FILTERDATE #[06/06/2014]
              If [HRLSTH]LVEACCOPT = 2 : ACCDAT = evalue([F:HRLSTH]LVEACCCAL) : Endif
              If [HRLSTH]LVEACCOPT = 7
                If evalue([F:HRLSTH]CYCSTRCAL)<[HRCTR]DATANC
                  ACCDAT = [HRCTR]DATANC
                Else
                  ACCDAT = evalue([F:HRLSTH]CYCSTRCAL)
                Endif
              Endif
              Gosub EXTRACTION_ACCRUAL
            Endif
            If ([HRLSTH]LVEACCOPT = 3 | [HRLSTH]LVEACCOPT = 5) #Start of period/cycle
                CHECKD=FILTERDATE
              Gosub EXTRACTION_ACCRUAL
            Endif
            If ([HRLSTH]LVEACCOPT = 4 | [HRLSTH]LVEACCOPT = 6) #End of Period/CYCLE
                CHECKD=FILTERDATE
                Gosub EXTRACTION_ACCRUAL
            Endif
          Else
              CHECKD=FILTERDATE
          #check for daily and Cal
            If ([HRLSTH]LVEACCOPT = 2 | [HRLSTH]LVEACCOPT = 7)
              CHECKD=FILTERDATE
            Endif
            #Filter array
            For F=1 To maxtab(FUTBALS)
            If FUTBALS(F-1,4)="" : Break : Endif
            Call CONVERT_TO_DATE(FUTBALS(F-1,4), CARDATOVER) From SUBHRBAL
            If (CHECKD<=CARDATOVER and CHECKD >= CARDATOVER)
            #Filter [HRACCR] Where [F:HRACCR]CTR = [HRCTR]CTRNUM and [F:HRACCR]LVEACCLST = [TIM]LVESUBTYP(S-1) Order By [HRACCR]LVEACCDAT
            #For [HRACCR]
#            If GUSER="SAVAN"
#                ##infobx " Expiry Carry over exp " - num$(CARDATOVER)
#              Endif
              Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and (CHECKD<=[HRPEOD]PEREND(1) and CHECKD>=[HRPEOD]PERSTR(1))
              For [HRPEOD]
                [L]ARRLVEACCDAT=[F:HRPEOD]PEREND(1)
                #ARRAYCHECK=1
                Gosub CARRY_OVER_EXP
              Next
              Filter [HRPEOD]
              Endif
            Next
            Filter [HRACCR]
          Endif

          Filter [HRLSTH]
        Endif
        Next
    Next

  Filter [TIM]
  Filter [HRCTR]
#  If GUSER="PEVAN"
#    #infobx "Checking Array FCST"
#  Local Integer G
#  G=0
#    For G=0 To maxtab(FUTBALS)
#      If FUTBALS(G,1)<>""
#        #infbox "ARRAY LOOP SUB " - FUTBALS(G,2) - " with TRANDATE " - FUTBALS(G,3) - " and amount " - FUTBALS(G,5)
#      Endif
#    Next
#  Endif
End

$CARRY_OVER_EXP
  #read from DEMCONGE
  #read from accruals done from date of cycle
  Local Decimal ACCRUALS
  Local Decimal LVETKN
  Local Decimal CAROVERAMT
  Local Date EXPIRY1
  Local Char CARRYLST(250)
  #Local Date PREVCYCDAT
  If PREVCYCDAT = [0/0/0] : PREVCYCDAT=[F:HRACCR]LVEACCEXP :  Endif
  Filter [HRLSTH1] Where COD = [F:HRLSTH]LVECARSUB and LEG = [F:CPY]LEG
      #NEW lst EXPIR
  Read [HRLSTH1] First
      ###infobx "LINKED SUB TYPE " - num$([F:HRLSTH1]LVECARSUB ) - "WITH OPTION " - num$([F:HRLSTH1]CYCLENU) - "AND" - num$([F:HRLSTH1]CYCLEN)
  Filter [HRLSTH1]
  CURRDAT = TESTDATE
  CYCLEN = [F:HRLSTH1]CYCLEN
  If [HRLSTH1]CYCLENU = 1
    CARRYDATE = addmonth(CURRDAT,CYCLEN*-12)
  Else
    CARRYDATE = addmonth(CURRDAT,-CYCLEN)
  Endif


  #If PREVCYCDAT = [0/0/0] : PREVCYCDAT=EXPIRY :  Endif
  ###infobx "checking trans from " - num$(CARRYDATE) - "till the " - num$(PREVCYCDAT) - "for code " - [TIM]COD
  Filter [DCG] Where CTRNUM = [F:HRACCR]CTR and [F:DCG]TIM = [F:TIM]COD and ([F:DCG]STRDAT >= CARRYDATE and [F:DCG]STRDAT <= CURRDAT) and UID>0 and ([DCG]STA=1|[DCG]STA=2|[DCG]STA=3|[DCG]STA=4|[DCG]
& STA=5)
#  If GUSER="SAVAN"
#  ##infobx "Contract " - [LNK]CTRNUM - "  and the LST  " - num$([TIM]LVESUBTYP(S-1)) - "  date compared in PREVCYCDAT " - num$(PREVCYCDAT)
#  Endif
  Filter [HRACCR1] Where CTR = [F:HRCTR]CTRNUM and [F:HRACCR1]LVEACCLST = [F:TIM]LVESUBTYP(S-1) and [F:HRACCR1]LVEACCEXP = [F:HRACCR]LVEACCEXP#PREVCYCDAT
  #calculate all accruals plus the previous carry overs excluding Excess
  For [HRACCR1]
     ACCRUALS += val([HRACCR1]LVEACCAMT)
  Next
  ###infobx num$(ACCRUALS)
  If rowcount([DCG]) > 0
        #check for transaction in DCG and amounts taken for whole transaction falling into cycle.
    For [DCG]
        #no over laps
      #If [DCG]STRDAT >= CARRYDATE and [DCG]ENDDAT <= PREVCYCDAT
        LVETKN = LVETKN + [DCG]NBRDAY
      #Endif
        #Over laps --> nou nou
    Next
  Endif

  #carry over
  CAROVERAMT=ACCRUALS-LVETKN
  #AMT = CAROVERAMT
  ARRAMT=CAROVERAMT
  #[F:HRACCR]LVEACCTYP = "Carry Over"

  If [F:HRLSTH1]LVECARSUB <> ""
    CARRYLST = [F:HRLSTH1]LVECARSUB
    #[F:HRACCR]ACCFRM=[F:HRLSTH]COD
      #CHECK DIE MOVE
#      Filter [HRLSTH1] Where COD = [F:HRLSTH]LVECARSUB and LEG = [F:CPY]LEG
#      #NEW lst EXPIR
#      Read [HRLSTH1] First
#      ###infobx "LINKED SUB TYPE " - num$([F:HRLSTH1]LVECARSUB ) - "WITH OPTION " - num$([F:HRLSTH1]CYCLENU) - "AND" - num$([F:HRLSTH1]CYCLEN)
#      Filter [HRLSTH1]
    If [F:HRLSTH1]CYCLENU = 1
      EXPIRY1 = addmonth(PREVCYCDAT,[F:HRLSTH1]CYCLEN*12)
    Else
      EXPIRY1 = addmonth(PREVCYCDAT,[F:HRLSTH1]CYCLEN)
    Endif
    [L]ARREXPIRY=EXPIRY1#-1
      #END CHECK
#      If GUSER="SAVAN"
#      ##infobx "SubTYPE Carry over exp " - [F:HRLSTH]LVECARSUB -  "PREVCYCDAT " - num$(PREVCYCDAT) - " and [F:HRLSTH1]CYCLEN " - num$([F:HRLSTH1]CYCLEN)
#      ##infobx "NEW EXPIRY for carry over " - num$(EXPIRY1)
#      Endif

  Else
    CARRYLST = [TIM]LVESUBTYP(S-1)
    [L]ARREXPIRY=EXPIRY#-1
  Endif

  #build array
    FUTBALS(Z,1)=[TIM]COD
    FUTBALS(Z,2)=CARRYLST
    FUTBALS(Z,3)=[L]ARRLVEACCDAT
    FUTBALS(Z,4)=[L]ARREXPIRY#-
    FUTBALS(Z,5)=num$(ARRAMT)
#    Call DEBUG_TRACE(2, "SUBHRLTA", "CARRY OVER AMOUNT" - num$(ARRAMT) - " to CARRYLST " - CARRYLST) From DEBUGTRACE
#        FUTBALS(Z,1)=[TIM]COD
#    FUTBALS(Z,2)=[TIM]LVESUBTYP(S-1)
#    FUTBALS(Z,3)=num$([L]ARRLVEACCDAT)
#    FUTBALS(Z,4)=num$([L]ARREXPIRY)#-
#    FUTBALS(Z,5)=num$(ARRAMT)
    Z+=1
  #Write [F:HRACCR]

Return

$WRITE_ACCRU
  Local Date CHECKWRITE
  Gosub GET_EXPIRY
  Gosub GET_VALUE

  If EXPIRY2<>[0/0/0]
    CHECKWRITE=EXPIRY2
  Else
    CHECKWRITE=CURRDAT
  Endif
#  Call DEBUG_TRACE(2, "SUBHRLTA", [F:HRLSTH]COD - "EXPIRY2" - num$(EXPIRY2) - "CURRDAT" - num$(CURRDAT) - "CHECKWRITE" - num$(CHECKWRITE) - "[F:HRPEOD]PERSTR(1)" - num$([F:HRPEOD]PERSTR(1))) From
#& DEBUGTRACE

  If [F:HRLSTH]LVEACCOPT = 3 | [F:HRLSTH]LVEACCOPT = 5
#PEVAN - 2017-10-24 - X3-60930 - START
#    If ([F:HRLSTH]CYCREC=1 and ([F:HRPEOD]PERSTR(1)>=CHECKWRITE)) | ([F:HRLSTH]CYCREC=2)
    If ([F:HRLSTH]CYCREC=1 and ([F:HRPEOD]PERSTR(1)<=CHECKWRITE)) | ([F:HRLSTH]CYCREC=2)
#PEVAN - 2017-10-24 - X3-60930 - END
        FUTBALS(Z,1)=[TIM]COD
        FUTBALS(Z,2)=[TIM]LVESUBTYP(S-1)
        FUTBALS(Z,3)=[L]ARRLVEACCDAT
        FUTBALS(Z,4)=[L]ARREXPIRY#-
        FUTBALS(Z,5)=num$(ARRAMT)
        Z+=1
    Endif
  Elsif [F:HRLSTH]LVEACCOPT = 4 | [F:HRLSTH]LVEACCOPT = 6
    If ([F:HRLSTH]CYCREC=1 and (([F:HRPEOD]PEREND(1)<=CHECKWRITE))) | ([F:HRLSTH]CYCREC=2)
        FUTBALS(Z,1)=[TIM]COD
        FUTBALS(Z,2)=[TIM]LVESUBTYP(S-1)
        FUTBALS(Z,3)=[L]ARRLVEACCDAT
        FUTBALS(Z,4)=[L]ARREXPIRY#-
        FUTBALS(Z,5)=num$(ARRAMT)
        Z+=1
    Endif
  Elsif ([F:HRLSTH]CYCREC=1 | [F:HRLSTH]CYCREC=2)  and ([HRLSTH]LVEACCOPT = 2 & CYCARR(I-1,1)<CHECKWRITE)
    #BUILD ARRAY
    FUTBALS(Z,1)=[TIM]COD
    FUTBALS(Z,2)=[TIM]LVESUBTYP(S-1)
    FUTBALS(Z,3)=[L]ARRLVEACCDAT
    FUTBALS(Z,4)=[L]ARREXPIRY#-
    FUTBALS(Z,5)=num$(ARRAMT)
    Z+=1
  Endif
Return

$GET_VALUE
  Local Decimal AMT
  Local Decimal NRDAYS,NRDAYSL #: NRDAYS = 0
  Local Decimal NRHOURS,NRHOURSL #: NRHOURS = 0

  NRDAYS=0
  NRDAYSL=0
  NRHOURS=0
  NRHOURSL=0
  #check pro rata
  #If VARDAT > [F:HRPEOD]PERSTR(1)
  ###infobx "Call DCG Valour"
  ###infobx "Start " - num$(VARDAT) - " and end " - num$([F:HRPEOD]PEREND(1)) - " with TIM " - [TIM]COD - " and FCY " - [F:HRCTR]ETRFCY - " and CTR " - [F:HRCTR]CTRNUM
  If VARDAT > [F:HRPEOD]PERSTR(1) and [F:HRLSTH]LVEPRORAT=2
  ###infobx "Call Valoris"

    Call VALORIS_L(VARDAT,[F:HRPEOD]PEREND(1),[LNK]REFNUM,[TIM]COD,NRDAYS,NRHOURS,[F:HRCTR]ETRFCY,[LNK]CTRNUM) From SUBACCRUAL

    Call VALORIS_L([F:HRPEOD]PEREND(1),[F:HRPEOD]PEREND(1),[LNK]REFNUM,[TIM]COD,NRDAYSL,NRHOURSL,[LNK]ETRFCY,[LNK]CTRNUM) From SUBACCRUAL

    Gosub GET_CYCLE_LENGTH

    AMT=evalue([F:HRLSTH]ENTCAL)/DIV
    ARRAMT=AMT
###infobx "days calc" - num$([L]NRDAYS)
  Else
    Gosub GET_CYCLE_LENGTH
#  If [F:HRLSTH]COD = "SICK"
#  ##infobx "DIVIDE by buite " - num$(DIV)
#Endif
  #If MDIFF > 0 : DIV = 12/(12-MDIFF) : Endif
    If DIV=0 : DIV=1 : Endif
    If [F:HRLSTH]COD="SSP_E"
    AMT=evalue([F:HRLSTH]ENTCAL)/DIV
    Else
    AMT=val([F:HRLSTH]ENTCAL)/DIV
    Endif
    ARRAMT=AMT
  Endif
Return

$CYCLE_CHECK
  Local Date CYCDAT ,FILTERDATE_DCG ,CCYCLDAT
  Local Integer CYCBD
  Local Date PREVCYCDAT
  Local Integer XMONTH,R,D
  Local Date LVEEXP
  Local Date LENUINT
  Local Decimal CYCLEN
  Local Date CYCARR(0..99,0..99)

  R=0
  If GFONCTION = "GESDCG"
    If clalev([F:VEP2])=0   : Local File VALEMP     [VEP2]  : Endif

      CHECKD=[M:DCG1]DATLVE
#      If CHECKD>ENDDAT and CHECKD<>[0/0/0] : FILTERDATE=CHECKD : Endif
      If CHECKD>ENDDAT and CHECKD<>[0/0/0] : FILTERDATE_DCG=CHECKD : Endif
      CYCLEN = [F:HRLSTH]CYCLEN
      If CYCLEN>50
#       FILTERDATE=addmonth([M:DCG1]ENDDAT,12)
       FILTERDATE_DCG=addmonth([M:DCG1]ENDDAT,12)
      Endif
      LENOPT = [F:HRLSTH]CYCLENU
        If CCYCLDAT=[0/0/0]
          CCYCLDAT=VARDAT
        Endif
      CYCLEN = [F:HRLSTH]CYCLEN
      LENOPT = [F:HRLSTH]CYCLENU
#        If LENOPT=2
#          FILTERDATE=addmonth(FILTERDATE,CYCLEN)
#          Else
#          FILTERDATE=addmonth(FILTERDATE,(CYCLEN*12))
#        Endif
      If parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 0
        CCYCLDAT = [HRCTR]DATANC
      Else
        If evalue([F:HRLSTH]CYCSTRCAL)<[HRCTR]DATANC
          CCYCLDAT = [HRCTR]DATANC
        Else
          CCYCLDAT = evalue([F:HRLSTH]CYCSTRCAL)
        Endif
      Endif

        #SAVAN 2017/09/11 Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= CCYCLDAT and [F:HRPEOD]PEREND(1) <= FILTERDATE)
        Filter [HRPEOD]
        Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= CCYCLDAT and [F:HRPEOD]PEREND(1) <= FILTERDATE)
        If rowcount([HRPEOD])<> 0
          Read [HRPEOD] First
        For [HRPEOD]
          If [F:HRPEOD]PERSTR(1)<=CCYCLDAT & [F:HRPEOD]PEREND(1)>=CCYCLDAT

            CYCARR(R,1)=CCYCLDAT
            If LENOPT= 1
              CCYCLDAT=addmonth(CCYCLDAT,CYCLEN*12)
            Else
              CCYCLDAT=addmonth(CCYCLDAT,CYCLEN)
            Endif
            CYCARR(R,2)=CCYCLDAT
            R+=1
          Endif
        Next
      Endif
      Filter [HRPEOD]
    Endif
  If GFONCTION <> "GESDCG"
  #Build array for cycle
    If [HRLSTH]LVEACCOPT = 2 | [HRLSTH]LVEACCOPT = 7
      If CCYCLDAT=[0/0/0]
        CCYCLDAT=ACCDAT
      Endif
      CYCLEN = [F:HRLSTH]CYCLEN
      LENOPT = [F:HRLSTH]CYCLENU
      CHECKD=FILTERDATE
      CYCARR(0,1)=CCYCLDAT
      If LENOPT= 1
        CCYCLDAT=addmonth(CCYCLDAT,CYCLEN*12)
      Else
        CCYCLDAT=addmonth(CCYCLDAT,CYCLEN)
      Endif
      CYCARR(0,2)=CCYCLDAT
      For I=1 To 99
        If CCYCLDAT<=CHECKD
          CYCARR(I,1)=CCYCLDAT
          If LENOPT= 1
            CCYCLDAT=addmonth(CCYCLDAT,CYCLEN*12)
          Else
            CCYCLDAT=addmonth(CCYCLDAT,CYCLEN)
          Endif
          CYCARR(I,2)=CCYCLDAT
        Endif
        If CCYCLDAT>CHECKD : Break : Endif
      Next
      If [HRLSTH]LVEACCOPT = 7
        If RCOUNTACCR=0
          DAYSTOACCRU=CHECKD-CYCARR(0,1)
          Local Date LOOPDATE(0..DAYSTOACCRU-1,0..DAYSTOACCRU-1)
          CCYCLDAT=ACCDAT
          For Y=1 To DAYSTOACCRU
            LOOPDATE(Y-1,1)=CCYCLDAT
            CCYCLDAT=CCYCLDAT+1
          Next
        Else
          DAYSTOACCRU=CHECKD-[F:HRACCR]LVEACCDAT
          Local Date LOOPDATE(0..DAYSTOACCRU-1,0..DAYSTOACCRU-1)
          CCYCLDAT=[F:HRACCR]LVEACCDAT
          For Y=1 To DAYSTOACCRU
            LOOPDATE(Y-1,1)=CCYCLDAT
            CCYCLDAT=CCYCLDAT+1
          Next
        Endif
      Endif
    Else
      If parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 0
        CCYCLDAT = [HRCTR]DATANC
      Else
        If evalue([F:HRLSTH]CYCSTRCAL)<[HRCTR]DATANC
          CCYCLDAT = [HRCTR]DATANC
        Else
          CCYCLDAT = evalue([F:HRLSTH]CYCSTRCAL)
        Endif
      Endif
      If CCYCLDAT=[0/0/0]
        CCYCLDAT=VARDAT
      Endif
      CYCLEN = [F:HRLSTH]CYCLEN
      LENOPT = [F:HRLSTH]CYCLENU
      Filter [HRPEOD]
      Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= CCYCLDAT)# and [F:HRPEOD]PEREND(1) <= FILTERDATE)
      For [HRPEOD]
        If [F:HRPEOD]PERSTR(1)<=CCYCLDAT & [F:HRPEOD]PEREND(1)>=CCYCLDAT
          CYCARR(R,1)=CCYCLDAT
          If LENOPT= 1
            CCYCLDAT=addmonth(CCYCLDAT,CYCLEN*12)
          Else
            CCYCLDAT=addmonth(CCYCLDAT,CYCLEN)
          Endif
          CYCARR(R,2)=CCYCLDAT
          R+=1
        Endif
      Next
      Filter [HRPEOD]
    Endif
  Endif
Return

$EXTRACTION_ACCRUAL
  Local Date CCYCLDAT,ARRLVEACCDAT,ARREXPIRY,EXTRACTION_START_DATE,EXTRACTION_END_DATE
  Local Decimal ARRAMT
  Local Integer I,Y,V
  Filter [VEP2] Where CTRNUM = [HRCTR]CTRNUM Order By [F:VEP2]PYRDAT
  Read [VEP2] Last

  If [HRLSTH]LVEACCOPT <> 2
    If [HRLSTH]LVEACCOPT = 3 | [HRLSTH]LVEACCOPT = 4
      If RCOUNTACCR=0
        I=1
        Gosub CYCLE_CHECK From SUBDCGGLM
#        If GFONCTION <> "GESDCG"
#          FILTERDATE = VARDAT
#        Endif
        Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, VARDAT, EXTRACTION_START_DATE, EXTRACTION_END_DATE) From SUBHRBAL
#        Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, FILTERDATE, EXTRACTION_START_DATE, EXTRACTION_END_DATE) From SUBHRBAL
        If [HRLSTH]LVEACCOPT = 3
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PERSTR(1) <= FILTERDATE)
#          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) >= [F:HRCTR]DATANC and [F:HRPEOD]PERSTR(1) <= FILTERDATE)
        Else
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PEREND(1) <= FILTERDATE)
        Endif
        For [HRPEOD]
        I=0
          For V=0 To maxtab(CYCARR)
            If CYCARR(V,1)=[0/0/0] : Break : Endif
            If [F:HRPEOD]PEREND(1) >= CYCARR(V,1) :
              I+=1:
            Endif
          Next
          If I > 0
            If CYCARR(I-1,1) <> [0/0/0]
              If [F:HRPEOD]PEREND(1) < CYCARR(I-1,2) & [F:HRLSTH]LVEACCOPT = 4
                [L]ARRLVEACCDAT=[F:HRPEOD]PEREND(1)
              Elsif [F:HRPEOD]PERSTR(1) < CYCARR(I-1,2) & [F:HRLSTH]LVEACCOPT = 3
                [L]ARRLVEACCDAT=[F:HRPEOD]PERSTR(1)
              Endif
              Gosub WRITE_ACCRU
            Endif
          Endif
        Next
        Filter [HRPEOD]
      Else
        I=1
        Gosub CYCLE_CHECK From SUBDCGGLM
        If [HRLSTH]LVEACCOPT = 3
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) > [F:HRACCR]LVEACCDAT and [F:HRPEOD]PERSTR(1) <= FILTERDATE)
        Else
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) > [F:HRACCR]LVEACCDAT and [F:HRPEOD]PEREND(1) <= FILTERDATE)
        Endif
        For [HRPEOD]
        I=0
          For V=0 To maxtab(CYCARR)
            If CYCARR(V,1)=[0/0/0] : Break : Endif
            If [F:HRPEOD]PEREND(1) >= CYCARR(V,1) : I+=1: Endif
          Next
          If I > 0
            If CYCARR(I-1,1) <> [0/0/0]
              If [F:HRPEOD]PEREND(1) < CYCARR(I-1,2) & [F:HRLSTH]LVEACCOPT = 4
                [L]ARRLVEACCDAT=[F:HRPEOD]PEREND(1)
              Elsif [F:HRPEOD]PERSTR(1) < CYCARR(I-1,2) & [F:HRLSTH]LVEACCOPT = 3
                [L]ARRLVEACCDAT=[F:HRPEOD]PERSTR(1)
              Endif
              Gosub WRITE_ACCRU
            Endif
          Endif
        Next
        Filter [HRPEOD]
      Endif
    Endif

    If [HRLSTH]LVEACCOPT = 5 | [HRLSTH]LVEACCOPT = 6
      If RCOUNTACCR=0
        Gosub CYCLE_CHECK From SUBDCGGLM
        Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, VARDAT, EXTRACTION_START_DATE, EXTRACTION_END_DATE) From SUBHRBAL
#        Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, FILTERDATE, EXTRACTION_START_DATE, EXTRACTION_END_DATE) From SUBHRBAL
        If [HRLSTH]LVEACCOPT = 5
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) >= [F:HRCTR]DATANC and [F:HRPEOD]PERSTR(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PERSTR(1) <= FILTERDATE)
        Else
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= [F:HRCTR]DATANC and [F:HRPEOD]PEREND(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PEREND(1) <= FILTERDATE)
        Endif
        For I=1 To maxtab(CYCARR)
          If CYCARR(I-1,1) <> [0/0/0]
            For [HRPEOD]
            If [HRLSTH]LVEACCOPT = 5 & [F:HRPEOD]PERSTR(1)<=CYCARR(I-1,1) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,1)
              [L]ARRLVEACCDAT=[F:HRPEOD]PERSTR(1)
              Gosub WRITE_ACCRU
            Elsif [HRLSTH]LVEACCOPT = 6 & [F:HRPEOD]PERSTR(1)<=CYCARR(I-1,2) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,2)
              [L]ARRLVEACCDAT=[F:HRPEOD]PEREND(1)
              Gosub WRITE_ACCRU
            Endif
            Next
          Endif
        Next
        Filter [HRPEOD]
      Else
        Gosub CYCLE_CHECK From SUBDCGGLM
        If [HRLSTH]LVEACCOPT = 5
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) > [F:HRACCR]LVEACCDAT and [F:HRPEOD]PERSTR(1) <= FILTERDATE)
        Else
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) > [F:HRACCR]LVEACCDAT and [F:HRPEOD]PEREND(1) <= FILTERDATE)
        Endif
        For I=1 To maxtab(CYCARR)
          If CYCARR(I-1,1) <> [0/0/0]
            For [HRPEOD]
              If [HRLSTH]LVEACCOPT = 5 & [F:HRPEOD]PERSTR(1)<=CYCARR(I-1,1) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,1)
                [L]ARRLVEACCDAT=[F:HRPEOD]PERSTR(1)
                Gosub WRITE_ACCRU
              Elsif [HRLSTH]LVEACCOPT = 6 & [F:HRPEOD]PERSTR(1)<=CYCARR(I-1,2) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,2)
                [L]ARRLVEACCDAT=[F:HRPEOD]PEREND(1)
                Gosub WRITE_ACCRU
              Endif
            Next
          Endif
        Next
        Filter [HRPEOD]
      Endif
    Endif
  Else
    If [HRLSTH]LVEACCOPT = 2
      Gosub CYCLE_CHECK From SUBDCGGLM
      I=1
      If RCOUNTACCR=0
        I=1
        If CHECKD>=CYCARR(I-1,1) & CYCARR(I-1,1) <> [0/0/0]
          [L]ARRLVEACCDAT=CYCARR(I-1,1)
          Gosub WRITE_ACCRU
        Endif
      Endif
      For I=2 To maxtab(CYCARR)
        If CYCARR(I-1,1)=[0/0/0] : Break : Endif
        [L]ARRLVEACCDAT=CYCARR(I-1,1)
        Gosub WRITE_ACCRU
      Next
    Endif
    If  [HRLSTH]LVEACCOPT = 7
      Local Integer DAYSTOACCRU,E,I
      E=1
      Gosub CYCLE_CHECK From SUBDCGGLM
      I=1
      For E=1 To maxtab(LOOPDATE)
        If LOOPDATE(E-1,1) >= CYCARR(I-1,2) : I+=1: Endif
        If CYCARR(I-1,1)=[0/0/0] : Break : Endif
        If LOOPDATE(E-1,1)>=CYCARR(I-1,1)
          [L]ARRLVEACCDAT=LOOPDATE(E-1,1)
          Gosub WRITE_ACCRU
        Endif
      Next
    Endif
  Endif
  Filter [VEP2]
Return

$CONTRACT_ACCRUAL
  Local Date CCYCLDAT
  Local Integer DIFFDATE
  Local Integer L
  Local Date PAYSLIPDAT
  Local Integer LENOPT
  #Local Integer MDIFF

  #CALCULATION OPTION
  #If [F:HRLSTH]LVEACCOPT = 2
      #If rowcount([HRACCR])=0
            #Gosub CYCLE_CHECK
            #on date that is set to system date
  If CCYCLDAT = CHECKD
    DIFFDATE = 1
  Endif
            #Past system date engine missed accrual
  If CHECKD > [L]ACCDAT and [LNK]DATANC = CCYCLDAT
    DIFFDATE = 1
  Endif
            #past system date contract only after setup date --> pro rat
  If CHECKD > [L]ACCDAT and CCYCLDAT < [LNK]DATANC
    If year([LNK]DATANC) - year(CCYCLDAT)
      MDIFF = (month([LNK]DATANC)+12) -month(CCYCLDAT)
    Else
      MDIFF = month([LNK]DATANC) -month(CCYCLDAT)
    Endif
  Endif
#            If year(CHECKD) - year(CCYCLDAT) = 1
#            DIFFDATE = (month(CHECKD)+12) - month(CCYCLDAT)
#            Else
#            DIFFDATE = month(CHECKD) - month(CCYCLDAT)
#            Endif
      #Else
             #Gosub CYCLE_CHECK
#            If year(CHECKD) - year([HRACCR]LVEACCDAT) = 1
#            DIFFDATE = (year(CHECKD)+12) - year([HRACCR]LVEACCDAT)
#            Else
#            DIFFDATE = year(CHECKD) - year([HRACCR]LVEACCDAT)
#            Endif


 #Endif
      #WRITE
  If DIFFDATE > 0 | MDIFF > 0
    [L]ARRLVEACCDAT=CCYCLDAT
    Gosub WRITE_ACCRU
  Endif

  #Endif

Return

$GET_CYCLE_LENGTH
  #Local Char ENTTYP(10)
  #Local Integer CYCLENUNIT
  #Local Decimal CYCLEN
  #Local Integer DIV

#CYCLEN = [F:HRLSTH]CYCLEN
#CYCLENUNIT = [F:HRLSTH]CYCLENU
##############SAVAN CHECK START 2017/09/07
###infobx "Cycle Length  ENTYP" - num$([F:HRLSTH]ENTTYP) - " with CYCLENU"  - num$([HRLSTH]CYCLENU) - "  "
#  If NRDAYSL <> 0
#    DIV=NRDAYS/NRDAYSL
#  Endif
#
#  If [F:HRLSTH]ENTTYP = 2
#    If ([HRLSTH]CYCLENU = 1)
#      DIV = 12
#    Else
#      DIV = [HRLSTH]CYCLEN
#    Endif
#    If [HRLSTH]LVEACCOPT = 7
#      If mod(year(CCYCLDAT),4) = 0
#        DIV = 366
#      Else
#        DIV = 365
#      Endif
#    Endif
#    If [HRLSTH]LVEACCOPT = 5 | [HRLSTH]LVEACCOPT = 6 | [HRLSTH]LVEACCOPT = 2
#      DIV = 1
#    Endif
#  Endif
###########SAVAN CHECK END 2017/09/07
#If [F:HRLSTH]COD = "SICK"
#  ##infobx "DIVIDE by " - num$(DIV)
#Endif
 Local Char ENTTYP(10)
  Local Integer CYCLENUNIT
  Local Decimal CYCLEN,PRO
  Local Integer DIV,DIVCYC
  Local Date CYCLESTARTDATE, CYCLEENDDATE

#CYCLEN = [F:HRLSTH]CYCLEN
#CYCLENUNIT = [F:HRLSTH]CYCLENU
  If clalev([F:HRPEODD])=0 : Local File HRPEODET   [HRPEODD] : Endif

  If [F:HRLSTH]ENTTYP = 2
    If ([HRLSTH]CYCLENU = 1)
      DIV = 12
    Else
      DIV = [HRLSTH]CYCLEN
    Endif
    If [HRLSTH]LVEACCOPT = 7
      If mod(year(CCYCLDAT),4) = 0
        DIV = 366
      Else
        DIV = 365
      Endif
    Endif
    If [HRLSTH]LVEACCOPT = 5 | [HRLSTH]LVEACCOPT = 6 | [HRLSTH]LVEACCOPT = 2
      DIV = 1
    Endif
  Endif

    For COUNTER = 0 To maxtab(CYCARR)
    If CYCARR(COUNTER, 1) <> [0/0/0] and [F:HRPEOD]PEREND(1) >= CYCARR(COUNTER, 1) and [F:HRPEOD]PEREND(1) <= CYCARR(COUNTER, 2)
      CYCLESTARTDATE = CYCARR(COUNTER, 1)
      CYCLEENDDATE = CYCARR(COUNTER, 2)
      Break
    Endif
  Next
      Filter [HRPEODD]
      Filter [HRPEODD] Where [HRPEODD]PERCOD = [F:HRCTR]PERCOD and [HRPEODD]PEREND(1)>=CYCLESTARTDATE and [HRPEODD]PEREND(1)<=CYCLEENDDATE
      DIVCYC=rowcount([HRPEODD])
      Filter [HRPEODD]
 If DIVCYC<>0
  If ([HRLSTH]LVEACCOPT = 5 | [HRLSTH]LVEACCOPT = 6 | [HRLSTH]LVEACCOPT = 2)
   DIV=DIV
  Else
    DIV=DIVCYC
  Endif
Endif

  If NRDAYSL <> 0 and CPRO=1
    PRO=NRDAYS/NRDAYSL
  Endif
Return


$GET_EXPIRY
  Local Date CURRDAT
  Local Date EXPIRY,TESTDATE
  Local Date EXPIRY2
  Local Date CARRYDATE
  Local Integer CARRYOVER,ARRAYCHECK
  Local Integer CHKDD,H

  If clalev ([HRACCR2]) = 0   : Local File HRLVEACCRU [HRACCR2] Endif
  Filter [HRACCR2] Where [F:HRACCR2]CTR = [HRCTR]CTRNUM and [F:HRACCR2]LVEACCLST = [TIM]LVESUBTYP(S-1) and [F:HRACCR2]LVEACCTYP = "Accrual" Order By [HRACCR2]LVEACCDAT
 ###infobx "RECORDS READ AFTER WRITE " - num$(rowcount([HRACCR2]))
 #normal check if filterdate
  Read [F:HRACCR2] Last
  Filter [HRACCR2]
  If !fstat
    EXPIRY2=[F:HRACCR2]LVEACCEXP
  Endif
  Close File [HRACCR2]
  CURRDAT=CYCARR(I-1,2)
  #CURRDAT = num$([F:HRPEOD]PEREND(1))
  If ([HRLSTH]LVEACCOPT = 2) & (CURRDAT > EXPIRY2 & EXPIRY2<>[0/0/0])
    CARRYOVER=1
    TESTDATE = CURRDAT
#    Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, TESTDATE, CYCLESTARTDATE, CYCLEENDDATE) From SUBHRBAL
  Endif
  If ([HRLSTH]LVEACCOPT = 7)  & (CURRDAT > EXPIRY2& EXPIRY2<>[0/0/0])
    CARRYOVER=1
  Endif
#  If [F:HRPEOD]PERSTR(1)=EXPIRY2 & (([HRLSTH]LVEACCOPT <> 2) & ([HRLSTH]LVEACCOPT <> 7))#[F:HRPEOD]PEREND(1)>=CURRDAT    #([F:HRPEOD]PEREND(1)<=CURRDAT & CURRDAT>=[F:HRPEOD]PERSTR(1))
  If [F:HRPEOD]PEREND(1)>=CURRDAT & [F:HRPEOD]PERSTR(1)<=CURRDAT & (([HRLSTH]LVEACCOPT <> 2) & ([HRLSTH]LVEACCOPT <> 7))#[F:HRPEOD]PEREND(1)>=CURRDAT    #([F:HRPEOD]PEREND(1)<=CURRDAT &
# CURRDAT>=[F:HRPEOD]PERSTR(1))
    CARRYOVER = 1
    # "Array carry over normal"
  Endif
  If Z>0
    For F=0 To maxtab(FUTBALS)
    If (FUTBALS(F,4)="" or FUTBALS(F,4)=[0/0/0]) : Break : Endif
      Call CONVERT_TO_DATE(FUTBALS(F,4), TESTDATE) From SUBHRBAL
      ###infobx "FUTBALS(Z,4)"  - num$(TESTDATE) - "  with expiry cycle " - num$(CYCARR(I-1,2))
#PEVAN 2017-09-29 START
#      If [F:HRPEOD]PERSTR(1)>=TESTDATE and EXPIRY2<>TESTDATE
      If [F:HRPEOD]PERSTR(1)<=TESTDATE and [F:HRPEOD]PEREND(1)>TESTDATE
#PEVAN 2017-09-29 END
         ##infobx "Array carry over futbals"
         CARRYOVER=1
         ARRAYCHECK=1
      Endif
    Next
  Endif
  EXPIRY = CYCARR(I-1,2)
  [L]ARREXPIRY=EXPIRY
###infobx "EXPIRY " - num$(EXPIRY) - " [F:HRPEOD]PERSTR(1)" - num$([F:HRPEOD]PERSTR(1)) - " [F:HRPEOD]PEREND(1)" - num$([F:HRPEOD]PEREND(1)) - " EXPIRTY 2 " - num$(EXPIRY2)
#Call DEBUG_TRACE(1, "SUBHRLTA", "EXPIRY " - num$(EXPIRY) - " [F:HRPEOD]PERSTR(1)" - num$([F:HRPEOD]PERSTR(1)) - " [F:HRPEOD]PEREND(1)" - num$([F:HRPEOD]PEREND(1)) - " EXPIRTY 2 " - num$(EXPIRY2)
#& - "CURRDAT" - num$(CURRDAT)) From DEBUGTRACE
  PREVCYCDAT=EXPIRY
  If [F:HRLSTH]COD = "SICK6"
  Call DEBUG_TRACE(2, "SUBHRLTA", "--------------------------------------------------") From DEBUGTRACE
Call DEBUG_TRACE(1, "SUBHRLTA", "EXPIRY " - num$(EXPIRY) - " [F:HRPEOD]PERSTR(1)" - num$([F:HRPEOD]PERSTR(1)) - " [F:HRPEOD]PEREND(1)" - num$([F:HRPEOD]PEREND(1)) - " EXPIRTY 2 " - num$(EXPIRY2)
& - "CURRDAT" - num$(CURRDAT) - "CARRYOVER" - num$(CARRYOVER)) From DEBUGTRACE
  Call DEBUG_TRACE(2, "SUBHRLTA", "--------------------------------------------------") From DEBUGTRACE
  Endif
  If CARRYOVER = 1 and [F:HRLSTH]LVECARSUB <> ""
    Gosub CARRY_OVER
  Endif
  Raz PREVCYCDAT,CARRYOVER

Return

$CARRY_OVER
  #read from DEMCONGE
  #read from accruals done from date of cycle
  Local Decimal ACCRUALS
  Local Decimal LVETKN
  Local Decimal CAROVERAMT,ALLOWAMT,EXCESSAMT
  Local Date EXPIRY1,FORMDAT,ARRAYD,CYCLESTARTDATE,CYCLEENDDATE
  Local Char CARRYLST(250)

  Filter [HRLSTH1] Where COD = [F:HRLSTH]LVECARSUB and LEG = [F:CPY]LEG
      #NEW lst EXPIR
  Read [HRLSTH1] First
  Filter [HRLSTH1]
  CURRDAT = TESTDATE #[F:HRACCR]LVEACCDAT
  CYCLEN = [F:HRLSTH1]CYCLEN
  ALLOWAMT= val([F:HRLSTH]LVECARFWD)
  If [HRLSTH1]CYCLENU = 1
    CARRYDATE = addmonth((CURRDAT),CYCLEN*-12)
  Else
    CARRYDATE = addmonth((CURRDAT),-CYCLEN)
  Endif

  If [F:HRLSTH1]LVEACCOPT = 2
    Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH1]COD, CURRDAT, CYCLESTARTDATE, CYCLEENDDATE) From SUBHRBAL
  Endif

#  Filter [HRLSTH1]
  Filter [DCG] Where CTRNUM = [F:HRACCR]CTR and [F:DCG]TIM = [TIM]COD and ([F:DCG]STRDAT >= CYCLESTARTDATE and [F:DCG]STRDAT <= CYCLEENDDATE and UID>0 and ([DCG]STA=1|[DCG]STA=2|[DCG]STA=3|[DCG]STA=4|
& [DCG]STA=5
& ))

  Filter [HRACCR1] Where CTR = [F:HRCTR]CTRNUM and [F:HRACCR1]LVEACCLST = [TIM]LVESUBTYP(S-1) and [F:HRACCR1]LVEACCEXP = CYCLEENDDATE
  #calculate all accruals plus the previous carry overs excluding Excess
  For [HRACCR1]
    ACCRUALS += val([HRACCR1]LVEACCAMT)
  Next
  Filter [HRACCR1]
  If rowcount([DCG]) > 0
        #check for transaction in DCG and amounts taken for whole transaction falling into cycle.
    For [DCG]
        LVETKN = LVETKN + [DCG]NBRDAY
    Next
  Endif
  Filter [DCG]
   #loop array
   #to get couple of accruals extra IF IF IF
#   If ARRAYCHECK<>1
#   For K=0 To maxtab(FUTBALS(K,5))
#          If FUTBALS(K,5)="" : Break : Endif
#          Call CONVERT_TO_DATE(FUTBALS(K,3), ARRAYD) From SUBHRBAL
#          ###infobx "FUTBALS(K,5)= "- FUTBALS(K,5) - " ARRAY CALC " - num$(ARRAYD) - " with cycle last " - num$(CYCARR(I-1,1))
#            ACCRUALS += val(FUTBALS(K,5))
#      Next
#   Endif
#   If ARRAYCHECK=1
      For K=0 To maxtab(FUTBALS(K,5))
          If FUTBALS(K,5)="" : Break : Endif
          Call CONVERT_TO_DATE(FUTBALS(K,3), ARRAYD) From SUBHRBAL
          ACCRUALS += val(FUTBALS(K,5))
      Next
#   Endif

  #carry over
  CAROVERAMT=ACCRUALS-LVETKN
  ####infbox " in CAROVERAMT with " - num$(CAROVERAMT) - " with ALLOWAMT " - num$(ALLOWAMT)
      If [HRLSTH]LVECARPRC=1
      PERCAMT=val([F:HRLSTH]LVECARFWD)/100
      ALLOWAMT= CAROVERAMT*PERCAMT
      ##infbox " PERCAMT " - num$(val([F:HRLSTH]LVECARFWD)) - " with " - num$(PERCAMT)
    Else
      ALLOWAMT= val([F:HRLSTH]LVECARFWD)
    Endif
  If CAROVERAMT>ALLOWAMT
    EXCESSAMT=CAROVERAMT-ALLOWAMT
    CAROVERAMT=ALLOWAMT
    If [HRLSTH1]LVEEXSSUB<>""
      EXCESSCHK=1
      Gosub EXCESS_CARRY_OVER
    Endif
  Endif

  If [F:HRLSTH]LVECARSUB <> ""
    CARRYLST = [F:HRLSTH]LVECARSUB
    #[F:HRACCR]ACCFRM=[F:HRLSTH]COD
      #CHECK DIE MOVE
    Filter [HRLSTH1] Where COD = [F:HRLSTH]LVECARSUB and LEG = [F:CPY]LEG
      #NEW lst EXPIRY
    Read [HRLSTH1] First
      ###infobx "LINKED SUB TYPE " - num$([F:HRLSTH1]LVECARSUB ) - "WITH OPTION " - num$([F:HRLSTH1]CYCLENU) - "AND" - num$([F:HRLSTH1]CYCLEN)
    Filter [HRLSTH1]
    If [F:HRLSTH]LVEACCOPT<>1
      If [F:HRLSTH1]CYCLENU = 1
        [L]ARREXPIRY=EXPIRY#-1
      Else
        [L]ARREXPIRY=EXPIRY#-1
      Endif
          #Gosub CYCLE_CHECK From SUBDCGGLM
          #Call GET_CYCLE_START_DATE([F:HRCTR]CTRNUM, [F:HRLSTH]LVECARSUB, [F:HRACCR1]LVEACCEXP, CYCLESTARTDATE, CYCLEENDDATE) From SUBHRBAL
        For COUNTER = 0 To maxtab(CYCARR)
          If (CYCARR(COUNTER, 1)=[0/0/0]) : Break : Endif
          If ([HRLSTH]LVEACCOPT = 6)
          If (CYCARR(COUNTER, 1) <> [0/0/0]) and ([F:HRACCR1]LVEACCEXP >= CYCARR(COUNTER, 1) and [F:HRACCR1]LVEACCEXP <= CYCARR(COUNTER, 2) and [F:HRPEOD]PEREND(1)<=CYCARR(COUNTER, 2))
            CYCLESTARTDATE = CYCARR(COUNTER, 1)
            CYCLEENDDATE = CYCARR(COUNTER, 2)
            Break
          Endif
          Else
          If (CYCARR(COUNTER, 1) <> [0/0/0]) and ([F:HRACCR1]LVEACCEXP >= CYCARR(COUNTER, 1) and [F:HRACCR1]LVEACCEXP <= CYCARR(COUNTER, 2) and [F:HRPEOD]PEREND(1)<=CYCARR(COUNTER, 2))
            CYCLESTARTDATE = CYCARR(COUNTER, 1)
            CYCLEENDDATE = CYCARR(COUNTER, 2)
            Break
          Endif
          Endif
        Next
        [L]ARREXPIRY=CYCLEENDDATE
     ARRAMT=CAROVERAMT
    Endif
  Else
    #[F:HRACCR]LVEACCLST = [TIM]LVESUBTYP(S-1)
    [L]ARREXPIRY=CYCLEENDDATE#-1
  Endif
  #build array
    FUTBALS(Z,1)=[TIM]COD
    FUTBALS(Z,2)=CARRYLST
    FUTBALS(Z,3)=[L]ARRLVEACCDAT
    FUTBALS(Z,4)=[L]ARREXPIRY#-
    FUTBALS(Z,5)=num$(ARRAMT)
    Call DEBUG_TRACE(2, "SUBHRLTA", "CARRY OVER: [TIM]COD" - [TIM]COD - "[F:HRLSTH]" - [F:HRLSTH]COD - "CARRYLST" - CARRYLST - "[L]ARRLVEACCDAT" - num$([L]ARRLVEACCDAT) - "[L]ARREXPIRY" - num$([L]
& ARREXPIRY) - "ARRAMT"- num$(ARRAMT)) From DEBUGTRACE
    Z+=1
  #Write [F:HRACCR]
Return

$EXCESS_CARRY_OVER
  If [F:HRLSTH]LVEEXSSUB<>""
    #build array
    FUTBALS(Z,1)=[TIM]COD
    FUTBALS(Z,2)=[TIM]LVESUBTYP(S-1)
    FUTBALS(Z,3)=[L]ARRLVEACCDAT
    FUTBALS(Z,4)=[L]ARREXPIRY#-
    FUTBALS(Z,5)=num$(ARRAMT)
    Z+=1
    #Write [F:HRACCR]
  Endif
Return

Subprog DCG_HRLST_FCST(NOE,DCG_LEG,DCG_CRTNUM,AMOUNT,STARTDAT,ENDDAT,N_UID)
Value Char NOE()
Value Decimal AMOUNT()
Value Char DCG_CRTNUM()
Value Char DCG_LEG()
Value Date STARTDAT()
Value Date ENDDAT()
Value Integer N_UID()
  Local Date VARDAT,CYCLESTARTDATE, CYCLEENDDATE
  Local Integer LL,N,DCG_PREV,UPD_CHK,DEFPAYRATE
  Local Char PREV_LST(5),MSUB_TYP(5)
  Local Char AR_LST(10)(0..9,0..9),FUTBALS(50)(0..,0..10)
  Local Decimal LVE_REM
  Local Decimal BASE_AMT,CHECK_DCG
  #Local Date CCYCLDAT
  CHECK_DCG=1
  If clalev([F:TIM])=0      : Local File TIMCOD [TIM] Endif
  If clalev([F:HRLSTH])=0   : Local File HRLVESUBHEA [HRLSTH] Endif
  If clalev([F:HRACCR])=0   : Local File HRLVEACCRU [HRACCR] Endif

  Filter [TIM] Where COD = NOE and LEG = DCG_LEG Order By [TIM]LVESUBPRI
  #SAVAN 2017/09/05
  #Filter [HRLSTH] Where COD = [TIM]LVESUBTYP and LEG = [TIM]LEG
  #Read [HRLSTH] First
#  If [F:HRLSTH]CYCSTRCAL <>""
#    VARDAT = evalue([F:HRLSTH]CYCSTRCAL)
#  #ACCDAT = evalue([F:HRLSTH]CYCSTRCAL)
#  Endif
    #SAVAN 2017/09/05 end
  Gosub CHECK_MINUS_TYPE
  If [F:HRLSTH]CONSCALC<>""
    CHECK_DCG=evalue([F:HRLSTH]CONSCALC)
  Endif
  #Gosub CYCLE_CHECK
  If NOE="SSP"
   Local Integer SSP_TRANS
   If clalev([F:DCGSSP])=0      : Local File DEMCONGE [DCGSSP] Endif
   If clalev([F:HRLSTHS])=0      : Local File HRLVESUBHEA [HRLSTHS] Endif
   Local Char CRITHRTIM(250),CRITHRCTR(250)
    CRITHRLST="1=0 | ([F:HRCTR]CTRNUM = '"+DCG_CRTNUM+"')"
    Filter [HRLSTHS] Where COD = "SSP_E" and LEG = [TIM]LEG
    Read [HRLSTHS] First
    Filter [HRLSTHS]
      VARDAT = evalue([F:HRLSTHS]CYCSTRCAL)
        Filter [DCGSSP] Where CTRNUM=DCG_CRTNUM and TIM="SSP" and ([DCGSSP]STRDAT>=VARDAT | [DCGSSP]ENDDAT >=VARDAT)  and [DCGSSP]ENDDAT<=ENDDAT and UID>0 and ([DCGSSP]STA=1|[DCGSSP]STA=2|[DCGSSP]STA=
& 3|[DCGSSP]STA=4|[DCGSSP]STA=5
& )
        Read [DCGSSP] First
      If rowcount([DCGSSP])=0
        Call LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR) From SUBACCRUAL
      Endif
      Filter [DCGSSP]
  Else
  Call LVE_ENG_FCST(NOE,DCG_CRTNUM,"",ENDDAT,FUTBALS)
  Endif
#  If NOE="SSP"
#   Filter [TIM] Where COD = NOE and LEG = DCG_LEG Order By [TIM]LVESUBPRI
#  Endif
#Filter [HRLSTH]
  BASE_AMT = 0.00
  N=0
  PREV_LST = ""
  DCG_PREV=0
  UPD_CHK=0
  LVE_REM = AMOUNT

  Gosub CHECK_ARRU_TOT

  Gosub CHECK_PREV_DCG_HRLST

  If DCG_PREV = 0
    #SAVAN 2017/08/18 Removed as CTC_END is already set
    #CYC_END = PREVCYCDAT
    #SAVAN end
    Gosub CHECK_DCG_TRANS
  Else
    Gosub CHECK_DCG_TRANS
  Endif
## PEVAN - 2017-10-02 - X3-57843 - START
#  Gosub CHECK_MINUS
  Gosub CHECK_MINUS_BALANCES From SUBDCGGLM
## PEVAN - 2017-10-02 - X3-57843 - END
  Gosub WRITE_DCG_HRLST
  If DCG_PREV=1
    Gosub UPDATE_TRANS_HRLST
  Endif
: DCGFCST_FS
  Filter [TIM]

End
$CHECK_MINUS_TYPE
Local Char MSUB_TYP(5)
If clalev([F:HHRLST])=0 : Local File HRLVESUBHEA [HHRLST] : Endif
For [TIM]
 For CC=1 To dim([TIM]LVESUBTYP)
  If [TIM]LVESUBTYP(CC-1)<>""
         Filter [HHRLST] Where COD = [TIM]LVESUBTYP(CC-1)
         Read [HHRLST] First
        If [HHRLST]LVEFORFEIT=1
          MSUB_TYP=[TIM]LVESUBTYP(CC-1)
        Endif
  Endif
  Filter [HHRLST]
 Next
Next

Return
$CHECK_ARRU_TOT
Local Integer ARRLOOP
Local Decimal ALLOW_AMT,TOTALACCRU,EXT_ALLOW_AMT,TOTZERO
Filter [TIM] Where COD = NOE and LEG = DCG_LEG Order By [TIM]LVESUBPRI
  For [TIM]
    For LL=1 To dim([TIM]LVESUBTYP)
     Call GET_CYCLE_START_DATE_EXTRACTION (DCG_CRTNUM, [TIM]LVESUBTYP(LL-1), ENDDAT, CYCLESTARTDATE, CYCLEENDDATE) From SUBHRBAL
      # filter for accruals where type = TIM and contract and Accrual transaction date > than cycle currently in : and end of leave fits into expiry date
        If [TIM]LVESUBTYP(LL-1)="SSP_E" and DCG_LEG="BRI"
          Filter [HRACCR] Where [HRACCR]LVEACCLST="SSP_E" and [HRACCR]CTR=DCG_CRTNUM Order By [HRACCR]LVEACCDAT
          Read [HRACCR] Last
          Else
      Filter [HRACCR] Where [HRACCR]LVEACCLST = [TIM]LVESUBTYP(LL-1) and [HRACCR]CTR = DCG_CRTNUM and (([HRACCR]LVEACCDAT >= CYCLESTARTDATE and ENDDAT < CYCLEENDDATE) | ([HRACCR]LVEACCEXP >=
& CYCLEENDDATE))
      Endif
        #get base arruals and carry overs
      If rowcount([HRACCR])>0
      For  [HRACCR]
          #Get expiry date for type which will the same
          #get totals for all subtypes from accrual table
          ###infobx "PREV_LST " - PREV_LST - " and LST " - [HRACCR]LVEACCLST
        If PREV_LST = "" | PREV_LST = [HRACCR]LVEACCLST
          PREVCYCDAT = [HRACCR]LVEACCEXP
          BASE_AMT = BASE_AMT + val([HRACCR]LVEACCAMT)
          PREV_LST = [HRACCR]LVEACCLST
          #check for previous
        Else
          BASE_AMT = BASE_AMT + val([HRACCR]LVEACCAMT)
          PREV_LST = [HRACCR]LVEACCLST
            ###infobx "N+1"
          #N=N+1
        Endif
      Next
      Endif
      #SAVAN 2017/08/31 start
      #checking for max credit if allowed for subtypes
      #Max credits is allow or stop for transactions taken
#      Filter [HRLSTH] Where COD = [TIM]LVESUBTYP(LL-1) and LEG = DCG_LEG
#        Read [HRLSTH] First
#        Filter [HRLSTH]
        ALLOW_AMT=[TIM]LVEMAXCRE
        If [TIM]LVEMAXOPT=1 and [TIM]LVEMAXCRE>0   : EXT_ALLOW_AMT=1000 : Endif
        #If ALLOW_AMT="" : ALLOW_AMT=0 : Endif
        ##infobx "ALLOW_AMT " - num$(ALLOW_AMT)
      #SAVAN 2017/08/31
      For ARRLOOP=0 To maxtab(FUTBALS)
        If FUTBALS(ARRLOOP,2)="" : Break : Endif
        If FUTBALS(ARRLOOP,2)=[TIM]LVESUBTYP(LL-1)
          BASE_AMT = BASE_AMT + val(FUTBALS(ARRLOOP,5))
        Endif
      Next
      If [TIM]LVESUBTYP(LL-1) <> ""
        If [TIM]LVESUBTYP(LL-1)=MSUB_TYP
          AR_LST(N,1)=[TIM]LVESUBTYP(LL-1)
          AR_LST(N,2)=num$(BASE_AMT+ALLOW_AMT+EXT_ALLOW_AMT)
          TOTALACCRU= TOTALACCRU + (BASE_AMT+ALLOW_AMT+EXT_ALLOW_AMT)
          TOTZERO=TOTZERO+BASE_AMT
        Else
          AR_LST(N,1)=[TIM]LVESUBTYP(LL-1)
          AR_LST(N,2)=num$(BASE_AMT)
          TOTALACCRU= TOTALACCRU + (BASE_AMT)
          TOTZERO=TOTZERO+BASE_AMT
        Endif
        If GUSER="SAVAN"
             Infbox "write array type arruc - " - [TIM]LVESUBTYP(LL-1) - " with amount " - num$(BASE_AMT)
          Endif
        BASE_AMT = 0.00
        N=N+1
        #check accrual array
      Endif
      Filter [HRACCR]
    Next
  Next
  ARRLOOP=0
          If GUSER="SAVAN"
          #infobx "MSUB_TYP predict- " - MSUB_TYP
        Endif
  #Filter [TIM]
Return


$CHECK_DCG_TRANS
###infobx "DCG Transaction"
  Local Char TKN_LST(10)(0..99,0..99)
  Local Char PREV_T_LST(5)
  Local Decimal TAKN,TOT_TAKN,SSP_TRANS
  #Local Integer TKN
  #If !clalev([F:LSTHEA]) : Local File HRLVESUBHEA  [LSTHEA] : Endif
  CYC_SRT = CYCLESTARTDATE

  #Consumption check

  If clalev([F:DCG1])=0 : Local File DEMCONGE [DCG1] : Endif
  If clalev([F:TIMP])=0 : Local File TIMEMP [TIMP] : Endif

  #Filter [TIM] Where COD = NOE and LEG = DCG_LEG Order By [TIM]LVESUBPRI
  For [TIM]
    For LL=1 To dim([TIM]LVESUBTYP)
     Call GET_CYCLE_START_DATE_DCG (DCG_CRTNUM, [TIM]LVESUBTYP(LL-1), ENDDAT, CYCLESTARTDATE, CYCLEENDDATE,DCG_LEG)
      #Filter [TIMP] Where CTRNUM = DCG_CRTNUM and (STRDAT >= CYCLESTARTDATE and STRDAT < CYCLEENDDATE) and DCGUID>0 Order By [F:TIMP]DCGUID
#      If [F:HRLSTH]CONSCALC<>""
#        CYC_SRT=evalue([F:HRLSTH]CYCSTRCAL)
#      Endif
#For [TIMP]

  Filter [DCG1] Where CTRNUM = DCG_CRTNUM and [DCG1]TIM = [TIM]COD  and ((STRDAT >= CYCLESTARTDATE and STRDAT < CYCLEENDDATE) | (ENDDAT >= CYCLESTARTDATE and ENDDAT < CYCLEENDDATE)) and UID>0 and ([
& DCG1]STA=1|[DCG1]STA=2|[DCG1]STA=3|[DCG1]STA=4|[DCG1]STA=5)
& Order By [F:DCG1]STRDAT
#    If GUSER="SAVAN" and [TIM]LVESUBTYP(LL-1)="SSP_W"
#        #infbox "cycle check for UK  - CYCLESTARTDATE " -  num$(CYCLESTARTDATE) - " and CYCLEENDDATE " - num$(CYCLEENDDATE) - " rocount" - num$(rowcount([DCG1]))
#  Endif
  #SAVAN UK SSP_W check only used for UK checks
  SSP_TRANS=rowcount([DCG1])
  #SAVAN end
  Read [DCG1] First
    ###infobx num$(rowcount([DCG1])) - " for contract " - DCG_CRTNUM - " for period between " - num$(CYC_SRT) - " and " - num$(CYC_END)
  If !fstat
    For TKN = 1 To dim([F:DCG1]LVESUBTYP)
      For [DCG1]
        If [F:DCG1]LVESUBTYP(TKN-1) = "" : Break : Endif
#        If PREV_T_LST = "" | PREV_T_LST = [F:DCG1]LVESUBTYP(TKN-1)
#          TAKN = TAKN + val(num$([F:DCG1]LVESUBBAL(TKN-1)))
#          PREV_T_LST = [F:DCG1]LVESUBTYP(TKN-1)
#            #check for previous
#        Else
#          TAKN = TAKN + val(num$([F:DCG1]LVESUBBAL(TKN-1)))
#          PREV_T_LST = [F:DCG1]LVESUBTYP(TKN-1)
#          #N=N+1
#        Endif
      If [F:DCG1]LVESUBTYP(TKN-1)=[TIM]LVESUBTYP(LL-1)
       TAKN = TAKN + val(num$([F:DCG1]LVESUBBAL(TKN-1)))
      Endif
      Next
      If [F:DCG1]LVESUBTYP(TKN-1) <> "" and [F:DCG1]LVESUBTYP(TKN-1)=[TIM]LVESUBTYP(LL-1)
          If GUSER="SAVAN"
             Infbox "write array type TAKEN - " - [F:DCG1]LVESUBTYP(TKN-1) - " with amount " - num$(TAKN)
          Endif
        TOT_TAKN=TOT_TAKN+TAKN
        TKN_LST(N,1)=[F:DCG1]LVESUBTYP(TKN-1)
        TKN_LST(N,2)=num$(TAKN)
        TAKN = 0.00
        N=N+1
      Endif
    Next
  Endif
    Next
      Filter [DCG1]
  Next
  #Filter [TIM]
#Next
Return

$CHECK_MINUS
Local Integer FRC_ERR
Local Decimal DD
DD=TOT_TAKN+AMOUNT
 If GUSER="SAVAN"
  ##infobx "TOT_TAKEN " - num$(TOT_TAKN) - " with AMOUNT" - num$(AMOUNT) - " added equals " - num$(DD)- " with TOTALACCRU " - num$(TOTALACCRU)
 Endif
 If DD>TOTZERO
  GERR=2
  GMESSAGE = mess(27,11691,1)
 Endif
 If DD>TOTZERO+ALLOW_AMT
  GERR=2
  GMESSAGE = mess(29,11691,1)
 Endif
  If DD>TOTALACCRU
    GMESSAGE = mess(26,11691,1)
    #Raz [M:DCG1]NBLIG(nolign)
    Goto DCGFCST_FS
  Endif

Return
$WRITE_DCG_HRLST
#check for priority and determin fractions
#accruals
  For SS =1 To dim(AR_LST)
    If AR_LST(SS-1,1) <> ""
      If LVE_REM > 0 #and LVE_REM <= val(num$(AR_LST(SS-1,2)))
        Gosub CHECK_SPLIT_DCG_HRLST
      Elsif LVE_REM=0
             ###infobx "0"
        If UPD_CHK=0
           Gosub GET_DEF_NUM
          [F:DCG]LVESUBRAT(SS-1)=DEFPAYRATE
          [F:DCG]LVESUBTYP(SS-1)=AR_LST(SS-1,1)
          [F:DCG]LVESUBBAL(SS-1)=LVE_REM
        Else
          #Update [DCG_T] Where UID = TKN_LST_DAT(UPD_LST-1,5) With [DCG]LVESUBBAL(SS-1) = LVE_REM
          Gosub UPDATE_DCG
        Endif
      Endif
    Endif
  Next
  If UPD_CHK=0
    ##infobx "[F:DCG]UID " - num$([F:DCG]UID)
    Write [DCG]
    #JOJAC - START
    #If [M:DCG1]SXPCAT(nolign-1)="SMP"
    #  Write [SMPLVE]
    #Endif
    #JOJAC - END
    ##infobx " PAST"
    #build array
  Endif
Return
$UPDATE_DCG
#Jaco DCG super split


Update [DCG_T] Where LNK = TKN_LST_DAT(UPD_LST-1,5)  With [DCG_T]LVESUBBAL(SS-1) = LVE_REM
Return
$CHECK_SPLIT_DCG_HRLST

  Local Decimal DIFF_TAKEN
  Local Char NEW_LST(5)

  If !clalev([F:HRLSTH2]) : Local File HRLVESUBHEA  [HRLSTH2] : Endif
  Read [HRLSTH2]HRLST1 = [TIM]LVESUBTYP(SS-1)
  If [F:HRLSTH2]CONSCALC<>""
    CHECK_DCG=evalue([F:HRLSTH2]CONSCALC)
  Endif
#        If GUSER="SAVAN" and [TIM]LVESUBTYP(SS-1)="SSP_W"
#             #infbox "CHECK_DCG " - num$(CHECK_DCG) - " with amount trans " - num$(SSP_TRANS)
#      Endif
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'PIW_N'
  #true DCG end - str > 3
    AR_LST(0,2)="0"
    TKN_LST(0,2)="0"
  Endif
    If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SSP_N'
  #true DCG end - str > 3
    AR_LST(3,2)="0"
    TKN_LST(3,2)="0"
  Endif

If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SSP_W'
    ##infobx "SSP_W"
    AR_LST(1,2)="0"
    TKN_LST(1,2)="0"
  Endif
If CHECK_DCG=1 & SSP_TRANS<>0 & [TIM]LVESUBTYP(SS-1) = 'SSP_W'
    ##infobx "SSP_W"
    TKN_LST(1,2)="3"
  Endif

  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SSP_E'
  #true DCG end - str > 3
    AR_LST(2,2)="0"
    TKN_LST(2,2)="0"
  Endif

  #JOJAC - 2017-10-16 - X3-15908 - START
  #SMP
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SMP_H'
    AR_LST(0,2)="0"
    TKN_LST(0,2)="0"
  Endif

  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SMP_S'
    AR_LST(1,2)="0"
    TKN_LST(1,2)="0"
  Endif

  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SMP_N'
    AR_LST(2,2)="0"
    TKN_LST(2,2)="0"
  Endif

#SPP
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SPP_E'
    AR_LST(0,2)="0"
    TKN_LST(0,2)="0"
  Endif

  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SPP_N'
    AR_LST(1,2)="0"
    TKN_LST(1,2)="0"
  Endif
  #JOJAC - 2017-10-16 - X3-15908 - END

  For SL =1 To dim(TKN_LST)
    If TKN_LST(SL-1,1) = "" : NEW_LST = AR_LST(SS-1,1) : Endif
    If (TKN_LST(SL-1,1) = AR_LST(SS-1,1) and LVE_REM <> 0) | ((NEW_LST = AR_LST(SS-1,1)) and LVE_REM <> 0)
              #check allready taken vs requested
      DIFF_TAKEN = val(num$(AR_LST(SS-1,2))) - val(num$(TKN_LST(SL-1,2)))
              ###infobx "Diff taken" - num$(DIFF_TAKEN) - " leave type " - AR_LST(SS-1,1)
      If TKN_LST(SL-1,2) = "" : DIFF_TAKEN = val(num$(AR_LST(SS-1,2))) : Endif
      If DIFF_TAKEN > 0
        If LVE_REM <= DIFF_TAKEN
                  ###infobx "1" - num$(LVE_REM) - " leave type " - AR_LST(SS-1,1)
          If UPD_CHK=0
            Gosub GET_DEF_NUM
            [F:DCG]LVESUBRAT(SS-1)=DEFPAYRATE
            [F:DCG]LVESUBTYP(SS-1)=AR_LST(SS-1,1)
            [F:DCG]LVESUBBAL(SS-1)=LVE_REM
            LVE_REM = 0.00
          Else
            #Gosub UPDATE_DCG
             Update [DCG_T] Where LNK = TKN_LST_DAT(UPD_LST-1,5) and UID>0  With [F:DCG_T]LVESUBBAL(SS-1)=LVE_REM
            LVE_REM = 0.00
          Endif
                  #return to LST loop
          Break
        Endif
        If LVE_REM > DIFF_TAKEN and LVE_REM <> 0
                   ###infobx "2" - num$(LVE_REM)  - " leave type " - AR_LST(SS-1,1)
          If UPD_CHK=0
            LVE_REM = LVE_REM - DIFF_TAKEN
                     ###infobx "3" - num$(LVE_REM)
            Gosub GET_DEF_NUM
            [F:DCG]LVESUBRAT(SS-1)=DEFPAYRATE
            [F:DCG]LVESUBTYP(SS-1)=AR_LST(SS-1,1)
            [F:DCG]LVESUBBAL(SS-1)=DIFF_TAKEN
          Else
          #Gosub UPDATE_DCG
           Update [DCG_T] Where LNK = TKN_LST_DAT(UPD_LST-1,5) and UID>0  With [F:DCG_T]LVESUBBAL(SS-1)=DIFF_TAKEN
          Endif
        Endif
                #return to LST loop
        Break
      Endif
      If DIFF_TAKEN = 0
        If UPD_CHK=0
          Gosub  GET_DEF_NUM
          [F:DCG]LVESUBRAT(SS-1)=DEFPAYRATE
          [F:DCG]LVESUBTYP(SS-1)=AR_LST(SS-1,1)
          [F:DCG]LVESUBBAL(SS-1)=DIFF_TAKEN
        Else
          #Gosub UPDATE_DCG
          Update [DCG_T] Where LNK = TKN_LST_DAT(UPD_LST-1,5) and UID>0  With [DCG_T]LVESUBBAL(SS-1) = DIFF_TAKEN
        Endif
      Endif
              #return to LST loop
      Break
    Endif
          #Endif
  Next
Return

$CHECK_PREV_DCG_HRLST

  Local Integer AFF_DCG
#check dates of transaction for future transactions
  Local Date CYC_SRT,CYC_END
  Local Char TKN_LST_DAT(10)(0..99,0..99)
  Local Char PREV_T_LST(5)
  Local Date CYC_END_1(10)
  If clalev([F:DCG_T])=0      : Local File DEMCONGE [DCG_T] : Endif
  #CYC_SRT = CCYCLDAT
  CYC_END = CYCLEENDDATE
  N=0

  Filter [DCG_T] Where CTRNUM = DCG_CRTNUM and (STRDAT >= CYCLESTARTDATE and ENDDAT <= CYCLEENDDATE) and UID>0 and ([DCG_T]STA=1|[DCG_T]STA=2|[DCG_T]STA=3|[DCG_T]STA=4|[DCG_T]STA=5) Order By [DCG_T]
& STRDAT
    ###infobx num$(rowcount([DCG_T])) - " for contract " - DCG_CRTNUM - " for period between " - num$(CYC_SRT) - " and " - num$(PREVCYCDAT)
  Read [DCG_T] First
  If !fstat
    For [DCG_T]
      If STARTDAT < [DCG_T]STRDAT
            ###infobx  " Dates smaller than " - num$([DCG_T]STRDAT)
        TKN_LST_DAT(N,1)=[DCG_T]TIM
        TKN_LST_DAT(N,2)=num$([DCG_T]NBRDAY)
        TKN_LST_DAT(N,3)=[DCG_T]STRDAT
        TKN_LST_DAT(N,4)=[DCG_T]ENDDAT
        TKN_LST_DAT(N,5)=num$([DCG_T]UID)
        CYC_END_1(N)=[DCG_T]STRDAT
        DCG_PREV = 1
        N=N+1
      Endif
        #1. write new transaction if there was no future trans
        #2. Get list of trans after the middle one
        #3. Update the remaining trans split from CHECK_DCG_TRANS with days.
        #4. Calculate the LST part -- Ann1 = amount after middle on is inserted.

    Next
    If DCG_PREV = 1
      CYC_END = CYC_END_1(0) - 1
    Endif
  Endif

      #Loop check for Leave trans affected
      ###infobx "Dimentions " - num$(dim(TKN_LST_DAT))

  Filter [DCG_T]
  Close File [DCG_T]
Return

$UPDATE_TRANS_HRLST
  Local Integer UPD_LST
  For UPD_LST=1 To dim(TKN_LST_DAT)
    If TKN_LST_DAT(UPD_LST-1,1) <> ""
      CYC_END=TKN_LST_DAT(UPD_LST-1,3)
      LVE_REM=val(TKN_LST_DAT(UPD_LST-1,2))
      ###infobx "history update check is 1"
      UPD_CHK=1
      ###infobx "testing the TIM" - num$(TKN_LST_DAT(UPD_LST-1,1)) - " with date" - num$(CYC_END) - " and LVE_REM" - num$(LVE_REM)
      If clalev([F:DCG_T])=0      : Local File DEMCONGE   [DCG_T] : Endif
      Gosub CHECK_DCG_TRANS
      ###infobx "datum om te check" - num$(TKN_LST_DAT(UPD_LST-1,3)) - " with dim" - num$(UPD_LST)
      Gosub WRITE_DCG_HRLST
      Close File [DCG_T]
    Endif
  Next
Return
$GET_DEF_NUM

Local Integer DEFPAYRATE
If clalev([HRLSTRAT]) = 0      : Local File HRLVESUBHEA [HRLSTRAT] Endif
Filter [HRLSTRAT] Where COD = AR_LST(SS-1,1) and LEG = [TIM]LEG
  Read [HRLSTRAT] First
For PAY=1 To dim([HRLSTRAT]LVEPAYDEF)
   If [HRLSTRAT]LVEPAYDEF(PAY-1)=2
   DEFPAYRATE=PAY
   ###infobx " DEFAULT PAYRATE " - num$(DEFPAYRATE)
   Endif
  Next
  #Filter [HRLSTH1]
Return
Subprog GET_CYCLE_START_DATE_DCG(CTRNUMBER, LVESUBTYPE, FILTERDATE, CYCLESTARTDATE, CYCLEENDDATE,DCG_LEG)
Value Char CTRNUMBER
Value Char LVESUBTYPE
Value Date FILTERDATE
Variable Date CYCLESTARTDATE
Variable Date CYCLEENDDATE
Value Char DCG_LEG

  If (CTRNUMBER = "" | LVESUBTYPE = "" | FILTERDATE = [0/0/0])
    End
  Endif

  Local Date CCYCLDAT, CHECKD, VARDAT, LASTACCRUAL, ACCDAT
  Local Integer COUNTER, RCOUNTACCR
  Local Date CYCARRSTR(0..)
  Local Date CYCARREND(0..)

  If clalev([F:HRLSTH]) = 0: Local File HRLVESUBHEA [HRLSTH]: Endif
  If clalev([F:HRCTR]) = 0: Local File EMPLOCTR [HRCTR]: Endif
  If clalev([F:ACCRU]) = 0: Local File HRLVEACCRU [ACCRU] : Endif
  If clalev([F:DEMCONGE]) = 0: Local File DEMCONGE [DCG]  : Endif
  If clalev([F:HRPEOD]) = 0 : Local File HRPEODET [HRPEOD] : Endif
  If clalev([F:VEP2]) = 0 : Local File VALEMP [VEP2]  : Endif

  Filter [HRCTR] Where [HRCTR]CTRNUM = CTRNUMBER
  Read [HRCTR] First

  Filter [VEP2] Where CTRNUM = CTRNUMBER Order By [F:VEP2]ENDDAT
  Read [VEP2] Last

  Filter [HRLSTH] Where [F:HRLSTH]COD = LVESUBTYPE
  Read [HRLSTH] First

  If parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 0
    VARDAT = [HRCTR]DATANC
  Else
    If evalue([F:HRLSTH]CYCSTRCAL) < [HRCTR]DATANC
      VARDAT=[HRCTR]DATANC
    Else
      VARDAT = evalue([F:HRLSTH]CYCSTRCAL)
    Endif
  Endif

  If parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 0
    ACCDAT = [HRCTR]DATANC
  Else
    If [HRLSTH]LVEACCOPT = 2 : ACCDAT = evalue([F:HRLSTH]LVEACCCAL) : Endif
    If [HRLSTH]LVEACCOPT = 7
      If evalue([F:HRLSTH]CYCSTRCAL) < [HRCTR]DATANC
        ACCDAT = [HRCTR]DATANC
      Else
        ACCDAT = evalue([F:HRLSTH]CYCSTRCAL)
      Endif
    Endif
  Endif

  Local Integer CYCLETRACE
  #SAVAN 2017/08/18
  If [HRLSTH]LVEACCOPT = 2 : VARDAT = evalue([F:HRLSTH]CYCSTRCAL) : Endif
  If ACCDAT=[0/0/0]
    ACCDAT=VARDAT
  Endif
  #SAVAN END
## PEVAN 2017-08-22 X3-53416 START
#  If (FILTERDATE <= datesyst)
#    Gosub CYCLE_CHECK From SUBACCRUAL
#  Else
#    Gosub CYCLE_CHECK From SUBACCFCST
#  Endif
  If [F:HRLSTH]LEG<>"BRI"
  Gosub CYCLE_CHECK From SUBACCRUAL
  Else
  Gosub CYCLE_CHECK From SUBDCGGLM
  Endif
## PEVAN 2017-08-22 X3-53416 END
  If CYCLETRACE <> 0
    ###infobx LVESUBTYPE - "Cycle error"
  Endif
  CYCLETRACE = 0

  For COUNTER = 0 To maxtab(CYCARR)
    If CYCARR(COUNTER, 1) <> [0/0/0] and FILTERDATE >= CYCARR(COUNTER, 1) and FILTERDATE <= CYCARR(COUNTER, 2)
      CYCLESTARTDATE = CYCARR(COUNTER, 1)
      CYCLEENDDATE = CYCARR(COUNTER, 2)
      Break
    Endif
  Next

  If CYCLESTARTDATE = [0/0/0]
    #Call DEBUG_TRACE(2, "SUBHRLTA", CTRNUMBER - LVESUBTYPE - " FILTERDATE: " - num$(FILTERDATE) - " CYCLESTARTDATE: " - num$(CYCLESTARTDATE) - " CYCLEENDDATE: " - num$(CYCLEENDDATE)) From DEBUGTRACE
#    Call DEBUG_TRACE(2, "SUBHRLTA", "CYCARR" - num$(CYCARR(0, 1)) - num$(CYCARR(0, 2))) From DEBUGTRACE
#    Call DEBUG_TRACE(2, "SUBHRLTA", "CYCARR" - num$(CYCARR(1, 1)) - num$(CYCARR(1, 2))) From DEBUGTRACE
#    Call DEBUG_TRACE(2, "SUBHRLTA", "CYCARR" - num$(CYCARR(2, 1)) - num$(CYCARR(2, 2))) From DEBUGTRACE
  Else
    #Call DEBUG_TRACE(1, "SUBHRLTA", CTRNUMBER - LVESUBTYPE - " FILTERDATE: " - num$(FILTERDATE) - " CYCLESTARTDATE: " - num$(CYCLESTARTDATE) - " CYCLEENDDATE: " - num$(CYCLEENDDATE)) From DEBUGTRACE
  Endif
  Filter [HRCTR]
  Filter [VEP2]
  Filter [HRLSTH]
End

