#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UUCHK  Squelette pour Moulinette                      Module CPT    #
#            description de la moulinette                                #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UUCHK71182 Process") From LECFIC

  Call MAJ_71182(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_71182(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, NBRPYH
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30)
Local Integer ICLE1, ICLE2, ICLE3


Call ECR_TRACE("UUCHK : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:DAE])  =0  Local File =DOSSIER+".GACCENTRYD"   [DAE] : Endif
If clalev([F:RBK])  =0  Local File =DOSSIER+".RELBANK"      [RBK] : Endif
If clalev([F:BAN])  =0  Local File =DOSSIER+".BANK"         [BAN] : Endif


Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
Raz COMPTEUR

Local Decimal  CHKDAE,CHKRBK

Filter [RBK] Order By Key CLE=BAN;CHK;RBKNUM;NUMRBK

$LOOP_RBK
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:RBK]BAN='"+ACLE1+"' & [F:RBK]CHK='"+ACLE2+"' & [F:RBK]RBKNUM='"+ACLE3+"' & [F:RBK]NUMRBK>"+num$(ICLE1)
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:RBK]BAN='"+ACLE1+"' & [F:RBK]CHK='"+ACLE2+"' & [F:RBK]RBKNUM>'"+ACLE3+"'" 
Elsif STOP=3
 STOP = 4 
 CRITERE = "[F:RBK]BAN='"+ACLE1+"' & [F:RBK]CHK>'"+ACLE2+"'"
Elsif STOP=4
 STOP = 0
 CRITERE = "[F:RBK]BAN>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

For [RBK]CLE(1) Where evalue(CRITERE) 

 Read [BAN]BAN0 = [F:RBK]BAN
 If !fstat

  For [RBK]CLE(2)
 
   If [RBK]CHK<>"" & [RBK]CHK<>"*" & [RBK]CHK>="AAAAA" & [RBK]CHK<="ZZZZZ"
    Raz CHKRBK,CHKDAE
 
    For [RBK]CLE(3)
     Call ECR_TRACE("----------RBK----------"-[F:RBK]BAN-[F:RBK]RBKNUM,-1) From GESECRAN
     For [RBK]CLE
      CHKRBK += [F:RBK]AMTCUR*[F:RBK]SNS
      NB+=1
     Next
    Next

    Filter [DAE] Where COA=[F:BAN]COA & ACC=[F:BAN]BANACC & CHK=[F:RBK]CHK
    For [DAE]
     Call ECR_TRACE("----------DAE----------"-[F:DAE]TYP-[F:DAE]NUM,-1) From GESECRAN
     CHKDAE += [F:DAE]AMTCUR*[F:DAE]SNS
    Next

    If CHKRBK<>CHKDAE
     Call ECR_TRACE([F:RBK]CHK-"("+num$(CHKDAE)+"<>"+num$(CHKRBK)+")",1) From GESECRAN
     COMPTEUR+=1
    Else
#     Call ECR_TRACE([F:RBK]CHK-"("+num$(CHKDAE)+"="+num$(CHKRBK)+")",0) From GESECRAN
    Endif
   Endif

   If NB>GMAXUPDTRS
    ACLE1 = [F:RBK]BAN
    ACLE2 = [F:RBK]CHK
    ACLE3 = [F:RBK]RBKNUM
    ICLE1 = [F:RBK]NUMRBK
    STOP=1
    Break 2
   Endif
  Next
 Endif
Next

If STOP
 Goto LOOP_RBK
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [DAE], [RBK], [BAN]

Call ECR_TRACE("UUCHK : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End




