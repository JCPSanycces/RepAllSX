#<AdxTL>@(#)2.0.0.0 $Revision$
#** FQ100587 (G80E53) UMAJFACT
#
# CBO 2014.07.29 Taux de TVA récupérée FAS
# CBO 2014.07.28 Taux de TVA récupérée LOF
# CBO 2014.07.21 Mauvaise sélection des dépenses
#
#** Traitement de synchronisation des tx de TVA
#*
#*
#* @param PCPY          si vide : toutes
#* @param PFCY          si vide : tous
#* @param PDATECHGT     date de chgt du taux de TVA
#* @param PFLGSIM       simulation
#* @param PTRACEDET     Non : trace uniquement avec les champs (concernés) modifiés    Oui : trace avec tous les champs (concernés)
#* @param PSELLOF       Sélection supplémentaire (sur les dépenses)
#* @param PVERIF_AFTER  pour vérifier après traitement : sélectio de TOUTES les dépenses liées à des factures et trace de
#*                      tous les champs traités au niveau dépenses/bien
#*!
Subprog UMAJFACT(PCPY, PFCY, PDATECHGT, PFLGSIM, PTRACEDET, PSELLOF, PVERIF_AFTER)
Value Char PCPY(), PFCY
Value Date PDATECHGT
Value Integer PFLGSIM, PTRACEDET
Value Char PSELLOF()
Value Integer PVERIF_AFTER


If PVERIF_AFTER = G_OUI
    PFLGSIM = G_OUI
    PTRACEDET = G_NON
Else
    PVERIF_AFTER = G_NON
Endif

Local Char TAX(10), COMPANY(10), WCH(250)(50), WCHCPY(250)
Local Char WFILTRECPY(250), WFILTRELOF(250), WDEV_PCG(10), WDEV_IAS(10)
Local Char WOBJET(30), WREF(30)
Local Date DAT
Local Integer  STAT, WBOK, WB_A_MAJ, WIAS_GERE, I, J, WCPTR, WCPTR_CH, WB_MTTS_TVA_MODIFIE
Local Integer WNBTOT_BIENMAJ, WNBTOT_LOFMAJ, WNBTOT_BIENERR
Local Decimal WECART_TVA_PCG, WECART_TVA_RECUP_PCG, WECART_TVA_IAS, WECART_TVA_RECUP_IAS
Local Decimal  TAUX1, TAUX2, ANCIEN_TAUX_DEP, WCALC
Local Decimal L_AMTVATIAS, L_AMTVATRIAS
Local Decimal WMMT_LOF_TVA_FACT, WMMT_LOF_TVA_FACT_REC, WIAS_LOF_TVA_FACT, WIAS_LOF_TVA_FACT_REC

Local Integer NBCNX
Local Integer TCNX(50), TPLN(50, 100), TORIBASDPR(50, 100)
Local Date TFIYENDDAT(50), TPERENDDAT(50)

    If PFLGSIM <> G_OUI
        PFLGSIM = G_NON
    Endif
    If PDATECHGT = [0/0/0]
        End
    Endif


# ************************************************************************

    Raz WNBTOT_BIENMAJ,WNBTOT_LOFMAJ,  WNBTOT_BIENERR, WCPTR


    Call TEMPON(mess(71, 7784, 1)) From GESECRAN
    Call DEB_TRACE(PCPY, PFCY, PDATECHGT, PFLGSIM, PSELLOF, PTRACEDET, PVERIF_AFTER)

    If !clalev([F:CPY])
        Local File COMPANY  [CPY]
    Endif

    If !clalev([F:FCY])
        Local File FACILITY  [FCY]
    Endif

    If !clalev([F:CNX])
        Local File CONTEXT  [CNX]
    Endif

    If !clalev([FIY])
        Local File FISCYEAR  [FIY]
    Endif

    If !clalev([F:LOF])
        Local File LAYOUTFAS  [LOF]
    Endif
    If !clalev([F:LOF2])
        Local File LAYOUTFAS  [LOF2]
    Endif

    If !clalev([F:FAS])
        Local File FXDASSETS  [FAS]
    Endif

    If !clalev([F:DEP])
        Local File DEPREC  [DEP]
    Endif


    If !clalev([F:PIH])
        Local File PINVOICE  [PIH]
    Endif

    If !clalev([F:TVT])
        Local File TABVAT  [TVT]
    Endif

    If !clalev([F:TRA])
        Local File TABRATVAT  [TRA]
    Endif




    If PCPY = ""
        WFILTRECPY = "CPY <> ''"
    Else
        WFILTRECPY = "CPY = PCPY"
    Endif


    For [CPY] Where evalue(WFILTRECPY)

        WBSOCERR = 0
        WCPTR += 1
        If mod (WCPTR, 100) = 0
            Call TEMPON(mess(6, 47, 1) - ":" - [F:CPY]CPY) From GESECRAN
        Endif

        Gosub INIT_CNXPLN
        If NBCNX
            Gosub TRT_CPY
        Endif

    Next

    Call TEMPOFF From GESECRAN
    Call FIN_TRACE(WNBTOT_LOFMAJ, WNBTOT_BIENMAJ, WNBTOT_BIENERR, PFLGSIM)

End

# Infos cnx et pln de la société traitée
$INIT_CNXPLN

    Raz NBCNX, TCNX, TPLN, TORIBASDPR, WIAS_GERE, TFIYENDDAT, TPERENDDAT, WDEV_PCG, WDEV_IAS

    For [CNX]CNX0 Where CPY = [F:CPY]CPY
        NBCNX += 1
        TCNX(NBCNX) = [F:CNX]CNX
        Read[FIY]FIY1 = [F:CPY]CPY; [F:CNX]CNX; GVML_TECOURA
        TFIYENDDAT(NBCNX) = [F:FIY]DATENDFIY
        TPERENDDAT(NBCNX) = [F:FIY]DATENDPER([F:FIY]INDCURPER - 1)

        For I = 0 To [F:CNX]NBPLC - 1
            TPLN(NBCNX, I + 1) = [F:CNX]PLNCAA(I)
            If [F:CNX]PLNCAA(I) = 1
                WDEV_PCG = [F:CNX]CUR
            Endif
            TORIBASDPR(NBCNX, I + 1) = [F:CNX]ORIBASDPR(I) # 1 PCG  2 IAS autre -> non
            If [F:CNX]ORIBASDPR(I) = 2
                WIAS_GERE = 1
                WDEV_IAS = [F:CNX]CUR
            Endif
#Call ECR_TRACE(num$([F:CNX]CNX) - num$(TPLN(NBCNX, I + 1)) - num$(TORIBASDPR(NBCNX, I + 1)) - num$(WIAS_GERE), 0) From GESECRAN
        Next I
    Next
Return


$TRT_CPY

    WFILTRELOF = "(CPY = '" + [F:CPY]CPY + "'"
    If PFCY <> ""
        WFILTRELOF -= "and FCY = '" + PFCY + "'"
    Endif

    # sélection des LOF d'origine facture
    WFILTRELOF -= "and (CPMCREORI = 1 or CPMCREORI = 2)"

    # dépenses >= à la date sélectionnée
    # La date de facture < PDATECHGT    et
    # La date d'imputation >= PDATECHGT donnent la condition pour un mauvais taux
# CBO 2014.07.21
#    WFILTRELOF -= "and DATVCR >= PDATECHGT)"
    WFILTRELOF -= "and DATVCR <  PDATECHGT"
    WFILTRELOF -= "and DATIMP >= PDATECHGT)"

    # sélection complémentaire des dépenses (saisie à l'écran)
    If PSELLOF <> ""
        If left$(PSELLOF, 3) = "and"
            WFILTRELOF -= PSELLOF
        Else
            WFILTRELOF -= "and" - PSELLOF
        Endif
    Endif
    WCHCPY = mess(6, 47, 1)    - ":" - [F:CPY]CPY - "______________________________________________"

    # cpy, fcy, liaison, bien, dep principale
    # La dépense principale doit être traitée après les autres :
    # on calcule les montants IAS pour maj des biens

    Filter [LOF] Where evalue(WFILTRELOF) Order With "CPY; FCY; FLGLIKAAS; AASREF; FLGLOFMAI; CODLOF; LINLOF"
    For [LOF]

        Trbegin [LOF]
        WB_A_MAJ = 0

        # recherche facture et infos ________________________________________
        WBOK = 1
        Read [PIH]PIH0 = [F:LOF]CODLOF
        If fstat
            WBOK = 0
            WNBTOT_BIENERR += 1
            Call ECR_TRACE(mess(79, 7770, 1) - ":" - [F:LOF]CPY - [F:LOF]CODLOF - "PIH not found CPMCREORI =" -
&                          num$([F:LOF]CPMCREORI) - "(<-" - mess([F:LOF]CREORI, GML_CREORI, 1), 0) From GESECRAN
        Else

            # Recherche des infos TVA
            If [F:PIH]TAX = ""
                WBOK = 0
            Else
                [L]TAX = [F:PIH]TAX
#                [L]DAT     = [F:LOF]DATIMP C'était le bug
                [L]DAT     = [F:LOF]DATVCR
                [L]COMPANY = [F:LOF]CPY

                [L]STAT = 0
                Gosub LECTAX From SUBTVT
                If [L]STAT
                    WBOK = 0
                    WNBTOT_BIENERR += 1
                    Call ECR_TRACE(mess(79, 7770, 1) - ":" - [F:LOF]CPY - [F:LOF]CODLOF - "/ tax code" - [L]TAX - "not found", 0) From GESECRAN
                Endif
            Endif
        Endif

        If WBOK
# CBO 2014.07.28
            # If [F:LOF]RATVAT = [L]TAUX1 and PVERIF_AFTER <> G_OUI
            If [F:LOF]RATVAT = [L]TAUX1 and [F:LOF]RATVATREC = [L]TAUX2 and PVERIF_AFTER <> G_OUI
                WBOK = 0
                Raz WCH
                WCPTR_CH = 1
            Else
                # Tx de TVA différent : dépense à traiter

                If WCHCPY <> ""
                    Call ECR_TRACE("", 0) From GESECRAN
                    Call ECR_TRACE(WCHCPY, 0) From GESECRAN
                    WCHCPY = ""

                    WCPTR_CH = 1 #
#                    Call AFFLIGNE("Objet", "Référence", "Texte", "Avant", "Après", 2, PTRACEDET ,WCH, WCPTR_CH)
                    Call AFFLIGNE(mess(3, 3, 1), mess(6, 159, 1), mess(4, 38, 1), mess(205, 197, 1), mess(206, 197, 1), 2, PTRACEDET ,WCH, WCPTR_CH)

                    WCPTR_CH = 1
                    Call ECR_TRACE(WCH(WCPTR_CH), 0) From GESECRAN
                Endif

                Raz WCH
                WCPTR_CH = 1
                Gosub TRT_LOF

                If WBOK
                    # Dépense immobilisée et principale -> on s'occupe du bien
                    If [F:LOF]FLGLIKAAS = G_OUI and [F:LOF]FLGLOFMAI = G_OUI

                        Read [FAS]FAS0 = [F:LOF]AASREF
                        If fstat
                            WBOK = 0
                            Call AFFLIGNE(mess(80, 7770, 1), [F:LOF]AASREF, mess(86, 7784, 1) - num$(fstat), "", "", 0, PTRACEDET, WCH, WCPTR_CH)

                            WNBTOT_BIENERR += 1
                        Else
                            Gosub TRT_FAS
                        Endif
                    Endif
                Endif
            Endif
        Endif

        If PFLGSIM = G_OUI or WB_A_MAJ = 0
            Rollback
        Else
            Commit
        Endif

        # Compte-rendu
        If WCPTR_CH > 1
              For I = 1 To WCPTR_CH
                  Call ECR_TRACE(WCH(I), 0) From GESECRAN
              Next I
        Endif
    Next
    Filter [LOF]

Return


# Maj de la dépense (taux) ________________________________________
$TRT_LOF
#    If PVERIF_AFTER <> G_OUI or [F:LOF]RATVAT <> [L]TAUX1 or [F:LOF]RATVATREC <> [L]TAUX2
    If [F:LOF]FLGLIKAAS = G_OUI
        Call AFFLIGNE(mess(79, 7770, 1), [F:LOF]CODLOF + "/" + num$([F:LOF]LINLOF), "(<-" - mess([F:LOF]CREORI, GML_CREORI, 1) + ")", mess(78, 7771, 1), "", 2, PTRACEDET, WCH, WCPTR_CH)
    Else
        Call AFFLIGNE(mess(79, 7770, 1), [F:LOF]CODLOF + "/" + num$([F:LOF]LINLOF), "(<-" - mess([F:LOF]CREORI, GML_CREORI, 1) + ")", "", "", 2, PTRACEDET, WCH, WCPTR_CH)
    Endif
#    Endif
    If [F:LOF]RATVAT <> [L]TAUX1 or PVERIF_AFTER = G_OUI
        Call AFFLIGNE("", "", "RATVAT", num$([F:LOF]RATVAT), num$([L]TAUX1), 2, PTRACEDET, WCH, WCPTR_CH)
        [F:LOF]RATVAT = [L]TAUX1
    Endif

# CBO 2014.07.28
    ANCIEN_TAUX_DEP = [F:LOF]RATVATREC
    If [F:LOF]RATVATREC <> [L]TAUX2 or PVERIF_AFTER = G_OUI
        Call AFFLIGNE("", "", "RATVATREC", num$([F:LOF]RATVATREC), num$([L]TAUX2), 2, PTRACEDET, WCH, WCPTR_CH)
        [F:LOF]RATVATREC = [L]TAUX2
        [F:LOF]TAXCOE    = arr([F:LOF]RATVATREC/100, 0.01)
    Endif

    If PVERIF_AFTER = G_OUI
        WB_A_MAJ = 1
        WNBTOT_LOFMAJ += 1
    Else
        Rewrite [LOF]
        If fstat
            WCPTR_CH -= 2
            Call AFFLIGNE(mess(79, 7770, 1), [F:LOF]CODLOF + "/" + num$([F:LOF]LINLOF), mess(87, 7784, 1) - num$(fstat), "", "", 0, PTRACEDET, WCH, WCPTR_CH)
            WBOK = 0
        Else
            WB_A_MAJ = 1
            WNBTOT_LOFMAJ += 1
        Endif
    Endif

Return


# Maj du bien ________________________________________
$TRT_FAS

    # si crédit bail : non traité
    If [F:FAS]OWNTYP = 3
        Call AFFLIGNE(mess(80, 7770, 1), [F:LOF]AASREF, mess(414, 177, 1) - ":" - mess(3, 3171, 1), "", "", 0, PTRACEDET, WCH, WCPTR_CH)
        WBOK = 0
        Return
    Endif


    # Calcul des cumuls TVA des dépenses -> pour Maj des biens

    Raz WMMT_LOF_TVA_FACT, WMMT_LOF_TVA_FACT_REC, WIAS_LOF_TVA_FACT, WIAS_LOF_TVA_FACT_REC
    Raz WECART_TVA_PCG, WECART_TVA_RECUP_PCG, WECART_TVA_IAS, WECART_TVA_RECUP_IAS

    For [LOF2]LOF6 Where AASREF = [F:FAS]AASREF

        If [F:LOF]GACACN = GVML_NIENCOU or [F:LOF]GACACN = GVML_NIENSER
            WMMT_LOF_TVA_FACT += [F:LOF2]AMTVATCPY
            WMMT_LOF_TVA_FACT_REC += [F:LOF2]AMTVATRCPY
        Endif

        If WIAS_GERE and ([F:LOF]IASACN = GVML_NIENCOU or [F:LOF]IASACN = GVML_NIENSER)

            # 1° Recalcul des montants de TVA et TVA récupérée IAS
            # (calculés avec le mauvais taux lors de l'immobilisation)
            If [F:LOF2]CUR = WDEV_IAS
                [F:LOF2]AMTVATIAS = [F:LOF2]AMTVATCUR
                [F:LOF2]AMTVATRIAS = [F:LOF2]AMTVATRCUR
            Elsif WDEV_PCG = WDEV_IAS
                [F:LOF2]AMTVATIAS = [F:LOF2]AMTVATCPY
                [F:LOF2]AMTVATRIAS = [F:LOF2]AMTVATRCPY
            Else
                L_AMTVATIAS = [F:LOF2]AMTNOTIAS * ([F:LOF2]RATVAT / 100 )
                Call GET_MNT_ARRONDI (L_AMTVATIAS, WDEV_IAS, L_AMTVATIAS) From GLOBIENS
                [F:LOF2]AMTVATIAS = L_AMTVATIAS

                L_AMTVATRIAS = L_AMTVATIAS * ([F:LOF2]RATVATREC / 100 )
                Call GET_MNT_ARRONDI (L_AMTVATRIAS, WDEV_IAS, L_AMTVATRIAS) From GLOBIENS
                [F:LOF2]AMTVATRIAS = L_AMTVATRIAS
            Endif
            Rewrite [LOF2]

            # 2° calcul des cumuls
            WIAS_LOF_TVA_FACT += [F:LOF2]AMTVATIAS
            WIAS_LOF_TVA_FACT_REC += [F:LOF2]AMTVATRIAS

        Endif
    Next

    WECART_TVA_PCG = WMMT_LOF_TVA_FACT - [F:FAS]IVCVATAMT
    WECART_TVA_RECUP_PCG = WMMT_LOF_TVA_FACT_REC - [F:FAS]DEDVATAMT

    If WIAS_GERE
        WECART_TVA_IAS = WIAS_LOF_TVA_FACT - [F:FAS]IVCVATAMTI
        WECART_TVA_RECUP_IAS = WIAS_LOF_TVA_FACT_REC - [F:FAS]DEDVATAMTI
    Endif


    # si flg tva forcé et TVA facturée du bien <> de la somme des TVA des dépenses : non

    If [F:FAS]IVCVATFLG = G_OUI and WMMT_LOF_TVA_FACT <> [F:FAS]IVCVATAMT
        Call AFFLIGNE(mess(80, 7770, 1), [F:LOF]AASREF, mess(414, 177, 1) - ": Flag TVA forcé", "", "", 0, PTRACEDET, WCH, WCPTR_CH)

        WBOK = 0
        Return
    Endif


    # traitement du bien ________________________________________

    WB_MTTS_TVA_MODIFIE = 0
    WOBJET = mess(80, 7770, 1)
    WREF = [F:LOF]AASREF

    Call AFFLIGNE2(WOBJET, WREF, "(<-" - mess([F:FAS]CREORI, GML_CREORI, 1) + ")", "", "", 2, PTRACEDET, WCH, WCPTR_CH)
    # TVA PCG non forcée
    If [F:FAS]IVCVATFLG = G_NON or PVERIF_AFTER = G_OUI
#        If PVERIF_AFTER <> G_OUI or
#&          [F:FAS]IVCVATRAT <> [F:LOF]RATVAT or
#&          [F:FAS]IVCVATAMT <> WMMT_LOF_TVA_FACT or
#&          [F:FAS]IVCVATFLG <> G_OUI
#            Call AFFLIGNE2(WOBJET, WREF, "(<-" - mess([F:FAS]CREORI, GML_CREORI, 1) + ")", "", "", 2, PTRACEDET, WCH, WCPTR_CH)
#        Endif
        Call AFFLIGNE2(WOBJET, WREF, "IVCVATAMT", num$([F:FAS]IVCVATAMT), num$(WMMT_LOF_TVA_FACT), 1, PTRACEDET, WCH, WCPTR_CH)
        Call AFFLIGNE2(WOBJET, WREF, "IVCVATFLG", num$([F:FAS]IVCVATFLG), num$(G_OUI), 2, PTRACEDET, WCH, WCPTR_CH)

        [F:FAS]IVCVATAMT = WMMT_LOF_TVA_FACT
        [F:FAS]IVCVATFLG = G_OUI
        WB_MTTS_TVA_MODIFIE = 1
    Endif
    Call AFFLIGNE2(WOBJET, WREF, "IVCVATRAT", num$([F:FAS]IVCVATRAT), num$([F:LOF]RATVAT), 2, PTRACEDET, WCH, WCPTR_CH)
    [F:FAS]IVCVATRAT = [F:LOF]RATVAT

    # TVA PCG récupérée non forcée
    If [F:FAS]DEDVATFLG = G_NON or PVERIF_AFTER = G_OUI
        Call AFFLIGNE2(WOBJET, WREF, "DEDVATAMT", num$([F:FAS]DEDVATAMT), num$(WMMT_LOF_TVA_FACT_REC), 1, PTRACEDET, WCH, WCPTR_CH)
        Call AFFLIGNE2(WOBJET, WREF, "DEDVATFLG", num$([F:FAS]DEDVATFLG), num$(G_OUI), 2, PTRACEDET, WCH, WCPTR_CH)

        [F:FAS]DEDVATAMT = WMMT_LOF_TVA_FACT_REC
        [F:FAS]DEDVATFLG = G_OUI
        WB_MTTS_TVA_MODIFIE = 1

    Endif

# CBO 2014.07.29
    If [F:FAS]DEDVATRAT = ANCIEN_TAUX_DEP
        If [F:FAS]DEDVATRAT <> [L]TAUX2 or PVERIF_AFTER = G_OUI
            Call AFFLIGNE2(WOBJET, WREF, "DEDVATRAT", num$([F:FAS]DEDVATRAT), num$([L]TAUX2), 2, PTRACEDET, WCH, WCPTR_CH)
            [F:FAS]DEDVATRAT = [L]TAUX2
            If WIAS_GERE
                Call AFFLIGNE2(WOBJET, WREF, "DEDVATRATI", num$([F:FAS]DEDVATRATI), num$([L]TAUX2), 2, PTRACEDET, WCH, WCPTR_CH)
                [F:FAS]DEDVATRATI = [L]TAUX2
            Endif
            WCALC = arr([F:FAS]DEDVATRAT/100, 0.01)
            Call AFFLIGNE2(WOBJET, WREF, "TAXCOER", num$([F:FAS]TAXCOER), num$(WCALC), 2, PTRACEDET, WCH, WCPTR_CH)
            [F:FAS]TAXCOER   = WCALC

            Call TVA_COE_DEDUCTION ( [F:FAS]ASJCOER, [F:FAS]TAXCOER, [F:FAS]ADMCOER,
&           WCALC ) From TRTFAS
            Call AFFLIGNE2(WOBJET, WREF, "DEDCOER", num$([F:FAS]DEDCOER), num$(WCALC), 2, PTRACEDET, WCH, WCPTR_CH)
            [F:FAS]DEDCOER = WCALC

            [F:FAS]TAXCOEF = [F:FAS]TAXCOER
            [F:FAS]DEDCOEF = [F:FAS]DEDCOER
        Endif
    Endif

    If WIAS_GERE
        # TVA IAS non forcée
        If [F:FAS]IVCVATFLGI = G_NON or PVERIF_AFTER = G_OUI
            Call AFFLIGNE2(WOBJET, WREF, "IVCVATAMTI", num$([F:FAS]IVCVATAMTI), num$(WIAS_LOF_TVA_FACT), 1, PTRACEDET, WCH, WCPTR_CH)
            Call AFFLIGNE2(WOBJET, WREF, "IVCVATFLGI", num$([F:FAS]IVCVATFLGI), num$(G_OUI), 2, PTRACEDET, WCH, WCPTR_CH)

            [F:FAS]IVCVATAMTI = WIAS_LOF_TVA_FACT
            [F:FAS]IVCVATFLGI = G_OUI
            WB_MTTS_TVA_MODIFIE = 1
        Endif
        Call AFFLIGNE2(WOBJET, WREF, "IVCVATRATI", num$([F:FAS]IVCVATRATI), num$([F:LOF]RATVAT), 2, PTRACEDET, WCH, WCPTR_CH)
        [F:FAS]IVCVATRATI = [F:LOF]RATVAT

        # TVA IAS récupérée non forcée
        If [F:FAS]DEDVATFLGI = G_NON or PVERIF_AFTER = G_OUI
            Call AFFLIGNE2(WOBJET, WREF, "DEDVATAMTI", num$([F:FAS]DEDVATAMTI), num$(WIAS_LOF_TVA_FACT_REC), 1, PTRACEDET, WCH, WCPTR_CH)
            Call AFFLIGNE2(WOBJET, WREF, "DEDVATFLGI", num$([F:FAS]DEDVATFLGI), num$(G_OUI), 2, PTRACEDET, WCH, WCPTR_CH)

            [F:FAS]DEDVATAMTI = WIAS_LOF_TVA_FACT_REC
            [F:FAS]DEDVATFLGI = G_OUI
            WB_MTTS_TVA_MODIFIE = 1
        Endif
    Endif


    If WB_MTTS_TVA_MODIFIE or PVERIF_AFTER = G_OUI
        Call AFFLIGNE2(WOBJET, WREF, "TAXBAS", num$([F:FAS]TAXBAS), num$([F:FAS]TAXBAS + WECART_TVA_PCG - WECART_TVA_RECUP_PCG), 1, PTRACEDET, WCH, WCPTR_CH)
        Call AFFLIGNE2(WOBJET, WREF, "GALREFBAS", num$([F:FAS]GALREFBAS), num$([F:FAS]GALREFBAS + WECART_TVA_PCG - WECART_TVA_RECUP_PCG), 1, PTRACEDET, WCH, WCPTR_CH)

        [F:FAS]TAXBAS    += WECART_TVA_PCG - WECART_TVA_RECUP_PCG
        [F:FAS]GALREFBAS += WECART_TVA_PCG - WECART_TVA_RECUP_PCG

        # Maj des plans d'amt ________________________________________

        If (WECART_TVA_PCG - WECART_TVA_RECUP_PCG) or
&          (WIAS_GERE and(WECART_TVA_IAS - WECART_TVA_RECUP_IAS)) or
&           PVERIF_AFTER = G_OUI

            Gosub TRT_PLN
        Endif

    Endif

    # Maj du bien ________________________________________
    If WBOK # and WB_MTTS_TVA_MODIFIE
        If PVERIF_AFTER = G_OUI
            WB_A_MAJ = 1
            WNBTOT_BIENMAJ += 1
            Return
        Endif
        Rewrite [FAS]

        If fstat
            WBOK = 0
            WB_A_MAJ = 0
            WNBTOT_BIENERR += 1
            WCH(WCPTR_CH)  = func AFFCHP(10, mess(80, 7770, 1), 0)
            WCH(WCPTR_CH) += func AFFCHP(30, [F:LOF]AASREF, 0)
            WCH(WCPTR_CH) += func AFFCHP(20, mess(87, 7784, 1) - num$(fstat), 0)
            WCH(WCPTR_CH) += func AFFCHP(20, "", 0)
            WCH(WCPTR_CH) += func AFFCHP(20, "", 0)
            WCPTR_CH += 1

            Return
        Endif
        WB_A_MAJ = 1
        WNBTOT_BIENMAJ += 1
    Endif

Return


# Maj des plans d'amt ________________________________________
$TRT_PLN

    For I = 1 To NBCNX
        J = 1
        While  TPLN(I, J) <> 0
            Read [DEP]DEP0 = [F:FAS]AASREF; TPLN(I, J); TFIYENDDAT(I); TPERENDDAT(I)
            If fstat
                WBOK = 0
                Call AFFLIGNE(mess(TPLN(I, J), 3101, 1), [F:LOF]AASREF - TPERENDDAT(I), mess(86, 7784, 1) - num$(fstat), "", "", 0, PTRACEDET, WCH, WCPTR_CH)

                WNBTOT_BIENERR += 1
                Break(2)
            Endif

            If TORIBASDPR(I, J) = 1 # origine PCG
                If WECART_TVA_PCG <> WECART_TVA_RECUP_PCG or PVERIF_AFTER = G_OUI
                    [F:FAS]FLGCLC = G_OUI
                    [F:FAS]FLGCNXCLC(TCNX(I) - 1) = G_OUI

                    WOBJET = mess(TPLN(I, J), 3101, 1)
#                    WREF = [F:FAS]AASREF #- format$("D:DD[/]MM[/]YYYY", TPERENDDAT(I))

                    Call AFFLIGNE2(WOBJET, WREF, "BSEVAL",
&                                         num$([F:DEP]BSEVAL), num$([F:DEP]BSEVAL + WECART_TVA_PCG -  WECART_TVA_RECUP_PCG),
&                                         1, PTRACEDET, WCH, WCPTR_CH)
                    Call AFFLIGNE(WOBJET, WREF, "DPRBAS",
&                                         num$([F:DEP]DPRBAS), num$([F:DEP]DPRBAS + WECART_TVA_PCG - WECART_TVA_RECUP_PCG),
&                                         1, PTRACEDET, WCH, WCPTR_CH)

                    [F:DEP]BSEVAL += WECART_TVA_PCG - WECART_TVA_RECUP_PCG
                    [F:DEP]DPRBAS += WECART_TVA_PCG - WECART_TVA_RECUP_PCG
                Endif
            Elsif TORIBASDPR(I, J) = 2 # origine IAS
                If WECART_TVA_IAS <> WECART_TVA_RECUP_IAS or PVERIF_AFTER = G_OUI
                    [F:FAS]FLGCLC = G_OUI
                    [F:FAS]FLGCNXCLC(TCNX(I) - 1) = G_OUI

                    WOBJET = mess(TPLN(I, J), 3101, 1)
#                    WREF = [F:FAS]AASREF #- format$("D:DD[/]MM[/]YYYY", TPERENDDAT(I))

                    Call AFFLIGNE2(WOBJET, WREF, "BSEVAL",
&                                         num$([F:DEP]BSEVAL), num$([F:DEP]BSEVAL + WECART_TVA_IAS - WECART_TVA_RECUP_IAS),
&                                         1, PTRACEDET, WCH, WCPTR_CH)
                    Call AFFLIGNE2(WOBJET, WREF, "DPRBAS",
&                                         num$([F:DEP]DPRBAS), num$([F:DEP]DPRBAS + WECART_TVA_IAS - WECART_TVA_RECUP_IAS),
&                                         1, PTRACEDET, WCH, WCPTR_CH)

                    [F:DEP]BSEVAL += WECART_TVA_IAS - WECART_TVA_RECUP_IAS
                    [F:DEP]DPRBAS += WECART_TVA_IAS - WECART_TVA_RECUP_IAS
                Endif
            Endif

            If PVERIF_AFTER <> G_OUI
                Rewrite [DEP]
                If fstat
                    WBOK = 0
                    WB_A_MAJ = 0
                    WNBTOT_BIENERR += 1
                    WCH(WCPTR_CH)  = func AFFCHP(10, mess(184, 7773, 1), 0)
                    WCH(WCPTR_CH) += func AFFCHP(30, [F:LOF]AASREF - mess(TPLN(I, J), 3101, 1) - TPERENDDAT(I), 0)
                    WCH(WCPTR_CH) += func AFFCHP(20, mess(87, 7784, 1) - num$(fstat), 0)
                    WCH(WCPTR_CH) += func AFFCHP(20, "", 0)
                    WCH(WCPTR_CH) += func AFFCHP(20, "", 0)
                    WCPTR_CH += 1

                    Break(2)
                Endif
            Endif

            J += 1
        Wend
    Next I
Return

Subprog DEB_TRACE(PCPY, PFCY, PDATECHGT, PFLGSIM, PSELLOF, PTRACEDET, PVERIF_AFTER)
Value Char PCPY(), PFCY()
Value Date PDATECHGT
Value Integer PFLGSIM
Value Char PSELLOF()
Value Integer PTRACEDET, PVERIF_AFTER

Local Integer I

    Local Char WLIB(250)

    Call OUVRE_TRACE(mess(85, 7784, 1)) From LECFIC

    Call ECR_SOUL(mess(85, 7784, 1), "_")
    Call ECR_TRACE("", 0) From GESECRAN

    Call ECR_SOUL(mess(4, 26, 1) - ":", "=")
    Call ECR_TRACE("", 0) From GESECRAN

#    Call ECR_TRACE(mess(2, 72, 1) - ":" - GUSER, 0) From GESECRAN
    Call ECR_TRACE("Date :" - format$("D:DD[/]MM[/]YYYY", date$) - "-" - time$, 0) From GESECRAN
    Call ECR_TRACE(mess(815, 9913, 1), 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN

    If PCPY = ""
        Call ECR_TRACE(mess(444, 7773, 1) - ":" - mess(G_OUI, 1, 1), 0) From GESECRAN
    Else
        Call ECR_TRACE(mess(6, 47, 1)    - ":" - PCPY, 0) From GESECRAN
    Endif

    If PFCY = ""
        Call ECR_TRACE(mess(449, 7773, 1) - ":" - mess(G_OUI, 1, 1), 0) From GESECRAN
    Else
        Call ECR_TRACE(mess(7, 47, 1)    - ":" - PFCY, 0) From GESECRAN
    Endif
    Call ECR_TRACE(mess(31, 15, 1)   - ":" - mess(PFLGSIM, 1, 1), 0) From GESECRAN

    Call ECR_TRACE(mess(71, 104, 1) - ":" - PDATECHGT, 0) From GESECRAN

    If PSELLOF <> ""
        Call ECR_TRACE(mess(84, 7784, 1) - PSELLOF, 0) From GESECRAN
    Endif

    Call ECR_TRACE(mess(707, 7773, 1) - mess(PTRACEDET, 1, 1), 0) From GESECRAN
    Call ECR_TRACE(mess(83, 7784, 1)   - ":" - mess(PVERIF_AFTER, 1, 1), 0) From GESECRAN

    Call ECR_TRACE("", 0) From GESECRAN

    Call ECR_SOUL(mess(29, 7778, 1) - ":", "=")
    Call ECR_TRACE("", 0) From GESECRAN

End

Subprog FIN_TRACE(PNBTOT_LOFMAJ, PNBTOT_BIENMAJ, PNBTOT_BIENERR, PFLGSIM)
Value Integer PNBTOT_LOFMAJ, PNBTOT_BIENMAJ, PNBTOT_BIENERR, PFLGSIM

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
    If PFLGSIM = G_OUI
        Call ECR_TRACE(mess(31, 15, 1) - ":", 0) From GESECRAN
        Call ECR_TRACE(num$(PNBTOT_LOFMAJ) - mess(88, 7784, 1), 0) From GESECRAN
        Call ECR_TRACE(num$(PNBTOT_BIENMAJ) - mess(89 , 7784, 1), 0) From GESECRAN
    Else
        Call ECR_TRACE(num$(PNBTOT_LOFMAJ) - mess(82, 7784, 1), 0) From GESECRAN
        Call ECR_TRACE(num$(PNBTOT_BIENMAJ) - mess(73, 7784, 1), 0) From GESECRAN
    Endif
    Call ECR_TRACE(num$(PNBTOT_BIENERR) - mess(95, 143, 1), 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_SOUL(mess(18, 2, 1) - ":" - format$("D:DD[/]MM[/]YYYY", date$) - "-" - time$, "=")

    Call FERME_TRACE() From LECFIC

    If GSERVEUR = 0
        Call LEC_TRACE From LECFIC
    Endif

End

Subprog ECR_SOUL(PTXT, PSOUL)
Value Char PTXT, PSOUL

    Call ECR_TRACE(PTXT, 0) From GESECRAN
    Call ECR_TRACE(string$(len(PTXT), PSOUL), 0) From GESECRAN
End


#**
#* donne le libellé d'1 champ de masque
#*
#* @param PLANGUE
#* @param PMASQUE
#* @param PCHAMP
#* @param RLIBELLE
#*!
Subprog LIBCHPATZ(PLANGUE, PMASQUE, PCHAMP, RLIBELLE)
Value Char PLANGUE, PMASQUE, PCHAMP
Variable Char RLIBELLE

    If !clalev ([F:AMZ])
        Local File = "AMSKZON" [AMZ]
    Endif
    If !clalev ([F:ATX])
        Local File = "ATEXTE" [ATX]
    Endif


    Read [AMZ]CODE = PMASQUE ; PCHAMP
    If fstat
        RLIBELLE = ""
    Else
        Read [ATX]NUMERO =PLANGUE ; [F:AMZ]INTIT
        RLIBELLE = [F:ATX]TEXTE
    Endif
End

#** Formatage d'un champ (pour 1 trace)
#*
#*
#* @param PLEN_CO   longueur affichée
#* @param PCHP      champà afficher
#* @param PBCOLNUM  0 col cadrée à gauche   1 col num   2 col alpha à cadrer à droite
#*!
Funprog AFFCHP(PLEN_COL, PCHP, PBCOLNUM)
Value Integer PLEN_COL
Value Char PCHP()
Value Integer PBCOLNUM

    Local Integer LG, LG2

    # cadrage à droite d'1 alpha
    LG = len(PCHP)
    If PBCOLNUM = 2
        If LG >= PLEN_COL
            LG = PLEN_COL
        Endif
        End string$(PLEN_COL - LG, " ") + left$(PCHP, LG)
    Endif

    # cadrage numérique
    If LG > 2
        If PBCOLNUM = 1
            If mid$(PCHP, LG -2, 1) = "," or  mid$(PCHP, LG -2, 1) = "."
                LG += 0
            Elsif mid$(PCHP, LG -1, 1) = "," or  mid$(PCHP, LG -1, 1) = "."
                PCHP += "0"
                LG += 1
            Else
                PCHP += ".00"
                LG += 3
            Endif
        Endif
    Elsif LG > 0 and PBCOLNUM = 1
        PCHP += ".00"
        LG += 3
    Endif


    LG2 = PLEN_COL - LG
    If LG2 > 0
        If PBCOLNUM = 1
            # cadrage numérique
            End string$(LG2, " ") + left$(PCHP, LG)
        Else
            # cadrage alpha à gauche
            End PCHP + string$(LG2, " ")
        Endif
    Endif
End left$(PCHP, PLEN_COL - 1)

#** Formatage d'1 ligne de trace
#*
#*
#* @param POBJET      objet
#* @param PREF        clef de l'objet
#* @param PMESS       message
#* @param PAVANT      valeur avant
#* @param PAPRES      valeur après
#* @param PBCOLNUM    type des 2 dernières colonnes
#* @param PTRACEDET   trace détaillée
#* @param RCH         ligne formatée
#* @param RCPTR_CH    compteur
#*!
Subprog AFFLIGNE(POBJET, PREF, PMESS, PAVANT, PAPRES, PBCOLNUM, PTRACEDET, RCH, RCPTR_CH)
Value Char POBJET(), PREF(), PMESS(), PAVANT(), PAPRES()
Value Integer PBCOLNUM, PTRACEDET
Variable Char RCH()()
Variable Integer RCPTR_CH


    # Si ... et valeur non modifiée
    If PTRACEDET = G_NON and (PAVANT <> "" or PAPRES <> "") and PAVANT = PAPRES
        End
    Endif

    RCH(RCPTR_CH)  = func AFFCHP(15, POBJET, 0)
    RCH(RCPTR_CH) += func AFFCHP(30, PREF, 0)
    RCH(RCPTR_CH) += func AFFCHP(30, PMESS, 0)
    RCH(RCPTR_CH) += func AFFCHP(20, PAVANT, PBCOLNUM)
    RCH(RCPTR_CH) += func AFFCHP(20, PAPRES, PBCOLNUM)

    RCPTR_CH += 1
End

#** Formatage d'1 ligne de trace AVEC non répétition de la clef
#*
#*
#* @param POBJET      objet
#* @param PREF        clef de l'objet
#* @param PMESS       message
#* @param PAVANT      valeur avant
#* @param PAPRES      valeur après
#* @param PBCOLNUM    type des 2 dernières colonnes
#* @param PTRACEDET   trace détaillée
#* @param RCH         ligne formatée
#* @param RCPTR_CH    compteur
#*!
Subprog AFFLIGNE2(POBJET, PREF, PMESS, PAVANT, PAPRES, PBCOLNUM, PTRACEDET, RCH, RCPTR_CH)
Variable Char POBJET(), PREF()
Value Char PMESS(), PAVANT(), PAPRES()
Value Integer PBCOLNUM, PTRACEDET
Variable Char RCH()()
Variable Integer RCPTR_CH

Local Integer WCPTR_SV

    WCPTR_SV = RCPTR_CH
    Call AFFLIGNE(POBJET, PREF, PMESS, PAVANT, PAPRES, PBCOLNUM, PTRACEDET, RCH, RCPTR_CH)
    If WCPTR_SV <> RCPTR_CH
        Raz POBJET, PREF
    Endif
End
