####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0TECPJT
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_IMODULE From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_SFROM From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_IBOOCRM From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_IBOOPJM From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_IBOOPJMBUD From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_IBOOPJMTAC5 From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_IBOOPJMTAC6 From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_IBOOPJMTAC7 From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_IUSEDISPJM From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_IUSEDISBUD From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_IUSEDISTAC From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_SSITE From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_SSOCIETE From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_SBPR From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_SAIN From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_SPJTFLDH From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_SCOLLECTION From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_SPJTFLDD From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_TCHSNGDOCANS From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1TECPJT : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1TECPJT : Gosub TESTALLSTAT
Gosub AINIT From WMC0TECPJT : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0TECPJT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0TECPJT
Gosub LNKPRO_SSITE From WMC1TECPJT : Gosub TESTALLSTAT
Gosub LNKPRO_SSOCIETE From WMC1TECPJT : Gosub TESTALLSTAT
Gosub LNKPRO_SBPR From WMC1TECPJT : Gosub TESTALLSTAT
Gosub LNKPRO_SAIN From WMC1TECPJT : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1TECPJT : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1TECPJT : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



