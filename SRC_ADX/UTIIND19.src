#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################
# UTIIND19 
# ---------------------------------------------------------------------- #
#         Suppression des trts QLF ne pas les livrer
##########################################################################
Infbox "only update folder by patch"

End


##########################################################################
# Pour exécution automatique en gestion de patch                         #
##########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

# mettre a jour uniquement sur tous les dossiers 
if GADONIX = 2   : End  : endif
if APPLI <> "X3" :  End : endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat = 0
    Call EXE_UTIIND19(APPLI)
Endif
End


##########################################################################
## Suppression process QLF
##########################################################################
#--------------------
Subprog EXE_UTIIND19(DOSSIER)
Value Char    DOSSIER

Local Char    TRT(30)
Local Integer STAT


Call ECR_TRACE("UTIIND19 Start of Update : Deletion of the process QLF in the folder"+DOSSIER,0) From GESECRAN


# delete dico ADICTRT 
If clalev([F:DADC])=0 : Local File =DOSSIER+".ADICTRT"  [DADC] : Endif

Trbegin [DADC]

Filter [DADC]  Where  CODTRT >= "QLF" and CODTRT <= "QLF_Z"

# delete Traitement source et adx
For [DADC] 
    TRT = [F:DADC]CODTRT
    If TRT >= "QLF" and TRT <= "QLF_Z"
        If filinfo(filpath("TRT",TRT,"adx",DOSSIER),1) >= 0
            Call EFFACE_ADX("",DOSSIER,TRT,STAT) from ORDSYS
            If STAT
                Call ECR_TRACE("UTIIND19: Error of deletion - "-filpath("TRT",TRT,"adx",DOSSIER)
&                                 -"(STAT="+num$(STAT)-")",1) From GESECRAN
            Endif
        Endif
        If filinfo(filpath("TRT",TRT,"src",DOSSIER),1) >= 0
            Call EFFACE(filpath("TRT",TRT,"src",DOSSIER),STAT) From ORDSYS
            If STAT
                Call ECR_TRACE("UTIIND19: Error of deletion - "-filpath("TRT",TRT,"src",DOSSIER)
&                                 -"(STAT="+num$(STAT)-")",1) From GESECRAN
            Endif
        Endif
    Endif
Next

Delete [DADC] Where CODTRT >= "QLF" and CODTRT <= "QLF_Z"

Filter [DADC] 

Commit

Call ECR_TRACE("UTIIND19 End of Update",0) From GESECRAN

Close Local File

End



