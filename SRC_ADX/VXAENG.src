#<AdxTL>@(#)4.0.0.0 $Revision$
####################################################################################
# Program Name: VXAENG
# Description : ADC Engagement
# Date        : 13/08/2010
# Type        :
####################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"VXAENG","VXA","XVWXAENG") From GSAISIE
End

########################################################
# Production tracking
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
#
#
#
#
# Necessary value in Entry transaction
# ------------------------------------
########################################################
$ACTION
#--- Actions liées à la fenêtre de saisie
Case ACTION
    When "OUVRE"         : Gosub OUVRE
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "BOUTON"        : Gosub BOUTON
    When "ABANDON"       : Gosub ABANDON
    When "FINSAI"        : Gosub FINSAI
    When "FIN"           : Gosub FIN
Endcase
Return

########################################################
$OUVRE

Global Integer GHCBWCPT
Global Integer GHCBWCPTART
Global Char    GHCBIVALEUR (GLONVCR)
Global Char    GHCBLMFGNUM (GLONVCR)
Global Char    GHCBLITMREF (GLONITM)  # mm 05.08
Global Integer GHCBLBOMOPE
Global Integer GHCBLMFGLIN
Global Integer GHCBLBOMSEQ
Global Date    GHCBLCBTDAT
Global Integer GHCBLMVTSEQ
Global Integer GHCBWBOUT
Global Integer GHCBWCPTENR
Global Integer GHCBLWGGSTA
Global Char    GHCBLPESEE  (GLONVCR)
Global Integer GHCBLRECONCIL


# lreconcil = 0 pas de reconciliation de faite
# lwggsta = ancien code wggsta
GHCBLWGGSTA = 0
GHCBLRECONCIL = 0
GHCBLMFGNUM = ""
GHCBWBOUT = 5
GHCBWCPT = 0
GHCBWCPTENR = 0
GHCBLPESEE =""

# Ouverture des fichiers utilisés
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:WGG])  = 0 : Local File WEIGHING    [WGG]  : Endif
If clalev([F:WGG1]) = 0 : Local File WEIGHING    [WGG1] : Endif   :#DT

Return


########################################################
$DEBUT
Local Integer WOK, WCPT
Global Char GTRAVT(250)

# Initialisation du site de  stock
If GXAFCY="" GXAFCY=GFCYDEF(7) Endif
Call GETCPY(GXAFCY,"",0,"") From TRTX3CPT

# verify that the ADC site is set
If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 2 : Return
Endif

Gosub TRT_ORDRE

Return
########################################################

$SETBOUT

If GHCBWBOUT = 1
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 7
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 1
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 8
    ETABOU(GSPE1) = 1
    ETABOU(GSPE2) = 1
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 9
    ETABOU(GSPE1) = 1
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif

Return
##########################################################
$FINSAI
Kill GHCBWCPT
Kill GHCBWCPTART
Kill GHCBIVALEUR
Kill GHCBLMFGNUM
Kill GHCBLITMREF
Kill GHCBLBOMOPE
Kill GHCBLMFGLIN
Kill GHCBLBOMSEQ
Kill GHCBLCBTDAT
Kill GHCBLMVTSEQ
Kill GHCBWBOUT
Kill GHCBWCPTENR
Kill GHCBLWGGSTA
Kill GHCBLRECONCIL
Kill GHCBLPESEE

GBIDC1 = ""

#Nettoie l'écran avant de partir.
Raz [M:XENG]

Return

#########################################################
$ABANDON
Return

#########################################################
$FIN
Gosub TRT_FIN
Return

##########################################################
$BOUTON

Case BOUT
     When "a" Gosub TRT_ENREGISTREMENT
     When "b" Gosub TRT_SUPPRIMER
     When "c" Gosub TRT_ABANDON
     When Default
Endcase
Return

#########################################################
# Sous-programmes bouton
#########################################################
$TRT_FIN

If GHCBLRECONCIL <> 0
    If GENGAGE<>3
        OK=1
        Call OUINON(mess(48,2324,1),OK) From GESECRAN
        If OK <> 2
            mkstat=2
        Else
            # suppression engagement
            Gosub TRT_SUPPRIME
        Endif
    Endif
Endif

### Ordre bloqué en engagement
If [M:XENG]MFGNUM <>""
    Read [F:MFG]MFG0= [M:XENG]MFGNUM
    If !fstat
       If [F:MFG]WGGSTA = 11
           Call DEBTRANS From GLOCK
           Trbegin [MFG]
           Call MAJ_FICHIERS ("MFG",0,1,[M:XENG]MFGNUM,"",0,0) From SCALEXCHAN
           If GOK = 1  : Commit
           Else        : Rollback
           Endif

       Endif
    Endif
Endif
Return

#########################################################
$TRT_ABANDON
If GHCBLRECONCIL <> 0
    OK=1
    Call OUINON(mess(48,2324,1),OK) From GESECRAN
    If OK <> 2 : mkstat=2 : Return : Endif
Endif
# suppression engagement
Gosub TRT_SUPPRIME
# retour saisie ordre
GHCBIVALEUR = ""
Gosub MAJ_MFGHEAD
Gosub TRT_ORDRE
GHCBWCPT = 0
ACTION = "ABANDON" : Gosub ACTION
Raz[M:XENG]MFGNUM
Affzo[M:XENG]MFGNUM

Return
##########################################################
$TRT_SUPPRIMER
# Confirmation de la suppression
OK=1
Call OUINON(mess(49,2324,1),OK) From GESECRAN
If OK <> 2 : mkstat=2 : Return : Endif
# suppression engagement
Gosub TRT_SUPPRIME
# retour saisie ordre
Gosub TRT_ORDRE

### Ordre bloqué en engagement
If [M:XENG]MFGNUM <>""
    Read [F:MFG]MFG0= [M:XENG]MFGNUM
    If !fstat
       If [F:MFG]WGGSTA = 11
        Call DEBTRANS From GLOCK
        Trbegin [MFG]
        Call MAJ_FICHIERS ("MFG",0,1,[M:XENG]MFGNUM,"",0,0) From SCALEXCHAN
        If GOK = 1  : Commit
        Else        : Rollback
        Endif



       Endif
    Endif
Endif

Return
#########################################################
$TRT_ENREGISTREMENT

Call DEBTRANS From GLOCK
Trbegin [WGG]

Readlock [WGG]WGG0 = [M:XENG]MFGNUM;[M:XENG]BOMOPE;[M:XENG]ITMREF;GHCBLMFGLIN;GHCBLBOMSEQ;GHCBLCBTDAT;GHCBLMVTSEQ
If fstat=1     GOK=-1 : GLOCK="$WEIGHING"-GHCBLMFGNUM : Gosub TRT_ROLL : Return
Elsif fstat GOK=0  : Call RSTA("WGG",GHCBLMFGNUM) From GLOCK :  Gosub TRT_ROLL : Return
Endif

[F:WGG]ENGCOD = 2        :# DT
[F:WGG]ENGDAT = date$    :# DT
# Issue number 82926- 2012-06-14 by SR
[F:WGG]ENGUSR = GUSER
[F:WGG]ENGTIM = mid$(time$,1,2)+mid$(time$,4,2)

GHCBLRECONCIL = 1
Rewrite [F:WGG]
If fstat
    GOK = 0 : Call FSTA("WGG") From GLOCK : Return
Endif
Commit

#DT-22/06/2010

Gosub CALCUL

If GHCBWCPTENR = 0
    OK=1
    Call OUINON(mess(50,2324,1),OK) From GESECRAN
    If OK <> 2
        Gosub TRT_SUPPRIME
    Else
        Gosub TRT_VALIDATION
        If WOK = 6
            GHCBIVALEUR = ""
            Gosub TRT_ORDRE
        Endif
    Endif

    Raz[M:XENG]MFGTRKNUM,ITMREF,BOMOPE,LOT,WEIWEI,WEU
    Affzo[M:XENG]MFGTRKNUM,ITMREF,BOMOPE,LOT,WEIWEI,WEU
    zonsui = "BOMOPE0"

 Else
     GHCBWBOUT = 1
     If [M:XENG]WEU <> ""
         If GHCBLRECONCIL = 1 GHCBWBOUT = 8
         Else
             GHCBWBOUT = 9
         Endif
     Else
         If GHCBLRECONCIL = 1 GHCBWBOUT = 7 Endif
     Endif

     ACTION = "SETBOUT" : Gosub ACTION

     Call MESSAGE (mess(53,2324,1)+num$(GHCBWCPTENR)) From GESECRAN

     Raz[M:XENG]MFGTRKNUM,ITMREF,BOMOPE,LOT,WEIWEI,WEU
     Affzo[M:XENG]MFGTRKNUM,ITMREF,BOMOPE,LOT,WEIWEI,WEU
     zonsui = "MFGTRKNUM"
Endif
Return
########################################################################
# sous programme :
########################################################################

$TRT_VALIDATION
# verification que l'engagement soit faite sur toutes les matieres pesées
# sont exclu de l'engagement les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)
# sr 03.02 ainsi que les mouvements de type "fin de contenant"
# sr 01.03 ainsi que les mouvements de type "Inventaire"
# sr 09.03 ainsi que les matières pesée en fabrication (code à servir 3,5,7)
#          En fait on garde les PCK : 2,4,6

For [MFM]MFM0 Where MFGFCY = [M:XENG]MFGFCY         &
&                   MFGNUM = [M:XENG]MFGNUM         &
&                   MATSTA <> 4                     &
&                   (WGGSTA = 3 |WGGSTA = 5 )       &
&                   find([F:MFM]PKC,2,4,6)          &
&    ([V]GENGAGE<>2  | BOMOPE = [M:XENG]BOMOPE0)
         WOK = 0
         For [WGG]WGG0 Where MFGNUM = [M:XENG]MFGNUM     &
&                            MFGLIN = [F:MFM]MFGLIN      &
&                            ITMREF = [F:MFM]ITMREF      &
&                            BOMSEQ = [F:MFM]BOMSEQ      &
&                            BOMOPE = [F:MFM]BOMOPE      &
&                            WEIWEI <> 0                 &
&                            WEIFLG <> 4                 &
&                            WEIFLG <> 5                 &
&                           ([V]GRECONOBLI<>2| [WGG]RCLCOD=2)


         If [F:WGG]ENGCOD <> 2 WOK = 9 : Break : Endif             # 04.02
         If [F:WGG]ENGCOD =  2 WOK = 1 : Endif                     # 04.02
         Next

        If WOK = 1
                  Call DEBTRANS From GLOCK
                  Trbegin [MFM]

                  Readlock [F:MFM] Curr
                  If fstat=1     GOK=-1 : GLOCK="$MFM"-GHCBLMFGNUM : Gosub  TRT_ROLL : Break  # mm 05.11 - Ctrl des sources avant Return
                  Elsif fstat GOK=0  : Call RSTA("MFM",GHCBLMFGNUM) From GLOCK : Gosub TRT_ROLL : Break  # mm 05.11 - Ctrl des sources avant Return
                  Endif

                  [F:MFM]WGGSTA = 7

                  Rewrite [F:MFM]
                  If fstat       GOK = 0 : Call FSTA("MFM") From GLOCK : Gosub TRT_ROLL : Break :  Endif   # mm 05.11 - Ctrl des sources avant Return
                  Commit

        Endif
Next
If GOK<= 0 Return Endif #  mm 05.11 -  Ctrl des sources Ligne ajoutée

# verification que toutes les matieres soient réconciliées (wggsta = 5)
# sont exclu de l'engagement les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)
# sr 09.03 on ne traite que les PKC = 2,4,6

    WOK = 6
# mm 05.11 - l'ensemble des matières doivent être engagées pour modifier le statut de l'entête.
For [MFM]MFM0 Where  MFGFCY = [M:XENG]MFGFCY     &
&                    MFGNUM = [M:XENG]MFGNUM     &
&                    MATSTA <> 4                 &
&                    find([F:MFM]PKC,2,4,6)
                                                  #&   ([V]GENGAGE<>2  | BOMOPE = [M:XENG]BOMOPE0)
    WOK = 6
    If [F:MFM]WGGSTA <> 7  WOK = 9 : Break : Endif
Next

# X3-85050.sn JOBRO 05/06/2018
# We have to check if there are unweighed material lines
# of type (8,9) before we can update header
If WOK<>9
For [F:MFM]MFM0 Where MFGFCY = [M:XENG]MFGFCY     &
&                    MFGNUM = [M:XENG]MFGNUM     &
&                    MATSTA <> 4                 &
&                    find([F:MFM]PKC,8,9)        &
&                    WGGSTA = 1
    WOK=9
    Break
Next
Endif
#X3-85050.en

If WOK = 6

      If [V]GENGAGE=1
          GHCBLWGGSTA     = 8
          [M:XENG]WGGSTA  = 8
          Call DEBTRANS From GLOCK
          Trbegin [MFG]
          Call MAJ_FICHIERS ("MFG",7,GHCBLWGGSTA,[M:XENG]MFGNUM,"",0,0) From SCALEXCHAN
          If GOK = 1  : Commit
          Else        : Rollback
          Endif

      Else
          GHCBLWGGSTA     = 1
          [M:XENG]WGGSTA  = 1
          Call DEBTRANS From GLOCK
          Trbegin [MFG]
          Call MAJ_FICHIERS ("MFG",7,GHCBLWGGSTA,[M:XENG]MFGNUM,"",0,0) From SCALEXCHAN
          If GOK = 1  : Commit
          Else        : Rollback
          Endif
      Endif

      Call MESSAGE (mess(47,2324,1)) From GESECRAN

# sr 10.03
# si il reste des matières pesées en fabrication non encore pesées,
# on remet l'OF dans le plan de pesée et statut "fin de pesée en box"

    For [F:MFM]MFM0 Where MFGFCY = [M:XENG]MFGFCY          &
&                         MFGNUM = [M:XENG]MFGNUM          &
&                         MATSTA <> 4                      &
&                         find([F:MFM]PKC,3,5,7)           &
&        ([V]GENGAGE<>2 | BOMOPE = [M:XENG]BOMOPE0)

          If [F:MFM]WGGSTA < 3

             If [V]GENGAGE=1
                 GHCBLWGGSTA    = 3
             Else
                 GHCBLWGGSTA    = 1
             Endif
              Call DEBTRANS From GLOCK
              Trbegin [MFG]
              Call MAJ_FICHIERS ("MFG",3,GHCBLWGGSTA,[M:XENG]MFGNUM,"",0,0) From SCALEXCHAN
              If GOK = 1  : Commit
              Else        : Rollback
              Endif
              [M:XENG]WGGSTA =GHCBLWGGSTA
              #DT==================
              Break
          Endif
    Next
Endif

# 104069 mm 03.2015 - Case of commitment by phases
# Check that all materials from phases are commited
If [V]GENGAGE=2 & WOK = 9
  For [MFM]MFM0 Where MFGFCY = [M:XENG]MFGFCY       &
&                       MFGNUM = [M:XENG]MFGNUM     &
&                       MATSTA <> 4                 &
&                      find([F:MFM]PKC,2,4,6)       &   BOMOPE = [M:XENG]BOMOPE0
   If [F:MFM]WGGSTA <> 7  WOK = 10 : Break : Endif
  Next
  If WOK =9 GHCBLRECONCIL = 0 Endif
Endif

Return
#########################################################
$TRT_ROLL
Rollback
Return
#########################################################
$TRT_SUPPRIME
For [WGG]WGG0 Where MFGNUM = [M:XENG]MFGNUM         &
&                   WEIWEI <> 0                     &
&                   CCLDAT = [0/0/0]                &
&                   ENGCOD =  2                     &
&                   WEIFLG <> 4                     &
&                   WEIFLG <> 5                     &
&   ([V]GENGAGE<>2 | BOMOPE = [M:XENG]BOMOPE0)

        Call DEBTRANS From GLOCK
        Trbegin [WGG]

        Readlock Curr
        If fstat=1     GOK=-1 : GLOCK="$WEIGHING"-GHCBLMFGNUM : Gosub TRT_ROLL : Break   # mm 06.11 74630 contrôle des sources
        Elsif fstat GOK=0  : Call RSTA("WGG",GHCBLMFGNUM) From GLOCK : Gosub TRT_ROLL : Break   # mm 06.11 74630 contrôle des sources
        Endif

        [F:WGG]ENGCOD = 1
        [F:WGG]ENGDAT = [0/0/0]
        # Issue number 82926- 2012-06-14 by SR
        [F:WGG]ENGUSR = ""
        Raz [F:WGG]ENGTIM
        Rewrite [F:WGG]
        If fstat       GOK = 0 : Call FSTA("WGG") From GLOCK : Gosub TRT_ROLL : Break   # mm 06.11 74630 contrôle des sources
        Endif
        Commit
Next
Return
#########################################################
$TRT_ORDRE

[M:XENG]MFGFCY = GXAFCY
Actzo  [M:XENG]MFGNUM
Actzo  [M:XENG]BOMOPE0
Raz    [M:XENG]BOMOPE0
Raz    [M:XENG]MFGSTA
Raz    [M:XENG]MFGTRKNUM
Raz    [M:XENG]ITMREF
Raz    [M:XENG]BOMOPE
Raz    [M:XENG]LOT
Raz    [M:XENG]WEIWEI
Raz    [M:XENG]WEU
Affzo  [M:XENG]

GHCBLRECONCIL = 0
GHCBWBOUT     = 1
GHCBWCPT      = 0

#DT-22/06/2010
If [M:XENG]MFGFCY<>""
    Gosub CHARGE_PARAM

    If  [V]GENGAGE=2
        Actzo[M:XENG]BOMOPE0
    Else
        Raz[M:XENG]BOMOPE0
#RDH18022011
#        Diszo[M:XENG]BOMOPE0
         Grizo [M:XENG]BOMOPE0
    Endif

Endif
Return
#########################################################
$TRT_ITMREF
Actzo  [M:XENG]ITMREF
Gosub TRT_RAZITMREF

GHCBLRECONCIL = 0
GHCBWBOUT     = 1

Return


#########################################################
$TRT_RAZITMREF

[M:XENG]BOMOPE  = 0
[M:XENG]LOT     = ""
[M:XENG]WEU     = ""
[M:XENG]WEIWEI  = 0

Affzo [M:XENG]ITMREF
Affzo [M:XENG]LOT
Affzo [M:XENG]WEIWEI
Affzo [M:XENG]WEU
Affzo [M:XENG]BOMOPE
Return

#########################################################
$TRT_RAZORDRE
[M:XENG]MFGNUM  = ""
[M:XENG]WCPTENR = 0
Affzo [M:XENG]MFGNUM
Affzo [M:XENG]WCPTENR
Return


########################################################################
# calcul nombre de pesée à reconcilier pour un of
########################################################################
$CALCUL
Local Char CRIT_WGG(250),CRIT_WGG1(250),CRIT_WGG2(250)

GHCBWCPTENR = 0

If [V]GENGAGE<=0 | [V]GRECONOBLI<=0
    Gosub CHARGE_PARAM
Endif

If GENGAGE<>3
  Gosub SEL_WGG

  Filter [WGG] Where evalue([L]CRIT_WGG) & evalue([L]CRIT_WGG1)
  For [WGG]WGG0
      GHCBWCPTENR += 1
  Next
  Filter [WGG]
  [M:XENG]WCPTENR = GHCBWCPTENR
Else

  [M:XENG]WCPTENR -=1
  GHCBWCPTENR =  [M:XENG]WCPTENR
Endif

Affzo  [M:XENG]WCPTENR

Return

########################################################################
$SEL_WGG

Raz[L]CRIT_WGG,CRIT_WGG1

[L]CRIT_WGG   = "[WGG]MFGNUM=[M:XENG]MFGNUM & [WGG]WEIWEI<>0 &[WGG]ENGDAT=[0/0/0] & [WGG]ENGCOD<>2"
[L]CRIT_WGG  -= "&[WGG]CCLDAT=[0/0/0]&[WGG]WEIFLG<>4 & [WGG]WEIFLG<>5 & find([F:WGG]PKC,2,4,6)"

[L]CRIT_WGG1  = " ([V]GRECONOBLI<>2|([WGG]RCLDAT<>[0/0/0] & [WGG]RCLCOD=2))"
[L]CRIT_WGG1 -= "&([V]GENGAGE<>2 |([WGG]BOMOPE=[M:XENG]BOMOPE0 & [M:XENG]BOMOPE0<>0)|[M:XENG]BOMOPE0=0)"

Return
########################################################################
# recherche element article à engager
########################################################################
$CRTHISTART
GHCBWCPTART = 0

For [WGG]WGG0 Where MFGNUM = [M:XENG]MFGNUM     &
&                   BOMOPE = GHCBLBOMOPE        &
&                   ITMREF = GHCBLITMREF        &
&                   WEIWEI <> 0                 &
&                   CCLDAT = [0/0/0]            &
&                   ENGCOD <> 2                 &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5                 &
&                   find([F:WGG]PKC,2,4,6)      &
&                   ([V]GRECONOBLI<>2 | [WGG]RCLCOD=2)

    GHCBWCPTART += 1
    Break
Next

Return

########################################################################
# recherche element à réconcilier N° pesée
########################################################################
$CRTHIST_PESEE
GHCBWCPT = 0
#  mm 05.11 - RCLDAT peut être =2 si pesée annulée  ENGCOD    <> 2
For [WGG]WGG0 Where  MFGNUM    = [M:XENG]MFGNUM                          &
&                    MFGTRKNUM = VALEUR                                  &
&                    WEIWEI    <> 0                                      &
&                    CCLDAT    = [0/0/0]                                 &
&                    ENGDAT    = [0/0/0]                                 &
&                    WEIFLG    <> 4                                      &
&                    WEIFLG    <> 5                                      &
&                    find([F:WGG]PKC,2,4,6)                              &
&                    ([V]GRECONOBLI<>2 | [WGG]RCLCOD=2)                  &
&                    ([V]GENGAGE<>2 | BOMOPE = [M:XENG]BOMOPE0)

            GHCBWCPT += 1
            If GHCBWCPT > 1 Break : Endif
Next
Return

########################################################################
# recherche element à réconcilier lot
########################################################################
$CRTHISTLOT
GHCBWCPT = 0
For [WGG]WGG0 Where MFGNUM = [M:XENG]MFGNUM               &
&                   BOMOPE = [M:XENG]BOMOPE               &
&                   WEIWEI <> 0                           &
&                   ITMREF = [M:XENG]ITMREF               &
&                   LOT    = VALEUR                       &
&                   CCLDAT = [0/0/0]                      &
&                   ENGCOD <> 2                           &
&                   WEIFLG <> 4                           &
&                   WEIFLG <> 5                           &
&                 ([V]GRECONOBLI<>2 | [WGG]RCLCOD=2)      &
&                 ([M:XENG]MFGTRKNUM="" | [WGG]MFGTRKNUM= [M:XENG]MFGTRKNUM)


    GHCBWCPT += 1
    If GHCBWCPT > 1 Break : Endif
Next

If GHCBWCPT = 1 GHCBLMFGLIN = [F:WGG]MFGLIN
                GHCBLBOMSEQ = [F:WGG]BOMSEQ
                GHCBLCBTDAT = [F:WGG]CBTDAT
                GHCBLMVTSEQ = [F:WGG]MVTSEQ
                GHCBLPESEE  = [F:WGG]MFGTRKNUM

Endif
Return
########################################################################
# recherche element à réconcilier lot + montant
########################################################################
$CRTHISTWEI

GHCBWCPT = 0

For [WGG]WGG0 Where MFGNUM = [M:XENG]MFGNUM               &
&                   BOMOPE = [M:XENG]BOMOPE               &
&                   WEIWEI <> 0                           &
&                   ITMREF = [M:XENG]ITMREF               &
&                   LOT    = [M:XENG]LOT                  &
&                   WEIWEI = VALEUR                       &
&                   CCLDAT = [0/0/0]                      &
&                   ENGCOD <> 2                           &
&                   WEIFLG <> 4                           &
&                   WEIFLG <> 5                           &
&                  ([V]GRECONOBLI<>2 | [WGG]RCLCOD=2)     &
&                  ([M:XENG]MFGTRKNUM="" | [WGG]MFGTRKNUM= [M:XENG]MFGTRKNUM)

    GHCBWCPT += 1

    If GHCBWCPT <> 0 Break : Endif

Next

If GHCBWCPT <>0
    GHCBLMFGLIN = [F:WGG]MFGLIN
    GHCBLBOMSEQ = [F:WGG]BOMSEQ
    GHCBLCBTDAT = [F:WGG]CBTDAT
    GHCBLMVTSEQ = [F:WGG]MVTSEQ
    GHCBLPESEE  = [F:WGG]MFGTRKNUM
Endif

Return
########################################################################
# mise à jour MFGHEAD
########################################################################
$MAJ_MFGHEAD

If GHCBLMFGNUM <> ""
   Call DEBTRANS From GLOCK
   Trbegin [MFG]
   Call MAJ_FICHIERS ("MFG",0,GHCBLWGGSTA,GHCBLMFGNUM,"",0,0) From SCALEXCHAN
   If GOK = 1  : Commit
   Else        : Rollback
   Endif
Endif
If GHCBIVALEUR <> ""
    GHCBLMFGNUM = GHCBIVALEUR
     Call DEBTRANS From GLOCK
     Trbegin [MFG]
     Call MAJ_FICHIERS ("MFG",0,11,GHCBIVALEUR,"",0,0) From SCALEXCHAN   :#ordre bloquee en engagement
     If GOK = 1  : Commit
     Else        : Rollback
     Endif
    GHCBLWGGSTA = [M:XENG]WGGSTA
Endif

Return

#########################################################################
#       sous prog ETIQUETTES
#########################################################################
$CHARGE_PARAM
Local Char VALPAR(20)

Call PARAM([M:XENG]MFGFCY,"ENGAGE",[L]VALPAR) From ADOVAL
[V]GENGAGE = val([L]VALPAR)

Call PARAM([M:XENG]MFGFCY,"RECONOBLI",[L]VALPAR) From ADOVAL
[V]GRECONOBLI = val([L]VALPAR)

Call PARAM([M:XENG]MFGFCY,"WEIVT",[L]VALPAR) From ADOVAL
[V]GWEIVT = val([L]VALPAR)

If [V]GWEIVT =1
    Raz[M:XENG]ITMREF,BOMOPE,LOT,WEIWEI,WEU
    Actzo[M:XENG]MFGTRKNUM
Else
    Raz[M:XENG]MFGTRKNUM
#RDH18022011
#    Diszo[M:XENG]MFGTRKNUM
    Grizo [M:XENG]MFGTRKNUM

    Actzo[M:XENG]ITMREF,BOMOPE,LOT,WEIWEI,WEU
Endif

Return
########################################################################
$ETI_MFGNUM

# Lecture MFGHEAD
# sr 01.03 faire un readlock ici (pour être sûr de pouvoir aller jusqu'à la fin sans qu'une
# autre session ne nous prenne l'entête ???

Read [MFG]MFG0 = VALEUR
If fstat :                             GMESSAGE = mess(16,2324,1) : GERR =2  : mkstat = 2 : Return : Endif
If [F:MFG]WGGFLG < 3                   GMESSAGE = mess(44,2324,1) : GERR =2  : mkstat = 2 : Return : Endif
If [F:MFG]WGGFLG < 6 &[V]GRECONOBLI=2  GMESSAGE = mess(54,2324,1) : GERR =2  : mkstat = 2 : Return : Endif
If [F:MFG]WGGSTA = 9                   GMESSAGE = mess(15,2324,1) : GERR =2  : mkstat = 2 : Return : Endif
If [F:MFG]WGGSTA = 11                  GMESSAGE = mess(51,2324,1) : GERR =2  : mkstat = 2 : Return : Endif

If [F:MFG]WGGFLG =  7
    GMESSAGE = mess(45,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
Endif

# sr 05.03
If [F:MFG]MFGSTA =  4  GMESSAGE = mess(114,193,1) : GERR =2 : mkstat = 2 : Return : Endif

# verification que toutes les matieres soient pesées (wggsta = 3)
# sont exclu de l'engagement les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)

WOK = 0
For [MFM]MFM0 Where MFGFCY = [M:XENG]MFGFCY     &
&                   MFGNUM = VALEUR             &
&                   MATSTA <> 4                 &
&                   find([F:MFM]PKC,2,4,6)
    WOK = 1

    If [F:MFM]WGGSTA =  7 & [V]GENGAGE =1 WOK = 8 : Break : Endif  :#DT-3006
    # mm 05.11- si engagement par phase/pesée => toutes les phases de l'OF n'ont pas besoin d'être pesées
    # seulement les matières de la phase/pesée
    If GENGAGE = 1
      If [F:MFM]WGGSTA  < 3  WOK = 9 : Break : Endif
    Endif
Next

If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If WOK = 9  GMESSAGE = mess(17,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If WOK = 8  GMESSAGE = mess(46,2324,1) : GERR =2 : mkstat = 2 : Return : Endif  :#DT

# mm 05.11 : calcul du nombre total de pesée à engager pour un of
If WOK = 1 & GENGAGE = 1

     [M:XENG]MFGNUM = VALEUR
     Gosub CALCUL
     If GHCBWCPTENR = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Raz [M:XENG]MFGNUM
     Else
#RDH18022011
#         Diszo  [M:XENG]MFGFCY
#         Diszo  [M:XENG]MFGNUM
          Grizo  [M:XENG]MFGFCY
          Grizo  [M:XENG]MFGNUM

     Endif
Endif

If GENGAGE= 3
  GHCBWCPTENR = 1
  [M:XENG]WCPTENR = GHCBWCPTENR
  Affzo  [M:XENG]WCPTENR
Endif
Return

#########################################################
$ETI_BOMOPE
#DT-22/06/2010
# Lecture MFGMAT
Local Shortint W_BOMOPE
Local Shortint W_WGGSTA
Raz W_BOMOPE
Raz W_WGGSTA


If [V]GENGAGE=2
    # Engagement par phase
    WOK = 0
    For [MFM]MFM0 Where MFGFCY = [M:XENG]MFGFCY     &
&                       MFGNUM = [M:XENG]MFGNUM     &
&                       BOMOPE = VALEUR             &
&                       MATSTA <> 4                 &
&                       find([F:MFM]PKC,2,4,6)
#&                      ([V]GRECONOBLI<>2 |[WGG]RCLCOD=2)

      If ([V]GRECONOBLI<>2)
          WOK = 1
          If [F:MFM]WGGSTA = 7 & [V]GENGAGE <>2 WOK = 8 : Break : Endif    :#DT
          If [F:MFM]WGGSTA  < 3  WOK = 9 : Break : Endif
      Else
      # mm 03.2015 - Si Réconciliation obligatoire de la phase avant l'engagement
         If W_BOMOPE = 0
            W_BOMOPE = [F:MFM]BOMOPE
            W_WGGSTA = [F:MFM]WGGSTA
         Endif
         If W_BOMOPE = [F:MFM]BOMOPE
           If [F:MFM]WGGSTA <  W_WGGSTA  : W_WGGSTA = [F:MFM]WGGSTA : Endif
         Endif

         WOK=1
         If W_WGGSTA = 7   WOK = 8 : Break : Endif
         If W_WGGSTA = 3   WOK = 10 : Break : Endif
         If W_WGGSTA < 3   WOK = 9 : Break : Endif
      Endif
    Next

    If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 9  GMESSAGE = mess(17,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 8  GMESSAGE = mess(46,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 10 GMESSAGE = mess(58,2324,1) : GERR =2 : mkstat = 2 : Return : Endif

    If WOK = 1
         [M:XENG]BOMOPE0 = VALEUR
         Gosub CALCUL
         If GHCBWCPTENR = 0  GMESSAGE = mess(47,2324,1) : GERR =2 : mkstat = 2 : Raz [M:XENG]BOMOPE0 : Endif
    Endif
    Actzo[M:XENG]BOMOPE0
Else
    Raz [M:XENG]BOMOPE0
#    Diszo[M:XENG]BOMOPE0
#RDH18022011
    Grizo[M:XENG]BOMOPE0

Endif
Return
#########################################################
$ETI_MFGTRKNUM

Local Char    ITM
Local Char    LOT
Local Char    WEU
Local Decimal OPE
Local Decimal WEI

Gosub CRTHIST_PESEE

If GHCBWCPT <>0

    Filter[F:WGG1] Where MFGNUM=[M:XENG]MFGNUM & FCY=[M:XENG]MFGFCY & MFGTRKNUM=VALEUR & ([V]GENGAGE<>2|BOMOPE=[M:XENG]BOMOPE0)
    Read[F:WGG1]WGG0 First
    If !fstat

        [L]ITM = [F:WGG1]ITMREF
        [L]OPE = [F:WGG1]BOMOPE
        [L]LOT = [F:WGG1]LOT
        [L]WEI = [F:WGG1]WEIWEI
        [L]WEU = [F:WGG1]WEU


        [M:XENG]ITMREF     = [F:WGG1]ITMREF
        [M:XENG]BOMOPE     = [F:WGG1]BOMOPE
        [M:XENG]LOT        = [F:WGG1]LOT
        [M:XENG]WEIWEI     = [F:WGG1]WEIWEI
        [M:XENG]WEU        = [F:WGG1]WEU
        [M:XENG]MFGTRKNUM  = VALEUR


        Affzo[M:XENG]MFGTRKNUM,ITMREF,BOMOPE,LOT,WEIWEI,WEU

        If mkstat = 0  Call C_ITMREF([L]ITM)     Endif
        If mkstat = 0  Call C_BOMOPE([L]OPE)     Endif
        If mkstat = 0  Call AM_BOMOPE([L]OPE)    Endif
        If mkstat = 0  Call C_LOT([L]LOT)        Endif
        If mkstat = 0  Call AM_LOT([L]LOT)       Endif
        If mkstat = 0  Call C_WEIWEI([L]WEI)     Endif
        If mkstat = 0  Call AM_WEIWEI([L]WEI)    Endif

        If mkstat=0
            [M:XENG]WEU=[L]WEU
            [M:XENG]WEIWEI = [F:WGG1]WEIWEI
#RDH18022011
#            Diszo[M:XENG]ITMREF,BOMOPE,LOT,WEIWEI,WEU
            Grizo [M:XENG]ITMREF,BOMOPE,LOT,WEIWEI,WEU

        Else
            zonsui = "MFGTRKNUM"
            GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
        Endif
    Else
        VALEUR =""
    Endif
    Filter[F:WGG1]
Else
    GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return
#########################################################


#########################################################
$ETI_LOT
Gosub CRTHISTLOT
[M:XENG]WEIWEI = 0
[M:XENG]WEU    = ""

# sr 09.03 mis en commentaire suite à demande de Céline Charron : ils doivent aussi confirmer la quantité même si une seule pesée
#If GHCBWCPT > 1 Actzo [M:XENG]WEIWEI
#Else Grizo [M:XENG]WEIWEI
#Endif

If GHCBWCPT = 1 [M:XENG]WEU    = [F:WGG]WEU
Elsif GHCBWCPT = 0 : GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return

#########################################################
$ETI_WEIWEI
#DT-21/06/2010
Gosub CRTHISTWEI
[M:XENG]WEU   = ""
If GHCBWCPT = 1  [M:XENG]WEU   = [F:WGG]WEU
Elsif GHCBWCPT = 0 GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return

#########################################################
$ETI_ITMREF
Gosub CRTHISTART
If GHCBWCPTART = 0 GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Endif
Return
#########################################################################

#########################################################################
#                     ETIQUETTES                                        #
#########################################################################
########################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
Gosub ETI_MFGNUM
End

########################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
# sr 01.03 y-a-t-il des matières exclues
# Si oui on propose d'anabndonner l'engagement

Filter [F:MFM] Where MFGNUM = VALEUR & MATSTA = 4
Look [F:MFM]MFM0 First
If !fstat
    Filter [F:MFM]
    WOK=1
    Call OUINON(mess(39,2324,1),WOK) From GESECRAN
    If WOK <> 2 : mkstat=2 : End : Endif
Endif
Filter [F:MFM]

GHCBIVALEUR = VALEUR
[M:XENG]WGGSTA = [F:MFG]WGGSTA
Affzo [M:XENG]WGGSTA
Gosub MAJ_MFGHEAD
End

########################################
Subprog S_MFGNUM(VALEUR)
Variable Char    VALEUR()
########################################
#                              WGGFLG >2  > une peser doit etre faite
#                              WGGSTA <>7 > en reconciliation
#                              WGGSTA <>9 > bloqué en peser
#                              WGGFLG <>6 > reconcilié

Filter [F:MFG] Where MFGFCY = [M:XENG]MFGFCY &  WGGFLG > 2 & WGGFLG < 7 & WGGSTA <> 9
Call SELECT("MFG","",VALEUR,"") From SELOBJ
Filter [F:MFG]

End

########################################
Subprog C_BOMOPE(VALEUR)
Variable Decimal VALEUR

#DT-21/06/2010
If [V]GENGAGE=2 & VALEUR <> [M:XENG]BOMOPE0
    GMESSAGE = mess(6,2324,1)  : GERR =2 : mkstat = 2
Else
    GHCBLBOMOPE = VALEUR
    Gosub ETI_ITMREF
Endif

End

########################################
Subprog AM_BOMOPE(VALEUR)
Variable Decimal VALEUR
GHCBLBOMOPE = VALEUR
End

########################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()

Gosub ETI_LOT

GHCBWBOUT = 1

If [M:XENG]WEU <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End

########################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
LLOT = VALEUR
#Gosub ETI_LOT

Affzo  [M:XENG]WEIWEI
Affzo  [M:XENG]WEU

GHCBWBOUT = 1

If [M:XENG]WEU <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
GHCBLITMREF = VALEUR
End
########################################
Subprog C_WEIWEI(VALEUR)
Variable Decimal VALEUR

Gosub ETI_WEIWEI
GHCBWBOUT = 1
#DT-21/06/2010
If [M:XENG]WEU <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif

End

########################################
Subprog AM_WEIWEI(VALEUR)
Variable Decimal VALEUR

Affzo  [M:XENG]WEU
GHCBWBOUT = 1
#DT-21/06/2010
If [M:XENG]WEU <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End
########################################
Subprog C_BOMOPE0(VALEUR)
Variable Decimal  VALEUR
#DT-18/06/2010
If [V]GENGAGE=2 & VALEUR=0
     GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
     End
Endif
Gosub ETI_BOMOPE
End

########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char     VALEUR
#DT-18/06/2010

[M:XENG]MFGFCY=VALEUR
Gosub CHARGE_PARAM

If  [V]GENGAGE=2
    Actzo[M:XENG]BOMOPE0
Else
    Raz[M:XENG]BOMOPE0
#RDH18022011
#    Diszo[M:XENG]BOMOPE0
    Grizo [M:XENG]BOMOPE0

Endif
End
########################################
Subprog AM_SAISIE(VALEUR)
Variable Integer  VALEUR
Local Integer NOL   : [L]NOL=nolign-1
#DT-18/06/2010
If VALEUR=1
    Raz[M:XENG]ITMREF,BOMOPE,LOT,WEIWEI,WEU
    #Diszo[M:XENG]ITMREF,BOMOPE,LOT,WEIWEI,WEU
    Actzo[M:XENG]MFGTRKNUM
    zonsui = "MFGTRKNUM"
Else
    Raz[M:XENG]MFGTRKNUM
#RDH18022011
#    Diszo[M:XENG]MFGTRKNUM
    Grizo[M:XENG]MFGTRKNUM

    Actzo[M:XENG]ITMREF,BOMOPE,LOT,WEIWEI,WEU
    zonsui = "ITMREF"
Endif

End
########################################
Subprog C_MFGTRKNUM(VALEUR)
Variable Char     VALEUR
If [M:XENG]SAISIE=1 & VALEUR=""
    GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
Endif
If mkstat <> 2
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End
########################################
Subprog AM_MFGTRKNUM(VALEUR)
Variable Char VALEUR
Gosub ETI_MFGTRKNUM
If mkstat <> 2
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End
########################################
Subprog AS_BOMOPE(VALEUR)
Variable Decimal  VALEUR
If [M:XENG]BOMOPE0 <>0
    VALEUR=[M:XENG]BOMOPE0
Endif
End

