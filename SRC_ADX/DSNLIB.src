#------------------------------------------------------------------------------------------------------
# MENU
#------------------------------------------------------------------------------------------------------
#        COD       : Code du champ û  convertir
#        PHASE     : Phase de la DSN
#        VERSION   : Version spûˋcifique û  utiliser, si version non trouvûˋe on utilise la version "vide"
#        VALEUR    : Valeur û  convertir, en alpha
#------------------------------------------------------------------------------------------------------
Funprog MENU(COD,PHASE,VERSION,VALEUR)
Value Char COD(), VERSION(), VALEUR()
Value Integer PHASE
Local Char RESULTAT(250)
Raz [L]RESULTAT
Local File HRTABDSH [HRDSH_], HRTABDSD [HRDSD_]

Read [F:HRDSH_]HRDSH0 = [L]COD;[L]PHASE;[L]VERSION
If fstat
 [L]VERSION =""
 Read [F:HRDSH_] = [L]COD;[L]PHASE;[L]VERSION
 If fstat
  [L]PHASE=1
  Read [F:HRDSH_] = [L]COD;[L]PHASE;[L]VERSION
 Endif
Endif
If !fstat
 Filter [F:HRDSD_] Where CODDSN=[F:HRDSH_]CODDSN & PHADSN=[F:HRDSH_]PHADSN & VERDSN =[F:HRDSH_]VERDSN & CMP1=[L]VALEUR
 Read [F:HRDSD_]HRDSD0 First
 If fstat <= 2
  [L]RESULTAT = [F:HRDSD_]VAL1
 Else
  [L]RESULTAT = [F:HRDSH_]VALDEF
 Endif
Endif

Close Local File [HRDSH_], [HRDSD_]

End [L]RESULTAT

#--------------------------------------------------
# TABLE
#--------------------------------------------------
#        NUMTAB    : Numûˋro de la table diverse
#        COLONNE   : code de la colonne
#        VALEUR    : Valeur û  convertir, en alpha
#------------------------------------------------------------------------------------------------------
Funprog TABLE(NUMTAB,COLONNE,VALEUR)
Value Integer NUMTAB
Value Char COLONNE()
Value Char VALEUR()

Local Char RESULTAT(250)
Local Char W_TMP(30)
W_TMP=COLONNE
Local File ATABDIV [ADI_]

If VALEUR="" : End [L]RESULTAT : Endif

Read [ADI_]CODE = [L]NUMTAB;[L]VALEUR

If fstat<>0
 #Erreur de lecture sur le fichier ATABDIV [ADI] (nô¯XXX / Code YYY)
 #MIPEA - 2016-11-04 - X3PEOP-1594 - START
 Call ECR_TRACE(mess(4,10707,1)-"ATABDIV [ADI] (nô¯"+num$([L]NUMTAB)-"/"-mess(37,100,1)-[L]VALEUR+")",1) From GESECRAN
 #Call ECR_TRACE(mess(4,707,1)-"ATABDIV [ADI] (nô¯"+num$([L]NUMTAB)-"/"-mess(37,100,1)-[L]VALEUR+")",1) From GESECRAN
 #MIPEA - 2016-11-04 - X3PEOP-1594 - END
Else
  If COLONNE=""
    RESULTAT=[F:ADI_]A1
  Else
    # Protection si colonne est juste un numûˋrique. ca plante l'evalue
    If len(COLONNE)=len(num$(val(COLONNE))) : COLONNE="A"+COLONNE : Endif
    If evalue("dim([F:ADI_]"+COLONNE+")=-1")
   #MIPEA - 2016-11-04 - X3PEOP-1594 - START
    Call ECR_TRACE(mess(4,10707,1)-"ATABDIV [ADI] (nô¯"+num$([L]NUMTAB)-"/"-mess(37,100,1)-[L]VALEUR-"/"-mess(140,111,1)-W_TMP+")",1) From GESECRAN
      #Call ECR_TRACE(mess(4,707,1)-"ATABDIV [ADI] (nô¯"+num$([L]NUMTAB)-"/"-mess(37,100,1)-[L]VALEUR-"/"-mess(140,111,1)-W_TMP+")",1) From GESECRAN
   #MIPEA - 2016-11-04 - X3PEOP-1594 - END
    Else
      RESULTAT=evalue("num$([F:ADI_]"+COLONNE+")")
    Endif
  Endif
Endif

Close Local File [ADI_]

End [L]RESULTAT

#--------------------------------------------------------------------------
# CODPREV : Formatage du code prûˋvoyance selon le contenu du code lui mûˆme
#--------------------------------------------------------------------------
Funprog CODPREV(COD)
Value Char COD()
Local Char RESULTAT(250)

  If len([L]COD) < 9
    If mid$([L]COD, 1, 1) >= "A" & mid$([L]COD, 1, 1) <= "Z"
      # Si on a dûˋjû  le A ou le P , on garde la valeur "en l'ûˋtat" ; les opûˋrateurs ont saisis dans la table la
      # "bonne" valeur envoyûˋe par l'organisme
      [L]RESULTAT = [L]COD
    Else
      # Ah, ca ne commence pas par une lettre, on a probablement saisi la valeur ûˋpurûˋe du premier caractû´re, on va
      # essayer de le deviner.
      If len([L]COD) <= 4
        [L]RESULTAT = "P" + [L]COD
      Elsif len([L]COD) <= 5
        [L]RESULTAT = "A" + [L]COD
      Else
        [L]RESULTAT = "P" + [L]COD
      Endif
    Endif
  Else
    [L]RESULTAT = [L]COD
  Endif

End [L]RESULTAT


#---------------------------------------------------------------------------------------
# FMT : Formatage d'une chaine
#---------------------------------------------------------------------------------------
#       FMT     : Chaine de formatage û  utiliser (format adonix Nz:3.2# par exemple)
#       OPT     : Option
#                 Si FMT = "Nxxxx" = numûˋrique
#                    OPT = 1 = Pas de traitement spûˋcial
#                    OPT = 2 = Arrondi û  0.01 (arr(valeur, 0.01))
#                    OPT = 3 = Arrondi û  1 (arr(valeur, 1))
#                    OPT = 4 = Troncature û  l'euro (int(valeur))
#       MINI    : Nombre minimum de caractû´re en sortie
#       VALEUR  : Valeur û  convertir (alpha)
#---------------------------------------------------------------------------------------
Funprog FMT(FMT, OPT, MINI, VALEUR)
Value Char FMT()
Value Integer OPT, MINI
Value Char VALEUR()
Local Char RESULTAT(250)
Local Integer LONGUEUR

# Vûˋrifications pour les petits comiques
[L]MINI = max(0, [L]MINI)

Case mid$([L]FMT, 1, 1)
    When "N"

        # Option permet de gûˋrer l'arrondi / troncature
        Case [L]OPT
            When 1
                # On laisse la valeur en l'ûˋtat
            When 2
                # On arrondi au centime prû´s
                [L]VALEUR = num$(arr(val([L]VALEUR), 0.01))
            When 3
                # On arrondi û  l'euro prû´s
                [L]VALEUR = num$(arr(val([L]VALEUR), 1))
            When 4
                # On tronque û  l'euro
                [L]VALEUR = num$(int(val([L]VALEUR)))
            When Default
        Endcase

        [L]RESULTAT = format$([L]FMT, val([L]VALEUR))

        [L]RESULTAT = vireblc([L]RESULTAT, 4)

        [L]LONGUEUR = len([L]RESULTAT)

        While [L]LONGUEUR < [L]MINI
            [L]RESULTAT = "0" + [L]RESULTAT
            [L]LONGUEUR = len([L]RESULTAT)
        Wend

        # La virgule doit ûˆtre remplacûˋe par un point
        [L]RESULTAT = ctrans([L]RESULTAT, ",", ".")

    When "K"
        [L]RESULTAT = format$([L]FMT, [L]VALEUR)
    When "D"
        [L]RESULTAT = [L]VALEUR
    When Default
        [L]RESULTAT = [L]VALEUR
Endcase

End [L]RESULTAT

#----------------------------------
#  TR : ctrans d'une chaine
#----------------------------------
Funprog TR(ENTREE, FILTRE)
Value Char ENTREE(), FILTRE()
Local Char RESULTAT(250)
#110758 On ne force pas les majuscules
#[L]RESULTAT = toupper(ctrans(num$([L]ENTREE), [L]FILTRE, chr$(32)))
[L]RESULTAT = ctrans(num$([L]ENTREE), [L]FILTRE, chr$(32))
# V01X07 - Bug sur deux blancs consûˋcutifs dans certains cas (Sociûˋtûˋ Machin & Fils => Sociûˋtûˋ Machin   Fils")
# ajout vireblc pour supprimer les blancs en dûˋbut et fin de chaine 29/12/14
[L]RESULTAT = vireblc(vireblc([L]RESULTAT,2), 5)
End [L]RESULTAT


#-------------------------------------------------
#  NUMSSC : Complûˋment numûˋro de sûˋcuritûˋ sociale
#-------------------------------------------------
Funprog NUMSSC(NUMSSC, REFNUM)
Value Char NUMSSC(), REFNUM()

Local Integer DEC, LONGUEUR
[L]LONGUEUR = 13
Local Char RESULTAT([L]LONGUEUR)

If len([L]NUMSSC) < [L]LONGUEUR
    # On va refabriquer ce que l'on peut du numûˋro de sûˋcu ... On repart directement de la fiche salariûˋ, plantûˋ pour plantûˋ ....
    Local File EMPLOID [ID_]
    Read [F:ID_]ID0 = [L]REFNUM
    If fstat = 0
        If [F:ID_]CIV = 1
            [L]RESULTAT = "1"
        Else
            [L]RESULTAT = "2"
        Endif
    Else
        # Ben la on est mal
    Endif
    [L]DEC = len([L]RESULTAT)
    While [L]DEC < [L]LONGUEUR
        [L]RESULTAT = [L]RESULTAT+"9"
        [L]DEC += 1
    Wend
    Close Local File [ID_]
Else
    [L]RESULTAT = [L]NUMSSC
Endif

End [L]RESULTAT

#-------------------------------------------------------------------------------------------------------------------
# EVALP : permet d'ûˋvaluer une condition sur la valeur d'une structure
Funprog EVALP(TSTR, TVAL, FORMULE)
Value Char TSTR()(), TVAL()(), FORMULE()
Local Char STR(250)
Local Char RESULTAT(250)
Local Char SEPDEB(1), SEPFIN(1), PARSING_ERROR(250)
Local Integer DEB, FIN, POS, RANG

[L]SEPDEB = "{" : [L]SEPFIN = "}"

While [L]FORMULE <> ""
    [L]DEB = instr([L]POS, [L]FORMULE, [L]SEPDEB)
    If [L]DEB
        [L]FIN = instr([L]DEB+1, [L]FORMULE, [L]SEPFIN)
        If ! [L]FIN
            # Erreur de formatage , pas de {}
            Break
        Endif
        [L]STR = seg$([L]FORMULE, [L]DEB+1, [L]FIN-1)
        # On cherche dans le TSTR notre structure
        [L]RANG = find([L]STR, [L]TSTR)
        [L]RANG -= 1
        If [L]RANG >= 0
            [L]STR = chr$(34) + [L]TVAL([L]RANG) + chr$(34)
        Else
            [L]STR = "[L]PARSING_ERROR"
        Endif

        FORMULE = left$([L]FORMULE, [L]DEB-1) + [L]STR + right$([L]FORMULE, [L]FIN+1)

        [L]POS = [L]DEB + len([L]STR)
    Else
        # Plus rien û  parser, on sort
        Break
    Endif
Wend

[L]RESULTAT = [L]FORMULE

End [L]RESULTAT

#-------------------------------------------------
# NUMSSC : Recherche du SIRET d'un site
# CRN
#-------------------------------------------------
Funprog CRN(CRN, FCY)
Value Char CRN(), FCY()
Local Char RESULTAT (20)
Local File FACILITY [FCY_]
Raz [L]RESULTAT

Read [F:FCY_]FCY0 = [L]FCY
If !fstat
  [L]RESULTAT = [F:FCY_]CRN
Else
  [L]RESULTAT = [L]CRN
Endif

Close Local File [FCY_]

End [L]RESULTAT

#P2 105175 US3533
# POUR UN CODE INSTITUTION COMMENCANT PAR A* ALORS METTRE RETA
# POUR UN CODE INSTITUTION COMMENCANT PAR C* ALORS METTRE RETC
# POUR UN CODE INSTITUTION COMMENCANT PAR G* ALORS METTRE
# SI RMGCOD ALIMENTû ALORS RETA
# SI RMGCOD2 ALIMENTû ALORS RETC
#**
#* @param PRGMCOD Code RGMCOD ûˋvaluûˋ
#* @param PIND    Indice de RCMCOD
#* @param return RESULTAT
#*!
Funprog RGMCOD(PRGMCOD, PIND)
Value Char PRGMCOD()
Value Integer PIND
Local Char RESULTAT (20)

[L]RESULTAT=string$(left$(PRGMCOD,1)='A','RETA')+string$(left$(PRGMCOD,1)='C','RETC')

If left$(PRGMCOD,1)='G' & PIND=0
   [L]RESULTAT='RETA'
Endif
If left$(PRGMCOD,1)='G' & PIND=1
   [L]RESULTAT='RETC'
Endif

# FQ109014 - 22/06/15 - Pour un code institution ne commencant pas par A*, C* ou G*, on ne change pas le code IRC par RETA ou RETC
If [L]RESULTAT="" Then [L]RESULTAT=PRGMCOD : Endif

End [L]RESULTAT

#JOJAC - END

