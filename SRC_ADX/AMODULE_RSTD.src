#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure AMODULE_RSTD

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
       When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
       When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
       When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
       When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
       When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
       When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return



##########################################################################################################
# METHODS
##########################################################################################################

$AQUERY_DECODE_CRITERIA_AFTER
  Raz NBPRO
  NBPRO += 1
  TBPRO(NBPRO) = "MODULE"      : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AMODULE.MODULE"      : TBFIL(NBPRO) = "[LNK_]MODULE"
  NBPRO += 1
  TBPRO(NBPRO) = "DESCRIPTION" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AMODULE.DESCRIPTION" : TBFIL(NBPRO) = "[LNK_]DESCRIPTION"
Return

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = "[LNK_]MODULE;[LNK_]DESCRIPTION"
Return

$AQUERY_OPEN_AFTER
  Local File APLSTD [QRY_AST]
  Local Shortint TMODULE(1..)
  Local Char    TDESCRIPTION(123)(1..)
  Local Integer I

  For [F:QRY_AST]LAN  From GACTX.LAN To GACTX.LAN Where [F:QRY_AST]LANCHP=14
    If [F:QRY_AST]LANNUM<>0
      I += 1
      TMODULE(I)      = [F:QRY_AST]LANNUM
      TDESCRIPTION(I) = [F:QRY_AST]LANMES
    Endif
  Next

  Local File (Integer MODULE,Char DESCRIPTION(123)) From Variable TMODULE,TDESCRIPTION As [LNK_]
Return

$AQUERY_TRANS_AFTER
  this.AMODULE.MODULE      = [LNK_]MODULE
  this.AMODULE.DESCRIPTION = [LNK_]DESCRIPTION
Return

$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
  LogicClose File  [QRY_AST]
Return

$AREAD_AFTER
Return

