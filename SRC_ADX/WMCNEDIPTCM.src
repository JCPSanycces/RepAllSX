# Supervisor
## ACLA-CLASSE ## EDIPTCM
# 2018-11-06 07:05:00 498

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDIPTCM
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_PTCCOD From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub INIT_NUMLIN From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub INIT_PTCMLINCOD From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub INIT_PTCMLINDES From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub INIT_PTCMLINVAL From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub INIT_PTCMLVALTYP From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDIPTCM : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDIPTCM
Gosub _ALOADATTRIBUTE_PTCCOD From WMC1EDIPTCM : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_NUMLIN From WMC1EDIPTCM : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDIPTCM
Gosub LNKPRO_PTCCOD From WMC1EDIPTCM : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



