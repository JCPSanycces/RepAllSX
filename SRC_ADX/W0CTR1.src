# Superviseur
# Gestion du masque CTR1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SUICAR
mkstat = 0
zoncou = "SUICAR"
indice = 0
IMPENT = [M]SUICAR
If varinit([M]SUICAR,indice)=0
 IMPENT = 2
Endif
If varmode([M]SUICAR,indice)=0
 [M]SUICAR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SUICAR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SUICAR(indice)
 Endif
Endif
[M]SUICAR = IMPENT

## Zone CLLCVT
mkstat = 0
zoncou = "CLLCVT"
indice = 0
If varmode([M]CLLCVT,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRCLV"
 Call DEFHRCLV([M]CLLCVT,GCURLEG,GSOCIETE) From SUBHRCLV
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CLLCVT : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call AS_CLLCVT([M]CLLCVT) From SUBCTR
  GACTION = SAVACT
  If mkstat=1 : Raz [M]CLLCVT : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "CLLCVT" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   If vireblc([M]CLLCVT,2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 47302 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTHRCLV"
    Call CONTHRCLV([M]CLLCVT,GCURLEG,GSOCIETE) From SUBHRCLV
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 47302 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTOBJN"
     Local Char    VALEUR(250)
     VALEUR = [M]CLLCVT
     Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
     [M]CLLCVT = VALEUR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 47302 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

