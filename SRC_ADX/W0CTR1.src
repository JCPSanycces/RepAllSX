zoncou = "DNATYPMOD"
indice = 0
IMPENT = [M]DNATYPMOD
If varinit([M]DNATYPMOD,indice)=0
 IMPENT = 1
 SAVACT = GACTION : GACTION = "STD"
 Call D_DNATYPMOD(IMPENT) From SUBCTR
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DNATYPMOD,indice)=0
  Call INICOMBO(10810) From COMBOS
  SAVACT = GACTION : GACTION = "STD"
  Call AS_DNATYPMOD(IMPENT) From SUBCTR
  GACTION = SAVACT
  If mkstat=1 : Raz IMPENT : Endif
  If IMPENT<1 | GMENLOC(IMPENT)=1
   IMPENT = find(0,GMENLOC(1..len(mess(0,10810,1))))
  Endif
  [M]DNATYPMOD(indice) = IMPENT
  If !mkstat
   IMPMOD = 0 : IMPZON = "DNATYPMOD" : Gosub ACTION From =IMPTRT
   IMPENT = [M]DNATYPMOD(indice)
  Endif
  If !mkstat
   If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
    mkstat = 1 : GMESSAGE = mess(99,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "DNATYPMOD" : GZNUM = 48814 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_DNATYPMOD(IMPENT) From SUBCTR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "DNATYPMOD" : GZNUM = 48814 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif
