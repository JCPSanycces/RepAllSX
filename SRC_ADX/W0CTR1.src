If varmode([M]DATFCY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_DATFCY([M]DATFCY) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]DATFCY : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATFCY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_DATFCY([M]DATFCY) From SUBCTR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DATFCY" : GZNUM = 46554 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

