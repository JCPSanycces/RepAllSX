#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
Subprog AS_NBREP

  If nolign >= dim([M:LKP6]MAIREP) Then
    End
  Endif
  If [M:LKP6]NBREP = 0 or nolign > [M:LKP6]NBREP Then # FGR 07/08/2012 : X3SUIVI83873
    End
  Endif
  If nolign > 0 Then
    Raz [M:LKP6]NBSECSEL
    Raz [M:LKP6]NBREPSEL
    [M:LKP6]NBREPSEL(nolign-1) = "->"
    [M:LKP6]SELREP = [M:LKP6]MAIREP(nolign-1)
  Endif
  Affzo [M:LKP6]
End

