#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case [L]ACTION
When "DEBUT_FAT"
 Case [L]TABLE
  When "F_EFFECTIF" : Gosub DEBUT_EFFECTIF
 Endcase
When "FIN_FAT"
 Case [L]TABLE
  When "F_EFFECTIF" : Gosub FIN_EFFECTIF
 Endcase
Endcase
Return

################################################################################
#
# Table de fait EFFECTIF
#
################################################################################

$DEBUT_EFFECTIF
If clalev([F:LNK_]) : Close Local File [LNK_] : Endif
Local File =[V]GDOSSIER+".CEFFECTIF" [LNK_] Order By Key CLE=POP;CPY;REFNUM;CTRNUM;STRDAT
Return

#-------------------------------------------------------------------------------
$FIN_EFFECTIF
If clalev([F:LNK_]) : Close Local File [LNK_] : Endif
Return

# Bug 68616 Synchro quand la règle de synchro utilise une vue et que l'on met AREPORTM dan la table d'origine
$SET_TCLE

[L]NBTCLE =7
[L]TCLE(1)="POP"
[L]TCLE(2)="CPY"
[L]TCLE(3)="FCY"
[L]TCLE(4)="REFNUM"
[L]TCLE(5)="CTRNUM"
[L]TCLE(6)="CTRDAT"
[L]TCLE(7)="STRDAT"

If dim([L]ABR_TABORG)>0 : [L]ABR_TABORG="LNK_" : Endif
If dim([L]TTYP)>0
 [L]TTYP(1)=7
 [L]TTYP(2)=7
 [L]TTYP(3)=7
 [L]TTYP(4)=7
 [L]TTYP(5)=7
 [L]TTYP(6)=8
 [L]TTYP(7)=8
Endif
Return

#-------------------------------------------------------------------------------
Funprog EFFECTIF(TCLE,NBTCLE)
Variable Char TCLE()(1..)
Variable Integer NBTCLE
# Bug 68616 Synchro quand la règle de synchro utilise une vue et que l'on met AREPORTM dan la table d'origine
#[L]NBTCLE =5
#[L]TCLE(1)="POP"
#[L]TCLE(2)="CPY"
#[L]TCLE(3)="REFNUM"
#[L]TCLE(4)="CTRNUM"
#[L]TCLE(5)="STRDAT"
Gosub SET_TCLE

End [F:LNK_]REFNUM

################################################################################
#
# Dimension EMPLOCTR
#
################################################################################

Funprog ZERO2MAX(DAT)
Value Date DAT

If [L]DAT=[0/0/0] : End gdat$(31,12,adxdcs+99) : Else End [L]DAT : Endif

#-------------------------------------------------------------------------------
Funprog CDDYEA(NBRPER,PERCON)
Value Shortint NBRPER
Value Libelle  PERCON

Case [L]PERCON
 When 1       : End arr([L]NBRPER/365.25,0.0001)
 When 2       : End arr([L]NBRPER/52.17857,0.0001)
 When 3       : End arr([L]NBRPER/12,0.0001)
 When 4       : End [L]NBRPER
 When Default : End 0
Endcase

#-------------------------------------------------------------------------------
Funprog CDDMTH(NBRPER,PERCON)
Value Shortint NBRPER
Value Libelle  PERCON

Case [L]PERCON
 When 1       : End arr(12*[L]NBRPER/365.25,0.001)
 When 2       : End arr(12*[L]NBRPER/52.17857,0.001)
 When 3       : End [L]NBRPER
 When 4       : End 12*[L]NBRPER
 When Default : End 0
Endcase

#-------------------------------------------------------------------------------
Funprog CDDWEK(NBRPER,PERCON)
Value Shortint NBRPER
Value Libelle  PERCON

Case [L]PERCON
 When 1       : End arr([L]NBRPER/7,0.01)
 When 2       : End [L]NBRPER
 When 3       : End arr(52.17857*[L]NBRPER/12,0.01)
 When 4       : End arr(52.17857*[L]NBRPER,0.01)
 When Default : End 0
Endcase

#-------------------------------------------------------------------------------
Funprog CDDDAY(NBRPER,PERCON)
Value Shortint NBRPER
Value Libelle  PERCON

Case [L]PERCON
 When 1       : End [L]NBRPER
 When 2       : End 7*[L]NBRPER
 When 3       : End arr(365.25*[L]NBRPER/12,1)
 When 4       : End arr(365.25*[L]NBRPER,1)
 When Default : End 0
Endcase

