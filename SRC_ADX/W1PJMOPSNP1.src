#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMOPSNP1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:49"
A_USER  = "DOC"
A_STAMP = "20181109230549"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMOPSNP1 [PJSNP1]
Gosub HORODAT
Local Inpbox "PJMOPSNP1" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJSNP1] As [SIM_]
Grizo [PJSNP1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJSNP1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_NBLIG
Onevent CONTROL Call C_NBLIG From W1PJMOPSNP1
Onevent BEFORE_INPUT Call AS_NBLIG From W1PJMOPSNP1
Return

Subprog IB_NBLIG
Local Decimal BASPAG
## Action STD
Call IB_NBLIG From SUBPJMOPSNP
Gosub _AFF
End

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(12102,GBOUT2) From OBJDIV
Call IB_NBLIG
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1PJMOPSNP1
Gosub _AFF
End

Subprog C_NBLIG
Local Decimal BASPAG
## Action STD
Call C_NBLIG From SUBPJMOPSNP
If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMOVE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMOVE"
 PARMSK(1) = [M:PJSNP0]OPPNUM
 PARMSK(2) = [M:PJSNP1]KEYEXT(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"OPJMOVE","PJMOVE","") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_BTCMT
Onevent BEFORE_INPUT Call AS_BTCMT(zc) From W1PJMOPSNP1
Return

Subprog AS_BTCMT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(42564,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_BTCMT(zc) From W1PJMOPSNP1
Gosub _AFF
End

Subprog CL_BTCMT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action PJMTXTCLA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMTXTCLA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "ACL_BTCMT" : PROGSUB = "SUBPJMOPSNP" : PROGSPE = "SPEPJMOPSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMOPSNP1"
 PARMSK(2) = "PJSNP1"
 PARMSK(3) = num$(nolign-1)
 PARMSK(4) = "CLOB"
 PARMSK(5) = "ACT"
 PARMSK(6) = [M:PJSNP1]KEYEXT(nolign-1)
 Call SAISIE_CHAR(VALEUR,PARMSK,"PJMTXTCLA","SUBPJMCLA","") From GSAISIE
 ACTION = "BCL_BTCMT" : PROGSUB = "SUBPJMOPSNP" : PROGSPE = "SPEPJMOPSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_DDESAXX
Onevent INIT_AREA Call D_DDESAXX(zc) From W1PJMOPSNP1
Onevent BEFORE_INPUT Call AS_DDESAXX(zc) From W1PJMOPSNP1
Return

Subprog IB_DDESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DDESAXX(VALEUR)
Variable Char    VALEUR()
If varinit([M]DDESAXX,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PJMOPSNPD","DDESAXX",[M:PJSNP0]SNPCOD,num$([M:PJSNP1]SNPSEQ(nolign-1))) From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DDESAXX(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DDESAXX(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DDESAXX(zc) From W1PJMOPSNP1
Gosub _AFF
End

Subprog B1_DDESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DDESAXX" : PROGSUB = "SUBPJMOPSNP" : PROGSPE = "SPEPJMOPSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMOPSNPD"
 PARMSK(2) = "DDESAXX"
 PARMSK(3) = [M:PJSNP0]SNPCOD
 PARMSK(4) = num$([M:PJSNP1]SNPSEQ(nolign-1))
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DDESAXX" : PROGSUB = "SUBPJMOPSNP" : PROGSPE = "SPEPJMOPSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_DSNPCREDAT
Onevent BEFORE_AREA Gosub AV_DSNPCREDAT From W1PJMOPSNP1
Return

$AV_DSNPCREDAT
Chgfmt [M]DSNPCREDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_DEFBAS
Onevent AFTER_CHANGE Gosub AMM_DEFBAS From W1PJMOPSNP1
Onevent INIT_AREA Call D_DEFBAS(zc) From W1PJMOPSNP1
Onevent BEFORE_INPUT Call AS_DEFBAS(zc) From W1PJMOPSNP1
Onevent CONTROL Call C_DEFBAS(zc) From W1PJMOPSNP1
Return

Subprog D_DEFBAS(VALEUR)
Variable Integer VALEUR
If varinit([M]DEFBAS,indice)=0
 VALEUR = [V]CST_ANO
Endif
Gosub _AFF
End

Subprog AS_DEFBAS(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_DEFBAS(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DEFBAS" : GZNUM = 1003764 : Endif
Gosub _AFF
End

$AMM_DEFBAS
Call AM_DEFBAS(zc)
If !mkstat & GOBJET
 zoncou = "DEFBAS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DEFBAS(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_DEFBAS(VALEUR) From SUBPJMOPSNP
If mkstat : GERR = 1 : GZONE = "DEFBAS" : GZNUM = 1003764 : Endif
Gosub _AFF
End

$ON_KEYEXT
Return

$CHG_STY
Return


