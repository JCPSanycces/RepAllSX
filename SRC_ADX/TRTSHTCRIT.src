#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque STKSHTCRIT
## GPROG    = Traitement
## GTYPPROG = 1:Direct  2:O/N   3:Dialogue  4:Autre
## GWINDOW  = Ecran de saisie
## GWINCRIT = Ecran de critères

GPROG    = "TRTSHTS"
GTYPPROG = 3
GWINDOW  = "ISHTS"
GWINCRIT = "ISHTCRIT"
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG,"") From GTRAITE

End

# Regularisation mouvements en attente et manquants
############################################################
$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE
  When "DEBUT"          : Gosub DEBUT
  When "OK"             : Gosub OK_MVTATT
  When "END"            : Gosub END_MVTATT
Endcase

Return
#############################################################
$INIT_DIA
    Raz   [M:SSC]
    Actzo [M:SSC]1-99

    [M:SSC]STOFCY = GFCYDEF(0)
    [M:SSC]MONOITMFLG = 1
    [M:SSC]PRIDEFFLG = 2
    [M:SSC]REGFLG = 2

    Raz [F:ITM]
    If [M:SSC]STOFCY <> ""                               # hcb 45810
        Call LECSTE("", [M:SSC]STOFCY, 1) From TRTSHTA
    Endif                                                # hcb 45810
    GPOINT="INI_SSC" : Gosub ENTREE From EXEFNC          # hcb 42790

    Call C_PRIDEFFLG([M:SSC]PRIDEFFLG)
    Call C_REGFLG([M:SSC]REGFLG)


    Affzo [M:SSC]1-99
Return

#############################################################
$OUVRE
    # Masque de sauvegarde des valeurs. Utilisé dans le cas du clic sur le bouton "Fin"
    If !clalev([DIAS]) : Local Mask STKSHTCRIT [DIAS] : Endif
    Raz [M:DIAS]
Return

#############################################################
$DEBUT
    Affzo [M:SSC]
    Actzo [M:SSC]1-99
    Default Mask "[SSC]"
    Call C_PRIDEFFLG([M:SSC]PRIDEFFLG)
    Call C_REGFLG([M:SSC]REGFLG)
    Transmask [M:SSC] To [M:DIAS]# Issue 25606[M:DIAS] = [M:SSC]
    Affzo [M:SSC]1-99
Return

#############################################################
$OK_MVTATT
    Call LOADSHTS(0) From TRTSHTA
    FIN  = 1
Return

#############################################################
$END_MVTATT
# Si on clique sur "Fin" il ne faut pas effacer les paramètres qui ont été saisis précédemment
    [M:SSC] = [M:DIAS]
    FIN = 1
Return

#----------------------------------------------------------------#
#----------------------------------------------------------------#
#------------        Actions écran          ---------------------#
#----------------------------------------------------------------#
#----------------------------------------------------------------#
########################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
    If [M:SSC]PRIDEFFLG=2
        Call LECSTE("", VALEUR, 1) From TRTSHTA
    Endif
End

#---------------------------------------#
#          CATEGORIES - ARTICLES        #
#---------------------------------------#

########################################
Subprog AM_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
    If [M:SSC]TCLCODEND=[M:SSC]TCLCODSTR | [M:SSC]TCLCODEND<VALEUR
        [M:SSC]TCLCODEND = VALEUR
        Affzo [M:SSC]TCLCODEND
    Endif
End

########################################
Subprog C_TCLCODEND(VALEUR)
Variable Char    VALEUR()
    If [M:SSC]TCLCODSTR>VALEUR
        GMESSAGE = mess(44,199,1)
        mkstat=2
    Endif
    If VALEUR = ""
        VALEUR = [M:SSC]TCLCODSTR
    Endif
End

########################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
    If [M:SSC]ITMREFEND=[M:SSC]ITMREFSTR | [M:SSC]ITMREFEND<VALEUR
        [M:SSC]ITMREFEND = VALEUR
        Affzo [M:SSC]ITMREFEND
    Endif
End

########################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
    If [M:SSC]ITMREFSTR>VALEUR
        GMESSAGE = mess(44,199,1)
        mkstat=2
    Endif
    If VALEUR = ""
        VALEUR = [M:SSC]ITMREFSTR
    Endif
    If VALEUR = [M:SSC]ITMREFSTR & VALEUR <>""
        If [F:ITM]ITMREF<>VALEUR
            Read [ITM]ITM0=VALEUR
            If fstat
                GMESSAGE = mess(212,199,1)
                mkstat=2
                End
            Endif
        Endif
        If [F:ITF]ITMREF<>VALEUR
            Read [ITF]ITF0=VALEUR;[M:SSC]STOFCY
            If fstat
                GMESSAGE = mess(25,192,1)
                mkstat=2
                End
            Endif
        Endif
        If [F:ITM]TCLCOD<[M:SSC]TCLCODSTR | ([M:SSC]TCLCODEND<>"" & [F:ITM]TCLCOD>[M:SSC]TCLCODEND)
            GMESSAGE = mess(9,180,1)
            mkstat=2
            End
        Endif
    Endif
End



#---------------------------------------#
#             TRAITEMENTS               #
#---------------------------------------#
########################################
Subprog C_PRIDEFFLG(VALEUR)
Variable Integer VALEUR
    If VALEUR=2
        Grizo [M:SSC]20-25
    Else
        Actzo [M:SSC]20-25
        Call MODIF_PRI("SHTPAR",1,[M:SSC]SHTPAR1) From TRTSHTA
        Call MODIF_PRI("SHTPAR",2,[M:SSC]SHTPAR2) From TRTSHTA
        Call MODIF_PRI("SHTCAT",1,[M:SSC]SHTCAT1) From TRTSHTA
        Call MODIF_PRI("SHTCAT",2,[M:SSC]SHTCAT2) From TRTSHTA
    Endif
End

########################################
Subprog C_REGFLG(VALEUR)
Variable Integer VALEUR
    If VALEUR=2
        [M:SSC]ERRFLG = 2
        Grizo [M:SSC]ERRFLG
        Affzo [M:SSC]ERRFLG
    Else
        Actzo [M:SSC]ERRFLG
        Affzo [M:SSC]ERRFLG
    Endif
End


#---------------------------------------#
#             PRIORITES                 #
#---------------------------------------#

########################################
Subprog AS_SHTPAR1(VALEUR)
Variable Integer VALEUR
    GMENLOC(1)=1
End

########################################
Subprog C_SHTPAR1(VALEUR)
Variable Integer VALEUR
    Call MODIF_PRI("SHTPAR", 1, VALEUR) From TRTSHTA
    Affzo [M:SSC]SHTPAR2,SHTPAR3
End


########################################
Subprog AS_SHTPAR2(VALEUR)
Variable Integer VALEUR
    GMENLOC([M:SSC]SHTPAR1)=1
End

########################################
Subprog C_SHTPAR2(VALEUR)
Variable Integer VALEUR
    Call MODIF_PRI("SHTPAR", 2, VALEUR) From TRTSHTA
    Affzo [M:SSC]SHTPAR3
End

########################################
Subprog AS_SHTPAR3(VALEUR)
Variable Integer VALEUR
    GMENLOC([M:SSC]SHTPAR1)=1
    GMENLOC([M:SSC]SHTPAR2)=1
End

########################################
Subprog AS_SHTCAT1(VALEUR)
Variable Integer VALEUR
    GMENLOC(1)=1
End

########################################
Subprog C_SHTCAT1(VALEUR)
Variable Integer VALEUR
    Call MODIF_PRI("SHTCAT", 1, VALEUR) From TRTSHTA
    Affzo [M:SSC]SHTCAT2,SHTCAT3
End

########################################
Subprog AS_SHTCAT2(VALEUR)
Variable Integer VALEUR
    GMENLOC([M:SSC]SHTCAT1)=1
End

########################################
Subprog C_SHTCAT2(VALEUR)
Variable Integer VALEUR
    Call MODIF_PRI("SHTCAT", 2, VALEUR) From TRTSHTA
    Affzo [M:SSC]SHTCAT3
End

########################################
Subprog AS_SHTCAT3(VALEUR)
Variable Integer VALEUR
    GMENLOC([M:SSC]SHTCAT1)=1
    GMENLOC([M:SSC]SHTCAT2)=1
End


#---------------------------------------#
#             FAMILLES STAT             #
#---------------------------------------#

############################################################
Subprog AS_TSICODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" | VALEUR < [M]TSICODSTR(indice)
  VALEUR = [M:SSC]TSICODSTR(indice)
Endif
End
############################################################
Subprog C_TSICODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M:SSC]TSICODSTR(indice)
 GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
###########################################################
Subprog AV_PRIDEFFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Grizo [M:SSC]20-25
Endif
End

