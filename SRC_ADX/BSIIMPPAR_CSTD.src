#<AdxTL>@(#)2.0.0.0 $Revision$ Bank statement import
######################################################################################################
# Project       : Bank file import (MT940)
# File          : BSIIMPPAR_CSTD
# Version       : 1.0
# Author        : Anton Gregolec
# Creation Date : 02.05.16
######################################################################################################
# Module        : Finance
# Description   : Bank file import parameters (Class BSIIMPPAR)
######################################################################################################
# Updates :
# Date       |Author |Version| Description
# 2016-08-10 |angre  |U11    | check for invoice number definition and BPR number definition
# 2016-08-26 |angre  |U11    | Initalize merge description field with 1
# 2016-08-26 |angre  |U11    | additional check for CDAACCSUSP
# 2016-10-13 |bader  |U11    | additional check for CDAEXCPAY
# 2017-05-04 |bader  |2017.R3| AUPDATE_CONTROL_BEFORE: check BVRREFNUM instead of ORDERNUM
# 2017-07-06 |DNE    |2017.R5| X3-47552 Introduction of ATMVARCUR and CDVARCUR fields
# 2017-07-10 |DNE    |2017.R5| AUPDATE_CONTROL_BEFORE: Single check of AMT flag not allowed
# 2017-07-14 |DNE    |2017.R5| PROP_AMTVAR: Reset AMTVARLIM to 0 if AMTVAR is set to 0.
# 2017-08-17 |DNE    |2017.R5| X3-52272 FLGCLS: If active "Suspense account" etc. are disabled.
######################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
    Case [L]CURPTH
        When ""
            Case [L]AEVENT
                When "AUPDATE_CONTROL_BEFORE", "AINSERT_CONTROL_BEFORE" : Gosub AUPDATE_CONTROL_BEFORE
                When "AREAD_AFTER" : Gosub AREAD_AFTER
            Endcase
    Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
    Case [L]ARULE
        When "INIT"
            Case [L]CURPRO
                When "ALLTYP"      : this.ALLTYP = 2
                When "ALLBPR"      : this.ALLBPR = 2
                When "ALLCAT"      : this.ALLCAT = 2
                When "MRGDESFLD"   : this.MRGDESFLD = 1
# 2017-08-17 DNE INSERT BEGIN (X3-52272)
                When "ACCSUSPENSE" : Gosub INIT_ACCSUSPENSE
                When "CDAACCSUSP"  : Gosub INIT_CDAACCSUSP
# 2017-08-17 DNE INSERT END
                When "MOVAFTIMP"   : Gosub INIT_MOVAFTIMP
                When "FLOTYP"      : Gosub INIT_FLOTYP
            Endcase
        When "CONTROL"
            Case [L]CURPRO
                When "BAN"         : Gosub CHECK_BAN_VS_CPY_FCY From BSILIB
                When "IMPVOL"      : Gosub CHECK_VOLUME_PATH From BSILIB
                When "MOVVOL"      : Gosub CHECK_VOLUME_PATH From BSILIB
                When "INVNUM"      : Gosub CHECK_INVNUM_DEF From BSILIB
                When "BPRNUM"      : Gosub CHECK_BPRNUM_DEF From BSILIB
                When "DEPTOL"      : Gosub CHECK_DEPTOL
                When "AMTVAR"      : Gosub CHECK_AMTVAR
                When "AMTVARCUR"   : Gosub CHECK_AMTVARCUR
                When "AMTVARLIM"   : Gosub CHECK_AMTVARLIM
                When "CDAACCSUSP"  : Gosub CHECK_CDAACCSUSP
                When "ACCSUSPENSE" : Gosub CONTROL_ACCSUSPENSE
                When "CDASHOPAY"   : Gosub CONTROL_CDASHOPAY
                When "CDAEXCPAY"   : Gosub CONTROL_CDAEXCPAY
                When "CDAVARCUR"   : Gosub CONTROL_CDAVARCUR
            Endcase
        When "PROPAGATE"
            Case [L]CURPRO
                When "CPY"         : Gosub PROPAGATE_COMPANY
                When "FLOTYP"      : Gosub PROPAGATE_FLOTYP
                When "AMTVAR"      : Gosub PROPAGATE_AMTVAR
# 2017-08-17 DNE INSERT BEGIN (X3-52272)
                When "FLGCLS"      : Gosub PROPAGATE_FLGCLS
# 2017-08-17 DNE INSERT END
                When "MOVAFTIMP"   : Gosub PROPAGATE_MOVAFTIMP
            Endcase
    Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


$INIT_ACCSUSPENSE
    If this.FLOTYP = 1 Then
        ASTATUS = fmet this.ASETATTRIBUTE("ACCSUSPENSE", "$isMandatory", "true")
    Else
        ASTATUS = fmet this.ASETATTRIBUTE("ACCSUSPENSE", "$isMandatory", "false")
    Endif
Return


$INIT_CDAACCSUSP
    If this.FLOTYP = 1 Then
        ASTATUS = fmet this.ASETATTRIBUTE("CDAACCSUSP", "$isMandatory", "true")
    Else
        ASTATUS = fmet this.ASETATTRIBUTE("CDAACCSUSP", "$isMandatory", "false")
    Endif
Return


$INIT_MOVAFTIMP
    ASTATUS = fmet this.ASETATTRIBUTE("MOVVOL", "$isMandatory", "false")
    this.RENAFTIMP = [V]CST_ANO
Return


$INIT_FLOTYP
    this.FLOTYP = 1
Return


#**
#* Determine and assign Legislation and chart of account for company
#*!
$PROPAGATE_COMPANY
  Local File COMPANY [CPY]
  Local File GACM [GCM]
  Local File GLED [LED]
  Read [CPY]CPY0 = this.CPY
  If !fstat
    this.LEG = [F:CPY]LEG  # assign legislation
    Read [GCM]GCM0 = [CPY]ACM
    If !fstat
      Read [LED]LED0 = [GCM]LED( [GCM]GENLEDTYP - 1 )
      If !fstat
        this.COA = [LED]COA # assign coa
      Endif
    Endif
  Endif
  LogicClose File [CPY]
  LogicClose File [GCM]
  LogicClose File [LED]
Return


#**
#* Update availability of fields based on the Flow type value chosen
#*!
$PROPAGATE_FLOTYP
    If this.FLOTYP = 1 Then
        # restore mandatory attribute
        ASTATUS = fmet this.ASETATTRIBUTE("PAYTYP", "$isMandatory", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("CDASHOPAY", "$isMandatory", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("CDAEXCPAY", "$isMandatory", "true")
        Gosub PROPAGATE_FLGCLS
    Else
        # remove mandatory attribute
        ASTATUS = fmet this.ASETATTRIBUTE("PAYTYP", "$isMandatory", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("CDASHOPAY", "$isMandatory", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("CDAEXCPAY", "$isMandatory", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("ACCSUSPENSE", "$isMandatory", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("CDAACCSUSP",  "$isMandatory", "false")
    Endif
Return


#**
#* Reset AMTVARLIM to 0 if AMTVAR is set to 0.
#*!
$PROPAGATE_AMTVAR
    If this.AMTVAR = 0
        this.AMTVARLIM = 0
    Endif
Return


# 2017-08-17 DNE INSERT BEGIN (X3-52272)
#**
#* Emptying of fields ACCSUSPENSE and CDAACCSUSP field FLGCLS is checked.
#**
#*!
$PROPAGATE_FLGCLS
    If this.FLGCLS = [V]CST_AYES Then
        ASTATUS = fmet this.ASETATTRIBUTE ( "ACCSUSPENSE", "$isMandatory", "false" )
        ASTATUS = fmet this.ASETATTRIBUTE ( "CDAACCSUSP",  "$isMandatory", "false" )
        this.ACCSUSPENSE = ""
        this.CDAACCSUSP  = ""
    Else
        If this.FLOTYP = 1 Then
            ASTATUS = fmet this.ASETATTRIBUTE ( "ACCSUSPENSE", "$isMandatory", "true"  )
            ASTATUS = fmet this.ASETATTRIBUTE ( "CDAACCSUSP",  "$isMandatory", "true"  )
        Endif
    Endif
Return
# 2017-08-17 DNE INSERT END


$PROPAGATE_MOVAFTIMP
    If this.MOVAFTIMP = [V]CST_AYES Then
        ASTATUS = fmet this.ASETATTRIBUTE ("MOVVOL", "$isMandatory", "true")
    Else
        ASTATUS = fmet this.ASETATTRIBUTE ("MOVVOL", "$isMandatory", "false")
        this.RENAFTIMP = [V]CST_ANO
    Endif
Return


#**
#*  Check if one of the the necessary search criteria is selected
#*!
$AUPDATE_CONTROL_BEFORE
    If this.FLOTYP = 1 Then
        # check this only for Standard flow type
        If this.BPRNUM      <> CST_AYES
&         and this.INVNUM   <> CST_AYES
&         and this.SRCDOC   <> CST_AYES
&         and dim(this.BVRREFNUM) > 0 and this.BVRREFNUM <> CST_AYES Then
            ASTATUS = fmet this.ASETERROR( "", mess(229,7703,1), [V]CST_AERROR ) # 'Please check at least one search criteria out of BP number, invoice number or ISR reference.'
        Endif
    Endif
Return


#**
#* Update availability of fields based on the Flow type value chosen
#*!
$AREAD_AFTER
    Gosub PROPAGATE_FLOTYP
    Gosub PROPAGATE_MOVAFTIMP
Return


$CHECK_DEPTOL
    If this.DEPTOL < 0 Then
        ASTATUS = fmet this.ASETERROR("DEPTOL", mess(29,7703,1), [V]CST_AERROR) # 'A positive value is expected.'
    Endif
Return

$CHECK_AMTVARCUR
    If this.AMTVARCUR < 0 or this.AMTVARCUR > 100 Then
        ASTATUS = fmet this.ASETERROR( "AMTVARCUR", func AFNC.MES2(mess(227,7703,1), num$(0 ), num$( 100 ) ), [V]CST_AERROR) #  'Values must be in the range $1$ to $2$.'
    Endif
Return

$CHECK_AMTVAR
    If this.AMTVAR < 0 or this.AMTVAR > 100 Then
        ASTATUS = fmet this.ASETERROR( "AMTVAR", func AFNC.MES2(mess(227,7703,1), num$(0 ), num$( 100 ) ), [V]CST_AERROR) # A  'Values must be in the range $1$ to $2$.'
    Endif
Return

$CHECK_AMTVARLIM
    If this.AMTVARLIM < 0 Then
        ASTATUS = fmet this.ASETERROR( "AMTVARLIM", mess(29,7703,1), [V]CST_AERROR ) # A positive value is expected.
    Endif
Return

#**
#*  Check if payment sign is checked in selected payment attribute
#*!
$CHECK_CDAACCSUSP
# 2017-08-17 DNE INSERT BEGIN (X3-52272)
    If this.CDAACCSUSP <> "" Then
# 2017-08-17 DNE INSERT END
        If !clalev([F:CDA]) Local File GACCDENCOD  [CDA]  Endif
        Filter [F:CDA] Where [F:CDA]LEG = this.LEG and [F:CDA]COD = this.CDAACCSUSP
        Read [F:CDA]CDA0 First
        If !fstat Then
            If [F:CDA]ACCSNS > 1 or [F:CDA]ACCTYP > 1 Then
              ASTATUS = fmet this.ASETERROR("CDAACCSUSP", func AFNC.MES1( mess(69,7703,1), this.CDAACCSUSP), [V]CST_AERROR) # 'Invalid payment attribute $1$'
            Endif
        Else
            ASTATUS = fmet this.ASETERROR( "CDAACCSUSP", "'" + this.CDAACCSUSP + "'" - mess(23,100,1), [V]CST_AERROR ) # 'Record does not exist'
        Endif
        Filter [F:CDA]
# 2017-08-17 DNE INSERT BEGIN (X3-52272)
    Endif
# 2017-08-17 DNE INSERT END
Return


$CONTROL_CDASHOPAY
    If this.CDASHOPAY <> "" Then
        If !clalev([F:CDA]) Local File GACCDENCOD  [CDA]  Endif
        Filter [F:CDA] Where [F:CDA]LEG = this.LEG and [F:CDA]COD = this.CDASHOPAY
        Read [F:CDA]CDA0 First
        If fstat Then
            ASTATUS = fmet this.ASETERROR( "CDASHOPAY", "'" + this.CDASHOPAY + "'" - mess(23,100,1), [V]CST_AERROR ) # 'Record does not exist'
        Endif
        Filter [F:CDA]
    Endif
Return


#**
#*  Check if account structure isn't "Account<=>BP" in selected payment attribute
#*!
$CONTROL_CDAEXCPAY
    If this.CDAEXCPAY <> "" Then
        If !clalev([F:CDA]) Local File GACCDENCOD  [CDA]  Endif
        Filter [F:CDA] Where [F:CDA]LEG = this.LEG and [F:CDA]COD = this.CDAEXCPAY
        Read [F:CDA]CDA0 First
        If !fstat Then
            If [F:CDA]ACCTYP = 3 Then
              # 'Account structure "Account<=>BP" is not allowed for overpayment payment attribute $1$.'
              ASTATUS = fmet this.ASETERROR("CDAEXCPAY", func AFNC.MES1( mess(77,7703,1), this.CDAEXCPAY), [V]CST_AERROR)
            Endif
        Else
            ASTATUS = fmet this.ASETERROR( "CDAEXCPAY", "'" + this.CDAEXCPAY + "'" - mess(23,100,1), [V]CST_AERROR ) # 'Record does not exist'
        Endif
        Filter [F:CDA]
    Endif
Return

#**
#*  Check if account structure isn't "Account<=>BP" in selected payment attribute
#*!
$CONTROL_CDAVARCUR
  # TODO (DNE) for the future: If CDAVARCUR field is set to "visible" and "mandatory" you can remove this check.
  If this.CDAVARCUR = ""
      Return
  Endif

  If !clalev([F:CDA]) Local File GACCDENCOD  [CDA]  Endif
  Filter [F:CDA] Where [F:CDA]LEG = this.LEG and [F:CDA]COD = this.CDAVARCUR
  Read [F:CDA]CDA0 First
  If !fstat Then
      If [F:CDA]ACCTYP = 3 Then
        ASTATUS = fmet this.ASETERROR("CDAVARCUR", func AFNC.MES1( mess(230,7703,1), this.CDAVARCUR), [V]CST_AERROR) # 'Account structure "Account<=>BP" is not allowed for bank charge payment
# attribute $1$.'
      Endif
      If [F:CDA]ACCSNS <> 2 Then
        ASTATUS = fmet this.ASETERROR("CDAVARCUR", func AFNC.MES1( mess(69,7703,1), this.CDAVARCUR), [V]CST_AERROR) # 'Invalid payment attribute $1$'
      Endif
  Else
      ASTATUS = fmet this.ASETERROR( "CDAVARCUR", this.CDAVARCUR - mess(23,100,1), [V]CST_AERROR ) # 'Record does not exist'
  Endif
  Filter [F:CDA]
Return


#**
#*  Check if suspense account belongs to the country's main legal ledger.
#*!
$CONTROL_ACCSUSPENSE
# 2017-08-17 DNE INSERT BEGIN (X3-52272)
    If this.ACCSUSPENSE <> "" Then
# 2017-08-17 DNE INSERT END
        Local File GACCOUNT [GAC]

        Look [F:GAC]GAC0 = this.COA; this.ACCSUSPENSE
        If fstat Then
            ASTATUS = fmet this.ASETERROR( "ACCSUSPENSE", mess(176,105,1), [V]CST_AERROR ) # 'Not defined in the chart of accounts'
        Endif
# 2017-08-17 DNE INSERT BEGIN (X3-52272)
    Endif
# 2017-08-17 DNE INSERT END
Return

