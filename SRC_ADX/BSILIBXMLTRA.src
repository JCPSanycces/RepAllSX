#**
#* Purpose: Gets an XML file as a Clbfile and a JSON transformation description as a Clbfile
#*          and returns the transformed data as CSV file in a Clbfile
#*
#* @param RESHEAD     Stream that contains the javascript result header
#* @param RESBODY     Stream that contains the javascript result body
#* @param INPXML      Stream containing the XML file to transform
#* @param INPTRANSF   Stream containing the JSON transformation description
#*!
# Note: We use the same parameter names used in the web service to make clear which parameter is
#       meant when we send it to web service.
#
Funprog X3XMLTRANS( RESHEAD, RESBODY , INPXML, INPTRANSF )
Variable Clbfile RESHEAD      # Stream that contains the javascript result header
Variable Clbfile RESBODY      # Stream that contains the javascript result body
Variable Clbfile INPXML
Variable Clbfile INPTRANSF
    Local Integer STATUSCODE
    Local Clbfile PARAMS

    PARAMS = '"' + escJson( INPXML ) + '","' + escJson( INPTRANSF ) + '"'
    STATUSCODE = func ASYRWEBSER.EXEC_JS(
&        "bundle-sage-camt/lib/xmlfilt",
&        "x3XmlTrans",
&        "sync",
&        PARAMS,
&        "",
&        0, "", "0", RESHEAD, RESBODY )
    If STATUSCODE = 200
# TODO (DNE): Reset to origin after correction of SAM #122244.
# 2017-03-30 DNE MODIF BEGIN (Workarount because of SAM #122244)
        Local Integer N : N = fix( ln( ( len( RESBODY ) + 4.0 ) / 512.0 ) / ln( 2 ) + 1 )
        Local Clbfile RESBODY2(N)

        RESBODY2 = RESBODY
        RESBODY = unescJson( RESBODY2 )
# 2017-03-30 DNE MODIF ORIG
#        RESBODY = unescJson( RESBODY )
# 2017-03-30 DNE MODIF END
    Endif
End STATUSCODE


#**
#* Purpose: Gets an XML file as a Clbfile and a JSON transformation description as a Clbfile
#*          and returns the transformed data as a multiline CSV ClbFile.
#*
#* @param RESHEAD     Stream that contains the javascript result header
#* @param RESBODY     Stream that contains the javascript result body
#* @param INPXML      Stream containing the XML file to transform
#* @param INPTRANSF   Stream containing the JSON transformation description
#*!
# Note: We use the same parameter names used in the web service to make clear which parameter is
#       meant when we send it to web service.
#
Funprog X3XMLTRANSMULTILINE( RESHEAD, RESBODY, INPXML, INPTRANSF )
Variable Clbfile RESHEAD      # Stream that contains the javascript result header
Variable Clbfile RESBODY      # Stream that contains the javascript result body
Variable Clbfile INPXML
Variable Clbfile INPTRANSF
    Local Integer STATUSCODE
    Local Clbfile PARAMS

    PARAMS = '"' + escJson( INPXML ) + '","' + escJson( INPTRANSF ) + '","' + escJson( "1" ) + '"'
    STATUSCODE = func ASYRWEBSER.EXEC_JS(
&        "bundle-sage-camt/lib/xmlfilt",
&        "x3XmlTransMultiline",
&        "sync",
&        PARAMS,
&        "",
&        0, "", "0", RESHEAD, RESBODY )
    If STATUSCODE = 200
# TODO (DNE): Reset to origin after correction of SAM #122244.
# 2017-03-30 DNE MODIF BEGIN (Workarount because of SAM #122244)
        Local Integer N : N = fix( ln( ( len( RESBODY ) + 4.0 ) / 512.0 ) / ln( 2 ) + 1 )
        Local Clbfile RESBODY2(N)

        RESBODY2 = RESBODY
        RESBODY = unescJson( RESBODY2 )
# 2017-03-30 DNE MODIF ORIG
#        RESBODY = unescJson( RESBODY )
# 2017-03-30 DNE MODIF END
    Endif
End STATUSCODE


#**
#* Purpose: Returns the version of the XML transformation (Camt) JS bundle
#*!
Funprog X3XMLTRANSVERSION()
    Local Clbfile RESHEAD      # Stream that contains the javascript result header
    Local Clbfile RESBODY      # Stream that contains the javascript result body
    Local Integer STATUSCODE

    STATUSCODE = func ASYRWEBSER.EXEC_JS(
&        "bundle-sage-camt/lib/xmlfilt",
&        "x3XmlTransVersion",
&        "sync",
&        "",
&        "",
&        0, "", "0", RESHEAD, RESBODY )
    If STATUSCODE = 200
        End val( unescJson( RESBODY ) )
    Endif
End -1


#**
#* Purpose: Read a file's content in a Clbfile variable.
#*
#* @param FILNAM     Name of the file to read
#* @param CLOB       Clbfile containing the file content
#*!
Subprog READCLOB( FILNAM, CLOB )
Value Char FILNAM
Variable Clbfile CLOB

    Local Clbfile LINE

    CLOB = ""
    If filinfo( FILNAM, 0 ) > 0
        Openi FILNAM Using [RC]
        adxium = 0 # UTF-8
        While 1
            Rdseq LINE Using [RC]
            Append CLOB, LINE
            Break ( fstat <> 0 )
        Wend
        Openi Using [RC]
    Endif
End


#**
#* Purpose: Read a file's content in a Clbfile variable and return filesize.
#*
#* @param FILNAM     Name of the file to read
#* @param CLOB       Clbfile containing the file content
#*!
Subprog WRITECLOB( FILNAM, CLOB )
Value Char FILNAM
Variable Clbfile CLOB

    Openo FILNAM, 0 Using [WC]
    adxium = 0 # UTF-8
    adxifs = ""
    adxirs = ""

    # Write clob to text file.
    Wrseq CLOB Using [WC]

    # Close text file.
    Openo Using [WC]
End

