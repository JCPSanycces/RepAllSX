& + '    { "level": 3, "path":  ".Amt",                          "value": "$value"            },'
& + '    { "level": 3, "path":  ".Amt",                          "value": "$.Ccy"             },'
& + '    { "level": 3, "path":  "",                              "value": "CdtDbtInd"         },'
& + '    { "level": 3, "path":  ".NtryDtls[]",                   "value": ""                  },'
& + '    { "level": 4, "path":  ".TxDtls[]",                     "value": ""                  },'
& + '    { "level": 5, "path":  ".Amt",                          "value": "$value"            },'
& + '    { "level": 5, "path":  ".Amt",                          "value": "$.Ccy"             },'
& + '    { "level": 5, "path":  "",                              "value": "CdtDbtInd"         },'
& + '    { "level": 5, "path":  ".Refs",                         "value": "AcctSvcrRef"       }'
& + ']'

FILEPATH = func AVOLUME_CSTD._GETFULLPATH( QVOLUME.ROOT, "BSILIBXMLTRA.JSON" )
Call WRITECLOB( FILEPATH, INPTRANSF )

STATUSCODE = func X3XMLTRANSMULTILINE( RESHEAD, RESBODY, INPXML, INPTRANSF )
If STATUSCODE = 200
    FILEPATH = func AVOLUME_CSTD._GETFULLPATH( QVOLUME.ROOT, "BSILIBXMLTRA.CSV" )
    Call WRITECLOB( FILEPATH, RESBODY )
Else
    Infbox num$( STATUSCODE )
    Infbox RESHEAD
    Infbox RESBODY
Endif
End
