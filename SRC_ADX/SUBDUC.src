#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du fichier PRMDUCS
Raz GPILOBJ
Call OBJET("DUC",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LIENS"    : Gosub LIENS
 When "SETBOUT"  : Gosub SETBOUT
 When "VERF_ANU" : Gosub VERF_ANU    
Endcase
Return

$OUVRE
If clalev([F:DUC])=0 : Local File PRMDUCS   [DUC] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
Return

$SETBOUT
#Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR  CHAINE+="A"  Endif
Return

$VERF_ANU
Trbegin [DUC]
 Delete [DUC] Where CPY=[M:DUC0]CPY & CAI=[M:DUC0]CAI
 If fstat = 1  : # enreg locké
  GLOCK = "$PRMDUCS" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard 
Return

$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

$AB_ANN
Rollback
Return

$LIENS
Local Integer VIDENT

VIDENT=[F:DUC]CAI
VIDENT=[F:DUC]KEYSEN
Call AM_KEYSEN(VIDENT)

VIDENT=[F:DUC]KEYDCL
Call AM_KEYDCL(VIDENT)

VIDENT=[F:DUC]KEYRPB
Call AM_KEYRPB(VIDENT)

VIDENT=[F:DUC]FLGEXT
Call AM_FLGEXT(VIDENT)

Call AM_FCYSEN([F:DUC]FCYSEN)
Call AM_FCYDCL([F:DUC]FCYDCL)
Call AM_FCYRPB([F:DUC]FCYRPB)

Return

#********************************************************************************
#                        ETIQUETTES ECRAN 
#********************************************************************************

########################################
Subprog AM_FCYSEN(VALEUR)
Variable Char    VALEUR()
Call INFO_SITE(VALEUR,[M:DUC1]CRNFCYSEN, [M:DUC1]CRYFCYSEN)
Affzo [M:DUC1]CRNFCYSEN
End

########################################
Subprog AS_FCYDCL(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Read[F:CPY]CPY0=[M:DUC0]CPY
 If !fstat  
  VALEUR=[F:CPY]MAIFCY
 Endif
Endif
End

########################################
Subprog AM_FCYDCL(VALEUR)
Variable Char    VALEUR()
Call INFO_SITE(VALEUR,[M:DUC1]CRNFCYDCL, [M:DUC1]CRYFCYDCL)
Affzo [M:DUC1]CRNFCYDCL
End

########################################
Subprog AS_FCYRPB(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : VALEUR=[M:DUC1]FCYDCL : Endif
End

########################################
Subprog AM_FCYRPB(VALEUR)
Variable Char    VALEUR()
Call INFO_SITE(VALEUR,[M:DUC1]CRNFCYRPB, [M:DUC1]CRYFCYRPB)
Affzo [M:DUC1]CRNFCYRPB
End

########################################
Subprog AS_FCYSEN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : VALEUR=[M:DUC1]FCYDCL : Endif
End

########################################
Subprog AM_KEYSEN(VALEUR)
Variable Integer VALEUR
If VALEUR=3
 Actzo [M:DUC1]LIBKEYSEN
Else
 Effzo [M:DUC1]LIBKEYSEN
 Grizo [M:DUC1]LIBKEYSEN
Endif
End

########################################
Subprog AM_KEYDCL(VALEUR)
Variable Integer VALEUR
If VALEUR=3
 Actzo [M:DUC1]LIBKEYDCL
Else
 Effzo [M:DUC1]LIBKEYDCL
 Grizo [M:DUC1]LIBKEYDCL
Endif
End

########################################
Subprog AM_KEYRPB(VALEUR)
Variable Integer VALEUR
If VALEUR=3
 Actzo [M:DUC1]LIBKEYRPB
Else
 Effzo [M:DUC1]LIBKEYRPB
 Grizo [M:DUC1]LIBKEYRPB
Endif
End

########################################
Subprog INFO_SITE(FCY, SIRET, PAYS)
Value Char FCY ()
Variable Char SIRET ()
Variable Char PAYS ()
Read [F:FCY]FCY0=FCY
If fstat=0
 SIRET=[F:FCY]CRN
 PAYS=[F:FCY]CRY
Else
 SIRET=""
 PAYS=""
Endif
If SIRET=""
 Local Integer OK
 OK=2
 Call AVERTIR(mess(5,10705,1)-FCY,OK) From GESECRAN
Endif
End

########################################
Subprog AM_FLGEXT(VALEUR)
Variable Integer VALEUR
If VALEUR=2 
 Actzo [M:DUC2]
 Call AM_KEYEXT([M:DUC2]KEYEXT)
Else
 Effzo [M:DUC2] : Grizo [M:DUC2]
 Actzo [M:DUC2]FLGEXT
Endif
End

########################################
Subprog AM_KEYEXT(VALEUR)
Variable Integer VALEUR
If VALEUR=3
 Actzo [M:DUC2]LIBKEYEXT
 Effzo [M:DUC2]CRNEXT : Grizo [M:DUC2]CRNEXT
Else
 Effzo [M:DUC2]LIBKEYEXT : Grizo [M:DUC2]LIBKEYEXT
 Actzo [M:DUC2]CRNEXT 
Endif
End

########################################
Subprog AV_CRNEXT(VALEUR)
Variable Char    VALEUR()
If [M:DUC2]FLGEXT<>2 |[M:DUC2]KEYEXT=3
 Grizo [M:DUC2]CRNEXT
Else
 Actzo [M:DUC2]CRNEXT
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran PRMDUCS0) 21/09/2010 16:30:52 (DBA)
######################################################################################
Subprog AS_CAI(VALEUR)
Variable Integer VALEUR
GMENLOC(8)=1
End


