#<AdxTL>@(#)7.0.0.0 $Revision$
###################################################################################
## Initialisation du champ CSLC (code partenaire) dans les transactions de saisie
## à la valeur invisible
###################################################################################
Call MAJ_UTICPT25    
End

Subprog MAJ_UTICPT25

Local Char DOSSIER(30) : DOSSIER=nomap
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTICPT25:"-"Field CLSD Update (GDIAENTRYD Table)") From LECFIC
Call SAIDOS(DOSSIER,"UTICPT25") From SAIDOS
If DOSSIER<>"" Call EXE_UTICPT25(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End


Subprog EXE_UTICPT25(APPLI)
Value Char APPLI
Local Integer OK
If filinfo(filpath("FIL","GDIAENTRY","fde",APPLI),0) < 0 : End : Endif
If filinfo(filpath("FIL","GDIAENTRYD","fde",APPLI),0) < 0 : End : Endif
If clalev([F:GDE])=0 : Local File =APPLI+".GDIAENTRY"  [GDE] : Endif
If clalev([F:GDD])=0 : Local File =APPLI+".GDIAENTRYD" [GDD] : Endif

Call ECR_TRACE("UTICPT25: Process Start on : "+APPLI,0) From GESECRAN

Call DEBTRANS From GLOCK
Gosub TR_UTICPT25
Call ECR_TRACE("UTICPT25: Process End on : "+APPLI,0) From GESECRAN
End


#### Corps de la moulinette - début
$TR_UTICPT25
Trbegin [GDE], [GDD]
 For [GDE]DIA
  Read [GDD]GDD0 = [F:GDE]DIA;"CSLC"
  If !fstat
   [F:GDD]DAC = 3
   Rewrite [GDD]
   If fstat
    GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"GDIAENTRYD"-":"-[F:GDD]DIA-[F:GDD]FLD,1) From GESECRAN
    Break
   Endif
  Elsif fstat
   [F:GDD]DIA = [F:GDE]DIA
   [F:GDD]FLD = "CSLC"
   [F:GDD]DAC = 3
   [F:GDD]CRD = 1   
   Write [GDD]
   If fstat
    GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"GDIAENTRYD"-":"-[F:GDD]DIA-[F:GDD]FLD,1) From GESECRAN
    Break
   Endif
  Endif
 Next
 If !GOK : Goto AB_UTICPT25 : Endif
Commit
Return


$AB_UTICPT25
Rollback
Return 

#### Corps de la moulinette - fin 

Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_UTICPT25(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTICPT25(APPLI)
End
