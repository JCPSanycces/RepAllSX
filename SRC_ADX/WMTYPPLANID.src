#<AdxTL>@(#)0.0.0.0 $Revision$Class Non-conformance plan
# Supervisor
## ATY-ATYPE ## PLANID
# 2018-11-09 07:14:54 985

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,PLANID,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char PLANID
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File PLANHDR [PLAHDR]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".PLANHDR" [PLAHDR]
Endif

Default File [F:PLAHDR]
Read [F:PLAHDR]PLAHDR_0 = [L]PLANID
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]PLANID)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]PLANID)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


