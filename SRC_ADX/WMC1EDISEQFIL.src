[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_KEYALIAS
Gosub DECLARE_VAR From WMC0EDISEQFIL
[L]CURPRO = "KEYALIAS"
$_LNKPRO_KEYALIAS
If vireblc(this.KEYALIAS,2)<>""
 # Link ASHWEXPPRO
 Local File ASHWEXPPRO [WASWR]
 Read [F:WASWR]ASWR0 = this.REPCOD;this.KEYALIAS
 If !fstat
  Local File ATEXTE [WATX]
  For [F:WATX] Where NUMERO=[F:WASWR]INTPRO & LAN=this.ACTX.LAN
   [L]ASTATUS = fmet this.ASETATTRIBUTE("KEYALIAS","$description",[WATX]TEXTE)
  Next WATX
  LogicClose File [WATX]
 Endif
 LogicClose File [WASWR]
Endif
Return


