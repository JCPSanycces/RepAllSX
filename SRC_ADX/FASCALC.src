#<AdxTL>@(#)1.0.0.0 $Revision$


################################################################################
#    CALCUL SOCIETE AMORTISSEMENTS
#    Création le :
#    Modification le :
#
#    MWA - 16.05.2018 - FQ89794   Wrong definition of the site
#    GLE - 06.03.2013 - FQ97426   Changement de la gestion des licences
#    MWA - 15.04.2013 - FQ88613   Forcer recalcul
#    MWA - 01.04.2012 - FQ77877   Roumanie
#
################################################################################
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM

Local Char VALBOUT(30)
Local Char PARBOUT(250)(1..10)
VALBOUT = "12"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","FASCALC","DFASCALC",3, "") From GTRAITE
End

################################################################################
$ACTION
  #If GUSER="MWA" : Infbox "ACTION = "-num$(ACTION) : Endif
  Case ACTION
    When "OUVRE_BATCH"      : Gosub OUVRE_BATCH
    When "INIT"             : Gosub INIT
    When "INIT_DIA"         : Gosub INIT_DIA
    When "CONTROLE"         : Gosub CONTROLE
    When "CONT_BATCH"       : Gosub CONT_BATCH
    When "EXEC"             : Gosub EXEC
    When "TERMINE"          : Gosub TERMINE
    When Default
  Endcase
Return
################################################################################

#-------------------------------------------------------------------------------
$OUVRE_BATCH
 # Action  ( Saisie - Batch )
  # -- Ouverture des fichiers
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif
  If clalev([F:CNX]) = 0 : Local File CONTEXT     [CNX]  : Endif
  If clalev([F:FIS]) = 0 : Local File FISCYEAR    [FIS]  : Endif
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif
Return

#-------------------------------------------------------------------------------
$INIT
  # Action - ( Standard & Execution - Batch)
  # Vérification qu'au moins un contexte existe dans le sossier
  # ------------------
  If (func FASCALC.CALCUL_POSSIBLE()) Then
    # Aucun contexte dans ce dossier
    Errbox mess(123,7774,1)
    # Arrêt du calcul
    FIN=1
    Return
  Endif
  # ------------------
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif
  If clalev([F:CNX]) = 0 : Local File CONTEXT     [CNX]  : Endif
  If clalev([F:FIS]) = 0 : Local File FISCYEAR    [FIS]  : Endif
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif
Return

#-------------------------------------------------------------------------------
$AVANT_PAR

  # Action - Traitement ( Standard & Saisie et Execution - Batch)

Return

#-------------------------------------------------------------------------------
$INIT_DIA
  # Action - Traitement ( Standard & Saisie et Execution - Batch)
  Local Integer BCLOFIL

  #-- Pour interactif
  Global Integer GCURCPY            : # -- Indice société cliquée

  GOK=1

  # Chargement & affichage de la fenêtre de dialogue
  Gosub CHARGE_MASQUE_G

Return

#-------------------------------------------------------------------------------
$CHARGE_MASQUE_G

Local Integer LAUTORISEE  : # Utilisateur habilité pour au moins un site de la société
Local Integer LCONTEXTE   : # Au moins un contexte défini pour la société
Local Integer N_S, N_E, N_C, N_E_DEB, N_C_DEB

  #------------------------------
  N_S = 1
  N_E = 1
  N_C = 1
  N_E_DEB = 1
  N_C_DEB = 1

  # FQ88613
  [M:FASC]FLGFASCLC = G_NON
  # >>>>>>>
  For [CPY]CPY0
    LAUTORISEE = 0
    #-1 -----------------------------
    # Société juridique
    If ( [F:CPY]CPYLEGFLG = 2 ) Then
      Read [CNX]CNX0=[F:CPY]CPY
      If ( fstat ) Then : LCONTEXTE = 0 :  Else : LCONTEXTE = 1 : Endif

      #-2 -----------------------------
      If (LCONTEXTE) Then
      # Au moins un contexte pour la société
        # Pour tous les Etablissements financier de la société
        Filter [FCY] Where ( LEGCPY = [F:CPY]CPY and FINFLG = G_OUI)
        # >>>>>>>
        For [FCY]FCY1
          # Utilisateur habilité à la fonction pour le site
          #-3 -----------------------------
          If ( GUSRFCY(1) = "\" or find([F:FCY]FCY, GUSRFCY(1..GNBAUZ)) ) Then
            LAUTORISEE = 1
            # -- Etablissement
            [M:FASC]FCYG       (N_E-1)  = [F:FCY]FCY
            [M:FASC]FLGCLCFCYG (N_E-1)  = G_NON
            N_E += 1
          Endif
          #-3 -----------------------------
        Next FCY1
        # >>>>>>>
        Filter [FCY]

        #-3 -----------------------------
        If ( LAUTORISEE ) Then

          # -- Contextes
          # >>>>>>
          For [CNX]CNX0 Where CPY=[F:CPY]CPY
            Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
            Read [FIS]FIY0 First
            Filter [FIS]
            [M:FASC]FLGCLCCNXG(N_C-1)   = G_NON
            [M:FASC]DATSTRFIYG(N_C-1)   = [F:FIS]DATSTRFIY
            [M:FASC]CNXG(N_C-1)         = [F:CNX]CNX
            [M:FASC]DATSTRPERG(N_C-1)   = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
            N_C += 1
          Next CNX0
          # >>>>>>

          # -- Société
          [M:FASC]FLGCLCCPY  (N_S-1) = G_NON
          [M:FASC]CPY        (N_S-1) = [F:CPY]CPY
          [M:FASC]FCYDEB     (N_S-1) = N_E_DEB
          [M:FASC]FCYFIN     (N_S-1) = N_E-1
          [M:FASC]CNXDEB     (N_S-1) = N_C_DEB
          [M:FASC]CNXFIN     (N_S-1) = N_C-1
          N_E_DEB = N_E
          N_C_DEB = N_C

          N_S +=1
        Endif
        #-3 -----------------------------
      Endif
      #-2 -----------------------------
    Endif
    #-1 -----------------------------

  Next CPY0
  # >>>>>>>

  #------------------------------
  [M:FASC]NBCPY  = N_S-1
  [M:FASC]NBFCYG = N_E-1
  [M:FASC]NBCNXG = N_C-1
  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCPY")  From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBFCYG") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCNXG") From GLOBIENS
  #------------------------------
  GCURCPY        = 1
  Call AFFICHE_G_EN_S (GCURCPY)
  #------------------------------
Return

#-------------------------------------------------------------------------------
$CONTROLE

  # Action - Traitement ( Standard & Execution - Batch)

  Call AFFICHE_S_EN_G (GCURCPY)
  #-------------------------
  # Désélection des sociétés qui n'ont aucun site ou aucun contexte à calculer
  # Contrôle qu'au moins une société est à calculer
  Gosub CTRL_CALCUL

Return

#-------------------------------------------------------------------------------
$CONT_BATCH

  # Action - Traitement ( Saisie - Batch)

  Call AFFICHE_S_EN_G (GCURCPY)
  #-------------------------
  # Désélection des sociétés qui n'ont aucun site ou aucun contexte à calculer
  # Contrôle qu'au moins une société est à calculer
  Gosub CTRL_CALCUL
  #-------------------------
  If ( dim([M:FASC]NBCPY) > 0 ) Then
    If ( GERR = 0 ) Then
      # Suppression du masque de toutes les infos des sociétés non sélectionnées
      Gosub EPURATION_MASQUE_G
    Endif
  Endif

  # 1ere ligne
  Call AFFICHE_G_EN_S (1)

Return

#-------------------------------------------------------------------------------
$EXEC

  # Action - Traitement ( Standard & Execution - Batch)
  Call TEMPON('C') From GESECRAN
  Gosub CALCULER_SOCIETES

  FIN = 0
Return

#-------------------------------------------------------------------------------
$TERMINE

  # Action - Traitement ( Standard & Execution - Batch)
  Call TEMPOFF() From GESECRAN

  # -- Interactif
  If (dim(GCURCPY)>0) Then : Kill GCURCPY : Endif  : # -- Indice société cliquée

Return

#-------------------------------------------------------------------------------
$EPURATION_MASQUE_G


 # Recherche et suppression des informations de toutes les sociétés non sélectionnées
 # ???? Il faudrait pouvoir toujours conserver la première.

 Local Integer I_CPY, N_I
 Local Integer FINI

 FINI=G_NON
 # >>>>
 Repeat
  I_CPY = find (G_NON,[M:FASC]FLGCLCCPY(1..[M:FASC]NBCPY))
  If ( I_CPY=0 ) Then
    FINI=G_OUI
  Else
    I_CPY +=1  : # A faire car on traite pas la 1ère société
    Gosub SUP_CPY
  Endif
 Until FINI=G_OUI
 # <<<<

Return

#---
$SUP_CPY

 Local Integer NBCNXSUP
 Local Integer NBFCYSUP

 #Infbox "Suppression de la société :"-[M:FASC]CPY(I_CPY-1)

 # Calcul du nombre de lignes Contexte à supprimer dans G
 NBCNXSUP = [M:FASC]CNXFIN(I_CPY-1)- [M:FASC]CNXDEB(I_CPY-1) +1
 # Suppression des lignes Contextes dans  G
 Dela [M:FASC]CNXDEB(I_CPY-1)-1, NBCNXSUP, [M:FASC]NBCNXG-1 [M:FASC]NBCNXG
 [M:FASC]NBCNXG -= NBCNXSUP


 # Calcul du nombre de lignes Sites à supprimer dans G
 NBFCYSUP = [M:FASC]FCYFIN(I_CPY-1)- [M:FASC]FCYDEB(I_CPY-1) +1
 # Suppression des lignes Sites dans  G
 Dela [M:FASC]FCYDEB(I_CPY-1)-1, NBFCYSUP, [M:FASC]NBFCYG-1 [M:FASC]NBFCYG
 [M:FASC]NBFCYG -= NBFCYSUP

 # Suppression dans le tableau Société
 # A faire impérativement après la suppression des sites et des contextes
 Dela I_CPY-1, 1, [M:FASC]NBCPY-1 [M:FASC]NBCPY
 [M:FASC]NBCPY -= 1


 # Mise à jour des CNXDEB,CNXFIN & FCYDEB,FCYFIN dans le tableau Société
 For N_I= I_CPY To [M:FASC]NBCPY
  [M:FASC]CNXDEB(N_I-1) -= NBCNXSUP
  [M:FASC]CNXFIN(N_I-1) -= NBCNXSUP
  [M:FASC]FCYDEB(N_I-1) -= NBFCYSUP
  [M:FASC]FCYFIN(N_I-1) -= NBFCYSUP
 Next N_I

Return

#-------------------------------------------------------------------------------
$CTRL_CALCUL

Local Integer N_S, N_I, NBCNXCLC, NBFCYCLC, NBCPYCLC

  NBCPYCLC = 0

  # >>>>>>>>>>>>>>
  For N_S = 1 To [M:FASC]NBCPY
    #-1 ---------------------------
    If [M:FASC]FLGCLCCPY(N_S-1) = G_OUI Then
      NBCNXCLC = 0
      For N_I = [M:FASC]CNXDEB(N_S-1) To [M:FASC]CNXFIN(N_S-1)
        If ( [M:FASC]FLGCLCCNXG(N_I-1) = G_OUI ) Then
          NBCNXCLC += 1
        Endif
      Next N_I
      #-2 ---------------------------
      If ( NBCNXCLC = 0 ) Then
        # 52 La société
        # 53 n'a pas de contexte à calculer. Elle est désélectionnée.
        Call MESSAGE (mess(52,7774,1)-num$([M:FASC]CPY(N_S-1))-mess(53,7774,1)) From GESECRAN
        [M:FASC]FLGCLCCPY (N_S-1) = G_NON
        Affzo [M:FASC]FLGCLCCPY (N_S-1)
      Else
      #-2 ---------------------------
        NBFCYCLC = 0
        For N_I = [M:FASC]FCYDEB(N_S-1) To [M:FASC]FCYFIN(N_S-1)
          If ( [M:FASC]FLGCLCFCYG(N_I-1) = G_OUI ) Then
            NBFCYCLC += 1
          Endif
        Next N_I
        #-3 ---------------------------
        If ( NBFCYCLC = 0 ) Then
          # 52 La société
          # ?? n'a pas de site à calculer. Elle est désélectionnée.
          Call MESSAGE (mess(52,7774,1)-num$([M:FASC]CPY(N_S-1))-
&         "n'a pas de site à calculer. Elle est désélectionnée." ) From GESECRAN
          [M:FASC]FLGCLCCPY (N_S-1) = G_NON
          Affzo [M:FASC]FLGCLCCPY (N_S-1)
        Else
        #-3 ---------------------------
          NBCPYCLC += 1
        Endif
        #-3 ---------------------------
      Endif
      #-2 ---------------------------
    Endif
    #-1 ---------------------------
  Next N_S
  # >>>>>>>>>>>>>>

  #------------------------------
  If ( NBCPYCLC = 0 ) Then
    GMESSAGE = mess(54,7774,1) : # Aucune société n'est à calculer !
    FIN      = 0
    GERR     = 1
  Endif
  #------------------------------

Return



########################################
Subprog AFFICHE_G_EN_S (PIND)
# Affiche les sites et les contextes de la Société sélectionnée dans le tableau visible
#
Value Integer PIND
Local Integer N_I, N_C, N_E

  # -------------
  # -- Sites
  # -------------

  # -- Réinitialisation tableau Sites de la Société
  [M:FASC]NBFCY = 0
  Call ACTION_BLOCK (ACB_EFFZO, "FASCALC", "NBFCY") From GLOBIENS

  N_E = 1

  #------------------------------
  For N_I = [M:FASC]FCYDEB(PIND-1) To [M:FASC]FCYFIN(PIND-1)
    [M:FASC]FLGCLCFCY(N_E-1) = [M:FASC]FLGCLCFCYG  (N_I-1)
    [M:FASC]FCY      (N_E-1) = [M:FASC]FCYG        (N_I-1)
    [M:FASC]INDRETFCY(N_E-1) = N_I
    N_E += 1
  Next N_I
  #------------------------------
  [M:FASC]NBFCY = N_E-1
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBFCY") From GLOBIENS


  # -------------
  # -- Contextes
  # -------------
  # -- Réinitialisation tableau Contextes de la Société
  [M:FASC]NBCNX = 0
  Call ACTION_BLOCK (ACB_EFFZO, "FASCALC", "NBCNX") From GLOBIENS

  N_C = 1
  #------------------------------
  For N_I = [M:FASC]CNXDEB(PIND-1) To [M:FASC]CNXFIN(PIND-1)
    [M:FASC]FLGCLCCNX(N_C-1) = [M:FASC]FLGCLCCNXG   (N_I-1)
    [M:FASC]CNX      (N_C-1) = [M:FASC]CNXG         (N_I-1)
    [M:FASC]DATSTRFIY(N_C-1) = [M:FASC]DATSTRFIYG   (N_I-1)
    [M:FASC]DATSTRPER(N_C-1) = [M:FASC]DATSTRPERG   (N_I-1)
    [M:FASC]INDRETCNX(N_C-1) = N_I
    N_C += 1
  Next N_I
  #------------------------------
  [M:FASC]NBCNX = N_C-1
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCNX") From GLOBIENS
  #------------------------------
End


########################################
Subprog AFFICHE_S_EN_G (PIND)
# renvoi les contextes et les sites modifiés de la société sélectionnée dans le tableau invisible

Value Integer PIND

Local Integer N_I, N_C, N_E

  # -------------
  # -- Sites
  # -------------
  # >>>>>>>
  For N_I = 1 To [M:FASC]NBFCY
    N_E = [M:FASC]INDRETFCY(N_I-1)
    [M:FASC]FLGCLCFCYG(N_E-1)  = [M:FASC]FLGCLCFCY(N_I-1)
  Next N_I
  # <<<<<<<
  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBFCYG") From GLOBIENS
  #------------------------------
  # -------------
  # -- Contextes
  # -------------
  # >>>>>>>
  For N_I = 1 To [M:FASC]NBCNX
    N_C = [M:FASC]INDRETCNX(N_I-1)
    [M:FASC]FLGCLCCNXG(N_C-1)  = [M:FASC]FLGCLCCNX   (N_I-1)
  Next N_I
  # <<<<<<<
  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCNXG") From GLOBIENS
  #------------------------------
End

#########################################################
Funprog CALCUL_POSSIBLE()
# - Objet  : Renvoie 1 si au moins un contexte est déini dans le dossier.
#
# - Entrée :
#
# - Sortie : 0 Pas de contexte défini
#            1 Au moins un contexte est défini dans le dossier
#
#

Local Integer CDRET  : CDRET =0
  If clalev([F:CNX]) = 0 : Local File CONTEXT [CNX]  : Endif
  Read [CNX]CNX0 First
  If ( fstat ) Then : CDRET = 1 : Endif
End CDRET


################################################################################
# Gestion du masque FASCALC
# Ecran -- FASC --
################################################################################
########################################
Subprog AS_NBCPY

Local Integer N_I
Local Integer N_TROUVE

  Call AFFICHE_S_EN_G (GCURCPY)
  #------------------------------
  If ( nolign-1 < [M:FASC]NBCPY ) Then
    # On reçoit quelque chose lorqu'on passe la dernière ligne
    # Pas d'affectation quand on est sur la dernière ligne
    GCURCPY = nolign
    Call AFFICHE_G_EN_S (GCURCPY)
  Endif
  #------------------------------

End


########################################
Subprog AM_FLGCLCCPY(VALEUR)
Variable Integer VALEUR

 #-------------------------------
 If ( VALEUR <> G_OUI ) Then
   # -------------
   # -- Sites
   # -------------
   # >>>>>>>
   For N_I = 1 To [M:FASC]NBFCY
     [M:FASC]FLGCLCFCY(N_I-1)  = G_NON
   Next N_I
   # <<<<<<<
   #------------------------------
   Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBFCY") From GLOBIENS
   #------------------------------
   # -------------
   # -- Contextes
   # -------------
   # >>>>>>>
   For N_I = 1 To [M:FASC]NBCNX
     [M:FASC]FLGCLCCNX(N_I-1)  = G_NON
   Next N_I
   # <<<<<<<
   #------------------------------
   Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCNX") From GLOBIENS
   #------------------------------
 Endif
 #-------------------------------

 #--
 Call AFFICHE_S_EN_G (GCURCPY)

End


########################################
Subprog C_FLGCLCCPY(VALEUR)
Variable Integer VALEUR

End


########################################
Subprog B1_NBCPY

# Bouton "Toute la société"

  # Contrôle uniquement si le champ passe à G_OUI
  If ([M:FASC]FLGCLCCPY(GCURCPY-1) <> G_OUI ) Then
  Call C_FLGCLCCPY(G_OUI)
  Endif
  #------------------------------
  If (!GERR) Then
    Local Integer N_I
    # -------------
    # -- Société
    # -------------
    [M:FASC]FLGCLCCPY(nolign-1)  = G_OUI
    #------------------------------
    Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCPY") From GLOBIENS
    # -------------
    # -- Sites
    # -------------
    # >>>>>>>
    For N_I = 1 To [M:FASC]NBFCY
      [M:FASC]FLGCLCFCY(N_I-1)  = G_OUI
    Next N_I
    # <<<<<<<
    #------------------------------
    Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBFCY") From GLOBIENS
    #------------------------------
    # -------------
    # -- Contextes
    # -------------
    # >>>>>>>
    For N_I = 1 To [M:FASC]NBCNX
      [M:FASC]FLGCLCCNX(N_I-1)  = G_OUI
    Next N_I
    # <<<<<<<
    #------------------------------
    Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCNX") From GLOBIENS
    #------------------------------
  Endif
  #------------------------------

  #--
  Call AFFICHE_S_EN_G (GCURCPY)

End

########################################
Subprog B2_NBCPY

# Bouton "La société et les suivantes"

Local Integer N_I, N_S, N_C, N_E, N_Z

  #------------------------- TOUTES SOCIETES
  #-- Sociétés
  # >>>>>>>>>>>>>>
  For N_S = GCURCPY To [M:FASC]NBCPY
    [M:FASC]FLGCLCCPY (N_S-1) = G_OUI
    #--  Sites
    For N_E = [M:FASC]FCYDEB (N_S-1) To [M:FASC]FCYFIN (N_S-1)
      [M:FASC]FLGCLCFCYG (N_E-1) = G_OUI
    Next N_E
    #-- Contextes
    For N_C = [M:FASC]CNXDEB (N_S-1) To [M:FASC]CNXFIN (N_S-1)
      [M:FASC]FLGCLCCNXG (N_C-1) = G_OUI
    Next N_C
  Next N_S
  # <<<<<<<<<<<<<<

  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCPY") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBFCYG") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCNXG") From GLOBIENS
  #------------------------------


  #------------------------- SOCIETE COURANTE
  Call AFFICHE_G_EN_S (GCURCPY)

End


########################################
Subprog B3_NBCPY

# Bouton "Toutes les sociétés"

Local Integer N_I, N_S, N_C, N_E, N_Z

  #------------------------- TOUTES SOCIETES
  #-- Sociétés
  # >>>>>>>>>>>>>>
  For N_S = 1 To [M:FASC]NBCPY
    [M:FASC]FLGCLCCPY (N_S-1) = G_OUI
    #------------------------------------
    #--  Sites
    For N_E = [M:FASC]FCYDEB (N_S-1) To [M:FASC]FCYFIN (N_S-1)
      [M:FASC]FLGCLCFCYG (N_E-1) = G_OUI
    Next N_E
    #-- Contextes
    For N_C = [M:FASC]CNXDEB (N_S-1) To [M:FASC]CNXFIN (N_S-1)
      [M:FASC]FLGCLCCNXG (N_C-1) = G_OUI
    Next N_C
  Next N_S
  # <<<<<<<<<<<<<<

  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCPY") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBFCYG") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASCALC", "NBCNXG") From GLOBIENS
  #------------------------------


  #------------------------- SOCIETE COURANTE
  Call AFFICHE_G_EN_S (GCURCPY)

End


#-------------------------------------------------------------------------------
$CALCULER_SOCIETES

# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#  A maintenir en parallèle
#  SIMULER_SOCIETES de FASSIMU
#  CALCULER_SOCIETES de FASCALC
#  CALCULER_BIEN     de GLOBB0
#  SIMULER_CALCUL_BIEN  de GLOBB
#  SIMULER_VALEUR_NETTE de GLOBB
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

Local Integer N_I, N_S, N_E, N_C
# Local Char    TABFCY(GLONCPY)(1..func AFNC.ACTIV("SIT"))  : # X3-89794
Local Char    TABFCY(GLONFCY)(1..func AFNC.ACTIV("SIT"))
Local Integer TABCNT(0..G300MAX-1)
Local Char    LCNBRTRY
Local Integer LNBRTRY
Local Decimal LCLCERR
Local Integer TCLCCPY(0..func AFNC.ACTIV("SOC"))
Local Integer TNBRTRY(0..func AFNC.ACTIV("SOC"))

Local Integer RTRN

  ############Call ACTIVE From TIMING

  # Heure de démarrage
  Global Integer G_TIMD     : G_TIMD = time

  #-- Ouverture écran CALDIV
  If clalev([M:DIV])=0  : Local Mask CALDIV     [DIV]  :  Endif             : # Infos diverses
  If clalev([M:DIV2])=0  : Local Mask CALDIV2    [DIV2]  :  Endif             : # Infos diverses FQ77877
  #--
  # Initialisation des constantes
  [M:DIV]CSTLVLMAX = 10
  [M:DIV]CSTFIYMAX = func AFNC.ACTIV("NFIY") : # FQ59941
  [M:DIV]DATNUL    = [0/0/0]
  [M:DIV]MNTNUL    = 0
  [M:DIV]DATFMT    = "D:" + GFMDAT4
  [M:DIV]TRTLVL    = 0                    : # -- Niveau atteint dans le traitement
  [M:DIV]BDEBUG    = 2                    : # Debug
  [M:DIV]TRTDEM    = "CALSOC"             : # -- Traitement demandeur


  # Ouverture du Compte-rendu
  # si GSERVEUR c'est le traitement batch lui-même qui ouvre la trace
  If ( !(GSERVEUR) and GTRACE = "" ) Then
    # La trace n'est pas déjà ouverte
    Call OUVRE_TRACE(mess(1,7774,1))  From LECFIC
  Endif
  Call ECR_TRACE(mess(61,7774,1),0) From GLOBB0   : # COMPTE RENDU TRAITEMENT DE CALCUL D'AMORTISSEMENTS

  #================
  # Gestionnaire d'erreurs
  Onerrgo KO From GLOBB0
  #================

  # FQ71297
  # Mise à jour "Nombre de biens gérés dans la solution"
  # pour contôle ultérieur par rapport aux termes de la licence
  Local Integer RERR
  Local Integer LFASCNT
  Call FASCNT(LFASCNT,RERR) From TRTLIC
  If ( RERR ) Then
    # Erreur dans la gestion du compteur de limite de licence. Traitement interrompu.
    # Contactez votre fournisseur.
    Call ECR_TRACE(mess(136,7770,1), 1) From GLOBB0
    Goto FIN_CALCULER_SOCIETES
  Endif
  # Contrôle dépassement du nombre maximum de biens gérés par la solution
  Local Integer LFASMAX  : # Nombre de biens accordés par la licence
  Local Integer LNBFAS   : # Nombre de biens gérés dans la solution
  Local Decimal LNIVDEP  : # Niveau de dépassement
  #--
  # Si Limite licence largement dépassée on interdit le calcul
  # Le nombre de biens est stocké dans le compteur NOMBCO
  #Call NOMBRE(1, LFASMAX) From GLOCK : # FQ97426
  LFASMAX = func TRTLIC.GET_FASMAX()  : # FQ97426
  LNBFAS = func TRTLIC.LEC_NOMBCO()
  NIVDEP = func TRTLIC.FASRAT(LFASMAX, LNBFAS)
  If ( NIVDEP = 2 ) Then
    Call ECR_TRACE(mess(111,7770,1)-mess(112,7770,1),1) From GLOBB0
    Goto FIN_CALCULER_SOCIETES
  Endif
  # FQ71297

  # Récupération du "Nom" des champs de l'écran CALDEP dans le tableau [M:DIV]TDFN
  # Il est dimensionné à 200 si dépassement, il faut modifier la dimension de [M:DIV]TDFN et LNBF ci-dessous
  Local Integer LNBF   : LNBF = 200
  Call CAL_LEC_CALDEP_FLD( LNBF, [M:DIV]TDFN, [M:DIV]NBF ) From GLOBB0
  If ([M:DIV]NBF > LNBF and GADONIX = 2) Then
    #-- Débordement du tableau contenant les champs de l'écran  CALDEP dans la fonction ( CAL_LEC_CALDEP_FLD)
    Call ECR_TRACE(mess(151,7774,1),1) From GLOBB0
    [M:DIV]NBF = 0
    Goto FIN_CALCULER_SOCIETES
  Endif

  # Evaluation du booleen Read avant Rewrite
  Call CMP_CALDEP_DEPREC_EQ (RTRN) From GLOBB0
  [M:DIV]BLECMAJ = !(RTRN)
  If ( [M:DIV]BLECMAJ ) Then
    # DEPREC & CALDEP ne sont pas en phase
    Call ECR_TRACE(mess(150,7774,1),1) From GLOBB0
  Endif

  # Nombre d'essais
  Call PARAM("","NBESSCLC",LCNBRTRY) From ADOVAL
  LNBRTRY = val(LCNBRTRY)
  If ( LNBRTRY < 0 ) Then : LNBRTRY = 0 : Endif

  # Initialisation TBNRTY, TCLCCPY
  For N_S = 1 To [M:FASC]NBCPY
    TCLCCPY(N_S-1)=G_NON
    If ([M:FASC]FLGCLCCPY(N_S-1)= G_OUI) Then : TCLCCPY(N_S-1)= G_OUI : TNBRTRY(N_S-1)= LNBRTRY : Endif
  Next N_S

  # FQ88613
  Local Integer PFASCLC : PFASCLC = [M:FASC]FLGFASCLC

  LCLCERR     = 0
  # >>>>>>>>>>>>>>>>
  Repeat
    LRETENTECLC = 0
    LNBSLEEP    = 0
    # >>>>>>>>>>>>>>>>
    For N_S = 1 To [M:FASC]NBCPY
      #-1 -----------------
      # Si la société est à calculer
      If ( TCLCCPY(N_S-1) = G_OUI ) Then
        # FQ70465 Contrôle synchronisation des contextes de la société à calculer avec Exercice/Périodes comptabilité
        If ( func GLOBIENS.IS_DESYNC_CNX([M:FASC]CPY(N_S-1), 0) = G_OUI ) Then
          # Contexte société désynchronisé
          Call ECR_TRACE(func GLOFUNC.SUBSTIT1(mess(272,7770,1), [M:FASC]CPY(N_S-1)),1) From GLOBB0
          Break 2
        Endif
        # Tableau des sites à calculer
        Raz TABFCY : N_I = 1
        For N_E = [M:FASC]FCYDEB(N_S-1) To [M:FASC]FCYFIN(N_S-1)
          If ([M:FASC]FLGCLCFCYG(N_E-1) = G_OUI) Then : TABFCY(N_I) = [M:FASC]FCYG(N_E-1) : N_I += 1 : Endif
        Next N_E
        # Tableau des contextes à calculer
        Raz TABCNT : N_I = 0
        For N_C = [M:FASC]CNXDEB(N_S-1) To [M:FASC]CNXFIN(N_S-1)
          If ([M:FASC]FLGCLCCNXG(N_C-1) = G_OUI) Then : TABCNT(N_I) = [M:FASC]CNXG(N_C-1) : N_I += 1 : Endif
        Next N_C
        #-2 -----------------
        If ( LCLCERR = -3 and LNBSLEEP < 4  ) Then
          # Si précédemment le calcul a échoué parce qu'on n'a pas pu verrouillé FXDASSETS ou CONTEXT
          # temporisation d'une minute avant de tenter de recalculer.
          # Au cours d'un REPEAT, 3 temporisations maximum.
          Call TEMPON(mess(79,7774,1)-[M:FASC]CPY(N_S-1)) From GESECRAN
          Sleep 5
          LNBSLEEP += 1
        Endif
        #-2 -----------------
        Call TEMPON(mess(78,7774,1)-[M:FASC]CPY(N_S-1)) From GESECRAN
        # Calcul de la société
        #    **************
        Call CALCULER_SOCIETE([M:FASC]CPY(N_S-1), TABFCY, TABCNT, PFASCLC, LCLCERR ) From GLOBB
        #    **************
        # Arrêt du traitement si dépassement du temps limite
        If ( LCLCERR = -2 ) Then : Break 2 : Endif
        TNBRTRY(N_S-1) -= 1
        If ( LCLCERR  = -3 and TNBRTRY(N_S-1) > 0 ) Then
          # Société non verrouillée & au moins un essai restant ( le calcul sera retenté pour cette société )
          LRETENTECLC = 1
        Elsif ( LCLCERR <> -3 or ( LCLCERR = -3 and TNBRTRY(N_S-1) = 0 ) ) Then
          # Société à ne plus calculer ( Calcul effectué ou Aucun essai restant ou en erreur)
          TCLCCPY(N_S-1) = G_NON
        Endif
      Endif
      #-1 -----------------
    Next N_S
    # >>>>>>>>>>>>>>>>
  Until LRETENTECLC = 0
  # >>>>>>>>>>>>>>>>
  #--


  # FQ71297
  #Call TEMPOFF() From GESECRAN


  Call ECR_TRACE(string$(80, '-'),0) From GLOBB0

$FIN_CALCULER_SOCIETES

  # FQ71297
  Call TEMPOFF() From GESECRAN

  # Fermeture du Compte-rendu
  If ( !(GSERVEUR) ) Then
    Call FERME_TRACE From LECFIC
  Endif

  ###############Call ARRET From TIMING

  # Visualisation du Compte-rendu
  If !( GSERVEUR ) Then : Call LEC_TRACE From LECFIC : Endif

  #--
  # Fermeture écran CALDIV
  If (clalev([M:DIV]))  Then : Close Local Mask [DIV]  : Endif : # Infos diverses
  If (clalev([M:DIV2]))  Then : Close Local Mask [DIV2]  : Endif : # Infos diverses FQ77877

  # Heure de début de calcul
  If (dim(G_TIMD)    >0) Then : Kill G_TIMD     : Endif

Return

