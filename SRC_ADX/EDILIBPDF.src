#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#Case ACTION
#  When "INIT"        : Gosub INIT
#Endcase
Return

$INIT
Return
##################################################################################
# Epic X3-64474_US X3-85220 Attachment file management in EDI (JUCON 04/06/2018) #
##################################################################################
$PRINT_CLASSIC
  Local Integer RETMETH  : RETMET  = [V]CST_AERROR
  Local Integer RETVAL   : RETVAL  = [V]CST_AOK
  Local Integer RETMES   : RETMES  = [V]CST_AOK
  Local Integer WNBPAR   : WNBPAR=0
  Local Char WERRPRO(250): WERRPRO    = ""

  Local Char WETAT(20) :
  Local Char WDEST(80)   :
  Local Char WLANG(3)    : WLANG   = ""
  Local Integer WFLG     : WFLG    = 0
  Local Char WMSGIMP(3)  : WMSGIMP = ""
  Local Char WTBPAR_BP(15)(1..)
  Local Char WTBVAL_BP(30)(1..)
  Local Char WTBVAL   (30)(1..)

  Local Char WFCY(5)     :
  Local Char WNUM(20)    : WNUM=NUMDOC
  Local Integer WINVTYP  :
  Local Char WBPRNUM(20) :
  Local Char WFIXNAM(100)
  Local Char WFIXDIR(250)
  Local Integer WSIGN
  Local Integer WPARTYP(1..)
  Local Integer WALIAS (1..)
  Local Char WDOCID(20): WDOCID=WNUM
#añadir WFLO y WREL
  Call GET_FLOW_PDF_PROP(WNUM,WETAT,WDEST,WTBPAR_BP,WTBVAL_BP,WSIGN,WNBPAR,WALIAS, WPARTYP)

  For I=1 To WNBPAR
    If WALIAS(I)=2 and WTBVAL_BP(I)<>""
      Case WPARTYP(I)
        When 7,8  : WTBVAL(I) = evalue(evalue("WTBVAL_BP(I)"))
        When Default: WTBVAL(I) = num$(evalue(evalue("WTBVAL_BP(I)")))
      Endcase
    Else
      WTBVAL(I) = WTBVAL_BP(I)
    Endif
  Next

# Instanciate ETNA gateway
  Local Instance MYGATE Using C_AGATEWAYETNA
  MYGATE = NewInstance C_AGATEWAYETNA AllocGroup null


# Send parameters to the gateway structure and handle the errors
  If fmet MYGATE.ASETVALCHAR("WDOCID",WDOCID)   <>[V]CST_AOK: RETVAL=[V]CST_AERROR: Endif
  If fmet MYGATE.ASETVALCHAR("WETAT",WETAT)     <>[V]CST_AOK: RETVAL=[V]CST_AERROR: Endif
  If fmet MYGATE.ASETVALCHAR("WDEST",WDEST)     <>[V]CST_AOK: RETVAL=[V]CST_AERROR: Endif
  If fmet MYGATE.ASETVALCHAR("WCPY",WCPY)       <>[V]CST_AOK: RETVAL=[V]CST_AERROR: Endif
  If fmet MYGATE.ASETVALCHAR("WPARCOD",WPARCOD) <>[V]CST_AOK: RETVAL=[V]CST_AERROR: Endif
  If fmet MYGATE.ASETVALINTEGER("WSIGN",WSIGN)  <>[V]CST_AOK: RETVAL=[V]CST_AERROR: Endif

  For I=1 To WNBPAR
    If fmet MYGATE.ASETVALCHAR(evalue("WTBPAR_BP("+num$(I)+")"),WTBVAL(I))<>[V]CST_AOK
      RETVAL=[V]CST_AERROR: Break
    Endif
  Next

  If RETVAL=[V]CST_AERROR
    # Handle the error and exit
    WERR = mess(204,196,1) #Error in the parameter code
    Goto PRINT_ERROR
   Endif

# Call the ARPC method
  RETVAL = fmet MYGATE.ARPC("EDILIBPDF","GAT_PRINTACTION_CLASSIC")

# Check if it was successful
  RETVAL = fmet MYGATE.AGETVALINTEGER("RETMETH", RETMETH)
  RETMES = fmet MYGATE.AGETVALCHAR   ("WERR", WERR)

# Free ETNA gateway
  FreeInstance MYGATE

# Display error or succes message depending of ARPC method call result
  If WERR<>"" or RETVAL=[V]CST_AERROR:
    WERR = "ATENCIÓN:"-WERR+"."-"ARPC"-mess(7,21,1)+"."-mess(209,2006,1)# Attachment unsuccessfully generated'
    RETVAL=[V]CST_AINFO
  Endif

  WSTATUS=RETVAL
Return

$GATEWAYS
  Case AGATEWAY:
    When "GAT_PRINTACTION_CLASSIC" Gosub GAT_PRINTACTION_CLASSIC
  Endcase
Return

###############################################################################
$GAT_PRINTACTION_CLASSIC
  Local Integer RETMETH  : RETMET  = [V]CST_AERROR
  Local Integer RETVAL   : RETVAL  = [V]CST_AOK
  Local Integer RETMES   : RETMES  = [V]CST_AOK
  Local Char WERR(250)   : WERR = ""
  Local Char WERRPRO(250): WERRPRO = ""
  Local Char WMESS(250)
  Local Char WETAT(20) :
  Local Char WDEST(80)
  Local Integer WSIGPRO  :
  Local Char WDOCID(20)    :
  Local Char WCPYGAT(5)
  Local Char WPARGAT (20)
  Local Char WTBPAR_BP(15)(1..)
  Local Char WRBPAR_BP(15)(1..)
  Local Char WRBVAL   (30)(1..)
  Local Integer WNBPAR, WRETVAL

# Get parameters from the gateway structure and handle the errors
  If fmet this.AGETVALCHAR("WDOCID",WDOCID )    <>[V]CST_AOK: WRETVAL=[V]CST_AERROR: Endif
  If fmet this.AGETVALCHAR("WETAT",WETAT)       <>[V]CST_AOK: WRETVAL=[V]CST_AERROR: Endif
  If fmet this.AGETVALCHAR("WDEST",WDEST)       <>[V]CST_AOK: WRETVAL=[V]CST_AERROR: Endif
  If fmet this.AGETVALCHAR("WCPY",WCPYGAT)      <>[V]CST_AOK: WRETVAL=[V]CST_AERROR: Endif
  If fmet this.AGETVALCHAR("WPARCOD",WPARGAT)   <>[V]CST_AOK: WRETVAL=[V]CST_AERROR: Endif
  If fmet this.AGETVALINTEGER ("WSIGN",WSIGPRO) <>[V]CST_AOK: WRETVAL=[V]CST_AERROR: Endif

  Call GET_GATE_PROP(WDOCID,WTBPAR_BP,WNBPAR)

  For I=1 To WNBPAR
    WRBPAR_BP(I)=evalue("WTBPAR_BP("+num$(I)+")")
    If fmet this.AGETVALCHAR(WRBPAR_BP(I),WRBVAL(I))<>[V]CST_AOK: RETVAL=[V]CST_AERROR: Break:  Endif
  Next

  If RETVAL=[V]CST_AERROR
    # Handle the error and exit
    WERR    = "GATEWAY"-mess(7,21,1)+"."-WERRPRO  #GATEWAY Error"
    RETMETH = [V]CST_AERROR
    RETVAL  = fmet this.AGETVALINTEGER("RETMETH", RETMETH)
    Return
  Endif

# Call the classic signature function and handle the errors
  RETMETH = func MY_PRINT(WETAT,WDEST,"",0,WMESS,WTBPAR_BP,WRBVAL)

  If RETMETH <> [V]CST_AOK #error
    If WERRPRO="": WERRPOR=WMESS: Endif
    WERR = mess(139,199,1)+"."-WERRPRO  #Processing Failure
  Else
    If WSIGPRO=2
    # firmar si tiene firma
      Local Char WJOB(250), WDES(250), WFILNAME(250), WCERT(50)
      Local Clbfile RESHEAD(0)
      Local Clbfile RESBODY(0)
      Local Integer WSTATUS
      Local Blbfile DATA(7)
      Local Clbfile B64(0)
      Local Integer COUNT
      Local Clbfile WTO(1)

      WJOB      =WFICHIER
      WDES      =WFICHIER #Same directory and name because we replace the not signed file
      WFILNAME  =WFICNAME

      Call GET_CERT_USER(GUSER,WCPYGAT,WPARGAT,WCERT,WMESS) From EDILIBPDF

      If WMESS=""  and filinfo(WJOB,0)>0
        Openi WJOB,0 Using [EDI1]
        Getseq 1, DATA Using [EDI1]
        Openi Using [EDI1]
        #Encode
        COUNT = b64Encode(DATA, B64)
#
        WOK=func ASYRSYS.DELETEFILE(WJOB,WMESS)

        If WMESS=""
          #Sign PDF
          WSTATUS = func EDILIBPDF.PDFSIGN(WFILNAME, B64,WCERT, 0, "data", RESHEAD, RESBODY)
          If WSTATUS = 200
            #Decode
            COUNT=b64Decode(RESBODY,DATA)
            Openo WDES Using [EDI1]
            Putseq 1, DATA Using [EDI1]
            Openo Using [EDI1]
          Else
            WMESS=left$(RESHEAD,len(RESHEAD))
          Endif
        Endif
      Endif
    Endif
  Endif

  # Send result parameters to the gateway structure
  If WERRPRO="":  WERRPRO = WMESS
  Else WERRPRO= WERRPRO+"."-WMESS : RETMETH = [V]CST_AERROR  #X3-98912 (JUCON 02/07/2018)
  Endif
  RETVAL = fmet this.ASETVALINTEGER("RETMETH", RETMETH)
  RETMES = fmet this.ASETVALCHAR("WERR", WERRPRO)
  Kill WTBPAR, WTBVAL, WFICHIER, WFICNAME
Return

###############################################################################

#**************************************************************************************
#* Error management : Error
#**************************************************************************************!
$PRINT_ERROR
#  ARET_VALUE  = [V]CST_AERROR
#
#  # Free ETNA gateway
#  FreeInstance MYGATE
#
#  If WERR <> ""
#    ASTATUS = fmet this.ASETERROR ("", WERR, ARET_VALUE)
#  Endif
Return

##################################################
Funprog MY_PRINT(ETAT,IMPRIMANTE,LANGUE,TRACE,MSGIMP,TBPAR,TBVAL)
Value    Char    ETAT
Value    Char    IMPRIMANTE
Value    Char    LANGUE
Value    Integer TRACE
Variable    Char    MSGIMP
Value    Char    TBPAR()(1..)
Value    Char    TBVAL()(1..)

  Local Integer WOK : WOK = [V]CST_AERROR
  Local Char    PARAM(250)(1..8)
  Local Char    VALWRK(10)
  Local Char    SPEWRK(GLONADC)
  Local Char    PRINTACTION(25)
  Local Char    PRINTSCRIPT(40)
  Global Char   WTBPAR(15)(1..)
  Global Char   WTBVAL(39)(1..)
  Global Char   WFICHIER(250)
  Global Char   WFICNAME(250)

  For I=1 To dim(TBPAR)
    WTBPAR(I)=TBPAR(I)
    WTBVAL(I)=TBVAL(I)
  Next

  PRINTACTION="SYREDIETAT"
  PRINTSCRIPT="EDIPRTPDF"

  PARAM(1) = TBVAL(3)
  PARAM(2) = TBVAL(1)
  PARAM(3) = TBVAL(5)
  PARAM(4) = TBVAL(7)
  PARAM(5) = TBVAL(9)
  PARAM(6) = "1"
  PARAM(7) = ETAT
  PARAM(8) = ""

  ##############################################
  #PRINTACTION
  #PRINTSCRIPT
  #PARAM()
  # Can be modified in entry point
  ##############################################
  GPOINT = "INITPRINT" : Gosub ENTREE From EXEFNC

  Call TRTSPE(nomap,PRINTACTION,SPEWRK) From SUBACT
  Call TRAITE_CHAR(VALWRK,PARAM,"",PRINTSCRIPT,"",5,SPEWRK) From GTRAITE : #

  If val(PARAM(6)) <> 2
    WOK = [V]CST_AOK #success !!
  Else
    MSGIMP=PARAM(8)
    WOK = [V]CST_INFO
  Endif
End WOK

##################################################
#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It allows to sign PDF using certificate defined in Syracuse administration.
#*
#* @param PDFNAME : Char : The PDF name
#* @param DATA : Clbfile : The content encoded in base 64
#* @param CERTNAME : Char : The name of the certificate to use and that is defined in Syracuse administration
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#* @param RESHEAD : Clbfile : The response header
#* @param RESBODY : Clbfile : The PDF signed content.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog PDFSIGN(PDFNAME, DATA, CERTNAME, FUTURE, RETURNS, RESHEAD, RESBODY)
Value Char PDFNAME
Value Clbfile DATA
Value Char CERTNAME
Value Integer FUTURE
Value Char RETURNS
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-4gl-api/lib/pdf'
Local Char FONCTION(30) : FONCTION = 'sign'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif

Local Clbfile ARGUMENTS(0)
ARGUMENTS = '"' + PDFNAME + '","' + DATA + '","' + CERTNAME + '", {"returnData": true, "encoding": "base64"}'
Local Clbfile RESBODY(0)
# Call 'sign' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '0,1,0,0', 0, RETURNS, '0', RESHEAD, RESBODY)

End STATUSCODE

################################################################
# Funprog- Get properties to pdf generation from flow setup
# DOC -    Document number
################################################################
Funprog GET_FLOW_PDF(DOC)
Variable Char DOC

  Local Char WFLO(20), WREL(20)
  Local Char WNUM(50): WNUM=DOC
  Local Integer STA : STA=0

  Local File EDITMPDOC [ETC]
  Read [ETC]ETC2=WNUM
  If fstat=[V]CST_AOK
    WFLO=[F:ETC]FLOCOD
    WREL=[F:ETC]FLOREL
  Endif
  LogicClose File [ETC]

  If WFLO<>"" and WREL<>""
    Local File EDIFLOA [EFLA]
    Filter [EFLA] Where FLOCOD=WFLO and FLOREL=WREL and GENFLG=2
    If rowcount([F:EFLA])=0: STA=1: Endif
    LogicClose File [EFLA]
  Endif

End STA

################################################################
# Subprog- Get properties to pdf generation from flow setup
# WNUM -    Document number
# WETAT-    CR to use
# WDEST-    Destination
# WTBPAR-   CR parameters
# WTBVAL-   CR parameters values
# WFIXNAM-  Fixed name
# WPTCDIR-  Volumen/directory to generate the file
# Wsign -   Signef file
#################################################################
Subprog GET_FLOW_PDF_PROP(WNUM,WETAT,WDEST,WTBPAR_BP,WTBVAL_BP,WSIGN,WNBPAR,WALIAS, WPARTYP)
Value Char WNUM
Variable Char WETAT
Variable Char WDEST
Variable Char WTBPAR_BP()()
Variable Char WTBVAL_BP()()
Variable Integer WSIGN
Variable Integer WNBPAR
Variable Integer WALIAS
Variable Integer WPARTYP

  Local Char WFLO(20), WREL(20), WUSER(20)
  Local Char DOCNUM(50): DOCNUM=WNUM
  Local Integer WNLIN:  WNLIN=0

  Local File EDITMPDOC [ETC]
  Read [ETC]ETC2=WNUM
  If fstat=[V]CST_AOK
    WFLO=[F:ETC]FLOCOD
    WREL=[F:ETC]FLOREL
  Endif
  LogicClose File [ETC]

  If WFLO<>"" and WREL<>""
    Local File EDIFLOA [EFLA]
    Filter [EFLA] Where FLOCOD=WFLO and FLOREL=WREL and GENFLG=2
    Read [EFLA]First
    If fstat=[V]CST_AOK
      WSIGN=[F:EFLA]SGNFLG
      WETAT=[F:EFLA]CRUSED
      WDEST=[F:EFLA]DESTIN
    Endif
    LogicClose File [EFLA]

    Local File EDIFLOAP [EFLP]
    Filter [EFLP] Where FLOCOD=WFLO and FLOREL=WREL
    For [EFLP]
      WTBPAR_BP(WNLIN)=[F:EFLP]PARNAM
      If [F:EFLP]ALIAS<>""
        WTBVAL_BP(WNLIN)="this."+[F:EFLP]PROPERTY
        WALIAS(WNLIN)=2
      Else
        WTBVAL_BP(WNLIN)=[F:EFLP]CONSTANT
        WALIAS(WNLIN)=1
      Endif
      WPARTYP(WNLIN)=[F:EFLP]VALTYPE
      If [F:EFLP]VALTYPE=0:  WPARTYP(WNLIN)=7: Endif
      WNLIN+=1
    Next
    # fixed parameters to use
    If WNLIN>0
      WTBPAR_BP(WNLIN) = "usr"       : WTBVAL_BP(WNLIN)   = GACTX.USER: WALIAS(WNLIN)  =1 : WPARTYP(WNLIN)  =7
      WTBPAR_BP(WNLIN+1) = "etat"    : WTBVAL_BP(WNLIN+1) = WETAT     : WALIAS(WNLIN+1)=1 : WPARTYP(WNLIN+1)=7
      WTBPAR_BP(WNLIN+2) = "X3ETA"   : WTBVAL_BP(WNLIN+2) = WETAT     : WALIAS(WNLIN+2)=1 : WPARTYP(WNLIN+2)=7
      WNBPAR=WNLIN+3
    Endif
    LogicClose File [EFLP]
  Endif
$EXIT
End

################################################################
# Subprog- Get properties to pdf generation from flow setup
# WDOCID   -  Document number
# WTBPAR_BP-  Parameters
# WNBPAR   -  Numbers of parameters
################################################################
Subprog GET_GATE_PROP(WDOCID,WTBPAR_BP,WNBPAR)
Value Char WDOCID
Variable Char WTBPAR_BP()()
Variable Integer WNBPAR

  Local Char WFLO(20), WREL(20), WUSER(20)
  Local Integer WNLIN:  WNLIN=0

  Local File EDITMPDOC [ETC]
  Read [ETC]ETC2=WDOCID
  If fstat=[V]CST_AOK
    WFLO=[F:ETC]FLOCOD
    WREL=[F:ETC]FLOREL
  Endif
  LogicClose File [ETC]

  If WFLO<>"" and WREL<>""
    Local File EDIFLOAP [EFLP]
    Filter [EFLP] Where FLOCOD=WFLO and FLOREL=WREL
    For [EFLP]
      WTBPAR_BP(WNLIN)=[F:EFLP]PARNAM
      WNLIN+=1
    Next
    # fixed parameters to use
    If WNLIN>0
      WTBPAR_BP(WNLIN)   = "usr"

      WTBPAR_BP(WNLIN+1) = "etat"
      WTBPAR_BP(WNLIN+2) = "X3ETA"
      WNBPAR=WNLIN+3
    Endif
    LogicClose File [EFLP]
  Endif

End

################################################################
# Subprog- Get properties to pdf generation from flow setup
# WNUM   -  Document number
# WDEST  -  Destination
# WFICNAM-  File name
# WDICDIR-  Directory name
# WERRPTC-  Error
################################################################
Subprog GET_ETAT_PROP(WNUM,WDEST,WFICNAM, WFICDIR,WPTC,WERRPTC)
Value Char WNUM
Variable Char WDEST
Variable Char WFICNAM
Variable Char WFICDIR
Variable Char WPTC
Variable Char WERRPTC

  Local Char WFLO(20), WREL(20), WUSER(20)
  Local Integer WNLIN:  WNLIN=0

  Local File EDITMPDOC [ETC]
  Read [ETC]ETC2=WNUM
  If fstat=[V]CST_AOK
    WFLO=[F:ETC]FLOCOD
    WREL=[F:ETC]FLOREL
  Endif
  LogicClose File [ETC]

  If WFLO<>"" and WREL<>""
    Local File EDIFLOA [EFLA]
    Filter [EFLA] Where FLOCOD=WFLO and FLOREL=WREL and GENFLG=2
    Read [EFLA]First
    If fstat=[V]CST_AOK
      WDEST=[F:EFLA]DESTIN
      If [F:EFLA]FIXNAM=2
        WFICNAM=[F:EFLA]FICNAM
      Else
        WFICNAM=WNUM+".pdf"
      Endif
      WFICNAME=WFICNAM
      Local File EDIFLO [EFL]
      Read[EFL]EFL0=WFLO:WREL
      If fstat=[V]CST_AOK
        WPTC=[F:EFL]PTCCOD
        Local File EDIPTCD [EPTD]
        Filter [EPTD] Where PTCCOD=[F:EFL]PTCCOD and PTCLINCOD="DIRATTACHMENT"
        Read[EPTD] First
        If fstat=[V]CST_AOK
          WFICDIR=[F:EPTD]PTCLINVAL   # PATH
        Else
          WERRPTC=mess(113,2006,1)+":"-[F:EFL]PTCCOD+"."-"DIRATTACHMENT:"- mess(86,105,1)
        Endif
        LogicClose File [EPTD]
      Endif
      LogicClose File [EFL]
    Else
      WERRPTC=WFLO+"/"+WREL+":"-mess(212,2006,1) #No attachments in this flow
    Endif
    LogicClose File [EFLA]
  Else
    WERRPTC=mess(66,2006,1) # Flow nonexistent
  Endif

End

##########################################################################
Subprog GET_CERT_USER(WUSER,WCPY,WPARCOD,WCRT,WERRCER)
Value Char WUSER
Value Char WCPY
Value Char WPARCOD
Variable Char WCRT
Variable Char WERRCER

  Local File EDICPYPAR [ECP]
  Read [ECP]ECP0=WCPY;WPARCOD
  If fstat=[V]CST_AOK and [F:ECP]VALID=2 and [F:ECP]SIGNATURE=2
    Local File EDICPYPARD [ECPD]
    Filter [ECPD] Where CPY=WCPY and PARCOD=WPARCOD and USER=WUSER
    Read [ECPD]First
    If fstat=[V]CST_AOK
      WCRT=[F:ECPD]CERTIFICATE
    Else
      WERRCER=mess(210,2006,1) #User without certificate in the company
    Endif
    LogicClose File [ECPD]
  Else
    WERRCER=mess(211,2006,1)-WCPY #Invalid certificate for the user or does not exist in the company WCPY
  Endif
  LogicClose File [ECP]

End

##########################################################################
# X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file
##########################################################################
Subprog ATTACHMENT(WFLOCOD,WFLOREL,ATTXML,ATTPDFNAM,ATTPDFVOL,ATTFIXNAM,ATTFIXVOL,ATT,XMLSGN,ATTPDF)
Value Char WFLOCOD
Value Char WFLOREL
Variable Integer ATTXML
Variable Char ATTPDFNAM
Variable Char ATTPDFVOL
Variable Char ATTFIXNAM
Variable Char ATTFIXVOL
Variable Integer ATT
Variable Integer XMLSGN
Variable Integer ATTPDF

  Local Integer WNGFILE
  Local File EDIFLOD [EFLD]
  Filter [EFLD] Where FLOCOD=WFLOCOD and FLOREL=WFLOREL and SIGNATURE=2
  If rowcount([EFLD])>0: XMLSGN=1 Else : XMLSGN=0: Endif
  LogicClose File [EFLD]
#  Endif

#  LogicClose File [EDF]
  Local File EDIFLOA [EDFA]
  Filter [EDFA] Where FLOCOD=WFLOCOD and FLOREL=WFLOREL
  For [EDFA]
    ATT+=1
    If [F:EDFA]GENFLG=2
      ATTPDF=1
      If [F:EDFA]EXCMSG=2: ATTXML=1: Endif
      If [F:EDFA]FIXNAM=2: ATTPDFNAM=[F:EDFA]FICNAM: ATTPDFVOL=[F:EDFA]PATH: Endif
    Else
      ATTFIXNAM(WNGFILE)=[F:EDFA]FICNAM: ATTFIXVOL(WNGFILE)=[F:EDFA]PATH
      WNGFILE+=1
    Endif
  Next
  LogicClose File [EDFA]
End

################################################################
# Funprog- Get properties to pdf generation from flow setup
# This Function is working on Fusion Session Client AND Syracuse session client
# It allows to send emails through Syracuse notification server definition.
#* @param WFROM : Char : The e-mail address of the sender. All e-mail addresses can be plain `'sender@server.com'` or formatted `'Sender Name <sender@server.com>'`
#* @param WTO : Clbfile : Comma separated list of recipients e-mail addresses that will appear on the *To:* field
#* @param SUBJECT : Char : The subject of the e-mail
#* @param SMTPSRV : Char : The notification server code set in Syracuse administration
#* @param THEME : Char : The notification theme defined in Syracuse administration you want to use
#* @param TITLE : Char : The email title
#* @param SUBTITLE : Char : The email subtitle
#* @param CONTENT : Char : The main text of the email
#* @param SIG : Char : The signature used at the end of the email
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#* @param RESHEAD : Clbfile : The response header
#* @param RESBODY : Clbfile : Nothing is returned.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#* X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file
Funprog SENDEMAIL(WFROM, WTO, SUBJECT, SMTPSRV, THEME, TITLE, SUBTITLE, CONTENT, SIG, ATT_NAME, ATT_CONTENT, FUTURE, RESHEAD, RESBODY)
Value Char WFROM
Value Clbfile WTO
Value Char SUBJECT
Value Char SMTPSRV
Value Char THEME
Value Char TITLE
Value Char SUBTITLE
Value Clbfile CONTENT
Value Char SIG
Value Char ATT_NAME()(1..)
Value Clbfile ATT_CONTENT()(1..)
Value Integer FUTURE
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-4gl-api/lib/mailer'
Local Char FONCTION(30) : FONCTION = 'send'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif

Local Clbfile DATA(4) : DATA = ''


Append DATA, '{'
Append DATA, '"from": "' + WFROM + '",'
Append DATA, '"to": "' + WTO + '",'

Append DATA, '"subject": "' + SUBJECT + '"'

If dim(ATT_NAME) <> 0
   Append DATA, ', "attachments": ['
   For I=0 To dim(ATT_NAME) - 1
     If ATT_NAME(I + 1)<>""
       If I>0: Append DATA, ',': Endif
       Append DATA, '{'
         Append DATA, '"filename": "' + ATT_NAME(I + 1) + '",'
         Append DATA, '"content": "' + ATT_CONTENT(I + 1) + '",'
         Append DATA, '"encoding": "base64"'
       Append DATA, '}'
     Endif
   Next
   Append DATA, ']'
Endif

Append DATA, '}'

Local Clbfile OPT(4) : OPT = ''
Append OPT, '{'
# set explicitely notification server
If SMTPSRV <> ""
   Append OPT, '"server": "' + SMTPSRV + '",'
Endif
# Manage theme
If THEME <> ""
   Append OPT, '"theme": "' + THEME+ '",'
Else
   Append OPT, '"noTheme": true,'
Endif

# Manage the view object
Append OPT, '"view": {'
Append OPT,       '"title": "' + TITLE + '",'
Append OPT,       '"subtitle": "' + SUBTITLE + '",'
Append OPT,       '"content": "' + CONTENT + '",'
Append OPT,       '"signature": "' + SIG + '"'
Append OPT,    '}' # close view object
Append OPT, '}' # close OPT object

Local Clbfile ARGUMENTS(0)
ARGUMENTS = DATA + ',' + OPT
Local Clbfile RESBODY(0)
# Call 'sign' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, '', '0', RESHEAD, RESBODY)

End STATUSCODE

################################################################
# Funprog- Get properties from SOLUTION file
# @param PROTOCOL -    protocol
# X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file
################################################################
Funprog SOLUTION(NUM)
Value Integer NUM

  Local Char    DOSREF(GLONADS) , PATH_NAMSOL(250)
  Local Clbfile CLOB(8)
  Local Char SVRPATH (250)
  Local Char SVRNAME (250)
  Local Char SVRPORT (10)
  Local Char RESULT (250)

  For I=7 To 0 Step -1
  If adxmother(I)<>""
    DOSREF = adxmother(I)
    Break
  Endif
  Next

  PATH_NAMSOL = filpath("","","",DOSREF)
  PATH_NAMSOL = left$(PATH_NAMSOL,len(PATH_NAMSOL)-len(DOSREF))
  PATH_NAMSOL += "solution.xml"

  If filinfo(PATH_NAMSOL,7)>0

    Openi PATH_NAMSOL,0 Using [SOLUTION]
    Iomode adxifs ""    Using [SOLUTION]
    Iomode adxirs ""    Using [SOLUTION]
    Iomode adxium GUTF8 Using [SOLUTION]
    Rdseq CLOB          Using [SOLUTION]
    Openi               Using [SOLUTION]

   Case NUM
    When 1:
      I = instr(1,CLOB,"component.report.path")
      If I
        I = instr(I+1,CLOB,">")
        If I
          J = instr(I+1,CLOB,'<')
          If J
            SRVPATH = seg$(CLOB,I+1,J-1)
          Endif
        Endif
      Endif
      RESULT=SRVPATH
    When 2:
      I = instr(1,CLOB,"component.report.servername")
      If I
        I = instr(I+1,CLOB,">")
        If I
          J = instr(I+1,CLOB,'<')
          If J
            SRVNAME = seg$(CLOB,I+1,J-1)
          Endif
        Endif
      Endif
      RESULT=SRVNAME
    When 3:
      I = instr(1,CLOB,"report.service.printport")
      If I
        I = instr(I+1,CLOB,">")
        If I
          J = instr(I+1,CLOB,'<')
          If J
            SRVPORT = seg$(CLOB,I+1,J-1)
          Endif
        Endif
      Endif
      RESULT=SRVPORT
    Endcase
  Endif

End RESULT

##############################################################
# X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file #
##############################################################
Subprog COPY_ATT(PTC,FICNAME,FIC2,WSEP,WMESS)
Value Char PTC
Value Char FICNAME
Value Char FIC2
Value Char WSEP
Variable Char WMESS

  Local Integer NBTEST, WOKK
  Local Char F1(250), F2(250)
  Local Char WMESCOP (250)
  Local Integer WOK

  Local File EDIPTCD [EPTD]
  Filter [EPTD] Where PTCCOD=PTC and PTCLINCOD="DIRPRINTSERVER"
  Read [EPTD] First
  If fstat=[V]CST_AOK
    F1=[F:EPTD]PTCLINVAL
  Endif
  LogicClose File [EPTD]

  F1=F1+WSEP+FICNAME
  F2=FIC2

# Taking time for attrachment generation
  Repeat
    NBTEST+=1
    Sleep NBTEST
  Until filinfo(F1,0)>0 or NBTEST>10

  If filinfo(F1,0)>0
    WOKK=func ASYRSYS.COPYFILE(F1,F2,WMESCOP)
  Else
    WMESCOP= mess(267,151,1)+"."-mess(00209,02006,1) # Waiting time exceeded. Attachment generation failed
  Endif
WMESS=WMESCOP
End

################################################################
# Funprog- Get values to prepare the email send
# X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file
################################################################
Funprog PROTOCOL(PROTOCOL,ATTXMLNAM,ATTPDFNAM,ATTPDFVOL,ATTFIXNAM,ATTFIXVOL,NBATT,XMLSGN,ATTXML,ATTPDF,ERR)
Value Char PROTOCOL
Value Char ATTXMLNAM
Value Char ATTPDFNAM
Value Char ATTPDFVOL
Value Char ATTFIXNAM
Value Char ATTFIXVOL
Value Integer NBATT
Value Integer XMLSGN
Value Integer ATTXML
Value Integer ATTPDF
Variable Char ERR

  Local Integer WOK
  Local Char WFROM(250)
  Local Clbfile WTO
  Local Char SUBJECT(250)
  Local Char SMTPSRV(250)
  Local Char THEME(100)
  Local Char TITTLE(250)
  Local Char SUBTITLE(250)
  Local Clbfile CONTENT
  Local Char SIG(250)
  Local Char CONTENT(250)
  Local Char ATT_NAME(250)(1..4)
  Local Clbfile ATT_CONTENT(2)(1..4)
  Local Integer FUTURE
  Local Clbfile RESHEAD
  Local Clbfile RESBODY
  Local Blbfile DATA(7)
  Local Char WJOB(250)
  Local Integer WOK, XMLSGN. J
  Local Char ATTXMLDIR(250), ATTPDFDIR(250)
  Local Char WFICHIER(250)(1..5)
  Local Integer COUNT, NBFILES
  Local Char WERR (250)
  #reading path for not fixed attachments
  If ATTXML=0
    Local File EDIPTCD [EPTD]
    If ATTXMLNAM<>""
      If XMLSGN=0
        Filter [EPTD] Where PTCCOD=PROTOCOL and PTCLINCOD="DIRISSUE"
      Else
        Filter [EPTD] Where PTCCOD=PROTOCOL and PTCLINCOD="DIRATTACHMENT"
      Endif
      Read [EPTD] First
      If fstat=[V]CST_AOK
        ATTXMLDIR=[F:EPTD]PTCLINVAL
      Endif
    Endif
  Endif

  If ATTPDF=1
    If ATTPDFVOL=""
      Filter [EPTD] Where PTCCOD=PROTOCOL and PTCLINCOD="DIRATTACHMENT"
      Read [EPTD] First
      If fstat=[V]CST_AOK
        ATTPDFDIR=[F:EPTD]PTCLINVAL
      Endif
    Else ATTPDFDIR=ATTPDFVOL
    Endif
    LogicClose File [EPTD]
  Endif

  J=instr(1,filpath("","",""),"\")
  If J>0: WSEP="\" Else : WSEP="/" : Endif

  #Filling ATT_NAMES values
  If ATTXMLNAM<>"" and ATTXML=0
    For I=1 To maxtab(ATTXMLNAM)
      NBFILES+=1
      ATT_NAME(I)=ATTXMLNAM(I-1)
      WFICHIER(I)=ATTXMLDIR+WSEP+ATT_NAME(I)
    Next
  Else I=0
  Endif
  If ATTPDFNAM<>"" and ATTPDF=1
    NBFILES+=1
    ATT_NAME(I)=ATTPDFNAM
    WFICHIER(I)=ATTPDFDIR+WSEP+ATT_NAME(I)
  Endif
  J=NBFILES+1

  For I=J To maxtab(ATTFIXNAM)+J
    If ATTFIXNAM(I-J)<>""
      ATT_NAME(I)=ATTFIXNAM(I-J)
      WFICHIER(I)=ATTFIXVOL(I-J)+WSEP+ATT_NAME(I)
    Endif
  Next

  For I=1 To maxtab(ATT_NAME)
    WJOB=WFICHIER(I)
    If filinfo(WJOB,0)>0
      If WJOB<>""
        Openi WJOB,0 Using [EDI1]
        Getseq 1, DATA Using [EDI1]
        Openi Using [EDI1]
        #Encode
        COUNT = b64Encode(DATA, ATT_CONTENT(I))
      Endif
    Else
      Raz ATT_NAME(I)
    Endif
  Next

  #reading mail setup
  Local File EDIPTCM [EPTM]
  Filter [EPTM] Where PTCCOD=PROTOCOL
  For [EPTM]
    Case NUMLIN
      When 1: SMTPSRV=[F:EPTM]PTCMLINVAL
      When 2: THEME=[F:EPTM]PTCMLINVAL
      When 3: WTO=[F:EPTM]PTCMLINVAL
      When 4: WTO+=";"+[F:EPTM]PTCMLINVAL
      When 5: SUBJECT=[F:EPTM]PTCMLINVAL
      When 6: TITLE=[F:EPTM]PTCMLINVAL
      When 7: SUBTITLE=[F:EPTM]PTCMLINVAL
      When 8: CONTENT=[F:EPTM]PTCMLINVAL
      When 9: SIG=[F:EPTM]PTCMLINVAL
    Endcase
  Next
  LogicClose File [EPTM]

  Local File AUTILIS [AUS]
  Read [AUS]CODUSR=GACTX.USER
  If fstat=[V]CST_AOK
    WFROM=[F:AUS]ADDEML
  Endif
  LogicClose File [AUS]

  WOK= func EDILIBPDF.SENDEMAIL(WFROM, WTO, SUBJECT, SMTPSRV, THEME, TITLE, SUBTITLE, CONTENT, SIG, ATT_NAME, ATT_CONTENT, FUTURE, RESHEAD, RESBODY)

  If WOK<>200
    J=instr(1,RESHEAD,"message")
    K=instr(J,RESHEAD,",")
    L=instr(J,RESHEAD,"\n")
    If K>L and L<>0: K=L : Endif  #Ini X3-110508 EDI: Manage error sending Mail (JUCON 27/09/18)
    If J>0 and K>J
      ERR=seg$(RESHEAD,J+10,K-2)
    Else
      ERR=mess(1163,196,1) #Email sending error
    Endif                         #End X3-110508 EDI: Manage error sending Mail (JUCON 27/09/18)
    WOK=[V]CST_AINFO
  Else WOK=[V]CST_AOK
  Endif

End WOK

