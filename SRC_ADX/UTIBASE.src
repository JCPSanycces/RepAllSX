#<AdxTL>@(#)12.0.0.0 $Revision$
Call UTIBASE
End

##########################################################################
Subprog UTIBASE
##########################################################################
Local   Char    PARAM(10)(1..1) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","UTIBASE","UTIBASE",3,"XYUTIBASE") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "OUVRE_BATCH" : Gosub OUVRE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

########################################
$INIT
Local Integer OK, I, J, K, L, I1, J1 , STOP , D , T , TYPERR , ER
Local Integer NBREC, INTERRUPT
Local Integer DIME, ZLIEN, ZSEC, TYP, VALNUL
Local Char    FICORG(GLONATB) , FICDES(GLONATB)
Local Integer ERR, TOTERR , ERRAS
Local Char    DOSSIER(GDIMFIC), FICDEB(GLONATB), FICFIN(GLONATB)
Local Integer NBLIEN, MAXLIEN, MAXFIC
Local Char    VALCLE(250)
MAXLIEN = 100 : MAXFIC = 30
Local Char    FICLIEN(GLONATB)(1..MAXLIEN)
Local Char    TBZONE(GLONAVA)(1..MAXLIEN)
Local Integer TBDIME(1..MAXLIEN) , TBTYP(1..MAXLIEN)
Local Libelle TBOBLIG(1..MAXLIEN)
Local Integer TBNCLE(1..MAXLIEN),TBZNCLE(1..MAXLIEN)
Local Char    TBCLE(GLONAVA)(1..MAXLIEN,1..16) , TBZCLE(30)(1..MAXLIEN,1..16) , TBZLEG(3)(1..MAXLIEN,1..16)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC)
Local Integer IFIC , JFIC , NBFIC , OKFIC(1..MAXFIC)
Local Char    CFIC(10) , GFIC(10)
Local Char    TBFIC(GLONATB)(1..MAXFIC)
Local Char    CHAINE(250) , SCLE(GLONAVA)
Local Integer NBOBLIG
Local Char    ZOBLIG(GLONAVA)(1..100)
Local Char    CRITERE(250)
Local Integer SUPCLE

Gosub OUVRE

Return

########################################
$INIT_DIA
Raz [M]
[M]NBLIG = len(mess(0,14,1))
For I=1 To [M]NBLIG
 [M]LIBMOD(I-1) = I
 [M]MODULE(I-1) = 2
Next I
If adxmac(0)=""
 [M]DOSSIER = nomap
Else
 [M]DOSSIER = adxmac(0)+"@"+nomap
Endif
Return

########################################
$OUVRE
Local File    ADOSSIER [ADS]
Return

########################################
$EXEC
DOSSIER = [M]DOSSIER
Call MACHINE(DOSSIER,MACHINE,NOMDOS) From ORDSYS

FICDEB = [M]FICDEB : FICFIN = [M]FICFIN
If FICFIN="" : FICFIN = "ZZ" : Endif

If !GSERVEUR
 Call OUVRE_TRACE(mess(163,115,1)) From LECFIC : # Vérif. cohérence de la base
Endif

If nomap=DOSSIER
 Local File ATABLE [ATB], ATABZON [ATZ], ATABIND [ATI], ATYPE [ATY], ACTIV [ACV] , ATABZON [ATZ2] , AMSKPAR [AMP]
Else
 Local File =DOSSIER+".ATABLE"   [ATB] , =DOSSIER+".ATABZON"  [ATZ] , =DOSSIER+".AMSKPAR"  [AMP]
&         , =DOSSIER+".ATABIND"  [ATI] , =DOSSIER+".ATYPE"    [ATY]
&         , =DOSSIER+".ACTIV"    [ACV] , =DOSSIER+".ATABZON"  [ATZ2]
Endif

TOTERR=0 : INTERRUPT=0
If !GSERVEUR
 Call OUVRE_BOITE(mess(2,100,1),0) From GESECRAN  : #  : Vérification en cours ...
Endif

If !GSERVEUR
 Inter
Endif
STOP = 0
CRITERE = 'TYPFIC<>3 & CODFIC>="'+FICDEB+'" & CODFIC<="'+FICFIN+'" & find(MODULE'
For I=1 To len(mess(0,14,1))
 If [M]MODULE(I-1)=2
  CRITERE += ','+num$(I)
 Endif
Next I
CRITERE += ")"

If !GSERVEUR
 Onintgo ARRET
Endif
Onerrgo ERRR
For [ATB]CODFIC Where evalue(CRITERE)
 FICORG = [F:ATB]CODFIC
 ERR=0 : OK=0
 If nomap=DOSSIER
  If filinfo(filpath("FIL",FICORG,"fde"),0)>=0
   Local File =FICORG [AAA_]
   OK=1
  Endif
 Elsif filinfo(filpath("FIL",FICORG,"fde",NOMDOS,"",MACHINE),0)>=0
  Local File =DOSSIER+"."+FICORG [AAA_]
  OK=1
 Endif
 If OK
  If !GSERVEUR
   Call SET_BOITE(mess(57,123,1)-FICORG,nbrecord([AAA_])) From GESECRAN
  Endif
  Gosub VERF_FIC
  Close Local File [AAA_]
  If INTERRUPT or STOP : Break : Endif
 Endif
Next

If !GSERVEUR
 Call FERME_BOITE From GESECRAN
Endif

If !TOTERR
 If !GSERVEUR
  Call MESSAGE(mess(164,115,1)) From GESECRAN : # Aucune anomalie
 Endif
Else
 Call ECR_TRACE(string$(60,"-"),0) From GESECRAN
 Call ECR_TRACE(num$(TOTERR)-mess(165,115,1),0) From GESECRAN : # Anomalies
 Call ECR_TRACE(string$(60,"-"),0) From GESECRAN
Endif
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$FIN
If !GSERVEUR
 Nointer
 TRA = 1
Else
 TRA = 0
Endif
Return

$ARRET
STOP = 2
Call ABANDON(STOP) From GESECRAN
If STOP<>2 : STOP = 0 : Endif
Resume

##################################################
$VERF_FIC
# Comptage des liens
Onerrgo ERRR
NBLIEN  = 0
NBOBLIG = 0
Raz NBFIC , OKFIC , TBCLE , TBZCLE ,TBZLEG

For [ATZ]NUMLIG Where CODFIC=FICORG
 If [F:ATZ]LIEN<>"" & [F:ATZ]VERIF=2
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If !fstat
   NBLIEN += 1
   FICDES = [F:ATZ]LIEN
   If GDOSCPT<>"" and find([F:ATZ]CODTYP,GABRCPT(1..GNBTABCPT))
    FICDES  =GTABCPT+FICDES
   Endif
   FICLIEN(NBLIEN) = FICDES
   TBZONE(NBLIEN)  = [F:ATZ]CODZONE
   TBOBLIG(NBLIEN) = [F:ATZ]OBLIG
   TBDIME(NBLIEN)  = [F:ATZ]DIME
   If [F:ATZ]CODACT<>"" : # mb 8.4.8 bug 46810
    Read [ACV]CODACT=[F:ATZ]CODACT
    If fstat or [F:ACV]FLACT<>2
     TBDIME(NBLIEN) = 0
    Elsif [F:ACV]DIME>0
     TBDIME(NBLIEN) = max(1,[F:ACV]DIME)
    Endif
   Endif
   TBTYP(NBLIEN) = [F:ATY]TYPTYP
   Read [ATI]NUMLIG(2) = FICDES;1
   CHAINE = [F:ATI]DESCRIPT
   TBNCLE(NBLIEN)=0
   While CHAINE<>""
    TBNCLE(NBLIEN) += 1
    I = instr(1,CHAINE,"+")
    J = instr(1,CHAINE,"-")
    If I & J : I = min(I,J)
    Elsif J & !I : I = J
    Endif
    If I
     TBCLE(NBLIEN,TBNCLE(NBLIEN)) = left$(CHAINE,I-1) : CHAINE = right$(CHAINE,I+1)
    Else
     TBCLE(NBLIEN,TBNCLE(NBLIEN)) = CHAINE : CHAINE = ""
    Endif
   Wend
   CHAINE = [F:ATZ]EXPLIEN
   K = 0
   While CHAINE<>""
    I = instr(1,CHAINE,";")
    If I
     K += 1
     TBZCLE(NBLIEN,K) = left$(CHAINE,I-1)
     CHAINE = right$(CHAINE,I+1)
    Elsif I & left$(CHAINE,I-1)="[V]GSUPCLE"
     CHAINE = right$(CHAINE,I+1)
    Else
     K += 1
     TBZCLE(NBLIEN,K) = CHAINE
     CHAINE = ""
    Endif
    If left$(TBZCLE(NBLIEN,K),1)>="A" & left$(TBZCLE(NBLIEN,K),1)<="Z"
     Read [ATZ2]CODZONE = [F:ATZ]CODFIC;TBZCLE(NBLIEN,K)
     If !fstat & [F:ATZ2]CODTYP="ADI"
     Read [AMP]CODPAR=2;[F:ATZ2]CODFIC;[F:ATZ2]CODZONE;"ADI"
      If !fstat & num$(evalue([F:AMP]VALPAR))= "909"
       TBZLEG(NBLIEN,K)= "LEG"
      Endif
     Endif
     TBZCLE(NBLIEN,K) = "[F:AAA_]"+TBZCLE(NBLIEN,K)
    Endif
   Wend
   TBZNCLE(NBLIEN)=K
   IFIC = find(FICDES,TBFIC(1..NBFIC))
   If IFIC=0
    If NBFIC<MAXFIC
     NBFIC += 1 : TBFIC(NBFIC) = FICDES
     IFIC = NBFIC
     OKFIC(NBFIC) = 1
     If nomap=DOSSIER
      If filinfo(filpath("FIL",FICDES,"fde"),0)<0
       OKFIC(NBFIC) = 0
      Endif
     Else
      If filinfo(filpath("FIL",FICDES,"fde",DOSSIER),0)<0
       OKFIC(NBFIC) = 0
      Endif
     Endif
     If OKFIC(NBFIC)
      Gosub OUVFIC
     Endif
    Endif
   Endif
  Elsif [F:ATZ]OBLIG=2
   NBOBLIG += 1
   ZOBLIG(NBOBLIG) = [F:ATZ]CODZONE
  Endif
 Endif
Next

# Parcours du fichier

If NBLIEN>0
 NBREC = 0
 For [AAA_]
  Gosub VERF_AAA_
  NBREC += 1
  OK=1 : If !GSERVEUR : Call AFF_BOITE("",NBREC,OK) From GESECRAN : Endif
  If !OK
   INTERRUPT=1 : Break
  Endif
  If STOP : Break : Endif
 Next
Endif

# Fermeture fichiers

For IFIC=1 To NBFIC
 If OKFIC(IFIC) : Gosub FERFIC : Endif
Next IFIC
Return

## Vérif d'un lien pour un enreg

$VERF_AAA_
For L=1 To NBLIEN
 FICDES = FICLIEN(L)
 IFIC = find(FICDES,TBFIC(1..NBFIC))
 If OKFIC(IFIC)
  CFIC = "[F:L"+format$("N0:2#",IFIC)+"]"
  GFIC = "[G:L"+format$("N0:2#",IFIC)+"]"
  Gosub DEFAUT
  If OK
   Gosub VERF_LIEN
  Endif
 Endif
Next L

## Vérif des zones obligatoires

For L=1 To NBOBLIG
 D = evalue("dim([F:AAA_]"+ZOBLIG(L)+")")
 T = evalue("type([F:AAA_]"+ZOBLIG(L)+")")
 For J=1 To D
  K = 1
  Case T
   When 1,2,4,5,6,7,8,9
    If evalue("[F:AAA_]"+ZOBLIG(L)+"("+num$(J-1)+")")=0       : K = 0 : Endif
   When 3
    If evalue("[F:AAA_]"+ZOBLIG(L)+"("+num$(J-1)+")")=[0/0/0] : K = 0 : Endif
   When Default
    If evalue("[F:AAA_]"+ZOBLIG(L)+"("+num$(J-1)+")")=""      : K = 0 : Endif
  Endcase
  If !K
   Gosub ERR_OBLIG
  Endif
 Next J
Next L

Return

$VERF_LIEN
For J=0 To TBDIME(L)-1
 If TBOBLIG(L)<>2
  Case TBTYP(L)
   When 1,2,3,4,5,6
    VALNUL =  (evalue("[F:AAA_]"+TBZONE(L)+"("+num$(J)+")",0) = 0)
   When 8
    VALNUL =  (evalue("[F:AAA_]"+TBZONE(L)+"("+num$(J)+")",0) = [0/0/0])
   When 7
    VALNUL =  (evalue("[F:AAA_]"+TBZONE(L)+"("+num$(J)+")",0) = "")
  Endcase
 Else
  VALNUL = 0
 Endif
 If !VALNUL
  Raz [F]
  VALCLE = ""
  SUPCLE = 0
  For K=1 To TBNCLE(L)
   ERRAS = 0
   indice = J
   If TBZCLE(L,K)=""
    Onerrgo ERR_AS
    Assign CFIC+TBCLE(L,K) With evalue("[F:AAA_]"+TBZONE(L)+"("+num$(J)+")")
    VALCLE -= num$(evalue("[F:AAA_]"+TBZONE(L)+"("+num$(J)+")"))
    Onerrgo ERRR
    If ERRAS<>0
     Call ECR_TRACE("Error assign"-CFIC+TBCLE(L,K)-"With"-"[F:AAA_]"+TBZONE(L)+"("+num$(J)+")",1) From GESECRAN
    Endif
   Elsif TBZCLE(L,K) = "[V]GSUPCLE"
    SUPCLE = TBZNCLE(L)-1
   Else
    Onerrgo ERR_AS
    Assign CFIC+TBCLE(L,K) With evalue(TBZCLE(L,K))
    VALCLE -= num$(evalue(TBZCLE(L,K)))
    Onerrgo ERRR
    If ERRAS
     Call ECR_TRACE("Error assign"-CFIC+TBCLE(L,K)-"With"-TBZCLE(L,K),1) From GESECRAN
    Endif
   Endif
  Next K
  If SUPCLE
   Assign GFIC+"currind" With 1
   Assign GFIC+"currlen" With SUPCLE
  Else
   Assign GFIC+"currind" With 1
   Assign GFIC+"currlen" With 0
  Endif
  Read =
  If fstat>2
   HASLEG = 0
   For K=1 To TBNCLE(L)
    If TBZLEG(L,K)="LEG"
     Assign CFIC+TBCLE(L,K) With ""
     HASLEG  = 1
    Endif
   Next
   If HASLEG  = 1
    Read =
   Endif
   If fstat>2 : Gosub ERR_LIEN : Endif
  Endif
 Endif
Next J
Return

$ERR_AS
ERRAS = errn
Resume

$ERR_LIEN
TYPERR = 1
Goto ERREUR

$ERR_OBLIG
TYPERR = 2
Goto ERREUR

$ERREUR
If FICORG="APLSTD"     & TBZONE(L)="LAN"    &  vireblc(VALCLE,2)="XXX" : Return : Endif
If FICORG="ATEXTRA"    & TBZONE(L)="LANGUE" &  vireblc(VALCLE,2)="imp" : Return : Endif
If FICORG="ABITABLNK"  & TBZONE(L)="CODLNK"                            : Return : Endif

If !ERR
 Call ECR_TRACE(string$(60,"-"),0) From GESECRAN
 Call ECR_TRACE(mess(166,115,1)-FICORG,0) From GESECRAN : # Anomalies sur la table
Endif
ERR += 1
TOTERR += 1
Read [ATI]NUMLIG(2) = FICORG;1
CHAINE = [F:ATI]DESCRIPT
GCLE = ""
While CHAINE<>""
 I1 = instr(1,CHAINE,"+")
 J1 = instr(1,CHAINE,"-")
 If I1 & J1 : I1 = min(I1,J1)
 Elsif J1 & !I1 : I1 = J1
 Endif
 If I1
  SCLE = left$(CHAINE,I1-1) : CHAINE = right$(CHAINE,I1+1)
 Else
  SCLE = CHAINE : CHAINE = ""
 Endif
 GCLE -= num$(evalue("[F:AAA_]"+SCLE))
Wend
Case TYPERR
 When 1 : # Liens
  If VALCLE="" : VALCLE="''" : Endif
   # Clé/Lien incorrect vers
   Call ECR_TRACE("   "+mess(55,123,1)+":"-GCLE-mess(162,115,1)-TBZONE(L)-mess(167,115,1)-FICDES-"("+VALCLE+")",1) From GESECRAN
 When 2 : # Obligatoire
   Call ECR_TRACE("   "+mess(55,123,1)+":"-GCLE-mess(162,115,1)-ZOBLIG(L)-mess(10,123,1),1) From GESECRAN
Endcase
Return

####################################################################
$DEFAUT
Case IFIC
 When 01 : Default File [L01]
 When 02 : Default File [L02]
 When 03 : Default File [L03]
 When 04 : Default File [L04]
 When 05 : Default File [L05]
 When 06 : Default File [L06]
 When 07 : Default File [L07]
 When 08 : Default File [L08]
 When 09 : Default File [L09]
 When 10 : Default File [L10]
 When 11 : Default File [L11]
 When 12 : Default File [L12]
 When 13 : Default File [L13]
 When 14 : Default File [L14]
 When 15 : Default File [L15]
 When 16 : Default File [L16]
 When 17 : Default File [L17]
 When 18 : Default File [L18]
 When 19 : Default File [L19]
 When 20 : Default File [L20]
 When 21 : Default File [L21]
 When 22 : Default File [L22]
 When 23 : Default File [L23]
 When 24 : Default File [L24]
 When 25 : Default File [L25]
 When 26 : Default File [L26]
 When 27 : Default File [L27]
 When 28 : Default File [L28]
 When 29 : Default File [L29]
 When 30 : Default File [L30]
Endcase
Return

$OUVFIC
If nomap=DOSSIER
 Case IFIC
  When 01 : Local File =FICDES [L01]
  When 02 : Local File =FICDES [L02]
  When 03 : Local File =FICDES [L03]
  When 04 : Local File =FICDES [L04]
  When 05 : Local File =FICDES [L05]
  When 06 : Local File =FICDES [L06]
  When 07 : Local File =FICDES [L07]
  When 08 : Local File =FICDES [L08]
  When 09 : Local File =FICDES [L09]
  When 10 : Local File =FICDES [L10]
  When 11 : Local File =FICDES [L11]
  When 12 : Local File =FICDES [L12]
  When 13 : Local File =FICDES [L13]
  When 14 : Local File =FICDES [L14]
  When 15 : Local File =FICDES [L15]
  When 16 : Local File =FICDES [L16]
  When 17 : Local File =FICDES [L17]
  When 18 : Local File =FICDES [L18]
  When 19 : Local File =FICDES [L19]
  When 20 : Local File =FICDES [L20]
  When 21 : Local File =FICDES [L21]
  When 22 : Local File =FICDES [L22]
  When 23 : Local File =FICDES [L23]
  When 24 : Local File =FICDES [L24]
  When 25 : Local File =FICDES [L25]
  When 26 : Local File =FICDES [L26]
  When 27 : Local File =FICDES [L27]
  When 28 : Local File =FICDES [L28]
  When 29 : Local File =FICDES [L29]
  When 30 : Local File =FICDES [L30]
 Endcase
Else
 Case IFIC
  When 01 : Local File =DOSSIER+"."+FICDES [L01]
  When 02 : Local File =DOSSIER+"."+FICDES [L02]
  When 03 : Local File =DOSSIER+"."+FICDES [L03]
  When 04 : Local File =DOSSIER+"."+FICDES [L04]
  When 05 : Local File =DOSSIER+"."+FICDES [L05]
  When 06 : Local File =DOSSIER+"."+FICDES [L06]
  When 07 : Local File =DOSSIER+"."+FICDES [L07]
  When 08 : Local File =DOSSIER+"."+FICDES [L08]
  When 09 : Local File =DOSSIER+"."+FICDES [L09]
  When 10 : Local File =DOSSIER+"."+FICDES [L10]
  When 11 : Local File =DOSSIER+"."+FICDES [L11]
  When 12 : Local File =DOSSIER+"."+FICDES [L12]
  When 13 : Local File =DOSSIER+"."+FICDES [L13]
  When 14 : Local File =DOSSIER+"."+FICDES [L14]
  When 15 : Local File =DOSSIER+"."+FICDES [L15]
  When 16 : Local File =DOSSIER+"."+FICDES [L16]
  When 17 : Local File =DOSSIER+"."+FICDES [L17]
  When 18 : Local File =DOSSIER+"."+FICDES [L18]
  When 19 : Local File =DOSSIER+"."+FICDES [L19]
  When 20 : Local File =DOSSIER+"."+FICDES [L20]
  When 21 : Local File =DOSSIER+"."+FICDES [L21]
  When 22 : Local File =DOSSIER+"."+FICDES [L22]
  When 23 : Local File =DOSSIER+"."+FICDES [L23]
  When 24 : Local File =DOSSIER+"."+FICDES [L24]
  When 25 : Local File =DOSSIER+"."+FICDES [L25]
  When 26 : Local File =DOSSIER+"."+FICDES [L26]
  When 27 : Local File =DOSSIER+"."+FICDES [L27]
  When 28 : Local File =DOSSIER+"."+FICDES [L28]
  When 29 : Local File =DOSSIER+"."+FICDES [L29]
  When 30 : Local File =DOSSIER+"."+FICDES [L30]
 Endcase
Endif
Return

$FERFIC
Case IFIC
 When 01 : Close Local File [L01]
 When 02 : Close Local File [L02]
 When 03 : Close Local File [L03]
 When 04 : Close Local File [L04]
 When 05 : Close Local File [L05]
 When 06 : Close Local File [L06]
 When 07 : Close Local File [L07]
 When 08 : Close Local File [L08]
 When 09 : Close Local File [L09]
 When 10 : Close Local File [L10]
 When 11 : Close Local File [L11]
 When 12 : Close Local File [L12]
 When 13 : Close Local File [L13]
 When 14 : Close Local File [L14]
 When 15 : Close Local File [L15]
 When 16 : Close Local File [L16]
 When 17 : Close Local File [L17]
 When 18 : Close Local File [L18]
 When 19 : Close Local File [L19]
 When 20 : Close Local File [L20]
 When 21 : Close Local File [L21]
 When 22 : Close Local File [L22]
 When 23 : Close Local File [L23]
 When 24 : Close Local File [L24]
 When 25 : Close Local File [L25]
 When 26 : Close Local File [L26]
 When 27 : Close Local File [L27]
 When 28 : Close Local File [L28]
 When 29 : Close Local File [L29]
 When 30 : Close Local File [L30]
Endcase
Return

$ERRR
ER = errn
Call ECR_TRACE(FICORG-":"-errmes$(ER)-num$(errl)-errm,-1) From GESECRAN
Resume

$SEL_TABLE
If nomap=PARAM(1) | PARAM(1)=""
 Local File ATABLE [ATB]
Else
 Local File =PARAM(1)+".ATABLE"   [ATB]
Endif
OBJET = "ATB"
Return

##########################################################################
# Etiquettes du masque UTIBASE [DIA]
##########################################################################
Subprog AS_FICFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [M]FICDEB
Endif
End

Subprog C_FICFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]FICDEB
 mkstat=1 : End
Endif
End

########################################
Subprog B1_NBLIG
Local Integer I
For I=nolign To [M]NBLIG
 [M]MODULE(I-1) = 2
Next I
Affzo 20
End

########################################
Subprog B2_NBLIG
Local Integer I
For I=nolign To [M]NBLIG
 [M]MODULE(I-1) = 1
Next I
Affzo 20
End
