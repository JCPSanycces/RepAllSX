#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT7 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone BPR
mkstat = 0
zoncou = "BPR"
indice = 0
If varmode([M]BPR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPR" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_BPR([M]BPR) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "BPR" : GZNUM = 46536 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ACCCOD
mkstat = 0
zoncou = "ACCCOD"
indice = 0
If varinit([M]ACCCOD,indice)=0
 SAVACT = GACTION : GACTION = "INITACCCOD"
 Call INITACCCOD([M]ACCCOD,27) From TRTX3
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]ACCCOD,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call AS_ACCCOD([M]ACCCOD) From SUBEML2
  GACTION = SAVACT
  If mkstat=1 : Raz [M]ACCCOD : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "ACCCOD" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   If vireblc([M]ACCCOD,2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTCAC"
    Call CONTCAC([M]ACCCOD,"27") From SUBCAC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     Call CONTROLE("CAC","",[M]ACCCOD,"27",mkstat) From CONTOBJ
     If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "STD"
      Call C_ACCCOD([M]ACCCOD) From SUBEML2
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DSP
mkstat = 0
zoncou = "DSP"
indice = 0
WCHAR = [M]DSP
If varmode([M]DSP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DSP" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("DSP","!",[M]DSP,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_DSP([M]DSP) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]DSP or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_DSP([M]DSP) From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone DSPDES
mkstat = 0
zoncou = "DSPDES"
indice = 0
If varinit([M]DSPDES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DSPDES,"CADSP","DESTRA",[M:EMP7]DSP,"") From ATEXTRA
 GACTION = SAVACT
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBAXE
mkstat = 0
zoncou = "NBAXE"
indice = 0
status = 1
zoncou = "NBAXE"
If varmode([M]NBAXE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBAXE" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBAXE
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBAXE = nolign
   status = 75
   Call SAI_NBAXE(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBRRIB
mkstat = 0
zoncou = "NBRRIB"
indice = 0
status = 1
zoncou = "NBRRIB"
If varmode([M]NBRRIB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRRIB" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRRIB
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRRIB = nolign
   status = 75
   Call SAI_NBRRIB(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBRRIB From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBRRIB" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone BDFECOCOD
mkstat = 0
zoncou = "BDFECOCOD"
indice = 0
If varinit([M]BDFECOCOD,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]BDFECOCOD,"10309","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]BDFECOCOD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "BDFECOCOD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]BDFECOCOD,"10309","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "BDFECOCOD" : GZNUM = 7511 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]BDFECOCOD,"10309",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "BDFECOCOD" : GZNUM = 7511 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBAXE(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBAXE
mkstat = 0
zoncou = "NBAXE"

## Zone CCE
mkstat = 0
zoncou = "CCE"
SAVACT = GACTION : GACTION = "INICCEFMT"
Call INICCEFMT(num$([M]DIE(nolign-1))) From SETGLBDIE
GACTION = SAVACT
If mkstat=1 : Raz [M]CCE(indice) : Endif
If !mkstat
 If varmode([M]CCE,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call AS_CCE([M]CCE(indice)) From SUBEML2
  GACTION = SAVACT
  If mkstat=1 : Raz [M]CCE(indice) : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "CCE" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   Call CONTROLE("CCE","!",[M]CCE(indice),num$([M]DIE(nolign-1)),mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 21 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CCE([M]CCE(indice)) From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 21 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone INICCE
mkstat = 0
zoncou = "INICCE"
IMPENT = [M]INICCE(indice)
If varinit([M]INICCE,indice)=0
 IMPENT = 1
Endif
If varmode([M]INICCE,indice)=0
 Call INICOMBO(10315) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_INICCE(IMPENT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10315,1))))
 Endif
 [M]INICCE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "INICCE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]INICCE(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "INICCE" : GZNUM = 13750 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]INICCE(indice) = IMPENT

## Zone NBAXE
mkstat = 0
zoncou = "NBAXE"

End

####################################
## Bloc tableau 3
####################################
