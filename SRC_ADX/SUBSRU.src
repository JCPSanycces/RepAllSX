#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################
# Saisie des règles de gestion par défaut
# Alimentation de la table TABSTORUL
# Action SAISTORUL de type saisie de fenêtre
##########################################################################

# Règles par défaut pour les types
#----------------------------------
# Type de mouvement (ML 704)    --> Poste du tableau flux d'entrée
#  1 : Entrée diverse                        1
#  3 : Réception                             2
# 16 : Réception sous-traitance              3
#  5 : Entrée OF                             4
#  8 : Contrôle qualité                      5
# 12 : Retour livraison                      6
# 18 : Retour livraison prêt                 7
# 33 : Retour livraison sous-traitance       8
# 19 : Réintégration stock                   9
# 26 : Chgt stock (statut et emplacement)   10
# 28 : Entrée transfert interne             11
# 34 : Demande analyse                      12  mis en inactif (accord Gilles Lefebvre)
#----------------------------------
# Type de mouvement (ML 704)    --> Poste du tableau flux de sortie
#  2 : Sortie diverse                        1
#  4 : Livraison client                      2
# 17 : Livraison prêt                        3
# 20 : Livraison sous-traitance              4
#  6 : Sortie OF                             5
# 29 : Sortie ordre sous-traitance           6
# 11 : Retour réception                      7
# 32 : Retour réception sous-traitance       8
# 24 : Demande de service                    9
# 25 : Réapprovisionnement                  10
# 27 : Sortie transfert interne             11
#----------------------------------
$ACTION
Case ACTION
 When "OUVRE"        Gosub OUVRE
 When "DEBUT"        Gosub DEBUT
 When "SETBOUT"      Gosub SETBOUT
 When "ABA"          Gosub ABA
 When "ENR"          Gosub ENR
 When "FIN"          Gosub FIN
 When "APRES_MODIF"  Gosub APRES_MODIF
Endcase
Return

$OUVRE
Local Char SYMBOLE(10)
If !clalev([F:SRU]) Local File TABSTORUL [SRU] Endif

Local Mask ITGSTA [ISTA] # pour les sous-statuts en tableau
Local Integer I
Return

$DEBUT
# Si les enregistrements n'existent pas : précharger le tableau (1ère fois)
# S'ils existent : charger le tableau après lecture des SRU
# (avec les types de mouvements nécesssitant des paramétrages)

#----------------
# Flux d'entrée
#----------------
Raz [M:SRU1]

Raz I
For [SRU] Where TCLCOD="" & STOFCY="" & find(TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
  Case [F:SRU]TRSTYP
   When  1  : nolign =  1
   When  3  : nolign =  2
   When 16  : nolign =  3
   When  5  : nolign =  4
   When  8  : nolign =  5
   When 12  : nolign =  6
   When 18  : nolign =  7
   When 33  : nolign =  8
   When 19  : nolign =  9
   When 26  : nolign = 10
   When 28  : nolign = 11
#   When 34   nolign = 12
  Endcase
  [M:SRU1] = [F:SRU]
  #--- Issue X3-53322
  If dim([M:SRU1]DACCTR)>0
    If [M:SRU1]DACCTR(nolign-1)=0 [M:SRU1]DACCTR(nolign-1)=1 Endif
  Endif
  #---
  I += 1
Next

# Si tout le tableau n'est pas rempli
If I < 11
  For I = 1 To 11
    If [M:SRU1]TRSTYP(I-1)=0
      Case I
        When  1  : [M:SRU1]TRSTYP(I-1) =  1
        When  2  : [M:SRU1]TRSTYP(I-1) =  3
        When  3  : [M:SRU1]TRSTYP(I-1) = 16
        When  4  : [M:SRU1]TRSTYP(I-1) =  5
        When  5  : [M:SRU1]TRSTYP(I-1) =  8
        When  6  : [M:SRU1]TRSTYP(I-1) = 12
        When  7  : [M:SRU1]TRSTYP(I-1) = 18
        When  8  : [M:SRU1]TRSTYP(I-1) = 33
        When  9  : [M:SRU1]TRSTYP(I-1) = 19
        When 10  : [M:SRU1]TRSTYP(I-1) = 26
        When 11  : [M:SRU1]TRSTYP(I-1) = 28
#       When 12    [M:SRU1]TRSTYP(I-1) = 34
      Endcase
      [M:SRU1]AUZSTA(I-1) = 1
      [M:SRU1]AUZSST(I-1) = "A*"
      [M:SRU1]FORSTA(I-1) = 'pat(%,"A*")<>0'
      [M:SRU1]UPDFLG(I-1) = 1
      #--- Issue X3-53322
      If dim([M:SRU1]DACCTR)>0
        [M:SRU1]DACCTR(I-1) = 1
      Endif
      #---
    Endif
  Next
Endif

[M:SRU1]NBSRU1 = 11

Affzo [M:SRU1]1-99

nolign=1
For nolign=1 To [M:SRU1]NBSRU1
  Case nolign
   When 4      : If dim([M:SRU1]DACCTR)>0           : #--- Issue X3-53322 ajout 4 : entrée OF (à supprimer quand GP)
                   Grizo [M:SRU1]DACCTR(nolign-1)
                   [M:SRU1]DACCTR(nolign-1)    = 1
                 Endif
   When 5      : Grizo [M:SRU1]QLYCTLFLG(nolign-1)  : # Ctrl qualité
                 [M:SRU1]QLYCTLFLG(nolign-1)   = 1
                 If dim([M:SRU1]DACLOT)>0
                   Grizo [M:SRU1]DACLOT(nolign-1)
                   Grizo [M:SRU1]LOTSUPINH(nolign-1)
                   [M:SRU1]DACLOT(nolign-1)    = 2
                   [M:SRU1]LOTSUPINH(nolign-1) = 1
                 Endif
                 If dim([M:SRU1]DACCTR)>0           : #--- Issue X3-53322 ajout DACCTR
                   Grizo [M:SRU1]DACCTR(nolign-1)
                   [M:SRU1]DACCTR(nolign-1)    = 1
                 Endif
   When 7,8    : If dim([M:SRU1]DACLOT)>0          : # Retour prêt & sst  # issue X3-53322 supp du 11
                   Grizo [M:SRU1]DACLOT(nolign-1)
                   Grizo [M:SRU1]LOTSUPINH(nolign-1)
                   [M:SRU1]DACLOT(nolign-1)    = 2
                   [M:SRU1]LOTSUPINH(nolign-1) = 1
                 Endif
   When 9      : If dim([M:SRU1]DACCTR)>0           : #--- Issue X3-53322 ajout 9 : réintégration stock (à supprimer quand GP)
                   Grizo [M:SRU1]DACCTR(nolign-1)
                   [M:SRU1]DACCTR(nolign-1)    = 1
                 Endif
   When 10     : Grizo [M:SRU1]DEFSTA(nolign-1)    : # Chgt stock
                 Raz [M:SRU1]DEFSTA(nolign-1)
                 If dim([M:SRU1]DACLOT)>0
                   Grizo [M:SRU1]DACLOT(nolign-1)
                   Grizo [M:SRU1]LOTSUPINH(nolign-1)
                   [M:SRU1]DACLOT(nolign-1)    = 2
                   [M:SRU1]LOTSUPINH(nolign-1) = 1
                 Endif
                 If dim([M:SRU1]DACCTR)>0           : #--- Issue X3-53322 ajout DACCTR
                   Grizo [M:SRU1]DACCTR(nolign-1)
                   [M:SRU1]DACCTR(nolign-1)    = 1
                 Endif
   When 11     : If dim([M:SRU1]DACLOT)>0           : #--- Issue X3-53322 ajout 11 : trf interne
                   Grizo [M:SRU1]DACLOT(nolign-1)
                   Grizo [M:SRU1]LOTSUPINH(nolign-1)
                   [M:SRU1]DACLOT(nolign-1)    = 2
                   [M:SRU1]LOTSUPINH(nolign-1) = 1
                 Endif
                 If dim([M:SRU1]DACCTR)>0
                   Grizo [M:SRU1]DACCTR(nolign-1)
                   [M:SRU1]DACCTR(nolign-1)    = 1
                 Endif
#   When 12     : If dim([M:SRU1]DACLOT)>0          : # Demande analyse
#                   Grizo [M:SRU1]DACLOT   (nolign-1)
#                   Grizo [M:SRU1]LOTSUPINH(nolign-1)
#                   Grizo [M:SRU1]AUZSTA   (nolign-1)
#                   Grizo [M:SRU1]QLYCTLFLG(nolign-1)
#                   [M:SRU1]DACLOT         (nolign-1) = 1
#                   [M:SRU1]LOTSUPINH      (nolign-1) = 1
#                   [M:SRU1]AUZSTA         (nolign-1) = 2
#                   [M:SRU1]QLYCTLFLG      (nolign-1) = 2
#                 Endif

  Endcase
Next nolign

#----------------
# Flux de sortie
#----------------
Raz [M:SRU2]

Raz I
For [SRU] Where TCLCOD="" & STOFCY="" & find(TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
  Case [F:SRU]TRSTYP
   When  2  : nolign =  1
   When  4  : nolign =  2
   When 17  : nolign =  3
   When 20  : nolign =  4
   When  6  : nolign =  5
   When 29  : nolign =  6
   When 11  : nolign =  7
   When 32  : nolign =  8
   When 24  : nolign =  9
   When 25  : nolign = 10
   When 27  : nolign = 11
  Endcase
  [M:SRU2] = [F:SRU]
  I += 1
Next

# Si tout le tableau n'est pas rempli
If I < 11
  For I = 1 To 11
    If [M:SRU2]TRSTYP(I-1)=0
      Case I
        When  1  : [M:SRU2]TRSTYP(I-1) =  2
        When  2  : [M:SRU2]TRSTYP(I-1) =  4
        When  3  : [M:SRU2]TRSTYP(I-1) = 17
        When  4  : [M:SRU2]TRSTYP(I-1) = 20
        When  5  : [M:SRU2]TRSTYP(I-1) =  6
        When  6  : [M:SRU2]TRSTYP(I-1) = 29
        When  7  : [M:SRU2]TRSTYP(I-1) = 11
        When  8  : [M:SRU2]TRSTYP(I-1) = 32
        When  9  : [M:SRU2]TRSTYP(I-1) = 24
        When 10  : [M:SRU2]TRSTYP(I-1) = 25
        When 11  : [M:SRU2]TRSTYP(I-1) = 27
      Endcase
      [M:SRU2]AUZSTA(I-1) = 1
      [M:SRU2]AUZSST(I-1) = "A*"
      [M:SRU2]FORSTA(I-1) = 'pat(%,"A*")<>0'
      [M:SRU2]UPDFLG(I-1) = 1
    Endif
  Next
Endif

[M:SRU2]NBSRU2 = 11

Affzo [M:SRU2]1-99

nolign=1
For nolign=1 To [M:SRU2]NBSRU2
  Case nolign
   When 7, 8 : If dim([M:SRU2]AUZPRO)>0             : #--- HCB106217
                  Grizo [M:SRU2]AUZPRO(nolign-1)    : #--- TS 106217
                  [M:SRU2]AUZPRO(nolign-1)=3        : #--- TS 106217
                  Grizo [M:SRU2]AUZACT(nolign-1)    : #--- TS 106217
                  [M:SRU2]AUZACT(nolign-1)=3        : #--- TS 106217
                  Grizo [M:SRU2]AUZSTP(nolign-1)    : #--- TS 106217
                  [M:SRU2]AUZSTP(nolign-1)=3        : #--- TS 106217
                  Grizo [M:SRU2]ORDVER(nolign-1)    : #--- TS 106217
                  [M:SRU2]ORDVER(nolign-1)=1        : #--- TS 106217
               Endif                                : #--- HCB106217
   When 11   : If dim([M:SRU2]LOCNUM)>0          : # Sortie trf
                 Grizo [M:SRU2]LOCNUM(nolign-1)
                 Grizo [M:SRU2]LOCNUM2(nolign-1)
                 Grizo [M:SRU2]LOCNUM3(nolign-1)
                 [M:SRU2]LOCNUM(nolign-1) =0
                 [M:SRU2]LOCNUM2(nolign-1)=0
                 [M:SRU2]LOCNUM3(nolign-1)=0
                 If dim([M:SRU2]ORDVER)>0           : #--- HCB106217
                    Grizo [M:SRU2]ORDVER(nolign-1)  : #--- TS 106217
                    [M:SRU2]ORDVER(nolign-1)=1      : #--- TS 106217
                 Endif                              : #--- HCB106217
               Endif
  Endcase
Next nolign

# pour Accès EXCLUSIF !! (car gestion tableau)
SYMBOLE = "TABSTORUL"
Lock =SYMBOLE With lockwait = 0
Return

$FIN
Unlock =SYMBOLE
Return

$APRES_MODIF
# sur une modif dans le tableau, passer en mode Modif et poser un verrou logique
If REP=""
  # si verrou
  Lock =SYMBOLE With lockwait = 0
  # > mettre l'indicateur dans la ligne du bas
  If fstat
    GMESSAGE = mess(10,100,1) : #  Modification en cours sur un autre poste
    GERR = 1
  Else
    REP = "M"
    If instr(1,dbgstr(1),"SRU1")=3
      [M:SRU1]UPDFLG(nolign-1) = 1 : # car REP="M" ne suffit pas apparemment
    Else
      [M:SRU2]UPDFLG(nolign-1) = 1
    Endif
  Endif
Endif
Return

$SETBOUT
# à l'entrée dans le tableau, activer Enregistrer et Abandon
If find(1,[M:SRU1]UPDFLG(0..[M:SRU1]NBSRU1-1)) |
&  find(1,[M:SRU2]UPDFLG(0..[M:SRU2]NBSRU2-1))
  CHBOU += "EA"
Else
  Call VIREBOUT(CHBOU,"EA") From GOBJET
Endif
Return

$ABA
# obligé à enregistrer si les enreg n'ont pas encore été créés ??

# réafficher les enreg d'origine : équivalent de
Raz [M:SRU1]
Raz [M:SRU2]
REP = ""
Gosub DEBUT
Gosub SETBOUT From GSAISIE
Return

$ENR
# (ré)écrire les enregistrements avec Catégorie et Site vides !
Trbegin [SRU]
Raz GERR, GOK

For nolign=1 To [M:SRU1]NBSRU1
  If [M:SRU1]UPDFLG(nolign-1)=1
    Readlock [SRU]SRU0="";"";[M:SRU1]TRSTYP(nolign-1);""
    If fstat = 5
      Raz [F:SRU]
      [F:SRU] = [M:SRU1]
      [F:SRU]SHLLOT = 1
      [F:SRU]CREDAT = date$
      [F:SRU]CREUSR = GUSER
      Write [SRU]
      If fstat : GOK=0 : GERR=1 : Break : Endif
    Elsif fstat = 1
      GOK = -1 : GERR = 1
      Call FSTA("SRU") From GLOCK
      Break
    Elsif !fstat
      [F:SRU] = [M:SRU1]
      Raz [F:SRU]LOCNUM2
      Raz [F:SRU]LOCNUM3
      [F:SRU]SHLLOT = 1
      [F:SRU]UPDDAT = date$
      [F:SRU]UPDUSR = GUSER
      Rewrite [SRU]
      If fstat : GOK=0 : GERR=1 : Break : Endif
    Endif
  Endif
Next

If GERR=1 Goto ENR_SUI Endif

For nolign=1 To [M:SRU2]NBSRU2
  If [M:SRU2]UPDFLG(nolign-1)=1
    Readlock [SRU]SRU0="";"";[M:SRU2]TRSTYP(nolign-1);""
    If fstat = 5
      Raz [F:SRU]
      [F:SRU] = [M:SRU2]
      [F:SRU]QLYCTLFLG = 1
      [F:SRU]DACLOT    = 2
      [F:SRU]LOTSUPINH = 1
      [F:SRU]CREDAT = date$
      [F:SRU]CREUSR = GUSER
      Write [SRU]
      If fstat : GOK=0 : GERR=1 : Break : Endif
    Elsif fstat = 1
      GOK = -1 : GERR = 1
      Call FSTA("SRU") From GLOCK
      Break
    Elsif !fstat
      [F:SRU] = [M:SRU2]
      Raz [F:SRU]DEFSTA
      [F:SRU]QLYCTLFLG = 1
      [F:SRU]DACLOT    = 2
      [F:SRU]LOTSUPINH = 1
      [F:SRU]UPDDAT = date$
      [F:SRU]UPDUSR = GUSER
      Rewrite [SRU]
      If fstat : GOK=0 :GERR=1 : Break : Endif
    Endif
  Endif
Next

$ENR_SUI

If GERR<>1
  Commit
  Raz [M:SRU1]UPDFLG
  Raz [M:SRU2]UPDFLG
  Raz REP
Elsif GOK=0
  GERR = 1
  GMESSAGE = mess(13,100,1)-"TABSTORUL"
  Rollback
Else
  Rollback
Endif

Return

