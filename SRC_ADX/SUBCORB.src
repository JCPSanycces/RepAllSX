######################################################################################################
$MAJLDS
  #Liens avec la lead
  If [M:COR0]CNTNUM = "" Then
    Return
  Endif
  #
  Gosub TEST_LDS_M_COR_M_CORSAVE
  If IBMODIF = 0 Then
    Return
  Endif
  #On a eu une modif sur la lead, il faut la reporté
  Readlock [LDS]LDS0=[M:COR0]CNTNUM
  If fstat <> 0 Then
    IBERROR = 1
    GERR = 1
    #Erreur : impossible de locker la lead - ":"-[M:COR0]CNTNUM
    GMESSAGE = mess(466,177,1)- ":"-[M:COR0]CNTNUM
    GOK = 0
  Endif
  #
  # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
  Raz [BPA]
  Filter [BPA] Where BPATYP = 6 and BPANUM = [M:COR0]CNTNUM and BPAADDFLG = 2
  For [BPA]
    Break
  Next
  Filter [BPA]
  Readlock [BPA]BPA0=6;[M:COR0]CNTNUM;[F:BPA]BPAADD
  If fstat <> 0 Then
    IBERROR = 1
    GERR = 1
    #Erreur : impossible de locker l'adresse- ":"-"6" - "/" - [M:COR0]CNTNUM - "/" - [F:BPA]BPAADD
    GMESSAGE = mess(425,177,1)- ":" - "6" - "/" - [M:COR0]CNTNUM - "/" - [F:BPA]BPAADD
    GOK = 0
  Endif
  #
  If IBERROR = 0 Then
    #On test si les valeurs sont différentes
    Gosub TEST_LDS_M_COR_F_LDS
  Endif
  #
  If IBMODIF = 1 and IBERROR = 0 Then
    [F:LDS]CPYNAM = [M:COR2]BPRLIB
    # FGR 20/03/2008 : X3Suivi46077 Le val ne sert à rien les 2 rubriques sont de type A(3)
    #[F:LDS]FNC = val([M:COR2]FNC)
    [F:LDS]FNC = [M:COR2]FNC
    [F:LDS]FNCLIB = [M:COR2]FNCLIB
    [F:LDS]MSS = [M:COR2]MSS
    [F:LDS]SRV = [M:COR2]SRV
    [F:LDS]UPDUSR = GUSER
    [F:LDS]UPDDAT = date$
    Rewrite [LDS]
    If fstat <> 0 Then
      IBERROR = 1
      #Erreur lors de la modification de la lead+ " (a) : "+[M:COR0]CNTNUM
      GMESSAGE = mess(467,177,1) - ":" - [M:COR0]CNTNUM
      GOK = 0
    Endif
    #
    # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
    [F:BPA]BPADES = [M:COR2]CPYBPADES
    If dim([M:COR2]CPYADD(0)) > 0 Then
      [F:BPA]BPAADDLIG(0) = [M:COR2]CPYADD(0)
    Endif
    If dim([M:COR2]CPYADD(1)) > 0 Then
      [F:BPA]BPAADDLIG(1) = [M:COR2]CPYADD(1)
    Endif
    # FGR 13/01/2010 : X3SUIVI60986
    #If dim([M:LDS2]CPYADD(2)) > 0 Then
    If dim([M:COR2]CPYADD(2)) > 0 Then
      [F:BPA]BPAADDLIG(2) = [M:COR2]CPYADD(2)
    Endif
    [F:BPA]POSCOD = [M:COR2]CPYZIP
    [F:BPA]CTY = [M:COR2]CPYCTY
    If dim([M:COR2]CPYSAT) > 0 Then
      [F:BPA]SAT = [M:COR2]CPYSAT
    Endif
    [F:BPA]CRY = [M:COR2]CPYCRY
    [F:BPA]CRYNAM = [M:COR2]CPYCRYNAM
    [F:BPA]WEB(0) = [M:COR2]CPYEML  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]WEB
    [F:BPA]TEL(0) = [M:COR2]CPYTEL  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
    # FGR 21/08/2015 : X3SUIVI109994 (début)
    [F:BPA]TEL(1) = [M:COR2]CPYFAX
    If dim([F:BPA]FAX) >= 0 Then
      [F:BPA]FAX = [M:COR2]CPYFAX
    Endif
    [F:BPA]TEL(4) = [M:COR2]CPYMOB
    If dim([F:BPA]MOB) >= 0 Then
      [F:BPA]MOB = [M:COR2]CPYMOB
    Endif
    # FGR 21/08/2015 : X3SUIVI109994 (fin)
    #
    Rewrite [BPA]
    If fstat <> 0 Then
      IBERROR = 1
      #Erreur lors de la modification de la lead+ " (b) : "+[M:COR0]CNTNUM
      GMESSAGE = mess(467,177,1) - ":" - [M:COR0]CNTNUM
      GOK = 0
    Endif
  Else
    Unlock [LDS]
    Unlock [BPA]
  Endif
  #
  If IBMODIF = 1 and IBERROR = 0 Then
    #On a eu une modif, il faut reporté la modif
    For [CORL] Where [F:CORL]CNTNUM = [M:COR0]CNTNUM
      If IBERROR = 1 Then
        Break
      Endif
      IBTRAITECOR = 1
      Gosub TEST_LDS_F_CORL_F_LDS
      If IBMODIF = 1 and IBTRAITECOR = 1 Then
        [F:CORL]BPRLIB = [F:LDS]CPYNAM
        [F:CORL]FNC = [F:LDS]FNC
        [F:CORL]FNCLIB = [F:LDS]FNCLIB
        [F:CORL]MSS = [F:LDS]MSS
        [F:CORL]SRV = [F:LDS]SRV
        # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
        [F:CORL]CPYBPADES = [F:BPA]BPADES
        If dim([F:BPA]BPAADDLIG(0)) > 0 Then
          [F:CORL]CPYADD(0) = [F:BPA]BPAADDLIG(0)
        Endif
        If dim([F:BPA]BPAADDLIG(1)) > 0 Then
          [F:CORL]CPYADD(1) = [F:BPA]BPAADDLIG(1)
        Endif
        If dim([F:BPA]BPAADDLIG(2)) > 0 Then
          [F:CORL]CPYADD(2) = [F:BPA]BPAADDLIG(2)
        Endif
        [F:CORL]CPYZIP = [F:BPA]POSCOD
        [F:CORL]CPYCTY = [F:BPA]CTY
        If dim([F:BPA]SAT) > 0 Then
          [F:CORL]CPYSAT = [F:BPA]SAT
        Endif
        [F:CORL]CPYCRY = [F:BPA]CRY
        [F:CORL]CPYCRYNAM = [F:BPA]CRYNAM
        [F:CORL]CPYEML = [F:BPA]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]WEB
        [F:CORL]CPYTEL = [F:BPA]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
        [F:CORL]CPYFAX = [F:BPA]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]FAX
        [F:CORL]CPYMOB = [F:BPA]TEL(4)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]MOB
        #
        [F:CORL]UPDUSR = GUSER
        [F:CORL]UPDDAT = date$
        Rewrite [CORL]
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
          GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
          GOK = 0
        Endif
        If IBTRAITECOR = 1 and IBERROR = 0 Then
          Gosub GERE_COP
        Endif
        If IBERROR = 1 Then
          Break
        Endif
      Endif
    Next
  Endif
  If IBERROR = 1 Then
    GOK = 0
  Endif
Return

