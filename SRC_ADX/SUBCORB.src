#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion des correspondants                   Module CRM     0/04/2006
##########################################################################################################
# SAVECLOB                 : Enregistrement des CLOBs
# DELCLOB                  : Suppression des CLOBs
# LOADCLOB                 : Chargement du CLOB compte-rendu
# RAZ_COR1
# RAZ_COR4
# LOADCOP                  : Chargement du tableau des représentants
# VERIFALLCOP              : Verification des représentants
# CREALLCOP                : Création de tous les représentants
# SAVEALLCOP               : Sauvegarde du tableau des représentants
# DELLALLCOP               : Suppression de tous les représentants
# COREXIST                 : Test l'existance d'un correspondant par rapport à un couple tiers/interlocuteur
# CORREPEXIST              : Test l'existance d'un représentant pour un correspondant donnée
# CORREPCRE                :    Création d'un lien pour un représentant donnée
# CORREPDEL                :    suppression d'un lien pour un représentant donnée
# CORGERE                  : Verifie si un correspondant existe pour une personne donnée et sinon le crée
# CORGEREREP               : Verifie si un correspondant/représentant existe pour un représentant sinon le crée
# FORCECOR                 : créer les données de synchro de forçage pour le représentant
# MAJTABLES                : mise à jour des tables liées
# MAJBPR                   : gestion mise à jour de la tables BPR Tiers
# MAJAIN                   : gestion mise à jour de la table AIN interlocuteur
# GERE_COP                 : gestion de l'écriture dans SYD par rapport aux données de CORREP
# TEST_AIN_M_COR_M_CORSAVE : test si différence sur écran pour pour partie AIN interlocuteur
# TEST_AIN_M_COR_F_AIN     : test si différence écran/AIN avec données interlocuteur
# TEST_AIN_F_CORL_F_AIN    : test si différence COR/AIN avec données interlocuteur
# MAJCNT                   : gestion mise à jour contact
# TEST_CNT_M_COR_M_CORSAVE : test si différence sur écran pour pour partie CNT contact
# TEST_CNT_M_COR_F_AIN     : test si différence écran/CNT avec données CNT contact
# TEST_CNT_F_CORL_F_AIN    : test si différence COR/CNT avec données contact
# MAJADR                   : gestion mise à jour des adresses
# TEST_ADR_M_COR_M_CORSAVE : test si différence sur écran pour pour partie Adresse
# TEST_ADR_M_COR_F_ADR     : test si différence écran/BPA avec données adresse
# TEST_ADR_F_CORL_F_ADR    : test si différence COR/BPA avec données adresse
##########################################################################################################
##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
Local Integer IBNEW
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBNEW = 0
  If GOK < 1 Then
    Return
  Endif
  If [M:COR1]CRCCLOB = "" Then
    If [M:COR1]CRCNUM <> "" Then
      #Il faut supprimer le clob
      Gosub DELCLOB
    Endif
    Return
  Endif
  #On a un clob non vide on enregistre
  If [M:COR1]CRCNUM = "" Then
    #Il faut créer le numéro
    IBNEW = 1
    Raz [F:CRC]
    # Récupération du compteur correspondant
    If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", "", GSZCPTCRC, date$, "", [M:COR1]CRCNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
      If IBRETOUR = 1 Then
        [F:CRC]CRCNUM = [M:COR1]CRCNUM
        Affzo [M:COR1]CRCNUM
      Else
        # problème lors de la récupération du compteur
        GERR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GOK = 0
        Return
      Endif
    Endif
  Else
    Read [CRC]CRC0=[M:COR1]CRCNUM
    If fstat <> 0 Then
      # Problème lors de la lecture du clob CRM
      GERR = 1
      GMESSAGE = mess(262,177,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:CRC]CRCTYP = "COR"
  [F:CRC]CRCCLOB = [M:COR1]CRCCLOB
  [F:CRC]CRCCORNUM =[M:COR0]CORNUM
  [F:CRC]CRCAINNUM = [M:COR0]CNTNUM
  [F:CRC]CRCBPATYP = [M:COR2]CPYBPATYP
  If IBNEW = 1 Then
    [F:CRC]CREUSR = GUSER
    [F:CRC]CREDAT = date$
    Write [CRC]
  Else
    [F:CRC]UPDUSR = GUSER
    [F:CRC]UPDDAT = date$
    Rewrite [CRC]
  Endif
  If fstat <> 0 Then
    #Erreur lors de l'enregistrement du clob CRM
    GMESSAGE = mess(263,177,1)
    GERR = 1
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  If GOK < 1 Then
    Return
  Endif
  If [M:COR1]CRCNUM <> "" Then
    Delete [CRC] Where [F:CRC]CRCNUM = [M:COR1]CRCNUM
    If fstat <> 0 Then
      #Erreur lors de la suppression du clob CRM
      GMESSAGE = mess(264,177,1)
      GERR = 1
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
# Chargement du CLOB compte-rendu
######################################################
$LOADCLOB
  Gosub RAZ_COR1
  #Pour l'insatnt on ne gère qu'un clob par correspondant
  For [CRC] Where [F:CRC]CRCCORNUM = [M:COR0]CORNUM and [F:CRC]CRCREP = ""
    [M:COR1]CRCNUM = [F:CRC]CRCNUM
    [M:COR1]CRCCLOB = [F:CRC]CRCCLOB
    Break
  Next
Return

##########################################################################################################
$RAZ_COR1
  Raz [M:COR1]CRCNUM
  Raz [M:COR1]CRCCLOB
Return

##########################################################################################################
$RAZ_COR4
  Raz [M:COR4]NBLIGNCOP
  Raz [M:COR4]COPREP
  Raz [M:COR4]REPNAM
  Raz [M:COR4]AUSNUM
  Raz GTBCORVALREP
  Raz GTBCORVALUSR
  GICORNBREP = 0
Return

##########################################################################################################
$INIT_COPREP
  # FGR 04/07/2008 : X3SUIVI48214 : Initialisation du représentant (courant) par défaut s'il existe
  Read [REP]REP1=GUSER
  If !fstat and [F:REP]REPNUM <> "" Then
    # On ajoute pas de représentant s'il est déjà dans la liste
    If find([F:REP]REPNUM, [M:COR4]COPREP(0..[M:COR4]NBLIGNCOP-1)) = 0 Then
      [M:COR4]NBLIGNCOP += 1
      nolign = [M:COR4]NBLIGNCOP
      [M:COR4]COPREP([M:COR4]NBLIGNCOP-1) = [F:REP]REPNUM
      Call AM_COPREP([M:COR4]COPREP([M:COR4]NBLIGNCOP-1)) From SUBCOR
      Affzo [M:COR4]1-99
    Endif
  Endif
Return

##########################################################################################################
# Affichage type correspondant
$SET_CORTYPMEN
  [M:COR0]CORTYPMEN = 2
  If [M:COR0]CORTYPMEN = 0 Then
    [M:COR0]CORTYPMEN = 1
  Endif
  If [M:COR0]CORTYP = "REP" Then
    [M:COR0]CORTYPMEN = 3
  Else
    [M:COR0]CORTYPMEN = 1
    If [M:COR0]CNTNUM <> "" Then
      Read [AIN]AIN0=[M:COR0]CNTNUM
      If fstat = 0 Then
        If [F:AIN]CNTTYP = 1 Then
          [M:COR0]CORTYPMEN = 1
        Else
          [M:COR0]CORTYPMEN = 2
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Chargement des représentants
$LOADCOP
Local Integer IINDICE

  IINDICE = 0
  Gosub RAZ_COR4
  Filter [COP] Where [F:COP]COPNUM = [M:COR0]CORNUM Order By [F:COP]COPNUM Asc
  For [COP]
    If IINDICE >= dim([M:COR4]COPREP) Then
      Break
    Endif
    [M:COR4]COPREP(IINDICE) = [F:COP]COPREP
    GTBCORVALREP(IINDICE) = [M:COR4]COPREP(IINDICE)
    Read [REP]REP0=[M:COR4]COPREP(IINDICE)
    If fstat = 0 Then
      [M:COR4]REPNAM (IINDICE) = [F:REP]REPNAM
      [M:COR4]AUSNUM (IINDICE) = [F:REP]AUSNUM
    Endif
    GTBCORVALUSR(IINDICE) = [M:COR4]AUSNUM(IINDICE)
    IINDICE += 1
  Next
  Filter [COP]
  [M:COR4]NBLIGNCOP = IINDICE
  GICORNBREP = IINDICE
Return

##########################################################################################################
# Verification des représentants
$VERIFALLCOP
  If GOK < 1 Then
    Return
  Endif

Local Integer IINDICE
Local Integer ILIGNEWORK

  IILIGNE = 0
  While IINDICE < [M:COR4]NBLIGNCOP
    If [M:COR4]COPREP(IINDICE) <> "" Then
      # on vérifie si il n'existe pas en double
      ILIGNEWORK = IINDICE + 1
      While ILIGNEWORK < [M:COR4]NBLIGNCOP
        If [M:COR4]COPREP(ILIGNEWORK) <> "" Then
          If [M:COR4]COPREP(ILIGNEWORK) = [M:COR4]COPREP(IINDICE) Then
            GOK = 0
            #On ne peut pas mettre plusieurs fois le même représentant
            GMESSAGE = mess(559,177,1)
            Break
          Endif
        Endif
        ILIGNEWORK += 1
      Wend
    Endif
    IINDICE += 1
  Wend
Return

##########################################################################################################
# Création des représentants
$CREALLCOP
  If GOK < 1 Then
    Return
  Endif

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IINDICE

  IINDICE = 0
  While IINDICE < [M:COR4]NBLIGNCOP
    Raz [COP]
    If [M:COR4]COPREP(IINDICE) <> "" Then
      [F:COP]COPNUM = [M:COR0]CORNUM
      [F:COP]COPREP = [M:COR4]COPREP(IINDICE)
      [F:COP]CREUSR = GUSER
      [F:COP]CREDAT = date$
      Write [COP]
      If fstat <> 0 Then
        #Erreur lors de l'enregistrement d'une relation représentant
        GMESSAGE = mess(265,177,1)
        GERR = 1
        GOK = 0
        Break
      Endif
      #Création des données de synchronisation
      Call SYDCORCRE ([M:COR4]COPREP(IINDICE), IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
      If IBRETOUR = 0 Then
        #Erreur lors de la création des données pour la synchronisation
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
        GOK = 0
        Break
      Endif
    Endif
    IINDICE += 1
  Wend
Return

##########################################################################################################
# Création des représentants
$SAVEALLCOP
  If GOK < 1 Then
    Return
  Endif

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IINDICE
Local Integer ILIGNETAB
Local Integer IBTROUVE

  #On traite le cas des représentants supprimés
  ILIGNETAB = 0
  While ILIGNETAB < GICORNBREP
    If GTBCORVALREP(ILIGNETAB) <> "" Then
      #On regarde si on trouve le représentant
      IBTROUVE = 0
      # --------------------------------------
      # FGR 06/05/2015 : X3SUIVI108160 (début) : IINDICE part de 0 seulement la première fois !
      #While IINDICE < [M:COR4]NBLIGNCOP
      #  If [M:COR4]COPREP(IINDICE) <> "" Then
      #    If GTBCORVALREP(ILIGNETAB) = [M:COR4]COPREP(IINDICE) Then
      #      IBTROUVE = 1
      #      Break
      #    Endif
      #  Endif
      #  IINDICE += 1
      #Wend
      For IINDICE = 0 To [M:COR4]NBLIGNCOP-1
        If [M:COR4]COPREP(IINDICE) <> "" Then
          If GTBCORVALREP(ILIGNETAB) = [M:COR4]COPREP(IINDICE) Then
            IBTROUVE = 1
            Break
          Endif
        Endif
      Next IINDICE
      # FGR 06/05/2015 : X3SUIVI108160 (début)
      # --------------------------------------
      If IBTROUVE = 0 Then
        #On n'a trouvé aucune fois ce représentant
        #Il faut le supprimer
        Delete [COP] Where [F:COP]COPNUM = [M:COR0]CORNUM and [F:COP]COPREP = GTBCORVALREP(ILIGNETAB)
        If fstat <> 0 Then
          #Erreur lors de la suppression d'une relation représentant
          GMESSAGE = mess(266,177,1)
          GERR = 1
          GOK = 0
          Break
        Endif
        Call SYDCORDEL (GTBCORVALREP(ILIGNETAB), IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
        If IBRETOUR = 0 Then
          #Erreur lors de la création des données pour la synchronisation
          GMESSAGE = mess(210,177,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
    Endif
    ILIGNETAB += 1
  Wend
  If GOK < 0 Then
    Return
  Endif
  IINDICE = 0
  IBTROUVE = 0
  While IINDICE < [M:COR4]NBLIGNCOP
    If [M:COR4]COPREP(IINDICE) <> "" Then
      ILIGNETAB = 0
      IBTROUVE = 0
      While ILIGNETAB < GICORNBREP
        If GTBCORVALREP(ILIGNETAB) = [M:COR4]COPREP(IINDICE) Then
          IBTROUVE = 1
          Break
        Endif
        ILIGNETAB += 1
      Wend
      If IBTROUVE = 0 Then
        #Ce représenant n'existait pas au début, c'est un nouveau
        Raz [COP]
        [F:COP]COPNUM = [M:COR0]CORNUM
        [F:COP]COPREP = [M:COR4]COPREP(IINDICE)
        [F:COP]CREUSR = GUSER
        [F:COP]CREDAT = date$
        Write [COP]
        If fstat <> 0 Then
          #Erreur lors de l'enregistrement d'une relation représentant
          GMESSAGE = mess(265,177,1) - "fstat=" + num$(fstat) - "-COPNUM=" + [F:COP]COPNUM + "-COPREP=" + [F:COP]COPREP
          GERR = 1
          GOK = 0
          Break
        Endif
        #Création des données de synchronisation
        Call SYDCORCRE ([M:COR4]COPREP(IINDICE), IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
        If IBRETOUR = 0 Then
          #Erreur lors de la création des données pour la synchronisation
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Else
        #Ce représenant existait, c'est une modif
        #On ne fait que créer les données de synchro
        Call SYDCORUPD ([M:COR4]COPREP(IINDICE), IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
        If IBRETOUR = 0 Then
          #Erreur lors de la création des données pour la synchronisation
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
    Endif
    IINDICE += 1
  Wend
Return

##########################################################################################################
# Suppression de tous les représentants
$DELLALLCOP
  If GOK < 1 Then
    Return
  Endif

Local Char SZTABCREP(GLONREP)(dim([M:COR4]COPREP))
Local Integer INBREP
Local Integer IINDICE

  Raz SZTABCREP
  IINDICE = 0
  INBREP = 0
  For [COP] Where [F:COP]COPNUM = [M:COR0]CORNUM
    SZTABCREP(INBREP) = [F:COP]COPREP
    INBREP += 1
  Next
  Delete [COP] Where [F:COP]COPNUM = [M:COR0]CORNUM
  If fstat <> 0 Then
    #Erreur lors de la suppression d'une relation représentant
    GMESSAGE = mess(266,177,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  While IINDICE < INBREP
    Call SYDCORDEL (SZTABCREP(IINDICE), IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
    If IBRETOUR = 0 Then
      #Erreur lors de la création des données pour la synchronisation
      GMESSAGE = mess(210,177,1)
      GERR = 1
      GOK = 0
      Break
    Endif
    IINDICE += 1
  Wend
Return

##########################################################################################################
#  COREXIST : Test l'existance d'un correspondant par rapport à un couple tiers/interlocuteur
#                la référence est renvoyé s'il existe et est à null sinon
Subprog COREXIST (SZBPCNUM, SZCNTNUM, SZCORNUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZBPCNUM
Value Char SZCNTNUM
Variable Char SZCORNUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  If !clalev([F:COR]) : Local File CORRESPOND [COR] : Endif
  IBRETOUR = 1
  Raz SZCORNUM
  For [COR] Where [F:COR]BPRNUM = SZBPCNUM and [F:COR]CNTNUM = SZCNTNUM
    SZCORNUM = [F:COR]CORNUM
    Break
  Next
End

##########################################################################################################
#  CORREPEXIST : Test l'existance d'un représentant pour un correspondant donnée
Subprog CORREPEXIST (SZCORNUM, SZREP, IBEXIST, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZCORNUM
Value Char SZREP
Variable Integer IBEXIST
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  If !clalev([F:COP]) : Local File CORREP [COP] : Endif
  IBEXIST = 0
  IBRETOUR = 1
  Read [COP]COP0=SZREP;SZCORNUM
  If fstat = 0 Then
    IBEXIST = 1
  Endif
End

##########################################################################################################
#  CORREPCRE:    Création d'un lien pour un représentant donnée
Subprog CORREPCRE(SZCORNUM, SZREP, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZCORNUM
Value Char SZREP
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  If !clalev([F:COP]) : Local File CORREP [COP] : Endif
  IBRETOUR = 1
  Raz [F:COP]
  [F:COP]COPNUM = SZCORNUM
  [F:COP]COPREP = SZREP
  [F:COP]CREUSR = GUSER
  [F:COP]CREDAT = date$
  Write [COP]
  If fstat Then
    #Erreur lors de la création des données dans la table CORREP
    IERRINF = 312
    ICHAPTER = 177
    IBRETOUR = 0
    End
  Endif
End

##########################################################################################################
#  CORREPDEL:    suppression d'un lien pour un représentant donnée
Subprog CORREPDEL(SZCORNUM, SZREP, INBDELETE, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZCORNUM
Value Char SZREP
Variable Integer INBDELETE
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  If !clalev([F:COP]) : Local File CORREP [COP] : Endif
  IBRETOUR = 1
  Delete [F:COP] Where [F:COP]COPNUM = SZCORNUM and [F:COP]COPREP = SZREP
  If fstat Then
    #Erreur lors de la suppression des données dans la table CORREP
    IERRINF = 477
    ICHAPTER = 177
    IBRETOUR = 0
    End
  Else
    INBDELETE = adxdlrec
  Endif
End

##########################################################################################################
# Verifie si un correspondant existe pour un interlocuteur donnée et sinon le crée
Subprog CORGERE (SZREP, SZBPC, SZCCN, SZCOR, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZREP
Value Char SZBPC
Variable Char SZCCN
Variable Char SZCOR
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZSITE(GLONFCY)
Local Char SZSYDNUM
Local Char SZSYDUSR
Local Char SZDATAFILE
Local Integer IBUSRSYNC_OK
Local Integer IBEXIST
Local Integer IBFOUND
Local Integer IBCNT
Local Integer INBRECORD
Local Integer IBERROR
Local Integer LERRCOD
Local Integer IBGERE_SYD
Global Char GSZREP(GLONREP)
Local Integer IBDEBTRANSFLG

  LERRCOD = 0
  Raz GSZREP
  Raz SZSITE
  Raz SZSYDUSR
  Raz SZDATAFILE
  IBRETOUR = 1
  IBUSRSYNC_OK = 0
  IBEXIST = 0
  IBFOUND = 0
  IBCNT = 0
  INBRECORD = 0
  IBERROR = 0
  IBGERE_SYD = 0
  If GCRMSYNC <> 2 Then
    End
  Endif
  If GCRMSYNCCOR <> 2 Then
    End
  Endif
  If SZREP = "" Then
    #On arrete car pas d'utilisateur pour la syncro
    End
  Endif
  If SZCCN = "" and SZCOR = "" Then
    #On n'a pas d'interlocuteur on n'a rien à faire
    End
  Endif
  #---------------------------------------------------#
  # Récupération de l'utilisateur
  #---------------------------------------------------#
  Call SYDUSRFROMREP(SZREP, SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
  If IBUSRSYNC_OK = 0 Then
    #On arrete car pas d'utilisateur pour la syncro
    End
  Endif
  Call SYDUSRSYNCTYP(SZSYDUSR, "COR", IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
  If IBUSRSYNC_OK = 0 Then
    #On arrete car aucun droit sur la synchro
    End
  Endif
  #On est en cours de synchronisation, on ne fait rien pour l'utilisateur synchro
  If GSYNCOUTLOOK = 1 and GUSER = SZSYDUSR Then
    End
  Endif
  If SZCOR <> "" Then
    #On vérifie si concordance Interlocuteur / correspondant
    Read [COR]COR0=SZCOR
    If fstat = 0 Then
      If SZCCN <> "" Then
        If [F:COR]CNTNUM <> SZCCN Then
          #Erreur, le correspondant n'est pas lié à la personnee
          IERRINF = 319
          ICHAPTER = 177
          IBRETOUR = 0
          End
        Endif
      Else
        SZCCN = [F:COR]CNTNUM
      Endif
    Else
      #Erreur lors de la lecture du correspondant :
      IERRINF = 271
      ICHAPTER = 177
      IBRETOUR = 0
      End
    Endif
  Endif
  If SZCOR = "" Then
    #On recherche si un correspondant convient
    If SZCCN <> "" Then
      If SZBPC <> "" Then
        For [COR] Where [F:COR]CNTNUM = SZCCN and [F:COR]BPRNUM = SZBPC
          IBFOUND = 1
          Break
        Next
      Endif
      If IBFOUND = 0 Then
        For [COR] Where [F:COR]CNTNUM = SZCCN and [F:COR]BPRNUM = ""
          IBFOUND = 1
          Break
        Next
      Endif
      If IBFOUND = 1 Then
        SZCOR = [F:COR]CORNUM
      Endif
    Endif
  Endif
  #
  If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [COR]
  Endif
  If SZCOR <> "" Then
    #On vérifie si le correspondant est défini pour le représentant
    Call CORREPEXIST (SZCOR ,SZREP, IBEXIST, IERRINF, ICHAPTER, IBRETOUR)
    If IBRETOUR = 1 Then
      If IBEXIST = 0 Then
        Call CORREPCRE(SZCOR, SZREP, IERRINF, ICHAPTER, IBRETOUR)
        If IBRETOUR = 1 Then
          IBGERE_SYD = 1
        Endif
      Endif
    Else
      IBERROR = 1
      Goto FIN_CORGERE
    Endif
  Else
    #Il faut créer le correspondant
    If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
    If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
    If !clalev([F:CNT]) : Local File CONTACT    [CNT] : Endif
    If !clalev([F:BPA]) : Local File BPADDRESS  [BPA] : Endif
    If !clalev([F:LDS]) : Local File LEAD       [LDS] : Endif
    IFOUND = 0
    #On recherche si on a un correspondant
    For [CNT] Where BPATYP = 1 and [F:CNT]BPANUM = SZBPC and [F:CNT]CCNCRM = SZCCN
      IFOUND = 1
      IBCNT = 1
      Break
    Next
    If IBCNT = 1 and IBERROR = 0 Then
      #On a un contact
      Read [BPC]BPC0=[F:CNT]BPANUM
      If fstat <> 0 Then
        #Erreur lors de la lecture du client
        IERRINF = 317
        ICHAPTER = 177
        IBRETOUR = 0
        IBERROR = 1
        Goto FIN_CORGERE
      Endif
      Read [AIN]AIN0=[F:CNT]CCNCRM
      If fstat <> 0 Then
        #Erreur lors de la lecture de l'interlocuteur
        IERRINF = 313
        ICHAPTER = 177
        IBRETOUR = 0
        IBERROR = 1
        Goto FIN_CORGERE
      Endif
      If [F:CNT]BPAADD <> "" Then
        Read [BPA]BPA0=[F:CNT]BPATYP;[F:CNT]BPANUM;[F:CNT]BPAADD
        If fstat <> 0 Then
          #Erreur lors de la lecture de l'adresse
          IERRINF = 314
          ICHAPTER = 177
          IBRETOUR = 0
          IBERROR = 1
          Goto FIN_CORGERE
        Endif
      Else
        INBRECORD = 0
        For [BPA] Where [F:BPA]BPATYP = [F:CNT]BPATYP and [F:BPA]BPANUM = [F:CNT]BPANUM and [F:BPA]BPAADDFLG = 2
          INBRECORD += 1
          Break
        Next
        If INBRECORD = 0 Then
          #Erreur lors de la lecture de l'adresse par défaut
          IERRINF = 315
          ICHAPTER = 177
          IBRETOUR = 0
          IBERROR = 1
          Goto FIN_CORGERE
        Endif
      Endif
    Else
      Read [AIN]AIN0=SZCCN
      If fstat <> 0 Then
        #Erreur lors de la lecture de l'interlocuteur
        IERRINF = 313
        ICHAPTER = 177
        IBRETOUR = 0
        IBERROR = 1
        Goto FIN_CORGERE
      Endif
      If [F:AIN]CNTTYP = 2 Then
        Read [LDS]LDS0=SZCCN
        If fstat <> 0 Then
          #Erreur lors de la lecteure de la table LEAD
          IERRINF = 465
          ICHAPTER = 177
          IBRETOUR = 0
          IBERROR = 1
          Goto FIN_CORGERE
        Endif
        # FGR 03/02/2009 : Les adresses des leads sont dans BPADDRESS
        Read [BPA]BPA0=6;[F:LDS]PSTNUM;[F:LDS]BPAADD
        If fstat <> 0 Then
          #Erreur lors de la lecture de l'adresse
          IERRINF = 314
          ICHAPTER = 177
          IBRETOUR = 0
          IBERROR = 1
          Goto FIN_CORGERE
        Endif
      Endif
    Endif
    GSZREP = SZREP
    If IBCNT = 1 Then
      SZDATAFILE = "SUBCORCNTD"
    Else
      If [F:AIN]CNTTYP = 1 Then
        SZDATAFILE = "SUBCORAIND"
      Else
        SZDATAFILE = "SUBCORLDSD"
      Endif
    Endif
    Call CRECOR(SZDATAFILE, 1, 0, SZCOR, LERRCOD) From SUBCORCC
    If LERRCOD <> 0 Then
      #Erreur lors de la création du correspondant
      IERRINF = 318
      ICHAPTER = 177
      IBRETOUR = 0
      IBERROR = 1
      Goto FIN_CORGERE
    Endif
    IBGERE_SYD = 1
  Endif
  If IBGERE_SYD = 1 Then
    INBRECORD = 0
    Filter [SYD] Where [F:SYD]SYDUSR = SZSYDUSR and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCOR and [F:SYD]SYDGEN = 0
    For [SYD]SYD1
      INBRECORD += 1
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDATTTYP = "R"
        [F:SYD]SYDOTKSTA = 1
        [F:SYD]SYDUPD = 0
        [F:SYD]SYDDAT = date$
        [F:SYD]SYDHOU = time$
        [F:SYD]UPDUSR= GUSER
        [F:SYD]UPDDAT = date$
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la modification des données de synchronisation pour le correspondant :
          IERRINF = 280
          ICHAPTER = 177
          IBRETOUR = 0
          Break
        Endif
      Else
        IBERROR = 1
        #Impossible de locker les données de synchronisation pour le correspondant :
        IERRINF = 281
        ICHAPTER = 177
        IBRETOUR = 0
        Break
      Endif
    Next
    Filter [SYD]
    If INBRECORD = 0 and IBERROR = 0 Then
      #On n'a pas de données de synchro, il faut créer
      Call SYDWRITE (SZSYDUSR , "", SZCOR, "COR", "C", 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
      If IBRETOUR = 0 Then
        IBERROR = 1
      Endif
    Endif
  Endif
  Goto FIN_CORGERE # pas vraiment utile, mais plus propre du point de vue programme
End

###################################
$FIN_CORGERE
  If IBDEBTRANSFLG = 0 Then
    If adxlog Then
      If IBERROR = 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif
  Endif
End

##########################################################################################################
# Verifie si un correspondant/représentant existe pour un représentant donnée et sinon le crée
Subprog CORGEREREP (SZREPSYNC, SZREP, SZCOR, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZREPSYNC
Value Char SZREP
Variable Char SZCOR
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZSITE(GLONFCY)
Local Char SZSYDNUM
Local Char SZSYDUSR
Local Integer IBUSRSYNC_OK
Local Integer IBEXIST
Local Integer IBFOUND
Local Integer INBRECORD
Local Integer IBERROR
Local Integer LERRCOD
Local Integer IBGERE_SYD
Global Char GSZREP(GLONREP)

  LERRCOD = 0
  Raz GSZREP
  Raz SZSITE
  Raz SZSYDUSR
  IBRETOUR = 1
  IBUSRSYNC_OK = 0
  IBEXIST = 0
  IBFOUND = 0
  IBCNT = 0
  INBRECORD = 0
  IBERROR = 0
  IBGERE_SYD = 0
  If GCRMSYNC <> 2 Then
    End
  Endif
  If GCRMSYNCCOR <> 2 Then
    End
  Endif
  If SZREPSYNC = "" Then
    #On arrete car pas d'utilisateur pour la syncro
    End
  Endif
  If SZREP = "" Then
    #On n'a pas de représentant,on n'a rien à faire
    End
  Endif
  #---------------------------------------------------#
  # Récupération de l'utilisateur
  #---------------------------------------------------#
  Call SYDUSRFROMREP (SZREPSYNC, SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
  If IBUSRSYNC_OK = 0 Then
    IBRETOUR = 1
    #On arrete car pas d'utilisateur pour la syncro
    End
  Endif
  Call SYDUSRSYNCTYP (SZSYDUSR, "COR", IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
  If IBUSRSYNC_OK = 0 Then
    #On arrete car aucun droit sur la synchro
    End
  Endif
  #On est en cours de synchronisation, on ne fait rien pour l'utilisateur synchro
  If GSYNCOUTLOOK = 1 and GUSER = SZSYDUSR Then
    End
  Endif
  If !clalev([F:CORW]) : Local File CORRESPOND [CORW] : Endif
  For [CORW] Where [F:CORW]BPRNUM = SZREP and [F:CORW]CORTYP = "REP"
    IBFOUND = 1
    SZCOR = [F:CORW]CORNUM
    Break
  Next
  If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  If SZCOR <> "" Then
    #On a un correspondant
    #On vérifie si il existe un lien  correspondant pour ce représentant
    Call CORREPEXIST (SZCOR, SZREPSYNC, IBEXIST, IERRINF, ICHAPTER, IBRETOUR)
    If IBRETOUR = 0 T
      End
    Endif
    If IBEXIST = 0 Then
      #Le correspondant existe, est ce qu'il est affecté au représentant sync
      Call CORREPCRE(SZCOR, SZREPSYNC, IERRINF, ICHAPTER, IBRETOUR)
      If IBRETOUR = 0 Then
        End
      Endif
      IBGERE_SYD = 1
    Endif
  Else
    #Il faut créer le correspondant
    If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
    If !clalev([F:REPC]) : Local File SALESREP [REPC] : Endif
    If !clalev([F:BPAR]) : Local File BPADDRESS [BPAR] : Endif
    If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
    If !clalev([F:BPAA]) : Local File BPADDRESS [BPAA] : Endif
    Read [BPR]BPR0=SZREP
    If fstat <> 0 Then
      #Erreur lors de la lecture du business partner
      IERRINF = 334
      ICHAPTER = 177
      IBRETOUR = 0
      End
    Endif
    Read [REPC]REP0=SZREP
    If fstat <> 0 Then
      #Erreur lors de la lecture du représentant
      IERRINF = 330
      ICHAPTER = 177
      IBRETOUR = 0
      End
    Endif
    If [F:BPR]BPAADD <> "" Then
      Read [BPAR]BPA0=1;SZREP;[F:BPR]BPAADD
      If fstat <> 0 Then
        #Erreur lors de la lecture de l'adresse par défaut du représentant
        IERRINF = 331
        ICHAPTER = 177
        IBRETOUR = 0
        End
      Endif
    Endif
    If [F:REPC]AUSNUM <> "" Then
      Read [AUS]CODUSR=[F:REPC]AUSNUM
      If fstat <> 0 Then
        #Erreur lors de la lecture de l'utilisateur associé au représentant
        IERRINF = 332
        ICHAPTER = 177
        IBRETOUR = 0
        End
      Endif
      If [F:AUS]BPAADD <> "" Then
        Read [BPAA]BPA0=4;[F:AUS]USR;[F:AUS]BPAADD
        If fstat <> 0 Then
          #Erreur lors de la lecture de l'adresse associée à l'utilisateur
          IERRINF = 333
          ICHAPTER = 177
          IBRETOUR = 0
          End
        Endif
      Endif
    Endif
    GSZREP = SZREPSYNC
    Call CRECOR("SUBCORREPD", 1, 0, SZCOR, LERRCOD) From SUBCORCC
    If LERRCOD <> 0 Then
      #Erreur lors de la création du correspondant
      IERRINF = 318
      ICHAPTER = 177
      IBRETOUR = 0
      End
    Endif
    IBGERE_SYD = 1
  Endif
  If IBGERE_SYD = 1 Then
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    INBRECORD = 0
    Filter [SYD] Where [F:SYD]SYDUSR = SZSYDUSR and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCOR and [F:SYD]SYDGEN = 0
    For [SYD]SYD1
      INBRECORD += 1
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDATTTYP = "R"
        [F:SYD]SYDOTKSTA = 1
        [F:SYD]SYDUPD = 0
        [F:SYD]SYDDAT = date$
        [F:SYD]SYDHOU = time$
        [F:SYD]UPDUSR= GUSER
        [F:SYD]UPDDAT = date$
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la modification des données de synchronisation pour le correspondant :
          IERRINF = 280
          ICHAPTER = 177
          IBRETOUR = 0
          Break
        Endif
      Else
        #Impossible de locker les données de synchronisation pour le correspondant :
        IBERROR = 1
        IERRINF = 281
        ICHAPTER = 177
        IBRETOUR = 0
        Break
      Endif
    Next
    Filter [SYD]
    If INBRECORD = 0 and IBERROR = 0 Then
      #On n'a pas de données de synchro, il faut créer
      Call SYDWRITE (SZSYDUSR , "", SZCOR, "COR", "C", 1, 0, 0,IERRINF, ICHAPTER, IBRETOUR)  From SUBSYDB
      If IBRETOUR = 0 Then
        IBERROR = 1
      Endif
    Endif
    If adxlog Then
      If IBERROR = 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif
  Endif
End

##########################################################################################################
#créer les données de synchro de forçage pour le représentant
$FORCECOR
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IINDICE
Local Integer IBTROUVE

  IBTROUVE = 0
  IINDICE = 0
  While IINDICE < [M:COR4]NBLIGNCOP
    If [M:COR4]COPREP(IINDICE) = [M:COR0]FORCAGEREP Then
      IBTROUVE = 1
      Break
    Endif
    IINDICE += 1
  Wend
  If IBTROUVE = 0 Then
    GERR = 1
    #Erreur : le représentant de forçage n'est pas dans la liste des représentants
    GMESSAGE = mess(416,177,1)
    GOK = 0
    Return
  Endif
  #On laisse la fonction de forçage géré l'écriture des données
Return

##########################################################################################################
# MAJTABLES  : mise à jour des tables liées
$MAJTABLES
Local Integer IBMODIF
Local Integer IBERROR
Local Integer IBTRAITE
Local Integer IBTRAITECOR
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCOPUSER
Local Integer IBUSRSYNC_OK
Local Integer INBRECORD
Local Char SZTYPECOR

  IBMODIF = 0
  IBERROR = 0
  IBTRAITE = 1
  IBTRAITECOR = 1
  Raz SZCOPUSER
  IBUSRSYNC_OK = 0
  INBRECORD = 0
  Raz SZTYPECOR
  If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS[BPA] : Endif
  If !clalev([F:LDS]) : Local File LEAD[LDS] : Endif
  If !clalev([F:CORL]) : Local File CORRESPOND [CORL] : Endif
  If !clalev([F:COPL]) : Local File CORREP [COPL] : Endif
  Gosub MAJBPR
  If GOK < 1 Then
    Return
  Endif
  #Liens avec l'interlocuteur
  If dim(GIMPLDS) < 0 Then
    # FGR 09/01/2009 : en import des Leads, il ne faut pas passer ici, c'est deja fait avant
    Gosub MAJAIN
    If GOK < 1 Then
      Return
    Endif
  Endif
  If SZTYPECOR = "LDS" and GNAVIG <> "GESLDS" Then
    # FGR 17/08/2009 : X3SUIVI57117 : Ne pas faire si on est en création de Lead
    #Liens avec les leads
    Gosub MAJLDS
    If GOK < 1 Then
      Return
    Endif
  Else
    #Liens avec adresse
    Gosub MAJADR
    If GOK < 1 Then
      Return
    Endif
    #Liens avec contacts
    Gosub MAJCNT
    If GOK < 1 Then
      Return
    Endif
  Endif
Return

##########################################################################################################
# MAJBPR  : mise à jour de la tables BPR
$MAJBPR
  IBMODIF = 0
  IBERROR = 0
  #Liens avec Tiers
  If [M:COR2]BPRNUM = "" Then
    #Pas de données à mettre à jour
    Return
  Endif
  If [M:COR2]BPRLIB = [M:CR2S]BPRLIB Then
    Return
  Endif
  #On a eu une modif sur le libellé du tiers, il faut la reporté
  Readlock [BPR]BPR0=[M:COR2]BPRNUM
  If fstat <> 0 Then
    IBERROR = 1
    GERR = 1
    #Erreur : impossible de locker le tiers + " : "+ [M:COR2]BPRNUM
    GMESSAGE = mess(419,177,1) - ":" - [M:COR2]BPRNUM
    GOK = 0
  Endif
  If [F:BPR]BPRNAM <> [M:COR2]BPRLIB Then
    IBMODIF = 1
    [F:BPR]BPRNAM = [M:COR2]BPRLIB
    Rewrite [BPR]
    If fstat <> 0 Then
      IBERROR = 1
      #Erreur lors de la modification du tiers + " : + [M:COR2]BPRNUM
      GMESSAGE = mess(420,177,1) - ":" - [M:COR2]BPRNUM
      GOK = 0
    Endif
  Else
    Unlock [BPR]
  Endif
  If IBMODIF = 1 and IBERROR = 0 Then
    #On a eu une modif, il faut reporté la modif
    For [CORL] Where [F:CORL]BPRNUM=[M:COR2]BPRNUM and [F:CORL]BPRLIB<> [F:BPR]BPRNAM and CORTYP<>"REP"
      IBTRAITECOR = 1
      [F:CORL]BPRLIB = [F:BPR]BPRNAM
      Rewrite [CORL]
      If fstat <> 0 Then
        #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
        IBERROR = 1
        GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
        GOK = 0
        Break
      Endif
      If IBTRAITECOR = 1 and IBERROR = 0 Then
        Gosub GERE_COP
      Endif
      If IBERROR = 1 Then
        Break
      Endif
    Next
  Endif
  If IBERROR = 1 Then
    GOK = 0
  Endif
Return

##########################################################################################################
$MAJAIN
  SZTYPECOR = "AIN"
  #Liens avec l'interlocuteur
  If [M:COR0]CNTNUM = "" Then
    Return
  Endif
  Read [AIN]AIN0=[M:COR0]CNTNUM
  If fstat <> 0 Then
    IBERROR = 1
    GERR = 1
    #Erreur lors de la lecture de l'interlocuteur + " : "+ [M:COR2]CNTNUM
    # FGR 13/01/2010 : X3SUIVI60986
    #GMESSAGE = mess(313,177,1) - ":" - [M:COR2]CNTNUM
    GMESSAGE = mess(313,177,1) - ":" - [M:COR0]CNTNUM
    GOK = 0
  Else
    If [F:AIN]CNTTYP = 2 Then
      SZTYPECOR = "LDS"
    Endif
  Endif
  If IBERROR = 0 Then
    Gosub TEST_AIN_M_COR_M_CORSAVE
  Endif
  If IBMODIF = 0 or IBERROR = 1 Then
    Return
  Endif
  #on a eu une modif sur l'interlocuteur, il faut la reporté
  Readlock [AIN]AIN0=[M:COR0]CNTNUM
  If fstat <> 0 Then
    IBERROR = 1
    GERR = 1
    #Erreur : impossible de locker l'interlocuteur + " : "+ [M:COR2]CNTNUM
    # FGR 14/01/2010 : X3SUIVI60986
    #GMESSAGE = mess(421,177,1) - ":" - [M:COR2]CNTNUM
    GMESSAGE = mess(421,177,1) - ":" - [M:COR0]CNTNUM
    GOK = 0
  Endif
  If IBERROR = 0 Then
    #On test si les valeurs sont différentes
    Gosub TEST_AIN_M_COR_F_AIN
  Endif
  If IBMODIF = 1 and IBERROR = 0 Then
    [F:AIN]CNTTTL = [M:COR0]TTL
    [F:AIN]CNTLNA = [M:COR0]LNA
    [F:AIN]CNTFNA = [M:COR0]FNA
    [F:AIN]CNTBIR = [M:COR3]BIR
    [F:AIN]CNTLAN = [M:COR3]LAN
    [F:AIN]CNTCSP = [M:COR3]CSP
    [F:AIN]CRY = [M:COR3]HOMCRY
    [F:AIN]CRYNAM = [M:COR3]HOMCRYNAM
    If dim([M:COR3]HOMADD(0)) > 0 Then
      [F:AIN]ADD(0) = [M:COR3]HOMADD(0)
    Else
      [F:AIN]ADD(0) = ""
    Endif
    If dim([M:COR3]HOMADD(1)) > 0 Then
      [F:AIN]ADD(1) = [M:COR3]HOMADD(1)
    Else
      [F:AIN]ADD(1) = ""
    Endif
    If dim([M:COR3]HOMADD(2)) > 0 Then
      [F:AIN]ADD(2) = [M:COR3]HOMADD(2)
    Else
      [F:AIN]ADD(2) = ""
    Endif
    [F:AIN]ZIP = [M:COR3]HOMZIP
    [F:AIN]CTY = [M:COR3]HOMCTY
    If dim([M:COR3]HOMSAT) > 0 Then
      [F:AIN]SAT = [M:COR3]HOMSAT
    Else
      [F:AIN]SAT = ""
    Endif
    [F:AIN]CNTETS = [M:COR3]HOMTEL
    [F:AIN]CNTFAX = [M:COR3]HOMFAX
    [F:AIN]CNTMOB = [M:COR3]HOMMOB
    [F:AIN]CNTEMA = [M:COR3]HOMEML
    [F:AIN]UPDUSR = GUSER
    [F:AIN]UPDDAT = date$
    Rewrite [AIN]
    If fstat <> 0 Then
      IBERROR = 1
      #Erreur lors de la modification de l'interlocuteur + " : + [M:COR0]CNTNUM
      GMESSAGE = mess(422,177,1) - ":" - [M:COR0]CNTNUM
      GOK = 0
    Endif
  Else
    Unlock [AIN]
  Endif
  If IBMODIF = 1 and IBERROR = 0 Then
    #On a eu une modif, il faut reporté la modif
    For [CORL] Where [F:CORL]CNTNUM = [M:COR0]CNTNUM
      If IBERROR = 1 Then
        Break
      Endif
      IBTRAITECOR = 1
      Gosub TEST_AIN_F_CORL_F_AIN
      If IBMODIF = 1 and IBTRAITECOR = 1 Then
        [F:CORL]TTL = [F:AIN]CNTTTL
        [F:CORL]LNA = [F:AIN]CNTLNA
        [F:CORL]FNA = [F:AIN]CNTFNA
        [F:CORL]BIR = [F:AIN]CNTBIR
        [F:CORL]LAN = [F:AIN]CNTLAN
        [F:CORL]CSP = [F:AIN]CNTCSP
        [F:CORL]HOMCRY = [F:AIN]CRY
        [F:CORL]HOMCRYNAM = [F:AIN]CRYNAM
        [F:CORL]HOMADD(0) = [F:AIN]ADD(0)
        [F:CORL]HOMADD(1) = [F:AIN]ADD(1)
        [F:CORL]HOMADD(2) = [F:AIN]ADD(2)
        [F:CORL]HOMZIP = [F:AIN]ZIP
        [F:CORL]HOMCTY = [F:AIN]CTY
        [F:CORL]HOMSAT = [F:AIN]SAT
        [F:CORL]HOMTEL = [F:AIN]CNTETS
        [F:CORL]HOMFAX = [F:AIN]CNTFAX
        [F:CORL]HOMMOB = [F:AIN]CNTMOB
        [F:CORL]HOMEML = [F:AIN]CNTEMA
        [F:CORL]UPDUSR = GUSER
        [F:CORL]UPDDAT = date$
        Rewrite [CORL]
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
          GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
          GOK = 0
        Endif
        If IBTRAITECOR = 1 and IBERROR = 0 Then
          Gosub GERE_COP
        Endif
        If IBERROR = 1 Then
          Break
        Endif
      Endif
    Next
  Endif
  If IBERROR = 1 Then
    GOK = 0
  Endif
Return

##########################################################################################################
$GERE_COP
  For [COPL] Where [F:COPL]COPNUM = [F:CORL]CORNUM
    If IBERROR = 1 Then
      Break
    Endif
    Raz SZCOPUSER
    IBTRAITE = 1
    Call SYDUSRFROMREP([F:COPL]COPREP, SZCOPUSER, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
    If IBUSRSYNC_OK = 0 Then
      IBRETOUR = 1
      #On arrete car pas d'utilisateur pour la syncro
      IBTRAITE = 0
    Endif
    If IBTRAITE = 1 and IBERROR = 0 Then
      Call SYDUSRSYNCTYP(SZCOPUSER, "COR", IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
      If IBUSRSYNC_OK = 0 Then
        IBRETOUR = 1
        #On arrete car pas d'utilisateur pour la syncro
        IBTRAITE = 0
      Endif
    Endif
    If IBTRAITE = 1 and IBERROR = 0 Then
      #On est en cours de synchronisation, on ne fait rien pour l'utilisateur synchro
      If GSYNCOUTLOOK = 1 and GUSER = SZCOPUSER Then
        IBTRAITE = 0
      Endif
    Endif
    If IBTRAITE = 1 and IBERROR = 0 Then
      INBRECORD = 0
      Filter [SYD] Where [F:SYD]SYDUSR = SZCOPUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = [F:CORL]CORNUM and [F:SYD]SYDGEN = 0
      For [SYD]SYD1
        INBRECORD += 1
        Readlock [SYD] Curr
        If fstat = 0 Then
          [F:SYD]SYDATTTYP = "R"
          [F:SYD]SYDOTKSTA = 1
          [F:SYD]SYDUPD = 0
          [F:SYD]SYDDAT = date$
          [F:SYD]SYDHOU = time$
          [F:SYD]UPDUSR= GUSER
          [F:SYD]UPDDAT = date$
          Rewrite [SYD]
          If fstat <> 0 Then
            IBERROR = 1
            #Erreur lors de la modification des données de synchronisation pour le correspondant + ":" +[F:CORL]CORNUM
            GMESSAGE = mess(280,177,1) - ":" - [F:CORL]CORNUM
            GOK = 0
          Endif
        Else
          IBERROR = 1
          #Impossible de locker les données de synchronisation pour le correspondant- ":"  -[F:CORL]CORNUM
          GMESSAGE = mess(281,177,1) - ":" - [F:CORL]CORNUM
          IBRETOUR = 0
          GOK = 0
        Endif
        If IBERROR = 1 Then
          Break
        Endif
      Next
      Filter [SYD]
      If INBRECORD = 0 and IBERROR = 0 Then
        #On n'a pas de données de synchro, il faut créer
        Call SYDWRITE(SZCOPUSER , "", [F:CORL]CORNUM, "COR", "C", 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
        If IBRETOUR = 0 Then
          IBERROR = 1
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          IBRETOUR = 0
          GOK = 0
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
$TEST_AIN_M_COR_M_CORSAVE
  IBMODIF = 0
  #On test les différentes zones
  #Ecran COR0
