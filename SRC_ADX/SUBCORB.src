    IBMODIF = 1
  Endif
  #Etat
  If dim([M:COR3]HOMSAT) > 0 Then
    If [M:COR3]HOMSAT <> [M:CR3S]HOMSAT Then
      IBMODIF = 1
    Endif
  Endif
  #Pays
  If [M:COR3]HOMCRY <> [M:CR3S]HOMCRY Then
    IBMODIF = 1
  Endif
  #Nom Pays
  If [M:COR3]HOMCRYNAM <> [M:CR3S]HOMCRYNAM Then
    IBMODIF = 1
  Endif
  #Email
  If [M:COR3]HOMEML <> [M:CR3S]HOMEML Then
    IBMODIF = 1
  Endif
  #Téléphone
  If [M:COR3]HOMTEL <> [M:CR3S]HOMTEL Then
    IBMODIF = 1
  Endif
  #Fax
  If [M:COR3]HOMFAX <> [M:CR3S]HOMFAX Then
    IBMODIF = 1
  Endif
  #Portable
  If [M:COR3]HOMMOB <> [M:CR3S]HOMMOB Then
    IBMODIF = 1
  Endif
Return

