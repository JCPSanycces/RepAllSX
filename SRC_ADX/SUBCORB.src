##########################################################################################################
$MAJCNT
  #Liens avec l'interlocuteur
  If [M:COR0]CNTNUM = "" or [M:COR2]BPRNUM = "" Then
    Return
  Endif
  Look [CNT]CNT0=1;[M:COR2]BPRNUM;[M:COR0]CNTNUM
  If fstat <> 0 Then
    #le contact n'existe pas on le crée
    [F:CNT]BPATYP = 1
    [F:CNT]BPANUM = [M:COR2]BPRNUM
    [F:CNT]CCNCRM = [M:COR0]CNTNUM
    [F:CNT]CNTFNC = [M:COR2]FNC
    [F:CNT]CNTMSS = [M:COR2]MSS
    [F:CNT]CNTSRV = [M:COR2]SRV
    [F:CNT]BPAADD = [M:COR2]CPYBPANUM
    [F:CNT]WEB = [M:COR2]CPYEML
    [F:CNT]TEL = [M:COR2]CPYTEL
    [F:CNT]FAX = [M:COR2]CPYFAX
    [F:CNT]CREUSR = GUSER
    [F:CNT]CREDAT = date$
    Write [CNT]
    If fstat <> 0 Then
      IBERROR = 1
      #Erreur lors de la création du contact+ " : "+ num$([M:COR2]CPYBPATYP)+" / "+[M:COR2]BPRNUM+" / "+[M:COR0]CNTNUM
      GMESSAGE = mess(537,177,1) - ":" - num$([M:COR2]CPYBPATYP) - "/" - [M:COR2]BPRNUM - "/" - [M:COR0]CNTNUM
      GOK = 0
    Endif
    If IBERROR = 1 Then
      GOK = 0
    Endif
    Return
  Endif
  Gosub TEST_CNT_M_COR_M_CORSAVE
  If IBMODIF = 0 Then
    Return
  Endif
  #On a eu une modif sur un contact existant, il faut la reporté
  Readlock [CNT]CNT0=[M:COR2]CPYBPATYP;[M:COR2]BPRNUM;[M:COR0]CNTNUM
  If fstat <> 0 Then
    IBERROR = 1
    GERR = 1
    #Erreur : impossible de locker le contact+ " : "+ num$([M:COR2]CPYBPATYP)- "/" -[M:COR2]BPRNUM- "/" -[M:COR0]CNTNUM
    GMESSAGE = mess(423,177,1) - ":" - num$([M:COR2]CPYBPATYP) - "/" - [M:COR2]BPRNUM - "/" - [M:COR0]CNTNUM
    GOK = 0
  Endif
  #On test si les valeurs sont différentes
  If IBERROR = 0 Then
    Gosub TEST_CNT_M_COR_F_AIN
  Endif
  If IBMODIF = 1 and IBERROR = 0 Then
    [F:CNT]CNTFNC = [M:COR2]FNC
    [F:CNT]CNTMSS = [M:COR2]MSS
    [F:CNT]CNTSRV = [M:COR2]SRV
    [F:CNT]BPAADD = [M:COR2]CPYBPANUM
    [F:CNT]WEB = [M:COR2]CPYEML
    [F:CNT]TEL = [M:COR2]CPYTEL
    [F:CNT]FAX = [M:COR2]CPYFAX
    [F:CNT]UPDUSR = GUSER
    [F:CNT]UPDDAT = date$
    [F:CNT]UPDDATTIM = time
    Rewrite [CNT]
    If fstat <> 0 Then
      IBERROR = 1
      #Erreur lors de la modification du contact+ " : "+ num$([M:COR2]CPYBPATYP)- "/" -[M:COR2]BPRNUM- "/" -[M:COR0]CNTNUM
      GMESSAGE = mess(424,177,1) - ":" - num$([M:COR2]CPYBPATYP) - "/" - [M:COR2]BPRNUM - "/" - [M:COR0]CNTNUM
      GOK = 0
    Endif
  Else
    Unlock [CNT]
  Endif
  If IBMODIF = 1 and IBERROR = 0 Then
    #On a eu une modif, il faut reporté la modif
    For [CORL] Where [F:CORL]CNTNUM = [M:COR0]CNTNUM
      If IBERROR = 1 Then
        Break
      Endif
      IBTRAITECOR = 1
      Gosub TEST_CNT_F_CORL_F_AIN
      If IBMODIF = 1 and IBTRAITECOR = 1 Then
        [F:CORL]FNC = [F:CNT]CNTFNC
        [F:CORL]MSS = [F:CNT]CNTMSS
        [F:CORL]SRV = [F:CNT]CNTSRV
        [F:CORL]CPYBPANUM = [F:CNT]BPAADD
        [F:CORL]CPYEML = [F:CNT]WEB
        [F:CORL]CPYTEL = [F:CNT]TEL
        [F:CORL]CPYFAX = [F:CNT]FAX
        [F:CORL]UPDUSR = GUSER
        [F:CORL]UPDDAT = date$
        Rewrite [CORL]
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
          GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
          GOK = 0
        Endif
        If IBTRAITECOR = 1 and IBERROR = 0 Then
          Gosub GERE_COP
        Endif
        If IBERROR = 1 Then
          Break
        Endif
      Endif
    Next
  Endif
  If IBERROR = 1 Then
    GOK = 0
  Endif
Return

