##########################################################################################################
$MAJADR
  #Liens avec l'interlocuteur
  If [M:COR2]BPRNUM = "" or [M:COR2]CPYBPANUM = "" Then
   Return
  Endif
  Look [BPA]BPA0=1;[M:COR2]BPRNUM;[M:COR2]CPYBPANUM
  If fstat <> 0 Then
    #L"adresse n'existe pas on la creé
    [F:BPA]BPATYP = 1
    [F:BPA]BPANUM = [M:COR2]BPRNUM
    [F:BPA]BPAADD = [M:COR2]CPYBPANUM
    [F:BPA]BPADES = [M:COR2]CPYBPADES
    If dim([M:COR2]CPYADD(0)) > 0 Then
      [F:BPA]BPAADDLIG(0) = [M:COR2]CPYADD(0)
    Else
      [F:BPA]BPAADDLIG(0) = ""
    Endif
    If dim([M:COR2]CPYADD(1)) > 0 Then
      [F:BPA]BPAADDLIG(1) = [M:COR2]CPYADD(1)
    Else
      [F:BPA]BPAADDLIG(1) = ""
    Endif
    If dim([M:COR2]CPYADD(2)) > 0 Then
      [F:BPA]BPAADDLIG(2) = [M:COR2]CPYADD(2)
    Else
      [F:BPA]BPAADDLIG(2) = ""
    Endif
    [F:BPA]POSCOD = [M:COR2]CPYZIP
    [F:BPA]CTY = [M:COR2]CPYCTY
    If dim([M:COR2]CPYSAT) > 0 Then
      [F:BPA]SAT = [M:COR2]CPYSAT
    Else
      [F:BPA]SAT = ""
    Endif
    [F:BPA]CRY = [M:COR2]CPYCRY
    [F:BPA]CRYNAM = [M:COR2]CPYCRYNAM
    [F:BPA]CREUSR = GUSER
    [F:BPA]CREDAT = date$
    Write [BPA]
    If fstat <> 0 Then
      IBERROR = 1
      #Erreur lors de la création de l'adresse+ " : "+ num$([M:COR2]CPYBPATYP)- "/" -[M:COR2]BPRNUM- "/" -[M:COR2]CPYBPANUM
      GMESSAGE = mess(536,177,1) - ":" - num$([M:COR2]CPYBPATYP) - "/" - [M:COR2]BPRNUM - "/" - [M:COR2]CPYBPANUM
      GOK = 0
    Endif
    If IBERROR = 1 Then
      GOK = 0
    Endif
    Return
  Endif
  Gosub TEST_ADR_M_COR_M_CORSAVE
  If IBMODIF = 0 Then
    Return
  Endif
  #On a eu une modif sur l'interlocuteur existant, il faut la reporté
  Readlock [BPA]BPA0=[M:COR2]CPYBPATYP;[M:COR2]BPRNUM;[M:COR2]CPYBPANUM
  If fstat <> 0 Then
    IBERROR = 1
    GERR = 1
    #Erreur : impossible de locker l'adresse- ":"- num$([M:COR2]CPYBPATYP)- "/" -[M:COR2]BPRNUM- "/" -[M:COR2]CPYBPANUM
    GMESSAGE = mess(425,177,1)- ":" - num$([M:COR2]CPYBPATYP) - "/" - [M:COR2]BPRNUM - "/" - [M:COR2]CPYBPANUM
    GOK = 0
  Endif
  #On test si les valeurs sont différentes
  Gosub TEST_ADR_M_COR_F_ADR
   If IBMODIF = 1 Then
    [F:BPA]BPADES = [M:COR2]CPYBPADES
    If dim([M:COR2]CPYADD(0)) > 0 Then
      [F:BPA]BPAADDLIG(0) = [M:COR2]CPYADD(0)
    Else
      [F:BPA]BPAADDLIG(0) = ""
    Endif
    If dim([M:COR2]CPYADD(1)) > 0 Then
      [F:BPA]BPAADDLIG(1) = [M:COR2]CPYADD(1)
    Else
      [F:BPA]BPAADDLIG(1) = ""
    Endif
    If dim([M:COR2]CPYADD(2)) > 0 Then
      [F:BPA]BPAADDLIG(2) = [M:COR2]CPYADD(2)
    Else
      [F:BPA]BPAADDLIG(2) = ""
    Endif
    [F:BPA]POSCOD = [M:COR2]CPYZIP
    [F:BPA]CTY = [M:COR2]CPYCTY
    If dim([M:COR2]CPYSAT) > 0 Then
      [F:BPA]SAT = [M:COR2]CPYSAT
    Else
      [F:BPA]SAT = ""
    Endif
    [F:BPA]CRY = [M:COR2]CPYCRY
    [F:BPA]CRYNAM = [M:COR2]CPYCRYNAM
    [F:BPA]UPDUSR = GUSER
    [F:BPA]UPDDAT = date$
    Rewrite [BPA]
    If fstat <> 0 Then
      IBERROR = 1
      #Erreur lors de la modification de l'adresse- ":"- num$([M:COR2]CPYBPATYP) - "/" - [M:COR2]BPRNUM - "/" - [M:COR2]CPYBPANUM
      GMESSAGE = mess(426,177,1)- ":"- num$([M:COR2]CPYBPATYP) - "/" - [M:COR2]BPRNUM - "/" - [M:COR2]CPYBPANUM
      GOK = 0
    Endif
  Else
    Unlock [BPA]
  Endif
  If IBMODIF = 1 and IBERROR = 0 Then
    #On a eu une modif, il faut reporté la modif
    For [CORL] Where [F:CORL]CNTNUM = [M:COR0]CNTNUM
      IBTRAITECOR = 1
      Gosub TEST_ADR_F_CORL_F_ADR
      If IBMODIF = 1 and IBTRAITECOR = 1 Then
        [F:CORL]CPYBPADES = [F:BPA]BPADES
        [F:CORL]CPYADD(0) = [F:BPA]BPAADDLIG(0)
        [F:CORL]CPYADD(1) = [F:BPA]BPAADDLIG(1)
        [F:CORL]CPYADD(2) = [F:BPA]BPAADDLIG(2)
        [F:CORL]CPYZIP = [F:BPA]POSCOD
        [F:CORL]CPYCTY = [F:BPA]CTY
        [F:CORL]CPYSAT = [F:BPA]SAT
        [F:CORL]CPYCRY = [F:BPA]CRY
        [F:CORL]CPYCRYNAM = [F:BPA]CRYNAM
        [F:CORL]UPDUSR = GUSER
        [F:CORL]UPDDAT = date$
        Rewrite [CORL]
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
          GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
          GOK = 0
        Endif
        If IBTRAITECOR = 1 and IBERROR = 0 Then
          Gosub GERE_COP
        Endif
        If IBERROR = 1 Then
          Break
        Endif
      Endif
    Next
  Endif
  If IBERROR = 1 Then
    GOK = 0
  Endif
Return

##########################################################################################################
$TEST_ADR_M_COR_M_CORSAVE
  IBMODIF = 0
  #On test les différentes zones
  #Ecran COR2
  #Libellé adresse
  If [M:COR2]CPYBPADES <> [M:CR2S]CPYBPADES Then
    IBMODIF = 1
  Endif
  #Adresse 1
  If dim([M:COR2]CPYADD(0)) > 0 Then
    If [M:COR2]CPYADD(0) <> [M:CR2S]CPYADD(0) Then
      IBMODIF = 1
    Endif
  Endif
  #Adresse 2
  If dim([M:COR2]CPYADD(1)) > 0 Then
    If [M:COR2]CPYADD(1) <> [M:CR2S]CPYADD(1) Then
      IBMODIF = 1
    Endif
  Endif
  #Adresse 3
  If dim([M:COR2]CPYADD(2)) > 0 Then
    If [M:COR2]CPYADD(2) <> [M:CR2S]CPYADD(2) Then
      IBMODIF = 1
    Endif
  Endif
  #Code postal
  If [M:COR2]CPYZIP <> [M:CR2S]CPYZIP Then
    IBMODIF = 1
  Endif
  #Ville
  If [M:COR2]CPYCTY <> [M:CR2S]CPYCTY Then
    IBMODIF = 1
  Endif
  #Etat
  If dim([M:COR2]CPYSAT) > 0 Then
    If [M:COR2]CPYSAT <> [M:CR2S]CPYSAT Then
      IBMODIF = 1
    Endif
  Endif
  #Pays
  If [M:COR2]CPYCRY <> [M:CR2S]CPYCRY Then
    IBMODIF = 1
  Endif
  #Nom Pays
  If [M:COR2]CPYCRYNAM <> [M:CR2S]CPYCRYNAM Then
    IBMODIF = 1
  Endif
Return

