#<AdxTL>@(#)6.0.0.0 $Revision$ Consultation SFC
Local Char PARAM(20)(1..10)
PARAM(1) = num$(0)
PARAM(2) = ""
PARAM(3) = "A-HNAV"
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""
PARAM(8) = ""
Call GCONSULT("SFC","",PARAM) From GCONSULT
End


$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : [M:SFC1]FLG = 0
                      [M:SFC1]    = [M:CSFC]
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When "CLECUR"     : Gosub CLECUR
  When Default
Endcase
Return
############################################################
$AUTORIS
# Ouvertures des tables en local pour conservation des pointeurs
Local File ITMMASTER  [ITM]
Local File FACILITY   [FCY]
Local File ITMFACILIT [ITF]
Local File ITMMVT     [ITV]
Local File ITMCATEG   [ITG]
Local File STOLOT     [STL]
Local File STOCK      [STO]
Local File STOALL     [STA]
Local File STOLOC     [STC]
Local File ORDERS     [ORD]
Return
############################################################
$OUVRE
#--- Issue 122102
# Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#---
Local Char    WPAR
Local Char    WFIL(250), WFILS(250), WFIL1(250), WFILSPE(250)
Local Char    DFCY(GLONFCY), FFCY(GLONFCY)
Local Integer WGCONSULT : WGCONSULT = GCONSULT
#
Local Integer W_LIG, SVGMAXLIG, WNOL, SVGNOLIGN, CUMLIG, WDET, SVGNOL, WPREM, I
#
Local Char    W_FLD(44)(18)
W_FLD(00) = "AQR INTSTO    PHYSTO    CTLSTO    REJSTO    "
W_FLD(01) = "AQR PLFSTO    PLFPHYSTO PLFCTLSTO PLFREJSTO "
W_FLD(02) = "AQR BPRSTO    BPRPHYSTO BPRCTLSTO BPRREJSTO "
W_FLD(03) = "AQR SCOSTO    SCOPHYSTO SCOCTLSTO SCOREJSTO "
W_FLD(04) = "AQR INTALL    PHYALL    CTLALL    REJALL    "
W_FLD(05) = "AQR SCOALL    SCOPHYALL SCOCTLALL SCOREJALL "
W_FLD(06) = "    DETSHT    DETSHT                        "
W_FLD(07) = "    GLOALL    GLOALL                        "
W_FLD(08) = "    GLOSHT    GLOSHT                        "
W_FLD(09) = "    TRFSTO    TRFSTO                        "
W_FLD(10) = "    TRASTO    TRASTO                        "
W_FLD(11) = "    SALSTO    SALSTO                        "
W_FLD(12) = "    WAISTO    WAISTO                        "
W_FLD(13) = "    ORDSTO    ORDSTO                        "
W_FLD(14) = "    SCCALL    SCCALL                        "
W_FLD(15) = "    SCCLNDSTO SCCLNDSTO                     "
W_FLD(16) = "   MAVASTO    AVASTO                        "
#W_FLD(17) = "   MALLSTO    ALLSTO                        "
W_FLD(17) = "   MALLSTO    INTALL    SCOALL              "   #MAE,bg 92805

#
Local Decimal W_TOTFCY(dim(W_FLD))
Local Decimal W_TOTAAA(dim(W_FLD))
Local Decimal W_TOTQQQ(dim(W_FLD))
Local Decimal W_TOTRRR(dim(W_FLD))
Local Decimal W_TOTAQR(dim(W_FLD))
#
Local Decimal W_CUMTOTFCY(dim(W_FLD))
Local Decimal W_CUMTOTAAA(dim(W_FLD))
Local Decimal W_CUMTOTQQQ(dim(W_FLD))
Local Decimal W_CUMTOTRRR(dim(W_FLD))
Local Decimal W_CUMTOTAQR(dim(W_FLD))


Local Char    W_EVA(40)
Local Decimal W_ACT
Local Integer W_I, W_J, W_K, W_L, W_M, W_N

Local Integer WSTA
Local Decimal WDISPO
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSFC"
SUITE = 1
RETOUR = 1
Raz [F:FCY]
Return
############################################################
$LOAD_SCREEN

For W_I = 1 To dim(PARAM)
  Case W_I
    When 1 :
      GCONSULT = val(PARAM(W_I))
    When 2 :
      If PARAM(W_I) <> "" & PARAM(W_I) <> "***"
        Call LECTURE("FCY",PARAM(W_I),"") From CONTOBJ
        If !fstat
          [M:SFC1]FCY = PARAM(W_I)
        Endif
      Else
        If PARAM(W_I) = ""
          [M:SFC1]FCY = GFCYDEF(0)
          Call LECTURE("FCY",[M:SFC1]FCY,"") From CONTOBJ
        Endif
      Endif
    When 3 :
      If PARAM(W_I) <> ""
        Call LECTURE("ITM",PARAM(W_I),"") From CONTOBJ
        If !fstat
          [M:SFC1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(W_I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(W_I))
      Endif
  Endcase
Next W_I

If clalev([M:CSFC]) <> 0 & [M:CSFC]MEMO = "STD"       # hcb 61281
  [M:SFC1] = [M:CSFC]
Endif


If !find([M:SFC1]AAAFLG,1,2) : [M:SFC1]AAAFLG= 2 : Endif
If !find([M:SFC1]QQQFLG,1,2) : [M:SFC1]QQQFLG= 2 : Endif
If !find([M:SFC1]RRRFLG,1,2) : [M:SFC1]RRRFLG= 2 : Endif
If !find([M:SFC1]DETFLG,1,2) : [M:SFC1]DETFLG= 1 : Endif
If !find([M:SFC1]CUMFLG,1,2) : [M:SFC1]CUMFLG= 1 : Endif
If find([M:SFC1]WMAXLIG,0)   : [M:SFC1]WMAXLIG=dim([M:SFC2]STOFCY) : Endif
Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
#--- Issue 122102
# Restauration variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#---
Return
############################################################
$LECTURE
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:SFC1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:SFC1]ITMREF
        Diszo [M:SFC1]FCY
    Endif
Endif

Raz SVGMAXLIG
If [M:SFC1]ITMREF = ""
  NBLU = 0
  Return
Endif
Gosub CHANGE_MSK From GCONSULT
Raz SVGNOL
Raz WPREM
If SVGMAXLIG=0
    [M:SFC1]WMAXLIG=MAXLIG
    SVGMAXLIG=MAXLIG
Endif
If MAXLIG<>SVGMAXLIG
  MAXLIG=SVGMAXLIG
Endif
If [M:SFC1]DETFLG=2 & [M:SFC1]CUMFLG=2
  MAXLIG-=4
Endif
If [M:SFC1]DETFLG=1 & [M:SFC1]CUMFLG=2
  MAXLIG-=1
Endif
If MAXLIG<1
  GMESSAGE=mess(151,184,1)
  Call ERREUR(GMESSAGE)     From GESECRAN
  Goto LECTURE_FIN
Endif
#-- ligne à partir de laquelle on commence l'impression
If CHGPAG<0 NOL=MAXLIG-1 : Endif
Gosub TRT_FILTER
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
#-- Si on souhaite avoir un cumul
If [M:SFC1]CUMFLG=2 & CHGPAG=1
  Raz W_CUMTOTFCY, W_CUMTOTAAA, W_CUMTOTQQQ, W_CUMTOTRRR, W_CUMTOTAQR
  Gosub CAL_CUMUL
Endif
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
        Filter [ITV] Where evalue(WFIL) &
&                    evalue(WFILS)      &
&                    evalue(WFIL1)      &
&                    evalue(WFILSPE)
&                    Order By Key ITV0 Asc
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
        Filter [ITV] Where evalue(WFIL) &
&                    evalue(WFILS)      &
&                    evalue(WFIL1)      &
&                    evalue(WFILSPE)
&                    Order By Key ITV0 Desc
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:SFC2] : Endif

$BOUCLE
For [ITV] With Nohint
  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:SFC2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
    If [M:SFC1]DETFLG=1 & [M:SFC1]CUMFLG=1 & NOL+1 >= MAXLIG : SUITE=2 : Break : Endif
    If [M:SFC1]DETFLG=1 & [M:SFC1]CUMFLG=2 & NOL+1 >= MAXLIG : SUITE=2 : Break : Endif
    If [M:SFC1]DETFLG=2 & [M:SFC1]CUMFLG=1 & NOL+4 >= MAXLIG : SUITE=2 : Break : Endif
    If [M:SFC1]DETFLG=2 & [M:SFC1]CUMFLG=2 & NOL+4 >= MAXLIG : SUITE=2 : Break : Endif
  Else
    If [M:SFC1]DETFLG=1 & [M:SFC1]CUMFLG=1 & NOL   < 0  : RETOUR=2 : Break : Endif
    If [M:SFC1]DETFLG=1 & [M:SFC1]CUMFLG=2 & NOL   < 0  : RETOUR=2 : Break : Endif
    If [M:SFC1]DETFLG=2 & [M:SFC1]CUMFLG=1 & NOL-4 < 0  : RETOUR=2 : Break : Endif
    If [M:SFC1]DETFLG=2 & [M:SFC1]CUMFLG=2 & NOL-4 < 0  : RETOUR=2 : Break : Endif
  Endif
  Gosub LOA_LIGNE
Next
Filter [ITV]    # 38354 mm 11.06
#
If CHGPAG<0
  SVGNOL=NOL
Endif
If [M:SFC1]CUMFLG=2
  Gosub AFF_TOTAL
Endif
#
$LECTURE_FIN
#[M:SFC2]NBLIG=SVGMAXLIG   # 78572
MAXLIG=SVGMAXLIG
If CHGPAG<0
  Raz WNOL
  For I=0 To MAXLIG-1
    If [M:SFC2]STOFCY(I)<>""
      WNOL+=1
    Endif
  Next
  NOL=(SVGMAXLIG-WNOL)
  If NOL<0 NOL=0 : Endif
Endif
Return
############################################################
$DEB_CRIT

[M:CSFC]    = [M:SFC1]
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:CSFC]FCYSEL
        Endif
Endif

Return
############################################################

$TRT_FILTER
[M:SFC1]FLG = 1
Raz [M:SFC2]
Raz W_TOTFCY, W_TOTAAA, W_TOTQQQ, W_TOTRRR, W_TOTAQR
Gosub LOAD_FILTER
# Calcul nombre de lignes affichées
If [M:SFC1]DETFLG = 2
  W_LIG = 0
  If [M:SFC1]AAAFLG = 2
    W_LIG += 1
  Endif
  If [M:SFC1]QQQFLG = 2
    W_LIG += 1
  Endif
  If [M:SFC1]RRRFLG = 2
    W_LIG += 1
  Endif
  If W_LIG > 1
    W_LIG += 1
  Endif
Else
  W_LIG = 1
Endif
Return
############################################################
$LOAD_FILTER
WFIL1="1=1"
WFIL = "[F:ITV]ITMREF=[M:SFC1]ITMREF"
If [M:SFC1]BASPAG > 0
    WFIL += "&find([F:ITV]STOFCY,[M:SFC1]FCYSEL(0..[M:SFC1]BASPAG-1))"
Else
    If [M:SFC1]FCY <> ""
      WFIL += "&[F:ITV]STOFCY=[M:SFC1]FCY"
    Endif
Endif
If [M:SFC1]FCY = "" | [M:SFC1]BASPAG > 0
    If GUSRFCY(1) <> "\" & GNBAUZ <> GNBSITE
      WFIL += "&find([F:ITV]STOFCY,GUSRFCY(1..GNBAUZ))"
    Endif
Endif
Case CHGPAG
    When  3 : # rafraichissement
       WFIL1 += "&[F:ITV]STOFCY>=DFCY"
    When  2 : # suite
       WFIL1 += "&[F:ITV]STOFCY>FFCY"
    When -2 : # retour
       WFIL1 += "&[F:ITV]STOFCY<DFCY"
Endcase
Return
############################################################
$LOA_LIGNE
Raz WDET
Gosub ADD_ENR
If NOL+1<0 : Return : Endif
#
Read [ITM]ITM0=[F:ITV]ITMREF
If fstat
  Raz [F:ITM]
Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:ITV]STOFCY | [F:ITF]ITMREF <> [F:ITV]ITMREF
   Read [ITF]ITF0 = [F:ITV]ITMREF;[F:ITV]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

[M:SFC1]STU       = [F:ITM]STU
[M:SFC1]UOM       = [F:ITM]STU
[M:SFC1]ITMSTA    = [F:ITM]ITMSTA
[M:SFC1]STOMGTCOD = [F:ITF]STOMGTCOD
If [F:FCY]FCY <> [F:ITV]STOFCY
  Read [FCY]FCY0=[F:ITV]STOFCY
  If fstat
    Raz [F:FCY]
  Else
    Call PARAM([F:ITV]STOFCY,"STODIS",WPAR) From ADOVAL
  Endif
Endif
Read [ITG]ITG1=[F:ITM]TCLCOD;[F:ITV]STOFCY
If fstat
   Read [ITG]ITG1=[F:ITM]TCLCOD;""
   If fstat Raz [F:ITG] Endif
Endif
If [M:SFC1]QTYTYP = 1 & ([F:ITF]STOMGTCOD = 3 | [F:ITF]STOMGTCOD = 4)
  Gosub TRT_TITRE
Endif
Raz W_TOTFCY,W_J, W_K, W_L, W_M, W_N
Case [M:SFC1]DETFLG
  When 2 :
    If [M:SFC1]AAAFLG = 2
      Gosub ADD_LIG
      Call LOA_LIGSTA([F:ITV]STOFCY,"A",2,0,0,0,W_K)
      Call CAL_TOT("A" ,W_FLD,W_TOTFCY,W_L)
      Call CAL_TOT("A" ,W_FLD,W_TOTAAA,W_M)
      Call CAL_TOT("A" ,W_FLD,W_TOTAQR,W_N)
    Endif
    If [M:SFC1]QQQFLG = 2
      Gosub ADD_LIG
      Call LOA_LIGSTA([F:ITV]STOFCY,"Q",0,2,0,0,W_K)
      W_L = 0  #MAE, bg 92805
      Call CAL_TOT("Q" ,W_FLD,W_TOTFCY,W_L)
      Call CAL_TOT("Q" ,W_FLD,W_TOTQQQ,W_M)
      Call CAL_TOT("Q" ,W_FLD,W_TOTAQR,W_N)
    Endif
    If [M:SFC1]RRRFLG = 2
      Gosub  ADD_LIG
      Call LOA_LIGSTA([F:ITV]STOFCY,"R",0,0,2,0,W_K)
      W_L = 0  #MAE, bg 92805
      Call CAL_TOT("R" ,W_FLD,W_TOTFCY,W_L)
      Call CAL_TOT("R" ,W_FLD,W_TOTRRR,W_M)
      Call CAL_TOT("R" ,W_FLD,W_TOTAQR,W_N)
    Endif
    Gosub ADD_LIG
    Call AFF_CUM([F:ITV]STOFCY,"*",W_FLD,W_TOTFCY)
  When Default :
    Gosub ADD_LIG
    Call LOA_LIGSTA([F:ITV]STOFCY,"* ",[M:SFC1]AAAFLG,[M:SFC1]QQQFLG,[M:SFC1]RRRFLG,0,W_K)
    If [M:SFC1]AAAFLG = 2
      Call CAL_TOT("A" ,W_FLD,W_TOTAQR,W_L)
    Endif
    If [M:SFC1]QQQFLG = 2
      Call CAL_TOT("Q" ,W_FLD,W_TOTAQR,W_L)
    Endif
    If [M:SFC1]RRRFLG = 2
      Call CAL_TOT("R" ,W_FLD,W_TOTAQR,W_L)
    Endif
Endcase
If CHGPAG <0
  If [M:SFC1]DETFLG=1 : NOL-= 1 : Endif
  If [M:SFC1]DETFLG=2 : NOL-= 4 : Endif
Endif
Return
############################################################
Subprog LOA_LIGSTA(LFCY,LTXT,LSTA,LSTQ,LSTR,LCUM,LFLG)
Value    Char     LFCY
Value    Char     LTXT
Value    Shortint LSTA
Value    Shortint LSTQ
Value    Shortint LSTR
Value    Shortint LCUM
Variable Integer  LFLG
#
Local    Integer W_I
If LCUM<>0
  nolign=1
Endif
#
[M:SFC2]STOFCY(nolign-1) = LFCY
If left$(LFCY,1) = "*"
  [M:SFC2]FCYSHO(nolign-1) = mess(142,124,1)
  [M:SFC2]NODSP(nolign-1) = "X"
Else
  [M:SFC2]FCYSHO(nolign-1) = [F:FCY]FCYSHO
  [M:SFC2]NODSP(nolign-1) = ""
Endif

#eb
If [M:SFC1]DETFLG=2 & LTXT="*"
   [M:SFC2]NODSP(nolign-1) = "X"
Endif
If [M:SFC1]DETFLG=2 & (LSTA=2 |LSTQ=2 | LSTR=2)
   [M:SFC2]LIB(nolign-1) = [M:SFC2]STOFCY(nolign-1)+"/"+LTXT
Else
   [M:SFC2]LIB(nolign-1) = [M:SFC2]STOFCY(nolign-1)
Endif

[M:SFC2]STA   (nolign-1) = LTXT
[M:SFC2]STU   (nolign-1) = [F:ITM]STU
[M:SFC2]INTSTO(nolign-1) = 0
[M:SFC2]PLFSTO(nolign-1) = 0
[M:SFC2]BPRSTO(nolign-1) = 0
[M:SFC2]SCOSTO(nolign-1) = 0
[M:SFC2]INTALL(nolign-1) = 0
[M:SFC2]SCOALL(nolign-1) = 0
[M:SFC2]ALLSTO(nolign-1) = 0
If LSTA  = 2
  [M:SFC2]INTSTO(nolign-1) += [F:ITV]PHYSTO
  [M:SFC2]PLFSTO(nolign-1) += [F:ITV]PLFPHYSTO
  [M:SFC2]BPRSTO(nolign-1) += [F:ITV]BPRPHYSTO
  [M:SFC2]SCOSTO(nolign-1) += [F:ITV]SCOPHYSTO
  [M:SFC2]INTALL(nolign-1) += [F:ITV]PHYALL
  [M:SFC2]SCOALL(nolign-1) += [F:ITV]SCOPHYALL
  [M:SFC2]ALLSTO(nolign-1) += [F:ITV]PHYALL
  [M:SFC2]ALLSTO(nolign-1) += [F:ITV]SCOPHYALL
Endif
If LSTQ = 2
  [M:SFC2]INTSTO(nolign-1) += [F:ITV]CTLSTO
  [M:SFC2]PLFSTO(nolign-1) += [F:ITV]PLFCTLSTO
  [M:SFC2]BPRSTO(nolign-1) += [F:ITV]BPRCTLSTO
  [M:SFC2]SCOSTO(nolign-1) += [F:ITV]SCOCTLSTO
  [M:SFC2]INTALL(nolign-1) += [F:ITV]CTLALL
  [M:SFC2]SCOALL(nolign-1) += [F:ITV]SCOCTLALL
  [M:SFC2]ALLSTO(nolign-1) += [F:ITV]CTLALL
  [M:SFC2]ALLSTO(nolign-1) += [F:ITV]SCOCTLALL
Endif
If LSTR = 2
  [M:SFC2]INTSTO(nolign-1) += [F:ITV]REJSTO
  [M:SFC2]PLFSTO(nolign-1) += [F:ITV]PLFREJSTO
  [M:SFC2]BPRSTO(nolign-1) += [F:ITV]BPRREJSTO
  [M:SFC2]SCOSTO(nolign-1) += [F:ITV]SCOREJSTO
  [M:SFC2]INTALL(nolign-1) += [F:ITV]REJALL
  [M:SFC2]SCOALL(nolign-1) += [F:ITV]SCOREJALL
  [M:SFC2]ALLSTO(nolign-1) += [F:ITV]REJALL
  [M:SFC2]ALLSTO(nolign-1) += [F:ITV]SCOREJALL
Endif
If LFLG = 0
  [M:SFC2]GLOALL(nolign-1)     = [F:ITV]GLOALL
  [M:SFC2]GLOSHT(nolign-1)     = [F:ITV]GLOSHT
  [M:SFC2]DETSHT(nolign-1)     = [F:ITV]DETSHT
  [M:SFC2]TRFSTO(nolign-1)     = [F:ITV]TRFSTO
  [M:SFC2]TRASTO(nolign-1)     = [F:ITV]TRASTO
  [M:SFC2]ORDSTO(nolign-1)     = [F:ITV]ORDSTO
  [M:SFC2]SALSTO(nolign-1)     = [F:ITV]SALSTO
  [M:SFC2]WAISTO(nolign-1)     = [F:ITV]WAISTO
  [M:SFC2]SCCALL(nolign-1)     = [F:ITV]SCCALL
  [M:SFC2]SCCLNDSTO(nolign-1)  = [F:ITV]SCCLNDSTO
  #--- calcul du stock dispo en statut R
  WSTA=0
  WDISPO=0
  If [F:ITG]GLOAAAFLG = 2   WSTA += 1  Endif
  If [F:ITG]GLOQQQFLG = 2   WSTA += 2  Endif
  If [F:ITG]GLORRRFLG = 2   WSTA += 4  Endif
  #--- TS 106217
  #Call STODISPO("",[M:SFC2]STOFCY(nolign-1),[M:SFC1]ITMREF,"*","*",1,WSTA,"","","",WDISPO) From STKLIB
  Call STODISPO("",[M:SFC2]STOFCY(nolign-1),[M:SFC1]ITMREF,"*","*",1,WSTA,"","","","",WDISPO) From STKLIB
  #---
  #--- Issue 99815
  #[M:SFC2]AVASTO(nolign-1)  = WDISPO
  [M:SFC2]AVASTO(nolign-1)  = max(WDISPO,0)
  #---
Endif
LFLG = 1
End
############################################################
Subprog CAL_TOT(LSTA,LREF,LTOT,LFLG)
Value    Char    LSTA
Value    Char    LREF()
Variable Decimal LTOT()
Variable Integer LFLG
#
Local Char    W_TBL(10), W_FLDA(20), W_FLDQ(20), W_FLDR(20)
Local Decimal W_TOT
Local Integer W_I
#
For W_I = 0 To dim(LREF)-1
  W_TBL  = vireblc(mid$(LREF(W_I),05,10),1)
  If mid$(LREF(W_I),4,7)="MALLSTO"       #MAE,bg 92805
     W_FLDA = "[M]"+vireblc(mid$(LREF(W_I),15,10),1)+"(nolign-1)"
     W_FLDQ = "[M]"+vireblc(mid$(LREF(W_I),25,10),1)+"(nolign-1)"
  Elsif mid$(LREF(W_I),4,1)="M"   #MAE,fin bg 92805
     W_FLDA = "[M]"+vireblc(mid$(LREF(W_I),15,10),1)+"(nolign-1)"
     W_FLDQ = "[M]"+vireblc(mid$(LREF(W_I),25,10),1)+"(nolign-1)"
     W_FLDR = "[M]"+vireblc(mid$(LREF(W_I),35,10),1)+"(nolign-1)"
  Else
     W_FLDA = "[F:ITV]"+vireblc(mid$(LREF(W_I),15,10),1)
     W_FLDQ = "[F:ITV]"+vireblc(mid$(LREF(W_I),25,10),1)
     W_FLDR = "[F:ITV]"+vireblc(mid$(LREF(W_I),35,10),1)
  Endif
#
  If left$(LREF(W_I),3) = "   "
    If LFLG = 0
      #--- X3-42424
      If LSTA="A"  & mid$(LREF(W_I),4,7)<>"MALLSTO"
        W_TOT = evalue(W_FLDA)
        LTOT(W_I) += W_TOT
      Endif
      #---
      If mid$(LREF(W_I),4,7)="MALLSTO"    #MAE,bg 92805
        W_TOT = evalue(W_FLDA)
        LTOT(W_I) += W_TOT
        W_TOT = evalue(W_FLDQ)            #MAE,bg 92805
        LTOT(W_I) += W_TOT                #MAE,bg 92805
      Endif                               #MAE, fin bg 92805
    Endif
  Else
    Case LSTA
      When "A" :
        W_TOT = evalue(W_FLDA)
        LTOT(W_I) += W_TOT
      When "Q" :
        W_TOT = evalue(W_FLDQ)
        LTOT(W_I) += W_TOT
      When "R" :
        W_TOT = evalue(W_FLDR)
        LTOT(W_I) += W_TOT
      When "*"
        W_TOT = evalue(W_FLDA)
        LTOT(W_I) += W_TOT
        W_TOT = evalue(W_FLDQ)
        LTOT(W_I) += W_TOT
        W_TOT = evalue(W_FLDR)
        LTOT(W_I) += W_TOT
    Endcase
  Endif
Next W_I
#
LFLG = 1

End
############################################################
$AFF_TOTAL
SVGNOLIG=nolign
WNOL    =NOL
Raz I
Raz WNOL
[M:SFC2]NBLIG=SVGMAXLIG
MAXLIG=SVGMAXLIG
If CHGPAG<0
  For I=SVGMAXLIG-1 To 0 Step -1
    If [M:SFC2]STOFCY(I)<>""
      WNOL=I : Break
    Endif
  Next I
Endif
If CHGPAG<0 : NOL=MAXLIG-1 : Endif
If CHGPAG<0 : NOL=WNOL : Endif
If [M:SFC1]FCY = "" & [M:SFC1]ITMREF<>""
  If [M:SFC1]DETFLG=2 & [M:SFC1]CUMFLG=2 & NOL+4 <=SVGMAXLIG
    If [M:SFC1]AAAFLG = 2
      NOL    += 1
      nolign = NOL+1
      Call AFF_CUM("***","A",W_FLD,W_CUMTOTAAA)
    Endif
    If [M:SFC1]QQQFLG = 2
      NOL    += 1
      nolign = NOL+1
      Call AFF_CUM("***","Q",W_FLD,W_CUMTOTQQQ)
    Endif
    If [M:SFC1]RRRFLG = 2
      NOL    += 1
      nolign = NOL+1
      Call AFF_CUM("***","R",W_FLD,W_CUMTOTRRR)
    Endif
    NOL    += 1
    nolign = NOL+1
    Call AFF_CUM("***","*",W_FLD,W_CUMTOTAQR)
  Elsif [M:SFC1]DETFLG=1 & [M:SFC1]CUMFLG=2 & NOL+1 <=SVGMAXLIG
      NOL    += 1
      nolign = NOL+1
      Call AFF_CUM("***","*",W_FLD,W_CUMTOTAQR)
  Endif
Endif
nolign=SVGNOLIGN
Return
############################################################
Subprog AFF_CUM(LFCY,LTXT,LREF,LTOT)
Value Char    LFCY
Value Char    LTXT
Value Char    LREF()
Value Decimal LTOT()
#
Local Char    W_MSK(30)
Local Integer W_I
#
[M:SFC2]STOFCY(nolign-1) = LFCY
If left$(LFCY,1) = "*"
  [M:SFC2]FCYSHO(nolign-1) = mess(142,124,1)
  [M:SFC2]NODSP(nolign-1) = "X"
Else
  [M:SFC2]FCYSHO(nolign-1) = [F:FCY]FCYNAM
  [M:SFC2]NODSP(nolign-1) = ""
Endif
[M:SFC2]STA   (nolign-1) = LTXT

#eb
If [M:SFC1]DETFLG=2 & LTXT="*"
   [M:SFC2]NODSP(nolign-1) = "X"
Endif


#
For W_I = 0 To dim(LTOT)-1
  W_MSK = "[M:SFC2]"+vireblc(mid$(LREF(W_I),5,10),1)+"(nolign-1)"
  Assign W_MSK With LTOT(W_I)
Next W_I
End

############################################################
# Article gérés par titre : effacement stock du buffer
# et reconstitution via les tables stock
############################################################
$TRT_TITRE
Raz [F:ITV]PHYSTO,[F:ITV]PHYALL,[F:ITV]CTLSTO,[F:ITV]CTLALL,[F:ITV]REJSTO,
&   [F:ITV]REJALL,[F:ITV]PLFPHYSTO,[F:ITV]PLFCTLSTO,[F:ITV]PLFREJSTO,
&   [F:ITV]BPRPHYSTO,[F:ITV]BPRCTLSTO,[F:ITV]BPRREJSTO,[F:ITV]SCOPHYSTO,
&   [F:ITV]SCOPHYALL,[F:ITV]SCOCTLSTO,[F:ITV]SCOCTLALL,[F:ITV]SCOREJALL

Filter [STO] Where STOFCY = [F:ITV]STOFCY &
&                    ITMREF = [F:ITV]ITMREF
&              Order By Key STO3
For [STO]
  Case [F:STO]LOCCAT
      When 0, 1 :
        Case left$([F:STO]STA,1)
          When "A" : [F:ITV]PHYSTO    += [F:STO]QTYSTU
                     [F:ITV]PHYALL    += [F:STO]CUMALLQTY
          When "Q" : [F:ITV]CTLSTO    += [F:STO]QTYSTU
                     [F:ITV]CTLALL    += [F:STO]CUMALLQTY
          When "R" : [F:ITV]REJSTO    += [F:STO]QTYSTU
                     [F:ITV]REJALL    += [F:STO]CUMALLQTY
        Endcase
      When 2 :
        Case left$([F:STO]STA,1)
          When "A" : [F:ITV]PLFPHYSTO += [F:STO]QTYSTU
          When "Q" : [F:ITV]PLFCTLSTO += [F:STO]QTYSTU
          When "R" : [F:ITV]PLFREJSTO += [F:STO]QTYSTU
        Endcase
     When 3 :
        Case left$([F:STO]STA,1)
          When "A" : [F:ITV]BPRPHYSTO += [F:STO]QTYSTU
          When "Q" : [F:ITV]BPRCTLSTO += [F:STO]QTYSTU
          When "R" : [F:ITV]BPRREJSTO += [F:STO]QTYSTU
        Endcase
     When 4 :
        Case left$([F:STO]STA,1)
          When "A" : [F:ITV]SCOPHYSTO += [F:STO]QTYSTU
                     [F:ITV]SCOPHYALL += [F:STO]CUMALLQTY
          When "Q" : [F:ITV]SCOCTLSTO += [F:STO]QTYSTU
                     [F:ITV]SCOCTLALL += [F:STO]CUMALLQTY
          When "R" : [F:ITV]SCOREJSTO += [F:STO]QTYSTU
                     [F:ITV]SCOREJALL += [F:STO]CUMALLQTY
        Endcase
    Endcase
Next
Filter [STO]
Return

############################################################
$AP_MAGNETO
[M:SFC1]FLG = 0
Return

############################################################
$CLECUR
If CLECUR=1
   #[M:SFC1]ITMDES1 = [F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SFC1]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   Affzo [M:SFC1]ITMDES1
Endif
Return

############################################################
$SETBOUT
If [M:SFC1]ITMREF <> "" & [M:SFC2]NBLIG > 0
  CHMEN = "1"
  Gosub SET_BOUT_SPE From GSAISIE
Endif
If [M:SFC1]FCY = ""
  Call VIREBOUT(CHAINE,"d") From GOBJET
Endif
Return
############################################################
$EXEBOUT
Return
############################################################
$CAL_CUMUL

Filter [ITV] Where evalue(WFIL) &
&                  evalue(WFILS)&
&                  evalue(WFIL1)
&                  Order By Key ITV0 Asc
For [ITV]ITV0
    Raz W_CUMTOTFCY,W_J, W_K, W_L, W_M, W_N
    If [M:SFC1]DETFLG=2 | [M:SFC1]CUMFLG=2
      # Issue X3-80585 - 2018-03-02 by MAE : on réaffecte ITV avec les qtés contenues dans STOCK
      #avant le calcul des cumuls si on est en qté physique. Dans ITV, on a que les qtés actives
      If [M:SFC1]QTYTYP <> 2 & ([F:ITM]STOMGTCOD = 3 | [F:ITM]STOMGTCOD = 4)
        Gosub TRT_TITRE
      Endif
      # End issue X3-80585
      If [M:SFC1]AAAFLG = 2
        Call LOA_LIGSTA([F:ITV]STOFCY,"A",2,0,0,1,W_K)
        Call CAL_TOT("A" ,W_FLD,W_CUMTOTFCY,W_L)
        Call CAL_TOT("A" ,W_FLD,W_CUMTOTAAA,W_M)
        Call CAL_TOT("A" ,W_FLD,W_CUMTOTAQR,W_N)
      Endif
      If [M:SFC1]QQQFLG = 2
        Call LOA_LIGSTA([F:ITV]STOFCY,"Q",0,2,0,1,W_K)
        Call CAL_TOT("Q" ,W_FLD,W_CUMTOTFCY,W_L)
        Call CAL_TOT("Q" ,W_FLD,W_CUMTOTQQQ,W_M)
        Call CAL_TOT("Q" ,W_FLD,W_CUMTOTAQR,W_N)
      Endif
      If [M:SFC1]RRRFLG = 2
        Call LOA_LIGSTA([F:ITV]STOFCY,"R",0,0,2,1,W_K)
        Call CAL_TOT("R" ,W_FLD,W_CUMTOTFCY,W_L)
        Call CAL_TOT("R" ,W_FLD,W_CUMTOTRRR,W_M)
        Call CAL_TOT("R" ,W_FLD,W_CUMTOTAQR,W_N)
      Endif
    Endif
Next
Filter [ITV]
Return
############################################################
$ADD_LIG
NOL    += 1
nolign = NOL+1
Return
############################################################
$ADD_ENR
If CHGPAG <0
  If NOL=MAXLIG
    FFCY      = [F:ITV]STOFCY
  Endif
  DFCY  = [F:ITV]STOFCY
  If [M:SFC1]DETFLG=1 : NOL-= 1 : Endif
  If [M:SFC1]DETFLG=2 : NOL-= 4 : Endif
  If NOL<=-1 NOL=-1 : Endif
Else
  If NOL+1=0
    DFCY  = [F:ITV]STOFCY
  Endif
  FFCY    = [F:ITV]STOFCY
Endif
Return
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SFC1]FLG    = 0
End

############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char     VALEUR
[M:SFC1]UOM       = [F:ITM]STU
[M:SFC1]STU       = [F:ITM]STU
[M:SFC1]ITMSTA    = [F:ITM]ITMSTA
[M:SFC1]STOMGTCOD = [F:ITM]STOMGTCOD
Affzo [M:SFC1]STU
Affzo [M:SFC1]ITMSTA
Affzo [M:SFC1]STOMGTCOD
End
###########################################################
Subprog C_FCYSEL(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:CSFC]FCYSEL(0..[M:CSFC]BASPAG-1)) From OBJDIV
End
############################################################
Subprog AV_STOFCY(VALEUR)
Variable Char    VALEUR
If nolign > 0
  If VALEUR = "***"
    pcolor = GCOUL(1)
  Else
    Case [M]STA(nolign-1)
      When "*"     : pcolor = GCOUL(3)
      When Default : pcolor = GCOUL(0)
    Endcase
  Endif
Endif
End
############################################################
Subprog IB_NBLIG
If nolign > 0
  If [M]ALLSTO(nolign-1) = 0 & GFONC1 <> "GESPNH" : Raz GBOUT4 : Endif
  If [M]GLOALL(nolign-1) = 0     : Raz GBOUT5 : Endif
  If [M]DETSHT(nolign-1) = 0 & [M]GLOSHT(nolign-1) = 0  : Raz GBOUT6 : Endif
  If [M]TRFSTO(nolign-1) = 0     : Raz GBOUT7 : Endif
  If [M]TRASTO(nolign-1) = 0     : Raz GBOUT8 : Endif
  If [M]BPRSTO(nolign-1) = 0     : Raz GBOUT9 : Endif
  If [M]STOFCY(nolign-1) = "***"
    If [M:SFC1]FCY = "" & [M:SFC1]BASPAG <> 0
      Raz GBOUT11
      Raz GBOUT12
    Endif
  Endif
# <eb> 28.11.2003
#  Case [M:SFC2]STA(nolign-1)
#    When "A"     : [M:SFC1]FILTAB = 'left$(STA,1)="A"'
#    When "Q"     : [M:SFC1]FILTAB = 'left$(STA,1)="Q"'
#    When "R"     : [M:SFC1]FILTAB = 'left$(STA,1)="R"'
#    When Default : [M:SFC1]FILTAB = '1=1'
#  Endcase
Endif
End
############################################################
Subprog AS_NBLIG
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SFC1]FLG = 0
# Issue X3-80585 - 2018-03-02 by MAE : lecteure de ITM pour le calcul des cumuls en titre
Read [ITM]ITM0 = VALEUR
If fstat
  Raz [ITM]
Endif
# End issue X3-80585
End
############################################################
Subprog C_DETFLG(VALEUR)
Variable Integer VALEUR
[M:SFC1]FLG = 0
If VALEUR=2 & [M]CUMFLG=2 & [M:SFC1]WMAXLIG<8
  GERR=1
  GMESSAGE=mess(151,184,1)
  mkstat=1
Elsif VALEUR=2 & [M]CUMFLG=1 & [M:SFC1]WMAXLIG<4
  GERR=1
  GMESSAGE=mess(151,184,1)
  mkstat=1
Elsif VALEUR=1 & [M]CUMFLG=2 & [M:SFC1]WMAXLIG<2
  GERR=1
  GMESSAGE=mess(151,184,1)
  mkstat=1
Endif
End
############################################################
Subprog AM_QTYTYP(VALEUR)
Variable Integer VALEUR
[M:SFC1]FLG = 0
End
############################################################
Subprog AM_AAAFLG(VALEUR)
Variable Integer VALEUR
[M:SFC1]FLG = 0
End
############################################################
Subprog AM_QQQFLG(VALEUR)
Variable Integer VALEUR
[M:SFC1]FLG = 0
End
############################################################
Subprog AM_RRRFLG(VALEUR)
Variable Integer VALEUR
[M:SFC1]FLG = 0
End
##########################################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
##########################################################################
Subprog AV_FCY(VALEUR)
Variable Char     VALEUR
If [M]FCYSEL <> ""
   mkstat = 1
Endif
End
##########################################################################
Subprog IB_ITMREF
If [M:SFC1]ITMREF=""
  Raz GBOUT2, GBOUT3, GBOUT4
Endif
End
##########################################################################
Subprog C_CUMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]DETFLG=2 & [M:SFC1]WMAXLIG<5
  GMESSAGE=mess(151,184,1)
  mkstat=1
Elsif VALEUR=2 & [M]DETFLG=1 & [M:SFC1]WMAXLIG<2
  GERR=1
  GMESSAGE=mess(151,184,1)
  mkstat=12
Elsif VALEUR=1 & [M]DETFLG=2 & [M:SFC1]WMAXLIG<4
  GERR=1
  GMESSAGE=mess(151,184,1)
  mkstat=1
Endif
End
##########################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SFC") From SUBGTC

End

