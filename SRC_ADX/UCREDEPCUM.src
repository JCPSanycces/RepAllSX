#<AdxTL>@(#)3.0.0.0 $Revision$
# Gestion du masque UCREDEPCUM
################################################################
#
# Modifs :
# CBO 2012.08.31 FQ84188 ajout test dim (pour batch)
#
################################################################
#  Outil :
#
# Recherche des deprec sans exercice courant mais avec la période précédente :
# pour recréer le deprec courant et faire la clotûre (exercice ou périodique)
#
################################################################
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT, PARBOUT, "", "UCREDEPCUM", "UCREDEPCUM", 3, "") From GTRAITE
End

$ACTION
Case ACTION
    When"AVANT_PAR"     : Gosub AVANT_PAR
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "END"           : ABANDON=G_OUI
    When "EXEC"         : Gosub EXEC
Endcase
Return


$AVANT_PAR
  If !clalev([M:DIA])
    Local Mask UCREDEPCUM [DIA]
  Endif
Return

$OUVRE
  Global Integer ABANDON
  Local Integer OK
Return

$DEBUT
  [M:DIA]FLGSIM = G_OUI
  [M:DIA]FLGTRC = G_NON
  [M:DIA]CPY = ""
  [M:DIA]CPYTOUS = G_OUI
  [M:DIA]DPRPLNTOUS = G_OUI
  [M:DIA]DPRPLN = 1
  Affzo [M:DIA]
Return
#________
$EXEC

  # CBO 2012.08.31 FQ84188 ajout test dim (pour batch)
  If dim(ABANDON) >= 0
    If ABANDON=G_OUI
      Return
    Endif
  Endif

  If [M:DIA]FLGSIM = G_NON
  Call OUINON(mess(188, 7774, 1), OK) From GESECRAN
#    Call OUINON(mess(188, 404, 1), OK) From GESECRAN
  Else
  Call OUINON(mess(176, 7774, 1), OK) From GESECRAN
#    Call OUINON(mess(176, 404, 1), OK) From GESECRAN
  Endif
  If (OK = 1) Then
    FIN      = 0
    GERR     = 1
    Return
  Endif

  Call UCREDEPCUM([M:DIA]FLGSIM, [M:DIA]FLGTRC,
&    [M:DIA]CPYTOUS, [M:DIA]CPY, [M:DIA]DPRPLNTOUS, [M:DIA]DPRPLN) From UCREDEPCUM2

Return


Subprog AM_CPYTOUS(VALEUR)
Variable Integer VALEUR
  If VALEUR = G_OUI
    [M:DIA]CPY = ""
    Diszo [M:DIA]CPY
  Else
    Actzo [M:DIA]CPY
  Endif
  Affzo [M:DIA]CPY
End

Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()
  If [M:DIA]CPYTOUS = G_OUI
    Diszo [M:DIA]CPY
  Else
    Actzo [M:DIA]CPY
  Endif
End

Subprog AM_DPRPLNTOUS(VALEUR)
Variable Integer VALEUR
  If VALEUR = G_OUI
    [M:DIA]DPRPLN = 1
    Diszo [M:DIA]DPRPLN
  Else
    Actzo [M:DIA]DPRPLN
  Endif
  Affzo [M:DIA]DPRPLN
End

Subprog AV_DPRPLN(VALEUR)
Variable Integer VALEUR
  If [M:DIA]DPRPLNTOUS = G_OUI
    Diszo [M:DIA]DPRPLN
  Else
    Actzo [M:DIA]DPRPLN
  Endif
End
