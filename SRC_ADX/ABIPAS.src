#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10) , PROGSPE(GLONADC)
PARAM(1) = "ADMIN"
Call TRTSPE(nomap,"ABIPAS",PROGSPE) From SUBACT
Call SAISIE_CHAR(VALEUR,PARAM,"ABIPAS","ABIPAS",PROGSPE) From GSAISIE
End

#------------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "OK"           : Gosub OK
Endcase
Return

#--------------------------------------------------------------#
$OUVRE
Local File ABIPRFUSR [AIU] , AUTILIS [AUS]
Return

#--------------------------------------------------------------#
$DEBUT
Local Char USR(GLONAIU)
[L]USR = PARAM(1)
Raz [M]
Return

#--------------------------------------------------------------#
$OK
Call MAJ_NEWPASSE([L]USR,[M]PAS1,[M]PAS2,[M]PAS3,OK)
If !OK : FIN = 0 : Endif
Return

#--------------------------------------------------------------#
Subprog MAJ_NEWPASSE(USER,OLDPASSE,NEWPASSE1,NEWPASSE2,OK)
Value Char    USER , OLDPASSE , NEWPASSE1 , NEWPASS2
Variable Integer OK
Local Char    PASSE(24)
If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If clalev([F:AIU])=0 : Local File ABIPRFUSR [AIU] : Endif
Read [AIU]AIU0 = USER
If fstat
 GMESSAGE = USER-mess(141,100,1) : # Code utilisateur inexistant
 GERR = 1 : OK = 0
Else
 Lock ="AIU"+USER With lockwait=0
 If fstat=1
  GMESSAGE = mess(30,100,1) : # Opération en cours sur un autre poste
  GERR = 1 : FIN = 1
 Else
  If [F:AIU]PWD=""
   [L]PASSE = ""
   Call CRYPTNEW([L]PASSE) From GESUSER
  Else
   [L]PASSE = [F:AIU]PWD
  Endif
  Call VERF_PASSE(USER,[L]PASSE,"",OLDPASSE,NEWPASSE1,NEWPASSE2,0,8,OK) From PASSE
  If OK
   [L]PASSE = NEWPASSE1
   GOK = 1
   Call DEBTRANS From GLOCK
   Gosub TR1
   If GOK<1
    OK = 0
   Else
    GMESSAGE = [L]PASSE
    For [AUS] Where USRBI=[L]USER
     Call WORKFLOW(1,"PBI","","") From AWRK
    Next
    GMESSAGE = mess(82,100,1) : # Nouveau mot de passe enregistré
    GERR = 2 : OK = 1
   Endif
  Endif
  Unlock ="AIU"+USER
 Endif
Endif
End

#--------------------------------------------------------------#
$TR1
Trbegin [AIU]
 Readlock [AIU]AIU0=USER
 If fstat=1
  GOK=-1 : GLOCK="$ABIPRFUSR"-USER : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("AIU",USER) From GLOCK : Goto AB_TR1
 Endif
 If dim([F:AIU]UPDUSR)>0 : [F:AIU]UPDUSR = USER : Endif
 If dim([F:AIU]UPDDAT)>0 : [F:AIU]UPDDAT = date$ : Endif
 If dim([F:AIU]UPDTIM)>0 : [F:AIU]UPDTIM = time : Endif
 [F:AIU]PWD = [L]PASSE : Call CRYPTNEW([F:AIU]PWD) From GESUSER
 Rewrite [AIU]
 If fstat
  GOK=0 : Call FSTA("AIU") From GLOCK : Goto AB_TR1
 Endif
 Call ESPION("",8,[F:AIU]PWD,USER) From ESPION
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

