##########################################################################
# UTIGPAX        Utilitaire de dÃĐtection                    Module GPAO  #
# ---------------------------------------------------------------------- #
# ProblÃĻme Ã  dÃĐtecter :                                                  #
#   Certaines matiÃĻres prÃĐsentent des quantitÃĐs allouÃĐes/en rupture      #
#   dÃĐsynchronisÃĐes. Cet outil permet de tracer les OF concernÃĐs.        #
##########################################################################

Call MAJ_UTIGPAX
End


Subprog MAJ_UTIGPAX
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("Correction") From LECFIC
If DOSSIER <> ""
  Call EXE_UTIGPAX(DOSSIER) 
Endif
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


Subprog EXE_UTIGPAX(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("UTIGPAX : DÃĐbut traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:MFM])  =0  Local File =DOSSIER+".MFGMAT"      [MFM]  : Endif
Local Decimal  WALLQTY, WBESOIN 
Local Integer  WNBMAT, WNBPB, WNBOF

Local Integer COMPTEUR, STOP 
Local Char     CLE1(20), CLE3(20), CRITERE(200), WMFGNUM
Local Integer  CLE2, CLE4, CLE5

#----------------------------------------------------------------#
Call ECR_TRACE("UTIGPAX : recherche OF/matiÃĻre Ã  rÃĐ-allouer ",0) From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MFM_1
If STOP=1
  STOP=2 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN ='+num$(CLE2)+' & BOMSEQ='+num$(CLE4)+ 
&                                      ' & ITMREF >"'+CLE3+'"'                      
Elsif STOP=2
  STOP=3 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN ='+num$(CLE2)+' & BOMSEQ >'+num$(CLE4)
Elsif STOP=3
  STOP=4 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN >'+num$(CLE2)
Elsif STOP=4
  STOP=0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
# si il reste un besoin et les quantitÃĐs allouÃĐs sont non nulles
CRITERE -="& MATSTA < 3 & ([F:MFM]RETQTY > [F:MFM]USEQTY)&([F:MFM]ALLQTY <> 0 | [F:MFM]SHTQTY <> 0)"


Raz COMPTEUR

For [F:MFM] Where evalue(CRITERE)
    WNBMAT += 1
    WALLQTY = [F:MFM]ALLQTY + [F:MFM]SHTQTY
    WBESOIN = [F:MFM]RETQTY - [F:MFM]USEQTY
    If WALLQTY <> WBESOIN
        WNBPB += 1
        If WNBOF = 0 
            WMFGNUM = [F:MFM]MFGNUM
            WNBOF += 1
        Else
            If [F:MFM]MFGNUM <> WMFGNUM
                WNBOF += 1
                WMFGNUM = [F:MFM]MFGNUM
            Endif
        Endif 
        Call ECR_TRACE("Composant:"-[F:MFM]MFGNUM -"-"-[F:MFM]ITMREF-"-"-num$([F:MFM]MFGLIN) - "-"-num$([F:MFM]BOMSEQ),0) From GESECRAN
    Endif
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS 
        CLE1 = [F:MFM]MFGNUM
        CLE2 = [F:MFM]MFGLIN
        CLE4 = [F:MFM]BOMSEQ
        CLE3 = [F:MFM]ITMREF
        STOP = 1 
        Break 
    Endif
$NXT1
Next
If STOP : Goto BOUCLE_MFM_1 : Endif
Call ECR_TRACE(num$(WNBOF)-"OF doivent ÃŠtre traitÃĐs ",0) From GESECRAN

Call ECR_TRACE(num$(WNBPB)-"matiÃĻres doivent faire l'objet d'une rÃĐ-allocation",0) From GESECRAN
Call ECR_TRACE("UTIGPAX : fin traitement ",0) From GESECRAN

#----- Fin du traitement -----#
$FIN_UTIGPAX
End

########################################################################
# Pour exÃĐcution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(7)<>2 End : Endif
Call EXE_UTIGPAX(APPLI)
End



