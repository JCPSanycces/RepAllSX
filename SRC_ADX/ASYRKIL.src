#**
#* Funprog HANDLER_DELETE()
#*!
Funprog HANDLER_DELETE(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

End func  PROGRAM_DELETE(ACTX,PSYR,ARCV,ASND,PSYR.CODREP,PSYR.SELREP,PSYR.WRKUID)

#------------------------------------------------------------#
# Request delete management (POST)
#------------------------------------------------------------#

Funprog PROGRAM_DELETE(ACTX,PSYR,ARCV,ASND,REPRES,KEYS,UID)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance PSYR Using C_ASYR
Variable Instance ARCV Using C_ASYRRCV
Variable Instance ASND Using C_ASYRSND
Value Char REPRES
Value Char KEYS
Variable Uuident  UID

Local Integer   I , J , ASTATUS ,ASTAERR
Local Char      PRGREP(30) , PRGEXE(30)

Local Instance REP      Using C_AREPENT
Local Instance WREP     Using ="R_"+REPRES

# Load json presentation (metadata & data)
PRGREP = func SUBASW.PREFIX_TRT+REPRES                        : # WMREP*
Call DESCRIPTION_REPRESENTATION(REP,"REP") From =func SUBASW.PREFIX_TRT+REPRES

# Create instance class
PRGEXE = func ACLAVALCRUD.GET_PREFIX_REP_READ+REP.REP  : # WMRD_*
WREP = evalue ("Newinstance R_"+REP.REP+ " AllocGroup null")

# Load data (Read from CRUD)
Call _AREADSUP(WREP,KEYS,ASTATUS) From =PRGEXE
ASTAERR = fmet WREP._AERROR(ACTX,2)
If ASTATUS>CST_AOK :  Goto REPONSE : Endif

# Test right on suppression
ASTATUS = fmet WREP.AGETWRIGHTD
ASTAERR = fmet WREP._AERROR(ACTX,2)
If ASTATUS>CST_AOK :  Goto REPONSE : Endif

#  Execution of the  Delete with CRUD scrypt
ASTATUS = fmet WREP.ADELETE
ASTAERR = fmet WREP._AERROR(ACTX,2)
If ASTATUS>CST_AOK :  Goto REPONSE : Endif

# Deleted with success
ASTAERR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_ASUCCESS,[V]CST_AHTTP_OK,func ASYRFNC.MES1(mess(61,149,1),KEYS))

#------------------------------------------------------#
# Prepare response (OK with or without errors)
#------------------------------------------------------#

$REPONSE
ASND.URL      = PSYR.PREFIX+'/'+REP.CLA+PSYR.URLREP+REPRES+".$query"
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+REPRES+".$query"

FreeGroup WREP

End fmet ACTX.AGETMAXERROR("")
