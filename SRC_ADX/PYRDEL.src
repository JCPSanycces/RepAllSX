#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("GYM",GBIDC1,GBIDC2) From GOBJET
End

###########################################################################
## Effacement d'une pyramide et de ses groupes
###########################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When Default
Endcase
Return

$INIT
If clalev([F:GYM])=0 : Local File GACCPYM    [GYM] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:GYK])=0 : Local File GACCPYMLIK [GYK] : Endif
TMP = 1
Return

$INIT_DIA
[M]COA    = PARAM(1)
[M]PYM    = PARAM(2)
Return

$EXEC
OK = 2
Call AVERTIR(mess(70,103,1),OK) From GESECRAN
If OK=2
 Call EFFACE([M]PYM,1)
Endif
Return

Subprog EFFACE(PYRAMIDE,TETE)
Value Char    PYRAMIDE
Value Integer TETE
If clalev([F:GYM])=0 : Local File GACCPYM    [GYM] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:GYK])=0 : Local File GACCPYMLIK [GYK] : Endif
If clalev([F:GYP])=0 : Local File GACCPYMPRT [GYP] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [GYK],[GYP],[GRY],[GYM]
 Delete [GYK] Where PYM=PYRAMIDE
 If fstat=1
  GOK = -1 : GLOCK = "$GACCPYMLIK"-PYRAMIDE : Goto ROLL_TR1
 Endif
 Delete [GYP] Where PYM=PYRAMIDE
 If fstat=1
  GOK = -1 : GLOCK = "$GACCPYMPRT"-PYRAMIDE : Goto ROLL_TR1
 Endif
 Delete [GRY] Where PYM=PYRAMIDE
 If fstat=1
  GOK = -1 : GLOCK = "$GACCGRUPYM"-PYRAMIDE : Goto ROLL_TR1
 Endif
 Delete [AXX] Where CODFIC="GACCGRUPYM" & IDENT1=PYRAMIDE
 If fstat=1
  GOK = -1 : GLOCK = "$ATEXTRA"-"GACCGRUPYM"-PYRAMIDE : Goto ROLL_TR1
 Endif
 If TETE
  Delete [GYM] Where PYM=PYRAMIDE
  If fstat=1
   GOK = -1 : GLOCK = "$GACCPYM"-PYRAMIDE : Goto ROLL_TR1
  Endif
  Delete [AXX] Where CODFIC="GACCPYM" & IDENT1=PYRAMIDE
  If fstat=1
   GOK = -1 : GLOCK = "$ATEXTRA"-"GACCPYM"-PYRAMIDE : Goto ROLL_TR1
  Endif
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

######################################################################################
## Ecran PYRDEL
######################################################################################
Subprog C_PYM(VALEUR)
Variable Char    VALEUR()
Call LECTURE("GYM",VALEUR,"") From CONTOBJ
If fstat 
 GMESSAGE = mess(96,102,1) : # Pyramide pas exitent
 mkstat = 2 : End
Elsif [F:GYM]COA<>[M]COA
 GMESSAGE = mess(93,102,1)-"("+[F:GYM]COA+")" : # Plan de compte incompatible
 mkstat = 2 : End
Endif
End
