#<AdxTL>@(#)11.0.0.0 $Revision$
#########################################################################
# FUNPPD3 : Transformation des réponses d'appels d'offre    SR 10/12/97 #
#           en tarif                               Modifié MBT 27/07/99 #
# --------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                    #
# --------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                #
#   - TRTFUNPPD3 : Fonction de transformation des réponses AOF en tarif #
#                                                                       #
# ACTIONS modélisation WEB (Sélection dans une table GACTION)           #
#   - SELPPD     : Sélection des réponses aux appels d'offre            #
#   - SELPPC2    : Sélection des tarifs achats                          #
#########################################################################

$ACTION
##########################################################
# Actions sur le traitement standard (GTRAITE)           #
# ------------------------------------------------------ #
# TRTFUNPPD3 : Fonction de tranformation AOF en tarif    #
##########################################################
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "EXEC"       : Gosub EXEC
##########################################################
# Actions sur la sélection dans une table (GACTION)      #
# ------------------------------------------------------ #
# SELPPD     : Sélection des réponses aux appels d'offre #
# SELPPC2    : Sélection des tarifs achats               #
##########################################################
 When "SEL_TABLE"
  #--------------------------------------------#
  # Avant ouverture de la fenêtre de sélection #
  #--------------------------------------------#
  Case TABLE
   When "SELPPD"   : Gosub S_PPD
   When "SELPPC2"  : Gosub S_PPC
  Endcase
 When "VERF_TABLE"
  #-------------------------------#
  # Après sélection dans la table #
  #-------------------------------#
  Case TABLE
   When "SELPPD"   : Gosub V_PPD
  Endcase
###################################################
# Actions champs modèlisées de l'écran PPD3 [DIA] #
###################################################
 When "AB1_NBTAR"  : Gosub AB1_NBTAR
 When Default
Endcase
Return


##########################################################
# Actions sur le traitement standard (GTRAITE)           #
# ------------------------------------------------------ #
# TRTFUNPPD3 : Fonction de tranformation AOF en tarif    #
##########################################################

#-----------------------------------------------#
# Initialisations avant exécution du traitement #
#-----------------------------------------------#
$INIT
#----- Variables locales -----#
Local Integer OK
Local Char    WMSG(80), PARAMA(10)
Local Char    SAV_GSOCIETE(GLONCPY)
#----- Ouverture des tables -----#
If clalev ([F:PQH]) <= 0 : Local File PQUOTAT    [PQH] : Endif
If clalev ([F:PQD]) <= 0 : Local File PQUOTATD   [PQD] : Endif
If clalev ([F:PPF]) <= 0 : Local File PQUOTATF   [PQF] : Endif
If clalev ([F:PPH]) <= 0 : Local File PRESP      [PPH] : Endif
If clalev ([F:PPD]) <= 0 : Local File PRESPD     [PPD] : Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER [BPS] : Endif
If clalev ([F:BPR]) <= 0 : Local File BPARTNER   [BPR] : Endif
If clalev ([F:MVS]) <= 0 : Local File BPSUPPMVT  [MVS] : Endif
If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:ITP]) <= 0 : Local File ITMBPS     [ITP] : Endif
If clalev ([F:PPL]) <= 0 : Local File PPRICLIST  [PPL] : Endif
If clalev ([F:PPF]) <= 0 : Local File PPRICFICH  [PPF] : Endif
If clalev ([F:PPC]) <= 0 : Local File PPRICCONF  [PPC] : Endif
If clalev ([F:TCA]) <= 0 : Local File TABCOUAFF  [TCA] : Endif
#----- Chargement paramètre "Motifs prix obligatoires -----#
Call PARAM(GFCYDEF(6),"PURREN",PARAMA) From ADOVAL
GPURREN=val(PARAMA)
#--- Alimentation du compteur fiche tarif -----#
SAV_GSOCIETE=GSOCIETE
Raz GSOCIETE : Call LECTCA(6,OK) From SUBTCA
GSOCIETE=SAV_GSOCIETE
If fstat | !OK
  GERR=1 : GMESSAGE=mess(64,199,1) : FIN=1 : Return
Endif
GMANCOU=[F:TCA]MANCOU(11)
GCODNUM=[F:TCA]CODNUM(11)
Return

#-----------------------------------------------------------#
# Après déclaration de l'écran mais avant ouverture fenêtre #
#-----------------------------------------------------------#
$INIT_DIA
Raz [M:DIA]
If GHISTO  GCONSDIA=2 : Endif
Return

#-------------------------#
# Exécution du traitement #
#-------------------------#
$EXEC
Call TEMPON("E") From GESECRAN
Call OUVRE_TRACE(mess(28,195,1)) From LECFIC
Call DEBTRANS    From GLOCK
Gosub ECRIRE
Call ECR_TRACE(mess(28,195,1)-mess(124,100,1),0) From GESECRAN
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
TRA=1 : # Lecture de la trace
Return


########################################################################
# S_PPC : Sélection tarif achat                      action e-commerce #
#                                                                      #
#                                                          HN 17/10/00 #
########################################################################
$S_PPC
If !clalev([F:ATZ])  Local File ATABZON   [ATZ] : Endif
If !clalev([F:AXX])  Local File ATEXTRA   [AXX] : Endif
Link [PPC] With [AXX]AXX0="PPRICCONF";"DESAXX";GLANGUE;PLI;"" As [PPX]
START ='[F:PPC]PLI'
CRITERE(1) = '[F:PPC]PLISTC="'+PARAM(1)+'"'
If GPURREN = 2
  CRITERE(1)+='& PRIREN=[M:DIA]PRIREN(nolign-1)'
Endif
TIT(0) = mess(10,16,1)
NBCOL  = 1 : COL(NBCOL) = "[PPC]PLI"
Call TEXTFIC("PPRICCONF","PLI",1,TIT(NBCOL))    From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[AXX]TEXTE"
Call TEXTFIC("PPRICCONF","DESAXX",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[PPC]PLISTC"
Call TEXTFIC("PPRICCONF","PLISTC",1,TIT(NBCOL)) From OBJDIV
Default File [PPX]
Return


########################################################################
# S_PPD : Sélection réponse au appel d'offre         action e-commerce #
#                                                                      #
#                                                          HN 16/10/00 #
########################################################################
$S_PPD
If clalev([F:ATZ])=0  Local File ATABZON    [ATZ] : Endif
Local Char    WZONE(GLONAVA)   : WZONE   = PARAM(1)
Local Char    WBPSNUM(GLONBPS) : WBPSNUM = PARAM(2)
Local Char    WNUM(GLONPQH)    : WNUM    = PARAM(3)
Local Integer WLIN(08)         : WLIN    = val(PARAM(4))
Default File [PPD]
CRITERE(1) = 'PRIFLG<>2'
Case WZONE
  When "BPSNUM" : START = 'BPSNUM'
  When "PQHNUM" : START = 'PQHNUM'
                  CRITERE(1) +=' & BPSNUM="'+WBPSNUM+'"'
  When "PQDLIN" : START = 'PQDLIN'
                  CRITERE(1) +=' & BPSNUM="'+WBPSNUM+'"'
                  CRITERE(1) +=' & PQHNUM="'+WNUM+'"'
Endcase
TIT(0) = mess(194,195,1)
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = "BPSNUM"
Call TEXTFIC("PRESPD","BPSNUM",1,TIT(NBCOL))    From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PQHNUM"
Call TEXTFIC("PRESPD","PQHNUM",1,TIT(NBCOL))    From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PQDLIN"
Call TEXTFIC("PRESPD","PQDLIN",1,TIT(NBCOL))    From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC("PRESPD","ITMREF",1,TIT(NBCOL))    From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PPDLIN"
Call TEXTFIC("PRESPD","PPDLIN",1,TIT(NBCOL))    From OBJDIV
Return
#-------------------------------#
# Après sélection dans la table #
#-------------------------------#
$V_PPD
If WZONE="BPSNUM" : Effzo [DIA]15 : Endif
PARAM(2)=[F:PPD]BPSNUM
PARAM(3)=[F:PPD]PQHNUM
PARAM(4)=num$([F:PPD]PQDLIN)
Return

############################################################################
# GOSUB                                                                    #
#--------------------------------------------------------------------------#
# Proposition en tableau des réponses du fournisseur pour l'appel concerné #
# Appelé en AM_PQDLIN                                                      #
#--------------------------------------------------------------------------#
$LIRE
nolign = 0
For [PPD] PPD0 Where BPSNUM=[M:DIA]BPSNUM
&                  & PQHNUM=[M:DIA]PQHNUM
&                  & PQDLIN=[M:DIA]PQDLIN
&                  & PRIFLG<2
    nolign += 1
    [M:DIA]PLISTC(nolign-1) = [F:PPH]PLISTC
    [M:DIA]PPDLIN(nolign-1) = [F:PPD]PPDLIN
    [M:DIA]PLISTRDAT(nolign-1) = [F:PPD]PLISTRDAT
    [M:DIA]PLIENDDAT(nolign-1) = [F:PPD]PLIENDDAT
    [M:DIA]PRIREN(nolign-1) = [F:PPD]PRIREN
    Gosub RECTAR
    If [M:DIA]PLI(nolign-1) <> "" & [M:DIA]PLICRD(nolign-1) <> ""
       [M:DIA]PRO(nolign-1) = 2
    Else
       [M:DIA]PRO(nolign-1) = 1
    Endif
Next
[M:DIA]NBTAR = nolign
Return

#--------------------#
# Appelé depuis LIRE #
#--------------------#
$RECTAR
Raz [M:DIA]PLI(nolign-1), [M:DIA]PLICRD(nolign-1)
If GPURREN=2
  Filter [PPC] Where PLIENAFLG=2
&                  & PLITYP   =1
&                  & PLISTC   =[F:PPH]PLISTC
&                  & PRIREN   =[F:PPD]PRIREN
Else
  Filter [PPC] Where PLIENAFLG=2
&                  & PLITYP   =1
&                  & PLISTC   =[F:PPH]PLISTC
Endif
Read [PPC] PPC1 First
Filter [PPC]
If fstat  Return : Endif
[M:DIA]PLI(nolign-1)=[F:PPC]PLI
Filter [PPF] Where PLI      =[F:PPC]PLI
&                & PLISTRDAT=[F:PPD]PLISTRDAT
&                & PLIENDDAT=[F:PPD]PLIENDDAT
Read [PPF] PPF0 First
Filter [PPF]
If fstat  Return : Endif
[M:DIA]PLICRD(nolign-1)=[F:PPF]PLICRD
Return

#-------------------------------------------------#
# Transformer les réponses sélectionnées en tarif #
# Appelé dans EXEC                                #
#-------------------------------------------------#
$ECRIRE
Local Integer WPLILIN
Local Char    CLEFIC(50), NOMFIC(GLONATB)
Local Char    FICHIER(GLONATB), ABRFIC(3)
Local Libelle CODMAJFIC : CODMAJFIC=3
#----- Début transaction de mise à jour -----#
$DEB_TRA_ECRIRE
GOK=1
Trbegin [PPH],[PPD],[PPL],[ITP],[BPS]
#-------------------------------------------------#
# Transformation éventuelle du prospect en normal #
#-------------------------------------------------#
  If [F:BPS]BPSTYP = 2 Gosub MODIF_BPS
     If GOK<1 Goto TRT_ERR : Endif
  Endif
  NOMFIC="PRESP"
  CLEFIC=[M:DIA]BPSNUM-[M:DIA]PQHNUM-num$([M:DIA]PQDLIN)
  WMSG=mess(12,100,1)-NOMFIC-CLEFIC
  Readlock [PPH] PPH0=[M:DIA]BPSNUM;[M:DIA]PQHNUM;[M:DIA]PQDLIN
  If fstat=1  GOK=-1 : GLOCK="$PRESP"-CLEFIC              : Goto TRT_ERR
  Elsif fstat GOK=0  : Call RSTA("PPH",CLEFIC) From GLOCK : Goto TRT_ERR
  Endif
  #--- Lecture des fichiers eventuellement utilisés dans les critères ---#
  Read [ITM] ITM0=[M:DIA]ITMREF : If fstat  Raz [F:ITM] : Endif
  Read [BPR] BPR0=[M:DIA]BPSNUM : If fstat  Raz [F:BPR] : Endif
  Read [FCY] FCY0=[M:DIA]PQHFCY : If fstat  Raz [F:FCY] : Endif
  Read [ITF] ITF0=[M:DIA]ITMREF;[M:DIA]PQHFCY : If fstat  Raz [F:ITF] : Endif
  #--------------------------------------------------------------------#
  # Création éventuelle de l'enregistrement Article-Fournisseur ITMBPS #
  #--------------------------------------------------------------------#
  Read [ITP] ITP0=[M:DIA]ITMREF;[M:DIA]BPSNUM
  If fstat & [F:ITM]ITMREF<>""
     Gosub CREA_ITP : If GOK<1 Goto TRT_ERR : Endif
  Endif
  For nolign=1 To [M:DIA]NBTAR
    NOL=nolign-1
    If [M:DIA]PRO(NOL)=1 Goto SUIV : Endif
    Read [PPD] PPD0=[M:DIA]BPSNUM;[M:DIA]PQHNUM;[M:DIA]PQDLIN;[M:DIA]PPDLIN(NOL)
    If fstat Raz [F:PPD] : Goto SUIV : Endif
    #-------------------------------------------------#
    # Lecture PPRICLIST pour récupération no de ligne #
    #-------------------------------------------------#
    Raz WPLILIN
    Read [PPF] PPF0=[M:DIA]PLI(NOL);[M:DIA]PLICRD(NOL)
    If !fstat
      Filter [PPL] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD
      Read [PPL] PPL0 Last
      If !fstat WPLILIN=[F:PPL]PLILIN : Endif
      Filter [PPL]
    Endif
    #---------------------------#
    # Création des lignes tarif #
    #---------------------------#
    If CODMAJFIC>1
      Gosub CREA_TARIF : If GOK<1 Break : Endif
      If GOK=2 GOK=1 : Goto SUIV : Endif
    Endif
    NOMFIC="PRESPD"
    CLEFIC=[M:DIA]BPSNUM-[M:DIA]PQHNUM-num$([M:DIA]PQDLIN)-num$([M:DIA]PPDLIN(NOL))
    WMSG=mess(12,100,1)-NOMFIC-CLEFIC
    Readlock [PPD] PPD0=[M:DIA]BPSNUM;[M:DIA]PQHNUM;[M:DIA]PQDLIN;[M:DIA]PPDLIN(NOL)
    If fstat=1
       GOK=-1 : GLOCK="$PRESPD"-CLEFIC             : Break
    Elsif fstat
       GOK=0  : Call RSTA("PPD",CLEFIC) From GLOCK : Break
    Endif
    [F:PPD]PRIFLG=2
    WMSG=mess(13,100,1)-NOMFIC-CLEFIC
    Rewrite [F:PPD]
    If fstat GOK=0 : Call FSTA("PPD") From GLOCK : Break : Endif
    [F:PPH]PRILINNBR+=1
$SUIV
  Next
  If GOK <1 Goto TRT_ERR : Endif
  If [F:PPH]PRILINNBR=[F:PPH]LINNBR  [F:PPH]PRIFLG=2 : Endif
  NOMFIC="PRESP"
  CLEFIC=[M:DIA]BPSNUM-[M:DIA]PQHNUM-num$([M:DIA]PQDLIN)
  WMSG=mess(13,100,1)-NOMFIC-CLEFIC
  Rewrite [F:PPH]
  If fstat GOK=0 : Call FSTA("PPH") From GLOCK : Goto TRT_ERR : Endif
Commit
Return

#----- Traitement des erreurs -----#
$TRT_ERR
If GOK=0 Goto AB_ECRIRE   : Endif
#----- Nouvel essai si possible -----#
$ROLL_ECRIRE
Rollback : Call ROLL From GLOCK
If GROLL   Call ECR_TRACE(WMSG,1) From GESECRAN : # Erreur d'accès ou d'écriture
           WMSG=mess(157,199,1)
           Call ECR_TRACE(WMSG,1) From GESECRAN : # Transaction abandonnée
           Return
      Else Goto DEB_TRA_ECRIRE : Endif
#----- Abandon de la transaction -----#
$AB_ECRIRE
Rollback
Call ECR_TRACE(WMSG,1) From GESECRAN : # Erreur d'accès ou d'écriture
WMSG=mess(157,199,1)
Call ECR_TRACE(WMSG,1) From GESECRAN : # Transaction abandonnée
Return


##############################################################
$IMPRIME
Return
##############################################################

###############################################################
# Transformation du type du fournisseur de prospect en normal #
###############################################################
$MODIF_BPS
NOMFIC="BPSUPPLIER"
CLEFIC=[M:DIA]BPSNUM
WMSG=mess(12,100,1)-NOMFIC-CLEFIC
Readlock [BPS] BPS0=[M:DIA]BPSNUM
If fstat=1
  GOK=-1 : GLOCK="$BPSUPPLIER"-CLEFIC         : Return
Elsif fstat
  GOK=0  : Call RSTA("BPS",CLEFIC) From GLOCK : Return
Endif
If [F:BPS]BPSTYP=2 [F:BPS]BPSTYP=1 : Endif
WMSG=mess(13,100,1)-NOMFIC-CLEFIC
Rewrite [BPS]
If fstat  GOK=0 : Call FSTA("BPS") From GLOCK : Return : Endif
Return

##################################
# Création enregistrement ITMBPS #
##################################
$CREA_ITP
NOMFIC="ITMBPS"
CLEFIC=[M:DIA]BPSNUM-[F:PPH]ITMREFBPS
Look [ITP] ITP2=[M:DIA]BPSNUM;[F:PPH]ITMREFBPS
If !fstat : Return : Endif
Raz [F:ITP]
[F:ITP]ITMREF    = [M:DIA]ITMREF
[F:ITP]BPSNUM    = [M:DIA]BPSNUM
[F:ITP]PIO       = 50
[F:ITP]ITMREFBPS = [F:PPH]ITMREFBPS
[F:ITP]ITMDESBPS = [F:PPH]ITMDESBPS
[F:ITP]EANCODBPS = [F:PPH]EANCODBPS
[F:ITP]PUU       = [F:ITM]PUU
Call MODUNIT([F:ITP]PUU,[F:ITM]STU,[F:ITP]PUUSTUCOE) From SUBITM # (Corr 8214)
If [F:ITP]PUUSTUCOE=0
  [F:ITP]PUUSTUCOE=[F:ITM]PUUSTUCOE
Endif
[F:ITP]PCU       = [F:ITM]PCU(0)
Call MODUNIT([F:ITP]PCU,[F:ITM]PUU,[F:ITP]PCUPUUCOE) From SUBITM
If [F:ITP]PCUPUUCOE = 0
  [F:ITP]PCUPUUCOE = arr(([F:ITM]PCUSTUCOE(0)/[F:ITP]PUUSTUCOE),0.000001)
Endif
[F:ITP]CTMBPSFLG = 1
[F:ITP]DOUFLG    = [F:BPS]DOUFLG
[F:ITP]QUAFLG    = [F:ITF]QUAFLG                    # hcb V6CQ
[F:ITP]QUAFRY    = 1                                # hcb V6CQ
[F:ITP]CREUSR    = GUSER
[F:ITP]CREDAT    = date$
[F:ITP]EXPNUM    = [C]EXPORT
WMSG=mess(13,100,1)-NOMFIC-CLEFIC
#------------------------------------------------------------------#
# Point d'entrée MAJITP pour alimentation de zones spécifiques     #
# ---------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                      #
#                                                                  #
# CODMAJFIC : Code mise à jour fichiers                            #
#             0 = pas de mise à jour                               #
#             1 = création article-fournisseur                     #
#             2 = création tarif                                   #
#             3 = création article-fournisseur + tarif             #
# FICHIER   : Nom de la table qui va être écrite                   #
# ABRFIC    : Abréviation de la table qui va être écrite           #
# Les classes [F:PPH], [F:ITM] et [F:BPR] sont disponibles         #
# La  classe  [F:ITP] est modifiable avant le Write                #
#------------------------------------------------------------------#
CODMAJFIC=3
FICHIER="ITMBPS"
ABRFIC ="ITP"
GPOINT="MAJITP" : Gosub ENTREE From EXEFNC
#-----
If CODMAJFIC<>0 & CODMAJFIC<>2
  Write [ITP]
  If fstat  GOK=0 : Call FSTA("ITP") From GLOCK : Return : Endif
Endif
Return

##################
# Création tarif #
##################
$CREA_TARIF
#--- Lecture du paramétrage tarif pour récup des critères ---#
NOMFIC="PPRICCONF"
CLEFIC=[M:DIA]PLI(nolign-1)
WMSG=mess(12,100,1)-NOMFIC-CLEFIC
Read [PPC] PPC0=[M:DIA]PLI(nolign-1)
If fstat GOK=0 : Call RSTA("PPC",CLEFIC) From GLOCK : Return : Endif
#-----------------------------------------------------------------------#
# Contrôles : Si diviseur de prix et type de prix n'est pas prix pour n #
#             Si quantités et tarif sans prix par quantité              #
#             Si pas de quantité et tarif avec prix par quantité        #
#             Si devises différentes :issue X3-38382 : contrôle supprimé#
#-----------------------------------------------------------------------#
Raz WMSG
If [F:PPD]PRIDIV>1 & [F:PPC]PRIPRO<>3
   WMSG=mess(210,197,1) : # Incomptabilité diviseur de prix
Endif
If [F:PPD]MAXQTY<>0 & ([F:PPC]PRIQTYFLG<2 | [F:PPC]PRIQTYFLG>3)
   WMSG=mess(211,197,1) : # Incompatibilité quantités
Endif
If [F:PPD]MAXQTY=0  & ([F:PPC]PRIQTYFLG=2 | [F:PPC]PRIQTYFLG=3)
   WMSG=mess(211,197,1) : # Incomptabilité quantités
Endif
# Issue X3-38382 - 2017-08-18 by SR : autoriser devise différente puisque autorisé en saisie directe
#If [F:PPC]CUR<>"" & [F:PPD]CUR<>[F:PPC]CUR
#   WMSG=mess(212,197,1) : # Incomptabilité devises
#Endif
If WMSG<>""
   WMSG-=[F:PPD]BPSNUM-[F:PPD]PQHNUM-num$([F:PPD]PQDLIN)-num$([F:PPD]PPDLIN)
   Call ECR_TRACE(WMSG,1) From GESECRAN
   WMSG=mess(213,197,1)-[M:DIA]PLI(nolign-1)-[M:DIA]PLICRD(nolign-1)
   Call ECR_TRACE(WMSG,1) From GESECRAN : # Ligne tarif non générée !
   GOK=2 : Return
Endif
If WPLILIN=0
  Gosub CREA_FICH : # Création fiche tarif
  If GOK<1 Return : Endif
Endif
If WPLILIN=0 WPLILIN=1000 Else WPLILIN+=10 : Endif
Gosub CREA_PLILIN : # Création ligne tarif
If GOK<1 Return : Endif
Return

########################
# Création fiche tarif #
########################
$CREA_FICH
Local Integer STAT : STAT=0
Raz [F:PPF]
[F:PPF]PLI       = [M:DIA]PLI(nolign-1)
[F:PPF]PLISTRDAT = [F:PPD]PLISTRDAT
[F:PPF]PLIENDDAT = [F:PPD]PLIENDDAT
If GMANCOU=2 & [M:DIA]PLICRD(nolign-1)<>""
  [F:PPF]PLICRD = [M:DIA]PLICRD(nolign-1)
Else
  Call NUMERO(GCODNUM,"",[F:PPF]PLISTRDAT,"",[F:PPF]PLICRD,STAT) From SUBANM
  If GOK<0
    WMSG=GCODNUM-mess(60,199,1) : Return
  Elsif GOK<1 | STAT<>0
    GOK=0 : GERR=1 : GMESSAGE=GCODNUM-mess(60,199,1)
    WMSG=GCODNUM-mess(60,199,1) : Return
  Endif
Endif
[F:PPF]LINNBR = 0
[F:PPF]CREUSR = GUSER
[F:PPF]CREDAT = date$
[F:PPF]EXPNUM = [C]EXPORT
NOMFIC="PPRICFICH"
CLEFIC=[F:PPF]PLI-[F:PPF]PLICRD
WMSG=mess(13,100,1)-NOMFIC-CLEFIC
Write [PPF]
If fstat GOK=0 : Call FSTA("PPF") From GLOCK : Return : Endif
Return

########################
# Création ligne tarif #
#######################
$CREA_PLILIN
Local Char CRIT1,CRIT2,CRIT3,CRIT4,CRIT5
Local Integer WPASSE
Raz [F:PPL]
For WPASSE=0 To 4
  If [F:PPC]ABB(WPASSE)="" Break : Endif
  If evalue ("dim([F:"+[F:PPC]ABB(WPASSE)+"]"+[F:PPC]FLD(WPASSE)+"("+num$([F:PPC]CRIIND(WPASSE))+"))")>0
     Assign "CRIT"+num$(WPASSE+1) With
&         evalue("[F:"+[F:PPC]ABB(WPASSE)+"]"+[F:PPC]FLD(WPASSE)+"("+num$([F:PPC]CRIIND(WPASSE))+")")
  Endif
Next WPASSE
[F:PPL]PLI       = [F:PPF]PLI
[F:PPL]PLICRD    = [F:PPF]PLICRD
[F:PPL]PLILIN    = WPLILIN
[F:PPL]PLICRI    = CRIT1+"~"+CRIT2+"~"+CRIT3+"~"+CRIT4+"~"+CRIT5+"~"
[F:PPL]PLICRI1   = CRIT1
[F:PPL]PLICRI2   = CRIT2
[F:PPL]PLICRI3   = CRIT3
[F:PPL]PLICRI4   = CRIT4
[F:PPL]PLICRI5   = CRIT5
[F:PPL]PLISTRDAT = [F:PPF]PLISTRDAT
[F:PPL]PLIENDDAT = [F:PPF]PLIENDDAT
[F:PPL]UOM       = [F:PPD]PUU
[F:PPL]CUR       = [F:PPD]CUR
[F:PPL]MINQTY    = [F:PPD]MINQTY
[F:PPL]MAXQTY    = [F:PPD]MAXQTY
[F:PPL]PRIDIV    = [F:PPD]PRIDIV
If [F:PPC]PRIPRO=2 | [F:PPC]PRIPRO=3
   [F:PPL]PRI    = [F:PPD]PRI
Endif
[F:PPL]LTI       = [F:PPD]LTI
For I = 0 To 8
  [F:PPL]DCGVAL(I) = evalue("[F:PPD]DISCRGVAL"+num$(I+1))
Next I
[F:PPL]CREUSR = GUSER
[F:PPL]CREDAT = date$
[F:PPL]EXPNUM = [C]EXPORT
NOMFIC="PPRICLIST"
CLEFIC=[F:PPL]PLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)
WMSG=mess(13,100,1)-NOMFIC-CLEFIC
#----------------------------------------------------------------------#
# Point d'entrée MAJPPL pour modif zones std et alim zones spécifiques #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                          #
#                                                                      #
# Les classes [F:PPL], [F:PPF] et [F:PPD] sont disponibles             #
# La  classe  [F:PPL] est modifiable avant le Rewrite                  #
#----------------------------------------------------------------------#
GPOINT="MAJPPL" : Gosub ENTREE From EXEFNC
#-----
Write [PPL]
If fstat GOK=0 : Call FSTA("PPL") From GLOCK : Return : Endif
#--- Ecriture dans fichier TRACE ---#
WMSG=mess(89,194,1)-":"-[F:PPL]PLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)
Call ECR_TRACE(WMSG,0) From GESECRAN
#--- Incrémentation du nombre de lignes de l'entête ---#
NOMFIC="PPRICFICH"
CLEFIC=[F:PPL]PLI-[F:PPL]PLICRD
WMSG=mess(12,100,1)-NOMFIC-CLEFIC
Readlock [PPF] PPF0=[F:PPL]PLI;[F:PPL]PLICRD
If fstat=1
  GOK=-1 : GLOCK="$PPRICFICH"-CLEFIC          : Return
Elsif fstat
  GOK=0  : Call RSTA("PPF",CLEFIC) From GLOCK : Return
Endif
[F:PPF]LINNBR+=1
WMSG=mess(13,100,1)-NOMFIC-CLEFIC
Rewrite [PPF]
If fstat  GOK=0 : Call FSTA("PPF") From GLOCK : Return : Endif
Return


#########################################################################
#              Actions sur champ du masque PPD3 [DIA]                   #
#########################################################################
Subprog C_BPSNUM(VALEUR)
#------------------------------------------------------------------#
# Contrôle que le fournisseur est sollicité pour au moins un appel #
#------------------------------------------------------------------#
Variable Char    VALEUR()
Filter [PPH] Where BPSNUM = VALEUR
Read [PPH] PPH0 First
If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
Filter [PPH]
Read [BPS] BPS0 = VALEUR
If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
[M:DIA]BPSNAM = [F:BPS]BPSNAM
End

Subprog AM_BPSNUM(VALEUR)
#---------------------------------------------------------------------#
# Après-modif numéro de fournisseur                                   #
# Si fournisseur prospect on demande si il faut transformer en normal #
# Si réponse à NON on ne va pas plus loin                             #
#---------------------------------------------------------------------#
Variable Char    VALEUR()
Local Integer OK
#--- Controle du type de fournisseur ---#
If [F:BPS]BPSTYP <> 2 : End : Endif
OK = 1
Call OUINON(mess(53,194,1),OK) From GESECRAN
If OK <> 2 : mkstat = 1 : End : Endif
End

Subprog C_PQHNUM(VALEUR)
#--------------------------------------------------------------------#
# Contrôle que l'appel d'offre saisi a bien des réponses de ce fourn #
#--------------------------------------------------------------------#
Variable Char    VALEUR()
Local Char PARAMA(10)
Filter [PPH] Where PQHNUM = VALEUR & BPSNUM = [M:DIA]BPSNUM
Read [PPH] PPH0 First
If fstat Raz [F:PPH] : GMESSAGE = mess(23,100,1) : GERR = 1 : mkstat = 1 : Endif
Filter [PPH]
If GERR <> 0 : End : Endif
Read [PQH] PQH0=VALEUR
If fstat Raz [F:PQH] : : GMESSAGE = mess(23,100,1) : GERR = 1 : mkstat = 1: End : Endif
#--- Si pas habilité sur tous sites  on verifie
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  If !find([F:PQH]PQHFCY,GUSRFCY(1..GNBAUZ))
    GERR = 1 : GMESSAGE=mess(2,104,1)
    mkstat=1 : End
  Endif
Endif
If [F:PQH]PQHFCY <> GFCYDEF(6)
  Call PARAM([F:PQH]PQHFCY,"PURREN",PARAMA) From ADOVAL
  GPURREN = val(PARAMA)
Endif
[M:DIA]PQHFCY = [F:PQH]PQHFCY
[M:DIA]PQHDAT = [F:PQH]PQHDAT
[M:DIA]RSPDEA = [F:PQH]RSPDEA
[M:DIA]REQUSR = [F:PQH]REQUSR
Affzo [DIA]PQHFCY, PQHDAT, RSPDEA, REQUSR
End

Subprog AM_PQHNUM(VALEUR)
#-------------------------------------------#
# Récup des infos de l'entête appel d'offre #
#-------------------------------------------#
Variable Char    VALEUR()
Local Char PARAMA(10)

Read [PQH] PQH0=VALEUR
If fstat
  GERR = 1 : GMESSAGE =mess(23,100,1) : mkstat = 1 : End
Endif
#--- Si pas habilité sur tous sites  on verifie
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  If !find([F:PQH]PQHFCY,GUSRFCY(1..GNBAUZ))
    GERR = 1 : GMESSAGE=mess(2,104,1)
    mkstat=1 : End
  Endif
Endif
If [F:PQH]PQHFCY <> GFCYDEF(6)
  Call PARAM([F:PQH]PQHFCY,"PURREN",PARAMA) From ADOVAL
  GPURREN = val(PARAMA)
Endif

[M:DIA]PQHFCY = [F:PQH]PQHFCY
[M:DIA]PQHDAT = [F:PQH]PQHDAT
[M:DIA]RSPDEA = [F:PQH]RSPDEA
[M:DIA]REQUSR = [F:PQH]REQUSR
Affzo [DIA]PQHFCY, PQHDAT, RSPDEA, REQUSR
If [M:DIA]PQDLIN<>0
  [M:DIA]PQHNUM=VALEUR
  Call AM_PQDLIN ([M:DIA]PQDLIN) From FUNPPD3
Endif
End

Subprog C_PQDLIN(VALEUR)
#-------------------------------------------------------------#
# Contrôle qu'il y a bien des réponses pour cette ligne,      #
# qu'il reste des lignes non transformées en tarif et         #
# enfin que l'article concerné existe dans la table ITMMASTER #
#-------------------------------------------------------------#
Variable Decimal VALEUR
Read [PPH] PPH0 = [M:DIA]BPSNUM;[M:DIA]PQHNUM;VALEUR
If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
If [F:PPH]PRILINNBR>=[F:PPH]LINNBR
  GMESSAGE = mess(123,194,1) : mkstat = 1 : End : Endif
Read [ITM] ITM0 = [F:PPH]ITMREF
If fstat : GMESSAGE = mess(123,194,1) : mkstat = 1 : End : Endif
If [M:DIA]PQDLIN<>0 & [M:DIA]PQDLIN=VALEUR & [M:DIA]NBTAR = 0
  Call AM_PQDLIN(VALEUR)
Endif
End

Subprog AM_PQDLIN(VALEUR)
#--------------------------------#
# Après modification zone PQDLIN #
#--------------------------------#
Variable Decimal VALEUR
[M:DIA]PQDLIN = VALEUR
Read [PQD] PQD0 = [M:DIA]PQHNUM;VALEUR
[M:DIA]ITMREF = [F:PQD]ITMREF
[M:DIA]ITMDES = [F:PQD]ITMDES
Gosub LIRE
If [M:DIA]NBTAR = 0
  GERR = 2 : GMESSAGE =mess(99,100,1)
  mkstat = 1
Endif
Affzo [DIA]1-99
End

Subprog IB_NBTAR
#--------------------------------------#
# Init BOUTON et alim pour exécution   #
#--------------------------------------#
GBOUT1 = mess(65,198,1)
End

$AB1_NBTAR
#---------------------#
# Action avant bouton #
#---------------------#
Local Char WSCLE2(20)(0..1)
WSCLE2(0) = [M:DIA]BPSNUM
WSCLE2(1) = num$([M:DIA]PQDLIN)
Return

Subprog C_NBTAR
#------------------#
# Controle NBTAR   #
#------------------#
End

Subprog AS_PLI(VALEUR)
#-------------------------#
# Avant saisie code tarif #
#-------------------------#
Variable Char     VALEUR
If [M:DIA]PRO(nolign-1) = 1 : mkstat = 2 : Endif
End

Subprog C_PLI(VALEUR)
#------------------------------------------------#
# Contrôle sur saisie code tarif :               #
# Interdire la zone à spaces si traitement à oui #
#------------------------------------------------#
Variable Char    VALEUR()
If [M:DIA]PRO(nolign-1) = 2 & VALEUR = "" : mkstat = 1 : End : Endif
VALEUR = toupper(VALEUR)
Read [PPC] PPC0 = VALEUR
If fstat : mkstat = 1 : End : Endif
#-------------------------------------------------------------------------#
# Contrôler que le code structure du paramétrage tarif est le même        #
# que celui du fournisseur sinon les tarifs générés seront inexploitables #
# de plus le motif doit être le même                                      #
#-------------------------------------------------------------------------#
If [F:PPC]PLISTC <> [M:DIA]PLISTC(nolign-1)
   GMESSAGE = mess(54,194,1)
   mkstat = 1
Endif
If GPURREN = 2
    If [F:PPC]PRIREN <> [M:DIA]PRIREN(nolign-1)
       GMESSAGE = mess(54,194,1)
       mkstat = 1
    Endif
Endif
End

Subprog AS_PLICRD(VALEUR)
#--------------------------#
# Avant saisie fiche tarif #
#--------------------------#
Variable Char    VALEUR()
If [M:DIA]PRO(nolign-1) = 1 : mkstat = 2 : Endif
End

Subprog C_PLICRD(VALEUR)
#---------------------------------#
# Contrôle sur saisie fiche tarif #
#---------------------------------#
Variable Char    VALEUR()
Local Integer OK
VALEUR = toupper(VALEUR)
If VALEUR = "" : End : Endif
#----- Si fiche existe déjà controle des bornes de validité -----#
Read [PPF] PPF0 = [M:DIA]PLI(nolign-1);VALEUR
If fstat
  If GMANCOU <> 2 : Raz VALEUR : Endif
  End
Endif
If [F:PPF]PLISTRDAT <> [M:DIA]PLISTRDAT(nolign-1) |
&  [F:PPF]PLIENDDAT <> [M:DIA]PLIENDDAT(nolign-1)
  Call AVERTIR(mess(81,194,1),OK) From GESECRAN
  If OK = 1 : mkstat = 1 : End : Endif
Endif
End

