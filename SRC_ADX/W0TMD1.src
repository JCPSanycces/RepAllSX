#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TMD1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone MDL
mkstat = 0
zoncou = "MDL"
indice = 0
If varmode([M]MDL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MDL" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]MDL,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "MDL" : GZNUM = 1722 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "TMD"
  Local Char    VALEUR(250)
  VALEUR = [M]MDL
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]MDL = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MDL" : GZNUM = 1722 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone DESAXX
mkstat = 0
zoncou = "DESAXX"
indice = 0
If varinit([M]DESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESAXX,"TABMODELIV","DESAXX",[M:TMD1]MDL,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESAXX" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone SHOAXX
mkstat = 0
zoncou = "SHOAXX"
indice = 0
If varinit([M]SHOAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]SHOAXX,"TABMODELIV","SHOAXX",[M:TMD1]MDL,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SHOAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SHOAXX" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone GFY
mkstat = 0
zoncou = "GFY"
indice = 0
If varmode([M]GFY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GFY" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("AGF","!",[M]GFY,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "GFY" : GZNUM = 616 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone EECICT
mkstat = 0
zoncou = "EECICT"
indice = 0
If varmode([M]EECICT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EECICT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ICT","!",[M]EECICT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "EECICT" : GZNUM = 2523 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone EECLOC
mkstat = 0
zoncou = "EECLOC"
indice = 0
IMPENT = [M]EECLOC
If varinit([M]EECLOC,indice)=0
 IMPENT = 1
Endif
If varmode([M]EECLOC,indice)=0
 [M]EECLOC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EECLOC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EECLOC(indice)
 Endif
Endif
[M]EECLOC = IMPENT

## Zone EECTRN
mkstat = 0
zoncou = "EECTRN"
indice = 0
IMPENT = [M]EECTRN
If varinit([M]EECTRN,indice)=0
 IMPENT = 1
Endif
If varmode([M]EECTRN,indice)=0
 Call INICOMBO(237) From COMBOS
 SAVACT = GACTION : GACTION = "DIVEECTRN"
 GACTION = SAVACT
 GMENLOC(6)=1
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,237,1))))
 Endif
 [M]EECTRN(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EECTRN" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EECTRN(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "EECTRN" : GZNUM = 39773 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]EECTRN = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone REGION
mkstat = 0
zoncou = "REGION"
indice = 0
If varinit([M]REGION,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]REGION,"950","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]REGION,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "REGION" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]REGION,"950","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "REGION" : GZNUM = 1812 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]REGION,"950",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "REGION" : GZNUM = 1812 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PORT
mkstat = 0
zoncou = "PORT"
indice = 0
If varinit([M]PORT,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]PORT,"951","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]PORT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PORT" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]PORT,"951","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PORT" : GZNUM = 13272 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]PORT,"951",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "PORT" : GZNUM = 13272 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TMD1"
Return

