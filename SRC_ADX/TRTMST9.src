#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
#   Affiche secteur par adresse pour un tiers CRM Mars 2007 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GMST9_IN_MODIF
Global Integer GMST9_NOCHGLIGNE
Global Integer GMST9_MODIFIER

  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:MAD]) : Local File MARASSDEF [MAD] : Endif
  If !clalev([F:MAR]) : Local File MARASSREP [MAR] : Endif
  If !clalev([F:BPD]) : Local File BPDLVCUST [BPD] : Endif
  If !clalev([F:RSE]) : Local File REPSEC [RSE] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER[BPC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:MST]) : Local File MARSCT [MST] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER[BPR] : Endif
  GMST9_MODIFIER = 0
  GMST9_IN_MODIF = 0
  GMST9_NOCHGLIGNE = 0
  PARAM(3) = "0"
  If PARAM(1) = "" Then
    #Aucun client n'est indiqué. Action refusée.
    GMESSAGE = mess(408,182,1)
    GERR = 2
    FIN = 1
  Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If GMST9_IN_MODIF = 0 Then
    Call VIREBOUT(CHMEN,"IJ") From GOBJET
  Else
    Call VIREBOUT(CHMEN,"K") From GOBJET
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Integer ILIGNE
Local Integer IBADR_POSITION

  ILIGNE = 0
  IBADR_POSITION = 0
  Diszo [M:MST9]BPRNUM
  [M:MST9]BPRNUM = PARAM(1)
  Gosub LOAD_ALLADR
  If PARAM(2) <> "" Then
    ILIGNE = 0
    #on a un code adresse renseigné, on le recherche
    While ILIGNE < [M:MST9]NBADR
      If [M:MST9]CODADR(ILIGNE) = PARAM(2) Then
        IBADR_POSITION = 1
        #on a l'adresse en parmètre
        [M:MST9]NBADRSEL(0) = ""
        [M:MST9]NBADRSEL(ILIGNE) = "->"
        [M:MST9]XCODADR = [M:MST9]CODADR(ILIGNE)
        [M:MST9]XMGTBPD = [M:MST9]MGTBPD(ILIGNE)
        [M:MST9]XBPADEF = [M:MST9]BPADEF(ILIGNE)
        [M:MST9]XNOLIGN = ILIGNE + 1
        Break
      Endif
      ILIGNE += 1
    Wend
  Endif
  Gosub AFFFICHE_ADR_SEC
  If IBADR_POSITION = 0 Then
    GMST9_IN_MODIF = 0
    Gosub DISZO_SECTEUR
  Else
    GMST9_IN_MODIF = 1
    Gosub ACTZO_SECTEUR
  Endif
  Affzo [M:MST9]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If dim([M:MST9]BPRNUM) > 0 Then
    Raz [M:MST9]
  Endif
  PARAM(2) = num$(GMST9_MODIFIER)
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "K"
      #Modifier
      Gosub BOUT_K
    When "I"
      #Enregistrer
      Gosub BOUT_I
    When "J"
      #Abandon
      Gosub BOUT_J
  Endcase
Return

##########################################################################################################
$BOUT_K
  #Modifier
  GMST9_NOCHGLIGNE = 1
  GMST9_IN_MODIF = 1
  Gosub ACTZO_SECTEUR
  Affzo [M:MST9]1-99
Return

##########################################################################################################
$BOUT_I
  #Enregistrer
  GMST9_NOCHGLIGNE = 1
  GOK = 1
  Gosub VERIF_SECTEUR
  If GOK < 1 Then
    Return
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [MAR]
  Gosub SAVE_SECTEUR
  If GOK < 1 Then
    GERR = 1
    Rollback
    Return
  Else
    GMST9_MODIFIER = 1
    Commit
    GMST9_IN_MODIF = 0
    Gosub DISZO_SECTEUR
    If [M:MST9]SECNUM([M:MST9]XNOLIGN-1) <> [M:MST9]XSECNUM Then
      [M:MST9]SECNUM([M:MST9]XNOLIGN-1) = [M:MST9]XSECNUM
    Endif
    Gosub  AFFFICHE_ADR_SEC
    Affzo [M:MST9]1-99
  Endif
Return

##########################################################################################################
$BOUT_J
  #Abandon
  If adxlog = 1 Then
    Rollback
  Endif
  GMST9_NOCHGLIGNE = 1
  Gosub AFFFICHE_ADR_SEC
  GMST9_IN_MODIF = 0
  Gosub DISZO_SECTEUR
  Affzo [M:MST9]1-99
Return

##########################################################################################################
$LOAD_ALLADR
Local Integer ILIGNE

  ILIGNE = 0
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [M:MST9]BPRNUM Order By [F:BPA]BPAADD
  For [BPA]
    If ILIGNE >= dim([M:MST9]CODADR) Then
      Break
    Endif
    If ILIGNE = 0 Then
      [M:MST9]NBADRSEL(ILIGNE) = "->"
    Else
      [M:MST9]NBADRSEL(ILIGNE) = ""
    Endif
    [M:MST9]CODADR(ILIGNE) = [F:BPA]BPAADD
    [M:MST9]BPADES(ILIGNE) = [F:BPA]BPADES
    [M:MST9]POSCOD(ILIGNE) = [F:BPA]POSCOD
    [M:MST9]CTY(ILIGNE) = [F:BPA]CTY
    [M:MST9]SAT(ILIGNE) = [F:BPA]SAT
    [M:MST9]BPACRY(ILIGNE) = [F:BPA]CRY
    [M:MST9]BPADEF(ILIGNE) = [F:BPA]BPAADDFLG
    Read [MAD]MAD0=[M:MST9]BPRNUM;[F:BPA]BPAADD;"BPR"
    If fstat = 0 Then
      [M:MST9]SECNUM(ILIGNE) = [F:MAD]MARSCTNUM
    Endif
    Read [BPD]BPD0=[M:MST9]BPRNUM;[F:BPA]BPAADD
    If fstat = 0 Then
      [M:MST9]MGTBPD(ILIGNE) = 2
    Else
      [M:MST9]MGTBPD(ILIGNE) = 1
    Endif
    If ILIGNE = 0 Then
      [M:MST9]XCODADR = [M:MST9]CODADR(0)
    Endif
    ILIGNE += 1
  Next
  Filter [BPA]
  [M:MST9]NBADR = ILIGNE
Return

##########################################################################################################
$AFFFICHE_ADR_SEC
Local Integer ILIGNE
Local Integer INUM_ADI

  ILIGNE = 0
  INUM_ADI= 19 + GFAMCIA
  Gosub RAZ_ADR_SEC
  Read [BPA]BPA0=1;[M:MST9]BPRNUM;[M:MST9]XCODADR
  If fstat = 0 Then
    [M:MST9]XBPADES = [F:BPA]BPADES
  Endif
  #Secteur
  Read [MAD]MAD0=[M:MST9]BPRNUM;[M:MST9]XCODADR;"BPR"
  If fstat = 0 Then
    [M:MST9]XSECNUM = [F:MAD]MARSCTNUM
    [M:MST9]XSECINI = [F:MAD]MARSCTNUM
  Else
    [M:MST9]XSECNUM = ""
    [M:MST9]XSECINI = ""
  Endif
  #Représentants
  ILIGNE = 0
  Filter [MAR] Where [F:MAR]RECORDNUM = [M:MST9]BPRNUM and [F:MAR]RECORDADD = [M:MST9]XCODADR and [F:MAR]RECORDTYP = "BPR" Order By [F:MAR]REPNUM
  For [MAR]
    If [F:MAR]REPTYP = 0 Then
      #représentant secondaire
      [M:MST9]REPNUMBPC(ILIGNE) = [F:MAR]REPNUM
      [M:MST9]REPMSSBPC(ILIGNE) = [F:MAR]REPMSS
      [M:MST9]ITMBPC(ILIGNE) = [F:MAR]REPITM
      If [M:MST9]ITMBPC(ILIGNE) = "" Then
        [M:MST9]LIBITMBPC(ILIGNE) = ""
      Else
        Call GET_LIB(INUM_ADI, [M:MST9]ITMBPC(ILIGNE), [M:MST9]LIBITMBPC(ILIGNE)) From CRM_UTIL
      Endif
      [M:MST9]MANASSBPC = [F:MAR]MANASS
      ILIGNE += 1
    Else
      If [F:MAR]REPTYP = 1 Then
        If dim([M:MST9]XREPNUMBPC) > 0 Then
          [M:MST9]XREPNUMBPC(0) = [F:MAR]REPNUM
          [M:MST9]XREPINIBPC(0) = [F:MAR]REPNUM
        Endif
      Elsif [F:MAR]REPTYP = 2 Then
        If dim([M:MST9]XREPNUMBPC) > 1 Then
          [M:MST9]XREPNUMBPC(1) = [F:MAR]REPNUM
          [M:MST9]XREPINIBPC(1) = [F:MAR]REPNUM
        Endif
      Endif
    Endif
  Next
  Filter [MAR]
  [M:MST9]NBREPBPC = ILIGNE
  #Représentants clients livrés
  ILIGNE = 0
  Filter [MAR] Where [F:MAR]RECORDNUM = [M:MST9]BPRNUM and [F:MAR]RECORDADD = [M:MST9]XCODADR and [F:MAR]RECORDTYP = "BPD" Order By [F:MAR]REPNUM
  For [MAR]
    If [F:MAR]REPTYP = 0 Then
      #représentant secondaire
      [M:MST9]REPNUMBPD(ILIGNE) = [F:MAR]REPNUM
      [M:MST9]REPMSSBPD(ILIGNE) = [F:MAR]REPMSS
      [M:MST9]ITMBPD(ILIGNE) = [F:MAR]REPITM
      If [M:MST9]ITMBPD(ILIGNE) = "" Then
        [M:MST9]LIBITMBPD(ILIGNE) = ""
      Else
        Call GET_LIB(INUM_ADI, [M:MST9]ITMBPD(ILIGNE), [M:MST9]LIBITMBPD(ILIGNE)) From CRM_UTIL
      Endif
      [M:MST9]MANASSBPD = [F:MAR]MANASS
      ILIGNE += 1
    Else
      If [F:MAR]REPTYP = 1 Then
        If dim([M:MST9]XREPNUMBPD) > 0 Then
          [M:MST9]XREPNUMBPD(0) = [F:MAR]REPNUM
          [M:MST9]XREPINIBPD(0) = [F:MAR]REPNUM
        Endif
      Elsif [F:MAR]REPTYP = 2
        If dim([M:MST9]XREPNUMBPD) > 1 Then
          [M:MST9]XREPNUMBPD(1) = [F:MAR]REPNUM
          [M:MST9]XREPINIBPD(1) = [F:MAR]REPNUM
        Endif
      Endif
    Endif
  Next
  Filter [MAR]
  [M:MST9]NBREPBPD = ILIGNE
  Affzo [M:MST9]1-99
Return

##########################################################################################################
$RAZ_ADR_SEC
  Raz [M:MST9]XBPADES
  Raz [M:MST9]XSECNUM
  Raz [M:MST9]XSECINI
  If dim([M:MST9]XREPNUMBPC) >= 0 Then  # FGR 30/10/2014 : X3SUIVI103688 : champ soumis à code activité
    Raz [M:MST9]XREPNUMBPC
    Raz [M:MST9]XREPINIBPC
  Endif
  If dim([M:MST9]XREPNUMBPD) >= 0 Then  # FGR 30/10/2014 : X3SUIVI103688 : champ soumis à code activité
    Raz [M:MST9]XREPNUMBPD
    Raz [M:MST9]XREPINIBPD
  Endif
  Raz [M:MST9]NBREPBPC
  Raz [M:MST9]REPNUMBPC
  Raz [M:MST9]REPMSSBPC
  Raz [M:MST9]ITMBPC
  Raz [M:MST9]LIBITMBPC
  Raz [M:MST9]MANASSBPC
  Raz [M:MST9]NBREPBPD
  Raz [M:MST9]REPNUMBPD
  Raz [M:MST9]REPMSSBPD
  Raz [M:MST9]ITMBPD
  Raz [M:MST9]LIBITMBPD
  Raz [M:MST9]MANASSBPD
Return

##########################################################################################################
$ACTZO_SECTEUR
  Actzo [M:MST9]XSECNUM
  If dim([M:MST9]XREPNUMBPC) >= 0 Then  # FGR 30/10/2014 : X3SUIVI103688 : champ soumis à code activité
    Actzo [M:MST9]XREPNUMBPC
  Endif
  Actzo [M:MST9]REPNUMBPC
  Actzo [M:MST9]REPMSSBPC
  Actzo [M:MST9]ITMBPC
  If [M:MST9]XMGTBPD = 2 Then
    If dim([M:MST9]XREPNUMBPD) >= 0 Then  # FGR 30/10/2014 : X3SUIVI103688 : champ soumis à code activité
      Actzo [M:MST9]XREPNUMBPD
    Endif
    Actzo [M:MST9]REPNUMBPD
    Actzo [M:MST9]REPMSSBPD
    Actzo [M:MST9]ITMBPD
  Else
    If dim([M:MST9]XREPNUMBPD) >= 0 Then  # FGR 30/10/2014 : X3SUIVI103688 : champ soumis à code activité
      Diszo [M:MST9]XREPNUMBPD
    Endif
    Diszo [M:MST9]REPNUMBPD
    Diszo [M:MST9]REPMSSBPD
    Diszo [M:MST9]ITMBPD
  Endif
Return

##########################################################################################################
$DISZO_SECTEUR
  Diszo [M:MST9]XSECNUM
  If dim([M:MST9]XREPNUMBPC) >= 0 Then  # FGR 30/10/2014 : X3SUIVI103688 : champ soumis à code activité
    Diszo [M:MST9]XREPNUMBPC
  Endif
  Diszo [M:MST9]REPNUMBPC
  Diszo [M:MST9]REPMSSBPC
  Diszo [M:MST9]ITMBPC
  If dim([M:MST9]XREPNUMBPD) >= 0 Then  # FGR 30/10/2014 : X3SUIVI103688 : champ soumis à code activité
    Diszo [M:MST9]XREPNUMBPD
  Endif
  Diszo [M:MST9]REPNUMBPD
  Diszo [M:MST9]REPMSSBPD
  Diszo [M:MST9]ITMBPD
Return

##########################################################################################################
$VERIF_SECTEUR
  #Vérification que tout est correct
  If dim([M:MST9]XREPNUMBPC) > 1 Then
    If [M:MST9]XREPNUMBPC(0) = "" Then
      If [M:MST9]XREPNUMBPC(1) <> "" Then
        [M:MST9]XREPNUMBPC(0) = [M:MST9]XREPNUMBPC(1)
        [M:MST9]XREPNUMBPC(1) = ""
      Endif
    Endif
  Endif
  If [M:MST9]XMGTBPD = 2 Then
    If dim([M:MST9]XREPNUMBPD) > 1 Then
      If [M:MST9]XREPNUMBPD(0) = "" Then
        If [M:MST9]XREPNUMBPD(1) <> "" Then
          [M:MST9]XREPNUMBPD(0) = [M:MST9]XREPNUMBPD(1)
          [M:MST9]XREPNUMBPD(1) = ""
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$SAVE_SECTEUR
Local Integer IBREWRITE
Local Integer IBMODIF_BPC
Local Integer IBMODIF_BPD
Local Integer IBERROR
Local Integer IAUTASS

  IBREWRITE = 0
  IBMODIF_BPC = 0
  IBMODIF_BPD = 0
  #Gestion des secteurs
  If [M:MST9]XSECNUM <> [M:MST9]XSECINI Then
    #modification du secteur
    If [M:MST9]XSECNUM <> "" Then
      IBREWRITE = 0
      If [M:MST9]XSECINI <> "" Then
        Read [MAD]MAD0=[M:MST9]BPRNUM;[M:MST9]XCODADR;"BPR"
        If fstat <> 0 Then
          #Erreur lors de la lecture du secteur de marché.
          GMESSAGE = mess(589,177,1)
          GOK = 0
          Return
        Endif
        IBREWRITE = 1
      Endif
      Call WRITE_MAD(IBREWRITE, [M:MST9]BPRNUM, [M:MST9]XCODADR, "BPR", [M:MST9]XSECNUM, 1, IBERROR) From SUBMSTB1
      If IBERROR Then
        #Erreur lors de la mise à jour du secteur de marché.
        GMESSAGE = mess(590,177,1)
        GOK = 0
        Return
      Endif
    Endif
  Endif
  If GOK < 1 Then
    Return
  Endif
  #Gestion des représentants principaux
  For IINDICE = 1 To dim([M:MST9]XREPNUMBPC)
    If [M:MST9]XREPNUMBPC(IINDICE-1) <> [M:MST9]XREPINIBPC(IINDICE-1) Then
      If [M:MST9]XREPNUMBPC(IINDICE-1) <> "" Then
        IBREWRITE = 0
        If [M:MST9]XREPINIBPC(IINDICE-1) <> "" Then
          Read [MAR]MAR2=[M:MST9]BPRNUM;[M:MST9]XCODADR;"BPR";IINDICE
          If fstat <> 0 Then
            #Erreur lors de la lecteur des portefeuilles représentants
            GMESSAGE = mess(584,177,1)
            GOK = 0
            Break
          Endif
          IBREWRITE = 1
        Endif
        Call WRITE_MAR(IBREWRITE, [M:MST9]BPRNUM, [M:MST9]XCODADR, "BPR", [M:MST9]XREPNUMBPC(IINDICE-1), IINDICE, "", "", 1, IBERROR) From SUBMSTB1
        If IBERROR Then
          #Erreur lors de la mise à jour des portefeuilles représentants
          GMESSAGE = mess(585,177,1)
          GOK = 0
          Break
        Endif
        IBMODIF_BPC = 1
      Else
        If [M:MST9]XREPINIBPC(IINDICE-1) <> "" Then
          Delete [MAR] Where [F:MAR]RECORDNUM = [M:MST9]BPRNUM and [F:MAR]RECORDADD = [M:MST9]XCODADR and [F:MAR]RECORDTYP = "BPR" and [F:MAR]REPTYP = IINDICE
          If fstat <> 0 Then
            #Erreur lors de la mise à jour des portefeuilles représentants
            GMESSAGE = mess(585,177,1)
            GOK = 0
            Break
          Endif
          IBMODIF_BPC = 1
        Endif
      Endif
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  #Représentants secondaires
  Delete [MAR] Where [F:MAR]RECORDNUM = [M:MST9]BPRNUM and [F:MAR]RECORDADD = [M:MST9]XCODADR and [F:MAR]RECORDTYP = "BPR" and [F:MAR]REPTYP = 0
  If fstat <> 0 Then
    #Erreur lors de la mise à jour des portefeuilles représentants
    GMESSAGE = mess(585,177,1)
    GOK = 0
  Endif
  If GOK < 1 Then
    Return
  Endif
  If [M:MST9]XBPADEF = 2 Then
    Delete [RSE] Where [F:RSE]BPCNUM = [M:MST9]BPRNUM
    If fstat <> 0 Then
      #Erreur lors de la mise à jour des commerciaux secondaires.
      GMESSAGE = mess(587,196,1)
      GOK = 0
    Endif
  Endif
  If GOK < 1 Then
    Return
  Endif
  IINDICE = 0
  While IINDICE< [M:MST9]NBREPBPC
    If [M:MST9]REPNUMBPC <> "" Then
      Call WRITE_MAR(0, [M:MST9]BPRNUM, [M:MST9]XCODADR, "BPR", [M:MST9]REPNUMBPC(IINDICE), 0, [M:MST9]REPMSSBPC(IINDICE), [M:MST9]ITMBPC(IINDICE), [M:MST9]MANASSBPC(IINDICE), IBERROR) From SUBMSTB1
      If IBERROR Then
        #Erreur lors de la mise à jour des portefeuilles représentants
        GMESSAGE = mess(585,177,1)
        GOK = 0
        Break
      Endif
      If [M:MST9]XBPADEF = 2 Then
        If [M:MST9]MANASSBPC(IINDICE) = 1 Then
          IAUTASS = 0
        Else
          IAUTASS = 1
        Endif
        Call WRITE_RSE(0, [M:MST9]BPRNUM, [M:MST9]REPNUMBPC(IINDICE), [M:MST9]REPMSSBPC(IINDICE), [M:MST9]ITMBPC(IINDICE), IAUTASS, IBERROR) From SUBMSTB1
        If IBERROR Then
          #Erreur lors de la mise à jour des commerciaux secondaires.
          GMESSAGE = mess(587,196,1)
          GOK = 0
          Break
        Endif
      Endif
    Endif
    IINDICE += 1
  Wend
  If GOK < 1 Then
    Return
  Endif
  If [M:MST9]XBPADEF = 2 Then
    #représentants principaux
    If IBMODIF_BPC = 1 Then
      #il faut reporté sur le client
      Read [BPC]BPC0=[M:MST9]BPRNUM
      If fstat <> 0 Then
        #Erreur lors de la lecture du client
        GMESSAGE = mess(317,177,1)
        GOK = 0
        Return
      Endif
      For IINDICE = 0 To dim([M:MST9]XREPNUMBPC)-1
        [F:BPC]REP(IINDICE) = [M:MST9]XREPNUMBPC(IINDICE)
      Next
      Rewrite [BPC]
      If fstat <> 0 Then
        #Erreur lors de la mise à jour du client
        GMESSAGE = mess(586,177,1)
        GOK = 0
        Return
      Endif
    Endif
  Endif
  If GOK < 1 Then
    Return
  Endif
  #Clients livrés
  If [M:MST9]XMGTBPD = 2 Then
    #on gère les clients livrés sur cette adresse
    For IINDICE = 1 To dim([M:MST9]XREPNUMBPD)
      If [M:MST9]XREPNUMBPD(IINDICE-1) <> [M:MST9]XREPINIBPD(IINDICE-1) Then
        If [M:MST9]XREPNUMBPD(IINDICE-1) <> "" Then
          IBREWRITE = 0
          If [M:MST9]XREPINIBPD(IINDICE-1) <> "" Then
            Read [MAR]MAR2=[M:MST9]BPRNUM;[M:MST9]XCODADR;"BPD";IINDICE
            If fstat <> 0 Then
              #Erreur lors de la lecteur des portefeuilles représentants
              GMESSAGE = mess(584,177,1)
              GOK = 0
              Break
            Endif
            IBREWRITE = 1
          Endif
          Call WRITE_MAR(IBREWRITE, [M:MST9]BPRNUM, [M:MST9]XCODADR, "BPD", [M:MST9]XREPNUMBPD(IINDICE-1), IINDICE, "", "", 1, IBERROR) From SUBMSTB1
          If IBERROR Then
            #Erreur lors de la mise à jour des portefeuilles représentants
            GMESSAGE = mess(585,177,1)
            GOK = 0
            Break
          Endif
          IBMODIF_BPD = 1
        Else
          If [M:MST9]XREPINIBPD(IINDICE-1) <> "" Then
            Delete [MAR] Where [F:MAR]RECORDNUM = [M:MST9]BPRNUM and [F:MAR]RECORDADD = [M:MST9]XCODADR and [F:MAR]RECORDTYP = "BPD" and [F:MAR]REPTYP = IINDICE
            If fstat <> 0 Then
              #Erreur lors de la mise à jour des portefeuilles représentants
              GMESSAGE = mess(585,177,1)
              GOK = 0
              Break
            Endif
            IBMODIF_BPD = 1
          Endif
        Endif
      Endif
    Next
    If IBMODIF_BPD = 1 Then
      Read [BPD]BPD0=[F:BPR]BPRNUM;[F:BPA]BPAADD
      If fstat <> 0 Then
        #Erreur lors de la lecture des clients livrés
        GMESSAGE = mess(566,177,1)
        GOK = 0
        Return
      Endif
      For IINDICE = 0 To dim([M:MST9]XREPNUMBPD)-1
        [F:BPD]REP(IINDICE) = [M:MST9]XREPNUMBPD(IINDICE)
      Next
      Rewrite [BPD]
      If fstat <> 0 Then
        #Erreur lors de la mise à jour du client livré
        GMESSAGE = mess(588,177,1)
        GOK = 0
        Return
      Endif
    Endif
    #Représentants secondaires
    Delete [MAR] Where [F:MAR]RECORDNUM = [M:MST9]BPRNUM and [F:MAR]RECORDADD = [M:MST9]XCODADR and [F:MAR]RECORDTYP = "BPD" and [F:MAR]REPTYP = 0
    If fstat <> 0 Then
      #Erreur lors de la mise à jour des portefeuilles représentants
      GMESSAGE = mess(585,177,1)
      GOK = 0
    Endif
    If GOK < 1 Then
      Return
    Endif
    IINDICE = 0
    While IINDICE < [M:MST9]NBREPBPD
      If [M:MST9]REPNUMBPD <> "" Then
        Call WRITE_MAR(0, [M:MST9]BPRNUM, [M:MST9]XCODADR, "BPD", [M:MST9]REPNUMBPD(IINDICE), 0, [M:MST9]REPMSSBPD(IINDICE), [M:MST9]ITMBPD(IINDICE), [M:MST9]MANASSBPD(IINDICE), IBERROR) From SUBMSTB1
        If IBERROR Then
          #Erreur lors de la mise à jour des portefeuilles représentants
          GMESSAGE = mess(585,177,1)
          GOK = 0
          Break
        Endif
      Endif
      IINDICE += 1
    Wend
  Endif
Return
