#<AdxTL>@(#)8.0.0.0 $Revision$
Call PARCLI("UserName",GBIDC1) From GLOBVAR
GBIDC2 = password
Call PASSE(GBIDC1,GBIDC2)
Infbox GBIDC1,GBIDC2
End

#-----------------------------------#
Subprog PASSE(USER,PASSE)
Variable Char USER,PASSE
Local Integer OK
Local Char TIT(30)
If !GSERVEUR
 GMODIF = 0
 Local Mask ASSOPASWEB [PAS]
 [M:PAS]USER  = [L]USER
# [M:PAS]PASSE = [L]PASSE :# il y avait un commentaire CCL  (c'est voulu, il faut le saisir CC- 19/06/2013)
 Call TITAWI("ASSOPASWEB",TIT) From OBJDIV
 Call DIALWIN(OK,TIT,"ASSOPASWEB") From GESECRAN
 If OK<>2 : mkstat = 1 : End : Endif
 [L]USER  = [M:PAS]USER
 [L]PASSE = [M:PAS]PASSE
 Close Local Mask [PAS]
Endif
End

#------------------------------------#
Subprog AS_USER(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & !GMODIF
 If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
 Read [AUS]LOGIN=toupper(VALEUR)
 If !fstat : mkstat = 2 : Endif
Endif
GMODIF = 1
End

Subprog C_USER(VALEUR)
Variable Char USER
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If VALEUR<>""
 Read [AUS]LOGIN=toupper(VALEUR)
 If fstat
  GMESSAGE = VALEUR-":"-mess(60,130,1) : # Code utilisateur inexistant dans l'application courante
  mkstat = 1 : End
 Endif
Endif
End
