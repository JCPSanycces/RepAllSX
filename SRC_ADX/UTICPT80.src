#<AdxTL>@(#)0.0.0.0 $Revision$
End
########################################################################################
# UTICPT80   UTI process                                                 FIN module
#            Migration From U10 to U11
#
#  The migration must take into account the changes in Account parameterization :
#  ==> New fields must be initialized :
#    1- 'Rate type management’    [F:GAC]TYPRATFLG (‘Management’ tab)
#    2- ‘Rate type’               [F:GAC]TYPRAT    (‘Management’ tab)
#    3- ‘Debit balance decrease’  [F:GAC]CNVACC1 (FRA : diminution solde débiteur)
#     - ‘Debit balance increase’  [F:GAC]CNVACC2 (FRA : augmentation solde débiteur)
#     - ‘Credit balance decrease’ [F:GAC]CNVACC3 (FRA : diminution solde créditeur)
#     - ‘Credit balance increase’ [F:GAC]CNVACC4 (FRA : augmentation solde créditeur)
#
########################################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Common Data Module
  If [F:ADS]MODULE(8)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update GACCOUNT table for new conversion variance setup") From LECFIC
  Call MAJ_UTICPT80(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File

End
##########################################################################
Subprog MAJ_UTICPT80(DOSSIER)
Value Char DOSSIER

Local Integer ERR
Local Integer WFLACT
Local Integer WCOUNT

Call ECR_TRACE("UTICPT80 : Start of process on : "+DOSSIER,0) From GESECRAN

  If filinfo(filpath("FIL","GACCOUNT","fde",DOSSIER),0)<=0 or func DOSVUE.ISVIEW(DOSSIER,"GACCOUNT")<>0 : End : Endif
  If filinfo(filpath("FIL","GCOA","fde",DOSSIER),0)<=0 or func DOSVUE.ISVIEW(DOSSIER,"GCOA")<>0 : End : Endif

  If clalev([F:ADA])=0    : Local File =DOSSIER+".ADOSACT"  [ADA]   : Endif
  If clalev([F:GAC])=0    : Local File =DOSSIER+".GACCOUNT" [GAC]   : Endif  : # GAC- U11
  If clalev([F:GAC10])=0  : Local File =DOSSIER+".GACCOUNT" [GAC10] : Endif  : # GAC- U10
  If clalev([F:COA])= 0   : Local File =DOSSIER+".GCOA"     [COA]   : Endif

  Read [ADA]ADA0=DOSSIER;"KDEAT"
  WFLACT=  [F:ADA]FLACT

  Link [GAC] With [COA]COA0~=[GAC]COA As [LNK]

  # Search Sequence Number in the table of allocations for the Financial Module
  Call DEBTRANS From GLOCK
  Trbegin [GAC]

  For [LNK]
    [F:GAC10] = [F:GAC]
    # If KDEAT="No" or the chart of account is associated to a legislation <> "GER" and <>  "AUT"
    If WFLACT = 1 or ([F:COA]LEG <> "GER" and [F:COA]LEG <> "AUT")
      Gosub  KDEAT_NO
    # If KDEAT="Yes" and the chart of account is associated to a legislation =  "GER" or "AUT"
    Elsif WFLACT = 2 and ([F:COA]LEG = "GER" or [F:COA]LEG = "AUT")
      Gosub  KDEAT_YES
    Endif

    Gosub UPDATE_GAC
    If GOK<1
      Break
    Endif
  Next #[LNK]


  If GOK<1
    Rollback
  Else
    Commit
  Endif

  Close Local File [GAC]
  Close Local File [GAC10]
  Close Local File [COA]

Call ECR_TRACE("UTICPT80 : "+num$(WCOUNT)+ "[GAC] records processed",0) From GESECRAN
Call ECR_TRACE("UTICPT80 : End of process on : "+DOSSIER,0) From GESECRAN

End
#===================
$KDEAT_NO

 # If KDEAT="No" or the chart of account is associated to a legislation <> "GER" or "AUT"
 Case [F:GAC10]DIF
   When 1      #  U10 = "Not managed"     ==> U11= "None"
     [F:GAC]DIF = 1                      # None
     [F:GAC]CNVACC1 =  ""
     [F:GAC]CNVACC2 =  ""
     [F:GAC]CNVACC3 =  ""
     [F:GAC]CNVACC4 =  ""
   When 2      #  U10 = "Balance sheet"   ==> U11= "By account balance"
     [F:GAC]DIF     =  3                 # "By account balance"
     [F:GAC]CNVACC1 =  ""
     [F:GAC]CNVACC2 =  ""
     [F:GAC]CNVACC3 =  ""
     [F:GAC]CNVACC4 =  ""
   When 3      #  U10 = "Profit and loss" ==> U11= "By account balance"
     [F:GAC]DIF    = 3                   # "By account balance"
     [F:GAC]CNVACC1 =  [F:COA]ACCMIS(9)  # Pertes change/Exchange loss
     [F:GAC]CNVACC2 =  [F:COA]ACCMIS(8)  # gains change/Exchange gain
     [F:GAC]CNVACC3 =  [F:COA]ACCMIS(8)  # gains change/Exchange gain
     [F:GAC]CNVACC4 =  [F:COA]ACCMIS(9)  # Pertes change/Exchange loss
   When Default
 Endcase


Return
#===================
$KDEAT_YES

 # If KDEAT="yes" and LEG of the COA = "GER" or "AUT"
 Case [F:GAC10]DIF
   When 1      #  U10 = "Not managed"     ==> U11= "None"
     [F:GAC]DIF = 1                      # None
     [F:GAC]CNVACC1 =  ""
     [F:GAC]CNVACC2 =  ""
     [F:GAC]CNVACC3 =  ""
     [F:GAC]CNVACC4 =  ""
   When 2      #  U10 = "Balance sheet"   ==> U11= "By journal entry"
     [F:GAC]DIF     =  2                 # "By journal entry"
     [F:GAC]CNVACC1 =  ""
     [F:GAC]CNVACC2 =  ""
     [F:GAC]CNVACC3 =  ""
     [F:GAC]CNVACC4 =  ""
   When 3      #  U10 = "Profit and loss" ==> U11= "By account balance"
     [F:GAC]DIF    = 3                   # "By account balance"
     [F:GAC]CNVACC1 =  [F:COA]ACCMIS(9)  # Pertes change/Exchange loss
     [F:GAC]CNVACC2 =  [F:COA]ACCMIS(8)  # gains change/Exchange gain
     [F:GAC]CNVACC3 =  [F:COA]ACCMIS(8)  # gains change/Exchange gain
     [F:GAC]CNVACC4 =  [F:COA]ACCMIS(9)  # Pertes change/Exchange loss
   When Default
 Endcase

Return
#===================
$UPDATE_GAC

   [F:GAC]TYPRATFLG = 1   # Rate type management="No"
   [F:GAC]TYPRAT    = 0   # Rate type
   If dim([F:GAC]UPDTIM)>0
     [F:GAC]UPDTIM    = time
   Endif
   If dim([F:GAC]UPDDATTIM)>0
     [F:GAC]UPDDATTIM = datetime$
   Endif
   Rewrite [F:GAC]
   If fstat
     Call ECR_TRACE("UTICPT80 : File GACCOUNT, ERROR while update ="-num$(fstat),1) From GESECRAN
     GOK=0
   Else
     WCOUNT+=1
   Endif

 Return
########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT80 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

# Check Common Data Module
If [F:ADS]MODULE(8)<>2 : End : Endif
Call MAJ_UTICPT80(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
# Check Common Data Module
If [F:ADS]MODULE(8)<>2 : End : Endif
Call MAJ_UTICPT80(APPLI)
End

