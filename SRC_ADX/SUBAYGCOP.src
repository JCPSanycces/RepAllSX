#<AdxTL>@(#)12.0.0.0 $Revision$
#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = "AYS"
PARBOUT(2) = "ZSITE1COP1"
PARBOUT(3) = ""
#FLGEXE = 1
GACTION = "AYSCOP"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","SUBAYSCOP","AYSCOP",3,"") From GTRAITE
End
######################################################################################
## Xtend: Copie fiche Alias de page
######################################################################################
#    GACTION
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES
#        ELTCOD
#    [F:AYS1] Site origine       Ouvert et lu
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap
 Local File AYTPAG  [AYG1]
 Local File ATEXTE  [ATX1]
 Local File ATEXTRA [AXX1]
Else
 Local File =[L]DOSORG+".AYTPAG"  [AYG1]
 Local File =[L]DOSORG+".ATEXTE"  [ATX1]
 Local File =[L]DOSORG+".ATEXTRA" [AXX1]
Endif
If [L]DOSDES=nomap
 Local File AYTPAG  [AYG2]
 Local File ATEXTE  [ATX2]
 Local File ATEXTRA [AXX2]
 Local File AYTPAG  [AYGS]         # Sauvegarde pour Données à reconduire
Else
 Local File =[L]DOSDES+".AYTPAG"  [AYG2]
 Local File =[L]DOSDES+".ATEXTE"  [ATX2]
 Local File =[L]DOSDES+".ATEXTRA" [AXX2]
 Local File =[L]DOSDES+".AYTPAG"  [AYGS]         # Sauvegarde pour Données à reconduire
Endif

Read [AYG1]AYG0 = [L]FCYORG;[L]ELTCOD
If fstat
  OK=0
  Call RSTA("AYG",[L]FCYORG-[L]ELTCOD) From GLOCK
  Goto FINALLY
Endif

Read [AYG2]AYG0 = [L]FCYDES;[L]ELTCOD
DES_ELTCOD=[F:AYG2]PAGCOD : Gosub MSGDESOBJ From AYTCOP
If OK
 Call DEBTRANS From GLOCK
 [F:AYGS]=[F:AYG2]
 Gosub TR_COP
Endif

If OK=1 & GOK=1 & GTRACE=""
    Call ECR_TRACE(mess(23,7900,1),0) From GESECRAN
Endif

$FINALLY
Close Local File [AYG1], [ATX1] , [AXX1] , [AYGS]
&              , [AYG2], [ATX2] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AYG2] , [ATX2]
 If DES_HASELT
     Delete [AYG2] Where FCYCOD=[L]FCYDES and PAGCOD=[L]DES_ELTCOD
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTPAG" : Goto ROLL_TR_COP
     Elsif fstat>5
      GOK = 0 : Call RSTA("AYG2","") From GLOCK : Goto AB_TR_COP
     Endif
 Endif

 For [AYG1]AYG0 Where FCYCOD=[L]FCYORG & PAGCOD=[L]ELTCOD
  [F:AYG2] = [F:AYG1]
  [F:AYG2]FCYCOD = [L]FCYDES
  Call COPTEXTRA("AYTPAG","INTIT",[F:AYG1]FCYCOD,[F:AYG1]PAGCOD,[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  [F:AYG2]UPDUSR = GUSER
  [F:AYG2]UPDDAT = date$
  # [F:AYG2]UPDTIM = time  - 93575
  Call SET_UPDTIM("AYG2") From AYTCOP # 93575
  [F:AYG2]BRWX3  = [F:AYG2]FCYCOD+"_"+[F:AYG2]PAGCOD
  # Données reconduites
  [F:AYG2]WEBPRO=[F:AYGS]WEBPRO
  Write [AYG2]
  If fstat
   GOK=0 : Call FSTA("AYG2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
