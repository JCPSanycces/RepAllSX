######################################################################################
Subprog AS_BASPAG1

Local Integer SNOLIGN

  If nolign > 0 & nolign <= [M]BASPAG1 Then
    Local File BPADDRESS [BPA1]        # FGR 21/10/2015 : X3SUIVI111873
    SNOLIGN = nolign
    Read [BPA1]BPA0=[M:BPAW]BPATYP;[M:BPAW]BPANUM;[M:BPAW]BPAADD(nolign-1)
    If fstat Then
      Raz [F:BPA1]
    Endif
    [M:BPAW] = [F:BPA1]
    [M:BPAW]TEL = [F:BPA1]TEL(0)       # FGR 21/10/2015 : X3SUIVI111873
    [M:BPAW]FAX = [F:BPA1]TEL(1)       # FGR 21/10/2015 : X3SUIVI111873
    [M:BPAW]WEB = [F:BPA1]WEB(0)       # FGR 21/10/2015 : X3SUIVI111873
    Affzo [BPAW]15-20
    nolign = SNOLIGN
  Endif
End

######################################################################################
Subprog AV_SAT(VALEUR)
Variable Char    VALEUR()

  If !GWEBSERV Then
    If GFMT<>"" Then
      Chgfmt [M:BPAW]SAT With "K:"+GFMT
    Else
      Chgfmt [M:BPAW]SAT With "-K:1X"
    Endif
  Endif
End

