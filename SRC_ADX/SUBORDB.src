#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################
Subprog AM_YEASTR(VALEUR)
Variable Decimal VALEUR
[M:ORDB]YEAMONSTR = month$([M:ORDB]MONSTR)-num$(VALEUR)
Affzo [M:ORDB]YEAMONSTR
End
############################################################
Subprog AM_MONSTR(VALEUR)
Variable Decimal VALEUR
[M:ORDB]YEAMONSTR = month$(VALEUR)-num$([M:ORDB]YEASTR)
Affzo [M:ORDB]YEAMONSTR
End
############################################################
Subprog C_MONSTR(VALEUR)
Variable Decimal VALEUR
If ([M:ORDB]YEASTR*100)+VALEUR < ([M:ORDB]YEAFIR*100)+[M:ORDB]MONFIR
  mkstat = 2
Endif
End
############################################################
Subprog AV_YEAMONSTR(VALEUR)
Variable Char    VALEUR()
VALEUR = month$([M:ORDB]MONSTR)-num$([M:ORDB]YEASTR)
End
############################################################
Subprog C_MONEND(VALEUR)
Variable Decimal VALEUR
If ([M:ORDB]YEAEND*100)+VALEUR > ([M:ORDB]YEALAS*100)+[M:ORDB]MONLAS
  mkstat = 2
Endif
End
############################################################
Subprog AM_YEAEND(VALEUR)
Variable Decimal VALEUR
[M:ORDB]YEAMONEND = month$([M:ORDB]MONSTR)-num$(VALEUR)
Affzo [M:ORDB]YEAMONEND
End
############################################################
Subprog AM_MONEND(VALEUR)
Variable Decimal VALEUR
[M:ORDB]YEAMONEND = month$(VALEUR)-num$([M:ORDB]YEAEND)
Affzo [M:ORDB]YEAMONEND
End
############################################################
Subprog AV_YEAMONEND(VALEUR)
Variable Char    VALEUR()
VALEUR = month$([M:ORDB]MONEND)-num$([M:ORDB]YEAEND)
End
############################################################
Subprog AM_LASMONFLG(VALEUR)
Variable Integer VALEUR
[M:ORDB]YEAEND = [M:ORDB]YEALAS
[M:ORDB]MONEND = [M:ORDB]MONLAS
[M:ORDB]YEAMONEND = month$([M:ORDB]MONEND)-num$([M:ORDB]YEAEND)
Affzo [M:ORDB]YEAEND
Affzo [M:ORDB]MONEND
Affzo [M:ORDB]YEAMONEND
End
############################################################
Subprog AM_RNDCOD(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:ORDB]RNDVAL = 1
  Affzo [M:ORDB]RNDVAL
  Grizo [M:ORDB]RNDVAL
Else 
  Actzo [M:ORDB]RNDVAL
Endif
End
############################################################
Subprog AV_RNDVAL(VALEUR)
Variable Decimal VALEUR
If [M:ORDB]RNDCOD = 1
  VALEUR = 1
Endif
End
############################################################
Subprog AS_RNDVAL(VALEUR)
Variable Decimal VALEUR
Raz GBOUT1, GBOUT2
If [M:ORDB]RNDCOD = 1
  mkstat = 2
Else
  GBOUT1 = mess(150,198,1)
  GBOUT2 = mess(151,198,1)
Endif
End
############################################################
Subprog B1_RNDVAL(VALEUR)
Variable Decimal VALEUR
VALEUR = [M:ORDB]REOMINQTY
End
############################################################
Subprog B2_RNDVAL(VALEUR)
Variable Decimal VALEUR
VALEUR = [M:ORDB]MFGLOTQTY
End

