#<AdxTL>@(#)0.0.0.0 $Revision$
#MAPAD - 2016-10-26 -
#Handling all properties for SKLMAP_CSTD

$PROPERTIES
Case [L]CURPRO
When "REFERENCENUM"                     : Gosub SKLMAP_REFERENCENUM
When "BUSSUNIT"                         : Gosub SKLMAP_BUSSUNIT
When "CONTACT"                          : Gosub SKLMAP_CONTACT
When "OCONTACT"                         : Gosub SKLMAP_OCONTACT
When "QUANTITY"                         : Gosub SKLMAP_QUANTITY
When "POSITION"                         : Gosub SKLMAP_POSITION






Endcase
Return


$SKLMAP_REFERENCENUM
Case [L]ACTION
  When "CONTROL"
    Gosub SKLMAP_REFERENCENUM_CONTROL
  When "PROPAGATE"
    Gosub SKLMAP_REFERENCENUM_PROPAGATE
Endcase
Return



$SKLMAP_BUSSUNIT
Case [L]ACTION
  When "CONTROL"
    Gosub SKLMAP_BUSSUNIT_CONTROL
  When "PROPAGATE"
    Gosub SKLMAP_BUSSUNIT_PROPAGATE
Endcase
Return

$SKLMAP_CONTACT
Case [L]ACTION
  When "CONTROL"
    Gosub SKLMAP_CONTACT_CONTROL
  When "PROPAGATE"
    Gosub SKLMAP_CONTACT_PROPAGATE
Endcase
Return

$SKLMAP_OCONTACT
Case [L]ACTION
  When "CONTROL"
    Gosub SKLMAP_OCONTACT_CONTROL
  When "PROPAGATE"
    Gosub SKLMAP_OCONTACT_PROPAGATE
Endcase
Return

$SKLMAP_QUANTITY
Case [L]ACTION
  When "INIT"
    Gosub SKLMAP_QUANTITY_INIT
  When "CONTROL"
    Gosub SKLMAP_QUANTITY_CONTROL
  When "PROPAGATE"
    Gosub SKLMAP_QUANTITY_PROPAGATE
Endcase
Return


$SKLMAP_POSITION
Case [L]ACTION
  When "CONTROL"
    Gosub SKLMAP_POSITION_CONTROL
  When "PROPAGATE"
    Gosub SKLMAP_POSITION_PROPAGATE
Endcase
Return


$SKLMAP_CCELL
Case [L]ACTION
  When "INIT"
     Gosub SKLMAP_CCELL_PROPAGATE
  When "PROPAGATE"
    Gosub SKLMAP_CCELL_PROPAGATE
Endcase
Return


$SKLMAP_OCELL
Case [L]ACTION
    When "INIT"
     Gosub SKLMAP_OCELL_PROPAGATE
  When "PROPAGATE"
    Gosub SKLMAP_OCELL_PROPAGATE
Endcase
Return



$SKLMAP_CCELL_PROPAGATE
If this.CCELL <> "" Then
  this.CCELL = "+27" + this.CCELL
Endif
Return


$SKLMAP_OCELL_PROPAGATE
If this.OCELL <> "" Then
  this.OCELL = "+27" + this.OCELL
Endif
Return



$SKLMAP_REFERENCENUM_CONTROL

If this.REFERENCENUM <> "" Then

  Local File EMPLOCTR [CTR]
  Filter [CTR] Where [CTR]CTRNUM = this.REFERENCENUM
  Read [CTR]CTR0 Last

  If (!fstat)
   ASTATUS=fmet this.ASETERROR("",mess(2,11773,1)- ":" -num$(this.REFERENCENUM),[V]CST_AERROR)
  Endif
#
If this.JOBSTAT = 0  Then
   Local File SKLMAP [SKM]
   Filter [SKM] Where [SKM]REFERENCENUM = this.REFERENCENUM
   Read [SKM]SKM0 Last

  If (!fstat)
   ASTATUS=fmet this.ASETERROR("",mess(2,11773,1)- ":" -num$(this.REFERENCENUM),[V]CST_AERROR)
  Endif
   LogicClose File  [SKM]
Endif

 LogicClose File  [CTR]


Else




Endif

Return


$SKLMAP_REFERENCENUM_PROPAGATE

Return

$SKLMAP_BUSSUNIT_CONTROL
Return

$SKLMAP_BUSSUNIT_PROPAGATE

Local File FACILITY [FCY]
Read [FCY]FCY0 = this.BUSSUNIT

Local File BPADDRESS [BPA]
Filter [BPA] Where [F:BPA]BPAADD = [F:FCY]BPAADD and [F:BPA]BPANUM = this.BUSSUNIT
Read [BPA]BPA0 Last

this.COUNTRY=num$([F:BPA]CRY)
this.CITY=num$([F:BPA]CTY)
this.PROVINCE=num$([F:BPA]SAT)

LogicClose File  [BPA]
LogicClose File  [FCY]

Return


$SKLMAP_CONTACT_CONTROL
Return

$SKLMAP_CONTACT_PROPAGATE
Local File EMPLOID [ID]
Local File TABCOUNTRY [TCY]
Local Integer STRTEL
Local Integer ENDTEL
Local Integer LENFORMAT
Local Char PREFIXTEL(100)


Read [ID]ID0 = this.CONTACT
Read [TCY]TCY0 = [F:ID]CRY

If len([F:TCY]TELFMT) > 0 Then
  If len([F:ID]MOB) > 0
    LENFORMAT = len([F:TCY]TELFMT)
    STRTEL = instr(1,[F:TCY]TELFMT,"[")
    ENDTEL = instr(1,[F:TCY]TELFMT,"]")

    ENDTEL = ENDTEL-STRTEL
    PREFIXTEL = mid$([F:TCY]TELFMT,STRTEL+1,ENDTEL-1)
    this.CCELL = PREFIXTEL + [F:ID]MOB
  Endif
Else
 this.CCELL=[F:ID]MOB
Endif

this.CNAME= [F:ID]SRN
this.CSURNAME=[F:ID]NAM
this.CEMAIL=[F:ID]EML

LogicClose File  [ID]

Return


$SKLMAP_OCONTACT_CONTROL
Return

$SKLMAP_OCONTACT_PROPAGATE
Local File EMPLOID [ID]
Local File TABCOUNTRY [TCY]
Local Integer STRTEL
Local Integer ENDTEL
Local Integer LENFORMAT
Local Char PREFIXTEL(100)


Read [ID]ID0 = this.OCONTACT
Read [TCY]TCY0 = [F:ID]CRY

If len([F:TCY]TELFMT) > 0 Then
  If len([F:ID]MOB) > 0
    LENFORMAT = len([F:TCY]TELFMT)
    STRTEL = instr(1,[F:TCY]TELFMT,"[")
    ENDTEL = instr(1,[F:TCY]TELFMT,"]")

    ENDTEL = ENDTEL-STRTEL
    PREFIXTEL = mid$([F:TCY]TELFMT,STRTEL+1,ENDTEL-1)
    this.OCELL = PREFIXTEL + [F:ID]MOB
  Endif
Else
 this.OCELL=[F:ID]MOB
Endif

this.OEMAIL=[F:ID]EML
this.ONAME=[F:ID]SRN
this.OSURNAME=[F:ID]NAM

LogicClose File  [ID]
LogicClose File  [TCY]

Return

$SKLMAP_QUANTITY_INIT
  If this.JOBSTAT = 0 Then
    this.QUANTITY=1
  Endif
Return

$SKLMAP_QUANTITY_CONTROL
Return

$SKLMAP_QUANTITY_PROPAGATE
Return



$SKLMAP_POSITION_CONTROL
Return

$SKLMAP_POSITION_PROPAGATE

Local File POSTE [POT]
Read [POT]POT0 = this.POSITION

this.BUSSUNIT = [F:POT]FCYPOT
#this.JOBSPEC = num$([F:POT]TEX)

Local File CLASSCONV [CCV]
Read [CCV]CCV0 = [F:POT]CCV

this.SALMIN=[F:CCV]SALMIN
this.SALMAX=[F:CCV]SALMAX



LogicClose File  [POT]
LogicClose File  [CCV]

Return

