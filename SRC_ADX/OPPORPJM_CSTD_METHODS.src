#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPORPJM
#######################################################################################
# METHODS                                                                             #
#######################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  SLEVEL = func AFNC.MES1(mess(939,2260,1), this.OPPNUM)
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA)
Return

#######################################################################################
$PROJECT_LAUNCH
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Variable Instance LOGFILE Using C_ALOG : #
#Local Integer ARET_VALUE

  # Preliminary checkes
  If this.TCHACTION <> "LAUNCH" Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR)
  Endif
  If this.OPPSTATE <> 1 Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR)
  Endif
  # -------------------
  If this.OPPMOD = [V]CST_AYES Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(445,2260,1), [V]CST_AERROR)
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    this.OPPSTATE = 2
    If TECOPPACT.EVTDAT = [0/0/0] Then
      this.OPPDATLA = date$
    Else
      this.OPPDATLA = TECOPPACT.EVTDAT
    Endif
    this.OPPCOMTEX = TECOPPACT.COMTEX
    # -------------------
    [L]ARET_VALUE = fmet this.BUD_ENABLE_ALL()
    # -------------------
  Endif
Return

#######################################################################################
$PROJECT_DELIVERY
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Variable Instance LOGFILE Using C_ALOG : #
#Local Integer ARET_VALUE

  # Preliminary checkes
  If this.TCHACTION <> "DELIVERY" Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR)
  Endif
  If this.OPPSTATE <> 1 and this.OPPSTATE <> 2 Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR)
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    this.OPPSTATE = 3
    If TECOPPACT.EVTDAT = [0/0/0] Then
      this.OPPDATLV = date$
    Else
      this.OPPDATLV = TECOPPACT.EVTDAT
    Endif
    this.OPPCOMTEX = TECOPPACT.COMTEX
    # -------------------
    [L]ARET_VALUE = fmet this.BUD_ENABLE_ALL()
    # -------------------
  Endif
Return

#######################################################################################
$PROJECT_CLOSING
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Variable Instance LOGFILE Using C_ALOG : #
#Local Integer ARET_VALUE

Local Integer IRET
Local Integer NI

  # Preliminary checkes
  If this.TCHACTION <> "CLOSING" Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR)
  Endif
  # -------------------
  If this.OPPSTATE = 4 Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR)
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    this.OPPSTATE = 4
    If TECOPPACT.EVTDAT = [0/0/0] Then
      this.OPPDATS = date$
    Else
      this.OPPDATS = TECOPPACT.EVTDAT
    Endif
    this.OPPCOMTEX = TECOPPACT.COMTEX
    # -------------------
    # Issue X3-101833 - 2018-08-02 by FGR : BEGIN
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS_RITT_CLOSE_RELEASE_UNDER(AVOID.ACHAR, AVOID.ACHAR))
    # Issue X3-101833 - 2018-08-02 by FGR : END
    # -------------------
    For NI = 1 To maxtab(this.BUD)
      If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.BUD(NI).PBUSTATE <> 4 Then
          IRET = fmet this._BUD_CLOSING(this.BUD(NI).PBUCOD, LOGFILE, TECOPPACT)
          [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
        Endif
      Endif
    Next NI
    # -------------------
    For NI = 1 To maxtab(this.TAS)
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.TAS(NI).TASSTATE <> 4 Then
          IRET = fmet this._TAS_CLOSING(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT)
          [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
        Endif
      Endif
    Next NI
  Endif
Return

#######################################################################################
$PROJECT_SUSPENSION
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Variable Instance LOGFILE Using C_ALOG : #
#Local Integer ARET_VALUE

Local Integer NI

  # Preliminary checkes
  If this.TCHACTION <> "SUSPENSION" Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR)
    Return
  Endif
  # -------------------
  If this.OPPSTATE <> 2 and this.OPPSTATE <> 3 Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR)
  Endif
  # -------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    this.OPPSTATE = 9
    If TECOPPACT.EVTDAT = [0/0/0] Then
      this.OPPDATTH = date$
    Else
      this.OPPDATTH = TECOPPACT.EVTDAT
    Endif
    this.OPPCOMTEX = TECOPPACT.COMTEX
    # -------------------
    For NI = 1 To maxtab(this.BUD)
      If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.BUD(NI).PBUSTATE <> 4 and this.BUD(NI).PBUSTATE <> 9 Then
          IRET = fmet this._BUD_SUSPENSION(this.BUD(NI).PBUCOD, LOGFILE, TECOPPACT)
          [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
        Endif
      Endif
    Next NI
    # -------------------
    For NI = 1 To maxtab(this.TAS)
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.TAS(NI).TASSTATE <> 4 and this.TAS(NI).TASSTATE <> 9 Then
          IRET = fmet this._TAS_SUSPENSION(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT)
          [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
        Endif
      Endif
    Next NI
  Endif
Return

#######################################################################################
$PROJECT_REACTIVATE
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Variable Instance LOGFILE Using C_ALOG : #
#Local Integer ARET_VALUE

Local Integer NI
Local Integer IRET

  # Preliminary checkes
  If this.TCHACTION <> "REACTIVATE" Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR)
    Return
  Endif
  If this.OPPSTATE <> 4 and this.OPPSTATE <> 9 Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(202,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR)
    Return
  Endif
  # -------------------
  If this.OPPDATLV <> [0/0/0] Then
    # Become "Delivred"
    this.OPPSTATE = 3
  Elsif this.OPPDATLA <> [0/0/0] Then
    # Become "Launched"
    this.OPPSTATE = 2
  Else
    # Become "New"
    this.OPPSTATE = 1
  Endif
  For NI = 1 To maxtab(this.BUD)
    If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.snapshot.OPPSTATE = 4 Then
        If this.BUD(NI).PBUSTATE = 4 Then
          # if the budget is closed...
          If this.BUD(NI).PBUDATS = this.snapshot.OPPDATS Then
            # ...at the same date than the project : the budget is reactivate
            IRET = fmet this._BUD_REACTIVATE(this.BUD(NI).PBUCOD, LOGFILE, TECOPPACT)
            [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
          Endif
        Endif
      Elsif this.snapshot.OPPSTATE = 9 Then
        If this.BUD(NI).PBUSTATE = 9 Then
          # if the budget is closed...
          If this.BUD(NI).PBUDATH = this.snapshot.OPPDATTH Then
            # ...at the same date than the project : the budget is reactivate
            IRET = fmet this._BUD_REACTIVATE(this.BUD(NI).PBUCOD, LOGFILE, TECOPPACT)
            [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
          Endif
        Endif
      Endif
    Endif
  Next NI
  # -------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.snapshot.OPPSTATE = 4 Then
        If this.TAS(NI).TASSTATE = 4 Then
          # if the task is closed...
          If this.TAS(NI).TASDATS = this.snapshot.OPPDATS Then
            # ...at the same date than the project : the task is reactivate
            IRET = fmet this._TAS_REACTIVATE(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT)
            [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
          Endif
        Endif
      Elsif this.snapshot.OPPSTATE = 9 Then
        If this.TAS(NI).TASSTATE = 9 Then
          # if the task is closed...
          If this.TAS(NI).TASDATH = this.snapshot.OPPDATTH Then
            # ...at the same date than the project : the task is reactivate
            IRET = fmet this._TAS_REACTIVATE(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT)
            [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
          Endif
        Endif
      Endif
    Endif
  Next NI
  this.OPPCOMTEX = TECOPPACT.COMTEX
Return

#######################################################################################
$PROJECT_PROPAGATE_OPPSTATE
#Local Integer ARET_VALUE

Local Integer NI

  If this.OPPSTATE <> this.snapshot.OPPSTATE Then
    # -------------------
    For NI = 1 To maxtab(this.BUD)
      If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.BUD(NI).PIMPL.OPPSTATE <> this.OPPSTATE Then
          If this.BUD(NI).TCHACTION = AVOID.ACHAR Then
            this.BUD(NI).TCHACTION = "STATUS"
          Endif
          this.BUD(NI).PIMPL.TCHACTION = "STATUS"
          this.BUD(NI).PIMPL.OPPSTATE = this.OPPSTATE
        Endif
      Endif
    Next NI
    # -------------------
    For NI = 1 To maxtab(this.TAS)
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.TAS(NI).PIMPL.OPPSTATE <> this.OPPSTATE Then
          If this.TAS(NI).TCHACTION = AVOID.ACHAR Then
            this.TAS(NI).TCHACTION = "STATUS"
          Endif
          this.TAS(NI).PIMPL.TCHACTION = "STATUS"
          this.TAS(NI).PIMPL.OPPSTATE = this.OPPSTATE
        Endif
      Endif
    Next NI
  Endif
Return

#######################################################################################
$PROJECT_PROPAGATE_PBUSTATE
#Value Char BUDGET ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1
Local Integer ILINE

  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  If ILINE > 0 Then
    If this.BUD(ILINE).PBUSTATE <> this.BUD(ILINE).snapshot.PBUSTATE Then
      # -------------------
      NI = find(this.BUD(ILINE).PBUCOD, this.TAS(1..maxtab(this.TAS)).PBUCOD)
      While NI > 0
        If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.TAS(NI).PIMPL.PBUSTATE <> this.BUD(ILINE).PBUSTATE Then
            If this.TAS(NI).TCHACTION = AVOID.ACHAR Then
              this.TAS(NI).TCHACTION = "STATUS"
            Endif
            this.TAS(NI).PIMPL.TCHACTION = "STATUS"
            this.TAS(NI).PIMPL.PBUSTATE = this.BUD(ILINE).PBUSTATE
          Endif
        Endif
        NI1 = NI
        NI = find(this.BUD(ILINE).PBUCOD, this.TAS(NI+1..maxtab(this.TAS)).PBUCOD)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
  Endif
Return

#######################################################################################
$CDIE_INSERT
Local Integer NI
Local Integer I_DIECOL
Local Integer I_LED
Local Integer I_DIE
Local Integer I_FCY
Local Char L_CPY(GLONCPY)
Local Char L_FCY(GLONFCY)
Local Integer IPJTAUTCRE
Local Integer RNBRLED
Local Tinyint RLEDTYP(1..len(mess(0,2644,1)))
Local Char    RLEDCOD(GLONLED)(1..len(mess(0,2644,1)))
Local Char    RLEDCUR(GLONCUR)(1..len(mess(0,2644,1)))
Local Char    RCOA(GLONCOA)(1..len(mess(0,2644,1)))
Local Char    RCOAFMT(15)(1..len(mess(0,2644,1)))
Local Char    RCOACOLHEA(15)(1..len(mess(0,2644,1)))
Local Integer RNBRDIE
Local Char    RDIE(GLONDIE)(1..max(1,GOPTCANA))
Local Char    RDIEFMT(15)(1..max(1,GOPTCANA))
Local Char    RDIECOLHEA(15)(1..max(1,GOPTCANA))
Local Integer RDIEOBYFLG(1..max(1,GOPTCANA))
Local Char    RERRMES(250)
Local Integer BFND

  MAXFLD = 5

Local Char LCODFLD(GLONAVA)(1..MAXFLD)
Local Char LVALFLD(type(this.APARENT.PIMPL.PIMDESAXX)-10)(1..MAXFLD)
Local Integer IRET

  If this.TCHREPDIECCE = [V]CST_AYES Then
    Local File GLED [LED]
    Local File GDIE [DIE]
    Local File CACCE [CCE]
    # -------------------
    I_FCY = fmet this.ACTX.ACACHE.AFCY.AGETINDEX(this.SALFCY)
    If I_FCY <> [V]CST_ANOTDEFINED Then
      L_CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.SALFCY, "LEGCPY")
    Endif
    IPJTAUTCRE = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, L_CPY, "PJTAUTCRE")
    If find(IPJTAUTCRE,[V]CST_ANO,[V]CST_AYES) = 0 Then
      IPJTAUTCRE = [V]CST_AYES         # Confirmation / Toujours
    Endif
    # -------------------
    If func FINACM_SYRA.GET_FINSTC(this.ACTX, L_CPY, 2, RNBRLED, RLEDTYP, RLEDCOD, RLEDCUR, RCOA, RCOAFMT, RCOACOLHEA, RNBRDIE, RDIE, RDIEFMT, RDIECOLHEA, RDIEOBYFLG, RERRMES) = [V]CST_AOK Then
      # Récupération du référentiel Gérée à l'affaire
      BFND = [V]CST_AFALSE
      For I_LED = 1 To RNBRLED
        Call LEC_LED(RLEDCOD(I_LED)) From CPTLEC
        If [F:LED]PJMFLG = [V]CST_AYES Then
          BFND = [V]CST_ATRUE          # Référentiel Flagué Gestion à l'affaire
          Break
        Endif
      Next I_LED
      BPJMFND = [V]CST_AFALSE
      If BFND = [V]CST_ATRUE Then
        # Récupération de l'axe géré à l'affaire
        If func FINCCE_SYRA.GET_DIELST(this.ACTX, L_CPY, RLEDTYP(I_LED), RNBRDIE, RDIE, RERRMES) = [V]CST_AOK Then
          For I_DIE = 1 To RNBRDIE
            Call LEC_DIE(RDIE(I_DIE)) From CPTLEC
            If [F:DIE]PJMFLG = [V]CST_AYES Then
              BPJMFND = [V]CST_ATRUE   # Axe flagué Gestion à l'affaire
              Break
            Endif
          Next I_DIE
        Endif
      Endif
      #--
      If BPJMFND = [V]CST_ATRUE Then
        Call LEC_CCE(this.OPPNUM, RDIE(I_DIE)) From CPTLEC
        If fstat Then
          # Trouver l'indice de RDIE(I_DIE) dans la collection
          For NI = 1 To maxtab(this.CDIE)
            If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
              If this.CDIE(NI).DIE = RDIE(I_DIE) Then
                I_DIECOL = NI
                Break
              Endif
            Endif
          Next NI
          #
          If I_DIECOL > 0 and this.CDIE(I_DIECOL).CCE = "" Then
            If this.OPPNUM = vireblc(format$([F:DIE]CCEFMT,this.OPPNUM),1) Then
              L_FCY = fmet this.CDIE_SITE()
              Raz LCODFLD
              Raz LVALFLD
              LCODFLD(1) = "DES"
              LVALFLD(1) = this.APARENT.PIMPL.PIMDESAX1  # FGR/LSEY 12/08/2016 : this.OPPNUM
              LCODFLD(2) = "FCY"
              LVALFLD(2) = L_FCY
              LCODFLD(3) = "ENAFLG"
              LVALFLD(3) = num$(2)
              LCODFLD(4) = "DESSHO"
              LVALFLD(4) = this.APARENT.PIMPL.PIMDESAX1   # FLORENT ICI voir pour ne pas utiliser APARENT
              LCODFLD(5) = "IPT"
              LVALFLD(5) = num$(2)
              IRET = func FINCCE_SYRA.CRE_CCE(this.ACTX, "C", RDIE(I_DIE), this.OPPNUM, LCODFLD, LVALFLD, RERRMES)
              If IRET <> [V]CST_AOK Then
                [L]ARET_VALUE = fmet this.SETERROR("", RERRMES, IRET)
              Else
                this.CDIE(I_DIECOL).CCE = this.OPPNUM
              Endif
            Else
              [L]ARET_VALUE = fmet this.SETERROR("CCE", func AFNC.MES2(mess(442,2260,1), this.CDIE(I_DIECOL).DIE, this.OPPNUM), [V]CST_AWARNING)
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

#######################################################################################
$CDIE_UPDATE
Local Integer NI
Local Integer MAXFLD
Local Char RERRMES(250)

  MAXFLD = 4

Local Char LCODFLD(GLONAVA)(1..MAXFLD)
Local Char LVALFLD(type(this.APARENT.PIMPL.PIMDESAXX)-10)(1..MAXFLD)
Local Integer IRET

  Local File GDIE [DIE]
  # -------------------
  For NI = 1 To maxtab(this.CDIE)
    If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      Call LEC_DIE(this.CDIE(NI).DIE) From CPTLEC
      If [F:DIE]PJMFLG = [V]CST_AYES Then
        # Axe flagué Gestion à l'affaire
        If this.CDIE(NI).CCE = this.OPPNUM Then
          Raz LCODFLD
          Raz LVALFLD
          LCODFLD(1) = "DES"
          LVALFLD(1) = this.APARENT.PIMPL.PIMDESAX1  # FGR/LSEY 12/08/2016 : this.OPPNUM
          LCODFLD(2) = "DESSHO"
          LVALFLD(2) = this.APARENT.PIMPL.PIMDESAX1  # FLORENT ICI voir pour ne pas utiliser APARENT
          IRET = func FINCCE_SYRA.CRE_CCE(this.ACTX, "U", this.CDIE(NI).DIE, this.OPPNUM, LCODFLD, LVALFLD, RERRMES)
          If IRET <> [V]CST_AOK Then
            [L]ARET_VALUE = fmet this.SETERROR("", RERRMES, IRET)
          Endif
        Endif
        Break
      Endif
    Endif
  Next NI
Return

#######################################################################################
$CDIE_DELETE
Local Integer NI
Local Integer NE
Local Integer IOKANU
Local Instance ZCACCE Using C_CACCE

  # Issue X3-3500 - 2018-07-18 by FGR
  NE = 0
  Local File GDIE [DIE]
  # -------------------
  For NI = 1 To maxtab(this.CDIE)
    If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ANEW,[V]CST_AUPD) = 0 Then
      Call LEC_DIE(this.CDIE(NI).DIE) From CPTLEC
      If [F:DIE]PJMFLG = [V]CST_AYES Then
        # Axe flagué Gestion à l'affaire
        If this.CDIE(NI).CCE = this.OPPNUM Then
          # Deletion only if section value is the same than project code
          NE = NI
        Endif
        Break
      Endif
    Endif
  Next NI
  If NE > 0 Then
    # Section deletion
    ZCACCE = NewInstance C_CACCE AllocGroup null
    IOKANU = fmet ZCACCE.AREAD(this.CDIE(NE).DIE, this.CDIE(NE).CCE)
    If IOKANU < [V]CST_AERROR Then
      IOKANU = fmet ZCACCE.ADELETE()
      If IOKANU < [V]CST_AERROR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES2(mess(1104,2260,1), this.CDIE(NE).DIE, this.CDIE(NE).CCE), [V]CST_AWARNING))
      Else
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES2(mess(1105,2260,1), this.CDIE(NE).DIE, this.CDIE(NE).CCE), [V]CST_AWARNING))
      Endif
    Endif
    FreeGroup ZCACCE
  Endif
Return

#######################################################################################
$CDIE_SITE
Local Integer L_UPDFCYCCE

  # -------------------
  L_UPDFCYCCE = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "UPDFCYCCE")
  If find(L_UPDFCYCCE,[V]CST_ANO,[V]CST_AYES) = 0 Then
    L_UPDFCYCCE = [V]CST_AYES  # Oui par défaut
  Endif
  # -------------------
  Raz [L]ARET_VALUE
  If L_UPDFCYCCE = [V]CST_AYES Then
    [L]ARET_VALUE = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.SALFCY, "FINRSPFCY")
  Endif
Return

