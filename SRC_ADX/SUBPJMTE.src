#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE               From SUBPJMTEA
    When "DEBUT"        : Gosub DEBUT               From SUBPJMTEA
    When "FERME"        : Gosub FERME               From SUBPJMTEA
    When "END"          : Gosub CLEARFIELDS         From SUBPJMTEA
    When "APRES_MODIF"  : Gosub APRES_MODIF         From SUBPJMTEA
    When "ABA"          : Gosub ABANDON             From SUBPJMTEA
    When "SETBOUT"      : Gosub SETBOUT             From SUBPJMTEA
    When "BOUTON"       : Gosub BOUTON              From SUBPJMTEA
    When "ENR"          : Gosub ENR                 From SUBPJMTEA
    #
    When "BS_OPPNUM"    : Gosub BS_OPPNUM
    When "BS_TASCOD"    : Gosub BS_TASCOD
    When "BB1_NBLIG"    : Gosub BB1_NBLIG
    When Default
  Endcase
Return

###################################################################################################
$BS_OPPNUM
Global Integer BS_OPPNUM   # To know that I'm coming from the selection list

  # Issue X3-85806 - 2018-06-07 by FGR : BEGIN : If selected value is on the same project AM_OPPNUM is not called
  If VALEUR = [M:PTED]OPPNUM(nolign-1) Then
    Call AM_OPPNUM(VALEUR)
  Endif
  # Issue X3-85806 - 2018-06-07 by FGR : END
Return

###################################################################################################
$BS_TASCOD
Global Integer BS_TASCOD   # To know that I'm coming from the selection list

  # Issue X3-85806 - 2018-06-07 by FGR : BEGIN : If selected value is on the same task AM_TASCOD is not called
  If VALEUR = [M:PTED]TASCOD(nolign-1) Then
    Call AM_TASCOD(VALEUR)
  Endif
  # Issue X3-85806 - 2018-06-07 by FGR : END
Return

###################################################################################################
$BB1_NBLIG
  Gosub SEARCH From SUBPJMTEA
Return

###################################################################################################
# Screens fields
###################################################################################################
# PTEH
###################################################################################################
Subprog AM_CLB(VALEUR)
Variable Char    VALEUR()

  Effzo [M:PTED]1-99
  Effzo [M:PTEAFF]1-99
  # -----------------------------
  [M:PTEH]CLB = VALEUR
  # -----------------------------
  If GZINSPJMTH <> null Then
    FreeGroup GZINSPJMTH
    Raz GZINSPJMTH
  Endif
  # -----------------------------
  Call INIT_GZINSPJMTH(GZINSPJMTH) From SUBPJMTEA
  # -----------------------------
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Endif
  # -----------------------------
  Call LECTEXTRA([M:PTEH]PTENAM,"AUTILIS","INTUSR",VALEUR,"") From ATEXTRA
  Call LOAD_ASSIGNMENTS From SUBPJMTEA
  Call DISPLAY_WITH_STYLE() From SUBPJMTEA
  Affzo [M:PTEAFF]1-99
End

###################################################################################################
Subprog C_TSDATE(VALEUR)
Variable Date    VALEUR

  If VALEUR <> [0/0/0] and [M:PTEH]TEDATE <> [0/0/0] and VALEUR > [M:PTEH]TEDATE Then
    GMESSAGE = func AFNC.MES1(mess(58,2260,1), format$(GFMDAT,[M:PTEH]TSDATE))
    mkstat= 2
    End
  Endif
  If VALEUR <> [0/0/0] and [M:PTEH]TEDATE = [0/0/0] Then
    [M:PTEH]TEDATE = VALEUR
  Endif
End

###################################################################################################
Subprog C_TEDATE(VALEUR)
Variable Date    VALEUR

  If VALEUR <> [0/0/0] and VALEUR < [M:PTEH]TSDATE and [M:PTEH]TSDATE <> [0/0/0]
    GMESSAGE = func AFNC.MES1(mess(59,2260,1), format$(GFMDAT,[M:PTEH]TEDATE))
    mkstat= 2
    End
  Endif
End

###################################################################################################
# PTED
###################################################################################################
Subprog C_NBLIG
Local Integer IRET
Local Integer ILINE

  If status = 82 or status = 73 Then
    # Insert a line
    ILINE = fmet GZINSPJMTH.ADDLINE("TIMENT", [V]CST_ALASTPOS)
    If ILINE <> [V]CST_ANOTDEFINED Then
      Call SHOW_TIMENT_LINE(ILINE) From SUBPJMTEA
    Else
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJMTH)
      [L]IRET = fmet GZINSPJMTH.PTE_RESET_ERRORS()
      GERR = 4
      mkstat = 2
      GOK = 1
      End
    Endif
  Elsif status = 65 Then
    # Delete a line
    If [M:PTEH]OPPNUM = AVOID.ACHAR and [M:PTEH]TSDATE = [0/0/0] and [M:PTEH]TEDATE = [0/0/0] and [M:PTEH]STAVAL = [V]CST_ANO Then
      IRET = fmet GZINSPJMTH.ADELLINE("TIMENT", GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).AORDER)
    Else
      ILINE = fmet GZINSPJMTH.TIMENT_GET_INDEX([M:PTED]PTESEQ(nolign-1))
      IRET = fmet GZINSPJMTH.ADELLINE("TIMENT", GZINSPJMTH.TIMENT(ILINE).AORDER)
    Endif
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJMTH)
      [L]IRET = fmet GZINSPJMTH.PTE_RESET_ERRORS()
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

###################################################################################################
Subprog AV_NBLIG
  # Issue X3-99928 - 2018-08-24 by FGR : BEGIN : needed for Authorizations
  If nolign > 0 Then
    GFCY = [M:PTED]FCY(nolign-1)
  Endif
  # Issue X3-99928 - 2018-08-24 by FGR : END
  # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  #If [M:PTEDIE]SEARCH <> [V]CST_AYES and [M:PTED]COLLIN(nolign-1) > 0 Then                         # Issue X3-99928 - 2018-08-24 by FGR
  If [M:PTEDIE]SEARCH <> [V]CST_AYES and nolign > 0 and [M:PTED]COLLIN(nolign-1) > 0 Then           # Issue X3-99928 - 2018-08-24 By FGR
    Call SHOW_CDIE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
  Endif
End

###################################################################################################
Subprog AM_PTEDAT(VALEUR)
Variable Date    VALEUR

  GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEDAT = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
  If GERR = 1 Then
    GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEDAT = GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).snapshot.PTEDAT
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
  Endif
End

###################################################################################################
Subprog AM_PTEQTY(VALEUR)
Variable Decimal VALEUR

  GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEQTY = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
  If GERR = 1 Then
    GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEQTY = GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).snapshot.PTEQTY
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
  Endif
End

###################################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

Local Integer IRET

  If dim(BS_OPPNUM) >= 0 Then
    If [M:PTED]TASCOD(nolign-1) <> AVOID.ACHAR Then
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).TASCOD
      GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMTASCOD = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GZINSPJMTH.ACTX, VALEUR, [M:PTED]TASCOD(nolign-1))
      If [M:PTED]OPENUM(nolign-1) <> 0 Then
        GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPENUM = [M:PTED]OPENUM(nolign-1)
      Else
        Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPENUM
        Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPESPLNUM
        Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).POANUM
      Endif
      Diszo [M:PTED]PBUCOD(nolign-1)
      IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_PJMPCC(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMPCC)
      IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_PTEUOM(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEUOM)
      IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_CLBPCC(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBPCC)
      Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
      If GERR = 1 Then
        GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMTASCOD = GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).snapshot.PIMTASCOD
        GERR = 1
        mkstat = 2
        End
      Endif
      [M:PTED]OPPNUM(nolign-1) = VALEUR
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPPNUM
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).TASCOD
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PBUCOD
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMCST
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBCST
      Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
      Affzo [M:PTED]1-99
      zonsui = "[M:PTED]PTEUOM(" + num$(indice) + ")"
    Elsif [M:PTED]PBUCOD(nolign-1) <> AVOID.ACHAR Then
      Actzo [M:PTED]PBUCOD(nolign-1)
      GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMPBUCOD = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GZINSPJMTH.ACTX, VALEUR, [M:PTED]PBUCOD(nolign-1))
      IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_PJMPCC(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMPCC)
      IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_PTEUOM(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEUOM)
      IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_CLBPCC(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBPCC)
      Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
      If GERR = 1 Then
        GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMPBUCOD = GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).snapshot.PIMPBUCOD
        GERR = 1
        mkstat = 2
        End
      Endif
      [M:PTED]OPPNUM(nolign-1) = VALEUR
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPPNUM
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMTASCOD
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).TASCOD
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPENUM
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPESPLNUM
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).POANUM
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMCST
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBCST
      Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
      Affzo [M:PTED]1-99
      zonsui = "[M:PTED]PTEUOM(" + num$(indice) + ")"
    Else
      [M:PTED]OPPNUM(nolign-1) = VALEUR
      Actzo [M:PTED]PBUCOD(nolign-1)
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPPNUM
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMTASCOD
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).TASCOD
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMPBUCOD
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PBUCOD
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPENUM
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPESPLNUM
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).POANUM
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).FCY
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CUR
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMPCC
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBPCC
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEUOM
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMCST
      Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBCST
      Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
      Affzo [M:PTED]1-99
    Endif
    Kill BS_OPPNUM
  Else
    [M:PTED]OPPNUM(nolign-1) = VALEUR
    Actzo [M:PTED]PBUCOD(nolign-1)
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPPNUM
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMTASCOD
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).TASCOD
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMPBUCOD
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PBUCOD
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPENUM
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPESPLNUM
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).POANUM
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).FCY
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CUR
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMPCC
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBPCC
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEUOM
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMCST
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBCST
    Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
    Affzo [M:PTED]1-99
  Endif
End

###################################################################################################
Subprog AM_TASCOD(VALEUR)
Variable Char    VALEUR()

Local Integer IRET
Local Char SMESSAGE(250)     # Issue X3-85806 - 2018-06-04 by FGR

  If VALEUR <> AVOID.ACHAR Then
    GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMTASCOD = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GZINSPJMTH.ACTX, [M:PTED]OPPNUM(nolign-1), VALEUR)
    IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_PJMPCC(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMPCC)
    IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_PTEUOM(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEUOM)
    IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_CLBPCC(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBPCC)
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
    If GERR = 1 Then
      GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMTASCOD = GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).snapshot.PIMTASCOD
      GERR = 1
      mkstat = 2
      End
    Endif
    Diszo [M:PTED]PBUCOD(nolign-1)
    [M:PTED]PBUCOD(nolign-1) = func PJMTSK_CSTD_PROGS.GET_PBUCOD(GZINSPJMTH.ACTX, [M:PTED]OPPNUM(nolign-1), VALEUR, SMESSAGE)  # Issue X3-85806 - 2018-06-04 by FGR
    # -----------------------------
    If dim(BS_TASCOD) >= 0 Then
      If [M:PTED]OPENUM(nolign-1) <> 0 Then
        GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPENUM = [M:PTED]OPENUM(nolign-1)
        [M:PTED]TASCOD(nolign-1) = VALEUR
        Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
        zonsui = "[M:PTED]PTEUOM(" + num$(indice) + ")"
      Else
        [M:PTED]TASCOD(nolign-1) = VALEUR
        Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
      Endif
      Kill BS_TASCOD
    Else
      [M:PTED]TASCOD(nolign-1) = VALEUR
      Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
    Endif
  Else
    [M:PTED]TASCOD(nolign-1) = VALEUR
    IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CDIE_DELETE()
    Actzo [M:PTED]PBUCOD(nolign-1)
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMTASCOD
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).TASCOD
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMPBUCOD
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PBUCOD
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPENUM
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPESPLNUM
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).POANUM
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PBUCOD
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).FCY
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CUR
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMPCC
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBPCC
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEUOM
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMCST
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBCST
    Raz GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CHGTYP
    Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
    Affzo [M:PTED]1-99
  Endif
End

###################################################################################################
Subprog AM_OPENUM(VALEUR)
Variable Decimal VALEUR

Local Integer IRET

  GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPENUM = VALEUR
  IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_PTEUOM(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEUOM)
  IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_PJMPCC(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMPCC)
  IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_CLBPCC(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBPCC)
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
  If GERR = 1 Then
    GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).OPENUM = GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).snapshot.OPENUM
    GERR = 1
    mkstat = 2
    End
  Else
    [M:PTED]OPENUM(nolign-1) = VALEUR
    Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
  Endif
End

###################################################################################################
Subprog AM_PBUCOD(VALEUR)
Variable Char    VALEUR()

Local Integer IRET

  GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMPBUCOD = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GZINSPJMTH.ACTX, [M:PTED]OPPNUM(nolign-1), VALEUR)
  IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_PJMPCC(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PJMPCC)
  IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_PTEUOM(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PTEUOM)
  IRET = fmet GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).GET_CLBPCC(GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CLBPCC)
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
  If GERR = 1 Then
    GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).PIMPBUCOD = GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).snapshot.PIMPBUCOD
    GERR = 1
    mkstat = 2
    End
  Else
    [M:PTED]PBUCOD(nolign-1) = VALEUR
    Call SHOW_TIMENT_LINE([M:PTED]COLLIN(nolign-1)) From SUBPJMTEA
  Endif
End

###################################################################################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()

  GZINSPJMTH.TIMENT([M:PTED]COLLIN(nolign-1)).CUR = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJMTH) From SUBPJMTEA
  If GERR = 1 Then
