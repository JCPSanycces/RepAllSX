#<AdxTL>@(#)7.0.0.0 $Revision$
###########################################################################
# Henri Combet                         S C A L E L I B         GPAO  2001 #
# Pilotage du poste de pesée graphique                         GPAO  2001 #
###########################################################################
Subprog SCALEENGINE
Local Char    SCALEFILE(200)
Local Char    PARAMFILE(200)
Local Char    CALIGUIDEFILE(200)
Local Char    PLANPESE(200)
Local Char    PHASES(200)
Local Char    COMPOSANTS(200)
Local Char    FICHISM(200)
Local Char    ALLOCATIONS(200)
Local Char    CONTAINERS(200)
Local Char    COEFFILE(200)
Local Char    FICTRACE(200)

Local Char    NUMOF(GLONVCR)    # 57505 mm 08.09
Local Integer LOPT1 : LOPT1 = 0
Local Char    LFONC : LFONC = GFONC1

# 99508 mm 11.2014 - License management V7
If GBROWS = 0 & GADONIX = 2
  LOPT1 = 1
Else
  Gosub TRT_DEB From OPTLIB
Endif

If !LOPT1
    Call ERREUR(mess(192,193,1)) From GESECRAN
    End
Endif

# pour gestion des erreurs dans le fichier trace X3Scales.tra    sur le serveur
#                                               X3SCALESTRA.csv sur le serveur
#GSERVEUR = 1
Local Integer TRA   : TRA = 0
Local Char    TIT
TIT = mess(25,2324,1)
TRA=0
Call OUVRE_TRACE(TIT) From LECFIC

# ouverture tables
If clalev([F:SLE])  <= 0 : Local File SCALES     [SLE]  : Endif
If clalev([F:STX])  <= 0 : Local File STATION    [STX]  : Endif
If clalev([F:SBX])  <= 0 : Local File STATIONBOX [SBX]  : Endif
If clalev([F:CGD])  <= 0 : Local File CALIGUIDES [CGD]  : Endif
If clalev([F:HSH])  <= 0 : Local File HANDLING   [HSH]  : Endif
If clalev([F:HSR])  <= 0 : Local File HANDLINGR  [HSR]  : Endif
If clalev([F:TKS])  <= 0 : Local File TANKS      [TKS]  : Endif
If clalev([F:TGT])  <= 0 : Local File TANKSGATES [TGT]  : Endif
If clalev([F:CTN])  <= 0 : Local File CONTAINERS [CTN]  : Endif

If clalev([F:CBT])  <= 0 : Local File CALIBRAT   [CBT]  : Endif
If clalev([F:MWA])  <= 0 : Local File MWMCRDASW  [MWA]  : Endif

If clalev([F:ITM])  <= 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITF])  <= 0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:ITG])  <= 0 : Local File ITMCATEG   [ITG]  : Endif

If clalev([F:MFG])  <= 0 : Local File MFGHEAD    [MFG]  : Endif
If clalev([F:MFI])  <= 0 : Local File MFGITM     [MFI]  : Endif
If clalev([F:MFM])  <= 0 : Local File MFGMAT     [MFM]  : Endif
If clalev([F:MFO])  <= 0 : Local File MFGOPE     [MFO]  : Endif
If clalev([F:MKM])  <= 0 : Local File MFGMATTRK  [MKM]  : Endif
If clalev([F:ORD])  <= 0 : Local File ORDERS     [ORD]  : Endif
If clalev([F:XMFM]) <= 0 : Local File MFGMAT     [XMFM] : Endif

If clalev([F:STL])  <= 0 : Local File STOLOT     [STL]  : Endif
If clalev([F:SLF])  <= 0 : Local File STOLOTFCY  [SLF]  : Endif
If clalev([F:STO])  <= 0 : Local File STOCK      [STO]  : Endif
If clalev([F:STA])  <= 0 : Local File STOALL     [STA]  : Endif
If clalev([F:STJ])  <= 0 : Local File STOJOU     [STJ]  : Endif


If clalev([F:ADI])  <= 0 : Local File ATABDIV    [ADI]  : Endif
If clalev([F:TST])  <= 0 : Local File TABSTASTO  [TST]  : Endif
If clalev([F:AUS])  <= 0 : Local File AUTILIS    [AUS]  : Endif
If clalev([F:ACC])  <= 0 : Local File ACCES      [ACC]  : Endif
If clalev([F:TCO])  <= 0 : Local File TABCOEFF   [TCO]  : Endif
If clalev([F:TFO])  <= 0 : Local File TABFOR     [TFO]  : Endif
If clalev([F:SRU])  <= 0 : Local File TABSTORUL  [SRU]  : Endif
If clalev([F:TRU])  <= 0 : Local File TABALLRUL  [TRU]  : Endif
If clalev([F:BTS])  <= 0 : Local File BENCHTRS   [BTS]  : Endif
If clalev([F:CUT])  <= 0 : Local File TABCABCUT  [CUT]  : Endif   # 83201 mm 10.2014
If clalev([F:MODL]) <= 0 : Local File MODSCALE   [MODL] : Endif   # 114545 mm 09.2016


# lecture BTS suivant transaction du parametre GWEITRSNUM
Read [F:BTS]BTS0 = 61;GWEITRSNUM
If fstat : Call ERREUR(mess(23,2324,1)) From GESECRAN : OK=0 : End : Endif


# EXTRACTION initiale des données
Gosub XTRACT_DATA

# transfert des données sur le client
Gosub TRF_FILES

# appel poste graphique
Call X3SCALES From ILOGLIB
GSERVEUR = 0

Gosub TRT_END From OPTLIB

End

###########################################################################
$XTRACT_DATA
###########################################################################
#X3-85848.so - commented out below to accomodate new process
# Call XTRACT_INITIAL (NUMOF) From SCALEXCHAN
# Call XTRACT_NUMOF (NUMOF, "null")   From SCALEXCHAN
#X3-85848.sn

Local Shortint EXPITM     #X3-85848.n - Added for below call

  Call XTRACT_INITIAL (NUMOF, "null") From SCALEXCHAN    #X3-85848.sn - added for new process
Return

########################################################################
$TRF_FILES
########################################################################
     Call TRF_TCO  From SCALEXCHAN
     Call TRF_PAR  From SCALEXCHAN
     Call TRF_SLE  From SCALEXCHAN
     Call TRF_CGD  From SCALEXCHAN
     Call TRF_MWG  From SCALEXCHAN
     Call TRF_PHA  From SCALEXCHAN
     Call TRF_MAT  From SCALEXCHAN
     Call TRF_HSH  From SCALEXCHAN
     #CATUA X3-67237.sn
     #Call TRF_LGN  From SCALEXCHAN
     #CATUA X3-67237.en
Return

