#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################
# UTIVEN02 - Utilitaire de mise à jour de [F:SOP]SOQSTA     Module Vente #
##########################################################################
Call MAJ_UTIVEN02
End

Subprog MAJ_UTIVEN02
Local Char DOSSIER(30) : DOSSIER=nomap
Call OUVRE_TRACE("UTIVEN02: Maj Etat ligne détail commande (SOQSTA) ds SORDERP ") From LECFIC
Call TEMPON("O") From GESECRAN
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>"" Call EXE_UTIVEN02(DOSSIER) : Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End






Subprog EXE_UTIVEN02(DOSSIER)
Value Char DOSSIER

#Call TEMPON("O") From GESECRAN
#Call OUVRE_TRACE("UTIVEN02: Maj Etat ligne détail commande (SOQSTA) ds SORDERP ") From LECFIC
Call ECR_TRACE("UTIVEN02: Début traitement ",0) From GESECRAN

If filinfo(filpath("FIL","SORDERQ","fde",DOSSIER),0) < 0     End Endif
If filinfo(filpath("FIL","SORDERP","fde",DOSSIER),0) < 0     End Endif

If clalev([F:SOQ])=0  Local File =DOSSIER+".SORDERQ" [SOQ] : Endif
If clalev([F:SOP])=0  Local File =DOSSIER+".SORDERP" [SOP] : Endif

Local Char     CLE1(GLONVCR)
Local Integer  NBENR, CLE2
Local Shortint STOP
Local Integer  COMPTEUR

Raz CLE1, CLE2, NBENR
Trbegin [SOQ],[SOP]

$BOUCLE_SOQ
Raz COMPTEUR
Raz STOP

For [SOQ]SOQ0 Hint Key SOQ4 Where SOQSTA=3 & SOHCAT<>4 & (SOHNUM>CLE1 | (SOHNUM=CLE1 & SOPLIN>CLE2)) 
    Read [SOP]SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
    If fstat 
        Call ECR_TRACE("File SORDERP"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)-", ERROR ="-num$(fstat),1) From GESECRAN
    Elsif [F:SOP]SOQSTA <> [F:SOQ]SOQSTA
        NBENR+=1
        Update [SOP] Where SOHNUM=[F:SOQ]SOHNUM & SOPLIN=[F:SOQ]SOPLIN & SOPSEQ=[F:SOQ]SOQSEQ 
&                    With SOQSTA=[F:SOQ]SOQSTA
        If !fstat COMPTEUR+=1 Endif
    Endif 
    If COMPTEUR>GMAXUPDTRS 
        Commit
        Trbegin [SOQ],[SOP]
        CLE1=[F:SOQ]SOHNUM : CLE2=[F:SOQ]SOPLIN : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_SOQ : Endif
Commit

#Call TEMPOFF From GESECRAN
Call ECR_TRACE("UTIVEN02 : Nbre d'enregistrements traités :"-num$(NBENR),0) From GESECRAN
#Call FERME_TRACE From LECFIC
#Call LEC_TRACE   From LECFIC
Close Local File [SOQ]
Close Local File [SOP]

End


Subprog VERF_UTIVEN02
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>"" Call EXE_VERFUTIVEN02(DOSSIER) : Endif
End

Subprog EXE_VERFUTIVEN02(DOSSIER)
Value Char DOSSIER

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIVEN02: Recherche des ligne détail commande (SOQSTA) ds SORDERP ") From LECFIC
Call ECR_TRACE("UTIVEN02: Début traitement ",0) From GESECRAN

If filinfo(filpath("FIL","SORDERQ","fde",DOSSIER),0) < 0     End Endif
If filinfo(filpath("FIL","SORDERP","fde",DOSSIER),0) < 0     End Endif

If clalev([F:SOQ])=0  Local File =DOSSIER+".SORDERQ" [SOQ] : Endif
If clalev([F:SOP])=0  Local File =DOSSIER+".SORDERP" [SOP] : Endif

Local Char     CLE1(GLONVCR)
Local Integer  NBENR, CLE2
Local Shortint STOP
Local Integer  COMPTEUR

Raz CLE1, CLE2, NBENR
Trbegin [SOQ],[SOP]

$BOUCLE_SOQ1
Raz COMPTEUR
Raz STOP

For [SOQ]SOQ0 Hint Key SOQ4 Where SOQSTA=3 & SOHCAT<>4 & (SOHNUM>CLE1 | (SOHNUM=CLE1 & SOPLIN>CLE2)) 
    Read [SOP]SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
    If !fstat & [F:SOP]SOQSTA <> [F:SOQ]SOQSTA
        NBENR+=1
        Call ECR_TRACE("File SORDERP"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ),1) From GESECRAN
    Endif 
    If COMPTEUR>GMAXUPDTRS 
        Commit
        Trbegin [SOQ],[SOP]
        CLE1=[F:SOQ]SOHNUM : CLE2=[F:SOQ]SOPLIN : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_SOQ1 : Endif
Commit

Call TEMPOFF From GESECRAN
Call ECR_TRACE("UTIVEN02 : Nbre d'enregistrements traités :"-num$(NBENR),0) From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Close Local File [SOQ]
Close Local File [SOP]

End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

If [F:ADS]MODULE(4) <> 2 : End : Endif
Call EXE_UTIVEN02(APPLI)
End

