#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(30)(1..5) , VALEUR(10)
Call S_TAB_CHAR(VALEUR,PARAM,"SELTPT","SELTPT","") From GACTION
End

#######################################################################
# Action SELTPT
#######################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
    When "SELTPT2"   : Gosub SELTPT2
  Endcase
Endcase
Return

###########################################################################
# $SELTPT2 : selection conditions de paiements depuis les tiers 
###########################################################################
$SELTPT2
If clalev([F:TPT])=0  : Local File TABPAYTERM [TPT]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif
If clalev([F:AGC])=0  : Local File AGRPCPY    [AGC]  : Endif : #- Groupes de sociétés 

Local Char    LEG(GLONADI), WGROUPE

LEG     = PARAM(1)
SOCIETE = PARAM(2)

If SOCIETE='' : Return : Endif 

#-- On recoit la société , on lit avec la LEG de la société ----#
Call GETLEG(SOCIETE,"",LEG) From TRTLECLEG

#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOTPT

For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL  = NBSEL
SIZCOL = 240
SIZLIG = 100
TIT(0) = mess(12,123,1)  # Choix
Call TITOBJ("TPT","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START  = "[F:TPT]PTE"
ORDRE  = "[F:TPT]PTE;[F:TPT]LEG;1"
OBJET  = ""

#--------------------------------------------------------------------------------------------------
## Critères pour la sélection 
#--------------------------------------------------------------------------------------------------

CRITERE(1) = ' [F:TPT]LEG="' + [L]LEG +'"'

#-- test pour voir si un groupe existe pour la société de la ligne tiers/société lue  ----#
Filter [F:AGC] Where [F:AGC]CPY = SOCIETE & [F:AGC]CPY<>[F:AGC]GRP

Read [AGC]AGC0 First
If !fstat 
 CRITERE(1) -= ' & [F:AGC]CPY="' + [L]SOCIETE +'" & [F:TPT]GFY=[F:AGC]GRP ' : #-- Selection enreg TPT qui ont un groupe lié a la société   
Else 
 CRITERE(1) -= ' & [F:TPT]GFY="' + '"'                                      : #-- Selection enreg dans TPT sans groupe   
Endif
 CRITERE(1) -= ' & [F:TPT]PTELIN=1'                                            
 
Filter [F:AGC]


 Link [F:TPT] With [AXX]AXX0     = "TABPAYTERM";"DESAXX";GLANGUE;[F:TPT]PTE;[F:TPT]LEG
&                , [AGC]AGC0     =  [F:TPT]GFY;SOCIETE 
& As [LNC]

Default File [LNC]
DEFPAG = 1

Return

 



