#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion des tâches                           Module CRM     12 Décembre 2003  #
##########################################################################################################
#
#  DISPICON     : Affichage des icônes
#  SAVECLOB     : Enregistrement des CLOBs
#  DELCLOB      : Suppression des CLOBs
#  LOADCLOB     : Chargement du CLOB compte-rendu
#  DISPCCN      : Affichage de l'interlocuteur
#  DISPBKGCCN   : Affichage du background de l'interlocuteur
#
#  DEFOBJORI    : Définition du type de pièce
#  VERIFORI     : Vérification cohérence entre origine et numéro de pièce
#  VERIFDATE    : Vérifie la validité des dates début et echéance
#  VERIFCCNCOR  : Vérifie adéquation entre interlocuteur et correspondant
#  DEFCOR       : Affecte le correspondant par défaut
#  GERE_LCM_CREATION  : gere les données  pour la gestion des en cours en creation
#  GERE_LCM_MODIF     : gere les données  pour la gestion des en cours en modification
#  GERE_LCM_ANNULE    : gere les données  pour la gestion des en cours en annulation
##########################################################################################################
##########################################################################################################
Subprog AFFICHE_BCK_TIERS(SZBPRNUM)
Value Char SZBPRNUM

Local Char SZTYP(GLONDES)

  # FGR 05/04/2011 : X3SUIVI72615
  Call GETBPRTYP(SZBPRNUM, SZTYP, [M:TSK0]TSKCMPAOB) From CRM_UTIL
  Chgtzn [M:TSK0]TSKCMP With SZTYP
  [M:TSK0]TSKCMPLIB = SZTYP
End

##########################################################################################################
#Affichage des icônes
######################################################
$DISPICON
  Gosub DEFICONNUM From CRMUTIL150
  If len([M:TSK2]FULRPO) > GLONCLE Then
    If [M:TSK2]RPOFLG Then
      [M:TSK2]RPOICO = SZICOSYNDON
    Else
      [M:TSK2]RPOICO = SZICOSYN
    Endif
    Actzo [M:TSK2]RPOICO
  Else
    [M:TSK2]RPOICO = "-1"
    Grizo [M:TSK2]RPOICO
  Endif
  If len([M:TSK1]FULOBJ) > GLONCLE Then
    If [M:TSK1]OBJFLG Then
      [M:TSK1]OBJICO = SZICOSYNDON
    Else
      [M:TSK1]OBJICO = SZICOSYN
    Endif
    Actzo [M:TSK1]OBJICO
  Else
    [M:TSK1]OBJICO = "-1"
    Grizo [M:TSK1]OBJICO
  Endif
Return

##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif
  #Compte-rendu
  If [M:TSK2]FULRPO <> "" Then
    Raz [F:HD4]
    [F:HD4]NUM = [M:TSK2]NUMFULRPO
    [F:HD4]TYP = [M:TSK2]TYPFULRPO
    [F:HD4]CLOB = [M:TSK2]FULRPO
    Write [HD4]
    If fstat Then
      #Erreur lors de l'enregistrement du compte-rendu de la tâche. Transaction abandonnée.
      GMESSAGE = mess(865,182,1)
      GERR = 1
      Call FSTA("HD4") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
  #Objet de l'action
  If [M:TSK1]FULOBJ <> "" Then
    Raz [F:HD6]
    [F:HD6]NUM = [M:TSK1]NUMFULOBJ
    [F:HD6]TYP = [M:TSK1]TYPFULOBJ
    [F:HD6]CLOB = [M:TSK1]FULOBJ
    Write [HD6]
    If fstat Then
      #Erreur lors de l'enregistrement de la description de la tâche. Transaction abandonnée.
      GMESSAGE = mess(866,182,1)
      GERR = 1
      Call FSTA("HD6") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD4] Where [F:HD4]NUM = [M:TSK2]NUMFULRPO and [F:HD4]TYP = [M:TSK2]TYPFULRPO
  If fstat Then
    #Erreur lors de la suppression du compte-rendu de la tâche. Transaction abandonnée.
    GMESSAGE = mess(867,182,1)
    GERR = 1
    Call FSTA("HD4") From GLOCK
    GOK = 0
    Return
  Endif
  Delete [HD6] Where [F:HD6]NUM = [M:TSK1]NUMFULOBJ and [F:HD6]TYP = [M:TSK1]TYPFULOBJ
  If fstat Then
    #Erreur lors de la suppression de la description de la tâche. Transaction abandonnée.
    GMESSAGE = mess(868,182,1)
    GERR = 1
    Call FSTA("HD6") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB compte-rendu
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:TSK2]NUMFULRPO = "" Then
    Raz [M:TSK2]FULRPO
    ILOOKFORCLOB = 0
  Endif
  If [M:TSK2]TYPFULRPO = "" Then
    Raz [M:TSK2]FULRPO
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD4]HD40=[M:TSK2]NUMFULRPO;[M:TSK2]TYPFULRPO
    If fstat Then
      Raz [M:TSK2]FULRPO
    Else
      [M:TSK2]FULRPO = [F:HD4]CLOB
    Endif
  Endif
  ILOOKFORCLOB = 1
  If [M:TSK1]NUMFULOBJ = "" Then
    Raz [M:TSK1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If [M:TSK1]TYPFULOBJ = "" Then
    Raz [M:TSK1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD6]HD60=[M:TSK1]NUMFULOBJ;[M:TSK1]TYPFULOBJ
    If fstat Then
      Raz [M:TSK1]FULOBJ
    Else
      [M:TSK1]FULOBJ = [F:HD6]CLOB
    Endif
  Endif
Return

##########################################################################################################
#Affichage de l'interlocuteur
######################################################
$DISPCCN
  If [M:TSK0]TSKCCN = "" Then
    [M:TSK0]CCNTYP = 1
    [M:TSK0]TSKCCNCLA = ""
  Else
    Read [AIN]AIN0=[M:TSK0]TSKCCN
    If fstat Then
      [M:TSK0]TSKCCNCLA = ""
      [M:TSK0]CCNTYP = 1
    Else
      Call BUILDFULNAM("AIN", [M:TSK0]TSKCCNCLA) From CRMUTIL140
      [M:TSK0]CCNTYP = [F:AIN]CNTTYP
    Endif
  Endif
  If [M:TSK0]CCNTYP = 1 Then
    [M:TSK0]CCNOBJ = "AIN"
  Else
    [M:TSK0]CCNOBJ = "LDS"
  Endif
Return

##########################################################################################################
#Affichage du background de l'interlocuteur
######################################################
$DISPBKGCCN
  If GIMPORT Then
    Return
  Endif
  If [M:TSK0]CCNTYP = 0 Then
    [M:TSK0]CCNTYP = 1
  Endif
  Chgtzn [M:TSK0]TSKCCN With mess([M:TSK0]CCNTYP,3038,1)
  If [M:TSK0]CCNTYP = 1 Then
    [M:TSK0]CCNOBJ = "AIN"
  Else
    [M:TSK0]CCNOBJ = "LDS"
  Endif
Return

##########################################################################################################
#Vérification cohérence entre origine et numéro de pièce
$VERIFORI
  # FGR 04/03/2010 : X3SUIVI62924
  If [M:TSK1]TSKORIAOB <> "" and [M:TSK1]TSKORIVCR = "" Then
    #Le numéro de pièce / ligne est obligtoire pour la liaison spécifiée.
    GMESSAGE = mess(442,177,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
  Endif
Return

##########################################################################################################
# Vérifie la validité des dates début et echéance
$VERIFDATE
  If [M:TSK1]TSKSTR <> [00/00/00] and [M:TSK1]TSKDAT <> [00/00/00] Then
    If [M:TSK1]TSKDAT < [M:TSK1]TSKSTR Then
      #La date de début est supérieure à la date d'échéance.
      GMESSAGE = mess(504,177,1)
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return
    Endif
  Endif
  If [M:TSK0]TSKDON = 2 Then
    If [M:TSK1]TSKSTR = [00/00/00] or [M:TSK1]TSKDAT = [00/00/00] Then
      #Les dates de début de d'échéance sont obligatoires pour une tâche effectuée.
      GMESSAGE = mess(510,177,1)
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
# Vérifie adéquation entre interlocuteur et correspondant
$VERIFCCNCOR
  #Vérification interlocuteur/correspondant
  If [M:TSK0]TSKCCN <> "" Then
    If [M:TSK0]TSKCOR <> "" Then
      Read [COR]COR0=[M:TSK0]TSKCOR
      If fstat = 0 Then
        If [F:COR]CNTNUM <> [M:TSK0]TSKCCN Then
          [M:TSK0]TSKCOR = ""
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Affecte le correspondant par défaut
$DEFCOR
Local Integer IBFOUND

  IBFOUND = 0
  If [M:TSK0]TSKCOR = "" Then
    If [M:TSK0]TSKCCN <> ""  Then
      If [M:TSK0]TSKCMP <> "" Then
        For [COR] Where [F:COR]CNTNUM = [M:TSK0]TSKCCN and [F:COR]BPRNUM = [M:TSK0]TSKCMP
          IBFOUND = 1
          Break
        Next
      Endif
      If IBFOUND = 0 Then
        For [COR] Where [F:COR]CNTNUM = [M:TSK0]TSKCCN and [F:COR]BPRNUM = ""
          IBFOUND = 1
          Break
        Next
      Endif
      If IBFOUND = 1 Then
        [M:TSK0]TSKCOR = [F:COR]CORNUM
      Endif
    Endif
  Endif
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en creation
$GERE_LCM_CREATION
  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  Raz [BPR]
  If [M:TSK0]TSKCMP <> "" Then
    Read [BPR]BPR0=[M:TSK0]TSKCMP
    If fstat <> 0 Then
      #Erreur lors de la lecture du tiers - ":" - [M:TSK0]TSKCMP
      GMESSAGE = mess(445,177,1) - ":" - [M:TSK0]TSKCMP
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
    If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
      Return
    Endif
    # FGR 12/08/2009 : X3SUIVI57005 : Ce sont les S/P fais pour qui gèrent, on ne le fait pas directement par LCM_MAJINFO
    #                                 En plus directement ça ne tient pas compte de la priorité Appel/Tâche/RdV
    If [M:TSK0]TSKDON = 2 Then
      # Gestion premier contact
      Call LCM_BPRFIRSTCNT ([M:TSK0]TSKCMP, GSOCIETE, [M:TSK0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion dernier contact
      Call LCM_BPRLASTCNT ([M:TSK0]TSKCMP, GSOCIETE, [M:TSK0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      # Gestion prochain contact
      Call LCM_BPRNEXTCNT ([M:TSK0]TSKCMP, GSOCIETE, [M:TSK0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en modification
$GERE_LCM_MODIF
Local Integer IBTRAITBPR
Local Integer IBTRAITBPRINI
Local Char SZSOCINI(GLONCPY)
Local Integer IBCHANGE_LCMKEY

  IBTRAITBPR = 0
  IBTRAITBPRINI = 0
  Raz SZSOCINI
  IBCHANGE_LCMKEY = 0
  Raz [BPR]
  If [M:TSK0]SALFCYINI = [M:TSK0]SALFCY and [M:TSK0]TSKCMPINI = [M:TSK0]TSKCMP and
&    [M:TSK0]TSKDONINI = [M:TSK0]TSKDON and [M:TSK1]TSKSTRINI = [M:TSK1]TSKSTR and
&    [M:TSK1]TSKDATINI = [M:TSK1]TSKDAT
& Then
    #Rien n'a été changé sur les données encours, on sort
    Return
  Endif
  If [M:TSK0]TSKCMP <> "" Then
    Read [BPR]BPR0=[M:TSK0]TSKCMP
    If fstat <> 0 Then
      #Erreur lors de la lecture du tiers + " : " +[M:TSK0]TSKCMP
      GMESSAGE = mess(445,177,1) - ":" - [M:TSK0]TSKCMP
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
    If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
      IBTRAITBPR = 1
    Endif
  Endif
  If [M:TSK0]SALFCYINI <> [M:TSK0]SALFCY Then
    #On recherche la société initiale
    If [M:TSK0]SALFCYINI <> "" Then
      Read [FCY]FCY0=[M:TSK0]SALFCYINI
      If fstat = 0 Then
        SZSOCINI = [F:FCY]LEGCPY
      Else
        #Erreur lors de la lecture de la table des sites
        GMESSAGE = mess(444,177,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      SZSOCINI = ""
    Endif
    If SZSOCINI <> GSOCIETE Then
      IBCHANGE_LCMKEY = 1
    Endif
  Else
    SZSOCINI = GSOCIETE
  Endif
  If [M:TSK0]TSKCMPINI <> [M:TSK0]TSKCMP Then
    If [M:TSK0]TSKCMPINI <> "" Then
      IBCHANGE_LCMKEY = 1
      Read [BPR]BPR0=[M:TSK0]TSKCMPINI
      If fstat <> 0 Then
        #Erreur lors de la lecture du tiers + " : " +[M:TSK0]TSKCMP
        GMESSAGE = mess(445,177,1) - ":" - [M:TSK0]TSKCMPINI
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
        IBTRAITBPRINI = 1
      Endif
    Endif
  Else
    IBTRAITBPRINI = IBTRAITBPR
  Endif
  If IBCHANGE_LCMKEY = 1 and IBTRAITBPRINI = 1 Then
    # On a changé de société. On remet à jour les infos pour l'ancienne société
    If [M:TSK0]TSKDONINI = 2 Then
      # Gestion premier contact
      Call LCM_BPRFIRSTCNT ([M:TSK0]TSKCMPINI, SZSOCINI, [M:TSK0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion dernier contact
      Call LCM_BPRLASTCNT ([M:TSK0]TSKCMPINI, SZSOCINI, [M:TSK0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      # Gestion prochain contact
      Call LCM_BPRNEXTCNT ([M:TSK0]TSKCMPINI, SZSOCINI, [M:TSK0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
  #
  If IBTRAITBPR = 1 Then
    # C'est un client ou un prospect
    If [M:TSK0]TSKDONINI = [M:TSK0]TSKDON Then
      # Le statut n'a pas changé : GERE_LCM_CREATION fait tout ce qu'il faut.
      Gosub GERE_LCM_CREATION
    Else
      # Le statut n'a pas changé : il faut refaire les trois étapes
      # Gestion premier contact
      Call LCM_BPRFIRSTCNT ([M:TSK0]TSKCMP, GSOCIETE, [M:TSK0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion dernier contact
      Call LCM_BPRLASTCNT ([M:TSK0]TSKCMP, GSOCIETE, [M:TSK0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion prochain contact
      Call LCM_BPRNEXTCNT ([M:TSK0]TSKCMP, GSOCIETE, [M:TSK0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en annulation
$GERE_LCM_ANNULE
Local Integer IBSUPR

  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  If [M:TSK0]TSKCMP = "" Then
    Return
  Endif
  Raz [BPR]
  Read [BPR]BPR0=[M:TSK0]TSKCMP
  If fstat <> 0 Then
    #Erreur lors de la lecture du tiers + " : " +[M:TSK0]TSKCMP
    GMESSAGE = mess(445,177,1) - ":" - [M:TSK0]TSKCMP
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    GOK = 0
    Return
  Endif
  If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
    Return
  Endif
  IBSUPR = 0
  #If faut supprimer les anciennes données
  Call LCM_DELKEY(13, [M:TSK0]TSKNUM, IBSUPR, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    GOK = 0
    Return
  Endif
  If IBSUPR = 1 Then
    # on a supprimé quelque chose : donc on refait la recherche
    If [M:TSK0]TSKDONINI = 2 Then
      # Gestion premier contact
      Call LCM_BPRFIRSTCNT ([M:TSK0]TSKCMP, GSOCIETE, [M:TSK0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion dernier contact
      Call LCM_BPRLASTCNT ([M:TSK0]TSKCMP, GSOCIETE, [M:TSK0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      # Gestion prochain contact
      Call LCM_BPRNEXTCNT ([M:TSK0]TSKCMP, GSOCIETE, [M:TSK0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return
