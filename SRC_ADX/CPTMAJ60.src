#** ######################################################################################################
#*
#* Procedure: CREATE_ERC_AND_BPGROUPS
#*
#* Purpose:   ...
#*
#*! ######################################################################################################
Subprog CREATE_ERC_AND_BPGROUPS
    Local Char LEGSEL(30)
    Local Char STDGRP(30)
    Local Integer I

    # Check existance of economic reason code base tables. If not stop here.
    If   ( filinfo( filpath( "FIL", "PBDECOCOD", "fde", [F:ADS]DOSSIER), 0 ) <= 0 )
&    and ( filinfo( filpath( "FIL", "PBDBPGRP",  "fde", [F:ADS]DOSSIER), 0 ) <= 0 )
&    and ( filinfo( filpath( "FIL", "PBDBPGRPD", "fde", [F:ADS]DOSSIER), 0 ) <= 0 )
        End
    Endif

    # Check if misc. table 309 exists, and stop if it does not.
    Local File =[F:ADS]DOSSIER + ".ATABTAB" [ADV]
# 2015-06-24 DNE INSERT BEGIN
    Local File ADOVAL [F:ADW]
# 2015-06-24 DNE INSERT END

    Read [F:ADV]CODE = 309
    If fstat Then
        Close Local File [F:ADV]
        End
    Endif
    Close Local File [F:ADV]

    # Get the legislation to migrate:
    #
    # Check mono-legislation folder
    If [F:ADS]NBLEG = 1
        # Mono-legislaton: Take the one and only one.
        LEGSEL = [F:ADS]DOSLEG(0)
    Else
        # OK. We are in multi-legislation folder. Let's check for MIGECOCOD parameter on folder level.
# 2015-06-24 DNE MODIF BEGIN
        Read [F:ADW]ADW0 = ""; ""; "MIGECOCOD"
        If !fstat
            LEGSEL= [F:ADW]VALEUR
        Endif
# 2015-06-24 DNE MODIF ORIG
#        LEGSEL = func AFNC.PARAMDOS( [F:ADS]DOSSIER, "MIGECOCOD" )
# 2015-06-24 DNE MODIF END
        If LEGSEL = ""
            # MIGECOCOD is not set so we search for FRA legislation.
            For I = 0 To [F:ADS]NBLEG - 1
                If [F:ADS]DOSLEG(I) = "FRA"
                    LEGSEL = "FRA"
                    Break
                Endif
            Next
            If LEGSEL = ""
                # Even FRA legislation does not exist. Let's take the first one that comes our way.
                LEGSEL = [F:ADS]DOSLEG(0)
            Endif
        Endif
    Endif

    # Get the standard BP group for economic reason codes
    #
# 2015-06-24 DNE MODIF BEGIN
    Read [F:ADW]ADW0 = ""; ""; "PBDDEFGRU"
    If !fstat
        STDGRP= [F:ADW]VALEUR
    Endif
# 2015-06-24 DNE MODIF ORIG
#    STDGRP = func AFNC.PARAMDOS( [F:ADS]DOSSIER, "PBDDEFGRU" )
# 2015-06-24 DNE MODIF END
    If STDGRP = ""
        # Fallback: Take "STD" if parameter PBDDEFGRU is not set correcctly (or does not exist at all).
        STDGRP = "STD"
    Endif

    # Create economic reason codes from misc. table 309
    Gosub CREATE_ECONOMIC_REASON_CODES

    # Create economic reason BP groups and connect BPs
    Gosub CREATE_BP_GROUPS

# 2015-06-24 DNE INSERT BEGIN
    Close Local File [F:ADW]
# 2015-06-24 DNE INSERT END
End


#** ######################################################################################################
#*
#* Sub chunk: CREATE_ECONOMIC_REASON_CODES
#*
#* Purpose:   Created new economic reason codes for the codes already found in ADI 309.
#*
#*! ######################################################################################################

$CREATE_ECONOMIC_REASON_CODES
    Call ECR_TIME( mess(81,125,1 ) - ": PBDECOCOD" ) From DOSSUB

    Local File =[F:ADS]DOSSIER + ".ATABDIV"   [ADI]
    Local File =[F:ADS]DOSSIER + ".ATEXTRA"   [ATX]
    Local File =[F:ADS]DOSSIER + ".ATEXTRA"   [ATXDST]
    Local File =[F:ADS]DOSSIER + ".PBDECOCOD" [PBDECO]

    Trbegin [F:PBDECO]

    Filter [F:ADI] Where NUMTAB = 309
    For [F:ADI]CODE

        # Create economic reason codes from misc. table 309
        Read [PBDECO]PBDECO0 = [F:ADI]CODE; LEGSEL
        If fstat
            Raz [PBDECO]
            [F:PBDECO]     = [F:ADI]
            [F:PBDECO]COD  = [F:ADI]CODE
            [F:PBDECO]LEG  = LEGSEL
            [F:PBDECO]TYP  = 1 # "Not used"
            Write [F:PBDECO]
            If fstat Then
                Call ERREUR( "PBDECO" - [F:PBDECO]COD - [F:PBDECO]LEG, 2 ) From DOSDIC
            Endif

            # Add description and short description (ATX fields).
            Filter [F:ATX]
&             Where [F:ATX]CODFIC = "ATABDIV"
&             and ( [F:ATX]ZONE = "LNGDES" or [F:ATX]ZONE = "SHODES" )
&             and [F:ATX]IDENT1 = "309"
&             and [F:ATX]IDENT2 = [F:ADI]CODE
            For [F:ATX]
                [F:ATXDST] = [F:ATX]
                [F:ATXDST]CODFIC = "PBDECOCOD"
                If [F:ATX]ZONE = "LNGDES" Then
                    [F:ATXDST]ZONE = "DES"
                Else
                    [F:ATXDST]ZONE = "TIT"
                Endif
                [F:ATXDST]IDENT1 = [F:ATXDST]IDENT2
                [F:ATXDST]IDENT2 = LEGSEL
                Write [F:ATXDST]
                If fstat Then
                    Call ERREUR( "ATEXTRA" - [F:ATXDST]CODFIC - [F:ATXDST]ZONE - [F:ATXDST]LANGUE - [F:ATXDST]IDENT1 - [F:ATXDST]IDENT2, 2 ) From DOSDIC
                Endif
            Next
            Filter [F:ATX]
        Endif
    Next
    Filter [F:ADI]

    Commit

    Close Local File [ADI]
    Close Local File [ATX]
    Close Local File [ATXDST]
    Close Local File [PBDECO]
Return



#** ######################################################################################################
#*
#* Sub chunk: CREATE_BP_GROUPS
#*
#* Purpose:   Creates the links between BP with existing economic reason codes based on ADI 309
#*            to the new ones
#*
#*! ######################################################################################################

$CREATE_BP_GROUPS
    Call ECR_TIME( mess(81,125,1) - ": PBDBPGRP - PBDBPGRPD" ) From DOSSUB

    Local File =[F:ADS]DOSSIER + ".PBDBPGRP"  [PBDBPG]
    Local File =[F:ADS]DOSSIER + ".PBDBPGRPD" [PBDBPD]

    # Special handling for BPARTNER table.
    Local Integer ERR
    Local Char WNAMBPR(255)

    Call MIGTABNAME( [F:ADS]DOSSIER, "BPARTNER", WNAMBPR, ERR ) From TRTMIG
    If filinfo( filpath( "FIL", WNAMBPR, "fde", [F:ADS]DOSSIER ), 0 ) > 0
        Local File = [F:ADS]DOSSIER + "." + WNAMBPR [BPR]
    Else
        Local File = [F:ADS]DOSSIER + ".BPARTNER" [BPR]
    Endif

    Trbegin [F:PBDBPG]

    # Create economic reason BP group header.
    Raz [F:PBDBPG]
    [F:PBDBPG]COD = STDGRP
    [F:PBDBPG]LEG = LEGSEL
    Write [F:PBDBPG]
    If fstat Then
        Call ERREUR( "PBDBPG" - [F:PBDBPG]COD - [F:PBDBPG]LEG, 2 ) From DOSDIC
    Else
        # Create economic reason BP group details.
        Filter [F:BPR] Where BDFECOCOD <> ""
        For [F:BPR]BPR0
            Read [F:PBDBPD]PBDBPD0 = STDGRP; LEGSEL; [F:BPR]BPRNUM
            If fstat
                Raz [F:PBDBPD]
                [F:PBDBPD] = [F:BPR]
                [F:PBDBPD]COD = STDGRP
                [F:PBDBPD]LEG = LEGSEL
                [F:PBDBPD]FLGALL = 1
                [F:PBDBPD]TYP = 1
                [F:PBDBPD]BPR = [F:BPR]BPRNUM
                [F:PBDBPD]CRYADDCOD = 1
                [F:PBDBPD]FLGBPNINC = 1
                [F:PBDBPD]ECOCOD = [F:BPR]BDFECOCOD
                Write [F:PBDBPD]
                If fstat Then
                    Call ERREUR( "PBDBPD" - [F:PBDBPD]COD - [F:PBDBPD]LEG - [F:PBDBPD]BPR, 2 ) From DOSDIC
                Endif
            Endif
        Next
        Filter [F:BPR]
    Endif

    Commit

    Close Local File [PBDBPG]
    Close Local File [PBDBPD]
    Close Local File [BPR]
Return

########################################################################################################################
########################################################################################################################
########################################################################################################################
########################################################################################################################

$TABLE_TABPAM
  Call ECR_TIME(mess(81,125,1) - ": TABPAM - SWIPAMBVR") From DOSSUB

  Local File =[F:ADS]DOSSIER + ".TABPAM" [TAM]
  # see SAM 110433:  Filter [F:TAM] Where [F:TAM]LEG = "SWI"

  Trbegin [F:TAM]
  For [F:TAM]TAM0
    # SWIPAMBVR
    [F:TAM]SWIPAMBVR = 1
    Case left$([F:TAM]PAM, 3)
      When "DT8" : [F:TAM]SWIPAMBVR = 3
      When "OPA" : [F:TAM]SWIPAMBVR = 4
    Endcase

    # update
    Rewrite [F:TAM]
    If fstat <> 0 Then
      Call ERREUR(" TABPAM " - [F:TAM]PAM - [F:TAM]LEG, 2) From DOSDIC
    Endif
  Next
  Commit

  # see SAM 110433:  Filter [F:TAM]
  Close Local File [TAM]
Return

########################################################################################################################

$TABLE_TABPAYTYP
  Call ECR_TIME(mess(81,125,1) - ": TABPAYTYP - SWIPAYTYP") From DOSSUB

  Local File =[F:ADS]DOSSIER + ".TABPAYTYP" [TPY]
  # see SAM 110433:  Filter [F:TPY] Where [F:TPY]LEG = "SWI"

  Trbegin [F:TPY]
  For [F:TPY]TPY0
    # SWIPAYTYP
    If [F:TPY]PAYTYP = "SWDTA" or [F:TPY]PAYTYP = "FDTA" Then
      [F:TPY]SWIPAYTYP = 2
    Elsif [F:TPY]PAYTYP = "SWOPA" or [F:TPY]PAYTYP = "OPAE" Then
      [F:TPY]SWIPAYTYP = 3
    Else
      [F:TPY]SWIPAYTYP = 1
    Endif

    # update
    Rewrite [F:TPY]
    If fstat <> 0 Then
      Call ERREUR(" TABPAYTYP " - [F:TPY]PAYTYP - [F:TPY]LEG, 2) From DOSDIC
    Endif
  Next
  Commit

  # see SAM 110433:  Filter [F:TPY]
  Close Local File [TPY]
Return

