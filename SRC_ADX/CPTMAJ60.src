 [F:CCL]TXT    = 171
 [F:CCL]TYPCPT = 1
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/21-9",1) From DOSDIC
 Endif
Endif

Read [CCL]CCL0 = 21;10
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 21
 [F:CCL]NUMLIG = 10
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 172
