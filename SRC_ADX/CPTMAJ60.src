#** ######################################################################################################
#*
#* Procedure: GACCCODLIG
#*
#* Purpose:   Updating of accounting code lines V9
#*
#*! ######################################################################################################
$GACCCODLIG
Local Integer NBRLIG
Local File =[F:ADS]DOSSIER+".GACCCODLIG"  [CCL]

Call ECR_TIME(mess(81,125,1)-": GACCCODLIG") From DOSSUB : # maj table

Trbegin [CCL]

Read [CCL]CCL0 = 21;4
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 21
