#<AdxTL>@(#)0.0.0.0 $Revision$ Consultation numéros de série
#CHECK UNUSED_SOURCE
###########################################################
$SET_NOL
Local Integer NOL
NOL = nolign - 1
Return
###########################################################
#Sous programme d'affichage des numéros de série
# LFCY = Site de stock
# LITM = Article 
# LLOT = Lot
# LCHR = Chrono stock
# LSER = Numéro serie départ
# LTYP = Type piece livraison 
# LLIV = Numéro livraison
# LBPC = Client
# LADD = Code adresse
# LSEL = 0 interro / 1 selection 
# LSERS= Numéro série selectionné
Subprog AFFSER(LFCY,LITM,LLOT,LCHR,LSER,LTYP,LLIV,LBPC,LADD,LSEL,LSERS)
Variable Char    LFCY
Variable Char    LITM
Variable Char    LLOT
Variable Decimal LCHR
Variable Char    LSER
Variable Integer LTYP
Variable Char    LLIV
Variable Char    LBCP
Variable Char    LADD
Value    Integer LSEL
Variable Char    LSERS
#
Local    Integer CHOIX
Local    Integer SAVOBJET
Local    Char    SAVPROG
Local    Integer WPRE
Local    Integer WNOLIGN
Local    Integer WFSTAT 
Local    Integer WBOU(1..GNBBOU)  
# 
Local    Char    WITM(GLONITM)    # hcb 121825
Local    Char    WNUM(GLONSER) 
Local    Integer I
Local    Integer ISEL
Local    Char    WREP
Local    Integer WLEC
Local    Char    WFIL(250)
Local    Char    WTIT(60) : WTIT = mess(10,723,1)
Local    Integer WTRI, WTRIE, WTRIL, WTRIS   
#
WNOLIGN = nolign
Call SAVBOUT From GESECRAN
SAVOBJET = GOBJET
SAVPROG  = GPROGRAMME  
GOBJET   = 0 
# 
For I = 1 To GNBBOU  
  WBOU(I) = 0  
Next I 
WBOU(GVALI) = 1
WBOU(GABAN) = 1
WBOU(GSPE2) = 1
WBOU(GSPE3) = 1
WBOU(GSPE4) = 1
WBOU(GSPE5) = 1
Call SETBOUT(WBOU) From GESECRAN
#  
LSERS    = ""
#
If clalev([F:TCU])  = 0 : Local File TABCUR    [TCU]  : Endif
If clalev([F:ITM1]) = 0 : Local File ITMMASTER [ITM1] : Endif
If clalev([F:STS1]) = 0 : Local File STOSER    [STS1] : Endif
If clalev([F:STO2]) = 0 : Local File STOCK     [STO2] : Endif
Read [ITM1]ITM0=LITM
  If fstat 
    End
Endif
#
Local Mask STKD [STKD]
Local Dlgbox Mask [STKD]
&    Button mess(27,123,1),           mess(22,123,1),
&           mess(297,198,1),          mess(298,198,1),   
&           mess(308,198,1),          mess(65,123,1)
&    With   left$(mess(27,123,1),1),  left$(mess(22,123,1),1),
&           left$(mess(297,198,1),1), left$(mess(298,198,1),1),
&           left$(mess(308,198,1),1), left$(mess(65,123,1),1) 
&    Coded GSTAOK, GSTABOU+2, GSTABOU+3, GSTABOU+4, GSTABOU+5, GSTAFIN 
&    Titled WTIT
&    As [STKD]
#
Boxact [STKD]
#
Raz [M:STKD]
[M:STKD]STOFCY    = LFCY 
[M:STKD]ITMREF    = [F:ITM1]ITMREF
#[M:STKD]ITMDES1   = [F:ITM1]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:STKD]ITMDES1, "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:STKD]STU       = [F:ITM1]STU
[M:STKD]SDHTYPSEL = LTYP
[M:STKD]SDHNUMSEL = LLIV
[M:STKD]BPCNUMSEL = LBPC
[M:STKD]BPAADDSEL = LADD
Gosub TRT_INI
If LSEL = 0
  WBOU(GSPE2) = 0
Endif
If !(WBOU(GPREM) = 0 & WBOU(GDERN) = 0)
  WBOU(GSPE3) = 0
  WBOU(GSPE4) = 0
  WBOU(GSPE5) = 0
Endif  
Call SETBOUT(WBOU) From GESECRAN
Enable GSTAEDI
$AFFSER1
Boxinp [STKD] Using CHOIX
  Case CHOIX
    When GSTAEDI :
      Call PRTSCR("STKD","",WTIT,0,0) From ATRTX3
    When GSTABOU+1 :
      Gosub DEL_TAB
      
    When GSTAOK , GSTARET :
      Gosub TRT_INI 
      Gosub AFF_TAB 
    When GSTABOU+2 :
      LSERS = [M:STKD]SERNUM(nolign-1)
      Goto AFFSER2 
    When GSTABOU+3 :
      WTRI = 1
      Gosub TRT_TRI 
    When GSTABOU+4 :
      WTRI = 2
      Gosub TRT_TRI 
    When GSTABOU+5 :
      WTRI = 3
      Gosub TRT_TRI 
    When GSTAFIN, GSTAESC :
      If LSEL = 1 & nolign > 0
        LSERS = ""
      Endif 
      Goto  AFFSER2
    When GSTAFIR :
      Gosub TRT_PRE
    When GSTALAS :
      Gosub TRT_DER
    When GSTAPRE :
      WPRE = 0
      Gosub PAG_PRE
    When GSTASUI :
      Gosub PAG_SUI
  Endcase
Goto AFFSER1
$AFFSER2
Filter [STS1]
Close Local File [STO2]
Close Local File [STS1]
nolign     = WNOLIGN
GOBJET     = SAVOBJET
GPROGRAMME = SAVPROG
Call RESTBOUT From GESECRAN
End
###########################################################
$TRT_TRI
Case WTRI
  When 1 :
    Raz WTRIL, WTRIS
    Call TEMPON(mess(297,198,1)) From GESECRAN
    If WTRIE = 0
      WTRIE = 1 
      Sorta [M:STKD]BASPAG2 [M:STKD]BASPAG2 Order By [M:STKD]LOC(indice),
&           [M:STKD]SERNUM(indice)
    Else
      WTRIE = 0
      Sorta [M:STKD]BASPAG2 [M:STKD]BASPAG2 Order By [M:STKD]LOC(indice) Desc
    Endif 
  When 2 :
    Raz WTRIE, WTRIS
    Call TEMPON(mess(298,198,1)) From GESECRAN
    If WTRIL = 0
      WTRIL = 1
      Sorta [M:STKD]BASPAG2 [M:STKD]BASPAG2 Order By [M:STKD]LOT(indice),
&           [M:STKD]SERNUM(indice)
    Else
      WTRIL = 0
      Sorta [M:STKD]BASPAG2 [M:STKD]BASPAG2 Order By [M:STKD]LOT(indice) Desc
    Endif 
  When 3 :
    Raz WTRIE, WTRIL
    Call TEMPON(mess(308,198,1)) From GESECRAN
    If WTRIS = 0 
      WTRIS = 1
      Sorta [M:STKD]BASPAG2 [M:STKD]BASPAG2 Order By [M:STKD]SERNUM(indice),
&           [M:STKD]LOT(indice)
    Else
      WTRIS = 0
      Sorta [M:STKD]BASPAG2 [M:STKD]BASPAG2 Order By [M:STKD]SERNUM(indice) Desc
    Endif
Endcase
Affzo [M:STKD]15
Call TEMPOFF From GESECRAN
Return
###########################################################
$AFF_TAB
WFSTAT = fstat 
Grizo [M:STKD]5-10
Affzo [M:STKD]15
[M:STKD]FLG = 0
Actzo [M:STKD]10
fstat = WFSTAT
Return
###########################################################
$DEL_TAB
Effzo [M:STKD]15
Return
###########################################################
$TRT_INI
If [M:STKD]FLG <> 0
  Return 
Endif
[M:STKD]FLG = 1
WFIL = ""
If [M:STKD]ALLFLG = 2
  WFIL = "1=1"
Else
  If [M:STKD]BPCNUMSEL <> ""
    WFIL = "[F:STS1]BPCNUM=[M:STKD]BPCNUMSEL"
  Endif
  If [M:STKD]BPAADDSEL <> ""
    If WFIL <> ""
      WFIL += "&"
    Endif
    WFIL += "[F:STS1]BPAADD=[M:STKD]BPAADDSEL"
  Endif
  If [M:STKD]SDHTYPSEL <> 0
    If WFIL <> ""
      WFIL += "&"
    Endif
    Case LTYP
      When 4,5,12  : WFIL += "[F:STS1]SDHTYP   =[M:STKD]SDHTYPSEL"
      When 6,15    : WFIL += "[F:STS1]RCPVCRTYP=[M:STKD]SDHTYPSEL"
      When Default : WFIL += "[F:STS1]VCRTYP   =[M:STKD]SDHTYPSEL"
   Endcase 
  Endif
  If [M:STKD]SDHNUMSEL <> ""
    If WFIL <> ""
      WFIL += "&"
    Endif
    Case LTYP :
      When 4,5,12  : WFIL += "[F:STS1]SDHNUM   =[M:STKD]SDHNUMSEL"
      When 6,15    : WFIL += "[F:STS1]RCPVCRNUM=[M:STKD]SDHNUMSEL"
      When Default : WFIL += "[F:STS1]VCRNUM   =[M:STKD]SDHNUMSEL"
   Endcase
  Endif
Endif
#Positionnement fichier selon les choix
If WFIL = ""
  If LLOT <> ""                  
    If LFCY <> ""
     Link [STS1] With  [STO2]STO0 = [F:STS1]STOFCY;[F:STS1]STOCOU
&                As    [SLO]
&                Where [F:STO2]STOFCY=LFCY    &
&                      [F:STO2]ITMREF=LITM    & 
&                      [F:STO2]LOT=LLOT       &
&                      [F:STS1]SERNUM >= LSER &
&                      [F:STS1]ISSDAT = [0/0/0]
&                Order By Key CLE = [F:STO2]ITMREF;[F:STO2]STOFCY;[F:STO2]LOT
    Else
     Link [STS1] With  [STO2]STO0 = [F:STS1]STOFCY;[F:STS1]STOCOU 
&                As    [SLO]
&                Where [F:STO2]ITMREF=WITM    &
&                      [F:STO2]LOT=WLOT       &
&                      [F:STS1]SERNUM >= LSER &
&                      [F:STS1]ISSDAT = [0/0/0]
&                Order By Key CLE = [F:STO2]ITMREF;[F:STO2]STOFCY;[F:STO2]LOT
    Endif
  Else
    If LCHR = 0
      Filter [STS1]  Where ITMREF= LITM       &
&                          SERNUM >= LSER     &
&                          [F:STS1]ISSDAT = [0/0/0]
&                    Order By Key STS0
    Else
      Filter [STS1]  Where STOCOU= LCHR       &
&                          SERNUM >= LSER     &
&                          [F:STS1]ISSDAT = [0/0/0]
&                    Order By Key STS1
    Endif
  Endif
Else
  If LLOT <> ""                  
    If LFCY <> ""
     Link [STS1] With  [STO2]STO0 = [F:STS1]STOFCY;[F:STS1]STOCOU 
&                As    [SLO]
&                Where [F:STO2]STOFCY=LFCY       &
&                      [F:STO2]ITMREF=LITM       &
&                      [F:STO2]LOT=LLOT          &
&                      [F:STS1]SERNUM >= LSER    &
&                      [F:STS1]ISSDAT <> [0/0/0] &   
&                      evalue(WFIL)
&                Order By Key CLE = [F:STO2]ITMREF;[F:STO2]STOFCY;[F:STO2]LOT
    Else
     Link [STS1] With  [STO2]STO0 = [F:STS1]STOFCY;[F:STS1]STOCOU 
&                As    [SLO]
&                Where [F:STO2]ITMREF=WITM       &
&                      [F:STO2]LOT=WLOT          &
&                      [F:STS1]SERNUM >= LSER    &
&                      [F:STS1]ISSDAT <> [0/0/0] &
&                      evalue(WFIL)
&                Order By Key CLE = [F:STO2]ITMREF;[F:STO2]STOFCY;[F:STO2]LOT
    Endif
  Else
    If LCHR = 0
#sr 270199 : Si visu des no de série depuis déclaration de production ou réception
#            on ne doit pas filtrer sur la date de sortie
#ts 080399 : Ni depuis livraison car si livraison de prêt, il n'y a pas de date de sortie 
      Case LTYP :                                        
           When 4,6,15 :  Filter [STS1]  Where ITMREF= LITM   &
&                             SERNUM >= LSER                  &
&                             evalue(WFIL)
&                             Order By Key STS0
           When Default : Filter [STS1]  Where ITMREF= LITM   &
&                             SERNUM >= LSER                  &
&                             [F:STS1]ISSDAT <> [0/0/0]       & 
&                             evalue(WFIL)
&                             Order By Key STS0
      Endcase
#sr 270199 : fin de la modif
    Else
      Filter [STS1]  Where STOCOU= LCHR              &
&                          SERNUM >= LSER            &
&                          [F:STS1]ISSDAT <> [0/0/0] &
&                          evalue(WFIL)
&                    Order By Key STS1
    Endif
  Endif
Endif
Affzo [STKD]5-10
###########################################################
#Lecture premier selectionné
If LLOT <> ""
  Raz [F:SLO] 
  Read [SLO]FIRST
Else
  Raz [F:STS1]  
  Read [STS1] First
Endif
$TRT_INI0
If fstat 
  Goto TRT_INI1
Endif
Gosub TRT_SEL
If ISEL  = 2
  WITM = [F:STS1]ITMREF
  WNUM = [F:STS1]SERNUM 
  Gosub PAG_SUI
  Return
Endif
If LLOT <> ""
  Raz [F:SLO]
  Read [SLO] Next
Else 
  Raz [F:STS1]
  Read [STS1] Next 
Endif
Goto TRT_INI0
#
$TRT_INI1 
WBOU(GPREM) = 0  
WBOU(GSUIV) = 0  
WBOU(GPREC) = 0  
WBOU(GDERN) = 0  
Call SETBOUT(WBOU) From GESECRAN  
Gosub DEL_TAB
[M:STKD]BASPAG2 = 0
nolign          = 1
Call MESSAGE(mess(99,100,1)) From GESECRAN 
Return
###########################################################
$PAG_SUI
#
Local Integer WDIM
WDIM = dim([M:STKD]SERNUM)
If [F:STS1]ITMREF = WITM & [F:STS1]SERNUM = WNUM 
  WBOU(GPREM) = 0  
  WBOU(GPREC) = 0  
  WBOU(GSUIV) = 1  
  WBOU(GDERN) = 1  
Else  
  WBOU(GPREM) = 1  
  WBOU(GPREC) = 1  
  WBOU(GSUIV) = 1  
  WBOU(GDERN) = 1  
Endif 
Call SETBOUT(WBOU) From GESECRAN   
#
Gosub DEL_TAB
[M:STKD]BASPAG2 = 0
nolign          = 1
$PAG_SUI1
If fstat = 0
  Gosub TRT_SEL
  If ISEL = 2  
    If [M:STKD]BASPAG2 < WDIM 
      [M:STKD] = [F:STS1]
      If LLOT = ""
        If [F:STS1]STOFCY <> [F:STO2]STOFCY | [F:STS1]STOCOU <> [F:STO2]STOCOU
            Read [STO2]STO0 = [F:STS1]STOFCY;[F:STS1]STOCOU
        Endif
      Endif
      If dim([M:STKD]LOC) > 0
        [M:STKD]LOC(nolign-1) = [F:STO2]LOC
      Endif
      If dim([M:STKD]LOT) >0 
        [M:STKD]LOT(nolign-1) = [F:STO2]LOT
      Endif
      nolign          += 1
      [M:STKD]BASPAG2 += 1
      Goto PAG_SUI2
    Else
      Goto PAG_SUI3
    Endif
  Else
    Goto PAG_SUI2
  Endif  
Else
  WBOU(GSUIV) = 0  
  WBOU(GDERN) = 0  
  Call SETBOUT(WBOU) From GESECRAN   
  Goto PAG_SUI3
Endif
#Lecture suivant
$PAG_SUI2
If LLOT <> ""
  Raz [F:SLO]
  Read [SLO]NEXT
Else
  Raz [F:STS1]
  Read [STS1] Next
Endif
Goto PAG_SUI1
$PAG_SUI3
Gosub AFF_TAB
nolign = 1
Return
###########################################################
#Pour selections ultérieures
$TRT_SEL
ISEL = 2
Return
###########################################################
#Traitement page précedente
$PAG_PRE
If WPRE <> 0
  WLEC = dim([M:STKD]SERNUM)-1
Else
  WLEC = ([M:STKD]BASPAG2+dim([M:STKD]SERNUM))
  If fstat : WLEC -= 1 : Endif
Endif
While WLEC <> 0 
If LLOT <> ""
  Read [SLO] Prev
Else
  Read [STS1] Prev
Endif
  If fstat 
    Break
  Endif
  Gosub TRT_SEL
  If ISEL = 2
    WLEC -= 1
  Endif
Wend
If fstat 
  If LLOT <> ""
    Raz [F:SLO]
    Read [SLO] First
  Else
    Raz [F:STS1]
    Read [STS1] First
  Endif
Endif
#
Gosub PAG_SUI
Return
###########################################################
$TRT_PRE
#Lecture premier
If LLOT <> ""
  Raz [SLO] 
  Read [SLO] First
Else
  Raz [F:STS1]
  Read [STS1] First
Endif
Gosub PAG_SUI
Return
###########################################################
$TRT_DER
If LLOT <> ""
  Read [SLO] Last
Else
  Read [STS1] Last
Endif
WPRE = 1
Gosub PAG_PRE
Return
############################################################
Subprog AV_BASPAG2
End
############################################################
Subprog AS_BPCNUMSEL(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AM_BPCNUMSEL(VALEUR)
Variable Char    VALEUR()
GBPCNUM = VALEUR
End
############################################################
Subprog AS_BPAADDSEL(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AM_BPAADDSEL(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AS_SDHNUMSEL(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AM_SDHNUMSEL(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AS_ALLFLG(VALEUR)
Variable Integer VALEUR
End
############################################################
Subprog AM_ALLFLG(VALEUR)
Variable Integer VALEUR
Raz [M:STKD]BPCNUMSEL, BPAADDSEL, SDHTYPSEL, SDHNUMSEL
Affzo [M:STKD]BPCNUMSEL
Affzo [M:STKD]BPAADDSEL
Affzo [M:STKD]SDHNUMSEL

End




