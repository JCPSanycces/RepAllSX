######################################################################################
Raz GPILOBJ
GBIDC1="200800000272"
GBIDC2="2009~ASN999999~20090101~1~1"
Call OBJET_CHAR(GBIDC1,"IDP",GBIDC2) From GOBJET
End

## Etiquette ajoutée par le superviseur (Objet IDP) 23/06/2009 17:34:23 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SEL_TABLE"
  Case TABLE
   When "SELEMPDDSI"   : Gosub SELEMPDDSI
  Endcase
 When "BS_WEMP"     : Gosub BS_WEMP
Endcase
Return

#######################################################################################################################################
# BOITE DE DIALOGUE + BOUTON NOUVEAU
#######################################################################################################################################
###################################

###################################
$INIT_DIA
Raz [M:DIA]
[M:DIA]WYEA=[F]YEAEMPDDS
[M:DIA]WEMP=[F]EMPDDS
[M:DIA]WCTR=[F]CTRNUM
[M:DIA]WFCY=[F]ETRFCY
[M:DIA]WETRDAT=[F]ETRDAT
[M:DIA]WXITDAT=[F]XITDAT
[M:DIA]WTYP=[F]TYPDAE
If GFONCTION="GESIDR"
 [M:DIA]WREFCTR=[F]REFCTR
 Read [IDP2]IDP0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR
 If !fstat
  [M:DIA]WNUMDCS=[F:IDP2]NUMDCS
 Endif
Endif
Return

###################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

###################################
$EXEC
If GFONCTION="GESIDR"
 Gosub NEWIDR
Else
 Gosub NEWIDP
Endif
Return

###################################
$NEWIDP
# Vérif existance fiche DADS-U
Read [IDA2]IDA0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;1
If fstat
 #Période d'activité salarié dads-u inexistante
 GMESSAGE = mess(80,10705,1)
 GERR = 1 : SAI = 1
 Return
Endif
# Vérif absence fiche Prévoyance DADS-U
Read [IDP2]IDP0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR
If !fstat
 #Ce contrat de prévoyance dads-u existe déjà
 GMESSAGE = [M:DIA]WREFCTR-":"-mess(82,10705,1)
 GERR = 1 : SAI = 1
 Return
Endif
# Vérif absence fiche Prévoyance DADS-U
Read [IDR2]IDR0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR;[M:DIA]WDATDEB
If !fstat
 #Une période de cotisations existe déjà en date du
 GMESSAGE = [M:DIA]WREFCTR-":"-mess(83,10705,1)-num$([M:DIA]WDATDEB)
 GERR = 1 : SAI = 1
 Return
Endif

SYMBOLE = "    "+[M:DIA]WYEA+"\"+[M:DIA]WEMP+"\"+[M:DIA]WCTR+"\"+[M:DIA]WREFCTR

Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif

Call DEBTRANS From GLOCK
Gosub TR1
Unlock =SYMBOLE
Return

###################################
$TR1
GOK=1
Trbegin [IDP2],[IDR2]
Raz[F:IDP2]
Gosub TR_IDP
If GOK : Gosub TR_IDR : Endif
If GOK<0    : Goto ROL_TR1
Elsif GOK=0 : Goto AB_TR1
Endif
Commit
Return

###################################
$TR_IDP
[F:IDP2]=[F:IDA2]
[F:IDP2]REFCTR=[M:DIA]WREFCTR
[F:IDP2]NUMDCS=[M:DIA]WNUMDCS
#Nb enfants
Call LECTURE("EML",[M:DIA]WEMP,"") From CONTOBJ
[F:IDP2]NBRCHD= num$([F:ID]CHD)
Write [IDP2]
If fstat<>0
 GOK = 0 : Call FSTA("HRIDP") From GLOCK
Endif
Return

###################################
$AB_TR1
Rollback
Return

###################################
$ROL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

##################################
$NEWIDR
# Vérif existance fiche prévoyance DADS-U
Read [IDP2]IDP0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR
If fstat
 #Contrat de prévoyance dads-u inexistant
 GMESSAGE = mess(81,10705,1)
 GERR = 1 : SAI = 1
 Return
Endif
# Vérif absence fiche Prévoyance DADS-U
Read [IDR2]IDR0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR;[M:DIA]WDATDEB
If !fstat
 #Une période de cotisations existe déjà en date du
 GMESSAGE = [M:DIA]WREFCTR-":"-mess(83,10705,1)-num$([M:DIA]WDATDEB)
 GERR = 1 : SAI = 1
 Return
Endif
SYMBOLE = "IDR"+[M:DIA]WYEA+"\"+[M:DIA]WEMP+"\"+[M:DIA]WCTR+"\"+[M:DIA]WREFCTR+"\"+[M:DIA]WDATDEB
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR2
Unlock =SYMBOLE
Return

###################################
$TR2
GOK=1
Trbegin[IDR2]
Gosub TR_IDR
If GOK<0    : Goto ROL_TR2
Elsif GOK=0 : Goto AB_TR2
Endif
Commit
Return

###################################
$TR_IDR
GOK=1
Raz[F:IDR2]
[F:IDR2]=[F:IDP2]
[F:IDR2]STRDATCTR=[M:DIA]WDATDEB
[F:IDR2]ENDDATCTR=[M:DIA]WDATFIN
Write [IDR2]
If fstat<>0
 GOK = 0 : Call FSTA("IDR") From GLOCK
Endif
Return

###################################
$AB_TR2
Rollback
Return

###################################
$ROL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

###################################
$SELEMPDDSI
Local Char ANCOUR (4)
ANCOUR=PARAM(1)
Case GFONCTION
 When "GESIDR" : OBJET = "IDP" : CRITERE = "YEAEMPDDS='"+PARAM(1)+"'"
 When "GESIDV" : OBJET = "IDU" : CRITERE = "YEAEMPDDS='"+PARAM(1)+"'"
 When Default  : OBJET = "IDA" : CRITERE = "YEAEMPDDS='"+PARAM(1)+"' & FLGDNA=1"
Endcase
If VALEUR<>""
 CRITERE -= "& EMPDDS>='"+VALEUR+"'" 
Endif
START = "EMPDDS"
Return

###################################
$BS_WEMP
Gosub DEFTAB
Gosub AFFDIA
Return

###################################
$DEFTAB
Case GFONCTION
 When "GESIDR" : Default File [HRIDP]
 When "GESIDV" : Default File [IDU]
 When Default  : Default File [IDA]
Endcase
Return

###################################
$AFFDIA
[M:DIA]WCTR=[F]CTRNUM
[M:DIA]WFCY=[F]ETRFCY
[M:DIA]WETRDAT=[F]ETRDAT
[M:DIA]WXITDAT=[F]XITDAT
[M:DIA]WTYP=[F]TYPDAE
If GFONCTION="GESIDR" |  GFONCTION="GESIDV"
 [M:DIA]WREFCTR=[F]REFCTR
 [M:DIA]WNUMDCS=[F]NUMDCS
Endif
Affzo [M:DIA]
Return

#########################################################################################################
# Ecran
#########################################################################################################

Subprog AS_WYEA(VALEUR)
Variable Char    VALEUR()
Local Char VALPAR (10)
If VALEUR=""
 Call PARAM("","IDADAT",VALPAR) From ADOVAL
 If VALPAR<>""
  VALEUR=num$(year(VALPAR))
 Else
  VALEUR=num$(year(date$))
 Endif
Endif
If GFONCTION ="GESHRIDP" | GFONCTION ="GESIDU" 
 Grizo [M:DIA]25
Elsif GFONCTION ="GESIDR" | GFONCTION ="GESIDV"
 Grizo [M:DIA]15
 Grizo [M:DIA]25
Endif
End

###################################
Subprog C_WEMP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Gosub DEFTAB
If VALEUR<>[M:DIA]WEMP & VALEUR<>[F]EMPDDS
 If GFONCTION="GESIDR" 
  Filter [HRIDP] Where YEAEMPDDS=[M:DIA]WYEA & EMPDDS=VALEUR
  Read [HRIDP]IDP0 First
  Filter [HRIDP]
 #59275
 Elsif GFONCTION ="GESIDV"
  Filter [IDU] Where YEAEMPDDS=[M:DIA]WYEA & EMPDDS=VALEUR
  Read [IDU]IDU0 First
  Filter [IDU]
 Else 
  Filter [IDA] Where YEAEMPDDS=[M:DIA]WYEA & EMPDDS=VALEUR & FLGDNA=1
  Read [IDA]IDA0 First
  Filter [IDA]
 Endif
 If !fstat 
  Gosub AFFDIA
 Else
  GMESSAGE=mess(23,100,1) #: Fiche inexistante
  mkstat=2 : End
 Endif
Endif
Call LECTURE("EML",VALEUR,"") From CONTOBJ
If [F:ID]FLGMULCTR=2
 Effzo [M:DIA]WCTR
 Actzo [M:DIA]WCTR
Else
 Grizo [M:DIA]WCTR
Endif
End

###################################
Subprog AS_WCTR(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call SELCTR([M]WEMP,[M]WETRDAT,[M]WXITDAT,VALEUR) From DIVPAYE
Endif
End

###################################
Subprog S_WCTR(VALEUR)
Variable Char    VALEUR()
Call SELCTR([M]WEMP,[M]WETRDAT,[M]WXITDAT,VALEUR) From DIVPAYE
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran IDPC) 30/07/2009 17:18:45 (DBA)
######################################################################################
Subprog C_WDATDEB(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR<[M:DIA]WETRDAT | VALEUR>[M:DIA]WXITDAT
 #Valeur non autorisée
  GMESSAGE=mess(100,10703,1)
  mkstat=2 : End
Endif
If VALEUR<>[M:DIA]WETRDAT 
 #Un évènement salarié doit obligatoirement être renseigné pour justififier le décalage avec la période d'activité
 Call AVERTIR (mess(79,10705,1), OK) From GESECRAN
 If OK=1 : mkstat=2 : End : Endif
Endif
End

Subprog C_WDATFIN(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR<[M:DIA]WETRDAT | VALEUR>[M:DIA]WXITDAT
 #Valeur non autorisée
  GMESSAGE=mess(100,10703,1)
  mkstat=2 : End
Endif
If VALEUR<>[M:DIA]WXITDAT & [M:DIA]WDATDEB=[M:DIA]WETRDAT
 #Un évènement salarié doit obligatoirement être renseigné pour justififier le décalage avec la période d'activité
 Call AVERTIR (mess(79,10705,1), OK) From GESECRAN
 If OK=1 : mkstat=2 : End : Endif
Endif
End


