#<AdxTL>@(#)2.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# delete BATCHRUN and BATCHSTOP task and Recurring tasks
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Delete BATCHRUN and BATCHSTOP") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#
$MAJTAB

Local File ABATTAC [ABT] :# CODTAC,FONCTION
Local File ABATABT [ABA] :# CODABT,TACHE
Local File ABATABTD [ABD] :# ABD0: CODABT, CODTAC
Local Char CODE (30)

Trbegin [ABT],[ABA],[ABD]
 For CODE="BATCHRUN","BATCHSTOP"
  For [ABT] Where FONCTION=[L]CODE
   For [ABA] Where TACHE=[F:ABT]CODTAC
    #Call ECR_TRACE("deleting Recurring tasks"-[F:ABA]CODABT,0) From GESECRAN
    Delete [ABD] Where CODABT=[F:ABA]CODABT
    Delete [ABA] Curr
   Next
   #Call ECR_TRACE("deleting Tasks"-[F:ABT]CODTAC,0) From GESECRAN
   Delete [ABT] Curr
  Next
 Next

 For CODE="BATCHRUN","BATCHSTOP"
  For [ABA] Where TACHE=[L]CODE
   #Call ECR_TRACE("deleting Recurring tasks"-[F:ABA]CODABT,0) From GESECRAN
   Delete [ABD] Where CODABT=[F:ABA]CODABT
   Delete [ABA] Curr
  Next
 Next
Commit

Close Local File [ABT],[ABA],[ABD]
Return

