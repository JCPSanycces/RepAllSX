##################################################################################################
# SUBTGLB    Dictionnaire des cibles                    Module CRM                15 mars 2002   #
#                                                                                                #
# Sous-programmes utilitaires                                                                    #
##################################################################################################
#                                                                                                #
# SETTABSRT  : Définie si le champ table de tri est grisé ou non.                                #
# LOADFIE    : Charge une description des champs.                                                #
# SAVEFIE    : Enregistre une description des champs.                                            #
# CHKFIESRT  : Vérifie la présence du champ de tri dans les quinzes premières lignes du tableau  #
# SETUSERTGP : Définit le nouveau support de présentation personnel d'un utilisateur             #
#                                                                                                #
##################################################################################################
##########################################################################################################
# Définie si le champ table de tri est grisé ou non.
##################################################################################################
Subprog SETTABSRT(SZTAB)
Value Char SZTAB

Local Integer Z2
Local Integer IFOUND

  IFOUND = 0
  For Z2 = 0 To [M:TGP1]NBFIE-1
    If [M:TGP1]TGRFIE(Z2) = [M:TGP1]FIESRT Then
      IFOUND += 1
    Endif
  Next
  If IFOUND > 1 Then
    Actzo [M:TGP1]TABSRT
  Else
    Grizo [M:TGP1]TABSRT
  Endif
  Affzo [M:TGP1]TABSRT
End

##################################################################################################
# Charge une description des champs.
##################################################################################################
Subprog LOADFIE(SZCRITAB, SZSSPDEF)
Value Char SZCRITAB
Value Char SZSSPDEF

Local Integer INBFIE
Local Integer ITER
Local Char SZTEXTE(GLONDCO)
Local Char SZLEFTCRIFIE(GLONAVA)

  ITER = 0
  INBFIE = 0
  SZTEXTE = ""
  Raz [M:TGP1]NBFIE
  Raz [M:TGP1]TGRTABLNK
  Raz [M:TGP1]TGRFIE
  Raz [M:TGP1]TGRFIEORD
  #---------------------------------------------------#
  #On charge une description personnalisée.
  Filter [TLF] Where [F:TLF]TGRTAB = SZCRITAB and [F:TLF]TGRSSPNUM = SZSSPDEF
  For [TLF]TLF1
    If INBFIE >= dim([M:TGP1]TGRFIE) Then
      Break
    Endif
    [M:TGP1]TGRTABLNK(INBFIE) = [F:TLF]TGRTABLNK
    [M:TGP1]TGRFIE(INBFIE) = [F:TLF]TGRFIE
    Read [FDF]FDF0=[M:TGP1]TGRTABLNK(INBFIE);[M:TGP1]TGRFIE(INBFIE);GAUSCRMI
    If fstat Then
      Read [FDF]FDF0=[M:TGP1]TGRTABLNK(INBFIE);[M:TGP1]TGRFIE(INBFIE);""
      If fstat Then
        # FGR 12/01/2009 : X3SUIVI51579
        SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([M:TGP1]TGRFIE(INBFIE))
        Read [ATZ]CODZONE=[M:TGP1]TGRTABLNK(INBFIE);SZLEFTCRIFIE
        If fstat Then
          [M:TGP1]TGRFIENAM(INBFIE) = ""
        Else
          Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
          [M:TGP1]TGRFIENAM(INBFIE) = left$(SZTEXTE, GLONDCO)
        Endif
      Else
        Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
        [M:TGP1]TGRFIENAM(INBFIE) = left$(SZTEXTE, GLONDCO)
      Endif
    Else
      Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
      [M:TGP1]TGRFIENAM(INBFIE) = left$(SZTEXTE, GLONDCO)
    Endif
    [M:TGP1]TGRFIEORD(INBFIE) = [F:TLF]TGRFIEORD
    INBFIE += 1
  Next
  Filter [TLF]
  [M:TGP1]NBFIE = INBFIE
  If [M:TGP1]NBFIE > 0 Then
    Gosub UNDER15
    End
  Endif
  #---------------------------------------------------#
  #On charge à partir des critères de ciblage
  Read [FID]FID0=SZCRITAB;GAUSCRMI
  If fstat Then
    Read [FID]FID0=SZCRITAB;""
    If !fstat Then
      Filter [FDF] Where [F:FDF]CRITAB = SZCRITAB and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = "" Order By [F:FDF]SELCRISRT Asc
      For [FDF] Hint Key FDF0
        If INBFIE >= dim([M:TGP1]TGRFIE) Then
          Break
        Endif
        [M:TGP1]TGRTABLNK(INBFIE) = SZCRITAB
        [M:TGP1]TGRFIE(INBFIE) = [F:FDF]SELCRIFIE
        # FGR 12/01/2009 : X3SUIVI51579
        SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([M:TGP1]TGRFIE(INBFIE))
        Read [ATZ]CODZONE=[M:TGP1]TGRTABLNK(INBFIE);SZLEFTCRIFIE
        If fstat Then
          [M:TGP1]TGRFIENAM(INBFIE) = ""
        Else
          Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
          [M:TGP1]TGRFIENAM(INBFIE) = left$(SZTEXTE, GLONDCO)
        Endif
        [M:TGP1]TGRFIEORD(INBFIE) = [F:FDF]SELCRISRT
        INBFIE += 1
      Next
      Filter [FDF]
      [M:TGP1]NBFIE = INBFIE
    Endif
  Else
    Filter [FDF] Where [F:FDF]CRITAB = SZCRITAB and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = GAUSCRMI Order By [F:FDF]SELCRISRT Asc
    For [FDF] Hint Key FDF0
      If INBFIE >= dim([M:TGP1]TGRFIE) Then
        Break
      Endif
      [M:TGP1]TGRTABLNK(INBFIE) = SZCRITAB
      [M:TGP1]TGRFIE(INBFIE) = [F:FDF]SELCRIFIE
      # FGR 12/01/2009 : X3SUIVI51579
      SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([M:TGP1]TGRFIE(INBFIE))
      Read [ATZ]CODZONE=[M:TGP1]TGRTABLNK(INBFIE);SZLEFTCRIFIE
      If fstat Then
        [M:TGP1]TGRFIENAM(INBFIE) = ""
      Else
        Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
        [M:TGP1]TGRFIENAM(INBFIE) = left$(SZTEXTE, GLONDCO)
      Endif
      [M:TGP1]TGRFIEORD(INBFIE) = [F:FDF]SELCRISRT
      INBFIE += 1
    Next
    Filter [FDF]
    [M:TGP1]NBFIE = INBFIE
  Endif
  If [M:TGP1]NBFIE > 0 Then
    Gosub UNDER15
    End
  Endif
  #---------------------------------------------------#
  # On charge à partir de la personnalisation objet de la table.
  Read [ATB]CODFIC=SZCRITAB
  If !fstat Then
    Read [AOL]AOL0=[F:ATB]ABRFIC
    If !fstat Then
      Read [AOB]ABREV=[F:ATB]ABRFIC
      If !fstat Then
        If [F:AOB]NOMFIC = SZCRITAB Then
          #On charge les champs
          For ITER = 0 To dim([F:AOL]SELZON)-1
            If [F:AOL]SELZON(ITER) <> "" Then
              If [F:AOL]SELFIC(ITER) = SZCRITAB Then
                [M:TGP1]TGRTABLNK(INBFIE) = [F:AOL]SELFIC(ITER)
                [M:TGP1]TGRFIE(INBFIE) = [F:AOL]SELZON(ITER)
                # FGR 12/01/2009 : X3SUIVI51579
                SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([M:TGP1]TGRFIE(INBFIE))
                Read [ATZ]CODZONE=[M:TGP1]TGRTABLNK(INBFIE);SZLEFTCRIFIE
                If fstat Then
                  [M:TGP1]TGRFIENAM(INBFIE) = ""
                Else
                  Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
                  [M:TGP1]TGRFIENAM(INBFIE) = left$(SZTEXTE, GLONDCO)
                Endif
                [M:TGP1]TGRFIEORD(INBFIE) = INBFIE + 1
                INBFIE += 1
              Endif
            Endif
          Next
          [M:TGP1]NBFIE = INBFIE
        Endif
      Endif
    Endif
  Endif
  If [M:TGP1]NBFIE > 0 Then
    Gosub UNDER15
    End
  Endif
  #---------------------------------------------------#
  # On charge à partir du dictionnaire des tables standards X3
  Filter [ATZ] Where [F:ATZ]CODFIC = SZCRITAB
  For [ATZ] CODZONE
    If INBFIE >= dim([M:TGP1]TGRFIE) Then
      Break
    Endif
    [M:TGP1]TGRTABLNK(INBFIE) = SZCRITAB
    [M:TGP1]TGRFIE(INBFIE) = [F:ATZ]CODZONE
    Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
    [M:TGP1]TGRFIENAM(INBFIE) = left$(SZTEXTE, GLONDCO)
    [M:TGP1]TGRFIEORD(INBFIE) = INBFIE + 1
    INBFIE += 1
  Next
  Filter [ATZ]
  [M:TGP1]NBFIE = INBFIE
  Gosub UNDER15
End

##########################################################################################################
#On s'assure que la champs de tri soit toujours dans les quinze premiers
################################################################################
$UNDER15
  If [M:TGP1]NBFIE > 15 Then
    For ITER = 15 To [M:TGP1]NBFIE-1
      If [M:TGP1]TGRFIE(ITER) = [M:TGP1]FIESRT Then
        [M:TGP1]TGRFIEORD(ITER) = 1
      Endif
    Next
  Endif
Return

##########################################################################################################
# Enregistre une description des champs.
##################################################################################################
$SAVEFIE
Local Integer IFIEITER
Local Integer ITGLPBL

  ITGLPBL = 0
  #On efface tout et on recommence
  Delete [TLF] Where [F:TLF]TGRTAB = [M:TGP0]TGR and [F:TLF]TGRSSPNUM = [M:TGP0]TGRSSPNUM
  If fstat Then
    ITGLPBL = 1
    GOK = 0
    Call FSTA("TLF") From GLOCK
    Return
  Endif
  #Enregistre le tableau des champs affichés
  For IFIEITER = 0 To [M:TGP1]NBFIE-1
    If [M:TGP1]TGRTABLNK(IFIEITER) <> "" Then
      If [M:TGP1]TGRFIE(IFIEITER) <> "" Then
        [F:TLF]TGRTAB = [M:TGP0]TGR
        [F:TLF]TGRSSPNUM = [M:TGP0]TGRSSPNUM
        [F:TLF]TGRTABLNK = [M:TGP1]TGRTABLNK(IFIEITER)
        [F:TLF]TGRFIE = [M:TGP1]TGRFIE(IFIEITER)
        [F:TLF]TGRFIEORD = [M:TGP1]TGRFIEORD(IFIEITER)
        [F:TLF]TGRFIESTD = 0
        Write [TLF]
        If fstat Then
          ITGLPBL = 1
          GOK = 0
          Call FSTA("TLF") From GLOCK
        Endif
      Endif
    Endif
    If ITGLPBL Then
      Break
    Endif
  Next
  If ITGLPBL Then
    Return
  Endif
Return

##########################################################################################################
# Charge une description des tables liées
##################################################################################################
Subprog LOADLNK(SZCRITAB)
Value Char SZCRITAB

Local Integer INBLNK

  INBLNK = 0
  Raz [M:TGL3]NBLNK
  Raz [M:TGL3]TGRLNK
  Raz [M:TGL3]TGRLNKIDX
  Raz [M:TGL3]TGREXPLNK
  Filter [TLL] Where [F:TLL]TGRTAB = SZCRITAB
  For [TLL]
    If INBLNK >= dim([M:TGL3]TGRLNK) Then
      Break
    Endif
    [M:TGL3]TGRLNK(INBLNK) = [F:TLL]TGRLNK
    [M:TGL3]TGRLNKIDX(INBLNK) = [F:TLL]TGRLNKIDX
    [M:TGL3]TGREXPLNK(INBLNK) = [F:TLL]TGREXPLNK
    INBLNK += 1
  Next
  Filter [TLL]
  [M:TGL3]NBLNK = INBLNK
End

##########################################################################################################
# Vérifie la présence du champ de tri dans les quinzes premières lignes du tableau des champs affichés
#######################################################################
$CHKFIESRT
Local Integer ITERZ
Local Integer IFIEFOUND
Local Integer IFIEORD([M:TGP1]NBFIE)
Local Char SZFIENAM(30)([M:TGP1]NBFIE)

  Raz SZFIENAM
  Raz IFIEORD
  IFIEFOUND = 0
  For ITERZ = 0 To [M:TGP1]NBFIE-1
    IFIEORD(ITERZ) = [M:TGP1]TGRFIEORD(ITERZ)
    SZFIENAM(ITERZ) = [M:TGP1]TGRFIE(ITERZ)
  Next
  Sorta IFIEORD, SZFIENAM
  For ITERZ = 0 To 14
    If ITERZ >= [M:TGP1]NBFIE Then
      Break
    Endif
    If SZFIENAM(ITERZ) = [M:TGP1]FIESRT Then
      IFIEFOUND = 1
      Break
    Endif
  Next
  If !IFIEFOUND Then
    #Le champ de tri n'est pas inclus dans l'une des quinze premières lignes de la liste ci-dessus.
    GMESSAGE = mess(718,196,1)
    GERR = 3
    OK = 0
  Endif
Return

##########################################################################################################
# Définit le nouveau support de présentation personnel d'un utilisateur
##########################################################################
Subprog SETUSERTGP(SZUSERSSP, SZDVATGR)
Value Char SZUSERSSP
Value Char SZDVATGR

Local Char SZDVAPARAM(100)

  If SZDVATGR = "" Then
    End
  Endif
  SZDVAPARAM = GUSER + SZDVATGR
  #Enregistre le nouveau support par défaut
  Read [DVA]="TGP";SZDVAPARAM
  If fstat Then
    Call DEBTRANS From GLOCK
    Trbegin [DVA]
    [F:DVA]OBC = "TGP"
    [F:DVA]PARAM = SZDVAPARAM
    [F:DVA]ALHX(0) = SZUSERSSP
    Write [DVA]
    If fstat Then
      #Erreur lors de l'enregistrement du support par défaut de l'utilisateur.
      GMESSAGE = mess(765,196,1)
      GERR = 1
      Rollback
    Else
      Commit
    Endif
  Else
    Call DEBTRANS From GLOCK
    Trbegin [DVA]
    Readlock [DVA]="TGP";SZDVAPARAM
    If fstat Then
      #Erreur lors de l'enregistrement du support par défaut de l'utilisateur.
      GMESSAGE = mess(765,196,1)
      GERR = 1
      Rollback
    Else
      [F:DVA]OBC = "TGP"
      [F:DVA]PARAM = SZDVAPARAM
      [F:DVA]ALHX(0) = SZUSERSSP
      Rewrite [DVA]
      If fstat Then
        #Erreur lors de l'enregistrement du support par défaut de l'utilisateur.
        GMESSAGE = mess(765,196,1)
        GERR = 1
        Rollback
      Else
        Commit
        Unlock [DVA]
      Endif
    Endif
  Endif
End
