#CHECK UNUSED_SOURCE
##############################################################################
##
## DEBUGVALID
##
## programme destiner à valider les développement du fonctionnement
## du debugger en mode web
##
## - mise au point du dialogue en UTF16 sur la socket
##
##
##
##############################################################################


Local Char    DBG_HOST(255)
Local Char    DBG_PORT(255)
Local Char    DBG_SESTYPE(5)        : # type de la session
Local Char    DBG_SESWEIGHT(3)      : # poids de la session

[L]DBG_HOST = "gattazmpro.ech.adx"
[L]DBG_PORT = "1789"
[L]DBG_SESTYPE = "X3_CS"
[L]DBG_SESWEIGHT =  "NA1"

Local File ZZDEBUGGER[LDB]

[LDB]DBG_SEPAR   = "¤¨¤"
[LDB]DBG_TRACON=0

    # Ouverture Socket pour Debug Intradon sur poste client
    Opsock [L]DBG_HOST,val([L]DBG_PORT) Using [OPS]
    Seek 0 Using [OPS]

    Onerrgo :# pour supprimer le débranchement sur erreur
    
    #envoi de la commande 01 = "open" 
    Call SEND_OPEN ([L]DBG_SESTYPE,[L]DBG_SESWEIGHT,"test from DEBUGGERTEST") From DEBUGGER






    # fermeture Socket pour Debug Intradon sur poste client
    Call SEND_CLOSE() From DEBUGGER

    Opsock [L]DBG_HOST,0 Using [OPS]

End
