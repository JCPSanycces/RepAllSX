###########################################################
Subprog AV_TRKENDDAT(VALEUR)
Variable Date     VALEUR
If VALEUR = [M:QLC2]TRKSTRDAT
  VALEUR = [0/0/0]
Endif
End
###########################################################
Subprog AV_MVTSEQ1(VALEUR)
Variable Decimal  VALEUR
VALEUR = (10000 - [M:QLC2]MVTSEQ)
End
Subprog AP_MVTSEQ1(VALEUR)
Variable Decimal  VALEUR
[M:QLC2]MVTSEQ = (10000 - VALEUR)
End
Subprog C_MVTSEQ1(VALEUR)
Variable Decimal  VALEUR
If VALEUR < 1 | VALEUR > 9999
  mkstat = 2
Endif
End
