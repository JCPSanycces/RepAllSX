#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTICRM201801001
# Issue X3-67352 - 2017-12-11 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTICRM201801001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTICRM201801001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE
Local Char SCHAINE(30)

  Call ECR_TRACE("UTICRM201801001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".AOBJEXT"    [AOE]
  Local File =DOSSIER + ".AOBJEXTD"   [AOD]
  Local File =DOSSIER + ".ATEXTRA"    [AXX]
  Local File =DOSSIER + ".AREPORTV"   [ARV]
  Local File =DOSSIER + ".AREPORTX"   [ARX]
  # --------------------------
  Raz COMPTEUR
  Trbegin [AOE]
  # --------------------------
  SCHAINE = "OPP"
  Delete [AOE] Where EXT=SCHAINE
  If fstat Then
    Call ECR_TRACE("File AOBJEXT" - SCHAINE + ", Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  COMPTEUR += adxdlrec
  #
  Delete [AOD] Where EXT=SCHAINE
  If fstat Then
    Call ECR_TRACE("File AOBJEXTD" - SCHAINE + ", Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  COMPTEUR += adxdlrec
  #
  Delete [AXX] Where CODFIC="AOBJEXT" & ZONE="INTIT"  & IDENT1=SCHAINE
  If fstat=1 | fstat>5 Then
    Call ECR_TRACE("File ATEXTRA" - SCHAINE + ", Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  COMPTEUR += adxdlrec
  #
  Delete [AXX] Where CODFIC="AOBJEXTD" & ZONE="INTFLD"  & IDENT1=SCHAINE
  If fstat=1 | fstat>5
    Call ECR_TRACE("File ATEXTRA" - SCHAINE + ", Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  COMPTEUR += adxdlrec
  #
  Delete [ARV] Where TYPCOD=4 & ETAT = SCHAINE
  If fstat
    Call ECR_TRACE("File AREPORTV" - SCHAINE + ", Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  COMPTEUR += adxdlrec
  #
  Delete [ARX] Where TYPCOD=4 & EXTCOD = SCHAINE
  If fstat
    Call ECR_TRACE("File AREPORTX" - SCHAINE + ", Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  COMPTEUR += adxdlrec
  # --------------------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTICRM201801001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTICRM201801001 : records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI <> GDOSX3 and GADONIX <> 2 Then
    # Only on X3 folder or all the time when GADONIX=2
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","AOBJEXT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AOBJEXT") : End : Endif
  If filinfo(filpath("FIL","AOBJEXTD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AOBJEXTD") : End : Endif
  If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATEXTRA") : End : Endif
  If filinfo(filpath("FIL","AREPORTV","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AREPORTV") : End : Endif
  If filinfo(filpath("FIL","AREPORTX","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AREPORTX") : End : Endif
  # -------------------------
  Call MAJ_UTICRM201801001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI <> GDOSX3 and GADONIX <> 2 Then
    # Only on X3 folder or all the time when GADONIX=2
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","AOBJEXT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AOBJEXT") : End : Endif
  If filinfo(filpath("FIL","AOBJEXTD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AOBJEXTD") : End : Endif
  If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATEXTRA") : End : Endif
  If filinfo(filpath("FIL","AREPORTV","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AREPORTV") : End : Endif
  If filinfo(filpath("FIL","AREPORTX","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AREPORTX") : End : Endif
  # -------------------------
  Call MAJ_UTICRM201801001(APPLI)
End

