#<AdxTL>@(#)9.0.0.0 $Revision$
Call CREFOLDERS
End
Call DETARX3CLI("")
End

#  VALCSTWEB                                        CC 20/01/2010
#                                                   DOM 21/02/2012
#
#
#             Génération des constantes Web
#
#   INILIBW          - Intitulés Web (menus 151,152 et 9802 à 9810  + 9801+9832)
#   COPIEMEN         - Pecd ;;:;;rmet de copier les XML d'un profil A en B
#   INIX3CLI         - Menu 151, 152, création répertoires d'X3CLI, parsage des fenêtres
#   CREFOLDERS       - Création de la table XML de description des dossiers (FOLDERS.xml)
#   CRELOCALP        - Création des pages locales dans la langue "LANG" dans X3_CLIENT
#   DETARPORTAL      - Recrée un nouveau portail à partir des archives .tar
#   DETARX3CLI       - Detare l'arborescence Xblock nécessaire au fonctionnement des blocs graphiques
#   DETARRES         - Detare l'arborescence des ressources RESSTD, RESVER ou RESPER
#   INILIBMEN        - Crée le fichier MENU.xml pour toutes les langues de la solution
#   INIONEMEN        - Crée le fichier MENU.xml pour une langue
#   DETARX3CLIENT    - Detare l'arborescence X3_CLIENT utilisée pour les prévisu
#
#-------------------------------------------------------------------------------------
#              Initialisation des libellés Web (menus  9802 à 9810 + FILE=9801+9832)

Subprog INILIBW(APPLI)

Value Char APPLI

Local Char TEXT(200),VALL1(200),REPERT(200)
Local Char NOMFIC(250),LANCOU,KEYS,WE_HORDAT(14)
Local Integer NBVAL,I,J,NOMEN,NOMES,TREC
Local Char TLAN(GLONLAN)(1..50)
Local Integer NBLAN

Call GLOBWEB(APPLI) From INTRUTILA
Call ENVVAR(WE_HORDAT) From INTRUTILA

If clalev([F:AST])=0  : Local File =GI_DOSS+".APLSTD" [AST]  : Endif
If clalev([F:AST1])=0 : Local File =GI_DOSS+".APLSTD" [AST1] : Endif
If clalev([F:AEL])=0  : Local File =GI_DOSS+".AELT" [AEL]    : Endif

If adxlog=0
 Trbegin [AEL]
 TREC=1
Endif
For I=1 To GI_NBLAN
  LANCOU=GI_LLAN(I)
  Gosub CREREPSRV
  For NOMEN=9802 To 9810
    Gosub CRESRVL
  Next NOMEN
Local Integer SRV151
  NOMEN=151
  Gosub CRESRVL
  NOMEN=152
  Gosub CRESRVL
Kill SRV151
Next I


#                          Libellés du menu fichier  (définis dans les menus locaux 9832 et 9801)

Local Integer XID,XIDF,RG
Local Integer TBOUT(1..3,1..50),NBBOUT
Local Char CBOUT(20)(1..50)
#  TBOUT(1,I)      : 1- Bouton 2-Menu  3-Ligne
#  TBOUT(2,I)      : No d'action
#  TBOUT(3,I)      : No de l'entrée de menu
#  CBOUT(I)        : Code de l'entrée



For I=1 To 100
  If len(mess(I,9832,1))=0 : Break 1 : Endif
  RG+=1
  NBBOUT+=1
  Case right$(mess(I,9832,1),len(mess(I,9832,1)))
    When "M" : TBOUT(1,I)=2
    When "L" : TBOUT(1,I)=3
    When "B" : TBOUT(1,I)=1
  Endcase
  If len(mess(I,9832,1))>6
    TBOUT(2,NBBOUT)=val(mid$(mess(I,9832,1),5,len(mess(I,9832,1))-6))
  Endif
  TBOUT(3,NBBOUT)=RG
  CBOUT(NBBOUT)=left$(mess(I,9832,1),3)
Next I


XIDF=2163457
XID=XIDF
KEYS="FILE"
For J=1 To GI_NBLAN
  LANCOU=GI_LLAN(J)
  Call NAMEFIC(GI_DOSS,"SRVL",LANCOU,"FILE",NOMFIC) From INTRUTILA

  Openo NOMFIC,0 Using [CST_]
  Iomode adxifs "" Using [CST_]
  Iomode adxirs chr$(10) Using [CST_]
  Iomode adxium GUTF8 Using [CST_]
  VALL1='<?xml version="1.0" encoding="utf-8" ?>'
  Wrseq VALL1 Using [CST_]
  For I=1 To NBBOUT
    Case TBOUT(1,I)
      When 1
        If TBOUT(2,I)>0
          XID+=1
          VALL1='<ITM XID="'+num$(XID)+'" IDF="'+num$(XIDF)+'" NAC="'+num$(TBOUT(2,I))+'" C="'
          Gosub CRELIBFILE
          VALL1+=TEXT+'"/>'
          Wrseq VALL1 Using [CST_]
        Endif
      When 2
        VALL1='<MAW XID="'+num$(XIDF)+'" TIME="'+WE_HORDAT+'" C="'
        Gosub CRELIBFILE
        VALL1+=TEXT+'">'
        Wrseq VALL1 Using [CST_]
      When 3
        VALL1='<LIG/>'
        Wrseq VALL1 Using [CST_]
    Endcase
  Next I
  VALL1="</MAW>"
  Wrseq VALL1 Using [CST_]
  Openo Using [CST_]
  Gosub WI_CRESRVL From INTRUTILB
Next J

If TREC=1 : Commit : Endif
End

#-----------------------------------------------------------------------

Subprog COPIEMEN(DOSS,LANG,MENDEP,MENRES)
Value Char DOSS,LANG,MENDEP,MENRES

#  Phase 1 : Recherche les menus MENDEP à copier

Local Integer NBMEN,POSK,STAT
Local Char LMEN(100)(1..100)
Local Char REP(GDIMFIC),NAMEREP(GDIMFIC),NAMEREP1(GDIMFIC)
Local Char MACHINE(GDIMFIC),ORDRE(250),MENRES1(50),OPT

If clalev([F:HLP_])>0 : Close Local File [HLP_] : Endif
Call NAMEFIC(DOSS,"PROF",LANG,"",REP) From INTRUTILA
NAMEREP=filpath(REP,"","","X3_PUB")
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
Local File (HLP(30)) From System adxmac(0)+'@lsadx -a'-toupper(nomap(0))-NAMEREP As [HLP_]
For [HLP_] Where HLP<>""
 If [F:HLP_]HLP=MENDEP+".xml" or left$([F:HLP_]HLP,len(MENDEP)+1)=MENDEP+"-"
   NBMEN+=1
   LMEN(NBMEN)=left$([F:HLP_]HLP,len([F:HLP_]HLP)-4)
 Endif
Next HLP_
If NBMEN=0 : End : Endif


#  Phase 2 : Copie les menus MENDEP en MENRES

For indice=1 To NBMEN
  NAMEREP=filpath(REP,LMEN(indice),"xml","X3_PUB")
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  MENRES1=MENRES+right$(LMEN(indice),len(MENDEP)+1)
  NAMEREP1=filpath(REP,MENRES1,"xml","X3_PUB")
  POSK = instr(1,NAMEREP1,"@")
  If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
  ORDRE="ae_cp "+NAMEREP-NAMEREP1
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Next indice

End


# ---------------------------------------------------------------------------------------

Subprog INIX3CLI(APPLI)

Value Char APPLI

Local Char TEXT(200),VALL1(200),REPERT(200)
Local Char NOMFIC(250),LANCOU,KEYS,WE_HORDAT(14)
Local Integer NBVAL,I,J,NOMEN,NOMES
Local Char TLAN(GLONLAN)(1..50)
Local Integer NBLAN

Call GLOBWEB(APPLI) From INTRUTILA
Call ENVVAR(WE_HORDAT) From INTRUTILA

Call GLOBLANG(TLAN,NBLAN) From INTRUTILA
#For I=7 To 0 Step -1
#  If adxmother(I)<>""
#    GI_DOSS=adxmother(I)
#    Break 1
#  Endif
#Next I
If clalev([F:AST])=0  : Local File =GI_DOSS+".APLSTD" [AST]    : Endif
If clalev([F:AST1])=0 : Local File =GI_DOSS+".APLSTD" [AST1]   : Endif
If clalev([F:AEL])=0  : Local File =GI_DOSS+".AELT"   [AEL]    : Endif


Trbegin [AEL]

For I=1 To NBLAN
  LANCOU=GI_LLAN(I)
  Gosub CREREPSRV
  NOMEN=151
  Gosub CRESRVL
  NOMEN=152
  Gosub CRESRVL
Next I
Commit

# Libellés et organisation du bandeau menu
Call INILIBMEN(nomap)



End


# ---------------------------------------------------------------------------------------

$CRESRVL
    KEYS="M"+format$("N0:"+func GENMENULOC.FMTMNL(NOMEN),NOMEN)
    If (NOMEN<>151 and NOMEN<>152) or dim(SRV151)>0
      Call NAMEFIC(GI_DOSS,"SRVL",LANCOU,KEYS,NOMFIC) From INTRUTILA
    Else
      Call NAMEFIC(GI_DOSS,"M151",LANCOU,KEYS,NOMFIC) From INTRUTILA
    Endif
#    NBVAL=len(mess(0,NOMEN,1))
    Openo NOMFIC,0 Using [CST_]
    Iomode adxifs "" Using [CST_]
    Iomode adxirs chr$(10) Using [CST_]
    Iomode adxium GUTF8 Using [CST_]
    VALL1='<?xml version="1.0" encoding="utf-8" ?>'
    Wrseq VALL1 Using [CST_]
    VALL1='<'+KEYS+' LANG="'+LANCOU+'" TIME="'+WE_HORDAT+'">'
    Wrseq VALL1 Using [CST_]
    Filter [AST1] Where LANCHP=NOMEN and LANNUM>0 and LAN=LANCOU
    For [AST1]
      NOMES=[F:AST1]LANNUM
      Gosub ECR_FIC
    Next
    Filter [AST1]
    VALL1="</"+KEYS+">"
    Wrseq VALL1 Using [CST_]
    Openo Using [CST_]
    If (NOMEN<>151 and NOMEN<>152) or dim(SRV151)>0 : Gosub WI_CRESRVL From INTRUTILB : Endif
Return

$CREREPSRV
  Local Char MACHINE(GDIMFIC),ORDSYS(100),REPERT(GDIMFIC)
  Local Integer STAT,K
  Call NAMEFIC(GI_DOSS,"SRVL",GI_LLAN(I),"",REPERT) From INTRUTILA
  If filinfo(REPERT,0)<0
   K = instr(1,REPERT,"@")
   If K
    ORDSYS = 'ae_mkdir'-'"'+right$(REPERT,K+1)+'"'
   Else
    ORDSYS = 'ae_mkdir'-'"'+REPERT+'"'
   Endif
   Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
  Endif
Return


$CRELIBFILE
  Read [AST]CLE=9801;TBOUT(3,I);LANCOU
  If fstat=0 Then
    TEXT=[F:AST]LANMES
  Else
    If LANCOU<>GLANGUE
      Read [AST]CLE=9801;TBOUT(3,I);GLANGUE
    Else
      Read [AST]CLE=9801;TBOUT(3,I);GLANDEF
    Endif
    If fstat=0 : TEXT=[F:AST]LANMES : Else : TEXT=CBOUT(I) : Endif
  Endif
  Call MODVAL(TEXT) From INTRUTILA
Return



$ECR_FIC
Read [AST]CLE=NOMEN;NOMES;LANCOU
If fstat=0 Then
  TEXT=[F:AST]LANMES
Else
  If LANCOU<>GLANGUE
    Read [AST]CLE=NOMEN;NOMES;GLANGUE
  Else
    Read [AST]CLE=NOMEN;NOMES;GLANDEF
  Endif
  If fstat=0 : TEXT=[F:AST]LANMES : Else : WE_VALUE=".." : Endif
Endif
  Call MODVAL(TEXT) From INTRUTILA
  VALL1='  <OCCURS VALUE="'+num$(NOMES)+'" C'+'="'+TEXT+'"/>'
  Wrseq VALL1 Using [CST_]
Return


#-----------------------------------------------------------------------
#              Création du fichier FOLDERS.xml
#              Rajout par DOM : création du fichier FOLDERS.json

Subprog CREFOLDERS

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif

Local Char NOMFIC(250),VALL1(200),DIRSEP,CHEMIN1,DOSSROOT,NOMD
Local Char STOINFO(30)(1..9,1..100),STOLANG(GLONLAN)(1..dim([F:ADS]LAN),1..100),STOMOTHER(10)(1..8,1..100)
Local Integer NBFOLD,I,J,K,J1,J2,INDM,ERRCOU

# La table STOINFO stocke les informations des dossiers en mémoire
#    STOINFO(1)  : Nom du dossier
#            2   : Version
#            3   : Release
#            4   : Update date (date du jour par défaut)
#            5   : No de Patch
#            6   : Nom du dossier origine (si dossier historisé)
#            7   : Nombre de langues du dossier
#            8   : Nombre de dossiers mères
#            9   : Dossier indexé pour la recherche (YES ou NO)

For I=7 To 0 Step -1
  If adxmother(I)<>""
    DOSSROOT=adxmother(I)
    Break 1
  Endif
Next I

Local Integer STAL

For [ADS]
  If filinfo(filpath("FIL","APATCH","fde",[F:ADS]DOSSIER),0)<=0
   Goto SUITXML : #  Ce n'est pas un vrai dossier
  Endif
  Call LECDOS([F:ADS]DOSSIER) From DOSCONT   : # Bug 45759
  If mkstat=2 : Goto SUITXML : Endif #  Ce n'est pas un vrai dossier
  ERRCOU=0
  Onerrgo ERRXML
  Local File =[F:ADS]DOSSIER+".APATCH" [APT]
  If !ERRCOU
   Filter [APT] Where TYP="P"
   Read [APT]APT0 Last
   If !ERRCOU
    STAL=fstat
   Endif
  Endif
  Onerrgo
  If ERRCOU : Goto SUITXML : Endif
  NBFOLD+=1
  STOINFO(1,NBFOLD)=[F:ADS]DOSSIER

  If fstat<>0      : # On lit les informations sur le dossier mère si APATCH est vide : bug 26145
    Filter [APT]
    Close Local File [APT]
    ERRCOU=0
    Onerrgo ERRXML
    Local File =DOSSROOT+".APATCH" [APT]
    If !ERRCOU
     Filter [APT] Where TYP="P"
     Read [APT]APT0 Last
     If !ERRCOU
      STAL=fstat
     Endif
    Endif
    Onerrgo
    If ERRCOU : Goto SUITXML : Endif
  Endif

  If fstat=0
    If left$(num$([F:APT]DAT),5)="00/00"
     STOINFO(4,NBFOLD)=num$(date$)
    Else
     STOINFO(4,NBFOLD)=num$([F:APT]DAT)
    Endif
    STOINFO(5,NBFOLD)=num$([F:APT]PATNUM)
    If [F:APT]RELEASE<>""
      #106969
      #STOINFO(2,NBFOLD)=ctrans([F:APT]RELEASE,".","")
      STOINFO(2,NBFOLD)=[F:APT]RELEASE
    Else
      #106969
      #STOINFO(2,NBFOLD)=num$(GVERSION)
      STOINFO(2,NBFOLD)=func APRODUCT.AGETRELEASEABR(GDOSX3)+"."+format$("N0:3#",func AFNC.PARAMDOS(GDOSX3, "NUMPATCH"))
    Endif
  Else
    STOINFO(4,NBFOLD)=num$(date$)
    STOINFO(5,NBFOLD)="0"
    #106969
    #STOINFO(2,NBFOLD)=num$(GVERSION)
    STOINFO(2,NBFOLD)=func APRODUCT.AGETRELEASEABR(GDOSX3)+"."+format$("N0:3#",func AFNC.PARAMDOS(GDOSX3, "NUMPATCH"))
  Endif
  If clalev([F:APT])>0
   Close Local File [APT]
  Endif
  Gosub LECMOTHER
  Local File =[F:ADS]DOSSIER+".ADOVAL" [A_DW]
  Read [A_DW]ADW0 = "";"";"RELEASE"
  If fstat=0
    STOINFO(3,NBFOLD)=num$([F:A_DW]VALEUR)
  Else
    STOINFO(3,NBFOLD)="0"
  Endif
  Read [A_DW]ADW0 = "";"";"PUBLIASEAR"
  If fstat=0 and [F:A_DW]VALEUR="2"
    STOINFO(9,NBFOLD)="YES"
  Else
    STOINFO(9,NBFOLD)="NO"
  Endif

  Close Local File [A_DW]
#  STOINFO(3,NBFOLD)=num$([F:ADS]RELEASE)  modif CC 03/01/2005
  STOINFO(6,NBFOLD)=""
  STOINFO(7,NBFOLD)=num$([F:ADS]NBRLAN)
  For I=1 To [F:ADS]NBRLAN
    STOLANG(I,NBFOLD)=[F:ADS]LAN(I-1)
  Next I
  If [F:ADS]DOSHIS<>""
    NBFOLD+=1
    STOINFO(1,NBFOLD)=[F:ADS]DOSHIS
    STOINFO(2,NBFOLD)=STOINFO(2,NBFOLD-1)
    STOINFO(3,NBFOLD)=STOINFO(3,NBFOLD-1)
    STOINFO(4,NBFOLD)=STOINFO(4,NBFOLD-1)
    STOINFO(5,NBFOLD)=STOINFO(5,NBFOLD-1)
    STOINFO(6,NBFOLD)=STOINFO(1,NBFOLD-1)
    STOINFO(7,NBFOLD)=STOINFO(7,NBFOLD-1)
    STOINFO(9,NBFOLD)="NO"
    For I=1 To val(STOINFO(7,NBFOLD))
      STOLANG(I,NBFOLD)=STOLANG(I,NBFOLD-1)
    Next I
  Endif
$SUITXML
 If clalev([F:APT])>0 : Close Local File [APT] : Endif
Next


# Ouverture du fichier résultat

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

NOMFIC=filpath("","","",DOSSROOT)
NOMFIC=left$(NOMFIC,len(NOMFIC)-len(DOSSROOT))
NOMFIC+="FOLDERS.xml"
Openo NOMFIC,0 Using [CST_]
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
#  Ecriture du fichier XML

VALL1='<?xml version="1.0" encoding="utf-8" ?>'
Wrseq VALL1 Using [CST_]
VALL1="<INFOFOLDERS"
VALL1+=' versolsup="'+func APRODUCT.AGETRELEASESUP()+'"'
VALL1+=">"
Wrseq VALL1 Using [CST_]
VALL1=" <ACTUAL>"
Wrseq VALL1 Using [CST_]


For I=1 To NBFOLD
  VALL1='    <FOLDER ID="'+STOINFO(1,I)+'"'
  If STOINFO(6,I)<>""
    VALL1+=' HIST="1"'
  Endif
  For J=1 To val(STOINFO(8,I))
    VALL1+=' MOTH'+num$(J)+'="'+STOMOTHER(J,I)+'"'
  Next J
  VALL1+=">"
  Wrseq VALL1 Using [CST_]
  VALL1="      <IAD>"+GINSTID+"</IAD>"
  Wrseq VALL1 Using [CST_]
  If STOINFO(6,I)<>""
    VALL1="      <ORIGINE>"+STOINFO(6,I)+"</ORIGINE>"
    Wrseq VALL1 Using [CST_]
  Endif
  VALL1="      <VERSION>"+STOINFO(2,I)+"</VERSION>"
  Wrseq VALL1 Using [CST_]
  VALL1="      <RELEASE>"+STOINFO(3,I)+"</RELEASE>"
  Wrseq VALL1 Using [CST_]
  VALL1="      <PATCH>"+STOINFO(5,I)+"</PATCH>"
  Wrseq VALL1 Using [CST_]
  #VALL1="      <NEWVER>"+func ABOUT_CSTD.NEWVER(STOINFO(2,I),STOINFO(5,I))+"</NEWVER>"
  VALL1="      <NEWVER>"+func APRODUCT.AGETVERSION()+"</NEWVER>"
  Wrseq VALL1 Using [CST_]
  VALL1="      <UPDATE>"+STOINFO(4,I)+"</UPDATE>"
  Wrseq VALL1 Using [CST_]
  VALL1="      <PUBLIASEAR>"+STOINFO(9,I)+"</PUBLIASEAR>"
  Wrseq VALL1 Using [CST_]
  VALL1="      <LANGS>"
  For J=1 To val(STOINFO(7,I))
     VALL1+=STOLANG(J,I)
     If J < val(STOINFO(7,I)) : VALL1+=";" : Endif
  Next J
  VALL1+="</LANGS>"
  Wrseq VALL1 Using [CST_]
  VALL1='    </FOLDER>'
  Wrseq VALL1 Using [CST_]
Next I

VALL1=" </ACTUAL>"
Wrseq VALL1 Using [CST_]
Gosub INFOLIC
VALL1="</INFOFOLDERS>"
Wrseq VALL1 Using [CST_]

Openo Using [CST_]


# Ouverture du fichier json

If !clalev([TLA]) : Local File TABLAN : Endif

NOMFIC=filpath("","FOLDERS","json","X3_PUB")
Openo NOMFIC,0 Using [CST_]
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]



#  Ecriture du fichier JSON
Wrseq "{" Using [CST_]
Wrseq ' "solution" : "'+GINSTID+'",' Using [CST_]
Wrseq ' "folders" : [' Using [CST_]

For I=1 To NBFOLD
  Wrseq "  {" Using [CST_]
  Wrseq '    "name" : "'+STOINFO(1,I)+'",' Using [CST_]
  Wrseq '    "version" : "'+STOINFO(2,I)+'",' Using [CST_]
  Wrseq '    "release" : "'+STOINFO(3,I)+'",' Using [CST_]
  Wrseq '    "patch" : "'+STOINFO(5,I)+'",' Using [CST_]
  Wrseq '    "update" : "'+right$(STOINFO(4,I),7)+"-"+mid$(STOINFO(4,I),4,2)+"-"+left$(STOINFO(4,I),2)+'",' Using [CST_]
  If STOINFO(6,I)<>""
    Wrseq '    "hist" : true,' Using [CST_]
    Wrseq '    "origin" : "'+STOINFO(6,I)+'",' Using [CST_]
  Else
    Wrseq '    "hist" : false,' Using [CST_]
    Wrseq '    "mother" : [ '; Using [CST_]
    For J=1 To val(STOINFO(8,I))
      Wrseq '"'+STOMOTHER(J,I)+'"'+string$(J<val(STOINFO(8,I)),","); Using [CST_]
    Next J
    Wrseq '],' Using [CST_]
  Endif
  Wrseq '    "publisear" : '+string$(STOINFO(9,I)="YES",'true')+string$(STOINFO(9,I)<>"YES",'false')+"," Using [CST_]
  Wrseq '    "languages" : [ '; Using [CST_]
  For J=1 To val(STOINFO(7,I))
     Wrseq '"'; Using [CST_]
     Read [TLA]TLA0=STOLANG(J,I)
     If fstat=0 and [TLA]LANISO<>""
        Wrseq ctrans([TLA]LANISO,"_","-"); Using [CST_]
     Else

       # Default rule if iso code cannot be found
       Case STOLANG(J,I)
         When "FRA" : Wrseq 'fr-FR'; Using [CST_]
         When "ENG" : Wrseq 'en-US'; Using [CST_]
         When "CHI" : Wrseq 'zh-CN'; Using [CST_]
         When "GER" : Wrseq 'de-DE'; Using [CST_]
         When "ITA" : Wrseq 'it-IT'; Using [CST_]
         When "POR" : Wrseq 'pt-PT'; Using [CST_]
         When "SPA" : Wrseq 'es-ES'; Using [CST_]
         When "BRI" : Wrseq 'en-GB'; Using [CST_]
         When "POL" : Wrseq 'pl-PL'; Using [CST_]
         # Issue X3-67176 - 2018-01-15 by CCC : remove russian language
         #When "RUS" : Wrseq 'ru-RU'; Using [CST_]
       Endcase
    Endif
    Wrseq '"'+string$(J < val(STOINFO(7,I)),","); Using [CST_]
  Next J
  Wrseq ']' Using [CST_]
  Wrseq "  }"+string$(I<NBFOLD,",") Using [CST_]
Next I

Wrseq ' ]' Using [CST_]
Wrseq "}" Using [CST_]
Openo Using [CST_]

End

$INFOLIC
# supression serial adonix
#Local Char FICHIER(250)
#Local Char    LICENCE(12)
#Local Char    CHCLI(100)(1..4)
#Local Char    CHDIS(100)(1..4)
#Local Date    DATDEB
#Local Date    DATFIN
#Local Integer USER
#Local Integer DIVERS(1..9)
#Local Integer NOMBRE(1..12)
#Local Char PRODUIT(30)
#
#If func GLOBSUP.FICSERIAL(GPRODUIT,"",FICHIER)<>0
# Call SERIAL(FICHIER,LICENCE,CHCLI,CHDIS,DATDEB,DATFIN,USER,DIVERS,NOMBRE) From VISULIC
#Endif
#
## Type de produit (menu 2902)
#
## NOMBRE(6) : # Type produit : 1=X3, 2=Paye, 4=Géode
#PRODUIT = ""
#For I=len(mess(0,2902,1)) To 1 Step -1
# If NOMBRE(6)>=2^(I-1)
#  PRODUIT = mess(I,2902,1)-PRODUIT
#  NOMBRE(6) -= 2^(I-1)
# Endif
#Next
#PRODUIT = vireblc(PRODUIT,2)
#If PRODUIT=""
# PRODUIT = mess(1,2902,1)
#Endif
#
## Nombre de sessions
#
## DIVERS(1) : # Sessions primaires
## DIVERS(2) : # Sessions secondaires
## DIVERS(3) : # Batchs
## DIVERS(4) : # Adapis
## DIVERS(5) : # Sessions web "technique"
#
## DIVERS(6..8) non utilisés pour l'instant
#
##[M]PORT = 1 + (mod(DIVERS(9),2)<>0)    : # 1 : Portail
#
## Limites fonctionnelles applicatives (menu 933)
##   NOMBRE(1) : # (X3=Immobilisations)
##   NOMBRE(2) : # (X3=Configurateur)
##   NOMBRE(3) : # (X3=Ordonnancement)
##   NOMBRE(4) : # (X3=Optimisation)
##   NOMBRE(5) : # (X3=Balances)
#
#
#VALL1="<DEFLIC>" : Gosub ECRIT
#VALL1="<PRODUIT>"+PRODUIT+"</PRODUIT>" : Gosub ECRIT
#VALL1="<LICENCE>"+LICENCE+"</LICENCE>" : Gosub ECRIT
#VALL1="<DATDEB>"+DATDEB+"</DATDEB>" : Gosub ECRIT
#VALL1="<DATFIN>"+DATFIN+"</DATFIN>" : Gosub ECRIT
#VALL1="<TEXTLIC>" : Gosub ECRIT
#For I=1 To 4
#  Call MODVAL(CHCLI(I)) From INTRUTILA
#  VALL1="<TEXT>"+CHCLI(I)+"</TEXT>" : Gosub ECRIT
#Next I
#VALL1="</TEXTLIC>" : Gosub ECRIT
#VALL1="<TEXTDIST>" : Gosub ECRIT
#For I=1 To 4
#  Call MODVAL(CHDIS(I)) From INTRUTILA
#  VALL1="<TEXT>"+CHDIS(I)+"</TEXT>" : Gosub ECRIT
#Next I
#VALL1="</TEXTDIST>" : Gosub ECRIT
#VALL1="<SESPRI>"+num$(DIVERS(1))+"</SESPRI>" : Gosub ECRIT
#VALL1="<SESSEC>"+num$(DIVERS(2))+"</SESSEC>" : Gosub ECRIT
#VALL1="<BATCH>"+num$(DIVERS(3))+"</BATCH>" : Gosub ECRIT
#VALL1="<WEBSERV>"+num$(DIVERS(4))+"</WEBSERV>" : Gosub ECRIT
#VALL1="<TERMPORT>"+num$(DIVERS(5))+"</TERMPORT>" : Gosub ECRIT
#VALL1="<PORTAIL>"+num$((mod(DIVERS(9),2)<>0))+"</PORTAIL>" : Gosub ECRIT
#
#For I=1 To 5
#  VALL1="<COMPTEUR>" : Gosub ECRIT
#  VALL1="<LIB>"+mess(I,933,1)+"</LIB>" : Gosub ECRIT
#  VALL1="<VAL>"+num$(NOMBRE(I))+"</VAL>" : Gosub ECRIT
#  VALL1="</COMPTEUR>" : Gosub ECRIT
#Next I
#VALL1="</DEFLIC>" : Gosub ECRIT

Return


$ECRIT
  Wrseq VALL1 Using [CST_]
Return



$ERRXML
 If clalev([F:APT])=1 : Close Local File [APT] : Endif
 ERRCOU=1
Resume

$LECMOTHER:
NOMFIC=filpath("","APL","ini",STOINFO(1,NBFOLD))
Openi NOMFIC,0 Using [AP1_]
Iomode adxifs ""  Using [AP1_]
Iomode adxirs chr$(10)  Using [AP1_]
Iomode adxium GUTF8  Using [AP1_]
fstat=0
While fstat=0
  Rdseq VALL1 Using [AP1_]
    If instr(1,VALL1,"adxmother(")<>0
      J1=instr(1,VALL1,"(")
      INDM=val(mid$(VALL1,J1+1,1))
      J1=instr(J1+2,VALL1,'"')
      J2=instr(J1+1,VALL1,'"')
      If J2-J1>2 : NOMD=mid$(VALL1,J1+1,J2-J1-1) : Endif
      If NOMD<>STOINFO(1,NBFOLD)
        If INDM=0 or NOMD<>STOMOTHER(INDM,NBFOLD)
          STOMOTHER(INDM+1,NBFOLD)=mid$(VALL1,J1+1,J2-J1-1)
          STOINFO(8,NBFOLD)=num$(val(STOINFO(8,NBFOLD))+1)
        Endif
      Endif
    Endif
Wend

Openi Using [AP1_]
Return



# ---------------------------------------------------------------------------------------
Subprog CRELOCALP(CLANG)

#             Création des pages locales dans la langue "CLANG" sous X3_CLIENT
#             1) Crée le répertoire si il n'existe pas
#             2) Copie WINA depuis la langue FRA (qui est livrée)
#             3) Génère les menus 151 et 152
#             4) Parse les fenêtres locales


Value Char CLANG

Local Integer I, K, STAT
Local Char    APPLI(GDIMFIC),NOMFIC(GDIMFIC),VALL1(200)
Local Char    REPERT(GDIMFIC) , ORDSYS(250), DIRSEP, RESULT(200)(1..10)
Local Char    MACHINE(GDIMFIC) , REP(GDIMFIC)


MACHINE = adxmac(0)

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase


# 1) Crée le répertoire "LANG" et ses sous-répertoires si il n'existe pas

REP = "X3_CLIENT"+DIRSEP+"WEBF"+DIRSEP+CLANG
Gosub CREREP
REP = "X3_CLIENT"+DIRSEP+"WEBF"+DIRSEP+CLANG+DIRSEP+"WINA"
Gosub CREREP
REP = "X3_CLIENT"+DIRSEP+"WEBF"+DIRSEP+CLANG+DIRSEP+"FENW"
Gosub CREREP
REP = "X3_CLIENT"+DIRSEP+"WEBF"+DIRSEP+CLANG+DIRSEP+"HTML"
Gosub CREREP
REP = "X3_CLIENT"+DIRSEP+"WEBF"+DIRSEP+CLANG+DIRSEP+"SRVL"
Gosub CREREP


# 2) Copie de WINA à partir de "FRA" si CLANG<>"FRA"
If CLANG<>"FRA"
  ORDSYS="ae_cpdir "+filpath("X3_CLIENT"+DIRSEP+"WEBF"+DIRSEP+"FRA"+DIRSEP+"WINA","","","X3_PUB")
  ORDSYS-=filpath("X3_CLIENT"+DIRSEP+"WEBF"+DIRSEP+CLANG+DIRSEP+"WINA","","","X3_PUB")
  System RESULT = adxmac(0)+"@"+ORDSYS
Endif


# 3) Crée les menus 151 et 152 dans la langue CLANG

Local Char TEXT(200)
Local Char LANCOU,KEYS,WE_HORDAT(14)
Local Integer NOMEN,NOMES

Call GLOBWEB(APPLI) From INTRUTILA
Call ENVVAR(WE_HORDAT) From INTRUTILA
If clalev([F:AST])=0  : Local File =GI_DOSS+".APLSTD" [AST]    : Endif
If clalev([F:AST1])=0 : Local File =GI_DOSS+".APLSTD" [AST1]   : Endif
LANCOU=CLANG
NOMEN=151
Gosub CRESRVL From VALCSTWEB
NOMEN=152
Gosub CRESRVL From VALCSTWEB


# 4) Parse les fenêtres locales
Local Char LOCALW(50)(1..30)
Local Integer NBLW
Gosub CHARGE
REPERT=filpath("","","","X3_PUB")
I=instr(1,REPERT,"@")
If I<>0 : REPERT=right$(REPERT,I+1) : Endif
For I=1 To NBLW
  ORDSYS="ae_localparse "
  If GOS(1)<>"dos" : ORDSYS+="-a" : Endif
  ORDSYS+=REPERT+" "
  If GOS(1)<>"dos" : ORDSYS+="-f" : Endif
  ORDSYS-=LOCALW(I)+" "
  If GOS(1)<>"dos" : ORDSYS+="-l" : Endif
  ORDSYS-=CLANG
  System RESULT = adxmac(0)+"@"+ORDSYS
Next I

End
# ---------------------------------------------------------------------------------------


$CREREP
REPERT = filpath(REP,"","","X3_PUB")
If filinfo(REPERT,0)<0
 K = instr(1,REPERT,"@")
 If K
  ORDSYS = 'ae_mkdir'-'"'+right$(REPERT,K+1)+'"'
 Else
  ORDSYS = 'ae_mkdir'-'"'+REPERT+'"'
 Endif
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 If filinfo(REPERT,0)<0
  Call ECR_TRACE(mess(184,124,1)+"\|"+ctrans(REPERT,"\","/")+"|",1) From GESECRAN
  Return
 Endif
Endif
Return


$CHARGE
If clalev([F:HLP_])>0 : Close Local File [HLP_] : Endif
REPERT=filpath("X3_CLIENT"+DIRSEP+"WEBF"+DIRSEP+"FRA"+DIRSEP+"WINA","","","X3_PUB")

Local File (HLP(30)) From System adxmac(0)+'@lsadx -a'-toupper(nomap(0))-REPERT As [HLP_]
For [HLP_] Where HLP<>""
 If len([F:HLP_]HLP)>4 and right$([F:HLP_]HLP,len([F:HLP_]HLP)-3)=".xml"
   NBLW+=1
   LOCALW(NBLW)=left$([F:HLP_]HLP,len([F:HLP_]HLP)-4)
 Endif
Next HLP_
Return

# ---------------------------------------------------------------------------------------

Subprog DETARPORTAL(MACH)
Value Char MACH()

#    Recrée un nouveau portail à partir des archives .tar
#    MACHINE : si précisé nom de la machine distante  exemple gaile610:1941
#              si MACHINE est vide on considère que l'on travaille sur adxmac(0)


Local Char NAMEREP(GDIMFIC),NAMEREP1(GDIMFIC),MACHINE(GDIMFIC)
Local Char OPT(250),ORDRE(250),DIRSEP
Local Char REP(GDIMFIC),REP1(GDIMFIC),BASEREF(GDIMFIC),TYPOS
Local Integer STAT,POSK

MACHINE=MACH
Call GET_OS(MACHINE,TYPOS) From ORDSYS

Case toupper(TYPOS)
 When "DOS"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

#  Pour test
# BASEREF="CC"+DIRSEP

#  Phase 1 : Détruit et recrée les répertoires de SAV_PORTAL

REP = BASEREF+"SAV_PORTAL"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_rmdir "+NAMEREP
#           On fait plusieurs dois le delete pour corriger un pb détecté en envt Windows
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS

REP = BASEREF+"SAV_PORTAL"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_mkdir "+NAMEREP
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS

REP = BASEREF+"SAV_PORTAL"+DIRSEP+"Archives"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_mkdir "+NAMEREP
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS

REP = BASEREF+"SAV_PORTAL"+DIRSEP+"Custom"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_mkdir "+NAMEREP
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS



#  Phase 2 : Copie les tar de ADX_PORTAL/Archives vers SAV_PORTAL
#            Copie ADX_PORTAL/Custom vers SAV_PORTAL

REP = BASEREF+"ADX_PORTAL"+DIRSEP+"Archives"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
REP = BASEREF+"SAV_PORTAL"+DIRSEP+"Archives"
NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP1,"@")
If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
ORDRE="ae_cpdir "+NAMEREP-NAMEREP1
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS

REP = BASEREF+"ADX_PORTAL"+DIRSEP+"Custom"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
REP = BASEREF+"SAV_PORTAL"+DIRSEP+"Custom"
NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP1,"@")
If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
ORDRE="ae_cpdir "+NAMEREP-NAMEREP1
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS



#  Phase 3 : Recherche les archives à dezipper

Local Integer NBARCH
Local Char ARCH(100)(1..100)

If clalev([F:HLP_])>0 : Close Local File [HLP_] : Endif
REP = BASEREF+"SAV_PORTAL"+DIRSEP+"Archives"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
Local File (HLP(30)) From System MACHINE+'@lsadx -a'-"X3_PUB"-NAMEREP As [HLP_]
For [HLP_] Where HLP<>""
 If len([F:HLP_]HLP)>6 and toupper(right$([F:HLP_]HLP,len([F:HLP_]HLP)-3))=".TAR" and
&   toupper(left$([F:HLP_]HLP,4))="ARCH"
   NBARCH+=1
   ARCH(NBARCH)=left$([F:HLP_]HLP,len([F:HLP_]HLP)-4)
 Endif
Next HLP_
If NBARCH=0 : End : Endif   : # Sécurité car sinon on efface le portail existant


#  Phase 4 : Copie les archives à dezipper sous SAV_PORTAL

REP  = BASEREF+"SAV_PORTAL"+DIRSEP+"Archives"
REP1 = BASEREF+"SAV_PORTAL"
For indice=1 To NBARCH
  NAMEREP=filpath(REP,ARCH(indice),"tar","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  NAMEREP1=filpath(REP1,ARCH(indice),"tar","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP1,"@")
  If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
  ORDRE="ae_cp "+NAMEREP-NAMEREP1
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Next indice


#  Phase 5 : tar des archives

Local Char RESULT(200)(1..5)
REP  = BASEREF+"SAV_PORTAL"
REP1 = BASEREF+"SAV_PORTAL"
NAMEREP1=filpath(REP1,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP1,"@")
If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
If toupper(TYPOS)="DOS" : NAMEREP1+=DIRSEP : Endif
For indice=1 To NBARCH
  NAMEREP=filpath(REP,ARCH(indice),"tar","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  If toupper(TYPOS)="DOS"
    ORDRE='7za.exe x "'+NAMEREP+'" -r -y -o"'+NAMEREP1+'"'
  Else
    ORDRE="cd "+NAMEREP1+";tar -xvf "+NAMEREP
  Endif
#  System RESULT = MACHINE+"@"+ORDRE
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Next indice

#  Phase 6 : Détruit les .tar sous SAV_PORTAL

REP = BASEREF+"SAV_PORTAL"
For indice=1 To NBARCH
  NAMEREP=filpath(REP,ARCH(indice),"tar","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  ORDRE="ae_rm "+NAMEREP
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Next indice


#  Phase 7 : Détruit ADX_PORTAL

REP = BASEREF+"ADX_PORTAL"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_rmdir "+NAMEREP
#           On fait plusieurs dois le delete pour corriger un pb détecté en envt Windows
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS


#  Phase 7 bis : Vérifie la suppression d'ADX_PORTAL et au cas ou le copie sous un autre nom
#                Pour contourner un pb Unix    --  CC   10/01/2007
REP = BASEREF+"ADX_PORTAL"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
LKF=filinfo(NAMEREP,7)
If LKF>0
REP = BASEREF+"ADX_PORTAL"
 NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
 POSK = instr(1,NAMEREP,"@")
 If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
 REP = BASEREF+"X3CLIOLD"
 NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
 POSK = instr(1,NAMEREP1,"@")
 If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
# ------------------------------------------------------------------------------
###  Bug 49030    - on détruit X3CLIOLD à tout hasard
ORDRE="ae_rmdir "+NAMEREP1
#           On fait plusieurs dois le delete pour corriger un pb détecté en envt Windows
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
# ------------------------------------------------------------------------------
 ORDRE="ae_mv "+NAMEREP-NAMEREP1
 Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Endif


#  Phase 8 : Renomne SAV_PORTAL ADX_PORTAL

REP = BASEREF+"SAV_PORTAL"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
REP = BASEREF+"ADX_PORTAL"
NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP1,"@")
If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
ORDRE="ae_mv "+NAMEREP-NAMEREP1
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS


#  Phase 9 : Si systeme Unix change les droits sur ADX_PORTAL

If toupper(TYPOS)<>"DOS"
  REP = BASEREF+"ADX_PORTAL"
  NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  For indice=1 To 10
    ORDRE="chmod -R 777 "+NAMEREP
    Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
  Next indice
Endif
End

# -------------------------------------------------------------------------------------

Subprog DETARX3CLI(MACH)
Value Char MACH()

#    Recrée une nouvelle arborescence X3CLI à partir de l'archive .tar
#    MACHINE : si précisé nom de la machine distante  exemple gaile610:1941
#              si MACHINE est vide on considère que l'on travaille sur adxmac(0)


Local Char NAMEREP(GDIMFIC),NAMEREP1(GDIMFIC),MACHINE(GDIMFIC)
Local Char OPT(250),ORDRE(250),DIRSEP
Local Char REP(GDIMFIC),REP1(GDIMFIC),BASEREF(GDIMFIC),TYPOS
Local Integer STAT,POSK,LKF,NBARCH,FLASHCUST,STATAF,LKF1

#  Génération de l' archive X3CLI
Call ECR_TRACE(mess(216,139,1)-"X3CLI  1"-MACH,0) From GESECRAN


MACHINE=MACH
Call GET_OS(MACHINE,TYPOS) From ORDSYS


Case toupper(TYPOS)
 When "DOS"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
#  Pour test
# BASEREF="CC"+DIRSEP



#  Phase 1 : Détruit et recrée les répertoires de SAV_X3CLI
BASEREF="X3_ROOT"+DIRSEP
REP = BASEREF+"SAV_X3CLI"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_rmdir "+NAMEREP
#           On fait plusieurs fois le delete pour corriger un pb détecté en envt Windows
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS

REP = BASEREF+"SAV_X3CLI"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_mkdir "+NAMEREP
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
REP = BASEREF+"SAV_X3CLI"+DIRSEP+"XBLOCK"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_mkdir "+NAMEREP
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
REP = BASEREF+"SAV_X3CLI"+DIRSEP+"XPORTAL"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_mkdir "+NAMEREP
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS

#REP = BASEREF+"SAV_X3CLI"+DIRSEP+"FLASH_CUSTOM"
#NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
#POSK = instr(1,NAMEREP,"@")
#If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
#ORDRE="ae_mkdir "+NAMEREP
#Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS



# Phase 2 : Si le répertoire FLASH_CUSTOM existe déjà sous X3CLI/XBLOCK, on le rezippe et on le tranfère
#           sinon on prendra le tar de référence xblock_coreflashcust à partir du tar

REP  = BASEREF+"X3CLI"+DIRSEP+"XBLOCK"+DIRSEP+"FLASH_CUSTOM"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
LKF=filinfo(NAMEREP,7)
If LKF>0
 Call CREFLASHCUST(MACHINE,"","",STATAF) From ARCHFLASH
 FLASHCUST=1
Endif

#  Phase 3 : Recherche les archives à dezipper + les archives IDE

Local Integer NBARCH,IACH,NBIDE
Local Char ARCH(100)(1..10),AREXT(10)(1..10)
Local Char ARCHIDE(100)(1..10),AREXTIDE(10)(1..10)
If clalev([F:HLP_])>0 : Close Local File [HLP_] : Endif
REP = BASEREF+"X3CLI"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
Local File (HLP(30)) From System MACHINE+'@lsadx -a'-"X3_PUB"-NAMEREP As [HLP_]
For [HLP_] Where HLP<>""
 If len([F:HLP_]HLP)>6 and toupper(right$([F:HLP_]HLP,len([F:HLP_]HLP)-3))=".TAR" and
&   toupper(left$([F:HLP_]HLP,1))="X"
   NBARCH+=1
   ARCH(NBARCH)=left$([F:HLP_]HLP,len([F:HLP_]HLP)-4)
   AREXT(NBARCH)=right$([F:HLP_]HLP,len([F:HLP_]HLP)-2)
 Elsif len([F:HLP_]HLP)>4 and toupper(left$([F:HLP_]HLP,3))="IDE"
   NBIDE+=1
   POSK = instr(1,[F:HLP_]HLP,".")
   If POSK>0
     ARCHIDE(NBIDE)=left$([F:HLP_]HLP,POSK-1)
     AREXTIDE(NBIDE)=right$([F:HLP_]HLP,POSK+1)
   Else
     ARCHIDE(NBIDE)=[F:HLP_]HLP
   Endif
 Endif
Next HLP_
If NBARCH=0 : End : Endif   : # Sécurité car sinon on efface le portail existant


#  Phase 4 : Copie les tar de X3CLI vers SAV_X3CLI     Modif 14/10/2008
REP = BASEREF+"X3CLI"
REP1 = BASEREF+"SAV_X3CLI"
For IACH=1 To NBARCH
  NAMEREP=filpath(REP,ARCH(IACH),AREXT(IACH),"X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  NAMEREP1=filpath(REP1,ARCH(IACH),AREXT(IACH),"X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP1,"@")
  If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
  ORDRE="ae_cp "+NAMEREP-NAMEREP1
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Next IACH


# Phase 4 bis : on copie les composants IDE (archives Eclipse à copier sans les dezipper)
REP = BASEREF+"X3CLI"
REP1 = BASEREF+"SAV_X3CLI"
For IACH=1 To NBIDE
  NAMEREP=filpath(REP,ARCHIDE(IACH),AREXTIDE(IACH),"X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  NAMEREP1=filpath(REP1,ARCHIDE(IACH),AREXTIDE(IACH),"X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP1,"@")
  If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
  ORDRE="ae_cp "+NAMEREP-NAMEREP1
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Next IACH


#  Phase 5 : detar des archives

Local Char RESULT(200)(1..5)
Local Integer JJ
REP  = BASEREF+"SAV_X3CLI"
REP1 = BASEREF+"SAV_X3CLI"+DIRSEP+"XBLOCK"
NAMEREP1=filpath(REP1,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP1,"@")
If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
If toupper(TYPOS)="DOS" : NAMEREP1+=DIRSEP : Endif

For IACH=1 To NBARCH
  REP1 = BASEREF+"SAV_X3CLI"
  JJ=instr(1,ARCH(IACH),"_")
 # If tolower(ARCH(IACH))<>"xblock_corecust" and tolower(ARCH(IACH))<>"xhelp_flash"
#  If  tolower(ARCH(IACH))<>"xhelp_flash"
#    REP1+=DIRSEP+toupper(left$(ARCH(IACH),JJ-1))
#  Elsif tolower(ARCH(IACH))="xhelp_flash"
#    REP1+=DIRSEP+"XBLOCK"
#  Endif
  REP1+=DIRSEP+toupper(left$(ARCH(IACH),JJ-1))
  NAMEREP1=filpath(REP1,"","","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP1,"@")
  If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
  If toupper(TYPOS)="DOS" : NAMEREP1+=DIRSEP : Endif

  NAMEREP=filpath(REP,ARCH(IACH),AREXT(IACH),"X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  If toupper(TYPOS)="DOS"
    ORDRE='7za.exe x "'+NAMEREP+'" -r -y -o"'+NAMEREP1+'"'
  Else
    ORDRE="cd "+NAMEREP1+";tar -xvf "+NAMEREP
  Endif
#  System RESULT = MACHINE+"@"+ORDRE
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Next IACH

#  Renommer FLASH_CUSTOMREF en FLASH_CUSTOM si on vient d'initialiser
If FLASHCUST=0
 REP = BASEREF+"SAV_X3CLI"+DIRSEP+"XBLOCK"+DIRSEP+"FLASH"+DIRSEP+"FLASH_CUSTOMREF"
 NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
 POSK = instr(1,NAMEREP,"@")
 If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
 REP = BASEREF+"SAV_X3CLI"+DIRSEP+"XBLOCK"+DIRSEP+"FLASH_CUSTOM"
 NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
 POSK = instr(1,NAMEREP1,"@")
 If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
 ORDRE="ae_mv "+NAMEREP-NAMEREP1
 Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
 Call CREFLASHCUST(MACHINE,"SAV_X3CLI","",STATAF) From ARCHFLASH
 If STATAF<>0
   Call ECR_TRACE(mess(221,124,1)-" : FLASHCUST",0) From GESECRAN
 Endif
Endif

#  Phase 7 : Détruit X3CLI
REP = BASEREF+"X3CLI"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_rmdir "+NAMEREP
#           On fait plusieurs fois le delete pour corriger un pb détecté en envt Windows
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS


#  Phase 8 : Vérifie la suppression d'X3CLI et au cas ou le copie sous un autre nom
#                Pour contourner un pb Unix    --  CC   10/01/2007
REP  = BASEREF+"X3CLI"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
LKF=filinfo(NAMEREP,7)
If LKF>0
 REP = BASEREF+"X3CLI"
 NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
 POSK = instr(1,NAMEREP,"@")
 If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
 REP = BASEREF+"X3CLIOLD"
 NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
 POSK = instr(1,NAMEREP1,"@")
 If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
 ORDRE="ae_mv "+NAMEREP-NAMEREP1
 Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Endif



#  Phase 9 : Renomne SAV_X3CLI X3CLI

REP = BASEREF+"SAV_X3CLI"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
REP = BASEREF+"X3CLI"
NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP1,"@")
If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
ORDRE="ae_mv "+NAMEREP-NAMEREP1
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS


#  Phase 10 : Si systeme Unix change les droits sur X3CLI

If toupper(TYPOS)<>"DOS"
  REP = BASEREF+"X3CLI"
  NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  For indice=1 To 10
    ORDRE="chmod -R 777 "+NAMEREP
    Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
  Next indice
Endif


# Phase 11 : Message d'erreur si X3CLI n'existe pas ou si SAV_X3CLI n'a pas été supprimé

REP  = BASEREF+"X3CLI"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
LKF=filinfo(NAMEREP,7)
REP  = BASEREF+"SAV_X3CLI"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
LKF1=filinfo(NAMEREP,7)
If LKF<0 or LKF1>0
   Call ECR_TRACE(mess(221,124,1),1) From GESECRAN :#SAM 112765 : log an error instead of a warning !
Endif


End

# -------------------------------------------------------------------------------

Subprog DETARRES(MACH,TYPRES)
Value Char MACH()
Value Char TYPRES

#    Recrée une nouvelle arborescence RES+"TYPRES" à partir de l'archive .tar
#    MACHINE : si précisé nom de la machine distante  exemple gaile610:1941
#              si MACHINE est vide on considère que l'on travaille sur adxmac(0)

#   TYPRES doit etre égal à STD, VER ou PER

If !find(TYPRES,"STD","VER","PER") : End : Endif

Local Char NAMEREP(GDIMFIC),NAMEREP1(GDIMFIC),MACHINE(GDIMFIC)
Local Char OPT(250),ORDRE(250),DIRSEP
Local Char REP(GDIMFIC),REP1(GDIMFIC),BASEREF(GDIMFIC),TYPOS
Local Integer STAT,POSK,LKF
MACHINE=MACH
Call GET_OS(MACHINE,TYPOS) From ORDSYS

Case toupper(TYPOS)
 When "DOS"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

#  Pour test
# BASEREF="CC"+DIRSEP

#  Phase 1 : Détruit et recrée les répertoires de SAV_X3RES
BASEREF="X3_ROOT"+DIRSEP
REP = BASEREF+"SAV_X3RES"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_rmdir "+NAMEREP
#           On fait plusieurs fois le delete pour corriger un pb détecté en envt Windows
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS

REP = BASEREF+"SAV_X3RES"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_mkdir "+NAMEREP
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS



#  Phase 3 : Recherche les archives à dezipper

Local Char ARCH(100)

ARCH="RES"+TYPRES


#  Phase 4 : Copie les archives à dezipper sous SAV_X3RES

REP  = BASEREF+"RES"+TYPRES
REP1 = BASEREF+"SAV_X3RES"
  NAMEREP=filpath(REP,ARCH,"tar","X3_PUB","",MACHINE)
  LKF=filinfo(NAMEREP,7)
  If LKF<=0 : End : Endif     : #  Protection si il n'y a pas de fichier archive
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  NAMEREP1=filpath(REP1,ARCH,"tar","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP1,"@")
  If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
  ORDRE="ae_cp "+NAMEREP-NAMEREP1
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS


#  Phase 5 : tar des archives

Local Char RESULT(200)(1..5)
REP  = BASEREF+"SAV_X3RES"
REP1 = BASEREF+"SAV_X3RES"
NAMEREP1=filpath(REP1,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP1,"@")
If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
If toupper(TYPOS)="DOS" : NAMEREP1+=DIRSEP : Endif
  NAMEREP=filpath(REP,ARCH,"tar","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  If toupper(TYPOS)="DOS"
    ORDRE='7za.exe x "'+NAMEREP+'" -r -y -o"'+NAMEREP1+'"'
  Else
    ORDRE="cd "+NAMEREP1+";tar -xvf "+NAMEREP
  Endif
#  System RESULT = MACHINE+"@"+ORDRE
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS



#  Phase 7 : Détruit RES+"TYPRES"
REP = BASEREF+"RES"+TYPRES
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_rmdir "+NAMEREP
#           On fait plusieurs fois le delete pour corriger un pb détecté en envt Windows
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS


#  Phase 7 bis : Vérifie la suppression de RES+"TYPRES" et au cas ou le copie sous un autre nom
#                Pour contourner un pb Unix    --  CC   10/01/2007
REP = BASEREF+"RES"+TYPRES
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
LKF=filinfo(NAMEREP,7)
If LKF>0
REP = BASEREF+"RES"+TYPRES
 NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
 POSK = instr(1,NAMEREP,"@")
 If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
 REP = BASEREF+"X3RESOLD"
 NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
 POSK = instr(1,NAMEREP1,"@")
 If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
# ------------------------------------------------------------------------------
###  Bug 49030    - on détruit X3RESOLD à tout hasard
ORDRE="ae_rmdir "+NAMEREP1
#           On fait plusieurs dois le delete pour corriger un pb détecté en envt Windows
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
# ------------------------------------------------------------------------------
 ORDRE="ae_mv "+NAMEREP-NAMEREP1
 Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Endif



#  Phase 8 : Renomne SAV_X3RES RES+"TYPRES"

REP = BASEREF+"SAV_X3RES"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
REP = BASEREF+"RES"+TYPRES
NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP1,"@")
If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
ORDRE="ae_mv "+NAMEREP-NAMEREP1
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS


#  Phase 9 : Si systeme Unix change les droits sur RES+"TYPRES"

If toupper(TYPOS)<>"DOS"
  REP = BASEREF+"RES"+TYPRES
  NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  For indice=1 To 10
    ORDRE="chmod -R 777 "+NAMEREP
    Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
  Next indice
Endif
End

# -----------------------------------------------------------------------
Subprog INILIBMEN(APPLI)

Value Char APPLI

Local Char WE_HORDAT(14)
Local Integer ILAN,NBLAN
Local Char TLAN(GLONLAN)(1..50)

Call GLOBWEB(APPLI) From INTRUTILA
Call ENVVAR(WE_HORDAT) From INTRUTILA

Call GLOBLANG(TLAN,NBLAN) From INTRUTILA

For ILAN=1 To NBLAN
 Call INIONEMEN(GI_DOSS,TLAN(ILAN))
Next ILAN

End


# -----------------------------------------------------------------------
Subprog INIONEMEN(APPLI,LANCOU)
Value Char APPLI
Value Char LANCOU

Local Char TEXT(200),VALL1(200),NOMFIC(250),NOMFIC1(250)
Local Char DIRSEP,CAR
Local Integer I,J,K,L,M,NOMEN,NOMES
Local Integer NBLU

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

Local File =APPLI+".APLSTD" [AST]

 NOMFIC=filpath("","","","X3_PUB")+DIRSEP+"X3_ROOT"+DIRSEP+"GEN"+DIRSEP
 NOMFIC1=NOMFIC
 NOMFIC+="ALL"+DIRSEP+"LIB"+DIRSEP+"ADX_MENUREF.xml"
 NOMFIC1+=LANCOU+DIRSEP+"LIB"+DIRSEP+"MENU.xml"
 fstat=0

 If filinfo(NOMFIC,0)<0 : End : Endif :#115606

 Openi NOMFIC,0 Using [INP_]
 If fstat<>0 : Call ERREUR("Error while reading ADX_MENUREF.xml") From GESECRAN  : End : Endif
 Iomode adxifs "" Using [INP_]
 Iomode adxirs chr$(10) Using [INP_]
 Iomode adxium GUTF8 Using [INP_]
 Openo NOMFIC1,0 Using [OUT_]
 If fstat<>0 : Call ERREUR("Error while writing MENU.xml in language "-LANCOU) From GESECRAN : End : Endif
 Iomode adxifs "" Using [OUT_]
 Iomode adxirs chr$(10) Using [OUT_]
 Iomode adxium GUTF8 Using [OUT_]


 While fstat=0
  Rdseq VALL1  Using [INP_]
  If fstat<>0 : Goto SUITINIL : Endif
  Gosub RECHMCLE
  Wrseq VALL1 Using [OUT_]
  NBLU+=1
 Wend

$SUITINIL:
 Openi  Using [INP_]
 Openo  Using [OUT_]


End



$RECHMCLE
K = instr(1,VALL1,"X3(")
If K=0 : Return : Endif
CAR=mid$(VALL1,K-1,1)
J=0
Case CAR
 When '"'  : J=instr(K+5,VALL1,CAR)
 When '>'  : J=instr(K+5,VALL1,"<")
Endcase
If J=0 : Call ERREUR("MENU.xml "-mess(152,115,1)-VALL1) From GESECRAN : End : Endif
L= instr(K,VALL1,",")
M= instr(L,VALL1,")")
NOMEN=val(mid$(VALL1,K+3,L-K-3))
NOMES=val(mid$(VALL1,L+1,M-L-1))
Gosub CRELIB
VALL1=left$(VALL1,K-1)+TEXT+right$(VALL1,J)
Return


$CRELIB
  Read [AST]CLE=NOMEN;NOMES;LANCOU
  If fstat=0 Then
    TEXT=[F:AST]LANMES
  Else
    If LANCOU<>GLANGUE
      Read [AST]CLE=NOMEN;NOMES;GLANGUE
    Else
      Read [AST]CLE=NOMEN;NOMES;GLANDEF
    Endif
    If fstat=0 : TEXT=[F:AST]LANMES : Else : TEXT="mess("+num$(NOMES)+","+num$(NOMEN)+")" : Endif
  Endif
  Call MODVAL(TEXT) From INTRUTILA
  fstat=0
Return


# -------------------------------------------------------------------------------------

Subprog DETARX3CLIENT(MACH)
Value Char MACH()

#    Recrée une nouvelle arborescence X3_CLIENT à partir de l'archive .tar
#    MACHINE : si précisé nom de la machine distante  exemple gaile610:1941
#              si MACHINE est vide on considère que l'on travaille sur adxmac(0)

Local Char NAMEREP(GDIMFIC),NAMEREP1(GDIMFIC),MACHINE(GDIMFIC)
Local Char OPT(250),ORDRE(250),DIRSEP
Local Char REP(GDIMFIC),REP1(GDIMFIC),BASEREF(GDIMFIC),TYPOS
Local Integer STAT,POSK,LKF
MACHINE=MACH
Call GET_OS(MACHINE,TYPOS) From ORDSYS

Case toupper(TYPOS)
 When "DOS"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

#  Pour test
# BASEREF="CC"+DIRSEP

#  Phase 1 : Détruit et recrée les répertoires de SAV_X3CLI
BASEREF=""
REP = BASEREF+"SAV_X3CLIENT"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_rmdir "+NAMEREP
#           On fait plusieurs fois le delete pour corriger un pb détecté en envt Windows
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS

REP = BASEREF+"SAV_X3CLIENT"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_mkdir "+NAMEREP
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS



#  Phase 3 : Recherche les archives à dezipper

Local Char ARCH(100)

ARCH="X3CLIENT"


#  Phase 4 : Copie les archives à dezipper sous SAV_X3CLI

REP  = BASEREF+"X3_CLIENT"
REP1 = BASEREF+"SAV_X3CLIENT"
  NAMEREP=filpath(REP,ARCH,"tar","X3_PUB","",MACHINE)
  LKF=filinfo(NAMEREP,7)
  If LKF<=0 : End : Endif     : #  Protection si il n'y a pas de fichier archive
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  NAMEREP1=filpath(REP1,ARCH,"tar","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP1,"@")
  If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
  ORDRE="ae_cp "+NAMEREP-NAMEREP1
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS


#  Phase 5 : tar des archives

Local Char RESULT(200)(1..5)
REP  = BASEREF+"SAV_X3CLIENT"
REP1 = BASEREF+"SAV_X3CLIENT"
NAMEREP1=filpath(REP1,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP1,"@")
If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
If toupper(TYPOS)="DOS" : NAMEREP1+=DIRSEP : Endif
  NAMEREP=filpath(REP,ARCH,"tar","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  If toupper(TYPOS)="DOS"
    ORDRE='7za.exe x "'+NAMEREP+'" -r -y -o"'+NAMEREP1+'"'
  Else
    ORDRE="cd "+NAMEREP1+";tar -xvf "+NAMEREP
  Endif
#  System RESULT = MACHINE+"@"+ORDRE
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS



#  Phase 7 : Détruit X3_CLIENT
REP = BASEREF+"X3_CLIENT"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
ORDRE="ae_rmdir "+NAMEREP
#           On fait plusieurs fois le delete pour corriger un pb détecté en envt Windows
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS


#  Phase 7 bis : Vérifie la suppression d'X3_CLIENT et au cas ou le copie sous un autre nom
#                Pour contourner un pb Unix    --  CC   10/01/2007
REP  = BASEREF+"X3_CLIENT"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
LKF=filinfo(NAMEREP,7)
If LKF>0
 REP = BASEREF+"X3_CLIENT"
 NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
 POSK = instr(1,NAMEREP,"@")
 If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
 REP = BASEREF+"X3_CLIOLD"
 NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
 POSK = instr(1,NAMEREP1,"@")
 If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
 ORDRE="ae_mv "+NAMEREP-NAMEREP1
 Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Endif

#  Phase 8 : Renomne SAV_X3CLIENT X3_CLIENT

REP = BASEREF+"SAV_X3CLIENT"
NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
REP = BASEREF+"X3_CLIENT"
NAMEREP1=filpath(REP,"","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP1,"@")
If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
ORDRE="ae_mv "+NAMEREP-NAMEREP1
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS


#  Phase 9 : Si systeme Unix change les droits sur X3_CLIENT

If toupper(TYPOS)<>"DOS"
  REP = BASEREF+"X3_CLIENT"
  NAMEREP=filpath(REP,"","","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP,"@")
  If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
  For indice=1 To 10
    ORDRE="chmod -R 777 "+NAMEREP
    Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
  Next indice
Endif
End

