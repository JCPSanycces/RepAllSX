#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GBIDC1
Call OBJET("PCP",GBIDC1,GBIDC2) From GOBJET
End


$SELECH
Case ACTSELECH
 When "DEBUT"

  Local Char    OPT(1), ODEFMASK(200), CODE_ESC(10)
  Local Char    CRITERE(200), BPR(GLONBPR)
  Local Integer IND, CAS, FINTYP, I, J, K
  Local Integer BPROPT, FCYOPT
  Local Libelle BPRFIX, FLMT
  Local Decimal NNUM, NLIG
  Local Decimal MT

  If OPT="" : Call PARAM(VALEUR,"SEVFCYENT",OPT) From ADOVAL : Endif
  [L]FCYOPT=val(OPT) : # OD inter-sites
  Call PARAM(VALEUR,"SEVBPRENT",OPT) From ADOVAL
  [L]BPROPT=val(OPT) : # OD inter-tiers

  ODEFMASK=dbgstr(1)
  IND=SAVNOLIGN2-1 : NNUM=[M:PCP]DUDNUM(IND) : NLIG=[M:PCP]DUDLIG(IND)
  If NNUM<>0 & NLIG<>0
   Call LECDUD(NNUM,NLIG) From SUBPCP
   If fstat=0 & [F:DUD]NUM=VALEUR
    CAS=3
   Endif
  Endif
  If CAS : FIN=1 : FINTYP=0 : Return : Endif
  If [L]FCYOPT=1 : CRITERE="FCY='"+[M:PCP]FCY(IND)+"'"
  Else           : CRITERE="CPY='"+[M:PCP]CPY+"'"
  Endif

  CRITERE += " & DUDSTA=2"
  CRITERE += " & TYP='"+[M:PCP]TYP(IND)+"'"


  If VALEUR<>"" : CRITERE+=" & NUM='"+VALEUR+"'" : Endif

  Filter [DUD] Where evalue(CRITERE)
  [L]BPR=[M:PCP]BPRPAY(IND)
  Local Mask REGECHW [RECH]
  Default Mask ODEFMASK
  Raz [M:RECH] : I = dim([M:RECH]BPRPAY)
  nolign = 0 : J = 0
  Repeat
   If [L]BPR<>"" : [L]BPRFIX=![L]BPRFIX : Endif
   If [L]BPR="" & VALEUR<>""
    Filter [DUD] Where evalue(CRITERE) Order By Key DUD0
   Else
    Filter [DUD] Where evalue(CRITERE) Order By Key DUD3
   Endif
   ## Chargement des échéances dans la masque de sélection : on fait apparaître uniquement les échéances
   ## qui ont un solde supérieur ou égal au montant du règlement
   For [DUD] Where FLGCLE=1 & ((BPRPAY=[L]BPR & [L]BPRFIX) | ![L]BPRFIX) With Nohint
    If nolign>=I : Break : Endif
    Call MTECHE(MT,-1)
    If MT>=[M:PCP]AMTCUR(IND)
     nolign+=1 : [M:RECH]=[F:DUD]
     [M:RECH]ACCLIG(nolign-1)=[F:DUD]DUDLIG
     [M:RECH]SOLDE(nolign-1)=MT
     [M:RECH]TOTAL += [M:RECH]AMTCUR(nolign-1)-[M:RECH]SOLDE(nolign-1)
     If !J & MT>0 : J=nolign : Endif
     If NNUM=[F:DUD]ACCNUM & NLIG=[F:DUD]DUDLIG : J=nolign : Endif
    Endif
   Next : # [DUD]
   [M:RECH]DEVISE = [M:RECH]CUR(0)
  Until nolign | ![L]BPRFIX
  Filter [DUD]
  If !J : J=1 : Endif
  [M:RECH]NECH=nolign
  If nolign>1 & !find("",[M:RECH]BPRFCT(0..[M:RECH]NECH-1)) 
   # Facture gérée par le factor XXX
   GMESSAGE=mess(89,121,1)-[M:RECH]BPRFCT(0) : GERR=1 :  FIN=1 : FINTYP=2 : Return
  Endif
  CHARGE=0 : Default Mask [RECH]

 When "FIN"

  If !CAS & PARAM(3)="1"
   NNUM=val(PARAM(1)) : NLIG=val(PARAM(2))
  Endif

  IND=SAVNOLIGN2-1 : PARAM(1)=num$([M:PCP]DUDNUM(IND)) : PARAM(2)=num$([M:PCP]DUDLIG(IND))
  Default Mask ODEFMASK
  If FINTYP=2 | (!CAS & PARAM(3)="-1") : mkstat=2 : Return
  Elsif !CAS & PARAM(3)="0" : # Pas d'échéance
   # Aucune échéance
   GMESSAGE=mess(10,117,1) : mkstat=2 : Return
  Endif

  GMESSAGE=""
  If CAS=0 | CAS=3
   ## Contrôles bloquants
   Read [DUD]DUD1 = NNUM;NLIG 
   If fstat
    GOK=2 : Call RSTA("DUD",num$(NNUM)-num$(NLIG)) From GLOCK : mkstat=2 : Return
   Endif
   Gosub CTL_DUD
   If GMESSAGE<>"" : mkstat=2 : Return : Endif
   If NNUM<>[M:PCP]OD1 | NLIG<>[M:PCP]OD2
    ## Avertissements
    Call MTECHE(MT,IND) : FLMT=1
    # Echéance déjà soldée
    If [F:DUD]AMTCUR*MT<=0 : GMESSAGE+="\"+mess(15,117,1) : Endif
    Gosub VRF_DUD
    If instr(1,GMESSAGE,mess(28,121,1)) : mkstat=2 : Return : Endif
   Endif : # NNUM<>DUDNUM & NLIG<>DUDLIG
  Endif
  If CAS<>2 & (NNUM<>[M:PCP]OD1 | NLIG<>[M:PCP]OD2)
   For I=0 To [M:PCP]NBLIG-1
    If I<>IND & [M:PCP]DUDNUM(I)=NNUM & [M:PCP]DUDLIG(I)=NLIG 
    GMESSAGE+="\"+mess(22,117,1)-num$(I+1) :# Echéance imputée ligne I+1
   Endif
  Next I
  If len(GMESSAGE)>=mod(type(GMESSAGE)-10,256)
   # Echéance imputée sur plusieurs lignes
   GMESSAGE="\"+mess(140,121,1)
  Endif   
  If GMESSAGE<>""
   GMESSAGE=right$(GMESSAGE,2)
   I=2 : Call AVERTIR(GMESSAGE,I) From GESECRAN
   GMESSAGE="" : If I<>2 : mkstat=2 : Return : Endif
  Endif
 Endif
 
 If NNUM<>[M:PCP]DUDNUM(IND) | NLIG<>[M:PCP]DUDLIG(IND)
  PARAM(1)=num$(NNUM) : PARAM(2)=num$(NLIG)

  CODE_ESC = [F:DUD]DEP
   
  If [M:PCP]BPRPAY(IND)=""
   [M:PCP]BPRPAY(IND) = [F:DUD]BPRPAY
  Endif
  [M:PCP]DUDNUM(IND) = NNUM 
  [M:PCP]DUDLIG(IND) = NLIG
  [M:PCP]DUDDAT(IND) = [F:DUD]DUDDAT
  [M:PCP]FCYLIN(IND) = [F:DUD]FCY
  [M:PCP]BPRINV(IND) = [F:DUD]BPR
  #[M:PCP]DEP(IND)    = CODE_ESC
 Endif
 Affzo DUDDAT, BPRPAY, BPRINV, FCYLIN
Endcase
Return

$CTL_DUD
If [F:DUD]BPRFCT<>""
 # Facture gérée par le factor FACTOR 
 GMESSAGE = mess(89,121,1)-[F:DUD]BPRFCT : Return
Elsif [F:DUD]DUDSTA<>2 & !find([F:DUD]TYP,"*SO","*PO")
 Call LECTURE("BIC",[F:DUD]NUM,"") From CONTOBJ
 If fstat=0 & [F:SIH]GTE=[F:DUD]TYP
 If !find([F:SIH]ORIMOD,3,2)
  ## Echéance non validée 
  GMESSAGE = mess(28,121,1)
  Return
 Endif
Endif
If GMESSAGE<>"" : Return : Endif
Elsif [L]BPROPT=1 & [M:PCP]BPRPAY<>"" & !find([F:DUD]TYP,"*SO","*PO")
&  & ([F:DUD]BPR<>[M:PCP]BPRPAY(IND))
 # Génération OD-Tiers SAC BPR
 GMESSAGE = mess(19,117,1)-[F:DUD]SAC-[F:DUD]BPR
Endif
Return


$VRF_DUD
If [F:DUD]SOINUM<>"" & OPT<>"R" : # Echéance sur relevé SOINUM
 Gosub MSG_VRF_DUD 
 GMESSAGE+=mess(17,117,1)-[F:DUD]SOINUM
Endif
If [L]FCYOPT=3 & [M:PCP]FCY(nolign-1)<>"" & [F:DUD]FCY<>[M:PCP]FCYLIN(nolign-1) : # Génération OD-sites
 Gosub MSG_VRF_DUD 
 GMESSAGE+=mess(18,117,1)-[M:PCP]FCY(nolign-1)-"->"-[F:DUD]FCY
Endif
If [L]BPROPT=3 & [M:PCP]BPRPAY(nolign-1)<>"" & [F:DUD]BPR<>[M:PCP]BPRPAY(nolign-1)
 # Génération OD-tiers
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(19,117,1)-[M:PCP]BPRPAY(nolign-1)-"->"-[F:DUD]BPR
Endif
If !find([F:DUD]TYP,"*SO","*PO") & [F:DUD]DUDSTA<>2
 # Echéance non validée
 Gosub MSG_VRF_DUD 
 GMESSAGE+=mess(28,121,1)
Endif
Return

$MSG_VRF_DUD 
GMESSAGE+="\" : # Echéance
If GIMPORT : GMESSAGE+=mess(1,292,1)-num$([F:DUD]ACCNUM)-num$([F:DUD]DUDLIG)+" : " : Endif
Return


######################
Subprog MTECHE(MT,IND)
######################
Value Integer IND
Variable Decimal MT
Local Integer I, SIGN
MT=[F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
For I=0 To [M:PCP]NBLIG-1
 If I<>IND & [F:DUD]ACCNUM=[M:PCP]DUDNUM(I) & [F:DUD]DUDLIG=[M:PCP]DUDLIG(I)
  MT-=[M:PCP]AMTCUR(I)
 Endif
Next I
End
