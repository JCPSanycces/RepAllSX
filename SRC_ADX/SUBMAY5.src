#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque MAY5
End
######################################################################################
Subprog AS_TYPMRGX(VALEUR)
Variable Integer VALEUR

  If [M:MAI5]SHIMOD = 4 Then
    GMENLOC(1) = 1  # Utilisation de Seagate Crystal Report
    GMENLOC(2) = 1  # Utilisation de Microsoft Word
  Else
    GMENLOC(3) = 1  # Générer sur la machine cliente
    GMENLOC(4) = 1  # Générer sur le serveur
    If [M:MAI5]SHIMOD <> 1 Then
      # si différent de "Courrier", seul "Crystal Report" est autorisé.
      GMENLOC(2) = 1  # Utilisation de Microsoft Word
    Endif
  Endif
End

######################################################################################
Subprog AM_TYPMRGX(VALEUR)
Variable Integer VALEUR

  If VALEUR = 1 Then
    # Crystal
    Chgfmt [M:MAY5]MAGTPL With "K:" + type([M:MAY5]MAGTPL)-10 + "X"
  Elsif VALEUR = 2 Then
    # Word
    Chgfmt [M:MAY5]MAGTPL With "-K:1X"
  Else
    # XML
    Chgfmt [M:MAY5]MAGTPL With "K:" + type([M:MAY5]MAGTPL)-10 + "X"
  Endif
  [M:MAY5]TYPMRGX = VALEUR   # FGR à faire à cause de TRTMAY5.$SETBOUT le champ n'a pas encore la bonne valeur !
End

######################################################################################
Subprog C_MAGTPL(VALEUR)
Variable Char    VALEUR()

Local Char STEXTE(250)

  If VALEUR <> "" Then
    If [M:MAY5]TYPMRGX = 1 Then
      # Crystal
      Local File OMMRPT [OMR]
      Read [OMR]OMR0=GLANGUE;VALEUR
      If fstat Then
        # L'etat n'est pas défini
        Call TEXTE(17419, STEXTE) From OBJDIV      # Etat mailing
        GMESSAGE = STEXTE - ":" - VALEUR  - mess(1101,196,1)
        mkstat = 1
        End
      Endif
      # Vérifier que le fichier rpt existe dans REPORT/<langueDeConnexion>
      If filinfo(filpath("REPORT\" + GLANGUE, [F:OMR]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)), 7) < 0 Then
        # Le fichier Crystal n'existe pas
        GMESSAGE = [F:OMR]MAGTPLRPT + ".rpt :" - mess(1144,196,1)
        mkstat = 1
        End
      Endif
    Else
      # XML
      Local File MAILXML [MXL]
      Read [MXL]MXL0=VALEUR
      If fstat Then
        # L'etat n'est pas défini
        Call TEXTE(23535, STEXTE) From OBJDIV      # Publipostage XML
        GMESSAGE = STEXTE - ":" - VALEUR  - mess(1101,196,1)
        mkstat = 1
        End
      Endif
      # Vérifier qu'il a le bon type
      If [F:MXL]TYP = 1 Then
        # Tiers
        If GSZTYPSEA = "CCN" Then
          GMESSAGE = VALEUR - ":" - mess(59,100,1) - "'" + mess(1,3021,1) +  "'" - ":" - mess(357,199,1)
          mkstat = 1
          End
        Endif
      Elsif [F:MXL]TYP = 2 Then
        # Interlocuteur
        If GSZTYPSEA <> "CCN" Then
          GMESSAGE = VALEUR - ":" - mess(59,100,1) - "'" + mess(2,3021,1) +  "'" - ":" - mess(357,199,1)
          mkstat = 1
          End
        Endif
      Endif
    Endif
  Elsif [M:MAY5]TYPMRGX <> 2 Then
    GMESSAGE = mess(419,9139,1)
    mkstat = 1
    End
  Endif
End

######################################################################################
Subprog AM_MAGTPL(VALEUR)
Variable Char    VALEUR()

Local Char SZTPLSUFIX(30)
Local Char SZVALEUR(type(VALEUR)-10)

  If [M:MAY5]TYPMRGX = 1 Then
    # Crystal
    If VALEUR = "" Then
      [M:MAY5]MAGTPL = VALEUR
      Affzo [M:MAY5]MAGTPL
      End
    Endif
    SZVALEUR = VALEUR
    # Formatte le nom du modèle
    If len(SZVALEUR) >= 5 Then
      If mid$(SZVALEUR, len(SZVALEUR)-4, 4) = ".rpt" Then
        Call REMTPLEXT(SZVALEUR, [M:MAY5]MAGTPL) From CRM_UTIL
      Endif
    Endif
    # Crystal
    SZTPLSUFIX = ".rpt"
    Call ADDTPLEXT2(SZTPLSUFIX, [M:MAY5]MAGTPL, GSZNEWTPL) From CRM_UTIL
    #
    VALEUR = SZVALEUR
    [M:MAY5]MAGTPL = VALEUR
    Affzo [M:MAY5]MAGTPL
  Else
    # XML
  Endif
End
