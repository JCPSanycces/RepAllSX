#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ADELETE","ADELETE",3,"XYADELETE") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
Endcase
Return

#######################################################
## Actions nécessaires à la saisie des paramètres
#######################################################
$INIT
Local Char TIT(80)
GERREUR = 0
Onerrgo ERREUR
Gosub OUVRE
Onerrgo
If GERREUR : FIN = 1 : Return : Endif
Return

#######################################
$INIT_DIA
Raz [M:DIA]
If clalev([M:ABA1])=0
 nolign = 0
 For [ADL]ADL0
  nolign += 1
  [M:DIA] = [F:ADL]
  If dim([M:DIA]CRETIM)>0 & dim([F:ADL]CRETIM)>0
   [M:DIA]CRETIM(nolign-1) = format$("N0:##",int([F:ADL]CRETIM/3600))+format$("N0:##",int(mod([F:ADL]CRETIM,3600)/60))
  Endif
  Call SETDES([M:DIA]OBJ(nolign-1),[M:DIA]CLE1(nolign-1),[M:DIA]CLE2(nolign-1),[M:DIA]DES(nolign-1))
  If nolign>=dim([M:DIA]OBJ)
   Break
  Endif
 Next ADL
 [M:DIA]NBLIG = nolign
Endif
Return

#######################################
$OUVRE_BATCH
$OUVRE
If clalev([ADL])=0 : Local File ADELETE  [ADL] : Endif
If clalev([ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([ALI])=0 : Local File ALINK    [ALI] : Endif
If clalev([AOX])=0 : Local File AOBJTXT  [AOX] : Endif
If clalev([AOM])=0 : Local File AOBJTXTA [AOM] : Endif
Local File AOBJET [A_OB] , ADICTRT [A_DC] , AREPORT [A_RP]
Return

#######################################
$CONTROLE
If !GSERVEUR & clalev([M:ABA1])=0
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK<>1 or [M:DIA]NBLIG=0 : FIN = 1 : Return : Endif
 OK=2
 Call OUINON(mess(123,105,1),OK) From GESECRAN
 If OK<>2 : FIN=1 : Return : Endif
Endif
TMP = 1
Return

$TR1
GOK = 1
Trbegin [ADL]
 For nolign=1 To [M:DIA]NBLIG
  Delete [ADL] Where OBJ=[M:DIA]OBJ(nolign-1) & CLE1=[M:DIA]CLE1(nolign-1) & CLE2=[M:DIA]CLE2(nolign-1)
  If fstat=1
   GOK = -1 : GLOCK = "$ADELETE"
   Break
  Endif
 Next nolign
 If GOK<0 : Goto ROLL_TR1 : Endif
 I = 1
 For nolign=1 To [M:DIA]NBLIG
  While 1=1
   Look [ADL]ADL0=I
   If fstat
    Break
   Else
    I += 1
   Endif
  Wend
  [F:ADL] = [M:DIA]
  [F:ADL]NUM = I
  If dim([F:ADL]CRETIM)>0 & [F:ADL]CRETIM=0       : [F:ADL]CRETIM = time  : Endif
  If dim([F:ADL]CREDAT)>0 & [F:ADL]CREDAT=[0/0/0] : [F:ADL]CREDAT = date$ : Endif
  If dim([F:ADL]CREUSR)>0 & [F:ADL]CREUSR=""      : [F:ADL]CREUSR = GUSER : Endif
  Write [ADL]
  If fstat
   GOK = 0 : Call FSTA("ADL") From GLOCK : Break
  Endif
  I += 1
 Next nolign
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

##############################################################
## Actions nécessaires à la suppression
##############################################################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(mess(3,115,1)) From LECFIC : # Suppressions
 TRA = 1
Else
 Call ECR_TRACE(mess(3,115,1)-format$("D:",date$)-time$,0) From GESECRAN
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif

For [ADL]ADL0
 Call SUPPRIME([F:ADL]OBJ,[F:ADL]CLE1,[F:ADL]CLE2,OK)
 If OK
  Trbegin [ADL]
   Delete [ADL]
   If fstat=1
    Call ECR_TRACE(mess(49,125,1)-": ADELETE",1) From GESECRAN : # Erreur de lecture
    Rollback : Break
   Endif
  Commit
 Endif
Next ADL

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Else
 Call ECR_TRACE("",0) From GESECRAN
Endif
Return

$ERREUR
Call ECR_TRACE(errp+"("+num$(errl)+") :"-errmes$(errn)-errm,1) From GESECRAN
GERREUR = errn
Resume

#######################################################################################
Subprog SUPPRIME(ABREV,CLE1,CLE2,OKANU)
Value    Char ABREV
Value    Char CLE1
Value    Char CLE2
Variable Integer OKANU
If dim(CLE2)=1 & instr(1,CLE2,"~")
 Gosub SET_CLETAB From GOBJET
 Call SUPOBJ(ABREV,CLE1,CLETAB,OKANU)
Else
 Call SUPOBJ(ABREV,CLE1,CLE2,OKANU)
Endif
End

#######################################################################################
Subprog SUPOBJ(ABREV,SAVCLE1,SAVCLE2,OKANU)
Value    Char ABREV
Value    Char SAVCLE1
Value    Char SAVCLE2()
Variable Integer OKANU

Local Char    ACTION(20) , SAVFONC(GLONAFC) , SAVABREV(GLONAOB)
Local Char    CLEAFF(250) , CHAINE(255) , MESSA(250)
Local Integer PSUB, PSPE, PSPV, OKVAR, OKCHARGE, NDOS, SAVIMP, OK, STAT
Local Char    NOMDOS(20)(1..255) , FENETRE(GLONFEN) , WINPROG(GLONADC)
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(30)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)

OKANU = 0

Case ABREV
 When "AML" : Gosub SUP_AML : End
 When "TRT" : Gosub SUP_TRT : End
 When "ETA" : Gosub SUP_ETA : End
 When "ADO" : Gosub SUP_ADO : End
Endcase

SAVABREV = GABREV
SAVIMP  = GIMPORT

GABREV = ABREV

Raz GTUNCPT

NDOS = 1 : NOMDOS(NDOS) = nomap(0)
If GDOSH<>""
 NDOS += 1 : NOMDOS(NDOS) = GDOSH
Endif

Gosub DEFVAR From GOBJET
If GPRODUIT=1 : ## GEODE
 SAVDEP       = GDEP
 SAVFCY       = GFCY
Endif

CLE1  = SAVCLE1
For CL = 0 To dim(SAVCLE2)-1 : SCLE2(CL) = SAVCLE2(CL): Next CL
Call CLEAFF(ABREV,CLE1,SCLE2,CLEAFF)
If CLEAFF="" : CLEAFF = CLE1-sigma(CL=0,dim(SCLE2)-1,"~"+SCLE2(CL)) : Endif
Gosub TIT From =PROGOBJ
Local File =NOMFIC [AN__]
Gosub OUVFIC From =PROGOBJ

# Choix d'une fenêtre disponible
Call CONT_FEN(ABREV,FENETRE) From GOBJET
If FENETRE=""
 Call ECR_TRACE(mess(107,133,1),1) From GESECRAN : # Il n'y pas de fenêtre disponible pour cet objet
 Goto FIN_SUPP
Else
 Call NOMTRTWIN(FENETRE,WINPROG) From MSKDIV
Endif
OK = 1 : Raz GMESSAGE
Gosub SET_MODE
ACTION = "AVANT_OUVRE" : Gosub GACTION
Gosub UNSET_MODE
If !OK
 If GMESSAGE<>"" : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Endif
 Goto FIN_SUPP
Endif

Onerrgo ERREUR From CONTROLE
Gosub OUVRE  From =PROGOBJ
Onerrgo
If GERREUR : GERREUR=0 : Goto FIN_SUPP : Endif
Gosub NOMFIC From =PROGOBJ
Raz AMA
For MA=0 To dim(AMA)-1 : AMA(MA) = 1 :  Next MA

Gosub VARIANTE
If !OKVAR : Goto FIN_SUPP : Endif

Gosub OUVRE_MSK From GOBJET
Gosub ESPION From =PROGOBJ

OK = 1 : Raz GMESSAGE
Gosub SET_MODE
Onerrgo ERREUR From CONTROLE
ACTION = "OUVRE" : Gosub GACTION
Onerrgo
Gosub UNSET_MODE
If GERREUR : GERREUR=0 : Goto FIN_SUPP : Endif
If !OK
 If GMESSAGE<>"" : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Endif
 Goto FIN_SUPP
Endif
If !OKVAR : Goto FIN_SUPP : Endif

Gosub INIT_BOITE From =WINPROG

Gosub SET_MODE
ACTION = "AFFMASK" : Gosub GACTION
Gosub UNSET_MODE

Gosub CHARGE_MSK
Case OKCHARGE
 When -1
  OKANU = 1 : Goto FIN_SUPP
 When 0
  Goto FIN_SUPP
Endcase

ACTION = "ADELETE" : Gosub GACTION

Call ECR_TRACE(time$-mess(53,123,1)-TIT-":"-CLEAFF,0) From GESECRAN : # Suppression

OKANU = 1
GIMPORT = 1 :  # pour la récup des erreurs dans GMESSAGE
Read [A_OB]ABREV = ABREV
If fstat
 OKANU=0
Else
 For I=1 To NDOS
  Call VERIF(NOMDOS(I),ABREV,CLE1,SCLE2,OKANU) From ANUCOD
  If !OKANU : Break : Endif
 Next I
Endif
If !OKANU
 If GMESSAGE="" : GMESSAGE=mess(1,115,1) : Endif : # Suppression impossible
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 Goto FIN_SUPP
Endif
For I=1 To NDOS
 Call ANNULATION(NOMDOS(I),ABREV,CLE1,SCLE2) From ANUCOD
Next I
If GOK<1
 OKANU = 0
 Call ECR_TRACE(mess(18,114,1)-GMESSAGE,1) From GESECRAN : # Transaction abandonnée
Else
 Call ANNULE(ABREV,CLE1,SCLE2) From GOBJTXT
 Call ANNULE(ABREV,CLE1,SCLE2) From SUBALI
 SAVFONC = GFONCTION
 GFONCTION = "GES"+ABREV
 Call IDENT3(ABREV,IDENT,CLE1,SCLE2) From GOBJTXT
 Call ESPION(NOMFIC,3,IDENT,"") From ESPION
 Call WORKFLOW(2,ABREV,"S",IDENT) From AWRK
 GFONCTION = SAVFONC
 Call ECR_TRACE(time$-mess(60,126,1),0) From GESECRAN : # Suppression effectuée
 Call ECR_TRACE("",0) From GESECRAN
Endif

$FIN_SUPP
If dim([L]VERROU)>0 & VERROU
 Unlock =SYMBOLE
 ACTION = "DEVERROU" : Gosub GACTION
Endif

ACTION = "FERME" : Gosub GACTION

GIMPORT = SAVIMP
GABREV  = SAVABREV
If GPRODUIT=1 : ## GEODE
 GDEP = SAVDEP
 GFCY = SAVFCY
Endif
End

#######################################
$SET_MODE
Local Integer  INBAFF , IAFFCOD(0..10) , IAFFIND(0..10) , IAFFRANG(0..10) , IAFFOPT1(0..10) , IAFFOPT2(0..10)
Local Char     IAFFMASK(GLONABR)(0..10) , IAFFCHP(50)(0..10) , IAFFTXT(250)(0..10)
Setmode INBAFF , IAFFCOD , IAFFMASK , IAFFCHP , IAFFIND , IAFFTXT , IAFFRANG , IAFFOPT1 , IAFFOPT2
Return

#######################################
$UNSET_MODE
Setmode
Return

#######################################
$CHARGE_MSK
OKCHARGE = 1
Gosub SETCLE From =PROGOBJ
Gosub DEFAUT From =PROGOBJ
If evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")>=10
 CRITERE = CLEPRIM+'="'+CLE1+'"'
Elsif evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")=3
 CRITERE = CLEPRIM+'=['+CLE1+']'
Else
 CRITERE = CLEPRIM+'='+CLE1
Endif
For CL=0 To dim(CLESEC)-1
 If TYPGES=3 & CLESEC(CL)=CLELIG : Break : Endif
 If CLESEC(CL)<>""
  CRITERE -= "&"-CLESEC(CL)+'='
  If evalue("type([F:"+ABFIC+"]"+CLESEC(CL)+")")>=10
   CRITERE += '"'+SCLE2(CL)+'"'
  Elsif evalue("type([F:"+ABFIC+"]"+CLESEC(CL)+")")=3
   CRITERE += '['+SCLE2(CL)+']'
  Else
   CRITERE += SCLE2(CL)
  Endif
 Endif
Next CL
Filter [F] Where evalue(CRITERE)
Assign "[G:"+ABFIC+"]currind" With 1
If TYPGES=3
 Assign "[G:"+ABFIC+"]currlen" With dim(CLESEC)
Else
 Assign "[G:"+ABFIC+"]currlen" With 0
Endif
Read First
Filter [F]
If fstat
 Call ECR_TRACE(TIT-CLEAFF-":"-mess(6,114,1),1) From GESECRAN : # Clé inexistante
 OKCHARGE = -1 : Return
Endif
[F:AN__] = [F]

If dim([L]CLEFCY)>0 & [L]CLEFCY<>""
 GFCY=evalue("[F:"+ABFIC+"]"+[L]CLEFCY)
Endif
If dim([L]CLEDEP)>0 & [L]CLEDEP<>""
 GDEP=evalue("[F:"+ABFIC+"]"+[L]CLEDEP)
Endif
CLECUR1 = CLE1
For CL=0 To dim(CLESEC)-1
 CLECUR2(CL)=SCLE2(CL)
Next CL

If evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")>10
 TPCLE1 = 1
Elsif evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")=3
 TPCLE1 = 3
Else
 TPCLE1 = 2
Endif
For CL=0 To dim(CLESEC)-1
 If CLESEC(CL)<>""
  If evalue("type([F:"+ABFIC+"]"+CLESEC(CL)+")")>10
   TPCLE2(CL) = 1
  Elsif evalue("type([F:"+ABFIC+"]"+CLESEC(CL)+")")=3
   TPCLE2(CL) = 3
  Else
   TPCLE2(CL) = 2
  Endif
 Endif
Next CL

Gosub SYMBOLE From GOBJET
Lock =SYMBOLE With lockwait=0
If fstat
 Call ECR_TRACE(TIT-CLEAFF-":"-mess(10,100,1),1) From GESECRAN : # En cours de modif...
 OKCHARGE = 0 : SYMBOLE="" : Return
Else
 OK=1
 ACTION = "VERROU" : Gosub GACTION
 If !OK : Unlock =SYMBOLE : OKCHARGE = 0 : Return : Endif
Endif
VERROU=1

Gosub OUVOBJ From GOBJET : # Pour AOX
For MA=0 To NBMASK
 If AMA(MA)<2
  Gosub RAZMASK From =WINPROG
 Endif
Next MA
Case TYPGES
 When 1 : Gosub CHARGE From GOBJET1
 When 2 : Gosub CHARGE From GOBJET2
 When 3 : Gosub CHARGE From GOBJET3
Endcase
For MA=0 To NBMASK
 If AMA(MA)
  Gosub SETMASK  From =WINPROG
 Endif
Next MA
If TYPGES=1
 ACTION = "LIENS" : Gosub GACTION
Endif
Gosub DEFAUT From =PROGOBJ : # cas ou un close local file est fait dans le lien

[F] = [F:AN__] : # Pour les objets de TYPGES<>1
Return

#######################################
$VARIANTE
VARIANTE = 0
GVARIANTE = 0
OKVAR = 1
If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
OK = 1 : GMESSAGE = ""
Gosub SET_MODE
ACTION = "DEFTRANS" : Gosub GACTION
Gosub UNSET_MODE
If !OK
 If GMESSAGE<>"" : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Endif
 OKVAR = 0
 Return
Endif
If GFLAG<>"" & left$(GFLAG,1)<>"\"
 Read [AWI]AWI2(2) = ABREV;GFLAG
 If fstat or [F:AWI]ENAFLG<>2
  GFLAG = "\"
 Else
  GBOITE = [F:AWI]WIN
 Endif
Endif
If GFLAG="" or left$(GFLAG,1)="\"
 Gosub DEF_VARIANTE
 If GFLAG="" : GFLAG = OGFLAG : Endif : # Pour ne pas sortir si on est déjà entré !
Endif
If GFLAG="" : OKVAR = 0 : Return : Endif
VARIANTE = 1
GVARIANTE = 1 : # Globale à cause d'ANUCOD et CHGCOD
If GFLAG="1-3-5-7-9-"
 GFLAG = "" : # TS pas de code transaction si objet sans variante
Endif
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG
Gosub SET_MODE
ACTION = "SETTRANS" : Gosub GACTION
Gosub UNSET_MODE
Return

#######################################
$DEF_VARIANTE
Local Integer VARINB , VARIREP
Local Char    VARICOD(10)(200)
Local Char    VARIBOI(GLONFEN)(200) #X3-46988 BODEL Deferred deletion fails because variable isn't large enough
Local Char    VARCOD(10)
VARINB = 0
GFLAG = right$(GFLAG,2)
For [AWI]AWI1 Where OBJ=ABREV & ENAFLG=2 & MDL<>2
 OK = 1
 If [F:AWI]CODACT<>""
  If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat | [F:ACV]FLACT<>2
   OK = 0
  Endif
 Endif
 If OK & [F:AWI]ACS<>"" & GUSRACS<>2
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [ACC]CODACC = GUSER;[F:AWI]ACS
  If fstat | [F:ACC]EXEC<>2
   OK = 0
  Endif
 Endif
 If OK
  VARCOD = [F:AWI]TRN
  ACTION = "VARIANTE" : Gosub GACTION
 Endif
 If OK
  VARINB += 1
  VARIBOI(VARINB) = [F:AWI]WIN
  VARICOD(VARINB) = VARCOD
  Break
 Endif
Next
If VARINB=0
 Call ECR_TRACE(mess(4,126,1),1) From GESECRAN : # Aucune transaction autorisée
 GFLAG = ""
Else
 GFLAG  = VARICOD(1)
 GBOITE = VARIBOI(1)
 If GFLAG="" : GFLAG="1-3-5-7-9-" Endif : # TS pas de code transaction si objet sans variante
Endif
Return

#######################################
$GACTION
GPE = 0
GPV = 0
If PSPE
 Gosub ACTION From =PROGSPE
Endif
If PSPV & !GPV
 If dim(GENTOBJ)>0 & dim(PROGSPV)>1
  For IPE=1 To dim(PROGSPV)
   If PROGSPV(IPE)="" : Break : Endif
   Gosub ACTION From =PROGSPV(IPE)
  Next IPE
 Else
  Gosub ACTION From =PROGSPV
 Endif
Endif
If PSUB & !GPE
 Gosub ACTION From =PROGSUB
Endif
Return

###################################
Subprog SETDES(OBJET,CLE1,CLE2,DES)
###################################
Value    Char OBJET(), CLE1(), CLE2()
Variable Char DES()

Local Integer I1, I2, J, OKTRT
Local Char    PROGOBJ(GLONADC)
Local Char    VCLE(50), ZCLE(GLONAVA), CLE(250), VCLE2(250)

DES = ""

Case OBJET
 When "TRT"
  Read [A_DC]ADC0=CLE1
  If !fstat
   DES = [F:A_DC]DES
  Else
   DES = mess(19,123,1) : # Traitement
  Endif
  End
 When "ETA"
  Read [A_RP]ARP0=CLE1
  If !fstat
   Call TEXTE([F:A_RP]RPTDES,DES) From OBJDIV
  Else
   DES = mess(1,91,1) : # Etat Crystal Report
  Endif
  End
 When "AML"
  Local File AMENLOC [AML] , APLSTD [AST4] , APLSTD [AST5] , APLSTD [AST6]
  Link [AML]  With [AST4]CLE = [F:AML]MENLOC;0;GLANGUE
&                , [AST5]CLE = 0;[F:AML]MENLOC;GLANGUE
&                , [AST6]CLE = 200;([F:AML]MENLOC-200);GLANGUE
& As [AML_]
& Order By Key MENLOC
  Call CONTROLE("AML","#",CLE1,"",mkstat) From CONTOBJ
  If !fstat
   Read [AML_]MENLOC=val(CLE1)
   DES =  string$([F:AML]MENLOC<100&[F:AML]MENLOCAL=2,[F:AST5]LANMES)
   DES -= string$([F:AML]MENLOC>200&[F:AML]MENLOCAL=2,[F:AST6]LANMES)
   DES -= string$([F:AML]MENLOCAL<>2,[F:AST4]LANMES)
  Else
   DES = ""
  Endif
  End
Endcase

PROGOBJ = "WO"+OBJET
Call EXISTE_ADX("","",PROGOBJ,OKTRT) From ORDSYS
If !OKTRT : End : Endif

Gosub NOMFIC From =PROGOBJ
If NOMINT="" : End: Endif
Local File ATABZON [A_TZ]
Gosub OUVFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ

VCLE = CLE1
ZCLE = CLEPRIM
Gosub AFF_CLE

CLE = CLE2
J   = 0
While CLE<>""
 I1 = instr(1,CLE,"~")
 If I1
  VCLE = left$(CLE,I1-1)
  CLE  = right$(CLE,I1+1)
 Else
  VCLE = CLE
  CLE  = ""
 Endif
 If dim(CLESEC)<J+1 or CLESEC(J)="" or (TYPGES=3 & CLESEC(J)=CLELIG) : Break : Endif
 ZCLE = CLESEC(J)
 Gosub AFF_CLE
 J+=1
Wend

Gosub DEFAUT From =PROGOBJ
[G]currind = 1
If TYPGES=3 : [G]currlen = dim(CLESEC)
Else        : [G]currlen = 0
Endif
Read =
If fstat
 End
Elsif evalue("type([F]"+NOMINT+")")>10
 DES = evalue("[F]"+NOMINT)
Else
 Read [A_TZ]CODZONE = NOMFIC ; NOMINT
 If fstat
  End
 Elsif [F:A_TZ]CODTYP="ATX"
  Call TEXTE(evalue("[F]"+NOMINT),DES) From OBJDIV
 Elsif find([F:A_TZ]CODTYP,"AXX","AX1","AX2","AX3")
  Local File ATABIND [A_TI]
  Read [A_TI]NUMLIG(2) = NOMFIC;1
  If fstat : End : Endif
  CLE = [F:A_TI]DESCRIPT
  J = 0 : VCLE2 = "" : VCLE = ""
  While CLE<>""
   I1 = instr(1,CLE,"+")
   I2 = instr(1,CLE,"-")
   If I2
    If I1 : I1 = min(I1,I2) : Else : I1=I2 : Endif
   Endif
   If I1
    ZCLE = left$(CLE,I1-1)
    CLE  = right$(CLE,I1+1)
   Else
    ZCLE = CLE
    CLE=""
   Endif
   If TYPGES=3 & ZCLE=CLELIG : Break
   Elsif J=0 : VCLE = num$(evalue("[F:"+ABFIC+"]"+ZCLE))
   Elsif J=1 : VCLE2+= num$(evalue("[F:"+ABFIC+"]"+ZCLE))
   Else      : VCLE2+= "~"+num$(evalue("[F:"+ABFIC+"]"+ZCLE))
   Endif
   J+=1
  Wend
  Call LECTEXTRA(DES,NOMFIC,NOMINT,VCLE,VCLE2) From ATEXTRA
 Endif
Endif
End

$AFF_CLE
If evalue("type([F:"+ABFIC+"]"+ZCLE+")")>10
 Assign "[F:"+ABFIC+"]"+ZCLE With VCLE
Elsif evalue("type([F:"+ABFIC+"]"+ZCLE+")")=3
 If VCLE="" : VCLE = "00000000" : Endif
 If instr(1,VALEUR,"/")
  Assign "[F:"+ABFIC+"]"+ZCLE With evalue("["+VCLE+"]")
 Else
  Assign "[F:"+ABFIC+"]"+ZCLE With VCLE
 Endif
Else
 Assign "[F:"+ABFIC+"]"+ZCLE With val(VCLE)
Endif
Return

###################################
Subprog CLEAFF(OBJET,CLE1,CLE2,DES)
###################################
Value    Char OBJET(), CLE1(), CLE2()()
Variable Char DES()

Local Integer I1, I2, J
Local Char    PROGOBJ(GLONADC)
Local Char    VCLE(50), ZCLE(GLONAVA), CLE(250)

PROGOBJ="WO"+OBJET
DES=""

Gosub NOMFIC From =PROGOBJ
Local File ATABZON [A_TZ]
Gosub OUVFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ

Local File ATABIND [A_TI]
Read [A_TI]NUMLIG(2) = NOMFIC;1
If fstat=0
 CLE = [F:A_TI]DESCRIPT
 While CLE<>""
  I1 = instr(1,CLE,"+")
  I2 = instr(1,CLE,"-")
  If I2
   If I1 : I1 = min(I1,I2) : Else : I1=I2 : Endif
  Endif
  If I1
   ZCLE = left$(CLE,I1-1)
   CLE  = right$(CLE,I1+1)
  Else
   ZCLE = CLE
   CLE=""
  Endif
  If TYPGES=3 & ZCLE=CLELIG : Break : Endif
  J=find(ZCLE,CLEPRIM,CLESEC)
  If J=1    : VCLE = CLE1
  Elsif J>1 : VCLE = CLE2(J-2)
  Else      : VCLE = ""
  Endif
  If VCLE="" : VCLE="~" : Endif
  If DES<>"" : DES+=" " : Endif
  DES += VCLE
 Wend
Endif
End

####################################################################
$SUP_AML
Local File APLSTD [AST] , AMENLOC [AML]
Local Integer CHAPITRE , VERROU , TROUVE
Local Char SYMBOLE(250)
CHAPITRE = val(SAVCLE1)
Read [AML]MENLOC=CHAPITRE
If fstat
 Call ECR_TRACE(mess(78,100,1)-num$(CHAPITRE)-":"-mess(208,115,1),1) From GESECRAN : # Chapitre inexistant
 OKANU = 1 : Return
Endif
Gosub VERROU From APLSTD
If !VERROU
 Call ECR_TRACE(mess(78,100,1)-num$(CHAPITRE)-":"-mess(10,100,1),1) From GESECRAN : # Modification en cours sur un autre poste
 OKANU = 0 : Return
Endif
If [F:AML]MENLOCAL=2
 Call VERIF_MEN(CHAPITRE,OK,MESSA) From APLSTD
 If !OK
  Call ECR_TRACE(mess(78,100,1)-num$(CHAPITRE)-":"-mess(1,115,1)+"\"+MESSA,1) From GESECRAN : # Suppression impossible
  OKANU = 1 : Goto FIN_MENLOC
 Endif
Elsif GSOPHIA
 Call RECHERCHE("TRT","mess(*,"+num$(CHAPITRE)+",*)",TROUVE) From RECHADC
 If TROUVE
  Call ECR_TRACE(mess(78,100,1)-num$(CHAPITRE)-":"-mess(1,115,1)+"\"+MESSA,1) From GESECRAN : # Suppression impossible
  OKANU = 1 : Goto FIN_MENLOC
 Endif
Endif
Call ANNU(CHAPITRE,[F:AML]MENLOCAL) From APLSTD
If GOK>=1
 Call ECR_TRACE(mess(189,125,1)-num$(CHAPITRE),0) From GESECRAN : # Suppression du chapitre
Endif
OKANU = (GOK=1)

$FIN_MENLOC
Gosub DEVERROU From APLSTD
Return

####################################################################
$SUP_TRT
If filinfo(filpath("TRT",SAVCLE1,"LCKsrc",nomap),0)>0
 Call ECR_TRACE("|"+filpath("TRT",SAVCLE1,"LCKsrc",nomap)-"|\"+mess(13,139,1),1) From GESECRAN : # Traitement verrouillé
 OKANU = 0 : Return
Endif
Call EXISTE_ADX("",nomap,SAVCLE1,OK) From ORDSYS
If !OK & filinfo(filpath("TRT",SAVCLE1,"src",nomap),0)<=0 & filinfo(filpath("TRT",SAVCLE1,"adx",nomap),0)<=0
 Call ECR_TRACE(SAVCLE1-":"-mess(90,123,1),1) From GESECRAN : # Traitement inexistant
 OKANU = 1 : Return
Endif
Call VERF_ANU("ADC","ADICTRT",SAVCLE1,CHAINE)
If CHAINE<>""
 # Suppression impossible
 Call ECR_TRACE(SAVCLE1-":"-mess(1,115,1)+"\"+CHAINE,1) From GESECRAN
 OKANU = 0 : Return
Endif
If filinfo(filpath("TRT",SAVCLE1,"src",nomap),0)>0
 Call EFFACE(filpath("TRT",SAVCLE1,"src",nomap),STAT) From ORDSYS
Endif
If filinfo(filpath("TRT",SAVCLE1,"xrc",nomap),0)>0
 Call EFFACE(filpath("TRT",SAVCLE1,"xrc",nomap),STAT) From ORDSYS
Endif
Call EFFACE_ADX("",nomap,SAVCLE1,STAT) From ORDSYS
If filinfo(filpath("TRT",SAVCLE1,"adx",nomap),0)>0
 Call EFFACE(filpath("TRT",SAVCLE1,"adx",nomap),STAT) From ORDSYS
Endif
OKANU = (STAT=0)
# Suppression du traitement #
Call ECR_TRACE(func AFNC.MES(mess(193,125,1),SAVCLE1),0) From GESECRAN
Return

####################################################################
$SUP_ETA
If filinfo(filpath("REPORT/"+GLANGUE,SAVCLE1,"rpt",nomap),0)<=0
 Call ECR_TRACE(SAVCLE1-":"-mess(163,123,1),1) From GESECRAN : # Etat inexistant
 OKANU = 1 : Return
Endif
Call VERF_ANU("ACR","",SAVCLE1,CHAINE)
If CHAINE<>""
 # Suppression impossible
 Call ECR_TRACE(SAVCLE1-":"-mess(1,115,1)+"\"+CHAINE,1) From GESECRAN
 OKANU = 0 : Return
Endif
Call EFFACE(filpath("REPORT/"+GLANGUE,SAVCLE1,"rpt",nomap),STAT) From ORDSYS
OKANU = (STAT=0)
# Suppression de l'état Crystal Report #
Call ECR_TRACE(func AFNC.MES(mess(194,125,1),SAVCLE1),0) From GESECRAN
Return

####################################################################
$SUP_ADO
If SAVCLE2(1)<>""
 Call ANNU(SAVCLE2(0),SAVCLE1,SAVCLE2(1),MESSA) From SUBADO
 If GOK=1
  Call ECR_TRACE(MESSA,0) From GESECRAN
 Endif
 OKANU = (GOK=1)
Else
 Call ECR_TRACE(SAVCLE1-SAVCLE2-":"-mess(262,139,1),1) From GESECRAN : # Documentation inexistante
 OKANU = 1
Endif
Return

####################################################################
Subprog VERF_ANU(TYP,TABLE,CLE,MESSA)
Value Char TYP , TABLE , CLE
Variable Char MESSA
Local Integer I , ER , OK , DIME
Local Char    NOMZON(30)
If !GSERVEUR
 Call TEMPON(mess(4,115,1)) From GESECRAN : # Vérifications
Endif
Local File ATABZON [ATZ]
Raz MESSA
For [ATZ] Where CODTYP=[L]TYP & CODFIC<>[L]TABLE
 If filinfo(filpath("FIL",[F:ATZ]CODFIC,"fde",nomap),0)>0
  ER = 0
  Onerrgo ERRFIC
  Local File =[F:ATZ]CODFIC [AAA_]
  Read [AAA_] First
  Onerrgo
  If !ER
   DIME = evalue("dim([F:AAA_]"+[F:ATZ]CODZONE+")")
   OK = 0
   For [AAA_]
    If DIME=1
     NOMZON = "[F:AAA_]"+[F:ATZ]CODZONE
     Case evalue("type([F:AAA_]"+[F:ATZ]CODZONE+")")
      When 1,2,4,5,6,7 : OK = (evalue(NOMZON) = val(CLE))
      When Default     : OK = (evalue(NOMZON) = CLE)
     Endcase
    Elsif DIME>1
     For I=0 To DIME-1
      NOMZON = "[F:AAA_]"+[F:ATZ]CODZONE+"("+num$(I)+")"
      Case evalue("type([F:AAA_]"+[F:ATZ]CODZONE+")")
       When 1,2,4,5,6,7 : OK = (evalue(NOMZON) = val(CLE))
       When Default     : OK = (evalue(NOMZON) = CLE)
      Endcase
      If OK : Break : Endif
     Next I
    Endif
    If OK
     Call ERRCLE([F:ATZ]CODFIC,"AAA_",MESSA)
     Break 2
    Endif
   Next AAA_
   Close Local File [AAA_]
  Endif
 Endif
Next ATZ
Close Local File [ATZ]
If !GSERVEUR
 Call TEMPOFF From GESECRAN
Endif
End

$ERRFIC
ER = errn
Resume

Subprog ERRCLE(TABLE,ABREV,MESSA)
Value Char TABLE , ABREV
Variable Char MESSA
Local Char    CLE(GLONAVA)(1..16) , NOMCLE(250) , CODCLE(GLONID) , CHAINE(250) , TEXTE(250)
Local Integer I , J , NBCLE
If clalev([F:ATB_])=0 : Local File ATABLE  [ATB_] : Endif
If clalev([F:ATZ_])=0 : Local File ATABZON [ATZ_] : Endif
If clalev([F:ATI_])=0 : Local File ATABIND [ATI_] : Endif
If clalev([F:ATX])=0  : Local File ATEXTE  [ATX]  : Endif
Read [ATI_]NUMLIG(2) = TABLE;1
CHAINE = [F:ATI_]DESCRIPT
Raz CLE, NBCLE
While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 NBCLE += 1
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
If [F:ATI_]DESCRIPT=CLE(1)
 Read [ATZ_]CODZONE = TABLE ; CLE(1)
 Call TEXTE([F:ATZ_]NOLONG,NOMCLE) From OBJDIV
Else
 NOMCLE = mess(55,123,1)-"(" : # Clé
 For I=1 To NBCLE
  If I>1 : NOMCLE += "+" : Endif
  Read [ATZ_]CODZONE = TABLE ; CLE(I)
  Call TEXTE([F:ATZ_]NOLONG,CHAINE) From OBJDIV
  NOMCLE += CHAINE
 Next I
 NOMCLE += ")"
Endif
CODCLE = ""
For I=1 To NBCLE
 If CODCLE<>"" : CODCLE += "+" : Endif
 CODCLE += num$(evalue("["+ABREV+"]"+CLE(I)))
Next I
MESSA = mess(49,139,1) : # Clé utilisée dans
Read [ATB_]CODFIC=TABLE
Call TEXTE([F:ATB_]INTITFIC,TEXTE) From OBJDIV
MESSA -= TEXTE-"("+[F:ATB_]CODFIC+")"
MESSA -= "\"+NOMCLE-"="-CODCLE
End

################################################
## Ecran ADELETE
################################################

Subprog C_CLE1(VALEUR)
Variable Char VALEUR
Local Char    OBJET(GLONAOB) , SUPP(10)
Local Integer I
Case [M]OBJ(nolign-1)
 When "TRT","ADX","ETA"
  VALEUR = vireblc(toupper(VALEUR),4)
 When "AML"
  Call CONTROLE("AML","#",VALEUR,"",mkstat) From CONTOBJ
 When Default
  OBJET = [M]OBJ(nolign-1)
  Gosub NOMFIC From ="WO"+OBJET
  Gosub SETCLE From ="WO"+OBJET
  If CLESEC="" or TYPGES=3
   For I=0 To [M]NBLIG-1
    If I<>nolign-1 & [M]OBJ(I)=[M]OBJ(nolign-1) & [M]CLE1(I)=VALEUR
     GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
     mkstat=2 : Break
    Endif
   Next I
   If mkstat : End : Endif
   Call CONTROLE(OBJET,"",VALEUR,SUPP,mkstat) From CONTOBJ
  Endif
Endcase
End

Subprog AS_CLE2(VALEUR)
Variable Char VALEUR
Local Char OBJET(GLONAOB)
Case [M]OBJ(nolign-1)
 When "TRT","ADX","ETA","AML"
  mkstat = 1 : End
 When Default
  OBJET = [M]OBJ(nolign-1)
  Gosub NOMFIC From ="WO"+OBJET
  Gosub SETCLE From ="WO"+OBJET
  If CLESEC="" or TYPGES=3
   mkstat = 1 : End
  Endif
Endcase
End

Subprog C_CLE2(VALEUR)
Variable Char VALEUR
Local Char    OBJET(GLONAOB)
Local Integer I
Case [M]OBJ(nolign-1)
 When "TRT","ADX","ETA","AML"
 When Default
  OBJET = [M]OBJ(nolign-1)
  Gosub NOMFIC From ="WO"+OBJET
  Gosub SETCLE From ="WO"+OBJET
  For I=0 To [M]NBLIG-1
   If I<>nolign-1 & [M]OBJ(I)=[M]OBJ(nolign-1) & [M]CLE1(I)=[M]CLE1(nolign-1) & [M]CLE2(I)=VALEUR
    GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
    mkstat=2 : Break
   Endif
  Next I
  If mkstat : End : Endif
  Call CONTROLE(OBJET,"",[M]CLE1(nolign-1),VALEUR,mkstat) From CONTOBJ
Endcase
End

Subprog S_CLE1(VALEUR)
Variable Char    VALEUR()
Local Char    PARMSK(250)(1..2)
Case [M]OBJ(nolign-1)
 When "TRT"
  PARMSK(2) = "src"
  Call S_TAB_CHAR(VALEUR,PARMSK,"SELTRT","EDITRTWEB","") From GACTION
 When "ADX"
  PARMSK(2) = "adx"
  Call S_TAB_CHAR(VALEUR,PARMSK,"SELTRT","EDITRTWEB","") From GACTION
 When "ETA"
  Call S_TAB_CHAR(VALEUR,PARMSK,"SELCRY","SUBARP","") From GACTION
 When "AML"
  Local Integer PARVAL
  PARVAL = val(VALEUR)
  Call S_TAB_LIB(PARVAL,PARMSK,"SELAST","APLSTD","") From GACTION
  VALEUR = num$(PARVAL)
 When Default
  Call SELECT([M]OBJ(nolign-1),"",VALEUR,[M]CLE2(nolign-1)) From SELOBJ
Endcase
End

Subprog C_OBJ(VALEUR)
Variable Char     VALEUR
Case VALEUR
 When "TRT","ADX","ETA","AML"
 When Default
  Call CONTSEL("AOB","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
  Gosub NOMFIC From ="WO"+VALEUR
  If dim(DELDEF)<=0 or !DELDEF
   GMESSAGE = mess(149,126,1) : # La suppression différée est désactivée pour cet objet
   mkstat = 1 : End
  Endif
Endcase
End

Subprog AV_INTIT(VALEUR)
Variable Char    VALEUR()
Case [M]OBJ(nolign-1)
 When "TRT"
  VALEUR = mess(43,115,1) : # Traitement (src)
 When "ADX"
  VALEUR = mess(44,115,1) : # Traitement (adx)
 When "ETA"
  VALEUR = mess(45,115,1) : # Etat (rpt)
 When Default
  Read [A_OB]ABREV=[M]OBJ(indice)
  If !fstat
   Call TEXTE([F:A_OB]LIBEL,VALEUR) From OBJDIV
  Endif
Endcase
End

Subprog C_NBLIG
If GPRODUIT=1 & !find(status,65,68,83,GSTAOK) : ## GEODE->suppression de lignes uniquement
 mkstat=1 : End
Endif
If clalev([M:ABA1])>0 & !adxgtb
 # Il n'y a aucun paramètre à saisir pour cet abonnement
 Call MESSAGE(mess(104,134,1)) From GESECRAN
 mkstat = 1 : End
Endif
End

Subprog APRES_NBLIG
If status<>6 & [M]OBJ(nolign-1)<>""
 Call SETDES([M]OBJ(nolign-1),[M]CLE1(nolign-1),[M]CLE2(nolign-1),[M]DES(nolign-1))
 Affzo DES(nolign-1)
Endif
End

