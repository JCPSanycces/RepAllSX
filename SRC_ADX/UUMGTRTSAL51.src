#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGTRTSAL51   Moulinette de Migration des mouvements clients  Module TC #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTSAL51") From LECFIC
  Endif

  #Call RAZ_UUMGTRTSAL51(DOSSIER)
  Call MAJ_UUMGTRTSAL51(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTSAL51(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"BPCUSTMVT")=1 | func DOSVUE.ISVIEW(DOSSIER,"LASTCUSMVT")=1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL51",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
# Issue 106947 - 20150811 by LD

#Gbn-121203/X3-25868
#####################################
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL51",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

##1 - verifications
####################

Local Char WNAMMVCM
Call MIGTABNAME (DOSSIER,"BPCUSTMVT",WNAMMVCM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL51",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMMVCM,"fde",DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL51",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL51",2,ERR) From TRTMIG : #2=En cours
Gosub MIG_OUVRE From TRTMIG #Gbn-108768

###################

#variables pour le traitement
Local Char    PARAM(10)
Local Char    WIFFFCY(GLONFCY), WCUR(GLONCUR), WCURRPT(GLONCUR), WCPY(GLONCPY), WBPCRSK(GLONBPC)
Local Integer WIFFTYP, WMVTTYP
Local Integer STAT, WTYPCUR
Local Decimal WMNTDES, WAMT

# Lecture du paramètre au cas où cela ne soit pas fait lors de la migration
Global Char GCURSHR
Call PARAM("","CURSHRFLD",PARAM) From ADOVAL : # Devise zones communes
GCURSHR = PARAM

Local Char WTAB_MVC (100) (adxwrb)

Local Shortint WCPT_MVC

Call ECR_TIME("UUMGTRTSAL51 tables MVC Process : Update MVC") From DOSSUB
Call ECR_TRACE("UUMGTRTSAL51 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"BPCUSTMVT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
Local File =[F:ADS]DOSSIER+".LASTCUSMVT" [LCM]

#Gbn-121916 Tables opened in OUVRE_SAL
#Local File =[F:ADS]DOSSIER+".BPCUSTOMER" [BPC]
#Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
#Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU0]
#Local File =[F:ADS]DOSSIER+".TABCHANGE"  [TCH]

If [F:ADS]MODULE(4)=2
    Local File =[F:ADS]DOSSIER+".SQUOTE"    [SQH]
    Local File =[F:ADS]DOSSIER+".SORDER"    [SOH]
    Local File =[F:ADS]DOSSIER+".SDELIVERY" [SDH]
Endif
Local File =[F:ADS]DOSSIER+".SINVOICE"   [SIH]
If [F:ADS]MODULE(2)=2
    Local File =[F:ADS]DOSSIER+".PAYMENTH" [PYH]
Endif

#Gbn-121916 Tables opened in OUVRE_SAL
#Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]
#Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]

#Gbn-121203/X3-25868
Gosub OUVRE_SAL From UUMGTRTSAL00
If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL51",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif
#Gosub INISOC From UUMGTRTSAL00 #Gbn-121203/X3-25868

If clalev([F:MVC])  = 0 : Local File =DOSSIER+".BPCUSTMVT"    [MVC]  : Endif   # Fichier X3 "Vide"

If clalev([F:MVCM]) = 0 : Local File =DOSSIER+"."+WNAMMVCM   [MVCM] : Endif   # Fichier X3 renommé Avant Migration

#If clalev([F:MVC1]) = 0 : Local File =DOSSIER+".BPCUSTMVT"   [MVC1] : Endif   # Fichier X3


#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# Déclaration des variables communes de travail
Local Integer I, J
#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTSAL51",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

Link [MVCM] With [BPC]BPC0~=[F:MVCM]BPCNUM
&    As [LNK]
&    Order By Key CLE = [F:MVCM]BPCNUM;[F:MVCM]FINRSPFCY

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTSAL51" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_MVC00
Raz NB
If  STOP=1
  CRITERE = '[F:MVCM]BPCNUM=TABMIGKEY(1) & [F:MVCM]FINRSPFCY>TABMIGKEY(2)'
  STOP = 2
Elsif STOP=2
  CRITERE = '[F:MVCM]BPCNUM>TABMIGKEY(1)'
  STOP = 0
Else
  CRITERE = '1=1'
Endif


Trbegin [MVC]
GOK = 1

For [LNK]CLE Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTSAL51" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif
  Raz [F:MVC]
  If [F:BPC]BPCNUM<>"" & [F:MVCM]FINRSPFCY<>""
    #Appel proc de migration sur entete
    Gosub MAJ30_MVC
    If GOK<1 : Break : Endif

    NB+=1
    If NB>GMAXUPDTRS
      TABMIGKEY(1) = [F:MVCM]BPCNUM
      TABMIGKEY(2) = [F:MVCM]FINRSPFCY
      STOP=1
      Break
    Endif
  Else
    Goto SUITE_BOUCLE
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL51",7,ERR) From TRTMIG : #7=Erreur
Else
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(3)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTSAL51",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTSAL51",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_MVC00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

$FIN #121203/X3-25868

Close Local File [MVC]
Close Local File [MVCM]
Close Local File [LCM]
Close Local File [BPC]
Close Local File [TCU]
Close Local File [TCU0]
Close Local File [TCH]
If [F:ADS]MODULE(4)=2
    Close Local File [SQH]
    Close Local File [SOH]
    Close Local File [SDH]
Endif
Close Local File [SIH]
If [F:ADS]MODULE(2)=2
    Close Local File [PYH]
Endif


#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"BPCUSTMVT",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTSAL51") From TRTMIG
Call ECR_TIME("UUMGTRTSAL51 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
$MAJ30_MVC

If [F:BPC]BPCNUM<>[F:MVCM]BPCNUM
  Read [BPC]BPC0=[F:MVCM]BPCNUM : If fstat Raz [F:BPC] Endif
Endif
  WBPCRSK=[F:BPC]BPCNUM : If [F:BPC]BPCINV<>"" WBPCRSK=[F:BPC]BPCINV Endif
  Call GETDEV([F:ADS]DOSSIER,[F:MVCM]FINRSPFCY) From TRTX3CPT

  Call PARAM(GSOCIETE,"CNSTYPCUR",PARAM) From ADOVAL : # Type de cours pour consultation
  WTYPCUR=val(PARAM)
  WCPY=GSOCIETE
  If [F:MVCM]ACCCUR<>"" WCUR=[F:MVCM]ACCCUR Else WCUR=GLOCALDEV Endif
  If WCUR<>"" & WCPY<>""
    # On recherche si l'enr correspondant existe (avec les éléments de la future clé)
    Filter [MVC] Where BPCRSK=WBPCRSK & CPY=WCPY & BPCNUM=[F:MVCM]BPCNUM & CUR=WCUR
    Read [MVC] First
    Filter [MVC]
    If fstat = 0
       Gosub INIT_MVC_MNT
       If GOK<1 : Return : Endif
       Rewrite [F:MVC]
       If fstat
          Call ECR_TRACE("File BPCUSTMVT(BPCNUM)/FINRSPFCY"-[F:MVCM]BPCNUM+"/"+[F:MVCM]FINRSPFCY+", ERROR ="-num$(fstat),1) From GESECRAN
          GOK=0 : Return
       Endif
    Else
      Raz [F:MVC]
      [F:MVC]BPCRSK=WBPCRSK
      [F:MVC]CPY=WCPY
      [F:MVC]BPCNUM=[F:MVCM]BPCNUM
      [F:MVC]CUR=WCUR
      [F:MVC]ACCCUR=WCUR
      Gosub INIT_MVC_MNT
      If GOK<1 : Return : Endif
      Write [F:MVC]
      If fstat
          Call ECR_TRACE("File BPCUSTMVT(BPCNUM)/FINRSPFCY"-[F:MVCM]BPCNUM+"/"+[F:MVCM]FINRSPFCY+", ERROR ="-num$(fstat),1) From GESECRAN
          GOK=0 : Return
      Endif
    Endif
   Else
    Goto SUITE_BOUCLE
  Endif

Return
################################################
$INIT_MVC_MNT
Local Integer I,W_DEB,W_FIN

# Initialisation des mnts en devise transaction
[F:MVC]ORDBPCNOTC+=[F:MVCM]ORDBPCNOT : [F:MVC]ORDBPCATIC+=[F:MVCM]ORDBPCATI
[F:MVC]ORDBPINOTC+=[F:MVCM]ORDBPINOT : [F:MVC]ORDBPIATIC+=[F:MVCM]ORDBPIATI
[F:MVC]DLVOSTC   +=[F:MVCM]DLVOST    : [F:MVC]NIVDLVC   +=[F:MVCM]NIVDLV
[F:MVC]NPTINVC   +=[F:MVCM]NPTINV
[F:MVC]NYTBILC(0)+=[F:MVCM]NYTBIL(0) : [F:MVC]NYTBILC(1)+=[F:MVCM]NYTBIL(1) : [F:MVC]NYTBILC(2)+=[F:MVCM]NYTBIL(2)
[F:MVC]BLCC      +=[F:MVCM]BLC
[F:MVC]LNDBPCNOTC+=[F:MVCM]LNDBPCNOT : [F:MVC]LNDBPCATIC+=[F:MVCM]LNDBPCATI
[F:MVC]LNDBPINOTC+=[F:MVCM]LNDBPINOT : [F:MVC]LNDBPIATIC+=[F:MVCM]LNDBPIATI
[F:MVC]LNDDLVC   +=[F:MVCM]LNDDLV
# Initialisation des mnts en devise societe
If [F:BPC]BPCNUM<>[F:MVC]BPCRSK
    Read [BPC]BPC0=[F:MVC]BPCRSK : If fstat Raz [F:BPC] Endif
Endif
If [F:MVC]CUR<>GLOCALDEV
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]ORDBPCNOT,WMNTDES, STAT) From TRTDEV
    [F:MVC]ORDBPCNOTL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]ORDBPCATI,WMNTDES, STAT) From TRTDEV
    [F:MVC]ORDBPCATIL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]ORDBPINOT,WMNTDES, STAT) From TRTDEV
    [F:MVC]ORDBPINOTL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]ORDBPIATI,WMNTDES, STAT) From TRTDEV
    [F:MVC]ORDBPIATIL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]DLVOST,WMNTDES, STAT) From TRTDEV
    [F:MVC]DLVOSTL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]NIVDLV,WMNTDES, STAT) From TRTDEV
    [F:MVC]NIVDLVL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]NPTINV,WMNTDES, STAT) From TRTDEV
    [F:MVC]NPTINVL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]NYTBIL(0),WMNTDES, STAT) From TRTDEV
    [F:MVC]NYTBILL(0)+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]NYTBIL(1),WMNTDES, STAT) From TRTDEV
    [F:MVC]NYTBILL(1)+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]NYTBIL(2),WMNTDES, STAT) From TRTDEV
    [F:MVC]NYTBILL(2)+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]BLC,WMNTDES, STAT) From TRTDEV
    [F:MVC]BLCL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]LNDBPCNOT,WMNTDES, STAT) From TRTDEV
    [F:MVC]LNDBPCNOTL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]LNDBPCATI,WMNTDES, STAT) From TRTDEV
    [F:MVC]LNDBPCATIL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]LNDBPINOT,WMNTDES, STAT) From TRTDEV
    [F:MVC]LNDBPINOTL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]LNDBPIATI,WMNTDES, STAT) From TRTDEV
    [F:MVC]LNDBPIATIL+=WMNTDES
    Call CONVERT([F:MVC]CUR,GLOCALDEV,GLOCALDEV,WTYPCUR,date$,[F:MVCM]LNDDLV,WMNTDES, STAT) From TRTDEV
    [F:MVC]LNDDLVL+=WMNTDES
Else
    [F:MVC]ORDBPCNOTL+=[F:MVCM]ORDBPCNOT : [F:MVC]ORDBPCATIL+=[F:MVCM]ORDBPCATI
    [F:MVC]ORDBPINOTL+=[F:MVCM]ORDBPINOT : [F:MVC]ORDBPIATIL+=[F:MVCM]ORDBPIATI
    [F:MVC]DLVOSTL   +=[F:MVCM]DLVOST    : [F:MVC]NIVDLVL   +=[F:MVCM]NIVDLV
    [F:MVC]NPTINVL   +=[F:MVCM]NPTINV
    [F:MVC]NYTBILL(0)+=[F:MVCM]NYTBIL(0) : [F:MVC]NYTBILL(1)+=[F:MVCM]NYTBIL(1) : [F:MVC]NYTBILL(2)+=[F:MVCM]NYTBIL(2)
    [F:MVC]BLCL      +=[F:MVCM]BLC
    [F:MVC]LNDBPCNOTL+=[F:MVCM]LNDBPCNOT : [F:MVC]LNDBPCATIL+=[F:MVCM]LNDBPCATI
    [F:MVC]LNDBPINOTL+=[F:MVCM]LNDBPINOT : [F:MVC]LNDBPIATIL+=[F:MVCM]LNDBPIATI
    [F:MVC]LNDDLVL   +=[F:MVCM]LNDDLV
Endif
# Initialisation des mnts en devise dossier
# On prend la devise zone commune si elle est renseignée sinon on prend la devise dossier
If GCURSHR <> "" WCURRPT=GCURSHR Else WCURRPT=GSYSCUR Endif
If [F:MVC]CUR<>WCURRPT
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]ORDBPCNOT,WMNTDES, STAT) From TRTDEV
    [F:MVC]ORDBPCNOTR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]ORDBPCATI,WMNTDES, STAT) From TRTDEV
    [F:MVC]ORDBPCATIR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]ORDBPINOT,WMNTDES, STAT) From TRTDEV
    [F:MVC]ORDBPINOTR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]ORDBPIATI,WMNTDES, STAT) From TRTDEV
    [F:MVC]ORDBPIATIR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]DLVOST,WMNTDES, STAT) From TRTDEV
    [F:MVC]DLVOSTR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]NIVDLV,WMNTDES, STAT) From TRTDEV
    [F:MVC]NIVDLVR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]NPTINV,WMNTDES, STAT) From TRTDEV
    [F:MVC]NPTINVR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]NYTBIL(0),WMNTDES, STAT) From TRTDEV
    [F:MVC]NYTBILR(0)+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]NYTBIL(1),WMNTDES, STAT) From TRTDEV
    [F:MVC]NYTBILR(1)+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]NYTBIL(2),WMNTDES, STAT) From TRTDEV
    [F:MVC]NYTBILR(2)+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]BLC,WMNTDES, STAT) From TRTDEV
    [F:MVC]BLCR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]LNDBPCNOT,WMNTDES, STAT) From TRTDEV
    [F:MVC]LNDBPCNOTR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]LNDBPCATI,WMNTDES, STAT) From TRTDEV
    [F:MVC]LNDBPCATIR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]LNDBPINOT,WMNTDES, STAT) From TRTDEV
    [F:MVC]LNDBPINOTR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]LNDBPIATI,WMNTDES, STAT) From TRTDEV
    [F:MVC]LNDBPIATIR+=WMNTDES
    Call CONVERT([F:MVC]CUR,WCURRPT,GLOCALDEV,WTYPCUR,date$,[F:MVCM]LNDDLV,WMNTDES, STAT) From TRTDEV
    [F:MVC]LNDDLVR+=WMNTDES
Else
    [F:MVC]ORDBPCNOTR+=[F:MVCM]ORDBPCNOT : [F:MVC]ORDBPCATIR+=[F:MVCM]ORDBPCATI
    [F:MVC]ORDBPINOTR+=[F:MVCM]ORDBPINOT : [F:MVC]ORDBPIATIR+=[F:MVCM]ORDBPIATI
    [F:MVC]DLVOSTR   +=[F:MVCM]DLVOST    : [F:MVC]NIVDLVR   +=[F:MVCM]NIVDLV
    [F:MVC]NPTINVR   +=[F:MVCM]NPTINV
    [F:MVC]NYTBILR(0)+=[F:MVCM]NYTBIL(0) : [F:MVC]NYTBILR(1)+=[F:MVCM]NYTBIL(1) : [F:MVC]NYTBILR(2)+=[F:MVCM]NYTBIL(2)
    [F:MVC]BLCR      +=[F:MVCM]BLC
    [F:MVC]LNDBPCNOTR+=[F:MVCM]LNDBPCNOT : [F:MVC]LNDBPCATIR+=[F:MVCM]LNDBPCATI
    [F:MVC]LNDBPINOTR+=[F:MVCM]LNDBPINOT : [F:MVC]LNDBPIATIR+=[F:MVCM]LNDBPIATI
    [F:MVC]LNDDLVR   +=[F:MVCM]LNDDLV
Endif

# Bascule tableau LASDOCXXX dans la nouvelle table LASTCUSMVT
If [F:ADS]MODULE(4)=2 W_DEB=0 Else W_DEB=3 Endif
If [F:ADS]MODULE(2)=2 W_FIN=5 Else W_FIN=3 Endif

For I=W_DEB To W_FIN
    If [F:MVCM]LASDOCNUM(I)="" Goto NXTDOC Endif
    # Vérification que le dernier n° document existe toujours
    # S'il n'existe pas faut-il le rechercher ? Risque de pb de perfs si oui voir TRTCNSBAG
    Case I
        When 0 : # Dernier devis
            WIFFTYP=4 : WMVTTYP=1
            If [F:SQH]SQHNUM<>[F:MVCM]LASDOCNUM(I)
                Read [SQH]SQH0=[F:MVCM]LASDOCNUM(I) : If fstat Raz [F:SQH] : Raz WIFFTYP, WMVTTYP : Endif
            Endif
            WIFFFCY=[F:SQH]SALFCY : WCUR=[F:SQH]CUR : WAMT=[F:SQH]QUOATI
        When 1 : # Dernière commande
            WIFFTYP=6 : WMVTTYP=2
            If [F:SOH]SOHNUM<>[F:MVCM]LASDOCNUM(I)
                Read [SOH]SOH0=[F:MVCM]LASDOCNUM(I) : If fstat Raz [F:SOH] : Raz WIFFTYP, WMVTTYP : Endif
            Endif
            WIFFFCY=[F:SOH]SALFCY : WCUR=[F:SOH]CUR : WAMT=[F:SOH]ORDATI
        When 2 : # Dernière livraison
            WIFFTYP=7 : WMVTTYP=3
            If [F:SDH]SDHNUM<>[F:MVCM]LASDOCNUM(I)
                Read [SDH]SDH0=[F:MVCM]LASDOCNUM(I) : If fstat Raz [F:SDH] : Raz WIFFTYP, WMVTTYP : Endif
            Endif
            WIFFFCY=[F:SDH]SALFCY : WCUR=[F:SDH]CUR : WAMT=[F:SDH]DLVATI
        When 3 : # Dernière facture
            WIFFTYP=9 : WMVTTYP=5
            If [F:SIH]NUM<>[F:MVCM]LASDOCNUM(I)
                Read [SIH]SIH0=[F:MVCM]LASDOCNUM(I) : If fstat Raz [F:SIH] : Raz WIFFTYP, WMVTTYP : Endif
            Endif
            WIFFFCY=[F:SIH]FCY    : WCUR=[F:SIH]CUR : WAMT=[F:SIH]AMTATI
        When 4 : # Dernier règlement
            WIFFTYP=15 : WMVTTYP=10
            If [F:PYH]NUM<>[F:MVCM]LASDOCNUM(I)
                Read [PYH]PYH0=[F:MVCM]LASDOCNUM(I) : If fstat Raz [F:PYH] : Raz WIFFTYP, WMVTTYP : Endif
            Endif
            WIFFFCY=[F:PYH]FCY    : WCUR=[F:PYH]CUR : WAMT=[F:PYH]AMTCUR
        When 5 : # Dernier impayé
            WIFFTYP=16 : WMVTTYP=11
            If [F:PYH]NUM<>[F:MVCM]LASDOCNUM(I)
                Read [PYH]PYH0=[F:MVCM]LASDOCNUM(I) : If fstat Raz [F:PYH] : Raz WIFFTYP, WMVTTYP : Endif
            Endif
            WIFFFCY=[F:PYH]FCY    : WCUR=[F:PYH]CUR : WAMT=[F:PYH]AMTCUR
    Endcase
    If WIFFTYP<>0
        Read [LCM]LCM0 = [F:MVCM]BPCNUM;WIFFTYP;GSOCIETE  # FGR 11/03/2010 : X3SUIVI63191
        If fstat = 1
            Call ECR_TRACE("File LASTCUSMVT"-[F:MVCM]BPCNUM-num$(WIFFTYP)-GSOCIETE+", Error ="-num$(fstat),1) From GESECRAN
            GOK=0 : Break
        Elsif fstat = 4 | fstat = 5
            Raz [F:LCM]
            [F:LCM]BPCNUM    = [F:MVCM]BPCNUM
            [F:LCM]IFFTYP    = WIFFTYP
            [F:LCM]CPY       = GSOCIETE
            [F:LCM]MVTTYP    = WMVTTYP
            [F:LCM]MVTDAT    = [F:MVCM]LASDOCDAT(I)
            [F:LCM]VCRNUM    = [F:MVCM]LASDOCNUM(I)
            [F:LCM]IFFFCY    = WIFFFCY
            [F:LCM]CUR       = WCUR
            [F:LCM]AMT       = WAMT
            [F:LCM]CREUSR = GUSER
            [F:LCM]CREDAT = date$
            Write [LCM]
            If fstat
                Call ECR_TRACE("File LASTCUSMVT"-[F:MVCM]BPCNUM-num$(WIFFTYP)-GSOCIETE+", Error ="-num$(fstat),1) From GESECRAN
                GOK=0 : Break
            Endif
        Elsif fstat = 0 : # Ce cas ne devrait pas arriver
            [F:LCM]MVTDAT    = [F:MVCM]LASDOCDAT(I)
            [F:LCM]VCRNUM    = [F:MVCM]LASDOCNUM(I)
            [F:LCM]IFFFCY    = WIFFFCY
            [F:LCM]CUR       = WCUR
            [F:LCM]AMT       = [F:MVCM]LASDOCAMT(I)
            [F:MVCM]UPDDAT = date$
            [F:MVCM]UPDUSR = GUSER
            Rewrite [LCM]
            If fstat
                Call ECR_TRACE("File LASTCUSMVT"-[F:MVCM]BPCNUM-num$(WIFFTYP)-GSOCIETE+", Error ="-num$(fstat),1) From GESECRAN
                GOK=0 : Break
            Endif
        Endif
    Endif
    $NXTDOC
Next
If GOK<1 : Return : Endif

# Récupération des données comptables
[F:MVC]FCTOST    +=[F:MVCM]FCTOST
[F:MVC]UNPNBR    +=[F:MVCM]UNPNBR
If [F:MVCM]UNPDAT>[F:MVC]UNPDAT       [F:MVC]UNPDAT=[F:MVCM]UNPDAT : Endif
If [F:MVCM]FUPDAT>[F:MVC]FUPDAT
    [F:MVC]FUPDAT=[F:MVCM]FUPDAT
    [F:MVC]FUPLEV=[F:MVCM]FUPLEV
Endif
If [F:MVCM]MAXFUPLEV>[F:MVC]MAXFUPLEV [F:MVC]MAXFUPLEV=[F:MVCM]MAXFUPLEV : Endif
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGTRTSAL51(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTSAL51(APPLI)
End

#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTSAL51(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"BPCUSTMVT")=1 | func DOSVUE.ISVIEW(DOSSIER,"LASTCUSMVT")=1 : End : Endif
# Issue 106947 - 20150811 by LD

##1 - verifications
####################

Local Char WNAMMVCM
Call MIGTABNAME (DOSSIER,"BPCUSTMVT",WNAMMVCM,ERR) From TRTMIG
If ERR : End : Endif

If filinfo(filpath("FIL",WNAMMVCM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif

##2 - On vide les fichiers selon le cas
#######################################
Call MIGTABRAZ (DOSSIER,"BPCUSTMVT",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"LASTCUSMVT",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTSAL51",ERR) From TRTMIG

End





