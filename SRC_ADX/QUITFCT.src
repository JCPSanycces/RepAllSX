#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################
#                                                    #
#  GENERATION DES QUITTANCES SUBROGATIVES            #
#                                                    #
# - on affecte un numéro de quittance sur :          #
#       . les factures                               #
#       . les échéances                              #
# - en fin de trt, les quittances sont éditées       #
######################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","QUITFCT","FQUITFCT",3,"") From GTRAITE
End


$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "TERMINE"    : Gosub FIN
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "SORTIE"     : Gosub SORTIE
Endcase
Return


$INIT
Local Integer NB
Local Char FILTRE(255),CRITERE(255), CRIT2(255), CRIT3(255)
Local Char CRITERE2(255) # SAM 88426 - 2015-06-22 by LUCUE : Factoring Management
Local Char FCTCUR(GLONFCT), NUMQUIT(GLONVCR)
Local Char TBPAR(10)(1..5), TBVAL(30)(1..5)
Local Decimal MONTMIN
Gosub OUVRE
Return

$INIT_DIA
Gosub TIT
Return

$TIT
TIT = mess(62,121,1)    # Génération des n° de quittance
Return

$CONTROLE
# DdM51697
#TMP = 1  :# Pour afficher des tempon/tempoff
Return

$FIN
If !GSERVEUR & [M:DIA]TRACE=2
 TRA = 1
Else
 TRA = 0
Endif
Return

$SORTIE
Return

$EXEC
If GSERVEUR
### batch
 [M:DIA]TRACE = 2
Endif

Gosub TIT
If !GSERVEUR & [M:DIA]TRACE=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRACE=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

#### Filtre sur table FACTOR
Gosub SELFCT

#### Boucle sur les factors sélectionnés
NB = 0
##For [FCT]FCT0 Where evalue(CRITERE) ## SAM 88426
For [FCT]FCT0 Where evalue(CRITERE) & evalue(CRITERE2) # SAM 88426

 FCTCUR = [F:FCT]FCTCOD
 GRAISON = [F:FCT]FCTNAM
 If !GSERVEUR  :  Call TEMPON(TIT-FCTCUR) From GESECRAN : Endif
 Call DEBTRANS From GLOCK
 Gosub TR1
 If !GSERVEUR : Call TEMPOFF From GESECRAN : Endif
 If NUMQUIT<>""
  TBPAR(1)='numquit' : TBVAL(1)=NUMQUIT
  TBPAR(2)='factor'  : TBVAL(2)=FCTCUR
  TBPAR(3)='graison' : TBVAL(3)=GRAISON
  Call ETAT("LISFAC",GFONCTION,TBPAR,TBVAL) From ETAT
 Endif
Next

If !NB
 Call ECR_TRACE(mess(64,121,1),0) From GESECRAN   # Pas de facture à quittancer
Endif
If !GSERVEUR & [M:DIA]TRACE=2
 Call FERME_TRACE From LECFIC
Endif

Return

####################################################
$OUVRE
If clalev([F:SIH])=0 : Local File SINVOICE [SIH]  : Endif
If clalev([F:FCT])=0 : Local File FACTOR   [FCT]  : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY]  : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY]  : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
Return

######################################################################
### Ecriture du numéro de quittance sur les factures et les échéances
######################################################################
$TR1
Trbegin [SIH], [DUD]
Gosub SELFAC
NUMQUIT = ""
GOK=1
For [SIH]SIH0 Where evalue(CRIT2) & evalue(CRIT3) & evalue(FILTRE) With Nohint
 # Les factures annulées par un avoir et non encore cédées au factor ne doivent pas générer de quittance.
 # Il n’y a aucun intérêt à céder au factor une créance à zéro
 # Ces factures sont lettrées à l'avoir+zone factor renseignée+soldée.
 # => Générer quittance si échéances non soldées
 MONTMIN = 0
 For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  MONTMIN += [F:DUD]PAYCUR+[F:DUD]TMPCUR
 Next
 If [F:SIH]AMTATI - MONTMIN <> 0
  # SAM 88426   Factoring management -
  If [F:FCT]FCTTYP>1 & [F:FCT]BANFCY<>"" & [F:FCT]BANFCY<>[F:SIH]FCY
    Call ECR_TRACE(mess(206,121,1)+"-"-mess(16,122,1)+":"-[F:SIH]NUM,2) From GESECRAN
  Else
  # END SAM 88426
   NB += 1
   If NUMQUIT = "" : Gosub SET_NOQUIT : Endif
   If GOK < 1 : Break : Endif
   Readlock [SIH]
   If fstat=1 : GOK = -1 : GLOCK = "$SINVOICE"-[F:SIH]NUM : Break
   Elsif fstat : GOK = 0 : Call RSTA("SIH",[F:SIH]NUM) From GLOCK : Break
   Endif
   [F:SIH]FCTVCR = NUMQUIT
   Rewrite [SIH]
   If fstat : GOK = 0 : Call FSTA("SIH") From GLOCK : Break : Endif
   If GTRACE <> ""
    # Quittance nnn, Facture/Avoir ...
    Call ECR_TRACE(mess(77,121,1)+":"-[F:SIH]FCTVCR + " ,"-mess(16,122,1)+":"-[F:SIH]NUM,0)
&   From GESECRAN
   Endif
   Update [DUD] Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM With FCTVCR=NUMQUIT
   If fstat=1
    GOK = -1 : GLOCK = "$GACCDUDATE"-[F:SIH]GTE-[F:SIH]NUM : Break
   Elsif fstat
    GOK = 0 : Call FSTA("DUD") From GLOCK : Break
   Endif
  Endif # SAM 88426  Factoring management -
 Endif
Next
If GOK<0    : Goto ROLL
Elsif GOK=0 : Goto ABORT
Endif
Commit
Return

$ROLL
Rollback
Call ROLL From GLOCK
If GROLL : NUMQUIT = "" : Return : Else : Goto TR1 : Endif
Return

$ABORT
Rollback
Return

######################################################################
### Incrémente le compteur de quittance pour le factor en cours
######################################################################
$SET_NOQUIT
Local Char SITE(GLONFCY)
Local Integer STAT
If [M:DIA]ALLFCY=2
 Call LEC_CPY([M:DIA]CPY) From CPTLEC
 SITE = [F:CPY]MAIFCY
 If SITE <> ''
  If GUSRFCY(1)<>"\" & !find(SITE,GUSRFCY(1..GNBAUZ))
   # Vous n'avez pas les droits pour ce site
   GERR=1 : GMESSAGE=SITE-mess(2,104,1)
   GOK=0
  Endif
 Else
  # Renseigner le site par défaut de la société
  GERR=1 : GMESSAGE=mess(149,121,1)-[M:DIA]CPY
  GOK=0
 Endif
Else
 SITE = [M:DIA]FCY
Endif

If GOK>0
 Call NUMERO([F:FCT]FCTQTCVCR,SITE,[M:DIA]DATFIN,FCTCUR,NUMQUIT,STAT) From SUBANM
 If STAT
  Gosub MESSAGE From SUBANM
  GMESSAGE = mess(60,199,1)-"("+[F:FCT]FCTQTCVCR+") : "+MESSA
  GERR=1 : GOK = 0
 Endif
Endif
Return

######################################################################
### Sélection des factors [FCT]
######################################################################
$SELFCT
Raz CRITERE
If [M:DIA]FCTDEB<>""
  CRITERE = "FCTCOD>='" + [M:DIA]FCTDEB + "'"
Endif
If [M:DIA]FCTFIN<>""
  If CRITERE<>"" : CRITERE -= "&" : Endif
  CRITERE -= "FCTCOD<='" + [M:DIA]FCTFIN + "'"
Endif
If CRITERE = "" : CRITERE = "1=1" : Endif

# SAM 88426   Factoring management -
  If [M:DIA]ALLFCY=2
     CRITERE2="FCTTYP<2 | BANCPY='"+[M:DIA]CPY+"'"
  Else
     CRITERE2="FCTTYP<2 | (BANCPY='"+[M:DIA]CPY+"' & (BANFCY='' | BANFCY='"+[M:DIA]FCY+"'))"
  Endif
# End SAM 88426
Return

######################################################################
### Sélection des factures [SIH]
######################################################################
$SELFAC
Raz CRIT2, CRIT3
### Table Factures: sélection sur facture validée, pas de n° quittance et date cpt < date saisie
CRIT2 = "STA=3 & FCTVCR='' & ACCDAT<=[" + format$(GFMD,[M]DATFIN) + "]"
If [M:DIA]ALLFCY<>2
 CRIT2 -= "& FCY='" + [M:DIA]FCY + "'"
Endif
If [M:DIA]CUR<>""
 CRIT2 -= "& CUR='" + [M:DIA]CUR + "'"
Endif
If ([M:DIA]NUMDEB<>"" and [M:DIA]NUMFIN<>"") or ([M:DIA]AVRDEB<>"" and [M:DIA]AVRFIN<>"")
  CRIT2 -= "& ((INVTYP=1 & (NUM>='" + [M:DIA]NUMDEB + "' & NUM<='" + [M:DIA]NUMFIN + "'))"
  CRIT2 -= "|  (INVTYP=2 & (NUM>='" + [M:DIA]AVRDEB + "' & NUM<='" + [M:DIA]AVRFIN + "')))"
Endif
CRIT3  = "BPRFCT='"+FCTCUR+"' & FCTVCRFLG=0 & CPY='" + [M:DIA]CPY + "'"
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 CRIT3 -= "& find(FCY,GUSRFCY(1..GNBAUZ))"
Endif

#################### Point d'entrée FILTRE ####################
Raz FILTRE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If FILTRE = "" : FILTRE = "1=1" : Endif
Return


##################################
### Etiquettes du masque QUITFCT
##################################
Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M]ALLFCY=2
 mkstat = 1 : End
Endif
If [M]CPY<>""
 GBOUT2=mess(73,121,1)-[M]CPY    # Sites de...
Else
 GBOUT2=""
Endif
End

Subprog D_DATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0]
 VALEUR=date$
Endif
End

Subprog AS_FCTFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]FCTDEB : VALEUR=[M]FCTDEB : Endif
End

Subprog C_FCTFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]FCTDEB
  GMESSAGE = (mess(63,121,1))    : # Factor début > factor fin
  mkstat = 2
Endif

# SAM 88426   Factoring management -
If VALEUR=[M]FCTDEB and [F:FCT]FCTTYP>1 and VALEUR<>""
  If [F:FCT]BANCPY<>[M]CPY or ([F:FCT]BANFCY<>"" and [M]FCY<>"" and [F:FCT]BANFCY<>[M]FCY)
  GMESSAGE = (mess(205,121,1))    : # Incompatibility between the company/site of the factor and the company/site of the generation
  mkstat = 2
  Endif
Endif
# End SAM 88426
End

Subprog AS_NUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]NUMDEB : VALEUR=[M]NUMDEB : Endif
End

Subprog C_NUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]AVRDEB
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 2
Endif
End

Subprog AS_AVRFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]AVRDEB : VALEUR=[M]AVRDEB : Endif
End

Subprog C_AVRFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]AVRDEB
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 2
Endif
End

##########################

$SEL_TABLE
Case COUZON
 When "FCY" :
  OBJET = "FCY"
  If [M]CPY<>''
   CRITERE = "LEGCPY='" + [M]CPY + "'"
   If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    CRITERE -= "& find(FCY,GUSRFCY(1..GNBAUZ))"
   Endif
  Endif
 When "NUMDEB" , "NUMFIN" :
  OBJET = "BIT"
  CRITERE = "CPY='" + [M]CPY + "' & INVTYP<>2 & FCTVCRFLG=0 & BPRFCT>='" + [M]FCTDEB + "' & BPRFCT<='" + [M]FCTFIN +"'"
 When "AVRDEB" , "AVRFIN" :
  OBJET = "BIT"
  CRITERE = "CPY='" + [M]CPY + "' & INVTYP=2 & FCTVCRFLG=0 & BPRFCT>='" + [M]FCTDEB + "' & BPRFCT<='" + [M]FCTFIN +"'"
Endcase
Return

