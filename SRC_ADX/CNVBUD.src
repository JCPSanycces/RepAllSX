#<AdxTL>@(#)8.0.0.0 $Revision$

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CNVBUD","DCNVBUD",3,"") From GTRAITE
End


#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
Endcase
Return

#######################################################
# Moulinette Passage Euro                             #
#######################################################
$INIT
Local Integer OK, I, ERR
Raz ERR
Onerrgo ERR
Gosub OUVRE
If ERR : FIN=1 : Return : Endif
Local Mask CNVBUD [CNV] : Raz [M]
Return

$CONTROLE
If !GSERVEUR & [M:CNV]TRACE=2
 Call OUVRE_TRACE(mess(67,115,1)) From LECFIC
 TRA =1 
Endif
TMP=1
Return

$EXEC
Read [TCY]TCY0 = GPAYS
If fstat
 Read [TCY]TCY0 = ""
Endif
If fstat=0
 GLOCALDEV = [F:TCY]CUR
Else
 GLOCALDEV = "FRF"
Endif

If [M]TOUBUD=2
 For [BUP2] Where CUR=[M]DEVCUR
  Call CNVBUD2([F:BUP2]BUD,[M]DATPAS,[M]DEVCUR,[M]DEVDES)
  If GOK<1 : Break : Endif
 Next
Else
 For I=0 To [M]NBLIG-1
  If [M]CNV(I)=2
   Call CNVBUD2([M]BUD(I),[M]DATPAS,[M]DEVCUR,[M]DEVDES)
   If GOK<1 : Break : Endif
  Endif
 Next I
Endif
Return

$OUVRE
If clalev([F:TCY])=0  : Local File TABCOUNTRY [TCY]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:TCH])=0  : Local File TABCHANGE  [TCH]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:ADW])=0  : Local File ADOVAL     [ADW]  : Endif
If clalev([F:BUP])=0  : Local File BUDPAR     [BUP]  : Endif
If clalev([F:BUD])=0  : Local File BUD        [BUD]  : Endif
If clalev([F:BUP2])=0 : Local File BUDPAR     [BUP2] : Endif
Return

$ERR
ERR = errn
Resume

###########################################################################
Subprog CNVBUD2(CODE,DATPAS,DEVCUR,DEVDES)
Value Char    CODE
Value Date    DATPAS
Value Char    DEVCUR
Value Char    DEVDES

Gosub OUVRE

Local Integer I, TYPCUR, SPSTAT
Local Char    VALPAR(20), SYMBOLE(80)

Read [BUP2]BUP0 = CODE
If [F:BUP2]CUR<>DEVCUR : End : Endif

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : End : Endif

If GTRACE<>""
 Call ECR_TRACE(CODE-[L]DEVCUR-"->"-[L]DEVDES,0) From GESECRAN
Endif

End

$TR1
GOK = 1
Trbegin [BUP], [BUD]

 SYMBOLE = format$("K:3X","BUP")+CODE
 Lock =SYMBOLE With lockwait=0
 If fstat
  Call ECR_TRACE(mess(47,103,1)-CODE-mess(39,107,1),1) From GESECRAN : # Budget x en cours de modification
  GOK=0 : Goto AB_TR1
 Endif
 Readlock [BUP]BUP0 = CODE
 If fstat=1
  GOK=-1 : GLOCK="$BUDPAR"-[F:BUP]BUD : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("BUP",[F:BUP]BUD) From GLOCK : Goto AB_TR1
 Endif
 [F:BUP]CUR = DEVDES
 Rewrite [BUP]
 If fstat
  GOK=0 : Call FSTA("BUP") From GLOCK : Goto AB_TR1
 Endif
 Filter [BUD] Where BUD=[L]CODE
 For [BUD]BUD0(3)
  SYMBOLE = "BUD"+[F:BUD]FCY+[F:BUD]BUD+num$([F:BUD]FIY) 
  Lock =SYMBOLE With lockwait=0 
  If fstat
   Call ECR_TRACE([F:BUD]BUD-[F:BUD]FCY-num$(FIY)-mess(39,107,1),1) From GESECRAN
   GOK=0 : Break
  Endif
  For [BUD]BUD0
   Call PARAM([F:BUD]FCY,"BUDTYPCUR",VALPAR) From ADOVAL
   TYPCUR = val(VALPAR)
   If TYPCUR=0 : TYPCUR = 1 : Endif
   Call CONVERT_TAB(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,[F:BUD]AMT,[F:BUD]AMT,SPSTAT) From TRTDEV
   Rewrite [BUD]
   If fstat=1
    GOK=-1 : GLOCK = "$BUD" : Break 2
   Elsif fstat
    GOK=0 : Call FSTA("BUD") From GLOCK : Break 2
   Endif
  Next
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

########################################
Subprog C_DEVDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]DEVCUR
 mkstat = 2 : End
Endif
End

$CHARGE
Effzo 10
If [M]TOUBUD=2 : mkstat = 1 : End : Endif
Local Integer I
Raz I
For [BUP] Where CUR=[M]DEVCUR
 [M]BUD(I) = [F:BUP]BUD
 Call LECTEXTRA([M]DES(I),"BUDPAR","DESTRA",[F:BUP]BUD,"") From ATEXTRA
 If I>=dim([M]BUD)-1 
  Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 I +=1
Next
[M]NBLIG = I
Affzo 10
Return

Subprog C_BUD(VALEUR)
Variable Char    VALEUR()
Call CONTROLE("BUP","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Call LECTEXTRA([M]DES(nolign-1),"BUDPAR","DESTRA",[F:BUP]BUD,"") From ATEXTRA
End

Subprog AS_NBLIG
GBOUT1 = mess(2,1,1)
GBOUT2 = mess(1,1,1)
If adxgtb : Gosub CHARGE : Endif
End

Subprog B1_NBLIG
Local Integer I
For I=0 To [M]NBLIG-1
 [M]CNV(I) = 2 : # Oui
Next I
Affzo
End

Subprog B2_NBLIG
Local Integer I
For I=0 To [M]NBLIG-1
 [M]CNV(I) = 1 : # Non
Next I
Affzo
End



