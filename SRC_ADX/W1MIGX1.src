#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque MIGX1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:25"
A_USER  = "DOC"
A_STAMP = "20181109230525"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "TMNBR"
  If [M]TMNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask MIGX1 [MIGX1]
Gosub HORODAT
Local Inpbox "MIGX1" From GFONCTION At A_STAMP With A_WINDPREV Mask [MIGX1] As [SIM_]
Grizo [MIGX1]5
Grizo [MIGX1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [MIGX1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=100 : Y1(1)=3 : Y2(1)=20
Return

$ON_TMOSELALL
Onevent AFTER_CHANGE Gosub AMM_TMOSELALL From W1MIGX1
Onevent INIT_AREA Call D_TMOSELALL(zc) From W1MIGX1
Onevent BEFORE_INPUT Call AS_TMOSELALL(zc) From W1MIGX1
Onevent CONTROL Call C_TMOSELALL(zc) From W1MIGX1
Return

Subprog D_TMOSELALL(VALEUR)
Variable Integer VALEUR
If varinit([M]TMOSELALL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TMOSELALL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_TMOSELALL(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TMOSELALL" : GZNUM = 26794 : Endif
Gosub _AFF
End

$AMM_TMOSELALL
Call AM_TMOSELALL(zc)
If !mkstat & GOBJET
 zoncou = "TMOSELALL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TMOSELALL(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_TMOSELALL(VALEUR) From SUBMIGX
If mkstat : GERR = 1 : GZONE = "TMOSELALL" : GZNUM = 26794 : Endif
Gosub _AFF
End

$ON_TMINCLUDE
Onevent INIT_AREA Call D_TMINCLUDE(zc) From W1MIGX1
Onevent BEFORE_INPUT Call AS_TMINCLUDE(zc) From W1MIGX1
Return

Subprog D_TMINCLUDE(VALEUR)
Variable Integer VALEUR
If varinit([M]TMINCLUDE,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TMINCLUDE(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_TMSRCTBL
Onevent CONTROL Call C_TMSRCTBL(zc) From W1MIGX1
Onevent BEFORE_INPUT Call AS_TMSRCTBL(zc) From W1MIGX1
Return

Subprog AS_TMSRCTBL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_TMSRCTBL(zc) From W1MIGX1
Onkey 144 Titled GBOUTP Call P_TMSRCTBL(zc) From W1MIGX1
Onkey 146 Titled GBOUTA Call SA_TMSRCTBL(zc) From W1MIGX1
Gosub _AFF
End

Subprog C_TMSRCTBL(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ATB","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "TMSRCTBL" : GZNUM = 12075 : Endif
Gosub _AFF
End

Subprog S_TMSRCTBL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ATB"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_TMSRCTBL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ATB"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TMSRCTBL(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ATB",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_TMTRGTBL
Return

$ON_TMCLSMAP
Onevent BEFORE_INPUT Call AS_TMCLSMAP(zc) From W1MIGX1
Return

Subprog AS_TMCLSMAP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(21870,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_TMCLSMAP(zc) From W1MIGX1
Onkey   2 Titled GBOUTS Call S_TMCLSMAP(zc) From W1MIGX1
Gosub _AFF
End

Subprog S_TMCLSMAP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADC"
 Call S_TAB_CHAR(VALEUR,PARMSK,"","SUBADC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_TMCLSMAP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TRTADC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "TRTADC"
 PARMSK(1) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"EDITION","SUBADC","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


