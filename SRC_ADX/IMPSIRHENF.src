#<AdxTL>@(#)7.0.0.0 $Revision$
Call IMPORTATION("SIRHENFANT") From GIMPOBJ
End
################################################################################################

## On importe tous les enfants du salarié => Création

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "IMP_CREATION"  : Gosub IMP_CREATION
 When "AP_IMPORT"     : Gosub AP_IMPORT
Endcase
Return

$IMP_OUVRE
If clalev([F:CHD1])=0 : Local File EMPLOCHD [CHD1] : Endif
If clalev([F:ID])=0   : Local File EMPLOID  [ID]   : Endif
Local Char    MATRI(GLONEML)
Local Integer NOUVEAU, NUML
Return

$AP_IMPORT
GOK = 1
If MATRI<>[F:CHD]REFNUM
 Call LECTURE("EML",[F:CHD]REFNUM,"") From CONTOBJ
 If fstat
  # Matricule inexistant : xxxx Import yyyyyyyy zzzzzz
  Call TRACE(2,mess(83,10702,1)+" : "+format$("K:15X",[F:CHD]REFNUM)+space$(1)+mess(143,141,1)
&              +space$(1)+format$("K:30X",[F:CHD]CHDNAM)-[F:CHD]CHDSRN) From SUBIMPOBJ
  GOK=0 :  Return
 Endif
 Read [CHD1]CHD0=[F:CHD]REFNUM;1
 If !fstat & [F:AOE]OPTUPD<>2
  # Opération non effectuée
  Call TRACE(2,mess(105,141,1)+" : "+format$("K:15X",[F:CHD]REFNUM)+space$(1)+mess(143,141,1)
&              +space$(1)+format$("K:30X",[F:CHD]CHDNAM)-[F:CHD]CHDSRN) From SUBIMPOBJ
  GOK=0 : Return
 Endif
 Gosub TR_DEL
 If GOK=0 
  # Enregistrement verrouillé
  Call TRACE(2,mess(60,100,1)+" : "+format$("K:15X",[F:CHD]REFNUM)+space$(1)+mess(143,141,1)
&              +space$(1)+format$("K:30X",[F:CHD]CHDNAM)-[F:CHD]CHDSRN) From SUBIMPOBJ
  Return
 Endif
 MATRI         = [F:CHD]REFNUM
 [F:CHD]NUMLIG = 1
 NUML          = 1
 NOUVEAU       = 1
Else
 NUML         +=1
 [F:CHD]NUMLIG = NUML
 NOUVEAU       = 0 
Endif
Return

$TR_DEL
Trbegin [CHD1]
 Delete [CHD1] Where REFNUM=[F:CHD]REFNUM
 If fstat=1
  GOK = 0 : Rollback
  Return
 Endif
Commit
Return


$IMP_CREATION
# Mise à jour du nombre d'enfants
# Mise à jour du nombre d'enfants à charge
GOK = 1
Readlock [ID]ID0=[F:CHD]REFNUM
If fstat=1
 GOK = -1 : GLOCK = "$EMPLOID"-[F:CHD]REFNUM : Return
Else
 If NOUVEAU
  Raz [F:ID]CHD
 Endif
 If val(GIMP(1))=1 : # 1=A charge 2=Pas à charge
  [F:ID]CHD   += 1
 Endif
 [F:ID]NBRCHD = [F:CHD]NUMLIG
 Rewrite [ID]
 If fstat
  GOK=0 : Call FSTA("ID") From GLOCK : Return
 Endif
Endif
Return
