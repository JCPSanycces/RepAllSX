#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################
#                                                    #
#  MISE A JOUR DU CODE FACTOR SUR LES FACTURES       #
#               ET LES ECHEANCES                     #
#                                                    #
######################################################

Local Char VALEUR(10), PARAM(10)(1..2)
Call SAISIE_CHAR(VALEUR,PARAM,"FMAJFCT","MAJFCT","") From GSAISIE
End


$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIR"         : Gosub PREMIER
 When "SUI"         : Gosub SUIVANT
 When "PRE"         : Gosub PRECEDENT
 When "LAS"         : Gosub DERNIER
 When "ENR"         : Gosub ENREG
 When "RAF"         : Gosub RAFFR
 When "ABA"         : Gosub ABANDON
 When "END"         : Gosub FIN
 When "SETBOUT"     : Gosub SETBOUT
 When "AP_CHOIX"    : Gosub AP_CHOIX
 When "AB1_NBLIG"   : Gosub AB1_NBLIG
 When "BB1_NBLIG"   : Gosub BB1_NBLIG
Endcase
Return

$OUVRE
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:FCT])=0 : Local File FACTOR     [FCT] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If GMODU(5)=2
 If clalev([F:SIV])=0  : Local File SINVOICEV  [SIV]  : Endif : # Costing sales invoice
Endif
Local Integer NBMAX, SAVCONS
Local Decimal MONTMIN, MONTPRO
Local Char    CRIT(250)

Global Integer GMODIF2
Global Char    GSYMBOLE(30)
Return

$DEBUT
Raz [M:MFT1], GMODIF
Return

# Gère l'état des boutons et des options du menu
$SETBOUT
Raz ETABOU
If GMODIF=1
  ETABOU(GENRE) = 1
  ETABOU(GABAN) = 1
  Grizo [MFT1]5
Else
  Actzo [MFT1]5
Endif
ETABOU(GBFIN) = 1
ETABOU(GPREM) = 1
ETABOU(GDERN) = 1
ETABOU(GRAFF) = 1
If [M:MFT1]BPR <> ""
 ETABOU(GSUIV) = 1
 ETABOU(GPREC) = 1
Endif
Call SETBOUT(ETABOU) From GESECRAN
Return

$AP_CHOIX
If REPONSE = GSTARET
 Gosub ENREG
Endif
Return

$PREMIER
Gosub CONFIRME
If (GMODIF and !OK) or (!GMODIF)
  Read [F:BPC]BPC0 First
  If !fstat
   [M:MFT1]BPR=[F:BPC]BPCNUM
  Endif
  Gosub CHARGE
Endif
Return

$DERNIER
Gosub CONFIRME
If (GMODIF and !OK) or (!GMODIF)
  Read [F:BPC]BPC0 Last
  If !fstat
   [M:MFT1]BPR=[F:BPC]BPCNUM
  Endif
  Gosub CHARGE
Endif
Return

$SUIVANT
Gosub CONFIRME
If (GMODIF and !OK) or (!GMODIF)
  Read [F:BPC]BPC0 > [M:MFT1]BPR
  If fstat
    GERR=2 : GMESSAGE=mess(11,100,1)  : # Début/fin de fichier
    Return
  Else
    [M:MFT1]BPR=[F:BPC]BPCNUM
  Endif
  Gosub CHARGE
Endif
Return

$PRECEDENT
Gosub CONFIRME
If (GMODIF and !OK) or (!GMODIF)
  Read [F:BPC]BPC0 < [M:MFT1]BPR
  If fstat
    GERR=2 : GMESSAGE=mess(11,100,1)  : # Début/fin de fichier
    Return
  Else
    [M:MFT1]BPR=[F:BPC]BPCNUM
  Endif
  Gosub CHARGE
Endif
Return

# Fin de programme
$FIN
# Si des modifications ont été faites, on demande une confirmation avant de sortir
Gosub CONFIRME
If GMODIF and OK
 # on retourne en saisie
 FIN = 0
Else
 Gosub DEVERROU
Endif
Return

$DEVERROU
Unlock =GSYMBOLE
Return

$ENREG
If GMODIF = 1
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK=1
  GMODIF = 0
 Else
  GMODIF = 1
 Endif
Endif
Return

$ABANDON
 Gosub CHARGE
Return

$GAUCHE
Gosub CONFIRME
If (GMODIF and !OK) or (!GMODIF)
  [M:MFT1]BPR = [F:BPC]BPCNUM
  Gosub CHARGE
Endif
Return

$CONFIRME
OK = 0
# La fiche courante a été modifiée, voulez-vous abandonner la modification
If GMODIF
 Call OUINON(mess(7,126,1) + "\" + mess(9,126,1),OK) From GESECRAN
Endif
OK=!(OK=2)
Return

#############################################
$TR1
GOK = 1
Trbegin [SIH], [DUD]
 For I=0 To [M:MFT1]NBLIG-1
  If [M:MFT1]UPDREC(I)=1
   If ([M:MFT1]BPRFCT(I)="") and ([M:MFT1]MTTREG(I)<>0)
    # Facture avec règlement sans factor
    Call MESSAGE(mess(61,121,1) + " : " + [M:MFT1]NUM(I)) From GESECRAN
   Endif
   Update [SIH] Where NUM=[M:MFT1]NUM(I) With BPRFCT=[M:MFT1]BPRFCT(I)
   If fstat=1 : GOK = -1 : GLOCK = "$SINVOICE"-[M:MFT1]NUM(I) : Break
   Elsif fstat<>0 : GOK = 0 : Call RSTA("SIH",[M:MFT1]NUM(I)) From GLOCK : Break
   Elsif !fstat
    [M:MFT1]UPDREC(I) = 0
    Update [DUD] Where TYP=[M:MFT1]GTE(I) & NUM=[M:MFT1]NUM(I) With BPRFCT=[M:MFT1]BPRFCT(I)
    If fstat=1 : GOK = -1 : GLOCK = "$GACCDUDATE"-[M:MFT1]NUM(I) : Break
    Elsif fstat<>0 : GOK = 0 : Call RSTA("DUD",[M:MFT1]NUM(I)) From GLOCK : Break
    Elsif !fstat & GMODU(5)=2 & [M:MFT1]ORIMOD(I)=5
     Update [SIV] Where NUM=[M:MFT1]NUM(I) With BPRFCT=[M:MFT1]BPRFCT(I)
     If fstat=1 : GOK = -1 : GLOCK = "$SINVOICEV"-[M:MFT1]NUM(I) : Break
     Elsif fstat<>0 : GOK = 0 : Call RSTA("SIV",[M:MFT1]NUM(I)) From GLOCK : Break
     Endif
    Endif
   Endif
  Endif
 Next I
 If GOK<0    : Goto ROLL
 Elsif GOK=0 : Goto ABORT
 Endif
Commit
Return

$ROLL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$ABORT
Rollback
Return

##############
$APRES_MODIF
Case COUZON
 When "BPRFCT"
   GMODIF = 1
   [M:MFT1]UPDREC(nolign-1) = 1
   Gosub SETBOUT
 When Default
Endcase
Return

$VERROU
If GSYMBOLE<>""
 Unlock =GSYMBOLE
Endif
GSYMBOLE ="MAJFCT\"+[M:MFT1]BPR
Lock =GSYMBOLE With lockwait=0
If fstat
 # Modification en cours sur un autre poste
 GERR=1 : GMESSAGE=mess(10,100,1) : Return
Endif
Return

##############
# Rechargement du tableau en cas de demande de rafraîchissement
$RAFFR
Gosub CONFIRME
If (GMODIF and !OK) or (!GMODIF)
 Gosub CHARGE
Endif
Return

##########################################################
$CHARGE
 Gosub VERROU
 If GERR=1 : Return : Endif
 # Filtre sur quittance="" et Mtt non nul
 CRIT = "BPR='" + [M:MFT1]BPR + "' & FCTVCR='' & AMTATI<>0 & INVTYP<>5"
 If [M:MFT1]CPY<>""
  CRIT -= "& CPY='" + [M:MFT1]CPY + "'"
 Endif
 If [M:MFT1]FCY<>""
  CRIT -= "& FCY='" + [M:MFT1]FCY + "'"
 Endif
 If [M:MFT1]INVNUMDEB<>""
  CRIT -= "& NUM>='" + [M:MFT1]INVNUMDEB + "'"
 Endif
 If [M:MFT1]INVNUMFIN<>""
  CRIT -= "& NUM<='" + [M:MFT1]INVNUMFIN + "'"
 Endif
 Effzo [M:MFT1]10
 NBMAX = max(dim([M:MFT1]NUM),100)
 If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
  CRIT -= "& find(FCY, GUSRFCY(1..GNBAUZ))"
 Endif
 nolign = 0
 For [SIH]SIH0 Where evalue(CRIT)
  nolign += 1
  If nolign > NBMAX : Break : Endif
  [M:MFT1] = [F:SIH]
  Call INFOECHE(1,[F:SIH]NUM,MONTMIN,MONTPRO) From SUBBIH
  If [M:MFT1]AMTATI(nolign-1) - MONTMIN <= 0
   nolign -= 1
  Else
   [M:MFT1]MTTREG(nolign-1) = MONTMIN
   [M:MFT1]NBLIG += 1
  Endif
 Next
 If nolign = 0
   GERR=2 : GMESSAGE=mess(60,121,1)  :# Pas de facture non quittancée pour ce client
 Elsif nolign > NBMAX
   GERR=2 : GMESSAGE=mess(26,100,1)  :# Tableau plein
 Endif
 Affzo [MFT1]10
 GMODIF = 0
Return


############################################
## Etiquettes du masque MAJFCT0
############################################
Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()
GMODIF2 = 1
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M]CPY <> ""
 GBOUT2=mess(73,121,1)-[M]CPY    # Sites de
Else
 GBOUT2=""
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]CPY<>""
 Call CONTALLFCY([M]CPY) From CPTSUB : # Contrôle si tous les sites de la société sont accessibles
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
GMODIF2 = 1
# <JFL>
If VALEUR<>""
Local Integer OK
# récupération de la société dont dépend le site
 Read [FCY]FCY0=VALEUR
Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
GMODIF2 = 1
If VALEUR<>""
 [M]FCY="" : Affzo [M]FCY
Endif
End

$SEL_TABLE
Case COUZON
 When "FCY" : Gosub S_FCY
 When "INVNUMDEB", "INVNUMFIN" : Gosub S_NUM
Endcase
Return

$S_FCY
OBJET = "FCY"
If [M]CPY<>''
 CRITERE = "LEGCPY='"+[M]CPY+"'"
 If GUSRFCY(1)<>'\' & GNBAUZ<>GNBSITE
  CRITERE -= "& find(FCY,GUSRFCY(1..GNBAUZ))"
 Endif
Endif
Return

$S_NUM
OBJET = "BIT"
CRITERE = "BPR='"+[M]BPR+"'"
Return

Subprog IB_NBLIG
If [M]NUM(nolign-1)<>""
 GBOUT1 = mess(1,645,1)  :# Facture
Else
 GBOUT1 = ""
Endif
End

$AB1_NBLIG
Case [M]ORIMOD(nolign-1)
  When 3 : GBIDC1 = "BIC"
  When 5 : GBIDC1 = "SIH"
Endcase
SAVCONS = GCONSULT
GCONSULT = 2
Return

$BB1_NBLIG
GCONSULT = SAVCONS
Return


Subprog AM_INVNUMDEB(VALEUR)
Variable Char    VALEUR()
GMODIF2 = 1
End

Subprog AS_INVNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]INVNUMDEB : VALEUR=[M]INVNUMDEB : Endif
End

Subprog C_INVNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]INVNUMDEB
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 2
Endif
End

Subprog AP_INVNUMFIN(VALEUR)
Variable Char    VALEUR()
Local Char    CRIT(250)
Local Integer NBMAX
Local Decimal MONTMIN, MONTPRO
If !GMODIF2 & VALEUR = [M]INVNUMFIN
 End
Else
 [M]INVNUMFIN = VALEUR
 Gosub CHARGE
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 29/08/2003 16:16:57 (CP) Bug 19292
##########################################################################
Subprog C_BPRFCT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<>[M]BPRFCT(nolign-1) & [M:MFT1]MTTREG(nolign-1)<>0
    Call MESSAGE(mess(50,117,1))From GESECRAN  # Il y a un règlement sur cette échéance
Endif
# SAM 88426 - 2015-06-22 by LUCUE : Factoring Management
If VALEUR<>"" & [F:FCT]FCTTYP>1
  If !clalev([SIHX]): Local File SINVOICE [SIHX]: Endif
  Read [F:SIHX]SIH0=[M]NUM(nolign-1)
  If !fstat
     If [F:SIHX]CPY<>[F:FCT]BANCPY or ([F:FCT]BANFCY<>"" and [F:SIHX]FCY<>[F:FCT]BANFCY)
       GMESSAGE=mess(204,121,1): mkstat=2 #Incompatibility between the company/site of the factor and the company/site of the invoice
     Endif
  Endif
Endif
# End SAM 88426
End

