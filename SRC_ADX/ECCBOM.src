#<AdxTL>@(#)11.0.0.0 $Revision$
######################################################
## Versioning management for BOMs
## GH 03/2015
######################################################

$ACTION
Case ACTION
 When "SEL_TABLE"        : Case COUZON
                             When "BOHECCMAJ","BOHECCMIN" : Gosub SELBOHECC
                             When "ECCVALMAJ","ECCVALMIN" : Gosub SELECCVAL
                           Endcase
 When "VERF_TABLE"       : Case COUZON
                             When "BOHECCMAJ"             : Gosub SELBOHECCMIN
                             When "ECCVALMAJ"             : Gosub VERFECCVAL
                           Endcase
 When "REVISION"         : Gosub REVISION
Endcase
Return

######################################################################################

$OUVRE
If clalev([F:EVL])=0 : Local File ECCVAL [EVL] : Endif
Return

######################################################

$OUVRE_BOITE
If GFONBOD = "BOMC" & dim([M:BOH0]BOHECCMAJ)=1
   Chgfmt [M:BOH0]BOHECCMAJ  With "-K:1X"
   Chgfmt [M:BOH0]BOHECCMIN  With "-K:1X"
   If dim([M:BOH0]ZBOHECCMAJ)=1 : Chgfmt [M:BOH0]ZBOHECCMAJ  With "-K:1X" : Endif
   Chgfmt [M:BOH0]ECCSTRDAT  With "-"+GFMD                 # GH 12/10/2015 bug 111671
   Chgfmt [M:BOH0]ECCENDDAT  With "-"+GFMD                 # GH 12/10/2015 bug 111671
Endif
Return

######################################################

$STATUT
Case BOUT
  When "n","v" : # revision, validation
    OK=0
    If val([L]PARBOUT(3))>0
       Read [EVL]EVL0 = [L]PARBOUT(1);val([L]PARBOUT(3));val([L]PARBOUT(2))
       If !fstat
          Read [BOH]BOH0 = [F:EVL]ITMREF;[F:EVL]BOMALT;[F:EVL]ECCTYP
          If !fstat
             If VERROU : Gosub DEVERROU From GOBJET : Endif
             Gosub LECTURE From GOBJSUB
             OK=1
          Endif
       Endif
    Endif
    If !OK : Gosub RELIT From GOBJSUB : Endif
  When "g","p" : # management, propagation
    Gosub RELIT From GOBJSUB
Endcase
Return

######################################################

$APRES_MODIF
Case COUZON
 When "BOMALT"
     If find(GREP,"","C","D") & dim([M:BOH0]ECCSEQ)=1
        If varmode([M:BOH0]BOHECCMAJ)
           [M:BOH0]ECCSEQ=0 : Return
        Endif
        Read [BOH]BOH0 = [M:BOH0]ITMREF;zc;[M:BOH0]BOMALTTYP
        If fstat
           Filter [EVL] Where ITMREF=[M:BOH0]ITMREF & ECCTYP=[M:BOH0]BOMALTTYP
           If rowcount([EVL])>0 : GMESSAGE = mess(7,123,1) : OK=0 : Endif : # Création impossible
           Filter [EVL]
           If OK & GREP="D"
              For I=0 To [M:BOD1]NBLIG-1
                  If [M:BOD1]CPNTYP(I)=1
&                    & ([M:BOD1]BOMSTRDAT(I)<>[M:BOH0]BOHSTRDAT | [M:BOD1]BOMENDDAT(I)<>[M:BOH0]BOHENDDAT)
                     GMESSAGE=mess(206,192,1) : OK=0 : Break : # Duplication impossible
                  Endif
              Next
           Endif
           If !OK : Return : Endif
           [M:BOH0]ECCSEQ=-1 : [M:BOH0]USESTA=1 : Affzo [BOH0]USESTA
        Endif
     Endif
 When "DATREF"
     If !GIMPORT & dim([M:BOH0]BOHECCMAJ)=1 : Affzo [BOH0]BOHECCMAJ, BOHECCMIN : Endif
 When "BOHECCMAJ","BOHECCMIN"
     OK = -1
     If COUZON="BOHECCMAJ"
        If CZ=""
           [M:BOH0]BOHECCMIN=""
        Elsif func ECCLIB.NBRCPN([M:BOH0]ITMREF)=2 & [M:BOH0]BOHECCMIN=""
           Return
       Endif
     Endif
     Assign "[M:BOH0]"+COUZON  With CZ : # because [M] is not already loaded ! 04/03/03 (17507)
     If GREP="D" : Return : Endif
     Raz [M:BOD1]
     Gosub LIENS From SUBBODA : # read again the lines and load screen
     If !GIMPORT
       If dim([M:BOH0]BOHECCMAJ)=1 : Affzo [BOH0]BOHECCMAJ, BOHECCMIN : Endif
       If dim([M:BOH0]ZBOHECCMAJ)=1 : Affzo [BOH0]ZBOHECCMAJ : Endif
       Affzo [BOD1]
     Endif
Endcase
Return

######################################################

$LIENS1
If dim([M:BOH0]BOHECCMAJ)=1
   Raz [M:BOH0]ECCDAT, [M:BOH0]ECCSEQ, [M:BOH0]GRPMAX, [M:BOH0]TYPREV, [M:BOH0]ECCSTRDAT, [M:BOH0]ECCENDDAT
   Call ECCAFF([M:BOH0]ITMREF) From ECCBOM
   If varmode([M:BOH0]BOHECCMAJ)=0
      If [M:BOH0]DATREF=[0/0/0]
         If !find(GREP,"C","D") : [M:BOH0]BOHECCMAJ="" : [M:BOH0]BOHECCMIN="" : Endif
         Filter [EVL] Where ITMREF=[M:BOH0]ITMREF & ECCTYP=[M:BOH0]BOMALTTYP
         If rowcount([EVL])=1    : [M:BOH0]ECCSEQ=1
         Elsif [M:BOH0]USESTA=2  : [M:BOH0]ECCSEQ=-2
         Endif
         Filter [EVL]
      Endif
      If [M:BOH0]ECCSEQ=0
        If [M:BOH0]USESTA=1
           Filter [EVL] Where ITMREF=[M:BOH0]ITMREF & ECCTYP=[M:BOH0]BOMALTTYP & USESTA=1
        Else
           Filter [EVL] Where ITMREF=[M:BOH0]ITMREF & ECCTYP=[M:BOH0]BOMALTTYP & USESTA=2
&                           & [M:BOH0]DATREF>=[F:EVL]STRDAT & ([M:BOH0]DATREF<=[F:EVL]ENDDAT | [F:EVL]ENDDAT=[0/0/0])
        Endif
        Read [EVL]EVL0 Last
        If fstat>2
           Filter [EVL] Where ITMREF=[M:BOH0]ITMREF & ECCTYP=[M:BOH0]BOMALTTYP
           Read [EVL]EVL0 Last
        Endif
        Filter [EVL]
        If fstat<=2
           [M:BOH0]ECCSEQ    = [F:EVL]ECCSEQ
           If [M:BOH0]DATREF<>[0/0/0]
              [M:BOH0]BOHECCMAJ = [F:EVL]ECCVALMAJ
              [M:BOH0]BOHECCMIN = [F:EVL]ECCVALMIN
              If [M:BOH0]DATREF<[F:EVL]STRDAT | ([M:BOH0]DATREF>[F:EVL]ENDDAT & [F:EVL]ENDDAT<>[0/0/0])
                 # Issue 115658 - 2016-10-12 by CCC : during import don't set GDATEREF & [M]DATREF otherwise the screen is not filled completely
                 If !GIMPORT
                    [M:BOH0]DATREF = [F:EVL]STRDAT : GDATEREF = [M:BOH0]DATREF
                 Endif
              Endif
           Endif
        Endif
      Endif

      If [M:BOH0]ECCSEQ>0
        If [F:EVL]ITMREF<>[M:BOH0]ITMREF | [F:EVL]ECCSEQ<>[M:BOH0]ECCSEQ | [F:EVL]ECCTYP<>[M:BOH0]BOMALTTYP
           Read [EVL]EVL0 = [M:BOH0]ITMREF;[M:BOH0]ECCSEQ;[M:BOH0]BOMALTTYP
        Else
           fstat=0
        Endif
        If !fstat
           [M:BOH0]ECCDAT = [F:EVL]STRDAT
           [M:BOH0]ECCSTRDAT = [F:EVL]STRDAT
           [M:BOH0]ECCENDDAT = [F:EVL]ENDDAT
        Endif
      Elsif [M:BOH0]ECCSEQ=0 & find(GREP,"C","D")   # precaution
        [M:BOH0]ECCSEQ=-1 : [M:BOH0]USESTA=1 : Affzo [BOH0]USESTA
      Endif
   Endif
   If varmode([M:BOH0]ECCSTRDAT)<>3 # GH 12/10/2015 bug 111671
      Affzo [BOH0] ECCSTRDAT, ECCENDDAT
   Endif
Endif
Return

######################################################

$LIENS2
# no style for lines for BOM available to use or first version in developpement
If dim([M:BOH0]ECCSEQ)=1 & [M:BOH0]BOMALTTYP<>1 & !GIMPORT
   If  !([M:BOH0]USESTA=1 & [M:BOH0]ECCSEQ>1)
     Chgstl [BOD1] With  ""
   Elsif [M:BOD1]NBLIG>0
     Affzo [BOD1]
     Call HIGHLIGHT
   Endif
Endif
Return

######################################################

$RAZDUP
If !GIMPORT & dim([M:BOH0]ECCSEQ)=1
   If dim([M:BOD1]ECCRLEGRP)>0 : Effzo [BOD1]ECCRLEGRP : Endif
   If [M:BOH0]BOHECCMAJ<>"" & varmode([M:BOH0]BOHECCMAJ) : Effzo [BOH0]BOHECCMAJ : Endif
   If [M:BOH0]BOHECCMIN<>"" & varmode([M:BOH0]BOHECCMIN) : Effzo [BOH0]BOHECCMIN : Endif
   Effzo [BOH0] ECCSTRDAT, ECCENDDAT
   If [M:BOH0]BOHECCMAJ=""
      [M:BOH0]ECCSEQ=0
   Else
     Effzo [BOH0] BOHENDDAT
     For nolign = 1 To [M:BOD1]NBLIG
       If [M:BOD1]CPNTYP(nolign-1)=1
          [M:BOD1]BOMSTRDAT(nolign-1) = [M:BOH0]BOHSTRDAT
          [M:BOD1]BOMENDDAT(nolign-1) = [M:BOH0]BOHENDDAT
       Endif
     Next
     Affzo [BOD1] BOMSTRDAT
     Affzo [BOD1] BOMENDDAT
   Endif
Endif
Return

######################################################

$APRES_CRE
If dim([M:BOH0]ECCSEQ)=1 & [M:BOH0]ECCSEQ=-1
   [M:BOH0]ECCSEQ = 1
   [M:BOH0]ECCDAT = [M:BOH0]BOHSTRDAT

   If GDATEREF<[M:BOH0]BOHSTRDAT
&   & !GIMPORT  # Issue 115658 - 2016-10-12 by CCC : during import don't set GDATEREF & [M]DATREF otherwise the screen is not filled completely
        GDATEREF=[M:BOH0]BOHSTRDAT
   Endif
Endif
Return

######################################################

$MODIF
If dim([M:BOH0]ECCSEQ)=1 & [M:BOH0]ECCSEQ=1 & [M:BOH0]USESTA=1
   # modification of starting/ending dates for the first version in development
   Readlock [EVL]EVL0 = [M:BOH0]ITMREF;1;[M:BOH0]BOMALTTYP
   If fstat=1
      GOK=-1 : GLOCK="$ECCVAL"-[M:BOH0]ITMREF-"1"-num$([M:BOH0]BOMALTTYP) : Return
   Elsif fstat
      GOK=0 : Call FSTA("EVL") From GLOCK : Return
   Endif
   [F:EVL]STRDAT    = [M:BOH0]BOHSTRDAT
   [F:EVL]ENDDAT    = [M:BOH0]BOHENDDAT
   Rewrite [EVL]
   If fstat
      GOK=0 : Call FSTA("EVL") From GLOCK : Return
   Endif
Endif

# suppression of a revision group
If MAJGRP>0
   For [BOD] Where ITMREF=[M:BOH0]ITMREF & BOMALT=[M:BOH0]BOMALT & BOMALTTYP=[M:BOH0]BOMALTTYP & ECCRLEGRP>0
&                &  (BOMSTRDAT>[M:BOH0]DATREF | (BOMENDDAT<>[0/0/0] & BOMENDDAT<[M:BOH0]DATREF))
       Filter [BOD2] Where ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & BOMALTTYP=[F:BOD]BOMALTTYP & ECCRLEGRP=[F:BOD]ECCRLEGRP
       If rowcount([BOD2])<2
          Read [BOD]BOD0 =
          [F:BOD]ECCRLEGRP = 0
          Rewrite [BOD]
          If fstat
             GOK=0 : Call FSTA("BOD") From GLOCK : Break
          Endif
       Endif
   Next
   Filter [BOD2]
   If GOK<0 : Return : Endif
Endif
Return

######################################################

$APRES_MOD
If [M:BOH0]USESTA=2 & !(dim([L]TRTGBM)=1 & [L]TRTGBM="VALEVL")
   Filter [EVL] Where ITMREF=[M:BOH0]ITMREF & ECCTYP=[M:BOH0]BOMALTTYP & USESTA=1
   Look [EVL]EVL0 Last
   If fstat<=2
      # If necessary, transfer manually modifications on the BOM in development
      Call MESSAGE(mess(316,193,1)) From GESECRAN
   Endif
   Filter [EVL]
Endif
Return

######################################################

$CREATION
If dim([L]TRTGBM)=1 & [L]TRTGBM<>""
   # version in development creation or revision
   Local Char SAVACTION(20) : SAVACTION = ACTION
   ACTION = "CREATION" : Gosub ACTION From =[L]TRTGBM
   ACTION = SAVACTION
   If GOK<1 : Return : Endif

Elsif dim([M:BOH0]BOHECCMAJ)=1 & [M:BOH0]BOHECCMAJ<>""
   # first version in development creation
   Raz [F:EVL]
   [F:EVL] = [M:BOH0]
   [F:EVL]ECCSEQ    = 1
   [F:EVL]ECCTYP    = [M:BOH0]BOMALTTYP
   [F:EVL]ECCVALMAJ = [M:BOH0]BOHECCMAJ
   [F:EVL]ECCVALMIN = [M:BOH0]BOHECCMIN
   [F:EVL]STRDAT    = [M:BOH0]BOHSTRDAT
   [F:EVL]ENDDAT    = [M:BOH0]BOHENDDAT
   [F:EVL]EXNFLG    = 1
   If dim([F:EVL]UPDBOMNUM)=1
      [F:EVL]UPDBOMNUM = ""
      [F:EVL]UPDBOMFLG = 1 : # No propagation to be managed
   Endif
   Write [EVL]
   If fstat
      GOK=0 : Call FSTA("EVL") From GLOCK : Return
   Endif

   Readlock [ITM]ITM0 = [M:BOH0]ITMREF
   If fstat
      GOK=0 : Call RSTA("ITM",[M:BOH0]ITMREF) From GLOCK : Return
   Endif
   Assign "[F:ITM]ECCBOMALT"+num$([M:BOH0]BOMALTTYP)+"(0)" With [M:BOH0]BOMALT
   Rewrite [ITM]
   If fstat
      GOK=0 : Call FSTA("ITM") From GLOCK : Return
   Endif
Endif
Return

######################################################

$SETBOUT
# head menu for versioning
If CLECUR & GREP="" & dim([M:BOH0]ECCSEQ)=1 & [M:BOH0]ECCSEQ<>0
   CHMEN+="ag" : # BOM codes, management
   If [M:BOH0]USESTA=2 & VERROU : CHMEN+="n"  : Endif : # revision
   If [M:BOH0]USESTA=1 & VERROU : CHMEN+="v"  : Endif : # validation
Endif
Return

######################################################

$VERF_ANU
If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0  : Return : Endif
If dim([M:BOH0]NEWALT)=1 & [M:BOH0]NEWALT<>0 : Return : Endif

If [F:AN__]USESTA<>2
  # Deletion of a BOM in development with versioning

  If !clalev([F:EVL])  : Local File ECCVAL   [EVL] : Endif
  If dim([F:EVL]UPDBOMNUM)=1
    Filter [EVL] Where ITMREF=[F:AN__]ITMREF & ECCTYP=[F:AN__]BOMALTTYP & USESTA=1
    Read [EVL]EVL0 Last
    Filter [EVL]
    If fstat<=2 & [F:EVL]UPDBOMNUM<>""
       GERR=1 : GMESSAGE = mess(317,193,1)-[F:EVL]UPDBOMNUM : # Delete before the propagation of version
       OK = 0 : Return
    Endif
  Endif

Else
  # Deletion of a BOM available to use with versioning

  Case [F:AN__]BOMALTTYP
    When 2
      # No WO should use the BOM to delete (tracability)
      If !clalev([F:MFI])  : Local File MFGITM     [MFI] : Endif
      For [MFI] Where ITMREF=[F:AN__]ITMREF & BOMALT=[F:AN__]BOMALT & ITMTYP=1
          GMESSAGE = mess(101,126,1)-"MFGITM"-[F:MFI]MFGNUM+"~"+num$([F:MFI]MFGLIN)
          GMESSAGE+="\"+mess(176,115,1)
          OK=0 : Break
      Next
    When 3
      # No EO should use the BOM to delete (tracability)
      If !clalev([F:SCI])  : Local File SCOITM     [SCI] : Endif
      For [SCI] Where ITMREF=[F:AN__]ITMREF & BOMALT=[F:AN__]BOMALT
          GMESSAGE = mess(101,126,1)-"SCOITM"-[F:SCI]SCONUM+"~"+num$([F:SCI]SCOLIN)
          GMESSAGE+="\"+mess(176,115,1)
          OK=0 : Break
      Next
  Endcase
  If !OK : Return : Endif

  If !clalev([F:EVL])  : Local File ECCVAL   [EVL] : Endif
  Filter [EVL] Where ITMREF=[F:AN__]ITMREF & ECCTYP=[F:AN__]BOMALTTYP & USESTA=1
  Look [EVL]EVL0 Last
  Filter [EVL]
  If fstat<=2
     GERR=1 : GMESSAGE = mess(315,193,1) : # Delete before the BOM in development
     OK = 0 : Return
  Endif
Endif
Return

######################################################

$ANNULE
If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0  : Return : Endif

If dim([M:BOH0]NEWALT)=1 & ![M:BOH0]NEWALT

   Local Char    VMAJ(GLONICVVAL), VMIN(GLONICVVAL)
   Local Integer K
   If !clalev([F:EVL])  : Local File ECCVAL   [EVL] : Endif
   If !clalev([F:EVL3]) : Local File ECCVAL   [EVL3] : Endif
   If !clalev([F:ECS])  : Local File ECCSTA   [ECS]  : Endif
   If !clalev([F:BOD])  : Local File BOMD     [BOD]  : Endif
   # optimisation
   If !clalev([F:EVL2]) : Local File ECCVAL   [EVL2] : Endif
   If !clalev([F:STL])  : Local File STOLOT   [STL]  : Endif
   If !clalev([F:ORD])  : Local File ORDERS   [ORD]  : Endif

   For [EVL]EVL1(2) Where ITMREF=[F:AN__]ITMREF & ECCTYP=[F:AN__]BOMALTTYP & BOMALT=[F:AN__]BOMALT
     VMAJ = [F:EVL]ECCVALMAJ

     For [EVL]EVL1
       VMIN = [F:EVL]ECCVALMIN

       # Deletion of versions relative to the BOM (item, BOM code, flow) to delete
       GCLE=[F:AN__]ITMREF-VMAJ-VMIN-num$([F:AN__]BOMALTTYP)
       Delete [EVL] =
       If fstat=1 | fstat>5
         GOK=0 : Call RSTA("EVL",GCLE) From GLOCK : Break (2)
       Endif

       K=0
       Read [EVL3]EVL1 =[F:AN__]ITMREF;[L]VMAJ;[L]VMIN;4
       If fstat>2 : K=1
       Elsif !func ECCLIB.TSTEVL4DEL([F:AN__]ITMREF,[L]VMAJ,[L]VMIN) : K=2
         # For the item and the major and minor version,
         # deletion of record in table ECCVAL with flow=4
         #   if no more record in table ECCVAL with flow<4
         #   and if no more record in tables STOLOT and ORDERS
       Endif
       If K
         For [BOD] Where CPNITMREF=[F:AN__]ITMREF & ECCVALMAJ=[L]VMAJ & ECCVALMIN=[L]VMIN
&                      & !(ITMREF=[F:AN__]ITMREF & BOMALT=[F:AN__]BOMALT & BOMALTTYP=[F:AN__]BOMALTTYP)
          If K=2
              K=1
              # Keep the record ECCVAL with flow=4
          Else
              GOK=0
              Call RSTA("BOD",mess(101,126,1)-[F:BOD]ITMREF-num$([F:BOD]BOMALT)-num$([F:BOD]BOMSEQ)-[F:BOD]CPNITMREF-num$([F:BOD]BOMALTTYP)) From GLOCK
              # The record is used by another BOM line
           Endif
           Break (2)
         Next
       Endif
       If K=2
         GCLE=[F:AN__]ITMREF-VMAJ-VMIN-"4"
         Delete [EVL3] =
         If fstat=1 | fstat>5
            GOK=0 : Call RSTA("EVL3",GCLE) From GLOCK : Break (2)
         Endif
       Endif
     Next

     # delete major version in table ECCSTA if there is no more record relative in table ECCVAL
     If !func ECCLIB.TSTECSDEL([F:AN__]ITMREF,[L]VMAJ)
         Delete [ECS] Where ITMREF=[F:AN__]ITMREF & ECCVALMAJ=[L]VMAJ
         If fstat=1 | fstat>5
            GOK=0 : Call RSTA("ECS",[F:AN__]ITMREF-[L]VMAJ) From GLOCK : Break
         Endif
     Endif
   Next
Endif
Return

$AFFMASK
If [M:BOH0]ITMREF<>""
   Call ECCAFF([M:BOH0]ITMREF) From ECCBOM
Endif
Return

######################################################################################
## Labels for header screen
######################################################################################

Subprog ECCAFF(ITM)
Value Char ITM()

If GFONBOD="BOMC" | dim([M:BOH0]BOHECCMAJ)<0 : End : Endif

Local Integer I
I=func ECCLIB.NBRCPN(ITM)

If !I
     Diszo [BOH0]BOHECCMAJ, BOHECCMIN
     Chgfmt [M:BOD1]ECCRLEGRP  With "-N:#"
Else
     If I=1 : Actzo [BOH0]BOHECCMAJ : Diszo [BOH0] BOHECCMIN
     Else   : Actzo [BOH0]BOHECCMAJ, BOHECCMIN
     Endif
     Local File AMSKZON [AMZ]
     Read [AMZ]CODE = "BOD1";"ECCRLEGRP"
     If fstat : Raz [F:AMZ] : Endif
     Chgfmt [M:BOD1]ECCRLEGRP  With "NPz:"+num$(max(4,fix([F:AMZ]LONG)))+"#"
Endif
End

######################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

Call ECCAFF(VALEUR)
End

######################################################
Subprog C_BOMALT(VALEUR)
Variable Decimal  VALEUR

If !GIMPORT & dim([M:BOH0]ECCSEQ)=1 & GREP="D": mkstat=4 : Endif
End

######################################################
Subprog C_BOHSTRDAT(VALEUR)
Variable Date     VALEUR

If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0 : End : Endif

If VALEUR=[0/0/0]
   GMESSAGE=mess(10,123,1) : mkstat=2 : End :  # Mandatory field
Endif
End

######################################################
Subprog AM_BOHSTRDAT(VALEUR)
Variable Date     VALEUR

If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0 : End : Endif

# Issue 115658 - 2016-09-29 by CCC : During import, when modifying the date the previous value is not known in the screen
Local Date LBOHSTRDAT
LBOHSTRDAT = [M:BOH0]BOHSTRDAT
If GIMPORT & [M:BOD1]NBLIG>0
    If clalev([F:BOH2])=0 : Local File BOM [BOH2] : Endif
    Read [F:BOH2]BOH0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;[M:BOH0]BOMALTTYP
    If !fstat
        LBOHSTRDAT = [F:BOH2]BOHSTRDAT
    Endif
Endif

# first version in development => all lines with normal type have same validity period than header
For nolign = 1 To [M:BOD1]NBLIG
  If [M:BOD1]CPNTYP(nolign-1)=1 & [M:BOD1]BOMSTRDAT(nolign-1) = LBOHSTRDAT
    [M:BOD1]BOMSTRDAT(nolign-1) = VALEUR : Affzo [BOD1]BOMSTRDAT(nolign-1)
    [M:BOD1]UPDFLG(nolign-1)=1
  Endif
Next

[M:BOH0]ECCDAT=VALEUR
End

######################################################################################
## new fields for versioning management
######################################################################################
# [M:BOH0]ECCSEQ = 0  => Item with no versioning
# [M:BOH0]ECCSEQ = x  => Item with version x (in development or available to use)
# [M:BOH0]ECCSEQ = -1 => Item with version 1 in creation (in developement)
# [M:BOH0]ECCSEQ = -2 => Item with all versions (if more than 1 version)

Subprog AS_BOHECCMAJ(VALEUR)
Variable Char    VALEUR()

If [M:BOH0]BOMALTTYP=1 : # Issue 116773 GH 23/06/2016 - needed for importation
   mkstat=1
Elsif GREP="M"
   mkstat = 2
Elsif func ECCLIB.NBRCPN([M:BOH0]ITMREF)<1 : # Issue 118943 GH 11/10/2016 - needed for BOMs copy
   mkstat = 1
Endif
End

######################################################
Subprog C_BOHECCMAJ(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
   Filter [EVL] Where ITMREF=[M:BOH0]ITMREF & ECCTYP=[M:BOH0]BOMALTTYP & USESTA=[M:BOH0]USESTA
   If rowcount([EVL])=0
      GMESSAGE = mess(10,123,1) : mkstat=2 : # Mandatory field
   Else
      GDATEREF=[0/0/0] : [M:BOH0]DATREF=GDATEREF : Affzo [BOH0]DATREF
   Endif
   Filter [EVL]
   End
Endif

Local Integer OK
Local Char FMT(GLONICVVAL)
Filter [EVL] Where ECCTYP=[M:BOH0]BOMALTTYP & USESTA=[M:BOH0]USESTA
Read [EVL]EVL1(2) = [M:BOH0]ITMREF;VALEUR
If fstat>2 & find(GREP,"C","D")
   If !func ECCLIB.CTLCPN([M:BOH0]ITMREF,1,VALEUR,FMT)
     If FMT=""
        GMESSAGE = mess(209,187,1)
     Else
        GMESSAGE = mess(209,187,1)-"("+FMT+")"+string$(GMESSAGE<>"","\")+GMESSAGE
     Endif
     mkstat=2 :  # Incorrect format for version
   Endif
Elsif fstat>2
   GMESSAGE = mess(308,193,1) : mkstat=2 : # Non existing version
Elsif VALEUR<>[M:BOH0]BOHECCMAJ & func ECCLIB.NBRCPN([M:BOH0]ITMREF)=1
   OK=1
Elsif VALEUR<>[M:BOH0]BOHECCMAJ & func ECCLIB.NBRCPN([M:BOH0]ITMREF)=2
   Read [EVL]EVL1 = [M:BOH0]ITMREF;VALEUR;[M:BOH0]BOHECCMIN;[M:BOH0]BOMALTTYP
   If fstat<2 : OK=1 : Else Effzo [BOH0]BOHECCMIN : Endif
Endif
Filter [EVL]
If OK & ([M:BOH0]DATREF<[F:EVL]STRDAT | ([M:BOH0]DATREF>[F:EVL]ENDDAT & [F:EVL]ENDDAT<>[0/0/0]))
   GDATEREF=[F:EVL]STRDAT : [M:BOH0]DATREF=GDATEREF : Affzo [BOH0]DATREF
Endif
End

######################################################
Subprog AS_BOHECCMIN(VALEUR)
Variable Char    VALEUR()

If GREP="M"
   mkstat=2
Elsif [M:BOH0]BOHECCMAJ="" | func ECCLIB.NBRCPN([M:BOH0]ITMREF)<2
   mkstat=1
Endif
End

######################################################
Subprog C_BOHECCMIN(VALEUR)
Variable Char    VALEUR()

Filter [EVL] Where USESTA=[M:BOH0]USESTA
Read [EVL]EVL1 = [M:BOH0]ITMREF;[M:BOH0]BOHECCMAJ;VALEUR;[M:BOH0]BOMALTTYP
Filter [EVL]
If fstat>2 & find(GREP,"C","D")
   Local Char FMT(GLONICVVAL)
   If !func ECCLIB.CTLCPN([M:BOH0]ITMREF,2,VALEUR,FMT)
     If FMT=""
        GMESSAGE = mess(209,187,1)
     Else
        GMESSAGE = mess(209,187,1)-"("+FMT+")"+string$(GMESSAGE<>"","\")+GMESSAGE
     Endif
     mkstat=2 :  # Incorrect format for version
   Endif
Elsif fstat>2
   GMESSAGE = mess(308,193,1) : mkstat=2 : # Non existing version
Elsif [M:BOH0]DATREF<[F:EVL]STRDAT | ([M:BOH0]DATREF>[F:EVL]ENDDAT & [F:EVL]ENDDAT<>[0/0/0])
   GDATEREF=[F:EVL]STRDAT : [M:BOH0]DATREF=GDATEREF : Affzo [BOH0]DATREF
Endif
End

######################################################
$SELBOHECC
OBJET="EVL1"
CRITERE="ITMREF='"+[M:BOH0]ITMREF+"' & ECCTYP="+num$([M:BOH0]BOMALTTYP)+" & USESTA="+num$([M:BOH0]USESTA)
Case COUZON
  When "BOHECCMAJ"
       EXPSTART="ECCVALMAJ='"+VALEUR+"' & ECCVALMIN='"+[M:BOH0]BOHECCMIN+"'"
  When "BOHECCMIN"
       CRITERE-="& ECCVALMAJ='"+[M:BOH0]BOHECCMAJ+"'"
       EXPSTART="ECCVALMAJ='"+[M:BOH0]BOHECCMAJ+"' & ECCVALMIN='"+VALEUR+"'"
       START="ECCVALMIN"
Endcase
Return

$SELBOHECCMIN
VALEUR = [F:EVL]ECCVALMAJ
START  = ""

If ([F:EVL]ECCVALMAJ<>[M:BOH0]BOHECCMAJ | [F:EVL]ECCVALMIN<>[M:BOH0]BOHECCMIN)
&  & ([M:BOH0]DATREF<[F:EVL]STRDAT | ([M:BOH0]DATREF>[F:EVL]ENDDAT & [F:EVL]ENDDAT<>[0/0/0]))
   GDATEREF=[F:EVL]STRDAT : [M:BOH0]DATREF=GDATEREF : Affzo [BOH0]DATREF
Endif

If [F:EVL]ECCVALMIN<>[M:BOH0]BOHECCMIN
   [M:BOH0]BOHECCMIN = [F:EVL]ECCVALMIN
   Affzo [BOH0]BOHECCMIN
   mkstat=4
Endif
Return

######################################################
Subprog AS_BOHSTRDAT(VALEUR)
Variable Date    VALEUR

If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0 : End : Endif

If [M:BOH0]USESTA=2 | [M:BOH0]ECCSEQ>1
   # Version available to use or not first version => starting date not enterable
   mkstat=2
Endif
End

######################################################
Subprog AS_BOHENDDAT(VALEUR)
Variable Date    VALEUR

If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0 : End : Endif

If [M:BOH0]USESTA=1
   # version in development => no ending date, field not enterable date
   mkstat=1
Else
   # version available to use => ending date not enterable
   mkstat=2
Endif
End

######################################################
Subprog AS_USESTA(VALEUR)
Variable Integer VALEUR

If dim([M:BOH0]ECCSEQ)<>1 |  [M:BOH0]ECCSEQ=0 : End : Endif
If find(GREP,"C","D") : VALEUR=1 : Endif
mkstat=2
End

######################################################
# Tab screens (also record entry)
######################################################

Subprog IB_NBLIG

#GBOUT10 = "Revision line"
#GBOUT11 = "Exclude line"
#GBOUT12 = "Reintegrate line"
If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]USESTA=2 | [M:BOD1]CPNTYP(nolign-1)<>1 | [M:BOH0]ECCDAT=[0/0/0] |
&   ([M:BOD1]BOMSTRDAT(nolign-1)=[M:BOH0]ECCDAT & [M:BOD1]BOMENDDAT(nolign-1)=[M:BOH0]BOHENDDAT)
#&  ([M:BOD1]BOMSTRDAT(nolign-1)=[M:BOH0]ECCDAT & [M:BOD1]BOMENDDAT(nolign-1)=[0/0/0])
   Raz GBOUT10, GBOUT11, GBOUT12
#Elsif [M:BOD1]BOMENDDAT(nolign-1)=[0/0/0] & [M:BOD1]BOMSTRDAT(nolign-1)<>[M:BOH0]ECCDAT
Elsif [M:BOD1]BOMENDDAT(nolign-1)=[M:BOH0]BOHENDDAT & [M:BOD1]BOMSTRDAT(nolign-1)<>[M:BOH0]ECCDAT
   Raz GBOUT12
Elsif  [M:BOD1]BOMENDDAT(nolign-1)=[M:BOH0]ECCDAT-1
   Raz GBOUT10, GBOUT11
Else
   Raz GBOUT10, GBOUT11, GBOUT12
Endif

If dim([M:BOH0]ECCSEQ)=1 & [M:BOH0]ECCSEQ<>0
   # no merging for BOMs with version
   Raz GBOUT4
   # no record entry for a new line of BOMs SST with version and available to use
   If [M:BOH0]BOMALTTYP=3 & [M:BOH0]USESTA=2 & [M:BOD1]BOMSEQ(nolign-1)=0 : Raz GBOUT1 : Endif
Endif
End

######################################################
Subprog D_BOMSTRDAT(VALEUR)
Variable Date     VALEUR

If dim([M:BOH0]ECCSEQ)=1 & !find([M:BOH0]ECCSEQ,0,-1)
  Gosub SETNOL
  If [M]CREFLG(NOL)=0
     VALEUR = [M:BOH0]ECCDAT
  Endif
Endif
End

######################################################
Subprog AS_CPNTYP(VALEUR)
Variable Integer VALEUR

# type Normal not changeable for a component line created by revision
# type Normal not enterable for a new line of a BOM available to use
# type Normal not enterable for a old line with another type and a BOM available to use

# Issue 115658 - 2016-10-10 by CCC : for import
If dim([M:BOH0]ECCSEQ)=1 & [M:BOH0]ECCSEQ<>0 #& !GIMPORT
   Gosub SETNOL
   If [M]ECCRLEGRP(NOL)<>0 : mkstat=2 : End : Endif
   If ([M]CREFLG(NOL)=0 | [M]CPNTYP(NOL)<>1) & [M:BOH0]USESTA=2
      GMENLOC(1)=1
   Endif
Endif
End

######################################################
Subprog AM_CPNTYP(VALEUR)
Variable Integer VALEUR

If dim([M:BOH0]ECCSEQ)=1 & [M:BOH0]ECCSEQ<>0 & VALEUR=1
   Gosub SETNOL
   [M]BOMSTRDAT(NOL) = [M:BOH0]ECCDAT    : Affzo BOMSTRDAT(NOL)
   [M]BOMENDDAT(NOL) = [M:BOH0]BOHENDDAT : Affzo BOMSTRDAT(NOL) : # Effzo BOMENDDAT(NOL)
Endif
End

######################################################
Subprog AS_BOMSTRLOT(VALEUR)
Variable Char    VALEUR()

If dim([M:BOH0]ECCSEQ)=1 & [M:BOH0]ECCSEQ<>0
   Gosub SETNOL
   If [M]CPNTYP(NOL)=1 : mkstat=1 : End :Endif
Endif
End

######################################################
Subprog AS_BOMENDLOT(VALEUR)
Variable Char    VALEUR()

If dim([M:BOH0]ECCSEQ)=1 & [M:BOH0]ECCSEQ<>0
   Gosub SETNOL
   If [M]CPNTYP(NOL)=1 : mkstat=1 : End :Endif
Endif
End

######################################################################################
## new fields for versioning management
######################################################################################

$SETNOL
Local Integer NOL
If dim([M]CPNITMREF)=1 : NOL=0 : Else NOL=nolign-1 : Endif
Return

######################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Gosub SETNOL
If func ECCLIB.NBRCPN([M]CPNITMREF(NOL))<1
   mkstat=1
Elsif dim([M]UPDBOMNUM)>0 & [M]UPDBOMNUM(NOL)<>"" : # no change of version for BOM line with propagation
   mkstat=2
Endif
End

######################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Gosub SETNOL
# Search of a version (without considering commercial BOMs)
Filter [EVL] Where ECCTYP>1
Look [EVL]EVL1(2) = [M]CPNITMREF(NOL);VALEUR
Filter [EVL]
If fstat>2
   GMESSAGE = mess(308,193,1) : # Non-existing version
   mkstat=2
Endif
End

######################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

If GIMPORT : End : Endif
Gosub SETNOL

If [M]CPNTYP(NOL)=1 & [M:BOH0]USESTA=1 & [M:BOH0]ECCSEQ>1 & [M:BOH0]TYPREV<>1
   # Change of major version on a parent item in development with version (but not the first one)
   If [M:BOH0]TYPREV=0
      Read [EVL]EVL0 = [M:BOH0]ITMREF;[M:BOH0]ECCSEQ-1;[M:BOH0]BOMALTTYP
      If !fstat
          [M:BOH0]TYPREV=2-([F:EVL]ECCVALMAJ<>[M:BOH0]BOHECCMAJ)
      Endif
   Endif
   If [M:BOH0]TYPREV=2 : # minor revision
      Local Integer OK
      # Change of  major version during minor revision
      Call AVERTIR(mess(324,193,1),OK) From GESECRAN
      If OK<>2
         VALEUR=[M]ECCVALMAJ(NOL)
      Endif
   Endif
Endif
End

######################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

Gosub SETNOL
If [M]ECCVALMAJ(NOL)="" | func ECCLIB.NBRCPN([M]CPNITMREF(NOL))<2
   mkstat=1
Elsif dim([M]UPDBOMNUM(NOL))=1 & [M]UPDBOMNUM(NOL)<>"" : # no change of version for BOM line with propagation
   mkstat=2
Endif
End

######################################################
Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

Gosub SETNOL
# Search of a version (without considering commercial BOMs)
Filter [EVL] Where ECCTYP>1
Look [EVL]EVL1(3) = [M]CPNITMREF(NOL);[M]ECCVALMAJ(NOL);VALEUR
Filter [EVL]
If fstat>2
   GMESSAGE = mess(308,193,1) : # Non-existing version
   mkstat=2
Endif
End

######################################################

Subprog TYPREV(ITM,SEQ,TYPALT)
Value Char    ITM()
Value Integer SEQ, TYPALT

If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif
Read [EVL]EVL0 = [L]ITM;[L]SEQ-1;[L]TYPALT
If fstat
   End 0
Elsif [F:EVL]ECCVALMAJ<>[M:BOH0]ECCVALMAJ
   End 1 : # major revision
Else
   End 2 : # minor revision
Endif
End

######################################################

$SELECCVAL
Gosub SELECCVAL3 From ECCLIB
If !PSTD : Return : Endif

Gosub SETNOL
CRITERE="[EVL3]ITMREF='"+[M]CPNITMREF(NOL)+"'"
I=find("[F:EVL3]ITMREF",COL(1..NBCOL))
If I
   Dela I COL,TIT
   NBCOL-=1
   TIT(0)-=[M]CPNITMREF(NOL)
Endif

If [M:BOH0]USESTA=2
   # BOM available to use => stock status = Active displayed
   CRITERE+=" & [EVL3]ECCSTA=2"
Else
   # BOM in development => stock status = (not defined,Active,To be activated) displayed
   CRITERE+=" & find([EVL3]ECCSTA,1,3)=0"
Endif

Case COUZON
  When "ECCVALMAJ"
       EXPSTART="ECCVALMAJ='"+VALEUR+"' & ECCVALMIN='"+[M]ECCVALMIN(NOL)+"'"
  When "ECCVALMIN"
       CRITERE-="& [EVL3]ECCVALMAJ='"+[M]ECCVALMAJ(NOL)+"'"
       EXPSTART="ECCVALMAJ='"+[M]ECCVALMAJ(NOL)+"' & ECCVALMIN='"+VALEUR+"'"
       START="ECCVALMIN"
Endcase
Return

$VERFECCVAL
VALEUR = [F:EVL3]ECCVALMAJ
START  = ""

If [F:EVL3]ECCVALMIN<>[M]ECCVALMIN(NOL)
   [M]ECCVALMIN(NOL) = [F:EVL3]ECCVALMIN
   Affzo ECCVALMIN(NOL)
Endif
Return

######################################################

Subprog AS_BOMSTRDAT(VALEUR)
Variable Date    VALEUR

If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0 : End : Endif
Gosub SETNOL
If [M]CPNTYP(NOL)<>1 : End : Endif

If [M:BOH0]ECCSEQ=-1
   # first version in development
   VALEUR = [M:BOH0]BOHSTRDAT
Elsif [M:BOH0]USESTA=1 & [M]CREFLG(NOL)=0
   # new line for a version in development
   VALEUR = [M:BOH0]ECCDAT
Endif
mkstat=2
End

######################################################

Subprog AS_BOMENDDAT(VALEUR)
Variable Date    VALEUR

If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0 : End : Endif
Gosub SETNOL
If [M]CPNTYP(NOL)<>1 : End : Endif

If [M:BOH0]USESTA=1 & [M]CREFLG(NOL)=0
   VALEUR = [M:BOH0]BOHENDDAT
Endif
mkstat=2
End

######################################################
## Version available       => no line with type Normal addable/deletable
## Version in development  => line of previous versions not deletable

Subprog C_NBLIG
If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0 : End : Endif

If find(status,73,82) & [M:BOH0]BOMALTTYP=3 & [M:BOH0]USESTA=2   : # Insert line, Add in last line
   mkstat=2 :  # no entry for CPNTYP field (=Normal always)

Elsif find(status,65,83) : # Delete line or lines
   Local Integer I, J
   If status=83 : J=nolign1 : Else J=nolign : Endif
   For I=nolign To J
     If [M:BOD1]CPNTYP(I-1)=1 : # Normal
        If [M:BOH0]USESTA=2 | ([M:BOH0]USESTA=1 & [M:BOD1]BOMSTRDAT(I-1)<>[M:BOH0]ECCDAT)
           mkstat=2 : Break
        Endif
     Endif
   Next I
   If mkstat
    GMESSAGE=mess(422,198,1)+"\"+mess(186,123,1) : End : # Delete line \ Action not possible
   Endif
   If [M:BOH0]USESTA=1 : # in development
      Local Integer L, K, I2
      For I=nolign To J
        If [M:BOD1]ECCRLEGRP(I-1)<>0
           K=0
           For I2=0 To [M:BOD1]NBLIG-1
              If (I2<nolign-1 | I2>J-1) & [M:BOD1]ECCRLEGRP(I2)=[M:BOD1]ECCRLEGRP(I-1) : K+=1 : L=I2+1 : Endif
           Next I2
           If K=1 & [M:BOH0]DATREF<>[0/0/0]
              # consideration of BOM lines not loaded
              For [BOD] Where ITMREF=[M:BOH0]ITMREF & BOMALT=[M:BOH0]BOMALT & BOMALTTYP=[M:BOH0]BOMALTTYP
&                   &  (BOMSTRDAT>[M:BOH0]DATREF | (BOMENDDAT<>[0/0/0] & BOMENDDAT<[M:BOH0]DATREF))
&                   &  ECCRLEGRP=[M:BOD1]ECCRLEGRP(I-1)
                  K=0 : Break
              Next
           Endif
           If K=1 : Effzo [BOD1]ECCRLEGRP(L-1) : [M:BOD1]UPDFLG(L-1)=1 : Endif
        Endif
      Next I
   Endif
Endif
End

######################################################
## Revision line
Subprog B10_NBLIG
If [M:BOD1]NBLIG >= dim([M:BOD1]CPNITMREF)
   GMESSAGE = mess(26,100,1) : mkstat=2 : # Table is full
   End
Endif

Local Integer NOL, SEQ, OK
NOL = nolign-1
# Search of a new sequence
If [M:BOH0]SEQMAX=0
   [M:BOH0]SEQMAX=9999
   If find(type([F:BOD]BOMSEQ),2,4)
      Local File AMSKZON [AMZ]
      Read [AMZ]CODE = "BOD1";"BOMSEQ"
      If fstat : Raz [F:AMZ] : Endif
      [M:BOH0]SEQMAX=max([M:BOH0]SEQMAX,val(string$([F:AMZ]LONG,"9")))
   Endif
Endif
SEQ =[M:BOD1]BOMSEQ(NOL)
Repeat
  SEQ += 1
  OK=1
  If find(num$(SEQ)+[M:BOD1]CPNITMREF(NOL),[M:BOD1]CONCATKEY(0..[M:BOD1]NBLIG-1))
     OK=0
  Elsif [M:BOH0]DATREF<>[0/0/0]
     # taking into account unloaded lines
     Read [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;[L]SEQ;[M:BOD1]CPNITMREF(NOL);[M:BOH0]BOMALTTYP
     If !fstat & ([F:BOD]BOMSTRDAT>[M:BOH0]DATREF | ([F:BOD]BOMENDDAT<[M:BOH0]DATREF & [F:BOD]BOMENDDAT<>[0/0/0]))
        OK=0
     Endif
  Endif
Until OK or SEQ>[M:BOH0]SEQMAX
If !OK | SEQ>[M:BOH0]SEQMAX : GMESSAGE = mess(313,193,1) : mkstat=2 : End : Endif : # Sequence not found

# line revisioned (destination)
Insa NOL+1,1 [M:BOD1]NBLIG
indice = NOL+1 : nolign = indice+1
[M:BOD1]BOMSEQ(indice)    = SEQ
[M:BOD1]BOMSTRDAT(indice) = [M:BOH0]ECCDAT
[M:BOD1]BOMENDDAT(indice) = [M:BOH0]BOHENDDAT : # [M:BOD1]BOMENDDAT(indice) = [0/0/0]
[M:BOD1]CPNTYP(indice) = [M:BOD1]CPNTYP(NOL)    # Issue 115658 - 2016-10-12 by CCC : for import
If [M:BOD1]ECCRLEGRP(NOL) = 0
   # new revision group
   If [M:BOH0]GRPMAX=0 & [M:BOH0]DATREF<>[0/0/0] : # consideration of unloaded lines
      For [BOD] Where ITMREF=[M:BOH0]ITMREF & BOMALT=[M:BOH0]BOMALT & BOMALTTYP=[M:BOH0]BOMALTTYP & ECCRLEGRP>0
&                   & (BOMSTRDAT>[M:BOH0]DATREF | (BOMENDDAT<[M:BOH0]DATREF & BOMENDDAT<>[0/0/0]))
          [M:BOH0]GRPMAX=max([M:BOH0]GRPMAX,[F:BOD]ECCRLEGRP)
      Next
   Endif
   [M:BOD1]ECCRLEGRP(indice) = 1+max([M:BOH0]GRPMAX,[M:BOD1]ECCRLEGRP(0..[M:BOD1]NBLIG-1))
Else
   [M:BOD1]ECCRLEGRP(indice) =  [M:BOD1]ECCRLEGRP(NOL)
Endif
[M:BOD1]BOMTEXNUM(indice) = [M:BOD1]BOMTEXNUM(indice-1)
If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
If [F:AWI]WIN<>GBOITE
   Read [AWI]AWI0  = GBOITE
Endif
OK=GIMPORT
GIMPORT=1
Call SAI_NBLIG("","REVISION","ECCBOM") From ="W0"+[F:AWI]NOMMSK(0) : # BOMTEXNUM not managed
GIMPORT=OK
If mkstat
    Dela NOL+1,1 [M:BOD1]NBLIG
    End
Endif
Call DUP_CLOB("BOD",[M:BOD1]BOMTEXNUM(NOL+1),OK) From TRTX3TEX
If OK<1 : Raz [M:BOD1]BOMTEXNUM(NOL+1) : Endif

# line to be revisioned (origin)
nolign = NOL+1 : Call AVANT_NBLIG From SUBBOD # Issue 118704 GH 07/10/16 - to update CUMQTE for BOM in percentage
[M:BOD1]UPDFLG(NOL)=1
If [M:BOD1]ECCRLEGRP(NOL) = 0
   [M:BOD1]ECCRLEGRP(NOL) = [M:BOD1]ECCRLEGRP(NOL+1) : Affzo [BOD1]ECCRLEGRP(NOL)
Endif
[M:BOD1]BOMENDDAT(NOL)=[M:BOH0]ECCDAT-1 : Affzo [BOD1]BOMENDDAT(NOL)
Call APRES_NBLIG From SUBBOD  # Issue 118704 GH 07/10/16 - to update CUMQTE for BOM in percentage
[M:BOD1]NBLIG+=1

If GIMPORT : End : Endif
Affzo [BOD1]

Call HIGHLIGHT
Goto FIN_BOD_BOUT

$REVISION
If !find(IMPZON,"BOMSEQ","BOMSTRDAT","BOMENDDAT","ECCRLEGRP")
   Assign "[M:BOD1]"+IMPZON+"(indice)" With evalue("[M:BOD1]"+IMPZON+"(indice-1)")
Endif
Return

######################################################
## Exclude line
Subprog B11_NBLIG
If !([M:BOD1]BOMENDDAT(nolign-1)=[M:BOH0]BOHENDDAT & [M:BOD1]BOMSTRDAT(nolign-1)<>[M:BOH0]ECCDAT) : End : Endif
#If !([M:BOD1]BOMENDDAT(nolign-1)=[0/0/0] & [M:BOD1]BOMSTRDAT(nolign-1)<>[M:BOH0]ECCDAT) : End : Endif

Call AVANT_NBLIG From SUBBOD # Issue 118704 GH 07/10/16 - to update CUMQTE for BOM in percentage
[M:BOD1]UPDFLG(nolign-1)=1
[M:BOD1]BOMENDDAT(nolign-1)=[M:BOH0]ECCDAT-1 : Affzo [BOD1]BOMENDDAT(nolign-1)
Call APRES_NBLIG From SUBBOD # Issue 118704 GH 07/10/16 - to update CUMQTE for BOM in percentage

Gosub HIGHLIGHT_LINE
Goto FIN_BOD_BOUT

######################################################
## Reintegrate line
Subprog B12_NBLIG
If [M:BOD1]BOMENDDAT(nolign-1)<>[M:BOH0]ECCDAT-1 : End : Endif

Call AVANT_NBLIG From SUBBOD # Issue 118704 GH 07/10/16 - to update CUMQTE for BOM in percentage
[M:BOD1]UPDFLG(nolign-1)=1
[M:BOD1]BOMENDDAT(nolign-1)=[M:BOH0]BOHENDDAT : Affzo [BOD1]BOMENDDAT(nolign-1) : # Effzo [BOD1]BOMENDDAT(nolign-1)
Call APRES_NBLIG From SUBBOD # Issue 118704 GH 07/10/16 - to update CUMQTE for BOM in percentage

Local Integer I, K, L, NOL
If [M:BOD1]ECCRLEGRP(nolign-1)<>0
   K=0 : L=0
   For I=0 To [M]NBLIG-1
     If I<>nolign-1 & [M:BOD1]ECCRLEGRP(I)=[M:BOD1]ECCRLEGRP(nolign-1)
        If [M:BOD1]BOMSTRDAT(I)=[M:BOH0]ECCDAT : L=I+1 : Else K+=1 : Endif
     Endif
   Next
   # Issue 115658 - 2016-11-02 by CCC : Replace Effzo by Raz+Affzo for import
   If !K
      Raz [M:BOD1]ECCRLEGRP(nolign-1)
      If !GIMPORT
         Affzo [BOD1]ECCRLEGRP(nolign-1)
      Endif
   Endif
   If L
      GCLE = [M:BOD1]ECCVALMAJ(L-1)-[M:BOD1]ECCVALMIN(L-1)
      NOL=nolign : nolign=L : Call AVANT_NBLIG From SUBBOD : nolign=NOL # Issue 118704 GH 07/10/16 - to update CUMQTE for BOM in percentage
      Dela L-1,1 [M:BOD1]NBLIG
      [M:BOD1]NBLIG-=1
      If !GIMPORT
         Affzo [BOD1]
         Call HIGHLIGHT
      Endif
   Endif
Endif

If GIMPORT : End : Endif
If !L : Gosub HIGHLIGHT_LINE : Endif
Goto FIN_BOD_BOUT

######################################################

$FIN_BOD_BOUT
If GREP="" : mkstat=4 : # to force to enter in modification
Else       : mkstat=3 : # to force to redo IB_NBLIG
Endif
End

######################################################

Subprog HIGHLIGHT
Local Integer NOL
NOL=nolign
For nolign=1 To [M:BOD1]NBLIG
   Gosub HIGHLIGHT_LINE
Next
nolign=NOL
End

$HIGHLIGHT_LINE
If [M:BOD1]CPNTYP(nolign-1)<>1
   Chgstl [BOD1]NBLIG(nolign-1) With  ""
Elsif [M:BOD1]BOMENDDAT(nolign-1)=[M:BOH0]ECCDAT-1
   Chgstl [BOD1]NBLIG(nolign-1) With  "ECCBODA"    : # line excluded from the version => red
Elsif [M:BOD1]BOMSTRDAT(nolign-1)=[M:BOH0]ECCDAT
   Chgstl [BOD1]NBLIG(nolign-1) With  "ECCBODC"    : # line added to the version => green
Elsif  [M:BOD1]BOMENDDAT(nolign-1)<>[0/0/0] &  [M:BOD1]BOMENDDAT(nolign-1)<[M:BOH0]ECCDAT
   Chgstl [BOD1]NBLIG(nolign-1) With  "ECCBODB"    : # line excluded from a former version => grey
Else
   Chgstl [BOD1]NBLIG(nolign-1) With  ""           : # line preserved from a former version => no style
Endif
Return

