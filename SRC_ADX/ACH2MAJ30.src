#<AdxTL>@(#)1.0.0.0 $Revision$
################################################################################
# ACH2MAJ30 : Mises à jour à effectuer lors du passage à la v6   Module achats #
# ---------------------------------------------------------------------------- #
# AV_PTH : Alimentation des nouveaux champs dans les réceptions                #
################################################################################


###########################################################
#  Alimentation des nouveaux champs dans les réceptions   #
# ------------------------------------------------------- #
# Table PRECEIPT - Entête réception :                     #
#   CPY        Code société                               #
#   BPOADD     Code adresse fournisseur expéditeur        #
#   FFWADD     Code adresse transitaire                   #
#   BPAINV     Code adresse fournisseur facturant         #
#   BPRPAY     Tiers payé                                 #
#   BPAPAY     Code adresse tiers payé                    #
#   VACBPR     Régime de taxe                             #
#   VACTYP     Type de régime de taxe                     #
#   EECNAT     Nature transaction 2 car (sup "0" devant)  #
#   EECNUM     Identification CEE                         #
#   DIE        Codes axes analytiques                     #
#   DSPWEU     Unité de poids  pour répartition           #
#   DSPVOU     Unité de volume pour répartition           #
#   TOTLINAMT  Total HT lignes                            #
#   TOTLINQTY  Total qtés lignes en UA                    #
#   TOTLINWEU  Total poids  lignes                        #
#   TOTLINVOU  Total volume lignes                        #
#   TOTAMTNOT  Total HT réception                         #
#   TOTAMTNOTL Total HT réception en devise société       #
#   TOTTAXAMT  Total taxes                                #
#   TOTAMTATI  Total TTC réception                        #
#   TOTAMTATIL Total TTC réception en devise société      #
#   INVDTALIN1 Eléments facturation ligne tarif           #
#   INVDTAVAT1 Taxes éléments ligne tarif                 #
#                                                         #
# Table PRECEIPTD - Lignes réception :                    #
#   CPY        Code société                               #
#   BPAINV     Code adresse fournisseur facturant         #
#   QTYWEU     Poids                                      #
#   QTYVOU     Volume                                     #
#   CPRPRI     Prix de revient sans frais d'approche      #
#   BPOCRY     Pays expéditeur                            #
#   CLCAMT1-3  Bases spéciales 1-3 calcul taxe            #
#   ITMREFORI  Article lancé          (remplace MFGITM)   #
#   VCRTYPORI  Type pièce origine                         #
#   VCRNUMORI  No pièce origine       (remplace MFGNUM)   #
#   VCRLINORI  Ligne pièce prigine    (remplace OPENUM)   #
#   VCRSEQORI  Séquence pièce origine (remplace OPESPLNUM)#
#   LINTYP     Type de ligne réception (1=Normale)        #
#   LINCAT     Catégorie de mouvement  (1=Standard)       #
#                                                         #
# Table CPTANALIN - Lignes comptables analytiques         #
#   Création d'enregistrements dans cette nouvelle table  #
#   en remplacement des champs comptes et sections        #
#                                                         #
# Table PVCRFOOT  - Eléments de facturation               #
#   Création d'enregistrements dans cette nouvelle table  #
#                                                         #
# Table PVCRVAT   - Tableau des taxes                     #
#   Création d'enregistrements dans cette nouvelle table  #
###########################################################
$AV_PTH
Local File =[F:ADS]DOSSIER+".PRECEIPT"   [PTH]
Local File =[F:ADS]DOSSIER+".PRECEIPTD"  [PTD]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER" [BPS]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]
Local File =[F:ADS]DOSSIER+".PORDER"     [POH]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]
Local File =[F:ADS]DOSSIER+".PFOOTINV"   [PFI]
Local File =[F:ADS]DOSSIER+".TABVAC"     [TVC]
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".TABCHANGE"  [TCH]
Local File =[F:ADS]DOSSIER+".TABUNIT"    [TUN]
Local File =[F:ADS]DOSSIER+".TABCOEFF"   [TCO]
Local File =[F:ADS]DOSSIER+".PRICSTRUCT" [PRS]
Local File =[F:ADS]DOSSIER+".PVCRVAT"    [PVV]
Local File =[F:ADS]DOSSIER+".PVCRFOOT"   [PVF]
If [F:ADS]MODULE(1)=2  Local File =[F:ADS]DOSSIER+".GACM" [GCM] : Endif
#-----
Local Libelle  WPVVFLG, WPVFFLG
Local Integer  COMPTEUR, STOP, WNBR
Local Char     CLE1(GLONPTH), CRITERE(90)
Local Integer  I, J, K
Local Decimal  WRND
#----- Variables locales pour calcul TVA -----#
Local Integer  TYPREG, STAT
Local Decimal  BASE, MONTANT(1..3), MONTDED(1..3)
Local Char     TAXE(GLONVAT)(1..3)
Local Decimal  WCLCAMT1, WCLCAMT2, WCLCAMT(1..7)
Local Libelle  WCLCFLG1, WCLCFLG2, WCLCFLG(1..7)
Local Decimal  WBASE, WAMTTAX, WDEDTAX
Local Char     WTAX(GLONVAT)
#----- Tableau des taxes en mémoire (20 maxi) -----#
Local Integer  NBTAX
Local Char     TAX(GLONVAT)(20)
Local Decimal  BASTAX(20)
Local Decimal  AMTTAX(20)
Local Decimal  DEDTAX(20)
Local Libelle  PURTYP(20)
Local Libelle  VATTYP(20)
#----- Tableau des éléments de facturation en mémoire (10 maxi) -----#
Local Integer  NBFAC
Local Integer  INVDTA(10)
Local Decimal  INVLINAMT(10)
Local Libelle  DEBCDT(10)
Local Char     INVDTAVAT(GLONVAT)(10)
Local Decimal  DTAAMTTAX(10)
Local Decimal  DTADEDTAX(10)
#-----
Raz CLE1, STOP, WNBR
Call ECR_TIME("DOSMAJ30 Purchase Receipt Process 1 : Update PRECEIPT-D") From DOSSUB
$BOUCLE_PTH
If  STOP=1
  CRITERE = 'PTHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif
Raz COMPTEUR
Trbegin [PTH],[PTD]
  For [PTH] PTH0 Where evalue(CRITERE)
    Raz [F:PTH]TOTLINAMT, [F:PTH]TOTLINQTY, [F:PTH]TOTLINWEU, [F:PTH]TOTLINVOU
    Raz NBTAX, TAX, BASTAX, AMTTAX, DEDTAX, PURTYP
    Raz NBFAC, INVDTA, INVLINAMT, DEBCDT, INVDTAVAT, DTAAMTTAX, DTADEDTAX
    #----- Alimentation de la société sur l'entête de réception -----#
    Call PARAM([F:PTH]PRHFCY,"SALDSPWEU",[F:PTH]DSPWEU) From ADOVAL
    Call PARAM([F:PTH]PRHFCY,"SALDSPVOU",[F:PTH]DSPVOU) From ADOVAL
    Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:PTH]PRHFCY) From TRTX3CPT
    [F:PTH]CPY=GSOCIETE
    #----- Taxes déjà traitées car présentes dans PVCRVAT ? -----#
    Look [PVV] PVV1=6;[F:PTH]PTHNUM;1
    If fstat  WPVVFLG=1  Else  WPVVFLG=0 : Endif
    #----- Eléments déjà traités car présents dans PVCRFOOT ? -----#
    Look [PVF] PVF1=6;[F:PTH]PTHNUM;1
    If fstat  WPVFFLG=1  Else  WPVFFLG=0 : Endif
    #----- Alimentation code adresse fournisseur expéditeur -----#
    If [F:PTH]BPOADD=""  [F:PTH]BPOADD=[F:PTH]BPAADD : Endif
    #----- Alimentation code adresse transitaire -----#
    If [F:PTH]FFWNUM<>"" & [F:PTH]FFWADD=""
      If [F:BPR]BPRNUM<>[F:PTH]FFWNUM
        Read [BPR] BPR0=[F:PTH]FFWNUM : If fstat  Raz [F:BPR] : Endif
      Endif
      [F:PTH]FFWADD=[F:BPR]BPAADD
    Endif
    #----- Alimentation code adresse fournisseur facturant -----#
    If [F:PTH]BPAINV=""
      If [F:BPS]BPSNUM<>[F:PTH]BPSINV
        Read [BPS] BPS0=[F:PTH]BPSINV : If fstat  Raz [F:BPS] : Endif
      Endif
      [F:PTH]BPAINV=[F:BPS]BPAADD
    Endif
    #----- Alimentation tiers payé et code adresse tiers payé -----#
    If [F:PTH]BPRPAY=""
      If [F:BPS]BPSNUM<>[F:PTH]BPSNUM
        Read [BPS] BPS0=[F:PTH]BPSNUM : If fstat  Raz [F:BPS] : Endif
      Endif
      [F:PTH]BPRPAY=[F:BPS]BPRPAY
      [F:PTH]BPAPAY=[F:BPS]BPAPAY
    Endif
    #----- Alimentation du régime de taxe et du type de régime -----#
    If [F:PTH]VACBPR=""
      If [F:BPS]BPSNUM<>[F:PTH]BPSNUM
        Read [BPS] BPS0=[F:PTH]BPSNUM : If fstat  Raz [F:BPS] : Endif
      Endif
      [F:PTH]VACBPR=[F:BPS]VACBPR
      #----- Chargement du régime de taxe du fournisseur -----#
      #Call INIT_REGIME([F:PTH]BPSNUM,[F:PTH]PRHFCY,"F",[F:PTH]VACBPR) From CPTSUB
      #----- Chargement du type de régime taxe -----#
      If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PTH]VACBPR
        Read [ADI] CODE=1;[F:PTH]VACBPR : If fstat Raz [F:ADI] : Endif
      Endif
      [F:PTH]VACTYP=[F:ADI]N1
      #-----
    Endif
    #----- Passage de la nature transaction CEE à 2 caractères -----#
    If len([F:PTH]EECNAT)>2 & left$([F:PTH]EECNAT,1)="0"
      [F:PTH]EECNAT=right$([F:PTH]EECNAT,2)
    Endif
    #----- Alimentation de l'identification CEE -----#
    If GACTDEB=2 & [F:PTH]EECNUM=""
      If [F:BPR]BPRNUM<>[F:PTH]BPSINV
        Read [BPR] BPR0=[F:PTH]BPSINV : If fstat  Raz [F:BPR] : Endif
      Endif
      [F:PTH]EECNUM=[F:BPR]EECNUM
    Endif
    #----- Alimentation champs pour le multi-référentiels comptabilité -----#
    If dim([F:PTH]DIE)>0 & [F:PTH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
        [F:PTH]DIE(I-1)=GDIE(I)
      Next I
    Endif
    #----- Alimentation éléments et taxes ligne tarif -----#
    If [F:BPS]BPSNUM<>[F:PTH]BPSNUM
      Read [BPS] BPS0=[F:PTH]BPSNUM : If fstat  Raz [F:BPS] : Endif
    Endif
    #-----
    Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE
    #----- Chargement arrondi devise réception -----#
    If [F:TCU]CUR<>[F:PTH]CUR
      Read [TCU] TCU0=[F:PTH]CUR
      If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
    Else
      WRND=[F:TCU]CURRND
    Endif
    #-----
    For I=0 To dim([F:PTH]INVDTAVAT1)-1
      If GINVDTALIN(I)<>0 & GNPRNOTFLG(I)=1
        [F:PTH]INVDTALIN1(I)=GINVDTALIN(I)
        If [F:PTH]INVDTAVAT1(I)=""
          Read [PFI] PFI0=GINVDTALIN(I) : If fstat  Raz [F:PFI] : Endif
          If [F:PFI]VATRUL=2
            Read [TVC] TVC0=[F:BPS]VACBPR;[F:PFI]VACITM : If fstat  Raz [F:TVC] : Endif
            [F:PTH]INVDTAVAT1(I)=[F:TVC]VAT
          Endif
        Endif
      Endif
    Next I
    #-----
    For [PTD] PTD0 Where PTHNUM=[F:PTH]PTHNUM
      #----- Alimention prix de revient sans frais d'approche (arrondi mini à 4 décimales) -----#
      If [F:PTD]CPRPRI=0
        If [F:PTD]CPRCOE=0  [F:PTD]CPRCOE=1 : Endif
        [F:PTD]CPRPRI=arr([F:PTD]CPR/[F:PTD]CPRCOE,10^-max(GDECPRI,4))
      Endif
      #----- Alimentation société et adresse fourniss. facturant sur lignes réception -----#
      [F:PTD]CPY   =[F:PTH]CPY
      [F:PTD]BPAINV=[F:PTH]BPAINV
      #----- Mise à jour des quantités poids et volume -----#
      If [F:ITM]ITMREF<>[F:PTD]ITMREF
        Read [ITM] ITM0=[F:PTD]ITMREF : If fstat  Raz [F:ITM] : Endif
      Endif
      #----- Par sécurité, chargement des unités de l'article si nécessaire -----#
      If [F:PTH]DSPWEU=""  [F:PTH]DSPWEU=[F:ITM]WEU : Endif
      If [F:PTH]DSPVOU=""  [F:PTH]DSPVOU=[F:ITM]VOU : Endif
      #-----
      [F:PTD]QTYWEU=[F:ITM]ITMWEI*[F:PTD]QTYSTU
      [F:PTD]QTYVOU=[F:ITM]ITMVOU*[F:PTD]QTYSTU
      Call CONVERT_QTY([F:ITM]WEU,[F:PTH]DSPWEU,[F:PTD]QTYWEU) From TRTX3
      Call CONVERT_QTY([F:ITM]VOU,[F:PTH]DSPVOU,[F:PTD]QTYVOU) From TRTX3
      #----- Alimentation des bases spéciales 1-3 calcul taxe -----#
      If ([F:PTD]CLCAMT1<>0 | [F:PTD]CLCAMT2<>0)
&       & [F:PTD]CLCAMT3=0
&       & [F:PTD]CLCAMT4=0
&       & [F:PTD]CLCAMT5=0
&       & [F:PTD]CLCAMT6=0
&       & [F:PTD]CLCAMT7=0
        #-----
        Raz WCLCAMT, WCLCFLG
        WCLCAMT1=[F:PTD]CLCAMT1 : WCLCFLG1=0
        WCLCAMT2=[F:PTD]CLCAMT2 : WCLCFLG2=0
        For I=2 To 3
          Case I
            When 2 : WTAX=[F:PTD]VAT(I-1) : Gosub TRT_BASE
            When 3 : WTAX=[F:PTD]VAT(I-1) : Gosub TRT_BASE
          Endcase
        Next I
        If WCLCFLG1 | WCLCFLG2
          If WCLCFLG1  Raz [F:PTD]CLCAMT1 : Endif
          If WCLCFLG2  Raz [F:PTD]CLCAMT2 : Endif
          For I=2 To 3
            If WCLCFLG(I)=1
              Assign "[F:PTD]CLCAMT"+num$(I) With WCLCAMT(I)
            Endif
          Next I
        Endif
      Endif
      #----- Alimentation des nouveaux champs sous-traitance à partir des anciens -----#
      If dim([F:PTD]MFGITM)>0    [F:PTD]ITMREFORI=[F:PTD]MFGITM    : Endif
      If dim([F:PTD]MFGNUM)>0    [F:PTD]VCRNUMORI=[F:PTD]MFGNUM    : Endif
      If dim([F:PTD]OPENUM)>0    [F:PTD]VCRLINORI=[F:PTD]OPENUM    : Endif
      If dim([F:PTD]OPESPLNUM)>0 [F:PTD]VCRSEQORI=[F:PTD]OPESPLNUM : Endif
      If [F:PTD]VCRNUMORI<>"" & [F:PTD]VCRTYPORI=0
        [F:PTD]VCRTYPORI=10
      Endif
      #----- Alimentation de la province de sortie et du pays expéditeur -----#
      # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
      #If (func AFNC.ACTIV("PTX") & [F:PTD]SATISS="") | [F:PTD]BPOCRY=""
      If (func TRTX3.ACTIV_PTX & [F:PTD]SATISS="") | [F:PTD]BPOCRY=""
        If [F:PTD]POHNUM<>""
          If [F:POH]POHNUM<>[F:PTD]POHNUM
            Read [POH] POH0=[F:PTD]POHNUM : If fstat  Raz [F:POH] : Endif
          Endif
          If [F:POH]BPOSAT<>"" | [F:POH]BPOCRY<>""
            If func TRTX3.ACTIV_PTX & len([F:POH]BPOSAT)<=4 & toupper([F:POH]BPOSAT)=[F:POH]BPOSAT
              [F:PTD]SATISS=[F:POH]BPOSAT
            Endif
            [F:PTD]BPOCRY=[F:POH]BPOCRY
          Else
            #----- Lecture de l'adresse d'expédition si nécessaire -----#
            If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
              Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD : If fstat  Raz [F:BPA] : Endif
            Endif
            #-----
            If func TRTX3.ACTIV_PTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
              [F:PTD]SATISS=[F:BPA]SAT
            Endif
            [F:PTD]BPOCRY=[F:BPA]CRY
          Endif
        Elsif [F:PTH]BETFCY=2 & [F:PTD]SDHNUM<>"" & [F:PTD]LINSTOFCY<>""
          #----- Lecture du site d'expédition si nécessaire -----#
          If [F:FCY]FCY<>[F:PTD]LINSTOFCY
            Read [FCY] FCY0=[F:PTD]LINSTOFCY : If fstat  Raz [F:FCY] : Endif
          Endif
          #----- Lecture de l'adresse d'expédition si nécessaire -----#
          If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:PTD]LINSTOFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
            Read [BPA] BPA0=3;[F:PTD]LINSTOFCY;[F:FCY]BPAADD : If fstat  Raz [F:BPA] : Endif
          Endif
          #-----
          If func TRTX3.ACTIV_PTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
            [F:PTD]SATISS=[F:BPA]SAT
          Endif
          [F:PTD]BPOCRY=[F:BPA]CRY
        Else
          #----- Lecture fournisseur si nécessaire -----#
          If [F:BPS]BPSNUM<>[F:PTH]BPSNUM
            Read [BPS] BPS0=[F:PTH]BPSNUM : If fstat  Raz [F:BPS] : Endif
          Endif
          #----- Lecture de l'adresse d'expédition si nécessaire -----#
          If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PTH]BPSNUM | [F:BPA]BPAADD<>[F:BPS]BPAADD
            Read [BPA] BPA0=1;[F:PTH]BPSNUM;[F:BPS]BPAADD : If fstat  Raz [F:BPA] : Endif
          Endif
          #-----
          If func TRTX3.ACTIV_PTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
            [F:PTD]SATISS=[F:BPA]SAT
          Endif
          [F:PTD]BPOCRY=[F:BPA]CRY
        Endif
      Endif
      #----- Alimentation Type ligne et catégorie de mouvement -----#
      If [F:PTD]LINTYP=0  [F:PTD]LINTYP=1 : Endif
      If [F:PTD]LINCAT=0  [F:PTD]LINCAT=1 : Endif
      #----- Création lignes comptables analytiques -----#
      Look [CAL] CAL0="PTD";0;[F:PTD]PTHNUM;[F:PTD]PTDLIN;0;"";1
      If fstat
        Raz [F:CAL]
        [F:CAL]ABRFIC="PTD"
        [F:CAL]VCRNUM=[F:PTD]PTHNUM
        [F:CAL]VCRLIN=[F:PTD]PTDLIN
        [F:CAL]ANALIG=1
        For I=1 To max(GNBCOA,2)
          [F:CAL]LED(I-1)=GLEDSOC(I)
          [F:CAL]COA(I-1)=GCOA(I)
        Next I
        [F:CAL]ACC(0)=[F:PTD]LINACC
        [F:CAL]ACC(1)=[F:PTD]LINCNA
        For I=1 To max(GNBDIE,GOPTCANA)
          [F:CAL]DIE(I-1)=GDIE(I)
          If evalue("dim([F:PTD]CCE"+num$(I)+")")>0
            [F:CAL]CCE(I-1)=evalue("[F:PTD]CCE"+num$(I))
          Endif
        Next I
        COMPTEUR+=1
        Write [CAL]
        If fstat
          Call ECR_TRACE("File CPTANALIN PTD 0"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
&                        +", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
      #----- Calcul bases et taxes de la ligne de réception -----#
      If WPVVFLG & WPVFFLG
        Gosub MAJ_CALTAX_LIG
        Gosub MAJ_BASTAX_LIG
      Endif
      #----- Cumuls montants et qtés des lignes -----#
      [F:PTH]TOTLINAMT+=[F:PTD]LINAMT
      [F:PTH]TOTLINQTY+=[F:PTD]QTYPUU
      [F:PTH]TOTLINWEU+=[F:PTD]QTYWEU
      [F:PTH]TOTLINVOU+=[F:PTD]QTYVOU
      #-----
      COMPTEUR+=1
      Rewrite [PTD]
      If fstat
        Call ECR_TRACE("File PRECEIPTD"-[F:PTH]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Next
    #-----
    If WPVVFLG & WPVFFLG
      [F:PTH]TOTAMTNOT=[F:PTH]TOTLINAMT
      #----- Calcul taxes des éléments de facturation en pied -----#
      For I=0 To NBFAC-1
        [F:PTH]TOTAMTNOT+=INVLINAMT(I)
        If INVDTAVAT(I)<>""
          #-----
          Raz TAXE : TAXE(1)=INVDTAVAT(I)
          Call CALTAXE(GSOCIETE,[F:PTD]RCPDAT,[F:PTH]VACBPR,[F:PTH]CUR,1,TAXE,1,
&                      INVLINAMT(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          DTAAMTTAX(I)=MONTANT(1)
          DTADEDTAX(I)=MONTDED(1)
          #----- Recherche si taxe déja existante -----# 
          J=find(INVDTAVAT(I),TAX(0..NBTAX-1))
          If J<>0 & PURTYP(J-1)<>1
            K=find(INVDTAVAT(I),TAX(J..NBTAX-1))
            If K<>0
              J+=K
              If PURTYP(J-1)<>1
                K=find(INVDTAVAT(I),TAX(J..NBTAX-1))
                If K<>0 J+=K Else J=0 : Endif
              Endif
            Else
              J=0
            Endif
          Endif
          #----- Nouvelle taxe -----# 
          If J=0
            #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
            If NBTAX>=dim(TAX)  Goto MAJ_SUIT0 : Endif
            #-----
            J=NBTAX
            NBTAX+=1  
            TAX   (J)=INVDTAVAT(I) 
            PURTYP(J)=1
            If [F:TVT]VAT<>INVDTAVAT(I)
              Read [TVT] TVT0=INVDTAVAT(I) : If fstat  Raz [F:TVT] : Endif
            Endif
            VATTYP(J)=[F:TVT]VATTYP
          Else
            J-=1
          Endif
          #----- Mise à jour de la base et des montants de taxe -----#
          BASTAX(J)+=INVLINAMT(I)
          AMTTAX(J)+=DTAAMTTAX(I)
          DEDTAX(J)+=DTADEDTAX(I)
        Endif
$MAJ_SUIT0
      Next I
      #----- Calcul total taxes -----#
      If [F:PTH]VACTYP<>4
        [F:PTH]TOTTAXAMT=sum([L]AMTTAX)
      Else
        [F:PTH]TOTTAXAMT=0
      Endif
      [F:PTH]TOTAMTATI=[F:PTH]TOTAMTNOT+[F:PTH]TOTTAXAMT
      #----- Ecriture du tableau des éléments dans la table PVCRFOOT -----#
      Raz [F:PVF]
      [F:PVF]VCRTYP=6
      [F:PVF]VCRNUM=[F:PTH]PTHNUM
      [F:PVF]PTHNUM=[F:PTH]PTHNUM
      [F:PVF]CREDAT=date$
      [F:PVF]CREUSR=GUSER
      For I=0 To NBFAC-1
        If [F:PFI]PFINUM<>[L]INVDTA(I)
          Read [PFI] PFI0=[L]INVDTA(I)
        Endif
        [F:PVF]INVDTA   =[L]INVDTA(I)
        [F:PVF]INVDTAAMT=[L]INVLINAMT(I)
        [F:PVF]INVLINAMT=[L]INVLINAMT(I)
        [F:PVF]INVDTAFLG=1
        [F:PVF]INVLINFLG=6
        [F:PVF]INVORDFLG=[F:PFI]DACORD
        [F:PVF]DEBCDT   =[L]DEBCDT(I)
        [F:PVF]INVDTAVAT=[L]INVDTAVAT(I)
        [F:PVF]DTAAMTTAX=[L]DTAAMTTAX(I)
        [F:PVF]DTADEDTAX=[L]DTADEDTAX(I)
        [F:PVF]AMTCOD   =2
        [F:PVF]CLCORD   =[F:PFI]CLCORD
        [F:PVF]CLCBAS   =[F:PFI]CLCBAS
        [F:PVF]IND=I+1
        COMPTEUR+=1
        Write [PVF]
        If fstat
          Call ECR_TRACE("File PVCRFOOT 6"-[F:PTH]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Next I
      #----- Ecriture du tableau des taxes dans la table PVCRVAT -----#
      Raz [F:PVV]
      [F:PVV]VCRTYP=6
      [F:PVV]VCRNUM=[F:PTH]PTHNUM
      [F:PVV]PTHNUM=[F:PTH]PTHNUM
      [F:PVV]CREDAT=date$
      [F:PVV]CREUSR=GUSER
      For I=0 To [L]NBTAX-1
        [F:PVV]TAX   =[L]TAX(I)
        [F:PVV]BASTAX=[L]BASTAX(I)
        [F:PVV]AMTTAX=[L]AMTTAX(I)
        [F:PVV]DEDTAX=[L]DEDTAX(I)
        [F:PVV]PURTYP=[L]PURTYP(I)
        [F:PVV]VATTYP=[L]VATTYP(I)
        #----- Chargement des taux de taxe -----#
        Filter [TRA] Where CPY=[F:PTH]CPY & VAT=[F:PVV]TAX & STRDAT<=[F:PTH]RCPDAT
        Read [TRA] TRA0 Last
        If fstat>2
          Filter [TRA] Where CPY="" & VAT=[F:PVV]TAX & STRDAT<=[F:PTH]RCPDAT
          Read [TRA]TRA0 Last
          If fstat>2  Raz [F:TRA] : Endif
        Endif
        [F:PVV]VATRAT=[F:TRA]VATRAT
        [F:PVV]DEDRAT=[F:TRA]DEDRAT
        #-----
        [F:PVV]IND=I+1
        COMPTEUR+=1
        Write [PVV]
        If fstat
          Call ECR_TRACE("File PVCRVAT 6"-[F:PTH]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Next I
    Endif
    #----- Chargement HT et TTC réception en devise société -----#
    Call COURMNT([F:PTH]CUR,GLOCALDEV,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,1,
&                [F:PTH]TOTAMTNOT,[F:PTH]TOTAMTNOTL,[F:PTH]CHGCOE,STAT) From TRTDEV
    If STAT <> 0 Then
      # FGR 12/01/2010 : X3SUIVI61184
      Call ECR_TRACE("     1-File PRECEIPT"-[F:PTH]PTHNUM+", Error ="-num$(STAT),1) From GESECRAN
    Endif
    Call COURMNT([F:PTH]CUR,GLOCALDEV,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,1,
&                [F:PTH]TOTAMTATI,[F:PTH]TOTAMTATIL,[F:PTH]CHGCOE,STAT) From TRTDEV
    If STAT <> 0 Then
      # FGR 12/01/2010 : X3SUIVI61184
      Call ECR_TRACE("     2-File PRECEIPT"-[F:PTH]PTHNUM+", Error ="-num$(STAT),1) From GESECRAN
    Endif
    #-----
    COMPTEUR+=1
    Rewrite [PTH]
    If fstat
      Call ECR_TRACE("File PRECEIPT"-[F:PTH]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    #-----
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PTH]PTHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PTH : Endif
Close Local File [PTH], [PTD], [CAL], [BPR], [BPS], [ITM], [POH], [BPA], [FCY],
&                [ADI], [PFI], [TVC], [TVT], [TRA], [TCU], [TCH], [TUN], [TCO],
&                [PRS], [PVV], [PVF]
If [F:ADS]MODULE(1)=2  Close Local File [GCM] : Endif
Call ECR_TIME("DOSMAJ30 Purchase Receipt Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#########################################################################
# MAJ_CALTAX_LIG : S/P de calcul des bases et des taxes    MBT 03/12/07 #
#                     de la ligne de réception                          #
#########################################################################
$MAJ_CALTAX_LIG
#-----
For I=1 To 3
  Case I
    When 1 : TAXE(1)=[F:PTD]VAT(0) : WCLCAMT(1)=[F:PTD]CLCAMT1
    When 2 : TAXE(2)=[F:PTD]VAT(1) : WCLCAMT(2)=[F:PTD]CLCAMT2
    When 3 : TAXE(3)=[F:PTD]VAT(2) : WCLCAMT(3)=[F:PTD]CLCAMT3
  Endcase
Next I
#-----
Call CALTAXE2(GSOCIETE,[F:PTD]RCPDAT,[F:PTH]VACBPR,[F:PTH]CUR,3,TAXE,1,[F:PTD]LINAMT,
&             WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#-----
For I=1 To 3
  Case I
    When 1
      [F:PTD]BASTAXLIN1=[F:PTD]LINAMT
      [F:PTD]AMTTAXLIN1=MONTANT(1)
      [F:PTD]DEDTAXLIN1=MONTDED(1)
    When 2
      If [F:PTD]VAT(1)=""
        Raz [F:PTD]AMTTAXLIN2, [F:PTD]DEDTAXLIN2
      Else
        [F:PTD]AMTTAXLIN2=MONTANT(2)
        [F:PTD]DEDTAXLIN2=MONTDED(2)
        Read [TVT] TVT0=[F:PTD]VAT(1) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [F:PTD]BASTAXLIN1+=[F:PTD]AMTTAXLIN2 : Endif
      Endif
    When 3
      If [F:PTD]VAT(2)=""
        Raz [F:PTD]AMTTAXLIN3, [F:PTD]DEDTAXLIN3
      Else
        [F:PTD]AMTTAXLIN3=MONTANT(3)
        [F:PTD]DEDTAXLIN3=MONTDED(3)
        Read [TVT] TVT0=[F:PTD]VAT(2) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [F:PTD]BASTAXLIN1+=[F:PTD]AMTTAXLIN3 : Endif
      Endif
  Endcase
Next I
#-----
If [F:PTH]VACTYP<>4
  [F:PTD]LINATIAMT=[F:PTD]LINAMT
  For I=1 To 3
    Case I
      When 1 : [F:PTD]LINATIAMT+=[F:PTD]AMTTAXLIN1
      When 2 : [F:PTD]LINATIAMT+=[F:PTD]AMTTAXLIN2
      When 3 : [F:PTD]LINATIAMT+=[F:PTD]AMTTAXLIN3
    Endcase
  Next I
Else
  [F:PTD]LINATIAMT=[F:PTD]LINAMT
Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
For I=1 To 9
  If evalue("dim([F:PTD]DISCRGVAL"+num$(I)+")")>0
    If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0
      #----- C'est un montant -----#
      If GDISCRGTYP(I-1)=1
        If GCLCRUL(I-1)=1 : # Par unité
          BASE=arr(evalue("[F:PTD]DISCRGVAL"+num$(I))*[F:PTD]QTYUOM,WRND)
        Else              : # Par ligne
          BASE=evalue("[F:PTD]DISCRGVAL"+num$(I))
        Endif
      #----- C'est un pourcentage -----#
      Else
        BASE=arr([F:PTD]LINAMT*evalue("[F:PTD]DISCRGVAL"+num$(I))/100,WRND)
      Endif
      #----- Inversion du montant si minoration -----#
      If GINCDCR(I-1)=2  BASE=-BASE : Endif
      #----- Màj base et mt taxe ligne si taux produit -----#
      If [F:PTH]INVDTAVAT1(I-1)=""
        Raz TAXE : TAXE(1)=[F:PTD]VAT(0)
        If BASE<>0
          Call CALTAXE(GSOCIETE,[F:PTD]RCPDAT,[F:PTH]VACBPR,[F:PTH]CUR,1,TAXE,1,
&                      BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          [F:PTD]BASTAXLIN1+=BASE
          [F:PTD]AMTTAXLIN1+=MONTANT(1)
          [F:PTD]DEDTAXLIN1+=MONTDED(1)
        Endif
      Endif
      #----- Recherche si élément déja existant -----# 
      J=find(GINVDTALIN(I-1),INVDTA(0..NBFAC-1))
      If J=0
        #----- Le nombre maximum d'élément est dépassé ! (Impossible en théorie) ------#
        If NBFAC>=dim(INVDTA)  Goto MAJ_SUIT1 : Endif
        #-----
        J=NBFAC
        NBFAC+=1
        INVDTA   (J)=GINVDTALIN       (I-1)
        DEBCDT   (J)=GINCDCR          (I-1)
        INVDTAVAT(J)=[F:PTH]INVDTAVAT1(I-1)
      Else
        J-=1
      Endif
      INVLINAMT(J)+=BASE
    Endif
  Endif
$MAJ_SUIT1
Next I
#-----
Return


#########################################################################
# MAJ_BASTAX_LIG : S/P de mise à jour des bases et         MBT 03/12/07 #
#                     montants de taxe à partir des                     #
#                     valeurs de la ligne de réception                  #
#########################################################################
$MAJ_BASTAX_LIG 
#----- Mise à jour des bases et des montants de taxe -----#
For I=1 To 3
  Case I
    When 1 : WTAX   =[F:PTD]VAT(0)     : WBASE  =[F:PTD]BASTAXLIN1
             WAMTTAX=[F:PTD]AMTTAXLIN1 : WDEDTAX=[F:PTD]DEDTAXLIN1
    When 2 : WTAX   =[F:PTD]VAT(1)     : WBASE  =[F:PTD]LINAMT
             WAMTTAX=[F:PTD]AMTTAXLIN2 : WDEDTAX=[F:PTD]DEDTAXLIN2
    When 3 : WTAX   =[F:PTD]VAT(2)     : WBASE  =[F:PTD]LINAMT
             WAMTTAX=[F:PTD]AMTTAXLIN3 : WDEDTAX=[F:PTD]DEDTAXLIN3
  Endcase
  If WTAX<>""
    If [F:TVT]VAT<>WTAX
      Read [TVT] TVT0=WTAX : If fstat  Raz [F:TVT] : Endif
    Endif
    If I>1 & [F:TVT]VATBAS>1
      WBASE=evalue("[F:PTD]CLCAMT"+num$(I))
    Endif
    #----- Recherche si taxe déja existante -----# 
    J=find(WTAX,TAX(0..NBTAX-1))
    If J<>0 & PURTYP(J-1)<>[F:PTD]LINPURTYP
      K=find(WTAX,TAX(J..NBTAX-1))
      If K<>0
        J+=K
        If PURTYP(J-1)<>[F:PTD]LINPURTYP
          K=find(WTAX,TAX(J..NBTAX-1))
          If K<>0 J+=K Else J=0 : Endif
        Endif
      Else
        J=0
      Endif
    Endif
    #----- Nouvelle taxe -----# 
    If J=0
      #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
      If NBTAX>=dim(TAX)  Goto MAJ_SUIT2 : Endif
      #-----
      J=NBTAX
      NBTAX+=1  
      TAX   (J)=WTAX 
      PURTYP(J)=[F:PTD]LINPURTYP
      VATTYP(J)=[F:TVT]VATTYP
    Else
      J-=1
    Endif
    #----- Mise à jour de la base et des montants de taxe -----#
    BASTAX(J)+=WBASE
    AMTTAX(J)+=WAMTTAX
    DEDTAX(J)+=WDEDTAX
  Endif
$MAJ_SUIT2
Next I
Return


##################################
# Traitement des bases spéciales #
##################################
$TRT_BASE
If [F:TVT]VAT<>WTAX
  Read [TVT] TVT0=WTAX : If fstat  Raz [F:TVT] : Endif
Endif
If [F:TVT]VATBAS=2 & WCLCAMT1<>0
  WCLCFLG1=1 : WCLCAMT(I)=WCLCAMT1 : WCLCFLG(I)=1
Endif
If [F:TVT]VATBAS=3 & WCLCAMT2<>0
  WCLCFLG2=1 : WCLCAMT(I)=WCLCAMT2 : WCLCFLG(I)=1
Endif
Return
