#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SITINTEGR 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone FIC
mkstat = 0
zoncou = "FIC"
indice = 0
If varmode([M]FIC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FIC" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]FIC,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FIC" : GZNUM = 15179 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_FIC([M]FIC) From SITSIG
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FIC" : GZNUM = 15179 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone OPT
mkstat = 0
zoncou = "OPT"
indice = 0
IMPENT = [M]OPT
If varinit([M]OPT,indice)=0
 IMPENT = 1
Endif
If varmode([M]OPT,indice)=0
 [M]OPT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPT(indice)
 Endif
Endif
[M]OPT = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SITINTEGR"
Return

