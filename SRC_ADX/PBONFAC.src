#########################################################################
# PBONFAC : Impression du bon de contrôle facture achats   MBT 08/06/99 #
# --------------------------------------------------------------------- #
# Chargement du paramètre euro                                          #
#########################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

#########################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR 
Variable Char    PARAMETRE()()

Local Integer I, J
Local Char    PARAM(30), VALEUR(30)

For I=1 To NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
   #[L]VALEUR = right$([L]PARAMETRE(I),J+1)
    Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
    Case [L]PARAM
      When "euro"    : [L]PARAMETRE(I) = "euro="    + GEURO                         # euro    : provenant de la globale GEURO
      When "gtypgen" : [L]PARAMETRE(I) = "gtypgen=" + num$(max(0 , [V]GTYPGEN - 1)) # gtypgen : Indice du référentiel social de la comptabilité pour CPTANALIN (si non renseigné, on prend le premier)
    Endcase
  Endif
Next I

End
