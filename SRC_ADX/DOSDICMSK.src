#<AdxTL>@(#)5.0.0.0 $Revision$
##############################################################
# DOSDICMSK Remplissage du dico des écrans
##############################################################
$DICMSK
Call ECR_TIME(mess(15,125,1)-mess(17,125,1)) From DOSSUB
# MAJ dictionnaire - Ecrans
Local File =GDOSREF+".AMSK"    [AMK]
&         ,=GDOSREF+".AMSKZON" [AMZ]
&         ,=GDOSREF+".AMSKACT" [AMA]
&         ,=GDOSREF+".AMSKPAR" [AMP]
Local File =[F:ADS]DOSSIER+".AMSK"    [DAMK]
&         ,=[F:ADS]DOSSIER+".AMSKZON" [DAMZ]
&         ,=[F:ADS]DOSSIER+".AMSKZON" [DAZ2]
&         ,=[F:ADS]DOSSIER+".AMSKACT" [DAMA]
&         ,=[F:ADS]DOSSIER+".AMSKPAR" [DAMP]
&         ,=[F:ADS]DOSSIER+".AMSK"    [DAM2]
&         ,=[F:ADS]DOSSIER+".ACTIV"   [DACV]
&         ,=[F:ADS]DOSSIER+".ACTION"  [DACT]

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(17,125,1),"") From GESECRAN
Endif
GNBMSK = 0

## Effacement anciens écrans

If !GCRE
 Trbegin [DAMK] , [DAMZ] , [DAMA] , [DAMP]
  For [DAMK]CODMSK Where CODMSK<GXX & left$(CODMSK,1)<>"W"
   Call SPEC([F:DAMK]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [AMK]CODMSK = [F:DAMK]CODMSK
    If fstat
     Call EFFACE([F:DAMK]CODMSK)
    Endif
   Endif
  Next
 Commit
Endif

## Mise à jour

Filter [AMK] Where CODMSK<GXX & left$(CODMSK,1)<>"W"
Read [AMK]CODMSK First
While fstat<=2
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(17,125,1),[F:AMK]CODMSK) From GESECRAN
 Endif
 ACTIV = 0
 Trbegin [DAMK] , [DAMZ] , [DAMA] , [DAMP]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DAMK]CODMSK = [F:AMK]CODMSK
  If !fstat
   OLD = 1
   Call SPEC([F:DAMK]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:AMK]CODACT,[F:AMK]MODULE,NEWREC) From DOSSUB
  If !SPEC

   If OLD & !NEWREC : # On le vire

    Call EFFACE([F:AMK]CODMSK)

   Elsif NEWREC & !OLD : # C'est un nouvel et bel écran

    Raz [F:DAMK]
    RWO = 1
    [F:DAMK] = [F:AMK]
    [F:DAMK]UPDFLG = 1
    [F:DAMK]CREDAT = date$
    [F:DAMK]CREUSR = GUSER
    If dim([F:DAMK]CRETIM)>0 : [F:DAMK]CRETIM = time : Endif
    If [F:DAMK]MDL<>2 : GNBMSK += 1 : Endif
    Write [DAMK]
    If fstat : Call ERREUR("AMSK"-[F:DAMK]CODMSK,1) From DOSDIC : Endif
    For [AMZ]CODE Where CODMSK=[F:AMK]CODMSK
     [F:DAMZ] = [F:AMZ]
     Write [DAMZ]
     If fstat : Call ERREUR("AMSKZON"-[F:DAMZ]CODMSK-[F:DAMZ]CODZON,1) From DOSDIC : Endif
    Next
    For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK
     [F:DAMA] = [F:AMA]
     Write [DAMA]
     If fstat : Call ERREUR("AMSKACT"-[F:DAMA]CODAFF,1) From DOSDIC : Endif
    Next
    For [AMP]CODPAR Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK
     [F:DAMP] = [F:AMP]
     Write [DAMP]
     If fstat : Call ERREUR("AMSKPAR"-[F:DAMP]CODAFF,1) From DOSDIC : Endif
    Next

   Elsif NEWREC & OLD : # Ecran modifié ??

    DIFF = 0

    ## Comparaison en-tête

    If [F:AMK]ABRMSK   <> [F:DAMK]ABRMSK    : DIFF = 1 : Endif
    If [F:AMK]CODACT   <> [F:DAMK]CODACT    : DIFF = 1 : Endif
    If [F:AMK]INTMSK   <> [F:DAMK]INTMSK    : DIFF = 1 : Endif
    If [F:AMK]MODULE   <> [F:DAMK]MODULE    : DIFF = 1 : Endif
    If [F:AMK]MDL      <> [F:DAMK]MDL       : DIFF = 1 : Endif
    If [F:AMK]NBBLOC   <> [F:DAMK]NBBLOC    : DIFF = 1 : Endif
    If [F:AMK]NBFIC    <> [F:DAMK]NBFIC     : DIFF = 1 : Endif
    If [F:AMK]TRTSPE   <> [F:DAMK]TRTSPE    : DIFF = 1 : Endif
    If [F:AMK]TRTSPV   <> [F:DAMK]TRTSPV    : DIFF = 1 : Endif
    If [F:AMK]TRTSTD   <> [F:DAMK]TRTSTD    : DIFF = 1 : Endif
    If [F:AMK]ABRMSK   <> [F:DAMK]ABRMSK    : DIFF = 1 : Endif
    If [F:AMK]TYPMSK   <> [F:DAMK]TYPMSK    : DIFF = 1 : Endif

    SPELIG = 0
    #If GADONIX<>2
    # SPELIG = 1
    If [F:AMK]NBRLIG<[F:DAMK]NBRLIG : # Si le nb de ligne de l'écran de référence est inférieur à celui validé
     For B=0 To min([F:DAMK]NBLIGT-1,dim([F:DAMK]ACTBLOC)-1)
      If [F:DAMK]ACTBLOC(B)<>""
       Call SPEC([F:DAMK]ACTBLOC(B),SPELIG) From DOSSUB
       If SPELIG : Break : Endif
      Endif
     Next B
     If !SPELIG
      For [F:DAMZ]CODE Where CODMSK=[F:DAMK]CODMSK
       If [F:DAMZ]CODACT<>""
        Call SPEC([F:DAMZ]CODACT,SPELIG) From DOSSUB
        If SPELIG : Break : Endif
       Endif
      Next AMZ
     Endif
    Endif
    If !SPELIG : # Si pas de spé sur l'écran
     NEWLIG = [F:AMK]NBRLIG
     If [F:AMK]NBRLIG<>[F:DAMK]NBRLIG
      DIFF = 1
     Endif
    Elsif [F:AMK]NBRLIG>[F:DAMK]NBRLIG : # Si le nb de ligne de l'écran de référence est supérieur à celui validé
     NEWLIG = [F:AMK]NBRLIG
     DIFF = 1
    Else
     NEWLIG = [F:DAMK]NBRLIG : # Le nb de ligne reste inchangé
    Endif

    If [F:AMK]NBRCOL    > [F:DAMK]NBRCOL    : DIFF = 1 : Endif
    If !DIFF : Call TXT([F:AMK]INTMSK,DIFF) From DOSSUB : Endif

    ## Comparaison des blocs

    If !DIFF
     For B=0 To [F:AMK]NBBLOC-1
      If !find([F:DAMK]ACTBLOC(B),GSPE(1..GNBSPE))
       If [F:AMK]TYPBLOC(B)    <> [F:DAMK]TYPBLOC(B)     : DIFF = 1 : Endif
       If [F:AMK]TITBLOC(B)    <> [F:DAMK]TITBLOC(B)     : DIFF = 1 : Endif
       If [F:AMK]RANG   (B)    <> [F:DAMK]RANG   (B)     : DIFF = 1 : Endif
       If [F:AMK]LNGLIB (B)    <> [F:DAMK]LNGLIB (B)     : DIFF = 1 : Endif
       If [F:AMK]NBLIGT (B)    <> [F:DAMK]NBLIGT (B)     : DIFF = 1 : Endif
       If [F:AMK]OPTION (B)    <> [F:DAMK]OPTION (B)     : DIFF = 1 : Endif
       If [F:AMK]BASPAG (B)    <> [F:DAMK]BASPAG (B)     : DIFF = 1 : Endif
       If [F:AMK]ACTBLOC(B)    <> [F:DAMK]ACTBLOC(B)     : DIFF = 1 : Endif
       If [F:AMK]POSBLOC(B)    <> [F:DAMK]POSBLOC(B)     : DIFF = 1 : Endif
       If [F:AMK]COLBLOC(B)    <> [F:DAMK]COLBLOC(B)     : DIFF = 1 : Endif
       If [F:AMK]LINBLOC(B)    <> [F:DAMK]LINBLOC(B)     : DIFF = 1 : Endif
       If [F:AMK]HTBLOC (B)    <> [F:DAMK]HTBLOC (B)     : DIFF = 1 : Endif
       If [F:AMK]LGBLOC (B)    <> [F:DAMK]LGBLOC (B)     : DIFF = 1 : Endif
       If [F:AMK]DETBLC (B)    <> [F:DAMK]DETBLC (B)     : DIFF = 1 : Endif
       If [F:AMK]BLOCACT1(B)   <> [F:DAMK]BLOCACT1(B)    : DIFF = 1 : Endif
       If [F:AMK]BLOCTYPT(B)   <> [F:DAMK]BLOCTYPT(B)    : DIFF = 1 : Endif
       If [F:AMK]BLOCTYPG(B)   <> [F:DAMK]BLOCTYPG(B)    : DIFF = 1 : Endif
       If [F:AMK]BLOCPOSG(B)   <> [F:DAMK]BLOCPOSG(B)    : DIFF = 1 : Endif
       If [F:AMK]BLOCGDEF(B)   <> [F:DAMK]BLOCGDEF(B)    : DIFF = 1 : Endif
       If [F:AMK]BLOCAFFD(B)   <> [F:DAMK]BLOCAFFD(B)    : DIFF = 1 : Endif
       If [F:AMK]BLOCREPD(B)   <> [F:DAMK]BLOCREPD(B)    : DIFF = 1 : Endif
       If B<=dim([F:DAMK]BLOCVIEW)-1 & B<=dim([F:AMK]BLOCVIEW)-1
        If [F:AMK]BLOCVIEW(B)   <> [F:DAMK]BLOCVIEW(B)    : DIFF = 1 : Endif
       Endif
       If [F:AMK]BLOCLIEN1(B)  <> [F:DAMK]BLOCLIEN1(B)   : DIFF = 1 : Endif
       If [F:AMK]BLOCLIEN2(B)  <> [F:DAMK]BLOCLIEN2(B)   : DIFF = 1 : Endif
       If [F:AMK]BLOCLIEN3(B)  <> [F:DAMK]BLOCLIEN3(B)   : DIFF = 1 : Endif
       If [F:AMK]BLOCPAR1(B)   <> [F:DAMK]BLOCPAR1(B)    : DIFF = 1 : Endif
       If [F:AMK]BLOCPAR2(B)   <> [F:DAMK]BLOCPAR2(B)    : DIFF = 1 : Endif
       If !DIFF : Call TXT([F:AMK]TITBLOC(B),DIFF) From DOSSUB : Endif
       If [F:AMK]INTBLOC(B)    <> [F:DAMK]INTBLOC(B)     : DIFF = 1 : Endif
      Endif
      Call DIFFACT([F:ADS]DOSSIER,[F:AMK]ACTBLOC(B),ACTIV) From DOSSUB
     Next B
    Endif

    ## Comparaison des fichiers de référence

    If !DIFF
     For B=0 To [F:AMK]NBFIC-1
      If [F:AMK]FICREF(B)     <> [F:DAMK]FICREF(B)      : DIFF = 1 : Endif
     Next B
    Endif

    #X3PLAT-2092
    [F:DAM2] = [F:DAMK]
    [F:DAMK] = [F:AMK]
    Gosub TRT_BLC

    ## Comparaison et mise à jour des zones

    NBZONE = 0
    For [AMZ]CODE Where CODMSK=[F:AMK]CODMSK
     NBZONE += 1
     TBZONE(NBZONE) = [F:AMZ]CODZON
     Read [DAMZ]CODE = [F:AMK]CODMSK;[F:AMZ]CODZON

     If fstat

      # Nouvelle zone, on la créé si le bloc n'est pas spécifique

      If !find([F:DAMK]ACTBLOC([F:AMZ]NUMBLOC-1),GSPE(1..GNBSPE))
       DIFF = 1
       [F:DAMZ] = [F:AMZ]
       #X3PLAT-2092
       If dim([F:AMZ]RANG)>0 & [F:AMZ]RANG>0
        [F:DAMZ]NUMBLOC=find([F:AMZ]RANG,BLCRANG(1..NBBLC))
       Endif
       If dim([F:DAMZ]RANG)>0 & [F:DAMZ]RANG=0 & [F:DAMZ]NUMBLOC<>0
        [F:DAMZ]RANG=BLCRANG([F:DAMZ]NUMBLOC)
       Endif
       Write [DAMZ]
       If fstat : Call ERREUR("AMSKZON"-[F:DAMZ]CODMSK-[F:DAMZ]CODZON,1) From DOSDIC : Endif
       Gosub CREACT
      Endif

     Elsif [F:DAMZ]NUMBLOC=0 or (!find([F:DAMZ]CODACT,GSPE(1..GNBSPE))
&        & !find([F:DAMK]ACTBLOC([F:DAMZ]NUMBLOC-1),GSPE(1..GNBSPE)))

      # Ancienne zone existante et non spécifique, on compare

      RW = 0
      Call DIFFACT([F:ADS]DOSSIER,[F:AMZ]CODACT,ACTIV) From DOSSUB
      If dim([F:AMZ]RANG)>0
      If [F:AMZ]RANG     <> [F:DAMZ]RANG         : RW = 1 : Endif : #X3PLAT-2092
      Endif
      If [F:AMZ]CODACT   <> [F:DAMZ]CODACT       : RW = 1 : Endif
      If [F:AMZ]CODTYP   <> [F:DAMZ]CODTYP       : RW = 1 : Endif
      If [F:AMZ]CONSAI   <> [F:DAMZ]CONSAI       : RW = 1 : Endif
      If [F:AMZ]DIME     <> [F:DAMZ]DIME         : RW = 1 : Endif
      If [F:AMZ]INTIT    <> [F:DAMZ]INTIT        : RW = 1 : Endif
      If [F:AMZ]INTEVAL  <> [F:DAMZ]INTEVAL      : RW = 1 : Endif
      If [F:AMZ]LIEN     <> [F:DAMZ]LIEN         : RW = 1 : Endif
      If [F:AMZ]LONG     <> [F:DAMZ]LONG         : RW = 1 : Endif
      If [F:AMZ]NOLIB    <> [F:DAMZ]NOLIB        : RW = 1 : Endif
      If [F:AMZ]NOZONE   <> [F:DAMZ]NOZONE       : RW = 1 : Endif
      If [F:AMZ]NUMBLOC  <> [F:DAMZ]NUMBLOC      : RW = 1 : Endif
      If [F:AMZ]PDSZON   <> [F:DAMZ]PDSZON       : RW = 1 : Endif
      If [F:AMZ]OBLIG    <> [F:DAMZ]OBLIG        : RW = 1 : Endif
      If [F:AMZ]OPTFOR   <> [F:DAMZ]OPTFOR       : RW = 1 : Endif
      If [F:AMZ]OPTLNG   <> [F:DAMZ]OPTLNG       : RW = 1 : Endif
      If [F:AMZ]OPTOBJ   <> [F:DAMZ]OPTOBJ       : RW = 1 : Endif
      If [F:AMZ]OPTSAI   <> [F:DAMZ]OPTSAI       : RW = 1 : Endif
      If [F:AMZ]SAIAFF   <> [F:DAMZ]SAIAFF       : RW = 1 : Endif
      If [F:AMZ]TUNNEL   <> [F:DAMZ]TUNNEL       : RW = 1 : Endif
      If [F:AMZ]TYPGRAPH <> [F:DAMZ]TYPGRAPH     : RW = 1 : Endif
      If [F:AMZ]VAL1     <> [F:DAMZ]VAL1         : RW = 1 : Endif
      If [F:AMZ]VAL2     <> [F:DAMZ]VAL2         : RW = 1 : Endif
      If [F:AMZ]VAL3     <> [F:DAMZ]VAL3         : RW = 1 : Endif
      If [F:AMZ]VALDEF   <> [F:DAMZ]VALDEF       : RW = 1 : Endif
      If [F:AMZ]MODE     <> [F:DAMZ]MODE         : RW = 1 : Endif
      If [F:AMZ]CHPARG   <> [F:DAMZ]CHPARG       : RW = 1 : Endif
      If [F:AMZ]CHREPR   <> [F:DAMZ]CHREPR       : RW = 1 : Endif
      If [F:AMZ]TRANSM   <> [F:DAMZ]TRANSM       : RW = 1 : Endif
      If !RW : Call TXT([F:AMZ]INTIT,RW) From DOSSUB : Endif
      ACCES = [F:DAMZ]CODACC           : # On conserve le code d'accès
      If left$([F:DAMZ]CODACC,1)="/"
       ACCES = [F:AMZ]CODACC : RW = 1 : # Sauf s'il commence "/", on le vire
      Endif
      If RW
       DIFF  = 1
       [F:DAZ2] = [DAMZ]
       [F:DAMZ] = [F:AMZ]
       [F:DAMZ]CODACC = ACCES
       If [F:DAZ2]CODCTL<>""  : [F:DAMZ]CODCTL  = [F:DAZ2]CODCTL  : Endif : # Table de contrôle
       If [F:DAZ2]STYZON<>""  : [F:DAMZ]STYZON  = [F:DAZ2]STYZON  : Endif : # Style valeur
       If [F:DAZ2]INTSTYL<>"" : [F:DAMZ]INTSTYL = [F:DAZ2]INTSTYL : Endif : # Style intitulé
       If [F:DAZ2]STYCND<>""  : [F:DAMZ]STYCND  = [F:DAZ2]STYCND  : Endif : # Style conditionnel
       #X3PLAT-2092
       If dim([F:AMZ]RANG)>0 & [F:AMZ]RANG>0
        [F:DAMZ]NUMBLOC=find([F:AMZ]RANG,BLCRANG(1..NBBLC))
       Endif
       If dim([F:DAMZ]RANG)>0 & [F:DAMZ]RANG=0 & [F:DAMZ]NUMBLOC<>0
        [F:DAMZ]RANG=BLCRANG([F:DAMZ]NUMBLOC)
       Endif
       Rewrite [DAMZ]
       If fstat : Call ERREUR("AMSKZON"-[F:DAMZ]CODMSK-[F:DAMZ]CODZON,2) From DOSDIC : Endif
      Endif

      ## Lecture des anciennes et nouvelles actions

      MODACT = 0
      NBACT  = 0
      For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK & CODZON=[F:AMZ]CODZON
       NBACT += 1
       TBACT(NBACT)  = [F:AMA]ACTION
       TBTYP(NBACT)  = [F:AMA]TYPACT
       TBINT(NBACT)  = [F:AMA]INTITACT
       TBNUM(NBACT)  = [F:AMA]NOACT
       TBAAA(NBACT)  = num$([F:AMA]TYPACT)-[F:AMA]ACTION
       TBWEB(NBACT)  = [F:AMA]EXEACT
       TBDIS(NBACT)  = [F:AMA]DISACT
      Next AMA
      ONBACT = 0
      For [DAMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK & CODZON=[F:AMZ]CODZON
       If find(num$([F:DAMA]TYPACT)-[F:DAMA]ACTION,OTBAAA(1..ONBACT)) : # Détection des doublons
        MODACT = 1
       Else
        ONBACT += 1
        OTBACT(ONBACT) = [F:DAMA]ACTION
        OTBTYP(ONBACT) = [F:DAMA]TYPACT
        OTBINT(ONBACT) = [F:DAMA]INTITACT
        OTBNUM(ONBACT) = [F:DAMA]NOACT
        OTBAAA(ONBACT) = num$([F:DAMA]TYPACT)-[F:DAMA]ACTION
        OTBWEB(ONBACT) = [F:DAMA]EXEACT
        OTBDIS(ONBACT) = [F:DAMA]DISACT
        Read [DACT]ACTION=[F:DAMA]ACTION
        Call SPEC([F:DACT]CODACT,OTBVER(ONBACT)) From DOSSUB
       Endif
      Next DAMA

      # Détection des actions supprimées

      NUMACT = 0
      For IACT=1 To ONBACT
       If OTBACT(IACT)="SPE" | (!VERT & OTBACT(IACT)="SPV") | OTBVER(IACT)<>0
        NUMACT = max(NUMACT,OTBNUM(IACT))
       Elsif !find(OTBAAA(IACT),TBAAA(1..NBACT))
        MODACT = 1 : DIFF = 1
       Endif
      Next IACT

      # Détection des actions modifiées

      For IACT=1 To ONBACT
       If !(OTBACT(IACT)="SPE" | (!VERT & OTBACT(IACT)="SPV") | OTBVER(IACT)<>0)
        B = find(OTBAAA(IACT),TBAAA(1..NBACT))
        If B
         If OTBINT(IACT)<>TBINT(B)   : MODACT = 1 : DIFF = 1 : Endif
         If OTBWEB(IACT)<>TBWEB(B)   : MODACT = 1 : DIFF = 1 : Endif
         If OTBDIS(IACT)<>TBDIS(B)   : MODACT = 1 : DIFF = 1 : Endif
         If !DIFF
          Call TXT(OTBINT(IACT),DIFF) From DOSSUB
          If DIFF : MODACT = 1 : Endif
         Endif
        Endif
       Endif
      Next IACT

      # Détection nouvelles actions

      For IACT=1 To NBACT
       If !find(TBAAA(IACT),OTBAAA(1..ONBACT))
        MODACT = 1 : DIFF = 1
       Endif
      Next IACT

      # On traite globalement la modif des actions

      If MODACT

       # On vire tout ce qui n'est pas spécifique

       Delete [DAMA] Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK & CODZON=[F:AMZ]CODZON

       # Fusion des 2 tableaux

       For IACT=1 To ONBACT
        If OTBACT(IACT)="SPE" | (!VERT & OTBACT(IACT)="SPV") | OTBVER(IACT)<>0
         # On vérifie que l'action n'existe pas
         JACT = 0
         For KACT=1 To NBACT
          If TBTYP(KACT)=OTBTYP(IACT) & TBACT(KACT)=OTBACT(IACT)
           JACT = KACT : Break
          Endif
         Next KACT
         If JACT=0
          # On essaye de trouver l'action STD qui était avant
          If IACT>1 & OTBTYP(IACT-1)=OTBTYP(IACT)
           For KACT=1 To NBACT
            If TBTYP(KACT)=OTBTYP(IACT) & TBACT(KACT)=OTBACT(IACT-1)
             JACT = KACT+1 : Break
            Endif
           Next KACT
          Endif
          # Sinon on l'insère en première position
          If JACT=0
           For KACT=1 To NBACT
            If TBTYP(KACT)>=OTBTYP(IACT)
             JACT = KACT : Break
            Endif
           Next KACT
           If JACT=0 : JACT = NBACT+1 : Endif
          Endif
          If !find(OTBAAA(IACT),TBAAA(1..NBACT))
           NBACT += 1
           Insa JACT,1,NBACT TBACT,TBTYP,TBINT,TBNUM,TBAAA,TBWEB,TBDIS
           TBACT(JACT)  = OTBACT(IACT)
           TBTYP(JACT)  = OTBTYP(IACT)
           TBINT(JACT)  = OTBINT(IACT)
           TBNUM(JACT)  = OTBNUM(IACT)
           TBAAA(JACT)  = OTBAAA(IACT)
           TBWEB(JACT)  = OTBWEB(IACT)
           TBDIS(JACT)  = OTBDIS(IACT)
          Endif
         Endif
        Endif
       Next IACT

       # Et on recréé tout

       NUMACT = 0
       For IACT=1 To NBACT
        NUMACT += 1
        Raz [F:DAMA]
        [F:DAMA]TYPAFF   = 1
        [F:DAMA]CODAFF   = [F:AMK]CODMSK
        [F:DAMA]CODZON   = [F:AMZ]CODZON
        [F:DAMA]TYPACT   = TBTYP(IACT)
        [F:DAMA]ACTION   = TBACT(IACT)
        [F:DAMA]EXEACT   = TBWEB(IACT)
        [F:DAMA]DISACT   = TBDIS(IACT)
        [F:DAMA]INTITACT = TBINT(IACT)
        [F:DAMA]NOACT    = NUMACT
        Write [DAMA]
       Next IACT
      Endif

      # Pour les paramètres on créé les nouveaux

      For [AMP]CODPAR Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK & CODZON=[F:AMZ]CODZON
       Read [DAMP]CODPAR = 1;[F:AMK]CODMSK;[F:AMZ]CODZON;[F:AMP]CODPAR
       If fstat
        DIFF = 1
        [F:DAMP] = [F:AMP]
        Write [DAMP]
        If fstat : Call ERREUR("AMSKPAR"-[F:DAMP]CODAFF-[F:DAMP]CODZON-[F:DAMP]CODPAR,1) From DOSDIC : Endif
       Else
        RW = 0
        If [F:AMP]VALPAR   <> [F:DAMP]VALPAR   : RW = 57 : Endif
        If RW
         DIFF = RW
         [F:DAMP] = [F:AMP]
         Rewrite [DAMP]
         If fstat : Call ERREUR("AMSKPAR"-[F:DAMP]CODAFF-[F:DAMP]CODZON-[F:DAMP]CODPAR,2) From DOSDIC : Endif
        Endif
       Endif
      Next AMP

     Endif : # (!SPE)
    Next AMZ

    # On vire les zones en trop

    For [DAMZ]CODZON Where CODMSK=[F:AMK]CODMSK
     If [F:DAMZ]NUMBLOC=0 or (!find([F:DAMZ]CODACT,GSPE(1..GNBSPE))
&     & !find([F:DAMK]ACTBLOC([F:DAMZ]NUMBLOC-1),GSPE(1..GNBSPE)))
      If !find([F:DAMZ]CODZON,TBZONE(1..NBZONE))
       DIFF = 1
       Delete [DAMA] Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK & CODZON=[F:DAMZ]CODZON
       If fstat=1 : Call ERREUR("AMSKACT"-[F:AMK]CODMSK-[F:DAMZ]CODZON,3) From DOSDIC : Endif
       Delete [DAMP] Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK & CODZON=[F:DAMZ]CODZON
       If fstat=1 : Call ERREUR("AMSKPAR"-[F:AMK]CODMSK-[F:DAMZ]CODZON,3) From DOSDIC : Endif
       Delete [DAMZ]
       If fstat=1 : Call ERREUR("AMSKZON"-[F:DAMZ]CODMSK-[F:DAMZ]CODZON,3) From DOSDIC : Endif
      Endif
     Endif
     Call DIFFACT([F:ADS]DOSSIER,[F:DAMZ]CODACT,ACTIV) From DOSSUB
    Next DAMZ

    # Réécriture de l'en-tête

    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff écran"-[F:AMK]CODMSK-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
#     [F:DAM2] = [F:DAMK]
#     [F:DAMK] = [F:AMK]
     If [F:DAMK]MDL<>2 : GNBMSK += 1 : Endif
#     For B=0 To [F:DAM2]NBBLOC-1
#      If find([F:DAM2]ACTBLOC(B),GSPE(1..GNBSPE))
#       [F:DAMK]ACTBLOC(B)   = [F:DAM2]ACTBLOC(B)
#       [F:DAMK]BASPAG(B)    = [F:DAM2]BASPAG(B)
#       [F:DAMK]LNGLIB(B)    = [F:DAM2]LNGLIB(B)
#       [F:DAMK]POSBLOC(B)   = [F:DAM2]POSBLOC(B)
#       [F:DAMK]COLBLOC(B)   = [F:DAM2]COLBLOC(B)
#       [F:DAMK]LINBLOC(B)   = [F:DAM2]LINBLOC(B)
#       [F:DAMK]HTBLOC(B)    = [F:DAM2]HTBLOC(B)
#       [F:DAMK]LGBLOC(B)    = [F:DAM2]LGBLOC(B)
#       [F:DAMK]NBLIGT(B)    = [F:DAM2]NBLIGT(B)
#       [F:DAMK]OPTION(B)    = [F:DAM2]OPTION(B)
#       [F:DAMK]RANG(B)      = [F:DAM2]RANG(B)
#       [F:DAMK]TITBLOC(B)   = [F:DAM2]TITBLOC(B)
#       [F:DAMK]INTBLOC(B)   = [F:DAM2]INTBLOC(B)
#       [F:DAMK]TYPBLOC(B)   = [F:DAM2]TYPBLOC(B)
#       [F:DAMK]STYBLOC(B)   = [F:DAM2]STYBLOC(B)
#       [F:DAMK]DETBLC(B)    = [F:DAM2]DETBLC(B)
#       [F:DAMK]BLOCACT1(B)  = [F:DAM2]BLOCACT1(B)
#       [F:DAMK]BLOCTYPT(B)  = [F:DAM2]BLOCTYPT(B)
#       [F:DAMK]BLOCTYPG(B)  = [F:DAM2]BLOCTYPG(B)
#       [F:DAMK]BLOCPOSG(B)  = [F:DAM2]BLOCPOSG(B)
#       [F:DAMK]BLOCGDEF(B)  = [F:DAM2]BLOCGDEF(B)
#       [F:DAMK]BLOCAFFD(B)  = [F:DAM2]BLOCAFFD(B)
#       [F:DAMK]BLOCREPD(B)  = [F:DAM2]BLOCREPD(B)
#       If B<=dim([F:DAMK]BLOCVIEW)-1 & B<=dim([F:AMK]BLOCVIEW)-1
#        [F:DAMK]BLOCVIEW(B)  = [F:DAM2]BLOCVIEW(B)
#       Endif
#       [F:DAMK]BLOCLIEN1(B) = [F:DAM2]BLOCLIEN1(B)
#       [F:DAMK]BLOCLIEN2(B) = [F:DAM2]BLOCLIEN2(B)
#       [F:DAMK]BLOCLIEN3(B) = [F:DAM2]BLOCLIEN3(B)
#       [F:DAMK]BLOCPAR1(B)  = [F:DAM2]BLOCPAR1(B)
#       [F:DAMK]BLOCPAR2(B)  = [F:DAM2]BLOCPAR2(B)
#       If B>[F:DAMK]NBBLOC-1
#        [F:DAMK]NBBLOC = B+1
#       Endif
#      Endif
#     Next B
     [F:DAMK]TRTSPE = [F:DAM2]TRTSPE
     If !VERT
      [F:DAMK]TRTSPV = [F:DAM2]TRTSPV
     Endif
     [F:DAMK]NBRLIG = NEWLIG
     [F:DAMK]NBRCOL = max([F:DAMK]NBRCOL,[F:DAM2]NBRCOL)
     [F:DAMK]UPDFLG = 1
     [F:DAMK]UPDDAT = date$
     If dim([F:DAMK]UPDTIM)>0 : [F:DAMK]UPDTIM = time : Endif
     [F:DAMK]UPDUSR = GUSER
     Rewrite [DAMK]
     If fstat : Call ERREUR("AMSK"-[F:DAMK]CODMSK,2) From DOSDIC : Endif

    Elsif ACTIV : # Changement d'un code activité
     [F:DAMK]=[F:DAM2] :#X3PLAT-2092
     RWO = 1
     [F:DAMK]UPDFLG = 1
     [F:DAMK]UPDDAT = date$
     If dim([F:DAMK]UPDTIM)>0 : [F:DAMK]UPDTIM = time : Endif
     [F:DAMK]UPDUSR = GUSER
     If [F:DAMK]MDL<>2 : GNBMSK += 1 : Endif
     Rewrite [DAMK]
     If fstat : Call ERREUR("AMSK"-[F:DAMK]CODMSK,2) From DOSDIC : Endif

    Endif
   Endif : # (new & old)
  Endif : # (spec)

 Commit

 Read [AMK]CODMSK Next
Wend

# On vire les actions inexistantes

Trbegin [DAMA] , [DAMP]
 For [DAMA]TYPAFF Where TYPAFF=1
  Read [DACT]ACTION = [F:DAMA]ACTION
  If fstat
   Delete [DAMA]
   If fstat=1 : Call ERREUR("AMSKACT"-[F:DAMA]CODAFF-[F:DAMA]CODZON-[F:DAMA]ACTION,3) From DOSDIC : Endif
  Endif
 Next
Commit

Close Local File [DAMK] , [DAMZ] , [DAMA] , [DAMP] , [DAM2] , [DACV] , [DACT]
Close Local File [AMK] , [AMZ] , [AMA] , [AMP] , [DAZ2]
Return

#################################
$TRT_BLC
Local Integer NBBLC : NBBLC=0
Local Integer BLCRANG(1..dim([F:AMK]RANG))
Local Integer BLCANCPOS(1..dim([F:AMK]RANG))
Local Integer BLCNEWPOS(1..dim([F:AMK]RANG))

Local Integer NOBLK,IBLC,BLC_SPE,BLC_POS
For NOBLK=0 To [F:DAMK]NBBLOC-1
 NBBLC+=1 : IBLC=NBBLC
 BLCRANG(IBLC)=[F:DAMK]RANG(NOBLK)
 BLCANCPOS(IBLC)=find([F:DAMK]RANG(NOBLK),[F:DAM2]RANG)
 BLCNEWPOS(IBLC)=NBBLC
Next
For NOBLK=0 To [F:DAM2]NBBLOC-1
 BLC_SPE=0
 BLC_POS=find([F:DAM2]RANG(NOBLK),BLCRANG(1..NBBLC))
 If !BLC_POS
  If find([F:DAM2]ACTBLOC(NOBLK),GSPE(1..GNBSPE))
   NBBLC+=1 : IBLC=NBBLC
   BLCRANG(IBLC)=[F:DAM2]RANG(NOBLK)
   BLCANCPOS(IBLC)=NOBLK+1
   BLCNEWPOS(IBLC)=NBBLC
   BLC_SPE=1
   DIFF=1
  Endif
 Elsif find([F:DAM2]ACTBLOC(NOBLK),GSPE(1..GNBSPE))
  BLC_SPE=1
  IBLC=BLC_POS
 Endif
 If BLC_SPE=1
   [F:DAMK]RANG         (BLCNEWPOS(IBLC)-1) = [F:DAM2]RANG        (BLCANCPOS(IBLC)-1)
   [F:DAMK]STYBLOC      (BLCNEWPOS(IBLC)-1) = [F:DAM2]STYBLOC     (BLCANCPOS(IBLC)-1)
   [F:DAMK]TITBLOC      (BLCNEWPOS(IBLC)-1) = [F:DAM2]TITBLOC     (BLCANCPOS(IBLC)-1)
   [F:DAMK]OPTION       (BLCNEWPOS(IBLC)-1) = [F:DAM2]OPTION      (BLCANCPOS(IBLC)-1)
   [F:DAMK]LGBLOC       (BLCNEWPOS(IBLC)-1) = [F:DAM2]LGBLOC      (BLCANCPOS(IBLC)-1)
   [F:DAMK]NBLIGT       (BLCNEWPOS(IBLC)-1) = [F:DAM2]NBLIGT      (BLCANCPOS(IBLC)-1)
   [F:DAMK]HTBLOC       (BLCNEWPOS(IBLC)-1) = [F:DAM2]HTBLOC      (BLCANCPOS(IBLC)-1)
   [F:DAMK]INTBLOC      (BLCNEWPOS(IBLC)-1) = [F:DAM2]INTBLOC     (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCTYPG     (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCTYPG    (BLCANCPOS(IBLC)-1)
   [F:DAMK]DETBLC       (BLCNEWPOS(IBLC)-1) = [F:DAM2]DETBLC      (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCPOSG     (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCPOSG    (BLCANCPOS(IBLC)-1)
   [F:DAMK]TYPBLOC      (BLCNEWPOS(IBLC)-1) = [F:DAM2]TYPBLOC     (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCTYPT     (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCTYPT    (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCACT1     (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCACT1    (BLCANCPOS(IBLC)-1)
   [F:DAMK]LINBLOC      (BLCNEWPOS(IBLC)-1) = [F:DAM2]LINBLOC     (BLCANCPOS(IBLC)-1)
   [F:DAMK]COLBLOC      (BLCNEWPOS(IBLC)-1) = [F:DAM2]COLBLOC     (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCLIEN2    (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCLIEN2   (BLCANCPOS(IBLC)-1)
   [F:DAMK]BASPAG       (BLCNEWPOS(IBLC)-1) = [F:DAM2]BASPAG      (BLCANCPOS(IBLC)-1)
   [F:DAMK]ACTBLOC      (BLCNEWPOS(IBLC)-1) = [F:DAM2]ACTBLOC     (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCLIEN3    (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCLIEN3   (BLCANCPOS(IBLC)-1)
   [F:DAMK]POSBLOC      (BLCNEWPOS(IBLC)-1) = [F:DAM2]POSBLOC     (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCLIEN1    (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCLIEN1   (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCPAR2     (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCPAR2    (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCVIEW     (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCVIEW    (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCGDEF     (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCGDEF    (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCPAR1     (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCPAR1    (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCAFFD     (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCAFFD    (BLCANCPOS(IBLC)-1)
   [F:DAMK]LNGLIB       (BLCNEWPOS(IBLC)-1) = [F:DAM2]LNGLIB      (BLCANCPOS(IBLC)-1)
   [F:DAMK]BLOCREPD     (BLCNEWPOS(IBLC)-1) = [F:DAM2]BLOCREPD    (BLCANCPOS(IBLC)-1)
 Endif
Next
[F:DAMK]NBBLOC=NBBLC

#fill RANG if not yet filled on old blocks
If dim([F:DAMZ]RANG)>0
 For IBLC=1 To NBBLC
  If BLCANCPOS(IBLC)<>0
   Update [DAMZ] Where  [DAMZ]CODMSK=[AMK]CODMSK & [DAMZ]RANG=0 & [DAMZ]NUMBLOC=BLCANCPOS(IBLC)
&  With [DAMZ]RANG=BLCRANG(IBLC)
   If fstat
    Call ERREUR("AMSKZON"-[AMK]CODMSK-"NUMBLOC="+num$(BLCANCPOS(IBLC))-"RANG->"+num$(BLCRANG(IBLC)),2) From DOSDIC
   Endif
  Endif
 Next IBLC
Endif

#change block position to fill new position on all fields
 For IBLC=1 To NBBLC
  If BLCANCPOS(IBLC)<>0 & BLCANCPOS(IBLC)<>BLCNEWPOS(IBLC)
   Update [DAMZ] Where  [DAMZ]CODMSK=[AMK]CODMSK & [DAMZ]NUMBLOC=BLCANCPOS(IBLC)
&  With [DAMZ]NUMBLOC=BLCNEWPOS(IBLC)+50
   If fstat
    Call ERREUR("AMSKZON"-[AMK]CODMSK-"NUMBLOC="+num$(BLCANCPOS(IBLC))-"NUMBLOC->"+num$(BLCNEWPOS(IBLC)+50),2) From DOSDIC
   Endif
  Endif
 Next IBLC

 For IBLC=1 To NBBLC
  If BLCANCPOS(IBLC)<>0 & BLCANCPOS(IBLC)<>BLCNEWPOS(IBLC)
   Update [DAMZ] Where  [DAMZ]CODMSK=[AMK]CODMSK & [DAMZ]NUMBLOC=BLCNEWPOS(IBLC)+50
&  With [DAMZ]NUMBLOC=BLCNEWPOS(IBLC)
   If fstat
    Call ERREUR("AMSKZON"-[AMK]CODMSK-"NUMBLOC="+num$(BLCANCPOS(IBLC))-"NUMBLOC->"+num$(BLCNEWPOS(IBLC)),2) From DOSDIC
   Endif
  Endif
 Next IBLC


Return

$CREACT
For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK & CODZON=[F:AMZ]CODZON
 [F:DAMA] = [F:AMA]
 Write [DAMA]
 If fstat : Call ERREUR("AMSKACT"-[F:DAMA]CODAFF-[F:DAMA]CODZON-[F:DAMA]ACTION,1) From DOSDIC : Endif
Next
For [AMP]CODPAR Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK & CODZON=[F:AMZ]CODZON
 [F:DAMP] = [F:AMP]
 Write [DAMP]
 If fstat : Call ERREUR("AMSKPAR"-[F:DAMP]CODAFF-[F:DAMP]CODZON-[F:DAMP]CODPAR,1) From DOSDIC : Endif
Next
Return

## Effacement d'un écran

Subprog EFFACE(ECRAN)
Value Char ECRAN
Local Integer W
Call ECR_TRACE(mess(54,125,1)-ECRAN,0) From GESECRAN
For W=0 To 9
 Call SUPP_TRT("W"+num$(W)+ECRAN) From DOSSUB
Next W
Delete [DAMZ] Where CODMSK = ECRAN
If fstat=1 : Call ERREUR("AMSKZON"-ECRAN,3) From DOSDIC : Endif
Delete [DAMA] Where TYPAFF=1 & CODAFF=ECRAN
If fstat=1 : Call ERREUR("AMSKACT"-ECRAN,3) From DOSDIC : Endif
Delete [DAMP] Where TYPAFF=1 & CODAFF=ECRAN
If fstat=1 : Call ERREUR("AMSKPAR"-ECRAN,3) From DOSDIC : Endif
Delete [DAMK] Where CODMSK=ECRAN
If fstat=1 : Call ERREUR("AMSK"-ECRAN,3) From DOSDIC : Endif
End

