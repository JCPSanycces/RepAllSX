#<AdxTL>@(#)0.0.0.0 $Revision$Class Concession
# Supervisor
## CRUD-CLASSE ## CONCESSION
# 2018-11-06 07:04:17 600

Gosub TEST From WMCR_CONCESSION : End

############################################################################################
## R : Subprog AREAD(INSTANCE,CCNREF)
############################################################################################
# CONCESSION : CONCESSION
# ECCNREV : CONCESSION ECCNREV
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet CONCESSION._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1,A_N2,A_S2
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = CONCESSION.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(CONCESSION.ACTX.AFOLDER,nomap,"")>0
 Local File CONCESSION [CCN]
 Local File ECCNREV [E51]
Else
 Local File =CONCESSION.ACTX.AFOLDER+".CONCESSION" [CCN]
 Local File =CONCESSION.ACTX.AFOLDER+".ECCNREV" [E51]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet CONCESSION.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [CCN] With
& [E51]EVE0 = [CCN]CCNREF
& As [LNK_]
Return



