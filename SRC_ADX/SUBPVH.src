Subprog C_VRACOD(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Char MESSAGE(250)
Local Integer I

If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif

# Contrôle code accès

If [V]GUSRACS <> 2
    Read [ACC]CODACC = GUSER;[F:VRA]CODACC
    If fstat or [F:ACC]EXEC <> 2
        [V]GMESSAGE = mess(41,10703,1)-VALEUR : # Accès interdit à la variable
        mkstat = 2 : End
    Endif
Endif

# Contrôle actif / inactif basé sur le code activité ... reprise de ce que l'on fait
# dans TRTDIR mais bof bof ...

If [F:VRA]CODACT <> ""
    Read [ACV]CODACT = [F:VRA]CODACT
    If fstat or [F:ACV]FLACT <> 2
        [V]GMESSAGE = VALEUR-":"-mess(42,10703,1) : # Variable inactive
        mkstat = 2 : End
    Endif
Endif

# Contrôle d'unicité
For [L]I = 0 To [M:PVH2]NBVRA-1
    If [M:PVH2]VRACOD([L]I) = [L]VALEUR & [L]NOL <> [L]I
        # mess(29,100,1) : Code déjà saisi ligne
        [L]MESSAGE = mess(29, 100, 1)-num$([L]I+1)
        # Call ERREUR([L]MESSAGE) From GESECRAN
        [V]GMESSAGE = [L]MESSAGE
        mkstat = 2
    Endif
Next

End

Subprog AS_VRAROW(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL

# Demande DBA - reprendre le rang de la variable

If [L]VALEUR = 0
    Read [F:VRA]VRA0 = GCURLEG;[M:PVH2]VRACOD([L]NOL)
    If fstat = 0
        [L]VALEUR = [F:VRA]ROWEMP
    Endif
Endif
End

Subprog AS_VRAGRP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If dim([V]GPPHVRAGRP) > 0 & [V]GPPHVRAGRP = 1
    # On "fusionne" la notion de groupe avec la notion de thème de la variable
    If [L]VALEUR = ""
        Read [F:VRA]VRA0 = GCURLEG;[M:PVH2]VRACOD([L]NOL)
        If fstat = 0
            [L]VALEUR = [F:VRA]VRATHM
        Endif
    Endif
    Affzo [M:PVH2]VRAGRP([L]NOL) : mkstat = 2
Endif
End

Subprog C_DOCCOD(VALEUR)
Variable Char    VALEUR()
If [L]VALEUR <> ""
    Read [F:AYY]AYY0(1) = [L]VALEUR
    If fstat <> 0
        mkstat = 2
        End
    Endif
Endif
End

Subprog S_DOCCOD(VALEUR)
Variable Char    VALEUR()

Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJ1"
PARMSK(1) = "AYY"    : # Objet
PARMSK(2) = "|"      : # Clé DOCCOD ; LAN - sauf que par défaut la gestion / sélection objet considère
                       # que CLE2 est la valeur recherchée ; le | change l'ordre des choses
PARMSK(3) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
GACTION = SAVACT

End

#--------------------------------------------------------------------
# Pour le code liste renseigné dans le paramètre CODPVH, on ne peut pas supprimer une variable si elle est utilisée
# dans la table de correspondance Dispositif/Variable (GESPVR)
#--------------------------------------------------------------------
Subprog C_NBVRA
Local Char CODPVH(GLONPVH)

  Case status
    When 65 : : # Suppression d'une ligne
      Call PARAM(GCURLEG, "CODPVH", CODPVH) From ADOVAL
      If CODPVH=[M:PVH0]PVHCOD Then
        If clalev([F:PVR])=0 : Local File PARVAR       [PVR] : Endif
        Filter [F:PVR] Where VRACOD=[M:PVH2]VRACOD(nolign-1)
        If rowcount([F:PVR])>0 Then
          GMESSAGE=mess(184,10717,1) : # Cette variable est utilisée dans la correspondance Dispositif/Action. Elle ne peut être supprimée du code liste.
          mkstat=2
        Endif
        Filter [F:PVR]
      Endif
  Endcase
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran PVH0) 25/05/2012 18:32:38 (DBA)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Char RESULT
Local Integer DISPMSG
GCURLEG=VALEUR
Raz [M:PVH2]: Affzo [M:PVH2]
#81085 - RAZ des informations incohérentes quand je change de législation
Call GET_LEGSRV([M:PVH1]CRISRV,OK,RESULT,DISPMSG) From TOOLSHRLEG
If(OK and (RESULT<>"" and VALEUR<>RESULT))
 Raz [M:PVH1]CRISRV : [M:PVH1]ALLSRV=2 : Grizo [M:PVH1]CRISRV
Endif
Raz OK, RESULT, DISPMSG
Call GET_LEGPOP([M:PVH1]CRIPOP,OK,RESULT,DISPMSG) From TOOLSHRLEG
If(OK and (RESULT<>"" and VALEUR<>RESULT))
 Raz [M:PVH1]CRIPOP
Endif
Raz [M:PVH1]CRICPY, CRIFCY, CRIPRF
[M:PVH1]ALLCPY=2 : Grizo [M:PVH1]CRICPY
[M:PVH1]ALLFCY=2 : Grizo [M:PVH1]CRIFCY
[M:PVH1]ALLPRF=2 : Grizo [M:PVH1]CRIPRF
Affzo [M:PVH1]
#
End


######################################################################################

#JOJAC - 2016-08-02 - X3PEOP-889 - START
Subprog CONTPVH(COD)
Variable Char    COD()

If GFONCTION = "GESPVH" | PVHCOD="" : End : Endif

If clalev([F:PVH])=0 : Local File PPVRALISH [PVH] : Endif

If COD <> ""
  Filter [F:PVH] Where PVHCOD=[L]COD
  Read [F:PVH] First
  If fstat
      GMESSAGE = COD-":"-mess(23,100,1)
      mkstat = 2 : End
  Else
      Filter [F:PVH]
      Read [F:PVH]PVH0 = GCURLEG;[L]COD
      If fstat
        Filter [F:PVH] Where PVHCOD=[L]COD
        Read [F:PVH] First
        GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:PVH]LEG
        mkstat = 2 : End
      Endif
  Endif
Endif
Filter [F:PVH]
End

$SEL_TABLE
Case TABLE
  When "SELPVH"
    If clalev ([F:PVH])=0 : Local File PPVRALISH [PVH] : Endif
    Filter [F:PVH]
    OBJET     = "PVH"
    If PARAM(1)<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:PVH]LEG="'+PARAM(1)+'" | [F:PVH]LEG="")',"&") From GOBJSUB
    Endif
Endcase
Return

Subprog TUNPVH(COD)
Variable Char    COD()

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONPVH)
 TOKILL = 1
Endif
If clalev([F:PVH])=0 : Local File PPVRALISH [PVH] : Endif
# To update the PRF code after the tunnel order
VCOD = COD
If VCOD="" & GLECOBJ=2
#If no code is specified, it's better to select one of the curent legislation
  Filter [PVH] Where LEG=GCURLEG
  Read [F:PVH] First
  Filter [PVH]
  If !fstat : VCOD=[F:PVH]PVHCOD : Endif
Else
  Read [PVH]PVH0 = GCURLEG;VCOD
Endif
Call OBJET("PVH",VCOD,GCURLEG) From GOBJET
COD = VCOD
If TOKILL : Kill VCOD : Endif
End
#JOJAC - 2016-08-02 - X3PEOP-889 - END

