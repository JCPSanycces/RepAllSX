#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion objet PVH
#-----------------------------------------------------------------------------------------------------
# SUBPVH : Gestion de l'objet PVH - Définition d'une liste de variables utilisées en préparation paye
#-----------------------------------------------------------------------------------------------------
#Permet de définir la liste des variables utilisables en préparation paye
#D'indiquer si on souhaite une validation hiérarchique (FLGVAL)
#Plus d'autres petits gadgets à venir
#NBCOLSAISIECROISEETAG

Call OBJET("PVH", [V]GBIDC1, [V]GBIDC2) From GOBJET
End

$ACTION
Case [L]ACTION
 When "OUVRE" : Gosub OUVRE
 When "LIENS" : Gosub LIENS
 When "RAZCRE": Gosub RAZCRE
 When "CREATION": Gosub CREATION
 When "MODIF" : Gosub MODIF
 When "ANNULE": Gosub ANNULE
 When "FERME" : Gosub FERME
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "AS_PVHCOD"      : Gosub AS_PVHCOD
 When "BS_PVHCOD"      : Gosub BS_PVHCOD
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

$OUVRE
If not clalev([F:VRA]) : Local File VARIA [VRA] : Endif
If not clalev([F:AYY]) : Local File AYTDOC [AYY] : Endif
If dim([V]GPPHVRAGRP)<0:  Global Integer GPPHVRAGRP : [V]GPPHVRAGRP = 2 : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONPVH) : Endif
VCOD = CLE1
Return

#Before selection on field COD
#############
$AS_PVHCOD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_PVHCOD
# To do nothing if the user doesn't select a record
If [F:PVH]PVHCOD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:PVH0]LEG)>=0 : [M:PVH0]LEG=[F:PVH]LEG: Endif
 GCURLEG=[F:PVH]LEG
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:PVH0]LEG)>=0
  GCURLEG=[M:PVH0]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return

$LIENS
GCURLEG=[F:PVH]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

Call LECTEXTRA([M]PVHDES,"PPVRALISH","PVHDES",GCURLEG,[M]PVHCOD) From ATEXTRA

Raz [M:PVH2], nolign
For [F:HRPVD]PVD0 Where [F:HRPVD]PVHCOD = [M:PVH0]PVHCOD & LEG=GCURLEG
    If nolign >= dim([M:PVH2]VRACOD)
        # mess(26,100,1) : Tableau plein
        Call ERREUR(mess(26, 100, 1)) From GESECRAN
        Break
    Endif
    nolign += 1
    [M:PVH2] = [F:HRPVD]
Next
[M:PVH2]NBVRA = nolign

Gosub SET_GRIZO
Affzo [M:PVH1]
Affzo [M:PVH2]

Return


$SET_GRIZO
If [M:PVH1]ALLCPY = 2
    Grizo [M:PVH1]CRICPY
    Grizo [M:PVH1]ALLFCY
Else
    Actzo [M:PVH1]CRICPY
Endif
If [M:PVH1]ALLFCY = 2
    Grizo [M:PVH1]CRIFCY
Else
    Actzo [M:PVH1]CRIFCY
Endif
If [M:PVH1]ALLPRF = 2
    Grizo [M:PVH1]CRIPRF
Else
    Actzo [M:PVH1]CRIPRF
Endif
If [M:PVH1]ALLSRV = 2
    Grizo [M:PVH1]CRISRV
Else
    Actzo [M:PVH1]CRISRV
Endif

# Pour l'instant le préchargement n'est pas accessible ! - V2 en cours d'étude

Grizo [M:PVH1]FLGLOA

Return


$RAZCRE
# Par défaut les cases à cocher sont cochées ....
[M:PVH1]ALLCPY = 2 : [M:PVH1]ALLFCY = 2 : [M:PVH1]ALLPRF = 2 : [M:PVH1]ALLSRV = 2
[M:PVH0]ENAFLG = 2

[M:PVH1]FLGLOA = 2

Gosub SET_GRIZO

Affzo [M:PVH0]
Affzo [M:PVH1]
Affzo [M:PVH2]

Return

$VERIF_CRE
Gosub VERIFICATION
Return

$VERIF_MOD
Gosub VERIFICATION
Return

# SEGAY - 05/02/13 - FQ82073 86022 US1201 US1209 - Blank is Groupe
$VERIFICATION
# Contrôle si  groupe variables < 16
Local Integer WI
Raz [L]WI
For [L]WI = 0 To [M:PVH2]NBVRA - 1
  Call CTR_VRAGRP([M:PVH2]VRAGRP(WI),WI)
  If mkstat = 2
    [L]OK = 0
    Break
  Endif
Next

Return


$CREATION
Gosub TEXTRA
Gosub WRITE_PVD
If [V]GOK < 1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
Gosub DELETE_PVD
If [V]GOK < 1 : Return : Endif
Gosub WRITE_PVD
If [V]GOK < 1 : Return : Endif
Return

$ANNULE
Call SUPTEXTRA("PPVRALISH","PVHDES",[L]CODE,SUPP) From ATEXTRA
Gosub DELETE_PVD
If [V]GOK < 1 : Return : Endif
Return

$AP_CHANGE
Call CHGTEXTRA("PPVRALISH","PVHDES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Return

$TEXTRA
If GREP="D"
  Call DUPTEXTRA("PPVRALISH", "PVHDES", CLECUR1, "", "PPVRALISH", "PVHDES", GCURLEG, [F:PVH]PVHCOD) From ATEXTRA
Endif
Call MAJTEXTRA([M]PVHDES, "PPVRALISH", "PVHDES", GCURLEG, [F:PVH]PVHCOD) From ATEXTRA
Return

$WRITE_PVD
For nolign = 1 To [M:PVH2]NBVRA
    Raz [F:HRPVD]
    [F:HRPVD] = [M:PVH0]
    [F:HRPVD] = [M:PVH2]
    [F:HRPVD]LEG = GCURLEG
    [F:HRPVD]NUMLIG = nolign
    Write [F:HRPVD]
    If fstat <> 0
        [V]GOK = 0
        Call FSTA("HRPVD") From GLOCK
        Break
    Endif
Next
If [V]GOK < 1 : Return : Endif
Return

$DELETE_PVD
Delete [F:HRPVD] Where [F:HRPVD]PVHCOD = [M:PVH0]PVHCOD & LEG=GCURLEG
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("HRPVD") From GLOCK
    Return
Endif
Return

#--------------------------------------------------------------------
# Renvoi le code de la liste de variable par défaut pour une prépaie
#--------------------------------------------------------------------
Funprog GET_DFLTPVHCOD(USER, MGR)
Value Char USER(), MGR()

# A faire évoluer selon les besoins
# => Paramètre par utilisateur , par manager, pour un couple donné ?
# => La spécification initiale ne prévoyait qu'une liste de variable, on prends donc la "première"
#    active de la table.

Local File PPVRALISH [WPVH] Where [F:WPVH]ENAFLG = 2 and [F:WPVH]LEG = GCURLEG
Local Char PVHCOD([V]GLONPVH)

#JOJAC - 2016-08-02 - X3PEOP-919 - START
Filter [F:WPVH] Where LEG=GCURLEG
#JOJAC - 2016-08-02 - X3PEOP-919 - END
Read [F:WPVH]PVH0 First
If fstat = 0
    [L]PVHCOD = [F:WPVH]PVHCOD
Endif
#JOJAC - 2016-08-02 - X3PEOP-919 - START
Filter [F:WPVH]
#JOJAC - 2016-08-02 - X3PEOP-919 - END
Close Local File [WPVH]

End [L]PVHCOD

#--------------------------------------------------------
# Renvoi le code liste PVH pour un couple société / site
# => N'a plus lieu d'être / à virer
#--------------------------------------------------------
Funprog GET_PVHCOD(CPY, FCY)
Value Char CPY(), FCY()

If clalev([F:PVH]) = 0 : Local File PPVRALISH [PVH] : Endif

Local Char WPVHCOD([V]GLONPVH)
Raz [L]WPVHCOD

Read [F:PVH]PVH1(2) = [L]CPY ; [L]FCY
If fstat = 0
    [L]WPVHCOD = [F:PVH]PVHCOD
Else
    # Recherche sur la société
    Read [F:PVH]PVH1(2) = [L]CPY ; ""
    If fstat = 0
        [L]WPVHCOD = [F:PVH]PVHCOD
    Else
        # Recherche sur une valeur générique "dossier"
        Read [F:PVH]PVH1(2) = "" ; ""
        If fstat = 0
            [L]WPVHCOD = [F:PVH]PVHCOD
        Endif
    Endif
Endif

End [L]WPVHCOD

#----------------------- ECRANS ----------------------
$SETNOL
Local Integer NOL
[L]NOL = nolign - 1
Return

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
End

Subprog C_VRAGRP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
#Local Integer NBCOLVRA, NBVRAGRP
#Local Char MESSAGE(250)
#
## NBCOLSAISIECROISEETAG
#[L]NBCOLVRA = 15 : [L]NBVRAGRP = 0
#
#If [L]VALEUR <> ""
#    [M:PVH2]VRAGRP([L]NOL) = [L]VALEUR
#    [L]NBVRAGRP = sigma(0, [M:PVH2]NBVRA-1, [M:PVH2]VRAGRP(indcum)=[L]VALEUR)
#    [L]NBVRAGRP += ([L]NOL=[M:PVH2]NBVRA)
#    If [L]NBVRAGRP > [L]NBCOLVRA
#        # mess(173,10702,1) : variables maximum par groupe de saisie
#        [L]MESSAGE = num$([L]NBCOLVRA)-mess(173,10702,1)
#        # Call ERREUR([L]MESSAGE) From GESECRAN
#        [V]GMESSAGE = [L]MESSAGE
#        mkstat = 2
#    Endif
#Endif
# SEGAY - 05/02/13 - FQ82073 86022 US1201 US1209 - Blank is Groupe
Call CTR_VRAGRP(VALEUR,[L]NOL)
End

# SEGAY - 05/02/13 - FQ82073 86022 US1201 US1209 - Blank is Groupe
Subprog CTR_VRAGRP(VALEUR,NOL)
Value Char    VALEUR()
Value Integer NOL
Local Integer NBCOLVRA, NBVRAGRP
Local Char MESSAGE(250)

# NBCOLSAISIECROISEETAG
[L]NBCOLVRA = 15 : [L]NBVRAGRP = 0

[M:PVH2]VRAGRP([L]NOL) = [L]VALEUR
[L]NBVRAGRP = sigma(0, [M:PVH2]NBVRA-1, [M:PVH2]VRAGRP(indcum)=[L]VALEUR)
[L]NBVRAGRP += ([L]NOL=[M:PVH2]NBVRA)
If [L]NBVRAGRP > [L]NBCOLVRA
    # mess(173,702,1) : variables maximum par groupe de saisie
    [L]MESSAGE = num$([L]NBCOLVRA)-mess(173, 10702, 1)
    # Call ERREUR([L]MESSAGE) From GESECRAN
    [V]GMESSAGE = [L]MESSAGE
    mkstat = 2
Endif
End

