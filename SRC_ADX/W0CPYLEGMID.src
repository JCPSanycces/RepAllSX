#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGMID 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone BOXNUM
mkstat = 0
zoncou = "BOXNUM"
indice = 0
If varmode([M]BOXNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BOXNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]BOXNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "BOXNUM" : GZNUM = 55594 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_BOXNUM([M]BOXNUM) From TRTCPYLEGMID
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "BOXNUM" : GZNUM = 55594 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NUMPRMVIS
mkstat = 0
zoncou = "NUMPRMVIS"
indice = 0
If varmode([M]NUMPRMVIS,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NUMPRMVIS([M]NUMPRMVIS) From TRTCPYLEGMID
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NUMPRMVIS : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMPRMVIS" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NUMACTPRMVIS
mkstat = 0
zoncou = "NUMACTPRMVIS"
indice = 0
If varmode([M]NUMACTPRMVIS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMACTPRMVIS" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CPYRGTTYP
mkstat = 0
zoncou = "CPYRGTTYP"
indice = 0
IMPENT = [M]CPYRGTTYP
WNUM = IMPENT
If varinit([M]CPYRGTTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]CPYRGTTYP,indice)=0
 Call INICOMBO(11730) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CPYRGTTYP(IMPENT) From TRTCPYLEGMID
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,11730,1))))
 Endif
 [M]CPYRGTTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPYRGTTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CPYRGTTYP(indice)
 Endif
 If !mkstat
  If IMPENT=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CPYRGTTYP" : GZNUM = 55591 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
    mkstat = 1 : GMESSAGE = mess(99,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "CPYRGTTYP" : GZNUM = 55591 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WNUM<>IMPENT or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_CPYRGTTYP(IMPENT) From TRTCPYLEGMID
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CPYRGTTYP" : GZNUM = 55591 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif
[M]CPYRGTTYP = IMPENT

## Zone CPYRGTDAT
mkstat = 0
zoncou = "CPYRGTDAT"
indice = 0
If varmode([M]CPYRGTDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPYRGTDAT" : Gosub ACTION From =IMPTRT
 Endif
 If [M]CPYRGTDAT=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CPYRGTDAT" : GZNUM = 55592 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_CPYRGTDAT([M]CPYRGTDAT) From TRTCPYLEGMID
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPYRGTDAT" : GZNUM = 55592 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CPYPRC
mkstat = 0
zoncou = "CPYPRC"
indice = 0
If varmode([M]CPYPRC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPYPRC" : Gosub ACTION From =IMPTRT
 Endif
 If [M]CPYPRC=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CPYPRC" : GZNUM = 55593 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_CPYPRC([M]CPYPRC) From TRTCPYLEGMID
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPYPRC" : GZNUM = 55593 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone AGNID
mkstat = 0
zoncou = "AGNID"
indice = 0
If varmode([M]AGNID,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AGNID" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]AGNID,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "AGNID" : GZNUM = 56094 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone SPOTYP
mkstat = 0
zoncou = "SPOTYP"
indice = 0
IMPENT = [M]SPOTYP
WNUM = IMPENT
If varinit([M]SPOTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPOTYP,indice)=0
 [M]SPOTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPOTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPOTYP(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SPOTYP" : GZNUM = 680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_SPOTYP(IMPENT) From TRTCPYLEGMID
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "SPOTYP" : GZNUM = 680 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]SPOTYP = IMPENT

## Zone SPOBOX
mkstat = 0
zoncou = "SPOBOX"
indice = 0
If varmode([M]SPOBOX,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPOBOX" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SPOTIT
mkstat = 0
zoncou = "SPOTIT"
indice = 0
IMPENT = [M]SPOTIT
If varinit([M]SPOTIT,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPOTIT,indice)=0
 [M]SPOTIT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPOTIT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPOTIT(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SPOTIT" : GZNUM = 1826 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]SPOTIT = IMPENT

## Zone SPONAM
mkstat = 0
zoncou = "SPONAM"
indice = 0
If varmode([M]SPONAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPONAM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]SPONAM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SPONAM" : GZNUM = 18622 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone SPOADD
mkstat = 0
zoncou = "SPOADD"
indice = 0
If varmode([M]SPOADD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPOADD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SPOOWN
mkstat = 0
zoncou = "SPOOWN"
indice = 0
If varmode([M]SPOOWN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPOOWN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_SPOOWN([M]SPOOWN) From TRTCPYLEGMID
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "SPOOWN" : GZNUM = 56097 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone PMTLIGNUM
mkstat = 0
zoncou = "PMTLIGNUM"
indice = 0
status = 1
zoncou = "PMTLIGNUM"
If varmode([M]PMTLIGNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PMTLIGNUM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]PMTLIGNUM
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]PMTLIGNUM = nolign
   status = 75
   Call SAI_PMTLIGNUM(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone PERNUM
mkstat = 0
zoncou = "PERNUM"
indice = 0
status = 1
zoncou = "PERNUM"
If varmode([M]PERNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PERNUM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]PERNUM
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]PERNUM = nolign
   status = 75
   Call SAI_PERNUM(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_PMTLIGNUM(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone PMTLIGNUM
mkstat = 0
zoncou = "PMTLIGNUM"

## Zone PMTCAT
mkstat = 0
zoncou = "PMTCAT"
IMPENT = [M]PMTCAT(indice)
If varinit([M]PMTCAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]PMTCAT,indice)=0
 [M]PMTCAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PMTCAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PMTCAT(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PMTCAT" : GZNUM = 707 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_PMTCAT(IMPENT) From TRTCPYLEGMID
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PMTCAT" : GZNUM = 707 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PMTCAT(indice) = IMPENT

## Zone PMTNUM
mkstat = 0
zoncou = "PMTNUM"
If varmode([M]PMTNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PMTNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PMTNUM(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PMTNUM" : GZNUM = 1120 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PMTDAT
mkstat = 0
zoncou = "PMTDAT"
If varmode([M]PMTDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PMTDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_PMTDAT([M]PMTDAT(indice)) From TRTCPYLEGMID
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PMTDAT" : GZNUM = 15655 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PMTLIGNUM
mkstat = 0
zoncou = "PMTLIGNUM"

End

####################################
## Bloc tableau 4
####################################
Subprog SAI_PERNUM(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone PERNUM
mkstat = 0
zoncou = "PERNUM"

## Zone PERNTT
mkstat = 0
zoncou = "PERNTT"
If varinit([M]PERNTT,indice)=0
 [M]PERNTT(indice) = GPAYS
Endif
If varmode([M]PERNTT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PERNTT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TCY","!",[M]PERNTT(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PERNTT" : GZNUM = 44771 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PERNBR
mkstat = 0
zoncou = "PERNBR"
If varmode([M]PERNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PERNBR" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_PERNBR([M]PERNBR(indice)) From TRTCPYLEGMID
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PERNBR" : GZNUM = 1120 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PEREXPDAT
mkstat = 0
zoncou = "PEREXPDAT"
If varmode([M]PEREXPDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PEREXPDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PERCAT
mkstat = 0
zoncou = "PERCAT"
If varmode([M]PERCAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PERCAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PERNUM
mkstat = 0
zoncou = "PERNUM"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CPYLEGMID"
Return

