$MSG_ERREUR

#    RTRN = -1    #  Pas régularisable
#    RTRN =  0    #  OK
#    RTRN =  1    #  Secteur d'activité non trouvé dans la table 410
#    RTRN =  2    #  Erreur mise à jour DEPREC
#    RTRN =  3    #  Erreur conversion  DEPREC
#    RTRN =  4    #  Erreur génération événement
#    RTRN =  5    #  Erreur extourne événements
#    RTRN =  6    #  Erreur suppression amortissements
#    RTRN =  7    #  Erreur en gestion des flux


  If (RTRN > 0 )
    If (RTRN = 1 )
#       # Dépense - Erreur lors de la génération d'événement
        RMES= mess(323,GML_MSGFAS,1)-[F:MAS1]CODLOF+"-"+num$([F:MAS1]LINLOF)+" : "-mess(101,GML_MSGGRT,1)
    Endif
    NBCPYERR += 1
    GOK=0 : Return
  Endif


Return

