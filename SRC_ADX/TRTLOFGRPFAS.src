# XXXXX DD.MM.YYYY nnnnnn_nn CCCCCCCCCCCCCCCCCCCCCCCCCCCCC
#
# Issue X3-99989 - 2018-08-07 by CBO : Mass capitalization of asset not taking into account all criteria the expense grouping
# MDJ   22.07.2016 117740    Alimentation des zones libres avec associations ou selon paramétrage
# MDJ   26.04.2016 115019    PRVSITUPD="No" and DPRCUM forced
# MDJ   08.04.2016 115015    Associations sur zones libres NOK
# CBO   28.11.2014 FQ104360  Undo a linked expense when balance sht val is changed
# MDJ   16.06.2014 FQ98116   Deductible VAT recalculated when capitalizing Expense
# MDJ   16.05.2014 FQ100085  Ajout initialisation de champs (THESLI, FLGCNXFLX, VATREGDAT, GALREFDAT, VATRSD)
# MDJ   29.04.2014 FQ99561   Add free field loading management
# MDJ   26.02.2014 FQ95888   Ajout du code comptable dans les événements LOFCIM*
# GLE   04.12.2013 FQ94306   Ajout du point d'entrée LOFTOFAS pour compléter l'alimentation du bien à partir de la dépense
# CBO   15.10.2013 FQ93595   erreur conversion pour 1 dépense en devise /plan IAS
# MDJ   11.10.2013 FQ92171   Pas de maj du plan de subvention avec le montant subventionné des dépenses rattachées
# MDJ   06.03.2013 FQ88152   code comptable non trouvé car variable GFASLEDSOC non alimentée (chargement FASPARCPY ajouté)
# GLE   15.02.2013 FQ88052   Division par zéro si la valeur bilan PCG du bien est égal à zéro
# GLE   04.10.2012 FQ84794   Gestion d'un montant IAS pour éviter une double conversion si devise IAS = devise pièce
# MDJ   26.04.2016 115019    PRVSITUPD and DPRCUM forced
# MDJ   08.04.2016 115015    Associations sur zones libres NOK
# CBO   28.11.2014 FQ104360  Undo a linked expense when balance sht val is changed
# MDJ   16.06.2014 FQ98116   Deductible VAT recalculated when capitalizing Expense
# MDJ   16.05.2014 FQ100085  Ajout initialisation de champs (THESLI, FLGCNXFLX, VATREGDAT, GALREFDAT, VATRSD)
# MDJ   29.04.2014 FQ99561   Add free field loading management
# MDJ   26.02.2014 FQ95888   Ajout du code comptable dans les événements LOFCIM*
# GLE   04.12.2013 FQ94306   Ajout du point d'entrée LOFTOFAS pour compléter l'alimentation du bien à partir de la dépense
# CBO   15.10.2013 FQ93595   erreur conversion pour 1 dépense en devise /plan IAS
# MDJ   11.10.2013 FQ92171   Pas de maj du plan de subvention avec le montant subventionné des dépenses rattachées
# MDJ   06.03.2013 FQ88152   code comptable non trouvé car variable GFASLEDSOC non alimentée (chargement FASPARCPY ajouté)
# GLE   15.02.2013 FQ88052   Division par zéro si la valeur bilan PCG du bien est égal à zéro
# GLE   04.10.2012 FQ84794   Gestion d'un montant IAS pour éviter une double conversion si devise IAS = devise pièce
################################################################################
# GTAMMAS massif
 Raz GPILOBJ
 Call DEFVAR From GLOBIMM
 Call INIVAR From GLOBIMM
 Call LAUNCH_ACT(GTAMMAS)
End
#==============================================================#
#            Gestion de l'action métier LOFGRPFAS              #
#==============================================================#
######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION

# Infbox "LOFGRPFAS  /"-ACTION
 Case ACTION
  When "INIT"         : Gosub INIT
  When "INIT_DIA"     : Gosub INIT_DIA
  When "AVANT_PAR"    : Gosub AVANT_PAR
  When "OUVRE"        : Gosub OUVRE
  When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
  When "DEBUT"        : Gosub DEBUT
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "SETBOUT"      : Gosub SETBOUT
  When "AP_CHOIX"     : Gosub AP_CHOIX
  When "BOUTON"       : Gosub BOUTON
  When "END"          : Gosub END_BOITE
  When "OK"           : Gosub OK
  When "ABA"          : Gosub ABA
  When "EXEC"         : Gosub EXEC
  When "CONTROLE"     : Gosub CONTROLE
  When "CONT_BATCH"   : Gosub CONT_BATCH
  When "FIN"          : Gosub FIN
  When "TERMINE"      : Gosub TERMINE
  When "SORTIE"       : Gosub SORTIE
  When "SEL_TABLE"    : Gosub SEL_TABLFG
  When Default
 Endcase

Return
#=====================================================================
$OUVRE_BATCH             # (Massif uniquement - Soumission batch uniquement)

  Global Integer GLONLINE # Issue X3-99989
  GLONLINE = 115         # Issue X3-99989

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT
  Gosub OUVRE_TABLES

Return
#=====================================================================
$INIT_DIA                    # (Massif - Traitement ( Standard & Saisie et Execution - Batch)

  Global Integer GLONLINE # Issue X3-99989
  GLONLINE = 115         # Issue X3-99989

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

Return
#=====================================================================
$INIT                    # (Massif uniquement - interactif et exécution batch)

  Global Integer GLONLINE # Issue X3-99989
  GLONLINE = 115         # Issue X3-99989

 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT

 If GSERVEUR
   Gosub CREE_GLOBTRT
 Endif

Return
#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  # Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
  # EXEC - Ouverture manuelle des masques de la fenêtre.
  Local Char WINACT : WINACT=ACTMETNAM+"M"
  Local Integer I_MSK
  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif
  Read [AWI]AWI0=WINACT
  If !fstat
    Local Mask =[F:AWI]MSKENT
    For I_MSK=0 To [F:AWI]NBMSK
      Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
      Local Mask =[F:AMK]CODMSK
    Next I_MSK
  Endif

Return
#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  Gosub ACTION From =TRTMODACT
  Gosub OUVRE_TABLES

  If !GSERVEUR
    Gosub CREE_GLOBTRT
  Endif

Return
#=====================================================================
$CREE_GLOBTRT

  Global Integer    G_TRACE
  Global Integer    G_NBLOF, G_NBLOF_SEL, G_NBLOF_TRT
  Global Integer    G_PRILOF            # Choix dépense principale
  Global Char       GIASCUR
  Global Integer    GIASCURTYP
  #------------------------------
  Global Date       WCNXDAT (1..5)
  Global Date       WCNXDATI(1..5)
  Global Integer    WRET, WCNXCPT, WCNXIAS
  Global Integer    G_NBFAS_CRE
  Global Integer    RERROR
  Global Char       LMESSAGE(250)
  Global Integer    TRT_ERROR               # Au moins une erreur dans le traitement ?
  Global Char       CRITSUPG1(255)          # Sélection avancée de l'objet Code regroupement
  Global Char       CRITSUPG2(255)          # Sélection Expression de l'objet Code regroupement
  Global Char       GORDGRP (255)           # Critères de tri des dépenses sélectionnées
  Global Integer    GPARTYPPHY (100)        # types physique des critères déterminants
  Global Integer    GRUPT_FCY               # Indicateur de rupture de site
  Global Integer    GPRVSITUPD   # Issue 115019
  TRT_ERROR = 1

Return
#=====================================================================
$DEBUT # (Massif et Unitaire)

  Gosub ACTION From =TRTMODACT

  If !GBATCH
    #-> Effacement du masque paramètre
    Raz [M:LOFG]
  Endif
  #=> Raz de l'onglet de sélection avancée
  Raz [M:ASL]FLD1, [M:ASL]VAL1
  Raz [M:ASL]FLD2, [M:ASL]VAL2
  Raz [M:ASL]FLD3, [M:ASL]VAL3
  Raz [M:ASL]FLD4, [M:ASL]VAL4
  Raz [M:ASL]FLD5, [M:ASL]VAL5
  # Lancement de tâche batch.
  If GBATCH=1
    Affzo [LOFG]
  Endif

Return
#=====================================================================
$APRES_MODIF
  Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$SETBOUT                 # (Massif interactif et unitaire : )

  Gosub ACTION From =TRTMODACT
#
  If  ( [M:LOFG]GRPREF = "" )
    # On grise le bouton OK si le code de regroupement n'est pas renseigné
    If ( dim(CHBOU)>0 )   : Call VIREBOUT (CHBOU,"O") From GOBJET : Endif
  Endif

Return
#=====================================================================
$AP_CHOIX                 # (Unitaire : )
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$BOUTON                  # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$END_BOITE               # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
 GCONTROLE = G_NON

Return
#=====================================================================
$OK                      # (Massif intéractif et unitaire)
 Gosub ACTION From =TRTMODACT
 # --------------------------------
Return
#=====================================================================
$ABA

 Effzo [M:LOFG]
 Gosub DEBUT
 Gosub ACTION From =TRTMODACT

Return
#=====================================================================
$CONTROLE

If (GSERVEUR)
  Call ACTION_CPY ([M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)) From GLOFCYCPY
 Endif

Return
#=====================================================================
$CONT_BATCH
 # La prise en charge de la sauvegarde des paramétres qui ne se fait pas
 # dans le cas où l'action est incluse dans un groupe de tâche ou abonnée.
Return
#=====================================================================
$EXEC                    # (Massif intéractif et batch)

# Gosub ACTION From =TRTMODACT
If ABANDON_TRT : Return : Endif
 If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA] : Endif
 TRTYP=1 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2 #=> OUVERTURE de la trace
 FLGSIM=[M:MHC]FLGSIM
 FLGREP=[M:MHC]FLGREP
 FLGETA=[M:MHC]FLGETA
 FLGDET=[M:MHC]FLGDET
 #=> Variables nécessaires au traitement
 Local Char    MES(255)
 Local Integer ERR
 #=> Emission des informations relatives à l'action dans la trace :
 #-> Emssion dans la trace des options du traitement massif
 TRTYP=2  : TRPARM=1 : Gosub GESTRACE From TRCPROCOM2 #-> En-tête "option du traitement"
 TRTYP=25 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2 #-> Liste des options du traitement massif
 #-> Emission dans la trace des critères de sélection
 TRTYP=2  : TRPARM=2 : Gosub GESTRACE From TRCPROCOM2 #-> En-tête "En-tête critères de sélection"
 TRTYP=21 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2 #-> Emission dans la trace des critères de sélection
 #-> Emission dans la trace des paramètres de l'action
 TRTYP=2  : TRPARM=3 : Gosub GESTRACE From TRCPROCOM2  #-> Emission de l'en-tête "Paramètres de l'action" dans la trace
 TRTYP=20 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2  #-> Edition des paramètres dans la trace
 TRTYP=2  : TRPARM=4 : Gosub GESTRACE From TRCPROCOM2  #-> Emission de l'en-tête "Compte-rendu des modifications" dans la trace
 #-> Traitement de la population
 If ACTSTATUS=STA_DEBUT   #=> Cas 1 - Clic direct sur OK
  FLGREP=G_NON
  Gosub DEF_CRITERES_SEL
  Gosub SET_CRITERE From TRMPROACT
  If !GSERVEUR & ACTTYPGES=GTAMMAS & dim(ACTSILENCE)<0 : Call TEMPON('R') From GESECRAN : Endif
  Gosub LOCKER_POPULATION From TRMPROACT
  If !GSERVEUR & ACTTYPGES=GTAMMAS & dim(ACTSILENCE)<0 : Call TEMPOFF() From GESECRAN   : Endif
  If ACTSTATUS=STA_LOCK & !ERR
   Gosub MAJ_DIRECTE From TRTLOFGRPFAS
   If ERR
    Return
   Endif
  Else
   Return
  Endif
 Endif

Return
#=====================================================================
$FIN                     # ()
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$TERMINE                  # ()
 Gosub ACTION From =TRTMODACT

  Call FERME_BOITE From GESECRAN

  If dim(G_TRACE)       > 0    : Kill G_TRACE      : Endif
  If dim(G_NBLOF)       > 0    : Kill G_NBLOF      : Endif
  If dim(G_NBLOF_SEL)   > 0    : Kill G_NBLOF_SEL  : Endif
  If dim(G_NBLOF_TRT)   > 0    : Kill G_NBLOF_TRT  : Endif
  If dim(GCONTROLE)     > 0    : Kill GCONTROLE    : Endif
  If dim(RERROR)        > 0    : Kill RERROR       : Endif
  If dim(LMESSAGE)      > 0    : Kill LMESSAGE     : Endif
  If dim(TRT_ERROR)     > 0    : Kill TRT_ERROR    : Endif
  If dim(CRITSUPG1)     > 0    : Kill CRITSUPG1    : Endif
  If dim(CRITSUPG2)     > 0    : Kill CRITSUPG2    : Endif
  If dim(GORDGRP)       > 0    : Kill GORDGRP      : Endif
  If dim(GPARTYPPHY)    > 0    : Kill GPARTYPPHY      : Endif
  If dim(GRUPT_FCY)    > 0    : Kill GRUPT_FCY      : Endif

Return
#=====================================================================
$SORTIE
 Gosub ACTION From =TRTMODACT
Return
######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################
$ACTMET

 Case ACTMET
  When "AM_FLGCPY"          :   Gosub AM_FLGCPY            # M - pour pouvoir prendre la main en cas de changement de société
  When "SET_GLO_MAS"        :   Gosub SET_GLO_MAS
  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critère de sélection particulier à l'action métier
  When "FILL_HEA"           :   Gosub FILL_HEA             # U  - Alimentation partie spécifique en-tête

# Locker
  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # UM  - Exclusion élément de la population à sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet lié à l'enr en ligne de la population

# Charger
  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

# Applique_temp
  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Ouverture de tables annexes
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale
  When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       # UM - Application des paramètres de l'action aux enr de la table temporaire annexe

# Report_mask Report objet principal dans les masques (unitaire uniquement)
  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "TPF1_ALIM_MASK"     :   Gosub TPF1_ALIM_MASK       # U  - Tansfert table temporaire annexe     -> masques de l'écran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

# Applique_dirt Mise à jour directe (massif uniquement)
  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "CPY_APPL_DIRT"      :   Gosub CPY_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
 #When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à jour directe des tables de données avec les paramètres de l'action
  When "CLOS_APPL_DIRT"     :   Gosub CLOS_APPL_DIRT       # M  - Fin mise à jour directe
  When "END_APPL_DIRT"      :   Gosub END_APPL_DIRT        # M  - Fin de la mise à jour directe des tables de données avec les paramètres de l'action
# reporter
  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture tables annexes avant report tables tempo -> tables de données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> table de données
  When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      # UM - Report table temporaire par plan   -> table de données par plan

  When Default

 Endcase

Return
#=====================================================================
# Unitaire / massif :
$SET_GLO_MAS
Return
#=====================================================================
# Massif : pour prendre la main et remettre le mask à blanc dans le cas
# d'un changement de société
$AM_FLGCPY

  Raz [M:LOFG] : Affzo [M:LOFG]

Return
#=====================================================================
# Unitaire / massif : Critère de sélection particulier à l'action métier
$SET_CRITACT

    # CRITACT contient les critères de sélection suppplémentaires à appliquer à la population à sélectionner
    # On prend les dépenses immobilisables et validées
    CRITACT=" (FLGLIKAAS= 1 & FLGVAL=2) "
#  CRITACT += "(ISSDAT=[0/0/0] or EXTISSFLG=G_OUI) and "

Return
#=====================================================================
# Unitaire : Permet d'alimenter des zones spécifiques de l'en-tête de la fenêtre
$FILL_HEA
Return
#=====================================================================
# Unitaire et massif : Sert à ouvrir des tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK
  Gosub OUVRE_TABLES
Return
#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE

  # Lecture pour contrôle et exclusion eventuelle
  Read [LFG]LFG0=[M:LOFG]GRPREF
  If fstat or ([F:LFG]CPY <> [F:MAS1]CPY and [F:LFG]CPY <> "") GOK=0 : Return : Endif
  If [F:LFG]REQUETE <> "" : Endif

Return
#=====================================================================
# Unitaire / massif : Lock d'objet lié à l'enregistrement en ligne
#                     Alimenter RMES si un message soit apparaître
$MAS1_LOCK_AUTRE
Return
#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1
  # Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
  Gosub OUVRE_TABLES
Return
#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
$MAS1_ALIM_TMP1
Return
#=====================================================================
# Unitaire / massif : Ouverture de tables annexes
$OUVR_APPL_TMP1
Return
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1
Return
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1
Return
#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK
Return
#=====================================================================
# Unitaire : Permet de reporter les infos de TPF1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TPF1_ALIM_MASK
Return
#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
REAF_ALIM_MASK
Return
#=====================================================================
# Massif : Sert à ouvrir des tables utilisées dans MAS1_APPL_DIRT
$OUVR_APPL_DIRT

 If !clalev([M:LOF7])     : Global Mask LOFGRP [LOF7]  : Endif
 If !clalev([M:METH])     : Global Mask METH   [METH]  : Endif

 Gosub OUVRE_TABLES
 # Société courante : rupture société pour émission en-tête trace
 Local Char    TRC_CPY
 Local Char    TXTPROG(40)
 Local Integer NBLOF

 TXTPROG = mess(84,GML_MSGLOF,1)
 G_NBLOF   = NBOBJLCK
 Call TEMPOFF() From GESECRAN
 Call OUVRE_BOITE(TXTPROG, G_NBLOF) From GESECRAN
 Call SET_BOITE(TXTPROG, G_NBLOF) From GESECRAN

Return
#=====================================================================
# Massif : Sert à ouvrir des tables utilisées dans MAS1_APPL_DIRT
$CPY_APPL_DIRT

  Call GET_CNX_FROM_PLAN ([F:MAS1]CPY, G301CPT, WCNXCPT ) From GLOBIENS #Fq-77197
  Call GET_CNX_FROM_PLAN ([F:MAS1]CPY, G301IAS, WCNXIAS ) From GLOBIENS #Fq-77197

  If  WCNXCPT > 0
    Call GET_CNX_DAT([F:MAS1]CPY, WCNXCPT, WCNXDAT, WRET ) From GLOBIENS
  Endif
  If  WCNXIAS > 0
    Call GET_CNX_DAT([F:MAS1]CPY, WCNXIAS, WCNXDATI, WRET ) From GLOBIENS
  Endif
  #>Fq-88152  Chargement du masque de travail contenant le paramétrage comptable de la société
  Local Integer ERR
  Call LOAD_FASPARCPY([F:MAS1]CPY,"",G_NON,ERR) From GLOFCYCPY

Return
#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à jour directe
$MAS1_APPL_DIRT

 If ( G_TRACE = G_OUI) : Infbox "MAS1_APPL_DIRT" : Endif

Local Char    TXTPROG(40)
Local Integer NBLOF_TRT, LOK
Local Integer RTRN
Local Integer LCDRET, CDRET
Local Char    LCDINT(10)

#-> A rupture société on émet un en-tête dans la trace
  If ( [F:MAS1]CPY<>TRC_CPY )
    Gosub ECR_ENTETE
    TRC_CPY=[F:MAS1]CPY
    Raz G_NBLOF_TRT
  Endif

##-> A rupture site
  If ( [F:MAS1]FCY <> TRC_FCY )
    TRC_AASREF =[F:MAS1]CODLOF
    Raz G_NBLOF_TRT
    Raz G_NBLOF_ERR
  Endif

  G_NBLOF_TRT += 1
  TXTPROG    = mess(293,GML_MSGFAS,1)+[F:MAS1]CODLOF+'['+num$(G_NBLOF_TRT)+'/'+num$(G_NBLOF)+']'
  Call AFF_BOITE(TXTPROG,G_NBLOF_TRT,LOK) From GESECRAN

  If ( RTRN = 0 )
    Gosub ECR_LIGNE
    NBCPYMAJ += 1
  Endif

  If ( FLGSIM <> G_OUI and RTRN = 0 )
    Rewrite [MAS1]
    #-------------------
    If (fstat)
      # Erreur technique
      RMES= mess(104,GML_MSGFAS,1)+" LAYOUTFAS"+mess(105,GML_MSGFAS,1)+" 01"+mess(106,GML_MSGFAS,1)-[F:MAS1]CODLOF+"-"+num$([F:MAS1]LINLOF)
      GOK=0 : Return
      #-------------------
    Else
      # Génération des évènements
      Endif
      #---------------------
    Endif
    #-------------------

Return
#=====================================================================
