$GESTRACE
Local Char LDES
Local Integer I, LERROR, ERROR
Local    Char    LINE(GLONLINE) # Issue X3-99989
Local Integer IFIRST
Local Integer WLEN_LINE # Issue X3-99989
Local Char WCODZON(250) # Issue X3-99989

  Case TRTYP
    When 1         # Ouverture de la trace
      Call OUVRE_TRACE(mess(84,GML_MSGLOF,1),1) From TRACEABX3
    When 20        # Paramètres de l'action
       Local Char LCPY
       LCPY =[M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1)
       If !(clalev([F:LFG]))     : Local File FXDLOFGRP     [LFG]    : Endif
       Read [LFG]LFG0=[M:LOFG]GRPREF
       If fstat = 0
         Call ECR_TRACE("",GTRC_PARAM,left$(mess(86,GML_MSGLOF,1)+space$(32),32)+":"-[F:LFG]GRPREF+" : "+[F:LFG]DES,0,1) From TRACEABX3
         LINE = left$(mess(91,GML_MSGLOF,1)+space$(32),32)+": "
         WLEN_LINE = len(LINE) # Issue X3-99989
         For I=1 To [F:LFG]NBCRIT
           If [F:LFG]CODZON(I-1) <>  ""
# Issue X3-99989
#              LINE +=  num$([F:LFG]CODZON(I-1)) + " "
#              LINE += " - "
             WCODZON = num$([F:LFG]CODZON(I-1)) + " - "
             If len(LINE) + len(WCODZON) > GLONLINE
               Call ECR_TRACE("",GTRC_PARAM,LINE,0,1) From TRACEABX3
               LINE = space$(WLEN_LINE - 2) + ": " + WCODZON
             Else
               LINE +=  WCODZON
             Endif
# End Issue X3-99989
           Endif
        Next
        Call ECR_TRACE("",GTRC_PARAM,LINE,0,1) From TRACEABX3
        If CRITSUPG1 <> ""
           Call ECR_TRACE("",GTRC_PARAM,left$(mess(89,GML_MSGLOF,1)+space$(32),32)+": "-num$([F:LFG]REQUETE),0,1) From TRACEABX3
        Endif
        Call ECR_TRACE("",GTRC_PARAM,left$(mess(90,GML_MSGLOF,1)+space$(32),32)+": "-mess([F:LFG]PRILOF,GML_PRILOF,1),0,1) From TRACEABX3
        LINE = ""
        Call ECR_TRACE("",GTRC_PARAM,LINE,0,1) From TRACEABX3
        LIGNE = string$(41,"-")
        Call ECR_TRACE("",GTRC_PARAM,LIGNE,0,1) From TRACEABX3
        LIGNE = string$(41,"-")
       Endif
    When Default
  Endcase

Return

######################################################################
# Sous-pro et routines communes
######################################################################
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

 Case PACTTYP
   When GTAMUNI
     Infbox mess(1,GML_MSGACT,1)
   When GTAMMAS
     Local Char PARAM(30)(1..7)
     Local Char VALEUR
     PARAM(1)=GTAMMAS             # Massif / unitaire
     PARAM(2)="LOFGRPFAS"         # Nom de l'action métier
     PARAM(3)=num$(GVML_OMDEPEN)  # Objet métier de référence
     PARAM(4)=num$(G_OUI)         # Mono société
     PARAM(5)=num$(G_NON)         # Plan d'amortissement
     #  Traitement      Fenêtre
     Call TRAITE_CHAR(VALEUR,PARAM,"","TRTLOFGRPFAS","LOFGRPFAS",3,"") From GTRAITE
   When Default
  Endcase

End
########################################
#       TRAITEMENTS METIERS
########################################

#=====================================================================
# Traitement métier principal
#**
#*=============================================================================
#* Définition et alimentation des critères de sélection
#*=============================================================================
#*!
$DEF_CRITERES_SEL
Global Char    CRITSUPG1(255)                  # Sélection avancée de l'objet Code regroupement
Global Char    CRITSUPG2(255)                  # Sélection Expression de l'objet Code regroupement
Global Char    GORDGRP (255)                   # Critères de tri des dépenses sélectionnées
#Global Char    LCONDA(250)(2)                  # Pour pouvoir dépasser la limite des 255 caractères par chaine, # # Issue X3-99989
Global Clbfile    LCONDA                       # Pour pouvoir dépasser la limite des 255 caractères par chaine, # # Issue X3-99989

Local Integer N_I, N_J

  Raz CRITSUPG1, CRITSUPG2
  # Récupération des critères de sélection et de regroupement stockés dans la table FXDLOFGRP [LFG]
  Read [LFG]LFG0=[M:LOFG]GRPREF
  If fstat=0
     [M:LOFG]GRPDES = [F:LFG]DES
     G_PRILOF = [F:LFG]PRILOF
     # Construction critère supplémentaire (onglet de la fenêtre OLGT)
     If ( [F:LFG]EXP1 <> "" )
        CRITSUPG2=[F:LFG]EXP1
     Else
        CRITSUPG2="1=1"
     Endif
     If ( [F:LFG]REQUETE <> "" )
        CRITSUPG1=[F:LFG]REQUETE
     Else
        CRITSUPG1="1=1"
     Endif
  Endif

  For N_I = 1 To [F:LFG]NBCRIT
    #------------------------------
    # Champ dimensionné : on supprime les parenthèse pour récupérer le type physique correctement
    Local Char LFIELD
    If pat([F:LFG]CODZON(N_I-1),"*(*")
     LFIELD=seg$([F:LFG]CODZON(N_I-1),1,instr(1,[F:LFG]CODZON(N_I-1),'(')-1)
    Else
     LFIELD=[F:LFG]CODZON(N_I-1)
    Endif
    #------------------------------
    GPARTYPPHY(N_I-1) = func GLOBIENS.GET_TYPE_PHYSIQUE ("LAYOUTFAS", LFIELD)
    #------------------------------
    # Suite de la boucle
  Next N_I

  # Récupération des critères de regroupement des dépenses
  GORDGRP = ""
  LCONDA = ""

  N_J = 0
  N_I = 1

  For N_I=1 To [F:LFG]NBCRIT
    If [F:LFG]CODZON (N_I-1) <> ""
      If N_I=1
        GORDGRP += [F:LFG]CODZON(N_I-1)
      Else
        GORDGRP += "; "+[F:LFG]CODZON(N_I-1)
      Endif
# Issue X3-99989
#      If ( len(LCONDA(N_J)) > 180 )
#        # La chaine est pleine, on change d'occurence
#        N_J += 1
#        If ( N_J > 1 )
#          # Plus de place pour stocker les critères
#          # Trop de critères dans le paramétrage "Regroupement des dépenses".
#          Call MESSAGE(mess(66,GML_MSGLOF,1)) From GESECRAN
#          LCONDA(N_J-1)="1=0" : # on empêche toute sélection de dépenses supplémentaires
#          Break
#        Endif
#      Endif
#      If ( LCONDA(N_J) <> "" )
      If LCONDA <> ""
        LCONDA += "&"
      Endif
      # Champ dimensionné : on supprime les parenthèse pour récupérer le type physique correctement
      Local Char LFIELD
      LFIELD=[F:LFG]CODZON(N_I-1)
      If (  GPARTYPPHY(N_I-1) > 0 )
        LCONDA += "("
      Endif
      LCONDA += "[F:MAS1]" + [F:LFG]CODZON(N_I-1) + "=" + "[F:LOFP]" + [F:LFG]CODZON(N_I-1)
      LCONDA += ")"
# End Issue X3-99989
    Endif
  Next

Return
#===================
$ALIM_LOF7
#===================
Local Char    LCOND(250)
Local Char    LCOND1(250)
Local Char    LCODLOF
Local Integer LLINLOF
Local Integer I
Local Integer STAT
Local Decimal MTDES
#Local Decimal RIASRATCUR           : # FQ88052
Local Integer DIFF_RATVAT
#Local Decimal L_AMTVATIAS           : # FQ84794 Montant de TVA IAS          FQ98116
#Local Decimal L_AMTVATRIAS          : # FQ84794 Montant de TVA récupéré IAS FQ98116

  If [M:LOF7]NBDEST = 0
    NOL=1
    [M:LOF7]CPY = [F:MAS1]CPY
    [M:LOF7]FCY = [F:MAS1]FCY
    [M:LOF7]ACT = [F:MAS1]ACT
  Else
    NOL= [M:LOF7]NBDEST+1
  Endif

  [M:LOF7]CODLOF(NOL-1)     = [F:MAS1]CODLOF
  [M:LOF7]LINLOF(NOL-1)     = [F:MAS1]LINLOF
  [M:LOF7]DATVCR(NOL-1)     = [F:MAS1]DATVCR
  [M:LOF7]DATIMP(NOL-1)     = [F:MAS1]DATIMP
  [M:LOF7]GAC(NOL-1)        = [F:MAS1]GAC
  [M:LOF7]GACACN(NOL-1)     = [F:MAS1]GACACN
  [M:LOF7]IASACC(NOL-1)     = [F:MAS1]IASACC
  [M:LOF7]IASACN(NOL-1)     = [F:MAS1]IASACN
  [M:LOF7]AMTNOTCPY(NOL-1)  = [F:MAS1]AMTNOTCPY
  [M:LOF7]RATVAT(NOL-1)     = [F:MAS1]RATVAT
  [M:LOF7]DEVSOC            = [F:MAS1]CUR
  [M:LOF7]DES(NOL-1)        = [F:MAS1]DES
  [M:LOF7]ACGGRP(NOL-1)     = [F:MAS1]ACGGRP
  If [M:LOF7]MAIVCR(NOL-1) = G_OUI
    [M:LOF7]ACGGRPV        = [M:LOF7]ACGGRP(NOL-1)
    [M:LOF7]GACV           = [M:LOF7]GAC(NOL-1)
    [M:LOF7]GACACNV        = [M:LOF7]GACACN(NOL-1)
    [M:LOF7]IASACCV        = [M:LOF7]IASACC(NOL-1)
    [M:LOF7]IASACNV        = [M:LOF7]IASACN(NOL-1)
  Endif
  [M:LOF7]QTY(NOL-1)       = [F:MAS1]QTY
  [M:LOF7]DEVIAS           = GCNXCURIAS
  If [M:LOF7]GACACN(NOL-1) = GVML_NIENCOU or [M:LOF7]GACACN(NOL-1) = GVML_NIENSER
     [M:LOF7]CUMPREVCR    +=  [F:MAS1]AMTNOTCPY
     [M:LOF7]CUMVATAMT    +=  [F:MAS1]AMTVATCPY
     [M:LOF7]CUMDVATAMT   +=  [F:MAS1]AMTVATRCPY
  Endif

  # DEBUT FQ84794
  If ( GCNXPROIAS = G_OUI )
    If [M:LOF7]IASACN(NOL-1) = GVML_NIENCOU or [M:LOF7]IASACN(NOL-1) = GVML_NIENSER
      If [F:MAS1]AMTNOTIAS = 0
        # Gestion de l'IAS
        If [F:MAS1]CUR = GCNXCURIAS
          # Même devise que la devise pièce
          [M:LOF7]AMTNOTIAS(NOL-1)  = [F:MAS1]AMTNOTCUR
          [M:LOF7]AMTVATIAS(NOL-1)  = [F:MAS1]AMTVATCUR  : # FQ98116
          [M:LOF7]AMTVATRIAS(NOL-1) = [F:MAS1]AMTVATRCUR : # FQ98116
        Elsif GCNXCURIAS = GCNXCURCPF
          [M:LOF7]AMTNOTIAS(NOL-1)  = [F:MAS1]AMTNOTCPY
          [M:LOF7]AMTVATIAS(NOL-1)  = [F:MAS1]AMTVATCPY  : # FQ98116
          [M:LOF7]AMTVATRIAS(NOL-1) = [F:MAS1]AMTVATRCPY : # FQ98116
        Else
          [M:LOF7]AMTNOTIAS(NOL-1) = 0
          Call CONVERT3([F:MAS1]CUR,
&                       GCNXCURIAS,
&                       GCNXCURCPF,
&                       [F:MAS1]CURTYP,
&                       [F:MAS1]DATVCR,
&                       [F:MAS1]AMTNOTCUR,
&                       [M:LOF7]AMTNOTIAS(NOL-1),
&                       0,
&                       STAT) From CPTSUB
          If STAT
            Infbox(mess(34,110,1)-[F:MAS1]CODLOF-num$([F:MAS1]LINLOF)-[F:MAS1]CUR-GCNXCURIAS-num$(STAT))
          Endif
          Call GET_MNT_ARRONDI ([M:LOF7]AMTNOTIAS(NOL-1), GCNXCURIAS, [M:LOF7]AMTNOTIAS(NOL-1)) From GLOBIENS
          #--------------------------------------- FQ98116
          Call CONVERT3([F:MAS1]CUR,
&                       GCNXCURIAS,
&                       GCNXCURCPF,
&                       [F:MAS1]CURTYP,
&                       [F:MAS1]DATVCR,
&                       [F:MAS1]AMTVATCUR,
&                       [M:LOF7]AMTVATIAS(NOL-1),
&                       0,
&                       STAT) From CPTSUB
          If STAT
            Infbox(mess(34,110,1)-[F:MAS1]CODLOF-num$([F:MAS1]LINLOF)-[F:MAS1]CUR-GCNXCURIAS-num$(STAT))
          Endif
          Call GET_MNT_ARRONDI ([M:LOF7]AMTVATIAS(NOL-1), GCNXCURIAS, [M:LOF7]AMTVATIAS(NOL-1)) From GLOBIENS
          #--------------------------------------- FQ98116
          Call CONVERT3([F:MAS1]CUR,
&                       GCNXCURIAS,
&                       GCNXCURCPF,
&                       [F:MAS1]CURTYP,
&                       [F:MAS1]DATVCR,
&                       [F:MAS1]AMTVATRCUR,
&                       [M:LOF7]AMTVATRIAS(NOL-1),
&                       0,
&                       STAT) From CPTSUB
          If STAT
            Infbox(mess(34,110,1)-[F:MAS1]CODLOF-num$([F:MAS1]LINLOF)-[F:MAS1]CUR-GCNXCURIAS-num$(STAT))
          Endif
          Call GET_MNT_ARRONDI ([M:LOF7]AMTVATRIAS(NOL-1), GCNXCURIAS, [M:LOF7]AMTVATRIAS(NOL-1)) From GLOBIENS
        Endif
      Else
        [M:LOF7]AMTNOTIAS(NOL-1)  = [F:MAS1]AMTNOTIAS
        [M:LOF7]AMTVATIAS(NOL-1)  = [F:MAS1]AMTVATIAS  : # FQ98116
        [M:LOF7]AMTVATRIAS(NOL-1) = [F:MAS1]AMTVATRIAS : # FQ98116
      Endif

      [M:LOF7]CUMPREIAS += [M:LOF7]AMTNOTIAS(NOL-1)

      #L_AMTVATIAS = [M:LOF7]AMTNOTIAS(NOL-1) * ([F:MAS1]RATVAT / 100 )
      #Call GET_MNT_ARRONDI (L_AMTVATIAS, GCNXCURIAS, L_AMTVATIAS) From GLOBIENS
      #[M:LOF7]CUMVATIAS += L_AMTVATIAS
      [M:LOF7]CUMVATIAS += [M:LOF7]AMTVATIAS(NOL-1) : # FQ98116

      #L_AMTVATRIAS = L_AMTVATIAS * ([F:MAS1]RATVATREC / 100 )
      #Call GET_MNT_ARRONDI (L_AMTVATRIAS, GCNXCURIAS, L_AMTVATRIAS) From GLOBIENS
      #[M:LOF7]CUMDVATIAS += L_AMTVATRIAS
      [M:LOF7]CUMDVATIAS += [M:LOF7]AMTVATRIAS(NOL-1) : # FQ98116
    Endif
  Endif
  # FIN FQ84794

  #[F:FAS]IASRATCUR= RIASRATCUR : # FQ88052
  [M:LOF7]NBDEST = NOL


Return
# ------------------------------------------------------------------------------------------
# Traitement de chaque regroupement de dépenses en fonction du code regroupement
# ------------------------------------------------------------------------------------------
$CREAT_AUTO_FAS

Local Integer FLGASS

  Sorta  [M:LOF7]NBDEST [M:LOF7]NBDEST Order By [M:LOF7]CODLOF([S]indice),[M:LOF7]LINLOF([S]indice) Asc
  If G_PRILOF = GVML_HTMAX
    Sorta  [M:LOF7]NBDEST [M:LOF7]NBDEST Order By [M:LOF7]AMTNOTCPY([S]indice) Desc
  Endif
  If G_PRILOF = GVML_DATVCRR
    Sorta  [M:LOF7]NBDEST [M:LOF7]NBDEST Order By [M:LOF7]DATVCR([S]indice) Desc
  Endif
  If G_PRILOF = GVML_DATVCRO
    Sorta  [M:LOF7]NBDEST [M:LOF7]NBDEST Order By [M:LOF7]DATVCR([S]indice) Asc
  Endif
  If G_PRILOF = GVML_DATIMPR
    Sorta  [M:LOF7]NBDEST [M:LOF7]NBDEST Order By [M:LOF7]DATIMP([S]indice) Desc
  Endif
  If G_PRILOF = GVML_DATIMPO
     Sorta  [M:LOF7]NBDEST [M:LOF7]NBDEST Order By [M:LOF7]DATIMP([S]indice) Asc
  Endif

  [M:LOF7]MAIVCR(0) = G_OUI
  For I=1 To [M:LOF7]NBDEST-1
      [M:LOF7]MAIVCR(I) = G_NON
  Next

  DIFF_RATVAT = G_NON

  For I=1 To [M:LOF7]NBDEST-1
    If [M:LOF7]RATVAT(I) <> [M:LOF7]RATVAT(0)
      DIFF_RATVAT = G_OUI
      Break
    Endif
  Next

  [M:LOF7]ACGGRPV     = [M:LOF7]ACGGRP(0)
  [M:LOF7]GACV        = [M:LOF7]GAC(0)
  [M:LOF7]GACACNV     = [M:LOF7]GACACN(0)
  [M:LOF7]IASACCV     = [M:LOF7]IASACC(0)
  [M:LOF7]IASACNV     = [M:LOF7]IASACN(0)
  [M:LOF7]ACCCODV     = [M:LOF7]ACCCOD(0)

  Local Integer I_PRI, N_LOF
  Raz[FAS]
  # Traitement de chaque regroupement de dépenses : stockés dans le masque LOF7
  # ------------------------------------------------------------------------------------------
  # Initialisation de certains champs
  [F:FAS]OWNTYP  = GVML_TDPROPR       # Type détention = "En propriété"
  [F:FAS]PURNAT     = 1               # Etat = "Neuf"
  [F:FAS]ETRNAT     = 1               # Nature d'entrée = "Achat"
  [F:FAS]AASTYP     = 1               # Type immo = "Corporel"
  [F:FAS]STABILTYP  = 1               # Type stabilité = "Fixe"
  [F:FAS]CMPSTA     = 1               # Statut = "Autonome"
  [F:FAS]TAXTYP     = 1               # Type de taxe = "BNTPF"
  [F:FAS]THESLI     = 5               # Durée de détention théorique du bien  #*FQ100085

  #*FQ100085
  If GKFR = G_OUI
     # Détermination de la durée pour régularisation TVA
     Call EVAL_PERIODE_REGUL_TVA([F:FAS]TAXTYP,[F:FAS]PURDAT,[F:FAS]THESLI) From TRTFAS
   Endif #*FQ100085 END

    [F:FAS]ADMCOE     = 1               # Coefficient d'admission = 1
    Read[LOFP]LOF0=[M:LOF7]CODLOF(0); [M:LOF7]LINLOF(0)
    If fstat=0
      [F:FAS] = [F:LOFP]
      #*FQ99561 The free fields will be fed in LOAD_FREEFLD with setup for free field loading
      [F:FAS]USRFLDA1 = ""
      [F:FAS]USRFLDA2 = ""
      [F:FAS]USRFLDA3 = ""
      [F:FAS]USRFLDA4 = ""
      [F:FAS]USRFLDA5 = ""
      [F:FAS]USRFLDA6 = ""
      [F:FAS]USRFLDA7 = ""
      [F:FAS]USRFLDA8 =""
      [F:FAS]USRFLDA9 = ""
      [F:FAS]USRFLDA10 = ""
      [F:FAS]USRFLDM1 = 0
      [F:FAS]USRFLDM2 = 0
      [F:FAS]USRFLDM3 = 0
      [F:FAS]USRFLDM4 = 0
      [F:FAS]USRFLDM5 = 0
      [F:FAS]USRFLDM6 = 0
      [F:FAS]USRFLDC1 = 0
      [F:FAS]USRFLDC2 = 0
      [F:FAS]USRFLDD1 = [0/0/0]
      [F:FAS]USRFLDD2 = [0/0/0]
      [F:FAS]USRFLDD3 = [0/0/0]
      [F:FAS]USRFLDD4 = [0/0/0]
      #*FQ99561 END

      [F:FAS]AASDES1       = [F:LOFP]DES
      [F:FAS]AASDES2       = [F:LOFP]DES2
      [F:FAS]CPY           = [F:LOFP]CPY
      [F:FAS]FCY           = [F:LOFP]FCY
      [F:FAS]ENAFAS        = G_OUI
      [F:FAS]ORDREF        = [F:LOFP]ORDBUY
      [F:FAS]PURDAT        = [F:LOFP]DATVCR
      [F:FAS]ITSDAT        = [F:LOFP]DATVCR
      [F:FAS]AASIPTDAT     = [F:LOFP]DATIMP
      [F:FAS]AASUOM        = [F:LOFP]UOM
      [F:FAS]AASQTY        = [F:LOFP]QTY
      [F:FAS]BPR           = [F:LOFP]BPR
      [F:FAS]AASBUS        = [F:LOFP]ACT
      [F:FAS]ACGCUR        = [F:LOFP]CUR
      [F:FAS]INVPLN        = [F:LOFP]PLNINV
      [F:FAS]BUDREF        = [F:LOFP]BUDINV
      [F:FAS]BUDFIY        = [F:LOFP]FIYBUD
      [F:FAS]INVREQ        = [F:LOFP]DEMINV
      [F:FAS]ASJCOE        = [F:LOFP]ASJCOE
      [F:FAS]TAXCOE        = [F:LOFP]TAXCOE
      [F:FAS]TAXCOEFLG     = [F:LOFP]TAXCOEFLG
      [F:FAS]ADMCOE        = [F:LOFP]ADMCOE

      Call TVA_COE_DEDUCTION ( [F:FAS]ASJCOE, [F:FAS]TAXCOE, [F:FAS]ADMCOE, [F:FAS]DEDCOE ) From TRTFAS
      # FQ98116 : on prend les taux de la dépense principale
      ## Si au moins 2 dépenses ont des taux de TVA facturée différents
      ## ==> le taux de TVA facturée du bien créé sera égal zéro
      #If DIFF_RATVAT <> G_OUI
      #[F:FAS]IVCVATRAT     = [F:LOFP]RATVAT
      #Else
      #   [F:FAS]IVCVATRAT     = 0
      #Endif
      # On force les montants de TVA
      [F:FAS]IVCVATFLG     = G_OUI
      [F:FAS]DEDVATFLG     = G_OUI
      [F:FAS]IVCVATRAT     = [F:LOFP]RATVAT     : # FQ98116 : on prend les taux de la dépense principale
      [F:FAS]DEDVATRAT     = [F:LOFP]RATVATREC
      [F:FAS]ACGETRNOT     = [M:LOF7]CUMPREVCR
      [F:FAS]IVCVATAMT     = [M:LOF7]CUMVATAMT
      [F:FAS]DEDVATAMT     = [M:LOF7]CUMDVATAMT

      If GCNXPROIAS = G_OUI
        # Détermination du cours devise IAS : FQ88052
        Call CDVCAL([F:FAS]IASRATCUR, GCNXCURCPF, GCNXCURIAS, [F:FAS]CPY, GIASCURTYP,
&                   [F:FAS]PURDAT ) From TRTDIV

        # FQ98116 : on prend les taux de la dépense principale
        ## Si au moins 2 dépenses ont des taux de TVA facturée différents
        ## ==> le taux de TVA facturée du bien créé sera égal zéro
        #If DIFF_RATVAT <> G_OUI
        #[F:FAS]IVCVATRATI     = [F:LOFP]RATVAT
        #Else
        #  [F:FAS]IVCVATRATI     = 0
        #Endif
        # On force les montants de TVA
        [F:FAS]IVCVATFLGI     = G_OUI
        [F:FAS]DEDVATFLGI     = G_OUI
        [F:FAS]IVCVATRATI     = [F:LOFP]RATVAT     : # FQ98116 : on prend les taux de la dépense principale
        [F:FAS]DEDVATRATI     = [F:LOFP]RATVATREC
        [F:FAS]IASETRNOT      = [M:LOF7]CUMPREIAS
        [F:FAS]IVCVATAMTI     = [M:LOF7]CUMVATIAS
        [F:FAS]DEDVATAMTI     = [M:LOF7]CUMDVATIAS
      Endif

      # On recalcule le coff de déduction
      Local Decimal TXTVAREC
      Call TVA_COE_DEDUCTION ( [F:FAS]ASJCOE,[F:FAS]TAXCOE, [F:FAS]ADMCOE, TXTVAREC ) From TRTFAS
      [F:FAS]DEDCOE = TXTVAREC
      TXTVAREC = TXTVAREC * 100.
      If ( [F:FAS]DEDVATRAT <> TXTVAREC )
        [F:FAS]DEDVATRAT = TXTVAREC
      Endif
      If (GCNXPROIAS = G_OUI)
        [F:FAS]DEDVATRATI = TXTVAREC
      Endif
  Endif
  # - on récupère les imputations comptables de la dépense principale

  Call RECUP_CODE_COMPTABLE ()
  [M:LOF7]ACCCOD   =  [M:LOF7]ACCCODV
  [F:FAS]ACCCOD    =  [M:LOF7]ACCCODV
  [F:FAS]GACACN    =  [M:LOF7]GACACNV
  [F:FAS]GAC       =  [M:LOF7]GACV
  [F:FAS]IASACN    =  [M:LOF7]IASACNV
  [F:FAS]IASACC    =  [M:LOF7]IASACCV
  [F:FAS]ACGGRP    =  [M:LOF7]ACGGRPV
  # Récupération des valeurs définies par association dans [M:LOF7]
  Call GERER_ASSOCIATION([M:LOF7]ACGGRPV,"FAM","FAS",[F:FAS]OWNTYP,"LOFGRPFASM",FLGASS) From TRTASSO
  If [M:LOF7]ACCCOD <> ""
     Call GERER_ASSOCIATION([M:LOF7]ACCCOD ,"COD","FAS",[F:FAS]OWNTYP, "LOFGRPFASM",FLGASS) From TRTASSO
  Endif

  # Report des valeurs dans [FAS]
  If [M:LOF7]AASTYP > 0        : [F:FAS]AASTYP      =  [M:LOF7]AASTYP     : Endif
  If [M:LOF7]ACCCOD <>""       : [F:FAS]ACCCOD      =  [M:LOF7]ACCCOD     : Endif
  If [M:LOF7]ADMCOE <> 0       : [F:FAS]ADMCOE      =  [M:LOF7]ADMCOE     : Endif
  If [M:LOF7]TAXTYP > 0        : [F:FAS]TAXTYP      =  [M:LOF7]TAXTYP     : Endif
  If [M:LOF7]STABILTYP > 0     : [F:FAS]STABILTYP   =  [M:LOF7]STABILTYP  : Endif
  If [M:LOF7]CMPSTA <> 0       : [F:FAS]CMPSTA      =  [M:LOF7]CMPSTA     : Endif

  # Issue 117740 Zones libres : MAJ de [FAS] avec résultat des associations
  If [M:LOF7]USRFLDA1 <> ""  : [F:FAS]USRFLDA1   =  [M:LOF7]USRFLDA1  : Endif
  If [M:LOF7]USRFLDA2 <> ""  : [F:FAS]USRFLDA2   =  [M:LOF7]USRFLDA2  : Endif
  If [M:LOF7]USRFLDA3 <> ""  : [F:FAS]USRFLDA3   =  [M:LOF7]USRFLDA3  : Endif
  If [M:LOF7]USRFLDA4 <> ""  : [F:FAS]USRFLDA4   =  [M:LOF7]USRFLDA4  : Endif
  If [M:LOF7]USRFLDA5 <> ""  : [F:FAS]USRFLDA5   =  [M:LOF7]USRFLDA5  : Endif
  If [M:LOF7]USRFLDA6 <> ""  : [F:FAS]USRFLDA6   =  [M:LOF7]USRFLDA6  : Endif
  If [M:LOF7]USRFLDA7 <> ""  : [F:FAS]USRFLDA7   =  [M:LOF7]USRFLDA7  : Endif
  If [M:LOF7]USRFLDA8 <> ""  : [F:FAS]USRFLDA8   =  [M:LOF7]USRFLDA8  : Endif
  If [M:LOF7]USRFLDA9 <> ""  : [F:FAS]USRFLDA9   =  [M:LOF7]USRFLDA9  : Endif
  If [M:LOF7]USRFLDA10 <> "" : [F:FAS]USRFLDA10  =  [M:LOF7]USRFLDA10 : Endif
  ## Issue 115015   Gosub LOAD_FREEFLD
  # Issue 117740 - On applique ensuite le paramétrage d'alimentation des zones libres
  Gosub LOAD_FREEFLD
  If [F:FAS]USRFLDA1  = ""  :   [F:FAS]USRFLDA1  =  [M:LOF7]USRFLDA1   : Endif
  If [F:FAS]USRFLDA2  = ""  :   [F:FAS]USRFLDA2  =  [M:LOF7]USRFLDA2   : Endif
  If [F:FAS]USRFLDA3  = ""  :   [F:FAS]USRFLDA3  =  [M:LOF7]USRFLDA3   : Endif
  If [F:FAS]USRFLDA4  = ""  :   [F:FAS]USRFLDA4  =  [M:LOF7]USRFLDA4   : Endif
  If [F:FAS]USRFLDA5  = ""  :   [F:FAS]USRFLDA5  =  [M:LOF7]USRFLDA5   : Endif
  If [F:FAS]USRFLDA6  = ""  :   [F:FAS]USRFLDA6  =  [M:LOF7]USRFLDA6   : Endif
  If [F:FAS]USRFLDA7  = ""  :   [F:FAS]USRFLDA7  =  [M:LOF7]USRFLDA7   : Endif
  If [F:FAS]USRFLDA8  = ""  :   [F:FAS]USRFLDA8  =  [M:LOF7]USRFLDA8   : Endif
  If [F:FAS]USRFLDA9  = ""  :   [F:FAS]USRFLDA9  =  [M:LOF7]USRFLDA9   : Endif
  If [F:FAS]USRFLDA10 = ""  :   [F:FAS]USRFLDA10 =  [M:LOF7]USRFLDA10  : Endif
  # End  Issue 117740

  #+FQ99561 --------------------
   [F:FAS]USRFLDM1    =  [M:LOF7]USRFLDM1
   [F:FAS]USRFLDM2    =  [M:LOF7]USRFLDM2
   [F:FAS]USRFLDM3    =  [M:LOF7]USRFLDM3
   [F:FAS]USRFLDM4    =  [M:LOF7]USRFLDM4
   [F:FAS]USRFLDM5    =  [M:LOF7]USRFLDM5
   [F:FAS]USRFLDM6    =  [M:LOF7]USRFLDM6
   [F:FAS]USRFLDC1    =  [M:LOF7]USRFLDC1
   [F:FAS]USRFLDC2    =  [M:LOF7]USRFLDC2
   [F:FAS]USRFLDD1    =  [M:LOF7]USRFLDD1
   [F:FAS]USRFLDD2    =  [M:LOF7]USRFLDD2
   [F:FAS]USRFLDD3    =  [M:LOF7]USRFLDD3
   [F:FAS]USRFLDD4    =  [M:LOF7]USRFLDD4
  #+FQ99561 END --------------------

  # Si on ne récupère pas de code comptable et/ou pas de compte comptable ==> on ne traite pas le bien
  # et message d'erreur dans la trace
  If [F:FAS]ACCCOD = ""
    # Aucun code comptable n'a été trouvé pour ce compte :
    RMES=mess(92,GML_MSGLOF,1)+[F:LOFP]CODLOF+"-"+num$([F:LOFP]LINLOF)-" ==> "-mess(71,GML_MSGLOF,1)+": "-num$([M:LOF7]GACV)
    Call ECR_TRACE([F:MAS1]CPY,GTRC_CRERREU, RMES,-1,1) From TRACEABX3
    GOK=0
    Goto END_FAS
  Endif
  # Champs de l'onglet Entrée/sortie
  [F:FAS]GALREFDAT =  [F:FAS]PURDAT
  # Alimentation de la Numérotation automatique du bien
  If ( GAASAUTNUM = GVML_OBLIG or GAASAUTNUM = GVML_FACUL )
    Local Integer STAT
    Local Char    WCNUMERO
    # Appel du compteur de document
    Call GET_NUMERO("FAS",GVML_NUMAAS-1,1,[M:LOF7]CPY,[M:LOF7]FCY,date$,WCNUMERO,STAT)  From GLOBIENS
    If ( STAT )   : GOK = 0 : Return : Endif
    If WCNUMERO <> ""
      [F:FAS]AASREF   = WCNUMERO
      [F:FAS]SET = WCNUMERO
    Endif
  Endif

  Gosub CALCUL_VALEUR_BILAN From TRTLOFGRPFAS
#
  If FLGSIM <> G_OUI
    [F:FAS]FLGCLC = G_OUI   # Bien à calculer
    For [CNX] Where CPY=[F:FAS]CPY
       [F:FAS]FLGCNXCLC([F:CNX]CNX-1) = G_OUI
     Next
   Endif

  #------------------------------ FQ94306
  GPOINT = "LOFTOFAS" : Gosub ENTREE From EXEFNC

  [F:FAS]CREDAT = date$
  [F:FAS]UPDDAT = date$
  [F:FAS]CREUSR = GUSER
  [F:FAS]UPDUSR = GUSER
  [F:FAS]CREORI = GVML_CORGLOF
 #- Si simulation : prépa de la trace -----------------------
  If ( FLGDET = G_OUI ) and FLGSIM = G_OUI
    Gosub TRC_CRITRUPT
    Gosub TRACE_FAS
  Endif

  #*FQ100085 : initialisation FLGCNXFLX pour gestion des flux
  Call INIFLGCNXFLX("[F:FAS]") From TRTFAS

  #*FQ100085  Récupération date début exercice du contexte Comptable et Fiscal
  If GKFR = G_OUI
     Local Date    WDDATE(1..5)
     Local Integer WICODERET
     Call GET_CNX_DAT([F:FAS]CPY,1,WDDATE,WICODERET) From GLOBIENS
     [F:FAS]VATREGDAT =[F:FAS]PURDAT
     [F:FAS]GALREFDAT =[F:FAS]PURDAT
     [F:FAS]VATRSD = func TRTFAS.TVA_GET_PERIODE_RESID( [F:FAS]THESLI, [F:FAS]VATREGDAT, WDDATE(1) )
  Endif #*FQ100085  END

  # Issue 115019 : Si remise en cause situation antérieure = "non"
  If ( GPRVSITUPD = G_NON ) and not ( func TRTFAS.IS_SUPEG_EXC ([F:LOFP]CPY, [F:LOFP]DATIMP, 0) )
    #"La date de comptabilisation doit être >= aux dates de début des exercices courants des contextes"
    RMES= "Dépense principale : "-num$([F:LOFP]CODLOF)-"/"-num$([F:LOFP]LINLOF)-" ==> "-mess(494, GML_MSGFAS,1)
    Call ECR_TRACE([F:LOFP]CPY,GTRC_CRERREU, RMES,1,1) From TRACEABX3
    GOK=0
  Endif # End Issue 115019

  If GOK # Issue 115019
    Write [F:FAS]
    If fstat
      Case fstat
        When 1
          RMES=mess(226,GML_MSGFAS,1)-[F:FAS]AASREF  # "Enregistrement en cours d'utilisation"
          GOK=-1
        When 3
          RMES=mess(129,GML_MSGFAS,1)-[F:FAS]AASREF
          GOK=0
        When Default
      Endcase
      Call ECR_TRACE_ERREUR([F:FAS]CPY, [F:MAS1]CODLOF, 0, G_OUI, RMES) From TRCPROCOM
    Endif

    Gosub ALIM_PLANS_AMT
  Endif # Issue 115019

  #- 2 -----------------------
  If ( FLGDET = G_OUI ) and   FLGSIM <> G_OUI
    Gosub TRC_CRITRUPT
    Gosub TRACE_FAS
  Endif

  Gosub MARQUE_DEPENSE_LIEES

  $END_FAS

  If RMES <> "" and [M:LOF7]NBDEST > 0
     NBCPYERR += [M:LOF7]NBDEST
     RMES=""
  Endif

  [M:LOF7]NBDEST = 0
  Raz [M:LOF7]

Return

#*****************************
$MAJ_DIRECTE

 If !GSERVEUR & dim(ACTSILENCE)<0 : Call OUVRE_BOITE(mess(14,GML_MSGACT,1),NBOBJLCK) From GESECRAN  : Endif
 If !GSERVEUR & dim(ACTSILENCE)<0 : Call SET_BOITE(mess(17,GML_MSGACT,1),NBOBJLCK) From GESECRAN    : Endif

 Call APPLIQUE_DIRT(CRITSUPR,CRITOBJ,CRITACT,CRITSUP1,TABOBJ,MES,ERR) From TRTLOFGRPFAS

 If !GSERVEUR & dim(ACTSILENCE)<0 : Call FERME_BOITE() From GESECRAN : Endif

Return
#========================================================================
#
Subprog APPLIQUE_DIRT(PCRIT1,PCRIT2,PCRIT3,PCRIT4,PTABLE,RMES,RERR)
#
# Sous-programme permettant de mettre à jour les enregistrements des tables
# de données avec les paramètres de l'action métier
# les codes erreurs retournés sont les suivants :
# 0    Pas d'erreur
# ------------------------------------------------------------------------------
Value    Char    PCRIT1      # Critère 1 -> Critère tous objets
Value    Char    PCRIT2      # Critère 2 -> Critère pour toutes les actions d'un objet
Value    Char    PCRIT3      # Critère 3 -> Critère propre à l'action
Value    Char    PCRIT4      # Critère 4 -> Critère supplémentaire (Spécifique massif)
Value    Char    PTABLE      # Table sur laquelle la population est lockée
Variable Char    RMES        # Message d'erreur retourné
Variable Integer RERR        # Code retour du sous-programme

 Raz RMES, RERR

Local Char    RUPTURE_CPY       # Sauvegarde rupture société pour émission dans la trace
Local Char    RUPTURE_FCY       # Sauvegarde rupture site pour émission dans la trace
Local Char    RUPTURE_CUR       # Sauvegarde rupture devise  pour émission dans la trace
Local Char    RUPTURE_CURLIB    # Sauvegarde rupture libellé devise pour émission dans la trace
Local Integer NBMAJ_RECALC      # Si oui indique si calculé à partir de NBCPYTRT-NBCPYERR

Local Integer NBTRT    : Raz NBTRT
Local Integer OK
Local Integer I

RUPTURE_FCY = ""
  #=> Contrôle des paramètres
  If PTABLE="" : RERR=1 : RMES="Paramètre PTABLE incorrect." : GOK=0 : End : Endif

  #=> Débranchement vers traitement ERREUR_SP  # Erreur sous-programme
  Onerrgo ERREUR_SP From TRCPROCOM

  #=> Initialisations diverses
  NBMAJ_RECALC = G_OUI

  #=> Scan des critères pour qu'ils ne plantent pas le filter
  If PCRIT1="" : PCRIT1="1=1" : Endif
  If PCRIT2="" : PCRIT2="1=1" : Endif
  If PCRIT3="" : PCRIT3="1=1" : Endif
  If PCRIT4="" : PCRIT4="1=1" : Endif
  If CRITSUPG1="" : CRITSUPG1="1=1" : Endif
  If CRITSUPG2="" : CRITSUPG2="1=1" : Endif

  #=> Ouverture des tables
  If !clalev([F:MAS1]) : Local File =nomap+'.'+ PTABLE     [MAS1] : Endif    #=> Ouverture table à mettre à jour
  If !clalev([F:TML])  : Local File =nomap+'.'+'TMPMASLCK' [TML]  : Endif    #=> Ouverture de la table des locks # A supprimer
  If !clalev([F:XTRA]) : Local File =nomap+'.'+'TRCABX3'   [XTRA] : Endif    #=> Ouverture de la table contenant la trace
  If !clalev([F:FAS])  : Local File FXDASSETS     [FAS]    : Endif
  If !clalev([F:DEP])  : Local File DEPREC        [DEP]    : Endif
  # Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
  If !(clalev([F:LOF]))     : Local File LAYOUTFAS     [LOF]    : Endif
  If !(clalev([F:LOFP]))    : Local File LAYOUTFAS     [LOFP]   : Endif
  If !(clalev([F:LFG]))     : Local File FXDLOFGRP     [LFG]    : Endif
  If !(clalev([F:CNX]))     : Local File CONTEXT       [CNX]    : Endif
  If !(clalev([F:FIS]))     : Local File FISCYEAR      [FIS]    : Endif
  If !(clalev([F:CPY]))     : Local File COMPANY       [CPY]    : Endif
  #=> Début de transaction de mise à jour

  #=> Avant de début de la transaction
  ACTMET="DEB_APPL_DIRT" : Gosub ACTMET From TRCPROCOM

  If !GTRANS
    Call DEBTRANS From GLOCK
    Trbegin [MAS1], [FAS], [DEP]
  Endif

  #=> Ouverture table annexes
  ACTMET="OUVR_APPL_DIRT" : Gosub ACTMET From TRCPROCOM

  #=> Avant Pose du filtre (vérif. critères pour debugger )
  If GUSER="XXX"
    Call ECR_TRACE("",GTRC_PARAM,"PCRIT1="-PCRIT1,0,1) From TRACEABX3
    Call ECR_TRACE("",GTRC_PARAM,"PCRIT2="-PCRIT2,0,1) From TRACEABX3
    Call ECR_TRACE("",GTRC_PARAM,"PCRIT3="-PCRIT3,0,1) From TRACEABX3
    Call ECR_TRACE("",GTRC_PARAM,"PCRIT4="-PCRIT4,0,1) From TRACEABX3
    Call ECR_TRACE("",GTRC_PARAM,"CRITSUPG1="-CRITSUPG1,0,1) From TRACEABX3
    Call ECR_TRACE("",GTRC_PARAM,"CRITSUPG2="-CRITSUPG2,0,1) From TRACEABX3
    Call ECR_TRACE("",GTRC_PARAM,"GORDGRP="-GORDGRP,0,1) From TRACEABX3
  Endif

  #=> Pose du filtre
  Filter [MAS1] Where ( evalue(PCRIT1) & evalue(PCRIT2) & evalue(PCRIT3) & evalue(PCRIT4) &
&                       evalue(CRITSUPG1) & evalue (CRITSUPG2)) Order With GORDGRP
#=> Boucle sur la population sélectionnée
  For [MAS1]
    ######################################
    OK=1
    If dim(GNB_CRITFCY) > 0
      I =  find([F:MAS1]FCY, LIST_FCY_1)
      If I=0  and  dim(LIST_FCY_2) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_2)  : Endif
      If I=0  and  dim(LIST_FCY_3) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_3)  : Endif
      If I=0  and  dim(LIST_FCY_4) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_4)  : Endif
      If I=0  and  dim(LIST_FCY_X) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_X)  : Endif
      If I = 0 : OK=0 :  Endif
    Endif
    ###########################################
    If OK <> 0
      Read [TML]TML1=NUMACT;[F:MAS1]CODLOF;[F:MAS1]LINLOF
      If fstat
        LOCKOK=0           #=> Enr pas trouvé dans TML, on le traitera pas (Pas considéré comme une erreur)
      Else
        LOCKOK=1
      Endif
      If LOCKOK
         If RUPTURE_CPY<>[F:MAS1]CPY
            If RUPTURE_CPY<>""
               If NBCPYMAJ=0 & NBMAJ_RECALC=G_OUI : NBCPYMAJ=NBCPYTRT-NBCPYERR : Endif
               Call ECR_TRACE_STAT(RUPTURE_CPY,NBCPYTRT,NBCPYMAJ,NBCPYERR) From TRCPROCOM
            Endif
            RUPTURE_CPY=[F:MAS1]CPY
            Gosub CHRG_PAR_TRANSIT_SPE
            Call GET_CPY_CUR([F:MAS1]CPY,RUPTURE_CUR,RUPTURE_CURLIB) From GLOFCYCPY
            ACTMET="CPY_APPL_DIRT" : Gosub ACTMET From TRCPROCOM
            TRTYP=3 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2
            Raz NBCPYTRT, NBCPYMAJ, NBCPYERR
         Endif
         NBOBJ+=1
         # Mise à jour directe des tables de données avec les paramètres de l'action
         If !(clalev([F:LOFP]))    : Local File LAYOUTFAS     [LOFP]   : Endif
         If [M:LOF7]NBDEST > 0
            Read[LOFP]LOF0=[M:LOF7]CODLOF(0); [M:LOF7]LINLOF(0)
#            If evalue(LCONDA(0)) # Issue X3-99989
            If evalue(LCONDA)     # Issue X3-99989
               Gosub ALIM_LOF7
            Else
               Gosub CREAT_AUTO_FAS
               Gosub ALIM_LOF7
            Endif
         Else
            Gosub ALIM_LOF7
         Endif
         If RMES<>"" & ACTSILENCE <> G_OUI : Call ECR_TRACE([F:MAS1]CPY,GTRC_CRACTIO,RMES,1,1) From TRACEABX3 : Endif
         If GOK=1 : NBCPYTRT+=1 : Endif
         If !GSERVEUR & ACTTYPGES=GTAMMAS & ACTSILENCE<>G_OUI
            NBTRT+=1
            Call AFF_BOITE(mess(17,GML_MSGACT,1),NBTRT,OK) From GESECRAN
         Endif
      Endif
    Endif
    $NEXTLOF
  Next

  If [M:LOF7]NBDEST> 0
      Gosub CREAT_AUTO_FAS
  Endif

  If NBCPYMAJ=0 & NBMAJ_RECALC=G_OUI : NBCPYMAJ=NBCPYTRT-NBCPYERR : Endif
  Call ECR_TRACE_STAT(RUPTURE_CPY,NBCPYTRT,NBCPYMAJ,NBCPYERR) From TRCPROCOM

  #=> Suppression du filtre
  Filter [MAS1]

  #=> Traitement de fin de MAJ directe :
  ACTMET="END_APPL_DIRT" : Gosub ACTMET From TRCPROCOM
  If ACTTYPGES = GTAMMAS
    If GOK<1 | FLGSIM=G_OUI
      If ACTSILENCE<>G_OUI : Gosub VIDE_TRACE_EN_FICHIER From TRACEABX3 : Endif
      If !GTRANS : Rollback : Endif
      If dim(GSEQTRACE) > 0 Then Kill GSEQTRACE : Endif
      If dim(GNUMTRACE) > 0 Then Kill GNUMTRACE : Endif
      # Le traitement appelant doit supprimer les verrous si nécessaire
    Else
      If !GTRANS : Commit : Endif
      # Le traitement appelant doit supprimer les verrous si nécessaire
    Endif
  Endif

  #=> Fermeture des tables

  #=> Traitement de fin de sous-programme
  ACTMET="CLOS_APPL_DIRT" : Gosub ACTMET From TRCPROCOM

  Onerrgo

End
#*****************************
$MARQUE_DEPENSE_LIEES
#*****************************
#-> Variables pour générations événements sur dépenses
Local Integer  MOD_NAT_PCG, MOD_ACC_PCG, MOD_NAT_IAS, MOD_ACC_IAS, CDRET, MOD_ACT
Local Integer  N_I
Global Integer G_SV_GACACN, G_SV_IASACN
Global Char    G_SV_GACACC, G_SV_IASACC
Global Char    G_FASACCCOD  #*FQ95888
Local Date     WDATEFF, WACCDAT
#Local Decimal  L_AMTVATIAS            : # FQ84794 # FQ98116
#Local Decimal  L_AMTVATRIAS           : # FQ84794 # FQ98116

  For N_I = 1 To [M:LOF7]NBDEST
    MOD_NAT_PCG = 0
    MOD_ACC_PCG = 0
    MOD_NAT_IAS = 0
    MOD_ACC_IAS = 0
    #------------------------------
    Raz [LOF]
    Read [LOF]LOF0=[M:LOF7]CODLOF(N_I-1);[M:LOF7]LINLOF(N_I-1)
    #------------------------------
    If fstat
      # Erreur en lecture de la dépense
      GMESSAGE  = mess(28,GML_MSGLOF,1)-num$(STAT)
      GMESSAGE += ' '-num$([M:LOF7]CODLOF(N_I-1))-num$([M:LOF7]LINLOF(N_I-1))
      GOK       = 0
      Call FSTA("LOF") From GLOCK
      Return
    Endif

      [F:LOF]AASREF    = [F:FAS]AASREF
      [F:LOF]FLGLIKAAS = G_OUI
      [F:LOF]FLGLOFMAI = [M:LOF7]MAIVCR(N_I-1)
      [F:LOF]FLGDETEXP  = G_OUI # FQ104360
      #------------------------------
      # On planque les imputation d'origine pour pouvoir générer les bons événements
      G_SV_GACACN      = [F:LOF]GACACN
      G_SV_GACACC      = [F:LOF]GAC
      If GCNXPROIAS = G_OUI
        G_SV_IASACN    = [F:LOF]IASACN
        G_SV_IASACC    = [F:LOF]IASACC
      Endif
      #------------------------------
      # S'il y a un plan IAS
      # Si les natures de compte et compte (PCG ou IAS) sont différents sur la dépense
      # de ce qui sera sur le bien, il faut recaler la dépense avec le bien
      #------------------------------
      If [F:LOF]GACACN = GVML_NIENSER or [F:LOF]GACACN  = GVML_NIENCOU
        If [F:LOF]GACACN <> [M:LOF7]GACACNV
          [F:LOF]GACACN = [M:LOF7]GACACNV
          [F:LOF]GACORI = [F:LOF]GAC
          [F:LOF]GAC    = [M:LOF7]GACV
          MOD_NAT_PCG   = 1
        Elsif [F:LOF]GAC <> [M:LOF7]GACV
          [F:LOF]GACORI = [F:LOF]GAC
          [F:LOF]GAC    = [M:LOF7]GACV
          MOD_ACC_PCG   = 1
        Endif
      Endif
      If GCNXPROIAS = G_OUI
        #------------------------------
        If [F:LOF]IASACN = GVML_NIENSER or [F:LOF]IASACN  = GVML_NIENCOU
          If [F:LOF]IASACN <> [M:LOF7]IASACNV
            [F:LOF]IASACN = [M:LOF7]IASACNV
            [F:LOF]IASACCORI = [F:LOF]IASACC
            [F:LOF]IASACC = [M:LOF7]IASACCV
            MOD_NAT_IAS   = 1
          Elsif [F:LOF]IASACC <> [M:LOF7]IASACCV
            [F:LOF]IASACCORI = [F:LOF]IASACC
            [F:LOF]IASACC = [M:LOF7]IASACCV
            MOD_ACC_IAS   = 1
          Endif

          #------------------------------ FQ84794
          # Stockage pour détachement de la valorisation IAS
          [F:LOF]AMTNOTIAS = [M:LOF7]AMTNOTIAS(N_I-1)

          #L_AMTVATIAS = [M:LOF7]AMTNOTIAS(N_I-1) * ([F:LOF]RATVAT / 100 )
          #Call GET_MNT_ARRONDI (L_AMTVATIAS, GCNXCURIAS, L_AMTVATIAS) From GLOBIENS
          #[F:LOF]AMTVATIAS = L_AMTVATIAS
          [F:LOF]AMTVATIAS = [M:LOF7]AMTVATIAS(N_I-1) : # FQ98116

          #L_AMTVATRIAS = L_AMTVATIAS * ([F:LOF]RATVATREC / 100 )
          #Call GET_MNT_ARRONDI (L_AMTVATRIAS, GCNXCURIAS, L_AMTVATRIAS) From GLOBIENS
          #[F:LOF]AMTVATRIAS = L_AMTVATRIAS
          [F:LOF]AMTVATRIAS = [M:LOF7]AMTVATRIAS(N_I-1) : # FQ98116
          #------------------------------ FQ84794
        Endif
      Endif
      If MOD_NAT_PCG | MOD_ACC_PCG
        WDATEFF = [F:FAS]AASIPTDAT
        WACCDAT = WCNXDAT(3)
        G_FASACCCOD  = [F:FAS]ACCCOD #*FQ95888
        Call GENER_EVE
&           (GVML_OMDEPEN,[F:LOF]CPY,[F:LOF]FCY,[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFCIM1",WDATEFF,WACCDAT, CDRET)
&       From GENEVE
        If CDRET > 20
          # Erreur lors de la génération de l'événement PCG
          GMESSAGE  = mess(40,GML_MSGLOF,1)-num$(CDRET) :
          GMESSAGE += ' '-num$([M:LOF7]CODLOF(N_I-1))-num$([M:LOF7]LINLOF(N_I-1))
          GOK       = 0
          Call FSTA("LOF") From GLOCK
          Kill G_SV_GACACN, G_SV_IASACN, G_SV_GACACC, G_SV_IASACC
          Return
        Endif
      Endif
      #------------------------------
      If MOD_NAT_IAS | MOD_ACC_IAS
        WDATEFF = [F:FAS]AASIPTDAT
        WACCDAT = WCNXDATI(3)
        G_FASACCCOD  = [F:FAS]ACCCOD #*FQ95888
        Call GENER_EVE
&           (GVML_OMDEPEN,[F:LOF]CPY,[F:LOF]FCY,[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFCIM6", WDATEFF ,WACCDAT, CDRET)
&       From GENEVE
        If CDRET > 20
          # Erreur lors de la génération de l'événement IAS
          GMESSAGE  = mess(41,GML_MSGLOF,1)-num$(CDRET)
          GMESSAGE += ' '-num$([M:LOF7]CODLOF(N_I-1))-num$([M:LOF7]LINLOF(N_I-1))
          GOK       = 0
          Call FSTA("LOF") From GLOCK
          Kill G_SV_GACACN, G_SV_IASACN, G_SV_GACACC, G_SV_IASACC
          Return
        Endif
      Endif
      #------------------------------
      [F:LOF]UPDDAT  = date$
      [F:LOF]UPDUSR = GUSER
      #- Si simulation : prépa de la trace -----------------------
      If ( FLGDET = G_OUI ) and FLGSIM = G_OUI
        #----------------------------------------------------
        Gosub TRACE_LOF
      Endif
      Rewrite [LOF]
      If fstat
        # Erreur réécriture dépense
        GMESSAGE  = mess(27,GML_MSGLOF,1)-num$(STAT)
        GMESSAGE += ' '-num$([M:LOF7]CODLOF(N_I-1))-num$([M:LOF7]LINLOF(N_I-1))
        GOK       = 0
        Call FSTA("LOF") From GLOCK
        Kill G_SV_GACACN, G_SV_IASACN, G_SV_GACACC, G_SV_IASACC
        Return
      Endif
      #- 2 -----------------------
      If ( FLGDET = G_OUI ) and FLGSIM <>  G_OUI
        #----------------------------------------------------
        Gosub TRACE_LOF
      Endif
    #------------------------------
    # Suite de la boucle
  Next N_I

  Kill G_SV_GACACN, G_SV_IASACN, G_SV_GACACC, G_SV_IASACC
  Kill G_FASACCCOD #*FQ95888
  #------------------------------

Return
#*****************************
Subprog RECUP_CODE_COMPTABLE ()
#*****************************
# Récupère le code comptable à partir du compte PCG et aussi les info IAS si besoin
Local Integer LERROR, GACCCOD_ASSO
Local Char    LCODGAC
Local Char    LGAC, LIASACC
Local Integer LGACACN, LIASACN
  #> Chargement du masque de travail contenant le paramétrage comptable de la société
  Local Integer ERR
  Call LOAD_FASPARCPY( [M:LOF7]CPY,"",G_NON,ERR) From GLOFCYCPY
  # Regarder si une association "FAMILLE" permet de déterminer le code comptable.
  # Si OUI : c'est l'association qui gagne. classe [F:LOFP] Famille ACGGRP
  # Si NON : On fait comme maintenant.
  # On ne cherche une association pour déterminer le compte que si la famille
  # de la dépense principale est renseignée
  If [M:LOF7]ACGGRPV <> ""
    Call DETER_ACCCOD([M:LOF7]ACGGRPV, [M:LOF7]CPY, LCODGAC, GACCCOD_ASSO) From TRTASSO
  Endif
  If LCODGAC = ""
    # Pas d'association sur code comptable : on en cherche un à partir des comptes de la dépense principale
    If GCNXPROIAS = G_OUI
      LCODGAC = func GLOBIENS.GET_GACCCODE (GVML_COGIMMO, GGACIMMO, [M:LOF7]GACV, GIASIMMO, [M:LOF7]IASACCV, LERROR)
    Else
      LCODGAC = func GLOBIENS.GET_GACCCODE (GVML_COGIMMO, GGACIMMO, [M:LOF7]GACV, -1, "", LERROR)
    Endif
    # -----------------------------------------------------
  Endif

If LCODGAC <> ""
   [M:LOF7]ACCCODV = LCODGAC
    Call AM_ACCCODV(LCODGAC)
  Endif

End
#*****************************
$CALCUL_VALEUR_BILAN
#*****************************
Local Decimal MTDES, ACGBSESAV, IASBSESAV
Local Integer STAT
Local Integer I_PLN

  # Valeur bilan PCG
  ACGBSESAV = [F:FAS]ACGETRNOT + [F:FAS]IVCVATAMT - [F:FAS]DEDVATAMT
  # Valeur bilan IAS
  If GCNXPROIAS = G_OUI
    IASBSESAV = [F:FAS]IASETRNOT + [F:FAS]IVCVATAMTI - [F:FAS]DEDVATAMTI
  Endif
  # Valeur bilan PCG alimente base de taxe et base de référence de +/- value
  # Si Valeur bilan PCG = 0 et Valeur bilan IFRS > 0 alors Base Taxe = Valeur bilan IFRS
  # Prise en compte de la devise IAS
  If ( GCNXPROIAS = G_OUI and ACGBSESAV = 0 and IASBSESAV > 0 )
    [F:FAS]TAXBAS  = IASBSESAV / [F:FAS]IASRATCUR
    Call GET_MNT_ARRONDI ([F:FAS]TAXBAS, [F:FAS]IASCUR, [F:FAS]TAXBAS) From GLOBIENS
  Else
    [F:FAS]TAXBAS  = ACGBSESAV
  Endif

  [F:FAS]GALREFBAS = ACGBSESAV

Return
#
#*****************************
#*   ALIM_PLANS_AMT         *
#*****************************
$ALIM_PLANS_AMT
Local Integer I_PLN
Local Date    FIYSTRDAT2,PERENDDAT2

  G_PLNIAS = 0
  G_CNXIAS = 0
  #>1 >>>>>>>>>>>>>>>>>>
  For [CNX]CNX0 Where CPY =[M:LOF7]CPY
    # Courant
    Filter [FIS] Where CPY=[M:LOF7]CPY and CNX = [F:CNX]CNX and STAFIY = GVML_TECOURA
    Read [FIS]First
    Filter [FIS]
    #-1 ---------------------------
    For I_PLN = 0 To [F:CNX]NBPLC-1
       If ( [F:CNX]PLNCAA(I_PLN) = G301FIS )       : Endif
       If ( [F:CNX]PLNCAA(I_PLN) = G301IAS ) : G_PLNIAS = 1 : G_CNXIAS = [F:CNX]CNX : Endif
       [F:DEP] = [F:FAS]
       [F:DEP]ALWAMTFLG  = G_NON                  : # Mt règl part forc ex
       [F:DEP]ALWCOD     = GVML_RPAUCUN           : # Type règle particul   : TABLE 368
       [F:DEP]ALWCUMFLG  = G_NON                  : # Cum règl part forcé
       [F:DEP]DEPSTA     = GVML_SCNOCAL           : # Statut clôture        : TABLE 310
       [F:DEP]DPRCUMFLG  = G_NON                  : # Cumul amort ex forcé
       [F:DEP]DPRRAT     = 0                      : # Taux d'amortissement
       [F:DEP]DPRRATFLG  = G_NON                  : # Taux d'amort forcé
       [F:DEP]ENDDPEFLG  = G_NON                  : # Dot exercice forcée
       [F:DEP]IMLFLG     = G_NON                  : # Dépréciation forcée
       [F:DEP]IMLRVEFLG  = G_NON                  : # Repr dépréc forcée
       [F:DEP]PRATYP     = 0                      : # Type de prorata par défaut
       [F:DEP]MTCDEVADJ  = 1                      : # Rattrap éc chg méth
       [F:DEP]PERDPEFLG  = G_NON                  : # Dotation pér forcée
       [F:DEP]RATCUR     = 1                      : # Cours devise
       [F:DEP]RVACOE     = 0                      : # Coef réévaluation
       [F:DEP]RVATYP     = 1                      : # Type réévaluation
       [F:DEP]DPM        = G_DPMSA
       [F:DEP]DPRDUR      = 0
       [F:DEP]DPRPLN     = [F:CNX]PLNCAA(I_PLN)
       [F:DEP]PRATYP     = 0
       [F:DEP]CNX        = [F:CNX]CNX
       [F:DEP]UOM        = GDEFUOM
       [F:DEP]FIYSTRDAT  = [F:FIS]DATSTRFIY
       [F:DEP]FIYENDDAT  = [F:FIS]DATENDFIY
       [F:DEP]PERSTRDAT  = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
       [F:DEP]PERENDDAT  = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
       Case func TRTFAS.GET_DPRSTRDAT_TYP([F:DEP]DPM, [F:DEP]CPY)
         When GVML_TPURDAT : [F:DEP]STRDPRDAT = [F:FAS]PURDAT
         When GVML_TITSDAT : [F:DEP]STRDPRDAT = [F:FAS]ITSDAT
         When GVML_TACCDAT : [F:DEP]STRDPRDAT = [F:FAS]AASIPTDAT
       When Default
       Endcase

       # Issue 115019
       #  Si la remise en cause  de la situation après clôture est interdite pour la société
       #  et Début d'Amortissement < Début d'Exercice alors le Cumul E-1 est forcé à 0
       #  En import, il faut laisser la possibilité d'importer des biens avec un cumul forcé <> de 0
       If ( !GIMPORT )  and ( GPRVSITUPD <> G_OUI and  [F:DEP]STRDPRDAT <  [F:DEP]FIYSTRDAT )
         [F:DEP]DPRCUM  =0
         [F:DEP]DPRCUMFLG=G_OUI
       Endif   # End Issue 115019

      # Alimentation de la base avec Valeur bilan PCG ou IAS selon paramétrage contextes
      If ( [F:CNX]ORIBASDPR(I_PLN) = GVML_OBIAS )
         [F:DEP]RATCUR    = [F:FAS]IASRATCUR
         MTDES = IASBSESAV
         MTDES = IASBSESAV
      #Fq-92171 Elsif (  [F:CNX]ORIBASDPR(I_PLN) = GVML_OBSAI )
      Elsif ( [F:CNX]ORIBASDPR(I_PLN) = GVML_OBSUB  or  [F:CNX]ORIBASDPR(I_PLN) = GVML_OBSAI  )
         MTDES   = 0
      Else
         MTDES   =  ACGBSESAV
      Endif

       [F:DEP]DPRBAS = MTDES
       [F:DEP]BSEVAL = MTDES

       Gosub DECLENCHE_ASSOCIATION

#       # Controle de la méthode pour chaque plan d'amortissement
       [F:DEP]DEPSTA     = GVML_SCNOCAL
       [M:METH]           = [F:FAS]
       [M:METH]           = [F:DEP]
       [M:METH]FLGBCO     = G_OUI
       [M:METH]DPRRATFLG  = LFLGRAT
       #<<<<<<<<<<<<<<<<<<<<<<<<<<<<
       # DEPREC
       #<<<<<<<<<<<<<<<<<<<<<<<<<<<<
       Write [F:DEP]
       If fstat
         Case fstat
           When 1
             RMES=mess(226,GML_MSGFAS,1)-[F:DEP]AASREF  # "Enregistrement en cours d'utilisation"
             GOK=-1
           When 3
             RMES=mess(129,GML_MSGFAS,1)-[F:DEP]AASREF
              GOK=0
           When Default
         Endcase
         Call ECR_TRACE_ERREUR([F:DEP]CPY, [F:DEP]AASREF, 0, G_OUI, RMES) From TRCPROCOM
       Endif
       #-1 ---------------------------
    Next
    [F:FAS]FLGCNXCLC([F:CNX]CNX-1)    = G_OUI
  Next

Return
#*****************************
Subprog AM_ACCCODV(VALEUR)
#*****************************
Variable Char    VALEUR()

Local Char    LGAC,    LIASACC
Local Integer LGACACN, LIASACN

  Call GET_GAC_IAS_FROM_GACCODE (GVML_COGIMMO, VALEUR, GGACIMMO, GIASIMMO, LGACACN, LGAC, LIASACN, LIASACC) From GLOBIENS
  # 2 cas d'erreurs possibles 1) compte absent ou 2) nature invalide
  If LGACACN = 0
    # Le compte d'immobilisation PCG associé au code comptable est invalide ou sa nature est incorrecte.
    RMES= "Nature : "-num$(LGACACN)-" "-mess(422,GML_MSGFAS,1)
    Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]CODLOF,0, G_NON, RMES ) From TRCPROCOM
  Endif
  If GCNXPROIAS = G_OUI
    # 2 cas d'erreurs possible 1) compte absent ou 2) nature invalide
    If LIASACN = 0
      # Le compte d'immo. IFRS associé au code comptable est invalide ou sa nature est incorrecte
      RMES= "Nature : "-num$(LIASACN)-" "-mess(423,GML_MSGFAS,1)
      Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]CODLOF,0, G_NON, RMES ) From TRCPROCOM
    Endif
  Endif
    # ----------------------------------------
    # La nature du compte PCG déduit du code comptable doit être compatible avec celle de la dépense princip.
    #    * Nature PCG dépense principale = Dépense, nature du compte PCG déduit du code comptable aussi
    If [M:LOF7]GACACNV = GVML_NIENCOU or [M:LOF7]GACACNV = GVML_NIENSER
      # C'est une nature IMMOBILISATION
      If LGACACN <> GVML_NIENCOU and LGACACN <> GVML_NIENSER
        # Nature compte PCG issu du Code comptable incompatible avec Nature compte PCG de la dépense princip.
      Endif
    Else
      # C'est une nature CHARGE
      If LGACACN = GVML_NIENCOU or LGACACN = GVML_NIENSER
        # Nature compte PCG issu du Code comptable incompatible avec Nature compte PCG de la dépense princip.
        End
      Endif
    Endif
    #
    If GCNXPROIAS = G_OUI
      # ----------------------------------------
      # La nature du compte IASdéduit du code comptable doit être compatible avec celle de la dépense princip.
      #    * Nature IASdépense principale = Dépense, nature du compte IASdéduit du code comptable aussi
      If [M:LOF7]IASACNV = GVML_NIENCOU or [M:LOF7]IASACNV = GVML_NIENSER
        # C'est une nature IMMOBILISATION
        If LIASACN <> GVML_NIENCOU and LIASACN <> GVML_NIENSER
#          # Nature compte IFRS issu du code comptable incompatible avec Nature compte IFRS de la dépense princ
        Endif
      Else
        # C'est une nature CHARGE
        If LIASACN = GVML_NIENCOU or LIASACN = GVML_NIENSER
#          # Nature compte IFRS issu du code comptable incompatible avec Nature compte IFRS de la dépense princ
        Endif
      Endif
    Endif
    # ----------------------------------------
  [M:LOF7]GACACNV   = 0
  [M:LOF7]GACV      = ""
  If LGACACN <> 0
    [M:LOF7]GACACNV = LGACACN
    [M:LOF7]GACV    = LGAC
    [F:FAS]GACACN   = LGACACN
    [F:FAS]GAC      = LGAC
  Endif
   # ----------------------------------------
  [M:LOF7]IASACNV     = 0
  [M:LOF7]IASACCV     = ""
  If GCNXPROIAS = G_OUI
    If LIASACN <> 0
      [M:LOF7]IASACNV = LIASACN
      [M:LOF7]IASACCV = LIASACC
      [F:FAS]IASACN   = LIASACN
      [F:FAS]IASACC   = LIASACC
    Endif
  Endif
End
#*****************************
$DECLENCHE_ASSOCIATION
#*****************************
Local Integer PLAN (G301MAX), LALW(G301MAX), LFLGRAT, RERROR, LERROR, RUPDFLG(5,G301MAX)
Local Char    LDPM(GLONDPM) (G301MAX), LVEH(G301MAX), FAM, ACCCOD, LCPY
Local Decimal LDUR(G301MAX)
Local Decimal LRAT(G301MAX)
Local Decimal LRAT2(G301MAX)
Local Integer LTYPD(G301MAX)
Local Integer LPRA(G301MAX)
Local Decimal LACL(G301MAX)
Local Char    LPROPLN (G301MAX)
Local Integer LFLGBCO (G301MAX)

  PLAN       =  [F:DEP]DPRPLN
  ACCCOD     =  [F:FAS]ACCCOD
  FAM        =  [F:FAS]ACGGRP
  LPROPLN    =  [F:FAS]PROPLN
  LCPY       =  [F:FAS]CPY
  LFLGBCO    =  G_OUI

  RERROR = 0
  LERROR = 0
  Call DETER_VAL_PLANS(LCPY,FAM,ACCCOD,PLAN,LDPM,LDUR,LRAT,LRAT2,LALW,LVEH,LPRA,LACL,RUPDFLG) From TRTASSO
  If RERROR = 0
    If LRAT > 0
      LFLGRAT=G_OUI
    Else
      LFLGRAT=G_NON
    Endif

    If LDPM <> ""     :      [F:DEP]DPM         = LDPM      :     Endif
    If LDUR > 0       :      [F:DEP]DPRDUR      = LDUR      :     Endif
    If LRAT > 0       :      [F:DEP]DPRRAT      = LRAT      :     Endif
    If LRAT2 > 0      :      [F:DEP]DPRRAT2     = LRAT2     :     Endif
    If LALW > 0       :      [F:DEP]ALWCOD      = LALW      :     Endif
    If LVEH <> ""     :      [F:DEP]CRBVEHCOD   = LVEH      :     Endif
    If LPRA > 0       :      [F:DEP]PRATYP      = LPRA      :     Endif
    If LACL > 0       :      [F:DEP]ACLCOE      = LACL      :     Endif
    If LFLGRAT > 0    :      [F:DEP]DPRRATFLG   = LFLGRAT   :     Endif
  Endif

Return
#-------------------------------------------------------------------------------
##################################################################
# Traitement du ou des masques de paramètres de l'action massive #
# -----> PARAMETRES  LOFGRPFAS                                   #
##################################################################

#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#
Subprog AM_GRPREF(VALEUR)
Variable Char    VALEUR()
Local Char       LPARAM  # Issue 115019

  If VALEUR <> ""
    [M:LOFG]GRPREF = VALEUR
    Read [LFG]LFG0=VALEUR
    If fstat=0 and ([F:LFG]CPY=[M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1) or ([F:LFG]CPY="")) and ([F:LFG]FGACTIF=G_OUI)
      [M:LOFG]GRPDES = [F:LFG]DES
      Affzo [M:LOFG]GRPDES
    Else
      Call ERREUR (mess(88,GML_MSGLOF,1)) From GESECRAN
      mkstat=2
      End
    Endif
    # Issue 115019
    Raz GPRVSITUPD
    Call PARAML([F:LFG]CPY,"PRVSITUPD",LPARAM) From ADOVAL
    GPRVSITUPD = val(LPARAM)
  Endif # End issue 115019

End
#---------------------------------
$SEL_TABLFG

  # SEL_TABLFG : table des critères de regroupement des dépenses
  Local Char CODFIC    : CODFIC = "FXDLOFGRP"

  OBJET = "LGT"
  CRITERE = '((CPY=[M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1)) or (CPY="")) and (FGACTIF=G_OUI)'
  Default File [LFG]
  Affzo [M:LOFG]

  DEFPAG=1

Return

#*****************************
$TRC_CRITRUPT
#*****************************
#*
Local Integer I
Local Char LINE_R(GLONLINE) # Issue X3-99989
Local Integer WLEN_LINE # Issue X3-99989
Local Char WCODZON(250) # Issue X3-99989

  #--Ligne rupture de site----------------------
  If !(clalev([F:LFG]))     : Local File FXDLOFGRP     [LFG]    : Endif
  Read [LFG]LFG1=[F:LOFP]CPY;[M:LOFG]GRPREF
  If [F:LOFP]FCY <> RUPTURE_FCY
     LINE_R =string$(GLONLINE,"") : Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO,LINE_R,0,1) From TRACEABX3 # Issue X3-99989
     LINE_R =string$(GLONLINE,"") : Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO,LINE_R,0,1) From TRACEABX3 # Issue X3-99989
     LIGNE = "Site : "+num$([F:LOFP]FCY)
     Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO, LIGNE,0,1) From TRACEABX3
     RUPTURE_FCY = [F:LOFP]FCY
  Endif
  #--Ligne rappel critères de regroupement ----------------------
  LINE_R =string$(GLONLINE,"") : Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO,LINE_R,0,1) From TRACEABX3 # Issue X3-99989

# Issue X3-99989
  LINE_R = string$(10, "<")
  WLEN_LINE = len(LINE_R)

  For I=1 To [F:LFG]NBCRIT
     If [F:LFG]CODZON(I-1) <>  ""
#        LINE_R += " "+num$([F:LFG]CODZON(I-1))+" = "+num$(evalue("[F:LOFP]"+[F:LFG]CODZON(I-1)))
#        LINE_R += " - "
        WCODZON = " " + num$([F:LFG]CODZON(I-1)) + " = " + num$(evalue("[F:LOFP]" + [F:LFG]CODZON(I-1))) + " - "
        If len(LINE_R) + len(WCODZON) > GLONLINE
          Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO,LINE_R,0,1) From TRACEABX3
          LINE_R = space$(WLEN_LINE) + WCODZON
        Else
          LINE_R += WCODZON
        Endif
     Endif
   Next
   LINE_R += string$(10,">")
   Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO,LINE_R,0,1) From TRACEABX3
# End Issue X3-99989

Return
#*****************************
$TRACE_FAS
#*****************************
#--Ligne entête Bien comptable ------------
#*!
  Local Char LIGNE(GLONLINE) # Issue X3-99989
  LIGNE =string$(GLONLINE,"=") : Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3 # Issue X3-99989
  LIGNE  = "*"
  LIGNE += left$(mess(182,GML_MSGFAS,1)+string$(25,' ' ), 25)+"*"
  LIGNE += left$(mess(251,GML_MSGFAS,1)+string$(25,' ' ), 25)+"*"
  LIGNE += left$(mess(214,GML_MSGFAS,1)+string$(15,' ' ), 15)+"*"
  LIGNE += left$(mess(215,GML_MSGFAS,1)+string$(12,' ' ), 12)+"*"
  LIGNE += left$(mess(132,GML_MSGCPT,1)+string$(10,' ' ), 10)+"*"
  LIGNE += left$(mess(93,GML_MSGLOF,1)+string$(15,' ' ), 15)
  Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO, LIGNE,0,1) From TRACEABX3

  #--Ligne détail Bien comptable ----------------------
  LIGNE  = "  "
  LIGNE+=left$([F:FAS]AASREF+ string$(25,' '), 25)+" "
  LIGNE+=left$([F:FAS]AASDES1+ string$(25,' '), 25)+" "
  LIGNE+=left$([F:FAS]ACGGRP+ string$(15,' '), 15)+ "  "
  LIGNE+=left$([F:FAS]ACCCOD+  string$(12,' '), 12)+" "
  LIGNE+=left$(mess([M:FPC]GENLEDTYP,2644,1)+ string$(10,' '), 10)+" "
  LIGNE+= format$('N:'+GFMT3,[F:FAS]ACGETRNOT )+" "
  LIGNE+=left$(GCNXCURCPF+ string$(3,' '), 3)
  Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  # FQ84794
  If GCNXPROIAS = G_OUI
    LIGNE =space$(83)
    LIGNE+=left$(mess([M:FPC]IASLEDTYP,2644,1)+ string$(10,' '), 10)+" "
    LIGNE+= format$('N:'+GFMT3,[F:FAS]IASETRNOT )+" "
    LIGNE+=left$(GCNXCURIAS+ string$(3,' '), 3)
    Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  Endif
  LIGNE =string$(GLONLINE,"=") : Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3 # Issue X3-99989

  #--Ligne entête Dépenses  ----------------------
  LIGNE  = "*"
  LIGNE += left$(mess(92,GML_MSGLOF,1)+string$(20,' '), 20)+" "
  LIGNE += space$(4)+"*"
  LIGNE += left$(mess(251,GML_MSGFAS,1)+string$(25,' ' ), 25)+"*"
  LIGNE += left$(mess(214,GML_MSGFAS,1)+string$(15,' ' ), 15)+"*"
  LIGNE += left$(mess(40,GML_MSGCPT,1)+string$(12,' ' ), 12)+"*"
  LIGNE += left$(mess(132,GML_MSGCPT,1)+string$(10,' ' ), 10)+"*"
  LIGNE += left$(mess(93,GML_MSGLOF,1)+string$(15,' ' ), 15)
  Call ECR_TRACE([F:FAS]CPY,GTRC_CRACTIO, LIGNE,0,1) From TRACEABX3
#*
Return
#*****************************
$TRACE_LOF
#*****************************
  # Construction de la ligne Dépenses régroupées à émettre dans la trace
  #*!
  Local Char LIGNE(GLONLINE) # Issue X3-99989
  If [F:LOF]FLGLOFMAI = G_OUI
     LIGNE ="X "
  Else
     LIGNE =space$(2)
  Endif
  LIGNE+=left$([F:LOF]CODLOF+string$(20,' '), 20)+" "
  LIGNE+=left$(num$([F:LOF]LINLOF)+ string$(4,' '), 4)+" "
  LIGNE+=left$([F:LOF]DES+ string$(25,' '), 25)+ " "
  LIGNE+=left$(num$([F:LOF]ACGGRP)+ string$(15,' '), 15)+ "  "
  LIGNE+=left$([F:LOF]GACORI+ string$(12,' '), 12)+ " "
  LIGNE+=left$(mess([M:FPC]GENLEDTYP,2644,1)+ string$(10,' '), 10)+ " "
  LIGNE+=format$('N:'+GFMT3,[F:LOF]AMTNOTCPY )+ " "
  LIGNE+=left$(GCNXCURCPF+ string$(3,' '), 3)
  Call ECR_TRACE([F:LOF]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  # FQ84794
  If GCNXPROIAS = G_OUI
    LIGNE =space$(70)
    LIGNE+=left$([F:LOF]IASACCORI+ string$(12,' '), 12)+ " "
    LIGNE+=left$(mess([M:FPC]IASLEDTYP,2644,1)+ string$(10,' '), 10)+ " "
    LIGNE+=format$('N:'+GFMT3,[F:LOF]AMTNOTIAS )+ " "
    LIGNE+=left$(GCNXCURIAS+ string$(3,' '), 3)
    Call ECR_TRACE([F:LOF]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  Endif

Return
#*FQ99561##################################################################################
# Chargement des zones libres en fonction du paramétrage d'alimentation des zones libres  #
###########################################################################################
$CHRG_PAR_TRANSIT_SPE

Local Char LIDENT
Local Integer LNBTRAN : LNBTRAN = 0
Local Integer LMAXCHM : LMAXCHM = 200
Local Char    LCHMSRC  (10)(LMAXCHM) : # Champ source
Local Char    LCHMDES  (10)(LMAXCHM) : # Champ destination
Local Integer LCUMUL       (LMAXCHM) : # Champ à cumuler (uniquement pour les rubriques numériques)
Local Integer LLTTVLEG     (LMAXCHM) : # Champ transit si tt les valeurs sont identique à dépense principale
Local Integer LORNUL       (LMAXCHM) : # Associé à LLTTVLEG et si LLTTVLEG=OUI ou NULL
Local Integer LVIDPRI      (LMAXCHM) : # Vide ou Principal
Local Char    LCNTVAL(20)(0..LMAXCHM): # Constante
Local Integer LRUBMNT      (LMAXCHM) : # Rubriques montant (HT,TVA,TTC) mises à 1 sinon 0 permet de traiter l'IAS
Local Integer LTYPPHY      (LMAXCHM) : # Type physique du champ source (initialisé slt si LLTTVLEG=OUI et LVIDPRI=VIDE)
Local Integer LTTVEVID     (LMAXCHM) : # Si mis à 1 si condition non remplie du coup on vide LCHMDES et on ne le remplis plus
                                       # (utilisé slt si LLTTVLEG=OUI et LVIDPRI=VIDE)
Local Integer LPRIBCO      (LMAXCHM) : # Si mis à 2 le champ du BCO n'est pas alimenté par celui de la dépense lorsque
                                       # le bien a été crée en autonome et qu'on lui rattache une première dépense

  #------------------------------
  # A ce point précis, [M:LOF7]CPY ne contient pas toujours la bonne société
  # ==> on ne lit pas le bon paramétrage car souvent le champ contient la société sur
  # laquelle on était positionné avant de démarrer la création du nouveau bien
  Call GET_IDENT_TZL ([F:LFG]CPY , GVML_OMDEPEN, GVML_OMBIEN, LIDENT) From SUBTZL
  Read [TZL]TZL0=LIDENT
  If fstat
    # Si un paramétrage TZL n'existe pas sur la société, on le recherche par défaut
    Call GET_IDENT_TZL ("", GVML_OMDEPEN, GVML_OMBIEN, LIDENT) From SUBTZL
    Read [TZL]TZL0=LIDENT
    If fstat
      Return
    Endif
  Endif
  #------------------------------
  For [TZD] Where KEYTZL=LIDENT
    LNBTRAN          += 1
    LRUBMNT(LNBTRAN)  = 0
    LCHMSRC(LNBTRAN)  = [F:TZD]CODZONSRC
    LCHMDES(LNBTRAN)  = [F:TZD]CODZONDES
    LCUMUL(LNBTRAN)   = [F:TZD]CUM
    LLTTVLEG(LNBTRAN) = [F:TZD]ALLVALEQU
    LORNUL(LNBTRAN)   = [F:TZD]ORNUL
    LVIDPRI(LNBTRAN)  = [F:TZD]FREMAI
    LCNTVAL(LNBTRAN)  = [F:TZD]CNSVAL
    LPRIBCO(LNBTRAN)  = G_NON
    #----------------------------
    # Suite de la boucle
  Next
  #------------------------------

  #------------------------------
  Raz LTYPPHY
  For N_I = 0 To LNBTRAN
    If (LLTTVLEG(N_I)=G_OUI and LVIDPRI(N_I)=GVML_VPVIDE) or LCNTVAL(N_I)<>""
      # Uniquement dans ce cas on aura besoin du type physique
      LTYPPHY(N_I) = func GLOBIENS.GET_TYPE_PHYSIQUE ("LAYOUTFAS", LCHMSRC(N_I))
    Endif
    #----------------------------
    # Suite de la boucle
  Next N_I

Return
#*FQ99561##################################################################################
# Chargement des zones libres en fonction du paramétrage d'alimentation des zones libres  #
###########################################################################################
$LOAD_FREEFLD

  Local Integer  N_E, N_I

  For N_I = 1 To [M:LOF7]NBDEST
    If ( [M:LOF7]MAIVCR(N_I-1) = G_OUI )
      # On relit la dépense principale pour être sur qu'elle soit bien en mémoire
      Raz [LOFP]
      Read [LOFP]LOF0=[M:LOF7]CODLOF(N_I-1);[M:LOF7]LINLOF(N_I-1)
      Break
    Endif
  Next N_I
  # <<<<<<<<<
  Raz LTTVEVID

  For N_I = 1 To [M:LOF7]NBDEST
    #- 1 ------------------
    Read [LOF]LOF0=[M:LOF7]CODLOF(N_I-1);[M:LOF7]LINLOF(N_I-1)
    For N_E = 1 To LNBTRAN
       #- 2------------------
       # Cumul = "OUI" ---------
       If ( LCUMUL(N_E) = G_OUI )
           # On cumule
           If ( LRUBMNT(N_E) = 0 )
              # Toute rubrique numérique identifiée comme étant un montant
              Assign '[M:LOF7]'+LCHMDES(N_E) With evalue('[M:LOF7]'+LCHMDES(N_E)) + evalue('[F:LOF]'+LCHMSRC(N_E))
           Endif
        Else # Cumul = "NON" --------------------------------------
           If LLTTVLEG(N_E) <> G_OUI   #---- "Même valeur" = NON
              If LCNTVAL(N_E) <> ""
                 # on regarde s'il y a une constante, si oui on la prend
                 If LTYPPHY(N_E) = GNUMBER
                    Assign '[M:LOF7]'+LCHMDES(N_E) With val(LCNTVAL(N_E))
                 Elsif LTYPPHY(N_E) = GALPHA
                    Assign '[M:LOF7]'+LCHMDES(N_E) With num$(LCNTVAL(N_E))
                 Elsif LTYPPHY(N_E) = GDATE
                    Assign '[M:LOF7]'+LCHMDES(N_E) With evalue('['+LCNTVAL(N_E)+']')
                 Endif
              Else
                 # sinon on prend celle de la dépense principale
                 Assign '[M:LOF7]'+LCHMDES(N_E) With evalue('[F:LOFP]'+LCHMSRC(N_E))
              Endif
           #----
           Else  #---- "Même valeur"  = OUI
              If [M:LOF7]NBDEST=1
                 # "Une seule dépense ==> dans ce cas on prend toujours la principale
                 Assign '[M:LOF7]'+LCHMDES(N_E) With evalue('[F:LOFP]'+LCHMSRC(N_E))
              Else
                 # Dans ce cas il faut regarder si les valeurs sont différentes entre la principale
                 # et les autres, et éventuellement on met vide si c'est différent
                 # Tenir compte du cas où le paramétrage définit la valeur NULL
                 # comme non différente de la principale
                 #------------------------------
                 If evalue('[F:LOF]'+LCHMSRC(N_E)) <> evalue('[F:LOFP]'+LCHMSRC(N_E))
                    If LORNUL(N_E) = G_OUI
                       # Ca peut être nul : on regarde si c'est le cas !
                       If LTYPPHY(N_E) = GNUMBER
                          If evalue('[F:LOF]'+LCHMSRC(N_E)) = 0
                             LTTVEVID(N_E) = 1
                          Endif
                       Elsif LTYPPHY(N_E) = GALPHA
                          If evalue('[F:LOF]'+LCHMSRC(N_E)) = ""
                             LTTVEVID(N_E) = 1
                          Endif
                       Elsif LTYPPHY(N_E) = GDATE
                          If evalue('[F:LOF]'+LCHMSRC(N_E)) = [0/0/0]
                             LTTVEVID(N_E) = 1
                          Endif
                       Endif
                    Else  # ORNUL = "NON
                       # Strictement identique : c'est pas le cas on efface !
                       LTTVEVID(N_E) = 1
                    Endif
                 Endif
              Endif
              #------------------------------
              If LTTVEVID(N_E) = 0
                Assign '[M:LOF7]'+LCHMDES(N_E) With evalue('[F:LOFP]'+LCHMSRC(N_E))
              Else
                 # On vide la rubrique
                 If LTYPPHY(N_E) = GNUMBER
                   Assign '[M:LOF7]'+LCHMDES(N_E) With 0
                 Elsif LTYPPHY(N_E) = GALPHA
                   Assign '[M:LOF7]'+LCHMDES(N_E) With ""
                 Elsif LTYPPHY(N_E) = GDATE
                    Assign '[M:LOF7]'+LCHMDES(N_E) With [0/0/0]
                 Endif
              Endif
           Endif # END---- "Même valeur"
           If left$(LCHMDES(N_E), 7) = 'USRFLDA'
              Call GERE_REFTAB (LCHMDES(N_E), evalue('[M:LOF7]'+LCHMDES(N_E)))
           Endif
        Endif # END "Cumul" -----
     Next N_E
     #< 2 <<<<<<<<<<<<<<<<<
  Next N_I
  #< 1 <<<<<<<<<<<<<<<<<

Return
#*FQ99561##################################################################
# Mémorisation du n° de la table diverse de référence des champs USRFLDAn #
###########################################################################
Subprog GERE_REFTAB (PZONE, PVALEUR)
Value Char PZONE()
Value  Char PVALEUR()
# Affecte le numéro de la table diverse au "champ qui va bien", lorsque
# la valeur de la ZL ADI est renseignée.
# Vide la rubrique contenant le numéro de la table diverse, lorsque la
# valeur n'est pas renseignée

  If PVALEUR<>"" Then
    Assign ("[F:FAS]REFTAB"+right$(PZONE,8)) With evalue("GABLIADI"+right$(PZONE,8))
  Else
    Assign ("[F:FAS]REFTAB"+right$(PZONE,8)) With 0
  Endif
End

