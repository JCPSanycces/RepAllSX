#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################
Subprog IB_NBCXT

  Raz GBOUT1
  If [M:CXT0]NBRSRE(nolign - 1) > 0 Then
    If [M:CXT0]NBRSRE = 1 Then
      #Demande de service
      Call TEXTE(14603, GBOUT1) From OBJDIV
    Else
      #Demandes de service
      Call TEXTE(14508, GBOUT1) From OBJDIV
    Endif    
  Endif
End

##########################################################################
Subprog AS_NBCXT

  If nolign-1 >= 0 Then
    Raz [M:CXT0]NBCXTSEL
    Raz [M:CXT2]BNBCXTSEL
    [M:CXT0]NBCXTSEL(nolign-1) = "->"
    GSZSELCXT = [M:CXT0]CXTNUM(nolign-1)
    [M:CXT3]SELSRENUM = [M:CXT0]CXTSRENUM(nolign-1)
    GISELNOLCXT = nolign-1
    GICXT0CXT2SEL = 0
  Endif
  Affzo [M:CXT0]
  Affzo [M:CXT2]
End

##########################################################################
Subprog C_NBCXT

  If nolign-1 >= 0 Then
    Raz [M:CXT0]NBCXTSEL
    Raz [M:CXT2]BNBCXTSEL
    [M:CXT0]NBCXTSEL(nolign-1) = "->"
    GSZSELCXT = [M:CXT0]CXTNUM(nolign-1)
    [M:CXT3]SELSRENUM = [M:CXT0]CXTSRENUM(nolign-1)
    GISELNOLCXT = nolign-1
    GICXT0CXT2SEL = 0
  Endif
  Affzo [M:CXT0]
  Affzo [M:CXT2]
End

##########################################################################
Subprog C_CXTNUM(VALEUR)
Variable Char    VALEUR()

Local Integer I

  #Vérifie si ce code n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:CXT0]NBCXTSEL)-1
    If I <> nolign-1 Then
      If [M:CXT0]CXTNUM(I) = VALEUR and [M:CXT0]CXTNUM(I) <> "" Then
        #Ce code statistique a déjà été saisi en ligne n° NNN
        GMESSAGE = mess(714,182,1) - num$(I+1)
        GERR = 2
        mkstat = 2
        Break
      Endif
    Endif
  Next
End

##########################################################################
Subprog IB_NBCXT2

  Raz GBOUT1
  If [M:CXT2]BNBRSRE(nolign-1) > 0 Then
    If [M:CXT2]BNBRSRE = 1 Then
      #Demande de service
      Call TEXTE(14603, GBOUT1) From OBJDIV
    Else
      #Demandes de service
      Call TEXTE(14508, GBOUT1) From OBJDIV
    Endif    
  Endif
End

##########################################################################
Subprog AS_NBCXT2

  If nolign-1 >= 0 Then
    Raz [M:CXT0]NBCXTSEL
    Raz [M:CXT2]BNBCXTSEL
    [M:CXT2]BNBCXTSEL(nolign-1) = "->"
    GSZSELCXT = [M:CXT2]BCXTNUM(nolign-1)
    [M:CXT3]SELSRENUM = [M:CXT2]BCXTSRENUM(nolign-1)
    GISELNOLCXT = nolign-1
    GICXT0CXT2SEL = 1
  Endif
  Affzo [M:CXT0]
  Affzo [M:CXT2]
End

##########################################################################
Subprog C_NBCXT2

  If nolign-1 >= 0 Then
    Raz [M:CXT0]NBCXTSEL
    Raz [M:CXT2]BNBCXTSEL
    [M:CXT2]BNBCXTSEL(nolign-1) = "->"
    GSZSELCXT = [M:CXT2]BCXTNUM(nolign-1)
    [M:CXT3]SELSRENUM = [M:CXT2]BCXTSRENUM(nolign-1)
    GISELNOLCXT = nolign-1
    GICXT0CXT2SEL = 1
  Endif
  Affzo [M:CXT0]
  Affzo [M:CXT2]
End

##########################################################################
Subprog C_BCXTNUM(VALEUR)
Variable Char    VALEUR()

Local Integer I

  #Vérifie si ce code n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:CXT2]BNBCXTSEL)-1
    If I <> nolign-1 Then
      If [M:CXT2]BCXTNUM(I) = VALEUR and [M:CXT2]BCXTNUM(I) <> "" Then
        #Ce code statistique a déjà été saisi en ligne n° NNN
        GMESSAGE = mess(714,182,1) - num$(I+1)
        GERR = 2
        mkstat = 2
        Break
      Endif
    Endif
  Next
End
