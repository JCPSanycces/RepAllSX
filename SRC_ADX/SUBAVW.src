#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV, GTRACE
Call OBJET("AVW",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------------------------#
$ACTION
If dim([L]PSUBW)<=0
 Local Integer PSUBW
 Call EXISTE_ADX("","","SUBAVWB",PSUBW) From ORDSYS
Endif
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "EXEBOUT"     : Gosub EXEBOUT
 When "STATUT"      : Gosub STATUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "TRT_DIV"     : Gosub TRT_DIV
Endcase
If PSUBW
 Gosub ACTION From SUBAVWB
Endif
Return

#------------------------------------#
$OUVRE
Local Integer  STAT
Local Mask AFFCLOB [AFF]
Return

#------------------------------------#
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
If CLECUR=0 or REP="M" or !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, Copie
Endif
If CLECUR
 CHMEN += "56" : # Visu srf/Visu viw
Endif
Return

#------------------------------------#
$LIENS
Call TEXTE([F:AVW]INTIT,[M]INTITSAI) From OBJDIV
nolign = 0
For [AVD]AVD0 Where CODVUE=[F:AVW]CODVUE
 nolign += 1
 [M:AVW2] = [F:AVD]
 Call TEXTE([F:AVD]FLDINT,[M]FLDINTSAI(nolign-1)) From OBJDIV
Next AVD
[M]NBFLD = nolign
nolign = 0
For [AVC]AVC1 Where CODVUE=[F:AVW]CODVUE
 nolign += 1
 [M:AVW3] = [F:AVC]
Next AVD
[M]NBCLE = nolign
For I=1 To 2
 Read [AVB]AVB0 = [F:AVW]CODVUE;I
 If !fstat
  Assign "[M:AVW1]TEX"+num$(I) With [F:AVB]TEXTE
 Endif
Next I
Gosub INICFG
Call LIRE_CFG(NOMCFG,[M:AVW3]FICCFG) From SUBATB
Return

#----------------------------------------------------------#
$APRES_MODIF
Case zoncou
 When "FICCFG"
  If !VERROU
   Gosub INICFG
   Call LIRE_CFG(NOMCFG,[M:AVW3]FICCFG) From SUBATB
  Endif
 When "TEXTE"
  Assign "[M:AVW1]TEX"+num$([M:AVW1]TYPDBA) With zc
Endcase
Return

#------------------------------------#
$VERIF_CRE
Read [ATB]CODFIC=[M]CODVUE
If !fstat
 # Il existe déjà une table du même nom
 Call ERREUR(VALEUR-":"-mess(74,139,1)) From GESECRAN
 OK = 0 : Return
Endif
If func DOSBASE.ISBASE_RESERVED_WORDS([M]CODVUE)
 Call ERREUR(func AFNC.MES1(mess(272,133,1),[M]CODVUE)) From GESECRAN : # $1$ est un mot réservé aux bases de données
 OK = 0 : Return
Endif
Return

#------------------------------------#
$CREATION
$MODIF
Delete [AVD] Where CODVUE=[M]CODVUE
If fstat=1
 GOK = -1 : GLOCK = "$AVIEWD"-[M]CODVUE : Return
Endif
For nolign=1 To [M]NBFLD
 Raz [F:AVD]
 [F:AVD] = [M:AVW2]
 [F:AVD] = [M:AVW0]
 [F:AVD]NUMLIG = nolign
 Write [AVD]
 If fstat
  GOK = 0 : Call FSTA("AVD") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Delete [AVC] Where CODVUE=[M]CODVUE
If fstat=1
 GOK = -1 : GLOCK = "$AVIEWC"-[M]CODVUE : Return
Endif
For nolign=1 To [M]NBCLE
 Raz [F:AVC]
 [F:AVC] = [M:AVW3]
 [F:AVC] = [M:AVW0]
 [F:AVC]NUMLIG = nolign
 Write [AVC]
 If fstat
  GOK = 0 : Call FSTA("AVC") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Delete [AVB] Where CODVUE=[M]CODVUE
If fstat=1
 GOK = -1 : GLOCK = "$AVIEWB"-[M]CODVUE : Return
Endif
For I=1 To 2
 [F:AVB]CODVUE = [M:AVW0]CODVUE
 [F:AVB]TYPDBA = I
 [F:AVB]TEXTE = evalue("[M:AVW1]TEX"+num$(I))
 Write [AVB]
 If fstat
  GOK = 0 : Call FSTA("AVB") From GLOCK : Break
 Endif
Next I
If GOK<1 : Return : Endif
Gosub INICFG
Call ECRIRE_CFG(NOMCFG,[M:AVW3]FICCFG) From SUBATB
Call MODIF_CFG(NOMCFG,[M:AVW1]SECURE) From SUBATB
Call LIRE_CFG(NOMCFG,[M:AVW3]FICCFG) From SUBATB
Affzo [M:AVW3]FICCFG
Return

#------------------------------------#
$AP_ANNULE
Local Char WDOS(GLONADS),NOMOBJ(GLONAVW)
[L]WDOS = nomap
[L]NOMOBJ = [L]CODE
Gosub PROG_DEL_AWE
Return

$PROG_DEL_AWE
Read [ADS]DOSSIER = [L]WDOS
Call SUPVUE([L]NOMOBJ,[L]WDOS,[F:ADS]TYPDBA) From DOSVUE
#107271 dossier histo uniquement sur GEODE
If GPRODUIT=1 & GDOSH<>"" & filinfo(filpath("FIL",[L]CODE,"viw",GDOSH),0)>0
 Call SUPVUE([L]CODE,GDOSH,[F:ADS]TYPDBA) From DOSVUE
Endif
Return

#------------------------------------#
$EXEBOUT
Case REP
 When "V" : # Validation
  Read [ADS]DOSSIER = nomap
  Call CREVUE([M]CODVUE,nomap,[F:ADS]TYPDBA,[F:ADS]CODDBA,K) From DOSVUE
  #107271 dossier histo uniquement sur GEODE
  If GDOSH<>"" & GPRODUIT=1
   Call CREVUE([M]CODVUE,GDOSH,[F:ADS]TYPDBA,[F:ADS]CODDBA,K) From DOSVUE
  Endif
  Call OUVRE_TRACE("") From LECFIC
  Call GENVUE(nomap) From DOSVUE
  Call FERME_TRACE From LECFIC
  Call EFFACE(filpath("TRA",GTRACE,"tra"),STAT) From ORDSYS
  Raz GTRACE , GERRTRACE
Endcase
Return

#------------------------------------#
$STATUT
Case BOUT
 When "5" : Gosub VISU_SRF
 When "6" : Gosub VISU_VIW
Endcase
Return

#----------------------------------------------------------#
$VISU_SRF
If filinfo(filpath("FIL",[M:AVW0]CODVUE,"srf",nomap),0)>0
 Openi filpath("FIL",[M:AVW0]CODVUE,"srf",nomap) Using [FI_]
 Iomode adxirs "" Using [FI_]
 Iomode adxifs "" Using [FI_]
 Iomode adxium GUTF8 Using [FI_]
 Rdseq [M:AFF]AFFCLB Using [FI_]
 Openi Using [FI_]
Else
 [M:AFF]AFFCLB = filpath("FIL",[M:AVW0]CODVUE,"srf",nomap)-":"-mess(101,100,1) : # Fichier inexistant
Endif
Call DIALWIN(OK,mess(258,139,1),"AFFCLOB") From GESECRAN : # Visualisation source
Return

#----------------------------------------------------------#
$VISU_VIW
If filinfo(filpath("FIL",[M:AVW0]CODVUE,"viw",nomap),0)>0
 Openi filpath("FIL",[M:AVW0]CODVUE,"viw",nomap) Using [FI_]
 Iomode adxirs "" Using [FI_]
 Iomode adxifs "" Using [FI_]
 Iomode adxium GUTF8 Using [FI_]
 Rdseq [M:AFF]AFFCLB Using [FI_]
 Openi Using [FI_]
Else
 [M:AFF]AFFCLB = filpath("FIL",[M:AVW0]CODVUE,"viw",nomap)-":"-mess(101,100,1) : # Fichier inexistant
Endif
Call DIALWIN(OK,mess(258,139,1),"AFFCLOB") From GESECRAN : # Visualisation source
Return

#------------------------------------#
$INICFG
Local Char NOMCFG(GDIMFIC)
NOMCFG = filpath("FIL",[M:AVW0]CODVUE,"cfg",0)
Return

#-------------------------------------------------------------------------#
# Actions type de donnée AVT (Vue ou table)
#-------------------------------------------------------------------------#

$TRT_DIV
Case TRAIT
 When "AGESVTAB" : Gosub GESVTAB : # Bouton B1 type de donnée AVT
 When "ACTLVTAB" : Gosub CTLVTAB : # Contrôle type de donnée AVT
 When "ALNKVTAB" : Gosub LNKVTAB : # Champ lien type de donnée AVT
Endcase
Return

$GESVTAB
Local Char OBJET(GLONAOB)
If clalev([F:AVW])=0 : Local File AVIEW [AVW] : Endif
Look [AVW]AVW0=VALEUR
If !fstat
 OBJET = "AVW"
Else
 OBJET = "ATB"
Endif
Call OBJET(OBJET,VALEUR,"") From GOBJET
Return

$CTLVTAB
Local Char OBJET(GLONAOB)
If clalev([F:AVW])=0 : Local File AVIEW [AVW] : Endif
Look [AVW]AVW0=VALEUR
If !fstat
 OBJET = "AVW"
Else
 OBJET = "ATB"
Endif
Call CONTROLE(OBJET,"!",VALEUR,"",mkstat) From CONTOBJ
Return

$LNKVTAB
If clalev([F:AVW])=0 : Local File AVIEW [AVW] : Endif
Read [AVW]AVW0=PARAM(1)
If !fstat
 Call TEXTE([F:AVW]INTIT,VALEUR) From OBJDIV
Else
 If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
 Call LECTURE("ATB",PARAM(1),"") From CONTOBJ
 Call TEXTE([F:ATB]INTITFIC,VALEUR) From OBJDIV
Endif
Return

#-------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "ASELVTAB" : Gosub SELVTAB : # Sélection type de donnée AVT
 When "ASELVFLD" : Gosub SELVFLD : # Sélection champ AVD
 When "ASELVATI" : Gosub SELVATI : # Sélection champ AVD

Endcase
Return

$SELVATI
If filinfo(filpath("FIL","AVIEWIND","fde"),0)<0
 OBJET = "ATI"
 Return
Endif
Local Char    SELFMT(30)(0..16)
If clalev([ATX])=0 : Local File ATEXTE [ATX] : Endif
Local File AVIEWIND [AVWI]
Local File AVIEWIND [AVWI2]
Link [AVWI] With
& [AVWI2]CODIND=[AVWI]CODFIC;[AVWI]CODIND
& As [AVT_]
NBCOL = 0
For ZON="CODFIC","CODIND","DESCRIPT"
 Case ZON
  When Default
   NBCOL += 1
   COL(NBCOL) = "[F:AVWI]"+ZON
   COLTYP(NBCOL) = evalue("type([F:AVWI]"+ZON+")")
   Call TITZON("AVIEWIND",ZON,TIT(NBCOL)) From CONTOBJ
 Endcase
Next ZON
TIT = mess(8,31,1) : # Sélection
Default File [AVT_]
START = 'CODIND'
CRITERE  = 'CODFIC = "'+PARAM(1)+'"'
DEFPAG = 1
Return

$SELVTAB
If filinfo(filpath("FIL","AVIEWFLD","fde"),0)<0
 OBJET = "ATB"
 Return
Endif
Local Char    SELFMT(30)(0..16)
If clalev([ATX])=0 : Local File ATEXTE [ATX] : Endif
Local File AVIEWTAB [AVWT]
Link [AVWT] With
& [ATX]NUMERO=GLANGUE;[F:AVWT]INTITFIC
& As [AVT_]
NBCOL = 0
For ZON="CODFIC","INTITFIC","ABRFIC","COMFIC","CODACT","MODULE"
 Case ZON
  When "MODULE"
   NBCOL += 1
   COL(NBCOL) = "mess([F:AVWT]MODULE,14,1)"
   COLTYP(NBCOL) = 40
   Call TITZON("AVIEWTAB",ZON,TIT(NBCOL)) From CONTOBJ
  When "INTITFIC"
   NBCOL += 1
   COL(NBCOL) = "[F:ATX]TEXTE"
   COLTYP(NBCOL) = 40
   Call TITZON("AVIEWTAB",ZON,TIT(NBCOL)) From CONTOBJ
  When Default
   NBCOL += 1
   COL(NBCOL) = "[F:AVWT]"+ZON
   COLTYP(NBCOL) = evalue("type([F:AVWT]"+ZON+")")
   Call TITZON("AVIEWTAB",ZON,TIT(NBCOL)) From CONTOBJ
 Endcase
Next ZON
TIT = mess(142,139,1) : # Sélection d'une table ou d'une vue
Default File [AVT_]
DEFPAG = 1
Return

$SELVFLD
If filinfo(filpath("FIL","AVIEWFLD","fde"),0)<0
 OBJET = "ATZ"
 Return
Endif
Local Schar   SELFOR(30)(0..16)
Local Char    SELFMT(30)(0..16)
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
If clalev([ATX])=0 : Local File ATEXTE [ATX] : Endif
Local File AVIEWFLD [AVWF]
Link [AVWF] With
& [ATX]NUMERO=GLANGUE;[F:AVWF]NOCOURT,
& [ACV]CODACT=[F:AVWF]CODACT,
& [ATY]CODTYP=[F:AVWF]CODTYP
& As [AVF_]
NBCOL = 0
For ZON="CODFIC","CODZONE","NOCOURT","CODTYP","LONG","DIME","NUMLIG"
 Case ZON
  When "NOCOURT"
   NBCOL += 1
   COL(NBCOL) = "[F:ATX]TEXTE"
   COLTYP(NBCOL) = 40
   Call TITZON("AVIEWFLD",ZON,TIT(NBCOL)) From CONTOBJ
  When Default
   NBCOL += 1
   COL(NBCOL) = "[F:AVWF]"+ZON
   COLTYP(NBCOL) = evalue("type([F:AVWF]"+ZON+")")
   Call TITZON("AVIEWFLD",ZON,TIT(NBCOL)) From CONTOBJ
   If ZON =" DIME" : SELEXP(NBCOL) = "max([F:AVWF]DIME,[F:ACV]DIME)" : Endif
   If ZON = "LONG" : FMTCOL(NBCOL) = "N+z:5F" : Endif
 Endcase
Next ZON
TIT = mess(280,139,1) : # Sélection d'un champ d'une table ou d'une vue
Default File [AVF_]
DEFPAG = 1
START = 'CODZONE'
CRITERE  = 'CODFIC = "'+PARAM(1)+'"'
CRITERE += '& ([F:AVWF]CODACT="" | [F:ACV]FLACT=2)'
Return

#-------------------------------------------------------------------#
# Copie vue
#-------------------------------------------------------------------#

$TRTCOP
If [M]DOSORG=nomap
 Local File AVIEW   [AVW1]
 Local File AVIEWD  [AVD1]
 Local File AVIEWC  [AVC1]
 Local File AVIEWB  [AVB1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".AVIEW"   [AVW1]
 Local File =[M]DOSORG+".AVIEWD"  [AVD1]
 Local File =[M]DOSORG+".AVIEWC"  [AVC1]
 Local File =[M]DOSORG+".AVIEWB"  [AVB1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AVIEW   [AVW2]
 Local File AVIEWD  [AVD2]
 Local File AVIEWC  [AVC2]
 Local File AVIEWB  [AVB2]
 Local File ATEXTE  [ATX2]
 Local File ATABLE  [ATB2]
Else
 Local File =[M]DOSDES+".AVIEW"   [AVW2]
 Local File =[M]DOSDES+".AVIEWD"  [AVD2]
 Local File =[M]DOSDES+".AVIEWC"  [AVC2]
 Local File =[M]DOSDES+".AVIEWB"  [AVB2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
 Local File =[M]DOSDES+".ATABLE"  [ATB2]
Endif
OK = 1
Read [ATB2]CODFIC = TABLE
If !fstat
 Call ECR_TRACE(TABLE-":"-mess(74,139,1),1) From GESECRAN : # Il existe déjà une table du même nom
 OK = 0
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AVW1], [AVD1], [AVC1], [AVB1], [ATX1]
&              , [AVW2], [AVD2], [AVC2], [AVB2], [ATX2], [ATB2]
Return

$TR_COP
GOK = 1
Trbegin [AVW2] , [AVD2] , [AVC2] , [AVB1] , [ATX2]
 Delete [AVW2] Where CODVUE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AVIEW" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AVW2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AVD2] Where CODVUE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AVIEWD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AVD2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AVC2] Where CODVUE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AVIEWC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AVC2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AVB2] Where CODVUE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AVIEWB" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AVB2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AVW1]AVW0 Where CODVUE=TABLE
  [F:AVW2] = [F:AVW1]
  Call COPTEXTE([F:AVW1]INTIT,[F:AVW2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:AVW2]UPDUSR)>0 : [F:AVW2]UPDUSR = GUSER : Endif
  If dim([F:AVW2]UPDDAT)>0 : [F:AVW2]UPDDAT = date$ : Endif
  If dim([F:AVW2]UPDTIM)>0 : [F:AVW2]UPDTIM = time  : Endif
  Write [AVW2]
  If fstat
   GOK=0 : Call FSTA("AVW2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AVD1]AVD0 Where CODVUE=TABLE
  [F:AVD2] = [F:AVD1]
  Call COPTEXTE([F:AVD1]FLDINT,[F:AVD2]FLDINT) From OBJDIV
  If GOK<1 : Break : Endif
  Write [AVD2]
  If fstat
   GOK=0 : Call FSTA("AVD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AVC1]AVC0 Where CODVUE=TABLE
  [F:AVC2] = [F:AVC1]
  Write [AVC2]
  If fstat
   GOK=0 : Call FSTA("AVC2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AVB1]AVB0 Where CODVUE=TABLE
  [F:AVB2] = [F:AVB1]
  Write [AVB2]
  If fstat
   GOK=0 : Call FSTA("AVB2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#-------------------------------------------------------------------#
# Etiquettes des écrans
#-------------------------------------------------------------------#

Subprog C_CODVUE(VALEUR)
Variable Char    VALEUR()
Read [ATB]CODFIC=VALEUR
If !fstat
 GMESSAGE = VALEUR-":"-mess(74,139,1) : # Il existe déjà une table du même nom
 mkstat = 1 : End
Endif
If func DOSBASE.ISBASE_RESERVED_WORDS(VALEUR)
 Call MESSAGE(func AFNC.MES1(mess(272,133,1),VALEUR)) From GESECRAN : # $1$ est un mot réservé aux bases de données
Endif
End

Subprog C_ABRVUE(VALEUR)
Variable Char    VALEUR()
Read [AVW]AVW1(1) = VALEUR
If !fstat & [M]CODVUE<>[F:AVW]CODVUE
 # Abréviation déjà existante\Vue
 GMESSAGE = VALEUR-":"-mess(17,176,1) : # Abréviation déjà existante
 GMESSAGE += "\"+mess(77,139,1)-":"-[F:AVW]CODVUE : # Vue
 mkstat=2 : End
Endif
Read [ATB]ABRFIC=VALEUR
If !fstat
 GMESSAGE = VALEUR-":"-mess(17,176,1) : # Abréviation déjà existante
 GMESSAGE += "\"+mess(56,123,1)-":"-[F:ATB]CODFIC : # Table
 mkstat=2 : End
Endif

Subprog AM_ABRVUE(VALEUR)
Variable Char    VALEUR()
End

Subprog C_INTITSAI(VALEUR)
Variable Char    VALEUR()
Call C_QUOTE(VALEUR) From SUBATB
End

#-----------------------------------------------#
# Ecran AVW2
#-----------------------------------------------#

Subprog B1_NBFLD
Local Char CHAINE(250)
Local Integer I
If NBFLD >0
 Case GTYPDBA
  When 1 : If [M:AVW1]TEX1<>"" : CHAINE = chr$(10) : Endif
  When 2 : If [M:AVW1]TEX2<>"" : CHAINE = chr$(10) : Endif
 Endcase
 CHAINE += "Select "
 For I=0 To [M:AVW2]NBFLD-1
  If I=[M:AVW2]NBFLD-1
   CHAINE += [M:AVW2]FLDVUE(I)+"_0"
  Else
   CHAINE += [M:AVW2]FLDVUE(I)+"_0, "
  Endif
 Next I
 Case GTYPDBA
  When 1 : [M:AVW1]TEX1 += CHAINE : Affzo [M:AVW1]TEX1 : zonsui = "[M:AVW1]TEX1"
  When 2 : [M:AVW1]TEX2 += CHAINE : Affzo [M:AVW1]TEX2 : zonsui = "[M:AVW1]TEX2"
 Endcase
 mkstat = 4
Endif
End

Subprog C_FLDVUE(VALEUR)
Variable Char    VALEUR()
If vireblc(format$("KT:30X",VALEUR),2)<>VALEUR
 mkstat = 1 : End
Endif
Call UNICITE(VALEUR,[M]FLDVUE) From OBJDIV
If mkstat : End : Endif
If VALEUR<>[M]FLDVUE(nolign-1)
 Call PLAGE_ZON([M]CODVUE,VALEUR) From CONTOBJ
 If mkstat : End : Endif
Endif
End

Subprog C_CODTYP(VALEUR)
Variable Char    VALEUR()
If find(VALEUR,"AXX","AX1","AX2","AX3")
 GMESSAGE = VALEUR-":"-mess(30,139,1) : # Type de donnée non géré
 mkstat = 2 : End
Endif
End

Subprog AS_NOLIB(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If [F:ATY]TYPTYP<>1 | [F:ATY]NOLIB<>0
 mkstat = 1
Endif
End

Subprog AM_NOLIB(VALEUR)
Variable Decimal VALEUR
Read [AML]MENLOC = VALEUR
If fstat=0 & [F:AML]LONG<>0
 [M]LNG(nolign-1) = [F:AML]LONG
 Affzo [M]LNG(nolign-1)
Endif
End

Subprog D_LNG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If [F:ATY]FORTYP=""  & [F:ATY]LNGTYP=0 : # S'il s'agit d'un type de donnée standard
 Case [F:ATY]TYPTYP
  When 1  : VALEUR = 15  : # Libellé
  When 2  : VALEUR = 4   : # Entier Court
  When 3  : VALEUR = 8   : # Entier Long
  When 4  : VALEUR = 9.2 : # Décimal
  When 7  : VALEUR = 10  : # Alphanumérique
  When 9  : VALEUR = 1   : # Blob
  When 10 : VALEUR = 1   : # Clob
 Endcase
Endif
End

Subprog AS_LNG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If [F:ATY]FORTYP<>"" | [F:ATY]LNGTYP<>0 | find([F:ATY]TYPTYP,8) | find([F:ATY]CODTYP,"AXX","AX1","AX2","AX3")
 mkstat=1
Endif
End

Subprog C_LNG(VALEUR)
Variable Decimal VALEUR
Local Integer E, D , ER
ER = 0
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
Case [F:ATY]TYPTYP
 When 1  : If VALEUR>30 : ER = 1 : Endif                                    : # Libellé
 When 2  : If VALEUR<=0 | VALEUR>4 : ER = 1 : Endif                         : # Entier court
 When 3  : If VALEUR<=0 | VALEUR>8 : ER = 1 : Endif                         : # Entier long
 When 4  : E = int(VALEUR)                                                  : # Décimal
           D = val(right$(num$(mod(VALEUR,1)),3))
           If (E+D>32) | (E=0 & D=0) : ER = 1 : Endif
 When 7  : If VALEUR<=0 | VALEUR>250 | VALEUR<>fix(VALEUR) : ER = 1 : Endif : # Char
 When 9  : If VALEUR<=0 | VALEUR>20 | VALEUR<>fix(VALEUR)  : ER = 1 : Endif : # Blob
 When 10 : If VALEUR<=0 | VALEUR>20 | VALEUR<>fix(VALEUR)  : ER = 1 : Endif : # Clob
Endcase
If ER
 mkstat = 2 : GMESSAGE = mess(111,123,1) : # Longueur incorrecte
Endif
End

Subprog D_FLDACT(VALEUR)
Variable Char VALEUR()
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
VALEUR = [F:ATY]CODACT
End

Subprog AS_DIME(VALEUR)
Variable Decimal  VALEUR
If [M]FLDACT(nolign-1)<>""
 Read [ACV]CODACT = [M]FLDACT(nolign-1)
 If !fstat & [F:ACV]DIME<>0
  mkstat =1
 Endif
Endif
End

Subprog C_FLDINTSAI(VALEUR)
Variable Char VALEUR()
Call C_QUOTE(VALEUR) From SUBATB
End

Subprog C_OPTION(VALEUR)
Variable Char VALEUR()
Local Integer I , OK
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
Gosub DEF_OPTFMT From SELAMK
For I=1 To len(VALEUR)
 If !find(mid$(VALEUR,I,1),TEX(1..NBTEX))
  GMESSAGE = mid$(VALEUR,I,1)-":"-mess(99,123,1) : # Option incorrecte
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif
Case [F:ATY]TYPTYP
 When 1,8,9,10
 When 4 : # DCB
  # Dans la gestion des tables on accepte de saisir l'option F avec des décimales (Sql Server)
 When 7 : # Alpha
  #115175
  #If [F:ATY]FORTYP<>""
  If mid$([F:ATY]FORTYP,1,1)="="
   OK = 1
   For I=1 To len(VALEUR)
    If find(mid$(VALEUR,I,1),"A","#")
     OK = 0 : Break
    Endif
   Next I
   If !OK
    GMESSAGE = mid$(VALEUR,I,1)-":"-mess(53,139,1)-[F:ATY]FORTYP-"("+mess(21,115,1)-[F:ATY]CODTYP+")"
    # Option incompatible avec le format x (Type de donnée y)
    mkstat = 2 : End
   Endif
  Endif
 When Default
Endcase
End

#-----------------------------------------------#
# Ecran AVW3
#-----------------------------------------------#

Subprog C_DESCLE(VALEUR)
Variable Char    VALEUR()
Local Integer I , OK , ERR
Local Char    MESSA(250)
VALEUR = vireblc(toupper(VALEUR),2)
If VALEUR="" : mkstat=1 : End : Endif
Gosub SETNOL
If VALEUR<>""
 I = find(VALEUR,[M]DESCLE(0..[M]NBCLE-1))-1
 If I>=0 & I<>NOL
  Call ERREUR(mess(21,176,1)-[M]CODCLE(I)) From GESECRAN : # Composantes de clé déjà saisies pour l'index
  mkstat=2 : End
 Endif
Endif
Call VERF_INDEX(VALEUR,NOL,MESSA,ERR)
Case ERR
 When 1 : Call ERREUR(MESSA) From GESECRAN : mkstat=2 : End
 When 2 : Call AVERTIR(MESSA,OK) From GESECRAN : If OK<>2 : mkstat=2 : End : Endif
Endcase
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog VERF_INDEX(INDEX,NOL,MESSA,ERR)
Variable Char    INDEX()
Value    Integer NOL
Variable Char    MESSA
Variable Integer ERR
Local Integer I , J , K , NB
Local Char    DESCRIPTEUR(120), ZINDEX(120), ZCLE(20)(1..16) , ERRIND(250)
Local Decimal LNGZON , LNGCLE
Raz ERR, NB
LNGCLE = 1
DESCRIPTEUR = INDEX
While DESCRIPTEUR<>""
 ERR = 0
 NB += 1
 If NB>dim(ZCLE) : Break : Endif
 I = instr(1,DESCRIPTEUR,"+")
 J = instr(1,DESCRIPTEUR,"-")
 If I=0 & J=0
  ZINDEX = DESCRIPTEUR
  DESCRIPTEUR = ""
 Elsif I=0 & J<>0
  ZINDEX = left$(DESCRIPTEUR,J-1)
  DESCRIPTEUR = right$(DESCRIPTEUR,J+1)
 Elsif I<>0 & J=0
  ZINDEX = left$(DESCRIPTEUR,I-1)
  DESCRIPTEUR = right$(DESCRIPTEUR,I+1)
 Else
  K = min(I,J)
  ZINDEX = left$(DESCRIPTEUR,K-1)
  DESCRIPTEUR = right$(DESCRIPTEUR,K+1)
 Endif
 K = find(ZINDEX,[M:AVW2]FLDVUE(0..[M:AVW2]NBFLD-1))
 If K=0
  MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(11,176,1)
  # Index...Zone inexistante
  ERR = 1 : Break
 Elsif [M:AVW2]DIME(K-1)>1
  MESSA = ZINDEX-":"-mess(105,123,1) : # Zone dimensionnée
  ERR = 1 : Break
 Elsif find([M:AVW2]CODTYP(K-1),"AXX","AX1","AX2","AX3")
  MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(277,123,1)
  # Index Ce type de champ est interdit dans les index
  ERR = 1 : Break
 Elsif find(ZINDEX,ZCLE(1..NB-1))
  MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(278,123,1) : # Champ déjà existant
  ERR = 1 : Break
 Elsif [M:AVW2]FLDACT(K-1)<>""
  Read [ACV]CODACT = [M:AVW2]FLDACT(K-1)
  If [F:ACV]FLACT=1
   ERRIND -= ZINDEX
   ERR = 2
  Endif
 Else
  LNGCLE += 2
  Read [ATY]CODTYP=[M:AVW2]CODTYP(K-1)
  Case [F:ATY]TYPTYP
   When 1,2,3,5
    LNGZON = 4
   When 4,6
    LNGZON = 8
   When 7
    If [F:ATY]LNGTYP<>0
     LNGZON = ([F:ATY]LNGTYP+1)*2
    Else
     LNGZON = ([M:AVW2]LNG(K-1)+1)*2
    Endif
   When 8
    LNGZON = 3
   When 9,10
    MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(277,123,1)
    # Index Ce type de champ est interdit dans les index
    ERR = 1 : Break
  Endcase
  LNGCLE += LNGZON
 Endif
 ZCLE(NB) = ZINDEX
Wend

#---------------------------------------------------------------------------------------#
#  La longueur de la clé est limité à 500 octets (limite adonix)
#  Le nombre maxi d'index est 15 (un index est réservé en cas de link)
#  Une clé peut être composée de 16 champs maximum
#---------------------------------------------------------------------------------------#

If LNGCLE>500
 MESSA = INDEX-":"-mess(33,126,1)-num$(LNGCLE)+"(500)" : # Clé trop longue
 ERR = 1
Elsif NB>dim(ZCLE)
 MESSA = INDEX-":"-mess(29,176,1) : # Trop de composantes de clé (maximum #)
 K = instr(1,MESSA,"#")
 If K : MESSA = left$(MESSA,K-1)+num$(dim(ZCLE))+right$(MESSA,K+1) : Endif
 ERR = 1
Elsif NB=0
 MESSA = INDEX-":"-mess(158,133,1) : # Aucune zones actives sur cet index
 ERR = 2
Elsif ERRIND<>""
 # Index...Zone avec un code activité inactif
 MESSA = mess(10,176,1)-INDEX+"\"+ERRIND-mess(22,176,1)
 ERR = 2
Endif
End

Subprog AM_KEYDUP(VALEUR)
Variable Integer  VALEUR
Local Integer OK
If VALEUR=1
 # Etes-vous sûr qu'il n'y a pas d'homonymes sur l'index de cette vue ?
 Call AVERTIR(mess(68,143,1),OK) From GESECRAN
 If OK<>2 : mkstat = 1 : Endif
Endif
End


Subprog ACTLAVWT(TABLE,APPLI)
Variable Char    TABLE()
Value Char APPLI

If filinfo(filpath("FIL","AVIEWTAB","fde",APPLI),0)<0
 Local File =APPLI+".ATABLE"  [AVWT]
Else
 Local File =APPLI+".AVIEWTAB" [AVWT]
Endif

Read [AVWT]CODFIC = TABLE
If fstat
 GMESSAGE = TABLE-":"-mess(284,139,1) : # Table ou vue inexistante
 mkstat = 2
 End
Endif

End

