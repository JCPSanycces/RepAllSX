################################################################################
#    Gestion des traces dans ABEL X3
#    FGR
#    Création le : 23/04/2004
#    Modification le : 23/04/2004
################################################################################
################################################################################
########################################
$ERR_VIDAGE_TRACE
  Call FERME_TRACE(1)
End

########################################
# Ouvre la trace en mode "Table"
# Si on est en mode batch, ou si la trace fichier est déjà ouverte, on ne la
# ré-ouvre pas.
# ------------------------------------------------------------------------------
Subprog OUVRE_TRACE(COMMENT, NTRACE)
Value Char     COMMENT             : # Commentaire de la trace (titre normalement)
Value Shortint NTRACE              : # numéro de trace. non utilisé. Pour le moment TOUJOURS 1

Global Integer GNUMTRACE(2)        : # Numéro de trace
Global Integer GSEQTRACE           : # Numéro de séquence de trace

  # -------------------------
  Onerrgo ERR_VIDAGE_TRACE From TRACEABX3
  # -------------------------
  If clalev([F:XTRA])  = 0 : Local File TRCABX3    [XTRA]  : Endif
  # -------------------------
  If !GSERVEUR and GTRACE="" Then
    Call OUVRE_TRACE(COMMENT) From LECFIC
    GNUMTRACE(0) = G_OUI           : # Indique que le fichier trace a été ouvert ici
  Else
    GNUMTRACE(0) = G_NON           : # Indique que le fichier trace a été ouvert "ailleurs" !
  Endif
  # -------------------------
  # Pour le moment je prends adxuid(2), mais je passe quand même par la GLOBAL
  # Pour le cas où, dans le futur on changerais d'avis.
  # La globale pourrait notamment permettre de gérer plusieurs états
  GNUMTRACE(1) = adxuid(2)
  GSEQTRACE    = 0
  # -------------------------
  # Je vide la trace pour la cas où il resterait quelque chose
  Delete [XTRA] Where NUMACT=GNUMTRACE(1)
  # -------------------------
End

########################################
# Transfert du sous-pro depuis
# GLOCALC3 V140.
# ------------------------------------------------------------------------------
Subprog ECR_TRACE2(TEX,ERR)
Value    Char    TEX() : # Texte du message
Value    Integer ERR

  If dim(GSEQTRACE) > 0 Then
    # Si on est dans le mode de gestion des trace TRACEABX3
    If dim(GNOTRCCALC)<0 Then
      # On gère les traces normalement
      Call ECR_TRACE(GTRCCPY, GTRC_CCALCUL, TEX, ERR, 1) From TRACEABX3
    Else
      # On ne gère les trace que dans le cas d'erreurs
      If ERR <> 0 Then
        Call ECR_TRACE(GTRCCPY, GTRC_CCALCUL, TEX, ERR, 1) From TRACEABX3
      Endif
    Endif
  Else
    # Mode de gestion des traces "classique" X3
    If dim(GNOTRCCALC)<0 Then
      # On gère les traces normalement
      Call ECR_TRACE(TEX,ERR) From GESECRAN
    Else
      # On ne gère les trace que dans le cas d'erreurs
      If ERR <> 0 Then
        Call ECR_TRACE(TEX,ERR) From GESECRAN
      Endif
    Endif
  Endif
End

########################################
# Ecriture du texte de la trace dans la table
# ------------------------------------------------------------------------------
Subprog ECR_TRACE(PCPY, PTRITRC, TEX, ERR, NTRACE)
Value Char     PCPY()              : # Société
Value Char     TEX()               : # Texte du message
Value Integer  PTRITRC             : # Tri trace
Value Integer  ERR                 : # Code erreur
Value Shortint NTRACE              : # numéro de trace. non utilisé. Pour le moment TOUJOURS 1

  If dim(GSEQTRACE) > 0 Then 
    # -------------------------
    If clalev([F:XTRA])  = 0 : Local File TRCABX3    [XTRA]  : Endif
    # -------------------------
    GSEQTRACE     += 1
    [F:XTRA]NUMACT = GNUMTRACE(1)
    [F:XTRA]CPY    = PCPY
    [F:XTRA]TRITRC = PTRITRC
    [F:XTRA]SEQNUM = GSEQTRACE
    [F:XTRA]ERRCOD = ERR
    [F:XTRA]MSG    = TEX
    Write [F:XTRA]
    # -------------------------
  Else
    Call ECR_TRACE(TEX, ERR) From GESECRAN
  Endif
End

########################################
# Recopie du contenu de la table TRCABX3 dans le fichier trace. L'ordre de tri
# permet de restituer les informations correctement triées.
# et referme la trace
# ------------------------------------------------------------------------------
Subprog FERME_TRACE(NTRACE)
Value Shortint NTRACE              : # numéro de trace. non utilisé. Pour le moment TOUJOURS 1

  # -------------------------
  Gosub VIDE_TRACE_EN_FICHIER
  # -------------------------
  If GNUMTRACE(0) = G_OUI Then
    # La trace a été ouverte par cette tâche : c'est elle qui doit la fermer
    Call FERME_TRACE From LECFIC
  Endif
  # -------------------------
  If dim(GSEQTRACE) > 0 Then Kill GSEQTRACE : Endif
  If dim(GNUMTRACE) > 0 Then Kill GNUMTRACE : Endif
  # -------------------------
  Onerrgo
  # -------------------------
End

########################################
# Recopie du contenu de la table TRCABX3 dans le fichier trace. L'ordre de tri
# permet de restituer les informations correctement triées.
# La trace reste ouverte et peut continuer d'être utilisée
# ------------------------------------------------------------------------------
Subprog VIDE_TRACE(NTRACE)
Value Shortint NTRACE              : # numéro de trace. non utilisé. Pour le moment TOUJOURS 1

  # -------------------------
  Gosub VIDE_TRACE_EN_FICHIER
  # -------------------------
End

#---------------------------------------------------------------------------------------------------
$VIDE_TRACE_EN_FICHIER

  If clalev([F:XTRA])  = 0 : Local File TRCABX3    [XTRA]  : Endif
  # -------------------------
  Filter [XTRA] Where NUMACT=GNUMTRACE(1) and (TRITRC<GTRC_DBFINTR or (TRITRC>=GTRC_DBFINTR and CPY<>""))
  For [XTRA]TAB0
    Call ECR_TRACE([F:XTRA]MSG,[F:XTRA]ERRCOD) From GESECRAN
    #------------------------------------
    # Suite de la boucle
  Next
  #
  Filter [XTRA] Where NUMACT=GNUMTRACE(1) and TRITRC>=GTRC_DBFINTR and CPY=""
  For [XTRA]TAB0
    Call ECR_TRACE([F:XTRA]MSG,[F:XTRA]ERRCOD) From GESECRAN
    #------------------------------------
    # Suite de la boucle
  Next
  Filter [XTRA]
  # -------------------------
  Delete [XTRA] Where NUMACT=GNUMTRACE(1)
  # -------------------------
Return



################################################################################
#    Gestion des traces dans ABEL X3
#    GBN
#    Création le : 09/09/2004
#    Modification le : 09/09/2004
#
#    S/P construits sur le principe de ceux écrits au dessus mais utilisant
#    un fichier temporaire séquentiel dans le répertoire tmp. Ce fichier est
#    vidé dans la table XTRA à la fin du traitement.   
#
################################################################################
################################################################################

########################################
# Ouvre la trace en mode "Table"
# Si on est en mode batch, ou si la trace fichier est déjà ouverte, on ne la
# ré-ouvre pas.
# ------------------------------------------------------------------------------
Subprog OUVRE_TRACE_FIC(COMMENT, NTRACE)
Value Char     COMMENT             : # Commentaire de la trace (titre normalement)
Value Shortint NTRACE              : # numéro de trace. non utilisé. Pour le moment TOUJOURS 1

Global Integer GNUMTRACE(2)        : # Numéro de trace
Global Integer GSEQTRACE           : # Numéro de séquence de trace
Global Char    GTRACENAM           : # Nom de la trace X3

Local Char     TMPFICTRA(250)         
Local Char     TEXTE(200) , SAVIFS(10) , SAVIRS(10)
Local Integer  SAVIUM

#> Ouverture de la trace classique X3
Call OUVRE_TRACE(COMMENT) From LECFIC : GTRACENAM=GTRACE

#> Sauvegarde des séprateurs de champs
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

#> Construction du nom de fichier temporaire
TMPFICTRA = filpath("tmp",GTRACE,"tmp",0)
Openo TMPFICTRA , 0

#> Définition des séprateurs de champs
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Openo

#> Restauration des séprateurs de champs
adxifs    = SAVIFS
adxirs    = SAVIRS
adxium    = SAVIUM

#> Initialisation de GSEQTRACE

End



########################################
# Ecriture du texte de la trace dans la table
# ------------------------------------------------------------------------------
Subprog ECR_TRACE_FIC(PCPY, PTRITRC, TEX, ERR, NTRACE)
Value Char     PCPY()              : # Société
Value Char     TEX()               : # Texte du message
Value Integer  PTRITRC             : # Tri trace
Value Integer  ERR                 : # Code erreur
Value Shortint NTRACE              : # numéro de trace. non utilisé. Pour le moment TOUJOURS 1

Local Char TEXTE(250)

#> Sauvegarde des séprateurs de champs
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

#> Construction du nom de fichier temporaire
TMPFICTRA = filpath("tmp",GTRACE,"tmp",0)
Openo TMPFICTRA , -1

#> Définition des séprateurs de champs et enregistrements
adxifs = "~"
adxirs = chr$(10)
adxium = GUTF8

GSEQTRACE+=1
TEXTE  = PCPY+adxifs+num$(PTRITRC)+adxifs+num$(GSEQTRACE)+adxifs+num$(ERR)+adxifs+TEX
Wrseq TEXTE

Openo

#> Restauration des séparateurs de champs
adxifs    = SAVIFS
adxirs    = SAVIRS
adxium    = SAVIUM

End


########################################
# Fermeture de la trace sans affichage de celle-ci
# A faire par le trt appelant avec call LEC_TRACE from LECFIC
# ------------------------------------------------------------------------------
Subprog LEC_TRACE_FIC(NTRACE)
 Value Shortint NTRACE              : # numéro de trace. non utilisé. Pour le moment TOUJOURS 1

If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA] : Endif

Local Integer STA
Local Char    FIC_CPY
Local Char    FIC_TRITRC
Local Char    FIC_SEQTRC
Local Char    FIC_ERR
Local Char    FIC_TXT(200)
Local Char    SGTRACE
  
#> Sauvegarde des séprateurs de champs
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

#> Construction du nom de fichier temporaire
TMPFICTRA = filpath("tmp",GTRACE,"tmp",0)

#> Ouverture du fichier temporaire

Openi TMPFICTRA Using [FTRA]

#> Définition des séprateurs de champs et enregistrements
adxifs = "~"
adxirs = chr$(10)
adxium = GUTF8

Trbegin [XTRA]
#> Lecture du fichier séquentiel
Repeat
 Rdseq FIC_CPY,FIC_TRITRC,FIC_SEQTRC,FIC_ERR,FIC_TXT Using [FTRA]
 If !(FIC_CPY="" & FIC_TRITRC="" & FIC_SEQTRC="" & FIC_ERR="" & FIC_TXT="")
  [F:XTRA]NUMACT = val(right$(GTRACE,2))
  [F:XTRA]CPY    = FIC_CPY
  [F:XTRA]TRITRC = val(FIC_TRITRC)
  [F:XTRA]SEQNUM = val(FIC_SEQTRC)
  [F:XTRA]ERRCOD = val(FIC_ERR)
  [F:XTRA]MSG    = FIC_TXT
  Write [XTRA]
  If fstat
   GOK=0
   Break
  Else
   GOK=1
  Endif
 Endif
Until !(fstat=0)
If GOK<1
 Rollback
Else
 Commit
Endif

#> Fermeture du fichier séquentiel

Openi Using [FTRA]

#> Suppression du fichier temporaire

If filinfo(TMPFICTRA,0)>=0
 Call EFFACE(TMPFICTRA,STA) From ORDSYS
Endif

#> Restauration des séparateurs de champs

adxifs    = SAVIFS
adxirs    = SAVIRS
adxium    = SAVIUM

#> On vide le contenu de la table dans la trace X3

Filter [XTRA] Where NUMACT=val(right$(GTRACE,2)) and (TRITRC<GTRC_DBFINTR or (TRITRC>=GTRC_DBFINTR and CPY<>""))
For [XTRA]TAB0
 Call ECR_TRACE([F:XTRA]MSG,[F:XTRA]ERRCOD) From GESECRAN
Next
Filter [XTRA]
Filter [XTRA] Where NUMACT=val(right$(GTRACE,2)) and TRITRC>=GTRC_DBFINTR and CPY=""
For [XTRA]TAB0
 Call ECR_TRACE([F:XTRA]MSG,[F:XTRA]ERRCOD) From GESECRAN
Next
Filter [XTRA]
  # -------------------------
Delete [XTRA] Where NUMACT=val(right$(GTRACE,2))

#> Destruction des globales

If dim(GNUMTRACE)          >0      : Kill GNUMTRACE : Endif     
If dim(GSEQTRACE)          >0      : Kill GSEQTRACE: Endif     
If dim(GTRACENAM)          >0      : Kill GTRACENAM: Endif     

End

########################################
# Recopie du contenu de la table TRCABX3 dans le fichier trace. L'ordre de tri
# permet de restituer les informations correctement triées.
# et referme la trace .. et l'affiche
# ------------------------------------------------------------------------------
Subprog FERME_TRACE_FIC(NTRACE)
Value Shortint NTRACE              : # numéro de trace. non utilisé. Pour le moment TOUJOURS 1
 
Call LEC_TRACE_FIC(NTRACE)  From TRACEABX3

#> Fermeture de la trace X3
Call FERME_TRACE From LECFIC : TRA=1

End

