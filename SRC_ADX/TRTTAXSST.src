#############################################################################
Subprog CALCTAX(WABMSK, ERR, ERRMSG)

Value    Char    WABMSK
Variable Integer ERR
Variable Char    ERRMSG()

Call CALCTAX(WABMSK,ERR,ERRMSG) From TRTTAXUSA

End

#############################################################################
Subprog POSTBPINV(ERR,ERRMSG)

  Variable Integer ERR
  Variable Char    ERRMSG()

 Call POSTBPINV(ERR,ERRMSG) From TRTTAXUSA

End

#############################################################################
Subprog CANCEL_TAX(X3_CPY,VCRNUM,INVTYP)

Value Char X3_CPY(),VCRNUM()
Value Shortint INVTYP

Call CANCEL_TAX(X3_CPY,VCRNUM,INVTYP) From TRTTAXUSA

End

#############################################################################
Subprog CLCTAXEUSA(WABMSK,WSSTFLG)
Value    Char       WABMSK()
Value Char       WSSTFLG()

Call CLCTAXEUSA(WABMSK,WSSTFLG) From TRTTAXUSA

End

#############################################################################
Subprog SST_UNCOMMITBPINV(X3_CPY,X3_VCRNUM,X3_INVTYP,ERR,ERRMSG)

Value Char X3_CPY(),X3_VCRNUM()
Value Integer X3_INVTYP
Variable Integer ERR
Variable Char ERRMSG()

Call SST_UNCOMMITBPINV(X3_CPY,X3_VCRNUM,X3_INVTYP,ERR,ERRMSG) From TRTTAXUSA

End

#############################################################################
Subprog LTAGREP

Call LTAGREP From TRTTAXUSA

End

#############################################################################
Subprog IB_LTAINVATI(WBOUT)
Value Shortint WBOUT

Call IB_LTAINVATI(2) From TRTTAXUSA     # Display SST button or not

End

#############################################################################
######################################################################################
# 122614 - JOBRO - rework of SST transaction management in Sales Orders GESSOH
$RECALC_SST_SOH

  Local Integer SSTERR
  Local Char    SSTERRMSG(250)
  Local Char    SOHNUM(20) : SOHNUM = [F:SOH]SOHNUM
  Local Integer SSTTRBEGIN  #122614 - JOBRO
  Local Char    HGFONCTION(12)  #122614 - JOBRO

  #122614 - JOBRO
  # We need to be able to call the web service within a transaction or else
  # taxes won't be calculated when these routines are called from an outside
  # entity that starts the tranaction.  So set an exception variable so that
  # TRTVENFACC will call sage sales tax
  If dim(G_SST_EXCEPTION) <= 0
    Global Integer G_SST_EXCEPTION
  Endif
  G_SST_EXCEPTION = 1  #122614 - JOBRO

  GTAXBYDOC = 1

  HGFONCTION="GESSOH"
  If GFONCTION<>"GESSOH"
      HGFONCTION=GFONCTION
      GFONCTION="GESSOH"
  Endif

  # 122614 - JOBRO - If appropriate start SST's transaction
  SSTTRBEGIN = 0    #122614 - JOBRO
  If adxlog<>1
    Trbegin [SOH]
    SSTTRBEGIN=1
  Endif

  Gosub INIVALTTC From SUBSOHA  # Call the webservice to calculate tax
  If !GOK
    GERR = 1 : GMESSAGE = mess(541,192,1)
    Goto SST_TRANS_SOH
  Endif

  Call UPD_VALORISATION ("M","SOH") From TRTVENFACC
  If !GOK
    GERR = 1 : GMESSAGE = mess(541,192,1)
    Goto SST_TRANS_SOH
  Endif

  Readlock [SOH]SOH0 = [L]SOHNUM With lockwait=3
  If fstat
    Call FSTA("SOH") From GLOCK
    GOK=0
    Goto SST_TRANS_SOH
  Endif

  # Update the order header totals
  [F:SOH]ORDINVNOT  = [M:SIHV]INVNOT
  [F:SOH]ORDINVATI  = [M:SIHV]INVATI
  [F:SOH]ORDINVNOTL = [M:SIHV]INVNOTRPT
  [F:SOH]ORDINVATIL = [M:SIHV]INVATIRPT

  # Update the values back to the table
  Rewrite [SOH]
  If fstat
    Call FSTA("SOH") From GLOCK
    GOK=0
    Goto SST_TRANS_SOH
  Endif

  # Update the line level fields back to the table
  Local Integer I
  For I=0 To [M:SOH4]NBLIG-1
    Readlock [SOP]SOP3 = [L]SOHNUM;[M:SOH4]SOPLIN(I) With lockwait=3
    If fstat : Call FSTA("SOP") From GLOCK : Endif
    [F:SOP]NETPRIATI = [M:SOH4]NETPRIATI(I)
    [F:SOP]NETPRINOT = [M:SOH4]NETPRINOT(I)
    Rewrite [SOP]
    If fstat
      Call FSTA("SOP") From GLOCK
      GOK=0
      Break
    Endif
  Next

  If !GOK : Goto SST_TRANS_SOH : Endif

  #Issue 118686.sn - 2017-03-15 by CATUA
  #Sage Sales Tax
  #Move ACOMPTES call in APRES event since tax is calculated at the end of creation/modification (out of transaction)
  If WPMTREP = "C" | WPMTREP = "M"
    Case WPMTREP
      When "C"
          Call ACOMPTES(5,1,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&                 [F:SOH]CUR,[F:SOH]CHGTYP,[F:SOH]BPCINV,[F:SOH]BPCPYR,[F:SOH]BPAPYR, 1,OK) From TRTTPT
          If GOK<1 : Goto SST_TRANS_SOH : Endif

      When "M"

        #In the event where order the amount has changed TRT_ACPTE is typically called within INIMOD (in transaction) event.
        #Need to call TRT_ACPTE again in APRES_MOD (out of transaction) event since order amount including tax field ([M:SOH4]ORDINVATI)
        #may not be correct if it is in a transaction.
        If MODPTE=0 : Gosub TRT_ACPTE From SUBSOHA : Endif

        If MODPTE=1 | MODPTE=3
          Call ACOMPTES(5,2,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&               [F:SOH]CUR,0,"","","",1,OK) From TRTTPT
          If GOK<1 : Goto SST_TRANS_SOH : Endif
        Endif

        If MODPTE=1
          Call ACOMPTES(5,1,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&                 [F:SOH]CUR,[F:SOH]CHGTYP,[F:SOH]BPCINV,[F:SOH]BPCPYR,[F:SOH]BPAPYR,
&                 1,OK) From TRTTPT
          If GOK<1 : Goto SST_TRANS_SOH : Endif
        Endif

        If MODPTE<>1 and MODPTE<>3 and (MODBPCINV=1 | MODBPCPYR=1)
          Gosub UPDATE_DUD_SOH_MODBPC From SUBSOHB
          If GOK<1 : Goto SST_TRANS_SOH : Endif
        Endif

        Raz MODBPCINV,MODBPCPYR
      Endcase
  Endif

  Gosub CREMOD_LTV From TRTTAXSST  # Creates/Updates the LTAVCR table

# 122614 - JOBRO - If appropriate finish SST's transaction
$SST_TRANS_SOH
  If HGFONCTION<>"GESSOH"
    GFONCTION=HGFONCTION
  Endif

  #Handle error
  If GERR and GMESSAGE <> ""
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Raz GERR, GMESSAGE
  Endif

  #
  # If there is a transaction and WE started it, then do the commit or rollback
  # If it was started BEFORE the SST code, then rely on GOK being used there
  #
  If adxlog=1 and SSTTRBEGIN=1
    If GOK<1
      Rollback
      GOK=1
    Else
      Commit
    Endif
  Endif

  Raz WPMTREP

Return
###################################################################################
# 122614 - JOBRO - rework of SST transaction management in Deliveries GESSDH
$RECALC_SST_SDH

Local Integer SSTERR
Local Char    SSTERRMSG(250)
Local Char    SDHNUM(20) : SDHNUM = [F:SDH]SDHNUM
Local Integer SSTTRBEGIN  #122614 - JOBRO
Local Char    HGFONCTION(12)  #122614 - JOBRO

#122614 - JOBRO
# We need to be able to call the web service within a transaction or else
# taxes won't be calculated when these routines are called from an outside
# entity that starts the tranaction.  So set an exception variable so that
# TRTVENFACC will call sage sales tax
If dim(G_SST_EXCEPTION) <= 0
  Global Integer G_SST_EXCEPTION
Endif
G_SST_EXCEPTION = 1  #122614 - JOBRO

GTAXBYDOC = 1

HGFONCTION="GESSDH"
If GFONCTION<>"GESSDH"
    HGFONCTION=GFONCTION
    GFONCTION="GESSDH"
Endif

# 122614 - JOBRO - If appropriate start SST's transaction
SSTTRBEGIN = 0    #122614 - JOBRO
If adxlog<>1
  Trbegin [SOH]
  SSTTRBEGIN=1
Endif

Gosub INIVALTTC From SUBSDHA
If !GOK
  GERR = 1 : GMESSAGE = mess(541,192,1)
  Goto SST_TRANS_SDH
Endif

Call UPD_VALORISATION ("M","SDH") From TRTVENFACC
If !GOK
  GERR = 1 : GMESSAGE = mess(541,192,1)
  Goto SST_TRANS_SDH
Endif

Readlock [SDH]SDH0 = [L]SDHNUM With lockwait=3
If fstat
  Call FSTA("SDH") From GLOCK
  GOK=0
  Goto SST_TRANS_SDH
Endif

# Update the shipment header totals
[F:SDH]DLVINVNOT  = [M:SIHV]INVNOT
[F:SDH]DLVINVATI  = [M:SIHV]INVATI
[F:SDH]DLVINVNOTL = [M:SIHV]INVNOTRPT
[F:SDH]DLVINVATIL = [M:SIHV]INVATIRPT

# Update the values back to the table
Rewrite [SDH]
If fstat
  Call FSTA("SDH") From GLOCK
  GOK=0
  Goto SST_TRANS_SDH
Endif

# Update the line level fields back to the table
Local Integer I
For I=0 To [M:SDH1]NBLIG-1
  Readlock [SDD]SDD0 = [L]SDHNUM;[M:SDH1]SDDLIN(I) With lockwait=3
  If fstat
    Call FSTA("SDD") From GLOCK
    GOK=0
    Break
  Endif

  [F:SDD]NETPRIATI = [M:SDH1]NETPRIATI(I)
  [F:SDD]NETPRINOT = [M:SDH1]NETPRINOT(I)
  Rewrite [SDD]
  If fstat
    Call FSTA("SDD") From GLOCK
    GOK=0
    Break
  Endif
Next

If GOK=0 : Goto SST_TRANS_SDH : Endif

[M:SIHV]VCRTYP=2 : [M:SIHV]NUM=[L]SDHNUM
Gosub CREMOD_LTV From TRTTAXSST

$SST_TRANS_SDH

If HGFONCTION<>"GESSDH"
  GFONCTION=HGFONCTION
Endif

#Handle error
If GERR and GMESSAGE <> ""
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Raz GERR, GMESSAGE
Endif

#
# If there is a transaction and WE started it, then do the commit or rollback
# If it was started BEFORE the SST code, then rely on GOK being used there
#
If adxlog=1 and SSTTRBEGIN=1
  If GOK<1
    Rollback
    GOK=1
  Else
    Commit
  Endif
Endif

Return
######################################################################################
#122614 - JOBRO - rework of SST transaction management in Customer Invoices GESBIC
$RECALC_SST_BIC
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
  Local Integer ERR
  Local Char    ERRMSG(250)
  Local Char    SIHNUM(20) : SIHNUM = [F:SIH]NUM
  Local Integer SSTTRBEGIN

  SSTTRBEGIN = 0
  If adxlog<>1
    Trbegin [SIH]
    SSTTRBEGIN=1
  Endif

  If GREP="C" and [M:BIC0]NUM = "" : [M:BIC0]NUM=SIHNUM : Endif
  Call CALCTAX("BIC3",ERR,ERRMSG) From TRTTAXSST
  If ERR
    Call ECR_TRACE(ERRMSG,1) From GESECRAN
    GMESSAGE = mess(540,192,1)
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Raz GMESSAGE, GERR : GOK=0
    Goto SST_TRANS_BIC
  Endif

  Readlock [SIH]SIH0 = [L]SIHNUM With lockwait=3
  If fstat
    Call FSTA("SIH") From GLOCK
    GOK=0
    Goto SST_TRANS_BIC
  Endif

  # Update sales invoice header
  [F:SIH]AMTNOT   = [M:BIC1]AMTNOT
  [F:SIH]AMTATI   = [M:BIC1]AMTATI

  # Update the values back to the table
  Rewrite [SIH]
  If fstat
    Call FSTA("SIH") From GLOCK
    GOK=0
    Goto SST_TRANS_BIC
  Endif

  #CATUA X3-78917.sn
  # Create records in open items table GACCDUDATE with newly adjusted amt + tax (AMTATI)
  If !GIMPORT
    CRITSUPPR="ACCNUM="+num$([F:SIH]ACCNUM)
    Call HISTOSUPPR (CRITSUPPR) From MODECHE
    Delete [DUD] Where ACCNUM=[F:SIH]ACCNUM
    If fstat=1 : GOK=0 : Goto SST_TRANS_BIC : Endif
    Call CREECHE(1,[M]XSOI,[M]XFLGFUP,len(mess(0,510,1))) From SUBBIH
    If GOK=0 : Goto SST_TRANS_BIC : Endif
  Endif
  #CATUA X3-78917.en

  # Update customer invoice lines
  Local Integer I
  For I=0 To [M:BIC3]NBLIG-1
    Readlock [SIL]SIL0 = [L]SIHNUM; I+1 With lockwait=3
    If fstat
      Call FSTA("SIL") From GLOCK
      GOK=0
      Break
    Endif

    [F:SIL]AMTNOTLIN = [M:BIC3]AMTNOTLIN(I)
    [F:SIL]AMTATILIN = [M:BIC3]AMTATILIN(I)
    [F:SIL]AMTVAT    = [M:BIC3]AMTVAT(I)

    Rewrite [SIL]
    If fstat
      Call FSTA("SIL") From GLOCK
      GOK=0
      Break
    Endif
  Next

  If GOK=0 : Goto SST_TRANS_BIC : Endif

  Gosub CREMOD_LTV From TRTTAXSST

$SST_TRANS_BIC
  #
  # If there is a transaction and WE started it, then do the commit or rollback
  # If it was started BEFORE the SST code, then rely on GOK being used there
  #
  If adxlog=1 and SSTTRBEGIN=1
    If GOK<1
      Rollback
      GOK=1
    Else
      Commit
    Endif
  Endif

Endif

Return
######################################################################################
#122614 - JOBRO - rework of SST transaction management in Sales Invoices GESSIH
$RECALC_SST_SIH

  # If not an SST doc - get out.
  If !(func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2) : Return : Endif

  Local Char SIHNUM(20) : SIHNUM = [F:SIH]NUM
  Local Integer SSTERR
  Local Integer SSTSIHTRBEGIN
  Local Char    HGFONCTION(12)  #122614 - JOBRO

  #122614.sn - JOBRO - rework of SST transaction management
  SSTSIHTRBEGIN = 0
  If adxlog<>1
    Trbegin [SIH], [SIV] #CATUA X3-77369.n Add SIV
    SSTSIHTRBEGIN=1
  Endif

  HGFONCTION="GESSIH"
  If GFONCTION<>"GESSIH"
      HGFONCTION=GFONCTION
      GFONCTION="GESSIH"
  Endif
  #122614.en - JOBRO - rework of SST transaction management

  # This calls the web service and also handles writing back to the database
  Gosub INICREMOD_SIH From TRTTAXSST   # 106867.n
  If !GOK
    If GREP = "M" : GERR = 1 : GMESSAGE = mess(540,192,1)
    Else : SSTERR = 1 : Goto SST_TRANS_SIH : Endif
  Endif

  #CATUA X3-84760.sn
  # Calculation of the line distribution in SIHV
  If dim(G_CLCDSPLIN)<1
    Global Integer G_CLCDSPLIN
  Endif
  G_CLCDSPLIN=1

  Gosub CLC_DSPLIN From TRTVENFACC
  #CATUA X3-84760.en

  Call UPD_VALORISATION ("M","SIH") From TRTVENFACC
  If !GOK
    If GREP = "M" : GERR = 1 : GMESSAGE = mess(540,192,1)
    Else : SSTERR = 1 : Goto SST_TRANS_SIH : Endif
  Endif

  # This handles transferring details to lines and re-write
  Call ALISIDTAX([L]SIHNUM) From TRTTAXUSA
  If !GOK
    If GREP = "M" : GERR = 1 : GMESSAGE = mess(540,192,1)
    Else : SSTERR = 1 : Goto SST_TRANS_SIH : Endif
  Endif

  # When creating, update the values for the open items - 117130/115597
  If [F:SIV]INVTYP <> 5
    If !clalev([F:DUD]) : Local File GACCDUDATE [DUD] : Endif
    Filter [DUD] Where TYP=[M:SIH0]GTE & NUM=[M:SIH0]NUM
    Read [DUD]DUD0 First : If fstat : Raz [F:DUD] : Endif
    Filter [DUD]
    If [F:DUD]TYP="" & [F:DUD]NUM=""
      Call CRE_ECHEANCES From TRTVENFACC
      If !GOK
        If GREP = "M" : GERR = 1 : GMESSAGE = mess(540,192,1)
        Else : SSTERR = 1 : Goto SST_TRANS_SIH : Endif
      Endif
    Else
      Call MODECHE(1,[F:SIH]NUM,[F:SIH]AMTATI,MODFAC,MODECH) From SUBBIH
      If !GOK
        If GREP = "M" : GERR = 1 : GMESSAGE = mess(540,192,1)
        Else : SSTERR = 1 : Goto SST_TRANS_SIH : Endif
      Endif
    Endif
    Default File [SIV]

    #CATUA X3-77369.sn
    #Update the values for costing sales invoice SINVOICEV to properly handle prepayment amt + tax [SIV]INSATI
    If [F:SIV]INVTYP = 1
      Readlock [F:SIV]SIV0 = [L]SIHNUM With lockwait=3
      If fstat
        GOK=0: Call FSTA("SIV") From GLOCK
      Else
        Call AFF_ACOMPTES (1) From TRTVENFACC
        Rewrite [SIV]
        If fstat
          GOK=0: Call FSTA("SIV") From GLOCK
        Endif
      Endif
    Endif

    If !GOK
      If GREP = "M" : GERR = 1 : GMESSAGE = mess(540,192,1)
      Else : SSTERR = 1 : Goto SST_TRANS_SIH : Endif
    Endif
    #CATUA X3-77369.en
  Endif

$SST_TRANS_SIH
  If HGFONCTION<>"GESSIH"
    GFONCTION=HGFONCTION
  Endif
  If adxlog=1 and SSTSIHTRBEGIN=1
    If GOK<1
      Rollback
    Else
      Commit
    Endif
  Endif

  If GREP<> "M" and GOK<1 : Goto WEBSERVICE_ERROR  : Endif  # Delete the invoice

Return
##########################################################################################################
$WEBSERVICE_ERROR

  # Issue 117130 An error occurred with either SE or SST.
  # Since those calls are outside of the transaction, can't just do a rollback
  # Have to delete the invoice here
  Local Integer OK
  Local Char PARAM2(10)(1), SAVREP(1), DELSIHNUM(20), WSMESS(255)

  WSMESS=GMESSAGE
  SAVREP=GREP : GREP="A" : DELSIHNUM = [F:SIH]NUM
  [L]OK=-9 : Raz [L]PARAM2 : # Don't ask for confirmation
  Call ANUCOD("SIH",DELSIHNUM,PARAM2,OK) From GOBJACT
  GREP=SAVREP

  #Clear the screens
  Raz [M:SIH0], [M:SIH1], [M:SIH2], [M:SIH4], [M:SIHV]
  Affzo [M:SIH0]
  Affzo [M:SIH1]
  Affzo [M:SIH2]
  Affzo [M:SIH4]
  Affzo [M:SIHV]

  GOK = 0

  # did we come from SST or SE?
  If dim([L]SSTERR)>0 & [L]SSTERR
    WSMESS = func AFNC.MES2(mess(524,192,1),mess(45,109,1),DELSIHNUM)-WSMESS
  Else
    WSMESS = func AFNC.MES2(mess(59,2092,1),mess(45,109,1),DELSIHNUM)-WSMESS
  Endif
  Call ECR_TRACE(WSMESS, 1) From GESECRAN

Return

