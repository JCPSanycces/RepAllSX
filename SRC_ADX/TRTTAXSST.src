#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
#
#  TRTTAXSST created to call to other Taxing programs such TRTTAXUSA
#  And to check / set common fields such as [F:CPY]SSTTAXACT
#  Created May 4, 2015 due to SAM 106867
#
#############################################################################
#  Read the current company record so we can test [F:CPY]SSTTAXACT as needed
$GET_CPY_SSTTAXACT

If clalev([F:CPY]) = 0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>GSOCIETE | !(func AFNC.ACTIV("LTA"))
  Read [F:CPY] CPY0=GSOCIETE
  If fstat : Raz [F:CPY] : Endif
Endif

Return

#############################################################################
#  Read the company record so we can test [F:CPY]SSTTAXACT as needed
Subprog SET_CPY_SSTTAXACT(CPY)
Value Char CPY

If clalev([F:CPY]) = 0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>CPY | !(func AFNC.ACTIV("LTA"))
  Read [F:CPY] CPY0=CPY
  If fstat : Raz [F:CPY] : Endif
Endif

End

#############################################################################
# Make sure the LTA activity code is on before...
# Return variable to determine whether the Company sent has SST Activated / [F:CPY]SSTTAXACT = 2
# Called from SUBBIC2; C_FCYLIN and TRTADRLIB

Funprog CHK_SSTTAXACT(CPY)
Value Char CPY
Local Integer SSTTAX
SSTTAX = 0

If func AFNC.ACTIV("LTA")
  If clalev([F:CPY2]) = 0 : Local File COMPANY [CPY2] : Endif
  Read [F:CPY2] CPY0=CPY
  If fstat : Raz [F:CPY2] : Endif

  If [F:CPY2]SSTTAXACT = 2
    SSTTAX = 1
  Endif
Endif

End SSTTAX

