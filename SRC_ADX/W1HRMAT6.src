Gosub _AFF
Return

$ON_WCTRNUM
Return

$ON_ICO
Onevent BEFORE_INPUT Call AS_ICO(zc) From W1HRMAT6
Return

Subprog AS_ICO(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(735,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_ICO(zc) From W1HRMAT6
Gosub _AFF
End

Subprog CL_ICO(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GOBJETC0
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0"
 Local Char    OBJCLE(30)
 OBJCLE = [M]WCTRNUM
 Call OBJET_CHAR(OBJCLE,"CTR",[M]REFNUM+"~"+[M]WCTRDAT) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

