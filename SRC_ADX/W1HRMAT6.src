#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT6 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:43"
A_USER  = "DOC"
A_STAMP = "20181109230443"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRCTR"
  If [M]NBRCTR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT6 [EMP6]
Gosub HORODAT
Local Inpbox "HRMAT6" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMP6] As [SIM_]
Grizo [EMP6]10
Grizo [EMP6]20
Grizo [EMP6]30
Grizo [EMP6]40
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMP6]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=0 : Y1(0)=1 : Y2(0)=23
X1(1)=1 : X2(1)=88 : Y1(1)=1 : Y2(1)=7
X1(2)=1 : X2(2)=88 : Y1(2)=8 : Y2(2)=19
X1(3)=1 : X2(3)=88 : Y1(3)=20 : Y2(3)=23
Return

$ON_NBRCTR
Onevent BEFORE_INPUT Call AS_NBRCTR From W1HRMAT6
Return

Subprog AS_NBRCTR
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBRCTR From SUBEML2
Gosub _AFF
End

$ON_CTRDAT
Onevent BEFORE_AREA Gosub AV_CTRDAT From W1HRMAT6
Return

$AV_CTRDAT
Chgfmt [M]CTRDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_CTRNUM
Return

$ON_LEGCTR
Onevent INIT_AREA Call D_LEGCTR(zc) From W1HRMAT6
Return

Subprog D_LEGCTR(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEGCTR,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

$ON_SOCCTR
Return

$ON_WCTRDAT
Onevent BEFORE_AREA Gosub AV_WCTRDAT From W1HRMAT6
