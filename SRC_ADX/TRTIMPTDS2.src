$RAZ_IMPORT
GOK=1
Trbegin [HRDAE],[DAS],[DAP], [DAC], [DAG], [DAH], [DAI], [DAJ], [DAK], [DAL],[DAM],[DPE],[DPP],[DAQ],[DQE],[DMU],[DME],[DMP]
Delete [HRDAE] Where YEAEMPDDS=[M:ITDS]FICYEA
If fstat=1
 GOK = -1 : GLOCK = "IDADEMP" : Goto ROLL_RAZ
Elsif fstat
 Goto AB_RAZ
Endif
Delete [DAS] Where YEAEMPDDS=[M:ITDS]FICYEA
If fstat=1
 GOK = -1 : GLOCK = "IDADEMP2" : Goto ROLL_RAZ
