#<AdxTL>@(#)7.0.0.0 $Revision$
##############################################################################################
#
############## AU 14/09/10 ; IMPORT POSSIBLE AVEC UN FICHIER V08R09 & V08R10 #################
#
##############################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTIMPTDS","TRTIMPTDS",4,"") From GTRAITE
End

###############################
$OUVRE
Close Local File [HRDAE]
Gosub OUVRE From SUBIDA
If clalev([F:HRDAE])=0  : Local File IDADEMP    [HRDAE]  : Endif
If clalev([F:DAS])=0  : Local File IDADEMP2   [DAS]  : Endif
If clalev([F:DAP])=0  : Local File IDADEMP3   [DAP]  : Endif
If clalev([F:DPE])=0  : Local File IDADEMP31  [DPE] : Endif
If clalev([F:DPP])=0  : Local File IDADEMP32  [DPP] : Endif
If clalev([F:DMU])=0  : Local File IDADEMP33  [DMU]  : Endif
If clalev([F:DME])=0  : Local File IDADEMP34  [DME]  : Endif
If clalev([F:DMP])=0  : Local File IDADEMP35  [DMP]  : Endif
If clalev([F:DAC])=0  : Local File IDADEMP4   [DAC]  : Endif
If clalev([F:DAG])=0  : Local File IDADEMP5   [DAG]  : Endif
If clalev([F:DAH])=0  : Local File IDADEMP6   [DAH]  : Endif
If clalev([F:DAI])=0  : Local File IDADEMP7   [DAI]  : Endif
If clalev([F:DAJ])=0  : Local File IDADEMP8   [DAJ]  : Endif
If clalev([F:DAK])=0  : Local File IDADEMP9   [DAK]  : Endif
If clalev([F:DAL])=0  : Local File IDADEMP10  [DAL]  : Endif
If clalev([F:DAM])=0  : Local File IDADEMP11  [DAM]  : Endif
If clalev([F:DAQ])=0  : Local File IDADEMP12  [DAQ]  : Endif
If clalev([F:DQE])=0  : Local File IDADEMP121 [DQE]  : Endif
#DNA
If clalev([F:DNA])=0 : Local File IDADDNA   [DNA] : Endif
If clalev([F:DNB])=0 : Local File IDADDNA2  [DNB] : Endif
If clalev([F:DNE])=0 : Local File IDADDNA5  [DNE] : Endif
If clalev([F:DNF])=0 : Local File IDADDNA6  [DNF] : Endif

Local Integer TYP, IDAS, IDPP, IDPP2, FLGPREV, NEWSAL, AFFOK,IDAE
Local Integer NBDAE, NBDAS, NBDAG, NBDAH, NBDAI, NBDAJ, NBDAK, NBDAL, NBDAM
Local Integer NBDAP, NBDPE, NBDPP, NBDAQ, NBDQE, NBDAC
Local Integer NBDNA, NBDNB, NBDNE, NBDNF
Local Char SIGNE (1), REFCTR(50), SITE (GLONFCY),SITEDAD (GLONFCY)
Local Date STRDATCTR, ENDDATCTR
Return

###############################
$TR_IMPORT_IDA
GOK=1
If[M:ITDS]FLGRAZ=2
 Gosub RAZ_IMPORT
Endif
If GOK>0
 Trbegin [HRDAE],[DAS],[DAP], [DAC], [DAG], [DAH], [DAI], [DAJ], [DAK], [DAL],[DAM],[DPE],[DPP],[DAQ],[DQE],[DMU],[DME],[DMP]
 Gosub IMPORT
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Return : Else Goto TR_IMPORT_IDA : Endif
 Elsif ![V]GOK
  Rollback
  Return
 Endif
 Commit
Endif
Return


######################################
$IMPORT
Raz [F:ARM], [F:ATT]
[F:ARM]NUMREQ=[L]NUMREQ
[F:ARM]CREDAT=date$
[F:ARM]USR   =[V]GUSER
[F:ARM]RPTCOD="TRTIMPTDS2"
[F:ATT]NUMREQ=[F:ARM]NUMREQ
[F:ATT]CREDAT=[F:ARM]CREDAT

# Démarrage en cours d'année on importe toutes les zones dads-u...
Filter [FTD] Where YEA=[M:ITDS]FICYEA & NATREC<>2 & (XPSRES<>'' & XPSRES<>'SIGNE' & left$(XPSRES,7)<>'[L]VOID')
&                  & left$(NUMREC,4)<'S70.'


[L]SAVIFS=adxifs
[L]SAVIRS=adxirs
[L]SAVIUM=adxium
adxifs   =","
adxirs   =chr$(13)+chr$(10)
adxium   =[V]GASCII
Openi [L]FICHIER, 0

Repeat
 Rdseq [F:ARM]CLEA1, [F:ATT]TXT
 If fstat : Break : Endif
 [F:ATT]TXT=seg$([F:ATT]TXT,2,len([F:ATT]TXT)-1)

 Case [F:ARM]CLEA1
  When "S20.G01.00.001"
   I=1
   [F:ARM]CLEA2 =[F:ATT]TXT : # SIREN de l'entreprise
   [F:ARM]SEQREQ=2
   [L]MAIFCY=[F:ATT]TXT : # SIREN de l'entreprise                              :#N4DS
   Raz [F:ARM]CLEN1, [F:ARM]CLEA3, [F:ARM]CLEA4, [F:ARM]CLED1
  When "S10.G01.00.001.001","S80.G01.00.001.001"
   I=1
   #Le site principal n'est plus l'emetteur mais le siège (Demande BASAH)
   #If [F:ARM]CLEA1 ="S10.G01.00.001.001" & [M:ITDS]CPY=2 & [M:ITDS]FCY=2
   # [L]MAIFCY=[F:ATT]TXT : # SIREN de l'émetteur / de l'établissement
   #Endif
   [F:ARM]CLEA2 =[F:ATT]TXT
   [F:ARM]SEQREQ=3
   Raz [F:ARM]CLEA3, [F:ARM]CLEA4, [F:ARM]CLED1
 When "S30.G01.00.001"
   I=1
   [F:ARM]CLEA4 =[F:ATT]TXT : # N°ss
   [F:ARM]SEQREQ=4
   Raz [F:ARM]CLED1
  When "S41.G01.00.001","S40.G01.00.001"        :#N4DS
   I=1
   [F:ARM]CLED1 =func TRTIMPTDS.GDAT([F:ATT]TXT)
 Endcase

 If I
  Look [FTD]FTD0=[M:ITDS]FICYEA;[F:ARM]CLEA1
  If !fstat
   [F:ARM]NUMLIG+=1
   [F:ATT]LIG    =[F:ARM]NUMLIG
   Write [ARM]
   If fstat
    [V]GOK=0
    Call FSTA("ARM") From GLOCK
    Break
   Endif
   Write [ATT]
   If fstat
    [V]GOK=0
    Call FSTA("ATT") From GLOCK
    Break
   Endif
  Endif
 Endif
Until 0
Filter [FTD]

Openi
adxifs=[L]SAVIFS
adxirs=[L]SAVIRS
adxium=[L]SAVIUM

If [V]GOK<1 : Return : Endif

Link [ARM] With [ATT]ATT0=NUMREQ;NUMLIG As [LNK]

Link [ARM2] With [ATT2]ATT0=NUMREQ;NUMLIG As [LNK2]

Filter [LNK] Where NUMREQ=[L]NUMREQ & SEQREQ=4 & CLED1<>[0/0/0] Order By Key CLE=CLEA4;CLED1;NUMLIG
For [LNK]CLE(1)
 Gosub SALARIE
 If [V]GOK<1 : Break : Endif
Next
Filter [LNK]
If [V]GOK<1 : Return : Endif

Delete [ATT] Where NUMREQ=[L]NUMREQ
Delete [ARM] Where NUMREQ=[L]NUMREQ
Return

#-------------------------------------------------------------------------------
$SALARIE
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(func AFNC.MES1(mess(55,10711,1),[F:ARM]CLEA4),0) From GESECRAN
#              Import salarié de NIR $1$


#"S41.G01.00.005" : NIC de l'établissement d'affectation
#"S40.G01.00.005" : NIC de l'établissement d'affectation                                  :#N4DS
Filter [LNK2] Where NUMREQ=[L]NUMREQ & SEQREQ=4 & CLEA2=[F:ARM]CLEA2
&                 & CLEA4=[F:ARM]CLEA4 & (CLEA1="S41.G01.00.005" | CLEA1="S40.G01.00.005")
&      Order By Key CLE=CLED1
I=0
For [LNK2]CLE
 Filter [FCY] Where CRN=[F:ARM2]CLEA2+[F:ATT2]TXT
 Read [FCY]FCY0 First
 Filter [FCY]
 If fstat
  Call ECR_TRACE(mess(39,10711,1)-":"-[F:ARM2]CLEA2+[F:ATT2]TXT,1) From GESECRAN
  #              Salarié non importé ; Site de rattachement inconnu
  I=1
 Endif
Next
Filter [LNK2]
If I : Return : Endif

Raz [L]REFNUM
Filter [ID] Where left$(NUMSSC,13)=[F:ARM]CLEA4
Read [ID]ID0 First
Filter [ID]
If !fstat
 [L]REFNUM = [F:ID]REFNUM
 [L]NEWSAL = 1
Else
 Raz [F:ID]
Endif

If [L]REFNUM=""
 #Matricule provisoire car salarié pas dans la base...
 #Read [TCA]TCA0=9 : # Module tronc commun
 Call LECTCA(9,STAT) From SUBTCA
 Call NUMERO([F:TCA]CODNUM(2),[F:FCY]FCY,[F:ARM2]CLED1,"",[L]REFNUM,I) From SUBANM
 If I
  Call ECR_TRACE(mess(4,10702,1)-[F:TCA]CODNUM(2),1) From GESECRAN : # Erreur sur compteur
  [V]GOK=0
  Return
 Endif
 [L]NEWSAL = 2
Endif

For [LNK]CLE(2)

 Raz [L]CTR,[L]SITE,[L]SITEDAD
 # Récupération du numéro de contrat tel qu'il a été créé lors de l'import des données salarié
 Filter [CTR] Where REFNUM=[L]REFNUM & CTRDAT<=[F:ARM]CLED1 & ETRFCY=[F:FCY]FCY
 Read [CTR] CTR1 Last
 Filter [CTR]
 If !fstat
  [L]CTR = [F:HRCTR]CTRNUM
  [L]SITE = [F:HRCTR]ETRFCY
 Else
  #Read [TCA]TCA0=9 : # Module tronc commun
  Call LECTCA(9,STAT) From SUBTCA
  Call NUMERO([F:TCA]CODNUM(4),[F:FCY]FCY,[F:ARM2]CLED1,"",[L]CTR,I) From SUBANM
  If I
   Call ECR_TRACE(mess(4,10702,1)-[F:TCA]CODNUM(4),1) From GESECRAN : # Erreur sur compteur
   [V]GOK=0
   Break
  Endif
  [L]SITE = [F:FCY]FCY
 Endif

 If [F:FCY]DADFCY<>""
  [L]SITEDAD=[F:FCY]DADFCY
 Else
  [L]SITEDAD=SITE
 Endif

 # Type de fiche dads-u Normal (passe à 3 si BTP)
 [L]TYP= 1

 Raz[HRDAE],[DAS],[DAP], [DAC], [DAG], [DAH], [DAI], [DAJ], [DAK], [DAL],[DAM],[DPE],[DPP],[DAQ],[DQE],[DMU],[DME],[DMP]
 Raz NBDAE, NBDAS, NBDAG, NBDAH, NBDAI, NBDAJ, NBDAK, NBDAL, NBDAM, NBDAP, NBDAQ, NBDAC, NBDNA, NBDNB, NBDNE, NBDNF
 IDAS=0 : IDPP=0 : IDPP2=0
 For [LNK]CLE
  If ([F:ARM]CLEA1="S41.G01.00.001"  | [F:ARM]CLEA1="S40.G01.00.001")    :#N4DS
   # Ecriture des structures & sous-structures avant de passer à une nouvelle période d'activité
   If NBDNF
    Gosub WRITE_DNF
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DNF]: Raz NBDNF
   Endif
   If NBDNE
    Gosub WRITE_DNE
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DNE]: Raz NBDNE
   Endif
   If NBDNB
    Gosub WRITE_DNB
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DNB]: Raz NBDNB
   Endif
   If NBDNA
    Gosub WRITE_DNA
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DNA]: Raz NBDNA
   Endif
   If NBDAQ
    Gosub WRITE_DAQ
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DAQ]: Raz NBDAQ
   Endif
   If NBDAP
    Gosub WRITE_DAP
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DAP]: Raz NBDAP
   Endif
   If NBDAM
    Gosub WRITE_DAM
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DAM]: Raz NBDAM
   Endif
   If NBDAL
    Gosub WRITE_DAL
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DAL]: Raz NBDAL
   Endif
   If NBDAK
    Gosub WRITE_DAK
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DAK]: Raz NBDAK
   Endif
   If NBDAJ
    Gosub WRITE_DAJ
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DAJ]: Raz NBDAJ
   Endif
   If NBDAI
    Gosub WRITE_DAI
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DAI]: Raz NBDAI
   Endif
   If NBDAH
    Gosub WRITE_DAH
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DAH]: Raz NBDAH
   Endif
   If NBDAG
    Gosub WRITE_DAG
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DAG]: Raz NBDAG
   Endif
   If NBDAS
    Gosub WRITE_DAS
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:DAS]: Raz NBDAS
   Endif
   If NBDAE
    Gosub WRITE_DAE
    If [V]GOK<1 : Break 2 : Endif
    Raz [F:HRDAE]: Raz NBDAE
   Endif
  Elsif ([F:ARM]CLEA1="S41.G01.01.001" | [F:ARM]CLEA1="S40.G01.00.001") & NBDAS
   Gosub WRITE_DAS
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAS]: Raz NBDAS
  Elsif ([F:ARM]CLEA1="S41.G30.10.001" | [F:ARM]CLEA1="S40.G30.10.001") & NBDAG
   Gosub WRITE_DAG
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAG]
  Elsif ([F:ARM]CLEA1="S41.G30.11.001.001" | [F:ARM]CLEA1="S40.G30.11.001") & NBDAH
   Gosub WRITE_DAH
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAH]
  Elsif ([F:ARM]CLEA1="S41.G30.15.001" | [F:ARM]CLEA1="S40.G30.15.001") & NBDAI
   Gosub WRITE_DAI
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAI]
  Elsif ([F:ARM]CLEA1="S41.G30.20.001" | [F:ARM]CLEA1="S40.G30.20.001") & NBDAJ
   Gosub WRITE_DAJ
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAJ]
  Elsif [F:ARM]CLEA1="S41.G30.25.001" & NBDAK
   Gosub WRITE_DAK
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAK]
  Elsif [F:ARM]CLEA1="S41.G30.30.001.001" & NBDAL
   Gosub WRITE_DAL
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAL]
  Elsif ([F:ARM]CLEA1="S41.G30.36.001" | [F:ARM]CLEA1="S40.G30.36.001") & NBDAM
   Gosub WRITE_DAM
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAM]
  Elsif [F:ARM]CLEA1="S45.G05.00.001" & NBDAP
   Gosub WRITE_DAP
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAP]
  Elsif [F:ARM]CLEA1="S45.G10.00.001" & NBDAQ
   Gosub WRITE_DAQ
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAQ]
  Elsif ([F:ARM]CLEA1="S46.G01.00.001" |[F:ARM]CLEA1="S60.G05.00.001" )& NBDAC
   Gosub WRITE_DAC
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAC]: Raz NBDAC
  Elsif [F:ARM]CLEA1="S40.G10.00.005" & NBDNA
   Gosub WRITE_DNA
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DNA] : Raz NBDNA
  Elsif [F:ARM]CLEA1="S40.G28.10.001" & NBDNB
   Gosub WRITE_DNB
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DNB]
  Elsif [F:ARM]CLEA1="S40.G28.15.001" & NBDNE
   Gosub WRITE_DNE
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DNE]
  Elsif [F:ARM]CLEA1="S40.G15.00.001" & NBDNF
   Gosub WRITE_DNF
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:DNF]
  Endif
  [L]AFFOK=0
  Gosub AFFECTE_COMMUN From TRTIMPTDS
  If ![L]AFFOK :  Gosub AFFECTE_SUITE : Endif
 Next
 If [V]GOK<1 : Break : Endif

 # Ecriture des structures & sous-structures de la dernière période d'activité
 If NBDNF=1
   Gosub WRITE_DNF
   If [V]GOK<1 : Break : Endif
 Endif
 If NBDNE=1
   Gosub WRITE_DNE
   If [V]GOK<1 : Break : Endif
 Endif
 If NBDNB=1
   Gosub WRITE_DNB
   If [V]GOK<1 : Break : Endif
 Endif
 If NBDNA=1
   Gosub WRITE_DNA
   If [V]GOK<1 : Break : Endif
 Endif
 If NBDAC
  Gosub WRITE_DAC
  If [V]GOK<1 : Break 2 : Endif
  Raz [F:DAC]: Raz NBDAC
 Endif
 If NBDAQ
  Gosub WRITE_DAQ
  If [V]GOK<1 : Break 2 : Endif
  Raz [F:DAQ]: Raz NBDAQ
 Endif
 If NBDAP
  Gosub WRITE_DAP
  If [V]GOK<1 : Break 2 : Endif
   Raz [F:DAP]: Raz NBDAP
  Endif
 If NBDAM
  Gosub WRITE_DAM
  If [V]GOK<1 : Break 2 : Endif
  Raz [F:DAM]: Raz NBDAM
 Endif
 If NBDAL
  Gosub WRITE_DAL
  If [V]GOK<1 : Break 2 : Endif
  Raz [F:DAL]: Raz NBDAL
 Endif
 If NBDAK
  Gosub WRITE_DAK
  If [V]GOK<1 : Break 2 : Endif
  Raz [F:DAK]: Raz NBDAK
 Endif
 If NBDAJ
  Gosub WRITE_DAJ
  If [V]GOK<1 : Break 2 : Endif
  Raz [F:DAJ]: Raz NBDAJ
 Endif
 If NBDAI
  Gosub WRITE_DAI
  If [V]GOK<1 : Break 2 : Endif
  Raz [F:DAI]: Raz NBDAI
 Endif
 If NBDAH
  Gosub WRITE_DAH
  If [V]GOK<1 : Break 2 : Endif
  Raz [F:DAH]: Raz NBDAH
 Endif
 If NBDAG
  Gosub WRITE_DAG
  If [V]GOK<1 : Break 2 : Endif
  Raz [F:DAG]: Raz NBDAG
 Endif
 If NBDAS=1
   Gosub WRITE_DAS
   If [V]GOK<1 : Break : Endif
 Endif
 Gosub WRITE_DAE
 If [V]GOK<1 : Break : Endif
Next

If [V]GOK<1 : Return : Endif
Return


###########################
$AFFECTE_SUITE
Case [F:ARM]CLEA1
When "S41.G01.00.001","S40.G01.00.001"
 [F:HRDAE]ETRDAT=func TRTIMPTDS.GDAT([F:ATT]TXT)
 [F:HRDAE]ETRFCY=[L]SITE
 [F:HRDAE]DADFCY=[L]SITEDAD
 NBDAE =1
 IDAE  =-1 : IAVN=-1 : IEXS=-1
When "S41.G01.00.002.001","S40.G01.00.002.001"
 Read [ADI]CODE=10607;[F:ATT]TXT
 If !fstat
  [F:HRDAE]ETRGRD=[F:ADI]A1
 Else
  [F:HRDAE]ETRGRD=func TRTIMPTDS.ATABDIV(10386,"A1",[F:ATT]TXT) :#CHECK IGNORE_LINE
 Endif
When "S41.G01.00.003","S40.G01.00.003"
 [F:HRDAE]XITDAT=func TRTIMPTDS.GDAT([F:ATT]TXT)
When "S41.G01.00.004.001", "S40.G01.00.004.001"
  Read [ADI]CODE=10607;[F:ATT]TXT
  If !fstat
   [F:HRDAE]XITGRD=[F:ADI]A2
  Else
   #[F:HRDAE]XITGRD=func TRTIMPTDS.ATABDIV(10359,"A1",[F:ATT]TXT)
   [F:HRDAE]XITGRD=func TRTIMPTDS.GROUND_COD("HRXGD","CODN4H",[F:ATT]TXT)
  Endif
When "S41.G01.00.009","S40.G10.00.009.001"
  [F:HRDAE]MOVPAY=val([F:ATT]TXT)
################################################## DNA
When "S40.G10.00.005"
Case val([F:ATT]TXT)
  When 10 : [F:DNA]DNASITADM=1
  When 11 : [F:DNA]DNASITADM=2
  When 13 : [F:DNA]DNASITADM=3
  When 14 : [F:DNA]DNASITADM=4
  When 40 : [F:DNA]DNASITADM=5
  When 42 : [F:DNA]DNASITADM=6
  When 43 : [F:DNA]DNASITADM=7
 Endcase
 NBDNA=1
When "S40.G10.00.006"
 [F:DNA]DNACPYSTG   =val([F:ATT]TXT)
 NBDNA=1
When "S40.G10.00.037"
 Case val([F:ATT]TXT)
  When 90 : [F:DNA]TYPLNK=5
  When Default : [F:DNA]TYPLNK=val([F:ATT]TXT)
 Endcase
 NBDNA=1
When "S40.G10.06.001.001"
 If val([F:ATT]TXT)<4
  [F:DNA]DNACCP=val([F:ATT]TXT)
 Elsif val([F:ATT]TXT)=4
  [F:DNA]DNACCP=5
 Endif
 NBDNA=1
When "S40.G15.05.013.001"
 Case val([F:ATT]TXT)
  When 10 : [F:DNA]DNACODMOD=1
  When 20 : [F:DNA]DNACODMOD=2
  When 21 : [F:DNA]DNACODMOD=3
  When Default : [F:DNA]DNACODMOD=4
 Endcase
 NBDNA=1
 If [F:HRDAE]TYPJOB=0 :
  Case val([F:ATT]TXT)
   When 10    : [F:HRDAE]TYPJOB=1
   When 20,21 : [F:HRDAE]TYPJOB=2
   When Default :  [F:HRDAE]TYPJOB=12    :#Autre
  Endcase
 Endif
When "S48.G10.00.015"
 [F:DNA]DNAACTASS = val([F:ATT]TXT)
 NBDNA=1
When "S48.G10.00.016"
 Case val([F:ATT]TXT)
  When 1,2     : [F:DNA]DNAEXOASS = val([F:ATT]TXT)
  When 3       : [F:DNA]DNAEXOASS = 4
  When Default : [F:DNA]DNAEXOASS = 3
 Endcase
 NBDNA=1
When "S48.G10.00.017"
 [F:DNA]DNAAGS = val([F:ATT]TXT)
 NBDNA=1
################################################### DNB
When "S40.G28.10.001"
 [F:DNB]DNACODPRM = val([F:ATT]TXT)
 NBDNB+=1
################################################### DNE
When "S40.G28.15.001"
 Case val([F:ATT]TXT)
  When 103: [F:DNE]DNACODIND =7
  When 220: [F:DNE]DNACODIND =19
  When 3  : [F:DNE]DNACODIND =20
  When 4  : [F:DNE]DNACODIND =21
  When 101  : [F:DNE]DNACODIND =22
  When 102  : [F:DNE]DNACODIND =23
  When 104  : [F:DNE]DNACODIND =24
  When Default : [F:DNE]DNACODIND = val([F:ATT]TXT)-200
 Endcase
 NBDNE+=1
################################################### DNF
When "S40.G15.00.001","S40.G15.05.025.001"
 Case val([F:ATT]TXT)
  When 10 : [F:DNF]DNACODTIM = 3
  When 12 : [F:DNF]DNACODTIM = 9
  When 20 : [F:DNF]DNACODTIM = 5
  When 21 : [F:DNF]DNACODTIM = 6
  When 31 : [F:DNF]DNACODTIM = 1
  When 32 : [F:DNF]DNACODTIM = 2
  When 33 : [F:DNF]DNACODTIM = 7
  When 34 : [F:DNF]DNACODTIM = 8
  When 36 : [F:DNF]DNACODTIM = 4
  When Default : [F:DNF]DNACODTIM = 3
 Endcase
 NBDNF+=1
When "S40.G15.05.025.002"
 [F:DNF]DNAHORCPY=val([F:ATT]TXT)
When "S40.G15.05.025.003"
 [F:DNF]DNAHORCTR=val([F:ATT]TXT)
###################################################
When "S40.G10.05.017"
 [F:HRDAE]GRA=left$([F:ATT]TXT,5)
 [F:HRDAE]COE=seg$([F:ATT]TXT,6,14)
 [F:HRDAE]IND=seg$([F:ATT]TXT,15,23)
When "S41.G02.00.008","S40.G10.05.018"
 Case val([F:ATT]TXT)
  When 1       : [F:HRDAE]PRUFLG=2
  When Default : [F:HRDAE]PRUFLG=1
 Endcase
When "S41.G01.00.012.003"
  Case[F:ATT]TXT
   When "03" : [F:HRDAE]FLGJNT=2
   When Default : [F:HRDAE]FLGJNT=1
  Endcase
When "S41.G01.00.017", "S41.G01.00.019","S45.G05.00.006"
 [V]GOK=1     : # Juste pour ne pas avoir d'erreur dans la trace car info utilisées
                # mais non importées directement

When "S41.G01.00.025","S40.G25.00.025"
 [F:HRDAE]SCTFCY=num$(val([F:ATT]TXT))
 [F:HRDAE]RSKWRK=[F:ATT]TXT
When "S41.G01.00.026","S40.G25.00.026"
 [F:HRDAE]CODRSK=[F:ATT]TXT
 [F:HRDAE]RSKWRK+=[F:ATT]TXT
When "S41.G01.00.027","S40.G25.00.027"
 [F:HRDAE]CODOFC=2
When "S41.G01.00.028","S40.G25.00.028"
 [F:HRDAE]RATWAC=val([F:ATT]TXT)/100
When "S41.G01.00.029.003","S40.G28.05.029.003"
 [F:HRDAE]NATBAS=val([F:ATT]TXT)
When "S40.G30.02.001" :
 If [F:DAS]NBRURSBBE<>IDAS : IDAS=[F:DAS]NBRURSBBE : Endif
 [F:DAS]URSBBECOD(IDAS)=func TRTIMPTDS.ATABDIV(10640,"A1",[F:ATT]TXT)
 [F:DAS]NBRURSBBE+=1
 NBDAS=1
When "S40.G30.03.001" :
 If [F:DAS]NBRURSBBP<>IDAS : IDAS=[F:DAS]NBRURSBBP : Endif
 [F:DAS]URSBBPCOD(IDAS)=func TRTIMPTDS.ATABDIV(10641,"A1",[F:ATT]TXT)
 [F:DAS]NBRURSBBP+=1
 NBDAS=1
When "S41.G01.01.001","S44.G03.05.001"
 If [F:DAS]NBRRGM<>IDAS : IDAS=[F:DAS]NBRRGM : Endif
 [F:DAS]RGMCOD(IDAS)=func TRTIMPTDS.ATABDIV(10340,"A1",[F:ATT]TXT)
 [F:DAS]NBRRGM+=1
 NBDAS=1
When "S41.G01.02.001","S44.G10.10.001"
 If [F:DAS]NBRSPEBAS<>IDAS : IDAS=[F:DAS]NBRSPEBAS : Endif
 [F:DAS]SPEBASCOD(IDAS)=func TRTIMPTDS.ATABDIV(10341,"A1",[F:ATT]TXT)
 [F:DAS]NBRSPEBAS+=1
 NBDAS=1
When "S41.G01.03.001" :
 If [F:DAS]NBRSPECLG<>IDAS : IDAS=[F:DAS]NBRSPECLG : Endif
 [F:DAS]SPECLGCOD(IDAS)=func TRTIMPTDS.ATABDIV(10341,"A1",[F:ATT]TXT)
 [F:DAS]NBRSPECLG+=1
 NBDAS=1
When "S41.G01.04.001" ,"S44.G40.05.001"
 If [F:DAS]NBRALO<>IDAS : IDAS=[F:DAS]NBRALO : Endif
 [F:DAS]ALOAMTCOD(IDAS)=func TRTIMPTDS.ATABDIV(10343,"A1",[F:ATT]TXT)
 [F:DAS]NBRALO+=1
 NBDAS=1
When "S41.G01.06.001", "S40.G30.06.001"
 If [F:DAS]NBRSPEEXO<>IDAS : IDAS=[F:DAS]NBRSPEEXO : Endif
 [F:DAS]SPEEXOCOD(IDAS)=func TRTIMPTDS.ATABDIV(10342,"A1",[F:ATT]TXT)
 [F:DAS]NBRSPEEXO+=1
 NBDAS=1
When "S41.G30.10.001","S40.G30.10.001" #*************
 [F:DAG]CODDAG=val([F:ATT]TXT)
 NBDAG+=1
When "S40.G30.11.001"
 [F:DAH]CTXACT=val([F:ATT]TXT)
 NBDAH+=1
When "S41.G30.11.001.001"                # Ne pas mettre pour la "S40.G30.11.001"car auto
 [F:DAH]NBRACT=val([F:ATT]TXT)
 NBDAH+=1
When "S41.G30.11.001.002"
 [F:DAH]VALACT = val([F:ATT]TXT)/100
When "S40.G30.12.001"
 IDAE+=1                    :# Init à -1 dans le S40.G01.00.001
 If IDAE<dim([F:HRDAE]CTXSTK)
  [F:HRDAE]CTXSTK(IDAE)=val([F:ATT]TXT)
 Endif
When "S41.G30.12.001"
 IDAE+=1                    :# Init à -1 dans le S40.G01.00.001
 If IDAE<dim([F:HRDAE]NBRSTK)
  [F:HRDAE]NBRSTK(IDAE) = val([F:ATT]TXT)
 Endif
When "S40.G30.13.001"
 If IDAE>-1 : IDAE=-1 : Endif   :# réinit si S40.G30.12.* l'a utilisé !
 IDAE+=1                        :# Init à -1 dans le S40.G01.00.001
 If IDAE<dim([F:HRDAE]BSPCENBRTI)
  [F:HRDAE]BSPCENBRTI(IDAE)=val([F:ATT]TXT)
 Endif
When "S41.G30.15.001","S40.G30.15.001"
 [F:DAI]CODDAI=val([F:ATT]TXT)
 NBDAI+=1
When "S41.G30.20.001","S40.G30.20.001"
 [F:DAJ]CODDAJ=val([F:ATT]TXT)
 NBDAJ+=1
When "S41.G30.25.001"
 [F:DAK]CODDAK=val([F:ATT]TXT)
 NBDAK+=1
When"S41.G30.30.001.001"
 [F:DAL]AMTDAL1=val([F:ATT]TXT)
 NBDAL+=1
When "S41.G30.36.001","S40.G30.36.001"
 [F:DAM]CODBRTHRS=func TRTIMPTDS.ATABDIV(10440,"A1",[F:ATT]TXT)
 NBDAM+=1
When "S41.G30.36.003"
 [F:DAM]NBRHRSDAY = val([F:ATT]TXT)/100

When "S41.G47.10.001.001"
 [F:HRDAE]DNABRTASS = val([F:ATT]TXT)/100
When "S44.G01.00.001"
 Case [F:ATT]TXT
  When "03"    : [F:HRDAE]UOMTIMWRK=2
  When "07"    : [F:HRDAE]UOMTIMWRK=3
  When Default : [F:HRDAE]UOMTIMWRK=1
 Endcase

When "S44.G01.00.003","S44.G01.00.003.001","S44.G03.00.001"
Case val([F:ATT]TXT)
 When 1 : [F:HRDAE]AGFFLG = 3
 When 2 : [F:HRDAE]AGFFLG = 4
 When 3 : [F:HRDAE]AGFFLG = 5
 When 4 : [F:HRDAE]AGFFLG = 2
 When Default : [F:HRDAE]AGFFLG = 1
Endcase
When "S44.G01.00.003.002"                      # Ne pas mettre pour la "S44.G03.00.002" car pas /100
 [F:HRDAE]RATTOD = val([F:ATT]TXT)/100
When "S45.G01.01.009","S45.G01.00.002"
 Case [F:ATT]TXT
  When "90"    : [F:HRDAE]CODSITFAM=8
  When "91"    : [F:HRDAE]CODSITFAM=9
  When Default : [F:HRDAE]CODSITFAM=val([F:ATT]TXT)
 Endcase

When "S45.G01.05.001.001"
 [F:HRDAE]TYPANC(IDPP)=val([F:ATT]TXT)
When "S45.G01.05.001.002"
 If val([F:ATT]TXT)>1
  [F:HRDAE]UOMANC(IDPP)=val([F:ATT]TXT)+1 :# 2d position = 'semaine' dans le ML
 Else
  [F:HRDAE]UOMANC(IDPP)=val([F:ATT]TXT)
 Endif
When "S45.G01.05.002"
 [F:HRDAE]AMTANC(IDPP)=val([F:ATT]TXT)
 IDPP+=1
When "S45.G05.00.001"
 [L]REFCTR=[F:ATT]TXT
 NBDAP+=1
When "S45.G05.00.004","S45.G01.00.006"
 [F:DAP]NBRCHD=num$([F:ATT]TXT)
When "S45.G05.00.005"
 If toupper(left$([F:ATT]TXT,1))="P"
  [L]FLGPREV=1
  [F:DAP]NUMDCS=func TRTIMPTDS.ATABDIV(10340,"A1",right$([F:ATT]TXT,2))
 Else
  [L]FLGPREV=0
  [F:DAP]NUMDCS=func TRTIMPTDS.ATABDIV(10340,"A1",[F:ATT]TXT)
 Endif
When "S45.G05.05.001"
 [F:DPE]EVECTRCOD=func TRTIMPTDS.ATABDIV(10345,"A1",[F:ATT]TXT)
 NBDPE+=1
When "S45.G05.05.002"
 [F:DPE]EVECTRDAT=func TRTIMPTDS.GDAT([F:ATT]TXT)
When "S45.G05.10.001"
[L]STRDATCTR=func TRTIMPTDS.GDAT([F:ATT]TXT)
 NBDPP+=1
When "S45.G05.10.002"
[L]ENDDATCTR=func TRTIMPTDS.GDAT([F:ATT]TXT)
When "S45.G05.15.001.001"
 [F:DPP]AMTPRV1 = val([F:ATT]TXT)/100
When "S45.G05.15.002.001"
 [F:DPP]AMTPRV2 = val([F:ATT]TXT)/100
When "S45.G05.15.003.001"
 [F:DPP]AMTPRV3 = val([F:ATT]TXT)/100
When "S45.G05.15.004.001"
 [F:DPP]AMTPRV4 = val([F:ATT]TXT)/100
When "S45.G05.15.005.001"
 [F:DPP]AMTPRV5 = val([F:ATT]TXT)/100
When "S45.G05.15.006.001"
 [F:DPP]AMTPRV6 = val([F:ATT]TXT)/100
When "S45.G05.15.007.001"
 [F:DPP]AMTPRV7 = val([F:ATT]TXT)/100
When "S45.G05.15.008.001"
 [F:DPP]AMTPRV8 = val([F:ATT]TXT)/100
When "S45.G05.15.009.001"
 [F:DPP]AMTPRV9 = val([F:ATT]TXT)/100
When "S45.G05.25.001"
 [F:DPP]NBRPEO1=val([F:ATT]TXT)
When "S45.G05.25.002"
 [F:DPP]NBRPEO2=val([F:ATT]TXT)
When "S45.G05.25.003"
 [F:DPP]NBRPEO3=val([F:ATT]TXT)
When "S45.G05.25.004"
 [F:DPP]NBRPEO4=val([F:ATT]TXT)
When "S45.G05.20.001"
 IDPP=IDPP2
 Case [F:ATT]TXT
   When "59" : [F:DPP]CODTYPBAS(IDPP)=9
   When "60" : [F:DPP]CODTYPBAS(IDPP)=10
   When "70" : [F:DPP]CODTYPBAS(IDPP)=11
   When "80" : [F:DPP]CODTYPBAS(IDPP)=13
   When Default : [F:DPP]CODTYPBAS(IDPP)=val([F:ATT]TXT)-9
 Endcase
 IDPP2+=1
When "S45.G10.00.001"
 [F:DAQ]TYPBNF=val([F:ATT]TXT)
 NBDAQ+=1
When "S45.G10.00.009"
[F:DAQ]FLGBNF1=2
When "S45.G10.00.010"
[F:DAQ]FLGBNF2=2
When "S45.G10.00.011"
[F:DAQ]FLGBNF3=2
When "S45.G10.00.012"
[F:DAQ]FLGBNF4=2
When "S45.G10.05.001"
 [F:DQE]REFCTRBNF=[F:ATT]TXT
 NBDQE+=1
When "S46.G01.00.001","S60.G05.00.001"
 [F:DAC]GRDSPE=func TRTIMPTDS.ATABDIV(10344,"A1",[F:ATT]TXT)
 NBDAC+=1
When "S46.G01.00.004","S60.G05.00.004"
 [F:DAC]OLDSPE=2
When "S46.G01.02.001.001","S60.G05.15.001.001"
  Case [F:ATT]TXT
   When "01" : [F:DAC]SPETIMEVE=1
   When "03" : [F:DAC]SPETIMEVE=2
   When "07" : [F:DAC]SPETIMEVE=3
   When "09" : [F:DAC]SPETIMEVE=4
   When Default : [F:DAC]SPETIMEVE=3
  Endcase
When "S46.G01.02.001.002","S60.G05.15.001.002"
  Case [F:ATT]TXT
   When "02" : [F:DAC]DAYTYP=2
   When Default : [F:DAC]DAYTYP=1
  Endcase

#S65
When "S65.G30.40.001"
  [F:HRDAE]FILREDSMC = val([F:ATT]TXT)
When "S65.G30.40.002"
  [F:HRDAE]FILREDSAL = val([F:ATT]TXT)
When "S65.G30.40.003"
  [F:HRDAE]FILREDAMT = val([F:ATT]TXT)
When "S41.G01.00.023.001","S65.G40.10.023.001"
  [F:HRDAE]YEAWRK = val([F:ATT]TXT)
When "S41.G01.00.023.002","S65.G40.10.023.002"
  [F:HRDAE]TRMWRK = val([F:ATT]TXT)
When "S41.G01.00.023.003","S65.G40.10.023.003"
  [F:HRDAE]MTHWRK = val([F:ATT]TXT)
When "S65.G40.10.023.004"
  [F:HRDAE]TRMWRKFIR = val([F:ATT]TXT)
When "S65.G40.10.023.005"
  [F:HRDAE]MTHWRKFIR = val([F:ATT]TXT)


When "S66.G01.00.002.001","S56.G01.00.002.001"
 [L]TYP=3 :# Btp normale
 Case val([F:ATT]TXT)
  When 3     : [F:HRDAE]BUICODTIM = 2
  When 7     : [F:HRDAE]BUICODTIM = 3
  When 9     : [F:HRDAE]BUICODTIM = 4
  When Default: [F:HRDAE]BUICODTIM = 1
 Endcase
 NBBTP+=1
When "S66.G01.00.012","S56.G01.00.012"                                                    :#N4DS
 Case [F:ATT]TXT
  When "99"    : [F:HRDAE]BUISITFAM=8
  When Default : [F:HRDAE]BUISITFAM=val([F:ATT]TXT)
 Endcase
When "S66.G01.00.014"
 [F:HRDAE]BUIRATEXS = num$(val([F:ATT]TXT)/100)
When Default
Onerrgo ERREUR
 Read [FTD]FTD0=[M:ITDS]FICYEA;[F:ARM]CLEA1
 If !fstat & [F:ATT]TXT<>""
  Case [F:FTD]TYPREC
   When 1 : Assign [F:FTD]XPSRES With vireblc(evalue([F:FTD]XPSRES)-[F:ATT]TXT,2)
   When 2 : Assign [F:FTD]XPSRES With val([F:ATT]TXT)
   When 3 : Assign [F:FTD]XPSRES With func TRTIMPTDS.GDAT([F:ATT]TXT)
  Endcase
 Endif
Onerrgo
Endcase
Return

$ERREUR
Call ECR_TRACE([F:ARM]CLEA1-mess(93,100,1)-num$(errn)-errmes$(errn),0) From GESECRAN
Resume

###########################
$S30_AFFECTE
Case [F:ARM2]CLEA1
When "S30.G01.00.001"
 [F:HRDAE]NUMSSC=[F:ATT2]TXT
When "S30.G01.00.007"
 [F:HRDAE]CIV=val([F:ATT2]TXT)
When "S30.G01.00.009"
 [F:HRDAE]DATBRN=func TRTIMPTDS.GDAT([F:ATT2]TXT)
When "S30.G10.05.001"
 [V]GOK=1     : # Juste pour ne pas avoir d'erreur dans la trace car info utilisées
                # mais non importées directement
When Default
Onerrgo S30_ERREUR
 Read [FTD]FTD0=[M:ITDS]FICYEA;[F:ARM2]CLEA1
 If !fstat & [F:ATT]TXT<>""
  Case [F:FTD]TYPREC
   When 1 : Assign [F:FTD]XPSRES With vireblc([F:ATT2]TXT,2)
   When 2 : Assign [F:FTD]XPSRES With val([F:ATT2]TXT)
   When 3 : Assign [F:FTD]XPSRES With func TRTIMPTDS.GDAT([F:ATT2]TXT)
  Endcase
 Endif
Onerrgo
Endcase
Return

###########################
$S30_ERREUR
Call ECR_TRACE([F:ARM2]CLEA1-mess(93,100,1)-num$(errn)-errmes$(errn),0) From GESECRAN
Resume

###########################
$WRITE_DAE
#Init S30
Filter [LNK2] Where NUMREQ=[L]NUMREQ & SEQREQ=4
&                 & CLEA4=[F:ARM]CLEA4 & left$(CLEA1,4)="S30."
&      Order By Key CLE=CLEA1
 For [LNK2]CLE
  Gosub S30_AFFECTE
 Next
Filter [LNK2]

# Init menu locaux
If ![F:HRDAE]WRKSTG : [F:HRDAE]WRKSTG=2 : Endif : # Non
If ![F:HRDAE]STG    : [F:HRDAE]STG=1    : Endif : # Non
If ![F:HRDAE]CODCNB : [F:HRDAE]CODCNB=5 : Endif : # Aucun
If ![F:HRDAE]PRUVOT : [F:HRDAE]PRUVOT=[F:HRCTR]PRUVOT : Endif
If ![F:HRDAE]PRUCOL : [F:HRDAE]PRUCOL=[F:HRCTR]PRUCOL : Endif
If ![F:HRDAE]PRUACV : [F:HRDAE]PRUACV=[F:HRCTR]PRUACV : Endif
If ![F:HRDAE]DEGMAL : [F:HRDAE]DEGMAL=3 : Endif
If ![F:HRDAE]WRKFLGADD : [F:HRDAE]WRKFLGADD=2 : Endif

#V08R09
If ![F:HRDAE]AGFFLG : [F:HRDAE]AGFFLG=1 : Endif

If  [F:HRDAE]NAM="" : [F:HRDAE]NAM=[F:HRDAE]OLDNAM : Endif

# Init pays
If [F:HRDAE]CRYNAM<>""    : Call PAYS([F:HRDAE]CRY,[F:HRDAE]CRYNAM) From TRTIMPTDS       : Endif
If [F:HRDAE]NTTNAM<>""    : Call PAYS([F:HRDAE]NTT,[F:HRDAE]NTTNAM) From TRTIMPTDS       : Endif
If [F:HRDAE]CRYNAMBRN<>"" :
 Call PAYS([F:HRDAE]CRYBRN,[F:HRDAE]CRYNAMBRN) From TRTIMPTDS
 If [F:HRDAE]CTYBRN<>""
  Filter [POS] Where CRY=[F:HRDAE]CRYBRN & POSCTY=[F:HRDAE]CTYBRN
  Read [POS]POS1 First
  Filter [POS]
  If !fstat
   [F:HRDAE]CTYBRNSEE = [F:POS]POSCTYCOD
  Endif
 Endif
Endif

# Init code risque AT
If [F:HRDAE]CODRSK<>"" &  val([F:HRDAE]SCTFCY)>0
 Filter [WAC] Where CODRSK=[F:HRDAE]CODRSK & val(SCTFCY)=val([F:HRDAE]SCTFCY)
 Read [WAC]WAC0 First
 Filter [WAC]
 If !fstat
  [F:HRDAE]RSKWRK=[F:WAC]CODWAC
 Endif
Endif

Look [HRDAE]IDA0= [M:ITDS]FICYEA;[L]REFNUM;[L]CTR;[F:HRDAE]ETRDAT;[L]TYP;1
If fstat
 [F:HRDAE]YEAEMPDDS =[M:ITDS]FICYEA
 [F:HRDAE]EMPDDS =[L]REFNUM
 [F:HRDAE]CTRNUM =[L]CTR
 [F:HRDAE]TYPDAE =[L]TYP
 [F:HRDAE]FLGNEWSAL=[L]NEWSAL
 [F:HRDAE]FLGDNA =1
 Write [F:HRDAE]
 If fstat
  [V]GOK=0
  Call FSTA("DAE") From GLOCK
  Return
 Endif
 Call ECR_TRACE(mess(68,10711,1)-":"-mess(69,10711,1)-[L]REFNUM-[L]CTR-num$([F:HRDAE]ETRDAT),0) From GESECRAN
 #              Création d'informations : Données salariés XXXX
Else
 Call ECR_TRACE(mess(67,10711,1)-":"-mess(69,10711,1)-[L]REFNUM-[L]CTR-num$([F:HRDAE]ETRDAT),0) From GESECRAN
 #              Informations  déjà existantes : Données salariés XXXX
Endif
Return

###########################
$WRITE_DAS
Look [DAS]IDS0= [M:ITDS]FICYEA;[L]REFNUM;[L]CTR;[F:HRDAE]ETRDAT;[L]TYP;1
If fstat
 [F:DAS]=[F:HRDAE]
 [F:DAS]YEAEMPDDS =[M:ITDS]FICYEA
 [F:DAS]EMPDDS =[L]REFNUM
 [F:DAS]CTRNUM =[L]CTR
 [F:DAS]ETRDAT =[F:HRDAE]ETRDAT
 [F:DAS]TYPDAE =[L]TYP
 [F:DAS]FLGDNA =1
 Write [F:DAS]
 If fstat
  [V]GOK=0
  Call FSTA("DAS") From GLOCK
  Return
 Endif
Endif
Return

###########################
$WRITE_DAG
Look [DAG]IDG0= [M:ITDS]FICYEA;[L]REFNUM;[L]CTR;[F:HRDAE]ETRDAT;[L]TYP;NBDAG
If fstat
 [F:DAG]=[F:HRDAE]
 [F:DAG]YEAEMPDDS =[M:ITDS]FICYEA
 [F:DAG]EMPDDS =[L]REFNUM
 [F:DAG]CTRNUM =[L]CTR
 [F:DAG]ETRDAT =[F:HRDAE]ETRDAT
 [F:DAG]TYPDAE =[L]TYP
 [F:DAG]NUMLIG =NBDAG
 Write [F:DAG]
 If fstat
  [V]GOK=0
  Call FSTA("DAG") From GLOCK
  Return
 Endif
Endif
Return

###########################
$WRITE_DAH
Look [DAH]IDH0= [M:ITDS]FICYEA;[L]REFNUM;[L]CTR;[F:HRDAE]ETRDAT;[L]TYP;NBDAH
If fstat
 [F:DAH]=[F:HRDAE]
 [F:DAH]YEAEMPDDS =[M:ITDS]FICYEA
