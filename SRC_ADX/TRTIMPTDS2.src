###########################
$WRITE_DAP
If NBDPE
 If FLGPREV
  Gosub WRITE_DPE     : # Prevoyance
 Else
  Gosub WRITE_DME     : # Mutuelle
  Raz [F:DME]
 Endif
 If [V]GOK<1 : Return : Endif
 Raz [F:DPE]: Raz NBDPE
Endif
If NBDPP
 If FLGPREV
  Gosub WRITE_DPP     : # Prevoyance
 Else
  Gosub WRITE_DMP     : # Mutuelle
  Raz [F:DME]
 Endif
 If [V]GOK<1 : Return : Endif
 Raz [F:DPP]: Raz NBDPE
Endif
If FLGPREV
 # Prevoyance
 Look [DAP]IDP0= [M:ITDS]FICYEA;[L]REFNUM;[L]CTR;[F:HRDAE]ETRDAT;[L]TYP;[L]REFCTR
 If fstat
  [F:DAP]=[F:HRDAE]
  [F:DAP]YEAEMPDDS =[M:ITDS]FICYEA
  [F:DAP]EMPDDS = [L]REFNUM
  [F:DAP]CTRNUM = [L]CTR
  [F:DAP]TYPDAE = [L]TYP
  [F:DAP]REFCTR = [L]REFCTR
  Write [F:DAP]
  If fstat
   [V]GOK=0
   Call FSTA("DAP") From GLOCK
   Return
  Endif
  Call ECR_TRACE(mess(68,10711,1)-":"-mess(71,10711,1)-[L]REFNUM-[L]CTR-[L]REFCTR,0) From GESECRAN
  #              Création d'informations : Contrat de prévoyance XXXX
 Else
  Call ECR_TRACE(mess(67,10711,1)-":"-mess(71,10711,1)-[L]REFNUM-[L]CTR-[L]REFCTR,0) From GESECRAN
  #              Informations  déjà existantes : Contrat de prévoyance XXXX
 Endif
Else
 Gosub WRITE_DMU     : # Mutuelle
 Raz [F:DMU]
Endif
Return

