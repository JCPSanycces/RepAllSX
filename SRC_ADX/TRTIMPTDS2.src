###########################
$WRITE_DNA
Look [DNA]IDN0= [M:ITDS]FICYEA;[L]REFNUM;[L]CTR;[F:HRDAE]ETRDAT;[L]TYP;1
If fstat
 [F:DNA]=[F:HRDAE]
 [F:DNA]YEAEMPDDS =[M:ITDS]FICYEA
 [F:DNA]EMPDDS =[L]REFNUM
 [F:DNA]CTRNUM =[L]CTR
 [F:DNA]ETRDAT =[F:HRDAE]ETRDAT
 [F:DNA]TYPDAE =[L]TYP
 [F:DNA]FLGDNA =1
 If ![F:DNA]DNASITADM : [F:DNA]DNASITADM=1         : Endif              :# droit privé
 If ![F:DNA]DNACPYSTG : [F:DNA]DNACPYSTG=len(mess(0,10963,1)) : Endif    :# non étrangère
 If ![F:DNA]DNAACTASS : [F:DNA]DNAACTASS=1         : Endif              :# Assujetti chomage
 If ![F:DNA]DNAEXOASS : [F:DNA]DNAEXOASS=len(mess(0,10973,1)) : Endif    :# non concerné
 If [F:DNA]DNACCP=0 & [F:DNA]DNACCPNUM="" : [F:DNA]DNACCP=4 : Endif
 If [F:DNA]TYPLNK>0 : [F:DNA]LNK=2 : Else [F:DNA]LNK=1 : Endif
 If ![F:DNA]DNAAGS    : [F:DNA]DNAAGS=1                      : Endif    :# Assujetti AGS
 Write [F:DNA]
 If fstat
  [V]GOK=0
  Call FSTA("DNA") From GLOCK
  Return
 Endif
Endif
Return

