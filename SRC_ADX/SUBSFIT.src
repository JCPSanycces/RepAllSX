#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
# SUBSFIT : Transfert des éléments de facturation vente                              #
#           Chargement des libellés d'un tableau                                     #
#           ACA                                                                      #
######################################################################################
# Issue 118718 - 20161010 by LD : Message Format missing or wrong : "4"
# Issue 119267 - 20161019 by LD : V11 RC1 [F:SID1] : Class Non-existent

######################################################################################
# Init. [M:SFIT] tableau des elements facture du document pour la societe GSOCIETE   #
# - Dans $OUVRE                                                                      #
# - Dans AM_ si changement de société                                                #
######################################################################################
#-------------------------------------------------------------------------------------
$INIT_SFIT
Local Integer IJ0, IJ1
Local Char SFI_CRITERE (30)
Local Char SFI_TST     (15)

If GREP<>"C" & GREP<>"" : Return: Endif
# Bug 54087
SAV_DEF_MSK=dbgstr(1) : SAV_DEF_TAB=dbgstr(2)

Gosub OPEN_SFI From TRTX3CPY
If clalev([F:AXX])=0  : Local File ATEXTRA  [AXX]  : Endif
If clalev([M:SFIT])=0 : Local Mask SFITRF   [SFIT] : Endif
Raz [M:SFIT]

# 91606 :(04/08/14) Transportation notes (Sales part dev)
#If find(SFIT_OBJ,"SQH","SOH","SDH","SRH", "SRL", "SIH","SOR")
If find(SFIT_OBJ,"SQH","SOH","SDH","TNH","SRH", "SRL", "SIH","SOR")
# 91606 :(04/08/14) Transportation notes (Sales part dev)
   [M:SFIT]S_OBJ=SFIT_OBJ
  Else
   If find(GFONCTION,"GESSQH") :    [M:SFIT]S_OBJ="SQH" : Endif
   If find(GFONCTION,"GESSOH") :    [M:SFIT]S_OBJ="SOH" : Endif
   If find(GFONCTION,"GESSDH") or find(GFONCTION,"GESSDHF") :    [M:SFIT]S_OBJ="SDH" : Endif
   # 91606 :(04/08/14) Transportation notes (Sales part dev)
   If find(GFONCTION,"GESTNH") :    [M:SFIT]S_OBJ="TNH" : Endif
   # 91606 :(04/08/14) Transportation notes (Sales part dev)
   If find(GFONCTION,"GESSRH") :    [M:SFIT]S_OBJ="SRH" : Endif
   If find(GFONCTION,"GESSRL") :    [M:SFIT]S_OBJ="SRL" : Endif
   If find(GFONCTION,"GESSIH") :    [M:SFIT]S_OBJ="SIH" : Endif
Endif

# --- constitution du critere de lecture de SFI : suivant les elements saisis dans le document
Case [M:SFIT]S_OBJ
     When "SQH","SOH","SOR"  : SFI_CRITERE="DACORD<>0" : # dans les devis et commandes
     When "SDH","SRH","SRL"  : SFI_CRITERE="DACDLV<>0" : # dans les livraisons retours
     # 91606 :(04/08/14) Transportation notes (Sales part dev)
     When "TNH"              : SFI_CRITERE="DACDLV<>0" : # in transportation notes
     # 91606 :(04/08/14) Transportation notes (Sales part dev)
     When "SIH"              : SFI_CRITERE="DACINV<>0" : # dans les factures
Endcase
# --- Si Paramètre société Remise sur taxe à non, exclure les élts Remise sur taxe
If GDEPMGTMOD>1 : SFI_CRITERE-="& MISRULSTD<>2" : Endif

Local Integer EXNOLIGN: EXNOLIGN=nolign
Raz nolign

# --- chargement dans tableau NBSFI des elements saisis dans le document
# For [SFI] Where WCPY=GSOCIETE & evalue(SFI_CRITERE)
For [SFI] Where evalue(SFI_CRITERE)
    nolign +=1 : [M:SFIT]NBSFI=nolign

    [M:SFIT]=[F:SFI]
    Case [M:SFIT]S_OBJ
         When "SQH","SOH","SOR"  : [M:SFIT]SFIORD(nolign-1)=[F:SFI]DACORD
         When "SDH","SRH","SRL"  : [M:SFIT]SFIORD(nolign-1)=[F:SFI]DACDLV
         # 91606 :(04/08/14) Transportation notes (Sales part dev)
         When "TNH"              : [M:SFIT]SFIORD(nolign-1)=[F:SFI]DACDLV
         # 91606 :(04/08/14) Transportation notes (Sales part dev)
         When "SIH"              : [M:SFIT]SFIORD(nolign-1)=[F:SFI]DACINV
    Endcase
    # 107888 : Scheduled invoices - X3-26242 (LD:27/02/17) : Performance improvement on automatic process
    # SFITRF is a work screen, long title and short description are not useful ...
#    If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
#        Call GET_ATEXTRA("SFOOTINV","DESAXX",GLANGUE,[M:SFIT]SFIDES(nolign-1)) From TRTX3TEX
#        Call GET_ATEXTRA("SFOOTINV","SHOAXX",GLANGUE,[M:SFIT]SFISHO(nolign-1)) From TRTX3TEX
#    Endif                        : # Dde 81811 : Optimisation
    # 107888 : Scheduled invoices - X3-26242 (LD:27/02/17) : Performance improvement on automatic process
    [M:SFIT]SFICUR(nolign-1)=[F:SFI]CUR
    # 85879 : Valeur par défaut non convertie car devise non alimentée dans SFOOTINV
    If [M:SFIT]SFICUR(nolign-1)="" [M:SFIT]SFICUR(nolign-1)=GSYSCUR Endif

#   --- chargement dans tableau NBSFIT de particularites de transfert (ex : commande --> livraison)
#       nota : pas de selection suivant document recepteur (faire eventuellement)
    For IJ0=0 To dim([F:SFI]ORIVCR)-1
        If [F:SFI]ORIVCR(IJ0)=0 : Break : Endif
        SFI_TST    = num$([F:SFI]SFINUM)+"~"
        SFI_TST   += num$([F:SFI]ORIVCR(IJ0))+"~"
        SFI_TST   += num$([F:SFI]DESVCR(IJ0))
        [M:SFIT]T_TST_RUL(IJ1)=SFI_TST
        [M:SFIT]T_ORIVCR(IJ1)=[F:SFI]ORIVCR(IJ0)
        [M:SFIT]T_DESVCR(IJ1)=[F:SFI]DESVCR(IJ0)
        [M:SFIT]T_BRDRUL(IJ1)=[F:SFI]BRDRUL(IJ0)
        [M:SFIT]T_GRUFLG(IJ1)=[F:SFI]GRUFLG(IJ0)
        [M:SFIT]T_GRURUL(IJ1)=[F:SFI]GRURUL(IJ0)
        IJ1 += 1
    Next
Next
[M:SFIT]NBSFIT = IJ1         # FGR 17/04/2015 : X3SUIVI107637

Local Integer SAVIND : SAVIND=indice

Sorta [M:SFIT]NBSFI [M:SFIT]NBSFI Order By [M:SFIT]SFIORD(indice)

indice=SAVIND

[M:SFIT]S_SOC=GSOCIETE
[M:SFIT]S_CUR=GLOCALDEV    : # devise de la societe

nolign=EXNOLIGN

Default Mask SAV_DEF_MSK : Default File SAV_DEF_TAB

Return


######################################################################################
# Chargement des données affichées et invisibles du tableau des elements facture     #
# CUR Devise du document                                                             #
######################################################################################
Subprog NEW_SFIT (CLASSE,ABREV,CUR,BPCINV,BPCORD,RATDAT)
Value Char    CLASSE
Value Char    ABREV
Value Char    CUR             : # Devise du document
Value Char    BPCINV          : # Client facture
Value Char    BPCORD          : # Client commande
Value Date    RATDAT          : # Date pour le cours (date du doc)

If GREP<>"C" & GREP<>"" : End : Endif

Local Integer IJ0, IJ1, IJ2

SAV_DEF_MSK=dbgstr(1) : SAV_DEF_TAB=dbgstr(2)
If !find (CLASSE,"F","M") : CLASSE="" : Endif
If CLASSE<>""
   If evalue("clalev(["+CLASSE+":"+ABREV+"])")=0 : End : Endif
   If    CLASSE="F"
      Local Char DEF_TAB : DEF_TAB="["+ABREV+"]" : Default File DEF_TAB
   Elsif CLASSE="M"
      Local Char DEF_MSK : DEF_MSK="["+ABREV+"]" : Default Mask DEF_MSK
   Endif
Endif

# --- Init des codes clients
[M:SFIT]S_BPCINV=BPCINV
[M:SFIT]S_BPCORD=BPCORD

# --- Init dans bloc NBSFI
Raz [M:SFIT]DTAAMT

# --- Raz du bloc NBTRF
# 107888 : Scheduled invoices - X3-26242 (LD:27/02/17) : Performance improvement on automatic process
# add a max nb of elts to be deleted
#Dela 0, dim([M:SFIT]VCRENT) [M:SFIT]NBTRF
Dela 0, dim([M:SFIT]VCRENT),[M:SFIT]NBTRF [M:SFIT]NBTRF
# 107888 : Scheduled invoices - X3-26242 (LD:27/02/17) : Performance improvement on automatic process

Raz [M:SFIT]NBTRF

# --- Maj de valeurs par défaut
Gosub FROM_DEFAULT

# --- Maj des éléments issus du client ( facture ou commande )
If [M:SFIT]S_BPCORD<>"" or [M:SFIT]S_BPCINV<>""
    Gosub FROM_BPC
Endif

If CLASSE<>"" & ABREV<>""
   Call UPD_NBFAC(CLASSE,ABREV)
Endif

Default Mask SAV_DEF_MSK : Default File SAV_DEF_TAB

End

######################################################################################
# Chargement des lignes dans tableau des transferts
######################################################################################
#-------------------------------------------------------------------------------------
# Lignes issues des valeurs par défaut
#-------------------------------------------------------------------------------------
$FROM_DEFAULT

Local Integer PORI, PDTA
Local Decimal PDTAAMT

# FGR 17/01/2014 : X3SUIVI95927 : appeler sur la variable de bas de tableau ça en fera moins
#For IJ0=0 To dim([M:SFIT]SFIORD)-1
For IJ0=0 To [M:SFIT]NBSFI-1
   If [M:SFIT]SFIORD(IJ0)=0 : Break : Endif
   If [M:SFIT]DEFVAL(IJ0)<>0                      : # Présence d'une valeur par défaut
      PDTA=[M:SFIT]SFINUM(IJ0)                    : # No. element (critère de tri du tableau NBTRF)
      If [M:SFIT]AMTCOD(IJ0)=2                    : # C'est un montant
         If [M:SFIT]SFICUR(IJ0)<>CUR              : # Convertir dans la devise du document
            Local Integer STAT
            Local Integer CHGTYP
            If (evalue("dim([M:"+left$(ABREV,3)+"0]CHGTYP)")>0)
                [L]CHGTYP=evalue("[M:"+left$(ABREV,3)+"0]CHGTYP")
            Else
                [L]CHGTYP=1
            Endif
            Call CONVERT([M:SFIT]SFICUR(IJ0),CUR,GLOCALDEV,[L]CHGTYP,RATDAT,[M:SFIT]DEFVAL(IJ0),PDTAAMT,STAT) From TRTDEV
            If STAT<>0
                PDTAAMT=[M:SFIT]DEFVAL(IJ0)
            Endif
         Else
            PDTAAMT = [M:SFIT]DEFVAL(IJ0)
         Endif
      Else
         PDTAAMT = [M:SFIT]DEFVAL(IJ0)
      Endif
      PORI = 9
      Call ADD_NBTRF(PORI, PDTA, PDTAAMT)
   Endif
Next IJ0
Return

#-------------------------------------------------------------------------------------
# Lignes issues des clients ( facture ou commande )
#-------------------------------------------------------------------------------------
$FROM_BPC

Local Integer PORI, PDTA
Local Decimal PDTAAMT

# FGR 17/01/2014 : X3SUIVI95927 : appeler sur la variable de bas de tableau ça en fera moins
#For IJ0=0 To dim([M:SFIT]SFIORD)-1
For IJ0=0 To [M:SFIT]NBSFI-1
   If [M:SFIT]SFIORD(IJ0)=0 : Break : Endif

   If [M:SFIT]BPCORI(IJ0)=1                       : # Origine client facture
      If [F:BPC]BPCNUM<>[M:SFIT]S_BPCINV
         Read [BPC]BPC0=[M:SFIT]S_BPCINV
         If fstat : Raz [F:BPC] : Endif
      Endif
   Endif

   If [M:SFIT]BPCORI(IJ0)=2                       : # Origine client commande
      If [F:BPC]BPCNUM<>[M:SFIT]S_BPCORD
         Read [BPC]BPC0=[M:SFIT]S_BPCORD
         If fstat : Raz [F:BPC] : Endif
      Endif
   Endif

   IJ2=find ([M:SFIT]SFINUM(IJ0),[F:BPC]INVDTA)
   If IJ2
      PDTA=[M:SFIT]SFINUM(IJ0)                      : # No. element (critère de tri du tableau NBTRF)
      If [M:SFIT]AMTCOD(IJ0)=2                      : # C'est un montant
         If [F:BPC]CUR<>CUR       : # Convertir dans la devise du document
            Local Integer STAT
            Local Integer CHGTYP
            If (evalue("dim([M:"+left$(ABREV,3)+"0]CHGTYP)")>0)
                [L]CHGTYP=evalue("[M:"+left$(ABREV,3)+"0]CHGTYP")
            Else
                [L]CHGTYP=1
            Endif
            Call CONVERT([F:BPC]CUR,CUR,GLOCALDEV,[L]CHGTYP,RATDAT,[F:BPC]INVDTAAMT(IJ2-1),PDTAAMT,STAT) From TRTDEV
            If STAT<>0
                PDTAAMT=[M:SFIT]DEFVAL(IJ0)
            Endif
         Else
            PDTAAMT=[F:BPC]INVDTAAMT(IJ2-1)
         Endif
      Else
         PDTAAMT=[F:BPC]INVDTAAMT(IJ2-1)
      Endif
      PORI=5
      Call ADD_NBTRF(PORI, PDTA, PDTAAMT)
   Endif
Next IJ0

Return
#-------------------------------------------------------------------------------------
# En saisie Commande : Picking Devis ( ultérieur )
#-------------------------------------------------------------------------------------
# --- Dans PICKE : on y passe pour chaque ligne de devis ( plus des valeurs de la ligne )
$SQH_SOH_PLUS
Local Char TST_RUL (15)


# FGR 17/01/2014 : X3SUIVI95927 : appeler sur la variable de bas de tableau ça en fera moins
#For IJ0=0 To dim([M:SFIT]SFINUM)-1
For IJ0=0 To [M:SFIT]NBSFI-1
    If [M:SFIT]SFINUM(IJ0)=0 : Break : Endif

    If [M:SFIT]S_OBJ="SOH" : TST_RUL=num$( [M:SFIT]SFINUM(IJ0) ) + "~1~10" : Endif   : # devis --> commande
    Gosub REGLES
    Call MAJ_SFIT(1, 4, [M:SFIT]SFINUM(IJ0), [F:SQH]SQHNUM, GERR, GMESSAGE)    # FGR 19/08/2014 : X3SUIVI100811 Call MAJ_SFIT (1,4,[M:SFIT]SFINUM(IJ0),[F:SQH]SQHNUM)
    #If GERR <> 0 Then        # FGR 19/08/2014 : X3SUIVI100811
    If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
      Break
    Endif
  Next IJ0
  #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
  If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
    Return
  Endif
  # Dde 81811 : Optimisation : Contexte migration : Le sorta se fait à la main
  If dim(GMIGRATION)>0 & [M:SFIT]NBTRF>0            : # Dde 81811 : Optimisation
    Local Integer SAVIND : SAVIND=indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND                                 : # Dde 81811 : Optimisation
  Else                                              : # Dde 81811 : Optimisation
    #Issue 116728 - 2016-05-24 by CPO : Delivery performance up-porting 95927
    # FGR 17/01/2014 : X3SUIVI95927 (début)
    Local Integer SAVIND : SAVIND=indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND                                 : # Dde 81811 : Optimisation
    # FGR 17/01/2014 : X3SUIVI95927 (fin)
    #Affzo [M:SFIT] # Issue 117933 - 2016-08-04 by CPO : SUBSFIT-NEW_SFIT performance-Implus (no need for affzo on stored mask)1811 : Optimisation
  Endif
Return

Subprog SQH_SOH_CALCUL()
Local Char TST_RUL (15)
TST_RUL="~1~10"
Call UPD_NBFAC("M","SOH3")
End


# --- Dans DEPICK : on y passe pour chaque ligne de devis ( moins des valeurs de la ligne )
$SQH_MOINS
Local Char TST_RUL (15)

# FGR 17/01/2014 : X3SUIVI95927 : appeler sur la variable de bas de tableau ça en fera moins
#For IJ0=0 To dim([M:SFIT]SFINUM)-1
For IJ0=0 To [M:SFIT]NBSFI-1
    If [M:SFIT]SFINUM(IJ0)=0 : Break : Endif

    If [M:SFIT]S_OBJ="SOH" : TST_RUL=num$( [M:SFIT]SFINUM(IJ0) ) + "~1~10" : Endif   : # devis --> commande

    Gosub REGLES
    Call MAJ_SFIT(2, 4, [M:SFIT]SFINUM(IJ0), [F:SQH]SQHNUM, GERR, GMESSAGE)    # FGR 19/08/2014 : X3SUIVI100811 : Call MAJ_SFIT (2,4,[M:SFIT]SFINUM(IJ0),[F:SQH]SQHNUM)
    #If GERR <> 0 Then        # FGR 19/08/2014 : X3SUIVI100811
    If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
      Break
    Endif
  Next IJ0
  #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
  If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
    Return
  Endif
  # Dde 81811 : Optimisation  : Contexte migration : Le sorta se fait à la main
  If dim(GMIGRATION)>0 & [M:SFIT]NBTRF>0            : # Dde 81811 : Optimisation
    Local Integer SAVIND : SAVIND=indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND                                 : # Dde 81811 : Optimisation
  Else                                              : # Dde 81811 : Optimisation
    #Issue 116728 - 2016-05-24 by CPO : Delivery performance up-porting 95927
    # FGR 17/01/2014 : X3SUIVI95927 (début)
    Local Integer SAVIND : SAVIND=indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND                                 : # Dde 81811 : Optimisation
    # FGR 17/01/2014 : X3SUIVI95927 (fin)
    #Affzo [M:SFIT] # Issue 117933 - 2016-08-04 by CPO : SUBSFIT-NEW_SFIT performance-Implus (no need for affzo on stored mask)
  Endif                                             : # Dde 81811 : Optimisation
Return

#-------------------------------------------------------------------------------------
# En saisie Livraison : Picking Commande
#-------------------------------------------------------------------------------------

# --- Dans PICKE : on y passe pour chaque ligne de commande ( plus des valeurs de la ligne )
#     de commande normale --> livraison
$SOH_SDH_PLUS
Local Char TST_RUL (15)

# FGR 17/01/2014 : X3SUIVI95927 : appeler sur la variable de bas de tableau ça en fera moins
#For IJ0=0 To dim([M:SFIT]SFINUM)-1
For IJ0=0 To [M:SFIT]NBSFI-1
    If [M:SFIT]SFINUM(IJ0)=0 : Break : Endif

    If [M:SFIT]S_OBJ="SDH" : TST_RUL=num$( [M:SFIT]SFINUM(IJ0) ) + "~10~2" : Endif : # Commande->Livraison
    Gosub REGLES
    Call MAJ_SFIT(1, 3, [M:SFIT]SFINUM(IJ0), [F:SOH]SOHNUM, GERR, GMESSAGE)    # FGR 19/08/2014 : X3SUIVI100811 : Call MAJ_SFIT (1,3,[M:SFIT]SFINUM(IJ0),[F:SOH]SOHNUM)
    #If GERR <> 0 Then        # FGR 19/08/2014 : X3SUIVI100811
    If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
      Break
    Endif
  Next IJ0
  #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
  If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
    Return
  Endif
  # Dde 81811 : Optimisation : Contexte migration : Le sorta se fait à la main
  If dim(GMIGRATION)>0 & [M:SFIT]NBTRF>0            : # Dde 81811 : Optimisation
    Local Integer SAVIND : SAVIND=indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND                                 : # Dde 81811 : Optimisation
  Else                                              : # Dde 81811 : Optimisation
    #Issue 116728 - 2016-05-24 by CPO : Delivery performance up-porting 95927
    # FGR 17/01/2014 : X3SUIVI95927 (début)
    Local Integer SAVIND : SAVIND=indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND                                 : # Dde 81811 : Optimisation
    # FGR 17/01/2014 : X3SUIVI95927 (fin)
    #Affzo [M:SFIT] # Issue 117933 - 2016-08-04 by CPO : SUBSFIT-NEW_SFIT performance-Implus (no need for affzo on stored mask)
  Endif                                             : # Dde 81811 : Optimisation
Return

# --- Dans DEPICK : on y passe pour chaque ligne de commande ( moins des valeurs de la ligne )
$SOH_MOINS
Local Char TST_RUL (15)

# FGR 17/01/2014 : X3SUIVI95927 : appeler sur la variable de bas de tableau ça en fera moins
#For IJ0=0 To dim([M:SFIT]SFINUM)-1
For IJ0=0 To [M:SFIT]NBSFI-1
    If [M:SFIT]SFINUM(IJ0)=0 : Break : Endif

    If [M:SFIT]S_OBJ="SDH" : TST_RUL=num$( [M:SFIT]SFINUM(IJ0) ) + "~10~2" : Endif   : # commande -> liv
    If [M:SFIT]S_OBJ="SIH" : TST_RUL=num$( [M:SFIT]SFINUM(IJ0) ) + "~12~18" : Endif   : # commande -> fac cmd
    Gosub REGLES
    Call MAJ_SFIT(2, 3, [M:SFIT]SFINUM(IJ0), [F:SOH]SOHNUM, GERR, GMESSAGE)    # FGR 19/08/2014 : X3SUIVI100811 : Call MAJ_SFIT (2,3,[M:SFIT]SFINUM(IJ0),[F:SOH]SOHNUM)
    #If GERR <> 0 Then        # FGR 19/08/2014 : X3SUIVI100811
    If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
      Break
    Endif
  Next IJ0
  #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
  If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
    Return
  Endif
  # Dde 81811 : Optimisation  : Contexte migration : Le sorta se fait à la main
  If dim(GMIGRATION)>0 & [M:SFIT]NBTRF>0            : # Dde 81811 : Optimisation
    Local Integer SAVIND : SAVIND=indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND                                 : # Dde 81811 : Optimisation
  Else                                              : # Dde 81811 : Optimisation
    #Issue 116728 - 2016-05-24 by CPO : Delivery performance up-porting 95927
    # FGR 17/01/2014 : X3SUIVI95927 (début)
    Local Integer SAVIND : SAVIND=indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND                                 : # Dde 81811 : Optimisation
    # FGR 17/01/2014 : X3SUIVI95927 (fin)
