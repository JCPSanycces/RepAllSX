    Endif
    If [M:SFIT]S_OBJ="SIH"
      TST_RUL=num$( [M:SFIT]SFINUM(IJ0) ) + "~23~4"
    Endif
    Gosub REGLES
    #--ORI = 3 comme pour les commandes
    Call MAJ_SFIT(1, 3, [M:SFIT]SFINUM(IJ0), [F:CON]CONNUM, GERR, GMESSAGE)    # FGR 19/08/2014 : X3SUIVI100811 : Call MAJ_SFIT (1,2,[M:SFIT]SFINUM(IJ0),[F:SDH]SDHNUM)
    #If GERR <> 0 Then        # FGR 19/08/2014 : X3SUIVI100811
    If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
      Break
    Endif
  Next IJ0
  #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
  If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
    Return
  Endif
  # Dde 81811 : Optimisation : Contexte migration : Le sorta se fait à la main
  If dim(GMIGRATION)>0 & [M:SFIT]NBTRF>0            : # Dde 81811 : Optimisation
    SAVIND = indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice = SAVIND                                 : # Dde 81811 : Optimisation
  Else                                              : # Dde 81811 : Optimisation
    #Issue 116728 - 2016-05-24 by CPO : Delivery performance up-porting 95927
    # FGR 17/01/2014 : X3SUIVI95927 (début)
    Local Integer SAVIND : SAVIND=indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND                                 : # Dde 81811 : Optimisation
    # FGR 17/01/2014 : X3SUIVI95927 (fin)
    #Affzo [M:SFIT] # Issue 117933 - 2016-08-04 by CPO : SUBSFIT-NEW_SFIT performance-Implus (no need for affzo on stored mask)
  Endif                                             : # Dde 81811 : Optimisation
Return
######################################################################################
# --- Dans DEPICK : on y passe pour chaque contrat de service ( moins des valeurs de la ligne )
$CON_MOINS
Local Char TST_RUL(15)
Local Integer SAVIND

  For IJ0 = 0 To dim([M:SFIT]SFINUM)-1
    If [M:SFIT]SFINUM(IJ0) = 0
      Break
    Endif
    If [M:SFIT]S_OBJ = "SIH"
      # retour -> avoir
      TST_RUL = num$( [M:SFIT]SFINUM(IJ0) ) + "~23~4"
    Endif
    Gosub REGLES
    Call MAJ_SFIT(2, 3, [M:SFIT]SFINUM(IJ0), [F:CON]CONNUM, GERR, GMESSAGE)    # FGR 19/08/2014 : X3SUIVI100811 : Call MAJ_SFIT (2,2,[M:SFIT]SFINUM(IJ0),[F:SDH]SDHNUM)
    #If GERR <> 0 Then        # FGR 19/08/2014 : X3SUIVI100811
    If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
      Break
    Endif
  Next IJ0
  #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
  If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
    Return
  Endif
  # Dde 81811 : Optimisation : Contexte migration : Le sorta se fait à la main
  If dim(GMIGRATION)>0 & [M:SFIT]NBTRF>0          : # Dde 81811 : Optimisation
    SAVIND = indice                               : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice = SAVIND                               : # Dde 81811 : Optimisation
  Else                                            : # Dde 81811 : Optimisation
    #Issue 116728 - 2016-05-24 by CPO : Delivery performance up-porting 95927
    # FGR 17/01/2014 : X3SUIVI95927 (début)
    Local Integer SAVIND : SAVIND=indice          : # Dde 81811 : Optimisation
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND                                 : # Dde 81811 : Optimisation
    # FGR 17/01/2014 : X3SUIVI95927 (fin)
    #Affzo [M:SFIT] # Issue 117933 - 2016-08-04 by CPO : SUBSFIT-NEW_SFIT performance-Implus (no need for affzo on stored mask)
  Endif                                           : # Dde 81811 : Optimisation
Return
######################################################################################
Subprog CON_SIH_CALCUL()

Local Char TST_RUL(15)
  TST_RUL="~23~4"
  Call UPD_NBFAC("M", "SIH2")
End
#--/79550
######################################################################################
# Issue 107888 - 2016-06-20 by CPO : Scheduled invoices object management
#-- Normal order -> Invoices (by using a scheduling invoice)
$SVIC_ORISOH_SIH_PLUS
Local Char TST_RUL(15)
Local Integer SAVIND

  For IJ0=0 To dim([M:SFIT]SFINUM)-1
    If [M:SFIT]SFINUM(IJ0)=0
      Break
    Endif
    If [M:SFIT]S_OBJ="SIH"
      TST_RUL=num$( [M:SFIT]SFINUM(IJ0) ) + "~10~4"
    Endif

    Gosub REGLES

    #--ORI = 3 #--ORI=3 Normal orders
    Call MAJ_SFIT(1, 3, [M:SFIT]SFINUM(IJ0), [F:SOH]SOHNUM, GERR, GMESSAGE)
    If GERR = 1 Then
      Break
    Endif
  Next IJ0

  If GERR = 1 Then
    Return
  Endif

  # Dde 81811 : Optimisation : Contexte migration : Le sorta se fait à la main
  If dim(GMIGRATION)>0 & [M:SFIT]NBTRF>0
    SAVIND = indice
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice = SAVIND
  Else
    Local Integer SAVIND : SAVIND=indice
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND

    Affzo [M:SFIT]
  Endif

Return
#-------------------------------------------------------------------------------------
$SVIC_ORISOH_SIH_MOINS
Local Char TST_RUL(15)
Local Integer SAVIND

  For IJ0 = 0 To dim([M:SFIT]SFINUM)-1
    If [M:SFIT]SFINUM(IJ0) = 0
      Break
    Endif
    If [M:SFIT]S_OBJ = "SIH"
      # Cde normale -> Facture
      TST_RUL = num$( [M:SFIT]SFINUM(IJ0) ) + "~10~4"
    Endif

    Gosub REGLES

    #--ORI=3 Normal orders
    Call MAJ_SFIT(2, 3, [M:SFIT]SFINUM(IJ0), [F:SOH]SOHNUM, GERR, GMESSAGE)
    If GERR = 1 Then
      Break
    Endif
  Next IJ0

  If GERR = 1 Then
    Return
  Endif
  # Dde 81811 : Optimisation : Contexte migration : Le sorta se fait à la main
  If dim(GMIGRATION)>0 & [M:SFIT]NBTRF>0
    SAVIND = indice
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice = SAVIND
  Else
    Local Integer SAVIND : SAVIND=indice
    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1    : # Dde 81811 : Optimisation
    indice=SAVIND
    Affzo [M:SFIT]
  Endif

Return
#-------------------------------------------------------------------------------------
Subprog SVIC_ORISOH_SIH_CALCUL()

Local Char TST_RUL(15)

  TST_RUL="~10~4"
  Call UPD_NBFAC("M", "SIH2")

End
# End issue 107888
#-------------------------------------------------------------------------------------
# Recherche des règles de transfert a appliquer pour un element
#-------------------------------------------------------------------------------------
$REGLES

Raz [M:SFIT]C_ORIVCR, [M:SFIT]C_DESVCR, [M:SFIT]C_BRDRUL, [M:SFIT]C_GRUFLG, [M:SFIT]C_GRURUL
#Issue 116728 - 2016-05-24 by CPO : Delivery performance
#IJ2=find(TST_RUL,[M:SFIT]T_TST_RUL)
IJ2=find(TST_RUL,[M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))
#End issue 116728
If IJ2
   [M:SFIT]C_ORIVCR=[M:SFIT]T_ORIVCR(IJ2-1)
   [M:SFIT]C_DESVCR=[M:SFIT]T_DESVCR(IJ2-1)
   [M:SFIT]C_BRDRUL=[M:SFIT]T_BRDRUL(IJ2-1)
   [M:SFIT]C_GRUFLG=[M:SFIT]T_GRUFLG(IJ2-1)
   [M:SFIT]C_GRURUL=[M:SFIT]T_GRURUL(IJ2-1)
Elsif pat(TST_RUL, "*~1~12") # Devis -> Proforma : 1-1, pas de paramétrage fait
   [M:SFIT]C_ORIVCR=1
   [M:SFIT]C_DESVCR=12
   [M:SFIT]C_BRDRUL=5
   [M:SFIT]C_GRUFLG=2
   [M:SFIT]C_GRURUL=1
Endif
Return


# En cas de modification de la quantité sur une ligne pickée
# Appelé par ADD ou SUB_TOT de SUBSxHB (Après et Avant_Ligne)
#
Subprog MAJ_SFIT_QTY (CLASSE, ABMSK, VCRENT, DELTAQTY, DELTAAMT, DELTAWEI, DELTAVOL)
Value Char CLASSE
Value Char ABMSK
Value Char VCRENT
Value Decimal DELTAQTY : # Augmentation ou diminution de la qty
Value Decimal DELTAAMT : # Augmentation ou diminution du montant
Value Decimal DELTAWEI : # Augmentation ou diminution du poids
Value Decimal DELTAVOL : # Augmentation ou diminution du volume

Local Integer IJ

If GREP<>"C" : End : Endif

If CLASSE=""
&  | ABMSK=""
&  | VCRENT=""
    End
Endif

# Trouver la ligne dans [M:SFIT]NBTRF
#For IJ=0 To dim([M:SFIT]DTA)-1                  # FGR 22/04/2015 : X3SUIVI107637 : pas la peine de parcourir tout le tableau
For IJ=0 To [M:SFIT]NBTRF-1                      # FGR 22/04/2015 : X3SUIVI107637 : pas la peine de parcourir tout le tableau
    If [M:SFIT]VCRENT(IJ) = [L]VCRENT
        [M:SFIT]LIGQTYPRO(IJ)+=[L]DELTAQTY
        [M:SFIT]LIGAMTPRO(IJ)+=[L]DELTAAMT
        [M:SFIT]LIGWEIPRO(IJ)+=[L]DELTAWEI
        [M:SFIT]LIGVOLPRO(IJ)+=[L]DELTAVOL
    Endif
Next IJ

# FGR 22/04/2015 : X3SUIVI107637 (début)
# ------------------------------------
# Si la ligne est supprimée (qté=0) on la supprime de SFITRF
#---CPO 62810 - En création, après picking, si on click sur la ligne pickée, les elts de facturation sont remis à 0
#For IJ=dim([M:SFIT]DTA)-1 To 0 Step -1
#    If [M:SFIT]VCRENT(IJ) = [L]VCRENT
#        If [M:SFIT]LIGQTYPRO(IJ)=0 and [M:SFIT]LIGAMTPRO(IJ)=0
#            #---CPO 62810 : on ne vire pas systématiquement les lignes à 0 car le sous-pro est appellé aussi en AVANT_LIGNE
#            #--ce qui provoque une décrémentation totale des qtés, poids etc. pour le calcul des elts de fact.
#            #--du coup si on vire la ligne, en APRES_LIGNE on ne trouve plus de ligne liée à VCRENT (n°pièce pickée)
#            If find(GFONCTION,"GESSOH","GESSDH","GESSIH","GESSRH","GESSRL","GESSRS")>0
#&                & (dim(GMODIF)>0 & find(GMODIF,1,3,4)>0) :# CPO : GMODIF=1ou3ou4 en cas de suppréssion de ligne
#              Dela IJ,1 [M:SFIT]NBTRF
#            Endif
#        Endif
#    Endif
#Next IJ
If find(GFONCTION,"GESSOH","GESSDH","GESSIH","GESSRH","GESSRL","GESSRS")>0 & (dim(GMODIF)>0 & find(GMODIF,1,3,4)>0) :# CPO : GMODIF=1ou3ou4 en cas de suppréssion de ligne
  For IJ=[M:SFIT]NBTRF-1 To 0 Step -1
    If [M:SFIT]VCRENT(IJ) = [L]VCRENT
      If [M:SFIT]LIGQTYPRO(IJ)=0 and [M:SFIT]LIGAMTPRO(IJ)=0
        Dela IJ,1 [M:SFIT]NBTRF
      Endif
    Endif
  Next IJ
Endif
# FGR 22/04/2015 : X3SUIVI107637 (fin)
# ------------------------------------
Call UPD_NBFAC(CLASSE, ABMSK)
End

######################################################################################
# MAJ du tableau des transferts en fonction des actions effectuées sur le document   #
# ( Changement de devise / changement de client / PICKE / DEPICKE )                  #
# - TRAIT   : 1=Ajout / 2=Suppression / 3=Update                                     #
# - ORI     : Valeur logique en fonction de l'origine de la ligne                    #
#             9 = Lignes des valeurs par défaut                                      #
#             5 = Lignes des éléments saisis dans le client ( facture ou commande )  #
#             4 = Lignes des éléments issus du devis                                 #
#             3 = Lignes des éléments issus de la commande                           #
#             2 = Lignes des elements issus de la livraison                          #
#             1 = Lignes des eléments issus de la facture                            #
#             0 = Lignes des éléments modifiés manuellement                          #
# - DTA     : No. de l'élément                                                       #
#             ( ne concerne que la saisie manuelle de l'élément ( dans AM_INVDTAAMT  #
# - VCRENT  : Clé recherche des lignes document origine pour le PICKE ou DEPICKE     #
# Appelé à partir des xxx_MOINS                                                      #
######################################################################################
Subprog MAJ_SFIT (TRAIT, ORI, DTA, VCRENT, IERR, SMESSAGE)
Value Integer TRAIT
Value Integer ORI
Value Integer DTA
Value Char VCRENT
Variable Integer IERR     # FGR 19/08/2014 : X3SUIVI100811
Variable Char SMESSAGE    # FGR 19/08/2014 : X3SUIVI100811

    # FLORENT ICI : déplacer le test GREP ici, ça gagnera tj le temps de déclaration des variables
    If GREP<>"C" : End : Endif  # FGR 17/01/2013 : X3SUIVI95927

    Local Integer IJ1, IJ2

    Local Decimal TOTAMTPRO, TOTQTYPRO, TOTWEIPRO, TOTVOLPRO
    Local Decimal NETPRINOT, QTY, LINWEI, LINVOL
    Local Decimal INVDTAAMT
    Local Integer TROUVE : [L]TROUVE=0

    Local Integer WERR #--CPO 79550 Transferts : Retours -> Avoirs sur retours

    #If GREP<>"C" : End : Endif  # FGR 17/01/2013 : X3SUIVI95927

    If [M:SFIT]C_ORIVCR=1
        # Devis ->
        [L]TOTAMTPRO = [F:SQH]QUONOT
        [L]TOTQTYPRO = [F:SQH]DSPTOTQTY
        [L]TOTWEIPRO = [F:SQH]DSPTOTWEI
        [L]TOTVOLPRO = [F:SQH]DSPTOTVOL

        [L]NETPRINOT = [F:SQD]NETPRINOT
        [L]QTY       = [F:SQD]QTY
        [L]LINWEI    = [F:SQD]DSPLINWEI
        [L]LINVOL    = [F:SQD]DSPLINVOL

        IJ1=find (DTA,[F:SQH]INVDTA)
        If IJ1>0
            [L]INVDTAAMT = [F:SQH]INVDTAAMT(IJ1-1)
            [L]TROUVE=1
        Endif

    Elsif [M:SFIT]C_ORIVCR=10 or [M:SFIT]C_ORIVCR=12
        # Commande ->
        [L]TOTAMTPRO = [F:SOH]ORDNOT
        [L]TOTQTYPRO = [F:SOH]DSPTOTQTY
        [L]TOTWEIPRO = [F:SOH]DSPTOTWEI
        [L]TOTVOLPRO = [F:SOH]DSPTOTVOL

        [L]NETPRINOT = [F:SOP]NETPRINOT
        [L]QTY       = [F:SOQ]QTY
        If [F:SOQ]DLVFLG=2 # Issue 107888 - 2016-06-20 by CPO : US120 Normal order -> Invoices (by using a scheduling invoice)
          [L]LINWEI    = [F:SOQ]DSPLINWEI
          [L]LINVOL    = [F:SOQ]DSPLINVOL
        Endif

        IJ1=find (DTA,[F:SOH]INVDTA)
        If IJ1>0
            [L]INVDTAAMT = [F:SOH]INVDTAAMT(IJ1-1)
            [L]TROUVE=1
        Endif

    Elsif [M:SFIT]C_ORIVCR=2
        # Livraison ->
        [L]TOTAMTPRO = [F:SDH]DLVNOT
        [L]TOTQTYPRO = [F:SDH]DSPTOTQTY
        [L]TOTWEIPRO = [F:SDH]DSPTOTWEI
        [L]TOTVOLPRO = [F:SDH]DSPTOTVOL

        [L]NETPRINOT = [F:SDD]NETPRINOT
        [L]QTY       = [F:SDD]QTY
        [L]LINWEI    = [F:SDD]DSPLINWEI
        [L]LINVOL    = [F:SDD]DSPLINVOL

        IJ1=find (DTA,[F:SDH]INVDTA)
        If IJ1<>0
            [L]INVDTAAMT = [F:SDH]INVDTAAMT(IJ1-1)
            [L]TROUVE=1
        Else
            # Les elts de facturation peuvent venir de la livraison elle-meme, ou de la commande
            IJ1=find (DTA,[F:SOH]INVDTA)
            If IJ1<>0
                [L]INVDTAAMT = [F:SOH]INVDTAAMT(IJ1-1)
                [L]TROUVE=1
            Endif
        Endif

    Elsif [M:SFIT]C_ORIVCR=4
        # Facture -> Avoir
        [L]TOTAMTPRO = 0
        # --------------------------------------
        # FGR 22/04/2015 : X3SUIVI107637 (début)
        #For [F:SID]SID0 Where NUM=[F:SIH]NUM
        #    [L]TOTAMTPRO+=[F:SID]AMTNOTLIN
        #Next
        Local Char WREQ(250)

        WREQ = "SELECT SUM(AMTNOTLIN_0) FROM SINVOICED WHERE NUM_0='" + [F:SIH]NUM + "'"  # Requête SQL standard
        Onerrgo ERROR_SQL_MAJ_SFIT
        For (Decimal SUMAMTNOTLIN) From num$((GTYPDBA*2)+1) Sql WREQ As [XSID]
          [L]TOTAMTPRO = [F:XSID]SUMAMTNOTLIN
        Next
        Onerrgo
        If dim(ISQLERROR) >= 0 Then
          Kill ISQLERROR
          For [F:SID]SID0 Where NUM=[F:SIH]NUM
            [L]TOTAMTPRO += [F:SID]AMTNOTLIN
          Next
        Endif
        # FGR 22/04/2015 : X3SUIVI107637 (fin)
        # --------------------------------------
        [L]TOTQTYPRO = [F:SIV]DSPTOTQTY
        [L]TOTWEIPRO = [F:SIV]DSPTOTWEI
        [L]TOTVOLPRO = [F:SIV]DSPTOTVOL

        [L]NETPRINOT = [F:SID]NETPRINOT
        [L]QTY       = [F:SID]QTY
        [L]LINWEI    = [F:SID]DSPLINWEI
        [L]LINVOL    = [F:SID]DSPLINVOL

        IJ1=find (DTA,[F:SIV]INVDTA)
        If IJ1>0
            [L]INVDTAAMT = [F:SIV]INVDTAAMT(IJ1-1)
            [L]TROUVE=1
        Endif
  #--CPO 79550 Transferts : Retours -> Avoirs sur retours
  Elsif [M:SFIT]C_ORIVCR = 3
    If [F:SRD]SDHNUM<>""
      # Retour livraison -> Avoir
      #If !clalev([F:SDH]) : Local File SDELIVERY  [SDH] : Endif
      #If !clalev([F:SDD]) : Local File SDELIVERYD [SDD] : Endif
      WERR=0
      If [F:SDH]SDHNUM<>[F:SRD]SDHNUM
        Read [F:SDH]SDH0=[F:SRD]SDHNUM
        If fstat : Raz [F:SDH] : WERR = 1 : Endif
      Endif
      If WERR=0 and ([F:SDD]SDHNUM<>[F:SRD]SDHNUM or [F:SDD]SDDLIN<>[F:SRD]SDDLIN)
        Read [F:SDD]SDD0=[F:SRD]SDHNUM;[F:SRD]SDDLIN
        If fstat : Raz [F:SDD] : WERR = 1 : Endif
      Endif
      If WERR=0
        #--On prends les infos à partir de la livraison
        # Livraison ->
        [L]TOTAMTPRO = [F:SDH]DLVNOT
        [L]TOTQTYPRO = [F:SDH]DSPTOTQTY
        [L]TOTWEIPRO = [F:SDH]DSPTOTWEI
        [L]TOTVOLPRO = [F:SDH]DSPTOTVOL
        #
        #--Les infos lignes ne sont pas utilisées ici, à garder ???
#        [L]NETPRINOT = [F:SDD]NETPRINOT
#        [L]QTY       = [F:SDD]QTY
#        [L]LINWEI    = [F:SDD]DSPLINWEI
#        [L]LINVOL    = [F:SDD]DSPLINVOL
        #
        IJ1 = find(DTA,[F:SDH]INVDTA)
        If IJ1 <> 0
          [L]INVDTAAMT = [F:SDH]INVDTAAMT(IJ1-1)
          [L]TROUVE = 1
        Else
          If [F:SDD]SOHNUM<>""
            # Les elts de facturation peuvent venir de la livraison elle-meme, ou de la commande
            #If clalev([F:SOH])=0 : Local File SORDER [SOH] : Endif
            WERR=0
            If [F:SOH]SOHNUM<>[F:SDD]SOHNUM
              Read [F:SOH]SOH0=[F:SDD]SOHNUM
              If fstat : Raz [F:SOH] : WERR = 1 : Endif
            Endif
            If WERR = 0
              IJ1 = find(DTA,[F:SOH]INVDTA)
              If IJ1 <> 0
                [L]INVDTAAMT = [F:SOH]INVDTAAMT(IJ1-1)
                [L]TROUVE = 1
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  #--CPO 79550 Transferts : Contrats de service -> Factures
  Elsif [M:SFIT]C_ORIVCR = 23
    # Contrats de service -> Factures
    [L]TOTAMTPRO = [F:CON]CONAMT   #-----A CONFIRMER !
    [L]TOTQTYPRO = 0 :#--N/A
    [L]TOTWEIPRO = 0 :#--N/A
    [L]TOTVOLPRO = 0 :#--N/A
    #
    IJ1 = find(DTA,[F:CON]INVDTA)
    If IJ1 > 0
      [L]INVDTAAMT = [F:CON]INVDTAAMT(IJ1-1)
      [L]TROUVE = 1
    Endif
    Endif

    If [L]TROUVE=1
        # find manuel, car sur plusieurs critères : VCRENT et DTA et ORI
        IJ1=-1
        # FLORENT ICI : tester la valeur de la variable bas de tableau plutôt que le dimensionnement d'un champ
        #               ca évitera de boucler 300 fois s'il n'y a pas de réponse
        # FGR 17/01/2013 : X3SUIVI95927
        #For IJ2 = 0 To dim([M:SFIT]VCRENT)-1
        For IJ2 = 0 To [M:SFIT]NBTRF-1
            If [M:SFIT]VCRENT(IJ2) = VCRENT and [M:SFIT]DTA(IJ2) = DTA and [M:SFIT]ORI(IJ2) = ORI
                IJ1=IJ2
                Break
            Endif
        Next

        Local Integer CURDAC

        If IJ1=-1 : # Si nouveau
            IJ1=[M:SFIT]NBTRF
        Endif
        #Issue 116728 - 2016-05-24 by CPO : Delivery performance
        #IJ2 = find(VCRENT, [M:SFIT]VCRENT)
        IJ2 = find(VCRENT, [M:SFIT]VCRENT(0..[M:SFIT]NBTRF-1))
        #End issue 116728
        If IJ2=0
            [L]CURDAC = max ([M:SFIT]DAC)+1
        Else
            [L]CURDAC = [M:SFIT]DAC(IJ2-1)
        Endif
        # # FGR 19/08/2014 : X3SUIVI100811 (début)
        If IJ1 >= dim([M:SFIT]VCRENT) Then
          IERR = 1  # FGR 22/06/2015 : X3SUIVI109023 : pas IERR=2
          SMESSAGE = mess(1153,196,1) - "(" + num$(IJ1+1) + ">" + num$(dim([M:SFIT]VCRENT)) + ")"
          End
        Endif
        # # FGR 19/08/2014 : X3SUIVI100811 (fin)

        [M:SFIT]VCRENT(IJ1)    = VCRENT
        [M:SFIT]DAC(IJ1)       = [L]CURDAC
        [M:SFIT]ORI(IJ1)       = ORI
        [M:SFIT]DTA(IJ1)       = DTA

        [M:SFIT]TOTAMTPRO(IJ1) = [L]TOTAMTPRO
        [M:SFIT]TOTQTYPRO(IJ1) = [L]TOTQTYPRO
        [M:SFIT]TOTWEIPRO(IJ1) = [L]TOTWEIPRO
        [M:SFIT]TOTVOLPRO(IJ1) = [L]TOTVOLPRO

        [M:SFIT]DTAAMTORI(IJ1) = [L]INVDTAAMT

        If TRAIT=1 : # Ajout
            If IJ1=[M:SFIT]NBTRF
                [M:SFIT]NBTRF+=1
                #Issue 116728 - 2016-05-24 by CPO : Delivery performance up-porting 95927
                # ------------------------------------------------------------------
                # FGR 17/01/2014 : X3SUIVI95927 (début) : pas de raison de trier ici
                # Dde 81811 : Optimisation : Contexte migration : On fera le sorta à la fin
                #If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
                #    Local Integer SAVIND : SAVIND=indice
                #    #Issue 116728 - 2016-05-24 by CPO : Delivery performance
                #    #Sorta [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1
                #    Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1
                #    #End issue 116728
                #    indice=SAVIND
                #Endif                        : # Dde 81811 : Optimisation
                # FGR 17/01/2014 : X3SUIVI95927 (fin)
                # ------------------------------------------------------------------
            Endif
        Elsif TRAIT=2 : # Suppression
            If [M:SFIT]LIGQTYPRO(IJ1)=0 and [M:SFIT]LIGAMTPRO(IJ1)=0
                Dela IJ1 [M:SFIT]NBTRF
            Endif
        Endif
    Endif : # Non trouve
End

$ERROR_SQL_MAJ_SFIT
Local Integer ISQLERROR

  # FGR 22/04/2015 : X3SUIVI107637
  ISQLERROR = 1
Resume

Subprog ADD_NBTRF(PORI, PDTA, PDTAAMT)
Value Integer PORI
Value Integer PDTA
Value Decimal PDTAAMT

    Local Integer IJ0, IJ1

    # find manuel, car sur plusieurs critères : DTA et ORI
    IJ1=-1
    #Issue 116728 - 2016-05-24 by CPO : Delivery performance
    #For IJ0 = 0 To dim([M:SFIT]DTA)-1
    For IJ0 = 0 To [M:SFIT]NBTRF-1
    #End issue 116728
        If  [M:SFIT]DTA(IJ0) = PDTA and [M:SFIT]ORI(IJ0) = PORI
            IJ1=IJ0
            Break
        Endif
    Next

    If IJ1=-1 : # Si nouveau
        IJ1=[M:SFIT]NBTRF
        [M:SFIT]NBTRF  +=1
    Endif

    [M:SFIT]ORI(IJ1)      =PORI
    [M:SFIT]DTA(IJ1)      =PDTA
    [M:SFIT]DTAAMTORI(IJ1)=PDTAAMT
    [M:SFIT]DTAAMTCLC(IJ1)=PDTAAMT

End

######################################################################################
# Chargement des données affichées et invisibles du tableau des elements facture     #
# CLASSE  F ou M                                                                     #
# ABMSK   Abréviation du masque                                                      #
# CUR     Devise (?)
######################################################################################
Subprog INI_NBFAC (CLASSE,ABMSK,CUR)
Value Char    CLASSE
Value Char    ABMSK
Value Char    CUR

# Not used -> SAISFOOT From SUBSFIT

SAV_DEF_MSK=dbgstr(1) : SAV_DEF_TAB=dbgstr(2)

If evalue("clalev([M:"+ABMSK+"])")=0 : End : Endif
Local Char DEF_MSK : DEF_MSK="["+ABMSK+"]" : Default Mask DEF_MSK

Local Integer IJ0
For IJ0=0 To dim([M]NBFAC)-1
    If IJ0>dim([M:SFIT]SFIORD)-1 : Break : Endif
    If [M:SFIT]SFINUM(IJ0)=0     : Break : Endif
    If dim([M]INVDTA)>0    : [M]INVDTA(IJ0)=[M:SFIT]SFINUM(IJ0) : Endif
    If dim([M]INVDTA)>0    : [M]INVDTA(IJ0)=[M:SFIT]SFINUM(IJ0) : Endif
Next IJ0

Default Mask SAV_DEF_MSK : Default File SAV_DEF_TAB
End


Subprog SOH_SDH_CALCUL()
Local Char TST_RUL (15)
TST_RUL="~10~2"
Call UPD_NBFAC("M","SDH2")
End


#####################################################################################
# Sauvegarde et restore les masques et fichiers par défaut                          #
#####################################################################################
$SAVE_DEFS
    SAV_DEF_MSK=dbgstr(1) : SAV_DEF_TAB=dbgstr(2)
    If !find (CLASSE,"F","M") : CLASSE="" : Endif
    If CLASSE<>""
       If evalue("clalev(["+CLASSE+":"+ABMSK+"])")=0 : End : Endif

       If    CLASSE="F"
          Local Char DEF_TAB : DEF_TAB="["+ABMSK+"]" : Default File DEF_TAB
       Elsif CLASSE="M"
          Local Char DEF_MSK : DEF_MSK="["+ABMSK+"]" : Default Mask DEF_MSK
       Endif
    Endif
Return
$REST_DEFS
    Default Mask SAV_DEF_MSK : Default File SAV_DEF_TAB
Return

######################################################################################
# FGR 17/04/2015 : X3SUIVI107637 (début)
Funprog GET_NOM_SCRPIT_OPT(CLASSE, ABMSK)
Value Char CLASSE
Value Char ABMSK

Local Char SZPROGNAME(GLONADC)

  SZPROGNAME = "WSFIT1" + CLASSE + ABMSK
End SZPROGNAME

######################################################################################
Subprog OPTIMISATION_UPD_NBFAC(CLASSE, ABMSK, IERROR)
Value Char CLASSE
Value Char ABMSK
Variable Integer IERROR

Local Integer PSUBB
Local Integer IVALIDOK
Local Integer IOK
Local Integer INB
Local Char SZADXIFS(type(adxifs)-10)
Local Char SZADXIRS(type(adxirs)-10)
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Char SVERSIONSRC(10)

  SZPROGNAME = func GET_NOM_SCRPIT_OPT(CLASSE, ABMSK)
  SVERSIONSRC = "V1.2"                                  # Vesion du script généré pour permettre des évolutions
  #---------------------------------------------------
  IERROR = 0
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", nomap)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", nomap)
  #---------------------------------------------------
  #Call EFFACE_ADX("", nomap, SZPROGNAME, IVALIDOK) From ORDSYS
  #Call EFFACE(SZFULLSRC, IVALIDOK) From ORDSYS
  #Call EFFACE(SZFULLADX, IVALIDOK) From ORDSYS
  #---------------------------------------------------
  #Call EXISTE_ADX("", "", SZPROGNAME, PSUBB) From ORDSYS
  #If PSUBB Then
  PSUBB = 1
  If filinfo(filpath("TRT", SZPROGNAME, "src", 0), 0) >= 0 and filinfo(filpath("TRT", SZPROGNAME, "adx", 0), 0) >= 0 Then
    # On regarde si le traitement est toujours valable
    Call CONTROLE(SVERSIONSRC, IOK) From =SZPROGNAME
    If IOK = 0 Then
      Call EFFACE_ADX("", nomap, SZPROGNAME, IVALIDOK) From ORDSYS
      Call EFFACE(SZFULLSRC, IVALIDOK) From ORDSYS
      Call EFFACE(SZFULLADX, IVALIDOK) From ORDSYS
      PSUBB = 0
    Endif
  Else
    PSUBB = 0
  Endif
  #---------------------------------------------------
  If !PSUBB Then
    SZADXIFS = adxifs
    SZADXIRS = adxirs
    adxifs = ""
    adxirs = chr$(10)
    # --------------------------------------------------
    Openo SZFULLSRC, 0 Using [FSFI]
    # --------------------------------------------------
    Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [FSFI]
    Wrseq "#Traitement généré pour SUBSFIT" Using [FSFI]
    Wrseq "#" + string$(80, "=") Using [FSFI]
    Wrseq "End" Using [FSFI]
    Wrseq "" Using [FSFI]
    Wrseq "$DYNRIEN" Using [FSFI]
    Wrseq "Local Integer IERRSFIT" Using [FSFI]
    Wrseq "  IERRSFIT = 1" Using [FSFI]
    Wrseq "Resume" Using [FSFI]
    Wrseq "" Using [FSFI]
    # --------------------------------------------------
    Wrseq "Subprog CONTROLE(SVERSION, IOK)" Using [FSFI]
    Wrseq "Value Char SVERSION" Using [FSFI]
    Wrseq "Variable Integer IOK" Using [FSFI]
    Wrseq "" Using [FSFI]
    Wrseq "  IOK = 1" Using [FSFI]
    Wrseq "  If SVERSION <> '" + SVERSIONSRC + "' Then" Using [FSFI]                                 # Pour gérer d'ÉVENTUELLES ÉVOLUTIONS
    Wrseq "    IOK = 0" Using [FSFI]
    Wrseq "    End" Using [FSFI]
    Wrseq "  Endif " Using [FSFI]
    INB = evalue("dim(["+CLASSE+":"+ABMSK+"]INVDTAAMT)-1")
    Wrseq "  If " + num$(INB) - "<> dim(["+CLASSE+":"+ABMSK+"]INVDTAAMT)-1 Then" Using [FSFI]
    Wrseq "    IOK = 0" Using [FSFI]
    Wrseq "    End" Using [FSFI]
    Wrseq "  Endif " Using [FSFI]
    Wrseq "End" Using [FSFI]
    Wrseq "" Using [FSFI]
    # --------------------------------------------------
    Wrseq "$DYNAMIQUE_RAZ" Using [FSFI]
    Wrseq "  Onerrgo DYNRIEN" Using [FSFI]
    Wrseq "  Raz [" + CLASSE + ":" + ABMSK + "]INVDTAAMT" Using [FSFI]
    Wrseq "  Onerrgo" Using [FSFI]
    Wrseq "Return" Using [FSFI]
    Wrseq "" Using [FSFI]
    # --------------------------------------------------
    Wrseq "$DYNAMIQUE_DESTINATION" Using [FSFI]
    Wrseq "  Onerrgo DYNRIEN" Using [FSFI]
  If CLASSE = "M" Then
    Wrseq "  If [" + CLASSE + ":" + ABMSK + "]AMTCOD(IELT-1)=1 Then # Taux" Using [FSFI]
    Wrseq "    [" + CLASSE + ":" + ABMSK + "]INVDTAAMT(IELT-1) = arr([L]NEWDTAAMT,[F:TCU]CURRND/100)   # nb de decimale = nb de decimale +2 (pour arrondis) - CH" Using [FSFI]
    Wrseq "    If arr([L]NEWDTAAMT,[F:TCU]CURRND/100) <> arr([L]NEWDTAAMT,[F:TCU]CURRND) Then # Si plus de X décimales, on augmente le format"                    Using [FSFI]
    Wrseq "      [" + CLASSE + ":" + ABMSK + "]FORMAT(IELT-1) = num$(len(num$([F:TCU]CURRND)) - instr(0,num$([F:TCU]CURRND),'.')+2)"                              Using [FSFI]
    Wrseq "    Endif" Using [FSFI]
    Wrseq "  Else" Using [FSFI]
    Wrseq '    [' +CLASSE+':'+ABMSK+']INVDTAAMT(IELT-1) = val(ctrans(format$((['+CLASSE+':'+ABMSK+']FORMAT(IELT-1)), [L]NEWDTAAMT),",","."))'       Using [FSFI]
    Wrseq "  Endif" Using [FSFI]
  Else
    Wrseq "  [" + CLASSE + ":" + ABMSK + "]INVDTAAMT(IELT-1) = [L]NEWDTAAMT" Using [FSFI]
  Endif
    Wrseq "  Onerrgo" Using [FSFI]
    Wrseq "Return" Using [FSFI]
    Wrseq "" Using [FSFI]
    # --------------------------------------------------
    Wrseq "$DYNAMIQUE_OLDDTAAMT" Using [FSFI]
    Wrseq "  Onerrgo DYNRIEN" Using [FSFI]
    Wrseq "  [L]OLDDTAAMT = [" + CLASSE + ":" + ABMSK + "]INVDTAAMT(IELT-1)" Using [FSFI]
    Wrseq "  Onerrgo" Using [FSFI]
    Wrseq "Return" Using [FSFI]
    # --------------------------------------------------
    Openo Using [FSFI]
    # --------------------------------------------------
    # On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    # --------------------------------------------------
    # Compilation du traitement généré
    Call VALID("TRT", SZPROGNAME, nomap, IVALIDOK) From VALMSKSUB
    If !IVALIDOK Then
      IERROR = 1
    Endif
    # --------------------------------------------------
  Endif
End
# FGR 17/04/2015 : X3SUIVI107637 (fin)

######################################################################################
# Calcul des éléments :                                                              #
#  - Eclatement dans SFITRF                                                          #
#  - Regroupement de SFITRF -> SFI                                                   #
# Appelé par $FIN_PICK, par l'intermédiaire d'un Subprog XXX_YYY_CALCUL()            #
#  ou par $INIT_SFIT                                                                 #
######################################################################################
# FGR 17/04/2015 : X3SUIVI107637 (début)
Subprog UPD_NBFAC(CLASSE, ABMSK)
Value Char CLASSE
Value Char ABMSK

Local Char TST_RUL

If GREP<>"C" : End : Endif

# --------------------------------------------------
# FGR 17/04/2015 : X3SUIVI107637 (début)
Local Integer IERROROPT
Local Char SZPROGNAME(GLONADC)

  Call OPTIMISATION_UPD_NBFAC(CLASSE, ABMSK, IERROROPT)
  If IERROROPT = 0 Then
    SZPROGNAME = func GET_NOM_SCRPIT_OPT(CLASSE, ABMSK)
  Endif
# FGR 17/04/2015 : X3SUIVI107637 (fin)
# --------------------------------------------------

Gosub SAVE_DEFS

Local Integer SAVIND : SAVIND=indice
Local Char    WNUMCURRVCR(GLONVCR) :#--CPO 106895
Local Char    WSAVEVCRENT(GLONVCR) :#--CPO 106895
Local Integer WSAVETOATTRIB        :#--CPO 106895
WNUMCURRVCR="" : WSAVEVCRENT=""    :#--CPO 106895

# Regen du TST_RUL
If [M:SFIT]C_ORIVCR<>[M:SFIT]C_DESVCR
    TST_RUL="~" + num$([M:SFIT]C_ORIVCR) + "~" + num$([M:SFIT]C_DESVCR)
Else
    TST_RUL=""
Endif
Local Integer IJ0, IJ1, IJSFI
Local Integer TOATTRIB : # Pour Eclatement de type "1ere"
Local Decimal TMTGOAL  : # Prorata % : Mt à obtenir

# Eclatement
Local Integer BRDRUL
#Issue 116728 - 2016-05-24 by CPO : Delivery performance
#For IJ0=0 To dim([M:SFIT]DTA)-1
For IJ0=0 To [M:SFIT]NBTRF-1
#End issue 116728
    If [M:SFIT]DTA(IJ0)=0     : Break : Endif

    #IJ1=find(num$([M:SFIT]DTA(IJ0)) + TST_RUL, [M:SFIT]T_TST_RUL)                       # FGR 17/04/2015 : X3SUIVI107637
    #IJSFI=find([M:SFIT]DTA(IJ0) , [M:SFIT]SFINUM)                                       # FGR 17/04/2015 : X3SUIVI107637
    IJ1=find(num$([M:SFIT]DTA(IJ0)) + TST_RUL, [M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))   # FGR 17/04/2015 : X3SUIVI107637
    IJSFI=find([M:SFIT]DTA(IJ0), [M:SFIT]SFINUM(0..[M:SFIT]NBSFI-1))                     # FGR 17/04/2015 : X3SUIVI107637
    #
    If IJ1<>0 and [M:SFIT]ORI(IJ0)<5 and [M:SFIT]ORI(IJ0)<>0 : # Lié au document
        #Recup règle d'éclatement
        [L]BRDRUL = [M:SFIT]T_BRDRUL(IJ1-1)
        If    [L]BRDRUL =  9 : # Prorata Montants
            If [M:SFIT]TOTAMTPRO(IJ0)<>0
                If [M:SFIT]AMTCOD(IJSFI-1)=1 # If TAUX
                    # Pas utilisé, laissé au cas où ("ceinture et bretelles")
                    [M:SFIT]DTAAMTCLC(IJ0)=[M:SFIT]DTAAMTORI(IJ0)
                Else # Montant
                    [M:SFIT]DTAAMTCLC(IJ0)=[M:SFIT]DTAAMTORI(IJ0) * [M:SFIT]LIGAMTPRO(IJ0) / [M:SFIT]TOTAMTPRO(IJ0)
                Endif
            Else
                [M:SFIT]DTAAMTCLC(IJ0)=[M:SFIT]DTAAMTORI(IJ0)
            Endif
        Elsif [L]BRDRUL = 10 : # Prorata Quantités
            If [M:SFIT]TOTQTYPRO(IJ0)<>0 and [M:SFIT]LIGAMTPRO(IJ0)<>0
                If [M:SFIT]AMTCOD(IJSFI-1)=1 : # If TAUX
                    [L]TMTGOAL=[M:SFIT]TOTAMTPRO(IJ0) * [M:SFIT]DTAAMTORI(IJ0) * [M:SFIT]LIGQTYPRO(IJ0) / [M:SFIT]TOTQTYPRO(IJ0)
                    [M:SFIT]DTAAMTCLC(IJ0) = [L]TMTGOAL / [M:SFIT]LIGAMTPRO(IJ0)
                Else  : # Montant
                    [M:SFIT]DTAAMTCLC(IJ0) = [M:SFIT]DTAAMTORI(IJ0) * [M:SFIT]LIGQTYPRO(IJ0) / [M:SFIT]TOTQTYPRO(IJ0)
                Endif
            Elsif [M:SFIT]LIGAMTPRO(IJ0)=0
                [M:SFIT]DTAAMTCLC(IJ0)=0
            Else [M:SFIT]DTAAMTCLC(IJ0)=[M:SFIT]DTAAMTORI(IJ0)
            Endif
        Elsif [L]BRDRUL = 11 : # Prorata Poids
            If [M:SFIT]TOTWEIPRO(IJ0)<>0 and [M:SFIT]LIGAMTPRO(IJ0)<>0
                If [M:SFIT]AMTCOD(IJSFI-1)=1 : # If TAUX
                    [L]TMTGOAL=[M:SFIT]TOTAMTPRO(IJ0) * [M:SFIT]DTAAMTORI(IJ0) * [M:SFIT]LIGWEIPRO(IJ0) / [M:SFIT]TOTWEIPRO(IJ0)
                    [M:SFIT]DTAAMTCLC(IJ0) = [L]TMTGOAL / [M:SFIT]LIGAMTPRO(IJ0)
                Else  : # Montant
                    [M:SFIT]DTAAMTCLC(IJ0)=[M:SFIT]DTAAMTORI(IJ0) * [M:SFIT]LIGWEIPRO(IJ0) / [M:SFIT]TOTWEIPRO(IJ0)
                Endif
            Elsif [M:SFIT]LIGAMTPRO(IJ0)=0
                [M:SFIT]DTAAMTCLC(IJ0)=0
            # 107888 : Scheduled invoices : Backporting - X3-16063 (LD:25/01/17)
            # In case of Normal order -> Invoice we should set to 0 (there is a single type of original doc at a time)
            Elsif [M:SFIT]C_ORIVCR=10 and [M:SFIT]C_DESVCR=4
                 [M:SFIT]DTAAMTCLC(IJ0)=0
            # 107888 : Scheduled invoices : Backporting - X3-16063 (LD:25/01/17)
            Else [M:SFIT]DTAAMTCLC(IJ0)=[M:SFIT]DTAAMTORI(IJ0)
            Endif
        Elsif [L]BRDRUL = 12 : # Prorata Volumes
            If [M:SFIT]TOTVOLPRO(IJ0)<>0 and [M:SFIT]LIGAMTPRO(IJ0)<>0
                If [M:SFIT]AMTCOD(IJSFI-1)=1 : # If TAUX
                    [L]TMTGOAL=[M:SFIT]TOTAMTPRO(IJ0) * [M:SFIT]DTAAMTORI(IJ0) * [M:SFIT]LIGVOLPRO(IJ0) / [M:SFIT]TOTVOLPRO(IJ0)
                    [M:SFIT]DTAAMTCLC(IJ0) = [L]TMTGOAL / [M:SFIT]LIGAMTPRO(IJ0)
                Else  : # Montant
                    [M:SFIT]DTAAMTCLC(IJ0)=[M:SFIT]DTAAMTORI(IJ0) * [M:SFIT]LIGVOLPRO(IJ0) / [M:SFIT]TOTVOLPRO(IJ0)
                Endif
            Elsif [M:SFIT]LIGAMTPRO(IJ0)=0
                [M:SFIT]DTAAMTCLC(IJ0)=0
            # 107888 : Scheduled invoices : Backporting - X3-16063 (LD:25/01/17)
            # In case of Normal order -> Invoice we should set to 0 (there is a single type of original doc at a time)
            Elsif [M:SFIT]C_ORIVCR=10 and [M:SFIT]C_DESVCR=4
                 [M:SFIT]DTAAMTCLC(IJ0)=0
            # 107888 : Scheduled invoices : Backporting - X3-16063 (LD:25/01/17)
            Else [M:SFIT]DTAAMTCLC(IJ0)=[M:SFIT]DTAAMTORI(IJ0)
            Endif
        Elsif find([L]BRDRUL,1,2,3,4)<>0 : # 1ere
            TOATTRIB=0
            Case [M:SFIT]C_ORIVCR
                When 10, 12 : # SOH
                    #--CPO 106895
                    #--Dans le cas d'un ttt auto, l'en-tête [SOH] est mis à jours
                    #--une fois qu'on a fini de l'intégrer à une livraison en cours de création
                    #--Si, on est toujours sur la même livraison, lorsqu'on ajoute d'autres cdes
                    #--le test [SOH]DLVSTA ramène la valeur déjà mise à jours dans [SOH] alors que la livr
                    #--n'a pas été encore créée !!!
                    #--Il vaut mieux passer par rech sur SDD => par contre il faut trouver un moyen d'optimiser...
#                    If clalev([F:SOH1])=0
#                        Local File SORDER [SOH1]
#                        If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
#                    Endif
#                    If [F:SOH1]SOHNUM<>[M:SFIT]VCRENT(IJ0)
#                        Read [F:SOH1]SOH0=[M:SFIT]VCRENT(IJ0)
#                    Endif
#                    If  ([M:SFIT]C_DESVCR=2  and [F:SOH1]DLVSTA=1)
#&                    or ([M:SFIT]C_DESVCR=18 and [F:SOH1]INVSTA=1)
#&                    or [F:SOH1]SOHCAT=4 # Commande ouverte
#                        TOATTRIB=1
#                    Endif
                    If CLASSE="M"
                      If clalev([F:SOH1])=0
                          Local File SORDER [SOH1]
                          If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                      Endif
                      If [F:SOH1]SOHNUM<>[M:SFIT]VCRENT(IJ0)
                          Read [F:SOH1]SOH0=[M:SFIT]VCRENT(IJ0)
                      Endif
                      If  ([M:SFIT]C_DESVCR=2  and [F:SOH1]DLVSTA=1)
&                      or ([M:SFIT]C_DESVCR=18 and [F:SOH1]INVSTA=1)
&                      or  [F:SOH1]SOHCAT=4
&                      or ([M:SFIT]C_DESVCR=4  and [F:SOH1]INVSTA=1) # Issue 107888 - 2016-06-20 by CPO : Normal order -> Invoices (by using a scheduling invoice)
                          TOATTRIB=1
                          # Issue 107888 - 2016-06-20 by CPO : US 135 Normal order -> Invoices (by using a scheduling invoice)
                          #--In case of a delivery as destination document, we'll also have to check if not invoice schedules are invoiced on the original order
                          If [F:SOH1]SOHCAT=1 and (([M:SFIT]C_DESVCR=2 and [F:SOH1]INVSTA>1) or
&                                                   ([M:SFIT]C_DESVCR=4 and [F:SOH1]DLVSTA>1))
                            TOATTRIB=0
                          Endif
                      Endif
                    Elsif CLASSE="F"
                      If [M:SFIT]C_DESVCR=2 :#--Cde -> Livr

                        #--Pour les cdes ouvertes
                        If clalev([F:SOH1])=0
                            Local File SORDER [SOH1]
                            If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                        Endif
                        #--Pour les cdes normales
                        If clalev([F:SDD1])=0
                            Local File SDELIVERYD [SDD1]
                            If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                        Endif
                        # Issue 119267
                        If clalev([F:SID1])=0
                            Local File SINVOICED [SID1]
                            If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                        Endif
                        # End issue 119267
                        # Issue X3-69917 - 2018-01-04 by CPO : Invoice elements Transfer Rules are not followed when using FUNAUTDLV
                        If clalev([F:SOP1])=0
                            Local File SORDERP [SOP1]
                            If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                        Endif
                        # End issue X3-69917
                        If WSAVEVCRENT<>[M:SFIT]VCRENT(IJ0)
                          WNUMCURRVCR = evalue("["+CLASSE+":"+ABMSK+"]SDHNUM")
                          If [F:SOH1]SOHNUM<>[M:SFIT]VCRENT(IJ0)
                              Read [F:SOH1]SOH0=[M:SFIT]VCRENT(IJ0)
                          Endif
                          If [F:SOH1]SOHCAT=4 # Commande ouverte
                              TOATTRIB=1
                          Else
                            #--Cdes autres que de type ouvertes
                            Filter [F:SDD1] Where [F:SDD1]SOHNUM=[M:SFIT]VCRENT(IJ0) and SDHNUM<>WNUMCURRVCR
                            Read   [F:SDD1] First
                            If fstat>1 #--Y cpris le cas d'un éventuel lock
                              TOATTRIB=1
                            Endif
                            Filter [F:SDD1]
                            # Issue 107888 - 2016-06-20 by CPO : US 135 Normal order -> Invoices (by using a scheduling invoice)
                            If TOATTRIB=0
                              # Issue X3-69917 - 2018-01-04 by CPO : Invoice elements Transfer Rules are not followed when using FUNAUTDLV
                              #--The following code added during US135 concern orders mixing lines with scheduling invoices and lines to be delivered
                              #--It induces a side effect;
                              #--so taking into account the SID1 should only be done if the original order has a line having a scheduling invoice condition
                              Filter [F:SOP1] Where [F:SOP1]SOHNUM=[M:SFIT]VCRENT(IJ0) and [F:SOP1]INVCND<>""
                              Read   [F:SOP1] First
                              If fstat=0
                              # End issue X3-69917
                                Filter [F:SID1] Where [F:SID1]SOHNUM=[M:SFIT]VCRENT(IJ0) and [F:SID1]SIDORI=10 and [F:SID1]VCRINVCNDTYP=10 and [F:SID1]VCRINVCNDLIN>0
                                Read   [F:SID1] First
                                If fstat>1 #--Y cpris le cas d'un éventuel lock
                                  TOATTRIB=1
                                Endif
                                Filter [F:SID1]
                              # Issue X3-69917 - 2018-01-04 by CPO : Invoice elements Transfer Rules are not followed when using FUNAUTDLV
                              Endif
                              Filter [F:SOP1]
                              # End issue X3-69917
                            Endif
                            # End issue 107888 US 135
                          Endif
                          WSAVEVCRENT=[M:SFIT]VCRENT(IJ0)
                          WSAVETOATTRIB=TOATTRIB
                        Else
                          TOATTRIB=WSAVETOATTRIB
                        Endif
                      Elsif [M:SFIT]C_DESVCR=18 :#-- Cde -> Fact
                        If clalev([F:SID1])=0
                            Local File SINVOICED [SID1]
                            If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                        Endif
                        If WSAVEVCRENT<>[M:SFIT]VCRENT(IJ0)
                          WNUMCURRVCR = evalue("["+CLASSE+":"+ABMSK+"]NUM")
                          Filter [SID1] Where [F:SID1]SOHNUM=[M:SFIT]VCRENT(IJ0) and NUM<>WNUMCURRVCR
                          Read [F:SID1] First
                          If fstat<>0
                            TOATTRIB=1
                          Endif
                          Filter [F:SID1]
                          WSAVEVCRENT=[M:SFIT]VCRENT(IJ0)
                          WSAVETOATTRIB=TOATTRIB
                        Else
                          TOATTRIB=WSAVETOATTRIB
                        Endif
                      # Issue 107888 - 2016-06-20 by CPO : US 130 Scheduled invoices object management
                      Elsif [M:SFIT]C_DESVCR=4 :#-- Normal order -> Invoices (by using a scheduling invoice)
                        If clalev([F:SDD1])=0
                            Local File SDELIVERYD [SDD1]
                            If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                        Endif
                        If clalev([F:SID1])=0
                            Local File SINVOICED [SID1]
                            If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                        Endif
                        If WSAVEVCRENT<>[M:SFIT]VCRENT(IJ0)
                          WNUMCURRVCR = evalue("["+CLASSE+":"+ABMSK+"]NUM") :#--CPO 79550 TO DO : on peut le sortir du For mais avec un case pour SDHNUM/NUM
                          Filter [F:SID1] Where [F:SID1]SOHNUM=[M:SFIT]VCRENT(IJ0) and [F:SID1]SIDORI=10 and [F:SID1]VCRINVCNDTYP=10 and [F:SID1]VCRINVCNDLIN>0 and NUM<>WNUMCURRVCR
                          Read [F:SID1] First
                          If fstat>1
                            TOATTRIB=1
                          Endif
                          Filter [F:SID1]
                          If TOATTRIB=0
                              # Issue X3-69917 - 2018-01-04 by CPO : Invoice elements Transfer Rules are not followed when using FUNAUTDLV
                              #--The following code added during US135 concern orders mixing lines with scheduling invoices and lines to be delivered
                              #--It induces a side effect;
                              #--so taking into account the SDD1 should only be done if the original order has a line without a scheduling invoice condition
                              Filter [F:SOP1] Where [F:SOP1]SOHNUM=[M:SFIT]VCRENT(IJ0) and [F:SOP1]INVCND=""
                              Read   [F:SOP1] First
                              If fstat=0
                               #--WNUMCURRVCR contains the current invoice to be created !
                               #Filter [F:SDD1] Where [F:SDD1]SOHNUM=[M:SFIT]VCRENT(IJ0) and SDHNUM<>WNUMCURRVCR
                                Filter [F:SDD1] Where [F:SDD1]SOHNUM=[M:SFIT]VCRENT(IJ0)
                              # End issue X3-69917
                                Read   [F:SDD1] First
                                If fstat>1 #--Y cpris le cas d'un éventuel lock
                                  TOATTRIB=1
                                Endif
                                Filter [F:SDD1]
                              # Issue X3-69917 - 2018-01-04 by CPO : Invoice elements Transfer Rules are not followed when using FUNAUTDLV
                              Endif
                              Filter [F:SOP1]
                              # End issue X3-69917
                          Endif
                          WSAVEVCRENT=[M:SFIT]VCRENT(IJ0)
                          WSAVETOATTRIB=TOATTRIB
                        Else
                          TOATTRIB=WSAVETOATTRIB
                        Endif
                      # End issue 107888
                      Endif
                    Endif
                    #--/
                When 2 : # SDH
                    # 1 livraison est forcément éclatée sur 1 seule facture
                    #If [F:SDH]SDHNUM<>[M:SFIT]VCRENT(IJ0)
                    #    Read [F:SDH]SDH0=[M:SFIT]VCRENT(IJ0)
                    #Endif
                    #If [F:SDH]SIHNUM=""
                    TOATTRIB=1
                    #Endif
                When 1 : # SQH
                    If clalev([F:SQH1])=0
                        Local File SQUOTE [SQH1]
                        If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                    Endif
                    If [F:SQH1]SQHNUM<>[M:SFIT]VCRENT(IJ0)
                        Read [F:SQH1]SQH0=[M:SFIT]VCRENT(IJ0)
                    Endif
                    If [F:SQH1]QUOSTA=1
                        TOATTRIB=1
                    Endif
                When 4 : # SIH
                    If clalev([F:SIV1])=0
                        Local File SINVOICEV [SIV1]
                        If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                    Endif
                    If [F:SIV1]NUM<>[M:SFIT]VCRENT(IJ0)
                        Read [F:SIV1]SIV0=[M:SFIT]VCRENT(IJ0)
                    Endif
                    If [F:SIV1]INVCNOSTA=1 : # Si Pas d'avoir
                        TOATTRIB=1
                    Endif
                When 3 : # SRH
                    #--CPO 79550 Transferts : Retours -> Avoirs sur retours
                    #--Il ne doit pas exister de ligne ayant un avoir déjà effectué
                    If clalev([F:SRD1])=0
                        Local File SRETURND [SRD1]
                        If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                    Endif
                    #--Ici, on applique la logique inverse : par défaut TOATTRIB=1
                    #--si existe une ligne de retour sur la même livraison
                    #--et que cette ligne contient un avoir, alors on Raz le TOATTRIB
                    If WSAVEVCRENT<>[M:SFIT]VCRENT(IJ0)
                      TOATTRIB=1
                      WNUMCURRVCR = ""
                      If CLASSE="M"
                        WNUMCURRVCR = [M:SIH0]NUM
                      Elsif CLASSE="F"
                        #--Pas de ttt auto pour l'instant...
                      Endif

                      If WNUMCURRVCR<>""
                        Filter [F:SRD1] Where [F:SRD1]SDHNUM=[M:SFIT]VCRENT(IJ0) and [F:SRD1]SIHNUM<>WNUMCURRVCR
                      Else
                        Filter [F:SRD1] Where [F:SRD1]SDHNUM=[M:SFIT]VCRENT(IJ0)
                      Endif
                      For [F:SRD1]
                      If [F:SRD1]SIHNUM<>""
                        TOATTRIB=0 : Break
                      Endif
                      Next
                      Filter [F:SRD1]
                      WSAVEVCRENT=[M:SFIT]VCRENT(IJ0)
                      WSAVETOATTRIB=TOATTRIB
                    Else
                      TOATTRIB=WSAVETOATTRIB
                    Endif
                When 23 : # CON
                    #--CPO 79550 Transferts : Contrats de services -> Factures
                    #--Cela doit être la première facture du contrats de services
                    If clalev([F:SID1])=0
                        Local File SINVOICED [SID1]
                        If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                    Endif
                    If WSAVEVCRENT<>[M:SFIT]VCRENT(IJ0)
                      If CLASSE="M"
                        Filter [SID1] Where [F:SID1]CONNUM=[M:SFIT]VCRENT(IJ0)
                      Else
                        #--Pour les traitements auto
                        WNUMCURRVCR = evalue("["+CLASSE+":"+ABMSK+"]NUM")
                        Filter [SID1] Where [F:SID1]CONNUM=[M:SFIT]VCRENT(IJ0) and NUM<>WNUMCURRVCR
                      Endif
                      Read [F:SID1] First
                      If fstat>1
                        TOATTRIB=1
                      Endif
                      Filter [F:SID1]
                      WSAVEVCRENT=[M:SFIT]VCRENT(IJ0)
                      WSAVETOATTRIB=TOATTRIB
                    Else
                      TOATTRIB=WSAVETOATTRIB
                    Endif
            Endcase
            If TOATTRIB=1 & [M:SFIT]LIGQTYPRO(IJ0)<>0 # Si suppression, on met 0 (51731)
                [M:SFIT]DTAAMTCLC(IJ0) = [M:SFIT]DTAAMTORI(IJ0)
            Else
                [M:SFIT]DTAAMTCLC(IJ0) = 0
            Endif
        Elsif find([L]BRDRUL,5,6,7,8)<>0 : # Toutes
            [M:SFIT]DTAAMTCLC(IJ0)=[M:SFIT]DTAAMTORI(IJ0)
        Endif
    Else
        # Non lié au document (saisi, client ou defaut -> pas d'éclatement)
        [M:SFIT]DTAAMTCLC(IJ0)=[M:SFIT]DTAAMTORI(IJ0)
    Endif

Next IJ0
# --------------------------------------------------
# FGR 17/04/2015 : X3SUIVI107637 (début)
  #For I = 0 To evalue("dim( ["+CLASSE+":"+ABMSK+"]INVDTAAMT ) - 1")
  #    Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT (I)"    With 0
  #Next
  If IERROROPT = 0 Then
    Gosub DYNAMIQUE_RAZ From =SZPROGNAME
  Endif
  If IERROROPT = 1 or dim(IERRSFIT) >= 0 Then
    # On se replie sur la méthode non optimisée
    $NOT_DYNAMIQUE_RAZ       # Pour détecter, en trace timing que le script généré n'a pas été utilisé
    If GTRACE <> "" Then
      Call ECR_TRACE("Generated script not used (1).", -1) From GESECRAN
    Endif
    For I = 0 To evalue("dim( ["+CLASSE+":"+ABMSK+"]INVDTAAMT) - 1")
      Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT (I)"    With 0
    Next
    If dim(IERRSFIT) >= 0 Then
      Kill IERRSFIT
    Endif
  Endif
# FGR 17/04/2015 : X3SUIVI107637 (fin)
# --------------------------------------------------

Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice), [M:SFIT]DAC([S]indice), [M:SFIT]DTA([S]indice)    : # Dde 81811 : Optimisation

# Regroupement
Local Integer GRURUL, DESTDOC
Local Integer IELT
Local Decimal NEWDTAAMT, OLDDTAAMT
Local Integer IJ2
# --------------------------------------------------
# FGR 17/04/2015 : X3SUIVI107637 (début) : Note : dimension bien (0..dim([M:SFIT]SFINUM)
Local Integer DTAFLG(0..dim([M:SFIT]SFINUM))
If max([M:SFIT]DAC)>0 and dim([M:SFIT]SFINUM)>0
  Local Decimal DTAMOYTAB( dim([M:SFIT]SFINUM) ) : # Tableau utilisé pour les moyennes : Moyenne
  Local Decimal DTATOTLIG( dim([M:SFIT]SFINUM) ) : # Tableau utilisé pour les moyennes : Amounts  ## LCC 15/12716 SAM 118593
  Local Integer DTAMOYIND( dim([M:SFIT]SFINUM) ) : # Tableau utilisé pour les moyennes : Nb de valeurs
Endif

  #For IJ0=0 To dim([M:SFIT]SFINUM)
  #    [L]DTAFLG(IJ0)=10
  #Next IJ0
  For IJ0 = 0 To dim([L]DTAFLG)-1
    [L]DTAFLG(IJ0) = 10
  Next IJ0
# FGR 17/04/2015 : X3SUIVI107637 (fin)
# --------------------------------------------------

#SAV_DEF_MSK=dbgstr(1) : SAV_DEF_TAB=dbgstr(2)
#If clalev([F:TCU])=0  : Local File TABCUR [TCU]  : Endif
#Default Mask SAV_DEF_MSK : Default File SAV_DEF_TAB
If clalev([F:TCU])=0
    Local File TABCUR [TCU]  :
    If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
Endif
If [F:TCU]CUR<>[M:SFIT]S_CUR            : # Dde 81811 : Optimisation
  Read [TCU]TCU0=[M:SFIT]S_CUR
Endif                                   : # Dde 81811 : Optimisation

  # -------------------------------------------------------
  # FLORENT ICI : même remarque pour la variable bas de tableau, même si là on teste : "If [M:SFIT]DTA(IJ0)<>0"
  #               mais on va quand même jusqu'à la fin du tableau !
  # FGR 12/02/2015 : X3SUIVI106256 (début)
  # Pas la peine de le faire à chaque fois qu'on s'en sert dans la boucle. Sa valeur ne change pas.
  # Une fois au début, planqué dans une variable est suffisant.
  # Ca réduit le nombre d'appels de MINNOTZERO au nombre d'appels de UPD_NBFAC
  # Notes :
  #       Le problème de la fonction MINNOTZERO est triple :
  #           1°) Il reçoit un tableau ([M:SFIT]DAC) en passage par valeur. Le tableau source est donc "physiquement" recopié à chaque fois qu'on appelle la
  #               fonction
  #           2°) L'ordre dans lequel les données sont dans le tableau n'étant pas pertinant relativement au besoin de la fonction, ce dernier
  #               est retrié à chaque fois.
  #           3°) Il ne serait pas opportun de faire un passage par variable du tableau, plutôt que par valeur. Ce dernier étant trié dans
  #               la fonction, l'ordre du tableau, en sortie, ne serait plus cohérerent avec les autres colonnes
  #-------------------------------------
  Local Integer IMINNOTZERO

  IMINNOTZERO = func MINNOTZERO([M:SFIT]DAC)
  # FGR 12/02/2015 : X3SUIVI106256 (fin)
  #-------------------------------------
  #For IJ0=0 To dim([M:SFIT]DTA)-1                                                                 # FGR 12/02/2015 : X3SUIVI106256 optimisation
  For IJ0=0 To [M:SFIT]NBTRF-1                                                                     # FGR 12/02/2015 : X3SUIVI106256 optimisation
    If [M:SFIT]DTA(IJ0)<>0
      # Indice de l'element dans la liste des élements (1e tableau)
      #IJ2 = find([M:SFIT]DTA(IJ0), [M:SFIT]SFINUM)                                                # FGR 17/04/2015 : X3SUIVI107637
      IJ2 = find([M:SFIT]DTA(IJ0), [M:SFIT]SFINUM(0..[M:SFIT]NBSFI-1)) # -1 car déphasage          # FGR 17/04/2015 : X3SUIVI107637
      # Retrouver la regle associée (2e tableau)
      #IJ1=find(num$([M:SFIT]DTA(IJ0)) + TST_RUL, [M:SFIT]T_TST_RUL)                               # FGR 17/04/2015 : X3SUIVI107637
      IJ1=find(num$([M:SFIT]DTA(IJ0)) + TST_RUL, [M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))           # FGR 17/04/2015 : X3SUIVI107637
      If CLASSE="M"
        IELT = find( [M:SFIT]DTA(IJ0), [M]INVDTA )
      Else
        IELT = find( [M:SFIT]DTA(IJ0), [F]INVDTA )
      Endif
      If IELT<>0 and IJ2<>0
        #Assign "[L]OLDDTAAMT" With evalue ( "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" )           # FGR 12/02/2015 : X3SUIVI106256 optimisation
        # --------------------------------------------------
        # FGR 17/04/2015 : X3SUIVI107637 (début)
        #[L]OLDDTAAMT = evalue("["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)")                          # FGR 12/02/2015 : X3SUIVI106256 optimisation
        If IERROROPT = 0 Then
          Gosub DYNAMIQUE_OLDDTAAMT From =SZPROGNAME
        Endif
        If IERROROPT = 1 or dim(IERRSFIT) >= 0 Then
          $NOT_DYNAMIQUE_OLDDTAAMT     # Pour détecter, en trace timing que le script généré n'a pas été utilisé
          If GTRACE <> "" Then
            Call ECR_TRACE("Generated script not used (2).", -1) From GESECRAN
          Endif
          [L]OLDDTAAMT = evalue("["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)")
          If dim(IERRSFIT) >= 0 Then
            Kill IERRSFIT
          Endif
        Endif
        # FGR 17/04/2015 : X3SUIVI107637 (fin)
        # --------------------------------------------------
        # On passe si on a trouvé  la règle, ou si l'origine n'est pas le document,
        # ou si on est dans le cas :
        #   Devis -> Proforma : 1-1, pas de paramétrage fait
        If ( IJ1<>0 or [M:SFIT]ORI(IJ0)>=5 or [M:SFIT]ORI(IJ0)=0 or TST_RUL="~1~12" ) and [L]DTAFLG(IJ2)>=[M:SFIT]ORI(IJ0)
          If [M:SFIT]ORI(IJ0)>=5 or [M:SFIT]ORI(IJ0)=0 or TST_RUL="~1~12"
            [L]NEWDTAAMT = [M:SFIT]DTAAMTCLC(IJ0)
            [L]DTAFLG(IJ2)=[M:SFIT]ORI(IJ0)
          Else
            [L]DTAFLG(IJ2)=[M:SFIT]ORI(IJ0)
            #Recup règle de regroupement
            [L]GRURUL = [M:SFIT]T_GRURUL(IJ1-1)
            #--CPO 84215 Cas des élts en taux avec regroupement "Non si différent"
            #--Dans ce cas la règle est vide, il faut l'alimenter
            If [L]GRURUL=0
              #--  [M:SFIT]C_ORIVCR ou [M:SFIT]T_ORIVCR(IJ1-1)?
              Case [M:SFIT]T_ORIVCR(IJ1-1)
                When 1  : [L]GRURUL=1 :# SQH
                When 10 : [L]GRURUL=2 :# SOH Cde normale
                When 12 : [L]GRURUL=2 :# SOH Cde à fact. directe
                When 2  : [L]GRURUL=3 :# SDH
                When 4  : [L]GRURUL=4 :# SIH
                When 3  : [L]GRURUL=14 :# SRH #--CPO 79550 Transferts : Retours -> Avoirs sur retours
                When 23 : [L]GRURUL=16 :# CON #--CPO 79550 Transferts : Contrats de services -> Facture
              Endcase
            Endif
            #--/
            # Retrouver le doc de destination
            [L]DESTDOC=[M:SFIT]T_DESVCR(IJ1-1)
            # -------------------------------------------------------
            # Valeur actuelle de l'élément du document de destination
            #If find([L]GRURUL,1,2,3,4)<>0
            If find([L]GRURUL,1,2,3,4,14,16)<>0 #--CPO 79550 Transferts : Retours -> Avoirs sur retours, Contrats de serv -> Fact
              # 1ere
              #If [M:SFIT]DAC(IJ0) = func MINNOTZERO ([M:SFIT]DAC)                                 # FGR 12/02/2015 : X3SUIVI106256 optimisation
              If [M:SFIT]DAC(IJ0) = IMINNOTZERO                                                    # FGR 12/02/2015 : X3SUIVI106256 optimisation
                [L]NEWDTAAMT = [M:SFIT]DTAAMTCLC(IJ0)
              Else
                [L]NEWDTAAMT = [L]OLDDTAAMT
              Endif
            #Elsif    find([L]GRURUL,5,6,7,8)<>0
            Elsif    find([L]GRURUL,5,6,7,8,15,17)<>0 #--CPO 79550 Transferts : Retours -> Avoirs sur retours, Contrats de serv -> Fact
              # Somme des montants devis, commandes, livraisons ou factures
              [L]NEWDTAAMT=[L]OLDDTAAMT + [M:SFIT]DTAAMTCLC(IJ0)
            Elsif [L]GRURUL = 10 or [L]GRURUL=12
              # Montant maxi ou % maxi
              #If [M:SFIT]DAC(IJ0) = func MINNOTZERO ([M:SFIT]DAC)                                 # FGR 12/02/2015 : X3SUIVI106256 optimisation
              If [M:SFIT]DAC(IJ0) = IMINNOTZERO                                                    # FGR 12/02/2015 : X3SUIVI106256 optimisation
                [L]NEWDTAAMT = [M:SFIT]DTAAMTCLC(IJ0)
              Else
                [L]NEWDTAAMT = max ([L]OLDDTAAMT , [M:SFIT]DTAAMTCLC(IJ0) )
              Endif
            Elsif [L]GRURUL = 9 or [L]GRURUL=11
              # Montant mini ou % mini
              #If [M:SFIT]DAC(IJ0) = func MINNOTZERO ([M:SFIT]DAC)                                 # FGR 12/02/2015 : X3SUIVI106256 optimisation
              If [M:SFIT]DAC(IJ0) = IMINNOTZERO                                                    # FGR 12/02/2015 : X3SUIVI106256 optimisation
                [L]NEWDTAAMT = [M:SFIT]DTAAMTCLC(IJ0)
              Else
                [L]NEWDTAAMT = min ([L]OLDDTAAMT , [M:SFIT]DTAAMTCLC(IJ0) )
              Endif
            Elsif [L]GRURUL = 13
              # % Moyen
              ## LCC 15/12716 SAM 118593
              #[L]DTAMOYTAB( IJ2 ) = (([L]DTAMOYTAB( IJ2 ) * [L]DTAMOYIND(IJ2) ) + [M:SFIT]DTAAMTCLC(IJ0))/([L]DTAMOYIND(IJ2)+1)
              If [M:SFIT]LIGAMTPRO(IJ0)<>0
              [L]DTAMOYTAB( IJ2 ) = (([L]DTAMOYTAB( IJ2 ) * [L]DTATOTLIG (IJ2) ) + [M:SFIT]DTAAMTCLC(IJ0)*[M:SFIT]LIGAMTPRO(IJ0))/([L]DTATOTLIG(IJ2)+[M:SFIT]LIGAMTPRO(IJ0))
              Endif
              [L]DTATOTLIG (IJ2) += [M:SFIT]LIGAMTPRO(IJ0)
              ## end LCC 15/12716 SAM 118593
              [L]DTAMOYIND(IJ2)+=1
              [L]NEWDTAAMT = [L]DTAMOYTAB( IJ2 )
            Elsif [L]GRURUL = 14
              # TODO % Mt Mini
            Elsif [L]GRURUL = 15
              # TODO % Mt Max
            Endif
          Endif
          # -------------------------------------------------------
          # Impacter sur le doc de destination
          # --------------------------------------------------
          # FGR 17/04/2015 : X3SUIVI107637 (début)
          #If CLASSE="M"
          #  If evalue("["+CLASSE+":"+ABMSK+"]AMTCOD(IELT-1)")=1 # Taux
          #    Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" With arr([L]NEWDTAAMT,[F:TCU]CURRND/100) # nb de decimale = nb de decimale +2 (pour arrondis) - CH
          #    If arr([L]NEWDTAAMT,[F:TCU]CURRND/100) <> arr([L]NEWDTAAMT,[F:TCU]CURRND) : # Si plus de X décimales, on augmente le format
          #      Assign "["+CLASSE+":"+ABMSK+"]FORMAT(IELT-1)" With "NZ:3." + num$(len(num$([F:TCU]CURRND)) - instr(0,num$([F:TCU]CURRND),".")+2)
          #    Endif
          #  Else
          #    Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" With val(ctrans(format$(evalue("["+CLASSE+":"+ABMSK+"]FORMAT(IELT-1)"), [L]NEWDTAAMT),",","."))
          #  Endif
          #Else
          #  Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" With [L]NEWDTAAMT
          #Endif
          If IERROROPT = 0 Then
            Gosub DYNAMIQUE_DESTINATION From =SZPROGNAME
          Endif
          If IERROROPT = 1 or dim(IERRSFIT) >= 0 Then
            # On se replie sur la méthode non optimisée
            $NOT_DYNAMIQUE_DESTINATION # Pour détecter, en trace timing que le script généré n'a pas été utilisé
            If GTRACE <> "" Then
              Call ECR_TRACE("Generated script not used (3).", -1) From GESECRAN
            Endif
            If CLASSE="M"
              If evalue("["+CLASSE+":"+ABMSK+"]AMTCOD(IELT-1)")=1 # Taux
                Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" With arr([L]NEWDTAAMT,[F:TCU]CURRND/100) # nb de decimale = nb de decimale +2 (pour arrondis) - CH
                If arr([L]NEWDTAAMT,[F:TCU]CURRND/100) <> arr([L]NEWDTAAMT,[F:TCU]CURRND) : # Si plus de X décimales, on augmente le format
                  Assign "["+CLASSE+":"+ABMSK+"]FORMAT(IELT-1)" With "NZ:3." + num$(len(num$([F:TCU]CURRND)) - instr(0,num$([F:TCU]CURRND),".")+2)
                Endif
              Else
                Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" With val(ctrans(format$(evalue("["+CLASSE+":"+ABMSK+"]FORMAT(IELT-1)"), [L]NEWDTAAMT),",","."))
              Endif
            Else
              Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" With [L]NEWDTAAMT
            Endif
            If dim(IERRSFIT) >= 0 Then
              Kill IERRSFIT
            Endif
          Endif
          # FGR 17/04/2015 : X3SUIVI107637 (fin)
          # --------------------------------------------------
        Endif
      Endif
    Endif
  Next IJ0
  # -------------------------------------------------------

If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
    If CLASSE="M" : Affzo [M]INVDTAAMT : Endif #--CPO 2016-08-04 Here, given the fact that the CLASS equal "M" we don't do it while comming from automatic processes
Endif                        : # Dde 81811 : Optimisation

# Restauration du tri "naturel", indispensable pour MAJ_SFIT
Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1        : # Dde 81811 : Optimisation

If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
    #Affzo [M:SFIT] # Issue 117933 - 2016-08-04 by CPO : SUBSFIT-NEW_SFIT performance-Implus (no need for affzo on stored mask)
Endif                        : # Dde 81811 : Optimisation

indice=SAVIND

Gosub REST_DEFS

End

