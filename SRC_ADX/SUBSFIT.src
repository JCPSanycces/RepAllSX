##Default Mask SAV_DEF_MSK : Default File SAV_DEF_TAB
#If clalev([F:TCU])=0
#    Local File TABCUR [TCU]  :
#    If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
#Endif
#If [F:TCU]CUR<>[M:SFIT]S_CUR            : # Dde 81811 : Optimisation
#  Read [TCU]TCU0=[M:SFIT]S_CUR
#Endif                                   : # Dde 81811 : Optimisation
#
#  # -------------------------------------------------------
#  # FLORENT ICI : même remarque pour la variable bas de tableau, même si là on teste : "If [M:SFIT]DTA(IJ0)<>0"
#  #               mais on va quand même jusqu'à la fin du tableau !
#  # FGR 12/02/2015 : X3SUIVI106256 (début)
#  # Pas la peine de le faire à chaque fois qu'on s'en sert dans la boucle. Sa valeur ne change pas.
#  # Une fois au début, planqué dans une variable est suffisant.
#  # Ca réduit le nombre d'appels de MINNOTZERO au nombre d'appels de UPD_NBFAC
#  # Notes :
#  #       Le problème de la fonction MINNOTZERO est triple :
#  #           1°) Il reçoit un tableau ([M:SFIT]DAC) en passage par valeur. Le tableau source est donc "physiquement" recopié à chaque fois qu'on appelle la
#  #               fonction
#  #           2°) L'ordre dans lequel les données sont dans le tableau n'étant pas pertinant relativement au besoin de la fonction, ce dernier
#  #               est retrié à chaque fois.
#  #           3°) Il ne serait pas opportun de faire un passage par variable du tableau, plutôt que par valeur. Ce dernier étant trié dans
#  #               la fonction, l'ordre du tableau, en sortie, ne serait plus cohérerent avec les autres colonnes
#  #-------------------------------------
#  Local Integer IMINNOTZERO
#
#  IMINNOTZERO = func MINNOTZERO([M:SFIT]DAC)
#  # FGR 12/02/2015 : X3SUIVI106256 (fin)
#  #-------------------------------------
#  #For IJ0=0 To dim([M:SFIT]DTA)-1                                                                 # FGR 12/02/2015 : X3SUIVI106256 optimisation
#  For IJ0=0 To [M:SFIT]NBTRF-1                                                                     # FGR 12/02/2015 : X3SUIVI106256 optimisation
#
#    If [M:SFIT]DTA(IJ0)<>0
#      # Indice de l'element dans la liste des élements (1e tableau)
#      IJ2 = find([M:SFIT]DTA(IJ0), [M:SFIT]SFINUM)
#      # Retrouver la regle associée (2e tableau)
#      IJ1=find(num$([M:SFIT]DTA(IJ0)) + TST_RUL, [M:SFIT]T_TST_RUL)
#      If CLASSE="M"
#        IELT = find( [M:SFIT]DTA(IJ0), [M]INVDTA )
#      Else
#        IELT = find( [M:SFIT]DTA(IJ0), [F]INVDTA )
#      Endif
#      If IELT<>0 and IJ2<>0
#        #Assign "[L]OLDDTAAMT" With evalue ( "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" )           # FGR 12/02/2015 : X3SUIVI106256 optimisation
#        [L]OLDDTAAMT = evalue ( "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" )                        # FGR 12/02/2015 : X3SUIVI106256 optimisation
#        # On passe si on a trouvé  la règle, ou si l'origine n'est pas le document,
#        # ou si on est dans le cas :
#        #   Devis -> Proforma : 1-1, pas de paramétrage fait
#        If ( IJ1<>0 or [M:SFIT]ORI(IJ0)>=5 or [M:SFIT]ORI(IJ0)=0 or TST_RUL="~1~12" ) and [L]DTAFLG(IJ2)>=[M:SFIT]ORI(IJ0)
#          If [M:SFIT]ORI(IJ0)>=5 or [M:SFIT]ORI(IJ0)=0 or TST_RUL="~1~12"
#            [L]NEWDTAAMT = [M:SFIT]DTAAMTCLC(IJ0)
#            [L]DTAFLG(IJ2)=[M:SFIT]ORI(IJ0)
#          Else
#            [L]DTAFLG(IJ2)=[M:SFIT]ORI(IJ0)
#            #Recup règle de regroupement
#            [L]GRURUL = [M:SFIT]T_GRURUL(IJ1-1)
#            #--CPO 84215 Cas des élts en taux avec regroupement "Non si différent"
#            #--Dans ce cas la règle est vide, il faut l'alimenter
#            If [L]GRURUL=0
#              #--  [M:SFIT]C_ORIVCR ou [M:SFIT]T_ORIVCR(IJ1-1)?
#              Case [M:SFIT]T_ORIVCR(IJ1-1)
#                When 1  : [L]GRURUL=1 :# SQH
#                When 10 : [L]GRURUL=2 :# SOH Cde normale
#                When 12 : [L]GRURUL=2 :# SOH Cde à fact. directe
#                When 2  : [L]GRURUL=3 :# SDH
#                When 4  : [L]GRURUL=4 :# SIH
#                When 3  : [L]GRURUL=14 :# SRH #--CPO 79550 Transferts : Retours -> Avoirs sur retours
#                When 23 : [L]GRURUL=16 :# CON #--CPO 79550 Transferts : Contrats de services -> Facture
#              Endcase
#            Endif
#            #--/
#            # Retrouver le doc de destination
#            [L]DESTDOC=[M:SFIT]T_DESVCR(IJ1-1)
#            # -------------------------------------------------------
#            # Valeur actuelle de l'élément du document de destination
#            #If find([L]GRURUL,1,2,3,4)<>0
#            If find([L]GRURUL,1,2,3,4,14,16)<>0 #--CPO 79550 Transferts : Retours -> Avoirs sur retours, Contrats de serv -> Fact
#              # 1ere
#              #If [M:SFIT]DAC(IJ0) = func MINNOTZERO ([M:SFIT]DAC)                                 # FGR 12/02/2015 : X3SUIVI106256 optimisation
#              If [M:SFIT]DAC(IJ0) = IMINNOTZERO                                                    # FGR 12/02/2015 : X3SUIVI106256 optimisation
#                [L]NEWDTAAMT = [M:SFIT]DTAAMTCLC(IJ0)
#              Else
#                [L]NEWDTAAMT = [L]OLDDTAAMT
#              Endif
#            #Elsif    find([L]GRURUL,5,6,7,8)<>0
#            Elsif    find([L]GRURUL,5,6,7,8,15,17)<>0 #--CPO 79550 Transferts : Retours -> Avoirs sur retours, Contrats de serv -> Fact
#              # Somme des montants devis, commandes, livraisons ou factures
#              [L]NEWDTAAMT=[L]OLDDTAAMT + [M:SFIT]DTAAMTCLC(IJ0)
#            Elsif [L]GRURUL = 10 or [L]GRURUL=12
#              # Montant maxi ou % maxi
#              #If [M:SFIT]DAC(IJ0) = func MINNOTZERO ([M:SFIT]DAC)                                 # FGR 12/02/2015 : X3SUIVI106256 optimisation
#              If [M:SFIT]DAC(IJ0) = IMINNOTZERO                                                    # FGR 12/02/2015 : X3SUIVI106256 optimisation
#                [L]NEWDTAAMT = [M:SFIT]DTAAMTCLC(IJ0)
#              Else
#                [L]NEWDTAAMT = max ([L]OLDDTAAMT , [M:SFIT]DTAAMTCLC(IJ0) )
#              Endif
#            Elsif [L]GRURUL = 9 or [L]GRURUL=11
#              # Montant mini ou % mini
#              #If [M:SFIT]DAC(IJ0) = func MINNOTZERO ([M:SFIT]DAC)                                 # FGR 12/02/2015 : X3SUIVI106256 optimisation
#              If [M:SFIT]DAC(IJ0) = IMINNOTZERO                                                    # FGR 12/02/2015 : X3SUIVI106256 optimisation
#                [L]NEWDTAAMT = [M:SFIT]DTAAMTCLC(IJ0)
#              Else
#                [L]NEWDTAAMT = min ([L]OLDDTAAMT , [M:SFIT]DTAAMTCLC(IJ0) )
#              Endif
#            Elsif [L]GRURUL = 13
#              # % Moyen
#              [L]DTAMOYTAB( IJ2 ) = (([L]DTAMOYTAB( IJ2 ) * [L]DTAMOYIND(IJ2) ) + [M:SFIT]DTAAMTCLC(IJ0))/([L]DTAMOYIND(IJ2)+1)
#              [L]DTAMOYIND(IJ2)+=1
#              [L]NEWDTAAMT = [L]DTAMOYTAB( IJ2 )
#            Elsif [L]GRURUL = 14
#              # TODO % Mt Mini
#            Elsif [L]GRURUL = 15
#              # TODO % Mt Max
#            Endif
#          Endif
#          # -------------------------------------------------------
#          # Impacter sur le doc de destination
#          If CLASSE="M"
#            If evalue("["+CLASSE+":"+ABMSK+"]AMTCOD(IELT-1)")=1 # Taux
#              Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" With arr([L]NEWDTAAMT,[F:TCU]CURRND/100) # nb de decimale = nb de decimale +2 (pour arrondis) - CH
#              If arr([L]NEWDTAAMT,[F:TCU]CURRND/100) <> arr([L]NEWDTAAMT,[F:TCU]CURRND) : # Si plus de X décimales, on augmente le format
#                Assign "["+CLASSE+":"+ABMSK+"]FORMAT(IELT-1)" With "NZ:3." + num$(len(num$([F:TCU]CURRND)) - instr(0,num$([F:TCU]CURRND),".")+2)
#              Endif
#            Else
#              Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" With val(ctrans(format$(evalue("["+CLASSE+":"+ABMSK+"]FORMAT(IELT-1)"), [L]NEWDTAAMT),",","."))
#            Endif
#          Else
#            Assign "["+CLASSE+":"+ABMSK+"]INVDTAAMT(IELT-1)" With [L]NEWDTAAMT
#          Endif
#        Endif
#      Endif
#    Endif
#  Next IJ0
#  # -------------------------------------------------------
#
#If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
#    If CLASSE="M" : Affzo [M]INVDTAAMT : Endif
#Endif                        : # Dde 81811 : Optimisation
#
## Restauration du tri "naturel", indispensable pour MAJ_SFIT
#Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]ORI([S]indice) * -1, [M:SFIT]DAC([S]indice)*-1, [M:SFIT]DTA([S]indice)*-1        : # Dde 81811 : Optimisation
#
#If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
#    Affzo [M:SFIT]
#Endif                        : # Dde 81811 : Optimisation
#
#indice=SAVIND
#
#Gosub REST_DEFS
#
#End
# FGR 17/04/2015 : X3SUIVI107637 (fin)

######################################################################################
# ACA - Renvoi le plus petit nombre d'un tableau, sauf 0
# Utilisé dans UPD_NBFAC
Funprog MINNOTZERO(TAB)
Value Integer TAB

Local Integer I
Local Integer RESULT
RESULT=1000

#Issue 116728 - 2016-05-24 by CPO : Delivery performance
#For I=0 To dim (TAB)-1
#    If TAB(I)<RESULT & TAB(I)<>0
#        RESULT=TAB(I)
#    Endif
#Next I
Local Integer WDIMTAB
WDIMTAB=dim(TAB)
Sorta WDIMTAB TAB
  I=-1
  Repeat
    I=I+1
  Until not (I<WDIMTAB and TAB(I)=0)
If I<WDIMTAB and TAB(I)<>0 : RESULT = TAB(I) : Endif
#End issue 116728
End RESULT

######################################################################################

Subprog DEL_NBTRF_ORI0(PDTA, CLASSE, ABMSK)
Value Integer PDTA : # DTA a supprimer
Value Char CLASSE
Value Char ABMSK

Local Integer IJ0,IJ1

# Suppr de NBTRF
    IJ1=-1
    For IJ0 = 0 To dim([M:SFIT]DTA)-1
        If  [M:SFIT]DTA(IJ0)=PDTA and [M:SFIT]ORI(IJ0)=0
            IJ1=IJ0
            Break
        Endif
    Next
    If IJ1>-1
        Dela IJ1 [M:SFIT]NBTRF
    Endif

# Relance le calcul
    Call UPD_NBFAC(CLASSE, ABMSK)

    #Affzo [M:SFIT] # Issue 117933 - 2016-08-04 by CPO : SUBSFIT-NEW_SFIT performance-Implus (no need for affzo on stored mask)

End


#########################################################################
#  Sous-programme de garnissage des éléments de facturation             #
#  dans la classe [M]                                                   #
#  avec les valeurs par défaut, et celle du client/fournisseur          #
#-----------------------------------------------------------------------#
# Subprog SAISFOOT (TRAIT,WABMSK,NBPOSTE,TYPCUR,CURORI,CURDES,ALIM)     #
#  TRAIT   = Ventes ( 1=client,   2=lignes,  3=commande,  4=livraison   #
#                     5=livraison directe,   6=facture                  #
#                     7=facture de commande, 8=facture directe )        #
#  WABMSK   = Abreviation du masque (ex: BPC1)                          #
#  NBPOSTE = Nbre de postes maxi du tableau (ex: 10 pour client)        #
#          =   Retour ---> Nbre de postes garnis pour alimenter BASTAB  #
#  TYPCUR  = Type de cours                                              #
#  CURORI  = Devise origine                                             #
#  CURDES  = Devise destination                                         #
#  ALIM    = OUI pour alimenter les mt et % , NON pour ne pas les alim. #
#                                                                       #
# Attention : GLOCALDEV doit être la devise de la société courante      #
#-----------------------------------------------------------------------#
# Retour                                                                #
#  NBPOSTE = Nbre de postes de [M] garnis après tri                     #
#  [M:xxx]INVDTA   no élément de facturation                            #
#  [M:xxx]SHO      Intitulé court de l'élément de facturation           #
#  [M:xxx]AMTCOD   % ou mt (menu local)                                 #
#  [M:xxx]FORMAT   format de saisie de l'élément                        #
#  [M:xxx]INVDTATYP type de valeur                                      #
#  [M:xxx]INVDTAAMT valeur par défaut convertie si en création et zone  #
#                   non garnie par saisie précédente                    #
# ATTENTION : Si le fichier des éléments de facturation est ouvert dans #
#             dans le s/p ce fichier est devenu fichier par défaut      #
# PREREQUIS : L'enregistrement client facture doit être en ligne        #
#########################################################################
Subprog STRUFOOT (TRAIT,WABMSK,NBPOSTE,TYPCUR,CURORI,CURDES,ALIM)
Value    Integer  TRAIT
Value    Char     WABMSK
Variable Integer  NBPOSTE
Value    Libelle  TYPCUR
Value    Char     CURORI,CURDES,ALIM

Gosub STRUFOOT_E
NBPOSTE=POSTE

End

$STRUFOOT_E
Local Integer  MLXFINUM (NBPOSTE)
Local Char     MLSHO (12) (NBPOSTE)
Local Integer  MLTRI    (NBPOSTE)
Local Integer  MLAMTCOD (NBPOSTE)
Local Char     MLFORMAT (15) (NBPOSTE)
Local Integer  MLVAL    (NBPOSTE)
Local Decimal  MLDEFVAL (NBPOSTE)
Local Integer  MLVALTYP (NBPOSTE)
Local Decimal  MTBPR
Local Integer  MLINCDCR (NBPOSTE)
Local Char     MLSSTCOD (8) (NBPOSTE) # 101380.n
Local Integer  MLSSTOVRFLG  (NBPOSTE) # 101380.n

Gosub STRUFOOTE1
Gosub STRUFOOTE2
Return

Subprog STRUFOOT1 (TRAIT,NBPOSTE,TYPCUR,CURORI,CURDES,ALIM,   MLXFINUM, MLSHO,MLTRI,MLAMTCOD,MLFORMAT,MLVAL,MLDEFVAL,MLVALTYP, MLINCDCR)
Value    Integer  TRAIT
Variable Integer  NBPOSTE
Value    Libelle  TYPCUR
Value    Char     CURORI,CURDES,ALIM
Variable Integer  MLXFINUM ()
Variable Char     MLSHO () ()
Variable Integer  MLTRI    ()
Variable Integer  MLAMTCOD ()
Variable Char     MLFORMAT () ()
Variable Integer  MLVAL    ()
Variable Decimal  MLDEFVAL ()
Variable Integer  MLVALTYP ()
Variable Integer  MLINCDCR ()
Local    Char     MLSSTCOD (8) (NBPOSTE)  # 101380.n
Local    Integer  MLSSTOVRFLG (NBPOSTE)   # 101380.n

Gosub STRUFOOTE1
End

$STRUFOOTE1
Local Char     PROGOBJX    : # pour appel à WOSFI
Local Char     WCRITERE(30)
Local Integer  POSTE       : # pour nbre de postes rééls triés
Local Integer  I, I2
Local Integer  CODTRT      : # code traitement interne
Local Integer  WMLTRI
Local Integer  WMLVAL      : # pour maj valeur par defaut
Local Decimal  COURS       : # pour conversion valeur par défaut
Local Integer  SPSTAT

# si le fichier des éléments de facturation est déjà ouvert
# on considère que l'enregistrement "" est alimenté
PROGOBJX = "WOSFI"

Gosub OPEN_SFI From TRTX3CPY : #If clalev([F:SFI])=0 Local File SFOOTINV [SFI] : Endif
Gosub OUVRE  From =PROGOBJX
Gosub DEFAUT From =PROGOBJX
#
Call LECDEV (CURDES) From TRTDIV

#-- Si Paramètre société Remise sur taxe à non, exclure les élts Remise sur taxe
WCRITERE = "1=1"
If GDEPMGTMOD>1 : WCRITERE-="& MISRULSTD<>2" : Endif

# chgt des postes à partir des éléments de facturation
For [SFI] Where evalue(WCRITERE) : # Where WCPY=GSOCIETE
  WMLTRI = 0
  WMLVAL = 0
  Case TRAIT
   When 1 : WMLTRI = [F]DACBPC : WMLVAL = 0
#   When 2 : WMLTRI = [F]DACLIN : WMLVAL = 0         JL le 10/03/06 ( sup de DACLIN dans SFOOTINV )
   When 3 : WMLTRI = [F]DACORD : WMLVAL = [F]DACBPC
   When 4 : WMLTRI = [F]DACDLV : WMLVAL = [F]DACBPC+[F]DACORD
   When 5 : WMLTRI = [F]DACDLV : WMLVAL = [F]DACBPC
   When 6 : WMLTRI = [F]DACINV : WMLVAL = [F]DACBPC+[F]DACORD+[F]DACDLV
   When 7 : WMLTRI = [F]DACINV : WMLVAL = [F]DACBPC+[F]DACORD
   When 8 : WMLTRI = [F]DACINV : WMLVAL = [F]DACBPC
  Endcase

  If WMLTRI <> 0
    I += 1
    MLTRI (I-1) = WMLTRI
    MLXFINUM (I-1) = [F]SFINUM
    If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
        Call LECTEXTRA (MLSHO(I-1),"SFOOTINV","SHOAXX",num$([F]SFINUM),"") From ATEXTRA
    Endif                        : # Dde 81811 : Optimisation
    MLAMTCOD (I-1) = [F]AMTCOD
    If MLAMTCOD (I-1) = 1
      MLFORMAT (I-1) = func TRTX3FNC.GETFMTREM(1) : # "NZ:3.2#[      ]"
      If (find(TRAIT,4,7) & [F]DACORD<>0) | (TRAIT=6 & [F]DACDLV<>0)
         Raz MLDEFVAL (I-1)
      Else
         MLDEFVAL (I-1) = [F]DEFVAL
      Endif
    Else
      MLFORMAT (I-1) = "NZ:"+[F:TCU]CURFMT1
      If (find(TRAIT,4,7) & [F]DACORD<>0) | (TRAIT=6 & [F]DACDLV<>0) | [F]DEFVAL=0         : # Dde 81811 : Optimisation
         Raz MLDEFVAL (I-1)
      Else
         Call CONVERT(GSYSCUR,CURDES,GLOCALDEV,TYPCUR,GHIDATE,[F]DEFVAL,MLDEFVAL(I-1),SPSTAT) From TRTDEV
      Endif
    Endif
    MLVALTYP (I-1) = [F]VALTYP
    MLVAL (I-1) = WMLVAL
    [L]MLINCDCR (I-1)=[F:SFI]INCDCR
    # 101380.sn
    If dim([F:SFI]SSTCOD)>0
      # If not before tax and not fixed rate, we will not allow overrides
      If [F:SFI]CLCBAS<>1 | [F:SFI]VATRUL<>4
        [L]MLSSTOVRFLG(I-1)=1 # Not allowed
      Else
        [L]MLSSTOVRFLG(I-1)=2 # Allow it
      Endif
      #121593.sn JOBRO
      If dim([F:CPY]SSTTAXACT)>0 and [F:CPY]SSTTAXACT=2
        [L]MLSSTCOD (I-1)=[F:SFI]SSTCOD
      Else
        Raz [L]MLSSTCOD(I-1)
        Raz [L]MLSSTOVRFLG(I-1)
      Endif
      #121593.en JOBRO
    Endif
    # 101380.en
  Endif
Next

  Sorta MLTRI,MLXFINUM,MLSHO,MLAMTCOD,MLFORMAT,MLVALTYP,MLVAL,MLDEFVAL,MLINCDCR,MLSSTCOD,MLSSTOVRFLG  # 101380.n
  #Sorta MLTRI , MLXFINUM , MLSHO , MLAMTCOD , MLFORMAT , MLVALTYP, MLVAL , MLDEFVAL, MLINCDCR        # 101380.o

Return

$STRUFOOTE2
For I = 1 To NBPOSTE
  If MLTRI (I-1) <> 0
    POSTE += 1
    If POSTE > NBPOSTE : POSTE=NBPOSTE: Break : Endif
    Assign "[M:"+WABMSK+"]INVDTA (POSTE-1)"    With MLXFINUM (I-1)
    Assign "[M:"+WABMSK+"]SHO (POSTE-1)"       With MLSHO (I-1)
    Assign "[M:"+WABMSK+"]AMTCOD (POSTE-1)"    With MLAMTCOD (I-1)
    Assign "[M:"+WABMSK+"]FORMAT (POSTE-1)"    With MLFORMAT (I-1)
    If evalue ("[M:"+WABMSK+"]INVDTATYP (POSTE-1)")=0
        Assign "[M:"+WABMSK+"]INVDTATYP (POSTE-1)" With MLVALTYP (I-1)
    Endif
    If ALIM = "OUI" & MLVAL (I-1) = 0
      Assign "[M:"+WABMSK+"]INVDTAAMT (POSTE-1)"  With MLDEFVAL (I-1)
    Endif
    # 101380.sn
    # Service contracts and requests (CONG, SRE8) always pass in NON for ALIM, check GREP instead
    If (ALIM = "OUI" | (find(WABMSK,"CONG","SRE8") & GREP="C")) & evalue ("dim([M:"+WABMSK+"]SFISSTCOD)")>0
      Assign "[M:"+WABMSK+"]SFISSTCOD (POSTE-1)"  With MLSSTCOD (I-1)
    Endif
    If evalue ("dim([M:"+WABMSK+"]SFISSTOVRFLG)")>0
      Assign "[M:"+WABMSK+"]SFISSTOVRFLG (POSTE-1)"  With MLSSTOVRFLG (I-1)
    Endif
    # 101380.en
  Endif
Next I

Return

Subprog SAISFOOT (TRAIT,WABMSK,NBPOSTE,TYPCUR,CURORI,CURDES,ALIM)
Value    Integer  TRAIT
Value    Char     WABMSK
Variable Integer  NBPOSTE
Value    Libelle  TYPCUR
Value    Char     CURORI,CURDES,ALIM

Gosub STRUFOOT_E
NBPOSTE=POSTE

#------------------------------------------------------------------#
# Chargement des valeurs par défaut client en commande             #
#                                          en livraison            #
#                                          en facture              #
#------------------------------------------------------------------#
If TRAIT >= 3 & ALIM ="OUI"
   For I=0 To dim([F:BPC]INVDTA)-1
       If [F:BPC]INVDTA(I)=0 : Break : Endif
       For I2=0 To NBPOSTE-1
           If evalue("[M:"+WABMSK+"]INVDTA(I2)")=[F:BPC]INVDTA(I)
              MTBPR = [F:BPC]INVDTAAMT(I)
              If evalue("[M:"+WABMSK+"]AMTCOD(I2)")=2
                 Call CONVERT(CURORI,CURDES,GLOCALDEV,TYPCUR,GHIDATE,
&                             [F:BPC]INVDTAAMT(I),MTBPR,SPSTAT) From TRTDEV
              Endif
              If find(TRAIT,4,6,7)
                 # Read [SFI]SFI0=GSOCIETE;[F:BPC]INVDTA(I)
                 Read [SFI]SFI0=[F:BPC]INVDTA(I)
                 If !fstat & ((find(TRAIT,4,7) & [F:SFI]DACORD<>0) | (TRAIT=6 & [F:SFI]DACDLV<>0))
                    Raz MTBPR
                 Endif
              Endif
              If MTBPR<>0
                 Assign "[M:"+WABMSK+"]INVDTAAMT(I2)" With MTBPR
              Endif
              Break
           Endif
       Next I2
   Next I
Endif

End


#########################################################################
#  Sous-programme de garnissage des éléments de facturation             #
#  dans la classe [F:SDH] ou [F:SIV]                                    #
#  avec les valeurs par défaut, et celle du client/fournisseur          #
#-----------------------------------------------------------------------#
# Subprog ALIMFOOT (TRAIT,NBPOSTE,TYPCUR,CURORI,CURDES,ALIM)            #
#  TRAIT   = Ventes ( 4=livraison , 6=facture , 7=facture de commande)  #
#  NBPOSTE = Nbre de postes maxi du tableau (ex: 10 pour client)        #
#          =   Retour ---> Nbre de postes garnis pour alimenter BASTAB  #
#  TYPCUR  = Type de cours                                              #
#  CURORI  = Devise origine                                             #
#  CURDES  = Devise destination                                         #
#  ALIM    = OUI pour alimenter les mt et % , NON pour ne pas les alim. #
#                                                                       #
# Attention : GLOCALDEV doit être la devise de la société courante      #
#-----------------------------------------------------------------------#
# Retour                                                                #
#  NBPOSTE = Nbre de postes de [F] garnis après tri                     #
#  [F:xxx]INVDTA   no élément de facturation                            #
#  [F:xxx]INVDTAAMT valeur par défaut convertie si en création et zone  #
#                   non garnie par saisie précédente                    #
# ATTENTION : Si le fichier des éléments de facturation est ouvert dans #
#             dans le s/p ce fichier est devenu fichier par défaut      #
# PREREQUIS : L'enregistrement client facture doit être en ligne        #
#########################################################################
Subprog ALIMFOOT (TRAIT,NBPOSTE,TYPCUR,CURORI,CURDES,ALIM)
Value    Integer  TRAIT
Variable Integer  NBPOSTE
Value    Libelle  TYPCUR
Value    Char     CURORI,CURDES,ALIM

Local Char     PROGOBJX    : # pour appel à WOSFI
Local Integer  POSTE       : # pour nbre de postes rééls triés
Local Integer  I, I2
Local Integer  CODTRT      : # code traitement interne
Local Integer  WMLTRI
Local Integer  WMLVAL      : # pour maj valeur par defaut
Local Decimal  COURS       : # pour conversion valeur par défaut
Local Integer  SPSTAT
Local Integer  SFIDIM
If TRAIT=4
    SFIDIM = dim([F:SDH]INVDTA)
Else
    SFIDIM = dim([F:SIV]INVDTA)
Endif
Local Integer  MLXFINUM (SFIDIM )
Local Integer  MLTRI    (SFIDIM )
Local Integer  MLAMTCOD (SFIDIM )
Local Integer  MLVAL    (SFIDIM )
Local Decimal  MLDEFVAL (SFIDIM )
Local Integer  MAMTCOD  (SFIDIM )
Local Decimal  MTBPR

# si le fichier des éléments de facturation est déjà ouvert
# on considère que l'enregistrement "" est alimenté
PROGOBJX = "WOSFI"
Gosub OPEN_SFI From TRTX3CPY: #If clalev([F:SFI])=0 Local File SFOOTINV [SFI] : Endif
Gosub OUVRE  From =PROGOBJX
Gosub DEFAUT From =PROGOBJX
#
Call LECDEV (CURDES) From TRTDIV
#Call COURDEV (CURORI,CURDES,TYPCUR,GHIDATE,COURS,SPSTAT) From TRTDIV

# chgt des postes à partir des éléments de facturation
For [SFI] : # Where WCPY=GSOCIETE
#For [F]
  WMLTRI = 0
  WMLVAL = 0
  Case TRAIT
   When 4 : WMLTRI = [F]DACDLV : WMLVAL = [F]DACBPC+[F]DACORD
   When 6 : WMLTRI = [F]DACINV : WMLVAL = [F]DACBPC+[F]DACORD+[F]DACDLV
   When 7 : WMLTRI = [F]DACINV : WMLVAL = [F]DACBPC+[F]DACORD
  Endcase

  If WMLTRI <> 0
    I += 1
    MLTRI (I-1) = WMLTRI
    MLXFINUM (I-1) = [F]SFINUM
    MLAMTCOD (I-1) = [F]AMTCOD
    If MLAMTCOD (I-1) = 1
      If (find(TRAIT,4,7) & [F]DACORD<>0) | (TRAIT=6 & [F]DACDLV<>0)
         Raz MLDEFVAL (I-1)
      Else
         MLDEFVAL (I-1) = [F]DEFVAL
      Endif
    Else
      If (find(TRAIT,4,7) & [F]DACORD<>0) | (TRAIT=6 & [F]DACDLV<>0)
         Raz MLDEFVAL (I-1)
      Else
         Call CONVERT(GSYSCUR,CURDES,GLOCALDEV,TYPCUR,GHIDATE,[F]DEFVAL,MLDEFVAL(I-1),SPSTAT) From TRTDEV
      Endif
    Endif
    MLVAL (I-1) = WMLVAL
  Endif
Next

Sorta MLTRI , MLXFINUM , MLAMTCOD , MLVAL , MLDEFVAL

For I = 1 To SFIDIM
  If MLTRI (I-1) <> 0
    POSTE += 1
    If POSTE > NBPOSTE : POSTE=NBPOSTE: Break : Endif
    If TRAIT = 4
       [F:SDH]INVDTA (POSTE-1) = MLXFINUM (I-1)
       MAMTCOD (POSTE-1)       = MLAMTCOD (I-1)
       If ALIM="OUI" & MLVAL (I-1) = 0
          [F:SDH]INVDTAAMT (POSTE-1) = MLDEFVAL (I-1)
       Endif
    Else
       [F:SIV]INVDTA (POSTE-1) = MLXFINUM (I-1)
       MAMTCOD (POSTE-1)       = MLAMTCOD (I-1)
       If ALIM="OUI" & MLVAL (I-1) = 0
          [F:SIV]INVDTAAMT (POSTE-1) = MLDEFVAL (I-1)
       Endif
    Endif
  Endif
Next I

NBPOSTE = POSTE

#------------------------------------------------------------------#
# Chargement des valeurs par défaut client en commande             #
#                                          en livraison            #
#                                          en facture              #
#------------------------------------------------------------------#
If ALIM="OUI"
    For I=0 To dim([F:BPC]INVDTA)-1
        If [F:BPC]INVDTA(I)=0 : Break : Endif
        For I2=0 To NBPOSTE-1
            If TRAIT = 4
               If [F:SDH]INVDTA(I2)=[F:BPC]INVDTA(I)
                  MTBPR = [F:BPC]INVDTAAMT(I)
                  If MAMTCOD(I2)=2
                     Call CONVERT(CURORI,CURDES,GLOCALDEV,TYPCUR,GHIDATE,
&                          [F:BPC]INVDTAAMT(I),MTBPR,SPSTAT) From TRTDEV
                  Endif
                  Read [SFI]SFI0=[F:BPC]INVDTA(I)
                  If !fstat & [F:SFI]DACORD<>0
                     Raz MTBPR
                  Endif
                  If MTBPR<>0
                     [F:SDH]INVDTAAMT(I2) = MTBPR
                  Endif
                  Break
               Endif
            Else
               If [F:SIV]INVDTA(I2)=[F:BPC]INVDTA(I)
                  MTBPR = [F:BPC]INVDTAAMT(I)
                  If MAMTCOD(I2)=2
                     Call CONVERT(CURORI,CURDES,GLOCALDEV,TYPCUR,GHIDATE,
&                          [F:BPC]INVDTAAMT(I),MTBPR,SPSTAT) From TRTDEV
                  Endif
                  Read [SFI]SFI0=[F:BPC]INVDTA(I) : # GSOCIETE;[F:BPC]INVDTA(I)
                  If !fstat & ((TRAIT=7 & [F:SFI]DACORD<>0) | (TRAIT=6 & [F:SFI]DACDLV<>0))
                     Raz MTBPR
                  Endif
                  If MTBPR<>0
                     [F:SIV]INVDTAAMT(I2) = MTBPR
                  Endif
                  Break
               Endif
            Endif
        Next I2
    Next I
Endif
End

###########################################################################
#  Sous-programme de garnissage des éléments de facturation               #
#  dans la classe [F:SDH] ou [F:SIV]                                      #
#  avec les valeurs : - commande  --> livraison                           #
#                     - commande  --> facture                             #
#                     - livraison --> facture                             #
#                     - devis     --> facture                             #
#-------------------------------------------------------------------------#
# Subprog ALIMFOOT2 (TRAIT,NBPOSTE,TYPCUR,CURORI,CURDES,INIT)             #
#  TRAIT   = Ventes (4=livraison 6=facture 7=facture cde 9=facture devis) #
#  NBPOSTE = Nbre de postes maxi du tableau (ex: 10 pour livraison)       #
#          =   Retour ---> Nbre de postes garnis pour alimenter BASTAB    #
#  TYPCUR  = Type de cours                                                #
#  CURORI  = Devise origine                                               #
#  CURDES  = Devise destination                                           #
#  INIT    = OUI pour la 1ère commande de la livraison ou de la facture   #
#                pour la 1ère livraison de la facture                     #
#            NON pour les suivantes                                       #
#                                                                         #
# Attention : GLOCALDEV doit être la devise de la société courante        #
#-------------------------------------------------------------------------#
# Retour                                                                  #
#  NBPOSTE = Nbre de postes de [M] garnis après tri                       #
#  [F:xxx]INVDTAAMT valeur par défaut convertie si en création et zone    #
#                   non garnie par saisie précédente                      #
# ATTENTION : Si le fichier des éléments de facturation est ouvert dans   #
#             dans le s/p ce fichier est devenu fichier par défaut        #
# PREREQUIS : Si TRAIT = 4 ou 7 l'enreg cde [F:SOH] doit être en ligne    #
#             Si TRAIT = 6      l'enreg liv [F:SDH] doit être en ligne    #
#             Si TRAIT = 9      l'enreg dev [F:SQH] doit être en ligne    #
###########################################################################
Subprog ALIMFOOT2 (TRAIT,NBPOSTE,TYPCUR,CURORI,CURDES,INIT)
Value    Integer  TRAIT
Variable Integer  NBPOSTE
Value    Libelle  TYPCUR
Value    Char     CURORI,CURDES
Value    Char     INIT

Local Char     PROGOBJX    : # pour appel à WOSFI
Local Integer  POSTE       : # pour nbre de postes rééls triés
Local Integer  I, I2
Local Integer  CODTRT      : # code traitement interne
Local Integer  WMLTRI
Local Decimal  COURS       : # pour conversion valeur par défaut
Local Integer  SPSTAT
Local Integer  SFIDIM
If TRAIT=4
    SFIDIM = dim([F:SDH]INVDTA)
Else
    SFIDIM = dim([F:SIV]INVDTA)
Endif
Local Integer  MLTRI    (SFIDIM)
Local Integer  MLTRFDLY (SFIDIM)
Local Integer  MLTRFINV (SFIDIM)
Local Integer  MLAMTCOD (SFIDIM)
Local Integer  MTRFDLY (SFIDIM)
Local Integer  MTRFINV (SFIDIM)
Local Integer  MAMTCOD (SFIDIM)
Local Decimal  MTBPR

# si le fichier des éléments de facturation est déjà ouvert
# on considère que l'enregistrement "" est alimenté
PROGOBJX = "WOSFI"
Gosub OPEN_SFI From TRTX3CPY : #If clalev([F:SFI])=0 Local File SFOOTINV [SFI] : Endif
Gosub OUVRE  From =PROGOBJX
Gosub DEFAUT From =PROGOBJX
#
Call LECDEV (CURDES) From TRTDIV
#Call COURDEV (CURORI,CURDES,TYPCUR,GHIDATE,COURS,SPSTAT) From TRTDIV

# chgt des postes à partir des éléments de facturation
For [SFI] : # Where WCPY=GSOCIETE
#For [F]
  WMLTRI = 0
  Case TRAIT
   When 4     : WMLTRI = [F]DACDLV : # livraison vente
   When 6,7,9 : WMLTRI = [F]DACINV : # facture vente
  Endcase

  If WMLTRI <> 0
    I += 1
    MLTRI (I-1) = WMLTRI
    MLTRFDLY (I-1) = [F]TRFDLY
    MLTRFINV (I-1) = [F]TRFINV
    MLAMTCOD (I-1) = [F]AMTCOD
  Endif
Next

Sorta MLTRI , MLTRFDLY , MLTRFINV, MLAMTCOD

For I = 1 To SFIDIM
  If MLTRI (I-1) <> 0
    POSTE += 1
    If POSTE > NBPOSTE : POSTE=NBPOSTE: Break : Endif
    MTRFDLY(POSTE-1) = MLTRFDLY (I-1)
    MTRFINV(POSTE-1) = MLTRFINV (I-1)
    MAMTCOD(POSTE-1) = MLAMTCOD (I-1)
  Endif
Next I

NBPOSTE = POSTE

#------------------------------------------------------------------#
# Chargement des valeurs des commandes  en livraison               #
#------------------------------------------------------------------#
If TRAIT = 4
#--CPO 79550 Lors de l'ajout de transfert de nouveaux docs,
#--Remarqué : le test MTRFINV(I2)=2 | (MTRFINV(I2)=1 & [F:SOH]INVSTA=1)
#--est tjs faux car basé sur les champs paramétrage tra,nsfert de la V5
#--et du coup on boucle pour rien
#   For I=0 To dim([F:SOH]INVDTA)-1
#      If [F:SOH]INVDTA(I)=0 : Break : Endif
#      For I2=0 To NBPOSTE-1
#         If [F:SDH]INVDTA(I2)=[F:SOH]INVDTA(I)
#            If MTRFDLY(I2)=2 | (MTRFDLY(I2)=1 & [F:SOH]DLVSTA=1)
#               MTBPR = [F:SOH]INVDTAAMT(I)
#               If MAMTCOD(I2)=2
#                  Call CONVERT(CURORI,CURDES,GLOCALDEV,TYPCUR,GHIDATE,
#&                       [F:SOH]INVDTAAMT(I),MTBPR,SPSTAT) From TRTDEV
#               Endif
#               If INIT = "OUI"
#                  [F:SDH]INVDTAAMT(I2)  = MTBPR
#               Else
#                  # on ajoute uniquement pour un montant
#                  If MAMTCOD(I2)=2 : [F:SDH]INVDTAAMT(I2) += MTBPR : Endif
#               Endif
#               Break
#            Endif
#         Endif
#      Next I2
#   Next I
Endif
#------------------------------------------------------------------#
# Chargement des valeurs des commandes  en facture                 #
#------------------------------------------------------------------#
If TRAIT = 7
#--CPO 79550 Lors de l'ajout de transfert de nouveaux docs,
#--Remarqué : le test MTRFINV(I2)=2 | (MTRFINV(I2)=1 & [F:SOH]INVSTA=1)
#--est tjs faux car basé sur les champs paramétrage tra,nsfert de la V5
#--et du coup on boucle pour rien
#   For I=0 To dim([F:SOH]INVDTA)-1
#      If [F:SOH]INVDTA(I)=0 : Break : Endif
#      For I2=0 To NBPOSTE-1
#         If [F:SIV]INVDTA(I2)=[F:SOH]INVDTA(I)
#            If MTRFINV(I2)=2 | (MTRFINV(I2)=1 & [F:SOH]INVSTA=1)
#               MTBPR = [F:SOH]INVDTAAMT(I)
#               If MAMTCOD(I2)=2
#                  Call CONVERT(CURORI,CURDES,GLOCALDEV,TYPCUR,GHIDATE,
#&                       [F:SOH]INVDTAAMT(I),MTBPR,SPSTAT) From TRTDEV
#               Endif
#               If INIT = "OUI"
#                  [F:SIV]INVDTAAMT(I2)  = MTBPR
#               Else
#                  # on ajoute uniquement pour un montant
#                  If MAMTCOD(I2)=2 : [F:SIV]INVDTAAMT(I2) += MTBPR : Endif
#               Endif
#               Break
#            Endif
#         Endif
#      Next I2
#   Next I
Endif
#------------------------------------------------------------------#
# Chargement des valeurs des livraisons en facture                 #
#------------------------------------------------------------------#
If TRAIT = 6
   For I=0 To dim([F:SDH]INVDTA)-1
      If [F:SDH]INVDTA(I)=0 : Break : Endif
      For I2=0 To NBPOSTE-1
         If [F:SIV]INVDTA(I2)=[F:SDH]INVDTA(I)
            MTBPR = [F:SDH]INVDTAAMT(I)
            If MAMTCOD(I2)=2
               Call CONVERT(CURORI,CURDES,GLOCALDEV,TYPCUR,GHIDATE,
&                        [F:SDH]INVDTAAMT(I),MTBPR,SPSTAT) From TRTDEV
            Endif
            If INIT = "OUI"
               [F:SIV]INVDTAAMT(I2)  = MTBPR
            Else
               # on ajoute uniquement pour un montant
               If MAMTCOD(I2)=2 : [F:SIV]INVDTAAMT(I2) += MTBPR : Endif
            Endif
            Break
         Endif
      Next I2
   Next I
Endif
#------------------------------------------------------------------#
# Chargement des valeurs des devis  en facture                     #
#------------------------------------------------------------------#
If TRAIT = 9
   For I=0 To dim([F:SQH]INVDTA)-1
      If [F:SQH]INVDTA(I)=0 : Break : Endif
      For I2=0 To NBPOSTE-1
         If [F:SIV]INVDTA(I2)=[F:SQH]INVDTA(I)
            MTBPR = [F:SQH]INVDTAAMT(I)
            If MAMTCOD(I2)=2
               Call CONVERT(CURORI,CURDES,GLOCALDEV,TYPCUR,GHIDATE,
&                    [F:SQH]INVDTAAMT(I),MTBPR,SPSTAT) From TRTDEV
            Endif
            If INIT = "OUI"
               [F:SIV]INVDTAAMT(I2)  = MTBPR
            Else
               # on ajoute uniquement pour un montant
               If MAMTCOD(I2)=2 : [F:SIV]INVDTAAMT(I2) += MTBPR : Endif
            Endif
            Break
         Endif
      Next I2
   Next I
Endif

End

#------------------------------------------------------------------#
$ALI_MNTECR
If INIT = "OUI"
   Assign "[M:"+WABMSK+"]INVDTAAMT(I2)" With MTBPR
Elsif INIT = "NON"
   # on ajoute uniquement pour un montant
   If evalue("[M:"+WABMSK+"]AMTCOD(I2)")=2
      Assign "[M:"+WABMSK+"]INVDTAAMT(I2)" With (evalue("[M:"+WABMSK+"]INVDTAAMT(I2)") + MTBPR)
   Endif
Else
   # on enleve uniquement pour un montant
   If evalue("[M:"+WABMSK+"]AMTCOD(I2)")=2
      Assign "[M:"+WABMSK+"]INVDTAAMT(I2)" With (evalue("[M:"+WABMSK+"]INVDTAAMT(I2)") - MTBPR)
   Endif
Endif
Return


# ACA (2009-05-27) Bug 55371 : Livraison de cde et perte élément facturation
################################################################
# FCTRL1STLIV : Controle en cas de suppression d'une livraison
#   ou d'une ligne de livraison, alors qu'il existe un élément
#   pour lequel le transfert commande->livraison est de type
#   première.
#   On avertit si :
#       - Il existe un élément de type "Première" dont la valeur
#            est >= à la valeur sur la commande
#       - Il existe d'autres livraisons liées à cette commande
#       - Pour ces livraisons, l'élément en question est à 0
################################################################
# Parameters E : SOHNUM
# Return       : 1 si OK, 0 si KO
################################################################
Funprog FCTRL1STLIV(SOHNUM)
Value Char SOHNUM

Local Integer OK:OK=1
Local Integer ISFINUMSDH,ISFINUMSOH
Local Char CURSDHNUM(GLONVCR), CURSOHNUM(GLONVCR)
# Liste des éléments déclenchant l'avertissement
Local Char LSTELT(255):LSTELT=""

CURSDHNUM=[F:SDH]SDHNUM
CURSOHNUM=[F:SOH]SOHNUM
# Vaut 1 si un élément de type 1er est >0
Local Integer HAS1STELT : HAS1SELT=0

Gosub OPEN_SFI From TRTX3CPY

Read [F:SOH]SOH0=[L]SOHNUM

For [SFI] Where BRDRUL(2)=2 # M473 - 1ère Livraison
  ISFINUMSDH=find([F:SFI]SFINUM,[M:SDH2]INVDTA) -1
  ISFINUMSOH=find([F:SFI]SFINUM,[F:SOH]INVDTA ) -1
  If ISFINUMSOH>=0 :# FQ 69820 evite d'avoir une erreur sur indice si l'élt n'est pas sur la cde
    If ( ISFINUMSDH>=0 &
&    [M:SDH2]INVDTAAMT(ISFINUMSDH) >0 &
&    [M:SDH2]INVDTAAMT(ISFINUMSDH) >= [F:SOH]INVDTAAMT(ISFINUMSOH) )
      HAS1STELT=1
      LSTELT = LSTELT + "\" + [M:SDH2]SHO(ISFINUMSDH) - ":" - num$([M:SDH2]INVDTAAMT(ISFINUMSDH))
      If [M:SDH2]INVDTATYP(ISFINUMSDH)=3
        LSTELT=LSTELT+"%"
      Else
        LSTELT=LSTELT-[M:SDH1]CUR
      Endif
    Endif
  Endif
Next

# Si on a un élément de type 1er avec une valeur,
#  on regarde si on a une autre livraison concernant la commande
If HAS1STELT=1
    For [SDH] Where SOHNUM=[L]SOHNUM
      If [F:SDH]SDHNUM <> CURSDHNUM
        OK=0
      Endif
    Next
Endif

If OK=0
    # Cette livraison porte au moins un élément de facturation issue d'une commande.
    # Cet élément est avec un type de transfert :
    # Vérifier qu'une autre livraison reçoive bien ces éléments :
    Local Integer AVOK
    Call AVERTIR (mess(335,192,1)- [F:SOH]SOHNUM +"\" +mess(336,192,1)-mess(2,473,1)+"\"+mess(337,192,1)  - LSTELT, AVOK) From GESECRAN
    If (AVOK=2) : OK=1 : Else : OK =0 : Endif
Endif

# On restaure les positions dans les fichiers
Read [F:SDH]SDH0=CURSDHNUM
Read [F:SOH]SOH0=CURSOHNUM

End OK

