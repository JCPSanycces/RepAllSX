#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Update ASHWPAR FOR LOOKUP OF DATA TYPE ADI
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update ASHWPAR for lookup of  DATA TYPE ADI") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub ASHWPARDEF
End





#-------------------#
$ASHWPARDEF
Call ECR_TRACE("Update ASHWPAR" - time$,0) From GESECRAN
Local Char MYVALUE (80)
Local Integer AERROR
AERROR=0
Local Integer AWRITE
AWRITE=0

Local Char TABPTR(250)(1..)
Local Char TABCLA(250)(1..)
Local Char OBJ(250)
Local Integer ISACTX
Local Integer NBCLA


Local File =[L]DOSSIER+".ASHWFLD" [ASWF]
Local File =[L]DOSSIER+".ASHWPAR" [ASWP]
Local File =[L]DOSSIER+".ASHWPAR" [ASWP2]
Local File =[L]DOSSIER+".ASHWPAR" [ASWP3]

 Local File =[L]DOSSIER+".ASHW" [ASW]
 Local File =[L]DOSSIER+".ACLAFLD"      [ACLAF]
 Local File =[L]DOSSIER+".ACLASSE"       [ACLA]
 Local File =[L]DOSSIER+".ACLACOL"       [ACLAC]

Trbegin [ASWP]

Filter [F:ASWP] Where CODPAR="NUMTAB" and CODLNK="ALOOKUP"


For [F:ASWP]
  Read [F:ASW]ASW0 = [F:ASWP]CODREP
  If !fstat
   Call DECODE_PRO([F:ASWP]CODFLD,0,"PRO",[L]DOSSIER,[F:ASWP]CODREP,[F:ASW]ABRCLA,[F:ASW]CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
   If (NBCLA>1 & TABCLA(NBCLA)="") or NBCLA=0
    Break :# error
   Elsif NBCLA>=1
    If TABCLA(NBCLA)=""
     If !ISACTX
      Read [ASWF]ASWF0 = [F:ASWP]CODREP;OBJ
      If !fstat
       # propriété representation
       If [ASWF]CODTYP="ADI"
          # code maj numtab
          Gosub MAJVALEUR
       Endif
      Endif
     Endif
    Else
     Read [ACLA]ACLA0 = TABCLA(NBCLA)
     If !fstat & find([F:ACLA]TYPCLA,3,4)
        Break : # erreur
     Endif
     Read [ACLAF]ACLAF0 = TABCLA(NBCLA);OBJ
     If !fstat
      If [F:ACLAF]CODTYP="" : # pointeur
       Break : # erreur
      Endif
      # propriété classe
      If [ACLAF]CODTYP="ADI"
        # code maj numtab
           # code maj numtab
        Gosub MAJVALEUR
      Endif
     Endif
    Endif
   Elsif NBCLA=-1
    # code activité inactif
    #Call ECR_TRACE("Alias :"-[F:ASWR]ALIAS-" CODPRO = "-[F:ASWP]COD-mess(24,176,1),0) From GESECRAN
   Endif
  Endif
Next

If AERROR= 0
  Commit
 Else
  Rollback
Endif

Close Local File [ACLAF]
Close Local File [ACLA]
Close Local File [ACLAC]
Close Local File [ASW]
Close Local File [ASWF]
Close Local File [ASWP]
Close Local File [ASWP2]
Close Local File [ASWP3]


Return


$MAJVALEUR
AWRITE=0
Read [ASWP3]ASWP0=[F:ASWP]CODREP;3;2;[F:ASWP]CODFLD;"ALOOKUP";1;"NUMTAB"
If fstat=0
  If [F:ASWP3]VALEUR <> ""
    AWRITE=0
    Read [ASWP2]ASWP0=[F:ASWP]CODREP;3;1;[F:ASWP]CODFLD;"ALOOKUP";1;"NUMTAB"
    If fstat=0
      If [F:ASWP2]VALEUR = ""
        [F:ASWP2]VALEUR=[F:ASWP3]VALEUR
        AWRITE=1
      Endif
      If [F:ASWP2]INTVAL<>[F:ASWP2]VALEUR
        [F:ASWP2]INTVAL=[F:ASWP2]VALEUR
        AWRITE=1
      Endif
      If AWRITE=1
        Rewrite [ASWP2]
        If fstat<>0
          AERROR=1
          Call ECR_TRACE([F:ASWP]CODREP +"/3/1/"+[F:ASWP]CODFLD+"/ALOOKUP/1/NUMTAB" - mess(27,125,1),0) From GESECRAN
        Else
          Call ECR_TRACE( [F:ASWP]CODREP +"/3/1/"+[F:ASWP]CODFLD+"/ALOOKUP/1/NUMTAB" -  mess(208,143,1)-time$,0) From GESECRAN
        Endif
      Endif
    Endif
    AWRITE=0
    Read [ASWP2]ASWP0=[F:ASWP]CODREP;3;1;[F:ASWP]CODFLD;"AQUERY";1;"NUMTAB"
    If fstat=0
      If [F:ASWP2]VALEUR = ""
        [F:ASWP2]VALEUR=[F:ASWP3]VALEUR
        AWRITE=1
      Endif
      If [F:ASWP2]INTVAL<>[F:ASWP2]VALEUR
        [F:ASWP2]INTVAL=[F:ASWP2]VALEUR
        AWRITE=1
      Endif
      If AWRITE=1
        Rewrite [ASWP2]
        If fstat<>0
          AERROR=1
          Call ECR_TRACE([F:ASWP]CODREP +"/3/1/"+[F:ASWP]CODFLD+"/AQUERY/1/NUMTAB" - mess(27,125,1),0) From GESECRAN
        Else
          Call ECR_TRACE( [F:ASWP]CODREP +"/3/1/"+[F:ASWP]CODFLD+"/AQUERY/1/NUMTAB" -  mess(208,143,1)-time$,0) From GESECRAN
        Endif
      Endif
    Endif
  Endif
Else
  Call ECR_TRACE([F:ASWP]CODREP +"/3/2/"+[F:ASWP]CODFLD+"/ALOOKUP/1/NUMTAB" - mess(49,125,1),0) From GESECRAN
Endif
Return
