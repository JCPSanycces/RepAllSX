#####################################################################################################
##  Controle del RIB (Cuenta corriente)                                                           ###
#####################################################################################################
Subprog RIB(RIB,SPSTAT)
Variable Char    RIB()
Variable Integer SPSTAT


SPSTAT=0
Local Char CD1(1) , CD2(1) , KEY1(8) , KEY2(10)
Local Integer I , J

##################################################
##  CONTROL DE CUENTA COMPLETA                 ###
##################################################
If RIB="" : Goto F_RIB : Endif

For I=1 To 20
 If mid$(RIB,I,1)>"9" | mid$(RIB,I,1)<"0"
  SPSTAT=2 : Goto F_RIB
 Endif
Next I

CD1=mid$(RIB,9,1)
CD2=mid$(RIB,10,1)
KEY1="37498625"
KEY2="0137498625"

##################################################
##  CONTROL DEL PRIMER DIGITO DE CONTROL       ###
##################################################

J=0
For I=1 To 8
 J += (val(mid$(RIB,I,1)))*(1+val(mid$(KEY1,I,1)))
Next I
J = 11-mod(J,11)
#--- le 23 novembre 99    If J=11 : J=0 : Endif
If J>9 : J = 11-J : Endif

If J <> val(CD1)
 SPSTAT=1 : Goto F_RIB
Endif

##################################################
##  CONTROL DEL SEGUNDO DIGITO DE CONTROL      ###
##################################################
C2=mid$(RIB,11,10)
J=0
For I=11 To 20
 J+=(val(mid$(RIB,I,1)))*(1+val(mid$(KEY2,I-10,1)))
Next I
J = 11-mod(J,11)
#--- le 23 novembre 99    If J=11 : J=0 : Endif
If J>9 : J = 11-J : Endif

If J <> val(CD2)
 SPSTAT=1 : Goto F_RIB
Endif

$F_RIB
End


#####################################################################################################
##  Controle del NIF/CIF                                                                          ###
#####################################################################################################
Subprog SIRET(SIRET,SITE,SPSTAT)                #MOD003
Variable Char SIRET()
Value    Char SITE
Variable Integer SPSTAT
Local Integer  I , J , K , LENG
Local Char CAR(1) , FIRS(1)
If clalev([F:BPRX])=0 : Local File BPARTNER [BPRX] : Endif

##################################################
##  Control del formato del NIF                ###
##################################################
LENG=len(SIRET)
If  SIRET="" : Goto F_SIRET
Elsif LENG <> 9
 SPSTAT=2 : Goto F_SIRET
Endif
FIRS=left$(SIRET,1)
If FIRS>="A" & FIRS<="Z"
 For I = 2 To LENG
  CAR=mid$(SIRET,I,1)
  If (CAR>="A" & CAR<="Z") | (CAR>="0" & CAR<="9") : Goto NEX
  Else
   SPSTAT=2 : Break
  Endif
$NEX
 Next I
Endif
If SPSTAT : Goto F_SIRET : Endif

##################################################
##  Control de NIF/CIF duplicado               ###
##################################################

If !GIMPORT and GPRODUIT=0   ######## jcc 08/03/11 evitar control en Abel
 Filter [BPRX] Where CRN=SIRET Order By Key CLE=CRN
 For [BPRX]CLE
 If dim([M]BPRNUM)>0
     If !fstat and [BPRX]BPRNUM<>[M]BPRNUM
     GMESSAGE="El Tercero"-[BPRX]BPRNUM- "tiene el mismo NIF/CIF"-[BPRX]BPRNAM
     GERR=3
     Break
     Endif
 Endif
 If dim([M]BPCNUM)>0
     If !fstat and [BPRX]BPRNUM<>[M]BPCNUM
     GMESSAGE="El Tercero"-[BPRX]BPRNUM- "tiene el mismo NIF/CIF"-[BPRX]BPRNAM
     GERR=3
     Break
     Endif
 Endif
  If dim([M]BPSNUM)>0
     If !fstat and [BPRX]BPRNUM<>[M]BPSNUM
     GMESSAGE="El Tercero"-[BPRX]BPRNUM- "tiene el mismo NIF/CIF"-[BPRX]BPRNAM
     GERR=3
     Break
     Endif
 Endif
  If dim([M]BPTNUM)>0 and dim([M]BPCNUM)<0
     If dim([M]BPTNUM)>0 and dim([M]BPSNUM)<0                #MOD005
       If !fstat and [BPRX]BPRNUM<>[M]BPTNUM
         GMESSAGE="El Tercero"-[BPRX]BPRNUM- "tiene el mismo NIF/CIF"-[BPRX]BPRNAM
         GERR=3
         Break
       Endif
     Endif                                                    #MOD005
 Endif
  If dim([M]REPNUM)>0 and dim([M]BPCNUM)<0
     If dim([M]REPNUM)>0 and dim([M]BPSNUM)<0                 #MOD005
       If !fstat and [BPRX]BPRNUM<>[M]REPNUM
       GMESSAGE="El Tercero"-[BPRX]BPRNUM- "tiene el mismo NIF/CIF"-[BPRX]BPRNAM
       GERR=3
       Break
       Endif
     Endif                                                     #MOD005
 Endif

Next
Endif

##################################################
##  ÃƒÃ‚                                         ###
##################################################
If num$(val(FIRS)) = FIRS or FIRS="M" or (FIRS>="X" & FIRS<="Z")   # MOD04
 Gosub DNI
Else
 Gosub NIF
Endif

$F_SIRET
End

##################################################
##  CONTROL DEL NIF                            ###
##################################################
$NIF
##  CONTROL DE LA PRIMERA LETRA

#If FIRS="X" | (FIRS>="A" & FIRS<="H") | (FIRS>="P" & FIRS<="S")                # MOD01

#If (FIRS>="A" & FIRS<="H") | (FIRS>="P" & FIRS<="S") | (FIRS="N") | (FIRS="U") # MOD02
#&     | (FIRS="J") | (FIRS="V")  | (FIRS="Q") | (FIRS="W")                     # MOD02
If (FIRS>="A" & FIRS<="H") | (FIRS>="P" & FIRS<="S") | (FIRS>="M") & (FIRS<="N")
&     | (FIRS="J") | (FIRS>="U" & FIRS<="Y")

 Goto NIF2
Else
 SPSTAT=1 : Return
Endif

$NIF2
## CONTROL DEL NIF

J = 0
For I = 2 To LENG-1 Step 2
 CAR=mid$(SIRET,I,1)
 If num$(val(CAR)) <> CAR
  SPSTAT=1 : Break
 Endif
 Case CAR
  When "1" : J+=2
  When "2" : J+=4
  When "3" : J+=6
  When "4" : J+=8
  When "5" : J+=1
  When "6" : J+=3
  When "7" : J+=5
  When "8" : J+=7
  When "9" : J+=9
 Endcase
 If I < 8
  J += val(mid$(SIRET,I+1,1))
 Endif
Next I
If SPSTAT : Return : Endif
J=10-mod(J,10)
If J=10 : J=0 : Endif

CAR=right$(SIRET,LENG)
K=val(CAR)
If num$(K) = CAR & K=J
 Return
Endif

If CAR>="A" & CAR<="J"
 Case CAR
  When "A" : I=1
  When "B" : I=2
  When "C" : I=3
  When "D" : I=4
  When "E" : I=5
  When "F" : I=6
  When "G" : I=7
  When "H" : I=8
  When "I" : I=9
  When "J" : I=0
 Endcase
 If I<>J : SPSTAT=1 : Endif
Else
 SPSTAT=1
Endif

Return

##################################################
##  CONTROL DEL DNI                            ###
##################################################
$DNI
CAR=right$(SIRET,LENG)
If CAR<"A" | CAR>"Z"
 SPSTAT=1 : Return
Endif
#If FIRS = "X" or FIRS = "M"                           # MOD02
If FIRS = "X" or FIRS = "M" or FIRS="Y" or FIRS="Z"    # MOD04
    J = val(mid$(SIRET,2,LENG-1))                      # MOD01
Else                                                   # MOD02
    J=val(left$(SIRET,LENG-1))
Endif
If FIRS="Y": J=J+10000000: Endif                      # MOD04
If FIRS="Z": J=J+20000000: Endif                      # MOD04

I=mod(J,23)
Case CAR
 When "T" : J=0
 When "R" : J=1
 When "W" : J=2
 When "A" : J=3
 When "G" : J=4
 When "M" : J=5
 When "Y" : J=6
 When "F" : J=7
 When "P" : J=8
 When "D" : J=9
 When "X" : J=10
 When "B" : J=11
 When "N" : J=12
 When "J" : J=13
 When "Z" : J=14
 When "S" : J=15
 When "Q" : J=16
 When "V" : J=17
 When "H" : J=18
 When "L" : J=19
 When "C" : J=20
 When "K" : J=21
 When "E" : J=22
 When "I" : J=23
Endcase
If J<>I
 SPSTAT=1
Endif

Return


#####################################################################################################
##  Contrle Nr TVA (VAT identification )              ###
#####################################################################################################
Subprog TVA(TVA,SPSTAT)
Variable Char    TVA()
Variable Integer SPSTAT

SPSTAT=0
# Suggestion SAM 104724
  Local Char NUMTVA(9)

  If TVA<>"" and dim([M]CRN)>0   # SAM 118792
    If left$(TVA,2)="ES"
      NUMTVA=right$(TVA,3)
      If len(NUMTVA) <> 9    : SPSTAT=2
#      Elsif [M]CRN<>NUMTVA: SPSTAT=2
      Elsif [M]CRN<>"" and [M]CRN<>NUMTVA: SPSTAT=2  # SAM 110589
      Endif
    Else
      SPSTAT=2
    Endif
  Endif
# Suggestion SAM 104724

End

