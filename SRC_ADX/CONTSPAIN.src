###########################################################################################################
###########################################################################################################
###########################################################################################################

#$CIF
K=0
CIF = SIRET
For I=2 To 8
 CAR = mid$(CIF,I,1)
 If num$(val(CAR)) = CAR
  J = val(CAR)
 Elsif find(CAR,"A","B","C","D","E","F","G","H","I","J","P","Q","S")
   Gosub TRANSNUM
 Else
  SPSTAT = 1 : Break
 Endif
 If !mod(I,2)
  J = 2*J
  If J>9
   J = 1+mod(J,10)
  Endif
 Endif
 K += J
Next I
If SPSTAT>0 : Return : Endif
I = mod(K,10)
If !I
 K = 0
Else
 K = 10-I
Endif
If val(right$(CIF,9))<>K
 SPSTAT = 1 : Return
Endif
Return

$TRANSNUM
Case CAR
 When "A" : J = 1
 When "B" : J = 2
 When "C" : J = 3
 When "D" : J = 4
 When "E" : J = 5
 When "F" : J = 6
 When "G" : J = 7
 When "H" : J = 8
 When "I" : J = 9
 When "J" : J = 0
Endcase
Return


#$DNI
DNI=SIRET
CHIFFRE=num$(mod(val(right$(DNI,2)),23))
Gosub VERF_LETTRE
If LETTRE<>left$(DNI,8)
 SPSTAT=1 : Return
Endif
Return

$VERF_LETTRE
Case CHIFFRE
 When "0"  : LETTRE="T"
 When "1"  : LETTRE="R"
 When "2"  : LETTRE="W"
 When "3"  : LETTRE="A"
 When "4"  : LETTRE="G"
 When "5"  : LETTRE="M"
 When "6"  : LETTRE="Y"
 When "7"  : LETTRE="F"
 When "8"  : LETTRE="P"
 When "9"  : LETTRE="D"
 When "10" : LETTRE="X"
 When "11" : LETTRE="B"
 When "12" : LETTRE="N"
 When "13" : LETTRE="J"
 When "14" : LETTRE="Z"
 When "15" : LETTRE="S"
 When "16" : LETTRE="Q"
 When "17" : LETTRE="V"
 When "18" : LETTRE="H"
 When "19" : LETTRE="L"
 When "20" : LETTRE="C"
 When "21" : LETTRE="K"
 When "22" : LETTRE="E"
 When "23" : LETTRE="T"
Endcase
Return

