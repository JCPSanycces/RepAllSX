#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion objet APP
Raz GPILOBJ
Call OBJET("APP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE    
 When "VERIF_CRE"     : Gosub VERIF_CRE
 When "LIENS"         : Gosub LIENS
 When "AVANT_MODFIC"  : Gosub AVANT_MODFIC
 When "SEL_LISTE"     : Gosub SEL_LISTE
 When "FIN_LISTE"     : Gosub FIN_LISTE
 When default
Endcase
Return

$OUVRE
Local Integer W_APPTYP
Local Integer W_I
Return

$AVANT_MODFIC
W_APPTYP=[M:APP0]APPTYP
Return

$VERIF_CRE
W_APPTYP=[M:APP0]APPTYP
Return

$LIENS
W_APPTYP=[F:APP]APPTYP    
Call TEXTE([M:APP0]APPDES,[M:APP0]ZAPPDES) From OBJDIV
For W_I = 0 To [M:APP0]PARNBR-1
 Call TEXTE([M:APP0]PARDES(W_I),[M:APP0]ZPARDES(W_I)) From OBJDIV
Next
Gosub $STATE_CMPTAB    # tableau pour les composants
Return

$SEL_LISTE
Local Integer CHANGE
Local Char SAV1(250)
Case LISTE
 When "SELMEN2"   :
  SAV1 = VALEUR
  If left$(VALEUR,1)='"' 
   CHANGE = 1
   VALEUR = mid$(VALEUR,2,len(VALEUR)-2)
  Elsif left$(VALEUR,1)="'"
   CHANGE = 2
   VALEUR = mid$(VALEUR,2,len(VALEUR)-2)
  Else
   CHANGE = 3
  Endif
  Gosub SEL_LIGNE_MENU
Endcase
Return

$FIN_LISTE
Case LISTE
 When "SELMEN2"
  If status <> 7
   If find(CHANGE,1,3)
    VALEUR = '"'+VALEUR+'"'
   Elsif CHANGE = 2
    VALEUR = "'"+VALEUR+"'"
   Endif
  Else
   VALEUR = SAV1
  Endif
Endcase
Return

$SEL_LIGNE_MENU
If val(PARAM(1)) <> 0
 If PARAM(2) = "ADI" 
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  Local Char TEXTAX(250)
  For [ADI] Where NUMTAB = val(PARAM(1))
   I += 1
   TEX(I) = [ADI]CODE
   Call LECTEXTRA([L]TEXTAX,"ATABDIV","LNGDES",num$([ADI]NUMTAB),[ADI]CODE) From ATEXTRA
   TEXTE(I) = [ADI]CODE-":"-[L]TEXTAX
   [L]TEXTAX = ""
  Next
  NBTEX = I
  Call TITOBJ("ADV","!",TIT) From CONTOBJ
  TIT  = mess(12,123,1)-TIT : # Sélection
 Else
  Local Integer NOLIB
  NOLIB = val(PARAM(1))
  If NOLIB = 2939 : # Représentation graphes
   NBTEX = 3
   TEX(1) = "XMONTH"
   TEX(2) = "XWEEK"
   TEX(3) = "XDAY"
   TEXTE(1) = TEX(1)-"("-mess(4,NOLIB,1)-")"
   TEXTE(2) = TEX(2)-"("-mess(5,NOLIB,1)-")"
   TEXTE(3) = TEX(3)-"("-mess(6,NOLIB,1)-")"
   TIT = mess(NOLIB-200,200,1)
   Return
  Elsif NOLIB = 2933 : # Graphe par défaut
   NBTEX = 4
   TEX(1) = "XBAR"
   TEX(2) = "XLINE" 
   TEX(3) = "XAREA"
   TEX(4) = "XPIE"
   For I=1 To NBTEX
    TEXTE(I) = TEX(I)-"("-mess(I,NOLIB,1)-")"
   Next
   TIT = mess(NOLIB-200,200,1)
   Return
  Elsif NOLIB = 2954 : # Graphe par défaut
   NBTEX = 16
   TEX(1) = "XBAR"
   TEX(2) = "XLINE" 
   TEX(3) = "XAREA"
   TEX(4) = "XPIE"
   TEX(5) = "XBARM"
   TEX(6) = "XLINEM" 
   TEX(7) = "XAREAM"
   TEX(8) = "XPIEM"
   TEX(9) = "XBARCU"
   TEX(10) = "XLINECU" 
   TEX(11) = "XAREACU"
   TEX(12) = "XPIECU"
   TEX(13) = "XBARCO"
   TEX(14) = "XLINECO" 
   TEX(15) = "XAREACO"
   TEX(16) = "XPIECO"
   For I=1 To NBTEX
    TEXTE(I) = TEX(I)-"("-mess(I,NOLIB,1)-")"
   Next
   TIT = mess(NOLIB-200,200,1)
   Return
  Elsif NOLIB = 2929 : # Graphes multiples
   NBTEX = 2
   TEX(1) = "XPERSO"
   TEX(2) = "XPIEM"
   For I=1 To NBTEX
    TEXTE(I) = TEX(I)-"("-mess(I,NOLIB,1)-")"
   Next
   TIT = mess(NOLIB-200,200,1)
   Return
  Elsif NOLIB=0
   OK=0
  Elsif NOLIB<100
   TIT = mess(NOLIB,0,1)
  Else
   TIT = mess(NOLIB-200,200,1)
  Endif
  NBTEX = len(mess(0,NOLIB,1))
  For I=1 To NBTEX
   TEX(I) = num$(I)
   TEXTE(I) = mess(I,NOLIB,1)
  Next I
 Endif
Endif
Return
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Etat tableau pour les composants
$STATE_CMPTAB
If W_APPTYP=1 : Effzo [M:APP0]20 : Grizo [M:APP0]20 : Else : Actzo [M:APP0]20 : Endif
Return

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Copie (ACOPIE)
# OBJET = "titre "
# TABLE  1er composante clé     ex: "1"
# TABLE2  2ième                 ex: "AGD" 
$TRTCOP
If [M]DOSORG=nomap 
 Local File APTLPAR  [APP1] 
 Local File ATEXTE   [ATX1] 
Else 
 Local File =[M]DOSORG+".APTLPAR"  [APP1]
 Local File =[M]DOSORG+".ATEXTE"   [ATX1] 
Endif 
If [M]DOSDES=nomap 
 Local File APTLPAR  [APP2] 
 Local File ATEXTE   [ATX2] 
Else 
 Local File =[M]DOSDES+".APTLPAR"  [APP2]
 Local File =[M]DOSDES+".ATEXTE"   [ATX2]
Endif 
OK = 1
Read [APP1]APP0 = val(TABLE);TABLE2
If fstat
  OK=0
  Call RSTA("APP",TABLE+TABLE2) From GLOCK 
  Goto FINALLY
Endif

If GTRACE=""
 Read [APP2]APP0 = val(TABLE);TABLE2
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Goto FINALLY : Endif
 Endif
Endif

If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif

$FINALLY
Close Local File [APP1], [ATX1]
&              , [APP2],  [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [APP2] ,[ATX2]
 Delete [APP2]APP0 = val(TABLE);TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".APTLPAR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("APP2","") From GLOCK : Goto AB_TR_COP
 Endif
 #
 Local integer W_BCL1, W_BCL2
 For W_BCL=0 to 0
  [F:APP2] = [F:APP1]
  Call COPTEXTE([F:APP1]APPDES,[F:APP2]APPDES) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:APP2]UPDUSR)>0 : [F:APP2]UPDUSR = GUSER : Endif
  If dim([F:APP2]UPDDAT)>0 : [F:APP2]UPDDAT = date$ : Endif
  If dim([F:APP2]UPDTIM)>0 : [F:APP2]UPDTIM = time  : Endif
  For W_BCL2=0 to (dim([F:APP2]PARDES)-1)
    Call COPTEXTE([F:APP1]PARDES(W_BCL2),[F:APP2]PARDES(W_BCL2)) From OBJDIV
If GOK<1 : Break 2 : Endif
  Next
  Write [APP2]
  If fstat
   GOK=0 : Call FSTA("APP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#
# Sous-programme de transcodage pour les graphes multiples
# Ecrit par Dom
# Paramètres de départ : FGCSER1,FGCSER2,FGCSER3 et FGCCOM1,FGCCOM2,FGCCOM3

Subprog TRANS_GRAPH(FGCSER1,FGCSER2,FGCSER3,FGCCOM1,FGCCOM2,FGCCOM3,RESULT)
Value Char FGCSER1(),FGCSER2(),FGCSER3(),FGCCOM1(),FGCCOM2(),FGCCOM3()
Variable Char RESULT()

Local Char FGC(100),FGCOM(100)
Local Integer II

  For FGC=FGCSER1,FGCSER2,FGCSER3
    FGCOM=FGCCOM1 : FGCCOM1=FGCCOM2 : FGCCOM2=FGCCOM3
    FGC=vireblc(ctrans(FGC,'"',' '),4)
    While FGC<>""
        II=instr(1,FGC,";")
        II+=(II=0)*(len(FGC)+1)
        RESULT+=string$(RESULT<>"",";")+left$(FGC,II-1)+","
        FGC=right$(FGC,II+1)
        RESULT+=vireblc(mid$("b  bcubcol  lculcoa  acuaco",3*max(val(vireblc(ctrans(FGCOM,'"',' '),4)),1)-2,3),2)
    Wend
  Next
  RESULT='"'+RESULT+'"'
End
            

##########################################################################################
######    Etiquettes du masques
##########################################################################################
Subprog AM_APPTYP(VALEUR)
Variable Integer  VALEUR
Raz [M]APPCOD   # Pour initialiser avec la valeur par défaut
# - - - - - - - - - - - - - - - - - - - - - - - - -
W_APPTYP=VALEUR    # ! repris ds les gosubs
# Etat du tableau pour les composants
    Gosub $STATE_CMPTAB From SUBAPP    
End

Subprog C_PARCOD(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]PARCOD) From OBJDIV
End

Subprog AM_SRCCODLNK(VALEUR)
Variable Char    VALEUR()
End

Subprog AV_SRCDESLNK(VALEUR)
Variable Char     VALEUR
Call LECTEXTRA(VALEUR,"ATABDIV","LNGDES","90",num$([M]SRCCODLNK(indice))) From ATEXTRA
End
 
Subprog C_PARNOLIB(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]OBJLIEN="ADI"
 If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
 Read [ADI]CODE = VALEUR
 If fstat
  GMESSAGE = mess(83,123,1) : # Valeur incorrecte
  mkstat = 2
 Endif
Else
 If VALEUR<1 | (VALEUR>99 & VALEUR<201)
  GMESSAGE = mess(5,176,1) : # No menu local incorrect
  mkstat = 2
 Elsif mess(0,VALEUR,1)=""
  GMESSAGE = mess(98,123,1) :  # Menu local non défini
  mkstat = 2
 Endif
Endif
End


Subprog AS_PARLNG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]FORTYP<>"" | [F:ATY]LNGTYP<>0 | [F:ATY]TYPTYP=1 | [F:ATY]TYPTYP=8 : mkstat=1 : End : Endif
End

Subprog D_PARLNG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
If !fstat & ([F:ATY]FORTYP="" | [F:ATY]LNGTYP=0) : # S'il s'agit d'un type de donnée standard
 Case [F:ATY]TYPTYP
  When 1       : VALEUR=15  : # Libellé
  When 2       : VALEUR=4   : # Entier Court
  When 3       : VALEUR=8   : # Entier Long
  When 4       : VALEUR=9.2 : # Décimal
  When 7       : VALEUR=10  : # Alphanumérique
 Endcase
Endif
End

######################################################################################
Subprog C_PARLNG(VALEUR)
Variable Decimal VALEUR
#If VALEUR=0 : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
Local Decimal ENTIER , DECIM
ENTIER = int(VALEUR)
DECIM  = 10*(VALEUR-ENTIER)
While DECIM<>int(DECIM)
 DECIM *= 10
Wend
Case [F:ATY]TYPTYP
 When 1 : If DECIM<>0 | ENTIER>20 : mkstat=1 : Endif : # Libellé
 When 2 : If DECIM<>0 | ENTIER>4 : mkstat=1 : Endif  : # Entier court
 When 3 : If DECIM<>0 | ENTIER>8 : mkstat=1 : Endif  : # Entier long
 When 4 : If DECIM+ENTIER<1 | DECIM+ENTIER>32 : mkstat=1 : Endif : # DCB
 When 7 : If DECIM<>0 | ENTIER>250 : mkstat=1 : Endif             : # Char
 When 8 : If DECIM<>0 | !find(ENTIER,4,6,8) : mkstat=1 : Endif   : # Date
Endcase
If mkstat : GMESSAGE = mess(111,123,1) : Endif : # Longueur incorrecte
End

######################################################################################
Subprog AS_PARNOLIB(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M:APP0]PARTYP(nolign-1),"") From CONTOBJ
If ([F:ATY]TYPTYP<>1 | [F:ATY]NOLIB<>0) & [F:ATY]OBJLIEN<>"ADI" : mkstat=1 : End : Endif
End

######################################################################################
Subprog AP_PARTYP(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
 Raz [M:APP0]PARLNG(nolign-1) : Raz [M:APP0]PARNOLIB(nolign-1)
 Grizo [M:APP0]PARLNG(nolign-1)
 Grizo [M:APP0]PARNOLIB(nolign-1)
Else
 Actzo [M:APP0]PARLNG(nolign-1)
 Actzo [M:APP0]PARNOLIB(nolign-1)
Endif
End

######################################################################################
Subprog IB_PARDEFVAL
If clalev([F:ATY])=0 : Local File ATYPE  [ATY] : Endif
Call LECTURE("ATY",[M:APP0]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]OBJLIEN<>""  & [F:ATY]OBJLIEN = [M:APP0]PARTYP(nolign-1) & [M:APP0]PARTYP(nolign-1)  <> "ADI"
 GBOUT4 =""
Elsif [M:APP0]PARNOLIB(nolign-1) > 0
 GBOUT5 = ""
Else
 GBOUT4 = ""
 GBOUT5 = ""
Endif
End

######################################################################################
Subprog B5_PARDEFVAL(VALEUR)
Variable Char    VALEUR()
Local Char    PARAM(250)(1..20),SAV1(250)
Local Integer CHANGE
SAV1 = VALEUR
PARAM(1) = [M:APP0]PARTYP(nolign-1)
If left$(VALEUR,1)='"' 
 CHANGE = 1
 VALEUR = mid$(VALEUR,2,len(VALEUR)-2)
Elsif left$(VALEUR,1)="'"
 CHANGE = 2
 VALEUR = mid$(VALEUR,2,len(VALEUR)-2)
Elsif VALEUR = ""
 CHANGE = 3
Endif
Call S_TAB_CHAR(VALEUR,PARAM,"SELOBJ","SELOBJ","") From GACTION
If status <> 7
 If find(CHANGE,1,3)
  VALEUR = '"'+VALEUR+'"'
 Elsif CHANGE = 2
  VALEUR = "'"+VALEUR+"'"
 Endif
Else
 VALEUR = SAV1
Endif
End

