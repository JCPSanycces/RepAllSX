## Etiquette ajoutée par le superviseur (écran DEBREGNAT) 21/10/2008 13:41:33 (CPO)
######################################################################################
Subprog AM_EECSCH(VALEUR)
Variable Char    VALEUR()

# FGR 17/11/2013 : X3SUIVI71937 (début) old
#If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
#If VALEUR <> ""
#    Read [ADI]=15;VALEUR
#    If !fstat
#        [M]FLUX=[F:ADI]N1
#        Diszo [M]FLUX
#        If [M]VALSTO=0
#            [M]VALSTO=[F:ADI]N2
#            Affzo [M]VALSTO
#        Endif
#    Endif
#Else
#    [M]FLUX=4 :# Aucune valeur
#    If [M]EECNAT<>"" : Actzo [M]FLUX : Endif
#Endif
# FGR 17/11/2013 : X3SUIVI71937 (fin)

Local Integer IRET

  If !clalev([F:TSC]) : Local File TABEECSCH [TSC] : Endif
  If VALEUR <> ""
    Call LEC_TSC_LEG(GCURLEG,VALEUR,IRET) From TRTLECLEG
    If !IRET Then
      [M]FLUX=[F:TSC]FLUX
      Diszo [M]FLUX
      If [M]VALSTO=0
        [M]VALSTO=[F:TSC]VALSTO
        Affzo [M]VALSTO
      Endif
    Endif
  Else
    [M]FLUX=4 :# Aucune valeur
    If [M]EECNAT<>"" : Actzo [M]FLUX : Endif
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran DEBREGNAT) 21/10/2008 13:43:21 (CPO)
######################################################################################
Subprog AM_EECSCHR(VALEUR)
Variable Char    VALEUR()

# FGR 17/11/2013 : X3SUIVI71937 (début) old
#If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
#If VALEUR <> ""
#  Read [ADI]=15;VALEUR
#  If !fstat : [M]FLUXREGUL=[F:ADI]N1 : Diszo [M]FLUXREGUL : Endif
#Else
#    [M]FLUXREGUL=4 :# Aucune valeur
#    If [M]EECNATR<>"" : Actzo [M]FLUXREGUL : Endif
#Endif
# FGR 17/11/2013 : X3SUIVI71937 (fin)

Local Integer IRET

  If !clalev([F:TSC]) : Local File TABEECSCH [TSC] : Endif
  If VALEUR <> ""
    Call LEC_TSC_LEG(GCURLEG,VALEUR,IRET) From TRTLECLEG
    If IRET Then
      [M]FLUXREGUL=[F:TSC]FLUX
      Diszo [M]FLUXREGUL
    Endif
  Else
    [M]FLUXREGUL=4 :# Aucune valeur
    If [M]EECNATR<>"" : Actzo [M]FLUXREGUL : Endif
  Endif
End

