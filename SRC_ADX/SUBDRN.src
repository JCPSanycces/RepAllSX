#--CPO 71937 Utilisation de EECNAT et EECSCH déclinées
GCURLEG = [F:DRN]LEG
GGRPFCY = [F:DRN]GRP
#--/CPO

#If dim([M]EECSCH)>0
  If [M]EECSCH <> ""
    #Read [ADI]=15;[M]EECSCH
    #If !fstat : [M]FLUX=[F:ADI]N1
    #Else
    #  [M]FLUX=4
    #Endif
    Affzo [M]FLUX
    If [M]FLUX>0 : Diszo [M]FLUX : Endif
  Else
    If [M]EECNAT<>"" : Actzo [M]FLUX : Endif
  Endif
  If [M]EECSCHR <> ""
    #Read [ADI]=15;[M]EECSCHR
    #If !fstat : [M]FLUXREGUL=[F:ADI]N1
    #Else
    #  [M]FLUXREGUL=4
    #Endif
    Affzo [M]FLUXREGUL
    If [M]FLUXREGUL>0 : Diszo [M]FLUXREGUL : Endif
  Else
    If [M]EECNATR<>"" : Actzo [M]FLUXREGUL : Endif
  Endif
#Endif

Return
