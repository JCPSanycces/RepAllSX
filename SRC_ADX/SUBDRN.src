Call CTL_COHERENCE_GRPS([M:DRN]EECSCH,VALEUR,[M:DRN]EECSCHR,[M:DRN]EECNATR,WRET)
If WRET : mkstat=2 : Endif

End
#--CPO 71937 Utilisation de EECNAT et EECSCH déclinées
