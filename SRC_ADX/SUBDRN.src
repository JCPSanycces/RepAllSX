######################################################################################
Subprog AS_FLUX(VALEUR)
Variable Integer VALEUR
# pas de type de flux "Introduction + Expédition"
GMENLOC(3)=1 : #GMENLOC(4)=1
If ([M]EECNAT="" and [M]EECSCH="") : mkstat=2 : Endif

End
######################################################################################
Subprog AS_FLUXREGUL(VALEUR)
Variable Integer VALEUR
# pas de type de flux "Introduction + Expédition"
GMENLOC(3)=1 : #GMENLOC(4)=1
If ([M]EECNATR="" and [M]EECSCHR="") : mkstat=2 : Endif

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran DEBREGNAT) 10/02/2009 10:44:30 (CPO)
######################################################################################
Subprog C_FLUX(VALEUR)
Variable Integer VALEUR
If VALEUR=3 : mkstat=2 : Endif
If VALEUR=4 and [M]EECSCH<>"" : mkstat=2 : Endif
If VALEUR=4 and [M]EECNAT<>"" : mkstat=2 : Endif

End
#-------------------------------------------------------------------------------------
Subprog AM_EECNAT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M]EECSCH="" : Actzo [M]FLUX : Endif
If VALEUR=""  and [M]EECSCH="" : Raz   [M]FLUX : Affzo [M]FLUX : Endif

End
#-------------------------------------------------------------------------------------
Subprog C_FLUXREGUL(VALEUR)
Variable Integer VALEUR
If VALEUR=3 : mkstat=2 : Endif
If VALEUR=4 and [M]EECSCHR<>"" : mkstat=2 : Endif
If VALEUR=4 and [M]EECNATR<>"" : mkstat=2 : Endif

End
#-------------------------------------------------------------------------------------
Subprog AM_EECNATR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M]EECSCHR="" : Actzo [M]FLUXREGUL : Endif
If VALEUR=""  and [M]EECSCHR="" : Raz   [M]FLUXREGUL : Affzo [M]FLUXREGUL : Endif

End
