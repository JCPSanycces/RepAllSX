$ACTION
Case ACTION
 When "OUVRE"		: Gosub OUVRE    :#--CPO 71937 Utilisation de EECNAT et EECSCH déclinées
 When "SETBOUT" : Gosub SETBOUT
 When "RAZCRE"  : Gosub RAZCRE
 When "LIENS"   : Gosub LIENS
 When "AFFMASK" : Gosub AFFMASK
 When "INICRE"  : Gosub CONTROLE_COHERENCE :#--CPO 71937 Contrôle global de cohérence avant enregistrement
 When "INIMOD"  : Gosub CONTROLE_COHERENCE :#--CPO 71937 Contrôle global de cohérence avant enregistrement
 When Default
Endcase

Return
######################################################################################
$OUVRE
#--CPO 71937 Utilisation de EECNAT et EECSCH déclinées
If clalev([F:TSC])=0 : Local File TABEECSCH [TSC] : Endif
If clalev([F:TEC])=0 : Local File TABEECNAT [TEC] : Endif

Return
######################################################################################
$SETBOUT
#----- Objet à plus de 2 éléments de clé : ajout de la touche suppression si autorisé -----#
If CLECUR & !GHISTO  CHAINE+="A" : Endif
#----- Si suppression non autorisée, grisage du bouton -----#
If GREP<>"C"
  GBIDC2="S" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2  Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
Endif
#----- Bouton copie
If CLECUR=0 | GREP<>""
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

Return
######################################################################################
$LIENS
#MAE, bg 75962, on ne lit pas la table diverse mais on lit la table DEBREGNAT
