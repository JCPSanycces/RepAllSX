If WRET : mkstat=2 : Endif

End
######################################################################################
#--CPO 71937 Utilisation de EECNAT et EECSCH déclinées
Subprog CTL_COHERENCE_GRPS(PEECSCH,PEECNAT,PEECSCHR,PEECNATR,PRET)
Value Char PEECSCH
Value Char PEECNAT
Value Char PEECSCHR
Value Char PEECNATR
Variable Integer PRET

Local Integer IRET
Local Char GRP_SCH,GRP_SCHR,GRP_NAT,GRP_NATR

If clalev([F:TSC])=0  : Local File TABEECSCH  [TSC] : Endif
If clalev([F:TEC])=0  : Local File TABEECNAT  [TEC] : Endif

#--Lecture groupe de EECSCH
Call LEC_TSC_LEG(GCURLEG,PEECSCH,IRET) From TRTLECLEG
If IRET : Raz [F:TSC] : Endif
GRP_SCH = [F:TSC]SOC
#--Lecture groupe de EECSCHR
Call LEC_TSC_LEG(GCURLEG,PEECSCHR,IRET) From TRTLECLEG
If IRET : Raz [F:TSC] : Endif
GRP_SCHR = [F:TSC]SOC
#--Lecture groupe de EECNAT
Call LEC_TEC_LEG(GCURLEG,PEECNAT,IRET) From TRTLECLEG
If IRET : Raz [F:TEC] : Endif
GRP_NAT = [F:TEC]SOC
#--Lecture groupe de EECNATR
Call LEC_TEC_LEG(GCURLEG,PEECNATR,IRET) From TRTLECLEG
If IRET : Raz [F:TSC] : Endif
GRP_NATR = [F:TEC]SOC

#  Call CTLGFYGRP(GRP_SCH ,GRP_SCHR,PRET) From TRTVENCTL
#  If PRET : End : Endif
#  Call CTLGFYGRP(GRP_SCH ,GRP_NAT ,IRET) From TRTVENCTL
#  If PRET : End : Endif
#  Call CTLGFYGRP(GRP_SCH ,GRP_NATR,IRET) From TRTVENCTL
#  If PRET : End : Endif
#  Call CTLGFYGRP(GRP_SCHR,GRP_NAT ,IRET) From TRTVENCTL
#  If PRET : End : Endif
#  Call CTLGFYGRP(GRP_SCHR,GRP_NATR,IRET) From TRTVENCTL
#  If PRET : End : Endif
#  Call CTLGFYGRP(GRP_NAT ,GRP_NATR,IRET) From TRTVENCTL
#  If PRET : End : Endif


End

###########################################################################
$TRTCOP
#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
If [M]DOSORG=nomap
   Local File DEBREGNAT [DRN1]
Else
   Local File =[M]DOSORG+".DEBREGNAT" [DRN1]
Endif
If [M]DOSDES=nomap
   Local File DEBREGNAT [DRN2]
   Local File ACTIV     [ACV2]
Else
   Local File =[M]DOSDES+".DEBREGNAT"  [DRN2]
   Local File =[M]DOSDES+".ATABDIV"    [ADI2]
   Local File =[M]DOSDES+".ACTIV"      [ACV2]
   Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
Endif

Gosub OUVDOS From ATEXTRA
## Multi-Lég... Vérifier que la législation existe dans le dossier destination
## Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
#If TABLE2<>"" & clalev([F:ADS2])>0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
#   Return
#Endif
Call DEBTRANS From GLOCK
Gosub TRT_COPIE
Close Local File [DRN1], [DRN2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return

$TRT_COPIE
#-----------------------------------------------------------#
# Traitement de la copie d'un enreg Régimes/natures mvt     #
#-----------------------------------------------------------#
Local Char    LEGDES
Local Integer WMONOLEGDES
# Par défaut : Leg destination=leg de l'enregistrement à copier
LEGDES=TABLE
GOK=1

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Pb lecture dossier
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Pas de législation pour le dossier
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
            Return
        Endif
        If TABLE<>[F:ADS2]DOSLEG(0) & TABLE<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
            Return
        Elsif TABLE=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE
          If fstat
           Call MESSAGE (TABLE - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

Read [DRN2]DRN0=LEGDES;TABLE2;TABLE3;val(TABLE4)
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

Local Integer ILIG
Trbegin [DRN2]
      Delete [DRN2] Where LEG=LEGDES & CRY=TABLE2 & GRP=TABLE3 & MVT=val(TABLE4)
      If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".DEBREGNAT"-LEGDES-TABLE2-TABLE3-TABLE4  : Goto ROLL_COPIE
      Elsif fstat GOK=0 : Call RSTA("DRN2","") From GLOCK    : Goto AB_COPIE
      Endif
      If !fstat
          #--- copie des données
          For [DRN1]Where LEG=TABLE & CRY=TABLE2 & GRP=TABLE3 & MVT=val(TABLE4)
               [F:DRN2]=[F:DRN1]
               [F:DRN2]LEG=LEGDES
               If dim([F:DRN2]UPDUSR)>0 : [F:DRN2]UPDUSR = GUSER : Endif
               If dim([F:DRN2]UPDDAT)>0 : [F:DRN2]UPDDAT = date$ : Endif
               If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
               Write [DRN2]
               If fstat
                  GOK = 0 : Call FSTA("DRN2") From GLOCK : Break
               Endif
          Next
      Endif
      If   GOK<0    : Goto ROLL_COPIE
         Elsif !GOK : Goto AB_COPIE
      Endif
Commit

Return
#----- Abandon de la copie -----#
$AB_COPIE
Rollback

Return
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif

Return
#--CPO 71937 Il faut un sous-pro de contrôle même si pas de type de donnée
#--Le sous-pro est appelé afin de contrôler la cohérence d'une détermination par rapport aux paramètres renséignés
# Control
Subprog CONTDRN(LEG,CRY,GRP,MVT,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Value    Char    LEG()
Value 	 Char    CRY()
Value 	 Char    GRP()
Value 	 Char    MVT()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

#DRN0 : LEG+CRY+GRP+MVT

Local Integer 	 WRET

Local    Integer CAS
Local    Char    OPTIONS(30)

If GFONCTION = "GESDRN" | (LEG="" and CRY="" and GRP="" and MVT="" ): End : Endif

If clalev([F:DRN]) =0 : Local File DEBREGNAT 	[DRN]  : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON  [AMZZ] : Endif :#Pour déterminer les options de sélection
If clalev([F:CPY])=0  : Local File COMPANY  [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY [FCY]  : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif
CAS = 1 : # Legislation is empty

#--CPO 71937
#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
	If [L]FCY<>""
		If [F:FCY]FCY<>[L]FCY
			Read [F:FCY]FCY0=[L]FCY
			If fstat : Raz [F:FCY] Endif
		Endif
		If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
	Endif
	If [L]CPY<>""
		If [F:CPY]CPY<>[L]CPY
			Read [F:CPY]CPY0=[L]CPY
			If fstat : Raz [F:CPY] Endif
		Endif
		[L]LEG=[F:CPY]LEG
	Endif
Endif
#--/CPO

If [L]LEG<>""
 Read [DRN]DRN0=[L]LEG;[L]CRY;[L]GRP;[L]MVT
 If fstat
  Read [DRN]DRN0="";[L]CRY;[L]GRP;[L]MVT
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Filter [DRN] Where CRY=[L]CRY and GRP=[L]GRP and MVT=[L]MVT
 Read [F:DRN] First
 If !fstat
  LEG = [F:DRN]LEG
  CAS = 2
 Endif
 Filter [DRN]
Endif
If fstat
 Filter [DRN] Where CRY=[L]CRY and MVT=[L]MVT and GRP=[L]GRP
 Look [DRN]DRN0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]CRY+"~"+[L]GRP+"~"+[L]MVT-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]CRY+"~"+[L]GRP+"~"+[L]MVT-":"-mess(23,100,1)
 Endif
 Filter [DRN]
 mkstat = 2 : End
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GRP de TABVACBPR, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:DRN]GRP<>""
  	#--CPO 71937
  	If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
		Read [AGF]AGF0=[F:DRN]GRP
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:DRN]GRP<>[L]CPY
          GMESSAGE += LEG+"~"+CRY+"~"+GRP+"~"+MVT+"\"+mess(63,127,1)-":"-[F:DRN]GRP : # Réservé au groupe de société
          mkstat = 2 : End
				Endif
  		Elsif [F:AGF]FLGCPY=2
  	#--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:DRN]GRP;[L]CPY
        If fstat
          GMESSAGE += LEG+"~"+CRY+"~"+GRP+"~"+MVT+"\"+mess(63,127,1)-":"-[F:DRN]GRP : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:DRN]GRP<>"" and LEG<>""
	Call CTLGFYLEG([F:DRN]GRP,LEG,"","") From TRTVENCTL
	If mkstat : End : Endif
Endif
#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If GROUPE<>"" and [F:DRN]LEG<>""
	Call CTLGFYLEG(GROUPE,[F:DRN]LEG,"","") From TRTVENCTL
	If mkstat : End : Endif
Endif
#--Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
#--uniquement si le groupe passé est renseigné
#--uniquement si pas de contexte site ou société !
If GROUPE<>""
  If CPY="" & FCY="" & [F:DRN]GRP<>"" & [F:DRN]GRP<>GROUPE
  		#--Les groupes doivent avoir au moins une société en commun
  		Gosub CTLGFYGRP
			If mkstat : End : Endif
  Endif
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
 Call CONTROLE("DRN",OPTIONS,CRY,LEG+"~"+GRP+"~"+MVT,mkstat) From CONTOBJ
Else
 Call CONTROLE("DRN",OPTIONS,CRY,""+"~"+GRP+"~"+MVT,mkstat) From CONTOBJ
Endif

End
#-------------------------------
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

Return
###################################################################################################
##--CPO 71937 Contrôle global de cohérence avant enregistrement
$CONTROLE_COHERENCE

  Local Integer WSTAT
  Local Char    WMESSA(250)
  Local Char  	WCODE(250)
  Local Char    WLEG
  Local Char    WCTX_CPY
  Local Char    WCTX_FCY
  Local Char    WCTX_LEG

	WCODE=[M:DRN]LEG+"~"+[M:DRN]CRY+"~"+[M:DRN]GRP+"~"+num$([M:DRN]MVT)
	WLEG =[M:DRN]LEG

  Call CTL_ML_CONSISTENCY("DRN", "NON", WCODE, WLEG , WCTX_CPY, WCTX_FCY, WCTX_LEG, WSTAT, WMESSA) From TRTVENCTL
  If WSTAT>0 or WMESSA<>""
  	GMESSAGE = WMESSA : GOK=0 : GERR=1 #--Si on ne veux pas bloquer..GERR=2
  Endif

Return

$CHECK_CONSISTENCY
	Local Integer WRET
	Local Char 		WLEG(GLONADI)
	Local Char 		WCRY(GLONCRY)
	Local Char 		WGRP(GLONAGF)
	Local Libelle WMVT
	Local Integer I
	Local Char    TMPCODE(250)


	If clalev([F:DRN])=0 : Local File DEBREGNAT [DRN] : Endif

  #--Vérification de la compatibilité des sous-données déclinées elles aussi

	#--  P_CODE<>"" and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and PACTUAL_LEG<>"" and P_LEG<>PACTUAL_LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-PACTUAL_LEG :# "Législations différentes"
		Return
	Endif

  #--Il faut d'abord éclater le P_CODE
  #P_CODE : [M:DRN]LEG+"~"+[M:DRN]CRY+"~"+[M:DRN]GRP+"~"+num$([M:DRN]MVT)
	Call CODE_TO_PTEKEYS(P_CODE,WLEG,WCRY,WGRP,WMVT,VSTATUS)
	If VSTATUS : Return : Endif

	#--Cohérence [DRN] et paramètres
	If GFONCTION<>"GESDRN"
		Call CONTDRN(PACTUAL_LEG,WCRY,WGRP,WMVT,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBDRN
		If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif
	Endif

  #--Cohérence [DRN]EECSCH et paramètres
  Call CONTTSC([DRN]EECSCH,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTSC
  If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif

  #--Cohérence [DRN]EECNAT et paramètres
  Call CONTTEC([DRN]EECNAT,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTEC
  If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif

  #--Cohérence [DRN]EECSCHR et paramètres
  Call CONTTSC([DRN]EECSCHR,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTSC
  If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif

  #--Cohérence [DRN]EECNATR et paramètres
  Call CONTTEC([DRN]EECNATR,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTEC
  If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CONTEXT
	Local Integer I,IJ
	Local Integer RET,I
	Local Integer CAS
	Local Char LEGS(GLONADI)(1..)
	Local Integer COHERENCE_OK

	Local Char 		WLEG(GLONADI)
	Local Char 		WCRY(GLONCRY)
	Local Char 		WGRP(GLONAGF)
	Local Libelle WMVT

	If clalev([F:DRN])=0  : Local File DEBREGNAT [DRN]  : Endif
	If clalev([F:TSC])=0  : Local File TABEECSCH [TSC]  : Endif
	If clalev([F:TEC])=0  : Local File TABEECNAT [TEC]  : Endif
	If clalev([F:TSCR])=0 : Local File TABEECSCH [TSCR] : Endif
	If clalev([F:TECR])=0 : Local File TABEECNAT [TECR] : Endif

  Local Instance GROUPES Using C_GRPCOLL

	#--On connait la détermination
	#--On cherche un contexte compatible
	#--Si pas de contexte compatible, alors la donnée multi-lég est mal paramétrée

	#-- P_CODE<>"" and (PACTUAL_CPY="" and PACTUAL_FCY=""and PACTUAL_LEG="")

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and [F:DRN]LEG<>"" and P_LEG<>[F:DRN]LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-[F:DRN]LEG :# "Législations différentes"
		Return
	Endif

  #--Il faut d'abord éclater le P_CODE
  #P_CODE : [M:DRN]LEG+"~"+[M:DRN]CRY+"~"+[M:DRN]GRP+"~"+num$([M:DRN]MVT)
	Call CODE_TO_PTEKEYS(P_CODE,WLEG,WCRY,WGRP,WMVT,VSTATUS)
	If VSTATUS : Return : Endif

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESDRN il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If GFONCTION<>"GESDRN" and ( find([F:DRN]CRY,WCRY,"")=0 | find([F:DRN]LEG,P_LEG,"")=0 | find([F:DRN]GRP,WGRP,"")=0 | find([F:DRN]MVT,WMVT,0)=0)
    If P_LEG<>""
      Read [DRN]DRN0=P_LEG;WCRY;WGRP;WMVT
      If fstat
        Read [DRN]DRN0="";WCRY;WGRP;WMVT
      Endif
    Else
      Filter [DRN] Where find(CRY,WCRY,"")>0 and find(GRP,WGRP,"")>0 and find(MVT,WMVT,0)>0
      Read [F:DRN] First
      If !fstat
        LEG = [F:DRN]LEG
      Endif
      Filter [DRN]
    Endif
    If fstat
     Filter [DRN] Where find(CRY,WCRY,"")>0 and find(GRP,WGRP,"")>0 and find(MVT,WMVT,0)>0
     Look [DRN]DRN0 First
     If !fstat
      # Fiche inexistante pour la législation courante
      VMESSAGE = WCRY-":"-mess(232,107,1)-"["+P_LEG+"]"
     Else
      # Fiche inexistante
      VMESSAGE = WCRY-":"-mess(23,100,1)
     Endif
     Filter [DRN]
     VSTATUS=99 : End
    Endif
  Endif

  P_LEG=[F:DRN]LEG
  LEGS(1)=P_LEG

  If P_LEG=""
		#--Le code retenu est toutes législations
		#--Il faut d'abord trouver une législation commune
		#--Puis pour cette législation, il faut déterminer une société commune aux groupes, sinon on renvoye ""
		I = 2

    If [F:DRN]EECSCH<>""
    	For [TSC] Where EECSCH=[F:DRN]EECSCH
    		If [F:TSC]LEG<>"" and find([F:TSC]LEG,LEGS)=0
    			LEGS(I) = [F:TSC]LEG
    			I += 1
    		Endif
    	Next
    Endif

		If [F:DRN]EECNAT<>""
  		For [TEC] Where EECNAT=[F:DRN]EECNAT
  			If [F:TEC]LEG<>"" and find([F:TEC]LEG,LEGS)=0
  				LEGS(I) = [F:TEC]LEG
  				I += 1
  			Endif
  		Next
  	Endif

    If [F:DRN]EECSCHR<>""
    	For [TSCR] Where EECSCH=[F:DRN]EECSCHR
    		If [F:TSCR]LEG<>"" and find([F:TSCR]LEG,LEGS)=0
    			LEGS(I) = [F:TSCR]LEG
    			I += 1
    		Endif
    	Next
    Endif

		If [F:DRN]EECNATR<>""
  		For [TECR] Where EECNAT=[F:DRN]EECNATR
  			If [F:TECR]LEG<>"" and find([F:TECR]LEG,LEGS)=0
  				LEGS(I) = [F:TECR]LEG
  				I += 1
  			Endif
  		Next
  	Endif

	Endif

	For I=1 To maxtab(LEGS)

  	#--Le code retenu contient une législation en particulier
  	#--Cette législation sera renvoyée
  	#--Reste à déterminer une société commune aux groupes, sinon on renvoye ""

  	#--On commence par lire les sous-données déclinées

  	#--Lecture du Régime
  	If [F:DRN]EECSCH<>""
    	Call LEC_TSC_LEG(LEGS(I),[F:DRN]EECSCH,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:TSC] :#--On continue pour les autres et on ne tient pas compte de ce dernier
		Endif

  	#--Lecture de la Nature
  	If [F:DRN]EECNAT<>""
    	Call LEC_TEC_LEG(LEGS(I),[F:DRN]EECNAT,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:TEC] :#--On continue pour les autres et on ne tient pas compte de ce dernier
    Endif

		#--Lecture du Régime de régularisation
		If [F:DRN]EECSCHR<>""
  		fstat=0
      If [F:TSCR]EECSCH<>[F:DRN]EECSCHR | [F:TSCR]LEG<>LEGS(I)
        Read [TSCR]TSC0=[F:DRN]EECSCHR;LEGS(I)
        If fstat
          Read [TSCR]TSC0=[F:DRN]EECSCHR;""
        Endif
      Endif
      If fstat
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
			Raz [F:TSCR] :#--On continue pour les autres et on ne tient pas compte de ce dernier
		Endif

		#--Lecture de la Nature de régularisation
		If [F:DRN]EECNATR<>""
  		fstat=0
      If [F:TECR]EECNAT<>[F:DRN]EECNATR | [F:TECR]LEG<>LEGS(I)
        Read [TECR]TEC0=[F:DRN]EECNATR;LEGS(I)
        If fstat
          Read [TECR]TEC0=[F:DRN]EECNATR;""
        Endif
      Endif
      If fstat
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:TECR] :#--On continue pour les autres et on ne tient pas compte de ce dernier
		Endif

  	#--Il reste à trouver une société commune aux différents groupes
  	#--La société doit être de la législation retenue

		If [F:DRN]GRP<>"" or [F:TSC]SOC <>"" or [F:TEC]SOC<>"" or [F:TSCR]SOC <>"" or [F:TECR]SOC<>""

      GROUPES = NewInstance [GRPDRN] With C_GRPCOLL


      RET= fmet GROUPES.GROUPADD([F:DRN]GRP)
      RET= fmet GROUPES.GROUPADD([F:TSC]SOC)
      RET= fmet GROUPES.GROUPADD([F:TEC]SOC)
      RET= fmet GROUPES.GROUPADD([F:TSCR]SOC)
      RET= fmet GROUPES.GROUPADD([F:TECR]SOC)

    	For IJ = 1 To maxtab(GROUPES.L_FCY)
      	If GROUPES.L_FCY(IJ)<>null and find(GROUPES.L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      	  If LEGS(I)="" | GROUPES.L_FCY(IJ).FCYCPYLEG = LEGS(I)

        		PACTUAL_FCY = GROUPES.L_FCY(IJ).FCY
        		PACTUAL_CPY = GROUPES.L_FCY(IJ).FCYCPY
        		PACTUAL_LEG = GROUPES.L_FCY(IJ).FCYCPYLEG

        		FreeInstance =GROUPES.ALLOCGRP

        		COHERENCE_OK = 1
        		Break 2

      		Endif
      	Endif
    	Next IJ

      #--On libère proprement...
      FreeInstance =GROUPES.ALLOCGRP

		Else
			#--On a trouvé une lég, et il n'y a pas de groupes
			#--C'est bon...
    	#--Les lectures ont abouti
    	#--On peut renvoyer le legs(i) comme législation du contexte
    	PACTUAL_LEG = LEGS(I)
    	COHERENCE_OK = 1
    	Break

		Endif

   	$NEXT_LEGS
	Next I

	#--On positionne le VSTATUS si rien trouvé
  If COHERENCE_OK <>1
  	VMESSAGE = mess(799,197,1)
  	VSTATUS  = 1 : Return
  Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CODE
	If clalev([F:DRN])=0 : Local File DEBREGNAT [DRN] : Endif
  #--On connait le contexte
  #--On cherche une détermination compatible

  #--  P_CODE=""  and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

	#--Filtre sur la législation ou "toutes législations"
  Filter [F:DRN] Where
&						find(LEG,"",PACTUAL_LEG)>0 and
&						find(CRY,WCRY,"")>0 and
&						find(GRP,WGRP,"")>0 and
&						find(MVT,WMVT,0 )>0

	For [F:DRN]

		Raz VSTATUS : Raz VMESSAGE

    #--Cohérence [DRN] et paramètres
    Call CONTDRN(PACTUAL_LEG,[F:DRN]CRY,[F:DRN]GRP,[F:DRN]MVT,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBDRN
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif

  	If VSTATUS=0
      #--Cohérence [DRN]EECSCH et paramètres
      Call CONTTSC([DRN]EECSCH,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTSC
      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
  	Endif

  	If VSTATUS=0
      #--Cohérence [DRN]EECNAT et paramètres
      Call CONTTEC([DRN]EECNAT,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTEC
      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
  	Endif

  	If VSTATUS=0
      #--Cohérence [DRN]EECSCHR et paramètres
      Call CONTTSC([DRN]EECSCHR,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTSC
      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
  	Endif

  	If VSTATUS=0
      #--Cohérence [DRN]EECNATR et paramètres
      Call CONTTEC([DRN]EECNATR,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTEC
      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
  	Endif

    If VSTATUS=0
    	#--Le code trouvé est cohérent avec le contexte
    	P_CODE=[F:DRN]LEG+"~"+[F:DRN]CRY+"~"+[F:DRN]GRP+"~"+num$([F:DRN]MVT)
			P_LEG =[F:DRN]LEG
			Break
		Endif

	Next

	Filter [F:DRN]

	If VSTATUS>0 | P_CODE=""
		VMESSAGE = mess(798,197,1)-":"-mess(218,107,1)-PACTUAL_LEG+","-mess(2,45,1)-PACTUAL_CPY
	Endif

Return

Subprog CODE_TO_PTEKEYS(P_CODE,V_LEG,V_CRY,V_GRP,V_MVT,V_ERR)
Value Char 			 P_CODE
Variable Char 	 V_LEG()
Variable Char 	 V_CRY()
Variable Char	 	 V_GRP()
Variable Libelle V_MVT
Variable Integer V_ERR

Local Integer I
Local Char TMPCODE(250)

	Raz V_LEG,V_CRY,V_GRP,V_MVT,V_ERR

  I=instr(1,P_CODE,"~")
  If I=0 : V_ERR=99 : End : Endif

	V_LEG=left$(P_CODE,I-1)

	TMPCODE=right$(P_CODE,I+1)
	I=instr(1,TMPCODE,"~")
	If I=0 : V_ERR=99 : End : Endif
  V_CRY=left$(TMPCODE,I-1)

  TMPCODE=right$(TMPCODE,I+1)
	I=instr(1,TMPCODE,"~")
	If I=0 : V_ERR=99 : End : Endif
	V_GRP=left$(TMPCODE,I-1)

	V_MVT=val(right$(TMPCODE,I+1))

End
