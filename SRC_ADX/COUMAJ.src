      If NBENREG3>0 Then Call ECR_TRACE(mess(130,10717,1)-":"-num$(NBENREG3),0) From GESECRAN Endif : # Nombre de coûts réels Participants calculés mis à jour
      If NBENREG4>0 Then Call ECR_TRACE(mess(131,10717,1)-":"-num$(NBENREG4),0) From GESECRAN Endif : # Nombre de coûts réels Formateurs calculés mis à jour
      If NBENREG5>0 Then Call ECR_TRACE(mess(214,10717,1)-":"-num$(NBENREG5),0) From GESECRAN Endif : # Nombre de coûts réels Formateurs non calculés mis à jour
      If NBDEL5>0   Then Call ECR_TRACE(mess(238,10717,1)-":"-num$(NBDEL5),0)   From GESECRAN Endif : # Nombre de coûts réels Formateurs non calculés supprimés
    Else
      Call ECR_TRACE(mess(141,10717,1),0) From GESECRAN : # Aucun coût à traiter
    Endif
  Endif
Return

#**#####################################################################################
#* Sous-pro général de calcul des taux par TAUX_HORAIRE avec constitution et affichage
#* du message d'erreur dans la trace, le cas échéant
#*!
Subprog RESULT_TAUX(REFNUM, CONTRAT, TYPE_C, TAUX, TYPCOU, TYPTX, DATE_TAUX, MOIS, TAUX_R, NB_R)
Value    Char    REFNUM, CONTRAT, TYPCOU
Value    Decimal TAUX, TYPTX
Value    Integer TYPE_C, MOIS
Value    Date    DATE_TAUX
Variable Decimal TAUX_R
Variable Integer NB_R
Local    Char    MESSAGE(255)

  Raz TAUX
  Call TAUX_HORAIRE(REFNUM, CONTRAT, DATE_TAUX, TAUX, TYPTX, 2, TYPE_C) From TRTCOUT
  If !TAUX Then
    MESSAGE = "   >"-REFNUM-":"
    If TYPE_C=1 Then
      MESSAGE -= mess(78,10717,1) : # Taux horaire total non défini
    Elsif TYPE_C=2 Then
      MESSAGE -= mess(79,10717,1) : # Taux horaire imputable non défini
    Endif
    If MOIS=2 Then
      MESSAGE -= mess(28,9900,1)-format$("D:MM[/]YYYY", DATE_TAUX-1) : # sur <mois année>
    Endif
    MESSAGE -= mess(128,10717,1)-TYPCOU : # pour type de coût
    Call ECR_TRACE(MESSAGE,0)From GESECRAN
  Else
    TAUX_R += TAUX
    NB_R   += 1
  Endif
End

#**#####################################################################################
#* Si REFNUM est connu : calcul des montants Imputable et Total selon le mode de calcul
#* défini par le paramètre MODCAL :
#*     - salaire au dernier jour de la session
#*     - ou moyenne des salaires sur la période de la session
#*
#* Quand REFNUM n'est pas connu (cas du calcul des taux pour le formateur, alors que celui-ci
#* n'est pas connu), on prend soit le coût moyen, soit le taux horaire de la catégorie stockée dans une nouvelle
#* valeur paramètre société (TRNCAT), en fonction d'une nouvelle valeur paramètre société de calcul du taux
#* horaire (CLCHRSRAT).
#*!
Subprog CALC_MTT(REFNUM, CONTRAT, STRDAT, ENDDAT, NBRHOU, PCPY, MTTTOT, MTTIPT)
Value    Char    REFNUM, CONTRAT, PCPY
Value    Date    STRDAT, ENDDAT
Value    Decimal NBRHOU
Variable Decimal MTTTOT, MTTIPT
Local    Decimal TAUX, TAUX_M, TAUX_T, TAUX_I
Local    Integer NB_T, NB_I, FORM_OK
Local    Char    LMODCAL(5)
Local    Char    CRITCPY(255), CRITFCY(255)

  MTTIPT=0 : MTTTOT=0
  TAUX_T=0 : NB_T=0
  TAUX_I=0 : NB_I=0

  If REFNUM<>"" Then
    Call PARAM([F:ID]FCY,"MODCAL",LMODCAL) From ADOVAL
    If LMODCAL="1" Then : # Salaire au dernier jour de la session
      # Recherche du dernier taux réel total connu à la date de fin de la session
      Call RESULT_TAUX(REFNUM, CONTRAT, 1, TAUX, [F:ADI]CODE, [F:ADI]N1, ENDDAT, 1, TAUX_T, NB_T)
      # Recherche du taux réel imputable connu à la date de fin de la session
      Call RESULT_TAUX(REFNUM, CONTRAT, 2, TAUX, [F:ADI]CODE, [F:ADI]N1, ENDDAT, 1, TAUX_I, NB_I)
    Elsif LMODCAL="2" Then : # Moyenne des salaires sur la période
      STRMONTH=month(STRDAT)
      ENDMONTH=month(ENDDAT)
      For I=STRMONTH To ENDMONTH
        DATE_TAUX=gdat$(0,I+1,year(STRDAT)) : # Dernier jour du mois I
        # Recherche du taux réel total sur chaque mois de la session
        Call RESULT_TAUX(REFNUM, CONTRAT, 1, TAUX_M, [F:ADI]CODE, [F:ADI]N1, DATE_TAUX, 2, TAUX_T, NB_T)
        # Recherche du taux réel imputable sur chaque mois de la session
        Call RESULT_TAUX(REFNUM, CONTRAT, 2, TAUX_M, [F:ADI]CODE, [F:ADI]N1, DATE_TAUX, 2, TAUX_I, NB_I)
      Next
    Endif
    If NB_T>0 Then TAUX = TAUX_T/NB_T : MTTTOT = arr(TAUX*NBRHOU,0.01) : Endif
    If NB_I>0 Then TAUX = TAUX_I/NB_I : MTTIPT = arr(TAUX*NBRHOU,0.01) : Endif
  Elsif [F:SESM]FRTINT=2 Then
    # Calcul des taux pour le formateur, alors que le formateur n'est pas connu
    Global Integer FLAG_MESSAGE : FLAG_MESSAGE = 2 : # Globale utilisée dans CALC_COUT_FORMATEUR
    If clalev([F:ADI2])=0 : Local File ATABDIV [ADI2] : Endif
    Call CALC_COUT_FORMATEUR(PCPY,ENDDAT,TAUX_T,[F:ADI]N1,2,1) From SUBPLF
    MTTTOT = arr(TAUX_T*NBRHOU,0.01)
    Call CALC_COUT_FORMATEUR(PCPY,ENDDAT,TAUX_I,[F:ADI]N1,2,2) From SUBPLF
    MTTIPT = arr(TAUX_I*NBRHOU,0.01)
    Kill FLAG_MESSAGE
  Endif
End

#**#####################################################################################
#* Calcul du 1er numéro de ligne disponible dans la table relative au paramètre CALC_TAB (COUTREEL ou COUT)
#*!
Funprog CALC_NUMLIG(CALC_TYPCOU, CALC_SES, CALC_REFNUM, CALC_TAB)
Value Integer CALC_TYPCOU
Value Char    CALC_SES, CALC_REFNUM, CALC_TAB
Local Integer NUMLIG

  If CALC_TAB="CR" Then : # Table COUTREEL
    If clalev([F:CORM])=0 : Local File COUTREEL [CORM] : Endif
    Filter [F:CORM] Where TYPCOU=CALC_TYPCOU & SES=CALC_SES & REFNUM=CALC_REFNUM Order By NUMLIG Desc
    If rowcount([F:CORM])=0 Then
      NUMLIG=1
    Else
      Read [F:CORM] First
      NUMLIG = [F:CORM]NUMLIG+1
    Endif
    Filter [F:CORM]
  Endif
  If CALC_TAB="CT" Then : # Table COUT
    If clalev([F:COUM])=0 : Local File COUT [COUM] : Endif
    Filter [F:COUM] Where TYPCOU=CALC_TYPCOU & SES=CALC_SES Order By NUMLIG Desc
    If rowcount([F:COUM])=0 Then
      NUMLIG=1
    Else
      Read [F:COUM] First
      NUMLIG = [F:COUM]NUMLIG+1
    Endif
    Filter [F:COUM]
  Endif
End NUMLIG

#**#####################################################################################
#* Création d'un enregistrement dans la table COUTREEL
#* Aucun enregistrement n'existe pour ce type de coût, cette session et ce matricule (si formateur, REFNUM="")
#* Donc, le NUMLIG est forcément égal à 1
#*!
Subprog CREATE_COR(TYPCOU, CODSES, REFNUM, TYPCRG, TYPFRT, ORGFIN, TYPFIN)
#Value Integer TYPCOU, TYPFRT
Value Integer TYPCOU
Value Char    TYPFRT                  : # JML 08/09/15
Value Char    CODSES, REFNUM, TYPCRG, ORGFIN, TYPFIN

# SEGAY 81085 US 460
  Local Char WSVGCURLEG(GLONADI) : WSVGCURLEG=GCURLEG
  Local Char LEGLIG(GLONADI) : LEGLIG=""
  Local Integer WOK
  Local Integer INDEX
# END SEGAY 81085 US 460

  Raz [F:HRCOR]
  If clalev([F:ADI2])=0 : Local File ATABDIV [ADI2] : Endif
  [F:HRCOR]TYPCOU     = TYPCOU
  [F:HRCOR]SES        = CODSES
  [F:HRCOR]REFNUM     = REFNUM
  [F:HRCOR]NUMLIG     = func CALC_NUMLIG(TYPCOU, CODSES, REFNUM, "CR")
  [F:HRCOR]TYPCRG2    = TYPCRG

# SEGAY 81085 US 460
  Call  GET_LEGHRSES(CODSES,WOK,LEGLIG,0) From TOOLSHRLEG
  INDEX=1
  Call CHECKLEG_LIGCOST(TYPCRG,TYPFIN,ORGFIN,INDEX,0,LEGLIG,WOK) From SUBSTG
# END SEGAY 81085 US 460

  If TYPFIN="" Then
# SEGAY 81085 US 460
#    Filter [ADI2] Where NUMTAB=10462 & DEFVAL=2
    If LEGLIG=""
      Filter [ADI2] Where NUMTAB=10462 & DEFVAL=2
    Else
      Filter [ADI2] Where NUMTAB=10462 & DEFVAL=2 & (LEG="" or LEG=LEGLIG)
    Endif
    Read[ADI2]CODE First
    Filter [ADI2]
    If !fstat Then
      [F:HRCOR]TYPFIN2  = [F:ADI2]CODE
# SEGAY 81085 US 460
      INDEX=2
      Call CHECKLEG_CRGFINOFT([F:HRCOR]TYPFIN2,INDEX,0,LEGLIG,WOK) From SUBSTG
# END SEGAY 81085 US 460
    Endif
  Else
    [F:HRCOR]TYPFIN2  = TYPFIN
  Endif

  If ORGFIN="" Then
# SEGAY 81085 US 460
#    If dim(GOFIDEF)>0 Then [F:HRCOR]ORGFIN2 = GOFIDEF Endif
    If dim(GOFIDEF)>0 Then
     INDEX=3
     Call CHECKLEG_CRGFINOFT(GOFIDEF,INDEX,0,LEGLIG,WOK) From SUBSTG
     If WOK
       [F:HRCOR]ORGFIN2 = GOFIDEF
     Endif
    Endif
# END SEGAY 81085 US 460
  Else
    [F:HRCOR]ORGFIN2  = ORGFIN
  Endif
  [F:HRCOR]DESTYPFRT2 = TYPFRT
  [F:HRCOR]CREDAT     = date$
  [F:HRCOR]CREUSR     = GUSER
End

#**#####################################################################################
#* Création d'un enregistrement dans la table COUT
#* Aucun enregistrement n'existe pour ce type de coût, cette session et ce matricule (si formateur, REFNUM="")
#* Donc, le NUMLIG est forcément égal à 1
#*!
Subprog CREATE_COU(TYPCOU, CODSES, REFNUM, TYPCRG, TYPFRT, ORGFIN, TYPFIN)
#Value Integer TYPCOU, TYPFRT
Value Integer TYPCOU
Value Char    TYPFRT   : # JML 08/09/15
Value Char    CODSES, REFNUM, TYPCRG, ORGFIN, TYPFIN

# SEGAY 81085 US 460
  Local Char WSVGCURLEG(GLONADI) : WSVGCURLEG=GCURLEG
  Local Char LEGLIG(GLONADI) : LEGLIG=""
  Local Integer WOK
  Local Integer INDEX
# END SEGAY 81085 US 460

# SEGAY 81085 US 460
  Call  GET_LEGHRSES(CODSES,WOK,LEGLIG,0) From TOOLSHRLEG
  INDEX=1
  Call CHECKLEG_LIGCOST(TYPCRG,TYPFIN,ORGFIN,INDEX,0,LEGLIG,WOK) From SUBSTG
# END SEGAY 81085 US 460

  Raz [F:COU2]
  If clalev([F:ADI2])=0 : Local File ATABDIV [ADI2] : Endif
  [F:COU2]TYPCOU     = TYPCOU
  [F:COU2]SES        = CODSES
  [F:COU2]NUMLIG     = func CALC_NUMLIG(TYPCOU, CODSES, REFNUM, "CT")
  [F:COU2]TYPCRG     = TYPCRG

  If TYPFIN="" Then
# SEGAY 81085 US 460
#    Filter [ADI2] Where NUMTAB=10462 & DEFVAL=2
    If LEGLIG=""
      Filter [ADI2] Where NUMTAB=10462 & DEFVAL=2
    Else
      Filter [ADI2] Where NUMTAB=10462 & DEFVAL=2 & (LEG="" or LEG=LEGLIG)
    Endif
    Read[ADI2]CODE First
    Filter [ADI2]
    If !fstat Then
      [F:COU2]TYPFIN  = [F:ADI2]CODE
# SEGAY 81085 US 460
      INDEX=2
      Call CHECKLEG_CRGFINOFT([F:COU2]TYPFIN,INDEX,0,LEGLIG,WOK) From SUBSTG
# END SEGAY 81085 US 460
    Endif
  Else
    [F:COU2]TYPFIN  = TYPFIN
  Endif

  If ORGFIN="" Then
# SEGAY 81085 US 460
#    If dim(GOFIDEF)>0 Then [F:COU2]ORGFIN = GOFIDEF Endif
    If dim(GOFIDEF)>0 Then
     INDEX=3
     Call CHECKLEG_CRGFINOFT(GOFIDEF,INDEX,0,LEGLIG,WOK) From SUBSTG
     If WOK
       [F:COU2]ORGFIN = GOFIDEF
     Endif
    Endif
# END SEGAY 81085 US 460
  Else
    [F:COU2]ORGFIN  = ORGFIN
  Endif
  [F:COU2]CREDAT    = date$
  [F:COU2]CREUSR    = GUSER
End

######################################################################################
#                                   ACTIONS SUR CHAMPS                               #
######################################################################################

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : contrôle du stage
######################################################################################
Subprog C_STRSTG(VALEUR)
Variable Char    VALEUR()
  Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
  If mkstat Then End Endif
End

#**#####################################################################################
#* Contrôle que la borne fin est supérieure à la borne début
#*!
Subprog C_ENDSTG(VALEUR)
Variable Char    VALEUR()

  # SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : contrôle du stage
  Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
  If mkstat Then End Endif

  Call CTLALPV(VALEUR, [M:CREE]STRSTG) From CONTDIV
End

#**#####################################################################################
#* Contrôle que la borne fin est supérieure à la borne début
#*!
Subprog C_ENDSES(VALEUR)
Variable Char    VALEUR()

  Call CTLALPV(VALEUR, [M:CREE]STRSES) From CONTDIV
End

#**#####################################################################################
#* Contrôle que la borne fin est supérieure à la borne début
#*!
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

  Call CTLDATV(VALEUR, [M:CREE]STRDAT) From CONTDIV
End

#**#####################################################################################
#* Initialisation de la borne fin par la borne début
#*!
Subprog AS_ENDSTG(VALEUR)
Variable Char    VALEUR()

  If [M:CREE]STRSTG<>"" and VALEUR="" Then
    VALEUR=[M:CREE]STRSTG
  Endif
End

#**#####################################################################################
#* Initialisation de la borne fin par la borne début
#*!
Subprog AS_ENDSES(VALEUR)
Variable Char    VALEUR()

  If [M:CREE]STRSES<>"" and VALEUR="" Then
    VALEUR=[M:CREE]STRSES
  Endif
End

#**#####################################################################################
#* Initialisation de la borne fin par la borne début
#*!
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR

  If [M:CREE]STRDAT<>[00/00/00] and VALEUR=[00/00/00] Then
    VALEUR=[M:CREE]STRDAT
  Endif
End


######################################################################################
# FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUFOR, on grise ou pas la case
Subprog AV_COUFORCAL(VALEUR)
Variable Integer VALEUR

  If GCALCOUFOR<>2 Then Grizo [M:CREE]COUFORCAL : Endif
End

# FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUPAR, on grise ou pas la case
Subprog AV_COUPARCAL(VALEUR)
Variable Integer VALEUR

  If GCALCOUPAR<>2 Then Grizo [M:CREE]COUPARCAL : Endif
End


######################################################################################
#ADNGO - 2017-06-28 - X3-29547 - START
######################################################################################
# X3PEOP-3476
$GEST_COUPARCAL

If clalev([F:DML])=0    : Local File DEMLIG [DML]     : Endif

Gosub DECLARE_VARS_FORREP
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(134,10717,1),0) From GESECRAN : # Mise à jour coûts réels Participants calculés
NBENREG3=0
Link [F:INS] With [F:SESM]SES0=SES As [IN_] Where evalue(CRITERE)
For [F:IN_]
  Gosub GET_VARS_FORREP
  Gosub SET_VARS_CALCIN_
  If [F:SESM]NBRHOUIPT=0 Then
    Call ECR_TRACE(mess(224,10717,1)-[F:SESM]COD,0) From GESECRAN : # Pas d'heures définies pour la session
  Else
  # Chargement [F:FCY] avec infos relatives au stage, session, matricule
    Gosub CALC_INFOS_CFY
    Read [F:ID]ID0=[F:INS]REFNUM
    If !fstat and evalue(CRITCPY)>0 and evalue(CRITFCY)>0 Then
      Filter [F:ADI] Where NUMTAB=10451 & N1<3 & N2=1
      For [F:ADI]
        Delete [F:HRCOR] Where TYPCOU=3 & SES=[F:SESM]COD & REFNUM=[F:INS]REFNUM & TYPCRG2=[F:ADI]CODE
        Call CALC_MTT([F:INS]REFNUM, [F:INS]CTRNUM, [F:SESM]STRDAT, [F:SESM]ENDDAT, [F:SESM]NBRHOUIPT, "", MTTTOT, MTTIPT)
        If MTTIPT<>0 | MTTTOT<>0 Then
          Call ECR_TRACE("   "-mess(34,10717,1)-[F:SESM]COD-";"-mess(71,10717,1)-[F:INS]REFNUM-";"-mess(133,10717,1)-[F:ADI]CODE,0) From GESECRAN : # Session ; Insription ; Type de coût
          # FQ73110 - MABON 11/04/11 - Le dispositif de l'inscription générée, est celui de la ligne de demande
          TYPFRT_I=""   : # JML 08/09/15
          If [F:INS]DEM<>"" Then
            Filter [F:DML] Where DEMNUM=[F:INS]DEM & EMP=[F:INS]REFNUM
            Read [F:DML] First
            If !fstat Then
              TYPFRT_I=[F:DML]DESTYPFRT
            Endif
          Endif
          If TYPFRT_I=""    : # JML 08/09/15
            TYPFRT_I=[F:SESM]TYPFRT
          Endif
          # Fin MABON
          Call CREATE_COR(3, [F:SESM]COD, [F:INS]REFNUM, [F:ADI]CODE, TYPFRT_I, "", "")
          [L]W_TYPCRG= [F:HRCOR]TYPCRG2
          Gosub GET_RECORD_REP From TRTCOUT
          Gosub SET_DEFAULTVALUES_LINECOR_FROMHRTCR
          Gosub AFFECTE_COR_SES_C
          Write [F:HRCOR]
          If fstat Then GOK=1 : Break 2 : Endif
          NBENREG3 += 1
          If IS_REP
            Write [F:HRCOR2]
            If fstat Then GOK=1 : Break 2 : Endif
            NBENREG3 += 1
          Endif
        Endif
      Next
      Filter [F:ADI]
    Endif
  Endif
Next
Return


$GEST_COUAUT_COUPARNCAL

Local Integer  IS_REP, IS_SAVE

Local Decimal W_CSTIPTCLL,W_CSTIPTIDV
Local Decimal W_CSTTOTCLL,W_CSTTOTIDV
Gosub DECLARE_VARS_FORREP

If [M:CREE]COUAUT=2 Then
      Call ECR_TRACE(mess(132,10717,1),0) From GESECRAN : # Mise à jour coûts réels Autres non calculés
Endif
If [M:CREE]COUPARNCAL=2 Then
  Call ECR_TRACE(mess(213,10717,1),0) From GESECRAN : # Mise à jour coûts réels Participants non calculés
Endif
NBENREG1 = 0 : NBENREG2 = 0
# FQ72865 - MABON 04/04/11 - Suppression des coûts de la session qui n'existent plus dans le stage
NBDEL1   = 0 : NBDEL2   = 0
Filter [F:SESM] Where evalue(CRITERE)
For [F:SESM]

  Gosub GET_VARS_FORREP
  Gosub SET_VARS_CALCSES

  # FQ72865 - MABON 04/04/11 - Suppression des coûts du stage qui n'existent plus
  If [M:CREE]COUPARNCAL=2 Then Call DEL_COU_SES_INS_ALL([F:SESM]COD,"[F:ADI]N1=3 & [F:ADI]N2=1", NBDEL1) : Endif
  If [M:CREE]COUAUT=2     Then Call DEL_COU_SES_INS_ALL([F:SESM]COD,"[F:ADI]N1=3 & [F:ADI]N2=3", NBDEL2) : Endif

  # Fin MABON
  Filter [F:COUD] Where  TYPCOU=1 & STG=[F:SESM]STG & LNKREP<>""
  For [COU]COU1 Where TYPCOU=1 & STG=[F:SESM]STG
    If [F:COU]LNKREP="" or right$([F:COU]LNKREP,len([F:COU]LNKREP))<>"D"
      Read [ADI]CODE=10451;[F:COU]TYPCRG
      If [F:ADI]N1=3 &(([M:CREE]COUAUT=2 & [F:ADI]N2=3) | ([M:CREE]COUPARNCAL=2 & [F:ADI]N2=1)) Then
      # On crée les couts
        [L]IS_REP=0
         Call CREATE_COU(2, [F:SESM]COD, "", [F:COU]TYPCRG, [F:SESM]TYPFRT, [F:COU]ORGFIN, [F:COU]TYPFIN)
       # [F:COU2]LNKREP=[F:COU]LNKREP
        If [F:COU]LNKREP<>""
          For [F:COUD] Where LNKREP=[F:COU]LNKREP+"D"
            [L]IS_REP=1
            Break
          Next
        Endif

        Gosub SET_DEFAULTVALUES_LINECOU
        Gosub AFFECTE_COUT_SES
        Write [F:COU2]
        #Gosub INC_CPT_COUAUT_COUPARNCAL
        If fstat Then GOK=1 : Break 2 : Endif
        If [L]IS_REP
          Write [F:COU4]
         # Gosub INC_CPT_COUAUT_COUPARNCAL
          If fstat Then GOK=1 : Break 2 : Endif
        Endif
        Filter [F:INS] Where SES=[F:SESM]COD
        NBRINS = rowcount([F:INS])
        For [F:INS]
          Gosub CALC_INFOS_CFY
          Read [F:ID]ID0=[F:INS]REFNUM
          If !fstat and evalue(CRITCPY)>0 and evalue(CRITFCY)>0 Then
            Call ECR_TRACE("   "-mess(34,10717,1)-[F:SESM]COD-";"-mess(71,10717,1)-[F:INS]REFNUM-";"-mess(133,10717,1)-[F:ADI]CODE,0) From GESECRAN : # Session ; Insription ; Type de coût
            If NBRINS>0 & (([M:CREE]COUAUT=2 & [F:ADI]N2=3) | ([M:CREE]COUPARNCAL=2 & [F:ADI]N2=1)) Then
              Gosub SET_VARS_CALCINS
              Call CREATE_COR(3, [F:SESM]COD, [F:INS]REFNUM, [F:ADI]CODE, [F:SESM]TYPFRT, [F:COU]ORGFIN, [F:COU]TYPFIN)
              If [L]IS_REP
                [F:HRCOR2]=[F:HRCOR]
                [F:HRCOR2]NUMLIG+=1
                [F:HRCOR2]ORGFIN2=[F:COUD]ORGFIN
                Gosub SET_TIMESTAMP_COR
              Endif
              Gosub AFFECTE_COR_INS
              Write [F:HRCOR]
              If fstat Then GOK=1 : Break 3 : Endif
              Gosub INC_CPT_COUAUT_COUPARNCAL
              If [L]IS_REP
                Write [F:HRCOR2]
                 If fstat Then GOK=1 : Break 3 : Endif
                Gosub INC_CPT_COUAUT_COUPARNCAL
              Endif
            Endif
          Endif
        Next
      Endif
    Endif # don't take
  Next

Next
Filter [F:SESM]
Return


$INC_CPT_COUAUT_COUPARNCAL
  If [M:CREE]COUAUT=2 & [F:ADI]N2=3     Then NBENREG2 += 1 : Endif
  If [M:CREE]COUPARNCAL=2 & [F:ADI]N2=1 Then NBENREG1 += 1 : Endif
Return





$DECLARE_VARS_FORREP
 If clalev([F:STG])=0    : Local File STAGE [STG]      : Endif
  Local Char W_TCRCOD(30),W_TYPCRG(30),TIMESTP(30)
  Local Integer W_NBRNIGHT
  Local Decimal W_NBRHOUR
  Local Decimal RESULT(0..1)

Return

$GET_VARS_FORREP
 If [F:SESM]STG<>""
    Read [F:STG]STG0=[F:SESM]STG
    If !fstat
      W_TCRCOD=[F:STG]TCRCOD
    Endif
  Endif

Return


$SET_VARS_CALCIN_
  If W_TCRCOD<>""
    W_NBRHOUR =[F:IN_]NBRHOUIPT
    W_NBRNIGHT =[F:IN_]NBRNGT
  Endif
Return

$SET_VARS_CALCINS
  If W_TCRCOD<>""
    W_NBRHOUR =[F:INS]NBRHOUIPT
    W_NBRNIGHT =[F:INS]NBRNGT
  Endif
Return


$SET_VARS_CALCSES

If W_TCRCOD<>""
  W_NBRHOUR =[F:SESM]NBRHOUIPT
  W_NBRNIGHT =[F:SESM]NBRNGT
Endif

Return




$DECLAR_W_COU_COR
Local Decimal WSTG1_CSTIDV,WSTG2_CSTIDV
Local Decimal WSTG12_CSTCLL,WSTG12_CSTIDV
Local Decimal W1_CSTIDV,W2_CSTIDV
Local Decimal W1_CSTCLL,W2_CSTCLL
Local Integer W_NBR
Local Char W_TYPCRG(30),W_TYPFIN(30),W_ORGFIN(30)
Return


$FCT_CALCULATE
  Call CALCULATE(W_TCRCOD,[F:COU]TYPCRG,[F:COU]TYPFIN,[F:COU]ORGFIN,W_NBRHOUR,W_NBRNIGHT,AMOUNT,RESULT)From SUBHRTCR
Return
#############################################################
$SET_DEFAULTVALUES_LINECOR_FROMHRTCR
If IS_REP
  [F:HRCOR]TYPFIN2=[F:HRTCR]TYPFIN
  [F:HRCOR]ORGFIN2=[F:HRTCR]ORGFIN
  [F:HRCOR2]=[F:HRCOR]
  [F:HRCOR2]NUMLIG+=1
  [F:HRCOR2]ORGFIN2=[F:HRTCR]ORGFIN2
  Gosub SET_TIMESTAMP_COR
Endif

Return

#############################################################
$SET_DEFAULTVALUES_LINECOU
W_CSTIPTCLL=[F:COU]CSTIPTCLL
W_CSTIPTIDV=[F:COU]CSTIPTIDV
W_CSTTOTCLL=[F:COU]CSTTOTCLL
W_CSTTOTIDV=[F:COU]CSTTOTIDV
If [L]IS_REP
  [F:COU4]=[F:COU2]
  [F:COU4]ORGFIN=[F:COUD]ORGFIN
  [F:COU4]NUMLIG+=1
  Gosub SET_TIMESTAMP_COU
  W_CSTIPTCLL+=[F:COUD]CSTIPTCLL
  W_CSTIPTIDV+=[F:COUD]CSTIPTIDV
  W_CSTTOTCLL+=[F:COUD]CSTTOTCLL
  W_CSTTOTIDV+=[F:COUD]CSTTOTIDV
Endif
Return

#############################################################
$GEST_COUFORNCAL
Gosub DECLARE_VARS_FORREP
Local Integer IS_REP
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(215,10717,1),0) From GESECRAN : # Mise à jour coûts réels Formateurs non calculés
NBENREG5 = 0
# FQ72865 - MABON 04/04/11 - Suppression des coûts de la session qui n'existent plus dans le stage
NBDEL5   = 0
# Mise à jour coûts réels sessions à partir des coûts prévisionnels du stage, relatifs au formateur
Link [F:SESM] With [F:STG]STG0=STG As [ST_] Where evalue(CRITERE)
For [F:ST_]
  Call CALC_FORM(CRITCPY, CRITFCY, FORMATEUR, CONTRAT, FORM_OK)
  If FORM_OK=2 Then
    # FQ72865 - MABON 04/04/11 - Suppression des coûts du stage qui n'existent plus
    # Je supprime tout
    [L]W_TCRCOD=[F:STG]TCRCOD
    Gosub SET_VARS_CALCSES
    # on delete cor and cou in the same
    Call DEL_COU_SES_INS_ALL([F:SESM]COD,  "[F:ADI]N1=3 & [F:ADI]N2=2", NBDEL5)
    Call DEL_COR_SES([F:SESM]COD, "[F:ADI]N1=3 & [F:ADI]N2=2", NBDEL5)
    Filter [COU] Where TYPCOU=1 & STG=[F:STG]COD & SES=""
    Filter [COUD] Where TYPCOU=1 & STG=[F:STG]COD & SES=""&LNKREP<>""
    For [COU]COU0
      If [F:COU]LNKREP="" or right$([F:COU]LNKREP,len([F:COU]LNKREP))<>"D"
        Read [ADI]CODE=10451;[F:COU]TYPCRG
        If !fstat & [F:ADI]N1=3 & [F:ADI]N2=2 Then   : # Coût non calculé pour formateur interne
          MTTIPT=[F:COU]CSTIPTIDV
          MTTTOT=[F:COU]CSTTOTIDV
          If MTTIPT<>0 | MTTTOT<>0 Then
            Call ECR_TRACE("   "-mess(34,10717,1)-[F:SESM]COD-";"-mess(136,10717,1)-FORMATEUR-";"-mess(133,10717,1)-[F:ADI]CODE,0) From GESECRAN : # Session ; Formateur ; Type de coût
          # Mise à jour coûts prévisionnels sessions
            [L]IS_REP=0
            Call CREATE_COU(2, [F:SESM]COD, "", [F:COU]TYPCRG, [F:SESM]TYPFRT, [F:COU]ORGFIN, [F:COU]TYPFIN)
            For [F:COUD] Where LNKREP=[F:COU]LNKREP+"D"
              [L]IS_REP=1
              Break
            Next
            Gosub SET_DEFAULTVALUES_LINECOU
            Gosub AFFECTE_COUT_SES
            Write [F:COU2]
            If fstat Then GOK=1 : Break 2 : Endif
            #NBENREG5+=1

            If [L]IS_REP
              Write [F:COU4]
              If fstat Then GOK=1 : Break 2 : Endif
              #NBENREG5+=1
            Endif

          # Mise à jour coûts réels sessions
            Call CREATE_COR(2, [F:SESM]COD, "", [F:COU]TYPCRG, [F:SESM]TYPFRT, [F:COU]ORGFIN, [F:COU]TYPFIN)
            If [L]IS_REP
                [F:HRCOR2]=[F:HRCOR]
                [F:HRCOR2]NUMLIG+=1
                [F:HRCOR2]ORGFIN2=[F:COUD]ORGFIN
                Gosub SET_TIMESTAMP_COR
            Endif
            Gosub AFFECTE_COR_SES_NC
            Write [F:HRCOR]
            If fstat Then GOK=1 : Break 2 : Endif
            NBENREG5 += 1
            If [L]IS_REP
              Write [F:HRCOR2]
              If fstat Then GOK=1 : Break 2 : Endif
              NBENREG5 += 1
            Endif
          Endif
        Endif
      Endif

    Next
    Filter [COU]
  Endif
Next

Return

#############################################################
Subprog DEL_COR_SES(CODSES, VALN1_N2, NBDEL)
Value    Char    CODSES,VALN1_N2
Variable Integer NBDEL

If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
For[F:ADI] Where NUMTAB=10451
  If evalue(VALN1_N2)>0 Then
      Delete [F:HRCOR] Where TYPCOU=2 & SES=CODSES & TYPCRG2=[F:ADI]CODE
      NBDEL += adxdlrec
  Endif
Next
End

#############################################################
Subprog DEL_COU_SES_INS_ALL(CODSES, VALN1_N2, NBDEL)
Value    Char    CODSES,VALN1_N2
Variable Integer NBDEL

If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
For[F:ADI] Where NUMTAB=10451
  If evalue(VALN1_N2)>0 Then
    Delete [F:COU2] Where TYPCOU=2 & SES=CODSES & TYPCRG=[F:ADI]CODE
    NBDEL+=adxdlrec
    For [F:INS] Where SES=CODSES
      Delete [F:HRCOR] Where TYPCOU=3 & SES=CODSES & REFNUM=[F:INS]REFNUM & TYPCRG2=[F:ADI]CODE
      NBDEL += adxdlrec
    Next
  Endif
Next
End

##########################################################################
$DECLARE_VARS_NEW
Local Integer W_NBR
Local Decimal RESULT(0..1)
Local Integer  IS_REP, IS_SAVE

Local Decimal W_CSTIPTCLL,W_CSTIPTIDV
Local Decimal W_CSTTOTCLL,W_CSTTOTIDV

Return

$GETVAL_COUT_CSTIPTIDV
  AMOUNT=W_CSTIPTIDV
  If W_CSTIPTCLL>0 :  AMOUNT=W_CSTIPTCLL/W_NBR    : Endif
  RESULT(0)=AMOUNT
  If IS_REP        :  Gosub FCT_CALCULATE         : Endif
Return

$GETVAL_COUT_CSTTOTIDV
  AMOUNT=W_CSTTOTIDV
  If W_CSTTOTCLL>0  :  AMOUNT=W_CSTTOTCLL/W_NBR   : Endif
  RESULT(0)=AMOUNT
  If IS_REP        :  Gosub FCT_CALCULATE         : Endif
Return

$INI_TIMESTAMP
 TIMESTP=timestamp$ # X3PEOP-3477

Return

$SET_TIMESTAMP_COR
  Gosub INI_TIMESTAMP
  [F:HRCOR]LNKREP=TIMESTP # X3PEOP-3477
  [F:HRCOR2]LNKREP=TIMESTP+"D"
Return

$SET_TIMESTAMP_COU
  Gosub INI_TIMESTAMP
  [F:COU2]LNKREP=TIMESTP # X3PEOP-3477
  [F:COU4]LNKREP=TIMESTP+"D"
Return
