#**#####################################################################################
#* Calcul critère sur les sites du contrat
#*!
Funprog CALC_CRITFCY
Local Char CRITERE(255)

  CRITERE = "1=1"
  # FQ72854 - MABON 01/04/11 - Le site n'est plus dans les critères de sélection
#  If [M:CREE]ALLFCY<>2      Then CRITERE -= "& [F:HRCTR]ETRFCY='"+[M:CREE]FCY+"'"      : Endif
End CRITERE

#**#####################################################################################
#* Calcul critère sur les sessions
#*!
Funprog CALC_CRITSES
Local Char CRITERE(255)

  CRITERE = "1=1"
  If [M:CREE]STRSES<>""      Then CRITERE -= "& [F:SESM]COD>='"+[M:CREE]STRSES+"'"    : Endif
  If [M:CREE]ENDSES<>""      Then CRITERE -= "& [F:SESM]COD<='"+[M:CREE]ENDSES+"'"    : Endif
End CRITERE

#**#####################################################################################
#* Calcul critère sur les stages
#*!
Funprog CALC_CRITSTG
Local Char CRITERE(255)

  CRITERE = "1=1"
  If [M:CREE]STRSTG<>""      Then CRITERE -= "& [F:SESM]STG>='"+[M:CREE]STRSTG+"'"    : Endif
  If [M:CREE]ENDSTG<>""      Then CRITERE -= "& [F:SESM]STG<='"+[M:CREE]ENDSTG+"'"    : Endif

  # SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini
  Local Char L_STAGE_NON_DEF(GLONSTG)
  L_STAGE_NON_DEF = func DIVFOR.GET_STG_NON_DEF
  If L_STAGE_NON_DEF <> "" Then
    CRITERE -= "& [F:SESM]STG<>'"+L_STAGE_NON_DEF+"'"
  Endif

End CRITERE

#**#####################################################################################
#* Calcul critère sur les dates
#*!
Funprog CALC_CRITDAT
Local Char CRITERE(255)

  CRITERE = "1=1"
  #If [M:CREE]STRDAT<>[0/0/0] Then CRITERE -= "& [F:SESM]STRDAT>=["+format$("D:"+GFMDAT4,[M:CREE]STRDAT)+"]" : Endif
  #If [M:CREE]ENDDAT<>[0/0/0] Then CRITERE -= "& [F:SESM]STRDAT<=["+format$("D:"+GFMDAT4,[M:CREE]ENDDAT)+"]" : Endif
  If [M:CREE]STRDAT<>[0/0/0] Then CRITERE -= "& [F:SESM]STRDAT>=[M:CREE]STRDAT" : Endif
  If [M:CREE]ENDDAT<>[0/0/0] Then CRITERE -= "& [F:SESM]STRDAT<=[M:CREE]ENDDAT" : Endif
End CRITERE

#**
#* Calcul de la société et du site pour le stage, la session et le matricule
#*!
$CALC_INFOS_CFY
Local Date DATSTR, DATEND

  # Calcul dates inscription
  Filter [F:INJ] Where STG=[F:INS]STG & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM Order By DAT
  Read [F:INJ] First : DATSTR=[F:INJ]DAT
  Read [F:INJ] Last  : DATEND=[F:INJ]DAT
  Filter [F:INJ]
  # Recherche site du contrat
  Filter [F:HRCTR] Where REFNUM=[F:INS]REFNUM & CTRNUM=[F:INS]CTRNUM & (CTRDAT>=DATSTR | CTRDAT<=DATEND) Order By CTRDAT Desc
  Read [F:HRCTR] First
  Filter [F:HRCTR]
  # Recherche société du contrat
  Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
Return

# Détermine le formateur et le contrat, et vérifie qu'il correspond au niveau de la société et du site éventuellement saisis
Subprog CALC_FORM(CRITCPY, CRITFCY, FORMATEUR, CONTRAT, FORM_OK)
Value    Char    CRITCPY, CRITFCY
Variable Char    FORMATEUR, CONTRAT
Variable Integer FORM_OK
Local    Date    DATSTR, DATEND
Local    Char    FORMEXT(GLONORG)

  # FQ89516 - 26/04/13 - Recherche d'abord dans la session, et ensuite dans le stage
#  # Recherche du formateur interne
#  FORMATEUR=[F:STG]TCHEMP : CONTRAT=[F:STG]CTRNUM
#  If FORMATEUR="" Then FORMATEUR=[F:SESM]TCHEMP : CONTRAT=[F:SESM]CTRNUM Endif
#  # FQ71040 - MABON 22/03/11 - Recherche du formateur externe
#  FORMEXT=[F:STG]ORG : If FORMEXT="" Then FORMEXT=[F:STG]TCHNAM : Endif
#  If FORMEXT="" Then FORMEXT=[F:SESM]ORG    : Endif
#  If FORMEXT="" Then FORMEXT=[F:SESM]TCHNAM : Endif
  # Recherche du formateur interne
  FORMATEUR=[F:SESM]TCHEMP : CONTRAT=[F:SESM]CTRNUM
  If FORMATEUR="" Then FORMATEUR=[F:STG]TCHEMP : CONTRAT=[F:STG]CTRNUM Endif
  # FQ71040 - MABON 22/03/11 - Recherche du formateur externe
  FORMEXT=[F:SESM]ORG : If FORMEXT="" Then FORMEXT=[F:SESM]TCHNAM : Endif
  If FORMEXT="" Then FORMEXT=[F:STG]ORG    : Endif
  If FORMEXT="" Then FORMEXT=[F:STG]TCHNAM : Endif
  # Fin FQ89516

  FORM_OK=2
  # FQ71040 - MABON 22/03/11 - Ajout test sur formateur externe
#  If [F:SESM]FRTINT=2 & FORMATEUR<>"" & FORMEXT="" Then
  # FQ73113 - MABON 11/04/11 - Si le formateur interne n'est pas renseigné, on calcule quand même
  If ([F:SESM]FRTINT=2 | FORMATEUR<>"") & FORMEXT="" Then
    # Calcul dates session
    DATSTR=[F:HRSES]STRDAT : DATEND=[F:HRSES]ENDDAT
    # Recherche site du contrat
    Filter [F:HRCTR] Where REFNUM=FORMATEUR & CTRNUM=CONTRAT & (CTRDAT>=DATSTR | CTRDAT<=DATEND) Order By CTRDAT Desc
    Read [F:HRCTR] First
    Filter [F:HRCTR]
    # Recherche société du contrat
    Read [F:FCY]FCY0=[F:HRCTR]ETRFCY

    Read [F:ID]ID0=FORMATEUR
    If !fstat & (CRITCPY<>"" | CRITFCY<>"") Then
      If !evalue(CRITCPY) or !evalue(CRITFCY) Then FORM_OK=1 Endif
    Endif
  # FQ71040 - MABON 22/03/11 - Le test sur FRTINT a été remonté
#  Elsif [F:SESM]FRTINT<>2 Then : # Si le formateur n'est pas renseigné, et que le stage n'est pas interne, on calcule pas
  Else : # Si le formateur n'est pas renseigné, et que le stage n'est pas interne, on calcule pas
    FORM_OK=1
  Endif
End

# Calcul des coûts formateur calculés (sous-pro utilisé ici et dans SUBHRSES)
Subprog CALC_COUFORCAL(CODSES, CODSTG, PCPY, TRACE, CRITCPY, CRITFCY, NBENR)
Value    Char    CODSES, CODSTG, PCPY, CRITCPY, CRITFCY
Value    Integer TRACE
Variable Integer NBENR
Local    Char    FORMATEUR(GLONEML), CONTRAT(GLONHRCTR)
Local    Date    DATSTR, DATEND
Local    Integer FORM_OK
Local    Decimal MTTIPT, MTTTOT

Local Char TIMESTP(30)
Local Integer IS_COR2,IS_SAVE, W_NBENR
Local Integer W_NBRNIGHT
Local Decimal W_NBRHOUR
Local Char W_TCRCOD(30),W_TYPCRG(30)
Local Decimal RESULT(0..1)

  # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUFOR, on calcule ou pas les coûts formateur
  If GCALCOUFOR<>2 Then End : Endif

  If clalev([F:SESM])=0 : Local File SESSIONS [SESM] : Endif
  If clalev([F:STG])=0  : Local File STAGE    [STG]  : Endif
  If clalev([F:FCY])=0  : Local File FACILITY [FCY]  : Endif
  If clalev([F:ID])=0   : Local File EMPLOID  [ID]   : Endif
  If [F:SESM]COD<>CODSES Then
    Read [F:SESM]SES0=CODSES
  Endif
  If [F:STG]COD<>CODSTG Then
    Read [F:STG]STG0=CODSTG
  Endif

  Local Char  W_TCRCOD(30)
  If !fstat
    W_TCRCOD=[F:STG]TCRCOD
  Endif
  W_NBRHOUR =[F:SESM]NBRHOUIPT
  W_NBRNIGHT =[F:SESM]NBRNGT

  Call CALC_FORM(CRITCPY, CRITFCY, FORMATEUR, CONTRAT, FORM_OK)
  If FORM_OK=2 Then
    Filter [F:ADI] Where NUMTAB=10451 & N1<3 & N2=2  : # Coût calculé pour formateur interne
    For [F:ADI]
      [L]W_TYPCRG= [F:ADI]CODE
      Gosub GET_RECORD_REP From TRTCOUT
      Call CALC_MTT(FORMATEUR, CONTRAT, [F:SESM]STRDAT, [F:SESM]ENDDAT, [F:SESM]NBRHOUIPT, PCPY, MTTTOT, MTTIPT)
      Delete [F:HRCOR] Where TYPCOU=2 & SES=[F:SESM]COD & TYPCRG2=[F:ADI]CODE
      If MTTIPT<>0 | MTTTOT<>0 Then
        If TRACE=2 Then
          Call ECR_TRACE("   "-mess(34,10717,1)-[F:SESM]COD-";"-mess(136,10717,1)-FORMATEUR-";"-mess(133,10717,1)-[F:ADI]CODE,0) From GESECRAN : # Session ; Formateur ; Type de coût
        Endif
        # Mise à jour coûts réels sessions
        Filter [F:HRCOR] Where TYPCOU=2 & SES=[F:SESM]COD & TYPCRG2=[F:ADI]CODE
        If rowcount([F:HRCOR])>0 Then
          For [F:HRCOR]
            Gosub AFFECTE_COR_SES_C
            Rewrite [F:HRCOR]
            If fstat Then GOK=1 : Break 3 : Endif
            NBENR += 1
          Next
        Else
          Call CREATE_COR(2, [F:SESM]COD, "", [F:ADI]CODE, [F:SESM]TYPFRT, "", "")
          Gosub SET_DEFAULTVALUES_LINECOR_FROMHRTCR
          Gosub AFFECTE_COR_SES_C
          Write [F:HRCOR]
          If fstat Then GOK=1 : Break 2 : Endif
          NBENR += 1
        Endif
        Filter [F:HRCOR]
      Endif
    Next
    Filter [F:ADI]
  Endif
End

#**#####################################################################################
#* Affectation des coûts prévisionnels de la session :
#*    - Si le coût collectif du stage est renseigné, on récupère le coût collectif du stage dans le coût collectif
#*      de la session, et le coût individuel de la session est le coût collectif du stage divisé par le nbr standard
#*      de la session
#*    - Si le coût collectif du stage n'est pas renseigné, on ne veut récupérer que le coût individuel dans le coût
#*      de la session
#*!
$AFFECTE_COUT_SES
#ADNGO - 2017-06-28 - X3-29547 - START
#  If [F:COU]CSTIPTCLL>0 Then
#    [F:COU2]CSTIPTCLL=[F:COU]CSTIPTCLL
#    [F:COU2]CSTIPTIDV=[F:COU]CSTIPTCLL/[F:SESM]NBRPRTSTD
#  Else
#    [F:COU2]CSTIPTIDV=[F:COU]CSTIPTIDV
#  Endif
#  If [F:COU]CSTTOTCLL>0 Then
#    [F:COU2]CSTTOTCLL=[F:COU]CSTTOTCLL
#    [F:COU2]CSTTOTIDV=[F:COU]CSTTOTCLL/[F:SESM]NBRPRTSTD
#  Else
#    [F:COU2]CSTTOTIDV=[F:COU]CSTTOTIDV
#  Endif

   W_NBR=[F:SESM]NBRPRTSTD
  Gosub SET_VARS_CALCSES

  # Case  CSTIPTCLL-CSTIPTIDV
  Gosub GETVAL_COUT_CSTIPTIDV

  # CSTIPTIDV
  [F:COU2]CSTIPTIDV=arr(RESULT(0),0.01)
  If IS_REP
    [F:COU4]CSTIPTIDV=arr(RESULT(1),0.01)
  Endif
  # CSTIPTCLL
  If W_CSTIPTCLL>0 Then
    [F:COU2]CSTIPTCLL=arr(RESULT(0)*W_NBR,0.01)
    If IS_REP
      [F:COU4]CSTIPTCLL=arr(RESULT(1)*W_NBR,0.01)
    Endif
  Endif

  # Case  CSTTOTCLL-W_CSTTOTIDV
  Gosub GETVAL_COUT_CSTTOTIDV

  # CSTTOTIDV
  [F:COU2]CSTTOTIDV=arr(RESULT(0),0.01)
  If IS_REP
    [F:COU4]CSTTOTIDV=arr(RESULT(1),0.01)
  Endif
  # CSTTOTCLL
  If W_CSTTOTCLL>0 Then
    [F:COU2]CSTTOTCLL=arr(RESULT(0)*W_NBR,0.01)
    If IS_REP
      [F:COU4]CSTTOTCLL=arr(RESULT(1)*W_NBR,0.01)
    Endif
  Endif
#ADNGO - 2017-06-28 - X3-29547 - END
Return

#**#####################################################################################
#* Affectation des coûts individuels réels calculés
#*    - Pour la session :
#*        * MTTIPT est le coût imputable individuel calculé pour le formateur
#*        * MTTTOT est le coût total individuel calculé pour le formateur
#*    - Pour l'inscription :
#*        * MTTIPT est le coût imputable individuel calculé pour le participant
#*        * MTTTOT est le coût total individuel calculé pour le participant
#*!
$AFFECTE_COR_SES_C
#ADNGO - 2017-06-28 - X3-29547 - START
#  [F:HRCOR]CSTIPTIDV2 = MTTIPT
#  [F:HRCOR]CSTTOTIDV2 = MTTTOT

  RESULT(0)= MTTIPT
  If IS_REP
    Call  CALCULATE([L]W_TCRCOD,[F:HRCOR]TYPCRG2,[F:HRCOR]TYPFIN2,[F:HRCOR]ORGFIN2,[L]W_NBRHOUR,[L]W_NBRNIGHT,MTTIPT,RESULT) From SUBHRTCR
    [F:HRCOR2]CSTIPTIDV2=arr(RESULT(1),0.01)
  Endif
  [F:HRCOR]CSTIPTIDV2=arr(RESULT(0),0.01)
  RESULT(0)= MTTTOT
  If IS_REP
    Call  CALCULATE([L]W_TCRCOD,[F:HRCOR]TYPCRG2,[F:HRCOR]TYPFIN2,[F:HRCOR]ORGFIN2,[L]W_NBRHOUR,[L]W_NBRNIGHT,MTTTOT,RESULT) From SUBHRTCR
    [F:HRCOR2]CSTTOTIDV2=arr(RESULT(1),0.01)
  Endif
  [F:HRCOR]CSTTOTIDV2 =arr(RESULT(0),0.01)
#ADNGO - 2017-06-28 - X3-29547 - END
Return

#**#####################################################################################
#* Affectation des coûts individuels réels non calculés de la session
#*    - Si le coût collectif du stage est renseigné, on récupère le coût collectif du stage dans le coût collectif
#*      de la session
#*    - Si le coût collectif du stage n'est pas renseigné, le coût individuel du stage est multiplié par le nbr
#*      standard de la session
#*!
$AFFECTE_COR_SES_NC
#ADNGO - 2017-06-28 - X3-29547 - START
#  If [F:COU]CSTIPTCLL>0 Then
#    [F:HRCOR]CSTIPTIDV2=[F:COU]CSTIPTCLL
#  Else
#    [F:HRCOR]CSTIPTIDV2=[F:COU]CSTIPTIDV*[F:SESM]NBRPRTSTD
#  Endif
#  If [F:COU]CSTTOTCLL>0 Then
#    [F:HRCOR]CSTTOTIDV2=[F:COU]CSTTOTCLL
#  Else
#    [F:HRCOR]CSTTOTIDV2=[F:COU]CSTTOTIDV*[F:SESM]NBRPRTSTD
#  Endif

   W_NBR=[F:SESM]NBRPRTSTD
  If W_CSTIPTCLL>0
    RESULT(0)=[F:COU]CSTIPTCLL
    If IS_REP
      RESULT(0)=[F:COU2]CSTIPTCLL
      RESULT(1)=[F:COU4]CSTIPTCLL
    Endif
  Else
   RESULT(0)=[F:COU]CSTIPTIDV*W_NBR
   If IS_REP
      RESULT(0)=[F:COU2]CSTIPTIDV*W_NBR
      RESULT(1)=[F:COU4]CSTIPTIDV*W_NBR
   Endif
  Endif
  # CSTIPTIDV2
  [F:HRCOR]CSTIPTIDV2=RESULT(0)
  If IS_REP
    [F:HRCOR2]CSTIPTIDV2=RESULT(1)
  Endif

  If W_CSTTOTCLL>0 Then
     RESULT(0)=[F:COU]CSTTOTCLL
    If IS_REP
      RESULT(0)=[F:COU2]CSTTOTCLL
      RESULT(1)=[F:COU4]CSTTOTCLL
    Endif
  Else
    RESULT(0)=[F:COU]CSTTOTIDV*W_NBR
   If IS_REP
      RESULT(0)=[F:COU2]CSTTOTIDV*W_NBR
      RESULT(1)=[F:COU4]CSTTOTIDV*W_NBR
   Endif
  Endif
  # CSTTOTIDV2
  [F:HRCOR]CSTTOTIDV2=RESULT(0)
  If IS_REP
    [F:HRCOR2]CSTTOTIDV2=RESULT(1)
  Endif
#ADNGO - 2017-06-28 - X3-29547 - END
Return

#**#####################################################################################
#* Affectation des coûts réels de l'inscription :
#*    - Si le coût collectif de la session est renseigné, le coût individuel de l'inscription est le coût collectif
#*      de la session divisé par le nbr réel d'inscrits
#*    - Si le coût collectif de la session n'est pas renseigné, on ne veut récupérer que le coût individuel dans le
#*      coût individuel de l'inscription
#*!
$AFFECTE_COR_INS
#ADNGO - 2017-06-28 - X3-29547 - START
#  If [F:COU]CSTIPTCLL>0 Then : # Coût collectif
#    [F:HRCOR]CSTIPTIDV2=arr([F:COU]CSTIPTCLL/NBRINS,0.01)
#  Else : # Coût individuel
#    [F:HRCOR]CSTIPTIDV2=[F:COU]CSTIPTIDV
#  Endif
#  If [F:COU]CSTTOTCLL>0 Then : # Coût collectif
#    [F:HRCOR]CSTTOTIDV2=arr([F:COU]CSTTOTCLL/NBRINS,0.01)
#  Else : # Coût individuel
#    [F:HRCOR]CSTTOTIDV2=[F:COU]CSTIPTIDV
#  Endif

  W_NBR=NBRINS
  Gosub GETVAL_COUT_CSTIPTIDV
  If IS_REP and  W_CSTIPTCLL=0
    RESULT(0)=[F:COU2]CSTIPTIDV
    RESULT(1)=[F:COU4]CSTIPTIDV
  Endif

  [F:HRCOR]CSTIPTIDV2=arr(RESULT(0),0.01)
  If IS_REP
    [F:HRCOR2]CSTIPTIDV2=arr(RESULT(1),0.01)
  Endif

  Gosub GETVAL_COUT_CSTTOTIDV
  If IS_REP and  W_CSTTOTCLL=0
    #RESULT(0)=[F:COU2]CSTIPTIDV    : # à verifier...bizarre
    #RESULT(1)=[F:COU4]CSTIPTIDV
    RESULT(0)=[F:COU2]CSTTOTIDV
    RESULT(1)=[F:COU4]CSTTOTIDV
  Endif

  [F:HRCOR]CSTTOTIDV2=arr(RESULT(0),0.01)
  If IS_REP
    [F:HRCOR2]CSTTOTIDV2=arr(RESULT(1),0.01)
  Endif
#ADNGO - 2017-06-28 - X3-29547 - END
Return

#**#####################################################################################
#* FQ72865 - MABON 04/04/11 - Suppression des coûts de la session qui n'existent plus dans le stage
#* C'est à faire uniquement pour les coûts qui peuvent être existants dans l'onglet Organisation du stage, c'est à dire
#* les coûts Non calculés, qu'ils soient Participants, Formateurs ou Autres
#* Ce sous-pro est donc appelé uniquement si on a coché les cases suivantes :
#*    - Coûts formateur non calculés
#*    - Et/ou Coûts participants non calculés
#*    - Et/ou Autres coûts
#*!
Subprog DEL_COU_SES(CODSES, CODSTG, VALN1_N2, NBDEL)
Value    Char    CODSES, CODSTG, VALN1_N2
Variable Integer NBDEL

  For [F:COU2] Where TYPCOU=2 & SES=CODSES
    Read [ADI]CODE=10451;[F:COU2]TYPCRG
    If !fstat & evalue(VALN1_N2)>0 Then
      Filter [F:COU] Where TYPCOU=1 & STG=CODSTG & TYPCRG=[F:ADI]CODE & TYPFIN=[F:COU2]TYPFIN & ORGFIN=[F:COU2]ORGFIN
      If rowcount([F:COU])=0 Then
        TYPCRG_D = [F:COU2]TYPCRG
        TYPFIN_D = [F:COU2]TYPFIN
        ORGFIN_D = [F:COU2]ORGFIN

        # On supprime le coût dans la session
        Delete [F:COU2] Curr

        If !fstat Then
          # Si on a supprimé le coût dans la session, il faut peut-être aussi le supprimer dans l'inscription
          Filter [F:INS] Where SES=CODSES
          NBRINS = rowcount([F:INS])
          For [F:INS]
            Call DEL_COU_INS(CODSES, CODSTG, [F:INS]REFNUM, TYPCRG_D, TYPFIN_D, ORGFIN_D, NBDEL)
          Next
          # Si le coût n'existe pas dans l'inscription, il faut quand même indiquer qu'on l'a supprimé dans la session
          If NBDEL=0 Then NBDEL=1 : Endif
        Endif
      Endif
      Filter [F:COU]
    Endif
  Next
End

#**#####################################################################################
#* FQ72865 - MABON 04/04/11 - Suppression des coûts de l'insription qui n'existent plus dans le stage
#*!
Subprog DEL_COU_INS(CODSES, CODSTG, MAT, TYPCRG_D, TYPFIN_D, ORGFIN_D, NBDEL)
Value    Char    CODSES, CODSTG, MAT, TYPCRG_D, TYPFIN_D, ORGFIN_D
Variable Integer NBDEL

  If clalev([F:COU3])=0 : Local File COUT [COU3] : Endif
  For [F:HRCOR] Where TYPCOU=3 & SES=CODSES & REFNUM=MAT & TYPCRG2=TYPCRG_D & TYPFIN2=TYPFIN_D & ORGFIN2=ORGFIN_D
    Filter [F:COU3] Where TYPCOU=1 & STG=CODSTG & TYPCRG=TYPCRG_D & TYPFIN=TYPFIN_D & ORGFIN=ORGFIN_D
    If rowcount([F:COU3])=0 Then
      Delete [F:HRCOR] Curr
      NBDEL += adxdlrec
    Endif
    Filter [F:COU3]
  Next
End

