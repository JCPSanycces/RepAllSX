#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Création
#     MABON - 31/08/10 - EXI 66191 LOT 5
#              - Mise à jour des coûts réels participants, formateurs ou autres
#     SYMEU - 04/10/10 - EXI 66191 LOT 10 - V6.1 : stage non défini
######################################################################################

$ACTION

  Case ACTION
    When "INIT_DIA"   : Gosub INIT_DIA
    When "CONTROLE"   : Gosub CONTROLE
    When "EXEC"       : Gosub EXEC
  Endcase
Return

#**#####################################################################################
#* Initialisation des paramètres avec les données connues de la session
#*!
$INIT_DIA

  [M:CREE]STRSES = [M:HRSES0]COD    : [M:CREE]ENDSES = [M:HRSES0]COD
  [M:CREE]STRSTG = [M:HRSES0]STG    : [M:CREE]ENDSTG = [M:HRSES0]STG
  [M:CREE]STRDAT = [M:HRSES1]STRDAT : [M:CREE]ENDDAT = [M:HRSES1]ENDDAT
Return

#####################################
$CONTROLE

  If GSTATUT<>GSTAOK
    FIN = 1
  Else
    TMP = 1
    TRA = 1
  Endif
Return

#**#####################################################################################
#* Exécution de l'action
#*!
$EXEC
Local Integer NBENREG1, NBENREG2, NBENREG3, NBENREG4, NBENREG5
# FQ72865 - MABON 04/04/11 - Suppression des coûts de la session qui n'existent plus dans le stage
Local Integer NBDEL1, NBDEL2, NBDEL5

  If clalev([F:SESM])=0     : Local File SESSIONS [SESM]  : Endif
  If clalev([F:TRN])=0      : Local File TRAINER  [TRN]   : Endif
  If clalev([F:INS])=0      : Local File INSCRIPT [INS]   : Endif
  If clalev([F:INJ])=0      : Local File INSJOU   [INJ]   : Endif
  If clalev([F:HRCTR])=0    : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:COU])=0      : Local File COUT     [COU]   : Endif
  If clalev([F:COU2])=0     : Local File COUT     [COU2]  : Endif
  If clalev([F:HRCOR])=0    : Local File COUTREEL [HRCOR] : Endif
  #  X3PEOP-3476
  If clalev([F:HRCOR2])=0   : Local File COUTREEL [HRCOR2]  : Endif
  If clalev([F:COUD])=0   : Local File COUT     [COUD]  : Endif
  If clalev([F:COU4])=0   : Local File COUT     [COU4]  : Endif

  TIT = mess(127,10717,1) : # Mise à jour des coûts réels
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(TIT-mess(34,10717,1)-":"-[M:CREE]STRSES-mess(46,100,1)-[M:CREE]ENDSES,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

  SYMBOLE = "COUMAJ"
  Lock =SYMBOLE
  If fstat
    GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
    Unlock =SYMBOLE
    GERR = 1 : SAI = 1 : Return
  Endif

  Call DEBTRANS From GLOCK

  Gosub TR1

  Unlock =SYMBOLE

  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call FERME_TRACE From LECFIC
Return

