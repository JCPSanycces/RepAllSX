#<AdxTL>@(#)4.0.0.0 $Revision$

##########################################################################
# UUMTC     Squelette pour Moulinette                      Module CPT    #
#            description de la moulinette                                #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UUMTC71182 Process") From LECFIC

  Call MAJ_71182(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_71182(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, NBRPYH
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30), ACLE5(30)
Local Integer ICLE1, ICLE2, ICLE3

Local Char SVG_NUM(30)

Call ECR_TRACE("UUMTC 1/2: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:DAE])  =0  Local File =DOSSIER+".GACCENTRYD"   [DAE] : Endif
If clalev([F:DUD])  =0  Local File =DOSSIER+".GACCDUDATE"   [DUD] : Endif

Link [DUD] With [DAE]DAE2=[F:DUD]ACCNUM
&   As [LNK] Where [F:DAE]MTC="" & [F:DUD]PAYCUR+[F:DUD]PAYLOC<>0
&   Order By Key CLE = [F:DAE]TYP;[F:DAE]NUM;[F:DAE]LIN;[F:DAE]LEDTYP

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
Raz COMPTEUR

$LOOP_DAE1
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:DAE]TYP='"+ACLE1+"' & [F:DAE]NUM='"+ACLE2+"' & [F:DAE]LIN="+num$(ICLE1)+" & [F:DAE]LEDTYP>"+num$(ICLE2)
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:DAE]TYP='"+ACLE1+"' & [F:DAE]NUM='"+ACLE2+"' & [F:DAE]LIN="+num$(ICLE1)
Elsif STOP=3
 STOP = 4
 CRITERE = "[F:DAE]TYP='"+ACLE1+"' & [F:DAE]NUM='"+ACLE2+"'"
Elsif STOP=4
 STOP = 0
 CRITERE = "[F:DAE]TYP>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
For [LNK]CLE Where evalue(CRITERE)
 Call ECR_TRACE([F:DAE]FCYLIN-[F:DAE]TYP-[F:DAE]NUM-[F:DAE]ACC-[F:DAE]BPR-num$([F:DAE]ACCNUM)-":"-mess(24,119,1),0) From GESECRAN
 NB+=1
 COMPTEUR+=1
 If NB>GMAXUPDTRS 
  ACLE1 = [F:DAE]TYP
  ACLE2 = [F:DAE]NUM
  ICLE1 = [F:DAE]LIN
  ICLE2 = [F:DAE]LEDTYP
  STOP=1
  Break
 Endif
Next

If STOP
 Goto LOOP_DAE1
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [DAE], [DUD]

Call ECR_TRACE("UUMTC 1/2 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN


$DAE2
Call ECR_TRACE("UUMTC 2/2: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:DAE])  =0 : Local File =DOSSIER+".GACCENTRYD"   [DAE] : Endif
If clalev([F:GAC])  =0 : Local File =DOSSIER+".GACCOUNT"     [GAC] : Endif

Local Decimal EQL,EQLLED
Local Char SVG(60)

Link [DAE] With [GAC]GAC0=[F:DAE]COA;[F:DAE]ACC
&   As [LNK] Where [F:GAC]MTC=2 & [F:GAC]SAC<>2 & [F:DAE]MTC>"A" & [F:DAE]MTC<"ZZZZZZ"
&   Order By Key CLE = [F:DAE]CPY;[F:DAE]FCYLIN;[F:DAE]LEDTYP;[F:DAE]ACC;[F:DAE]BPR;[F:DAE]MTC;[F:DAE]ACCNUM

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
Raz COMPTEUR

$LOOP_DAE2
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:DAE]CPY='"+ACLE1+"' & [F:DAE]FCYLIN='"+ACLE2+"' & [F:DAE]LEDTYP="+num$(ICLE1)+" & [F:DAE]ACC='"+ACLE3+"' & [F:DAE]BPR='"+ACLE4+"' & [F:DAE]MTC='"+ACLE5+"' & [F:DAE]ACCNUM>"+num$(ICLE2)
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:DAE]CPY='"+ACLE1+"' & [F:DAE]FCYLIN='"+ACLE2+"' & [F:DAE]LEDTYP="+num$(ICLE1)+" & [F:DAE]ACC='"+ACLE3+"' & [F:DAE]BPR='"+ACLE4+"' & [F:DAE]MTC>'"+ACLE5+"'"
Elsif STOP=3
 STOP = 4
 CRITERE = "[F:DAE]CPY='"+ACLE1+"' & [F:DAE]FCYLIN='"+ACLE2+"' & [F:DAE]LEDTYP="+num$(ICLE1)+" & [F:DAE]ACC='"+ACLE3+"' & [F:DAE]BPR>'"+ACLE4+"'"
Elsif STOP=4
 STOP = 5
 CRITERE = "[F:DAE]CPY='"+ACLE1+"' & [F:DAE]FCYLIN='"+ACLE2+"' & [F:DAE]LEDTYP="+num$(ICLE1)+" & [F:DAE]ACC>'"+ACLE3+"'"
Elsif STOP=5
 STOP = 6
 CRITERE = "[F:DAE]CPY='"+ACLE1+"' & [F:DAE]FCYLIN='"+ACLE2+"' & [F:DAE]LEDTYP>"+num$(ICLE1)
Elsif STOP=6
 STOP = 7
 CRITERE = "[F:DAE]CPY='"+ACLE1+"' & [F:DAE]FCYLIN>'"+ACLE2+"'"
Elsif STOP=7
 STOP = 0
 CRITERE = "[F:DAE]CPY>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif


For [LNK]CLE(6) Where evalue(CRITERE)
  Raz EQL, EQLLED
  SVG = [F:DAE]CPY-[F:DAE]FCYLIN-num$([F:DAE]LEDTYP)-[F:DAE]ACC-[F:DAE]BPR-[F:DAE]MTC
  For [LNK]CLE
   EQL+=[F:DAE]AMTCUR*[F:DAE]SNS
   EQLLED+=[F:DAE]AMTLED*[F:DAE]SNS
  Next
  If EQL<>0 & EQLLED<>0
   # Imputations déséquilibrées
   Call ECR_TRACE(SVG-":"-mess(8,110,1)-"("+num$(EQL)+"/"+num$(EQLLED)+")",0) From GESECRAN
  Endif
  NB+=1
  COMPTEUR+=1
  If NB>GMAXUPDTRS
   ACLE1 = [F:DAE]CPY
   ACLE2 = [F:DAE]FCYLIN
   ICLE1 = [F:DAE]LEDTYP
   ACLE3 = [F:DAE]ACC
   ACLE4 = [F:DAE]BPR
   ACLE5 = [F:DAE]MTC
   ICLE2 = [F:DAE]ACCNUM
   STOP=1
   Break
  Endif
Next

If STOP
 Goto LOOP_DAE2
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [DAE]

Call ECR_TRACE("UUMTC 2/2 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN
End



