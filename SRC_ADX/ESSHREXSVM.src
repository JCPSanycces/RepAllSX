#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "SETBOUT"     : Gosub SETBOUT
Endcase

Return

$SETBOUT
If REPONSE = 1102 or REPONSE = 1101
  #Disable sign buttons
  Call VIREBOUT(CHMEN,"a") From GOBJET
  Call VIREBOUT(CHMEN,"b") From GOBJET
Endif
Return

$OUVRE
#Manage Localisations
Call MANAGE_LOCALISATION("ESSHREXSVM") From DIVPAYE
Return

$DEBUT
#-------------------------------Hybrid----------------------------------#
Local Char VPARAM1(100)
Local Char VPARAM2(100)
Local Char VPARAM3(100)


VPARAM1 = PARAM(1)
VPARAM2 = PARAM(2)
VPARAM3 = PARAM(3)

If PARAM(6)="ESSWRKEXS"
  Gosub SET_EXSPARAM From ESSHREXSV
  Gosub UPDATE_FROM_EXPESSAWS From ESSHREXSV
Else
  Gosub UPDATE_FROM_EXPENSESESS From ESSHREXSV

Endif

#Setting GCURLEG
[V]GCURLEG = [M:ESEXV]LEG
#Save paramaters for other actions
[M:ESEXV]DEST      = PARAM(4)
[M:ESEXV]CHRONO    = PARAM(5)

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSHREXSVMHIDE
Call SHOW_LEGACTCALLS From WESSHREXSVMSHOW

Affzo [M:ESEXV]1-99

Return

