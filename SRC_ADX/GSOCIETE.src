#<AdxTL>@(#)4.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
Raz GPILOBJ,GBIDC1,GBIDC2
GDEFSOC="ADX"
Call OBJET("XOB",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "CHX_TABLE" : Gosub CHX_TABLE
 When "OUVRE"     : Gosub OUVRE
 When Default
  If dim(GESSOC)>0 & GESSOC>0
   TT = GESSOC
   Case ACTION
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "GRISE"        : Gosub GRISE
    When "DEGRISE"      : Gosub DEGRISE
    When "LIENS"        : Gosub LIENS
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE
    When "GAUCHE"       : Gosub GAUCHE
    When "GAUCHE9"      : Gosub GAUCHE9
    When "RAZCRE"       : Gosub RAZCRE
    When "CREATION"     : Gosub CREATION
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "AVANT_MODFIC" : Gosub AVANT_MODFIC
    When "INIMOD"       : Gosub INIMOD
    When "MODIF"        : Gosub MODIF
    When "DROIT"        : Gosub DROIT
    When "APRES_CHOI"   : Gosub APRES_CHOI
    When "ABANDON"      : Gosub ABANDON
    When "SETBOUT"      : Gosub SETBOUT
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When "LEC_DERLU"    : Gosub LEC_DERLU
   Endcase
  Endif
Endcase
Return

$OUVRE
Local Char    SOCCUR(GLONCPY) , OLDSOC(GLONCPY)
Local Char    BOX1(10) , BOX2(10) , BOX9(10)
Local Char    BRW1(GLONAOB) , BRW2(GLONAOB)
Local Char    ABRCPY(5) , OBJET(GLONAOB)
Local Integer GESSOC , OKACC , AUTORSOC , NEWCPY , UPDSOC
Local Integer OKRGL , OKCRE , STAINFO , STADIFF , OKMOD , OKUPD
Local Char    CRITFRM(30)(1..3)
Local Char    VALSOC(1) , PARSOC(10)(1..5)
Local Char    OLDACC(GLONACS) , NEWACC(GLONACS)
OBJET = ABREV
Gosub SETNUM From WWCPY
GESSOC  = TT
OKUPD   = UPDSOC
STAINFO = 50601+GPILOBJ
STADIFF = 2601+GPILOBJ
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If TT
 AUTORSOC = instr(1,GUSRAUZ(1),"W") : # Option toutes sociétés
 If AUTORSOC
  If CLESEC(0)="" & SAVCLE2<>""
   SOCCUR = SAVCLE2
  Elsif GDEFSOC<>""
   SOCCUR = GDEFSOC
  Endif
  Read [CPY]CPY0 = SOCCUR
  If fstat or SOCCUR = ""
   Filter [CPY] Where CPYLEGFLG=2
   Read [CPY]CPY0 First
   Filter [CPY]
   SOCCUR = [F:CPY]CPY
  Endif
 Else
  SOCCUR = GDEFSOC
  Read [CPY]CPY0 = SOCCUR
  If fstat
   GMESSAGE = mess(74,100,1) : # Fonction non autorisée
   OK = 0 : Return
  Endif
 Endif
 OLDSOC = SOCCUR
 Gosub OUVRE_FORCE From WWCPY
 Gosub OUVRE From WWCPY
 ABRCPY = "W"+format$("N0:2#",TT)
 BRW1   = "WA"+mid$("1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZ",TT,1)
 BRW2   = "WB"+mid$("1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZ",TT,1)
 Addmen STAINFO Titled mess(80,151,1) To 307     At 51 : # Infos
 Additm STADIFF Titled mess(899,196,1)To STAINFO At 60 : # Différences
Endif
Return
 
$OUVRE_BOITE
K = find(BRW1,OBJLIS(1..8)) : BOX1 = "GAU_CHE"+num$(K)
K = find(BRW2,OBJLIS(1..8)) : BOX2 = "GAU_CHE"+num$(K)
BOX9 = "GAU_CHE9"
Gosub DEFAUT From WWCPY
If CLE1<>""
 CLECUR1 = CLE1
 For CL=0 To dim(CLESEC)-1
  CLECUR2(CL) = CLE2(CL)
 Next CL 
 Gosub AFF_CLE
 Read [F] =
 If fstat
  Raz CLE1,CLE2
  Filter [F] Where WCPY=SOCCUR
  Read [F] First
  If fstat<=2
   Gosub SET_CLE
   CLE1 = CLECUR1
   For CL=0 To dim(CLESEC)-1
    CLE2(CL) = CLECUR2(CL)
   Next CL 
  Endif
  Filter [F]
  #Infbox "le dernier lu n'existe pas"-CLE1
 Endif
Endif
Gosub DEFAUT From =PROGOBJ
Return

$APRES_MODIF
If COUZON="SOC"
 If !AUTORSOC
  Call MESSAGE(mess(17,137,1)) From GESECRAN : # Modification non autorisée
  zc = SOCCUR
  [M]SOC = SOCCUR
  OK = 0 : Return
 Endif
 OLDSOC = SOCCUR
 SOCCUR = CZ
 If BOXCURR=BOX1 or BOXCURR=BOX9
  Gosub REMPLIT From GOBJSUB
 Endif
 Gosub DEFAUT From WWCPY
 Gosub AFF_CLE
 Read [F] =
 If !fstat
  Gosub DEFAUT From =PROGOBJ
  Gosub AFF_CLE From GOBJSUB
  Read [F] =
  Gosub LECSOC
  Gosub AFFZONE From GOBJSUB
  If REP="M"
   Gosub SORT_MODIF From GOBJSUB
  Endif
  OK = -1 : # Pour ne pas entrer en modif
 Endif
Endif
Return

$ABANDON
SOCCUR = OLDSOC
If BOXCURR=BOX1 or BOXCURR=BOX9
 Gosub REMPLIT From GOBJSUB
Endif
Return

$AFF_CLE
[F]WCPY = SOCCUR
If evalue("type([F:"+ABRCPY+"]"+CLEPRIM+")")>=10
 Assign "[F:"+ABRCPY+"]"+CLEPRIM With CLECUR1
Else
 Assign "[F:"+ABRCPY+"]"+CLEPRIM With val(CLECUR1)
Endif
For CL=0 To dim(CLESEC)-1
 If CLESEC(CL)<>""
  If evalue("type([F:"+ABRCPY+"]"+CLESEC(CL)+")")>=10
   Assign "[F:"+ABRCPY+"]"+CLESEC(CL) With CLECUR2(CL)
  Elsif evalue("type([F:"+ABRCPY+"]"+CLESEC(CL)+")")=3
   If CLECUR2(CL)="" : CLECUR2(CL) = "00000000" : Endif
   K = instr(1,CLECUR2(CL),"/")
   K = instr(K+1,CLECUR2(CL),"/")
   If K
    Assign "[F:"+ABRCPY+"]"+CLESEC(CL) With evalue("["+CLECUR2(CL)+"]")
   Elsif len(CLECUR2(CL))=8
    Assign "[F:"+ABRCPY+"]"+CLESEC(CL) With CLECUR2(CL)
   Endif
  Elsif TPCLE2(CL)=2
   Assign "[F:"+ABRCPY+"]"+CLESEC(CL) With val(CLECUR2(CL))
  Endif
 Endif
Next CL
Return

$SET_CLE
CLECUR1 = num$(evalue("[F:"+ABRCPY+"]"+CLEPRIM))
For CL=0 To dim(CLESEC)-1
 If CLESEC(CL)<>""
  CLECUR2(CL) = num$(evalue("[F:"+ABRCPY+"]"+CLESEC(CL)))
 Endif
Next CL
Return

$LECSOC
Call LECTURE(ABREV,SOCCUR) From WWCPY
Gosub CHARGE From GOBJET1
Return

$DROIT
Call LECTURE(ABREV,SOCCUR) From WWCPY
If fstat & COUZON<>"" & find(COUZON,CLEPRIM,CLESEC)
 Gosub ENTRE_MODIF From GOBJSUB
 Gosub DEGRISE_CLE From =WINPROG
 Gosub DEGRISE
Endif
Return

$LIENS
Gosub SETMA0
[M]SOC = SOCCUR
Return

$SETMA0
If AMA(0)
 MA = 0
Else
 MA = 1
Endif
Gosub SETMASK From =WINPROG
Return

$GRISE
Gosub SETMA0
Grizo SOC
Return

$DEGRISE
Gosub SETMA0
Actzo SOC
Return

$SETBOUT
CHGENV = 1
If AUTORSOC
 CHMEN += "1"
Endif
Enable STADIFF
Return

$GAUCHE
Case currbox
 When BOX2
  SOCCUR = evalue("[F:"+ABRCPY+"]WCPY")
  OLDSOC = SOCCUR
Endcase
Return

$GAUCHE9
Return

$FILGAUCHE
Case currbox
 When BOX1
  FILGAUSUP = '[F:'+ABRCPY+']WCPY="'+SOCCUR+'"'
 When BOX2
  If AUTORSOC
   FILGAUSUP = ""
  Else
   FILGAUSUP = '[F:'+ABRCPY+']WCPY="'+SOCCUR+'"'
  Endif
 When BOX9
 # Il nous manque un filtre dans ce cas (dernier lus)
Endcase
If FILTRE<>""
 If FILGAUSUP<>"" : FILGAUSUP -= "&" : Endif
 FILGAUSUP -= FILTRE
Endif
Return

$LEC_DERLU
Call LECTURE(ABREV,SOCCUR) From WWCPY
If fstat : OK = 0 : Endif
Return

$AP_FILGAUCHE
Gosub DEFAUT From WWCPY
Gosub AFF_CLE
Read [F] =
Return

$AVANTBOUT
Gosub RECHARGE From GOBJSUB
Return

$RAZCRE
Gosub SETMA0
[M]SOC = SOCCUR
Affzo SOC
Return

#################################################
## Création/modif
#################################################
$CREATION
Gosub DEFAUT From WWCPY
Raz [F]
Gosub TRANSF From WWCPY
[F]WCPY = SOCCUR
If dim([F]CREDAT)>0 : [F]CREDAT = date$   : Endif
If dim([F]CREUSR)>0 : [F]CREUSR = GUSER   : Endif
If dim([F]CRETIM)>0 : [F]CRETIM = time    : Endif
If dim([F]UPDDAT)>0 : [F]UPDDAT = [0/0/0] : Endif
If dim([F]UPDUSR)>0 : [F]UPDUSR = ""      : Endif
If dim([F]UPDTIM)>0 : [F]UPDTIM = 0       : Endif
Write
If fstat
 GOK = 0 : Call FSTA(ABRCPY) From GLOCK : Return
Endif
Gosub REGLE
If OKRGL
 Gosub DEFAUT From WWCPY
 For [CPY]CPY0 Where CPYLEGFLG=2
  OKCRE = find([F:CPY]CPY,[F:DCY]CPY(0..[F:DCY]NBRCPY-1))
  If [F:DCY]CREFLG=2 : OKCRE = !OKCRE : Endif
  If OKCRE
   [F]WCPY = [F:CPY]CPY
   Look =
   If fstat
    Write
    If fstat
     GOK = 0 : Call FSTA(ABRCPY) From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If !GOK : Return : Endif
Endif
Gosub DEFAUT From =PROGOBJ
Return

$REGLE
## Recherche d'une règle valable
## et création en chaîne
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:PCY])=0 : Local File PARCPY    [PCY] : Endif
If clalev([F:DCY])=0 : Local File PARDUPCPY [DCY] : Endif
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
Read [PCY]PCY0 = GESSOC
For I=1 To [F:PCY]NBRFRM
 Read [ATY]CODTYP = [F:PCY]TYP(I-1)
 Onerrgo RIEN
 Case [F:ATY]TYPTYP
  When 7       : CRITFRM(I) = evalue([F:PCY]CRT(I-1))
  When 8       : CRITFRM(I) = format$("YYYYMMDD",evalue([F:PCY]CRT(I-1)))
  When Default : CRITFRM(I) = num$(evalue([F:PCY]CRT(I-1)))
 Endcase
 Onerrgo
Next I
For [DCY]DCY0 Where TBL=GESSOC
 OKRGL = 1
 For I=1 To [F:PCY]NBRFRM
  Case I
   When 1 : OKRGL *= pat(CRITFRM(I),[F:DCY]CRI1)
   When 2 : OKRGL *= pat(CRITFRM(I),[F:DCY]CRI2)
   When 3 : OKRGL *= pat(CRITFRM(I),[F:DCY]CRI3)
  Endcase
 Next I
 If OKRGL : Break : Endif
Next
Return

$RIEN
Resume

$AVANT_MODFIC
Gosub DEFAUT From WWCPY
Gosub AFF_CLE

Readlock [F]CPY0 =
If fstat=1
 GOK = -1 : GLOCK = "$WCPY"+ABREV-SOCCUR-CLEPRIM : Return
Elsif fstat
 NEWCPY = 1
Else
 NEWCPY = 0
Endif
Gosub SAUVE    From WWCPY     : # ABREV => WW
If ZACC<>""
 OLDACC = evalue("[F:"+ABFIC+"]"+ZACC)
Endif
Return

$INIMOD
If ZACC<>""
 NEWACC = evalue("[F:"+ABFIC+"]"+ZACC)
Endif
Gosub TRANSF   From WWCPY     : # ABREV => W
#Gosub RESTAURE From WWCPY     : # WW    => ABREV
If ZACC<>""
 Assign "[F:"+ABFIC+"]"+ZACC With NEWACC
Endif
Return

$VERIF_MOD
Case OKUPD
 When 1 : OKMOD = 1
 When 2 : OKMOD = 2
 When 3
  OKMOD = 2 : Call OUINON(mess(36,127,1),OKMOD) From GESECRAN : # Propagation des modifs
Endcase
Return

$MODIF
Gosub DEFAUT From WWCPY
If NEWCPY
 [F]WCPY   = SOCCUR
 If dim([F]CREDAT)>0 : [F]CREDAT = date$   : Endif
 If dim([F]CREUSR)>0 : [F]CREUSR = GUSER   : Endif
 If dim([F]CRETIM)>0 : [F]CRETIM = time    : Endif
 If dim([F]UPDDAT)>0 : [F]UPDDAT = [0/0/0] : Endif
 If dim([F]UPDUSR)>0 : [F]UPDUSR = ""      : Endif
 If dim([F]UPDTIM)>0 : [F]UPDTIM = 0       : Endif
 Write
Else
 If dim([F]UPDDAT)>0 : [F]UPDDAT = date$   : Endif
 If dim([F]UPDUSR)>0 : [F]UPDUSR = GUSER   : Endif
 If dim([F]UPDTIM)>0 : [F]UPDTIM = time    : Endif
 Rewrite
Endif
If fstat
 GOK = 0 : Call FSTA(ABRCPY) From GLOCK : Return
Endif
If OKMOD=2
 Gosub REGLE
 If OKRGL
  Gosub FILTRE From WWCPY
  Gosub DEFAUT From WWCPY
  For [F]CPY1 Where evalue(FILTCPY) & WCPY<>SOCCUR
   OKCRE = find([F]WCPY,[F:DCY]CPY(0..[F:DCY]NBRCPY-1))
   If [F:DCY]CREFLG=2 : OKCRE = !OKCRE : Endif
   If OKCRE
    Gosub TRANSF   From WWCPY
    If dim([F]UPDDAT)>0 : [F]UPDDAT = date$   : Endif
    If dim([F]UPDUSR)>0 : [F]UPDUSR = GUSER   : Endif
    If dim([F]UPDTIM)>0 : [F]UPDTIM = time    : Endif
    Rewrite
    If fstat
     GOK = 0 : Call FSTA(ABRCPY) From GLOCK : Break
    Endif
   Endif
  Next
 Endif
Elsif ZACC<>"" & OLDACC<>NEWACC
 Gosub FILTRE From WWCPY
 For [F]CPY1 Where evalue(FILTCPY)
  Assign "[F:"+ABRCPY+"]"+ZACC With NEWACC
  Rewrite
  If fstat
   GOK = 0 : Call FSTA(ABRCPY) From GLOCK : Break
  Endif
 Next
Endif
Gosub DEFAUT From =PROGOBJ
Return

#################################################
## Boutons magnétos et actions spéciales
#################################################
$APRES_CHOI
If REPONSE=STADIFF
 Gosub RECHARGE From GOBJSUB
 PARSOC(1) = ABREV
 Call SAISIE_CHAR(VALSOC,PARSOC,"DIFFSOC","DIFFSOC","") From GSAISIE
 REPONSE = 0 : Return
Elsif REPONSE=GSTADAT
 Gosub RECHARGE From GOBJSUB
 PARSOC(1) = ABREV
 Call SAISIE_CHAR(VALSOC,PARSOC,"AOPVISU","GSOCPROP","") From GSAISIE
 REPONSE = 0 : Return
Elsif find(REPONSE,GSTASUI,GSTAPRE,GSTAFIR,GSTALAS)
 If currbox<>BOX9
  Gosub ABORT From GOBJSUB
  If !OK
   REPONSE = 0 : Return
  Endif
  If VERROU : Gosub DEVERROU From GOBJET : Endif
  Case REPONSE
   When GSTASUI : Goto SUIVANT
   When GSTAPRE : Goto PRECEDENT
   When GSTAFIR : Goto PREMIER
   When GSTALAS : Goto DERNIER
  Endcase
 Endif
Endif
Return

$PREMIER
Gosub FILTRE
Read First
Goto SUIV2

$DERNIER
Gosub FILTRE
Read Last
Goto PREC2

$SUIVANT
Gosub COURANT

$SUIV1
Gosub FILTRE
Read Next

$SUIV2
Filter [F]
If fstat<=2
 Gosub SET_CLE
 Gosub DEFAUT From =PROGOBJ
 Gosub AFF_CLE From GOBJSUB
 Read [F] =
 Gosub DROIT_ACCES
 If !OKACC : Goto SUIV1 : Endif
 REPONSE = GSTALFT
Else
 Call MESSAGE(mess(11,100,1)) From GESECRAN
 REPONSE = 0
Endif
Return

$PRECEDENT
Gosub COURANT

$PREC1
Gosub FILTRE
Read Prev

$PREC2
Filter [F]
If fstat<=2
 Gosub SET_CLE
 Gosub DEFAUT From =PROGOBJ
 Gosub AFF_CLE From GOBJSUB
 Read [F] =
 Gosub DROIT_ACCES
 If !OKACC : Goto PREC1 : Endif
 REPONSE = GSTALFT
Else
 Call MESSAGE(mess(11,100,1)) From GESECRAN
 REPONSE = 0
Endif
Return

$COURANT
Gosub DEFAUT From WWCPY
Gosub AFF_CLE
Read [F]CPY0 = 
Return

$FILTRE
Gosub DEFAUT From WWCPY
Case currbox
 When BOX2
  If AUTORSOC
   Filter [F]                   Order By Key CPY1
  Else
   Filter [F] Where WCPY=SOCCUR Order By Key CPY1
  Endif
 When Default
  Filter [F] Where WCPY=SOCCUR Order By Key CPY0
Endcase
Return

$DROIT_ACCES
OKACC = 1
If [L]ZACC<>"" & evalue("[F]"+[L]ZACC)<>""
 Read [ACC]CODACC = GUSER;evalue("[F]"+[L]ZACC)
 If [F:ACC]CONSUL<>2
  OKACC =0 : Return
 Endif
Endif
If GUSRFCY(1)<>"\" & [L]ZSITE<>"" & GNBAUZ<>GNBSITE & evalue("[F]"+[L]ZSITE)<>""
 If !evalue('find([F]'+[L]ZSITE+',GUSRFCY(1..GNBAUZ))<>0')
  OKACC = 0 : Return
 Endif
Endif
Gosub CRITERE From GOBJSUB
If CRITERE="" : CRITERE = "1=1" : Endif
If FILTSUP="" : FILTSUP = "1=1" : Endif
If FILROLE="" : FILROLE = "1=1" : Endif
If !evalue(CRITERE) or !evalue(FILTSUP) or !evalue(FILROLE)
 OKACC = 0 : Return
Endif
Return

#################################################
## Verrue pour SELOBJ
#################################################
$SELOBJ
Local Char    CRITSOC(250)
Local Integer KK
Gosub SETNUM From WWCPY
Gosub LIENS  From WWCPY
Gosub DEFAUT From WWCPY
If dim([F]ENAFLG)>0
 CRITSOC = "ENAFLG=2"
Endif
If GDEFSOC<>""
 If CRITSOC<>"" : CRITSOC -= "&" : Endif
 CRITSOC -= 'WCPY="'+GDEFSOC+'"'
Endif
If CRITSOC<>""
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= "("+CRITSOC+")"
Endif
Default File [WSEL]
Return

#################################################
## Action SELOBJSOC
#################################################
$SEL_TABLE
OBJET = PARAM(1)
Return

$CHX_TABLE
Local Char    SOCIETE(GLONCPY) , CRITSOC(250)
Local Integer KK
Gosub SETNUM From WWCPY
Gosub LIENS  From WWCPY
Gosub DEFAUT From WWCPY
If dim([F]ENAFLG)>0
 CRITSOC = "ENAFLG=2"
Endif
If PARAM(2)<>""
 KK = find(PARAM(2),GSITE(1..GNBSITE))
 If KK
  SOCIETE = GSOCSITE(KK)
 Else
  SOCIETE = PARAM(2)
 Endif
 If CRITSOC<>"" : CRITSOC -= "&" : Endif
 CRITSOC -= 'WCPY="'+SOCIETE+'"'
Endif
If CRITSOC="" : CRITSOC = "1=1" : Endif
Filter [F] Where evalue(CRITSOC)
Default File [WSEL]
Return
