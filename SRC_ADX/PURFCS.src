#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################
# PURFCS : Impression des charges achats                                #
# --------------------------------------------------------------------- #
# Chargement des paramètres                                             #
#########################################################################


###########################################
# Appelé par le Call ETAT from AIMP3      #
# --------------------------------------- #
# Le Call ETAT effectue dans l'ordre :    #
#   - Un Gosub ACTION  (ACTION="EXEC")    #
#   - Un Call  IMPRIME (NBPAR,PARAMETRE)  #
###########################################
$ACTION
Case ACTION
  When "EXEC"    : Gosub EXEC
Endcase
Return

############################################################################
# Avant l'impression du document, chargement paramètres si impression auto #
# ------------------------------------------------------------------------ #
############################################################################
$EXEC
#-----
If dim(I)<1       Local Integer I             : Endif
If dim(J)<1       Local Integer J             : Endif
If dim([L]ETAT)<1 Local Char    ETAT(GLONARP) : Endif
#-----
For I=1 To [L]NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM=left$([L]PARAMETRE(I),J-1)
    Case [L]PARAM
      When "X3ETA"          : Call GETPARAM([L]PARAM,[L]NBPAR,[L]PARAMETRE,[L]ETAT) From ETAT
      When "X3LAN"          : [L]PARAMETRE(I) = "X3LAN="+GLANGUE
      When "__REQUETE"      : [L]PARAMETRE(I) = "__REQUETE="+num$([V]GWNUMREQ)
      When "_PrinterCopies" : [L]PARAMETRE(I) = "_PrinterCopies="+chr$(1)+"1"
      When "numedt"         : [L]PARAMETRE(I) = "numedt="+num$([V]GWNUMREQ)
      When "seqedt"         : [L]PARAMETRE(I) = "seqedt="+num$([V]GWSEQREQ)
      When "usr"            : [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"           : [L]PARAMETRE(I) = "etat="+[L]ETAT
      When "euro"           : [L]PARAMETRE(I) = "euro="+GEURO
      When "nbcol"          : [L]PARAMETRE(I) = "nbcol="+num$(6)
    Endcase
  Endif
Next I
#-----
Return


####################################
# Appelé par le Call ETAT          #
#   après l'action EXEC            #
#   avant l'impression du document #
####################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
#----- Ouverture des tables -----#
Local File COMPANY   [CPY]
Local File WRKPURFCS [WPF]
Local File PRECEIPT  [PTH]
Local File PRECEIPTD [PTD]
Local File FACILITY  [FCY]
Local File COSTSTCD  [STCD]
Local File AREPORTM  [ARM]
Local File TMPPRPT   [TPRPT]
#----- Déclaration des variables locales -----#
Local  Char    CRITERE(255), CRITERE2(255), PARAM(30) , VALEUR(30) , ETAT(GLONARP)
Local  Integer WNUMLIG, NUMREQ, IMPR, I, J,WINDICE,WINDICE_REMP
Local  Date    DATDEB,DATFIN
Local  Integer WTYPPER, WREGROUP, WNBCOL, WFCSNAT, WTYPMNT
Local  Char    WFCSCOD, WCPY
Local  Integer WINDEXPER(15)(0..5)
Local  Char    WLIBPER(15)(0..5)
Local  Decimal WMNT
Local  Char    WGPGCOD

Global Integer GNBCOL,GNBPARAM
#-----
[L]CRITERE ="1=1"
[L]CRITERE2="1=1"
#-----
For I=1 To [L]NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
    Case [L]PARAM
      When "X3ETA"          : [L]ETAT     = [L]VALEUR
      When "__REQUETE"      : [L]NUMREQ   = val([L]VALEUR)
      When "cpy"            : WCPY        = [L]VALEUR
                              [L]CRITERE -= "& [F:FCY]LEGCPY='"+[L]VALEUR+"'"
      When "sitedeb"        : [L]CRITERE -= "& [F:PTD]PRHFCY>='"+[L]VALEUR+"'"
      When "sitefin"        : [L]CRITERE -= "& [F:PTD]PRHFCY<='"+[L]VALEUR+"'"
      When "fournisseurdeb" : [L]CRITERE -= "& [F:PTD]BPSNUM>='"+[L]VALEUR+"'"
      When "fournisseurfin" : [L]CRITERE -= "& [F:PTD]BPSNUM<='"+[L]VALEUR+"'"
      When "datedeb"        : [L]DATDEB   =  gdat$(val(right$([L]VALEUR,7)),
&                                            val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                              [L]CRITERE2 -= "& [F:PTD]RCPDAT >=["+format$(GFMD,[L]DATDEB)+']'
      When "datefin"        : [L]DATFIN   =  gdat$(val(right$([L]VALEUR,7)),
&                                            val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                              [L]CRITERE2 -= "& [F:PTD]RCPDAT  <=["+format$(GFMD,[L]DATFIN)+']'
      When "receptiondeb"   : [L]CRITERE2 -= "& [F:PTD]PTHNUM>='"+[L]VALEUR+"'"
      When "receptionfin"   : [L]CRITERE2 -= "& [F:PTD]PTHNUM<='"+[L]VALEUR+"'"
      When "chargedeb"      : [L]CRITERE2 -= "& [F:STCD]FCSCOD>='"+[L]VALEUR+"'"
      When "chargefin"      : [L]CRITERE2 -= "& [F:STCD]FCSCOD<='"+[L]VALEUR+"'"
      When "gpgcod"         : WGPGCOD      = [L]VALEUR
                              If WGPGCOD <> ""
                                 [L]CRITERE2 -= "& [F:PTH]GPGCOD='"+[L]VALEUR+"'"
                              Endif
      When "typmnt"         : WTYPMNT      =  val([L]VALEUR)
      When "regroup"        : WREGROUP     =  val([L]VALEUR)
      When "period"         : WTYPPER      =  val([L]VALEUR)
      When "nbcol"          : GNBPARAM = I
      #-----
      When "numedt"         : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
      When "usr"            : [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"           : [L]PARAMETRE(I) = "etat="+[L]ETAT
      When "euro"           : [L]PARAMETRE(I) = "euro="+GEURO
      When "_PrinterCopies" : [L]PARAMETRE(I) = "_PrinterCopies="+chr$(1)+"1"
    Endcase
  Endif
Next I
#-----
#------------------------------------------------------------------#
#  - Création d'un seul enregistrement dans AREPORTM               #
#  - Mise à jour indicateur d'impression sur l'entête de livraison #
#------------------------------------------------------------------#
Read [F:CPY]CPY0 = WCPY
If fstat : Raz [F:CPY] : Endif

CRITERE -= " & [F:STCD]VCRTYP = 6 & [F:STCD]FCSAMTSOC <> 0"

Gosub DECLARE_VARIABLES From TRTACHGRH1
GNBCOL = 6
WDATDEB = DATDEB
WDATFIN = DATFIN
WPERCOD = WTYPPER
 #----- Calcul date fin en fonction de la périodicité et du nbre de périodes -----#
Call CALDATPER(WPERCOD,6,"+",[0/0/0],WDATDEB,WDATFIN) From TRTX3DAT
If WDATFIN=[0/0/0]
   WDATFIN=DATFIN
Endif
# Optimisation : On réajuste la date de fin par rapport au nombre maxi de périodes que l'on pourra traiter = 6
DATFIN  = min(DATFIN,WDATFIN)

# création des 6 périodes
Gosub CREATE_PERIODES
Raz WFCSCOD, WFCSNAT
Call DEBTRANS From GLOCK
Trbegin [WPF]
Delete [F:WPF] Where USR = GUSER
#----- Chargement buffer WRKPURFCS -----#
Raz [F:WPF]
[F:WPF]USR     = GUSER
[F:WPF]RPTCOD  = [F:ARP]RPTCOD
[F:WPF]NUMREQ  = [L]NUMREQ
[F:WPF]CREDAT  = date$
[F:WPF]CUR     = [F:CPY]ACCCUR
[F:WPF]REGROUP = WREGROUP+1
[F:WPF]PERCOD  = WPERCOD
[F:WPF]TYPMNT  = WTYPMNT
For I = 0 To 5
  [F:WPF]PCST(I) = WLIBPER(I)
Next
#-----
Link [F:STCD] With [F:PTD]PTD0 ~= [F:STCD]VCRNUM;[F:STCD]VCRLIN,
&    [F:PTH]PTH0 ~= [F:STCD]VCRNUM,
&    [F:FCY]FCY0 ~= [F:PTD]PRHFCY As [STCX]
&    Where evalue(CRITERE) & evalue(CRITERE2)
&    Order By [F:STCD]FCSNAT;[F:STCD]FCSCOD;[F:STCD]CREDAT
For [F:STCX]
    # 1ere fois
    If WFCSCOD = ""
       Gosub INIT_ZONES
    Endif
    # si rupture
    If (WREGROUP = 0 & [F:STCD]FCSCOD <> WFCSCOD) | (WREGROUP = 1 & [F:STCD]FCSNAT <> WFCSNAT)
        [F:WPF]TOTLIN = sum([F:WPF]TOTPCST)
        [F:WPF]FCSCOD = WFCSCOD # même si regroupement par nature sinon Pb dans CR avec table des textes traduisibles
        [F:WPF]FCSNAT = WFCSNAT
        Write [F:WPF]
        If fstat  GOK=0 : Call FSTA("ARM") From GLOCK : Break : Endif
        # On garde le plus grand nombre de périodes remplies
        If WINDICE_REMP > WNBCOL
          WNBCOL = WINDICE_REMP
        Endif
        Gosub INIT_ZONES
    Endif
    WDATE    = [F:PTD]RCPDAT
    WPERCOD  = WTYPPER
    Gosub DETERMINE_PERIODE From TRTACHGRH1
    WINDICE = find (WLIBELLE,[F:WPF]PCST(0..5))
    If WINDICE
       If WTYPMNT = 1
          # Montant ajusté
          WMNT = [F:STCD]FCSAMTSOC
       Else
          # Montant calculé exprimé en devise société
          WMNT = [F:STCD]FCSAMTCLC * [F:STCD]CHGCOE
          Call ARRDEV(WMNT,[F:CPY]ACCCUR) From TRTDIV
       Endif
       Assign "[F:WPF]TOTPCST(" + num$(WINDICE-1)+")" With evalue("[F:WPF]TOTPCST(" + num$(WINDICE-1)+ ")") + WMNT
       # plus grand indice de période remplie
       If WINDICE > WINDICE_REMP
         WINDICE_REMP = WINDICE
       Endif
    Endif
Next
#Dernier enregistrement
If WINDICE_REMP <> 0
    [F:WPF]TOTLIN = sum([F:WPF]TOTPCST)
    [F:WPF]FCSCOD = WFCSCOD
    [F:WPF]FCSNAT = WFCSNAT
    Write [F:WPF]
    If fstat  GOK=0 : Call FSTA("WPF") From GLOCK : Endif
    If WINDICE_REMP > WNBCOL
       WNBCOL = WINDICE_REMP
    Endif
Endif

If func AFNC.ACTIV("KPO")
  Raz [F:ARM]
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [F:ARP]RPTCOD
  [F:ARM]NUMREQ  = [L]NUMREQ
  [F:ARM]NUMLIG  = 1
  [F:ARM]CLEA1   = [F:PTH]PTHNUM
  [F:ARM]CREDAT  = date$
  Write [F:ARM]
  If fstat : GOK = 0 : Endif

  Gosub ALIM_TMPPRPT

Endif

If GOK<1  Rollback  Else  Commit : Endif

# Nombre corrigé de périodes à imprimer
GNBCOL = min(GNBCOL,WNBCOL)
[L]PARAMETRE(GNBPARAM) = "nbcol="+num$(GNBCOL)
Kill GNBCOL,GNBPARAM
End


############################################################################
$INIT_ZONES
Raz WINDICE_REMP
For I = 0 To 5
  Raz [F:WPF]TOTPCST(I)
Next
Raz [F:WPF]TOTLIN
WFCSCOD    = [F:STCD]FCSCOD
WFCSNAT    = [F:STCD]FCSNAT
[F:WPF]NUMLIG += 1
Return



################################################################################
# Création des périodes en fonction du code périodicité                        #
# ---------------------------------------------------------------------------- #
# En entrée                                                                    #
#   - WDATDEB  : Date début                                                    #
#   - WDATFIN  : Date fin                                                      #
#   - WPERCOD  : Code périodicité (1=Jour, 2=Semaine, 4=Mois, 5=Trimestre,     #
#                                  6=Semestre, 7=Année)                        #
# Variables de travail                                                         #
#   - W0       : Maxi période-1                                                #
#   - W1       : Année                                                         #
#   - W2       : Période                                                       #
#   - WINDEX   : Numéro d'ordre période                                        #
#   - WLIBELLE : Libellé de la période                                         #
# En sortie, chargement des variables WINDEXPER et WLIBPER                     #
################################################################################
$CREATE_PERIODES
#-----
If WDATDEB<>[0/0/0]
  WDATE=WDATDEB : Gosub DETERMINE_PERIODE From TRTACHGRH1
Endif
#-----
Case WPERCOD
 When 1       : WDATE=WDATDEB-1
  When 2       : W0=51
  When 5       : W0=3
  When 6       : W0=1
  When 7       : W0=0
  When Default : W0=11
Endcase
If W0=0
  W1=int(WINDEX/1000)-1
  W2=mod(WINDEX,1000)
Else
  W1=int(WINDEX/1000)
  W2=mod(WINDEX,1000)-1
Endif
Raz I
While I<6
    If WPERCOD=1
      WDATE+=1 : Gosub DETERMINE_PERIODE From TRTACHGRH1
    Else
      If W0=0  W2=0 : W1+=1  Elsif W2>W0  W2=1 : W1+=1  Else  W2+=1 : Endif
      WINDEX=(W1*1000)+W2
    Endif
    If !find(WINDEX,WINDEXPER(0..5))
      Case WPERCOD
        When 1       : WLIBELLE=format$("D:"+GFMDAT,WDATE)
        When 2       : WLIBELLE=mess(2,52,1)-num$(W2)-right$(num$(W1),3)
        When 5       : WLIBELLE=mess(5,52,1)-num$(W2)-right$(num$(W1),3)
        When 6       : WLIBELLE=mess(6,2231,1)-num$(W2)-right$(num$(W1),3)
        When 7       : WLIBELLE=mess(7,2231,1)-num$(W1)
        When Default : WLIBELLE=format$("D:MMMMMMMMMM",gdat$(1,W2,W1))-num$(W1)
      Endcase
      WINDEXPER(I) = WINDEX
      WLIBPER(I)   =WLIBELLE
      I+=1
    Endif
Wend
#-----
Return
#########################################################################
$ALIM_TMPPRPT
# Issue 118829
Raz [F:TPRPT]

[F:TPRPT] = [F:ARM]
[F:TPRPT]VCRNUM = [F:PTH]PTHNUM

Write [F:TPRPT]
If fstat : GOK=0 :  Endif
# End issue 118829
Return
#########################################################################

