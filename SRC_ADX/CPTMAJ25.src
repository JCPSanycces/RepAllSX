#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################################
#  Traitement V5 permettant de passer d'une V140 => V5
#  Lors d'une migration V140-V6, traitement finalement non appelé sous le DOSMAJ25... 
#   dans ce cas modification à faire sous CPTMAJ30
#  Fiche 58563 - Appel de GRUCPYE depuis CPTMAJ30
#########################################################################################

Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = nomap
Call CPTMAJV5
Call TRSMAJV5
Call IMMMAJV5
End

####################################################
## Subprog ACPTMAJV5
## Subprog CPTMAJV5
## Subprog AIMMMAJV5
## Subprog IMMMAJV5
## Subprog ATRSMAJV5
## Subprog TRSMAJV5


####################################################
## Module compta
####################################################

####################################################
Subprog ACPTMAJV5

Gosub GRUCPYE

End

$GRUCPYE
# Groupe de société - Table comptable disparaissent
Local File =[F:ADS]DOSSIER+".GRUCPYE"    [GPY]
Local File =[F:ADS]DOSSIER+".GRUCPYD"    [CYD]


Local File =[F:ADS]DOSSIER+".AGRPFCY"    [AGF]
Local File =[F:ADS]DOSSIER+".AGRPCPY"    [AGC]
Local File =[F:ADS]DOSSIER+".FACGROUP"   [FGR]
Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]

Call ECR_TRACE(mess(81,125,1)-": GRUCPYE/GRUCPYD => AGRPFCY",0) From GESECRAN : # maj table
GOK = 1

Trbegin [GPY], [CYD], [FGR]

 For [GPY]CYE0
  Raz [F:AGC]
  [F:AGC]GRP = "MI"+[F:GPY]GRUCPY

  For [CYD] Where GRUCPY=[F:GPY]GRUCPY
   [F:AGC]CPY = [F:CYD]CPY
   Write [AGC]
   If fstat 
    Call ERREUR("AGRPCPY"-[F:AGC]GRP-[F:AGC]CPY,2) From DOSDIC : Break
   Endif

   For [FCY]FCY1 Where LEGCPY=[F:CYD]CPY
    [F:FGR]CPY = "MI"+[F:GPY]GRUCPY
    [F:FGR]FCY = [F:FCY]FCY
    Write [FGR]
    If fstat 
     Call ERREUR("FACGROUP"-[F:FGR]CPY-[F:FGR]FCY,2) From DOSDIC : Break 2
    Endif
   Next

  Next

  Raz [F:AGF]
  [F:AGF] = [F:GPY]
  [F:AGF]GRP = "MI"+[F:GPY]GRUCPY
  [F:AGF]DES = [F:GPY]GRUCPYNAM
  [F:AGF]SHO = [F:GPY]GRUCPYSHO
  [F:AGF]FLGCPY = 2 

  Write [AGF]
  If fstat
   Call ERREUR("AGRPFCY"-[F:AGF]GRP,2) From DOSDIC
  Endif
 Next
Commit
Close Local File [GPY],[CYD],[AGF],[AGC],[FGR],[FCY]
Return

####################################################
Subprog CPTMAJV5

Local File =[F:ADS]DOSSIER+".GACCOUNT"  [GAC]
Call ECR_TRACE(mess(81,125,1)-": GACCOUNT",0) From GESECRAN : # maj table
GOK = 1
Trbegin [GAC]
 For [GAC]GAC0 Where CUR<>"" 
  [F:GAC]FRWCUR = 2
  Rewrite [GAC]
  If fstat
   Call ERREUR("GACCOUNT"-[F:GAC]ACC,2) From DOSDIC
  Endif
 Next
Commit
Close Local File [GAC]


End


####################################################
## Module tiers
####################################################

####################################################
Subprog ATRSMAJV5

End


####################################################
Subprog TRSMAJV5

Local File =[F:ADS]DOSSIER+".ACTIV"      [XACV]

Read [XACV]CODACT = "FUP"
If !fstat & [F:XACV]FLACT=2

 Local File =[F:ADS]DOSREF+".FUPGRP"      [FGP]
 Local File =[F:ADS]DOSSIER+".BPCUSTOMER" [BPC]
 Local Char GROUPE(5)

 Call ECR_TRACE(mess(81,125,1)-": BPCUSTOMER",0) From GESECRAN : # maj table
 GOK = 1

 Read [FGP]FGP0 First
 GROUPE = [F:FGP]GRP
 If GROUPE="" : Goto NO_GRP : Endif

 Trbegin [BPC]
  For [BPC]BPC0 
   If [F:BPC]FUPTYP = 1 : # Pas de relance 
    [F:BPC]GRP = ""
   Else
    [F:BPC]GRP = [L]GROUPE
   Endif
   Rewrite [BPC]
   If fstat
    Call ERREUR("BPCUSTOMER"-[F:BPC]BPCNUM,2) From DOSDIC
   Endif
  Next
 Commit

 $NO_GRP
 Close Local File [BPC], [FGP]
Endif
Close Local File [XACV]


Local File =[F:ADS]DOSSIER+".ADOPAR" [ADP]
Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW]
Trbegin [ADP], [ADW]
 Delete [ADP] Where PARAM="FUPAMT"
 If fstat : Call ERREUR("ADP"-"FUPAMT",3) From DOSDIC : Endif
 Delete [ADP] Where PARAM="FUPBPC"
 If fstat : Call ERREUR("ADP"-"FUPBPC",3) From DOSDIC : Endif
 Delete [ADP] Where PARAM="FUPCDT"
 If fstat : Call ERREUR("ADP"-"FUPCDT",3) From DOSDIC : Endif
 Delete [ADP] Where PARAM="FUPCTL"
 If fstat : Call ERREUR("ADP"-"FUPCTL",3) From DOSDIC : Endif
 Delete [ADP] Where PARAM="FUPCUR"
 If fstat : Call ERREUR("ADP"-"FUPCUR",3) From DOSDIC : Endif
 Delete [ADP] Where PARAM="FUPFCY"
 If fstat : Call ERREUR("ADP"-"FUPFCY",3) From DOSDIC : Endif
 Delete [ADP] Where PARAM="FUPMAX"
 If fstat : Call ERREUR("ADP"-"FUPMAX",3) From DOSDIC : Endif
 Delete [ADW] Where PARAM="FUPAMT"
 If fstat : Call ERREUR("ADW"-"FUPAMT",3) From DOSDIC : Endif
 Delete [ADW] Where PARAM="FUPBPC"
 If fstat : Call ERREUR("ADW"-"FUPBPC",3) From DOSDIC : Endif
 Delete [ADW] Where PARAM="FUPCDT"
 If fstat : Call ERREUR("ADW"-"FUPCDT",3) From DOSDIC : Endif
 Delete [ADW] Where PARAM="FUPCTL"
 If fstat : Call ERREUR("ADW"-"FUPCTL",3) From DOSDIC : Endif
 Delete [ADW] Where PARAM="FUPCUR"
 If fstat : Call ERREUR("ADW"-"FUPCUR",3) From DOSDIC : Endif
 Delete [ADW] Where PARAM="FUPFCY"
 If fstat : Call ERREUR("ADP"-"FUPFCY",3) From DOSDIC : Endif
 Delete [ADW] Where PARAM="FUPMAX"
 If fstat : Call ERREUR("ADP"-"FUPMAX",3) From DOSDIC : Endif
Commit
Close Local File [ADP], [ADW]

End


####################################################
## Module immos
####################################################

####################################################
Subprog AIMMMAJV5
End

####################################################
Subprog IMMMAJV5
## Remplissage de la nouvelle table FIXWRODRG
Local Char    TABLE(GLONATB)
Local Integer OKIMMO

Local Decimal DOTFIS     : # Dotation fiscale de la période
Local Decimal DOTECO     : # Dotation economique de la période
Local Decimal TDOTFIS    : # Cumul amortissement fiscal fin période
Local Decimal TDOTECO    : # Cumul amortissement comptable fin période
Local Decimal CUMCRB     : # Cumul amortissement à réintégrer
Local Decimal OLDWROFIS  : # Amortissements antérieurs dotations fiscales 
Local Decimal OLDWROECO  : # Amortissements antérieurs dotations économiques 

Local Integer FIRSTPER   : # Indicateur 1ère période 1er exercice


Local Integer FIRSTPER   : # Indicateur 1ère période 1er exercice

TABLE = "FIXASSET"

If filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSSIER),0)>=0
 OKIMMO = 1
Endif

If OKIMMO
 ## On a les immos => on s'occupe de la MAJ de la table FIXWRODRG
 Local File =[F:ADS]DOSSIER+".FIXASSET"  [FAS]
 Local File =[F:ADS]DOSSIER+".FIXDEP"    [FDP]
 Local File =[F:ADS]DOSSIER+".FIXWRO"    [FWR]
 Local File =[F:ADS]DOSSIER+".FIXWRODRG" [FWG]
 Local File =[F:ADS]DOSSIER+".TABCUR"    [TCU]
 Local File =[F:ADS]DOSSIER+".COMPANY"   [CPY]

 Local Decimal OLDWROFIS  : # Amortissements antérieurs dotations fiscales 
 Local Decimal OLDWROECO  : # Amortissements antérieurs dotations économiques 

 GOK = 1
 Trbegin [FWG]

  For [FAS]FAS0

   Raz TDOTFIS, DOTFIS, TDOTECO, DOTECO, CUMCRB, OLDWROFIS, OLDWROECO

   Call LECTURE("CPY",[F:FAS]CPY,"") From CONTOBJ
   Call LECTURE("TCU",[F:CPY]ACCCUR,"") From CONTOBJ

   Read [FDP]FDP0 = [F:FAS]FASCOD ; [F:FAS]FASNUM ; "E"
   If !fstat
    OLDWROECO = [F:FDP]OLDWRO
   Endif
   Read [FDP]FDP0 = [F:FAS]FASCOD ; [F:FAS]FASNUM ; "F"
   If !fstat
    OLDWROFIS = [F:FDP]OLDWRO
   Endif

   FIRSTPER = 1

   For [FWR]FWR1(4) Where FASCOD=[F:FAS]FASCOD & FASNUM=[F:FAS]FASNUM & (DEPTYP="F" or DEPTYP="E")
    Raz DOTFIS, DOTECO
    ## Il y a des amortissements antérieurs : on initialise le cumul amortissements intégrés de la première
    ## période
    If (OLDWROECO | OLDWROFIS) & FIRSTPER
     TDOTFIS =  OLDWROFIS
     TDOTECO =  OLDWROECO
     If OLDWROECO>OLDWROFIS
      CUMCRB = OLDWROFIS-OLDWROECO
     Endif
    Endif
    FIRSTPER = 0
    For [F:FWR]FWR1
     If [F:FWR]DEPTYP = "F"
      TDOTFIS += [F:FWR]AMTWRO+[F:FWR]AMTEXC
      DOTFIS  = [F:FWR]AMTWRO+[F:FWR]AMTEXC
     Else
      TDOTECO += [F:FWR]AMTWRO+[F:FWR]AMTEXC
      DOTECO  = [F:FWR]AMTWRO+[F:FWR]AMTEXC
     Endif
    Next
    Raz [F:FWG]
    [F:FWG] = [F:FWR]
    If DOTECO>DOTFIS & TDOTECO>TDOTFIS
     ## Amortissement à réintégrer ([F:FWG]AMTWROCRB négatif)
     [F:FWG]AMTWROCRB = DOTFIS-DOTECO
     [F:FWG]AMTWRODRG = 0
     [F:FWG]CUMWROCRB = abs(CUMCRB) : # Cumul amortissement à réintégrer en DEBUT de période (donc CUMCRB doit être incrémentée après....)
     CUMCRB += [F:FWG]AMTWROCRB
    Elsif DOTECO>DOTFIS & TDOTFIS>=TDOTECO & CUMCRB=0
     ## Reprise dérogatoire ([F:FWG]AMTWRODRG négatif)
     [F:FWG]AMTWROCRB = 0
     [F:FWG]AMTWRODRG = DOTFIS-DOTECO
     [F:FWG]CUMWROCRB = abs(CUMCRB)
    Elsif DOTFIS>DOTECO & TDOTFIS<TDOTECO
     ## Reprise sur amortissement réintégré ([F:FWG]AMTWROCRB positif)
     [F:FWG]AMTWROCRB = DOTFIS-DOTECO
     [F:FWG]AMTWRODRG = 0
     [F:FWG]CUMWROCRB = abs(CUMCRB) : # Cumul amortissement à réintégrer en DEBUT de période (donc CUMCRB doit être incrémentée après....)
     CUMCRB += [F:FWG]AMTWROCRB
    Elsif DOTFIS>DOTECO & TDOTFIS>=TDOTECO
     ## Provision dérogatoire ([F:FWG]AMTWRODRG positif)
     ## et reprise amortissement réintégré ([F:FWG]AMTWROCRB positif)
     [F:FWG]AMTWRODRG = DOTFIS-DOTECO+CUMCRB
     [F:FWG]AMTWROCRB = DOTFIS-DOTECO-[F:FWG]AMTWRODRG
     [F:FWG]CUMWROCRB = abs(CUMCRB)
     CUMCRB += [F:FWG]AMTWROCRB
    Endif
    If [F:FWR]AMTWROACC<>0
     If [F:FWR]AMTWRO = [F:FWR]AMTWROACC : # Toute la période a été comptabilisée...
      [F:FWG]AMTDRGACC = [F:FWG]AMTWRODRG
     Else 
      [F:FWG]AMTDRGACC = arr([F:FWG]AMTWRODRG*([F:FWR]AMTWROACC/[F:FWR]AMTWRO),[F:TCU]CURRND)
     Endif
    Endif

    Write [FWG]
    If fstat
     Call ERREUR("FWG"-[F:FAS]FASCOD-num$([F:FAS]FASNUM),1) From DOSDIC
    Endif
   Next

  Next

 Commit
 Close Local File [FAS], [FDP], [FWR], [FWG], [CPY], [TCU]

Endif

End



####################################################
$ERREUR
Call ECR_TRACE("CPTMAJ14"-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
Resume






