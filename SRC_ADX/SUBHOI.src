#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet HOI
Call OBJET ("HOI", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "SETBOUT"      : Gosub SETBOUT 
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When default
  Endcase
Return

##########################################################################################################
$SETBOUT
  #----- Objet à 3 éléments de clé : ajout de la touche suppression si autorisé -----#
  If CLECUR and !GHISTO Then
    CHAINE += "A"
  Endif
  #----- Si suppression non autorisée, grisage du bouton -----#
  If GREP <> "C" Then
    GBIDC2 = "S"
    Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2 Then
      Call VIREBOUT(CHAINE, "A") From GOBJET
    Endif
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET # FGR 14/06/2010 : X3SUIVI65270
Return

##########################################################################################################
$VERIF_CRE
  GOK = 1
  Gosub VERIF_CREMOD
  If GOK < 0 Then
    OK = 0
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  GOK = 1
  Gosub VERIF_CREMOD
  If GOK < 0 Then
    OK = 0
    Return
  Endif
Return

##########################################################################################################
$VERIF_CREMOD
Local Integer IBTROUVE

  IBTROUVE = 0
  #Vérifie qu'un même couple article / compétence / utilisateur n'a pas déjà été saisi dans le tableau
  Filter [HOI] Where [F:HOI]MACNUM=[M:HOI0]MACNUM and [F:HOI]PBLNUM=[M:HOI0]PBLNUM and [F:HOI]AUSNUM=[M:HOI0]AUSNUM
  For [HOI]
    IBTROUVE = 1
    Break
  Next
  Filter [HOI]
  If IBTROUVE = 1 Then
    #Une combinaison (Article / Famille de compétence / Utilisateur) identique a déjà été saisie.
    GMESSAGE = mess(593,177,1) - num$(ITER+1)
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
Subprog C_PBLNUM(VALEUR)
Variable Char    VALEUR()

  Gosub CTLSHORTCUT From SUBPBLB
End

##########################################################################################################
Subprog C_AUSNUM(VALEUR)
Variable Char    VALEUR()

Local Char SZMESS(250)
Local Integer IONREP
Local Char SZHDKREP
Local Integer IHDKREP

  SZHDKREP = ""
  IHDKREP = 0
  SZMESS = ""
  IONREP = 0
  #Vérifie si l'utilisateur saisi est un collaborateur Help-Desk
  If VALEUR <> "" Then
    Read [AUS]CODUSR=VALEUR
    If fstat <> 0 Then
      GMESSAGE = mess(83,123,1) #Valeur incorrecte 
      GERR = 2
      mkstat = 2
    Else
      Call PARAMUTIL("AUSHDKA", SZHDKREP, VALEUR, "") From SUBAUS
      If SZHDKREP = "" Then
        IHDKREP = 1
      Else
        IHDKREP = val(SZHDKREP)
      Endif
      If IHDKREP <> 2 Then
        #XXX n'est pas un collaborateur du service Support client. Confirmez-vous la saisie ?
        SZMESS = [F:AUS]NOMUSR - mess(619,196,1)
        Call OUINON(SZMESS, IONREP) From GESECRAN
        If IONREP <> 2 Then
          mkstat = 2
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

  #Vérifie que l'utilisateur a bien saisi une prestation
  Read [ITM]ITM0=VALEUR
  If fstat <> 0 Then
    GMESSAGE = mess(83,123,1) #Valeur incorrect.
    GERR = 1
    mkstat = 2
    End
  Else
    If [F:ITM]HDKITMTYP <> 3 Then
      #L'article saisi n'est pas une prestation de service. Saisie refusée.
      GMESSAGE = mess(219,182,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End
