End

Subprog TRT_LOAD_KEYS(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Gosub INTERLINE
LIGNE = "# "-ACLA.ACLAV.TBMET(14) : Gosub ADDCLB
Gosub INTERLINE
LIGNE = "$"+ACLA.ACLAV.TBMET(14) : Gosub ADDCLB
For I=1 To ACLA.NBCLEREF
 LIGNE = 'this.AKEYS('+num$(I)+') = "'+ACLA.ACLAI(I).CLEREF+'"' : Gosub ADDCLB
Next
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
End



Subprog TRT_METHODES(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
For M=1 To maxtab(ACLA.ACLAM)
 If M=1 : Gosub SUB_COM_METHOD : Endif
 Call TRT_MET(ACLA.ACLAM(M),LIGNE,CLOB,DIF)
Next
End

Subprog TRT_MET_STD(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
If ACLA.TYPCLA<>1 : End : Endif
For MT=1 To maxtab(ACLA.ACLAT)
 Case ACLA.ACLAT(MT).CODMETSTD
  When "C" : Gosub TRTMETSTD
  When "R" : Gosub TRTMETSTD
  When "U" : Gosub TRTMETSTD
  When "D" : Gosub TRTMETSTD
 Endcase
Next
End

$TRTMETSTD
LIGNE = "# Method "-ACLA.ACLAT(MT).NAMMETSTD : Gosub ADDCLB
LIGNE = "$"+ACLA.ACLAT(MT).NAMMETSTD: Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR" : Gosub ADDCLB
LIGNE = '[L]AEVENT = "'+ACLA.ACLAT(MT).NAMMETSTD+'" : [L]ACTION = "'+ACLA.ACLAT(MT).NAMMETSTD+'" : [L]CURPRO = "" : Gosub ACTION From'-ACLA.ACLAV.TRTACT  : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

Subprog TRT_OPERATION(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
For O=1 To maxtab(ACLA.ACLAO)
 If O=1 : Gosub SUB_COM_OPERATION : Endif
  Call TRT_OPE(ACLA.ACLAO(O),LIGNE,CLOB,DIF)
Next
LIGNE = "" : Gosub ADDCLB
End

#---------------------------------#
Subprog TRT_MET(ACLAM,LIGNE,CLOB,DIF)
Variable  Instance  ACLAM Using C_ACLAMET
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "# Fmethod"-ACLAM.INTITMET  : Gosub ADDCLB
LIGNE = "$"+ACLAM.CODMET : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR" : Gosub ADDCLB
LIGNE = '[L]AISMET = [V]CST_AYES' :  Gosub ADDCLB
LIGNE = '[L]AMETHOD = "'+ACLAM.CODMET+'" : [L]ACTION = "'+ACLAM.CODMET+'" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB'  : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#---------------------------------#
Subprog TRT_OPE(ACLAM,LIGNE,CLOB,DIF)
Variable  Instance  ACLAM Using C_ACLAMET
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "# Fmethod"-ACLAM.INTITMET  : Gosub ADDCLB
LIGNE = "$"+ACLAM.CODMET : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR" : Gosub ADDCLB
LIGNE = '[L]AISMET = [V]CST_ANO' :  Gosub ADDCLB
LIGNE = '[L]AOPERATION = "'+ACLAM.CODMET+'" : [L]ACTION = "'+ACLAM.CODMET+'" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB'  : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End



#------------------------------------------------------------------------------#

Subprog TRT_ADDTRT(ACLA,ACLATRT,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Instance ACLATRT(1..) Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Integer J,I

Gosub INTERLINE
LIGNE = "# Traitments" : Gosub ADDCLB
Gosub INTERLINE
LIGNE = "$_ADDTRT" : Gosub ADDCLB

If dim(ACLA.ACLAV.TRTMAP)>0 & ACLA.ACLAV.TRTMAP<>""
 J+= 1
 LIGNE = 'this.AINF.TRT('+num$(J)+') = "'+ACLA.ACLAV.TRTMAP+'"' : Gosub ADDCLB
 LIGNE = 'this.AINF.TYP('+num$(J)+') = 1' : Gosub ADDCLB
 LIGNE = 'this.AINF.PTH('+num$(J)+') = ""' : Gosub ADDCLB
Endif

For I=1 To maxtab(ACLATRT)
 If ACLATRT(I)<>null & ACLATRT(I).CODTRT<>""
  J += 1
  LIGNE = 'this.AINF.TRT('+num$(J)+') = "'+ACLATRT(I).CODTRT+'"' : Gosub ADDCLB
  LIGNE = 'this.AINF.TYP('+num$(J)+') = '+num$(ACLATRT(I).TYPTRT) : Gosub ADDCLB
  LIGNE = 'this.AINF.PTH('+num$(J)+') = "'+ACLA.CODESUBCLA+'"' : Gosub ADDCLB
 Endif
Next

If dim(ACLA.ACLAV.TRTCTLSUP)>0 & ACLA.ACLAV.TRTCTLSUP<>""
 J+= 1
 LIGNE = 'this.AINF.TRT('+num$(J)+') = "'+ACLA.ACLAV.TRTCTLSUP+'"' : Gosub ADDCLB
 LIGNE = 'this.AINF.TYP('+num$(J)+') = 1' : Gosub ADDCLB
 LIGNE = 'this.AINF.PTH('+num$(J)+') = ""' : Gosub ADDCLB
Endif


If J>0
 LIGNE = 'this.AINF.NBTRT = '+num$(J) : Gosub ADDCLB
Endif
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End


Subprog TRT__ADELINSTANCE(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
