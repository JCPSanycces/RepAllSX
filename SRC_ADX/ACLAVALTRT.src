LIGNE = "Gosub DECLARE_VAR From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
APPEL_TYP =ACLA.ACLAV.TBMET(8)
LIGNE = "Local Integer "+ACLA.ACLAV.VARCTLALL : Gosub ADDCLB
Gosub APPEL_PRINCIPALE
LIGNE = "[L]"+ACLA.ACLAV.VARCTL-"= fmet this."+ACLA.ACLAV.TBMET(17)  : Gosub ADDCLB
# 115884 LIGNE = "If [L]"+ACLA.ACLAV.VARCTL+">=[V]CST_AERROR : [L]"+ACLA.ACLAV.VARCTLALL+" = max([L]"+ACLA.ACLAV.VARCTLALL+",[L]"+ACLA.ACLAV.VARCTL+") : Return : Endif" : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARCTLALL+" = max([L]"+ACLA.ACLAV.VARCTLALL+",[L]"+ACLA.ACLAV.VARCTL+")" : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
End

#------------------------------------------------------------------------------#

Subprog TRT_ATTRIBUTE_ALL(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Char APPEL_TYP(GLONAVB)

Gosub INTERLINE
LIGNE = "# _ALOADATTRIBUTE" : Gosub ADDCLB
Gosub INTERLINE
LIGNE = "" : Gosub ADDCLB
LIGNE = "$"+ACLA.ACLAV.TBMET(9) : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
APPEL_TYP = ACLA.ACLAV.TBMET(9)
Gosub APPEL_PRINCIPALE
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
End

#------------------------------------------------------------------------------#

$TRT_TESTALLSTAT
LIGNE = "$TESTALLSTAT" : Gosub ADDCLB
# 115884 LIGNE  = "If [L]ASTATUS>=[V]CST_AERROR : [L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS) : Endif" : Gosub ADDCLB
LIGNE  = "[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)" : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
Return

#------------------------------------------------------------------------------#
$APPEL_PRINCIPALE
Raz ACLA.ACLAV.NBPRG
Call SUB_DEF_TRT(ACLA)
For F=1 To maxtab(ACLA.ACLAF)
 Call APPEL_SECONDAIRE(ACLA,ACLA.ACLAF(F),APPEL_TYP,LIGNE,CLOB,DIF,F)
Next F
Return

Subprog APPEL_SECONDAIRE(ACLA,ACLAF,APPEL_TYP,LIGNE,CLOB,DIF,LIGCUR)
Variable Instance ACLA Using OBJECT
Value  Instance  ACLAF Using OBJECT
Value Char APPEL_TYP
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Value Integer LIGCUR

Local Integer I,J
If !find(ACLAF.FLDCLA,"",ACLA.ACLAV.VARLIG)
 If ACLAF.CODTYP<>"" & APPEL_TYP<>ACLA.ACLAV.TBMET(5)
  Gosub APPEL
 Elsif ACLAF.LNKCLA<>"" & find(APPEL_TYP,ACLA.ACLAV.TBMET(9))=0 & ACLAF.LNKCLATYP<>4
  If ACLAF.DIME=1
   If ACLAF.FLDGRP="" or find(ACLAF.FLDGRP,ACLA.CODGRP(1..ACLA.NBRGRP)) :# 110282 CCL
    LIGNE = "If this."+ACLAF.FLDCLA+"<>null" : Gosub ADDCLB
    DIF += 1
    Gosub APPEL_ALL
    DIF -= 1
    LIGNE = 'Endif' : Gosub ADDCLB
   Endif
  Else
   If find(APPEL_TYP,"AINIT")=0
    If ACLAF.DIME=0
     LIGNE = "For"-ACLA.ACLAV.VARIST+"=1 To maxtab(this."+ACLAF.FLDCLA+")" : Gosub ADDCLB
    Else
     LIGNE = "For"-ACLA.ACLAV.VARIST+"=1 To"-num$(ACLAF.DIME) : Gosub ADDCLB
    Endif
    DIF += 1
    LIGNE = "If this."+ACLAF.FLDCLA+"("+ACLA.ACLAV.VARIST+")<>null"
    If find(APPEL_TYP,"_AERROR","_ADELERRORS","ASEARCHINFOS")=0
     LIGNE += "& find(this."+ACLAF.FLDCLA+"("+ACLA.ACLAV.VARIST+")"+".ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0"
    Endif
    Gosub ADDCLB
    DIF += 1
    Gosub APPEL_ALL
    DIF -= 1
    LIGNE = 'Endif' : Gosub ADDCLB
    DIF -= 1
    LIGNE = 'Next'-ACLA.ACLAV.VARIST : Gosub ADDCLB
   Endif
  Endif
 Endif
Endif
If mod(LIGCUR,func ACLAVALLEC.MAXPRO)=0  : Call SUB_DEF_TRT(ACLA) : Endif
End


#------------------------------------------------------------------------------#
$APPEL_ALL
LIGNE = "[L]"+ACLA.ACLAV.VARCTL-"= fmet this."+ACLAF.FLDCLA
If ACLAF.DIME<>1  : #& !find(APPEL_TYP,TBMET(6),TBMET(7),TBMET(8),TBMET(9))
 LIGNE += "("+ACLA.ACLAV.VARIST+")"
Endif
If APPEL_TYP=ACLA.ACLAV.TBMET(17) : # A_CONTROL"
 LIGNE += "."+ACLA.ACLAV.TBMET(4) +"("+ACLA.ACLAV.VARNXT+")"
Elsif APPEL_TYP=ACLA.ACLAV.TBMET(5) : # "A_INIT"
 LIGNE += "."+ACLA.ACLAV.TBMET(5)
Elsif APPEL_TYP=ACLA.ACLAV.TBMET(10) : # "A_LNKPRO""
 LIGNE += "."+ACLA.ACLAV.TBMET(11)
Elsif APPEL_TYP=ACLA.ACLAV.TBMET(12) : # Aerror
 LIGNE += "."+ACLA.ACLAV.TBMET(12)+"(_CTX,_SUPP)"
Elsif APPEL_TYP=ACLA.ACLAV.TBMET(18) : # Aerror
 LIGNE += "."+ACLA.ACLAV.TBMET(18)+"(_APARAM)"
Elsif APPEL_TYP="ASEARCHINFOS"
#If GUSER="CCL"
  LIGNE += "._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'"+ACLAF.FLDCLA
# Else
 # LIGNE += "._ASEARCHINFOS(this,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'"+ACLAF.FLDCLA
 #Endif #
 #116843
 If ACLAF.DIME<>1
  LIGNE +=  "('+num$(AINDCLA)+')"
 Endif
 LIGNE += "')"
Else
 LIGNE += "."+[L]APPEL_TYP
Endif
If !find([L]APPEL_TYP,ACLA.ACLAV.TBMET(12),ACLA.ACLAV.TBMET(18),"ASEARCHINFOS")
 LIGNE += " : Gosub TESTALLSTAT"
Endif
Gosub ADDCLB
Return

#------------------------------------------------------------------------------#
$APPEL
If  find(ACLA.TYPCLA,3,4)>0 : Return : Endif
If APPEL_TYP=ACLA.ACLAV.TBMET(10)
#91088/5
 If ACLAF.ACHPSHO=null & ACLAF.ACHPLNG=null & ACLAF.ACHPSYM=null
&   & ACLAF.ACHPCOLFMT=null & ACLAF.ACHPCOLLNG=null & ACLAF.ACHPCOLDEC=null
&   & find(ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB)=0
&   & find(5,ACLAF.ATY.ARUL(1..maxtab(ACLAF.ATY.ARUL)).TYPRUL)=0 : #rule FORMAT
   Return
 Endif
Elsif APPEL_TYP=ACLA.ACLAV.TBMET(9) & ACLAF.OBLIG<>2
 Return
Endif
If find(APPEL_TYP,ACLA.ACLAV.TBMET(12),ACLA.ACLAV.TBMET(18),"ASEARCHINFOS")>0 : Return : Endif
LIGNE = ""
If find(APPEL_TYP,ACLA.ACLAV.TBMET(5),ACLA.ACLAV.TBMET(1)) :
 LIGNE += "[L]"+ACLA.ACLAV.VARCTL-"= fmet this."+ACLAF.FLDCLA+"."+ACLA.ACLAV.TBMET(1)
Else
 If  find(APPEL_TYP,ACLA.ACLAV.TBMET(6),ACLA.ACLAV.TBMET(7),ACLA.ACLAV.TBMET(8))
  LIGNE += "If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : "
 Endif
 If find(APPEL_TYP,ACLA.ACLAV.TBMET(16))
  LIGNE += "Gosub "+ACLA.ACLAV.TBMET(1)+"_"+ACLAF.FLDCLA+" From "+ACLA.ACLAV.NOMPRG
 Else
  LIGNE += "Gosub "+APPEL_TYP+"_"+ACLAF.FLDCLA+" From "+ACLA.ACLAV.NOMPRG
  If find(APPEL_TYP,ACLA.ACLAV.TBMET(8))
   LIGNE += " : Gosub TESTALLSTAT : Gosub "+APPEL_TYP+"_REF_"+ACLAF.FLDCLA+" From "+ACLA.ACLAV.NOMPRG
  Endif
 Endif
Endif
LIGNE += " : Gosub TESTALLSTAT"
If find(APPEL_TYP,ACLA.ACLAV.TBMET(6),ACLA.ACLAV.TBMET(7),ACLA.ACLAV.TBMET(8))
 LIGNE += " :  Endif"
Endif
Gosub ADDCLB
Return

#-------------------------------------------------------#
Subprog SUB_DEF_TRT(ACLA)
Variable Instance ACLA Using OBJECT
ACLA.ACLAV.NBPRG    += 1
If left$(ACLA.ACLAV.NOMSTC,1)="C"
 ACLA.ACLAV.NOMPRG     = func APREFIXTRT.GET_PREFIX_CLA+num$(ACLA.ACLAV.NBPRG)+ACLA.CODECLA
 ACLA.ACLAV.CTLPRG      = func APREFIXTRT.GET_PREFIX_CLA+"0"+ACLA.CODECLA
 ACLA.ACLAV.INICTLPRG  = func APREFIXTRT.GET_PREFIX_CLA+"N"+ACLA.CODECLA
 ACLA.ACLAV.ALLCTLPRG  = func APREFIXTRT.GET_PREFIX_CLA+"C"+ACLA.CODECLA
Else
 ACLA.ACLAV.NOMPRG    = func APREFIXTRT.GET_PREFIX_REP+num$(ACLA.ACLAV.NBPRG)+ACLA.CODECLA
 ACLA.ACLAV.CTLPRG      = func APREFIXTRT.GET_PREFIX_REP+"0"+ACLA.CODECLA
 ACLA.ACLAV.INICTLPRG  = func APREFIXTRT.GET_PREFIX_REP+"N"+ACLA.CODECLA
 ACLA.ACLAV.ALLCTLPRG  = func APREFIXTRT.GET_PREFIX_REP+"C"+ACLA.CODECLA
Endif
End

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return


#-------------------------------------------------------#
Subprog SUB_COM(LIGNE,ACLAF,CLOB,DIF)
Variable Char LIGNE
Variable  Instance  ACLAF Using C_ACLAFLD
Variable Clbfile CLOB
Variable Integer DIF

LIGNE -=  ACLAF.INTITFLD-"("
If ACLAF.LNKCLA<>"" : # Classe
 LIGNE += mess(3,140,1)-ACLAF.LNKCLA
Endif
If ACLAF.ATY<>null & !find(ACLAF.ATY.CODTYP,"")
 If ACLAF.FLDCLA <>""
  LIGNE += " "+mess(36,124,1)+" " : # Champ
 Endif
 If ACLAF.ATY.TYPTYP=1 : # Menu
  LIGNE += mess(56,142,1)-num$(ACLAF.MENU)
 Elsif ACLAF.ATY.TYPTYP=8 : # Date
  LIGNE += ACLAF.ATY.CODTYP
 Elsif ACLAF.ATY.CODTYP="ADI"
  LIGNE += mess(50,142,1) : # Table diverse numéro
  #K = find("CONTADI",ACT_COD(ASF_PTA(F)..(ASF_PTA(F)+ASF_NBA(F)-1)))
  #If K
  # K += ASF_PTA(F)-1
  # L = find("ADI",PAR_COD(K,1..ACT_PAR(K)))
  # If L : LIGNE -= PAR_VAL(K,L) : Endif
  #Endif
 Elsif ACLAF.ATY.TYPTYP=11 : # Uuid
  LIGNE += " Uuident"
 Elsif find(ACLAF.ATY.CODTYP,"ATX","AXX","AX1","AX2","AX3")
  LIGNE += ACLAF.ATY.CODTYP
 Else
  LIGNE += ACLAF.ATY.CODTYP-num$(ACLAF.LON)
 Endif
Endif
LIGNE += ")"
Gosub ADDCLB
End

