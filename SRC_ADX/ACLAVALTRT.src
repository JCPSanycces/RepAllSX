#------------------------------------------------#
Subprog SETFMT(TYPFMT,CHFMT,LONG,OPTSAI,FMT)
Value    Char    TYPFMT
Value    Char    CHFMT
Value    Integer LONG
Value    Char    OPTSAI
Variable Char    FMT
Local    Char    OPTFMT(20), CARFMT(20)
Local    Integer OK
OK = 1
If left$(CHFMT,1)="=" | instr(1,CHFMT,"[") | instr(1,CHFMT,">")
 CHFMT = ""
Endif
If left$(CHFMT,1)<>"=" & CHFMT<>""
 Gosub OPTCAR
 If OPTSAI="" & instr(1,CHFMT,"X")
  OK = 0
 Endif
Else
 Gosub OPTCAR
 CHFMT  = num$(LONG)+CARFMT
Endif
If instr(1,OPTFMT,"T") & !instr(1,OPTFMT,"TD")
 OK = 0
Endif
If !OK
 FMT = ""
Else
 FMT = TYPFMT+OPTFMT+":"+CHFMT
Endif
End

#------------------------#
$OPTCAR
If instr(1,OPTSAI,"C")
 CARFMT = "c" : #VVVVVV
 #CARFMT = "B" ????
Elsif instr(1,OPTSAI,"A")
 If instr(1,OPTSAI,"#") : CARFMT = "B" : Else : CARFMT = "A" : Endif
Elsif instr(1,OPTSAI,"#")
 CARFMT = "#"
Else
 CARFMT = "X"
Endif
If    instr(1,OPTSAI,"T") : OPTFMT += "T"
Elsif instr(1,OPTSAI,"D") : OPTFMT += "TD"
Endif
If    instr(1,OPTSAI,"*") : OPTFMT += "*+" : Endif
If    instr(1,OPTSAI,"1") : OPTFMT += "1" : Endif
If    instr(1,OPTSAI,"z") : OPTFMT += "z" : Endif
If    instr(1,OPTSAI,"=") : OPTFMT += "="
Elsif instr(1,OPTSAI,"<") : OPTFMT += "<"
Elsif instr(1,OPTSAI,">") : OPTFMT += ">"
Endif
If    instr(1,OPTSAI,"W") : OPTFMT += "W" : Endif
Return

