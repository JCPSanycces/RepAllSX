Variable Clbfile CLOB
Variable Integer DIF
Gosub INTERLINE
LIGNE = "# Delete all errors" : Gosub ADDCLB
Gosub INTERLINE
LIGNE = "" : Gosub ADDCLB
LIGNE = "$"+ACLA.ACLAV.TBMET(18) : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
APPEL_TYP =ACLA.ACLAV.TBMET(18)
LIGNE = "Local Integer "+ACLA.ACLAV.VARCTLALL : Gosub ADDCLB
#If ACLA.TYPCLA=-1 & instr(1,ACLA.CODCLA,"_")=0
# LIGNE = "[L]ASTATUS = fmet this."+ACLA.ABRCLA+"."+ACLA.ACLAV.TBMET(18)+"([L]_APARAM)": Gosub ADDCLB
#Endif
LIGNE = "[L]ASTATUS = fmet this.ADELETEERROR([L]_APARAM)" : Gosub ADDCLB
Gosub APPEL_PRINCIPALE
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
End

Subprog TRT_AGETERRORSFROM(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Gosub INTERLINE
LIGNE = "# AGETERRORSFROM" : Gosub ADDCLB
Gosub INTERLINE
LIGNE = "" : Gosub ADDCLB
LIGNE = "$_AGETERRORSFROM" : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
LIGNE = "If AINS_FROM<>null" : Gosub ADDCLB
LIGNE = ' [L]ASTATUS = fmet AINS_FROM.ASEARCHINFOS( [V]CST_ALL, "", [V]CST_AFATAL, 0)' : Gosub ADDCLB
LIGNE = "Endif" : Gosub ADDCLB
LIGNE = "Call AGETERRORSFROM(AINS_FROM,this,ENVIRONNEMENT) From ASYRSUB" : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
