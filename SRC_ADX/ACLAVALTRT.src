Gosub INTERLINE
LIGNE = "# _ADELINSTANCE": Gosub ADDCLB
Gosub INTERLINE
LIGNE = "$_ADELINSTANCE" : Gosub ADDCLB
LIGNE = '[L]ASTATUS = func ASYRSUBTAB._ADELINSTANCE(this)' : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#------------------------------------------------------------------------------#
Subprog METTABGEN(METCURTAB,ACLA,LIGNE,CLOB,DIF)
Value Char METCURTAB
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Integer I,K,J,G

Gosub INTERLINE
LIGNE = "# "-[L]METCURTAB : Gosub ADDCLB
Gosub INTERLINE
LIGNE = "$"+[L]METCURTAB : Gosub ADDCLB
LIGNE = "Case _ACOLLECTION" : Gosub ADDCLB
DIF += 1

For G=1 To ACLA.NBRGRP
  LIGNE = 'When "'+ACLA.CODGRP(G)+'"' : Gosub ADDCLB
  DIF +=1
  Case [L]METCURTAB
   When  "ADDLINE"
    If ACLA.PROUID(G)<>""
     LIGNE = '[L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"'+ACLA.PROUID(G)+'","'
     If ACLA.TYPCLA=-1 &  ACLA.ABRCLA<>ACLA.CODGRP(G): LIGNE += "R_"
     Else                    : LIGNE += "C_"
     Endif
     LIGNE += ACLA.CLAUID(G)+'",this)' : Gosub ADDCLB
     If ACLA.PROGRP(G)<>""
      LIGNE = "If [L]_ALINE<>[V]CST_ANOTDEFINED : this."+ACLA.PROGRP(G)+" += 1 : Endif" : Gosub ADDCLB
     Endif
    Endif
   When "ADELLINE"
    If ACLA.PROUID(G)<>""
     If ACLA.TYPCLA=3
      LIGNE = "If this."+ACLA.CODGRP(G)+"([L]ALINE)<>null : FreeInstance this."+ACLA.CODGRP(G)+"([L]ALINE) : this."+ACLA.CODGRP(G)+"([L]ALINE) = null :Endif" : Gosub ADDCLB
     Else
      LIGNE = '[L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"'+ACLA.PROUID(G)+'",this)' : Gosub ADDCLB
      If ACLA.PROGRP(G)<>""
       LIGNE = "If [L]_ALINE<>[V]CST_ANOTDEFINED : this."+ACLA.PROGRP(G)+" -= 1 : Endif" : Gosub ADDCLB
      Endif
     Endif
    Endif
   When "AGETMIN"
    LIGNE = '[L]_ALINE = '+num$(ACLA.MINGRP(G))
    Gosub ADDCLB
   When "AGETDIM"
    LIGNE = '[L]_ALINE = '+num$(ACLA.MAXGRP(G))
    Gosub ADDCLB
  Endcase
  DIF -=1
Next
LIGNE = 'When Default :'  : Gosub ADDCLB
DIF +=1
LIGNE = '[L]_ALINE = [V]CST_ANOTDEFINED'  : Gosub ADDCLB
DIF =1
DIF -= 1
LIGNE = "Endcase" : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End


Funprog DECLARE_TYPTYP(TYPTYP)
Value Integer TYPTYP
Case [L]TYPTYP
 When 1      : End "Tinyint"
 When 2     :  End "Shortint"
 When 3    :  End "Integer"
 When 4,5   : End "Decimal"
 When 6     : End "Double"
 When 8       : End "Date"
 When 9       : End "Blbfile"
 When 10      : End "Clbfile"
 When 11      : End "Uuident"
 When 12      : End "Datetime"
 When 13      : End "Instance"
 When Default : End "Char"
Endcase
End


#------------------------------------------------------------------------------#
Funprog DECLARE_DIME(DIME,TYP,MODPAR)
Value Integer DIME
Value Integer TYP
Value Integer MODPAR
Local Char CHAINE(10)
If find(TYP,[V]CST_ATYPCLOB,[V]CST_ATYPBLOB)>0 : #  or MODPAR<>1 6 7
 End ""
Endif
If TYP=[V]CST_ATYPCHAR
 CHAINE += '()'
Endif
If DIME=2
 CHAINE += "(1..)"
Elsif DIME=3
 CHAINE += "(0..)"
Endif
End CHAINE

#------------------------------------------------------------------------------#
Funprog DECLARE_MODE(MODES)
Value Integer MODES
Case MODES
 When 1        : End "Variable "
 When 2,3        : End "Value    "
 When Default  : End "Local    "
Endcase
End

#------------------------------------------------------------------------------#
Subprog TRT_ACTION(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "" : Gosub ADDCLB
Gosub SUB_COM_ACTION
LIGNE = "" : Gosub ADDCLB
LIGNE = "$ACTION" : Gosub ADDCLB
LIGNE = "Local    Char     "+ACLA.ACLAV.VARSTR+"("+num$(GLONADC)+") , CODTRT("+num$(GLONADC)+")(1..16)" : Gosub ADDCLB
LIGNE = "Local    Integer  TYPTRT(1..16) , NBRTRT , INDTRT" : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARSTR+' = "'+ACLA.CODECLA+'"' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = 'Gosub ACTION From'-ACLA.ACLAV.TRTACT : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#-------------------------------------------------------#
Subprog TRT_DECLARE_VAR(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Gosub SUB_COM_VAR
LIGNE = "" : Gosub ADDCLB
LIGNE = "$DECLARE_VAR" : Gosub ADDCLB
LIGNE = "Local Char    ACTION(50) , "+ACLA.ACLAV.VARPRO+"(250) , "+ACLA.ACLAV.VARVAL+"(250) , "+ACLA.ACLAV.VARQRY+"(50) , "+ACLA.ACLAV.VARPTH+"(250)" : Gosub ADDCLB
LIGNE = "Local Char    AMETHOD(50) ,AOPERATION(50),AEVENT(50),ARULE(50)" : Gosub ADDCLB
LIGNE = "Local Integer ALLSTAT,AISMET,"+ACLA.ACLAV.VARCTL : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#------------------------------------------------------------------------------#
Subprog TRT_A_LNKPRO(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Char APPEL_TYP(GLONAVB)

Gosub INTERLINE
LIGNE = "# "+ACLA.ACLAV.TBMET(11) : Gosub ADDCLB
Gosub INTERLINE
LIGNE = "" : Gosub ADDCLB
LIGNE = "$"+ACLA.ACLAV.TBMET(11) : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
APPEL_TYP = ACLA.ACLAV.TBMET(10)
Gosub APPEL_PRINCIPALE
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
End

#------------------------------------------------------------------------------#
#------------------------------------------------------------------------------#
Subprog TRT_AINIT(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Local Char APPEL_TYP(GLONAVB)
Gosub INTERLINE
LIGNE = "# AINIT" : Gosub ADDCLB
Gosub INTERLINE
LIGNE = "" : Gosub ADDCLB
LIGNE = "$AINIT" : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
LIGNE = "Local Integer ALINE,TBLINE,ASTASNAPSHOT,"+ACLA.ACLAV.VARCTLALL : Gosub ADDCLB
#APPEL_TYP = "AINIT"
APPEL_TYP = ACLA.ACLAV.TBMET(16)
LIGNE = "If this.APARENT=null & this.snapshotEnabled=0" : Gosub ADDCLB
DIF += 1
LIGNE = "this.snapshotEnabled = 1" : Gosub ADDCLB
DIF -= 1
LIGNE = "Elsif this.APARENT<>null" :Gosub ADDCLB
DIF += 1
LIGNE = "this.snapshotEnabled = this.APARENT.snapshotEnabled" : Gosub ADDCLB
DIF -= 1
LIGNE = "Endif" : Gosub ADDCLB
If ACLA.FLGACTX<>2
 LIGNE = "If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif" : Gosub ADDCLB
Endif
# 115884 LIGNE = "If [L]"+ACLA.ACLAV.VARCTLALL+">=[V]CST_AERROR : [L]"+ACLA.ACLAV.VARCTL+" = [L]"+ACLA.ACLAV.VARCTLALL+" : Return : Endif" : Gosub ADDCLB
If ACLA.TYPCLA=-1
 LIGNE  = 'this._AFCRIGHT = "'+ACLA.AFCRIGHT+'"' : Gosub ADDCLB
Endif
Gosub ADD_GRID
Gosub APPEL_PRINCIPALE
LIGNE = "Gosub AINIT From "+ACLA.ACLAV.CTLPRG-": Gosub TESTALLSTAT"  : Gosub ADDCLB
#LIGNE = '[L]ASTATUS = func ASYRSUB.AGETMAXERROR(this.AERROR,"") : Gosub TESTALLSTAT'   : Gosub ADDCLB
LIGNE = "If this.snapshotEnabled=1 & this.APARENT=null" : Gosub ADDCLB
DIF += 1
LIGNE = "[L]ASTASNAPSHOT = this.freeSnapshot" : Gosub ADDCLB
DIF -= 1
LIGNE = "Endif" : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
End

$ADD_GRID
# Add collection with maximum
Local Integer G,LINE,K
For G=1 To ACLA.NBRGRP
 If ACLA.PROUID(G)<>"" & ACLA.MINGRP(G)=3
  LIGNE = "For TBLINE=1 to "+num$(ACLA.MAXGRP(G)) : Gosub ADDCLB
  DIF += 1
  LIGNE = '[L]ALINE = func ASYRSUBTAB.ADDLINE([L]TBLINE,"'+ACLA.PROUID(G)+'","'
  If ACLA.TYPCLA=-1 &  ACLA.ABRCLA<>ACLA.CODGRP(G): LIGNE += "R_"
  Else                    : LIGNE += "C_"
  Endif
  LIGNE += ACLA.CLAUID(G)+'",this)': Gosub ADDCLB
  LIGNE = "If [L]ALINE=[V]CST_ANOTDEFINED : [L]"+ACLA.ACLAV.VARCTL+" = [V]CST_AERROR : Break : Endif" : Gosub ADDCLB
  If ACLA.PROGRP(G)<>""
   LIGNE = "this."+ACLA.PROGRP(G)+" += 1" : Gosub ADDCLB
  Endif
  DIF -= 1
  LIGNE = "Next" : Gosub ADDCLB
  LIGNE = "If [L]"+ACLA.ACLAV.VARCTL+" = [V]CST_AERROR :  Gosub TESTALLSTAT : Endif" : Gosub ADDCLB
 Endif
Next
Return

#------------------------------------------------------------------------------#
Subprog TRT_A_CONTROL(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Gosub INTERLINE
LIGNE = "# "+ACLA.ACLAV.TBMET(4) : Gosub ADDCLB
Gosub INTERLINE
LIGNE = "" : Gosub ADDCLB
LIGNE = "$"+ACLA.ACLAV.TBMET(4) : Gosub ADDCLB
LIGNE = "Gosub "+ACLA.ACLAV.TBMET(6)+space$(15-len(ACLA.ACLAV.TBMET(6)))+" : [L]"+ACLA.ACLAV.VARCTL+" = max([L]"+ACLA.ACLAV.VARCTL+",[L]"+ACLA.ACLAV.VARCTLALL+")"  : Gosub ADDCLB
LIGNE = "If [L]"+ACLA.ACLAV.VARCTL+">=[V]CST_AERROR : Return : Endif"  : Gosub ADDCLB
LIGNE = "Gosub "+ACLA.ACLAV.TBMET(7)+space$(15-len(ACLA.ACLAV.TBMET(7)))+" : [L]"+ACLA.ACLAV.VARCTL+" = max([L]"+ACLA.ACLAV.VARCTL+",[L]"+ACLA.ACLAV.VARCTLALL+")"  : Gosub ADDCLB
LIGNE = "If [L]"+ACLA.ACLAV.VARCTL+">=[V]CST_AERROR : Return : Endif"  : Gosub ADDCLB
LIGNE = "Gosub "+ACLA.ACLAV.TBMET(8)+space$(15-len(ACLA.ACLAV.TBMET(8)))+" : [L]"+ACLA.ACLAV.VARCTL+" = max([L]"+ACLA.ACLAV.VARCTL+",[L]"+ACLA.ACLAV.VARCTLALL+")"  : Gosub ADDCLB
LIGNE = "If [L]"+ACLA.ACLAV.VARCTL+">=[V]CST_AERROR : Return : Endif"  : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
End

