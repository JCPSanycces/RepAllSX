#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub TEST From ACLAVAL
End

#---------------------------------------------------------------------------------------------------#
# Ecriture du traitement
#---------------------------------------------------------------------------------------------------#
Subprog VALSTR_CLASSE(DOSSIER,CODCLA,TYPGEN,VALP,TYPAGE,ACLA,AERR)
Value Char DOSSIER , CODCLA
Value Integer TYPGEN
Value Integer VALP
Variable Integer TYPAGE
Variable  Instance  ACLA  Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR

Local Integer OK
Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

Call STC_VERF(ACLA.ACLAV.NOMSTC,ACLA.ACLAV.IDENTSTC,APPLI,MACHINE,"STC",OK,AERR) From ACLASUB
If  OK

 If TYPGEN=0
  Call SAVE_STC(DOSSIER,[L]CODCLA) From ACLAVALSUB :  # Save in stcol and srcold
  Call DELETE_STC(DOSSIER,[L]CODCLA) From ACLAVALSUB : # Delete STC and WMCL*
 Endif

 # creation du fichiet stc (classe)
 Call CREATE_STC(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR) From ACLAVALSTC
 If maxtab(AERR)>0  : End : Endif

 # Creation du traitement de mapping cle/propriété
 Call CREATE_TRTMAP(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR) From ACLAVALMAP
 If maxtab(AERR)>0  : End : Endif

 # Creation du fichier WCLA0 , qui integre les methodes, operations ,
 Call CREATE_TRT(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR)
 If maxtab(AERR)>0  : End : Endif

 # Creation du fichier d'init, et format
 Call CREATE_TRTINI(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR)
 If maxtab(AERR)>0  : End : Endif

 # Creation du fichier de control globale
 Call CREATE_TRTCTL(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR)
 If maxtab(AERR)>0  : End : Endif

 # Creation du traitement des champs
 Call CREATE_PRG(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR)
 If maxtab(AERR)>0  : End : Endif

 # Creation du traitement std
 Call CREATE_TRTSTD(ACLA,ACLA.ACLATRT,AERR)
 If maxtab(AERR)>0  : End : Endif

Endif

Close Local File
End

#-------------------------------------------------------#
Subprog CREATE_TRT(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR)  : # Fichier WCLA0***
Value Integer VALP
Variable Integer TYPAGE
Value Char MACHINE
Value Char APPLI
Value Char DOSSIER
Variable Instance ACLA Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR

Local Clbfile    CLOB(9)
Local Integer   DIF,OK
Local Char      LIGNE(250)

If ACLA.TEST : Call ECR_TRACE("- Create TRT"-ACLA.ACLAV.CTLPRG,0) From GESECRAN : Endif

#Call TRT_ACTION(ACLA,LIGNE,CLOB,DIF)
Call TRT_ADDTRT(ACLA,ACLA.ACLATRT,LIGNE,CLOB,DIF)
Call TRT_DECLARE_VAR(ACLA,LIGNE,CLOB,DIF)
Call TRT_METHODES(ACLA,LIGNE,CLOB,DIF)
Call TRT_MET_STD(ACLA,LIGNE,CLOB,DIF)
Call TRT_OPERATION(ACLA,LIGNE,CLOB,DIF)
If find(ACLA.TYPCLA,1,2,5) or ACLA.FLGACTX=2
 Gosub SUB_COM_STD
 Call TRT_INIT(ACLA,LIGNE,CLOB,DIF)
Endif
Call TRT_AERROR(ACLA,LIGNE,CLOB,DIF)
Call TRT_ADELERROR(ACLA,LIGNE,CLOB,DIF)
If find(ACLA.TYPCLA,1,2,3,5)>0
 Call TRT_ASEARCHINFOS(ACLA,LIGNE,CLOB,DIF)
Endif
Call TRT_AGETERRORSFROM(ACLA,LIGNE,CLOB,DIF)
Call TRT_RICHMEDIA(ACLA,[L]DOSSIER,LIGNE,CLOB,DIF)
If find(ACLA.TYPCLA,1,2,3,5)>0
 Call TRT_CONTROL(ACLA,LIGNE,CLOB,DIF)
 If ACLA.NBRGRP>0
  Call METTABGEN("ADELLINE",ACLA,LIGNE,CLOB,DIF)
  Call METTABGEN("ADDLINE",ACLA,LIGNE,CLOB,DIF)
  Call METTABGEN("AGETDIM",ACLA,LIGNE,CLOB,DIF)
  Call METTABGEN("AGETMIN",ACLA,LIGNE,CLOB,DIF)
 Endif
Endif
If find(ACLA.TYPCLA,2,5)>0
 Call TRT_LOAD_KEYS(ACLA,LIGNE,CLOB,DIF)
Endif
Call TRT__ADELINSTANCE(ACLA,LIGNE,CLOB,DIF)
Call TRT_ADDINSTANCE_BOUND([L]DOSSIER,ACLA,LIGNE,CLOB,DIF)
Call STC_DEB([L]APPLI,[L]MACHINE,ACLA.ACLAV.CTLPRG,ACLA.ACLAV.IDENTSTC,ACLA.CODCLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"TRT") From ACLASUB
Call TRT_FIN([L]CLOB,ACLA.ACLAV.CTLPRG,ACLA.FLGACTX,[L]DOSSIER,"TRT",[L]OK,AERR) From ACLASUB
If maxtab(AERR)>0  : End : Endif
End

#-------------------------------------------------------#
Subprog CREATE_TRTINI(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR)  : # Fichier WCLA0***
Value Integer VALP
Variable Integer TYPAGE
Value Char MACHINE
Value Char APPLI
Value Char DOSSIER
Variable Instance ACLA Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR

Local Clbfile    CLOB(9)
Local Integer   DIF,OK
Local Char      LIGNE(250) : # Fichier WCLAN**

If ACLA.TEST : Call ECR_TRACE("- Create TRT"-ACLA.ACLAV.INICTLPRG,0) From GESECRAN : Endif

Call TRT_AINIT(ACLA,LIGNE,CLOB,DIF)
If find(ACLA.TYPCLA,-1,1,2,5)>0 & ACLA.FLGBUFFER<>2
 Call TRT_ATTRIBUTE_ALL(ACLA,LIGNE,CLOB,DIF)
 Call TRT_A_LNKPRO(ACLA,LIGNE,CLOB,DIF)
Endif
Gosub TRT_TESTALLSTAT
Call STC_DEB([L]APPLI,[L]MACHINE,ACLA.ACLAV.INICTLPRG,ACLA.ACLAV.IDENTSTC,ACLA.CODCLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"TRT") From ACLASUB
Call TRT_FIN([L]CLOB,ACLA.ACLAV.INICTLPRG,ACLA.FLGACTX,[L]DOSSIER,"TRT",OK,AERR) From ACLASUB
If maxtab(AERR)>0  : End : Endif
End

#-------------------------------------------------------#
#-------------------------------------------------------#
Subprog CREATE_TRTCTL(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR)  : # Fichier WCLA0***
Value Integer VALP
Variable Integer TYPAGE
Value Char MACHINE
Value Char APPLI
Value Char DOSSIER
Variable Instance ACLA Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR

Local Clbfile    CLOB(9)
Local Integer   DIF,OK
Local Char      LIGNE(250) : # Fichier WCLAN**: # Fichier WCLAC**

If find(ACLA.TYPCLA,-1,1,2,5)>0 & ACLA.FLGBUFFER<>2
 If ACLA.TEST : Call ECR_TRACE("- Create TRT"-ACLA.ACLAV.ALLCTLPRG,0) From GESECRAN : Endif
 Call TRT_A_CONTROL(ACLA,LIGNE,CLOB,DIF)
 Call TRT_MANDATORY_CONTROL(ACLA,LIGNE,CLOB,DIF)
 Call TRT_FORMAT_CONTROL(ACLA,LIGNE,CLOB,DIF)
 Call TRT_OTHERS_CONTROL(ACLA,LIGNE,CLOB,DIF)
 Gosub TRT_TESTALLSTAT
 Call STC_DEB([L]APPLI,[L]MACHINE,ACLA.ACLAV.ALLCTLPRG,ACLA.ACLAV.IDENTSTC,ACLA.CODCLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"TRT") From ACLASUB
 Call TRT_FIN([L]CLOB,ACLA.ACLAV.ALLCTLPRG,ACLA.FLGACTX,[L]DOSSIER,"TRT",OK,AERR) From ACLASUB
 If maxtab(AERR)>0  : End : Endif
Endif
End

#-------------------------------------------------------#
Subprog CREATE_PRG(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR)  : # Fichier WCLA0***
Value Integer VALP
Variable Integer TYPAGE
Value Char MACHINE
Value Char APPLI
Value Char DOSSIER
Variable Instance ACLA Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR

Local Clbfile    CLOB(9)
Local Integer   DIF,OK
Local Char      LIGNE(250)

If (find(ACLA.TYPCLA,3,4)>0 & ACLA.FLGACTX<>2) : End : Endif
Raz ACLA.ACLAV.NBPRG

Call SUB_DEF_TRT(ACLA)
LIGNE = "" : Gosub ADDCLB
Gosub SUB_COM_TRT
LIGNE = "" : Gosub ADDCLB
If ACLA.TEST : Call ECR_TRACE("- Create TRT"-ACLA.ACLAV.NOMPRG,0) From GESECRAN  : Endif
For F=1 To maxtab(ACLA.ACLAF)
 If ACLA.ACLAF(F).FLDCLA<>"" & ACLA.ACLAF(F).LNKCLA=""
  Call SUB_COM_FIELD(F,ACLA.ACLAF(F),CLOB,DIF)
  LIGNE = "" : Gosub ADDCLB
  If ACLA.ACLAF(F).ATY<>null & ACLA.ACLAF(F).ATY.CODTYP<>"" & !find(ACLA.ACLAF(F).ATY.CODTYP,"")
   If ACLA.FLGACTX=2
    If ACLA.ACLAF(F).FLGACCGET=2: Call PRG_FIELD_GET(4,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF) : Endif
   Else
    If ACLA.ACLAF(F).FLGACCGET=2 : Call PRG_FIELD_GET(4,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF) : Endif
    If ACLA.ACLAF(F).FLGACCSET=2 : Call PRG_FIELD_SET(0,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF) : Endif
    If ACLA.ACLAF(F).FLGACCINI= 2 : Call PRG_FIELD_INIT(1,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF) : Endif
    If ACLA.ACLAF(F).FLGACCCTL=2
     Call PRG_FIELD_CONTROL(0,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF)
     Call PRG_FIELD_MANDATORY(0,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF)
     Call PRG_FIELD_FORMAT(0,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF)
     Call PRG_FIELD_OTHERS(2,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF)
     Call PRG_FIELD_OTHERS_REF(2,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF)
     Call PRG_FIELD_PROPAGATE(3,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF)
     Call PRG_FIELD_LNKPRO(10,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF)
    Endif
    If find(ACLA.TYPCLA,1,2,5)>0 and ACLA.FLGBUFFER<>2 : Call PRG_FIELD_ATTRIBUTE(0,ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF) : Endif
   Endif
   LIGNE = ""  : Gosub ADDCLB
  Endif
 Endif
 If mod(F,func ACLAVALLEC.MAXPRO)=0 :# find(F,30,60,90,120,150,180,210,240,270,300)>0
  Call STC_DEB([L]APPLI,[L]MACHINE,ACLA.ACLAV.NOMPRG,ACLA.ACLAV.IDENTSTC,ACLA.CODCLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"TRT") From ACLASUB
  Call TRT_FIN([L]CLOB,ACLA.ACLAV.NOMPRG,ACLA.FLGACTX,[L]DOSSIER,"TRT",[L]OK,AERR) From ACLASUB
  If maxtab(AERR)>0  :  : Break : Endif
  Call SUB_DEF_TRT(ACLA)
  Raz CLOB
  Gosub SUB_COM_TRT
  LIGNE = "" : Gosub ADDCLB
  If ACLA.TEST : Call ECR_TRACE("- Create TRT"-ACLA.ACLAV.NOMPRG,0) From GESECRAN  : Endif
 Endif
Next
If maxtab(AERR)>0  : End : Endif
Call STC_DEB([L]APPLI,[L]MACHINE,ACLA.ACLAV.NOMPRG,ACLA.ACLAV.IDENTSTC,ACLA.CODCLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"TRT") From ACLASUB
Call TRT_FIN([L]CLOB,ACLA.ACLAV.NOMPRG,ACLA.FLGACTX,[L]DOSSIER,"TRT",[L]OK,AERR) From ACLASUB
If maxtab(AERR)>0  : End : Endif
LIGNE = ""   : Gosub ADDCLB
End



#-------------------------------------------------------#
Subprog CREATE_TRTSTD(ACLA,ACLATRT,AERR)
Variable Instance ACLA Using OBJECT
Variable Instance ACLATRT(1..) Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
For I=1 To maxtab(ACLATRT)
If ACLATRT(I)<>null
  If ACLA.TEST : Call ECR_TRACE(mess(1,13,1)-":"-ACLATRT(I).CODTRT,0) From GESECRAN : Endif
 Call VALID_TRTSTD(ACLA.ACLAV.NOMSTC,ACLA.ACLAV.DOSSIER,ACLA.CODECLA,ACLA.FLGACTX,ACLA.INTITCLA,ACLA.MODULE,ACLA.CODACT,ACLA.ACLAV.TITETA,ACLATRT(I).CODTRT,ACLATRT(I).TYPTRT,AERR) From ACLASUB
Endif
Next
End

$INTERLINE
LIGNE = "####################################################################" : Gosub ADDCLB
Return


#-------------------------------------------------------#

Subprog TRT_ADDINSTANCE_BOUND(DOSSIER,ACLA,LIGNE,CLOB,DIF)
Value Char DOSSIER
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Char TBCLA(GLONACLA)(1..)
Local Char TBPRO(GLONAVA)(1..)
Local Char TBCOL(GLONAVA)(1..)
Local Char TBPTR(250)(1..)
Local Integer OK : OK = 1

If ACLA.TYPCLA=-1
 Call CREATE_1_1([L]DOSSIER,"",ACLA.CODECLA,TBCLA,TBPRO,TBPTR,TBCOL,OK) From ACLAVALLEC
Else
 Call CREATE_1_1([L]DOSSIER,ACLA.CODECLA,"",TBCLA,TBPRO,TBPTR,TBCOL,OK) From ACLAVALLEC
Endif
Gosub INTERLINE
LIGNE = "# ADDINSTANCE_BOUND" : Gosub ADDCLB
Gosub INTERLINE
LIGNE = "$ADDINSTANCE_BOUND" : Gosub ADDCLB
If OK>0
 For I=1 To  maxtab([L]TBCLA)
  If [L]TBCLA(I)<>"OBJECT"
   If TBCOL(I) <>""
    #LIGNE = "[L]ASTATUS = fmet this."+string$(TBPTR(I)<>"",TBPTR(I)+".")+'ADDLINE("'+TBCOL(I)+'",1)' : Gosub ADDCLB
    LIGNE = "this."+string$(TBPTR(I)<>"",TBPTR(I)+".")+[L]TBPRO(I)+"(1) = NewInstance C_"+[L]TBCLA(I)+'(this.ACTX,NullUuid,1,this'
    LIGNE += string$(TBPTR(I)<>"","."+TBPTR(I))
    LIGNE += ',"'+[L]TBPRO(I)+'")'-[V]CST_ALLOCGROUP-"this"  : Gosub ADDCLB
    LIGNE = "this."+string$(TBPTR(I)<>"",TBPTR(I)+".")+[L]TBPRO(I)+"(1).ASTALIN = [V]CST_ANEW" : Gosub ADDCLB
    LIGNE =  '[L]ASTATUS = fmet this.'+string$(TBPTR(I)<>"",TBPTR(I)+".")+[L]TBPRO(I)+'(1).ACTION("ADDLINE_AFTER")'  : Gosub ADDCLB
  Else
    #LIGNE = '[L]ASTATUS = func ASYRSUBTAB.ADDINSTANCE("'+[L]TBPRO(I)+'","C_'+[L]TBCLA(I)+'",this)' : Gosub ADDCLB
    LIGNE = "this."+[L]TBPRO(I)-"= NewInstance C_"+[L]TBCLA(I)+'(this.ACTX,NullUuid,0,this,"'+[L]TBPRO(I)+'")'-[V]CST_ALLOCGROUP-"this"  : Gosub ADDCLB
    LIGNE = "this."+[L]TBPRO(I)+".ASTALIN = [V]CST_ANEW" : Gosub ADDCLB
    LIGNE =  '[L]ASTATUS = fmet this.'+[L]TBPRO(I)+'.ACTION("ADDLINE_AFTER")'  : Gosub ADDCLB
   Endif
   LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : [L]ASTATUS = [V]CST_ANOTDEFINED : Return : Endif'  : Gosub ADDCLB
  Endif
 Next
Endif
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#-------------------------------------------------------#
Subprog PRG_FIELD_GET(WTYPRUL,ACLAF,ACLA,LIGNE,CLOB,DIF)
Value Integer WTYPRUL : # type regle (init,control...)
Variable  Instance  ACLAF Using C_ACLAFLD
Variable  Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Local Integer ISLOBRUL
LIGNE = "$GET_"+ ACLAF.FLDCLA: Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARPRO-'= "'+ACLAF.FLDCLA+'"' : Gosub ADDCLB
Call PRG_ADD_ASU(ACLA,WTYPRUL,0,ACLA.ACLAV.VARPRO,ACLAF,LIGNE,CLOB,DIF)
If ACLAF.ATY<>null
 If find(ACLAF.ATY.CODTYP,"AXX","AX1","AX2","AX3")>0
  LIGNE = "this."+ACLAF.FLDCLA+" = fmet this.AGETTEXTRA("+ACLA.ACLAV.VARPRO+")" : Gosub ADDCLB
 Elsif find(ACLAF.ATY.CODTYP,"ATT")>0
  LIGNE = "this."+ACLAF.FLDCLA+" = fmet this.AGETTEXT("+ACLA.ACLAV.VARPRO+")" : Gosub ADDCLB
 Elsif find(ACLAF.ATY.TYPTYP,9,10)>0
  ISLOBRUL = 0
  If ACLAF.ATY.SUPFLG=2
   [L]ISLOBRUL = 1
  Else
   For R=1 To maxtab(ACLAF.ATY.ARUL)
    If ACLAF.ATY.ARUL(R)<>null & ACLAF.ATY.ARUL(R).TYPRUL=6
     [L]ISLOBRUL = 1
     Break
    Endif
   Next
  Endif
  If [L]ISLOBRUL = 1
   LIGNE = "Local Char _CNT(100)"  : Gosub ADDCLB
   LIGNE = "Local Tinyint _EXI : [L]_EXI=1"  : Gosub ADDCLB
   LIGNE = '[L]ASTATUS = fmet this.AREAD_'
   If find(ACLAF.ATY.TYPTYP,10)>0
    LIGNE += "CLB"
   Else
    LIGNE += "BLB"
   Endif
   LIGNE += '("'+ACLAF.FLDCLA+'",' : Gosub ADDCLB
   Raz LIGNE
   Gosub ADD_PRO_GET_LOB
   LIGNE = '& ,[L]_CNT,this.'+ACLAF.FLDCLA+')'  : Gosub ADDCLB
   #LIGNE = "[L]ASTATUS = fmet this.AGETMAXERROR("+ACLA.ACLAV.VARPRO+")" : Gosub ADDCLB
   LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Return : Endif" : Gosub ADDCLB
   LIGNE = 'If fmet this.AGETATTRIBUTE([L]'+ACLA.ACLAV.VARPRO+',"$isLoaded")<>"true"' : Gosub ADDCLB
   DIF += 1
   LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE([L]'+ACLA.ACLAV.VARPRO+',"$isLoaded","true")' : Gosub ADDCLB
   DIF -=1
   LIGNE = "Endif"  : Gosub ADDCLB
  Endif
 Endif
Endif
If ACLAF.FLGACCGET=2
 LIGNE = '[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From '+ACLA.ACLAV.TRTACT : Gosub ADDCLB
Endif
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

$ADD_PRO_GET_LOB
Local Integer NK
If ACLAF.ATY.SUPFLG=2
 Local Char    KEYVAL(120)(1..15)
 Local Integer NBKEY, KEYTYP(1..15)
 Call GET_INDEX(ACLA.ACLAV.DOSSIER,ACLAF.LOBTAB,1,NBKEY,KEYVAL,KEYTYP) From ACLASUB
 For I=1 To NBKEY
  For J=1 To maxtab(ACLAF.ATBKEY)
   If KEYVAL(I)= ACLAF.ATBKEY(J).CODPAR
    NK += 1
    LIGNE = '& '
    If NK>1 : LIGNE += '+[V]CST_AURLSEPLOB+' : Endif
    Case ACLAF.ATBKEY(J).TYPINT
     When 1,2,3,4,5,6,11,12:    LIGNE += "num$("+func EVAL_VALEUR(ACLAF.ATBKEY(J).VALEUR,ACLA,"this")+")" : : Gosub ADDCLB
     When 8               :    LIGNE += "format$('D:YYYYMMDD',"+func EVAL_VALEUR(ACLAF.ATBKEY(J).VALEUR,ACLA,"this")+")" : Gosub ADDCLB
     When Default          : LIGNE += func EVAL_VALEUR(ACLAF.ATBKEY(J).VALEUR,ACLA,"this") : Gosub ADDCLB
    Endcase
    Break
   Endif
  Next
 Next
Else
 For R=1 To maxtab(ACLAF.ATY.ARUL)
  If ACLAF.ATY.ARUL(R)<>null & ACLAF.ATY.ARUL(R).TYPRUL=6
   For RP=1 To maxtab(ACLAF.ATY.ARUL(R).APARRUL)
    Case ACLAF.ATY.ARUL(R).APARRUL(RP).PARCOD
     When "AINSTANCE"   :
     When "APRONAME"    :
     When "AEXIST"     :
     When "AVALCNT"    :
     When "AVALUE"      :
     When Default       :
      NK += 1
      LIGNE = '& '
      If NK>1 : LIGNE = '+[V]CST_AURLSEPLOB+' : Endif
      Case ACLAF.ATY.ARUL(R).APARRUL(RP).PARTYP
       When 1,2,3,4,5,6,11,12 :    LIGNE += "num$("+func EVAL_VALEUR(ACLAF.ATY.ARUL(R).APARRUL(RP).PARVAL,ACLA,"this")+")" : Gosub ADDCLB
       When 8                :    LIGNE += "format$('D:YYYYMMDD',"+func EVAL_VALEUR(ACLAF.ATY.ARUL(R).APARRUL(RP).PARVAL,ACLA,"this")+")"  : Gosub ADDCLB
       When Default              : LIGNE += func EVAL_VALEUR(ACLAF.ATY.ARUL(R).APARRUL(RP).PARVAL,ACLA,"this") : : Gosub ADDCLB
      Endcase
      Break
    Endcase
   Next
   Break
  Endif
 Next
Endif
Return


#-------------------------------------------------------#
Subprog PRG_FIELD_SET(WTYPRUL,ACLAF,ACLA,LIGNE,CLOB,DIF)
Value Integer WTYPRUL : # type regle (init,control...)
Variable  Instance  ACLAF Using C_ACLAFLD
Variable  Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "$SET_"+ ACLAF.FLDCLA : Gosub ADDCLB

If find(ACLAF.ATY.TYPTYP,9,10)>0
 LIGNE = 'If fmet this.AGETATTRIBUTE("'+ACLAF.FLDCLA+'","$isLoaded")<>"true"'-"or [L]"+ACLA.ACLAV.VAROLD+"<>this."+ACLAF.FLDCLA
Else
 LIGNE = "If [L]"+ACLA.ACLAV.VAROLD+"<>this."+ACLAF.FLDCLA
Endif
Gosub ADDCLB
DIF +=1
LIGNE = 'Call _ASTATUSPARENT(this) From ASYRSUB' : Gosub ADDCLB
DIF -=1
LIGNE = "Endif"  : Gosub ADDCLB
LIGNE = "Gosub CONTROL_"+ACLAF.FLDCLA  : Gosub ADDCLB
LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Return : Endif" : Gosub ADDCLB
If find(ACLAF.ATY.TYPTYP,9,10)>0
  LIGNE = 'If fmet this.AGETATTRIBUTE("'+ACLAF.FLDCLA+'","$isLoaded")<>"true"'-"or [L]"+ACLA.ACLAV.VAROLD+"<>this."+ACLAF.FLDCLA
Else
  LIGNE = "If [L]"+ACLA.ACLAV.VAROLD+"<>this."+ACLAF.FLDCLA
Endif
Gosub ADDCLB
DIF += 1
#DIF +=1
LIGNE = "Gosub PROPAGATE_"+ACLAF.FLDCLA  : Gosub ADDCLB
#DIF -=1
#LIGNE = "Endif"  : Gosub ADDCLB
DIF -=1
LIGNE = "Endif"  : Gosub ADDCLB
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#-------------------------------------------------------#
Subprog PRG_FIELD_INIT(WTYPRUL,ACLAF,ACLA,LIGNE,CLOB,DIF)
Value    Integer WTYPRUL : # type regle (init,control...)
Variable Instance  ACLAF Using C_ACLAFLD
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "$INIT_"+ ACLAF.FLDCLA    : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR From "+ACLA.ACLAV.CTLPRG  : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARPRO-'= "'+ACLAF.FLDCLA+'"' : Gosub ADDCLB
Call PRG_ADD_ASU(ACLA,WTYPRUL,0,ACLA.ACLAV.VARPRO,ACLAF,LIGNE,CLOB,DIF)

If ACLAF.ATY.VALDEF<>"" & 0  : # Valeur par défaut
 LIGNE = "this."+ACLAF.FLDCLA+" = "
 If left$(ACLAF.ATY.VALDEF,1)="*"
  LIGNE += right$(ACLAF.ATY.VALDEF,2)
 Else
  LIGNE += ACLAF.ATY.VALDEF
 Endif
 Gosub ADDCLB
Endif
LIGNE = '[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From '+ACLA.ACLAV.TRTACT : Gosub ADDCLB
LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Return : Endif" : Gosub ADDCLB
# 105066 CCL validated by the team
If ACLAF.ATY.TYPTYP=1 : # Initialisation menu local
 LIGNE = "If this."+ACLAF.FLDCLA+'=0 and fmet this.AGETATTRIBUTE("'+ACLAF.FLDCLA+'","$isMandatory")="true"' : Gosub ADDCLB
 DIF += 1
 LIGNE = "this."+ACLAF.FLDCLA+" = 1" : Gosub ADDCLB
 DIF -=1
 LIGNE ="Endif" : Gosub ADDCLB
Endif
LIGNE = "Return" : Gosub ADDCLB
LIGNE = " "  : Gosub ADDCLB
End

#-------------------------------------------------------#
Subprog PRG_FIELD_CONTROL(WTYPRUL,ACLAF,ACLA,LIGNE,CLOB,DIF)
Value    Integer WTYPRUL : # type regle (init,control...)
Variable Instance  ACLAF Using OBJECT : # C_ACLAFLD
Variable Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

LIGNE = "$CONTROL_"+ ACLAF.FLDCLA : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR From "+ACLA.ACLAV.CTLPRG  : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARPRO-'= "'+ACLAF.FLDCLA+'"' : Gosub ADDCLB
LIGNE = "[L]ASTATUS = fmet this.ADELETEERROR([L]"+ACLA.ACLAV.VARPRO+")" : Gosub ADDCLB
LIGNE = "Gosub "+ACLA.ACLAV.TBMET(7)+"_"+ ACLAF.FLDCLA+space$(30-len(ACLA.ACLAV.TBMET(7)+"_"+ACLAF.FLDCLA))+
& " : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif" : Gosub ADDCLB
#& " : If "+"fmet this.AGETMAXERROR([L]"+ACLA.ACLAV.VARPRO+")>=[V]CST_AERROR : [L]"+ACLA.ACLAV.VARCTL+" = fmet this.AGETMAXERROR([L]"+ACLA.ACLAV.VARPRO+"): Return : Endif" : Gosub ADDCLB
#If ACLAF.ATY.FICLIEN<>""& ACLAF.ATY.CODCLA<>"" & ACLAF.ATY.CODCLA<>ACLA.CODECLA
# LIGNE = "Gosub "+ACLA.ACLAV.TBMET(13)+"_"+ ACLAF.FLDCLA+space$(30-len(ACLA.ACLAV.TBMET(7)+"_"+ACLAF.FLDCLA))+ " : If "+"fmet this.AGETMAXERROR([L]"+ACLA.ACLAV.VARPRO+")>=[V]CST_AERROR : [L]"+ACLA.
#& ACLAV.VARCTL+" = fmet this.AGETMAXERROR([L]"+ACLA.ACLAV.VARPRO+"): Return : Endif" : Gosub ADDCLB
#Endif
LIGNE = "Gosub "+ACLA.ACLAV.TBMET(8)+"_"+ ACLAF.FLDCLA+space$(30-len(ACLA.ACLAV.TBMET(8)+"_"+ACLAF.FLDCLA))+
& " : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif" : Gosub ADDCLB
#& " : If "+"fmet this.AGETMAXERROR([L]"+ACLA.ACLAV.VARPRO+")>=[V]CST_AERROR : [L]"+ACLA.ACLAV.VARCTL+" = fmet this.AGETMAXERROR([L]"+ ACLA.ACLAV.VARPRO+"): Return : Endif" : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#-------------------------------------------------------#
Subprog PRG_FIELD_MANDATORY(WTYPRUL,ACLAF,ACLA,LIGNE,CLOB,DIF)
Value    Integer WTYPRUL : # type regle (init,control...)
Variable Instance  ACLAF Using OBJECT : # C_ACLAFLD
Variable Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

LIGNE = "$"+ACLA.ACLAV.TBMET(6)+"_"+ ACLAF.FLDCLA : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARPRO-'= "'+ACLAF.FLDCLA+'"' : Gosub ADDCLB
LIGNE = 'If fmet this.AGETATTRIBUTE([L]'+ACLA.ACLAV.VARPRO+',"$isMandatory")="true"'
If ACLAF.ATY.CODTYP<>"ATX"
 Case ACLAF.ATY.TYPTYP
  When 1,2,3,4,5,6 : LIGNE += ' & this.'+ACLAF.FLDCLA+'=0'
  When 7           : LIGNE += ' & vireblc(this.'+ACLAF.FLDCLA+',2)=""'
  When 8           : LIGNE += ' & this.'+ACLAF.FLDCLA+'=[0/0/0]'
  When 11          : LIGNE += ' & this.'+ACLAF.FLDCLA+'=NullUuid'
  When 12          : LIGNE += ' & this.'+ACLAF.FLDCLA+'=AVOID.ADATTIM'
  When Default     : LIGNE += ' & len(this.'+ACLAF.FLDCLA+')=0'
 Endcase
Else
 LIGNE += ' & (maxtab(this.ATX)=0 or  func ASYRSUB._HASFIELDATX(this.ATX,[L]CURPRO)=0)'
Endif
Gosub ADDCLB
DIF += 1
LIGNE = "[L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]"+ACLA.ACLAV.VARPRO+',0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1))'
LIGNE += " :  Return : # "+mess(10,123,1) : Gosub ADDCLB
DIF -= 1 : LIGNE = 'Endif' : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

Subprog PRG_FIELD_FORMAT(WTYPRUL,ACLAF,ACLA,LIGNE,CLOB,DIF)
Value    Integer WTYPRUL : # type regle (init,control...)
Variable Instance  ACLAF Using OBJECT : # C_ACLAFLD
Variable Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Local Char FMT(30),WFLD(120)
LIGNE = "$"+ACLA.ACLAV.TBMET(7)+"_"+ ACLAF.FLDCLA : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARPRO-'= "'+ACLAF.FLDCLA+'"' : Gosub ADDCLB
If ACLAF.ATY.TYPTYP=7 & (ACLAF.ATY.FORTYP<>"" or ACLAF.ATY.OPTION<>"" or ACLAF.ATY.LNGTYP>0) : # Contrôle format
 Call SETFMT("K",ACLAF.ATY.FORTYP,ACLAF.LON,ACLAF.ATY.OPTION,FMT)
 If [L]FMT<>""
  If find(ACLAF.CODTYP,"AX1","AX2","AX3","AXX")>0
   WFLD = 'fmet this.AGETTEXTRA("'+ACLAF.FLDCLA+'")'
  Else
   WFLD = 'this.'+ACLAF.FLDCLA
  Endif
  LIGNE = 'If vireblc('+WFLD+',2)<>vireblc(format$("'+FMT+'",'+WFLD+'),2)' : Gosub ADDCLB
  DIF += 1
  LIGNE = "[L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]"+ACLA.ACLAV.VARPRO+',0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1))'
  LIGNE += " :  Return : # "+mess(149,100,1) : Gosub ADDCLB
  DIF -= 1
  LIGNE = 'Endif' : Gosub ADDCLB
 Endif
Endif
If ACLAF.ATY.TYPTYP=1  : # Menus locaux
 LIGNE = 'If this.'+ACLAF.FLDCLA+'<0 or this.'+ACLAF.FLDCLA+'>len(mess(0,'+num$(ACLAF.MENU)+',1))' : Gosub ADDCLB
 DIF += 1
 LIGNE = '# Pop / Invalid option' : Gosub ADDCLB
 LIGNE = "[L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]"+ACLA.ACLAV.VARPRO+',0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,'+'mess(4,11,1)-"'+num$(ACLAF.MENU)+' ->"-num$(this.'+ACLAF.FLDCLA+
& ')-mess(99,123,1)'+')'
 LIGNE += ':  Return : # '+mess(4,11,1)-'"'+num$(ACLAF.MENU)+' ->'-mess(99,123,1) : Gosub ADDCLB
 DIF -= 1
 LIGNE = 'Endif' : Gosub ADDCLB
Endif
If ACLAF.CODCTL<>"" : #  Table de contrôle a reprendre
 LIGNE = "# Control table"-ACLAF.CODCTL : Gosub ADDCLB
 LIGNE = "If func ASYRSUBACL. "
 Case ACLAF.ATY.TYPTYP
  When 1         : LIGNE += "CONTACL_LIB("
  When 2,3,4,5,6 : LIGNE += "CONTACL_NUM("
  When 8         : LIGNE += "CONTACL_DAT("
  When Default   : LIGNE += "CONTACL_CHAR("
 Endcase
 LIGNE += "this,"
 LIGNE += '"'+ACLAF.CODCTL+'",'
 If ACLAF.TABCONT<>""
  LIGNE +=  func EVAL_VALEUR(ACLAF.TABCONT,ACLA,"this")
 Else
  LIGNE += '""'
 Endif
 LIGNE += ',this.'+ACLAF.FLDCLA+')>=[V]CST_AERROR : Return : Endif' : Gosub ADDCLB
Endif
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

Subprog PRG_FIELD_OTHERS(WTYPRUL,ACLAF,ACLA,LIGNE,CLOB,DIF)
Value    Integer WTYPRUL : # type regle (init,control...)
Variable Instance  ACLAF Using C_ACLAFLD
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

LIGNE = "$"+ACLA.ACLAV.TBMET(8)+"_"+ ACLAF.FLDCLA : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARPRO-'= "'+ACLAF.FLDCLA+'"' : Gosub ADDCLB
Call PRG_ADD_ASU(ACLA,WTYPRUL,1,ACLA.ACLAV.VARPRO,ACLAF,LIGNE,CLOB,DIF)
LIGNE = '[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From '+ACLA.ACLAV.TRTACT : Gosub ADDCLB
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

Subprog PRG_FIELD_OTHERS_REF(WTYPRUL,ACLAF,ACLA,LIGNE,CLOB,DIF)
Value    Integer WTYPRUL : # type regle (init,control...)
Variable Instance  ACLAF Using C_ACLAFLD
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "$"+ACLA.ACLAV.TBMET(8)+"_REF_"+ ACLAF.FLDCLA : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARPRO-'= "'+ACLAF.FLDCLA+'"' : Gosub ADDCLB
Call PRG_ADD_ASU(ACLA,WTYPRUL,2,ACLA.ACLAV.VARPRO,ACLAF,LIGNE,CLOB,DIF)
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#-------------------------------------------------------#
Subprog PRG_FIELD_PROPAGATE(WTYPRUL,ACLAF,ACLA,LIGNE,CLOB,DIF)
Value    Integer WTYPRUL : # type regle (init,control...)
Variable Instance  ACLAF Using C_ACLAFLD
Variable Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Integer I,J,K
Local Char    VALEUR(250)

LIGNE = "$PROPAGATE_"+ ACLAF.FLDCLA : Gosub ADDCLB

LIGNE = "this.isReadonly = 0" : Gosub ADDCLB
#LIGNE = "If this.ASTALIN=[V]CST_ALL" : Gosub ADDCLB
#DIF += 1
#LIGNE = "this.ASTALIN = [V]CST_AUPD" : Gosub ADDCLB
#If instr(1,ACLA.CODECLA,"_")>0
# LIGNE = "If this.APARENT<>null and this.APARENT.ASTALIN=[V]CST_ALL" : Gosub ADDCLB
# DIF += 1
# LIGNE = "this.APARENT.ASTALIN = [V]CST_AUPD" : Gosub ADDCLB
# DIF -= 1
# LIGNE = "Endif" : Gosub ADDCLB
#Endif
#DIF -= 1
#LIGNE = "Endif" : Gosub ADDCLB

# CCL 116061
#LIGNE = 'Call _ASTATUSPARENT(this) From ASYRSUB' : Gosub ADDCLB

Call PRG_ADD_ASU(ACLA,WTYPRUL,0,ACLA.ACLAV.VARPRO,ACLAF,LIGNE,CLOB,DIF)
LIGNE = "[L]"+ACLA.ACLAV.VARPRO-'= "'+ACLAF.FLDCLA+'"' : Gosub ADDCLB
If find(ACLAF.ATY.TYPTYP,9,10)>0
 LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE([L]'+ACLA.ACLAV.VARPRO+',"$isLoaded","true")' : Gosub ADDCLB
Endif
If ACLAF.ATY<>null
 If find(ACLAF.ATY.CODTYP,"AXX","AX1","AX2","AX3")
  LIGNE = "[L]"+ACLA.ACLAV.VARCTL-"= fmet this.ASETTEXTRA("+ACLA.ACLAV.VARPRO+",this."+ACLAF.FLDCLA+")" : Gosub ADDCLB
 Elsif find(ACLAF.ATY.CODTYP,"ATX") : #  Revoir
  #LIGNE = VARCTL-"= fmet ASETTEXT("+VARPRO+VAREVL+","+ACLAF.FLDCLA+"("+VARIND+"),"+AZ C+")" : Gosub ADDCLB
 Endif
Endif

#91088/5
If ACLAF.ACHPLNG<>null or ACLAF.ACHPSHO<>null or ACLAF.ACHPSYM<>null
& or ACLAF.ACHPCOLFMT<>null or ACLAF.ACHPCOLLNG<>null or ACLAF.ACHPCOLDEC<>null
 LIGNE = "Gosub _"+ACLA.ACLAV.TBMET(10)+"_"+ACLAF.FLDCLA : Gosub ADDCLB
Endif
LIGNE = '[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From '+ACLA.ACLAV.TRTACT : Gosub ADDCLB
LIGNE = "this.isReadonly = 1" : Gosub ADDCLB
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#-------------------------------------------------------#
Subprog PRG_FIELD_LNKPRO(WTYPRUL,ACLAF,ACLA,LIGNE,CLOB,DIF)
Value    Integer WTYPRUL : # type regle (init,control...)
Variable Instance  ACLAF Using C_ACLAFLD
Variable Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Integer I,J,K
Local Char    VALEUR(250)

LIGNE ="$"+ACLA.ACLAV.TBMET(WTYPRUL)+"_"+ACLAF.FLDCLA : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR From "+ACLA.ACLAV.CTLPRG  : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARPRO-'= "'+ACLAF.FLDCLA+'"' : Gosub ADDCLB
### LNKPRO
LIGNE ="$_"+ACLA.ACLAV.TBMET(WTYPRUL)+"_"+ACLAF.FLDCLA : Gosub ADDCLB
#91088/5
If (ACLAF.ACHPLNG<>null or ACLAF.ACHPSHO<>null or ACLAF.ACHPSYM<>null)
& or (ACLAF.ACHPCOLFMT<>null or ACLAF.ACHPCOLLNG<>null or ACLAF.ACHPCOLDEC<>null)
 LIGNE = "If"
 Case ACLAF.ATY.TYPTYP
  When 1,2,3,4,5,6 : LIGNE += ' this.'+ACLAF.FLDCLA+'<>0'
  When 7           : LIGNE += ' vireblc(this.'+ACLAF.FLDCLA+',2)<>""'
  When 8           : LIGNE += ' this.'+ACLAF.FLDCLA+'<>[0/0/0]'
  When 11          : LIGNE += ' this.'+ACLAF.FLDCLA+'<>NullUuid'
  When Default     : LIGNE += ' len(this.'+ACLAF.FLDCLA+')<>0'
 Endcase
 Gosub ADDCLB
 DIF += 1
 LIGNE = "# Link"-ACLAF.ATY.FICLIEN : Gosub ADDCLB
 LIGNE = 'Local File '+ACLAF.ATY.FICLIEN+' [W'+ACLAF.ATY.ABRLIEN+"]": Gosub ADDCLB
 LIGNE = "Read [F:W"+ACLAF.ATY.ABRLIEN+"]"+ACLAF.ATY.INDLIEN+" = "
 K = 0
 For J=1 To maxtab(ACLAF.ATY.CHPLIEN)
  For  I=1 To maxtab(ACLAF.ATBKEY)
   If ACLAF.ATBKEY(I).CODPAR=ACLAF.ATY.CHPLIEN(J)
    If K>0 : LIGNE += ";" : Endif
    K+=1
    #[L]VALEUR = ACLAF.ATBKEY(I).VALEUR
    [L]VALEUR = func EVAL_VALEUR(ACLAF.ATBKEY(I).VALEUR,ACLA,"this")
    LIGNE += VALEUR
   Endif
  Next
 Next
 Gosub ADDCLB
 LIGNE = "If !fstat" : Gosub ADDCLB
 DIF += 1
 If ACLAF.ACHPSHO<>null
  Call ADD_CHPLNK(ACLA.ACLAV.DOSSIER,"",ACLAF.ATY.FICLIEN,"W"+ACLAF.ATY.ABRLIEN,"T",ACLAF.FLDCLA,ACLAF.DIME,ACLAF.ACHPSHO,LIGNE,DIF,CLOB)
 Endif
 If ACLAF.ACHPLNG<>null
  Call ADD_CHPLNK(ACLA.ACLAV.DOSSIER,"",ACLAF.ATY.FICLIEN,"W"+ACLAF.ATY.ABRLIEN,"D",ACLAF.FLDCLA,ACLAF.DIME,ACLAF.ACHPLNG,LIGNE,DIF,CLOB)
 Endif
 If ACLAF.ACHPSYM<>null
  Call ADD_CHPLNK(ACLA.ACLAV.DOSSIER,"",ACLAF.ATY.FICLIEN,"W"+ACLAF.ATY.ABRLIEN,"u",ACLAF.FLDCLA,ACLAF.DIME,ACLAF.ACHPSYM,LIGNE,DIF,CLOB)
 Endif
 #91088/5
 If ACLAF.ACHPCOLFMT<>null

   LIGNE = 'If int(val(['+"F:W"+ACLAF.ATY.ABRLIEN+"]"+ACLAF.ACHPCOLFMT.CHPCHAR+'))>0'  : Gosub ADDCLB
   #102833 correct precision/scale
   LIGNE = " Local Char WPREC(10)"  : Gosub ADDCLB
   LIGNE = " Local Char WSCALE(10)"  : Gosub ADDCLB

   LIGNE = " WPREC="+'num$(int(val(['+"F:W"+ACLAF.ATY.ABRLIEN+"]"+ACLAF.ACHPCOLFMT.CHPCHAR+')))'  : Gosub ADDCLB
   LIGNE = " WSCALE="+'num$(int(10*(val(['+"F:W"+ACLAF.ATY.ABRLIEN+"]"+ACLAF.ACHPCOLFMT.CHPCHAR+')-int(val(['+"F:W"+ACLAF.ATY.ABRLIEN+"]"+ACLAF.ACHPCOLFMT.CHPCHAR+')))))'  : Gosub ADDCLB

   LIGNE = ' [L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA
   If ACLAF.DIME>1
    LIGNE += '("+num$('+ACLAF.DIME+')+")'
   Endif
   LIGNE +=  '","$precision",WPREC)' : Gosub ADDCLB

   LIGNE = ' [L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA
   If ACLAF.DIME>1
    LIGNE += '("+num$('+ACLAF.DIME+')+")'
   Endif
   LIGNE +=  '","$scale",WSCALE)' : Gosub ADDCLB

   LIGNE = 'Endif'  : Gosub ADDCLB
 Else
  If ACLAF.ACHPCOLLNG<>null
   LIGNE = 'If int(['+"F:W"+ACLAF.ATY.ABRLIEN+"]"+ACLAF.ACHPCOLLNG.CHPCHAR+')>0'  : Gosub ADDCLB
   #102833 correct precision/scale
   LIGNE = " Local Char WPREC(10)"  : Gosub ADDCLB

   LIGNE = " WPREC="+'num$(int(['+"F:W"+ACLAF.ATY.ABRLIEN+"]"+ACLAF.ACHPCOLLNG.CHPCHAR+'))'  : Gosub ADDCLB
   LIGNE = ' [L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA
   If ACLAF.DIME>1
    LIGNE += '("+num$('+ACLAF.DIME+')+")'
   Endif
   LIGNE +=  '","$precision",WPREC)' : Gosub ADDCLB

   LIGNE = 'Endif'  : Gosub ADDCLB
  Endif
  If ACLAF.ACHPCOLDEC<>null
   LIGNE = 'If int(['+"W"+ACLAF.ATY.ABRLIEN+"]"+ACLAF.ACHPCOLDEC.CHPCHAR+')>0'  : Gosub ADDCLB
   #102833 correct precision/scale
   LIGNE = " Local Char WSCALE(10)"  : Gosub ADDCLB

   LIGNE = " WSCALE=num$(["+"F:W"+ACLAF.ATY.ABRLIEN+"]"+ACLAF.ACHPCOLDEC.CHPCHAR+')'  : Gosub ADDCLB
   LIGNE = ' [L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA
   If ACLAF.DIME>1
    LIGNE += '("+num$('+ACLAF.DIME+')+")'
   Endif
   LIGNE +=  '","$scale",WSCALE)' : Gosub ADDCLB

   LIGNE = 'Endif'  : Gosub ADDCLB
  Endif
 Endif

 #
 DIF -=1 : LIGNE ="Endif" : Gosub ADDCLB
 LIGNE = "LogicClose File [W"+ACLAF.ATY.ABRLIEN+"]" : Gosub ADDCLB
 DIF -=1 : LIGNE ="Endif" : Gosub ADDCLB
Elsif find(ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB)>0
 If ACLAF.ATY.SUPFLG<>2
  LIGNE = "Local Tinyint _EXI : [L]_EXI=1"  : Gosub ADDCLB
  Gosub PRG_ADD_ASU_CLB_R_EXI
  LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA+'","$isLobFound",func ASYRSUB.BOOLEAN_TO_SYR([L]_EXI+1))' : Gosub ADDCLB
 Endif
 If ACLAF.ATY.SUPFLG=2 & ACLAF.ATY.PROPREFLG=2 & ACLAF.LOBCNT<>""
  LIGNE = "Local Char _CNT(100)"  : Gosub ADDCLB
  LIGNE = "Local Tinyint _EXI : [L]_EXI=1"  : Gosub ADDCLB
  LIGNE = "Gosub READ_CNT_"+ACLAF.FLDCLA+" From "+ACLA.ACLAV.CTLPRG  : Gosub ADDCLB
  LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA+'","$contentType",[L]_CNT)' : Gosub ADDCLB
  LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA+'","$isLobFound",func ASYRSUB.BOOLEAN_TO_SYR([L]_EXI+1))' : Gosub ADDCLB
 Elsif ACLAF.ATY.SUPFLG=2
  LIGNE = "Local Tinyint _EXI : [L]_EXI=1"  : Gosub ADDCLB
  LIGNE = "Gosub READ_EXI_"+ACLAF.FLDCLA+" From "+ACLA.ACLAV.CTLPRG  : Gosub ADDCLB
  LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA+'","$isLobFound",func ASYRSUB.BOOLEAN_TO_SYR([L]_EXI+1))' : Gosub ADDCLB
 Elsif ACLAF.ATY.SUPFLG<>2 & ACLAF.ATY.PROPREFLG=2
  LIGNE = "Local Char _CNT(100)"  : Gosub ADDCLB
  Gosub PRG_ADD_ASU_CLB_R_CNT
  LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA+'","$contentType",[L]_CNT)' : Gosub ADDCLB
 Endif
Endif
# rule FORMAT
If find(5,ACLAF.ATY.ARUL(1..maxtab(ACLAF.ATY.ARUL)).TYPRUL)>0
 LIGNE = "Local Char AFORMAT(50)"  : Gosub ADDCLB
 Call PRG_ADD_ASU(ACLA,5,1,"'+ACLAF.FLDCLA+'",ACLAF,LIGNE,CLOB,DIF)
 LIGNE = "If [L]AFORMAT<>''"  : Gosub ADDCLB
 LIGNE = "[L]AFORMAT='"+'"'+"'+[L]AFORMAT+'"+'"'+"'"  : Gosub ADDCLB
 LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA+'","$x3Format",[L]AFORMAT)' : Gosub ADDCLB
 LIGNE = "Endif"  : Gosub ADDCLB
Endif
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

Funprog EVAL_CLE(DOSSIER,TAB,ABR,CLE)
Value Char DOSSIER
Value Char TAB
Value Char ABR
Variable Char CLE

If filinfo(filpath("FIL","AVIEWFLD","fde",DOSSIER),0)<0
 Local File =DOSSIER+".ATABZON" [ATZ]
Else
 Local File =DOSSIER+".AVIEWFLD" [ATZ]
Endif
Local File =[L]DOSSIER+".ATYPE"  [ATY]

Local Char    WCLE(250),CHAINE(250),CHP(250)
Local Integer I,J,K,N,M,P,WNUM,WABR

If CLE='""' | CLE="''" : End CLE : Endif

Onerrgo EVALCLE
WCLE=CLE
Raz CLE
While WCLE<>""
 Raz WABR,WNUM
 N = instr(1,WCLE,"+")
 M =  instr(1,WCLE,"-")
 If N>0 & M>0
  P=min(N,M)
 Else
  P=max(N,M)
 Endif
 If P>0
  CHAINE = left$(WCLE,P-1)
 Else
  CHAINE = WCLE
 Endif
 I = instr(1,CHAINE,"num$(")
 If I>0
  J =  instr(6,CHAINE,")")
  CLE += left$(CHAINE,I+4)
  CHP = seg$(CHAINE,I+5,instr(6,CHAINE,")")-1)
  Read [ATZ]CODZONE = TAB;CHP
  If !fstat
   CLE += "[F:"+ABR+"]"
  Endif
  CLE += CHP
  CLE += ")"
 Else
  Read [ATZ]CODZONE = TAB;toupper(CHAINE)
  If !fstat
   WABR = 1
   Read [ATY]CODTYP = [ATZ]CODTYP
   If !fstat
    If find([F:ATY]TYPTYP ,1,2,3,4,5,6,8,11,12)>0
     WNUM = 1 :#
    Endif
   Endif
  Endif
  If WNUM>0
   CLE += "num$("
  Endif
  If WABR
   CLE += "[F:"+ABR+"]"
  Endif
  CLE += CHAINE
  If WNUM>0
   CLE += ")"
  Endif
 Endif
 CLE += seg$(WCLE,P,P)
 If P
  WCLE = right$(WCLE,P+1)
 Else
  WCLE = ""
 Endif
Wend

Onerrgo
Close Local File [ATZ],[ATY]
End CLE

$EVALCLE
CLE=WCLE
End

Subprog  ADD_CHPLNK(DOSSIER,VARIND,CODFIC,ABRFIC,TYPLNK,FLDCLA,DIME,ALNKCHP,LIGNE,DIF,CLOB)
Value Char DOSSIER
Value Char VARIND
Value Char CODFIC
Value Char ABRFIC
Value Char TYPLNK
Value Char FLDCLA
Value Integer DIME
Variable Instance  ALNKCHP Using C_ACLALNKCHP
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB
Case ALNKCHP.CODTYP
 When "ATX"
   If ALNKCHP.CHPATX<>""
    LIGNE = "Local File ATEXTE [WATX]": Gosub ADDCLB
    LIGNE = 'For [F:WATX] Where NUMERO=[F:'+[L]ABRFIC+"]"+ALNKCHP.CHPATX+' & LAN=this.ACTX.LAN' : Gosub ADDCLB
    DIF += 1
    LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+[L]FLDCLA
    If [L]DIME>1
     LIGNE += '("+num$('+VARIND+')+")'
    Endif
    LIGNE += '","'+func ASYRSUB.CODATT([L]TYPLNK)+'",[WATX]TEXTE)'
    Gosub ADDCLB
    DIF -= 1 : LIGNE = "Next WATX"  : Gosub ADDCLB
    LIGNE = "LogicClose File [WATX]" : Gosub ADDCLB
   Endif
 When "AXX","AX1","AX2","AX3"
   If ALNKCHP.CHPTAB<>"" & ALNKCHP.CHPZON<>"" & ALNKCHP.CHPCUR1<>"" & ALNKCHP.CHPCUR2<>""
    LIGNE = "Local File ATEXTRA [WAXX]": Gosub ADDCLB
    LIGNE = "Local Char ILAN(GLONLAN)": Gosub ADDCLB :#SAM 118887
    LIGNE = 'For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF' : Gosub ADDCLB :#SAM 118887
    DIF += 1
    LIGNE = 'For [F:WAXX] Where CODFIC='+ALNKCHP.CHPTAB+' & ZONE='+ALNKCHP.CHPZON+
&  ' & IDENT1='+func EVAL_CLE(DOSSIER,CODFIC,ABRFIC,ALNKCHP.CHPCUR1)+
&  ' & IDENT2='+func EVAL_CLE(DOSSIER,CODFIC,ABRFIC,ALNKCHP.CHPCUR2)+
&  ' & LANGUE = ILAN'  : Gosub ADDCLB:#SAM 118887
    DIF += 1
    LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+[L]FLDCLA
    LIGNE += '","'+func ASYRSUB.CODATT([L]TYPLNK)+'",[WAXX]TEXTE)'
    Gosub ADDCLB
    LIGNE = "Break 2"  : Gosub ADDCLB
    DIF -=1 : LIGNE = "Next WAXX"  : Gosub ADDCLB
    DIF -=1 : LIGNE = "Next ILAN"  : Gosub ADDCLB  :#SAM 118887
    LIGNE = "LogicClose File [WAXX]" : Gosub ADDCLB
   Endif
 When Default
   LIGNE = '[L]ASTATUS = fmet this.ASETATTRIBUTE("'+[L]FLDCLA
   If [L]DIME>1
    LIGNE += '("+num$('+VARIND+')+")'
   Endif
   LIGNE +=  '","'+func ASYRSUB.CODATT([L]TYPLNK)+'",'
   LIGNE += '[F:'+[L]ABRFIC+"]"+ALNKCHP.CHPCHAR
   LIGNE += ')' : Gosub ADDCLB
Endcase
End

