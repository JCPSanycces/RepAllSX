#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSH3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:31"
A_USER  = "DOC"
A_STAMP = "20181109230531"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG5"
  If [M]NBLIG5=0
  Endif
 When "NBLIG6"
  If [M]NBLIG6=0
  Endif
 When "NBLIG7"
  If [M]NBLIG7=0
  Endif
 When "NBLIG8"
  If [M]NBLIG8=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask NCSH3 [NCSH3]
Gosub HORODAT
Local Inpbox "NCSH3" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSH3] As [SIM_]
Grizo [NCSH3]5
Grizo [NCSH3]10
Grizo [NCSH3]15
Grizo [NCSH3]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [NCSH3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=7
X1(1)=1 : X2(1)=74 : Y1(1)=8 : Y2(1)=13
X1(2)=1 : X2(2)=74 : Y1(2)=14 : Y2(2)=19
X1(3)=1 : X2(3)=74 : Y1(3)=20 : Y2(3)=25
Return

$ON_NBLIG5
Onevent CONTROL Call C_NBLIG5 From W1NCSH3
Return

Subprog C_NBLIG5
Local Decimal BASPAG
## Action STD
Call C_NBLIG5 From SUBNCSH
If mkstat : GERR = 1 : GZONE = "NBLIG5" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_NCSID
Return

$ON_BPSNUM
Onevent CONTROL Call C_BPSNUM(zc) From W1NCSH3
Onevent AFTER_CHANGE Gosub AMM_BPSNUM From W1NCSH3
Onevent BEFORE_INPUT Call AS_BPSNUM(zc) From W1NCSH3
Return

Subprog AS_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1515,GBOUT1) From OBJDIV
Call TEXTE(20355,GBOUT11) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_BPSNUM(zc) From W1NCSH3
Onkey 139 Titled GBOUT11 Call B11_BPSNUM(zc) From W1NCSH3
Onkey   2 Titled GBOUTS Call S_BPSNUM(zc) From W1NCSH3
Onkey 144 Titled GBOUTP Call P_BPSNUM(zc) From W1NCSH3
Onkey 146 Titled GBOUTA Call SA_BPSNUM(zc) From W1NCSH3
Gosub _AFF
End

Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BPSCHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BPSCHOICE"
 Call S_TAB_CHAR(VALEUR,PARMSK,"BPSCHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("BPS","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
 If !mkstat
  ## Action STD
  Call C_BPSNUM(VALEUR) From SUBNCSH
  If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_BPSNUM
Call AM_BPSNUM(zc)
If !mkstat & GOBJET
 zoncou = "BPSNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_BPSNUM(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
Gosub _AFF
End

Subprog S_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "BPS"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_BPSNUM(VALEUR)
Variable Char    VALEUR()
Call OBJET("BPS",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog B11_BPSNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action USASUPSEAS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "USASUPSEAS"
 Call SAISIE_CHAR(VALEUR,PARMSK,"USASUPSEA","USATRTSEA","XWUSASUPSEA") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "BPS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("BPS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_SUPPCONTACT
Onevent BEFORE_INPUT Call AS_SUPPCONTACT(zc) From W1NCSH3
Onevent AFTER_CHANGE Gosub AMM_SUPPCONTACT From W1NCSH3
Onevent CONTROL Call C_SUPPCONTACT(zc) From W1NCSH3
Return

Subprog AS_SUPPCONTACT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3527,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_SUPPCONTACT(VALEUR) From SUBNCSH
If mkstat=2
 [M]SUPPCONTACT(INDIC) = VALEUR
 Affzo SUPPCONTACT(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_SUPPCONTACT(zc) From W1NCSH3
Onkey   2 Titled GBOUTS Call S_SUPPCONTACT(zc) From W1NCSH3
Onkey 144 Titled GBOUTP Call P_SUPPCONTACT(zc) From W1NCSH3
Onkey 146 Titled GBOUTA Call SA_SUPPCONTACT(zc) From W1NCSH3
Gosub _AFF
End

Subprog C_SUPPCONTACT(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("AIN","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "SUPPCONTACT" : GZNUM = 1824 : Endif
Gosub _AFF
End

$AMM_SUPPCONTACT
Call AM_SUPPCONTACT(zc)
If !mkstat & GOBJET
 zoncou = "SUPPCONTACT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
