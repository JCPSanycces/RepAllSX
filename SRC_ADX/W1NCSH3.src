Onevent AFTER_CHANGE Gosub AMM_USER From W1NCSH3
Onevent BEFORE_INPUT Call AS_USER(zc) From W1NCSH3
Return

Subprog AS_USER(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(485,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_USER(zc) From W1NCSH3
Onkey   2 Titled GBOUTS Call S_USER(zc) From W1NCSH3
Onkey 144 Titled GBOUTP Call P_USER(zc) From W1NCSH3
Onkey 146 Titled GBOUTA Call SA_USER(zc) From W1NCSH3
Gosub _AFF
End

Subprog C_USER(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "USER" : GZNUM = 190 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("AUS","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "USER" : GZNUM = 190 : Endif
 If !mkstat
  ## Action STD
  Call C_USER(VALEUR) From SUBNCSH
  If mkstat : GERR = 1 : GZONE = "USER" : GZNUM = 190 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_USER
Call AM_USER(zc)
If !mkstat & GOBJET
 zoncou = "USER" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

