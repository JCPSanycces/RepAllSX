#<AdxTL>@(#)1.0.0.0 $Revision$
Call COPIES
End

Subprog COPIES
Local Char VALEUR(10), PARAM(10)(1.1)
Call TRAITE_CHAR(VALEUR,PARAM,"","ADOSCOP","ADOSCOP",3,"SPEDOSCOP") From GTRAITE
End

#####################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
Endcase
Return

#####################
$INIT
If !clalev([F:ADS])   : Local File ADOSSIER [ADS] : Endif
If !clalev([F:ADA])   : Local File ADOSACT  [ADA] : Endif
Local Integer I
If func APRODUCT.AGETRELEASESUP()>="17v.132"
 # Cette fonction est obsolète. Veuillez utiliser la fonction $1$
 Call ERREUR(func AFNC.MES1(mess(280,125,1),"ADOSCOPDAT")) From GESECRAN
 FIN = 1
Endif
Return

#####################
$INIT_DIA
Raz [M]
Read [ADS]DOSSIER = nomap
[M:DIA]DOSORI = [F:ADS]DOSCOP
If !fstat
 Gosub CHARGE_DEST
Endif
Read [ADS]DOSSIER = nomap
If !fstat
 Gosub CHARGE_ORI
Endif
Return

###################################
$CONTROLE
If [M:DIA]NBLEG = 0
 Call ERREUR(mess(241,133,1)) From GESECRAN
 SAI = 1
 Return
Endif
Read [F:ADA]ADA0 = [M]DOSDES;"LEG"
If !fstat
 If [F:ADA]FLACT <> 2
  If [M]NBLEG > 1
   Call ERREUR(mess(250,133,1)) From GESECRAN : # Trop de législation parametrées
   SAI = 1 : Return
  Endif
  If [M]LEG(0) <> [M]LEGD(0)
   Call ERREUR([M]LEG(0)-":"-mess(249,133,1)-[M]DOSDES) From GESECRAN : # LéGISLATION non gérée par le dossier
   SAI = 1 : Return
  Endif
 Endif
Endif
Return

#################################
$CHARGE_ORI
[M:DIA]NBLIG  = len(mess(0,26,1))
[M:DIA]NBLEG = [F:ADS]NBLEG
For I =0  To [M:DIA]NBLIG-1
 [M:DIA]OPTINI(I) = [F:ADS]OPTINI(I)
Next
For I=0 To [F:ADS]NBLEG-1
 If [F:ADS]DOSLEG(I) <> ""
  [M:DIA]LEG(I) = [F:ADS]DOSLEG(I)
  Call LECTEXTRA([M]INTITLEGORI(I),"ATABDIV","LNGDES","909",[M:DIA]LEG(I)) From ATEXTRA
 Endif
Next I
Affzo [M:DIA]LEG,INTITLEGORI
Affzo [M:DIA]OPTINI
Return

###################################
$CHARGE_DEST
[M:DIA]NBLIG  = len(mess(0,26,1))
[M:DIA]NBLEGD = [F:ADS]NBLEG
For I =0  To [M:DIA]NBLIG-1
 [M:DIA]OPTINI(I) = [F:ADS]OPTINI(I)
Next
For I=0 To [F:ADS]NBLEG-1
 If [F:ADS]DOSLEG(I) <> ""
  [M:DIA]LEGD(I) = [F:ADS]DOSLEG(I)
  Call LECTEXTRA([M]INTLEG(I),"ATABDIV","LNGDES","909",[M:DIA]LEGD(I)) From ATEXTRA
 Endif
Next I
Affzo [M:DIA]LEGD,INTLEG
Affzo [M:DIA]OPTINI
If func AFNC.ACVDOSACT([F:ADS]DOSSIER,"LEG")=0
 [M]AJOUT = 2
 Affzo [M]AJOUT
 Grizo [M]AJOUT
Else
 Actzo [M]AJOUT
Endif
Return

#########################################
$EXEC
Local Integer NBCOP
Local Char TBCOP(GLONATB)(1..500)

Read [F:ADS]DOSSIER = [M:DIA]DOSDES
If fstat
 Return
Endif

If !GSERVEUR & !GIMPORT
 GINFO = 1
Else
 GINFO = 0
Endif

If GINFO
 Call OUVRE_VLC(mess(174,125,1)-[F:ADS]DOSSIER,"","") From GESECRAN : # Copie
Endif

# Copie des données
Call OUVRE_TRACE(mess(30,125,1)-[F:ADS]DOSSIER) From LECFIC

# Début de copie
Call ECR_TRACE(mess(174,125,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

# Copie des données
Call COPIE([M:DIA]DOSDES,[M:DIA]DOSORI,[F:ADS]DOSREF,[M:DIA]OPTINI,[M:DIA]LEG
&         ,[F:ADS]DOSLEG,[F:ADS]MODULE,[M:DIA]AJOUT,[F:ADS]CRYDEF,2,NBCOP,TBCOP)

# Copie valeur parametre
Call COPADW([M:DIA]DOSDES,[M:DIA]DOSORI,[F:ADS]DOSREF,[M:DIA]LEG,[F:ADS]DOSLEG)

# Copie ADI
Call DICDIV([M:DIA]DOSDES,[M:DIA]DOSORI,[F:ADS]DOSREF,[M:DIA]LEG,[M:DIA]NBLEG,[M:DIA]AJOUT,0,[F:ADS]DOSLEG,2)

# Vérif des liens
Call LIENS([M:DIA]DOSDES,NBCOP,TBCOP)

# Fiche du dossier destinataire et paramètre général DOSLEG
Call MAJDOSDES([M:DIA]DOSDES,[M:DIA]LEGD,[M]NBLEGD)

# Fin de génération
Call ECR_TRACE(mess(175,125,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

Call FERME_TRACE From LECFIC

If GINFO
 Call FERME_VLC From GESECRAN
Endif

TRA = 1
Return

#######################################################################
Subprog MAJDOSDES(DOSSIER,LEGD,NBLEGD)
Value Char DOSSIER
Value Char LEGD()(0..)
Value Integer NBLEGD

Local Integer I,OK

Local File =[L]DOSSIER+".ADOVAL" [ADW]

If GINFO
 Call AFF_VLC(mess(3,125,1)-DOSSIER,"") From GESECRAN : # Mise à jour du dossier
Endif

Call ECR_TRACE(mess(3,125,1)-DOSSIER,0) From GESECRAN : # Mise à jour du dossier

Trbegin [F:ADS]
 Read [F:ADS]DOSSIER = [L]DOSSIER
 If !fstat
  For I=0 To [L]NBLEGD-1
   If !find(LEGD(I),[F:ADS]DOSLEG(0..[F:ADS]NBLEG-1)) & LEGD(I)<> ""
    [F:ADS]DOSLEG([F:ADS]NBLEG) = LEGD(I)
    [F:ADS]NBLEG+=1
    OK=1
   Endif
  Next I
  If OK
   Rewrite [F:ADS]
   If fstat
    Call ERREUR("ADOSSIER"-[F:ADS]DOSSIER,2) From DOSDIC
    Rollback
    End
   Endif
  Endif
  Call MAJPAR("DOSLEG",sigma(0,[F:ADS]NBLEG-1,string$(indcum>0,"~")+[F:ADS]DOSLEG(indcum)))  From DOSDIV
  If fstat
   Rollback
   End
  Endif
 Endif
Commit

End

######################################################################################
Subprog COPADW(DOSSIER,DOSCOP,DOSREF,DOSLEG,DOSLEGREF)
Value Char    DOSSIER
Value Char    DOSCOP
Value Char    DOSREF
Value Char    DOSLEG()(0..)
Value Char    DOSLEGREF()(0..)

Local File =[L]DOSSIER+".ADOVAL" [DADW]
Local File =[L]DOSCOP+".ADOVAL"  [ADW]
Local File =[L]DOSSIER+".ADOPAR" [DADP]
If clalev([F:ADA])=0 : Local File ADOSACT [ADA] : Endif

Local Char TBLEG(GLONADI)(1..dim(GDOSLEG))
Local Integer NBLEG , OKLEG

Call ECR_TIME(mess(15,125,1)-mess(25,125,1)-":"-mess(238,133,1)) From DOSSUB

Call SETLEG([L]DOSSIER,TBLEG,NBLEG) From DOSCONT
OKLEG = 0
Read [ADA]ADA0=DOSREF;"LEG"
If !fstat & [F:ADA]FLACT=2
 Read [ADA]ADA0=[F:ADS]DOSSIER;"LEG"
 If !fstat & [F:ADA]FLACT=2
  OKLEG = 1
 Endif
Endif

Trbegin [F:ADW]

 For [DADP]ADP0
  #If [F:DADP]NIVDEF=5 : # CCL bug 59436
   # Si le dossier validé est en mono-législation,
   # On copie la valeur de la législation du dossier validé dans la valeur dossier
   If !OKLEG
    Read [DADW]ADW0 = "";"";[F:DADP]PARAM
    If fstat
     Read [ADW]ADW0 = "*";[F:ADS]DOSLEG(0);[F:DADP]PARAM
     If !fstat
     [F:DADW] = [F:ADW]
     [F:DADW]CMP = ""
     [F:DADW]FCY = ""
     Write [DADW]
     If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
     Endif
    Endif
   Else
    # Sinon on copie les valeurs des nouvelles législations
    For I=0 To dim(DOSLEG)-1
     If [L]DOSLEG(I)<>""
      If find([L]DOSLEG(I),[L]DOSLEGREF(0..dim([L]DOSLEGREF)-1))
       Read [DADW]ADW0 = "*";[L]DOSLEG(I);[F:DADP]PARAM
       If fstat
        Read [ADW]ADW0 = "*";[L]DOSLEG(I);[F:DADP]PARAM
        If !fstat
         [F:DADW] = [F:ADW]
         Write [DADW]
         If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
        Endif
       Endif
      Endif
     Endif
    Next I
   Endif
  #Endif : # 56436
 Next DADP

Commit

End

#################################################################################################################
Subprog COPIE(DOSSIER,DOSCOP,DOSREF,OPTINI,DOSLEG,DOSLEGREF,MODULE,AJOUT,ACRYDEF,FONCT,NBCOP,TBCOP)
Value    Char    DOSSIER
Value    Char    DOSCOP
Value    Char    DOSREF
Value    Integer OPTINI(0..)
Value    Char    DOSLEG()(0..)
Value    Char    DOSLEGREF()(0..)
Value    Integer MODULE
Value    Integer AJOUT
Value    Char    ACRYDEF
Value    Integer FONCT
Variable Integer NBCOP
Variable Char    TBCOP()(1..)

# 1) On copie les fichiers

Onerrgo ERREUR

Local Char     TBTYP(GLONATY)(1..500)
Local Char     TBLEG(GLONATB)(1..500)
Local Char     TBCOPLEG(GLONATB)(1..500)

Local Integer  NBRAZ , NBREC , MAXREC
Local Char     ZONRAZ(GLONAVA)(1..50) , ACTION(20)
Local Integer  II, I , J , K , T , Z , D , X , M , OK , ERR , SUPP , RW , SAVSERV , JJ, NBLANAXX , ERN
Local Char     TBLANAXX(GLONLAN)(0..50)
Local Integer  NBCLE,NBCHP,TABVIDE,NBCHP2,NB_RECORD,NEWLEG
Local Char     CLE(30)(1..50),CHPS(30)(1..20),CHPS2(30)(1..20),LEG1(10),LEG2(10)
Local Char     WLEG(20)(0..20), WFOR(250)(0..20) , OKAXX(100) , LEG0(250) , SAVLEG(20)
Local Char     MIGTABLE(20) : # Issue 82373 - 2012-06-04 by VPO : ne pas copier les tables en migration
Local Integer ISMULTILEG

If GINFO
 Call AFF_VLC(mess(30,125,1),"") From GESECRAN
 # Copie des données
Endif

Call ECR_TIME(mess(30,125,1)) From DOSSUB
Local File =[L]DOSSIER+".ATABLE"   [ATB]
Local File =[L]DOSSIER+".ATABLE"   [ATB2] : # Issue 82373 - 2012-06-04 by VPO : ne pas copier les tables en migration
Local File =[L]DOSSIER+".ATABZON"  [ATZ]
Local File =[L]DOSSIER+".ATABZON"  [ATZ2]
Local File =[L]DOSSIER+".ATABIND"  [ATI]
Local File =[L]DOSSIER+".ACTIV"    [ACV]
Local File =[L]DOSSIER+".AMSKPAR"  [AMP]
Local File =[L]DOSSIER+".ATABZON"  [ATZ3]
Local File =[L]DOSSIER+".AMSKPAR"  [AMP2]

For I=0 To dim(DOSLEG)-1
 If [L]DOSLEG(I)<> ""
  If !find([L]DOSLEG(I),[L]DOSLEGREF(0..dim([L]DOSLEGREF)-1))
   NEWLEG = 1
   Call ECR_TRACE(mess(79,127,1)-":"-[L]DOSLEG(I),0) From GESECRAN
  Endif
 Endif
Next I

[L]ISMULTILEG = func AFNC.ACVDOSACT(DOSSIER,"LEG")

NBCOP  = 0
MAXREC = 1000

### Recup du tableau des langues par rapport a ATEXTRA
If filinfo(filpath("FIL","ATEXTRA","fde",[L]DOSSIER),0)>=0
 OK = 1
 If filinfo(filpath("FIL","ATEXTRA","fde",[L]DOSCOP),0)>=0
  Local File =[L]DOSCOP+".ATEXTRA"  [AXX]
 Elsif filinfo(filpath("FIL","ATEXTRA","fde",[L]DOSREF),0)>=0
  Local File =[L]DOSREF+".ATEXTRA"  [AXX]
 Elsif filinfo(filpath("FIL","ATEXTRA","fde",GDOSX3),0)>=0
  Local File =GDOSX3+".ATEXTRA" [AXX]
 Else
  OK = 0
 Endif
 If OK
  For [AXX]AXX0 (3)
   If !find([F:AXX]LANGUE,TBLANAXX(0..NBLANAXX))
    TBLANAXX(NBLANAXX) =[F:AXX]LANGUE
    NBLANAXX += 1
   Endif
  Next
  Close Local File [AXX]
 Endif
Endif

## On fait ATEXTRa en premier pour gerer les AXX des tables diverses en creation de dossier
For [ATB]CODFIC Where TYPFIC<3 & CODFIC ="ATEXTRA"
 Gosub COPIE_ATB
Next ATB

# les tables lignes
For [ATB]CODFIC Where TYPFIC<3
 For [ATZ2]CODZONE Where CODFIC=[F:ATB]CODFIC & CHPLEG = 2
  If [F:ATZ2]CODTYP="ADI"
   Read [AMP]CODPAR=2;[F:ATZ2]CODFIC;[F:ATZ2]CODZONE;"ADI"
   If !fstat & num$(evalue([F:AMP]VALPAR)) <> "909"
    Gosub COPIE_ATB
    Break
   Endif
  Else
   Gosub COPIE_ATB
   Break
  Endif
 Next ATZ
Next ATB

# les autres Tables
For [ATB]CODFIC Where TYPFIC<3
 Gosub COPIE_ATB
Next ATB

# Après la copie de la table ATEXTRA, on vire les enregs correspondant aux tables non copiées
If find("ATEXTRA",[L]TBCOP(1..NBCOP))
 Call ECR_TRACE(mess(30,133,1)-"ATEXTRA",0) From GESECRAN : # Epuration de la table
 Local File =[L]DOSSIER+".ATEXTRA" [AXX]
 Local File =[L]DOSSIER+".ATEXTRA" [AXX2]
 Local File =[L]DOSSIER+".ATABDIV" [ADI_]
 Local File =[L]DOSSIER+".ATABTAB" [ADV_]
 Trbegin [AXX2]
  For [AXX]AXX0(1)
   If !find([F:AXX]CODFIC,TBCOP(1..NBCOP))
    OK = 0
    Read [ATB]CODFIC=[F:AXX]CODFIC
    If fstat | filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSSIER),0)<0
     OK = 1
    Else
     Local File =[L]DOSSIER+"."+[F:ATB]CODFIC [F1]
     OK = (nbrecord([F1])=0)
     Close Local File [F1]
    Endif
    If OK
     Delete [AXX2] Where CODFIC=[F:AXX]CODFIC
     If fstat
      Call ERREUR([F:AXX]CODFIC,2) From DOSDIC
     Endif
    Endif
   Endif
  Next AXX
  # Epuration des textes traduisibles en trop provenant des tables diverses
  Call ECR_TRACE(mess(30,133,1)-"ATEXTRA->ATABTAB->ATABDIV",0) From GESECRAN : # Epuration de la table
  For [AXX]AXX0 Where CODFIC = "ATABTAB" or CODFIC="ATABDIV"
   If [F:AXX]CODFIC = "ATABTAB"
    Read [ADV_]CODE = val([F:AXX]IDENT1)
   Else
    Read [ADI_]CODE = val([F:AXX]IDENT1);[F:AXX]IDENT2
   Endif
   If fstat
    Delete [AXX]Curr
    If fstat
     Call ERREUR("AXX"-[F:AXX]CODFIC,2) From DOSDIC
    Endif
   Endif
  Next AXX
 Commit
 Close Local File [AXX] , [AXX2] , [ADI_] , [ADV_]

# Après la copie d'une table contenant des textes traduisibles, il faut copier les ATEXTRA correspondant
Elsif find("AXX",TBTYP(1..NBCOP))
 If filinfo(filpath("FIL","ATEXTRA","fde",[L]DOSSIER),0)>=0
  OK = 1
  If filinfo(filpath("FIL","ATEXTRA","fde",[L]DOSCOP),0)>=0
   Local File =[L]DOSCOP+".ATEXTRA"  [AXX]
  Elsif filinfo(filpath("FIL","ATEXTRA","fde",[L]DOSREF),0)>=0
   Local File =[L]DOSREF+".ATEXTRA"  [AXX]
  Elsif filinfo(filpath("FIL","ATEXTRA","fde",GDOSX3),0)>=0
   Local File =GDOSX3+".ATEXTRA" [AXX]
  Else
   OK = 0
  Endif
  If OK
   Call ECR_TIME(mess(56,123,1)-"ATEXTRA") From DOSSUB
   If GINFO
    # Copie des données - Table
    Call AFF_VLC(mess(30,125,1),mess(56,123,1)-"ATEXTRA") From GESECRAN
   Endif
   Local File =[L]DOSSIER+".ATEXTRA"   [AXX2]
   Trbegin [AXX2]
    For I=1 To NBCOP
     If TBTYP(I)="AXX"
      Delete [AXX2] Where CODFIC=TBCOP(I)
      If fstat
       Call ERREUR(TBCOP(I),2) From DOSDIC
      Endif
      For [AXX] Where CODFIC=TBCOP(I)
       [F:AXX2] = [F:AXX]
       Write [AXX2]
       If fstat
        Call ERREUR([F:AXX]CODFIC-[F:AXX]ZONE-[F:AXX]LANGUE-[F:AXX]IDENT1-[F:AXX]IDENT2,1) From DOSDIC
       Endif
      Next AXX
     Endif
    Next I
   Commit
   Close Local File [AXX2] , [AXX]
  Endif
 Endif
Endif

# Après la copie de la table ALISTEH, il faut copier le script des requêtes SQL
If find("ALISTEH",TBCOP(1..NBCOP))
 If filinfo(filpath("FIL","ACLOB","fde",[L]DOSSIER),0)>=0
  OK = 1
  If filinfo(filpath("FIL","ACLOB","fde",[L]DOSCOP),0)>=0
   Local File =[L]DOSCOP+".ACLOB"  [ACB]
  Elsif filinfo(filpath("FIL","ACLOB","fde",[L]DOSREF),0)>=0
   Local File =[L]DOSREF+".ACLOB"  [ACB]
  Elsif filinfo(filpath("FIL","ACLOB","fde",GDOSX3),0)>=0
   Local File =GDOSX3+".ACLOB" [ACB]
  Else
   OK = 0
  Endif
  If OK
   Call ECR_TIME(mess(56,123,1)-"ACLOB") From DOSSUB
   If GINFO
    # Copie des données - Table
    Call AFF_VLC(mess(30,125,1),mess(56,123,1)-"ACLOB") From GESECRAN
   Endif
   Local File =[L]DOSSIER+".ACLOB"   [DACB]
   Local File =[L]DOSSIER+".ALISTEH" [DALH]
   Gosub PFIX From SUBALQ
   Trbegin [DACB]
    For [DALH] Where TYP=2
     Read [ACB]ACB0 = IDCLOB;[F:DALH]COD;"";""
     If !fstat
      [F:DACB] = [F:ACB]
      Write [DACB]
      If fstat
       Call ERREUR("ACLOB",1) From DOSDIC
      Endif
     Endif
    Next DALH
   Commit
   Close Local File [DALH] , [DACB] , [ACB]
  Endif
 Endif
Endif

# Copie des paramètres utilisateurs
Read [ATB]CODFIC="AUTILIS"
If !fstat & [F:ATB]OPT>0 & [L]OPTINI([F:ATB]OPT-1)=2
 M = [F:ATB]OPT
 For I=1 To NBCOP
  Read [ATB]CODFIC = TBCOP(I)
  If [F:ATB]OPT=M
   Call ECR_TRACE(mess(68,126,1),0) From GESECRAN : # Validation des fonctions
   If GINFO
    Call AFF_VLC(mess(30,125,1),mess(68,126,1)) From GESECRAN
   Endif
   SAVSERV = GSERVEUR
   GSERVEUR = 1
   Onerrgo ERRFIC
   #Call VALIDATION([L]DOSSIER) From AVALAFC
   Onerrgo
   GSERVEUR = SAVSERV
   Break
  Endif
 Next I
Endif

# Après la copie des modèles d'import, il faut copier les valeurs par défaut et codes internes
If find("AOBJEXT",[L]TBCOP(1..NBCOP))
 If filinfo(filpath("FIL","AREPORTX","fde",[L]DOSSIER),0)>=0
  OK = 1
  If filinfo(filpath("FIL","AREPORTX","fde",[L]DOSCOP),0)>=0
   Local File =[L]DOSCOP+".AREPORTX"  [ARX]
  Elsif filinfo(filpath("FIL","AREPORTX","fde",[L]DOSREF),0)>=0
   Local File =[L]DOSREF+".AREPORTX"  [ARX]
  Elsif filinfo(filpath("FIL","AREPORTX","fde",GDOSX3),0)>=0
   Local File =GDOSX3+".AREPORTX" [ARX]
  Else
   OK = 0
  Endif
  If OK
   Call ECR_TIME(mess(56,123,1)-"AREPORTX/AOBJEXT") From DOSSUB
   If GINFO
    # Copie des données - Table
    Call AFF_VLC(mess(30,125,1),mess(56,123,1)-"AREPORTX/AOBJEXT") From GESECRAN
   Endif
   Local File =[L]DOSSIER+".AREPORTX" [DARX]
   Trbegin [DARX]
    Delete [DARX] Where TYPCOD=4
    For [ARX] Where TYPCOD=4
     [F:DARX] = [F:ARX]
     Write [DARX]
     If fstat
      Call ERREUR("AREPORTX",1) From DOSDIC
     Endif
    Next ARX
   Commit
   Close Local File [DARX] , [ARX]
  Endif
 Endif
 If filinfo(filpath("FIL","AREPORTV","fde",[L]DOSSIER),0)>=0
  OK = 1
  If filinfo(filpath("FIL","AREPORTV","fde",[L]DOSCOP),0)>=0
   Local File =[L]DOSCOP+".AREPORTV"  [ARV]
  Elsif filinfo(filpath("FIL","AREPORTV","fde",[L]DOSREF),0)>=0
   Local File =[L]DOSREF+".AREPORTV"  [ARV]
  Elsif filinfo(filpath("FIL","AREPORTV","fde",GDOSX3),0)>=0
   Local File =GDOSX3+".AREPORTV" [ARV]
  Else
   OK = 0
  Endif
  If OK
   Call ECR_TIME(mess(56,123,1)-"AREPORTV/AOBJEXT") From DOSSUB
   If GINFO
    # Copie des données - Table
    Call AFF_VLC(mess(30,125,1),mess(56,123,1)-"AREPORTV/AOBJEXT") From GESECRAN
   Endif
   Local File =[L]DOSSIER+".AREPORTV" [DARV]
   Trbegin [DARV]
    Delete [DARV] Where TYPCOD=4
    For [ARV] Where TYPCOD=4
     [F:DARV] = [F:ARV]
     Write [DARV]
     If fstat
      Call ERREUR("AREPORTV",1) From DOSDIC
     Endif
    Next ARV
   Commit
   Close Local File [DARV] , [ARV]
  Endif
 Endif
Endif

# Après la copie des requêtes, il faut copier les valeurs par défaut et codes internes
If find("ALISTEH",TBCOP(1..NBCOP))
 If filinfo(filpath("FIL","AREPORTX","fde",[L]DOSSIER),0)>=0
  OK = 1
  If filinfo(filpath("FIL","AREPORTX","fde",[L]DOSCOP),0)>=0
   Local File =[L]DOSCOP+".AREPORTX"  [ARX]
  Elsif filinfo(filpath("FIL","AREPORTX","fde",[L]DOSREF),0)>=0
   Local File =[L]DOSREF+".AREPORTX"  [ARX]
  Elsif filinfo(filpath("FIL","AREPORTX","fde",GDOSX3),0)>=0
   Local File =GDOSX3+".AREPORTX" [ARX]
  Else
   OK = 0
  Endif
  If OK
   Call ECR_TIME(mess(56,123,1)-"AREPORTX/AOBJEXT") From DOSSUB
   If GINFO
    # Copie des données - Table
    Call AFF_VLC(mess(30,125,1),mess(56,123,1)-"AREPORTX/AOBJEXT") From GESECRAN
   Endif
   Local File =[L]DOSSIER+".AREPORTX" [DARX]
   Trbegin [DARX]
    Delete [DARX] Where TYPCOD=2 or TYPCOD=3
    For [ARX] Where TYPCOD=2 or TYPCOD=3
     [F:DARX] = [F:ARX]
     Write [DARX]
     If fstat
      Call ERREUR("AREPORTX",1) From DOSDIC
     Endif
    Next ARX
   Commit
   Close Local File [DARX] , [ARX]
  Endif
 Endif
 If filinfo(filpath("FIL","AREPORTV","fde",[L]DOSSIER),0)>=0
  OK = 1
  If filinfo(filpath("FIL","AREPORTV","fde",[L]DOSCOP),0)>=0
   Local File =[L]DOSCOP+".AREPORTV"  [ARV]
  Elsif filinfo(filpath("FIL","AREPORTV","fde",[L]DOSREF),0)>=0
   Local File =[L]DOSREF+".AREPORTV"  [ARV]
  Elsif filinfo(filpath("FIL","AREPORTV","fde",GDOSX3),0)>=0
   Local File =GDOSX3+".AREPORTV" [ARV]
  Else
   OK = 0
  Endif
  If OK
   Call ECR_TIME(mess(56,123,1)-"AREPORTV/AOBJEXT") From DOSSUB
   If GINFO
    # Copie des données - Table
    Call AFF_VLC(mess(30,125,1),mess(56,123,1)-"AREPORTV/AOBJEXT") From GESECRAN
   Endif
   Local File =[L]DOSSIER+".AREPORTV" [DARV]
   Trbegin [DARV]
    Delete [DARV] Where TYPCOD=2 or TYPCOD=3
    For [ARV] Where TYPCOD=2 or TYPCOD=3
     [F:DARV] = [F:ARV]
     Write [DARV]
     If fstat
      Call ERREUR("AREPORTV",1) From DOSDIC
     Endif
    Next ARV
   Commit
   Close Local File [DARV] , [ARV]
  Endif
 Endif
Endif
Onerrgo
# Pour gérer le cas des adresses par exemple
ACTION = "DOSCOP" : Gosub ACTION From SUBADS
End

# Issue 82373 - 2012-06-04 by VPO : ne pas copier les tables en migration
$VERIF_MIG
If ([F:ATB]CRE=2) or ([F:ATB]CRE=3 & [L]OPTINI([F:ATB]OPT-1)=2)
  Call MIGTABNAME ([L]DOSSIER,[F:ATB]CODFIC,MIGTABLE,ERR) From TRTMIG
  Read [ATB2]CODFIC=MIGTABLE
  If !fstat & [F:ATB2]CODACT="MIG"
    NBCOP += 1
    TBCOP(NBCOP) = [F:ATB]CODFIC
  Endif
Endif
Return

$COPIE_ATB
Onerrgo ERRFIC
# Issue 82373 - 2012-06-04 by VPO : ne pas copier les tables en migration
Gosub VERIF_MIG
If !find([F:ATB]CODFIC,TBCOP(1..NBCOP)) & !find([F:ATB]CODFIC,TBCOPLEG(1..NBCOP))
 Raz TABVIDE
 If ([F:ATB]CRE=2) or ([F:ATB]CRE=3 & [L]OPTINI([F:ATB]OPT-1)=2)
  If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSSIER),0)>=0
   OK = 1
   If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSCOP),0)>=0
    Local File =[L]DOSCOP+"."+[F:ATB]CODFIC  [F1]
   Elsif filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[L]DOSREF),0)>=0
    Local File =[L]DOSREF+"."+[F:ATB]CODFIC  [F1]
   Elsif filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",GDOSX3),0)>=0
    Local File =GDOSX3+"."+[F:ATB]CODFIC [F1]
   Else
    OK = 0
   Endif
   If OK
    Local File =[L]DOSSIER+"."+[F:ATB]CODFIC [F2]
    Local File =[L]DOSSIER+".ATEXTRA"   [AXX2] : # pour la gestion avec multilegisaltion
    If nbrecord([F2])=0 | ([F:ATB]FLGLEG = 2 & (NEWLEG or FONCT))
     NBCOP += 1
     TBCOP(NBCOP) = [F:ATB]CODFIC
     NBRAZ = 0
     LEG1=""
     LEG2=""
     NB_RECORD = nbrecord([F2])
     For [ATZ]CODZONE Where CODFIC=[F:ATB]CODFIC & ZERO=2
      NBRAZ += 1
      ZONRAZ(NBRAZ) = [F:ATZ]CODZONE
     Next ATZ
     For [ATZ]CODZONE Where CODFIC=[F:ATB]CODFIC & find(CODTYP,"AXX","AX1","AX2","AX3")
      If nbrecord([F2])=0 & [F:ATB]FLGLEG <> 2
       TBTYP(NBCOP) = "AXX"
       Break
      Else
       TBTYP(NBCOP) = "LEG"
       Break
      Endif
     Next ATZ
     If [L]DOSLEG(0) <> "" & [F:ATB]FLGLEG = 2
      Gosub VERIF_COPIE
     Endif
     If OK
      If GINFO
       # Copie des données - Table
       Call AFF_VLC(mess(30,125,1),mess(56,123,1)-[F:ATB]CODFIC) From GESECRAN
      Endif
      # Table
      If TBLEG(NBCOP) = ""
       Call ECR_TIME(mess(56,123,1)-[F:ATB]CODFIC) From DOSSUB
      Endif
      NBREC = 0
      Trbegin [F2]
       For [F1]
        OK = 1
        If dim([F:F1]CODACT)>0 & [F:F1]CODACT<>""
         Read [ACV]CODACT = [F:F1]CODACT
         If fstat or [F:ACV]FLACT<>2 : OK = 0 : Endif
        Endif
        If dim([F:F1]MODULE)>0 & [F:F1]MODULE>0
         If [L]MODULE([F:F1]MODULE-1)<>2 : OK = 0 : Endif
        Endif
        If [F:ATB]CODFIC = "POSCOD"
         If dim([F1]CRY)>0 & [F1]CRY<>[L]ACRYDEF : OK =0 : Endif
        Endif
        If TBLEG(NBCOP) <> ""
         Gosub COPIE_LEG
        Endif
        If [F:ATB]CODFIC = "ATEXTRA"
         I= find([F1]CODFIC,TBCOP(1..NBCOP))
         If I
          If TBTYP(I) = "LEG" : OK =0 : Endif
         Endif
        Endif
        If OK
         If NBREC>=MAXREC
          Commit
          Trbegin [F2]
          NBREC = 0
         Endif
         NBREC += 1
         [F:F2] = [F:F1]
         For I=1 To NBRAZ
          D = evalue("dim([F:F2]"+ZONRAZ(I)+")")
          T = evalue("type([F:F2]"+ZONRAZ(I)+")")
          For J=1 To D
           Case T
            When 1,2,4,5,6,7,8,9
             Assign "[F:F2]"+ZONRAZ(I)+"("+num$(J-1)+")" With 0
            When 3
             Assign "[F:F2]"+ZONRAZ(I)+"("+num$(J-1)+")" With [0/0/0]
            When Default
             Assign "[F:F2]"+ZONRAZ(I)+"("+num$(J-1)+")" With ""
           Endcase
          Next J
         Next I
         If [F:ATB]CODFIC<>"TABFOR" & [L]ISMULTILEG=0 & LEG1<>"" & evalue("dim([F:F2]"+LEG1+")")>0
          Assign "SAVLEG" With evalue("[F:F2]"+LEG1)
          Assign "[F:F2]"+LEG1 With DOSLEG(0)
         Endif
         If [F:ATB]CODFIC = "TABFOR" & [F1]FORTYP = 21 & GPRODUIT=0
          J=0 :  Raz WLEG : Raz WFOR
          For I=0 To dim([F1]LEG)-1
           If  [F1]LEG(I) = ""  or find([F1]LEG(I),[L]DOSLEG(0..dim(DOSLEG)-1))>0
            WLEG(J) = [F1]LEG(I)
            If [L]ISMULTILEG=0 & WLEG(J) ="" & [F1]FORFOR(I)<>""
             WLEG(J) = DOSLEG(0)
            Endif
            WFOR(J) = [F1]FORFOR(I)
            J+=1
           Endif
          Next
          Raz [F2]LEG
          Raz [F2]FORFOR
          For I=0 To J-1
           [F2]LEG(I)    = WLEG(I)
           [F2]FORFOR(I) = WFOR(I)
          Next
         Endif
         Write [F2]
         If fstat
          Call ERREUR([F:ATB]CODFIC,1) From DOSDIC
         Elsif !fstat & TBTYP(NBCOP) = "LEG"
          Call WRITE_AXX([L]DOSSIER,[L]DOSCOP,[L]DOSREF,[F:ATB]CODFIC,[L]ISMULTILEG,LEG1,SAVLEG,TBLANAXX,NBLANAXX,OKAXX)
         Endif
        Endif
       Next F1
       If TBLEG(NBCOP) <> ""
        If NBREC>0 & TBCOPLEG(NBCOP)="" : # Pour afficher la table qu'une fois
         Call ECR_TIME(mess(56,123,1)-[F:ATB]CODFIC) From DOSSUB
         TBCOPLEG(NBCOP) = TBCOP(NBCOP)
        Elsif NBREC>0 & TBCOPLEG(NBCOP)<>""
         TBCOPLEG(NBCOP) = TBCOP(NBCOP)
         #TBCOP(NBCOP) = "" : # CCL 60026 on passe plus la table dans le subprog LIENS
        Else
         TBCOPLEG(NBCOP) = TBCOP(NBCOP)
         TBCOP(NBCOP) = ""
        Endif
       Endif
      Commit
     Endif
    Endif
    Close Local File [F1] , [F2] , [AXX2]
    If clalev([F:F3]) : Close Local File [F3] : Endif
    If clalev([F:F4]) : Close Local File [F4] : Endif
    If clalev([F:F5]) : Close Local File [F5] : Endif
   Endif
  Endif
 Endif
Endif
If OKAXX<>""
 Call ECR_TRACE(OKAXX,1) From GESECRAN
 OKAXX = ""
Endif
Onerrgo
Return

$VERIF_COPIE
For [ATZ]CODZONE Where CODFIC=[F:ATB]CODFIC & CHPLEG = 2
 If [F:ATZ]CODTYP="ADI"
  Read [AMP]CODPAR=2;[F:ATZ]CODFIC;[F:ATZ]CODZONE;"ADI"
  If !fstat & num$(evalue([F:AMP]VALPAR)) = "909"
   TBLEG(NBCOP)  = [F:ATB]CODFIC
   LEG1 =   [F:ATZ]CODZONE
   Break
  Endif
 Endif
 If TBLEG(NBCOP)  = ""
  TBLEG(NBCOP)  = [F:ATZ]LIEN
  Raz NBCHP,CHPS
  If [F:ATZ]EXPLIEN<> ""
   Call SETLIEN(NBCHP,CHPS,[F:ATZ]EXPLIEN)
  Else
   NBCHP =1
   CHPS = [F:ATZ]CODZONE
  Endif
  Read [ATI]NUMLIG(2)=[F:ATZ]LIEN;1
  Call SETCLE(NBCHP2,CHPS2,[F:ATI]DESCRIPT) From LNKSUB
  LEG2 =  func CHAMPLEG(TBLEG(NBCOP))
  If NBCHP <> NBCHP2 : OK =0 : Endif
  Break
 Endif
Next ATZ
If TBLEG(NBCOP) = ""
 TBLEG(NBCOP)  = [F:ATB]CODFIC
 LEG1 =  func CHAMPLEG(TBLEG(NBCOP))
Endif
If filinfo(filpath("FIL",[L]TBLEG(NBCOP),"fde",[L]DOSSIER),0)>=0
 Local File =[L]DOSCOP+"."+[L]TBLEG(NBCOP)  [F3]
 Local File =[L]DOSSIER+"."+[L]TBLEG(NBCOP) [F5]
Else
 OK = 0
Endif
If OK
 Local File =[L]DOSSIER+"."+[F:ATB]CODFIC [F4]
 Filter [F:ATI] Where CODFIC = [F:ATB]CODFIC
 Read [ATI]NUMLIG First
 Filter [F:ATI]
 Call SETCLE(NBCLE,CLE,[F:ATI]DESCRIPT) From LNKSUB
 If TBLEG(NBCOP) = [F:ATB]CODFIC
  Raz NBCHP,CHPS
  NBCHP = NBCLE
  For I=1 To NBCLE
   CHPS(I) = CLE(I)
  Next
 Endif
Endif
If LEG1="" & LEG2=""
 # Table non copiée suite à une erreur de paramétrage des législations
 OK = 0 : Call ECR_TRACE(mess(56,123,1)-[F:ATB]CODFIC-":"-mess(69,127,1),1) From GESECRAN
Endif
Return

$COPIE_LEG
For I=1 To NBCLE
 Assign "[F:F4]"+CLE(I) With evalue("[F:F1]"+CLE(I))
Next
Read [F:F4] =
If !fstat
 If OK=1  & [F:ATB]CODFIC = "TABFOR"
  Gosub TABFOR
 Else
  If TBLEG(NBCOP) = [F:ATB]CODFIC
   If evalue("dim([F:F1]"+LEG1+")") & evalue("dim([F:F4]"+LEG1+")")  & evalue("[F:F1]"+LEG1) <> evalue("[F:F4]"+LEG1)
    LEG0 = ""
    For X=1 To NBCLE
     LEG0 -= num$(evalue("[F:F4]"+CLE(X)))
    Next X
    If TBCOPLEG(NBCOP) = ""
     TBCOPLEG(NBCOP) = TBCOP(NBCOP)
     Call ECR_TIME(mess(56,123,1)-[F:ATB]CODFIC) From DOSSUB
    Endif
    Call ECR_TRACE(func AFNC.MES3(mess(78,127,1),LEG0,"'"+evalue("[F:F1]"+LEG1)+"'","'"+evalue("[F:F4]"+LEG1)+"'"),-1) From GESECRAN
   Endif
  Else
   If evalue("dim([F:F3]"+LEG2+")") & evalue("dim([F:F5]"+LEG2+")")
    For I=1 To NBCHP
     If pat(CHPS(I),"!*") <1
      Assign "[F:F3]"+CHPS2(I) With evalue(CHPS(I))
      Assign "[F:F5]"+CHPS2(I) With evalue(CHPS(I))
     Else
      Assign "[F:F3]"+CHPS2(I) With evalue("[F:F1]"+CHPS(I))
      Assign "[F:F5]"+CHPS2(I) With evalue("[F:F1]"+CHPS(I))
     Endif
    Next I
    Read [F:F5] =
    If !fstat
     Read [F:F3] =
     If !fstat
      LEG0 = ""
      For X=1 To NBCHP
       LEG0 -= num$(evalue("[F:F3]"+CHPS2(X)))
      Next X
      If evalue("[F:F3]"+LEG2) <> evalue("[F:F5]"+LEG2)
       If TBCOPLEG(NBCOP) = ""
        TBCOPLEG(NBCOP) = TBCOP(NBCOP)
        Call ECR_TIME(mess(56,123,1)-[F:ATB]CODFIC) From DOSSUB
       Endif
       Call ECR_TRACE(func AFNC.MES3(mess(78,127,1),LEG0,"'"+evalue("[F:F3]"+LEG2)+"'","'"+evalue("[F:F5]"+LEG2)+"'"),-1)  From GESECRAN
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
 OK = 0
Else
 Case [F:ATB]CODFIC
  When "TABFOR" : # Car Champ Leg dimensionné
  When Default :
   If TBLEG(NBCOP) <> [F:ATB]CODFIC
    For I=1 To NBCHP
     If pat(CHPS(I),"!*") <1
      Assign "[F:F3]"+CHPS2(I) With evalue(CHPS(I))
     Else
      Assign "[F:F3]"+CHPS2(I) With evalue("[F:F1]"+CHPS(I))
     Endif
    Next I
    If OK=1
     Read [F:F3] =
     If !fstat
      If evalue("dim([F:F3]"+LEG2+")")>0 & evalue("[F:F3]"+LEG2) <> ""
       If !find(evalue("[F:F3]"+LEG2),[L]DOSLEG(0..dim(DOSLEG)-1)) : OK = 0 Endif
       If find(evalue("[F:F3]"+LEG2),[L]DOSLEGREF(0..dim(DOSLEGREF)-1)) & NB_RECORD>0  & !FONCT : OK = 0 : Endif
      Else
       If [L]AJOUT <> 2 & NB_RECORD >0  : OK = 0 : Endif
      Endif
     Endif
    Endif
   Else
    If [L]ISMULTILEG>0
     If evalue("dim([F:F1]"+LEG1+")")>0 & evalue("[F:F1]"+LEG1)<>""
      If !find(evalue("[F:F1]"+LEG1),[L]DOSLEG(0..dim(DOSLEG)-1)) : OK = 0 Endif
      If find(evalue("[F:F1]"+LEG1),[L]DOSLEGREF(0..dim(DOSLEGREF)-1)) & NB_RECORD>0  & !FONCT : OK = 0 : Endif
     Else
      If [L]AJOUT <> 2  & NB_RECORD >0 : OK = 0 : Endif
     Endif
    Else
     If evalue("dim([F:F1]"+LEG1+")")
      If evalue("[F:F1]"+LEG1)="">0
       If find(LEG1,CHPS(1..NBCHP))>0
        # on regarde si il existe un enreg avec la leg en FRA dnas le dossier de destination
        For I=1 To NBCHP
         If CHPS(I)=LEG1
          Assign "[F:F5]"+CHPS(I) With [L]DOSLEG(0)
         Else
          If pat(CHPS(I),"!*") <1
           Assign "[F:F5]"+CHPS(I) With evalue(CHPS(I))
          Else
           Assign "[F:F5]"+CHPS(I) With evalue("[F:F1]"+CHPS(I))
          Endif
         Endif
        Next I
        Read [F:F5] =
        If !fstat
         OK = 0
        Endif
        # on regarde si il existe un enreg avec la leg en FRA dnas le dossier de reference
        For I=1 To NBCHP
         If CHPS(I)=LEG1
          Assign "[F:F3]"+CHPS(I) With [L]DOSLEG(0)
         Else
          If pat(CHPS(I),"!*") <1
           Assign "[F:F3]"+CHPS(I) With evalue(CHPS(I))
          Else
           Assign "[F:F3]"+CHPS(I) With evalue("[F:F1]"+CHPS(I))
          Endif
         Endif
        Next I
        Read [F:F3] =
        If !fstat
         OK = 0
        Endif
       Else
        If evalue("dim([F:F1]"+LEG1+")")>0 & evalue("[F:F1]"+LEG1)<>""
         If !find(evalue("[F:F1]"+LEG1),[L]DOSLEG(0..dim(DOSLEG)-1)) : OK = 0 Endif
         If find(evalue("[F:F1]"+LEG1),[L]DOSLEGREF(0..dim(DOSLEGREF)-1)) & NB_RECORD>0 & !FONCT : OK = 0 : Endif
        Else
         If [L]AJOUT <> 2  & NB_RECORD >0 : OK = 0 : Endif
        Endif
       Endif
      Else
       If evalue("dim([F:F1]"+LEG1+")")>0 & evalue("[F:F1]"+LEG1)<>""
        If !find(evalue("[F:F1]"+LEG1),[L]DOSLEG(0..dim(DOSLEG)-1)) : OK = 0 Endif
        If find(evalue("[F:F1]"+LEG1),[L]DOSLEGREF(0..dim(DOSLEGREF)-1)) & NB_RECORD>0  & !FONCT : OK = 0 : Endif
       Else
        If [L]AJOUT <> 2  & NB_RECORD >0 : OK = 0 : Endif
       Endif
      Endif
     Else
      If [L]AJOUT <> 2  & NB_RECORD >0 : OK = 0 : Endif
     Endif
    Endif
   Endif
 Endcase
Endif
Return

$TABFOR
If [F1]FORTYP = 21 & GPRODUIT =0
 J=0 :  Raz WLEG : Raz WFOR
 For I=0 To dim([F1]LEG)-1
  If  [F1]LEG(I) = "" or find([F1]LEG(I),[L]DOSLEG(0..dim(DOSLEG)-1))
   If [F1]LEG(I)="" & [F1]FORFOR(I)="" : Break : Endif
   WLEG(J) = [F1]LEG(I)
   If [L]ISMULTILEG=0 & WLEG(J) ="" & [F1]FORFOR(I)<>""
    WLEG(J) = DOSLEG(0)
   Endif
   WFOR(J) = [F1]FORFOR(I)
   J+=1
  Endif
 Next
 [F2] = [F1]
 Read [F:F2] =
 If !fstat
  JJ =0 : II = 0
  For I=0 To dim([F2]LEG)-1
   If [F2]LEG(I)="" & [F2]FORFOR(I)="" : Break : Endif
   JJ +=1
  Next
  For I=0 To J-1
   K = find(WLEG(I) ,[F2]LEG(0..dim([F2]LEG)-1))
   If !K
    [F2]LEG(JJ+II)    = WLEG(I)
    [F2]FORFOR(JJ+II) = WFOR(I)
    II+=1
   Elsif [F2]FORFOR(K)=""
    [F2]FORFOR(K-1) = WFOR(I)
   Endif
  Next
  Rewrite [F2]
  If fstat
   Call ERREUR([F:ATB]CODFIC,2) From DOSDIC
  Endif
  NBREC += 1
 Endif
Endif
Return

$ERRFIC
ERN = errn
GMESSAGE = mess(6,123,1)-num$(ERN)-":"-errmes$(ERN)-errm+"|"
Call ECR_TRACE(GMESSAGE ,1) From GESECRAN
GMESSAGE  = ""
OK = 0
Resume

$ERREUR
GMESSAGE = mess(6,123,1)-num$(errn)-errmes$(errn)-errm-errp-mess(61,100,1)-num$(errl) : # Erreur x ligne no y
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GMESSAGE = ""
Resume

Subprog SETLIEN(NBCHP,CHPS,LIEN)
Variable Integer NBCHP
Variable Char CHPS()(1..)
Value    Char LIEN
Local Integer I , J
Raz CHPS, NBCHP
While LIEN<>""
 I = instr(1,LIEN,";")
 NBCHP += 1
 If I
  CHPS(NBCHP) = left$(LIEN,I-1)
  LIEN = right$(LIEN,I+1)
 Else
  CHPS(NBCHP) = LIEN
  LIEN = ""
 Endif
Wend
End

Funprog CHAMPLEG(TABLE)
Value Char TABLE
Local Char CODZON(20)
For [ATZ3]CODZONE Where CODFIC=TABLE & CHPLEG =2
 [L]CODZON  =  [F:ATZ3]CODZONE
 Break
Next
End [L]CODZON

######################################################################################################
Subprog WRITE_AXX(DOSSIER,DOSCOP,DOSREF,TABLE,ISMULTILEG,LEG1,SAVLEG,TBLANAXX,NBLANAXX,OKAXX)
Value Char    DOSSIER
Value Char    DOSCOP
Value Char    DOSREF
Value Char    TABLE
Value Integer ISMULTILEG
Value Char    LEG1
Value Char    SAVLEG
Value Char    TBLANAXX
Value Integer NBLANAXX
Variable Char OKAXX


Local File =[L]DOSSIER+".AMSKPAR" [AMP]
Local File =[L]DOSSIER+".ATABZON" [ATZ2]
Local File =[L]DOSCOP+".ACTIV"    [ACV2]

Local Char    TEST(250),TZONE(80)
Local Char    CLECUR1(250),CLECUR2(250),ZONE(250),TABLE1(250)
Local Char    WCLECUR1(250),WCLECUR2(250),WZONE(250),WTABLE1(250),WWCLECUR1(250),WWCLECUR2(250)

Local Integer DIM1,DIM2,OK,II

If filinfo(filpath("FIL","ATEXTRA","fde",[L]DOSSIER),0)>=0
 OK = 1
 If filinfo(filpath("FIL","ATEXTRA","fde",[L]DOSCOP),0)>=0
  Local File =[L]DOSCOP+".ATEXTRA"  [AXX]
 Elsif filinfo(filpath("FIL","ATEXTRA","fde",[L]DOSREF),0)>=0
  Local File =[L]DOSREF+".ATEXTRA"  [AXX]
 Elsif filinfo(filpath("FIL","ATEXTRA","fde",GDOSX3),0)>=0
  Local File =GDOSX3+".ATEXTRA" [AXX]
 Else
  OK = 0
 Endif
 If OK =1
  Onerrgo ERR
  Default File [F2]
  For [ATZ]CODZONE Where CODFIC=TABLE & find(CODTYP,"AXX","AX1","AX2","AX3")
   OK = 0
   TZONE = [ATZ]CODZONE
   For [AMP] Where TYPAFF = 2 & CODAFF = TABLE & CODZON = [ATZ]CODZONE
    OK =1
    Case [AMP]CODPAR
     When "CLECUR1"  : CLECUR1 = [AMP]VALPAR
     When "CLECUR2"  : CLECUR2 = [AMP]VALPAR
     When "ZONE"     : ZONE    = [AMP]VALPAR
     When "TABLE1"   : TABLE1  = [AMP]VALPAR
    Endcase
   Next
   If OK
    REPET = 0
    If [ATZ]DIME>0
     DIM1 = [F:ATZ]DIME
    Elsif [F:ATZ]CODACT <> ""
     Read [ACV]CODACT = CODACT
     If !fstat
      If [F:ACV]DIMFIL>0 & [F:ACV]DIME>0 & [F:ACV]DIMMAX>0
       REPET = min(max([F:ACV]DIMFIL,[F:ACV]DIME),[F:ACV]DIMMAX)
      Elsif ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
       REPET = max([F:ACV]DIMFIL,[F:ACV]DIME)
      Endif
      DIM1 = max(REPET,1)
     Endif
    Endif
    REPET = 0
    Read [ATZ2]CODZONE = [F:ATZ]CODFIC;[F:ATZ]CODZONE
    If !fstat
     If [ATZ2]DIME>0
      DIM2 = [F:ATZ]DIME
     Elsif [F:ATZ2]CODACT <> ""
      Read [ACV2]CODACT = CODACT
      If !fstat
       If [F:ACV2]DIMFIL>0 & [F:ACV2]DIME>0 & [F:ACV2]DIMMAX>0
        REPET = min(max([F:ACV2]DIMFIL,[F:ACV2]DIME),[F:ACV2]DIMMAX)
       Elsif ([F:ACV2]DIMFIL<>0 | [F:ACV2]DIME<>0)
        REPET = max([F:ACV2]DIMFIL,[F:ACV2]DIME)
       Endif
       DIM2 = max(REPET,1)
      Endif
     Endif
    Endif
    If [L]ISMULTILEG=0 & TABLE<>"TABFOR" &  LEG1<>"" & evalue("dim([F:F2]"+LEG1+")")>0
     Local Char SAVAXXLEG(20),WTEXTMONO(80)
     Assign "[L]SAVAXXLEG" With evalue("[F:F2]"+LEG1)
    Endif
    DIMENSION = min(DIM1,DIM2)
    If DIMENSION =0 : DIMENSION =1 : Endif
    For indice=0 To DIMENSION-1
     nolign = indice+1
     If CLECUR1 <> "" : WCLECUR1 = num$(evalue(CLECUR1)) : Endif
     If CLECUR2 <> "" : WCLECUR2 = num$(evalue(CLECUR2)) : Endif
     If ZONE    <> "" : WZONE    = num$(evalue(ZONE))    : Endif
     If TABLE1  <> "" : WTABLE1  = num$(evalue(TABLE1))  : Endif
     If [L]ISMULTILEG=0 & TABLE<>"TABFOR" &  LEG1<>"" & evalue("dim([F:F2]"+LEG1+")")>0
      Assign "[F:F2]"+LEG1 With SAVLEG
      If CLECUR1 <> "" : WWCLECUR1 = num$(evalue(CLECUR1)) : Endif
      If CLECUR2 <> "" : WWCLECUR2 = num$(evalue(CLECUR2)) : Endif
     Endif
     If OK
      For II=0 To NBLANAXX-1
       Read [AXX]AXX0 = WTABLE1;WZONE;TBLANAXX(II);WCLECUR1;WCLECUR2
       If !fstat
        Gosub WRITE_AXX2
       Else
        If [L]ISMULTILEG=0 & TABLE<>"TABFOR" &  LEG1<>"" & evalue("dim([F:F2]"+LEG1+")")>0
         Read [AXX]AXX0 = WTABLE1;WZONE;TBLANAXX(II);WWCLECUR1;WWCLECUR2
         If !fstat
          WTEXTMONO  = [F:AXX]TEXTE
          Gosub WRITE_AXXMONO
         Endif
        Endif
       Endif
      Next
     Endif
     If [L]ISMULTILEG=0 & TABLE<>"TABFOR" &  LEG1<>"" & evalue("dim([F:F2]"+LEG1+")")>0
      Assign "[F:F2]"+LEG1 With SAVAXXLEG
     Endif
    Next
   Else
    OKAXX = TABLE-"("-TZONE-")"-"-->"-mess(68,127,1)-"(AMSKPAR)" : # PARAMèTRES inexistants
   Endif
  Next
  Onerrgo
 Endif
Endif
End

$ERR
OK=0
OKAXX = TABLE-"("-TZONE-")"-"-->"-errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-errm
Resume

$WRITE_AXX2
Read [AXX2]AXX0 = WTABLE1;WZONE;TBLANAXX(II);[F:AXX]IDENT1;[F:AXX]IDENT2
If !fstat
 [F:AXX2]TEXTE = [F:AXX]TEXTE
 Rewrite [F:AXX2]
 If fstat
  Call ERREUR([F:AXX]CODFIC-[F:AXX]ZONE-[F:AXX]LANGUE-[F:AXX]IDENT1-[F:AXX]IDENT2,2) From DOSDIC
 Endif
Else
 [F:AXX2] = [F:AXX]
 Write [AXX2]
 If fstat
  Call ERREUR([F:AXX]CODFIC-[F:AXX]ZONE-[F:AXX]LANGUE-[F:AXX]IDENT1-[F:AXX]IDENT2,1) From DOSDIC
 Endif
Endif
Return

$WRITE_AXXMONO
Read [AXX2]AXX0 = WTABLE1;WZONE;TBLANAXX(II);WCLECUR1;WCLECUR2
If fstat
 Raz [F:AXX2]
 [F:AXX2]CODFIC = WTABLE1
 [F:AXX2]LANGUE = TBLANAXX(II)
 [F:AXX2]IDENT1 = WCLECUR1
 [F:AXX2]TEXTE   =  WTEXTMONO
 [F:AXX2]IDENT2 = WCLECUR2
 [F:AXX2]ZONE = WZONE
 Write [F:AXX2]
 If fstat
  Call ERREUR(WTABLE1-WZONE-TBLANAXX(II)-WCLECUR1-WCLECUR2,1) From DOSDIC
 Endif
Endif
Return

################################################################
## La vérif des liens se fait après à cause des objets générés
################################################################

Subprog LIENS(DOSSIER,NBCOP,TBCOP)
Value Char DOSSIER
Variable  Integer NBCOP
Variable  Char    TBCOP()(1..)

Onerrgo ERREUR

Local Integer MAXLIEN
MAXLIEN = 30
Local Integer NBLIEN , NZLIEN(1..MAXLIEN) , NZCLE(1..MAXLIEN) , NBKEY , SUPCLE
Local Integer TYPLIEN(1..MAXLIEN) , OBLIEN(1..MAXLIEN)
Local Char    ZCLE(GLONAVA)(1..MAXLIEN,1..16) , ZKEY(GLONAVA)(1..16)
Local Char    LIEN(GLONAVA)(1..MAXLIEN) , ZLIEN(30)(1..MAXLIEN,0..16)
Local Integer I , J , K , T , Z , D , X , OK , ERR , SUPP , RW
Local Char    CHAINE(120) , CLE0(120) , ZONEL(120) , ZONEO(120)

Local File =[L]DOSSIER+".ATABLE"  [ATB]
Local File =[L]DOSSIER+".ATABZON" [ATZ]
Local File =[L]DOSSIER+".ATABIND" [ATI]

# 2) on vérifie les liens

If GINFO
 Call AFF_VLC(mess(71,125,1),"") From GESECRAN
 # Contrôle des liens
Endif
Call ECR_TIME(mess(71,125,1)) From DOSSUB

For I=1 To NBCOP

# Etablissement des liens
 NBLIEN = 0
 For [ATZ]CODZONE Where CODFIC=TBCOP(I) & LIEN<>"" & VERIF=2 & TBCOP(I)<>""
  If NBLIEN>=MAXLIEN : Break : Endif
  OK = 1
  If filinfo(filpath("FIL",[F:ATZ]LIEN,"fde",[L]DOSSIER),0)<0
   Read [ATB]CODFIC = [F:ATZ]LIEN
   If fstat
    OK = 0 : # C'est normal à cause des codes activités
   Elsif [F:ATB]TYPFIC<>3
    Call ECR_TRACE(TBCOP(I)-"=>"-[F:ATZ]LIEN-mess(73,125,1),1) From GESECRAN
#   Table inexistante
    OK = 0
   Endif
  Endif
  If OK
   NBLIEN += 1
   LIEN(NBLIEN)    = [F:ATZ]LIEN
   TYPLIEN(NBLIEN) = [F:ATZ]ANNUL
   OBLIEN(NBLIEN)  = [F:ATZ]OBLIG
   ZLIEN(NBLIEN,0) = [F:ATZ]CODZONE
   If [F:ATZ]EXPLIEN=""
    NZLIEN(NBLIEN) = 1
    ZLIEN(NBLIEN,1) = [F:ATZ]CODZONE
   Else
    CHAINE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
    NZLIEN(NBLIEN) = 0
    While CHAINE<>""
     K = instr(1,CHAINE,";")
     If K
      NZLIEN(NBLIEN) += 1
      ZLIEN(NBLIEN,NZLIEN(NBLIEN)) = left$(CHAINE,K-1)
      CHAINE = right$(CHAINE,K+1)
     Else
      NZLIEN(NBLIEN) += 1
      ZLIEN(NBLIEN,NZLIEN(NBLIEN)) = CHAINE
      CHAINE = ""
     Endif
    Wend
   Endif
   Read [ATI]NUMLIG(2) = [F:ATZ]LIEN;1
   CHAINE = [F:ATI]DESCRIPT
   NZCLE(NBLIEN) = 0
   While CHAINE<>""
    NZCLE(NBLIEN) += 1
    J = instr(1,CHAINE,"+")
    K = instr(1,CHAINE,"-")
    If    J & K  : J = min(J,K)
    Elsif K & !J : J = K
    Endif
    If J
     ZCLE(NBLIEN,NZCLE(NBLIEN)) = left$(CHAINE,J-1)
     CHAINE = right$(CHAINE,J+1)
    Else
     ZCLE(NBLIEN,NZCLE(NBLIEN)) = CHAINE
     CHAINE = ""
    Endif
   Wend
   If NZCLE(NBLIEN)<>NZLIEN(NBLIEN)
    Call ECR_TRACE(TBCOP(I)-"=>"-[F:ATZ]LIEN-mess(72,125,1),1) From GESECRAN
#   Erreur sur lien
    NBLIEN -= 1
   Endif
  Endif
 Next

# Parcours du fichier
 If NBLIEN>0
  If GINFO
   Call AFF_VLC(mess(71,125,1),mess(56,123,1)-TBCOP(I)) From GESECRAN
  Endif
# Table
  Call ECR_TIME(mess(56,123,1)-TBCOP(I)) From DOSSUB
  Local File =[L]DOSSIER+"."+TBCOP(I) [F0]
  Local File =[L]DOSSIER+"."+TBCOP(I) [F1]
  Read [ATI]NUMLIG(2) = TBCOP(I);1
  CHAINE = [F:ATI]DESCRIPT
  NBKEY = 0
  While CHAINE<>""
   NBKEY += 1
   J = instr(1,CHAINE,"+")
   K = instr(1,CHAINE,"-")
   If    J & K  : J = min(J,K)
   Elsif K & !J : J = K
   Endif
   If J
    ZKEY(NBKEY) = left$(CHAINE,J-1)
    CHAINE = right$(CHAINE,J+1)
   Else
    ZKEY(NBKEY) = CHAINE
    CHAINE = ""
   Endif
  Wend
  For K=1 To NBLIEN
   Gosub OUVFIC
  Next K
  Onerrgo ERRLIEN : # Y'a des erreurs à cause du mauvais remplissage du dico
  ERR = 0
  Trbegin [F0]
   For [F0]
    SUPP = 0
    RW   = 0
    For K=1 To NBLIEN
     Gosub DEFAUT
     T = evalue("type([F:F0]"+ZLIEN(K,0)+")")
     For D=1 To evalue("dim([F:F0]"+ZLIEN(K,0)+")")
      indice = D-1
      OK = 1
      Case T
       When 1,2,3,4,5,6,7,8,9 : If evalue("[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")")=0       : OK = 0 : Endif
       When 3                 : If evalue("[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")")=[0/0/0] : OK = 0 : Endif
       When Default           : If evalue("[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")")=""      : OK = 0 : Endif
      Endcase
      # On ne contrôle pas les liens sur les objets générés
      If find(LIEN(K),"AMSK","AWINDOW")
       If left$(evalue("[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")"),1)="W"
        OK = 0
       Endif
      Endif
      If OK
       CHAINE = ""
       For Z=1 To NZLIEN(K)
        If ZLIEN(K,Z) <> "[V]GSUPCLE"
         ZONEL = "[F:L"+num$(K)+"]"+ZCLE(K,Z)
         If ZLIEN(K,Z)>="A" & ZLIEN(K,Z)<"ZZZZZZZZZZ"
          ZONEO = "[F:F0]"+ZLIEN(K,Z)
         Else
          ZONEO = ZLIEN(K,Z)
         Endif
         Assign ZONEL With evalue(ZONEO)
         CHAINE -= num$(evalue(ZONEO))
        Else
         SUPCLE = NZLIEN(K)-1
        Endif
       Next Z
       If SUPCLE
        Assign "[G:L"+num$(K)+"]currind" With 1
        Assign "[G:L"+num$(K)+"]currlen" With SUPCLE
        SUPCLE = 0
       Else
        Assign "[G:L"+num$(K)+"]currind" With 1
        Assign "[G:L"+num$(K)+"]currlen" With 0
       Endif
       Read =
       If fstat
        Case TYPLIEN(K)
         When 1 : # Bloquant
          If OBLIEN(K)=2
           SUPP = 1
           Gosub TR_LIEN
           Break 2
          Else
           [F:F1] = [F:F0]
           Case T
            When 1,2,4,5,6,7,8,9 : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With 0
            When 3               : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With [0/0/0]
            When Default         : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With ""
           Endcase
           RW = 1
           Gosub TR_LIEN
          Endif
         When 2 : # Suppression
          SUPP = 1
          Gosub TR_LIEN
          Break 2
         When 3   : # RAZ
          [F:F1] = [F:F0]
          Case T
           When 1,2,4,5,6,7,8,9 : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With 0
           When 3               : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With [0/0/0]
           When Default         : Assign "[F:F0]"+ZLIEN(K,0)+"("+num$(D-1)+")" With ""
          Endcase
          RW = 1
          Gosub TR_LIEN
        Endcase
       Endif
      Endif
      If ERR : Break 3 : Endif : # On ne signale que la première erreur
     Next D
    Next K
    If SUPP
     Delete [F0]
    Elsif RW
     Rewrite [F0]
     If fstat
      [F:F0] = [F:F1]
      Delete [F0] =
     Endif
    Endif
   Next
  Commit
  Onerrgo
  For K=1 To NBLIEN
   Gosub FERME
  Next K
  Close Local File [F0] , [F1]
 Endif
Next I
Onerrgo
End

$TR_LIEN
CLE0 = ""
For X=1 To NBKEY
 CLE0 -= num$(evalue("[F:F0]"+ZKEY(X)))
Next X
Call ECR_TRACE(space$(10)-CLE0-ZLIEN(K,0)-"=>"-LIEN(K)-":"-CHAINE,0) From GESECRAN
Return

$ERRLIEN
ERR = errn
Call ECR_TRACE(TBCOP(I)-"=>"-LIEN(K)-errmes$(errn)-num$(errl)-errm,1) From GESECRAN
Resume

$OUVFIC
Case K
 When  1 : Local File =[L]DOSSIER+"."+LIEN(K) [L1]
 When  2 : Local File =[L]DOSSIER+"."+LIEN(K) [L2]
 When  3 : Local File =[L]DOSSIER+"."+LIEN(K) [L3]
 When  4 : Local File =[L]DOSSIER+"."+LIEN(K) [L4]
 When  5 : Local File =[L]DOSSIER+"."+LIEN(K) [L5]
 When  6 : Local File =[L]DOSSIER+"."+LIEN(K) [L6]
 When  7 : Local File =[L]DOSSIER+"."+LIEN(K) [L7]
 When  8 : Local File =[L]DOSSIER+"."+LIEN(K) [L8]
 When  9 : Local File =[L]DOSSIER+"."+LIEN(K) [L9]
 When 10 : Local File =[L]DOSSIER+"."+LIEN(K) [L10]
 When 11 : Local File =[L]DOSSIER+"."+LIEN(K) [L11]
 When 12 : Local File =[L]DOSSIER+"."+LIEN(K) [L12]
 When 13 : Local File =[L]DOSSIER+"."+LIEN(K) [L13]
 When 14 : Local File =[L]DOSSIER+"."+LIEN(K) [L14]
 When 15 : Local File =[L]DOSSIER+"."+LIEN(K) [L15]
 When 16 : Local File =[L]DOSSIER+"."+LIEN(K) [L16]
 When 17 : Local File =[L]DOSSIER+"."+LIEN(K) [L17]
 When 18 : Local File =[L]DOSSIER+"."+LIEN(K) [L18]
 When 19 : Local File =[L]DOSSIER+"."+LIEN(K) [L19]
 When 20 : Local File =[L]DOSSIER+"."+LIEN(K) [L20]
 When 21 : Local File =[L]DOSSIER+"."+LIEN(K) [L21]
 When 22 : Local File =[L]DOSSIER+"."+LIEN(K) [L22]
 When 23 : Local File =[L]DOSSIER+"."+LIEN(K) [L23]
 When 24 : Local File =[L]DOSSIER+"."+LIEN(K) [L24]
 When 25 : Local File =[L]DOSSIER+"."+LIEN(K) [L25]
 When 26 : Local File =[L]DOSSIER+"."+LIEN(K) [L26]
 When 27 : Local File =[L]DOSSIER+"."+LIEN(K) [L27]
 When 28 : Local File =[L]DOSSIER+"."+LIEN(K) [L28]
 When 29 : Local File =[L]DOSSIER+"."+LIEN(K) [L29]
 When 30 : Local File =[L]DOSSIER+"."+LIEN(K) [L30]
Endcase
Return

$DEFAUT
Case K
 When  1 : Default File [L1]
 When  2 : Default File [L2]
 When  3 : Default File [L3]
 When  4 : Default File [L4]
 When  5 : Default File [L5]
 When  6 : Default File [L6]
 When  7 : Default File [L7]
 When  8 : Default File [L8]
 When  9 : Default File [L9]
 When 10 : Default File [L10]
 When 11 : Default File [L11]
 When 12 : Default File [L12]
 When 13 : Default File [L13]
 When 14 : Default File [L14]
 When 15 : Default File [L15]
 When 16 : Default File [L16]
 When 17 : Default File [L17]
 When 18 : Default File [L18]
 When 19 : Default File [L19]
 When 20 : Default File [L20]
 When 21 : Default File [L21]
 When 22 : Default File [L22]
 When 23 : Default File [L23]
 When 24 : Default File [L24]
 When 25 : Default File [L25]
 When 26 : Default File [L26]
 When 27 : Default File [L27]
 When 28 : Default File [L28]
 When 29 : Default File [L29]
 When 30 : Default File [L30]
Endcase
Return

$FERME
Case K
 When  1 : Close Local File [L1]
 When  2 : Close Local File [L2]
 When  3 : Close Local File [L3]
 When  4 : Close Local File [L4]
 When  5 : Close Local File [L5]
 When  6 : Close Local File [L6]
 When  7 : Close Local File [L7]
 When  8 : Close Local File [L8]
 When  9 : Close Local File [L9]
 When 10 : Close Local File [L10]
 When 11 : Close Local File [L11]
 When 12 : Close Local File [L12]
 When 13 : Close Local File [L13]
 When 14 : Close Local File [L14]
 When 15 : Close Local File [L15]
 When 16 : Close Local File [L16]
 When 17 : Close Local File [L17]
 When 18 : Close Local File [L18]
 When 19 : Close Local File [L19]
 When 20 : Close Local File [L20]
 When 21 : Close Local File [L21]
 When 22 : Close Local File [L22]
 When 23 : Close Local File [L23]
 When 24 : Close Local File [L24]
 When 25 : Close Local File [L25]
 When 26 : Close Local File [L26]
 When 27 : Close Local File [L27]
 When 28 : Close Local File [L28]
 When 29 : Close Local File [L29]
 When 30 : Close Local File [L30]
Endcase
Return


###############################################################
###############################################################
###############################################################
## Tables diverses
###############################################################
###############################################################
Subprog DICDIV(DOSSIER,DOSCOP,DOSREF,DOSLEG,NBLEG,AJOUT,CRE,LEGREF,FONCT)
Value Char    DOSSIER
Value Char    DOSCOP
Value Char    DOSREF
Value Char    DOSLEG()(0..)
Value Integer NBLEG
Value Integer AJOUT
Value Integer CRE
Value Char    LEGREF()(0..)
Local Char CHAINE(80)

# Variable local pour le traitement des tables diverses
Local Integer OKLEG,SPEC,OLD,NEWREC
Local Integer STA1 , STA2 , ISMULTILEG
Local Char    CHAMP(20)

# Remplissage du dico des tables diverses
Call ECR_TIME(mess(15,125,1)-mess(75,125,1)-":"-mess(238,133,1)) From DOSSUB
# MAJ dictionnaire - Tables diverses

Local File =[L]DOSREF +".ATABTAB" [ADV]
Local File =[L]DOSCOP +".ATABDIV" [ADI]

Local File =[L]DOSSIER+".ATABTAB" [DADV]
Local File =[L]DOSSIER+".ATABDIV" [DADI]
If !CRE
 Local File =[L]DOSSIER+".ATEXTRA" [DAXX]
 Local File =[L]DOSCOP +".ATEXTRA" [CAXX]
 Local File =[L]DOSREF +".ATEXTRA" [RAXX]
Endif

Local Integer DIFFA(0..dim([F:ADV]COLALPTYP)-1)
Local Integer DIFFN(0..dim([F:ADV]COLNUMTYP)-1)

If clalev([F:ADA])=0 : Local File ADOSACT          [ADA] : Endif

[L]ISMULTILEG = func AFNC.ACVDOSACT(DOSSIER,"LEG")

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(75,125,1),"") From GESECRAN
Endif

For [ADV] Where FLGLEG = 2
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(75,125,1),num$([F:ADV]NUMTAB)) From GESECRAN
 Endif
 Trbegin [DADV]
  OLD = 0
  SPEC = 0
  Read [DADV]CODE = [F:ADV]NUMTAB
  If !fstat
   OLD = 1
   Call SPEC([F:DADV]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([L]DOSSIER,[F:ADV]CODACT,[F:ADV]MODULE,NEWREC) From DOSSUB
  If !SPEC

   If OLD & !NEWREC : # On le vire

    If !CRE
     Delete [DAXX] Where find(CODFIC,"ATABDIV","ATABTAB")<>0 & IDENT1=num$([F:ADV]NUMTAB)
     If fstat=1 : Call ERREUR("ATEXTRA"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif
    Endif
    Delete [DADI] Where NUMTAB=[F:ADV]NUMTAB
    If fstat=1 : Call ERREUR("ATABDIV"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif
    Delete [DADV] Where NUMTAB=[F:ADV]NUMTAB
    If fstat=1 : Call ERREUR("ATABTAB"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif

   Elsif NEWREC & !OLD

    Raz [F:DADV]

    [F:DADV] = [F:ADV]
    If !CRE
     Call COPTEXREF("ATABTAB","LNGDES",num$([F:ADV]NUMTAB),"")  From DOSDICDIV
     Call COPTEXREF("ATABTAB","SHODES",num$([F:ADV]NUMTAB),"")  From DOSDICDIV

     # Exigence 53267
     For K=0 To dim([F:ADV]COLALPTYP)-1
       Call COPTEXREF("ATABTAB","COLALPDES",num$([F:ADV]NUMTAB),num$(K)) From DOSDICDIV
     Next
     For K=0 To dim([F:ADV]COLNUMTYP)-1
       Call COPTEXREF("ATABTAB","COLNUMDES",num$([F:ADV]NUMTAB),num$(K)) From DOSDICDIV
     Next

    Endif
    Write [DADV]
    If fstat : Call ERREUR("ATABTAB"-num$([F:DADV]NUMTAB),1) From DOSDIC : Endif
    For [ADI]CODE Where NUMTAB=[F:ADV]NUMTAB
     If ([F:ADI]LEG = ""  | ( find([F:ADI]LEG,[L]DOSLEG(0..[L]NBLEG)) &  !find([F:ADI]LEG,LEGREF(0..dim(LEGREF)-1))) )
      [F:DADI] = [F:ADI]
      If [L]ISMULTILEG=0
       [F:DADI]LEG = [L]DOSLEG(0)
      Endif
      If !CRE
       Call COPTEXTRA("ATABDIV","LNGDES",num$([F:ADV]NUMTAB),[F:ADI]CODE)  From DOSDICDIV
       Call COPTEXTRA("ATABDIV","SHODES",num$([F:ADV]NUMTAB),[F:ADI]CODE)  From DOSDICDIV
      Endif
      Write [DADI]
      If fstat : Call ERREUR("ATABDIV"-num$([F:DADV]NUMTAB)-[F:ADI]CODE,1) From DOSDIC : Endif
     Endif
    Next ADI

   Elsif NEWREC & OLD

    Raz DIFFA
    Raz DIFFN


    For K=0 To dim([F:ADV]COLALPTYP)-1
     Read [RAXX]AXX0 = "ATABTAB";"COLALPDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
     If fstat or [F:RAXX]TEXTE=""
      STA1 = 0
     Else
      STA1 = 1
     Endif
     Read [DAXX]AXX0 = "ATABTAB";"COLALPDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
     If fstat or [F:DAXX]TEXTE=""
      STA2 = 0
     Else
      STA2 = 1
     Endif
     If STA1=0 & STA2<>0
      DIFFA(K) = -1
      Delete [DAXX]
      If fstat : Call ERREUR("ATEXTRA"-"ATABTAB"-"COLALPDES"-num$([F:DADV]NUMTAB)-num$(K),3) From DOSDIC : Endif
     Elsif STA1<>0 & STA2=0
      DIFFA(K) =  1
      Call COPTEXREF("ATABTAB","COLALPDES",num$([F:ADV]NUMTAB),num$(K)) From DOSDICDIV
     Endif
     [F:DADV]COLALPTYP(K)     = [F:ADV]COLALPTYP(K)
     [F:DADV]COLALPSUP(K)     = [F:ADV]COLALPSUP(K)
    Next K

    For K=0 To dim([F:ADV]COLNUMTYP)-1
     Read [RAXX]AXX0 = "ATABTAB";"COLNUMDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
     If fstat or [F:RAXX]TEXTE=""
      STA1 = 0
     Else
      STA1 = 1
     Endif
     Read [DAXX]AXX0 = "ATABTAB";"COLNUMDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
     If fstat or [F:DAXX]TEXTE=""
      STA2 = 0
     Else
      STA2 = 1
     Endif
     If STA1=0 & STA2<>0
      DIFFN(K) = -1
      Delete [DAXX]
      If fstat : Call ERREUR("ATEXTRA"-"ATABTAB"-"COLNUMDES"-num$([F:DADV]NUMTAB)-num$(K),3) From DOSDIC : Endif
     Elsif STA1<>0 & STA2=0
      DIFFN(K) =  1
      Call COPTEXREF("ATABTAB","COLNUMDES",num$([F:ADV]NUMTAB),num$(K)) From DOSDICDIV
     Endif

     [F:DADV]COLNUMTYP(K)     = [F:ADV]COLNUMTYP(K)
     [F:DADV]COLNUMSUP(K)     = [F:ADV]COLNUMSUP(K)
    Next K

    [F:DADV]CODACT  = [F:ADV]CODACT
    [F:DADV]UPDFLG  = [F:ADV]UPDFLG
    [F:DADV]LNGFLG  = [F:ADV]LNGFLG
    If [F:ADV]LNGFLG<>2 or [F:DADV]LNG=0
     [F:DADV]LNG = [F:ADV]LNG
    Endif
    [F:DADV]MODULE = [F:ADV]MODULE
    [F:DADV]FLGLEG = [F:ADV]FLGLEG
    [F:DADV]FLGSOC = [F:ADV]FLGSOC
    Rewrite [DADV]
    If fstat : Call ERREUR("ATABTAB"-num$([F:DADV]NUMTAB),2) From DOSDIC : Endif

    For [DADI]CODE Where NUMTAB=[F:ADV]NUMTAB
     Read [ADI]CODE = [F:DADI]NUMTAB ; [F:DADI]CODE

     For K=1 To dim([F:ADV]COLALPTYP)
      If    DIFFA(K-1)>0
       If !fstat
        Assign "[F:DADI]A"+num$(K) With evalue("[F:ADI]A"+num$(K))
       Else
        Assign "[F:DADI]A"+num$(K) With ""
       Endif
      Elsif DIFFA(K-1)<0
       Assign "[F:DADI]A"+num$(K) With ""
      Endif
     Next

     For K=1 To dim([F:ADV]COLNUMTYP)
      If    DIFFN(K-1)>0
       If !fstat
        Assign "[F:DADI]N"+num$(K) With evalue("[F:ADI]N"+num$(K))
       Else
        Assign "[F:DADI]N"+num$(K) With 0
       Endif
      Elsif DIFFN(K-1)<0
       Assign "[F:DADI]N"+num$(K) With 0
      Endif
     Next

     Rewrite [DADI]
     If fstat : Call ERREUR("ATABDIV"-num$([F:DADV]NUMTAB-[F:DADI]CODE),2) From DOSDIC : Endif
    Next

    For [ADI]CODE Where NUMTAB=[F:ADV]NUMTAB
     Read [DADI]CODE = [F:ADI]NUMTAB ; [F:ADI]CODE
     If fstat
      If ([F:ADI]LEG = "" and AJOUT=2)
&     or ( find([F:ADI]LEG,[L]DOSLEG(0..[L]NBLEG)) & (!find([F:ADI]LEG,LEGREF(0..dim(LEGREF)-1))))
&     or ( find([F:ADI]LEG,[L]DOSLEG(0..[L]NBLEG)) & FONCT )
       [F:DADI] = [F:ADI]
       If [L]ISMULTILEG=0
        [F:DADI]LEG = [L]DOSLEG(0)
       Endif
       If !CRE
        Call COPTEXTRA("ATABDIV","SHODES",num$([F:ADV]NUMTAB),[F:ADI]CODE)  From DOSDICDIV
        Call COPTEXTRA("ATABDIV","LNGDES",num$([F:ADV]NUMTAB),[F:ADI]CODE)  From DOSDICDIV
       Endif
       Write [DADI]
       If fstat : Call ERREUR("ATABDIV"-num$([F:DADV]NUMTAB)-[F:ADI]CODE,1) From DOSDIC : Endif
      Endif
     Else
      If ([F:ADI]LEG<>[F:DADI]LEG) & FONCT
       Call ECR_TRACE(func AFNC.MES3(mess(78,127,1),mess(56,123,1)-num$([F:ADI]NUMTAB)
&       -"("+[F:ADI]CODE+")","'"+[F:ADI]LEG+"'","'"+[F:DADI]LEG+"'"),-1) From GESECRAN
      Endif
     Endif
    Next
   Endif
  Endif
 Commit
Next

Close Local File [ADV] , [DADV]
Close Local File [ADI] , [DADI]
If !CRE
 Close Local File [DAXX] , [CAXX] , [RAXX]
Endif
End

######################################################################################
Subprog AM_DOSDES(VALEUR)
Variable Char    VALEUR()
Read [ADS]DOSSIER = VALEUR
If !fstat
 Gosub CHARGE_DEST
Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]LEG(0..[M]NBLEG-1)) From OBJDIV
If !mkstat
 Read [F:ADS]DOSSIER = [M]DOSORI
 If !fstat
  If !find(VALEUR,[F:ADS]DOSLEG(0..dim([F:ADS]DOSLEG)-1))
   GMESSAGE = mess(249,133,1)-":"-[M]DOSORI
   mkstat   = 2 : End
  Endif
 Endif
Endif
End

Subprog C_DOSORI(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_DOSORI(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_ORI
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call DOSORGDES([M]DOSORI,VALEUR) From DOSCONT
End

Subprog C_LEGD(VALEUR)
Variable Char    VALEUR()
If !find(VALEUR,[M]LEG(0..[M]NBLEG-1))
 GMESSAGE = mess(249,133,1)-[M]DOSORI : # Législation non gérée par le dossier
 mkstat =2 : End
Endif
End

Subprog AS_AJOUT(VALEUR)
Variable Integer VALEUR
#If func AFNC.ACVDOSACT([M]DOSDES,"LEG")=0
# mkstat = 1 : End
#Endif
End

