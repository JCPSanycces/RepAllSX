#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPORPJM
#######################################################################################
# METHODS linked to SPLD collection                                                   #
# Issue X3-5069/119370 - 2016-10-20 ALMON :                                           #
#                   1.Changes to Consolidate Planned Quantity and Stocking QTY        #
#                   2.Consolidate at budget level even when tasks selected to process #
#                     if driven from budgets.                                         #
#######################################################################################
# Issue X3-5348/119525 - 2016-10-31 ALMON : Begin Allow consolidation of PJMSALITMD at#
#                                           1. Project Item Level (New) "PJM"         #
#                                           2. Budget Item Level        "PJMBUD"      #
#                                           3. Task Item Level          "PJMTAS"      #
#######################################################################################
# Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Convert Planned Qty to 1st UOM      #
#                                           on subsequent Update of PJMSALITMD        #
#######################################################################################
# Issue X3-17297/120494 - 2016-12-20 ALMON : SUMMLVL variable replaced by class prop  #
#                                            Removed as parameter to various methods  #
#######################################################################################
$SPLD_INIT_TECH_PROP
#Value Integer LIN

  If this.SPLD(LIN) <> null Then
    this.SPLD(LIN).OPPCMP = this.OPPCMP
    If fmet this.ACTX.ACACHE.AFCY.AGETVALNUM(this.SALFCY, "WRHFLG") = [V]CST_AYES Then
      this.SPLD(LIN).STOFCY = this.SALFCY
    Else
      this.SPLD(LIN).STOFCY = AVOID.ACHAR
    Endif
  Endif
Return

#######################################################################################
$SPLD_AUTOMATION
#Variable Instance TECSPLDAUT Using C_TECSPLDAUT
#Local Integer ARET_VALUE

Local Integer ILINE
Local Date RTEEFD
Local Char PCCCOD(GLONPJCC)
Local Integer TASSUB, BUDSUB
Local Integer STTASSUB
Local Integer NZ
Local Integer B1
Local Integer LOK
Local Char LOGNAME (40)
Local Char SMESSAGE(250)
Local Integer UPDCLS
Local Integer OPPSUB, TSKSUB, OPESUB, RTESUB, BUDSUB
Local File PJMTSKCAT [PTC]
Local Integer BUDLVL
Local Char STPAE (GLONPBU) (1..)
Local Integer LVLNI(1..)
Local Char STPBUCOD (GLONPBU) (1..)
Local Char STTASCOD (GLONTAC) (1..)
#Local Char SUMMLVL (6)                 # ISSUE X3-5348/119525 - 2016-10-31 ALMON : BEGIN Document additional Paramter
                                        # Issue X3-17297/120494 - 2016-12-20 ALMON : SUMMLVL included in TECSPLDAUT
  # --------------------------------
# ISSUE X3-5348/119525 - 2016-10-31 ALMON : BEGIN Set Summary Level
# Issue X3-17297/120494 - 2016-12-20 ALMON : SUMMLVL variable replaced by class prop
  If TECSPLDAUT.SUMMLVL  = AVOID.ACHAR Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(465,2260,1), [V]CST_AERROR)
    Return
  Endif
# ISSUE X3-5348/119525 - 2016-10-31 ALMON : End
# Issue X3-17297/120494 - 2016-12-20 ALMON : END
  # --------------------------------
  # 1°) Preliminary checks
  If this.OPPSTATE = 4 Then #and this.OPPMOD <> 2 Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR) # Issue X3-81871 - 2018-04-13 by FGR : not 206
    Return
  Endif
  If this.OPPMOD = [V]CST_AYES Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(206,2260,1), mess(this.OPPMOD,1,1)), [V]CST_AERROR)
    Return
  Endif
  If TECSPLDAUT.TASCOD <> AVOID.ACHAR Then
    ILINE = fmet this.TAS_GET_INDEX(TECSPLDAUT.TASCOD)
    If ILINE < 1 Then
      [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(6,2260,1), TECSPLDAUT.TASCOD), [V]CST_AERROR)
      If TECSPLDAUT.INCLOG = [V]CST_AYES
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(6,2260,1), TECSPLDAUT.TASCOD),[V]CST_AWARNING)
      Endif
      Return
    Endif
  Else
    If TECSPLDAUT.PBUCOD <> AVOID.ACHAR Then
      ILINE = fmet this.BUD_GET_INDEX(TECSPLDAUT.PBUCOD)
      If ILINE < 1 Then
        [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(4,2260,1), TECSPLDAUT.PBUCOD), [V]CST_AERROR)
        If TECSPLDAUT.INCLOG = [V]CST_AYES
          [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(4,2260,1), TECSPLDAUT.PBUCOD),[V]CST_AWARNING)
        Endif
        Return
      Endif
    Endif
  Endif
  # -------------------------------- Testing Parent/Child Processing [ALMON]
  # Issue X3-21304/121072 - 2017-01-19 ALMON : Delete Project Level Entries
  If TECSPLDAUT.SUMMLVL = "PJM" Then
    If TECSPLDAUT.INCDAL = [V]CST_AYES Then
      If TECSPLDAUT.INCBUD = [V]CST_AYES Then
        [L]ARET_VALUE = fmet this.SPLD_DEL_ALL_LINES(4)
      Else
        If TECSPLDAUT.INCOPE = [V]CST_AYES Then
          [L]ARET_VALUE = fmet this.SPLD_DEL_ALL_LINES(2)
        Endif
        If [L]ARET_VALUE > [V]CST_AWARNING  Then
          Return
        Endif
        If TECSPLDAUT.INCITM = [V]CST_AYES Then
          [L]ARET_VALUE = fmet this.SPLD_DEL_ALL_LINES(3)
        Endif
      Endif
      If [L]ARET_VALUE > [V]CST_AWARNING  Then
        Return
      Endif
    Endif
  Endif
  # Issue X3-21304/121072 - 2017-01-19 ALMON : Delete Project Level Entries
  If TECSPLDAUT.TASCOD <> AVOID.ACHAR
    If TECSPLDAUT.INCALL = [V]CST_AYES
      [L]ARET_VALUE = fmet this.TAS_GET_FAMILY(TECSPLDAUT.TASCOD,STTASCOD)
      If [L]ARET_VALUE = [V]CST_AOK and maxtab(STTASCOD) > 0
        For B1 = 1 To maxtab(STTASCOD)
          TASSUB = find(STTASCOD(B1), this.TAS(1..maxtab(this.TAS)).TASCOD)
          If TASSUB > 0
          # ISSUE X3-5069/119370 - 2016-10-20 ALMON : Begin
          # Change reference from this.BUD to this.TAS
            If this.TAS(TASSUB) <> null and find(this.TAS(TASSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
              [L]ARET_VALUE = fmet this.SPLD_TASCOD_AUTOPROC(TASSUB,TECSPLDAUT,SPLDLOG) # Issue X3-17297/120494 - 2016-12-20 ALMON : SUMMLVL removed as param
          # ISSUE X3-5069/119370 - 2016-10-20 ALMON : End
            Else
              If TECSPLDAUT.INCLOG = [V]CST_AYES
                [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(345,2260,1), TECSPLDAUT.TASCOD),[V]CST_AWARNING)
              Endif
            Endif
          Endif
        Next B1
      Endif
    Else
      If this.TAS <> null
        TASSUB = find(TECSPLDAUT.TASCOD, this.TAS(1..maxtab(this.TAS)).TASCOD)
        If this.TAS(TASSUB) <> null and find(this.TAS(TASSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          # ISSUE X3-5348/119370 - 2016-10-20 ALMON : Begin Added SUMMLVL as a paramter
          [L]ARET_VALUE = fmet this.SPLD_TASCOD_AUTOPROC(TASSUB,TECSPLDAUT,SPLDLOG) # Issue X3-17297/120494 - 2016-12-20 ALMON : SUMMLVL removed as param
          # ISSUE X3-5348/119370 - 2016-10-20 ALMON : END
        Endif
      Endif
    Endif
  Else
    If TECSPLDAUT.PBUCOD <> AVOID.ACHAR
      If TECSPLDAUT.INCALL = [V]CST_AYES
        [L]ARET_VALUE = fmet this.BUD_GET_FAMILY(TECSPLDAUT.PBUCOD,STPBUCOD)
        If [L]ARET_VALUE = [V]CST_AOK and maxtab(STPBUCOD) > 0
          For B1 = 1 To maxtab(STPBUCOD)
            BUDSUB = find(STPBUCOD(B1), this.BUD(1..maxtab(this.BUD)).PBUCOD)
            If BUDSUB > 0
              If this.BUD(BUDSUB) <> null and find(this.BUD(BUDSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                # ISSUE X3-5348/119370 - 2016-10-20 ALMON : Begin Added SUMMLVL as a paramter
                [L]ARET_VALUE = fmet this.SPLD_BUDCODE_AUTOPROC(BUDSUB,TECSPLDAUT,SPLDLOG) # Issue X3-17297/120494 - 2016-12-20 ALMON : SUMMLVL removed as param
                # ISSUE X3-5348/119370 - 2016-10-20 ALMON : END
              Else
                If TECSPLDAUT.INCLOG = [V]CST_AYES
                  [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(316,2260,1), TECSPLDAUT.PBUCOD),[V]CST_AWARNING)
                Endif
              Endif
            Endif
          Next B1
        Endif
      Else
        If this.BUD <> null
          BUDSUB = find(TECSPLDAUT.PBUCOD, this.BUD(1..maxtab(this.BUD)).PBUCOD)
          If this.BUD(BUDSUB) <> null and find(this.BUD(BUDSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            [L]ARET_VALUE = fmet this.SPLD_BUDCODE_AUTOPROC(BUDSUB,TECSPLDAUT,SPLDLOG) # Issue X3-17297/120494 - 2016-12-20 ALMON : SUMMLVL removed as param
          Endif
        Endif
      Endif
    Else
        For BUDSUB = 1 To maxtab(this.BUD)
          If this.BUD(BUDSUB) <> null and find(this.BUD(BUDSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            [L]ARET_VALUE = fmet this.SPLD_BUDCODE_AUTOPROC(BUDSUB,TECSPLDAUT,SPLDLOG) # Issue X3-17297/120494 - 2016-12-20 ALMON : SUMMLVL removed as param
          Endif
        Next BUDSUB
    Endif
  Endif
Return

#######################################################################################
$SPLD_BUDCODE_AUTOPROC
#Variable Integer BUDSUB : PJMBUD Collection Subscript
#Variable Instance TECSPLDAUT Using C_TECSPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Char SBUDCOD(GLONPBU)
Local Integer ILINE

      If TECSPLDAUT.INCLOG = [V]CST_AYES
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(282,2260,1), this.BUD(BUDSUB).PBUCOD),[V]CST_AWARNING)
      Endif
      If TECSPLDAUT.INCTAS = [V]CST_AYES Then
        TASSUB = find(this.BUD(BUDSUB).PBUCOD, this.TAS(1..maxtab(this.TAS)).PBUCOD)
        While TASSUB > 0
          If this.TAS(TASSUB) <> null and find(this.TAS(TASSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.TAS(TASSUB).TASSTATE = 4 or this.TAS(TASSUB).TASSTATE = 9 Then
              [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(13,2260,1), this.TAS(TASSUB).TASCOD),[V]CST_AWARNING)
              # Break # Issue X3-21304/121072 - 2017-01-19 ALMON : Added Else instead of EndIf
            Else
            # Issue X3-21304/121072 - 2017-01-19 ALMON : Added Else Delete records based on products and operations
              If TECSPLDAUT.INCDAL = [V]CST_AYES Then
                If TECSPLDAUT.INCOPE = [V]CST_AYES Then
                  [L]ARET_VALUE = fmet this.BUD(BUDSUB).SPLD_DEL_ALL_LINES(2)
                  If [L]ARET_VALUE > [V]CST_AWARNING  Then
                    Return
                  Endif
                Endif
                If TECSPLDAUT.INCITM = [V]CST_AYES Then
                  [L]ARET_VALUE = fmet this.BUD(BUDSUB).SPLD_DEL_ALL_LINES(3)
                  If [L]ARET_VALUE > [V]CST_AWARNING  Then
                    Return
                  Endif
                Endif
              # endif
                For TASCOD = this.BUD(BUDSUB).PBUCOD, this.BUD(BUDSUB).PBUPAE
                  If TASCOD <> AVOID.ACHAR Then
                    ILINE = fmet this.BUD_GET_INDEX(TASCOD)
                    If ILINE > 0 Then
                      If TECSPLDAUT.INCOPE = [V]CST_AYES Then
                        [L]ARET_VALUE = fmet this.BUD(BUDSUB).SPLD_DEL_ALL_LINES(2)
                        If [L]ARET_VALUE > [V]CST_AWARNING  Then
                          Return
                        Endif
                      Endif
                      If TECSPLDAUT.INCITM = [V]CST_AYES Then
                        [L]ARET_VALUE = fmet this.BUD(BUDSUB).SPLD_DEL_ALL_LINES(3)
                        If [L]ARET_VALUE > [V]CST_AWARNING  Then
                          Return
                        Endif
                      Endif
                    Endif
                  Endif
                Next
              Endif
              # Issue X3-21304/121072 - 2017-01-19 ALMON : End
              Read [F:PTC]CTA0 = this.TAS(TASSUB).TCACOD # [ALMON] Start use Category Type not Task Type
              If !fstat
                If TECSPLDAUT.INCLOG = [V]CST_AYES
                  [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(283,2260,1), this.TAS(TASSUB).TASCOD),[V]CST_AWARNING)
                Endif
                #If ([F:PTC]TASTYP = 2 or [F:PTC]TASTYP = 3)
                  # ----- PROCESS OPERATIONS
                  If TECSPLDAUT.INCOPE = [V]CST_AYES
                    [L]ARET_VALUE = fmet this.SPLD_AUTOMATE_OPE(BUDSUB,TASSUB,TECSPLDAUT,SPLDLOG)
                  Else
                    If TECSPLDAUT.INCLOG = [V]CST_AYES
                      [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(mess(257,2260,1),[V]CST_AWARNING)
                    Endif
                  Endif
                  # ----- PROCESS PRODUCTS
                  If TECSPLDAUT.INCITM = [V]CST_AYES
                    [L]ARET_VALUE = fmet this.SPLD_AUTOMATE_ITM(BUDSUB,TASSUB,TECSPLDAUT,SPLDLOG)
                  Else
                    If TECSPLDAUT.INCLOG = [V]CST_AYES
                      [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(mess(346,2260,1),[V]CST_AWARNING)
                    Endif
                  Endif
                #Else
                #  If TECSPLDAUT.INCLOG = [V]CST_AYES
                #    [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(256,2260,1), num$([F:PTC]TASTYP)) ,[V]CST_AWARNING)
                #  Endif
                #Endif
              Else
                If TECSPLDAUT.INCLOG = [V]CST_AYES
                  [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(249,2260,1), this.TAS(TASSUB).TASCOD),[V]CST_AWARNING)
                Endif
              Endif
             Endif # Issue X3-21304/121072 - 2017-01-19 ALMON : Added Else instead of EndIf
            Else
              If TECSPLDAUT.INCLOG = [V]CST_AYES
                [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(254,2260,1), this.BUD(BUDSUB).PBUCOD),[V]CST_AWARNING)
              Endif
            Endif
          # --------------------------------
          STTASSUB = TASSUB #ALMON without STNE logic iteration remains in a loop
          TASSUB = find(this.BUD(BUDSUB).PBUCOD, this.TAS(TASSUB+1..maxtab(this.TAS)).PBUCOD)
          If TASSUB > 0
            TASSUB = STTASSUB + TASSUB
          Endif
        Wend
      Else
      # Process BUDLIG Only
        If TECSPLDAUT.INCBUD = [V]CST_AYES
          # ISSUE X3-5348/119525 - 2016-10-31 ALMON : BEGIN Add SUMMLVL Param #
          [L]ARET_VALUE = fmet this.SPLD_AUTOMATE_BUDLIG(BUDSUB,TECSPLDAUT,SPLDLOG) # Issue X3-17297/120494 - 2016-12-20 ALMON : SUMMLVL removed as param #
          # ISSUE X3-5348/119525 - 2016-10-31 ALMON : End #
        Endif
      Endif
  # --------------------------------
Return

#######################################################################################
$SPLD_TASCOD_AUTOPROC
#Variable Integer TASSUB : PJMBUD Collection Subscript
#Variable Instance TECSPLDAUT Using C_SPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Char TASCOD(GLONPBU)
Local Integer ILINE

    If this.TAS(TASSUB).TASSTATE <> 4 and this.TAS(TASSUB).TASSTATE <> 9 Then
      # [ALMON] Bypass Deleteing
      If TECSPLDAUT.INCDAL = [V]CST_AYES
        # Issue X3-21304/121072 - 2017-01-19 ALMON : Added Else Delete records based on products and operations
        If TECSPLDAUT.INCOPE = [V]CST_AYES Then
          [L]ARET_VALUE = fmet this.TAS(TASSUB).SPLD_DEL_ALL_LINES(2)
          If [L]ARET_VALUE > [V]CST_AWARNING  Then
            Return
          Endif
        Endif
        If TECSPLDAUT.INCITM = [V]CST_AYES Then
          [L]ARET_VALUE = fmet this.TAS(TASSUB).SPLD_DEL_ALL_LINES(3)
          If [L]ARET_VALUE > [V]CST_AWARNING  Then
            Return
          Endif
        Endif
        # Issue X3-21304/121072 - 2017-01-19 ALMON : END
      # endif
        For TASCOD = this.TAS(TASSUB).TASCOD, this.TAS(TASSUB).TASPAE
          If TASCOD <> AVOID.ACHAR Then
            ILINE = fmet this.TAS_GET_INDEX(TASCOD)
            If ILINE > 0 Then
              # Issue X3-21304/121072 - 2017-01-19 ALMON : Added Else Delete records based on products and operations
              If TECSPLDAUT.INCOPE = [V]CST_AYES Then
                [L]ARET_VALUE = fmet this.TAS(TASSUB).SPLD_DEL_ALL_LINES(2)
                If [L]ARET_VALUE > [V]CST_AWARNING  Then
                  Return
                Endif
              Endif
              If TECSPLDAUT.INCITM = [V]CST_AYES Then
                [L]ARET_VALUE = fmet this.TAS(TASSUB).SPLD_DEL_ALL_LINES(3)
                If [L]ARET_VALUE > [V]CST_AWARNING  Then
                  Return
                Endif
              Endif
              # Issue X3-21304/121072 - 2017-01-19 ALMON : END
            Endif
          Endif
        Next
      Endif #[ALMON] END

      If [L]ARET_VALUE > [V]CST_AWARNING  Then
        Return
      Endif
      If TECSPLDAUT.INCLOG = [V]CST_AYES
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(283,2260,1), this.TAS(TASSUB).TASCOD),[V]CST_AWARNING)
      Endif
      TASSUB = find(this.TAS(TASSUB).TASCOD, this.TAS(1..maxtab(this.TAS)).TASCOD)
      While TASSUB > 0
        If this.TAS(TASSUB) <> null and find(this.TAS(TASSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          Read [F:PTC]CTA0 = this.TAS(TASSUB).TCACOD # [ALMON] Start use Category Type not Task Type
          If !fstat
            If TECSPLDAUT.INCLOG = [V]CST_AYES
              [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(283,2260,1), this.TAS(TASSUB).TASCOD),[V]CST_AWARNING)
            Endif
            #If ([F:PTC]TASTYP = 2 or [F:PTC]TASTYP = 3)
              # ----- PROCESS OPERATIONS
              If TECSPLDAUT.INCOPE = [V]CST_AYES
              # ISSUE X3-5348/119525 - 2016-10-31 ALMON : BEGIN Add SUMMLVL Param #
                [L]ARET_VALUE = fmet this.SPLD_AUTOMATE_OPE(0,TASSUB,TECSPLDAUT,SPLDLOG)
              # ISSUE X3-5348/119525 - 2016-10-31 ALMON : End #
              Else
                If TECSPLDAUT.INCLOG = [V]CST_AYES
                  [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(mess(257,2260,1),[V]CST_AWARNING)
                Endif
              Endif
              # ----- PROCESS PRODUCTS
              If TECSPLDAUT.INCITM = [V]CST_AYES
              # ISSUE X3-5348/119525 - 2016-10-31 ALMON : BEGIN Add SUMMLVL Param #
                [L]ARET_VALUE = fmet this.SPLD_AUTOMATE_ITM(0,TASSUB,TECSPLDAUT,SPLDLOG)
              # ISSUE X3-5348/119525 - 2016-10-31 ALMON : End #
              Else
                If TECSPLDAUT.INCLOG = [V]CST_AYES
                  [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(mess(346,2260,1),[V]CST_AWARNING)
                Endif
              Endif
            #Else
            #  If TECSPLDAUT.INCLOG = [V]CST_AYES
            #    [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(256,2260,1), num$([F:PTC]TASTYP)) ,[V]CST_AWARNING)
            #  Endif
            #Endif
          Else
            If TECSPLDAUT.INCLOG = [V]CST_AYES
              [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(249,2260,1), this.TAS(TASSUB).TCACOD),[V]CST_AWARNING)
            Endif
          Endif
        Else
          If TECSPLDAUT.INCLOG = [V]CST_AYES
            [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(254,2260,1), this.TAS(TASSUB).PBUCOD),[V]CST_AWARNING)
          Endif
        Endif
        # --------------------------------
        STTASSUB = TASSUB #ALMON without STNE logic iteration remains in a loop
        TASSUB = find(this.TAS(TASSUB).TASCOD, this.TAS(TASSUB+1..maxtab(this.TAS)).PBUCOD)
        If TASSUB > 0
          TASSUB = STTASSUB + TASSUB
        Endif
      Wend
    Else
      If TECSPLDAUT.INCLOG = [V]CST_AYES
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(this.TAS(TASSUB).PBUCOD + " "+ mess(208,2260,1),[V]CST_AWARNING)
      Endif
    Endif
  # --------------------------------
Return

#######################################################################################
$SPLD_AUTOMATE_BUDLIG
#Variable Integer BUDSUB : PJMBUD Collection Subscript
#Variable Instance TECSPLDAUT Using C_SPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Char    TASCOD(GLONPBU)
Local Char    ITMREF(GLONITM)
Local Char    ITMDES1(GLONDES)
Local Integer ILINE
Local Integer LIGSUB
Local Decimal PARPRI
Local Decimal OPEQTY
Local Char    WRKPCCCOD(GLONPJCC)
Local Char    WRKCUR (GLONCUR)
Local Char    WRKUOM (GLONUOM)
Local Char    PARSAU (GLONUOM)

Local Char     EXTUOM (GLONUOM)
Local Char     PARSTU (GLONUOM)
Local Decimal  EXTQTY
Local Decimal  QTYSTU

    If this.BUD(BUDSUB).PBUSTATE <> 3 and this.BUD(BUDSUB).PBUSTATE <> 4 and this.BUD(BUDSUB).PBUSTATE <> 9 and this.BUD(BUDSUB).PBUIMP = [V]CST_AYES Then
      # Issue X3-21304/121072 - 2017-01-19 ALMON : Delete Only if called by PJMBUD
      If TECSPLDAUT.SUMMLVL = "PJMBUD" Then
        # [ALMON] Bypass Deleteing
        If TECSPLDAUT.INCDAL = [V]CST_AYES # delete related BUDLIGS
          [L]ARET_VALUE = fmet this.BUD(BUDSUB).SPLD_DEL_ALL_LINES(4)
          If [L]ARET_VALUE > [V]CST_AWARNING  Then
            Return
          Endif

        # endif
          For TASCOD = this.BUD(BUDSUB).PBUCOD, this.BUD(BUDSUB).PBUPAE
            If TASCOD <> AVOID.ACHAR Then
              ILINE = fmet this.BUD_GET_INDEX(TASCOD)
              If ILINE > 0 Then
                [L]ARET_VALUE = fmet this.BUD(BUDSUB).SPLD_DEL_ALL_LINES(4)
                If [L]ARET_VALUE > [V]CST_AWARNING  Then
                  Break
                Endif
              Endif
            Endif
          Next
        Endif #[ALMON] END

        If [L]ARET_VALUE > [V]CST_AWARNING  Then
          Return
        Endif
      Endif
      # Issue X3-21304/121072 - 2017-01-19 ALMON : END
      If TECSPLDAUT.INCLOG = [V]CST_AYES
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(283,2260,1), this.BUD(BUDSUB).PBUCOD),[V]CST_AWARNING)
      Endif
      LIGSUB = find(this.BUD(BUDSUB).PBUCOD, this.BUD(BUDSUB).BUDLIG(1..maxtab(this.BUD(BUDSUB).BUDLIG)).PBUCOD)
      While LIGSUB > 0
        If this.BUD(BUDSUB) <> null and find(this.BUD(BUDSUB).BUDLIG(LIGSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          OPEQTY = this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBQTY
          QTYSTU = this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBQTY
          EXTUOM = this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBU
          EXTQTY = this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBQTY
          PCCCOD = this.BUD(BUDSUB).BUDLIG(LIGSUB).PCCCOD
          PARSEQ = this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBSEQ
          # -------------------
          [L]ARET_VALUE = fmet this.SPLD_IS_OPE_SALEABLE(this.OPEDEFFCY,PCCCOD,ITMREF)
          # -------------------
          If [L]ARET_VALUE = [V]CST_AOK and ITMREF <> AVOID.ACHAR Then
            [L]ARET_VALUE = fmet this.SPLD_GET_ITMMASTER(ITMREF, ITMDES1, PARSAU, PARPRI, PARSTU)

            If [L]ARET_VALUE = [V]CST_AOK and ITMREF <> AVOID.ACHAR Then
              If PARSAU = AVOID.ACHAR
                PARSAU = this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBU
              Endif
              If PARSAU <> this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBU
                Call CONVERT_QTY(this.ACTX, this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBU, PARSAU, OPEQTY) From TRTX3_SYRA
                If TECSPLDAUT.INCLOG = [V]CST_AYES
                  [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(260,2260,1), num$(this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBQTY)) ,0)
                Endif
              Endif
              If PARSTU = AVOID.ACHAR
                PARSTU = this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBU
              Endif
              If PARSTU <> this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBU
                Call CONVERT_QTY(this.ACTX, this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBU, PARSTU, QTYSTU) From TRTX3_SYRA
                If TECSPLDAUT.INCLOG = [V]CST_AYES
                  [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(260,2260,1), num$(this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBQTY)) ,0)
                Endif
              Endif
              If [L]ARET_VALUE = [V]CST_AOK
          # ISSUE X3-5348/119525 - 2016-10-31 ALMON : BEGIN Update depending on Project or Budget Summarization #
                If TECSPLDAUT.SUMMLVL = "PJMBUD" Then
                  WRKORI = 4
                  [L]ARET_VALUE = fmet this._SPLD_UPD_BUDLIN(WRKORI, BUDSUB, this.BUD(BUDSUB).PBUCOD, ITMREF, ITMDES1,OPEQTY,PARSAU,PARPRI, PARSTU, QTYSTU, EXTUOM, EXTQTY, this.BUD(BUDSUB).BUDLIG(
& LIGSUB).PLBSEQ,this.BUD(BUDSUB).BUDLIG(LIGSUB).SPLDREF,TECSPLDAUT, SPLDLOG)
                Endif
                If TECSPLDAUT.SUMMLVL = "PJM" Then
                  WRKORI = 4
                  [L]ARET_VALUE = fmet this._SPLD_UPD_PJMLIN(WRKORI, BUDSUB, ITMREF, ITMDES1,OPEQTY,PARSAU,PARPRI, PARSTU, QTYSTU, EXTUOM, EXTQTY, this.BUD(BUDSUB).BUDLIG(
& LIGSUB).PLBSEQ,this.BUD(BUDSUB).BUDLIG(LIGSUB).SPLDREF,TECSPLDAUT, SPLDLOG)
                Endif
          # ISSUE X3-5348/119525 - 2016-10-31 ALMON : End #
              Endif
            Endif
          Endif
        Else
          If TECSPLDAUT.INCLOG = [V]CST_AYES
            [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(254,2260,1), this.BUD(BUDSUB).PBUCOD),[V]CST_AWARNING)
          Endif
        Endif
        # --------------------------------
        STNE = LIGSUB #ALMON without STNE logic iteration remains in a loop
        LIGSUB = find(this.BUD(BUDSUB).PBUCOD, this.BUD(BUDSUB).BUDLIG(LIGSUB+1..maxtab(this.BUD(BUDSUB).BUDLIG)).PBUCOD)
        If LIGSUB > 0
          LIGSUB = STNE + LIGSUB
        Endif
      Wend
    Else
      If TECSPLDAUT.INCLOG = [V]CST_AYES
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(this.BUD(BUDSUB).PBUCOD + " "+ mess(208,2260,1),[V]CST_AWARNING)
      Endif
    Endif
  # --------------------------------
Return
#######################################################################################
$SPLD_DEL_TAS_LINES
#Value Char TASCOD ()
#Local Decimal ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = 0
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  # -------------------
  If ILINE < 1 Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(6,2260,1), TASCOD), [V]CST_AERROR)
    Return
  Endif
  If this.TAS(ILINE).TASSTATE = 4 Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(288,2260,1), mess(this.TAS(ILINE).TASSTATE,2250,1)), [V]CST_AERROR)
    Return
  Endif
  # -------------------
  If ILINE > 0 Then
    [L]ARET_VALUE = fmet this._SPLD_DEL_TAS_LINES(TASCOD)
  Endif
Return

#######################################################################################
$_SPLD_DEL_TAS_LINES
#Value Char TASCOD ()
#Local Decimal ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  # -------------------
  ILINE = fmet this.TAS_GET_INDEX(TASCOD)
  # -------------------
  If ILINE > 0 Then
    IISPARENT = fmet this.TAS_IS_PARENT(TASCOD)
    # -------------------
    If IISPARENT = [V]CST_AYES Then
      NI = find(TASCOD, this.BUD(1..maxtab(this.TAS)).TASCOD)
      While NI > 0
        If this.BUD(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE += fmet this.SPLD_DEL_TAS_LINES(this.TAS(NI).TASCOD)
        Endif
        NI1 = NI
        NI = find(BUDGET, this.TAS(NI+1..maxtab(this.TAS)).TASCOD)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
    # -------------------
    [L]ARET_VALUE += fmet this.TAS(ILINE).SPLD_DEL_ALL_LINES()
    # -------------------
  Endif
Return

#######################################################################################
$SPLD_DEL_BUD_LINES
#Value Char BUDGET ()
#Local Decimal ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = 0
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  # -------------------
  If ILINE < 1 Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(239,2260,1), BUDGET), [V]CST_AERROR)
    Return
  Endif
  If this.OPPSTATE <> 3 or this.OPPSTATE <> 4 or this.OPPSTATE <> 9 Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(242,2260,1), mess(this.BUD(ILINE).PBUSTATE,2251,1)), [V]CST_AERROR)
    Return
  Endif
  # -------------------
  If ILINE > 0 Then
    [L]ARET_VALUE = fmet this._SPLD_DEL_BUD_LINES(BUDGET)
  Endif
Return

#######################################################################################
$_SPLD_DEL_BUD_LINES
#Value Char BUDGET ()
#Local Decimal ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  # -------------------
  If ILINE > 0 Then
    IISPARENT = fmet this.BUD_IS_PARENT(BUDGET)
    # -------------------
    If IISPARENT = [V]CST_AYES Then
      NI = find(BUDGET, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE += fmet this._SPLD_DEL_BUD_LINES(this.BUD(NI).PBUCOD)
        Endif
        NI1 = NI
        NI = find(BUDGET, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
    # -------------------
    [L]ARET_VALUE += fmet this.BUD(ILINE).SPLD_DEL_ALL_LINES()
    # -------------------
  Endif
Return

#######################################################################################
$SPLD_AUTOMATE_OPE
# ISSUE X3-5348/119525 - 2016-10-31 ALMON : BEGIN Document additional Paramter #
#Variable Char SUMMLVL
# ISSUE X3-5348/119525 - 2016-10-31 ALMON : End
#Variable Integer BUDSUB - Budget Subscript
#Variable Integer TASSUB - Task Subscript
#Variable Instance TECSPLDAUT Using C_TECSPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Decimal DRATE
Local Integer ISTAT
Local Decimal WRKRATE
Local Decimal PARPRI
Local Decimal OPEQTY
Local Char WRKPCCCOD(GLONPJCC)
Local Char WRKCUR (GLONCUR)
Local Char WRKUOM (GLONUOM)
Local Char PARSAU (GLONUOM)
Local Char PARSTU (GLONUOM)
Local Char CUR (GLONCUR)
Local Char UOM (GLONUOM),OPEITM(1)
Local Char PCCCOD(GLONPJCC)
Local Char ITMREF(GLONITM)
Local Char ITMDES1(GLONDES)
Local Date RTEEFD
Local Integer NZ, WRKORI

Local Char     EXTUOM (GLONUOM)
Local Decimal  EXTQTY
Local Decimal  QTYSTU

  WRKORI = 2
  For NZ = 1 To maxtab(this.TAS(TASSUB).RTKO)
    If this.TAS(TASSUB).RTKO(NZ) <> null and find(this.TAS(TASSUB).RTKO(NZ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If TECSPLDAUT.INCLOG = [V]CST_AYES
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(284,2260,1), num$(this.TAS(TASSUB).RTKO(NZ).OPENUM), num$(this.TAS(TASSUB).RTKO(NZ).OPESPLNUM)),[V]CST_AWARNING)
      Endif
      # [ALMON] START
      #--------------
      # Get Task Oper Rate Effective Date - now incorporated into this.TAS_GET_COST_EFFECTIVE_RATE()
      OPEQTY = this.TAS(TASSUB).RTKO(NZ).EXTQTY
      QTYSTU = this.TAS(TASSUB).RTKO(NZ).EXTQTY
      [L]ARET_VALUE = fmet this.TAS_GET_COST_TYPE (this.TAS(TASSUB).TASCOD,this.TAS(TASSUB).RTKO(NZ).OPENUM, this.TAS(TASSUB).RTKO(NZ).OPESPLNUM, 0,CUR, UOM, PCCCOD)
      If [L]ARET_VALUE = [V]CST_AOK and PCCCOD <> AVOID.ACHAR
        If TECSPLDAUT.INCLOG = [V]CST_AYES
          [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(285,2260,1), PCCCOD),[V]CST_AWARNING)
        Endif
        WRKPCCCOD = PCCCOD
        [L]ARET_VALUE = fmet this.SPLD_IS_OPE_SALEABLE(this.OPEDEFFCY,PCCCOD,ITMREF)
        If [L]ARET_VALUE = [V]CST_AOK and ITMREF <> AVOID.ACHAR Then
          [L]ARET_VALUE = fmet this.SPLD_GET_ITMMASTER(ITMREF, ITMDES1, PARSAU, PARPRI, PARSTU)
        Endif
      Else
        If TECSPLDAUT.INCLOG = [V]CST_AYES
          [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(258,2260,1), this.TAS(TASSUB).TASCOD+":"+num$(this.TAS(TASSUB).RTKO(NZ).OPENUM)) ,[V]CST_AWARNING)
        Endif
      Endif
      If [L]ARET_VALUE = [V]CST_AOK and ITMREF <> AVOID.ACHAR Then
        If PARSAU = AVOID.ACHAR
          PARSAU = this.TAS(TASSUB).RTKO(NZ).OPEUOM2
        Endif
        If PARSAU <> this.TAS(TASSUB).RTKO(NZ).OPEUOM2
          Call CONVERT_QTY(this.ACTX, this.TAS(TASSUB).RTKO(NZ).OPEUOM2, PARSAU, OPEQTY) From TRTX3_SYRA
          If TECSPLDAUT.INCLOG = [V]CST_AYES
             [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(260,2260,1), num$(this.TAS(TASSUB).RTKO(NZ).EXTQTY)) ,0)
          Endif
        Endif
        If PARSTU = AVOID.ACHAR
          PARSTU = this.TAS(TASSUB).RTKO(NZ).OPEUOM2
        Endif
        If PARSTU <> this.TAS(TASSUB).RTKO(NZ).OPEUOM2
          Call CONVERT_QTY(this.ACTX, this.TAS(TASSUB).RTKO(NZ).OPEUOM2, PARSTU, QTYSTU) From TRTX3_SYRA
          If TECSPLDAUT.INCLOG = [V]CST_AYES
             [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(260,2260,1), num$(this.TAS(TASSUB).RTKO(NZ).EXTQTY)) ,0)
          Endif
        Endif
        If [L]ARET_VALUE = [V]CST_AOK
          EXTUOM = this.TAS(TASSUB).RTKO(NZ).OPEUOM2
          EXTQTY = this.TAS(TASSUB).RTKO(NZ).EXTQTY
          # ISSUE X3-5348/119525 - 2016-10-31 ALMON : BEGIN Update depending on Project, Budget or Task Summarization #
          If TECSPLDAUT.SUMMLVL = "PJMTAS"  Then
            [L]ARET_VALUE = fmet this._SPLD_UPD_TASLIN(WRKORI, TASSUB, this.TAS(TASSUB).PBUCOD, this.TAS(TASSUB).TASCOD,ITMREF, ITMDES1,OPEQTY,PARSAU,PARPRI, PARSTU, QTYSTU, EXTUOM, EXTQTY, this.TAS
& (TASSUB).RTKO(NZ).OPENUM,this.TAS(TASSUB).RTKO(NZ).SPLDREF,TECSPLDAUT, SPLDLOG)
          # Issue X3-5069/119370 - 2016-10-20 ALMON : Begin If from Budgets Consolidate to Budgets
          Endif
          If TECSPLDAUT.SUMMLVL = "PJMBUD" Then
            [L]ARET_VALUE = fmet this._SPLD_UPD_BUDLIN(WRKORI, BUDSUB, this.TAS(TASSUB).PBUCOD,ITMREF, ITMDES1,OPEQTY,PARSAU,PARPRI, PARSTU, QTYSTU, EXTUOM, EXTQTY, this.TAS(
& TASSUB).RTKO(NZ).OPENUM, this.TAS(TASSUB).RTKO(NZ).SPLDREF,TECSPLDAUT, SPLDLOG)
          Endif
          If TECSPLDAUT.SUMMLVL = "PJM" Then
            [L]ARET_VALUE = fmet this._SPLD_UPD_PJMLIN(WRKORI, BUDSUB, ITMREF, ITMDES1,OPEQTY,PARSAU,PARPRI, PARSTU, QTYSTU, EXTUOM, EXTQTY, this.TAS(
& TASSUB).RTKO(NZ).OPENUM,this.TAS(TASSUB).RTKO(NZ).SPLDREF, TECSPLDAUT, SPLDLOG)
          Endif
          # ISSUE X3-5348/119525 - 2016-10-31 ALMON : End #
          # Issue X3-5069/119370 - 2016-10-20 ALMON :  End
        Endif
      Endif
    Endif
  Next NZ
Return

#######################################################################################
$SPLD_AUTOMATE_ITM
#Variable Integer BUDSUB - Budget Subscript
#Variable Integer TASSUB - Task Subscript
#Variable Instance TECSPLDAUT Using C_TECSPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Decimal DRATE
Local Integer ISTAT
Local Decimal WRKRATE
Local Decimal PARPRI
Local Decimal OPEQTY
Local Char WRKPCCCOD(GLONPJCC)
Local Char WRKCUR (GLONCUR)
Local Char WRKUOM (GLONUOM)
Local Char PARSAU (GLONUOM)
Local Char CUR (GLONCUR)
Local Char UOM (GLONUOM),OPEITM(1)
Local Char PCCCOD(GLONPJCC)
Local Char ITMREF(GLONITM)
Local Char ITMDES1(GLONDES)
Local Date RTEEFD
Local Integer NZ, WRKORI

Local Char     EXTUOM (GLONUOM)
Local Char     PARSTU (GLONUOM)
Local Decimal  EXTQTY
Local Decimal  QTYSTU

  WRKORI = 3
  For NZ = 1 To maxtab(this.TAS(TASSUB).RITT)
    If this.TAS(TASSUB).RITT(NZ) <> null and find(this.TAS(TASSUB).RITT(NZ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If TECSPLDAUT.INCLOG = [V]CST_AYES
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(284,2260,1), num$(this.TAS(TASSUB).RITT(NZ).ITTSEQ), num$(this.TAS(TASSUB).RITT(NZ).ITMREF)),[V]CST_AWARNING)
      Endif
      # [ALMON] START
      #--------------
      # Get Task Product
      If this.TAS(TASSUB).RITT(NZ).SALITM = [V]CST_AYES and this.TAS(TASSUB).RITT(NZ).ITMREF <> AVOID.ACHAR Then
        OPEQTY = this.TAS(TASSUB).RITT(NZ).ITTQTY
        QTYSTU = this.TAS(TASSUB).RITT(NZ).ITTQTY
        ITMREF = this.TAS(TASSUB).RITT(NZ).ITMREF
        [L]ARET_VALUE = fmet this.SPLD_GET_ITMMASTER(ITMREF, ITMDES1, PARSAU, PARPRI, PARSTU)
        If [L]ARET_VALUE = [V]CST_AOK Then
          If PARSAU = AVOID.ACHAR
            PARSAU = this.TAS(TASSUB).RITT(NZ).UOM
          Endif
          If PARSAU <> this.TAS(TASSUB).RITT(NZ).UOM
            Call CONVERT_QTY(this.ACTX, this.TAS(TASSUB).RITT(NZ).UOM, PARSAU, OPEQTY) From TRTX3_SYRA
            If TECSPLDAUT.INCLOG = [V]CST_AYES
               [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(260,2260,1), num$(this.TAS(TASSUB).RITT(NZ).ITTQTY)) ,0)
            Endif
          Endif
          If PARSTU <> this.TAS(TASSUB).RITT(NZ).UOM
            Call CONVERT_QTY(this.ACTX, this.TAS(TASSUB).RITT(NZ).UOM, PARSTU, QTYSTU) From TRTX3_SYRA
            If TECSPLDAUT.INCLOG = [V]CST_AYES
               [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(260,2260,1), num$(this.TAS(TASSUB).RITT(NZ).ITTQTY)) ,0)
            Endif
          Endif
          If [L]ARET_VALUE = [V]CST_AOK
             EXTUOM = this.TAS(TASSUB).RITT(NZ).UOM
             EXTQTY = this.TAS(TASSUB).RITT(NZ).ITTQTY
          # ISSUE X3-5348/119525 - 2016-10-31 ALMON : BEGIN Update depending on Project, Budget or Task Summarization #
             If TECSPLDAUT.SUMMLVL = "PJMTAS" Then
              [L]ARET_VALUE = fmet this._SPLD_UPD_TASLIN(WRKORI, TASSUB, this.TAS(TASSUB).PBUCOD, this.TAS(TASSUB).TASCOD,ITMREF, ITMDES1,OPEQTY,PARSAU,PARPRI,PARSTU, QTYSTU, EXTUOM, EXTQTY,this.TAS(
& TASSUB).RITT(NZ).ITTSEQ, this.TAS(TASSUB).RITT(NZ).SPLDREF, TECSPLDAUT,SPLDLOG)
             Endif
             If TECSPLDAUT.SUMMLVL = "PJMBUD" Then
              # Issue X3-5069/119370 - 2016-10-20 ALMON : Begin If from Budgets Consolidate to Budgets
              [L]ARET_VALUE = fmet this._SPLD_UPD_BUDLIN(WRKORI, BUDSUB, this.TAS(TASSUB).PBUCOD, ITMREF, ITMDES1,OPEQTY,PARSAU,PARPRI, PARSTU, QTYSTU, EXTUOM, EXTQTY, this.TAS(TASSUB).RITT(NZ).ITTSEQ
& , this.TAS(TASSUB).RITT(NZ).SPLDREF,TECSPLDAUT, SPLDLOG)
             Endif
             If TECSPLDAUT.SUMMLVL = "PJM" Then
             #ISSUE X3-5069/119370 - 2016-10-20 ALMON : BEGIN If From BUDGETS CONSOLIDATE To BUDGETS
                [L]ARET_VALUE = fmet this._SPLD_UPD_PJMLIN(WRKORI, BUDSUB, ITMREF, ITMDES1,OPEQTY,PARSAU,PARPRI, PARSTU, QTYSTU, EXTUOM, EXTQTY,
& this.TAS(TASSUB).RITT(NZ).ITTSEQ, this.TAS(TASSUB).RITT(NZ).SPLDREF, TECSPLDAUT, SPLDLOG)
             Endif
            # ISSUE X3-5348/119525 - 2016-10-31 ALMON : End #
            # Issue X3-5069/119370 - 2016-10-20 ALMON : End
          Endif
        Endif
      Endif
    Endif
  Next NZ
Return

#######################################################################################
$_SPLD_UPD_TASLIN
#Variable Integer PARORI
#Variable Integer TASSUB
#Variable Char BUDCOD
#Variable Char TASCOD
#Variable Char ITMREF
#Variable Char ITMDES1
#Variable Decimal OPEQTY
#Variable Char PARSAU
#Variable Decimal PARPRI
#Variable Integer PARSEQ
#Variable Char SPLDREF
#Variable Instance TECSPLDAUT Using C_TECSPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Integer SPLSUB, SPLSUB1, SPLSUB2
Local Char    ORIUOM (GLONUOM) # Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Declare 1st Record UOM

    ORIUOM = AVOID.ACHAR # Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Initialize Original UOM
    If GUSER = "OLD" Then # Issue X3-25035 - 2017-02-23 ALMON : Temporary for Dual Testing
        SPLSUB = find(ITMREF,this.TAS(TASSUB).SPLD(1..maxtab(this.TAS(TASSUB).SPLD)).ITMREF)


        If SPLSUB > 0 and this.TAS(TASSUB).SPLD(SPLSUB) <> null and find(this.TAS(TASSUB).SPLD(SPLSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0  Then
            If TECSPLDAUT.INCOWRT = [V]CST_AYES Then
                # Issue X3-17297/120494 - 2016-12-20 ALMON : Do Not Overwite if PSONUM exists  #
                If this.TAS(TASSUB).SPLD(SPLSUB).PSONUM = AVOID.ACHAR Then
                  ORIUOM = this.TAS(TASSUB).SPLD(SPLSUB).EXTUOM # Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Set Original UOM to the first record
                  If this.TAS(TASSUB).SPLD(SPLSUB).ASTALIN = [V]CST_ALL
                    Raz this.TAS(TASSUB).SPLD(SPLSUB).QTY
                    Raz this.TAS(TASSUB).SPLD(SPLSUB).QTYSTU
                    Raz this.TAS(TASSUB).SPLD(SPLSUB).EXTQTY
                  Endif
                Else
                    If TECSPLDAUT.INCLOG = [V]CST_AYES
                      [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(495,2260,1), ITMREF) ,[V]CST_AWARNING)
                    Endif
                    Return
                Endif
                # Issue X3-17297/120494 - 2016-12-20 ALMON : END  #
            Else
                If this.TAS(TASSUB).SPLD(SPLSUB).ASTALIN <> [V]CST_ANEW Then # Issue X3-17297/120494 - 2016-12-20 ALMON : Only return if not new
                  Return
                Endif
            Endif
        Else
            If SPLSUB > 0 and (this.TAS(TASSUB).SPLD(SPLSUB).ASTALIN = [V]CST_ADEL or this.TAS(TASSUB).SPLD(SPLSUB).ASTALIN = [V]CST_ANEWDEL) Then
                SPLSUB2 = SPLSUB
                Repeat
                  SPLSUB1 = find(ITMREF, this.TAS(TASSUB).SPLD((SPLSUB2+1)..maxtab(this.TAS(TASSUB).SPLD)).ITMREF)
                  If SPLSUB1 > 0 and find(this.TAS(TASSUB).SPLD(SPLSUB1).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) <> 0 Then
                    SPLSUB2 += SPLSUB1
                    If this.TAS(TASSUB).SPLD(SPLSUB2) <> null and find(this.TAS(TASSUB).SPLD(SPLSUB2).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                      SPLSUB1 = SPLSUB2
                      Break
                    Endif
                  Else
                    Break
                  Endif
                Until 1=1
                If SPLSUB1 > 0 Then
                  # SPLSUB = SPLSUB + SPLSUB1 # Issue X3-21304/121072 - 2017-01-19 ALMON : Places Collection pointer outside of scope
                  SPLSUB = SPLSUB1
                Else
                  SPLSUB = fmet this.TAS(TASSUB).ADDLINE("SPLD",[V]CST_ALASTPOS)
                  If SPLSUB = [V]CST_ANOTDEFINED Then
                    If TECSPLDAUT.INCLOG = [V]CST_AYES
                      [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(433,2260,1), ITMREF, this.TAS(TASSUB).TASCOD) ,[V]CST_AWARNING)
                    Endif
                    Return
                  Endif
                Endif
            Else # Issue X3-21304/121072 - 2017-01-19 ALMON : Added Else instead of EndIf
                SPLSUB = fmet this.TAS(TASSUB).ADDLINE("SPLD",[V]CST_ALASTPOS)
                If SPLSUB = [V]CST_ANOTDEFINED Then
                  If TECSPLDAUT.INCLOG = [V]CST_AYES
                    [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(433,2260,1), ITMREF, this.TAS(TASSUB).TASCOD) ,[V]CST_AWARNING)
                  Endif
                  Return
                Endif
            Endif
        Endif
    Else
        # Issue X3-25035 - 2017-02-23 ALMON : Search for SPLD Records with Link
        [L]ARET_VALUE = fmet this.SPLD_FIND_TAS_LINE(TASSUB,SPLDREF,ITMREF,SPLSUB, TECSPLDAUT, SPLDLOG)
        If [L]ARET_VALUE = [V]CST_ANO Then
          Return
        Else
          If SPLSUB = 0 Then
            [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(500,2260,1), ITMREF, this.TAS(TASSUB).TASCOD) ,[V]CST_AERROR)
            Return
          Endif
        Endif
    Endif
    # Issue X3-25035 - 2017-02-23 ALMON : END
      # -------------------------------------------
# Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Convert Quantity if Original exists and the 2 UOM are different
        If ORIUOM <> AVOID.ACHAR and ORIUOM <> EXTUOM Then
          Call CONVERT_QTY(this.ACTX, EXTUOM, ORIUOM, EXTQTY) From TRTX3_SYRA
          If TECSPLDAUT.INCLOG = [V]CST_AYES Then
             [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(260,2260,1), num$(EXTQTY)) ,0)
          Endif
          EXTUOM = ORIUOM
        Endif
# Issue X3-5390/119524 - 2016-11-02 ALMON : End
      # ------------------------------------------
      this.TAS(TASSUB).SPLD(SPLSUB).TCHACTION = "SOLD"
      # ------------------------------------------
      this.TAS(TASSUB).SPLD(SPLSUB).ORI    = PARORI
      this.TAS(TASSUB).SPLD(SPLSUB).PRODGRPLVL = TECSPLDAUT.PRODGRPLVL   # 4 # Issue X3-107681 - 2018-09-11 ALMON
      this.TAS(TASSUB).SPLD(SPLSUB).OPPNUM = this.OPPNUM
      this.TAS(TASSUB).SPLD(SPLSUB).PBUCOD = this.TAS(TASSUB).PBUCOD
      this.TAS(TASSUB).SPLD(SPLSUB).TASCOD = this.TAS(TASSUB).TASCOD
      this.TAS(TASSUB).SPLD(SPLSUB).ITMREF = ITMREF
      this.TAS(TASSUB).SPLD(SPLSUB).ITMDES = ITMDES1
      this.TAS(TASSUB).SPLD(SPLSUB).QTY = this.TAS(TASSUB).SPLD(SPLSUB).QTY + OPEQTY
      #this.TAS(TASSUB).SPLD(SPLSUB).DOCQTY = this.TAS(TASSUB).SPLD(SPLSUB).DOCQTY + OPEQTY
      this.TAS(TASSUB).SPLD(SPLSUB).SAU     = PARSAU
      this.TAS(TASSUB).SPLD(SPLSUB).BASPRI  = PARPRI
      this.TAS(TASSUB).SPLD(SPLSUB).STU     = PARSTU
      # Issue X3-5069/119370 - 2016-10-20 ALMON : Begin Consolidate Stock nd Planed Qty
      this.TAS(TASSUB).SPLD(SPLSUB).QTYSTU += QTYSTU
      this.TAS(TASSUB).SPLD(SPLSUB).EXTQTY += EXTQTY
      # Issue X3-5069/119370 - 2016-10-20 ALMON : End
      this.TAS(TASSUB).SPLD(SPLSUB).EXTUOM = EXTUOM
      this.TAS(TASSUB).SPLD(SPLSUB).CUR    = this.CUR
      #this.TAS(TASSUB).SPLD(SPLSUB).PCCCUR = this.CUROPP
      this.TAS(TASSUB).SPLD(SPLSUB).OPENUM = 0
      this.TAS(TASSUB).SPLD(SPLSUB).ITTSEQ = 0
      this.TAS(TASSUB).SPLD(SPLSUB).PLBSEQ = 0
      If PARORI = 2 Then
        this.TAS(TASSUB).SPLD(SPLSUB).OPENUM = PARSEQ
      Endif
      If PARORI = 3 Then
        this.TAS(TASSUB).SPLD(SPLSUB).ITTSEQ = PARSEQ
      Endif
      If PARORI = 4 Then
        this.TAS(TASSUB).SPLD(SPLSUB).PLBSEQ = PARSEQ
      Endif
      SPLDREF = this.TAS(TASSUB).SPLD(SPLSUB).KEYCONCAT
      If TECSPLDAUT.INCLOG = [V]CST_AYES
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(347,2260,1), this.TAS(TASSUB).TASCOD+" "+ITMREF) ,[V]CST_AWARNING)
      Endif
Return

#######################################################################################
$_SPLD_UPD_BUDLIN
#Variable Integer PARORI
#Variable Integer BUDSUB
#Variable Char BUDCOD
#Variable Char ITMREF
#Variable Char ITMDES1
#Variable Decimal OPEQTY
#Variable Char PARSAU
#Variable Decimal PARPRI
#Variable Char PARSTU
#Variable Decimal QTYSTU
#Variable Char EXTUOM
#Variable Decimal EXTQTY
#Variable Integer PARSEQ
#Variable Char SPLDREF
#Variable Instance TECSPLDAUT Using C_TECSPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Integer SPLSUB, SPLSUB1, SPLSUB2
Local Char    ORIUOM (GLONUOM) # Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Declare working Variable

        ORIUOM = AVOID.ACHAR # Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Initialize Original UOM
        If GUSER = "OLD" Then # Issue X3-25036 - 2017-02-23 ALMON : Find SPLD Record, Temporary for Dual Processing
          SPLSUB = find(ITMREF,this.BUD(BUDSUB).SPLD(1..maxtab(this.BUD(BUDSUB).SPLD)).ITMREF)
          If SPLSUB > 0 and this.BUD(BUDSUB).SPLD(SPLSUB) <> null and find(this.BUD(BUDSUB).SPLD(SPLSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If TECSPLDAUT.INCOWRT = [V]CST_AYES Then
              # Issue X3-17297/120494 - 2016-12-20 ALMON : Do Not Overwite if PSONUM exists  #
              If this.BUD(BUDSUB).SPLD(SPLSUB).PSONUM = AVOID.ACHAR Then
                ORIUOM = this.BUD(BUDSUB).SPLD(SPLSUB).EXTUOM # Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Set Original UOM to the first record
                If this.BUD(BUDSUB).SPLD(SPLSUB).ASTALIN = [V]CST_ALL Then
                  Raz this.BUD(BUDSUB).SPLD(SPLSUB).QTY
                  Raz this.BUD(BUDSUB).SPLD(SPLSUB).QTYSTU
                  Raz this.BUD(BUDSUB).SPLD(SPLSUB).EXTQTY
                Endif
              Else
                If TECSPLDAUT.INCLOG = [V]CST_AYES
                  [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(495,2260,1), ITMREF) ,[V]CST_AWARNING)
                Endif
                Return
              Endif
              # Issue X3-17297/120494 - 2016-12-20 ALMON : END  #
            Else
                If this.BUD(BUDSUB).SPLD(SPLSUB).ASTALIN <> [V]CST_ANEW Then # Issue X3-17297/120494 - 2016-12-20 ALMON : Only return if not new
                  Return
                Endif
            Endif
          Else
              If SPLSUB > 0 and (this.BUD(BUDSUB).SPLD(SPLSUB).ASTALIN = [V]CST_ADEL or this.BUD(BUDSUB).SPLD(SPLSUB).ASTALIN = [V]CST_ANEWDEL) Then
                  SPLSUB2 = SPLSUB
                  Repeat
                    SPLSUB1 = find(ITMREF, this.BUD(BUDSUB).SPLD((SPLSUB2+1)..maxtab(this.BUD(BUDSUB).SPLD)).ITMREF)
                    If SPLSUB1 > 0 and find(this.BUD(BUDSUB).SPLD(SPLSUB1).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                      SPLSUB2 += SPLSUB1
                      If SPLSUB2 > 0 Then
                        SPLSUB1 = SPLSUB2
                        Break
                      Endif
                    Else
                      Break
                    Endif
                  Until 1=1
                  If SPLSUB1 > 0 Then
                    # SPLSUB = SPLSUB + SPLSUB1 # Issue X3-21304/121072 - 2017-01-19 ALMON : Places Collection pointer outside of scope
                    SPLSUB = SPLSUB1
                  Else
                    SPLSUB = fmet this.BUD(BUDSUB).ADDLINE("SPLD",[V]CST_ALASTPOS)
                    If SPLSUB = [V]CST_ANOTDEFINED Then
                      If TECSPLDAUT.INCLOG = [V]CST_AYES Then
                        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(434,2260,1),ITMREF, this.BUD(BUDSUB).PBUCOD) ,[V]CST_AWARNING)
                      Endif
                      Return
                    Endif
                  Endif
              Else # Issue X3-21304/121072 - 2017-01-19 ALMON : Added Else instead of EndIf
                  ORIUOM = AVOID.ACHAR
                  SPLSUB = fmet this.BUD(BUDSUB).ADDLINE("SPLD",[V]CST_ALASTPOS)
                  If SPLSUB = [V]CST_ANOTDEFINED Then
                    If TECSPLDAUT.INCLOG = [V]CST_AYES Then
                      [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(434,2260,1), ITMREF, this.BUD(BUDSUB).PBUCOD) ,[V]CST_AWARNING)
                    Endif
                    Return
                  Endif
              Endif
          Endif
        Else
          # Issue X3-25036 - 2017-02-23 ALMON : Find SPLD Record for Budget Level
          [L]ARET_VALUE = fmet this.SPLD_FIND_BUD_LINE(BUDSUB,SPLDREF,ITMREF,SPLSUB, TECSPLDAUT, SPLDLOG)
          If [L]ARET_VALUE = [V]CST_ANO Then
            Return
          Else
            If SPLSUB = 0 Then
              [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(500,2260,1), ITMREF, this.BUD(BUDSUB).PBUCOD) ,[V]CST_AERROR)
              Return
            Endif
          Endif
          # Issue X3-25036 - 2017-02-23 ALMON : END
        Endif
     # ---------------------------------------------------------------------------
# Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Convert Planned Qty if different to original UOM
        If ORIUOM <> AVOID.ACHAR and ORIUOM <> EXTUOM Then
          Call CONVERT_QTY(this.ACTX, EXTUOM, ORIUOM, EXTQTY) From TRTX3_SYRA
          If TECSPLDAUT.INCLOG = [V]CST_AYES Then
             [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(260,2260,1), num$(EXTQTY)) ,0)
          Endif
          EXTUOM = ORIUOM
        Endif
# Issue X3-5390/119524 - 2016-11-02 ALMON : End
      # ------------------------------------------
      this.BUD(BUDSUB).SPLD(SPLSUB).TCHACTION = "SOLD"
      # ------------------------------------------
      this.BUD(BUDSUB).SPLD(SPLSUB).ORI    = PARORI
      this.BUD(BUDSUB).SPLD(SPLSUB).PRODGRPLVL = TECSPLDAUT.PRODGRPLVL   # 3 # Issue X3-107681 - 2018-09-11 ALMON
      this.BUD(BUDSUB).SPLD(SPLSUB).OPPNUM = this.OPPNUM
      this.BUD(BUDSUB).SPLD(SPLSUB).PBUCOD = this.BUD(BUDSUB).PBUCOD
      this.BUD(BUDSUB).SPLD(SPLSUB).TASCOD = ""
      this.BUD(BUDSUB).SPLD(SPLSUB).ITMREF = ITMREF
      this.BUD(BUDSUB).SPLD(SPLSUB).ITMDES = ITMDES1
      this.BUD(BUDSUB).SPLD(SPLSUB).QTY    = this.BUD(BUDSUB).SPLD(SPLSUB).QTY + OPEQTY
      #this.BUD(BUDSUB).SPLD(SPLSUB).DOCQTY = this.BUD(BUDSUB).SPLD(SPLSUB).DOCQTY + OPEQTY
      this.BUD(BUDSUB).SPLD(SPLSUB).SAU    = PARSAU
      this.BUD(BUDSUB).SPLD(SPLSUB).BASPRI = PARPRI
      this.BUD(BUDSUB).SPLD(SPLSUB).STU     = PARSTU
      # Issue X3-5069/119370 - 2016-10-20 ALMON : Begin Consolidate Planned and Stock Qty
      this.BUD(BUDSUB).SPLD(SPLSUB).QTYSTU += QTYSTU
      this.BUD(BUDSUB).SPLD(SPLSUB).EXTQTY += EXTQTY
      # Issue X3-5069/119370 - 2016-10-20 ALMON : End
      this.BUD(BUDSUB).SPLD(SPLSUB).EXTUOM = EXTUOM
      this.BUD(BUDSUB).SPLD(SPLSUB).CUR    = this.CUR
      this.BUD(BUDSUB).SPLD(SPLSUB).OPENUM = 0
      this.BUD(BUDSUB).SPLD(SPLSUB).ITTSEQ = 0
      this.BUD(BUDSUB).SPLD(SPLSUB).PLBSEQ = 0
      If PARORI = 2 Then
        this.BUD(BUDSUB).SPLD(SPLSUB).OPENUM = PARSEQ
      Endif
      If PARORI = 3 Then
        this.BUD(BUDSUB).SPLD(SPLSUB).ITTSEQ = PARSEQ
      Endif
      If PARORI = 4 Then
        this.BUD(BUDSUB).SPLD(SPLSUB).PLBSEQ = PARSEQ
      Endif
      SPLDREF = this.BUD(BUDSUB).SPLD(SPLSUB).KEYCONCAT
      If TECSPLDAUT.INCLOG = [V]CST_AYES Then
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(347,2260,1), this.BUD(BUDSUB).PBUCOD+" "+ITMREF) ,[V]CST_AWARNING)
      Endif
Return

#######################################################################################
# ISSUE X3-5348/119525 - 2016-10-31 ALMON : BEGIN Update depending on Project #
$_SPLD_UPD_PJMLIN
#Variable Integer PARORI
#Variable Integer CLSSUB
#Variable Char ITMREF
#Variable Char ITMDES1
#Variable Decimal OPEQTY
#Variable Char PARSAU
#Variable Decimal PARPRI
#Variable Char PARSTU
#Variable Decimal QTYSTU
#Variable Char EXTUOM
#Variable Decimal EXTQTY
#Variable Integer PARSEQ
#Variable Char SPLDREF
#Variable Instance TECSPLDAUT Using C_TECSPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Integer SPLSUB, SPLSUB1, SPLSUB2
# Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Declare working variable for Original UOM
Local Char    ORIUOM (GLONUOM) # Issue X3-5390/119524 - 2016-11-02 by ALMON

        ORIUOM = AVOID.ACHAR # Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Initialize Original UOM
        If GUSER = "OLD"  Then # Issue X3-25037 - 2017-02-23 ALMON : Find SPLD Record, Temporary for Dual processing
          SPLSUB = find(ITMREF,this.SPLD(1..maxtab(this.SPLD)).ITMREF)
          If SPLSUB > 0 and this.SPLD(SPLSUB) <> null and find(this.SPLD(SPLSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If TECSPLDAUT.INCOWRT = [V]CST_AYES Then
              # Issue X3-17297/120494 - 2016-12-20 ALMON : Do Not Overwite if PSONUM exists  #
              If this.SPLD(SPLSUB).PSONUM = AVOID.ACHAR Then
              # Issue X3-5390/119524 - 2016-11-02 ALMON : Set Original UOM
                ORIUOM = this.SPLD(SPLSUB).EXTUOM
              # Issue X3-5390/119524 - 2016-11-02 ALMON : End
                If this.SPLD(SPLSUB).ASTALIN = [V]CST_ALL Then
                  Raz this.SPLD(SPLSUB).QTY
                  Raz this.SPLD(SPLSUB).QTYSTU
                  Raz this.SPLD(SPLSUB).EXTQTY
                Endif
              Else
                If TECSPLDAUT.INCLOG = [V]CST_AYES
                  [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(495,2260,1), ITMREF) ,[V]CST_AWARNING)
                Endif
                Return
              Endif
              # Issue X3-17297/120494 - 2016-12-20 ALMON : END  #
            Else
                If this.SPLD(SPLSUB).ASTALIN <> [V]CST_ANEW Then # Issue X3-17297/120494 - 2016-12-20 ALMON : Only return if not new
                  Return
                Endif
            Endif
          Else
             If SPLSUB > 0 and (this.SPLD(SPLSUB).ASTALIN = [V]CST_ADEL or this.SPLD(SPLSUB).ASTALIN = [V]CST_ANEWDEL) Then
              SPLSUB2 = SPLSUB
              Repeat
                SPLSUB1 = find(ITMREF, this.SPLD((SPLSUB2+1)..maxtab(this.SPLD)).ITMREF)
                If SPLSUB1 <> 0 and find(this.SPLD(SPLSUB1).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                  SPLSUB2 += SPLSUB1
                  If SPLSUB2 > 0 Then
                    SPLSUB1 = SPLSUB2
                    Break
                  Endif
                Else
                  Break
                Endif
              Until 1=1
              If SPLSUB1 > 0 Then
                #SPLSUB = SPLSUB + SPLSUB1 # Issue X3-21304/121072 - 2017-01-19 ALMON : Places Collection pointer outside of scope
                SPLSUB = SPLSUB1
              Else
                SPLSUB = fmet this.ADDLINE("SPLD",[V]CST_ALASTPOS)
                If SPLSUB = [V]CST_ANOTDEFINED Then
                  If TECSPLDAUT.INCLOG = [V]CST_AYES Then
                    [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(434,2260,1),ITMREF, this.OPPNUM) ,[V]CST_ERROR)
                  Endif
                  Return
                Endif
              Endif
            Else # Issue X3-21304/121072 - 2017-01-19 ALMON : Added Else instead of EndIf
                SPLSUB = fmet this.ADDLINE("SPLD",[V]CST_ALASTPOS)
                If SPLSUB = [V]CST_ANOTDEFINED Then
                  If TECSPLDAUT.INCLOG = [V]CST_AYES Then
                    [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(434,2260,1), ITMREF, this.OPPNUM) ,[V]CST_AERROR)
                  Endif
                  Return
                Endif
            Endif
          Endif
        Else
          # Issue X3-25037 - 2017-02-23 ALMON : Search for SPLD Record at Project Level
          [L]ARET_VALUE = fmet this.SPLD_FIND_PJM_LINE(SPLDREF,ITMREF,SPLSUB, TECSPLDAUT, SPLDLOG)
          If [L]ARET_VALUE = [V]CST_ANO Then
            Return
          Else
            If SPLSUB = 0 Then
              [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(500,2260,1), ITMREF, this.OPPNUM) ,[V]CST_AERROR)
              Return
            Endif
          Endif
        Endif
        # Issue X3-25037 - 2017-02-23 ALMON : END
      # -------------------------------------------
        # Issue X3-5390/119524 - 2016-11-02 ALMON : Begin Convert Planned Qty to Original UOM
        If ORIUOM <> AVOID.ACHAR and ORIUOM <> EXTUOM Then
          Call CONVERT_QTY(this.ACTX, EXTUOM, ORIUOM, EXTQTY) From TRTX3_SYRA
          If TECSPLDAUT.INCLOG = [V]CST_AYES Then
             [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(260,2260,1), num$(EXTQTY)) ,[V]CST_AWARNING)
          Endif
          EXTUOM = ORIUOM
        Endif
        # Issue X3-5390/119524 - 2016-11-02 ALMON : End
      # ------------------------------------------
      this.SPLD(SPLSUB).TCHACTION = "SOLD"
      # ------------------------------------------
      this.SPLD(SPLSUB).ORI    = PARORI
      this.SPLD(SPLSUB).PRODGRPLVL = TECSPLDAUT.PRODGRPLVL   # 2 # Issue X3-107681 - 2018-09-11 ALMON
      this.SPLD(SPLSUB).OPPNUM = this.OPPNUM
      this.SPLD(SPLSUB).PBUCOD = ""
      this.SPLD(SPLSUB).TASCOD = ""
      this.SPLD(SPLSUB).ITMREF = ITMREF
      this.SPLD(SPLSUB).ITMDES = ITMDES1
      this.SPLD(SPLSUB).QTY    = this.SPLD(SPLSUB).QTY + OPEQTY
      this.SPLD(SPLSUB).SAU    = PARSAU
      this.SPLD(SPLSUB).BASPRI = PARPRI
      this.SPLD(SPLSUB).STU     = PARSTU
      # Issue X3-5069/119370 - 2016-10-20 ALMON : Begin Consolidate Planned and Stock Qty
      this.SPLD(SPLSUB).QTYSTU += QTYSTU
      this.SPLD(SPLSUB).EXTQTY += EXTQTY
      # Issue X3-5069/119370 - 2016-10-20 ALMON : End
      this.SPLD(SPLSUB).EXTUOM = EXTUOM
      this.SPLD(SPLSUB).CUR    = this.CUR
      this.SPLD(SPLSUB).OPENUM = 0
      this.SPLD(SPLSUB).ITTSEQ = 0
      this.SPLD(SPLSUB).PLBSEQ = 0
      If PARORI = 2 Then
        this.SPLD(SPLSUB).OPENUM = PARSEQ
      Endif
      If PARORI = 3 Then
        this.SPLD(SPLSUB).ITTSEQ = PARSEQ
      Endif
      If PARORI = 4 Then
        this.SPLD(SPLSUB).PLBSEQ = PARSEQ
      Endif
      SPLDREF = this.SPLD(SPLSUB).KEYCONCAT
      If TECSPLDAUT.INCLOG = [V]CST_AYES Then
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(347,2260,1), this.OPPNUM+" "+ITMREF) ,[V]CST_AWARNING)
      Endif
Return
# ISSUE X3-5348/119525 - 2016-10-31 ALMON : End #
#######################################################################################
$SPLD_IS_OPE_SALEABLE
#Variable Char PARFCY
#Variable Char PARPCCCOD
#Variable Char PARITM
  PARITM = ""
  Local File PJMCOSTCTR[PJCC] Where PCCFCY = PARFCY and PCCCOD = PARPCCCOD
  Read [PJCC] First
  If fstat <> 0 Then
    Close Local File [PJCC]
    Local File PJMCOSTCTR[PJCC] Where PCCCOD = PARPCCCOD
    Read [PJCC] First
    If fstat <> 0 Then
      Return
    Endif
  Endif
  If [PJCC]ITMREF <> AVOID.ACHAR Then
    PARITM = [PJCC]ITMREF
  Endif
Return
#######################################################################################
$SPLD_GET_ITMMASTER
#Variable Char PARITM
#Variable Char PARDES1
#Variable Char PARSAU
#Variable Decimal PARPRI
  PARDES1 = ""
  PARSAU = ""
  PARPRI = 0

  Local File ITMMASTER[ITM] Where ITMREF = PARITM
  Read [ITM] First
  If fstat <> 0 Then
    Return
  Endif
  Local File ITMSALES[ITS] Where ITMREF = PARITM
  Read [ITS] First
  If fstat <> 0 Then
    Return
  Endif
  PARSAU = [ITM]SAU
  PARSTU = [ITM]STU
  PARDES1 = [ITM]ITMDES1
  PARPRI = [ITS]BASPRI
Return

#######################################################################################
$SPLD_GET_INDEX
#Value Integer SEQNUM
#Local Integer ARET_VALUE

Local Integer NI

  For NI = 1 To maxtab(this.SPLD)
    If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.SPLD(NI).SEQNUM = SEQNUM Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

###################################################################################################
$SPLD_SOLD
#Value Char PSONUM : #
#Value Integer IACTION : #
#Variable Instance TECSPLDSOLD Using C_TECSPLDSOLD : #
#Variable Instance LOGFILE Using C_ALOG : #
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NE
Local Integer ILINE
Local Integer ILINETAS
Local Integer ILINEBUD
Local Instance PJMSOLITMH Using C_PJMSOLITMH
Local Instance PJMSOLITMO Using C_PJMSOLITMO

  PJMSOLITMH = NewInstance C_PJMSOLITMH AllocGroup null
  PJMSOLITMO = NewInstance C_PJMSOLITMO AllocGroup null
  # -----------------------------
  If this.TCHACTION <> "SALES_DOC" Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR)
    Return
  Endif
  # -----------------------------
  [L]ARET_VALUE = fmet PJMSOLITMH.AREAD(PSONUM)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(382,2260,1), [L]ARET_VALUE)   # Issue X3-8085/121537 - 2017-02-15 by FGR fmet was missing
  Endif
  # -----------------------------
  If IACTION = [V]CST_AUPD Then
    For NI = 1 To maxtab(this.SPLD)
      If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.SPLD(NI).PSONUM = PSONUM Then
          [L]ARET_VALUE = fmet this.SPLD_SOLD_GET_VALUES([V]CST_ADEL, this.SPLD(NI), PJMSOLITMO, TECSPLDSOLD, LOGFILE)
        Endif
      Endif
    Next
    # -----------------------------
    For NI = 1 To maxtab(this.BUD)
      If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        For NE = 1 To maxtab(this.BUD(NI).SPLD)
          If this.BUD(NI).SPLD(NE) <> null and find(this.BUD(NI).SPLD(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.BUD(NI).SPLD(NE).PSONUM = PSONUM Then
              [L]ARET_VALUE = fmet this.SPLD_SOLD_GET_VALUES([V]CST_ADEL, this.BUD(NI).SPLD(NE), PJMSOLITMO, TECSPLDSOLD, LOGFILE)
            Endif
          Endif
        Next NE
      Endif
    Next NI
    # -----------------------------
    For NI = 1 To maxtab(this.TAS)
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0 Then
        For NE = 1 To maxtab(this.TAS(NI).SPLD)
          If this.TAS(NI).SPLD(NE) <> null and find(this.TAS(NI).SPLD(NE).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0 Then
            If this.TAS(NI).SPLD(NE).PSONUM = PSONUM Then
              [L]ARET_VALUE = fmet this.SPLD_SOLD_GET_VALUES([V]CST_ADEL, this.TAS(NI).SPLD(NE), PJMSOLITMO, TECSPLDSOLD, LOGFILE)
            Endif
          Endif
        Next NE
      Endif
    Next NI
  Endif
  # -----------------------------
  For NI = 1 To maxtab(PJMSOLITMH.SPLO)
    # -----------------------------
    If PJMSOLITMH.SPLO(NI) <> null and find(PJMSOLITMH.SPLO(NI).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0 Then
      # -----------------------------
      If PJMSOLITMH.SPLO(NI).TASCOD = AVOID.ACHAR and PJMSOLITMH.SPLO(NI).PBUCOD = AVOID.ACHAR Then
        # -----------------------------
        # PJMOPP
        ILINE = fmet this.SPLD_GET_INDEX(PJMSOLITMH.SPLO(NI).SEQNUM)
        If ILINE < 1 Then
          [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(359,2260,1), PJMSOLITMH.SPLO(NI).ITMREF), [V]CST_AERROR)
          Break
        Endif
        # -----------------------------
        [L]ARET_VALUE = fmet this.SPLD_SOLD_GET_VALUES(IACTION, this.SPLD(ILINE), PJMSOLITMH.SPLO(NI), TECSPLDSOLD, LOGFILE)
      Elsif PJMSOLITMH.SPLO(NI).TASCOD <> AVOID.ACHAR Then
        # -----------------------------
        # PJMTASK
        ILINE = fmet this.TAS_GET_INDEX(PJMSOLITMH.SPLO(NI).TASCOD)
        If ILINE < 1 Then
          [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(245,2260,1), PJMSOLITMH.SPLO(NI).TASCOD), [V]CST_AERROR)
          Break
        Endif
        # -----------------------------
        ILINETAS = fmet this.TAS(ILINE).SPLD_GET_INDEX(PJMSOLITMH.SPLO(NI).SEQNUM)
        If ILINETAS < 1 Then
          [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(359,2260,1), PJMSOLITMH.SPLO(NI).ITMREF), [V]CST_AERROR)
          Break
        Endif
        # -----------------------------
        [L]ARET_VALUE = fmet this.SPLD_SOLD_GET_VALUES(IACTION, this.TAS(ILINE).SPLD(ILINETAS), PJMSOLITMH.SPLO(NI), TECSPLDSOLD, LOGFILE)
      Else
        # -----------------------------
        # PJMBUDGET
        ILINE = fmet this.BUD_GET_INDEX(PJMSOLITMH.SPLO(NI).PBUCOD)
        If ILINE < 1 Then
          [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(239,2260,1), PJMSOLITMH.SPLO(NI).PBUCOD), [V]CST_AERROR)
          Break
        Endif
        # -----------------------------
        ILINEBUD = fmet this.BUD(ILINE).SPLD_GET_INDEX(PJMSOLITMH.SPLO(NI).SEQNUM)
        If ILINEBUD < 1 Then
          [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(359,2260,1), PJMSOLITMH.SPLO(NI).ITMREF), [V]CST_AERROR)
          Break
        Endif
        # -----------------------------
        [L]ARET_VALUE = fmet this.SPLD_SOLD_GET_VALUES(IACTION, this.BUD(ILINE).SPLD(ILINEBUD), PJMSOLITMH.SPLO(NI), TECSPLDSOLD, LOGFILE)
      Endif
      # -----------------------------
    Endif
    # -----------------------------
  Next
  # -----------------------------
  FreeGroup PJMSOLITMH
  FreeGroup PJMSOLITMO
Return

###################################################################################################
$SPLD_SOLD_GET_VALUES
#Value Integer IACTION : #
#Variable Instance SPLD Using C_PJMSALITMD : #
#Variable Instance PJMSOLITMO Using C_PJMSOLITMO : #
#Variable Instance TECSPLDSOLD Using C_TECSPLDSOLD : #
#Variable Instance LOGFILE Using C_ALOG : #
#Local Integer ARET_VALUE

  If IACTION = [V]CST_ANEW or IACTION = [V]CST_AUPD Then
    SPLD.TCHACTION = "SALES_DOC"
    SPLD.PSONUM = PJMSOLITMO.PSONUM
    SPLD.PSOLIN = PJMSOLITMO.PSOLIN
    SPLD.QTY    = PJMSOLITMO.QTY
    SPLD.BASPRI = PJMSOLITMO.BASPRI
    SPLD.PRODGRPLVL = PJMSOLITMO.PRODGRPLVL
  Elsif IACTION = [V]CST_ADEL Then
    SPLD.TCHACTION = "SALES_DOC"
    SPLD.PSONUM = AVOID.ACHAR
    SPLD.PSOLIN = 0
  Endif
Return

###################################################################################################
$SPLD_EXISTING
# Issue X3-6423/120294 - 2016-12-09 by SINGO
#Local Integer ARET_VALUE
Local Integer NI

  [L]ARET_VALUE = [V]CST_ANO
  For NI = 1 To maxtab(this.SPLD)
    If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = [V]CST_AYES
      Break
    Endif
  Next NI
Return

###################################################################################################
$SPLD_EXISTING_SOMEWHERE
# Issue X3-6423/120294 - 2016-01-13 by SINGC
#Local Integer ARET_VALUE
Local Integer NI

  [L]ARET_VALUE = [V]CST_ANO
  # -----------------------------
  [L]ARET_VALUE = fmet this.SPLD_EXISTING()
  If [L]ARET_VALUE = [V]CST_ANO Then
    For NI = 1 To maxtab(this.TAS)
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = fmet this.TAS(NI).SPLD_EXISTING()
        If [L]ARET_VALUE = [V]CST_AYES Then
          Break
        Endif
      Endif
    Next NI
    # -----------------------------
    If [L]ARET_VALUE = [V]CST_ANO Then
      For NI = 1 To maxtab(this.BUD)
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = fmet this.BUD(NI).SPLD_EXISTING()
          If [L]ARET_VALUE = [V]CST_AYES Then
            Break
          Endif
        Endif
      Next NI
    Endif
  Endif
  # -----------------------------
Return
####################################################################################################
# Issue X3-21304/121072 - 2017-01-19 ALMON : Use PARORI to specifically delete "PJM" SPLD records from Budglines, operations or products
$SPLD_DEL_ALL_LINES
#Value Integer PARORI # Issue X3-21304/121072 - 2017-01-19 ALMON : Added Origin to select correct records to delete

Local Integer NI

    For NI = 1 To maxtab(this.SPLD)
      If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.SPLD(NI).ORI = PARORI and this.SPLD(NI).PSONUM = AVOID.ACHAR Then
          [L]ARET_VALUE = fmet this.ADELLINE("SPLD", this.SPLD(NI).AORDER)
          If [L]ARET_VALUE = [V]CST_ANOTDEFINED Then
            Break
          Endif
          # Issue X3-21304/121072 - 2017-01-19 ALMON : END
        Endif
      Endif
    Next NI
Return
# Issue X3-21304/121072 - 2017-01-19 ALMON : END
###################################################################################################
# ISSUE PJM_X3_19726_AMO_SPLDAUTO - 2016-02-08 ALMON : Search for SPLD Record with SPLDREF from TASK Summary Level
$SPLD_FIND_TAS_LINE
#Value Integer TASSUB
#Value Char SPLDREF
#Value Char INITMREF
#Variable Integer SPLSUB
#Variable Instance TECSPLDAUT Using C_TECSPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Char OTASCOD (GLONTAC)
Local Char OPBUCOD (GLONPBU)
Local Char OOPPNUM (GLONOPP)

  [L]ARET_VALUE = [V]CST_ANO
  If TECSPLDAUT.SUMMLVL = "PJMTAS" Then
    If SPLDREF <> AVOID.ACHAR Then
      If TECSPLDAUT.INCOWRT = [V]CST_ANO Then
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(501,2260,1), INITMREF),[V]CST_AWARNING)
        [L]ARET_VALUE = [V]CST_ANO
        Return
      Endif
      [L]ARET_VALUE = func PJMSALITMD_CSTD_PROGS.SPLD_KEY_SPLIT(this.ACTX,SPLDREF,OOPPNUM,OPBUCOD,OTASCOD)
      If OTASCOD = AVOID.ACHAR Then
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(mess(503,2260,1),[V]CST_AWARNING)
        [L]ARET_VALUE = [V]CST_ANO
        Return
      Endif
      # We have an established link, loop through collection sequentially for appropriate record
      SPLSUB = find(SPLDREF,this.TAS(TASSUB).SPLD(1..maxtab(this.TAS(TASSUB).SPLD)).KEYCONCAT)
      If SPLSUB > 0 and this.TAS(TASSUB).SPLD(SPLSUB) <> null and find(this.TAS(TASSUB).SPLD(SPLSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          # Issue X3-107681 - 2018-09-11 ALMON : If non-grouped add a new line instead of aggregating to found line
          If this.TAS(TASSUB).SPLD(SPLSUB).PSONUM <> AVOID.ACHAR Then
            [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(495,2260,1), INITMREF) ,[V]CST_AERROR)
            [L]ARET_VALUE = [V]CST_ANO # Found but Closed not to Update SPLD
            Return
          Else
            # Issue X3-107681 - 2018-09-11 ALMON : If non-grouped add a new line instead of aggregating to found line
            If TECSPLDAUT.PRODGRPLVL <> this.TAS(TASSUB).SPLD(SPLSUB).PRODGRPLVL Then
              [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(1135,2260,1), INITMREF) ,[V]CST_AERROR)
              [L]ARET_VALUE = [V]CST_ANO # Found but Closed not to Update SPLD
              Return
            Endif
            [L]ARET_VALUE = [V]CST_AYES
            If this.TAS(TASSUB).SPLD(SPLSUB).ASTALIN = [V]CST_ALL Then
              Raz this.TAS(TASSUB).SPLD(SPLSUB).QTY
              Raz this.TAS(TASSUB).SPLD(SPLSUB).QTYSTU
              Raz this.TAS(TASSUB).SPLD(SPLSUB).EXTQTY
            Endif
            Return # SPLSUB Set and SPLD Open for Update
          Endif
          # Issue X3-107681 - 2018-09-11 ALMON : END
      Endif
    Endif
    # We have no established link, loop through collection sequentially for appropriate record if overwrite is yes
    [L]ARET_VALUE = [V]CST_ANO
    #If TECSPLDAUT.INCOWRT = [V]CST_AYES Then
    # Issue X3-107681 - 2018-09-11 ALMON : If non-grouped add a new line instead of aggregating to found line
    If TECSPLDAUT.PRODGRPLVL <> 1 Then
      For SPLSUB = 1 To maxtab(this.TAS(TASSUB).SPLD)
        SPLDREF = this.TAS(TASSUB).SPLD(SPLSUB).KEYCONCAT
        If INITMREF = this.TAS(TASSUB).SPLD(SPLSUB).ITMREF and this.TAS(TASSUB).SPLD(SPLSUB) <> null and find(this.TAS(TASSUB).SPLD(SPLSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 and TECSPLDAUT.
& PRODGRPLVL = this.TAS(TASSUB).SPLD(SPLSUB).PRODGRPLVL Then
          If this.TAS(TASSUB).SPLD(SPLSUB).PSONUM = AVOID.ACHAR Then
            [L]ARET_VALUE = [V]CST_AYES
            If this.TAS(TASSUB).SPLD(SPLSUB).ASTALIN = [V]CST_ALL
              Raz this.TAS(TASSUB).SPLD(SPLSUB).QTY
              Raz this.TAS(TASSUB).SPLD(SPLSUB).QTYSTU
              Raz this.TAS(TASSUB).SPLD(SPLSUB).EXTQTY
            Endif
            Break # SPLSUB Set and SPLD Open for Update
          Endif
        Endif
      Next SPLSUB
    Endif
    # Issue X3-107681 - 2018-09-11 ALMON : END
    If [L]ARET_VALUE = [V]CST_ANO Then
      # Add Line to collection
      SPLSUB = fmet this.TAS(TASSUB).ADDLINE("SPLD",[V]CST_ALASTPOS)
      If SPLSUB = [V]CST_ANOTDEFINED Then
        If TECSPLDAUT.INCLOG = [V]CST_AYES
          [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(433,2260,1), INITMREF, this.TAS(TASSUB).TASCOD) ,[V]CST_AWARNING)
          [L]ARET_VALUE = [V]CST_ANO
        Endif
        Return
      Else
        [L]ARET_VALUE = [V]CST_AYES
        this.TAS(TASSUB).SPLD(SPLSUB).QTY = 0 # Issue X3-107681 - 2018-09-11 ALMON : QTY = 1 on ADDLINE
      Endif
    Endif
  Endif
Return
# Issue X3-25035 - 2017-02-23 ALMON : END
################################################################################################
# ISSUE PJM_X3_19726_AMO_SPLDAUTO - 2016-02-08 ALMON : Search for SPLD Record with SPLDREF from Budget Summary Level
$SPLD_FIND_BUD_LINE
#Value Integer BUDSUB
#Value Char SPLDREF
#Value Char INITMREF
#Variable Integer SPLSUB
#Variable Instance TECSPLDAUT Using C_TECSPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Char OTASCOD (GLONTAC)
Local Char OPBUCOD (GLONPBU)
Local Char OOPPNUM (GLONOPP)

  [L]ARET_VALUE = [V]CST_ANO
  If TECSPLDAUT.SUMMLVL = "PJMBUD" Then
    If SPLDREF <> AVOID.ACHAR Then
      If TECSPLDAUT.INCOWRT = [V]CST_ANO Then
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(501,2260,1), INITMREF),[V]CST_AWARNING)
        [L]ARET_VALUE = [V]CST_ANO
        Return
      Endif
      [L]ARET_VALUE = func PJMSALITMD_CSTD_PROGS.SPLD_KEY_SPLIT(this.ACTX,SPLDREF,OOPPNUM,OPBUCOD,OTASCOD)
      If OPBUCOD = AVOID.ACHAR or OTASCOD <> AVOID.ACHAR Then #already assigned to Project level
          [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(mess(504,2260,1),[V]CST_AWARNING)
          [L]ARET_VALUE = [V]CST_ANO
          Return
      Endif
      # We have an established link, loop through collection sequentially for appropriate record
      SPLSUB = find(SPLDREF,this.BUD(BUDSUB).SPLD(1..maxtab(this.BUD(BUDSUB).SPLD)).KEYCONCAT)
      If SPLSUB > 0 and this.BUD(BUDSUB).SPLD(SPLSUB) <> null and find(this.BUD(BUDSUB).SPLD(SPLSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        # Issue X3-107681 - 2018-09-11 ALMON : If non-grouped add a new line instead of aggregating to found line
          If this.BUD(BUDSUB).SPLD(SPLSUB).PSONUM <> AVOID.ACHAR Then
            [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(495,2260,1), INITMREF) ,[V]CST_AERROR)
            [L]ARET_VALUE = [V]CST_ANO # Found but Closed not to Update SPLD
            Return
          Else
            # Issue X3-107681 - 2018-09-11 ALMON : If non-grouped add a new line instead of aggregating to found line
            If TECSPLDAUT.PRODGRPLVL <> this.BUD(BUDSUB).SPLD(SPLSUB).PRODGRPLVL Then
              [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(1135,2260,1), INITMREF) ,[V]CST_AERROR)
              [L]ARET_VALUE = [V]CST_ANO # Found but allocated to another group
              Return
            Endif
            # Issue X3-107681 - 2018-09-11 ALMON : If non-grouped add a new line instead of aggregating to found line
            [L]ARET_VALUE = [V]CST_AYES
            If this.BUD(BUDSUB).SPLD(SPLSUB).ASTALIN = [V]CST_ALL
              Raz this.BUD(BUDSUB).SPLD(SPLSUB).QTY
              Raz this.BUD(BUDSUB).SPLD(SPLSUB).QTYSTU
              Raz this.BUD(BUDSUB).SPLD(SPLSUB).EXTQTY
            Endif
            Return # SPLSUB Set and SPLD Open for Update
          Endif
          # Issue X3-107681 - 2018-09-11 ALMON : END
      Endif
    Endif
    # We have no established link, loop through collection sequentially for appropriate record if overwrite is yes
    [L]ARET_VALUE = [V]CST_ANO
    # Issue X3-107681 - 2018-09-11 ALMON : If non-grouped add a new line instead of aggregating to found line
    If TECSPLDAUT.PRODGRPLVL <> 1 Then
      For SPLSUB = 1 To maxtab(this.BUD(BUDSUB).SPLD)
        SPLDREF = this.BUD(BUDSUB).SPLD(SPLSUB).KEYCONCAT
        If INITMREF = this.BUD(BUDSUB).SPLD(SPLSUB).ITMREF and this.BUD(BUDSUB).SPLD(SPLSUB) <> null and find(this.BUD(BUDSUB).SPLD(SPLSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 and TECSPLDAUT.
& PRODGRPLVL = this.BUD(BUDSUB).SPLD(SPLSUB).PRODGRPLVL Then
          If this.BUD(BUDSUB).SPLD(SPLSUB).PSONUM = AVOID.ACHAR Then
            [L]ARET_VALUE = [V]CST_AYES
            If this.BUD(BUDSUB).SPLD(SPLSUB).ASTALIN = [V]CST_ALL
              Raz this.BUD(BUDSUB).SPLD(SPLSUB).QTY
              Raz this.BUD(BUDSUB).SPLD(SPLSUB).QTYSTU
              Raz this.BUD(BUDSUB).SPLD(SPLSUB).EXTQTY
            Endif
            Break # SPLSUB Set and SPLD Open for Update
          Endif
        Endif
      Next SPLSUB
    Endif
    # Issue X3-107681 - 2018-09-11 ALMON : END
    If [L]ARET_VALUE = [V]CST_ANO Then
      # Add Line to collection
      SPLSUB = fmet this.BUD(BUDSUB).ADDLINE("SPLD",[V]CST_ALASTPOS)
      If SPLSUB = [V]CST_ANOTDEFINED Then
        If TECSPLDAUT.INCLOG = [V]CST_AYES
          [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(434,2260,1), INITMREF, this.BUD(BUDSUB).PBUCOD) ,[V]CST_AWARNING)
        Endif
        [L]ARET_VALUE = [V]CST_ANO
        Return
      Else
        [L]ARET_VALUE = [V]CST_AYES
        this.BUD(BUDSUB).SPLD(SPLSUB).QTY = 0 # Issue X3-107681 - 2018-09-11 ALMON : QTY = 1 on ADDLINE
      Endif
    Endif
  Endif
Return
# Issue X3-25036 - 2017-02-23 ALMON : END
##################################################################################################################
# ISSUE PJM_X3_19726_AMO_SPLDAUTO - 2016-02-08 ALMON : Search for SPLD Record with SPLDREF from Project Summary Level
$SPLD_FIND_PJM_LINE
#Value Char SPLDREF
#Value Char INITMREF
#Variable Integer SPLSUB
#Variable Instance TECSPLDAUT Using C_TECSPLDAUT : #
#Variable Instance SPLDLOG Using C_ALOG #

Local Char OTASCOD (GLONTAC)
Local Char OPBUCOD (GLONPBU)
Local Char OOPPNUM (GLONOPP)

  [L]ARET_VALUE = [V]CST_ANO
  If TECSPLDAUT.SUMMLVL = "PJM" Then
    If SPLDREF <> AVOID.ACHAR Then
      If TECSPLDAUT.INCOWRT = [V]CST_ANO Then
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(501,2260,1), INITMREF),[V]CST_AWARNING)
        [L]ARET_VALUE = [V]CST_ANO
        Return
      Endif
      [L]ARET_VALUE = func PJMSALITMD_CSTD_PROGS.SPLD_KEY_SPLIT(this.ACTX,SPLDREF,OOPPNUM,OPBUCOD,OTASCOD)
      If OTASCOD <> AVOID.ACHAR Then
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(mess(503,2260,1),[V]CST_AWARNING)
        [L]ARET_VALUE = [V]CST_ANO
        Return
      Endif
      If  OPBUCOD <> AVOID.ACHAR Then
        [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(mess(504,2260,1),[V]CST_AWARNING)
        [L]ARET_VALUE = [V]CST_ANO
        Return
      Endif
      # We have an established link, loop through collection sequentially for appropriate record
      SPLSUB = find(SPLDREF,this.SPLD(1..maxtab(this.SPLD)).KEYCONCAT)
      If SPLSUB > 0 and this.SPLD(SPLSUB) <> null and find(this.SPLD(SPLSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.SPLD(SPLSUB).PSONUM <> AVOID.ACHAR Then
            [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(495,2260,1), INITMREF) ,[V]CST_AERROR)
            [L]ARET_VALUE = [V]CST_ANO # Found but Closed not to Update SPLD
            Return
          Else
            # Issue X3-107681 - 2018-09-11 ALMON : If non-grouped add a new line instead of aggregating to found line
            If TECSPLDAUT.PRODGRPLVL <> this.SPLD(SPLSUB).PRODGRPLVL Then
              [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES1(mess(1135,2260,1), INITMREF) ,[V]CST_AERROR)
              [L]ARET_VALUE = [V]CST_ANO # Found but Closed not to Update SPLD
              Return
            Endif
            [L]ARET_VALUE = [V]CST_AYES
            If this.SPLD(SPLSUB).ASTALIN = [V]CST_ALL
              Raz this.SPLD(SPLSUB).QTY
              Raz this.SPLD(SPLSUB).QTYSTU
              Raz this.SPLD(SPLSUB).EXTQTY
            Endif
            Return # SPLSUB Set and SPLD Open for Update
            # Issue X3-107681 - 2018-09-11 ALMON : END
          Endif
      Endif
    Endif
    # We have no established link, loop through collection sequentially for appropriate record if overwrite is yes
    [L]ARET_VALUE = [V]CST_ANO
    #If TECSPLDAUT.INCOWRT = [V]CST_AYES Then
    # Issue X3-107681 - 2018-09-11 ALMON : If non-grouped add a new line instead of aggregating to found line
    If TECSPLDAUT.PRODGRPLVL <> 1 Then
      For SPLSUB = 1 To maxtab(this.SPLD)
        SPLDREF = this.SPLD(SPLSUB).KEYCONCAT
        If INITMREF = this.SPLD(SPLSUB).ITMREF and this.SPLD(SPLSUB) <> null and find(this.SPLD(SPLSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 and TECSPLDAUT.PRODGRPLVL = this.SPLD(SPLSUB).PRODGRPLVL
& Then
          If this.SPLD(SPLSUB).PSONUM = AVOID.ACHAR Then
            [L]ARET_VALUE = [V]CST_AYES
            If this.SPLD(SPLSUB).ASTALIN = [V]CST_ALL
              Raz this.SPLD(SPLSUB).QTY
              Raz this.SPLD(SPLSUB).QTYSTU
              Raz this.SPLD(SPLSUB).EXTQTY
            Endif
            Break # SPLSUB Set and SPLD Open for Update
          Endif
        Endif
      Next SPLSUB
    Endif
    # Issue X3-107681 - 2018-09-11 ALMON : END
    If [L]ARET_VALUE = [V]CST_ANO Then
      # Add Line to collection
      SPLSUB = fmet this.ADDLINE("SPLD",[V]CST_ALASTPOS)
      If SPLSUB = [V]CST_ANOTDEFINED Then
        If TECSPLDAUT.INCLOG = [V]CST_AYES
          [L]ARET_VALUE = fmet SPLDLOG.APUTLINE(func AFNC.MES2(mess(434,2260,1), INITMREF, this.PBUCOD) ,[V]CST_AWARNING)
        Endif
        [L]ARET_VALUE = [V]CST_ANO
        Return
      Else
        [L]ARET_VALUE = [V]CST_AYES
        this.SPLD(SPLSUB).QTY = 0 # Issue X3-107681 - 2018-09-11 ALMON : QTY = 1 on ADDLINE
      Endif
    Endif
  Endif
Return
# Issue X3-25037 - 2017-02-23 ALMON : END
###################################################################################################################
# ISSUE PJM_X3_19726_AMO_SPLDAUTO - 2016-02-08 ALMON : Reset SPLDREF fields on source records
$SPLD_RESET_SPLDREF
#Variable Char KEYCONCAT

Local Integer NI
Local Integer NE
  For NE = 1 To maxtab(this.TAS)
    If this.TAS(NE) <> null and find(this.TAS(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      For NI = 1 To maxtab(this.TAS(NE).RTKO)
        If this.TAS(NE).RTKO(NI) <> null and find(this.TAS(NE).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.TAS(NE).RTKO(NI).SPLDREF = KEYCONCAT Then
           this.TAS(NE).RTKO(NI).SPLDREF = AVOID.ACHAR
          Endif
        Endif
      Next NI
      For NI = 1 To maxtab(this.TAS(NE).RITT)
         If this.TAS(NE).RITT(NI) <> null and find(this.TAS(NE).RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.TAS(NE).RITT(NI).SPLDREF = KEYCONCAT Then
            this.TAS(NE).RITT(NI).SPLDREF = AVOID.ACHAR
          Endif
        Endif
      Next NI
    Endif
 Next NE
  # -----------------
  For NE = 1 To maxtab(this.BUD)

    If this.BUD(NE) <> null and find(this.BUD(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      For NI = 1 To maxtab(this.BUD(NE).BUDLIG)
        If this.BUD(NE).BUDLIG(NI) <> null and find(this.BUD(NE).BUDLIG.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.BUD(NE).BUDLIG(NI).SPLDREF = KEYCONCAT Then
           this.BUD(NE).BUDLIG(NI).SPLDREF = AVOID.ACHAR
          Endif
        Endif
      Next NI
    Endif
 Next NE
  # -----------------
Return
# Issue X3-25035/6/7 - 2017-02-23 ALMON : END
######################################################################################################

