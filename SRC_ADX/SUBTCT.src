###########################################################
## Programme de gestion des tables de contrôle           ##
###########################################################
## écrit en novembre 1997 par Adeline Lenoir             ##
###########################################################
$ACTION
Case ACTION
  When "FILGAUCHE"    : Gosub FILGAUCHE
  When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
  When "OUVRE_BOITE"  : Gosub OUVRE_BOITE    # FQ 60150 GA 11/2009
  When "SETBOUT"      : Gosub SETBOUT
  When "EXEBOUT"      : Gosub EXEBOUT
  When "RAZCRE"       : Gosub RAZCRE       : # FQ 46343 GA 03/2008
  When "LIENS"        : Gosub LIENS
  When "AV_IMPRIME"   : Call PRTSCR("TCT1","TCT1","",0,0) From ATRTX3
                        OK = 0
  When "FERME"        : Gosub FERME
  When "ANNULE"      : Gosub ANNULE
  When "CREATION"    : Gosub CREATION
  When "MODIF"       : Gosub MODIF
  When "CHANGE"      : Call CHANGE_AXX ("TABCTL", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When Default
Endcase
Return
###########################################################
$AVANT_OUVRE
Global Char    GSINTCOL(30)(10)
Global Char    GWINVDES(10)(10)
Local  Char    WINT    (30)
Local  Char    WDESCOD (GLONDCT)(10) # FQ 49950 WDESCOD (30)(10)
Local  Char    WLAN    (03)(10)
Local  Integer W_I, W_J
# Issue 112717 - 2015-11-27 by MAE
Local Integer  WNBRLAN
#
Call TEXTE(6196,WINT) From OBJDIV
If clalev([F:ADS1]) = 0 : Local File ADOSSIER [ADS1] : Endif
Read [ADS1]DOSSIER=nomap
If fstat
  Raz [F:ADS1]
Endif
# Issue 112717 - 2015-11-27 by MAE : Si le nb de langue du dossier > 10, WNBRLAN = 10
If [F:ADS1]NBRLAN >10
  WNBRLAN = 10
Else
  WNBRLAN = [F:ADS1]NBRLAN
Endif
# Issue 112717 - 2015-11-27 by MAE
#For W_I = 0 To [F:ADS1]NBRLAN-1
For W_I = 0 To WNBRLAN-1
  If W_I >= dim([F:TCT]LAN) Break Endif  # Issue 105687 GA 01/2015
  GSINTCOL(W_I) = WINT+" ("+[F:ADS1]LAN(W_I)+")"
Next
For W_I=1 To 9
    # Issue 112535
    #GWINVDES(W_I)="K:"+num$(GLONDES)+"X"
    GWINVDES(W_I)="K:"+num$(GLONDCT)+"X"
    If GSINTCOL(W_I)=""
        GWINVDES(W_I)="-"+GWINVDES(W_I)
    Endif
Next
Return
###########################################################
$OUVRE_BOITE
#-------------------------------#
# Après ouverture de la fenêtre #
#-------------------------------#
#----- Chargement des noms des Currbox de chaque tiroir -----#
Global Char     GBOXTCT(10),GBOXTCN(10)
GBOXTCT="GAU_CHE"+num$(find("TCT",OBJLIS(1..8))) : # Tables alphanumeriques
GBOXTCN="GAU_CHE"+num$(find("TCN",OBJLIS(1..8))) : # Tables numeriques
Return
###########################################################
$RAZCRE   : # FQ 46343 GA 03/2008
# FQ 55365 GA 09/2009 les colonnes restent dans la table si code activité désactivé
#If dim([F:TCT]LANNBR) > 0
# Local Integer WRET                                          # hcb 57658
# Call LECACT("CFG",WRET) From TRTX3                          # hcb 57658
#If WRET=1 & dim([F:TCT]LANNBR) > 0                           # hcb 57658
If dim([F:TCT]LANNBR) > 0                                     # hcb 57658
  Local  Integer W_I
  # Issue 112717
  #For W_I = 0 To [F:ADS1]NBRLAN-1
  For W_I = 0 To WNBRLAN-1
    If W_I >= dim([F:TCT]LAN) Break Endif  # Issue 105687 GA 01/2015
    [F:TCT]LAN(W_I) = [F:ADS1]LAN(W_I)
  Next
  [F:TCT]LANNBR = WNBRLAN
  [M:TCT1] = [F:TCT]
Endif
Return
###########################################################
$LIENS
#
# FQ 55365 GA 09/2009 les colonnes restent dans la table si code activité désactivé
#If dim([F:TCT]LANNBR) > 0
# Local Integer WRET                                          # hcb 57658
# Call LECACT("CFG",WRET) From TRTX3                          # hcb 57658
#If WRET=1 & dim([F:TCT]LANNBR) > 0                           # hcb 57658
If dim([F:TCT]LANNBR) > 0                                     # hcb 57658
  Raz WDESCOD
  Raz WLAN
  # Issue 112717 - 2015-11-27 by MAE : Si le nb de langue est sup à 10 = [F:TCT]LANNBR = 10
  If [F:TCT]LANNBR > 10
    [F:TCT]LANNBR = 10
  Endif
  For W_I = 0 To [F:TCT]LANNBR-1
    If W_I = 0
      WDESCOD(W_I)  = [F:TCT]DESCOD
      [F:TCT]DESCOD = ""
    Else
      WDESCOD(W_I) = evalue("[F:TCT]DESCOD"+num$(W_I))
      Assign "[F:TCT]DESCOD"+num$(W_I) With ""
    Endif
    WLAN      (W_I) = [F:TCT]LAN(W_I)
    [F:TCT]LAN(W_I) = ""
  Next W_I
  # Issue 112717
  #For W_I = 0 To [F:ADS1]NBRLAN-1
  For W_I = 0 To WNBRLAN-1
    If W_I >= dim([F:TCT]LAN) Break Endif  # Issue 105687 GA 01/2015
    [F:TCT]LAN(W_I) = [F:ADS1]LAN(W_I)
    W_J = find([F:ADS1]LAN(W_I),WLAN(0..[F:TCT]LANNBR-1))
    If W_J = 0
      If W_I = 0
        [F:TCT]DESCOD = [F:TCT]DESCOD
      Else
        Assign "[F:TCT]DESCOD"+num$(W_I) With [F:TCT]DESCOD
      Endif
    Else
      If W_I = 0
        [F:TCT]DESCOD = WDESCOD(W_J-1)
      Else
        If WDESCOD(W_J-1) = ""
          Assign "[F:TCT]DESCOD"+num$(W_I) With WDESCOD(0)
        Else
          Assign "[F:TCT]DESCOD"+num$(W_I) With WDESCOD(W_J-1)
        Endif
      Endif
    Endif
  Next W_I
  # Issue 112717  - 2015-11-26 by MAE : Si le nombre de langue du dossier > 10, limite à 10 (10 colonnes dans TABCTL)
  [F:TCT]LANNBR = WNBRLAN
  [M:TCT1] = [F:TCT]
Endif
If [M:TCT1]TCTTYP=1
   [M:TCT1]COD(nolign-1)=[M]ALPCOD(nolign-1)
Else
   [M:TCT1]COD(nolign-1)=num$([M:TCT1]NUMCOD(nolign-1))
Endif
Return
###########################################################
$FILGAUCHE
# FQ 60150 GA 11/2009 ne pas filtrer le tiroir "Derniers lus"
#FILTSUP      = "[F:TCT]TCTTYP =  1 & [F:TCT]TCTLIN = 1"
#FILGAUSUP(0) = "[F:TCT]TCTTYP <> 1 & [F:TCT]TCTLIN = 1"
Case currbox
 When GBOXTCN                     : # Tables numeriques
    FILGAUSUP(0)= "[F:TCT]TCTTYP <> 1 & [F:TCT]TCTLIN = 1"
 When "GAU_CHE"                   : # Tables alphanumeriques (GBOXTCT ?)
    FILTSUP= "[F:TCT]TCTTYP =  1 & [F:TCT]TCTLIN = 1"
  When "GAU_CHE9"                  : # Derniers lus
    FILGAUSUP(0)= ""
    FILTSUP= ""
Endcase
Return
###########################################################
$SETBOUT
# cas du tunnel pour consultation
If GCONSULT = 1
  Call VIREBOUT(CHAINE,"1CMADH") From GOBJET
Endif
# cas du tunnel pour consultation sans recherche
If GCONSULT = 2
  Call VIREBOUT(CHAINE,"RCMAD><LI0129SH") From GOBJET
Endif
If GREP <> ""
  Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
Return
###########################################################
$EXEBOUT
Case REP
  When "1" :
    If [M:TCT1]TCTTYP=1
      Sorta [M:TCT1]BASTAB [M:TCT1]BASTAB Order By COD(indice)
    Else
      Sorta [M:TCT1]BASTAB [M:TCT1]BASTAB Order By NUMCOD(indice)
    Endif
    Affzo [M:TCT1]1-99
  When "2" :
#    Call COPIE([M:TCT1]TCT)
  When "3"
     Gosub GEN_TRT : GCFG_GENTRT=0
Endcase
Return
###########################################################
$FERME
Kill GSINTCOL
Call IMPSCR        From ATRTX3
Return
###########################################################
Subprog COPIE(LPAR)
Value Char    LPAR
#
Local Char    W_TRA(100)
Local Integer W_OK
Local Integer W_ERR
Local Integer W_I, W_J, W_K
#
If GTRACE = ""
  Call OUVRE_TRACE(mess(117,188,1)-LPAR) From LECFIC
Endif
W_ERR = 0
If clalev([M:DIA]) = 0
  GMODIF = 0
  Local Mask ACOPIE [DIA]
  Raz [M:DIA]
  [M:DIA]OBJET = mess(118,188,1)+" : "+LPAR
  W_OK = 2
  zonsui = "DOSDES"
  Call DIALWIN(W_OK,mess(117,188,1),"ACOPIE") From GESECRAN
  If W_OK <> 2
   Goto COPIE_FIN
  Endif
Endif
# Tables en lecture (From)
If [M:DIA]DOSORG <> nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File TABCTL    [TCT1]
  Local File ATEXTRA   [AXX1]    # Issue 91643 GA 11/2013
Endif
# tables en écriture (To)
If [M:DIA]DOSDES = nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File =[M:DIA]DOSDES+".TABCTL"    [TCT2]
  Local File =[M:DIA]DOSDES+".ATEXTRA"   [AXX2]  # Issue 91643 GA 11/2013
Endif
# Contrôle copie possible
Read [TCT1]TCT0=LPAR;1
If fstat
  Goto COPIE_FIN
Endif
Read [TCT2]TCT0=LPAR;1
If fstat = 0
  If [F:TCT1]TCTTYP <> [F:TCT2]TCTTYP
    W_TRA = [F:TCT1]TCT-mess(119,188,1)
    W_ERR = 1
    Call ECR_TRACE(W_TRA,1) From GESECRAN
  Else
    W_OK = 2
    Call OUINON(mess(148,196,1),W_OK) From GESECRAN
    If W_OK <> 2
      Call OUVRE_TRACE(mess(117,188,1)-LPAR) From LECFIC
      Goto COPIE_FIN
    Endif
  Endif
Endif
If W_ERR <> 0
  Goto COPIE_FIN
Endif
# Tout est ok on copie
#
Call TEMPON("T") From GESECRAN
Gosub TRT_COPIE
Call TEMPOFF From GESECRAN
# Fin de copie
$COPIE_FIN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End
############################################################
# Etiquette pour action modélisée ACOPIE
$TRTCOP
If [M]DOSORG=nomap
  Local File TABCTL [TCT1]
  Local File ATEXTRA   [AXX1]    # Issue 91643 GA 11/2013
Else
  Local File =[M:DIA]DOSORG+".TABCTL" [TCT1]
  Local File =[M:DIA]DOSORG+".ATEXTRA"   [AXX2]  # Issue 91643 GA 11/2013
Endif
If [M]DOSDES=nomap
  Local File TABCTL [TCT2]
  Local File ATEXTRA   [AXX2]    # Issue 91643 GA 11/2013
Else
  Local File =[M:DIA]DOSDES+".TABCTL"    [TCT2]
  Local File =[M:DIA]DOSDES+".ATEXTRA"   [AXX2]  # Issue 91643 GA 11/2013
Endif

Gosub TRT_COPIE
Close Local File [TCT1], [TCT2]
Close Local File [AXX1], [AXX2]  # Issue 91643 GA 11/2013
Return

###########################################################
$TRT_COPIE
Call DEBTRANS    From GLOCK
Trbegin [TCT2]
Delete [TCT2] Where TCT = PARAM(2)
If fstat
    GOK=-1
    Goto ROLL_COPIE
Endif
# Copie abaques
Filter [TCT1] Where TCT = PARAM(2)
For [TCT1]
  [F:TCT2] = [F:TCT1]
  [F:TCT2]CREUSR = GUSER
  [F:TCT2]CREDAT = date$
  [F:TCT2]UPDUSR = ""
  [F:TCT2]UPDDAT = [0/0/0]
  Write [TCT2]
  If fstat
    GOK = 0
    Call FSTA("TCT2") From GLOCK
    Break
  Endif
  If [F:TCT2]TCTLIN = 1
    W_TRA = mess(91,123,1)-mess(105,188,1)-[F:TCT2]TCT
    Call ECR_TRACE(W_TRA,0) From GESECRAN
  Endif
  # Issue 91643 GA 11/2013
  Call COPTEXTRA("TABCTL","TCTDESAXX",[F:TCT1]TCT,"") From ATEXTRA
Next
Filter [TCT1]
If GOK <> 1
  Goto AB_COPIE
Else
  Commit
Endif
Return


############################################################
$GEN_TRT
Call TEMPON(mess(76,188,1)) From GESECRAN
Call GEN_WUVAR(nomap,"","") From CFGLIBA
adxmbm = adxmbm
Call TEMPOFF From GESECRAN
Return

############################################################
$AB_COPIE
Rollback
Return
############################################################
$ROLL_COPIE
Rollback
Call ROLL From GLOCK
If !GROLL
  Goto TRT_COPIE
Endif
Return
#############################################################
$ANNULE
Delete [AXX] Where CODFIC="TABCTL" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return  # FGR 17/12/2009 : X3SUIVI60986
Endif
Return
#############################################################
$CREATION
Call MAJTEXTRA([M]TCTDESAXX,"TABCTL","TCTDESAXX",[M]TCT,"") From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M]TCTDESAXX,"TABCTL","TCTDESAXX",[M]TCT,"") From ATEXTRA

Return
#############################################################
Subprog AV_COD(VALEUR)
Variable Char     VALEUR
#If [M]TCTTYP=1
#   VALEUR=[M]ALPCOD(nolign-1)
#Else
#   VALEUR=num$([M]NUMCOD(nolign-1))
#Endif
End
############################################################
Subprog AM_COD(VALEUR)
Variable Char     VALEUR
If [M]TCTTYP=1
   [M]ALPCOD(nolign-1)=VALEUR
Else
   [M]NUMCOD(nolign-1)=val(VALEUR)
Endif
End
############################################################
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
If [M]TCTTYP = 1
 VALEUR = vireblc(VALEUR,1)
 Call UNICITE(VALEUR,[M]ALPCOD(0..[M]BASTAB-1)) From OBJDIV
Else
 VALEUR = num$(val(VALEUR))     # JPJ E22591
 Call UNICITE(val(VALEUR),[M]NUMCOD(0..[M]BASTAB-1)) From OBJDIV
Endif
End
############################################################
Subprog AS_TCTTYP(VALEUR)
Variable Integer  VALEUR
If GREP <> "C" & GREP<>"D"
    mkstat = 2
Endif
End
############################################################
Subprog AV_TCTLIN(VALEUR)
Variable Decimal  VALEUR
VALEUR = nolign
End
############################################################
Subprog AS_DESCOD1(VALEUR)
Variable Char    VALEUR()
If GSINTCOL(1) = ""
  mkstat = 2
Else
  If VALEUR = ""
    VALEUR = [M:TCT1]DESCOD(nolign-1)
  Endif
Endif
End
