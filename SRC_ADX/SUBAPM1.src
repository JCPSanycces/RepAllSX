#<AdxTL>@(#)5.0.0.0 $Revision$
##------------------------------------------------------##
##------------------------------------------------------##
##                   PICKING                            ##
##------------------------------------------------------##
##------------------------------------------------------##
$PICKING
Local Integer REPONSE, SAVNOLIGN, SAVMXL, NOL, OK
Local  Char LIBEL(50)

SAVMXL    = adxmxl
adxmxl    = 1000
GPICK = 1

# Picking sur les fonctions  
Link [AFC0] With
&   [ATX]NUMERO = GLANGUE ; [AFC0]NOM
&   As [PIK]
&   Where TYPTRAIT <> 2
&   Order By Key MODULE

# sauvegarde indice ligne pour remplissage du tableau
SAVNOLIGN = nolign

Pickbox [PIK] PIC_KING
& mess(58,105,1)-" : "-mess([F:AFC0]MODULE,14,1) Titled  "",
& mess(2,13,1)-" : "-[F:AFC0]MENU Titled "",
& [F:AFC0]CODINT-" : "-[F:ATX]TEXTE Titled ""
& Sized(200,150)
& Titled mess(9,42,1)
& As [PIK]
Boxact [PIK]
Fillbox [PIK]

Boxinp [PIK] Using REPONSE 
Case REPONSE 
    When GSTAPIC : Gosub TRT_PICK  : Gosub FERME_PICK
    When GSTAPKF : Gosub FERME_PICK
Endcase
Return

#######################################
$TRT_PICK
Repeat
    Pick [PIK]
    Case status
        When 7     : Break
        When 28,37 : Gosub SEL_PICK   : If !OK : Break : Endif
        When 41,43 : Gosub DSEL_PICK
    Endcase
Affzo [M:APM1]15
Until 1=0
Return

############################
$SEL_PICK
OK=1
## Vérification de l'existence
NOL = find([F:AFC0]CODINT,[M:APM1]FONCTIONS(0..[M:APM1]NBFONCS-1)) 
If NOL : Return : Endif
If [M:APM1]NBFONCS + 1 > dim([M:APM1]FONCTIONS)
    Call ERREUR(mess(26,100,1)) From GESECRAN          # Tableau plein
    OK = 0
    Return
Endif
## Cas d'une insertion
If SAVNOLIGN - 1  < [M:APM1]NBFONCS
    Insa SAVNOLIGN-1,1,[M:APM1]NBFONCS [M:APM1]CODMENS,[M:APM1]FONCTIONS,[M:APM1]ZLIBMENUS
Endif

## Remplissage du tableau
Read [F:AFC1]CODINT = [F:AFC0]CODINT
[M:APM1]FONCTIONS(SAVNOLIGN-1) = [F:AFC1]CODINT
[M:APM1]CODMENS(SAVNOLIGN-1) = ""
If [F:AFC1]NOM =0
    [M:APM1]ZLIBMENUS(SAVNOLIGN-1) = " "
Else
    Call TEXTE([F:AFC1]NOM,LIBEL) From OBJDIV
    [M:APM1]ZLIBMENUS(SAVNOLIGN-1) = LIBEL
Endif
[M:APM1]NBFONCS += 1
SAVNOLIGN += 1
GREP="M" 

Setlbox [PIK]
Return

############################
$DSEL_PICK
NOL = find([F:AFC0]CODINT,[M:APM1]FONCTIONS(0..[M:APM1]NBFONCS-1))
If NOL
    Dislbox [PIK]
    Dela NOL-1 [M:APM1]NBFONCS
    [M:APM1]NBFONCS -= 1
Endif
Return

############################
$FERME_PICK
GPICK = 0
Boxclr [PIK]
adxmxl = SAVMXL
Return
