#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITRS26      Mise à jour de la zone                    Module Tiers   #
#               script spécifique dans l'action PAYECART
##########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Mise à jour de l'action PAYECART") From LECFIC
  Call MAJ_UTITRS26(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTITRS26(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Call ECR_TRACE("UTITRS26 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ACT])  =0  Local File =DOSSIER+".ACTION"   [ACT] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [ACT]
 Readlock [ACT]ACTION="PAYECART"
 If fstat = 0 & [F:ACT]SPETRT="SPEPAY"
  [F:ACT]SPETRT = "SPEPAY2"
  Rewrite [F:ACT]
  If !fstat WCOMPTEUR += 1 Endif
 Endif
Commit

Close Local File [ACT]

Call ECR_TRACE("UTITRS26 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTITRS26 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 : # Module tiers

If filinfo(filpath("FIL","ACTION","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTITRS26(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 : # N= module
If filinfo(filpath("FIL","ACTION","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table

Call MAJ_UTITRS26(APPLI)
End
