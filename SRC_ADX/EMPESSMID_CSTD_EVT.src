$AINSERT_AUPDATE_AFTER

#Write the data for all the EMPESSXXX classes to workflow
#Using activity codes - Check all classes and pass to workflow function in ESS_WRKFLOW_FUNC
#Manage call with activity codes
#---------------------All legislations------------------------------------------------------------#
Gosub PASS_CLASSES_WORKFLOW_EMPESSMID
Gosub PASS_CLASSES_WORKFLOW_EMPESSMID_EMPADR

Return

$PASS_CLASSES_WORKFLOW_EMPESSMID
#The following steps must be followed to trigger the workflow for all employee related records
#Declare all variables - Standard no custom code needed
Gosub PASS_CLASSES_WORKFLOW_VARIABLES From ESS_WRKFLOW_FUNC

#---------------------------------------------------------------------------------------------------#
#Before creating possible workflow records - indicate any properties that must be excluded (SYSPROP - From (30)
#..
#Specify the keys of the actual table - Char ALPKEY(250)(1..3),Integer INTKEY(1..3) ,Date DATKEY(1..3)
ALPKEY(0) = this.REFNUM

#Specify function variables
MAIN_CLASSCOD = "EMPLOIDMID"    #The main class that was used to create the ESSXXX Class
CLASSCOD      = "EMPESSMID"     #The ESS Class where the change occurred
THISUSR       = this.ACTX.USER

#EMPESSAFR
If this.EMPESSMID <> null
  #Getting paramater values
  CLASSPARAMFNC = func ESS_WRKFLOW_FUNC.GET_CLASS_PARAMETERS(MAIN_CLASSCOD,CTABLE,CABR) #Manual assignment
  If this.EMPESSMID <> null
    For COLLECTION_IND = 1 To maxtab(this.EMPESSMID)
      If CLASSPARAMFNC = [V]CST_AOK and this.EMPESSMID(COLLECTION_IND) <> null
        #Specify the keys needed for workflow (ALPKEY,INTKEY,DATKEY)
        INTKEY(0) = COLLECTION_IND

        #Test the status of the class and set WRK variable
        #This test must include the manual status added on class transfer
          If this.EMPESSMID(COLLECTION_IND).ASTALIN = [V]CST_ADEL
            WRK = "D"
          Else
            WRK = "M"
          Endif

        #New lines created by the user
        If this.EMPESSMID(COLLECTION_IND).TCH_MIDSTA <> "T"
          If this.EMPESSMID(COLLECTION_IND).ASTALIN <> [V]CST_ANEWDEL
            If this.EMPESSMID(COLLECTION_IND).ASTALIN = [V]CST_ANEW
              WRK = "C"
            Endif
          Endif
        Endif

        If WRK <> ""
          #A Function per class must be added to ESS_WRKLOW_FUNC
          CLASS_WRKFLOW = func ESS_WRKFLOW_FUNC.GENESSWRKFLOW_ESSWRKMID(WRK,this,THISUSR,this.EMPESSMID,this.EMPESSMID,
&         CLASSCOD,CTABLE, CABR,CLASS_ERROR,SYSPROP,ALPKEY,INTKEY,DATKEY,CLEOBJ)
        Endif
      Endif
    Next
  Endif
Endif

Return

$PASS_CLASSES_WORKFLOW_EMPESSMID_EMPADR
#The following steps must be followed to trigger the workflow for all employee related records
#Declare all variables - Standard no custom code needed
Gosub PASS_CLASSES_WORKFLOW_VARIABLES From ESS_WRKFLOW_FUNC

#---------------------------------------------------------------------------------------------------#
#Before creating possible workflow records - indicate any properties that must be excluded (SYSPROP - From (30)
#..

#Specify function variables
MAIN_CLASSCOD = "EMPLOIDMID"    #The main class that was used to create the ESSXXX Class
CLASSCOD      = "EMPESSMID" #The ESS Class where the change occurred
THISUSR       = this.ACTX.USER

#EMPESSAFR
If this.EMPESSMID <> null
  #Getting paramater values
  #CLASSPARAMFNC = func ESS_WRKFLOW_FUNC.GET_CLASS_PARAMETERS(MAIN_CLASSCOD,CTABLE,CABR) #Manual assignment
  CTABLE  = "EMPLOIDMIDRT"
  CABR    = "EMIR"
  If this.EMPESSMID.EMPADR <> null
    For COLLECTION_IND = 1 To maxtab(this.EMPESSMID.EMPADR)
      If CLASSPARAMFNC = [V]CST_AOK and this.EMPESSMID.EMPADR(COLLECTION_IND) <> null
        #Specify the keys of the actual table - Char ALPKEY(250)(1..3),Integer INTKEY(1..3) ,Date DATKEY(1..3)
        Raz INTKEY,DATKEY,ALPKEY
        ALPKEY(0) = this.REFNUM
        INTKEY(0) = COLLECTION_IND

        #Test the status of the class and set WRK variable
        #This test must include the manual status added on class transfer
        If this.EMPESSMID.EMPADR(COLLECTION_IND).TCH_ADDSTA = "T"
          If this.EMPESSMID.EMPADR(COLLECTION_IND).ASTALIN = [V]CST_ANEWDEL
            WRK = "D"
          Else
            WRK = "M"
          Endif
        Endif

        #New lines created by the user
        If this.EMPESSMID.EMPADR(COLLECTION_IND).TCH_ADDSTA <> "T"
          If this.EMPESSMID.EMPADR(COLLECTION_IND).ASTALIN <> [V]CST_ANEWDEL
            If this.EMPESSMID.EMPADR(COLLECTION_IND).ASTALIN = [V]CST_ANEW
              WRK = "C"
            Endif
          Endif
        Endif
        If WRK <> ""
          #A Function per class must be added to ESS_WRKLOW_FUNC
          CLASS_WRKFLOW = func ESS_WRKFLOW_FUNC.GENESSWRKFLOW_ESSWRKMID_EMPADR(WRK,this,THISUSR,this.EMPESSMID,this.EMPESSMID.EMPADR(COLLECTION_IND),
&         CLASSCOD,CTABLE, CABR,CLASS_ERROR,SYSPROP,ALPKEY,INTKEY,DATKEY,CLEOBJ)
        Endif
      Endif
    Next
  Endif
Endif

Return

