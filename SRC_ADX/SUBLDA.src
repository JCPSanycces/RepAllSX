################################################################################
#    PARAMETRAGE BIEN
#    FGR
#    Création le : 14/03/2003
#    Modification le : 20/11/2003
#-------------------------------------------------------------------------------
# GLE - 10.12.2009 - FQ60756 - Autoriser les champs "affichés" dans la sélection lien dépense-biens
#-------------------------------------------------------------------------------
# PROGRAMMES ACTIONS :
################################################################################
################################################################################
# Mon petit bazar jusqu'à ce que je le connaisse par coeur
#     Infbox "ligne = "-num$(nolign)
################################################################################
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("LDA",GBIDC1,GBIDC2) From GOBJET
End

################################################################################
$ACTION
  #Infbox "ACTION = "-num$(ACTION)
  Case ACTION
    When "OUVRE"            : Gosub OUVRE
    When "LIENS"            : Gosub LIENS
    When "SETBOUT"          : Gosub SETBOUT
    When Default
  Endcase
Return
################################################################################

#-------------------------------------------------------------------------------
$OUVRE
  If clalev([F:LDA])=0  : Local File PARLDAP  [LDA]  : Endif : # Paramétrage liaison dépense à bien
  If clalev([F:AMZB])=0 : Local File AMSKZON  [AMZB] : Endif : # Dictionnaire des champs écran
Return

#-------------------------------------------------------------------------------
$LIENS
Local Char CHAINE, CHECRAN(250), LCODZON(20)
Local Integer N_I

  Call GET_LISTE_ECRAN ("OLOF", CHECRAN) From GLOBIENS
  If CHECRAN = "" Then
    CHECRAN = "1=1"
  Endif
  For N_I = 1 To [M:LDA0]NBLDAP
    LCODZON =  func GLOBIENS.VIRE_INDICE_CODZON ([M:LDA0]CODZON(N_I-1))
    Filter [AMZB] Where CODZON=LCODZON and evalue(CHECRAN)
    Read [AMZB]CODE Last
    Filter [AMZB]
    [M:LDA0]ZINTIT(N_I-1) = func GLOBIENS.GET_LIBELLE_CHAMP ([M:LDA0]CPY, [F:AMZB]CODMSK, [M:LDA0]CODZON(N_I-1), GVML_OMDEPEN)
    #------------------------------
    # Suite de la boucle
  Next N_I
Return

#-------------------------------------------------------------------------------
$SETBOUT
Local Integer LSTAT : # réponse call VERFALLCPY

  # Pas de suppression du paramétrage par défaut en dehors des environnements de développement
  If GADONIX=G_NON & [M]CPY="" Then
   Call VIREBOUT(CHAINE,"A") From GOBJET
  Else
    # Pas de suppression du paramétrage par défaut si pas d'habilitation "tous sites du dossier"
    If [M]CPY="" & GNBAUZ <> GNBSITE Then
      Call VIREBOUT(CHAINE,"A") From GOBJET
    Else
      # Pas de suppression du paramétrage d'1 société si pas d'habilitation "tous sites de la société"
      Call VERFALLFCY([M]CPY,[L]LSTAT) From SUPCPT
      If [L]LSTAT < 1 Then
        Call VIREBOUT(CHAINE,"A") From GOBJET
      Endif
    Endif
  Endif
Return

################################################################################
# ECRAN : PARLDAP
################################################################################
########################################
Subprog AP_CODZON(VALEUR)
Variable Char    VALEUR()

Local Char CHAINE, CHECRAN(250), LCODZON(20)
Local Integer N_I

  #----------------------------
  Call GET_LISTE_ECRAN ("OLOF", CHECRAN) From GLOBIENS
  If CHECRAN = "" Then
    CHECRAN = "1=1"
  Endif
  #----------------------------
  LCODZON =  func GLOBIENS.VIRE_INDICE_CODZON (VALEUR)
  Filter [AMZB] Where CODZON=LCODZON and evalue(CHECRAN)
  Read [AMZB]CODE Last
  Filter [AMZB]
  If fstat>2 Then
    # Erreur : code inexistant
    GMESSAGE = mess(25,7770,1) : # Champ inexistant
    GERR     = 1
    mkstat   = 2
    End
  Else
    #----------------------------
    #If [F:AMZB]SAIAFF=2 or [F:AMZB]SAIAFF=3 Then : # FQ60756
    If [F:AMZB]SAIAFF=3 Then
      # Erreur : Champ invisible en standard. Choix interdit
      GMESSAGE = mess(26,7770,1) : # Champ invisible en standard. Il ne peut être choisi
      GERR     = 1
      mkstat   = 2
      End
    Elsif [F:AMZB]CODTYP='W' &[F:AMZB]CODTYP='ABS' Then
      # Erreur : Champ interdit
      GMESSAGE = mess(26,7770,1) : # Champ invisible en standard. Il ne peut être choisi
      GERR     = 1
      mkstat   = 2
      End
    Else
      #----------------------------
      For N_I = 1 To [M:LDA0]NBLDAP
        If N_I <> nolign Then
          If [M:LDA0]CODZON(N_I-1) = VALEUR Then
            # Erreur : Un champ ne peut être saisi plusieurs fois
            GMESSAGE = mess(27,7770,1)-num$(N_I) : # Ce champ a déjà été saisi à la ligne
            GERR     = 1
            mkstat   = 2
            End
          Endif
        Endif
        #------------------------------
        # Suite de la boucle
      Next N_I
      #----------------------------
      [M:LDA0]CODZON(nolign-1) = VALEUR
      [M:LDA0]ZINTIT(nolign-1) = func GLOBIENS.GET_LIBELLE_CHAMP ([M:LDA0]CPY, [F:AMZB]CODMSK, VALEUR, GVML_OMDEPEN)
      #----------------------------
      Affzo [M:LDA0]CODZON(nolign-1)
      Affzo [M:LDA0]ZINTIT(nolign-1)
      #----------------------------
    Endif
  Endif
End


