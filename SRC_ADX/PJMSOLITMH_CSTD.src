#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMSOLITMH
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER                     From PJMSOLITMH_CSTD_EVENTS
      Endcase
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SPL_RESET_ERRORS"             : Gosub SPL_RESET_ERRORS               From PJMSOLITMH_CSTD_METHODS
    When "GET_PSONUM_FROM_SALE_DOC"     : Gosub GET_PSONUM_FROM_SALE_DOC       From PJMSOLITMH_CSTD_METHODS    # Issue 7539/119856 - 2016-11-18 by TEJAC : Sales Document Delinking
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
    When "DOC_DELINK"                  : Gosub DOC_DELINK                      From PJMSOLITMH_CSTD_OPERATIONS        # Issue 7539/119856 - 2016-11-18 by TEJAC : Sales Document Delinking
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "VACBPR"                      : Gosub VACBPR                          From PJMSOLITMH_CSTD_PROPERTIES
    When "PTE"                         : Gosub PTE                             From PJMSOLITMH_CSTD_PROPERTIES
  Endcase
Return

