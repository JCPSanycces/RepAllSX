#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion objet AYM
Call OBJET("AYM",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Xtend:  Gestion des Messages Xtend 
#  Version 0001
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "FERME"          : Gosub FERME
 When "FILTRE"         : Gosub FILTRE
 When "FILGAUCHE"      : Gosub FILGAUCHE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "OUVRE"          : Gosub OUVRE
 When "OUVRE_BOITE"    : Gosub OUVRE_BOITE
 When "RAZCRE"         : Gosub RAZCRE
 When "SETBOUT"        : Gosub SETBOUT
 When "CREATION"       : Gosub CREATION
 When "MODIF"          : Gosub MODIF
 When "ANNULE"         : Gosub ANNULE
 When default
Endcase
Return

$CREATION
$MODIF
#  textes AXX
Call MAJTEXTRA([M]INTIT,"AYTMES","INTIT",[M:AYM1]FCYCOD,[M:AYM1]MESCOD) From  ATEXTRA
Return

$ANNULE
Delete [AXX] Where CODFIC="AYTMES" & ZONE = "INTIT"   & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
Return

$AVANT_OUVRE
#---------------------------------------------------------------#
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

$OUVRE
#---------------------------------------------------------------#
Local Char WSTR1 (250), WFCYFLT(200)
Local Integer WI
Local Integer W_MES(0..1), W_LANCHP
Global Char    GLANREF(GLONLAN) : GLANREF=GLANGUE    # PF12 sur n° ligne message

Gosub DSYFCY From SUBAYS     # Infos site

WFCYFLT = func SUBAYS.FILTFCY

If clalev([F:AYS])=0 : Local File AYTFCY [AYS] : Endif
Read [F:AYS]AYS0 = GAYTFCYWRK 
Return

#---------------------------------------------------------------#
$OUVRE_BOITE
#----- Chargement des noms des Currbox de chaque tiroir -----#
Global Char GBOXAY1(10)
GBOXAY1="GAU_CHE"+num$(find("AY1",OBJLIS(1..8))) 
Return

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
Return

#---------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Endif
Return

#---------------------------------------------------------------#
$LIENS
Gosub DSYFCY From SUBAYS     # Infos site
W_LANCHP=[F:AYM]LANCHP : Gosub AFF_CHPDES
W_MES(0)=[F:AYM]LANNUM(0) : W_MES(1)=[F:AYM]LANNUM(1) : Gosub AFF_MES
Return

#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return

#---------------------------------------------------------------#
$FILGAUCHE
If currbox=GBOXAY1
  FILGAUSUP(0)= WFCYFLT 
Endif
Return

#---------------------------------------------------------------#
$RAZCRE
Gosub DSYFCY From SUBAYS     # Infos site
#[M]CODACT=WFCY_CODACT        # Code activité site
Gosub AFF_MES : Affzo [M:AYM1]15
Return

#---------------------------------------------------------------#
$INICRE
$INIMOD
# Clé browser X3
[F]BRWX3=[F]FCYCOD+"_"+[F]MESCOD 
#
Return

#---------------------------------------------------------------#
$AFF_MES
Effzo LANMES
If W_MES(0)<>0
    Read[AST]CLE=[M]LANCHP;W_MES(0);GLANGUE
    If fstat = 0   
        [M]LANMES = [F:AST]LANMES
    Endif
Endif
If W_MES(1)<>0
    Read[AST]CLE=[M]LANCHP;W_MES(1);GLANGUE
    If fstat = 0   
        [M]LANMES += [F:AST]LANMES
    Endif
Endif
Return

#---------------------------------------------------------------#
$AFF_CHPDES
[M]CHPDES=mess(0,W_LANCHP,1)
Return


######################################################################################
## Ecran AYM1
######################################################################################

Subprog C_LANNUM(VALEUR)
Variable Decimal VALEUR
If indice=0 and VALEUR=0
 mkstat = 2 : GMESSAGE = mess(10,123,1) : End
Endif
#
Local Integer W_MES(0..1)
Effzo LANMES
If indice=0 
    W_MES(0)=VALEUR : W_MES(1)=[M]LANNUM(1)
Else
    W_MES(1)=VALEUR : W_MES(0)=[M]LANNUM(0)
Endif
Gosub AFF_MES : Affzo [M]LANMES
End


Subprog C_LANCHP(VALEUR)
Variable Decimal VALEUR
W_LANCHP=VALEUR : Gosub AFF_CHPDES
End

