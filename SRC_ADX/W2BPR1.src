#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque BPR1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_CCNFLG
Onevent INIT_AREA Call D_CCNFLG(zc) From W2BPR1
Onevent BEFORE_INPUT Call AS_CCNFLG(zc) From W2BPR1
Return

Subprog D_CCNFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]CCNFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CCNFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


