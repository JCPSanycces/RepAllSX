#<AdxTL>@(#)160.0.0.0 $Revision$
#########################################################################
# Traitement liĂŠe Ă  l'action d'ĂŠclatement des demandes de livraisons    #
#    Action : TRTREPPER                                                 #
#########################################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub OK
 When "EXEC"       : Gosub EXEC
Endcase

Return

#########################################################################
# Actions sur le traitement standard                                    #
#########################################################################

$INIT
Local Integer I, J, NOL
Local Decimal  COEF
Local Integer  WRETOUR
Local Char     WNUMTEX(12)

#   --> Ctrl autorisation ĂŠclatement (on teste l'autorisation de modification)
GBIDC2="M": GFCY=[M]SALFCY : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GZNUM=0:GERR = 1:GMESSAGE = mess(2,104,1): FIN=1 : Return : Endif

# Pas d'ĂŠxĂŠcution si des pĂŠriodes antĂŠrieures (semaine ou mois) existent
If nolign > 1 & [M]CAD(nolign-1) = 2 & [M]CAD(nolign-2) <> 1
   GERR=1 : GMESSAGE=mess(23,192,1)
   FIN=1 : Return
Endif
If nolign > 1 & [M]CAD(nolign-1) = 3 & [M]CAD(nolign-2) = 3
   GERR=1 : GMESSAGE=mess(23,192,1)
   FIN=1 : Return
Endif
NOL = nolign-1

Return

#########################################################################
$OUVRE
Local Integer  I, J, OK
Local Integer  NOL           : # No ligne Ă  traiter
Local Integer  DERPER        : # indice du dernier jour de rĂŠpartition
Local Integer  TOTPER        : # diviseur pour calcul du prorata
Local Decimal  ENCQTY        : # quantitĂŠ dĂŠjĂ  rĂŠpartie
Local Integer  SEMDEB        : # semaine dĂŠbut
Local Integer  SEMFIN        : # semaine fin
Local Integer  NBSEM         : # nombre de semaines
Local Integer  REPONSE
Local Decimal  WQTY1, WQTY2
Local Char     WWJOUR(2), WWMOIS(2), WWAN(4)
Local Decimal  WARR          : # code arrondi de l'unitĂŠ

If clalev([F:TUN])=0 : Local File TABUNIT   [TUN] : Endif
If clalev([F:BPD])=0 : Local File BPDLVCUST [BPD] : Endif : # 88893

NOL = nolign-1   : # En V140 ne pas recuperer nolign ici

Return

#########################################################################
$DEBUT

# 88893 : Ctrl jours ouvrĂŠs et pĂŠriodes indispo
Local Date    WWDAT
Local Char    WWPER
Local Integer J, K
Local Integer WUVYDAY (0..6)
# 88893

#NOL = nolign-1   : # En V140 ne pas recuperer nolign (il est casse)

[M:SOQ1]ECLAT  = 0
Raz [M:RPER]
[M:RPER]SAU     = [M:SOQ1]SAU
[M:RPER]XDLVDAT = [M:SOQ1]XDLVDAT(NOL)
[M:RPER]QTY     = [M:SOQ1]QTY(NOL)
#[M:RPER]YTOT    = [M:SOQ1]QTY(NOL) # FGR 27/02/2014 : X3SUIVI97295
[M:RPER]YTOT    = 0                 # FGR 27/02/2014 : X3SUIVI97295
[M:RPER]CAD     = [M:SOQ1]CAD(NOL)
WARR=1                               : # par defaut pas de decimales
Read [TUN]TUN0=[M:RPER]SAU
If !fstat
   Case [F:TUN]UOMDEC
        When 0         WARR=1
        When 1         WARR=0.1
        When 2         WARR=0.01
        When 3         WARR=0.001
        When 4         WARR=0.0001
        When 5         WARR=0.00001
        When 6         WARR=0.000001
   Endcase
Endif

[M:RPER]YNBLIG  = 7
ENCQTY = 0

# Eclatement par dĂŠfaut d'une semaine en jours
If [M:RPER]CAD = 2
   TOTPER = sum([F:SOC]DSPPRC(0..6))
   If TOTPER = 0
      DERPER = 6
   Else
      For I = 6 To 0 Step -1
         If [F:SOC]DSPPRC(I) <> 0 DERPER = I : Break : Endif
      Next I
   Endif
   # FGR 27/02/2014 : X3SUIVI97295 (dĂŠbut)
   Local Integer NDAYOPEN

   If [F:BPD]BPCNUM<>[M:SOQ1]BPCORD | [F:BPD]BPAADD<>[M:SOQ1]BPAADD
     Read [BPD] BPD0=[M:SOQ1]BPCORD;[M:SOQ1]BPAADD
     If fstat Raz [F:BPD] : Endif
   Endif
   For K=0 To 6
     WUVYDAY(K) = evalue ("[F:BPD]UVYDAY"+num$(K+1))
     If WUVYDAY(K) = 2 Then
       NDAYOPEN += 1
     Endif
   Next
   # FGR 27/02/2014 : X3SUIVI97295 (fin)
   If TOTPER = 0
       # FGR 27/02/2014 : X3SUIVI97295 (dĂŠbut)
       #WQTY1=arr([M:RPER]QTY/7,WARR) : # modif jl
       #WQTY2=[M:RPER]QTY-(WQTY1*7)   : # modif jl
       WQTY1=arr([M:RPER]QTY/NDAYOPEN,WARR) : # modif jl
       WQTY2=[M:RPER]QTY-(WQTY1*NDAYOPEN)   : # modif jl
       # FGR 27/02/2014 : X3SUIVI97295 (fin)
   Endif
   For I = 0 To 6
# 88893 : Ctrl jours ouvrĂŠs et pĂŠriodes indispo
#      [M:RPER]YDAT(I) = [M:SOQ1]DEMDLVDAT(NOL) + I
#      If len(num$(day([M:RPER]YDAT(I)))) = 1
#         WWJOUR = "0"+num$(day([M:RPER]YDAT(I)))
#      Else
#         WWJOUR = num$(day([M:RPER]YDAT(I)))
#      Endif
#      If len(num$(month([M:RPER]YDAT(I)))) = 1
#         WWMOIS = "0"+num$(month([M:RPER]YDAT(I)))
#      Else
#         WWMOIS = num$(month([M:RPER]YDAT(I)))
#      Endif
#      WWAN = num$(year([M:RPER]YDAT(I)))
#
#      [M:RPER]YPER(I) = format$("D:"+GFMDAT4,gdat$(val(WWJOUR),val(WWMOIS),val(WWAN)))
      WWDAT = [M:SOQ1]DEMDLVDAT(NOL) + I
      If len(num$(day(WWDAT))) = 1
         WWJOUR = "0"+num$(day(WWDAT))
      Else
         WWJOUR = num$(day(WWDAT))
      Endif
      If len(num$(month(WWDAT))) = 1
         WWMOIS = "0"+num$(month(WWDAT))
      Else
         WWMOIS = num$(month(WWDAT))
      Endif
      WWAN = num$(year(WWDAT))

      WWPER = format$("D:"+GFMDAT4,gdat$(val(WWJOUR),val(WWMOIS),val(WWAN)))

      GBIDA1=gdat$(val(WWJOUR),val(WWMOIS),val(WWAN))
      GBIDA2=gdat$(val(WWJOUR),val(WWMOIS),val(WWAN))
      # FGR 27/02/2014 : X3SUIVI97295 (dĂŠbut)
      #If [F:BPD]BPCNUM<>[M:SOQ1]BPCORD | [F:BPD]BPAADD<>[M:SOQ1]BPAADD
      #  Read [BPD] BPD0=[M:SOQ1]BPCORD;[M:SOQ1]BPAADD
      #  If fstat Raz [F:BPD] : Endif
      #Endif
      #For K=0 To 6
      #  WUVYDAY(K) = evalue ("[F:BPD]UVYDAY"+num$(K+1))
      #Next
      # FGR 27/02/2014 : X3SUIVI97295 (fin)
      Call CTL_JOU2(GBIDA1,GBIDA2,WUVYDAY,[F:BPD]UVYCOD,0) From CONTX3
      Raz GMESSAGE
      If GBIDA2 = GBIDA1 & mkstat=0
          [M:RPER]YDAT(J) = WWDAT
          [M:RPER]YPER(J) = WWPER
#          [M:RPER]YDEMSTA(I) = 1
#          If TOTPER = 0
#             [M:RPER]YQTY(I) = WQTY1
#             If WQTY2<>0
#                If WQTY2>0 : [M:RPER]YQTY(I) += WARR : WQTY2 -=WARR : Endif
#                If WQTY2<0 : [M:RPER]YQTY(I) -= WARR : WQTY2 +=WARR : Endif
#             Endif
#          Else
#             If I <= DERPER
#                [M:RPER]YQTY(I) = [M:RPER]QTY * [F:SOC]DSPPRC(I) / TOTPER
#                Call QTEARR([M:RPER]YQTY(I),[M:RPER]SAU) From TRTDIV
#                ENCQTY += [M:RPER]YQTY(I)
#             Endif
#          Endif
          [M:RPER]YDEMSTA(J) = 1
          If TOTPER = 0
             [M:RPER]YQTY(J) = WQTY1
             If WQTY2<>0
                If WQTY2>0 : [M:RPER]YQTY(J) += WARR : WQTY2 -=WARR : Endif
                If WQTY2<0 : [M:RPER]YQTY(J) -= WARR : WQTY2 +=WARR : Endif
             Endif
          Else
             If I <= DERPER
                [M:RPER]YQTY(J) = [M:RPER]QTY * [F:SOC]DSPPRC(J) / TOTPER
                Call QTEARR([M:RPER]YQTY(J),[M:RPER]SAU) From TRTDIV
             Endif
          Endif
          ENCQTY += [M:RPER]YQTY(J)
          [M:RPER]YTOT += [M:RPER]YQTY(J)  # FGR 27/02/2014 : X3SUIVI97295
          J+=1
      Else
          mkstat=0
      Endif
# 88893 : Ctrl jours ouvrĂŠs et pĂŠriodes indispo
   Next I
# 88893 : Ctrl jours ouvrĂŠs et pĂŠriodes indispo
#   If TOTPER <> 0
#      WQTY2 = [M:RPER]QTY - ENCQTY
#      For I = 0 To 6
#         If WQTY2 > 0
#            [M:RPER]YQTY(I) += 1
#            WQTY2 -= 1
#         Elsif WQTY2 < 0
#            If [M:RPER]YQTY(I) > 0
#               [M:RPER]YQTY(I) -= 1
#               WQTY2 += 1
#            Endif
#         Endif
#      Next I
#   Endif
   [M:RPER]YNBLIG  = J
   If [M:RPER]YNBLIG>0
#     Si la qtĂŠ Ă  rĂŠpartir ne l'a pas ĂŠtĂŠ complĂ¨tement, rĂŠpartition du reste
      WQTY2 = [M:RPER]QTY - ENCQTY
      WQTY1 = arr(WQTY2/[M:RPER]YNBLIG, WARR)
      If WQTY1<>0
        For I = 0 To [M:RPER]YNBLIG-1
              [M:RPER]YTOT -= [M:RPER]YQTY(J)                                  # FGR 27/02/2014 : X3SUIVI97295
              [M:RPER]YQTY(I) = max(0,[M:RPER]YQTY(I)+WQTY1)
              [M:RPER]YTOT += [M:RPER]YQTY(J)                                  # FGR 27/02/2014 : X3SUIVI97295
              ENCQTY+=WQTY1
              # Si reste, rĂŠpartition sur la premiĂ¨re ligne (comme l'arrondi)
              If I=[M:RPER]YNBLIG-1 & ENCQTY<[M:RPER]QTY
                  [M:RPER]YTOT -= [M:RPER]YQTY(0)                              # FGR 27/02/2014 : X3SUIVI97295
                  [M:RPER]YQTY(0)=max(0, [M:RPER]YQTY(0)+([M:RPER]QTY-ENCQTY))
                  [M:RPER]YTOT += [M:RPER]YQTY(0)                              # FGR 27/02/2014 : X3SUIVI97295
              Endif
        Next I
      Endif
   Endif
# 88893 : Ctrl jours ouvrĂŠs et pĂŠriodes indispo
# Eclatement par dĂŠfaut d'un mois en semaines
Else
   # DĂŠtermination de la premiĂ¨re semaine du mois
   [M:RPER]YTOT = [M:RPER]QTY                                                  # FGR 14/01/2015 : X3SUIVI104853
   SEMDEB = week([M:SOQ1]DEMDLVDAT(NOL))
   If SEMDEB=53
       #-----------------------------------------------------------------#
       # on regarde si le 4Ă¨me jour de la semaine est sur annee suivante #
       #-----------------------------------------------------------------#
       If  year(aweek (SEMDEB, year([M:SOQ1]DEMDLVDAT(NOL))+ 3)) <> year([M:SOQ1]DEMDLVDAT(NOL))
           SEMDEB=01
       Endif
   Endif
   If dayn([M:SOQ1]DEMDLVDAT(NOL)) > 4
      SEMDEB += 1
   Endif
   # DĂŠtermination de la derniĂ¨re semaine du mois
   SEMFIN = week(eomonth(gdat$(01,[M:SOQ1]MON(NOL),[M:SOQ1]YEA(NOL))))
   If dayn(eomonth(gdat$(01,[M:SOQ1]MON(NOL),[M:SOQ1]YEA(NOL)))) < 4
      SEMFIN -= 1
   Endif
   NBSEM = SEMFIN - SEMDEB + 1
   [M:RPER]YNBLIG = NBSEM
    If NBSEM<>0
       WQTY1=arr([M:RPER]QTY/NBSEM,WARR) : # modif jl
    Endif
    WQTY2=[M:RPER]QTY-(WQTY1*NBSEM)      : # modif jl

   For I = 0 To NBSEM-1
      If left$(GFMMOI,2) = "MM"
         If SEMDEB + I < 10
            [M:RPER]YPER(I) = "00"+num$(SEMDEB+I)+"-"+num$([M:SOQ1]YEA(NOL))
         Else
            [M:RPER]YPER(I) = "0"+num$(SEMDEB+I)+"-"+num$([M:SOQ1]YEA(NOL))
         Endif
      Else
         If SEMDEB + I < 10
            [M:RPER]YPER(I) = num$([M:SOQ1]YEA(NOL))+"-"+"00"+num$(SEMDEB+I)
         Else
            [M:RPER]YPER(I) = num$([M:SOQ1]YEA(NOL))+"-"+"0"+num$(SEMDEB+I)
         Endif
      Endif
      [M:RPER]YDAT(I) = aweek(SEMDEB+I,[M:SOQ1]YEA(NOL))
      [M:RPER]YDEMSTA(I) = 2

      [M:RPER]YQTY(I) = WQTY1
      If WQTY2<>0
         If WQTY2>0 : [M:RPER]YQTY(I) += WARR : WQTY2 -=WARR : Endif
         If WQTY2<0 : [M:RPER]YQTY(I) -= WARR : WQTY2 +=WARR : Endif
      Endif
   Next I
Endif
Affzo [M:RPER]1-99
Return

#########################################################################
$OK

# 88893 : Ctrl jours ouvrĂŠs et pĂŠriodes indispo
J = 0
If [M:RPER]YNBLIG = 0 Return Endif
# 88893

# La rĂŠpartition ne correspond pas Ă  la quantitĂŠ Ă  rĂŠpartir
If [M:RPER]YTOT <> [M:RPER]QTY
   GERR=1 : GMESSAGE=mess(85,199,1)
   FIN=0  : Return
Endif

J = 0
For I = 0 To 6
   If [M:RPER]YQTY(I) <> 0
      [M:SOQ1]PERLIV(J) = [M:RPER]YPER(I)
      [M:SOQ1]DATLIV(J) = [M:RPER]YDAT(I)
      [M:SOQ1]QTELIV(J) = [M:RPER]YQTY(I)
      [M:SOQ1]ENCSTA(J) = [M:RPER]YDEMSTA(I)
      J += 1
   Endif
Next I
[M:SOQ1]ECLAT = J
Return

#########################################################################
$EXEC
nolign = NOL+1
If [M:SOQ1]ECLAT=0 Return Endif

If [M:SOQ1]NBLIG + [M:SOQ1]ECLAT >= dim([M:SOQ1]XDLVDAT) - 1
   GERR=1 : GMESSAGE=mess(122,199,1)
   Return
Endif

# ContrĂ´le de l'insertion
If nolign < [M:SOQ1]NBLIG
   If [M:SOQ1]SOQSEQ(nolign) - [M:SOQ1]SOQSEQ(nolign-1) <= [M:SOQ1]ECLAT
      GERR=1 : GMESSAGE=mess(122,199,1)
      Return
   Endif
Endif

# Ouverture des n lignes Ă  gĂŠnĂŠrer
[M:SOQ1]NBLIG += [M:SOQ1]ECLAT
Insa nolign,[M:SOQ1]ECLAT,[M:SOQ1]NBLIG [M:SOQ1]NBLIG
nolign = NOL+2
#status = 0
#Call LINNUM("SOQSEQ") From TABLEAUX

# Alimentation des nouvelles lignes
J = 0
For I = NOL+1 To NOL+[M:SOQ1]ECLAT
   [M:SOQ1]XDLVDAT(I)   = [M:SOQ1]PERLIV(J)
   [M:SOQ1]DEMDLVDAT(I) = [M:SOQ1]DATLIV(J)
   [M:SOQ1]DEMSTA(I)    = [M:SOQ1]ENCSTA(J)
   [M:SOQ1]QTY(I)       = [M:SOQ1]QTELIV(J)
   If [M:SOQ1]CAD(NOL) = 3
      [M:SOQ1]CAD(I) = 2
   Else
      [M:SOQ1]CAD(I) = 1
   Endif
   If [M:SOQ1]CAD(I) = 1
#     Format DD-MM-YYYY
      If left$(GFMDAT,2) = "DD"
         [M:SOQ1]DLVDAY(I) = val(left$([M:SOQ1]XDLVDAT(I),2))
         [M:SOQ1]MON(I)    = val(mid$([M:SOQ1]XDLVDAT(I),4,2))
         [M:SOQ1]YEA(I)    = val(right$([M:SOQ1]XDLVDAT(I),7))
#     Format YYYY-MM-DD
      Elsif left$(GFMDAT,2) = "YY"
         [M:SOQ1]YEA(I)    = val(left$([M:SOQ1]XDLVDAT(I),4))
         [M:SOQ1]MON(I)    = val(mid$([M:SOQ1]XDLVDAT(I),6,2))
         [M:SOQ1]DLVDAY(I) = val(right$([M:SOQ1]XDLVDAT(I),9))
#     Format MM-DD-YYYY
      Else
         [M:SOQ1]MON(I)    = val(left$([M:SOQ1]XDLVDAT(I),2))
         [M:SOQ1]DLVDAY(I) = val(mid$([M:SOQ1]XDLVDAT(I),4,2))
         [M:SOQ1]YEA(I)    = val(right$([M:SOQ1]XDLVDAT(I),7))
      Endif
#         [M:SOQ1]SHIDAT(I) = [M:SOQ1]DEMDLVDAT(I) - [M:SOQ1]DAYLTI(NOL)
#         Call CTL_JOU([M:SOQ1]SHIDAT(I),[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
      Call CALC_SHIDAT([M:SOQ1]DEMDLVDAT(I),[M:SOQ1]DAYLTI(NOL),[M:SOQ1]DSTOFCY(NOL),1,1,[0/0/0],[M:SOQ1]SHIDAT(I)) From TRTVENDAT
   Else
      [M:SOQ1]WEE(I)    = val(left$([M:SOQ1]XDLVDAT(I),3))
      [M:SOQ1]YEA(I)    = val(right$([M:SOQ1]XDLVDAT(I),5))
   Endif

   [M:SOQ1]SOQSTA(I) = 1
   If [M:SOQ1]DEMDLVDAT(I) < date$  [M:SOQ1]SOQSTA(I) = 2 : Endif
   Call CNVQTY([M:SOQ1]QTY(I),[M:SOQ1]SAUSTUCOE,[M:SOQ1]STU, [M:SOQ1]QTYSTU(I)) From TRTVENQTE
   [M:SOQ1]DSTOFCY(I)  = [M:SOQ1]DSTOFCY(NOL)
   [M:SOQ1]DUSEPLC(I)  = [M:SOQ1]DUSEPLC(NOL)
   [M:SOQ1]DRN(I)      = [M:SOQ1]DRN(NOL)
   [M:SOQ1]DLVPIO(I)   = [M:SOQ1]DLVPIO(NOL)
   [M:SOQ1]BPTNUM(I)   = [M:SOQ1]BPTNUM(NOL)
   [M:SOQ1]MDL(I)      = [M:SOQ1]MDL(NOL)
   [M:SOQ1]DAYLTI(I)   = [M:SOQ1]DAYLTI(NOL)
   [M:SOQ1]PCK(I)      = [M:SOQ1]PCK(NOL)
   [M:SOQ1]PCKCAP(I)   = [M:SOQ1]PCKCAP(NOL)
   [M:SOQ1]LOT(I)      = [M:SOQ1]LOT(NOL)
   [M:SOQ1]LOC(I)      = [M:SOQ1]LOC(NOL)
   [M:SOQ1]STA(I)      = [M:SOQ1]STA(NOL)
   [M:SOQ1]ALLTYP(I)   = [M:SOQ1]ALLTYP(NOL)
   [M:SOQ1]DSTOMGTCOD(I) = [M:SOQ1]DSTOMGTCOD(NOL)    : # 108376
   [M:SOQ1]DPJT(I)       = [M:SOQ1]DPJT(NOL)          : # 71065  : Project management
# --- Il y a un texte sur la ligne Ă  ĂŠclater = Duplication
    If [M:SOQ1]SOQTEX (NOL) <> ""
#        WRETOUR = 0
#        WNUMTEX = [M:SOQ1]SOQTEX (NOL)
        #--- dupli texte ligne ---#
#        Call TEX(5,"SOQ1","","","",WNUMTEX,"D",WRETOUR) From TRTX3TEX
#        If WRETOUR <> 99
#            [M:SOQ1]SOQTEX (I) = WNUMTEX
#        Endif
        [M:SOQ1]SOQTEX(I) = [M:SOQ1]SOQTEX(NOL)
        If left$([M:SOQ1]SOQTEX(NOL),3)="SOQ"
            Call DUP_CLOB("SOQ",[M:SOQ1]SOQTEX(I),WRETOUR) From TRTX3TEX
            If WRETOUR<1 Raz [M:SOQ1]SOQTEX(I) Endif
        Endif
    Endif
   [M:SOQ1]UPDFLG(I)   = 1

#  Calcul des cumuls Ă  livrer et Ă  atteindre
   If I = 1

#     On est en dĂŠbut de tableau : les cumuls dĂŠbutent Ă  0
      If [M:SOQ1]SOQSTA(I) = 2
         [M:SOQ1]XCUMLIV(I) = [M:SOQ1]QTY(I)
      Elsif [M:SOQ1]SOQSTA(I) = 1
         [M:SOQ1]XCUMLIV(I) = [M:SOQ1]QTY(I)
         [M:SOQ1]XCUMATT(I) = [M:SOQ1]QTY(I)
      Endif

#  On est sur la ligne qui suit celle ĂŠclatĂŠe : il ne faut pas en tenir compte
   Elsif I = NOL+1
      If [M:SOQ1]SOQSTA(I) = 2
         [M:SOQ1]XCUMLIV(I) = [M:SOQ1]XCUMLIV(I-2) + [M:SOQ1]QTY(I)
      Elsif [M:SOQ1]SOQSTA(I) = 1
         [M:SOQ1]XCUMLIV(I) = [M:SOQ1]XCUMLIV(I-2) + [M:SOQ1]QTY(I)
         [M:SOQ1]XCUMATT(I) = [M:SOQ1]XCUMATT(I-2) + [M:SOQ1]QTY(I)
      Endif
#  On est sur une des nouvelles lignes (sauf la premiĂ¨re)
   Else
      If [M:SOQ1]SOQSTA(I) = 2
         [M:SOQ1]XCUMLIV(I) = [M:SOQ1]XCUMLIV(I-1) + [M:SOQ1]QTY(I)
      Elsif [M:SOQ1]SOQSTA(I) = 1
         [M:SOQ1]XCUMLIV(I) = [M:SOQ1]XCUMLIV(I-1) + [M:SOQ1]QTY(I)
         [M:SOQ1]XCUMATT(I) = [M:SOQ1]XCUMATT(I-1) + [M:SOQ1]QTY(I)
      Endif
   Endif
#  Si la ligne gĂŠnĂŠrĂŠe est en retard et de type CF, Maj de l'A/R
   If [M:SOQ1]SOQSTA(I) = 2 & [M:SOQ1]DEMSTA(I) = 1
      [M:SOQ1]EARQTY += [M:SOQ1]QTY(I)
      [M:SOQ1]EARDAT = date$-1
   Endif
   J += 1
Next I
# Suppression de la ligne initiale
Dela NOL,1 [M:SOQ1]NBLIG
[M:SOQ1]NBLIG -=1
nolign = NOL+1
status=0
Call LINNUM("SOQSEQ") From TRTX3
Affzo [M:SOQ1]EARQTY,EARDAT
Affzo 25
mkstat = 4
Return

#########################################################################

######################################## Facultatif
Subprog AVANT_YNBLIG
[M]YTOT -= [M]YQTY(nolign-1)
End

######################################## Facultatif
Subprog APRES_YNBLIG
[M]YTOT += [M]YQTY(nolign-1)
Affzo [M]YTOT
End

######################################## Facultatif
Subprog AS_YDEMSTA(VALEUR)
Variable Integer VALEUR
If [M:RPER]CAD<>2 mkstat=2 : End Endif
# On autorise uniquement les F et P dans le menu local 317
For I = 3 To 15
   GMENLOC(I) = 1
Next I
End

######################################## Facultatif
Subprog AP_YDEMSTA(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End

#########################################################################

