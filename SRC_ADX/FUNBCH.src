Variable Char    VALEUR()
[M]FILTRE_AGF="FLGCPY=2"                  : # filtre pour action SELOBJCRI1
End

Subprog IB_GRPCPYTSO
GBOUTS=mess(479,198,1)                  : # Sélection Groupe sociétés
GBOUT1=mess(481,198,1)                  : # Groupe sociétés
End

Subprog C_GRPCPYTSO(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY [AGF] : Endif
Read [AGF]AGF0=VALEUR
