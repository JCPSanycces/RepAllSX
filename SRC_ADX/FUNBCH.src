######################################## Type commande
Subprog C_SOHTYP(VALEUR)
Variable Char    VALEUR()

#--CPO 71937
Local Integer WRET
Call LEC_TSO_LEG([M:BCH1]LEGGRPTSO(nolign-1),VALEUR,WRET) From TRTLECLEG
If WRET
	Raz [F:TSO]
	#Call MESSAGE(num$(VALEUR)-mess(609,199,1)+"."-mess(610,199,1)) From GESECRAN
Endif
#--CPO 71937 26.04.2013 Cohérence
Local Char VMESSAGE(250)
If [F:TSO]SOHTYP<>""
	Call CTL_ML_CONSISTENCY("TSO", "NON",[F:TSO]SOHTYP,[F:TSO]LEG,AVOID.ACHAR,AVOID.ACHAR,[M:BCH1]LEGGRPTSO(nolign-1),WRET,VMESSAGE) From TRTVENCTL
	If WRET
		Call MESSAGE(VMESSAGE) From GESECRAN
		mkstat=1
	Endif
Endif
#--/
#--contrôle : catégorie
If [F:TSO]SOHCAT>0 & [F:TSO]SOHCAT<>[M:BCH1]SOHCAT(nolign-1)
	Call MESSAGE(num$(VALEUR)-mess(361,192,1)+":"-mess([F:TSO]SOHCAT,412,1)+"<>"+mess([M:BCH1]SOHCAT(nolign-1),412,1)) From GESECRAN
	mkstat = 1
Endif

#--CPO 71937 Contrôle de cohérence groupe fait par le type TSO
## --- controle : groupe
#If [F:TSO]GFY<>"" & [F:TSO]GFY<>[M]GRPCPYTSO(nolign-1)
#	Call MESSAGE(num$(VALEUR)-mess(92,187,1)+":"-[F:TSO]GFY+"<>"+[M:BCH1]GRPCPYTSO(nolign-1)) From GESECRAN
#	mkstat=1
#Endif

# --- Controle unicite
Local Char IDEM (20)
IDEM=num$([M]SOHCAT(nolign-1))+"~"+[M]GRPCPYTSO(nolign-1)+"~"+VALEUR
Call UNICITE(IDEM,[M]TYPCIDEM) From OBJDIV
If mkstat : End : Endif

End

################################################################################
# Controle des flux autorises en inter-sites et inter-sociétés
################################################################################
Subprog IS_FLUX (VCRTYP,FCYORI,FCYDES,PTRFPRI, STAT)
Value    Integer VCRTYP       : # document (2=cde vente / 5=fac vente / 14=cde achat)
Value    Char    FCYORI ()    : # site origine
Value    Char    FCYDES ()    : # site destinataire
Variable Integer PTRFPRI      : # 1-Non/2-Oui     : # Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
Variable Integer STAT         : # 0=interdit / 1=autorise

Local    Integer TYPBET       : # type de flux (1=intra-societe / 2=inter-societes)
Local    Char    CPYORI       : # societe origine
Local    Char    CPYDES       : # societe destinataire
Local    Integer IJL

If clalev([F:BCL])=0 : Local File BETCPYL  [BCL] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif

STAT=0
#--- recherche societe origine
IJL=find(FCYORI,GSITE(1..GNBSITE))
If IJL   CPYORI=GSOCSITE(IJL)   Else   Goto FIN0   Endif

#--- recherche societe destinataire
IJL=find(FCYDES,GSITE(1..GNBSITE))
If IJL   CPYDES=GSOCSITE(IJL)   Else   Goto FIN0   Endif

#--- determination du flux ( 1=intra-société / 2=inter-sociétés )
If CPYORI=CPYDES   TYPBET=1   Else   TYPBET=2   Endif

# Il faut lire selon l'index BCL1(FLG1234+NUMERO)
# For [BCL]BCL0 Where TYPBET=[L]TYPBET & VCRTYP=[L]VCRTYP
For [BCL]BCL1 Where TYPBET=[L]TYPBET & VCRTYP=[L]VCRTYP
    #---  societe origine
    If [F:BCL]FLG1CPYORI=1 & CPYORI<>[F:BCL]GRPCPYORI : Goto NOK0 : Endif
    If [F:BCL]FLG1CPYORI=2
       Look [AGC]AGC0=[F:BCL]GRPCPYORI;CPYORI
       If fstat : Goto NOK0 : Endif
    Endif
    #---  site origine
    If [F:BCL]FLG2FCYORI=1 & FCYORI<>[F:BCL]GRPFCYORI : Goto NOK0 : Endif
    If [F:BCL]FLG2FCYORI=2
       Look [FGR]FGR0=[F:BCL]GRPFCYORI;FCYORI
       If fstat : Goto NOK0 : Endif
    Endif
    #---  societe destination
    If [F:BCL]FLG3CPYDES=1 & CPYDES<>[F:BCL]GRPCPYDES : Goto NOK0 : Endif
    If [F:BCL]FLG3CPYDES=2
       Look [AGC]AGC0=[F:BCL]GRPCPYDES;CPYDES
       If fstat : Goto NOK0 : Endif
    Endif
    #---  site destination
    If [F:BCL]FLG4FCYDES=1 & FCYDES<>[F:BCL]GRPFCYDES : Goto NOK0 : Endif
    If [F:BCL]FLG4FCYDES=2
       Look [FGR]FGR0=[F:BCL]GRPFCYDES;FCYDES
       If fstat : Goto NOK0 : Endif
    Endif

    #--- autorisation flux
    If [F:BCL]AUZBETFLG=1 : STAT=0 : Endif
    If [F:BCL]AUZBETFLG=2 : STAT=1 : Endif

    PTRFPRI = [F:BCL]TRFPRI : # Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
    Break

$NOK0
Next

$FIN0

End


################################################################################
# Recherche du type de commande vente
################################################################################
Subprog IS_SOHTYP (SOHCAT,FCYDES,SOHTYP)
Value    Integer SOHCAT       : # categorie cde (1=cde normale / 3=cde fac directe)
Value    Char    FCYDES ()    : # site destinataire
Variable Char    SOHTYP ()    : # type de commande

Local    Char    CPYDES       : # societe destinataire
Local    Integer IJL, IJ, NBL
Local    Char    WLEGCPYDES   : # FGR 19/11/2012 : X3SUIVI71937
Local    Integer WERR         : # FGR 19/11/2012 : X3SUIVI71937

If clalev([F:BCH])=0 : Local File BETCPY   [BCH] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY  [AGF] : Endif

# FGR 19/11/2012 : X3SUIVI71937 (début)
#--Ici le type de fact. achat rendu doit avoir une législation
#--en cohérence avec la lég. de la soc du site de destination
If clalev([F:TSO])=0 : Local File TABSOHTYP [TSO] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP  [FGR] : Endif
# FGR 19/11/2012 : X3SUIVI71937 (fin)

Local Integer FLG123             (0..dim([F:BCH]SOHCAT))
Local Char    T_SOHTYP (GLONTSO) (0..dim([F:BCH]SOHCAT))

Local Char VMESSAGE(250)	#--CPO 71937 26.04.2013 Cohérence

Raz SOHTYP

If SOHCAT<1 : Goto FIN1 : Endif :#--CPO 71937

#--- recherche societe destinataire
IJL = find(FCYDES,GSITE(1..GNBSITE))
If IJL  CPYDES=GSOCSITE(IJL)   Else   Goto TYP_STD   Endif

# FGR 19/11/2012 : X3SUIVI71937 (début)
#--Lecture de la législation de la soc du site dest
#--afin de comparer à celle du type de fact. rendu
WLEGCPYDES = ""
Read [CPY]CPY0=CPYDES
If !fstat WLEGCPYDES=[F:CPY]LEG Endif
# FGR 19/11/2012 : X3SUIVI71937 (fin)


Read [BCH]BCH0="STD"
If fstat : Goto TYP_STD : Endif

#--- recherche dans le parametrage

For IJ=0 To dim([F:BCH]SOHCAT)-1
  If [F:BCH]SOHTYP(IJ)="" : Break : Endif
  If [F:BCH]SOHCAT(IJ)=SOHCAT
    # FGR 19/11/2012 : X3SUIVI71937 (début)
    Raz WERR
    Call LEC_TSO_LEG(WLEGCPYDES,[F:BCH]SOHTYP(IJ),WERR) From TRTLECLEG
    If WERR=0
    #--/CPO
    	#--CPO 71937 26.04.2013 Cohérence
      If [F:TSO]SOHTYP<>""
      	Call CTL_ML_CONSISTENCY("TSO", "NON",[F:TSO]SOHTYP,[F:TSO]LEG,AVOID.ACHAR,FCYDES,WLEGCPYDES,WERR,VMESSAGE) From TRTVENCTL
      	If WERR=0
      #--/
        	If [F:TSO]SOHCAT=[F:BCH]SOHCAT(IJ) :#--CPO 71937 Un petit contrôle pour éviter les changements après le paramètrage...
           If    [F:BCH]GRPCPYTSO(IJ)=""
                 #NBL +=1 : FLG123(NBL-1)=3 : T_SOHTYP(NBL-1)=[F:BCH]SOHTYP(IJ)
                 NBL +=1 : FLG123(NBL-1)=30 : T_SOHTYP(NBL-1)=[F:BCH]SOHTYP(IJ) :#--CPO 71937 Tenir compte de la priorité de la lég
                 If [F:TSO]LEG="" : FLG123(NBL-1)+=1 : Endif 										:#--CPO 71937 Tenir compte de la priorité de la lég
           Elsif [F:BCH]GRPCPYTSO(IJ)=CPYDES
                 NBL +=1 : FLG123(NBL-1)=1 : T_SOHTYP(NBL-1)=[F:BCH]SOHTYP(IJ)
                 If [F:TSO]LEG="" : FLG123(NBL-1)+=10 : Endif :#--CPO 71937 Tenir compte de la priorité de la lég
           Else
                 Look [AGC]AGC0=[F:BCH]GRPCPYTSO(IJ);CPYDES
                 If !fstat
                    #NBL +=1 : FLG123(NBL-1)=2 : T_SOHTYP(NBL-1)=[F:BCH]SOHTYP(IJ)
                    NBL +=1 : FLG123(NBL-1)=20 : T_SOHTYP(NBL-1)=[F:BCH]SOHTYP(IJ)  :#--CPO 71937 Tenir compte de la priorité de la lég
                    If [F:TSO]LEG="" : FLG123(NBL-1)+=1 : Endif 										:#--CPO 71937 Tenir compte de la priorité de la lég
                 Endif
           Endif
      	  Endif
        Endif 	:#--CPO 71937 26.04.2013 Cohérence
      Endif :#--CPO 71937
     Endif 	:#--CPO 71937
  Endif
Next IJ

If NBL
   Sorta NBL FLG123, T_SOHTYP
   SOHTYP=T_SOHTYP(0)
Endif

If SOHTYP<>""   Goto FIN1   Endif

#--- absent du parametrage : on fait au mieux
$TYP_STD

#If clalev([F:TSO])=0 : Local File TABSOHTYP  [TSO] : Endif   :#--CPO 71937 Ouvert au début
Raz NBL, FLG123, T_SOHTYP
#--CPO 71937 - Déclinaison par législation
#--Filter avec order by afin d'avoir les entrées avec LEG sur les indices NBL infér.
#--Le Sorta à la fin donnera le SOHTYP avec LEG en premier
#For [TSO] Where SOHCAT=[L]SOHCAT
Filter [F:TSO] Where SOHCAT = [L]SOHCAT and (LEG = "" | LEG = [L]WLEGCPYDES)
& 						 Order By LEG Desc ; SOHTYP Asc
#--On réouvre le FLG123 selon la dimension de TPV
If rowcount([F:TSO])>0
  Kill FLG123,T_SOHTYP
  Local Integer FLG123 							(0..rowcount([F:TSO])-1)
  Local Char    T_SOHTYP  (GLONTSO) (0..rowcount([F:TSO])-1)
  For [TSO]
  #--/CPO
     If    [F:TSO]GFY=""
           #NBL +=1 : FLG123(NBL-1)=3 : T_SOHTYP(NBL-1)=[F:TSO]SOHTYP
           NBL +=1 : FLG123(NBL-1)=30 : T_SOHTYP(NBL-1)=[F:TSO]SOHTYP :#--CPO 71937 Tenir compte de la priorité de la lég
           If [F:TSO]LEG="" : FLG123(NBL-1)+=1 : Endif 								:#--CPO 71937 Tenir compte de la priorité de la lég
     Elsif [F:TSO]GFY=CPYDES
           NBL +=1 : FLG123(NBL-1)=1 : T_SOHTYP(NBL-1)=[F:TSO]SOHTYP
           If [F:TSO]LEG="" : FLG123(NBL-1)+=10 : Endif :#--CPO 71937 Tenir compte de la priorité de la lég
     Else
           #--CPO 71937 Le champ GFY est un groupe de sites
           #Look [AGC]AGC0=[F:TSO]GFY;CPYDES
           Look [FGR]FGR0=[F:TSO]GFY;FCYDES
           If !fstat
              #NBL +=1 : FLG123(NBL-1)=2 : T_SOHTYP(NBL-1)=[F:TSO]SOHTYP
              NBL +=1 : FLG123(NBL-1)=20 : T_SOHTYP(NBL-1)=[F:TSO]SOHTYP :#--CPO 71937 Tenir compte de la priorité de la lég
              If [F:TSO]LEG="" : FLG123(NBL-1)+=1 : Endif 							 :#--CPO 71937 Tenir compte de la priorité de la lég
           Endif
     Endif
  Next
  Filter [F:TSO] :#--CPO 71937

  If NBL
     Sorta NBL FLG123, T_SOHTYP
     SOHTYP=T_SOHTYP(0)
  Endif
Else
	Filter [F:TSO]
Endif
#---
$FIN1

End

################################################################################
#CPO
#-------------------------------------------------------------------------------
# Détermine le type de facture achat correspondant à un type de facture vente
# en fonction des Soc/Grp. Vente et Soc/Grp. Achat
#-------------------------------------------------------------------------------
Subprog IS_PIVTYP(FCYVEN,FCYACH,SIVTYP,PIVTYP)
Value    Char FCYVEN()    :# site origine
Value    Char FCYACH()    :# site destinataire
Value    Char SIVTYP()    :# type de facture Vente
Variable Char PIVTYP()    :# type de facture Achat

Local Char CPYVEN         :# société du site d'origine
Local Char CPYACH         :# société du site destinataire

Local Integer IJL, IJ, NBL
Local Char    WLEGCPYACH(GLONADI)   : # FGR 19/11/2012 : X3SUIVI71937
Local Char    WLEGCPYVEN(GLONADI)   : # FGR 19/11/2012 : X3SUIVI71937
Local Integer WERR                  : # FGR 19/11/2012 : X3SUIVI71937

If clalev([F:BCH])=0 : Local File BETCPY   [BCH] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY  [AGF] : Endif

#--CPO 71937 - Déclinaison par législation
#--Ici le type de fact. achat rendu doit avoir une législation
#--en cohérence avec la lég. de la soc du site de destination
If clalev([F:TPV])=0 : Local File TABPIVTYP [TPV] : Endif
If clalev([F:TSV])=0 : Local File TABSIVTYP [TSV] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP  [FGR] : Endif
#--/CPO

Local Integer FLG123             (0..dim([F:BCH]PIVTYP))
Local Char    T_PIVTYP (GLONTPV) (0..dim([F:BCH]PIVTYP))

Local Char VMESSAGE(250)	#--CPO 71937 26.04.2013 Cohérence

Raz PIVTYP
#--- recherche societe vente
IJL=find(FCYVEN,GSITE(1..GNBSITE))
If IJL   CPYVEN=GSOCSITE(IJL)   Else   Goto PIV_STD   Endif
#--CPO 71937 - Déclinaison par législation
#--Lecture de la législation de la soc du site dest
#--afin de comparer à celle du type de fact. rendu
WLEGCPYVEN = ""
Read [CPY]CPY0=CPYVEN
If !fstat WLEGCPYVEN=[F:CPY]LEG Endif
#--/CPO

#--CPO 71937 - Déclinaison par législation
Raz WERR
Call LEC_TSV_LEG(WLEGCPYVEN,SIVTYP,WERR) From TRTLECLEG
If WERR : Raz [F:TSV] : Endif
#--/CPO

#--- recherche societe achat
IJL=find(FCYACH,GSITE(1..GNBSITE))
If IJL   CPYACH=GSOCSITE(IJL)   Else   Goto PIV_STD   Endif
#--CPO 71937 - Déclinaison par législation
#--Lecture de la législation de la soc du site dest
#--afin de comparer à celle du type de fact. rendu
WLEGCPYACH = ""
Read [CPY]CPY0=CPYACH
If !fstat WLEGCPYACH=[F:CPY]LEG Endif
#--/CPO

Read [BCH]BCH0="STD"
If fstat : Goto PIV_STD : Endif

#--- recherche dans le parametrage
For IJ=0 To dim([F:BCH]PIVTYP)-1
  If [F:BCH]PIVTYP(IJ)="" : Break : Endif
  If [F:BCH]SIVTYP(IJ)=SIVTYP
    #--CPO 71937 - Déclinaison par législation
    Raz WERR
    Call LEC_TPV_LEG(WLEGCPYACH,[F:BCH]PIVTYP(IJ),WERR) From TRTLECLEG
    If WERR=0
    #--/CPO
    	#--CPO 71937 T757 Contrôle de cohérence
      Call CTL_ML_CONSISTENCY("TPV", "NON",[F:TPV]PIVTYP,[F:TPV]LEG,AVOID.ACHAR,FCYACH,WLEGCPYACH,WERR,VMESSAGE) From TRTVENCTL
      If WERR=0
      #--/
				#------------------------------------------
        If [F:BCH]GRPCPYTSV(IJ)=""
          NBL +=1
          If [F:BCH]GRPCPYTPV(IJ)=""
            #FLG123(NBL-1)=33
            FLG123(NBL-1)=163 :#--CPO 71937 Tenir compte de la priorité de la lég
          Elsif [F:BCH]GRPCPYTPV(IJ)=CPYACH
            #FLG123(NBL-1)=31
            FLG123(NBL-1)=121 :#--CPO 71937 Tenir compte de la priorité de la lég
          Else
            Look [AGC]AGC0=[F:BCH]GRPCPYTPV;CPYACH
            If fstat : NBL-=1 : Goto NEXT_IJ : Endif
            #FLG123(NBL-1)=32
            FLG123(NBL-1)=142 :#--CPO 71937 Tenir compte de la priorité de la lég
          Endif
          T_PIVTYP(NBL-1)=[F:BCH]PIVTYP(IJ)
        Elsif [F:BCH]GRPCPYTSV(IJ)=CPYVEN
          NBL +=1
          If [F:BCH]GRPCPYTPV(IJ)=""
            #FLG123(NBL-1)=13
            FLG123(NBL-1)=53 :#--CPO 71937 Tenir compte de la priorité de la lég
          Elsif [F:BCH]GRPCPYTPV(IJ)=CPYACH
            FLG123(NBL-1)=11
          Else
            Look [AGC]AGC0=[F:BCH]GRPCPYTPV;CPYACH
            If fstat : NBL-=1 : Goto NEXT_IJ : Endif
            #FLG123(NBL-1)=12
            FLG123(NBL-1)=32 :#--CPO 71937 Tenir compte de la priorité de la lég
          Endif
          T_PIVTYP(NBL-1)=[F:BCH]PIVTYP(IJ)
        Else
          Look [AGC]AGC0=[F:BCH]GRPCPYTSV(IJ);CPYVEN
          If !fstat
            NBL +=1
            If [F:BCH]GRPCPYTPV(IJ)=""
              #FLG123(NBL-1)=23
              FLG123(NBL-1)=103 :#--CPO 71937 Tenir compte de la priorité de la lég
            Elsif [F:BCH]GRPCPYTPV(IJ)=CPYACH
              #FLG123(NBL-1)=21
              FLG123(NBL-1)=61 :#--CPO 71937 Tenir compte de la priorité de la lég
            Else
              Look [AGC]AGC0=[F:BCH]GRPCPYTPV;CPYACH
              If fstat : NBL-=1 : Goto NEXT_IJ : Endif
              #FLG123(NBL-1)=22
              FLG123(NBL-1)=82 :#--CPO 71937 Tenir compte de la priorité de la lég
            Endif
            T_PIVTYP(NBL-1)=[F:BCH]PIVTYP(IJ)
          Endif
          If NBL>0
          	#--CPO 71937 Tenir compte de la priorité de la lég
            If     [F:TSV]LEG<>"" and [F:TPV]LEG=""
            	FLG123(NBL-1)+=10
            Elsif  [F:TSV]LEG=""  and [F:TPV]LEG<>""
            	FLG123(NBL-1)+=11
            Elsif  [F:TSV]LEG=""  and [F:TPV]LEG=""
            	FLG123(NBL-1)+=12
            Endif
            #--/CPO
          Endif
        Endif
#------------------------------------------
#      If [F:BCH]GRPCPYTSV(IJ)=""
#        NBL +=1
#        If [F:BCH]GRPCPYTPV(IJ)=""
#          FLG123(NBL-1)=33
#        Elsif [F:BCH]GRPCPYTPV(IJ)=CPYACH
#          FLG123(NBL-1)=31
#        Else
#          Look [AGC]AGC0=[F:BCH]GRPCPYTPV;CPYACH
#          If fstat : NBL-=1 : Goto NEXT_IJ : Endif
#          FLG123(NBL-1)=32
#        Endif
#        T_PIVTYP(NBL-1)=[F:BCH]PIVTYP(IJ)
#      Elsif [F:BCH]GRPCPYTSV(IJ)=CPYVEN
#        NBL +=1
#        If [F:BCH]GRPCPYTPV(IJ)=""
#          FLG123(NBL-1)=13
#        Elsif [F:BCH]GRPCPYTPV(IJ)=CPYACH
#          FLG123(NBL-1)=11
#        Else
#          Look [AGC]AGC0=[F:BCH]GRPCPYTPV;CPYACH
#          If fstat : NBL-=1 : Goto NEXT_IJ : Endif
#          FLG123(NBL-1)=12
#        Endif
#        T_PIVTYP(NBL-1)=[F:BCH]PIVTYP(IJ)
#      Else
#        Look [AGC]AGC0=[F:BCH]GRPCPYTSV(IJ);CPYVEN
#        If !fstat
#          NBL +=1
#          If [F:BCH]GRPCPYTPV(IJ)=""
#            FLG123(NBL-1)=23
#          Elsif [F:BCH]GRPCPYTPV(IJ)=CPYACH
#            FLG123(NBL-1)=21
#          Else
#            Look [AGC]AGC0=[F:BCH]GRPCPYTPV;CPYACH
#            If fstat : NBL-=1 : Goto NEXT_IJ : Endif
#            FLG123(NBL-1)=22
#          Endif
#          T_PIVTYP(NBL-1)=[F:BCH]PIVTYP(IJ)
#        Endif
#        If NBL>0
#        If [F:TPV]LEG="" : FLG123(NBL-1)+=100 : Endif :#--CPO 71937 Tenir compte de la priorité de la lég
#        Endif
#      Endif
			Endif 	:#--CPO 71937 26.04.2013 Cohérence
    Endif :#--CPO
  Endif
$NEXT_IJ
Next IJ

If NBL
   Sorta NBL FLG123, T_PIVTYP
   PIVTYP=T_PIVTYP(0)
Endif

If PIVTYP<>""   Goto FIN3   Endif

$PIV_STD
#----------------------------------------
#--- absent du parametrage : on fait au mieux
Raz NBL, FLG123, T_PIVTYP
#--CPO 71937 - Déclinaison par législation
#--Filter avec order by afin d'avoir les entrées avec LEG sur les indices NBL infér.
#--Le Sorta à la fin donnera le PIVTYP avec LEG en premier
#---
Filter [F:TPV] Where INVTYP = [F:TSV]INVTYP and (LEG = "" | LEG = [L]WLEGCPYACH)
& Order By LEG Desc ; PIVTYP Asc
If rowcount([F:TPV])>0
  #--On réouvre le FLG123 selon la dimension de TPV
  Kill FLG123,T_PIVTYP
  Local Integer FLG123 						 (0..rowcount([F:TPV])-1)
  Local Char    T_PIVTYP (GLONTPV) (0..rowcount([F:TPV])-1)
  For [TPV]
  #--/CPO
     If    [F:TPV]GFY=""
           NBL +=1 : FLG123(NBL-1)=30 : T_PIVTYP(NBL-1)=[F:TPV]PIVTYP :#--CPO 71937 Tenir compte de la priorité de la lég
           If [F:TPV]LEG="" : FLG123(NBL-1)+=1 : Endif 								:#--CPO 71937 Tenir compte de la priorité de la lég
     Elsif [F:TPV]GFY=[L]CPYACH
           NBL +=1 : FLG123(NBL-1)=1 : T_PIVTYP(NBL-1)=[F:TPV]PIVTYP
           If [F:TPV]LEG="" : FLG123(NBL-1)+=10 : Endif :#--CPO 71937 Tenir compte de la priorité de la lég
     Else
           Look [FGR]FGR0=[F:TPV]GFY;FCYACH
           If !fstat
              NBL +=1 : FLG123(NBL-1)=20 : T_PIVTYP(NBL-1)=[F:TPV]PIVTYP :#--CPO 71937 Tenir compte de la priorité de la lég
              If [F:TPV]LEG="" : FLG123(NBL-1)+=1 : Endif 							 :#--CPO 71937 Tenir compte de la priorité de la lég
           Endif
     Endif
  Next
  Filter [F:TPV] :#--CPO 71937

  If NBL
     Sorta NBL FLG123, T_PIVTYP
     PIVTYP=T_PIVTYP(0)
  Endif
Endif

#---
If PIVTYP<>""   Goto FIN3   Endif
#----------------------------------------
#--CPO A Revoir ...
PIVTYP=SIVTYP :# logique reprise de TRTACHFAC2

$FIN3
End
#fin CPO

################################################################################
# Recherche qui valorise les elt de facturation (origine / destinataire)
# - si non trouve par le parametrage la valeur par defaut est :
#   cde achat : destinataire / cde vente = origine / fac vente = origine
################################################################################

Subprog IS_VLTFOOINV (VCRTYP,FCYORI,FCYDES,VLTFOOINV)
Value    Integer VCRTYP       : # document (2=cde vente / 5=fac vente / 14=cde achat)
Value    Char    FCYORI ()    : # site origine
Value    Char    FCYDES ()    : # site destinataire
Variable Integer VLTFOOINV    : # 1=achats / 2=ventes

Local    Integer TYPBET       : # type de flux (1=inter-sites / 2=inter-societes)
Local    Char    CPYORI       : # societe origine
Local    Char    CPYDES       : # societe destinataire

Local    Integer IJL

#--- valeur par defaut
Case VCRTYP
  When 2         : VLTFOOINV=2    : # cde de vente = valorisation ventes
  When 5         : VLTFOOINV=2    : # fac de vente = valorisation ventes
  When 14        : VLTFOOINV=2    : # cde achat = valorisation ventes
  When Default   : VLTFOOINV=2
Endcase

If clalev([F:BCL])=0 : Local File BETCPYL  [BCL] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif

#--- recherche societe origine
IJL=find(FCYORI,GSITE(1..GNBSITE))
If IJL   CPYORI=GSOCSITE(IJL)   Else   Goto FIN2   Endif

#--- recherche societe destinataire
IJL=find(FCYDES,GSITE(1..GNBSITE))
If IJL   CPYDES=GSOCSITE(IJL)   Else   Goto FIN2   Endif

#--- determination du flux ( 1=intra-saociété / 2=inter-sociétés )
If CPYORI=CPYDES   TYPBET=1   Else   TYPBET=2   Endif

# Pour tenir compte à la fin des cas généraux, index utilisé BCL1
# For [BCL]BCL0 Where TYPBET=[L]TYPBET & VCRTYP=[L]VCRTYP
For [BCL]BCL1 Where TYPBET=[L]TYPBET & VCRTYP=[L]VCRTYP
    #---  societe origine
    If [F:BCL]FLG1CPYORI=1 & CPYORI<>[F:BCL]GRPCPYORI : Goto NOK2 : Endif
    If [F:BCL]FLG1CPYORI=2
       Look [AGC]AGC0=[F:BCL]GRPCPYORI;CPYORI
       If fstat : Goto NOK2 : Endif
    Endif
    #---  site origine
    If [F:BCL]FLG2FCYORI=1 & FCYORI<>[F:BCL]GRPFCYORI : Goto NOK2 : Endif
    If [F:BCL]FLG2FCYORI=2
       Look [FGR]FGR0=[F:BCL]GRPFCYORI;FCYORI
       If fstat : Goto NOK2 : Endif
    Endif
    #---  societe destination
    If [F:BCL]FLG3CPYDES=1 & CPYDES<>[F:BCL]GRPCPYDES : Goto NOK2 : Endif
    If [F:BCL]FLG3CPYDES=2
       Look [AGC]AGC0=[F:BCL]GRPCPYDES;CPYDES
       If fstat : Goto NOK2 : Endif
    Endif
    #---  site destination
    If [F:BCL]FLG4FCYDES=1 & FCYDES<>[F:BCL]GRPFCYDES : Goto NOK2 : Endif
    If [F:BCL]FLG4FCYDES=2
       Look [FGR]FGR0=[F:BCL]GRPFCYDES;FCYDES
       If fstat : Goto NOK2 : Endif
    Endif

    #--- enregistrement significatif
    VLTFOOINV=[F:BCL]VLTFOOINV
    Break

$NOK2
Next

$FIN2

End


################################################################################
# Saisie commande achat
# Constitution tableau des elts facturation achat ( ex: bloc NBFAC de M:POH3)
# - Phase 1 : creation tableau elts achats à partir du fournisseur
# - Phase 2 : creation tableau elts ventes à partir de SFOOTINV
# - Phase 3 : m.a.j. correspondance dans tableau achats
# - Phase 4 : m.a.j. correspondance dans tableau ventes
# - Phase 5 : m.a.j. complementaire dans tableau ventes
# - Phase 6 : creation tableau NBFAC
#    ( la valorisation est effectuée à partir des achats ou des ventes
#     en fonction du paramétrage inter sociétés )
################################################################################

Subprog IS_DTAPOH (FCYORI,FCYDES,ABREVDES,BPSNUM,BPCINV,TYPCUR,CUR,DAT,RETOUR)
Value    Char    FCYORI ()        : # site origine (site achat)
Value    Char    FCYDES ()        : # site destinataire (site vente)
Value    Char    ABREVDES         : # abb destinataire (masque ou table)
Value    Char    BPSNUM           : # fournisseur
Value    Char    BPCINV           : # client facture (les elts sont ceux du client facture voir SAISFOOT)
Value    Libelle TYPCUR           : # type de cours
Value    Char    CUR              : # devise
Value    Date    DAT              : # date (date de commande achat)
Variable Integer RETOUR           : # 0=ok / 1 a x=erreur

Local    Char    CPYORI           : # societe origine (societe achat)
Local    Char    CPYDES           : # societe destinataire (societe vente)

Local    Decimal A_INVDTA    (0..50) : # elts achats
Local    Decimal A_INVDTAAMT (0..50)
Local    Integer A_AMTCOD    (0..50)
Local    Decimal A_SFINUM    (0..50) : # elt vente correspondant

Local    Decimal V_INVDTA    (0..50) : # elts ventes
Local    Decimal V_INVDTAAMT (0..50)
Local    Integer V_AMTCOD    (0..50)
Local    Integer V_INCDCR    (0..50)
Local    Decimal V_PFINUM    (0..50) : # elt achat correspondant

Local    Integer VLTFOOINV
Local    Char    ABRDES      (20)     : # abreviation destinataire
Local    Char    ABRMSK      (20)     : # abreviation masque
Local    Char    ABRFIC      (20)     : # abreviation fichier
Local    Char    FORMAT_TX   (20)     : # format affichage taux
Local    Char    FORMAT_MT   (20)     : # format affichage montant
Local    Char    LIB_SHO     (20)     : # designation element

Local    Integer JL0, JL1, JL2, JLR
Raz RETOUR

#--- recherche societe origine
IJL=find(FCYORI,GSITE(1..GNBSITE))
If IJL   CPYORI=GSOCSITE(IJL)   Else   RETOUR=5 : End   Endif

#--- recherche societe destinataire
IJL=find(FCYDES,GSITE(1..GNBSITE))
If IJL   CPYDES=GSOCSITE(IJL)   Else   RETOUR=5 : End   Endif

#------------------------------------------------------------------------
#    constitution abreviation destinataire

#  recherche prioritaire sur abreviation masque
If instr(1,ABREVDES,"[M:")  ABRMSK=ABREVDES  Else  ABRMSK="[M:"+ABREVDES+"]"  Endif
If evalue ("clalev ("+ABRMSK+")") = 0 : Raz ABRMSK : Endif
#  recherche secondaire sur abreviation table
If ABRMSK=""
   If instr(1,ABREVDES,"[F:")  ABRFIC=ABREVDES  Else  ABRFIC="[F:"+ABREVDES+"]"  Endif
   If evalue ("clalev ("+ABRFIC+")") = 0 : Raz ABRFIC : Endif
Endif
If    ABRMSK<>"" : ABRDES=ABRMSK   : # si abreviation masque
Elsif ABRFIC<>"" : ABRDES=ABRFIC   : # si abreviation table
Else  RETOUR=1 : End               : # pas de tableau de variables destinataires
Endif

#------------------------------------------------------------------------
#    recherche de la priorité de valorisation

Call IS_VLTFOOINV (14,FCYORI,FCYDES,VLTFOOINV) From FUNBCH

If clalev([PFI])=0 : Local File PFOOTINV   [PFI] : Endif
Gosub OPEN_SFI From TRTX3CPY
#If clalev([SFI])=0 : Local File SFOOTINV   [SFI] : Endif
If clalev([BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([AXX])=0 : Local File ATEXTRA    [AXX] : Endif
If clalev([BCH])=0 : Local File BETCPY     [BCH] : Endif

Read [BPR]BPR0=BPSNUM
If fstat : RETOUR=2 : End : Endif
Read [BPS]BPS0=BPSNUM
If fstat : RETOUR=3 : End : Endif

#------------------------------------------------------------------------
# - Phase 1 : creation tableau elts achats à partir du fournisseur
Raz JL1
For JL0=0 To dim(A_INVDTA)-1
    If JL0>dim([F:BPS]INVDTA)-1 : Break : Endif
    If [F:BPS]INVDTA(JL0)=0     : Break : Endif
    Read [PFI]PFI0=[F:BPS]INVDTA(JL0)
    If !fstat
       If [F:PFI]DACORD=2
          A_INVDTA(JL1)   =[F:BPS]INVDTA(JL0)
          A_AMTCOD(JL1)   =[F:BPS]AMTCOD(JL0)
          If [F:BPS]AMTCOD(JL0)=1                  : # c'est un taux
             A_INVDTAAMT(JL1)=[F:BPS]INVDTAAMT(JL0)
          Endif
          If [F:BPS]AMTCOD(JL0)=2                  : # c'est un montant
             If [F:BPS]CUR<>CUR & [F:BPS]INVDTAAMT(JL0)<>0 : # conv.dev.(fournisseur->document)
                Call CONVERT([F:BPS]CUR,CUR,GLOCALDEV,TYPCUR,DAT,[F:BPS]INVDTAAMT(JL0),A_INVDTAAMT(JL1),JLR)
&                           From TRTDEV
              Else
                A_INVDTAAMT(JL1)=[F:BPS]INVDTAAMT(JL0)
             Endif
          Endif
          JL1 +=1
       Endif
    Endif
Next JL0

#------------------------------------------------------------------------
# - Phase 2 : creation tableau elts ventes à partir de SFOOTINV

Raz JL1
For [SFI] Where find(PROCOD,1,2) & DACORD>0
    V_INVDTA(JL1)   =[F:SFI]SFINUM
    V_AMTCOD(JL1)   =[F:SFI]AMTCOD
    V_INCDCR(JL1)   =[F:SFI]INCDCR
    If [F:SFI]AMTCOD=1         : # c'est un taux
       V_INVDTAAMT(JL1)=[F:SFI]DEFVAL
    Endif
    If [F:SFI]AMTCOD=2         : # c'est un montant
       If GSYSCUR<>CUR & [F:SFI]DEFVAL<>0           : # Conv.dev.(gsyscur->document)
          Call CONVERT(GSYSCUR,CUR,GLOCALDEV,TYPCUR,DAT,[F:SFI]DEFVAL,V_INVDTAAMT(JL1),JLR) From TRTDEV
        Else
          V_INVDTAAMT(JL1)=[F:SFI]DEFVAL
       Endif
    Endif
    JL1 +=1
Next

Read [BPC]BPC0=BPCINV
If fstat : RETOUR=4 : End : Endif
For JL0=0 To dim([F:BPC]INVDTA)-1
    If [F:BPC]INVDTA(JL0)=0 : Break : Endif
    JL1=find([F:BPC]INVDTA(JL0),V_INVDTA)
    If JL1
       V_INVDTAAMT(JL1-1)=[F:BPC]INVDTAAMT(JL0)
    Endif
Next JL0

#--- recherche des correspondances elements achats <--> ventes
Read [BCH]BCH0="STD"
If fstat : RETOUR=5 : End : Endif

#------------------------------------------------------------------------
# - Phase 3 : m.a.j. correspondance dans tableau achats
#    Attention :plusieurs elts achats peuvent avoir le meme elt vente,
#    il faut prendre en priorite la correspondance avec les elts fournisseur
#    --> donc concerne en premier les elts issus du fournisseur

For JL0=0 To dim(A_INVDTA)-1
    If A_INVDTA(JL0)=0 : Break : Endif
    JL1=find(A_INVDTA(JL0),[F:BCH]PFINUM)
    If JL1
       A_SFINUM(JL0)=[F:BCH]SFINUM(JL1-1)
    Endif
Next JL0

#------------------------------------------------------------------------
# - Phase 4 : m.a.j. correspondance dans tableau ventes
#    --> donc concerne en premier les elts issus du fournisseur

For JL0=0 To dim(V_INVDTA)-1
    If V_INVDTA(JL0)=0 : Break : Endif
    JL1=find(V_INVDTA(JL0),A_SFINUM)
    If JL1
       V_PFINUM(JL0)=A_INVDTA(JL1-1)
    Endif
Next JL0

#------------------------------------------------------------------------
# - Phase 5 : m.a.j. complementaire dans tableau ventes
#    concerne les elts ventes non issus du fournisseur mais ayant correspondance achats
#    Remarque : dans les cdes achats il n'est pas possible d'ajouter des elts comme en facture
#               mais permis en creation auto du tableau pour intersociete

For JL0=0 To dim(V_INVDTA)-1
    If V_INVDTA(JL0)=0 : Break : Endif
    If V_PFINUM(JL0)=0
       JL1=find(V_INVDTA(JL0),[F:BCH]SFINUM)
       If JL1
          V_PFINUM(JL0)=[F:BCH]PFINUM(JL1-1)
       Endif
    Endif
Next JL0

#------------------------------------------------------------------------
# - Phase 6 : creation tableau NBFAC
#    La valorisation est effectuée à partir des achats ou des ventes
#    en fonction du paramétrage intersociétés
Read [TCU]TCU0=CUR
If fstat
   FORMAT_MT="NZ:11.2[ ]"
Else
   FORMAT_MT="NZ:"+[F:TCU]CURFMT1+"[ ]"
Endif
FORMAT_TX="NZ:3.2#[      ]"

#   boucle sur elts des ventes
For JL0=0 To dim(V_INVDTA)-1
    If V_INVDTA(JL0)=0 : V_PFINUM(JL0)=999 : Endif   : # postes non utilises à 999 (pour tri)
    If V_PFINUM(JL0)<>0                              : # si presence elt achat correspondant
       If VLTFOOINV=1                                : #    si valorisation à partir achats
          JL1=find(V_PFINUM(JL0),A_INVDTA)           : #       recherche elt achat issu fournisseur
          If JL1                                     : #       si existe
             V_INVDTAAMT(JL0)=A_INVDTAAMT(JL1-1)     : #          initialisation valeur
          Else                                       : #       si n'existe pas
             V_INVDTA(JL0)=0 : V_PFINUM(JL0)=999     : #          poste initialise
          Endif
       Endif
    Else
       V_INVDTA(JL0)=0 : V_PFINUM(JL0)=999            : # pas elt achat correspondant
    Endif
Next JL0

Sorta V_PFINUM, V_INVDTA, V_INVDTAAMT, V_AMTCOD, V_INCDCR #--CPO 106359 perte correspondance;Ajout de V_INCDCR

Raz JL1
For JL0=0 To evalue("dim("+ABRDES+"INVDTA)-1")
   If V_PFINUM(JL0)>0 & V_PFINUM(JL0)<>999
#        chargement du poste element facturation
      JL1 +=1
      Read [PFI] PFI0=V_PFINUM(JL0) : If fstat  Raz [F:PFI] : Endif
      If evalue ("dim("+ABRDES+"INVDTA)")-1 >= JL0
         Assign (ABRDES+"INVDTA("+num$(JL0)+")")    With V_PFINUM(JL0)
      Endif
      Call LECTEXTRA(LIB_SHO,"PFOOTINV","SHOAXX",num$([F:PFI]PFINUM),"") From ATEXTRA
      If evalue ("dim("+ABRDES+"INVDTALIB)")-1 >= JL0
         Assign (ABRDES+"INVDTALIB("+num$(JL0)+")")  With LIB_SHO
      Endif
      If evalue ("dim("+ABRDES+"INVDTAAMT)")-1 >= JL0
         Assign (ABRDES+"INVDTAAMT("+num$(JL0)+")")  With V_INVDTAAMT(JL0)
      Endif
      If V_AMTCOD(JL0)=1
        If evalue ("dim("+ABRDES+"AMTCODLIB)")-1 >= JL0
          Assign (ABRDES+"AMTCODLIB("+num$(JL0)+")") With "%"
        Endif
      Else
        If evalue ("dim("+ABRDES+"AMTCODLIB)")-1 >= JL0
          Assign (ABRDES+"AMTCODLIB("+num$(JL0)+")") With CUR
        Endif
      Endif
      If [F:PFI]VATRUL=2
        Call RECHVATFOOT(2,[L]BPSNUM,[F:PFI]PFINUM,ABREVDES,GBIDC3) From TRTX3
      Else
        Raz GBIDC3
      Endif
      If evalue ("dim("+ABRDES+"INVDTAVAT)")-1 >= JL0
         Assign (ABRDES+"INVDTAVAT("+num$(JL0)+")")  With GBIDC3
      Endif
      If evalue ("dim("+ABRDES+"INVDTAFLG)")-1 >= JL0
         Assign (ABRDES+"INVDTAFLG("+num$(JL0)+")")  With 1
      Endif
      If evalue ("dim("+ABRDES+"INVLINFLG)")-1 >= JL0
         Assign (ABRDES+"INVLINFLG("+num$(JL0)+")")  With [F:PFI]DSPLIN
      Endif
      If evalue ("dim("+ABRDES+"INVORDFLG)")-1 >= JL0
         Assign (ABRDES+"INVORDFLG("+num$(JL0)+")")  With [F:PFI]DACORD
      Endif
      If evalue ("dim("+ABRDES+"DISVATFLG)")-1 >= JL0
         Assign (ABRDES+"DISVATFLG("+num$(JL0)+")")  With [F:PFI]DISVATFLG
      Endif
      If evalue ("dim("+ABRDES+"DEBCDT)")-1 >= JL0
         Assign (ABRDES+"DEBCDT("+num$(JL0)+")")     With V_INCDCR(JL0)
      Endif
      If evalue ("dim("+ABRDES+"AMTCOD)")-1 >= JL0
         Assign (ABRDES+"AMTCOD("+num$(JL0)+")")     With V_AMTCOD(JL0)
      Endif
      If evalue ("dim("+ABRDES+"FORMAT)")-1 >= JL0
         If V_AMTCOD(JL0)=1
            Assign (ABRDES+"FORMAT("+num$(JL0)+")")  With FORMAT_TX
         Else
            Assign (ABRDES+"FORMAT("+num$(JL0)+")")  With FORMAT_MT
         Endif
      Endif
      If evalue ("dim("+ABRDES+"CLCORD)")-1 >= JL0
         Assign (ABRDES+"CLCORD("+num$(JL0)+")")     With [F:PFI]CLCORD
      Endif
      If evalue ("dim("+ABRDES+"CLCBAS)")-1 >= JL0
         Assign (ABRDES+"CLCBAS("+num$(JL0)+")")     With [F:PFI]CLCBAS
      Endif
      If evalue ("dim("+ABRDES+"DSP)")-1 >= JL0
         Assign (ABRDES+"DSP("+num$(JL0)+")")        With [F:PFI]DSP
      Endif
   Else
#        initialisation du poste
      If evalue ("dim("+ABRDES+"INVDTA)")-1 >= JL0
         Assign (ABRDES+"INVDTA("+num$(JL0)+")")    With 0
      Endif
      If evalue ("dim("+ABRDES+"INVDTAAMT)")-1 >= JL0
         Assign (ABRDES+"INVDTAAMT("+num$(JL0)+")") With 0
      Endif
      If evalue ("dim("+ABRDES+"AMTCOD)")-1 >= JL0
         Assign (ABRDES+"AMTCOD("+num$(JL0)+")")    With 0
      Endif
      If evalue ("dim("+ABRDES+"SHO)")-1 >= JL0
         Assign (ABRDES+"SHO("+num$(JL0)+")")       With ""
      Endif
      If evalue ("dim("+ABRDES+"FORMAT)")-1 >= JL0
         Assign (ABRDES+"FORMAT("+num$(JL0)+")")    With ""
      Endif
   Endif
Next I

#        chargement variable bas tableau
If evalue ("dim("+ABRDES+"NBFAC)")-1 >= 0
   Assign (ABRDES+"NBFAC")     With JL1
Elsif evalue ("dim("+ABRDES+"NBELEMENT)")-1 >= 0
   Assign (ABRDES+"NBELEMENT") With JL1
Endif

End

################################################################################
# Saisie commande achat
# - modification du tableau des éléments de facturation ventes si la
#   valorisation est effectuée à partir des achats (paramétrage inter sociétés)
################################################################################

Subprog IS_DTAPOHSOH (FCYORI,FCYDES,ABREVORI,ABREVDES,CURORI,TYPCUR,CUR,DAT,RETOUR)
Value    Char    FCYORI ()        : # site origine (societe achat)
Value    Char    FCYDES ()        : # site destinataire (societe vente)
Value    Char    ABREVORI         : # abb masque origine des elements
Value    Char    ABREVDES         : # abb masque ou creer les elements
Value    Char    CURORI           : # devise origine (du document saisi)
Value    Libelle TYPCUR           : # type de cours
Value    Char    CUR              : # devise
Value    Date    DAT              : # date
Variable Integer RETOUR           : # 0=ok / 1 à x=erreur

Local    Char    CPYORI           : # societe origine (societe achat)
Local    Char    CPYDES           : # societe destinataire (societe vente)

Local    Decimal V_INVDTA    (0..50) : # elts ventes
Local    Integer V_INVDTATYP (0..50)

Local    Decimal A_INVDTA    (0..50) : # elts achats
Local    Decimal A_INVDTAAMT (0..50)
Local    Decimal A_DTAAMTTAX (0..50)
Local    Integer A_AMTCOD    (0..50)
Local    Decimal A_SFINUM    (0..50) : # elt vente correspondant

Local    Integer VLTFOOINV
Local    Char    ABRORI      (20)     : # abreviation origine
Local    Char    ABRDES      (20)     : # abreviation destinataire
Local    Char    ABRMSK      (20)     : # abreviation masque
Local    Char    ABRFIC      (20)     : # abreviation fichier

Local    Integer JL0, JL1, JL2, JL3, JLR
Raz RETOUR

#--- recherche societe origine
IJL=find(FCYORI,GSITE(1..GNBSITE))
If IJL   CPYORI=GSOCSITE(IJL)   Else   RETOUR=3 : End   Endif

#--- recherche societe destinataire
IJL=find(FCYDES,GSITE(1..GNBSITE))
If IJL   CPYDES=GSOCSITE(IJL)   Else   RETOUR=3 : End   Endif

#------------------------------------------------------------------------
#    recherche priorité de valorisation (si ventes : ne pas modifier)

Call IS_VLTFOOINV (14,FCYORI,FCYDES,VLTFOOINV) From FUNBCH
If VLTFOOINV=2 : End : Endif

#------------------------------------------------------------------------
#    constitution abreviation origine
Raz ABRMSK, ABRFIC
#  recherche primaire sur abreviation masque
If instr(1,ABREVORI,"[M:")  ABRMSK=ABREVORI  Else  ABRMSK="[M:"+ABREVORI+"]"  Endif
If evalue ("clalev ("+ABRMSK+")") = 0 : Raz ABRMSK : Endif
#  recherche secondaire sur abreviation table
If ABRMSK=""
   If instr(1,ABREVORI,"[F:")  ABRFIC=ABREVORI  Else  ABRFIC="[F:"+ABREVORI+"]"  Endif
   If evalue ("clalev ("+ABRFIC+")") = 0 : Raz ABRFIC : Endif
Endif

If    ABRMSK<>"" : ABRORI=ABRMSK   : # si abreviation masque
Elsif ABRFIC<>"" : ABRORI=ABRFIC   : # si abreviation table
Endif

#------------------------------------------------------------------------
#    constitution abreviation destinataire

Raz ABRMSK, ABRFIC
#  recherche primaire sur abreviation masque
If instr(1,ABREVDES,"[M:")  ABRMSK=ABREVDES  Else  ABRMSK="[M:"+ABREVDES+"]"  Endif
If evalue ("clalev ("+ABRMSK+")") = 0 : Raz ABRMSK : Endif
#  recherche secondaire sur abreviation table
If ABRMSK=""
   If instr(1,ABREVDES,"[F:")  ABRFIC=ABREVDES  Else  ABRFIC="[F:"+ABREVDES+"]"  Endif
   If evalue ("clalev ("+ABRFIC+")") = 0 : Raz ABRFIC : Endif
Endif

If    ABRMSK<>"" : ABRDES=ABRMSK   : # si abreviation masque
Elsif ABRFIC<>"" : ABRDES=ABRFIC   : # si abreviation table
Endif

If ABRORI="" : RETOUR=1 : End : Endif
If ABRDES="" : RETOUR=2 : End : Endif

If clalev([BCH])=0 : Local File BETCPY  [BCH] : Endif
Read [BCH]BCH0="STD"
If fstat : RETOUR=3 : End : Endif

#------------------------------------------------------------------------
#    creation tableau des elts commandes achats
For JL0=0 To evalue("dim("+ABRORI+"INVDTA)-1")
    If evalue(ABRORI+"INVDTA(JL0)")=0 : Break : Endif
    A_INVDTA(JL0)   =evalue(ABRORI+"INVDTA(JL0)")
    A_INVDTAAMT(JL0)=evalue(ABRORI+"INVDTAAMT(JL0)")
    #----- Le champ n'existe pas pour les commandes ouvertes d'achat -----#
    If evalue("dim("+ABRORI+"DTAAMTTAX)")>0
      A_DTAAMTTAX(JL0)=abs(evalue(ABRORI+"DTAAMTTAX(JL0)"))
    Else
      A_DTAAMTTAX(JL0)=0
    Endif
    #-----
    A_AMTCOD(JL0)   =evalue(ABRORI+"AMTCOD(JL0)")
Next JL0

#------------------------------------------------------------------------
#    creation tableau des elts commandes ventes

For JL0=0 To evalue("dim("+ABRDES+"INVDTA)-1")
    If evalue(ABRDES+"INVDTA(JL0)")=0 : Break : Endif
    V_INVDTA(JL0)=evalue(ABRDES+"INVDTA(JL0)")
    V_INVDTATYP(JL0)=evalue(ABRDES+"INVDTATYP(JL0)")
Next JL0

#------------------------------------------------------------------------
#    modification vente a partir tableau achat
For JL0=0 To dim(A_INVDTA)-1
    If A_INVDTA(JL0)=0 : Break : Endif
    JL1=find(A_INVDTA(JL0),[F:BCH]PFINUM)
    If JL1
       A_SFINUM(JL0)=[F:BCH]SFINUM(JL1-1)
       JL2=find(A_SFINUM(JL0),V_INVDTA)
       If JL2
          If A_AMTCOD(JL0)=2                           : # c'est un montant
             If CURORI<>CUR & A_INVDTAAMT(JL0)<>0      : # conversion devise
                Call CONVERT(CURORI,CUR,GLOCALDEV,TYPCUR,DAT,A_INVDTAAMT(JL0),A_INVDTAAMT(JL0),JLR)
&                           From TRTDEV
             Endif
          Endif
          If evalue ("dim("+ABRDES+"INVDTAAMT)")-1 >= JL2
              If evalue (ABRDES+"INVDTATYP("+num$(JL2-1)+")") <>2  : # Bug 54201 : Elt exprimé en HT ou %
                 Assign (ABRDES+"INVDTAAMT("+num$(JL2-1)+")")  With A_INVDTAAMT(JL0)
              Else                                          : # Bug 54201 : Elt exprimé en TTC : Ajout de la taxe
                 Assign (ABRDES+"INVDTAAMT("+num$(JL2-1)+")")  With A_INVDTAAMT(JL0)+A_DTAAMTTAX(JL0)
              Endif
          Endif
       Endif
    Endif
Next JL0


End

