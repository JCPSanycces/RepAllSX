######################################## Type facture achat

Subprog AS_PIVTYP(VALEUR)
Variable Char    VALEUR()
 If [F:TSV]SIVTYP<>[M]SIVTYP(nolign-1)
  #--  Read [TSV] TSV0=[M]SIVTYP(nolign-1) : If fstat  Raz [F:TSV] : Endif
  #- X3Suivi 71937 Multi-législation -#
  Local Integer WRET
  Call LEC_TSV_LEG("",[M]SIVTYP(nolign-1),WRET) From TRTLECLEG
  If WRET : Raz [F:TSV] : Endif
 Endif
End

Subprog C_PIVTYP(VALEUR)
Variable Char    VALEUR()

#--CPO 71937
Local Integer WRET
Call LEC_TPV_LEG([M:BCH1]LEGGRPTPV(nolign-1),VALEUR,WRET) From TRTLECLEG
If WRET
	Raz [F:TPV]
	#Call MESSAGE(VALEUR-mess(609,199,1)+"."-mess(610,199,1)) From GESECRAN
Endif
#--/CPO

#--CPO 71937 Contrôle de cohérence fait par le type TPV
## --- controle : groupe
#If [F:TPV]GFY<>"" & [F:TPV]GFY<>[M]GRPCPYTPV(nolign-1)
#	Call MESSAGE(num$(VALEUR)-mess(92,187,1)+":"-[F:TPV]GFY+"<>"+[M:BCH1]GRPCPYTPV(nolign-1)) From GESECRAN
# 	mkstat=1
#Endif

 #--- controle : catégorie de facture idem vente
  #--  Read [TSV] TSV0=[M]SIVTYP(nolign-1) : If fstat  Raz [F:TSV] : Endif
  #- X3Suivi 71937 Multi-législation -#
  Local Integer WRET
  Call LEC_TSV_LEG([M:BCH1]LEGGRPTSV(nolign-1),[M]SIVTYP(nolign-1),WRET) From TRTLECLEG
  If WRET : Raz [F:TSV] : Endif

 If [F:TPV]INVTYP>0 & [F:TPV]INVTYP<>[F:TSV]INVTYP
   Call MESSAGE(num$(VALEUR)-"-"-[M:BCH1]SIVTYP(nolign-1)-mess(361,192,1)+":"-mess([F:TPV]INVTYP,645,1)+"<>"+mess([F:TSV]INVTYP,645,1)) From GESECRAN
   mkstat=1 : End
 Endif

# --- Controle unicite
Local Char IDEM (30)
IDEM=[M]GRPCPYTSV(nolign-1)+"~"+[M]SIVTYP(nolign-1)+"~"+[M]GRPCPYTPV(nolign-1)+"~"+VALEUR
Call UNICITE(IDEM,[M]TYPFIDEM) From OBJDIV
If mkstat : End : Endif
End


