#CPO 01/10/08
######################################################################################
## Etiquette ajoutée par le superviseur (écran BCH150A) 01/10/2008 14:07:42 (CPO)
######################################################################################
Subprog APRES_NBCOR
#--- concatenation pour controle unicite
If [M]SFINUM(nolign-1)<>0
   [M]CORIDEM(nolign-1)=num$([M]SFINUM(nolign-1))+"~"+num$([M]PFINUM(nolign-1))
Endif

End
######################################################################################
Subprog C_PFINUM(VALEUR)
Variable Decimal VALEUR
Local Char IDEM (20)

IDEM=num$([M]SFINUM(nolign-1))+"~"+num$(VALEUR)
Call UNICITE(IDEM,[M]CORIDEM) From OBJDIV
If mkstat : End : Endif

Read [SFI]SFI0=[M]SFINUM(nolign-1)
If fstat : End : Endif

Read [PFI]PFI0=VALEUR
If fstat : End : Endif

Raz GMESSAGE
If [F:PFI]ENAFLG=1
   GMESSAGE += mess(860,196,1)-num$([F:PFI]PFINUM)+" : "+mess(1,8,1)
Endif
If [F:SFI]PROCOD=3
   If GMESSAGE<>"" : GMESSAGE += " \ " Endif
   GMESSAGE += mess(861,196,1)-num$([F:SFI]SFINUM)+" : "+mess(1,8,1)
Endif
If [F:PFI]AMTCOD<>[F:SFI]AMTCOD
   If GMESSAGE<>"" : GMESSAGE += " \ " Endif
   GMESSAGE += mess(860,196,1)-num$([F:PFI]PFINUM)+" : "+mess([F:PFI]AMTCOD,269,1)+"   "
   GMESSAGE += mess(861,196,1)-num$([F:SFI]SFINUM)+" : "+mess([F:SFI]AMTCOD,269,1)
Endif
If [F:PFI]INCDCR<>[F:SFI]INCDCR
   If GMESSAGE<>"" : GMESSAGE += " \ " Endif
   GMESSAGE += mess(860,196,1)-num$([F:PFI]PFINUM)+" : "+mess([F:PFI]INCDCR,254,1)+"   "
   GMESSAGE += mess(861,196,1)-num$([F:SFI]SFINUM)+" : "+mess([F:SFI]INCDCR,254,1)
Endif

# Bug 54201 : Interdire Elt Achat Tx produit et Elt Vente exprimé en TTC
# Un Elt Achat est tjs en HT. Si Tx produit, on ne connaît pas le mnt de taxe de l'élément pour l'ajouter au mnt HT
If [F:PFI]VATRUL=1 & [F:SFI]VALTYP=2
   If GMESSAGE<>"" : GMESSAGE += " \ " Endif
   GMESSAGE += mess(860,196,1)-num$([F:PFI]PFINUM)+" : "+mess([F:PFI]VATRUL,538,1)+"   "
   GMESSAGE += mess(861,196,1)-num$([F:SFI]SFINUM)+" : "+mess([F:SFI]VALTYP,2227,1)
Endif

If GMESSAGE<>"" : GERR=1 : mkstat=1 : Endif

End
######################################################################################
Subprog AM_SFINUM(VALEUR)
Variable Decimal VALEUR

Read [SFI] SFI0=VALEUR
[M]AMTCOD(nolign-1)=[F:SFI]AMTCOD
Affzo [M]AMTCOD(nolign-1)

End
