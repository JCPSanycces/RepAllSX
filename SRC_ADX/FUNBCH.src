################################################################################
## Ecran BCH1 : Bloc : Association types de factures
################################################################################

Subprog APRES_NBTYPF
If [M]SIVTYP(nolign-1)<>""
   [M]TYPFIDEM(nolign-1) =[M]GRPCPYTSV(nolign-1)+"~"+[M]SIVTYP(nolign-1)+"~"
   [M]TYPFIDEM(nolign-1)+=[M]GRPCPYTPV(nolign-1)+"~"+[M]PIVTYP(nolign-1)
Endif
End

######################################## Soc/Grp Vente
Subprog AS_GRPCPYTSV(VALEUR)
Variable Char    VALEUR()
[M]FILTRE_AGF="FLGCPY=2"                      : # filtre pour action SELOBJCRI1
End

Subprog IB_GRPCPYTSV
GBOUTS=mess(479,198,1)                  : # Sélection Groupe sociétés
GBOUT1=mess(481,198,1)                  : # Groupe sociétés
End

Subprog C_GRPCPYTSV(VALEUR)
Variable Char    VALEUR()
Local Integer WTROUVE :# CPO
Local Char    WSOC    :# CPO
If VALEUR="" : End : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY [AGF] : Endif
Read [AGF]AGF0=VALEUR
If fstat : mkstat=1 : Endif
If [F:AGF]FLGCPY<>2 : mkstat=1 : Endif
#--- Contrôle cohérence entre groupes saisis Achat/Vente
If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
If [M]GRPCPYTPV(nolign-1)<>""
    Filter [AGC] Where GRP=VALEUR
    If rowcount([F:AGC])=1
        Read [F:AGC] First
        Filter [F:AGC]
        If fstat : mkstat=1 : End : Endif
        WSOC=[F:AGC]CPY
        Raz WTROUVE
        For [AGC]AGC0 Where GRP=[M]GRPCPYTPV(nolign-1)
            If WSOC<>[F:AGC]CPY : WTROUVE=1 : Break : Endif
        Next
        If WTROUVE=0 : mkstat=1 : End : Endif
    Else
        Filter [F:AGC]
    Endif
Endif

End

Subprog AM_GRPCPYTSV(VALEUR)
Variable Char    VALEUR()
# Raz [M]SIVTYP(nolign-1), [M]GRPCPYTPV(nolign-1), [M]PIVTYP(nolign-1)
#--CPO 71937/84176 Multi-législation
Raz [M:BCH1]LEGGRPTSV(nolign-1)
If VALEUR<>""
	[M:BCH1]LEGGRPTSV(nolign-1)=func FUNBCH.GET_LEGGRP(VALEUR)
Endif
Affzo [M:BCH1]LEGGRPTSV(nolign-1) :#--A enlever : uniquement en phase de tests
#--/CPO
Affzo SIVTYP(nolign-1), ZSIVTYP(nolign-1), GRPCPYTPV(nolign-1), PIVTYP(nolign-1), ZPIVTYP(nolign-1)

End

