#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque BCH1
################################################################################
# FUNBCH                                                            Juin 2006  #
#                                                       Modifié CPO Oct  2008  #
#    PARAMETRAGE INTER-SOCIETES                                                #
#                                                                              #
#    - Traitement        : FUNBCH                                              #
#    - Action e_commerce : SAIBCH      (Saisie fenêtre)                        #
#                Fenêtre : FBCH1                                               #
#------------------------------------------------------------------------------#
# Attention : Ce traitement contient aussi les actions sur champ               #
#             de l'écran BCH1 [M:BCH1]                                         #
# Tables    : Ce traitement gere les tables                                    #
#             - BETCPY    : les correspondances (1 enr unique)                 #
#             - BETCPYL   : les flux autorisés/interdits (x enr)               #
#             Pas cette dernière (CPO)                                         #
#             - BETCPYDTA : les correspondances des éléments de facturation    #
################################################################################

################################################################################
# Etiquettes ACTION
################################################################################
$ACTION
#--- Actions liées à la fenêtre de paramétrage inter-sociétés
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "LECTURE"      : Gosub LECTURE      : # FGR 23/11/2009 : X3SUIVI60029
  When "SETBOUT"      : Gosub SETBOUT
  When "AV_CHOIX"     : Gosub AV_CHOIX
  When "AP_CHOIX"     : Gosub AP_CHOIX     : # FGR 23/11/2009 : X3SUIVI60029
  When "APRES_MODIF"  : Gosub APRES_MODIF  : # FGR 23/11/2009 : X3SUIVI60029 REP="M"
  When "FIN"          : Gosub FIN          : # FGR 23/11/2009 : X3SUIVI60029
  When "ABA"          : REP=""
  When "ENR"          : Gosub ENR : REP=""
#  When "AVANT_EDI"    : Gosub COP_ECRAN          : # remplacer par un etat crystal
#  When "FINSAI"       : Call IMPSCR From ATRTX3  : # remplacer par un etat crystal
  When Default
Endcase
Return

################################################################################
# Détail des actions liées à la saisie fenêtre
################################################################################

$OUVRE
Local Char SYMBOLE(30)  # FGR 20/08/2010 : X3SUIVI66795 : oublié sur la X3SUIVI60029

If clalev([F:BCH])<=0 : Local File BETCPY    [BCH] : Endif
If clalev([F:BCL])<=0 : Local File BETCPYL   [BCL] : Endif
If clalev([F:PFI])<=0 : Local File PFOOTINV  [PFI] : Endif
Gosub OPEN_SFI From TRTX3CPY
#If clalev([F:SFI])<=0 : Local File SFOOTINV  [SFI] : Endif
If clalev([F:TSV])<=0 : Local File TABSIVTYP [TSV] : Endif
If clalev([F:TPV])<=0 : Local File TABPIVTYP [TPV] : Endif
If clalev([F:TSO])<=0 : Local File TABSOHTYP [TSO] : Endif

If clalev([F:AGF])<=0 : Local File AGRPFCY   [AGF] : Endif
If clalev([F:AGC])<=0 : Local File AGRPCPY   [AGC] : Endif
If clalev([F:FGR])<=0 : Local File FACGROUP  [FGR] : Endif
If clalev([F:FCY])<=0 : Local File FACILITY  [FCY] : Endif

# --- Table BETCPY : enr. "STD" doit exister ( enr. unique de la table )
Raz [F:BCH]
Look [BCH]BCH0="STD"
If fstat
  [F:BCH]CLE="STD"
  [F:BCH]CREUSR=GUSER
  [F:BCH]CREDAT=date$
  Write [BCH]
  If fstat : FIN=1 : Return : Endif
Endif
Gosub LECTURE  # FGR 20/08/2010 : X3SUIVI66795
Return

################################################################################
$LECTURE
  # FGR 23/11/2009 : X3SUIVI60029
  Read [BCH]BCH0="STD"
  Gosub DEVERROU
  Gosub VERROU
Return

################################################################################
$VERROU
  # FGR 23/11/2009 : X3SUIVI60029
  SYMBOLE = "BCH" + "~" + "STD"
  Lock =SYMBOLE With lockwait=0
  If fstat Then
    VERROU = 0
  Else
    VERROU = 1
  Endif
Return

################################################################################
$DEVERROU
  # FGR 23/11/2009 : X3SUIVI60029
  If VERROU Then
    Unlock =SYMBOLE
    VERROU = 0
  Endif
Return

################################################################################
$SETBOUT
  # FGR 23/11/2009 : X3SUIVI60029
  If !VERROU and !find(REP,"C","D") Then
    IMGFLG(3) = 1 : # Cadenas
  Else
    IMGFLG(3) = 0
  Endif
Return

################################################################################
$APRES_MODIF
  # FGR 23/11/2009 : X3SUIVI60029
  If !VERROU Then
    Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
    mkstat = 2
    Return
  Endif
  REP = "M"
Return

################################################################################
$AP_CHOIX
  # FGR 23/11/2009 : X3SUIVI60029 clé REPONSE=2333
  If REPONSE = GSTACLK+3 Then
    If !VERROU Then
      Gosub VERROU
      If VERROU = 0 Then
        Return
      Else
        # Il faut tout relire, pas uniquement l'entête, sinon il pourrait en manquer un bout
        Gosub LECTURE
        Gosub AV_CHOIX
      Endif
    Endif
  Endif
Return

################################################################################
$FIN
  # FGR 23/11/2009 : X3SUIVI60029
  Gosub DEVERROU
Return

################################################################################

$AV_CHOIX
Local Char MANIP (25)
Local Integer IJ, IJ0, IJ1
Default Mask [BCH1]
Raz [M:BCH1]

#--- Chargement à partir de table BETCPY [BCH] --------------------------------
[M:BCH1]=[F:BCH]

#--- chargement correspondance éléments facturation
For IJ=0 To dim([M:BCH1]PFINUM)-1
    If dim([F:BCH]PFINUM)<IJ+1 : Break : Endif
    If [F:BCH]PFINUM(IJ)=0 and [F:BCH]SFINUM(IJ)=0 : Break : Endif
    [M:BCH1]PFINUM(IJ)=[F:BCH]PFINUM(IJ)
    [M:BCH1]SFINUM(IJ)=[F:BCH]SFINUM(IJ)
    [M:BCH1]CORIDEM(IJ)=num$([F:BCH]SFINUM(IJ))+"~"+num$([F:BCH]PFINUM(IJ)) :# A REVOIR ordre dans la chaîne
    Read [SFI]SFI0=[M:BCH1]SFINUM(IJ)
    If !fstat : [M:BCH1]AMTCOD(IJ)=[F:SFI]AMTCOD : Endif
    [M:BCH1]NBCOR +=1
 Next IJ

#--- Bloc : Correspondance types factures
For IJ=0 To dim([M:BCH1]GRPCPYTSV)-1
    If dim([F:BCH]SIVTYP)<IJ+1 : Break : Endif
    If [F:BCH]SIVTYP(IJ)=""    : Break : Endif
    [M:BCH1]GRPCPYTSV(IJ)=[F:BCH]GRPCPYTSV(IJ)
    [M:BCH1]SIVTYP(IJ)   =[F:BCH]SIVTYP(IJ)
    [M:BCH1]GRPCPYTPV(IJ)=[F:BCH]GRPCPYTPV(IJ)
    [M:BCH1]PIVTYP(IJ)   =[F:BCH]PIVTYP(IJ)
    [M:BCH1]TYPFIDEM(IJ) =[F:BCH]GRPCPYTSV(IJ)+"~"+[F:BCH]SIVTYP(IJ)+"~"
    [M:BCH1]TYPFIDEM(IJ)+=[F:BCH]GRPCPYTPV(IJ)+"~"+[F:BCH]PIVTYP(IJ)
    [M:BCH1]NBTYPF +=1
Next IJ

#--- Bloc : Types commandes à générer
For IJ=0 To dim([M:BCH1]SOHCAT)-1
    If dim([F:BCH]SOHCAT)<IJ+1 : Break : Endif
    If [F:BCH]SOHCAT(IJ)=0     : Break : Endif
    [M:BCH1]SOHCAT(IJ)   =[F:BCH]SOHCAT(IJ)
    [M:BCH1]GRPCPYTSO(IJ)=[F:BCH]GRPCPYTSO(IJ)
    [M:BCH1]SOHTYP(IJ)   =[F:BCH]SOHTYP(IJ)
    [M:BCH1]TYPCIDEM(IJ) =num$([F:BCH]SOHCAT(IJ))+"~"+[F:BCH]GRPCPYTSO(IJ)+"~"+[F:BCH]SOHTYP(IJ)
    [M:BCH1]NBTYPC +=1
Next IJ

# --- Chargement à partir de table BETCPYL [BCL] -------------------------------
# --- Bloc : Flux automatiques
nolign=1
For [BCL]
    [M:BCH1]=[F:BCL]
    [M:BCH1]NBCRI=nolign
    nolign +=1
Next
Affzo [M:BCH1]

# Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
For IJ=0 To [M:BCH1]NBCRI-1
  If [M:BCH1]VCRTYP(IJ)=5       : #  5-Facture vente  vers 17-Facture achat
    Diszo [M:BCH1]TRFPRI(IJ)
  Elsif [M:BCH1]VCRTYP(IJ)=14   : # 14-Commande achat  vers 2-Commande vente
    Actzo [M:BCH1]TRFPRI(IJ)
  Endif
Next IJ
# Issue 26113 - 20150707 by LD : Inter-site : Price recalculation

Return

################################################################################

$ENR
Local Integer IJL
#     tri du bloc des flux autorises
Sorta [M]NBCRI [M]NBCRI Order By [M]TYPBET([S]indice),[M]GRPCPYORI([S]indice),[M]GRPCPYDES([S]indice),[M]VCRTYP([S]indice)

#     tri du bloc correspondance elements
Sorta [M]NBCOR [M]NBCOR Order By [M]SFINUM([S]indice),[M]PFINUM([S]indice)

#     tri du bloc types factures
Sorta [M]NBTYPF [M]NBTYPF Order By [M]GRPCPYTSV([S]indice),[M]SIVTYP([S]indice)

#     tri du bloc types commandes
Sorta [M]NBTYPC [M]NBTYPC Order By [M]GRPCPYTSO([S]indice),[M]SOHCAT([S]indice)

Trbegin [BCH]

#### Ecriture enregistrement unique BETCPY [BCH]
Readlock [BCH]BCH0="STD"
If !fstat
   Raz [F:BCH]
   [F:BCH]CLE="STD" : [F:BCH]UPDUSR=GUSER : [F:BCH]UPDDAT=date$

   [F:BCH]=[M:BCH1]

   For IJL=0 To dim([M:BCH1]PFINUM)-1
       If [M:BCH1]PFINUM(IJL)=0 : Break : Endif
       [F:BCH]PFINUM(IJL)    = [M:BCH1]PFINUM(IJL)
       [F:BCH]SFINUM(IJL)    = [M:BCH1]SFINUM(IJL)
   Next IJL

   For IJL=0 To dim([M:BCH1]SIVTYP)-1
       If [M:BCH1]SIVTYP(IJL)="" : Break : Endif
       [F:BCH]GRPCPYTSV(IJL) = [M:BCH1]GRPCPYTSV(IJL)
       [F:BCH]SIVTYP(IJL)    = [M:BCH1]SIVTYP(IJL)
       [F:BCH]GRPCPYTSV(IJL) = [M:BCH1]GRPCPYTSV(IJL)
       [F:BCH]PIVTYP(IJL)    = [M:BCH1]PIVTYP(IJL)
   Next IJL

   For IJL=0 To dim([M:BCH1]SOHCAT)-1
       If [M:BCH1]SOHTYP(IJL)="" : Break : Endif
       [F:BCH]GRPCPYTSO(IJL) = [M:BCH1]GRPCPYTSO(IJL)
       [F:BCH]SOHCAT(IJL)    = [M:BCH1]SOHCAT(IJL)
       [F:BCH]SOHTYP(IJL)    = [M:BCH1]SOHTYP(IJL)
   Next IJL

   Rewrite [BCH]
Endif

#### Ecriture enregistrements BETCPYL [BCL]
Delete [BCL] Where 1=1

For IJL=0 To dim([M:BCH1]GRPCPYORI)-1
    If [M:BCH1]FLG1CPYORI(IJL)=0 : Break : Endif
    Raz [F:BCL] :# CPO
    [F:BCL]NUMERO=IJL+1
    # A supprimer après 1er passage
#    If [M:BCH1]GRPCPYORI(IJL)<>""  [M:BCH1]FLG1CPYORI(IJL)=1  Else  [M:BCH1]FLG1CPYORI(IJL)=3  Endif
#    If [M:BCH1]GRPFCYORI(IJL)<>""  [M:BCH1]FLG2FCYORI(IJL)=1  Else  [M:BCH1]FLG2FCYORI(IJL)=3  Endif
#    If [M:BCH1]GRPCPYDES(IJL)<>""  [M:BCH1]FLG3CPYDES(IJL)=1  Else  [M:BCH1]FLG3CPYDES(IJL)=3  Endif
#    If [M:BCH1]GRPFCYDES(IJL)<>""  [M:BCH1]FLG4FCYDES(IJL)=1  Else  [M:BCH1]FLG4FCYDES(IJL)=3  Endif
    # A supprimer après 1er passage
    [F:BCL]TYPBET    = [M:BCH1]TYPBET(IJL)
    [F:BCL]GRPCPYORI = [M:BCH1]GRPCPYORI(IJL)
    [F:BCL]GRPFCYORI = [M:BCH1]GRPFCYORI(IJL)
    [F:BCL]VCRTYP    = [M:BCH1]VCRTYP(IJL)
    [F:BCL]GRPCPYDES = [M:BCH1]GRPCPYDES(IJL)
    [F:BCL]GRPFCYDES = [M:BCH1]GRPFCYDES(IJL)
    [F:BCL]VCRTYPDES = [M:BCH1]VCRTYPDES(IJL)
    [F:BCL]AUZBETFLG = [M:BCH1]AUZBETFLG(IJL)
    [F:BCL]TRFPRI    = [M:BCH1]TRFPRI    (IJL) : # Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
    [F:BCL]VLTFOOINV = [M:BCH1]VLTFOOINV(IJL)
    [F:BCL]FLG1CPYORI= [M:BCH1]FLG1CPYORI(IJL)
    [F:BCL]FLG2FCYORI= [M:BCH1]FLG2FCYORI(IJL)
    [F:BCL]FLG3CPYDES= [M:BCH1]FLG3CPYDES(IJL)
    [F:BCL]FLG4FCYDES= [M:BCH1]FLG4FCYDES(IJL)
    [F:BCL]FLG1234   = [M:BCH1]FLG1CPYORI(IJL)*1000  : # constitution flag de tri
    [F:BCL]FLG1234  += [M:BCH1]FLG2FCYORI(IJL)*100
    [F:BCL]FLG1234  += [M:BCH1]FLG3CPYDES(IJL)*10
    [F:BCL]FLG1234  += [M:BCH1]FLG4FCYDES(IJL)
    #CPO
    [F:BCL]CRIBETCPY= [M:BCH1]CRIBETCPY(IJL)
    Write [BCL]
Next IJL

Commit

Return

################################################################################
# Hard copy des écrans de paramétrage ( écran principal )
# ( ne concerne pas la correspondance des elts de facturation ( objet séparé )
################################################################################
$COP_ECRAN
Local Char WTIT(100)
Local Char WMSK(GLONAMK)(5)
Local Char WABR(4)(5)
#-----
WTIT = mess(209,195,1)-mess(491,197,1)
WMSK(0) = "BCH1"
Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
FOK=0 : # Pour ne pas imprimer tout de suite !
Return



################################################################################
## Ecran BCH1 : Bloc : Flux automatique
################################################################################
Subprog APRES_NBCRI

If [M]TYPBET(nolign-1)<>0
   [M]CRIBETCPY(nolign-1)  = num$([M]TYPBET(nolign-1))+"~"
   [M]CRIBETCPY(nolign-1) += vireblc([M]GRPCPYORI(nolign-1),2)+"~"
   [M]CRIBETCPY(nolign-1) += vireblc([M]GRPFCYORI(nolign-1),2)+"~"
   [M]CRIBETCPY(nolign-1) += num$([M]VCRTYP(nolign-1))+"~"
   [M]CRIBETCPY(nolign-1) += vireblc([M]GRPCPYDES(nolign-1),2)+"~"
   [M]CRIBETCPY(nolign-1) += vireblc([M]GRPFCYDES(nolign-1),2)
Endif

End

######################################## Type
Subprog AM_TYPBET(VALEUR)
Variable Integer VALEUR
If VALEUR=1 : [M]FILTRE_AGF="FLGLEG=2" : Endif     :# filtre pour action SELOBJCRI1
If VALEUR=2 : [M]FILTRE_AGF="FLGCPY=2" : Endif     :# filtre pour action SELOBJCRI1
End

######################################## Soc/Grp Origine
# Valeur de FLG1CPYORI suivant contenu du champ societe origine GRPCPYORI
#    1= societe / 2= groupe de societes / 3= pas de saisie
#---------------------------------------
# --- Si Intra-société : Groupe d'une seule société juridique
# --- Si Inter-société : Groupe de sociétés ( une ou x sociétés juridiques ou  non )
#---------------------------------------
Subprog AS_GRPCPYORI(VALEUR)
Variable Char    VALEUR()
Raz [M]FILTRE_AGF
If [M]TYPBET(nolign-1)=1 : [M]FILTRE_AGF="FLGLEG=2" : Endif   :# filtre pour action SELOBJCRI1
If [M]TYPBET(nolign-1)=2 : [M]FILTRE_AGF="FLGCPY=2" : Endif   :# filtre pour action SELOBJCRI1
Raz [M]FILTRE_CPY
End

Subprog IB_GRPCPYORI
GBOUTS=mess(479,198,1)                  : # Sélection Groupe sociétés
GBOUT1=mess(481,198,1)                  : # Groupe sociétés
End

Subprog C_GRPCPYORI(VALEUR)
Variable Char    VALEUR()
Local Integer IJL,IJL1
Local Char WKSOCSITE
Local Integer WTROUVE
Local Integer WNBSOC

[M]FLG1CPYORI(nolign-1)=3
If VALEUR="" : End : Endif

If clalev([F:AGF])=0 : Local File AGRPFCY  [AGF] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif

Read [AGF]AGF0=VALEUR
If fstat : mkstat=1 : End : Endif
If [M]TYPBET(nolign-1)=1 & [F:AGF]FLGLEG<>2 : mkstat=1 : End : Endif :# uniquement des sociétés
If [M]TYPBET(nolign-1)=2 & [F:AGF]FLGCPY<>2 : mkstat=1 : End : Endif :# pas de groupes de sites
If [F:AGF]FLGLEG=2   [M]FLG1CPYORI(nolign-1)=1   Else [M]FLG1CPYORI(nolign-1)=2   Endif
#---Contrôle de la cohérence de ce qui a été saisi dans la colonne des sites/grp.sites
If [M]TYPBET(nolign-1)=1 :# "Intra-société"
    #--- Cohérence avec Soc/Grp. de Destination
    If [M]GRPCPYDES(nolign-1)<>""
        If [M]GRPCPYDES(nolign-1)<>VALEUR : mkstat=1 : End : Endif
    Endif
    #--- Cohérence avec Site/Grp. Origine
    If [M]GRPFCYORI(nolign-1)<>"" :# Cohérence Site/grp ORI
        If [M]FLG2FCYORI(nolign-1)=1    :# Site
            IJL=find([M]GRPFCYORI(nolign-1),GSITE(1..GNBSITE))
            If IJL & VALEUR<>GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG2FCYORI(nolign-1)=2 :# Groupe de sites
            # "Intra-sites" : le groupe de sites porte sur 1 seule et unique société
            Filter [F:FGR] Where CPY=[M]GRPFCYORI(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Read [F:FGR] First
            If fstat : mkstat=1 : Filter [F:FGR] : End : Endif
            IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
            If IJL : WKSOCSITE=GSOCSITE(IJL) : Endif
            If WKSOCSITE<>VALEUR : mkstat=1 : Filter [F:FGR] : End : Endif
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                #MAE, bg 70563
                #If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Filter [FGR] : End : Endif
                If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Break : Endif
            Next
            Filter [F:FGR]
            If mkstat = 1 : End : Endif
        Endif
    Endif
    #--- Cohérence avec Site/Grp. de Destination
    If [M]GRPFCYDES(nolign-1)<>""
        If [M]FLG4FCYDES(nolign-1)=1    :# Site
            IJL=find([M]GRPFCYDES(nolign-1),GSITE(1..GNBSITE))
            If IJL & VALEUR<>GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG4FCYDES(nolign-1)=2 :# Groupe de sites
            #nous sommes in "Intra-sites", le groupe de sites porte sur 1 seule et unique société
            Filter [F:FGR] Where CPY=[M]GRPFCYDES(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Read [F:FGR] First
            If fstat : mkstat=1 : Filter [F:FGR] : End : Endif
            IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
            If IJL : WKSOCSITE=GSOCSITE(IJL) : Endif
            If WKSOCSITE<>VALEUR : mkstat=1 : Filter [F:FGR] : End : Endif
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                #MAE, bg70563
                #If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Filter [FGR] : End : Endif
                If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Break : Endif
            Next
            Filter [F:FGR]
            If mkstat = 1 : End : Endif
        Endif
    Endif
Elsif [M]TYPBET(nolign-1)=2 :# "Inter-société"
    #--- La saisie correspond à une société
    If [M]FLG1CPYORI(nolign-1)=1
        #--- Cohérence avec Soc/Grp. de Destination
        If [M]FLG3CPYDES(nolign-1)=1                                    :# société de destination
            If [M]GRPCPYDES(nolign-1)=VALEUR : mkstat=1 : End : Endif
        Elsif [M]FLG3CPYDES(nolign-1)=2                                 :# groupe de sociétés de destination
            Filter [AGC] Where GRP=[M]GRPCPYDES(nolign-1)
            If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
            If rowcount([F:AGC])=1
                Read [F:AGC] First
                If fstat : mkstat=1 : Filter [F:AGC] : End : Endif
                If [F:AGC]CPY=VALEUR : mkstat=1 : Filter [F:AGC] : End : Endif
            Endif
            Filter [F:AGC]
        Endif
        #--- Cohérence avec Site/Grp. de destination
        If [M]FLG4FCYDES(nolign-1)=1                                    :# site de destination
            IJL=find([M]GRPFCYDES(nolign-1),GSITE(1..GNBSITE))
            If IJL & VALEUR=GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG4FCYDES(nolign-1)=2                                 :# groupe de sites de destination
            Filter [FGR] Where CPY=[M]GRPFCYDES(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL & VALEUR<>GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
        #--- Cohérence avec Site/Grp. Origine
        If [M]FLG2FCYORI(nolign-1)=1                                    :# site d'origine
            IJL=find([M]GRPFCYORI(nolign-1),GSITE(1..GNBSITE))
            If IJL & VALEUR<>GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG2FCYORI(nolign-1)=2                                 :# groupe de sites d'origine
            Filter [F:FGR] Where CPY=[M]GRPFCYORI(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL & VALEUR<>GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=1 : mkstat=1 : End : Endif
        Endif
    #--- La saisie correspond à un groupe de sociétés
    Elsif [M]FLG1CPYORI(nolign-1)=2
        #--- Cohérence avec Soc/Grp. de Destination
        If [M]FLG3CPYDES(nolign-1)=1                                    :# société de destination
            Filter [AGC] Where GRP=VALEUR
            If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
            If rowcount([F:AGC])=1
                Read [F:AGC] First
                If fstat : mkstat=1 : Filter [F:AGC] : End : Endif
                If [F:AGC]CPY=[M]GRPCPYDES(nolign-1) : mkstat=1 : Filter [F:AGC] : End : Endif
            Endif
            Filter [F:AGC]
        Elsif [M]FLG3CPYDES(nolign-1)=2                                 :# groupe de sociétés de destination
            #Si une société dans chaque groupe : elles doivent être différentes
            Raz WTROUVE
            For [AGC] Where GRP=VALEUR
                Look [AGC]AGC0=[M]GRPCPYDES(nolign-1);[F:AGC]CPY
                If fstat>0 : :WTROUVE=1 : Break : Endif
            Next
            If WTROUVE=0
                #recherche depuis groupe de destination (possible plus de sociétés dans ce dernier)
                For [AGC] Where GRP=[M]GRPCPYDES(nolign-1)
                    Look [AGC]AGC0=VALEUR;[F:AGC]CPY
                    If fstat>0 : :WTROUVE=1 : Break : Endif
                Next
            Endif
            If WTROUVE=0
                #il reste à vérifier si les deux ont le même nombre d'enregistrements
                # auquel cas c'est Ok car on peux avoir des opérations croisées
                Filter [AGC] Where GRP=VALEUR
                WNBSOC=rowcount([F:AGC]) :# Filter [AGC]
                If WNBSOC<2 : Filter [AGC] : mkstat=1 : End : Endif
                Filter [AGC] Where GRP=[M]GRPCPYDES(nolign-1)
                If WNBSOC<>rowcount([F:AGC]) : mkstat=1 : Filter [F:AGC] : End : Endif
            Endif
        Endif
        #--- Cohérence avec Site/Grp. de Destination
        If [M]FLG4FCYDES(nolign-1)=1                                    :# site de destination
            IJL=find([M]GRPFCYDES(nolign-1),GSITE(1..GNBSITE))
            If IJL
                Filter [AGC] Where GRP=VALEUR
                If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
                If rowcount([F:AGC])=1
                    Read [F:AGC] First
                    If fstat : mkstat=1 : Filter [F:AGC] : End : Endif
                    If [F:AGC]CPY=GSOCSITE(IJL) : mkstat=1 : Filter [F:AGC] : End : Endif
                Endif
                Filter [F:AGC]
            Endif
        Elsif [M]FLG4FCYDES(nolign-1)=2                                 :# groupe de sites de destination
            #Si une société dans chaque groupe : elles doivent être différentes
            Filter [AGC] Where GRP=VALEUR
            #Si le groupe de société est constitué de pls sociétés, inutile de tester car croisements possibles
            If rowcount([F:AGC])<2
                #Si un groupe de sociétés d'une seule société
                Filter [F:AGC]
                Raz WTROUVE
                For [FGR] Where CPY=[M]GRPFCYDES(nolign-1)
                    IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                    If IJL
                        Look [F:AGC]AGC0=VALEUR;GSOCSITE(IJL)
                        If fstat>0 : WTROUVE=1 : Break : Endif
                    Endif
                Next
                If WTROUVE=0 : mkstat=1 : End : Endif
            Endif
            Filter [F:AGC]
        Endif
        #--- Cohérence avec Site/Grp. d'Origine
        If [M]FLG2FCYORI(nolign-1)=1                                    :# site d'origine
            IJL=find([M]GRPFCYORI(nolign-1),GSITE(1..GNBSITE))
            If IJL
                Filter [AGC] Where GRP=VALEUR
                If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
                Raz WTROUVE
                For [AGC]
                    If [F:AGC]CPY=GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
                Next
                Filter [F:AGC]
                If WTROUVE=0 : mkstat=1 : End : Endif
            Endif
        Elsif [M]FLG2FCYORI(nolign-1)=2                                 :# groupe de sites d'origine
            #Les 2 groupes doivent avoir au moins une société en commun
            Raz WTROUVE
            For [FGR] Where CPY=[M]GRPFCYORI(nolign-1)
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL
                    Look [F:AGC]AGC0=VALEUR;GSOCSITE(IJL)
                    If fstat=0 : WTROUVE=1 : Break : Endif
                Endif
            Next
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
    Endif
Endif

End

Subprog AM_GRPCPYORI(VALEUR)
Variable Char    VALEUR()
If [M]TYPBET(nolign-1)=1
   [M]GRPCPYDES(nolign-1)=VALEUR : Affzo [M]GRPCPYDES(nolign-1)
   [M]FLG3CPYDES(nolign-1)=[M]FLG1CPYORI(nolign-1)
Endif
End

######################################## Site/Grp Origine
# Valeur de FLG2FCYORI suivant contenu du champ site origine GRPFCYORI
#    1= site / 2= groupe de sites / 3= pas de saisie
#---------------------------------------
# --- Si Intra-société : Soit pas de saisie ( tous les sites du Groupe une seule société )
#                        Soit 1 site de la société
#                        Soit Groupe sites ( il faut créer un groupe pour les sites concernés )
# --- Si Inter-société : Soit pas de saisie ( tous les sites du Groupe )
#                        Soit 1 site du Groupe
#                        Soit Groupe sites ( il faut créer un groupe pour les sites concernés )
#---------------------------------------
Subprog AS_GRPFCYORI(VALEUR)
Variable Char    VALEUR()
Raz [M]FILTRE_AGF
Raz [M]FILTRE_CPY
If [M]GRPCPYORI(nolign-1)<>"" and [M]FLG1CPYORI(nolign-1)=1
    [M]FILTRE_CPY="[F:FGR]CPY=[M]GRPCPYORI(nolign-1)"
Endif

[M]FILTRE_AGF="FLGCPY<>2"               : # filtre pour action SELOBJCRI1
End

Subprog IB_GRPFCYORI

If [M]FLG1CPYORI(nolign-1)<>1               :# si Société -> on sélectionne que les sites de cette dernière
    GBOUTS=mess(480,198,1)                  :# Sélection Groupe de sites
Else
    Raz GBOUTS
    Raz GBOUT3
    Raz GBOUT4
Endif
If [M]GRPCPYORI(nolign-1)<>"" and [M]FLG1CPYORI(nolign-1)=1
    GBOUT2=mess(264,198,1)                  : # Sélection sites
Else
    Raz GBOUT2
Endif

End

Subprog C_GRPFCYORI(VALEUR)
Variable Char    VALEUR()
Local Integer IJL,IJL1
Local Char WKSOCSITE
Local Char WOLDSOC
Local Integer WTROUVE
Local Integer WNBSOC

[M]FLG2FCYORI(nolign-1)=3
If VALEUR="" : End : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY  [AGF] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif

Read [AGF]AGF0=VALEUR
If !fstat                               : # c est un groupe de sites ( non groupe societe )
   If [F:AGF]FLGCPY=2   GMESSAGE=mess(940,196,1) : mkstat=1 : End : Endif
   [M]FLG2FCYORI(nolign-1)=2
Else
   If [M]GRPCPYORI(nolign-1)<>""
       #--- Le site doît appartenir au groupe de sociétés
       Read [FGR]FGR0=[M]GRPCPYORI(nolign-1);VALEUR
       If fstat   GMESSAGE=mess(941,196,1)-[M]GRPCPYORI(nolign-1) : mkstat=1 : End : Endif
       [M]FLG2FCYORI(nolign-1)=1
   Endif
   #--- On peux avoir un site s'il n'y a pas de société renseignée
   #--- Il doit exister dans la table FACILITY si saisie manuelle
   Look [FCY]FCY0=VALEUR
   If fstat : mkstat=1 : Endif     :#un site qui existe
   [M]FLG2FCYORI(nolign-1)=1
   #--- Le site ne doit pas étre identique à celui saisi en destination, le cas échéant
   If [M]FLG4FCYDES(nolign-1)=1
        If [M]GRPFCYDES(nolign-1)=VALEUR : mkstat=1 : End : Endif
   Endif
Endif
#--- Type de flux : "Intra-société"
If [M]TYPBET(nolign-1)=1
    Raz WKSOCSITE
    #si groupe de sites -> doit porter sur une seule société
    If [M]FLG2FCYORI(nolign-1)=2     :# groupe de sites
        Filter [F:FGR] Where CPY=VALEUR
        If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
        Read [F:FGR] First
        If fstat : mkstat=1 : Filter [F:FGR] : End : Endif
        IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
        If IJL : WKSOCSITE=GSOCSITE(IJL) : Endif
        For [FGR]
            IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
            #MAE, bg 70563
            #If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Filter [FGR] : End : Endif
            If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Break : Endif
        Next
        Filter [F:FGR]
        If mkstat = 1 : End : Endif
    Elsif [M]FLG2FCYORI(nolign-1)=1  :# Site
        IJL=find(VALEUR,GSITE(1..GNBSITE))
        If IJL : WKSOCSITE=GSOCSITE(IJL) : Endif
    Endif
    If WKSOCSITE="" : mkstat=1 : End : Endif
    If [M]GRPCPYORI(nolign-1)<>"" and WKSOCSITE<>[M]GRPCPYORI(nolign-1) : mkstat=1 : End : Endif
    If [M]GRPCPYDES(nolign-1)<>""
        If WKSOCSITE<>[M]GRPCPYDES(nolign-1) : mkstat=1 : End : Endif
    Elsif [M]GRPFCYDES(nolign-1)<>""
        If [M]FLG4FCYDES(nolign-1)=1     :#Site
            IJL=find([M]GRPFCYDES(nolign-1),GSITE(1..GNBSITE))
            If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG4FCYDES(nolign-1)=2  :# groupe de site
            Filter [F:FGR] Where CPY=[M]GRPFCYDES(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                #MAE, bg 70563
                #If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Filter [FGR] : End : Endif
                If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Break : Endif
            Next
            Filter [F:FGR]
            If mkstat = 1 : End : Endif
        Endif
    Endif
#--- Type de flux : "Inter-société"
Elsif [M]TYPBET(nolign-1)=2
    #--- La valeur renseignée est un Site
    If [M]FLG2FCYORI(nolign-1)=1
        IJL=find(VALEUR,GSITE(1..GNBSITE))
        If IJL<= 0 : mkstat=1 : End : Endif
        #--- Cohérence avec la Soc/Grp. Origine
        If [M]FLG1CPYORI(nolign-1)=1                                    :# Société d'origine
            If [M]GRPCPYORI(nolign-1)<>GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG1CPYORI(nolign-1)=2                                 :# Groupe de sociétés d'origine
            Filter [AGC] Where GRP=[M]GRPCPYORI(nolign-1)
            If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
            Raz WTROUVE
            For [AGC]
                If [F:AGC]CPY=GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:AGC]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
        #--- Cohérence avec la Soc/Grp. de Destination
        If [M]FLG3CPYDES(nolign-1)=1                                    :# Société de destination
            If [M]GRPCPYDES(nolign-1)=GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG3CPYDES(nolign-1)=2                                 :# Groupe de sociétés de destination
            Filter [AGC] Where GRP=[M]GRPCPYDES(nolign-1)
            If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
            Raz WTROUVE
            For [AGC]
                If [F:AGC]CPY<>GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:AGC]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
        #--- Cohérence avec le Site/Grp. de Destination
        If [M]FLG4FCYDES(nolign-1)=1                                    :# Site de destination
            If VALEUR=[M]GRPFCYDES(nolign-1) : mkstat=2 : End : Endif
            IJL1=find([M]GRPFCYDES(nolign-1),GSITE(1..GNBSITE))
            If IJL1 & GSOCSITE(IJL)=GSOCSITE(IJL1) : mkstat=1 : End : Endif
        Elsif [M]FLG4FCYDES(nolign-1)=2                                 :# Groupe de sites de destination
            Filter [FGR] Where CPY=[M]GRPFCYDES(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL1=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL1<=0 : Break : Endif
                If GSOCSITE(IJL)<>GSOCSITE(IJL1) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
    #--- La valeur renseignée est un groupe de sites
    Elsif [M]FLG2FCYORI(nolign-1)=2
        #--- Cohérence avec la Soc/Grp. Origine
        If [M]FLG1CPYORI(nolign-1)=1                                    :# Société d'origine
            Filter [FGR] Where CPY=VALEUR
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL1<=0 : Break : Endif
                If [M]GRPCPYORI(nolign-1)<>GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=1 : mkstat=1 : End : Endif
        Elsif [M]FLG1CPYORI(nolign-1)=2                                 :# Groupe de sociétés d'origine
            #Les groupes doivent avoir au moins une société en commun
            Raz WTROUVE
            For [FGR] Where CPY=VALEUR
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL
                    Look [F:AGC]AGC0=[M]GRPCPYORI(nolign-1);GSOCSITE(IJL)
                    If fstat=0 : WTROUVE=1 : Break : Endif
                Endif
            Next
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
        #--- Cohérence avec la Soc/Grp. de Destination
        If [M]FLG3CPYDES(nolign-1)=1                                    :# Société de destination
            Filter [FGR] Where CPY=VALEUR
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL1<=0 : Break : Endif
                If [M]GRPCPYDES(nolign-1)<>GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Elsif [M]FLG3CPYDES(nolign-1)=2                                 :# Groupe de sociétés de destination
            #Si les 2 groupes ont chacun une société, elles doivent être différentes
            Filter [AGC] Where GRP=[M]GRPCPYDES(nolign-1)
            If [M]GRPCPYDES(nolign-1)<2
                Filter [F:AGC]
                Raz WTROUVE
                For [FGR] Where CPY=VALEUR
                    IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                    If IJL
                        Look [F:AGC]AGC0=[M]GRPCPYDES(nolign-1);GSOCSITE(IJL)
                        If fstat<>0 : WTROUVE=1 : Break : Endif
                    Endif
                Next
                If WTROUVE=0 : mkstat=1 : End : Endif
            Endif
            Filter [F:AGC]
        Endif
        #--- Cohérence avec le Site/Grp. de Destination
        If [M]FLG4FCYDES(nolign-1)=1                                    :# Site de destination
            IJL=find([M]GRPFCYDES(nolign-1),GSITE(1..GNBSITE))
            If IJL<=0 : mkstat=1 : End : Endif
            Filter [FGR] Where CPY=VALEUR
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL1=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL1<=0 : Break : Endif
                If GSOCSITE(IJL)<>GSOCSITE(IJL1) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Elsif [M]FLG4FCYDES(nolign-1)=2                                 :# Groupe de sites de destination
            #Si les 2 groupes ont chacun une société, elles doivent être différentes
            Filter [FGR] Where CPY=VALEUR
            Raz WKSOCSITE
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL
                    If WKSOCSITE="" : WKSOCSITE=GSOCSITE(IJL) : WNBSOC+=1
                    Elsif WKSOCSITE<>GSOCSITE(IJL) : WNBSOC+=1 : Break : Endif
                Endif
            Next
            Filter [F:FGR]
            If WNBSOC<2
                Filter [FGR] Where CPY=[M]GRPFCYDES(nolign-1)
                WOLDSOC=WKSOCSITE
                Raz WKSOCSITE
                Raz WNBSOC
                For [FGR]
                    IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                    If IJL
                        If WKSOCSITE="" : WKSOCSITE=GSOCSITE(IJL) : WNBSOC+=1
                        Elsif WKSOCSITE<>GSOCSITE(IJL) : WNBSOC+=1 : Break : Endif
                    Endif
                Next
                Filter [F:FGR]
                If WNBSOC<2
                    If WOLDSOC=WKSOCSITE : mkstat=1 : End : Endif
                Endif
            Endif
        Endif
    Endif
Endif

End

######################################## Document
Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR
Local Integer IJL
For IJL=0 To dim(GMENLOC)-1 : GMENLOC(IJL)=1 : Next IJL
#GMENLOC(2)=0                           : # commande vente  (non actif actuellement)
GMENLOC(5)=0                            : # facture vente
GMENLOC(14)=0                           : # commande achat
Case [M]TYPBET(nolign-1)
  When 1 : VALEUR=14 :# Flux intra-société - pièce par défaut "Commande achat"
  When 2 : VALEUR=5  :# Flux inter-sociétés- pièce par défaut "Facture  vente"
Endcase

End

Subprog AP_VCRTYP(VALEUR)
Variable Integer VALEUR
Case VALEUR
     When 5   [M]VCRTYPDES(nolign-1)=17  : # fac vente --> fac achat
     When 14  [M]VCRTYPDES(nolign-1)=2   : # cde achat --> cde vente
Endcase
Affzo [M]VCRTYPDES(nolign-1)
Raz GMENLOC

# Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
If VALEUR=5       : #  5-Facture vente  vers 17-Facture achat
  [M:BCH1]TRFPRI(nolign-1)=2
  Diszo [M:BCH1]TRFPRI(nolign-1)
Elsif VALEUR=14   : # 14-Commande achat  vers 2-Commande vente
  [M:BCH1]TRFPRI(nolign-1)=1
  Actzo [M:BCH1]TRFPRI(nolign-1)
Endif
Affzo [M:BCH1]TRFPRI(nolign-1)
# Issue 26113 - 20150707 by LD : Inter-site : Price recalculation

End

Subprog C_VCRTYP(VALEUR)
Variable Integer VALEUR
#---Pas de factures pour le flux "Intra-société"
If (VALEUR=5) and [M]TYPBET(nolign-1)=1 : mkstat=2 : Endif

End
######################################################################################
######################################## Soc/Grp Dest.
# Valeur de FLG3CPYDES suivant contenu du champ societe destination GRPCPYDES
#    1= societe / 2= groupe de societes / 3= pas de saisie
#---------------------------------------
# --- Si Intra-société : Pas de saisie ou société idem Soc/Grp Origine
# --- Si Inter-société : Groupe de sociétés ( une ou x sociétés juridiques ou  non )
#---------------------------------------
Subprog AS_GRPCPYDES(VALEUR)
Variable Char    VALEUR()
Raz [M]FILTRE_AGF

#If [M]TYPBET(nolign-1)=1 : mkstat=2 : Endif
If [M]TYPBET(nolign-1)=1 : [M]FILTRE_AGF="FLGLEG=2" : Endif    :# filtre pour action SELOBJCRI1
If [M]TYPBET(nolign-1)=2 : [M]FILTRE_AGF="FLGCPY=2" : Endif    :# filtre pour action SELOBJCRI1
Raz [M]FILTRE_CPY
End

Subprog IB_GRPCPYDES
GBOUTS=mess(479,198,1)                  : # Sélection Groupe sociétés
GBOUT1=mess(481,198,1)                  : # Groupe sociétés
End

Subprog C_GRPCPYDES(VALEUR)
Variable Char    VALEUR()

Local Integer IJL,IJL1
Local Char WKSOCSITE
Local Integer WTROUVE
Local Integer WNBSOC


[M]FLG3CPYDES(nolign-1)=3
# If [M]TYPBET(nolign-1)=1 : End : Endif
If VALEUR="" : End : Endif

If clalev([F:AGF])=0 : Local File AGRPFCY [AGF] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif

Read [AGF]AGF0=VALEUR
If fstat : mkstat=1 : End : Endif
If [M]TYPBET(nolign-1)=1 & [F:AGF]FLGLEG<>2 : mkstat=1 : End : Endif
If [M]TYPBET(nolign-1)=2 & [F:AGF]FLGCPY<>2 : mkstat=1 : End : Endif
If [F:AGF]FLGLEG=2   [M]FLG3CPYDES(nolign-1)=1   Else [M]FLG3CPYDES(nolign-1)=2   Endif
#---Contrôle de la cohérence de ce qui a été saisi dans la colonne des sites/grp.sites
If [M]TYPBET(nolign-1)=1 :# "Intra-société"
    If [M]GRPCPYORI(nolign-1)<>"" :# Cohérence Soc/grp ORI
        If [M]GRPCPYORI(nolign-1)<>VALEUR : mkstat=1 : End : Endif
    Endif
    If [M]GRPFCYDES(nolign-1)<>"" :# Cohérence Site/grp DES
        If [M]FLG4FCYDES(nolign-1)=1 :# Site
            IJL=find([M]GRPFCYDES(nolign-1),GSITE(1..GNBSITE))
            If IJL & VALEUR<>GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG4FCYDES(nolign-1)=2 :# Groupe de sites
            #nous sommes in "Intra-sites", le groupe de sites porte sur 1 seule et unique société
            Filter [F:FGR] Where CPY=[M]GRPFCYDES(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Read [F:FGR] First
            If fstat : mkstat=1 : Filter [F:FGR] : End : Endif
            IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
            If IJL : WKSOCSITE=GSOCSITE(IJL) : Endif
            If WKSOCSITE<>VALEUR : mkstat=1 : Filter [F:FGR] : End : Endif
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                #MAE, bg 70563
                #If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Filter [FGR] : End : Endif
                If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Break : Endif
            Next
            Filter [F:FGR]
            If mkstat = 1 : End : Endif
        Endif
    Endif
    If [M]GRPFCYORI(nolign-1)<>"" :# Cohérence Site/grp ORI
        If [M]FLG2FCYORI(nolign-1)=1 :# Site
            IJL=find([M]GRPFCYORI(nolign-1),GSITE(1..GNBSITE))
            If IJL & VALEUR<>GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG2FCYORI(nolign-1)=2 :# Groupe de sites
            #nous sommes in "Intra-sites", le groupe de sites porte sur 1 seule et unique société
            Filter [F:FGR] Where CPY=[M]GRPFCYORI(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Read [F:FGR] First
            If fstat : mkstat=1 : Filter [F:FGR] : End : Endif
            IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
            If IJL : WKSOCSITE=GSOCSITE(IJL) : Endif
            If WKSOCSITE<>VALEUR : mkstat=1 : Filter [F:FGR] : End : Endif
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                #MAE, bg 70563
                #If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Filter [FGR] : End : Endif
                If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Break : Endif
            Next
            Filter [F:FGR]
            If mkstat = 1 : End : Endif
        Endif
    Endif
Elsif [M]TYPBET(nolign-1)=2 :# "Inter-société"
    #--- La saisie correspond à une société
    If [M]FLG3CPYDES(nolign-1)=1
        #--- Cohérence avec Soc/Grp. ORI
        If [M]FLG1CPYORI(nolign-1)=1                                    :# société d'origine
            If [M]GRPCPYORI(nolign-1)=VALEUR : mkstat=1 : End : Endif
        Elsif [M]FLG1CPYORI(nolign-1)=2                                 :# groupe de sociétés d'origine
            Filter [AGC] Where GRP=[M]GRPCPYORI(nolign-1)
            If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
            If rowcount([F:AGC])=1
                Read [F:AGC] First
                If fstat : mkstat=1 : Filter [F:AGC] : End : Endif
                If [F:AGC]CPY=VALEUR : mkstat=1 : Filter [F:AGC] : End : Endif
            Endif
            Filter [F:AGC]
        Endif
        #--- Cohérence avec Site/Grp. d'origine
        If [M]FLG2FCYORI(nolign-1)=1                                    :# site d'origine
            IJL=find([M]GRPFCYORI(nolign-1),GSITE(1..GNBSITE))
            If IJL & VALEUR=GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG2FCYORI(nolign-1)=2                                 :# groupe de sites d'origine
            Filter [FGR] Where CPY=[M]GRPFCYORI(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL & VALEUR<>GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
        #--- Cohérence avec Site/Grp. de destination
        If [M]FLG4FCYDES(nolign-1)=1                                    :# site de destination
            IJL=find([M]GRPFCYDES(nolign-1),GSITE(1..GNBSITE))
            If IJL & VALEUR<>GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG4FCYDES(nolign-1)=2                                 :# groupe de sites de destination
            Filter [F:FGR] Where CPY=[M]GRPFCYDES(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL & VALEUR<>GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=1 : mkstat=1 : End : Endif
        Endif
    #--- La saisie correspond à un groupe de sociétés
    Elsif [M]FLG3CPYDES(nolign-1)=2
        #--- Cohérence avec Soc/Grp. d'origine
        If [M]FLG1CPYORI(nolign-1)=1                                    :# société d'origine
            Filter [AGC] Where GRP=VALEUR
            If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
            If rowcount([F:AGC])=1
                Read [F:AGC] First
                If fstat : mkstat=1 : Filter [F:AGC] : End : Endif
                If [F:AGC]CPY=[M]GRPCPYORI(nolign-1) : mkstat=1 : Filter [F:AGC] : End : Endif
            Endif
            Filter [F:AGC]
        Elsif [M]FLG1CPYORI(nolign-1)=2                                 :# groupe de sociétés d'origine
            #Si une société dans chaque groupe : elles doivent être différentes
            Raz WTROUVE
            For [AGC] Where GRP=VALEUR
                Look [AGC]AGC0=[M]GRPCPYORI(nolign-1);[F:AGC]CPY
                If fstat>0 : :WTROUVE=1 : Break : Endif
            Next
            If WTROUVE=0
                #recherche depuis groupe d'origine (possible plus de sociétés dans ce dernier)
                For [AGC] Where GRP=[M]GRPCPYORI(nolign-1)
                    Look [AGC]AGC0=VALEUR;[F:AGC]CPY
                    If fstat>0 : :WTROUVE=1 : Break : Endif
                Next
            Endif
            If WTROUVE=0
                #il reste à vérifier si les deux ont le même nombre d'enregistrements
                # auquel cas c'est Ok car on peux avoir des opérations croisées
                Filter [AGC] Where GRP=VALEUR
                WNBSOC=rowcount([F:AGC]) :# Filter [AGC]
                If WNBSOC<2 : Filter [AGC] : mkstat=1 : End : Endif
                Filter [AGC] Where GRP=[M]GRPCPYORI(nolign-1)
                If WNBSOC<>rowcount([F:AGC]) : mkstat=1 : Filter [F:AGC] : End : Endif
            Endif
        Endif
        #--- Cohérence avec Site/Grp. d'origine
        If [M]FLG2FCYORI(nolign-1)=1                                    :# site d'origine
            IJL=find([M]GRPFCYORI(nolign-1),GSITE(1..GNBSITE))
            If IJL
                Filter [AGC] Where GRP=VALEUR
                If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
                If rowcount([F:AGC])=1
                    Read [F:AGC] First
                    If fstat : mkstat=1 : Filter [F:AGC] : End : Endif
                    If [F:AGC]CPY=GSOCSITE(IJL) : mkstat=1 : Filter [F:AGC] : End : Endif
                Endif
                Filter [F:AGC]
            Endif
        Elsif [M]FLG2FCYORI(nolign-1)=2                                 :# groupe de sites d'origine
            #Si une société dans chaque groupe : elles doivent être différentes
            Filter [AGC] Where GRP=VALEUR
            #Si le groupe de société est constitué de pls sociétés, inutile de tester car croisements possibles
            If rowcount([F:AGC])<2
                #Si un groupe de sociétés d'une seule société
                Filter [F:AGC]
                Raz WTROUVE
                For [FGR] Where CPY=[M]GRPFCYORI(nolign-1)
                    IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                    If IJL
                        Look [F:AGC]AGC0=VALEUR;GSOCSITE(IJL)
                        If fstat>0 : WTROUVE=1 : Break : Endif
                    Endif
                Next
                If WTROUVE=0 : mkstat=1 : End : Endif
            Endif
            Filter [F:AGC]
        Endif
        #--- Cohérence avec Site/Grp. de destination
        If [M]FLG4FCYDES(nolign-1)=1                                    :# site de destination
            IJL=find([M]GRPFCYDES(nolign-1),GSITE(1..GNBSITE))
            If IJL
                Filter [AGC] Where GRP=VALEUR
                If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
                Raz WTROUVE
                For [AGC]
                    If [F:AGC]CPY=GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
                Next
                Filter [F:AGC]
                If WTROUVE=0 : mkstat=1 : End : Endif
            Endif
        Elsif [M]FLG4FCYDES(nolign-1)=2                                 :# groupe de sites de destination
            #Les 2 groupes doivent avoir au moins une société en commun
            Raz WTROUVE
            For [FGR] Where CPY=[M]GRPFCYDES(nolign-1)
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL
                    Look [F:AGC]AGC0=VALEUR;GSOCSITE(IJL)
                    If fstat=0 : WTROUVE=1 : Break : Endif
                Endif
            Next
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
    Endif
Endif

End

######################################## Site/Grp Dest.
# Valeur de FLG4FCYDES suivant contenu du champ site origine GRPFCYDES
#    1= site / 2= groupe de sites  / 3= pas de saisie
#---------------------------------------
# --- Si Intra-société : Soit pas de saisie ( tous les sites du Groupe une seule société )
#                        Soit 1 site de la société
#                        Soit Groupe sites ( il faut créer un groupe pour les sites concernés )
# --- Si Inter-société : Soit pas de saisie ( tous les sites du Groupe )
#                        Soit 1 site du Groupe
#                        Soit Groupe sites ( il faut créer un groupe pour les sites concernés )
#---------------------------------------
Subprog AS_GRPFCYDES(VALEUR)
Variable Char    VALEUR()
[M]FLG4FCYDES(nolign-1)=3
Raz [M]FILTRE_AGF
[M]FILTRE_AGF="FLGCPY<>2"               : # filtre pour action SELOBJCRI1
Raz [M]FILTRE_CPY
If [M]GRPCPYDES(nolign-1)<>"" and [M]FLG3CPYDES(nolign-1)=1
    [M]FILTRE_CPY="[F:FGR]CPY=[M]GRPCPYDES(nolign-1)"
Endif
End

Subprog IB_GRPFCYDES

If [M]FLG3CPYDES(nolign-1)<>1               :# si Société -> on sélectionne que les sites de cette dernière
    GBOUTS=mess(480,198,1)                  : # Sélection Groupe sites
Else
    Raz GBOUTS
    Raz GBOUT3
    Raz GBOUT4
Endif
If [M]GRPCPYDES(nolign-1)<>"" and [M]FLG3CPYDES(nolign-1)=1
    GBOUT2=mess(264,198,1)                  : # Sélection sites
Else
    Raz GBOUT2
Endif

End

Subprog C_GRPFCYDES(VALEUR)
Variable Char    VALEUR()

Local Integer IJL,IJL1
Local Char WKSOCSITE
Local Char WOLDSOC
Local Integer WTROUVE
Local Integer WNBSOC

[M]FLG4FCYDES(nolign-1)=3
If VALEUR="" : End : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY  [AGF] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif

Read [AGF]AGF0=VALEUR
If !fstat                               : # c est un groupe de sites ( non groupe societe )
   If [F:AGF]FLGCPY=2   GMESSAGE=mess(940,196,1) : mkstat=1 : End   Endif
   [M]FLG4FCYDES(nolign-1)=2
Else
   If [M]GRPCPYDES(nolign-1)<>""
       Read [FGR]FGR0=[M]GRPCPYDES(nolign-1);VALEUR
       If fstat   GMESSAGE=mess(941,196,1)-[M]GRPCPYDES(nolign-1) : mkstat=1 : End   Endif
       [M]FLG4FCYDES(nolign-1)=1
   Endif
   #--- On peux avoir un site s'il n'y a pas de société renseignée
   Look [FCY]FCY0=VALEUR
   If fstat : mkstat=1 : Endif     :#un site qui existe

   #--- Le site ne doit pas étre identique à celui saisi en origine, le cas échéant
   If [M]FLG2FCYORI(nolign-1)=1
        If [M]GRPFCYORI(nolign-1)=VALEUR : mkstat=1 : End : Endif
   Endif
   [M]FLG4FCYDES(nolign-1)=1
Endif
If [M]TYPBET(nolign-1)=1    :# Type de flux : "Intra-société"
    Raz WKSOCSITE
    #si groupe de sites -> doit porter sur une seule société
    If [M]FLG4FCYDES(nolign-1)=2     :# groupe de sites
        Filter [F:FGR] Where CPY=VALEUR
        If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
        Read [F:FGR] First
        If fstat : mkstat=1 : Filter [F:FGR] : End : Endif
        IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
        If IJL : WKSOCSITE=GSOCSITE(IJL) : Endif
        For [FGR]
            IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
            #MAE, bg 70563
            #If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Filter [FGR] : End : Endif
            If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Break : Endif
        Next
        Filter [F:FGR]
        If mkstat = 1 : End : Endif
    Elsif [M]FLG4FCYDES(nolign-1)=1  :# Site
        IJL=find(VALEUR,GSITE(1..GNBSITE))
        If IJL WKSOCSITE=GSOCSITE(IJL) : Endif
    Endif
    If WKSOCSITE="" : mkstat=1 : End : Endif
    If [M]GRPCPYDES(nolign-1)<>"" and WKSOCSITE<>[M]GRPCPYDES(nolign-1) : mkstat=1 : End : Endif
    If [M]GRPCPYORI(nolign-1)<>""
        If WKSOCSITE<>[M]GRPCPYORI(nolign-1) : mkstat=1 : End : Endif
    Elsif [M]GRPFCYORI(nolign-1)<>""
        If [M]FLG2FCYORI(nolign-1)=1     :#Site
            IJL=find([M]GRPFCYORI(nolign-1),GSITE(1..GNBSITE))
            If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG2FCYORI(nolign-1)=2  :# groupe de site
            Filter [F:FGR] Where CPY=[M]GRPFCYORI(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                #MAE, bg 70563
                #If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Filter [FGR] : End : Endif
                If IJL & WKSOCSITE<>GSOCSITE(IJL) : mkstat=1 : Break : Endif
            Next
            Filter [F:FGR]
            If mkstat = 1 : End : Endif
        Endif
    Endif
Elsif [M]TYPBET(nolign-1)=2 :# Type de flux : "Inter-société"
    #--- La valeur renseignée est un Site
    If [M]FLG4FCYDES(nolign-1)=1
        IJL=find(VALEUR,GSITE(1..GNBSITE))
        If IJL<= 0 : mkstat=1 : End : Endif
        #--- Cohérence avec la Soc/Grp. de destination
        If [M]FLG3CPYDES(nolign-1)=1                                    :# Société de destination
            If [M]GRPCPYDES(nolign-1)<>GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG3CPYDES(nolign-1)=2                                 :# Groupe de sociétés de destination
            Filter [AGC] Where GRP=[M]GRPCPYDES(nolign-1)
            If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
            Raz WTROUVE
            For [AGC]
                If [F:AGC]CPY=GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:AGC]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
        #--- Cohérence avec la Soc/Grp. d'origine
        If [M]FLG1CPYORI(nolign-1)=1                                    :# Société d'origine
            If [M]GRPCPYORI(nolign-1)=GSOCSITE(IJL) : mkstat=1 : End : Endif
        Elsif [M]FLG1CPYORI(nolign-1)=2                                 :# Groupe de sociétés d'origine
            Filter [AGC] Where GRP=[M]GRPCPYORI(nolign-1)
            If rowcount([F:AGC])<1 : mkstat=1 : Filter [F:AGC] : End : Endif
            Raz WTROUVE
            For [AGC]
                If [F:AGC]CPY<>GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:AGC]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
        #--- Cohérence avec le Site/Grp. d'origine
        If [M]FLG2FCYORI(nolign-1)=1                                    :# Site d'origine
            If VALEUR=[M]GRPFCYORI(nolign-1) : mkstat=2 : End : Endif
            IJL1=find([M]GRPFCYORI(nolign-1),GSITE(1..GNBSITE))
            If IJL1 & GSOCSITE(IJL)=GSOCSITE(IJL1) : mkstat=1 : End : Endif
        Elsif [M]FLG2FCYORI(nolign-1)=2                                 :# Groupe de sites d'origine
            Filter [FGR] Where CPY=[M]GRPFCYORI(nolign-1)
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL1=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL1<=0 : Break : Endif
                If GSOCSITE(IJL)<>GSOCSITE(IJL1) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
    #--- La valeur renseignée est un groupe de sites
    Elsif [M]FLG4FCYDES(nolign-1)=2
        #--- Cohérence avec la Soc/Grp. de destination
        If [M]FLG3CPYDES(nolign-1)=1                                    :# Société de destination
            Filter [FGR] Where CPY=VALEUR
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL1<=0 : Break : Endif
                If [M]GRPCPYDES(nolign-1)<>GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=1 : mkstat=1 : End : Endif
        Elsif [M]FLG3CPYDES(nolign-1)=2                                 :# Groupe de sociétés de destination
            #Les groupes doivent avoir au moins une société en commun
            Raz WTROUVE
            For [FGR] Where CPY=VALEUR
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL
                    Look [F:AGC]AGC0=[M]GRPCPYDES(nolign-1);GSOCSITE(IJL)
                    If fstat=0 : WTROUVE=1 : Break : Endif
                Endif
            Next
            If WTROUVE=0 : mkstat=1 : End : Endif
        Endif
        #--- Cohérence avec la Soc/Grp. d'origine
        If [M]FLG1CPYORI(nolign-1)=1                                    :# Société d'origine
            Filter [FGR] Where CPY=VALEUR
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL1<=0 : Break : Endif
                If [M]GRPCPYORI(nolign-1)<>GSOCSITE(IJL) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Elsif [M]FLG1CPYORI(nolign-1)=2                                 :# Groupe de sociétés d'origine
            #Si les 2 groupes ont chacun une société, elles doivent être différentes
            Filter [AGC] Where GRP=[M]GRPCPYORI(nolign-1)
            If [M]GRPCPYORI(nolign-1)<2
                Filter [F:AGC]
                Raz WTROUVE
                For [FGR] Where CPY=VALEUR
                    IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                    If IJL
                        Look [F:AGC]AGC0=[M]GRPCPYORI(nolign-1);GSOCSITE(IJL)
                        If fstat<>0 : WTROUVE=1 : Break : Endif
                    Endif
                Next
                If WTROUVE=0 : mkstat=1 : End : Endif
            Endif
            Filter [F:AGC]
        Endif
        #--- Cohérence avec le Site/Grp. d'origine
        If [M]FLG2FCYORI(nolign-1)=1                                    :# Site d'origine
            IJL=find([M]GRPFCYORI(nolign-1),GSITE(1..GNBSITE))
            If IJL<=0 : mkstat=1 : End : Endif
            Filter [FGR] Where CPY=VALEUR
            If rowcount([F:FGR])<1 : mkstat=1 : Filter [F:FGR] : End : Endif
            Raz WTROUVE
            For [FGR]
                IJL1=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL1<=0 : Break : Endif
                If GSOCSITE(IJL)<>GSOCSITE(IJL1) : WTROUVE=1 : Break : Endif
            Next
            Filter [F:FGR]
            If WTROUVE=0 : mkstat=1 : End : Endif
        Elsif [M]FLG2FCYORI(nolign-1)=2                                 :# Groupe de sites d'origine
            #Si les 2 groupes ont chacun une société, elles doivent être différentes
            Filter [FGR] Where CPY=VALEUR
            Raz WKSOCSITE
            For [FGR]
                IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                If IJL
                    If WKSOCSITE="" : WKSOCSITE=GSOCSITE(IJL) : WNBSOC+=1
                    Elsif WKSOCSITE<>GSOCSITE(IJL) : WNBSOC+=1 : Break : Endif
                Endif
            Next
            Filter [F:FGR]
            If WNBSOC<2
                Filter [FGR] Where CPY=[M]GRPFCYORI(nolign-1)
                WOLDSOC=WKSOCSITE
                Raz WKSOCSITE
                Raz WNBSOC
                For [FGR]
                    IJL=find([F:FGR]FCY,GSITE(1..GNBSITE))
                    If IJL
                        If WKSOCSITE="" : WKSOCSITE=GSOCSITE(IJL) : WNBSOC+=1
                        Elsif WKSOCSITE<>GSOCSITE(IJL) : WNBSOC+=1 : Break : Endif
                    Endif
                Next
                Filter [F:FGR]
                If WNBSOC<2
                    If WOLDSOC=WKSOCSITE : mkstat=1 : End : Endif
                Endif
            Endif
        Endif
    Endif
Endif

End

######################################## Elts facture
Subprog AS_VLTFOOINV(VALEUR)
Variable Integer VALEUR
Local Integer IJL
For IJL=0 To dim(GMENLOC)-1 : GMENLOC(IJL)=1 : Next IJL
GMENLOC(1)=0           : # Achats
GMENLOC(2)=0           : # Ventes
If [M]VCRTYP(nolign-1)<>14 : VALEUR=2 : mkstat=2 : Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BCH1) 06/11/2008 17:06:32 (CPO)
######################################################################################
Subprog C_AUZBETFLG(VALEUR)
Variable Integer VALEUR
Local Char IDEM(25)

#Contrôle unicité ligne
IDEM  =num$([M]TYPBET(nolign-1))+"~"
IDEM +=[M]GRPCPYORI(nolign-1)+"~"
IDEM +=[M]GRPFCYORI(nolign-1)+"~"
IDEM +=num$([M]VCRTYP(nolign-1))+"~"
IDEM +=[M]GRPCPYDES(nolign-1)+"~"
IDEM +=[M]GRPFCYDES(nolign-1)
Call UNICITE(IDEM,[M]CRIBETCPY) From OBJDIV
If mkstat : End : Endif

End
