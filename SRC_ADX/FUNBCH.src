######################################################################################
#--CPO 71937/84173 Déclinaison par législation et inter-société
Funprog GET_LEGGRP(GROUPE)
Value Char GROUPE

Local Char    LEGGRP(GLONADI)
Local Integer WLEGDIFF

LEGGRP=""

If GROUPE="" Goto END_GET_LEGGRP : Endif

If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY [AGF] : Endif
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
#--Lecture du groupe
If [F:AGF]GRP<>GROUPE
	Read [F:AGF]AGF0=GROUPE
	If fstat : Raz [F:AGF] : Goto END_GET_LEGGRP : Endif
Endif

If [F:AGF]FLGLEG=2
	#--Société juridique : on renvoie la législation de cette dernière
	If [F:CPY]CPY<>[F:AGF]GRP
		Read [F:CPY]CPY0=[F:AGF]GRP
		If fstat : Raz [F:CPY] : Goto END_GET_LEGGRP : Endif
	Endif
	LEGGRP=[F:CPY]LEG
Elsif [F:AGF]FLGCPY=2
	#--Groupe de sociétés : on renvoie "" si au moins deux sociétés du groupe ont des lég différentes
	WLEGDIFF = 0
	Link [F:CPY] With [F:AGC]AGC0~=GROUPE;[F:CPY]CPY As [CPYL_]
	Read [F:CPYL_] First
	If !fstat
		LEGGRP=[F:CPYL_]LEG
		While fstat=0 and WLEGDIFF=0
			Read [F:CPYL_] Next
			If !fstat
				If LEGGRP<>"" and LEGGRP<>[F:CPYL_]LEG : LEGGRP="" : WLEGDIFF=1 : Endif
			Endif
		Wend
	Endif
Endif

$END_GET_LEGGRP
End LEGGRP

