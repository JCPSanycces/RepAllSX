Return

$PROPAGATE_USRFLDA7
this.isReadonly = 0
[L]CURPRO = "USRFLDA7"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
