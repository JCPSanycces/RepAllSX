Endif
Gosub CONTROL_USRFLDA7
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.USRFLDA7
 Gosub PROPAGATE_USRFLDA7
Endif
Return

$INIT_USRFLDA7
Gosub DECLARE_VAR From WMC0ECCNREV
[L]CURPRO = "USRFLDA7"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_USRFLDA7
