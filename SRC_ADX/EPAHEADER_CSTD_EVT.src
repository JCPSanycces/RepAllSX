#<AdxTL>@(#)0.0.0.0 $Revision$
#FRLAA - 2016-12-06 - REQUIREMENT X3-11647 US X3-12771 - START
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINSERT_CONTROL_AFTER"    : Gosub AINSERT_CONTROL_AFTER
      When "AUPDATE_CONTROL_AFTER"    : Gosub AUPDATE_CONTROL_AFTER
      When "AINSERT_CONTROL_BEFORE"   : Gosub AINSERT_CONTROL_BEFORE
      When "AUPDATE_CONTROL_BEFORE"   : Gosub AUPDATE_CONTROL_BEFORE
      When "AREAD_AFTER"              : Gosub AREAD_AFTER
    Endcase
Endcase
Return

$AREAD_AFTER
Local File EMPLOID  [ID]
Read[F:ID]ID0=this.REFNUM
If fstat = [V]CST_AOK Then
  this.TCHNAM = [F:ID]NAM
  this.TCHSRN = [F:ID]SRN
Endif


#Store VCPY and VFCY
Local Char VCPY(GLONCPY), VFCY(GLONFCY)
Local Integer TYPVAL,K
Local Integer EPADETIND : EPADETIND = 1
If this.EPADETAILS = null
  If this.EPADETAILS(EPADETIND) = null
    K = fmet this.ADDLINE("EPADETAILS",EPADETIND)
  Endif
Endif

If this.EPADETAILS(EPADETIND).ADMCST = 2
  TYPVAL = 7
Elsif this.EPADETAILS(EPADETIND).ADMCST = 3
  TYPVAL = 5
Else
  TYPVAL = 0
Endif

Call FCY_CPY(this.REFNUM,this.CTRNUM,this.CTRDAT,VCPY,VFCY) From EPAHEADER_CSTD_PRO

this.EPADETAILS(EPADETIND).WADMVAL = func EPAFUNCTIONS.GET_RATE(TYPVAL,eomonth(GMOIPAY),this.LEG,VCPY,VFCY) + this.EPADETAILS(EPADETIND).ADMVAL

LogicClose File [ID]
Return

$AINSERT_CONTROL_BEFORE
$AUPDATE_CONTROL_BEFORE
Return


$AINSERT_CONTROL_AFTER
Local Integer RANKNBR, VARLIGNBR,INDEX
Local Integer EPADETIND : EPADETIND = 1
#Assign variables
INDEX = 1
#Adding lines to the collections
If this.EPADETAILS(INDEX) = null : INDEX = fmet this.ADDLINE("EPADETAILS", [V]CST_ALASTPOS) : Endif

#Assign the rank only when the record is created
RANKNBR = func EPAFUNCTIONS.GET_EPAVAR_RANK(this.REFNUM, this.CTRNUM, this.CTRDAT, this.EPADETAILS(INDEX).EPATYP)
If RANKNBR = 0
  ASTATUS=fmet this.ASETERROR("",mess(00045,00133,1),[V]CST_AERROR)
Endif

#Assign the rank number to the class
this.EPADETAILS.HEARNK = RANKNBR

#Getting the variable ranges
VARLIGNBR = func EPAFUNCTIONS.GETVARIABLE(this.EPADETAILS(INDEX).EPATYP, this.REFNUM, this.CTRNUM, this.CTRDAT)
If VARLIGNBR = 0
  ASTATUS=fmet this.ASETERROR("",mess(00010,10661,1),[V]CST_AERROR)
Endif

If func EPAFUNCTIONS.ASSIGN_VARIABLES(this,VARLIGNBR,INDEX) = 0
  ASTATUS=fmet this.ASETERROR("",mess(00045,00133,1)-mess(00010,10661,1),[V]CST_AERROR)
Endif

$AUPDATE_CONTROL_AFTER
If (ASTATUS <> [V]CST_AOK) : Return : Endif
Return

