#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_SETDEF
Onevent INIT_AREA Call D_SETDEF(zc) From W5CTR4
Onevent BEFORE_INPUT Call AS_SETDEF(zc) From W5CTR4
Return

Subprog D_SETDEF(VALEUR)
Variable Integer VALEUR
If varinit([M]SETDEF,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SETDEF(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CARREG
Onevent CONTROL Call C_CARREG(zc) From W5CTR4
Onevent BEFORE_INPUT Call AS_CARREG(zc) From W5CTR4
Return

Subprog AS_CARREG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CARREG(zc) From W5CTR4
Onkey 144 Titled GBOUTP Call P_CARREG(zc) From W5CTR4
Onkey 146 Titled GBOUTA Call SA_CARREG(zc) From W5CTR4
Gosub _AFF
End

Subprog C_CARREG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CARREG" : GZNUM = 55180 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CUCA","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CARREG" : GZNUM = 55180 : Endif
 If !mkstat
  ## Action STD
  Call C_CARREG(VALEUR) From SUBCTR
  If mkstat : GERR = 1 : GZONE = "CARREG" : GZNUM = 55180 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CARREG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJCRIT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJCRIT"
 PARMSK(1) = "CUCA"
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = "[F:CUCA]CPY=[M:CTR0]CPY"
 PARMSK(5) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CARREG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CUCA"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CARREG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CUCA",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_FUETYP
Onevent INIT_AREA Call D_FUETYP(zc) From W5CTR4
Return

Subprog D_FUETYP(VALEUR)
Variable Integer VALEUR
If varinit([M]FUETYP,indice)=0
 VALEUR = 1
