$AV_DATAVA
Chgfmt [M]DATAVA(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_DATAVA(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DATAVA" : GZNUM = 1003382 : Endif
If !mkstat
 ## Action STD
 Call C_DATAVA(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "DATAVA" : GZNUM = 1003382 : Endif
Endif
Gosub _AFF
End

