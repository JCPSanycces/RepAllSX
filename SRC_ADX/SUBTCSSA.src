#<AdxTL>@(#)0.0.0.0 $Revision$
#ADNGO - 2017-04-19 - X3-29542 - START
#FRLAA -2015-08-17 - Requirement 110204 - US 3850 - START
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "LIENS"       : Gosub LIENS
 Endcase
Return

$OUVRE
If clalev([F:TCSSA])=0 : Local File TYPCOURSESA  [TCSSA] : Endif
Return

$MODIF
$CREATION
Delete [TCSSA] Where COD=[M:TCS1]COD
If fstat=1
 GOK = -1
 GLOCK = "$TYPCOURSESA"-[F:TCS]COD
 Return
Elsif fstat>5
 GOK = 0
 Call RSTA("TCSSA",[F:TCS]COD) From GLOCK
 Return
Endif
[F:TCSSA]COD = [M:TCS1]COD
[F:TCSSA]    = [M:TCS1]
Write [TCSSA]
If fstat
  GOK=0 : Return
Endif
Return

$ANNULE
Delete [TCSSA] Where COD=[M:TCS1]COD
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("TCSSA",[F:TCS]COD) From GLOCK : Return
Endif
Return


$LIENS
Read [F:TCSSA]TCSSA0=[M:TCS1]COD
If !fstat
  [M:TCS1] = [F:TCSSA]
Endif
Return
#FRLAA -2015-08-17 - Requirement 110204 - US 3850 - END
#ADNGO - 2017-04-19 - X3-29542 - END

