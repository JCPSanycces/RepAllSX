#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_GUAEMPDAT
Onevent BEFORE_AREA Gosub AV_GUAEMPDAT From W3HRMAT2
Return

$AV_GUAEMPDAT
Chgfmt [M]GUAEMPDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_SPOTYPEMP
Onevent CONTROL Call C_SPOTYPEMP(zc) From W3HRMAT2
Onevent INIT_AREA Call D_SPOTYPEMP(zc) From W3HRMAT2
Onevent BEFORE_INPUT Call AS_SPOTYPEMP(zc) From W3HRMAT2
Return

Subprog D_SPOTYPEMP(VALEUR)
Variable Integer VALEUR
If varinit([M]SPOTYPEMP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SPOTYPEMP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_SPOTYPEMP(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SPOTYPEMP" : GZNUM = 680 : Endif
If !mkstat
 ## Action STD
 Call C_SPOTYPEMP(VALEUR) From SUBEML2
 If mkstat : GERR = 1 : GZONE = "SPOTYPEMP" : GZNUM = 680 : Endif
Endif
Gosub _AFF
End

$CHG_STY
Return


