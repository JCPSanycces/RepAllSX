#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
## Pas bouton 'Contexte' si le contexte de la formule n'est pas renseigné
#########################################################################
Subprog CXTDEF(LISTAB)
Value Char LISTAB()
If LISTAB="" : Raz GBOUT5 : Endif
End

#########################################################################
## Affichage du contexte d'utilisation de de la formule
#########################################################################
Subprog CXTDOC(LISTAB)
Value Char LISTAB()

Local Integer I1, I2
Local Char    CLE1(250), CLE2(250)
Local Char    TABLE(GLONATB), ABREV(GLONABR), TEXTE(GLONDES)
Local Integer NBTAB, VALEUR
Local Char    TIT(80)(4), COL(GLONDES) (30,1..3)

If !clalev([ATB]) : Local File ATABLE [ATB] : Endif

CLE1  = LISTAB
While CLE1<>""
 I1 = instr(1,CLE1,",")
 If I1
  CLE2 = vireblc(left$(CLE1,I1-1),4)
  CLE1 = right$(CLE1,I1+1)
 Else
  CLE2 = vireblc(CLE1,4)
  CLE1 = ""
 Endif

 # CLE2 = [ABR] ou TABLE[ABR] ou TABLE
 ABREV=""
 I1 = instr(1,CLE2,"[")
 If I1
  TABLE =left$(CLE2,I1-1)
  I2 = instr(I1,CLE2,"]")
  If I2
     ABREV = seg$(CLE2,I1+1,I2-1)
  Endif
 Else
  TABLE=CLE2
 Endif

 If TABLE="" & ABREV<>""
    Read [ATB]ABRFIC = ABREV
    If !fstat : TABLE = [F:ATB]CODFIC : Endif
 Endif

 If TABLE<>""
    If [F:ATB]CODFIC<>TABLE
       Read [ATB]CODFIC = TABLE
       If fstat
          Read [ATB]ABRFIC = TABLE
          If !fstat : TABLE = [F:ATB]CODFIC : Endif
       Endif
       If fstat : Raz [F:ATB] : Endif
    Endif
    If ABREV="" : ABREV = [F:ATB]ABRFIC : Endif
    Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
    COL(NBTAB,1)=TABLE
    COL(NBTAB,2)=ABREV
    COL(NBTAB,3)=TEXTE
    NBTAB+=1
    If NBTAB>=dim([L]COL,1) : Break : Endif
 Endif
Wend

TIT(0)=mess(302,195,1) : # Tables utilisables dans la formule
TIT(1)=mess(56,123,1)  : # Table"
TIT(2)=mess(119,123,1) : # Abrev
TIT(3)=mess(82,123,1)  : # Intitulé
Call SAITEX_COL(NBTAB,COL,VALEUR,TIT) From GESECRAN
End
