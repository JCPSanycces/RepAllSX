  FLGEXE = 1
  GACTION = "CONSCPJ"
  Call CONSULT_CHAR(VALBOUT,"CPJ",PARBOUT) From GCONSULT
 When "ç"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = [M:PJTA0]KEYCONCAT
  PARBOUT(5) = [M:PJTA0]CREDAT
  FLGEXE = 1
  GACTION = "CONSCPQ"
  Call CONSULT_CHAR(VALBOUT,"CPQ",PARBOUT) From GCONSULT
 When "$"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJTA0A]TASFCY
  PARBOUT(2) = ""
  PARBOUT(3) = [00/00/0000]
  PARBOUT(4) = ""
  PARBOUT(5) = ""
  PARBOUT(6) = ""
  PARBOUT(7) = num$("0")
  PARBOUT(8) = [M:PJTA0]KEYCONCAT
  PARBOUT(9) = ""
  PARBOUT(10) = num$(1)
  FLGEXE = 1
  GACTION = "CONSMKI"
  Call CONSULT_CHAR(VALBOUT,"MKI",PARBOUT) From GCONSULT
 When "~"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJTA0A]TASFCY
  PARBOUT(2) = ""
  PARBOUT(3) = [00/00/0000]
  PARBOUT(4) = ""
  PARBOUT(5) = ""
  PARBOUT(6) = ""
  PARBOUT(7) = ""
