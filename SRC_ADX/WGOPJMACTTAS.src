NBMEN += 1
NMEN(NBMEN) = 30 : Call TEXTE(44372,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 30 : CMEN(NBMEN) = "(" : LMEN(NBMEN) = 2006 : Call TEXTE(11543,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 40 : Call TEXTE(6084,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : Call TEXTE(1886,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : CMEN(NBMEN) = "*" : LMEN(NBMEN) = 2007 : Call TEXTE(48408,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : Call TEXTE(3821,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : CMEN(NBMEN) = "^" : LMEN(NBMEN) = 2008 : Call TEXTE(6346,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : CMEN(NBMEN) = "£" : LMEN(NBMEN) = 2009 : Call TEXTE(3312,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : CMEN(NBMEN) = "à" : LMEN(NBMEN) = 2010 : Call TEXTE(5852,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : CMEN(NBMEN) = "|" : LMEN(NBMEN) = 2011 : Call TEXTE(9784,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : CMEN(NBMEN) = "\" : LMEN(NBMEN) = 2012 : Call TEXTE(36870,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : Call TEXTE(3820,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : CMEN(NBMEN) = "è" : LMEN(NBMEN) = 2013 : Call TEXTE(10409,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : CMEN(NBMEN) = "{" : LMEN(NBMEN) = 2014 : Call TEXTE(3312,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 41 : CMEN(NBMEN) = "}" : LMEN(NBMEN) = 2015 : Call TEXTE(2706,TMEN(NBMEN)) From OBJDIV
