  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = ""
  PARBOUT(5) = [M:PJTA0]KEYCONCAT
  PARBOUT(6) = [M:PJTA0]CREDAT
  FLGEXE = 1
  GACTION = "CONSCPS"
  Call CONSULT_CHAR(VALBOUT,"CPS",PARBOUT) From GCONSULT
 When "_"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = ""
  PARBOUT(5) = [M:PJTA0]KEYCONCAT
