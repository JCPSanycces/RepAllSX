  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = [M:PJTA0]KEYCONCAT
  PARBOUT(5) = [M:PJTA0]CREDAT
  FLGEXE = 1
  GACTION = "CONSCST"
  Call CONSULT_CHAR(VALBOUT,"CST",PARBOUT) From GCONSULT
 When "\"
