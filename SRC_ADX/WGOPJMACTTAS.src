  FLGEXE = 1
  GACTION = "CONSCPD"
  Call CONSULT_CHAR(VALBOUT,"CPD",PARBOUT) From GCONSULT
 When "{"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = ""
  PARBOUT(5) = [M:PJTA0]KEYCONCAT
  PARBOUT(6) = [M:PJTA0]CREDAT
  FLGEXE = 1
  GACTION = "CONSCPP"
