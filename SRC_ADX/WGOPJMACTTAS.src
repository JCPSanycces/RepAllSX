# Superviseur
# Gestion de la fenêtre OPJMACTTAS

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:40"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OPJMACTTAS",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="PJTA0;PJTA0A;PJTA0B;PJTA0C;PJTA2;PJTA1;PJTA3;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
If clalev([M:PJTA0])=0 : Local Mask PJMTAS0 [PJTA0] : Endif
If clalev([M:PJTA0A])=0 : Local Mask PJMTAS0A [PJTA0A] : Endif
If clalev([M:PJTA0B])=0 : Local Mask PJMTAS0B [PJTA0B] : Endif
If clalev([M:PJTA0C])=0 : Local Mask PJMTAS0C [PJTA0C] : Endif
If clalev([M:PJTA2])=0 : Local Mask PJMTAS2 [PJTA2] : Endif
If clalev([M:PJTA1])=0 : Local Mask PJMTAS1 [PJTA1] : Endif
If clalev([M:PJTA3])=0 : Local Mask PJMTAS3 [PJTA3] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGOPJMACTTAS
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPJMACTTAS" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTA0]
&   Folder Mask [PJTA0A]
& , Folder Mask [PJTA0B]
& , Folder Mask [PJTA0C]
& , Folder Mask [PJTA2]
& , Folder Mask [PJTA1]
& , Folder Mask [PJTA3]
& As [PJTA0A]
Titled [PJTA0A] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOPJMACTTAS
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPJMACTTAS" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTA0]
&   Folder Mask [PJTA0A]
& , Folder Mask [PJTA0B]
& , Folder Mask [PJTA0C]
& , Folder Mask [PJTA2]
& , Folder Mask [PJTA1]
& , Folder Mask [PJTA3]
& As [PJTA0A]
Titled [PJTA0A] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [PJTA0A] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [PJTA0A] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [PJTA0A]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TIT(60) , TITTRN(60)
Call TEXTE(54488,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$DEFAUT_BRO
Return

$SETBOX
Return

$SETORDER
Return

$ENDORDER
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "PJMTAS0"      : ABMSK(0)  = "PJTA0"    : AMA(0) = 1
NOMMSK(1) = "PJMTAS0A"     : ABMSK(1)  = "PJTA0A"   : AMA(1) = 1
NOMMSK(2) = "PJMTAS0B"     : ABMSK(2)  = "PJTA0B"   : AMA(2) = 1
NOMMSK(3) = "PJMTAS0C"     : ABMSK(3)  = "PJTA0C"   : AMA(3) = 1
NOMMSK(4) = "PJMTAS2"      : ABMSK(4)  = "PJTA2"    : AMA(4) = 1
NOMMSK(5) = "PJMTAS1"      : ABMSK(5)  = "PJTA1"    : AMA(5) = 1
NOMMSK(6) = "PJMTAS3"      : ABMSK(6)  = "PJTA3"    : AMA(6) = 1
NBMASK = 6
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:PJTA0])>0 : Default Mask [PJTA0] : Endif
 When 1 : If clalev([M:PJTA0A])>0 : Default Mask [PJTA0A] : Endif
 When 2 : If clalev([M:PJTA0B])>0 : Default Mask [PJTA0B] : Endif
 When 3 : If clalev([M:PJTA0C])>0 : Default Mask [PJTA0C] : Endif
 When 4 : If clalev([M:PJTA2])>0 : Default Mask [PJTA2] : Endif
 When 5 : If clalev([M:PJTA1])>0 : Default Mask [PJTA1] : Endif
 When 6 : If clalev([M:PJTA3])>0 : Default Mask [PJTA3] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:PJTA0])>0 : Gosub TITRES From W1PJMTAS0 : Endif
 When 1 : If clalev([M:PJTA0A])>0 : Gosub TITRES From W1PJMTAS0A : Endif
 When 2 : If clalev([M:PJTA0B])>0 : Gosub TITRES From W1PJMTAS0B : Endif
 When 3 : If clalev([M:PJTA0C])>0 : Gosub TITRES From W1PJMTAS0C : Endif
 When 4 : If clalev([M:PJTA2])>0 : Gosub TITRES From W1PJMTAS2 : Endif
 When 5 : If clalev([M:PJTA1])>0 : Gosub TITRES From W1PJMTAS1 : Endif
 When 6 : If clalev([M:PJTA3])>0 : Gosub TITRES From W1PJMTAS3 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:PJTA0])>0 : Close Local Mask [PJTA0] : Endif
If clalev([M:PJTA0A])>0 : Close Local Mask [PJTA0A] : Endif
If clalev([M:PJTA0B])>0 : Close Local Mask [PJTA0B] : Endif
If clalev([M:PJTA0C])>0 : Close Local Mask [PJTA0C] : Endif
If clalev([M:PJTA2])>0 : Close Local Mask [PJTA2] : Endif
If clalev([M:PJTA1])>0 : Close Local Mask [PJTA1] : Endif
If clalev([M:PJTA3])>0 : Close Local Mask [PJTA3] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:PJTA0])>0 : Raz [M:PJTA0] : Endif
 When 1 : If clalev([M:PJTA0A])>0 : Raz [M:PJTA0A] : Endif
 When 2 : If clalev([M:PJTA0B])>0 : Raz [M:PJTA0B] : Endif
 When 3 : If clalev([M:PJTA0C])>0 : Raz [M:PJTA0C] : Endif
 When 4 : If clalev([M:PJTA2])>0 : Raz [M:PJTA2] : Endif
 When 5 : If clalev([M:PJTA1])>0 : Raz [M:PJTA1] : Endif
 When 6 : If clalev([M:PJTA3])>0 : Raz [M:PJTA3] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:PJTA0])>0 : Affzo [M:PJTA0] : Endif
 When 1 : If clalev([M:PJTA0A])>0 : Affzo [M:PJTA0A] : Endif
 When 2 : If clalev([M:PJTA0B])>0 : Affzo [M:PJTA0B] : Endif
 When 3 : If clalev([M:PJTA0C])>0 : Affzo [M:PJTA0C] : Endif
 When 4 : If clalev([M:PJTA2])>0 : Affzo [M:PJTA2] : Endif
 When 5 : If clalev([M:PJTA1])>0 : Affzo [M:PJTA1] : Endif
 When 6 : If clalev([M:PJTA3])>0 : Affzo [M:PJTA3] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
