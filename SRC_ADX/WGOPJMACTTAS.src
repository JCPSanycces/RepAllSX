$BOUTON
STDBOUT = "ESAN"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "3" : LBOUT(NBTEX) = 1101 : Call TEXTE(26974,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1802 : Call TEXTE(16964,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
NBMEN += 1
NMEN(NBMEN) = 10 : Call TEXTE(23819,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "Z" : LMEN(NBMEN) = 2001 : Call TEXTE(1002908,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "U" : LMEN(NBMEN) = 2002 : Call TEXTE(56876,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
