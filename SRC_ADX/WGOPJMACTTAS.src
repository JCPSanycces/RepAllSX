$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "1"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "PJMTAS"
  PARBOUT(2) = [M:PJTA0A]TASCOD
  FLGEXE = 1
  GACTION = "PJMEVET"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OEVENT","SUBPEV","") From GSAISIE
 When "Z"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJTA0]OPPNUM
  FLGEXE = 1
  GACTION = "PJMGANTT"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"FPJMGANTT","PJMGANTT","XWPJMGANTT") From GSAISIE
 When "U"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJTA0]OPPNUM
  PARBOUT(2) = AVOID.ACHAR
  FLGEXE = 1
  GACTION = "PJMOVE"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMOVE","PJMOVE","") From GSAISIE
 When "D"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJTA0]OPPNUM
  PARBOUT(2) = AVOID.ACHAR
  PARBOUT(3) = AVOID.ACHAR
  FLGEXE = 1
  GACTION = "PJMFINOV0"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMFINOV0","PJMFINOV0","") From GSAISIE
 When "2"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = func PJMACTSPLD.CALLER_TASK()
  PARBOUT(2) = [M:PJTA0A]TASCOD
  FLGEXE = 1
  GACTION = "PJMACTSPLD"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMACTSPLD","PJMACTSPLD","") From GSAISIE
 When "-"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = GBIDC3
  PARBOUT(2) = "PSO"
  PARBOUT(3) = ""
  FLGEXE = 1
  GACTION = "GOBJETC1"
  Call OBJET_CHAR(PARBOUT(1),PARBOUT(2),PARBOUT(3)) From GOBJET
  GBIDC3 = PARBOUT(1)
 When "("
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = num$("0")
  PARBOUT(4) = ""
  PARBOUT(5) = [M:PJTA0]KEYCONCAT
  PARBOUT(6) = ""
  PARBOUT(7) = [00/00/0000]
  PARBOUT(8) = ""
  PARBOUT(9) = num$("0")
  FLGEXE = 1
  GACTION = "FMFGB"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"FMFGB","FUNGBENCH","",5,"XYZFUNGBENCH") From GTRAITE
 When "*"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJTA0]KEYCONCAT
  PARBOUT(2) = [M:PJTA0A]TASFCY
  PARBOUT(3) = num$(0)
  PARBOUT(4) = [M:PJTA0]CREDAT
  PARBOUT(5) = ""
  FLGEXE = 1
  GACTION = "CONSPTE"
  Call CONSULT_CHAR(VALBOUT,"PTE",PARBOUT) From GCONSULT
 When "^"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = [M:PJTA0]KEYCONCAT
  PARBOUT(5) = [M:PJTA0]CREDAT
  FLGEXE = 1
  GACTION = "CONSCSL"
  Call CONSULT_CHAR(VALBOUT,"CSL",PARBOUT) From GCONSULT
 When "£"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = [M:PJTA0]KEYCONCAT
  PARBOUT(5) = [M:PJTA0]CREDAT
  FLGEXE = 1
  GACTION = "CONSCSP"
  Call CONSULT_CHAR(VALBOUT,"CSP",PARBOUT) From GCONSULT
 When "à"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = [M:PJTA0]KEYCONCAT
  PARBOUT(5) = [M:PJTA0]CREDAT
  FLGEXE = 1
  GACTION = "CONSCSF"
  Call CONSULT_CHAR(VALBOUT,"CSF",PARBOUT) From GCONSULT
 When "|"
