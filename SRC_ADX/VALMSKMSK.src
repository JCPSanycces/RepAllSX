#<AdxTL>@(#)3.0.0.0 $Revision$
VALMSK

# Revu par Dom pour améliorer les performances...
# Dom pourraient être déclarées en local maintenant ?
# Je ne vois pas de Kill : ceci signifie que ces grosses variables restent en mémoire ad vitam aeternam ?


Local Integer  NDMX, INMX, IDMX, STMX, ACMX
Local Integer  TSYMB1 : TSYMB1=5000  : #  9999 anciennement     JC 15/09/2005 passe de 3000 à 5000
Local Integer  TSYMB2 : TSYMB2=15000 : # 30000 anciennement     JC 15/09/2005 passe de 10000 à 15000
Local Shortint CODE(0..TSYMB1), PTOB(0..TSYMB1), PTHE(0..TSYMB1)
Local Shortint PTTA(0..TSYMB1), PTNX(0..TSYMB1), ETYP(0..TSYMB1)
Local Shortint ICOD(0..TSYMB1), ELT1(0..TSYMB1), ELT2(0..TSYMB1)
Local Shortint INXT(0..TSYMB1)
Local Libelle  IDEN(0..TSYMB2)
Local Shortint STUC(0..TSYMB2)
Local Integer  INTG(0..TSYMB1)

Local Char      FICMSK(250), OLDMSK(250), DIRECR(4), MESTRA(250)
Local Integer   STAT
Local Shortint  NDBK, NDCH, NDCL, NDFD, NDHL, NDZN
Local Shortint  NDT1, NDT2, NDT3, NDT4, NDIN
Local Shortint  JCI2, JCI3
Local Integer   JCI4
Local Libelle   JCI1, DCB(17)

# Déclaration des variables de passage d'argument (Dom)
Local Char STCHP_ARG1(255) : Local Integer STCHP_ARG2,STCHP_ARG3,STCHP_ARG4,STCHP_RET
Local Integer COORD_ARG1,COORD_ARG2,COORD_ARG3,COORD_ARG4,COORD_ARG5,COORD_RET
Local Integer SURFACE_ARG1,SURFACE_ARG2,SURFACE_ARG3,SURFACE_ARG4,SURFACE_RET
Local Integer COUPLE_ARG1,COUPLE_ARG2,COUPLE_RET
Local Char STZON_ARG1(255) : Local Integer STZON_ARG2,STZON_ARG3,STZON_ARG4,STZON_RET
Local Char STIDE_ARG1(255) : Local Integer STIDE_RET, STIDE_I
Local Char STSTU_ARG1(255) : Local Integer STSTU_RET, STSTU_I
Local Integer STINT_ARG1,STINT_RET
Local Char STSEX_ARG1(255) : Local Integer STSEX_RET
Local Integer STIEX_ARG1,STIEX_RET

# Variables pour optimiser certains ST (cf en fin de traitement)
Local Schar STSTU_CHAR(255)(1..800) : # Pas plus de 800 chaines dans un masque ?
Local Schar STIDE_CHAR(255)(1..800) : # Pas plus de 800 identifiants dans un masque ?
Local Integer PT_STSTU(1..800)
Local Integer PT_STIDE(1..800)
Local Integer NB_STSTU
Local Integer NB_STIDE

# On se met sur ECR
DIRECR = adxrob(0)
adxrob(0) = "ECR"

#  Le Repertoire existe ?
FICMSK = filpath("ECR","","",APPLI)
If filinfo(FICMSK,0) < 0
  Call ECR_TRACE("|"+FICMSK-mess(86,133,1),1) From GESECRAN
  Return
Endif

#  Et le Fichier ?
FICMSK = filpath("ECR",ECRAN,"msk",APPLI)
#If filinfo(FICMSK,0)>=0
#  OLDMSK = filpath("ECR",ECRAN,"old",APPLI)
#  Call MOVE(FICMSK,OLDMSK,STAT) From ORDSYS
#  If STAT <> 0
#    MESTRA = mess(6,123,1)-num$(STAT)-"MOVE"+"\"
#    MESTRA += ctrans(FICMSK,"\","/")+"\"+ctrans(OLDMSK,"\","/")
#    Call ECR_TRACE( MESTRA, 1 ) From GESECRAN
#  Endif
#Endif
Openo FICMSK , 0

# On Repasse en Normal
adxrob(0) =DIRECR

Gosub ECRIRE_MASQUE

#If OK
#  Call EFFACE(OLDMSK,STAT) From ORDSYS
#  If STAT
#    MESTRA = mess(6,123,1)-num$(STAT)-"EFFACE"+"\"
#    MESTRA += ctrans(OLDMSK,"\","/")
#    Call ECR_TRACE( MESTRA, 1 ) From GESECRAN
#  Endif
#Endif
Return

$ECRIRE_MASQUE
MAXX = 0
MAXY = 0
MINX = 80
MINY = 21
For B=1 To BLC_NBR
  If BLC_TYP(B)<>5 & BLC_TYP(B)<>10
    MAXX = max(MAXX,BLC_X(B)+BLC_NCO(B))
    MAXY = max(MAXY,BLC_Y(B)+BLC_NLI(B))
    MINX = min(MINX,BLC_X(B))
    MINY = min(MINY,BLC_Y(B))
  Endif
Next B

#  -----------------------  #
#  Construction des Noeuds  #
#  -----------------------  #
NODECONST
NDMX = 3 : # Les 2 Noeuds de Base
PTNX(1) = 2
INMX = 1
IDMX = 1
STMX = 1
ACMX = 1

# Entete d'ecran
NDBK = NDMX : NDMX += 1
CODE(NDBK) = 339
PTOB(NDBK) = 0 : # Va pointer sur les Blocs
COORD_ARG1 = MINY
COORD_ARG2 = 0
COORD_ARG3 = MINX
COORD_ARG4 = 0
COORD_ARG5 = 0
Gosub COORD : # Correspond à Func COORD
PTHE(NDBK) = COORD_RET

If TET_TAI=5 : # C'est un Ecran d'en-tete
  #  Le Folder
  If MINY=1 Then B = 1 Else B = 0 : Endif
  NDFD = NDMX : NDMX += 1
  CODE(NDFD) = 343
  PTOB(NDFD) = 0
  COORD_ARG1 = MAXY+1-MINY+1
  COORD_ARG2 = 0
  COORD_ARG3 = 1
  COORD_ARG4 = 0
  COORD_ARG5 = NDBK
  Gosub COORD : # Correspond à Func COORD
  PTHE(NDFD) = COORD_RET
  SURFACE_ARG1 = 22-B-MAXY
  SURFACE_ARG2 = 6
  SURFACE_ARG3 = MAXX-MINX
  SURFACE_ARG4 = 0
  Gosub SURFACE : # Correspond à Func SURFACE
  PTTA(NDFD) = SURFACE_RET
  ETYP(NDFD) = 0
  PTNX(NDFD) = 0
  ETYP(1) = NDFD
  SURFACE_ARG1 = 23-B-MINY
  SURFACE_ARG2 = 0
  SURFACE_ARG3 = MAXX-MINX
  SURFACE_ARG4 = 0
  Gosub SURFACE : # Correspond à Func SURFACE
  PTTA(NDBK) = SURFACE_RET
Else
  SURFACE_ARG1 = MAXY-MINY+1
  SURFACE_ARG2 = 0
  SURFACE_ARG3 = MAXX-MINX
  SURFACE_ARG4 = 0
  Gosub SURFACE : # Correspond à Func SURFACE
  PTTA(NDBK) = SURFACE_RET
Endif
PTOB(2) = NDBK

# Parcours des blocs
For B=1 To BLC_NBR
  If find(BLC_TYP(B),1,2,4,5,6,7,8,9,10,11)
    PTNX(NDBK) = NDMX : NDBK = NDMX : NDMX += 1
    CODE(NDBK) = 339
    PTOB(NDBK) = 0 : # Va pointer sur les champs
    PTNX(NDBK) = 0
    If BLC_TYP(B)=5 or BLC_TYP(B)=10
      COORD_ARG1 = 1
      COORD_ARG2 = 0
      COORD_ARG3 = 1
      COORD_ARG4 = 0
      COORD_ARG5 = 0
      Gosub COORD : # Correspond à Func COORD
      PTHE(NDBK) = COORD_RET
      SURFACE_ARG1 = 0
      SURFACE_ARG2 = 0
      SURFACE_ARG3 = 0
      SURFACE_ARG4 = 0
      Gosub SURFACE : # Correspond à Func SURFACE
      PTTA(NDBK) = SURFACE_RET
    Else
      COORD_ARG1 = BLC_Y(B)-MINY+1
      COORD_ARG2 = 1
      COORD_ARG3 = BLC_X(B)-MINX+1
      COORD_ARG4 = 1
      COORD_ARG5 = 0
      Gosub COORD : # Correspond à Func COORD
      PTHE(NDBK) = COORD_RET
      SURFACE_ARG1 = BLC_NLI(B)
      SURFACE_ARG2 = 0
      SURFACE_ARG3 = BLC_NCO(B)-1
      SURFACE_ARG4 = 0
      Gosub SURFACE : # Correspond à Func SURFACE
      PTTA(NDBK) = SURFACE_RET
    Endif

    # Intitule
    ETYP(NDBK) = 0

    # Traitement des differents types de blocs
    Case BLC_TYP(B)
      When 1 : # Tableau
        If BLC_LIG(B) = 0
#          Errbox "Tableau Vide :"-BLC_BAS(B)
          Call ECR_TRACE(mess(20,124,1)-BLC_BAS(B),1) From GESECRAN
          Return
        Endif
        If PTHE(2) = 0
          PTHE(2) = NDMX
        Else
          PTNX(NDT1) = NDMX
        Endif
        NDT1 = NDMX
        NDT2 = NDMX+1
        NDT3 = NDMX+2
        NDT4 = NDMX+3
        NDMX += 4
        CODE(NDT1)= 341
        CODE(NDT2) = 328
        CODE(NDT3) = 342
        CODE(NDT4) = 313
        PTOB(NDT1) = NDT4
        PTHE(NDT1) = NDT2
        PTHE(NDT2) = NDT3
        If LIG_NBR(B)<> 0
          If ((BLC_EVL(B) <> "") | (BLC_TXT(B) <> "")) : # S'il y a un intitule, on decale vers le bas
            COORD_ARG1 = 2
            COORD_ARG2 = -2
            COORD_ARG3 = 1
            COORD_ARG4 = 1
            COORD_ARG5 = NDBK
            Gosub COORD : # Correspond à Func COORD
            PTOB(NDT2) = COORD_RET
            SURFACE_ARG1 = BLC_NLI(B)
            SURFACE_ARG2 = -6
            SURFACE_ARG3 = BLC_NCO(B)-1
            SURFACE_ARG4 = -4
            Gosub SURFACE : # Correspond à Func SURFACE
            PTTA(NDT3) = SURFACE_RET
          Else
            COORD_ARG1 = 1
            COORD_ARG2 = +5
            COORD_ARG3 = 1
            COORD_ARG4 = 1
            COORD_ARG5 = NDBK
            Gosub COORD : # Correspond à Func COORD
            PTOB(NDT2) = COORD_RET
            SURFACE_ARG1 = BLC_NLI(B)
            SURFACE_ARG2 = -5
            SURFACE_ARG3 = BLC_NCO(B)-1
            SURFACE_ARG4 = -4
            Gosub SURFACE : # Correspond à Func SURFACE
            PTTA(NDT3) = SURFACE_RET
          Endif
          NBCHAMP = 0
          For I=1 To LIG_NBR(B)
            If LIG_ZON(B,I)=BLC_BAS(B)
              L = I
            Elsif LIG_SAI(B,I)<3 or (LIG_SAI(B,I)=3 and LIG_TRF(B,I)=2) 
              NBCHAMP += 1
            Endif
          Next I
          OPTTAB = BLC_OPT(B)
          K = 0  : # k, nb de colonnes fixes
          For I=1 To 9
            J = instr(1,OPTTAB,num$(I))
            If J
              OPTTAB = left$(OPTTAB,J-1)+right$(OPTTAB,J+1)
              K = I
              Break
            Endif
          Next I
          If instr(1,OPTTAB,"K")  : OPTTAB += "M" : Endif
          If !instr(1,OPTTAB,"G") : OPTTAB += "G" : Endif
          COUPLE_ARG1 = BLC_LIG(B)
          COUPLE_ARG2 = LIG_NBR(B)
          Gosub COUPLE : # Correspond à Func COUPLE
          PTHE(NDT3) = COUPLE_RET
          STSEX_ARG1 =  OPTTAB 
          Gosub STSEX : # Correspond à Func STSEX
          ETYP(NDT3) = STSEX_RET
          STIDE_ARG1 =  BLC_BAS(B) 
          Gosub STIDE : # Correspond à Func STIDE
          PTOB(NDT4) = STIDE_RET
          STINT_ARG1 =  BLC_RNG(B) 
          Gosub STINT : # Correspond à Func STINT
          PTTA(NDT2) = STINT_RET
          STINT_ARG1 =  BLC_IDX(B) 
          Gosub STINT : # Correspond à Func STINT
          ETYP(NDT2) = STINT_RET
          Gosub ACTION : PTTA(NDT1) = NDIN
          PRZON = 1
          For L=1 To LIG_NBR(B)
            If LIG_ZON(B,L)<>BLC_BAS(B)
              If PRZON & LIG_TYP(B,L)=FMTSHO & LIG_SAI(B,L)=2
                # Pour virer le "NUMLIG"
                LIG_FTY(B,L) = "-N"
              Endif
              If PTOB(NDT3) = 0
                PTOB(NDT3) = NDMX
              Else
                PTNX(NDCL) = NDMX
              Endif
              NDCL = NDMX : NDMX += 1
              Gosub ZONE_TABLEAU
              PRZON = 0
            Endif
          Next L
        Endif

    When 2,6,7,8,9,11 : # Liste, Flash Clob, Browser, Bureautique, Editeur
#  Les zones
    For L=1 To LIG_NBR(B)
      If LIG_DUP(B,L) <> 0
        JCI3 = LIG_DUP( B, LIG_ORI(B,L) )
        STIEX_ARG1 =  LIG_IDX(B,L) 
        Gosub STIEX : # Correspond à Func STIEX
        JCI2 = STIEX_RET
        PTNX(JCI3) = JCI2
        LIG_DUP( B, LIG_ORI(B,L) ) = JCI2
      Elsif LIG_TYP(B,L) <> FMTFIL : # Filler
        If PTOB(1) = 0
          PTOB(1) = NDMX
        Else
          PTNX(NDCH) = NDMX
        Endif
        NDCH = NDMX : NDMX += 1
        NDZN = NDMX : NDMX += 1
        NDHL = NDMX : NDMX += 1
        CODE(NDZN) = 345
        CODE(NDCH) = 340
        PTHE(NDCH) = NDZN
        ETYP(NDCH) = NDHL
        Case LIG_GRA(B,L)
          When 3       : Gosub BOUT_VERT_CAD
          When 4       : Gosub BOUT_VERT_SANS
          When 5       : Gosub BOUT_HZ_CAD
          When 6       : Gosub BOUT_HZ_SANS
          When Default : Gosub ZONE
        Endcase
        STINT_ARG1 =  BLC_RNG(B) 
        Gosub STINT : # Correspond à Func STINT
        PTTA(NDZN) = STINT_RET
        STIEX_ARG1 =  LIG_IDX(B,L) 
        Gosub STIEX : # Correspond à Func STIEX
        ETYP(NDZN) = STIEX_RET
        LIG_DUP(B,L) = ETYP(NDZN)
        Gosub FORMA
        Gosub AIDE
        Gosub ACTION : PTTA(NDCH) = NDIN
        If LIG_GRA(B,L)=2
          If LIG_EVL(B,L)<>""
            STSEX_ARG1 =  vireblc(format$("KT:80X",LIG_EVL(B,L)),2) 
            Gosub STSEX : # Correspond à Func STSEX
            PTNX(PTHE(NDZN)) = STSEX_RET
          Else
            STSEX_ARG1 =  LIG_TXT(B,L) 
            Gosub STSEX : # Correspond à Func STSEX
            PTNX(PTHE(NDZN)) = STSEX_RET
          Endif
        Endif
      Endif

    Next L

#   Les fonds
    For L=1 To LIG_NBR(B)
      If LIG_SAI(B,L)<3 & (LIG_EVL(B,L)<>"" or LIG_TXT(B,L)<>"") & LIG_GRA(B,L)<2
        If (PTHE(1) = 0)
          PTHE(1) = NDMX
        Else
          PTNX(NDFD) = NDMX
        Endif
        NDFD = NDMX : NDMX += 1
        LNGFMT = BLC_CAR(B,max(1,LIG_POS(B,L)-1))
        CODE(NDFD)= 337
        COORD_ARG1 = LIG_Y(B,L)
        COORD_ARG2 = -1
        COORD_ARG3 = LIG_X(B,L)-2-LNGFMT
        COORD_ARG4 = 0
        COORD_ARG5 = NDBK
        Gosub COORD : # Correspond à Func COORD
        PTHE(NDFD) = COORD_RET
        STINT_ARG1 =  1 
        Gosub STINT : # Correspond à Func STINT
        PTTA(NDFD) = STINT_RET
        SURFACE_ARG1 =  1
        SURFACE_ARG2 = 0
        SURFACE_ARG3 = LNGFMT
        SURFACE_ARG4 = 0
        Gosub SURFACE : # Correspond à Func SURFACE
        ETYP(NDFD) = SURFACE_RET
        If LIG_EVL(B,L)<>""
          If left$(LIG_EVL(B,L),1)="#"
            For indice=0 To LIG_DIM(B,L)-1
              If indice>0
                NDFD = NDMX : NDMX += 1
                CODE(NDFD)= 337
                COORD_ARG1 = LIG_Y(B,L)+indice
                COORD_ARG2 = -1
                COORD_ARG3 = LIG_X(B,L)-2-LNGFMT
                COORD_ARG4 = 0
                COORD_ARG5 = NDBK
                Gosub COORD : # Correspond à Func COORD
                PTHE(NDFD) = COORD_RET
                STINT_ARG1 =  1 
                Gosub STINT : # Correspond à Func STINT
                PTTA(NDFD) = STINT_RET
                SURFACE_ARG1 =  1
                SURFACE_ARG2 = 0
                SURFACE_ARG3 = LNGFMT
                SURFACE_ARG4 = 0
                Gosub SURFACE : # Correspond à Func SURFACE
                ETYP(NDFD) = SURFACE_RET
              Endif
              STSEX_ARG1 =  evalue(right$(LIG_EVL(B,L),2)) 
              Gosub STSEX : # Correspond à Func STSEX
              PTOB(NDFD) = STSEX_RET
            Next indice
          Else
            STSEX_ARG1 =  LIG_EVL(B,L) 
            Gosub STSEX : # Correspond à Func STSEX
            PTOB(NDFD) = STSEX_RET
          Endif
        Elsif LIG_TXT(B,L)<>""
          If LIG_DIM(B,L)>1 & LIG_GRA(B,L)=1
            LIGNE = LIG_TXT(B,L)
            For J=1 To LIG_DIM(B,L)
              If LIGNE="" : Break : Endif
              If J>1
                NDFD = NDMX : NDMX += 1
                CODE(NDFD)= 337
                COORD_ARG1 = LIG_Y(B,L)+J-1
                COORD_ARG2 = -1
                COORD_ARG3 = LIG_X(B,L)-2-LNGFMT
                COORD_ARG4 = 0
                COORD_ARG5 = NDBK
                Gosub COORD : # Correspond à Func COORD
                PTHE(NDFD) = COORD_RET
                STINT_ARG1 =  1 
                Gosub STINT : # Correspond à Func STINT
                PTTA(NDFD) = STINT_RET
                SURFACE_ARG1 =  1
                SURFACE_ARG2 = 0
                SURFACE_ARG3 = LNGFMT
                SURFACE_ARG4 = 0
                Gosub SURFACE : # Correspond à Func SURFACE
                ETYP(NDFD) = SURFACE_RET
              Endif
              K = instr(1,LIGNE,"\")
              If !K
                STSEX_ARG1 =  LIGNE 
                Gosub STSEX : # Correspond à Func STSEX
                PTOB(NDFD) = STSEX_RET
                LIGNE = ""
              Else
                STSEX_ARG1 =  left$(LIGNE,K-1) 
                Gosub STSEX : # Correspond à Func STSEX
                PTOB(NDFD) = STSEX_RET
                LIGNE = right$(LIGNE,K+1)
              Endif
            Next J
          Else
            STSEX_ARG1 =  LIG_TXT(B,L) 
            Gosub STSEX : # Correspond à Func STSEX
            PTOB(NDFD) = STSEX_RET
          Endif
        Endif
      Endif
    Next L

   When 4 : # Texte

#   Les fonds
      For L=1 To LIG_NBR(B)
        If LIG_EVL(B,L)<>"" or LIG_TXT(B,L)<>""
          NDFD = NDMX : NDMX += 1
          CODE(NDFD)= 337
          COORD_ARG1 = LIG_Y(B,L)
          COORD_ARG2 = -1
          COORD_ARG3 = LIG_X(B,L)
          COORD_ARG4 = -1
          COORD_ARG5 = NDBK
          Gosub COORD : # Correspond à Func COORD
          PTHE(NDFD) = COORD_RET
          STINT_ARG1 =  1 
          Gosub STINT : # Correspond à Func STINT
          PTTA(NDFD) = STINT_RET
          SURFACE_ARG1 =  1
          SURFACE_ARG2 = 0
          SURFACE_ARG3 = BLC_CAR(B,1)-2
          SURFACE_ARG4 = 0
          Gosub SURFACE : # Correspond à Func SURFACE
          ETYP(NDFD) = SURFACE_RET
          If LIG_EVL(B,L)<>""
            STSEX_ARG1 =  LIG_EVL(B,L) 
            Gosub STSEX : # Correspond à Func STSEX
            PTOB(NDFD) = STSEX_RET
          Elsif LIG_TXT(B,L)<>""
            STSEX_ARG1 =  LIG_TXT(B,L) 
            Gosub STSEX : # Correspond à Func STSEX
            PTOB(NDFD) = STSEX_RET
          Endif
        Endif
      Next L

   When 5,10 : # Invisible, Technique

     For L=1 To LIG_NBR(B)
        If PTOB(1) = 0
          PTOB(1) = NDMX
        Else
          PTNX(NDCH) = NDMX
        Endif
        NDCH = NDMX : NDMX += 1
        NDZN = NDMX : NDMX += 1
        NDHL = NDMX : NDMX += 1
        CODE(NDZN) = 345
        CODE(NDCH) = 340
        PTHE(NDCH) = NDZN
        ETYP(NDCH) = NDHL
        Gosub ZONE
        STINT_ARG1 =  BLC_RNG(B) 
        Gosub STINT : # Correspond à Func STINT
        PTTA(NDZN) = STINT_RET
        STIEX_ARG1 =  LIG_IDX(B,L) 
        Gosub STIEX : # Correspond à Func STIEX
        ETYP(NDZN) = STIEX_RET
        LIG_DUP(B,L) = ETYP(NDZN)
        Gosub FORMA
        Gosub AIDE
        Gosub ACTION : PTTA(NDCH) = NDIN
     Next L

   Endcase

# Bloc vide
    If LIG_NBR(B)=0
      NDFD = NDMX : NDMX += 1
      CODE(NDFD)= 337
      COORD_ARG1 =  1
      COORD_ARG2 = 1
      COORD_ARG3 = 1
      COORD_ARG4 = 1
      COORD_ARG5 = NDBK
      Gosub COORD : # Correspond à Func COORD
      PTHE(NDFD) = COORD_RET
      STINT_ARG1 =  1 
      Gosub STINT : # Correspond à Func STINT
      PTTA(NDFD) = STINT_RET
      SURFACE_ARG1 =  0
      SURFACE_ARG2 = 1
      SURFACE_ARG3 = 0
      SURFACE_ARG4 = 1 
      Gosub SURFACE : # Correspond à Func SURFACE
      ETYP(NDFD) = SURFACE_RET
      STSEX_ARG1 =  "" 
      Gosub STSEX : # Correspond à Func STSEX
      PTOB(NDFD) = STSEX_RET
    Endif
  Endif
Next B

#  -------------------------  #
#  Epanchement sur le Disque  #
#  -------------------------  #

# Entete
If len(TET_ABR)<5
 Wrseq "#<Adxv"+GADOVERS+">@(#)%I% "+TET_TXT
Else
 Wrseq "#<AdxvO>@(#)%I% "+TET_TXT
Endif
For B = 1 To len(TET_ABR)
  JCI1 = ascii(right$(TET_ABR,B))
  Putseq 1,JCI1
Next B
JCI1=0
If len(TET_ABR)<5
 While B < 5
  Putseq 1,JCI1
  B += 1
 Wend
Else
 While B < GLONABR+1
  Putseq 1,JCI1
  B += 1
 Wend
Endif

#  Ecriture des Noeuds
JCI2 = 11 : Putseq 1, JCI2 : # 11 Sections
JCI2 = 1 : Putseq 1, JCI2 : # Depart : 1

# Expressions
#JCI2 = 13*NDMX : #Putseq 1, JCI2 : # Taille Expressions
# JC le 13 SEPT
I=13*ndmx

jci1 = i/256 : putseq 1, jci1
jci1 = i - jci1*256 : putseq 1, jci1 

JCI2 = NDMX : Putseq 1, JCI2 : # Nombre d'Expressions
JCI1 = 255
For I = 0 To NDMX-1
  Putseq 7, CODE(I), PTOB(I), JCI1, ETYP(I), PTHE(I), PTTA(I), PTNX(I)
Next I

# Entiers
JCI2 = 4*INMX : Putseq 1, JCI2 : # Taille Entiers
JCI2 = INMX : Putseq 1, JCI2 : # Nombre d'Entiers
Putseq INMX,INTG

# DCB
JCI2 = 17 : Putseq 1, JCI2 : # Taille DCB
JCI2 = 1 : Putseq 1, JCI2 : # Nombre de DCB
Putseq 17,DCB

# Chaines
JCI2 = 2*STMX : Putseq 1, JCI2 : # Taille Chaines
JCI2 = STMX : Putseq 1, JCI2 : # Nombre de Chaines
Putseq STMX,STUC

# Identificateurs
JCI2 = IDMX : Putseq 1, JCI2 : # Taille Identificateurs
JCI2 = IDMX : Putseq 1, JCI2 : # Nombre d'Identificateurs
Putseq IDMX,IDEN

# PTCLA
JCI2 = 4 : Putseq 1, JCI2 : # Taille PTCLA
JCI2 = 1 : Putseq 1, JCI2 : # Nombre de PTCLA
Putseq 4,DCB

# PTCID
JCI2 = 4 : Putseq 1, JCI2 : # Taille PTCID
JCI2 = 1 : Putseq 1, JCI2 : # Nombre de PTCID
Putseq 4,DCB

# Instructions
JCI2 = 9*INMX : Putseq 1, JCI2 : # Taille Instructions
JCI2 = INMX : Putseq 1, JCI2 : # Nombre d'Instructions
JCI1 = 60
For I = 0 To INMX-1
  Putseq 5, ICOD(I), INXT(I), JCI1, ELT1(I), ELT2(I)
Next I

JCI2 = 5 : Putseq 1, JCI2 : # Taille Instructions
JCI2 = 1 : Putseq 1, JCI2 : # Nombre d'Instructions
JCI1 = 0
Putseq 3, CODE(I), PTOB(I), JCI1

# Labels
JCI2 = 4 : Putseq 1, JCI2 : # Taille Labels
JCI2 = 1 : Putseq 1, JCI2 : # Nombre de Labels
Putseq 4,DCB

# EST
JCI2 = 4 : Putseq 1, JCI2 : # Taille Labels
JCI2 = 1 : Putseq 1, JCI2 : # Nombre de Labels
Putseq 4,DCB

# IST
JCI2 = 4 : Putseq 1, JCI2 : # Taille Labels
JCI2 = 1 : Putseq 1, JCI2 : # Nombre de Labels
Putseq 4,DCB

Openo

Return

#################################################################################
## Ecriture d'une zone. Cas tableau
#################################################################################
$ZONE_TABLEAU
NDZN = NDMX : NDMX += 1
NDHL = NDMX : NDMX += 1
CODE(NDCL) = 344 : CODE(NDZN) = 345
PTHE(NDCL) = NDZN
ETYP(NDCL) = NDHL
If left$(LIG_EVL(B,L),1)="#"
  STSEX_ARG1 =  evalue(right$(LIG_EVL(B,L),2)) 
  Gosub STSEX : # Correspond à Func STSEX
  ETYP(NDHL) = STSEX_RET
  LRGENT = len(evalue(right$(LIG_EVL(B,L),2)))
Elsif LIG_EVL(B,L)<>""
  STSEX_ARG1 =  vireblc(format$("KT:80X",LIG_EVL(B,L)),2) 
  Gosub STSEX : # Correspond à Func STSEX
  ETYP(NDHL) = STSEX_RET
  If LIG_LGR(B,L)<>0
    LRGENT = LIG_LGR(B,L)
  Else
    LRGENT = len(vireblc(format$("KT:80X",LIG_EVL(B,L)),2))
  Endif
Elsif LIG_TXT(B,L)<>""
  STSEX_ARG1 =  LIG_TXT(B,L) 
  Gosub STSEX : # Correspond à Func STSEX
  ETYP(NDHL) = STSEX_RET
  LRGENT = len(LIG_TXT(B,L))
Else
  ETYP(NDHL) = 0
  LRGENT = 0
Endif
LRGENT = -int(-COEF2*LRGENT) : # Le titre des colonnes est en minuscule gras
STIEX_ARG1 =  LIG_IDX(B,L) 
Gosub STIEX : # Correspond à Func STIEX
ETYP(NDZN) = STIEX_RET
If find(LIG_TYI(B,L),1,7)
  STZON_ARG1 =  LIG_ZON(B,L)
  STZON_ARG2 =  val(LIG_FNU(B,L))
  STZON_ARG3 =  LIG_LNG(B,L)
  STZON_ARG4 =  0 
  Gosub STZON : # Correspond à Func STZON
  PTOB(NDCL) = STZON_RET
Else
  STZON_ARG1 =  LIG_ZON(B,L)
  STZON_ARG2 =  val(LIG_FNU(B,L))
  STZON_ARG3 =  0
  STZON_ARG4 =  0 
  Gosub STZON : # Correspond à Func STZON
  PTOB(NDCL) = STZON_RET
Endif

Gosub FORMA
Gosub AIDE
Gosub ACTION
PTTA(NDCL) = NDIN

Return

##################################################################
## Ecriture d'une zone. Cas liste##
##################################################################
$ZONE
  If find(LIG_TYI(B,L),1,7,9,10)
    STZON_ARG1 =  LIG_ZON(B,L)
    STZON_ARG2 =  val(LIG_FNU(B,L))
    STZON_ARG3 =  LIG_LNG(B,L)
    STZON_ARG4 =  LIG_DIM(B,L) 
    Gosub STZON : # Correspond à Func STZON
    PTOB(NDCH) = STZON_RET
  Else
    STZON_ARG1 =  LIG_ZON(B,L)
    STZON_ARG2 =  val(LIG_FNU(B,L))
    STZON_ARG3 =  0
    STZON_ARG4 =  LIG_DIM(B,L) 
    Gosub STZON : # Correspond à Func STZON
    PTOB(NDCH) = STZON_RET
  Endif
  If LIG_SAI(B,L)<3
    COORD_ARG1 =  LIG_Y(B,L)
    COORD_ARG2 =  -1
    COORD_ARG3 =  LIG_X(B,L)
    COORD_ARG4 =  -3
    COORD_ARG5 = NDBK 
    Gosub COORD : # Correspond à Func COORD
    PTOB(NDZN) = COORD_RET
  Else
    COORD_ARG1 =  1
    COORD_ARG2 =  0
    COORD_ARG3 =  1
    COORD_ARG4 =  0
    COORD_ARG5 =  NDBK 
    Gosub COORD : # Correspond à Func COORD
    PTOB(NDZN) = COORD_RET
  Endif

Return

#################################################################################
## Ecriture d'une zone. Cas boutons
#################################################################################
$BOUT_VERT_CAD
JCI2 = NDBK : NDBK = NDMX : NDMX += 1
CODE(NDBK) = 339
COORD_ARG1 =  LIG_Y(B,L)
COORD_ARG2 =  0
COORD_ARG3 =  LIG_X(B,L)
COORD_ARG4 =  0
COORD_ARG5 =  JCI2 
Gosub COORD : # Correspond à Func COORD
PTHE(NDBK) = COORD_RET
SURFACE_ARG1 =  func VALMSKSUB.LENMESS(LIG_LIB(B,L))+1 : # len(mess(0,LIG_LIB(B,L),1))+1
SURFACE_ARG2 =  0
SURFACE_ARG3 =  LIG_FLN(B,L)
SURFACE_ARG4 =  -2 
Gosub SURFACE : # Correspond à Func SURFACE
PTTA(NDBK) = SURFACE_RET
STSEX_ARG1 =  LIG_TXT(B,L) 
Gosub STSEX : # Correspond à Func STSEX
ETYP(NDBK) = STSEX_RET
PTOB(NDBK) = NDCH
STZON_ARG1 =  LIG_ZON(B,L)
STZON_ARG2 =  val(LIG_FNU(B,L))
STZON_ARG3 =  LIG_LNG(B,L)
STZON_ARG4 =  LIG_DIM(B,L) 
Gosub STZON : # Correspond à Func STZON
PTOB(NDCH) = STZON_RET
COORD_ARG1 =  2
COORD_ARG2 =  -1
COORD_ARG3 =  2
COORD_ARG4 =  -3
COORD_ARG5 = NDBK 
Gosub COORD : # Correspond à Func COORD
PTOB(NDZN) = COORD_RET
Return

$BOUT_VERT_SANS
STZON_ARG1 =  LIG_ZON(B,L)
STZON_ARG2 =  val(LIG_FNU(B,L))
STZON_ARG3 =  LIG_LNG(B,L)
STZON_ARG4 =  LIG_DIM(B,L) 
Gosub STZON : # Correspond à Func STZON
PTOB(NDCH) = STZON_RET
COORD_ARG1 =  LIG_Y(B,L)
COORD_ARG2 =  -1
COORD_ARG3 =  LIG_X(B,L)
COORD_ARG4 =  -3
COORD_ARG5 = NDBK 
Gosub COORD : # Correspond à Func COORD
PTOB(NDZN) = COORD_RET
Return

$BOUT_HZ_CAD
JCI2 = NDBK : NDBK = NDMX : NDMX += 1
CODE(NDBK) = 339
COORD_ARG1 =  LIG_Y(B,L)
COORD_ARG2 =  0
COORD_ARG3 =  LIG_X(B,L)
COORD_ARG4 =  0
COORD_ARG5 =  JCI2 
Gosub COORD : # Correspond à Func COORD
PTHE(NDBK) = COORD_RET
SURFACE_ARG1 =  2
SURFACE_ARG2 =  0
SURFACE_ARG3 =  LIG_FLN(B,L)
SURFACE_ARG4 =  -2 
Gosub SURFACE : # Correspond à Func SURFACE
PTTA(NDBK) = SURFACE_RET
STSEX_ARG1 =  LIG_TXT(B,L) 
Gosub STSEX : # Correspond à Func STSEX
ETYP(NDBK) = STSEX_RET
PTOB(NDBK) = NDCH
STZON_ARG1 =  LIG_ZON(B,L)
STZON_ARG2 =  val(LIG_FNU(B,L))
STZON_ARG3 =  LIG_LNG(B,L)
STZON_ARG4 =  LIG_DIM(B,L) 
Gosub STZON : # Correspond à Func STZON
PTOB(NDCH) = STZON_RET
COORD_ARG1 =  2
COORD_ARG2 =  -1
COORD_ARG3 =  2
COORD_ARG4 =  -3 
COORD_ARG5 = NDBK
Gosub COORD : # Correspond à Func COORD
PTOB(NDZN) = COORD_RET
Return

$BOUT_HZ_SANS
STZON_ARG1 =  LIG_ZON(B,L)
STZON_ARG2 =  val(LIG_FNU(B,L))
STZON_ARG3 =  LIG_LNG(B,L)
STZON_ARG4 =  LIG_DIM(B,L) 
Gosub STZON : # Correspond à Func STZON
PTOB(NDCH) = STZON_RET
COORD_ARG1 =  LIG_Y(B,L)
COORD_ARG2 =  -1
COORD_ARG3 =  LIG_X(B,L)
COORD_ARG4 =  -3
COORD_ARG5 = NDBK 
Gosub COORD : # Correspond à Func COORD
PTOB(NDZN) = COORD_RET
Return

$FORMA
If LIG_FMT(B,L) <> ""
  STSEX_ARG1 =  LIG_FMT(B,L) 
  Gosub STSEX : # Correspond à Func STSEX
  PTHE(NDZN) = STSEX_RET
Elsif LIG_FTY(B,L) <> ""
  STSEX_ARG1 =  LIG_FTY(B,L)+LIG_FOP(B,L)+":"+LIG_FCH(B,L) 
  Gosub STSEX : # Correspond à Func STSEX
  PTHE(NDZN) = STSEX_RET
Else
  PTHE(NDZN) = 0
Endif
Return

$AIDE
CODE(NDHL) = 333
STSEX_ARG1 =  '|'+ECRAN+'|"+GFONCTION+"|'+LIG_AID(B,L)  : # AIDE SUR F1
Gosub STSEX : # Correspond à Func STSEX
PTHE(NDHL) = STSEX_RET
STSEX_ARG1 =  LIG_TXT(B,L)  : # AIDE OBLIGATOIRE
Gosub STSEX : # Correspond à Func STSEX
PTTA(NDHL) = STSEX_RET
Return

#################################################################################
## Generation des Evenements
#################################################################################
$ACTION
#  Actions
Gosub SETPROG
NBETQ = 0
For A=LIG_PTA(B,L) To LIG_PTA(B,L)+LIG_ACT(B,L)-1
  If find(ACT_ETQ(A),"IB_","AV_","D_","AS_","C_","AP_","AM_","AVANT_","APRES_","S_","SA_","P_","CL_")
    NBETQ = 1 : Break
  Endif
Next A
If NBETQ
  NDIN = ACMX : ACMX += 2
  A = NDMX : NDMX += 1
  ICOD(NDIN) = 12
  STIDE_ARG1 =  "ON_"+LIG_ZON(B,L) 
  Gosub STIDE : # Correspond à Func STIDE
  ELT1(NDIN) = STIDE_RET
  CODE(A) = 313
  STIDE_ARG1 =  NOMPROG 
  Gosub STIDE : # Correspond à Func STIDE
  PTOB(A) = STIDE_RET
  ELT2(NDIN) = A
  INXT(NDIN) = NDIN+1
Else
  NDIN = 0
Endif
Return

$SETPROG
NOMPROG = "W"+num$(LIG_PRO(B,L))+TET_AUT
Return

####################################
##  Sous-programmes divers du JC  ##
####################################

#  Nouveau Champs
$STCHP : # En remplacement de la fonction STCHP

STCHP_RET = NDMX : NDMX += 1
CODE(STCHP_RET) = 340
STZON_ARG1 = STCHP_ARG1
STZON_ARG2 = STCHP_ARG2
STZON_ARG3 = STCHP_ARG3
STZON_ARG4 = STCHP_ARG4
Gosub STZON : # Correspond à Func STZON
PTOB(STCHP_RET) = STZON_RET

Return


# Nouvelle COORDONNEES
$COORD : # En remplacement de la fonction COORD

COUPLE_ARG1 =  8*(COORD_ARG1-1)+COORD_ARG2
COUPLE_ARG2 =  4*(COORD_ARG3-1)+COORD_ARG4 
Gosub COUPLE : # Correspond à Func COUPLE

PTNX(PTNX(COUPLE_RET)) = COORD_ARG5

COORD_RET = COUPLE_RET
Return

# Nouvelle Surface
$SURFACE : # En remplacement de la fonction SURFACE

COUPLE_ARG1 =  8*SURFACE_ARG1+SURFACE_ARG2
COUPLE_ARG2 =  4*SURFACE_ARG3+SURFACE_ARG4 
Gosub COUPLE : # Correspond à Func COUPLE
SURFACE_RET = COUPLE_RET
Return


# Nouveau duplet
$COUPLE : # En remplacement de la fonction COUPLE

COUPLE_RET = NDMX
NDMX += 1
CODE(COUPLE_RET) = 302
STINT_ARG1 = COUPLE_ARG1
Gosub STINT : # Correspond à Func STINT
PTOB(COUPLE_RET) = STINT_RET
PTHE(COUPLE_RET) = 0
PTTA(COUPLE_RET) = 0
PTNX(COUPLE_RET) = NDMX
ETYP(COUPLE_RET) = 0
CODE(NDMX) = 302
STINT_ARG1 = COUPLE_ARG2
Gosub STINT : # Correspond à Func STINT
PTOB(NDMX) = STINT_RET
PTHE(NDMX) = 0
PTTA(NDMX) = 0
PTNX(NDMX) = 0
ETYP(NDMX) = 0
NDMX += 1

Return


#  Nouvelle Zone
$STZON : # En remplacement de la fonction STZON

STZON_RET = NDMX : NDMX += 1
CODE(STZON_RET) = 313
STIDE_ARG1 = STZON_ARG1 
Gosub STIDE : # Correspond à Func STIDE
PTOB(STZON_RET)= STIDE_RET
STINT_ARG1 = STZON_ARG4
Gosub STINT : # Correspond à Func STINT
ETYP(STZON_RET)= STINT_RET
STINT_ARG1 = STZON_ARG2 
Gosub STINT : # Correspond à Func STINT
PTHE(STZON_RET)= STINT_RET
STINT_ARG1 = STZON_ARG3 
Gosub STINT : # Correspond à Func STINT
PTTA(STZON_RET) = STINT_RET

Return

#  Nouvel Identificateur
$STIDE : # En remplacement de la fonction STIDE

STIDE_I = 1
STIDE_RET = IDMX
Repeat
IDEN(IDMX)=ascii(right$(STIDE_ARG1,STIDE_I))
STIDE_I += 1
IDMX += 1
Until IDEN(IDMX-1)=0

Return

#  Nouvel Identificateur
$STIDE_NEW : # En remplacement de la fonction STIDE, revue par Dom (optimisation de la taille du compilé)

STIDE_I=find(STIDE_ARG1,STIDE_CHAR(1..NB_STIDE))

If STIDE_I
  STIDE_RET=PT_STIDE(STIDE_I)
  Return
Endif

STIDE_I = 1
STIDE_RET = IDMX
Repeat
IDEN(IDMX)=ascii(right$(STIDE_ARG1,STIDE_I))
STIDE_I += 1
IDMX += 1
Until IDEN(IDMX-1)=0

NB_STIDE+=1
PT_STIDE(NB_STIDE)=STIDE_RET
STIDE_CHAR(NB_STIDE)=STIDE_ARG1
Return

#  Nouvelle Chaine
$STSTU_NONOP : # En remplacement de la fonction STSTU

STSTU_I = 1
STSTU_RET = STMX
Repeat
JCI4 = ascii(right$(STSTU_ARG1,STSTU_I))
If JCI4>32767 : JCI4 = JCI4-65536 : Endif
STUC(STMX)=JCI4
STSTU_I += 1
STMX += 1
Until STUC(STMX-1)=0

Return

#  Nouvelle Chaine
$STSTU : # En remplacement de la fonction STSTU, 2ème optimisation

STSTU_RET = STMX
Repeat
JCI4 = ascii(STSTU_ARG1)
If JCI4>32767 : JCI4 = JCI4-65536 : Endif
STUC(STMX)=JCI4
STSTU_ARG1=right$(STSTU_ARG1,2)
STMX += 1
Until STUC(STMX-1)=0

Return


#  Nouvelle Chaine
$STSTU_NEW : # En remplacement de la fonction STSTU , revue par Dom (optimisation de la taille du compilé)

STSTU_I=find(STSTU_ARG1,STSTU_CHAR(1..NB_STSTU))
If STSTU_I
  STSTU_RET=PT_STSTU(STSTU_I)
  Return
Endif


STSTU_I = 1
STSTU_RET = STMX
Repeat
JCI4 = ascii(right$(STSTU_ARG1,STSTU_I))
If JCI4>32767 : JCI4 = JCI4-65536 : Endif
STUC(STMX)=JCI4
STSTU_I += 1
STMX += 1
Until STUC(STMX-1)=0

NB_STSTU+=1
PT_STSTU(NB_STSTU)=STSTU_RET

Return

# Nouvel Entier
$STINT_NEW : # En remplacement de la fonction STINT, revue par Dom (optimisation de la taille du compilé)

STINT_RET=find(STINT_ARG1,INTG(0..INMX-1))-1
If STINT_RET>0 : Return : Endif

INTG(INMX)=STINT_ARG1
INMX += 1

STINT_RET = INMX-1
Return

# Nouvel Entier
$STINT : # En remplacement de la fonction STINT

INTG(INMX)=STINT_ARG1
INMX += 1

STINT_RET = INMX-1
Return

# Nouvelle Chaine Expression
$STSEX : # En remplacement de la fonction STSEX

STSEX_RET = NDMX : NDMX += 1
CODE(STSEX_RET) = 378
STSTU_ARG1 = STSEX_ARG1
Gosub STSTU : # Correspond à Func STSTU
PTOB(STSEX_RET) = STSTU_RET

Return

# Nouvel Entier Expression
$STIEX : # En remplacement de la fonction STIEX

STIEX_RET = NDMX : NDMX += 1
CODE(STIEX_RET) = 302
STINT_ARG1 = STIEX_ARG1
Gosub STINT : # Correspond à Func STINT
PTOB(STIEX_RET) = STINT_RET

Return





