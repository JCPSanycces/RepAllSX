#<AdxTL>@(#)7.0.0.0 $Revision$
Call OBJET("BCG", GBIDC1, GBIDC2) From GOBJET
End
########################################################################
#    GESTION DES CATEGORIES CLIENTS                                    #
#----------------------------------------------------------------------#
#                                                         DL Aout 2007 #
#                                                                      #
########################################################################
# Gestion du masque BCG0
$ACTION
  Case ACTION
    When "AFFMASK"       : Gosub AFFMASK
    When "OUVRE"         : Gosub OUVRE
    When "LIENS"         : Gosub LIENS
    When "RAZCRE"        : Gosub RAZCRE
    When "RAZDUP"        : Gosub RAZDUP
    When "INIMOD"        : Gosub INIMOD
    When "INICRE"        : Gosub INICRE
    When "FERME"         : Gosub FERME
    When "CHANGE"        : Gosub CHANGE
    When "SEL_TABLE"
      Case COUZON
        When "GRP"       : Gosub S_GRP
      Endcase
    When Default
  Endcase
Return

###################################################################
$CHANGE
  Call CHANGE_AXX("BPCCATEG", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
Return

###################################################################
$S_GRP
  OBJET="FGP"
  # si besoin, renseigner la variable CRITERE pour restreindre la sélection
Return

###################################################################
$OUVRE
Local Integer SPSTAT
Local Char WLEGCPY(GLONCPY)
Local Char WFINRSPFCY(GLONFCY)
Local Decimal WDECIMAL

  #----- Sauvegarde variables globales -----#
  Gosub SAUV_GLOB From TRTX3GLOB
  #---- devise site alimentée par devise dossier ----#
  GCUR = GSYSCUR
  #---- lecture du site par défaut ----#
  If GFCYDEF(9) <> ""
    If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
    Read [F:FCY]FCY0=GFCYDEF(9)
    If fstat = 0
      WLEGCPY    = [F:FCY]LEGCPY
      WFINRSPFCY = [F:FCY]FINRSPFCY
    Endif
  Endif
  #---- lecture société correspondant au site ----#
  If clalev([F:CPY]) = 0 : Local File COMPANY [CPY] : Endif
  If WLEGCPY <> ""
    Read [F:CPY]CPY0=WLEGCPY
    If fstat = 0
      GCUR = [F:CPY]ACCCUR
    Endif
  Endif
  #-- si pas de cours entre devise dossier et devise affichage
  #-- la devise affichage devient la devise de reporting
  #-- cg le 14 septembre 99 demande numéro ????
  GBIDD1 = 0
  GBIDD2 = 0
  Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,GBIDD1,GBIDD2,SPSTAT) From TRTDEV
  If SPSTAT <> 0
    GCUR = GSYSCUR
  Endif
  #-----------------------#
  # decimal de la devise  #
  #-----------------------#
  WDECIMAL = 0
  Read [F:TCU]TCU0=GCUR
  If fstat = 0
    WDECIMAL = [F:TCU]CURRND
  Endif
Return

###################################################################
$FERME
  #----- Restitution variables globales -----#
  Gosub REST_GLOB From TRTX3GLOB
Return

###################################################################
$RAZCRE
  # Ne pas écraser les zones qui ont pu venir du tiers
  If [M:BCGI]CRY = ""
    [M:BCGI]CRY = GPAYS
    If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
    If [F:TCY]CRY <> GPAYS
      Read [F:TCY]TCY0=GPAYS
      If fstat Raz [F:TCY] Endif
    Endif
    [M:BCGI]LAN = [F:TCY]LAN
    [M:BCGI]CUR = [F:TCY]CUR
  Endif
  # Raz des zones mémoire de stockage des textes
  Call RAZ_CLOB From ACLOB
  #---------------------------------------------------------------------------
  #IRMUE 17.05.12 81574:AP/AR management: GMODU(3) added
  #The Price/Amount type ([M:BCG1]PRITYP) is initialized  by GPRITYP/SALPRITYP.
  If (GMODU(5)=2 or GMODU(3)=2) & dim(GPRITYP)>0
    [M:BCG1]PRITYP = GPRITYP
  Endif
  If [M:BCG1]PRITYP=0
    [M:BCG1]PRITYP=1
  Endif
  #IRMUE 17.05.12 81574:AP/AR management
  #bug 82493 IRMUE (field PRITYP on customer categories (GESBCG).If Parameter NOTATI='No' the radio buttons are disabled. The default value is determined by SALPRITYP.
  If dim(GNOTATI)>0 & GNOTATI=2
    Actzo [M:BCG1]PRITYP
  Else
    Grizo [M:BCG1]PRITYP
  Endif
  #---------------------------------#
  # Initialisation tableau des axes #
  #---------------------------------#
  If dim([M:BCG3]NBAXE)>0
    If dim([M:BCG0]SOC)>0 & [M:BCG0]SOC<>""
      Call INIT_DIE(2,[M:BCG0]SOC,"BCG3","NBAXE") From TRTX3CPT
    Else
      Call INIT_DIE(2,"","BCG3","NBAXE") From TRTX3CPT
    Endif
  Endif
  Gosub AFFICHE_TOUT
  Gosub GRIZE_BCG1   # FGR 17/02/2015 : X3SUIVI82493
Return

###################################################################
$RAZDUP
  If GACTFTC=2
    If [M:BCG1]PRITYP=0
      [M:BCG1]PRITYP=1
    Endif
  Endif
  Gosub AFFICHE_TOUT
  Gosub GRIZE_BCG1   # FGR 17/02/2015 : X3SUIVI82493
Return

###################################################################
$AFFICHE_TOUT
  Affzo [M:BCG0]1-99
  Affzo [M:BCGI]1-99
  Affzo [M:BCG1]1-99
  Affzo [M:BCG3]1-99
  Affzo [M:BCG4]1-99
Return

###################################################################
$LIENS
Local Char WCUR(GLONCUR)
Local Decimal WMONTORG(0..10)
Local Decimal WMONTDES(0..10)
Local Char SCUR(GLONCUR)

  GIBPCEXIST = 0
  If dim([M:BCG3]FUPTYP)>0        #MAE, bg 74979
    Actzo [M:BCG3]FUPTYP, FUPMINAMT
    [M:BCG3]FUPCUR = GCURSHR
  Endif
  [M:BCGI]XCUR = GCUR
  If GACTFTC=2
    [M:BCG1]XCUR = GCUR
  Endif
  #---- conversion montants devise dossier en devise société
  If GACTFTC=2
    WMONTORG(0) = [F:BCG]ORDMINAMT
    Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG(0),WMONTDES(0),SPSTAT) From TRTDEV
    If SPSTAT = 0
      [M:BCG1]WORDMINAMT = arr(WMONTDES(0),WDECIMAL)
    Else
      [M:BCG1]WORDMINAMT = [F:BCG]ORDMINAMT
    Endif
  Endif
  WMONTORG(2) = [F:BCG]OSTAUZ
  Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG(2),WMONTDES(2),SPSTAT) From TRTDEV
  If SPSTAT = 0
    [M:BCGI]WOSTAUZ = arr(WMONTDES(2),WDECIMAL)
  Else
    [M:BCGI]WOSTAUZ = [F:BCG]OSTAUZ
  Endif
  ## Champs relances
  If dim([M:BCG3]FUPTYP)>0        #MAE, bg 74979
    [M:BCG3]FUPCUR = GCURSHR
    If [M:BCG3]GRP=""
      Raz [M:BCG3]FUPMINAMT
      Raz [M:BCG3]FUPCUR
      [M:BCG3]FUPTYP=1
      Grizo [M:BCG3]FUPTYP, FUPMINAMT
      Affzo [M:BCG3]FUPTYP, FUPMINAMT
    Endif
  Endif
  #---- chargt tableau des elements de facturation
  Gosub TRT_FOOT
  #-----------------------------#
  # Chargement tableau des axes #
  #-----------------------------#
  If dim([M:BCG3]NBAXE)>0
    If dim([M:BCG0]SOC)>0 & [M:BCG0]SOC<>""
      Call CHARG_DIE(102,[M:BCG0]SOC,"BCG3","NBAXE") From TRTX3CPT
    Else
      Call CHARG_DIE(102,"","BCG3","NBAXE") From TRTX3CPT
    Endif
  Endif
  Gosub DEFAUT
  Gosub GRIZE_BCG1   # FGR 17/02/2015 : X3SUIVI82493
Return

###################################################################
$TRT_FOOT
Local Integer NBPOSTE

  If GACTFTC=2
    If [M:BCG1]NBFAC = 0
      NBPOSTE = dim([M:BCG1]NOLIG)
      Call SAISFOOT(1,"BCG1",NBPOSTE,[M:BCGI]CHGTYP,GSYSCUR,[M:BCGI]CUR,"NON") From SUBSFIT
      [M:BCG1]NBFAC = NBPOSTE
    Endif
    # chargement devise client sur ligne montant
    For nolign = 0 To [M:BCG1]NBFAC-1
      If [M:BCG1]AMTCOD(nolign) = 2
        [M:BCG1]WWCUR(nolign)  = [M:BCGI]CUR
      Endif
    Next
  Endif
Return

###################################################################
$DEFAUT
  For MA=0 To NBMASK
    If AMA(MA)
      Gosub SETMASK From ="WGO"+GABREV
    Endif
  Next MA
Return

###################################################################
$INICRE
  Gosub INIBCG
Return

###################################################################
$INIMOD
  Gosub INIBCG
Return

###################################################################
$INIBCG
#---- conversion montants devise société en devise dossier
Local Decimal WMONTORG(0..2)
Local Decimal WMONTDES(0..2)

  If GACTFTC=2
    WMONTORG(0)=[M:BCG1]WORDMINAMT
    Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG(0),WMONTDES(0),SPSTAT) From TRTDEV
    If SPSTAT = 0
      [F:BCG]ORDMINAMT = WMONTDES(0)
    Else
      [F:BCG]ORDMINAMT = [M:BCG1]WORDMINAMT
    Endif
  Endif
  WMONTORG(2) = [M:BCGI]WOSTAUZ
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG(2),WMONTDES(2),SPSTAT) From TRTDEV
  If SPSTAT = 0
    [F:BCG]OSTAUZ = WMONTDES(2)
  Else
    [F:BCG]OSTAUZ = [M:BCGI]WOSTAUZ
  Endif
  Call MAJTEXTRA([M:BCG0]DESAXX,"BPCCATEG","DESAXX",[M:BCG0]BCGCOD,"") From ATEXTRA
  Call MAJTEXTRA([M:BCGI]SHOAXX,"BPCCATEG","SHOAXX",[M:BCG0]BCGCOD,"") From ATEXTRA
Return

#########################################################################
$AFFMASK
  # FGR 17/022/2015 : X3SUIVI82493 (début)
  #If GACTFTC=2
  #  If dim(GNOTATI)>0 & GNOTATI=2
  #    Actzo [M:BCG1]PRITYP
  #  Else
  #    Diszo [M:BCG1]PRITYP
  #  Endif
  #  If dim([M:BCG1]COMCAT)>0
  #    If GCOMCAT=0
  #      Grizo [M:BCG1]COMCAT
  #    Else
  #      Actzo [M:BCG1]COMCAT
  #    Endif
  #  Endif
  #Endif
  Gosub GRIZE_BCG1
  # FGR 17/022/2015 : X3SUIVI82493 (fin)
  If func AFNC.ACTIV("RED")<1
    Chgfmt [M:BCG4]REPDLV With "-K:15x"
  Endif
Return

#########################################################################
$GRIZE_BCG1
  # FGR 17/022/2015 : X3SUIVI82493
  If GACTFTC=2
    If dim(GNOTATI)>0 & GNOTATI=2
      Actzo [M:BCG1]PRITYP
    Else
      Diszo [M:BCG1]PRITYP
    Endif
    If dim([M:BCG1]COMCAT)>0
      If GCOMCAT=0
        Grizo [M:BCG1]COMCAT
      Else
        Actzo [M:BCG1]COMCAT
      Endif
    Endif
  Endif
Return

######################################################################################
######################################################################################
######################################################################################
Subprog C_BCGCOD(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
Subprog AM_BCGCOD(VALEUR)
Variable Char    VALEUR()

Local Integer NBPOSTE

  GIBPCEXIST = 0
  Look [F:BCG]BCG0=VALEUR
  If !fstat
    # Si la fiche existe, vérification qu'elle est bien autorisée par la gestion des rôles -----#
    # (Si elle n'existe pas, il faut autoriser sa création)
    GBIDC2=""
    Call FILROLE("BCG",GBIDC2) From SUBARL
    If GBIDC2<>""
      Filter [F:BCG] Where evalue(GBIDC2)
      Look [F:BCG]BCG0=VALEUR
      Filter [F:BCG]
      If fstat
        End
      Endif
    Endif
  Endif
  # On a besoin de connaitre la devise pour charger les elements de facturation
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If [F:TCY]CRY <> GPAYS
    Read [TCY]TCY0 = GPAYS
    If fstat Raz [F:TCY] Endif
    [M:BCGI]CUR = [F:TCY]CUR
  Endif
  # Création d'un client : alimentation des zones
  If GREP = "C"
    If GACTFTC=2
      #---- chargt tableau des elements de facturation pour CLIENT seulement #
      If [M:BCG1]NBFAC = 0
        NBPOSTE = dim([M:BCG1]NOLIG)
        Call SAISFOOT(1,"BCG1",NBPOSTE,[M:BCGI]CHGTYP,GSYSCUR,[M:BCGI]CUR,"OUI") From SUBSFIT
        [M:BCG1]NBFAC = NBPOSTE
      Endif
      #---- chargement devise client sur ligne montant
      For nolign = 0 To [M:BCG1]NBFAC-1
        If [M:BCG1]AMTCOD(nolign) = 2
          [M:BCG1]WWCUR(nolign) = [M:BCGI]CUR
        Endif
      Next
      Gosub AFFICHE_TOUT
    Endif
  Endif
End

######################################################################################
Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Integer I

  IBRETOUR=1
  If VALEUR<>""
    Call GETCRYDATA(VALEUR, [M:BCGI]LAN, [M:BCGI]CUR, SZMESSAGE, IBRETOUR) From TRTX3FNC
    If IBRETOUR= 1
      Affzo [M:BCGI]1-99
      If [M:BCG1]NBFAC<>0
        For I=0 To [M:BCG1]NBFAC-1
          If [M:BCG1]AMTCOD(I)=2
            [M:BCG1]WWCUR(I)=[M:BCGI]CUR
          Endif
        Next I
        Affzo [M:BCG1]30
      Endif
    Endif
  Endif
End

######################################################################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()

  #---------------------------------------------------------------#
  # Convertion des montants si changement de devise               #
  #---------------------------------------------------------------#
  If GACTFTC=2
    Call INVDTAAMT(VALEUR,[M:BCGI]CHGTYP,"BCG") From SUBBPR
    #-- particularite client car valeur defaut dans ecran la classe M
    [M:BCGI]CUR = VALEUR
    Gosub AFFICHE_TOUT
  Endif
End

######################################################################################
Subprog C_REFCOU(VALEUR)
Variable Char    VALEUR()

Local Char FORMU(GLONVCR)

  If !clalev([F:ANM]) Local File ACODNUM [ANM] Endif  # avant modif du dico Objet
  If VALEUR <> ""
    For I = 0 To dim([F:ANM]POSTYP)-1
      # FQ 58536 Controler que la formule puisse être évaluée
      If instr(1,[F:ANM]POSCTE(I),"[")
        Onerrgo ERR_FORMU
        FORMU = evalue([F:ANM]POSCTE(I))
        Onerrgo
        If mkstat = 2
          Break
        Endif
      Elsif [F:ANM]POSCTE(I) <> "" & format$("K:"+num$([F:ANM]POSLNG(I))+"c",[F:ANM]POSCTE(I)) = string$([F:ANM]POSLNG(I)," ")
        # Controler que la constante est de type format "c"
        mkstat = 2
        Break
      Endif
    Next I
    If mkstat = 2
      GERR=1
      GMESSAGE = mess(6,196,1)-"("-[F:ANM]POSCTE(I)-")"
      End                          # hcb 58728
    Endif
    # Controle que le compteur n'est pas déjà utilisé dans une catégorie
    Local File BPCCATEG [BCG2] # pour ne pas écraser le buffer
    For [F:BCG2] Where BCGCOD <> [M:BCG0]BCGCOD & REFCOU = VALEUR
      GMESSAGE = mess(7,196,1)-[F:BCG2]BCGCOD
      GERR = 2 # avertissement seulement
      Break
    Next
  Endif
End

$ERR_FORMU
  mkstat = 2
Resume

######################################################################################
Subprog C_COMCAT(VALEUR)
Variable Integer VALEUR
End

######################################################################################
Subprog IB_REP

  Raz GBOUT2
End

######################################################################################
Subprog C_REP(VALEUR)
Variable Char    VALEUR()

  #---- erreur si rep1 saisi et rep0 non saisi
  If indice = 1 & [M:BCG1]REP(0) = "" & VALEUR <> ""
    GMESSAGE = mess(6,199,1)
    mkstat = 2
    End
  Endif
End

######################################################################################
Subprog AS_BPCTYP(VALEUR)
Variable Integer VALEUR

  GMENLOC(3)=1
  GMENLOC(4)=1
End

######################################################################################
Subprog AM_MDL(VALEUR)
Variable Char    VALEUR()

  [M:BCG4]EECICT = [F:TMD]EECICT
  If dim([M:BCG4]EECLOC)>0
    [M:BCG4]EECLOC = [F:TMD]EECLOC
    Affzo [M:BCG4]EECLOC
  Endif
  Affzo [M:BCG4]EECICT
End

######################################################################################
Subprog C_GRP(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>""
    # on autorise les clients sans groupe
    If !clalev([F:FGP]) : Local File FUPGRP [FGP] : Endif
    Call CONTROLE("FGP","",VALEUR,"",mkstat) From CONTOBJ
  Endif
End

######################################################################################
Subprog AM_GRP(VALEUR)
Variable Char    VALEUR()

  If VALEUR=""
    # on autorise les clients sans groupe effacer et griser les champs
    Raz [M:BCG3]FUPTYP, FUPMINAMT
    [M:BCG3]FUPTYP=1
    Grizo [M:BCG3]FUPTYP, FUPMINAMT
    Affzo [M:BCG3]FUPTYP, FUPMINAMT
  Else
    If !clalev([F:FGP]) : Local File FUPGRP [FGP] : Endif
    Call CONTROLE("FGP","",VALEUR,"",mkstat) From CONTOBJ
    # initialisation des champs du client avec les valeurs du groupe auquel il appartient
    Read [F:FGP]FGP0=VALEUR
    [M:BCG3]FUPTYP = [F:FGP]FUPTYP
    [M:BCG3]FUPMINAMT = [F:FGP]FUPMINAMT
    # activer les champs
    Actzo [M:BCG3]FUPTYP, FUPMINAMT
    Affzo [M:BCG3]FUPTYP, FUPMINAMT
  Endif
End
