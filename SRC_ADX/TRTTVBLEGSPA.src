#<AdxTL>@(#)2.0.0.0 $Revision$
#**###########################################################
#
#  Legal datas for legislation SPA for table TABVACBPR
#
# Window AWI=>TVBLEGSPA
# Mask/Screen AMK=>TVBLEGSPA [TVBSPA]
#
############################################################**!


$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FIN"           : Gosub FIN
Endcase
Return


$OUVRE
#----- Paramètres de l'action DATALEG -----#
Local Char LEG(GLONADI)
Local Char COD(max(GLONTVB,GLONVAT,5))
[L]LEG = PARAM(1)
[L]COD = PARAM(2)

#----- Tables utilisée -----#
If !clalev([F:TVB]) : Local File TABVACBPR [TVB] : Endif
If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif

#----- Masque local -----#
Local Mask TVBLEGSPA [TVBSPA]

#----- Variables locales pour sauvegarde du masque -----#
Local Char SPAOPE340(GLONADI)
Local Integer SPAISP
Local Integer SPAIGIC
Local Integer SPADCL347
Local Integer SPADCL349
Local Integer SPAEXEOPE
Local Integer SPAJOUDCL
Local Integer SPAEURSRV
Return

$DEBUT
#--- Alimentation des champs de l'écran ---#
Read [TVB]TVB0 = [L]COD;[L]LEG
If !fstat
 [M:TVBSPA] = [F:TVB]
Endif
#--- Sauvegarde des valeurs initiales du masque ---#
[L]=[M:TVBSPA]

Affzo [M:TVBSPA]
Return

$ENR
Trbegin [TVB]
Readlock [TVB]TVB0 = [L]COD;[L]LEG
If !fstat
 [F:TVB]SPAOPE340 = [M:TVBSPA]SPAOPE340
 [F:TVB]SPAISP    = [M:TVBSPA]SPAISP
 [F:TVB]SPAIGIC   = [M:TVBSPA]SPAIGIC
 [F:TVB]SPADCL347 = [M:TVBSPA]SPADCL347
 [F:TVB]SPADCL349 = [M:TVBSPA]SPADCL349
 [F:TVB]SPAEXEOPE = [M:TVBSPA]SPAEXEOPE
 [F:TVB]SPAJOUDCL = [M:TVBSPA]SPAJOUDCL
 [F:TVB]SPAEURSRV = [M:TVBSPA]SPAEURSRV
 Rewrite [TVB]
 If fstat
  GOK = 0 : Call FSTA("TVB") From GLOCK : Return
 Endif
Endif
Commit
[L]=[M:TVBSPA] : REP=""
Return

$ABA
[M:TVBSPA]=[L] : REP=""
Gosub ENR
Affzo [M:TVBSPA]
Return

$APRES_MODIF
Read [ALK]LCKCLE="TVB"+[L]LEG+"\"+[L]COD;0
If !fstat & [F:ALK]LCKPID<>adxuid(2)
 GMESSAGE=mess(10,100,1)
 GERR=1
 [M:TVBSPA]=[L]
 Affzo [M:TVBSPA] :# FIN=1
Else
 REP = "M"
 Local Char SYMB(20)
 SYMB="TVB"+[L]LEG+"\"+[L]COD
 Lock SYMB With lockwait=0
Endif
Return

$FIN
If dim(SYMB)>0
 Unlock SYMB
Endif
Return
