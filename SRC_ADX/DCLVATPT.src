#<AdxTL>@(#)12.0.0.0 $Revision$
#CHECK UNUSED_SOURCE

#######################################################################################
#  DCLVATPT   (portugal)      Paul dufour (21/02/00)                                  #
#######################################################################################

 
Subprog DCLVAT 
 
Local Char    TIT(30)
Local Char    OPT(1)             : # "1":on prend la date comptable "2":date document origine 
Local Char    TTYPDEB(10)(1..50) : # Table types pièces à prendre en cpte pour décl TVA/débits 
Local Char    TTAX(3)(1..50)     : # Table des codes taxes qui sont dues sur les débits 
Local Char    TTYPPAY(10)(1..50) : # Table types pièces à prendre en cpte pour décl TVA/encaiss.  
Local Char    SYMBOLE(30)        : # Pour lock...
Local Integer NBTYPDEB           : # Nombre de types de pièces 
Local Integer NBTAX              : # Nombre de codes taxes dues sur les débits
Local Integer NBTYPPAY           : # Nombre de types de pièce 
Local Integer DCLVAT             : # Si 1, la décl. TVA/débits a déjà été effectuée pour la société
Local Integer DCLVATPAY          : # Si 1, la décl. TVA/enc. a déjà été effectuée pour la société
Local Integer OK                 : # Variables diverses
 
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif : # Sociétés
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif : # Sites
If clalev([F:DLV])=0 : Local File DCLVAT     [DLV] : Endif : # Déclaration de TVA sur débits 
If clalev([F:DVP])=0 : Local File DCLVATPAY  [DVP] : Endif : # Fichier temp. pour décl. TVA/enc 
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif : # Valeur des paramètres
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif : # Types de pièces
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif : # Codes taxes    
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif : # Table des devises 

Local Mask DCLVAT [DIA] 
  
Raz [M:DIA]  
TIT = mess(71,107,1) : # Déclaration de TVA 
OK = 2 : Call DIALOD(OK,TIT) From GESECRAN  
If OK<>2 : Goto SORTIE : Endif 
 
SYMBOLE = "DCL"+[M:DIA]STRDAT
Lock =SYMBOLE With lockwait=0
If fstat
 # Opération en cours sur autre poste
 Call ERREUR(mess(30,100,1)) From GESECRAN : End
Endif

Call TEMPON("V") From GESECRAN 

If [M:DIA]REIMP = 1
 If [M:DIA]VAT = 2 : # On a demandé la TVA sur débits
  # Table des types de pièces qui doivent être pris en compte pour 
  # la déclaration de TVA sur débits 
  Raz NBTYPDEB, TTYPDEB 
  For [GTE]GTE0 Where VAT = 2 
   NBTYPDEB += 1 
   TTYPDEB(NBTYPDEB) = [F:GTE]TYP 
  Next
  # Table des taxes qui sont dues sur les débits 
  Raz NBTAX, TTAX 
  For [TVT]TVT0 Where VATPAY = 1 
   NBTAX += 1 
   TTAX(NBTAX) = [F:TVT]VAT 
  Next
 Endif 
 If [M:DIA]VATPAY = 2 : # On a demandé la TVA sur encaissements
  # Table des types de pièces qui doivent être pris en compte pour  
  # la déclaration de TVA sur encaissements  
  Raz NBTYPPAY, TTYPPAY  
  For [GTE]GTE0 Where VATPAI = 2  
   NBTYPPAY += 1  
   TTYPPAY(NBTYPPAY) = [F:GTE]TYP  
  Next   
 Endif

 OK=0 : GOK = 1
 For [CPY]CPY0 Where ([M:DIA]ALLCPY=2 | CPY=[M:DIA]CPY) & CPYLEGFLG=2
  Gosub CONTROLE
  Call LECTURE("TCU",[F:CPY]ACCCUR,"") From CONTOBJ
  GARODEV = [F:TCU]CURRND
  Call PARAM([F:CPY]CPY,"DCLVATDAT",OPT) From ADOVAL
  For [FCY]FCY0 Where LEGCPY=[F:CPY]CPY & FINFLG=2
   If [M:DIA]VAT = 2 : # On a demandé la TVA sur débits
    If !DCLVAT
     Call DCLVATDEB([F:CPY]CPY,[F:FCY]FCY,[M:DIA]STRDAT,[M:DIA]ENDDAT,[M:DIA]SIM,OPT,
&                   TTYPDEB,NBTYPDEB,TTAX,NBTAX)
    Else
     DCLVAT=0 : Break : # On change de société
    Endif
   Endif
   If GOK<1 : Break 2 : Endif
   If [M:DIA]VATPAY = 2 : # On a demandé la TVA sur encaissements
    If !DCLVATPAY
     Call DCLVATPAY([F:CPY]CPY,[F:FCY]FCY,[M:DIA]STRDAT,[M:DIA]ENDDAT,[M:DIA]SIM,
&                   TTYPPAY,NBTYPPAY) 
    Else
     DCLVATPAY=0 : Break : # On change de société
    Endif
   Endif
   If GOK<1 : Break 2 : Endif
  Next
 Next 
 Call TEMPOFF From GESECRAN
Endif

If [M:DIA]VAT = 2
 Call IMPRIME("DCLVAT01","DCLVAT") From ETAT 
Endif
If [M:DIA]VATPAY = 2
 Call IMPRIME("DCLVAT02","DCLVAT") From ETAT
Endif 
 
$SORTIE 
Unlock =SYMBOLE
End

$CONTROLE
# Si la déclaration de TVA sur débits a déjà été lancée en réel, alors on ne peut pas
# la relancer
DCLVAT=0
Filter [DLV] Where CPY=[F:CPY]CPY & STRDAT=[M:DIA]STRDAT & SIM<>2
Read [DLV]DLV0 First
If !fstat
 DCLVAT=1
Endif
Filter [DLV]
# Si la déclaration de TVA sur encaissements a déjà été lancée en réel, alors on ne peut pas
# la relancer
DCLVATPAY=0
Filter [DVP] Where CPY=[F:CPY]CPY & STRDAT=[M:DIA]STRDAT & SIM<>2
Read [DVP]DVP0 First
If !fstat
 DCLVATPAY=1
Endif
Filter [DVP]
Return


########################### 
#  TVA SUR DEBITS         # 
########################### 
Subprog DCLVATDEB(SOC,SIT,DATDEB,DATFIN,SIMUL,OPT,TTYP,NBTYP,TTAX,NBTAX) 
Value Char    SOC()       : # Société pour laquelle on fait la déclaration de TVA 
Value Char    SIT()       : # Site pour lequel on fait la déclaration 
Value Date    DATDEB      : # Date début de la déclaration de TVA 
Value Date    DATFIN      : # Date fin de la déclaration de TVA
Value Integer SIMUL       : # Si <>2, on lance la déclaration en réel (MAJ du montant TVA déclarée)
Value Char    OPT()       : # "1":on prend la date comptable "2":date document origine 
Value Char    TTYP()(1..)    : # Table types pièces à prendre en cpte pour décl TVA/débits 
Value Integer NBTYP       : # Nombre de types de pièces 
Value Char    TTAX()(1..) : # Table des codes taxes qui sont dues sur les débits 
Value Integer NBTAX       : # Nombre de codes taxes dues sur les débits
 
# NB : En France, la déclaration de TVA se fait tous les mois. Par contre, 
# dans d'autres pays la périodicité n'est pas la même : en Espagne, il y a une 
# déclaration trimestrielle. 
# C'est pourquoi, on ne raisonne pas sur une période ou sur un mois mais 
# sur une date de début et une date de fin de déclaration.  
 
Local Char    PLAN(GLONCOA)      : # Plan de comptes
Local Integer SIGN               : # Signe 
Local Integer IND, I             : # Variables diverses 
Local Decimal TMONTANT(1..NBTAX) : # Table des montants de TVA par code taxe
 
If clalev([F:DLV])=0 : Local File DCLVAT     [DLV] : Endif : # Déclaration de TVA sur débits 
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif : # En-tête des pièces comptables
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif : # Lignes des pièces comptables 
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif : # Comptes 

GSOCIETE = SOC
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN(GSOCIETE,GTYPGEN,PLAN) From CPTDIV
  
If OPT = "1"  
 Filter [DAE] Where CPY=SOC & FCYLIN=SIT & find(TYP,TTYP(1..NBTYP))
&                 & LEDTYP=GTYPGEN
&                 & ACCDAT>=DATDEB & ACCDAT<=DATFIN 
Else
 Filter [HAE] Where CPY=SOC & find(TYP,TTYP(1..NBTYP)) & (CAT=1 or CAT=2)
&                 & ((BPRDATVCR>=DATDEB & BPRDATVCR<=DATFIN) | BPRDATVCR=[0/0/0])
Endif 

Call DEBTRANS From GLOCK 
Gosub TR_DELDLV 
If GOK<1
 End
Endif
Gosub TR_DLV 
End 
 
$TR_DLV 
Trbegin [DLV] 
 # On parcourt les comptes de TVA et ceux soumis à la TVA (mais on ne prend pas
 # les comptes soumis TTC qui servent pour le cas des acomptes)
 For [GAC]GAC0 Where COA=PLAN & FLGVAT>1 & FLGVAT<5
  # On parcourt les lignes d'écritures qui mouvementent le compte  
  # de TVA ou soumis à la TVA 
  Raz TMONTANT
  If OPT = "1" 
   For [DAE]DAE1 Where LEDTYP=GTYPGEN & ACC=[F:GAC]ACC
    Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
    If [F:HAE]CAT=1 or [F:HAE]CAT=2
     Gosub MONTANT
     If GOK<1 : Break 2 : Endif
    Endif
   Next 
  Elsif OPT = "2"
   For [HAE]HAE0
    # Si la date de document d'origine est vide, c'est la date de pièce qui est retenue
    For [DAE]DAE0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=GTYPGEN & ACC=[F:GAC]ACC & FCYLIN=SIT
&                     & ([F:HAE]BPRDATVCR<>[0/0/0] | (ACCDAT>=DATDEB & ACCDAT<=DATFIN))
     Gosub MONTANT
     If GOK<1 : Break 3 : Endif
    Next 
   Next 
  Endif 
  For I=1 To NBTAX
   If TMONTANT(I)<>0 
    [F:DLV]CPY = SOC 
    [F:DLV]FCY = SIT 
    [F:DLV]STRDAT = DATDEB 
    [F:DLV]ENDDAT = DATFIN
    [F:DLV]SIM = SIMUL
    [F:DLV]ACC = [F:GAC]ACC 
    [F:DLV]VAT = TTAX(I)
    Case [F:GAC]FLGVAT 
     When 2    : [F:DLV]TYPAMT = 1 : # Compte soumis à TVA (base) 
     When 3, 4 : [F:DLV]TYPAMT = 2 : # Compte de TVA (montant) 
    Endcase  
    [F:DLV]FLGVAT = [F:GAC]FLGVAT 
    [F:DLV]VATIPT = [F:GAC]VATIPT 
    [F:DLV]AMT = TMONTANT(I)
    Write [DLV] 
    If fstat  
     GOK=0 : Call FSTA("DLV") From GLOCK : Break  
    Endif  
   Endif 
  Next
 Next 
 If GOK<0   : Goto ROLL_TR_DLV 
 Elsif !GOK : Goto AB_TR_DLV   
 Endif 
Commit 
End 
 
$AB_TR_DLV 
Rollback  
Return  
  
$ROLL_TR_DLV  
Rollback  
Call ROLL From GLOCK  
If GROLL : Return : Else : Goto TR_DLV : Endif  
  
$MONTANT 
# S'il y a un code taxe associé à la ligne d'écriture et que  
# cette taxe est due sur les débits, on doit prendre en compte  
# la base TVA ou le montant de TVA    
IND = find([F:DAE]TAX,TTAX(1..NBTAX)) 
############################################################ SPE
If IND 
 Case [F:GAC]VATIPT  
  When 1,5,6 
   SIGN=-1  : # VAT Collected
  When Default
   SIGN=1 : # VAT deduced
 Endcase
############################################################ SPE
 TMONTANT(IND) += SIGN*[F:DAE]SNS*[F:DAE]AMTLOC : # Compte soumis à la TVA  
 If SIMUL=1 & [F:GAC]FLGVAT=3
  # On lance la déclaration de TVA sur débits en réel. On va donc
  # mettre à jour le montant de TVA déclarée dans la ligne d'écriture
  # (GACCENTRYD).
  # NB : on fait la MAJ que pour les comptes de TVA (lignes d'écritures
  # correspondant à de la TVA.
  Gosub MAJ_AMTVAT
  If GOK<1 : Return : Endif
 Endif
Endif 
Return

$MAJ_AMTVAT
[F:DAE]AMTVAT = [F:DAE]AMTLED
Rewrite [DAE]
If fstat
 GOK=0 : Call FSTA("DAE") From GLOCK
Endif
Return
 
# On commence par effacer les enregistrements pour la déclaration de TVA 
# qu'on est en train de lancer.
$TR_DELDLV 
GOK = 1 
Trbegin [DLV] 
 Delete [DLV] Where CPY=SOC & FCY=SIT & (STRDAT=DATDEB & SIM=2) 
 If fstat=1 | fstat>5 
  GOK=0 : Call RSTA("DLV",SOC-SIT) From GLOCK : Goto AB_TR_DELDLV 
 Endif 
 If   GOK<0 : Goto ROLL_TR_DELDLV 
 Elsif !GOK : Goto AB_TR_DELDLV 
 Endif 
Commit 
Return 
 
$AB_TR_DELDLV 
Rollback 
Return 
 
$ROLL_TR_DELDLV 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_DELDLV : Endif 
  

########################### 
#  TVA SUR ENCAISSEMENTS  # 
########################### 
Subprog DCLVATPAY(SOC,SIT,DATDEB,DATFIN,SIMUL,TTYP,NBTYP)  
Value Char    SOC()       : # Société pour laquelle on fait la déclaration de TVA  
Value Char    SIT()       : # Site pour lequel on fait la déclaration  
Value Date    DATDEB      : # Date début de la déclaration de TVA  
Value Date    DATFIN      : # Date fin de la déclaration de TVA
Value Integer SIMUL       : # Si <>2, on lance la déclaration en réel (MAJ du montant TVA déclarée)
Value Char    TTYP()(1..) : # Table types pièces à prendre en cpte pour décl TVA/encaiss.  
Value Integer NBTYP       : # Nombre de types de pièce 

## Contraintes (règles de gestion)
# 1°) Les comptes doivent être correctement paramétrés en ce qui concerne les zones 'Gestion
# de TVA' (soumis, non soumis, compte de TVA) et 'Imputation taxe' (collectée ventes,
# collectée immos, déductible achats, déductible immos)
# 2°) Les types de pièces "déclenchants" (règlements) doivent être correctement
# paramétrés dans le paramétrage des types de pièces
# 3°) La somme des montants des lignes d'écritures lettrées d'une pièce
# donne le montant de la pièce de règlement
# 4°) Les règlements doivent obligatoirement être imputés à une facture tiers (=le règlement
# doit être associés à un tiers car s'il est associé à un compte général, il n'y a pas
# d'imputation)
# 5°) La pièce à utiliser pour le versement ou la réception d'un acompte  
# peut doit être non déclenchante ou déclenchante (son type de pièce doit être
# paramétré avec TVA/encaissements à non ou à oui)
# 6°) La pièce à utiliser pour l'imputation de l'acompte sur la facture doit être 
# déclenchante (son type de pièce doit être paramétré avec TVA/encaissements à oui) 
# 7°) Dans le cas d'un versement ou de la réception d'un acompte relatif à une
# prestation de service, le compte de TVA à régulariser doit être paramétré comme
# compte non soumis
# 8°) Dans le cas où les pièces ne sont pas générées automatiquement mais saisies
# diretement en comptabilité, les codes taxes au niveau des lignes d'écritures
# doivent être correctement renseignés et le lettrage de écritures doit être correct
  
Local Integer MAXREG : # Nb max de couples code taxe/imputation taxe (collec., déduc.)  
MAXREG = 50 
Local Integer MAXPCE : # Nb max d'écritures par groupe de lettrage 
MAXPCE = 1000  
  
Local Char    COD(3)              : # Code taxe 
Local Char    CATCOD(4)           : # Imputation taxe (collectée/déductible)+code taxe 
Local Char    TBPCE(20)(1..MAXPCE): # Table pièces faisant partie d'un même groupe de lettrage                
Local Char    TCODENC(4)(1..50)   : # Table codes taxes dues sur les encaissements 
Local Char    TCODDEB(4)(1..50)   : # Table codes taxes dues sur les débits
Local Char    TYPPCE(10)          : # Type de pièce
Local Char    NUMPCE(20)          : # Numéro de pièce
Local Decimal TMTTVA(1..50)       : # Montant TVA sur encaissements associé à chaque TACCNUM
Local Integer CAT                 : # Imputation taxe (LA609) 
Local Integer SIGN                : # Signe 
Local Integer NBCODENC            : # Nb codes taxes dues sur les encaissements 
Local Integer NBCODDEB            : # Nb codes taxes dues sur les débits
Local Integer TROUVE              : # Variables diverses 
Local Integer NBPCE               : # Nb de pièces qui fait partie du même groupe de lettrage 
Local Integer TBACCNUM(1..10,200) : # Table des lignes de pièces de factures (accnum) ayant même
                                  : # groupe de lettrage qu'un règlement et même CATCOD et auquel
                                  : # est associé un code taxe tva sur encaissement. Cette ligne
                                  : # peut correspondre à un compte de TVA ou à un compte soumis
                                  : # à la TVA
Local Integer NBACCNUM(1..10)     : # Nombre de ACCNUM (lignes de pièce) ayant même groupe de 
                                  : # lettrage qu'un règlement par CATCOD 
Local Decimal MTREG               : # Montant règlements traités pour l'option TVA/débits d'abord 
Local Decimal TOTREG              : # Montant total du règlement de la pièce  
Local Decimal TOTREG_DEB          : # Part de TOTREG qui règle de la TVA/débits (base+TVA)   
Local Decimal TOTREG_ENC          : # Part de TOTREG qui règle de la TVA/encaissements (base+TVA) 
Local Decimal TOTAL 
Local Decimal TOTDEB, TOTENC
Local Decimal MTHT, MTTVA, MTTTC
Local Decimal BASENC(1..MAXREG)  : # Tableau des montants de bases de TVA sur encaissements 
Local Decimal TVAENC(1..MAXREG)  : # Tableau des montants de TVA sur encaissements 
Local Decimal BASDEB(1..MAXREG)  : # Tableau des montants de bases de TVA sur débits 
Local Decimal TVADEB(1..MAXREG)  : # Tableau des montants de TVA sur débits
Local Decimal AMTREPAR
Local Decimal RESTE
Local Decimal OLDBASVAT, OLDAMTVAT
Local Char    COMPTE(GLONGAC), TIERS(GLONBPR)      # hcb V6
Local Char    PLAN(GLONCOA)

If clalev([F:DVP])=0  : Local File DCLVATPAY  [DVP]  : Endif : # Fichier temp. pour décl. TVA/enc 
If clalev([F:DVP2])=0 : Local File DCLVATPAY  [DVP2] : Endif : # Fichier temp. pour décl. TVA/enc 
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif : # En-tête de pièces
If clalev([F:HAE2])=0 : Local File GACCENTRY  [HAE2] : Endif : # En-tête de pièces 
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif : # Lignes d'écritures 
If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif : # Lignes d'écritures  
If clalev([F:DAE3])=0 : Local File GACCENTRYD [DAE3] : Endif : # Lignes d'écritures
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif : # Comptes 
If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif : # Comptes 
If clalev([F:TVT])=0  : Local File TABVAT     [TVT]  : Endif : # Codes taxes (taux)
If clalev([F:ADW])=0  : Local File ADOVAL     [ADW]  : Endif : # Valeur des paramètres     

GSOCIETE = SOC
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN(GSOCIETE,GTYPGEN,PLAN) From CPTDIV

## BY 01/07/99 Ajout du filtre sur la catégorie
Filter [HAE] Where CPY=SOC & FCY=SIT
&                & DUDDAT>=DATDEB & DUDDAT<=DATFIN  
&                & find(TYP,TTYP(1..NBTYP))
&                & (CAT=1 or CAT=2)

Call DEBTRANS From GLOCK
Gosub TR_DELDVP
If GOK<1
 End
Endif
Gosub TR_DVP  
End  
  
$TR_DVP  
Trbegin [DVP] 
 # Parcours des pièces de règlement
 For [HAE]HAE0

  Raz TBPCE, NBPCE 
  Raz NBCODENC, NBCODDEB, TCODENC, TCODDEB 
  Raz BASENC, TVAENC, BASDEB, TVADEB, TOTREG, TOTREG_ENC, MTREG
  Raz TBACCNUM, NBACCNUM
  Raz COMPTE, TIERS
  # Parcours des lignes de pièces de règlement

# BY 18/01/2000 on ne prend plus que les lignes tiers à cause des remises intermédiaires
#               qui sont aussi lettrées (ISD)
 
  For [DAE]DAE0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=GTYPGEN & MTC<>"" & BPR<>""

   # Parcours des lignes d'écritures qui ont été lettrées ensemble
   # (qui ont le même  code lettrage) : il peut s'agir de factures
   # issues du règlement mais aussi d'un deuxième règlement... On
   # ignore les comptes d'acompte
   Call LECTURE("GAC",[F:DAE]ACC,PLAN) From CONTOBJ
   If [F:GAC]FLGVAT<>5 

## BY 27/05/99 (voir plus bas)
## Le problème est de déterminer quel est le montant du règlement
## J'ai choisi de prendre tout ce qui est sur le premier compte qui mouvemente
## effectivement de la TVA... en attendant le prochain bug

    For [DAE2]DAE1 Where CPY=SOC & FCYLIN=SIT & LEDTYP=GTYPGEN & SAC=[F:DAE]SAC & ACC=[F:DAE]ACC & BPR=[F:DAE]BPR
&                      & MTC=[F:DAE]MTC
     IDPCE = num$([F:DAE2]TYP)-[F:DAE2]NUM

## BY 02/02/00
## On est obligé de faire une première passe pour exclure les pièces qui mouvementent
## le compte d'acompte, sinon on n'a pas les moyens d'éliminer la TVA de la pièce
## de reprise d'acompte
## (Ca va pas améliorer les performances...)

     OKPCE = 1
     For [DAE3] Where TYP=[F:DAE2]TYP & NUM=[F:DAE2]NUM & LEDTYP=GTYPGEN
      Read [GAC]GAC0 = [F:DAE3]COA;[F:DAE3]ACC
      If [F:GAC]FLGVAT=5 : OKPCE=0 : Break : Endif
     Next

     If OKPCE & !find(IDPCE,TBPCE(1..NBPCE)) 

      NBPCE += 1  
      TBPCE(NBPCE) = IDPCE  
      PCETYP = [F:DAE2]TYP : PCENUM = [F:DAE2]NUM
      For [DAE3]DAE0 Where TYP=PCETYP & NUM=PCENUM & LEDTYP=GTYPGEN

## BY 27/05/99 Pourquoi ne pas prendre la TVA de la pièce de règlement (récup) ?

##     If [F:DAE3]TYP<>[F:HAE]TYP & [F:DAE3]NUM<>[F:HAE]NUM
        TROUVE = 0
        Gosub CALTVAENC
        If TROUVE & COMPTE=""
         COMPTE = [F:DAE]ACC : TIERS = [F:DAE]BPR
        Endif
##     Endif
       Call LECTURE("GAC",[F:DAE3]ACC,PLAN) From CONTOBJ

# BY le 27/05/99
# Je ne sais pas pourquoi TOTREG est initialisé comme ça ?
# Toujours est-il que de cette manière on prend en compte les règlements postérieurs!!
# Dans entreprise TOTREG était simplement le montant du règlement
#
#       If find([F:DAE3]TYP,TTYP(1..NBTYP)) & [F:DAE3]MTC<>"" & [F:GAC]FLGVAT<>5
#        TOTREG += [F:DAE3]SNS*[F:DAE3]AMTLED
#       Endif

      Next : # [DAE3]
      If find(PCETYP,TTYP(1..NBTYP))
       # C'est un second règlement
       Read [HAE]HAE0  = [F:DAE]TYP ; [F:DAE]NUM : # 1er règlement
       Read [HAE2]HAE0 = PCETYP ; PCENUM         : # 2ème règlement
       If ([F:HAE]REFINT<>[F:HAE2]REFINT) & ([F:HAE2]DUDDAT<[F:HAE]DUDDAT  
&       | ([F:HAE2]DUDDAT=[F:HAE]DUDDAT & [F:DAE2]ACCNUM<[F:DAE]ACCNUM))
        MTREG  += [F:DAE2]SNS*[F:DAE2]AMTLED
       Endif     
      Endif
     Endif 
    Next : # [DAE2]
   Endif

## BY on essaie de calculer le total du règlement

   If [F:DAE]ACC=COMPTE & [F:DAE]BPR=TIERS
    TOTREG += [F:DAE]SNS*[F:DAE]AMTLED
   Endif

  Next : # [DAE]
  TOTDEB = sum(BASDEB(1..NBCODDEB))+sum(TVADEB(1..NBCODDEB))
  TOTENC = sum(BASENC(1..NBCODENC))+sum(TVAENC(1..NBCODENC))
  TOTAL  = TOTDEB + TOTENC

## BY 01/07//99 [DAE]SNS ne suffit pas pour décider si c'est une recette  ou une dépense
## il peut en effet y avoir plusieurs lignes, prendre la dernière est arbitraire
# If [F:DAE]SNS = -1 : # Si le règlement est une recette
## On essaye de se baser sur TOTREG

  If TOTREG<0 : # Si le règlement est une recette
   MTREG  = -MTREG
   TOTREG = -TOTREG
   TOTDEB = -TOTDEB
   TOTENC = -TOTENC
   TOTAL  = -TOTAL
  Endif

  If TOTREG>abs(TOTAL) 
   # Le montant du règlement est supérieur aux montants des factures
   # appartenant au même groupe de lettrage : il règle d'autres
   # factures... 
   TOTREG = abs(TOTAL) 
  Endif 

  Case [M]OPTPAY 
   When 1 
    # On suppose que la TVA sur débits est payée en premier.
    #  Par conséquence,  on diminue le règlement du montant sur débits. 
    # Ex : Fact. 1000 Frs HT + 200 Frs TVA sur débits 
    #            1000 Frs HT + 200 Frs TVA sur encaissements 
    #            Total = 2400 Frs TTC 
    # On a un règlement de 1500 Frs. Dans ce cas, le montant de
    # la TVA sur débits sera de 1200 Frs et la TVA sur encaissements
    # sera de 300 Frs. 
    # En fait la TVA sur encaissements à déclarer sera égale à :
    # (300/1200)*200 soit 50 Frs
    If TOTDEB>MTREG
     ## Cela signifie que le montant (base+TVA) sur débits n'a pas été
     ## entièrement (ou peut-être même pas du tout) "traité" par un
     ## autre règlement
     TOTREG_ENC = TOTREG - (TOTDEB-MTREG)
    Else
     ## Cela signifie que soit la facture ne comporte pas de TVA
     ## sur débits soit le montant (base+TVA) sur débits a déjà
     ## été "traité" par un autre règlement
     TOTREG_ENC = TOTREG
    Endif 
    If TOTREG_ENC<0 : TOTREG_ENC=0 : Endif 
   When 2 
    # On suppose qu'on paye on prorata. On proratise le règlement
    # par rapport au rapport base+TVA sur encaissements/
    # Total base+TVA (TVAENC/TOTAL) 
    If TOTAL<>0 
     TOTREG_ENC = TOTREG*(TOTENC/TOTAL) 
    Endif  
  Endcase
  If TOTREG_ENC<>0
   For IND=1 To NBCODENC 
    CAT = val(left$(TCODENC(IND),1)) 
    COD = right$(TCODENC(IND),2)
    If CAT=1 | CAT=2: SIGN=-1 : Else : SIGN=1 : Endif 
    If TVAENC(IND)<>0 | BASENC(IND)<>0
     MTHT       = SIGN*BASENC(IND) 
     MTTVA      = SIGN*TVAENC(IND)

## BY le 19/07/99 On n'imprime qu'une ligne par groupe, donc base = somme des bases
     MTTVA      = SIGN*sum(TVAENC(1..NBCODENC))
     MTTTC      = TOTENC
     MTPCE      = min(TOTREG_ENC,abs(MTTTC)) 
     MONTANT    = arr(SIGN*TVAENC(IND)*MTPCE/abs(MTTTC),GARODEV)
     BASE       = arr(MTHT*MTPCE/abs(MTTTC),GARODEV) 
     For I=1 To NBACCNUM(IND)
      Raz OLDBASVAT, OLDAMTVAT
      Read [DAE3]DAE2 = TBACCNUM(IND,I)
      If !fstat & [F:DAE3]TAX=COD
       Read [GAC]GAC0 = [F:DAE3]COA;[F:DAE3]ACC
       If ([F:GAC]FLGVAT=2 & BASE<>0) | ([F:GAC]FLGVAT=3 & MONTANT<>0)
        # On regarde si on a déjà traité une partie de la ligne
        # d'écriture numéro TBACCNUM(IND)(I) (elle a pu être déjà
        # traitée par un autre règlement...)
        # et si oui, on met dans les variables OLDBASVAT ou OLDAMTVAT
        # (selon le type de compte) les montants qu'on a déjà traité
        Look [DVP]DVP1 = [F:DAE3]ACCNUM
        If !fstat & [F:DVP]STRDAT = DATDEB
         For [F:DVP]DVP1 Where ACCNUM = [F:DAE3]ACCNUM & STRDAT=DATDEB
          # La ligne d'écriture [F:DAE3]ACCNUM a pu être traitée par plusieurs
          # autres règlements (on ne peut donc pas se contenter d'un Read...)
          If [F:GAC]FLGVAT=2
           OLDBASVAT += [F:DVP]BASVATPAY
          Elsif find([F:GAC]FLGVAT,3,4)
           OLDAMTVAT += [F:DVP]AMTVATPAY
          Endif 
         Next
        Endif
        If fstat | ([F:GAC]FLGVAT=2 & OLDBASVAT<[F:DAE3]AMTLED) 
&                | ([F:GAC]FLGVAT=3 & OLDAMTVAT<[F:DAE3]AMTLED)
         # Si la ligne de facture n'existe pas dans le fichier temporaire
         # DCLVATPAY ou que le montant de la base de TVA déjà traité (ou le 
         # montant de TVA selon le type de compte) est inférieur strictement
         # au montant de la ligne d'écriture, cela veut dire qu'on n'a pas
         # encore traité en totalité la ligne de facture... 
         # (on fait ce test car dans TBACCNUM, on a les lignes d'écritures
         # correspondant à des lignes de facture qui ont le même groupe
         # de lettrage que le règlement courant. Or, dans le cas où
         # on a deux règlements qui règlent une même facture, il ne faut
         # pas traiter deux fois les mêmes lignes de d'écriture...)
         Raz [F:DVP] 
         [F:DVP]NUM = [F:DAE]NUM 
         [F:DVP]TYP = [F:DAE]TYP 
         [F:DVP]CPY = SOC 
         [F:DVP]FCY = SIT 
         [F:DVP]VAT = COD
         [F:DVP]STRDAT = DATDEB 
         [F:DVP]ENDDAT = DATFIN
         [F:DVP]ACCNUM = TBACCNUM(IND,I)
         [F:DVP]VATIPT = [F:GAC]VATIPT : # Imputation taxe (LA609)
         [F:DVP]SIM    = SIMUL
         # NB : Dans AMTVCR, on stocke en fait la part du règlement
         # [F:DAE]TYP/[F:DAE]NUM règlant de la TVA sur encaissements
         # Dans BASVAT, on stocke le montant total de TVA sur encaissements
         # que contiennent les factures appartenant au même groupe de
         # lettrage que le règlement. Plus précisement, cela correspond au
         # montant total des lignes de factures lettrées avec le règlement
         # correspondant à des comptes de TVA et auxquels sont associés
         # un code taxe TVA/encaissements égal à COD.
         [F:DVP]AMTVCR    = MTPCE
         [F:DVP]TOTAMTATI = MTTTC
         [F:DVP]TOTAMTVAT = MTTVA
         If [F:GAC]FLGVAT = 2 & BASE<>0
          #[F:DVP]BASVATPAY = min(BASE,[F:DAE3]AMTLED-OLDBASVAT)
          #BASE -= [F:DVP]BASVATPAY
          If (SIGN=-1 & [F:DAE3]SNS=1) | (SIGN=1 & [F:DAE3]SNS=-1)
           # Ventes et c'est du débit ou Achats et c'est du crédit...
           [F:DVP]BASVATPAY = (min(abs(BASE),[F:DAE3]AMTLED-abs(OLDBASVAT)))*-1
          Else
           [F:DVP]BASVATPAY = (min(abs(BASE),[F:DAE3]AMTLED-abs(OLDBASVAT)))
          Endif 
          BASE -= [F:DVP]BASVATPAY
         Elsif find([F:GAC]FLGVAT,3,4) & MONTANT<>0
          #[F:DVP]AMTVATPAY = min(MONTANT,[F:DAE3]AMTLED-OLDAMTVAT)
          #MONTANT -= [F:DVP]AMTVATPAY
          If (SIGN=-1 & [F:DAE3]SNS=1) | (SIGN=1 & [F:DAE3]SNS=-1)
           [F:DVP]AMTVATPAY = (min(abs(MONTANT),[F:DAE3]AMTLED-abs(OLDAMTVAT)))*-1
          Else
           [F:DVP]AMTVATPAY = (min(abs(MONTANT),[F:DAE3]AMTLED-abs(OLDAMTVAT)))
          Endif 
          MONTANT -= [F:DVP]AMTVATPAY
         Endif
         Write [DVP]
         If fstat   
          GOK=0 : Call FSTA("DVP") From GLOCK : Break 3 
         Endif
         If SIMUL = 1 & find([F:GAC]FLGVAT,3,4) 
          # On lance la déclaration en réel => MAJ du montant TVA déclarée
          # NB : on fait cette MAJ que pour les comptes de TVA
          AMTREPAR = [F:DVP]AMTVATPAY
          If [F:DAE3]AMTVAT<[F:DAE3]AMTLED
           # Il reste de la TVA à déclarer à mettre à jour...
           RESTE = [F:DAE3]AMTLED - [F:DAE3]AMTVAT
           If RESTE<=AMTREPAR
            [F:DAE3]AMTVAT += RESTE
            AMTREPAR -= RESTE
           Else
            [F:DAE3]AMTVAT += AMTREPAR
            AMTREPAR -= AMTREPAR
           Endif
           Rewrite [DAE3]
           If fstat
            GOK=0 : Call FSTA("DAE3") From GLOCK 
           Endif
           If GOK<1 : Break 3 : Endif
          Endif
         Endif
        Endif
        If BASE=0 & MONTANT=0 : Break : Endif
       Endif
      Endif
     Next
    Endif
   Next 
  Endif
 Next : # [HAE]
 If GOK<0   : Goto ROLL_TR_DVP 
 Elsif !GOK : Goto AB_TR_DVP  
 Endif
 Filter [HAE]

 ## Cas des acomptes
 # Lors d'un versement ou de la réception d'un acompte relatif
 # à une prestation de service, l'acompte est considéré comme
 # porteur de TVA qu'il faut déclarer.
 # Le compte d'acompte (409, 419) reçu ou versé doit être
 # paramétré en "Compte d'acompte".
 # La pièce constatant le règlement ou le versement d'un
 # acompte peut être déclenchante ou non déclenchante.
 # Par contre, la pièce d'imputation d'acompte doit être
 # déclenchante.
 # On parcourt les comptes d'acompte (pour lesquels FLGVAT=5)
 # pour traiter le cas des acomptes
 Raz TYPPCE, NUMPCE
 Filter [DAE] Where CPY=SOC & FCYLIN=SIT & LEDTYP=GTYPGEN
 For [GAC]GAC0 Where COA=PLAN & FLGVAT=5
  For [DAE]DAE1 Where LEDTYP=GTYPGEN & ACC=[F:GAC]ACC
   If !([F:DAE]TYP=TYPPCE & [F:DAE]NUM=NUMPCE)
    Read [HAE]HAE0 = [F:DAE]TYP ; [F:DAE]NUM
    If fstat=0 & [F:HAE]DUDDAT>=DATDEB & [F:HAE]DUDDAT<=DATFIN
     TYPPCE = [F:DAE]TYP
     NUMPCE = [F:DAE]NUM
     Raz MTTTC, MTTVA
     For [DAE2]DAE0 Where TYP=TYPPCE & NUM=NUMPCE & LEDTYP=GTYPGEN
      If [DAE2]ACC=[F:GAC]ACC
       MTTTC += [F:DAE2]AMTLED*[F:DAE2]SNS 
      Else
       Read [F:GAC2]GAC0 = [F:DAE2]COA;[F:DAE2]ACC
       If !fstat & [F:GAC2]FLGVAT=3 : # C'est un compte de TVA
     ############################################################## SPE PT
        Case [F:GAC2]VATIPT 
         When 1,5,6 
          SIGN=-1  : # VAT Collected
         When Default
          SIGN=1 : # VAT deduced
        Endcase
     ############################################################## SPE PT
        MTTVA += [F:DAE2]AMTLED*[F:DAE2]SNS*SIGN
        [F:DAE2]AMTVAT = [F:DAE2]AMTLED
        Rewrite [DAE2] 
        If fstat
         GOK=0 : Call FSTA("DAE2") From GLOCK
        Endif
       Endif
      Endif
     Next
     MTTTC = MTTTC*SIGN
     Raz [F:DVP] 
     [F:DVP]NUM       = [F:DAE]NUM 
     [F:DVP]TYP       = [F:DAE]TYP 
     [F:DVP]CPY       = SOC 
     [F:DVP]FCY       = SIT 
     [F:DVP]VAT       = [F:DAE]TAX    
     [F:DVP]STRDAT    = DATDEB 
     [F:DVP]ENDDAT    = DATFIN
     [F:DVP]ACCNUM    = [F:DAE]ACCNUM
     [F:DVP]VATIPT    = [F:GAC]VATIPT : # Imputation taxe (LA609)
     [F:DVP]SIM       = SIMUL
     [F:DVP]AMTVCR    = abs(MTTTC)
     [F:DVP]BASVATPAY = MTTTC-MTTVA
     [F:DVP]AMTVATPAY = MTTVA
     Write [DVP]
     If fstat   
      GOK=0 : Call FSTA("DVP") From GLOCK : Break 2 
     Endif
    Endif
   Endif
  Next
 Next
 Filter [DAE]
 If GOK<0   : Goto ROLL_TR_DVP 
 Elsif !GOK : Goto AB_TR_DVP  
 Endif
Commit 
Return  

$AB_TR_DVP  
Rollback   
Return   
   
$ROLL_TR_DVP   
Rollback   
Call ROLL From GLOCK   
If GROLL : Return : Else : Goto TR_DVP : Endif   
   
 
$CALTVAENC 
# Calcul des bases et montants de TVA
# Vu avec BY le 21/10/98 suite à une remarque de Frédéric GUILLARD :
# si la ligne d'écriture ne contient pas de code taxe,
# on considère le compte comme non soumis.
# Il existe obligatoirement au moins un code taxe 'exonéré' dans
# le paramétrage de codes de taxes. Une ligne peut contenir un
# compte de type 'soumis à TVA' alors qu'il n'y a pas de code taxe
# associé. Dans ce cas, il ne faut pas la prendre en compte
If [F:DAE3]TAX<>""
 Read [GAC]GAC0 = [F:DAE3]COA;[F:DAE3]ACC
 If !fstat
  CAT = [F:GAC]VATIPT : # TVA coll.ven/coll.immo/déduc.achats/déduc.immos 
  COD = [F:DAE3]TAX 
  CATCOD = num$(CAT)+COD  
  Call LECTURE("TVT",COD,"") From CONTOBJ 
  If [F:TVT]VATPAY = 2 : # Taxe due sur les encaissements 
   IND = find(CATCOD,TCODENC(1..NBCODENC))
   If !IND 
    NBCODENC += 1 : IND = NBCODENC : TCODENC(IND) = CATCOD 
   Endif 
   Case [F:GAC]FLGVAT 
    When 2
     BASENC(IND)   += [F:DAE3]SNS*[F:DAE3]AMTLED
     NBACCNUM(IND) += 1 : TBACCNUM(IND,NBACCNUM(IND)) = [F:DAE3]ACCNUM
     TROUVE = 1
    When 3
     TVAENC(IND)   += [F:DAE3]SNS*[F:DAE3]AMTLED
     NBACCNUM(IND) += 1 : TBACCNUM(IND,NBACCNUM(IND)) = [F:DAE3]ACCNUM
     TROUVE = 1
   Endcase
  Else : # Taxe due sur les débits
   IND = find(CATCOD,TCODDEB(1..NBCODDEB)) 
   If !IND 
    NBCODDEB += 1 : IND = NBCODDEB : TCODDEB(IND) = CATCOD 
   Endif 
   Case [F:GAC]FLGVAT 
    When 2
     BASDEB(IND) += [F:DAE3]SNS*[F:DAE3]AMTLED 
    When 3
     TVADEB(IND) += [F:DAE3]SNS*[F:DAE3]AMTLED  
   Endcase 
  Endif
 Endif
Endif 
Return 
 
# On commence par effacer les enregistrements pour la déclaration
# de TVA sur encaissements qu'on est en train de lancer et pour
# lequels SIM=2 
$TR_DELDVP 
GOK = 1 
Trbegin [DVP] 
 Delete [DVP] Where CPY=SOC & FCY=SIT & (STRDAT=DATDEB & SIM=2) 
 If fstat=1 | fstat>5 
  GOK=0 : Call RSTA("DVP",SOC-SIT) From GLOCK : Goto AB_TR_DELDVP 
 Endif 
 If   GOK<0 : Goto ROLL_TR_DELDVP 
 Elsif !GOK : Goto AB_TR_DELDVP 
 Endif 
Commit 
Return 
 
$AB_TR_DELDVP 
Rollback 
Return 
 
$ROLL_TR_DELDVP 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_DELDVP : Endif 
   

#################################
# Etiquettes du masque DCLVAT   # 
################################# 
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Call AS_CPY(VALEUR) From CPTTRT
End

Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR 
VALEUR = gdat$(1,month(date$)-1,year(date$))
End
 
Subprog D_ENDDAT(VALEUR) 
Variable Date    VALEUR 
VALEUR = eomonth([M]STRDAT) 
End

Subprog AP_VATPAY(VALEUR) 
Variable Integer VALEUR
Local Integer OK
OK=0 
If [M]VAT=2
 For [DLV]DLV0 Where ([M]CPY="" | CPY=[M]CPY) & STRDAT=[M]STRDAT
  OK=1 : Break
 Next
Endif
If [M]VATPAY=2 & !OK
 For [DVP]DVP0 Where ([M]CPY="" | CPY=[M]CPY) & STRDAT=[M]STRDAT  
  OK=1 : Break
 Next
Endif
If !OK
 Grizo REIMP
Else
 Actzo REIMP
Endif
End

Subprog AS_OPTPAY(VALEUR)
Variable Integer VALEUR
If [M]VATPAY=1 
 mkstat=2 : End 
Endif 
End




