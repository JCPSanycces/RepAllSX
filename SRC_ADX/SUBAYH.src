#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion objet AYH
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AYH",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Etiquette ajoutée par le superviseur (Objet AYH) 29/04/2009 14:56:14 (CCL)
######################################################################################
$ACTION
Case ACTION
 When "MODIF"     : Gosub MAJTEX
 When "CREATION"  : Gosub MAJTEX
 When "CHANGE"    : Gosub CHANGE
 When "ANNULE"    : Gosub ANNULE
 When default
Endcase
Return


######################################################################################

$MAJTEX
Call MAJTEXTRA([M]INTPRF,"AYTPRFUSR","INTPRF",[M]CODPRF,"") From ATEXTRA
Return

$CHANGE
Update [AXX] Where CODFIC="AYTPRFUSR" & ZONE = "INTPRF" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA AYTPRFUSR"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

$ANNULE
Delete [AXX] Where CODFIC="AYTPRFUSR" & ZONE = "INTPRF"  & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
Return

$TRTCOP
If [M]DOSORG=nomap 
 Local File AYTPRFUSR  [AYH1] 
Else 
 Local File =[M]DOSORG+".AYTPRFUSR"  [AYH1]
Endif 
If [M]DOSDES=nomap 
 Local File AYTPRFUSR  [AYH2] 
Else 
 Local File =[M]DOSDES+".AYTPRFUSR"  [AYH2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AYH1], [AYH2]
Return

$TR_COP
GOK = 1
Trbegin [AYH2]
 Delete [AYH2] Where CODPRF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AYTPRFUSR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYH2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AYH1]AYH0 Where CODPRF=TABLE
  [F:AYH2] = [F:AYH1]
  If dim([F:AYH2]UPDUSR)>0 : [F:AYH2]UPDUSR = GUSER : Endif
  If dim([F:AYH2]UPDDAT)>0 : [F:AYH2]UPDDAT = date$ : Endif
  If dim([F:AYH2]UPDTIM)>0 : [F:AYH2]UPDTIM = time : Endif
  Write [AYH2]
  If fstat
   GOK=0 : Call FSTA("AYH2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

######################################################################################
######################################################################################
######################################################################################
Subprog C_PRFXTDCOD(VALEUR)
Variable Char    VALEUR()
Read [AYD]AYD0=[M]FCYXTDCOD(nolign-1);VALEUR
If fstat
 Call ERREUR([M]FCYXTDCOD(nolign-1)-VALEUR-":"-mess(23,100,1)) From GESECRAN : # Fiche inexistante
 mkstat = 1 : End
Endif
End

Subprog C_FCYXTDCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]FCYXTDCOD) From OBJDIV
End


######################################################################################

