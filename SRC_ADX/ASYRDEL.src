#<AdxTL>@(#)8.0.0.0 $Revision$
##**
## Delta POST management
##*!

#**
#* PARSEDELTA(ACTX,JSON,UPD)
#*
#* @param ACTX
#* @param JSON
#* @param UPD
#*!
Funprog PARSEDELTA(ACTX,NODE,DELTAS)
Variable Instance  ACTX        Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance  NODE        Using C_ASYRJSO
Variable Instance  DELTAS(1..) Using C_ADELTA

Local Uuident   UIDPAR : UIDPAR = NullUuid
Local Uuident   UID    : UID = NullUuid
Local Integer   FUIDF : FUIDF = 0
Local Char      UUIDS(40)(1..)
Local Integer   INDEXPAR : INDEXPAR=-1
Local Char      COLPAR(250)
If dim(NODE)>0 & maxtab(NODE)>0 & NODE(0) <> null
 Call WALKPROPERTIES(DELTAS,UUIDS,NODE,UIDPAR,UID,"","",FUIDF,INDEXPAR,COLPAR)
Endif
End 0

#**
#* WALKPROPERTIES
#*!
Subprog WALKPROPERTIES(DELTAS,UUIDS,NODE,UIDPARPAR,UIDPAR,FATHER,COL,FUIDF,INDEXPAR,COLPAR)
Variable Instance  DELTAS Using C_ADELTA
Variable Char      UUIDS()(1..)
Variable Instance  NODE  Using C_ASYRJSO
Value    Uuident   UIDPARPAR
Value    Uuident   UIDPAR
Value    Char      FATHER
Value    Char      COL
Value    Integer   FUIDF
Value    Integer   INDEXPAR
Value    Char      COLPAR

Local Char      PRO(250)
Local Instance  PNODE          Using C_ASYRJSO
Local Instance  PATTRIBUTES    Using C_ASYRJSO
Local Instance  PATTRIBUTE     Using C_ASYRJSO
Local Instance  PPARAMETERS    Using C_ASYRJSO
Local Instance  PACTIONS       Using C_ASYRJSO
Local Instance  PACTION          Using C_ASYRJSO
Local Instance  PPROPERTIES  Using C_ASYRJSO : PPROPERTIES = null

#TODO remove - Local Instance  PVALUE         Using C_ASYRJSO
Local Instance  PITEM          Using C_ASYRJSO
Local Instance  PNULL          Using C_ASYRJSO : PNULL = null
Local Instance  PDELTA         Using C_ADELTA
Local Integer   INDEX : INDEX =-1
Local Integer INDEXCHILD
Local Char      ISDELETED(250) : ISDELETED=""
Local Integer   IND
Local Integer   FUID  : FUID = 0
Local Uuident   LUIDPAR
Local Uuident   UID
Local Integer   ISEMPTY
Local Char      LCOLPAR(250)


LUIDPAR  = UIDPARPAR
UID      = UIDPAR

#1°) Loop on attributes:
PNODE=NODE
While PNODE <> null
 Case PNODE.PRO
  When "$uuid"     :
   If (UIDPAR <> NullUuid) and (!find(num$(UIDPAR),UUIDS))
    Call ADDDELTA(PDELTA,DELTAS,UUIDS,PNULL,COLPAR,"",UIDPARPAR,UIDPAR,ISDELETED,INDEXPAR,PPROPERTIES)
   Endif
   LUIDPAR = UID
   LCOLPAR = COL
   UID     = toUuid(mid$(fmet PNODE.AGETCNT,2 ,len(fmet PNODE.AGETCNT)-2))
   FUIDF   = 1
  #TODO remove - When "$value"    : PVALUE      = PNODE
  When "$index"       : INDEX             = val(fmet PNODE.AGETCNT)
  When "$isDeleted" : ISDELETED     = fmet PNODE.AGETCNT
  When "$actions"    : PACTIONS       = PNODE
  When "$"              : PATTRIBUTES = PNODE
  When "$properties": PPROPERTIES= PNODE
 Endcase
 PNODE = PNODE.NEX
Wend

If INDEX=-1 & INDEXPAR<>-1 :
 INDEXCHILD = INDEXPAR
Else
 INDEXCHILD = INDEX
Endif
#TODO remove - #2°) "$value"
#TODO remove - If PVALUE <> null
#TODO remove -   Call ADDDELTA(PDELTA,DELTAS,UUIDS,PVALUE,COL,FATHER,LUIDPAR,UID,ISDELETED,INDEX,PPROPERTIES)
#TODO remove - Endif

#3°) common attributes = $
If PATTRIBUTES <> null
 PNODE = PATTRIBUTES.SUB
 While PNODE <> null
  Call ADDDELTA(PDELTA,DELTAS,UUIDS,PNODE,COL,PNODE.PRO,LUIDPAR,UID,ISDELETED,INDEX,PPROPERTIES)
  PATTRIBUTE = PNODE.SUB
  While PATTRIBUTE <> null
   PDELTA.ATT(maxtab(PDELTA.ATT)+1)   = NewInstance [UPD],C_ADELTAATT
   PDELTA.ATT(maxtab(PDELTA.ATT)).COD = PATTRIBUTE.PRO
   PDELTA.ATT(maxtab(PDELTA.ATT)).ATT = fmet PATTRIBUTE.AGETCNT
   PATTRIBUTE        = PATTRIBUTE.NEX
  Wend
  PNODE = PNODE.NEX
 Wend
Endif

#4°) Loop on actions:
If PACTIONS <> null
 PACTION = PACTIONS.SUB
 While PACTION <> null
  Call ADDDELTA(PDELTA,DELTAS,UUIDS,PNODE,COL,PACTION.PRO,LUIDPAR,UID,ISDELETED,INDEX,PPROPERTIES)
  PATTRIBUTE = PACTION.SUB
  While PATTRIBUTE <> null
   If PATTRIBUTE.PRO <> "$parameters"
    PDELTA.ATT(maxtab(PDELTA.ATT)+1)     = NewInstance [UPD],C_ADELTAATT
    PDELTA.ATT(maxtab(PDELTA.ATT)).COD = PATTRIBUTE.PRO
    PDELTA.ATT(maxtab(PDELTA.ATT)).ATT = fmet PATTRIBUTE.AGETCNT
   Else
    PPARAMETERS = PATTRIBUTE.SUB
    While PPARAMETERS <> null
     PDELTA.ATT(maxtab(PDELTA.ATT)+1)   = NewInstance [UPD],C_ADELTAATT
     PDELTA.ATT(maxtab(PDELTA.ATT)).COD = PPARAMETERS.PRO
     PDELTA.ATT(maxtab(PDELTA.ATT)).ATT = fmet PPARAMETERS.AGETCNT
     PPARAMETERS        = PPARAMETERS.NEX
    Wend
   Endif
   PATTRIBUTE        = PATTRIBUTE.NEX
  Wend
  PACTION = PACTION.NEX
 Wend
Endif

#5°) Loop on properties:
PNODE=NODE
While PNODE <> null
 PRO = PNODE.PRO
 If (PNODE.TYP = 1) & ("$" <> left$(PNODE.PRO,1))
  #it's an object
  If(right$(PNODE.PRO,len(PNODE.PRO)-3)="_REF")
   Call WALKPROPERTIES(DELTAS,UUIDS,PNODE.SUB,LUIDPAR,UID,PRO,COL,FUID,INDEX,LCOLPAR)
  Else
   Call WALKPROPERTIES(DELTAS,UUIDS,PNODE.SUB,LUIDPAR,UID,PRO,PNODE.PRO,FUID,INDEX,LCOLPAR)
  Endif
 Elsif PNODE.TYP = 2
  #it's an array:
  ISEMPTY = 1
  IND     = 0
  PITEM   = PNODE.SUB
  #The array contains items :
  While PITEM <> null
   ISEMPTY = 0
   If PITEM.TYP = 1
    #it's an object
    Call WALKPROPERTIES(DELTAS,UUIDS,PITEM.SUB,LUIDPAR,UID,PITEM.PRO,PNODE.PRO,FUID,INDEX,LCOLPAR)
   Else
    Call ADDDELTA(PDELTA,DELTAS,UUIDS,PITEM,PNODE.PRO,PRO,LUIDPAR,UID,ISDELETED,IND,PPROPERTIES)
   Endif
   IND  += 1
   PITEM = PITEM.NEX
  Wend
  If ISEMPTY
   Call ADDDELTA(PDELTA,DELTAS,UUIDS,PITEM,PNODE.PRO,"IsEmpty",LUIDPAR,UID,ISDELETED,IND,PPROPERTIES)
  Endif
 Elsif "$" <> left$(PNODE.PRO,1)
  Call ADDDELTA(PDELTA,DELTAS,UUIDS,PNODE,COL,PRO,LUIDPAR,UID,ISDELETED,INDEXCHILD,PPROPERTIES)
 Endif
 PNODE = PNODE.NEX
Wend
If FUIDF and !find(num$(UID),UUIDS)
 #The $uuid has to appear in the delta
 Call ADDDELTA(PDELTA,DELTAS,UUIDS,PNULL,COL,"",UIDPAR,UID,ISDELETED,INDEX,PPROPERTIES)
Endif
End

#**
#* ADDDELTA
#*!
Subprog ADDDELTA(PDELTA,DELTAS,UUIDS,NODE,COL,PRO,UIDPAR,UID,ISDELETED,IND,PROPERTIES)
Variable Instance  PDELTA Using C_ADELTA
Variable Instance  DELTAS(1..) Using C_ADELTA
Variable Char      UUIDS()(1..)
Variable Instance  NODE  Using C_ASYRJSO
Value    Char      COL
Value    Char      PRO
Value    Uuident   UIDPAR
Value    Uuident   UID
Value    Char      ISDELETED
Value    Integer   IND
Variable Instance  PROPERTIES  Using C_ASYRJSO


Local Instance  PROPERTY Using C_ASYRJSO
Local Instance  ATTRIBUTES Using C_ASYRJSO
Local Clbfile CNT

Local Integer U,K

U=1
While len(UUIDS(U))>0
 If num$(UID) = UUIDS(U) : Break : Endif
 U +=1
Wend
UUIDS(U) = num$(UID)

PDELTA = NewInstance [UPD] With C_ADELTA
PDELTA.COL     = COL
PDELTA.PRO     = PRO
PDELTA.UIDPAR  = UIDPAR
PDELTA.UID     = UID
PDELTA.IND     = IND

If len(ISDELETED) > 0
 PDELTA.ATT(1)     = NewInstance [UPD],C_ADELTAATT
 PDELTA.ATT(1).COD = "$isDeleted"
 PDELTA.ATT(1).ATT = "true"
Endif

If PROPERTIES <> null
 PROPERTY=PROPERTIES.SUB
 While PROPERTY <> null
  If PROPERTY.PRO = PRO
   ATTRIBUTES = PROPERTY.SUB
   While ATTRIBUTES <> null
    PDELTA.ATT(maxtab(PDELTA.ATT)+1)     = NewInstance [UPD],C_ADELTAATT
    PDELTA.ATT(maxtab(PDELTA.ATT)).COD = ATTRIBUTES.PRO
    PDELTA.ATT(maxtab(PDELTA.ATT)).ATT  = fmet ATTRIBUTES.AGETCNT
    ATTRIBUTES = ATTRIBUTES.NEX
   Wend
   Break
  Endif
  PROPERTY = PROPERTY.NEX
 Wend
Endif

If NODE <> null
 CNT = fmet NODE.AGETCNT
 K = func ASYRSUB.ASETCHREX(PDELTA,PDELTA.CHR,CNT)
Endif

DELTAS(maxtab(DELTAS)+1) = PDELTA

End

