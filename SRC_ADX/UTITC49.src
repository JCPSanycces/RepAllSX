#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTITC49   Table BOM migration ACLOB                          Module TC #
##########################################################################
# Issue 90663 GA 07/2013
##########################################################################
Local Char DOSSIER(30)

  If 1=1 Then
    DOSSIER = nomap
    Call SAIDOS(DOSSIER, "") From SAIDOS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      Read [ADS]DOSSIER=[L]DOSSIER
      If fstat THEN
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITC49(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [ADS]DOSSIER<>GDOSX3
         DOSSIER = [F:ADS]DOSSIER
         Call MAJ_UTITC49(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC49(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE, ICPT
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)
Local Char WITM(GLONITM)
Local Integer WBOMALT
Local Integer WBOMALTTYP

    IERR = 0
    Call ECR_TRACE("UTITC49: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table BOM
  #
    If filinfo(filpath("FIL", "ACLOB", "fde", SZAPPLI), 0) <= 0
&   |  filinfo(filpath("FIL", "BOM", "fde", SZAPPLI), 0) <= 0
      End
    Endif
    Local File =SZAPPLI + ".ACLOB" [ACBW]
    Local File =SZAPPLI + ".BOM"   [BOHW]
  #
    Trbegin [BOHW], [ACBW]
    Filter [ACBW] Where CODBLB="CO_BOD"
    For [F:ACBW]
        IUPDATE = 0
        If !find(right$([F:ACBW]IDENT2,len([F:ACBW]IDENT2)-1),"~1","~2","~3")
           WBOMALT=val([F:ACBW]IDENT1)
           WITMREF=[F:ACBW]IDENT2
           # Cas 1) nomenclature commerciale
           Read [BOHW]BOH0=WITMREF;WBOMALT;1
           If !fstat
              IUPDATE = 1
              [F:ACBW]IDENT2+="~1"
           Else
               # Cas 2) nomenclature de production
               Read [BOHW]BOH0=WITMREF;WBOMALT;2
               If !fstat
                  IUPDATE = 1
                  [F:ACBW]IDENT2+="~2"
               Endif
           Endif
        Endif
        If IUPDATE
           ICPT+=1
           Rewrite [F:ACBW]
        Endif
    Next
    Filter [ACBW]
    If IERR = 0 Then
      Commit
    Else
      Rollback
    Endif
    Close Local File [BOHW]
    Close Local File [ACBW]
  #
  Call ECR_TRACE("UTITC49 : records processed ACLOB"-num$(ICPT)-SZAPPLI, 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat THEN
    Raz [F:ADS]
  Endif
  Call MAJ_UTITC49(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTITC49(APPLI)
End
