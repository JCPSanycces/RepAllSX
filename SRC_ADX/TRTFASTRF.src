#-> Avant zone FCYD
Subprog AV_FCYD(VALEUR)
Variable Char    VALEUR()
 If varmode([M:FASM]MVTDAT)=0
  If ACTTYPGES=GTAMMAS : Call GER_GEO("FCYD",0,0) : Endif
 Endif
End

#-> Contrôle FCYD
Subprog C_FCYD(VALEUR)
Variable Char    VALEUR()

 # En unitaire, le site financier ne peut être vide

 If ACTTYPGES=GTAMUNI & VALEUR=""
  GERR=1
  GMESSAGE=mess(10,123,1)
  mkstat=2
 Endif

 # En massif et en unitaire, le site financier doit toujours être cohérent avec la société sélectionnée s'il y en a une.

 If ACTTYPGES=GTAMMAS | ACTTYPGES=GTAMUNI
  If VALEUR<>""
   If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
   Read [FCY]FCY0=VALEUR
   If !fstat
    If [M:FASM]CPYP<>[F:FCY]LEGCPY
     GERR=1
      If ACTTYPGES=GTAMMAS
       GMESSAGE=mess(353,7773,1)-" :"-[M:FASM]CPYP # "Site incompatible avec la société sélectionnée"
      Elsif ACTTYPGES=GTAMUNI
       GMESSAGE=mess(354,7773,1)-" :"-[M:FASM]CPYP # Site financier incompatible avec la société du bien
      Endif
     mkstat=2
     End
    Endif
   Endif
  Endif
 Endif

End

#-> Après modif FCYD

Subprog AM_FCYD(VALEUR)
Variable Char    VALEUR()

Local Integer NBPHY, WCODERR
Local Char WMSGERR(250)

  #> Critère de sélection si annulation
  If [M:FASM]CCLTRF = G_OUI
    Call ACTCHGCRIT() From TRCPROCOM
  Endif

  #> Saisie possible de la localisation
  If VALEUR <> "" and GPHY = G_OUI

    # FQ110028
    # rendre la localisation accessible :
    # en unitaire si valeur différente et des elts phy rattachés
    # en itf des mvts si des elts phy rattachés (on a changé de valeur mais déjà affecté le site)
    # en massif mais pas itf des mvts

    If ACTTYPGES = GTAMUNI
      [L]NBPHY = func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [M:FAS0]AASREF + "'")
    Else
      If dim(GFXDNBERR) >= 0
        [L]NBPHY = func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [F:FXM]REF1MVT + "'")
      Else
        [L]NBPHY = 0
      Endif
    Endif
    If (ACTTYPGES = GTAMUNI and VALEUR <> [M:FASM]FCYD and [L]NBPHY > 0) or
&      (dim(GFXDNBERR) >= 0 and [L]NBPHY > 0) or
&      (ACTTYPGES <> GTAMUNI and dim(GFXDNBERR) < 0)

      # FQ110230
      If [M:FASM]LCTCOD = ""
        [M:FASM]LCTCOD = func PHYLCT_CSTD.GET_DEFAULT_LOCATION(VALEUR, WCODERR, WMSGERR)
      Endif

      Actzo [M:FASM]LCTCOD
      Affzo [M:FASM]LCTCOD
    Endif
  Endif

  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  Read [FCY]FCY0=VALEUR
  If !fstat
    [M:FASM]CPYP=[F:FCY]LEGCPY
  Endif
End

Subprog C_LCTCOD(VALEUR)
Variable Char    VALEUR()

  # FQ110230
#  If [M:FASM]LCTCOD = ""
#    If (ACTTYPGES = GTAMUNI and [M:FAS0]FCY <> [M:FASM]FCYD) or
#&     (ACTTYPGES <> GTAMUNI and [M:FASM]FCYD <> "")
#    Endif
#  Endif

  If VALEUR <> ""
    If !clalev([F:LCT]) : Local File PHYLCT [LCT] : Endif
    Read [LCT]LCT0 = VALEUR

    If fstat = 0 and [F:LCT]FCY <> [M:FASM]FCYD
        GERR = 1
        GMESSAGE = mess(28, 7776, 1)
        mkstat = 2
        End
    Endif
  Endif

End

#-> Contrôle AASBUSD

Subprog C_AASBUSD(VALEUR)
Variable Char VALEUR()
 #> Contrôle si un transfert de secteur peut-être réalisé
 If ACTTYPGES=GTAMUNI & VALEUR<>""

# Transfert de secteur d'activité interdit si bien acquis dans l'exercice courant
# et date de transfert postérieure à l'exercice courant
  If (VALEUR<>[M:FAS1]AASBUS)        &
&    ([M:FASM]MVTDAT>GFINEXECPF)     &
&    ([M:FAS1]AASIPTDAT>=GDEBEXECPF) &
&    ([M:FAS1]AASIPTDAT<=GFINEXECPF)
   GERR=1
   GMESSAGE=mess(355,7773,1) # "Changement de secteur d'activité interdit en dehors de l'exercice d'acquisition"
   mkstat=2
  Endif
 Endif

End

#-> Après modif AASBUSD

Subprog AM_AASBUSD(VALEUR)
Variable Char VALEUR()

 If ACTTYPGES=GTAMUNI and GKFR = G_OUI and [M:FAS5]VATYEAFLG=G_OUI : # FQ57624
   GERR=1
   GMESSAGE = mess(651,7773,1) # "Transfert de secteur interdit : Bien ayant déjà subi une régularisation annuelle pour l'exercice"
   mkstat=2 : End
 Endif

 If ( VALEUR <> "" ) Then
  If !clalev([F:SEA])  : Local File SECACT    [SEA]  : Endif  : # secteurs d'activité
  If ACTTYPGES=GTAMUNI
  Read [F:SEA]SEA0=[M:FAS0]CPY;VALEUR
  Else
  Read [F:SEA]SEA0=[M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1);VALEUR
  Endif
  If (fstat) Then
    # Secteur d'activité invalide
    GERR=1 : mkstat = 2 :  GMESSAGE = mess(636,7773,1) :  End
  Endif
  [M:FASM]SACDES = [F:SEA]SACDES : Affzo [M:FASM]SACDES
 Else
  Effzo [M:FASM]SACDES
 Endif

 If ACTTYPGES=GTAMUNI  : #FQ78968
   If VALEUR <> [M:FAS1]AASBUS and VALEUR <> "" and func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA"
     Actzo [M:FASM]LASMFLG
   Else
     [M:FASM]LASMFLG = G_NON : Affzo [M:FASM]LASMFLG : Diszo [M:FASM]LASMFLG
   Endif
 Endif

 #> Critère de sélection si annulation
 If ACTTYPGES=GTAMMAS Call ACTCHGCRIT() From TRCPROCOM : Endif

End

#-> Après modif IASCGUD

Subprog AM_IASCGUD(VALEUR)
Variable Char VALEUR()
 #> Critère de sélection si annulation
 If [M:FASM]CCLTRF=G_OUI : Call ACTCHGCRIT() From TRCPROCOM : Endif

 #> Uniquement en unitaire
 If ACTTYPGES=GTAMUNI
  Local Integer IS_DEPRECIE(G301MAX)
  Call IS_BCO_DEPRECIE([M:OAC0]OBJCPY, [M:OAC0]OBJREF, [L]IS_DEPRECIE) From GLOBIENS
  If IS_DEPRECIE(0)=G_OUI
   GERR=1
   GMESSAGE = mess(406,7773,1) # "Bien déprécié dans la période ou l'exercice courant."
   GMESSAGE+= "\"
   GMESSAGE+= mess(407,7773,1) # "Modification d'U.G.T. impossible"
   mkstat=2
  Endif
 Endif


End

