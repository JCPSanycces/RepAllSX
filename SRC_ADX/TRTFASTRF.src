#-> Contrôle de la validité des affectations analytiques

Subprog C_CCED(VALEUR)
Variable Char    VALEUR()

 #????
 #-1 ---------
 If VALEUR <> ""
  If ( [M:FASM]FCYD <> "" ) Then
    Local Integer I_DIE
    For I_DIE = 1 To [M:FPC]NBDIE : [M:FASM]CCE(I_DIE-1) = [M:FASM]CCED(I_DIE-1) : Next I_DIE
    Call CTRL_TABCCE(VALEUR,[M:FASM]DIE(nolign-1),[M:FASM]FCYD,[M:FASM]MVTDAT) From TRTX3CPT
    If mkstat : GERR = 1 : End : Endif
    ## Action %CNTOBJ
    Call CONTSEL("CCE","!",VALEUR,num$([M:FASM]DIE(nolign-1)),mkstat) From CONTOBJ
    If mkstat : GERR = 1 : End : Endif
  Else
   If !clalev([F:CCE]) : Local File =GTABCPT+"CACCE" [CCE] : Endif
   If !clalev([F:AUZ]) : Local File =GTABCPT+"CAAUZ" [AUZ] : Endif
   If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
   If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif

    #----- Section compatible avec le site/société -----#

   #????
   #Call LECTURE("CCE",VALEUR,num$([M:FASM]AXE(nolign-1))) From CONTOBJ
   Call LECTURE("CCE",VALEUR,num$([M:FASM]DIE(nolign-1))) From CONTOBJ
   If fstat
    GERR=1
    GMESSAGE=mess(35,106,1)
    mkstat=2 : End
   Endif

   # Contrôle société compatible FQ111320
   Call VERSOC([F:CCE]FCY, [M:FASM]CPYP, [F:CCE]FCY, VALEUR) From CFYSUB
   If mkstat : GERR = 1 : End : Endif
  Endif
 Endif
 #-1 ---------
End

