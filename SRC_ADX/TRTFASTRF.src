#**
#* Callback function
#*
#* @param PHY
#* @param PCASE
#* @param PVALUE
#* @param PPHYREF
#* @param PPHYDES1
#* @param PLCTCOD
#* @return CST_ATRUE or CST_AFALSE to stop transfer process
#*!
Funprog  CALLBACK_TRF(PHY, PCASE, PVALUE, PPHYREF, PPHYDES1, PLCTCOD)
Variable Instance PHY Using OBJECT
Value Integer PCASE
Value Integer PVALUE
Value Char PPHYREF()
Value Char PPHYDES1()
Value Char PLCTCOD()

  Local Integer LOK
  Local Integer WTEMP
#End [V]CST_ATRUE # 110028
  Case PCASE
    When 1:
      # Set progress bar
      Call SET_BOITE(TXTPROG, PVALUE) From GESECRAN
    When 2:
      # Increase transfer physical assets number
      NBPHY_TRT += 1

      # Update progress bar
      Local Char MSGPROG(40)

      MSGPROG = PPHYREF + '['+num$(NBPHY_TRT) + ']'
      Call AFF_BOITE(MSGPROG, NBPHY_TRT, LOK) From GESECRAN

      # Set log value columns
      [L]LOK  = fmet CLOG.LOG_INIT_LINE()
      [L]LOK += fmet CLOG.LOG_PUT_INT_COLUMN(1, NBPHY_TRT)
      [L]LOK += fmet CLOG.LOG_PUT_COLUMN(2, PPHYREF)
      [L]LOK += fmet CLOG.LOG_PUT_COLUMN(3, PPHYDES1)
      [L]LOK += fmet CLOG.LOG_PUT_COLUMN(4, PLCTCOD)
      [L]LOK += fmet CLOG.LOG_WRITE([V]CST_AOK)
    When Default:
  Endcase

  # Write error messages
  # (CLOG is global variable)
  Call LOG_WRITE_AERROR_STACK(PHY, CLOG, WTEMP, NBPHY_WAR, NBPHY_ERR, NBPHY_ERR) From FXDLOG_CSTD

End [V]CST_ATRUE


#**
#* Callback function
#*
#* @param PHY
#* @param PCASE
#* @param PVALUE
#* @param PPHYREF
#* @param PPHYDES1
#* @param PLCTCOD
#* @return CST_ATRUE or CST_AFALSE to stop transfer process
#*!
Funprog  CALLBACK_CNL_TRF(PHY, PCASE, PVALUE, PPHYREF, PPHYDES1, PLCTCOD)
Variable Instance PHY Using OBJECT
Value Integer PCASE
Value Integer PVALUE
Value Char PPHYREF()
Value Char PPHYDES1()
Value Char PLCTCOD()

  Local Integer LOK
  Local Integer WTEMP
End [V]CST_ATRUE
  Case PCASE
    When 1:
      # Set progress bar
      Call SET_BOITE(TXTPROG, PVALUE) From GESECRAN
    When 2:
      # Increase transfer physical assets number
      NBPHY_TRT += 1

      # Update progress bar
      Local Char MSGPROG(40)

      MSGPROG = PPHYREF + '['+num$(NBPHY_TRT) + ']'
      Call AFF_BOITE(MSGPROG, NBPHY_TRT, LOK) From GESECRAN

      # Set log value columns
      [L]LOK  = fmet CLOG.LOG_INIT_LINE()
      [L]LOK += fmet CLOG.LOG_PUT_INT_COLUMN(1, NBPHY_TRT)
      [L]LOK += fmet CLOG.LOG_PUT_COLUMN(2, PPHYREF)
      [L]LOK += fmet CLOG.LOG_PUT_COLUMN(3, PPHYDES1)
      [L]LOK += fmet CLOG.LOG_PUT_COLUMN(4, PLCTCOD)
      [L]LOK += fmet CLOG.LOG_WRITE([V]CST_AOK)
    When Default:
  Endcase

  # Write error messages
  # (CLOG is global variable)
  Call LOG_WRITE_AERROR_STACK(PHY, CLOG, WTEMP, NBPHY_WAR, NBPHY_ERR, NBPHY_ERR) From FXDLOG_CSTD

End [V]CST_ATRUE

