Subprog AV_NBOBJ
 If ACTTYPGES=GTAMMAS
  If [M:MFS0]CMP(nolign-1)=""
   Enable GSTAANU
   Enable 65
   GBOUT1=""
  Else
   Disable GSTAANU
   Disable 65
   GBOUT1=""
  Endif
 Else
  Disable GSTAANU
  Disable 65
  GBOUT1=""
 Endif
End

#-> Avant zone sur la variable de bas de tableau

Subprog C_NBOBJ

  If status=65
   Local Integer NBR_CMP_SUP
   Call SUPPRIME_COMPO([M:MFS0]OBJREF(nolign-1),NBR_CMP_SUP) From SUBMAS
   If NBR_CMP_SUP : Affzo [M:MFS0] : Endif
  Endif

  If status=71 # Si Esc, permet de restaurer les valeurs modifiées du ou des composants
   Gosub RESTAURE_COMPO
  Endif

End

