######################################################################################
# Alimentation du flag indiquant s'il y a des éléments physiques rattachés au bien de la ligne en cours
# Fiche 48468
######################################################################################
Subprog AVANT_NBOBJ
  If GPHY = G_OUI and ACTTYPGES=GTAMMAS Then
    # Recherche s'il y a des éléments physiques rattachés au bien, on ne donne plus accès au site financier
    If func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [M:MFS0]OBJREF(nolign-1) + "'") > 0
      SV_ELTPHYRAT = [V]CST_AYES
    Else
      SV_ELTPHYRAT = [V]CST_ANO
    Endif
  Endif

End


Subprog VERIF_FCY_FROM_CONT_IMP(POBJ, PCLE, PCLE_SUPP, PFCY, PDAT, RTABZON, RTABERR, I_ERR)
Value Char    POBJ        : # Type d'objet
Value Char    PCLE        : # Clé de l'objet
Value Char    PCLE_SUPP   : # Clé secondaire de l'objet (axes analytiques)
Value Char    PFCY        : # Site
Value Char    PDAT        : # Date à contrôler
Variable Char RTABZON()()
Variable Char RTABERR()()
Variable Integer I_ERR

  # FQ95579 : affectation de clesup à 1 si vide
  If PCLE_SUPP = ""
    PCLE_SUPP = "1"
  Endif
  Call CTRL_AUT_OBJ(POBJ, PCLE, PCLE_SUPP, PFCY, date$) From GLOBIENS

  If mkstat Then
    RET=1
    If POBJ="DSP"
      RTABZON(I_ERR)=mess(530,7773,1) # Répartition a priori
    Else
      RTABZON(I_ERR)=mess(338,7773,1)-"n°"-PCLE_SUPP # Axe analytique
    Endif
    RTABERR(I_ERR)=GMESSAGE
    I_ERR+=1

    # On remet GMESSAGE et mkstat à des valeurs nulles pour ne pas déclencher l'ouverture d'une boite
    # de message
    GMESSAGE=""
    mkstat=0
  Endif
End

