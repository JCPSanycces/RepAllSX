 Local Char MASUNI : MASUNI="M"
 Call LAUNCH_ACT(MASUNI)
End
######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION
 If dim(ORIACT)>0 & ORIACT<>""
  #If GUSER="GLE": Infbox "TRTFASTRF ORIACT/ACTION"-ORIACT+"/"+ACTION : Endif
  Case ORIACT
   When "TRTOBJ"
    Case ACTION
     When "LIENS"        : Gosub MFS_LIENS
     When "LIENS2"       : Gosub MFS_LIENS2
     When "INICRE"       : Gosub MFS_MODIF
     When "SEL_LISTE"    : Gosub SEL_LISTE
     #####When "SEL_TABLE"    : Gosub SEL_TABLE
     When Default
    Endcase
   When Default
  Endcase
 Else
  #If GUSER="GBO" & GSERVEUR & dim(GTRACE)>0 : Call ECR_TRACE(ACTION,0) From GESECRAN : Endif
  #If GUSER="GBO" : Infbox ACTION : Endif
  Case ACTION
   When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
   When "INIT_DIA"     : Gosub INIT_DIA
   When "INIT"         : Gosub INIT
   When "AVANT_PAR"    : Gosub AVANT_PAR
   When "CONTROLE"     : Gosub CONTROLE
   When "OUVRE"        : Gosub OUVRE
   When "DEBUT"        : Gosub DEBUT
   When "AV_CHOIX"     : Gosub AV_CHOIX  # FQ78968
   When "APRES_MODIF"  : Gosub APRES_MODIF
   When "SETBOUT"      : Gosub APPEL_MODELE
   When "AP_CHOIX"     : Gosub APPEL_MODELE
   When "BOUTON"       : Gosub BOUTON
   When "END"          : Gosub APPEL_MODELE
   When "OK"           : Gosub OK # Fiche 48468
   When "ABA"          : Gosub ABA
   When "EXEC"         : Gosub APPEL_MODELE
   When "FIN"          : Gosub APPEL_MODELE
   When "TERMINE"      : Gosub APPEL_MODELE
   When "SORTIE"       : Gosub APPEL_MODELE
   When "SEL_LISTE"    : Gosub SEL_LISTE
   When "IMP_MVT"      : Gosub IMP_MVT
   When Default
  Endcase
 Endif
Return

######################################################################
# Actions de l'objet "Contrôler"
######################################################################

#=====================================================================
$MFS_LIENS               # (Unitaire et Massif) - Action de l'objet de visu / contrôle
 Local Integer I_CCE
 Local Char    NOMAXE
 For I_CCE=1 To GOPTCANA
  If evalue("dim([M:MFS0]CCE"+num$(I_CCE)+")>0")
   NOMAXE="[M:MFS0]CCE"+num$(I_CCE)+"(nolign-1)"
   Assign NOMAXE With evalue("[F:MFS]CCE(I_CCE-1)")
   NOMAXE="[M:MFS0]CCE"+num$(I_CCE)+"O"+"(nolign-1)"
   Assign NOMAXE With evalue("[F:MFS]CCEO(I_CCE-1)")

   If [M:MFS0]DSP(nolign-1)<>""
     Grizo ="[M:MFS0]CCE"+num$(I_CCE)+"(nolign-1)"
   Endif
  Endif
 Next I_CCE

Return

#=====================================================================
MFS_LIENS2
 Sorta [M:MFS0]NBOBJ [M:MFS0]NBOBJ Order By [M:MFS0]CMP1([S]indice),[M:MFS0]CMP([S]indice)
Return

#=====================================================================
$MFS_MODIF
 Local Integer I_CCE
 Local Char    NOMAXE

 #????
 #For I_CCE=1 To GOPTCANA
 For I_CCE=1 To [M:FPC]NBDIE
  If evalue("dim([M:MFS0]CCE"+num$(I_CCE)+")>0")
   [F:MFS]CCE(I_CCE-1)=evalue("[M:MFS0]CCE"+num$(I_CCE)+"(nolign-1)")
  Endif
  # SEGAY le 16/07/08 on remet l'origine des axes qui ont été réinitialisés
  # Fiche 48468
  If evalue("dim([M:MFS0]CCE"+num$(I_CCE)+"O"+")>0")
   [F:MFS]CCEO(I_CCE-1)=evalue("[M:MFS0]CCE"+num$(I_CCE)+"O"+"(nolign-1)")
  Endif
 Next I_CCE
Return

######################################################################
# Actions de l'action FASTRF
######################################################################

$CONTROLE

    # CBO 20110907 exigence 69691 ajout pour import des mvts
    If dim(GFXDNBERR) >= 0

        # ne pas continuer si erreur lors de l'alim des champs
        If GFXDERRALCHP
            FIN = 1
            GERR = 1
            Setmode
            Return
        Endif

        Local Integer SV_ERR_TRACE
        Default Mask [M:FASM]

        GIMPORT = 1 # permet de ne pas afficher à l'écran les messages d'erreur
        SV_ERR_TRACE = GERRTRACE

        Call SAIMSK("", "IMP_MVT", "TRTFASTRF") From W0FASTRFP
        If SV_ERR_TRACE = GERRTRACE
            Call CTLVARMODE(GFXDNBERR) From FXDINT
        Endif
        GIMPORT = 0
        # setmode final
        Setmode

        If GFXDERRALCHP or SV_ERR_TRACE <> GERRTRACE
            FIN = 1
            GERR = 1
            # CBO 20120321 FQ10941
            If [F:FXM]DESRJTMVT = ""
                [F:FXM]DESRJTMVT = GMESSAGE
                If [F:FXM]DESRJTMVT = ""
                    [F:FXM]DESRJTMVT = right$(GMESSIMP, 2)
                Endif
            Endif
            Return
        Endif
    Endif

Gosub ACTION From =TRTMODACT

 If FIN = 1 : Return : Endif
Return

#=====================================================================
$OUVRE_BATCH
Return

#=====================================================================
$INIT_DIA                    # (Massif - Saisie des paramètres)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT
 Gosub INIT_WIN_FASTRF From TRTFASTRF    # Fiche 48468-> Initialisation de la fenêtre
Return

#=====================================================================
$INIT                    # (Unitaire et Massif - interactif et exécution batch)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT
 If (GSERVEUR) Then
   Gosub CRT_VARIABLES_GLOBALES
 Endif
Return

#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT

##### Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
##### EXEC - Ouverture manuelle des masques de la fenêtre.
##### Nécessaire jusqu'à ce qu'une modif permette de lancer une action massive avec plus
##### d'un écran de critère.
 Local Char WINACT : WINACT=ACTMETNAM+"M"
 Local Integer I_MSK
 If !clalev([F:AWI]) : Local File AWINDOW : Endif
 If !clalev([F:AMK]) : Local File AMSK    : Endif
 Read [AWI]AWI0=WINACT
 If !fstat
  Local Mask =[F:AWI]MSKENT
  For I_MSK=0 To [F:AWI]NBMSK
    Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
    Local Mask =[F:AMK]CODMSK
  Next I_MSK
 Endif

##### Préparation et lancement de l'action en mode silencieux

 If (ACTSILENCE = G_OUI) Then
   Gosub CRT_VARIABLES_GLOBALES
 Endif

 If ACTSILENCE=G_OUI & TRTFILMSK<>""
  TYPPRG=0
  Gosub INIT_WIN  From TRMPROACT
  Gosub ALIM_MASK From =TRTFILMSK
 Endif

Return

#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)
 If dim(TRTMODACT)<0
  Global Char TRTMODACT
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Endif
 If GPHY = G_OUI Then
     # Declaration des variables gbobales pour éléments physiques(TRTFASTRF)
     Call DEC_GLO_PHY From TRTPHYTOOL
 Endif

 If dim(TRFSELLOC)<0 : Global Char TRFSELLOC(255) : Endif
 Gosub ACTION From =TRTMODACT
 If !(GSERVEUR) Then
   Gosub CRT_VARIABLES_GLOBALES
 Endif
Return

#=====================================================================
$DEBUT # (Massif interactif et Unitaire)
 ############
 # UNITAIRE #
 ############

  If ACTTYPGES=GTAMUNI
    #==> Contrôles pour autoriser ou non l'exécution de l'action en unitaire

    # FQ55485
    # 1 Bien composant ou complémentaire ne peut être transférer que par son principal
    #If ([F:FAS]CMPSTA=GVML_SBCOMPO)
    #  GMESSAGE=mess(285,7773,1)-":"-[F:FAS]CMP
    #  GERR= 1
    #  FIN = 1
    #  Return
    #Endif

# CBO 20111012 exigence 69691 ajout pour import des mvts
# on va venir initialiser ici l'action
$DEB_ITFMVT

    # CBO 20110907 exigence 69691 ajout pour import des mvts
      # secteur d'activite
    If dim(GFXDINT) > 0
        If !clalev ([F:SEA])
            Local File = "SECACT" [SEA]
        Endif
    Endif

    # 2 Bien comptable sorti à une date antérieure à la date de début d'exercice du contexte comptable & fiscal
    If [F:FAS]EXTISSFLG=G_NON & [F:FAS]ISSDAT<>[0/0/0] # Bien sorti
      GMESSAGE= mess(286,7773,1)-":"-mess(60,7773,1)  #"Bien sorti. Transfert interdit"
      GERR= 1
      FIN = 1
      Return
    Endif

    # Le bien a fait l'objet d'un classement pour vente. FQ95754_3
    If ( [F:FAS]SALCLSDAT <> [0/0/0] )
      GMESSAGE = mess(931,GML_MSGFAS,1)
      GERR= 1
      FIN = 1
      Return
    Endif

    # 3 Bien comptable dont type de détention : "En modèle"
    If [F:FAS]OWNTYP=GVML_TDMODEL
      GMESSAGE = mess(61,7773,1)-":"-mess(GVML_TDMODEL,371,1)-"."-mess(60,7773,1) # "Type de détention en modèle : Transfert interdit"
      GERR= 1
      FIN = 1
      Return
    Endif

    # 4 Principal mais un des composants ou complémentaires est déjà utilisé

    If [F:FAS]CMPSTA=GVML_SBPRINC
      If func TRCPROCOM.IS_COMPO_DISPO([F:FAS]CPY,[F:FAS]AASREF)=G_NON
        GMESSAGE = mess(343,7773,1)-":"-mess(60,7773,1) # "L'un des composants ou complémentaires de ce bien est en cours d'utilisation"
        GERR= 1
        FIN = 1
        Return
      Endif
    Endif
    # contrôle si on a le droit de faire un transfert si des éléments physiques sont en attente de mouvement
    If GPHY = G_OUI Then
      # Issue 110656
#      Local Char WPHYREF(GLONPHY)
#      If func PHYELT_C_MPR._GET_SELECTED_MVT_PHY_NBR("AASREF = '" + [F:FAS]AASREF + "'") > 1
#        GMESSAGE = mess(38,7775,1)
#        GERR= 1
#        FIN = 1
#        mkstat=2
#        Return
#      Endif

      # fin 49517 : transfert site financier

      Local Integer WNBR_MVT

      Local Char WLCTCOD(GLONLCT), WFCY(GLONFCY)
      WNBR_MVT = func PHYELT_C_MPR._GET_INFOS_IDENTICAL_MVT_TRF("AASREF = '" + [F:FAS]AASREF + "'", WLCTCOD, WFCY)
      If WNBR_MVT < 0
        GMESSAGE = mess(230, 7775, 1)
        GERR= 1
        FIN = 1
        mkstat=2
        Return
      Endif
      # End Issue 110656

    Endif
  Endif

 ######################
 # MASSIF ET UNITAIRE #
 ######################

 Gosub ACTION From =TRTMODACT

 # FQ60744 : mise en commentaire du If !GBATCH et du setmok qui est déjà fait à la fin de INIT_WIN_FASTRF
 #If !GBATCH
  Gosub INIT_WIN_FASTRF From TRTFASTRF    # Fiche 48468-> Initialisation de la fenêtre
 #Endif
 #Setmok [M:FASM] With 0

 If ACTSILENCE=G_OUI & TRTFILMSK<>""
  TYPPRG=0
  Gosub ALIM_MASK From =TRTFILMSK
 Endif

Return

#=====================================================================
$AV_CHOIX
     # FQ78968
  If ACTTYPGES=GTAMUNI
    If func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) <> "FRA" or [M:FASM]AASBUSD = ""
       [M:FASM]LASMFLG = G_NON : Affzo [M:FASM]LASMFLG : Diszo [M:FASM]LASMFLG
    Endif
  Endif
Return

#=====================================================================
# FQ99720
$BOUTON        # (Massif interactif et Unitaire)

  If BOUT = "D" # controler
    If ACTTYPGES = GTAMMAS
      Gosub SET_CRITACT_CPLTE From TRTFASTRF2
    Else
      If [M:FASM]CCLTRF = G_OUI
        CRITACT = "TRFDAT = [M:FASM]MVTDAT"
      Endif
    Endif
  Endif

  Gosub APPEL_MODELE
Return

#=====================================================================
#$BOUTON_OLD             # (Massif interactif et Unitaire)
 Case [M:FASM]CCLTRF
  When G_OUI
   # FQ55485
   If ACTTYPGES=GTAMMAS
     CRITACT="CMPSTA<>GVML_SBCOMPO & TRFDAT=[M:FASM]MVTDAT"
   Else
     CRITACT="TRFDAT=[M:FASM]MVTDAT"
   Endif
  When G_NON
   # FQ55485
   If ACTTYPGES=GTAMMAS
     #Fq-78581 CRITACT="CMPSTA<>GVML_SBCOMPO "
     CRITACT="CMPSTA<>GVML_SBCOMPO & ISSDAT=[0/0/0]"
   Endif
 Endcase
 Gosub APPEL_MODELE
Return

#=====================================================================
$APRES_MODIF             # (Massif interactif et Unitaire)
 Case COUZON
  When "FLGCPY"
   Local Integer VALCPYFLG
   Case val(CZ)
    When G_OUI
     VALCPYFLG=1
     [M:FASM]CPYP=func TRMPROACT.GET_SOCSEL(COUIND+1,G_OUI)
     # FQ78968
     If func GLOFCYCPY.GET_SOC_LEG([M:FASM]CPYP) = "FRA"
       Actzo [M:FASM]LASMFLG
     Else
       [M:FASM]LASMFLG = G_NON : Affzo [M:FASM]LASMFLG : Diszo [M:FASM]LASMFLG
     Endif
    When G_NON
     VALCPYFLG=0
     [M:FASM]CPYP=func TRMPROACT.GET_SOCSEL(COUIND+1,G_NON)
   Endcase
   #TODO
   Call GER_GEO("FCYD",VALCPYFLG,COUIND+1)
   Setmok [M:FASM] With 0

  When "FLGFCY"
     #*Fq-77766 [M:FASM]CPYP=func TRMPROACT.GET_SOCSEL(COUIND+1,G_OUI)
     Local Integer VALFCYFLG  #*Fq-77766

     Case val(CZ)          #*Fq-77766
     When G_OUI            #*Fq-77766
       [M:FASM]CPYP=[M:MHC]FCYCPY(COUIND)
       # FQ78968
       If func GLOFCYCPY.GET_SOC_LEG([M:FASM]CPYP) = "FRA"
         Actzo [M:FASM]LASMFLG
       Else
         [M:FASM]LASMFLG = G_NON : Affzo [M:FASM]LASMFLG : Diszo [M:FASM]LASMFLG
       Endif
     Endcase               #*Fq-77766
   Setmok [M:FASM] With 0
  When Default
 Endcase
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$ABA
 Gosub INIT_WIN_FASTRF From TRTFASTRF    # Fiche 48468-> Initialisation de la fenêtre
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$SEL_LISTE
 Case LISTE
  When "SELGEOTRF"
    If GPHY = G_OUI and SV_ELTPHYRAT = G_OUI and (maskcou <> "FASTRFP" or ACTTYPGES=GTAMUNI)
      Return
    Endif
 Endcase
Return

######################################################################

$ACTMET
  ##Infbox ACTMET
  Gosub ACTMET From TRTFASTRF2
Return


######################################################################
# Points d'entrée objet de reprise
######################################################################

#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================
$LIENS
 If GBOITE="FASTRFR"
  Local Integer I_AXE
  Local Char    AXE
  For I_AXE=1 To [M:FPC]NBDIE
   AXE="[M:MFS0]CCE"+num$(I_AXE)+"(nolign-1)"
   Assign AXE With [F:MFS]CCE(I_AXE-1)
  Next I_AXE
 Endif
Return

################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################
$GESTRACE
 Case TRTYP
  When 1         # Ouverture de la trace
   If ACTSILENCE=G_NON
    If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA] : Endif
    Call OUVRE_TRACE(mess(344,7773,1),1) From TRACEABX3 # "Transfert analytique et / ou géographique"
   Endif
  When 20        # Paramètres de l'action
   If GPHY = G_OUI Then : # FQ51962
     Call ECR_TRACE("",GTRC_PARAM,left$(mess(84,7775,1)+space$(27),27)+":"-mess([M:FASM]ECRPHYATT,1,1),0,1) From TRACEABX3 # Fiche 48468 Ecraser les mouvements en attente
   Endif
   If [M:FASM]CCLTRF=G_NON : Call ECR_TRACE("",GTRC_PARAM,left$(mess(063,7773,1)+space$(27),27)+":"-format$("D:DD[ ]MMMMMMMMMM4Y",[M:FASM]MVTDAT),0,1) From TRACEABX3 : Endif  # Date de transfert
   If [M:FASM]CCLTRF=G_OUI : Call ECR_TRACE("",GTRC_PARAM,left$(mess(332,7773,1)+space$(27),27)+":"-format$("D:DD[ ]MMMMMMMMMM4Y",[M:FASM]MVTDAT),0,1) From TRACEABX3 : Endif  # Date du transfert à
# annuler
   If [M:FASM]CCLTRF=G_NON : Call ECR_TRACE("",GTRC_PARAM,left$(mess(333,7773,1)+space$(27),27)+":"-[M:FASM]REN-"/"-[M:FASM]ZREN,0,1) From TRACEABX3 : Endif                   # Motif du transfert
   Call ECR_TRACE("",GTRC_PARAM,"",0,1) From TRACEABX3
   If [M:FASM]CCLTRF=G_OUI : Call ECR_TRACE("",GTRC_PARAM,"Affectations et/ou imputations destinations du transfert à annuler",0,1) From TRACEABX3 : Endif           # Affectations et/ou imputations
# destinations du transfert à annuler
   If [M:FASM]FCYD   <>""  : Call ECR_TRACE("",GTRC_PARAM,left$(mess(334,7773,1)+space$(27),27) +":"-[M:FASM]FCYD-"/"-[M:FASM]ZFCYD,0,1) From TRACEABX3 : Endif                 # Site financier
   If [M:FASM]AASBUSD<>""  : Call ECR_TRACE("",GTRC_PARAM,left$(mess(336,7773,1)+space$(27),27) +":"-[M:FASM]AASBUSD-"/"-[M:FASM]SACDES,0,1) From TRACEABX3 : Endif           # Secteur d'activité
   If [M:FASM]IASCGUD<>""  : Call ECR_TRACE("",GTRC_PARAM,left$(mess(153,7773,1)+space$(27),27) +":"-[M:FASM]IASCGUD-"/"-[M:FASM]ZIASCGUD,0,1) From TRACEABX3 : Endif           # U.G.T.
   If [M:FASM]DSPD<>""     : Call ECR_TRACE("",GTRC_PARAM,left$(mess(530,7773,1)+space$(27),27)+":"-[M:FASM]DSPD-"/"-[M:FASM]ZDSPD,0,1) From TRACEABX3 : Endif               # Secteur I.A.S. 2
   Local Integer ECRTIT : Raz ECRTIT
   For nolign=1 To [M:FASM]NBLIG
    If [M:FASM]CCED(nolign-1)<>""
     If !ECRTIT            : Call ECR_TRACE("",GTRC_PARAM,mess(337,7773,1),0,1) From TRACEABX3 : Endif # "Imputations analytiques"
     ECRTIT=1
     #????
     Call ECR_TRACE("",GTRC_PARAM,"    "+left$([M:FASM]DIE(nolign-1)+space$(24),24)+":"-[M:FASM]CCED(nolign-1)-[M:FASM]ZCCED(nolign-1),0,1) From TRACEABX3
    Endif
   Next nolign
  When Default
 Endcase
Return
######################################################################
# Fiche 48468
######################################################################
$OK
 # Sauvegarde du dernier transfert TRFDAT de l'écran FAS2
 Local Date WTRFDAT
 If GPHY = G_OUI and ACTTYPGES=GTAMUNI Then
    WTRFDAT = [M:FAS2]TRFDAT
 Endif

  # FQ99720
  If ACTTYPGES = GTAMMAS
    Gosub SET_CRITACT_CPLTE From TRTFASTRF2
  Endif

 Gosub APPEL_MODELE

# FQ55578 : affichage en unitaire d'un message d'erreur fonctionnel. GERR est mis à 1 dans
#           $TMP1_ALIM_MASK de TRTFASTRF2 si [F:TMP1]FLGERR=G_OUI et GMESSAGE est alimenté
#           avec [F:TMP1]MSGERR
 If ACTTYPGES = GTAMUNI and GERR = 1
   FIN = 0 : # pour rester dans la fenêtre
   Return
 Endif


Return

######################################################################
# Sous-pro et routines communes
######################################################################

#===========================================================================
# Blocs appelés par Gosub
#
#   $APPEL_MODELE            Appel du modèle action métier
#   $ALIM_ENR                Routine d'alimentation d'un enr de TMP1
#   $LOAD_TABCCE             Chargement du tableau des axes analytiques dans FASTRFP
#   $INIT_WIN_FASTRF         # Fiche 48468 Initialisation du masque paramètre FASTRFP dans TRFFASTRF2
#   $LOAD_IMPUTATION_BCO     Charge les imputations actuelles du bien dans FASM (paramètres)
#   $LOAD_IMPUTATION_ORIGINE Charge les imputations avant le dernier transfert dans FASM
#   $SET_CPY_DAT             Alimentation des globales contenant les dates société
#   $EVT_TRF                 Routine de génération des événements de transfert
#   $TRF_CLASORI_TO_CLASDES  Transfert des zones analytiques et/ou géo
#
#===========================================================================

#--------------------------------------------------------------#
# Appel du modèle de traitement action métier                  #
#--------------------------------------------------------------#
$APPEL_MODELE

 Gosub ACTION From =TRTMODACT

Return

#--------------------------------------------------------------#
# Alimentation d'un enregistrement de TMP1                     #
#--------------------------------------------------------------#
$ALIM_ENR
  Local Integer I_AXE
  [F:TMP1]TRTNUM  = NUMACT
  [F:TMP1]FLGERR  = G_NON

  If [M:FASM]CCLTRF = G_NON
   If    TABORI="[F:MAS1]"
    [F:TMP1]FLGMOD  = G_OUI
   Elsif TABORI="[F:MAS2]"
    [F:TMP1]FLGMOD  = G_NON
   Endif
  Else
   [F:TMP1]FLGMOD  = G_NON
  Endif
  [F:TMP1]OBJREF  = evalue (TABORI+"AASREF")
  [F:TMP1]AASDES1 = evalue (TABORI+"AASDES1")
  [F:TMP1]CPY     = evalue (TABORI+"CPY")
  [F:TMP1]FCYO    = evalue (TABORI+"FCY")    : [F:TMP1]FCY     = evalue (TABORI+"FCY")
  [F:TMP1]CMPSTA  = evalue (TABORI+"CMPSTA")
  If TABORI="[F:MAS2]"
   [F:TMP1]CMP = evalue (TABORI+"CMP")
   [F:TMP1]CMP1= evalue (TABORI+"CMP")
  Elsif TABORI="[F:MAS1]"
   Raz [F:TMP1]CMP
   [F:TMP1]CMP1= evalue (TABORI+"AASREF")
  Endif
#  [F:TMP1]LOCO    = evalue (TABORI+"LOC")    : [F:TMP1]LOC     = evalue (TABORI+"LOC")
  [F:TMP1]AASBUSO = evalue (TABORI+"AASBUS") : [F:TMP1]AASBUS  = evalue (TABORI+"AASBUS")
  [F:TMP1]IASCGUO = evalue (TABORI+"IASCGU") : [F:TMP1]IASCGU  = evalue (TABORI+"IASCGU")
  [F:TMP1]DSPO    = evalue (TABORI+"DSP")    : [F:TMP1]DSP     = evalue (TABORI+"DSP")
  For I_AXE=1 To GOPTCANA
   [F:TMP1]CCEO(I_AXE-1) = evalue (TABORI+"CCE(I_AXE-1)")
   [F:TMP1]CCE(I_AXE-1)  = evalue (TABORI+"CCE(I_AXE-1)")
   #????
   [F:TMP1]DIE(I_AXE-1)  = evalue (TABORI+"DIE(I_AXE-1)")
  Next I_AXE
  #> Zones nécessaires à la régul de TVA
  Gosub ALIM_ENR_TVA : # FQ94515
Return

# FQ94515
$ALIM_ENR_TVA
  [F:TMP1]GACACN     = evalue (TABORI+"GACACN")
  [F:TMP1]IASACN     = evalue (TABORI+"IASACN")
  [F:TMP1]OWNTYP     = evalue (TABORI+"OWNTYP")
  [F:TMP1]ISSDAT     = evalue (TABORI+"ISSDAT")
  [F:TMP1]EXTISSFLG  = evalue (TABORI+"EXTISSFLG")
  [F:TMP1]VATREGDAT  = evalue (TABORI+"VATREGDAT")
  [F:TMP1]THESLI     = evalue (TABORI+"THESLI")

  [F:TMP1]DEDVATAMT  = evalue (TABORI+"DEDVATAMT")
  [F:TMP1]DEDVATRAT  = evalue (TABORI+"DEDVATRAT")
  [F:TMP1]IVCVATAMT  = evalue (TABORI+"IVCVATAMT")
  [F:TMP1]IVCVATFLG  = evalue (TABORI+"IVCVATFLG")
  [F:TMP1]DEDVATFLG  = evalue (TABORI+"DEDVATFLG")

  [F:TMP1]DEDVATAMTI = evalue (TABORI+"DEDVATAMTI")
  [F:TMP1]DEDVATRATI = evalue (TABORI+"DEDVATRATI")
  [F:TMP1]IVCVATAMTI = evalue (TABORI+"IVCVATAMTI")
  [F:TMP1]IVCVATFLGI = evalue (TABORI+"IVCVATFLGI")
  [F:TMP1]DEDVATFLGI = evalue (TABORI+"DEDVATFLGI")

  [F:TMP1]ASJCOE     = evalue (TABORI+"ASJCOE")
  [F:TMP1]TAXCOE     = evalue (TABORI+"TAXCOE")
  [F:TMP1]TAXCOEFLG  = evalue (TABORI+"TAXCOEFLG")
  [F:TMP1]ADMCOE     = evalue (TABORI+"ADMCOE")
  [F:TMP1]DEDCOE     = evalue (TABORI+"DEDCOE")
  [F:TMP1]ASJCOEF    = evalue (TABORI+"ASJCOEF")
  [F:TMP1]TAXCOEF    = evalue (TABORI+"TAXCOEF")
  [F:TMP1]ADMCOEF    = evalue (TABORI+"ADMCOEF")
  [F:TMP1]DEDCOEF    = evalue (TABORI+"DEDCOEF")
  [F:TMP1]VATRSD     = evalue (TABORI+"VATRSD")
Return

#--------------------------------------------------------------#
# Chargement du tableau des axes analytiques gérés ds          #
# le dossier                                                   #
#--------------------------------------------------------------#
$LOAD_TABCCE

 Local Integer I_AXE
 Raz nolign
 [M:FASM]NBLIG=nolign

Return
#--------------------------------------------------------------#
# Initialisation de la fenêtre paramètre des transferts        #
# analytiques et géographiques                                 #
#--------------------------------------------------------------#
$INIT_WIN_FASTRF
 Local Integer AUZANA
 Local Integer AUZGEO
 Local Char    CPY
 Local Char    FCY
 Local Date    CPYSTRFIY(1..G300MAX)
 Local Date    CPYENDFIY(1..G300MAX)
 Local Date    CPYSTRPER(1..G300MAX)
 Local Date    CPYENDPER(1..G300MAX)
 Local Integer RETOUR
 Local Integer I_CPY
 Local Integer I_CNX
 Local Integer NBR_CPY
 Local Decimal ORIACGETRNOT, ORIIASETRNOT
 Local Integer RCOD
 Local Integer PLAN
 Local Integer IS_CANCELABLE : IS_CANCELABLE=1
 Local Char CRITEFS(255)


 Effzo [M:FASM]

 #--> Chargement des intitulés des axes analytiques gérés par le dossier dans le masque
 #    paramètre de l'action

 Gosub LOAD_TABCCE From TRTFASTRF


 #-> Initialisation de la société servant au filtrage de la liste des sites financiers
# CBO 20110907 exigence 69691 ajout pour import des mvts
# ajout de or dim(GFXDINT) > 0
 If ACTTYPGES=GTAMUNI or dim(GFXDINT) > 0
    [M:FASM]CPYP=[M:FAS0]CPY
 Endif

 #-> Initialisation de la date de transfert et du motif de transfert et du témoin d'annulation
 [M:FASM]CCLTRF=G_NON
 [M:FASM]MVTDAT=date$
# Raz [M:FASM]REN

 # début 49517 (SYMEU) : quand on abandonne après avoir coché Annulation, les zones restaient grisées
 Actzo [M:FASM]MVTDAT
 Actzo [M:FASM]REN
 Actzo [M:FASM]15
 # Si on a des éléments physiques rattachés au bien, on ne propose pas le changement de localisation
 If ACTTYPGES=GTAMUNI & GPHY = G_OUI Then
    Gosub ACTIV_TYPLOC
 Endif
 Actzo [M:FASM]20
 Actzo [M:FASM]25
 Actzo [M:FASM]30
 # fin 49517 (SYMEU) : quand on abandonne après avoir coché Annulation, les zones restaient grisées

  #--> En unitaire chargement des valeurs actuelles du bien comptable courant
      # CBO 20110907 exigence 69691 ajout pour import des mvts
      # ajout de or dim(GFXDINT) > 0

 If ACTTYPGES=GTAMUNI or dim(GFXDINT) > 0
    Gosub LOAD_IMPUTATION_BCO From TRTFASTRF
 Endif
  #-> Activation / désactivation du flag d'annulation en unitaire (toujours modifiable en massif)
 If ACTTYPGES=GTAMUNI Then
  # Annulation impossible s'il n'y a pas eu de transfert
    If [M:FASM]TRFDAT=[0/0/0]
      IS_CANCELABLE=0
    Endif
    # Annulation impossible si le dernier transfert a été réalisé dans un exercice antérieur à l'exercice courant
    # pour tous les contextes gérés dans la société du BCO
    If IS_CANCELABLE Then
      Call GET_CPY_DAT([M:FAS0]CPY,CPYSTRFIY,CPYENDFIY,CPYSTRPER,CPYENDPER,RETOUR) From GLOBIENS
      For I_CNX=1 To G300MAX
        If CPYSTRFIY(I_CNX)<>[0/0/0] & [M:FASM]TRFDAT<CPYSTRFIY(I_CNX)
          IS_CANCELABLE=0
          Break
        Endif
      Next I_CNX
    Endif

  # Annulation impossible si pas d'événement permettant de retrouver la situation antérieur
#    If IS_CANCELABLE Then
#      If func TRTFASTRFHIS.GET_PLN_EVE_TRF([M:FAS0]CPY,[M:FAS0]FCY,[M:FAS0]AASREF,[M:FASM]TRFDAT)
#         IS_CANCELABLE=1
#      Else
#         IS_CANCELABLE=0
#      Endif
#    Endif

  # Annulation impossible si les valeurs d'entrée H.T. ont été modifiées depuis le dernier transfert
    If IS_CANCELABLE Then
      PLAN = func TRTFASTRFHIS.GET_PLN_EVE_TRF([M:FAS0]CPY,[M:FAS0]FCY,[M:FAS0]AASREF,[M:FASM]TRFDAT)
      If PLAN
        Call GET_ETRNOT_ORI([M:FAS0]CPY,PLAN,[M:FAS0]FCY,[M:FAS0]AASREF,[M:FASM]TRFDAT, ORIACGETRNOT, ORIIASETRNOT, RCOD) From TRTFASTRFHIS
        If (([M:FAS1]ACGETRNOT<>ORIACGETRNOT) | ([M:FAS1]IASETRNOT<>ORIIASETRNOT))
          IS_CANCELABLE=0
        Else
          IS_CANCELABLE=1
        Endif
      Else
        IS_CANCELABLE=0
      Endif
    Endif

 # Activation ou grisage de CCLTRF
    If IS_CANCELABLE
      Actzo [M:FASM]CCLTRF
    Else
      Grizo [M:FASM]CCLTRF
    Endif

 # Seul le transfert de localisation est autorisé pour un bien composant FQ55485
  If ([F:FAS]CMPSTA=GVML_SBCOMPO)
    Diszo [M:FASM]FCYD
    Call ACTION_BLOCK (ACB_DISZO, "FASTRFP", "AASBUSD") From GLOBIENS
    Call ACTION_BLOCK (ACB_DISZO, "FASTRFP", "DSPD")    From GLOBIENS
    Call ACTION_BLOCK (ACB_DISZO, "FASTRFP", "NBLIG")   From GLOBIENS
  Endif

 Endif

 # accessible uniquement en chgt de FCYD
# Diszo [M:FASM]LCTCOD # Issue 115092
 #--> Grisage des zones non saisissables en fonction des codes options A(nalytique) et G(éographique)
 If ACTTYPGES=GTAMUNI Then
   CPY=[M:FAS0]CPY
   FCY=[M:FAS0]FCY
   Call GET_AUZ_GEOANA(nomap,GUSER,CPY,FCY,AUZGEO,AUZANA) From TRTFASTRF
 Elsif ACTTYPGES=GTAMMAS
   # En massif, seules les sociétés cochées figurent dans le tableau
   AUZGEO=G_OUI
   AUZANA=G_OUI
 Endif

 If AUZGEO=G_NON
   Grizo [M:FASM]FCYD, LCTCOD
 Endif

 If AUZANA=G_NON
   Grizo [M:FASM]AASBUSD
   Grizo [M:FASM]IASCGUD
   Grizo [M:FASM]DSPD
   Grizo [M:FASM]CCED
 Endif

 # Si on a des éléments physiques rattachés au bien, on ne propose pas le changement de localisation
 If GPHY = G_OUI Then
   # accessible uniquement en chgt de FCYD
   Diszo [M:FASM]LCTCOD # Issue 115092
   If ACTTYPGES=GTAMUNI Then
     Gosub ACTIV_TYPLOC
     Grizo [M:FASM]ECRPHYATT
   Else # traitement massif
   # La combo de localisation multiple est grisée
#     Effzo [M:FASM]TYPLOC : Diszo [M:FASM]TYPLOC
     # Flag aucun élément physique rattaché
     SV_ELTPHYRAT = G_NON
   Endif
 Endif

 # FQ67615_8
 If ( ACTTYPGES=GTAMUNI and find ([M:FAS1]CMPSTA, GVML_SBPOOL, GVML_SBLVA)> 0  and
&     ( func GLOBIENS.GET_NB_LOF_ON_FAS ([M:FAS0]AASREF) > 0  or [M:FAS1]ACGETRNOT = 0 )   ) Then
   # En unitaire - Si le bien est de type POOL ou LVA et ( qu'au moins une dépense rattachée ou qu'il est non valortisé)
   # l'analytique n'est pas modifiable
   Grizo [M:FASM]DSPD
   Grizo [M:FASM]CCED
 Endif

 #--> Réaffichage du masque paramètre et positionnement à non valide pour forcer tous les contrôles
 Affzo  [M:FASM]
 Setmok [M:FASM] With 0

Return

#--------------------------------------------------------------------------------------------------#
# Fiche 48468
# GPHY = G_OUI
# S'il y a des éléments physiques rattachés au bien, on ne donne plus accès au site financier
#--------------------------------------------------------------------------------------------------#
$ACTIV_TYPLOC
#
# # Recherche s'il y a des éléments physiques rattachés au bien, on ne donne plus accès au site financier
#
  If func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [F:FAS]AASREF + "'") > 0
    SV_ELTPHYRAT = [V]CST_AYES
  Else
    SV_ELTPHYRAT = [V]CST_ANO
    Grizo [M:FASM]LCTCOD
  Endif
Return

#--------------------------------------------------------------#
# Chargement des imputations actuelles du BCO dans le masque   #
# de paramètre de la fonction de transfert - utilisée en unita.#
#--------------------------------------------------------------#
$LOAD_IMPUTATION_BCO
 [M:FASM]FCYD     = [M:FAS0]FCY
 If GPHY = G_OUI  # Issue 115092
  [M:FASM]LCTCOD = ""
 Endif
 ####[M:FASM]LOCD     = [M:FAS2]LOC
  # FQ54202
 [M:FASM]MVTDAT   = date$
 [M:FASM]AASBUSD  = [M:FAS1]AASBUS
 Read [F:SEA]SEA0=[M:FAS0]CPY;[M:FASM]AASBUSD
 [M:FASM]SACDES = [F:SEA]SACDES : Affzo [M:FASM]SACDES

 [M:FASM]IASCGUD  = [M:FAS2]IASCGU
 [M:FASM]TRFDAT   = [M:FAS2]TRFDAT
 [M:FASM]DSPD     = [M:FAS2]DSP

 #????
 # For nolign=1 To GOPTCANA
 #  [M:FASM]CCED(nolign-1) = [M:FAS2]CCE(nolign-1)
 # Next nolign
 Local Integer I_DIE
 Raz nolign
 For I_DIE=1 To [M:FPC]NBDIE
  nolign+=1
  [M:FASM]DIE(nolign-1)   = [M:FAS2]DIE(I_DIE-1)
  [M:FASM]CCED(nolign-1)  = [M:FAS2]CCE(I_DIE-1)
 Next I_DIE
 [M:FASM]NBLIG=nolign
 # FQyyyyyy interdit si composant
 If GPHY = G_OUI & ACTTYPGES=GTAMUNI and [M:FAS1]CMPSTA <> 3 Then

    Local Date DATE_ELT_PHY
    Local Integer WMVT
    Local Char WPHYREF(GLONPHY), WFCY(GLONFCY), WLCTCOD(GLONLCT), WREN(30)
    If func PHYELT_C_MPR._GET_INFO_PHY_WITH_TRF_MVT([M:FAS0]AASREF, 0,
&          WPHYREF, [M:FASM]MVTDAT, [M:FASM]FCYD, [M:FASM]LCTCOD, [M:FASM]REN, WMVT)

      If WMVT = [V]CST_PMVAGEO
        [M:FASM]CCLTRF = [V]CST_AYES
      Endif
#      Call AM_CCLTRF([M:FASM]CCLTRF) From TRTFASTRF
      Gosub ACTIV_TYPLOC
    Endif

    If ([M:FASM]TRFDAT>[M:FAS2]TRFDAT) and func TRTFASTRFHIS.GET_PLN_EVE_TRF([M:FAS0]CPY,[M:FAS0]FCY,[M:FAS0]AASREF,[M:FASM]TRFDAT)=0
      [M:FASM]TRFDAT=[M:FAS2]TRFDAT
    Endif
 Endif
 Affzo [M:FASM]
Return

#--------------------------------------------------------------#
# Chargement des imputations du BCO avant le dernier transfert #
# analytique et géographique. Les infos sont récupérées sur    #
# l'événement de transfert.                                    #
#--------------------------------------------------------------#
$LOAD_IMPUTATION_ORIGINE
 Local Integer  I_AXE
 Local Char     FCYORI
 Local Char     LOCORI
 Local Char     AASBUSORI
 Local Char     IASCGUORI
 Local Char     DSPORI
 Local Char     CCETABORI(15)(GOPTCANA)
 Local Date     TRFDATORI
 Local Decimal  PCGDEVORI
 Local Decimal  IASDEVORI
 Local Decimal  DEDVATRAT
 Local Decimal  DEDVATRATI
 Local Shortint TRFTYP : # FQ57840
 Local Decimal  IVCVATAMT # FQ78968 (1)
 Local Integer  IVCVATFLG
 Local Decimal  IVCVATAMTI
 Local Integer  IVCVATFLGI
 Local Decimal  TAXCOEORI
 Local Decimal  TAXCOEFORI
 Local Decimal  REGULPCGORI
 Local Decimal  REGULIASORI
 Local Date     VATREGDATORI

 Local Integer  RETOUR

 # Récupération des imputations d'origine du bien
  # FQ57840 FQ78968 (1)
  Call GET_IMPUT_GEOANA_ORI([M:FAS0]CPY,[M:FAS0]FCY,[M:FAS0]AASREF,[M:FASM]TRFDAT,
&                           FCYORI,AASBUSORI,IASCGUORI,DSPORI,
&                           CCETABORI,TRFDATORI,
&                           PCGDEVORI,IASDEVORI,DEDVATRAT,DEDVATRATI,TRFTYP,
&                           IVCVATAMT,IVCVATFLG,IVCVATAMTI,IVCVATFLGI,
&                           TAXCOEORI,TAXCOEFORI,REGULPCGORI,REGULIASORI,VATREGDATORI,RETOUR) From TRTFASTRFHIS

 [M:FASM]FCYD    = FCYORI
 If GPHY = G_OUI # Issue 115092
  [M:FASM]LCTCOD  = ""
 Endif

 # Transfert site financier : quand on a une annulation de transfert en attente, si on
 # décoche l'annulation puis si on la recoche, les infos de transfert en attente n'étaient pas reprises
 # Alimentation des imputations par les éléments physiques en attente
 If GPHY = G_OUI & ACTTYPGES=GTAMUNI Then
    Local Char WPHY(GLONPHY)
    Local Date WTRFDAT
    Local Integer WMVT,WMVTR, WI

    If VALEUR = [V]CST_AYES
      WMVT = [V]CST_PMVAGEO
    Else
      WMVT = [V]CST_PMVGEO
    Endif

   WI = func PHYELT_C_MPR._GET_INFO_PHY_WITH_TRF_MVT([F:FAS]AASREF, WMVT,
&          WPHY, WTRFDAT, [M:FASM]FCYD, [M:FASM]LCTCOD, [M:FASM]REN, WMVTR)
 Endif

 # FQ54202
 [M:FASM]MVTDAT  = [M:FASM]TRFDAT
 [M:FASM]AASBUSD = AASBUSORI
 Read [F:SEA]SEA0=[M:FAS0]CPY;[M:FASM]AASBUSD
 [M:FASM]SACDES = [F:SEA]SACDES : Affzo [M:FASM]SACDES

 [M:FASM]IASCGUD = IASCGUORI
 [M:FASM]DSPD    = DSPORI

 Raz nolign
 For I_AXE=1 To GOPTCANA
  [M:FASM]DIE(I_AXE-1)=[M:FPC]DIE(I_AXE-1)
  [M:FASM]CCED(I_AXE-1)=CCETABORI(I_AXE-1)
 Next I_AXE
 [M:FASM]NBLIG=I_AXE-1

 Affzo [M:FASM]

Return

#--------------------------------------------------------------#
# Initialisation des variables contenant les dates de période  #
# et d'exercice des contextes gérés par la société             #
#--------------------------------------------------------------#
$SET_CPY_DAT
 # Création des variables si elles n'existent pas
 If dim(GCPYSTRFIY)<0 : Local Date    GCPYSTRFIY(1..G300MAX) : Endif
 If dim(GCPYENDFIY)<0 : Local Date    GCPYENDFIY(1..G300MAX) : Endif
 If dim(GCPYSTRPER)<0 : Local Date    GCPYSTRPER(1..G300MAX) : Endif
 If dim(GCPYENDPER)<0 : Local Date    GCPYENDPER(1..G300MAX) : Endif
 Local Integer RETOUR
 # Appel du sous-pro d'alimentation des dates
 Call GET_CPY_DAT(TRC_CPY,GCPYSTRFIY,GCPYENDFIY,GCPYSTRPER,GCPYENDPER,RETOUR) From GLOBIENS
Return

#--------------------------------------------------------------#
# Traitement de régularisation de TVA. Appelé en mise à jour   #
# directe pour chaque BCO ou en report table temporaire vers   #
# FXDASSETS si passage par contrôler, ne s'exécute que si      #
# il y a un transfert de secteur d'activité                    #
#--------------------------------------------------------------#
$TRT_REGUL_TVA

  Local Char TABMES(50)(10)

 #> Si le bien a subi un transfert de secteur d'activité, il peut être nécessaire d'effectuer une
 #  régularisation de TVA.

 Local Integer DGBFLG : DBGFLG=0

  Call REGUL_TVA_TRANSFERT_SECTEUR ( CLASDES, TRFDAT, [M:FASM]LASMFLG, G_REGUL, G_REGULI, G_FORM, G_FORMI, PCGDEV, IASDEV,  RETOUR ) From TRTFAS

  #> Information de débug
  If DBGFLG & ACTTYPGES=GTAMUNI
   TABMES(1)="Retour du s/p   :"-num$(RETOUR)
   TABMES(2)="Base PCG PCGDEV :"-num$(PCGDEV)
   TABMES(3)="Base PCG IASDEV :"-num$(IASDEV)
   Infbox TABMES
  Endif

Return

#--------------------------------------------------------------#
# Traitements par plan d'amortissement :                       #
#   - Création ou annulation des événements                    #
#   - Mise à jour de DEPREC si régul de TVA ou annul de régul  #
#--------------------------------------------------------------#
$TRAITE_PLAN
 Local Char    EVTINT          # Code interne de l'événement à générer
 Local Decimal MNTREGDOT       # Montant de dotation à régulariser
 Local Integer RETOUR          # Code retour des sous-pro appelés
 Local Date    DATTRF          # Date du transfert ou de l'annulation de transfert
 Local Date    FIYENDDAT       # Date de fin de l'exercice durant lequel le BCO est transféré
 Local Date    PERENDDAT       # Date de fin de la période durant laquelle le BCO est transféré
 Local Date    FIYSTRDAT       # Date de début de l'exercice durant lequel le BCO est transféré
 Local Date    PERSTRDAT       # Date de début de la période durant laquelle le BCO est transféré
 Local Integer RERROR          #
 Local Char    LMESSAGE(250)   #
 Local Integer PRET
 Local Decimal LDPRBASO

 Global Char    WFCY(GLONFCY)  #
 Global Char    G_FCYD(GLONFCY) # issue 110515 pour alimenter le site destinataire dans les événements
 Global Integer EVTPRINC       # Type d'événement : G_OUI pour l'événement principal de la période d'effet
                               #                    G_NON pour les événements d'extourne au-delà de la periode d'effet
 Global Char    TIMSTPP        # Timestamp de l'evénement principal stocké sur les événements secondaires

 Global Decimal PSCDPE, PSCEXC, PSCDER, PSCDERRVE, PSCRVETRF, PSCRVACRB # Cumul de comptabilisé antérieur
 # Eléments physiques
 If GPHY=G_OUI Then
##############################


    If ACTTYPGES <> GTAMUNI

      If func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [F:FASD]AASREF + "'") > 0
        SV_ELTPHYRAT = [V]CST_AYES
      Else
        SV_ELTPHYRAT = [V]CST_ANO
      Endif
    Endif
 Endif

 If !clalev([F:CNX])   : Local File CONTEXT  [CNX]  : Endif
 If !clalev([F:DEPT])  : Local File DEPREC   [DEPT] : Endif
 If G_ACTCCN=G_OUI
  If !clalev([F:RPRT]) : Local File CCNRPR  [RPRT] : Endif
 Endif

 G_AASBUSO      = [F:FASO]AASBUS
 G_VATREGDATO   = [F:FASO]VATREGDAT
 G_IVCVATAMTO   = [F:FASO]IVCVATAMT
 G_IVCVATIASO   = [F:FASO]IVCVATAMTI
 G_DEDVATAMTO   = [F:FASO]DEDVATAMT
 G_DEDVATIASO   = [F:FASO]DEDVATAMTI
 G_ASJCOERO     = [F:FASO]ASJCOER
 G_TAXCOERO     = [F:FASO]TAXCOER
 G_ADMCOERO     = [F:FASO]ADMCOER
 G_DEDCOERO     = [F:FASO]DEDCOER
 G_ASJCOEO      = [F:FASO]ASJCOE
 G_TAXCOEO      = [F:FASO]TAXCOE
 G_TAXCOEFLGO   = [F:FASO]TAXCOEFLG
 G_ADMCOEO      = [F:FASO]ADMCOE
 G_DEDCOEO      = [F:FASO]DEDCOE
 G_ASJCOEFO     = [F:FASO]ASJCOEF
 G_TAXCOEFO     = [F:FASO]TAXCOEF
 G_ADMCOEFO     = [F:FASO]ADMCOEF
 G_DEDCOEFO     = [F:FASO]DEDCOEF

  For [CNX]CNX0 Where CPY=[F:FASO]CPY
    # Récupération dates début période et exercice dans laquelle se trouve la date de transfert
    Call GET_DATFIY_DATPER([M:FASM]MVTDAT,[F:FASO]CPY,[F:CNX]CNX,FIYSTRDAT,FIYENDDAT,PERSTRDAT,PERENDDAT,RETOUR) From GLOBIENS

   For [DEPW]DEP0 Where AASREF=[F:FASO]AASREF and CNX=[F:CNX]CNX and PERENDDAT=GCPYENDPER([F:CNX]CNX)
     WDATREF =  [M:FASM]MVTDAT    : # Date de transfert
     If  WDATREF   <= GCPYENDPER([F:CNX]CNX)
       WCPTDATINT = GCPYSTRPER([F:CNX]CNX) : # Date de début de période courante
     Else
       WCPTDATINT = PERSTRDAT              : # Date de début de la période contenant la date de transfert
     Endif

     LDPRBASO = [F:DEPW]BSEVAL

     # Lorsqu'il n'y a pas de tranfert entre sites financiers, le champ FCYD est vide, sinon il contient le
     # site de destination, ce qui permet de distinguer les différents cas de figure.
     If [F:FASO]FCY <> [F:FASD]FCY
       WFCY = [F:FASD]FCY
     Else
       WFCY = ""
     Endif

     #> Mise à jour de DEPREC
     If [F:FASO]FCY <> [F:FASD]FCY
       # Mise à jour des DEPREC avec le site financier destination FQ54202
       Gosub MAJDEPFCYD
     Endif
     Gosub MAJDEPREGTVA

     #> Evénements
     If GOK
       Case ACT_EVT
         When "EVT"
           EVTINT="FASAFF"+num$([F:DEPW]DPRPLN)
           # Création de l'événement de transfert principal.
           # -----------------------------------------------
           # Cet événement correspond à la période courante si la date de mouvement est inférieure
           # ou égale à la date de fin de la période courante, ou à la période qui contient la date de début
           # d'amortissement si la date de de mouvement est strictement supérieure à la date de fin
           # de la période courante.
           Filter [F:DEPT] Where AASREF=[F:DEPW]AASREF and DPRPLN=[F:DEPW]DPRPLN and PERSTRDAT=WCPTDATINT
           Read [F:DEPT] First
           Filter [F:DEPT]

           If !fstat
             EVTPRINC=G_OUI

             # Calcul des cumuls comptabilisés pour alimenter l'événement
             Raz PSCDPE, PSCEXC, PSCDER, PSCDERRVE, PSCRVETRF, PSCRVACRB
             # Les cumuls ne sont à calculer que si le transfert est rétroactif
             If WDATREF < GCPYSTRPER([F:CNX]CNX)
               Gosub GET_CUM_PST
             Endif
             Call GENER_EVE(GVML_OMBIEN,[F:FASO]CPY,[F:FASO]FCY,[F:FASO]AASREF,0,EVTINT,MVTDAT,WCPTDATINT,RETOUR) From GENEVE

             If [F:FASO]AASBUS <> [F:FASD]AASBUS : # FQ69571
               If ([F:DEPW]DPRPLN = G301CPT) Then
                 If clalev([F:HIS])  = 0  : Local File VATHIS [HIS]     : Endif
                 If clalev([F:HFAS]) = 0  : Local File FXDASSETS [HFAS] : Endif
                 # Ecriture dans HISVAT ( PCG )
                 [F:HFAS] = [F:MAS1]
                 G_BASDEV = [F:DEPW]DPRBAS - LDPRBASO
                 Call TVA_ECR_HISTORIQUE (GVML_TRSATRF,G301CPT,LDPRBASO,[F:DEPW]DPRBAS,G_FORM,RETOUR) From TRTFAS
               Endif
               If ([F:DEPW]DPRPLN = G301IAS) Then
                 If clalev([F:HIS])  = 0  : Local File VATHIS [HIS]     : Endif
                 If clalev([F:HFAS]) = 0  : Local File FXDASSETS [HFAS] : Endif
                 # Ecriture dans HISVAT ( PCG )
                 [F:HFAS] = [F:MAS1]
                 G_BASDEV = [F:DEPW]DPRBAS - LDPRBASO
                 Call TVA_ECR_HISTORIQUE (GVML_TRSATRF,G301IAS,LDPRBASO,[F:DEPW]DPRBAS,G_FORMI,RETOUR) From TRTFAS
               Endif
             Endif

             # Recherche / mémorisation du Timestamp de l'événement généré
             If !RETOUR
              Local Char TIMSTPP1(20)
              If !clalev([F:E22]) : Local File EFASAFFAGE [F:E22]  : Endif
              Filter [F:E22] Where CPY=[F:FASO]CPY & FCY=[F:FASO]FCY & REF=[F:FASO]AASREF & EVTDAT=MVTDAT
              Read [F:E22] Last
              TIMSTPP1 = [F:E22]TIMSTP
              Filter [F:E22]
             Endif

             # Création des événement sur le site financier destination
             # --------------------------------------------------------
             # S'il y a transfert de site financier, on va créer un deuxième jeu d'événement pour pouvoir comptabiliser
             # le mouvement sur les deux sites.
             If [F:FASO]FCY <> [F:FASD]FCY Then
               WFCY=[F:FASD]FCY  # Issue 110515
               Call GENER_EVE(GVML_OMBIEN,[F:FASD]CPY,[F:FASD]FCY,[F:FASD]AASREF,0,EVTINT,MVTDAT,WCPTDATINT,RETOUR) From GENEVE
               # Recherche / mémorisation du Timestamp de l'événement généré
               If !RETOUR
                Local Char TIMSTPP2(20)
                If !clalev([F:E22]) : Local File EFASAFFAGE [F:E22]  : Endif
                Filter [F:E22] Where CPY=[F:FASD]CPY & FCY=[F:FASD]FCY & REF=[F:FASD]AASREF & EVTDAT=MVTDAT
                Read [F:E22] Last
                TIMSTPP2 = [F:E22]TIMSTP
                Filter [F:E22]
               Endif
             Endif

             # Création des événements de transfert secondaires.
             # -------------------------------------------------
             # Il peut y avoir des dotations comptabilisées au-delà de la période courante ou de la période contenant
             # la date de début mouvement. Il faut donc créer, pour chaque période portant du comptabilisé,
             # un événement qui permettra la création d'une pièce d'extourne/annulation.
             EVTPRINC=G_NON
             Raz PSCDPE, PSCEXC, PSCDER, PSCDERRVE, PSCRVETRF, PSCRVACRB

             For [F:DEPT] Where AASREF=[F:FASO]AASREF and DPRPLN=[F:DEPW]DPRPLN and FLGPST=G_OUI and PERSTRDAT > WCPTDATINT
               TIMSTPP=TIMSTPP1
               Call GENER_EVE(GVML_OMBIEN,[F:FASO]CPY,[F:FASO]FCY,[F:FASO]AASREF,0,EVTINT,MVTDAT,[F:DEPT]PERSTRDAT,RETOUR) From GENEVE
               # Création des événement sur le site financier destination
               # --------------------------------------------------------
               # S'il y a transfert de site financier, on va créer un deuxième jeu d'événement pour pouvoir comptabiliser
               # le mouvement sur les deux sites.
               If [F:FASO]FCY <> [F:FASD]FCY Then
                 WFCY=[F:FASD]FCY  # Issue 110515
                 TIMSTPP=TIMSTPP2
                 Call GENER_EVE(GVML_OMBIEN,[F:FASD]CPY,[F:FASD]FCY,[F:FASD]AASREF,0,EVTINT,MVTDAT,[F:DEPT]PERSTRDAT,RETOUR) From GENEVE
               Endif
             Next
             Raz TIMSTPP
             If dim(TIMSTPP1)>0 : Kill TIMSTPP1 : Endif
             If dim(TIMSTPP2)>0 : Kill TIMSTPP2 : Endif
           Endif
         When "ANN"
           # ------------------------
           # TVA - Pas d'annulation de transfert de secteur d'activité
           # ------------------------
           If !clalev([F:EVT0]) : Local File EFASAFFAGE [EVT0] : Endif
           If !clalev([F:EVT1]) : Local File EFASAFFAGE [EVT1] : Endif
           EVTINT="FASAFF"+num$([F:DEPW]DPRPLN)
           Filter [F:EVT0] Where (CPY=WK_CPY & EVTINT=EVTINT & DPRPLN=[F:DEPW]DPRPLN & REF=WK_AASREF & EVTDAT=WK_TRFDAT & SNSEVE<>GVML_TEAACT)
           For [F:EVT0]EVE0
             If func GENEVE.EXISTE_EXTOURNE_EVE(RETOUR)=G_NON
               EVTDAT=[F:EVT0]EVTDAT
               Call EXTOURNE_EVE(GVML_OMBIEN,WK_CPY,WK_FCY,WK_AASREF,0,EVTINT,EVTDAT,RETOUR) From GENEVE
             Endif
           Next
           Filter [EVT0]
       Endcase
     Endif
   Next : # plan suivant
  Next   : # contexte suivant

  # Transfert des éléments physiques rattachés.
  If GPHY = G_OUI and GOK and SV_ELTPHYRAT = [V]CST_AYES
# Issue X3-32955
#    If (G_MODIF_LOC = G_OUI or [M:FASM]LCTCOD <> "" or ACT_EVT = "ANN" or [F:FASO]FCY <> [F:FASD]FCY) Then
    If (G_MODIF_LOC = G_OUI or [M:FASM]LCTCOD <> "" or [F:FASO]FCY <> [F:FASD]FCY) Then
# End Issue X3-32955

      Local Instance PARAM_TRF  Using C_PHYELTTRF
      PARAM_TRF = NewInstance  C_PHYELTTRF AllocGroup null

      PARAM_TRF.PHY_FILTER = "AASREF = '" + [F:FASD]AASREF + "'"
      PARAM_TRF.TRT_CALLBACK = AVOID.ACHAR

      If ACT_EVT = "ANN"

        If func PHYELT_C_MPR._CNL_TRANSFER_PHYELT_FROM_FAS(PARAM_TRF) = [V]CST_AFALSE
          GMESSAGE = func FXDFCT_SYRA.GET_MAXMSG(PARAM_TRF)
          GOK = 0
          GERR=1
          mkstat=2
          Return
        Endif
      Else

        PARAM_TRF.TRFLCTCOD = [M:FASM]LCTCOD
        PARAM_TRF.TRFDAT = WK_TRFDAT
        PARAM_TRF.TRFTYP = [M:FASM]REN

        If func PHYELT_C_MPR._TRANSFER_PHYELT_FROM_FAS(PARAM_TRF) = [V]CST_AFALSE
          GMESSAGE = func FXDFCT_SYRA.GET_MAXMSG(PARAM_TRF)
          GOK = 0
          GERR=1
          mkstat=2
          Return
        Endif
      Endif
    Endif
  Endif

############################################
############################################
 #> Ajout de la gestion des événements de transfert pour PPR : Concessions FQ54343
 If G_ACTCCN=G_OUI & [F:FASO]OWNTYP=GVML_TDCONCE
  If GOK
   Case ACT_EVT
    When "EVT"
     EVTINT="FASCCNAGE"
     # Création de l'événement de transfert principal.
     # -----------------------------------------------
     # Cet événement correspond à la période courante si la date de mouvement est inférieure
     # ou égale à la date de fin de la période courante, ou à la période qui contient la date de début
     # d'amortissement si la date de de mouvement est strictement supérieure à la date de fin
     # de la période courante.
     Filter [F:RPRT] Where AASREF=[F:DEPW]AASREF and PERSTRDAT=WCPTDATINT
     Read [F:RPRT] First
     Filter [F:RPRT]
     If !fstat
      EVTPRINC=G_OUI
      # Calcul des cumuls comptabilisés pour alimenter l'événement
      #Raz PSCDPE, PSCEXC, PSCDER, PSCDERRVE, PSCRVETRF, PSCRVACRB
      # Les cumuls ne sont à calculer que si le transfert est rétroactif
      If WDATREF < GCPYSTRPER([F:CNX]CNX)
       #Gosub GET_CUM_PPR
      Endif
      Call GENER_EVE(GVML_OMBIEN,[F:FASO]CPY,[F:FASO]FCY,[F:FASO]AASREF,0,EVTINT,MVTDAT,WCPTDATINT,RETOUR) From GENEVE
       # Recherche / mémorisation du Timestamp de l'événement généré
       If !RETOUR
        Local Char TIMSTPP1(20)
        If !clalev([F:E34]) : Local File EFASCCNAGE [F:E34]  : Endif
        Filter [F:E34] Where CPY=[F:FASO]CPY & FCY=[F:FASO]FCY & REF=[F:FASO]AASREF & EVTDAT=MVTDAT
        Read [F:E34] Last
        TIMSTPP1 = [F:E34]TIMSTP
        Filter [F:E34]
       Endif
       # Création des événement sur le site financier destination
       # --------------------------------------------------------
       # S'il y a transfert de site financier, on va créer un deuxième jeu d'événement pour pouvoir comptabiliser
       # le mouvement sur les deux sites.
       If [F:FASO]FCY <> [F:FASD]FCY Then
        WFCY=[F:FASD]FCY  # Issue 110515
        Call GENER_EVE(GVML_OMBIEN,[F:FASD]CPY,[F:FASD]FCY,[F:FASD]AASREF,0,EVTINT,MVTDAT,WCPTDATINT,RETOUR) From GENEVE
        # Recherche / mémorisation du Timestamp de l'événement généré
        If !RETOUR
         Local Char TIMSTPP2(20)
         If !clalev([F:E34]) : Local File EFASCCNAGE [F:E34]  : Endif
         Filter [F:E34] Where CPY=[F:FASD]CPY & FCY=[F:FASD]FCY & REF=[F:FASD]AASREF & EVTDAT=MVTDAT
         Read [F:E34] Last
         TIMSTPP2 = [F:E34]TIMSTP
         Filter [F:E34]
        Endif
       Endif
       # Création des événements de transfert secondaires.
       # -------------------------------------------------
       # Il peut y avoir des dotations comptabilisées au-delà de la période courante ou de la période contenant
       # la date de début mouvement. Il faut donc créer, pour chaque période portant du comptabilisé,
       # un événement qui permettra la création d'une pièce d'extourne/annulation.
       EVTPRINC=G_NON
      #Raz PSCDPE, PSCEXC, PSCDER, PSCDERRVE, PSCRVETRF, PSCRVACRB : # FQ48320
       For [F:RPRT] Where AASREF=[F:FASO]AASREF and FLGPST=G_OUI and PERSTRDAT > WCPTDATINT
        TIMSTPP=TIMSTPP1
        Call GENER_EVE(GVML_OMBIEN,[F:FASO]CPY,[F:FASO]FCY,[F:FASO]AASREF,0,EVTINT,MVTDAT,[F:RPRT]PERSTRDAT,RETOUR) From GENEVE
        # Création des événement sur le site financier destination
        # --------------------------------------------------------
        # S'il y a transfert de site financier, on va créer un deuxième jeu d'événement pour pouvoir comptabiliser
        # le mouvement sur les deux sites.
        If [F:FASO]FCY <> [F:FASD]FCY Then
         WFCY=[F:FASD]FCY  # Issue 110515
         TIMSTPP=TIMSTPP2
         Call GENER_EVE(GVML_OMBIEN,[F:FASD]CPY,[F:FASD]FCY,[F:FASD]AASREF,0,EVTINT,MVTDAT,[F:RPRT]PERSTRDAT,RETOUR) From GENEVE
        Endif
       Next
       Raz TIMSTPP : Kill TIMSTPP1 : If dim(TIMSTPP2)>0 : Kill TIMSTPP2 : Endif
     Endif

    When "ANN"

   Endcase
  Endif
 Endif
############################################
############################################

Return

#--------------------------------------------------------------# FQ54202
# Mise à jour des enregistrements DEPREC avec le site          #
# destination à partir de la date WCPTDATINT                   #
#--------------------------------------------------------------#
$MAJDEPFCYD
 For [F:DEPT] Where AASREF=[F:DEPW]AASREF and DPRPLN=[F:DEPW]DPRPLN and PERSTRDAT>=WCPTDATINT
   [F:DEPT]FCY = [F:FASD]FCY
   Rewrite [F:DEPT]
   If fstat
    GOK=0
   Endif
 Next
Return

#--------------------------------------------------------------#
# Traitement de régularisation de TVA. Appelé une fois par plan#
# d'amortissement géré. Permet de recalculer les valeurs bilan #
# servant de base à l'amortissement.                           #
# Le traitement ne s'exécute que si PCGDEV et / ou IASDEV sont #
# Différents de 0                                              #
#--------------------------------------------------------------#
$MAJDEPREGTVA

 # Issue 113691 - pas de maj plan subvention si non subventionné et base = 0
 If [F:DEPW]DPRPLN=G301SUB and [F:DEPW]DPRBAS = 0  and [F:FASO]INVPLN = ""
   Return
 Endif
 If (([F:FASO]DEDVATAMT<>[F:FASD]DEDVATAMT) | ([F:FASO]DEDVATAMTI<>[F:FASD]DEDVATAMTI))
  Call MAJREGTVA("FASD","DEPW",RETOUR) From TRTFASTRF
  If !RETOUR
   [F:DEPW]DEPSTA=GVML_SCNOCAL
   WK_NOMZON = CLASDES+"FLGCNXCLC([F:DEPW]CNX-1)" : Assign WK_NOMZON With G_OUI

   Rewrite [DEPW]
   If fstat
    GOK=0
   Else
   Endif
  Endif
 Endif
Return

#####################################################################
# Récupération des cumuls comptabilisé entre deux périodes
$GET_CUM_PST
  Raz PSCDPE, PSCEXC, PSCDER, PSCDERRVE, PSCRVETRF, PSCRVACRB
  If !clalev([F:DEPX]) : Local File DEPREC [DEPX] : Endif

  For [DEPX] Where AASREF=[F:DEPT]AASREF and DPRPLN=[F:DEPT]DPRPLN and FIYSTRDAT=[F:DEPT]FIYSTRDAT and PERSTRDAT>=[L]PERSTRDAT and PERSTRDAT<WCPTDATINT
    PSCDPE    += [F:DEPX]PSTDPE
    PSCEXC    += [F:DEPX]PSTEXC
    PSCDER    += [F:DEPX]PSTDER
    PSCDERRVE += [F:DEPX]PSTDERRVE
    PSCRVETRF += [F:DEPX]PSTRVETRF
    PSCRVACRB += [F:DEPX]PSTRVACRB
  Next

  Close File [DEPX]
Return

#---------------------------------------------------------------------
# Transfert des imputations et affectations d'une classe origine     !
# vers une classe destination                                        !
# CLASORI     - Classe contenant les informations à reporter         !
# CLASDES     - Classe à mettre à jour à partir de CLASORI           !
# SUFFIX_ZONE - Suffixe éventuel des noms de champ à transférer      !
#---------------------------------------------------------------------
$TRF_CLASORI_TO_CLASDES
Local Integer USE_PAR_VID2

 Call APPL_ZONE(CLASDES,"FCY",CLASORI,"FCY"+SUFFIX_ZONE,USE_PAR_VIDE,RETOUR) From TRTFASTRF
# Pour les biens sans éléments physiques, on doit pouvoir
# transférer même si site géo et localisation non renseignés dans les paramètres de transfert
# Call APPL_ZONE(CLASDES,"LOC",CLASORI,"LOC"+SUFFIX_ZONE,USE_PAR_VIDE,RETOUR) From TRTFASTRF
 USE_PAR_VID2=G_OUI
 If evalue(CLASORI+"FCY"+SUFFIX_ZONE)="" Then
  USE_PAR_VID2=G_NON
 Endif
 ####Call APPL_ZONE(CLASDES,"LOC",CLASORI,"LOC"+SUFFIX_ZONE,USE_PAR_VID2,RETOUR) From TRTFASTRF
 Call APPL_ZONE(CLASDES,"AASBUS",CLASORI,"AASBUS"+SUFFIX_ZONE,USE_PAR_VIDE,RETOUR) From TRTFASTRF
 Call APPL_ZONE(CLASDES,"IASCGU",CLASORI,"IASCGU"+SUFFIX_ZONE,USE_PAR_VIDE,RETOUR) From TRTFASTRF
 # Les champs "répartition a priori" et "axes analytiques" sont exclusifs. Il faut un traitement spécifique
 # pour déterminer s'il faut transférer ou pas les zones.
 Local Shortint IS_DSP_OR_CCE : IS_DSP_OR_CCE = G_NON : # Y-a-t'il au moins une valorisation DSP ou CCE ?

 If evalue(CLASORI+"DSP"+SUFFIX_ZONE+"<>''") : IS_DSP_OR_CCE = G_OUI : Endif

 For I_AXE=1 To [M:FPC]NBDIE
  If evalue(CLASORI+"CCE"+SUFFIX_ZONE+"(I_AXE-1)<>''") : IS_DSP_OR_CCE = G_OUI : Break : Endif
 Next

 # A ce stade, IS_DSP_OR_CCE vaut G_NON s'il n'y a aucune valorisation analytique Origine, G_OUI sinon.
 If (IS_DSP_OR_CCE = G_NON) | evalue(CLASORI+"DSP"+SUFFIX_ZONE+"<>''")
   Call APPL_ZONE(CLASDES,"DSP",CLASORI,"DSP"+SUFFIX_ZONE,USE_PAR_VIDE,RETOUR) From TRTFASTRF
 Else
   NOMZON=CLASDES+"DSP"
   Assign NOMZON With ""
 Endif
 If (IS_DSP_OR_CCE = G_NON) | evalue(CLASORI+"DSP"+SUFFIX_ZONE+"=''")

  #For I_AXE=1 To GOPTCANA
  For I_AXE=1 To [M:FPC]NBDIE
   If ((USE_PAR_VIDE=G_NON & evalue(CLASORI+"CCE"+SUFFIX_ZONE+"(I_AXE-1)<>''")) | (USE_PAR_VIDE=G_OUI))
    If evalue(CLASDES+"CCE(I_AXE-1)<>"+CLASORI+"CCE"+SUFFIX_ZONE+"(I_AXE-1)")
     NOMZON=CLASDES+"CCE(I_AXE-1)"
     Assign NOMZON With evalue(CLASORI+"CCE"+SUFFIX_ZONE+"(I_AXE-1)")
    Endif
   Endif
  Next I_AXE
 Else
  #????
  #For I_AXE=1 To GOPTCANA
  For I_AXE=1 To [M:FPC]NBDIE
   NOMZON=CLASDES+"CCE(I_AXE-1)"
   Assign NOMZON With ""
  Next I_AXE
 Endif
Return

#---------------------------------------------------------------------
# Contrôle Si les imputations du bien sont inchangées                !
# Dans ce cas la variable IMP_INCH est positionnée à G_OUI sinon elle!
# a la valeur G_NON. Les imputation du BCO sont à prendre dans       !
# CLASORI et les nouvelles imputations dans CLASDES                  !
# La variable USE_PAR_VIDE permet de prendre ou pas en compte des    !
# paramétres de valeur null                                          !
#---------------------------------------------------------------------
$CONTROLE_BCO_IMPUTATIONS_INCHANGEE
 If dim(IMPUT_INCH)<0 : Return : Endif

 Local Char    EXPR_COND1(255)
 Local Char    EXPR_COND2(255)
 Local Integer I_AXE

 IMPUT_INCH=G_OUI
 # On teste la localisation en dernier pour savoir s'il n'y a que la localisation de modifiée pour générer l'évènement que sur les éléments physiques
 If GPHY = G_OUI Then
    G_MODIF_LOC = G_NON
 Endif


 EXPR_COND1 = CLASDES+"FCY"+SUFFDES+"<>"+"''"    : EXPR_COND2 = CLASORI+"FCY"+SUFFORI+"<>"+CLASDES+"FCY"+SUFFDES       : Gosub CONT_INCH
 If IMPUT_INCH=G_NON : Return : Endif
 # Fiche 48468 On teste la localisation en dernier pour savoir s'il n'y a que la localisation de modifiée pour ne générer l'évènement que sur les éléments physiques
# EXPR_COND1 = CLASDES+"LOC"+SUFFDES+"<>"+"''"    : EXPR_COND2 = CLASORI+"LOC"+SUFFORI+"<>"+CLASDES+"LOC"+SUFFDES       : Gosub CONT_INCH
# If IMPUT_INCH=G_NON : Return : Endif
 EXPR_COND1 = CLASDES+"AASBUS"+SUFFDES+"<>"+"''" : EXPR_COND2 = CLASORI+"AASBUS"+SUFFORI+"<>"+CLASDES+"AASBUS"+SUFFDES : Gosub CONT_INCH
 If IMPUT_INCH=G_NON : Return : Endif
 EXPR_COND1 = CLASDES+"IASCGU"+SUFFDES+"<>"+"''" : EXPR_COND2 = CLASORI+"IASCGU"+SUFFORI+"<>"+CLASDES+"IASCGU"+SUFFDES : Gosub CONT_INCH
 If IMPUT_INCH=G_NON : Return : Endif
 EXPR_COND1 = CLASDES+"DSP"+SUFFDES+"<>"+"''"    : EXPR_COND2 = CLASORI+"DSP"+SUFFORI+"<>"+CLASDES+"DSP"+SUFFDES       : Gosub CONT_INCH
 If IMPUT_INCH=G_NON : Return : Endif

 #????
 #For I_AXE=1 To GOPTCANA
 For I_AXE=1 To [M:FPC]NBDIE
  EXPR_COND1 = CLASDES+"CCE"+SUFFDES+"("+num$(I_AXE-1)+")"+"<>"+"''"
  EXPR_COND2 = CLASORI+"CCE"+SUFFORI+"("+num$(I_AXE-1)+")"+"<>"+CLASDES+"CCE"+SUFFDES+"("+num$(I_AXE-1)+")"
  Gosub CONT_INCH
  If IMPUT_INCH=G_NON
   Break
  Endif
 Next I_AXE
 # Fiche 48468
 If IMPUT_INCH=G_NON : Return : Endif
 # On teste la localisation en dernier pour savoir s'il n'y a que la localisation de modifiée, pour ne générer l'événement que sur les éléments physiques
# EXPR_COND1 = CLASDES+"LOC"+SUFFDES+"<>"+"''"    : EXPR_COND2 = CLASORI+"LOC"+SUFFORI+"<>"+CLASDES+"LOC"+SUFFDES       : Gosub CONT_INCH

 If GPHY = G_OUI Then
    If IMPUT_INCH = G_OUI Then
       G_MODIF_LOC = G_NON
    Else
       G_MODIF_LOC = G_OUI
    Endif
 Endif
 If IMPUT_INCH=G_NON : Return : Endif

Return


$CONT_INCH
 If ((USE_PAR_VIDE=G_NON & evalue(EXPR_COND1)) | (USE_PAR_VIDE=G_OUI))
  If evalue(EXPR_COND2)
   IMPUT_INCH=G_NON
   Return
  Endif
 Endif
Return

#---------------------------------------------------------------------
# Contrôles pour savoir si les imputations d'un bien sont modifiées  !
#---------------------------------------------------------------------
$CONTROLE_BCO_IMPUTATIONS_INCHANGEE_MFS

 Local Integer IMPUTINCH
 Local Char WFCY
 Local Char WLOC
 Local Char WAASBUS
 Local Char WIASCGU
 Local Char WDSP
 Local Char WCCE1
 Local Char WCCE2
 Local Char WCCE3
 Local Char WCCE4
 Local Char WCCE5
 Local Char WCCE6
 Local Char WCCE7
 Local Char WCCE8
 Local Char WCCE9
 Local Char NOMZON

 WFCY=[M:MFS0]FCY(nolign-1)
 ####WLOC=[M:MFS0]LOC(nolign-1)
 WAASBUS=[M:MFS0]AASBUS(nolign-1)
 WIASCGU=[M:MFS0]IASCGU(nolign-1)
 WDSP=[M:MFS0]DSP(nolign-1)

 If dim([M:MFS0]CCE1)>0 : WCCE1=[M:MFS0]CCE1(nolign-1) : Endif
 If dim([M:MFS0]CCE2)>0 : WCCE2=[M:MFS0]CCE2(nolign-1) : Endif
 If dim([M:MFS0]CCE3)>0 : WCCE3=[M:MFS0]CCE3(nolign-1) : Endif
 If dim([M:MFS0]CCE4)>0 : WCCE4=[M:MFS0]CCE4(nolign-1) : Endif
 If dim([M:MFS0]CCE5)>0 : WCCE5=[M:MFS0]CCE5(nolign-1) : Endif
 If dim([M:MFS0]CCE6)>0 : WCCE6=[M:MFS0]CCE6(nolign-1) : Endif
 If dim([M:MFS0]CCE7)>0 : WCCE7=[M:MFS0]CCE7(nolign-1) : Endif
 If dim([M:MFS0]CCE8)>0 : WCCE8=[M:MFS0]CCE8(nolign-1) : Endif
 If dim([M:MFS0]CCE9)>0 : WCCE9=[M:MFS0]CCE9(nolign-1) : Endif

 If COUR<>""
  NOMZON="W"+COUR : Assign NOMZON With VALEUR # On alimente la zone courante COUR - Wxxx avec Valeur
 Endif

 IMPUTINCH=G_OUI
 If GPHY = G_OUI Then
    G_MODIF_LOC=G_NON
 Endif

 If WFCY<>[M:MFS0]FCYO(nolign-1)
  IMPUTINCH=G_NON
 Endif
 If IMPUTINCH=G_OUI
 Endif
# Fiche 48468
# On teste le changement de localisation en dernier pour les éléments physiques
# If IMPUTINCH=G_OUI
#  If WLOC<>[M:MFS0]LOCO(nolign-1)       : IMPUTINCH=G_NON : Endif
# Endif
 If IMPUTINCH=G_OUI
  If WAASBUS<>[M:MFS0]AASBUSO(nolign-1) : IMPUTINCH=G_NON : Endif
 Endif
 If IMPUTINCH=G_OUI
  If WIASCGU<>[M:MFS0]IASCGUO(nolign-1) : IMPUTINCH=G_NON : Endif
 Endif
 If IMPUTINCH=G_OUI
  If WDSP<>[M:MFS0]DSPO(nolign-1)       : IMPUTINCH=G_NON : Endif
 Endif

 If IMPUTINCH=G_OUI & dim([M:MFS0]CCE1)>0
  If WCCE1<>[M:MFS0]CCE1O(nolign-1)      : IMPUTINCH=G_NON : Endif
 Endif

 If IMPUTINCH=G_OUI & dim([M:MFS0]CCE2)>0
  If WCCE2<>[M:MFS0]CCE2O(nolign-1)      : IMPUTINCH=G_NON : Endif
 Endif

 If IMPUTINCH=G_OUI & dim([M:MFS0]CCE3)>0
  If WCCE3<>[M:MFS0]CCE3O(nolign-1)      : IMPUTINCH=G_NON : Endif
 Endif

 If IMPUTINCH=G_OUI & dim([M:MFS0]CCE4)>0
  If WCCE4<>[M:MFS0]CCE4O(nolign-1)      : IMPUTINCH=G_NON : Endif
 Endif

 If IMPUTINCH=G_OUI & dim([M:MFS0]CCE5)>0
  If WCCE5<>[M:MFS0]CCE5O(nolign-1)      : IMPUTINCH=G_NON : Endif
 Endif

 If IMPUTINCH=G_OUI & dim([M:MFS0]CCE6)>0
  If WCCE6<>[M:MFS0]CCE6O(nolign-1)      : IMPUTINCH=G_NON : Endif
 Endif

 If IMPUTINCH=G_OUI & dim([M:MFS0]CCE7)>0
  If WCCE7<>[M:MFS0]CCE7O(nolign-1)      : IMPUTINCH=G_NON : Endif
 Endif

 If IMPUTINCH=G_OUI & dim([M:MFS0]CCE8)>0
  If WCCE8<>[M:MFS0]CCE8O(nolign-1)      : IMPUTINCH=G_NON : Endif
 Endif

 If IMPUTINCH=G_OUI & dim([M:MFS0]CCE9)>0
  If WCCE9<>[M:MFS0]CCE9O(nolign-1)      : IMPUTINCH=G_NON : Endif
 Endif

# On arrive par le bouton "Erreur", on alimente TAB_ERR et NB_ERR

If dim(BOUT_ERREUR)>0
 If IMPUTINCH=G_OUI
  NBR_ERREUR+=1
  TAB_ZONERR(NBR_ERREUR-1)=""
  TAB_ERREUR(NBR_ERREUR-1)=mess(387,7773,1) # "Imputations inchangées pour ce bien"
 Endif
Else
 If IMPUTINCH=G_OUI
  [M:MFS0]FLGERR(nolign-1)=G_OUI           : Affzo [M:MFS0]FLGERR(nolign-1)
  [M:MFS0]MSGERR(nolign-1)=mess(387,7773,1) : Affzo [M:MFS0]MSGERR(nolign-1)
 Else
  [M:MFS0]FLGERR(nolign-1)=G_NON           : Affzo [M:MFS0]FLGERR(nolign-1)
  [M:MFS0]MSGERR(nolign-1)=""              : Affzo [M:MFS0]MSGERR(nolign-1)
 Endif

 Gosub AFFICHE_LIGNE
Endif

Return

#---------------------------------------------------------------------
# Contrôle de la cohérence des imputations analytiques et de la      !
# localisation géographique d'un bien comptables. Les éléments d'    !
# imputation et de localisation sont passés en paramétre et le s/p   !
# renvoie un tableau d'erreur, chaque occurrence du tableau          !
# correspondant à une erreur detectée.                               !
#---------------------------------------------------------------------

#-> Contrôles dans l'objet de visu / correction

$CONTROLE_BCO_IMPUTATIONS_MFS
Gosub DECLARE_VAR_CONTROLE

TRFDAT = [M:MFS0]MVTDAT(nolign-1)
CPY    = [M:MFS0]CPY(nolign-1)
FCYO   = [M:MFS0]FCYO(nolign-1) # FQ110722
If COUR="FCY"    : FCY=VALEUR    : Else : FCY    = [M:MFS0]FCY(nolign-1)    : Endif
####If COUR="LOC"    : LOC=VALEUR    : Else : LOC    = [M:MFS0]LOC(nolign-1)    : Endif
If COUR="IASCGU" & (VALEUR <> [M:MFS0]IASCGUO(nolign-1))
 IASCGU=VALEUR
 AASREF=[M:MFS0]OBJREF(nolign-1)
Elsif COUR<>"IASCGU" & ([M:MFS0]IASCGU(nolign-1) <> [M:MFS0]IASCGUO(nolign-1))
 IASCGU = [M:MFS0]IASCGU(nolign-1)
 AASREF = [M:MFS0]OBJREF(nolign-1)
Endif
If COUR="DSP"    : DSP=VALEUR    : Else : DSP    = [M:MFS0]DSP(nolign-1)    : Endif

AASREF =[M:MFS0]OBJREF(nolign-1)
#????
#For I_AXE=1 To GOPTCANA
For I_AXE=1 To [M:FPC]NBDIE
 If evalue("COUR='CCE"+num$(I_AXE)+"'")
  CCE(I_AXE-1) = VALEUR
 Else
  CCE(I_AXE-1) = evalue("[M:MFS0]CCE"+num$(I_AXE)+"(nolign-1)")
 Endif
Next I_AXE

Gosub APPEL_SP_CONTROLE

If dim(BOUT_ERREUR)>0
 Gosub CONTROLE_BCO_IMPUTATIONS_INCHANGEE_MFS
Endif

If NBR_ERREUR>0
 # Si on arrive ici par le choix erreur sur clique droit (Par CONTROLER), on affiche la liste des erreurs
 If dim (BOUT_ERREUR)>0
  Local Char PARAM(30)(1..2)
  Local Char VALEUR
  PARAM(1)=[M:MFS0]OBJREF(nolign-1)
  Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASTRFERR","FASTRFERR",4,"") From GTRAITE
 Endif
 If [M:MFS0]FLGERR(nolign-1)=G_NON
  [M:MFS0]FLGERR(nolign-1)=G_OUI
  [M:MFS0]MSGERR=mess(330,7773,1) # "Erreur d'imputation ou de localisation sur ce bien"
  Affzo [M:MFS0]CPY(nolign-1)
  Affzo [M:MFS0]OBJREF(nolign-1)
  Affzo [M:MFS0]AASDES1(nolign-1)
 Endif
Else
 If [M:MFS0]FLGERR(nolign-1)=G_OUI
  Raz [M:MFS0]MSGERR(nolign-1)
  [M:MFS0]FLGERR(nolign-1)=G_NON
  Affzo [M:MFS0]CPY(nolign-1)
  Affzo [M:MFS0]OBJREF(nolign-1)
  Affzo [M:MFS0]AASDES1(nolign-1)
 Endif
Endif
Kill TAB_ZONERR, TAB_ERREUR, NBR_ERREUR
Return

#-> Contrôle en application des paramétres dans la table temporaire

$CONTROLE_BCO_IMPUTATIONS_TMP
Gosub DECLARE_VAR_CONTROLE
TRFDAT = [F:TMP1]MVTDAT
CPY    = [F:TMP1]CPY
FCY    = [F:TMP1]FCY
FCYO   = [F:TMP1]FCYO # FQ110722
####LOC    = [F:TMP1]LOC
If [F:TMP1]IASCGU<>[F:TMP1]IASCGUO
 IASCGU = [F:TMP1]IASCGU
 AASREF = [F:TMP1]OBJREF
Endif
DSP    = [F:TMP1]DSP
AASREF = [F:TMP1]OBJREF
#????
#For I_AXE=1 To GOPTCANA
For I_AXE=1 To [M:FPC]NBDIE
 CCE(I_AXE-1) = evalue("[F:TMP1]CCE("+num$(I_AXE-1)+")")
Next I_AXE
Gosub APPEL_SP_CONTROLE
If NBR_ERREUR>0
 [F:TMP1]FLGERR=G_OUI
 [F:TMP1]MSGERR=mess(330,7773,1) # "Erreur d'imputation ou de localisation sur ce bien"
Elsif NBR_ERREUR<=0
 If [F:TMP1]FLGERR=G_OUI
  [F:TMP1]FLGERR=G_NON
  Raz [F:TMP1]MSGERR
 Endif
 If [F:TMP1]AASBUS<>[F:TMP1]AASBUSO
  # Régularisation de T.V.A
 Endif
Endif
Kill TAB_ZONERR, TAB_ERREUR, NBR_ERREUR
Return

#-> Contrôle en application des paramétres en mise à jour directe

$CONTROLE_BCO_IMPUTATIONS_DIRT

Gosub DECLARE_VAR_CONTROLE

TRFDAT = evalue (CLASDES+"TRFDAT")
CPY    = evalue (CLASDES+"CPY")
FCY    = evalue (CLASDES+"FCY")
FCYO   = [F:FASO]FCY # FQ110722
####LOC    = evalue (CLASDES+"LOC")
If [F:FASO]IASCGU<>[F:FASD]IASCGU
 IASCGU = [F:FASD]IASCGU
 AASREF = [F:FASD]AASREF
Endif
DSP    = evalue (CLASDES+"DSP")
AASREF = [F:FASD]AASREF
#????
#For I_AXE=1 To GOPTCANA
For I_AXE=1 To [M:FPC]NBDIE
 CCE(I_AXE-1) = evalue(CLASDES+"CCE("+num$(I_AXE-1)+")")
Next I_AXE

Default Mask [M:FASM]
Gosub APPEL_SP_CONTROLE

Return

#-> Appel du sous-programme de contrôle

$APPEL_SP_CONTROLE
# FQ110722 ajout FCYO
 Call CONT_IMPUTATION(TRFDAT, CPY, AASREF, FCYO, FCY, IASCGU,
&                     DSP, CCE, TAB_ZONERR, TAB_ERREUR, NBR_ERREUR, RETOUR) From TRTFASTRF
Return

#-> Déclaration des variables nécessaires à l'appel du sous-programme de contrôle des imputations.

$DECLARE_VAR_CONTROLE
 Local  Date    TRFDAT
 Local  Char    CPY
 Local  Char    AASREF
 Local  Char    FCY(GLONFCY), FCYO(GLONFCY) # FQ110722
# Local  Char    LOC(50)
 Local  Char    IASCGU
 Local  Char    DSP(10)
 Local  Char    CCE(15)(GOPTCANA)
 Local  Integer RETOUR
 Local  Integer I_AXE
 Local  Integer I_ERREUR
 Global Char    TAB_ZONERR(20)(30)
 Global Char    TAB_ERREUR(100)(30)
 Global Integer NBR_ERREUR
Return

#-> Report des modifs du BCO Principal sur les composants

$MAJ_COMPO

 # Le tableau est trié de telle sorte que les composants suivent les principaux
 # [M:MFS0]OBJREF(nolign-1) contient la référence du bien principal
 # COUR contient le nom de la zone à mettre à jour sur le composant

 Local Integer AFF_TOT_MSK : AFF_TOT_MSK=0    # Indicateur pour réafficher la totalité du masque après mise à jour (obsolète)

 Local Integer I_COMPO
 Local Char    NOMZON

 Gosub DECLARE_VAR_CONTROLE

 For I_COMPO=nolign+1 To [M:MFS0]NBOBJ
  If [M:MFS0]CMP(I_COMPO-1)="" : Break : Endif
  If [M:MFS0]CMP(I_COMPO-1)=[M:MFS0]OBJREF(nolign-1)
   If evalue("[M:MFS0]"+COUR+"(I_COMPO-1)<>VALEUR")
    #> Report de la valeur du principal sur le composant
    NOMZON="[M:MFS0]"+COUR+"(I_COMPO-1)"
    Assign NOMZON With VALEUR
    If !AFF_TOT_MSK : Affzo [M:MFS0] =NOMZON : Endif
    #> Contrôle du composant
    TRFDAT = [M:MFS0]MVTDAT(I_COMPO-1)
    CPY    = [M:MFS0]CPY(I_COMPO-1)
    FCY    = [M:MFS0]FCY(I_COMPO-1)
    FCYO   = [M:MFS0]FCYO(I_COMPO-1) # FQ110722
#    LOC    = [M:MFS0]LOC(I_COMPO-1)
    DSP    = [M:MFS0]DSP(I_COMPO-1)
    #???
    AASREF = [M:MFS0]OBJREF(I_COMPO-1) : # FQ82485
    For I_AXE=1 To [M:FPC]NBDIE
     CCE(I_AXE-1) = evalue("[M:MFS0]CCE"+num$(I_AXE)+"(I_COMPO-1)")
    Next I_AXE
    Gosub APPEL_SP_CONTROLE
    If NBR_ERREUR>0
     [M:MFS0]MSGERR(I_COMPO-1)=mess(330,7773,1) # "Erreur d'imputation ou de localisation sur ce bien"
     [M:MFS0]FLGERR(I_COMPO-1)=G_OUI
     If !AFF_TOT_MSK :      Affzo [M:MFS0]CPY(I_COMPO-1)    : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]OBJREF(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]AASDES1(I_COMPO-1): Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]MSGERR(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]FLGERR(I_COMPO-1) : Endif
    Else
     [M:MFS0]MSGERR(I_COMPO-1)=""
     [M:MFS0]FLGERR(I_COMPO-1)=G_NON
     If !AFF_TOT_MSK :      Affzo [M:MFS0]CPY(I_COMPO-1)    : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]OBJREF(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]AASDES1(I_COMPO-1): Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]MSGERR(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]FLGERR(I_COMPO-1) : Endif
    Endif
   Endif
  Endif
 Next I_COMPO
 If AFF_TOT_MSK : Affzo [M:MFS0] : Endif

Return

#-> Restauration des éventuelles modifs effectuées sur les composants

$RESTAURE_COMPO


 Local Integer AFF_TOT_MSK : AFF_TOT_MSK=0
 Local Integer I_COMPO
 Local Integer MODIF_COMPO : MODIF_COMPO=0
 Local Char    NOMZON

 Gosub DECLARE_VAR_CONTROLE

 For I_COMPO=nolign+1 To [M:MFS0]NBOBJ
  If [M:MFS0]CMP(I_COMPO-1)="" : Break : Endif
  If [M:MFS0]CMP(I_COMPO-1)=[M:MFS0]OBJREF(nolign-1)
   If [M:MFS0]FCY(I_COMPO-1)<>[M:MFS0]FCY(nolign-1)
    [M:MFS0]FCY(I_COMPO-1)=[M:MFS0]FCY(nolign-1) : MODIF_COMPO=1
    If !AFF_TOT_MSK : Affzo [M:MFS0]FCY(I_COMPO-1) : Endif
   Endif
#   If [M:MFS0]LOC(I_COMPO-1)<>[M:MFS0]LOC(nolign-1)
#    [M:MFS0]LOC(I_COMPO-1)=[M:MFS0]LOC(nolign-1) : MODIF_COMPO=1
#    If !AFF_TOT_MSK : Affzo [M:MFS0]LOC(I_COMPO-1) : Endif
#   Endif
   If [M:MFS0]AASBUS(I_COMPO-1)<>[M:MFS0]AASBUS(nolign-1)
    [M:MFS0]AASBUS(I_COMPO-1)=[M:MFS0]AASBUS(nolign-1) : MODIF_COMPO=1
    If !AFF_TOT_MSK : Affzo [M:MFS0]AASBUS(I_COMPO-1) : Endif
   Endif
   If [M:MFS0]IASCGU(I_COMPO-1)<>[M:MFS0]IASCGU(nolign-1)
    [M:MFS0]IASCGU(I_COMPO-1)=[M:MFS0]IASCGU(nolign-1) : MODIF_COMPO=1
    If !AFF_TOT_MSK : Affzo [M:MFS0]IASCGU(I_COMPO-1) : Endif
   Endif
   If [M:MFS0]DSP(I_COMPO-1)<>[M:MFS0]DSP(nolign-1)
    [M:MFS0]DSP(I_COMPO-1)=[M:MFS0]DSP(nolign-1) : MODIF_COMPO=1
    If !AFF_TOT_MSK : Affzo [M:MFS0]DSP(I_COMPO-1) : Endif
   Endif

   #????
   #For I_AXE=1 To GOPTCANA
   For I_AXE=1 To [M:FPC]NBDIE
    If evalue("[M:MFS0]CCE"+num$(I_AXE)+"(I_COMPO-1)<>[M:MFS0]CCE"+num$(I_AXE)+"(nolign-1)")
     NOMZON="[M:MFS0]CCE"+num$(I_AXE)+"(I_COMPO-1)"
     Assign NOMZON With evalue("[M:MFS0]CCE"+num$(I_AXE)+"(nolign-1)")
     MODIF_COMPO=1
     If !AFF_TOT_MSK : Affzo [M:MFS0] =NOMZON : Endif
    Endif
   Next I_AXE

   If MODIF_COMPO
    #> Contrôle du composant
    TRFDAT = [M:MFS0]MVTDAT(I_COMPO-1)
    CPY    = [M:MFS0]CPY(I_COMPO-1)
    FCY    = [M:MFS0]FCY(I_COMPO-1)
    FCYO   = [M:MFS0]FCYO(I_COMPO-1)
#    LOC    = [M:MFS0]LOC(I_COMPO-1)
    DSP    = [M:MFS0]DSP(I_COMPO-1)
    AASREF = [M:MFS0]OBJREF(I_COMPO-1) : # FQ82485
    #????
    #For I_AXE=1 To GOPTCANA
    For I_AXE=1 To [M:FPC]NBDIE
     CCE(I_AXE-1) = evalue("[M:MFS0]CCE"+num$(I_AXE)+"(I_COMPO-1)")
    Next I_AXE
    Gosub APPEL_SP_CONTROLE
    If NBR_ERREUR
     [M:MFS0]MSGERR(I_COMPO-1)=mess(330,7773,1) # "Erreur d'imputation ou de localisation sur ce bien"
     [M:MFS0]FLGERR(I_COMPO-1)=G_OUI
     If !AFF_TOT_MSK :      Affzo [M:MFS0]CPY(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]OBJREF(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]AASDES1(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]MSGERR(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]FLGERR(I_COMPO-1) : Endif
    Else
     [M:MFS0]MSGERR(I_COMPO-1)=""
     [M:MFS0]FLGERR(I_COMPO-1)=G_NON
     If !AFF_TOT_MSK :      Affzo [M:MFS0]CPY(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]OBJREF(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]AASDES1(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]MSGERR(I_COMPO-1) : Endif
     If !AFF_TOT_MSK :      Affzo [M:MFS0]FLGERR(I_COMPO-1) : Endif
    Endif
   Endif
  Endif
 Next I_COMPO

 If AFF_TOT_MSK : Affzo [M:MFS0] : Endif

Return

$AFFICHE_LIGNE
 Affzo [M:MFS0]CPY(nolign-1)
 Affzo [M:MFS0]OBJREF(nolign-1)
 Affzo [M:MFS0]AASDES1(nolign-1)
Return


# CBO 20110907 exigence 69691 ajout pour import des mvts

$IMP_MVT
Local Char WWIMPZON

    WWIMPZON = IMPZON

    Case IMPZON
        When "FCYD"
            If WCHAR <> [M:FAS0]FCY
                IMPMOD = 1
            Endif
#FQ100398
        When "LCTCOD"
            If WCHAR <> ""
                IMPMOD = 1
            Endif
#        When "LOCD"
#            If WCHAR <> [M:FAS2]LOC
#                IMPMOD = 1
#            Endif
        When "AASBUSD"
            If WCHAR <> [M:FAS1]AASBUS
                IMPMOD = 1
            Endif
        When "IASCGUD"
            If WCHAR <> [M:FAS2]IASCGU
                IMPMOD = 1
            Endif
# n'existe qu'en V5
#        When "SCT1D"
#            If WCHAR <> [M:FAS2]SCT1
#                IMPMOD = 1
#            Endif
#        When "SCT2D"
#            If WCHAR <> [M:FAS2]SCT2
#                IMPMOD = 1
#            Endif
        When "DSPD"
            If WCHAR <> [M:FAS2]DSP
                IMPMOD = 1
            Endif
        When "CCED"
            If WCHAR <> [M:FAS2]CCE([M]NBLIG - 1)
                IMPMOD = 1
            Endif
            WWIMPZON += "(" + num$([M]NBLIG - 1) + ")"
        When Default
    Endcase

    # si champ ds la liste (et valorisé) : il a forcément été paramétré : donc modifié
    If IMPMOD <> 1
        If find(WWIMPZON, GRUBALIM(1..GNBRUBALIM))
            IMPMOD = 1
        Endif
    Endif

Return
#===========================================================================
# Sous-programme
#
#  GET_AUZ_GEOANA     PAPPLI,PUSER,PCPY,PFCY,AUZGEO,RAUZANA
#  APPL_ZONE          PCLASSE,PZONE,PCLASSEP,PZONEP,RET
#  CONT_IMPUTATION    PCLASSE,RERR,RET
#  ET_COMPTE_RENDU    PCPY
#  BCO_COMPTE_RENDU   PCPY,PREF,PDES,PMES
#
#  LAUNCH_ACT
#
#===========================================================================

#---------------------------------------------------------------------
# Récupération des autorisations par type de transfert géo / ana
#---------------------------------------------------------------------
Subprog GET_AUZ_GEOANA(PAPPLI,PUSER,PCPY,PFCY,RAUZGEO,RAUZANA)
Value    Char    PAPPLI    # Dossier pour lequel on souhaite connaitre les habilitations
Value    Char    PUSER     # Code utilisateur pour lequel on souhaite connaître la valeur des codes options A et G
Value    Char    PCPY      # Société pour laquelle on souhaite connaitre la valeur des codes options A et G
Value    Char    PFCY      # Site pour lequel on souhaite connaitre la valeur des codes options A et G
Variable Integer RAUZGEO   # Valeur du code option G (G_OUI ou G_NON) pour l'utilisateur PUSER dans le dossier PAPPLI
Variable Integer RAUZANA   # Idem pour le code option A

If clalev([F:AUS])=0  : Local File =PAPPLI+".AUTILIS"    [AUS]  : Endif : # Utilisateurs
If clalev([F:AFT])=0  : Local File =PAPPLI+".AFCTFCT"    [AFT]  : Endif : # Habilitations fonctionnelles
If clalev([F:AFP])=0  : Local File =PAPPLI+".AFCTPRF"    [AFP]  : Endif : # Habilitations fonctionnelles
If clalev([F:CPY])=0  : Local File =PAPPLI+".COMPANY"    [CPY]  : Endif : # Sociétés
If clalev([F:AWI])=0  : Local File =PAPPLI+".AWINDOW"    [AWI]  : Endif : # fenêtre
If clalev([F:AMK])=0  : Local File =PAPPLI+".AMSK"       [AMK]  : Endif : # masques
If clalev([F:AMZ])=0  : Local File =PAPPLI+".AMSKZON"    [AMZ]  : Endif : # champs des masques
If clalev([F:FGR])=0  : Local File =PAPPLI+".FACGROUP"   [FGR]  : Endif : # Groupe de société


Local Char PRFFCT                    # Profil fonction associé à l'utilisateur
Local Char SEAFCT : SEAFCT="GESFAS"  # Fonction pour laquelle on charche les valeurs de code option
Local Char OPTANA : OPTANA="A"       # Code de l'option transfert analytique
Local Char OPTGEO : OPTGEO="G"       # Code de l'option transfert géographique

# Initialisation des valeurs de retour

  RAUZGEO = G_OUI
  RAUZANA = G_OUI
  PRFFCT  = GPROFIL

# Recherche si la transaction de saisie bien comptable fait apparaître ou non toutes les zones

  Read [AWI]AWI0=G_TRSSAV
  If fstat = 0
    Local Integer I_MSK
    For I_MSK=0 To [F:AWI]NBMSK-1
      Read [AMK] =[F:AWI]NOMMSK(I_MSK)
      If fstat = 0 and [F:AMK]ABRMSK = "FAS2"
        Local Char NOMMSKFAS2
        NOMMSKFAS2 = [F:AMK]CODMSK

        RAUZANA=G_NON
        Read [AMZ]CODE=NOMMSKFAS2;"AASBUS"
        If fstat = 0 and [F:AMZ]SAIAFF < 3
          RAUZANA = G_OUI
          Break
        Endif
        Read [AMZ]CODE=NOMMSKFAS2;"IASCGU"
        If fstat = 0 and [F:AMZ]SAIAFF < 3
          RAUZANA = G_OUI
          Break
        Endif
        Read [AMZ]CODE=NOMMSKFAS2;"DSP"
        If fstat = 0 and [F:AMZ]SAIAFF < 3
          RAUZANA = G_OUI
          Break
        Endif
        Read [AMZ]CODE=NOMMSKFAS2;"NBRCCE"
        If fstat = 0 and [F:AMZ]SAIAFF < 3
          Read [AMZ]CODE=NOMMSKFAS2;"CCE"
          If fstat = 0 and [F:AMZ]SAIAFF < 3
            RAUZANA = G_OUI
            Break
          Endif
        Endif

        Break
      Endif
    Next I_MSK
  Endif

 # Recherche si le profil autorise toutes fonctions

  Read [AFT]AFT0=PRFFCT
  If !fstat
    If [F:AFT]ALLFCT = G_OUI
      End
    Endif
  Else
    RAUZGEO=G_NON
    RAUZANA=G_NON
  Endif

# Accès à AFP car le profil n'autorise pas toutes les fonctions.
# Premier essai en utilisant la société passée en paramétre

  Read [AFP]AFP0=PRFFCT;SEAFCT;PCPY
  If !fstat
    If pat([F:AFP]OPT,"*"+OPTANA+"*")=0
      RAUZANA=G_NON
   Endif
     If pat([F:AFP]OPT,"*"+OPTGEO+"*")=0
       RAUZGEO=G_NON
     Endif
     End
  Endif

# Deuxième essai en utilisant le site passé en paramétre

  Read [AFP]AFP0=PRFFCT;SEAFCT;PFCY
  If !fstat
    If !pat([F:AFP]OPT,"*"+OPTANA+"*") : RAUZANA=G_NON : Endif
    If !pat([F:AFP]OPT,"*"+OPTGEO+"*") : RAUZGEO=G_NON : Endif
    End
  Endif

# Dernier essai en utilisant blanc dans le regroupement
  Read [AFP]AFP0=PRFFCT;SEAFCT;""
  If !fstat
    If !pat([F:AFP]OPT,"*"+OPTANA+"*") : RAUZANA=G_NON : Endif
    If !pat([F:AFP]OPT,"*"+OPTGEO+"*") : RAUZGEO=G_NON : Endif
    End
  Endif

# Recherche si la société fait partie d'un groupe de société pour lequel l'habilitation est positionné
#Filter [FGR] Where FCY=PFCY : # FQ77906
  For [FGR] Where FCY=PFCY
    Read [AFP]AFP0=PRFFCT;SEAFCT;[F:FGR]CPY
    If !fstat
      If !pat([F:AFP]OPT,"*"+OPTANA+"*") : RAUZANA=G_NON : Endif
      If !pat([F:AFP]OPT,"*"+OPTGEO+"*") : RAUZGEO=G_NON : Endif
      End #CHECK IGNORE_LINE
    Endif
  Next
#Filter [FGR] : # FQ77906

# Recherche infructueuse, on renvoie G_NON pour les deux codes options

  RAUZGEO=G_NON
  RAUZANA=G_NON

End

#---------------------------------------------------------------------
# Application des paramétres à une zone passée en paramètre
#---------------------------------------------------------------------
Subprog APPL_ZONE(PCLASSE,PZONE,PCLASSEP,PZONEP,PPARVIDE,RET)
Value    Char    PCLASSE      # Classe à mettre à jour
Value    Char    PZONE        # Zone à modifier
Value    Char    PCLASSEP     # Classe paramètre
Value    Char    PZONEP       # Zone paramètre
Value    Integer PPARVIDE     # Indique si un paramétre vide doit être pris en compte
Variable Integer RET          # Code retour

Local    Char    NOMZONE

If ((PPARVIDE=G_NON & evalue(PCLASSEP+PZONEP+"<>''")) | (PPARVIDE=G_OUI))
 If evalue(PCLASSE+PZONE+"<>"+PCLASSEP+PZONEP)
  NOMZONE=PCLASSE+PZONE
  Assign NOMZONE With evalue(PCLASSEP+PZONEP)
 Endif
Endif

End
#---------------------------------------------------------------------
# Contrôle des imputations et affectations d'un BCO
#---------------------------------------------------------------------
# FQ110722 ajout PFCYO
Subprog CONT_IMPUTATION(PTRFDAT, PCPY, PAASREF, PFCYO, PFCY, PIASCGU,
&                       PDSP, PCCE, RTABZON, RTABERR, RNBERR, RET)
Value    Date    PTRFDAT
Value    Char    PCPY()
Value    Char    PAASREF()
Value    Char    PFCYO()
Value    Char    PFCY()
Value    Char    PIASCGU
Value    Char    PDSP()
Value    Char    PCCE()
Variable Char    RTABZON()()
Variable Char    RTABERR()()
Variable Integer RNBERR
Variable Integer RET

If !clalev([F:WFCY]) : Local File FACILITY  [WFCY] : Endif
#If !clalev([F:WLOC]) : Local File LOCALIZAT [WLOC] : Endif # FQ100398/17
If !clalev([F:WCPY]) : Local File COMPANY   [WCPY] : Endif
If !clalev([F:WFGR]) : Local File FACGROUP  [WFGR] : Endif

Local Integer  I_ERR

Raz RNBERR
Raz RTABZON
Raz RTABERR
Raz RET
Raz I_ERR

#-> Contrôle de la cohérence des niveaux géographiques

#> Contrôle site financier par rapport à la société

Read [WFCY]FCY0=PFCY
If fstat
 RET=10+fstat
 End
Else
 If [F:WFCY]LEGCPY<>PCPY
  RET=1
  RTABZON(I_ERR)=mess(334,7773,1) #"Site financier"
  RTABERR(I_ERR)=PFCY-"ce site financier a pour société"-[F:WFCY]LEGCPY
  I_ERR+=1
 Endif
Endif


#> Contrôle U.G.T.

If PIASCGU<>""
 Local Integer IS_DEPRECIE(G301MAX)
 Call IS_BCO_DEPRECIE(PCPY, PAASREF, [L]IS_DEPRECIE) From GLOBIENS
 If IS_DEPRECIE(0)=G_OUI
  RET=1
  RTABZON(I_ERR)= mess(153,7773,1)                     # "U.G.T"
  RTABERR(I_ERR)= mess(406,7773,1)+"\"+mess(407,7773,1) # "Bien déprécié dans la période ou l'exercice courant."
  I_ERR+=1                                            # "Modification d'U.G.T. impossible"
 Endif
Endif

#-> Contrôle de la clé de répartition analytique
If PDSP<>""
  If !clalev([DSP]) : Local File =GTABCPT+"CADSP" [DSP] : Endif

  Read [DSP]DSP0 = PDSP;1 : # Lecture de la première ligne
  If fstat
   RET=1
   RTABZON(I_ERR)=mess(530,7773,1)     : # Répartition a priori
   RTABERR(I_ERR)=PDSP-mess(37,106,1) : # Section inexistante
   I_ERR+=1
  Else
    Call VERIF_FCY_FROM_CONT_IMP("DSP",PDSP,"",PFCY,date$,RTABZON,RTABERR,I_ERR)
  Endif
Endif

 If PDSP="" : # FQ60174
  Local Integer I_DIE
  For I_DIE = 1 To [M:FPC]NBDIE : [M:FASM]CCE(I_DIE-1) = PCCE(I_DIE-1) : Next I_DIE

  # FQ96153
  Local File FXDASSETS [CCFAS]
  Local Char WWCCE(15)(GOPTCANA), WWDIE(3)(GOPTCANA)
  Local Integer I_DIE2
  Read [CCFAS]FAS0 = PAASREF
  For I_DIE2 = 1 To [M:FPC]NBDIE
      WWCCE(I_DIE2 - 1) = [F:CCFAS]CCE(I_DIE2 - 1)
      WWDIE(I_DIE2 - 1) = [F:CCFAS]DIE(I_DIE2 - 1)
#      WWCCE(I_DIE2 - 1) = evalue("[F:CCFAS]CCE" + num$(I_DIE2 - 1))
#      WWDIE(I_DIE2 - 1) = evalue("[F:CCFAS]DIE" + num$(I_DIE2 - 1))
  Next I_DIE
  # fin décla FQ96153

  For I_DIE=1 To [M:FPC]NBDIE

   I_DIE2 = find([M:FPC]DIE(I_DIE-1), WWDIE) # FQ96153
#   If I_DIE2 and [M:FASM]CCE(I_DIE-1) <> WWCCE(I_DIE2 - 1) # FQ96153
   If I_DIE2 # FQ96153 FQ110722
   # Si changement de site, il faut contrôler la section dans le cas où elle est rattachée à un site
   # pour ne pas interférer avec la KQ96153 qui de mande de ne pas contrôler si la section ne change pas (pour les cas de date de fin de validité).

    If ([M:FASM]CCE(I_DIE-1) <> WWCCE(I_DIE2 - 1) or
&       (PFCYO <> PFCY and func CCE_A_UN_SITE([M:FPC]DIE(I_DIE-1), [M:FASM]CCE(I_DIE-1)))) # FQ96153 FQ110722

        Call CTRL_TABCCE([M:FASM]CCE(I_DIE-1),[M:FPC]DIE(I_DIE-1),PFCY,PTRFDAT) From TRTX3CPT
        If ( mkstat ) Then
          mkstat = 0
          RET=1
          RTABZON(I_ERR)=mess(338,7773,1)-"n°"-num$(I_DIE)     : # Axe analytique
          RTABERR(I_ERR)=PCCE(I_DIE-1)-GMESSAGE                : # Message d'erreur
          I_ERR+=1
        Else
          ## Action %CNTOBJ
          Call CONTSEL("CCE","!",[M:FASM]CCE(I_DIE-1),num$([M:FPC]DIE(I_DIE-1)),mkstat) From CONTOBJ
          If ( mkstat ) Then
            mkstat = 0
            RET=1
            RTABZON(I_ERR)=mess(338,7773,1)-"n°"-num$(I_DIE)     : # Axe analytique
            RTABERR(I_ERR)=PCCE(I_DIE-1)-GMESSAGE                : # Message d'erreur
            I_ERR+=1
          Endif
         Endif
    Endif
   Endif
  Next I_DIE

  # FQ96153
  Close File [CCFAS]
  Kill WWCCE, WWDIE, I_DIE2
 Endif

#-> Contrôle de validité des sections avec la localisation du bien

#-> Alimentation du nombre d'erreur avant de sortir

RNBERR=I_ERR

End

# FQ110722
Funprog CCE_A_UN_SITE(PDIE, PCCE)
Value Char PDIE(), PCCE()

If !clalev([F:CCE])  Local File CACCE  [CCE] : Endif

  Read [CCE] CCE0=PDIE; PCCE
  If fstat
    End 0
  Endif

  If [F:CCE]FCY <> ""
    # It's a fcy not a cpy :
    If find([F:CCE]FCY,GSITE(1..GNBSITE))
      End 1
    Endif
  Endif
End 0
#---------------------------------------------------------------------
# S/P de contrôle pour savoir si un bien a subi un transfert de secteur
# d'activité ayant donnée lieu à une régul de TVA. futur.
# Ce contrôle n'a d'utilité que si la date de mise en service du bien
# se trouve dans l'exercice courant.
# Paramètres :
#     PAASREF    Référence du bien comptable
#     PDATREF    Date de référence servant à la comparaison
# Valeurs retournées :
#     RTRANSFERE Oui s'il y eu un transfert de secteur d'ac. avec régul
#                de TVA.
#     RTRFCCL    Oui si le transfert postérieur est annulable (signifie)
#                que tous les transferts en DATREF et le trf de secteur
#                sont annulables.
#     RCDRET     Code retour -1 si erreur
#---------------------------------------------------------------------
Subprog BCO_TRANSFERE(PAASREF, PDATREF, RTRANSFERE, RTRFCCL, RCDRET)

Value    Char    PAASREF     : # Référence bien comptable
Value    Date    PDATREF     : # Date de référence
Variable Integer RTRANSFERE  : # Le bien a été transféré Oui/Non à une date postérieure
Variable Integer RTRFCCL     : # Le transfert peut être annulé ()
Variable Integer RCDRET      : # Code retour

If PAASREF="" | PDATREF=[0/0/0]
 RCDRET=0
 End
Endif

RCDRET     = 0
RTRANSFERE = G_NON
RTRFCCL    = G_NON

If !clalev([F:FASW]) : Local File FXDASSETS [FASW] : Endif
Read [FASW]FAS0=PAASREF
If fstat
 RCDRET=-1
 End
Endif

If [F:FASW]TRFDAT=[0/0/0]
 RTRANSFERE = G_NON
Else
 If [F:FASW]TRFDAT>PDATREF
  RTRANSFERE = G_OUI
  Gosub IS_TRF_ANNULABLE
 Else
  RTRANSFERE = G_NON
 Endif
Endif

End
#
# Code commun de BCO_TRANSFERE
#
$IS_TRF_ANNULABLE
 Local Char CRITEFS(255)
 If !clalev([F:TB0]) : Local File EFASAFFAGE [TB0] : Endif

 CRITEFS="CPY=[F:FASW]CPY & DPRPLN=G301CPT & REF=PAASREF & EVTDAT=[F:FASW]TRFDAT & EVTPRINC=G_OUI"
 Filter [F:TB0] Where evalue(CRITEFS)
 Read [TB0] Last

 If fstat
  Case fstat
   When 4       : RTRFCCL=G_NON  # Pas d'événement, on ne peut pas annuler le transfert
   When Default : RCDRET =-1     # Erreur d'accès à la table des événements
  Endcase
 Else
  # On a trouvé le dernier événement de transfert. S'il porte un changement de secteur d'activité et une régul de TVA
  # Le transfert est annulable on sort. Sinon, si le dernier evt est porteur d'une date de dernier transfert, on
  # Essaie de le récupérer

  Local Date     L_LASTDATTRF
  Local Decimal  L_IASDEV
  Local Decimal  L_PCGDEV
  Local Char     L_AASBUSO
  Local Char     L_AASBUSD

  L_AASBUSO    = [F:TB0]AASBUSO
  L_AASBUSD    = [F:TB0]AASBUSD
  L_PCGDEV     = [F:TB0]PCGDEV
  L_IASDEV     = [F:TB0]IASDEV
  L_LASTDATTRF = [F:TB0]LASTDATTRF

  Filter [F:TB0]

  # Cas 1 - Pas d'autre transfert postérieur

  If L_LASTDATTRF=[0/0/0] | L_LASTDATTRF<=PDATREF
   Gosub TEST_INFOS_TRANSFERT
  Endif

  # Cas 2 - Il y a d'autres transferts postérieurs (entre PDATREF et le trf postérieur en courant)

  If L_LASTDATTRF<>[0/0/0] & L_LASTDATTRF>PDATREF
   Gosub TEST_INFOS_TRANSFERT
   Local Integer FIN : FIN=0
   Repeat
    CRITEFS="CPY=[F:FASW]CPY & DPRPLN=G301CPT & FCY=[F:FASW]FCY & REF=PAASREF & EVTDAT=L_LASTDATTRF & EVTPRINC=G_OUI"
    Filter [F:TB0] Where evalue(CRITEFS)
    Read [TB0] Last
    If fstat
     Case fstat
      When 4       : RTRANSFERE=G_OUI : RTRFCCL=G_NON : FIN=1 # On a rien trouvé (rupture de la chaîne on s'arrête là)
      When Default : RCDRET =-1       : Break                 # Erreur d'accès à EFASAFFAGE
     Endcase
    Else
     L_AASBUSO    = [F:TB0]AASBUSO
     L_AASBUSD    = [F:TB0]AASBUSD
     L_PCGDEV     = [F:TB0]PCGDEV
     L_IASDEV     = [F:TB0]IASDEV
     L_LASTDATTRF = [F:TB0]LASTDATTRF
     Filter [F:TB0]
     If  L_LASTDATTRF=[0/0/0] | L_LASTDATTRF<=PDATREF
      FIN=1
     Endif
     Gosub TEST_INFOS_TRANSFERT
    Endif
   Until FIN
  Endif
 Endif

Return

#
# Code commun de BCO_TRANSFERE
#
$TEST_INFOS_TRANSFERT

 # Cas a - Pas de transfert de secteur d'activité (On rend pas transféré)

 If L_AASBUSO=L_AASBUSD
  RTRANSFERE = G_NON
 Endif

 # Cas b - Transfert de secteur d'activité mais pas de régul (On rend pas transféré)

 If (L_AASBUSO<>L_AASBUSD) & L_IASDEV=0 & L_PCGDEV=0
  RTRANSFERE = G_NON
 Endif

   # Cas c - Transfert de secteur d'activité et régul (On rend transféré et annulable)

 If (L_AASBUSO<>L_AASBUSD) & (L_IASDEV<>0 | L_PCGDEV<>0)
  RTRANSFERE= G_OUI
  RTRFCCL   = G_OUI
 Endif

Return

#---------------------------------------------------------------------
# Emission de l'en-tête société dans la trace
#---------------------------------------------------------------------
Subprog ET_COMPTE_RENDU(PCPY)
Value Char PCPY
Local Char LIGNE(100)

If FLGDET=G_OUI & ACTSILENCE<>G_OUI
 Call ECR_TRACE(PCPY,GTRC_CRACTIO,"",0,1) From TRACEABX3
 LIGNE="=================================================================================================" :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
 LIGNE="  "+mess(2,3141,1)+"         "+mess(251,7773,1)+""                                                   :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
 If GPHY = G_OUI Then
    # "Elément physique"              "Désignation"
    LIGNE="    "+mess(6,3141,1)+"       "+mess(251,7773,1)+""
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
 Endif
 LIGNE="=================================================================================================" :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
Endif

End

#---------------------------------------------------------------------
# Emission des infos de mise à jour du BCO dans la trace
#---------------------------------------------------------------------
Subprog BCO_COMPTE_RENDU(PCPY,PREF,PDES,PMES)
Value Char PCPY
Value Char PREF
Value Char PDES
Value Char PMES

If FLGDET=G_OUI & ACTSILENCE<>G_OUI
 Local Char LIGNE(130)
 LIGNE =space$(2)
 LIGNE+=left$(PREF+space$(23),23)
 LIGNE+=left$(PDES+space$(70),70)
 Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
Endif

If ACTSILENCE=G_OUI
 GT_OBJ_REF(I_OBJ)=PREF
 GT_OBJ_DES(I_OBJ)=PDES
 I_OBJ+=1
Endif

End

#---------------------------------------------------------------------
# S/p de lancement de l'action à partir du traitement
# Réservé développement
#---------------------------------------------------------------------
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

Case PACTTYP
 When "U"
  Raz GPILOBJ
  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM
  Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
 When "M"
  Local Char PARAM(30)(1..5)
  Local Char VALEUR
  PARAM(1)="M"              # Massif / unitaire
  PARAM(2)="FASTRF"         # Nom de l'action métier
  PARAM(3)="2"              # Objet métier de référence FAS
  PARAM(4)=num$(1)          # Mono société              Non
  PARAM(5)=num$(1)          # Plan d'amortissement géré Non
  Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASTRF","FASTRFM",4,"") From GTRAITE
 When Default
Endcase
End

#---------------------------------------------------------------------
# S/p d'affichage des paramétres de lancement de l'action dans la trace
# Réservé développement
#---------------------------------------------------------------------
$SHOW_PARAM
 Local Integer I_FCY, I_CPY
 Local Char LIGNE(120)
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE="Options" : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE="Simulation"-mess([M:MHC]FLGSIM,1,1)-"Trace détaillée"-mess([M:MHC]FLGDET,1,1) : Call ECR_TRACE(LIGNE,0) From GESECRAN

 For I_CPY=1 To [M:MHC]NBCPY
  LIGNE=[M:MHC]CPY(I_CPY-1)-mess([M:MHC]FLGCPY(I_CPY-1),1,1) : Call ECR_TRACE(LIGNE,0) From GESECRAN
 Next I_CPY

 For I_FCY=1 To [M:MHC]NBFCY
  LIGNE=[M:MHC]FCY(I_FCY-1)-mess([M:MHC]FLGFCY(I_FCY-1),1,1) : Call ECR_TRACE(LIGNE,0) From GESECRAN
 Next I_FCY

Call ECR_TRACE(mess(063,7773,1)+space$(27-len(mess(063,7773,1)))+":"-format$("D:DD[ ]MMMMMMMMMM4Y",[M:FASM]MVTDAT),0) From GESECRAN
Call ECR_TRACE(mess(332,7773,1)+space$(27-len(mess(332,7773,1)))+":"-format$("D:DD[ ]MMMMMMMMMM4Y",[M:FASM]MVTDAT),0) From GESECRAN
Call ECR_TRACE(mess(333,7773,1)+space$(27-len(mess(333,7773,1)))+":"-[M:FASM]REN-"/"-[M:FASM]ZREN,0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE("Affectations et/ou imputations destinations du transfert à annuler",0) From GESECRAN
Call ECR_TRACE(mess(334,7773,1)+space$(27-len(mess(334,7773,1)))+":"-[M:FASM]FCYD-"/"-[M:FASM]ZFCYD,0) From GESECRAN
####Call ECR_TRACE(mess(122,7776,1)+space$(27-len(mess(122,7776,1)))+":"-[M:FASM]LOCD,0) From GESECRAN
Call ECR_TRACE(mess(336,7773,1)+space$(27-len(mess(336,7773,1)))+":"-[M:FASM]AASBUSD-"/"-[M:FASM]ZAASBUSD,0) From GESECRAN
Call ECR_TRACE(mess(153,7773,1)+space$(27-len(mess(153,7773,1)))+":"-[M:FASM]IASCGUD-"/"-[M:FASM]ZIASCGUD,0) From GESECRAN
Call ECR_TRACE(mess(530,7773,1)+space$(27-len(mess(530,7773,1)))+":"-[M:FASM]DSPD-"/"-[M:FASM]ZDSPD,0) From GESECRAN
Local Integer ECRTIT : Raz ECRTIT
For nolign=1 To [M:FASM]NBLIG
 #????
 # Call ECR_TRACE("    "+mess([M:FASM]AXE(nolign-1),601,1)+space$(24-len(mess([M:FASM]AXE(nolign-1),601,1)))+":"-[M:FASM]CCED(nolign-1)-[M:FASM]ZCCED(nolign-1),0) From GESECRAN
 Call ECR_TRACE("    "+[M:FASM]DIE(nolign-1)+space$(24-len([M:FASM]DIE(nolign-1)))+":"-[M:FASM]CCED(nolign-1)-[M:FASM]ZCCED(nolign-1),0) From GESECRAN
Next nolign

Return

#---------------------------------------------------------------------
# S/p de lancement de l'action à partir du traitement
# Ce sous-pro recalcul et met à jour les valeurs bilan stockées dans
# DEPREC pour un plan donné à partir des informations stockées dans la
# classe du Bien mise à jour par le traitement de régul
#---------------------------------------------------------------------
Subprog MAJREGTVA(PCLASFAS,PCLASDEP,RTRN)
Value    Char    PCLASFAS    # Classe contenant le bien comptable mis à jour par la régul de TVA
Value    Char    PCLASDEP    # Classe chargé avec l'enregistrement de DEPREC à mettre à jour
Variable Integer RTRN        # Code retour du sous-programme

Local Char    FF
Local Char    FC
Local Char    NOMZON
Local Char    PLNCUR(GLONCUR)
Local Integer PLNCNX
Local Integer ORIBASDPR
Local Integer TYPCUR
Local Integer STAT
Local Decimal BSEVAL
Local Decimal DPRBAS
Local Decimal MTDES

FF = "[F:"+PCLASFAS+"]"
FC = "[F:"+PCLASDEP+"]"
RTRN = 0 :  # OK

# Plan de référence ORIBASDPR dans CNX

PLNCNX=evalue(FC+"CNX")
ORIBASDPR=func GLOBIENS.GET_ORIBASDPR(evalue(FF+"CPY"),PLNCNX,evalue(FC+"DPRPLN"))

# Recalcul des valeurs Bilan en fonction du plan de référence

Case ORIBASDPR
 When GVML_OBPCG
  BSEVAL=evalue(FF+"ACGETRNOT+"+FF+"IVCVATAMT-"+FF+"DEDVATAMT")
 When GVML_OBIAS
  BSEVAL=evalue(FF+"IASETRNOT+"+FF+"IVCVATAMTI-"+FF+"DEDVATAMTI")
Endcase

# Devise et type de cours du plan à modifier

PLNCUR= func GLOFCYCPY.GET_DEVISE_PLN (evalue(FF+"CPY"), evalue(FC+"DPRPLN"))
TYPCUR= func GLOBIENS.GET_TYPDEV_CNX(evalue(FF+"CPY"), PLNCNX)

# Conversion des valeurs bilan

Case ORIBASDPR
 When GVML_OBPCG
  If PLNCUR<>GCNXCURCPF
   Call CONVERT3(GCNXCURCPF, PLNCUR, GCOUDEV, TYPCUR, evalue (FF+"PURDAT"), BSEVAL, MTDES, evalue(FC+"RATCUR"), STAT) From CPTSUB
  Else
   MTDES=BSEVAL
  Endif
 When GVML_OBIAS
  If PLNCUR<>GCNXCURIAS
   Call CONVERT3(GCNXCURIAS, PLNCUR, GCOUDEV, TYPCUR, evalue (FF+"PURDAT"), BSEVAL, MTDES, evalue(FC+"RATCUR"), STAT) From CPTSUB
  Else
   MTDES=BSEVAL
  Endif
Endcase

# Arrondi et alimentation des valeurs bilan

Call GET_MNT_ARRONDI(MTDES, PLNCUR, MTDES) From GLOBIENS
#> Mise à jour de la valeur bilan réévalué si elle est identique à la valeur bilan initiale
If evalue(FC+"BSEVAL="+FC+"DPRBAS")
 NOMZON=FC+"DPRBAS" : Assign NOMZON With MTDES
Endif
#> Mise à jour de la valeur bilan initiale
NOMZON=FC+"BSEVAL" : Assign NOMZON With MTDES

### CHANGEMENT DU MODE ET EVENEMENT DE CHANGEMENT DE MODE
Local Date    CNXDAT(1..5)

Call GET_CNX_DAT(evalue(FC+"CPY"),PLNCNX,CNXDAT,STAT) From GLOBIENS

If [M:FASM]CCLTRF = G_OUI
  # On restaure le mode d'origine si le transfert était postérieur à l'exercice d'acquisition
  If ( evalue(FF+"VATREGDAT") < CNXDAT(1) ) Then
    Call MTC_RSD_NRSD(PCLASFAS, PCLASDEP, G_OUI, CNXDAT(3), STAT) From TRTFAS
  Endif
Elsif ( evalue(FF+"VATREGDAT")  < CNXDAT(1) )
  # Passage en mode résiduel si on est au-delà de l'exercice d'acquisition
  Call MTC_NRSD_RSD(PCLASFAS, PCLASDEP, G_OUI, CNXDAT(3), STAT) From TRTFAS
Endif
End

#===========================================================================
# Fonctions
#
#   1 GET_SOMDOT            PCPY, PFCY, PAASREF, PPLN, PTRFDAT
#   2 GET_DEDVAT            PCLASSE, PTYPDED
#   3 GET_CRBVAT            PCLASSE, PTYPDED
#   4 GET_CCE               PCPY, PAASREF,
#   5 GET_TRFTYP            PCLASSEO, PCLASSED
#
#===========================================================================

#---------------------------------------------------------------------
# Permet de récupérer la déduction complémentaire à partir de la classe
# contenant les informations du BCO
# PTYPDED = "ACG" ou "IAS"
#---------------------------------------------------------------------
Funprog GET_CPLDED(PCLASSE,PTYPDED)
Value Char PCLASSE
Value Char PTYPDED

Local Decimal DEDVAT : DEDVAT=0

DEDVAT=evalue(PCLASSE+PTYPDED+"CPLDED")

End DEDVAT

#---------------------------------------------------------------------
# Permet de récupérer le reversement de TVA à partir de la classe
# contenant les informations du BCO
# PTYPDED = "ACG" ou "IAS"
#---------------------------------------------------------------------
Funprog GET_REVVAT(PCLASSE,PTYPDED)
Value Char PCLASSE
Value Char PTYPDED

Local Decimal REVVAT : REVVAT=0

REVVAT=evalue(PCLASSE+PTYPDED+"REVVAT")

End REVVAT

#---------------------------------------------------------------------
# Permet de récupérer la section analytique du bien à une date donnée
# Un BCO porte les imputations analytiques résultant du dernier TRF
# analytique. Or celui-ci peut avoir une date d'effet postérieure à la
# période courante.
# Récupération de la répartition a priori si numéro d'axe = 0 FQ54202
#---------------------------------------------------------------------
Funprog GET_CCE(PCLASBCO,PDATREF,PAXE)
Value Char    PCLASBCO    # Classe contenant les infos du bien comptable
Value Date    PDATREF     # Date à laquelle on doit déterminer la valeur de la section.
Value Integer PAXE        # Axe analytique

Local Integer DEBUGMODE : DEBUGMODE=G_NON # Mode debug
Local Char    RCCE      # Section analytique retournée.

# Paramètre invalide, on sort sans alimenter la section
If PCLASBCO="" | PDATREF=[0/0/0] | PAXE<0 | PAXE>GOPTCANA
 RCCE=""
 End RCCE
Endif

# Si pas de date de transfert ou date de transfert antérieure à la date de référence on prend la section sur le BCO
If evalue("PDATREF=[0/0/0] | PDATREF"+">="+PCLASBCO+"TRFDAT")
 If DEBUGMODE=G_OUI : Infbox "On prend l'imputation analytique sur le BCO" : Endif
 If PAXE=0
   RCCE=evalue(PCLASBCO+"DSP")
 Else
   RCCE=evalue(PCLASBCO+"CCE(PAXE-1)")
 Endif
 End RCCE
Endif

# Si date de transfert postérieure à la date de référence
If evalue("PDATREF"+"<"+PCLASBCO+"TRFDAT")

 # Ouverture des tables
 Local Char    CRITSELEFS(255)   # Critère de sélection des événemnts
 Local Char    W_CCE             # Stockage de la valeur de la section
 Local Integer I_PLN             # Indice de parcours des plans d'amortissement
 Local Integer L_NOCCLTRF        # Au moins un événement non annulé trouvé

 If !clalev([F:TB0])   : Local File EFASAFFAGE [TB0]   : Endif
 If !clalev([F:XTB0])  : Local File EFASAFFAGE [XTB0]  : Endif

 # Recherche événement de transfert
 Raz RCCE

 For I_PLN=1 To G301MAX-1

  If DEBUGMODE=G_OUI : Infbox "Recherche d'événement sur le plan"-mess(I_PLN,3101,1) : Endif

  CRITSELEFS ="CPY="+PCLASBCO+"CPY"+"&"
  CRITSELEFS+="DPRPLN="+num$(I_PLN)+"&"
  CRITSELEFS+="FCY="+PCLASBCO+"FCY"+"&"
  CRITSELEFS+="REF="+PCLASBCO+"AASREF"+"&"
  CRITSELEFS+="EVTDAT>="+"["+num$(day(PDATREF))+"/"+num$(month(PDATREF))+"/"+num$(year(PDATREF))+"]"+"&"
  CRITSELEFS+="EVTPRINC=G_OUI&"
  CRITSELEFS+="SNSEVE = GVML_TEACT"

  Filter [TB0] Where evalue(CRITSELEFS)

  L_NOCCLTRF = G_NON

  For [TB0]EVE0
   Read [XTB0]EVE1(2)=[F:TB0]REF;[F:TB0]TIMSTP
   # Si l'événement est annulé (fstat<>0) on lit l'événement suivant
   If fstat
    # L'événement n'est pas annulé, on récupére l'imputation :
    If PAXE = 0
      W_CCE=[F:TB0]DSPO
    Else
      W_CCE=evalue("[F:TB0]CCE"+num$(PAXE)+"O")
    Endif
    L_NOCCLTRF = G_OUI
    Break 2
   Endif
  Next EVE0

 Next I_PLN

 Filter [TB0]

 #> Si on a trouvé au moins un événement non annulé, on prend l'info analytique récupérée sur cet événement,
 #  Si on a trouvé aucun événement ou que tous les événements trouvés on été annulé, on prend l'analytique
 #  présent sur le bien (=analytique pour la période courante.).

 If L_NOCCLTRF=G_OUI
  RCCE=W_CCE
 Elsif L_NOCCLTRF=G_NON
  If PAXE = 0
   RCCE=evalue(PCLASBCO+"DSP")
  Else
   RCCE=evalue(PCLASBCO+"CCE(PAXE-1)")
  Endif
 Endif

Endif

End RCCE

#---------------------------------------------------------------------
# Permet de récupérer le site financier du bien à une date donnée (date de référence)
# Fonction utilisée pour la génération des flux
#
# Si la date de référence est égale ou postérieure à la date de dernier tranfert on prend le site sur le bien
# Sinon on cherche le premier événement de transfert non annulé suivant la date de référence pour retrouver
# le site d'origine
#
# Remarque : si la date de référence est égale à la date de tranfert on renvoie le site porté par le bien. On
#            considère donc que le bien est sur le site destination le jour du transfert
#---------------------------------------------------------------------
Funprog GET_FCY(PCLASBCO,PDATREF)
Value Char    PCLASBCO    # Classe contenant les infos du bien comptable
Value Date    PDATREF     # Date à laquelle on doit déterminer la valeur de la section.

Local Integer DEBUGMODE : DEBUGMODE=G_NON # Mode debug
Local Char    RFCY        # Site financier retourné.

# Paramètre invalide, on sort sans alimenter la section
If PCLASBCO="" | PDATREF=[0/0/0]
 RFCY=""
 End RFCY
Endif

# Si pas de date de transfert ou date de référence supérieure ou égale à date de transfert on prend la section sur le BCO
#If evalue("PDATREF=[0/0/0] | PDATREF"+">="+PCLASBCO+"TRFDAT")  : # FQ105454
If evalue(PCLASBCO+"TRFDAT=[0/0/0] | PDATREF>="+PCLASBCO+"TRFDAT")
 If DEBUGMODE=G_OUI : Infbox "On prend l'imputation sur le BCO" : Endif
 RFCY=evalue(PCLASBCO+"FCY")
 End RFCY
Endif

# Si date de référence antérieure à date de transfert
If evalue("PDATREF"+"<"+PCLASBCO+"TRFDAT")
 # Ouverture des tables
 Local Char    CRITSELEFS(255)   # Critère de sélection des événemnts
 Local Char    W_FCY             # Stockage de la valeur du site
 Local Integer I_PLN             # Indice de parcours des plans d'amortissement
 Local Integer L_NOCCLTRF        # Au moins un événement non annulé trouvé

 If !clalev([F:TB0])   : Local File EFASAFFAGE [TB0]   : Endif
 If !clalev([F:XTB0])  : Local File EFASAFFAGE [XTB0]  : Endif

 # Recherche événement de transfert
 Raz RFCY

 For I_PLN=1 To G301MAX-1

  If DEBUGMODE=G_OUI : Infbox "Recherche d'événement sur le plan"-mess(I_PLN,3101,1) : Endif

  CRITSELEFS ="CPY="+PCLASBCO+"CPY"+"&"
  CRITSELEFS+="DPRPLN="+num$(I_PLN)+"&"
  CRITSELEFS+="FCYD<>''"+"&"
  CRITSELEFS+="REF="+PCLASBCO+"AASREF"+"&"
  #CRITSELEFS+="EVTDAT>="+"["+num$(day(PDATREF))+"/"+num$(month(PDATREF))+"/"+num$(year(PDATREF))+"]"+"&" : # FQ105454
  CRITSELEFS+="EVTDAT>"+"["+num$(day(PDATREF))+"/"+num$(month(PDATREF))+"/"+num$(year(PDATREF))+"]"+"&"
  CRITSELEFS+="EVTPRINC=G_OUI&"
  CRITSELEFS+="SNSEVE = GVML_TEACT"

  Filter [TB0] Where evalue(CRITSELEFS)

  L_NOCCLTRF = G_NON

  For [TB0]EVE0
   Read [XTB0]EVE1(2)=[F:TB0]CPY;[F:TB0]TIMSTP
   # Si l'événement est annulé (fstat<>0) on lit l'événement suivant
   #If fstat and [F:XTB0]FCY<>[F:XTB0]FCYD : # FQ105454 : erreur sur la classe
   If fstat and ([F:TB0]FCY<>[F:TB0]FCYD)
    # L'événement n'est pas annulé et on est sur l'événement d'origine, on récupére l'imputation :
    W_FCY=[F:TB0]FCY
    L_NOCCLTRF = G_OUI
    Break 2
   Endif
  Next EVE0

 Next I_PLN

 Filter [TB0]

 #> Si on a trouvé au moins un événement non annulé, on prend le site sur cet événement,
 #  Si on n'a trouvé aucun événement ou que tous les événements trouvés on été annulé, on prend le site
 #  présent sur le bien (=analytique pour la période courante.).

 If L_NOCCLTRF=G_OUI
  RFCY=W_FCY
 Elsif L_NOCCLTRF=G_NON
  RFCY=evalue(PCLASBCO+"FCY")
 Endif

Endif

End RFCY

#--------------------------------------------------------------------- FQ56508
# Renvoie un indicateur permettant de distinguer le type de transfert :
#   0 : aucun transfert (ne devrait jamais arriver)
#   1 : transfert géographique uniquement
#   2 : transfert analytique uniquement
#   3 : transfert géographique et analytique
#   4 : transfert économique uniquement
#   5 : transfert économique et géographique
#   6 : transfert économique et analytique
#   7 : transfert économique, géographique et analytique
Funprog GET_TRFTYP(PCLASSEO, PCLASSED)
Value Char PCLASSEO : # Classe avec les imputations d'origine
Value Char PCLASSED : # Classe avec les imputations de destination

Local Shortint TRFTYP : TRFTYP = 0

  # Transfert géographique
  If   WFCY <> ""
    TRFTYP += 1
  Endif

  # Transfert analytique
  If evalue(PCLASSEO+"DSP") <> evalue(PCLASSED+"DSP")
    TRFTYP += 2
  Else
    For N_AXE = 0 To GOPTCANA-1
      If evalue(PCLASSEO+"CCE("+num$(N_AXE)+")") <> evalue(PCLASSED+"CCE("+num$(N_AXE)+")")
        TRFTYP += 2
        Break
      Endif
    Next
  Endif

  # Transfert économique
  If   evalue(PCLASSEO+"IASCGU") <> evalue(PCLASSED+"IASCGU")
&   or evalue(PCLASSEO+"AASBUS") <> evalue(PCLASSED+"AASBUS")
    TRFTYP += 4
  Endif
End TRFTYP

##########################################################################
## Gestion du masque FASTRFP [M:FASM]
##########################################################################

#-> Après modif CCLTRF

Subprog AM_CCLTRF(VALEUR)
Variable Integer VALEUR

 Case VALEUR
  When G_OUI
   [M:FASM]REN="" : Grizo [M:FASM]REN
   If ACTTYPGES=GTAMUNI
    Gosub LOAD_IMPUTATION_ORIGINE
    Grizo [M:FASM]MVTDAT
    Grizo [M:FASM]15
    Grizo [M:FASM]20
    Grizo [M:FASM]25
    Grizo [M:FASM]30
   Endif
  When G_NON
  # CBO 20110909 exigence 69691 ajout test pour import des mvts
   If GIMPORT <> 1
     [M:FASM]REN="" : Actzo [M:FASM]REN
     If ACTTYPGES=GTAMUNI
      Gosub LOAD_IMPUTATION_BCO
      Actzo [M:FASM]MVTDAT
      Actzo [M:FASM]15
      # Si on a des éléments physiques rattachés au bien, on ne propose pas le changement de localisation
      If ACTTYPGES=GTAMUNI & GPHY = G_OUI Then
         Gosub ACTIV_TYPLOC
      Endif
      Actzo [M:FASM]20
      Actzo [M:FASM]25
      Actzo [M:FASM]30
     Endif
   Endif
 Endcase

 # Action CHGACTCRIT ne doit être exécutée qu'en massif. Pas d'impact sur la population en unitaire
 If ACTTYPGES=GTAMMAS
  Call ACTCHGCRIT() From TRCPROCOM
 Endif

End

##########################################################################
#-> Contrôle MVTDAT - Contrôle en saisie de la date de transfert
##########################################################################
Subprog C_MVTDAT(VALEUR)
Variable Date    VALEUR

 #=> En unitaire, la date de transfert doit être strictement postérieure à la date de dernier transfert
 #*FQ100332 If ACTTYPGES=GTAMUNI et que l'on est pas en annulation de transfert
 If ACTTYPGES=GTAMUNI and [M:FASM]CCLTRF <> G_OUI
    If (([M:FASM]TRFDAT<>[0/0/0]) & !(VALEUR>[M:FASM]TRFDAT))
      # "Le transfert doit être postérieur au 00/00/00 ("
      GMESSAGE=mess(339,7773,1)-format$("DD2",[M:FASM]TRFDAT)-"("
      If GPHY = G_OUI Then
        # Le message est différent selon que la date de transfert a été alimentée avec la dernière date de transfert du bien,
        # avec la date de dernier transfert des éléments physiques, avec la date de dernière réception des éléments physiques
        If G_ORI_TRFDAT = "R" Then
          GMESSAGE=GMESSAGE+mess(678,7773,1) #"Date de dernière réception d'un élément physique)"
        Elsif G_ORI_TRFDAT = "T"
           GMESSAGE=GMESSAGE+mess(677,7773,1) #"Date du dernier transfert d'un élément physique)"
        Else
          # GPHY = G_OUI and G_ORI_TRFDAT = "B"
          GMESSAGE=GMESSAGE+mess(340,7773,1) #"Date du dernier transfert)"
        Endif
      Else
        # GPHY = G_NON
        GMESSAGE=GMESSAGE+mess(340,7773,1) #"Date du dernier transfert)"
      Endif
      GMESSAGE=GMESSAGE+")"
      GERR=1
      mkstat=2
      End
    Endif
 Endif
 #=> En unitaire et en massif, la date de transfert doit être postérieure au début d'exercice de tous les contexte / sociétés
 Local Date    CPYSTRFIY(1..G300MAX)
 Local Date    CPYENDFIY(1..G300MAX)
 Local Date    CPYSTRPER(1..G300MAX)
 Local Date    CPYENDPER(1..G300MAX)
 Local Date    CPYSTRFIYS(1..G300MAX)      # Début exercice suivant
 Local Date    CPYENDFIYS(1..G300MAX)      # Fin exercice suivant
 Local Date    CPYSTRPERS(1..G300MAX)      # Début période courante exercice suivant
 Local Date    CPYENDPERS(1..G300MAX)      # Fin période courante exercice suivant
 Local Integer RETOUR
 Local Integer I_CPY
 Local Integer I_CNX
 Local Integer NBR_CPY
 If ACTTYPGES=GTAMUNI
  NBR_CPY=1
 Endif
 If ACTTYPGES=GTAMMAS
  Raz NBR_CPY
  For I_CPY=1 To [M:MHC]NBCPY
   If [M:MHC]FLGCPY(I_CPY-1)=G_OUI : NBR_CPY+=1 : Endif
  Next I_CPY
 Endif
 If !(NBR_CPY=0)
  #Fq-83941  Local Char TAB_CPY(3)(NBR_CPY)
  Local Char TAB_CPY(GLONCPY)(NBR_CPY)
  Local Date LIMDAT
  If ACTTYPGES=GTAMUNI
   TAB_CPY(0)=[M:FAS0]CPY
  Endif
  If ACTTYPGES=GTAMMAS
   Raz NBR_CPY
   For I_CPY=1 To [M:MHC]NBCPY
    If [M:MHC]FLGCPY(I_CPY-1)=G_OUI : NBR_CPY+=1 : TAB_CPY(NBR_CPY-1)=[M:MHC]CPY(I_CPY-1) : Endif
   Next I_CPY
  Endif
  For I_CPY=1 To NBR_CPY
   # Appel du sous-pro d'alimentation des dates
   Call GET_CPY_DAT_CS(TAB_CPY(I_CPY-1),CPYSTRFIY,CPYENDFIY,CPYSTRPER,CPYENDPER,CPYSTRFIYS,CPYENDFIYS,CPYSTRPERS,CPYENDPERS,RETOUR) From GLOBIENS
   For I_CNX=1 To G300MAX
    If CPYSTRFIY(I_CNX)<>[0/0/0] & VALEUR < CPYSTRFIY(I_CNX)
        # "La date de transfert doit être postérieure au"-"début d'exercice de tous les contextes gérés pour la(les) société(s)"
        GERR=1 : GMESSAGE=mess(339,7773,1)-mess(341,7773,1)
        mkstat=2
    Endif
    # Contrôle que la date de transfert n'est pas postérieure à la fin de l'exercice suivant
    If CPYENDFIYS(I_CNX)<>[0/0/0] & VALEUR >CPYENDFIYS(I_CNX)
       # "La date du transfert doit être au plus égale à la date de fin de l'exercice suivant de chaque contexte"
       GERR=1 : GMESSAGE=mess(556,7773,1)
       mkstat=2
    Endif
    If ACTTYPGES=GTAMUNI
      If !clalev([F:DEPW]) : Local File DEPREC    [DEPW] : Endif
      For I_PLN=1 To [M:FAS3]NBLIG1
        # Lecture DEPREC
        Read [F:DEPW]DEP0=[M:FAS0]AASREF;[M:FAS3]DPRPLN(I_PLN-1);CPYENDFIY(I_CNX);CPYENDPER(I_CNX)
        If fstat=0
          If [F:DEPW]STRDPRDAT > VALEUR
            # "La date de transfert doit être au moins égale à la date de début d'amortissement de chaque plan du bien"
            GERR=1 : GMESSAGE=mess(67,7773,1)
            mkstat=2
          Endif
        Endif
      Next I_PLN
    Endif
   Next I_CNX
  Next I_CPY
 Endif
End

