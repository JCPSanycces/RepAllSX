#-> S/p GER_GEO

Subprog GER_GEO(PZONE,PINIT,PINDICE)
Value Char    PZONE
Value Integer PINIT
Value Integer PINDICE

 Local Integer I_CPY
 Local Integer NB_CPY : NBR_CPY=PINIT

 For I_CPY=1 To [M:MHC]NBCPY
  If [M:MHC]FLGCPY(I_CPY-1)=G_OUI & I_CPY<>PINDICE
   NBR_CPY+=1
  Endif
 Next I_CPY

 If NBR_CPY=1
  Actzo [M:FASM]=PZONE
  If evalue("dim([M:FASM]Z"+PZONE+")>0")
   Actzo [M:FASM]="Z"+PZONE
  Endif
 Else
  Effzo [M:FASM]=PZONE
  Grizo [M:FASM]=PZONE
  If evalue("dim([M:FASM]Z"+PZONE+")>0")
   Effzo [M:FASM]="Z"+PZONE
   Actzo [M:FASM]="Z"+PZONE
  Endif
 Endif

End

