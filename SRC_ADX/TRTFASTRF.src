#-> Après zone DSPD
Subprog AP_DSPD(VALEUR)
Variable Char VALEUR()

Local Integer N_CCED

 #For N_CCED = 0 To [M:FPC]NBDIE  : # FQ66325
 For N_CCED = 0 To [M:FPC]NBDIE-1 : # FQ66325
   If VALEUR = ""
