Onevent BEFORE_AREA Gosub AV_ZPJTDEBC From W1CRITPTE
Return

$AV_ZPJTDEBC
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]PJTDEBC(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_PJTFINC
Onevent BEFORE_INPUT Call AS_PJTFINC(zc) From W1CRITPTE
Onevent CONTROL Call C_PJTFINC(zc) From W1CRITPTE
Onevent AFTER_CHANGE Gosub AMM_PJTFINC From W1CRITPTE
Return

Subprog IB_PJTFINC(VALEUR)
Variable Char    VALEUR()
## Action PJTINIBUT
Call PJT_INIT_BUTTON(VALEUR,"CPTE","PJTFINC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES
&,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,""
&,"","","","") From TRTPJT
## Action STD
Call IB_PJTFINC From CNSPTESTD
Gosub _AFF
End

Subprog AS_PJTFINC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(43841,GBOUT1) From OBJDIV
Call TEXTE(14667,GBOUT2) From OBJDIV
Call TEXTE(54273,GBOUT3) From OBJDIV
Call TEXTE(43844,GBOUT4) From OBJDIV
Call TEXTE(43868,GBOUT15) From OBJDIV
Call TEXTE(17676,GBOUT16) From OBJDIV
Call TEXTE(54274,GBOUT17) From OBJDIV
Call TEXTE(54275,GBOUT18) From OBJDIV
Call TEXTE(11781,GBOUT19) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_PJTFINC(VALEUR)
## Action PJTBEFZON
Call PJT_BEFORE_ZONE(VALEUR,"CPTE","PJTFINC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES
&,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,""
&,"","","","") From TRTPJT
If mkstat=2
 [M]PJTFINC(INDIC) = VALEUR
 Affzo PJTFINC(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_PJTFINC(zc) From W1CRITPTE
Onkey 130 Titled GBOUT2 Call B2_PJTFINC(zc) From W1CRITPTE
Onkey 131 Titled GBOUT3 Call B3_PJTFINC(zc) From W1CRITPTE
Onkey 132 Titled GBOUT4 Call B4_PJTFINC(zc) From W1CRITPTE
Onkey 172 Titled GBOUT15 Call B15_PJTFINC(zc) From W1CRITPTE
Onkey 173 Titled GBOUT16 Call B16_PJTFINC(zc) From W1CRITPTE
Onkey 174 Titled GBOUT17 Call B17_PJTFINC(zc) From W1CRITPTE
Onkey 175 Titled GBOUT18 Call B18_PJTFINC(zc) From W1CRITPTE
Onkey 176 Titled GBOUT19 Call B19_PJTFINC(zc) From W1CRITPTE
Onkey   2 Titled GBOUTS Call S_PJTFINC(zc) From W1CRITPTE
Onkey 144 Titled GBOUTP Call P_PJTFINC(zc) From W1CRITPTE
Onkey 146 Titled GBOUTA Call SA_PJTFINC(zc) From W1CRITPTE
Gosub _AFF
End

Subprog C_PJTFINC(VALEUR)
Variable Char    VALEUR()
## Action PJTCTL
Call PJT_CONTROL(VALEUR,"CPTE","PJTFINC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES
&,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,""
&,"","","","") From TRTPJT
If mkstat : GERR = 1 : GZONE = "PJTFINC" : GZNUM = 54672 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PJTFINC" : GZNUM = 54672 : Endif
 If !mkstat
  ## Action CTLALPV
  Call CTLALPV(VALEUR,[M:CPTE]PJTDEBC) From CONTDIV
  If mkstat : GERR = 1 : GZONE = "PJTFINC" : GZNUM = 54672 : Endif
  If !mkstat
   ## Action STD
   Call C_PJTFINC(VALEUR) From CNSPTESTD
   If mkstat : GERR = 1 : GZONE = "PJTFINC" : GZNUM = 54672 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_PJTFINC
Call AM_PJTFINC(zc)
If !mkstat & GOBJET
 zoncou = "PJTFINC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PJTFINC(VALEUR)
Variable Char    VALEUR()
## Action PJTAFTMOD
Call PJT_AFTER_MODIFY(VALEUR,"CPTE","PJTFINC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES
&,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,""
&,"","","","") From TRTPJT
If mkstat : GERR = 1 : GZONE = "PJTFINC" : GZNUM = 54672 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZPJTFINC)")>indice
 [M]PJTFINC(indice) = VALEUR
 Affzo ZPJTFINC(indice)
Endif
Gosub _AFF
End

