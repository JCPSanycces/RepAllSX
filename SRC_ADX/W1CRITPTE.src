$ON_PJTDEBC
Onevent BEFORE_INPUT Call AS_PJTDEBC(zc) From W1CRITPTE
Onevent CONTROL Call C_PJTDEBC(zc) From W1CRITPTE
Onevent AFTER_CHANGE Gosub AMM_PJTDEBC From W1CRITPTE
Return

Subprog IB_PJTDEBC(VALEUR)
Variable Char    VALEUR()
## Action PJTINIBUT
Call PJT_INIT_BUTTON(VALEUR,"CPTE","PJTDEBC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES
&,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,""
&,"","","","") From TRTPJT
## Action STD
Call IB_PJTDEBC From CNSPTESTD
Gosub _AFF
End

Subprog AS_PJTDEBC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(43841,GBOUT1) From OBJDIV
Call TEXTE(14667,GBOUT2) From OBJDIV
Call TEXTE(54273,GBOUT3) From OBJDIV
Call TEXTE(43844,GBOUT4) From OBJDIV
Call TEXTE(43868,GBOUT15) From OBJDIV
Call TEXTE(17676,GBOUT16) From OBJDIV
Call TEXTE(54274,GBOUT17) From OBJDIV
Call TEXTE(54275,GBOUT18) From OBJDIV
Call TEXTE(11781,GBOUT19) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_PJTDEBC(VALEUR)
## Action PJTBEFZON
Call PJT_BEFORE_ZONE(VALEUR,"CPTE","PJTDEBC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES
&,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,""
&,"","","","") From TRTPJT
If mkstat=2
 [M]PJTDEBC(INDIC) = VALEUR
 Affzo PJTDEBC(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_PJTDEBC(zc) From W1CRITPTE
Onkey 130 Titled GBOUT2 Call B2_PJTDEBC(zc) From W1CRITPTE
Onkey 131 Titled GBOUT3 Call B3_PJTDEBC(zc) From W1CRITPTE
Onkey 132 Titled GBOUT4 Call B4_PJTDEBC(zc) From W1CRITPTE
Onkey 172 Titled GBOUT15 Call B15_PJTDEBC(zc) From W1CRITPTE
Onkey 173 Titled GBOUT16 Call B16_PJTDEBC(zc) From W1CRITPTE
Onkey 174 Titled GBOUT17 Call B17_PJTDEBC(zc) From W1CRITPTE
Onkey 175 Titled GBOUT18 Call B18_PJTDEBC(zc) From W1CRITPTE
Onkey 176 Titled GBOUT19 Call B19_PJTDEBC(zc) From W1CRITPTE
Onkey   2 Titled GBOUTS Call S_PJTDEBC(zc) From W1CRITPTE
Onkey 144 Titled GBOUTP Call P_PJTDEBC(zc) From W1CRITPTE
Onkey 146 Titled GBOUTA Call SA_PJTDEBC(zc) From W1CRITPTE
Gosub _AFF
End

Subprog C_PJTDEBC(VALEUR)
Variable Char    VALEUR()
## Action PJTCTL
Call PJT_CONTROL(VALEUR,"CPTE","PJTDEBC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES
&,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,""
&,"","","","") From TRTPJT
If mkstat : GERR = 1 : GZONE = "PJTDEBC" : GZNUM = 54671 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PJTDEBC" : GZNUM = 54671 : Endif
Endif
Gosub _AFF
End

$AMM_PJTDEBC
Call AM_PJTDEBC(zc)
If !mkstat & GOBJET
 zoncou = "PJTDEBC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PJTDEBC(VALEUR)
Variable Char    VALEUR()
## Action PJTAFTMOD
Call PJT_AFTER_MODIFY(VALEUR,"CPTE","PJTDEBC",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES
&,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:CPTE]FCY,""
&,"","","","") From TRTPJT
If mkstat : GERR = 1 : GZONE = "PJTDEBC" : GZNUM = 54671 : Endif
If !mkstat
 ## Action STD
 Call AM_PJTDEBC(VALEUR) From CNSPTESTD
 If mkstat : GERR = 1 : GZONE = "PJTDEBC" : GZNUM = 54671 : Endif
 If !mkstat & evalue("dim("+clanam([M])+"ZPJTDEBC)")>indice
  [M]PJTDEBC(indice) = VALEUR
  Affzo ZPJTDEBC(indice)
 Endif
Endif
Gosub _AFF
End

Subprog S_PJTDEBC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action PJTSELBUT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJTSELBUT"
 PARMSK(1) = "CPTE"
 PARMSK(2) = "PJTDEBC"
 PARMSK(3) = "0"
 PARMSK(4) = "9"
 PARMSK(5) = num$([V]CST_ANO)
 PARMSK(6) = num$([V]CST_AYES)
 PARMSK(7) = num$([V]CST_AYES)
 PARMSK(8) = num$([V]CST_AYES)
 PARMSK(9) = num$([V]CST_ANO)
 PARMSK(10) = num$([V]CST_AYES)
 PARMSK(11) = num$([V]CST_AYES)
 PARMSK(12) = num$([V]CST_AYES)
 PARMSK(13) = num$([V]CST_AYES)
 PARMSK(14) = [M:CPTE]FCY
 PARMSK(15) = ""
 PARMSK(16) = ""
 PARMSK(17) = ""
 PARMSK(18) = ""
 PARMSK(19) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPJT","TRTPJT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

