#<AdxTL>@(#)12.0.0.0 $Revision$
# Issue X3-98708  - 2018-08-31 by FHA : Chart of account is lost after Journal Generation
# Issue X3-105232 - 2018-08-29 by FHA : Excluding Template journals
#*X3-39795  MWA  Manage ORIGIN and ORICOD fields in GL Entry
Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","CNVECAR","CNVECAR",4,"") From GTRAITE
End

##############################################################################################################
## Traitement des actions
##############################################################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Gosub DEBUT
Endcase
Return

##############################################################################################################
$CONTROLE
If GOK<1
 FIN = 1 : Return
Else
 TMP = 1
Endif

If FIN : Return : Endif
If [M:DIA]GENECR = 2
 Call AVERTDGI2([M:DIA]NBSOC,[M:DIA]SOC,[M:DIA]SITE,[M:DIA]TYP,SAI) From CPTDIV2
Endif
If SAI : Return : Endif

Call PRESENCE(MORT) From CPTBATCH
If MORT
 GERR = 1 : FIN = 1 : GMESSAGE = mess(49,134,1)
Endif
Return

##############################################################################################################
$OUVRE
Gosub OUVFIC
Local Integer MORT
Local Char    COMPTE(GLONGAC) , TIERS(GLONBPR)
Local Integer STAT ,  ER
Local Char    LETCUR(GLONCUR) , DEVCUR(GLONCUR) , SIMTYP(20)
Local Char    PCEAUTO(GLONGAU)
Local Char    SYMBOLE(80)
Local Integer X, STAECT
Local Decimal SOLDEV , SOLREVAL
Local Decimal RATETHEO
Local Integer FLGECART
Local Decimal EDEB , EFIN , EXER , PDEB , PFIN
Local Integer MAXECT, MAXLED
MAXLED = 9

Local Char    SOCIETE(GLONCPY) , SITE(GLONFCY), PLAN(GLONCOA)
Local Integer TYPLED                   : # Current ledger type = ledger type entered
Local Char    LEDCUR(GLONLED)          : # Code of the current ledger type
Local Char    DEVLED(GLONCUR)          : # Currency of the current ledger type
Local Integer TYPLEDVLDAUT(1..len(mess(0,2644,1))) : # List of the automatic ledger types for the current ledger
Local Integer NBRVLDAUT
Local Char    CODLEDVLDAUT(GLONLED)    : # Automatic ledger code
Local Char    CURLED(GLONCUR)          : # Currency of the ledger
Local Integer NUMERO

Local Char    FILTRE(250) , FILTRE_SPE(250) , FILECT(250) , MESSA(250) ,FILTVLD(250)
Local Char    TIT(50)
Local Integer FLEURO , OKDAT , OKMAJ , OKDEV , OKSOC , OKCHG , NBDEVIN
Local Char    DEVIN(GLONCUR)(1..100)

Local Char    IDENT(30)(1..5)
# X3-39795 MWA Local Char    TZONE(10)(1..7)          : # Table des zones à forcer pour génération d'une pièce
# X3-39795 MWA Local Char    TVAL(25)(1..7)           : # Table des valeurs des zones à forcer pour génération  d'une pièce
Local Char    TZONE(10)(1..10)           : # Table of the zones to be forced (Ex: ORICOD)
Local Char    TVAL(30)(1..10)            : # Table of values for zones to be forced

Local Integer GACTYPRAT                : # Rate type of the account
Local Integer CARRY_FORWARD            : # 1=Take the carry forward amounts in the balance(index 0) for "by account balance"
Local Date    STRDAT,ENDDAT            : # Start and end date of a fiscal year
Local Integer I_TYPLED                 : # Ledger type
Local Decimal TOTBLCLED(1..len(mess(0,2644,1)))    : # Total of the ledger balances in the ledger currency
Local Decimal TOTBLCLEDREV(1..len(mess(0,2644,1))) : # Revalued total of the ledger balances in the ledger currency
Local Decimal TOTVARIAN(1..len(mess(0,2644,1)))    : # Total of the variances for each ledger in the ledger currency
Local Integer I
Local Char    MTCTYP(GLONGTE)          : # Entry type displayed if matching code
Local Char    MTCNUM(GLONVCR)          : # Document number displayed if matching code
Local Integer OLDACCNUM                : # Accnum of the journal entry to display if matching code

Local Mask CNVECAR    [DIA]

MAXECT = dim([M:HAE]ACC1)
TIT = mess(55,107,1) : # Ecarts de conversion

Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","cp0") From GMEMO
Return

##############################################################################################################
$DEBUT
Raz [M:DIA]INI : Affzo [DIA]
Setmok [DIA] With 0
Return

##############################################################################################################
$OUVFIC
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR]  : Endif
If clalev([F:TCE])=0  : Local File TMPCNVECAR [TCE]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:GACC])=0 : Local File GACCOUNT   [GACC] : Endif
If clalev([F:ADW])=0  : Local File ADOVAL     [ADW]  : Endif
If clalev([F:DAEA])=0 : Local File GACCENTRYD [DAEA] : Endif
If clalev([F:DAEB])=0 : Local File GACCENTRYD [DAEB] : Endif
If clalev([F:DAEC])=0 : Local File GACCENTRYD [DAEC] : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:BAL1])=0  : Local File BALANCE [BAL1] Order By Key CLE=CPY;FCY;FIY;ACC;BPR;CUR;LEDTYP : Endif
If clalev([F:BAL2])=0  : Local File BALANCE   [BAL2] : Endif
If clalev([F:GSC])=0  : Local File GRPSAC     [GSC]  : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
If clalev([F:JOU])=0  : Local File GJOURNAL   [JOU]  : Endif
If clalev([F:HAE1])=0 : Local File GACCENTRY  [HAE1] : Endif
If clalev([F:HAT])=0  : Local File GACCTMP    [HAT]  : Endif
Return

##############################################################################################################
# Génération écarts de conversion
##############################################################################################################
$EXEC
If GSERVEUR
 [M:DIA]TRACE = 2
Endif

If !GSERVEUR & [M:DIA]TRACE=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRACE=2
 Call ECR_TRACE(mess(55,107,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Call ECR_TRACE(mess(14,103,1)-":",0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(3466,200,1))+" : "+mess([M:DIA]TYPECART,3666,1),0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(28,111,1))+" : "+[M:DIA]GRPSOC,0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(208,111,1))+" : "+mess([M:DIA]LEDTYP,2644,1),0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(26,113,1))+" : ",0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 For I=0 To [M:DIA]NBSOC-1
  If [M:DIA]SOC(I)="" : Break : Endif
  Call ECR_TRACE([M:DIA]SOC(I),0) From GESECRAN
 Next
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 If [M:DIA]TOUSIT = 2
  Call ECR_TRACE(format$("K:30X",mess(3,45,1))+" : "+mess(20,197,1),0) From GESECRAN
 Else
  Call ECR_TRACE(format$("K:30X",mess(3,45,1))+" : "+[M:DIA]SITE,0) From GESECRAN
 Endif
 If [M:DIA]TOUCOL = 2
  Call ECR_TRACE(format$("K:30X",mess(27,102,1))+" : "+mess(20,197,1)+space$(15)+format$("K:20X",mess(100,102,1))+" : "+[M:DIA]GRPCOL,0) From GESECRAN
 Else
  Call ECR_TRACE(format$("K:30X",mess(27,102,1))+" : "+[M:DIA]COLL+space$(15)+format$("K:20X",mess(100,102,1))+" : "+[M:DIA]GRPCOL,0) From GESECRAN
 Endif
 Call ECR_TRACE(format$("K:30X",mess(88,100,1))+" : "+mess(94,100,1)-format$("DD2",[M:DIA]DATDEB)-mess(95,100,1)-format$("DD2",[M:DIA]DATFIN),0) From GESECRAN
 If [M:DIA]TYPCOL<>0
  Call ECR_TRACE(format$("K:30X",mess(77,200,1))+" : "+mess([M:DIA]TYPCOL,277,1),0) From GESECRAN
 Else
  Call ECR_TRACE(format$("K:30X",mess(77,200,1))+" : ",0) From GESECRAN
 Endif
 If [M:DIA]CPTDEB<>""
  Call ECR_TRACE(format$("K:30X",mess(45,102,1))+" : "+mess(94,100,1)-[M:DIA]CPTDEB-mess(95,100,1)-[M:DIA]CPTFIN,0) From GESECRAN
 Else
  Call ECR_TRACE(format$("K:30X",mess(45,102,1))+" : ",0) From GESECRAN
 Endif
 If [M:DIA]BPRDEB<>""
  Call ECR_TRACE(format$("K:30X",mess(142,121,1))+" : "+mess(94,100,1)-[M:DIA]BPRDEB-mess(95,100,1)-[M:DIA]BPRFIN,0) From GESECRAN
 Else
  Call ECR_TRACE(format$("K:30X",mess(142,121,1))+" : ",0) From GESECRAN
 Endif
 Call ECR_TRACE(format$("K:30X",mess(86,100,1))+" : "+mess([M:DIA]COURTYP,202,1),0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(164,105,1))+" : "+format$("DD2",[M:DIA]COURDAT),0) From GESECRAN
 If [M:DIA]TYPECART=2
  Call ECR_TRACE(format$("K:30X",mess(3428,200,1))+" : "+mess([M:DIA]EVALTYP,3628,1),0) From GESECRAN
 Endif
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(0,106,1))+" : "-mess([M:DIA]GENECR,1,1),0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(169,115,1))+" : "-mess([M:DIA]TRACE,1,1),0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(29,115,1))+" : "-mess([M:DIA]TYP,639,1),0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(22,104,1))+" : "-mess([M:DIA]STA,617,1),0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(10,105,1))+" : "-[M:DIA]TYPPCE,0) From GESECRAN
 Call ECR_TRACE(format$("K:30X",mess(13,105,1))+" : "-[M:DIA]JOU,0) From GESECRAN
 If [M:DIA]DATPCE<>[0/0/0]
  Call ECR_TRACE(format$("K:30X",mess(2,2605,1))+" : "-format$("DD2",[M:DIA]DATPCE),0) From GESECRAN
 Else
  Call ECR_TRACE(format$("K:30X",mess(2,2605,1))+" : ",0) From GESECRAN
 Endif
 If [M:DIA]DATEXT<>[0/0/0]
  Call ECR_TRACE(format$("K:30X",mess(165,105,1))+" : "-format$("DD2",[M:DIA]DATEXT),0) From GESECRAN
 Else
  Call ECR_TRACE(format$("K:30X",mess(165,105,1))+" : ",0) From GESECRAN
 Endif
Endif

Gosub ECART

If !GSERVEUR & [M:DIA]TRACE=2
 Call FERME_TRACE From LECFIC
Endif
Return

##############################################################################################################
$FIN
If !GSERVEUR & [M:DIA]TRACE=2
 TRA = 1
Else
 TRA = 0
Endif
Return

###########################################################################################################
$ECART
Case [M:DIA]TYPECART

 When 2 : # Assessment method = By journal entry

  Local Integer NBDEV, INDDEV, INDLED, NBDEVCUR
  NBDEV = nbrecord([TCU])
  Local Integer ECARTOK, AFF_OK
  Local Integer INDB(1..NBDEV)
  Local Decimal AFF_SOLFRA, AFF_SOLREVAL, AFF_SOLDTIERS

  Local Integer INDB1(1..NBDEV),INDB2(1..NBDEV),INDB3(1..NBDEV),INDB4(1..NBDEV),INDB5(1..NBDEV)
  Local Integer INDB6(1..NBDEV),INDB7(1..NBDEV),INDB8(1..NBDEV),INDB9(1..NBDEV),INDB10(1..NBDEV)
  Local Char    DEVISE1(GLONCUR)(1..NBDEV),DEVISE2(GLONCUR)(1..NBDEV),DEVISE3(GLONCUR)(1..NBDEV)
  Local Char    DEVISE4(GLONCUR)(1..NBDEV),DEVISE5(GLONCUR)(1..NBDEV),DEVISE6(GLONCUR)(1..NBDEV)
  Local Char    DEVISE7(GLONCUR)(1..NBDEV),DEVISE8(GLONCUR)(1..NBDEV),DEVISE9(GLONCUR)(1..NBDEV),DEVISE10(GLONCUR)(1..NBDEV)
  Local Decimal SOLDEV1(1..NBDEV),SOLDEV2(1..NBDEV),SOLDEV3(1..NBDEV),SOLDEV4(1..NBDEV),SOLDEV5(1..NBDEV)
  Local Decimal SOLDEV6(1..NBDEV),SOLDEV7(1..NBDEV),SOLDEV8(1..NBDEV),SOLDEV9(1..NBDEV),SOLDEV10(1..NBDEV)
  Local Decimal SOLTRS1,SOLTRS2,SOLTRS3,SOLTRS4,SOLTRS5,SOLTRS6,SOLTRS7,SOLTRS8,SOLTRS9,SOLTRS10
  Local Decimal SOLDTIERS1(1..NBDEV),SOLDTIERS2(1..NBDEV),SOLDTIERS3(1..NBDEV),SOLDTIERS4(1..NBDEV),SOLDTIERS5(1..NBDEV)
  Local Decimal SOLDTIERS6(1..NBDEV),SOLDTIERS7(1..NBDEV),SOLDTIERS8(1..NBDEV),SOLDTIERS9(1..NBDEV),SOLDTIERS10(1..NBDEV)

  Local Decimal SOLFRA1(1..NBDEV),SOLFRA2(1..NBDEV),SOLFRA3(1..NBDEV),SOLFRA4(1..NBDEV),SOLFRA5(1..NBDEV)
  Local Decimal SOLFRA6(1..NBDEV),SOLFRA7(1..NBDEV),SOLFRA8(1..NBDEV),SOLFRA9(1..NBDEV),SOLFRA10(1..NBDEV)
  Local Decimal SOLREVAL1(1..NBDEV),SOLREVAL2(1..NBDEV),SOLREVAL3(1..NBDEV),SOLREVAL4(1..NBDEV),SOLREVAL5(1..NBDEV)
  Local Decimal SOLREVAL6(1..NBDEV),SOLREVAL7(1..NBDEV),SOLREVAL8(1..NBDEV),SOLREVAL9(1..NBDEV),SOLREVAL10(1..NBDEV)
  Local Decimal ECAR1(1..NBDEV),ECAR2(1..NBDEV),ECAR3(1..NBDEV),ECAR4(1..NBDEV),ECAR5(1..NBDEV)
  Local Decimal ECAR6(1..NBDEV),ECAR7(1..NBDEV),ECAR8(1..NBDEV),ECAR9(1..NBDEV),ECAR10(1..NBDEV)

  # This variable tells us if the CNVECAR's entry points is used
  Local Integer CALL_PT : Raz CALL_PT
  If dim(GNBENTREE)>0 & GNBENTREE>0 & find("CNVECAR",GENTSTD(1..GNBENTREE)) : CALL_PT=1 : Endif

 When 3 : # Assessment method = By account balance
  Local Integer NBCUR, INDCUR, INDLED, NBRCUR
  NBCUR = nbrecord([TCU])
  Local Integer VARIANOK, VARIAN                     : # Difference of rate=> variance
  Local Integer TO_DISLAY                            : # Indicates if titles have to be displayed
  Local Char    CUR_TRS(GLONCUR)(1..NBCUR)           : # List of transaction currencies used in balance
  # Balance in the ledger currency for the ledgers 1...10, for each transaction currency
  Local Decimal BLCLED1(1..NBCUR), BLCLED2(1..NBCUR), BLCLED3(1..NBCUR), BLCLED4(1..NBCUR), BLCLED5(1..NBCUR)
  Local Decimal BLCLED6(1..NBCUR), BLCLED7(1..NBCUR), BLCLED8(1..NBCUR), BLCLED9(1..NBCUR), BLCLED10(1..NBCUR)
  # Revalued balance in the ledger currency for the ledgers 1...10, for each transaction currency
  Local Decimal BLCLEDREV1(1..NBCUR), BLCLEDREV2(1..NBCUR), BLCLEDREV3(1..NBCUR), BLCLEDREV4(1..NBCUR)
  Local Decimal BLCLEDREV5(1..NBCUR), BLCLEDREV6(1..NBCUR), BLCLEDREV7(1..NBCUR), BLCLEDREV8(1..NBCUR)
  Local Decimal BLCLEDREV9(1..NBCUR), BLCLEDREV10(1..NBCUR)
  # Variance: balance - revalued balance in the ledger currency  for the ledgers 1...10, for each transaction currency
  Local Decimal VARIAN1(1..NBCUR), VARIAN2(1..NBCUR), VARIAN3(1..NBCUR), VARIAN4(1..NBCUR), VARIAN5(1..NBCUR)
  Local Decimal VARIAN6(1..NBCUR), VARIAN7(1..NBCUR), VARIAN8(1..NBCUR), VARIAN9(1..NBCUR), VARIAN10(1..NBCUR)

  Local Integer INDB1(1..NBCUR), INDB2(1..NBCUR), INDB3(1..NBCUR), INDB4(1..NBCUR), INDB5(1..NBCUR)
  Local Integer INDB6(1..NBCUR), INDB7(1..NBCUR), INDB8(1..NBCUR), INDB9(1..NBCUR), INDB10(1..NBCUR)
  Local Decimal BLCCUR                               : # Balance in the transaction currency
  Local Char    LET_BLC(1)                           : # C for Credit balance D for debit balance
  Local Decimal AMTLEDREV                            : # Revalued amont in ledger currency
  Local Char    LIN_TYPLED(114)                      : # Line to display if an automatic ledger has a variance
 Endcase

Local Integer NBSOC
TYPLED = [M:DIA]LEDTYP

# go through all entered companies
For [L]NBSOC=0 To [M:DIA]NBSOC-1
 PLAN      = [M:DIA]COA
 SOCIETE   = [M:DIA]SOC([L]NBSOC)
 DATPCE    = [M:DIA]DATPCE
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 PCEAUTO = ""
 Call PARAML(SOCIETE,"GAUCNV",PCEAUTO) From ADOVAL
 If PCEAUTO="" : PCEAUTO = "CNVEC" : Endif

 Call LECLED(SOCIETE,TYPLED,LEDCUR,DEVLED) From CPTDIV
 ILED = find(LEDCUR,GLED(1..GLEDNBR))
 If !ILED : Return : Endif

 GSOCIETE = SOCIETE
 Gosub TRTSOC
Next
Return

###########################################################################################################
$TRTSOC
Call LOCKCPY(SOCIETE,OKSOC) From AX3MONO
If OKSOC
 # go through all sites of a given company (SOCIETE)
 Call LEC_COA(PLAN) From CPTLEC
 If [F:COA]ACCMIS(4)="" | [F:COA]ACCMIS(5)="" | [F:COA]ACCMIS(6)="" | [F:COA]ACCMIS(7)=""
  If [M:DIA]TRACE=2
   Call ECR_TRACE(mess(56,107,1),1) From GESECRAN
  Endif
  Goto LOG_ENDSIT
 Endif

 If [M:DIA]TYPECART=3
  Call GETPERSOC(SOCIETE,TYPLED,[M:DIA]DATDEB,EDEB,PDEB) From CPTSUB
  Call GETPERSOC(SOCIETE,TYPLED,[M:DIA]DATFIN,EFIN,PFIN) From CPTSUB
  If EDEB<>EFIN
   # period is overlapping two fiscal years
   If [M:DIA]TRACE=2 : Call ECR_TRACE(mess(57,107,1),1) From GESECRAN : Endif
   Goto LOG_ENDSIT
  Else
   EXER = EDEB
   STAT = func FINPER_SYRA.GET_FIYDATES(GACTX, SOCIETE, TYPLED, EXER, STRDAT, ENDDAT, GMESSAGE)
   If STRDAT=[M:DIA]DATDEB
    CARRY_FORWARD = 1
   Else
    CARRY_FORWARD = 0
   Endif
  Endif
 Endif

 For [FCY]FCY1 Where LEGCPY=SOCIETE & FINFLG=2
  OK = 1
  # if 'All sites' unticked, check if selected site = entered site
  If [M:DIA]TOUSIT<>2
   OK *= ([F:FCY]FCY=[M:DIA]SITE)
  Endif
  If OK
   SITE = [F:FCY]FCY
   # Records for the same site, are waiting for the CNVECAR posting
   Filter [HAT] Where FCY=SITE & REFINT="CNVEC"
   Look [HAT]HAT0 First
   If !fstat
    OK = 0
    Call ECR_TRACE(mess(2,116,1)-SOCIETE-mess(5,116,1)-SITE-":"-mess(128,117,1),1) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
   Endif
   Filter [HAT]
   # End 116067
   If OK
    SYMBOLE = "CNVECAR\"+SITE
    Lock =SYMBOLE
    If fstat
     OK = 0
     Call ECR_TRACE(mess(2,116,1)-SOCIETE-mess(5,116,1)-SITE-":"-mess(30,100,1),1) From GESECRAN
     Call ECR_TRACE("",0) From GESECRAN
    Endif
   Endif
   If OK
    Gosub TRTSIT
    Unlock =SYMBOLE
   Endif
  Endif
 Next
Endif
Call UNLOCKCPY() From AX3MONO
Return

###########################################################################################################
$TRTSIT
# Contrôles préliminaires
If [M:DIA]TRACE=2
 # write company and site to trace
 Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
 Call ECR_TRACE(mess(2,116,1)-SOCIETE-mess(5,116,1)-SITE,0) From GESECRAN
 Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
Endif

# Reset Total
For INDLED=1 To len(mess(0,2644,1))
 Raz TOTBLCLED(INDLED)
 Raz TOTBLCLEDREV(INDLED)
 Raz TOTVARIAN(INDLED)
Next

#Verification que les comptes d'écart sont renseignés

# all collectives
If [M:DIA]TOUCOL=2
 For [GACC]GAC1 Where COA=PLAN & ACCSHO>"" & AUZBPR([M:DIA]TYPCOL-1)=2
  COLL = [F:GACC]ACCSHO
  Gosub TRTCOL
 Next

# collective group
Elsif [M:DIA]GRPCOL<>""
  Filter [GSC] Where [F:GSC]COA=PLAN & [F:GSC]GRU=[M:DIA]GRPCOL
  For [GSC]
   COLL = [F:GSC]SAC
   Read [GACC]GAC1 = PLAN;COLL
   Gosub TRTCOL
  Next
  Filter [GSC]

# single collective
Elsif [M:DIA]COLL<>""
 Read [GACC]GAC1 = PLAN;[M:DIA]COLL
 COLL = [M:DIA]COLL
 Gosub TRTCOL

# empty collective
Else
 COLL = "" : Gosub TRTCOL
Endif

###########################################################################################################
$LOG_ENDSIT
If [M:DIA]TRACE=2
 If [M:DIA]TYPECART=3
  TO_DISPLAY = 0
  For INDLED=1 To len(mess(0,2644,1))
   If TOTBLCLEDREV(INDLED)<>0 | TOTVARIAN(INDLED)<>0

    If TOTBLCLEDREV(INDLED)>0
     LET_BLC = "D"
    Else
     LET_BLC = "C"
    Endif

    If TO_DISPLAY=0
     Call ECR_TRACE("",0) From GESECRAN
     Call ECR_TRACE(format$("K:10X",mess(115,102,1))+format$("K:52X",mess(INDLED,2644,1))
&                  +format$("K:2X",LET_BLC)+format$("K:15X",num$(TOTBLCLED(INDLED)))+space$(6)
&                  +format$("K:2X",LET_BLC)+format$("K:15X",num$(TOTBLCLEDREV(INDLED)))
&                  +format$("K:12X",num$(TOTVARIAN(INDLED))),0) From GESECRAN
     TO_DISPLAY = 1
    Else
     Call ECR_TRACE(space$(10)+format$("K:52X",mess(INDLED,2644,1))
&                  +format$("K:2X",LET_BLC)+format$("K:15X",num$(TOTBLCLED(INDLED)))+space$(6)
&                  +format$("K:2X",LET_BLC)+format$("K:15X",num$(TOTBLCLEDREV(INDLED)))
&                  +format$("K:12X",num$(TOTVARIAN(INDLED))),0) From GESECRAN
    Endif

   Endif
  Next
 Endif
 Call ECR_TRACE(string$(114,"-"),0) From GESECRAN
Endif
Return

###########################################################################################################
$TRTCOL
# Elimination des simulations
SIMTYP = "EC"+"_"+COLL+"_"+SITE+"_"+num$(LEDTYP)
Gosub ANUPCE
If GOK<1 : Return : Endif

# Remplissage Table tempo
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
# start transaction with temporary table TMPCNVECAR
Trbegin [TCE]
 Call LEC_COA(PLAN) From CPTLEC :# Issue X3-98708
 Gosub CONV_ECART
 If GOK=1
  GPOINT = "AFTCALCNV" : Gosub ENTREE From EXEFNC
 Endif
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

###########################################################################################################
$CONV_ECART
Raz NUMERO
# empty TMPCNVECAR
Delete [TCE] Where SITE=[L]SITE

Case [M:DIA]TYPECART
 When 2 : # By journal entry
  Gosub JOURNAL_ENTRY
 When 3 : # By account balance
  Gosub ACCOUNT_BALANCE
Endcase

STAT = 0
TO_DISPLAY=0
GOK=1
For I=1 To dim(TZONE)
 Raz TZONE(I)
 Raz TVAL(I)
Next

If [M:DIA]GENECR=2
 TZONE(1) = "CAT"    : TVAL(1) = num$([M:DIA]TYP)
 If [M:DIA]TYP=1
  TZONE(3) = "REFSIM" : TVAL(3) = ""
 Else
  TZONE(3) = "REFSIM" : TVAL(3) = [L]SIMTYP
 Endif
 TZONE(4) = "TYP"    : TVAL(4) = [M:DIA]TYPPCE
 TZONE(5) = "JOU"    : TVAL(5) = [M:DIA]JOU
 TZONE(6) = "FCY"    : TVAL(6) = SITE
Endif
TZONE(7) = "REFINT" : TVAL(7) = "CNVEC"

TZONE(8)="ORIGIN" : TVAL(8)="2"               : # X3-39795 MWA Automatic loading
TZONE(9)="ORICOD" : TVAL(9)= [L]PCEAUTO       : # X3-39795 MWA

For [TCE]TCE0 Where SITE=[L]SITE
 STAT=0

 Call LEC_CPY([F:TCE]SOC) From CPTLEC
 STAECT = [M:DIA]STA : TVAL(2)=num$(STAECT)
 If [M:DIA]TYP=1 & func AFNC.PARAM("FRADGI",[F:TCE]SOC)="2"
  STAECT = 2 : TVAL(2)=num$(STAECT)
 Endif
 TZONE(2)="STA"    : TVAL(2)=num$(STAECT)

 IDENT(1) = num$([F:TCE]LEDTYP)
 IDENT(2) = [F:TCE]SOC
 IDENT(3) = [F:TCE]SITE
 IDENT(4) = num$([F:TCE]NUM)
 IDENT(5) = [F:TCE]DEV

 If [M:DIA]GENECR=2
  Call VALPCE3([L]PCEAUTO,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
 Else
  Call SIMPCE3([L]PCEAUTO,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
 Endif

 If STAT
  # Erreur en création de pièce automatique
  MESSA = MESSA-"("-num$(STAT)-")"
  If [M:DIA]TRACE=2 : Call ECR_TRACE(MESSA,1) From GESECRAN : Endif
  GOK=0 : Break
 Else
  If [M:DIA]GENECR=2
   If [M:DIA]TYP=1 & [M:DIA]STA<>STAECT
    MESSA=mess(40,107,1)-GTYPPCE-MESSA-"("+tolower(mess(192,107,1))+")"
   Else
    MESSA=mess(40,107,1)-GTYPPCE-MESSA
   Endif
  Endif

  If [M:DIA]TRACE=2 & MESSA<>""
   If TO_DISPLAY=0
    Call ECR_TRACE("",0) From GESECRAN
    TO_DISPLAY=1
   Endif
   Call ECR_TRACE(MESSA,0) From GESECRAN
  Endif

 Endif
Next
Return

###########################################################################################################
$ANUPCE
GOK=1
For [HAE1] Where REFSIM=SIMTYP  & CAT>1
 If [M:DIA]TRACE=2
  Call ECR_TRACE(mess(41,107,1)-[F:HAE1]TYP-[F:HAE1]NUM,0) From GESECRAN
 Endif
 # Annulation pièce
 Call DELPCE([F:HAE1]TYP,[F:HAE1]NUM) From CPTBATCH
 If GOK<1 : Break : Endif
Next
Return

####################################################################################################
## ACCOUNT BALANCE
####################################################################################################
$ACCOUNT_BALANCE
TO_DISPLAY = 0

# Get the automatic ledgers of the current ledger
Call GETTYPLEDVLDAUT(SOCIETE,TYPLED,TYPLEDVLDAUT,NBRVLDAUT) From CPTDIV

If COLL=""
 FILTRE = 'COA="'+PLAN+'" & DIF=3 & SAC<>2'
 If [M:DIA]CPTDEB<>"" : FILTRE -= '& ACC>="'+[M:DIA]CPTDEB+'"' : Endif
 If [M:DIA]CPTFIN<>"" : FILTRE -= '& ACC<="'+[M:DIA]CPTFIN+'"' : Endif

 For [GACC]GAC0 Where evalue(FILTRE)
  TIERS  = ""
  COMPTE = [F:GACC]ACC
  # Search the right rate to calculate the variance
  If [F:GACC]TYPRATFLG<>2
   [L]GACTYPRAT = [M:DIA]COURTYP
  Else
   [L]GACTYPRAT = [F:GACC]TYPRAT
  Endif
  Gosub BLC_ACC
 Next

Else

 If [F:GACC]DIF<>3 : Return : Endif
 COMPTE = [F:GACC]ACC
 # Search the right rate to calculate the variance
 If [F:GACC]TYPRATFLG<>2
  [L]GACTYPRAT = [M:DIA]COURTYP
 Else
  [L]GACTYPRAT = [F:GACC]TYPRAT
 Endif
 FILTRE = 'LEDTYP='+num$(TYPLED)+' & CPY="'+SOCIETE+'" & FCY="'+SITE+'" & ACC="'+COMPTE+'" & FIY='+num$(EXER)
 If [M:DIA]BPRDEB<>""
  FILTRE -= '& BPR>="'+[M:DIA]BPRDEB+'"'
 Endif
 If [M:DIA]BPRFIN<>""
  FILTRE -= '& BPR<="'+[M:DIA]BPRFIN+'"'
 Endif
 # Do not take BPR=null because BPRDEB and BPRFIN are mandatory if COLL<>""
 For [BAL2]BAL0(6) Where evalue(FILTRE)
  TIERS = [F:BAL2]BPR
  Gosub BLC_ACC
 Next
Endif
Return

####################################################################################################
$BLC_ACC
Raz VARIAN, VARIANOK, NBRCUR
For I=1 To NBRCUR
 Raz BLCLED1(I),BLCLED2(I),BLCLED3(I),BLCLED4(I),BLCLED5(I),BLCLED6(I),BLCLED7(I),BLCLED8(I),BLCLED9(I),BLCLED10(I)
 Raz BLCLEDREV1(I),BLCLEDREV2(I),BLCLEDREV3(I),BLCLEDREV4(I),BLCLEDREV5(I),BLCLEDREV6(I),BLCLEDREV7(I),BLCLEDREV8(I)
 Raz BLCLEDREV9(I),BLCLEDREV10(I)
 Raz VARIAN1(I),VARIAN2(I),VARIAN3(I),VARIAN4(I),VARIAN5(I),VARIAN6(I),VARIAN7(I),VARIAN8(I),VARIAN9(I),VARIAN10(I)
Next

 # Account balance in ledger currency (DEBLED & CDTLED) and in transaction currency (DEB,CDT)
Filter [BAL1] Where CPY=SOCIETE & FCY=SITE & FIY=EXER & ACC=COMPTE & BPR=TIERS
# Loop on currency
For [BAL1]CLE(6)
 # Search the index of the currency
 INDCUR = 0
 For I=1 To NBRCUR
  If CUR_TRS(I) = [F:BAL1]CUR
   INDCUR = I : Break
  Endif
 Next
 If !INDCUR
  NBRCUR +=1
  CUR_TRS(NBRCUR) = [F:BAL1]CUR
  INDCUR = NBRCUR
 Endif
 Raz LIN_TYPLED
 # Loop on ledger type
 For [BAL1]CLE(7)
  #Reset
  Raz I_TYPLED
  Raz CURLED, LET_BLC

  If [F:BAL1]LEDTYP=TYPLED
   I_TYPLED = TYPLED
   CURLED = DEVLED
  Else
   INDLED = find([F:BAL1]LEDTYP,TYPLEDVLDAUT)
   If INDLED
    I_TYPLED = TYPLEDVLDAUT(INDLED)
    STAT = func FINACM_SYRA.GET_LEDCUR(GACTX,SOCIETE,TYPLEDVLDAUT(INDLED),CODLEDVLDAUT,CURLED,GMESSAGE)
   Endif
  Endif

  If I_TYPLED<>0
   If CARRY_FORWARD=1
    BLCCUR = sum([F:BAL1]DEB(0..PFIN)) - sum([F:BAL1]CDT(0..PFIN))
    Assign "BLCLED"+num$(I_TYPLED)+"("+num$(INDCUR)+")" With sum([F:BAL1]DEBLED(0..PFIN)) - sum([F:BAL1]CDTLED(0..PFIN))
   Else
    BLCCUR = sum([F:BAL1]DEB(1..PFIN)) - sum([F:BAL1]CDT(1..PFIN))
    Assign "BLCLED"+num$(I_TYPLED)+"("+num$(INDCUR)+")" With sum([F:BAL1]DEBLED(1..PFIN)) - sum([F:BAL1]CDTLED(1..PFIN))
   Endif
   # Letter for sign of balance
   If BLCCUR>0 : LET_BLC = "D" : Endif
   If BLCCUR<0 : LET_BLC = "C" : Endif
   # Calculation of the reevaluated theoritical balance
   Call CONVERT([F:BAL1]CUR,CURLED,CURLED,[L]GACTYPRAT,[M:DIA]COURDAT,BLCCUR,AMTLEDREV,STAT) From TRTDEV
   If STAT
    If [M:DIA]TRACE=2 : Call ECR_TRACE(COMPTE-":"-mess(4,109,1)-[F:BAL1]CUR-"=>"-CURLED,1) From GESECRAN : Endif
    Break 2
   Else
    Assign "BLCLEDREV"+num$(I_TYPLED)+"("+num$(INDCUR)+")" With AMTLEDREV
   Endif

   # Calculation of the rate
   Call CONVERT([F:BAL1]CUR,CURLED,CURLED,[L]GACTYPRAT,[M:DIA]COURDAT,10^GDECRCU,RATETHEO,STAT) From TRTDEV
   If !STAT : RATETHEO = arr(RATETHEO/10^GDECRCU, 10^-GDECRCU) : Endif

   # Calculation of the conversion variance
   Assign "VARIAN"+num$(I_TYPLED)+"("+num$(INDCUR)+")"
&  With evalue("BLCLEDREV"+num$(I_TYPLED)+"("+num$(INDCUR)+")") - evalue("BLCLED"+num$(I_TYPLED)+"("+num$(INDCUR)+")")

   If evalue("VARIAN"+num$(I_TYPLED)+"("+num$(INDCUR)+")")<>0
    VARIAN = 1
    VARIANOK=1
   Else
    VARIAN= 0
   Endif

   # Display a line for the general ledeger that has no variance, if ana automatic ledger has a variance
   If VARIAN=0 & TYPLED=I_TYPLED & CURLED=[F:BAL1]CUR & [M:DIA]TRACE = 2
    LIN_TYPLED = format$("K:10X",mess(I_TYPLED,2644,1))+format$("K:10X",COMPTE)+format$("K:10X",TIERS)
&     +format$("K:7X",[F:BAL1]CUR)+format$("K:2X",LET_BLC)+format$("K:15X",num$(BLCCUR))+format$("K:8X",CURLED)
&     +format$("K:2X",LET_BLC)+format$("K:15X",num$(evalue("BLCLED"+num$(I_TYPLED)+"("+num$(INDCUR)+")")))
&     +format$("K:6X",num$(1))+format$("K:2X",LET_BLC)+format$("K:15X",num$(evalue("BLCLEDREV"+num$(I_TYPLED)+"("+num$(INDCUR)+")")))
&     +format$("K:12X",num$(0))
   Endif

   If VARIAN=1 & [M:DIA]TRACE = 2
    If !TO_DISPLAY # pour affichage du compte/tiers
     # Columns titles: Type.Compte.Tiers.Devise.Solde devise.Devise réf.Solde référentiel.Cours.Solde référentiel réévalué.Ecart
     Call ECR_TRACE(format$("K:10X",mess(59,100,1))+format$("K:10X",mess(45,102,1))+format$("K:10X",mess(410,107,1))
&     +format$("K:8X",mess(411,107,1))+format$("K:16X",mess(412,107,1))+format$("K:8X",mess(149,2288,1))
&     +format$("K:17X",mess(150,2288,1))+format$("K:6X",mess(19,105,1))+format$("K:17X",mess(408,107,1))
&     +format$("K:12X",mess(409,107,1)),0) From GESECRAN
     Call ECR_TRACE(string$(114,"-"),0) From GESECRAN
     TO_DISPLAY = 1
    Endif

    If I_TYPLED<>TYPLED
     # Display the general ledger if no variance is calculated on it
     If LIN_TYPLED<>""
      Call ECR_TRACE(LIN_TYPLED,0) From GESECRAN
      TOTBLCLED(TYPLED)    += evalue("BLCLED"+num$(TYPLED)+"("+num$(INDCUR)+")")
      TOTBLCLEDREV(TYPLED) += evalue("BLCLEDREV"+num$(TYPLED)+"("+num$(INDCUR)+")")
      TOTVARIAN(TYPLED)    += evalue("VARIAN"+num$(TYPLED)+"("+num$(INDCUR)+")")
      Raz LIN_TYPLED
     Endif
     Call ECR_TRACE(space$(3)+format$("K:10X",mess(I_TYPLED,2644,1))+space$(41)+format$("K:8X",CURLED)
&     +format$("K:2X",LET_BLC)+format$("K:15X",num$(evalue("BLCLED"+num$(I_TYPLED)+"("+num$(INDCUR)+")")))
&     +format$("K:6X",num$([L]RATETHEO))+format$("K:2X",LET_BLC)+format$("K:15X",num$(evalue("BLCLEDREV"+num$(I_TYPLED)+"("+num$(INDCUR)+")")))
&     +format$("K:12X",num$(evalue("VARIAN"+num$(I_TYPLED)+"("+num$(INDCUR)+")"))),0) From GESECRAN
    Else
     Call ECR_TRACE(format$("K:10X",mess(I_TYPLED,2644,1))+format$("K:10X",COMPTE)+format$("K:10X",TIERS)
&     +format$("K:7X",[F:BAL1]CUR)+format$("K:2X",LET_BLC)+format$("K:15X",num$(BLCCUR))+format$("K:8X",CURLED)
&     +format$("K:2X",LET_BLC)+format$("K:15X",num$(evalue("BLCLED"+num$(I_TYPLED)+"("+num$(INDCUR)+")")))
&     +format$("K:6X",num$([L]RATETHEO))+format$("K:2X",LET_BLC)+format$("K:15X",num$(evalue("BLCLEDREV"+num$(I_TYPLED)+"("+num$(INDCUR)+")")))
&     +format$("K:12X",num$(evalue("VARIAN"+num$(I_TYPLED)+"("+num$(INDCUR)+")"))),0) From GESECRAN
    Endif
    TOTBLCLED(I_TYPLED)    += evalue("BLCLED"+num$(I_TYPLED)+"("+num$(INDCUR)+")")
    TOTBLCLEDREV(I_TYPLED) += evalue("BLCLEDREV"+num$(I_TYPLED)+"("+num$(INDCUR)+")")
    TOTVARIAN(I_TYPLED)    += evalue("VARIAN"+num$(I_TYPLED)+"("+num$(INDCUR)+")")
   Endif

   If evalue("BLCLED"+num$(I_TYPLED)+"("+num$(INDCUR)+")")>0 : # Débit  => créance
    If evalue("BLCLEDREV"+num$(I_TYPLED)+"("+num$(INDCUR)+")") > evalue("BLCLED"+num$(I_TYPLED)+"("+num$(INDCUR)+")")
     Assign "INDB"+num$(I_TYPLED)+"("+num$(INDCUR)+")" With 3
    Else
     Assign "INDB"+num$(I_TYPLED)+"("+num$(INDCUR)+")" With 1
    Endif
   Else   : # Crédit => dette
    If evalue("BLCLEDREV"+num$(I_TYPLED)+"("+num$(INDCUR)+")") > evalue("BLCLED"+num$(I_TYPLED)+"("+num$(INDCUR)+")")
     Assign "INDB"+num$(I_TYPLED)+"("+num$(INDCUR)+")" With 4
    Else
     Assign "INDB"+num$(I_TYPLED)+"("+num$(INDCUR)+")" With 2
    Endif
   Endif

  Endif

 Next
Next
Filter [BAL1]
If STAT : Return : Endif

Gosub LIGNE

Return

####################################################################################################
## JOURNAL ENTRY
####################################################################################################
$JOURNAL_ENTRY
If COLL=""

 # DIF=2: Balance sheet, SAC<>2: No collective
 FILTRE = 'COA="'+PLAN+'" & DIF=2 & SAC<>2'
 If [M:DIA]CPTDEB<>"" : FILTRE -= '& ACC>="'+[M:DIA]CPTDEB+'"' : Endif
 If [M:DIA]CPTFIN<>"" : FILTRE -= '& ACC<="'+[M:DIA]CPTFIN+'"' : Endif
 For [GACC]GAC0 Where evalue(FILTRE)
  FLGECART = 0 : NBDEVCUR = 0
  COMPTE = [F:GACC]ACC :  TIERS = ""
  If [F:GACC]TYPRATFLG<>2
   [L]GACTYPRAT = [M:DIA]COURTYP
  Else
   [L]GACTYPRAT = [F:GACC]TYPRAT
  Endif
  Gosub JOU_ACC
 Next

Else

 If [F:GACC]DIF<>2 : Return : Endif
 COMPTE = [F:GACC]ACC
 If [F:GACC]TYPRATFLG<>2
  [L]GACTYPRAT = [M:DIA]COURTYP
 Else
  [L]GACTYPRAT = [F:GACC]TYPRAT
 Endif
 FILTRE = 'LEDTYP='+num$(TYPLED)+' & CPY="'+SOCIETE+'" & FCYLIN="'+SITE+'" & ACC="'+COMPTE+'"'
 If [M:DIA]BPRDEB<>""
  FILTRE -= '& BPR>="'+[M:DIA]BPRDEB+'"'
 Endif
 If [M:DIA]BPRFIN<>""
  FILTRE -= '& BPR<="'+[M:DIA]BPRFIN+'"'
 Endif
 FILTRE -= '& ACCDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'
 FILTRE -= '& ACCDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
 For [DAEA]DAE1(5) Where evalue(FILTRE)
  TIERS = [F:DAEA]BPR
  FLGECART = 0 : NBDEVCUR = 0
  For INDDEV=1 To NBDEV
   For INDLED=1 To MAXLED
    Assign "SOLDTIERS"+num$(INDLED)+"("+num$(INDDEV)+")" With 0
   Next INDLED
  Next
  Gosub JOU_ACC
  If FLGECART & [M:DIA]TRACE=2
   Call ECR_TRACE("",0) From GESECRAN
   AFF_OK = 0
   For INDDEV=1 To NBDEVCUR
    # Devise
    AFF_SOLDTIERS = evalue("SOLDTIERS"+num$(TYPLED)+"("+num$(INDDEV)+")")
    If AFF_SOLDTIERS<>0
     Call ECR_TRACE(mess(18,105,1)-evalue("DEVISE"+num$(TYPLED)+"("+num$(INDDEV)+")"),0) From GESECRAN : AFF_OK = 1
     If AFF_SOLDTIERS>0
      # TOTAL *référentiel*tiers Gain
      Call ECR_TRACE(mess(115,102,1)-mess(TYPLED,2644,1)-TIERS-":"-num$(AFF_SOLDTIERS)-"("+mess(38,853,1)+")",0) From GESECRAN
     Elsif AFF_SOLDTIERS<0
      # TOTAL *référentiel*tiers Perte
      Call ECR_TRACE(mess(115,102,1)-mess(TYPLED,2644,1)-TIERS-":"-num$(AFF_SOLDTIERS)-"("+mess(39,853,1)+")",0) From GESECRAN
     Else
      # TOTAL *référentiel*tiers
      Call ECR_TRACE(mess(115,102,1)-mess(TYPLED,2644,1)-TIERS-":"-num$(AFF_SOLDTIERS),0) From GESECRAN
     Endif
    Endif
    For INDLED=1 To MAXLED+1
     If TYPLED<>INDLED
      AFF_SOLDTIERS = evalue("SOLDTIERS"+num$(INDLED)+"("+num$(INDDEV)+")")
      If AFF_OK=0 & AFF_SOLDTIERS
       Call ECR_TRACE(mess(18,105,1)-evalue("DEVISE"+num$(TYPLED)+"("+num$(INDDEV)+")"),0) From GESECRAN :    AFF_OK = 1
      Endif
      If AFF_SOLDTIERS>0
       # TOTAL *référentiel*tiers Gain
       Call ECR_TRACE(mess(115,102,1)-mess(INDLED,2644,1)-TIERS-":"-num$(AFF_SOLDTIERS)-"("+mess(38,853,1)+")",0) From GESECRAN
      Elsif AFF_SOLDTIERS<0
       # TOTAL *référentiel*tiers Gain
       Call ECR_TRACE(mess(115,102,1)-mess(INDLED,2644,1)-TIERS-":"-num$(AFF_SOLDTIERS)-"("+mess(39,853,1)+")",0) From GESECRAN
      Endif
     Endif
    Next
   Next
  Endif
 Next
Endif
Return

####################################################################################################
$JOU_ACC
##
## On parcourt toutes les écritures (lettrées ou non)
## par groupe de lettrage (mono ou multi-devises)
## A l'intérieur d'un groupe de lettrage on ne prend en compte que les écritures
## dont la date comptable est inférieure ou égale à la date de fin de période
## On considère le groupe de lettrage si
## 1) Il y a au moins une écriture sur la période
## 2) Il y a au moins une devise "out", ou la devise de société est "out"
## 3) Il y a au moins une devise différente de la devise de société
## 4) Soit le lettrage est minuscule, soit il y au moins une écriture non prise en compte
##
## Nb : Une devise cochée "euro" est considérée "in" quelle que soit la date de pièce
##      et la date de passage de l'euro.
##
## Une écriture d'écart de change est réactualisée à 0
## (une écriture d'écart de change est réputée comme telle si la pièce mouvemente
##  un compte d'écrat de change CNVACC5 ou CNVACC6, ou si REFINT="MTC3")
##

GPE = 0
GPOINT =  "CALBSEDIF" : Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif

Raz INDB

FILECT  = 'LEDTYP='+num$(TYPLED)+' & CPY="'+SOCIETE+'" & FCYLIN="'+SITE+'"'
FILECT -= '& ACC="'+COMPTE+'" & BPR="'+TIERS+'"'

## Filtre non optimum, mais on fait ce qu'on peut
FILECT -= '& (MTC<"A" | MTC>"ZZZZZ" | MTCDATMAX>['+format$(GFMD,[M:DIA]DATFIN)+'])'

# If ledger cur is euro currency, load all euro currencies in DEVIN
Call LEC_TCU(DEVLED) From CPTLEC
If [F:TCU]EURFLG=2
 FLEURO = 1 # euro flag
 If [F:TCU]EURRAT=1 : FLEURO=0 : Endif
 NBDEVIN = 0
 For [TCU]TCU0 Where EURFLG=2
  NBDEVIN += 1
  DEVIN(NBDEVIN) = [F:TCU]CUR
 Next
Else
 FLEURO = 0
Endif

Raz FILTRE_SPE
If dim(CALL_PT)>0 & CALL_PT : GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC : Endif
If vireblc(FILTRE_SPE,2)="" : FILTRE_SPE="1=1" : Endif

# select accounting entry lines
Filter [DAEB] Where evalue(FILECT) & evalue(FILTRE_SPE)
& Order By Key CLE = MTC;ACCNUM

Local Decimal T_SOLREVAL1(1..NBDEV), T_SOLFRA1(1..NBDEV)
Local Decimal T_SOLREVAL2(1..NBDEV), T_SOLFRA2(1..NBDEV)
Local Decimal T_SOLREVAL3(1..NBDEV), T_SOLFRA3(1..NBDEV)
Local Decimal T_SOLREVAL4(1..NBDEV), T_SOLFRA4(1..NBDEV)
Local Decimal T_SOLREVAL5(1..NBDEV), T_SOLFRA5(1..NBDEV)
Local Decimal T_SOLREVAL6(1..NBDEV), T_SOLFRA6(1..NBDEV)
Local Decimal T_SOLREVAL7(1..NBDEV), T_SOLFRA7(1..NBDEV)
Local Decimal T_SOLREVAL8(1..NBDEV), T_SOLFRA8(1..NBDEV)
Local Decimal T_SOLREVAL9(1..NBDEV), T_SOLFRA9(1..NBDEV)

# init arrays with 0
For INDDEV=1 To NBDEV
 For INDLED=1 To MAXLED
  Assign "T_SOLREVAL"+num$(INDLED)+"("+num$(INDDEV)+")" With 0
  Assign "T_SOLFRA"+num$(INDLED)+"("+num$(INDDEV)+")"   With 0
 Next INDLED
Next

Call GETTYPLEDVLDAUT(SOCIETE,TYPLED,TYPLEDVLDAUT,NBRVLDAUT) From CPTDIV

For [DAEB]CLE(1)

 LETCUR = [F:DAEB]MTC
 DEVCUR = "#"
 OK = 1 : OKDAT = 0 : OKDEV = 0 : OKMAJ = 0 : OKSOC = 0

 If LETCUR<>""
  Raz MTCTYP, MTCNUM, OLDACCNUM
  For INDDEV=1 To NBDEV
   For INDLED=1 To MAXLED
    Assign "SOLREVAL"+num$(INDLED)+"("+num$(INDDEV)+")" With 0
    Assign "SOLFRA"+num$(INDLED)+"("+num$(INDDEV)+")"   With 0
   Next INDLED
  Next

  For INDLED=1 To MAXLED
   Assign "SOLTRS"+num$(INDLED)   With 0
  Next

  For [DAEB]CLE
   INDDEV = 0
   For I=1 To NBDEVCUR
    If evalue("DEVISE"+num$(TYPLED)+"("+num$(I)+")") = [F:DAEB]CUR
     INDDEV = I : Break
    Endif
   Next
   If !INDDEV
    NBDEVCUR+=1
    Assign "DEVISE"+num$(TYPLED)+"("+num$(NBDEVCUR)+")" With [F:DAEB]CUR
    INDDEV = NBDEVCUR
   Endif

    # acc date in entered period?
   If [F:DAEB]ACCDAT<=[M:DIA]DATFIN
    If [F:DAEB]ACCDAT>=[M:DIA]DATDEB
     OKDAT = 1
     If [F:DAEB]ACCNUM>OLDACCNUM
      MTCTYP    = [F:DAEB]TYP
      MTCNUM    = [F:DAEB]NUM
      OLDACCNUM = [F:DAEB]ACCNUM
     Endif
    Endif
    # ledger cur != accounting cur
    #If [F:DAEB]CUR<>DEVLED
     OKSOC = 1
    #Endif
    # incoming cur is no euro cur and accounting cur is not in euro curs
    If FLEURO=0 or !find([F:DAEB]CUR,DEVIN(1..NBDEVIN))
     OKDEV = 1
     If DEVCUR="#"
      DEVCUR = [F:DAEB]CUR
     Elsif DEVCUR<>[F:DAEB]CUR
      DEVCUR = ""
     Endif
    Endif
    Assign "SOLTRS"+num$(TYPLED) With evalue("SOLTRS"+num$(TYPLED)) + ([F:DAEB]SNS*[F:DAEB]AMTCUR)
    Assign "SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") + ([F:DAEB]SNS*[F:DAEB]AMTLED)
    Assign "T_SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("T_SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") + ([F:DAEB]SNS*[F:DAEB]AMTLED)

    ## S'agit-il d'un écart de change ?
    Read [HAE]HAE0 = [F:DAEB]TYP;[F:DAEB]NUM
    OKCHG = 0
    If [F:HAE]REFINT="MTC3"
     OKCHG = 1 : # Ecart automatique
    Elsif [F:DAEB]CUR=DEVLED
     For [DAEC]DAE0 Where TYP=[F:DAEB]TYP & NUM=[F:DAEB]NUM
      If [F:DAEC]ACC=[F:COA]ACCMIS(8) or [F:DAEC]ACC=[F:COA]ACCMIS(9)
       OKCHG = 1 : Break
      Endif
     Next
    Endif

    If !OKCHG
     If [F:DAEB]CUR<>DEVLED
       Call CONVERT([F:DAEB]CUR,DEVLED,DEVLED,[L]GACTYPRAT,[M:DIA]COURDAT,[F:DAEB]AMTCUR,SOLDEV,STAT) From TRTDEV
      If STAT
       If [M:DIA]TRACE=2 : Call ECR_TRACE(COMPTE-":"-mess(4,109,1)-[F:DAEC]CUR-"=>"-DEVLED,1) From GESECRAN : Endif
       OK = -1 : Break 2
      Else
       Assign "SOLDEV"+num$(TYPLED)+"("+num$(INDDEV)+")" With SOLDEV
      Endif
      # save converted amounts in SOL arrays
      Assign "SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")")+([F:DAEB]SNS*SOLDEV)
      Assign "T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")")+([F:DAEB]SNS*SOLDEV)
     Else # [F:DAEB]CUR = DEVLED no conversion was needed
      Assign "SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")")+([F:DAEB]SNS*[F:DAEB]AMTLED)
      Assign "T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")")+([F:DAEB]SNS*[F:DAEB]AMTLED)
     Endif

     #Pour référentiel en valid auto
     For I=1 To NBRVLDAUT
      FILTVLD = 'TYP="'+[F:DAEB]TYP+'" & NUM="'+[F:DAEB]NUM+'" & IDTLIN="'+[F:DAEB]IDTLIN+'" & LEDTYP='+num$(TYPLEDVLDAUT(I))
      For [DAEC]DAE7(3) Where evalue(FILTVLD)
       Assign "SOLFRA"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With evalue("SOLFRA"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")") + ([F:DAEC]SNS*[F:DAEC]AMTLED)
       Assign "T_SOLFRA"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With evalue("T_SOLFRA"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")") + ([F:DAEC]SNS*[F:DAEC]AMTLED)
       If [F:DAEC]CUR<>[F:DAEC]CURLED # entry cur != ledger cur
        Call CONVERT([F:DAEC]CUR,[F:DAEC]CURLED,DEVLED,[L]GACTYPRAT,[M:DIA]COURDAT,[F:DAEC]AMTCUR,SOLDEV,STAT) From TRTDEV
        If STAT
         If [M:DIA]TRACE=2 : Call ECR_TRACE(COMPTE-":"-mess(4,109,1)-[F:DAEC]CUR-"=>"-DEVLED,1) From GESECRAN : Endif
         OK = -1 : Break 3
        Else
         Assign "SOLDEV"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With SOLDEV
        Endif
        Assign "SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With evalue("SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")")+([F:DAEC]SNS*SOLDEV)
        Assign "T_SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With evalue("T_SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")")+([F:DAEC]SNS*SOLDEV)
       Else
        Assign "SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With evalue("SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")")+([F:DAEC]SNS*[F:DAEC]AMTLED)
        Assign "T_SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With evalue("T_SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")")+([F:DAEC]SNS*[F:DAEC]AMTLED)
       Endif
      Next
     Next
    Endif
   Else
    OKMAJ = 1
   Endif
  Next #[DAEB]CLE

  If LETCUR=toupper(LETCUR) & !OKMAJ : OK = 0 : Endif
  If !OKDAT or !OKDEV or !OKSOC : OK = 0 : Endif

  If OK=1
   MESSA = MTCTYP-MTCNUM-"(" + LETCUR + ")"
   If DEVCUR<>"" & DEVCUR<>"#" : MESSA -= "("+DEVCUR+")" : Endif
   AFF_SOLFRA = evalue("SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")")
   AFF_SOLREVAL =  evalue("SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")")
   If !func TAKEINACCOUNT(AFF_SOLREVAL, AFF_SOLFRA) and [F:HAE]REFINT <> 'CNVEC'
    AFF_SOLFRA = 0 : AFF_SOLREVAL = 0
    Assign ("T_SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") With evalue("T_SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") - evalue("SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")")
    Assign ("SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") With 0
    Assign ("T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")") With evalue("T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")") - evalue("SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")")
    Assign ("SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")") With 0
   Endif

   If AFF_SOLREVAL<>AFF_SOLFRA

    If [M:DIA]TRACE=2
     If !FLGECART # pour affichage du compte/tiers
      FLGECART = 1
      Call ECR_TRACE("",0) From GESECRAN
      Call ECR_TRACE([F:DAEB]ACC-TIERS,0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
     Endif
     If DEVCUR<>"" & DEVCUR<>"#"
      Call CONVERT([F:DAEB]CUR,DEVLED,DEVLED,[L]GACTYPRAT,[M:DIA]COURDAT,10^GDECRCU,RATETHEO,STAT) From TRTDEV
      If !STAT : RATETHEO = arr(RATETHEO/10^GDECRCU, 10^-GDECRCU) : Endif

      If AFF_SOLREVAL>AFF_SOLFRA # print conversion line with "profit" or "loss"
       Call ECR_TRACE(mess(TYPLED,2644,1)-MESSA-"=>"-num$(AFF_SOLFRA)-DEVLED-"/"-mess(407,107,1)-num$(RATETHEO)-
&      "=>"-num$(AFF_SOLREVAL)-DEVLED-"/"-mess(38,853,1)-num$(AFF_SOLREVAL-AFF_SOLFRA),0) From GESECRAN
      Else
       Call ECR_TRACE(mess(TYPLED,2644,1)-MESSA-"=>"-num$(AFF_SOLFRA)-DEVLED-"/"-mess(407,107,1)-num$(RATETHEO)-
&      "=>"-num$(AFF_SOLREVAL)-DEVLED-"/"-mess(39,853,1)-num$(AFF_SOLREVAL-AFF_SOLFRA),0) From GESECRAN
      Endif

     Else

      If AFF_SOLREVAL>AFF_SOLFRA# print conversion line with "profit" or "loss"
       Call ECR_TRACE(mess(TYPLED,2644,1)-MESSA-"=>"-num$(AFF_SOLFRA)-DEVLED-"/"-num$(AFF_SOLREVAL)-DEVLED-
&      "/"-mess(38,853,1)-num$(AFF_SOLREVAL-AFF_SOLFRA),0) From GESECRAN
      Else
       Call ECR_TRACE(mess(TYPLED,2644,1)-MESSA-"=>"-num$(AFF_SOLFRA)-DEVLED-"/"-num$(AFF_SOLREVAL)-DEVLED-
&      "/"-mess(39,853,1)-num$(AFF_SOLREVAL-AFF_SOLFRA),0) From GESECRAN
      Endif

     Endif
     Assign "SOLDTIERS"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("SOLDTIERS"+num$(TYPLED)+"("+num$(INDDEV)+")")+AFF_SOLREVAL-AFF_SOLFRA
    Endif # /TRACE
   Endif

   For I=1 To NBRVLDAUT
    STAT = func FINACM_SYRA.GET_LEDCUR(GACTX,SOCIETE,TYPLEDVLDAUT(I),CODLEDVLDAUT,CURLED,GMESSAGE)
    AFF_SOLFRA = evalue("SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")
    AFF_SOLREVAL =  evalue("SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")
    # 82426: compare old and new value and decide whether to take it in account or not
    If !func TAKEINACCOUNT(AFF_SOLREVAL, AFF_SOLFRA) and [F:HAE]REFINT <> 'CNVEC'
     AFF_SOLFRA = 0 : AFF_SOLREVAL = 0
     Assign ("T_SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") With evalue("T_SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") - evalue("SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")
     Assign ("SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") With 0
     Assign ("T_SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") With evalue("T_SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") - evalue("SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+
& ")")
     Assign ("SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") With 0
    Endif
    Assign "SOLDTIERS"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")" With evalue("SOLDTIERS"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")+AFF_SOLREVAL-AFF_SOLFRA
    If AFF_SOLREVAL<>AFF_SOLFRA
     If [M:DIA]TRACE=2
      If !FLGECART # pour affichage du compte/tiers
       FLGECART = 1
       Call ECR_TRACE("",0) From GESECRAN
       Call ECR_TRACE([F:DAEB]ACC-TIERS,0) From GESECRAN
       Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Endif
      # Adding RATETHEO in the log file
      Call CONVERT([F:DAEB]CUR,CURLED,CURLED,[L]GACTYPRAT,[M:DIA]COURDAT,10^GDECRCU,RATETHEO,STAT) From TRTDEV
      If !STAT : RATETHEO = arr(RATETHEO/10^GDECRCU, 10^-GDECRCU) : Endif
      If AFF_SOLREVAL>AFF_SOLFRA # print conversion line with "profit" or "loss"
       Call ECR_TRACE(mess(TYPLEDVLDAUT(I),2644,1)-MESSA-"=>"-num$(AFF_SOLFRA)-CURLED-"/"-mess(407,107,1)-num$(RATETHEO)-
&      "=>"-num$(AFF_SOLREVAL)-CURLED-"/"-mess(38,853,1)-num$(AFF_SOLREVAL-AFF_SOLFRA),0) From GESECRAN
      Else
       Call ECR_TRACE(mess(TYPLEDVLDAUT(I),2644,1)-MESSA-"=>"-num$(AFF_SOLFRA)-CURLED-"/"-mess(407,107,1)-num$(RATETHEO)-
&      "=>"-num$(AFF_SOLREVAL)-CURLED-"/"-mess(39,853,1)-num$(AFF_SOLREVAL-AFF_SOLFRA),0) From GESECRAN
      Endif
     Endif # /TRACE
    Endif
   Next # /NBRVLDAUT
  Else # OK != 1
   For INDDEV=1 To NBDEVCUR
    Assign "T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")")-evalue("SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")")
    Assign "T_SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("T_SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") - evalue("SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")")
    For I=1 To NBRVLDAUT
     Assign "T_SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")" With evalue("T_SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")-evalue("SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")
     Assign "T_SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")" With evalue("T_SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") - evalue("SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")
    Next
   Next
  Endif

 Else #LETCUR=""

  For [DAEB]CLE
   ## Ne pas prendre en compte les pièces d'ànouveau (DdM38016)
   If [F:DAEB]NUM<>[F:HAE]NUM or [F:DAEB]TYP<>[F:HAE]TYP
    Read [HAE]HAE0 = [F:DAEB]TYP;[F:DAEB]NUM
   Endif
   INDDEV = 0
   For I=1 To NBDEVCUR
    If evalue("DEVISE"+num$(TYPLED)+"("+num$(I)+")") = [F:DAEB]CUR
     INDDEV = I : Break
    Endif
   Next
   If !INDDEV
    NBDEVCUR+=1
    Assign "DEVISE"+num$(TYPLED)+"("+num$(NBDEVCUR)+")" With [F:DAEB]CUR
    INDDEV = NBDEVCUR
   Endif

# Issue X3-105232 excluding template journals (CAT<>5)
   If [F:DAEB]PER>0 & [F:HAE]FLGREP<>2 & [F:HAE]CAT<>3 & (FLEURO=0 or !find([F:DAEB]CUR,DEVIN(1..NBDEVIN)))
&&    [F:DAEB]ACCDAT>=[M:DIA]DATDEB & [F:DAEB]ACCDAT<=[M:DIA]DATFIN
&&    [F:HAE]CAT<>5
    OK = 1
    Assign "SOLTRS"+num$(TYPLED) With [F:DAEB]SNS*[F:DAEB]AMTCUR
    Assign "SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")" With [F:DAEB]SNS*[F:DAEB]AMTLED
    Assign "T_SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("T_SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") + ([F:DAEB]SNS*[F:DAEB]AMTLED)

    Call CONVERT([F:DAEB]CUR,DEVLED,DEVLED,[L]GACTYPRAT,[M:DIA]COURDAT,[F:DAEB]AMTCUR*[F:DAEB]SNS,SOLREVAL,STAT) From TRTDEV
    If STAT # "no exchange rate" and leave loop
     If [M:DIA]TRACE=2 : Call ECR_TRACE(COMPTE-":"-mess(4,109,1)-[F:DAEB]CUR-"=>"-DEVLED,1) From GESECRAN : Endif
     OK = -1 : Break 2
    Else
     Assign "SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")" With SOLREVAL
     Assign "T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")")+SOLREVAL
     OK = 1
    Endif

    If OK=1
     If [F:HAE]RATMLT(LEDTYP)=0 : [F:HAE]RATMLT(LEDTYP)=1 : Endif
     RATETHEO = arr([F:HAE]RATMLT(LEDTYP-1) / [F:HAE]RATDIV(LEDTYP-1),10^-GDECRCU)
     If [F:DAEB]AMTFLG<>1
      MESSA = [F:DAEB]TYP-[F:DAEB]NUM+":"-num$(evalue("SOLTRS"+num$(TYPLED)))-[F:DAEB]CUR-mess(407,107,1)-num$(RATETHEO)
     Else  # Théorique
      MESSA = [F:DAEB]TYP-[F:DAEB]NUM+":"-num$(evalue("SOLTRS"+num$(TYPLED)))-[F:DAEB]CUR-mess(406,107,1)-num$(RATETHEO)
     Endif
     AFF_SOLFRA = evalue("SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") # AMTLED
     AFF_SOLREVAL =  evalue("SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")") # AMTCUR
     # 82426: compare old and new value and decide whether to take it in account or not
     If !func TAKEINACCOUNT(AFF_SOLREVAL, AFF_SOLFRA) and [F:HAE]REFINT <> 'CNVEC'
      AFF_SOLFRA = 0 : AFF_SOLREVAL = 0
      Assign ("T_SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") With evalue("T_SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") - evalue("SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")")
      Assign ("SOLFRA"+num$(TYPLED)+"("+num$(INDDEV)+")") With 0
      Assign ("T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")") With evalue("T_SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")") - evalue("SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")")
      Assign ("SOLREVAL"+num$(TYPLED)+"("+num$(INDDEV)+")") With 0
     Endif

     If AFF_SOLREVAL<>AFF_SOLFRA
      # difference of AMTCUR and AMTLED
      Assign "SOLDTIERS"+num$(TYPLED)+"("+num$(INDDEV)+")" With evalue("SOLDTIERS"+num$(TYPLED)+"("+num$(INDDEV)+")")+AFF_SOLREVAL-AFF_SOLFRA

      If [M:DIA]TRACE=2
       If !FLGECART # pour affichage du compte/tiers
        FLGECART = 1
        Call ECR_TRACE("",0) From GESECRAN
        Call ECR_TRACE([F:DAEB]ACC-TIERS,0) From GESECRAN
        Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
       Endif

       Call CONVERT([F:DAEB]CUR,DEVLED,DEVLED,[L]GACTYPRAT,[M:DIA]COURDAT,10^GDECRCU,RATETHEO,STAT) From TRTDEV
       If !STAT : RATETHEO = arr(RATETHEO/10^GDECRCU, 10^-GDECRCU) : Endif

       If AFF_SOLREVAL>AFF_SOLFRA # print conversion line with "profit" or "loss"
        Call ECR_TRACE(mess(TYPLED,2644,1)-MESSA-"=>"-num$(AFF_SOLFRA)-DEVLED-"/"-mess(407,107,1)-num$(RATETHEO)-
&       "=>"-num$(AFF_SOLREVAL)-DEVLED-"/"-mess(38,853,1)-num$(AFF_SOLREVAL-AFF_SOLFRA),0) From GESECRAN
       Else
        Call ECR_TRACE(mess(TYPLED,2644,1)-MESSA-"=>"-num$(AFF_SOLFRA)-DEVLED-"/"-mess(407,107,1)-num$(RATETHEO)-
&       "=>"-num$(AFF_SOLREVAL)-DEVLED-"/"-mess(39,853,1)-num$(AFF_SOLREVAL-AFF_SOLFRA),0) From GESECRAN
       Endif
      Endif
     Endif

     #Pour référentiel en valid auto
     For I=1 To NBRVLDAUT
      STAT = func FINACM_SYRA.GET_LEDCUR(GACTX,SOCIETE,TYPLEDVLDAUT(I),CODLEDVLDAUT,CURLED,GMESSAGE)
      FILTVLD = 'TYP="'+[F:DAEB]TYP+'" & NUM="'+[F:DAEB]NUM+'" & IDTLIN="'+[F:DAEB]IDTLIN+'" & LEDTYP='+num$(TYPLEDVLDAUT(I))
      For [DAEC]DAE7(3) Where evalue(FILTVLD)
       Assign "SOLFRA"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With [F:DAEC]SNS*[F:DAEC]AMTLED
       Assign "T_SOLFRA"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With evalue("T_SOLFRA"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")") + ([F:DAEC]SNS*[F:DAEC]AMTLED)
       Call CONVERT([F:DAEC]CUR,[F:DAEC]CURLED,DEVLED,[L]GACTYPRAT,[M:DIA]COURDAT,[F:DAEC]AMTCUR*[F:DAEC]SNS,SOLREVAL,STAT) From TRTDEV
       If STAT
        Call ECR_TRACE(COMPTE-":"-mess(4,109,1)-[F:DAEC]CUR-"=>"-DEVLED,1) From GESECRAN
        OK = -1 : Break 4
       Else
        Assign "SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With SOLREVAL
        Assign "T_SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")" With evalue("T_SOLREVAL"+num$([F:DAEC]LEDTYP)+"("+num$(INDDEV)+")")+SOLREVAL
        OK = 1
       Endif
      Next
      If OK=1
       If [F:HAE]RATMLT(TYPLEDVLDAUT(I))=0 : [F:HAE]RATMLT(TYPLEDVLDAUT(I))=1 : Endif
       RATETHEO = arr([F:HAE]RATMLT(TYPLEDVLDAUT(I)-1) / [F:HAE]RATDIV(TYPLEDVLDAUT(I)-1),10^-GDECRCU)
       If [F:DAEB]AMTFLG<>1
        MESSA = [F:DAEC]TYP-[F:DAEC]NUM+":"+num$(evalue("SOLTRS"+num$(TYPLED)))-[F:DAEC]CUR-mess(407,107,1)-num$(RATETHEO)
       Else # Théorique
        MESSA = [F:DAEC]TYP-[F:DAEC]NUM+":"+num$(evalue("SOLTRS"+num$(TYPLED)))-[F:DAEC]CUR-mess(407,107,1)-num$(RATETHEO)
       Endif
       AFF_SOLFRA = evalue("SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")
       AFF_SOLREVAL =  evalue("SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")
       # compare old and new value and decide whether to take it in account or not
       If !func TAKEINACCOUNT(AFF_SOLREVAL, AFF_SOLFRA) and [F:HAE]REFINT <> 'CNVEC'
        AFF_SOLFRA = 0 : AFF_SOLREVAL = 0
        Assign ("T_SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") With evalue("T_SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") - evalue("SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")
        Assign ("SOLFRA"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") With 0
        Assign ("T_SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") With evalue("T_SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") - evalue("SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)
& +")")
        Assign ("SOLREVAL"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")") With 0
       Endif
       If AFF_SOLREVAL<>AFF_SOLFRA
        Assign "SOLDTIERS"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")" With evalue("SOLDTIERS"+num$(TYPLEDVLDAUT(I))+"("+num$(INDDEV)+")")+AFF_SOLREVAL-AFF_SOLFRA
        If [M:DIA]TRACE=2
         If !FLGECART # pour affichage du compte/tiers
          FLGECART = 1
          Call ECR_TRACE("",0) From GESECRAN
          Call ECR_TRACE([F:DAEB]ACC-TIERS,0) From GESECRAN
          Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
         Endif
         # Adding RATETHEO in the log file
         Call CONVERT([F:DAEB]CUR,CURLED,CURLED,[L]GACTYPRAT,[M:DIA]COURDAT,10^GDECRCU,RATETHEO,STAT) From TRTDEV
         If !STAT : RATETHEO = arr(RATETHEO/10^GDECRCU, 10^-GDECRCU) : Endif
         If AFF_SOLREVAL > AFF_SOLFRA # print conversion line with "profit" or "loss"
          Call ECR_TRACE(mess(TYPLEDVLDAUT(I),2644,1)-MESSA-"=>"-num$(AFF_SOLFRA)-CURLED-"/"-mess(407,107,1)-num$(RATETHEO)-
&         "=>"-num$(AFF_SOLREVAL)-CURLED-"/"-mess(38,853,1)-num$(AFF_SOLREVAL-AFF_SOLFRA),0) From GESECRAN
         Else
          Call ECR_TRACE(mess(TYPLEDVLDAUT(I),2644,1)-MESSA-"=>"-num$(AFF_SOLFRA)-CURLED-"/"-mess(407,107,1)-num$(RATETHEO)-
&         "=>"-num$(AFF_SOLREVAL)-CURLED-"/"-mess(39,853,1)-num$(AFF_SOLREVAL-AFF_SOLFRA),0) From GESECRAN
         Endif
        Endif
       Endif
      Endif
     Next # NBRVLDAUT
    Endif
   Endif
  Next #[DAEB]CLE
 Endif
Next #[DAEB]CLE(1)
If OK=-1 : Return : Endif

Gosub TRT_JOU
Gosub LIGNE
Return

###########################################################################################################
$TRT_JOU
ECARTOK = 0
# Raz
For INDDEV=1 To NBDEVCUR
 For INDLED=1 To MAXLED+1
  Assign "ECAR"+num$(INDLED)+"("+num$(INDDEV)+")" With 0
 Next
Next

For INDDEV=1 To NBDEVCUR
 For INDLED=1 To MAXLED
  Assign "ECAR"+num$(INDLED)+"("+num$(INDDEV)+")" With
& evalue("T_SOLREVAL"+num$(INDLED)+"("+num$(INDDEV)+")")-evalue("T_SOLFRA"+num$(INDLED)+"("+num$(INDDEV)+")")
  If evalue("ECAR"+num$(INDLED)+"("+num$(INDDEV)+")")<>0 : ECARTOK = 1 : Endif
  If evalue("T_SOLFRA"+num$(INDLED)+"("+num$(INDDEV)+")")>0 : # Débit  => créance
   If evalue("T_SOLREVAL"+num$(INDLED)+"("+num$(INDDEV)+")") > evalue("T_SOLFRA"+num$(INDLED)+"("+num$(INDDEV)+")")
    Assign "INDB"+num$(INDLED)+"("+num$(INDDEV)+")" With 3
   Else
    Assign "INDB"+num$(INDLED)+"("+num$(INDDEV)+")" With 1
   Endif
  Else   : # Crédit => dette
   If evalue("T_SOLREVAL"+num$(INDLED)+"("+num$(INDDEV)+")") > evalue("T_SOLFRA"+num$(INDLED)+"("+num$(INDDEV)+")")
    Assign "INDB"+num$(INDLED)+"("+num$(INDDEV)+")" With 4
   Else
    Assign "INDB"+num$(INDLED)+"("+num$(INDDEV)+")" With 2
   Endif
  Endif
 Next INDLED
Next INDDEV
Return


$RIEN
ER = errn
Resume

###########################################################################################################
$LIGNE
# Ecriture dans table temporaire
Case [M:DIA]TYPECART
 When 2
  Gosub DO_LIN_JOU
 When 3
  Gosub DO_LIN_BLC
Endcase
Return

###########################################################################################################
$DO_LIN_BLC
If !VARIANOK : Return : Endif
For X=1 To NBRCUR
 Raz VARIANOK
 NUMERO += 1
 [F:TCE]LEDTYP  = TYPLED
 [F:TCE]SOC     = SOCIETE
 [F:TCE]SITE    = SITE
 [F:TCE]NUM     = NUMERO
 [F:TCE]DEV     = CUR_TRS(X)
 [F:TCE]DAT     = DATPCE
 [F:TCE]BPR     = TIERS
 [F:TCE]CPTORI  = COMPTE

 Case evalue("INDB"+num$(TYPLED)+"("+num$(X)+")")
   When 1 : # Debit balance decrease
    If [F:GACC]CNVACC1<>""
     [F:TCE]CPTDES = [F:GACC]CNVACC1
    Else
     [F:TCE]CPTDES = [F:COA]ACCMIS(4)
    Endif
   When 2 : # Credit balance increase
    If [F:GACC]CNVACC4<>""
     [F:TCE]CPTDES = [F:GACC]CNVACC4
    Else
     [F:TCE]CPTDES = [F:COA]ACCMIS(7)
    Endif
   When 3 : # Debit balance increase
    If [F:GACC]CNVACC2<>""
     [F:TCE]CPTDES = [F:GACC]CNVACC2
    Else
     [F:TCE]CPTDES = [F:COA]ACCMIS(5)
    Endif
   When 4 : # Credit balance decrease
    If [F:GACC]CNVACC3<>""
     [F:TCE]CPTDES = [F:GACC]CNVACC3
    Else
     [F:TCE]CPTDES = [F:COA]ACCMIS(6)
    Endif
 Endcase

 [F:TCE]AMT(TYPLED-1) = evalue("VARIAN"+num$(TYPLED)+"("+num$(X)+")")

 If NBRVLDAUT<>0
  For I=1 To NBRVLDAUT
   [F:TCE]AMT(TYPLEDVLDAUT(I)-1) = evalue("VARIAN"+num$(TYPLEDVLDAUT(I))+"("+num$(X)+")")
  Next
 Endif

 Write [TCE]

Next
Return

###########################################################################################################
$DO_LIN_JOU
If !ECARTOK : Return : Endif
For X=1 To NBDEVCUR
  Raz ECARTOK
  NUMERO += 1
  [F:TCE]LEDTYP  = TYPLED
  [F:TCE]SOC     = SOCIETE
  [F:TCE]SITE    = SITE
  [F:TCE]NUM     = NUMERO
  [F:TCE]DEV     = evalue("DEVISE"+num$(TYPLED)+"("+num$(X)+")")
  [F:TCE]DAT     = DATPCE
  [F:TCE]BPR     = TIERS
  [F:TCE]CPTORI  = COMPTE

  Case evalue("INDB"+num$(TYPLED)+"("+num$(X)+")")
   When 1 : # Debit balance decrease
    If [F:GACC]CNVACC1<>""
     [F:TCE]CPTDES = [F:GACC]CNVACC1
    Else
     [F:TCE]CPTDES = [F:COA]ACCMIS(4)
    Endif
   When 2 : # Credit balance increase
    If [F:GACC]CNVACC4<>""
     [F:TCE]CPTDES = [F:GACC]CNVACC4
    Else
     [F:TCE]CPTDES = [F:COA]ACCMIS(7)
    Endif
   When 3 : # Debit balance increase
    If [F:GACC]CNVACC2<>""
     [F:TCE]CPTDES = [F:GACC]CNVACC2
    Else
     [F:TCE]CPTDES = [F:COA]ACCMIS(5)
    Endif
   When 4 : # Credit balance decrease
    If [F:GACC]CNVACC3<>""
     [F:TCE]CPTDES = [F:GACC]CNVACC3
    Else
     [F:TCE]CPTDES = [F:COA]ACCMIS(6)
    Endif
  Endcase

  For I=1 To MAXLED+1
   [F:TCE]AMT(I-1) = evalue("ECAR"+num$(I)+"("+num$(X)+")")
   If [F:TCE]AMT(I-1)<>0 : ECARTOK+=1 : Endif
  Next
  If ECARTOK
   Write [TCE]
  Else
   Raz [TCE]
  Endif
Next X
Return

###########################################################################################################
$DO_SIM
## Simulation
# On vide la table temporaire dans les traces
For [TCE]TCE0
 #Ligne numéro
 Call ECR_TRACE(mess(17,104,1)-num$([F:TCE]NUM),-1) From GESECRAN
 #Société , Site , Tiers , Type de référentiel
 Call ECR_TRACE(mess(2,45,1)-":"-[F:TCE]SOC-","-mess(3,45,1)-":"-[F:TCE]SITE-","-mess(31,105,1)-":"-[F:TCE]BPR-","-mess(166,105,1)-":"-mess([F:TCE]LEDTYP,2644,1),-1) From GESECRAN
 #Devise , Compte origine
 Call ECR_TRACE(mess(18,105,1)-":"-[F:TCE]DEV-","-mess(203,105,1)-":"-[F:TCE]CPTORI,-1) From GESECRAN
 For I=1 To len(mess(0,2644,1))
  If evalue("[F:TCE]AMT("+num$(I-1)+")")<>0
   #Montant référentiel ; Compte destination
   Call ECR_TRACE(mess(174,105,1)-mess(I,2644,1)+"=>"-num$([F:TCE]AMT(I-1))-";"-mess(204,105,1)-":"-[F:TCE]CPTDES,-1) From GESECRAN
  Endif
 Next
Next
Raz [TCE]
Return

###########################################################################################################
# 82426: considers EVALTYP returns True (1) when a value should be taken into account
Funprog TAKEINACCOUNT(NEWAMTLEDREV, OLDAMTLED)
Value Decimal NEWAMTLEDREV # new amount revalued
Value Decimal OLDAMTLED    # old amount

Case [M:DIA]EVALTYP
 When 1  # Fixed rate
  End 1
 When 2  # Lower-value principle
  If NEWAMTLEDREV < OLDAMTLED
   End 1 # Take into account
  Else
   End 0 # Do not take into account
  Endif
 When 3  # Higher-value principle
  If NEWAMTLEDREV > OLDAMTLED
   End 1 # Take into account
  Else
   End 0 # Do not take into account
  Endif
Endcase
End

#################################################################################################
## Etiquettes masque CNVECAR
#################################################################################################

Subprog C_GRPSOC(VALEUR)
Variable Char    VALEUR()
Call C_GRPSOC(VALEUR) From CPTTRT
If [M]TYP = 1 & [M]GENECR=2
 Local Integer DGI
 Call FRADGI([M:DIA]NBSOC,[M:DIA]SOC,[M:DIA]SITE,[M:DIA]TYP,[L]DGI) From CPTDIV2
 If [L]DGI = 2
  [M]STA = 2 : Grizo STA
  Affzo STA
 Else
  Actzo STA
 Endif
Endif
End

Subprog C_NBSOC
If [M]NBSOC>1
 Grizo TOUSIT
Else
 Actzo TOUSIT
Endif
Call C_NBSOC From CPTTRT
End

Subprog AS_SOC(VALEUR)
Variable Char    VALEUR()
Call AS_SOC(VALEUR) From CPTTRT
End

Subprog C_SOC(VALEUR)
Variable Char    VALEUR()
Call C_SOC(VALEUR) From CPTTRT
If [M]TYP = 1 & [M]GENECR=2
 Local Integer DGI
 [M:DIA]SOC(nolign-1) = VALEUR
 Call FRADGI([M:DIA]NBSOC+1,[M:DIA]SOC,[M:DIA]SITE,[M:DIA]TYP,[L]DGI) From CPTDIV2
 If [L]DGI = 2
  [M]STA = 2 : Grizo STA
  Affzo STA
 Else
  Actzo STA
 Endif
Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
If [M:DIA]COA="" : Call C_GRPSOC([M]GRPSOC) : Endif
Local Integer OPTION
OPTION=7
Call LEDTYP_CHOICE([M:DIA]SOC(0),OPTION) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
# En cas de modification du Type de Rérentiel - Raz - 58401
If [M:DIA]SOC(0)<>"" & VALEUR<>[M]LEDTYP
 Raz [M]NBSOC, [M]SITE
 Call C_GRPSOC([M]GRPSOC)
Endif
Call C_LEDTYP(VALEUR) From CPTTRT
End

Subprog AS_TOUSIT(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]SOC) From CPTTRT
If VALEUR=2 : Effzo SITE : Grizo SITE : Else : Actzo SITE : Endif
End

Subprog AS_SITE(VALEUR)
Variable Char VALEUR
If [M]TOUSIT=2 : mkstat = 1 : End : Endif
End

Subprog C_SITE(VALEUR)
Variable Char    VALEUR()
Call C_SITE(VALEUR) From CPTTRT
End

Subprog AS_DATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0]
 SOCIETE = [M]SOC(0)
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 Filter [FIY] Where CPY=SOCIETE & FIYSTA=2
 Read [FIY]FIY0 First
 Filter [FIY]
 If !fstat
  VALEUR = [F:FIY]FIYSTR : [M]DATFIN = [F:FIY]FIYEND
  Affzo [M]DATFIN   :# pour le web
 Endif
Endif
End

Subprog AS_CPTFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]CPTDEB : VALEUR=[M]CPTDEB : Endif
End

Subprog AS_BPRFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]BPRDEB : VALEUR=[M]BPRDEB : Endif
End

Subprog AS_COURDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR = [M]DATFIN : Endif
End

Subprog AS_TYPCOL(VALEUR)
Variable Integer VALEUR
If [M]TOUCOL<>2 : VALEUR = 0 : mkstat = 2 : End : Endif
If VALEUR=0 : VALEUR = 1 : Endif
End

Subprog AS_COLL(VALEUR)
Variable Char    VALEUR()
If [M]TOUCOL=2 : VALEUR = "" : mkstat = 2 : End : Endif
If [M:DIA]COA="" : Call C_GRPSOC([M]GRPSOC) : Endif
End

Subprog AS_GRPCOL(VALEUR)
Variable Char    VALEUR()
If [M]TOUCOL=2 or [M]COLL<>"" : VALEUR = "" : mkstat = 2 : End : Endif
If [M:DIA]COA="" : Call C_GRPSOC([M]GRPSOC) : Endif
End

Subprog AS_TYPECART(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1
End

Subprog C_TYPECART(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 1 : mkstat = 1
Endcase
End

Subprog C_TOUSIT(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Effzo SITE : Grizo SITE : Else : Actzo SITE : Endif
End

Subprog C_TOUCOL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo COLL,GRPCOL : Grizo COLL,GRPCOL : Actzo TYPCOL
 Effzo CPTDEB, CPTFIN :  Grizo CPTDEB, CPTFIN : Actzo BPRDEB, BPRFIN
Else
 Actzo COLL,GRPCOL : TYPCOL=0 : Affzo TYPCOL : Grizo TYPCOL
 If [M]COLL="" & [M]GRPCOL=""
  Effzo BPRDEB, BPRFIN
 Endif
 Grizo BPRDEB, BPRFIN : Actzo CPTDEB, CPTFIN
Endif
End

Subprog C_COLL(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
 If [F:GAC]COA<>[M:DIA]COA | VALEUR<>[F:GAC]ACCSHO
  Read [GAC]GAC1 = [M:DIA]COA;VALEUR
 Endif
 Case [M:DIA]TYPECART
  When 2 : If [F:GAC]DIF<>2 : mkstat = 2 : Endif
  When 3 : If [F:GAC]DIF<>3 : mkstat = 2 : Endif
 Endcase
 If mkstat=2 : GMESSAGE=mess(83,123,1) : End : Endif
 Effzo GRPCOL : Grizo GRPCOL
 Effzo CPTDEB, CPTFIN :  Grizo CPTDEB, CPTFIN : Actzo BPRDEB, BPRFIN
Else
 Actzo GRPCOL
 Effzo BPRDEB, BPRFIN :  Grizo BPRDEB, BPRFIN : Actzo CPTDEB, CPTFIN
Endif
End

Subprog C_GRPCOL(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Effzo CPTDEB, CPTFIN :  Grizo CPTDEB, CPTFIN : Actzo BPRDEB, BPRFIN
Else
 Effzo BPRDEB, BPRFIN :  Grizo BPRDEB, BPRFIN : Actzo CPTDEB, CPTFIN
Endif
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE
If [M]DATDEB = [0/0/0]
 SOCIETE = [M]SOC(0)
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 Filter [FIY] Where CPY=SOCIETE & FIYSTA=2
 Read [FIY]FIY0 First
 Filter [FIY]
 If !fstat
  [M]DATDEB = [F:FIY]FIYSTR : [M]DATFIN = [F:FIY]FIYEND
  Affzo DATDEB : Affzo DATFIN
 Endif
Endif
End

$GRISE
If [M]TOUSIT=2 : Effzo SITE : Grizo SITE : Else : Actzo SITE : Endif
If [M]TOUCOL=2
 Effzo COLL,GRPCOL : Grizo COLL,GRPCOL : Actzo TYPCOL
Else
 Actzo COLL
 If [M]COLL<>"" : Grizo GRPCOL : Else : Actzo GRPCOL : Endif
 TYPCOL=0 : Affzo TYPCOL : Grizo TYPCOL
Endif
If [M]GENECR<>2
 Grizo STA, TYP, TYPPCE, JOU, DATPCE, DATEXT
Else
 Actzo STA, TYP, TYPPCE, JOU, DATPCE, DATEXT
Endif
If [M]TYPECART=2
 Chgfmt [M:DIA]EVALTYP With "LA:1X"
Elsif TYPECART=3
 Chgfmt [M:DIA]EVALTYP With "-LA:1X"
Endif
Return

######################################################################################
## Nouveau bloc - Lot FI2
######################################################################################
Subprog C_GENECR(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Grizo STA, TYP, TYPPCE, JOU, DATPCE, DATEXT
Else
 Actzo STA, TYP, TYPPCE, JOU, DATPCE, DATEXT
 Local Integer TYPGEN : [L]TYPGEN = [M]TYP
 Gosub FRADGI : Affzo STA
Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>1
 Grizo STA
Else
 Actzo STA
 Local Integer TYPGEN : [L]TYPGEN = VALEUR
 Gosub FRADGI
Endif
End

$FRADGI
If [L]TYPGEN = 1
 Local Integer DGI
 Call FRADGI([M:DIA]NBSOC,[M:DIA]SOC,[M:DIA]SITE,[L]TYPGEN,[L]DGI) From CPTDIV2
 If [L]DGI = 2
  [M]STA = 2 : Grizo STA
 Else
  Actzo STA
 Endif
Endif
Return

Subprog AS_TYPPCE(VALEUR)
Variable Char    VALEUR()
Local Char VALPAR(9)
If [M]TYP = 1  : VALPAR = "CNVTYPACC"   : # En réel
Else           : VALPAR = "TYPACC"
Endif
If VALEUR=""
 If [M]SITE<>""
  Call PARAML([M]SITE,VALPAR,VALEUR) From ADOVAL
 Elsif [M]SOC(0)<>""
  Call PARAML([M]SOC(0),VALPAR,VALEUR) From ADOVAL
 Endif
Endif
End

Subprog C_TYPPCE(VALEUR)
Variable Char    VALEUR()
# No control if all the companies have a different legislation (GCURLEG="")
If GCURLEG<>""
 Call CONTEXE([F:GTE]ACS) From CPTSUB
 If mkstat  End : Endif
 If [M]TYP=1 & [F:GTE]VCRREA<>2
  GMESSAGE = mess(33,107,1)
  mkstat=2 : End
 Elsif [M]TYP>=2 & [F:GTE]VCRSIM<>2
  GMESSAGE=mess(32,107,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_JOU(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [F:GTE]DEFJOU
Endif
End

Subprog C_JOU(VALEUR)
Variable Char    VALEUR()
# No control if all the companies have a different legislation (GCURLEG="")
If GCURLEG<>""
 Call CONTEXE([F:JOU]ACS) From CPTSUB
 If mkstat : GMESSAGE=VALEUR-GMESSAGE : End : Endif
 If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
  GMESSAGE = [F:JOU]JOU-mess(8,106,1)
  mkstat=2 : End
 Endif
 Call VERSOC([F:JOU]FCY,[M]SOC,[M]SITE,[F:JOU]JOU) From CFYSUB
 If mkstat : End : Endif
Endif
End

Subprog AS_DATPCE(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = [M:DIA]DATFIN
Endif
End

Subprog AM_DATPCE(VALEUR)
Variable Date    VALEUR
## On initialise la date d'extourne au 1er jour du mois suivant la date de pièce
[M:DIA]DATEXT = gdat$(1,month(VALEUR)+1,year(VALEUR))
Affzo DATEXT
End

Subprog AV_TRACE(VALEUR)
Variable Integer VALEUR
If [M]GENECR = 2
# VALEUR = 2
# mkstat = 2 : End
Endif
End

##############################################################################################################
# AMTCNVEC : renvoie le montant "forcé" des écarts à générer
##############################################################################################################
Subprog AMTCNVEC(TYPLED,MONTANT,STAT)
Value    Integer TYPLED
Variable Decimal MONTANT
Variable Integer STAT

If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif

Local Char    SOCIETE(GLONCPY)
Local Char    CODLED(GLONLED)
Local Char    DEVLED1(GLONCUR), DEVLED2(GLONCUR), DEVMAINLED(GLONCUR)
Local Integer FLGAUT, SPSTAT

Call LECTURE("FCY",[F:TB0]SITE,"") From CONTOBJ
SOCIETE = [F:FCY]LEGCPY

Call LECLED(SOCIETE,TYPLED,CODLED,DEVLED2) From CPTDIV
If CODLED = "" : End : Endif

Call LEDTYPAUT(SOCIETE,TYPLED,FLGAUT) From CPTDIV

If TYPLED = [F:TB0]LEDTYP
 MONTANT = [F:TCE]AMT([F:TB0]LEDTYP-1)
Elsif FLGAUT=2
 MONTANT = [F:TCE]AMT(TYPLED-1)
Else
 Call LECLED(SOCIETE,[F:TB0]LEDTYP,CODLED,DEVLED1) From CPTDIV
 If DEVLED1 = DEVLED2
  MONTANT = [F:TCE]AMT([F:TB0]LEDTYP-1)
 Else
  Call SETCUR(1,SOCIETE,DEVMAINLED) From CPTDIV
  Call CONVERT(DEVLED1,DEVLED2,DEVMAINLED,1,[M:HAE0]ACCDAT,[F:TCE]AMT([F:TB0]LEDTYP-1),MONTANT,SPSTAT) From TRTDEV
  If SPSTAT
   STAT = 98 : GMESSAGE = "AMTLED"+num$(TYPLED)-":"-mess(4,109,1)-DEVLED1-"=>"-DEVLED2
  Endif
 Endif
Endif
End

######################################################################################
## Section automatically added (screen CNVECAR) 05/02/2013 15:11:40 (MAGER)
######################################################################################
Subprog AM_TYPECART(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Chgfmt [M:DIA]EVALTYP With "LA:1X"
Else
 Chgfmt [M:DIA]EVALTYP With "-LA:1X"
Endif
Affzo [M:DIA]EVALTYP
End

