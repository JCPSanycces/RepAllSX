#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du fichier ITMCOMP
Call OBJET ("CCC", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "FERME"      : Gosub FERME
    When "SETBOUT"    : Gosub SETBOUT
    When "CREATION"   : Gosub CREATION
    When "MODIF"      : Gosub MODIF
    When "LIENS"      : Gosub LIENS
    When "RAZCRE"     : Gosub RAZCRE
    When "RAZDUP"     : Gosub RAZDUP
    When "INICRE"     : Gosub INICRE
    When "VERIF_CRE"  : Gosub VERIF_CRE
    When "VERIF_MOD"  : Gosub VERIF_MOD
    When "APRES_CRE"  : Gosub APRES_CRE
    When "APRES_MOD"  : Gosub APRES_MOD
    When "AV_ANNULE"  : Gosub AV_ANNULE
    When "ANNULE"     : Gosub ANNULE     # FGR 23/09/2009 : X3SUIVI58000
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCCCCCPT(GLONANM)   # Code compteur pour article concurrent
Global Char SZTAB_ILK(GLONITM)(dim([M:CCC3]ITMNUM))
Global Integer INBTAB_ILK

  Raz SZTAB_ILK
  INBTAB_ILK = 0
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(5)
  #  GCCCCCPT = [F:TCA]CODNUM(5)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

##########################################################################################################
$FERME
  Kill GCCCCCPT            # Code compteur pour article concurrent
Return

##########################################################################################################
$SETBOUT
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$RAZCRE
  Gosub RAZ_SZTAB_ILK From SUBCCCB
Return

##########################################################################################################
$RAZDUP
  Gosub RAZ_SZTAB_ILK From SUBCCCB
Return

##########################################################################################################
$LIENS
  #---------------------------------------------------#
  #Lecture des clobs
  #---------------------------------------------------#
  Gosub LOADCLOB From SUBCCCB
  Gosub LOAD_ILK From SUBCCCB
  Gosub LOAD_SZTAB_ILK From SUBCCCB
  Affzo [M:CCC1]1-99
  Affzo [M:CCC2]1-99
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call READ_COUNTER([M:CCC0]SALFCY, 13, 5, GSOCIETE, GCURLEG, GCCCCCPT, GMANCOU) From CRM_UTIL     # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:CCC0]SALFCY, GCCCCCPT, date$, "", [M:CCC0]NUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:ICM]NUM = [M:CCC0]NUM
      Affzo [M:CCC0]NUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  #
  [F:ICM]TYPFULDES = "CCC"
  [F:ICM]NUMFULDES = [M:CCC0]NUM
  [M:CCC1]TYPFULDES = "CCC"
  [M:CCC1]NUMFULDES = [M:CCC0]NUM

  [F:ICM]TYPFULASE = "CCCASE"
  [F:ICM]NUMFULASE = [M:CCC0]NUM
  [M:CCC2]TYPFULASE = "CCCASE"
  [M:CCC2]NUMFULASE = [M:CCC0]NUM

  [F:ICM]TYPFULSHC = "CCCSHC"
  [F:ICM]NUMFULSHC = [M:CCC0]NUM
  [M:CCC2]TYPFULSHC = "CCCSHC"
  [M:CCC2]NUMFULSHC = [M:CCC0]NUM
Return

##########################################################################################################
$VERIF_CRE
  Gosub CHECKCUR
Return

##########################################################################################################
$VERIF_MOD
  Gosub CHECKCUR
Return

##########################################################################################################
$CREATION
  # FGR 23/09/2009 : X3SUIVI58000
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:CCC1]CPPITMDESAXX,"ITMCOMP","CPPITMDESAXX",[M:CCC0]NUM,"") From ATEXTRA
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBCCCB
  If GOK < 1 Then
    Return
  Endif
  #Call MANAGEILK From SUBCCCB
  Gosub SAVE_ILK From SUBCCCB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$MODIF
  # FGR 23/09/2009 : X3SUIVI58000
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:CCC1]CPPITMDESAXX,"ITMCOMP","CPPITMDESAXX",[M:CCC0]NUM,"") From ATEXTRA
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBCCCB
  If GOK < 1 Then
    Return
  Endif
  Gosub SAVE_ILK From SUBCCCB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$APRES_CRE
  Gosub LOAD_SZTAB_ILK From SUBCCCB
Return

##########################################################################################################
$APRES_MOD
  Gosub LOAD_SZTAB_ILK From SUBCCCB
Return

##########################################################################################################
$ANNULE
  # FGR 23/09/2009 : X3SUIVI58000
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("ITMCOMP","CPPITMDESAXX",[M:CCC0]NUM,"") From ATEXTRA
Return

##########################################################################################################
$AV_ANNULE
  #Suppression des clobs
  Gosub DELCLOB From SUBCCCB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
# Sous-programmes
#############################################################################################
# Vérifie si une devise accompagne un prix moyen constaté.
$CHECKCUR
  If [M:CCC1]SALPRI > 0 and [M:CCC1]CUR = "" Then
    GMESSAGE = mess(218,196,1) #Une devise doit accompagner le prix moyen constaté.
    GERR = 2
    OK = 0
  Endif
Return

##########################################################################################################
Subprog AM_ITMNUM(VALEUR)
Variable Char    VALEUR()

  #Effacement du produit précédent
  Read [ITM]ITM0=VALEUR
  If fstat = 0 Then
    #[M:CCC3]DES0(nolign-1) = [F:ITM]ITMDES1
    #[M:CCC3]DES1(nolign-1) = [F:ITM]ITMDES2
    #[M:CCC3]DES2(nolign-1) = [F:ITM]ITMDES3
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CCC3]DES0(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Call CHARGE_DEFITMDES("DES2AXX",GLANGUE,[F:ITM]ITMREF,[M:CCC3]DES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Call CHARGE_DEFITMDES("DES3AXX",GLANGUE,[F:ITM]ITMREF,[M:CCC3]DES2(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  Else
    [M:CCC3]DES0(nolign-1) = ""
    [M:CCC3]DES1(nolign-1) = ""
    [M:CCC3]DES2(nolign-1) = ""
  Endif
  Affzo [M:CCC3]DES0(nolign-1)
  Affzo [M:CCC3]DES1(nolign-1)
  Affzo [M:CCC3]DES2(nolign-1)
End

##########################################################################################################
Subprog C_ITMNUM(VALEUR)
Variable Char    VALEUR()

Local Integer I

  #Vérifie si cet article n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim([M:CCC3]ITMNUM)-1
    If I <> nolign-1 Then
      If [M:CCC3]ITMNUM(I) = VALEUR and [M:CCC3]ITMNUM(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(434,196,1) #Cet article a déjà été saisi.
        GERR = 2
      Endif
    Endif
  Next
End

##########################################################################################################
Subprog C_CUR(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [TCU]TCU0=VALEUR
    If fstat Then
      GMESSAGE = mess(84,116,1) #Devise incorrecte.
      GERR = 1
      mkstat = 2
      End
    Else
      If [F:TCU]EURFLG = 2 Then
        If [F:TCU]CURENDDAT <> [00/00/00] Then
          If [F:TCU]CURENDDAT < date$ Then
            GMESSAGE = mess(84,116,1) #Devise incorrecte.
            GERR = 1
            mkstat = 2
            End
          Endif
        Endif
      Endif
    Endif
  Endif
End

