#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OHREXT

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:00"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OHREXT",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="HREXT0;HREXT1;HREXT2;HREXT3;HREXT4;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "HREXT"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "EXRTEP"
If clalev([M:HREXT0])=0 : Local Mask HREXT0 [HREXT0] : Endif
If clalev([M:HREXT1])=0 : Local Mask HREXT1 [HREXT1] : Endif
If clalev([M:HREXT2])=0 : Local Mask HREXT2 [HREXT2] : Endif
If clalev([M:HREXT3])=0 : Local Mask HREXT3 [HREXT3] : Endif
If clalev([M:HREXT4])=0 : Local Mask HREXT4 [HREXT4] : Endif
Gosub TIT
nolign = 1
If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif
Link [HREXT] With
& [ACC]CODACC=GUSER;[F:HREXT]EXRCODACC
& As [HREXT_]
Return

$DEF_BOITE
Gosub HORODAT From WGOHREXT
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OHREXT" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXT0]
&   Folder Mask [HREXT1]
& , Folder Mask [HREXT2]
& , Folder Mask [HREXT3]
& , Folder Mask [HREXT4]
&  Listbox [HREXT_] GAU_CHE
&   [L]SAIRAP(1) = [F:HREXT]EXRTEP Using "K:20X" Titled TITSEL(1) ,
&   [L]SAIRAP(2) = [F:HREXT]EXRTIT Using "K:50X" Titled TITSEL(2)
&  Listbox [HREXT9] GAU_CHE9
&   [L]SAIRAP(1) = [F:HREXT9]A_TAB1 Using "K:20X" Titled TITSEL9(1)  ,
&   [L]SAIRAP(2) = [F:HREXT9]A_TAB2 Using "K:50X" Titled TITSEL9(2) 
& As [HREXT1]
Titled [HREXT1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOHREXT
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OHREXT" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXT0]
&   Folder Mask [HREXT1]
& , Folder Mask [HREXT2]
& , Folder Mask [HREXT3]
& , Folder Mask [HREXT4]
& As [HREXT1]
Titled [HREXT1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [HREXT1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [HREXT1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [HREXT1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS(30)
Call TEXTE(55254,TITLIS) From OBJDIV
Local Char TITLIS9(30)
TITLIS9 = mess(196,123,1)
Local Char TITSEL(30)(1..2)
Call TEXTE(5296,TITSEL(1)) From OBJDIV
Call TEXTE(1826,TITSEL(2)) From OBJDIV
Local Char TITSEL9(30)(1..2)
Call TEXTE(5296,TITSEL9(1)) From OBJDIV
Call TEXTE(1826,TITSEL9(2)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(55254,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Gosub SETCLE_
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""  : CRITERE  = "1=1" : Endif
 If FILTSUP=""  : FILTSUP  = "1=1" : Endif
 If FILROLE=""  : FILROLE  = "1=1" : Endif
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [HREXT_] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(0)<>'' or NOHLIS(0)<>0
 Fillbox [HREXT1] GAU_CHE Hint Key =HINTLIS(0)
Else
 Gosub CALNOHOBJ From GOBJET
 If A_NOH
  Fillbox [HREXT1] GAU_CHE
 Else
  Fillbox [HREXT1] GAU_CHE Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [HREXT_]
Return

$SETCLE_
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 1
GAUTRELIS = 1
CLELISTE = "EXRTEP"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 0 : Default file [HREXT_]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [HREXT_] Order With CLELISTE
  Setlbox [HREXT1] GAU_CHE
  Filter [HREXT_]
 When "GAU_CHE9"
  Gosub CLE_DERLU From =PROGOBJ
  Setlbox [HREXT1] GAU_CHE9
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [HREXT_] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [HREXT_]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "HREXT0"       : ABMSK(0)  = "HREXT0"   : AMA(0) = 1
NOMMSK(1) = "HREXT1"       : ABMSK(1)  = "HREXT1"   : AMA(1) = 1
NOMMSK(2) = "HREXT2"       : ABMSK(2)  = "HREXT2"   : AMA(2) = 1
NOMMSK(3) = "HREXT3"       : ABMSK(3)  = "HREXT3"   : AMA(3) = 1
NOMMSK(4) = "HREXT4"       : ABMSK(4)  = "HREXT4"   : AMA(4) = 1
NBMASK = 4
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:HREXT0])>0 : Default Mask [HREXT0] : Endif
 When 1 : If clalev([M:HREXT1])>0 : Default Mask [HREXT1] : Endif
 When 2 : If clalev([M:HREXT2])>0 : Default Mask [HREXT2] : Endif
 When 3 : If clalev([M:HREXT3])>0 : Default Mask [HREXT3] : Endif
 When 4 : If clalev([M:HREXT4])>0 : Default Mask [HREXT4] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:HREXT0])>0 : Gosub TITRES From W1HREXT0 : Endif
 When 1 : If clalev([M:HREXT1])>0 : Gosub TITRES From W1HREXT1 : Endif
 When 2 : If clalev([M:HREXT2])>0 : Gosub TITRES From W1HREXT2 : Endif
 When 3 : If clalev([M:HREXT3])>0 : Gosub TITRES From W1HREXT3 : Endif
 When 4 : If clalev([M:HREXT4])>0 : Gosub TITRES From W1HREXT4 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:HREXT0])>0 : Close Local Mask [HREXT0] : Endif
If clalev([M:HREXT1])>0 : Close Local Mask [HREXT1] : Endif
If clalev([M:HREXT2])>0 : Close Local Mask [HREXT2] : Endif
If clalev([M:HREXT3])>0 : Close Local Mask [HREXT3] : Endif
If clalev([M:HREXT4])>0 : Close Local Mask [HREXT4] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:HREXT0])>0 : Raz [M:HREXT0] : Endif
 When 1 : If clalev([M:HREXT1])>0 : Raz [M:HREXT1] : Endif
 When 2 : If clalev([M:HREXT2])>0 : Raz [M:HREXT2] : Endif
 When 3 : If clalev([M:HREXT3])>0 : Raz [M:HREXT3] : Endif
 When 4 : If clalev([M:HREXT4])>0 : Raz [M:HREXT4] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:HREXT0])>0 : Affzo [M:HREXT0] : Endif
 When 1 : If clalev([M:HREXT1])>0 : Affzo [M:HREXT1] : Endif
 When 2 : If clalev([M:HREXT2])>0 : Affzo [M:HREXT2] : Endif
 When 3 : If clalev([M:HREXT3])>0 : Affzo [M:HREXT3] : Endif
 When 4 : If clalev([M:HREXT4])>0 : Affzo [M:HREXT4] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 0 : If clalev([M:HREXT0])>0 : [F:HREXT] = [M:HREXT0] : Endif
 When 1 : If clalev([M:HREXT1])>0 : [F:HREXT] = [M:HREXT1] : Endif
 When 2 : If clalev([M:HREXT2])>0 : [F:HREXT] = [M:HREXT2] : Endif
 When 3 : If clalev([M:HREXT3])>0 : [F:HREXT] = [M:HREXT3] : Endif
 When 4 : If clalev([M:HREXT4])>0 : [F:HREXT] = [M:HREXT4] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 0 : If clalev([M:HREXT0])>0 : [M:HREXT0] = [F:HREXT] : Endif
 When 1 : If clalev([M:HREXT1])>0 : [M:HREXT1] = [F:HREXT] : Endif
 When 2 : If clalev([M:HREXT2])>0 : [M:HREXT2] = [F:HREXT] : Endif
 When 3 : If clalev([M:HREXT3])>0 : [M:HREXT3] = [F:HREXT] : Endif
 When 4 : If clalev([M:HREXT4])>0 : [M:HREXT4] = [F:HREXT] : Endif
Endcase
Return

$GRISE_CLE
If AMA(0)
 Grizo [HREXT0]EXRTEP
Else
 Grizo [HREXT1]EXRTEP
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [HREXT0]EXRTEP
Else
 Actzo [HREXT1]EXRTEP
Endif
Return

$BOUTON
STDBOUT = "ECSAN09<>RHILJMP"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "V" : LBOUT(NBTEX) = 1101 : Call TEXTE(21803,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "2" : LBOUT(NBTEX) = 1102 : Call TEXTE(1401,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1103 : Call TEXTE(1000741,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "V"
  FLGEXE = 1
  GACTION = "STD"
 When "2"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "HREXT"
  PARBOUT(2) = [M]EXRTEP
  PARBOUT(3) = ""
  PARBOUT(4) = ""
  PARBOUT(5) = ""
  FLGEXE = 1
  GACTION = "ACOPIE"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","ACOPIE","ACOPIE",3,"XYACOPIE") From GTRAITE
 When "1"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:HREXT0]EXRTEP
  FLGEXE = 1
  GACTION = "TRTGENHREX"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTGENHREX","GENHREXT",4,"XYTRTGENHREX") From GTRAITE
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


