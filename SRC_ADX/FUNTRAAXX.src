#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GNBMASKOUV
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FAXXTRA","FUNTRAAXX","") From GSAISIE
End

#---------------------------------------------------------------------#
# Traduction ATEXTRA ( Table des textes à traduire )
#---------------------------------------------------------------------#

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "ENR"          : Gosub ENR
 When "ABA"          : Gosub ABA
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub MENU
 When "SEL_LISTE"    : Gosub SEL_LISTE
Endcase
Return

#--------------------------------#
$DEBUT
If clalev ([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If clalev ([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev ([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev ([F:ATI])=0 : Local File ATABIND [ATI] : Endif
If clalev ([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
If clalev ([F:ATY])=0 : Local File ATYPE   [ATY] : Endif

Raz [M]

# Recherche des tables contenant des textes

For [ATZ]CODTYP(2) Where find(CODTYP,"AXX","AX1","AX2","AX3")<>0
 If !find([F:ATZ]CODFIC,[M]TABLE(0..[M]NBCHAP-1))
  If filinfo(filpath("FIL",[F:ATZ]CODFIC,"fde",0),0)>=0
   Read [ATB]CODFIC = [F:ATZ]CODFIC
   If !fstat & [M]NBCHAP-1<dim([M]TABLE)
    [M]NBCHAP += 1   
    [M]TABLE([M]NBCHAP-1) = [F:ATZ]CODFIC
    Call TEXTE([F:ATB]INTITFIC,[M]LIBTAB([M]NBCHAP-1)) From OBJDIV
   Endif
  Endif
 Endif 
Next  
Return

#--------------------------------#
$SETBOUT
If REP="M"
 Call VIREBOUT(CHBOU,"b") From GOBJET
Else
 If [M]BASTAB>0 
  If !instr(1,CHBOU,"b") : CHBOU += "b" : Endif
 Else
  Call VIREBOUT(CHBOU,"b") From GOBJET
 Endif
Endif
CHMEN += "12" : # Textes sans liens/Suppression
Return

#--------------------------------#
$APRES_MODIF
# si on modifie une ligne de tableau : activer btn Enr Aban
If COUZON="TEXTETRA"
 REP = "M"
Endif
Return
 
#--------------------------------#
$ENR
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [AXX]
 For I=0 To [M]BASTAB-1 
  If [M]TEXTETRA(I)<>""
   Readlock [AXX]AXX0 = [M]CODFIC;[M]ZONE(I);[M]LANGUETRA;[M]IDENT1(I);[M]IDENT2(I)
   If fstat=1 
    GOK = -1 : GLOCK = "$ATEXTRA"-[M]CODFIC-[M]ZONE(I)-[M]LANGUETRA-[M]IDENT1(I)-[M]IDENT2(I)
    Break
   Elsif fstat
    [F:AXX]CODFIC = [M]CODFIC
    [F:AXX]ZONE   = [M]ZONE(I) 
    [F:AXX]LANGUE = [M]LANGUETRA
    [F:AXX]IDENT1 = [M]IDENT1(I)
    [F:AXX]IDENT2 = [M]IDENT2(I)       
    [F:AXX]TEXTE  = [M]TEXTETRA(I) 
    Write [AXX]  
   Else  
    [F:AXX]TEXTE  = [M]TEXTETRA(I) 
    Rewrite [AXX]
   Endif 
   If fstat 
    GOK = 0 
    Call FSTA("AXX") From GLOCK
    Break 
   Endif
  Endif
 Next I 
 If    GOK<0 : Goto ROLL_TR1
 Elsif GOK=0 : Goto AB_TR1
 Endif
Commit
REP = "" # pour désactiver les boutons
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto ENR : Endif
 
#--------------------------------#
$AVANT_BOUTON
Local Integer OK 
OK = 2 
Case BOUT
 When "b"
  Call OUINON(mess(128,126,1),OK) From GESECRAN 
  # MAJ des textes traduisibles   
  If OK<>2 : FOK = 0 : Endif 
Endcase
Return
 
#--------------------------------#
$BOUTON
Case BOUT
 When "b"
  # Génération des fichiers séquentiels
  Call GENERE(nomap) From AGENTXTTRA
 When "I" : 
  # affichage du nombre d'enreg dans toutes les langues du dossier
  Call AFF_NBELEMENTS
 When "1" : Infbox "1"
Endcase
Return  

#--------------------------------#
$MENU
Case BOUT
 When "1" : Call TXT_AVIRER(1)
 When "2" : Call TXT_AVIRER(0)
Endcase
Return  

#--------------------------------#
$ABA
Gosub LIGNES
Return

$LIGNES  
If [M]LANGUEORI="" | [M]LANGUETRA="" | [M]LANGUEORI=[M]LANGUETRA | [M]CODFIC="" | [M]TEXPAT=""
 Return
Endif 

Local Char    CHAINE(250)
Local Integer I , J , K

Raz [M]TEXTEORI, TEXTETRA, ZONE, IDENT1, IDENT2
Raz [M]BASTAB
nolign = 0   
   
# --- recherche de tous les textes du chapitre dans langue origine 
If [M]TEXPAT<>"*"
 Filter [AXX]Where  LANGUE=[M]LANGUEORI & CODFIC=[M]CODFIC & TEXTE<>""
&                 & pat(toupper(TEXTE),toupper([M]TEXPAT))<>0
&                   Order By TEXTE
Else
 Filter [AXX]Where  LANGUE=[M]LANGUEORI & CODFIC=[M]CODFIC & TEXTE<>""
&                   Order By TEXTE
Endif
For [AXX] Hint Key="AXX1" 
 If nolign>=dim([M]ZONE)
  Call MESSAGE(mess(26,100,1)) From GESECRAN
  Break
 Endif 
 nolign += 1   
 [M]TEXTEORI(nolign-1) = [F:AXX]TEXTE
 [M]ZONE(nolign-1)     = [F:AXX]ZONE
 [M]IDENT1(nolign-1)   = [F:AXX]IDENT1
 [M]IDENT2(nolign-1)   = [F:AXX]IDENT2
Next AXX
[M]BASTAB = nolign   
Filter [AXX]    
If [M]BASTAB=0
 Call MESSAGE(mess(13,127,1)) From GESECRAN : # Pas de texte à traduire
Endif

For I=0 To [M]BASTAB-1   
 Read [AXX] AXX0 = [M]CODFIC;[M]ZONE(I);[M]LANGUETRA;[M]IDENT1(I);[M]IDENT2(I)    
 If !fstat   
  [M]TEXTETRA(I) = [F:AXX]TEXTE   
 Endif
Next I      
 
Affzo 10     
REP = ""
Return 

#--------------------------------#
$SEL_LISTE
TIT = mess(12,127,1) : # Tables à traduire
Sorta [M]NBCHAP [M]NBCHAP Order By [M]TABLE(indice)
NBTEX = [M]NBCHAP
Local Char TEX(GLONATB)(0..NBCHAP),TEXTE(60)(0..NBCHAP)
For I=1 To [M]NBCHAP
 TEX(I)   = [M]TABLE(I-1)
 TEXTE(I) = [M]TABLE(I-1)-[M]LIBTAB(I-1)
Next I
Return

#####################################################################################################
Subprog AFF_NBELEMENTS

Local File ATEXTRA  [ZZC]
Local File ADOSSIER [ZZA]

# recherche du nbre de lignes en fra
Local Integer WNBR_TRANSLATE (0..15)
Local Char WLAN (3)(0..dim([F:ZZA]LAN))
Local Integer WNBR_LAN, WINDICE
Local Clbfile WCLOB (4)

Raz WCLOB

Read [ZZA]DOSSIER =nomap
If fstat <> 0
    WCLOB = "No Texts"
    Goto FIN_AFF_TEXT
Endif


# lecture fiche dossier pour recup table des langue
For WINDICE=0 To [F:ZZA]NBRLAN-1 
     WLAN (WINDICE) = [F:ZZA]LAN (WINDICE)
Next WINDICE
WNBR_LAN = [F:ZZA]NBRLAN 

Raz WNBR_TRANSLATE
WCLOB = " ------ Number of descriptions which exist in ATEXTRA "+chr$(13)

#   remplissage de la table des langues 
For WINDICE = 0 To WNBR_LAN-1
    If WLAN (WINDICE) <> ""
        Filter [ZZC] Where LANGUE =  WLAN (WINDICE) and TEXTE <> ""
        WNBR_TRANSLATE (WINDICE) = rowcount ([F:ZZC])
        Filter [ZZC]
        # on ne peut pas calculer le restant par rapport au francais .. car cela depend du paramétrage
        # on peut avoir plus de pramatrage en anglais qu en francais du fait du multi ref.
        WCLOB += " in "+WLAN (WINDICE)+ ": "+num$(WNBR_TRANSLATE(WINDICE))+chr$(13)
    Endif
Next WINDICE

$FIN_AFF_TEXT

Call AFFMES(WCLOB) From GESECRAN
Close Local File
End

#####################################################################################################
Subprog TXT_AVIRER(TEST)
Value Integer TEST
Local Char    TABLE(GLONATB) , CHAMP(GLONAVA) , PARTAB(30) , PARZON(30) , REFTAB(30) , TIT(30)
Local Integer ER , OK , NBSUP , K
If !TEST
 Call OUINON(mess(79,115,1),OK) From GESECRAN : # Etes-vous sûr de bien vouloir lancer ce traitement ?
 If OK<>2 : End : Endif
Endif
Local File ATEXTRA [AXX] , ATABLE [ATB] , ATABZON [ATZ] , ATEXTRA [AXX2] , AMSKPAR [AMP] , AMSKPAR [AMP2]
If !TEST
 # Suppression des textes traduisibles non rattachés à une table et un champ de cette table
 TIT = mess(234,139,1)
Else
 # Textes traduisibles non rattachés à une table et un champ de cette table
 TIT = mess(233,139,1)
Endif
Call OUVRE_TRACE(TIT) From LECFIC
Trbegin [AXX2]
 For [AXX]AXX0(1)
  OK = 0
  TABLE = [F:AXX]CODFIC
  For [AMP] Where TYPAFF=2 & CODPAR="TABLE1"
   ER = 0
   Onerrgo ER
   If find(left$([F:AMP]VALPAR,1),'"',"'",'G')
    PARTAB = evalue([F:AMP]VALPAR) 
   Else
    PARTAB = ""
   Endif
   Onerrgo
   If !ER & PARTAB=TABLE
    OK = 1 : Break
   Endif
  Next AMP
  If !OK
   Read [ATB]CODFIC=TABLE
   If !fstat
    # Table # non renseignée dans les paramètres
    Call ECR_TRACE(func AFNC.MES(mess(219,115,1),TABLE),1) From GESECRAN
   Else
    # Table # inexistante
    Call ECR_TRACE(func AFNC.MES(mess(85,133,1),TABLE),1) From GESECRAN
   Endif
  Endif
  If !OK
   NBSUP = 0
   For [AXX2] Where CODFIC=TABLE
    If !TEST
     Delete [AXX2] Curr
    Endif
    NBSUP += 1
   Next AXX2
   If TEST
    # Table=
    # Il y a # enregistrements trouvés
    Call ECR_TRACE(mess(56,123,1)+'="'+TABLE+'" ->'-func AFNC.MES(mess(220,115,1),num$(NBSUP)),0)  From GESECRAN
   Else
    # Table=
    # enregistrements effacés
    Call ECR_TRACE(mess(56,123,1)+'="'+TABLE+'" ->'-num$(NBSUP)-mess(20,133,1),0) From GESECRAN
   Endif
  Else
   For [AXX]AXX0(2)
    CHAMP = [F:AXX]ZONE
    K = instr(1,CHAMP,"(")
    If K 
     CHAMP = left$(CHAMP,K-1) 
    Endif
    OK = 0
    For [AMP] Where TYPAFF=2 & CODPAR="TABLE1"
     ER = 0
     Onerrgo ER
     If find(left$([F:AMP]VALPAR,1),'"',"'",'G')
      PARTAB = evalue([F:AMP]VALPAR)
     Else
      PARTAB = ""
     Endif
     Onerrgo
     If !ER & PARTAB=TABLE
      For [AMP2] Where TYPAFF=2 & CODPAR="ZONE" & CODAFF=[F:AMP2]CODAFF
       ER = 0
       Onerrgo ER
       If find(left$([F:AMP2]VALPAR,1),'"',"'",'G')
        PARZON = evalue([F:AMP2]VALPAR)
       Else
        PARZON = ""
       Endif
       K = instr(1,PARZON,"(")
       If K
        PARZON = left$(PARZON,K-1)
       Endif
       Onerrgo
       If !ER & PARZON=CHAMP
        OK = 1 : Break 2
       Endif
      Next AMP2
     Endif
    Next AMP
    If !OK
     Read [ATZ]CODZONE=TABLE;CHAMP
     If !fstat
      # Champ $1$ de la table $2$ non renseigné dans les paramètres
      Call ECR_TRACE(func AFNC.MES2(mess(221,115,1),CHAMP,TABLE),1) From GESECRAN
     Else
      # Champ $1$ inexistant dans la table $2$
      Call ECR_TRACE(func AFNC.MES2(mess(222,115,1),CHAMP,TABLE),1) From GESECRAN
     Endif
    Endif
    If !OK
     NBSUP = 0
     For [AXX2] Where CODFIC=TABLE
      K = instr(1,[F:AXX2]ZONE,"(")
      If (K & left$([F:AXX2]ZONE,K-1)=CHAMP) or [F:AXX2]ZONE=CHAMP
       If !TEST
        Delete [AXX2] Curr
       Endif
       NBSUP += 1
      Endif
     Next AXX2
     If TEST
      # Champ= Table=
      # Il y a # enregistrements trouvés
      Call ECR_TRACE(mess(36,124,1)+'="'+CHAMP+'"'-mess(56,123,1)+'="'+TABLE+'" ->'-func AFNC.MES(mess(220,115,1),num$(NBSUP)),0)
&     From GESECRAN
     Else
      # Champ= Table=
      # enregistrements effacés
      Call ECR_TRACE(mess(36,124,1)+'="'+CHAMP+'"'-mess(56,123,1)+'="'+TABLE+'" ->'-num$(NBSUP)-mess(20,133,1),0) From GESECRAN
     Endif
    Endif
   Next AXX0(2)
  Endif
 Next AXX0(1)
Commit
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

$ER
ER = errn
Resume
 
#--------------------------------#
# Ecran AXX1
#--------------------------------#
Subprog D_LANGUEORI(VALEUR)
Variable Char     VALEUR
VALEUR = GLANGUE
End

Subprog AM_LANGUEORI(VALEUR) 
Variable Char    VALEUR() 
[M]LANGUEORI = VALEUR   
Gosub LIGNES  
End 
 
Subprog C_LANGUETRA(VALEUR) 
Variable Char    VALEUR() 
If VALEUR=[M]LANGUEORI
 mkstat = 2
Endif
End

Subprog AM_LANGUETRA(VALEUR) 
Variable Char    VALEUR() 
[M]LANGUETRA = VALEUR   
Gosub LIGNES  
End 

Subprog AM_CODFIC(VALEUR) 
Variable Char    VALEUR() 
[M]CODFIC = VALEUR  
Gosub LIGNES
End  

Subprog C_CODFIC(VALEUR)
Variable Char    VALEUR()
If !find(VALEUR,[M]TABLE(0..[M]NBCHAP-1))
 GMESSAGE = mess(11,127,1) : # Pas de texte traduisible dans cette table
 mkstat = 2
Endif
End

Subprog C_TEXTETRA(VALEUR) 
Variable Char    VALEUR()
Read [ATZ]CODZONE=[M]CODFIC;[M]ZONE(nolign-1)
If !fstat
 Read [ATY]CODTYP=[F:ATZ]CODTYP
 If [F:ATY]LNGTYP>0 & len(VALEUR)>[F:ATY]LNGTYP
  GMESSAGE = mess(2,124,1)-"("+num$(len(VALEUR))+"/"+num$([F:ATY]LNGTYP)+")" : # Champ trop long
  mkstat = 2 : End
 Endif
Endif 
End 
 
Subprog C_TEXPAT(VALEUR)
Variable Char    VALEUR()
If !instr(1,VALEUR,"*")
 VALEUR += "*"
Endif
End

Subprog AM_TEXPAT(VALEUR)
Variable Char    VALEUR()
[M]TEXPAT = VALEUR
Gosub LIGNES
zonsui = "TEXTETRA(0)"
End

