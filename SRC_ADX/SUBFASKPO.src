# LOCALISATION PORTUGAISE - FQ57371

# GLE 06/09/2010 FQ67036 : suppression du contrôle [F:KCO]REAVAUT<2 de C_KANOREAV
######################################################################################

Subprog D_NBLIG
 For I=0 To 9
   If [F:FAS]KVREAV(I)>0
     [M:KAS9]NBLIG+=1
   Else
     Break
   Endif
  Next I
End

Subprog C_KANOREAV(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
  NOL=nolign-1
  If NOL = 0 : Goto SALTA : Endif
  If VALEUR<=[M]KANOREAV(NOL-1)
    GMESSAGE=("O ano tem que ser superior ao ano anterior")
    mkstat=2
  Endif
  $SALTA
  # FQ67036
  #If !clalev([F:KCO]) : Local File KCOEF [KCO] : Endif
  #Read [F:KCO]KCO0=VALEUR
  #If [F:KCO]REAVAUT<2
  #  GMESSAGE=("Neste ano não foram aceites reavaliações fiscais")
  #  mkstat=2
  #Endif
End

Subprog C_KVREAV(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
  NOL=nolign-1
  If NOL = 0
    End
  Else
    If VALEUR<=[M]KVREAV(NOL-1)
      GMESSAGE=("O valor da reavaliação tem que ser superior à do ano anterior")
      mkstat=2
    Endif
  Endif
End

Subprog C_KAREAV(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
  NOL=nolign-1
  If NOL = 0 : End : Endif
  If VALEUR<=[M]KAREAV(NOL-1)
    GMESSAGE=("O valor das amortizações acumuladas reavaliadas têm que ser superior à do ano anterior")
    mkstat=2
  Endif
End

Subprog AS_KCOEF(VALEUR)
Variable Decimal VALEUR
  NOL=nolign-1
  If NOL>0
    VALEUR=[M]KVREAV(NOL)/[M]KVREAV(NOL-1)
  Endif
End

######################################################################################

# FIN LOCALISATION PORTUGAISE

######################################################################################
