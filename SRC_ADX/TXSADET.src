#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GPILCOD
GBIDC2 = "AUT"
GBIDC1 = "RATIOS1"
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "OK"          : Gosub OK
 When "FINSAI"      : Gosub FINSAI
 When "END"         : Gosub FIN
Endcase
Return

$DEBUT
Local Integer LIG , COL , LIG0 , COL0 , LIGMAX , COLMAX
LIG  = val(PARAM(1))
COL  = val(PARAM(2))
LIG0 = LIG
COL0 = COL
LIGMAX = [M:TXA2]NBLIG
COLMAX = [M:TXA1]NBRCOL
[M]L1 = "009"
[M]L2 = "010"
[M]L3 = "011"
[M]L4 = "012"
[M]C1 = "009"
[M]C2 = "010"
[M]C3 = "011"
[M]C4 = "012"
[M]FRMX = "260"
Gosub CHARGE
Return

$APRES_MODIF
Case zoncou
 When "C1"    : Gosub FIR
 When "C2"    : Gosub PRE
 When "C3"    : Gosub SUI
 When "C4"    : Gosub LAS
 When "L1"    : Gosub PREMLIG
 When "L2"    : Gosub PRECLIG
 When "L3"    : Gosub SUIVLIG
 When "L4"    : Gosub DERNLIG
Endcase
Return

$CHARGE
[M]LIG = LIG
[M]COL = COL
[M]LIGNAM = [M:TXA2]FRM0(LIG-1)
[M]COLNAM = [M:TXA1]NAMCOL(COL-1)
Case COL
 When 1  : [M]FRM = [M:TXA2]FRM1(LIG-1)
 When 2  : [M]FRM = [M:TXA2]FRM2(LIG-1)
 When 3  : [M]FRM = [M:TXA2]FRM3(LIG-1)
 When 4  : [M]FRM = [M:TXA2]FRM4(LIG-1)
 When 5  : [M]FRM = [M:TXA2]FRM5(LIG-1)
 When 6  : [M]FRM = [M:TXA2]FRM6(LIG-1)
 When 7  : [M]FRM = [M:TXA2]FRM7(LIG-1)
 When 8  : [M]FRM = [M:TXA2]FRM8(LIG-1)
 When 9  : [M]FRM = [M:TXA2]FRM9(LIG-1)
 When 10 : [M]FRM = [M:TXA2]FRM10(LIG-1)
 When 11 : [M]FRM = [M:TXA2]FRM11(LIG-1)
 When 12 : [M]FRM = [M:TXA2]FRM12(LIG-1)
 When 13 : [M]FRM = [M:TXA2]FRM13(LIG-1)
 When 14 : [M]FRM = [M:TXA2]FRM14(LIG-1)
 When 15 : [M]FRM = [M:TXA2]FRM15(LIG-1)
 When 16 : [M]FRM = [M:TXA2]FRM16(LIG-1)
 When 17 : [M]FRM = [M:TXA2]FRM17(LIG-1)
 When 18 : [M]FRM = [M:TXA2]FRM18(LIG-1)
 When 19 : [M]FRM = [M:TXA2]FRM19(LIG-1)
 When 20 : [M]FRM = [M:TXA2]FRM20(LIG-1)
Endcase
Call SETLF([M]FRM)
[M]FMTPRN = val(mid$([M:TXA2]FMTPRN(LIG-1),COL,1))
[M]EFFPRN = val(mid$([M:TXA2]EFFPRN(LIG-1),COL,1))
[M]DECCOL = val(mid$([M:TXA2]DEC(LIG-1),COL,1))
[M]CEN    = val(mid$([M:TXA2]CEN(LIG-1),COL,1))
Affzo
If [M:TXA1]COLNUM(COL-1)<>""
 Grizo FRM
Else
 Actzo FRM
Endif
Return

$DECHARGE
LIG = [M]LIG
COL = [M]COL
Call VIRELF([M]FRM)
Case COL
 When 1  : [M:TXA2]FRM1(LIG-1)  = [M]FRM
 When 2  : [M:TXA2]FRM2(LIG-1)  = [M]FRM
 When 3  : [M:TXA2]FRM3(LIG-1)  = [M]FRM
 When 4  : [M:TXA2]FRM4(LIG-1)  = [M]FRM
 When 5  : [M:TXA2]FRM5(LIG-1)  = [M]FRM
 When 6  : [M:TXA2]FRM6(LIG-1)  = [M]FRM
 When 7  : [M:TXA2]FRM7(LIG-1)  = [M]FRM
 When 8  : [M:TXA2]FRM8(LIG-1)  = [M]FRM
 When 9  : [M:TXA2]FRM9(LIG-1)  = [M]FRM
 When 10 : [M:TXA2]FRM10(LIG-1) = [M]FRM
 When 11 : [M:TXA2]FRM11(LIG-1) = [M]FRM
 When 12 : [M:TXA2]FRM12(LIG-1) = [M]FRM
 When 13 : [M:TXA2]FRM13(LIG-1) = [M]FRM
 When 14 : [M:TXA2]FRM14(LIG-1) = [M]FRM
 When 15 : [M:TXA2]FRM15(LIG-1) = [M]FRM
 When 16 : [M:TXA2]FRM16(LIG-1) = [M]FRM
 When 17 : [M:TXA2]FRM17(LIG-1) = [M]FRM
 When 18 : [M:TXA2]FRM18(LIG-1) = [M]FRM
 When 19 : [M:TXA2]FRM19(LIG-1) = [M]FRM
 When 20 : [M:TXA2]FRM20(LIG-1) = [M]FRM
Endcase
[M:TXA2]FMTPRN(LIG-1) = left$([M:TXA2]FMTPRN(LIG-1),COL-1)+num$([M]FMTPRN)+right$([M:TXA2]FMTPRN(LIG-1),COL+1)
[M:TXA2]EFFPRN(LIG-1) = left$([M:TXA2]EFFPRN(LIG-1),COL-1)+num$([M]EFFPRN)+right$([M:TXA2]EFFPRN(LIG-1),COL+1)
[M:TXA2]DEC(LIG-1)    = left$([M:TXA2]DEC(LIG-1),COL-1)+num$([M]DECCOL)+right$([M:TXA2]DEC(LIG-1),COL+1)
[M:TXA2]CEN(LIG-1)    = left$([M:TXA2]CEN(LIG-1),COL-1)+num$([M]CEN)+right$([M:TXA2]CEN(LIG-1),COL+1)
Return

$OK
 Gosub DECHARGE
Gosub AFFICHE
Return

$FINSAI
zonsui = "NBLIG"+"("+num$([M]LIG-1)+")"
mkstat = 99
Return

$FIN
Gosub AFFICHE
Return

$AFFICHE
If COLMAX>0  : Affzo [TXA2]FRM1  : Endif
If COLMAX>1  : Affzo [TXA2]FRM2  : Endif
If COLMAX>2  : Affzo [TXA2]FRM3  : Endif
If COLMAX>3  : Affzo [TXA2]FRM4  : Endif
If COLMAX>4  : Affzo [TXA2]FRM5  : Endif
If COLMAX>5  : Affzo [TXA2]FRM6  : Endif
If COLMAX>6  : Affzo [TXA2]FRM7  : Endif
If COLMAX>7  : Affzo [TXA2]FRM8  : Endif
If COLMAX>8  : Affzo [TXA2]FRM9  : Endif
If COLMAX>9  : Affzo [TXA2]FRM10 : Endif
If COLMAX>10 : Affzo [TXA2]FRM11 : Endif
If COLMAX>11 : Affzo [TXA2]FRM12 : Endif
If COLMAX>12 : Affzo [TXA2]FRM13 : Endif
If COLMAX>13 : Affzo [TXA2]FRM14 : Endif
If COLMAX>14 : Affzo [TXA2]FRM15 : Endif
If COLMAX>15 : Affzo [TXA2]FRM16 : Endif
If COLMAX>16 : Affzo [TXA2]FRM17 : Endif
If COLMAX>17 : Affzo [TXA2]FRM18 : Endif
If COLMAX>18 : Affzo [TXA2]FRM19 : Endif
If COLMAX>19 : Affzo [TXA2]FRM20 : Endif
Return

$SUI
Gosub DECHARGE
If COL<COLMAX
 COL += 1
Else
 COL = 1
Endif
Gosub CHARGE
Return

$PRE
Gosub DECHARGE
If COL>1
 COL -= 1
Else
 COL = COLMAX
Endif
Gosub CHARGE
Return

$FIR
Gosub DECHARGE : COL = 1 : Gosub CHARGE
Return

$LAS
Gosub DECHARGE : COL = COLMAX : Gosub CHARGE
Return

$PREMLIG
Gosub DECHARGE : LIG = 1 : Gosub CHARGE
Return

$SUIVLIG
Gosub DECHARGE
If LIG<LIGMAX
 LIG += 1
Else
 LIG = 1
Endif
Gosub CHARGE
Return

$PRECLIG
Gosub DECHARGE
If LIG>1
 LIG -= 1
Else
 LIG = LIGMAX
Endif
Gosub CHARGE
Return

$DERNLIG
Gosub DECHARGE : LIG = LIGMAX : Gosub CHARGE
Return

$SETBOUT
CHMEN = ""
Return

##########################################################################
## Ecran TXSADET
##########################################################################
Subprog C_FRM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]FRM
 [M:TXA2]MODIF = 2
Endif
Local Char FORMULE(250)
VALEUR = toupper(VALEUR)
FORMULE = VALEUR
Call VIRELF(FORMULE)
nolign = [M]LIG
Call C_FORMULE(FORMULE) From SUBTXSB
nolign = 1
End

Subprog B1_FRM(VALEUR)
Variable Char    VALEUR()
Call B1_FRM1(VALEUR) From SUBTXSA
End

Subprog B2_FRM(VALEUR)
Variable Char    VALEUR()
Call B2_FRM1(VALEUR) From SUBTXSA
End

Subprog VIRELF(FORMULE)
Variable Char FORMULE()
Local Integer I
Repeat
 I = instr(1,FORMULE,chr$(13)+chr$(10))
 If I
  FORMULE = left$(FORMULE,I-1)-right$(FORMULE,I+2)
 Endif
Until I=0
End

Subprog SETLF(FORMULE)
Variable Char FORMULE()
Local Char    NEWFOR(250)
Local Integer LGMAX , I , J
LGMAX = 60
While FORMULE<>""
 J = 0
 If len(FORMULE)<LGMAX
  NEWFOR += FORMULE
  FORMULE = ""
 Else
  For I=LGMAX+1 To 1 Step-1
   If mid$(FORMULE,I,1)=" "
    J = I : Break
   Endif
  Next I
  If J=0
   For J=LGMAX+1 To len(FORMULE)
    If mid$(FORMULE,I,1)=" "
     J = I : Break
    Endif
   Next J
  Endif
  If J=0
   NEWFOR += FORMULE
   FORMULE = ""
  Else
   NEWFOR += left$(FORMULE,J-1)
   If vireblc(right$(FORMULE,J+1),2)<>""
    NEWFOR += chr$(13)+chr$(10)
    FORMULE = vireblc(right$(FORMULE,J+1),2)
   Else
    FORMULE = ""
   Endif
  Endif
 Endif
Wend
FORMULE = NEWFOR
End

Subprog CL_L1(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_L2(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_L3(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_L4(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C1(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C2(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C3(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C4(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End



