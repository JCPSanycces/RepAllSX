#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE_BTRB
  When "AV_CHOIX" : Affzo [M:BTRB]
  When "END"      : Gosub END_BTRB
Endcase
Return

$OUVRE_BTRB
  If clalev([M:BTRB])=0   : Local Mask BTRBP      [BTRB]  : Endif
  If clalev([F:BAN]) =0   : Local File BANK       [BAN]   : Endif
  If clalev([F:BPL]) =0   : Local File BANKPOSD   [BPL]   : Endif
  If clalev([F:CFODD]) =0 : Local File CFODUDDATE [CFODD] : Endif

  Local Char TIT(50), SOC(5), CRITDUD(30), CRIT(250)(15)
  Local Char  BPBAN(5)(1..), CPT(15)(1..), BPCUR(3), CRITDUD1(250), CRITERE(250)
  Local Shortint I, J, K, L, TYPRAT, GRP
  Local Date DATINI, DATEND, PERINIDAT(15)(0..14), PERFINDAT(15)(0..14)
  Global Char GBPCOLDES(20)

  Raz [M:BTRB]

  GBPCOLDES=GCOLDES(GPER-1)

  Affzo [M:BTRB]

 PERFINDAT(0)=[M:BTR0]INIDAT-1
  Case [M:BTR0]PERCOD
    When 1: For H=1 To 14
              If H=1:  PERINIDAT(H)= [M:BTR0]INIDAT: PERFINDAT(H)=PERINIDAT(H)
              Else: PERINIDAT(H)= PERINIDAT(H-1)+1 : PERFINDAT(H)=PERINIDAT(H)
              Endif
              If PERFINDAT(H)>=[M:BTR0]ENDDAT: PERFINDAT(H)=[M:BTR0]ENDDAT: Break: Endif
            Next
    When 2: For H=1 To 14
              If H=1: PERINIDAT(H)= [M:BTR0]INIDAT: PERFINDAT(H)=PERINIDAT(H)+(7-dayn(PERINIDAT(H)))
              Else: PERINIDAT(H)= PERFINDAT(H-1)+1: PERFINDAT(H)=PERFINDAT(H-1)+7
              Endif
              If PERFINDAT(H)>=[M:BTR0]ENDDAT: PERFINDAT(H)=[M:BTR0]ENDDAT: Break: Endif
            Next
    When 3: For H=1 To 14
              If H=1: PERINIDAT(H)= [M:BTR0]INIDAT: PERFINDAT(H)=eomonth([M:BTR0]INIDAT)
              Else:  PERINIDAT(H)= PERFINDAT(H-1)+1: PERFINDAT(H)= eomonth(addmonth(PERFINDAT(H-1),1))
              Endif
              If PERFINDAT(H)>=[M:BTR0]ENDDAT: PERFINDAT(H)=[M:BTR0]ENDDAT: Break: Endif
            Next
  Endcase

  BPCUR=[M:BTR0]CUR
  TYPRAT=[M:BTR0]TYPRAT

  If [M:CBTR]CUR<>[M:BTR0]CUR
    BPCUR=[M:CBTR]CUR
    TYPRAT=[M:CBTR]TYPRAT
  Endif

  For I=0 To 14
    CRIT(I)="1=1"
  Next
  If [M:BTR1]TYPFRT(GNBL)=mess(195,121,1)
    DATINI=[00/00/00]
    DATEND=PERFINDAT(0)
    CRITDUD="TYP>'*CM99' &"
  Else
    DATINI=PERINIDAT(GPER-1)
    DATEND=PERFINDAT(GPER-1)
  Endif

  GRP=1
  Case [M:BTR0]LEVELA
    When 1:
      SOC=[M:BTR1]CPY(GNBL)
      GRP=0
    When 2:
      BANKGR=[M:BTR1]GRPBAN(GNBL)
    When 3:
      Raz GTBAN
      BANK=[M:BTR1]BAN(GNBL)
      GBAN=1: GTBAN(1)=BANK
    When 4:
      Raz GSIT
      SIT=[M:BTR1]FCY(GNBL)
      GSIT(1)=SIT
  Endcase

  Case [M:BTR0]LEVELD
    When 1: Gosub BPR_TOT
    When 2: Gosub TYP_CFO
  Endcase

  Onerrgo ERR_BPERROR

  Gosub READ_CFOD
  Gosub WRITE_SCR
  Filter [BPL]
Return


$BPR_TOT

   CRITDUD1="1=1"

   If [M:BTR1]TYPFRT(GNBL)<>mess(195,121,1)

     If [M:BTR0]TYPGAC=2:   CFOCRIT ="1" :  Else:  CFOCRIT ="0" : Endif #accounting
     If [M:BTR0]TYPDUD=2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #due date
     If [M:BTR0]CFOPQ =2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #RFQs
     If [M:BTR0]CFOPC =2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #purchasing contract
     If [M:BTR0]CFOPO =2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #purchase orders
     If [M:BTR0]CFORN =2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #receipts
     If [M:BTR0]CFOSQ =2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #quotes
     If [M:BTR0]CFOSO =2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #sales orders
     If [M:BTR0]CFOSC =2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #sales contract
     If [M:BTR0]CFOCM =2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #CRM contract
     If [M:BTR0]CFODN =2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #deliveries
     If [M:BTR0]CFOLEA=2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #leasing
     If [M:BTR0]CFOME =2:   CFOCRIT+="1" :  Else:  CFOCRIT+="0" : Endif #manual forecast


     If instr(2,CFOCRIT,"1")<>0
       CRITDUD1= "("
       If mid$(CFOCRIT,2,1)="1" : CRITDUD1 += "TYP>'*CM99'"          : Endif                #Due date
       If mid$(CFOCRIT,3,1)="1"
         If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM01'":  Else CRITDUD1 -= "TYP='*CM01'":  Endif
       Endif                                                                                #RFQ´s
       If mid$(CFOCRIT,4,1)="1"
         If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM02'":  Else CRITDUD1 -= "TYP='*CM02'":  Endif
       Endif                                                                                 #Purchasing contract
       If mid$(CFOCRIT,5,1)="1"
         If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM03'":  Else CRITDUD1 -= "TYP='*CM03'":  Endif
       Endif                                                                                 #Purchase orders
       If mid$(CFOCRIT,6,1)="1"
         If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM04'":  Else CRITDUD1 -= "TYP='*CM04'":  Endif
       Endif                                                                                 #Receipts
       If mid$(CFOCRIT,7,1)="1"
         If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM05'":  Else CRITDUD1 -= "TYP='*CM05'":  Endif
       Endif                                                                                 #Quotes
       If mid$(CFOCRIT,8,1)="1"
         If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM06'":  Else CRITDUD1 -= "TYP='*CM06'":  Endif
       Endif                                                                                 #Sales orders
       If mid$(CFOCRIT,9,1)="1"
         If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM07'":  Else CRITDUD1 -= "TYP='*CM07'":  Endif
       Endif                                                                                 #Sales contract
       If mid$(CFOCRIT,10,1)="1"
         If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM08'":  Else CRITDUD1 -= "TYP='*CM08'":  Endif
       Endif                                                                                 #CRM contract
       If mid$(CFOCRIT,11,1)="1"
         If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM09'":  Else CRITDUD1 -= "TYP='*CM09'":  Endif
       Endif                                                                                 #Deliveries
       If mid$(CFOCRIT,12,1)="1"
         If len(CRITDUD1)>1: CRITDUD1 -= "or TYP='*CM10'":  Else CRITDUD1 -= "TYP='*CM10'":  Endif
       Endif                                                                                 #Leasing
       CRITDUD1 +=')'
       If mid$(CFOCRIT,13,1)="1":
         If len(CRITDUD1)>1: CRITDUD1 -= "or (TYP>'*CM10' & TYP<'*CM99')": Else CRITDUD1 -= "(TYP>'*CM10' & TYP<'*CM99')": Endif
       Endif                                                                                  #Manual forecast
       Endif
    Endif
Return


$TYP_CFO
  Local Shortint PERIODE
  CRITDUD1="1=1"

  For I=1 To 19
    If [M:BTR1]TYPFRT(GNBL)=mess(I,3636,1)                               # CFO type
      CRITDUD="TYP='*CM"+format$("N0:2",I)+"' &"
      Break
    Endif
  Next
  If [M:BTR1]TYPFRT(GNBL)=mess(199,121,1) or [M:BTR1]TYPFRT(GNBL)=mess(195,121,1)
    CRITDUD="TYP>'*CM99' &"
  Endif
  If [M:BTR1]TYPFRT(GNBL)=mess(201,121,1)
    CRITDUD="TYP='*CM20' &"
  Endif
Return

$READ_CFOD
Local Char BPDET(15)(1..)
Local Shortint NBP, NB
Local Integer STAT, FILSTA
Local Decimal AMTBP(1..), AMTCV(1..)

Global Char GVCRBP(15)(1..), GVCRNUM(20)(1..), GVCRBAN(5)(1..)
Global Date GVCRDUD(1..)
Global Decimal GVCRAMT(1..)
Global Shortint GNVCR


For I=1 To GNBAN
  OKK=0
  Read [BAN]BAN0=GTBAN(I)
  If GRP=1: SOC=[F:BAN]CPY
  Else: If [F:BAN]CPY<>SOC: OKK=1: Endif
  Endif
  If OKK=0
    For J=1 To GNSITE
      Read [FCY]FCY0=GSIT(J)
      If [F:FCY]LEGCPY=SOC
        Raz OKK
        CRITERE=CRITDUD
        If DATINI<>[00/00/00]
          CRITERE +="CPY='"+SOC+"'& FCY='"+GSIT(J)+"' & CFOBAN='"+GTBAN(I)+"' & CFODAT>=["+format$(GFMD,DATINI)+"] & CFODAT<=["+format$(GFMD,DATEND)+"] & AMTCUR<>PAYCUR"
        Else
          CRITERE +="CPY='"+SOC+"'& FCY='"+GSIT(J)+"' & CFOBAN='"+GTBAN(I)+"' & CFODAT<["+format$(GFMD,DATEND)+"] & AMTCUR<>PAYCUR"
        Endif

        Filter [CFODD] Where evalue(CRITERE) & evalue(CRITDUD1) Order By TYP;CFODAT Asc

        For [CFODD]
          Call OTHERCRIT([F:CFODD]NUM,FILSTA,3) From CNSBTRSTD
          If FILSTA=0
            K=find([F:CFODD]BPR,BPDET())
            If K=0
              NBP+=1
              BPDET(NBP) = [F:CFODD]BPR
              NB=NBP
            Elsif K>0
              NB=K
            Endif
            AMTCV(NB) = ([F:CFODD]AMTCUR-[F:CFODD]PAYCUR)*[F:CFODD]SNS
            If [F:CFODD]CUR<>BPCUR
              Call CONVERT([F:CFODD]CUR,BPCUR,[M:BTR0]CURCPY,TYPRAT,[F:CFODD]CFODAT,[F:CFODD]AMTCUR,AMTCV(NB),STAT) From TRTDEV
              AMTCV(NB)= AMTCV(NB)*[F:CFODD]SNS  # SAM 120007
            Endif
            AMTBP(NB) += AMTCV(NB)
            If AMTBP(NB)<>0
              GNVCR+=1
              Gosub FILL_GLOBVCR
            Endif
          Endif
        Next
      Endif
    Next
    Raz CRITERE
 Endif
Next
Filter [CFODD]

Return

$WRITE_SCR
  For I=1 To NBP
    [M:BTRB]BPR(I-1)     = BPDET(I)
    [M:BTRB]AMOUNT(I-1)  = AMTBP(I)
    [M:BTRB]CUR(I-1)     = BPCUR
  Next

  [M:BTRB]NBLIG=NBP

  Affzo [M:BTRB]

Return


$FILL_GLOBVCR
GVCRBP(GNVCR)   = BPDET(NB)
GVCRNUM(GNVCR)  = [F:CFODD]NUM
GVCRAMT(GNVCR)  = AMTCV(NB)
GVCRDUD(GNVCR)  = [F:CFODD]CFODAT
GVCRBAN(GNVCR)  = [F:CFODD]CFOBAN

Return

$DOC_DETAIL
Local Char SOC(GLONCPY)
Local Char    PARMSK(250)(1..20), SAVACT(20)
Global Integer GNBD

GNBD=nolign-1

If [M:BTR1]CPY(GNBD)<>"": SOC=[M:BTR1]CPY(GNBD) Else SOC=[M:BTR0]CPY: Endif

SAVACT = GACTION : GACTION = "BTRVCR"

Call TRAITE_CHAR(SOC,PARMSK,"","SUBBTRVCR","BTRVCR",4,"BTRVCR") From GTRAITE

GACTION = SAVACT

Kill GNBD

Return

$ERR_BPERROR
Resume

$END_BTRB
  Kill GVCRBP, GVCRNUM, GVCRAMT, GVCRDUD, GVCRBAN, GNVCR
Return

######################################################################################
## Section automatically added (screen BTRBP) 11/05/2013 16:39:53 (JUCON)
######################################################################################
Subprog AV_AMOUNT(VALEUR)
Variable Decimal VALEUR
  Diszo [M:BTRB]AMOUNT(nolign-1)
End

Subprog B1_AMOUNT(VALEUR)
Variable Decimal VALEUR
  Gosub DOC_DETAIL
End


######################################################################################

