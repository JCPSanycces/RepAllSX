#<AdxTL>@(#)%I%
# Supervisor
# Inquiry SBF

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:18"
A_USER  = "ADMIN"
A_STAMP = "20181109081118"
Return

$DEFAUT
Default File [PLF]
Return

$OUVFIC
Local File PLNFORM [PLF]
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(44888,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSSBFSTD"
PROGSPE    = "CNSSBFSPE"
CBOITE     = "DCNSSBF"
BOITE      = "FCNSSBF"
NOMMSK(0)  = "CONSSBF1"
ABMSK(0)   = "SBF1"
NOMMSK(1)  = "CONSSBF2"
ABMSK(1)   = "SBF2"
NOMMSK(2)  = "CONSSBF3"
ABMSK(2)   = "SBF3"
CMEMO      = "sbf"
CNOMMSK    = "CRITSBF"
CABMSK     = "CSBF"
NOMFIC     = "PLNFORM"
ABFIC      = "PLF"
OBJDERLU   = "PLF"
MAGNETO    = 2
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..5), CLEMSK(10)(0..5)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = "PLF0"
NBCMP = 6
CLECMP(0) = "YEAPLF"
CLEMSK(0) = "YEAPLF"
CLECMP(1) = "LEGPLF"
CLEMSK(1) = "LEGPLF"
CLECMP(2) = "CPYPLF"
CLEMSK(2) = "CPYPLF"
CLECMP(3) = "FCYPLF"
CLEMSK(3) = "FCYPLF"
CLECMP(4) = "VERPLF"
CLEMSK(4) = "VERPLF"
CLECMP(5) = "NUMLIG"
CLEMSK(5) = "NUMLIG"
Return

$OUVRE
If clalev([F:PLF])=0 : Local File PLNFORM      [PLF] : Endif
If clalev([F:PLF])=0 : Local File PLNFORM      [PLF] : Endif
If clalev([F:PLC])=0 : Local File PLNCOUT      [PLC] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CSBF]
 When  0 : Local Mask =NOMMSK(0) [SBF1]
 When  1 : Local Mask =NOMMSK(1) [SBF2]
 When  2 : Local Mask =NOMMSK(2) [SBF3]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CSBF]
 When  0 : Grizo [SBF1]
 When  1 : Grizo [SBF2]
 When  2 : Grizo [SBF3]
Endcase
Return

$GRISE_CLE
Case MA
 When -1 : If dim([M:CSBF]YEAPLF)>0 : Grizo [CSBF]YEAPLF : Endif
           If dim([M:CSBF]LEGPLF)>0 : Grizo [CSBF]LEGPLF : Endif
           If dim([M:CSBF]CPYPLF)>0 : Grizo [CSBF]CPYPLF : Endif
           If dim([M:CSBF]FCYPLF)>0 : Grizo [CSBF]FCYPLF : Endif
           If dim([M:CSBF]NUMLIG)>0 : Grizo [CSBF]NUMLIG : Endif
 When  0 : If dim([M:SBF1]YEAPLF)>0 : Grizo [SBF1]YEAPLF : Endif
           If dim([M:SBF1]LEGPLF)>0 : Grizo [SBF1]LEGPLF : Endif
           If dim([M:SBF1]CPYPLF)>0 : Grizo [SBF1]CPYPLF : Endif
           If dim([M:SBF1]FCYPLF)>0 : Grizo [SBF1]FCYPLF : Endif
           If dim([M:SBF1]VERPLF)>0 : Grizo [SBF1]VERPLF : Endif
           If dim([M:SBF1]NUMLIG)>0 : Grizo [SBF1]NUMLIG : Endif
Endcase
Return

$GRISE_CRIT
If dim([M:CSBF]YEAPLF)>0
 Grizo [CSBF]YEAPLF
Endif
If dim([M:CSBF]LEGPLF)>0
 Grizo [CSBF]LEGPLF
Endif
If dim([M:CSBF]ALLCPY)>0
 Grizo [CSBF]ALLCPY
Endif
If dim([M:CSBF]CPYPLF)>0
 Grizo [CSBF]CPYPLF
Endif
If dim([M:CSBF]ALLFCY)>0
 Grizo [CSBF]ALLFCY
Endif
If dim([M:CSBF]FCYPLF)>0
 Grizo [CSBF]FCYPLF
Endif
If dim([M:CSBF]NUMLIG)>0
 Grizo [CSBF]NUMLIG
Endif
If dim([M:CSBF]CRIDSY)>0
 Grizo [CSBF]CRIDSY
Endif
If dim([M:CSBF]STRDAT)>0
 Grizo [CSBF]STRDAT
Endif
If dim([M:CSBF]ENDDAT)>0
 Grizo [CSBF]ENDDAT
Endif
If dim([M:CSBF]MONREA)>0
 Grizo [CSBF]MONREA
Endif
If dim([M:CSBF]YEAREA)>0
 Grizo [CSBF]YEAREA
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CSBF])>0 : Close Local Mask [CSBF] : Endif
 When  0 : If clalev([M:SBF1])>0 : Close Local Mask [SBF1] : Endif
 When  1 : If clalev([M:SBF2])>0 : Close Local Mask [SBF2] : Endif
 When  2 : If clalev([M:SBF3])>0 : Close Local Mask [SBF3] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CSBF]
 When  0 : Default Mask [SBF1]
 When  1 : Default Mask [SBF2]
 When  2 : Default Mask [SBF3]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CSBF]
 When  0 : Raz [M:SBF1]
 When  1 : Raz [M:SBF2]
 When  2 : Raz [M:SBF3]
Endcase
Return

$CRITENT
If dim([M:CSBF]YEAPLF)>0 & dim([M:SBF1]YEAPLF)>0
 [M:CSBF]YEAPLF = [M:SBF1]YEAPLF
Endif
If dim([M:CSBF]LEGPLF)>0 & dim([M:SBF1]LEGPLF)>0
 [M:CSBF]LEGPLF = [M:SBF1]LEGPLF
Endif
If dim([M:CSBF]ALLCPY)>0 & dim([M:SBF1]ALLCPY)>0
 [M:CSBF]ALLCPY = [M:SBF1]ALLCPY
Endif
If dim([M:CSBF]CPYPLF)>0 & dim([M:SBF1]CPYPLF)>0
 [M:CSBF]CPYPLF = [M:SBF1]CPYPLF
Endif
If dim([M:CSBF]ALLFCY)>0 & dim([M:SBF1]ALLFCY)>0
 [M:CSBF]ALLFCY = [M:SBF1]ALLFCY
Endif
If dim([M:CSBF]FCYPLF)>0 & dim([M:SBF1]FCYPLF)>0
 [M:CSBF]FCYPLF = [M:SBF1]FCYPLF
Endif
If dim([M:CSBF]NUMLIG)>0 & dim([M:SBF1]NUMLIG)>0
 [M:CSBF]NUMLIG = [M:SBF1]NUMLIG
Endif
If dim([M:CSBF]CRIDSY)>0 & dim([M:SBF1]CRIDSY)>0
 [M:CSBF]CRIDSY = [M:SBF1]CRIDSY
Endif
If dim([M:CSBF]STRDAT)>0 & dim([M:SBF1]STRDAT)>0
 [M:CSBF]STRDAT = [M:SBF1]STRDAT
Endif
If dim([M:CSBF]ENDDAT)>0 & dim([M:SBF1]ENDDAT)>0
 [M:CSBF]ENDDAT = [M:SBF1]ENDDAT
Endif
If dim([M:CSBF]MONREA)>0 & dim([M:SBF1]MONREA)>0
 [M:CSBF]MONREA = [M:SBF1]MONREA
Endif
If dim([M:CSBF]YEAREA)>0 & dim([M:SBF1]YEAREA)>0
 [M:CSBF]YEAREA = [M:SBF1]YEAREA
Endif
Return

$ENTCRIT
If dim([M:CSBF]YEAPLF)>0 & dim([M:SBF1]YEAPLF)>0
[M:SBF1]YEAPLF = [M:CSBF]YEAPLF
Endif
If dim([M:CSBF]LEGPLF)>0 & dim([M:SBF1]LEGPLF)>0
[M:SBF1]LEGPLF = [M:CSBF]LEGPLF
Endif
If dim([M:CSBF]ALLCPY)>0 & dim([M:SBF1]ALLCPY)>0
[M:SBF1]ALLCPY = [M:CSBF]ALLCPY
Endif
If dim([M:CSBF]CPYPLF)>0 & dim([M:SBF1]CPYPLF)>0
[M:SBF1]CPYPLF = [M:CSBF]CPYPLF
Endif
If dim([M:CSBF]ALLFCY)>0 & dim([M:SBF1]ALLFCY)>0
[M:SBF1]ALLFCY = [M:CSBF]ALLFCY
Endif
If dim([M:CSBF]FCYPLF)>0 & dim([M:SBF1]FCYPLF)>0
[M:SBF1]FCYPLF = [M:CSBF]FCYPLF
Endif
If dim([M:CSBF]NUMLIG)>0 & dim([M:SBF1]NUMLIG)>0
[M:SBF1]NUMLIG = [M:CSBF]NUMLIG
Endif
If dim([M:CSBF]CRIDSY)>0 & dim([M:SBF1]CRIDSY)>0
[M:SBF1]CRIDSY = [M:CSBF]CRIDSY
Endif
If dim([M:CSBF]STRDAT)>0 & dim([M:SBF1]STRDAT)>0
[M:SBF1]STRDAT = [M:CSBF]STRDAT
Endif
If dim([M:CSBF]ENDDAT)>0 & dim([M:SBF1]ENDDAT)>0
[M:SBF1]ENDDAT = [M:CSBF]ENDDAT
Endif
If dim([M:CSBF]MONREA)>0 & dim([M:SBF1]MONREA)>0
[M:SBF1]MONREA = [M:CSBF]MONREA
Endif
If dim([M:CSBF]YEAREA)>0 & dim([M:SBF1]YEAREA)>0
[M:SBF1]YEAREA = [M:CSBF]YEAREA
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
CRITAFF(1) = "CRIDSY" : CRITAFF2(1) = "CRIDSY"
NBCA = 1
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSSBF2"
Call AS_NBLIG From ="W1CONSSBF3"
NBBOUT = 0
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "SBF"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]STGPREV(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("STG","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT2<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT2
 VALBOUT(NBBOUT) = "SBF"
 VALBOUT(NBBOUT) += "~B2"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]DEMPREV(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("DEM","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M]DEMPREV(nolign-1),"~","¨")
 Onerrgo
Endif
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "SBF"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]STGPREV(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("STG","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT2<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT2
 VALBOUT(NBBOUT) = "SBF"
 VALBOUT(NBBOUT) += "~B2"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]DEMPREV(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("DEM","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M]DEMPREV(nolign-1),"~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B1"
  Onerrgo RIEN
  Assign "[M]STGPREV(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B1_NBLIG From ="W1CONSSBF2"
 When "B2"
  Onerrgo RIEN
  Assign "[M]DEMPREV(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "[M]DEMPREV(nolign-1)" With ctrans(func AFNC.PART(INFO,5),"¨","~")
  Onerrgo
  Call B2_NBLIG From ="W1CONSSBF2"
 When "B1"
  Onerrgo RIEN
  Assign "[M]STGPREV(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B1_NBLIG From ="W1CONSSBF3"
 When "B2"
  Onerrgo RIEN
  Assign "[M]DEMPREV(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "[M]DEMPREV(nolign-1)" With ctrans(func AFNC.PART(INFO,5),"¨","~")
  Onerrgo
  Call B2_NBLIG From ="W1CONSSBF3"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


