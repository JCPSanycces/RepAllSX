#<AdxTL>@(#)9.0.0.0 $Revision$ Consultation SAD
Local Char PARAM(20)(1..3)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = ""
Call GCONSULT("SCI","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV])=0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITG])=0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:STE])=0 : Local File STOPAR     [STE] : Endif
If GWRHACT = 2                                                    # hcb 62371
   If clalev([F:ITW]) = 0 : Local File ITMWRH    [ITW] : Endif
   If clalev([F:WRH]) = 0 : Local File WAREHOUSE [WRH] : Endif
Endif
Local Date    WNEXCUNDAT                                          # hcb 62371

#
Local Char    WFIL(250)
Local Char    WFILS(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
#
Local Decimal WTO1
Local Decimal WTO2
Local Decimal WTO3
Local Decimal WTOT(5,14)
Local Char    WMSG(120)
Local Char    WPAR
Local Integer WDAY
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSCI"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SCI1]FLG = 0
Return
############################################################
$AP_MAGNETO
[M:SCI1]FLG = 0
Return
############################################################
$FERME
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SCI1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
Return
############################################################
$LECTURE
SUITE  = 1
RETOUR = 1
NBLU   = 2
If [M:SCI1]FCY = "" | [M:SCI1]FLG = 2
  [M:SCI1]FLG = 0
  NBLU = 0
  Return
Endif
#
WMSG = mess(114,197,1)+" "+[M:SCI1]FCY
Call OUVRE_TRACE(WMSG) From LECFIC
#
Call TRT_CAL([M:SCI1]FCY,WTO1,WTO2,WTO3,WTOT,WMSG)
If WMSG <> ""
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
Gosub LOA_TAB
Gosub MAJ_STE
NOL += 5
Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
###########################################################
$LOA_TAB
[M:SCI2]CYCCUNCOD = WTO1
[M:SCI2]YEACUNCOD = WTO2
[M:SCI2]NONCUNCOD = WTO3
For I = 0 To 4
  [M:SCI2]CUNTOT(I) = WTOT(I,0)
  [M:SCI2]CUN01(I)  = WTOT(I,1)
  [M:SCI2]CUN02(I)  = WTOT(I,2)
  [M:SCI2]CUN03(I)  = WTOT(I,3)
  [M:SCI2]CUN04(I)  = WTOT(I,4)
  [M:SCI2]CUN05(I)  = WTOT(I,5)
  [M:SCI2]CUN06(I)  = WTOT(I,6)
  [M:SCI2]CUN07(I)  = WTOT(I,7)
  [M:SCI2]CUN08(I)  = WTOT(I,8)
  [M:SCI2]CUN09(I)  = WTOT(I,9)
  [M:SCI2]CUN10(I)  = WTOT(I,10)
  [M:SCI2]CUN11(I)  = WTOT(I,11)
  [M:SCI2]CUN12(I)  = WTOT(I,12)
  [M:SCI2]ITMNBR(I) = WTOT(I,13)
Next I
[M:SCI2]DES(0) = mess(1,212,1)
[M:SCI2]DES(1) = mess(2,212,1)
[M:SCI2]DES(2) = mess(3,212,1)
[M:SCI2]DES(3) = mess(4,212,1)
[M:SCI2]DES(4) = mess(9,197,1)
#Calcul comptages par jour
#Lecture paramètre nombre de jours ouvrés
Call PARAM([M:SCI1]FCY,"AVGWRKDAY",WPAR) From ADOVAL
If WPAR = ""
  WDAY = 250
Else
  WDAY = (val(WPAR)*12)
Endif
If WDAY <> 0
  [M:SCI2]AVGWRKDAY = WDAY
  [M:SCI2]CUNNBRA = int(WTOT(0,0)/WDAY)
  [M:SCI2]CUNNBRB = int(WTOT(1,0)/WDAY)
  [M:SCI2]CUNNBRC = int(WTOT(2,0)/WDAY)
  [M:SCI2]CUNNBRD = int(WTOT(3,0)/WDAY)                                                   # hcb 62371
  [M:SCI2]CUNNBRT = sum([M:SCI2]CUNNBRA,[M:SCI2]CUNNBRB,[M:SCI2]CUNNBRC,[M:SCI2]CUNNBRD)  # hcb 62371
Endif
#Ecriture trace
WTXT = format$("K:20X",mess(1,216,1))+" : "+num$(WTO1)
Call ECR_TRACE(WTXT,0) From GESECRAN
WTXT = format$("K:20X",mess(2,216,1))+" : "+num$(WTO2)
Call ECR_TRACE(WTXT,0) From GESECRAN
WTXT = format$("K:20X",mess(3,216,1))+" : "+num$(WTO3)
Call ECR_TRACE(WTXT,0) From GESECRAN
For I = 0 To 3
  WTXT = ""
  Call ECR_TRACE(WTXT,0) From GESECRAN
  For J = 1 To 12
    WTXT = format$("K:20X",mess(I+1,212,1))+" "+format$("K:15X",month$(J))+" : "+
&          num$(WTOT(I,J))
    Call ECR_TRACE(WTXT,0) From GESECRAN
  Next J
Next I
WTXT = ""
Call ECR_TRACE(WTXT,0) From GESECRAN
I = 4
For J = 1 To 12
    WTXT = format$("K:20X",mess(9,197,1))+" "+format$("K:15X",month$(J))+" : "+
&          num$(WTOT(I,J))
    Call ECR_TRACE(WTXT,0) From GESECRAN
  Next J
Return
############################################################
$MAJ_STE
# Sur les dossiers historisés on ne reecrit pas
If GHISTO : Return : Endif                          # hcb Historisation

# hcb 50599
Call DEBTRANS From GLOCK
Trbegin [STE]

Readlock [STE]STE0=[M:SCI1]FCY;""
If fstat
   Rollback
   Return
Endif
[F:STE]YEACUNNBRA = [M:SCI2]CUNTOT(0)
[F:STE]YEACUNNBRB = [M:SCI2]CUNTOT(1)
[F:STE]YEACUNNBRC = [M:SCI2]CUNTOT(2)
[F:STE]YEACUNNBRD = [M:SCI2]CUNTOT(3)    # hcb 62371
Rewrite [STE]
If fstat
   Call FSTA("STE") From GLOCK
   Rollback
   Return
Endif
Commit
# hcb 50599

Return
###########################################################
#Calcul
Subprog TRT_CAL(LFCY,LTO1,LTO2,LTO3,LTOT,LMSG)
Variable Char    LFCY
Variable Decimal LTO1
Variable Decimal LTO2
Variable Decimal LTO3
Variable Decimal LTOT(,)
Variable Char    LMSG
#
Local    Integer WIND
#Local    Integer WPERA(100)          # hcb 62371
#Local    Integer WPERB(100)          # hcb 62371
#Local    Integer WPERC(100)          # hcb 62371
#Local    Integer WPERD(100)          # hcb 62371
#Local    Char    WCAT(GLONITG)(100)  # hcb 62371
Local    Integer WDEFA
Local    Integer WDEFB
Local    Integer WDEFC
Local    Integer WDEFD
Local    Integer WPER
Local    Date    WDAT
Local    Integer WFSTAT, WWFSTAT, WCOD
Local    Char    WTXT(70)
Local    Integer I, J, K
#
Call TEMPON(mess(114,197,1)) From GESECRAN
#Stockage en mémoire des périodicités par catégorie
If clalev([F:ITM]) = 0 Local File ITMMASTER [ITM] : Endif
If clalev([F:ITF]) = 0 Local File ITMFACILIT[ITF] : Endif
If clalev([F:ITV]) = 0 Local File ITMMVT    [ITV] : Endif
If clalev([F:STE]) = 0 Local File STOPAR    [STE] : Endif
If clalev([F:ITG]) = 0 Local File ITMCATEG  [ITG] : Endif
#                                                                 # hcb 62371 deb
If GWRHACT = 2
   If clalev([F:ITW]) = 0 : Local File ITMWRH    [ITW] : Endif
   If clalev([F:WRH]) = 0 : Local File WAREHOUSE [WRH] : Endif
Endif
Local    Integer WNBITG
WNBITG = nbrecord([ITG])+1
Local    Integer WPERA        (WNBITG)
Local    Integer WPERB        (WNBITG)
Local    Integer WPERC        (WNBITG)
Local    Integer WPERD        (WNBITG)
Local    Char    WCAT(GLONITG)(WNBITG)
#                                                                 # hcb 62371 fin
Raz LMSG, LTO1, LTO2, LTO3
For I = 0 To 4
  For J = 0 To 13
    LTOT(I,J) = 0
  Next J
Next I
#lecture valeurs par défaut du site
Read [STE]STE0=LFCY;""
If fstat
  LMSG = mess(174,199,1)
  Goto TRT_CAL2
Endif
WDEFA = [F:STE]DAYGAPCLSA
WDEFB = [F:STE]DAYGAPCLSB
WDEFC = [F:STE]DAYGAPCLSC
WDEFD = [F:STE]DAYGAPCLSD
#
Raz WIND, WPERA, WPERB, WPERC, WPERD, WCAT
Filter [ITG]
For [ITG]
  If WIND < dim(WCAT)-1
    WCAT(WIND) = [F:ITG]TCLCOD
    WFSTAT = fstat
    Read [STE]STE0=LFCY;[F:ITG]TCLCOD
      If fstat
        WPERA(WIND) = WDEFA
        WPERB(WIND) = WDEFB
        WPERC(WIND) = WDEFC
        WPERD(WIND) = WDEFD
      Else
        WPERA(WIND) = [F:STE]DAYGAPCLSA
        WPERB(WIND) = [F:STE]DAYGAPCLSB
        WPERC(WIND) = [F:STE]DAYGAPCLSC
        WPERD(WIND) = [F:STE]DAYGAPCLSD
      Endif
    fstat  = WFSTAT
    WIND += 1
  Else
    Raz WIND
  Endif
Next
Filter [ITG]
#                                         hcb 62371 deb
If  GWRHACT = 2  & [F:FCY]WRHGES = 2
    Link [ITW] With [ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY,[ITV]ITV0=[F:ITW]ITMREF;[F:ITW]STOFCY,[ITM]ITM0=[F:ITW]ITMREF
&        As [LNK]
&        Where STOFCY = LFCY
&        Order By Key ITW1
Else
    Link [ITF] With [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY,[ITM]ITM0=[F:ITF]ITMREF
&        As [LNK]
&        Where STOFCY = LFCY
&        Order By Key ITF1
Endif
    For [LNK]
        If GWRHACT = 2 & [F:FCY]WRHGES = 2
           WNEXCUNDAT = [F:ITV]NEXCUNDAT
           If [F:ITW]CUNWRHFLG = 2
              If [F:ITW]NEXCUNDAT = [0/0/0]
                 If [F:ITW]CREDAT = [0/0/0]
                    WDAT = [F:ITF]CREDAT
                 Else
                    WDAT = [F:ITW]CREDAT
                 Endif
                 WCOD = [F:ITW]CUNCOD
                 Call CAL_NEXINVITW([F:ITF]STOFCY,[F:ITM]TCLCOD,WDAT,WCOD) From STKINV
              Endif
              WNEXCUNDAT = [F:ITW]NEXCUNDAT
              WCOD       = [F:ITW]CUNCOD
           Else
              If [F:ITV]NEXCUNDAT = [0/0/0]
                 If [F:ITV]CREDAT = [0/0/0]
                    WDAT = [F:ITF]CREDAT
                 Else
                    WDAT = [F:ITV]CREDAT
                 Endif
                 WCOD = [F:ITF]CUNCOD
                 Call CAL_NEXINV([F:ITF]STOFCY,[F:ITM]TCLCOD,WDAT,WCOD) From STKINV
              Endif
              WNEXCUNDAT = [F:ITV]NEXCUNDAT
              WCOD       = [F:ITF]CUNCOD
           Endif
        Else
           If [F:ITV]NEXCUNDAT = [0/0/0]
              If [F:ITV]CREDAT = [0/0/0]
                 WDAT = [F:ITF]CREDAT
              Else
                 WDAT = [F:ITV]CREDAT
              Endif
              WCOD = [F:ITF]CUNCOD
              Call CAL_NEXINV([F:ITF]STOFCY,[F:ITM]TCLCOD,WDAT,WCOD) From STKINV
           Endif
           WNEXCUNDAT = [F:ITV]NEXCUNDAT
           WCOD       = [F:ITF]CUNCOD
        Endif
        Case WCOD
             When 1 :
                  LTO1 += 1
                  Case [F:ITF]ABCCLS
                       When 1 :
                            LTOT(0,13) += 1
                            LTOT(4,13) += 1
                            Gosub CAL_TOURNANT
                       When 2 :
                            LTOT(1,13) += 1
                            LTOT(4,13) += 1
                            Gosub CAL_TOURNANT
                       When 3 :
                            LTOT(2,13) += 1
                            LTOT(4,13) += 1
                            Gosub CAL_TOURNANT
                       When 4 :
                            LTOT(3,13) += 1
                            LTOT(4,13) += 1
                            Gosub CAL_TOURNANT
                  Endcase
             When 2 :
                  LTO2 += 1
             When 3 :
                  LTO3 += 1
        Endcase
    Next
    Filter [LNK]
#                                         hcb 62371 fin
$TRT_CAL2
Call TEMPOFF From GESECRAN
End
###########################################################
#Comtage inventaire tournant
$CAL_TOURNANT
WPER = 0
If WIND <> 0
  J = find([F:ITM]TCLCOD,WCAT(0..WIND-1))
  If J <> 0
    Case [F:ITF]ABCCLS
      When 1 : WPER = WPERA(J-1)
      When 2 : WPER = WPERB(J-1)
      When 3 : WPER = WPERC(J-1)
      When 4 : WPER = WPERD(J-1)
    Endcase
  Endif
Else
  WWFSTAT = fstat
  Read [STE]STE0=LFCY;[F:ITM]TCLCOD
  If fstat
    Case [F:ITF]ABCCLS
      When 1 : WPER = WDEFA
      When 2 : WPER = WDEFB
      When 3 : WPER = WDEFC
      When 4 : WPER = WDEFD
    Endcase
  Else
    Case [F:ITF]ABCCLS
      When 1 : WPER = [F:STE]DAYGAPCLSA
      When 2 : WPER = [F:STE]DAYGAPCLSB
      When 3 : WPER = [F:STE]DAYGAPCLSC
      When 4 : WPER = [F:STE]DAYGAPCLSD
    Endcase
  Endif
  fstat  = WWFSTAT
Endif
If WPER <> 0
   WDAT = WNEXCUNDAT    # hcb 62371
  J = 0
  While J < 365
    K = month(WDAT)
    Case [F:ITF]ABCCLS
      When 1 :
        LTOT(0,0) += 1
        LTOT(0,K) += 1
        LTOT(4,0) += 1
        LTOT(4,K) += 1
      When 2 :
        LTOT(1,0) += 1
        LTOT(1,K) += 1
        LTOT(4,0) += 1
        LTOT(4,K) += 1
      When 3 :
        LTOT(2,0) += 1
        LTOT(2,K) += 1
        LTOT(4,0) += 1
        LTOT(4,K) += 1
      When 4 :
        LTOT(3,0) += 1
        LTOT(3,K) += 1
        LTOT(4,0) += 1
        LTOT(4,K) += 1
    Endcase
    WDAT += WPER
    J    += WPER
  Wend
Endif
Return
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SCI1]FLG = 0
End
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If GCONSULT <> 0
  mkstat = 2
Endif
End

# FQ 57754 Module Tronc commun GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(9)<>2 End Endif

Call VALGTC(APPLI,"SCI") From SUBGTC

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSCI1) 11/02/2010 15:18:51 hcb 62371
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
#If VALEUR <>[F:FCY]FCY
#  Read [FCY]FCY0=[M]FCY
#Endif
#                                                     # hcb x3-47481 deb
#lecture valeurs par défaut du site
Read [STE]STE0=VALEUR;""
If fstat
  GMESSAGE= mess(174,199,1)
  mkstat=2
  End
Endif
#                                                     # hcb x3-47481 end
#                                                # hcb x3-99277 deb
#If GWRHACT = 2 & [F:FCY]WRHGES = 2
#   [M:SCI1]WWRHGES  = mess(951,196,1)
#Else
#   Raz [M:SCI1]WWRHGES
#Endif
If dim([M:SCI1]WWRHGES) >0  & [F:FCY]WRHGES = 2
   [M:SCI1]WWRHGES  = mess(951,196,1)
Endif
#                                                # hcb x3-99277 fin


End

