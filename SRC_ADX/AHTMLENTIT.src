# -------------------------------------------------------------------------------

Subprog CHCARSPE(PROCDEB,PROCFIN,LANPROC,SIMUL)
Value Char PROCDEB
Value Char PROCFIN
Value Char LANPROC
Value Integer SIMUL

#  Recherche les remplacements à effectuer dans la table des textes processus
#  par rapport aux éléments codés dans la table des htmlentities

#  Si SIMUL<>0 les maj ne sont pas effectuées dans la base

If clalev([F:AXP])=0  : Local File APROCTEXTE [AXP]  : Endif
If clalev([F:AXP1])=0  : Local File APROCTEXTE [AXP1]  : Endif
Local Integer NBREC,NBREP,NBPROC,OP,NBREP1

Local Char PROCCOU,LEGCOU,FILTRE(250)
If PROCDEB<>"" : FILTRE='CODPRO>="'+PROCDEB+'"' : OP=1 : Endif
If PROCFIN<>"" 
  If OP=1 : FILTRE+=" and " : Endif 
  FILTRE+='CODPRO<="'+PROCFIN+'"' 
  OP=1 
Endif
If LANPROC<>"" 
  If OP=1 : FILTRE+=" and " : Endif 
  FILTRE+='LANG="'+LANPROC+'"' 
  OP=1 
Endif
If FILTRE="" : FILTRE="1=1" : Endif
Filter [AXP] Where evalue(FILTRE)

For [AXP]
 NBREC+=1
 If [F:AXP]CODPRO<>PROCCOU or [F:AXP]CODLEG<>LEGCOU 
   NBPROC+=1 
   PROCCOU=[F:AXP]CODPRO
   LEGCOU=[F:AXP]CODLEG 
 Endif
 NBREP1=0
 Call HTMLENTIT([F:AXP]CLBTEXT,NBREP1) From AHTMLENTIT
 NBREP+=NBREP1
 If SIMUL=0 and NBREP1>0
   Read [AXP1]AXP0=[F:AXP]CODPRO;[F:AXP]CODLEG;[F:AXP]LANG;[F:AXP]UNIQIDP
   If fstat=0
     [F:AXP1]=[F:AXP]
     Trbegin [AXP1]
     Rewrite [AXP1]
     Commit  
   Endif
 Endif
Next

Infbox("Number of processes :"-num$(NBPROC)-"  Number of records :"-num$(NBREC)-"  Number of replacement(s) :"-num$(NBREP))
End




