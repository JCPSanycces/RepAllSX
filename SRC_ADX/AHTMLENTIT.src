#<AdxTL>@(#)0.0.0.0 $Revision$
Local Clbfile CLBT(5)
Local Integer NBR
CLBT="Pour mettre &agrave; jour les informations li&eacute;es &agrave; l'approvisionnement d'un article,"
CLBT+=" Il faut acc&eacute;der &agrave; l'onglet Appro&deg; et Fournisseurs de la fiche article. Certaines informations"
CLBT+=" Compl&eacute;mentaires sont &agrave; d&eacute;finir sur la fiche article-site."
Call HTMLENTIT(CLBT,NBR)
Infbox("Nombre de remplacements :"-num$(NBR))
Infbox(CLBT)
End


#  Remplacement des html entities par leur valeur (utilisé pour l'import de processus) 

Subprog HTMLENTIT(CLBT,NBREP)
Variable Clbfile CLBT
Variable Integer NBREP

Local Integer DEB,RG,I
Gosub LISTENTIT
For I=1 To NBENT
  Gosub MODENT
Next I
End

$MODENT
  DEB=1
  Repeat
   RG=instr(DEB,CLBT,LISTENT(I))
   If RG<>0 and mid$(CLBT,RG-1,2)<>'\"'
     CLBT=left$(CLBT,RG-1)+REMPENT(I)+right$(CLBT,RG+len(LISTENT(I)))
     NBREP+=1
   Endif
   DEB=RG+len(REMPENT(I))-1
  Until RG=0
Return




$LISTENTIT
