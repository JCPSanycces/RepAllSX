#<AdxTL>@(#)0.0.0.0 $Revision$
# Class GSTGRP


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
    When ""
        Case [L]AEVENT
            When "AINSERT_CONTROL_BEFORE" : Gosub EVENT_CHECK_HEAD_ENTITY
            When "AUPDATE_CONTROL_BEFORE" : Gosub EVENT_CHECK_HEAD_ENTITY
    Endcase
    When "LINES"
        Case [L]AEVENT
            When "ADDLINE_AFTER"          : Gosub LINES_ADDLINE_AFTER
        Endcase
    Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
    Case [L]CURPRO
       When "ENAFLG"
           Case [L]ARULE
              When "INIT"    : this.ENAFLG = 2 # Active = YES
           Endcase
       When "GSTPER"
           Case [L]ARULE
              When "INIT"    : this.GSTPER = 1 # "Monthly"
           Endcase
# 2018-02-28 X3-76780
       When "PAYDAY"
           Case [L]ARULE
              When "CONTROL" : If ( this.PAYDAY < 0 ) or ( this.PAYDAY > 31 )
                                   # 'Day (1..31)'
                                   ASTATUS = fmet this.ASETERROR( "PAYDAY", mess(84,124,1), [V]CST_AERROR )
                               Endif
           Endcase
    Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


########################################################################################################################

$LINES_ADDLINE_AFTER
  this.CODGSTGRP = this.APARENT.CODGSTGRP
  this.LIN = 1 + max(this.APARENT.LINES(1..maxtab(this.APARENT.LINES)).LIN)
Return

########################################################################################################################

$EVENT_CHECK_HEAD_ENTITY
    Local Integer I, H
    # loop throug all lines
    For [L]I = 1 To maxtab(this.LINES)
        If this.LINES([L]I) <> null
&           and find(this.LINES([L]I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0
&       Then
            # check uniqueness of member company if group is active
            If this.ENAFLG = 2
                If func CHECK_IF_CPY_EXISTS_IN_GROUP(this,this.CODGSTGRP,this.LINES([L]I).CPY,ASTATUS)
                    Break
                Endif
            Endif
            If this.LINES([L]I).GSTHEA = [V]CST_AYES
                [L]H += 1
            Endif
        Endif
    Next
    If ASTATUS = 0
        If [L]H < 1 Then
            # One member company of a GST group must be marked as the head entity.
            ASTATUS = fmet this.ASETERROR("", mess(21,7704,1), [V]CST_AERROR)
        Endif
        If [L]H > 1 Then
            # Only one member of a GST group can be a head entity.
            ASTATUS = fmet this.ASETERROR("", mess(22,7704,1), [V]CST_AERROR)
        Endif
    Endif
Return

########################################################################################################################

Funprog CHECK_IF_CPY_EXISTS_IN_GROUP(MYINST,PGSTGRP,PCPY,PSTATUS)
Value Instance MYINST Using OBJECT
Value Char PGSTGRP
Value Char PCPY
Variable Integer PSTATUS
Local Integer EXISTS : EXISTS = 0
Local File GSTGRPD [GSTGD2]
Local File GSTGRP  [GSTG2]

Filter [F:GSTGD2] Where CPY = PCPY
For [F:GSTGD2]
    If [F:GSTGD2]CODGSTGRP <> PGSTGRP                 # don't check actual group
        Read [F:GSTG2]GSTGH0 = [F:GSTGD2]CODGSTGRP    # read header of group
        if !fstat and [F:GSTG2]ENAFLG = 2             # don't check inactive groups
            EXISTS = 1
            PSTATUS = fmet MYINST.ASETERROR("", func AFNC.MES2(mess(44,7704,1),PCPY,[F:GSTGD2]CODGSTGRP), [V]CST_AERROR)
            Break
        Endif
    Endif
Next
LogicClose File [GSTGD2]
LogicClose File [GSTG2]
End EXISTS

