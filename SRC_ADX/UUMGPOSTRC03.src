#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################
# UUMGPOSTRC03                                         Module Common Data  #
#                                                                          #
#              Post-migration of Open item                                 #
#                                                                          #
# Management of news fields : TYPDUD                                       #
#                                                                          #
############################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSTRC03") From LECFIC
  Endif

  #Call RAZ_UUMGPOSTRC03(DOSSIER)
  Call MAJ_UUMGPOSTRC03(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

########################################################################
Subprog RAZ_UUMGPOSTRC03(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(8)<>2 : End : Endif

Call MIGRAZKEY (DOSSIER,"UUMGPOSTRC03",ERR) From TRTMIG

End


###################################################################################
Subprog MAJ_UUMGPOSTRC03(DOSSIER)
Value Char DOSSIER
Local Integer NBLUS, NBCOMMIT, ERR, OK

If [F:ADS]MODULE(8)<>2 or func DOSSUB.ISHISTFOLD(DOSSIER)
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC03",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC03",2,ERR) From TRTMIG

#-----  n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC03",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER60
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC03",3,ERR) From TRTMIG : End
Endif


Call ECR_TIME("UUMGPOSTRC03 Open items Process : Update GACCDUDATE - Fields : TYPDUD") From DOSSUB
Call ECR_TRACE("UUMGPOSTRC03 : Process Start on : "+DOSSIER,0) From GESECRAN

#--------------- Opening of files  -----#
If clalev([F:DUD]) : Close File [DUD] : Endif
If clalev([F:DUD])  = 0 :  Local File =DOSSIER+".GACCDUDATE"  [DUD]   : Endif      # Open item
If clalev([F:SIH])  = 0 :  Local File =DOSSIER+".SINVOICE"    [SIH]   : Endif      # Customer BP Invoices
If clalev([F:PIH])  = 0 :  Local File =DOSSIER+".PINVOICE"    [PIH]   : Endif      # Supliers BP Invoices
If [F:ADS]MODULE(2)=2
 If clalev([F:PYH])  = 0 :  Local File =DOSSIER+".PAYMENTH"    [PYH]   : Endif      # Paymenth Header
 If clalev([F:HAE])  = 0 :  Local File =DOSSIER+".GACCENTRY"   [HAE]   : Endif      # Acccounting Journal Entry
 If clalev([F:DAE])  = 0 :  Local File =DOSSIER+".GACCENTRYD"  [DAE]   : Endif      # General Acccounting Line
Endif

#-----  Declaration of Variables
# Variables to Handle Loops Ruptures
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1

Raz NBLUS, NBCOMMIT, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_TRC03
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:DUD]TYPDUD=0 & [F:DUD]NUMDUD>'"+ACLE1+"'"
Else
 CRITERE = "[F:DUD]TYPDUD=0 & 1=1"
Endif

Trbegin [DUD]
GOK = 1

For [DUD]DUD8 Where evalue(CRITERE)

   NBLUS+=1

   #--- New field assignation

   # Others
   [F:DUD]TYPDUD=4

   # Order
   If [F:DUD]TYP="*SO" | [F:DUD]TYP="*PO"
    [F:DUD]TYPDUD=1  : Goto WRI_DUD
   Endif

   # Invoice
   Case [F:DUD]BPRTYP
    When 1
      If [F:DUD]NUM<>[F:SIH]NUM
       Read [SIH]SIH0 = [F:DUD]NUM
       If !fstat : [F:DUD]TYPDUD=2 : Goto WRI_DUD : Endif
      Else
       [F:DUD]TYPDUD=2 : Goto WRI_DUD
      Endif
    When 2
      If [F:DUD]NUM<>[F:PIH]NUM
       Read [PIH]PIH0 = [F:DUD]NUM
       If !fstat : [F:DUD]TYPDUD=2 : Goto WRI_DUD : Endif
      Else
       [F:DUD]TYPDUD=2 : Goto WRI_DUD
      Endif
   Endcase

   # Paymenth
   If [F:ADS]MODULE(2)=2
    OK = 0
    If [F:DAE]ACCNUM<>[F:DUD]ACCNUM
     Read [DAE]DAE2=[F:DUD]ACCNUM
    Else
     OK=1
    Endif
    If OK | !fstat
     OK = 0
     If [F:HAE]TYP<>[F:DAE]TYP | [F:HAE]NUM<>[F:DAE]NUM
      Read [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM
     Else
      OK=1
     Endif
     If OK | !fstat
      If left$([F:HAE]REFINT,3)="PYH" : [F:DUD]TYPDUD=3 :  Goto WRI_DUD : Endif
     Endif
    Endif
   Endif

   $WRI_DUD
   Rewrite [F:DUD]
   If fstat
    Call ECR_TRACE("File GACCDUDATE(NUMDUD)"-[F:DUD]NUMDUD+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
   Endif

   NBCOMMIT += 1
   NB+=1
   If NB>GMAXUPDTRS
    ACLE1 = [F:DUD]NUMDUD
    STOP=1
    Break
   Endif
Next

If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC03",7,ERR) From TRTMIG
Else
  Commit
  Call MIGSTKPROGRESS (DOSSIER,"UUMGPOSTRC03",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_TRC03
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
Close Local File [DUD]


$FIN
Call MIGTRTEND (DOSSIER,"UUMGPOSTRC03") From TRTMIG
Call ECR_TIME("UUMGPOSTRC03 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

