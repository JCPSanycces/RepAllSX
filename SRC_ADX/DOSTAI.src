#<AdxTL>@(#)132.0.0.0 $Revision$
Global Char GCODACTX3(GLONACV)(1..2)
GCODACTX3(1) = "TRU"
GCODACTX3(2) = "FAL"
Call CALTAILLE("SUPERV")
End


Subprog CALTAILLE(DOSSIER)
Value Char DOSSIER
Local Integer NBZONE , NBZTAB , LNGENR , REPET , LNGZON , NBENREG
Local Decimal TAILLE , TAILIDX , TAIL , TOTCLE
Local Integer LNGCLE , NBCLE , BLOC
Local Integer J , K , V , NOL   , NBFIC , INTERR , ERR
Local Integer VV(1..50)
Local Integer NEWREC , OLD , SPEC
Local Integer DIFF , RW , OLDENREG
Local Char    FORMULE(80) , VARIA(GLONAVA) , NEWVAR(GLONAVA) , TABLE(GLONATB)
Local Char    CHAINE(80) , ZONE(GLONAVA+5)
Local Integer CDBA , KDBA

If !clalev([ATB]) : Local File ATABLE [ATB] : Endif
Local File ATABZON [ATZ] , ATABIND [ATI] , ATYPE [ATY] , ACTIV [ACV]
Local File ADOSSIER [ADS] , AFORDIM [AFO] , ADOSDIM [ADE] , ADOSACT [ADA]

If filinfo(filpath("FIL","AINDEX","fde",DOSSIER),0)>=0
 Local File =DOSSIER+".AINDEX" [ANX]
Else
 Local File AINDEX [ANX]
Endif

# Type de données Ascii ou UTF8
Read [ADS]DOSSIER = DOSSIER
If !fstat
 CDBA = [F:ADS]CODDBA
 If CDBA<=0 : CDBA = 1 : Endif
Else
 CDBA = 1
Endif

# Coefficient multiplicateur
If GADONIX=2
 KDBA = 2
Else
 Case [F:ADS]TYPDBA
  When 1 : # Oracle
   KDBA = val(getenv$("STUSIZE"))
   If KDBA<=0 : KDBA = 2 : Endif
  When 2 : # Sql
   Case CDBA
    When 1 : # Ascii
     KDBA = 1
    When 2 : # Unicode
     KDBA = 2
    When Default
     KDBA = 1
   Endcase
 Endcase
Endif

Raz [M:DIA]
NOL = 0
NBFIC = nbrecord([ATB])
Call OUVRE_BOITE(mess(51,125,1),NBFIC) From GESECRAN : # Simulation taille
NBFIC = 0
For [ATB]CODFIC
 NBFIC += 1
 Call AFF_BOITE([F:ATB]CODFIC,NBFIC,INTERR) From GESECRAN
 OK = ([F:ATB]CODFIC<"X" & [F:ATB]TYPFIC<5 & [F:ATB]TYPFIC<>3)
 If OK
  TABLE = [F:ATB]CODFIC
  Call NEWREC([F:ADS]DOSSIER,[F:ATB]CODACT,[F:ATB]MODULE,NEWREC) From DOSSUB
  If NEWREC
     If dim([M:DIA]TABLE) <= NOL
        Call MESSAGE (mess(26,100,1))  From GESECRAN
        Break
     Else
       [M:DIA]TABLE(NOL) = TABLE
       Gosub LONGUEUR
       Gosub TAILLE
       TAILLE = LNGENR*NBENREG/(1024*1024)
       [M:DIA]NBENREG(NOL) = NBENREG
       If dim([M:DIA]LONGUEUR)>0
            [M:DIA]LONGUEUR(NOL) = LNGENR
       Endif
       [M:DIA]TAILLE(NOL)  = TAILLE
       Gosub INDEX
       [M:DIA]INDEX(NOL) = TAILIDX
       [M:DIA]TOTTAB += TAILLE
       [M:DIA]TOTIDX += TAILIDX
       [M:DIA]TOTAL  += TAILLE+TAILIDX
       NOL += 1
     Endif
  Endif
 Endif
Next
[M:DIA]NBLIG = NOL
Call FERME_BOITE From GESECRAN
End

$LONGUEUR
NBZONE = 0
NBZTAB = 0
NBBLOB = 0
LNGENR = 0
For [ATZ]CODZONE Where CODFIC=TABLE & find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")=0
# Pour les tables la dimension est définie par X3
 REPET = [F:ATZ]DIME
 Call REPTAB([F:ATZ]CODACT,REPET) From DOSSUB
 If REPET<>0
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If fstat
   LNGZON = 1
   REPET = 1
  Else
   REPET = abs(REPET)
   Case [F:ATY]TYPTYP
    When 1 : LNGZON = 1         : # Libellé
    When 2 : LNGZON = 2         : # Entier court
    When 3 : LNGZON = 4         : # Entier long
    When 4 : LNGZON = 8         : # BCD
    When 5 : LNGZON = 4         : # Float
    When 6 : LNGZON = 8         : # Double
    When 7,12                   : # Alphanumérique
     If [F:ATY]LNGTYP<>0
      LNGZON = [F:ATY]LNGTYP+1
     Else
      LNGZON = [F:ATZ]LONG+1
     Endif
     LNGZON *= KDBA             : # Coeff x (Ascii/Utf8)
    When 8  : LNGZON = 3        : # Date
    When 9,10                   : # Blob/Clob
     LNGZON = 0
     If [F:ATY]LNGTYP<>0
      LNGBLOB = [F:ATY]LNGTYP
     Else
      LNGBLOB = [F:ATZ]LONG
     Endif
     LNGBLOB = 2^LNGBLOB
     NBBLOB += REPET*LNGBLOB
    When 11
     LNGZON = 16*KDBA
   Endcase
  Endif
  LNGENR += REPET * LNGZON
  NBZTAB += REPET
  NBZONE += 1
 Endif
Next ATZ
Return


$TAILLE
V = 1
NBENREG = 0
Read [AFO]AFO0 = TABLE
If !fstat
 FORMULE = vireblc(format$("KT:80X",[F:AFO]FORDIM),2)
 If FORMULE<>""
  K = 1
  While K<len(FORMULE)
   If mid$(FORMULE,K,1)>="A" & mid$(FORMULE,K,1)<="Z"
    J = K
    VARIA = ""
    Repeat
     VARIA += mid$(FORMULE,K,1)
     K += 1
    Until K>len(FORMULE) | mid$(FORMULE,K,1)<"A" | mid$(FORMULE,K,1)>"Z"
    NEWVAR = "VV("+num$(V)+")"
    FORMULE = left$(FORMULE,J-1)+NEWVAR+right$(FORMULE,K)
    K += len(NEWVAR)-len(VARIA)
    Read [ADE]ADE0 = [F:ADS]DOSSIER;VARIA
    If !fstat
     VV(V) = [F:ADE]NBR
    Else
     VV(V) = 0
    Endif
    V += 1
   Else
    K += 1
   Endif
  Wend
  ERR = 0
  Onerrgo RIEN
  NBENREG = evalue(FORMULE)
  If ERR : NBENREG = 0 : Endif
  Onerrgo
 Endif
Endif
If NBENREG=0
 If [F:ATB]NBENREG<>0
  NBENREG = [F:ATB]NBENREG
 Else
  NBENREG = 1000 : # mb 21.3.3 bug 13546
 Endif
Endif
Return

$RIEN
ERR = errn
Resume


$INDEX
TAILIDX = 0
For [ATI]CODIND Where CODFIC=TABLE
 CHAINE = [F:ATI]DESCRIPT
 Gosub CALC_INDEX
Next
For [ANX]ANX1 Where TABLE=[L]TABLE & FLACT=2
 CHAINE = [F:ANX]DESCRIPT
 Gosub CALC_INDEX
Next
Return

$CALC_INDEX
LNGCLE = 0
While CHAINE<>""
 J = instr(1,CHAINE,"+")
 K = instr(1,CHAINE,"-")
 If J & K     : J= min(J,K)
 Elsif K & !J : J = K
 Endif
 If J
  ZONE = left$(CHAINE,J-1) : CHAINE = right$(CHAINE,J+1)
 Else
  ZONE = CHAINE : CHAINE = ""
 Endif
 I = instr(1,ZONE,"(")
 If I
  ZONE = left$(ZONE,I-1)
 Endif
 Read [ATZ]CODZONE = TABLE;ZONE
 Read [ATY]CODTYP  = [F:ATZ]CODTYP
 Case [F:ATY]TYPTYP
  When 1 : LNGZON = 1         : # Libellé
  When 2 : LNGZON = 2         : # Entier court
  When 3 : LNGZON = 4         : # Entier long
  When 4 : LNGZON = 8         : # BCD
  When 5 : LNGZON = 4         : # Float
  When 6 : LNGZON = 8         : # Double
  When 7,12                   : # Alphanumérique
   If [F:ATY]LNGTYP<>0
    LNGZON = [F:ATY]LNGTYP+1
   Else
    LNGZON = [F:ATZ]LONG+1
   Endif
   LNGZON *= KDBA             : # Coeff x (Ascii/Utf8)
  When 8  : LNGZON = 3        : # Date
  When 9  : LNGZON = 0        : # Blob
  When 10 : LNGZON = 0        : # Clob
  When 11 : LNGZON = 16*KDBA  : # Uuid
 Endcase
 LNGCLE += LNGZON
Wend
NBCLE  = max(1024/LNGCLE,3) : # Pb avec table stat
TOTCLE = NBENREG
BLOC   = TOTCLE
TAIL   = 0
While BLOC>1
 BLOC   = min(int(TOTCLE/NBCLE/0.75)+1,TOTCLE-1)
 TAIL  += BLOC/1024
 TOTCLE = BLOC
Wend
TAILIDX += TAIL
Return

