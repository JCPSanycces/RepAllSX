Funprog CODATT(COD)
Value Char COD
Local Integer I
Local Char ATT(15)
Gosub LOAATT_REF
Gosub LOAATT_JSON
Gosub LOAATT_INTERNAL
I = find(COD,CA(1..AA))
If I
 ATT = NA(I)
Endif
End ATT

#---------------------------------------------------#
# List of attributes used in reference properties
#---------------------------------------------------#

Funprog ATTOKREF(COD)
Value Char COD
Gosub LOAATT_REF
OK = find(COD,NA(1..AA))
End OK

Funprog AGETLISTATTOKREF(NA)
Variable Char    NA()(1..)

Local Integer AA , MA
Local Char    CA(1)(1..)
AA = 0
Gosub LOAATT_REF
MA = AA
End MA

$LOAATT_REF
Gosub DIMTAB
AA += 1 : CA(AA) = "T" : NA(AA) = "$title"       : # Intitulé court (lien court)
AA += 1 : CA(AA) = "D" : NA(AA) = "$description" : # Intitulé long (lien long)
AA += 1 : CA(AA) = "u" : NA(AA) = "$symbol"      : # Symbole pour unité
AA += 1 : CA(AA) = "Q" : NA(AA) = "$scale"       : # scale pour décimal
AA += 1 : CA(AA) = "P" : NA(AA) = "$precision"   : # precision pour décimal
Return



#---------------------------------------------------#
# List of attributes used in internal (not in json)
#---------------------------------------------------#

$LOAATT_INTERNAL
Gosub DIMTAB
AA += 1 : CA(AA) = "l" : NA(AA) = "$isLoaded"      : # Rich media chargé
AA += 1 : CA(AA) = "c" : NA(AA) = "$contentType"   : # Rich media contentType
AA += 1 : CA(AA) = "F" : NA(AA) = "$filename"      : # Rich media filename
AA += 1 : CA(AA) = "B" : NA(AA) = "$isLobFound"    : # Rich media exists
AA += 1 : CA(AA) = "A" : NA(AA) = "$acceptedTypes" : # Rich media : accepted contentTypes
AA += 1 : CA(AA) = "p" : NA(AA) = "$namProParent"   : # Management collections in CRUD
AA += 1 : CA(AA) = "j" : NA(AA) = "$_rightAccess"        : # No data in the json data
Return

