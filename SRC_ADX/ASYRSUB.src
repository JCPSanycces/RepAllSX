Funprog ASETCHREX(OBJ,CHR,CLOB)
Variable Instance OBJ Using OBJECT
Variable Instance CHR Using C_ACHR
Variable Clbfile CLOB
Local Integer STAT
If CHR<>null
 If CHR.ACHR8<>null   : FreeInstance CHR.ACHR8   : CHR.ACHR8   = null  : Endif
 If CHR.ACHR32<>null  : FreeInstance CHR.ACHR32  : CHR.ACHR32  = null  : Endif
 If CHR.ACHR128<>null : FreeInstance CHR.ACHR128 : CHR.ACHR128 = null  : Endif
 If CHR.ACHR250<>null : FreeInstance CHR.ACHR250 : CHR.ACHR250 = null  : Endif
 If CHR.ACHRCLB<>null : FreeInstance CHR.ACHRCLB : CHR.ACHRCLB = null  : Endif
Else
 CHR = NewInstance =OBJ.AllocGrp, C_ACHR
Endif
STAT = 1
If len(CLOB)<=8
 CHR.ACHR8 = NewInstance =CHR.AllocGrp, C_ACHR8
 CHR.ACHR8.CHR = CLOB
Elsif len(CLOB)<=32
 CHR.ACHR32 = NewInstance =CHR.AllocGrp, C_ACHR32
 CHR.ACHR32.CHR = CLOB
Elsif len(CLOB)<=128
 CHR.ACHR128 = NewInstance =CHR.AllocGrp, C_ACHR128
 CHR.ACHR128.CHR = CLOB
Elsif len(CLOB)<=250
 CHR.ACHR250 = NewInstance =CHR.AllocGrp, C_ACHR250
 CHR.ACHR250.CHR = CLOB
Else
 CHR.ACHRCLB = NewInstance =CHR.AllocGrp, C_ACHRCLB
 CHR.ACHRCLB.CHR = CLOB
Endif
End STAT

#----------------------------------------------------#
# Ajout d'une erreur dans l'instance courante
#----------------------------------------------------#

Subprog ASETERRORCAT(ERR , _AINSTANCE, _PROPERTY,_MESSAGE,_HTTP_STATUS,_CATEGORY,_ERROR)
Variable Instance ERR(1..) Using C_AERROR
Variable Instance    _AINSTANCE Using OBJECT
Value    Char     _PROPERTY
Value    Char     _MESSAGE
Value    Integer  _HTTP_STATUS
Value    Integer  _CATEGORY
Variable Integer  _ERROR

Local Integer ERROR
ERROR=func __ASETSTATUS(_AINSTANCE,ERR,_PROPERTY,0,_ERROR,_HTTP_STATUS,_MESSAGE,_CATEGORY)
End

#----------------------------------------------------#
# Ajout d'une erreur dans l'instance courante
#----------------------------------------------------#

Subprog ASETERROR(ERR , _AINSTANCE, _PROPERTY,_MESSAGE,_HTTP_STATUS,_ERROR)
Variable Instance ERR(1..) Using C_AERROR
Variable Instance    _AINSTANCE Using OBJECT
Value    Char     _PROPERTY
Value    Char     _MESSAGE
Value    Integer  _HTTP_STATUS
Variable Integer  _ERROR

Local Integer ERROR,CATEGORY
CATEGORY =0
ERROR=func __ASETSTATUS(_AINSTANCE,ERR,_PROPERTY,0,_ERROR,_HTTP_STATUS,_MESSAGE,CATEGORY)
End

#**
#* ASETSTATUS :
#*
#* @param _INSTANCE
#* @param _STATUS
#* @param _MESSAGE
#*!
Funprog _ASETSTATUS(_INSTANCE,_PROPERTY,_TYPE,_ERROR,_HTTP_STATUS,_MESSAGE)
Variable Instance _INSTANCE Using OBJECT
Value Char _PROPERTY
Value Integer _TYPE
Value Integer _ERROR
Value Integer _HTTP_STATUS
Value Char _MESSAGE

Local Integer ERROR,CATEGORY
CATEGORY =0
Local Integer _RO : _RO=  _INSTANCE.isReadonly
_INSTANCE.isReadonly = 0
ERROR=func __ASETSTATUS(_INSTANCE,_INSTANCE.AERROR,_PROPERTY,_TYPE,_ERROR,_HTTP_STATUS,_MESSAGE,CATEGORY)
_INSTANCE.isReadonly = _RO
End ERROR

Funprog __ASETSTATUS(_INSTANCE,ERR,_PROPERTY,_TYPE,_ERROR,_HTTP_STATUS,_MESSAGE,_CATEGORY)
Variable Instance _INSTANCE Using OBJECT
Variable Instance ERR(1..) Using C_AERROR
Value Char _PROPERTY
Value Integer _TYPE
Value Integer _ERROR
Value Integer _HTTP_STATUS
Value Char _MESSAGE
Value Integer _CATEGORY
Local Char ERRMES(250)
Local  Char OUTPUT_LOGNAME(100)

Local Integer ERROR : ERROR=[V]CST_AOK

 [L]ERROR = _ERROR
 If [L]_HTTP_STATUS >= [V]CST_AHTTP_BAD_REQUEST
 [L]ERROR = [V]CST_AERROR
Endif

 If !_HTTP_STATUS : _HTTP_STATUS = [V]CST_AHTTP_OK : Endif : #by default the http status is set to 200
 ERR(maxtab(ERR)+1) = NewInstance C_AERROR AllocGroup _INSTANCE
 ERR(maxtab(ERR)).MES = _MESSAGE
 ERR(maxtab(ERR)).NUM = _HTTP_STATUS
 ERR(maxtab(ERR)).STA = [L]ERROR
 ERR(maxtab(ERR)).PRO = _PROPERTY
 ERR(maxtab(ERR)).CATEGORY = _CATEGORY
 ERR(maxtab(ERR)).CREDATTIM  = timestamp$
 If dim(GNBERROSYR)>0
  [V]GNBERROSYR += 1
  ERR(maxtab(ERR)).ORDERCHRONO =  [V]GNBERROSYR
 Endif
 If GSERVEUR = 1 #X3-99385: control the number of errors created by a batch task
  If maxtab(ERR) >= 10000 #X3-99385 : stop here!.
   Call ERREUR(_MESSAGE) From GESECRAN
   Call ERREUR("number of errors stored in the context:"-num$(maxtab(ERR))-" => end of session") From GESECRAN
   Call CLOSE_SOCKET_WITH_LOG(num$(adxuid(2)), null, "", [L]_MESSAGE, [V]CST_ANO, [L]OUTPUT_LOGNAME) From ASESSIONS

  Elsif maxtab(ERR) > 5000 #X3-99385 : warns that something is wrong ...
   Call ERREUR(_MESSAGE) From GESECRAN
  Endif
 Endif
 End ERROR

#**
#* AGETDIAGNOSESEX
#* AGETDIAGNOSES + take _HTTP_STATUS into account
#*
#* @param _INSTANCE
#*!
Funprog _AGET_HTTP_STATUS(_INSTANCE)
Variable Instance _INSTANCE Using OBJECT

Local Integer ERROR : ERROR = [V]CST_AOK
Local Integer HTTP_STATUS
Local Char SEP(1) : SEP=''
Local Integer I

HTTP_STATUS = [V]CST_AHTTP_OK

For I=1 To maxtab(_INSTANCE.AERROR)
 If _INSTANCE.AERROR(I).STA >= CST_AERROR
  _INSTANCE.AERROR(I).NUM = max(_INSTANCE.AERROR(I).NUM , [V]CST_AHTTP_BAD_REQUEST)
 Endif
 HTTP_STATUS = max(HTTP_STATUS,_INSTANCE.AERROR(I).NUM)
Next I
End  HTTP_STATUS
#**
#* AGETDIAGNOSES
#*
#* @param _INSTANCE
#*!
Funprog _AGETDIAGNOSES(_INSTANCE,_HTTP_STATUS,_DIAGNOSES)
Variable Instance _INSTANCE Using OBJECT
Variable Integer _HTTP_STATUS
Variable Clbfile _DIAGNOSES

Local Integer ERROR : ERROR = [V]CST_AOK
Local Char SEP(1) : SEP=''

_HTTP_STATUS = [V]CST_AHTTP_OK

Raz _DIAGNOSES
If _INSTANCE.AERROR = null
 End ERROR
Endif


Local Integer I
For I=1 To maxtab(_INSTANCE.AERROR)
 If _INSTANCE.AERROR(I) <> null
   ERROR     = max(ERROR,_INSTANCE.AERROR(I).STA)
  _HTTP_STATUS = max(_HTTP_STATUS,_INSTANCE.AERROR(I).NUM)
  If len(_INSTANCE.AERROR(I).MES)
   Append _DIAGNOSES,SEP
   Append _DIAGNOSES, '{'
   Append _DIAGNOSES, '"$severity": "'
   Case max(_INSTANCE.AERROR(I).STA,[V]CST_AOK)
    When [V]CST_AOK : Append _DIAGNOSES,"success"
    When [V]CST_ASUCCESS : Append _DIAGNOSES,"success"
    When [V]CST_AINFO : Append _DIAGNOSES,"info"
    When [V]CST_AWARNING : Append _DIAGNOSES,"warning"
    When [V]CST_AERROR : Append _DIAGNOSES,"error"
    When [V]CST_AFATAL : Append _DIAGNOSES,"fatal"
   Endcase
   Append _DIAGNOSES, '",'
   Append _DIAGNOSES, '"$message": "'
   If len(_INSTANCE.AERROR(I).PRO)
    Append _DIAGNOSES, _INSTANCE.AERROR(I).PRO + ' : '
   Endif
    Append _DIAGNOSES,escJson(_INSTANCE.AERROR(I).MES)

   Append _DIAGNOSES,'"'
   Append _DIAGNOSES, '}'
   SEP=','
  Endif
 Endif
Next I
End [L]ERROR

#**
#* AGETDIAGNOSES
#*
#* @param _INSTANCE
#*!
Funprog _AGETDIAGNOSESHTML(_INSTANCE,_HTTP_STATUS,_DIAGNOSES)
Variable Instance _INSTANCE Using OBJECT
Variable Integer _HTTP_STATUS
Variable Clbfile _DIAGNOSES

Local Integer ERROR : ERROR = [V]CST_AOK
Local Char    CHR(1)
Local Integer I,J,K

_HTTP_STATUS = [V]CST_AHTTP_OK

Raz _DIAGNOSES
If _INSTANCE.AERROR = null
 End ERROR
Endif

Local Char SPECIALS(250),ESCHTML(10)(1..)
Raz I
SPECIALS = '<>"&àéèêëôöù'
I+=1 : ESCHTML(I) = "&lt;"
I+=1 : ESCHTML(I) = "&gt;"
I+=1 : ESCHTML(I) = "&quot;"
I+=1 : ESCHTML(I) = "&amp;"
I+=1 : ESCHTML(I) = "&agrav;"
I+=1 : ESCHTML(I) = "&eacute;"
I+=1 : ESCHTML(I) = "&egrave;"
I+=1 : ESCHTML(I) = "&euml;"
I+=1 : ESCHTML(I) = "&ecirc;"
I+=1 : ESCHTML(I) = "&ocirc;"
I+=1 : ESCHTML(I) = "&ouml;"
I+=1 : ESCHTML(I) = "&ugrave;"

For I=1 To maxtab(_INSTANCE.AERROR)
 If _INSTANCE.AERROR(I) <> null
   ERROR     = max(ERROR,_INSTANCE.AERROR(I).STA)
  _HTTP_STATUS = max(_HTTP_STATUS,_INSTANCE.AERROR(I).NUM)
  If len(_INSTANCE.AERROR(I).MES)
   Append _DIAGNOSES, '<p>'
   #DEBUG _INSTANCE.AERROR(I).MES = SPECIALS
   For J=1 To len(_INSTANCE.AERROR(I).MES)
    CHR = xgetchar( _INSTANCE.AERROR(I).MES, J )
    K = instr(1,SPECIALS,CHR)
    If K
     #DEBUG Append _DIAGNOSES, " " + CHR + "="
     Append _DIAGNOSES, ESCHTML(K)
    Else
     Append _DIAGNOSES, CHR
    Endif
   Next I
   Append _DIAGNOSES, '</p>'
  Endif
 Endif
Next I
End [L]ERROR

#**
#* _ADELSTATUS :
#*
#* @param _INSTANCE
#*!
Subprog _ADELSTATUS(_INSTANCE)
Variable Instance _INSTANCE Using OBJECT

Local Integer I
Local Integer _RO : _RO=  _INSTANCE.isReadonly
_INSTANCE.isReadonly = 0
Local Instance WTMP Using C_AERROR

For I=1 To maxtab(_INSTANCE.AERROR)
 WTMP = _INSTANCE.AERROR(I)
 _INSTANCE.AERROR(I) =  null
 FreeInstance WTMP
Next I
 Raz _INSTANCE.AERROR
_INSTANCE.isReadonly = _RO
End

#------------------------------------------------------#
# Statut le plus grand d'une erreur d'une propriété
#------------------------------------------------------#

Funprog AGETMAXERROR(ERR,PRO)
Variable Instance ERR(1..) Using C_AERROR
Value    Char     PRO
Local Integer AI , AERR
AERR = 0
If [L]PRO=""
 For AI=1 To maxtab(ERR)
  If ERR(AI)<>null & ERR(AI).DEL<>2 & ERR(AI).STA>AERR
   AERR = max(AERR,ERR(AI).STA)
  Endif
 Next AI
Else
 For AI=1 To maxtab(ERR)
  If ERR(AI)<>null & ERR(AI).DEL<>2 & ERR(AI).STA>AERR & ERR(AI).PRO=[L]PRO
   AERR = max(AERR,ERR(AI).STA)
  Endif
 Next AI
Endif
End AERR

#------------------------------------------------------#
# Statut le plus grand d'une erreur d'une instnac et sous-instances
#------------------------------------------------------#

Funprog AGETMAXERRORALL(_AINSTANCE)
Variable Instance _AINSTANCE Using OBJECT

Local Instance _CTX Using C_WMACONTEXT
_CTX= NewInstance C_WMACONTEXT AllocGroup _AINSTANCE

Local Integer ASTATUS

[L]ASTATUS = fmet _AINSTANCE._AERROR(_CTX,0)

End func AGETMAXERROR(_CTX.AERROR,"")

#------------------------------------------------------------------------------#
# Retourne le status et les informations de l'erreur la plus grave
#------------------------------------------------------------------------------#
Funprog AGETMAXERRORTXT(_AINSTANCE,ERR_TYPE,PROPERTY,STATUS_ERR,PROP_LAB,ERR_MES ,CATEGORY,ENVIRONNEMENT )
Variable Instance _AINSTANCE Using OBJECT
Value    Integer ERR_TYPE
Value    Char    PROPERTY
Value    Integer STATUS_ERR
Variable    Char    PROP_LAB
Variable    Char    ERR_MES
Variable    Integer CATEGORY
Variable    Char    ENVIRONNEMENT

Local Integer AI,AERR,AINS,ASTATUS
Local Char PATH(250)

[L]ASTATUS = [V]CST_AOK

If !find([L]ERR_TYPE, [V]CST_ALL,[V]CST_ACURRENT) : [L]ERR_TYPE =[V]CST_ALL  : Endif

[L]ASTATUS = fmet _AINSTANCE.ASEARCHINFOS([L]ERR_TYPE, "", [V]CST_AFATAL, 0)
If [L]ASTATUS=[V]CST_AERROR : End [V]CST_AERROR : Endif


If _AINSTANCE._AINFOS=null : End [L]ASTATUS : Endif

For AI=1 To maxtab(_AINSTANCE._AINFOS.ATABINFO)
 If _AINSTANCE._AINFOS.ATABINFO(AI)<>null and _AINSTANCE._AINFOS.ATABINFO(AI).AERR<>null
& and _AINSTANCE._AINFOS.ATABINFO(AI).AERR.DEL<>2 & _AINSTANCE._AINFOS.ATABINFO(AI).AERR.STA>AERR
& and ([L]ERR_TYPE=[V]CST_ALL or PROPERTY="" or _AINSTANCE._AINFOS.ATABINFO(AI).AERR.PRO=PROPERTY)
  If _AINSTANCE._AINFOS.ATABINFO(AI).AERR.STA>AERR
   [L]AERR = _AINSTANCE._AINFOS.ATABINFO(AI).AERR.STA
   [L]AINS = AI
  Endif
 Endif
Next I

If [L]AINS>0
 [L]PROPERTY       = _AINSTANCE._AINFOS.ATABINFO([L]AINS).AERR.PRO
 [L]PROP_LAB       = _AINSTANCE._AINFOS.ATABINFO([L]AINS).AERR.PRO
 If [L]ERR_TYPE=[V]CST_ALL : Raz [L]PROPERTY,[L]PROP_LAB  : Endif
 [L]STATUS_ERR     = _AINSTANCE._AINFOS.ATABINFO([L]AINS).AERR.STA
 [L]ERR_MES        = _AINSTANCE._AINFOS.ATABINFO([L]AINS).AERR.MES
 [L]CATEGORY       = _AINSTANCE._AINFOS.ATABINFO([L]AINS).AERR.CATEGORY
 If _AINSTANCE._AINFOS.ATABINFO([L]AINS).AERR.AINFOS <>null
  [L]ENVIRONNEMENT  = _AINSTANCE._AINFOS.ATABINFO([L]AINS).AERR.AINFOS.ENV
 Endif
Endif

Call _ADELETE_AINFOS(_AINSTANCE)

End [L]ASTATUS

#------------------------------------------------------------------------------#
# This method copies the error structures from the instance given
#------------------------------------------------------------------------------#
Funprog AGETERRORSFROM(AINS_FROM,AINS_TO,ENVIRONNEMENT)
Variable Instance AINS_FROM Using OBJECT
Variable Instance AINS_TO Using OBJECT
Value    Char     ENVIRONNEMENT


Local Integer AI,ASTATUS,AJ,AENV
Local Instance WTMP Using C_AERROR

If AINS_FROM._AINFOS=null : End [L]ASTATUS : Endif

For AI=1 To maxtab(AINS_FROM._AINFOS.ATABINFO)
 If AINS_FROM._AINFOS.ATABINFO(AI)<>null  and AINS_FROM._AINFOS.ATABINFO(AI).AERR<>null
  WTMP = AINS_FROM._AINFOS.ATABINFO(AI).AERR
  #AINS_FROM.AERROR(AI) = null
  AJ = maxtab(AINS_TO.AERROR)+1
  AINS_TO.AERROR(AJ) = NewInstance C_AERROR AllocGroup  AINS_TO
  AINS_TO.AERROR(AJ).STA = WTMP.STA
  AINS_TO.AERROR(AJ).MES = WTMP.MES
  AINS_TO.AERROR(AJ).NUM = WTMP.NUM
  AINS_TO.AERROR(AJ).PRO = WTMP.PRO
  AINS_TO.AERROR(AJ).DEL = WTMP.DEL
  AINS_TO.AERROR(AJ).CATEGORY = WTMP.CATEGORY
  AINS_TO.AERROR(AJ).ORDERCHRONO = WTMP.ORDERCHRONO
  AINS_TO.AERROR(AJ).AUUID = WTMP.AUUID
  AINS_TO.AERROR(AJ).CREDATTIM = WTMP.CREDATTIM
  AINS_TO.AERROR(AJ).UPDDATTIM = WTMP.UPDDATTIM
  AINS_TO.AERROR(AJ).AINFOS = NewInstance C_AERRINFOS AllocGroup  AINS_TO
  AINS_TO.AERROR(AJ).AINFOS.DES = AINS_TO.AERROR(AJ).PRO
  AINS_TO.AERROR(AJ).AINFOS.UPDDATTIM = WTMP.CREDATTIM
  AINS_TO.AERROR(AJ).AINFOS.UPDDATTIM = WTMP.UPDDATTIM
  If WTMP.COPY<>1
    AINS_TO.AERROR(AJ).AINFOS.FULLPRO = AINS_FROM._AINFOS.ATABINFO(AI).FULLPRO
    AINS_TO.AERROR(AJ).AINFOS.ENV = ENVIRONNEMENT
  Else
   If WTMP.AINFOS<>null
    AINS_TO.AERROR(AJ).AINFOS.ENV = WTMP.AINFOS.ENV
    AINS_TO.AERROR(AJ).AINFOS.FULLPRO =  WTMP.AINFOS.FULLPRO
   Endif
  Endif
  AINS_TO.AERROR(AJ).COPY = 1
  #FreeInstance WTMP
 Endif
Next AI

End ASTATUS

Funprog AGETNEXTINFOS(AINSTANCE,RSTATUS, RPROP, RPROP_LAB, RERR_MESS, RCATEGORY, RENVIRONMENT)
Variable Instance AINSTANCE Using OBJECT
Variable    Integer RSTATUS
Variable    Char    RPROP
Variable    Char    RPROP_LAB
Variable    Char    RERR_MESS
Variable    Integer RCATEGORY
Variable    Char    RENVIRONMENT


Raz RSTATUS, RPROP, RPROP_LAB, RERR_MESS, RCATEGORY, RENVIRONMENT

Local Integer ASTATUS : [L]ASTATUS=[V]CST_AOK

If AINSTANCE._AINFOS=null : End [V]CST_AERROR : Endif

AINSTANCE._AINFOS.CURLINE+=1

If AINSTANCE._AINFOS.CURLINE>maxtab(AINSTANCE._AINFOS.ATABINFO) : End [V]CST_ANOTDEFINED: Endif

If AINSTANCE._AINFOS.ATABINFO(AINSTANCE._AINFOS.CURLINE)<>null and AINSTANCE._AINFOS.ATABINFO(AINSTANCE._AINFOS.CURLINE).AERR<>null
  RSTATUS   = AINSTANCE._AINFOS.ATABINFO(AINSTANCE._AINFOS.CURLINE).AERR.STA
  RPROP     = AINSTANCE._AINFOS.ATABINFO(AINSTANCE._AINFOS.CURLINE).FULLPRO
  If AINSTANCE._AINFOS.ATABINFO(AINSTANCE._AINFOS.CURLINE).AERR.PRO<>""
   RPROP_LAB = RPROP
  Else
   Raz RPROP_LAB
  Endif
  RERR_MESS = AINSTANCE._AINFOS.ATABINFO(AINSTANCE._AINFOS.CURLINE).AERR.MES
  RCATEGORY = AINSTANCE._AINFOS.ATABINFO(AINSTANCE._AINFOS.CURLINE).AERR.CATEGORY
  If AINSTANCE._AINFOS.ATABINFO(AINSTANCE._AINFOS.CURLINE).AERR.AINFOS<>null
   RENVIRONMENT = AINSTANCE._AINFOS.ATABINFO(AINSTANCE._AINFOS.CURLINE).AERR.AINFOS.ENV
  Endif
Else
 [L]ASTATUS = [V]CST_AERROR
Endif

End [L]ASTATUS


#------------------------------------------------------------------------------#
# This first method fills the array of pointers in order to allow you to analyze it.
#------------------------------------------------------------------------------#
Funprog ASEARCHINFOS(AINSTANCE,AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,PATH)
Variable Instance AINSTANCE Using OBJECT
Variable Instance AINS_ORI Using OBJECT :#  not USED
Value Integer ERR_TYPE
Value    Char PROPERTY
Value Integer ASTAT
Value Integer SELSTAT
Value Char    PATH

Local Integer ASTATUS,ATAB,AI,OK
Local Integer CHRONO(1..)
Local Instance INFO Using C_ATABINFOS
Local Instance WTMP Using OBJECT

If  PATH="" : # AINS_ORI=null and
 Call _ADELETE_AINFOS(AINSTANCE)
 AINSTANCE._AINFOS = NewInstance C_ATABINFOS AllocGroup  AINSTANCE
 INFO = AINSTANCE._AINFOS
Else
 Local Char _AFAT(250)
 [L]_AFAT = "AINSTANCE"
 While evalue([L]_AFAT)<>null
  If evalue([L]_AFAT+"._AINFOS")<>null
   #Assign  INFO  With [L]_AFAT+"._AINFOS"
   INFO  = evalue([L]_AFAT+"._AINFOS")
   Break
  Endif
  [L]_AFAT += ".APARENT"
 Wend
 #If AINS_ORI._AINFOS<>null : INFO =  AINS_ORI._AINFOS : Endif
Endif

If INFO=null : End [V]CST_AERROR : Endif

For AI=1 To maxtab(AINSTANCE.AERROR)
 If AINSTANCE.AERROR(AI)<>null and AINSTANCE.AERROR(AI).DEL<>2 : # 117127
  If [L]ERR_TYPE=[V]CST_ALL
&  or ([L]ERR_TYPE=[V]CST_ACURRENT and [L]PROPERTY="")
&  or ([L]ERR_TYPE=[V]CST_ACURRENT and [L]PROPERTY=AINSTANCE.AERROR(AI).PRO)
   OK = 0
   Case SELSTAT
    When [V]CST_ALOWER : # LESS or EQUAL To ASTATUS
     If AINSTANCE.AERROR(AI).STA<=ASTAT : OK =1 : Endif
    When  [V]CST_AEQUAL : # EQUAL To ASTATUS
     If AINSTANCE.AERROR(AI).STA=ASTAT : OK =1 : Endif
    When [V]CST_AGREATER : # GREATER
     If AINSTANCE.AERROR(AI).STA>ASTAT : OK =1 : Endif
   Endcase
   If OK
    ATAB=maxtab(INFO.ATABINFO)
    For I=1 To ATAB
     If INFO.ATABINFO(I)<>null and INFO.ATABINFO(I).AERR<>null
      [L]CHRONO(I) = INFO.ATABINFO(I).AERR.ORDERCHRONO
     Endif
    Next
    ATAB+=+1
    INFO.ATABINFO(ATAB) = NewInstance C_ATABINFO AllocGroup  AINSTANCE
    INFO.ATABINFO(ATAB).AERR = AINSTANCE.AERROR(AI)
    If AINSTANCE.AERROR(AI).COPY=1
     INFO.ATABINFO(ATAB).FULLPRO = AINSTANCE.AERROR(AI).AINFOS.FULLPRO
    Else
     INFO.ATABINFO(ATAB).FULLPRO = [L]PATH+string$([L]PATH<>"" and AINSTANCE.AERROR(AI).PRO<>"",".")+AINSTANCE.AERROR(AI).PRO
    Endif
    [L]CHRONO(ATAB) = AINSTANCE.AERROR(AI).ORDERCHRONO
   Endif
  Endif
 Endif
Next

Sorta maxtab(INFO.ATABINFO) INFO.ATABINFO,[L]CHRONO Order By [L]CHRONO(indice+1)

End ASTATUS

#------------------------------------------------------------------------------#

Subprog _ADELETE_AINFOS(AINSTANCE)
Variable Instance AINSTANCE Using OBJECT
Local Instance WTMP Using OBJECT
Local Integer AI :#undeclared variable

If AINSTANCE._AINFOS<>null
 For AI=1 To maxtab(AINSTANCE._AINFOS.ATABINFO)
  If AINSTANCE._AINFOS.ATABINFO(AI)<>null
   If AINSTANCE._AINFOS.ATABINFO(AI).AERR<>null
    AINSTANCE._AINFOS.ATABINFO(AI).AERR = null
   Endif
   WTMP = AINSTANCE._AINFOS.ATABINFO(AI)
   AINSTANCE._AINFOS.ATABINFO(AI) = null
   FreeInstance  WTMP
  Endif
 Next AI
 WTMP = AINSTANCE._AINFOS
 AINSTANCE._AINFOS=null
 FreeInstance  WTMP
Endif
End

#------------------------------------------------------------------------------#
# Suppression d'une erreur ou toutes les erreurs (+) de l'instance courante
#------------------------------------------------------------------------------#
Subprog ADELETEERROR(ERR,GRP,PRO)
Variable Instance ERR(1..) Using C_AERROR
Value    Char     GRP
Value    Char     PRO
Local Integer AI
Local Instance WTMP Using C_AERROR
If [L]PRO=[V]CST_ALLERRORS
 For AI=1 To maxtab(ERR)
  If ERR(AI)<>null & (ERR(AI).PRO=[L]PRO or [L]PRO=[V]CST_ALLERRORS)
   WTMP = ERR(AI)
   ERR(AI) = null
   FreeInstance  WTMP
  Endif
 Next AI
Else
 For AI=1 To maxtab(ERR)
  If ERR(AI)<>null & ERR(AI).DEL<>2 & ERR(AI).PRO=[L]PRO
   WTMP = ERR(AI)
   ERR(AI) = WTMP : # For sysnapshot
   ERR(AI).DEL = 2 : # For return a null diagnose to Syracuse
  Endif
 Next AI
Endif
End

#**
#* AGETERRORS
#* - Obtention des erreurs pour une propriété donnée si PRO est renseigné
#* - Obtention de toutes les erreurs si PRO n'est âs renseigné
#*
#* @param ERR
#* @param PRO
#* @param ERRORS
#*!
Funprog AGETERRORS(ERR,PRO,ERRORS)
Variable Instance ERR(1..) Using C_AERROR
Value    Char     PRO
Variable Instance ERRORS(1..) Using C_AERROR

Local Integer  NBERRORS

Raz NBERRORS

Local Integer AI
For AI=1 To maxtab(ERR)
 If ERR(AI)<>null & ERR(AI).DEL<>2 & ( PRO = "" or ERR(AI).PRO=PRO )
  NBERRORS += 1
  ERRORS(NBERRORS) = ERR(AI)
 Endif
Next AI

End NBERRORS

#-------------------------------------------------------------------#
# Modification d'un attribut d'une propriété de l'instance courante
#-------------------------------------------------------------------#

Subprog ASETATTRIBUTE(ATT,GRP,PRO,COD,OPT)
Variable Instance ATT(1..) Using C_ATTRIBUTE
Value Char    GRP,PRO,COD,OPT

Local Integer AI , AJ
Local Char AKEY(100)
[L]AKEY = [L]PRO +"~" + [L]COD
AI = find([L]AKEY,ATT(1..maxtab(ATT)).AKEY )
If AI
 Local Instance WTMP Using C_ATTRIBUTE
 WTMP = ATT(AI)
 ATT(AI) = null
 FreeInstance   WTMP
Endif
AJ =  maxtab(ATT)+1
ATT(AJ) = NewInstance =[L]GRP , C_ATTRIBUTE
ATT(AJ).PRO = [L]PRO
ATT(AJ).COD = [L]COD
ATT(AJ).ATT = [L]OPT
ATT(AJ).AKEY = [L]AKEY
End

#-------------------------------------------------------------------------#
# Renvoie le statut d'un attribut d'une propriété de l'instance courante
#-------------------------------------------------------------------------#

Funprog AGETATTRIBUTE(ATT,PRO,COD)
Variable Instance ATT(1..) Using C_ATTRIBUTE
Value Char PRO,COD
Local Integer AI
Local Char AKEY(60)
[L]AKEY = [L]PRO +"~" + [L]COD
AI = find([L]AKEY,ATT(1..maxtab(ATT)).AKEY )
If AI : End ATT(AI).ATT : Endif
End ""

#-----------------------------------------------------------------------------------------------#
# Modification d'un attribut d'une propriété d'une collection de l'instance courante (obsolète)
#-----------------------------------------------------------------------------------------------#

Subprog ASETCOLATTRIBUTE(ATT,GRP,COL,PRO,COD,OPT)
Variable Instance ATT(1..) Using C_ATTRIBUTE
Value Char    GRP,COL,PRO,COD,OPT
Local Integer AI , AJ
Local Char    WGRP(20)
Local Instance WTMP Using C_ATTRIBUTE
AJ = maxtab(ATT)
For AI=1 To AJ
 If ATT(AI)<>null & ATT(AI).COL=COL & ATT(AI).PRO=[L]PRO & ATT(AI).COD=[L]COD
  #Trick set in order to make snapshots work !
  WTMP = ATT(AI)
  ATT(AI) = null
  FreeInstance  WTMP
  Break
 Endif
Next AI
AJ += 1
ATT(AJ) = NewInstance =[L]GRP , C_ATTRIBUTE
ATT(AJ).COL = [L]COL
ATT(AJ).PRO = [L]PRO
ATT(AJ).COD = [L]COD
ATT(AJ).ATT = [L]OPT
End

#-------------------------------------------------------------------#
# Modification d'un attribut d'un link (link, opération, méthode)
#-------------------------------------------------------------------#

Subprog ASETLNKATTRIBUTE(LNK,GRP,PRO,BUT,COD,OPT)
Variable Instance LNK(1..) Using C_ALINK
Value Char    GRP,PRO,BUT,COD,OPT
Local Integer AI , AJ , AK , AL
Local Char    WGRP(20)
Local Instance WLNK Using C_ALINK
AJ = maxtab(LNK)
For AI=1 To AJ
 If LNK(AI)<>null & LNK(AI).LNK=[L]BUT & LNK(AI).PRO=[L]PRO & LNK(AI).COD=[L]COD
  WLNK = LNK(AI)
  LNK(AI) = null
  FreeInstance   WLNK
  Break
 Endif
Next AI
AJ += 1
LNK(AJ) = NewInstance =[L]GRP , C_ALINK
LNK(AJ).PRO = [L]PRO
LNK(AJ).LNK = [L]BUT
LNK(AJ).COD = [L]COD
LNK(AJ).ATT = [L]OPT
End

#------------------------------------------------------------------------------------------------------#
# Lecture d'un intitulé traduisible superviseur à partir de l'instance ATX de l'instance courante
#------------------------------------------------------------------------------------------------------#

Funprog AGETTEXT(ATX,PRO,LAN)
Variable Instance ATX(1..) Using C_ATXTSUP
Value Char PRO
Value Char LAN
Local Integer AJ
For AJ=1 To maxtab(ATX)
 If ATX(AJ)<>null & ATX(AJ).PRO=[L]PRO & ATX(AJ).LAN=[L]LAN
  End ATX(AJ).TEX
  Break
 Endif
Next AI
End ""

#--------------------------------------------------------------------------------------------------#
# Mise à jour d'un intitulé traduisible superviseur dans une instance ATX de l'instance courante
#--------------------------------------------------------------------------------------------------#

Subprog ASETTEXT(ATX,GRP,PRO,TEX,LAN,NUM)
Variable Instance ATX(1..) Using C_ATXTSUP
Value Char    GRP
Value Char    PRO
Value Char    TEX
Value Char    LAN
Value Integer NUM
Local Integer AI , AJ, AK
Local Instance WTMP Using C_ATXTSUP
AJ = maxtab(ATX)
For AI=1 To AJ
 If ATX(AI)<>null & ATX(AI).PRO=[L]PRO & ATX(AI).LAN=[L]LAN
  AK = AI
  Break
 Endif
Next AI
If AK=0
 AK = AJ + 1
 ATX(AK) = NewInstance =[L]GRP , C_ATXTSUP
Endif
ATX(AK).PRO = [L]PRO
ATX(AK).LAN = [L]LAN
ATX(AK).NUM = [L]NUM
ATX(AK).TEX = [L]TEX
End

#--------------------------------------------------------------------------------------------#
# Lecture d'un intitulé traduisible à partir de l'instance AXX de l'instance courante
#--------------------------------------------------------------------------------------------#

Funprog AGETTEXTRA(AXX,PRO,LAN)
Variable Instance AXX(1..) Using C_ATXTTRA
Value Char PRO
Value Char LAN
Local Integer AI
For AI=1 To maxtab(AXX)
 If AXX(AI)<>null & AXX(AI).PRO=[L]PRO & AXX(AI).LAN=[L]LAN
  End AXX(AI).TEX
  Break
 Endif
Next AI
End ""

#--------------------------------------------------------------------------------------------#
# Mise à jour d'un intitulé traduisible dans une instance AXX de l'instance courante
#--------------------------------------------------------------------------------------------#

Subprog ASETTEXTRA(AXX,GRP,PRO,TEX,LAN)
Variable Instance AXX(1..) Using C_ATXTTRA
Value Char GRP
Value Char PRO
Value Char TEX
Value Char LAN

Local Integer AI,AJ,AK

AJ = maxtab(AXX)
For AI=1 To AJ
 If AXX(AI)<>null & AXX(AI).PRO=[L]PRO & AXX(AI).LAN=[L]LAN
  AK=AI
  Break
 Endif
Next AI
If AK=0
 AK = AJ + 1
 AXX(AK) = NewInstance =[L]GRP , C_ATXTTRA
Endif
AXX(AK).PRO = [L]PRO
AXX(AK).LAN = [L]LAN
AXX(AK).TEX = [L]TEX
AXX(AK).FLG = 1
End

#-------------------------------------------------------#
# Conversion booléen en data adonix (menu local 1)
#-------------------------------------------------------#

Funprog BOOLEAN_TO_ADX(VALEUR)
Value Char VALEUR
Local Integer NEWVAL
Case tolower(VALEUR)
 When "true"  : NEWVAL = 2
 When Default : NEWVAL = 1
Endcase
End NEWVAL

#-------------------------------------------#
# Conversion booléen adonix en Syracuse
#-------------------------------------------#

Funprog BOOLEAN_TO_SYR(VALEUR)
Value Integer VALEUR
Local Char NEWVAL(10)
Case VALEUR
 When 2       : NEWVAL = "true"
 When Default : NEWVAL = "false"
Endcase
End NEWVAL

#--------------------------------------#
# Conversion date en data adonix
#--------------------------------------#

Funprog DATE_TO_ADX(VALEUR)
Value Char VALEUR
Local Date NEWVAL
Case VALEUR
 When "0000-00-00","",func SYR_NULL : NEWVAL = [00/00/0000]
 When Default                       : NEWVAL = gdat$(val(right$(VALEUR,9)),val(mid$(VALEUR,6,2)),val(left$(VALEUR,5)))
Endcase
End NEWVAL

#--------------------------------------#
# Conversion date en Syracuse
#--------------------------------------#

Funprog DATE_TO_SYR(VALEUR)
Value Date VALEUR
Local Char NEWVAL(10)
NEWVAL = VALEUR
Case VALEUR
 When [0/0/0] : NEWVAL = "0000-00-00" :#func SYR_NULL
 When Default : NEWVAL = left$(VALEUR,4)+"-"+mid$(VALEUR,5,2)+"-"+right$(VALEUR,7)
Endcase
End NEWVAL

#--------------------------------------#
# Conversion time en data adonix
#--------------------------------------#

Funprog TIME_TO_ADX(VALEUR)
Value Char VALEUR
Local Char NEWVAL(30)
Case VALEUR
 When func SYR_NULL : NEWVAL = "0000"
 When Default       : NEWVAL = ctrans(VALEUR,":","")
Endcase
End NEWVAL

#--------------------------------------#
# Conversion time en syracuse
#--------------------------------------#

Funprog TIME_TO_SYR(VALEUR)
Value Char VALEUR
Local Char NEWVAL(30)
Case len(VALEUR)
 When 0,1,2,3,4
  NEWVAL = right$(num$(10000+val(VALEUR)),2)
  NEWVAL = left$(NEWVAL,2)+":"+right$(NEWVAL,3)+":00"
 When 5
  NEWVAL = right$(num$(100000+val(VALEUR)),2)
  NEWVAL = left$(NEWVAL,2)+":"+mid$(NEWVAL,3,2)+":00"
 When 6
  NEWVAL = right$(num$(1000000+val(VALEUR)),2)
  NEWVAL = left$(NEWVAL,2)+":"+mid$(NEWVAL,3,2)+":"+right$(NEWVAL,5)
 When Default
  NEWVAL = func SYR_NULL
Endcase
End NEWVAL

#-------------------------------------------------------#
# Conversion uuid en data adonix
#-------------------------------------------------------#

Funprog UUID_TO_ADX(VALEUR)
Value Char VALEUR
Local Uuident NEWVAL
Case VALEUR
 When func SYR_NULL : Assign "NEWVAL" With NullUuid
 When Default       : Assign "NEWVAL" With toUuid(VALEUR)
Endcase
End NEWVAL

#-------------------------------------------------------#
# Conversion uuid adonix en Syracuse
#-------------------------------------------------------#

Funprog UUID_TO_SYR(VALEUR)
Value Uuident VALEUR
Local Char NEWVAL (40)
NEWVAL = num$(VALEUR)
End NEWVAL

#--------------------------------------#
# Conversion datetime en data adonix
#--------------------------------------#

Funprog DATETIME_TO_ADX(VALEUR)
Value Char VALEUR
Local Datetime NEWVAL
# AAAA-MM-JJTHH:MM:SSZ
Local Integer A , M , J , H , N , S
Case VALEUR
 When "","0",func SYR_NULL,"0000-00-00T00:00:00Z"
  NEWVAL = gdatetime$("")
 When Default
  NEWVAL = gdatetime$(VALEUR)
Endcase
End NEWVAL

#--------------------------------------------#
# Conversion datetime adonix en Syracuse
#--------------------------------------------#

Funprog DATETIME_TO_SYR(VALEUR)
Value Datetime VALEUR
End num$(VALEUR)

#--------------------------------------#
# Conversion texte en data adonix
#--------------------------------------#

Funprog STRING_TO_ADX(TEXTE)
Value Clbfile TEXTE
End unescJson(TEXTE)

#------------------------------------------------#
# Conversion texte adonix en texte Syracuse
#------------------------------------------------#

Funprog STRING_TO_SYR(TEXTE)
Value Clbfile TEXTE
End escJson(TEXTE)

#------------------------------------------------------------#
Funprog CONTROL_TYP(TYPINT,TYPSYR,TYPLNG,DATA,ERRMES)
Value Integer TYPINT : # Type interne
Value Integer TYPSYR : # Type Syracuse
Value Integer TYPLNG : # Longueur
Value Char    DATA
Variable Char ERRMES
Local Date     DATDAT
Local Integer  DATINT
Local Decimal  DATDEC
Local Uuident  DATUID
Local Datetime DATTIM
Local Integer  I , J , K , A , M , D , OK , ERRSTA
Local Char     CHAINE(250)
ERRSTA = CST_AOK
ERRMES = ""
If DATA<>func SYR_NULL
 Onerrgo ERRTYP
 Case TYPSYR
  When 1 : # Boolean
   If !find(DATA,func BOOLEAN_TO_SYR(1),func BOOLEAN_TO_SYR(2))
    Gosub ERRMES
   Endif
  When 2 : # Integer
   Case TYPINT
    When 2
     If val(DATA)<-32767 or val(DATA)>32767
      Gosub ERRMES
     Endif
    When 3
     DATINT = val(DATA)
     If ERRSTA<>CST_AOK
      Gosub ERRMES
     Endif
   Endcase
  When 3 , 4 : # Real/Decimal
   DATDEC = val(DATA)
   If ERRSTA<>CST_AOK
    Gosub ERRMES
   Endif
  When 5 : # Date
   I = instr(1,DATA,"-")
   J = instr(I+1,DATA,"-")
   If !I or !J or len(DATA)<>10
    Gosub ERRMES
   Else
    A = val(left$(DATA,I-1))
    M = val(seg$(DATA,I+1,J-1))
    D = val(right$(DATA,J+1))
    CHAINE = ctrans(DATA,"-","")
    If A=0 & D=0 & M=0
     DATDAT = [0/0/0]
    Elsif A=1599 & M=12 & D=31 : # année null  Oracle
     DATDAT=[0/0/0]
    Elsif  A=1753 & M=01 & D=01 : # année null sqlserver
     DATDAT=[0/0/0]
    Elsif A<1800 or M<1 or M>12 or D<1 or D>31
     Gosub ERRMES
    Else
     DATDAT = gdat$(CHAINE)
     If ERRSTA<>CST_AOK
      Gosub ERRMES
     Endif
    Endif
   Endif
  When 6 : # Time
   OK = 0
   Case len(DATA)
    When 0
     OK = 1
    When 4 : # cas where we receive a time like "0945"  : bug 111039
     I = val(left$(DATA,2))
     J = val(right$(DATA,3))
     If I>=0 & I<=24 & J>=0 & J<=60
      OK = 1
     Endif
    When 5
     K = instr(1,DATA,":")
     If K
      I = val(left$(DATA,K-1))
      J = val(right$(DATA,K+1))
      If I>=0 & I<=60 & J>=0 & J<=60
       OK = 1
      Endif
     Endif
    When 8
     I = instr(1,DATA,":")
     J = instr(I+1,DATA,":")
     If I & J
      A = val(left$(DATA,I-1))
      M = val(seg$(DATA,I+1,J-1))
      D = val(right$(DATA,J+1))
      If A>=0 & A<=24 & M>=0 & M<=60 & D>=0 & D<=60
       OK = 1
      Endif
     Endif
   Endcase
   If !OK
    Gosub ERRMES
   Endif
  When 7
   Case TYPINT
    When 525 : # Uuid
     DATUID = func UUID_TO_ADX(DATA)
     If ERRSTA<>CST_AOK
      Gosub ERRMES
     Endif
    When Default : # Char
     CHAINE = func STRING_TO_ADX(DATA)
     Gosub CTRL_LONG
   Endcase
  When 8  : # Clob (todo)
  When 9  : # Nonsense
  When 10 : # Enum
   If val(DATA)<=0 or val(DATA)>=250
    Gosub ERRMES
   Endif
  When 11 : # Datetime
   DATTIM = gdatetime$(DATA)
   If ERRSTA<>CST_AOK or (len(DATA)<>0 & len(DATA)<>20)
    Gosub ERRMES
   Endif
  When 25 : # Textes superviseur
   K = instr(1,DATA,"~")
   If K
    CHAINE = func STRING_TO_ADX(left$(DATA,K-1))
   Else
    CHAINE = func STRING_TO_ADX(DATA)
   Endif
   Gosub CTRL_LONG
  When 26 : # Textes paramétrage
   CHAINE = func STRING_TO_ADX(DATA)
   Gosub CTRL_LONG
 Endcase
 Onerrgo
Endif
End ERRSTA

#-------------#
$ERRTYP
ERRMES = "'"+DATA+"'"-':'-errmes$(errn)
ERRSTA = CST_AERROR
Resume

#---------------------------#
$ERRMES
ERRSTA = CST_AERROR
# $1$ n'est pas au format $2$
ERRMES = func AFNC.MES2(mess(272,126,1),"'"+DATA+"'",func TYPINT(TYPINT,TYPSYR))
Return

#-----------------#
$CTRL_LONG
If TYPLNG>0 & len(CHAINE)>TYPLNG
 # $1$ est trop long (limité à $2$ caractères)
 ERRMES = func AFNC.MES2(mess(273,126,1),"'"+left$(DATA,50)+"'",num$(TYPLNG))
 ERRSTA = CST_AERROR
Endif
Return

#------------------------------------------------------------------------#
Funprog TYPINT(TYP,SYR)
Value Integer TYP : # Internal type of data (type adonix)
Value Integer SYR : # Interface type (Syracuse)
Local Char MES(20)
Case TYP
 When 1       : If SYR=1 : MES = "Boolean" : Else : MES = "Tinyint" : Endif
 When 2       : MES = "Shortint"
 When 3       : MES = "Date"
 When 4       : MES = "Integer"
 When 5       : MES = "Float"
 When 6       : MES = "Double"
 When 7       : If SYR=6 : MES = "Time" : Else : MES = "Decimal" : Endif
 When 8       : # VBT
 When 9       : # DCB Ibm
 When 522     : MES = "Blob"
 When 523     : MES = "Clob"
 When 525     : MES = "Uuident"
 When 526     : MES = "datetime"
 When Default : MES = "Char"
Endcase
End MES

#---------------------------------------------------------------#
# Détermination du type d'une propriété d'une représentation
#---------------------------------------------------------------#

Funprog TYP(REP,PRO)
Value Instance REP Using C_AREPENT
Value Char PRO
Local Char ZON(50)
Local Integer I , IND , TYP
ZON = func ZONE(PRO,IND)
I = find(ZON,REP.PRO(1..maxtab(REP.PRO)).PRO)
If I
 TYP = REP.PRO(I).TYP
Endif
End TYP

#-------------------------------------------------------------------------------------------------#
# Extraction du nom d'une propriété et de son indice à partir du nom complet d'une instance
#-------------------------------------------------------------------------------------------------#

Funprog ZONE(PRO,IND)
Value Char PRO
Variable Integer IND
Local Char ZON(250)
Local Integer I , J
IND = 0
ZON = PRO
If right$(ZON,len(ZON))=")"
 For I=len(ZON)-1 To 1
  If mid$(ZON,I,1)="("
   IND = val(right$(ZON,I+1))
   ZON = left$(ZON,I-1)
   Break
  Endif
 Next I
Endif
I = instr(1,ZON,"(")
While I
 J = instr(I,ZON,")")
 If J
  ZON = left$(ZON,I-1)+right$(ZON,J+1)
 Endif
 I = instr(1,ZON,"(")
Wend
End ZON

#--------------------------------------------------------------------------------------------------#
# Affectation de la valeur d'un paramètre suivant son type (utilisé pour méthodes et opérations)
#--------------------------------------------------------------------------------------------------#

Funprog PARAM_CHAR(COD,TBPAR,TBVAL)
Value Char    COD
Variable Char    TBPAR()(1..), TBVAL()(1..)
Local Integer I
Local Char    VALEUR(250)
VALEUR = ""
If COD<>""
 For I=1 To dim(TBPAR)
  If TBPAR(I)=""
   Break
  Elsif toupper(TBPAR(I))=toupper(COD)
   VALEUR = TBVAL(I)
   Break
  Endif
 Next I
Endif
End VALEUR

Funprog PARAM_UUID(COD,TBPAR,TBVAL)
Value Char    COD
Variable Char    TBPAR()(1..), TBVAL()(1..)
Local Integer I,ERROR
Local Uuident VALEUR
VALEUR = NullUuid
If COD<>""
 For I=1 To dim(TBPAR)
  If TBPAR(I)=""
   Break
  Elsif toupper(TBPAR(I))=toupper(COD)
   ERROR = func ASYRMAIN.SET_UUID(TBVAL(I),VALEUR)
   Break
  Endif
 Next I
Endif
End VALEUR

Funprog PARAM_NUM(COD,TBPAR,TBVAL)
Value Char    COD
Variable Char    TBPAR()(1..), TBVAL()(1..)
Local Integer I
Local Decimal VALEUR
VALEUR = 0
If COD<>""
 For I=1 To dim(TBPAR)
  If TBPAR(I)=""
   Break
  Elsif toupper(TBPAR(I))=toupper(COD)
   If TBVAL(I)="true"
    VALEUR = 2
   Elsif TBVAL(I)="false"
    VALEUR = 1
   Else
   VALEUR = val(TBVAL(I))
   Endif
   Break
  Endif
 Next I
Endif
End VALEUR

Funprog PARAM_DAT(COD,TBPAR,TBVAL)
Value Char    COD
Variable Char    TBPAR()(1..), TBVAL()(1..)
Local Integer I
Local Date VALEUR
VALEUR = [0/0/0]
If COD<>""
 Onerrgo ERDAT
 For I=1 To dim(TBPAR)
  If TBPAR(I)=""
   Break
  Elsif toupper(TBPAR(I))=toupper(COD)
   If instr(1,TBVAL(I),"-")=5
    VALEUR = ctrans(TBVAL(I),"-","")
    Break
   Elsif len(TBVAL(I))=8
    VALEUR = TBVAL(I)
   Endif
  Endif
 Next I
 Onerrgo
Endif
End VALEUR

$ERDAT
Resume

#--------------------------------------------------------------------------------------------#
# Etiquette appelée depuis les traitements WML
#--------------------------------------------------------------------------------------------#

Funprog ERREUR(TABLE,COD,FSTA)
Value Char    TABLE
Value Integer COD
Value Integer FSTA
Local Char MESSAGE(250)
Case COD
 When 1 : MESSAGE = mess(26,125,1)-TABLE-num$(FSTA) : # Erreur d'écriture
 When 2
  MESSAGE = mess(27,125,1)-TABLE-num$(FSTA) : # Erreur de réécriture
  If FSTA=6
   MESSAGE += "(Enregistrement a été mise a jour)"
  Endif
 When 3 : MESSAGE = mess(28,125,1)-TABLE-num$(FSTA) : # Erreur d'effacement
  If FSTA=7
   MESSAGE += "(Enregistrement a été mise a jour)"
  Endif
 When 4 : MESSAGE = mess(49,125,1)-TABLE-num$(FSTA) : # Erreur de lecture
 When 5 : MESSAGE = mess(58,134,1)-TABLE-num$(FSTA) : # Erreur de verrouillage
Endcase
End MESSAGE

$SET_CLE
Local Char    CLE(250)(1..16),CHAINE(250)
Local Integer NBCLE,I
If dim(ACLE)=0 : Return : Endif
CHAINE = ACLE
I=instr(1,CHAINE,"~")
While I>0
 NBCLE += 1
 CLE(NBCLE) = left$(CHAINE,I-1)
  # Restore ~ characters
 CLE(NBCLE)  = ctrans(CLE(NBCLE) ,[V]CST_ESCTILDE ,[V]CST_TILDE)
 CHAINE = right$(CHAINE,I+1)
 I=instr(1,CHAINE,"~")
Wend
NBCLE += 1
CLE(NBCLE) =CHAINE
Return

#--------------------------------------------------------------------------------------------#
# Etiquette appelée depuis la méthode contructor des classes et représentation
#--------------------------------------------------------------------------------------------#

$CREATE_INSTANCE
# Référence environnement
If dim(this.ACTX)>0
 If _GLO=null & dim(GACTX)>0
  this.ACTX = GACTX
 Else
  this.ACTX = _GLO
 Endif
Endif
# Unique identifier
If dim(this.AUUID)>0  :
 If [L]_UID=NullUuid
  this.AUUID  = getUuid
 Else
  this.AUUID  = [L]_UID
 Endif
 If(dim(this.ABASE)> 0 )
  If _IPA <> null & dim(_IPA.ABASE) > 0
   this.ABASE = _IPA.ABASE
  Else
   this.ABASE = this
  Endif
  this.ABASE.AINSNBR+=1
  this.ABASE.AINSUUID(this.ABASE.AINSNBR) = this.AUUID
  this.ABASE.AINSOBJ(this.ABASE.AINSNBR)  = this
 Endif
Endif
# Syracuse line
If dim(this.AORDER)>0 : this.AORDER = [L]_LIN : Endif
# Si class parent
If dim([L]_IPA)>0 &  [L]_IPA<> null
 this.APARENT = [L]_IPA
 If this.APARENT.sysSnapshotEnabled=1
  this.sysSnapshotEnabled=1
 Endif
 If [L]_IPA<>null and [L]_IPA.AINF<>null
  Local Integer _FINDTRT,_ANBTRT
  Local Char    _NAMTRT(120)
  For [L]_ANBTRT=1 To [L]_IPA.AINF.NBTRT
#   [L]_FINDTRT= find([L]_NAMTRT+string$([L]_NAMTRT<>"","~")+[L]_IPA.AINF.TRT([L]_ANBTRT),this.AINF.KEYPTH)
#   If len(this.ObjectType)>2 & instr(1,right$(this.ObjectType,3),"_")>0 & [L]_ANBTRT=1 : # Pour la gestion des collections
#    [L]_FINDTRT=1
#   Endif
   If [L]_ANBTRT=1 & instr(3,this.ObjectType,"_")>0 : # Pour la gestion des collections
    [L]_FINDTRT=1
   Else
    If [L]_IPA.AINF.PTH([L]_ANBTRT)<>""
    [L]_NAMTRT = [L]_IPA.AINF.PTH([L]_ANBTRT)+"."+[L]_PPA
    Else
    [L]_NAMTRT = [L]_PPA
    Endif
    [L]_FINDTRT=find([L]_NAMTRT+"~"+[L]_IPA.AINF.TRT([L]_ANBTRT),this.AINF.KEYPTH(1..this.AINF.NBTRT))
   Endif

   If [L]_FINDTRT=0 & [L]_IPA.AINF.TRT([L]_ANBTRT)<>""
    this.AINF.NBTRT += 1
    If left$([L]_IPA.AINF.TRT([L]_ANBTRT),5)<>"WMCM_"
     this.AINF.TRT(this.AINF.NBTRT)       = [L]_IPA.AINF.TRT([L]_ANBTRT)
     this.AINF.TYP(this.AINF.NBTRT)      = [L]_IPA.AINF.TYP([L]_ANBTRT)
     this.AINF.PTH(this.AINF.NBTRT)       = [L]_NAMTRT
     this.AINF.KEYPTH(this.AINF.NBTRT)  = [L]_NAMTRT+"~"+[L]_IPA.AINF.TRT([L]_ANBTRT)
    Else
     Insa 1,1 this.AINF.TRT,this.AINF.TYP,this.AINF.PTH,this.AINF.KEYPTH
     this.AINF.TRT(1)      = [L]_IPA.AINF.TRT([L]_ANBTRT)
     this.AINF.TYP(1)      = [L]_IPA.AINF.TYP([L]_ANBTRT)
     this.AINF.PTH(1)      = [L]_NAMTRT
     this.AINF.KEYPTH(1)  = [L]_NAMTRT+"~"+[L]_IPA.AINF.TRT([L]_ANBTRT)
    Endif
   Endif
  Next
 Endif
Else
 this.APARENT = null : # Pas de classe mère
Endif
Return

#**
#**
#* Create or find the good instance of AINFO
#*!
$AINFO_INSTANCE
Local Integer I : #Issue 3121
#Onerrgo CCL
#If adxmac(-2)="pc018948.sagefr.adinternal.com " & this.OBJECTTYPE="C_ATABLE"
# Call ECR_TRACE(" maxtab(_GLO.AINFOS) = "-num$( maxtab(_GLO.AINFOS)),0) From GESECRAN
#Endif
Local Char NAMCLA(250)

If _IPA <>null & len(_IPA.AINF.NAMCLA)
 NAMCLA = _IPA.AINF.NAMCLA + "~"
Endif
If [L]_PPA<>""
 [L]NAMCLA += [L]_PPA+"_"+this.ObjectType
Else
 [L]NAMCLA += this.ObjectType
Endif

I = find([L]NAMCLA,_GLO.AINFOS(1..maxtab(_GLO.AINFOS)).NAMCLA )
If I
 this.AINF = _GLO.AINFOS(I)
Else
 #The ANFO object can be cached in the context and shared :
 I=maxtab(_GLO.AINFOS)+1
 Local Integer _RO : _RO=  _GLO.isReadonly
 _GLO.isReadonly = 0
 _GLO.AINFOS(I) = NewInstance  [ASYRACTX] With C_AINFO
 _GLO.AINFOS(I).NAMCLA = [L]NAMCLA
 #this.AINF can be used by this._ADDTRT
 this.AINF = _GLO.AINFOS(I)
 [L]ASTATUS = fmet this._ADDTRT
 _GLO.isReadonly = _RO
Endif
#Onerrgo
Return

$CCL
Call ECR_TRACE("eerue",0) From GESECRAN
Resume

#**
#* SPLIT(ARRAY,TEXT,SEP)
#* Split the string TEXT on SEP and store the result in ARRAY
#* Returns the number of segments
#*
#* @param ARRAY
#* @param TEXT
#* @param SEP
#*!
Funprog SPLIT(ARRAY,TEXT,SEP)
Variable Char ARRAY()(0..)
Variable Char TEXT
Value Char SEP

Local Char STRING(250)
Local Char SUBSTRING(250)
Local Integer I,J,K
STRING = TEXT

Local Integer POS
Local Integer COUNT
POS=-1
COUNT=0
Raz ARRAY

If len(STRING) > 0
 POS = dim(ARRAY,-1)

 While STRING<>""
  Raz I,K
  For J=1 To len(SEP)
   K = instr(1,STRING,mid$(SEP,J,1))
   If K
    If I : I = min(I,K) : Else : I = K : Endif
   Endif
  Next J

  If I
   SUBSTRING  = left$(STRING,I-1)
   If len(SUBSTRING) > 0
    ARRAY(POS) = left$(STRING,I-1)
    POS   += 1
    COUNT += 1
   Endif
   STRING   = right$(STRING,I+1)
  Else
   ARRAY(POS) = STRING
   POS   += 1
   COUNT += 1
   Break
  Endif

 Wend
Endif
End COUNT

#**
#* SPLIT1(ARRAY,TEXT,SEP)
#* Split the string TEXT on SEP and store the result in ARRAY
#* An empty substring is set as empty
#* SEP is a unique separator
#* Returns the number of segments
#*
#* @param ARRAY
#* @param TEXT
#* @param SEP
#*!
Funprog SPLIT1(ARRAY,TEXT,SEP)
Variable Char ARRAY()(1..)
Value Char TEXT
Value Char SEP

Local Integer I,POS
Raz ARRAY

 While TEXT<>""
   POS+=1
   I = instr(1,TEXT,SEP)
   If I
    ARRAY(POS)= left$(TEXT,I-1)
    TEXT   = right$(TEXT,I+1)
  Else
   ARRAY(POS) = TEXT
   TEXT=""
  Endif
 Wend

End POS


#--------------------------------------------------------------------------------------------#
# Appelé pour l'update AXX
#--------------------------------------------------------------------------------------------#

Subprog MAJTEXTRALAN(WCLA,TEXTE,TABLE,CHAMP,LAN,CLE1,CLE2,OK)
Variable Instance WCLA Using OBJECT
Value    Char    TEXTE, TABLE,  CHAMP,LAN, CLE1, CLE2
Variable Integer OK
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If adxlog
 Read [AXX]AXX0 = TABLE;CHAMP;LAN;CLE1;CLE2
 If !fstat
  [F:AXX]TEXTE = TEXTE
  Call FLDUPD("AXX") From OBJDIV
  RewriteByKey [AXX]AXX0 = TABLE;CHAMP;LAN;CLE1;CLE2
  If fstat
   OK=0 : Call FSTA("AXX",WCLA,OK) From ASYRSUB : End
  Endif
 Else
  Raz [F:AXX]
  [F:AXX]CODFIC = TABLE
  [F:AXX]ZONE   = CHAMP
  [F:AXX]LANGUE = LAN
  [F:AXX]TEXTE  = TEXTE
  [F:AXX]IDENT1 = CLE1
  [F:AXX]IDENT2 = CLE2
  Call FLDCRE("AXX") From OBJDIV
  Write [AXX]
  If fstat
   OK=0 : Call FSTA("AXX",WCLA,OK) From ASYRSUB : End
  Endif
 Endif
Endif
End

#--------------------------------------------------------------------------------------------#
# Appelé pour le delete AXX
#--------------------------------------------------------------------------------------------#

Subprog SUPTEXTRA(WCLA,TEXTE,TABLE,CHAMP,LAN,CLE1,CLE2,OK)
Variable Instance WCLA Using OBJECT
Value    Char    TEXTE, TABLE,  CHAMP,LAN, CLE1, CLE2
Variable Integer OK
Local File ATEXTRA [AXX]
If adxlog
 Delete [AXX] Where CODFIC=TABLE and ZONE=CHAMP and LANGUE=LAN and IDENT1=CLE1 and IDENT2=CLE2
 If fstat
   OK=0 : Call FSTA("AXX",WCLA,OK) From ASYRSUB : End
 Endif
Endif
LogicClose File [AXX]
End

#--------------------------------------------------------------------------------------#
# Permet de collecter toutes les erreurs d'une instance (et des sous-instances)
# de les trier et de les transférer dans une autre classe
#--------------------------------------------------------------------------------------#
#used for subprog ALLERRORS and ALOG_CSTD/PUTERRORSCLA

Subprog ALLERRORS(CLA,CTX,SUPP)
Variable Instance CLA Using OBJECT
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Integer SUPP
Local Instance WTMP Using C_AERROR
Local Integer AI , AJ
Local Datetime DAT(1..)
CTX.isReadonly = 0
For AI=1 To maxtab(CLA.AERROR)
 If CLA.AERROR(AI)<>null & CLA.AERROR(AI).DEL<>2
  AJ = maxtab(CTX.AERROR)+1
  #CTX.AERROR(AJ) = NewInstance =CTX.AllocGrp, C_AERROR
  CTX.AERROR(AJ) = NewInstance C_AERROR AllocGroup  CTX
  CTX.AERROR(AJ).STA = CLA.AERROR(AI).STA
  CTX.AERROR(AJ).MES = CLA.AERROR(AI).MES
  CTX.AERROR(AJ).NUM = CLA.AERROR(AI).NUM
  CTX.AERROR(AJ).PRO = CLA.AERROR(AI).PRO
  CTX.AERROR(AJ).DEL = CLA.AERROR(AI).DEL
  CTX.AERROR(AJ).CATEGORY = CLA.AERROR(AI).CATEGORY
  CTX.AERROR(AJ).COPY = CLA.AERROR(AI).COPY
  CTX.AERROR(AJ).ORDERCHRONO = CLA.AERROR(AI).ORDERCHRONO
  CTX.AERROR(AJ).AUUID = CLA.AERROR(AI).AUUID
  CTX.AERROR(AJ).CREDATTIM = CLA.AERROR(AI).CREDATTIM
  CTX.AERROR(AJ).UPDDATTIM = CLA.AERROR(AI).UPDDATTIM
  If SUPP=CST_AYES
    WTMP = CLA.AERROR(AI)
    CLA.AERROR(AI) = null
    FreeInstance WTMP
  Endif
 Endif
Next AI
For AI=1 To maxtab(CTX.AERROR)
 If CTX.AERROR(AI)<>null
  [L]DAT(AI) = CTX.AERROR(AI).CREDATTIM
 Endif
Next AI
Sorta maxtab(CTX.AERROR) CTX.AERROR,[L]DAT Order By [L]DAT(indice+1)
CTX.isReadonly = 1
End

#----------------------------------------------------------------#
# Mise à jour des champs standard en création d'une fiche
#----------------------------------------------------------------#

Subprog INICRE(WCLA)
Variable Instance  WCLA Using OBJECT

Gosub INITPRO
 # jira 70340 init credattim tjs
 # alignement with atrifil for classic mode - init upddat and updtim
If dim(WCLA.CREDAT)>0
      WCLA.CREDAT = date$
Endif
If dim(WCLA.CRETIM)>0 & type(WCLA.CRETIM)=4
      WCLA.CRETIM = time
Endif
If dim(WCLA.CREUSR)>0 & dim(WCLA.ACTX.USER)>0
      WCLA.CREUSR=WCLA.ACTX.USER
Endif
If dim(WCLA.EXPNUM)>0
      WCLA.EXPNUM = [C]EXPORT
Endif
If dim(WCLA.UPDDAT)>0
      WCLA.UPDDAT= date$
Endif
If dim(WCLA.UPDTIM)>0 & type(WCLA.UPDTIM)=4
      WCLA.UPDTIM = time
Endif
If dim(WCLA.UPDUSR)>0
      WCLA.UPDUSR= WCLA.ACTX.USER
Endif
If dim(WCLA.CREDATTIM)>0 : Gosub INIT_CREDATTIM : Endif
If dim(WCLA.UPDDATTIM)>0 : Gosub INIT_UPDDATTIM : Endif
Gosub INIT_UUID
End

#----------------------------------------------------------------#
# Mise à jour des champs standard en modification d'une fiche
#----------------------------------------------------------------#

Subprog INIUPD(WCLA)
Variable Instance  WCLA Using OBJECT

Gosub INITPRO
 # jira 70340 init credattim tjs
 # alignement with atrifil for classic mode - init upddat and updtim

If dim(WCLA.UPDDAT)>0
    WCLA.UPDDAT = date$
Endif
If dim(WCLA.UPDTIM)>0 & type(WCLA.UPDTIM)=4
    WCLA.UPDTIM = time
Endif
If dim(WCLA.UPDUSR)>0 & dim(WCLA.ACTX.USER)>0
    WCLA.UPDUSR=WCLA.ACTX.USER
Endif
If dim(WCLA.EXPNUM)>0
    WCLA.EXPNUM = [C]EXPORT
Endif
If dim(WCLA.UPDDATTIM)>0 : Gosub INIT_UPDDATTIM   : Endif
Gosub INIT_UUID
End

$INITPRO
Local Char    ATIMSTP(50) , AUSRCUR(20)
Local Integer ER
If func AFNC.PARTSEP(ver$(0),2," ")>="17r.104"
 Local Datetime ADATTIM
 ADATTIM = datetime$
Endif
ATIMSTP = timestamp$
Return

#----------------------------#
$INIT_UUID
If dim(WCLA.AUUID)>0
 If type(WCLA.AUUID)=525
  Onerrgo ER
  If WCLA.AUUID=NullUuid : # Uuident
   WCLA.AUUID = getUuid
  Endif
  Onerrgo
  If ER & num$(WCLA.AUUID)="00000000-0000-0000-0000-000000000000" : # Uuident
   WCLA.AUUID = getUuid
  Endif
 Elsif WCLA.AUUID=""
  WCLA.AUUID = uuid$
 Endif
Endif
Return


#----------------------------#
$INIT_CREDATTIM
If dim(WCLA.CREDATTIM)>0
 If type(WCLA.CREDATTIM)=526
  If dim([L]ADATTIM)>0
   WCLA.CREDATTIM = ADATTIM
  Endif
 Else
  WCLA.CREDATTIM = ATIMSTP
 Endif
Endif
Return

#----------------------------#
$MAJ_UPDDATTIM
If dim(WCLA.UPDDATTIM)>0
 If type(WCLA.UPDDATTIM)=526
  If dim([L]ADATTIM)>0 & num$(WCLA.UPDDATTIM)=num$(gdatetime$(""))
   WCLA.UPDDATTIM = ADATTIM
  Endif
 Elsif WCLA.UPDDATTIM=""
  WCLA.UPDDATTIM = ATIMSTP
 Endif
Endif
Return

#----------------------------#
$MAJ_CREDATTIM
If dim(WCLA.CREDATTIM)>0
 If type(WCLA.CREDATTIM)=526
  If dim([L]ADATTIM)>0 & num$(WCLA.CREDATTIM)=num$(gdatetime$(""))
   WCLA.CREDATTIM = ADATTIM
  Endif
 Elsif WCLA.CREDATTIM=""
  WCLA.CREDATTIM = ATIMSTP
 Endif
Endif
Return

#----------------------------#
$INIT_UPDDATTIM
If dim(WCLA.UPDDATTIM)>0
 If type(WCLA.UPDDATTIM)=526
  If dim([L]ADATTIM)>0
   WCLA.UPDDATTIM = ADATTIM
  Endif
 Else
  WCLA.UPDDATTIM = ATIMSTP
 Endif
Endif
Return

#---------------#
$ER
ER = errn
Resume

#------------------------------------------------------------#
Subprog RSTA(ABR,CLE,WCLA,ASTATUS)
Value Char    ABR
Value Char CLE
Variable Instance WCLA Using OBJECT
Variable Integer ASTATUS

Local Integer RD
RD = 1
Goto STAT

#------------------------------------------------------------#
Subprog FSTA(ABR,WCLA,ASTATUS)
Value Char    ABR
Variable Instance WCLA Using OBJECT
Variable Integer ASTATUS

Local Integer RD
Local Char    CLE(250)
RD = 0

$STAT

Local Char    SUBCLE(GLONAVA)
Local Char    SAVIFS(10) , SAVIRS(10)
Local Integer SAVIUM
Local Char    CHEMIN(GLONTRA) , REPERT(GLONTRA) , NOMFIC(GLONATB) , EXT(10)
Local Char    MESSAGE(40) , TEXTE(240)
Local Char    VARIA(GLONAVA+GLONABR+10) , APPLI(GLONADS)
Local Integer I , J , SAVFSTAT, ERR
SAVFSTAT = fstat
Local File ATABIND [AZZ_]
Local Char    NOMCLE(type([F:AZZ_]DESCRIPT)-10)
Local Integer HTTP_STATUS

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

CHEMIN = ""
If left$(ABR,1)<>"@"
 For I=1 To adxmto
  If fileabre(I)=ABR
   If evalue("clalev([F:"+ABR+"])")=1
    CHEMIN = filename(I) : Break
   Endif
  Endif
 Next I
 If CHEMIN="" & left$(CLE,1)<>"#"
  If RD
   ASTATUS = fmet WCLA.ASETERROR("","RSTA"-mess(152,115,1)-ABR,[V]CST_AERROR)
  Else
   ASTATUS = fmet WCLA.ASETERROR("FSTA"-mess(152,115,1)-ABR,[V]CST_AERROR)
  Endif
  End
 Endif

 J = instr(1,CHEMIN,"@")
 If J
  I = instr(1,CHEMIN,".FIL")
  If I
   APPLI = seg$(CHEMIN,J+1,I-1)
   If APPLI = nomap(0) : APPLI="" : Endif
  Endif
 Endif

 J = instr(1,CHEMIN,"/")
 If J
  I = instr(1,CHEMIN,"$")
  If I
   NOMFIC = seg$(CHEMIN,J+1,I-1)
  Else
   NOMFIC = right$(CHEMIN,J+1)
  Endif
 Endif

 If !RD
  CLE=""
  Read [AZZ_]NUMLIG(2) = NOMFIC;1
  If !fstat
   NOMCLE = [F:AZZ_]DESCRIPT
   While NOMCLE<>""
    I = instr(1,NOMCLE,"+")
    J = instr(1,NOMCLE,"-")
    If I & J : I = min(I,J)
    Elsif J & !I : J = I
    Endif
    If I
     SUBCLE = left$(NOMCLE,I-1) : NOMCLE = right$(NOMCLE,I+1)
    Else
     SUBCLE = NOMCLE : NOMCLE = ""
    Endif
    CLE -= num$(evalue("[F:"+ABR+"]"+SUBCLE))
   Wend
  Endif
 Endif
Else
 NOMFIC = "APLLCK"
 CHEMIN = NOMFIC
 CLE = right$(ABR,2)
Endif

[L]HTTP_STATUS = [V]CST_AHTTP_BAD_REQUEST
Case SAVFSTAT
 When 0       :
  MESSAGE = ""
  [L]HTTP_STATUS = [V]CST_AHTTP_OK
 When 1       : MESSAGE = mess(60,100,1)  : # Enregistrement verrouillé
 When 2       : MESSAGE = mess(153,115,1) : # Clé suivante lue
 When 3       : MESSAGE = mess(22,100,1)  : # Clé déjà existante
 When 4       : MESSAGE = mess(11,100,1)  : # Début/fin de fichier
 When 5       : MESSAGE = mess(154,115,1) : # Pas d'enregistrement courant
 When 6,7     : MESSAGE = mess(240,115,1) : # Enregistrement obsolète
  [L]HTTP_STATUS = [V]CST_AHTTP_PRECONDITION_FAILED
 When Default : MESSAGE = mess(6,123,1)   : # Erreur
Endcase

TEXTE = func AFNC.MES3(mess(65,140,1),CLE,NOMFIC,MESSAGE)
#
#If NOMFIC<>""
# If APPLI<>"" : TEXTE = mess(85,115,1)-":"-APPLI+"\" : Endif
# TEXTE += mess(55,100,1)-":|"-NOMFIC-"["+ABR+"]"+"|\" : # Fichier
#Else
# TEXTE = ""
#Endif
#If left$(CLE,1)<>"#"
# TEXTE += mess(55,123,1)-NOMCLE+":"-CLE : # Clé
# If MESSAGE<>"" : TEXTE+="\"+MESSAGE : Endif
#Else
# TEXTE += right$(CLE,2)
#Endif
#TEXTE += "\\"+mess(14,100,1) : # Transaction interrompue
#ASTATUS = fmet WCLA.ASETERROR("",TEXTE,[V]CST_AERROR)
ASTATUS = func ASYRSUB._ASETSTATUS(WCLA,"",0,[V]CST_AERROR, HTTP_STATUS, TEXTE)
End

###############################################################################################
####  Removing class
###############################################################################################

Funprog VERIFY_INSTANCE(WCLA,ALNKDELTAB)
Variable Instance WCLA Using OBJECT
Variable Instance ALNKDELTAB Using C_ALNKDELTAB

Local Integer ASTATUS

ALNKDELTAB= NewInstance C_ALNKDELTAB AllocGroup WCLA
[L]ASTATUS  = fmet ALNKDELTAB.LOAD(WCLA)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

[L]ASTATUS  = fmet ALNKDELTAB.VERIFY(WCLA)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

End [L]ASTATUS


###############################################################################################
####  Removing class
###############################################################################################

Funprog DELETE_LINKS(WCLA,ALNKDELTAB)
Variable Instance WCLA Using OBJECT
Variable Instance ALNKDELTAB Using C_ALNKDELTAB

Local Integer ASTATUS

ALNKDELTAB= NewInstance =WCLA.AllocGrp, C_ALNKDELTAB

[L]ASTATUS  = fmet ALNKDELTAB.DELETE_LINKS(WCLA)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

End [L]ASTATUS


#**
#* Retrieve a file DATETIME
#*!
Funprog FILEDATETIME(PATH)
Variable Char PATH()
Local Datetime DT

Local Integer S , H , M
Local Date D
Local Char TIMESTAMP(20)
Local Integer FTIMES

FTIMES  = filinfo(PATH, 9)
If FTIMES > 0
 S = int(mod(FTIMES,60))
 M = int(mod(FTIMES,3600)/60)
 H = int(mod(FTIMES,86400)/3600)
 D = [01/01/1970]+int(FTIMES/86400)
 TIMESTAMP = right$(num$(100+H),2)+":"+right$(num$(100+M),2)+":"+right$(num$(100+S),2)+"Z"
 TIMESTAMP = num$(year(D))+"-"+right$(num$(100+month(D)),2)+"-"+right$(num$(100+day(D)),2)+"T"+TIMESTAMP
 DT = gdatetime$(TIMESTAMP)
Endif
End DT


#**
#* AINSSETKEY
#*
#* @param OBJ
#*!
Subprog AINSSETKEY(FATHER,CHILD)
Variable Instance FATHER Using OBJECT
Variable Instance CHILD  Using OBJECT

If(dim(CHILD.ABASE)> 0 )
 If FATHER <> null & dim(FATHER.ABASE) > 0
  CHILD.ABASE = FATHER.ABASE
 Else
  CHILD.ABASE = CHILD
 Endif
 CHILD.ABASE.AINSNBR+=1
 CHILD.ABASE.AINSUUID(CHILD.ABASE.AINSNBR) = CHILD.AUUID
 CHILD.ABASE.AINSOBJ(CHILD.ABASE.AINSNBR)  = CHILD
Endif
End
#**
#* AINSCHANGEKEY
#*
#* @param OBJ
#* @param OLDUUID
#*!
Subprog AINSCHANGEKEY(OBJ,OLDUUID)
Variable Instance   OBJ Using OBJECT
Value    Uuident    OLDUUID

Local Integer I
If dim(OBJ.AUUID)>0  :
 I = find(OLDUUID,OBJ.ABASE.AINSUUID)
 If I > 0
  OBJ.ABASE.AINSUUID(I) = OBJ.AUUID
 Endif
Endif
End

#**
#* AINSCHANGEKEY
#*
#* @param AUUID
#*!
Funprog  AINSFINDOBJECT(FATHER,AUUID)
Variable Instance   FATHER Using OBJECT
Value    Uuident    AUUID

Local Instance OBJ Using OBJECT

OBJ = null

Local Integer I
If dim(AUUID)>0  :
 I = find(AUUID,FATHER.AINSUUID)
 If I > 0
  OBJ = FATHER.AINSOBJ(I)
 Endif
Endif
End OBJ


#############################
Funprog AGETATTTYP(_COD)
Value Char _COD

Gosub _AGETATTTYP

End ATTTYP

###############
$_AGETATTTYP
Local Integer FCOD,SCOD,LCOD
Case [L]_COD
When "$title" : ATTTYP = 3 : SCOD=3
When "$description" : ATTTYP = 3 : SCOD=4

When "$isMandatory" : ATTTYP = 5 : FCOD=3
When "$isHidden" : ATTTYP = 5 : FCOD=4
When "$isReadOnly" : ATTTYP = 5 : FCOD=5
When "$isDisabled" : ATTTYP = 5 : FCOD=6
When "$isRequested" : ATTTYP = 5 : FCOD=7
When "$isEditMode" : ATTTYP = 5 : FCOD=8
When "$isDelta" : ATTTYP = 5 : FCOD=9
When "$isDeleted" : ATTTYP = 5 : FCOD=10
When "$isExcluded" : ATTTYP = 5 : FCOD=11
When "$_rightAccess" : ATTTYP = 5 : FCOD=12

When "$symbol" : ATTTYP = 3 : SCOD=1
When "$x3Format" : ATTTYP = 3 : SCOD=2
##
When "$contentType" : ATTTYP = 3 : SCOD=5
When "$filename" : ATTTYP = 3 : SCOD=6
When "$acceptedTypes" : ATTTYP = 3 : SCOD=7
When "$style" : ATTTYP = 3 : SCOD=8
When "$label" : ATTTYP = 3 : SCOD=9
When "$namProParent" : ATTTYP = 3 : SCOD=10

When "$index" : ATTTYP = 4 : LCOD=1
When "$scale" : ATTTYP = 4 : LCOD=2
When "$precision" : ATTTYP = 4 : LCOD=3
When "$isLobFound" : ATTTYP = 5 : FCOD=2
When "$isLoaded" : ATTTYP = 5 : FCOD=1
When Default
 ACOD =  find([L]_COD,PATTRIBUTES.ATT(1..maxtab(PATTRIBUTES.ATT)).COD )
 ATTTYP = 3 :#string
Endcase
Return

$_GETATTNAMES
Global Integer CST_ATTFCODMIN,CST_ATTFCODMAX,CST_ATTSCODMIN,CST_ATTSCODMAX,CST_ATTLCODMIN,CST_ATTLCODMAX
Global Char CST_ATT(20)(1..25)
Local Integer ACOD
ACOD +=1 : [V]CST_ATTFCODMIN = ACOD : CST_ATT(ACOD)="$isLoaded"
ACOD +=1 : CST_ATT(ACOD)="$isLobFound"
ACOD +=1 : CST_ATT(ACOD)="$isMandatory"
ACOD +=1 : CST_ATT(ACOD)="$isHidden"
ACOD +=1 : CST_ATT(ACOD)="$isReadOnly"
ACOD +=1 : CST_ATT(ACOD)="$isDisabled"
ACOD +=1 : CST_ATT(ACOD)="$isRequested"
ACOD +=1 : CST_ATT(ACOD)="$isEditMode"
ACOD +=1 : CST_ATT(ACOD)="$isDelta"
ACOD +=1 : CST_ATT(ACOD)="$isDeleted"
ACOD +=1 : CST_ATT(ACOD)="$isExcluded"
ACOD +=1 : CST_ATT(ACOD)="$_rightAccess"
[V]CST_ATTFCODMAX = ACOD

ACOD += 1 : [V]CST_ATTSCODMIN = ACOD : CST_ATT(ACOD) = "$symbol"
ACOD += 1 : CST_ATT(ACOD) = "$x3Format"
ACOD += 1 : CST_ATT(ACOD) = "$title"
ACOD += 1 : CST_ATT(ACOD) = "$description"
ACOD += 1 : CST_ATT(ACOD) = "$contentType"
ACOD += 1 : CST_ATT(ACOD) = "$filename"
ACOD += 1 : CST_ATT(ACOD) = "$acceptedTypes"
ACOD += 1 : CST_ATT(ACOD) = "$style"
ACOD += 1 : CST_ATT(ACOD) = "$label"
ACOD +=1  : CST_ATT(ACOD) = "$namProParent"
[V]CST_ATTSCODMAX = 1+ACOD-[V]CST_ATTSCODMIN

ACOD += 1 : [V]CST_ATTLCODMIN = ACOD : CST_ATT(ACOD) = "$index"
ACOD += 1 : CST_ATT(ACOD) = "$scale"
ACOD += 1 : CST_ATT(ACOD) = "$precision"
[V]CST_ATTLCODMAX = 1+ACOD-[V]CST_ATTLCODMIN
Return


#-------------------------------------------------------------------#
# Modification d'un attribut d'une propriété de l'instance courante
#-------------------------------------------------------------------#
Subprog _ASETATTRIBUTE(_THIS,_PRO,_COD,_OPT)
Variable Instance _THIS Using OBJECT
Value Char    _PRO
Value Char _COD
Value Char _OPT

Local Integer  AP
AP = find([L]_PRO,_THIS.AATTRIBUTES(1..maxtab(_THIS.AATTRIBUTES)).PRO )
If !AP
 AP =  maxtab(_THIS.AATTRIBUTES)+1
 _THIS.AATTRIBUTES(AP) = NewInstance C_ATTRIBUTES AllocGroup _THIS
 _THIS.AATTRIBUTES(AP).PRO = [L]_PRO
 _THIS.AATTRIBUTES(AP).sysSnapshotEnabled=_THIS.sysSnapshotEnabled
 _THIS.AATTRIBUTES(AP).snapshotEnabled=_THIS.snapshotEnabled
Elsif _THIS.snapshotEnabled=1
 Local Instance PTMP Using C_ATTRIBUTES
 #Trick to trigger snapshot changes :
 [L]PTMP      =  _THIS.AATTRIBUTES(AP)
 _THIS.AATTRIBUTES(AP)= null
 _THIS.AATTRIBUTES(AP)= [L]PTMP
Endif

Local Instance PATTRIBUTES Using C_ATTRIBUTES : PATTRIBUTES=_THIS.AATTRIBUTES(AP)
Gosub _AGETATTTYP

If FCOD
 PATTRIBUTES.AFATT = setBit(PATTRIBUTES.AFATT , FCOD , 1)
 If _THIS.snapshotEnabled=1
  #If syssnapshot enabled then flag the attribute as 'changed'
  PATTRIBUTES.AFSNA = setBit(PATTRIBUTES.AFSNA, FCOD,1)
 Endif
 If [L]_OPT="true"
  PATTRIBUTES.AFVAL = setBit( PATTRIBUTES.AFVAL,FCOD,1)
 Else
  PATTRIBUTES.AFVAL = setBit( PATTRIBUTES.AFVAL,FCOD,0)
 Endif
Elsif LCOD
 PATTRIBUTES.ALATT = setBit(PATTRIBUTES.ALATT , LCOD , 1)
 If _THIS.snapshotEnabled=1
  #If syssnapshot enabled then flag the attribute as 'changed'
  PATTRIBUTES.ALSNA =  setBit(PATTRIBUTES.ALSNA, LCOD,1)
 Endif
 PATTRIBUTES.ALVAL(LCOD) = val([L]_OPT)
Elsif SCOD
 PATTRIBUTES.ASATT = setBit(PATTRIBUTES.ASATT , SCOD , 1)
 If _THIS.snapshotEnabled=1
  #If syssnapshot enabled then flag the attribute as 'changed'
  PATTRIBUTES.ASSNA =  setBit(PATTRIBUTES.ASSNA, SCOD,1)
 Endif
 If !(PATTRIBUTES.RES(SCOD)<>null & PATTRIBUTES.RES(SCOD).CHR=[L]_OPT)
  If PATTRIBUTES.RES(SCOD)<>null
   FreeInstance PATTRIBUTES.RES(SCOD)
   PATTRIBUTES.RES(SCOD) = null
  Endif
  If len(_OPT)
   If len(_OPT)<=8
    PATTRIBUTES.RES(SCOD) = NewInstance C_ACHR8 AllocGroup  _THIS
   Elsif len(_OPT)<=32
    PATTRIBUTES.RES(SCOD) = NewInstance C_ACHR32 AllocGroup  _THIS
   Elsif len(_OPT)<=128
    PATTRIBUTES.RES(SCOD) = NewInstance C_ACHR128 AllocGroup  _THIS
   Elsif len(_OPT)<=250
    PATTRIBUTES.RES(SCOD) = NewInstance C_ACHR250 AllocGroup  _THIS
   Else
    PATTRIBUTES.RES(SCOD) = NewInstance C_ACHRCLB AllocGroup  _THIS
   Endif
   PATTRIBUTES.RES(SCOD).CHR = [L]_OPT
  Endif
 Endif
Else
 If ACOD and _THIS.snapshotEnabled=1
   Local Instance PATT Using C_ATTRIBUTE
   #Trick to make snapshots work
   [L]PATT               = PATTRIBUTES.ATT(ACOD)
   PATTRIBUTES.ATT(ACOD) = null
   PATTRIBUTES.ATT(ACOD)  = [L]PATT
  Elsif !ACOD
   ACOD = maxtab(PATTRIBUTES.ATT) + 1
   PATTRIBUTES.ATT(ACOD) = NewInstance C_ATTRIBUTE AllocGroup  _THIS
  Endif
  PATTRIBUTES.ATT(ACOD).COD = [L]_COD
  PATTRIBUTES.ATT(ACOD).ATT = [L]_OPT
Endif
End

#**
#* _AGETPROATTRIBUTES
#*!
$_AGETPROATTRIBUTES
Local Integer FCOD,SCOD,LCOD,ACOD
PATTRIBUTES = null
AP = find([L]_PRO,_THIS.AATTRIBUTES(1..maxtab(_THIS.AATTRIBUTES)).PRO )
If AP
 PATTRIBUTES = _THIS.AATTRIBUTES(AP)
Endif
Return
#**
#* AGETPROATTRIBUTES
#*
#* @param _THIS
#* @param _PRO
#* @param _ATTRIBUTES
#*!
Funprog AGETPROATTRIBUTES(_THIS,_PRO,PATTRIBUTES)
Variable Instance _THIS Using OBJECT
Value Char _PRO
Variable Instance PATTRIBUTES Using C_ATTRIBUTES
Local Integer AP

Gosub _AGETPROATTRIBUTES
End (PATTRIBUTES <> null)

#**
#* AGETPROATTRIBUTES
#*
#* @param _THIS
#* @param _PRO
#* @param _ATTRIBUTES
#*!
Funprog AGETPROATTRIBUTESEX(_THIS,_PRO,_COUNT,_COD,_OPT,_TYP)
Variable Instance _THIS Using OBJECT
Value Char _PRO
Variable Integer _COUNT
Variable Char _COD()(1..)
Variable Char _OPT()(1..)
Variable Integer _TYP(1..)
Raz _COUNT,_COD,_OPT,_TYP

Local  Instance PATTRIBUTES Using C_ATTRIBUTES
Local Integer AP


Gosub _AGETPROATTRIBUTES
If PATTRIBUTES <> null
 If dim([V]CST_ATTFCODMAX) <= 0 :Gosub _GETATTNAMES :Endif
 If PATTRIBUTES.AFATT
  Local Char ATTBOOL(10)(0..1)
  ATTBOOL(0) = "false"
  ATTBOOL(1) = "true"
  For FCOD =1 To [V]CST_ATTFCODMAX
   If getBit(PATTRIBUTES.AFATT,FCOD)
    _COUNT += 1
     [L]_COD(_COUNT) = [V]CST_ATT(FCOD)
     [L]_OPT(_COUNT)   = ATTBOOL(getBit(PATTRIBUTES.AFVAL,FCOD))
     [L]_TYP(_COUNT)  =  5 :# word
    Endif
  Next FCOD
 Endif

 If PATTRIBUTES.ALATT
  For LCOD =1 To [V]CST_ATTLCODMAX
   If getBit(PATTRIBUTES.ALATT,LCOD)
    _COUNT += 1
    [L]_COD(_COUNT) = [V]CST_ATT(LCOD-1+[V]CST_ATTLCODMIN)
    [L]_OPT(_COUNT)   =  num$(PATTRIBUTES.ALVAL(LCOD))
    [L]_TYP(_COUNT)  =  4 :# number
   Endif
  Next LCOD
 Endif

 If PATTRIBUTES.ASATT
  For SCOD =1 To [V]CST_ATTSCODMAX
    If getBit(PATTRIBUTES.ALATT,SCOD)
     _COUNT += 1
     [L]_COD(_COUNT) = [V]CST_ATT(SCOD-1+[V]CST_ATTSCODMIN)
     If PATTRIBUTES.RES(SCOD) <> null
       [L]_OPT(_COUNT)  = PATTRIBUTES.RES(SCOD).CHR
     Else
      [L]_OPT(_COUNT)  = ""
     Endif
     [L]_TYP(_COUNT)  =   3 :# string
    Endif
  Next SCOD
 Endif

 For SCOD =1 To maxtab(PATTRIBUTES.ATT)
   _COUNT += 1
   [L]_COD(_COUNT) = PATTRIBUTES.ATT(SCOD).COD
   [L]_OPT(_COUNT)  = PATTRIBUTES.ATT(SCOD).ATT
   [L]_TYP(_COUNT)  =   3 :# string
 Next SCOD
Endif
End (PATTRIBUTES <> null)

Funprog AGETPROATTRIBUTE(PATTRIBUTES,_COD,OPT,_TYP)
Variable Instance PATTRIBUTES Using C_ATTRIBUTES
Value Char _COD
Variable Char OPT
Variable Integer _TYP

_TYP=0
OPT=""
Gosub __AGETATTRIBUTE
End USED

Funprog _AGETATTRIBUTE(_THIS,_PRO,_COD)
Variable Instance _THIS Using OBJECT
Value Char _PRO,_COD

Local Char OPT(250) : OPT=""
Local Integer _TYP
Local Instance PATTRIBUTES Using C_ATTRIBUTES
Gosub _AGETPROATTRIBUTES
Gosub __AGETATTRIBUTE
End OPT

$__AGETATTRIBUTE
Local Integer USED
Local Integer  AI,AP

Local Char ATTBOOL(10)(0..1)
ATTBOOL(0) = "false"
ATTBOOL(1) = "true"

If PATTRIBUTES <> null
 Gosub _AGETATTTYP
 If FCOD
  If getBit(PATTRIBUTES.AFATT,FCOD)
   [L]OPT = ATTBOOL(getBit(PATTRIBUTES.AFVAL,FCOD))
   [L]USED=1
   [L]_TYP =  5 :# word
  Endif
 Elsif LCOD
  If getBit(PATTRIBUTES.ALATT,LCOD)
   [L]OPT = num$(PATTRIBUTES.ALVAL(LCOD))
   [L]USED=1
   [L]_TYP =  4 :# number
  Endif
 Elsif SCOD
  If getBit(PATTRIBUTES.ASATT,SCOD)
   [L]USED=1
   [L]_TYP =  3 :# string
   If PATTRIBUTES.RES(SCOD) <> null
    [L]OPT = PATTRIBUTES.RES(SCOD).CHR
  Else
    [L]OPT = ""
  Endif
  Endif
 Elsif ACOD
  [L]OPT = PATTRIBUTES.ATT(ACOD).ATT
  [L]USED=1
  [L]_TYP =  3 :# string
 Endif
Endif
Return

### Update alls atatus from all parents
Subprog _ASTATUSPARENT(AINSTANCE)
Variable Instance AINSTANCE Using OBJECT
Local Char _AFAT(250)
Local Integer WISREADONLY
WISREADONLY=AINSTANCE.isReadonly
AINSTANCE.isReadonly = 0
[L]_AFAT = "AINSTANCE"
While evalue([L]_AFAT)<>null
 If evalue([L]_AFAT+".ASTALIN")=[V]CST_ALL
  Assign  [L]_AFAT+".ASTALIN" With [V]CST_AUPD
 Endif
 [L]_AFAT += ".APARENT"
Wend
AINSTANCE.isReadonly=WISREADONLY
End

# Chech if the class ATX has one text *> for method mandatory
Funprog _HASFIELDATX(_ATX,_CURPRO)
Variable Instance _ATX(1..) Using C_ATXTSUP
Value Char _CURPRO

Local Integer OK , I

For I=1 To maxtab(_ATX)
 If _ATX(I).PRO=_CURPRO
  OK = 1
  Break
 Endif
Next
End OK

# funprog to get a vlaue of APARAMURL class
Funprog _AGETVALPARAMURL(AINSTANCE,CODPAR)
Variable Instance AINSTANCE Using OBJECT
Value Char CODPAR
Local Integer I
Local Clbfile WVALUE
If AINSTANCE<>null and maxtab(AINSTANCE._APARAMURL)>0
 For I=1 To maxtab(AINSTANCE._APARAMURL)
  If AINSTANCE._APARAMURL(I)<>null and AINSTANCE._APARAMURL(I).PAR=[L]CODPAR
   WVALUE = AINSTANCE._APARAMURL(I).VPR
   Break
  Endif
 Next
Endif
End WVALUE

