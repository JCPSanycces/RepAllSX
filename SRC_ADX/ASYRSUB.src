Funprog SYR_NULL
End "null"

#--------------------------------------#
# Transcle Crud : ACLE-->AACLE(x)
#--------------------------------------#

$TRANSCLE
Local Integer I,J
Local Char AACLE(250)(1..16)
I=instr(1,ACLE,"~")
While I>0
 J+=1
 AACLE(J) = left$(ACLE,I-1)
 ACLE = right$(ACLE,J+1)
 I=instr(1,ACLE,"~")
Wend
J+=1
AACLE(J)=ACLE
Return


#--------------------------------------#
# managment of links
#--------------------------------------#
$ASETLINK
Local Integer _CPTLNK
Local Integer FOUND
For _CPTLNK=1 To maxtab(this._ASTADETLNK)
 If this._ASTADETLNK(_CPTLNK)<>null & this._ASTADETLNK(_CPTLNK).ORICODLNK=num$([L]_AFFLNK)+'/'+[L]_CODLNK
  this._ASTADETLNK(_CPTLNK).ISDISABLED=[L]_ISDISABLED
  FOUND=1
  Break
 Endif
Next
If !FOUND & pat([L]_CODLNK,"*_LIG*")>0
 For _CPTLNK=1 To maxtab(this._ASTADETLNK)
  If this._ASTADETLNK(_CPTLNK)<>null & this._ASTADETLNK(_CPTLNK).CODLNK=[L]_CODLNK
   this._ASTADETLNK(_CPTLNK).ISDISABLED=[L]_ISDISABLED
   FOUND=1
   Break
  Endif
 Next
Endif
If !FOUND & left$([L]_CODLNK,1)="$"
 For _CPTLNK=1 To maxtab(this._ASTADETLNK)
  If this._ASTADETLNK(_CPTLNK)<>null & this._ASTADETLNK(_CPTLNK).CODLNK=[L]_CODLNK
   this._ASTADETLNK(_CPTLNK).ISDISABLED=[L]_ISDISABLED
   FOUND=1
   Break
  Endif
 Next
Endif
Return

#--------------------------------------------------------------------------------------------#
# Etiquette appelée depuis les traitements classes *.stc
#--------------------------------------------------------------------------------------------#
#  AMP CURPRO = "CODPAR" AMSKPAR_CSTD
#  ATZ CURPRO = "AMP.CODPAR" ATABZON_CSTD
#  ATB CURPRO = "ATZ.AMP.CODPAR" ATABLE_CSTD
#  REP CURPRO = "ATB.ATZ.AMP.CODPAR" ATABLE_RSTD


$ACTION
If dim(this.AINF.NBTRT)>0
 Local Integer AI , ATRT,AISPRO,AISACTION
 Local Char SAVCURPRO(GLONAVB) : [L]SAVCURPRO = [L]CURPRO
 [L]AISPRO = ([L]CURPRO<>"")
 If dim([L]AMETHOD)<0 : Local Char AMETHOD(50) : Endif
 For AI=1 To this.AINF.NBTRT
  If this.AINF.TRT(AI)<>""
   If [L]AISPRO
    #[L]CURPRO = [L]SAVCURPRO
    If [L]SAVCURPRO<>"" & this.AINF.PTH(AI)<>""
     [L]CURPRO = this.AINF.PTH(AI)+"."+[L]SAVCURPRO
    Else
     [L]CURPRO = this.AINF.PTH(AI)+[L]SAVCURPRO
    Endif
   Else
    [L]AISACTION=[V]CST_AYES
    [L]CURPTH = this.AINF.PTH(AI)
   Endif
   Gosub MET_PRO_ACTION
   If dim([L]ASTATUS)>0 & [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  Endif
 Next AI
Endif
Return

$MET_PRO_ACTION
If left$(this.AINF.TRT(AI),5) ="WMCM_": # func ACLAVALLEC.GETPREFIXTRTMAP pour gagner un call pas de func
 If find(ACTION,"PROPAGATE","ADDLINE_AFTER")>0
  If [L]AISPRO
   Gosub PROPERTIES From =this.AINF.TRT(AI)
  Else
   If find(ACTION,"ADDLINE_BEFORE","ADELLINE_BEFORE")>0 & dim([L]ACOLLECTION)>0 & [L]ACOLLECTION<>""
    If [L]CURPTH<>""
     [L]CURPTH = [L]CURPTH+"."+[L]ACOLLECTION
    Else
     [L]CURPTH = [L]ACOLLECTION
    Endif
   Endif
   Gosub METHODS From =this.AINF.TRT(AI)
   If dim([L]AISACTION)>0 and [L]AISACTION=[V]CST_AYES
    Gosub EVENTS From =this.AINF.TRT(AI)
   Elsif dim([L]AISMET)>0 and [L]AISMET=[V]CST_AYES
    #Gosub METHODS From =this.AINF.TRT(AI)
   Else
    Gosub OPERATIONS From =this.AINF.TRT(AI)
   Endif
  Endif
  LogicClose File
  If dim([L]ASTATUS)>0 & [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Else
 If [L]AISPRO
  Gosub PROPERTIES From =this.AINF.TRT(AI)
 Else
  If find(ACTION,"ADDLINE_BEFORE","ADELLINE_BEFORE")>0 & dim([L]ACOLLECTION)>0 & [L]ACOLLECTION<>""
   If [L]CURPTH<>""
    [L]CURPTH = [L]CURPTH+"."+[L]ACOLLECTION
   Else
    [L]CURPTH = [L]ACOLLECTION
   Endif
  Endif
  Gosub METHODS From =this.AINF.TRT(AI)
  If dim([L]AISACTION)>0 and [L]AISACTION=[V]CST_AYES
   Gosub EVENTS From =this.AINF.TRT(AI)
  Elsif dim([L]AISMET)>0 and [L]AISMET=[V]CST_AYES
   #Gosub METHODS From =this.AINF.TRT(AI)
  Else
   Gosub OPERATIONS From =this.AINF.TRT(AI)
  Endif
 Endif
 LogicClose File
 If dim([L]ASTATUS)>0 & [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

$ACTION_MET
If dim(this.AINF.NBTRT)>0
 Local Integer AI , ATRT,AISPRO
 Local Char SAVCURPRO(GLONAVB) : [L]SAVCURPRO = [L]CURPRO
 [L]AISPRO = ([L]CURPRO<>"")
 For AI=1 To this.AINF.NBTRT
  If this.AINF.TRT(AI)<>""
   If [L]AISPRO
    If [L]SAVCURPRO<>"" & this.AINF.PTH(AI)<>""
     [L]CURPRO = this.AINF.PTH(AI)+"."+[L]SAVCURPRO
    Else
     [L]CURPRO = this.AINF.PTH(AI)+[L]SAVCURPRO
    Endif
   Else
    [L]CURPTH = this.AINF.PTH(AI)
   Endif
   If CURPTH="" & left$(this.AINF.TRT(AI),5)<>"WMCM_"
    Gosub MET_PRO_ACTION
    If dim([L]ASTATUS)>0 & [L]ASTATUS>=[V]CST_AERROR : Break : Endif
   Endif
  Endif
 Next AI
Endif
Return

#----------------------------------------------------------------------#
# Optimisation mémoire des champs alpha
#----------------------------------------------------------------------#

Funprog AGETCHR(CHR)
Variable Instance CHR Using C_ACHR
Local Clbfile CLOB
CLOB = ""
If CHR<>null
 If    CHR.ACHR8<>null   : CLOB = CHR.ACHR8.CHR
 Elsif CHR.ACHR32<>null  : CLOB = CHR.ACHR32.CHR
 Elsif CHR.ACHR128<>null : CLOB = CHR.ACHR128.CHR
 Elsif CHR.ACHR250<>null : CLOB = CHR.ACHR250.CHR
 Elsif CHR.ACHRCLB<>null : CLOB = CHR.ACHRCLB.CHR
 Endif
Endif
End CLOB

