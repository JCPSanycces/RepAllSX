Funprog CODCMP(NUM)
Value Integer NUM
Local Char CMP(20)
Case NUM
 When 1  : CMP = '$create'
 When 2  : CMP = '$details'
 When 3  : CMP = '$edit'
 When 4  : CMP = '$delete'
 When 5  : CMP = '$query'
 When 6  : CMP = '$print'
 When 7  : CMP = '$excel'
 When 8  : CMP = '$execute'
 When 9  : CMP = '$lookup'
 When 10 : CMP = '$summary'
 When 11 : CMP = '$duplicate'
 When 12 : CMP = '$wordreport'
 When 13 : CMP = '$wordmailmerge'
Endcase
End CMP

