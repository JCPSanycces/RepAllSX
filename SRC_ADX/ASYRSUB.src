#---------------------------------------------#
# Gravité erreur en clair (Menu local 7878)
#---------------------------------------------#
# 1 Info
# 2 Successfull
# 3 Warning
# 4 Error
# 5 Fatal error
#---------------------------#

Funprog ERROR(STA)
Value Integer STA
Local Char    ERROR(10)
Case STA
 When CST_AOK      : ERROR = ""
 When CST_ASUCCESS : ERROR = "success"
 When CST_AINFO    : ERROR = "info"
 When CST_AWARNING : ERROR = "warning"
 When CST_AFATAL   : ERROR = "fatal"
 When Default      : ERROR = "error"
Endcase
End ERROR

#--------------------------#
# Formats spéciaux
#--------------------------#

Funprog FMTPRO(NUM)
Value Integer NUM
Local Char FMT(30)
If NUM<=1 & NUM<30
 FMT = ""
Else
 Case NUM
  When 2       : FMT = "$email"
  When 3       : FMT = "$phone"
  When 6       : FMT = "TT"     : # Time format hh:mm:ss
  When Default : FMT = mess(NUM,7880,1)
 Endcase
Endif
End FMT

#-----------------------------------------#
# Conversion type interne X3 (paramètres)
#-----------------------------------------#
#  X3 (30 or 10030)  Syracuse (7875)
#-----------------------------------------#
#  1 Menu local    1 Boolean
#  2 Entier court  2 Integer
#  3 Entien long   3 Decimal
#  4 Décimal       4 Real
#  5 Flottant      5 Date
#  6 Double        6 Time
#  7 Alpha         7 String
#  8 Date          8 Text
#  9 Blob          9 Binary data
# 10 Clob         10 Enumeration
# 11 Uuid         11 Datetime
# 12 Datetime
# 13 Instance
#-----------------------------------------#

Funprog TYPE_DATA_X3_TO_SYRACUSE(X3,MNL,CNTTYP)
Value Integer X3 , MNL
Value Char CNTTYP
Local Integer SYR
Case X3
 When CST_ATYPTINYINT  : If MNL=1 : SYR = 1 : Else : SYR = 10 : Endif
 When CST_ATYPSHORTINT : SYR = 2
 When CST_ATYPINTEGER  : SYR = 2
 When CST_ATYPDECIMAL  : SYR = 3
 When CST_ATYPFLOAT    : SYR = 4
 When CST_ATYPDOUBLE   : SYR = 4
 When CST_ATYPCHAR     : If CNTTYP="application/x-time"
                          SYR = 6
                         Else
                          SYR = 7
                         Endif
 When CST_ATYPDATE     : SYR = 5
 When CST_ATYPBLOB     : SYR = 9
 When CST_ATYPCLOB     : SYR = 8
 When CST_ATYPUUID     : SYR = 7
 When CST_ATYPDATETIME : SYR = 11
 When CST_ATYPINSTANCE : SYR = 0
 When Default          : SYR = 0
Endcase
End SYR

#-----------------------------------------#
# Conversion Menu local 33
#-----------------------------------------#
# X3 (33) ->  Syracuse (7875)
#-----------------------------------------#

Funprog TYPE_DATA_X3_33_TO_SYRACUSE(X3)
Value Integer X3
Local Integer SYR
Case X3
 When 1       : SYR = 7
 When 2,3,4   : SYR = 2
 When 5       : SYR = 10
 When 6       : SYR = 8
 When 7       : SYR = 9
 When 8       : SYR = 0
 When 9       : SYR = 7
 When 10      : SYR = 8
 When 11      : SYR = 11
 When Default : SYR = 0
Endcase
End SYR

