AA += 1 : CA(AA) = "R" : NA(AA) = "$isReadOnly"  : # Affiché
AA += 1 : CA(AA) = "G" : NA(AA) = "$isDisabled"  : # Grisé
AA += 1 : CA(AA) = "S" : NA(AA) = "$style"       : # Style
AA += 1 : CA(AA) = "L" : NA(AA) = "$label"       : # Intitulé d'un champ
AA += 1 : CA(AA) = "r" : NA(AA) = "$isRequested" : # Activé
AA += 1 : CA(AA) = "E" : NA(AA) = "$isEditMode"  : # Modifiable
AA += 1 : CA(AA) = "d" : NA(AA) = "$isDelta"     : # Mode delta
AA += 1 : CA(AA) = "s" : NA(AA) = "$isDeleted"   : # Ligne supprimée
AA += 1 : CA(AA) = "i" : NA(AA) = "$index"       : # No de la ligne (0..) gérée (celle qui est supprimée, insérée à partir de, ...)
AA += 1 : CA(AA) = "f" : NA(AA) = "$x3Format"    : # Format x3 pour l'affichage
AA += 1 : CA(AA) = "e" : NA(AA) = "$isExcluded"  : # Champs exclus de l'affichage ne devant jamais être affiché
Return

