#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# BRBAN 25/11/2014 - 97101
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

# Table opening
Gosub OUVRE

# Variable declaration
Gosub DECLARE

# Initialisation of CRITERE
[L]CRITERE(0) = '1=1'
[L]CRITERE(1) = '1=1'

For I=1 To NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
    Case [L]PARAM
      When "X3ETA"          : [L]ETAT     = [L]VALEUR
      When "__REQUETE"      : [L]NUMREQ   = val([L]VALEUR)
      # BRBAN 25/11/2014 - 97101
      When "sitedeb"        : [L]CRITERE(0) -= "& SALFCY>='"+[L]VALEUR+"'"
      When "sitefin"        : [L]CRITERE(0) -= "& SALFCY<='"+[L]VALEUR+"'"
      When "clientdeb"      : [L]CRITERE(0) -= "& CONBPC>='"+[L]VALEUR+"'"
      When "clientfin"      : [L]CRITERE(0) -= "& CONBPC<='"+[L]VALEUR+"'"
      When "referencedeb"   : [L]CRITERE(0) -= "& CONNUM>='"+[L]VALEUR+"'"
      When "referencefin"   : [L]CRITERE(0) -= "& CONNUM<='"+[L]VALEUR+"'"
      When "typecontratdeb" : [L]CRITERE(0) -= "& CONCAT>="+num$([L]VALEUR)
      When "typecontratfin" : [L]CRITERE(0) -= "& CONCAT<="+num$([L]VALEUR)
      # Issue 110704
      # Issue 110704 - 2015-12-18 by RICAR : Updating the parameters
      When "numedt"         : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
      When "seqedt"         : [L]PARAMETRE(I) = "seqedt=0"
      When "usr"            : [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"           : [L]PARAMETRE(I) = "etat="+[L]ETAT
      # End issue 110704
    Endcase
  Endif
Next

# Issue 110704
# Issue 110704 - 2015-12-18 by RICAR : Building the code to insert data in tables
Call DEBTRANS From GLOCK
Trbegin [ARM], [TCRPT]

Raz [F:ARM] #Do not move this to ALIM_ARM

For [F:CON]CON0 Where evalue([L]CRITERE(0))
  Gosub ALIM_ARM
  If [L]CKPO = 1
    Gosub ALIM_TMPCRPT
  Endif
  If GOK < 1 : Break : Endif
Next

If GOK<1  Rollback  Else  Commit : Endif
# End issue 110704

End
#########################################################################
$OUVRE
# Issue 110704
# Issue 110704 - 2015-12-18 by RICAR : Updating the parameters
Local File AREPORTM   [ARM]
Local File TMPCRPT    [TCRPT]
Local File CONTSERV   [CON]

Local Integer CKPO : [L]CKPO = 0
# End issue 110704
Return
#########################################################################
$DECLARE

Local Char    CRITERE(255)(0..1), PARAM(30) , VALEUR(30) , ETAT(15)
Local Integer NUMREQ

If func AFNC.ACTIV("KPO")
  [L]CKPO = 1
Endif

Return
#########################################################################
#########################################################################
$ALIM_ARM

[F:ARM]CLEA1   = [F:CON]CONNUM
[F:ARM]CREDAT  = date$
[F:ARM]NUMLIG += 1
[F:ARM]NUMREQ  = [L]NUMREQ
[F:ARM]RPTCOD  = [F:ARP]RPTCOD
[F:ARM]USR     = GUSER

Write [F:ARM]
If fstat : GOK=0 : Call FSTA("ARM") From GLOCK : Endif

Return
#########################################################################
#########################################################################
$ALIM_TMPCRPT

Raz [F:TCRPT]

[F:TCRPT] = [F:ARM]
[F:TCRPT]VCRNUM = [F:CON]CONNUM

Write [F:TCRPT]
If fstat : GOK=0 : Call FSTA("TCRPT") From GLOCK : Endif

Return
#########################################################################
#########################################################################

