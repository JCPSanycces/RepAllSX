##
##   Gestion du masque REPRISEAE
##
################################################################################
#    Création
#    GLE - 07.07.2010
#
################################################################################
#    Modification
#
#    XXX - XX.XX.XXXX  FQXXXXX : XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#    CBO - 05.10.2015  FQ110966 : Erreur accès fichier sur serveur
#    CBO - 29.04.2014  FQ69690 : Objet FAM
################################################################################

$ACTION
  Case ACTION
    When "OUVRE" : Gosub OUVRE
    When "DEBUT" : Gosub DEBUT
    When "OK"    : Gosub OK
  Endcase
Return

$OUVRE
Return

$DEBUT
  If GBATCH
    [M:RAE]TYPFAS=2
    [M:RAE]TYPLOF=2
    If GPHY = G_OUI : [M:RAE]TYPPHY=2 : Endif
  Endif

  [M:RAE]ICOFAS = ""
  [M:RAE]ICOLOF = ""
  If GPHY = G_OUI : [M:RAE]ICOPHY="" : Endif

  # Pour afficher les valeurs par défaut
  Affzo [M:RAE]
Return

$OK
  Local Char     MODELE(12)
  Local Integer  IMPSTA
  Local Char     MACHINE(12)
  Local Char     NOMREP(GDIMFIC), BASENOMFIC(GDIMFIC), NOMFIC(GDIMFIC)
  Local Char     REPERT(GDIMFIC)
  Local Char     MESSAGE(80)
  Local Integer  IMPSTA
  Local Shortint TYPEXP

  If !clalev([F:AOE])  : Local File AOBJEXT    [AOE]  : Endif
  If !clalev([F:AOD])  : Local File AOBJEXTD   [AOD]  : Endif
  If !clalev([F:ATB_]) : Local File ATABLE     [ATB_] : Endif
  If !clalev([F:AOB_]) : Local File AOBJET     [AOB_] : Endif

  If !clalev([M:AOE0]) : Local Mask AOE0       [AOE0] : Endif
  If !clalev([M:AOE1]) : Local Mask AOE1       [AOE1] : Endif
  If !clalev([M:AOE2]) : Local Mask AOE2       [AOE2] : Endif
  If !clalev([M:IEX])  : Local Mask IMPTEST    [IEX]  : Endif
  If !clalev([M:IMP2]) : Local Mask IMPOBJ2    [IMP2] : Endif

  # Ouverture de la trace
  If !GSERVEUR Then
    Call OUVRE_TRACE(mess(1,GML_MSGMIS,1)) From LECFIC
  Endif

  Gosub ENTETE_TRACE

  # Import des biens
  If [M:RAE]FLGFAS = G_OUI
    [M:RAE]ICOFAS = "128" : Affzo [M:RAE]ICOFAS
    [L]MODELE     = "FASAE"
    [L]TYPEXP     = [M:RAE]TYPFAS
    If [M:RAE]TYPFAS = 1
      [L]BASENOMFIC = "AEX3_FAS.csv"
    Else
      [L]BASENOMFIC = [M:RAE]PATHFAS
    Endif
    Raz [M:IMP2] # FQ110966
    [M:IMP2]NOMIMP = [M:RAE]FULLPATHFAS # FQ110966
    Gosub IMPORT
    [M:RAE]ICOFAS = "" : Affzo [M:RAE]ICOFAS
  Endif

  # Import des dépenses
  If [M:RAE]FLGLOF = G_OUI
    [M:RAE]ICOLOF = "128" : Affzo [M:RAE]ICOLOF
    [L]MODELE     = "LOFAE"
    [L]TYPEXP     = [M:RAE]TYPLOF
    If [M:RAE]TYPLOF = 1
      [L]BASENOMFIC = "AEX3_LOF.csv"
    Else
      [L]BASENOMFIC = [M:RAE]PATHLOF
    Endif
    Raz [M:IMP2] # FQ110966
    [M:IMP2]NOMIMP = [M:RAE]FULLPATHLOF # FQ110966
    Gosub IMPORT
    [M:RAE]ICOLOF = "" : Affzo [M:RAE]ICOLOF
  Endif

  # Import des éléments physiques Don't Work
  If GPHY = G_OUI
    If [M:RAE]FLGPHY = G_OUI
      [M:RAE]ICOPHY = "128" : Affzo [M:RAE]ICOPHY
      [L]MODELE     = "PHYAE"
      [L]TYPEXP     = [M:RAE]TYPPHY
      If [M:RAE]TYPPHY = 1
        [L]BASENOMFIC = "AEX3_PHY.csv"
      Else
        [L]BASENOMFIC = [M:RAE]PATHPHY
      Endif
      Raz [M:IMP2] # FQ110966
      [M:IMP2]NOMIMP = [M:RAE]FULLPATHPHY # FQ110966
      Gosub IMPORT
      [M:RAE]ICOPHY = "" : Affzo [M:RAE]ICOPHY
    Endif
  Endif

  # Fermeture de la trace
  If !GSERVEUR Then
    Call LEC_TRACE From LECFIC
  Endif
Return

###############################################################
$IMPORT
#On construit le nom du fichier
  Gosub GETNOMFIC

#  Raz [M:IMP2] FQ110966
  Raz [M:AOE0], [M:AOE1], [M:AOE2]
  Call CHARGE_MODELE([L]MODELE,IMPSTA) From GIMPOBJ
  If IMPSTA
    MESSAGE = GMESSAGE
    Gosub ERR_EXEC
    Return
  Endif
  If [F:AOE]OBJ<>""
    Read [AOB_]ABREV = [F:AOE]OBJ
    If fstat : IMPSTA = 18 : Return : Endif
  Endif
  [M:IMP2]MODIMP = [L]MODELE
#  [M:IMP2]NOMIMP = NOMFIC # FQ110966
  [M:IMP2]TYPEXP = [L]TYPEXP
  Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ
  IMPSTA = [M:IMP2]STAT
  If IMPSTA : Gosub ERR_EXEC : Endif
  If GOK<1 : IMPSTA = 11 : Gosub ERR_EXEC : Endif
  Raz mkstat
  Raz IMPSTA
  GOK=1
  OK=1
  Raz GERR
  Raz GMESSAGE
Return


##########################################################################
$GETNOMFIC
#On doit avoir NOMREP et BASENOMFIC

  NOMFIC=""

  Call MACHINE(NOMREP,MACHINE,REPERT) From ORDSYS
  Call SETFIC(REPERT,BASENOMFIC,MACHINE,NOMFIC) From SUBEXPOBJ
Return

###############################################################
$ERR_EXEC
  Call ERR_IMPORT(IMPSTA,MESSAGE) From GIMPOBJ
  Call ECR_TRACE(mess(6,123,1)-" : "-MESSAGE,1) From GESECRAN
Return

#################################################
$ENTETE_TRACE
  Call ECR_TRACE(mess(2,GML_MSGMIS,1),0) From GESECRAN                                                                  : # Reprise Abel Entreprise
  Call ECR_TRACE("  "+mess(47,GML_MSGLOF,1)+space$(25-len(mess(47,GML_MSGLOF,1)))+":"-mess([M:RAE]FLGBPR,1,1),0)   From GESECRAN   : # Fournisseur
  Call ECR_TRACE("  "+mess(48,GML_MSGLOF,1)+space$(25-len(mess(48,GML_MSGLOF,1)))+":"-mess([M:RAE]FLGITM,1,1),0)   From GESECRAN   : # Article
  Call ECR_TRACE("  "+mess(3,GML_MSGMIS,1)+space$(25-len(mess(3,GML_MSGMIS,1)))+":"-mess([M:RAE]FLGCCE,1,1),0)     From GESECRAN   : # Section analytique
  Call ECR_TRACE("  "+mess(122,GML_MSGINV,1)+space$(25-len(mess(122,GML_MSGINV,1)))+":"-mess([M:RAE]FLGLOC,1,1),0) From GESECRAN   : # Localisation
  Call ECR_TRACE("  "+mess(216,GML_MSGFAS,1)+space$(25-len(mess(216,GML_MSGFAS,1)))+":"-mess([M:RAE]FLGACC,1,1),0) From GESECRAN   : # Compte comptable
  Call ECR_TRACE("  "+mess(215,GML_MSGFAS,1)+space$(25-len(mess(215,GML_MSGFAS,1)))+":"-mess([M:RAE]FLGGAC,1,1),0) From GESECRAN   : # Code comptable
  Call ECR_TRACE("  "+mess(336,GML_MSGFAS,1)+space$(25-len(mess(336,GML_MSGFAS,1)))+":"-mess([M:RAE]FLGSAC,1,1),0) From GESECRAN   : # Secteur d'activité
  Call ECR_TRACE("  "+mess(214,GML_MSGFAS,1)+space$(25-len(mess(214,GML_MSGFAS,1)))+":"-mess([M:RAE]FLGFAM,1,1),0) From GESECRAN   : # Famille

  Call ECR_TRACE("",0) From GESECRAN

  Call ECR_TRACE(mess(4,GML_MSGMIS,1)-":"-mess([M:RAE]FLGFAS,1,1),0) From GESECRAN : # Reprise des biens comptables
  If [M:RAE]TYPFAS = 2 : Call ECR_TRACE("  "+mess(4,95,1)-":"-[M:RAE]PATHFAS,0) From GESECRAN : Endif : # Fichier
  Call ECR_TRACE(mess(5,GML_MSGMIS,1)-":"-mess([M:RAE]FLGLOF,1,1),0) From GESECRAN : # Reprise des dépenses
  If [M:RAE]TYPLOF = 2 : Call ECR_TRACE("  "+mess(4,95,1)-":"-[M:RAE]PATHLOF,0) From GESECRAN : Endif : # Fichier
  If GPHY = G_OUI
    Call ECR_TRACE(mess(6,GML_MSGMIS,1)-":"-mess([M:RAE]FLGPHY,1,1),0) From GESECRAN : # Reprise des éléments physiques
    If [M:RAE]TYPPHY = 2 : Call ECR_TRACE("  "+mess(4,95,1)-":"-[M:RAE]PATHPHY,0) From GESECRAN : Endif : # Fichier
  Endif
Return
#################################################

Subprog AUDIT(PTYP)
Value  Char PTYP
  Case PTYP
    When "TD" : Gosub AUDIT_TD
  Endcase
End

# Tables diverses
$AUDIT_TD
  Local Integer  LISTAB(25), I
  Local Char     INTIT(30)
  Local Shortint TABUL : TABUL = 35

  If !clalev([ZADV]) : Local File ATABTAB [ZADV] : Endif
  If !clalev([ZFRF]) : Local File FREFLD  [ZFRF] : Endif

  Call TEXTE(26961, INTIT) From OBJDIV : # Texte "Audit"
  Call OUVRE_TRACE(INTIT-mess(2,26,1)) From LECFIC : # Audit Tables diverses
  Call ECR_TRACE(string$(len(mess(136,125,1)),"-")+"\"+mess(136,125,1)+"\"+string$(len(mess(136,125,1)),"-"),0) From GESECRAN

  # Bien comptable
  # --------------
  Call ECR_TRACE("\"+mess(182,GML_MSGFAS,1)+"\"+string$(len(mess(182,GML_MSGFAS,1)),"-"),0) From GESECRAN

  LISTAB(0)  = 613
  LISTAB(1)  = 614
  LISTAB(2)  = 615
  LISTAB(3)  = 616
  LISTAB(4)  = 511
  LISTAB(5)  = 515
  LISTAB(6)  = 516
  LISTAB(7)  = 519
  LISTAB(8)  = 534
  LISTAB(9)  = 535
  LISTAB(10) = 955
#  LISTAB(10) = 611

  For I = 0 To 10
    Read [ZADV]CODE = LISTAB(I)
    If fstat = 0
      Call LECTEXTRA(INTIT,"ATABTAB","LNGDES",num$([F:ZADV]NUMTAB),"") From ATEXTRA
      Call ECR_TRACE(mess(50,142,1)-num$([F:ZADV]NUMTAB)-INTIT+space$(TABUL-len(INTIT))+mess(81,124,1)-num$([F:ZADV]LNG),0) From GESECRAN
    Endif
  Next I

  Call AUDIT_TD_ZL(GVML_OMBIEN)

  # Dépense
  # -------
  Call ECR_TRACE("\"+mess(84,GML_MSGGRT,1)+"\"+string$(len(mess(84,GML_MSGGRT,1)),"-"),0) From GESECRAN

  Raz LISTAB

#  LISTAB(0) = 611
  LISTAB(1) = 614
  LISTAB(2) = 615
  LISTAB(3) = 616
  LISTAB(4) = 620

  For I = 1 To 4
    Read [ZADV]CODE = LISTAB(I)
    If fstat = 0
      Call LECTEXTRA(INTIT,"ATABTAB","LNGDES",num$([F:ZADV]NUMTAB),"") From ATEXTRA
      Call ECR_TRACE(mess(50,142,1)-num$([F:ZADV]NUMTAB)-INTIT+space$(TABUL-len(INTIT))+mess(81,124,1)-num$([F:ZADV]LNG),0) From GESECRAN
    Endif
  Next I

  Call AUDIT_TD_ZL(GVML_OMDEPEN)

  # Elément physique
  # ----------------
  Call ECR_TRACE("\"+mess(124,GML_MSGPHY,1)+"\"+string$(len(mess(124,GML_MSGPHY,1)),"-"),0) From GESECRAN
  Raz LISTAB

  LISTAB(0) = 537
  LISTAB(1) = 538

  For [ZADV]CODE Where find(NUMTAB,LISTAB)<>0
    Call LECTEXTRA(INTIT,"ATABTAB","LNGDES",num$([F:ZADV]NUMTAB),"") From ATEXTRA
    Call ECR_TRACE(mess(50,142,1)-num$([F:ZADV]NUMTAB)-INTIT+space$(TABUL-len(INTIT))+mess(81,124,1)-num$([F:ZADV]LNG),0) From GESECRAN
  Next

  Call AUDIT_TD_ZL(GVMLOMPHY)

  Close File [ZADV]

  Call LEC_TRACE() From LECFIC
Return

Subprog AUDIT_TD_ZL(POBJ)
Value Integer POBJ

  Local Char     INTIT(30)
  Local Integer  N_I
  Local Shortint TABUL : TABUL = 35

  For [ZFRF]FRF0 Where OBJ = POBJ
    Call TEXTE(33980, INTIT) From OBJDIV : # Texte "Zones libres"
    If [ZFRF]CPY=""
      Call ECR_TRACE("\"+INTIT-mess(36,GML_MSGFASPR,1),0) From GESECRAN
    Else
      Call ECR_TRACE("\"+INTIT-mess(143,GML_MSGFAS,1)-[ZFRF]CPY,0) From GESECRAN
    Endif
    For N_I = 0 To 9
      If [F:ZFRF]ALPREF(N_I) <> 0
        Read [ZADV]CODE=[F:ZFRF]ALPREF(N_I)
        Call LECTEXTRA(INTIT,"ATABTAB","LNGDES",num$([F:ZADV]NUMTAB),"") From ATEXTRA
        Call ECR_TRACE(mess(50,142,1)-num$([F:ZADV]NUMTAB)-INTIT+space$(TABUL-len(INTIT))+mess(81,124,1)-num$([F:ZADV]LNG),0) From GESECRAN
        If [F:ZADV]NUMTAB = 611
          Call ECR_TRACE("--> Miscellaneous table 611 doesn't exist more and must be changed", 0) From GESECRAN
        Endif
      Endif
    Next
  Next
End

#################################################
Subprog AM_FLGFAS(VALEUR)
Variable Integer VALEUR
  If VALEUR = G_OUI
    Actzo [M:RAE]TYPFAS,PATHFAS
  Else
    Diszo [M:RAE]TYPFAS,PATHFAS
  Endif
  Call ACTION_BLOCK (ACB_AFFZO, "REPRISEAE", "FLGFAS") From GLOBIENS
End

Subprog AM_FLGLOF(VALEUR)
Variable Integer VALEUR
  If VALEUR = G_OUI
    Actzo [M:RAE]TYPLOF,PATHLOF
  Else
    Diszo [M:RAE]TYPLOF,PATHLOF
  Endif
  Call ACTION_BLOCK (ACB_AFFZO, "REPRISEAE", "FLGLOF") From GLOBIENS
End

Subprog AM_FLGPHY(VALEUR)
Variable Integer VALEUR
  If VALEUR = G_OUI
    Actzo [M:RAE]TYPPHY,PATHPHY
  Else
    Diszo [M:RAE]TYPPHY,PATHPHY
  Endif
  Call ACTION_BLOCK (ACB_AFFZO, "REPRISEAE", "FLGPHY") From GLOBIENS
End

Subprog AM_TYPFAS(VALEUR)
Variable Integer VALEUR
  If VALEUR = G_OUI
    Actzo [M:RAE]PATHFAS
  Else
    Diszo [M:RAE]PATHFAS
  Endif
  Affzo [M:RAE]PATHFAS
End

Subprog AM_TYPLOF(VALEUR)
Variable Integer VALEUR
  If VALEUR = G_OUI
    Actzo [M:RAE]PATHLOF
  Else
    Diszo [M:RAE]PATHLOF
  Endif
  Affzo [M:RAE]PATHLOF
End

Subprog AM_TYPPHY(VALEUR)
Variable Integer VALEUR
  If VALEUR = G_OUI
    Actzo [M:RAE]PATHPHY
  Else
    Diszo [M:RAE]PATHPHY
  Endif
  Affzo [M:RAE]PATHPHY
End

Subprog AV_TYPFAS(VALEUR)
Variable Integer VALEUR
  If [M:RAE]FLGFAS=2
    Actzo [M:RAE]TYPFAS
  Else
    Diszo [M:RAE]TYPFAS
  Endif
End

Subprog AV_PATHFAS(VALEUR)
Variable Char    VALEUR()
  If [M:RAE]FLGFAS=2 and [M:RAE]TYPFAS=2
    Actzo [M:RAE]PATHFAS
  Else
    Diszo [M:RAE]PATHFAS
  Endif
End

Subprog AV_TYPLOF(VALEUR)
Variable Integer VALEUR
  If [M:RAE]FLGLOF=2
    Actzo [M:RAE]TYPLOF
  Else
    Diszo [M:RAE]TYPLOF
  Endif
End

Subprog AV_PATHLOF(VALEUR)
Variable Char    VALEUR()
  If [M:RAE]FLGLOF=2 and [M:RAE]TYPLOF=2
    Actzo [M:RAE]PATHLOF
  Else
    Diszo [M:RAE]PATHLOF
  Endif
End

Subprog AV_TYPPHY(VALEUR)
Variable Integer VALEUR
  If [M:RAE]FLGPHY=2
    Actzo [M:RAE]TYPPHY
  Else
    Diszo [M:RAE]TYPPHY
  Endif
End

Subprog AV_PATHPHY(VALEUR)
Variable Char    VALEUR()
  If [M:RAE]FLGPHY=2 and [M:RAE]TYPPHY=2
    Actzo [M:RAE]PATHPHY
  Else
    Diszo [M:RAE]PATHPHY
  Endif
End

Subprog CL_ICOAUDIT(VALEUR)
Variable Char    VALEUR()
  #Local Integer RESULT
  #Call OUINON("Voulez-vous lancer un audit des structures ?", RESULT) From GESECRAN
  #If ( RESULT = 2) Then : Gosub AUDIT : Endif
  Call AUDIT("TD")
End

 # FQ110966
Subprog C_PATHFAS(VALEUR)
Variable Char    VALEUR()

#control de la valeur [espace]chemin relatif
#calcul du chemin absolu
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M:RAE]TYPFAS, VALEUR, [M:RAE]FULLPATHFAS, E_TYPE_FILEREAD, GMESSAGE)

End
Subprog C_PATHLOF(VALEUR)
Variable Char    VALEUR()

#control de la valeur [espace]chemin relatif
#calcul du chemin absolu
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M:RAE]TYPLOF, VALEUR, [M:RAE]FULLPATHLOF, E_TYPE_FILEREAD, GMESSAGE)

End
Subprog C_PATHPHY(VALEUR)
Variable Char    VALEUR()

#control de la valeur [espace]chemin relatif
#calcul du chemin absolu
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M:RAE]TYPPHY, VALEUR, [M:RAE]FULLPATHPHY, E_TYPE_FILEREAD, GMESSAGE)

End

