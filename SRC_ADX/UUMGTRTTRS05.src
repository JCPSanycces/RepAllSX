#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRS05                              Module   A/P-A/R Accounting  #
#                                                                        #
#                    Migration Process                                   #
#                                                                        #
#      Flow for Paymenth                                                 #
#                                                                        #
#            PAYLOT                                                      #
#                                                                        #
##########################################################################
#                                                                        #
#  Optimized Index for Migration                                         #
#                                                                        #
#   PAYLOT  : COD                                                        #
#                                                                        #
#  Index to keep for Migration                                           #
#                                                                        #
#   PAYLOT  : CPY;COD                                                    #
#                                                                        #
##########################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRS05") From LECFIC
  Endif

  Call RAZ_UUMGTRTTRS05(DOSSIER)
  Call MAJ_UUMGTRTTRS05(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


########################################################################
Subprog RAZ_UUMGTRTTRS05(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(2)<>2 : End : Endif

#----- File naming...  -----#
Local Char WNAMPYLM
Call MIGTABNAME (DOSSIER,"PAYLOT",WNAMPYLM,ERR) From TRTMIG : If ERR : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMPYLM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif

#----- Deleting of records...  -----#
Call MIGTABRAZ (DOSSIER,"PAYLOT",ERR) From TRTMIG

Call MIGRAZKEY (DOSSIER,"UUMGTRTTRS05",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGTRTTRS05(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(2)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS05",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMPYLM
Call MIGTABNAME (DOSSIER,"PAYLOT",WNAMPYLM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS05",7,ERR) From TRTMIG : End : Endif


#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMPYLM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS05",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS05",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS05",7,ERR) From TRTMIG : End : Endif

Call ECR_TIME("UUMGTRTTRS05 Payment Process : Update PAYLOT") From DOSSUB
Call ECR_TRACE("UUMGTRTTRS05 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"PAYLOT",ERR) From TRTMIG

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:PYL]) = 0 :  Local File =DOSSIER+".PAYLOT"  [PYL]   : Endif      # Entry batch

# X3 Renamed File
If clalev([F:PYLM]) = 0 :  Local File =DOSSIER+"."+WNAMPYLM  [PYLM]  : Endif    # Entry batch

# X3 Commun File
If clalev([F:PYH])  = 0 : Local File =DOSSIER+".PAYMENTH"    [PYH]   : Endif      # Business Partner

#-----  Declaration of Variables
Gosub DECLARE From UUMGTRTCPT00

# Variables to manage Flush instruction
Local Char WTAB_PYL (100) (adxwrb)
Local Shortint WCPT_PYL

# Variables to Handle Loops Ruptures
Local Integer NBMIGKEY : NBMIGKEY=2
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# Variables linked to the migration process
Local Integer OK

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRS05",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(2))

#-----  Link
Link [PYLM] With [PYH]PYH2~=[F:PYLM]COD
&    As [LNK]
&    Order By Key CLE = [F:PYLM]COD

# EP to add a criteria in the "where"
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRS05" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_TRS05
Raz NB

If STOP = 1
 STOP = 0
 CRITERE = "[F:PYLM]COD>'"+TABMIGKEY(1)+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [PYL]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

 NBLUS+=1

 # EP to delete line
 If FILTRELIN
  FLUX="UUMGTRTTRS05" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
  If ISVALID=0 : Goto SUITE_BOUCLE : Endif
 Endif

 Gosub MAJ30_PYL
 If GOK<1 : Break : Endif

 Gosub MAJ50_PYL
 If GOK<1 : Break : Endif

 Gosub WRI_PYL
 NB+=1
 If NB>GMAXUPDTRS
  TABMIGKEY(1)= [F:PYLM]COD
  STOP=1
  Break
 Endif
 $SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS05",7,ERR) From TRTMIG : #7=Erreur
Else
 Flush [F:PYL]
 If fstat
  Call ECR_TRACE("File PAYLOT, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub PYL_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(2)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY(DOSSIER,"UUMGTRTTRS05",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRS05",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_TRS05
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [PYL], [PYH]


#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"PAYLOT",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTTRS05") From TRTMIG
Call ECR_TIME("UUMGTRTTRS05 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


#############################################################################################################
$MAJ30_PYL
#--- Transclass
[PYL] = [PYLM]

[F:PYL]FCY= [F:PYH]FCY
Return

$MAJ50_PYL
OK = 1
For [LNK]CLE
 If [PYH]STA<5 : OK=0 : Break : Endif
Next
If OK=1
 [F:PYL]STA = 5
Else
 [F:PYL]STA = 0
Endif
Return


$WRI_PYL
# Write Instruction
# To Save reference
Gosub PYL_STK
WriteB [F:PYL]
If fstat
 Call ECR_TRACE("File PAYLOT, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub PYL_ERRTRA
 GOK=0 : Return
Endif
Return

##############################################################################################
$PYL_STK
Call STK (WTAB_PYL,WCPT_PYL,[F:PYL]COD) From TRTMIG
Return

##############################################################################################
$PYL_ERRTRA
Call ERRTRA (WTAB_PYL,WCPT_PYL,"File PAYLOT(COD)=") From TRTMIG
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTTRS05(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTTRS05(APPLI)
End

