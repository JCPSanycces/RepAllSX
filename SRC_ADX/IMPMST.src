#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
# IMPMST : Import/Export Secteur de marché
# --------------------------------------------------------------------- #
# Traitements des actions spécifiques à l'import/export                 #
# avec import/exports des textes sous formes clobs
#########################################################################
$ACTION
  Case ACTION
    When "IMPORT"
      Gosub IMPORT
  Endcase
Return

##########################################################################################################
#                                  IMPORT                                #
##########################################################################
#-----------------------------------------------------#
# Après lecture d'un enregistrement (entête ou ligne) #
#                                                     #
# IMPFIC : Abréviation du fichier en cours            #
#-----------------------------------------------------#
$IMPORT
  Case IMPFIC
    When "HD6"      
      #Affectation clob complément d'informations
      [M:MST1]FULDES = [F:HD6]CLOB
  Endcase
Return
