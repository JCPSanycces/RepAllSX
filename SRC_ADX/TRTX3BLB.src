#<AdxTL>@(#)3.0.0.0 $Revision$
Subprog ECRCBB
[F:CBB]CREUSR = GUSER
[F:CBB]CREDAT = date$
[F:CBB]CRETIM = mid$(time$,1,2)+mid$(time$,4,2)
Write [F:CBB]
End

Subprog REWCBB
[F:CBB]UPDUSR = GUSER
[F:CBB]UPDDAT = date$
[F:CBB]UPDTIM = mid$(time$,1,2)+mid$(time$,4,2)
Rewrite [F:CBB]
End

Subprog DELCBB(PCOD, PID1, PID2)
Value Char PCOD
Value Char PID1
Value Char PID2

Delete [CBB] Where CODBLB=PCOD & IDENT1=PID1 & IDENT2=PID2
End
