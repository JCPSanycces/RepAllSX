#<AdxTL>@(#)8.0.0.0 $Revision$
########################################################################
##  Subprog INIREQ
##  Subprog FINREQ
##  Subprog BLOCAGE(APPLI,BTACHE,ER)
##  Subprog DEBLOCAGE(APPLI,BTACHE,ER)
########################################################################

Case GBIDC1
 When "I" : Call INIREQ
 When "F" : Call FINREQ
Endcase
End

#########################################
## Initialisation d'une requête
#########################################
Subprog INIREQ
Onerrgo ERREUR

Local  Char    FICTRA(GDIMFIC)
Local  Char    FICTRQ(GDIMFIC)
Local  Integer NUMREQ
Global Char    GTRT(GLONADC)
Local  Char    ORDSYS(250)(1..2) , VALPAR(50)(1..20) , MESSA(250)
Local  Integer I , J , K , OK , STAT , NOAPR , OKTRT
#Local  Char    CODTRT(GLONADC) , SPETRT(GLONADC) , PARAM4(GLONAAR) , ETAT(GLONADC)
Local  Char    CODTRT(GLONADC) , SPETRT(GLONADC) , PARAM4(GLONADC) , ETAT(GLONADC)
Local  Char    HREQ(10)
Local  Integer ACTTYP , PARAM3 , TYPTAC

#109897
#[L]NUMREQ = val(getenv$("RQT_ENTREP"))
[L]NUMREQ = val(GBATCHRQT)
FICTRQ = filpath("TRA",GTRACE,"tra")

Local File ABATRQT [ABR] , ABATPAR [ABP] , ABATTAC [ABT] , AFONCTION [AFC] , ABATRQTL [ABL]

Read [ABP]SPOOL First
# Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
# Existence of directory must be tested before (in ASYRSRVBATCH for example)
FICTRA = func SERVSYS.GET_FILE_SERVEUR("tra") : #109897

Raz GTRT
Raz GMESSBATCH, GERRBATCH, GERREUR, GERRTRACE

##  Lecture requête
Read [ABR]NUMREQ = [L]NUMREQ
Raz I
# L'ordre système "adonix -a" est lancé par le serveur avant de mettre le flag "En cours" sur la requête
While !fstat & [F:ABR]FLAG<>2
 I += 1
 If I>20 : Break : Endif
 Read [ABR]NUMREQ = [L]NUMREQ
 Sleep 2
Wend
If fstat
 GOK = 5 : End
Endif

#109897
If dim([F:ABR]LAN)>0
Trbegin [ABR]
 [F:ABR]SERVER  = adxmac(-1)
 [F:ABR]PORT  = adxtcp
 [F:ABR]LAN  = GLANGUE
 Rewrite [ABR]
 If fstat
  GOK=0 : Call ECR_TRACE(mess(27,125,1)-":"-mess(38,114,1)-num$([L]NUMREQ),1) From GESECRAN
  End
 Endif
Commit
Endif

TYPTAC = [F:ABR]TYPTAC
ETAT   = [F:ABR]ETAT
If [V]GPRODUIT=1
 [V]GFCY = [F:ABR]FCY
 [V]GDEP = [F:ABR]DEP
Endif

##  Passage en mono
If [F:ABR]MONO=2
 Gosub SET_MODULE
 Call MONOX3(MODULE,OK,GBATCHCPT) From AX3MONO : # Si arrêt, il faudra redémarrer la tâche batch compta
 If !OK
  GOK = 3 : End
 Endif
Endif

# mb 24.5.11 permet de recharger les classes [ABT] et [ABR] après le Call MULTI
Gosub SET_MODULE

##  Trace activation
##  Activation requête
Call RTRACE(FICTRQ,51000,mess(15,134,1)) From SERVEUR
GOK = 1
Openo FICTRQ , -1

## Pour psadx
Call SET_CURFCT([F:ABR]TACHE,1,GLOGIN) From PSADX

## Droits utilisateurs
If [F:ABT]FONCTION<>""
 GFONCTION = [F:ABT]FONCTION
 GFONCTION1 = GFONCTION
 For I=0 To [F:AFC]NBVAR-1
  If [F:AFC]VALEUR(I)<>"#"
   Assign [F:AFC]VARIA(I) With evalue([F:AFC]VALEUR(I))
  Else
   Assign [F:AFC]VARIA(I) With [F:ABT]PARAM
  Endif
 Next I
 Call AUTORIS From EXEFNC
 If [F:AFC]ACTION<>""
  Local File ACTION [ACT] , ACTPAR [ATR]
  Read [ACT]ACTION = [F:AFC]ACTION
  Raz VALPAR
  NOPAR = 0
  For I=1 To [F:ACT]NBPAR
   If (I>1 or [F:ACT]TYPACT<>2)
    NOPAR += 1
    Read [ATR]NOPAR = [F:ACT]ACTION;I
    K = find([F:ATR]CODPAR,[F:AFC]CODPAR(0..dim([F:AFC]CODPAR)-1))
    If K & [F:AFC]VALPAR(K-1)<>""
     Onerrgo EVAL
     Case [F:ATR]TYPPAR
      When 1,4,6
       VALPAR(NOPAR) = evalue([F:AFC]VALPAR(K-1))
      When Default
       VALPAR(NOPAR) = num$(evalue([F:AFC]VALPAR(K-1)))
     Endcase
     Onerrgo ERREUR
    Else
     VALPAR(NOPAR) = ""
    Endif
   Endif
  Next I
  GACTION = [F:ACT]ACTION
  CODTRT  = [F:ACT]CODTRT
  PARAM4  = [F:ACT]PARAM4
  PARAM3  = [F:ACT]PARAM3
  SPETRT  = [F:ACT]SPETRT
  ACTTYP  = [F:ACT]TYP
  Close Local File [ACT] , [ATR] , [AFC] , [ABR] , [ABT] , [ABP]
  If ACTTYP=3
   $EXEC_GTRAITE
   Call TRAITE_CHAR(GBIDC1,VALPAR,"",CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
   Gosub CONTINU
   If OK : Goto EXEC_GTRAITE : Endif
   GTRT = ""
  Endif
  End
 Endif
Else
 GBIDC1 = [F:ABT]PARAM
 GUSRFCY(1) = "\"
 GNBAUZ = 1
Endif

## Autres exécutions
Close Local File [AFC] , [ABR] , [ABT] , [ABP]

Case TYPTAC
 When 1 : # Traitement
  If GOS(1)="NT"
   Call TEMPON(mess(34,134,1)-ETAT) From GESECRAN : # Traitement
  Endif
  Call EXISTE_ADX("","",ETAT,OKTRT) From ORDSYS
  If OKTRT>0
   GTRT = ETAT : # C'est MENU qui va s'en charger
  Else
   GOK = 4 : # Traitement inexistant
  Endif
 When 2 : # Ordre système
  If GOS(1)="NT"
   Call TEMPON(mess(36,134,1)-ETAT) From GESECRAN : #  Ordre système
  Endif
  Openo
  ORDSYS(1) = ETAT
  ORDSYS(2) = FICTRQ :  # mb 10.9.2 bug 15678 Pb écriture trace serveur en DOS
  $EXEC_SYSTEME
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
  Gosub CONTINU
  If OK : Goto EXEC_SYSTEME : Endif
Endcase
End

$ERREUR
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-string$(GERREUR>0,errmes$(GERREUR))-errm
GPOINT = "ERRREQ" : Gosub ENTREE From EXEFNC
End

$EVAL
Resume

$SET_MODULE
Local Integer MODULE
Read [ABR]NUMREQ = [L]NUMREQ
MODULE = 0
Read [ABT]CODTAC = [F:ABR]TACHE
If !fstat & [F:ABT]FONCTION<>""
 Read [AFC]CODINT = [F:ABT]FONCTION
 If !fstat
  MODULE = [F:AFC]MODULE
 Endif
Endif
Return

$CONTINU
Local File ABATRQT [ABR]
Local Char    HH(10), HS(10)
Local Date    DD

OK = 1
Read [ABR]NUMREQ = [L]NUMREQ
If fstat
 OK = 0
Elsif [F:ABR]ONE<>2 or [F:ABR]FLAG>2 or [F:ABR]FRQFIN=""
 OK = 0
Else
 # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
 Call SCHEDULING_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS) From SERVEUR

 I = val(left$([L]HH,2))*60+val(right$([L]HH,3))
 I += [F:ABR]FRQ
 HREQ = right$(num$(100+int(I/60)),2)+right$(num$(100+mod(I,60)),2)
 If HREQ>[F:ABR]FRQFIN or [F:ABR]DAT<>[L]DD
  OK = 0
 Else
  Trbegin [ABR]
   Readlock [ABR]NUMREQ=[L]NUMREQ
   If !fstat
    [F:ABR]IMPETX = min(32000,[F:ABR]IMPETX+1)
    [F:ABR]HFIN   = [L]HS
    Rewrite [ABR]
   Endif
  Commit
  Sleep [F:ABR]FRQ*60
 Endif
Endif
Close Local File [ABR]
Return

#################################################
## Traitement de fin d'une requête
#################################################
Subprog FINREQ
Local Integer NUMREQ , NEWREQ , FLAGREQ , GRPNUM , OKRQT , ERRMAX
Local Char    FICTRA(GDIMFIC) , FICTRQ(GDIMFIC)
Local Char    DOSSIER(GLONADS) , CODABT(GLONABA) , CODTAC(GLONABT)
Local Char    MESSA(250)
Local Integer I , OK , ERR
Local Char    HREQ(10)
Local Char    HH(10), HS(10)
Local Integer SS
Local Date    DD
Local  Integer GRPSEQ

FICTRQ     = filpath("TRA",GTRACE,"tra")
#109897
#[L]NUMREQ  = val(getenv$("RQT_ENTREP"))
[L]NUMREQ  = val(GBATCHRQT)

Onerrgo ERR_FIN

Call FLUSH_TRACE From GESECRAN

OKRQT = GOK : # Retour de la requête

Local File ABATRQT [ABR], ABATPAR [ABP], ABATTAC [ABT], AFONCTION [AFC], ABATRQTL [ABL]

Read [ABP]SPOOL First
# Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
# here we know that the batch server log directory exists
FICTRA = func SERVSYS.GET_FILE_SERVEUR("tra") :#109897

ERRMAX = 100

## GERRBATCH<errmax -> warning, GERRBATCH>=errmax -> erreur bloquante
## GERRTRACE est incrémentée à chaque écriture en erreur dans le fichier trace
## GERRBATCH peut être initialisé manuellement dans la tâche

## 1: En attente
## 2: En cours
## 3: Terminée
## 4: Bloquée
## 5: A tuer
## 6: Avortée
## 7: Erreur
## 8: Hors délai
## 9: Warning

If GERREUR or OKRQT=3
 [L]FLAGREQ = 6
Elsif GERRTRACE<>0 or OKRQT<>1 or GERRBATCH>=ERRMAX
 [L]FLAGREQ = 7
Elsif GERRBATCH<>0 & GERRBATCH<ERRMAX
 [L]FLAGREQ = 9
Else
 [L]FLAGREQ = 3
Endif

If OKRQT=5
 Raz [F:ABR]
Else
  Trbegin [ABR]
    Readlock [ABR]NUMREQ = [L]NUMREQ
    If fstat
      Rollback
      OKRQT = 2
    Else
      # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
      Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR

      [F:ABR]FLAG = [L]FLAGREQ
      [F:ABR]DFIN = [L]DD
      [F:ABR]HFIN = [L]HS
      Rewrite [ABR]
      If fstat
        Rollback
        OKRQT=0
        Call STRACE(FICTRA,42000,[L]NUMREQ,"FINREQ -"-mess(13,100,1)-"ABATRQT") From SERVEUR
      Else
        Commit
        Read [ABR]NUMREQ = [L]NUMREQ
      Endif
    Endif
Endif

# Suppression du .run
If [F:ABR]JOB<>""
 Call DELJOB([F:ABR]JOB,"run") From SERVJOB
Endif

##  Trace requête
If OKRQT=2
 ERR = 43000
 MESSA = mess(30,134,1) : # Requête inexistante
Elsif OKRQT=3
 ERR = 24000+min(nbruser-1,999)
 MESSA = mess(64,134,1) : # Passage en mono impossible car # utilisateurs connectés
 I = instr(1,MESSA,"#")
 If I
  MESSA = left$(MESSA,I-1)+num$(nbruser-1)+right$(MESSA,I+1)
 Endif
Elsif OKRQT=4
 ERR = 25000
 MESSA = [F:ABR]ETAT-mess(32,134,1) : # Traitement inexistant
Elsif OKRQT=5
 ERR = 43100
 MESSA = mess(113,134,1) : # Requête inexistante ou non lancée
Elsif GERREUR
 ERR = 11000+min(GERREUR,999)
 If GMESSAGE=""
  GMESSAGE = mess(61,134,1)-"("+errmes$(GERREUR)+")" : # Fin requête avec erreur adonix
 Endif
 MESSA = GMESSAGE
Elsif GERRBATCH<>0
 ERR = 13000+min(GERRBATCH,999)
 MESSA = mess(61,134,1)-"("+GMESSBATCH+")" : # Fin requête avec erreur
Elsif OKRQT<0
 ERR = 12000
 MESSA = mess(58,134,1) : # Erreur de verrouillage
Elsif OKRQT=0
 If GMESSAGE<>"" & val(left$(GMESSAGE,1))>0
  ERR = 10000+val(left$(GMESSAGE,1)) : # Mis à jour dans RSTA/FSTA de GLOCK en cas d'erreur d'accès table
  MESSA = mess(61,134,1)-"("+right$(GMESSAGE,2)+")" : # Fin requête avec erreur d'accès table
 Else
  ERR = 10000
  MESSA = mess(59,134,1): # Requête terminée avec erreur inconnue
 Endif
Elsif GERRTRACE
 ERR = min(GERRTRACE,9999)
 MESSA = mess(60,134,1) : # Requête terminée avec avertissements (erreurs dans la trace)
Else : # OKRQT=1
 ERR = 0
 MESSA = mess(33,134,1) : # Requête terminée (normal)
Endif

Call STRACE(FICTRA,ERR,[L]NUMREQ,"FINREQ - Ended query management:"-MESSA) From SERVEUR
Call RTRACE(FICTRQ,ERR,MESSA) From SERVEUR

Gosub IDENT_RQT

##  Message utilisateur
If [F:ABR]MESSAGE=2
 If OKRQT=1 & GERRTRACE=0 & GERRBATCH=0
  Call WORKFLOW(5,[F:ABR]TACHE,"0",RQTID) From AWRK
 Else
  Call WORKFLOW(5,[F:ABR]TACHE,num$(ERR)-MESSA,RQTID) From AWRK
 Endif
Endif

GPOINT = "FINREQ" : Gosub ENTREE From EXEFNC : # mb 2.10.3 bug 18666

# Contrôle des procédures de migration
If dim(GMIGPLAN)>0
  Local Integer PEXIST
  Call EXISTE_ADX("","","SUBAM4",PEXIST) From ORDSYS
  If PEXIST=1
    Call TRTFINMIG From SUBAM4
  Endif
Endif

# Remise en multi
If [F:ABR]MONO=2
 Gosub SET_MODULE
 Call MULTIX3(MODULE,GBATCHCPT) From AX3MONO
Endif

# mb 24.5.11 permet de recharger les classes [ABT] et [ABR] après le Call MULTI
Gosub SET_MODULE

# Pour le psadx
Call RAZ_CURFCT(num$(adxuid(1))) From PSADX

# Réactivation de la requête en cas d'abonnement avec fréquence<>0
OK =  (OKRQT=1 & GERRBATCH<ERRMAX & GERREUR=0)  : # Pas d'erreur grave
OK += (dim([F:ABR]CNTERR)>0 & [F:ABR]CNTERR=2)  : # Continuer même en cas d'erreur
OK *= ([F:ABR]FRQFIN<>"")                       : # Avec Heure de fin
OK *= ([F:ABR]ONE<>2)                           : # Pas toujours la même requête
If OK
    [L]DOSSIER = [F:ABR]DOSSIER
    [L]CODABT = [F:ABR]CODABT
    [L]CODTAC = [F:ABR]TACHE
    # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
    Call SCHEDULING_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS) From SERVEUR

    HREQ = [L]HH
    I = val(left$(HREQ,2))*60+val(right$(HREQ,3))
    I += [F:ABR]FRQ
    HREQ = right$(num$(100+int(I/60)),2)+right$(num$(100+mod(I,60)),2)
    If HREQ<=[F:ABR]FRQFIN & [F:ABR]DAT=[L]DD
        GOK = 1
        Trbegin [ABR], [ABP]
        Readlock [ABP]SPOOL First With lockwait=5
        If fstat
            GOK=0
            Call STRACE(FICTRA,44000,0,"FINREQ -"-mess(58,134,1)-"ABATPAR/ABP fstat="+num$(fstat)) From SERVEUR
        Else
            # Create the new request
            [L]NEWREQ = [F:ABP]NUMREQ
            [F:ABR]NUMREQ = [L]NEWREQ
            [F:ABP]NUMREQ += 1
            [F:ABR]HEURE  = HREQ
            [F:ABR]FLAG   = 1
            [F:ABR]HFIN   = ""
            [F:ABR]HDEB   = ""
            Raz [F:ABR]SERVER, [F:ABR]PORT, [F:ABR]PROCESS : #109897
            Write [ABR]
            If fstat
                GOK = 0
                Call STRACE(FICTRA,42000,[L]NEWREQ,mess(13,100,1)-"ABATRQT/ABR (FINREQ) query recreation fstat="+num$(fstat)) From SERVEUR
            Else
                # Create parameters of new request
                For [F:ABL] Where NUMREQ = [L]NUMREQ
                    [F:ABL]NUMREQ = [F:ABR]NUMREQ
                    Write [F:ABL]
                    If fstat
                        GOK = 0
                        Call STRACE(FICTRA,42000,[F:ABL]NUMREQ,mess(13,100,1)-"ABATRQTL/ABL (FINREQ) query line recreation fstat="+num$(fstat)) From SERVEUR
                        Break
                    Endif
                Next ABL
                If GOK=1
                    Rewrite [ABP]
                    If fstat
                     GOK = 0
                     Call STRACE(FICTRA,44000,0,mess(13,100,1)-"ABATPAR (FINREQ)") From SERVEUR
                    Else
                        # On garde la requête mère et on vire les grand-mères
                        For [ABR] Where DOSSIER=[L]DOSSIER & CODABT=[L]CODABT & TACHE=[L]CODTAC & NUMREQ<[L]NUMREQ & FLAG>2 & FLAG<>5 & EPUR=2
                            [L]NUMREQ = [F:ABR]NUMREQ
                            Delete [ABR] Where NUMREQ=[L]NUMREQ
                            If fstat
                                GOK = 0
                                Call STRACE(FICTRA,42000,[L]NUMREQ,"delete ABATRQT/ABR (FINREQ) fstat="+num$(fstat)) From SERVEUR
                                Break
                            Endif
                            Delete [ABL] Where NUMREQ=[L]NUMREQ
                            If fstat
                                GOK = 0
                                Call STRACE(FICTRA,42000,[L]NUMREQ,"delete ABATRQTL/ABL (FINREQ) fstat="+num$(fstat)) From SERVEUR
                                Break
                            Endif
                            #109897
                            #Call EFF_FIC([L]NUMREQ,[F:ABP]APPLI) From EPURRQT
                            Call EFF_FIC([L]NUMREQ) From EPURRQT
                        Next ABR
                    Endif
                Endif
            Endif
        Endif   #Readlock [ABP]
        If GOK
            Commit
        Else
            Rollback
        Endif
    Endif
Endif

# Activation de la requête suivante du groupe
If [F:ABR]GRP<>"" & [F:ABR]NUMGRP<>0
    GRPNUM = [F:ABR]NUMGRP
    # If an error occured and "not continue if error" => stop all following tasks
    If (OKRQT=1 & GERRBATCH<ERRMAX & GERREUR=0) or (dim([F:ABR]CNTERR)>0 & [F:ABR]CNTERR=2)
        If func RUN_NEXT_GRP_SEQ(GRPNUM,MESSA)<>[V]CST_AOK
            Call STRACE(FICTRA,42000,[F:ABR]NUMREQ,"FINREQ - Next sequence in group"-MESSA) From SERVEUR
        Endif
    Else
        Trbegin [ABR]
        Filter [ABR] Where NUMGRP=GRPNUM & FLAG=4
        For [ABR]NUMREQ
            # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
            Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR
            [F:ABR]FLAG = 6
            [F:ABR]DFIN = [L]DD
            [F:ABR]HFIN = [L]HS
            Rewrite [ABR]
            If fstat
                Call STRACE(FICTRA,42000,[F:ABR]NUMREQ,"FINREQ - group error"-mess(13,100,1)-"ABATRQT") From SERVEUR
            Endif
            If [F:ABR]JOB<>""
                Call MOVEJOB([F:ABR]JOB,"req","old") From SERVJOB
            Endif
            MESSA = mess(70,134,1)-[F:ABR]GRP : # Exécution impossible suite à erreur dans le groupe
            Call STRACE(FICTRA,27400,[F:ABR]NUMREQ,MESSA) From SERVEUR
            Call RTRACE(FICTRQ,27400,MESSA) From SERVEUR
            [L]NUMREQ = [F:ABR]NUMREQ
        Next
        Filter [ABR]
        Commit
    Endif
Endif

End

# Issue X3-59123 - 2018-05-29 by CCC
#**
#* Change status of 'on hold' group tasks to 'pending'.<br>
#* This change is done : <br>
#*  - if all tasks in the group are finished (with or without error, this control must be done previously)<br>
#*  - on the smallest sequence number of the group not run yet<br>
#*
#* @param GRPNUM : group number (corresponds to [F:ABR]NUMGRP)
#* @param MESSA  : error message if an error occurs
#*
#* @return : [V]CST_AERROR if an error occurs else [V]CST_AOK
#*!
Funprog RUN_NEXT_GRP_SEQ(GRPNUM,MESSA)
Value Integer GRPNUM
Variable Char MESSA

Local File ABATRQT [ABR]
Local Integer LRET, LTRANS
Local Integer REQNUM, GRPSEQ

Raz MESSA
LRET=[V]CST_AOK

# Check if all previous tasks are finished
Filter [ABR] Where [ABR]NUMGRP=GRPNUM & find(FLAG,1,2)<>0
Look [ABR] First
Filter [ABR]
If fstat
    If adxlog<>1
        Trbegin [ABR]
        LTRANS=1
    Endif
    # check if at least 1 task must be run
    Filter [ABR] Where NUMGRP=GRPNUM & FLAG=4
&                Order By SEQGRP;NUMREQ
    Read [ABR] First
    Filter [ABR]
    If !fstat
        # Issue X3-97776 - 2018-06-25 by CCC : Take into account the bad case where sequence number has not been initialized
        If [F:ABR]SEQGRP=0
            [L]REQNUM = [F:ABR]NUMREQ
            # Activate the first task with sequence number=0
            Update [ABR] Where NUMREQ=[L]REQNUM
&                        With FLAG=1,
&                             SERVER="", [F:ABR]PORT=0, [F:ABR]PROCESS="" : #109897
            If fstat
                MESSA = func GLOCK.GET_FSTAT_MSG(fstat)-"ABATRQT"-num$([L]REQNUM)
                LRET = [V]CST_AERROR
            Endif
        Else
            [L]GRPSEQ = [F:ABR]SEQGRP
            # Active all 'on hold' tasks for the same sequence number
            Update [ABR] Where NUMGRP=GRPNUM & FLAG=4
&                            & SEQGRP=[L]GRPSEQ
&                        With FLAG=1,
&                             SERVER="", [F:ABR]PORT=0, [F:ABR]PROCESS="" : #109897
            If fstat
                MESSA = func GLOCK.GET_FSTAT_MSG(fstat)-"ABATRQT NUMGRP="-num$([L]GRPNUM)
                LRET = [V]CST_AERROR
            Endif
        Endif
    Endif
    Filter [ABR]
    If LTRANS=1
        If LRET<>[V]CST_AOK
            Rollback
        Else
            Commit
        Endif
    Endif
Endif
LogicClose File [ABR]
End LRET


$ERR_FIN
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"
If GERREUR>0
 GMESSAGE -= errmes$(GERREUR)
Endif
GMESSAGE -= errm
Call STRACE(FICTRA,14000+GERREUR,[L]NUMREQ,GMESSAGE) From SERVEUR
Call RTRACE(FICTRQ,14000+GERREUR,GMESSAGE) From SERVEUR
GPOINT = "ERRREQ" : Gosub ENTREE From EXEFNC
End

###############################################
## Ecriture des paramètres => [ABR] [ABL]
###############################################
Subprog CRERQT(DOSSIER,USER,GROUPE,GRPNUM,TACHE,FLG,DAT,TIM,SERVICE,ABRECR,REQUETE)
Value    Char    DOSSIER
Value    Char    USER
Value    Char    GROUPE
Value    Integer GRPNUM
Value    Char    TACHE
Value    Integer FLG
Value    Date    DAT
Value    Char    TIM
Value    Char    SERVICE
Value    Char    ABRECR()
Variable Integer REQUETE
Local Char    LAN(GLONLAN) : LAN=""
Goto CREATE_RQT

Subprog CRERQTLAN(DOSSIER,USER,LAN,GROUPE,GRPNUM,TACHE,FLG,DAT,TIM,SERVICE,ABRECR,REQUETE)
Value    Char    DOSSIER
Value    Char    USER
Value    Char    LAN
Value    Char    GROUPE
Value    Integer GRPNUM
Value    Char    TACHE
Value    Integer FLG
Value    Date    DAT
Value    Char    TIM
Value    Char    SERVICE
Value    Char    ABRECR()
Variable Integer REQUETE
Goto CREATE_RQT

#####################################################
$CREATE_RQT
If clalev([F:ABP])=0 : Local File ABATPAR [ABP] : Endif
If clalev([F:ABT])=0 : Local File ABATTAC [ABT] : Endif
If clalev([F:ABR])=0 : Local File ABATRQT [ABR] : Endif

Local Integer I , K

Call DEBTRANS From GLOCK
Gosub TR_RQT
End

$TR_RQT
GOK = 1
Trbegin [ABP] , [ABR]
 Readlock [ABP]SPOOL First With lockwait=5
 If fstat=1
  GOK = -1 : GLOCK = "$ABATPAR" : Goto ROLL_RQT
 Elsif fstat
  GOK = 0 : Call RSTA("ABP","") From GLOCK : Goto AB_RQT
 Endif
 REQUETE = [F:ABP]NUMREQ
 Read [ABT]CODTAC = TACHE
 Raz [F:ABR]
 [F:ABR] = [F:ABT]
 [F:ABR]DOSSIER = DOSSIER
 [F:ABR]USER    = USER
 #109897
 [F:ABR]LAN     = LAN
 [F:ABR]TACHE   = TACHE
 [F:ABR]ETAT    = [F:ABT]TRAIT
 [F:ABR]NUMREQ  = [F:ABP]NUMREQ
 [F:ABR]FLAG    = FLG
 [F:ABR]DAT     = DAT
 [F:ABR]HEURE   = TIM
 #109897
 #[F:ABR]SERVICE = SERVICE
 [F:ABR]GRP     = GROUPE
 [F:ABR]NUMGRP  = GRPNUM
 If [V]GPRODUIT=1
  [F:ABR]FCY = [V]GFCY
  [F:ABR]DEP = [V]GDEP
 Endif
 Gosub ECRIT_PARAM
 If GOK=0 : Goto AB_RQT : Endif
 [F:ABP]NUMREQ  += 1
 Rewrite [ABP]
 If fstat
  GOK = 0 : Call FSTA("ABP") From GLOCK : Goto AB_RQT
 Endif
Commit
Return

$ECRIT_PARAM
Local Integer  LL : LL = [F:ABR]NUMREQ
Call SETPAR(ABRECR,LL)
If GOK =0 : Return : Endif
Write [ABR]
If fstat
 GOK = 0 : Call FSTA("ABR") From GLOCK : Return
Endif
Return

$AB_RQT
Rollback
Return

$ROLL_RQT
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_RQT : Endif

#####################################################
Subprog BLOCAGE(APPLI,BTACHE,ER)
Value    Char    APPLI
Value    Char    BTACHE
Variable Integer ER

Local File ABATRQT [ABR]
Filter [ABR] Where TACHE=BTACHE & DOSSIER=APPLI
Call DEBTRANS From GLOCK
Gosub TR1
Filter [ABR]
End

$TR1
GOK=1
Trbegin [ABR]
 For [ABR]NUMREQ With Lock
  If fstat=1
   GOK = -1 : GLOCK="$ABATRQT"-num$([F:ABR]NUMREQ) : Break
  Elsif [F:ABR]FLAG=2
   GOK =0 : ER = 1 : Break
  Elsif [F:ABR]FLAG=1
   [F:ABR]FLAG = 4
   Rewrite [ABR]
   If fstat
    GOK = 0 : ER = 2 : Break
   Endif
  Endif
 Next
 If   GOK=-1 : Goto ROLL_TR1
 Elsif GOK<1 : Goto AB_TR1
 Endif
Commit
ER =0
Return

$ROLL_TR1
Rollback
Goto TR1

$AB_TR1
Rollback
Return

#####################################################
Subprog DEBLOCAGE(APPLI,BTACHE,ER)
Value    Char    APPLI
Value    Char    BTACHE
Variable Integer ER
Local File ABATRQT [ABR]
Filter [ABR] Where TACHE=BTACHE & DOSSIER=APPLI
Call DEBTRANS From GLOCK
Gosub TR2
Filter [ABR]
End

$TR2
GOK=1
Trbegin [ABR]
 For [ABR] With Lock
  If fstat=1
   GOK=-1 : GLOCK="$ABATRQT"-num$([F:ABR]NUMREQ) : Break
  Elsif [F:ABR]FLAG=4
   [F:ABR]FLAG=1
   Rewrite [ABR]
   If fstat
    GOK=0 : ER=2 : Break
   Endif
  Endif
 Next
 If   GOK=-1 : Goto ROLL_TR2
 Elsif GOK<1 : Goto AB_TR2
 Endif
Commit
ER=0
Return

$ROLL_TR2
Rollback
Goto TR2

$AB_TR2
Rollback
Return

####################################
##  Déclaration fichier de trace  ##
####################################
$DCL_TRA
Local  Char    FICTRA(GDIMFIC)
Local  Char    FICTRQ(GDIMFIC)
FICTRA = func SERVSYS.GET_FILE_SERVEUR("tra") :#109897
FICTRQ = filpath("TRA",GTRACE,"tra")
Return

#################################
##  Identifiant de la requête  ##
#################################
$IDENT_RQT
Local Char RQTID(50)
RQTID  = [F:ABR]DOSSIER - [F:ABR]TACHE
RQTID -= left$(mess([F:ABR]TYPTAC,20,1),1) - [F:ABR]ETAT
RQTID -= "("+num$([L]NUMREQ)+")"
Return

#################################################
## Vidage d'un ou plusieurs masques dans [ABL] ##
#################################################
Subprog SETPAR(ABRMSK,REQUETE)
Value Char ABRMSK()
Value Integer REQUETE
If clalev([F:ABL])=0 : Local File ABATRQTL [ABL] : Endif
Default File [ABL]
Call ECRIT(ABRMSK,"","",0,REQUETE)
End

#############################################################################################
## S/P de vidage d'un ou plusieurs masques dans la table par défaut (ABATABTD ou ABATRQTL)
#############################################################################################
Subprog ECRIT(ABRMSK,CODABT,CODTAC,LIG,NUMREQ)
Value Char    ABRMSK()
Value Char    CODABT , CODTAC
Value Integer LIG , NUMREQ

Local Integer I , J , NBVAR , LNG , TYP , DIME , LMAX , MA , NUMS
Local Char    VARI(20) , PARAM(20) , ABREV(20) , PARS(250)
Local Char    VALEUR(250) , VALS(250)
Local Decimal NOMBRE , NUMERO
Local Date    DAT
Local Clbfile CHAINE(7)

LMAX = type([F]VALEUR)-10
NUMERO = 0

For MA=0 To dim(ABRMSK)-1
 If ABRMSK(MA)<>""
  ABREV = "[M:"+ABRMSK(MA)+"]"
  If evalue("clalev("+ABREV+")")>0
   NBVAR = evalue("clanbs("+ABREV+",1)")
   For I=1 To NBVAR
    VARI = evalue("clavar("+ABREV+","+num$(I)+")")
    TYP  = evalue("type("+ABREV+VARI+")")
    DIME = evalue("dim("+ABREV+VARI+")")
    For J=1 To DIME
     If DIME=1
      [L]PARAM = VARI
     Else
      [L]PARAM = VARI+"("+num$(J-1)+")"
     Endif
     Case TYP
      When 1,2,4,5,6,7,8,9
       NOMBRE = evalue(ABREV+[L]PARAM)
       If NOMBRE<>0
        [L]VALEUR   = num$(NOMBRE)
        Gosub ECRIT_PAR
        If GOK<1 : Break 3 : Endif
       Endif
      When 3
       DAT = evalue(ABREV+[L]PARAM)
       If DAT<>[0/0/0]
        [L]VALEUR   = DAT
        Gosub ECRIT_PAR
        If GOK<1 : Break 3 : Endif
       Endif
      When Default
       LNG = evalue("len("+ABREV+[L]PARAM+")")
       If LNG<>0
        CHAINE = evalue(ABREV+[L]PARAM)
        Repeat
         [L]VALEUR   = left$(CHAINE,LMAX)
         Gosub ECRIT_PAR
         If GOK<1 : Break 4 : Endif
         CHAINE = right$(CHAINE,LMAX+1)
        Until CHAINE=""
       Endif
     Endcase
    Next J
   Next I
  Endif
 Endif
Next MA
If NUMERO=0
 Gosub ECRIT_PAR : # Pour forcer l'écriture au moins d'une enregistrement
Endif
End

###########################################
$ECRIT_PAR
Raz [F]
[F] = [L]
[L]NUMERO += 1
[F]NUM    = [L]NUMERO
If [V]GPRODUIT=1
 If dim([F]FCY)>0 : [F]FCY = [V]GFCY : Endif
 If dim([F]DEP)>0 : [F]DEP = [V]GDEP : Endif
Endif
Write [F]
If fstat
 GOK = 0 : Call FSTA(func ABRDEF) From GLOCK
Endif
Return

Funprog ABRDEF
Local Char ABREV(30)
Local Integer K
ABREV = dbgstr(2)
K = instr(1,ABREV,",")
If K
 ABREV = left$(ABREV,K-1)
Endif
ABREV = ctrans(ABREV,", []","")
End ABREV

########################################################
## Vidage de la requête dans un ou plusieurs masques  ##
########################################################
Subprog GETPAR(ABRMSK)
Value    Char   ABRMSK()

Local Integer NBVAR , I , J ,  TYP , DIME , MA , CURLIG
Local Char    VARI(20) , VARIA(20) , ABREV(20)
Local Clbfile CHAINE(7)

For MA=0 To dim(ABRMSK)-1
 If ABRMSK(MA)<>""
  ABREV = "[M:"+ABRMSK(MA)+"]"
  If evalue("clalev("+ABREV+")")>0
   NBVAR = evalue("clanbs("+ABREV+",1)")
   For I=1 To NBVAR
    VARI = evalue("clavar("+ABREV+","+num$(I)+")")
    TYP  = evalue("type("+ABREV+VARI+")")
    DIME = evalue("dim("+ABREV+VARI+")")
    For J=1 To DIME
     If DIME=1
      VARIA = VARI
     Else
      VARIA = VARI+"("+num$(J-1)+")"
     Endif
     CURLIG = 0
     For [F] Where PARAM=VARIA
      CURLIG = [F]NUM
      Break
     Next
     If CURLIG
      Case TYP
       When 1,2,4,5,6,7,8,9
        Assign ABREV+VARIA With val([F]VALEUR)
       When 3
        If [F]VALEUR=""
         Assign ABREV+VARIA With [0/0/0]
        Else
         Assign ABREV+VARIA With [F]VALEUR
        Endif
       When Default
        CHAINE = ""
        For [F] Where PARAM=VARIA
         If [F]NUM<>CURLIG : # mb 16.6.9 bug 55825
          Break
         Endif
         CHAINE += [F]VALEUR
         CURLIG += 1
        Next
        Assign ABREV+VARIA With CHAINE
      Endcase
     Endif
    Next J
   Next I
  Endif
 Endif
Next MA
End

