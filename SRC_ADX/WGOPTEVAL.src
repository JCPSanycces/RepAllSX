#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OPTEVAL

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:57"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OPTEVAL",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="PJT0;PJT1;PJT2;PJT3;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
If clalev([M:PJT0])=0 : Local Mask PTEVAL0 [PJT0] : Endif
If clalev([M:PJT1])=0 : Local Mask PTEVAL1 [PJT1] : Endif
If clalev([M:PJT2])=0 : Local Mask PTEVAL2 [PJT2] : Endif
If clalev([M:PJT3])=0 : Local Mask PTEVAL3 [PJT3] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGOPTEVAL
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPTEVAL" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJT0]
&   Folder Mask [PJT1]
& , Folder Mask [PJT2]
& , Folder Mask [PJT3]
& As [PJT1]
Titled [PJT1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOPTEVAL
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPTEVAL" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJT0]
&   Folder Mask [PJT1]
& , Folder Mask [PJT2]
& , Folder Mask [PJT3]
& As [PJT1]
Titled [PJT1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [PJT1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [PJT1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [PJT1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TIT(60) , TITTRN(60)
Call TEXTE(46764,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$DEFAUT_BRO
Return

$SETBOX
Return

$SETORDER
Return

$ENDORDER
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "PTEVAL0"      : ABMSK(0)  = "PJT0"     : AMA(0) = 1
NOMMSK(1) = "PTEVAL1"      : ABMSK(1)  = "PJT1"     : AMA(1) = 1
NOMMSK(2) = "PTEVAL2"      : ABMSK(2)  = "PJT2"     : AMA(2) = 1
NOMMSK(3) = "PTEVAL3"      : ABMSK(3)  = "PJT3"     : AMA(3) = 1
NBMASK = 3
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:PJT0])>0 : Default Mask [PJT0] : Endif
 When 1 : If clalev([M:PJT1])>0 : Default Mask [PJT1] : Endif
 When 2 : If clalev([M:PJT2])>0 : Default Mask [PJT2] : Endif
 When 3 : If clalev([M:PJT3])>0 : Default Mask [PJT3] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:PJT0])>0 : Gosub TITRES From W1PTEVAL0 : Endif
 When 1 : If clalev([M:PJT1])>0 : Gosub TITRES From W1PTEVAL1 : Endif
 When 2 : If clalev([M:PJT2])>0 : Gosub TITRES From W1PTEVAL2 : Endif
 When 3 : If clalev([M:PJT3])>0 : Gosub TITRES From W1PTEVAL3 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:PJT0])>0 : Close Local Mask [PJT0] : Endif
If clalev([M:PJT1])>0 : Close Local Mask [PJT1] : Endif
If clalev([M:PJT2])>0 : Close Local Mask [PJT2] : Endif
If clalev([M:PJT3])>0 : Close Local Mask [PJT3] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:PJT0])>0 : Raz [M:PJT0] : Endif
 When 1 : If clalev([M:PJT1])>0 : Raz [M:PJT1] : Endif
 When 2 : If clalev([M:PJT2])>0 : Raz [M:PJT2] : Endif
 When 3 : If clalev([M:PJT3])>0 : Raz [M:PJT3] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:PJT0])>0 : Affzo [M:PJT0] : Endif
 When 1 : If clalev([M:PJT1])>0 : Affzo [M:PJT1] : Endif
 When 2 : If clalev([M:PJT2])>0 : Affzo [M:PJT2] : Endif
 When 3 : If clalev([M:PJT3])>0 : Affzo [M:PJT3] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Return

$CHARGEMSK
Return

$GRISE_CLE
Return

$DEGRISE_CLE
Return

$BOUTON
STDBOUT = "EA"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1101 : Call TEXTE(13580,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "2" : LBOUT(NBTEX) = 1102 : Call TEXTE(40355,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "3" : LBOUT(NBTEX) = 1103 : Call TEXTE(28989,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "4" : LBOUT(NBTEX) = 1104 : Call TEXTE(21803,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "5" : LBOUT(NBTEX) = 1105 : Call TEXTE(178,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "6" : LBOUT(NBTEX) = 1106 : Call TEXTE(38778,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


