############################################################
# Visu  procedure
############################################################
$OUVRE_CFM                        # Issue 106915 GA 03/2015
If PARAM(1) = ""
  FIN = 1
Else
  If clalev([F:CFM]) = 0 : Local File CFGMAC   [CFM] : Endif
Endif
# Issue 106132 & 106915 GA 03/2015
If dim(G_CFGWIN)<=0   Global Char G_CFGWIN(GLONAVA) Endif
# Issue 107692 - 2015-06-26 by GA
If dim(G_CFGRNG)<=0   Global Shortint G_CFGRNG Endif

# Issue 116184 - 2016-06-13 by STLIG : Tunnel from scenario, PARAM(1) is "" or dim([M]R_<PARAM(1)>) is -1
If (evalue("dim([M]"+W_PRR+PARAM(1)+")>=0"))
  If G_CFGWIN<>W_PRQ+PARAM(1) & G_CFGRNG<evalue("[M]"+W_PRR+PARAM(1))
    G_CFGWIN=W_PRQ+PARAM(1)
    G_CFGRNG=evalue("[M]"+W_PRR+PARAM(1))
  Else
    FIN = 1
    Gosub LASTTAB From CFGLIBD
  Endif
Endif

Return
############################################################
$DEBUT_CFM                        # Issue 106915 GA 03/2015
Raz [M:VCFM]
#
Read [CFM]CFM0=PARAM(1);1
If fstat
  FIN = 1
Else
  nolign = 0
  Filter [CFM] Where MACNUM = PARAM(1)
&              Order By Key CFM0
  For [CFM]
    If nolign < dim([M:VCFM]SYMTYP)-1
      nolign += 1
      [M:VCFM] = [F:CFM]
#CHECK IGNORE_BEGIN
     # FQ 53410 remplacé par lien
      If dim( [M:VCFM]SYMDES)>0 # Issue 84374 GA 09/2012
         Call SYM_TXT([M:VCFM]SYMDES(nolign-1),[M:VCFM]SYMTYP(nolign-1),[M:VCFM]SYMNUM(nolign-1),"") From CFGLIB
      Endif
#CHECK IGNORE_END
    Endif
  Next
  Filter [CFM]
  [M:VCFM]NBLIG = nolign
  Affzo [M:VCFM]
Endif
Return
############################################################
Subprog GEN_CND(LCOD,LTYP,LCND,LIND,LEVA)
Value    Integer LCOD
Value    Integer LTYP
Value    Integer LCND
Value    Integer LIND
Variable Char    LEVA
#
Local    Char    W_PRE(30)
Local    Char    W_FIC(30)
Case LCOD
  When 1 : W_PRE = "[M:CFGH]QSTVAL"
  When 2 : W_PRE = "[M:CFGH]VARVAL"
  When 3 : W_PRE = "W_VAL"
Endcase
W_FIC = "[F:CFH]VAL"
Case LTYP
  When 1 :
    W_PRE += "ALP"
    W_FIC += "ALP"
  When 2 :
    W_PRE += "NUM"
    W_FIC += "NUM"
  When 3 :
    W_PRE += "DAT"
    W_FIC += "DAT"
  When 4 :
    W_PRE += "NUM"
    W_FIC += "NUM"
Endcase
If LIND >= 0
  W_PRE += "("+num$(LIND)+")"
Endif
Case LCND
  When 2 : LEVA = W_FIC+"= "+W_PRE
  When 3 : LEVA = W_FIC+"<>"+W_PRE
  When 4 : LEVA = W_FIC+"> "+W_PRE
  When 5 : LEVA = W_FIC+">="+W_PRE
  When 6 : LEVA = W_FIC+"< "+W_PRE
  When 7 : LEVA = W_FIC+"<="+W_PRE
  When 8 : LEVA = "pat("+W_FIC+","+W_PRE+")"
Endcase
End
############################################################
Subprog GEN_CNDSQL(LCOD,LTYP,LCND,LIND,LEVA)
Value    Integer LCOD
Value    Integer LTYP
Value    Integer LCND
Value    Integer LIND
Variable Char    LEVA
#
Local    Char    W_PRE(30)
Local    Char    W_FIC(30)
Local    Char    W_SIGN(30)
Case LCOD
  When 1 : W_PRE = "[M:CFGH]QSTVAL"
  When 2 : W_PRE = "[M:CFGH]VARVAL"
  When 3 : W_PRE = "W_VAL"
Endcase
#W_FIC = "[F:CFH]VAL"
W_FIC = "VAL"   # directement nom de colonne en Sql
Case LCND
  When 2 : W_SIGN= "="
  When 3 : W_SIGN= "<>"
  When 4 : W_SIGN= ">"
  When 5 : W_SIGN= ">="
  When 6 : W_SIGN= "<"
  When 7 : W_SIGN= "<="
  When 8 : W_SIGN= " LIKE " ### avant = 'pat('+W_FIC+',"'+evalue(W_PRE)+'")'
  When Default : W_SIGN=" LIKE "
Endcase
Case LTYP
  When 1 :
    W_PRE += "ALP"+"("+num$(LIND)+")"
    W_FIC += "ALP_0"
    LEVA =  W_FIC+W_SIGN+"'"+evalue(W_PRE)+"'"
  When 2 :
    W_PRE += "NUM"+"("+num$(LIND)+")"
    W_FIC += "NUM_0"
    LEVA =  W_FIC+W_SIGN+num$(evalue(W_PRE))
  When 3 :
    W_PRE += "DAT"+"("+num$(LIND)+")"
    W_FIC += "DAT_0"
    Case GTYPDBA
      When 1 : # Oracle
        LEVA = W_FIC+W_SIGN+"to_date('"+format$("D:DD[/]MM[/]YYYY",evalue(W_PRE))+"','dd/mm/yyyy')"
      When 2 : # Sql*Server
        LEVA = W_FIC+W_SIGN+"CONVERT(DATETIME, '"+format$("D:DD[/]MM[/]YYYY",evalue(W_PRE))+"', 103)"
    Endcase
  When 4 :
    W_PRE += "NUM"+"("+num$(LIND)+")"
    W_FIC += "NUM_0"
    LEVA =  W_FIC+W_SIGN+num$(evalue(W_PRE))
Endcase
End
