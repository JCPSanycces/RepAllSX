#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "OUVRE"  : Gosub OUVRE From CPTRPT
 When "INIPAR" : Gosub INIPAR From CPTRPT
 When "CONT1"  : Gosub CONT1
Endcase
Return

$CONT1
Gosub CONT1 From CPTRPT

Case [M]PARCOD(nolign-1)
 When "borne5"

Local Integer I,K
Local Integer BORNE1,BORNE2,BORNE3,BORNE4,BORNE5
Raz BORNE1,BORNE2,BORNE3,BORNE4,BORNE5

K = find("borne1",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K : BORNE1 = val([M:RPT]VALINT1(K-1)) : Endif
K = find("borne2",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K : BORNE2 = val([M:RPT]VALINT1(K-1)) : Endif
K = find("borne3",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K : BORNE3 = val([M:RPT]VALINT1(K-1)) : Endif
K = find("borne4",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K : BORNE4 = val([M:RPT]VALINT1(K-1)) : Endif
K = find("borne5",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K : BORNE5 = val([M:RPT]VALINT1(K-1)) : Endif

For I=2 To 5
 If evalue("BORNE"+num$(I))>=evalue("BORNE"+num$(I-1))
  GMESSAGE = mess(39,104,1)
  mkstat=2 : Break
 Endif
Next I

Endcase
Return


####################################################
## Etats BALGEHIST
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

####################################################
## Vérif paramètres
####################################################
GOK = 1
Call IMPRIME(NBPAR,PARAMETRE) From CPTRPT
If GOK<1 : End : Endif

Call TEMPON("O") From GESECRAN

####################################################
## Récup paramètres
####################################################
Local Char    PARAM(30) , ETAT(GLONARP)
Local Integer NUMREQ , LIGNE
Local Integer I , J , OK

Local Char    SOCIETE(GLONCPY) , SITDEB(GLONFCY) , SITFIN(GLONFCY)
Local Char    CPTDEB(GLONGAC)  , CPTFIN(GLONGAC)
Local Char    COLDEB(GLONSAC)  , COLFIN(GLONSAC) , GRPCOL(GLONGSC)
Local Integer TRI
Local Date    DATREF
Local Integer EFFACE, ECRISIM

Local Integer ICRIT
Local Char    CRITERE(250)(1..5)
Local Clbfile SUBCRIT(1)
Local Char    X3PRF(10) , X3FCT(10)
Local Char    SVG_FLGEVT

Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : NUMREQ = val(PARAM)
Call GETPARAM("X3ETA",NBPAR,PARAMETRE,PARAM)
J = instr(1,PARAM,".")
If J : PARAM = left$(PARAM,J-1) : Endif
ETAT = PARAM

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE)
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITDEB)
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITFIN)
Call GETPARAM("coldeb",NBPAR,PARAMETRE,COLDEB)
Call GETPARAM("colfin",NBPAR,PARAMETRE,COLFIN)
Call GETPARAM("grpcol",NBPAR,PARAMETRE,GRPCOL)
Call GETPARAM("tiersdeb",NBPAR,PARAMETRE,CPTDEB)
Call GETPARAM("tiersfin",NBPAR,PARAMETRE,CPTFIN)
Call GETPARAM("datref",NBPAR,PARAMETRE,PARAM)    : DATREF   = PARAM
Call GETPARAM("tri",NBPAR,PARAMETRE,PARAM)       : TRI      = val(PARAM)
Call GETPARAM("efface",NBPAR,PARAMETRE,PARAM)    : EFFACE   = val(PARAM)
Call GETPARAM("ecrisim",NBPAR,PARAMETRE,PARAM)   : ECRISIM  = val(PARAM)
Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)

Gosub OUVFIC

####################################################
## Affectation du no de requête
####################################################
PARAM = num$(NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

####################################################
## Effacement table temporaire
####################################################
If EFFACE
 Call DEBTRANS From GLOCK
 Gosub TR3
Endif

####################################################
## Parcours des écritures
####################################################

Raz CRITERE
ICRIT = 1

## Critères généraux
Call ADDCRIT(CRITERE,ICRIT,'[FGR]CPY="'+SOCIETE+'"')
If SITDEB<>""
 Call ADDCRIT(CRITERE,ICRIT,'[HDU]FCY>="'+SITDEB+'"')
Endif
If SITFIN<>""
 Call ADDCRIT(CRITERE,ICRIT,'[HDU]FCY<="'+SITFIN+'"')
Endif
If COLDEB<>""
 Call ADDCRIT(CRITERE,ICRIT,'[HDU]SAC>="'+COLDEB+'"')
Endif
If COLFIN<>""
 Call ADDCRIT(CRITERE,ICRIT,'[HDU]SAC<="'+COLFIN+'"')
Endif
If CPTDEB<>""
 Call ADDCRIT(CRITERE,ICRIT,'[HDU]BPR>="'+CPTDEB+'"')
Endif
If CPTFIN<>""
 Call ADDCRIT(CRITERE,ICRIT,'[HDU]BPR<="'+CPTFIN+'"')
Endif
If GRPCOL<>""
 Gosub SETSOC
 If SOC<>""
  Read [GCM]GCM0 = [F:CPY]ACM
  Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
 Endif

 SUBCRIT = 'find([F:HD2]SAC'
 For [GSC]GSC0 Where COA = [F:LED]COA & GRU=GRPCOL
  SUBCRIT += ',"'+[F:GSC]SAC+'"'
 Next
 SUBCRIT += ")"
Else
 SUBCRIT = ""
Endif

Call ADDCRIT(CRITERE,ICRIT,'[F:HDU]DATEVT<=['+num$(DATREF)+']')
Call ADDCRIT(CRITERE,ICRIT,'[HAE]FLGREP<>2')

If ECRISIM
 Call ADDCRIT(CRITERE,ICRIT,'find([HAE]CAT,1,2,4)<>0')
Else
 Call ADDCRIT(CRITERE,ICRIT,'([HAE]CAT=1 | [F:HAE]CAT=4)')
Endif

For I=1 To dim(CRITERE)
 If CRITERE(I)="" : CRITERE(I) = "1=1" : Endif
Next I

Link [HDU] With [HAE]HAE0~=[F:HDU]TYP;[F:HDU]NUM , [FGR]FGR0~=SOCIETE;[F:HDU]FCY , [GSC]GSC1=[F:LED]COA;GRPCOL;[F:HDU]SAC
&              ,[BPR]BPR0~=[F:HDU]BPR , [ACC]CODACC=GUSER;[F:BPR]ACS , [AFF]AFF0=[F:HDU]FCY;X3PRF;X3FCT
&   As [LNK]
&   Where evalue(CRITERE(1)) & evalue(CRITERE(2)) & evalue(CRITERE(3)) & evalue(CRITERE(4))
&   & [F:ACC]CONSUL=2 & [F:AFF]PRFCOD<>""

Columns [LNK] ([HDU]TYP,[HDU]NUM,[HDU]FCY,[HDU]SAC,[HDU]BPR,[HDU]ACCNUM,[HDU]DUDLIG,[HDU]BPRPAY)

GOK = 1
LIGNE = 0
Call DEBTRANS From GLOCK
Trbegin [ARM]

#CHECK FILE_DECLARE HISTODUD [HD2]

For [F:LNK]HDU3(2) Nohint
  Raz OK
  Filter [HD2] Where ACCNUM=[HDU]ACCNUM & DUDLIG=[HDU]DUDLIG & (DATEVT<>[0/0/0] | FLGCLE=3)
  For [HD2]HDU3 Nohint

   # Echéances validées... 1ère étape
   If !OK & ([F:HD2]FLGCLE=1 or [F:HD2]FLGCLE=4) & [F:HD2]DUDSTA=2 & [F:HD2]DATEVT<=[L]DATREF  & SVG_FLGEVT=""
    If (COLDEB="" or [F:HD2]SAC>=COLDEB) & (COLFIN="" or [F:HD2]SAC<=COLFIN) &
&      (CPTDEB="" or [F:HD2]BPR>=CPTDEB) & (CPTFIN="" or [F:HD2]BPR<=CPTFIN) &
&      (SUBCRIT="" or evalue(SUBCRIT))

     LIGNE += 1
     Raz [F:ARM]
     [F:ARM]RPTCOD = ETAT
     [F:ARM]USR    = GUSER
     [F:ARM]NUMREQ = NUMREQ
     [F:ARM]NUMLIG = LIGNE
     [F:ARM]CLEA1  = [F:HD2]BPR
     [F:ARM]CLEN1 = [F:HD2]ACCNUM
     [F:ARM]CLEN2 = [F:HD2]DUDLIG
     [F:ARM]CLEN3 = [F:HD2]NUMHDU
     [F:ARM]CREDAT = date$
     OK=1
    Endif
   Elsif OK
    # Echéances annulées (annulation comptable ou suppression réel)
    If [F:HD2]DUDSTA<>2 or [F:HD2]FLGCLE=3
     LIGNE -= 1 : Raz OK
    # Echéances annulation comptable avec changement d'"entête"
    Elsif ([F:HD2]SAC<>[F:HDU]SAC or [F:HD2]BPR<>[F:HDU]BPR or  [F:HD2]BPRPAY<>[F:HDU]BPRPAY) and [F:HD2]DATEVT<=[L]DATREF
      LIGNE-=1   : Raz OK
      # Par contre, si l'échange modifié fait partie de la sélection de l'édition, il faut la garder et la mettre à jour.
      If (COLDEB="" or [F:HD2]SAC>=COLDEB) & (COLFIN="" or [F:HD2]SAC<=COLFIN) &
&        (CPTDEB="" or [F:HD2]BPR>=CPTDEB) & (CPTFIN="" or [F:HD2]BPR<=CPTFIN) &
&        (SUBCRIT="" or evalue(SUBCRIT))   & ([F:HD2]FLGCLE=1 or [F:HD2]FLGCLE=4) & [F:HD2]DUDSTA=2
           LIGNE +=1 : OK = 1
           [F:ARM]CLEA1 = [F:HD2]BPR
           [F:ARM]CLEN3 = [F:HD2]NUMHDU
      Endif
    # Echéances soldées (déjà réglées)
    Elsif [F:HD2]FLGCLE=2 and [F:HD2]DATEVT<=[L]DATREF
     LIGNE -= 1 : Raz OK
    # Modification d'échéances avant règlements
    Else
     If [F:HD2]DATEVT<=[L]DATREF
      If SVG_FLGEVT="" | (SVG_FLGEVT<>"" & [F:HD2]TMPCUR=0)
       [F:ARM]CLEN3=[F:HD2]NUMHDU
      Else
       Raz SVG_FLGEVT
      Endif
     Else
      SVG_FLGEVT = [F:HD2]FLGEVT
     Endif
    Endif
   Else
    SVG_FLGEVT = [F:HD2]FLGEVT
   Endif
  Next
  Gosub TR1
 Filter [HD2]
Next
Filter [F:LNK]
Commit
Call TEMPOFF From GESECRAN
End

$SETSOC
Local Char SOC(GLONCPY)
SOC = ""
K = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K
 SOC = [M:RPT]VALINT1(K-1)
 Read [CPY]CPY0 = SOC
 If [F:CPY]CPYLEGFLG<>2
  Read [FGR]FGR0(1) = SOC
  Read [FCY]FCY0 = [F:FGR]FCY
  SOC = [F:FCY]LEGCPY
  Read [CPY]CPY0 = SOC
 Endif
Endif
Return


$TR1
If OK=1
 Write [ARM]
 If fstat
  GOK = 0 : Call FSTA("ARM") From GLOCK
 Endif
 If GOK<1 : Goto AB_TR1 : Endif
Endif
Return

$AB_TR1
Rollback
Return

$TR3
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=ETAT & USR=GUSER
Commit
Return

$OUVFIC
If clalev([F:ARM])=0 : Local File AREPORTM   [ARM] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:HDU])=0 : Local File HISTODUD   [HDU] : Endif
If clalev([F:HD2])=0 : Local File HISTODUD   [HD2] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:GSC])=0 : Local File GRPSAC     [GSC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER  [BPR] : Endif
If clalev([F:ACC])=0 : Local File ACCES     [ACC] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY   [AFF] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
Return

Subprog ADDCRIT(CRITERE,ICRIT,SUBCRIT)
Variable Char    CRITERE()(1..)
Variable Integer ICRIT
Value    Char    SUBCRIT
If len(CRITERE(ICRIT))+len(SUBCRIT)>240
 ICRIT += 1
Endif
If CRITERE(ICRIT)<>"" : CRITERE(ICRIT) -= "&" : Endif
CRITERE(ICRIT) -= SUBCRIT
End

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End
