#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SVCRINVCND

#--------------------------------------
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case CURPTH
      When ""
                        Case [L]AEVENT
                          When "AINSERT" :
                          #----------------Standard methods (Events)-------------------
                          When "AREAD_AFTER"                        : Gosub AREAD_AFTER                   From SVCRINVCND_EVENTS
                          When "AREAD_BEFORE"                       : Gosub AREAD_BEFORE                  From SVCRINVCND_EVENTS
                          When "AINSERT_CONTROL_BEFORE"             : Gosub AINSERT_CONTROL_BEFORE        From SVCRINVCND_EVENTS
                          When "ACONTROL"                           : Gosub ACONTROL                      From SVCRINVCND_EVENTS
                          When "AUPDATE_CONTROL_BEFORE"             : Gosub AUPDATE_CONTROL_BEFORE        From SVCRINVCND_EVENTS
                        Endcase
      When "VCRINVCNDLIN"
                        Case [L]AEVENT
                          When "AREAD_BEFORE"                       : Gosub VCRINVCNDLIN_AREAD_BEFORE     From SVCRINVCND_EVENTS
                          When "AREAD_AFTER"                        : Gosub VCRINVCNDLIN_AREAD_AFTER      From SVCRINVCND_EVENTS
                          When "ADELLINE_AFTER"                     : Gosub VCRINVCNDLIN_ADELLINE_AFTER   From SVCRINVCND_EVENTS
                          When "ADDLINE_AFTER"                      : Gosub VCRINVCNDLIN_ADDLINE_AFTER    From SVCRINVCND_EVENTS
                          When "ACONTROL"                           : Gosub VCRINVCNDLIN_ACONTROL         From SVCRINVCND_EVENTS
                          When "AUPDATE_BEFORE"                     : Gosub VCRINVCNDLIN_AUPDATE_BEFORE   From SVCRINVCND_EVENTS
                          When "ADELLINE_BEFORE"                    : Gosub VCRINVCNDLIN_ADELLINE_BEFORE  From SVCRINVCND_EVENTS
                        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
                          When "INIT_FROM_ORDER"                    : Gosub INIT_FROM_ORDER                From SVCRINVCND_METHODS
                          When "CREATE_DETAIL_SCHEDINV"             : Gosub CREATE_DETAIL_SCHEDINV         From SVCRINVCND_METHODS
                          When "RECALC_PERCENT_ALL_LINES"           : Gosub RECALC_PERCENT_ALL_LINES       From SVCRINVCND_METHODS
                          When "EQUIL_TOT_PERCENT_ON_LAST_LINE"     : Gosub EQUIL_TOT_PERCENT_ON_LAST_LINE From SVCRINVCND_METHODS
                          When "DISPATCH_ON_ALL_LINES"              : Gosub DISPATCH_ON_ALL_LINES          From SVCRINVCND_METHODS
                          When "DISPATCH_ON_LASTLINE"               : Gosub DISPATCH_ON_LASTLINE           From SVCRINVCND_METHODS
                          When "CHANGE_SCHEDULING_DATE"             : Gosub CHANGE_SCHEDULING_DATE         From SVCRINVCND_METHODS
                          When "SET_CLOSED_SCHEDINV_LINES"          : Gosub SET_CLOSED_SCHEDINV_LINES      From SVCRINVCND_METHODS
                          When "SET_NOTCLOSED_SCHEDINV_LINES"       : Gosub SET_NOTCLOSED_SCHEDINV_LINES   From SVCRINVCND_METHODS
                          When "SET_INVOICE_QTY_CHANGED"            : Gosub SET_INVOICE_QTY_CHANGED        From SVCRINVCND_METHODS
                          When "SET_INVOICE_AMT_CHANGED"            : Gosub SET_INVOICE_AMT_CHANGED        From SVCRINVCND_METHODS
                          When "SET_INVOICE_PRC_CHANGED"            : Gosub SET_INVOICE_PRC_CHANGED        From SVCRINVCND_METHODS
                          When "SET_INVOICE_PRICE_CHANGED"          : Gosub SET_INVOICE_PRICE_CHANGED      From SVCRINVCND_METHODS
                          When "SET_LINE_STATUS"                    : Gosub SET_LINE_STATUS                From SVCRINVCND_METHODS
                          When "SET_LINE_INVOICE_NUM"               : Gosub SET_LINE_INVOICE_NUM           From SVCRINVCND_METHODS
                          When "TOTAL_ADD_FROM_INVOICE"             : Gosub TOTAL_ADD_FROM_INVOICE         From SVCRINVCND_METHODS
                          When "TOTAL_REMOVE_FROM_INVOICE"          : Gosub TOTAL_REMOVE_FROM_INVOICE      From SVCRINVCND_METHODS
                          When "GET_REMAINING_TO_INVOICE"           : Gosub GET_REMAINING_TO_INVOICE       From SVCRINVCND_METHODS
                          When "GET_INVOICED_VALUES"                : Gosub GET_INVOICED_VALUES            From SVCRINVCND_METHODS
                          When "GET_LINE_INVOICED_VALUES"           : Gosub GET_LINE_INVOICED_VALUES       From SVCRINVCND_METHODS
                          When "SET_CREDITNOTE_UPDTOTALS"           : Gosub SET_CREDITNOTE_UPDTOTALS       From SVCRINVCND_METHODS
  Endcase
  #--Supervisor bug ??
  If dim([L]ASTATUS)>0 and dim([L]ARET_VALUE)>0
    [L]ASTATUS = [L]ARET_VALUE
  Endif
Return
#---------------------------------------------------------------
$PROPERTIES
  Case [L]ARULE
      When "INIT"      :
                          Case CURPRO
                            When "VCRTYP"                    : Gosub INIT_VCRTYP                           From SVCRINVCND_PROPERTIES
                          Endcase
      When "CONTROL"   :
                          Case CURPRO
                            When "VCRTYP"                    : Gosub CONTROL_VCRTYP                        From SVCRINVCND_PROPERTIES
                            When "VCRNUMORI"                 : Gosub CONTROL_VCRNUMORI                     From SVCRINVCND_PROPERTIES
                            When "VCRINVCNDDAT"              : Gosub CONTROL_VCRINVCNDDAT                  From SVCRINVCND_PROPERTIES
                          Endcase
      When "PROPAGATE" :
                          Case CURPRO
                            When "VCRTYP"                    : Gosub PROPAGATE_VCRTYP                      From SVCRINVCND_PROPERTIES
                            When "SALFCY"                    : Gosub PROPAGATE_SALFCY                      From SVCRINVCND_PROPERTIES
                            When "CUR"                       : Gosub PROPAGATE_CUR                         From SVCRINVCND_PROPERTIES
                            When "SAU"                       : Gosub PROPAGATE_SAU                         From SVCRINVCND_PROPERTIES
                            When "VCRINVCNDLIN.INVPERCENT"   : Gosub PROPAGATE_VCRINVCNDLIN_INVPERCENT     From SVCRINVCND_PROPERTIES
                            When "VCRINVCNDLIN.INVCNDQTY"    : Gosub PROPAGATE_VCRINVCNDLIN_INVCNDQTY      From SVCRINVCND_PROPERTIES
                            When "VCRINVCNDLIN.INVCNDAMTNOT" : Gosub PROPAGATE_VCRINVCNDLIN_INVCNDAMTNOT   From SVCRINVCND_PROPERTIES
                            When "VCRINVCNDLIN.INVCNDAMTATI" : Gosub PROPAGATE_VCRINVCNDLIN_INVCNDAMTATI   From SVCRINVCND_PROPERTIES
                          Endcase
  Endcase
Return
#---------------------------------------------------------------

