#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################################################
# Gestion d'affectation des secteurs marketing     Module action commerciale                  février 2007
##########################################################################################################
##########################################################################################################
$ACTION
  #--- Actions liées au traitement standard
  Case ACTION
    When "INIT"        : Gosub INIT
    When "OUVRE_BATCH" : Gosub INIT
    When "INIT_DIA"    : Gosub INIT_DIA
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE
    When Default
  Endcase
Return

##########################################################################################################
$INIT
  If GMODU(13) = 2 Then
    # En batch , il vaut mieux mettre onerrgo
    If GSERVEUR Then
      Onerrgo ERRBATCH
    Endif
    Gosub OUVRE
  Else
    #Le module Action commerciale n'est pas activé. Fonction inaccessible.
    GMESSAGE = mess(243,177,1)
    GERR = 2
    FIN = 1
    Return
  Endif
Return

##########################################################################################################
$INIT_DIA
  Raz [M:MST6]
Return

##########################################################################################################
$EXEC
Local Integer INBRECORDTRT
Local Integer INBRECORDADRTRT
Local Integer IBRETOUR
Local Integer IBERROR
Local Char SZMESSAGE(250)

  Raz SZMESSAGE
  #---------------------------------------------------#
  Gosub INIT_VARIABLE From SUBMSTB1
  INBRECORDTRT = 0
  If !GSERVEUR Then
    # Ouverture de la trace
    #Affectation des secteurs de marché
    Call OUVRE_TRACE(mess(568,177,1)) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MST6","MST6","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Endif
  If IDIMREP_BPC = 0 Then
    #Les représentants ne sont pas gérés
    Call ECR_TRACE(mess(575,177,1),1) From GESECRAN
    Return
  Endif
  Gosub TRTMST
Return

##########################################################################################################
$TRTMST
Local Integer ICOUNT
Local Integer IOK
Local Integer IBTROUVE
Local Integer IBTRT
Local Char SZWHERE(250)(20)
Local Integer ILIGNEWHERE
Local Char SZAND(10)
Local Char SZVALEUR(100)
Local Char SZRECHERCHE(100)
Local Integer IBNONVIDE
Local Integer ILIGNE
Local Integer INBLIGNETOTAL

  IOK = func SUBMSTB1.GENTRT_VALIDE(2)
  If func SUBMSTB1.GENTRT_VALIDE(1) Then
    Call ECR_TRACE(mess(649,177,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(650,177,1),0) From GESECRAN
  Endif
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0) From GESECRAN
  ICOUNT = 0
  IOK = 0
  IBTROUVE = 0
  IBTRT = 0
  INBNONTRT = 0
  INBTRTOK = 0
  INBTRTKO = 0
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  IBNONVIDE = 0
  ILIGNE = 0
  INBLIGNETOTAL = 0
  ILIGNEWHERE = 0
  Raz SZWHERE
  SZAND = ""
  SZWHERE(ILIGNEWHERE) = "([F:BPR]BPCFLG=2 or [F:BPR]PPTFLG=2) "
  ILIGNEWHERE += 1
  SZAND = " AND "
  If [M]BPRMIN <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:BPR]BPRNUM>=[M]BPRMIN"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M]BPRMAX <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:BPR]BPRNUM<=[M]BPRMAX"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  ILIGNE = 0
  While ILIGNE < ILIGNEWHERE
    If SZWHERE(ILIGNE) <> "" Then
      IBNONVIDE = 1
    Endif
    ILIGNE += 1
  Wend
  #
  If IBNONVIDE = 1 Then
    Filter [BPR] Where evalue(SZWHERE) Order By BPRNUM
  Else
    Filter [BPR] Order By BPRNUM
  Endif
  If !GSERVEUR Then
    INBRECORDTRT = rowcount([BPR])
    #Traitement des tiers
    Call OUVRE_BOITE(mess(569,177,1), INBRECORDTRT) From GESECRAN
    #num$(INBRECORDTRT) tiers à traiter
    Call ECR_TRACE(num$(INBRECORDTRT) - mess(570,177,1),0) From GESECRAN
  Endif
  INBNONTRT = 0
  INBTRTOK = 0
  INBTRTKO = 0
  #
  For [BPR]
    If !GSERVEUR Then
      ICOUNT += 1
      Call AFF_BOITE ([F:BPR]BPRNUM, ICOUNT, IOK) From GESECRAN
    Endif
    #
    Call DEBTRANS From GLOCK
    Trbegin [BPC]
    #Traitement du tiers" : "+[F:BPR]BPRNUM
    Call ECR_TRACE(mess(571,177,1) - ":" - [F:BPR]BPRNUM,0) From GESECRAN
    Gosub TRTONEBPPR
    If adxlog Then
      If GOK < 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif
  Next
  #
  IOK = func SUBMSTB1.GENTRT_VALIDE(2)  # FGR 09/04/2010 : X3SUIVI63627
  Call ECR_TRACE(num$(INBRECORDTRT) - mess(572,177,1),0) From GESECRAN      #num$(INBRECORDTRT) tiers sélectionnés
  Call ECR_TRACE(num$(INBRECORDADRTRT) - mess(573,177,1),0) From GESECRAN   #num$(INBRECORDADRTRT) tiers/adresse sélectionnés
  Call ECR_TRACE(num$(INBNONTRT) - mess(578,177,1),0) From GESECRAN         #num$(INBNONTRT)+" " + tiers/adresse non traités
  Call ECR_TRACE(num$(INBTRTOK) - mess(579,177,1),0) From GESECRAN          #num$(INBTRTOK)+" " + tiers/adresse affectés
  Call ECR_TRACE(num$(INBTRTKO) - mess(580,177,1),0) From GESECRAN          #num$(INBTRTKO)+" " + tiers/adresse non affectés
  Call ECR_TRACE(mess(581,177,1),0) From GESECRAN                           #Fin du traitement d'affectation des secteurs
Return

##########################################################################################################
$TRTONEBPPR
  IREPONSE_REP = 0      # FGR 29/10/2009 : X3SUIVI59338
  IREPONSE_SECTEUR = 0  # FGR 29/10/2009 : X3SUIVI59338
  Read [BPC]BPC0=[F:BPR]BPRNUM
  If fstat <> 0 Then
    GOK = 0
    #Erreur lors de la lecture du client
    Call ECR_TRACE(mess(317,177,1) - ":" - [F:BPR]BPRNUM,1) From GESECRAN
    Return
  Endif
  #SZADRDEFAUT = [F:BPC]BPAADD # FGR 13/04/2010 : X3SUIVI63973 : [F:BPR]BPAADD et ne sert à rien
  #recherche des secteurs
  IREPONSE = 0
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BPR]BPRNUM
  For [BPA]
    If [F:BPR]BPCFLG = 2 Then
      #Il faut lire les clients livrés
      Read [BPD]BPD0=[F:BPR]BPRNUM;[F:BPA]BPAADD
      If fstat <> 0 Then
        Raz [F:BPD]
      Endif
    Endif
    #On compte les nombre de tiers/adressse
    INBRECORDADRTRT += 1
    #Traitement de l'adresse - ":" - [F:BPA]BPAADD - ":" -  [F:BPA]BPADES
    Call ECR_TRACE("    " + mess(574,177,1) - ":" - [F:BPA]BPAADD - ":" - [F:BPA]BPADES,0) From GESECRAN
    Call GERE_ONE_BPC_ADR_SEC(IDIMREP_BPC, IDIMREP_BPD, IDIMREP_BRS, [F:BPC]BPCNUM, [F:BPC]BPAADD, [F:BPA]BPAADD, [F:BPR]BPCFLG, 1, [M:MST6]MANASSREP, [M:MST6]MANASSSCT, IREPONSE_REP,
&                             IREPONSE_SECTEUR, INBTRTOK, INBNONTRT, INBTRTKO) From SUBMSTB1
    If GOK < 1 Then
      Break
    Endif
  Next
  Filter [BPA]
Return

##########################################################################################################
$OUVRE
Local Char TIT(50)

  #Affectation des secteurs de marché
  TIT = mess(568,177,1)
  #Ouvre les fichiers utilisés dans l'affichage des données de synchronisation
  # Issue X3-61585 - 2018-04-19 by FGR : BEGIN
  #If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  #If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  #If !clalev([F:BPD]) : Local File BPDLVCUST [BPD] : Endif
  #If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  #If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  #If !clalev([F:MAR]) : Local File MARASSREP [MAR] : Endif
  #If !clalev([F:MAR2]) : Local File MARASSREP [MAR2] : Endif
  #If !clalev([F:RSE]) : Local File REPSEC [RSE] : Endif
  #If !clalev([F:MAD]) : Local File MARASSDEF [MAD] : Endif
  #If !clalev([F:MST]) : Local File MARSCT [MST] : Endif
  #If !clalev([F:MDF]) : Local File MARDEF [MDF] : Endif
  #If !clalev([F:MRS]) : Local File MARREPSEC [MRS] : Endif
  Local File BPARTNER [BPR]
  Local File BPCUSTOMER [BPC]
  Local File BPDLVCUST [BPD]
  Local File SALESREP [REP]
  Local File BPADDRESS [BPA]
  Local File MARASSREP [MAR]
  Local File MARASSREP [MAR2]
  Local File REPSEC [RSE]
  Local File MARASSDEF [MAD]
  Local File MARSCT [MST]
  Local File MARDEF [MDF]
  Local File MARREPSEC [MRS]
  # Issue X3-61585 - 2018-04-19 by FGR : END
Return

##########################################################################################################
$TERMINE
  If !GSERVEUR Then
    Call FERME_BOITE From GESECRAN
  Endif
  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
    TRA = 1
  Endif
Return


##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

