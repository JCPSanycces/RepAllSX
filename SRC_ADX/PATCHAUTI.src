#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################
## Utility process - patch
# MODOBJ and ACVOBJ  are defined in PATCH TRT.
# in modification at the moment : rewrite in any case of scm
# only rewrite if launched  = NO
###################################################
$AUTILITY
Local Integer SAV_LAUNCHNBR
#
Local File =APPLI+".AUTILITY" [AUTI]
Local File =APPLI+".AUTILITY" [ZAUTI]

FICHIER = "AUTILITY" : ABR = "AUTI"
Read [AUTI]AUTI0 = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
    If TYPENR=-2
        Gosub DEL_AUTI
        Gosub FIN_OBJ From PATCH
    Else
        Read [ZAUTI]AUTI0 = NOMOBJ
        If fstat = 0
            SAV_LAUNCHNBR = [F:ZAUTI]LAUNCHNBR
            If [L]ISFULLMOD <> 2
                # for customer if uti not launched , rewrite
                # else nothing to do
                If [F:ZAUTI]LAUNCHSTATUS = 1
                    NEWOBJ = 0
                    Gosub TR_AUTI
                Else
                    Gosub FIN_OBJ From PATCH
                Endif
            Else
                # scm rewrite in case of error to be sure this uti is launched
                # else nothing to do (to let the dev to be able to modify in case of error
                If [F:ZAUTI]LAUNCHSTATUS = 4
                    NEWOBJ = 0
                    Gosub TR_AUTI
                Else
                    Gosub FIN_OBJ From PATCH
                Endif
            Endif
        Else
            # not possible but  in case.....
            Gosub FIN_OBJ From PATCH
        Endif
    Endif
Else
    # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
    If TYPENR<>-2
        NEWOBJ = 1
        Raz [F:AUTI]
        Gosub TR_AUTI
    Else
        Gosub FIN_OBJ From PATCH
    Endif
Endif

LogicClose File [AUTI]
LogicClose File [ZAUTI]

Return

$DEL_AUTI
Trbegin [AUTI]
Delete [AUTI] Curr
If fstat<>[V]CST_AOK
    Call LOG_ERROR_DETAILS(3, "AUTI", [F:AUTI]UTICOD, "") From GLOCK
    GOK = 0 : ER = 99 : ERFIC = "AUTILITY"-NOMOBJ : Rollback : Return
Endif
Commit

If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AUTI",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ

Return

$TR_AUTI
Call DEBTRANS From GLOCK
Trbegin [AUTI]
Repeat
    Gosub LIRE From PATCH
    Case TYPENR
        When 7,13 : # Fin normale
            Break
        When 3 :
            IDENT = CHAMP(2)
            Case CHAMP(1)
                When "AUTI"   : Gosub AUTI1
                When Default  : ER = 31
            Endcase
        When Default
            ER = 32
    Endcase
    If ER or !OKOBJ : Break : Endif
Until 1=0
If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AUTI",[F:AUTI]UTICOD,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

$AUTI1
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ
   If VARIA="ACS" and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

# on marque qu il y a eu un auti. de patcher
# on utilisera ce flag pour lancer exe à la fin fin  du patch
If dim(ISAUTI_PROCESS)>0
     ISAUTI_PROCESS += 1
Endif
MODOBJ = max(1,[F:AUTI]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
     OKOBJ = 0 : Return
Endif
ACVOBJ = [F:AUTI]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
   Read [ACV]CODACT = ACVOBJ
   If fstat | [F:ACV]FLACT<>2
          OKOBJ = 0 : Return
   Endif
Endif
If NEWOBJ
    # caution because if we don't use scm  the patch can contain some wrong information
    # like status....updateflg
    If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        # always this flag set = NO (modification not authorized)
        # voir les uti en spe..... on fait quoi ????
        [F:AUTI]UPDATEFLG = 1
        #
        [F:AUTI]LAUNCHNBR    = 0
        [F:AUTI]LAUNCHSTATUS = 1
        # si le type lancement non actif en patch
        # on met a jour status en non actif ne pas lancer ensuite
        If [F:AUTI]LAUNCHTYP  = 4
              [F:AUTI]LAUNCHSTATUS = 3
        Else
              [F:AUTI]LAUNCHSTATUS = 1
        Endif
        Raz [F:AUTI]LOGFIL
        Raz [F:AUTI]LAUNCHDAT
        Raz [F:AUTI]LAUNCHUSR
        Raz [F:AUTI]LASLAUNCHDAT
        Raz [F:AUTI]LASLAUNCHUSR
        Raz [F:AUTI]RELEASE
        Call FLDCRE("AUTI") From OBJDIV
    Endif
    Write [AUTI]
    If fstat
        Call LOG_ERROR_DETAILS(1, "AUTI", [F:AUTI]UTICOD, "") From GLOCK
        GOK = 0 : ER = 99 : ERFIC = "AUTILITY"-NOMOBJ
        Return
    Endif
Else
    If [L]ISFULLMOD <> 2  : # Patch not for scm - ISFULLMOD = 2 when SCM
         Call FLDUPD("AUTI") From OBJDIV
    Endif
    # always this flag set = NO (modification not authorized)
    [F:AUTI]UPDATEFLG = 1
    # si le type lancement non actif en patch
    # on met a jour status en non actif ne pas lancer ensuite
    If [F:AUTI]LAUNCHTYP  = 4
           [F:AUTI]LAUNCHSTATUS = 3
    Else
           [F:AUTI]LAUNCHSTATUS = 1
    Endif
    # never overwrite the number of launch
    [F:AUTI]LAUNCHNBR = SAV_LAUNCHNBR
    Rewrite [AUTI]
    If fstat
          Call LOG_ERROR_DETAILS(2, "AUTI", [F:AUTI]UTICOD, "") From GLOCK
          GOK = 0 : ER = 99 : ERFIC = "AUTILITY"-NOMOBJ
          Return
    Endif
Endif
Return

$ABORT
Rollback
Return

