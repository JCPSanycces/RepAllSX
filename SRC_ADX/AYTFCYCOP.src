#<AdxTL>@(#)9.0.0.0 $Revision$
 Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = nomap
  PARBOUT(2) = GAYTFCYCOP
  PARBOUT(3) = ""
  PARBOUT(4) = ""
  PARBOUT(5) = ""
  PARBOUT(6) = ""
  PARBOUT(7) = ""
  FLGEXE = 1
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","AYTFCYCOP","AYTFCYCOP",3,"") From GTRAITE
End
######################################################################################
## Xtend: Gestion copie site Xtend
######################################################################################
##  Gestion Ecran
#    AYTFCYCOP
#
##  Actions
#    AYTFCYCOP    Copie d'un site Xtend
#
##  Gosub
#
##  Subprog
#    FCYCOPPRG       Trt de copie d'un site Xtend
#
#  Rq #*: déactivation code activité 
######################################################################################
$ACTION
  #Call ECR_TRACE("Action:"-ACTION,0)From GESECRAN
  If dim([L]PTRTB)<=0        # Perso par produit
    Local Integer PTRTB
    Call EXISTE_ADX("","","AYTFCYDELB",PTRTB) From ORDSYS
  Endif
  Case ACTION
    When "INIT"         : Gosub FCYCOP_INI
    When "INIT_DIA"     : Gosub FCYCOP_DIA
    When "CONTROLE"     : Gosub FCYCOP_CTL
    When "EXEC"         : Gosub FCYCOP_EXEC
    When "SORTIE"       : Gosub FCYCOP_SORTIE
    When "AS_FCYDES"    : Gosub AV_SITWEBDES From AYTCOP
    When "AS_FCYORG"    : Gosub AV_SITWEBORG From AYTCOP
  Endcase
  If PTRTB: Gosub ACTION From AYTFCYDELB : Endif           # Perso par produit
Return

######################################################################################
#    AYSFCYCOP        Procédure de copie d’un site Xtend
#                     Ecran AYTFCYCOP
#        Param(1)      Dossier origine
#        Param(2)      Site Xtend origine
#        Param(3)      Dossier destination
#        Param(4)      Site Xtend destination
# $$$$
######################################################################################
$FCYCOP_INI
#-----------------------------
Local Char FCYORG(GLONAYS), WSTR1(200), WDES(50), WMSG(250)
Local Char DOSORG(GDIMFIC), MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000@XTEND ; sodaix01:5000 ; XTEND
Local Char DOSDES(GDIMFIC), MACDES(GDIMFIC), DOSNAMDES(GDIMFIC)
Local Char SAVACTION(10), WSTR(250)
Local Char LSTOBJCOD(3)(1..20)   : Local Integer LSTIND
Local Char OPTION(10)(1..10)     : Local Integer OPTIND
Local Integer RET, WI

DOSORG = PARAM(1)
FCYORG = PARAM(2)
DOSDES = PARAM(3)
FCYDES = PARAM(4)
    
Return

$FCYCOP_DIA
#-----------------------------
[M:DIA]OBJCOD="AYS"
[M:DIA]ELTCOD=""
[M:DIA]FCYORG=FCYORG
[M:DIA]DOSORG=DOSORG
Gosub  FCYREADORG From AYTCOP     # classe AYS1
#* [M:DIA]CODACTORG=[F:AYS1]CODACT
#
[M:DIA]DOSDES=DOSDES
If [M:DIA]DOSDES=""
    If GDOSPATH<>"" 
        Call C_DOSSIER(GDOSPATH) From DOSCONT
        If mkstat
         mkstat = 0
        Else
         [M:DIA]DOSDES = GDOSPATH
        Endif
    Else
         [M:DIA]DOSDES = [M:DIA]DOSORG
    Endif
Endif
#
[M:DIA]FCYDES=FCYDES
If [M:DIA]FCYDES=""
  If GAYTFCYCOP="" 
    [M:DIA]FCYDES=[M:DIA]FCYORG
  Else
    [M:DIA]FCYDES=GAYTFCYCOP
  Endif
Endif
[L]DOSDES = [M:DIA]DOSDES : [L]FCYDES = [M:DIA]FCYDES : Gosub  FCYREADDES  From AYTCOP     # classe AYS2
#* If !fstat : [M:DIA]CODACTDES=[F:AYS2]CODACT : Endif

Call TITOBJ([M:DIA]OBJCOD,"",[M]DES) From CONTOBJ
[M:DIA]DES=[M:DIA]DES+":"-[M:DIA]FCYORG
Return

$FCYCOP_CTL
#-----------------------------
Gosub COP_CTLFCY From AYTCOP
If RET=0 : SAI=1 : Return : Endif
#
[L]DOSDES = [M:DIA]DOSDES : [L]FCYDES = [M:DIA]FCYDES : Gosub  FCYREADDES From AYTCOP      # classe AYS2
If !fstat
 Call OUINON(mess(219,7900,1),RET) From GESECRAN
 If RET=1 : SAI=1 : Return : Endif
Endif

#
If DESM1<>2 & PARM1 <>2 : GERR=1 : GMESSAGE=mess(147,7900,1) : SAI=1 : Return : Endif
Return

$FCYCOP_EXEC
#-----------------------------
WMSG=mess(26,7900,1)-[M:DIA]FCYORG-"("-[M:DIA]DOSORG-") -> "-[M:DIA]FCYDES-"("-[M:DIA]DOSDES-")"
If !GSERVEUR
  TRA=1
  Call TEMPON(WMSG) From GESECRAN
  Call OUVRE_TRACE(WMSG) From LECFIC
Else
  OPTIND+=1 : OPTION(OPTIND)="NOTEMPON"
Endif
#
Raz LSTIND, OPTIND
If [M:DIA]PARM1=2: LSTIND+=1 : LSTOBJCOD(LSTIND)="***" : Endif
If [M:DIA]DESM1=2: OPTIND+=1 : OPTION(OPTIND)="DESCOP" : Endif
If [M:DIA]TRAOPT=2: OPTIND+=1 : OPTION(OPTIND)="TRADET" : Endif   
Call FCYCOPPRG([M:DIA]DOSORG, [M:DIA]FCYORG,[M:DIA]DOSDES, [M:DIA]FCYDES, "",  LSTOBJCOD, OPTION, RET) 
If RET=0 : FIN=1 : Goto FCYCOP_FIN: Endif


$FCYCOP_FIN
If !GSERVEUR
  Call TEMPOFF() From GESECRAN 
Endif
Return

$FCYCOP_SORTIE
#-----------------------------
If clalev([F:AYS1]) : Close Local File [AYS1] : Endif
If clalev([F:AYS2]) : Close Local File [AYS2] : Endif
Return

######################################################################################
###     Utilitaires générations subprog et funprog 
######################################################################################
#------------------------------------------------------------#
# Copie d'un site Xtend
# $$$$
#------------------------------------------------------------#
Subprog FCYCOPPRG(DOSORG, FCYORG, DOSDES, FCYDES, NOTUSED, LSTOBJCOD, OPTION, RET)       
Value Char DOSORG              # sodaix01:5000@XTEND
Value Char FCYORG              # Site Xtend
Value Char DOSDES              # sodaix01:5000@XTEND
Value Char FCYDES              # Site Xtend
Value Char NOTUSED             # Libre  (Ancien code activité destination: CODACTDES)
Value Char LSTOBJCOD()(1..)    # Liste des objets Xtend à copier AYG, AYS... ou "***" pour tous
Value Char OPTION()(1..)       # Options 
                               #   'TRADET'    =Trace détaillée
                               #   'DESCOP'    =Copie du design
                               #   'NOTEMPON'  =Pas de popup avancement
Variable Integer RET : RET=1   # 0:Ko 1: Ok
#
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        #  sodaix01:5000 ; XTEND
Local Char MACDES(GDIMFIC), DOSNAMDES(GDIMFIC)
Local Char OBJCOD(GLONAOB), ELTCOD(GLONAY9), ELTCODSUP(GLONAYC),  PRGCOP(GLONADC)
#* ELTCODACT(GLONACV),

Local Char     DES_ELTCOD(30)    # Dossier destination : code element (maj et minus )
Local Integer  DES_HASELT        # Dossier destination : Flag existence element dans dossier destination 
 
Local Integer FLGALL      : FLGALL    =find("***",LSTOBJCOD)          
Local Integer DESCOPFLG   : DESCOPFLG =find("DESCOP", OPTION)
Local Integer TRADETFLG   : TRADETFLG =find("TRADET",OPTION)
Local Integer TMPONFLG    : TMPONFLG  =(find("NOTEMPON",OPTION)=0)

Local Char WSTR1(250), WMSG(250), DES(50)
Local Integer WI, WNBELT, STAT, OK

# Pour appel sous-prgrm suppression
Local Char OPTIONDEL(10)(1..10)     : Local Integer OPTDELIND 
Local Char LSTOBJCODDEL(3)(1..20)   : Local Integer LSTDELIND

WMSG=mess(26,7900,1)-FCYORG-"("-DOSORG-") -> "-FCYDES-"("-DOSDES-")"
Call ECR_TRACE(WMSG,0) From GESECRAN
#
Call MACHINE([L]DOSORG,MACORG,DOSNAMORG) From ORDSYS
Call MACHINE([L]DOSDES,MACDES,DOSNAMDES) From ORDSYS
#


#Read [AYS1]AYS0 = FCYORG
#[L]DOSORG : [L]FCYORG
Gosub  FCYREADORG  From AYTCOP     # classe AYS1
If fstat
    Call ECR_TRACE(mess(19,7900,1)-FCYORG,1) From GESECRAN
    RET=0
    Goto FCYCOPPRG_F
Endif

#[L]DOSDES : [L]FCYDES
Gosub  FCYREADDES  From AYTCOP     # classe AYS2

# Perso par produit
Local Integer PTRTB
Call EXISTE_ADX("","","AYTGENB",PTRTB) From ORDSYS

# Suppression préalable (cohérence site)
If DESCOPFLG | (len(sum(LSTOBJCOD(1..20))))
    If DESCOPFLG : OPTDELIND+=1 : OPTIONDEL(OPTDELIND)="DESSUP"   : Endif
    If TRADETFLG : OPTDELIND+=1 : OPTIONDEL(OPTDELIND)="TRADET"   : Endif   
    If !TMPONFLG : OPTDELIND+=1 : OPTIONDEL(OPTDELIND)="NOTEMPON" : Endif   
    #LSTDELIND+=1 : LSTOBJCODDEL="***"  # Tous les paramètres
    #Call FCYDELPRG(DOSDES, FCYDES, LSTOBJCODDEL, OPTIONdel, RET) From AYTFCYDEL
    Call FCYDELPRG(DOSDES, FCYDES, LSTOBJCOD, OPTIONDEL, RET) From AYTFCYDEL
    If RET=0 : Goto FCYCOPPRG_F : Endif
Endif

# Fiche site
If FLGALL or find("AYS",LSTOBJCOD)
    [L]OBJCOD="AYS" 
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    [L]ELTCOD=[L]FCYDES : Gosub COPOBJ_FOR
    If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILFCY","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Page
If FLGALL or find("AYG",LSTOBJCOD)
    [L]OBJCOD="AYG"
    
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTPAG  [AYG_] 
    Else 
     Local File =[L]DOSORG+".AYTPAG"  [AYG_]
    Endif 
    #
    For [F:AYG_]AYG0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYG_]PAGCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYG_]) : Close Local File [AYG_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILPAG","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Profil
If FLGALL or find("AYD",LSTOBJCOD)
    [L]OBJCOD="AYD"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTPRF [AYD_] 
    Else 
     Local File =[L]DOSORG+".AYTPRF"  [AYD_]
    Endif 
    #
    For [F:AYD_]AYD0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYD_]PRFCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYD_]) : Close Local File [AYD_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILPRF","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Elt champ
If FLGALL or find("AYF",LSTOBJCOD)
    [L]OBJCOD="AYF"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTELTFLD [AYF_] 
    Else 
     Local File =[L]DOSORG+".AYTELTFLD"  [AYF_]
    Endif 
    #
    For [F:AYF_]AYF0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYF_]FIECOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYF_]) : Close Local File [AYF_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILFLD","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Elt spécial
If 0 
 If FLGALL or find("AYX",LSTOBJCOD) & 0 : # obsoltete les champs speciaux sont dans les tables
    [L]OBJCOD="AYX"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTELTSPE [AYX_] 
    Else 
     Local File =[L]DOSORG+".AYTELTSPE"  [AYX_]
    Endif 
    #
    For [F:AYX_]AYX0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYX_]SPXCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYX_]) : Close Local File [AYX_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILSPE","",[L]FCYDES,""), STAT) From ORDSYS
 Endif
Endif

# Messages
If FLGALL or find("AYM",LSTOBJCOD)
    [L]OBJCOD="AYM"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTMES [AYM_] 
    Else 
     Local File =[L]DOSORG+".AYTMES"  [AYM_]
    Endif 
    #
    For [F:AYM_]AYM0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYM_]MESCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYM_]) : Close Local File [AYM_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILMES","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Interfaces
If FLGALL or find("AYI",LSTOBJCOD)
    [L]OBJCOD="AYI"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTINT [AYI_] 
    Else 
     Local File =[L]DOSORG+".AYTINT"  [AYI_]
    Endif 
    #
    For [F:AYI_]AYI0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYI_]INTCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYI_]) : Close Local File [AYI_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILINT","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Entités
If FLGALL or find("AYE",LSTOBJCOD)
    [L]OBJCOD="AYE"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTENT [AYE_] 
    Else 
     Local File =[L]DOSORG+".AYTENT"  [AYE_]
    Endif 
    #
    For [F:AYE_]AYE0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYE_]ENTCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYE_]) : Close Local File [AYE_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILENT","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Elt bloc
If FLGALL or find("AYB",LSTOBJCOD)
    [L]OBJCOD="AYB"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTELTBLC [AYB_] 
    Else 
     Local File =[L]DOSORG+".AYTELTBLC"  [AYB_]
    Endif 
    #
    For [F:AYB_]AYB0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYB_]BLCCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYB_]) : Close Local File [AYB_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILBLC","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Actions
If FLGALL or find("AYA",LSTOBJCOD)
    [L]OBJCOD="AYA"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTACT [AYA_] 
    Else 
     Local File =[L]DOSORG+".AYTACT"  [AYA_]
    Endif 
    #
    For [F:AYA_]AYA0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYA_]ACTCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYA_]) : Close Local File [AYA_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILACT","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Lien dynamique
If FLGALL or find("AYL",LSTOBJCOD)
    [L]OBJCOD="AYL"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTELTDLK [AYL_] 
    Else 
     Local File =[L]DOSORG+".AYTELTDLK"  [AYL_]
    Endif 
    #
    For [F:AYL_]AYL0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYL_]DLKCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYL_]) : Close Local File [AYL_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILDLK","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Elt bloc conditionné
If FLGALL or find("AYW",LSTOBJCOD)
    [L]OBJCOD="AYW"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTELTBLCW [AYW_] 
    Else 
     Local File =[L]DOSORG+".AYTELTBLCW"  [AYW_]
    Endif 
    #
    For [F:AYW_]AYW0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYW_]BLCWHNCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYW_]) : Close Local File [AYW_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILCND","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Menus
If FLGALL or find("AYC",LSTOBJCOD)
    [L]OBJCOD="AYC"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTMEN [AYC_] 
    Else 
     Local File =[L]DOSORG+".AYTMEN"  [AYC_]
    Endif 
    #
    For [F:AYC_]AYC0 Where FCYCOD=[L]FCYORG
        [L]ELTCOD  = [F:AYC_]MENCOD
        Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYC_]) : Close Local File [AYC_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILACT","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Paramétres avancés
If FLGALL or find("AYU",LSTOBJCOD)
    [L]OBJCOD="AYU"
    Gosub COPOBJ_DEB : If RET=0 : Goto FCYCOPPRG_F : Endif
    #
    If DOSNAMORG=nomap 
     Local File AYTADVPAR [AYU_] 
    Else 
     Local File =[L]DOSORG+".AYTADVPAR"  [AYU_]
    Endif 
    #
    # LIN=1 car objet de type tableau
    For [F:AYU_]AYU0 Where FCYCOD=[L]FCYORG and LIN=1
            [L]ELTCOD     = [F:AYU_]OBJCOD
            [L]ELTCODSUP  = num$([F:AYU_]OBJTYP)
            Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    Next
    #
    Gosub COPOBJ_FIN : If RET=0 : Goto FCYCOPPRG_F : Endif
    If clalev([F:AYU_]) : Close Local File [AYU_] : Endif
    Call EFFACE(func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILADV","",[L]FCYDES,""), STAT) From ORDSYS
Endif

# Vérification racine Xtend: arborescence et mise à jour destination
If TMPONFLG : Call TEMPON(mess(11,7900,1)) From GESECRAN : Endif
Call DIRXTUPD(MACDES, DOSNAMDES,  RET) From AYTGESFILE
If RET=0 : Goto FCYCOP_FIN : Endif
Call DIRXTUNIX(MACDES, DOSNAMDES, RET) From AYTGESFILE
If RET=0 : Goto FCYCOP_FIN : Endif

# Design
If DESCOPFLG 
    If TMPONFLG : Call TEMPON(mess(40,7900,1)-"("+FCYDES+")") From GESECRAN : Endif
    Call ECR_TRACE(mess(40,7900,1)-"("+FCYDES+")",0) From GESECRAN
    Call DIRFCYTAR(MACORG,DOSNAMORG,FCYORG,FCYORG,RET) From AYTGESFILE
    If RET=0 : Goto FCYCOPPRG_F : Endif
    Call ECR_TRACE(mess(36,7900,1)-FCYORG-"-->"-FCYDES,0) From GESECRAN
    Call COPIE(func AYTGESFILE.GETPATH(MACORG,DOSNAMORG,"FILTAR","",FCYORG,FCYORG),
&              func AYTGESFILE.GETPATH(MACDES,DOSNAMDES,"FILTAR","",FCYDES,FCYDES),
&            STAT) From ORDSYS
    If STAT<>0 :  RET=0 : Goto FCYCOPPRG_F : Endif
    Call DIRFCYDETAR(MACDES,DOSNAMDES,FCYDES,FCYDES,RET) From AYTGESFILE
    If RET=0 :  Goto FCYCOPPRG_F : Endif
Endif
#
# Vérification site Xtend:  arborescence et mise à jour destination
Call DIRFCYUPD(MACDES, DOSNAMDES, [L]FCYDES, [F:AYS1]LANCOD,[F:AYS1]DIRLAN, RET) From AYTGESFILE
If RET=0 : Goto FCYCOPPRG_F : Endif
Call DIRFCYUNIX(MACDES, DOSNAMDES, [L]FCYDES, RET) From AYTGESFILE
If RET=0 : Goto FCYCOPPRG_F : Endif

# Perso par produit
If PTRTB: Gosub FCYCOPFIN From AYTCOPIEB: Endif           

$FCYCOPPRG_F
If TMPONFLG : Call TEMPOFF() From GESECRAN : Endif
End

######################################################################################
## Gosub
######################################################################################
#------------------------------------------------------------#
# Boucle: Initialisation 
# $$$$
#------------------------------------------------------------#
$COPOBJ_DEB
Call TITOBJ([L]OBJCOD,"",[L]DES) From CONTOBJ  : 
WMSG=mess(91,123,1)+":"-[L]DES 
&    -mess(128,124,1)+":"-[L]FCYORG+"-"+[L]DOSORG
&    -mess(129,124,1)+":"-[L]FCYDES+"-"+[L]DOSDES
Call ECR_TRACE(WMSG,0) From GESECRAN
If TMPONFLG : Call TEMPON(mess(91,123,1)-DES) From GESECRAN : Endif

Call COP_CTLTRT([L]OBJCOD, PRGCOP, RET) From AYTCOP  # ctl existence trt
If RET=0 
    Call ECR_TRACE(mess(27,7900,1)-PRGCOP-"-"-mess(12,139,1) ,1) From GESECRAN     # Copie non réalisée
Endif

WNBELT=0 # cpt
Return

#------------------------------------------------------------#
# Boucle: dedans
# $$$$
#------------------------------------------------------------#
$COPOBJ_FOR
WNBELT+=1
If TRADETFLG : Call ECR_TRACE(mess(91,123,1)+":"-[L]DES-"-"-[L]ELTCOD,0) From GESECRAN : Endif
OK=1
Gosub TRTCOP From =PRGCOP    
If !GOK=1 | OK=0 : RET=0 : Endif
Return

#------------------------------------------------------------#
# Boucle: Fin
# $$$$
#------------------------------------------------------------#
$COPOBJ_FIN
Call ECR_TRACE(mess(146,7900,1)-num$(WNBELT),0) From GESECRAN     # Bilan copie
Return

######################################################################################
## Ecran AYTFCYCOP
######################################################################################
Subprog C_DOSORG(VALEUR)
Variable Char    VALEUR()
Gosub VERIF_ACVAYT From AYTCOP
GDOSPATH = VALEUR
End

Subprog C_FCYORG(VALEUR)
Variable Char    VALEUR()
Local File =[M]DOSORG+".AYTFCY" [AYS]
Read [AYS]AYS0 = VALEUR
If fstat
 GMESSAGE = VALEUR-":"- mess(15,104,1) : # SITE inexistant
 mkstat =2 : End
Else
 Local File =[M]DOSORG+".ATEXTRA" [AXX]
 Call LECTEXTRA([M]FCYORGINT,"AYTFCY","INTIT",VALEUR,"") From ATEXTRA
Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Gosub VERIF_ACVAYT From AYTCOP
End

Subprog C_FCYDES(VALEUR)
Variable Char    VALEUR()
GAYTFCYCOP = VALEUR
# Infos site
Local Char FCYDES(GLONAYS), DOSDES(GDIMFIC)
[L]DOSDES = [M:DIA]DOSDES : [L]FCYDES = VALEUR : Gosub  FCYREADDES From AYTCOP      # classe AYS2
Local File =[M]DOSDES+".AYTFCY" [AYS]
Read [AYS]AYS0 = VALEUR
If !fstat
 Local File =[M]DOSORG+".ATEXTRA" [AXX]
 Call LECTEXTRA([M]FCYDESINT,"AYTFCY","INTIT",VALEUR,"") From ATEXTRA
Endif
End


