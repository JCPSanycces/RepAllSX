Else
    [M:CEUR]STA(12) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

#############################################################################
# Articles concurrents
#############################################################################
$PROICM
SZKEY = ""
IBOITEOK = 1
ICONVERT = 0
IGOCOUNT = 0
ICNVCOUNT = 0
IPROCOUNT = 0
IGO = 1
CODEDEVSOC = ""
STAT_OK = 1
IERRFLG = 0

While IGO

    IGO = 0

    Filter [ICM] Where [F:ICM]NUM > SZKEY

    For [ICM]
        IERRCOUNT = 0
        ICONVERT = 0
        Call MUSTCNV2([F:ICM]CUR, [F:ICM]SALFCY, ICONVERT)

        If ICONVERT
            Call DEBTRANS From GLOCK
            Trbegin [ICM]

            STAT_OK = 1
            CODEDEVSOC = ""
            If [F:ICM]SALFCY = ""
                Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:ICM]NUM,1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Else
                Call GETDEVCPY("", [F:ICM]SALFCY, CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:ICM]NUM,1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Endif

            # Devise d'origine
            # Devise destination
            # Devise de la société
            # Type de cours
            # Date du cours
            # Montant origine
            # Montant destination
            # Status de retour (0 = OK)

            If !IERRCOUNT

                #Champs SALPRI

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:ICM]SALPRI
                IERRCOUNT = 0
                If [F:ICM]CUR <> GEURO
                    Call CONVERT([F:ICM]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "SALPRI",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:ICM]NUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:ICM]SALPRI = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif

                [F:ICM]CUR = GEURO

                If IERRCOUNT
                    Rollback
                Else
                    Rewrite [ICM]
                    If fstat
                        Rollback
                        Call ECR_TRACE(mess(464,196,1) + [M:CEUR]COD(13),1) From GESECRAN    #Erreur lors de la conversion de la table
                        Call ECR_TRACE(mess(469,196,1) + [F:ICM]NUM,1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Else
                        Commit
                    Endif
                Endif
            Endif
        Endif

        IPROCOUNT += 1
        IGOCOUNT += 1

        If !GINTRA
            Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
        Endif

        If !IERRCOUNT
            If ICONVERT
                ICNVCOUNT += 1
                If IDETTRACE 
                    Call ECR_TRACE(mess(470,196,1) + [F:ICM]NUM,0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
                Endif
            Endif
        Else
            IERRFLG = 1
        Endif

        If IGOCOUNT > 1250
            SZKEY = [F:ICM]NUM
            IGO = 1
            IGOCOUNT = 0
            Break
        Endif
    Next
Wend

Filter [ICM]

[M:CEUR]NBRRECCNV(13) = ICNVCOUNT

If IERRFLG
    [M:CEUR]STA(13) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(13) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

#############################################################################
# Prestataires
#############################################################################
$PROPRX
SZKEY = ""
IBOITEOK = 1
ICONVERT = 0
IGOCOUNT = 0
ICNVCOUNT = 0
IPROCOUNT = 0
IGO = 1
CODEDEVSOC = ""
STAT_OK = 1
IERRFLG = 0

While IGO

    IGO = 0

    Filter [PRX] Where [F:PRX]BPRNUM > SZKEY

    For [PRX]
        IERRCOUNT = 0

        #Recherche la devise du tiers
        Read [BPR] BPR0 = [F:PRX]BPRNUM
        If fstat
            Call ECR_TRACE(mess(475,196,1),1) From GESECRAN
            Call ECR_TRACE(mess(469,196,1) + [F:PRX]BPRNUM, 1) From GESECRAN    #Enregistrement n° : XXX
            IERRCOUNT = 1
        Else
            SZFCYTOUSE = [F:BPR]FCY
        Endif

        ICONVERT = 0

        If !IERRCOUNT
            Call MUSTCNV2([F:PRX]CUR, SZFCYTOUSE, ICONVERT)

            If ICONVERT
                Call DEBTRANS From GLOCK
                Trbegin [PRX]

                STAT_OK = 1
                CODEDEVSOC = ""
                If SZFCYTOUSE = ""
                    Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
                    If !STAT_OK #Erreur
                        Rollback
                        Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                        Call ECR_TRACE(mess(469,196,1) + [F:PRX]BPRNUM,1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Endif
                Else
                    Call GETDEVCPY("", SZFCYTOUSE, CODEDEVSOC, STAT_OK) From CRM_UTIL
                    If !STAT_OK #Erreur
                        Rollback
                        Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                        Call ECR_TRACE(mess(469,196,1) + [F:PRX]BPRNUM,1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Endif
                Endif

                # Devise d'origine
                # Devise destination
                # Devise de la société
                # Type de cours
                # Date du cours
                # Montant origine
                # Montant destination
                # Status de retour (0 = OK)

                If !IERRCOUNT

                    #Champs RATHOU

                    STAT_OK = 0
                    MNTCURIN = 0
                    MNTEURO = 0
                    MNTCURIN = [F:PRX]RATHOU
                    IERRCOUNT = 0
                    If [F:PRX]CUR <> GEURO
                        Call CONVERT([F:PRX]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                        If STAT_OK #Erreur
                            IERRCOUNT = 1
                            Call ECR_TRACE(mess(468,196,1) + "RATHOU",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                            Call ECR_TRACE(mess(469,196,1) + [F:PRX]BPRNUM,1) From GESECRAN    #Enregistrement n° : XXX
                        Else #Calcul OK
                            [F:PRX]RATHOU = MNTEURO
                        Endif
                    Else
                        ICONVERT = 0
                    Endif

                    #Champs EXSVLT

                    STAT_OK = 0
                    MNTCURIN = 0
                    MNTEURO = 0
                    MNTCURIN = [F:PRX]EXSVLT
                    IERRCOUNT = 0
                    If [F:PRX]CUR <> GEURO
                        Call CONVERT([F:PRX]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                        If STAT_OK #Erreur
                            IERRCOUNT = 1
                            Call ECR_TRACE(mess(468,196,1) + "EXSVLT",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                            Call ECR_TRACE(mess(469,196,1) + [F:PRX]BPRNUM,1) From GESECRAN    #Enregistrement n° : XXX
                        Else #Calcul OK
                            [F:PRX]EXSVLT = MNTEURO
                        Endif
                    Else
                        ICONVERT = 0
                    Endif

                    [F:PRX]CUR = GEURO

                    If IERRCOUNT
                        Rollback
                    Else
                        Rewrite [PRX]
                        If fstat
                            Rollback
                            Call ECR_TRACE(mess(464,196,1) + [M:CEUR]COD(14),1) From GESECRAN    #Erreur lors de la conversion de la table
                            Call ECR_TRACE(mess(469,196,1) + [F:PRX]BPRNUM,1) From GESECRAN    #Enregistrement n° : XXX
                            IERRCOUNT = 1
                        Else
                            Commit
                        Endif
                    Endif
                Endif
            Endif
        Endif

        IPROCOUNT += 1
        IGOCOUNT += 1

        If !GINTRA
            Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
        Endif

        If !IERRCOUNT
            If ICONVERT
                ICNVCOUNT += 1
                If IDETTRACE 
                    Call ECR_TRACE(mess(470,196,1) + [F:PRX]BPRNUM,0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
                Endif
            Endif
        Else
            IERRFLG = 1
        Endif

        If IGOCOUNT > 1250
            SZKEY = [F:PRX]BPRNUM
            IGO = 1
            IGOCOUNT = 0
            Break
        Endif
    Next
Wend

Filter [PRX]

[M:CEUR]NBRRECCNV(14) = ICNVCOUNT

If IERRFLG
    [M:CEUR]STA(14) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(14) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

#############################################################################
# Donneurs d'ordres / Tiers divers
#############################################################################
$PROBPM
SZKEY = ""
IBOITEOK = 1
ICONVERT = 0
IGOCOUNT = 0
ICNVCOUNT = 0
IPROCOUNT = 0
IGO = 1
CODEDEVSOC = ""
STAT_OK = 1
IERRFLG = 0
IDIM = 0


For [BPM]
        IERRCOUNT = 0

        #Recherche la devise du tiers
        Read [BPR] BPR0 = [F:BPM]BPRNUM
        If fstat
            Call ECR_TRACE(mess(475,196,1),1) From GESECRAN
            Call ECR_TRACE(mess(469,196,1) + [F:BPM]BPRNUM + " - " + [F:BPM]BPRTYP, 1) From GESECRAN    #Enregistrement n° : XXX
            IERRCOUNT = 1
        Else
            SZCURTOUSE = [F:BPR]CUR
            SZFCYTOUSE = [F:BPR]FCY
        Endif

        ICONVERT = 0

        If !IERRCOUNT
            Call MUSTCNV2(SZCURTOUSE, SZFCYTOUSE, ICONVERT)

            If ICONVERT
                Call DEBTRANS From GLOCK
                Trbegin [BPM]

                STAT_OK = 1
                CODEDEVSOC = ""
                If SZFCYTOUSE = ""
                    Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
                    If !STAT_OK #Erreur
                        Rollback
                        Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                        Call ECR_TRACE(mess(469,196,1) + [F:BPM]BPRNUM + " - " + [F:BPM]BPRTYP,1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Endif
                Else
                    Call GETDEVCPY("", SZFCYTOUSE, CODEDEVSOC, STAT_OK) From CRM_UTIL
                    If !STAT_OK #Erreur
                        Rollback
                        Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                        Call ECR_TRACE(mess(469,196,1) + [F:BPM]BPRNUM + " - " + [F:BPM]BPRTYP,1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Endif
                Endif

                # Devise d'origine
                # Devise destination
                # Devise de la société
                # Type de cours
                # Date du cours
                # Montant origine
                # Montant destination
                # Status de retour (0 = OK)

                If !IERRCOUNT

                    #Champs DCBX
                    IDIM = 0
                    For IDIM = 0 To dim([F:BPM]DCBX) - 1
                        STAT_OK = 0
                        MNTCURIN = 0
                        MNTEURO = 0
                        MNTCURIN = [F:BPM]DCBX(IDIM)
                        IERRCOUNT = 0
                        If SZCURTOUSE <> GEURO
                            Call CONVERT(SZCURTOUSE,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                            If STAT_OK #Erreur
                                IERRCOUNT = 1
                                Call ECR_TRACE(mess(468,196,1) + "DCBX",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                                Call ECR_TRACE(mess(469,196,1) + [F:BPM]BPRNUM + " - " + [F:BPM]BPRTYP,1) From GESECRAN    #Enregistrement n° : XXX
                            Else #Calcul OK
                                [F:BPM]DCBX(IDIM) = MNTEURO
                            Endif
                        Else
                            ICONVERT = 0
                        Endif
                    Next

                    If IERRCOUNT
                        Rollback
                    Else
                        Rewrite [BPM]
                        If fstat
                            Rollback
                            Call ECR_TRACE(mess(464,196,1) + [M:CEUR]COD(15),1) From GESECRAN    #Erreur lors de la conversion de la table
                            Call ECR_TRACE(mess(469,196,1) + [F:BPM]BPRNUM + " - " + [F:BPM]BPRTYP,1) From GESECRAN    #Enregistrement n° : XXX
                            IERRCOUNT = 1
                        Else
                            Commit
                        Endif
                    Endif
                Endif
            Endif
        Endif

        IPROCOUNT += 1
        IGOCOUNT += 1

        If !GINTRA
            Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
        Endif

        If !IERRCOUNT
            If ICONVERT
                ICNVCOUNT += 1
                If IDETTRACE 
                    Call ECR_TRACE(mess(470,196,1) + [F:BPM]BPRNUM + " - " + [F:BPM]BPRTYP,0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
                Endif
            Endif
        Else
            IERRFLG = 1
        Endif

Next

[M:CEUR]NBRRECCNV(15) = ICNVCOUNT

If IERRFLG
    [M:CEUR]STA(15) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(15) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

#############################################################################
# Calcul devise Crystal Report
#############################################################################
$PROPPP
Call DEBTRANS From GLOCK
Trbegin [PPP]
Delete [PPP] Where [F:PPP]NUM <> ""
If fstat
    Rollback
    Call ECR_TRACE(mess(464,196,1) + [M:CEUR]COD(16),1) From GESECRAN    #Erreur lors de la conversion de la table
    IERRFLG = 1
Else
    Commit
Endif

[M:CEUR]NBRRECCNV(16) = GICTAB(16)

If IERRFLG
    [M:CEUR]STA(16) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(16) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

