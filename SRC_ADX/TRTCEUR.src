            # Devise d'origine
            # Devise destination
            # Devise de la société
            # Type de cours
            # Date du cours
            # Montant origine
            # Montant destination
            # Status de retour (0 = OK)

            If !IERRCOUNT

                #Champs BUD

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
