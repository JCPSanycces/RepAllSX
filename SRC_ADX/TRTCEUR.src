                        Call ECR_TRACE(mess(468,196,1) + "BUD",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:CMG]NUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:CMG]BUD = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif

                [F:CMG]CUR = GEURO

                If IERRCOUNT
                    Rollback
