#############################################################################
$PROITN
SZKEY = ""
IBOITEOK = 1
ICONVERT = 0
IGOCOUNT = 0
ICNVCOUNT = 0
IPROCOUNT = 0
IGO = 1
CODEDEVSOC = ""
