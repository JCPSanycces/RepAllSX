#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################################################
#   Bascule CRM Euro                                               Module CRM         27 septembre 2001 #
#########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When Default
Endcase
Return


$OUVRE
Local Integer IX
Global Integer GISCONV
Global Integer GITRACEDISP
Global Integer GICTAB(17)
GISCONV = 0
GITRACEDISP = 0
IX = 0
For IX = 0 To dim(GICTAB) - 1
    GICTAB(IX) = 0
Next

If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
If !clalev([F:PCO]) : Local File PRESTCOV [PCO] : Endif
If !clalev([F:CAM]) : Local File CONTAMT [CAM] : Endif
If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
If !clalev([F:MAI]) : Local File MACITN [MAI] : Endif
If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
If !clalev([F:CMG]) : Local File CMARKETING [CMG] : Endif
If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
If !clalev([F:OMT]) : Local File TRADESHOW [OMT] : Endif
If !clalev([F:OMN]) : Local File MEDIA [OMN] : Endif
If !clalev([F:ICM]) : Local File ITMCOMP [ICM] : Endif
If !clalev([F:PRX]) : Local File SUBCONT [PRX] : Endif
If !clalev([F:BPM]) : Local File BPMISC [BPM] : Endif
If !clalev([F:PPP]) : Local File PREREPORT [PPP] : Endif
If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif

Return

$DEFBOUT
Return

$SETBOUT
If GISCONV
    ETABOU(GSPE1) = 0
    If GITRACEDISP
        ETABOU(GSPE2) = 0
    Else
        ETABOU(GSPE2) = 1
    Endif
Else
    ETABOU(GSPE1) = 1
    ETABOU(GSPE2) = 0
Endif
Return

$OUVRE_BOITE
Return

$DEBUT
Local Integer IZ
IZ = 0
#Charge la colonne code table et nombre d'enregistrements

[M:CEUR]COD(0) = "OPPOR"
[M:CEUR]NBRRECTAB(0) = nbrecord([OPP])

[M:CEUR]COD(1) = "PRESTCOV"
[M:CEUR]NBRRECTAB(1) = nbrecord([PCO])

[M:CEUR]COD(2) = "CONTAMT"
[M:CEUR]NBRRECTAB(2) = nbrecord([CAM])

[M:CEUR]COD(3) = "CONTTEMPL"
[M:CEUR]NBRRECTAB(3) = nbrecord([COT])

[M:CEUR]COD(4) = "CONTSERV"
[M:CEUR]NBRRECTAB(4) = nbrecord([CON])

[M:CEUR]COD(5) = "MACHINES"
[M:CEUR]NBRRECTAB(5) = nbrecord([MAC])

[M:CEUR]COD(6) = "MACITN"
[M:CEUR]NBRRECTAB(6) = nbrecord([MAI])

[M:CEUR]COD(7) = "INTERVEN"
[M:CEUR]NBRRECTAB(7) = nbrecord([ITN])

[M:CEUR]COD(8) = "CMARKETING"
[M:CEUR]NBRRECTAB(8) = nbrecord([CMG])

[M:CEUR]COD(9) = "MAILING"
[M:CEUR]NBRRECTAB(9) = nbrecord([OMM])

[M:CEUR]COD(10) = "PHONING"
[M:CEUR]NBRRECTAB(10) = nbrecord([OMP])

[M:CEUR]COD(11) = "TRADESHOW"
[M:CEUR]NBRRECTAB(11) = nbrecord([OMT])

[M:CEUR]COD(12) = "MEDIA"
[M:CEUR]NBRRECTAB(12) = nbrecord([OMN])

[M:CEUR]COD(13) = "ITMCOMP"
[M:CEUR]NBRRECTAB(13) = nbrecord([ICM])

[M:CEUR]COD(14) = "SUBCONT"
[M:CEUR]NBRRECTAB(14) = nbrecord([PRX])

[M:CEUR]COD(15) = "BPMISC"
[M:CEUR]NBRRECTAB(15) = nbrecord([BPM])

[M:CEUR]COD(16) = "PREREPORT"
[M:CEUR]NBRRECTAB(16) = nbrecord([PPP])

[M:CEUR]NBTAB = 17

#Charge la colonne Intitulé table et Status
For IZ = 0 To [M:CEUR]NBTAB - 1
    Read [ATB]CODFIC = [M:CEUR]COD(IZ)
    Call TEXTE([F:ATB]INTITFIC, [M:CEUR]TAB(IZ)) From OBJDIV

    If [M:CEUR]NBRRECTAB(IZ) > 0
        [M:CEUR]STA(IZ) = mess(459,196,1) #A convertir
    Else
        [M:CEUR]STA(IZ) = mess(462,196,1) #Aucun élément à traiter
    Endif

    GICTAB(IZ) = [M:CEUR]NBRRECTAB(IZ)
Next

#Définit les valeurs du bloc de base
[M:CEUR]ALLCPY = 2
[M:CEUR]CPY = ""
Grizo [M:CEUR]CPY
[M:CEUR]CNVFLG = 2
[M:CEUR]CNVLESFLG = 2

Affzo [M:CEUR]

Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:CEUR]
Kill GISCONV
Kill GITRACEDISP
Kill GICTAB
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
Return

$BOUTON
Case BOUT
    When "A"
        Gosub DEMARRER
        Affzo [M:CEUR]
    When "B"
        Gosub TRACE
    When Default
Endcase
Return

$ONMENU
Return

