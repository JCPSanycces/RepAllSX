            # Date du cours
            # Montant origine
            # Montant destination
            # Status de retour (0 = OK)

            If !IERRCOUNT

                #Champs ONEXINVAMT

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:CON]ONEXINVAMT
                IERRCOUNT = 0
                If [F:CON]CUR <> GEURO
                    Call CONVERT([F:CON]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "ONEXINVAMT",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:CON]CONNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:CON]ONEXINVAMT = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs NEXINVAMT

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:CON]NEXINVAMT
                If [F:CON]CUR <> GEURO
                    Call CONVERT([F:CON]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "NEXINVAMT",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:CON]CONNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:CON]NEXINVAMT = MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs CONAMT

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:CON]CONAMT
                If [F:CON]CUR <> GEURO
                    Call CONVERT([F:CON]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "CONAMT",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:CON]CONNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:CON]CONAMT = MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs AMTPLY

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:CON]AMTPLY
                If [F:CON]CUR <> GEURO
                    Call CONVERT([F:CON]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "AMTPLY",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:CON]CONNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:CON]AMTPLY = MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs AMTPLYX

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:CON]AMTPLYX
                If [F:CON]CUR <> GEURO
                    Call CONVERT([F:CON]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "AMTPLYX",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:CON]CONNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:CON]AMTPLYX = MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                [F:CON]CUR = GEURO

                If IERRCOUNT
                    Rollback
                Else
                    Rewrite [CON]
                    If fstat
                        Rollback
                        Call ECR_TRACE(mess(464,196,1) + [M:CEUR]COD(4),1) From GESECRAN    #Erreur lors de la conversion de la table
                        Call ECR_TRACE(mess(469,196,1) + [F:CON]CONNUM,1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Else
                        Commit
                    Endif
                Endif
            Endif
        Endif

        IPROCOUNT += 1
        IGOCOUNT += 1

        If !GINTRA
            Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
        Endif

        If !IERRCOUNT
            If ICONVERT
                ICNVCOUNT += 1
                If IDETTRACE 
                    Call ECR_TRACE(mess(470,196,1) + [F:CON]CONNUM,0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
                Endif
            Endif
        Else
            IERRFLG = 1
        Endif

        If IGOCOUNT > 1250
            SZKEY = [F:CON]CONNUM
            IGO = 1
            IGOCOUNT = 0
            Break
        Endif
    Next
Wend

Filter [CON]

[M:CEUR]NBRRECCNV(4) = ICNVCOUNT

If IERRFLG
    [M:CEUR]STA(4) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(4) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

#############################################################################
# Parc client
#############################################################################
$PROMAC
SZKEY = ""
IBOITEOK = 1
ICONVERT = 0
IGOCOUNT = 0
ICNVCOUNT = 0
IPROCOUNT = 0
IGO = 1
CODEDEVSOC = ""
STAT_OK = 1
IERRFLG = 0

While IGO

    IGO = 0

    Filter [MAC] Where [F:MAC]MACNUM > SZKEY

    For [MAC]
        IERRCOUNT = 0
        ICONVERT = 0
        Call MUSTCNV2([F:MAC]CUR, [F:MAC]SALFCY, ICONVERT)

        If ICONVERT
            Call DEBTRANS From GLOCK
            Trbegin [MAC]

            STAT_OK = 1
            CODEDEVSOC = ""
            If [F:MAC]SALFCY = ""
                Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:MAC]MACNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Else
                Call GETDEVCPY("", [F:MAC]SALFCY, CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:MAC]MACNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Endif

            # Devise d'origine
            # Devise destination
            # Devise de la société
            # Type de cours
            # Date du cours
            # Montant origine
            # Montant destination
            # Status de retour (0 = OK)

            If !IERRCOUNT

                #Champs MACSALPRI

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:MAC]MACSALPRI
                IERRCOUNT = 0
                If [F:MAC]CUR <> GEURO
                    If [F:MAC]MACPURDAT = [00/00/00]
                        Call CONVERT([F:MAC]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Else
                        Call CONVERT([F:MAC]CUR,GEURO,CODEDEVSOC,TYPCUR,[F:MAC]MACPURDAT,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Endif
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "MACSALPRI",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:MAC]MACNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:MAC]MACSALPRI = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif

                [F:MAC]CUR = GEURO

                If IERRCOUNT
                    Rollback
                Else
                    Rewrite [MAC]
                    If fstat
                        Rollback
                        Call ECR_TRACE(mess(464,196,1) + [M:CEUR]COD(5),1) From GESECRAN    #Erreur lors de la conversion de la table
                        Call ECR_TRACE(mess(469,196,1) + [F:MAC]MACNUM,1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Else
                        Commit
                    Endif
                Endif
            Endif
        Endif

        IPROCOUNT += 1
        IGOCOUNT += 1

        If !GINTRA
            Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
        Endif

        If !IERRCOUNT
            If ICONVERT
                ICNVCOUNT += 1
                If IDETTRACE 
                    Call ECR_TRACE(mess(470,196,1) + [F:MAC]MACNUM,0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
                Endif
            Endif
        Else
            IERRFLG = 1
        Endif

        If IGOCOUNT > 1250
            SZKEY = [F:MAC]MACNUM
            IGO = 1
            IGOCOUNT = 0
            Break
        Endif
    Next
Wend

Filter [MAC]

[M:CEUR]NBRRECCNV(5) = ICNVCOUNT

If IERRFLG
    [M:CEUR]STA(5) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(5) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

#############################################################################
# Historique des implantations du parc client
#############################################################################
$PROMAI
SZKEY = ""
IBOITEOK = 1
ICONVERT = 0
IGOCOUNT = 0
ICNVCOUNT = 0
IPROCOUNT = 0
IGO = 1
CODEDEVSOC = ""
STAT_OK = 1
IERRFLG = 0

For [MAI]
    IERRCOUNT = 0

    #Recherche la devise contrat
    Read [MAC] MAC0 = [F:MAI]MACNUM
    If fstat
        Call ECR_TRACE(mess(475,196,1),1) From GESECRAN # Erreur lors de la recherche d'un site
        Call ECR_TRACE(mess(469,196,1) + [F:MAI]MACNUM + " - " + [F:MAI]BPC + " - " + [F:MAI]BPCTYP, 1) From GESECRAN    #Enregistrement n° : XXX
        IERRCOUNT = 1
    Else
        SZFCYTOUSE = [F:MAC]SALFCY
    Endif

    If !IERRCOUNT

        ICONVERT = 0
        Call MUSTCNV2([F:MAI]CUR, SZFCYTOUSE , ICONVERT)

        If ICONVERT
            Call DEBTRANS From GLOCK
            Trbegin [MAI]

            STAT_OK = 1
            CODEDEVSOC = ""
            If SZFCYTOUSE = ""
                Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:MAI]MACNUM + " - " + [F:MAI]BPC + " - " + [F:MAI]BPCTYP, 1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Else
                Call GETDEVCPY("", SZFCYTOUSE, CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:MAI]MACNUM + " - " + [F:MAI]BPC + " - " + [F:MAI]BPCTYP, 1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Endif

            # Devise d'origine
            # Devise destination
            # Devise de la société
            # Type de cours
            # Date du cours
            # Montant origine
            # Montant destination
            # Status de retour (0 = OK)

            If !IERRCOUNT

                #Champs SECPRI

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:MAI]SECPRI
                IERRCOUNT = 0
                If [F:MAI]CUR <> GEURO
                    If [F:MAI]ENDITN = [00/00/00]
                        Call CONVERT([F:MAI]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Else
                        Call CONVERT([F:MAI]CUR,GEURO,CODEDEVSOC,TYPCUR,[F:MAI]ENDITN,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Endif
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "SECPRI",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:MAI]MACNUM + " - " + [F:MAI]BPC + " - " + [F:MAI]BPCTYP, 1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:MAI]SECPRI = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif

               #Champs SALPRI

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:MAI]SALPRI
                IERRCOUNT = 0
                If [F:MAI]CUR <> GEURO
                    If [F:MAI]ENDITN = [00/00/00]
                        Call CONVERT([F:MAI]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Else
                        Call CONVERT([F:MAI]CUR,GEURO,CODEDEVSOC,TYPCUR,[F:MAI]ENDITN,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Endif
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "SALPRI",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:MAI]MACNUM + " - " + [F:MAI]BPC + " - " + [F:MAI]BPCTYP, 1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:MAI]SALPRI = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif

                [F:MAI]CUR = GEURO

                If IERRCOUNT
                    Rollback
                Else
                    Rewrite [MAI]
                    If fstat
                        Rollback
                        Call ECR_TRACE(mess(464,196,1) + [M:CEUR]COD(6),1) From GESECRAN    #Erreur lors de la conversion de la table
                        Call ECR_TRACE(mess(469,196,1) + [F:MAI]MACNUM + " - " + [F:MAI]BPC + " - " + [F:MAI]BPCTYP, 1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Else
                        Commit
                    Endif
                Endif
            Endif
        Endif
    Endif

    IPROCOUNT += 1
    IGOCOUNT += 1

    If !GINTRA
        Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
    Endif

    If !IERRCOUNT
        If ICONVERT
            ICNVCOUNT += 1
            If IDETTRACE 
                Call ECR_TRACE(mess(470,196,1) + [F:MAI]MACNUM + " - " + [F:MAI]BPC + " - " + [F:MAI]BPCTYP,0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
            Endif
        Endif
    Else
        IERRFLG = 1
    Endif
Next

[M:CEUR]NBRRECCNV(6) = ICNVCOUNT

If IERRFLG
    [M:CEUR]STA(6) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(6) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

#############################################################################
