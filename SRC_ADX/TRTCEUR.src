##########################################################
# Détermine si une devise doit faire l'objet d'une conversion
##########################################################
Subprog MUSTCONVERT(SZCUR, IREP)
Value Char SZCUR
Variable Integer IREP

IREP = 0

If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif

Read [TCU] TCU0 = SZCUR
If fstat
    IREP = 0
    End
Endif

If [F:TCU]EURFLG = 2
    IREP = 1
Else
    IREP = 0
Endif

End

##########################################################
# Détermine si un enregistrement doit faire l'objet d'une conversion
##########################################################
Subprog MUSTCNV2(SZCUR, SZFCY, IREP)
Value Char SZCUR
Value Char SZFCY
Variable Integer IREP

IREP = 0

#Recherche du code société à partir du code site
If [M:CEUR]ALLCPY = 2
    If SZFCY = ""
        If [M:CEUR]CNVFLG = 2
            IREP = 1
        Else
            IREP = 0
            End
        Endif
    Else
        IREP = 1
    Endif
Else
    If SZFCY = ""
        If [M:CEUR]CNVFLG = 2
            IREP = 1
        Else
            IREP = 0
            End
        Endif
    Else
        If clalev([F:FCY]) <= 0 Local File FACILITY[FCY] : Endif
        Read [FCY] FCY0 = SZFCY
        If fstat
            IREP = 0
            End
        Endif

        If [M:CEUR]CPY = [F:FCY]LEGCPY
            IREP = 1
        Else
            IREP = 0
            End    
        Endif
    Endif
Endif

If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif

Read [TCU] TCU0 = SZCUR
If fstat
    IREP = 0
    End
Endif

If [F:TCU]EURFLG = 2
    IREP = 1
Else
    IREP = 0
Endif

End

#############################################################################
#Affaires
#############################################################################
$PROOPP
SZKEY = ""
IBOITEOK = 1
ICONVERT = 0
IGOCOUNT = 0
ICNVCOUNT = 0
IPROCOUNT = 0
IGO = 1
CODEDEVSOC = ""
STAT_OK = 1
IERRFLG = 0

While IGO

    IGO = 0

    Filter [OPP] Where [F:OPP]OPPNUM > SZKEY

    For [OPP]
        IERRCOUNT = 0
        ICONVERT = 0
        Call MUSTCNV2([F:OPP]CUR, [F:OPP]SALFCY, ICONVERT)

        If ICONVERT
            Call DEBTRANS From GLOCK
            Trbegin [OPP]

            STAT_OK = 1
            CODEDEVSOC = ""
            If [F:OPP]SALFCY = ""
                Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:OPP]OPPNUM, 1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Else
                Call GETDEVCPY("", [F:OPP]SALFCY, CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:OPP]OPPNUM, 1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Endif

            # Devise d'origine
            # Devise destination
            # Devise de la société
            # Type de cours
            # Date du cours
            # Montant origine
            # Montant destination
            # Status de retour (0 = OK)

            If !IERRCOUNT

                #Champs OPPAMT

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:OPP]OPPAMT
                IERRCOUNT = 0
                If [F:OPP]CUR <> GEURO
                    If [F:OPP]OPPCDA = [00/00/00]
                        Call CONVERT([F:OPP]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Else
                        Call CONVERT([F:OPP]CUR,GEURO,CODEDEVSOC,TYPCUR,[F:OPP]OPPCDA,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Endif
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "OPPAMT",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:OPP]OPPNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:OPP]OPPAMT = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs PBYPRJAAM

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:OPP]PBYPRJAAM
                If [F:OPP]CUR <> GEURO
                    If [F:OPP]OPPCDA = [00/00/00]
                        Call CONVERT([F:OPP]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Else
                        Call CONVERT([F:OPP]CUR,GEURO,CODEDEVSOC,TYPCUR,[F:OPP]OPPCDA,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Endif
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "PBYPRJAAM",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:OPP]OPPNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:OPP]PBYPRJAAM = MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs OPPAAM

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:OPP]OPPAAM
                If [F:OPP]CUR <> GEURO
                    If [F:OPP]OPPCDA = [00/00/00]
                        Call CONVERT([F:OPP]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Else
                        Call CONVERT([F:OPP]CUR,GEURO,CODEDEVSOC,TYPCUR,[F:OPP]OPPCDA,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Endif
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "OPPAAM",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:OPP]OPPNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:OPP]OPPAAM = MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs DAM

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:OPP]DAM
                If [F:OPP]CUR <> GEURO
                    If [F:OPP]OPPCDA = [00/00/00]
                        Call CONVERT([F:OPP]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Else
                        Call CONVERT([F:OPP]CUR,GEURO,CODEDEVSOC,TYPCUR,[F:OPP]OPPCDA,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Endif
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "DAM",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:OPP]OPPNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:OPP]DAM = MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs CPPAMT

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:OPP]CPPAMT
                If [F:OPP]CUR <> GEURO
                    If [F:OPP]OPPCDA = [00/00/00]
                        Call CONVERT([F:OPP]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Else
                        Call CONVERT([F:OPP]CUR,GEURO,CODEDEVSOC,TYPCUR,[F:OPP]OPPCDA,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Endif
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "CPPAMT",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:OPP]OPPNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:OPP]CPPAMT = MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                [F:OPP]CUR = GEURO
                
                If IERRCOUNT
                    Rollback
                Else
                    Rewrite [OPP]
                    If fstat
                        Rollback
                        Call ECR_TRACE(mess(464,196,1) + [M:CEUR]COD(0),1) From GESECRAN    #Erreur lors de la conversion de la table 
                        Call ECR_TRACE(mess(469,196,1) + [F:OPP]OPPNUM,1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Else
                        Commit
                    Endif
                Endif
            Endif
        Endif

        IPROCOUNT += 1
        IGOCOUNT += 1

        If !GINTRA
            Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
        Endif

        If !IERRCOUNT
            If ICONVERT
                ICNVCOUNT += 1
                If IDETTRACE 
                    Call ECR_TRACE(mess(470,196,1) + [F:OPP]OPPNUM,0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
                Endif
            Endif
        Else
            IERRFLG = 1
        Endif

        If IGOCOUNT > 1250
            SZKEY = [F:OPP]OPPNUM
            IGO = 1
            IGOCOUNT = 0
            Break
        Endif
    Next
Wend

Filter [OPP]

[M:CEUR]NBRRECCNV(0) = ICNVCOUNT

If IERRFLG
    [M:CEUR]STA(0) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(0) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

#############################################################################
#Couverture article des contrats de service
#############################################################################
$PROPCO
SZKEY = ""
IBOITEOK = 1
ICONVERT = 0
IGOCOUNT = 0
ICNVCOUNT = 0
IPROCOUNT = 0
IGO = 1
CODEDEVSOC = ""
STAT_OK = 1
IERRFLG = 0

#Traitement des couvertures associées à un modèle de contrat
Call ECR_TRACE(mess(473,196,1), 0) From GESECRAN #Traitement des couvertures associées à un modèle de contrat

Filter [PCO] Where [F:PCO]TPL = 2

For [PCO]
    IERRCOUNT = 0
    #Recherche la devise contrat
    Read [COT] COT0 = [F:PCO]CONNUM
    If fstat
        Call ECR_TRACE(mess(472,196,1),1) From GESECRAN # Erreur lors de la recherche d'une devise de contrat de service.
        Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
        IERRCOUNT = 1
    Else
        SZCURTOUSE = [F:COT]CUR
    Endif

    If !IERRCOUNT
        ICONVERT = 0
        If [M:CEUR]CNVLESFLG = 2
            Call MUSTCONVERT(SZCURTOUSE, ICONVERT)
        Else
            ICONVERT = 0
        Endif

        If ICONVERT
            Call DEBTRANS From GLOCK
            Trbegin [PCO]

            STAT_OK = 1
            CODEDEVSOC = ""
            Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
            If !STAT_OK #Erreur
                Rollback
                Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
                IERRCOUNT = 1
            Endif

            # Devise d'origine
            # Devise destination
            # Devise de la société
            # Type de cours
            # Date du cours
            # Montant origine
            # Montant destination
            # Status de retour (0 = OK)

            If !IERRCOUNT

                #Champs MINCOV

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:PCO]MINCOV
                If SZCURTOUSE <> GEURO
                    Call CONVERT(SZCURTOUSE,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "MINCOV",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:PCO]MINCOV = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs MAXCOV

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:PCO]MAXCOV
                If SZCURTOUSE <> GEURO
                    Call CONVERT(SZCURTOUSE,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "NEXINVAMT",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:PCO]MAXCOV= MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                If IERRCOUNT
                    Rollback
                Else
                    Rewrite [PCO]
                    If fstat
                        Rollback
                        Call ECR_TRACE(mess(464,196,1) + "NEXINVAMT",1) From GESECRAN    #Erreur lors de la conversion de la table 
                        Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Else
                        Commit
                    Endif
                Endif
            Endif
        Endif
    Endif

    IPROCOUNT += 1

    If !GINTRA
        Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
    Endif

    If !IERRCOUNT
        If ICONVERT
            ICNVCOUNT += 1
            If IDETTRACE 
                Call ECR_TRACE(mess(470,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC,0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
            Endif
        Endif
    Else
        IERRFLG = 1
    Endif

Next

Filter [PCO]

#Traitement des couvertures associées à un contrat de service
Call ECR_TRACE(mess(474,196,1), 0) From GESECRAN ##Traitement des couvertures associées à un contrat de service

Filter [PCO] Where [F:PCO]TPL <> 2

For [PCO]
    IERRCOUNT = 0
    #Recherche la devise contrat
    Read [CON] CON0 = [F:PCO]CONNUM
    If fstat
        Call ECR_TRACE(mess(472,196,1),1) From GESECRAN
        Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
        IERRCOUNT = 1
    Else
        SZCURTOUSE = [F:CON]CUR
        SZFCYTOUSE = [F:CON]SALFCY
    Endif

    If !IERRCOUNT
        ICONVERT = 0
        Call MUSTCNV2(SZCURTOUSE, SZFCYTOUSE, ICONVERT)

        If ICONVERT
            Call DEBTRANS From GLOCK
            Trbegin [PCO]

            STAT_OK = 1
            CODEDEVSOC = ""
            If SZFCYTOUSE = ""
                Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Else
                Call GETDEVCPY("", SZFCYTOUSE, CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Endif

            # Devise d'origine
            # Devise destination
            # Devise de la société
            # Type de cours
            # Date du cours
            # Montant origine
            # Montant destination
            # Status de retour (0 = OK)

            If !IERRCOUNT

                #Champs MINCOV

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:PCO]MINCOV
                IERRCOUNT = 0
                If SZCURTOUSE <> GEURO
                    Call CONVERT(SZCURTOUSE,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "MINCOV",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:PCO]MINCOV = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs MAXCOV

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:PCO]MAXCOV
                If SZCURTOUSE <> GEURO
                    Call CONVERT(SZCURTOUSE,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "NEXINVAMT",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:PCO]MAXCOV= MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                If IERRCOUNT
                    Rollback
                Else
                    Rewrite [PCO]
                    If fstat
                        Rollback
                        Call ECR_TRACE(mess(464,196,1) + "NEXINVAMT",1) From GESECRAN    #Erreur lors de la conversion de la table 
                        Call ECR_TRACE(mess(469,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC, 1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Else
                        Commit
                    Endif
                Endif
            Endif
        Endif
    Endif

    IPROCOUNT += 1

    If !GINTRA
        Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
    Endif

    If !IERRCOUNT
        If ICONVERT
            ICNVCOUNT += 1
            If IDETTRACE 
                Call ECR_TRACE(mess(470,196,1) + [F:PCO]CONNUM + " - " + [F:PCO]MACNUM + " - " + [F:PCO]TYPSVC,0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
            Endif
        Endif
    Else
        IERRFLG = 1
    Endif

Next

Filter [PCO]

[M:CEUR]NBRRECCNV(1) = ICNVCOUNT

If IERRFLG
    [M:CEUR]STA(1) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(1) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

#############################################################################
# Historiques des bases annuelles de contrats de service
#############################################################################
$PROCAM
SZKEY = ""
IBOITEOK = 1
ICONVERT = 0
IGOCOUNT = 0
ICNVCOUNT = 0
IPROCOUNT = 0
IGO = 1
CODEDEVSOC = ""
STAT_OK = 1
IERRFLG = 0

For [CAM]
    IERRCOUNT = 0    
 
    #Recherche la devise contrat
    Read [CON] CON0 = [F:CAM]CONNUM
    If fstat
        Call ECR_TRACE(mess(472,196,1),1) From GESECRAN # Erreur lors de la recherche d'une devise de contrat de service.
        Call ECR_TRACE(mess(469,196,1) + [F:CAM]CONNUM + " - " + num$([F:CAM]AMTRECNUMX), 1) From GESECRAN    #Enregistrement n° : XXX
        IERRCOUNT = 1
    Else
        SZCURTOUSE = [F:CON]CUR
        SZFCYTOUSE = [F:CON]SALFCY
    Endif

    If !IERRCOUNT
        ICONVERT = 0
        Call MUSTCNV2(SZCURTOUSE, SZFCYTOUSE, ICONVERT)

        If ICONVERT
            Call DEBTRANS From GLOCK
            Trbegin [CAM]

            STAT_OK = 1
            CODEDEVSOC = ""
            If SZFCYTOUSE = ""
                Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:CAM]CONNUM + " - " + num$([F:CAM]AMTRECNUMX), 1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Else
                Call GETDEVCPY("", SZFCYTOUSE, CODEDEVSOC, STAT_OK) From CRM_UTIL
                If !STAT_OK #Erreur
                    Rollback
                    Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                    Call ECR_TRACE(mess(469,196,1) + [F:CAM]CONNUM + " - " + num$([F:CAM]AMTRECNUMX), 1) From GESECRAN    #Enregistrement n° : XXX
                    IERRCOUNT = 1
                Endif
            Endif

            # Devise d'origine
            # Devise destination
            # Devise de la société
            # Type de cours
            # Date du cours
            # Montant origine
            # Montant destination
            # Status de retour (0 = OK)

            If !IERRCOUNT

                #Champs AMT
    
                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:CAM]AMT
                IERRCOUNT = 0
                If SZCURTOUSE <> GEURO
                    If [F:CAM]AMTSTR = [00/00/00]
                        Call CONVERT(SZCURTOUSE,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Else
                        Call CONVERT(SZCURTOUSE,GEURO,CODEDEVSOC,TYPCUR,[F:CAM]AMTSTR,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Endif
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "AMT",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:CAM]CONNUM + " - " + num$([F:CAM]AMTRECNUMX), 1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:CAM]AMT = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif
                
                If IERRCOUNT
                    Rollback
                Else
                    Rewrite [CAM]
                    If fstat
                        Rollback
                        Call ECR_TRACE(mess(464,196,1) + [M:CEUR]COD(2), 1) From GESECRAN    #Erreur lors de la conversion de la table 
                        Call ECR_TRACE(mess(469,196,1) + [F:CAM]CONNUM + " - " + num$([F:CAM]AMTRECNUMX), 1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Else
                        Commit
                    Endif
                Endif
            Endif
        Endif
    Endif

    IPROCOUNT += 1

    If !GINTRA
        Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
    Endif

    If !IERRCOUNT
        If ICONVERT
            ICNVCOUNT += 1
            If IDETTRACE 
                Call ECR_TRACE(mess(470,196,1) + [F:CAM]CONNUM + " - " + num$([F:CAM]AMTRECNUMX), 0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
            Endif
        Endif
    Else
        IERRFLG = 1
    Endif
Next

[M:CEUR]NBRRECCNV(2) = ICNVCOUNT

If IERRFLG
    [M:CEUR]STA(2) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(2) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

#############################################################################
#Modèles de contrats de service
#############################################################################
$PROCOT
SZKEY = ""
IBOITEOK = 1
ICONVERT = 0
IGOCOUNT = 0
ICNVCOUNT = 0
IPROCOUNT = 0
IGO = 1
CODEDEVSOC = ""
STAT_OK = 1
IERRFLG = 0

While IGO

    IGO = 0

    Filter [COT] Where [F:COT]CONNUM > SZKEY

    For [COT]
        IERRCOUNT = 0
        ICONVERT = 0
        If [M:CEUR]CNVLESFLG = 2
            Call MUSTCONVERT([F:COT]CUR, ICONVERT)
        Else
            ICONVERT = 0
        Endif

        If ICONVERT
            Call DEBTRANS From GLOCK
            Trbegin [COT]

            STAT_OK = 1
            CODEDEVSOC = ""
            Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
            If !STAT_OK #Erreur
                Rollback
                Call ECR_TRACE(mess(465,196,1),1) From GESECRAN    #Erreur lors de la recherche de la devise société.
                Call ECR_TRACE(mess(469,196,1) + [F:COT]CONNUM,1) From GESECRAN    #Enregistrement n° : XXX
                IERRCOUNT = 1
            Endif

            # Devise d'origine
            # Devise destination
            # Devise de la société
            # Type de cours
            # Date du cours
            # Montant origine
            # Montant destination
            # Status de retour (0 = OK)

            If !IERRCOUNT

                #Champs AMTPLY

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:COT]AMTPLY
                IERRCOUNT = 0
                If [F:COT]CUR <> GEURO
                    Call CONVERT([F:COT]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "AMTPLY",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:COT]CONNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        [F:COT]AMTPLY = MNTEURO
                    Endif
                Else
                    ICONVERT = 0
                Endif

                #Champs AMTPLYX

                STAT_OK = 0
                MNTCURIN = 0
                MNTEURO = 0
                MNTCURIN = [F:COT]AMTPLYX
                If [F:COT]CUR <> GEURO
                    Call CONVERT([F:COT]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    If STAT_OK #Erreur
                        IERRCOUNT = 1
                        Call ECR_TRACE(mess(468,196,1) + "AMTPLYX",1) From GESECRAN    #Erreur lors de la conversion du champs : OPPAMT
                        Call ECR_TRACE(mess(469,196,1) + [F:COT]CONNUM,1) From GESECRAN    #Enregistrement n° : XXX
                    Else #Calcul OK
                        If !IERRCOUNT
                            [F:COT]AMTPLYX = MNTEURO
                        Endif
                    Endif
                Else
                    ICONVERT = 0
                Endif

                [F:COT]CUR = GEURO

                If IERRCOUNT
                    Rollback
                Else
                    Rewrite [COT]
                    If fstat
                        Rollback
                        Call ECR_TRACE(mess(464,196,1) + [M:CEUR]COD(3),1) From GESECRAN  #Erreur lors de la conversion de la table 
                        Call ECR_TRACE(mess(469,196,1) + [F:COT]CONNUM,1) From GESECRAN    #Enregistrement n° : XXX
                        IERRCOUNT = 1
                    Else
                        Commit
                    Endif
                Endif
            Endif
        Endif

        IPROCOUNT += 1
        IGOCOUNT += 1

        If !GINTRA
            Call AFF_BOITE (SZMESS, IPROCOUNT, IBOITEOK) From GESECRAN
        Endif

        If !IERRCOUNT
            If ICONVERT
                ICNVCOUNT += 1
                If IDETTRACE 
                    Call ECR_TRACE(mess(470,196,1) + [F:COT]CONNUM,0) From GESECRAN    #Conversion réussie pour l'enregistrement : XXX
                Endif
            Endif
        Else
            IERRFLG = 1
        Endif

        If IGOCOUNT > 1250
            SZKEY = [F:COT]CONNUM
            IGO = 1
            IGOCOUNT = 0
            Break
        Endif
    Next
Wend

Filter [COT]

[M:CEUR]NBRRECCNV(3) = ICNVCOUNT

If IERRFLG
    [M:CEUR]STA(3) = mess(466,196,1) #Erreurs constatées
    Call ECR_TRACE(mess(466,196,1),0) From GESECRAN
Else
    [M:CEUR]STA(3) = mess(460,196,1) #Conversion réussie
    Call ECR_TRACE(mess(460,196,1),0) From GESECRAN
Endif
Return

