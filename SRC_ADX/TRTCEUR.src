                        Call CONVERT([F:ITN]CUR,GEURO,CODEDEVSOC,TYPCUR,date$,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
                    Else
                        Call CONVERT([F:ITN]CUR,GEURO,CODEDEVSOC,TYPCUR,[F:ITN]DAT,MNTCURIN,MNTEURO,STAT_OK) From TRTDEV
