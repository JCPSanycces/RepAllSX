CODEDEVSOC = ""
STAT_OK = 1
IERRFLG = 0

While IGO

    IGO = 0

    Filter [CON] Where [F:CON]CONNUM > SZKEY

    For [CON]
        IERRCOUNT = 0
        ICONVERT = 0
        Call MUSTCNV2([F:CON]CUR, [F:CON]SALFCY, ICONVERT)

        If ICONVERT
            Call DEBTRANS From GLOCK
