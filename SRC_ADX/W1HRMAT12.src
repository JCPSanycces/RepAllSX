#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT12 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:40"
A_USER  = "DOC"
A_STAMP = "20181109230440"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRPAR"
  If [M]NBRPAR=0
  Endif
 When "WNBRFDSPAR"
  If [M]WNBRFDSPAR=0
  Endif
 When "WNBRFDSITS"
  If [M]WNBRFDSITS=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT12 [EMPC]
Gosub HORODAT
Local Inpbox "HRMAT12" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMPC] As [SIM_]
Grizo [EMPC]10
Grizo [EMPC]20
Grizo [EMPC]30
Grizo [EMPC]40
Grizo [EMPC]50
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMPC]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=22 : Y1(0)=1 : Y2(0)=23
X1(1)=23 : X2(1)=74 : Y1(1)=1 : Y2(1)=4
X1(2)=23 : X2(2)=74 : Y1(2)=5 : Y2(2)=13
X1(3)=23 : X2(3)=74 : Y1(3)=14 : Y2(3)=21
X1(4)=23 : X2(4)=74 : Y1(4)=22 : Y2(4)=23
Return

$ON_NBRPAR
Onevent BEFORE_INPUT Call AS_NBRPAR From W1HRMAT12
Onevent CONTROL Call C_NBRPAR From W1HRMAT12
Return

Subprog AS_NBRPAR
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBRPAR From SUBEML2
Gosub _AFF
End

Subprog C_NBRPAR
Local Decimal BASPAG
## Action STD
Call C_NBRPAR From SUBEML2
If mkstat : GERR = 1 : GZONE = "NBRPAR" : GZNUM = 0 : Endif
Gosub _AFF
End

