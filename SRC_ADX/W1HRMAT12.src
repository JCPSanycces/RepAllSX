$ON_WFDSPAR
Onevent CONTROL Call C_WFDSPAR(zc) From W1HRMAT12
Onevent AFTER_CHANGE Gosub AMM_WFDSPAR From W1HRMAT12
Onevent BEFORE_INPUT Call AS_WFDSPAR(zc) From W1HRMAT12
Return

Subprog AS_WFDSPAR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45508,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WFDSPAR(zc) From W1HRMAT12
Onkey   2 Titled GBOUTS Call S_WFDSPAR(zc) From W1HRMAT12
Onkey 144 Titled GBOUTP Call P_WFDSPAR(zc) From W1HRMAT12
Onkey 146 Titled GBOUTA Call SA_WFDSPAR(zc) From W1HRMAT12
Gosub _AFF
End

Subprog C_WFDSPAR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WFDSPAR" : GZNUM = 45508 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("FDS","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "WFDSPAR" : GZNUM = 45508 : Endif
 If !mkstat
  ## Action STD
  Call C_WFDSPAR(VALEUR) From SUBEML2
  If mkstat : GERR = 1 : GZONE = "WFDSPAR" : GZNUM = 45508 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_WFDSPAR
Call AM_WFDSPAR(zc)
If !mkstat & GOBJET
 zoncou = "WFDSPAR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WFDSPAR(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WFDSPAR(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "WFDSPAR" : GZNUM = 45508 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWFDSPAR)")>indice
 [M]WFDSPAR(indice) = VALEUR
 Affzo ZWFDSPAR(indice)
Endif
Gosub _AFF
End

Subprog S_WFDSPAR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FDS"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_WFDSPAR(VALEUR)
Variable Char    VALEUR()
Call OBJET("FDS",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_WFDSPAR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FDS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WFDSPAR(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FDS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZWFDSPAR
Onevent BEFORE_AREA Gosub AV_ZWFDSPAR From W1HRMAT12
Return

$AV_ZWFDSPAR
If clalev([F:FDS])=0 : Local File FONDS [FDS] : Endif
Call LECTURE("FDS",num$([M]WFDSPAR(indice)),"") From CONTOBJ
zc = [F:FDS]DES
Gosub _AFF
Return

