Return

$AV_WPARDAT
Chgfmt [M]WPARDAT(indice) With "DzZ:"+GFMDAT4
Gosub _AFF
Return

Subprog AS_WPARDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_WPARDAT(VALEUR) From SUBEML2
If mkstat=2
 [M]WPARDAT(INDIC) = VALEUR
 Affzo WPARDAT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_WPARDAT(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_WPARDAT(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "WPARDAT" : GZNUM = 212 : Endif
Gosub _AFF
End

$ON_WFLGPAR
Onevent BEFORE_INPUT Call AS_WFLGPAR(zc) From W1HRMAT12
Onevent AFTER_CHANGE Gosub AMM_WFLGPAR From W1HRMAT12
Onevent INIT_AREA Call D_WFLGPAR(zc) From W1HRMAT12
Return

Subprog D_WFLGPAR(VALEUR)
Variable Integer VALEUR
If varinit([M]WFLGPAR,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_WFLGPAR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_WFLGPAR(VALEUR) From SUBEML2
If mkstat=2
 [M]WFLGPAR(INDIC) = VALEUR
 Affzo WFLGPAR(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_WFLGPAR
Call AM_WFLGPAR(zc)
If !mkstat & GOBJET
 zoncou = "WFLGPAR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WFLGPAR(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_WFLGPAR(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "WFLGPAR" : GZNUM = 46653 : Endif
Gosub _AFF
End

