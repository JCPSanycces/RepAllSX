#<AdxTL>@(#)6.0.0.0 $Revision$
##############################################################################################
## AUSRSTA : Gestion des stats d'utilisation
##############################################################################################
$ACTION
Case ACTION
 When "EXEC" : Call ENVOI_STAT([M:DIA]DAT)
Endcase
Return

##############################################################################################
## Mise à jour des stats d'utilisation
##############################################################################################
Subprog MAJSTA(USER,EVENEMENT,COMP1,COMP2)
Value Char    USER
Value Integer EVENEMENT
Value Char    COMP1
Value Char    COMP2
If clalev([F:AUA])=0 : Local File AUSRSTA [AUA] : Endif
Local Char PERIODE(4) , PASSE(24)
PERIODE = format$("D:YYMM",date$)
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR1
Else
 Gosub MAJ_STA
Endif
End

$TR1
GOK = 1
Trbegin [AUA]
 Gosub MAJ_STA
 If GOK=-1 : Goto ROLL_TR1
 Elsif GOK<1 : Goto AB_TR1
 Endif
Commit
Return

$MAJ_STA
Readlock [AUA]AUA1 = nomap;USER;PERIODE;EVENEMENT;COMP1;COMP2
If fstat=1
 GOK = -1 : GLOCK = "$AUSRSTA" : Return
Elsif fstat
 Raz [F:AUA]
 [F:AUA]NUM = uniqid([AUA])
 [F:AUA]DOSSIER = nomap
 [F:AUA]USR     = USER
 [F:AUA]PER     = PERIODE
 [F:AUA]EVT     = EVENEMENT
 [F:AUA]ARG1    = COMP1
 [F:AUA]ARG2    = COMP2
 [F:AUA]NBR     = 1
 [F:AUA]FLG     = 0
 Gosub CRYPTE
 Write [AUA]
Else
 [F:AUA]NBR += 1
 [F:AUA]FLG  = 0
 Gosub CRYPTE
 Rewrite [AUA]
Endif
If fstat
 GOK = 0 : Call FSTA("AUA") From GLOCK : Return
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$CRYPTE
PASSE = format$("K:5X",COMP1)+format$("N0:7#",[F:AUA]NBR+[F:AUA]NUM)
Call CRYPTNEW(PASSE) From GESUSER
[F:AUA]CTR = PASSE
Return

##############################################################################################
## Création du fichier trace + vérification + envoi du mail
##############################################################################################
Subprog ENVOI_STAT(DAT)
Value Date DAT
Call TRACE(DAT)
Call MAJFLG(DAT)
Call MAIL(DAT)
End

Subprog TRACE(DAT)
Value Date DAT
If clalev([F:AUA])=0 : Local File AUSRSTA [AUA] : Endif
Local Char    SAVIFS(2) , SAVIRS(2)
Local Integer SAVIUM
Local Char    PERIODE(4) , PASSE(24) , LICENCE(12)
Local Char    FICHIER(250)
Local Integer NBLIG , NBTROU , NBERR , NUMLIG
PERIODE = format$("D:YYMM",DAT)
LICENCE = right$(ver$(0),len(ver$(0))-11)
FICHIER = filpath("tmp","stat"+PERIODE,"xml")
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxirs = chr$(10)
adxifs = ""
adxium = GASCII
Openo FICHIER,0
Wrseq "<STAT_LICENCE>"
Wrseq "<ENTETE>"
Wrseq "<LICENCE>";LICENCE;"</LICENCE>"
Wrseq "<PERIODE>";PERIODE;"</PERIODE>"
Wrseq "</ENTETE>"
NUMLIG = 0
NBLIG  = 0
NBTROU = 0
NBERR  = 0
Wrseq "<STATS>"
For [AUA]AUA0 Where PER=PERIODE & FLG=0
 Wrseq "<LIGNE>";
 NBLIG += 1
 If NUMLIG<>0 & [F:AUA]NUM<>NUMLIG+1
  NBTROU += 1
 Endif
 NUMLIG = [F:AUA]NUM
 Wrseq "<NUM>";num$([F:AUA]NUM);"</NUM>";
 Wrseq "<DOSSIER>";[F:AUA]DOSSIER;"</DOSSIER>";
 Wrseq "<USER>";[F:AUA]USR;"</USER>";
 Wrseq "<EVT>";num$([F:AUA]EVT);"</EVT>";
 Wrseq "<ARG1>";[F:AUA]ARG1;"</ARG1>";
 Wrseq "<ARG2>";[F:AUA]ARG2;"</ARG2>";
 Wrseq "<VALEUR>";num$([F:AUA]NBR);"</VALEUR>";
 Wrseq "<CLE>";[F:AUA]CTR;"</CLE>";
 PASSE = format$("K:5X",[F:AUA]ARG1)+format$("N0:7#",[F:AUA]NBR+[F:AUA]NUM)
 Call CRYPTNEW(PASSE) From GESUSER
 If PASSE<>[F:AUA]CTR
  Wrseq "<ERR>1</ERR>";
  NBERR += 1
 Else
  Wrseq "<ERR>0</ERR>";
 Endif
 Wrseq "</LIGNE>"
Next
Wrseq "</STATS>"
Wrseq "<PIED>"
Wrseq "<NBLIG>";num$(NBLIG);"</NBLIG>"
Wrseq "<TROU>";num$(NBTROU);"</TROU>"
Wrseq "<ERREUR>";num$(NBERR);"</ERREUR>"
Wrseq "</PIED>"
Wrseq "</STAT_LICENCE>"
Openo
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

Subprog MAJFLG(DAT)
Value Date DAT
If clalev([F:AUA])=0 : Local File AUSRSTA [AUA] : Endif
Local Char PERIODE(4)
PERIODE = format$("D:YYMM",DAT)
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR2
Else
 Gosub MAJ_FLG
Endif
End

$TR2
GOK = 1
Trbegin [AUA]
 Gosub MAJ_FLG
Commit
Return

$MAJ_FLG
Update [AUA] Where PER=PERIODE & FLG=0 With FLG=1
Return

Subprog MAIL(DAT)
Value Date DAT
If clalev([F:AUA])=0 : Local File AUSRSTA [AUA] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL  [ADW] : Endif
Local Char    PERIODE(4)
Local Char    FICMAIL(250) , FICTRA(250)
Local Char    PCEFIC(250) , PCEJNT(250) , ORDSYS(250)(1..2)
Local Char    SAVIFS(2) , SAVIRS(2)
Local Char    MELORG(250) , MELDES(250)
Local Integer SAVIUM , STAT
PERIODE = format$("D:YYMM",DAT)
FICMAIL = filpath("tmp","stat"+PERIODE,"mel")
FICTRA  = filpath("tmp","stat"+PERIODE,"tra")
PCEFIC  = filpath("tmp","stat"+PERIODE,"xml")
PCEJNT  = "stat"+PERIODE+".xml"
Read [ADW]ADW0 = "";"";"MAILSAGE"
MELDES = [F:ADW]VALEUR
Read [AUS]CODUSR = GUSER
MELORG = [F:AUS]ADDEML
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxirs = chr$(10)
adxifs = ""
adxium = GUTF8
Openo FICMAIL,0
Wrseq "From: ";MELORG
Wrseq "To: ";MELDES
Wrseq "Subject:"-"Statistiques"-month$(DAT)-num$(year(DAT))
Wrseq
Wrseq "Ci-joint les statistiques d'utilisation X3"
Wrseq "Licence"-ver$(0)
Wrseq
Wrseq '# Application/others ; name="';PCEJNT;'" "';PCEFIC;'"'
Wrseq
Openo
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
ORDSYS(1) = "meladx"-"-s"-GSERMES-"<"+FICMAIL
ORDSYS(2) = FICTRA
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
End
