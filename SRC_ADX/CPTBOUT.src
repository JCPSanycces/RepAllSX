#<AdxTL>@(#)3.0.0.0 $Revision$
#################################################################################
## COMPTA : Actions diverses de type 'bouton'
## DIELOAD : Bouton Pré-chargement automatique des axes du dossier
#################################################################################
Subprog DIELOAD(SOCIETE)
Value Char SOCIETE
## Pré-charge automatiquement les axes sans écraser ceux qui avaient été préalablement 
## saisi par l'utilisateur....  
## si SOCIETE<>"", on ne pré-charge que les axes définis pour la société via le modéle cptable
## puis les référentiel, sinon on les pré-charge tous
## SOCIETE peut être une site...

If clalev([F:DIE]) = 0 : Local File GDIE [DIE] : Endif
If clalev([F:CPY]) = 0 : Local File COMPANY [CPY] : Endif
If clalev([F:GCM]) = 0 : Local File GACM [GCM] : Endif
If clalev([F:LED]) = 0 : Local File GLED [LED] : Endif


Local Integer LASTSAI
LASTSAI = [M]NBRDIE

Local Char MODELE(GLONGCM)
If SOCIETE<>""
 Raz [M]DIE
 [M]NBRDIE=0
 Call SETGCM(SOCIETE,MODELE) From CPTDIV
 Call LECTURE("GCM",MODELE,"")  From CONTOBJ
 For I=0 To dim([F:GCM]LED)-1
  If [F:GCM]LED(I)<>""
   Call LECTURE("LED",[F:GCM]LED(I),"") From CONTOBJ
   For J=0 To [F:LED]DIENBR-1
    If !find([F:LED]DIE(J),[M]DIE(0..dim([M]DIE)-1))
     [M]DIE([M]NBRDIE) = [F:LED]DIE(J)
     [M]NBRDIE += 1
    Endif
    If [M]NBRDIE>=dim([M]DIE) : Break : Endif
   Next J
  Endif
 Next I
Else
 For [DIE]DIE0
  If !find([F:DIE]DIE,[M]DIE(0..LASTSAI-1))
   [M]DIE([M]NBRDIE) = [F:DIE]DIE
   [M]NBRDIE += 1
  Endif
  If [M]NBRDIE>=dim([M]DIE) : Break : Endif
 Next
Endif
Affzo [M]DIE
If dim([M]ZDIE)>0
 Affzo [M]ZDIE
Endif
mkstat = 4 
End

