#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation Class EDIPARTNER                                             #
# RBA + JUCON                                                                 #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
        When "AREAD_AFTER"           : Gosub AREAD_AFTER
      Endcase
    When "EPR" :
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EPR_AREAD_AFTER
      Endcase
    When "EPR.EPRD"
      Case [L]AEVENT
        When "AREAD_AFTER"          : Gosub EPR_EPRD_AREAD_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "EPR.EPRD.CATCOD"
      Case [L]ARULE
        When "PROPAGATE"  : Gosub EPR_EPRD_CATCOD_PROPAGATE
      Endcase
    When "EPR.EPRD.CATACT" #for refresh if error before
      Case [L]ARULE
        When "PROPAGATE"  : Gosub EPR_EPRD_CATACT_PROPAGATE
      Endcase
    When "EPR.EPRD.PTCCOD"
      Case [L]ARULE
        When "PROPAGATE"  : Gosub EPR_EPRD_PTCCOD_PROPAGATE
      Endcase
  Endcase
Return

#####################################################################

$EPR_EPRD_CATCOD_PROPAGATE
  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
Return

#####################################################################

$EPR_EPRD_CATACT_PROPAGATE
  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
Return

#####################################################################

$EPR_EPRD_PTCCOD_PROPAGATE
  this.PTCDES = fmet this.ACTX.ACACHE.EPT.AGETVALCHAR(this.PTCCOD,"PTCDES")
Return

#####################################################################

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#*
#*!
$AREAD_AFTER
  Local Integer WPOS, WNB

 #display EDI partners by company using the current partner
  WPOS = 0
  WNB = 0
  Local File EDICPYPAR [ECP]
  Local File COMPANY [CPY]
  Link [CPY] With [ECP]ECP0 = [CPY]CPY;this.EPR.PARCOD As [LIEN] Where [CPY]CPY = [ECP]CPY Order By [CPY]CPY
  For [LIEN]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      WPOS = fmet this.ADDLINE('CPYPAR', [V]CST_ALASTPOS)
      this.CPYPAR(WPOS).CPYPARCPY    = [CPY]CPY
      this.CPYPAR(WPOS).CPYPARCPYNAM = [CPY]CPYNAM
      this.CPYPAR(WPOS).CPYPARVALID  = [ECP]VALID
      this.CPYPAR(WPOS).CPYPAREDICOD = [ECP]EXCEDICOD
    Endif
  Next
  LogicClose File [ECP]
  LogicClose File [CPY]


 #display EDI partners by site using the current partner
  WPOS = 0
  WNB = 0
  Local File EDIFCYPAR [EFP]
  Local File FACILITY [FCY]
  Local File COMPANY [CPY]
  Link [FCY] With [EFP]EFP0 = [FCY]FCY;this.EPR.PARCOD, [CPY]CPY0 = [FCY]LEGCPY  As [LIEN] Where [FCY]FCY = [EFP]FCY Order By [CPY]CPY; [FCY]FCY
  For [LIEN]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      WPOS = fmet this.ADDLINE('FCYPAR', [V]CST_ALASTPOS)
      this.FCYPAR(WPOS).FCYPARCPY    = [CPY]CPY
      this.FCYPAR(WPOS).FCYPARCPYNAM = [CPY]CPYNAM
      this.FCYPAR(WPOS).FCYPARFCY    = [EFP]FCY
      this.FCYPAR(WPOS).FCYPARFCYNAM = [FCY]FCYNAM
      this.FCYPAR(WPOS).FCYPARVALID  = [EFP]VALID
      this.FCYPAR(WPOS).FCYPAREDICOD = [EFP]EXCEDICOD
    Endif
  Next
  LogicClose File [EFP]
  LogicClose File [FCY]
  LogicClose File [CPY]


  #display EDI partners by BP using the current partner
  WPOS = 0
  WNB = 0
  Local File EDIBPRPAR [EBP]
  Local File BPARTNER [BPR]
  Local File BPADDRESS [BPA]
  Link [EBP] With [BPR]BPR0 = [EBP]BPANUM, [BPA]BPA0 = [EBP]BPATYP;[EBP]BPANUM;[EBP]BPAADD As [LIEN] Where [EBP]PARCOD = this.EPR.PARCOD Order By [EBP]BPANUM; [EBP]BPAADD
  For [LIEN]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      WPOS = fmet this.ADDLINE('BPRPAR', [V]CST_ALASTPOS)
      this.BPRPAR(WPOS).BPRPARVALID     = [EBP]VALID
      this.BPRPAR(WPOS).BPRPARBPANUM    = [EBP]BPANUM
      this.BPRPAR(WPOS).BPRPARBPRNAM    = [BPR]BPRNAM
      this.BPRPAR(WPOS).BPRPARBPAADD    = [EBP]BPAADD
      this.BPRPAR(WPOS).BPRPARBPADES    = [BPA]BPADES
      this.BPRPAR(WPOS).BPRPAREDICOD = [EBP]EXCEDICOD
    Endif
  Next
  LogicClose File [BPA]
  LogicClose File [BPR]
  LogicClose File [EBP]


  #display EDI flows using the current partner
  WPOS = 0
  WNB = 0
  Local File EDIFLO [EFL]
  Filter [EFL] Where PARCOD = this.EPR.PARCOD Order By FLOCOD; FLOREL
  For [EFL]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      WPOS = fmet this.ADDLINE('FLO', [V]CST_ALASTPOS)
      this.FLO(WPOS).FLOFLOCOD = [EFL]FLOCOD
      this.FLO(WPOS).FLOFLOREL = [EFL]FLOREL
      this.FLO(WPOS).FLOFLODES = [EFL]FLODES
      this.FLO(WPOS).FLOVALID  = [EFL]VALID
      this.FLO(WPOS).FLOFLGACT = [EFL]FLGACT
    Endif
  Next
  LogicClose File [EFL]


  #display business partner/company with flows using the current partner
  WPOS = 0
  WNB = 0
  Local File EDIBPRCPYD [EBCD]
  Local File EDIBPRPAR [EBP]
  Local File EDICPYPAR [ECP]
  Local File EDIFCYPAR [EFP]

  Local File BPARTNER [BPR]
  Local File BPADDRESS [BPA]
  Local File COMPANY [CPY]
  Local File FACILITY [FCY]
  Local File EDIFLO [EFL]

  Link [EBCD] With [EBP]EBP0 = 1;[EBCD]BPRNUM,
&                  [CPY]CPY0 = [EBCD]CPY,
&                  [EFL]EFL0 = [EBCD]FLOCOD;[EBCD]FLOREL,
&                  [BPR]BPR0 = [EBCD]BPRNUM,
&                  [BPA]BPA0 = 1;[EBP]BPANUM;[EBP]BPAADD,
&                  [FCY]FCY1 = [EBCD]CPY,
&                  [EFP]EFP0 = [FCY]FCY; this.EPR.PARCOD
& As [LIEN] Where [EBCD]PARCOD = this.EPR.PARCOD and [EBP]PARCOD = this.EPR.PARCOD
& Order By [EBP]BPANUM; [EBP]BPAADD; [EBCD]CPY; [EFP]FCY; [EBCD]FLOCOD; [EBCD]FLOREL
#Issue X3-107513 by RBA 05-09-2018
  For [LIEN]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      WPOS = fmet this.ADDLINE('BPRCPY', [V]CST_ALASTPOS)
      this.BPRCPY(WPOS).BPRCPYBPRNUM = [EBCD]BPRNUM
      this.BPRCPY(WPOS).BPRCPYBPRNAM = [BPR]BPRNAM
      this.BPRCPY(WPOS).BPRCPYBPAADD = [EBP]BPAADD
      this.BPRCPY(WPOS).BPRCPYBPADES = [BPA]BPADES
      this.BPRCPY(WPOS).BPRCPYCPY    = [EBCD]CPY
      this.BPRCPY(WPOS).BPRCPYCPYNAM = [CPY]CPYNAM
      this.BPRCPY(WPOS).BPRCPYFCY    = [FCY]FCY
      this.BPRCPY(WPOS).BPRCPYFCYNAM = [FCY]FCYNAM
      this.BPRCPY(WPOS).BPRCPYFLOCOD = [EBCD]FLOCOD
      this.BPRCPY(WPOS).BPRCPYFLOREL = [EBCD]FLOREL
      this.BPRCPY(WPOS).BPRCPYVALID  = [EFL]VALID #Flow
      this.BPRCPY(WPOS).BPRCPYFLGACT = [EFL]FLGACT #Flow
    Endif
  Next

  LogicClose File [EFL]
  LogicClose File [FCY]
  LogicClose File [CPY]
  LogicClose File [BPA]
  LogicClose File [BPR]
  LogicClose File [EFP]
  LogicClose File [ECP]
  LogicClose File [EBP]
  LogicClose File [EBCD]

Return


#********************************************************************
# Method EPR_AREAD_AFTER
#********************************************************************
#*
#*!
$EPR_AREAD_AFTER
  WOK = fmet this.ASETATTRIBUTE('PARDES', "$isDisabled", 'false')
Return


#********************************************************************
# Method EPR_EPRD_AREAD_AFTER
#********************************************************************
#*
#*!
$EPR_EPRD_AREAD_AFTER
 # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  If this.CATOPE = 0  # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
    this.CATOPE = 2 #Create
  Endif

  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
  this.PTCDES = fmet this.ACTX.ACACHE.EPT.AGETVALCHAR(this.PTCCOD,"PTCDES")
Return


#********************************************************************
# Method AQUERY_TRANS_AFTER
#********************************************************************
#*
#*!
$AQUERY_TRANS_AFTER
Return

