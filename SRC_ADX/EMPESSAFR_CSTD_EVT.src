#<AdxTL>@(#)0.0.0.0 $Revision$
$AINSERT_AUPDATE_AFTER

#Write the data for all the EMPESSXXX classes to workflow
#Using activity codes - Check all classes and pass to workflow function in ESS_WRKFLOW_FUNC
#Manage call with activity codes
#---------------------All legislations------------------------------------------------------------#
Gosub PASS_CLASSES_WORKFLOW_EMPESSAFR
Gosub PASS_CLASSES_WORKFLOW_EMPESSAFR_EMPADR
Gosub PASS_CLASSES_WORKFLOW_EMPESSAFR_PASDET

Return

$PASS_CLASSES_WORKFLOW_EMPESSAFR
#The following steps must be followed to trigger the workflow for all employee related records
#Declare all variables - Standard no custom code needed
Gosub PASS_CLASSES_WORKFLOW_VARIABLES From ESS_WRKFLOW_FUNC

#---------------------------------------------------------------------------------------------------#
#Before creating possible workflow records - indicate any properties that must be excluded (SYSPROP - From (30)
#..

#Specify the keys of the actual table - Char ALPKEY(250)(1..3),Integer INTKEY(1..3) ,Date DATKEY(1..3)
ALPKEY(0) = this.REFNUM

#Specify function variables
MAIN_CLASSCOD = "EMPLOIDAFR"    #The main class that was used to create the ESSXXX Class
CLASSCOD      = "EMPESSAFR"     #The ESS Class where the change occurred
THISUSR       = this.ACTX.USER

#EMPESSAFR
If this.EMPESSAFR <> null
  #Getting paramater values
  CLASSPARAMFNC = func ESS_WRKFLOW_FUNC.GET_CLASS_PARAMETERS(MAIN_CLASSCOD,CTABLE,CABR) #Manual assignment
  If this.EMPESSAFR <> null
    For COLLECTION_IND = 1 To maxtab(this.EMPESSAFR)
      If CLASSPARAMFNC = [V]CST_AOK and this.EMPESSAFR(COLLECTION_IND) <> null
        #Specify the keys needed for workflow (ALPKEY,INTKEY,DATKEY)
        INTKEY(0) = COLLECTION_IND

        #Test the status of the class and set WRK variable
        #This test must include the manual status added on class transfer
          If this.EMPESSAFR(COLLECTION_IND).ASTALIN = [V]CST_ANEWDEL
            WRK = "D"
          Else
            WRK = "M"
          Endif

        #New lines created by the user
        If this.EMPESSAFR(COLLECTION_IND).TCH_AFRSTA <> "T"
          If this.EMPESSAFR(COLLECTION_IND).ASTALIN <> [V]CST_ANEWDEL
            If this.EMPESSAFR(COLLECTION_IND).ASTALIN = [V]CST_ANEW
              WRK = "C"
            Endif
          Endif
        Endif

        If WRK <> ""
          #A Function per class must be added to ESS_WRKLOW_FUNC
          CLASS_WRKFLOW = func ESS_WRKFLOW_FUNC.GENESSWRKFLOW_ESSWRKAFR(WRK,this,THISUSR,this.EMPESSAFR,this.EMPESSAFR,
&         CLASSCOD,CTABLE, CABR,CLASS_ERROR,SYSPROP,ALPKEY,INTKEY,DATKEY,CLEOBJ)
        Endif
      Endif
    Next
  Endif
Endif

Return

$PASS_CLASSES_WORKFLOW_EMPESSAFR_EMPADR
#The following steps must be followed to trigger the workflow for all employee related records
#Declare all variables - Standard no custom code needed
Gosub PASS_CLASSES_WORKFLOW_VARIABLES From ESS_WRKFLOW_FUNC

#---------------------------------------------------------------------------------------------------#
#Before creating possible workflow records - indicate any properties that must be excluded (SYSPROP - From (30)
#..



#Specify function variables
MAIN_CLASSCOD = "EMPLOIDAFR"    #The main class that was used to create the ESSXXX Class
CLASSCOD      = "EMPESSAFR" #The ESS Class where the change occurred
THISUSR       = this.ACTX.USER

#EMPESSAFR
If this.EMPESSAFR <> null
  #Getting paramater values
  #CLASSPARAMFNC = func ESS_WRKFLOW_FUNC.GET_CLASS_PARAMETERS(MAIN_CLASSCOD,CTABLE,CABR) #Manual assignment
  CLASSPARAMFNC = [V]CST_AOK
  CTABLE  = "EMPLOIDAFRRT"
  CABR    = "EAFR"
  If this.EMPESSAFR.EMPADR <> null
    For COLLECTION_IND = 1 To maxtab(this.EMPESSAFR.EMPADR)
      If CLASSPARAMFNC = [V]CST_AOK and this.EMPESSAFR.EMPADR(COLLECTION_IND) <> null
      #Specify the keys of the actual table - Char ALPKEY(250)(1..3),Integer INTKEY(1..3) ,Date DATKEY(1..3)
      Raz INTKEY,DATKEY,ALPKEY
      ALPKEY(0) = this.REFNUM
      INTKEY(0) = COLLECTION_IND

        #Test the status of the class and set WRK variable
        #This test must include the manual status added on class transfer
        If this.EMPESSAFR.EMPADR(COLLECTION_IND).TCH_ADDSTA = "T"
          If this.EMPESSAFR.EMPADR(COLLECTION_IND).ASTALIN = [V]CST_ANEWDEL
            WRK = "D"
          Else
            WRK = "M"
          Endif
        Endif

        #New lines created by the user
        If this.EMPESSAFR.EMPADR(COLLECTION_IND).TCH_ADDSTA <> "T"
          If this.EMPESSAFR.EMPADR(COLLECTION_IND).ASTALIN <> [V]CST_ANEWDEL
            If this.EMPESSAFR.EMPADR(COLLECTION_IND).ASTALIN = [V]CST_ANEW
              WRK = "C"
            Endif
          Endif
        Endif
        If WRK <> ""
          #A Function per class must be added to ESS_WRKLOW_FUNC
          CLASS_WRKFLOW = func ESS_WRKFLOW_FUNC.GENESSWRKFLOW_ESSWRKAFR_EMPADR(WRK,this,THISUSR,this.EMPESSAFR,this.EMPESSAFR.EMPADR(COLLECTION_IND),
&         CLASSCOD,CTABLE, CABR,CLASS_ERROR,SYSPROP,ALPKEY,INTKEY,DATKEY,CLEOBJ)
        Endif
      Endif
    Next
  Endif
Endif

Return

$PASS_CLASSES_WORKFLOW_EMPESSAFR_PASDET
#The following steps must be followed to trigger the workflow for all employee related records
#Declare all variables - Standard no custom code needed
Gosub PASS_CLASSES_WORKFLOW_VARIABLES From ESS_WRKFLOW_FUNC

#---------------------------------------------------------------------------------------------------#
#Before creating possible workflow records - indicate any properties that must be excluded (SYSPROP - From (30)
#..


#Specify function variables
MAIN_CLASSCOD = "EMPLOIDAFR"    #The main class that was used to create the ESSXXX Class
CLASSCOD      = "EMPESSAFR" #The ESS Class where the change occurred
THISUSR       = this.ACTX.USER

#EMPESSSA
If this.EMPESSAFR <> null
  #Getting paramater values
  #CLASSPARAMFNC = func ESS_WRKFLOW_FUNC.GET_CLASS_PARAMETERS(MAIN_CLASSCOD,CTABLE,CABR) #Manual assignment
  CTABLE  = "EMPLOIDSPAS"
  CABR    = "ESAR"
  If this.EMPESSAFR.PASDET <> null
    #Count all the records
    For COLLECTION_IND = 1 To maxtab(this.EMPESSAFR.PASDET)
      If this.EMPESSAFR.PASDET(COLLECTION_IND)<>null & find(this.EMPESSAFR.PASDET(COLLECTION_IND).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        COLCOUNT+=1
      Endif
    Next
    For COLLECTION_IND = 1 To maxtab(this.EMPESSAFR.PASDET)
      If CLASSPARAMFNC = [V]CST_AOK and this.EMPESSAFR.PASDET(COLLECTION_IND) <> null
        #Specify the keys of the actual table - Char ALPKEY(250)(1..3),Integer INTKEY(1..3) ,Date DATKEY(1..3)
        Raz INTKEY,DATKEY,ALPKEY
        ALPKEY(0) = this.REFNUM
        INTKEY(0) = COLLECTION_IND

        #Test the status of the class and set WRK variable
        #This test must include the manual status added on class transfer
        If this.EMPESSAFR.PASDET(COLLECTION_IND).TCH_PASSTA = "T"
          If this.EMPESSAFR.PASDET(COLLECTION_IND).ASTALIN = [V]CST_ANEWDEL
            WRK = "D"
          Else
            WRK = "M"
          Endif
        Endif

        #New lines created by the user
        If this.EMPESSAFR.PASDET(COLLECTION_IND).TCH_PASSTA <> "T"
          If this.EMPESSAFR.PASDET(COLLECTION_IND).ASTALIN <> [V]CST_ANEWDEL
            If this.EMPESSAFR.PASDET(COLLECTION_IND).ASTALIN = [V]CST_ANEW
              WRK = "C"
            Endif
          Endif
        Endif
        If WRK <> ""
          INTKEY(1)= COLCOUNT
          #A Function per class must be added to ESS_WRKLOW_FUNC
          CLASS_WRKFLOW = func ESS_WRKFLOW_FUNC.GENESSWRKFLOW_ESSWRKAFR_PASDET(WRK,this,THISUSR,this.EMPESSAFR,this.EMPESSAFR.PASDET(COLLECTION_IND),
&         CLASSCOD,CTABLE, CABR,CLASS_ERROR,SYSPROP,ALPKEY,INTKEY,DATKEY,CLEOBJ)
        Endif
      Endif
    Next
  Endif
Endif

Return

