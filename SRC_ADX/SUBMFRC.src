#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque MFRC
########################################
Subprog AM_XTRT(VALEUR)
Variable Decimal VALEUR
Local    Date    WDATE, WDATED, WDATEF
Local    Decimal WCAP (11) 
Local    Integer WRET, WCOR, I, J
Local    Integer IMAX : IMAX = 10
Local    Integer WCOUNT

If VALEUR = 0 : End : Endif

WDATE  = [M:MFRC]AVDATE 
WCOR   = 2
WCOUNT = 0

If VALEUR > 0    # décalage aval
    J = VALEUR
    I = 10
    While (J>0 & WCOUNT <= 2000) # si WCOUNT = 2000 à priori on boucle
        If I >= IMAX 
            WDATED = WDATE + 1
            WDATEF = WDATE + 11
            #  (llc 08.00 v130) nouvelle gestion des capacités
            Call LOACAP (WDATED,WDATEF,WCAP,WRET) From JALLIBB
            I = 0
        Endif
        If WCAP(I) > 0 : J -= 1 : Endif
        WDATE  += 1
        I      += 1
        WCOUNT += 1
    Wend
Else            # décalage amont
    J = abs(VALEUR)
    I = 10
    While (J>0 & WCOUNT <= 2000) # si WCOUNT = 2000 à priori on boucle
        If I >= IMAX 
            WDATED = WDATE - 10
            WDATEF = WDATE
            #  (llc 08.00 v130) nouvelle gestion des capacités
            Call LOACAP (WDATED,WDATEF,WCAP,WRET) From JALLIBB
            I = 0
        Endif
        If WCAP(9-I) > 0 : J -= 1 : Endif
        WDATE  -= 1
        I      += 1
        WCOUNT += 1
    Wend
Endif

[M:MFRC]APDATE = WDATE
Affzo [M:MFRC]APDATE

End

