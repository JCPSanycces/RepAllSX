#########################################################
Subprog VERF_PARAM (PPARAM, PVALEUR, ROK)
#
# - Objet  : Traitement à executer suite à modification d'un paramètre
# Traitement évolutif. Pour l'instant, un seul paramètre concerné : PRIFLG
#

Value    Char    PPARAM
Value    Char    PVALEUR
Variable Integer ROK
  If clalev([F:PSV]) = 0 : Local File PTDSTKVAL    [PSV] : Endif : # Régularisation des stocks

  Global Integer GNBRPARA  : GNBRPARA = 1
  Global Char    GPARLIST(10)(1..GNBRPARA)
  If (dim(GUPDPARAMB)  <0) Then  : Global Integer GUPDPARAMB(1..GNBRPARA)       : Endif
  If (dim(GUPDPARVALB) <0) Then  : Global Char    GUPDPARVALB(10)(1..GNBRPARA)  : Endif

  # Valeur avant modification
  Read [ADW]ADW0=[M:ADWP]CMP;[M:ADWP]FCY;PPARAM
  # Si le paramètre n'est pas modifié on sort
  If ( val(PVALEUR) = val([F:ADW]VALEUR) ) Then :  End :  Endif

  Case PPARAM
    When "PRIFLG"
       # Le paramètre peut passer à "NON" si rien dans la table PTDSTKVAL pour ce dossier/société/site
       If ( val(PVALEUR) = G_NON ) Then
         If [M:ADWP]FCY <> ""
          Filter [F:PSV] Where FCY = [M:ADWP]FCY
         Elsif [M:ADWP]CMP <> ""
          Filter [F:PSV] Where CPY = [M:ADWP]CMP
         Endif
         Look [F:PSV]PSV0 First
         #Des enregistrements existent dans la table de régularisation des stocks. \Modification impossible
         If !fstat: GMESSAGE = mess(584,194,1) : mkstat=2 : ROK=0 : End
         Endif
         Filter [PSV]
       Endif
    When Default
  Endcase

  GPARLIST(1) = "PRIFLG"
  If (find(PPARAM,GPARLIST)) Then
    GUPDPARAMB(find(PPARAM, GPARLIST)) = 1
    GUPDPARVALB(find(PPARAM,GPARLIST))=[F:ADW]VALEUR
  Endif
End

###############################################
Subprog UPD_PSVSTRDAT(LCPY,LFCY,LVAL,LDEL,LCOD)
Value    Char    LCPY
Value    Char    LFCY
Value    Integer LVAL
Value    Integer LDEL
Variable Integer  LCOD
If clalev([F:ADW1])=0  : Local File ADOVAL    [ADW1]  : Endif
If clalev([F:ADW2])=0  : Local File ADOVAL    [ADW2]  : Endif

If LFCY <> ""
  Read [F:ADW1]ADW0 = LCPY;LFCY;"PRIFLG"
Elsif LCPY <> ""
  Read [F:ADW1]ADW0 = LCPY;"";"PRIFLG"
Else
  Read [F:ADW1]ADW0 = "";"";"PRIFLG"
Endif
If fstat : Raz [F:ADW1] : End : Endif
Call DEBTRANS From GLOCK
Trbegin [ADW2]
   Readlock [ADW2]ADW0 = [F:ADW1]CMP;[F:ADW1]FCY;"PSVSTRDAT"
   If fstat=1
    GOK=-1 : GLOCK = "$ADOVAL"-"*"-LEGCUR-[M]PARAM(I) : Goto FIN_TR1
   Endif
   If fstat
      Raz [F:ADW2]
      [F:ADW2] = [F:ADW1]
      [F:ADW2]PARAM  = "PSVSTRDAT"
      If [F:ADW1]VALEUR = "2"
         [F:ADW2]VALEUR = date$
      Else
        Raz [F:ADW2]VALEUR
      Endif
      If dim([F:ADW2]CREDAT)>0 : [F:ADW2]CREDAT = date$ : Endif
      If dim([F:ADW2]CREUSR)>0 : [F:ADW2]CREUSR = GUSER : Endif
      If dim([F:ADW2]CRETIM)>0 : [F:ADW2]CRETIM = time  : Endif
      Write [ADW2]
      If fstat
       GOK=0 : Call FSTA("ADW2") From GLOCK : Goto FIN_TR1
      Endif
   Else
    If LDEL
     Delete [ADW2]
     Raz [F:ADW2]
    Else
      If [F:ADW1]VALEUR = "2"
         [F:ADW2]VALEUR = date$
      Else
        Raz [F:ADW2]VALEUR
      Endif
      Rewrite [ADW2]
      If fstat
       GOK=0 : Call FSTA("ADW2") From GLOCK : Goto FIN_TR1
      Endif
    Endif
   Endif
#---
  $FIN_TR1
  If GOK<1
    Rollback
  Else
    Commit
  Endif
End

