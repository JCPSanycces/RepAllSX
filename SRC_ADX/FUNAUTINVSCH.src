#-----------------------------------------------------------------------#
# Alimentation des paramètres dans [M:ALP] pour éxécution GENSTOSORW    #
#-----------------------------------------------------------------------#
#$ALI_GENALP
#--A REVOIR :
#--L'objectif est de détacher les quantités de la facturation par échéance
#[M:ALP]TRSTYP    = LTRSTYP
#[M:ALP]TRSCOD    = LTRSCOD
#[M:ALP]VCRTYP    = 5
#[M:ALP]STOFCY    = [F:SOQ]STOFCY
#[M:ALP]ITMREF    = [F:SOQ]ITMREF
#If func AFNC.ACTIV("ECC") Then
#  [M:ALP]ECCVALMAJ    = [F:SOQ]ECCVALMAJ
#Endif
#[M:ALP]QTY       = [F:SOQ]ALLQTYSTU
#[M:ALP]TYPQTY    = 2
#[M:ALP]BESDAT    = [F:SOQ]SHIDAT
#[M:ALP]DLVDAT    = [F:SOQ]DEMDLVDAT
#[M:ALP]ALLDAT    = [0/0/0]
#[M:ALP]STOLOC    = ""
#[M:ALP]PECINTLOC = 2
#[M:ALP]PECSCOLOC = 1
#[M:ALP]PECPLFLOC = 2
#[M:ALP]PECCUNLOK = 1
#[M:ALP]FILSTO    = ""
#[M:ALP]LOT       = [F:SOQ]LOT
#[M:ALP]LOC       = [F:SOQ]LOC
#[M:ALP]STA       = [F:SOQ]STA
#[M:ALP]WRH       = ""
#If [F:SOH]SOHCAT=4
#   [M:ALP]PCU       = [F:SOC]SAU
#   [M:ALP]PCUSTUCOE = [F:SOC]SAUSTUCOE
#Else
#   [M:ALP]PCU       = [F:SOP]SAU
#   [M:ALP]PCUSTUCOE = [F:SOP]SAUSTUCOE
#Endif
#Raz [M:ALP]ALLQTY
##-- Si allocation globale, on passe la qté déjà alloée en global
#If [F:SOQ]ALLTYP=1 [M:ALP]ALLQTY=[F:SOQ]ALLQTYSTU Endif
#--/A REVOIR
#Return
#-----------------------------------------------------------------------#
# Alimentation des paramètres dans [M:ALP] pour éxécution GENSTOSORW    #
#              pour les lignes de composants                            #
#-----------------------------------------------------------------------#
#$ALI_GENALP1
#--A REVOIR :
#--L'objectif est de détacher les quantités de la facturation par échéance
#[M:ALP]TRSTYP    = LTRSTYP
#[M:ALP]TRSCOD    = LTRSCOD
#[M:ALP]VCRTYP    = 5
#[M:ALP]STOFCY    = [F:SOQ1]STOFCY
#[M:ALP]ITMREF    = [F:SOQ1]ITMREF
#If func AFNC.ACTIV("ECC") Then
#  [M:ALP]ECCVALMAJ    = [F:SOQ1]ECCVALMAJ
#Endif
#[M:ALP]QTY       = [F:SOQ1]ALLQTYSTU
#[M:ALP]TYPQTY    = 2
#[M:ALP]BESDAT    = [F:SOQ1]SHIDAT
#[M:ALP]DLVDAT    = [F:SOQ1]DEMDLVDAT
#[M:ALP]ALLDAT    = [0/0/0]
#[M:ALP]STOLOC    = ""
#[M:ALP]PECINTLOC = 2
#[M:ALP]PECSCOLOC = 1
#[M:ALP]PECPLFLOC = 2
#[M:ALP]PECCUNLOK = 1
#[M:ALP]FILSTO    = ""
#[M:ALP]LOT       = [F:SOQ1]LOT
#[M:ALP]LOC       = [F:SOQ1]LOC
#[M:ALP]STA       = [F:SOQ1]STA
#[M:ALP]WRH       = ""
#[M:ALP]PCU       = [F:SOP1]SAU
#[M:ALP]PCUSTUCOE = [F:SOP1]SAUSTUCOE
#Raz [M:ALP]ALLQTY
##-- Si allocation globale, on passe la qté déjà alloée en global
#If [F:SOQ]ALLTYP=1 [M:ALP]ALLQTY=[F:SOQ1]ALLQTYSTU Endif
#--/A REVOIR
#
#Return

#-------------------------------------------------------------------------------------
#-----------------------------------------------------------------------#
# Recherche de la transaction de facture                                #
#-----------------------------------------------------------------------#
$RECH_TRSVEN
Local Char    WTRS(GLONTRS)

  OK=2
  If !clalev ([F:SLT]) : Local File SALTRS  [SLT] : Endif
  WTRS=GTRSFAC
  If WTRS <> ""
     Read [SLT]SLT0=5;WTRS
     If fstat WTRS="" Endif
  Endif
  #-- Aucune transaction paramétrée ou elle n'existe plus
  If WTRS = ""
      Filter [SLT] Where STRTYP=5 & ENAFLG=2 & find (INVTYP,1,4)
      Read [SLT]SLT0 First
      If fstat
          Call ECR_TRACE(mess(286,192,1),1) From GESECRAN : OK=1 : Return
      Endif
      Filter [SLT]
  Endif

  WP_TRSFAM = [F:SLT]TRSFAM
  WP_TRSCOD = [F:SLT]TRSCOD
  WP_ENTCOD = [F:SLT]ENTCOD

Return
#-------------------------------------------------------------------------------------
# -------------------------------------- #
#         Traitement des erreurs         #
# -------------------------------------- #
$ROL_CHGFIC

  Rollback

  Call ROLL From GLOCK
  If   GROLL
       Goto ERR_TRT
  Else Goto CHGFIC
  Endif

Return
#-------------------------------------------------------------------------------------
$ROL_TRT

  Rollback

  Call ROLL From GLOCK
  If   GROLL
       Raz WKEY, WKEY1, WNUM, WDATA
       Goto ERR_TRT
  Else Goto FIN_SOHSIH
Endif

Return
#-------------------------------------------------------------------------------------
$AB_TRT

  Rollback

  WTRBEGIN = 0
  Raz WKEY, WKEY1, WNUM, WDATA
  #-- Sage Exchange
  If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)
    Call POST_AUTH(2,[F:SIV]SIHORINUM,SEERR,SEMESSAGE) From SEPPLIB
  Endif
  $ERR_TRT
  Call PJT_WRITE_MSG() From TRTPJT
  WMESS =mess(17,107,1)
  Call ECR_TRACE("         "+WMESS,0)From GESECRAN
  Raz WMESS

Return
#-------------------------------------------------------------------------------------
#-----------------------------------------------#
# Contrôle de la législation du type de facture #
#-----------------------------------------------#
$VERF_SIVTYP

  If [F:TSV]SIVTYP<>GSIVTYP & GSIVTYP<>""
      #- X3Suivi 71937 Multi-législation -#
      Local Integer WRET
      Call LEC_TSV_LEG(GCURLEG,GSIVTYP,WRET) From TRTLECLEG
      If WRET : Raz [F:TSV] : Endif
  Endif
  If [F:TSV]LEG<>GCURLEG & GCURLEG<>"" & [F:TSV]LEG<>""
      Raz GSIVTYP
  Endif

Return
#-------------------------------------------------------------------------------------
#--87923 Gestion des prélèvements SDD
#-----------------------------------------------#
#--On initialise et on contrôle le mandat       #
#-----------------------------------------------#
$INIT_CTL_UMRNUM
Local Char WMESS_UMRNUM(250)

  Read [F:SIH]SIH0= LSIVNUM
  If !fstat
    Raz WMESS_UMRNUM
    Call INIT_CTL_UMRNUM([F:SIH]CPY,[F:SIH]BPRPAY,[F:SIH]PTE,[F:SIH]UMRNUM,WMESS_UMRNUM) From TRTVENSDD
    If WMESS_UMRNUM<>""
      Call ECR_TRACE(mess(55,198,1)-[F:SIH]NUM-":"-WMESS_UMRNUM,-1) From GESECRAN
    Endif
  Endif

Return
#-------------------------------------------------------------------------------------
#-----------------------------------------------------------------------#
#     Effacement fichier de travail si interruption auparavant          #
#-----------------------------------------------------------------------#
$DEL_SWICND

  Call DEBTRANS From GLOCK

  Trbegin [SWICND]
    Delete [SWICND] Where PRONUM=adxuid(1)
    If fstat=1  GOK=-1 : GLOCK="$SWRKINVCND"-num$(adxuid(1))            : Goto AB_TRT
    Elsif fstat GOK= 0 : Call RSTA("SWICND",num$(adxuid(1))) From GLOCK : Goto AB_TRT
    Endif
  Commit

Return
#-------------------------------------------------------------------------------------

#------------------------- Gestion du masque SAUTINVSCH ------------------------------
######################################################################################
#                               ACTIONS CHAMPS                                       #
######################################################################################

Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

  # --> Chargement globales référenciels, comptes et sections de la société
  If GFCY<>VALEUR : GFCY=VALEUR : Gosub CHARG_PARAM Endif
  # --> Recherche Type de facture utilisateur
  Call PARAML(GFCY,"SIVTYP",GSIVTYP) From ADOVAL
  # --> Vérif.Type de facture utilisateur : Législation identique à la législation du site
  Gosub VERF_SIVTYP
  [M]SIVTYP=GSIVTYP : Affzo [M]SIVTYP
End
######################################################################################
Subprog C_INVDAT(VALEUR)
Variable Date    VALEUR
Local    Date    WINVDAT

  #--75310 Before doing the control...
  If GSOCIETE<>[M]CPY or GFCY<>[M]SALFCY
    # --> Chargement globales référenciels, comptes et sections de la société
    GFCY=[M]SALFCY : Gosub CHARG_PARAM
    # --> Recherche Type de facture utilisateur
    Call PARAML(GFCY,"SIVTYP",GSIVTYP) From ADOVAL
  Endif

  WINVDAT=VALEUR
  If VALEUR <> [0/0/0] Gosub CTL_INVDAT Endif

End
#-------------------------------------------------------------------------------------
$CTL_INVDAT
Local Decimal    EXERCICE , PERIODE

  If clalev([F:PER])=0 : Local File PERIOD [PER] : Endif

  For [PER]PER0 Where CPY=GSOCIETE & PERSTR<=WINVDAT & PEREND>=WINVDAT & LEDTYP=GTYPGEN
    EXERCICE = [F:PER]FIYNUM
    PERIODE  = [F:PER]PERNUM
  Next
  If EXERCICE=0 | PERIODE=0
    GMESSAGE = mess(1,104,1) : # MSG=Date incorrecte
    mkstat = 2 : Return
  Endif
  If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
  Read [FIY]FIY0 = GSOCIETE;GTYPGEN;EXERCICE
  If fstat | [F:FIY]FIYSTA<>2
    GMESSAGE = mess(20,101,1) : # MSG=Exercice non ouvert
    mkstat = 2 : Return
  Endif
  If [F:PER]PERSTA<2
    GMESSAGE = mess(35,101,1) : # MSG=Periode non ouverte
    mkstat = 2 : Return
  Endif
  If [F:PER]PERSTA>2
    GMESSAGE = mess(36,101,1) : # MSG=Période fermee
    mkstat = 2 : Return
  Endif
  #Call CTLVLYDAT(VALEUR,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
  #If mkstat : GMESSAGE = [F:GTE]TYP-GMESSAGE : Return : Endif

  # V6.2 : Certification
  #----- Contrôle date pour certification NF -----#
  Call CTLDAT_CNF(5,[M:DIA]SALFCY,[0/0/0],WINVDAT,"","") From CONTX3
  If mkstat  Return  : Endif

Return
######################################################################################
Subprog AM_SOHNUMDEB(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" : [M:DIA]SOHNUMFIN = VALEUR : Endif

End
######################################################################################
Subprog AM_BPCINVDEB(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" : [M:DIA]BPCINVFIN = VALEUR : Endif

End
######################################################################################
Subprog S_BPCINVFIN(VALEUR)
Variable Char    VALEUR()

  Call SELECT("BPC","",VALEUR,"") From SELOBJ

End
######################################################################################
Subprog AP_PRNFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = 1
     Raz [M:DIA]PRNNAM, [M:DIA]PRNDEN, [M:DIA]PRNIMP, [M:DIA]PRNSRV
     Diszo [M:DIA]PRNNAM, PRNDEN
  Else
     If vireblc([M:DIA]PRNNAM,2)=""
        Call INIT_ARP("SIH", [M:DIA]PRNNAM) From TRTVENIMP
        Actzo [M:DIA]PRNNAM, PRNDEN
     Endif
  Endif
  Affzo [M:DIA]PRNNAM, PRNDEN, PRNIMP, PRNSRV

End
######################################################################################
Subprog C_PRNNAM(VALEUR)
Variable Char    VALEUR()

Local    Char    AUTSIT(10)
Local    Integer OK
  # Document obligatoire si impression facture
  If [M:DIA]PRNFLG = 2 & VALEUR = ""
     GMESSAGE=mess(10,123,1) : mkstat = 2
     End
  Endif

End
######################################################################################
Subprog C_PRNSRV(VALEUR)
Variable Char    VALEUR()

  Gosub CTL_SRV From TRTVENIMP

End
######################################################################################
Subprog C_PRNIMP(VALEUR)
Variable Char    VALEUR()

  # Imprimante obligatoire si impression
  If [M:DIA]PRNNAM <> "" & VALEUR = ""
     GMESSAGE=mess(10,123,1) : mkstat = 2
  Endif

End
######################################################################################
Subprog AM_SIVTYP(VALEUR)
Variable Char    VALEUR()

End
######################################################################################
Subprog C_PRNDEN(VALEUR)
Variable Char    VALEUR()

  # Imprimante obligatoire si impression
  If [M:DIA]PRNNAM <> "" & VALEUR = ""
     GMESSAGE=mess(10,123,1) : mkstat = 2
  Endif

End
######################################################################################
Subprog AP_PRNDEN(VALEUR)
Variable Char    VALEUR()

  Call INIT_SRV(VALEUR, [M]PRNSRV,[M]PRNIMP) From TRTVENIMP
  Affzo [M]PRNSRV, PRNIMP
  [M:DIA]PRTCOP=func TRTVENIMP.GET_NBRCPY_AIM(VALEUR)

End
######################################################################################
Subprog D_CPY(VALEUR)
Variable Char    VALEUR()

  Call GETSOC (GFCYDEF(5)) From DEVSUB   : # init avec societe du site ventes par defaut
  VALEUR=GSOCIETE
  [M]SALFCY=GFCYDEF(5)

End
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  GSOCIETE=VALEUR
  Raz [M]SALFCY

End
######################################################################################
Subprog C_SIVTYP(VALEUR)
Variable Char    VALEUR()

  #--71937 T757 Contrôle de cohérence
  GSIVTYP=VALEUR


  #85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
  If func AFNC.ACTIV("KPO") & GCURLEG = "POR"
    Call VAL_SIVTYP(VALEUR) From PORLEGLIB
    Call VAL_AUTINV(VALEUR) From PORLEGLIB
  Endif
  #85803 RICAR 2014/05/20 - Portuguese legal requirements - END

End
