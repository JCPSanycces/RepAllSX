#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
#                                       Module Ventes - Août 2016       #
#     FACTURES AUTO. DES ECHEANCIERS DE FACTURATION                     #
#                                                                       #
#     - Traitement        : FUNAUTINVSCH                                #
#     - Action e_commerce : TRTAUTINVSCH  (Traitement standard)         #
#                                                                       #
#########################################################################


#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#MGG Dbgaff
  #--- Actions liées au traitement standard
  Case ACTION
    When "OUVRE_BATCH" : Gosub INIT_TRTAUTINVSCH
    When "INIT"        : Gosub INIT_TRTAUTINVSCH
    When "DEBUT"       : Affzo [DIA]1-99
    When "OK"          : GOK=1
    When "END"         : GOK=0 : FIN=1
    When "CONTROLE"    : Gosub CONTROLE_TRTAUTINVSCH
    When "EXEC"        : Gosub EXEC_TRTAUTINVSCH
    When "TERMINE"     : Gosub TERMINE_TRTAUTINVSCH
    When "SORTIE"      : Gosub SORTIE_TRTAUTINVSCH
    When Default
  Endcase
Return
#-------------------------------------------------------------------------------------
#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################
#-------------------------------------------------------------------------------------
$INIT_TRTAUTINVSCH

  Gosub CHECK_INVCNO_MSK
  If FIN = 1 Then
    Return
  Endif

  # 107888 : Scheduled invoices : X3-4953 (LD:17/10/16)
  #If GMODU(12) = 2
  # 107888 : Scheduled invoices : X3-4953 (LD:17/10/16)
    Global Shortint GINVTYP  : GINVTYP = 1  : # Type document        = Facture
    #----- Ouverture des tables et déclaration des variables pour les états -----#
    Gosub INIT_ETAT From TRTX3ETA
    #-----
    # En batch , il vaut mieux mettre onerrgo
    If GSERVEUR
      Onerrgo ERRBATCH
    Endif
    Gosub OUVRE
  # 107888 : Scheduled invoices : X3-4953 (LD:17/10/16)
  #Endif
  # 107888 : Scheduled invoices : X3-4953 (LD:17/10/16)

  Local Mask SAUTINVSCH [DIA]
  Raz [M:DIA]

  [M]SALFCY    = GFCYDEF(5)
  [M]INVDAT    = date$
  [M]SIVTYP    = GSIVTYP
  [M]IMESVIC   = 1


  Call LECMEMO ("STD","[M:DIA]", "vfa") From GMEMO  # X3-28888 Manage memos in the scheduled invoices mass process


  # Positionner le flag si saisie des paramêtres depuis la gestion des abonnements
  [M]ABT = 1
  If GFONCTION1 = "GESABA" Then
    [M]ABT = 2
  Endif

Return
#-------------------------------------------------------------------------------------
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
#-------------------------------------------------------------------------------------
$CHECK_INVCNO_MSK
Local Integer OKTRT
# Local Char SNOMTRT(GLONADC) #X3-23080

  If filinfo(filpath("ECR","WSIH4INV","msk",0),0) < 0 Then
    Call ECR_TRACE(mess(262,191,1) - ":" - mess(263,191,1) - mess(264,191,1), 1) From GESECRAN
    OK = 0
    FIN = 1
  Else
   # For SNOMTRT = "W0WSIH4INV" #X3-23080
      # Call EXISTE_ADX("", "", SNOMTRT, OKTRT) From ORDSYS     #X3-23080
      Call EXISTE_ADX("", "", "W0WSIH4INV", OKTRT) From ORDSYS  #X3-23080
      If OKTRT > 0 Then
        # Il existe, c'est bon
      Else
        # Si l'écran existe on peut tenter de le valider : ça génèrera automatiquement le script
        If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
        If [F:ADS]DOSSIER <> nomap Then
          Read [F:ADS]DOSSIER=nomap
        Endif
        Call VALID("WSIH4INV", nomap, [F:ADS]NBRLAN, [F:ADS]LAN, 1, OKTRT) From VALMSK
        # Call EXISTE_ADX("", "", SNOMTRT, OKTRT) From ORDSYS    #X3-23080
        Call EXISTE_ADX("", "", "W0WSIH4INV", OKTRT) From ORDSYS #X3-23080
        If OKTRT > 0 Then
          # Il existe, c'est bon
        Else
          Call ECR_TRACE(mess(262,191,1) - ":" - mess(263,191,1) - mess(265,191,1), 1) From GESECRAN
          OK = 0
          FIN = 1
          #Break  #X3-23080
        Endif
      Endif
   # Next  #X3-23080
  Endif

Return
#-------------------------------------------------------------------------------------
$CONTROLE_TRTAUTINVSCH

If GOK < 1  FIN=1 Else TMP=1  Endif

  # --> suppression enreg. fichier travail
  Gosub DEL_SWICND

  If GOK < 1 Then
    FIN = 1
  Else
    TMP = 1
  Endif

Return
#-------------------------------------------------------------------------------------
$TERMINE_TRTAUTINVSCH

  If NBINV
    If [M:DIA]PRNFLG=2 & [M:DIA]PRNNAM<>"" & [M:DIA]PRNDEN<>""
      Call PRINT_ETAT (1,WARP_NUMREQ,[M:DIA]PRNDEN) From TRTX3ETA
    Endif
  Endif

  If !GSERVEUR
      #-- fermeture trace
      If !NBINV
        Call ECR_TRACE(mess(39,192,1),0) From GESECRAN
      Endif
      Call FERME_TRACE From LECFIC
      #-- aucune commande à traiter ou lecture trace
      If !NBINV
         GERR=2 : GMESSAGE=mess(39,192,1)
      Endif
      TRA=1
  Endif

  Raz GSIVTYP

Return
#-------------------------------------------------------------------------------------
$SORTIE_TRTAUTINVSCH

  #--On va utiliser l'écran SFITRFA dont les dimensions sont paramètrables
  If func AFNC.ACTIV("SFIAT")>0
    If clalev([M:SFIT])>0 Close Mask [M:SFIT] Endif
  Endif

Return
#-------------------------------------------------------------------------------------
$EXEC_TRTAUTINVSCH

  Gosub DECLAR_VAR

  If !GSERVEUR
      # Ouverture de la trace
      Call OUVRE_TRACE(TIT) From LECFIC
      Call ECR_TRACE(" ",0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call PRTSCR("SAUTINVSCH","DIA","",0,1) From ATRTX3
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE(" ",0) From GESECRAN
  Endif

  Gosub CHARG_PARAM

  # --> Récupération des paramêtres de vente
  Call GLOBVAR([M:DIA]SALFCY,"VEN") From TRTX3

  # --> Vérif.Type de facture utilisateur : Législation identique à la législation du site
  Gosub VERF_SIVTYP
  #85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
  If func AFNC.ACTIV("KPO") & GCURLEG = "POR"

    If [F:TSV]SAFTINVTYP = 2
      GMESSAGE = mess(78,7711,1)
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Return
    Endif

    If [F:TSV]AUTINV = 2
      GMESSAGE = mess(146,7711,1)
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Return
    Endif

  Endif
  #85803 RICAR 2014/05/20 - Portuguese legal requirements - END

  #GUSRFCY(1)=GFCY    #--A VIRER !! pour mock
  #GNBAUZ=1           #--A VIRER !! pour mock
  #GFONCTION="GESSIH" #--A VIRER !! pour mock

  #--Remplissage de la table temporaire

  Gosub LOAD_SWICND

  WFIN=0 : GERR=0
  #TODO
  #--Ajouter le SOH, SOQ et SOP dans le link ?

  Link [SWICND] With [SVICD]SVICD0~=[SWICND]VCRTYP;
&                                   [SWICND]VCRNUMORI;[SWICND]VCRLINORI;[SWICND]VCRSEQORI;[SWICND]VCRINVCNDLIN,
&                    [SVIC]SVIC0  ~=[SVICD]VCRTYP;
&                                   [SVICD]VCRNUMORI;[SVICD]VCRLINORI;[SVICD]VCRSEQORI
&    As [SWILNK_]
&    Where PRONUM=adxuid(1)
&    Order By Key CLE=SWIKEY;SWIKEY1;SWIKEYD;NUM;LIN;VCRINVCNDLIN

  Read [SWILNK_]CLE First
  If fstat : WFIN=1 : Endif

  While WFIN=0
#  If GUSER="LD" Dbgaff Endif
    Read [F:SOH]SOH0=[F:SVIC]VCRNUMORI
    If fstat : WFIN=1 : Goto FIN_SOHSIH : Endif

    #----- Blocage logique de la demande
    SYMBOLE = "SOH"+[F:SOH]SOHNUM
    Lock = SYMBOLE
    If fstat
       # modification en cours sur un autre poste
       GERR=1 : GMESSAGE=[F:SOH]SOHNUM-":"-mess(10,100,1)
       Call ECR_TRACE(GMESSAGE,1) From GESECRAN
       OK=1   : WFIN=1 : Goto FIN_SOHSIH
    Endif
    #-----

    #----- Blocage logique de l'échéance à facturer
    #......
    #-----

    #Appel du composant de création facture.

    Call GENSIH(LCOD, LMAJ, LECH, LTEST, LTRT, LORINUM, LSIVNUM, LERR) From TRTVENFACG
    If LERR>0 or GERR=1 Then
      # 107888 : Scheduled invoices : X3-4955 (LD:17/10/16)
#      Call ECR_TRACE(mess(511,192,1)-":"-mess(144,183,1)-num$([F:SVICD]NEXINVDAT)-mess(542,192,1)-":"
#&                 -mess(332,182,1)-[F:SVIC]VCRNUMORI-mess(3,61,1)-num$([F:SVIC]VCRLINORI)
#&                 -mess(162,154,1)-[F:SVIC]ITMREF,0) From GESECRAN
      Call ECR_TRACE(mess(511,192,1)-":"-mess(274,191,1)-num$([F:SVICD]NEXINVDAT)-mess(542,192,1)-":"
&                 -mess(98,197,1)-[F:SVIC]VCRNUMORI-mess(3,61,1)-num$([F:SVIC]VCRLINORI)
&                 -mess(162,154,1)-[F:SVIC]ITMREF,0) From GESECRAN
      # 107888 : Scheduled invoices : X3-4955 (LD:17/10/16)
      Call ECR_TRACE(mess(888,197,1),1) From GESECRAN
      #--Need to continue with the following entry
      WFIN = 1
    Else
      NBINV += 1
      #--87923 Gestion des prélèvements SDD
      Gosub INIT_CTL_UMRNUM

      If [M:DIA]PRNFLG=2 and [M:DIA]PRNNAM <> "" and [M:DIA]PRNDEN <> "" Then
        If LSIVNUM <> "" Then
          Read [SIV]SIV0=LSIVNUM
          If !fstat Then
            #----- Recherche du nouveau code état à partir du modèle -----#
            If [F:BPC]BPCNUM<>[F:SIH]BPR Then
              Read [BPC]BPC0=[F:SIH]BPR
              If fstat Then
                Raz [F:BPC]
              Endif
            Endif
            If [F:BPC]TPMCOD <> "" Then
              If [F:TPM]TPMCOD<>[F:BPC]TPMCOD Then
                Read [TPM]TPM0=[F:BPC]TPMCOD
                If fstat Then
                  Raz [F:TPM]
                Endif
              Endif
              If [F:TPM]SALINV<>"" Then
                WARP_RPTCOD(0)=[F:TPM]SALINV
              Else
                WARP_RPTCOD(0)=[M:DIA]PRNNAM
              Endif
            Else
              WARP_RPTCOD(0)=[M:DIA]PRNNAM
            Endif
            #----- Nombre de copies -----#
            WARP_NBRCPY=[F:SIV]COPNBR
            #----- Ecriture AREPORTM et màj indicateur d'impression sur entête facture -----#
            Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
            #-----
          Endif
        Endif
      Endif
      If !GSERVEUR Then
        ISCHCOUNT += 1
        Call AFF_BOITE ([F:SIV]NUM, ISCHCOUNT, ISCHOK) From GESECRAN
      Endif
    Endif

    $FIN_SOHSIH
    #----- Déblocage logique de la demande
    #-!!! ATTENTION il faut délocker les symboles posés ds GENSIH dans le LTRT en READ_DETAIL (A FAIRE aussi)
    #If OK=0 |LERR>0 Unlock = SYMBOLE : Endif
    Unlock =SYMBOLE
    #----- Déblocage logique de l'échéance à facturer
    #.....

    #--need to continue with Read [SWILNK_]CLE Next
    If WFIN >0 and not([SWICND]SWIKEY="" and [SWICND]SWIKEY1="" and [SWICND]SWIDATA="")
      WFIN = 0
      Read [SWILNK_]CLE Next
      If fstat : WFIN=1 : Endif
    Endif
    #--fields empty means no more entry for Read [SWILNK_]CLE next, need to exit the loop
    If  ([SWICND]SWIKEY="" and [SWICND]SWIKEY1="" and [SWICND]SWIDATA="")
      Break
    Endif

  Wend

  If !GSERVEUR Then
    Call FERME_BOITE From GESECRAN
  Endif

  # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)
  $EXEC_FIN
  # --> déverrouillage de toutes les commandes
  For [SWICND]
      SYMBOLE = "SOH"+[F:SWICND]NUM
      Unlock = SYMBOLE
  Next
  # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)

  Close File [SWILNK_]

  # --> suppression enreg. fichier travail
  Gosub DEL_SWICND

  Call TEMPOFF     From GESECRAN
#  Call FERME_TRACE From LECFIC
#  Call LEC_TRACE   From LECFIC

  #Kill GCPO_NBREAD #--A VIRER !! pour mock

Return
#-------------------------------------------------------------------------------------
$DECLAR_VAR
#Global Integer GCPO_NBREAD : GCPO_NBREAD=0 #--A VIRER !! pour mock

Local Integer WOK
Local Char SYMBOLE

#-- pour appel GENSIH
Local Integer LCOD      : LCOD = 1
Local Char    LMAJ(2)   : LMAJ ="C"
Local Integer LECH      : LECH = 2
Local Integer LTEST     : LTEST= 1 #2 commit avec trace #1 commit et pas de trace
Local Char    LTRT(30)  : LTRT ="TRTSIHSVICSOH"
Local Char    LORINUM(GLONVCR)
Local Char    LSIVNUM(GLONVCR)
Local Integer LERR      : LERR = 0

Local Integer ISCHTOINV
Local Integer ISCHCOUNT
Local Integer ISCHOK

  ISCHTOINV = 0
  ISCHCOUNT = 0
  ISCHOK = 0

  #--A REVOIR :
  #--L'objectif est de détacher les quantités de la facturation par échéance
  # Ouverture des masques de travail pour les stocks
  #Local Mask ALLPAR     [ALP]
  #Local Mask STOSORW    [SOW]
  #--/A REVOIR

  Local Char WP_TRSFAM, WP_TRSCOD, WP_ENTCOD

Return
#-------------------------------------------------------------------------------------
#-----------------------------------------------------------------------#
#    Ouvre                                                              #
#-----------------------------------------------------------------------#
$OUVRE
Local Char    TIT(50) : TIT = mess(884,197,1)

Local Integer OK, STAT, NBINV, NBPOSTE, WTRBEGIN
Local Char    CRITERE(250), CRITDET(150)
Local Char    WMESS(80), WMESS1(80), WMESS2(80)
Local Integer WRET
Local Char    WKEY(20), WKEY1(66), WNUM(GLONVCR), WDATA(250)
Local Char    WIME(1)

Local Char    WMESS_UMRNUM(250) :#--87923 Gestion des prélèvements SDD

  #--A REVOIR variables liées aux maj stock
  #Local Integer WGENKIT
  #Local Decimal WQTY, WQTYSTU, WSAUSTUCOE, WSOQQTY, WQTYARR
  #Local Decimal WQTYCPE, WQTYSTUCPE, WQTYCPS, WQTYSTUCPS, WCOECPE
  #Local Decimal LQTYOK, LQTYKO
  #Local Integer LRET, LTRSTYP
  #Local Char    LTRSCOD(GLONADI), WSAU(GLONUOM)
  #Local Char    WPARAM(10)
  #--/A REVOIR

  #---------------------------------------#
  # Ouverture des fichiers utilisés       #
  #---------------------------------------#
  If clalev([F:SVIC])   = 0 : Local File SVCRINVCND  [SVIC]   : Endif
  If clalev([F:SVIC_])  = 0 : Local File SVCRINVCND  [SVIC_]  : Endif
  If clalev([F:SVICD])  = 0 : Local File SVCRINVCNDD [SVICD]  : Endif
  If clalev([F:SWICND]) = 0 : Local File SWRKINVCND  [SWICND] : Endif
  If clalev([F:SWICND1])= 0 : Local File SWRKINVCND  [SWICND1]: Endif

  If clalev([F:TCA]) = 0 Local File TABCOUAFF   [TCA] : Endif
  If clalev([F:TSV]) = 0 Local File TABSIVTYP   [TSV] : Endif

  If clalev([F:SIH]) = 0 Local File SINVOICE    [SIH] : Endif
  If clalev([F:SIV]) = 0 Local File SINVOICEV   [SIV] : Endif
  If clalev([F:SID]) = 0 Local File SINVOICED   [SID] : Endif
  If clalev([F:SVF]) = 0 Local File SVCRFOOT    [SVF] : Endif
  If clalev([F:SVV]) = 0 Local File SVCRVAT     [SVV] : Endif

  If clalev([F:SOH]) = 0 Local File SORDER      [SOH] : Endif
  If clalev([F:SOQ]) = 0 Local File SORDERQ     [SOQ] : Endif
  If clalev([F:SOP]) = 0 Local File SORDERP     [SOP] : Endif
  If clalev([F:SOQ1])= 0 Local File SORDERQ     [SOQ1]: Endif
  If clalev([F:SOP1])= 0 Local File SORDERP     [SOP1]: Endif
  If clalev([F:CAL]) = 0 Local File CPTANALIN   [CAL] : Endif
  If clalev([F:BPC]) = 0 Local File BPCUSTOMER  [BPC] : Endif
  If clalev([F:BPD]) = 0 Local File BPDLVCUST   [BPD] : Endif
  If clalev([F:BPR]) = 0 Local File BPARTNER    [BPR] : Endif
  If clalev([F:MVC]) = 0 Local File BPCUSTMVT   [MVC] : Endif
  If clalev([F:LCM]) = 0 Local File LASTCUSMVT  [LCM] : Endif
  #--GACTSAD conditionne uniquement le stockage de l'adresse sur le document
  #If GACTSAD=2 If clalev([F:BPA])=0 Local File BPADDRESS [BPA] : Endif : Endif
  If clalev([F:BPA]) = 0 Local File BPADDRESS   [BPA] : Endif

  If clalev([F:GTE]) = 0 Local File GTYPACCENT  [GTE] : Endif
  If clalev([F:CAC]) = 0 Local File GACCCODE    [CAC] : Endif
  If clalev([F:GAC]) = 0 Local File GACCOUNT    [GAC] : Endif
  If clalev([F:GAU]) = 0 Local File GAUTACE     [GAU] : Endif
  If clalev([F:GAG]) = 0 Local File GAUTACEF    [GAG] : Endif
  If clalev([F:ANM]) = 0 Local File ACODNUM     [ANM] : Endif
  If GMODU(2)=2                :  #--Ajout test présence module compta
      If clalev([F:JOU]) = 0 Local File GJOURNAL [JOU] : Endif
  Endif

  If clalev([F:GCM]) = 0 Local File GACM        [GCM] : Endif

  If clalev([F:ITM]) = 0 Local File ITMMASTER   [ITM] : Endif
  If clalev([F:ITS]) = 0 Local File ITMSALES    [ITS] : Endif
  If clalev([F:ITU]) = 0 Local File ITMBPC      [ITU] : Endif
  If clalev([F:ITF]) = 0 Local File ITMFACILIT  [ITF] : Endif
  If clalev([F:TMD]) = 0 Local File TABMODELIV  [TMD] : Endif
  If clalev([F:FCY]) = 0 Local File FACILITY    [FCY] : Endif

  # 107888 : Scheduled invoices : X3-4953 (LD:17/10/16)
#  If GWRHACT=2
#     If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
#     If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
#  Endif
  # 107888 : Scheduled invoices : X3-4953 (LD:17/10/16)

  If clalev([F:CPY]) = 0 : Local File COMPANY   [CPY] : Endif   # 106867.n

  # --- Déclaration classe ecran pour les encours --- #
  #--L'objectif est de détacher les quantités de la facturation par échéance
  #Local Mask ORDK     [ORDK] : Raz [M:ORDK]
  #Local Mask STOK     [STOK] : Raz [M:STOK]

  # 107888 : Scheduled invoices : X3-4953 (LD:17/10/16)
  # v6 affectations
  #Gosub OPEN_MTO From MTOLINKLIB
  # 107888 : Scheduled invoices : X3-4953 (LD:17/10/16)

  # --> Chargement globales référenciels, comptes et sections de la société
  Raz GSOC_ACTIVE : GFCY=GFCYDEF(5) : Gosub CHARG_PARAM
  # ------------------------------------------- #
  # Récupération des paramêtres de vente        #
  # ------------------------------------------- #
  Call GLOBVAR(GFCYDEF(5),"VEN") From TRTX3
  # --> Vérification Type de facture utilisateur
  Gosub VERF_SIVTYP

  Local Integer  WCDTUNL
  #------------------------------------------------------------#
  # Chargement flag déblocage crédit autorisé                  #
  #------------------------------------------------------------#
  Local Char WPARAM(10)
  Call PARAMUTIL("SCDTUNL",WPARAM,"","") From SUBAUS
  WCDTUNL=val(WPARAM)
  If WCDTUNL=0 WCDTUNL=1 Endif

  #--On va utiliser l'écran SFITRFA dont les dimensions sont paramètrables
  If func AFNC.ACTIV("SFIAT")>0
    If clalev([M:SFIT])>0 Close Mask [M:SFIT] Endif
    Local Mask SFITRFA [M:SFIT]
  Endif

Return
#-------------------------------------------------------------------------------------
#--------------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la facture                 #
# ------------------------------------------------------------------------ #
# Chargement des globales référenciels, comptes et sections de la société  #
# Chargement des paramètres de localisation                                #
# ------------------------------------------------------------------------ #
$CHARG_PARAM
Local  Char     PARAM2(GLONADP) : # 107888 : Scheduled invoices : X3-4953 (LD:17/10/16)

  # --- Chargement des globales référenciels, comptes et sections de la société
  Call GETCPY(GFCY,"",0,"") From TRTX3CPT

  # --- Chargement des paramètres de localisation
  # --- Numérotation Argentine -----#
  If func AFNC.ACTIV("KAG")
      Call PARAML(GFCY,"ARGNUM",PARAM2) From ADOVAL
      GLOCARGNUM=val(PARAM2)
      If GLOCARGNUM>0  GLOCARGNUM-=1 : Endif
  Else
      Raz GLOCARGNUM
  Endif
  # --- Utilisation systeme de taxe
  Call LEC_CPY(GSOCIETE) From CPTLEC   # 106867.n
  #    If func AFNC.ACTIV("KUS")  # 106867.so
  #        Call PARAM(GFCY,"USATAX",PARAM2) From ADOVAL
  #        GLOCUSATAX=val(PARAM2)
  #        If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
  #    Else
  #      Raz GLOCUSATAX
  #    Endif  # 106867.eo
  # --- Contrôle date documents
  Call PARAML(GFCY,"CTLDATORI",PARAM2)    From ADOVAL
  GCTLDATORI=val(PARAM2)  : If GCTLDATORI=0   GCTLDATORI=2  : Endif

  # FGR 24/11/2011 : X3SUIVI71065
  GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)

Return
#-------------------------------------------------------------------------------------
$LOAD_SWICND
Local Char CRITERE(255)
Local Char CRITSVCRINVCND(255),CRITSVCRINVCNDLIN(255)

Local Char FILSUPENT(250), FILSUPDET(250)
Local Integer WSWIKEYD

  #--Schedule header
  CRITSVCRINVCND     = '1=1'
  #--Schedule line
  CRITSVCRINVCNDLIN  = '1=1'
  CRITSVCRINVCNDLIN += '&[F:SVICD]INVCNDSTA<=1'
  CRITSVCRINVCND    += '&[F:SVICD]NEXINVDAT<=['+format$(GFMD,[M:DIA]INVDAT)+']'
  If [M:DIA]DEMDLVDAT <> [0/0/0]
     CRITSVCRINVCND    += '&[F:SVICD]NEXINVDAT<=['+format$(GFMD,[M:DIA]DEMDLVDAT)+']'
  Endif
  CRITSVCRINVCND    += '&[F:SVICD]VCRTYP=10'

  #----Grouping cryteria
  # SIV.SALFCY       : SALES SITE
  # SIV.BPCINV       : BILL-To CUSTOMER
  # SIV.BPCORD       : SOLD-To CUSTOMER ? IS-IT USE For EXISTING INVOICE PROCESSES?
  # SIV.BPRPAY       : PAY-By PARTNER
  # SIV.BPCGRU       : GROUP CUSTOMER
  # SIV.CUR          : CURRENCY
  # SIH.VAC          : TAX RULE
  # SIV.PRITYP       : PRICE -/+ TAX
  # SIH.PTE          : PAYMENT TERM
  # SIH.BPRNAM(0)    : BILL-O CUSTOMER NAME 1
  # SIH.BPAADDLIG(0) : ADDRESS LINE 1
  # SIH.POSCOD       : POSTAL CODE
  # SIH.CTY          : CITY
  # SIH.CRY          : COUNTRY
  # SIH.SAT          : STATE

  #--Etape 1
  #--Set up des critères de filtre pour les lignes intermédiaires
  #--CRITERE : contient des filtres sur la table en-tête à l'origine de la ligne intermédiaire
  #--Objectif : sélectionner les lignes intermédiaires à traiter lors de la facturation courante
  #--> critères de saisie
  CRITERE = '[SOH]SALFCY="'+[M:DIA]SALFCY+'"'
  If [M:DIA]SOHNUMDEB <> ""
     CRITERE -= '&[SOH]SOHNUM>="'+[M:DIA]SOHNUMDEB+'"'
  Endif
  If [M:DIA]SOHNUMFIN <> ""
     CRITERE -= '&[SOH]SOHNUM<="'+[M:DIA]SOHNUMFIN+'"'
  Endif
  If [M:DIA]BPCINVDEB <> ""
     CRITERE -= '&[SOH]BPCINV>="'+[M:DIA]BPCINVDEB+'"'
  Endif
  If [M:DIA]BPCINVFIN <> ""
     CRITERE -= '&[SOH]BPCINV<="'+[M:DIA]BPCINVFIN+'"'
  Endif

  # V6.2 : Certification
  # Si ctrl date documents : La commande doit avoir une date <= à la date de la facture
  If GCTLDATORI=2  CRITERE -='& [SOH]ORDDAT<=['+format$(GFMD,[M:DIA]INVDAT)+']' Endif

  #--> Critères supplémentaires
  CRITERE -= "&[SOH]HLDSTA<2"                 :# order holds
  CRITERE -= "&[SOH]SOHCAT=1"                 :# cat  cde         =  normale
  #CRITERE -= "& ALLSTA <> 1"                  :# état alloc       allouée même partiellement
  CRITERE -= "&[SOH]INVSTA<>3"                :# état facture     non facturée
  # 107888 : Scheduled invoices : X3-21154 (LD:18/01/17)
  # The invoice mode should not be taken into account
  #CRITERE -= "&[SOH]IME<>6"                   :# mode facturation <> fact manuelle
  # 107888 : Scheduled invoices : X3-21154 (LD:18/01/17)
  CRITERE -= "&[SOH]APPFLG>2"                 :# état signature cde : signée

  #---------------------------------------------------------------------#
  # Point d'entree ajout filtres supplémentaires                        #
  #---------------------------------------------------------------------#
  FILSUPENT="1=1"
  FILSUPDET="1=1"
  GPOINT="AUTINVSCHFIL" : Gosub ENTREE From EXEFNC

  #--Etape 1
  #--Set up des critères de filtre pour les lignes intermédiaires
  #--CRITERE : contient des filtres sur la table en-tête à l'origine de la ligne intermédiaire
  #--Objectif : sélectionner les lignes intermédiaires à traiter lors de la facturation courante

  #--> Critères supplémentaires
  CRITDET = "[SOQ]SOQSTA<>3"
  #--Sur SVICD
  #If [M:DIA]DEMDLVDAT <> [0/0/0]
  #   CRITDET -= "&[SOQ]SHIDAT<=["+format$(GFMD,[M:DIA]DEMDLVDAT)+"]"
  #Endif
  #CRITDET -= '&[SOQ]SOHNUM="'+[F:SOH]SOHNUM+'"' #--Plus besoin car fera partie du link
  CRITDET -= "&[SOQ]DEMSTA=1"

  #--Etape 3
  #--Déterminer les éléments de facturation avec flag regroupement "Non si différent"
  #--Ces derniers vont alors faire partie des critères de regroupement
  #--On ajoute dans le tableau [L]GRUNOM les numeros des élements
  #--dont la regle de regroupement est à "Non si différent", pour ce document
  Gosub OPEN_SFI From TRTX3CPY
  Local Integer RCNTDFI : RCNTDFI= nbrecord([F:SFI])
  If RCNTDFI<=5 : RCNTDFI = 10 : Endif
  Local Integer GRUNON([L]RCNTDFI), I1, I2, I12, PDESVCR, PORIVCR
  PDESVCR=4  :#--'Facture'
  PORIVCR=10 :#--'Cde normale'
  I2=0
  Read [SFI]First
  While fstat=0
      I12=find([L]PDESVCR, [F:SFI]DESVCR(0..dim([F:SFI]DESVCR)-1))
      #--Deux règles de transfert portent sur le doc de destination "Facture"
      #--Il faut pointer sur le flux "Cde normale" -> "Facture"
      #--Normalement, c'est le suivant...
      If I12>0
        I1=find([L]PORIVCR, [F:SFI]ORIVCR(I12-1..dim([F:SFI]ORIVCR)-1))
        If I1>0 & [F:SFI]GRUFLG(I1-1) = 2
            [L]GRUNON(I2)=[F:SFI]SFINUM
            I2+=1
        Endif
      Endif
      Read [F:SFI] Next
  Wend

  WOK=1
  #If dim(GPJTSNGDOC)<1 : Global Integer GPJTSNGDOC : GPJTSNGDOC= G_NON : Endif #--A VIRER !! pour mock

  #--Etape 4
  #--Link de la table des lignes intermédiaires avec les tables en-tête/lignes à l'origine de ces dernières
  #--Les filtres utilisés :
  #--CRITSVCRINVCND      : porte directement sur la tables des échéanciers
  #--CRITSVCRINVCNDLIN   : porte directement sur les lignes de la table des échéanciers
  #--CRITERE             : porte sur les champs de la table en-tête d'origine (içi SORDER)
  #--FILSUPENT           : positionné par point d'entrée - contient les éventuels filtres sur champs en-tête table origine
  #--CRITDET             : porte sur les champs de la table lignes d'origine (içi SORDERQ uniquement)
  #--FILSUPDET           : positionné par point d'entrée - contient les éventuels filtres sur champs ligne table origine

#  #--Définition du Link entre table intermédiaire et en-tête/lignes origine
#  Link [SVICD] With [SVIC]SVIC0~=[SVICD]VCRTYP;
#&                                [SVICD]VCRNUMORI;[SVICD]VCRLINORI;[SVICD]VCRSEQORI,
#&                   [SOH]SOH0  ~=[SVICD]VCRNUMORI,
#&                   [SOQ]SOQ0  ~=[SVICD]VCRNUMORI;[SVICD]VCRLINORI;[SVICD]VCRSEQORI
#&               As  [SVICLNK]
#&           Where evalue(CRITSVCRINVCND) and
#&                 evalue(CRITSVCRINVCNDLIN) and
#&                (evalue(CRITERE) and evalue(FILSUPENT)) and
#&                (evalue(CRITDET) and evalue(FILSUPDET))
Gosub LOAD_SWICND_LINK
#--Boucle sur link et alimentation de la table temporaire (compte tenue des critères de regroupement)
#--Parcours des enregistrements intermédiaires afin de remplir la table temporaire
#--Objectif : chargement des différents critères de regroupement
#--           afin d'avoir un parcours linéaire de la création des factures
#--ESSENTIEL à l'utilisation du GENSIH !!! (car continue à lire au travers du READ_DETAIL de TRTSIHSVICSOH)

  WIME="1" # by default : 1 fac/date prochaine fac
  If [M:DIA]IMESVIC>0
    WIME=num$([M:DIA]IMESVIC)
  Endif

#  For [SVICLNK]
#    Gosub CHARGESWI
#    If WOK=0 : Break : Endif
#  Next
  Gosub LOAD_SWICND_USE_LINK

  Close File [SVICLNK]

Return
#-------------------------------------------------------------------------------------

$LOAD_SWICND_LINK
#--Définition du Link entre table intermédiaire et en-tête/lignes origine
Link [SVICD] With [SVIC]SVIC0~=[SVICD]VCRTYP;
&                                [SVICD]VCRNUMORI;[SVICD]VCRLINORI;[SVICD]VCRSEQORI,
&                   [SOH]SOH0  ~=[SVICD]VCRNUMORI,
&                   [SOQ]SOQ0  ~=[SVICD]VCRNUMORI;[SVICD]VCRLINORI;[SVICD]VCRSEQORI
&               As  [SVICLNK]
&           Where evalue(CRITSVCRINVCND) and
&                 evalue(CRITSVCRINVCNDLIN) and
&                (evalue(CRITERE) and evalue(FILSUPENT)) and
&                (evalue(CRITDET) and evalue(FILSUPDET))
Return

$LOAD_SWICND_USE_LINK
  For [SVICLNK]
    Gosub CHARGESWI
    If WOK=0 : Break : Endif
  Next
Return


#-----------------------------------------------------------------------#
#     chargement dans le fichier de travail                             #
#-----------------------------------------------------------------------#
$CHARGESWI
Local Integer WWEEK
Local Date    WDAT

  # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)
#  Call DEBTRANS From GLOCK
#  $CHGFIC
#  GOK=1
#  Trbegin [SWICND]
  # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)

  #--ATTENTION : trouver une solution car tables faisant partie du Link avec TIM !!!
  #--Erreur suite Readlock : pour l'instant mis en commentaire
  ## -------------------> lecture entête commande
  #Readlock [SOH]SOH0 Curr
  #If    fstat=1 : GOK=-1 : GLOCK="$SORDER"+[F:SOH]SOHNUM : Goto ROL_CHGFIC
  #Elsif fstat   : GOK=0  : Call RSTA("SOH",[F:SOH]SOHNUM) From GLOCK : Goto AB_TRT
  #Endif
  #
  ## -------------------> lecture détail cde qte
  #Readlock [SOQ]SOQ0 Curr
  #If    fstat=1 : GOK=-1 : GLOCK="$SORDERQ"+[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ) : Goto ROL_CHGFIC
  #Elsif fstat   : GOK=0  : Call RSTA("SOQ",[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)) From GLOCK : Goto AB_TRT
  #Endif
  Gosub SEL_DETCOMPL
  If OK = 2
    # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)
    # --> lock fichier entête commande
    SYMBOLE = "SOH"+[F:SOH]SOHNUM
    Lock = SYMBOLE
    If fstat
       # modification en cours sur un autre poste
       Call ECR_TRACE("$SORDER :"-[F:SOH]SOHNUM-mess(10,100,1),1) From GESECRAN
       OK=1
    Endif

    If OK=2
        # --> ouverture de la txn de maj après le lock SYMBOLE
        Call DEBTRANS From GLOCK
        $CHGFIC
        GOK=1
        Trbegin [SWICND]
        # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)

        Raz [F:SWICND]
        [F:SWICND]PRONUM  = adxuid(1)
        [F:SWICND]SWIKEY  = [F:SOH]SALFCY
        [F:SWICND]SWIKEY += "~"+[F:SOH]BPCINV

        [F:SWICND]SWIKEY1 = WIME

        Case WIME
         When "1" : #1 fac/date prochaine fac
            [F:SWICND]SWIKEY1 += "~"+num$([SVICLNK]NEXINVDAT)
         When "2" : #1 fac/cde
            [F:SWICND]SWIKEY1 += "~"+[F:SOH]SOHNUM
         When "3" : #1 fac/client
            [F:SWICND]SWIKEY1 += "~"+[F:SOH]BPCORD
            [F:SWICND]SWIKEY1 += "~"+[F:SOQ]BPAADD
         When "4" : #1 fac/projet
            #--Fait juste en dessous...
         When Default
        Endcase

        [F:SWICND]SWIKEY1 += "~"+[F:SOH]CUR
        [F:SWICND]SWIKEY1 += "~"+num$([F:SOH]PRITYP)

        #-- Ca n'est plus le PJT de l'entête qui compte
        If GPJTSNGDOC = G_OUI Then
          #-- Si le PJT est unique par pièce il est discriminant : on le prend
          [F:SWICND]SWIKEY1 += "~"+[F:SOH]PJT
        Else
          If WIME="4"
            #--Si 1 fac/projet on le prends à la ligne
            [F:SWICND]SWIKEY1 += "~"+[F:SOQ]PJT
          Else
            #-- Sinon, il n'est pas discriminant : on l'ignore
            [F:SWICND]SWIKEY1 += "~"
          Endif
        Endif

        [F:SWICND]SWIKEY1 += "~"+[F:SOH]BPCPYR
        [F:SWICND]SWIKEY1 += "~"+[F:SOH]VACBPR

        [F:SWICND]SWIKEY1 += "~"+[F:SOH]BPIEECNUM
        [F:SWICND]SWIKEY1 += "~"+[F:SOH]EECICT
        [F:SWICND]SWIKEY1 += "~"+num$([F:SOH]EECLOC)

        [F:SWICND]NUM = [F:SOH]SOHNUM
        [F:SWICND]LIN = [F:SOQ]SOPLIN
        [F:SWICND]SEQ = [F:SOQ]SOQSEQ

        [F:SWICND]SWIDATA  = [F:SOH]BPCGRU
        [F:SWICND]SWIDATA += "~"+[F:SOH]PTE
        [F:SWICND]SWIDATA += "~"+num$([F:SOH]BETFCY)
        [F:SWICND]SWIDATA += "~"+[F:SOH]ORIFCY
        [F:SWICND]SWIDATA += "~"+[F:SOH]PLISTC
        [F:SWICND]SWIDATA += "~"+toupper(vireblc([F:SOH]BPINAM(0),4))
        [F:SWICND]SWIDATA += toupper(vireblc([F:SOH]BPIADDLIG(0),4))
        [F:SWICND]SWIDATA += toupper(vireblc([F:SOH]BPIPOSCOD,4))
        [F:SWICND]SWIDATA += toupper(vireblc([F:SOH]BPICTY,4))
        [F:SWICND]SWIDATA += toupper(vireblc([F:SOH]BPISAT,4))

        # LTA - Sage sales tax USA
        If func AFNC.ACTIV("LTA")
          [F:SWICND]SWIDATA +="~"+[F:SOH]SSTENTCOD
        Endif

        #-- Gestion de GRUFLG (flag regroupement des éléments de facturation)
        Local Integer I, J : I=0
        While [L]GRUNON(I)>0 and I<RCNTDFI-1
            J=find([L]GRUNON(I), [F:SOH]INVDTA)
            If J>0
              #--Afin de tenir compte du paramètrage éclatement à "1ère Facture"
              #--Si cde déjà facturée, la facture suivante prends 0 pour l'élément de facturation
              If [F:SOH]INVSTA>1
                [F:SWICND]SWIDATA += "~" + "0"
              Else
                [F:SWICND]SWIDATA += "~" + vireblc( num$( [F:SOH]INVDTAAMT(J-1) ) ,4 )
              Endif
            Endif
            I+=1
        Wend

        #-- Codes adresses client commande et facture
        [F:SWICND]SWIDATA += [F:SOH]BPAORD
        [F:SWICND]SWIDATA += [F:SOH]BPAINV

        [F:SWICND]SWILINNBR = [F:SOH]LINNBR

        #-- Chargement qté à facturer dans (SWICND]
        #-- WQTY     = qté à facturer en UV
        #-- WQTYSTU  = qté à facturer en US
        [F:SWICND]QTY=[F:SVICD]INVCNDQTY

      #--A REVOIR A enlever
      #  If WQTY>[F:SVICD]INVCNDQTY
      #    WQTY    = [F:SVICD]INVCNDQTY
      #  Endif
      #  Raz [F:SWICND]QTY
      #  #-- Si ligne de commande normale ou de nomenclature
      #  If [F:SOH]SOHCAT=4 | !find([F:SOP]LINTYP,2,3,4,5,10,11,12,13)
      #     [F:SWICND]QTY    = WQTY
      ##     [F:SWICND]QTYSTU = WQTYSTU
      #  #-- Si composé kit/sous-traité
      #  Elsif find([F:SOP]LINTYP,2,10)
      #     [F:SWICND]QTY    = WQTY
      ##     [F:SWICND]QTYSTU = WQTYSTU
      #     #-- Stockage qté livré et cdé composé pour calcul qté composant
      #     WQTYCPE       = WQTY
      #     WSOQQTY       = [F:SOQ]QTY
      #  #-- Si composant kit/sous-traité
      #  Elsif find([F:SOP]LINTYP,3,4,5,11,12,13)
      #     [F:SWICND]QTY    = WQTYCPE*([F:SOQ]QTY/WSOQQTY)
      ##     [F:SWICND]QTYSTU = [F:SWICND]QTY*[F:SOP]SAUSTUCOE
      ##     Call QTEARR ([F:SWICND]QTYSTU,[F:SOP]STU) From TRTDIV
      #  Endif
      #--/A REVOIR

        #-- Pour rajouter des conditions de regroupements
        GPOINT="AUTINVSCHREG" : Gosub ENTREE From EXEFNC

        If [F:SWICND]SWIDATA<>""
          Filter [SWICND1] Where PRONUM=[F:SWICND]PRONUM & SWIKEY=[F:SWICND]SWIKEY & SWIKEY1=[F:SWICND]SWIKEY1 &
&                               SWIDATA=[F:SWICND]SWIDATA
          Read [SWICND1] First
          If fstat
            WSWIKEYD +=1
            [F:SWICND]SWIKEYD=WSWIKEYD
          Else
            [F:SWICND]SWIKEYD=[F:SWICND1]SWIKEYD
          Endif
          Filter [SWICND1]
        Endif

        #--Reporter la clé de [SVIC]
        #--Utile car le parcours de la table temporaire se fera sur un Link avec les tables en-tête/lignes d'origine
        [F:SWICND]VCRTYP       = [F:SVICLNK]VCRTYP
        [F:SWICND]VCRNUMORI    = [F:SVICLNK]VCRNUMORI
        [F:SWICND]VCRLINORI    = [F:SVICLNK]VCRLINORI
        [F:SWICND]VCRSEQORI    = [F:SVICLNK]VCRSEQORI
        [F:SWICND]INVCNDTYP    = [F:SVIC]INVCNDTYP
        [F:SWICND]VCRINVCNDLIN = [F:SVICLNK]VCRINVCNDLIN
        #--
        Write [SWICND]
        If fstat
           GOK=0 : Call FSTA("SWICND") From GLOCK : Goto AB_TRT
        Endif
        Commit
    # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)
    Endif
#  Else
#    Rollback
    # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)
  Endif

Return
#-------------------------------------------------------------------------------------
#-----------------------------------------------------------------------#
#     Sélection complémentaires pour lignes détail                      #
#-----------------------------------------------------------------------#
$SEL_DETCOMPL
  OK = 2

  If func TRTPJT.IS_PJT_AVAILABLE([F:SOQ]PJT, "[M:SIH4]DPJT", WMESS) = G_NON Then
    Call PJT_ADD_MSG([F:SOQ]PJT, WMESS) From TRTPJT
    OK = 1
    Return
  Endif

  #--Lecture des diverses tables dont nous avons besoin
  #-- Lecture détail cde prix
  If [F:SOP]SOHNUM<>[F:SOQ]SOHNUM or [F:SOP]SOPLIN<>[F:SOQ]SOPLIN or [F:SOP]SOPSEQ<>[F:SOQ]SOQSEQ
    Read [SOP]SOP0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN; [F:SOQ]SOQSEQ
    If fstat : OK=1 : Return : Endif
  Endif

  #--A REVOIR :
  #--L'objectif est de détacher les quantités de la facturation par échéance
  #WSAU       = [F:SOP]SAU
  #WSAUSTUCOE = [F:SOP]SAUSTUCOE
  #If WSAUSTUCOE=0 WSAUSTUCOE=1 Endif
  #--/A REVOIR

  #-- Lecture article maitre
  If [F:ITM]ITMREF<>[F:SOQ]ITMREF
    Read [ITM]ITM0 = [F:SOQ]ITMREF
    If fstat : OK=1 : Return : Endif
  Endif

  # Si ligne de contrat de service
  If [F:SOH]SOHCAT <> 4 & [F:SOP]CONNUM <> ""
     OK=1 : Return
  Endif

  #--A REVOIR :
  #--L'objectif est de détacher les quantités de la facturation par échéance
  #
  ##-- Ctl qte allouée si article géré en stock
  ##-- Ctl qte commandée si article non géré en stock
  #If [F:SOQ]STOMGTCOD<>1 | find([F:SOP]LINTYP,2,3,4,5,10,11,12,13)
  #   If [F:SOQ]ALLQTY<=0
  #      OK=1 : Return
  #   Endif
  #   If [F:SOH]DME=2 & [F:SOQ]ALLQTY+[F:SOQ]ODLQTY+[F:SOQ]INVQTY < [F:SOQ]QTY
  #      OK=1 : Return
  #   Endif
  #Elsif [F:SOQ]QTY <= [F:SOQ]INVQTY+[F:SOQ]ODLQTY
  #   OK=1 : Return
  #Endif
  #
  ## --> Si ligne gérée en contremarque, la commande d'achat doit avoir été générée
  #If [F:SOQ]FMI > 1 & [F:SOQ]FMI < 4 & [F:SOQ]FMINUM = ""
  #    WMESS=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1
  #    Call ECR_TRACE(WMESS,0) From GESECRAN
  #    WMESS=mess(160,197,1)
  #    Call ECR_TRACE("         "+WMESS,1) From GESECRAN
  #    OK=1
  #    Return
  #Endif
  ## --> Si ligne gérée avec un ordre de production, l'OF doit avoir été généré
  #If [F:SOQ]FMI = 5 & [F:SOQ]FMINUM = ""
  #    WMESS=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1
  #    Call ECR_TRACE(WMESS,0) From GESECRAN
  #    WMESS=mess(201,197,1)
  #    Call ECR_TRACE("         "+WMESS,1) From GESECRAN
  #    OK=1
  #    Return
  #Endif
  #
  ##-- Gestion des versions
  #If func AFNC.ACTIV("ECC") Then
  #  Call CTLECCVAL([F:SOQ]ECCVALMAJ, [F:SOQ]STOFCY, [F:SOQ]ITMREF, 4, "", [M:DIA]INVDAT, LRET) From STKSOR
  #  If LRET >= 1 Then
  #    WMESS = mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1
  #    Call ECR_TRACE(WMESS,0) From GESECRAN
  #    WMESS = GMESSAGE - "(" + [F:SOQ]ECCVALMAJ + ")"
  #    Raz GMESSAGE
  #    Call ECR_TRACE(WMESS,0) From GESECRAN
  #    OK = 1
  #    Return
  #  Endif
  #  #
  #  SVMESSAGE = GMESSAGE
  #  Call STKCTRECC([F:SOQ]ITMREF, [F:SOQ]ECCVALMAJ, [F:SOQ]ECCVALMIN, "", 4) From STKACT
  #  If mkstat Then
  #    WMESS = mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1
  #    Call ECR_TRACE(WMESS,0) From GESECRAN
  #    WMESS = GMESSAGE - "(" + [F:SOQ]ECCVALMIN + ")"
  #    Raz GMESSAGE
  #    Call ECR_TRACE(WMESS,0) From GESECRAN
  #    OK = 1
  #    Return
  #  Endif
  #Endif
  #--/A REVOIR

  #-- Pour rajouter des filtres sur les enregistrements à traiter
  GPOINT="AUTINVSCHSEL" : Gosub ENTREE From EXEFNC

  #--A REVOIR :
  #--L'objectif est de détacher les quantités de la facturation par échéance
  #--Question : comment gérer les nomenclatures ? Est-ce uniquement le composé qui possède un échéancier de facture ?
  ##---------------------------------------
  ## Détermination de la quantité livrable
  ##---------------------------------------
  #LTRSTYP=4
  #LTRSCOD=WP_TRSCOD
