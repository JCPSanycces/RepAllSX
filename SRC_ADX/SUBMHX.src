Subprog D_BUD(VALEUR)
Variable Char    VALEUR()
Read [F:SXH]SXH0 = GFLAG
If !fstat : VALEUR = [F:SXH]BUD : Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

#contrat du salarié
Call SELCTR(VALEUR,datesyst,datesyst,[M:MHX0]CTRNUM(nolign-1)) From DIVPAYE
If [M:MHX0]CTRNUM(nolign-1) = ""
 GOK=0 : GMESSAGE =mess(150,10702,1) : #Pas de contrat de travail pour ce salarié
 mkstat = 2
 End
Endif
If [F:ID]FLGMULCTR>1
 Actzo [M:MHX0]CTRNUM(nolign-1)
Else
 Diszo [M:MHX0]CTRNUM(nolign-1)
Endif
If [M:MHX0]CTRNUM(nolign-1) <> ""
#contrôle des doublons
 Call CTL_DBL(VALEUR,[M:MHX0]CTRNUM(nolign-1),nolign-1)
 If !GOK
  mkstat=2
  End
 Endif
Endif
#73013 : after contract ctrl
#maj nom-prénom
Call VAL_NAMSRN (VALEUR,"[M:MHX0]NAMSRN("+num$(nolign-1)+")") From SUBMHE
Affzo [M:MHX0]NAMSRN(nolign-1)

End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
Call CTL_DBL([M:MHX0]REFNUM(nolign-1),VALEUR,nolign-1)
If !GOK
 mkstat=2
 End
Endif
End

Subprog AM_REFRPL(VALEUR)
Variable Char    VALEUR()
#72635
  Call UPD_REFRPL(VALEUR)
#end 72635
End

Subprog AM_CTRRPL(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M:MHX0]REFRPL(nolign-1)<>""
 # Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2
 End
Endif
Call LOOK_FLDVAL([M:MHX0]REFRPL(nolign-1),VALEUR,nolign-1)
End

Subprog C_NBXIT
If !adxgtb and GREP<>""
 If[M:MHX0]OKFLD=0
  GMESSAGE=mess(3,10722,1) #Déphasage Champs salariés de l'hypothèse / champs salariés transaction
  mkstat=2 : End
 Endif
 If [M:MHX0]OKVRA=0
  GMESSAGE=mess(7,10722,1) #Déphasage Variables salariés de l'hypothèse / Variables salariés définies dans la transaction
  mkstat=2 : End
 Endif
Endif
End

Subprog C_ENAFLG1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Chgstl [M:MHX0]NBXIT(nolign-1) With "CONTRAT"
Else
 Chgstl [M:MHX0]NBXIT(nolign-1) With ""
Endif
End

