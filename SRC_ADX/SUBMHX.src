$B2_APPDOWN
  Local Char ZONE1, ZONE2
  ZONE2 = ""
  ZONE1 = "[M:MHX0]"+zoncou
  If left$(zoncou,6)="FLDVAL"
    ZONE2="[M:MHX0]VALINT"+right$(zoncou,7)
  Endif

  For I=nolign-1 To [M:MHX0]NBXIT-1
    Assign ZONE1+"("+num$(I)+")" With VALEUR
    If ZONE2<>""
      Assign ZONE2+"("+num$(I)+")" With VALEUR
    Endif
  Next

  Affzo[M:MHX0]
  Gosub CHANGE_STYLE
Return

Subprog AM_SRCENT(VALEUR)
Variable Char    VALEUR()
  Raz [M:MHX0]SRCOBJ(nolign-1)
  Raz [M:MHX0]SRCDES(nolign-1)
  If VALEUR<>""
    Call INIT_MODEL(VALEUR) From SUBMHE
    If mkstat
      GMESSAGE = mess(23,100,1) #fiche inexistante
      End
    Endif

    If [M:MHX0]SRCOBJ(nolign-1)<>""
      Call FILL_SRCDES([M:MHX0]SRCDES(nolign-1)) From SUBMHE
      Affzo [M:MHX0]SRCDES(nolign-1)
    Else
      End
    Endif

    Call GET_REFRPL(VALEUR)
    If [M:MHX0]REFRPL(nolign-1)<>""
      Affzo [M:MHX0]REFRPL(nolign-1)
      Call UPD_REFRPL([M:MHX0]REFRPL(nolign-1))
      If [M:MHX0]CTRRPL(nolign-1) <> "" & GOK
        zonsui="[M:MHX0]DATRPL(nolign-1)"
      Endif
    Endif
  Endif
End

Subprog GET_REFRPL(VALEUR)
Variable Char VALEUR
  Case [M:MHX0]SRCOBJ(nolign-1)
    When "EML" : [M:MHX0]REFRPL(nolign-1) = VALEUR
    When "POT"
      Call LECTURE("POT",VALEUR,"") From CONTOBJ
      If !fstat
        If [F:POT]EMPMDL<>""
          [M:MHX0]REFRPL(nolign-1) = [F:POT]EMPMDL
        Elsif [F:POT]JOBPOT<>""
          Call LECTURE("JOT",[F:POT]JOBPOT,"") From CONTOBJ
          If !fstat
            [M:MHX0]REFRPL(nolign-1) = [F:JOT]EMPMDL
          Endif
        Endif
      Endif
    When "JOT"
      Call LECTURE("JOT",VALEUR,"") From CONTOBJ
      If !fstat
        [M:MHX0]REFRPL(nolign-1) = [F:JOT]EMPMDL
      Endif
    When "PRF"
      Call LECTURE("PRF",VALEUR,GCURLEG) From CONTOBJ
      If !fstat
        [M:MHX0]REFRPL(nolign-1) = [F:PRF]EMPMDL
      Endif
  Endcase
End

Subprog S_SRCENT(VALEUR)
Variable Char    VALEUR()
  Call SELECT("EML","",VALEUR,"") From SELOBJ
End

Subprog B2_SRCENT(VALEUR)
Variable Char    VALEUR()
  Call SELECT("POT","",VALEUR,"") From SELOBJ
  mkstat=99
End

Subprog B3_SRCENT(VALEUR)
Variable Char    VALEUR()
  Call SELECT("JOT","",VALEUR,"") From SELOBJ
  mkstat=99
End

Subprog B4_SRCENT(VALEUR)
Variable Char    VALEUR()
  Call SELECT("PRF","",VALEUR,GCURLEG) From SELOBJ
  mkstat=99
End

Subprog UPD_REFRPL(VALEUR)
Variable Char VALEUR()
#SEGAY 04/10/11 bug 76798
Local Integer OK
Raz OK
#END bug 76798
  If VALEUR = ""
    Call AVERTIR(mess(4,10722,1),OK) From GESECRAN # Effacement des champs salarié remplaçant
    If OK = 2
      Call EFF_REMPL(VALEUR,nolign-1)
    Else
      VALEUR = [M:MHX0]REFRPL(nolign-1)
      mkstat=2
    Endif
  Else
    #maj nom-prénom
    Call VAL_NAMSRN (VALEUR,"[M:MHX0]NAMSRNRPL("+num$(nolign-1)+")") From SUBMHE
    Affzo [M:MHX0]NAMSRNRPL(nolign-1)
    #contrat du salarié
    Call SELCTR(VALEUR,datesyst,datesyst,[M:MHX0]CTRRPL(nolign-1)) From DIVPAYE
    If [M:MHX0]CTRRPL(nolign-1) = ""
     End
    Endif

    If [F:ID]FLGMULCTR>1
     Actzo [M:MHX0]CTRRPL(nolign-1)
    Else
     Diszo [M:MHX0]CTRRPL(nolign-1)
    Endif
    #Recherche des valeurs champs salarié MS
    Call LOOK_FLDVAL(VALEUR,[M:MHX0]CTRRPL(nolign-1),nolign-1)
  Endif
End

Subprog C_REFRPL(VALEUR)
Variable Char    VALEUR()
#SEGAY 04/10/11 bug 76798 rajout du test sur valeur pour ne pas bloquer les transacations
# de sortie, les transactions de remplacement si code à blanc sont tester au C_FLDVAL6
  If VALEUR <> ""
    Call SELCTR(VALEUR,datesyst,datesyst,[M:MHX0]CTRRPL(nolign-1)) From DIVPAYE
    If [M:MHX0]CTRRPL(nolign-1) = ""
      GOK=0 : GMESSAGE =mess(150,10702,1) : #Pas de contrat de travail pour ce salarié
      mkstat = 2
    Endif
  Endif
End
#end 72635

