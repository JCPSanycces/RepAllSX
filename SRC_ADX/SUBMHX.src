# LS : Si remplaçant est saisi il faut saisir une date
Subprog C_DATRPL(VALEUR)
Variable Date    VALEUR
If [M:MHX0]REFRPL(nolign-1)<>"" & VALEUR=[0/0/0]
 # Un remplaçant est saisi : Date de remplacement obligatoire
 GMESSAGE = mess(5,10722,1)
 mkstat = 2 : End
Endif
End


