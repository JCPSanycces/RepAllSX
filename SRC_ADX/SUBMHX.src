#<AdxTL>@(#)11.0.0.0 $Revision$
################################################################################
# MODIFICATION
#  SEGAY - 04/10/11 - Bug 76798
################################################################################
Raz GPILOBJ
Call OBJET("MHX",GBIDC1,"") From GOBJET
End

######################################################################################
## Objet MHX 00/00/0000 00:00:00 (WGA)
######################################################################################
$ACTION
Case ACTION
 When "FILTRE"      : Gosub FILTRE
 When "OUVRE"       : Gosub OUVRE
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "AVANT_MOD"   : Gosub AVANT_MOD
 When "ANNULE"      : Gosub ANNULE
 When "RAZDUP"      : Gosub RAZDUP
 When "APRES_CRE"   : Gosub APRES_CRE #72635
 When "APRES_MOD"   : Call GENHYPO(nomap,[F:MHX]COD) From SUBMHX
 When "SETBOUT"     : Gosub SETBOUT
 #72635
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 #end 72635
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "FERME"       : Gosub FERME
Endcase
Return

#####################################
$FILTRE
If GFLAG<>""
 Default File [MHX]
 FILTSUP+="TRN=GFLAG"
Endif
Return

#####################################
$OUVRE
If clalev ([F:BCB])=0  : Local File BCLOB     [BCB] : Endif
If clalev ([F:TCA])=0  : Local File TABCOUAFF [TCA] : Endif
If clalev ([F:SXH])=0  : Local File SCRMHXH   [SXH] : Endif
If clalev ([F:SXD])=0  : Local File SCRMHXD   [SXD] : Endif
If clalev ([F:ATZ])=0  : Local File ATABZON   [ATZ] : Endif
If clalev ([F:ATY])=0  : Local File ATYPE     [ATY] : Endif
If clalev ([F:MCL])=0  : Local File MSSCENAL  [MCL] : Endif
If clalev ([F:MCH])=0  : Local File MSSCENAH  [MCH] : Endif
#72635
If clalev ([F:POT])=0  : Local File POSTE     [POT] : Endif
If clalev ([F:JOT])=0  : Local File JOBTYP    [JOT] : Endif
If clalev ([F:PRF])=0  : Local File PROFIL    [PRF] : Endif

If clalev ([F:POD])=0  : Local File POSTEDEF  [POD] : Endif
If clalev ([F:JOD])=0  : Local File JOBTYPDEF [JOD] : Endif
If clalev ([F:HRPFD])=0  : Local File PROFILDEF [HRPFD] : Endif
If clalev ([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
#72635

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only

Gosub DEFVAR From SUBMHE

Raz GFLDMS
Raz GVRAMS
#Chargement des champs salariés
Local Integer JJ : JJ= 0
For [F:SXD]SXD0 Where [F:SXD]COD=GFLAG & [F:SXD]ORIFLD=1
 Read [F:DIC]DIC0 = [F:SXD]FLD
 If !fstat & ([F:DIC]CODACT = "" | func AFNC.ACTIV([F:DIC]CODACT) > 0)
  JJ+=1
  If JJ > dim(GFLDMS) : Break : Endif
  GFLDMS(JJ,0) = [F:SXD]FLD
  GFLDMS(JJ,1) = [F:SXD]TIT
 Endif
Next
#Chargement des variables salariés
JJ= 0
For [F:SXD]SXD0 Where [F:SXD]COD=GFLAG & [F:SXD]ORIFLD=2
 Read [F:VRA]VRA0 = GCURLEG;[F:SXD]FLD
 If !fstat
  #61896
  Call CONTEXE([F:VRA]CODACC) From CPTSUB
  If !mkstat & ([F:VRA]CODACT = "" | func AFNC.ACTIV([F:VRA]CODACT) > 0)
   JJ+=1
   If JJ > dim(GVRAMS) : Break : Endif
   GVRAMS(JJ,0) = [F:SXD]FLD
   GVRAMS(JJ,1) = [F:SXD]TIT
  Endif
 Endif
Next
Return

#####################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#Ajouter par DBA le 22/04 :
#Vérouillage de la modification, de la suppression et du changement de clé en fonction du contexte
#####################################
$SETBOUT
If GREP<>"" | !VERROU
 Call VIREBOUT (CHAINE,"AH") From GOBJET
 If GREP="M" | GREP="C" | GREP="D"
  Call VIREBOUT (CHAINE,"B") From GOBJET
 Endif
Elsif  [M:MHX0]FLGCLO=2
 Call VIREBOUT (CHAINE,"AH") From GOBJET
Endif

If [M:MHX0]FLGCLO=2
 Call VIREBOUT (CHAINE,"M") From GOBJET
Endif
Return

#72635
$AVANTBOUT
  Effzo [M:MHX0]
  REP="C" : GREP="C"
  Gosub RAZCRE
  Gosub INICRE
Return

$EXEBOUT
  Case BOUT
    When "B"
      If !GOK
        REP="" : GREP=""
      Endif
      Affzo [M:MHX0]
      Gosub CHANGE_STYLE
  Endcase
Return

$APRES_CRE
  Call GENHYPO(nomap,[F:MHX]COD) From SUBMHX
Return
#end 72635

#####################################
$LIENS
# On décoche Définitif si l'hypothèse n'est stockée dans aucun scénario définitif
Link [MCL] With [MCH]MCH0=[MCL]COD
& As [LMC]
& Where [MCH]FLGCLO=2 & [MCL]TYPHYP=5 & [MCL]CODHYP=[F:MHX]COD
Read [LMC]MCL1 First
If fstat
 [M:MHX0]FLGCLO = 1
 Call DEBTRANS From GLOCK
 Gosub TR_LIEN
Endif
Gosub MHX_VALROWFLD
Return

$TR_LIEN
Trbegin [MHX]
 [F:MHX]FLGCLO = 1
 Rewrite[MHX]
 If fstat : Call FSTA("MHX") From GLOCK : Rollback : Return : Endif
Commit
Return

#####################################
$LIENS2
#CMT
Default Mask [M:MHX0]
Call CHARGE_CMT ("SUBMHX",[F:MHX]COD,"","","")From SUBMSR
Gosub TITROWFLD From SUBMHE
Gosub CHG_FMTROW From SUBMHE
Gosub TITROWVRA From SUBMHE
Gosub CHG_FMTVRA From SUBMHE
Affzo [MHX0]
Gosub CHANGE_STYLE
If [M:MHX0]FLGCLO = 2
 Diszo [M:MHX0]BUD
 Diszo [M:MHX0]10
Else
 Actzo [M:MHX0]BUD
 Actzo [M:MHX0]10
Endif

Return

#####################################
$INIMOD
Default Mask [M:MHX0]
Call SAUVE_CMT ("SUBMHX",[F:MHX]COD,"","","")From SUBMSR
Return

#####################################
$INICRE
Local Integer STAT
Local Char    COMPTEUR(GLONANM)
Actzo [M:MHX0]
## Affectation du no de MSR
If [F:MHX]COD=""
 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(51,10722,1) : # Compteur MSR non défini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(13)
 Endif
 Call NUMERO(COMPTEUR,"",date$,"",[F:MHX]COD,STAT) From SUBANM
 If STAT
  # Erreur sur compteur
  GMESSAGE = mess(4,10702,1)-COMPTEUR
  GOK = 0 : Return
 Endif
 Call VERIF_CPT([F:MHX]COD,COMPTEUR)
 If GOK=0 : Return : Endif
 [M:MHX0]COD = [F:MHX]COD
 Affzo [M:MHX0]COD
Endif

#CMT
Default Mask [M:MHX0]
Call SAUVE_CMT ("SUBMHX",[F:MHX]COD,"","","")From SUBMSR
#enregistrement champs salarié
Gosub SAV_FLDVAL

Return


#####################################
## Changement de clé
$AP_CHANGE
Call APCHANGE(5,OCODE,NCODE) From SUBMHR
Return

#####################################
$AVANT_MOD
If [M:MHX0]FLGCLO = 2
 # Hypothèse non modifiable : présente sur un scénario définitif
 GMESSAGE=mess(6,10722,1) : GERR=1 : OK=0
Endif
Return

#####################################
$APRES_MODIF
If [M:MHX0]CTRRPL(nolign-1)=""
 Case zoncou
  When "DATRPL"  , "VRAVAL0" , "VRAVAL1" , "VRAVAL2" , "VRAVAL3" , "VRAVAL4" , "VRAVAL5" ,
&      "VRAVAL6" , "VRAVAL6" , "VRAVAL8" , "VRAVAL9" , "VRAVAL10", "VRAVAL11", "VRAVAL12",
&      "VRAVAL13", "VRAVAL14"
   GMESSAGE=mess(11,10722,1) : #Pas de remplaçant saisi : Champ réservé au remplaçant
   mkstat=2
  When Default
 Endcase
Endif
Return

#####################################
$ANNULE
Call ANNULE_CMT ("SUBMHX",[F:MHX]COD,"","","")From SUBMSR
PROG = "WPMS5"+[F:MHX]COD
Call DELTRTHYP (PROG) From SUBMHE
Return

#####################################
$RAZCRE
[M:MHX0]FLGCLO=1
[M]TRN=GFLAG
Gosub TITROWFLD From SUBMHE
Gosub CHG_FMTROW From SUBMHE
Gosub TITROWVRA From SUBMHE
Gosub CHG_FMTVRA From SUBMHE
Affzo [M:MHX0]
Return

#####################################
$RAZDUP
[M:MHX0]FLGCLO=1
Actzo [M:MHX0]BUD
Actzo [M:MHX0]10
Affzo [M:MHX0]
Return

####################################
$CHANGE_STYLE
For nolign=1 To [M:MHX0]NBXIT
 If [M:MHX0]ENAFLG1(nolign-1)=2
  Chgstl [M:MHX0]NBXIT(nolign-1) With "CONTRAT"
 Else
  Chgstl [M:MHX0]NBXIT(nolign-1) With ""
 Endif
Next
Return

####################################
$MHX_VALROWFLD
#alimentation du tableau des valeur des champs & variables salariés (maxi 20+15)
Local Integer L,R

For L=0 To dim([M:MHX0]REFNUM)-1
 If [M:MHX0]REFNUM(L) = "" : Break : Endif
 If [F:MHX]REFNUM = [M:MHX0]REFNUM(L) & [F:MHX]CTRNUM = [M:MHX0]CTRNUM(L)
#CHAMPS SALARIES
  For R=0 To dim([M:MHX0]FLDEML)-1
#on alimente les valeurs que l'on trouve
   Call VALROWFLD("[M:MHX0]FLDVAL"+num$(R)+"("+num$(L)+")","[F:MHX]FLDVAL("+num$(R)+")") From SUBMHE
   Call VALROWFLD("[M:MHX0]VALINT"+num$(R)+"("+num$(L)+")","[F:MHX]FLDVAL("+num$(R)+")") From SUBMHE
#et le code du champs si il correspond
   If [M:MHX0]FLDEML(R) = ""
    Call VALROWFLD("[M:MHX0]FLDEML"+"("+num$(R)+")","[F:MHX]FLDEML("+num$(R)+")") From SUBMHE
   Endif
  Next
#VARIABLES SALARIES
  For R=0 To dim([M:MHX0]VRAEML)-1
   Call VALROWFLD("[M:MHX0]VRAVAL"+num$(R)+"("+num$(L)+")","[F:MHX]VRAVAL("+num$(R)+")") From SUBMHE
   If [M:MHX0]VRAEML(R) = ""
    Call VALROWFLD("[M:MHX0]VRAEML"+"("+num$(R)+")","[F:MHX]VRAEML("+num$(R)+")") From SUBMHE
   Endif
  Next
# Au passage alimentation des noms-prénom
  Call VAL_NAMSRN ([M:MHX0]REFNUM(L),"[M:MHX0]NAMSRN("+num$(L)+")") From SUBMHE
  If [M:MHX0]REFRPL(L)<> ""
   Call VAL_NAMSRN ([M:MHX0]REFRPL(L),"[M:MHX0]NAMSRNRPL("+num$(L)+")") From SUBMHE
  Endif
#72635 ..fill SRCDES
  Call FILL_SRCDES([M:MHX0]SRCDES(L)) From SUBMHE
#end 72635
  Break
 Endif
Next
Return

####################################
$SAV_FLDVAL
#enregistrement valeurs salariés dans la table
Local Integer L,R

For L=0 To [M:MHX0]NBXIT
 If [M:MHX0]REFNUM(L) = [F:MHX]REFNUM & [M:MHX0]CTRNUM(L) = [F:MHX]CTRNUM
  For R=0 To dim(GFLDMS)-1
   [F:MHX]FLDVAL(R) = evalue("[M:MHX0]VALINT"+num$(R)+"("+num$(L)+")")
  Next
  For R=0 To dim(GVRAMS)-1
   [F:MHX]VRAVAL(R) = evalue("[M:MHX0]VRAVAL"+num$(R)+"("+num$(L)+")")
  Next
  Break
 Endif
Next
Return

####################################
Subprog EFF_REMPL(VALR,MSI)
Value Char    VALR()
Value Integer MSI
If VALR = ""
 Raz [M]CTRRPL(MSI)  :Raz [M]DATRPL(MSI)  :Raz [M]NAMSRNRPL(MSI):Raz [M]FLDVAL0(MSI)
 Raz [M]FLDVAL1(MSI) :Raz [M]FLDVAL2(MSI) :Raz [M]FLDVAL3(MSI) :Raz [M]FLDVAL4(MSI)
 Raz [M]FLDVAL5(MSI) :Raz [M]FLDVAL6(MSI) :Raz [M]FLDVAL7(MSI) :Raz [M]FLDVAL8(MSI)
 Raz [M]FLDVAL9(MSI) :Raz [M]FLDVAL10(MSI):Raz [M]FLDVAL11(MSI):Raz [M]FLDVAL12(MSI)
 Raz [M]FLDVAL13(MSI):Raz [M]FLDVAL14(MSI):Raz [M]FLDVAL15(MSI):Raz [M]FLDVAL16(MSI)
 Raz [M]FLDVAL17(MSI):Raz [M]FLDVAL18(MSI):Raz [M]FLDVAL19(MSI)
 Raz [M]VALINT0(MSI) :Raz [M]VALINT1(MSI) :Raz [M]VALINT2(MSI) :Raz [M]VALINT3(MSI)
 Raz [M]VALINT4(MSI) :Raz [M]VALINT5(MSI) :Raz [M]VALINT6(MSI) :Raz [M]VALINT7(MSI)
 Raz [M]VALINT8(MSI) :Raz [M]VALINT9(MSI) :Raz [M]VALINT10(MSI):Raz [M]VALINT11(MSI)
 Raz [M]VALINT12(MSI):Raz [M]VALINT13(MSI):Raz [M]VALINT14(MSI):Raz [M]VALINT15(MSI)
 Raz [M]VALINT16(MSI):Raz [M]VALINT17(MSI):Raz [M]VALINT18(MSI):Raz [M]VALINT19(MSI)
 Raz [M]VRAVAL0(MSI) :Raz [M]VRAVAL1(MSI) :Raz [M]VRAVAL2(MSI) :Raz [M]VRAVAL3(MSI)
 Raz [M]VRAVAL4(MSI) :Raz [M]VRAVAL5(MSI) :Raz [M]VRAVAL6(MSI) :Raz [M]VRAVAL7(MSI)
 Raz [M]VRAVAL8(MSI) :Raz [M]VRAVAL9(MSI) :Raz [M]VRAVAL10(MSI):Raz [M]VRAVAL11(MSI)
 Raz [M]VRAVAL12(MSI):Raz [M]VRAVAL13(MSI):Raz [M]VRAVAL14(MSI)
Endif
End

Subprog VERIF_CPT(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:MHXX])=0 : Local File MSXITEML [MHXX] : Endif
Read [MHXX]MHX0(1)=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",date$,"",NUM,STAT) From SUBANM
 Read [MHXX]MHX0(1)=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-COMPTEUR
 GOK = 0 : End
Endif
End

Subprog CTL_DBL (REFN,CTRN,LIG)
Value Char REFN
Value Char CTRN
Value Integer LIG
Local Integer IND
GOK=1
For IND=0 To [M:MHX0]NBXIT-1
 If IND<>LIG
  If [M:MHX0]REFNUM(IND)=REFN & [M:MHX0]CTRNUM(IND)=CTRN
   GOK=0 : GMESSAGE = mess(2,10722,1)-num$(IND+1) #Matricule/Contrat déjà saisi
   Break
  Endif
 Endif
Next
End

Subprog LOOK_FLDVAL(REFN,CTRN,LIG)
Value Char REFN
Value Char CTRN
Value Integer LIG
Local Integer MSI,MSJ
Local Char    TTBL  (GLONATB)(1..dim(GFLDMS))
Local Char    TABLE (GLONATB)
For MSI = 1 To dim(GFLDMS)
 Read [F:DIC]DIC0 = [M:MHX0]FLDEML(MSI-1)
 If !fstat & [F:DIC]TBL <> "" & [F:DIC]MSFLG = 2 & [F:DIC]ENAFLG = 2 &
&   ([F:DIC]CODACT = "" | func AFNC.ACTIV([F:DIC]CODACT) > 0)
# / 72635
  FILLED = 0
  Case [M:MHX0]SRCOBJ(LIG)
   When "PRF"     : # Profils modèle      - model Profiles
    Default File [HRPFD]
    [G:PFD]currind=1
    [G:PFD]currlen=0
   When "JOT"     : # Emplois type modèle - model standard jobs
    Default File [JOD]
    [G:JOD]currind=1
    [G:JOD]currlen=0
   When "POT"     : # Postes modèle       - model work centers
    Default File [POD]
    [G:POD]currind=1
    [G:POD]currlen=0
   When Default
    FILLED = -1
  Endcase

  If FILLED = 0     : # Objet source = PRF,JOT ou POT
    # niveau Population - Population level
    If !FILLED & dim([M:MHX0]POP) > 0 & [M:MHX0]POP <> ""
     Read [F] =  [M:MHX0]SRCENT(LIG);[M:MHX0]FLDEML(MSI-1);"";"";"";[M:MHX0]POP
     If !fstat
      FILLED = 1
     Endif
    Endif
    # niveau convention collective - CLLCVT level
    If !FILLED & dim([M:MHX0]CLLCVT) > 0 & [M:MHX0]CLLCVT <> ""
     Read [F] =  [M:MHX0]SRCENT(LIG);[M:MHX0]FLDEML(MSI-1);"";"";[M:MHX0]CLLCVT;""
     If !fstat
      FILLED = 1
     Endif
    Endif
    # niveau site - facility level
    If !FILLED & dim([M:MHX0]FCY) > 0 & [M:MHX0]FCY <> ""
     Read [F] =  [M:MHX0]SRCENT(LIG);[M:MHX0]FLDEML(MSI-1);"";FCY;"";""
     If !fstat
      FILLED = 1
     Endif
    Endif
    # niveau société - company level
    If !FILLED & dim([M:MHX0]CPY) > 0 & [M:MHX0]CPY <> ""
     Read [F] =  [M:MHX0]SRCENT(LIG);[M:MHX0]FLDEML(MSI-1);CPY;"";"";""
     If !fstat
      FILLED = 1
     Endif
    Endif
    # niveau dossier - folder level
    If !FILLED
     Read [F] =  [M:MHX0]SRCENT(LIG);[M:MHX0]FLDEML(MSI-1);"";"";"";""
     If !fstat
      FILLED = 1
     Endif
    Endif
  Endif

  If FILLED > 0    : # On a trouvé dans le modèle
   Assign("[M:MHX0]FLDVAL"+num$(MSI-1)+"("+num$(LIG)+")")  With  [F]VALINT
  Else
   # il n'y a pas de modèle ou le champ n'est pas dans le modèle
   # there is no model or the field was not found in the model
 #   72635 /

   MSJ = find([F:DIC]TBL,TTBL(1..dim(GFLDMS)))
  If !MSJ
   TTBL(MSI) = [F:DIC]TBL
   Local File =TTBL(MSI)
   MSJ = MSI
  Endif
  TABLE = TTBL(MSJ) : Gosub DEFAUT From WPDEFTABLE
  [G]currind = 1
  If dim([F]CTRNUM)>0 & TABLE="EMPLOMED"
   Filter [F] Where REFNUM=REFN & (CTRNUM=CTRN | CTRNUM="")
  Elsif dim([F]CTRNUM)>0
   Filter [F] Where REFNUM=REFN & CTRNUM=CTRN
  Else
   Filter [F] Where REFNUM=REFN
  Endif
  Read Last
  If !fstat
   Case [M:MHX0]TYP(MSI-1)
    When 1,2,3,4,5,6
     Assign("[M:MHX0]FLDVAL"+num$(MSI-1)+"("+num$(LIG)+")") With  num$(evalue("[F]"+[M:MHX0]FLDEML(MSI-1)))
    When  7
     Assign("[M:MHX0]FLDVAL"+num$(MSI-1)+"("+num$(LIG)+")") With  evalue("[F]"+[M:MHX0]FLDEML(MSI-1))
   Endcase
  Endif
  Filter [F]
  Endif : # 72635
 Endif
Next
End

$CONTROW
Local Char       VALCONT(250)
#57195
#Local Char       FLDINT(25)
Local Char       FLDINT(30)
Local Char       VALFLDINT(250)
If VALEUR <> "" & [M]CTRRPL(nolign-1) = ""
 # Pas de remplaçant saisi : Champ réservé au remplaçant
 GMESSAGE = mess(11,10722,1)
 zoncou="REFRPL"
 zonsui=zoncou+"("+num$((nolign-1))+")"
 #mkstat=2
 Return
Endif
VALCONT = VALEUR
VALFLDINT = VALEUR
FLDINT  = "[M:MHX0]VALINT"+num$(IROW)+"(nolign-1)"
If VALEUR <> ""
 Call CONTGEN([L]VALCONT,[M:MHX0]OBJET(IROW),[M:MHX0]NOLIBFLD(IROW),[M:MHX0]OBJFLD(IROW)) From SUBMHE
 If mkstat : Return : Endif
 #/FMT
 If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
 Call LECTURE("ATY",[M:MHX0]TYPFLD(IROW),"") From CONTOBJ
 If find([F:ATY]TYPTYP,2,3,4)
  VALFLDINT= vireblc(VALFLDINT,4)
 Else
  Local Integer J , K
  Local Char    COMT(100) , FMT(100)
  VALFLDINT = vireblc(VALFLDINT,2)
  If [F:ATY]TYPTYP=7 & [F:ATY]FORTYP<>""
   FMT = [F:ATY]FORTYP
   Repeat
    K = instr(1,FMT,"[")
    If K
     J = instr(K+1,FMT+"]","]")
     COMT = seg$(FMT,K+1,J-1)
     FMT  = left$(FMT,K-1)+right$(FMT,K+1)
     If left$(VALFLDINT,len(COMT))=COMT
      VALFLDINT = right$(VALFLDINT,len(COMT)+1)
     Elsif seg$(VALFLDINT,K,J-2)=COMT
      VALFLDINT = left$(VALFLDINT,K-1)+right$(VALFLDINT,J-1)
     Endif
    Endif
   Until K=0
  Endif
 Endif
Endif
Assign FLDINT With VALFLDINT
#/FMT

Return
######################################################################################

###############################################################################################################
# Génération Traitement lié à l'hypoyhèse courante
# Ce traitement doit se nommer ainsi : "WPMS"+5+COD    (Chiffre 5 cause ML 485)
###############################################################################################################
#si les doublons dans les remplaçants sont autorisés il faut reviser cette génération
#################################
Subprog GENHYPO(APPLI, CODHYP)
Value Char APPLI ()
Value Char CODHYP()

If clalev ([F:MHX2])=0 : Local File MSXITEML  [MHX2] : Endif
If clalev ([F:VRA])=0  : Local File VARIA      [VRA] : Endif
If clalev ([F:DIC])=0  : Local File DICOEMP    [DIC] : Endif
If clalev ([F:ATB])=0  : Local File ATABLE     [ATB] : Endif
If clalev ([F:ATZ])=0  : Local File ATABZON    [ATZ] : Endif


Local Char TETADO (50) , PROG (30) , FICSRC(250) , SAVREF(GLONEML)
Local Char CONDDEB (25) , CONDFIN (25)
Local Char XTBL (GLONATB) , XABR (GLONABR)
Local Integer L,R,C,OK
Local Integer MAXVRA : MAXVRA = func AFNC.ACTIV("MSV")
Local Integer MAXFLD : MAXFLD = func AFNC.ACTIV("MSF")

Local Char    TFLDEMP (GLONAVA)(1..MAXFLD)
Local Char    TFLDFUL (GLONABR+4+GLONAVA)(1..MAXFLD) #[F:xxxx]xxxxxx
Local Integer TFLDTYP (1..MAXFLD,1..2)

SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)

For [F:MHX2]MHX2 Where COD=CODHYP
 If SAVREF = ""
  TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  PROG = "WPMS5"+[F:MHX2]COD
  FICSRC = filpath("TRT",PROG,"src",APPLI)
  Openo FICSRC , 0
  Wrseq TETADO-mess(5,10485,1)-CODHYP
  Wrseq "###############################################"
  Wrseq "###  REMPLACANTS                              #" : Wrseq
  Wrseq "$HYPOVAR"
  Wrseq "# On ne veut pas traiter le salarié réel"
  Wrseq "If LIGHYPO=0 : Return : Endif"
  #57202
  Wrseq "# On ne veut pas traiter des salariés modèles d'une autre hypothèse"
  Wrseq "If LISHYP(GIHYP)<>LISHYP(LIGHYPO+1) | TYPHYP(GIHYP)<>TYPHYP(LIGHYPO+1) : Return : Endif"

  Wrseq "Case MATRI"
 Endif
 If [F:MHX2]REFRPL <> "" & [F:MHX2]REFRPL <> SAVREF
  Wrseq space$(1)+"When '"+[F:MHX2]REFRPL+"'"
 Endif
 If [F:MHX2]REFRPL <> "" & [F:MHX2]ENAFLG1 = 2
  #74218 Wrseq space$(2)+"If CTR='"+[F:MHX2]CTRRPL+"'"
  Wrseq space$(2)+"If CTR='"+[F:MHX2]CTRRPL+"'& [F:MHX]ORD="+num$([F:MHX2]ORD)
  For R=0 To MAXVRA-1
   If [F:MHX2]VRAVAL(R) <> 0
    Read [F:VRA]VRA0=GCURLEG;[F:MHX2]VRAEML(R)
    If !fstat
     Wrseq space$(3)+format$('K:15X','V_'+[F:VRA]COD)-' ='-num$([F:MHX2]VRAVAL(R))
    Endif
   Endif
  Next
  Wrseq space$(2)+"Endif"
 Endif
 SAVREF = [F:MHX2]REFRPL
Next
If TETADO<>""
 Wrseq space$(1)+"When default"
 Wrseq "Endcase"
 Wrseq "Return"
Endif

SAVREF=""
OK=0
For [F:MHX2]MHX2 Where COD=CODHYP
 If !OK
  Wrseq : Wrseq "###############################################"
  Wrseq "$LIRE"
  Wrseq "Case MATRI"
  OK=1
 Endif
 If [F:MHX2]REFRPL <> "" & [F:MHX2]REFRPL <> SAVREF
  Wrseq space$(1)+"When '"+[F:MHX2]REFRPL+"'"
 Endif
 If [F:MHX2]REFRPL <> "" & [F:MHX2]ENAFLG1 = 2 & [F:MHX2]DATRPL <> [00/00/0000]
  #74218 Wrseq space$(2)+"If CTR='"+[F:MHX2]CTRRPL+"'"
  Wrseq space$(2)+"If CTR='"+[F:MHX2]CTRRPL+"'& [F:MHX]ORD="+num$([F:MHX2]ORD)
  Wrseq space$(3)+"If PERFIN < ["+num$([F:MHX2]DATRPL)+"]"
  Wrseq space$(4)+"OKSIM = 0"
  Wrseq space$(3)+"Else"
  Wrseq space$(4)+"PERDEB = max(PERDEB,["+num$([F:MHX2]DATRPL)+"])"
  Wrseq space$(3)+"Endif"
  Wrseq space$(2)+"Endif"
 Endif
 SAVREF = [F:MHX2]REFRPL
Next
If OK
 Wrseq space$(1)+"When default"
 Wrseq "Endcase"
 Wrseq "Return"
Endif

SAVREF=""
Raz XTBL , XABR
Raz TFLDEMP , TFLDFUL , TFLDTYP
OK=0
For [F:MHX2]MHX2 Where COD=CODHYP
 If !OK
  Wrseq : Wrseq "###############################################"
  Wrseq "$LIRE_SOR"
  Wrseq "Case MATRI"
  OK=1
 Endif
 If [F:MHX2]REFRPL <> "" & [F:MHX2]REFRPL <> SAVREF
  Wrseq space$(1)+"When '"+[F:MHX2]REFRPL+"'"
 Endif
 If [F:MHX2]REFRPL <> "" & [F:MHX2]ENAFLG1 = 2
  #74218 Wrseq space$(2)+"If CTR='"+[F:MHX2]CTRRPL+"'"
  Wrseq space$(2)+"If CTR='"+[F:MHX2]CTRRPL+"'& [F:MHX]ORD="+num$([F:MHX2]ORD)

  ## 57205 date de contrat et date de fin
  Wrseq space$(3)+"[F:HRCTR]CTRDAT = ["+num$([F:MHX2]DATRPL)+"]"
  If [F:MHX2]ENDRPL<>[0/0/0]
   Wrseq space$(3)+"[F:HRCTR]XITDAT = ["+num$([F:MHX2]ENDRPL)+"]"
   Wrseq space$(3)+"[F:HRCTR]XITFNL = 2"
  Endif

  #parcours des champs salarié alimentés et génération au bon format
  For R=0 To MAXFLD-1
   Raz [F:DIC] , [F:ATB] , [F:ATZ] , [F:ATY]
   If [F:MHX2]FLDVAL(R) <> "" & [F:MHX2]FLDVAL(R) <> "0,00"
    #stockage du champ salarié et de son type
    L = find([F:MHX2]FLDEML(R),TFLDEMP(1..MAXFLD))
    If L = 0
     L = R+1
     TFLDEMP(L) = [F:MHX2]FLDEML(R)
     Read [F:DIC]DIC0=TFLDEMP(L)
     #recherche de l'abréviation de la table
     If !fstat & [F:DIC]TBL <> XTBL  : #pour ne pas relire inutilement ATABLE
      XTBL = [F:DIC]TBL
      Read [F:ATB]CODFIC=XTBL
      XABR = [F:ATB]ABRFIC
     Endif
     #recherche du type du champ
     Read [ATZ]CODZONE = [F:DIC]TBL;[F:DIC]FLD
     Read [ATY]CODTYP  = [F:ATZ]CODTYP
     TFLDTYP(L,1) = [F:ATY]TYPTYP
     TFLDTYP(L,2) = [F:ATZ]NOLIB
     TFLDFUL(L) = "[F:"+XABR+"]"+TFLDEMP(L)
    Endif
    If !find("",TFLDFUL(L)) & TFLDTYP(L,1) <> 0
     Case TFLDTYP(L,1)
      When 1 :              #menu local
       C=0
       Repeat C+=1
       Until C > len(mess(0,TFLDTYP(L,2),1)) | mess(C,TFLDTYP(L,2),1) = [F:MHX2]FLDVAL(R)
       If C <= len(mess(0,TFLDTYP(L,2),1))
       #58665 Remplace 15X par 20X
        Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' = '+num$(C)
       Endif
      When 2, 3, 4, 5, 6  : #numérique
       #58665 Remplace 15X par 20X
       Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' ='-func AFNC.TRANSF([F:MHX2]FLDVAL(R),",",".")
      When 8 :              #date
       #58665 Remplace 15X par 20X
       Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' ='-"["+[F:MHX2]FLDVAL(R)+"]"
      When Default :        #alphanumérique
       #58665 Remplace 15X par 20X
       Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' = "'+[F:MHX2]FLDVAL(R)+'"'
     Endcase
    Endif
   Endif
  Next

  Wrseq space$(2)+"Endif"
 Endif
 SAVREF = [F:MHX2]REFRPL
Next
If OK
 Wrseq space$(1)+"When default"
 Wrseq "Endcase"
 Wrseq "Return"
Endif

SAVREF=""
For [F:MHX2]MHX2 Where COD=CODHYP
 If SAVREF = ""
  Wrseq : Wrseq "###############################################"
  Wrseq "###  SORTANTS                                 #" : Wrseq
  Wrseq "$LECTURE"
  Wrseq "Case MATRI"
 Endif
 If [F:MHX2]REFNUM <> SAVREF
  Wrseq space$(1)+"When '"+[F:MHX2]REFNUM+"'"
 Endif
 If [F:MHX2]ENAFLG1 = 2 & [F:MHX2]XITDAT <> [00/00/0000]
  Wrseq space$(2)+"If CTR='"+[F:MHX2]CTRNUM+"'"
  Wrseq space$(3)+"If PERDEB <= ["+num$([F:MHX2]XITDAT)+"] & PERFIN >= ["+num$([F:MHX2]XITDAT)+"]"
  Wrseq space$(4)+"PERFIN = ["+num$([F:MHX2]XITDAT)+"]"
  #57210
  Wrseq space$(4)+"[F:HRCTR]XITDAT = ["+num$([F:MHX2]XITDAT)+"]"
  Wrseq space$(4)+"[F:HRCTR]XITFNL = "+num$(2)
  # fin 57210
  Wrseq space$(3)+"Elsif PERDEB > ["+num$([F:MHX2]XITDAT)+"]"
  Wrseq space$(4)+"OKSIM = 0"
  Wrseq space$(3)+"Endif"
  Wrseq space$(2)+"Endif"
 Endif
 SAVREF = [F:MHX2]REFNUM
Next
If SAVREF <> ""
 Wrseq space$(1)+"When default"
 Wrseq "Endcase"
 Wrseq "Return"
Endif

Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
adxirs = SAVIRS
adxifs = SAVIFS
End
