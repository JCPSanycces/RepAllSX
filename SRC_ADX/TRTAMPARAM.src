#<AdxTL>@(#)8.0.0.0 $Revision$
#
#*********************************************************************
#
#                    PARAMETRE
#
#*********************************************************************
#    Création
#    MWA - 16.03.2005
#
#*********************************************************************
#    Modification
#
# MWA    12.01.2017  119342     Amortissement des plans libres d'un bien en cours selon paramétrage WIPDEP.
#
#*********************************************************************
#             A P P E L A N T
#*********************************************************************
#

#
#########################################################
Subprog VERF_PARAM (PPARAM, PVALEUR, ROK)
#
# - Objet  : Traitement à executer suite à modification d'un paramètre
#

Value    Char    PPARAM
Value    Char    PVALEUR
Variable Integer ROK

Local    Char    L_SELCPY
Local    Integer L_REP

  # Valeur avant modification
  Read [ADW]ADW0=[M:ADWP]CMP;[M:ADWP]FCY;PPARAM
  # Si le paramètre n'est pas modifié on sort
  If ( val(PVALEUR) = val([F:ADW]VALEUR) ) Then :  End :  Endif

  If clalev([F:FAS]) = 0 : Local File FXDASSETS    [FAS] : Endif : # Biens comptables
  If clalev([F:DEP]) = 0 : Local File DEPREC       [DEP] : Endif : # Amortissements
  If ([M:ADWP]CMP <> "") Then
    L_SELCPY = "[F:FAS]CPY=[M:ADWP]CMP"
  Else
    L_SELCPY = "1=1"
  Endif

  #-1 --------------------
  Case PPARAM
    When "WIPDEP"
      # FQ119342
      # Contrôle : Le paramètre peut passer à Non si aucun bien "En cours" du dossier ou de la société
      # n'a eu de l'amortissement sur un plan libre.
      #-2 --------------------
      If ( val(PVALEUR) = G_NON ) Then
        Link [DEP] With [FAS]FAS0=AASREF  As [IML]
        Filter [IML]
&       Where  DPRPLN>=G301LI1 and ( [F:FAS]GACACN=GVML_NIENCOU or [F:FAS]IASACN=GVML_NIENCOU )
&         and  evalue(L_SELCPY) and  DPM<>G_DPMSA
        Read [IML]First
        If !(fstat) Then
          # Impossible : Il existe un bien de nature En cours amorti sur un plan libre
          GMESSAGE = mess(941,7773,1) : mkstat=2 : ROK=0 : End
        Endif
        Filter [IML]
      Endif
      #-2 --------------------
    When "DEROENCOUR"
      # Contrôle : Le paramètre peut passer à Non si aucun bien "En cours" du dossier ou de la société
      # n'a eu de l'amortissement sur le plan fiscal ayant généné de l'amortissement dérogatoire.
      #-2 --------------------
      If ( val(PVALEUR) = G_NON ) Then
        Link [DEP] With [FAS]FAS0=AASREF  As [IML]
        Filter [IML]
&       Where  DPRPLN=G301FIS and ( [F:FAS]GACACN=GVML_NIENCOU or [F:FAS]IASACN=GVML_NIENCOU )
&         and  evalue(L_SELCPY) and  DPM<>G_DPMSA
        Read [IML]First
        If !(fstat) Then
          # Impossible : Il existe un bien de nature En cours amorti fiscalement ayant généré du dérogatoire
          GMESSAGE = mess(615,7773,1) : mkstat=2 : ROK=0 : End
        Endif
        Filter [IML]
      Endif
      # Tous les biens "En cours" vont être positionnés comme étant à calculer. Confirmez-vous ?
      Wrnbox mess(616, 7773, 1) Titled mess(2, 9111, 1)  Using L_REP
      If (L_REP = 2) Then : # Annuler
        mkstat=2 : ROK=0 : End
      Endif
      #-2 --------------------
    When "NBEXESTO"
      # La modification entraîne le positionnement de tous les biens. Confirmez vous ?
      Wrnbox mess(617, 7773, 1)  Titled mess(2, 9111, 1) Using L_REP
      If (L_REP = 2) Then : # Annuler
        mkstat=2 : ROK=0 : End
      Endif
    When "IMLRVEISS"
      # Tous les biens sortis possédant un solde de dépréc. vont être positionnés à calculer  ?
      Wrnbox mess(618, 7773, 1) Titled mess(2, 9111, 1) Using L_REP
      If (L_REP = 2) Then : # Annuler
        mkstat=2 : ROK=0 : End
      Endif
    When "PRVSITUPD"
      # La maj de ce paramètre positionne certains biens comme étant à calculer. Confirmez-vous ?
      Wrnbox mess(619, 7773, 1) Titled mess(2, 9111, 1) Using L_REP
      If (L_REP = 2) Then : # Annuler
        mkstat=2 : ROK=0 : End
      Endif
    When "PCOAMTPMV"
      # Tous les biens sortis  vont être positionnés à calculer  ?
      Wrnbox mess(620, 7773, 1) Titled mess(2, 9111, 1) Using L_REP
      If (L_REP = 2) Then : # Annuler
        mkstat=2 : ROK=0 : End
      Endif
    When Default
  Endcase
  #-1 --------------------


  Global Integer GNBRPARA  : GNBRPARA = 5
  Global Char    GPARLIST(10)(1..GNBRPARA)
  GPARLIST(1) = "DEROENCOUR"
  GPARLIST(2) = "IMLRVEISS"
  GPARLIST(3) = "NBEXESTO"
  GPARLIST(4) = "PRVSITUPD"
  GPARLIST(5) = "PCOTVAPMV"

  If (dim(GUPDPARAM)  <0) Then  : Global Integer GUPDPARAM(1..GNBRPARA)      : Endif
  If (dim(GUPDPARVAL) <0) Then  : Global Char    GUPDPARVAL(10)(1..GNBRPARA)  : Endif

  If (find(PPARAM,GPARLIST)) Then
    GUPDPARAM(find(PPARAM, GPARLIST)) = 1
    GUPDPARVAL(find(PPARAM,GPARLIST))=[F:ADW]VALEUR
  Endif


End

