#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase

Return


$OUVRE
If clalev([F:AWS3])     = 0 : Local File AWRKHISSUI         [AWS3]      : Endif
If clalev([F:ID])       = 0 : Local File EMPLOID            [ID]        : Endif
If clalev([F:ESWD2])    = 0 : Local File ESSWRKFLWDET       [ESWD2]     : Endif

Return

$DEBUT
Local Char WORFKLOWCOD(1)
##Update header icon
#[M]WSTA2 = func ESS_FUNCTIONS.SET_ICON(2)
#[M]WSTADES2 = 2

nolign =0

Filter [F:AWS3] Where DEST = GUSER and FLGSIG =3 and (CODEVT="ESWD" | CODEVT = "ESWDMOD" )
For [F:AWS3]AWS0
  nolign +=1
  If nolign > dim([M:ESWEMP]REFNUM) : Break : Endif
  [M:ESWEMP] = [F:AWS3]
  [M:ESWEMP]WTEXSUI(nolign-1)= func ESS_FUNCTIONS.ESSGROUP([F:AWS3]VALCTX12)


  Filter [F:ESWD2] Where UID = val([F:AWS3]VALCTX5) and MAIREC = 2
  Read [ESWD2] First
  Filter [ESWD2]
  If !fstat
    [M:ESWEMP]STA(nolign-1) = [F:ESWD2]STA
    #[M:ESWEMP]WSTA(nolign-1) = func ESS_FUNCTIONS.SET_ICON([F:ESWD2]STA)
    [L]WORFKLOWCOD = [F:ESWD2]WRK
    [M:ESWEMP]WRKREQ(nolign-1) = func ESS_FUNCTIONS.WORKFLOWSTAT([L]WORFKLOWCOD)
 Endif

  Read [F:ID]ID0 = [F:AWS3]VALCTX1
    If !fstat
    [M:ESWEMP]NAM(nolign-1) = [F:ID]NAM
    [M:ESWEMP]SRN(nolign-1) = [F:ID]SRN
    [M:ESWEMP]REFNUM(nolign-1) = [F:ID]REFNUM
  Endif
  [M:ESWEMP]NBRLIN = nolign
Next
Filter [F:AWS3]
Affzo [M:ESWEMP]1-99
Return



Subprog ESSWRKEMPV(EMP,VALEUR1,DEST,CHRONO,FONCTION)
Value    Char    EMP
Value    Char    VALEUR1
Value    Char    DEST
Value    Char    CHRONO
Value    Char    FONCTION


Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Decimal BASPAG

#Open the employee workflow detail table
If !clalev([F:ESWD2]) : Local File ESSWRKFLWDET [ESWD2] : Endif

#Read the Employee workflow detail record to determine which table/class to update
Filter [F:ESWD2] Where UID = val(VALEUR1) and MAIREC = 2
Read [ESWD2] First
Filter [ESWD2]
If fstat  : End : Endif

Call ESSWRKVIEW(EMP,VALEUR1,[F:ESWD2]CODFIC,PARMSK,SAVACT,BASPAG,DEST,CHRONO,FONCTION)

End

Subprog ESSWRKVIEW(EMP,VALEUR1,CODFIC,PARMSK,SAVACT,BASPAG,DEST,CHRONO,VFONCTION)
Value    Decimal BASPAG
Value    Char    PARMSK
Value    Char    SAVACT
Value    Char    EMP
Value    Char    VALEUR1
Value    Char    CODFIC
Value    Char    DEST
Value    Char    CHRONO
Value    Char    VFONCTION

Local Char PROG(250)
Local Char _WINDOW(GLONFEN)
Local Char _MAINPROCESS(GLONADC)
Local Char _SPEPROCESS(GLONADC)
Local Char _ACTION(GLONACT)

PROG = CODFIC

Case PROG
  When "EMPLOIDPAS"   : Gosub EMPLOIDPAS
  When "EMPLOIDRT"    : Gosub EMPLOIDRT
  When "EMPLOCHD"     : Gosub EMPLOCHD
  When "EMPLOID"      : Gosub EMPLOID
  When "EMPLOIDSA"    : Gosub EMPLOID
  When "EMPLOIDUKI"   : Gosub EMPLOID
Endcase

End


$EMPLOCHD

If VFONCTION = "EMP"
  _WINDOW       = "ESSCHDV"
  _MAINPROCESS  = "ESSCHDV"
  _SPEPROCESS   = "SPEESSCHDV"
  _ACTION       = "ESSCHDV"
Else
   _WINDOW      = "ESSCHDAV"
  _MAINPROCESS  = "ESSCHDAV"
  _SPEPROCESS   = "SPEESSCHDAV"
  _ACTION       = "ESSCHDAV"
Endif

SAVACT = GACTION : GACTION = _ACTION
PARMSK(1) = VALEUR1
PARMSK(2) = DEST
PARMSK(3) = CHRONO
Call SAISIE_NUM(BASPAG,PARMSK,_WINDOW,_MAINPROCESS,_SPEPROCESS) From GSAISIE
GACTION = SAVACT
Return

$EMPLOIDRT

If VFONCTION = "EMP"
  _WINDOW       = "ESSPERCNTV"
  _MAINPROCESS  = "ESPERCNTV"
  _SPEPROCESS   = "SPEESPERCNTV"
  _ACTION       = "ESPERCNTV"
Else
   _WINDOW      = "ESSPERCNTAV"
  _MAINPROCESS  = "ESPERCNTAV"
  _SPEPROCESS   = "SPEESPERCNTAV"
  _ACTION       = "ESPERCNTAV"
Endif

SAVACT = GACTION : GACTION = _ACTION
PARMSK(1) = VALEUR1
PARMSK(2) = DEST
PARMSK(3) = CHRONO
Call SAISIE_NUM(BASPAG,PARMSK,_WINDOW,_MAINPROCESS,_SPEPROCESS) From GSAISIE
GACTION = SAVACT
Return

$EMPLOIDPAS

If VFONCTION = "EMP"
  _WINDOW       = "ESSPASDETV"
  _MAINPROCESS  = "ESPASDETV"
  _SPEPROCESS   = "SPEESPASDETV"
  _ACTION       = "ESPASDETV"
Else
   _WINDOW      = "ESSPASDETAV"
  _MAINPROCESS  = "ESPASDETAV"
  _SPEPROCESS   = "SPEESPASDETAV"
  _ACTION       = "ESPASDETAV"
Endif

SAVACT = GACTION : GACTION = _ACTION
PARMSK(1) = VALEUR1
PARMSK(2) = DEST
PARMSK(3) = CHRONO
Call SAISIE_NUM(BASPAG,PARMSK,_WINDOW,_MAINPROCESS,_SPEPROCESS) From GSAISIE
GACTION = SAVACT
Return

$EMPLOID

If VFONCTION = "EMP"
  _WINDOW       = "ESSEMPV"
  _MAINPROCESS  = "ESSEMPV"
  _SPEPROCESS   = "SPEESSEMPV"
  _ACTION       = "ESSEMPV"
Else
   _WINDOW      = "ESSEMPAV"
  _MAINPROCESS  = "ESSEMPAV"
  _SPEPROCESS   = "SPEESSEMPAV"
  _ACTION       = "ESSEMPAV"
Endif

SAVACT = GACTION : GACTION = _ACTION
PARMSK(1) = VALEUR1
PARMSK(2) = PROG
PARMSK(3) = DEST
PARMSK(4) = CHRONO
Call SAISIE_NUM(BASPAG,PARMSK,_WINDOW,_MAINPROCESS,_SPEPROCESS) From GSAISIE
GACTION = SAVACT
Return

$REFRESH_ESSWRKEMP
Local Integer TOTLINE, I
##This routine is used to refresh the screen after an approval has been made to remove the record(s) from the screen

[L]TOTLINE = [M:ESWEMP]NBRLIN
[L]I = [L]TOTLINE
For nolign = 1 To TOTLINE
  If [M:ESWEMP]WWRK(nolign-1) = "S" #signed
    Dela nolign-1 [M:ESWEMP]NBRLIN
    [L]I-=1
  Endif
Next
[M:ESWEMP]NBRLIN = [L]I
Affzo [M:ESWEMP]1-99
Return

