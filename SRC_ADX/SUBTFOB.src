#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
 When "CREATION"     : Gosub CREATION
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "ANNULE"       : Gosub ANNULE
 When "C_FORFOR"     : Gosub C_FORFOR
 When "AS_FORFOR"    : Gosub AS_FORFOR
 When "FC"           : Gosub FC
 When "CHARGE_LEG"   : Gosub CHARGE_LEG
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "FILGAUCHE"    : Gosub FILGAUCHE  : # 71277
Endcase
Return

$CHARGE_LEG
If [M]FORTYP=21
 OKLEG = 1
Endif
Return

$INICRE
$INIMOD
If GNBLEG<=1 or !OKLEG or !(func AFNC.ACTIV("LEG"))
 [F]LEG = GDOSLEG(1)
Endif
Return

$CREATION
If [M:TFO1]FORTYP = 7
  Call CFGWUS(30,[M:TFO1]FORCOD,0) From CFGLIBE
Endif
Return

$AVANT_MODFIC
If [M:TFO1]FORTYP = 7
  Call CFGWUS(30,[M:TFO1]FORCOD,0) From CFGLIBE
Endif
RETUN

$ANNULE
If [M:TFO1]FORTYP = 7
  Call CFGWUS(30,[M:TFO1]FORCOD,0) From CFGLIBE
Endif
Return

$FILGAUCHE
Case currbox
 When "GAU_CHE":
    # 71277 : Pour ne pas faire apparaître ces valeurs qui ne sont pas reportées en V7
    FILTSUP(0) = '[F:TFO]FORTYP<51 | [F:TFO]FORTYP>52'
 When Default  : Return
Endcase
Return

$C_FORFOR
If [M]FORTYP = 7
  Local Char W_FIC(10)(10)
  W_FIC(0) = "ITMMASTER"
  W_FIC(1) = "ITMFACILIT"
  W_FIC(2) = "ITMMMVT"
  W_FIC(3) = "ITMSALES"
  W_FIC(4) = "ITMBPC"
  W_FIC(5) = "BOM"
  W_FIC(6) = "BOMD"
  W_FIC(7) = "ROUTING"
  W_FIC(8) = "ROUOPE"
  Call CFGCTRFOR(VALEUR,W_FIC,0,0) From CFGLIB
Endif

If [M]FORTYP = 18
   If (instr(1,VALEUR,"ITV]")  | instr(1,VALEUR,"ITS]")| instr(1,VALEUR,"ITH]")  | instr(1,VALEUR,"ITP]"))
      GMESSAGE=mess(247,184,1)
      mkstat = 2
   Endif
Endif
If [M]FORTYP = 29
   If (instr(1,VALEUR,"ITM]")  | instr(1,VALEUR,"ITF]"))
      GMESSAGE=mess(248,184,1)
      mkstat = 2
   Endif
Endif
# VPO Ordres de fabrication "Articles"
If [M]FORTYP = 38
   If (instr(1,VALEUR,"MFG]")  & instr(1,VALEUR,"MFI]"))
      GMESSAGE=mess(332,184,1)
      mkstat = 2
   Endif
Endif
# VPO Ordres de fabrication "Matières"
If [M]FORTYP = 40
   If (instr(1,VALEUR,"MFG]")  & instr(1,VALEUR,"MFM]"))
      GMESSAGE=mess(332,184,1)
      mkstat = 2
   Endif
Endif
Return

$AS_FORFOR
# Filtre sur les tables selon le type de formule
Raz [M]TEXCON
Raz [M]VARSUP
Case [M]FORTYP   # Menu local 213
  When 1 : [M]FLTTAB = "find(ABRFIC,'TLK','ITM','ITS')"
  When 2 : [M]FLTTAB = "find(ABRFIC,'ITM','ITF')"    #   SR gammes opératoires
  When 3 : [M]FLTTAB = "find(ABRFIC,'ITS','SID','SIV','SIH')"
  When 5 : [M]FLTTAB = "find(ABRFIC,'ITM','ITF','ITV','MWC','MWS','BOH','BOD')"
  When 6 : [M]FLTTAB = "find(ABRFIC,'ITM','ITF','ITV','ITH','ITC')"
  When 7 : [M]FLTTAB = "find(ABRFIC,'ITM','ITF','ITV','ITS','BOH','BOD','ROH','ROO')"
           Call CFGSETFOR([M]FORTYP,"","",[M]FLTTAB,[M]TEXCON,[M]VARSUP) From CFGLIB
  When 8 : [M]FLTTAB = "find(ABRFIC,'FCY','ITM','ITF','MFG')"
  When 9 : [M]FLTTAB = "find(ABRFIC,'MWS','ROH','ROO','TRO','ROT','ITM','ITF')"    # llc 10.02 regroupement
  When 10: [M]FLTTAB = "find(ABRFIC,'ITM','ITF','ORD','OPS','MFG','MFI','MFO')"
  When 12: [M]FLTTAB = "find(ABRFIC,'MFG','MFI')"                   # HCB Plan de pesee               070701
  When 13: [M]FLTTAB = "find(ABRFIC,'MFG','STJ')"                   # SR  Réintégration               03.02
  When 14: [M]FLTTAB = "find(ABRFIC,'MFO','ROO')"                   # SR  Plan de suivi des temps     03.02
  When 15: [M]FLTTAB = "find(ABRFIC,'MFI','BOH')"                   # SR  Plan de production          03.02
  When 16: [M]FLTTAB = "find(ABRFIC,'MFM','BOD')"                   # SR  Plan de consommation        03.02
  When 17: [M]FLTTAB = "find(ABRFIC,'ITM','ITF','SRG')"             # HCB Plan de rangement 52838     02.09
  When 18: [M]FLTTAB = "find(ABRFIC,'ITM','ITF')"                   # HCB Inventaire "Articles"      10.03
  When 19: [M]FLTTAB = "find(ABRFIC,'ITM','ITF')"                   # HCB calcul réappro consommation 11 03
  When 20: [M]FLTTAB = "find(ABRFIC,'REO')"                         # HCB Emplacements réapprovisionnables 11 03
  When 22: [M]FLTTAB = "find(ABRFIC,'MFG')"                         # sr  pilotage des plans de suivi 01.05
  When 23: [M]FLTTAB = "find(ABRFIC,'MKO','MTK')"                   # sr  Plan des fiches techniques  05.05
  When 24: [M]FLTTAB = "find(ABRFIC,'STA')"                         # HCB Zones de consommation       07.05
  When 25: [M]FLTTAB = "find(ABRFIC,'STA')"                         # HCB Rupture sur emplacement     07.05
  When 26: [M]FLTTAB = "find(ABRFIC,'SOQ','SOP','SOC','SOH')"       # TS  Commandes à préparer        08.05
  When 27: [M]FLTTAB = "find(ABRFIC,'STO','STL')"                   # HCB Inventaire "Stocks"         09.05
  When 28: [M]FLTTAB = "find(ABRFIC,'STC')"                         # HCB Inventaire "Emplacements"   09.05
  When 29: [M]FLTTAB = "find(ABRFIC,'ITV','ITS','ITP','ITH')"       # HCB Inventaire "Cumuls"         09.05
  When 30: [M]FLTTAB = "find(ABRFIC,'ITM')"                          # HCB Changement categorie"       03.06
  When 31: [M]FLTTAB = "find(ABRFIC,'BOH','ITM','TBO')"
  When 32: [M]FLTTAB = "find(ABRFIC,'ITM','ITF','QLQ')"             # HCB V6CQ              "         11.07
#           [M]VARSUP = "ASW,Réponse"                               # HCB V6CQ              "         11.07
  When 33: [M]FLTTAB = "find(ABRFIC,'SPH','SPD','PRH','SDH')"       # HCB colisage          "         10.08
  When 36: [M]FLTTAB = "find(ABRFIC,'ITM','ITF','ORD','SCO','SCI','SCS','SCM')" # V6 GA Sous-traitance
  When 37: [M]FLTTAB = "find(ABRFIC,'MWS')"                         # VPO Postes de charges                       02.09
  When 38: [M]FLTTAB = "find(ABRFIC,'MFG','MFI')"                   # VPO Ordres de fabrication "Articles"        02.09
  When 39: [M]FLTTAB = "find(ABRFIC,'MFO')"                         # VPO Ordres de fabrication "Opérations"      02.09
  When 40: [M]FLTTAB = "find(ABRFIC,'MFG','MFM')"                   # VPO Ordres de fabrication "Matières"        02.09
  When 41: [M]FLTTAB = "find(ABRFIC,'ITM','ITF')"                   # Articles
  When 42: [M]FLTTAB = "find(ABRFIC,'ITM','ITF','ITW')"             # HCB Inventaire "Articles depots"
  When 43: [M]FLTTAB = "find(ABRFIC,'WRH')"                         # HCB Inventaire Depots
  When 44: [M]FLTTAB = "find(ABRFIC,'MFG')"                         # VPO Ordres de fabrication
  When 45: [M]FLTTAB = "find(ABRFIC,'SOQ','SOP','SOH','ITM','BPC','BPR','VSOQ')" # VPO SCM Commandes
  When 46: [M]FLTTAB = "find(ABRFIC,'VSDQ','ITM','BPC','BPR')"                   # VPO SCM Livraisons/factures
  When 47: [M]FLTTAB = "find(ABRFIC,'SCO','SCI')"                                # GA Ordre Sous-traitance "Articles"
  When 48: [M]FLTTAB = "find(ABRFIC,'SCO','SCS')"                                # GA Ordre Sous-traitance "Service"
  When 49: [M]FLTTAB = "find(ABRFIC,'SCO','SCM')"                                # GA Ordre Sous-traitance "Matières"
  When 50: [M]FLTTAB = "find(ABRFIC,'BPR','BPS','BPC','BPD')"                    # GA Tiers (Fournisseurs, ...)   06.2010
  When 53: [M]FLTTAB = "find(ABRFIC,'ITM','ITS','ITF','ITV')"                    # 71277 : Quantité composants
  When 54: [M]FLTTAB = "find(ABRFIC,'ITM','ITS','ITF','ITV','SBK')"              # 71277 : Quantité composants
  When 56: [M]FLTTAB = "find(ABRFIC,'ITM','ITP','ITF','BPS','PPK')"              # MAE, landed cost
  When 57: [M]FLTTAB = "find(ABRFIC,'LPN')"                                      # hcb X3-92342
Endcase
Return

# 71277 : Pour ne pas faire apparaître ces valeurs qui ne sont pas reportées en V7
$AS_FORTYP
GMENLOC(51)=1 : GMENLOC(52)=1
Return

$FC
