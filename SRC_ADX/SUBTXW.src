######################################
$SETBOUT
If instr(1,GUSRAUZ(1),"S")
 CHAINE += "A"   : # Bouton Supprimer
Endif
Call VIREBOUT(CHAINE,"C") From GOBJET   : # Nouveau
If REP<>"" | GREP<>"" | find(0,AUTSIT(1..[M:TXM2]NBRCOL))
 Call VIREBOUT(CHAINE,"UO") From GOBJET    :# boutons Calcul, Export
Else
 CHMEN += "P"   : # Fonctions / Paramétrage
Endif
Return

######################################
$AVANT_ACT
Case BOUT
 When "E" :   # Enregistrer
  If RECALCUL
   Gosub ENREG
   RECALCUL = 0
  Else
   Raz BOUT   :# pour ne pas executer l'action TXSRCAL
  Endif
Endcase
Return

######################################
$ENREG
Call DEBTRANS From GLOCK
Gosub ENR_TXM
Return

$ENR_TXM
Trbegin [TXM]
GOK = 1
# Enregistrement des valeurs modifiées repérées par [M]UPDCOL(IL)
For IL=0 To [M:TXM1]NBLIG-1
 For IC=1 To 20
  If mid$([M]UPDCOL(IL),IC,1)="1"
   Read [TXM]TXM0 = [M]TXSNAM;[M]VERSION;IL+1;IC;0
   If fstat
    # cas des cellules sans formule
    Gosub WR
    If GOK<1 : Break 2 : Endif
   Else
    Gosub REWR
    If GOK<1 : Break 2 : Endif
   Endif
  Endif
 Next IC
Next IL
If GOK<0   : Goto ROLL_ENR_TXM
Elsif !GOK : Goto AB_ENR_TXM
Endif
Commit
Return

$WR
Raz [F:TXM]
[F:TXM]TXSNAM = [M]TXSNAM
[F:TXM]VERSION = [M]VERSION
[F:TXM]LIG = IL+1
[F:TXM]COL = IC
[F:TXM]IND = 0
[F:TXM]AMTVAL = "0"
ARRONDI = 10^(-val(mid$([M:TXM3]DEC(IL),IC,1)))
[F:TXM]UPDVAL = num$(arr(evalue("[M]AMTVAL"+num$(IC)+"(IL)")*[M]DIVCOL(IC-1),ARRONDI))
Write [TXM]
If fstat
 GOK=0 : Call FSTA("TXM") From GLOCK
Endif
Return

$REWR
# il faut tenir compte du diviseur et du nombre de décimales
ARRONDI = 10^(-val(mid$([M:TXM3]DEC(IL),IC,1)))
FORMULE = num$(arr(evalue("[M]AMTVAL"+num$(IC)+"(IL)")*[M]DIVCOL(IC-1),ARRONDI))
MNT = arr(val([F:TXM]AMTVAL)/[M]DIVCOL(IC-1),ARRONDI)
If FORMULE="0"
 Raz FORMULE
 Assign "[M]AMTVAL"+num$(IC)+"(IL)" With MNT
 [M]UPDCOL(IL) = func SUBTXS.REPCAR([M]UPDCOL(IL),"0",IC)  # on raze la cellule...
 # ...donc on considère que le champ n'est plus modifié
Endif
[F:TXM]UPDVAL = FORMULE
Rewrite [TXM]
If fstat
 GOK=0 : Call FSTA("TXM") From GLOCK
Endif
Return

$ROLL_ENR_TXM
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto ENR_TXM : Endif

$AB_ENR_TXM
Rollback
Return

######################################
$APRES_MODIF
Case left$(COUZON,6)
 When "AMTVAL"
  RECALCUL = 1
  IC = val(right$(COUZON,7))
  IL = nolign
  If !AUTSIT(IC)
   Assign "[M]AMTVAL"+num$(IC)+"("+num$(IL-1)+")" With 0
   Affzo [TXM1] ="[M:TXM1]AMTVAL"+num$(IC)+"("+num$(IL-1)+")"
  Endif
 When "TXSNAM"
# Rien à faire!
Endcase
Return

######################################
$APRES_CHOI
Case REPONSE
 When GSTAANU   :# Supprimer les lignes de la table détail TXSD
   Gosub ANNUL
   REPONSE=0
Endcase
Return

$ANNUL
OK = 1
Call OUINON(mess(28,100,1)-":"-[M]TXSNAM-":"-[M]VERSION,OK) From GESECRAN
If OK<>2 : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR_ANNUL    :# Delete sur plusieurs tables
If GOK<1 : Return : Endif
# On se positionne sur la dernière version du tableau (choix totalement arbitraire)
Gosub LAST_VERS
Return

$TR_ANNUL
GOK = 1
Trbegin [TXM], [TXP], [TXW], [TXX]
 Gosub ANU_VERS
 If GOK<0   : Goto ROLL_TR_ANNUL
 Elsif !GOK : Goto AB_TR_ANNUL
 Endif
Commit
Return

$LAST_VERS
Unlock =SYMBOLE
Filter [TXW] Where LSTGRP=[M]LSTGRP & TXSNAM=[M]TXSNAM
Read [TXW]TXW0 Last
Filter [TXW]
If !fstat
 [M]LSTGRP = [F:TXW]LSTGRP
 [M]TXSNAM = [F:TXW]TXSNAM
 [M]VERSION = [F:TXW]VERSION
Endif
CLECUR1 = [M]TXSNAM
CLECUR2(0) = [M]LSTGRP
CLECUR2(1) = [M]VERSION
Gosub RELIT From GOBJET
Return

$ANU_VERS
GCLE = [M]TXSNAM-[M]VERSION
Delete [TXM] Where TXSNAM=[M:TXM0]TXSNAM & VERSION=[M]VERSION
If fstat=1
 GOK=-1 : GLOCK="$TXSM"-GCLE : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXM",GCLE) From GLOCK : Return
Endif
Delete [TXP] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
If fstat=1
 GOK=-1 : GLOCK="$TXSP"-GCLE : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXP",GCLE) From GLOCK : Return
Endif
Delete [TXW] Where LSTGRP=[M]LSTGRP & TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
If fstat=1
 GOK=-1 : GLOCK="$TXSW"-GCLE : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXW",GCLE) From GLOCK : Return
Endif
Delete [TXX] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
If fstat=1
 GOK=-1 : GLOCK="$TXSV"-GCLE : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXX",GCLE) From GLOCK : Return
Endif
Return

$ROLL_TR_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNUL : Endif

$AB_TR_ANNUL
Rollback
Return

######################################
$EXEBOUT
Case BOUT
 When "U" : Gosub AP_CAL
Endcase
Return

$AP_CAL
If [M:TXM0]RAFFR
 Unlock =SYMBOLE
 CLECUR1 = [M]TXSNAM
 CLECUR2(0) = [M]LSTGRP
 CLECUR2(1) = [M]VERSION
 Gosub RELIT From GOBJET
Endif
Return

######################################
$FIN_ACTION
Case BOUT
  When "E" : Gosub RELIT From GOBJSUB
Endcase
Return

######################################
$AV_IMPR
Read [TXS]TXS1 = [M:TXM0]TXSNAM
If !fstat & [F:TXS]RPTCOD<>""
 [L]REPORT1 = [F:TXS]RPTCOD
Else
 If [F:TXS]NBRCOL<=4
  [L]REPORT1 = "TXSVAL"
 Else
  [L]REPORT1 = "TXSVAL2"
 Endif
Endif
Return

######################################
$APRES_MOD
Return

######################################
## Action SELVERSION
######################################
$SEL_LISTE
Case GACTION
 When "SELVERSION" : Gosub SEL_VERSION
Endcase
Return

$SEL_VERSION
TIT = mess(12,123,1)-mess(126,105,1)   : # Choix version
NBTEX = 0
For [TXW]TXW1 Where TXSNAM=[M]TXSNAM
 NBTEX += 1
 TEX(NBTEX)=[F:TXW]VERSION
 TEXTE(NBTEX)=[F:TXW]VERSION-":"-[F:TXW]VERDES
Next
Return
