            Chgfmt [M:TXM2]COL95    With "-K:15X"
  When 96 : Chgfmt [M:TXM1]AMTVAL96 With "-Nz:14.2"
            Chgfmt [M:TXM3]FRM96    With "-K:250X"
            Chgfmt [M:TXM2]COL96    With "-K:15X"
  When 97 : Chgfmt [M:TXM1]AMTVAL97 With "-Nz:14.2"
            Chgfmt [M:TXM3]FRM97    With "-K:250X"
            Chgfmt [M:TXM2]COL97    With "-K:15X"
  When 98 : Chgfmt [M:TXM1]AMTVAL98 With "-Nz:14.2"
            Chgfmt [M:TXM3]FRM98    With "-K:250X"
            Chgfmt [M:TXM2]COL98    With "-K:15X"
  When 99 : Chgfmt [M:TXM1]AMTVAL99 With "-Nz:14.2"
            Chgfmt [M:TXM3]FRM99    With "-K:250X"
            Chgfmt [M:TXM2]COL99    With "-K:15X"
 Endcase
Next IC
Return

