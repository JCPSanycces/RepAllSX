  When 99  : Chgstl [M:TXM1]AMTVAL99 With "TDB00"
 Endcase
Next IC

For [TXD]TXD1(2) Where TXSNAM=[M:TXM0]TXSNAM : # Une colonne
 IC    = [F:TXD]COL
 IL0   = [F:TXD]LIG-1
 STYL0 = num$([F:TXD]FMTPRN-1)+num$([F:TXD]EFFPRN-1)
 OKCOL = 1
 For [TXD]TXD1
  IL = [F:TXD]LIG-1
  STYL1 = num$([F:TXD]FMTPRN-1)+num$([F:TXD]EFFPRN-1)
  If OKCOL
   If STYL1<>STYL0
    OKCOL = 0
    Gosub ST_CELLULE
    IL1 = IL-1
    For IL=IL0 To IL1
     STYL1 = STYL0
     Gosub ST_CELLULE
    Next IL
   Endif
  Else
   Gosub ST_CELLULE
  Endif
 Next
 If OKCOL
  STYL1 = STYL0
  Gosub ST_COLONNE
 Endif
Next
For IC=1 To [F:TXS]NBRCOL
 For IL=0 To [M:TXM1]NBLIG-1
  If mid$([M:TXM1]UPDCOL(IL),IC,1)="1"   :# est-ce un montant saisi ?
   STYL1 = "RED"
   Gosub ST_CELLULE
  Endif
 Next IL
Next IC
For IC=1 To [F:TXS]NBRCOL
 For IL=1 To [M:TXM1]NBLIG
  If mid$([M:TXM3]DEC(IL-1),IC,1)<>num$([M:TXM1]DECCOL(IC-1))
   Gosub SET_FMTN
   If mid$([M:TXM3]DEC(IL-1),IC,1)<>"0"
    FMT = FMTN+"14."+mid$([M:TXM3]DEC(IL-1),IC,1)+"#"
   Else
    FMT = FMTN+"14#"
   Endif
    Gosub FORMAT_CELLULE
    # Changing "Gosub AFF_CELLULE" with "Affzo [M:TXM1]" after the instruction "Next IC"
    # isn't equivalent. Indeed, column's data are displayed with the number of decimal
    # stored in the last variable "FMT" updated for the same column.
    Gosub AFF_CELLULE
  Endif
 Next IL
Next IC

Return

