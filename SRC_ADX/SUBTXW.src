#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du fichier TXSW
###########################################################################################
# Tables
#   TXSW (clé LSTGRP+TXSNAM+VERSION)     : versions des tableaux
#   TXSM (clé TXSNAM+VERSION+LIG+COL+IND): montants des versions
#   TXSP (clé TXSNAM+VERSION+COL)        : paramètres des colonnes des versions
#   TXSA (clé LSTGRP+TXSNAM)             : paramétrage des tableaux
#   TXSAC(clé TXSNAM+NUMCOL)             : paramétrage des colonnes des tableaux
#   TXSD (clé TXSNAM+LIG+COL)            : formules
#   TXSV (clé TXSNAM+VERSION+VARNAM)     : variables (VERSION à blanc = paramétrage)
#
#
# Ecran   | Intitulé      | Fenetre  | Action     | Fonction |  Traitement          |Objet
#____________________________________________________________________________________________________________

# Jusqu'à 20 colonnes
# TXSM0   | Consultation  |          |            |          |                      |
# TXSM1   | Consultation  | OTXW     |            | GESTXW   | SUBTXW  (Objet)      | TXW : transaction LIMIT
# TXSM2   | Consultation  |          | SELVERSION |          | SUBTXWM (Etiquettes) |
# TXSM3   |               |          |            |          |                      |
# TXSCAL  | Calcul        | DTXSCAL  | TXSCAL     | TXSCAL   | TXSCAL, CALTBD       |

# Plus de 20 colonnes
# TXSM0   | Consultation  |          |            |          |                      |
# TXSMA   | Consultation  | OTXWC    |            | GESTXW   | SUBTXW  (Objet)      | TXW : transaction NOLIMIT
# TXSMB   | Consultation  |          | SELVERSION |          | SUBTXWM (Etiquettes) |
# TXSMC   |               |          |            |          |                      |
# TXSCALA | Calcul        | DTXSCALA | TXSCALA    |          | TXSCAL, CALTBD       |

# TXSGRP  | Calcul groupe | DTXSGRP  | TXSGRP     | TXSGRP   | TXSGRP               |
# TXSCNS  | Détail        | DTXSCNS  | TXSCNS     |          | TXSCNS               |
# TXSANA  | Détail ana    | DTXSANA  | TXSANA     |          | TXSANA               |
# TXSEXP  | Export        | DTXSEXP  | TXSEXP     |          | TXSEXP               |
#         | Recalcul      |          | TXSRCAL    |          | TXSCAL               |
# TXSFMTC | Format        | DTXSFMTC | TXSFMTC    |          | TXSFMTC              |
#
###########################################################################################
Raz GPILCOD, GBIDC1
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETTRANS"    : Gosub SETTRANS
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "AVANT_ACT"   : Gosub AVANT_ACT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FIN_ACTION"  : Gosub FIN_ACTION
 When "AV_IMPRIME"  : Gosub AV_IMPR
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "STYLE"       : Gosub STYLE
 When "ANNULE"      : Gosub ANNULE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "FILTRE"      : Gosub FILTRE
Endcase
Return

######################################
$SETTRANS
If GFLAG="NOLIMIT"
  maxmem = max(int(maxmem/1024),200000)
Endif
Return

######################################
$OUVRE
If clalev([F:FGR])=0  : Local File FACGROUP [FGR] : Endif
If clalev([F:TXA])=0  : Local File TXSAC    [TXA] : Endif
Local Integer NBMAXCOL

If GFLAG="LIMIT"
 NBMAXCOL = 20
Else
 NBMAXCOL = 99
Endif

Local Integer IC, IL, I, LIG, COL, AUTSIT(1..NBMAXCOL), RECALCUL
Local Char    FORMULE(250), SYMBTXW(40), LISVER(10)(200), SOC(GLONCPY), SIT(GLONFCY)
Local Char    FMT(50), FMTN(20) , PAR(80)
Local Decimal MNT, MNTMOD, ARRONDI
Local Integer K, TYPCUMUL
Local Char FORMULE(250), EXPR(250)
Local Char CAR

If dim(GSLTOFFTYP)<=0 : Global Integer GSLTOFFTYP : Endif    : # Type de document office autorisé
Return

######################################
$ANNULE
# Suppression du document office
Call SUPBLOB ("TXW", [F:TXW]TXSNAM, [M:TXM0]VERSION, "") From SUBAON
Return

######################################
$LIENS
Call TEMPON("") From GESECRAN
Gosub CHARGE_COL   : # Chargement intitulé des colonnes, paramètres version et valeur des variables
Gosub CHARGE_PAR   : # Chargement du paramétrage [TXSM3]
Gosub CHARGE_LIG   : # Chargement des valeurs (intitulés + montants) [TXSM1]
Gosub SET_FORMAT
Call TEMPOFF From GESECRAN

# Document bureautique
If clalev([TXS])=0 : Local File TXSA [TXS] : Endif
Read [TXS]TXS1 = [M:TXM0]TXSNAM
GSLTOFFTYP = [F:TXS]TYPDOC

Local Integer LRET_VALUE
Local Char KEYS(250)(0..1)
KEYS(0) = [M:TXM0]TXSNAM
KEYS(1) = [M:TXM0]VERSION
LRET_VALUE=func AOFFDOC.OFFICE_DOC("TXW", "TXSW", "TXSW", KEYS, isomess, "", "", "TDB")
Return

######################################
$FILGAUCHE
If GFLAG="LIMIT"
 FILGAUSUP = "[F:TXS]NBRCOL<=20"
Endif
Return

######################################
$FILTRE
If GFLAG="LIMIT"
 FILTRE = "[F:TXS]NBRCOL<=20"
Endif
Return

######################################
$CHARGE_COL
Read [TXS]TXS1 = [M:TXM0]TXSNAM
If !fstat
 Call LECTEXTRA([M:TXM0]TXSDES,"TXSA","TXSDES",[F:TXS]TXSNAM,"") From ATEXTRA
 [M:TXM0]VERDES = [F:TXW]VERDES

 # Paramètres du calcul
 [M:TXM2]NBPAR = 8
 [M:TXM2]COL0(0) = mess(2,116,1)   :# Société
 [M:TXM2]COL0(1) = mess(5,116,1)   :# Site
 Call TEXTE(828,[M:TXM2]COL0(2)) From OBJDIV   :# Début
 [M:TXM2]COL0(3) = mess(65,123,1)   :# Fin
 [M:TXM2]COL0(4) = mess(124,105,1)  :# Dev sélection
 [M:TXM2]COL0(5) = mess(125,105,1)  :# Dev impression
 [M:TXM2]COL0(6) = mess(21,105,1)   :# Type de cours
 [M:TXM2]COL0(7) = mess(50,104,1)   :# Montant
 For I=1 To NBMAXCOL
  AUTSIT(I) = 1
 Next I
 For [TXP]TXP0 Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
  COL = [F:TXP]COL
  AUTSIT(COL)=1
  Read [TXA]TXA0=[M]TXSNAM;COL
  If !fstat & [F:TXA]COLNUM=""
   SOC = [F:TXP]CPY : SIT = [F:TXP]FCY
  Endif
  If GUSRFCY(1)<>"\"
   Gosub AUTORIS
  Endif
  I=0 :  Assign "[M:TXM2]COL"+num$(COL)+"(I)" With [F:TXP]CPY
  I+=1 : Assign "[M:TXM2]COL"+num$(COL)+"(I)" With [F:TXP]FCY
  I+=1
  If [F:TXP]STRDAT<>[0/0/0]
   Assign "[M:TXM2]COL"+num$(COL)+"(I)" With format$("D:"+GFMDAT4,[F:TXP]STRDAT)
  Endif
  I+=1
  If [F:TXP]ENDDAT<>[0/0/0]
   Assign "[M:TXM2]COL"+num$(COL)+"(I)" With format$("D:"+GFMDAT4,[F:TXP]ENDDAT)
  Endif
  I+=1 : Assign "[M:TXM2]COL"+num$(COL)+"(I)" With [F:TXP]CURSEL
  I+=1 : Assign "[M:TXM2]COL"+num$(COL)+"(I)" With [F:TXP]CURPRN
  I+=1
  If [F:TXP]TYPRAT=0
   Assign "[M:TXM2]COL"+num$(COL)+"(I)" With mess(1,43,1)
  Else
   Assign "[M:TXM2]COL"+num$(COL)+"(I)" With mess([F:TXP]TYPRAT,202,1)
  Endif
  I+=1
  If [F:TXP]TYPMNT<>0
   Assign "[M:TXM2]COL"+num$(COL)+"(I)" With mess([F:TXP]TYPMNT,2665,1)
  Endif
  [M]DIVMES(COL-1) = [F:TXP]NAMCOL
  Call LECTEXTRA([M:TXM1]NAMCOL(COL-1),"TXSAC","NAMCOL",[M:TXM0]TXSNAM,num$(COL)) From ATEXTRA
# Feature FINPRODUCTREQ 59640 - en cours
   [M]DIVMES(COL-1) =[M:TXM1]NAMCOL(COL-1)
#
 Next
 [M:TXM2]NBRCOL = COL

 # Valeurs des variables
 Raz nolign
 For [TXX]TXX0 Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
  nolign += 1
  [M:TXM2] = [F:TXX]
 Next
 [M:TXM1]NBLIG  = [F:TXS]NBLIG

 # Options d'affichage (diviseur, nb de décimales)
 Raz [M:TXM1]DIVCOL, I

 For [TXA]TXA0 Where TXSNAM=[M]TXSNAM
  # Diviseur
  If I<=[M:TXM2]NBRCOL-1
   [M:TXM1]DIVCOL(I) = [F:TXA]DIVCOL
  Endif
  # Format d'affichage des montants
  [M:TXM1]SAICOL(I) = [F:TXA]SAICOL
  [M:TXM1]DECCOL(I) = [F:TXA]DECCOL
  If [F:TXA]DECCOL<>0
   [M:TXM1]FORMAT(I) = "14."+num$([F:TXA]DECCOL)+"#"
  Else
   [M:TXM1]FORMAT(I) = "14#"
  Endif
  I +=1
 Next

 # 1ère colonne = Intitulé (mess(30,109,1)), Paramètre (mess(81,123,1))
 If GFLAG="LIMIT"
  Titcol [M:TXM1]NBLIG mess(30,109,1),
&   [M]DIVMES(0),  [M]DIVMES(1),  [M]DIVMES(2),  [M]DIVMES(3),  [M]DIVMES(4),  [M]DIVMES(5)
& , [M]DIVMES(6),  [M]DIVMES(7),  [M]DIVMES(8),  [M]DIVMES(9),  [M]DIVMES(10), [M]DIVMES(11)
& , [M]DIVMES(12), [M]DIVMES(13), [M]DIVMES(14), [M]DIVMES(15), [M]DIVMES(16), [M]DIVMES(17)
& , [M]DIVMES(18), [M]DIVMES(19)
  Titcol [M:TXM2]NBPAR mess(81,123,1),
&   [M]DIVMES(0),  [M]DIVMES(1),  [M]DIVMES(2),  [M]DIVMES(3),  [M]DIVMES(4),  [M]DIVMES(5)
& , [M]DIVMES(6),  [M]DIVMES(7),  [M]DIVMES(8),  [M]DIVMES(9),  [M]DIVMES(10), [M]DIVMES(11)
& , [M]DIVMES(12), [M]DIVMES(13), [M]DIVMES(14), [M]DIVMES(15), [M]DIVMES(16), [M]DIVMES(17)
& , [M]DIVMES(18), [M]DIVMES(19)
  Titcol [M:TXM3]NBLIG2 mess(30,109,1),
&   [M]NAMCOL(0),  [M]NAMCOL(1),  [M]NAMCOL(2),  [M]NAMCOL(3),  [M]NAMCOL(4)
& , [M]NAMCOL(5),  [M]NAMCOL(6),  [M]NAMCOL(7),  [M]NAMCOL(8),  [M]NAMCOL(9)
& , [M]NAMCOL(10), [M]NAMCOL(11), [M]NAMCOL(12), [M]NAMCOL(13), [M]NAMCOL(14)
& , [M]NAMCOL(15), [M]NAMCOL(16), [M]NAMCOL(17), [M]NAMCOL(18), [M]NAMCOL(19)
 Else
  Titcol [M:TXM1]NBLIG mess(30,109,1),
&   [M]DIVMES(0),  [M]DIVMES(1),  [M]DIVMES(2),  [M]DIVMES(3),  [M]DIVMES(4),  [M]DIVMES(5)
& , [M]DIVMES(6),  [M]DIVMES(7),  [M]DIVMES(8),  [M]DIVMES(9),  [M]DIVMES(10), [M]DIVMES(11)
& , [M]DIVMES(12), [M]DIVMES(13), [M]DIVMES(14), [M]DIVMES(15), [M]DIVMES(16), [M]DIVMES(17)
& , [M]DIVMES(18), [M]DIVMES(19), [M]DIVMES(20), [M]DIVMES(21), [M]DIVMES(22), [M]DIVMES(23)
& , [M]DIVMES(24), [M]DIVMES(25), [M]DIVMES(26), [M]DIVMES(27), [M]DIVMES(28), [M]DIVMES(29)
& , [M]DIVMES(30), [M]DIVMES(31), [M]DIVMES(32), [M]DIVMES(33), [M]DIVMES(34), [M]DIVMES(35)
& , [M]DIVMES(36), [M]DIVMES(37), [M]DIVMES(38), [M]DIVMES(39), [M]DIVMES(40), [M]DIVMES(41)
& , [M]DIVMES(42), [M]DIVMES(43), [M]DIVMES(44), [M]DIVMES(45), [M]DIVMES(46), [M]DIVMES(47)
& , [M]DIVMES(48), [M]DIVMES(49), [M]DIVMES(50), [M]DIVMES(51), [M]DIVMES(52), [M]DIVMES(53)
& , [M]DIVMES(54), [M]DIVMES(55), [M]DIVMES(56), [M]DIVMES(57), [M]DIVMES(58), [M]DIVMES(59)
& , [M]DIVMES(60), [M]DIVMES(61), [M]DIVMES(62), [M]DIVMES(62), [M]DIVMES(64), [M]DIVMES(65)
& , [M]DIVMES(66), [M]DIVMES(67), [M]DIVMES(68), [M]DIVMES(69), [M]DIVMES(70), [M]DIVMES(71)
& , [M]DIVMES(72), [M]DIVMES(73), [M]DIVMES(74), [M]DIVMES(75), [M]DIVMES(76), [M]DIVMES(77)
& , [M]DIVMES(78), [M]DIVMES(79), [M]DIVMES(80), [M]DIVMES(81), [M]DIVMES(82), [M]DIVMES(83)
& , [M]DIVMES(84), [M]DIVMES(85), [M]DIVMES(86), [M]DIVMES(87), [M]DIVMES(88), [M]DIVMES(89)
& , [M]DIVMES(90), [M]DIVMES(91), [M]DIVMES(92), [M]DIVMES(93), [M]DIVMES(94), [M]DIVMES(95)
& , [M]DIVMES(96), [M]DIVMES(97), [M]DIVMES(98)
  Titcol [M:TXM2]NBPAR mess(81,123,1),
&   [M]DIVMES(0),  [M]DIVMES(1),  [M]DIVMES(2),  [M]DIVMES(3),  [M]DIVMES(4),  [M]DIVMES(5)
& , [M]DIVMES(6),  [M]DIVMES(7),  [M]DIVMES(8),  [M]DIVMES(9),  [M]DIVMES(10), [M]DIVMES(11)
& , [M]DIVMES(12), [M]DIVMES(13), [M]DIVMES(14), [M]DIVMES(15), [M]DIVMES(16), [M]DIVMES(17)
& , [M]DIVMES(18), [M]DIVMES(19), [M]DIVMES(20), [M]DIVMES(21), [M]DIVMES(22), [M]DIVMES(23)
& , [M]DIVMES(24), [M]DIVMES(25), [M]DIVMES(26), [M]DIVMES(27), [M]DIVMES(28), [M]DIVMES(29)
& , [M]DIVMES(30), [M]DIVMES(31), [M]DIVMES(32), [M]DIVMES(33), [M]DIVMES(34), [M]DIVMES(35)
& , [M]DIVMES(36), [M]DIVMES(37), [M]DIVMES(38), [M]DIVMES(39), [M]DIVMES(40), [M]DIVMES(41)
& , [M]DIVMES(42), [M]DIVMES(43), [M]DIVMES(44), [M]DIVMES(45), [M]DIVMES(46), [M]DIVMES(47)
& , [M]DIVMES(48), [M]DIVMES(49), [M]DIVMES(50), [M]DIVMES(51), [M]DIVMES(52), [M]DIVMES(53)
& , [M]DIVMES(54), [M]DIVMES(55), [M]DIVMES(56), [M]DIVMES(57), [M]DIVMES(58), [M]DIVMES(59)
& , [M]DIVMES(60), [M]DIVMES(61), [M]DIVMES(62), [M]DIVMES(62), [M]DIVMES(64), [M]DIVMES(65)
& , [M]DIVMES(66), [M]DIVMES(67), [M]DIVMES(68), [M]DIVMES(69), [M]DIVMES(70), [M]DIVMES(71)
& , [M]DIVMES(72), [M]DIVMES(73), [M]DIVMES(74), [M]DIVMES(75), [M]DIVMES(76), [M]DIVMES(77)
& , [M]DIVMES(78), [M]DIVMES(79), [M]DIVMES(80), [M]DIVMES(81), [M]DIVMES(82), [M]DIVMES(83)
& , [M]DIVMES(84), [M]DIVMES(85), [M]DIVMES(86), [M]DIVMES(87), [M]DIVMES(88), [M]DIVMES(89)
& , [M]DIVMES(90), [M]DIVMES(91), [M]DIVMES(92), [M]DIVMES(93), [M]DIVMES(94), [M]DIVMES(95)
& , [M]DIVMES(96), [M]DIVMES(97), [M]DIVMES(98)
  Titcol [M:TXM3]NBLIG2 mess(30,109,1),
&   [M]NAMCOL(0),  [M]NAMCOL(1),  [M]NAMCOL(2),  [M]NAMCOL(3),  [M]NAMCOL(4),  [M]NAMCOL(5)
& , [M]NAMCOL(6),  [M]NAMCOL(7),  [M]NAMCOL(8),  [M]NAMCOL(9),  [M]NAMCOL(10), [M]NAMCOL(11)
& , [M]NAMCOL(12), [M]NAMCOL(13), [M]NAMCOL(14), [M]NAMCOL(15), [M]NAMCOL(16), [M]NAMCOL(17)
& , [M]NAMCOL(18), [M]NAMCOL(19), [M]NAMCOL(20), [M]NAMCOL(21), [M]NAMCOL(22), [M]NAMCOL(23)
& , [M]NAMCOL(24), [M]NAMCOL(25), [M]NAMCOL(26), [M]NAMCOL(27), [M]NAMCOL(28), [M]NAMCOL(29)
& , [M]NAMCOL(30), [M]NAMCOL(31), [M]NAMCOL(32), [M]NAMCOL(33), [M]NAMCOL(34), [M]NAMCOL(35)
& , [M]NAMCOL(36), [M]NAMCOL(37), [M]NAMCOL(38), [M]NAMCOL(39), [M]NAMCOL(40), [M]NAMCOL(41)
& , [M]NAMCOL(42), [M]NAMCOL(43), [M]NAMCOL(44), [M]NAMCOL(45), [M]NAMCOL(46), [M]NAMCOL(47)
& , [M]NAMCOL(48), [M]NAMCOL(49), [M]NAMCOL(50), [M]NAMCOL(51), [M]NAMCOL(52), [M]NAMCOL(53)
& , [M]NAMCOL(54), [M]NAMCOL(55), [M]NAMCOL(56), [M]NAMCOL(57), [M]NAMCOL(58), [M]NAMCOL(59)
& , [M]NAMCOL(60), [M]NAMCOL(61), [M]NAMCOL(62), [M]NAMCOL(63), [M]NAMCOL(64), [M]NAMCOL(65)
& , [M]NAMCOL(66), [M]NAMCOL(67), [M]NAMCOL(68), [M]NAMCOL(69), [M]NAMCOL(70), [M]NAMCOL(71)
& , [M]NAMCOL(72), [M]NAMCOL(73), [M]NAMCOL(74), [M]NAMCOL(75), [M]NAMCOL(76), [M]NAMCOL(77)
& , [M]NAMCOL(78), [M]NAMCOL(79), [M]NAMCOL(80), [M]NAMCOL(81), [M]NAMCOL(82), [M]NAMCOL(83)
& , [M]NAMCOL(84), [M]NAMCOL(85), [M]NAMCOL(86), [M]NAMCOL(87), [M]NAMCOL(88), [M]NAMCOL(89)
& , [M]NAMCOL(90), [M]NAMCOL(91), [M]NAMCOL(92), [M]NAMCOL(93), [M]NAMCOL(94), [M]NAMCOL(95)
& , [M]NAMCOL(96), [M]NAMCOL(97), [M]NAMCOL(98)
 Endif
Endif
For I=0 To min(NBMAXCOL,20)-1
 If [M:TXM1]DIVCOL(I) = 0
  [M:TXM1]DIVCOL(I) = 1   :# pour éviter la division/0
 Endif
Next I
Return

######################################
$AUTORIS    :# utilisé aussi dans trt TXSCAL
If SIT<>""
 If GUSRFCY(1)<>"\" & !find(SIT,GUSRFCY(1..GNBAUZ))
  AUTSIT(COL)=0
 Endif
Else
 For [FGR]FGR0 Where CPY=SOC
  SIT = [F:FGR]FCY
  If GUSRFCY(1)<>"\" & !find(SIT,GUSRFCY(1..GNBAUZ))
   AUTSIT(COL)=0 : Break
  Endif
 Next
Endif
Return

######################################
$CHARGE_LIG
# Valeurs. IND=0 : montant total de la cellule
Filter [TXM] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION & LIG>0 & IND=0
For [TXM]TXM0(3)
 IL = [F:TXM]LIG-1
 [M]UPDCOL(IL)=string$(99,"0")
 For [TXM]TXM0
  IC = [F:TXM]COL
  If IC
   If AUTSIT(IC)   :# pour cette colonne IC, on peut visualiser tous les sites
    ARRONDI = 10^(-val(mid$([M:TXM3]DEC(IL),IC,1)))
    MNT = arr(val([F:TXM]AMTVAL)/[M]DIVCOL(IC-1),ARRONDI)
    MNTMOD = arr(val([F:TXM]UPDVAL)/[M]DIVCOL(IC-1),ARRONDI)
    Gosub AFF
   Endif
  Else
   If [F:TXM]ACCINF<>""
    [M:TXM1]INTIT(IL) = [F:TXM]ACCINF
   Else
    Call LECTEXTRA([M:TXM1]INTIT(IL),"TXSD","DES",[F:TXM]TXSNAM,num$(IL+1)) From ATEXTRA
   Endif
  Endif
 Next
Next
Filter [TXM]
Return

######################################
$AFF
If MNTMOD<>0
  Assign "[M]AMTVAL"+num$(IC)+"(IL)" With MNTMOD
 [M]UPDCOL(IL) = func SUBTXS.REPCAR([M]UPDCOL(IL),"1",IC)
Else
  Assign "[M]AMTVAL"+num$(IC)+"(IL)" With MNT
Endif
Return

######################################
$TRT_FORM
CAR = left$(EXPR,1)
If CAR="-"
 EXPR = right$(EXPR,2)
 Goto TRT_FORM
Endif
If find(CAR,"L","R")   :# syntaxe de type cumul
 TYPCUMUL = 1
Endif
Return

######################################
$CHARGE_PAR
# Lignes
For [TXD]TXD0 Where TXSNAM=[M:TXM0]TXSNAM
 IC = [F:TXD]COL
 IL = [F:TXD]LIG-1
 Assign "[M:TXM3]FRM"+num$(IC)+"(IL)" With [F:TXD]FRM
 If IC>0
  [M:TXM3]CEN(IL) = func SUBTXS.REPCAR([M:TXM3]CEN(IL),num$([F:TXD]CEN),IC)
  [M:TXM3]DEC(IL) = func SUBTXS.REPCAR([M:TXM3]DEC(IL),num$([F:TXD]DECCOL),IC)
  If [F:TXD]FRM<>""
   FORMULE=[F:TXD]FRM
   TYPCUMUL = 0
   While FORMULE<>""
    K = instr(1,FORMULE," ")
    If K
     EXPR = left$(FORMULE,K-1) : FORMULE = vireblc(right$(FORMULE,K+1),2)
    Else
     EXPR = FORMULE : FORMULE = ""
    Endif
    Gosub TRT_FORM
    If TYPCUMUL : Break : Endif
   Wend
   If !TYPCUMUL :  [M:TXM1]NONAFF(IL)="" : Endif
  Endif
 Else
  [M:TXM1]INTIT(IL) = [F:TXD]FRM
 Endif
Next
[M:TXM3]NBLIG2 = [M:TXM1]NBLIG
For IL=1 To [M:TXM3]NBLIG2
 Call LECTEXTRA([M:TXM3]FRM0(IL-1),"TXSD","DES",[M:TXM0]TXSNAM,num$(IL)) From ATEXTRA
Next IL
Return

