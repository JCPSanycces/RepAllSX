######################################
$SET_FMTN
Case [M:TXM1]SAICOL(IC-1)
 When 2       : FMTN = "NP3z:"
 When 3       : FMTN = "-N3z:"
 When Default : FMTN = "N3z:"
Endcase
Return

######################################
$SET_FORMAT
For IC=1 To [F:TXS]NBRCOL
