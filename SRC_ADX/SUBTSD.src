#  GMESSAGE = mess(248,191,1)
#  mkstat = 2
#Endif

End
######################################################################################
# Contrôle de la longueur du compteur
######################################################################################
$CTL_CODNUM

If [F:ANM]CODNUM <> VALEUR
   Read [ANM]ANM0 = VALEUR
   If fstat Raz [F:ANM] Endif
Endif

# Contrôle de la cohérence de la législation entre le type de livraison et le compteur
## SAM 121563 JUCON 20/02/2017) wrong control by legislation
#If [F:ANM]LEG<>"" & [F:ANM]LEG<>[M:TSD1]LEG
#    GMESSAGE=mess(184,100,1)-VALEUR-mess(74,127,1)-"("
#    If [M:TSD1]LEG<>""
#      GMESSAGE+=[F:ANM]LEG-"<>"-[M:TSD1]LEG+")"
#    Else
#      GMESSAGE+=[F:ANM]LEG-"<>"-mess(91,187,1)+")"
#    Endif
#    mkstat=1 : End
#Endif

If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > GLONVCR
   GERR=1
   GMESSAGE = mess(223,199,1)
   mkstat = 1
Endif

Return
######################################################################################
Subprog CONTTSD(COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,PSDHCAT,CPY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Integer PSDHCAT
Value    Char    CPY


Local    Integer CAS
Local    Char    OPTIONS(30)

If GFONCTION = "GESTSD" | COD="" : End : Endif

If clalev([F:TSD]) =0 : Local File TABSDHTYP [TSD] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#Pour déterminer les options de sélection

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

CAS = 1 : # Legislation is empty

#--CPO 71937
#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If clalev([F:CPY])=0  : Local File COMPANY  [CPY]  : Endif :#--CPO 71937
If clalev([F:FCY])=0  : Local File FACILITY [FCY]  : Endif :#--CPO 71937
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
If [L]FCY<>""
If [F:FCY]FCY<>[L]FCY
Read [F:FCY]FCY0=[L]FCY
If fstat : Raz [F:FCY] Endif
Endif
If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
Endif
If [L]CPY<>""
If [F:CPY]CPY<>[L]CPY
Read [F:CPY]CPY0=[L]CPY
If fstat : Raz [F:CPY] Endif
Endif
[L]LEG=[F:CPY]LEG
Endif
Endif
#--/CPO

If LEG<>""
 Read [TSD]TSD0=[L]COD;[L]LEG
 If fstat
  Read [TSD]TSD0=[L]COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [TSD]TSD0(1)=[L]COD
 If !fstat
  LEG = [F:TSD]LEG
  CAS = 2
 Endif
Endif
If fstat
 Filter [TSD] Where SDHTYP=[L]COD
 Look [TSD]TSD0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [TSD]
 mkstat = 2 : End
Endif

# X3-1152 : Non invoiceable deliveries
#--Contrôle par catégorie
#If PSDHCAT<4 and PSDHCAT<>[F:TSD]SDHCAT
If (PSDHCAT<4 and PSDHCAT<>[F:TSD]SDHCAT) or (PSDHCAT=5 & [F:TSD]SDHCAT<>4 )
  # X3-1152 : Non invoiceable deliveries
  GMESSAGE = [L]COD-":"-mess(249,191,1)- mess(PSDHCAT*(PSDHCAT<4)+4*(PSDHCAT=5),490,1)  # FGR 03/03/2015 : X3SUIVI106635 ajout de '[L]COD-":"'
  # X3-1152 : Non invoiceable deliveries
  mkstat = 2 : End
Endif
# X3-1152 : Non invoiceable deliveries

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GFY de TABSDHTYP, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TSD]GFY<>""
  #--CPO 71937
  If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
Read [AGF]AGF0=[F:TSD]GFY
If !fstat
  If [F:AGF]FLGLEG=2
    #--Société
If [F:TSD]GFY<>[L]CPY
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TSD]GFY : # Réservé au groupe de société
          mkstat = 2 : End
Endif
  Elsif [F:AGF]FLGCPY=2
  #--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TSD]GFY;[L]CPY
        If fstat
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TSD]GFY : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TSD]GFY<>"" and LEG<>""
Call CTLGFYLEG([F:TSD]GFY,LEG,"","") From TRTVENCTL
If mkstat : End : Endif
Endif
#--Contrôle de cohérence entre le groupe passé en paramètre et la législation du type de livraison à contrôler
If GROUPE<>"" and [F:TSD]LEG<>""
Call CTLGFYLEG(GROUPE,[F:TSD]LEG,"","") From TRTVENCTL
If mkstat : End : Endif
Endif
#--Contrôle de la cohérence entre le groupe passé en param et celui du type de livraison courant
#--uniquement si le groupe passé est renseigné
#--uniquement si pas de contexte site ou société !
#--Il faut que le groupe de la taxes et celui du paramétrage aient au moins une soc en commun
If GROUPE<>""
If CPY="" & FCY="" & [F:TSD]GFY<>"" & [F:TSD]GFY<>GROUPE
  #--Les groupes doivent avoir au moins une société en commun
  Gosub CTLGFYGRP
If mkstat : End : Endif
Endif
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=[L]CODMSK;[L]CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
 Call CONTROLE("TSD",OPTIONS,LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("TSD",OPTIONS,"",COD,mkstat) From CONTOBJ
Endif

End
##################################################################################
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TSD]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTSDZGRP"
    Local File =SZVIEW [TSDZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TSDZ]TSDZ0 = [L]GROUPE;[F:TSD]SDHTYP;[F:TSD]GFY;[F:TSD]LEG
  If fstat
  GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TSD]GFY-":"-mess(178,187,1)
  mkstat=1
  Return
  Endif
Else
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTSDYGRP"
    Local File =SZVIEW [TSDY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TSDY]TSDY0 = [L]GROUPE;[F:TSD]SDHTYP;[F:TSD]GFY;[F:TSD]LEG
  If fstat
  GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TSD]GFY-":"-mess(178,187,1)
  mkstat=1
  Return
  Endif
Endif
Return
######################################################################################
## Tunnel Type de livraison
Subprog TUNTSD(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer TOKILL

TOKILL = 0
If dim(VCOD)<1
  Global Char VCOD(GLONTSD)
  TOKILL = 1
Endif

# To update the TSD code after the tunnel order
VCOD = COD
If clalev([F:TSD])=0 : Local File TABSDHTYP [TSD] : Endif
If GNBLEG=1
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
  LEG = GCURLEG
#--If LEG="" then firstly we search a TSD record with LEG="" secondly a TSD record with TSD<>""
Elsif LEG=""
  Read [TSD]TSD0 = VCOD;[L]LEG
  If fstat
    Read [TSD]TSD0(1)=VCOD
    If !fstat
      LEG = [F:TSD]LEG
    Endif
  Endif
Endif

Read [TSD]TSD0 = [L]COD;[L]LEG
If fstat : LEG = "" : Endif

Call OBJET("TSD",[L]LEG,VCOD) From GOBJET

COD = VCOD
If TOKILL : Kill VCOD : Endif

End
######################################################################################
Subprog VERF_PARAM(PPARAM,PVALEUR,POK)
Value Char PPARAM     # Nom du paramètre en cours de saisie
Value Char PVALEUR    # Valeur saisie à contrôler
Variable Integer POK  # 1 si contrôle satisfait, 0 si saisie incorrecte

If PVALEUR="" End Endif

If clalev([F:TSD])=0 : Local File TABSDHTYP [TSD] : Endif

Local Char    FCY(GLONFCY),SAVE_GCURFCY( GLONFCY)
Local Char    CPY(GLONCPY),SAVE_GSOCIETE(GLONCPY)
Local Char    LEG(GLONADI)
Local Integer CAT
Local Integer WNOL
Local Integer ERR

[L]SAVE_GCURFCY = GCURFCY
[L]SAVE_GSOCIETE= GSOCIETE

If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PGT
  FCY  = [M:ADWP]FCY : GCURFCY = FCY
  CPY  = [M:ADWP]CMP : GSOCIETE= CPY
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Else
    LEG = GDOSLEG
  Endif
  #--Catégorie livr. en fonction du nom du paramètre
  WNOL = nolign-1

  # X3-1152 : Non invoiceable deliveries
  CAT  = 4
  #CAT  = 5
  # X3-1152 : Non invoiceable deliveries

  #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #If WNOL>=0
  #  Case [M:ADWP]PARAM(WNOL)
  #    When "SDHTYPNOR" : CAT=1
  #    When "SDHTYPLND" : CAT=2
  #    When "SDHTYPSCO" : CAT=3
  #    When Default     : CAT=4   :#--Toutes catégories
  #  Endcase
  #Endif
  #--Initialisation de législation
  If [L]LEG=""
    If [L]FCY<>""
      Call LEC_FCY([L]FCY) From CPTLEC
      Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
      GSOCIETE = [F:FCY]LEGCPY
      [L]LEG = [F:CPY]LEG
    Elsif [L]CPY<>""
      Call LEC_CPY([L]CPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Endif
  Endif
  If [L]LEG=""
    [L]LEG = GCURLEG
  Endif
  #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #Call CONTTSD(PVALEUR,LEG,"","",FCY,"",CAT,CPY)
  Call CONTTSD(PVALEUR,LEG,"MULTILEGADP",PPARAM,FCY,"",CAT,CPY)
  If mkstat : POK=0 : Endif
Endif

GCURFCY = [L]SAVE_GCURFCY
GSOCIETE= [L]SAVE_GSOCIETE

End


######################################################
## $SELTSD
######################################################
$SELTSD
If clalev([F:TSD])=0  : Local File TABSDHTYP  [TSD] : Endif

If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection
If clalev([F:AGF])=0  : Local File AGRPFCY   [AGF] : Endif :#--CPO 71937

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)
Local Char    GRP(GLONAGC)
Local Integer CAT
Local Integer WNOL
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

#--CPO 71937 Pour déterminer les options de sélection
If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif
Local Char CODMSK   (GLONAMK)
Local Char CHAMPCOD (GLONAVA)
CODMSK  =PARAM(6)
CHAMPCOD=PARAM(7)
#--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
#--On charge les options définies sur le type de données du champ du masque
#OPTIONS=""
#If CODMSK<>"" & CHAMPCOD<>""
#  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
#  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
#Endif
#--/CPO
#--------------------------------------------------------------------------------------------------
If GFONCTION = "GESTSD" Then
  # Si on est sur l'objet de paramétrage, pas de filtre on part sur la sélection standard
  OBJET = "TSD"
  Return
Endif
#--------------------------------------------------------------------------------------------------

# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PGT
  FCY  = [M:ADWP]FCY
  CPY  = [M:ADWP]CMP
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Endif
  #--Catégorie livr. en fonction du nom du paramètre
  WNOL = nolign-1

  # X3-1152 : Non invoiceable deliveries
  CAT=4
  #CAT  = 5 #
  # X3-1152 : Non invoiceable deliveries

  If WNOL>=0
    Case [M:ADWP]PARAM(WNOL)
      When "SDHTYPNOR" : CAT=1
      When "SDHTYPLND" : CAT=2
      When "SDHTYPSCO" : CAT=3
      When "SDHTYPNINV": CAT=4   :# X3-1152 : Non invoiceable deliveries
      When Default     : CAT=4   :#--Toutes catégories
    Endcase
  Endif
Else
  LEG  = PARAM(1)
  FCY  = PARAM(2)
  GRP  = PARAM(3)
  CAT  = val(PARAM(4))
  CPY  = PARAM(5)
  #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #--On charge les options définies sur le type de données du champ du masque
  OPTIONS=""
  If CODMSK<>"" & CHAMPCOD<>""
    Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
    If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
  Endif
Endif

# Initialisation de législation
If func AFNC.ACTIV("LEG")=0
  LEG = GDOSLEG
Endif

If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

If [L]LEG=""
 [L]LEG = GCURLEG
Endif
#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOTSD
For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I)  = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I
NBCOL   = NBSEL
SIZCOL  = 240
SIZLIG  = 100
TIT(0)  = mess(12,123,1)  # Choix
Call TITOBJ("TSD","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START   = "[F:TSD]SDHTYP"
ORDRE   = "[F:TSD]SDHTYP;[F:TSD]LEG"
OBJET   = ""

#--------------------------------------------------------------------------------------------------
## Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

CRITERE(1) = '1=1'
#--Groupe de soc/sites
If [L]FCY="" & [L]CPY="" & [L]GRP<>""
#--Cas du groupe étant une société
 Read [F:AGF]AGF0=[L]GRP
 If !fstat
 If [F:AGF]FLGLEG=2 : [L]CPY=[L]GRP : Endif
 Endif
 #--Le filtrage sur les groupes sites/sociétés sont fait dans le link directement
Endif
#--Site
If    [L]FCY<>""
  CRITERE(1) -= '& ([F:TSD]GFY="" | ([F:TSD]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
#--Société
Elsif [L]CPY<>""
  CRITERE(1) -= '& ([F:TSD]GFY="" | ([F:TSD]GFY<>"" & [F:TSDC]LEGCPY="'+[L]CPY+'"))'
Endif
#--Législation
If LEG<>""
  CRITERE(2) -= '& ([F:TSD]LEG="'+[L]LEG+'" | [F:TSD]LEG="")'
Endif

# X3-1152 : Non invoiceable deliveries
#--Catégorie de livraison
If CAT>0 and CAT<>4 and CAT<>5
  CRITERE(2) -= '& ([F:TSD]SDHCAT='+num$(CAT)+')'
Endif
If CAT=5
  CRITERE(2) -= '& ([F:TSD]SDHCAT='+num$(CAT-1)+')'
Endif
# X3-1152 : Non invoiceable deliveries

If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(2) -= '& left$([F:TSD]SDHTYP,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 3

#MGG X3-38593 Row level permission
#Call FILROLE(OBJET,FILROLE) From SUBARL
Call FILROLE("TSD", FILROLE) From SUBARL
#MGG X3-38593 Row level permission

If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
#--Views calls
#--------------------------------------------------------------------------------------------------
If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
If [L]LEG<>""
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSDYGRP"
      Local File =SZVIEW [TSDY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TSD"
      Return
    Endif
Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSDZGRP"
      Local File =SZVIEW [TSDZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TSD"
      Return
    Endif
Endif
Endif

ERR = 0
Repeat
  # -----------------------------------------------------------------------------------------------
  # ERR=0  : Pas d'erreur, on sort
  # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
  # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
  # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
  # -----------------------------------------------------------------------------------------------
  Onerrgo ERRVUE
  SZVIEW = "LEGTSDCPY"
  Local File =SZVIEW [TSDC]
  Onerrgo
Until ERR <> -1
If ERR Then
  # Si problème, on se déroute sur le select standard
  OBJET = "TSD"
  Return
Endif
#--------------------------------------------------------------------------------------------------
## Appel à la vue
#--------------------------------------------------------------------------------------------------
If [L]LEG<>""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTSDSEL"
    Local File =SZVIEW [TSDS]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, on se déroute sur le select standard
    OBJET = "TSD"
    Return
  Endif
  If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
  Link [TSD] With [F:AXX]AXX0    = "TABSDHTYP";"DESAXX";GLANGUE;[F:TSD]SDHTYP;[F:TSD]LEG,
&                [F:TSDY]TSDY0 ~= [L]GRP;[F:TSD]SDHTYP;[F:TSD]GFY;[F:TSD]LEG,
&              [F:TSDS]TSD0  ~= [F:TSD]SDHTYP;[F:TSD]LEG;[L]LEG
&             As [LTSD]
Else
 Link [TSD] With [F:AXX]AXX0    = "TABSDHTYP";"DESAXX";GLANGUE;[F:TSD]SDHTYP;[F:TSD]LEG,
&                [F:FGR]FGR1    = [L]FCY;[F:TSD]GFY,
&                [F:TSDC]TSD0   = [F:TSD]SDHTYP;[F:TSD]LEG;[F:TSD]GFY;[L]CPY,
&                [F:TSDS]TSD0  ~= [F:TSD]SDHTYP;[F:TSD]LEG;[L]LEG
&   As [LTSD]
Endif
Else
 #--View without legislation
 ERR = 0
 Repeat
   # -----------------------------------------------------------------------------------------------
   # ERR=0  : Pas d'erreur, on sort
   # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
   # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
   # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
   # -----------------------------------------------------------------------------------------------
   Onerrgo ERRVUE
   SZVIEW = "LEGTSDPAR"
   Local File =SZVIEW [TSDP]
   Onerrgo
 Until ERR <> -1
 If ERR Then
   # Si problème, on se déroute sur le select standard
   OBJET = "TSD"
   Return
 Endif
  If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
  Link [TSD] With [F:AXX]AXX0    = "TABSDHTYP";"DESAXX";GLANGUE;[F:TSD]SDHTYP;[F:TSD]LEG,
&                [F:TSDZ]TSDZ0 ~= [L]GRP;[F:TSD]SDHTYP;[F:TSD]GFY;[F:TSD]LEG
&             As [LTSD]
Else
Link [TSD] With [F:AXX]AXX0    = "TABSDHTYP";"DESAXX";GLANGUE;[F:TSD]SDHTYP;[F:TSD]LEG,
&               [F:FGR]FGR1    = [L]FCY;[F:TSD]GFY,
&               [F:TSDC]TSD0   = [F:TSD]SDHTYP;[F:TSD]LEG;[F:TSD]GFY;[L]CPY,
&               [F:TSDP]TSD0  ~= [F:TSD]SDHTYP;[F:TSD]LEG
&   As [LTSD]
Endif
Endif

# Options de sélection
If OPTIONS<>""
  Gosub OPTIONS From WOTSD
  ICRITERE=2
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
Endif

Default File [LTSD]
DEFPAG = 1

Return

$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume
##################################################
Subprog SELTSDA(SDHTYP,LEG,FCY,GROUPE,PSDHCAT,CPY,CODMSK,CHAMPCOD)
Variable Char    SDHTYP()
Value    Char    LEG
Value    Char    FCY
Value    Char    GROUPE
Value    Integer PSDHCAT
Value    Char    CPY
Value    Char    CODMSK()
Value    Char    CHAMPCOD()

Local Char PARMSK(30)(1..10)
PARMSK(1)=[L]LEG
PARMSK(2)=[L]FCY
PARMSK(3)=[L]GROUPE
PARMSK(4)=num$([L]PSDHCAT)
PARMSK(5)=[L]CPY
PARMSK(6)=[L]CODMSK
PARMSK(7)=[L]CHAMPCOD

If clalev([F:TSD])=0 : Local File TABSDHTYP [TSD] : Endif
Call S_TAB_CHAR(SDHTYP,PARMSK,"SELTSD","SUBTSD","") From GACTION

End
#################################################################################
$SELTSDL


Return
###############################################################################
##  Copie
###############################################################################
$TRTCOP

If [M]DOSORG=nomap
 Local File TABSDHTYP [TSD1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[M]DOSORG+".TABSDHTYP" [TSD1]
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
 Local File TABSDHTYP [TSD2]
 Local File ATEXTRA   [AXX2]
 Local File ACTIV     [ACV2]
Else
 Local File =[M]DOSDES+".TABSDHTYP" [TSD2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
 Local File =[M]DOSDES+".ATABDIV"   [ADI2]
 Local File =[M]DOSDES+".ACTIV"     [ACV2]
 Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
Endif
Gosub OUVDOS From ATEXTRA
# Multi-Lég... Vérifier que la législation existe dans le dossier destination
# Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
#If TABLE2<>"" & clalev([F:ADS2])>0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
# Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #:--CPO 71937 -- Législation non gérée par ce dossier --#
#   Return
#Endif

Call DEBTRANS From GLOCK
Gosub TR_COP

Close Local File [TSD1], [TSD2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return

$TR_COP

#--------------------------------------------------#
# Transaction de copie d'un type de livraison      #
#--------------------------------------------------#
Local Char    LEGDES
Local Integer WMONOLEGDES
# Par défaut : Leg destination=leg de l'enregistrement à copier
LEGDES=TABLE2
GOK = 1
##--Quelques vérifications...
#If TABLE2<>''
# If [M]DOSDES<>nomap
#  Local Char SZDOSSIER(GLONADS)
#  Local Integer LG
#  Read [ADI2]CODE=909; TABLE2
#  If fstat
#   Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
#   Return
#  Endif
# Endif
#Endif

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Pb lecture dossier
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Pas de législation pour le dossier
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
            Return
        Endif
        If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
            Return
        Elsif TABLE2=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE2<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE2
          If fstat
           Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

Read [TSD2]TSD0=TABLE ;LEGDES
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

Trbegin [TSD2]
 Delete [TSD2] Where SDHTYP=TABLE & LEG=LEGDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABSDHTYP"-TABLE : Goto ROLL_TR_COP
 Elsif fstat
  GOK = 0 : Call RSTA("TSD2",TABLE) From GLOCK : Goto AB_TR_COP
 Endif
 If !fstat
    #--- copie des données
    For [TSD1]TSD0 Where SDHTYP=TABLE & LEG = TABLE2
      [F:TSD2] = [F:TSD1]
      [F:TSD2]LEG = LEGDES
      If TABLE2=LEGDES
          Call COPTEXTRA("TABSDHTYP","DESAXX",TABLE,TABLE2) From ATEXTRA
          Call COPTEXTRA("TABSDHTYP","SHOAXX",TABLE,TABLE2) From ATEXTRA
      Else
          Call COPTEXTRA1("TABSDHTYP","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
          Call COPTEXTRA1("TABSDHTYP","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
      Endif
      If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
      If dim([F:TSD2]UPDUSR)>0 : [F:TSD2]UPDUSR = GUSER : Endif
      If dim([F:TSD2]UPDDAT)>0 : [F:TSD2]UPDDAT = date$ : Endif
      Write [TSD2]
      If fstat
       GOK = 0 : Call FSTA("TSD2") From GLOCK : Break
      Endif
     Next
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit

Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

Return
######################################################################
$SETBOUT
If CLECUR=0 | GREP<>""
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

Return
