#########################################################################
Subprog SHOWHIDE_COUNT_SDHCAT(ISDHCAT)
Value Integer ISDHCAT

  # FGR 15/04/2013 : Mail Cyrille 03/05/2013 (DKS US 428) : disponible pour tout le monde
  # Les champs inter-site et inter-société ne sont pas disponibles pour la catégorie "Prêt"
  If ISDHCAT = 2 Then
    # Prêt
    Chgfmt [M:TSD1]CODNUMFCY With "-K:"+num$(GLONANM)+"B"
    If dim([M:TSD1]ZCODNUMFCY)>0
      Chgfmt [M:TSD1]ZCODNUMFCY With "-K:"+num$(type([M:TSD1]ZCODNUMFCY)-10)+"X"
    Endif
    Chgfmt [M:TSD1]CODNUMFCYD With "-K:"+num$(GLONANM)+"B"
    If dim([M:TSD1]ZCODNUMFCYD)>0
      Chgfmt [M:TSD1]ZCODNUMFCYD With "-K:"+num$(type([M:TSD1]ZCODNUMFCYD)-10)+"X"
    Endif
    #
    Chgfmt [M:TSD1]CODNUMCPY With "-K:"+num$(GLONANM)+"B"
    If dim([M:TSD1]ZCODNUMCPY)>0
      Chgfmt [M:TSD1]ZCODNUMCPY With "-K:"+num$(type([M:TSD1]ZCODNUMCPY)-10)+"X"
    Endif
    Chgfmt [M:TSD1]CODNUMCPYD With "-K:"+num$(GLONANM)+"B"
    If dim([M:TSD1]ZCODNUMCPYD)>0
      Chgfmt [M:TSD1]ZCODNUMCPYD With "-K:"+num$(type([M:TSD1]ZCODNUMCPYD)-10)+"X"
    Endif
  Else
    # Les autres
    Chgfmt [M:TSD1]CODNUMFCY With "K:"+num$(GLONANM)+"B"
    If dim([M:TSD1]ZCODNUMFCY)>0
      Chgfmt [M:TSD1]ZCODNUMFCY With "KP:"+num$(type([M:TSD1]ZCODNUMFCY)-10)+"X"
    Endif
    Chgfmt [M:TSD1]CODNUMFCYD With "K:"+num$(GLONANM)+"B"
    If dim([M:TSD1]ZCODNUMFCYD)>0
      Chgfmt [M:TSD1]ZCODNUMFCYD With "KP:"+num$(type([M:TSD1]ZCODNUMFCYD)-10)+"X"
    Endif
    #
    Chgfmt [M:TSD1]CODNUMCPY With "K:"+num$(GLONANM)+"B"
    If dim([M:TSD1]ZCODNUMCPY)>0
      Chgfmt [M:TSD1]ZCODNUMCPY With "KP:"+num$(type([M:TSD1]ZCODNUMCPY)-10)+"X"
    Endif
    Chgfmt [M:TSD1]CODNUMCPYD With "K:"+num$(GLONANM)+"B"
    If dim([M:TSD1]ZCODNUMCPYD)>0
      Chgfmt [M:TSD1]ZCODNUMCPYD With "KP:"+num$(type([M:TSD1]ZCODNUMCPYD)-10)+"X"
    Endif
  Endif
End

