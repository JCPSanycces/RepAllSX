  If find([M:TSD1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    If find(VALEUR,[M:TSD1]CODNUMEND,[M:TSD1]CODNUMFCYD,[M:TSD1]CODNUM,[M:TSD1]CODNUMFCY,[M:TSD1]CODNUMCPY) : GMESSAGE = mess(142,7711,1) : mkstat = 2 : End : Endif
