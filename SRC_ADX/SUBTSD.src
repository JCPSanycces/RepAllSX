#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################
# SUBTSD                                                Février  2012  #
#    TYPES DE LIVRAISONS VENTES                                        #
########################################################################

$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "AFFMASK"       : Gosub AFFMASK
 When "RAZCRE"        : Gosub RAZCRE
 When "RAZDUP"        : Gosub RAZDUP
 When "INICRE"        : Gosub INICRE
 When "INIMOD"        : Gosub INICRE
 When "ANNULE"        : Gosub ANNULE
 When "AP_CHANGE"     : Gosub AP_CHANGE
 When "LIENS"         : Gosub LIENS
 When "FERME"         : Gosub FERME
  When "SEL_LISTE"
   Case LISTE
     When "SELTSD"    : Gosub SELTSDL
   Endcase
 When "SEL_TABLE"
   Case TABLE
     When "SELTSD"    : Gosub SELTSD
   Endcase
 When "CHGCOD"        : Gosub CHGCOD
 When "SETBOUT"				: Gosub SETBOUT
 When "AS_SDHTYP"     : Raz GCURLEG   :#--CPO 92135 Sélection sur fiche ayant une lég
 When "VERIF_CRE"     : Gosub VERIF
 When "VERIF_MOD"     : Gosub VERIF
 When Default
Endcase

Return
######################################################################################
$OUVRE
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB

#--Lors d'un tunnel depuis un document (exemple : livraison)
Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes

#BRBAN 08/10/2014 - Document types control
If !clalev([F:TSD3]) : Local File TABSDHTYP [TSD3] : Endif
#-

Return
######################################################################
$VERIF
#BRBAN 08/10/2014 - Document types control
If func AFNC.ACTIV("KPO") > 0
  Case [M:TSD1]LEG
    When ""
      Read [F:TSD3]TSD0=[M:TSD1]SDHTYP;"POR"
      If !fstat
        If [M:TSD1]RECTYP <> [F:TSD3]RECTYP
          Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TSD3]SDHTYP,[F:TSD3]LEG),2) From GESECRAN
          OK = 0 : Return
        Endif
        If [M:TSD1]SAFTTRNTYP <> [F:TSD3]SAFTTRNTYP
          Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TSD3]SDHTYP,[F:TSD3]LEG),2) From GESECRAN
          OK = 0 : Return
        Endif
      Endif
    When "POR"
      Read [F:TSD3]TSD0=[M:TSD1]SDHTYP;""
      If !fstat
        If [M:TSD1]RECTYP <> [F:TSD3]RECTYP
          Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TSD3]SDHTYP,mess(59,151,1)),2) From GESECRAN
          OK = 0 : Return
        Endif
        If [M:TSD1]SAFTTRNTYP <> [F:TSD3]SAFTTRNTYP
          Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TSD3]SDHTYP,mess(59,151,1)),2) From GESECRAN
          OK = 0 : Return
        Endif
      Endif
  Endcase
Endif
#-
Return
######################################################################
$INICRE

Gosub MAJ_ATEXTRA

Return

$MAJ_ATEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("TABSDHTYP","DESAXX",CLECUR1,"","TABSDHTYP","SHOAXX",[F:TSD]SDHTYP,[F:TSD]LEG)  From ATEXTRA
 Call DUPTEXTRA("TABSDHTYP","SHOAXX",CLECUR1,"","TABSDHTYP","SHOAXX",[F:TSD]SDHTYP,[F:TSD]LEG)  From ATEXTRA
Endif
#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:TSD1]DESAXX,"TABSDHTYP","DESAXX",[M:TSD1]SDHTYP,[M:TSD1]LEG) From ATEXTRA
Call MAJTEXTRA ([M:TSD1]SHOAXX,"TABSDHTYP","SHOAXX",[M:TSD1]SDHTYP,[M:TSD1]LEG) From ATEXTRA

#    SOS libellés
If dim([F:TSD]LANDESSHO)>0
   [F:TSD]LANDESSHO=GLANGUE+"~"+[M:TSD1]DESAXX+"~"+[M:TSD1]SHOAXX
Endif

Return

$CHGCOD
  #-- X3Suivi 71937
  Call CHGCOD(ABREV, CLECUR1, CLECUR2, OK) From CHGCLELEG
Return

######################################################################
$AFFMASK
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG

Return
######################################################################
$RAZCRE
Gosub GRILEG
#RMA * 85785
If func AFNC.ACTIV("KPO")
  Call SHOW_HIDE_TSD([M:TSD1]LEG) From PORLEGLIB
Endif
Return
######################################################################
$RAZDUP

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TSD([M:TSD1]LEG) From PORLEGLIB
Endif

Return
######################################################################
$LIENS

GCURLEG = [F:TSD]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
GGRPFCY = [F:TSD]GFY

Call SHOWHIDE_COUNT_DEF([F:TSD]LEG)  # FGR 10/04/2013 : X3SUIVI75115
Call SHOWHIDE_COUNT_SDHCAT([F:TSD]SDHCAT) # FGR 27/05/2013

#RMA * 85785
If func AFNC.ACTIV("KPO")
  Call SHOW_HIDE_TSD([M:TSD1]LEG) From PORLEGLIB
Endif

# Issue X3-143 - 2016-10-03 by RICAR : 107966 - Change the field actions on RECTYP, SAFTTRNTYP and COMAT
# Issue X3-143
If func AFNC.ACTIV("KPO") > 0
  Gosub DISABLE_TSD_FIELDS From PORLEGLIB
Endif
# End issue X3-143

Return
######################################################################
$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [M:TSD1]LEG
  [M:TSD1]LEG=GDOSLEG(1)
  Affzo [M:TSD1]LEG : If dim([M:TSD1]ZLEG)>0  Affzo [TSD1]ZLEG : Endif
Endif

Return
######################################################################
$ANNULE
Delete [AXX]Where CODFIC="TABSDHTYP" & IDENT1=[F:TSD]SDHTYP & IDENT2=[F:TSD]LEG

Return
######################################################################
$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONTSD) : Endif

VCOD = CLE2

Return
#########################################################################
$AP_CHANGE
Call CHGTEXTRA("TABSDHTYP","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("TABSDHTYP","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA

Return

