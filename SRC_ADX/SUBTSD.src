#    Détail des actions : Classées par champs dans l'ordre des écrans   #
#########################################################################
######################################################################################
Subprog AS_SDHCAT(VALEUR)
Variable Integer VALEUR

# X3-1152 : Non invoiceable deliveries
#If func AFNC.ACTIV("PJM") = 0
#  GMENLOC(5)=1
#Endif
# X3-1152 : Non invoiceable deliveries

If !func AFNC.ACTIV("LST") GMENLOC(3)=1 Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran TSD1) 20/04/2012 11:02:52 (CPO)
######################################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR

#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If func AFNC.ACTIV("KPO")>0 & find(VALEUR,"POR","")
  Local Char WMESS(100) : WMESS = ""
  Call CTL_CODNUM_LEG(VALEUR,[M:TSD1]SDHTYP,"TSD",WMESS)    From PORLEGLIB
  If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
Endif
# Issue End

End
######################################################################################
Subprog C_CODNUM(VALEUR)
Variable Char    VALEUR()
#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If VALEUR<>''
  If func AFNC.ACTIV("KPO")>0 & find([M:TSD1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    If find(VALEUR,[M:TSD1]CODNUMEND,[M:TSD1]CODNUMFCYD,[M:TSD1]CODNUMCPYD) : GMESSAGE = mess(142,7711,1) : mkstat = 2 : End : Endif
    Call CTL_CODNUM_NORMAL(VALEUR,[M:TSD1]LEG,[M:TSD1]SDHTYP,"TSD",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
Endif
# Issue End

Gosub CTL_CODNUM

#RMA * control done above
##--Le compteur définitif doit être différent de celui normal
#If [M:TSD1]CODNUMEND<>"" and [M:TSD1]CODNUMEND=VALEUR
#  GMESSAGE= mess(248,191,1)
#  mkstat = 2
#Endif
#Gosub CTL_CODNUM

End
######################################################################################
Subprog C_CODNUMEND(VALEUR)
Variable Char    VALEUR()
#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If VALEUR<>''
  If find([M:TSD1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    If find(VALEUR,[M:TSD1]CODNUMFCYD,[M:TSD1]CODNUMCPYD,[M:TSD1]CODNUM,[M:TSD1]CODNUMFCY,[M:TSD1]CODNUMCPY) : GMESSAGE = mess(142,7711,1) : mkstat = 2 : End : Endif
    Call CTL_CODNUM_FINAL(VALEUR,[M:TSD1]LEG,[M:TSD1]SDHTYP,"TSD",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
Endif
# Issue End

Gosub CTL_CODNUM

#RMA * control done above
##--Le compteur définitif doit être différent de celui normal
#If [M:TSD1]CODNUM<>"" and [M:TSD1]CODNUM=VALEUR
#  GMESSAGE= mess(248,191,1)
#  mkstat = 2
#Endif

End
