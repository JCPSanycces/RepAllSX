#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque PLNANU
######################################################################################
# Modifications :
#     SEGAY - 26/03/12 - Bug 88191 US1418
#              - Test contrat successif 82073
######################################################################################

$ACTION

Case ACTION
 When "INIT"     : Gosub INIT
 When "DEBUT"    : Gosub DEBUT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "SORTIE"   : Gosub SORTIE
 When "OK"       : Gosub OK #ADNGO - 2017-04-05 - X3-24432
Endcase
Return

# Appelé dans le GTRAITE

$INIT
Local Mask PLNANU [DIA]
Local Char    CRITERE (250),CRITEMP (250) #88191
Local Integer NB
If clalev([F:PLE])=0 : Local File PLANEMP  [PLE] : Endif
If clalev([F:TIP])=0 : Local File TIMEMP   [TIP] : Endif
If clalev([F:ECT])=0 : Local File EMPCTR   [ECT] : Endif
#LIPET - 10-01-2017 - X3-18688 - START
#If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#LIPET - 10-01-2017 - X3-18688 - END
Return


## Appelé dans le GSAISIE

$DEBUT
# 47908
Local Integer STAT
Raz [M:DIA]
Case GACTION
 When "PLNANU"
  # 47908
  # Call LECMEMO("STD","[M:DIA]","pan") From GMEMO
  Call LECMEMORET("STD","[M:DIA]","pan",1,STAT) From GMEMO
  If STAT=1
# FQ92876 - 05/06/14 - On a maintenant un onglet par plage horaire
#   [M:DIA]MATDEB    = [M:PLE]REFNUM
#   [M:DIA]MATFIN    = [M:PLE]REFNUM
#   [M:DIA]DATSTRINI = [M:PLE]DAT(0)
#   [M:DIA]DATENDINI = [M:PLE]DAT(6)
   [M:DIA]MATDEB    = [M:PLE0]REFNUM
   [M:DIA]MATFIN    = [M:PLE0]REFNUM
   [M:DIA]DATSTRINI = [M:PLE0]DAT(0)
   [M:DIA]DATENDINI = [M:PLE0]DAT(6)
  Endif
 When "JOUANU"
  # 47908
  # Call LECMEMO("STD","[M:DIA]","jan") From GMEMO
  Call LECMEMORET("STD","[M:DIA]","jan",1,STAT) From GMEMO
  If STAT=1
#LIPET - 10-01-2017 - X3-18688 - START
   [M:DIA]LEG    = [M:TPSJ]LEG
#LIPET - 10-01-2017 - X3-18688 - END
   [M:DIA]MATDEB    = [M:TPSJ]REFNUM
   [M:DIA]MATFIN    = [M:TPSJ]REFNUM
   [M:DIA]DATSTRINI = [M:TPSJ]DAT(0)
   [M:DIA]DATENDINI = [M:TPSJ]DAT(6)
  Endif
Endcase
#LIPET - 10-01-2017 - X3-18688 - START
If [M:DIA]LEG<>""
  GCURLEG = [M:DIA]LEG
Endif
#LIPET - 10-01-2017 - X3-18688 - END
Affzo [M:DIA]

Return

$SORTIE
  #LIPET - 10-01-2017 - X3-18688 - START
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
  #LIPET - 10-01-2017 - X3-18688 - END
Return
#ADNGO - 2017-04-05 - X3-24432 - START
$OK
If [M:DIA]LEG="" Then
   GERR  = 1
   GMESSAGE = mess(232,143,1)
   zonsui = "[M:DIA]LEG" #Put the focus on the field.
   FIN = 0 # Instruct the supervisor to keep the window open
   GOK = 0
   Return
Endif
Return
#ADNGO - 2017-04-05 - X3-24432 - END
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

$EXEC
GOK = 1
Case GACTION
 When "PLNANU"
  #LIPET - 10-01-2017 - X3-18688 - START
  # Annulation des plannings opérationnels du xx/xx/xx au xx/xx/xx
  #TIT = mess(156,709,1)-mess(94,100,1)-num$([M:DIA]DATSTRINI)-mess(95,100,1)-num$([M:DIA]DATENDINI)
  TIT = mess(156,10709,1)-mess(94,100,1)-num$([M:DIA]DATSTRINI)-mess(95,100,1)-num$([M:DIA]DATENDINI)
  #LIPET - 10-01-2017 - X3-18688 - END
 When "JOUANU"
  #LIPET - 10-01-2017 - X3-18688 - START
  # Annulation des feuilles de temps du xx/xx/xx au xx/xx/xx
  #TIT = mess(159,709,1)-mess(94,100,1)-num$([M:DIA]DATSTRINI)-mess(95,100,1)-num$([M:DIA]DATENDINI)
  TIT = mess(159,10709,1)-mess(94,100,1)-num$([M:DIA]DATSTRINI)-mess(95,100,1)-num$([M:DIA]DATENDINI)
  #LIPET - 10-01-2017 - X3-18688 - END
Endcase
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGTPS=2" : # Salarié actif + géré dans les temps
# Société
If [M:DIA]ALLCPY<>2  : CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'  : Endif
#LIPET - 10-01-2017 - X3-18688 - START
# Site
#If [M:DIA]ALLFCY<>2  : CRITERE -= '& [F:CTR]ETRFCY = "'+[M:DIA]FCY+'"'      : Endif
If [M:DIA]ALLFCY<>2  : CRITERE -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'      : Endif
#LIPET - 10-01-2017 - X3-18688 - END
# FQ85820 - 30/04/13 - La vérification se fait maintenant dans VERIF_FLD, selon la rétroactivité
## Service
#If [M:DIA]ALLSRV<>2  : CRITERE -= '& [F:CTR]ETRSRV = "'+[M:DIA]SRV+'"'      : Endif
## Profil
#If [M:DIA]ALLPRF<>2  : CRITERE -= '& [F:CTR]PROPRF = "'+[M:DIA]PRF+'"'      : Endif
# Borne de salariés
If [M:DIA]MATDEB<>"" : CRITERE -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"' : Endif
If [M:DIA]MATFIN<>"" : CRITERE -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"' : Endif

#LIPET - 10-01-2017 - X3-18688 - START
##**88191
#CRITEMP = '[F:CTR]CTRDAT<=['+num$([M:DIA]DATENDINI)+'] & ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>=['+num$([M:DIA]DATSTRINI)+'])'
CRITEMP = '[F:HRCTR]CTRDAT<=['+num$([M:DIA]DATENDINI)+'] & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=['+num$([M:DIA]DATSTRINI)+'])'
#LIPET - 10-01-2017 - X3-18688 - END

#If [M:DIA]POP<>""
# Link [ECT] With
#&   [ID]ID0   = [F:ECT]REFNUM
#& , [CTR]CTR2 = [F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
#& , [FCY]FCY0 = [F:CTR]ETRFCY
#& , [POA]POA0 = [M:DIA]POP;[F:ID]REFNUM
#&   As [LNK]
#&   Where evalue(CRITERE) & [F:POA]REFNUM<>""
#Else
# Link [ECT] With
#&   [ID]ID0   = [F:ECT]REFNUM
#& , [CTR]CTR2 = [F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
#& , [FCY]FCY0 = [F:CTR]ETRFCY
#&   As [LNK]
#&   Where evalue(CRITERE)
#Endif
#LIPET - 10-01-2017 - X3-18688 - START
##**88191
#If [M:DIA]POP<>""
# Link [CTR] With
#&   [ID]ID0   = [F:CTR]REFNUM
#& , [FCY]FCY0 = [F:CTR]ETRFCY
#& , [CPY]CPY0 = [F:FCY]LEGCPY
#& , [POA]POA0 = [M:DIA]POP;[F:CTR]REFNUM
#&   As [LNK]
#&   Where evalue(CRITERE) & [F:POA]REFNUM<>"" & evalue(CRITEMP)
#Else
# Link [CTR] With
#&   [ID]ID0   = [F:CTR]REFNUM
#& , [FCY]FCY0 = [F:CTR]ETRFCY
#& , [CPY]CPY0 = [F:FCY]LEGCPY
#&   As [LNK]
#&   Where evalue(CRITERE) & evalue(CRITEMP)
#Endif
If [M:DIA]POP<>""
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
& , [POA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM
&   As [LNK]
&   Where evalue(CRITERE) & [F:POA]REFNUM<>"" & evalue(CRITEMP)
Else
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
&   As [LNK]
&   Where evalue(CRITERE) & evalue(CRITEMP)
Endif
#LIPET - 10-01-2017 - X3-18688 - END
Call DEBTRANS From GLOCK

Case GACTION
 When "PLNANU"
  #50000 : Action PLNANU et non PLANU
  Gosub TR1
  Call ECR_TRACE("",0) From GESECRAN
  #LIPET - 10-01-2017 - X3-18688 - START
  # xx plannings supprimés
  #Call ECR_TRACE(num$(NB)-mess(157,709,1),0) From GESECRAN
  Call ECR_TRACE(num$(NB)-mess(157,10709,1),0) From GESECRAN
  #LIPET - 10-01-2017 - X3-18688 - END
 When "JOUANU"
  Gosub TR2
  Call ECR_TRACE("",0) From GESECRAN
  #LIPET - 10-01-2017 - X3-18688 - START
  # xx feuilles de temps supprimées
  #Call ECR_TRACE(num$(NB)-mess(160,709,1),0) From GESECRAN
  Call ECR_TRACE(num$(NB)-mess(160,10709,1),0) From GESECRAN
  #LIPET - 10-01-2017 - X3-18688 - END
Endcase

Return


$TR1
GOK = 1
Trbegin [PLE]
 For [LNK]
  #LIPET - 10-01-2017 - X3-18688 - START
  # FQ85820 - 30/04/13 - Vérification profil/service selon rétroactivité
#  If func SUBCTRRET.VERIF_FLD([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[M:DIA]DATENDINI,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"CTR")=2
#&  & func SUBCTRRET.VERIF_FLD([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[M:DIA]DATENDINI,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"CTR")=2 Then
#   Delete [PLE] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & DAT>=[M]DATSTRINI & DAT<=[M]DATENDINI
    If func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATENDINI,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"HRCTR")=2
&  & func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATENDINI,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"HRCTR")=2 Then
   # Fin FQ85820
    Delete [PLE] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & DAT>=[M]DATSTRINI & DAT<=[M]DATENDINI
    #LIPET - 10-01-2017 - X3-18688 - END
    If fstat=1
     GOK=-1 : Call FSTA("PLE") From GLOCK : Break
    Elsif !fstat
     Call ECR_TRACE(format$("K:15X",[F:ID]REFNUM)-format$("K:40X",[F:ID]NAM)-[F:ID]SRN,0) From GESECRAN
     NB +=1
    Endif
  Endif
 Next
 If GOK=-1 : Goto ROLL_TR1 : Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$TR2
GOK = 1
Trbegin [TIP]
 For [LNK]
  #LIPET - 10-01-2017 - X3-18688 - START
  # FQ85820 - 30/04/13 - Vérification profil/service selon rétroactivité
#  If func SUBCTRRET.VERIF_FLD([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[M:DIA]DATENDINI,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"CTR")=2
#&  & func SUBCTRRET.VERIF_FLD([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[M:DIA]DATENDINI,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"CTR")=2 Then
  If func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATENDINI,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"HRCTR")=2
&  & func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATENDINI,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"HRCTR")=2 Then
  # Fin FQ85820
    # FQ85579 - MABON 06/11/12 - On ne doit pas supprimer ce qui a été créé en automatique, comme les congés par exemple
    # Sinon, on perd le lien, notamment dans TPSSTD où on ne trouvera plus les congés
  #  Delete [TIP] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & STRDAT>=[M]DATSTRINI & ENDDAT<=[M]DATENDINI
    #Delete [TIP] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & STRDAT>=[M]DATSTRINI & ENDDAT<=[M]DATENDINI & AUTFLG<>2
    Delete [TIP] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & STRDAT>=[M]DATSTRINI & ENDDAT<=[M]DATENDINI & AUTFLG<>2
    #LIPET - 10-01-2017 - X3-18688 - END
    # Fin MABON
    If fstat=1
     GOK=-1 : Call FSTA("TIP") From GLOCK : Break
    Elsif !fstat
     Call ECR_TRACE(format$("K:15X",[F:ID]REFNUM)-format$("K:40X",[F:ID]NAM)-[F:ID]SRN,0) From GESECRAN
     NB +=1
    Endif
  Endif
 Next
 If GOK=-1 : Goto ROLL_TR2 : Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return


######################################################################################
## Etiquette écrans PLNANU et JOUANU
######################################################################################

Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
Call AS_ALLCPY(VALEUR) From DIVPAYE
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From DIVPAYE
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Call AS_CPY(VALEUR) From DIVPAYE
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From DIVPAYE
End

Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR
Call C_ALLSRV(VALEUR) From DIVPAYE
End

Subprog AS_SRV(VALEUR)
Variable Char    VALEUR()
Call AS_SRV(VALEUR) From DIVPAYE
End

Subprog C_ALLPRF(VALEUR)
Variable Integer VALEUR
Call C_ALLPRF(VALEUR) From DIVPAYE
End

Subprog AS_PRF(VALEUR)
Variable Char    VALEUR()
Call AS_PRF(VALEUR) From DIVPAYE
End

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
Call C_MATFIN(VALEUR) From DIVPAYE
End

Subprog C_DATENDINI(VALEUR)
Variable Date    VALEUR
If VALEUR-[M]DATSTRINI>365

 #LIPET - 10-01-2017 - X3-18688 - START
 # La période dépasse une année
 #GMESSAGE = mess(139,709,1)
 GMESSAGE = mess(139,10709,1)
 #LIPET - 10-01-2017 - X3-18688 - END
 mkstat = 2 : End
Endif
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

#LIPET - 09-01-2017 - X3-11322 - START
 GCURLEG = VALEUR
#LIPET - 09-01-2017 - X3-11322 - END

#ADNGO - 2017-01-18 - X3-11992 - START
 If VALEUR=""
    [M]ALLPRF=2
    Diszo [M]ALLPRF
Else
    Actzo [M]ALLPRF
Endif
#ADNGO - 2017-01-18 - X3-11992 - END
End

######################################################################################
## Section automatically added (screen PLNANU) 01/27/2017 11:44:47 (MIPEA)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
End


