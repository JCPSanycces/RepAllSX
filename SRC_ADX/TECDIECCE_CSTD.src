###############################################################################
# Class TECDIECCE
# Issue X3-81871 - 2018-03-08 by FGR
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Return

###############################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "GET_DEFAULT_VALUES"                    : Gosub GET_DEFAULT_VALUES              From TECDIECCE_CSTD_METHODS
    When "SET_IDENTIFIER"                        : Gosub SET_IDENTIFIER                  From TECDIECCE_CSTD_METHODS
    #
    When "ADD_CDIE_DIE"                          : Gosub ADD_CDIE_DIE                    From TECDIECCE_CSTD_METHODS
    When "CHECK_CDIE_DIE_EXIST"                  : Gosub CHECK_CDIE_DIE_EXIST            From TECDIECCE_CSTD_METHODS
    When "CLEAR_ALL_CDIE"                        : Gosub CLEAR_ALL_CDIE                  From TECDIECCE_CSTD_METHODS
    #
    When "_CONTROL_INPUT_VALUES"                 : Gosub _CONTROL_INPUT_VALUES           From TECDIECCE_CSTD_METHODS
    When "_LOAD_DEFAULT_CCE"                     : Gosub _LOAD_DEFAULT_CCE               From TECDIECCE_CSTD_METHODS
    When "INIT_SECTION"                          : Gosub INIT_SECTION                    From TECDIECCE_CSTD_METHODS
    When "_INIT_SECTION"                         : Gosub _INIT_SECTION                   From TECDIECCE_CSTD_METHODS
    When "EVALUABLE"                             : Gosub EVALUABLE                       From TECDIECCE_CSTD_METHODS
    When "CDECCE_VALUE_ALLOWED"                  : Gosub CDECCE_VALUE_ALLOWED            From TECDIECCE_CSTD_METHODS
    When "_GET_TABLE_ACCESS_INF"                 : Gosub _GET_TABLE_ACCESS_INF           From TECDIECCE_CSTD_METHODS
    When "_LOAD_CALLER_CCE_VALUES"               : Gosub _LOAD_CALLER_CCE_VALUES         From TECDIECCE_CSTD_METHODS
  Endcase
Return

###############################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Return

###############################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Return

###############################################################################
#Subroutines
###############################################################################
Funprog GET_DEFAULT_VALUES(INSCALL, SCDECOD, SCDECPY, SCDIE, SDIE, SCCE, SGACCOA, SMESSAGE)
Variable Instance INSCALL Using OBJECT
Value Char SCDECOD ()
Value Char SCDECPY
Value Char SCDIE
Value Char SDIE
Value Char SCCE
Value Char SGACCOA
Variable Char SMESSAGE

Local Integer IARENDRE
Local Instance TECDIECCE Using C_TECDIECCE

  SMESSAGE
  If INSCALL = null Then
    IARENDRE = [V]CST_AERROR
    SMESSAGE = func AFNC.MES1(mess(5,2001,1), "INSCALL")
  Else
    TECDIECCE = NewInstance C_TECDIECCE AllocGroup null
    IARENDRE = fmet TECDIECCE.GET_DEFAULT_VALUES(INSCALL, SCDECOD, SCDECPY, SCDIE, SDIE, SCCE, SGACCOA)
    FreeGroup TECDIECCE
  Endif
End IARENDRE

