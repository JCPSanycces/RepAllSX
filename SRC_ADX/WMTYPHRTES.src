#<AdxTL>@(#)0.0.0.0 $Revision$Class Expense codes
# Supervisor
## ATY-ATYPE ## HRTES
# 2018-11-09 07:14:29 422

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,LEG,CODEXP,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char LEG
Value Char CODEXP
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File HRTABEXPENS [HRTES]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".HRTABEXPENS" [HRTES]
Endif

Default File [F:HRTES]
Read [F:HRTES]HRTES0 = [L]LEG;[L]CODEXP
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]LEG)+"~"+num$([L]CODEXP)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]LEG)+"~"+num$([L]CODEXP)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


