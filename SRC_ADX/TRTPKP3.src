#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque STOCKSNU
$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When "FINSAI"      : Gosub FINSAI
Endcase
Return

$OUVRE_BOITE
#########################################################################
#recuperation numero de ligne
Global Integer   GLIG_PKP1 : GLIG_PKP1 =   val(PARAM(1))
Return
#########################################################################
$DEBUT

Local Integer I, J, NOL, OK

NOL = nolign-1
If nolign > [M:PKP1]NBLIG : FIN=1 : Return : Endif

Raz [M:PKP3]
[M:PKP3]ITMREF   = [M:PKP1]ITMREF (GLIG_PKP1)
[M:PKP3]ITMDES1  = [M:PKP1]ITMDES1(GLIG_PKP1)
[M:PKP3]QTY      = [M:PKP1]QTY    (GLIG_PKP1)
[M:PKP3]SAU      = [M:PKP1]SAU    (GLIG_PKP1)
[M:PKP3]PCK      = [M:PKP1]PCK    (GLIG_PKP1)
[M:PKP3]PCKLEN   = [M:PKP1]PCKLEN (GLIG_PKP1)
[M:PKP3]VOL      = [M:PKP1]VOL    (GLIG_PKP1)
[M:PKP3]VOU      = [M:PKP1]VOU    (GLIG_PKP1)
[M:PKP3]PCKWID   = [M:PKP1]PCKWID (GLIG_PKP1)
[M:PKP3]PCKWEI   = [M:PKP1]PCKWEI (GLIG_PKP1)
[M:PKP3]WEU      = [M:PKP1]WEU    (GLIG_PKP1)
[M:PKP3]DIU      = [M:PKP1]DIU    (GLIG_PKP1)
[M:PKP3]PCKHEI   = [M:PKP1]PCKHEI (GLIG_PKP1)
[M:PKP3]LBLFMT   = [M:PKP1]LBLFMT (GLIG_PKP1)

Affzo [M:PKP3]1-99


Return

#########################################################################
$OK

If [M:PKP3]NBCOL=0 : FIN=1 : Return : Endif

nolign = NOL+1
# Contrôle que l'on peut insérer les lignes dans le tableau
If [M:PKP1]NBLIG + [M:PKP3]NBCOL > dim([M:PKP1]ITMREF)-1
   GERR=1
   GMESSAGE=mess(122,199,1)
   Return
Endif

# Insertion des lignes
Insa nolign,[M:PKP3]NBCOL,[M:PKP1]NBLIG+[M:PKP3]NBCOL-1 [M:PKP1]NBLIG
[M:PKP1]NBLIG += [M:PKP3]NBCOL
nolign = GLIG_PKP1+2
# Alimentation des nouvelles lignes
Raz J
For I = NOL+1 To NOL+[M:PKP3]NBCOL
     If [F:ITM]ITMREF <> [M:PKP1]ITMREF      (GLIG_PKP1)
        Read [F:ITM]ITM0=[M:PKP1]ITMREF      (GLIG_PKP1)
        If fstat
           Raz [F:ITM]
        Endif
     Endif
    [M:PKP1]ITMREF     (I)  = [M:PKP1]ITMREF      (GLIG_PKP1)
    [M:PKP1]ITMDES1    (I)  = [M:PKP1]ITMDES1     (GLIG_PKP1)
    [M:PKP1]QTYSAU     (I)  = [M:PKP3]QTPCOL
    [M:PKP1]SAU        (I)  = [M:PKP1]SAU         (GLIG_PKP1)
    [M:PKP1]SAUSTUCOE  (I)  = [M:PKP1]SAUSTUCOE   (GLIG_PKP1)
    [M:PKP1]QTYSAUSTU  (I)  = [M:PKP1]QTYSAU(I)*[M:PKP1]SAUSTUCOE (I)
    Call QTEARR([M:PKP1]QTYSAUSTU(I),[M:PKP1]STU  (GLIG_PKP1)) From TRTDIV
    [M:PKP1]STU        (I)  = [M:PKP1]STU         (GLIG_PKP1)
    [M:PKP1]QTY        (I)  = [M:PKP1]QTYSAU      (I)
    [M:PKP1]QTYSTU     (I)  = [M:PKP1]QTYSAUSTU   (I)
    [M:PKP1]PCK        (I)  = [M:PKP3]PCK
    [M:PKP1]PACSEQ     (I)  = [M:PKP3]PACSEQDEB + J
    [M:PKP1]PACSEQH    (I)  = 1
    [M:PKP1]LBLFMT     (I)  = [M:PKP3]LBLFMT
    [M:PKP1]PCKWEI     (I)  = [M:PKP3]PCKWEI
    [M:PKP1]LIGUNTWEI  (I)  = [M:PKP1]LIGUNTWEI   (GLIG_PKP1)
    [M:PKP1]STOMGTCOD  (I)  = [M:PKP1]STOMGTCOD   (GLIG_PKP1)
    [M:PKP1]PCKSTKFLG  (I)  = [M:PKP1]PCKSTKFLG   (GLIG_PKP1)
    [M:PKP1]PCKSERFLG  (I)  = [M:PKP1]PCKSERFLG   (GLIG_PKP1)                                      # hcb 110327-pck
    [M:PKP1]SERMGTCOD  (I)  = [M:PKP1]SERMGTCOD   (GLIG_PKP1)                                      # hcb 110327-pck
    [M:PKP1]NBCOL      (I)  = 1                                                                    # hcb 110327-pck aml

   [M:PKP1]NBDETAIL   (I)  = [M:PKP1]NBDETAIL    (GLIG_PKP1)

    [M:PKP1]NETWEI     (I)  = [M:PKP1]QTYSTU      (I) * [F:ITM]ITMWEI
    [M:PKP1]NETWEIPCK  (I)  = [M:PKP1]NETWEI      (I) * [M:PKP1]LIGUNTWEI(I)
    [M:PKP1]LIGWEU     (I)  = [M:PKP1]LIGWEU      (GLIG_PKP1)
    [M:PKP1]WEU        (I)  = [M:PKP3]WEU
    [M:PKP1]PCKLEN     (I)  = [M:PKP3]PCKLEN
    [M:PKP1]PCKWID     (I)  = [M:PKP3]PCKWID
    [M:PKP1]PCKHEI     (I)  = [M:PKP3]PCKHEI
    [M:PKP1]DIU        (I)  = [M:PKP3]DIU
    [M:PKP1]VOL        (I)  = [M:PKP3]VOL
    [M:PKP1]VOU        (I)  = [M:PKP3]VOU
    [M:PKP1]VCRLIN     (I)  = [M:PKP1]VCRLIN      (GLIG_PKP1)
    [M:PKP1]SPHTEX     (I)  = [M:PKP1]SPHTEX      (GLIG_PKP1)
    If [M:PKP1]PCKSERFLG (GLIG_PKP1) = 2 & [M:PKP1]SERMGTCOD (GLIG_PKP1) = 4 & [M:PKP1]IDETAIL (GLIG_PKP1)  = 0  # hcb 110327-pck
       [M:PKP1]MODFLG     (I)  = 0                                                                               # hcb 110327-pck
    Else                                                                                                         # hcb 110327-pck
       [M:PKP1]MODFLG     (I)  = 2
    Endif                                                                                                        # hcb 110327-pck
    [M:PKP1]PACFLG     (I)  = [M:PKP1]PACFLG      (GLIG_PKP1)
    [M:PKP1]VCRLIN     (I)  = [M:PKP1]VCRLIN      (GLIG_PKP1)
    [M:PKP1]PACQTYSTU  (I)  = [M:PKP1]PACQTYSTU   (GLIG_PKP1)
    [M:PKP1]UNTWEI     (I)  = [M:PKP1]UNTWEI      (GLIG_PKP1)
    [M:PKP1]WEUSDD     (I)  = [M:PKP1]WEUSDD      (GLIG_PKP1)
    [M:PKP1]WLLIG      (I)  = [M:PKP1]WLLIG       (GLIG_PKP1) + 1
    [M:PKP1]PACNUM_AV  (I)  = [M:PKP1]PACNUM_AV   (GLIG_PKP1)
    [M:PKP1]GROWEI     (I)  = [M:PKP1]NETWEIPCK   (I) + [M:PKP1]PCKWEI(I)
    If [M:PKP1]STOMGTCOD  (I)  <  2 |
&      [M:PKP1]PCKSTKFLG  (I)  <> 2 |
&      [M:PKP1]NBDETAIL   (I)  <  2
&      [M:PKP1]IDETAIL    (I)  = 1
    Else
       [M:PKP1]IDETAIL    (I)  = 2
    Endif
#                                                                                                  # hcb 110327-pck deb
    If [M:PKP1]IDETAIL (GLIG_PKP1) = 4
       [M:PKP1]IDETAIL (I) = 3
    Endif
#                                                                                                  # hcb 110327-pck fin
    J += 1
   # Quantité du dernier colis
    If J = [M:PKP3]NBCOL
       [M:PKP1]QTYSAU     (I) = [M:PKP1]QTY         (GLIG_PKP1) - [M:PKP3]QTPCOL*([M:PKP3]NBCOL-1)
       [M:PKP1]QTY        (I) = [M:PKP1]QTYSAU      (I)
       [M:PKP1]QTYSAUSTU  (I) = [M:PKP1]QTYSAU      (I)*[M:PKP1]SAUSTUCOE  (I)
       Call QTEARR([M:PKP1]QTYSAUSTU(I),[M:PKP1]STU (GLIG_PKP1)) From TRTDIV
       [M:PKP1]QTYSTU     (I)  = [M:PKP1]QTYSAUSTU  (I)
       [M:PKP1]NETWEI     (I)  = [M:PKP1]QTYSTU     (I) * [F:ITM]ITMWEI
       [M:PKP1]NETWEIPCK  (I)  = [M:PKP1]NETWEI     (I) * [M:PKP1]LIGUNTWEI(I)
       [M:PKP1]GROWEI     (I)  = [M:PKP1]NETWEIPCK  (I) + [M:PKP1]PCKWEI   (I)    # hcb 73385
     Endif
Next I

# Suppression de la ligne initiale
Dela GLIG_PKP1,1 [M:PKP1]NBLIG
[M:PKP1]NBLIG  -= 1

#                    hcb 91325 deb
If [M:PKP3]NBCOL > 1
   Affzo [M:PKP1]
Else
   Affzo [M:PKP1]ITMREF     (GLIG_PKP1)
   Affzo [M:PKP1]ITMDES1    (GLIG_PKP1)
   Affzo [M:PKP1]QTYSAU     (GLIG_PKP1)
   Affzo [M:PKP1]SAU        (GLIG_PKP1)
   Affzo [M:PKP1]SAUSTUCOE  (GLIG_PKP1)
   Affzo [M:PKP1]QTYSAUSTU  (GLIG_PKP1)
   Affzo [M:PKP1]STU        (GLIG_PKP1)
   Affzo [M:PKP1]QTY        (GLIG_PKP1)
   Affzo [M:PKP1]QTYSTU     (GLIG_PKP1)
   Affzo [M:PKP1]PCK        (GLIG_PKP1)
   Affzo [M:PKP1]PACSEQ     (GLIG_PKP1)
   Affzo [M:PKP1]PACNUM     (GLIG_PKP1)
   Affzo [M:PKP1]SCCCOD     (GLIG_PKP1)
   Affzo [M:PKP1]LBLFMT     (GLIG_PKP1)
   Affzo [M:PKP1]PCKWEI     (GLIG_PKP1)
   Affzo [M:PKP1]LIGWEU     (GLIG_PKP1)
   Affzo [M:PKP1]NETWEI     (GLIG_PKP1)
   Affzo [M:PKP1]GROWEI     (GLIG_PKP1)
   Affzo [M:PKP1]WEU        (GLIG_PKP1)
   Affzo [M:PKP1]PCKLEN     (GLIG_PKP1)
   Affzo [M:PKP1]PCKWID     (GLIG_PKP1)
   Affzo [M:PKP1]PCKHEI     (GLIG_PKP1)
   Affzo [M:PKP1]PCKCAP     (GLIG_PKP1)
   Affzo [M:PKP1]DIU        (GLIG_PKP1)
   Affzo [M:PKP1]VOL        (GLIG_PKP1)
   Affzo [M:PKP1]VOU        (GLIG_PKP1)
   Affzo [M:PKP1]VCRLIN     (GLIG_PKP1)
Endif
#                    hcb 91325 fin
FIN=1

Return

#########################################################################
$FINSAI

#f [M:SPK2]PACSEQ(GLIG_PKP1) = 0
#  Raz GBOUT3                     : # Annulation colisage
#lse
#  Raz GBOUT1                     : # Colisage manuel
#  Raz GBOUT2                     : # Colisage automatique
#ndif

mkstat=4

Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran PKP3) 12/09/2006 16:31:01 (HCB)
######################################################################################

Subprog AM_PCK(VALEUR)
Variable Char    VALEUR()
If  [F:TPA]PCK <> VALEUR
    Read [TPA]TPA0=VALEUR
    If fstat
       Raz [F:TPA]
    Endif
Endif
[M:PKP1]LIGUNTWEI (GLIG_PKP1) = 1
If [M:PKP1]WEUSDD (GLIG_PKP1) <> [F:TPA]WEU
# Conversion poids unitaire de unité poids liv en unité poids colis
       Call SCONV_TCO([M:PKP1]WEUSDD(GLIG_PKP1),[F:TPA]WEU,[M:PKP1]LIGUNTWEI (GLIG_PKP1)) From TRTVENQTE
Endif

[M:PKP3]PCKWEI      = [F:TPA]PCKWEI
[M:PKP3]VOL         = [F:TPA]VOL
[M:PKP3]WEU         = [F:TPA]WEU
[M:PKP3]VOU         = [F:TPA]VOU
[M:PKP3]PCKLEN      = [F:TPA]PCKLEN
[M:PKP3]PCKWID      = [F:TPA]PCKWID
[M:PKP3]PCKHEI      = [F:TPA]PCKHEI
[M:PKP3]DIU         = [F:TPA]DIU
[M:PKP3]LBLFMT      = [F:TPA]LBLFMT
If GVCRTYP = 4 & [F:TPA]LBLFMT = ""
   [M:PKP3]LBLFMT = GDOCNAM
Endif

Affzo [M:PKP3]10
Affzo [M:PKP3]LBLFMT

End

Subprog C_QTPCOL(VALEUR)
Variable Decimal VALEUR
If VALEUR > [M:PKP3]QTY
   mkstat = 2
Endif

End

Subprog AM_QTPCOL(VALEUR)
Variable Decimal VALEUR
[M:PKP3]NBCOL = int([M:PKP3]QTY/VALEUR)
If mod([M:PKP3]QTY,VALEUR) <> 0
   [M:PKP3]NBCOL += 1
Endif
[M:PKP3]PACSEQDEB = max([M:PKP1]PACSEQ(0..[M:PKP1]NBLIG-1)) + 1
[M:PKP3]PACSEQFIN = [M:PKP3]PACSEQDEB + [M:PKP3]NBCOL - 1
Affzo [M:PKP3]20
End

