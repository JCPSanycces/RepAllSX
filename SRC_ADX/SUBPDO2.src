# Gestion du masque PDSYSOH

######################################################################################
## Clic droit Pièce sur le bon de préparation
######################################################################################
Subprog IB_NBPRH
  GBOUT2 = mess(662,197,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESPRH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif

# MGG X3-44960 Quantity to invoice on sales order line status inquiry
  If(clalev([M:SOH0])>0)
    If [M:SOH0]SOHCAT=1
          Call INV_QTY_VISB
    Endif
  Endif
  # END MGG X3-44960 Quantity to invoice on sales order line status inquiry
End

# MGG X3-44960 Quantity to invoice on sales order line status inquiry
Subprog INV_QTY_VISB
  If [M:PDO2]DLVFLG=2
    Chgfmt [M:PDO2]OINQTY With "-N:"  + num$(type([M:PDO2]OINQTY)) + "B" # Hide
  Else
    Chgfmt [M:PDO2]OINQTY With "+N:"  + num$(type([M:PDO2]OINQTY)) + "B" # Hide
  Endif
End
# END MGG X3-44960 Quantity to invoice on sales order line status inquiry

Subprog B2_NBPRH
Local Integer NOL
  Filter [F:PRH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PDO2]PRHNUM(NOL)
  Call OBJET("PRH",[M:PDO2]PRHNUM(NOL),"") From GOBJET
  [M:PDO2]PRHNUM(NOL) = SAV_VCRNUM

  GCONSULT = 0
End


######################################################################################
## Clic droit Pièce sur la livraison
######################################################################################
Subprog IB_NBSDH
  GBOUT2 = mess(129,197,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESSDH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBSDH
Local Integer NOL
  Filter [F:SDH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PDO2]SDHNUM(NOL)
  Call OBJET("SDH",[M:PDO2]SDHNUM(NOL),"") From GOBJET
  [M:PDO2]SDHNUM(NOL) = SAV_VCRNUM

  GCONSULT = 0
End

######################################################################################
## Clic droit Pièce sur la facture
######################################################################################
Subprog IB_NBSIH
  If [M:PDO2]INVTYP(nolign-1)=1 or [M:PDO2]INVTYP(nolign-1)=5 Then
    GBOUT2 = mess(55,198,1)
  Elsif [M:PDO2]INVTYP(nolign-1)=2 Then
    GBOUT2 = mess(02,267,1)
  Endif
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESSIH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBSIH
Local Char    NOM_TYP
Local Integer NOL

  Filter [F:SIH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PDO2]NUM(NOL)
  NOM_TYP = ""
  If [M:PDO2]INVTYP(NOL)=1 or [M:PDO2]INVTYP(NOL)=5 Then
    NOM_TYP = "1"
  Elsif [M:PDO2]INVTYP(NOL)=2 Then
    NOM_TYP = "2"
  Endif
  Call OBJET("SIH",[M:PDO2]NUM(NOL),NOM_TYP) From GOBJET
  [M:PDO2]NUM(NOL) = SAV_VCRNUM

  GCONSULT = 0
End


######################################################################################

