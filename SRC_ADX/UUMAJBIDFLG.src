#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UTITRC2   Utilitaire de récupération du bug 39391    Module Tronc commun #
# ------------------------------------------------------------------------ #
# Problème à résoudre :                                                    #
#   Initialiser la valeur du champ BIDNUMFLG si nécessaire                 #
############################################################################

Call MAJ_UTITRC2
End

Subprog MAJ_UTITRC2
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTITRC2") From SAIDOS
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTITRC2 : Utilitaire de màj indicateur RIB par défaut") From LECFIC
If DOSSIER<>"" Call EXE_UTITRC2(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

Subprog EXE_UTITRC2(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(80), CLE2(15), CLE3(3), CRITERE(60), WNUM(21), WADR(30) : # Bug 50819 (old WADR(3))
Local Integer COMPTEUR, STOP
Local Integer  NBENR,    NBCOR,    CLE1,    WFLAG
#-----
Call ECR_TRACE("UTITRC2 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#

If clalev([F:BID]) =0  Local File =DOSSIER+".BID"         [BID] : Endif
If clalev([F:BPR]) =0  Local File =DOSSIER+".BPARTNER"    [BPR] : Endif
If clalev([F:CPY]) =0  Local File =DOSSIER+".COMPANY"     [CPY] : Endif
If clalev([F:FCY]) =0  Local File =DOSSIER+".FACILITY"    [FCY] : Endif
If clalev([F:AUS]) =0  Local File =DOSSIER+".AUTILIS"     [AUS] : Endif
If clalev([F:GAC]) =0  Local File =DOSSIER+".GACCOUNT"    [GAC] : Endif
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, CLE2, CLE3, NBENR, NBCOR, STOP
#-----
$BOUCLE_BPA
If  STOP=1
  CRITERE = 'BPATYP='+num$(CLE1)+' & BPANUM="'+CLE2+'" & BIDNUM>"'+CLE3+'"'
  STOP = 2
Elsif STOP=2
  CRITERE = 'BPATYP='+num$(CLE1)+' & BPANUM>"'+CLE2+'"'
  STOP = 3
Elsif STOP=3
  CRITERE = 'BPATYP>'+num$(CLE1)
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
Raz COMPTEUR
Trbegin [BID]
  For [BID] BID0 Where evalue(CRITERE)
    WNUM=num$([F:BID]BPATYP)-[F:BID]BPANUM-[F:BID]BIDNUM
    NBENR+=1
    Raz WADR
    Case [F:BID]BPATYP
      When 1 : #----- Tiers -----#
        If [F:BPR]BPRNUM<>[F:BID]BPANUM
          Read [BPR] BPR0=[F:BID]BPANUM   : If fstat  Raz [F:BPR] : Endif
        Endif
        WADR=[F:BPR]BIDNUM
      When 2 : #----- Société -----#
        If [F:CPY]CPY<>[F:BID]BPANUM
          Read [CPY] CPY0=[F:BID]BPANUM   : If fstat  Raz [F:CPY] : Endif
        Endif
        WADR=[F:CPY]BIDNUM
      When 3 : #----- Site -----#
        If [F:FCY]FCY<>[F:BID]BPANUM
          Read [FCY] FCY0=[F:BID]BPANUM   : If fstat  Raz [F:BPR] : Endif
        Endif
        WADR=[F:FCY]BIDNUM
      When 4 : #----- Utilisateur -----#
        If [F:AUS]USR<>[F:BID]BPANUM
          Read [AUS] CODUSR=[F:BID]BPANUM : If fstat  Raz [F:AUS] : Endif
        Endif
        WADR=[F:AUS]BIDNUM
      When 5 : #----- Compte -----#
        If [F:GAC]ACC<>[F:BID]BPANUM
          Read [GAC] GAC0=[F:BID]BPANUM   : If fstat  Raz [F:GAC] : Endif
        Endif
        WADR=[F:GAC]BIDNUM
    Endcase
    If [F:BID]BIDNUM=WADR  WFLAG=2  Else  WFLAG=1 : Endif
    If [F:BID]BIDNUMFLG<>WFLAG
      If COMPTEUR=0
        Call ECR_TRACE("----- Début de transaction ("+WNUM+")",0) From GESECRAN
      Endif
      COMPTEUR+=1
      Readlock [BID] Curr
      If fstat 
        Call ECR_TRACE("File BID"-WNUM+", Error ="-num$(fstat),1) From GESECRAN
        GOK=0
      Else
        [F:BID]BIDNUMFLG=WFLAG
        Rewrite [BID]
        If fstat
          Call ECR_TRACE("File BID, Error ="-num$(fstat),1) From GESECRAN
          GOK=0
        Else
          Call ECR_TRACE(WNUM-"Indicateur BIDNUMFLG mis à"-num$(WFLAG),0) From GESECRAN
          NBCOR+=1
        Endif
      Endif
      If GOK=1
        COMPTEUR+=1
        If COMPTEUR>GMAXUPDTRS
          CLE1=[F:BID]BPATYP : CLE2=[F:BID]BPANUM : CLE3=[F:BID]BIDNUM : STOP=1 : Break
        Endif
      Else
        Break
      Endif
    Endif
  Next
  If GOK=0
    Rollback
    Call ECR_TRACE("----- Transaction abandonnée ("+WNUM+")",1) From GESECRAN
    Goto FIN_UTITRC2
  Endif
Commit
If COMPTEUR>0
  Call ECR_TRACE("----- Transaction validée ("+WNUM+")",0) From GESECRAN
Endif
If STOP  Goto BOUCLE_BPA : Endif
#----- Fin du traitement -----#
$FIN_UTITRC2
WMSG ="UTITRC2 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Close Local File [BID], [BPR], [CPY], [FCY], [AUS], [GAC]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call EXE_UTITRC2(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTITRC2(APPLI)
End



