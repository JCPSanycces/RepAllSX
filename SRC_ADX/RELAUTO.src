#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RELAUTO","DRELAUTO",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

$OUVRE
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:BPC])=0  : Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:BPS])=0  : Local File BPSUPPLIER [BPS]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif
If clalev([F:GSC])=0  : Local File GRPSAC     [GSC]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:GCU])=0  : Local File GRPCUR     [GCU]  : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:DUD2])=0 : Local File GACCDUDATE [DUD2] : Endif
If clalev([F:DUD3])=0 : Local File GACCDUDATE [DUD3] : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:SOI])=0  : Local File SOI        [SOI]  : Endif
If clalev([F:SOI2])=0 : Local File SOI        [SOI2] : Endif
If clalev([F:TCA])=0  : Local File TABCOUAFF  [TCA]  : Endif
If clalev([F:CPY2])=0 : Local File COMPANY    [CPY2] : Endif
If clalev([F:TAM])=0  : Local File TABPAM     [TAM]  : Endif
Return

$INIT
Gosub OUVRE
TMP = 1  : TRA = 1
Return

$INIT_DIA
If [M:DIA]CPY<>""
 Call LECMAINPLAN(1,[M:DIA]CPY,[M:DIA]COA) From CPTDIV
Else
 Local Integer STAT
 Call CNTCPYCOA(0,[M:DIA]COA,STAT) From CPTCNT
 STAT = 0
Endif
Return

$EXEC
Local Char RELDEB(GLONVCR)
Call RELAUTO(RELDEB)
PARAM(1) = RELDEB
Return

##########################################################################
Subprog RELAUTO(RELDEB)
#########################################################################
Variable Char    RELDEB()

Local Integer NBMAX
If clalev([M:REL0])=0 : Local Mask RELEVE [REL0] : Endif
NBMAX=dim([M:REL0]NUM) : If NBMAX<1 : End : Endif

Gosub DECLARE

Raz RELDEB, RELFIN

Local Mask RELEVE [REL]
If GSERVEUR :  [M:DIA]TRC=2 :  Endif

# Génération des relevés d'échéances
If !GSERVEUR & [M:DIA]TRC=2
 Call OUVRE_TRACE(mess(69,117,1)) From LECFIC
Endif

#################### Point d'entrée FILTRE ####################
Raz [L]FILTSPE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If [L]FILTSPE="" : [L]FILTSPE = "1=1" : Endif

If [M:DIA]ALLCPY<>2
 [L]SOCIETE = [M:DIA]CPY
 Gosub PREL From RELAUTO
 Call SETCUR(1,[L]SOCIETE,[L]DEVLOC) From CPTDIV
 Gosub TRT_SOCIETE
Else
 # On ne prend plus que les sociétés juridiques.
 Filter [F:CPY2] Where CPYLEGFLG=2
 For [F:CPY2]CPY1(1)
  [L]SOCIETE = [F:CPY2]CPY
  Gosub PREL From RELAUTO
  For [F:CPY2]CPY1
   [L]SOCIETE = [F:CPY2]CPY
   Call SETCUR(1,[L]SOCIETE,[L]DEVLOC) From CPTDIV
   Gosub TRT_SOCIETE
  Next
 Next
 Filter [F:CPY2]
Endif

If [L]RELDEB=""
 # Aucun relevé généré
 Call ECR_TRACE(mess(27,121,1),0) From GESECRAN
Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call FERME_TRACE From LECFIC
Endif

End


########################################################################
$PREL
If clalev([F:TAM2])=0  : Local File TABPAM     [TAM2]  : Endif
[L]NBPAM = nbrecord([F:TAM2])
If [L]NBPAM<=0 : Return : Endif

Local Decimal TBMT(1..NBPAM)
Local Char    TBPAM(GLONTAM)(1..NBPAM) , TBCODREL(20)(1..NBPAM)
Local Libelle FLMT(1..NBPAM)

## Tableau des codes relevé
Call LEC_CPY([L]SOCIETE) From CPTLEC
GCURLEG  = [F:CPY]LEG

[L]NBPAM=0
Filter [TAM2] Where LEG=GCURLEG | LEG="" Order By Key CLE=PAM Asc ; LEG Desc
For [TAM2]CLE(1)
 If [F:TAM2]SOI<>""
  [L]NBPAM+=1
  [L]TBPAM([L]NBPAM)    = [F:TAM2]PAM
  [L]TBCODREL([L]NBPAM) = [F:TAM2]SOI
 Endif
Next
Filter [TAM2]
Return

########################################################################
# Traitement d'une société
$TRT_SOCIETE
Call PARAM([L]SOCIETE,"SOICPT",GDIV(0)) From ADOVAL  :# Comptabilisation relevé
Call PARAM([L]SOCIETE,"SOISAC",GDIV(1)) From ADOVAL  :# Relevé mono-colectif
Call PARAM([L]SOCIETE,"SOIFCY",GDIV(2)) From ADOVAL  :# Relevé mono-site
Call PARAM([L]SOCIETE,"SOIBPR",GDIV(3)) From ADOVAL  :# Tiers du relevé

CRITERE = "DUDSTA=2 & SOINUM='' & SOI=2 & CPY='"+[L]SOCIETE+"'"

# Site
Raz [L]CRITFCY
If [M:DIA]ALLFCY=1
 CRITFCY = "FCY='"+[M:DIA]FCY+"'"
 CRITERE -= "&"-[L]CRITFCY
Endif

# Collectif
Raz [L]CRITSAC
If [M:DIA]ALLSAC<>2
 If [M:DIA]GRPSAC<>"" :# Groupe collectif
  Call LECMAINPLAN(1,[L]SOCIETE,OCOA) From CPTDIV
  Filter [GSC] Where [F:GSC]COA=OCOA & [F:GSC]GRU=[M:DIA]GRPSAC
  Raz [L]CRITGRPSAC
  For [F:GSC]GSC0
   I+=1 : [L]CRITGRPSAC(I) = [F:GSC]SAC
  Next
  Filter [GSC]
  CRITSAC -= "find(SAC,[L]CRITGRPSAC)"
 Else                 :# Collectif
  [L]CRITSAC = "SAC='"+[M:DIA]SAC+"'"
 Endif
 If [L]CRITSAC<>""
  CRITERE -= "&"-[L]CRITSAC
 Endif
Endif

# Devise
If [M:DIA]ALLCUR=1
 If [M:DIA]GRPCUR<>""
  If [F:GCU]GRP<>[M:DIA]GRPCUR
   Read [F:GCU]GCU0=[M:DIA]GRPCUR
  Endif
  Raz [L]CRITGRPCUR
  For I = 1 To [F:GCU]NBRCUR
   If [L]CRITGRPCUR<>""
    [L]CRITGRPCUR += ","
   Endif
   [L]CRITGRPCUR += "'"+[F:GCU]CUR+"'"
  Next I
  CRITERE+=" & find(CUR,"+[L]CRITGRPCUR+")"
 Else
  CRITERE+=" & CUR='"+[M:DIA]CUR+"'"
 Endif
Endif

## Code relevé
## Un code relevé particulier -> uniquement les modes de règlements rattachés à ce code relevé
## Tous codes relevés         -> uniquement les modes de règlements rattachés à un code relevé
Raz [L]CRITPAM, [L]CRIT_PAM
If [M:DIA]ALLSOI=1  :# Un code relevé particulier
 [L]CRITPAM="find(PAM"
 For I=1 To [L]NBPAM
  If [L]TBCODREL(I) = [M:DIA]SOICOD
   [L]CRITPAM+=",'"+[L]TBPAM(I)+"'"
  Endif
 Next I
 If [L]CRITPAM="find(PAM"
  Return
 Else
  [L]CRITPAM+=")"
 Endif
Endif
If [L]CRITPAM<>""
 ## Filtre sur les modes de règlements dans une variable à part
 #[L]CRITERE -= "&"-[L]CRITPAM
 [L]CRIT_PAM = [L]CRITPAM
Else
 [L]CRIT_PAM = "1=1"
Endif

# Date d'échéance maxi
If [M:DIA]DATMAX<>[0/0/0]
 [L]CRITERE -= "& DUDDAT <= ["+format$(GFMD,[M:DIA]DATMAX)+"]"
Endif

# Echéances soldées?
If [M:DIA]SOLDON<>2
 [L]CRITERE -= "& AMTCUR*(AMTCUR-PAYCUR-TMPCUR)>0"
Endif

If [M:DIA]BPR<>""
 Case GDIV(3)
  When "1" : [L]CRIT_BPR = "BPRPAY='"+[M:DIA]BPR+"'"
  When "2" : [L]CRIT_BPR = "BPR='"+[M:DIA]BPR+"'"
 Endcase
 [L]TIERS = [M:DIA]BPR
 Gosub TRT_TIERS
Else
 If [M:DIA]TYPBPR=1   :# Clients uniquement
  For [F:BPC] Where SOIPER=[M:DIA]SOIPER With Nohint
   Case GDIV(3)
    When "1" : [L]CRIT_BPR = "BPRPAY='"+[F:BPC]BPCNUM+"'"
    When "2" : [L]CRIT_BPR = "BPR='"+[F:BPC]BPCNUM+"'"
   Endcase
   [L]TIERS = [F:BPC]BPCNUM
   Gosub TRT_TIERS
  Next
 Else
  For [F:BPS]
   Case GDIV(3)
    When "1" : [L]CRIT_BPR = "BPRPAY='"+[F:BPS]BPSNUM+"'"
    When "2" : [L]CRIT_BPR = "BPR='"+[F:BPS]BPSNUM+"'"
   Endcase
   [L]TIERS = [F:BPS]BPSNUM
   Gosub TRT_TIERS
  Next
 Endif
Endif
Filter [F:DUD]
Return

########################################################################
# Traitement d'un tiers dans une société
$TRT_TIERS
Raz [L]NBRELTIERS
Case GDIV(3)
 When "1"
  Filter [DUD] Where evalue(CRITERE) & evalue(CRIT_BPR) & evalue(CRIT_PAM)
& Order By Key CLE = BPRPAY;SOINUM;ACCNUM;DUDLIG
 When "2"
  Filter [DUD] Where evalue(CRITERE) & evalue(CRIT_BPR) & evalue(CRIT_PAM)
& Order By Key CLE = BPR;SOINUM;ACCNUM;DUDLIG
Endcase

Read [DUD]CLE First
While fstat<=2
 [L]OK=1
 ## Bornes sur date facture
 If [F:HAE]TYP<>[F:DUD]TYP | [F:HAE]NUM<>[F:DUD]NUM
  Read [F:HAE]HAE0=[F:DUD]TYP;[F:DUD]NUM
 Else
  fstat=0
 Endif
 If fstat=0 & [F:HAE]FLGREP<>2
  If [M:DIA]DATFAKD<>[0/0/0] & [F:HAE]ACCDAT<[M:DIA]DATFAKD : [L]OK=0
  Elsif [M:DIA]DATFAKF<>[0/0/0] & [F:HAE]ACCDAT>[M:DIA]DATFAKF : [L]OK=0
  Endif
 Else
  [L]OK=0
 Endif

 # Modes de règlement
 If [L]OK
  Raz [L]CRITPAM2, [L]CRIT_PAM2
  I=find([F:DUD]PAM,[L]TBPAM)
  If I
   [L]COD=[L]TBCODREL(I)
   [L]CRITPAM2="find(PAM"
   For I = 1 To [L]NBPAM
    If [L]TBCODREL(I)=[L]COD
     [L]CRITPAM2 += ",'"+[L]TBPAM(I)+"'"
    Endif
   Next I
   If [L]CRITPAM2="find(PAM"
    [L]OK=0
   Else
    [L]CRITPAM2 += ")"
   Endif
  Else
   [L]OK=0
  Endif
 Endif

 #Site authorization
 If GUSRFCY(1)<>"\" & !find([F:DUD]FCY,GUSRFCY(1..GNBAUZ))
  [L]OK=0
 Endif

 # Echéance OK
 If [L]OK
  [L]CRITERE2 = "DUDSTA=2 & SOINUM='' & SOI=2"

  Case GDIV(3)
   When "1" : [L]CRITERE2 -= "& BPRPAY='"+[F:DUD]BPRPAY+"'"
   When "2" : [L]CRITERE2 -= "& BPR='"+[F:DUD]BPR+"'"
  Endcase

  [L]CRITERE2 -= "& CPY='"+[F:DUD]CPY+"'"
  [L]CRITERE2 -= "& CUR='"+[F:DUD]CUR+"'"

  If GDIV(0)="2" | GDIV(2)="1" :# Mono-site
   [L]CRITERE2 -= "& FCY='"+[F:DUD]FCY+"'"
  Elsif [L]CRITFCY<>""
   [L]CRITERE2 -= "&"-[L]CRITFCY
  Endif

  If GDIV(0)="2" | GDIV(1)="1"  :# Mono-collectif
   [L]CRITERE2 -= "& SAC='"+[F:DUD]SAC+"'"
  Elsif [L]CRITSAC<>""
   [L]CRITERE2 -= "&"-[L]CRITSAC
  Endif

  If [L]CRITPAM2<>""
   ## Filtre sur les modes de règlements dans une variable à part
   #[L]CRITERE2 -= "&"-[L]CRITPAM2
   [L]CRIT_PAM2 = [L]CRITPAM2
  Else
   [L]CRIT_PAM2 = "1=1"
  Endif

  If [M:DIA]RELDATECH=2  :# 1 relevé par date d'échéance
   [L]CRITERE2 -= "& DUDDAT=["+format$(GFMD,[F:DUD]DUDDAT)+"]"
  Endif

  # Date d'échéance maxi
  If [M:DIA]DATMAX<>[0/0/0]
   [L]CRITERE2 -= "& DUDDAT <= ["+format$(GFMD,[M:DIA]DATMAX)+"]"
  Endif

  # Echéances soldées?
  If [M:DIA]SOLDON<>2
   [L]CRITERE2 -= "& AMTCUR*(AMTCUR-PAYCUR-TMPCUR)>0"
  Endif

  Case GDIV(3)
   When "1"
    Filter [DUD2] Where evalue(CRITERE2) & evalue(CRIT_PAM2) & evalue([L]FILTSPE)
&   Order By Key CLE = BPRPAY;SOINUM;ACCNUM;DUDLIG
   When "2"
    Filter [DUD2] Where evalue(CRITERE2) & evalue(CRIT_PAM2) & evalue([L]FILTSPE)
&   Order By Key CLE = BPR;SOINUM;ACCNUM;DUDLIG
  Endcase

  ######################################################################################
  ## Relevé à reporter?
  ##  PHASE I, on regarde jusqu'a 10 (NB_REL_REP) relevés par Tiers à reporter
  ##           On charge les variables pour le cas SOICPT=2
  [L]REPORT_REL = 0
  [L]CRITSAC2   = "1=1"
  [L]CRITFCY2   = "1=1"
  If GDIV(1)="1" : # SOISAC, Mono-collectif
   [L]CRITSAC2 = "SAC=[F:DUD]SAC"
  Endif
  If GDIV(2)="1" : # SOIFCY, Mono-site
   [L]CRITFCY2 = "FCY=[F:DUD]FCY"
  Endif
  If GDIV(0)="1"  :# Pas de comptabilisation
   Filter [F:SOI2] Where FLGFWD=2 & FWDSOI=""
&                      & BPR=[L]TIERS & CUR=[F:DUD]CUR
&                      & CPY=[F:DUD]CPY
&                      & evalue([L]CRITSAC2) & evalue([L]CRITFCY2)
  Else            :# Comptabilisation
   Filter [F:SOI2] Where FLGFWD=2 & FWDSOI="" & FLGPST=2
&                      & BPR=[L]TIERS & CUR=[F:DUD]CUR
&                      & CPY=[F:DUD]CPY
&                      & evalue([L]CRITSAC2) & evalue([L]CRITFCY2)
  Endif

  Raz [L]REL_NUM , [L]TYP_REL , [L]NUM_REL , [L]REL_FLG
  For [F:SOI2]SOI3
   If GDIV(0)="2"  :# Comptabilisation
    [L]REL_NUM([L]REPORT_REL) = [F:SOI2]SOINUM
    [L]TYP_REL([L]REPORT_REL) = [F:SOI2]TYPSOI
    [L]NUM_REL([L]REPORT_REL) = [F:SOI2]NUMSOI
   Endif
   [L]REPORT_REL+=1 : If [L]REPORT_REL=[L]NB_REL_REP : Break(2) : Endif
  Next
  Filter [F:SOI2]
  ######################################################################################

  Raz TBMT , FLMT
  Call DEBTRANS From GLOCK
  Gosub TR1
  If GOK<1 : Break : Endif
 Endif

 Read [DUD]CLE Next
Wend
Filter [F:SOI2] : # Pour cause de Break !
Filter [F:DUD2]
If GOK<1 : Return : Endif
If [L]NBRELTIERS<>0
 # Nombre de relevés pour ... (société ...)
 Call ECR_TRACE(mess(47,121,1)-[L]TIERS-"("+mess(2,116,1)-[L]SOCIETE
&               +") :"-num$([L]NBRELTIERS)+"\",0) From GESECRAN
Endif
Return

$TR1
Trbegin [SOI] , [DUD2] , [SOI2] , [DUD3]
 Raz [F:SOI]
 Raz [L]MTRELEVE
 For [F:DUD2]CLE
  Readlock [DUD2] Curr
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE" : Break
  Endif

  ######################################################################################
  ## Echéance de relevé à reporter?
  ##  PHASE II, on regarde dans les relevés de la PHASE I, s'il y en a un
  ##            qui 'colle' à l'échéance, Uniquement pour Comptabilisation SOICPT=2
  ##            car sinon on reporte tout les relevés en PHASE III.
  If [L]REPORT_REL & GDIV(0)="2"
   [L]REPORT_ECH = 0 : I = 0
   While [L]REL_NUM(I)<>"" & [L]REPORT_ECH=0
    If [L]REL_FLG(I)=0 & [L]TYP_REL(I)=[F:DUD2]TYP & [L]NUM_REL(I)=[F:DUD2]NUM
     [L]REL_FLG(I)=1 : [L]REPORT_ECH=1
    Endif
    I+=1 : If I=[L]NB_REL_REP : Break : Endif
   Wend
  Endif
  ######################################################################################

  [L]OK=1

  If ![L]REPORT_ECH
   If [F:HAE]TYP<>[F:DUD2]TYP | [F:HAE]NUM<>[F:DUD2]NUM
    Read [F:HAE]HAE0=[F:DUD2]TYP;[F:DUD2]NUM
   Else
    fstat=0
   Endif
   If fstat=0 & [F:HAE]FLGREP<>2
    If [M:DIA]DATFAKD<>[0/0/0] & [F:HAE]ACCDAT<[M:DIA]DATFAKD : [L]OK=0
    Elsif [M:DIA]DATFAKF<>[0/0/0] & [F:HAE]ACCDAT>[M:DIA]DATFAKF : [L]OK=0
    Endif
   Else
    [L]OK=0
   Endif
  Endif

  If [L]OK
   If [F:DUD2]CUR=[M:DIA]CURRELMT
    MT=[F:DUD2]AMTCUR
   Elsif [L]DEVLOC=[M:DIA]CURRELMT
    MT=[F:DUD2]AMTLOC
   Else
    Call CONVERT([F:DUD2]CUR,[M:DIA]CURRELMT,DEVLOC,[F:HAE]TYPRAT
&               ,[F:DUD2]DUDDAT,[F:DUD2]AMTCUR,MT,STAT) From TRTDEV
    If STAT : # Pas de cours de devises CUR -> [M:DIA]CURrelMT (DUDDAT)
     Call ECR_TRACE(mess(16,114,1)-[F:DUD2]CUR-"->"-[M:DIA]CURRELMT
&                  -"("+format$("D:"+GFMDAT,[F:DUD2]DUDDAT)-")",1) From GESECRAN
     OK = 0
    Endif
   Endif
  Endif

  If [L]OK
   # N° de relevé
   If [F:SOI]SOINUM=""
    Raz [L]FCY
    If GDIV(0)="2" | GDIV(2)="1"  :# Mono-site
     [L]FCY = [F:DUD]FCY
    Elsif [M:DIA]ALLFCY=1
     [L]FCY = [M:DIA]FCY
    Else
     [L]FCY = [F:DUD]CPY
    Endif
    COMPTREG = ""
    Call LECTCA(3,OKTCA) From SUBTCA
    If OKTCA : COMPTREG = [F:TCA]CODNUM(4) : Endif
    If COMPTREG="" : COMPTREG = "REL" : Endif
    # Déplace l'initialisation de SOIDAT pour l'attribution du compteur
    If [M:DIA]SOIDAT<>[0/0/0]
     [F:SOI]SOIDAT=[M:DIA]SOIDAT
    Else
     [F:SOI]SOIDAT = datesyst
    Endif
    Call NUMERO(COMPTREG,[L]FCY,[F:SOI]SOIDAT,"",[F:SOI]SOINUM,STAT) From SUBANM
    If GOK<1 | STAT
     If STAT
      # Problème lors de la récupération du compteur
      Gosub MESSAGE From SUBANM
      Call ECR_TRACE(mess(104,117,1)-"("+COMPTREG+") : "+MESSA,1) From GESECRAN
     Endif
     GOK=0 : Break
    Endif
    [L]TOTRELLOC=0
   Endif

   I=find([F:DUD2]PAM,[L]TBPAM)
   If I : FLMT(I) = 1 : Endif
   If [F:DUD2]SNS=1
    [F:SOI]AMTCUR += [F:DUD2]AMTCUR
    [L]TOTRELLOC  += [L]MT
    If I : TBMT(I)+= [F:DUD2]AMTCUR : Endif
   Else
    [F:SOI]AMTCUR -= [F:DUD2]AMTCUR
    [L]TOTRELLOC  -= [L]MT
    If I : TBMT(I)-= [F:DUD2]AMTCUR : Endif
   Endif
     If [M:DIA]DATECHE=[0/0/0]
    [F:SOI]DUDDAT = max([F:SOI]DUDDAT,[F:DUD2]DUDDAT)
   Endif
   [F:SOI]DUDNBR += 1
   [F:DUD2]SOINUM = [F:SOI]SOINUM
   Rewrite [F:DUD2]
   If fstat
    GOK=0 : Call FSTA("DUD2") From GLOCK : Break
   Endif
   Call HISTOECH("DUD2",1,[F:SOI]SOIDAT)From MODECHE
   [L]MTRELEVE += ([F:DUD2]AMTCUR-[F:DUD2]PAYCUR-[F:DUD2]TMPCUR)*[F:DUD2]SNS
   If [F:SOI]DUDNBR=NBMAX : Break : Endif
  Endif
 Next  :# [DUD2]
 If GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 If [F:SOI]DUDNBR<[M:DIA]RELNBECH
  Goto AB_TR1
 Endif

 [F:SOI]BPR = [L]TIERS
 [F:SOI]CUR = [F:DUD]CUR
 [F:SOI]CPY = [F:DUD]CPY
 If GDIV(0)="2" | GDIV(2)="1" :# Mono-site
  [F:SOI]FCY = [F:DUD]FCY
 Elsif [M:DIA]ALLFCY=1
  [F:SOI]FCY = [M:DIA]FCY
 Endif
 If GDIV(0)="2" | GDIV(1)="1"  :# Mono-collectif
  [F:SOI]SAC = [F:DUD]SAC
 Elsif [M:DIA]ALLSAC=1 & [M:DIA]SAC<>""
  [F:SOI]SAC = [M:DIA]SAC
 Endif
 If [M:DIA]DATECHE<>[0/0/0]
  [F:SOI]DUDDAT=[M:DIA]DATECHE
 Endif
 ## Mode de règlement = celui dont montant échéance est le plus élevé
 For I=1 To dim([L]TBMT)
  If [L]FLMT(I)=1 & ([F:SOI]PAM="" | TBMT(I)>TBMT(J))
   [F:SOI]PAM=[L]TBPAM(I) : J=I
  Endif
 Next I
 If [M:DIA]SOICOD<>""
  [F:SOI]SOICOD=[M:DIA]SOICOD  :# Code relevé saisi dans critères
 Else
  [F:SOI]SOICOD=[L]COD         :# Code relevé de l'échéance en cours
 Endif
 [F:SOI]FLGPST=1

 #########################################################################################
 ## Report des relevés effectif
 ##  PHASE III, si comptabilisation, on reporte uniquement les relevés dont
 ##             l'échéance correspond maximum 10, sinon on les reporte tous
 ##  Si pas de comptabilisation, on vire le relevé d'origine
 [F:SOI]FLGFWDSOI=1
 If [L]REPORT_REL :# Relevé à reporter
  If GDIV(0)="2" :# Comptabilisation
   I=0
   While [L]REL_NUM(I)<>""
    If [L]REL_FLG(I)=1
     Readlock [F:SOI2]SOI0=[L]REL_NUM(I)
     If fstat=1
      GOK=-1 : GLOCK="$SOI"-[L]REL_NUM(I) : Break
     Elsif fstat
      GOK=0 : Call RSTA("SOI2",[L]REL_NUM(I)) From GLOCK : Break
     Endif
     [F:SOI2]FWDSOI = [F:SOI]SOINUM
     Rewrite [F:SOI2]
     If fstat
      GOK=0 : Call FSTA("SOI2") From GLOCK : Break
     Endif
     [F:SOI]FLGFWDSOI=2
    Endif
    I+=1 : If I=[L]NB_REL_REP : Break : Endif
   Wend
   If GOK=-1  : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
  ####
  Else :# Pas de comptabilisation
  ####
   [F:SOI]FLGFWDSOI = 1    : # On va virer le relevé d'origine !

   [L]CRITSAC2   = "1=1"
   [L]CRITFCY2   = "1=1"
   If GDIV(1)="1" : # SOISAC, Mono-collectif
    [L]CRITSAC2 = "SAC=[F:SOI]SAC"
   Endif
   If GDIV(2)="1" : # SOIFCY, Mono-site
    [L]CRITFCY2 = "FCY=[F:SOI]FCY"
   Endif
   Filter [F:SOI2] Where FLGFWD=2 & FWDSOI=""
&                      & BPR=[F:SOI]BPR & CUR=[F:SOI]CUR
&                      & CPY=[F:SOI]CPY
&                      & evalue([L]CRITSAC2) & evalue([L]CRITFCY2)
   For [F:SOI2]SOI3
    Readlock [F:SOI2] Curr
    If fstat=1
     GOK=-1 : GLOCK="$SOI"-num$([F:SOI2]SOINUM) : Break
    Elsif fstat
     GOK=0 : Call RSTA("SOI2",num$([F:SOI2]SOINUM)) From GLOCK : Break
    Endif
    # A t'on assez de lignes pour reporter les échéances ?
    If [F:SOI2]DUDNBR+[F:SOI]DUDNBR<=NBMAX
     # il faut basculer les échéances sur nouveau relevé ! A condition qu'il y ait assez de ligne
     For [DUD3]DUD2 Where SOINUM=[F:SOI2]SOINUM
      Readlock [DUD3] Curr
      If fstat=1
       GOK=-1 : GLOCK="$GACCDUDATE" : Break(2)
      Endif
      ## Lock de la pièce
      SYMHAE = "HAE"+num$([F:DUD3]NUM)+"\"+num$([F:DUD3]TYP)
      Lock =SYMHAE
      If fstat : GOK=-1 : GLOCK="%"+SYMHAE : Break(2) : Endif

      [F:SOI]AMTCUR += [F:DUD3]AMTCUR*[F:DUD3]SNS

      If [F:DUD3]CUR=[M:DIA]CURRELMT
       MT=[F:DUD3]AMTCUR
      Elsif [L]DEVLOC=[M:DIA]CURRELMT
       MT=[F:DUD3]AMTLOC
      Else
       If [F:HAE]TYP<>[F:DUD3]TYP | [F:HAE]NUM<>[F:DUD3]NUM
        Read [F:HAE]HAE0=[F:DUD3]TYP;[F:DUD3]NUM
       Endif
       Call CONVERT([F:DUD3]CUR,[M:DIA]CURRELMT,DEVLOC,[F:HAE]TYPRAT
&                  ,[F:DUD3]DUDDAT,[F:DUD3]AMTCUR,MT,STAT) From TRTDEV
       If STAT : # Pas de cours de devises CUR -> [M:DIA]CURrelMT (DUDDAT)
        Call ECR_TRACE(mess(16,114,1)-[F:DUD3]CUR-"->"-[M:DIA]CURRELMT
&                    -"("+format$("D:"+GFMDAT,[F:DUD3]DUDDAT)-")",1) From GESECRAN
        OK = 0 : Break
       Endif
      Endif

      [L]TOTRELLOC  += [L]MT*[F:DUD3]SNS
      [L]MTRELEVE   += ([F:DUD3]AMTCUR-[F:DUD3]PAYCUR-[F:DUD3]TMPCUR)*[F:DUD3]SNS

      [F:DUD3]SOINUM = [F:SOI]SOINUM
      [F:SOI]DUDNBR += 1
      Rewrite [DUD3]
      If fstat
       GOK=0 : Call FSTA("DUD3") From GLOCK : Break(2)
      Endif
      Call HISTOECH("DUD3",1,[F:SOI]SOIDAT)From MODECHE
     Next : # [DUD3]

     Delete [SOI2]
     If fstat=1
      GOK = -1 : Call FSTA("SOI2") From GLOCK : Break
     Endif
    Endif : # If [F:SOI2]DUDNBR+[F:SOI]DUDNBR<=NBMAX
   Next : # [SOI2]
   Filter [F:SOI2]
   If GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
  Endif
 Endif
 #########################################################################################
 ## Le relevé est 'à reporter' si
 #   - on n'atteind pas le montant minimum de relevé
 #   - c'est un relevé créditeur client
 #   - c'est un relevé débiteur  fournisseur
 If ([M:DIA]RELMT<>0 & TOTRELLOC<[M:DIA]RELMT)
&  | (TOTRELLOC<0 & [M:DIA]TYPBPR=1) | (TOTRELLOC>0 & [M:DIA]TYPBPR<>1)
  [F:SOI]FLGFWD=2
 Else
  [F:SOI]FLGFWD=1
 Endif
 [F:SOI]BPRTYP = [M:DIA]TYPBPR
 If dim([F:SOI]CREDAT)>0 : [F:SOI]CREDAT = datesyst : Endif
 If dim([F:SOI]CREUSR)>0 : [F:SOI]CREUSR = GUSER : Endif

 GPOINT = "BEFWRISOI" : Gosub ENTREE From EXEFNC

 Write [F:SOI]
 If fstat
  GOK=0 : Call FSTA("SOI") From GLOCK : Goto AB_TR1
 Endif

 If [M:DIA]MAJON=2
  Filter [F:DUD2]
  Update [DUD2] Where SOINUM=[F:SOI]SOINUM
&               With PAM=[F:SOI]PAM,DUDDAT=[F:SOI]DUDDAT
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE" : Goto ROLL_TR1
  Elsif fstat>5
   GOK=0 : Call FSTA("DUD2") From GLOCK : Goto AB_TR1
  Endif
  Call HISTOECH("DUD2",1,[F:SOI]SOIDAT)From MODECHE
 Endif

Commit
[L]NBRELTIERS += 1 :# Nombre de relevés par tiers

Call LECTURE("TCU",[F:SOI]CUR,"") From CONTOBJ
# Relevé ... : ... échéances
Call ECR_TRACE(mess(42,117,1)-[F:SOI]SOINUM-":"
&              -num$([F:SOI]DUDNBR)-mess(48,121,1)
&              -"("+format$("N3:"+[F:TCU]CURFMT1,[L]MTRELEVE)
&              -[F:SOI]CUR+")"
&    ,0) From GESECRAN
If RELDEB="" : RELDEB=[F:SOI]SOINUM : Endif
[L]RELFIN = [F:SOI]SOINUM
Return

$ROLL_TR1
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

$DECLARE
Local Integer OK , I , STAT , REPORT_REL , REPORT_ECH , NBPAM, NBRELTIERS
Local Decimal TOTRELLOC , MT , MTRELEVE
Local Char    TIERS(GLONBPR) , RELFIN(GLONVCR) , SOCIETE(GLONCPY) , COD(10) , FCY(GLONFCY)
&             , CRITERE(255) , CRITERE2(255) , CRITPAM(255) , CRITPAM2(255) , CRIT_PAM(255), CRIT_PAM2(255)
&             , CRITGRPSAC(GLONSAC)(1..99), CRITGRPCUR(255) , CRITSAC(255) , CRITFCY(255) , MESSA(80), FILTSPE(255)
&             , CRIT_BPR(30), CRITSAC2(255), CRITFCY2(255)
&             , P1(30)(1..30) , P2(30)(1..30)
Local Char    SYMHAE(255)

Local Integer NB_REL_REP        : # Nbre de relevés maximum à reporter
[L]NB_REL_REP = NBMAX           : # Demande 25925

Local Char    REL_NUM(GLONVCR)([L]NB_REL_REP)  : # No relevé à reporter
Local Char    TYP_REL(GLONGTE)([L]NB_REL_REP)  : # Type de pièce du relevé à reporter
Local Char    NUM_REL(GLONVCR)([L]NB_REL_REP)  : # No   de pièce du relevé à reporter
Local Integer REL_FLG([L]NB_REL_REP)           : # Flag correspondance type de pièce/pièce avec Ech

Local Char DEVLOC(GLONCUR)                     : # Devise de référentiel générale principale
Local Char OCOA(GLONCOA)                       : # Code Plan du référentiel générale principale

Local Char    COMPTREG(GLONANM)
Local Integer OKTCA
Return

