######################################################################################
# Création
#     MABON - 20/08/12 - FQ81491 Phase 608 : changement de clé sur les dates début et fin
# Modifications :
#
######################################################################################

# Gestion du masque CHGEVADAT
Raz GPILOBJ , GNBMASKOUV
Call OBJET("EVA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

  Case ACTION
    When "INIT"     : Gosub INIT
    When "EXEC"     : Gosub EXEC
    When "INIT_DIA" : Gosub INIT_DIA
    When "CONTROLE" : Gosub CONTROLE
  Endcase
Return

$INIT_DIA

  [M:CHG]REFNUM    = [M:EVA0]REFNUM
  [M:CHG]CTRNUM    = [M:EVA0]CTRNUM
  [M:CHG]EVATYP    = [M:EVA0]EVATYP
  [M:CHG]EVADATSTR = [M:EVA0]EVADATSTR
  [M:CHG]EVADATEND = [M:EVA0]EVADATEND
  # FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
  Read [ID]ID0=[M:CHG]REFNUM
  If !fstat Then
    [M:CHG]NAM = [F:ID]NAM
    [M:CHG]SRN = [F:ID]SRN
  Endif
Return

$INIT

  If clalev([F:EVE])=0  : Local File EVAEMP     [EVE]   : Endif
  If clalev([F:EVC])=0  : Local File EVAEMPCPC  [EVC]   : Endif
  If clalev([F:EVD])=0  : Local File EVAEMPDET  [EVD]   : Endif
  # FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
  If clalev([F:ID])=0   : Local File EMPLOID    [ID]    : Endif
#  If clalev([F:EVE1])=0 : Local File EVAEMP     [EVE1]  : Endif
Return

$CONTROLE
Local Date NEWDATSTR,NEWDATEND

  If [M:CHG]EVADATSTR=[M:EVA0]EVADATSTR & [M:CHG]EVADATEND=[M:EVA0]EVADATEND Then
    FIN=1
  Else
    NEWDATSTR=[M:CHG]EVADATSTR
    NEWDATEND=[M:CHG]EVADATEND
  Endif
Return

$EXEC

  Call TEMPON("O") From GESECRAN
#  Call CHGDAT([M:EVA0]REFNUM,[M:EVA0]CTRNUM,[M:EVA0]EVADATSTR,[M:CHG]EVADATSTR,[M:EVA0]EVADATEND,[M:CHG]EVADATEND)
  Call CHGDAT([M:EVA0]REFNUM,[M:EVA0]CTRNUM,[M:EVA0]EVADATSTR,NEWDATSTR,[M:EVA0]EVADATEND,NEWDATEND,[M:EVA0]EVATYP)
  Call TEMPOFF From GESECRAN
  If GOK=1 Then
#    [M:EVA0]EVADATSTR = [M:CHG]EVADATSTR
#    [M:EVA0]EVADATEND = [M:CHG]EVADATEND
    [M:EVA0]EVADATSTR = NEWDATSTR
    [M:EVA0]EVADATEND = NEWDATEND
    Affzo [M:EVA0]EVADATSTR, EVADATEND
  Endif
Return

Subprog CHGDAT(MATRI,CONTRAT,OLDDATSTR,NEWDATSTR,OLDDATEND,NEWDATEND,TYPEVA)
Value Char MATRI
Value Char CONTRAT
Value Date OLDDATSTR, OLDDATEND
Value Date NEWDATSTR, NEWDATEND
Value Char TYPEVA
Local Char TABLE(GLONATB), DATFLDSTR(GLONAVA), DATFLDEND(GLONAVA), ABREV(5)
Local File ATABLE  [ATB]
Local File ATABZON [ATZ]

  Call DEBTRANS From GLOCK
  Gosub TR1
End

$TR1

  GOK = 1
  Trbegin [EVE], [EVC], [EVD]
  DATFLDSTR = "[F]EVADATSTR"
  DATFLDEND = "[F]EVADATEND"
  For [ATZ]CODTYP(2) Where CODZONE="EVADATSTR"
    Read [ATB]CODFIC = [F:ATZ]CODFIC
    TABLE  = [F:ATZ]CODFIC
    ABREV  = [F:ATB]ABRFIC
    Local File =TABLE
    If dim([F]REFNUM)>0 & dim([F]CTRNUM)>0
      For [F] Where REFNUM=MATRI & CTRNUM=CONTRAT & evalue(DATFLDSTR)=OLDDATSTR & evalue(DATFLDEND)=OLDDATEND & EVATYP=TYPEVA
        Assign DATFLDSTR With NEWDATSTR
        Assign DATFLDEND With NEWDATEND
        Rewrite [F]
        If fstat=1  : GOK = -1 : GLOCK = "$"+ABREV-MATRI-CONTRAT-num$(OLDDATSTR)-num$(OLDDATEND) : Break 2
        Elsif fstat : GOK = 0  : Call FSTA(ABREV) From GLOCK : Break 2
        Endif
      Next
    Endif
  Next
  If GOK<1 : Goto AB_TR1 : Endif
  Commit
Return

$AB_TR1

  Rollback
Return

$ROLL_TR1

  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR1 : Endif
Return

##########################################
## Contrôle
##########################################
Subprog C_EVADATSTR(DAT)
Variable Date    DAT

  If DAT=[M:EVA0]EVADATSTR : End : Endif

  # Une autre évaluation à une même date
  Read [F:EVE]EVE0 = [M:EVA0]REFNUM;[M:EVA0]CTRNUM;DAT;[M:CHG]EVADATEND;[M:EVA0]EVATYP
  If !fstat
    GMESSAGE = mess(81,10720,1) : # Evaluation déjà existante à cette période
    mkstat = 2
    End
  Endif

  # Verif chronologie
#  Filter [EVE1] Where REFNUM=[M:EVA0]REFNUM & CTRNUM=[M:EVA0]CTRNUM
#&                     & (EVADATSTR<>[M:EVA0]EVADATSTR | EVADATEND<>[M:EVA0]EVADATEND)
#  For [EVE1]EVE0
#    If [F:EVE1]CTRNUM<>[M:EVA0]CTRNUM | [F:EVE1]EVADATSTR<>DAT
#      If([F:EVE1]EVADATSTR>=DAT & [F:CTR1]XITDAT=[0/0/0] & ([M:CTR8]XITDAT=[0/0/0] | [M:CTR8]XITDAT>=[F:CTR1]CTRDAT))
#&|   ([F:CTR1]XITDAT>=DAT & [F:CTR1]CTRDAT<=DAT & [F:CTR1]XITDAT<>[0/0/0])
#     # La période du contrat chevauche celle d'un contrat déja existant :
#     GMESSAGE = mess(35,10701,1)-num$([F:CTR1]CTRDAT)-num$([F:CTR1]XITDAT)
#     mkstat = 2 : Break
#    Endif
#   Endif
#  Next
#  Filter [EVE1]
End

Subprog C_EVADATEND(DAT)
Variable Date    DAT

  If DAT=[M:EVA0]EVADATEND : End : Endif

  # Une autre évaluation à une même date
  Read [F:EVE]EVE0 = [M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:CHG]EVADATSTR;DAT;[M:EVA0]EVATYP
  If !fstat
    GMESSAGE = mess(81,10720,1) : # Evaluation déjà existante à cette période
    mkstat = 2
    End
  Endif
End


