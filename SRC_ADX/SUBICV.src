#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
## Gestion du compteur de version Article
##                                                        X3SUIVI71276  11/04/2012 FGR
######################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "SETBOUT"      : Gosub SETBOUT
    When "EXEBOUT"      : Gosub EXEBOUT
    When "LIENS"        : Gosub LIENS
    When "RAZCRE"       : Gosub RAZCRE
    When "RAZDUP"       : Gosub RAZDUP
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "CREATION"     : Gosub CREATION
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "MODIF"        : Gosub MODIF
    When "ANNULE"       : Gosub ANNULE
 When Default
Endcase
Return

######################################################################################
$OUVRE
  If !clalev([F:ITM]) Then Local File ITMMASTER  [ITM] : Endif
  If !clalev([F:ITF]) Then Local File ITMFACILIT [ITF] : Endif
Return

######################################################################################
$SETBOUT
  If GREP <> "" Then
    Call VIREBOUT(CHAINE, "1") From GOBJET
  Endif
Return

######################################################################################
$EXEBOUT
Local Char SMESSAGE(250)
Local Integer ISTAT

  Case BOUT
    When "1"
      Call CALCUL([M:ICV0]ICVCOD, [M:ICV1]ICVVALSIM, [M:ICV1]ICVVALSIM, SMESSAGE, ISTAT)
      If ISTAT = 0 Then
        Affzo [M:ICV1]ICVVALSIM
      Else
        Call MESSAGE(SMESSAGE) From GESECRAN
      Endif
  Endcase
Return

######################################################################################
$LIENS
  Call GESTION_CNS([M:ICV1]CNS, 0)
  Call GESTION_SEQTYP([M:ICV1]SEQTYP, 0)
  Raz [M:ICV1]ICVVALSIM
Return

######################################################################################
$RAZCRE_DUP
  Raz [M:ICV1]ICVVALSIM
Return

######################################################################################
$RAZCRE
Local Integer ISEQTYP

  Gosub RAZCRE_DUP
  [M:ICV1]CNS = G_NON
  Call GESTION_CNS([M:ICV1]CNS, 1)
  [M:ICV1]SEQ = G_OUI
  #
  ISEQTYP = 1
  Call AP_SEQTYP(ISEQTYP)
  Call AM_SEQTYP(ISEQTYP)
  [M:ICV1]SEQTYP = ISEQTYP
  #
  Affzo [M:ICV1]CNS
  Affzo [M:ICV1]SEQ
  Affzo [M:ICV1]SEQTYP
Return

######################################################################################
$RAZDUP
  Gosub RAZCRE_DUP
Return

######################################################################################
$VERIF_CRE_MOD
Local Integer ILG

  ILG = 0
  If [M:ICV1]CNS = G_OUI Then
    ILG = len([M:ICV1]CNSVAL)
  Endif
  ILG += [M:ICV1]SEQLNG
  If ILG > GLONICVVAL Then
    GERR = 1
    GMESSAGE = mess(146,187,1) - "(" + num$(ILG) - ">" - num$(GLONICVVAL) + ")"
    OK = 0
    Return
  Endif
Return

######################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
Return

######################################################################################
$CREATION
  Call MAJTEXTRA([M:ICV0]DESAXX, "ITMCPTVER", "DESAXX", [M:ICV0]ICVCOD, "") From ATEXTRA
  Raz [M:ICV1]ICVVALSIM
Return

######################################################################################
$VERIF_MOD
Local Integer ITROUVE
Local Integer WOK

  # -------------------------------------------------------------------------
  # En modification on vérifie que le compteur n'est pas utilisé quelque part
  ITROUVE = 0
  For [ITM] Where [F:ITM]ECCMAJ = [M:ICV0]ICVCOD or [F:ITM]ECCMIN = [M:ICV0]ICVCOD
      ITROUVE = 1
      Break
  Next
  If ITROUVE > 0 Then
    WOK = 1
    Call AVERTIR (mess(149,187,1) - mess(150,187,1), WOK) From GESECRAN
    If WOK=1 Then
      OK = 0
      GERR = 1
      Return
    Endif
  Endif
  # -------------------------------------------------------------------------
  Gosub VERIF_CRE_MOD
Return

######################################################################################
$MODIF
  Call MAJTEXTRA([M:ICV0]DESAXX, "ITMCPTVER", "DESAXX", [M:ICV0]ICVCOD, "") From ATEXTRA
  Raz [M:ICV1]ICVVALSIM
Return

######################################################################################
$ANNULE
  Call SUPTEXTRA("ITMCPTVER", "DESAXX", [M:ICV0]ICVCOD, "") From ATEXTRA
  Raz [M:ICV1]ICVVALSIM
Return

######################################################################################
######################################################################################
########################## SOUS-PROGRAMMES TECHNIQUES ECRANS #########################
######################################################################################
######################################################################################
Subprog GESTION_SEQTYP(ISEQTYP, ISAISIE)
Value Integer ISEQTYP
Value Integer ISAISIE

  # Si 2 ou 3 : SEQBEG non saisissable et effacé
  # Si 1      : SEQEND non saisissable et effacé
  Case ISEQTYP
    When 1
      Actzo [M:ICV1]SEQBEG
      Diszo [M:ICV1]SEQEND
      If ISAISIE = 1 Then
        Raz [M:ICV1]SEQEND
        Affzo [M:ICV1]SEQEND
      Endif
    When 2, 3
      Diszo [M:ICV1]SEQBEG
      If ISAISIE = 1 Then
        Raz [M:ICV1]SEQBEG
        Affzo [M:ICV1]SEQBEG
      Endif
      Actzo [M:ICV1]SEQEND
    When Default
      Actzo [M:ICV1]SEQBEG
      Actzo [M:ICV1]SEQEND
  Endcase
End

######################################################################################
Subprog GESTION_CNS(ICNS, ISAISIE)
Value Integer ICNS
Value Integer ISAISIE

  Case ICNS
    When G_OUI
      Actzo [M:ICV1]CNSVAL
    When Default
      Diszo [M:ICV1]CNSVAL
      If ISAISIE = 1 Then
        Raz [M:ICV1]CNSVAL
        Affzo [M:ICV1]CNSVAL
      Endif
  Endcase
End

######################################################################################
######################################################################################
############################### SOUS-PROGRAMMES CHAMPS ###############################
######################################################################################
######################################################################################
Subprog AP_CNS(VALEUR)
Variable Integer VALEUR

  Call GESTION_CNS(VALEUR, 1)
End

######################################################################################
Subprog AP_SEQTYP(VALEUR)
Variable Integer VALEUR

  # Si 2 ou 3 : SEQBEG non saisissable et effacé
  # Si 1      : SEQEND non saisissable et effacé
  Call GESTION_SEQTYP(VALEUR, 1)
End

######################################################################################
Subprog C_SEQLNG(VALEUR)
Variable Decimal VALEUR

  If VALEUR = 0 Then
    GMESSAGE = mess(10,123,1)
    mkstat = 2
    End
  Else
    If [M:ICV1]CNS = G_OUI Then
      If VALEUR > GLONICVVAL-len([M:ICV1]CNSVAL) Then
        GMESSAGE = mess(159,187,1) - num$(GLONICVVAL-len([M:ICV1]CNSVAL)) - mess(148,187,1)
        mkstat = 2
        End
      Endif
    Else
      If VALEUR > GLONICVVAL Then
        GMESSAGE = mess(159,187,1) - num$(GLONICVVAL) - mess(148,187,1)
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

######################################################################################
Subprog AM_SEQTYP(VALEUR)
Variable Integer VALEUR

  If VALEUR <> [M:ICV1]SEQTYP Then
    # Pour ne le faire que si la valeur a changée
    # ------------------------------------
    # Si 1, 4 ou 5 : SEQBEG initialisé à 1
    # Si 2, 4      : SEQEND initialisé à z
    # Si 3, 5      : SEQEND initialisé à Z
    # ------------------------------------
    If VALEUR = 1 or VALEUR = 4 or VALEUR = 5 Then
      [M:ICV1]SEQBEG = '1'
      Affzo [M:ICV1]SEQBEG
    Endif
    If VALEUR = 2 or VALEUR = 4 Then
      [M:ICV1]SEQEND = 'z'
      Affzo [M:ICV1]SEQEND
    Elsif VALEUR = 3 or VALEUR = 5 Then
      [M:ICV1]SEQEND = 'Z'
      Affzo [M:ICV1]SEQEND
    Endif
  Endif
End

######################################################################################
Subprog C_SEQBEG(VALEUR)
Variable Char    VALEUR()
  # Obligatoire ET Obligatoirement un chiffre (0 ou 1)
  If [M:ICV1]SEQTYP = 1 or [M:ICV1]SEQTYP = 4 or [M:ICV1]SEQTYP = 5 Then
    If VALEUR = "" Then
      GMESSAGE = mess(10,123,1)
      mkstat = 2
      End
    Endif
    If VALEUR <> "0" and VALEUR <> "1" Then
      GMESSAGE = mess(143,187,1)
      mkstat = 2
      End
    Endif
  Endif
End

######################################################################################
Subprog C_SEQEND(VALEUR)
Variable Char    VALEUR()
  # Obligatoire ET Obligatoirement une lettre
  If [M:ICV1]SEQTYP = 2 or [M:ICV1]SEQTYP = 3 or [M:ICV1]SEQTYP = 4 or [M:ICV1]SEQTYP = 5 Then
    If VALEUR = "" Then
      GMESSAGE = mess(10,123,1)
      mkstat = 2
      End
    Endif
  Endif
  If [M:ICV1]SEQTYP = 2 or [M:ICV1]SEQTYP = 4 Then
    If VALEUR < "a" or VALEUR > "z" Then
      GMESSAGE = mess(144,187,1)
      mkstat = 2
      End
    Endif
  Endif
  If [M:ICV1]SEQTYP = 3 or [M:ICV1]SEQTYP = 5 Then
    If VALEUR < "A" or VALEUR > "Z" Then
      GMESSAGE = mess(145,187,1)
      mkstat = 2
      End
    Endif
  Endif
End

######################################################################################
######################################################################################
################################## ACTION DE CALCUL ##################################
######################################################################################
######################################################################################
Subprog CALCUL(SICVCOD, SOLDVALUE, SNEWVALUE, SMESSAGE, STAT)
Value Char SICVCOD
Value Char SOLDVALUE
Variable Char SNEWVALUE
Variable Char SMESSAGE
Variable Integer STAT

Local Char SVOLDVALUE(GLONICVVAL)
Local Char SARENDRE(GLONICVVAL)
Local Char SSEQ(GLONICVVAL)
Local Char STBSEQ(1)(GLONICVVAL)
Local Char STBCAR(1)(1..37)
Local Char ASCIIDEB(1)
Local Char ASCIIFIN(1)
Local Integer ILG
Local Integer NI
Local Integer NE

  Local File ITMCPTVER [ICV]
  # ----------------------------
  Raz SMESSAGE
  STAT = 0
  # ----------------------------
  SVOLDVALUE = SOLDVALUE
  Raz SNEWVALUE
  Raz SARENDRE
  # ----------------------------
  # Controles préalables
  If SICVCOD = "" Then
    SMESSAGE = mess(151,187,1)
    STAT = 1
    End
  Endif
  Read [F:ICV]ICV0=SICVCOD
  If fstat Then
    SMESSAGE = mess(152,187,1)
    STAT = 1
    End
  Endif
  # ----------------------------
  If SOLDVALUE <> "" Then
    ILG = 0
    If [F:ICV]CNS = G_OUI Then
      ILG = len([F:ICV]CNSVAL)
      If left$(SOLDVALUE, ILG) <> [F:ICV]CNSVAL Then
        # Il y a eu un changement. On réinitialise le calcul
        Raz SOLDVALUE
      Endif
    Endif
    ILG += [F:ICV]SEQLNG
    If SOLDVALUE <> "" and len(SOLDVALUE) <> ILG Then
      # Il y a eu un changement. On réinitialise le calcul
      Raz SOLDVALUE
    Endif
  Endif
  # ----------------------------
  Raz STBCAR
  NE = 0
  If [F:ICV]SEQTYP = 1 or [F:ICV]SEQTYP = 4 or [F:ICV]SEQTYP = 5 Then
    For NI = 0 To 9
      NE += 1
      STBCAR(NE) = num$(NI)
    Next NI
  Endif
  If [F:ICV]SEQTYP <> 1 Then
    If [F:ICV]SEQTYP = 2 or [F:ICV]SEQTYP = 4 Then
      ASCIIDEB = 'a'
      ASCIIFIN = 'z'
    Elsif [F:ICV]SEQTYP = 3 or [F:ICV]SEQTYP = 5 Then
      ASCIIDEB = 'A'
      ASCIIFIN = 'Z'
    Endif
    For NI = ascii(ASCIIDEB) To ascii (ASCIIFIN)
      If NI > ascii([F:ICV]SEQEND) Then
        Break
      Endif
      NE += 1
      STBCAR(NE) = chr$(NI)
    Next NI
  Endif
  # ----------------------------
  If [F:ICV]CNS = G_OUI Then
    SARENDRE = [F:ICV]CNSVAL
  Endif
  Raz SSEQ
  Raz STBSEQ
  If SOLDVALUE <> "" Then
    # ----------------------------
    # Traitement de l'incrémentation
    SSEQ = right$(SOLDVALUE, len(SARENDRE)+1)
    For NI = 1 To [F:ICV]SEQLNG
      STBSEQ(NI-1) = mid$(SSEQ, NI, 1)
    Next NI
    # ----------------------------
    For NI = [F:ICV]SEQLNG To 1 Step -1
      NE = find(STBSEQ(NI-1), STBCAR)
      If STBCAR(NE+1) <> "" Then
        # Cas facile, on fait plus 1 et on s'arrête
        STBSEQ(NI-1) = STBCAR(NE+1)
        Break
      Else
        STBSEQ(NI-1) = STBCAR(1)
      Endif
    Next NI
    # ----------------------------
    Raz SSEQ
    For NI = 0 To [F:ICV]SEQLNG
      SSEQ += STBSEQ(NI)
    Next NI
    # ----------------------------
    # FGR 02/06/2015 : Limite du compteur atteinte (début)
    If SARENDRE + SSEQ < SVOLDVALUE Then
      Raz SARENDRE
      SMESSAGE = mess(221,187,1) - "(" + SICVCOD + ")"
      STAT = 1
      End
    Endif
    # FGR 02/06/2015 : Limite du compteur atteinte (fin)
  Else
    # ----------------------------
    # Initialisation pour la première fois
    For NI = 1 To [F:ICV]SEQLNG
      If [F:ICV]SEQTYP = 1 or [F:ICV]SEQTYP = 4 or [F:ICV]SEQTYP = 5 Then
        If NI < [F:ICV]SEQLNG Then
          SSEQ += STBCAR(1)
        Else
          SSEQ += [F:ICV]SEQBEG
        Endif
      Else
        SSEQ += STBCAR(1)
      Endif
    Next NI
    # ----------------------------
  Endif
  # ----------------------------
  SNEWVALUE = SARENDRE + SSEQ
End

######################################################################################
$INCREMENTE_CONTROLES
  Read [ITM]ITM0=SARTICLE
  If fstat Then
    STAT = 1
    SMESSAGE = mess(212,199,1)
    Return
  Endif
  Read [ITF]ITF0=SARTICLE;SSITE
  If fstat Then
    STAT = 1
    SMESSAGE = mess(260,199,1)
    Return
  Endif
  # ----------
  If [F:ITM]ECCSTO = 1 Then
    STAT = 1
    SMESSAGE = mess(153,187,1)
    Return
  Endif
Return

######################################################################################
Subprog INCREMENTE_MINEUR(SARTICLE, SSITE, SMESSAGE, STAT)
Value Char SARTICLE
Value Char SSITE
Variable Char SMESSAGE
Variable Integer STAT

Local Integer ITERLOCK
Local Integer ITRANSAC
Local Char SICVVAL(GLONICVVAL)

  Local File ITMCPTVER [ICV]
  If !clalev([F:ITM]) Then Local File ITMMASTER  [ITM] : Endif
  If !clalev([F:ITF]) Then Local File ITMFACILIT [ITF] : Endif
  # ----------
  Raz SMESSAGE
  STAT = 0
  # -------------
  # 1°) Contrôles
  Gosub INCREMENTE_CONTROLES
  If STAT <> 0 Then
    End
  Endif
  If [F:ITM]ECCSTO = 2 Then
    STAT = 1
    SMESSAGE = mess(154,187,1)
    End
  Endif
  If [F:ITM]ECCMIN = "" Then
    STAT = 1
    SMESSAGE = mess(155,187,1)
    End
  Endif
  # ----------------------------------------------------
  # 2°) Eventuellement on se met en transaction
  ITRANSAC = 0
  If adxlog = 1 Then
    ITRANSAC = 1    # On a une transaction en cours
  Else
    ITRANSAC = 0    # On n'a pas de transaction en cours
  Endif
  If ITRANSAC = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [ITF]
  Endif
  # ----------------------------------------------------
  # 3°) On tente de locker l'article/site
  # Dernier cas d'erreur possible : On essaie de locker au plus 5 fois l'ARTICLE/SITE
  ITERLOCK = 0
  Repeat
    Readlock [ITF]ITF0=SARTICLE;SSITE
    If fstat Then
      ITERLOCK += 1
      If ITERLOCK > 5 Then
        Break
      Endif
    Else
      Break
    Endif
  Until 1=1
  If ITERLOCK > 5 Then
    If ITRANSAC = 0 Then
      Rollback
    Endif
    STAT = 1
    SMESSAGE = mess(156,187,1)
    End
  Endif
  # ----------------------------------------------------
  # 4°) On calcul le nouvel indice mineur
  Call CALCUL([F:ITM]ECCMIN, [F:ITF]ECCVALMIN, SICVVAL, SMESSAGE, STAT)
  If STAT <> 0 Then
    If ITRANSAC = 0 Then
      Rollback
    Endif
    End
  Endif
  [F:ITF]ECCVALMIN = SICVVAL
  Rewrite [F:ITF]
  If !fstat Then
    If ITRANSAC = 0 Then
      Rollback
    Endif
    STAT = 1
    SMESSAGE = mess(157,187,1)
    End
  Endif
  # ----------------------------------------------------
  # 5°) Tout s'est bien passé, on commit s'il le faut.
  If ITRANSAC = 0 Then
    Commit
  Endif
End

######################################################################################
Subprog INCREMENTE_MAJEUR(SARTICLE, SSITE, SMESSAGE, STAT)
Value Char SARTICLE
Value Char SSITE
Variable Char SMESSAGE
Variable Integer STAT

Local Integer ITERLOCK
Local Integer ITRANSAC
Local Char SICVVAL(GLONICVVAL)

  Local File ITMCPTVER [ICV]
  If !clalev([F:ITM]) Then Local File ITMMASTER  [ITM] : Endif
  If !clalev([F:ITF]) Then Local File ITMFACILIT [ITF] : Endif
  # ----------
  Raz SMESSAGE
  STAT = 0
  # -------------
  # 1°) Contrôles
  Gosub INCREMENTE_CONTROLES
  If STAT <> 0 Then
    End
  Endif
  If [F:ITM]ECCMAJ = "" Then
    STAT = 1
    SMESSAGE = mess(158,187,1)
    End
  Endif
  # ----------------------------------------------------
  # 2°) Eventuellement on se met en transaction
  ITRANSAC = 0
  If adxlog = 1 Then
    ITRANSAC = 1    # On a une transaction en cours
  Else
    ITRANSAC = 0    # On n'a pas de transaction en cours
  Endif
  If ITRANSAC = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [ITF]
  Endif
  # ----------------------------------------------------
  # 3°) On tente de locker l'article/site
  # Dernier cas d'erreur possible : On essaie de locker au plus 5 fois l'ARTICLE/SITE
  ITERLOCK = 0
  Repeat
    Readlock [ITF]ITF0=SARTICLE;SSITE
    If fstat Then
      ITERLOCK += 1
      If ITERLOCK > 5 Then
        Break
      Endif
    Else
      Break
    Endif
  Until 1=1
  If ITERLOCK > 5 Then
    If ITRANSAC = 0 Then
      Rollback
    Endif
    STAT = 1
    SMESSAGE = mess(156,187,1)
    End
  Endif
  # ----------------------------------------------------
  # 4°) On calcul le nouvel indice majeur
  Call CALCUL([F:ITM]ECCMAJ, [F:ITF]ECCVALMAJ, SICVVAL, SMESSAGE, STAT)
  If STAT <> 0 Then
    If ITRANSAC = 0 Then
      Rollback
    Endif
    End
  Endif
  [F:ITF]ECCVALMAJ = SICVVAL
  Raz [F:ITF]ECCVALMIN
  Rewrite [F:ITF]
  If !fstat Then
    If ITRANSAC = 0 Then
      Rollback
    Endif
    STAT = 1
    SMESSAGE = mess(157,187,1)
    End
  Endif
  # ----------------------------------------------------
  # 5°) On calcul le nouvel indice mineur
  If [F:ITM]ECCSTO = 3 Then
    Call INCREMENTE_MINEUR(SARTICLE, SSITE, SMESSAGE, STAT)
    If STAT <> 0 Then
      If ITRANSAC = 0 Then
        Rollback
      Endif
      End
    Endif
  Endif
  # ----------------------------------------------------
  # 6°) Tout s'est bien passé, on commit s'il le faut.
  If ITRANSAC = 0 Then
    Commit
  Endif
End


