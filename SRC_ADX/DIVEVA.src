#JOJAC - START
#Traitement commun aux entretien
#**
#* return the number associate to the value Valent in tabdiv 4646
#*
#* @param VALENT Value of interview
#*!
Funprog GET_NBMONTH(VALENT)
Value Char VALENT()
Local Integer RES
If clalev([F:ADI])=0   : Local File ATABDIV [ADI]  : Endif
If([F:ADI]NUMTAB<>10464 | [F:ADI]CODE<>VALENT)
  Read [F:ADI]CODE=10464;VALENT
Endif
RES=max(0,[F:ADI]N1)
End RES

#**
#* Return true=1 or false=0 for the parameter EVASUI
#*
#*
#* @param SOC
#*!
Funprog IS_EVASUI(SOC)
Value Char SOC()
Local Integer RES
Local Char WFIND(2)
RES=1
If func AFNC.ACTIV("NCA")
  Call PARAM(SOC,"EVASUI",WFIND)From ADOVAL
  If WFIND <> "2"
    RES=0
  Endif
Endif
End RES

Funprog IS_EVASUI_GRPSOC(SOC,STRICT)
Value Char SOC()
Value Integer STRICT
Local Integer WI,WK
Local Char    LIS_CPY(GLONCPY)(0..100)
RES=0
#Call CALC_GRPCPY(SOC, LIS_CPY,  WI) From SUBSES
Call CALC_GRPCPY(SOC, LIS_CPY,  WI) From TOOLSVAR
If WI
  For WK=0 To WI-1
    If !func IS_EVASUI(LIS_CPY(WK))
      If STRICT
        RES=0
        Break
      Endif
    Else
      RES=1
      If !STRICT : Break  :Endif
    Endif
  Next
Endif

End RES

#**
#*
#*
#* @param NAMPARAM
#* @param VALENT
#*!
Funprog IS_TYPEOF(NAMPARAM,VALENT)
Value Char NAMPARAM(),VALENT()
Local Integer RES
If clalev([F:WAD_])=0  : Local File ADOVAL [WAD_] : Endif
For [WAD_] Where PARAM=NAMPARAM
  If func IS_SOC_TYPEOF([F:WAD_]CMP,NAMPARAM,VALENT)
   RES=1
   Break
  Endif
Next
End RES

#**
#* return 1 if ok else 0
#* return if the value of interviews is ok for company
#*
#* @param SOC
#* @param NAMPARAM
#* @param VALENT
#*!
Funprog IS_SOC_TYPEOF(SOC,NAMPARAM,VALENT)
Value Char SOC(),NAMPARAM(),VALENT()
Local Integer RES,WFIND

If func DIVPAYE.GET_VALTYPEVA(NAMPARAM,SOC,VALENT)>1
  RES=1
Endif
End RES


#**
#* Search if company respond to the criteria
#*
#* @param SOC     : company
#* @param NAMPARAM     : Type of interview
#* @param VALENT  : Value of interview
#* @param STRICT  : 0 or 1 : 0 if only one company responding criteria
#*!
Funprog IS_GRPSOC_TYPEOF(SOC,NAMPARAM,VALENT,STRICT)
Value Char SOC(),NAMPARAM(),VALENT()
Value Integer STRICT
Local Integer WI,WK
Local Char    LIS_CPY(GLONCPY)(0..100)
RES=0
#Call CALC_GRPCPY(SOC, LIS_CPY,  WI) From SUBSES
Call CALC_GRPCPY(SOC, LIS_CPY,  WI) From TOOLSVAR
If WI
  For WK=0 To WI-1
    If !func IS_SOC_TYPEOF(LIS_CPY(WK),NAMPARAM,VALENT)
      If STRICT
        RES=0
        Break
      Endif
    Else
      RES=1
      If !STRICT : Break  :Endif
    Endif
  Next
Endif
End RES


#**
#* Return values of message
#*
#* @param NUM
#* @param TYP
#* @param VALENT
#*!
Funprog GETMESSAGE(NUM,TYP,VALENT)
Value Integer NUM
Value Char TYP(),VALENT()
Local Char RES(250)
Case NUM
  When 1 : RES=mess(161,10720,1)  : #"Les entretiens ne sont pas suivis pour cette société"
  When 2 : RES=mess(162,10720,1)  : #"Type d'entretien non professionel pour cette société"
  When 3 : RES=mess(163,10720,1)  : #"Type d'entretien non professionel"
  When 4 : RES=mess(164,10720,1)  : #"La valeur paramètre EVASUI doit être à oui pour utiliser cette fonction"
  When 5 : RES=mess(165,10720,1)  : #"La valeur paramètre EVAPRO doit être renseignée pour utiliser cette fonction"
  When 6 : RES=mess(166,10720,1)  : #"Un nombre de mois doit être renseigné"
  When 7 : RES=mess(167,10720,1)  : #"Entretien existant"
Endcase

End RES
#JOJAC - END

