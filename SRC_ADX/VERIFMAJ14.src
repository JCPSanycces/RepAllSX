#<AdxTL>@(#)5.0.0.0 $Revision$
Local Integer OK
Call VERIF(OK)
End
##################################################################################
# VERIFMAJ14 : Vérification à effectuer avant le passage à la version 140
##################################################################################

Subprog VERIF(OK)
Variable Integer OK

OK=1
#-------------------------------------#
#       Avant validation dossier      #
#-------------------------------------#
Onerrgo ERREUR

Call ECR_TRACE("************** VERIFMAJ14 ***************",-1) From GESECRAN

Local Char WDOSSIER 
WDOSSIER=[F:ADS]DOSSIER  

# Vérification stocks 
If [F:ADS]MODULE(6)=2
   Gosub VERIF_STO
Endif

# Vérification GP 
If [F:ADS]MODULE(7)=2
   Gosub VERIF_GPA
Endif

# Vérification ventes
If [F:ADS]MODULE(4)=2
   Gosub VERIF_VEN
Endif

# Vérification achats
If [F:ADS]MODULE(5)=2
   Gosub VERIF_ACH
Endif

# FGR 28/08/2008 : X3SUIVI48777 : Remis parce qu'un client peut migrer de la 130 directement à cette version
# Vérification Tronc commun
If [F:ADS]MODULE(8)=2
   Gosub VERIF_TRC
Endif

Onerrgo
End

###################################################################################
###################################################################################
###################################################################################

$VERIF_STO
Local Char WTRFNUM
Raz WTRFNUM

Call ECR_TRACE("--- Stock transfers vérification ---",-1) From GESECRAN

Local File =WDOSSIER+".TRANSFERH"   [TFH]
Local File =WDOSSIER+".TRANSFERD"   [TFD]
Local File =WDOSSIER+".STOJOUAGG"   [SJA]
Local File =WDOSSIER+".STOREGAGG"   [SRA]
Local File =WDOSSIER+".STOJOU"      [STJ]

For [TFD]
   If [F:TFD]TRFNUM<>WTRFNUM
      Read [TFH]TFH0=[F:TFD]TRFNUM
      If !fstat
         Call ECR_TRACE("Transfer"-[F:TFH]TRFNUM-"not performed",1) From GESECRAN
         OK=0
      Endif
      WTRFNUM=[F:TFD]TRFNUM
   Endif 
Next

# vérifier qu'il n'y a plus d'enreg STOJOUAGG, STOREGAGG
Call ECR_TRACE("--- Stock accounting interface vérification ---",-1) From GESECRAN
If nbrecord([F:SJA])>0
   Call ECR_TRACE("STOJOUAGG not interfaced",1) From GESECRAN
   OK=0
Endif
If nbrecord([F:SRA])>0
   Call ECR_TRACE("STOREGAGG not interfaced",1) From GESECRAN
   OK=0
Endif

# CCC (14/05/08) Bug 47320 : Il n'est plus nécessaire d'interfacer avant la migration puisque
#   les nouveaux champs AMTORD et AMTVAL sont alimentés.
#For [STJ]
#   If [F:STJ]AGGIFAFLG<>2
#      Call ECR_TRACE("STOJOU not interfaced",1) From GESECRAN
#      Break
#   Endif
#Next

#--- Bug 70587
Call ECR_TRACE("--- Counts vérification ---",-1) From GESECRAN
Local File =WDOSSIER+".CUNLISDET"  [CUD]
For [CUD] Where [F:CUD]LINUPDFLG<>2
   Call ECR_TRACE(mess(52,184,1),1) From GESECRAN
   OK=0 : Break
Next
#---

Return

###################################################################################
###################################################################################
###################################################################################
$VERIF_GPA
Local File =WDOSSIER+".OPETRKAGG"   [OKA]
Local File =WDOSSIER+".OPEOVEAGG"   [OOA]
# vérifier qu'il n'y a plus d'enreg OPETRKAGG, OPEOVEAGG
Call ECR_TRACE("--- Time accounting interface vérification ---",-1) From GESECRAN
If nbrecord([F:OKA])>0
   Call ECR_TRACE("OPETRKAGG not interfaced",1) From GESECRAN
   OK=0
Endif
If nbrecord([F:OOA])>0
   Call ECR_TRACE("OPEOVEAGG not interfaced",1) From GESECRAN
   OK=0
Endif

# ? vérifier que les OF ont le flag à 'PRF calculé' ou statut 'En attente' sinon la finalisation 
# des WIPCOST trouvera un déséquilibre

Return

###################################################################################
###################################################################################
###################################################################################
$VERIF_VEN

Call ECR_TRACE("--- Shipments vérification ---",-1) From GESECRAN

Local File =WDOSSIER+".SDELIVERY"   [SDH]
Local File =WDOSSIER+".SDELIVERYD"  [SDD]
Local File =WDOSSIER+".ITMMASTER"   [ITM]

# Livraisons non validées
For [SDH]SDH3 Where INVFLG<2 & CFMFLG<2 
  For [SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM
    If [F:SDD]STOMGTCOD>1
      Read [ITM]ITM0=[F:SDD]ITMREF
      If (!fstat & [F:ITM]SERMGTCOD>1) | fstat
        Call ECR_TRACE("Shipment"-[F:SDH]SDHNUM-"not validated and"-"Item"-[F:SDD]ITMREF-"with serial number",1) From GESECRAN
        OK=0 : Break
      Endif
    Endif
  Next      
Next

Call ECR_TRACE("--- Sales invoices vérification ---",-1) From GESECRAN

Local File =WDOSSIER+".SINVOICEV"   [SIV]
Local File =WDOSSIER+".SINVOICED"   [SID]

# Factures non validés avec maj stock
For [SIV]SIV0 Where INVTYP=1 & STOMVTFLG=2 & INVSTA<3
   # Factures de livraison
   If [F:SIV]SIHORI=3
      For [SID]SID0 Where NUM=[F:SIV]NUM
         # Ligne de facture directe géré en stock
         If [F:SID]SDHNUM="" & [F:SID]STOMGTCOD>1
            Call ECR_TRACE("Invoice"-[F:SIV]NUM-"not validated",1) From GESECRAN
            OK=0 : Break
         Endif 
      Next
   Else
      Call ECR_TRACE("Invoice"-[F:SIV]NUM-"not validated",1) From GESECRAN
      OK=0
   Endif
Next

Return

###################################################################################
###################################################################################
###################################################################################

$VERIF_ACH

Call ECR_TRACE("--- Supplier returns vérification ---",-1) From GESECRAN

Local File =WDOSSIER+".PRETURN"   [PNH]

# Retours fournisseurs non validés
For [PNH]PNH0 Where CFMFLG<2 
   Call ECR_TRACE("Return"-[F:PNH]PNHNUM-"not validated",1) From GESECRAN
   OK=0
Next

Return

###################################################################################
###################################################################################
###################################################################################
# FGR 28/08/2008 : X3SUIVI48777 : Remis parce qu'un client peut migrer de la 130 directement à cette version
$VERIF_TRC
  Call ECR_TRACE("--- Contacts verification ---",-1) From GESECRAN
  #
  Local File =WDOSSIER+".CONTACT"    [CNT]
  Local File =WDOSSIER+".CONTACTCRM" [CCN]
  # Vérification des liens entre CONTACT et CONTACTCRM
  For [CNT]
    If [F:CNT]CCNCRM=""
      # FGR 28/08/2008 : X3SUIVI48777 : Une procédure va prendre en charge la création dans CONTACTCRM pour établir le lien.
      #                                 Le message reste ici pour info. Mais ne provoque plus le plantage de la validation.
      #Call ECR_TRACE("Contact"-[F:CNT]CNTNAM-" : Link between CONTACT [CNT] and CONTACTCRM [CCN] broken",1) From GESECRAN
      Call ECR_TRACE("Contact"-num$([F:CNT]BPATYP)+"/"+[F:CNT]BPANUM+"/"+[F:CNT]CCNCRM-" : Link between CONTACT [CNT] and CONTACTCRM [CCN] broken",-1) From GESECRAN
      #OK = 0
    Else
      Look [CCN]CCN0=[F:CNT]CCNCRM
      If fstat
        # FGR 28/08/2008 : X3SUIVI48777 : Une procédure va prendre en charge la création dans CONTACTCRM pour établir le lien.
        #                                 Le message reste ici pour info. Mais ne provoque plus le plantage de la validation.
        #Call ECR_TRACE("Contact"-[F:CNT]CNTNAM-" : Link between CONTACT [CNT] and CONTACTCRM [CCN] broken (CCNCRM="+[F:CNT]CCNCRM+" doesn't exist)",1) From GESECRAN
        #OK = 0
        Call ECR_TRACE("Contact"-num$([F:CNT]BPATYP)+"/"+[F:CNT]BPANUM+"/"+[F:CNT]CCNCRM-" : Link between CONTACT [CNT] and CONTACTCRM [CCN] broken (CCNCRM="+[F:CNT]CCNCRM+" doesn't exist)",-1) From GESECRAN
      Endif
    Endif
  Next
Return

###################################################################################
###################################################################################
###################################################################################


$ERREUR
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
LRET=1
Resume

