#<AdxTL>@(#)11.0.0.0 $Revision$
######################################################################
# IMPSQH : Import / Export des Devis Ventes                     V140 #
######################################################################
# Issue X3-38400 - 20180104 by LD : Field deleted by sale order import

$ACTION
Case ACTION
    When "IMP_TRTSUP"   : Gosub IMP_TRTSUP
    When "IMP_OUVRE"    : Gosub IMP_OUVRE
    When "IMPORT"       : Gosub IMPORT
    When "IMP_ZONE"     : Gosub IMP_ZONE
    When "IMP_TAB"      : Gosub IMP_TAB
    When "IMP_INICRE"   : Gosub IMP_INICRE
    When "IMP_INIMOD"   : Gosub IMP_INIMOD
    When "IMP_FERME"    : Gosub IMP_FERME
    When "INICRE_LIG"   : Gosub INICRE_LIG
    When "INIMOD_LIG"   : Gosub INIMOD_LIG
    When "EXP_OUVRE"    : Gosub EXP_OUVRE
    When "EXPORT"       : Gosub EXPORT
Endcase
Return

#######################################################################
#                        IMPORT
#######################################################################
$IMP_TRTSUP
Local Char FICZON_INT (20) (20)  : # champs interdits en import ( ex: SOP/SOPLIN )
FICZON_INT(0)="SQD/SQDLIN"
Gosub IMP_CPL From TRTX3IMP

Return

######################################################################
$IMP_OUVRE

Local Integer  OKCHAMP
Local  Integer WNOL
Local  Char    WNEWPJT (GLONPJT) : #--- X3Suivi 71065 : Gestion code affaire dans les ventes ---#

Global Integer G_BPCNAM, G_BPDNAM, G_QTY, G_VACITM1, G_VACITM2, G_VACITM3
Global Integer G_BPAORD
Global Integer G_CNCNAM, G_CNDNAM
Global Integer G_PRIREN
Global Integer G_DISCRGREN1, G_DISCRGREN2, G_DISCRGREN3, G_DISCRGREN4, G_DISCRGREN5
Global Integer G_DISCRGREN6, G_DISCRGREN7, G_DISCRGREN8, G_DISCRGREN9
Global Integer G_LINTYP, G_OCNPRNBOM, G_NDEPRNBOM, G_INVPRNBOM
Global Integer G_DBPAADD, G_DDAYLTI, G_DSTOFCY, G_DPJT : #--- X3Suivi 71065 : Gestion code affaire dans les ventes ---#
Global Integer G_FOCFLG
#--- X3Suivi 71065 : Gestion code affaire dans les ventes ---#
Global Integer G_PJTH             : # pour maj PJT entête
#--- X3Suivi 71065 : Gestion code affaire dans les ventes ---#
Global Integer G_SQHTYP                                                # FGR 24/02/2015 : X3SUIVI104383

Call TST_CHAMP ("SQH","SQHTYP", G_SQHTYP)         From SUBIMPOBJ       # FGR 24/02/2015 : X3SUIVI104383
Call TST_CHAMP ("SQH","PJT", G_PJTH)              From SUBIMPOBJ : #--- X3Suivi 71065 : Gestion code affaire dans les ventes ---#
Call TST_CHAMP ("SQH","BPCNAM",G_BPCNAM)          From SUBIMPOBJ
Call TST_CHAMP ("SQH","BPDNAM",G_BPDNAM)          From SUBIMPOBJ
Call TST_CHAMP ("SQH","BPAORD",G_BPAORD)          From SUBIMPOBJ
Call TST_CHAMP ("SQD","QTY",G_QTY)                From SUBIMPOBJ
Call TST_CHAMP ("SQD","VACITM(0)",G_VACITM1)      From SUBIMPOBJ
Call TST_CHAMP ("SQD","VACITM(1)",G_VACITM2)      From SUBIMPOBJ
Call TST_CHAMP ("SQD","VACITM(2)",G_VACITM3)      From SUBIMPOBJ
Call TST_CHAMP ("SQH","CNCNAM",G_CNCNAM)          From SUBIMPOBJ
Call TST_CHAMP ("SQH","CNDNAM",G_CNDNAM)          From SUBIMPOBJ
Call TST_CHAMP ("SQD","PRIREN",G_PRIREN)          From SUBIMPOBJ
Call TST_CHAMP ("SQD","DISCRGREN1",G_DISCRGREN1)  From SUBIMPOBJ
Call TST_CHAMP ("SQD","DISCRGREN2",G_DISCRGREN2)  From SUBIMPOBJ
Call TST_CHAMP ("SQD","DISCRGREN3",G_DISCRGREN3)  From SUBIMPOBJ
Call TST_CHAMP ("SQD","DISCRGREN4",G_DISCRGREN4)  From SUBIMPOBJ
Call TST_CHAMP ("SQD","DISCRGREN5",G_DISCRGREN5)  From SUBIMPOBJ
Call TST_CHAMP ("SQD","DISCRGREN6",G_DISCRGREN6)  From SUBIMPOBJ
Call TST_CHAMP ("SQD","DISCRGREN7",G_DISCRGREN7)  From SUBIMPOBJ
Call TST_CHAMP ("SQD","DISCRGREN8",G_DISCRGREN8)  From SUBIMPOBJ
Call TST_CHAMP ("SQD","DISCRGREN9",G_DISCRGREN9)  From SUBIMPOBJ
Call TST_CHAMP ("SQD","LINTYP",G_LINTYP)          From SUBIMPOBJ
Call TST_CHAMP ("SQD","OCNPRNBOM",G_OCNPRNBOM)    From SUBIMPOBJ
Call TST_CHAMP ("SQD","NDEPRNBOM",G_NDEPRNBOM)    From SUBIMPOBJ
Call TST_CHAMP ("SQD","INVPRNBOM",G_INVPRNBOM)    From SUBIMPOBJ
Call TST_CHAMP ("SQD","BPAADD",G_DBPAADD)         From SUBIMPOBJ
Call TST_CHAMP ("SQD","DAYLTI",G_DDAYLTI)         From SUBIMPOBJ
Call TST_CHAMP ("SQD","STOFCY",G_DSTOFCY)         From SUBIMPOBJ
Call TST_CHAMP ("SQD","PJT",G_DPJT)               From SUBIMPOBJ : #--- X3Suivi 71065 : Gestion code affaire dans les ventes ---#
Call TST_CHAMP ("SQD","FOCFLG",G_FOCFLG)          From SUBIMPOBJ

Gosub OUVRE_TEXTE

Return

#---------------------------------------------------------------------
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
  When "IMP_OUVRE"    : G_IMPORT=1
  When "EXP_OUVRE"    : G_EXPORT=1
Endcase

#     entete *71 à *78 / pied *81 à *88 / ligne *91 à *98
#     les zones TSTCHAMP  1 à  8 determinent l'entete
#     les zones TSTCHAMP 11 à 18 determinent le pied
#     les zones TSTCHAMP 21 à 28 determinent le detail
# lignes entete
Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
TSTCHAMP(1) ="SQH*71" : TSTCHAMP(2) ="SQH*72" : TSTCHAMP(3) ="SQH*73" : TSTCHAMP(4) ="SQH*74"
TSTCHAMP(5) ="SQH*75" : TSTCHAMP(6) ="SQH*76" : TSTCHAMP(7) ="SQH*77" : TSTCHAMP(8) ="SQH*78"
# lignes pied
Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
TSTCHAMP(11)="SQH*81" : TSTCHAMP(12)="SQH*82" : TSTCHAMP(13)="SQH*83" : TSTCHAMP(14)="SQH*84"
TSTCHAMP(15)="SQH*85" : TSTCHAMP(16)="SQH*86" : TSTCHAMP(17)="SQH*87" : TSTCHAMP(18)="SQH*88"
# lignes detail
Raz GIMP(91), GIMP(92), GIMP(93), GIMP(94), GIMP(95), GIMP(96), GIMP(97), GIMP(98)
TSTCHAMP(21)="SQD*91" : TSTCHAMP(22)="SQD*92" : TSTCHAMP(23)="SQD*93" : TSTCHAMP(24)="SQD*94"
TSTCHAMP(25)="SQD*95" : TSTCHAMP(26)="SQD*96" : TSTCHAMP(27)="SQD*97" : TSTCHAMP(28)="SQD*98"

Gosub OUVRE_TEXTE From TRTX3IMP
Return

######################################################################
$IMPORT

Gosub IMPORT_TEXTE

Case IMPFIC

    When "SQH"

        If GREP="C" : Raz [M:ADB1], [M:ADB2] : Endif

#       Chargement de l'ecran adresse client commande si raison sociale parametree
        If G_BPCNAM
           [M:ADB1]ADBBPR       = [F:SQH]BPCORD
           [M:ADB1]BPRNAM(0)    = [F:SQH]BPCNAM(0)
           [M:ADB1]BPRNAM(1)    = [F:SQH]BPCNAM(1)
           [M:ADB1]BPAADDLIG(0) = [F:SQH]BPCADDLIG(0)
           [M:ADB1]BPAADDLIG(1) = [F:SQH]BPCADDLIG(1)
           [M:ADB1]BPAADDLIG(2) = [F:SQH]BPCADDLIG(2)
           [M:ADB1]POSCOD       = [F:SQH]BPCPOSCOD
           [M:ADB1]CTY          = [F:SQH]BPCCTY
           [M:ADB1]SAT          = [F:SQH]BPCSAT
           [M:ADB1]CRY          = [F:SQH]BPCCRY
           [M:ADB1]CRYNAM       = [F:SQH]BPCCRYNAM
           [M:ADB1]ADBFLG = 2
        Endif
#       Chargement systématique du contact client commande s'il est paramétré
        If G_CNCNAM
           [M:ADB1]CNTNAM       = [F:SQH]CNCNAM
        Endif
#       Chargement systématique de l'adresse client commande si elle est paramétrée
        If G_BPAORD
            [M:ADB1]BPAADD      = [F:SQH]BPAORD
        Endif
#       Chargement de l'ecran adresse client livré si la raison sociale est paramétrée
        If G_BPDNAM
           [M:ADB2]ADBBPR       = [F:SQH]BPCORD
           [M:ADB2]BPRNAM(0)    = [F:SQH]BPDNAM(0)
           [M:ADB2]BPRNAM(1)    = [F:SQH]BPDNAM(1)
           [M:ADB2]BPAADDLIG(0) = [F:SQH]BPDADDLIG(0)
           [M:ADB2]BPAADDLIG(1) = [F:SQH]BPDADDLIG(1)
           [M:ADB2]BPAADDLIG(2) = [F:SQH]BPDADDLIG(2)
           [M:ADB2]POSCOD       = [F:SQH]BPDPOSCOD
           [M:ADB2]CTY          = [F:SQH]BPDCTY
           [M:ADB2]SAT          = [F:SQH]BPDSAT
           [M:ADB2]CRY          = [F:SQH]BPDCRY
           [M:ADB2]CRYNAM       = [F:SQH]BPDCRYNAM
           [M:ADB2]ADBFLG = 2
        Endif
#       Chargement systématique du contact client livré s'il est paramétré
        If G_CNDNAM
           [M:ADB2]CNTNAM       = [F:SQH]CNDNAM
        Endif

    When "CAL"
#--------------------------------------------------------------------#
# Traitement des comptes et sections analytiques des lignes commande #
#            left$([M:AOE1]FLGLNK(SEPNUM-1),5)='"SQD"'               #
#--------------------------------------------------------------------#
        [F:CAL]ABRFIC="SQD"
        [F:CAL]VCRTYP=0
        Call IMPORT_ACCCCE(WNOL,"","","[M:SQH2]CCE") From TRTX3CPT
        nolign=WNOL+1 : status=75 : # Modif élément

    When "SQD"
        Raz WNOL
        Gosub IMP_DECLARE From TRTX3IMP
#       Il faut déterminer s'il s'agit d'une nouvelle ligne ou pas
        If GREP="M"
           ICLEPRIM(0) = "SQDLIN"
           ICLEPRIM(1) = "ITMREF"
           NBASTAB     = "NBLIG"
           Gosub RECHERCHE_LIGNE From TRTX3IMP
           If nolign=0 : G_NLDET=1 :  Endif
           #If nolign>0 WNOL=nolign-1 Endif        : # Bug 77807
           If nolign>0 WNOL=nolign Endif           : # Bug 77807
#          Traitement de suppression d'une ligne
            If G_QTY & [F:SQD]QTY = 0 & nolign <> 0
               status=65
               # Contrôle de suppression de lignes
               Call C_NBLIG From W1SQH2
               If mkstat OK=0 : Return : Endif
               Call AVANT_NBLIG From W1SQH2
               Call APRES_NBLIG From W1SQH2
            Endif
        Endif
        #If WNOL=0 WNOL=[M]NBLIG Endif              : # Bug 77807
        If WNOL=0 WNOL=[M]NBLIG Else WNOL-=1 Endif  : # Bug 77807
  When "SVV" :
# -------------------------------------------------------------------#
#     Taxes                                                          #
# -------------------------------------------------------------------#
      If [F:SVV]VAT<>"" & dim([M:SIHV]XVTAX)>0
      	#--CPO 71937 TVT et multi-lèg
      	Call LEC_TVT_LEG(GCURLEG,[F:SVV]VAT,WRET) From TRTLECLEG
      	If WRET : Raz [F:TVT] : Endif
        #Read [F:TVT]TVT0=[F:SVV]VAT
        #If fstat : Raz [F:TVT] : Endif
        #--/CPO
        [M:SIHV]XVTYP([M:SIHV]NBVAT) = [F:TVT]VATTYP
        [M:SIHV]XVBAS([M:SIHV]NBVAT) = [F:TVT]VATBAS
        [M:SIHV]XVCHA([M:SIHV]NBVAT) = [F:TVT]VATCHA
        Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHV]XVSHO([M:SIHV]NBVAT)) From TRTX3TEX
        [M:SIHV]XVTAX([M:SIHV]NBVAT) = [F:SVV]VAT
        [M:SIHV]XVNOT([M:SIHV]NBVAT) = [F:SVV]VATGRO
        [M:SIHV]XVSMI([M:SIHV]NBVAT) = [F:SVV]VATNET
        [M:SIHV]XVRAT([M:SIHV]NBVAT) = [F:SVV]VATRAT
        [M:SIHV]XVAMT([M:SIHV]NBVAT) = [F:SVV]VATAMT
        [M:SIHV]XVSUP([M:SIHV]NBVAT) = [F:SVV]VATSUPAMT
        [M:SIHV]NBVAT +=1
      Endif
  When "SVF" :
# -------------------------------------------------------------------#
#     Pieds                                                          #
# -------------------------------------------------------------------#
#--      le tableau des pieds de facture
      If [F:SVF]DTA<>0 & dim([M:SIHV]XFNUM)>0
        [M:SIHV]XFNUM([M:SIHV]NBFOOT)    = [F:SVF]DTA
        [M:SIHV]XFNOT([M:SIHV]NBFOOT)    = [F:SVF]DTANOT
        [M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT

        Raz [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)
        For I=0 To dim([F:SVF]DTANET)-1
             If [F:SVF]DTAVAT(I)="" Break Endif
             Assign "[M:SIHV]DTANOT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATNOT(I)
             Assign "[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTANET(I)
             Assign "[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVAT(I)
             Assign "[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATRAT(I)
             Assign "[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATAMT(I)
             [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)+=[F:SVF]DTAVATAMT(I)
        Next
        If I=1
             [M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANET(I-1)
             [M:SIHV]XFTAX([M:SIHV]NBFOOT)    = [F:SVF]DTAVAT(I-1)
             [M:SIHV]XFRAT([M:SIHV]NBFOOT)    = [F:SVF]DTAVATRAT(I-1)
        Endif

        [M:SIHV]XFDTAAMT([M:SIHV]NBFOOT) = [F:SVF]DTAAMT
        [M:SIHV]XFATI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT+[M:SIHV]XFVATAMT([M:SIHV]NBFOOT)

        [M:SIHV]NBFOOT +=1
      Endif
Endcase

Return

#---------------------------------------------------------------------
$IMPORT_TEXTE
Raz G_NLDET

Case IMPFIC
  When "SQH"

    If G_ENT     : # --- Texte entete ---
       Raz [M:ITC]T_CLE_CLOB(1)
       Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
    Endif

    If G_PIE     : # --- Texte pied ---
       Raz [M:ITC]T_CLE_CLOB(2)
       Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(2)=G_CLE_CLOB
    Endif

  When "SQD"

    If G_DET     : # --- Texte detail ---
       Raz [M:ITC]T_CLE_CLOB(3)
       Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
    Endif

Endcase

Return

######################################################################
# Traitement particulier après chargement de l'enr. importé
#     Raz [F:SQH]
#     Les zones paramétrées sont chargées
#     Les zones non paramétrées sont vides
#     En création [M] est n'est pas chargée
#     En modif. [M] est chargée avec l'enr à modifier
# --------------------------------------------------------------------
$IMP_ZONE

If IMPFIC = "SQH"

#     Texte entete
   If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & GREP="C"
      [M:SQH0]SQHTEX1=[M:ITC]T_CLE_CLOB(1)
   Endif

#     Texte pied
   If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & GREP="C"
      [M:SQH0]SQHTEX2=[M:ITC]T_CLE_CLOB(2)
   Endif

#  chargement champs affiches et invisibles sur appel champ saisissable obligatoire
   If IMPZON="QUODAT" : IMPFICCPL="SQH" : Gosub CPL_FICMSK From =G_NOMTRT : Endif

   If IMPZON = "VACBPR" Then
     # FGR 16/11/2009 : X3SUIVI59843 : Si VACBPR vide dans le fichier, on prend la valeur par défaut
     If [F:SQH]VACBPR = "" Then
       Call INIADI([M:SQH1]VACBPR,"1") From TRTDIV
       IMPMOD = 1
       OK = 0
     Endif
   Endif
Endif

Case IMPFIC
  When "SQH"
    Case IMPZON
      When "SQHTYP"
        # FGR 24/02/2015 : X3SUIVI104383
        If [F:SQH]SQHTYP = "" and G_SQHTYP Then
          # Si la zone est vide et est dans le fichier d'import, on prend SQHTYP comme valeur par défaut
          [F:SQH]SQHTYP = GSQHTYP
        Endif
      When "CCE"
        If [F:SQH]CCE(indice)=""  OK=0 : Endif
    Endcase
Endcase

Return

######################################################################
# Traitement particulier après chargement de l'enr. importé
#     Raz [F:SQD]
#     Les zones paramétrées sont chargées
#     Les zones non paramétrées sont vides
#     En création [M] est n'est pas chargée
#     En modif. [M] est chargée avec l'enr à modifier
# --------------------------------------------------------------------
$IMP_TAB

If IMPFIC = "SQD"

   Case IMPZON

       When "QTY"
#            Texte detail sur QTY (champ obligatoire)
             If G_DET & [M:ITC]T_CLE_CLOB(3)<>""
                If GREP="C" | (GREP="M" & G_NLDET)
                   [M:SQH2]SQDTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
                Endif
             Endif

       When "VACITM1"
           If G_VACITM1 & [F:SQD]VACITM(0)<>[M:SQH2]VACITM1(nolign-1) & [F:SQD]VACITM(0)<>""
               [M:SQH2]VACITM1(nolign-1)=[F:SQD]VACITM(0) : OK=0: IMPMOD=1
            Endif
       When "VACITM2"
            If G_VACITM2 & [F:SQD]VACITM(1)<>[M:SQH2]VACITM2(nolign-1)
               [M:SQH2]VACITM2(nolign-1)=[F:SQD]VACITM(1) : OK=0: IMPMOD=1
            Endif
       When "VACITM3"
            If G_VACITM3 & [F:SQD]VACITM(2)<>[M:SQH2]VACITM3(nolign-1)
               [M:SQH2]VACITM3(nolign-1)=[F:SQD]VACITM(2) : OK=0: IMPMOD=1
            Endif
      #--- X3Suivi 71065 : Gestion code affaire dans les ventes ---#
      When "DPJT"
            If G_DPJT & [F:SQD]PJT<>[M:SQH2]DPJT(nolign-1)

               GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC([F:SQH]SALFCY)
               WNEWPJT = [F:SQH]PJT
               If  GPJTSNGDOC = G_OUI
                 If WNEWPJT <> [F:SQD]PJT
                   If !G_PJTH
                     #-- Tentative d'import affaire ligne $1$ <> affaire entête $2$ (Mono-Affaire) --> Rejet de la valeur ligne
                     Call ECR_TRACE(func AFNC.MES2(mess(1055,196, 1), [F:SQD]PJT, WNEWPJT ),0) From GESECRAN
                  Else
                    #-- Affaire ligne $1$ <> entête $2$. Maj de l'affaire ligne à partir de l'entête  (Société Mono-Affaire)--#
                    Call ECR_TRACE(func AFNC.MES2(mess(1050,196, 1), [F:SQD]PJT, WNEWPJT ),0) From GESECRAN
                    [M:SQH2]DPJT(nolign-1)= WNEWPJT : OK=0: IMPMOD=1
                   Endif
                 Else
                  [M:SQH2]DPJT(nolign-1)=[F:SQD]PJT    : OK=0: IMPMOD=1
                 Endif
               Else
                [M:SQH2]DPJT(nolign-1)=[F:SQD]PJT    : OK=0: IMPMOD=1
               Endif
            Endif
       #--- X3Suivi 71065 : Gestion code affaire dans les ventes ---#
       When "DBPAADD"
            If G_DBPAADD & [F:SQD]BPAADD<>[M:SQH2]DBPAADD(nolign-1)
               [M:SQH2]DBPAADD(nolign-1)=[F:SQD]BPAADD    : OK=0: IMPMOD=1
            Endif
       When "DDAYLTI"
            If G_DDAYLTI & [F:SQD]DAYLTI<>[M:SQH2]DDAYLTI(nolign-1)
               [M:SQH2]DDAYLTI(nolign-1)=[F:SQD]DAYLTI    : OK=0: IMPMOD=1
            Endif
       When "DSTOFCY"
            If G_DSTOFCY & [F:SQD]STOFCY<>[M:SQH2]DSTOFCY(nolign-1)
               [M:SQH2]DSTOFCY(nolign-1)=[F:SQD]STOFCY    : OK=0: IMPMOD=1
            Endif
            Gosub CHARG_ZONE_COMPLEMENT
       # 12/02/09 : Correction suite mail MBT
       When "CCE1", "CCE2", "CCE3", "CCE4", "CCE5", "CCE6", "CCE7", "CCE8", "CCE9", "CCE10",
&           "CCE11","CCE12","CCE13","CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
         #----- Pas de contrôle si les comptes et sections sont importés avec "CAL" -----#
            If find("CPTANALIN",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
               OK=0 : mkstat=1 : # Zones non concernées par SQUOTED
            Endif

   Endcase

#  chargement champs affiches et invisibles sur appel champ saisissable obligatoire
   # Issue X3-38400
   #If IMPZON="QTY" : IMPFICCPL="SQD" : Gosub CPL_FICMSK From =G_NOMTRT : Endif
   If IMPZON="QTY"
      IMPFICCPL="SQD" : Gosub CPL_FICMSK From =G_NOMTRT
      # On charge manuellement [M:JJJ3]ITMREF(nolign-1) pour savoir que CPL_FICMSK a été effectué et que [M:JJJ3] a été chargé pour cette ligne avec l'enregistrement importé
      # [M:JJJ3]ITMREF(nolign-1) sera testé avant l'appel à CPL_MSKFIC afin de recharger [F:SQD] ssi [M:JJJ3] est chargé
      # We charge manually [M:JJJ3]ITMREF(nolign-1) to know that CPL_FICMSK has been done and [M:JJJ3] is charged for this line with the imported record
      # [M:JJJ3]ITMREF(nolign-1) will be tested before call of CPL_MSKFIC to recharged [F:SQD] ssi [M:JJJ3] is charged
      [M:JJJ3]ITMREF(nolign-1)=[M:SQH2]ITMREF(nolign-1)
   Endif
   # End issue X3-38400

Endif

Return

#---------------------------------------------------------------------------------------#
#  Non appelées dans IMP-ZONE : Chgt effectué sur DSTOFCY (dernier champ saisissable    #
#    - Données saisies dans un écran complémentaires                                    #
#    - Données invisibles                                                               #
#---------------------------------------------------------------------------------------#
$CHARG_ZONE_COMPLEMENT

#    Ecran de saisie des motifs
If dim([M:SQH2]PRIREN)>0     & G_PRIREN     : [M:SQH2]PRIREN(nolign-1)    =[F:SQD]PRIREN     : Endif
If dim([M:SQH2]DISCRGREN1)>0 & G_DISCRGREN1 : [M:SQH2]DISCRGREN1(nolign-1)=[F:SQD]DISCRGREN1 : Endif
If dim([M:SQH2]DISCRGREN2)>0 & G_DISCRGREN2 : [M:SQH2]DISCRGREN2(nolign-1)=[F:SQD]DISCRGREN2 : Endif
If dim([M:SQH2]DISCRGREN3)>0 & G_DISCRGREN3 : [M:SQH2]DISCRGREN3(nolign-1)=[F:SQD]DISCRGREN3 : Endif
If dim([M:SQH2]DISCRGREN4)>0 & G_DISCRGREN4 : [M:SQH2]DISCRGREN4(nolign-1)=[F:SQD]DISCRGREN4 : Endif
If dim([M:SQH2]DISCRGREN5)>0 & G_DISCRGREN5 : [M:SQH2]DISCRGREN5(nolign-1)=[F:SQD]DISCRGREN5 : Endif
If dim([M:SQH2]DISCRGREN6)>0 & G_DISCRGREN6 : [M:SQH2]DISCRGREN6(nolign-1)=[F:SQD]DISCRGREN6 : Endif
If dim([M:SQH2]DISCRGREN7)>0 & G_DISCRGREN7 : [M:SQH2]DISCRGREN7(nolign-1)=[F:SQD]DISCRGREN7 : Endif
If dim([M:SQH2]DISCRGREN8)>0 & G_DISCRGREN8 : [M:SQH2]DISCRGREN8(nolign-1)=[F:SQD]DISCRGREN8 : Endif
If dim([M:SQH2]DISCRGREN9)>0 & G_DISCRGREN9 : [M:SQH2]DISCRGREN9(nolign-1)=[F:SQD]DISCRGREN9 : Endif

# Ici : bidouille necessaire pour avoir le bon type de ligne du compose

If dim([M:SQH2]LINTYP)>0
   If G_LINTYP
      If dim([F:ITS]ITMTYP)>0 & [F:ITS]ITMREF=[M:SQH2]ITMREF(nolign-1)
         If [F:ITS]ITMTYP=2 : [F:SQD]LINTYP=6 : Endif
         If [F:ITS]ITMTYP=3 : [F:SQD]LINTYP=2 : Endif
      Endif
      [M:SQH2]LINTYP(nolign-1)=[F:SQD]LINTYP
      If dim([M:JJJ3]LINTYP)>0 : [M:JJJ3]LINTYP(nolign-1)=[F:SQD]LINTYP : Endif
   Endif
Endif


Return


######################################################################
$IMP_INICRE
#  chargement champs affiches et invisibles
IMPFICCPL="SQH" : Gosub CPL_MSKFIC From =G_NOMTRT
Return

######################################################################
$IMP_INIMOD
#  chargement champs affiches et invisibles
IMPFICCPL="SQH" : Gosub CPL_MSKFIC From =G_NOMTRT
Return

######################################################################
# Appele en fin de INICRE_LIG du SUBSQHA
# --------------------------------------------------------------------
$INICRE_LIG
#  chargement champs affiches et invisibles
IMPFICCPL="SQD" : Gosub CPL_MSKFIC From =G_NOMTRT
Return

######################################################################
# Appele en fin de INIMOD_LIG du SUBSQHA
# --------------------------------------------------------------------
$INIMOD_LIG
#  chargement champs affiches et invisibles

# Issue X3-38400
# On teste si [M:JJJ3]ITMREF(nolign-1) est chargé pour savoir si CPL_FICMSK a été effectué et [M:JJJ3] est chargé pour cette ligne avec l'enregistrement importé
# et si on doit executer CPL_MSKFIC pour recharger [F:SQD] avec [M:JJJ3]
# We charge manually [M:JJJ3]ITMREF(nolign-1) to know that CPL_FICMSK has been done and [M:JJJ3] is charged for this line with the imported record
# [M:JJJ3]ITMREF(nolign-1) will be tested before call of CPL_MSKFIC to recharged [F:SQD] ssi [M:JJJ3] is charged
#IMPFICCPL="SQD" : Gosub CPL_MSKFIC From =G_NOMTRT
If [M:JJJ3]ITMREF(nolign-1)=[M:SQH2]ITMREF(nolign-1)
  IMPFICCPL="SQD" : Gosub CPL_MSKFIC From =G_NOMTRT
Endif
# End Issue X3-38400

Return


######################################################################
# --- Fin import
$IMP_FERME
If dim(G_SQHTYP)>0     : Kill G_SQHTYP     : Endif                     # FGR 24/02/2015 : X3SUIVI104383
If dim(G_BPCNAM)>0     : Kill G_BPCNAM     : Endif
If dim(G_BPAORD)>0     : Kill G_BPAORD     : Endif
If dim(G_BPDNAM)>0     : Kill G_BPDNAM     : Endif
If dim(G_QTY)>0        : Kill G_QTY        : Endif
If dim(G_VACITM1)>0    : Kill G_VACITM1    : Endif
If dim(G_VACITM2)>0    : Kill G_VACITM2    : Endif
If dim(G_VACITM3)>0    : Kill G_VACITM3    : Endif
If dim(G_CNCNAM)>0     : Kill G_CNCNAM     : Endif
If dim(G_CNDNAM)>0     : Kill G_CNDNAM     : Endif
If dim(G_PRIREN)>0     : Kill G_PRIREN     : Endif
If dim(G_DISCRGREN1)>0 : Kill G_DISCRGREN1 : Endif
If dim(G_DISCRGREN2)>0 : Kill G_DISCRGREN2 : Endif
If dim(G_DISCRGREN3)>0 : Kill G_DISCRGREN3 : Endif
If dim(G_DISCRGREN4)>0 : Kill G_DISCRGREN4 : Endif
If dim(G_DISCRGREN5)>0 : Kill G_DISCRGREN5 : Endif
If dim(G_DISCRGREN6)>0 : Kill G_DISCRGREN6 : Endif
If dim(G_DISCRGREN7)>0 : Kill G_DISCRGREN7 : Endif
If dim(G_DISCRGREN8)>0 : Kill G_DISCRGREN8 : Endif
If dim(G_DISCRGREN9)>0 : Kill G_DISCRGREN9 : Endif
If dim(G_LINTYP)>0     : Kill G_LINTYP     : Endif
If dim(G_OCNPRNBOM)>0  : Kill G_OCNPRNBOM  : Endif
If dim(G_NDEPRNBOM)>0  : Kill G_NDEPRNBOM  : Endif
If dim(G_INVPRNBOM)>0  : Kill G_INVPRNBOM  : Endif
If dim(G_DBPAADD)>0    : Kill G_DBPAADD    : Endif
If dim(G_DDAYLTI)>0    : Kill G_DDAYLTI    : Endif
If dim(G_DSTOFCY)>0    : Kill G_DSTOFCY    : Endif
If dim(G_FOCFLG)>0     : Kill G_FOCFLG     : Endif

#VPO 28/05/09 51611 il faut supprimer les variables
Gosub IMP_FIN_CPL From TRTX3IMP
Return


#######################################################################
#                        EXPORT
#######################################################################

$EXP_OUVRE

Raz GIMP
If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:TCU])=0    : Local File TABCUR     [TCU]   : Endif
If clalev([F:TCO])=0    : Local File TABCOEFF   [TCO]   : Endif

If clalev([F:BPR])=0    : Local File BPARTNER   [BPR]   : Endif
If clalev([F:BPC])=0    : Local File BPCUSTOMER [BPC]   : Endif
If clalev([F:BPD])=0    : Local File BPDLVCUST  [BPD]   : Endif
If clalev([F:BPT])=0    : Local File BPCARRIER  [BPT]   : Endif
If clalev([F:BPA])=0    : Local File BPADDRESS  [BPA]   : Endif

If clalev([F:ITM])=0    : Local File ITMMASTER  [ITM]   : Endif
If clalev([F:ITS])=0    : Local File ITMSALES   [ITS]   : Endif
If clalev([F:ITU])=0    : Local File ITMBPC     [ITU]   : Endif

Gosub OUVRE_TEXTE

Return

######################################################################

$EXPORT

Case EXPFIC

  When "SQH"
    If G_ENT
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:SQH]SQHTEX1)>0 & [F:SQH]SQHTEX1<>""
          G_CLE_CLOB=[F:SQH]SQHTEX1 : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_PIE
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:SQH]SQHTEX2)>0 & [F:SQH]SQHTEX2<>""
          G_CLE_CLOB=[F:SQH]SQHTEX2 : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif

  When "SQD"
    If G_DET
       Gosub EXP_RAZ_T3 From TRTX3IMP
       If dim([F:SQD]SQDTEX)>0 & [F:SQD]SQDTEX<>""
          G_CLE_CLOB=[F:SQD]SQDTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP
       Endif
    Endif
Endcase

Return

#######################################################################

$PISTAGE

Case ACTION
  When "IMP_ZONE"
    Setmode
#    Infbox ACTION-IMPFIC-IMPZON
  When "IMP_TAB"
    Setmode
#    Infbox ACTION-IMPFIC-IMPZON
  When Default
#    Infbox ACTION
Endcase

Return

