# Nouveau INTSTO
###########################################################
Subprog INTSTO(LFCY,LITM,LLOT,LLOC,LPAL,LCTR,LSER,LDAT,LOPT)
Variable Char    LFCY
Variable Char    LITM
Variable Char    LLOT
Variable Char    LLOC
Variable Char    LPAL
Variable Char    LCTR
Variable Char    LSER
Variable Date    LDAT
Variable Integer LOPT
Local Char PARAM(20)(4)
Local Char PARAM(20)(1..4)
PARAM(2) = LFCY
PARAM(3) = LITM
PARAM(4) = ""
If LITM = ""
  PARAM(1) = "0"
Else
  PARAM(1) = "1"
Endif
Call GCONSULT("SFC","",PARAM) From GCONSULT
End
