#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT CURRENCIES
##############################################################################################################
# GET_CURRND : returns the rounding defined for a given currency
# GET_CURRAT : returns the currency rate for two given currencies
##############################################################################################################

#########################################################################################################
## GET_CURRND
#########################################################################################################
#**
#* Returns the rounding defined for a given currency
#*
#* @param ACTX   Context
#* @param CUR    Currency
#* @param CURRND Currency rounding
#* @param ERRMES Error message
#*!
Funprog GET_CURRND(ACTX,CUR,CURRND,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     CUR()    : # Currency
Variable Decimal  CURRND   : # Currency rounding
Variable Char     ERRMES() : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer ICUR

ICUR=fmet ACTX.ACACHE.ACUR.AGETINDEX(CUR)
If ICUR=[V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = CUR-mess(151,105,1) : End [L]ASTATUS
Endif
CURRND = fmet ACTX.ACACHE.ACUR.AGETVALDEC(CUR,"CURRND")
End [L]ASTATUS

#########################################################################################################
## GET_CURRAT
#########################################################################################################
#**
#* Returns the conversion rate between two currencies
#*
#* @param ACTX    Context
#* @param CURORG  Origin/source currency
#* @param CURDES  Destination currency
#* @param TYPCUR  Rate type
#* @param DAT     Rate date
#* @param RATE    Rate
#*!
Funprog GET_CURRAT(ACTX,CURORG,CURDES,TYPCUR,DAT,RATE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     CURORG
Value    Char     CURDES
Value    Tinyint  TYPCUR
Value    Date     DAT
Variable Decimal  RATE

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK
Local Integer OK
If DAT=[0/0/0] : DAT = gdat$(31,12,adxdcs+99) : Endif : # GHIDATE before
If CURORG=CURDES
 RATE = 1
Else
 If adxtyp=33 | !clalev([F:TCH]): Local File TABCHANGE [TCH] : Endif
 OK = [V]CST_AFALSE
 Filter [TCH] Where CHGTYP=TYPCUR & CURDEN=[L]CURORG & CUR=[L]CURDES & CHGSTRDAT<=[L]DAT Order By Key TCH0 Desc
 For [TCH]
  OK = [V]CST_ATRUE
  Break
 Next
 Filter [TCH]
 If OK=[V]CST_ATRUE
  RATE = [F:TCH]REVCOURS/[F:TCH]CHGDIV
 Else
  RATE = 1
  [L]ASTATUS = [V]CST_AERROR
 Endif
Endif
End [L]ASTATUS
