$_AMANDATORY_RNWFLG
[L]CURPRO = "RNWFLG"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.RNWFLG=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_RNWFLG
[L]CURPRO = "RNWFLG"
If this.RNWFLG<0 or this.RNWFLG>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.RNWFLG)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_RNWFLG
[L]CURPRO = "RNWFLG"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_RNWFLG
[L]CURPRO = "RNWFLG"
Return

$PROPAGATE_RNWFLG
this.isReadonly = 0
[L]CURPRO = "RNWFLG"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_RNWFLG
Gosub DECLARE_VAR From WMC0FXDASSETS
[L]CURPRO = "RNWFLG"
$_LNKPRO_RNWFLG
Return


