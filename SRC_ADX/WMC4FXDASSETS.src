#<AdxTL>@(#)0.0.0.0 $Revision$Class Asset
# Supervisor
## ACLA-CLASSE ## FXDASSETS
# 2018-11-06 07:07:26 073

####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 91 : RNWDAT Renewal date ( Field D4)
####################################################################

$SET_RNWDAT
If [L]_AOLDVAL<>this.RNWDAT
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_RNWDAT
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.RNWDAT
 Gosub PROPAGATE_RNWDAT
Endif
Return

$INIT_RNWDAT
Gosub DECLARE_VAR From WMC0FXDASSETS
[L]CURPRO = "RNWDAT"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_RNWDAT
Gosub DECLARE_VAR From WMC0FXDASSETS
[L]CURPRO = "RNWDAT"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_RNWDAT                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_RNWDAT                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_RNWDAT
[L]CURPRO = "RNWDAT"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.RNWDAT=[0/0/0]
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_RNWDAT
[L]CURPRO = "RNWDAT"
Return

$_AOTHERS_RNWDAT
[L]CURPRO = "RNWDAT"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_RNWDAT
[L]CURPRO = "RNWDAT"
Return

$PROPAGATE_RNWDAT
this.isReadonly = 0
[L]CURPRO = "RNWDAT"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_RNWDAT
Gosub DECLARE_VAR From WMC0FXDASSETS
[L]CURPRO = "RNWDAT"
$_LNKPRO_RNWDAT
Return


####################################################################
# 92 : RNWFLG Effective renewal obligation ( Field Local menu number 1)
####################################################################

$SET_RNWFLG
