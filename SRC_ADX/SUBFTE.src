#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(30)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBFTE","FPERFTE",3,"") From GTRAITE
End 

##############################################################################################
## Programme de modification de période
##       Période = plage entre deux dates
##
##############################################################################################
$ACTION
Case ACTION
    When "INIT_DIA" : Gosub INIT_DIA
    When "EXEC"     : Gosub EXEC
    When Default
Endcase
Return

$INIT_DIA
[M:DIA]DATDEB = gdat$(PARAM(1))
[M:DIA]DATFIN = gdat$(PARAM(2))
Return

$EXEC
PARAM(1) = [M:DIA]DATDEB
PARAM(2) = [M:DIA]DATFIN
Return
