$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(20)(0..GNBDERNIER)
Local Libelle  A_BUF2(0..GNBDERNIER)
Local Char     A_BUF3(70)(0..GNBDERNIER)
Local Char     A_BUF4(5)(0..GNBDERNIER)
Local Char     A_BUF5(20)(0..GNBDERNIER)
Local Char     A_BUF6(10)(0..GNBDERNIER)
Local Char     A_BUF7(10)(0..GNBDERNIER)
Local Char     A_BUF8(15)(0..GNBDERNIER)
Local Char     A_BUF9(15)(0..GNBDERNIER)
Local Char     A_BUF10(30)(0..GNBDERNIER)
Local Char     A_BUF11(30)(0..GNBDERNIER)
Local Libelle  A_BUF12(0..GNBDERNIER)
Local Libelle  A_BUF13(0..GNBDERNIER)
Local Char     A_BUF14(20)(0..GNBDERNIER)
Local Libelle  A_BUF15(0..GNBDERNIER)
Local Libelle  A_BUF16(0..GNBDERNIER)
If clalev([F:NCSRC9])>0 : Close Local File [NCSRC9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(20),
& Libelle  A_TAB2,
& Char     A_TAB3(70),
& Char     A_TAB4(5),
& Char     A_TAB5(20),
& Char     A_TAB6(10),
& Char     A_TAB7(10),
& Char     A_TAB8(15),
& Char     A_TAB9(15),
& Char     A_TAB10(30),
& Char     A_TAB11(30),
& Libelle  A_TAB12,
& Libelle  A_TAB13,
& Char     A_TAB14(20),
& Libelle  A_TAB15,
& Libelle  A_TAB16
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6,A_BUF7,A_BUF8,A_BUF9,A_BUF10,A_BUF11,A_BUF12,A_BUF13,A_BUF14,A_BUF15,A_BUF16
& As [NCSRC9]
Return

$LEC_DERLU
Read [AXXM]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSMANAGER;""
If fstat : Raz [F:AXXM] : Endif
Read [AXXP]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSPLANNER;""
If fstat : Raz [F:AXXP] : Endif
Read [AXXC]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]CREUSR;""
If fstat : Raz [F:AXXC] : Endif
Return

$CHARGE_DERLU
If clalev([F:NCSRC9])>0
 Read [NCSRC9] = [F:NCSRC9]A_TABI
 [L]CLE = [F:NCSRC9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:NCSRC9])>0
 Filter [NCSRC9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [NCSH1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:NCSRC9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:NCSRC]NCSID+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:NCSRC9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:NCSRC9]
 Endif
Endif
Return

