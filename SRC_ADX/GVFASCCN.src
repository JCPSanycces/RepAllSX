#<AdxTL>@(#)0.0.0.0 $Revision$
# MODIFIE PAR : CBO
# LE          : 21 Décembre  2017 16:05:02

$OUVRE_TABLE
 If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif
 If !clalev([F:EVT0]) : Local File =APPLI+".EFASCCN" [EVT0] : Endif
 If !clalev([F:EVT1]) : Local File =APPLI+".EFASCCN" [EVT1] : Endif
Return

$CONDITION_EVE
 LCNDREQEVT="CPY=PCPY & REF=PREF & DPRPLN=LPLN & EVTINT=CODEVTINT & SNSEVE=PSNSEVE"
Return

$RAZ_F_EVT0_1
 Raz [F:EVT0]
 Raz [F:EVT1]
Return

$AIGUILLAGE
 Gosub OUVRE_TABLE
 Gosub RAZ_F_EVT0_1
 Gosub FASCCN
 [F:EVT0]CPY       = PCPY
 [F:EVT0]FCY       = PFCY
 [F:EVT0]REF       = PREF
 [F:EVT0]CURPERSTR = LCURPERSTR
 [F:EVT0]CREUSR    = GUSER
 [F:EVT0]CREDAT    = date$
 [F:EVT0]CRETIM    = time
 [F:EVT0]UPDUSR    = ""
 [F:EVT0]UPDDAT    = [0/0/0]
 [F:EVT0]DPRPLN    = LPLN
 [F:EVT0]EVTINT    = CODEVTINT
 [F:EVT0]EVTDAT    = PDAT
 [F:EVT0]CPTFLG    = 1
 [F:EVT0]SNSEVE    = 1
 [F:EVT0]CREUSRO   = ""
 [F:EVT0]TIMSTPO   = ""
 If PACCDAT<>[0/0/0]
  [F:EVT0]CPTDATINT = PACCDAT
 Else
  [F:EVT0]CPTDATINT = PDAT
 Endif
 Gosub CALCUL_TIMSTP
 Gosub ALIM_CUR
Return
 
$CALCUL_TIMSTP
 [F:EVT0]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EVT0]CREDAT, [F:EVT0]CRETIM)
Return

$ALIM_CUR
 [F:EVT0]CUR=Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
Return

$ANNULE_EVE
 [F:EVT0]SNSEVE = 2
 [F:EVT0]CREUSRO = [F:EVT0]CREUSR
 [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP
 [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT
 [F:EVT0]CREUSR = GUSER
 [F:EVT0]CREDAT = date$
 [F:EVT0]CRETIM = time
 [F:EVT0]UPDUSR = ""
 [F:EVT0]UPDDAT = [0/0/0]
 [F:EVT0]CPTFLG = 1
 [F:EVT0]EVTDAT = PDAT
 Gosub CALCUL_TIMSTP
Return

$FASCCN
 #--> Désignation
 [F:EVT0]DES        = [F:FASZ]AASDES1
 #--> Menus locaux
 [F:EVT0]OBYRNWCONO = G_RNWCONO
 [F:EVT0]OBYRNWCONN = [F:FASZ]OBYRNWCON
 [F:EVT0]TPAFLGO    = G_TPAFLGO
 [F:EVT0]TPAFLGN    = [F:FASZ]TPAFLG
 [F:EVT0]RNWFLGO    = G_RNWFLGO
 [F:EVT0]RNWFLGN    = [F:FASZ]RNWFLG
 #--> Zones numériques
 [F:EVT0]USRFLDM1   = [F:FASZ]USRFLDM1
 [F:EVT0]USRFLDM2   = [F:FASZ]USRFLDM2
 [F:EVT0]USRFLDM3   = [F:FASZ]USRFLDM3
 [F:EVT0]USRFLDM4   = [F:FASZ]USRFLDM4
 [F:EVT0]USRFLDM5   = [F:FASZ]USRFLDM5
 [F:EVT0]USRFLDM6   = [F:FASZ]USRFLDM6
 [F:EVT0]USRFLDC1   = [F:FASZ]USRFLDC1
 [F:EVT0]USRFLDC2   = [F:FASZ]USRFLDC2
 [F:EVT0]RNWTRFCAD  = G_RNWTRFCAD
 #--> Zones alphanumériques
 [F:EVT0]CCNACTCODN = [F:FASZ]CCNACTCOD
 [F:EVT0]CCNACTCODO = G_CCNACTCODO
 [F:EVT0]ACCCOD     = [F:FASZ]ACCCOD
 [F:EVT0]CUR        = Func GLOFCYCPY.GET_DEVISE_PLN([F:FASZ]CPY,G301CPT)
 [F:EVT0]USRFLDA1   = [F:FASZ]USRFLDA1
 [F:EVT0]USRFLDA2   = [F:FASZ]USRFLDA2
 [F:EVT0]USRFLDA3   = [F:FASZ]USRFLDA3
 [F:EVT0]USRFLDA4   = [F:FASZ]USRFLDA4
 [F:EVT0]USRFLDA5   = [F:FASZ]USRFLDA5
 [F:EVT0]USRFLDA6   = [F:FASZ]USRFLDA6
 [F:EVT0]USRFLDA7   = [F:FASZ]USRFLDA7
 [F:EVT0]USRFLDA8   = [F:FASZ]USRFLDA8
 [F:EVT0]USRFLDA9   = [F:FASZ]USRFLDA9
 [F:EVT0]USRFLDA10  = [F:FASZ]USRFLDA10
 [F:EVT0]REN        = [M:FASY]REN
 #--> Dates
 [F:EVT0]USRFLDD1   = [F:FASZ]USRFLDD1
 [F:EVT0]USRFLDD2   = [F:FASZ]USRFLDD2
 [F:EVT0]USRFLDD3   = [F:FASZ]USRFLDD3
 [F:EVT0]USRFLDD4   = [F:FASZ]USRFLDD4
 [F:EVT0]RNWDATO    = G_RNWDATO
 [F:EVT0]RNWDATN    = G_RNWDATN
Return

$ECLATE_NBFLD
 LNBFLD=2
Return

$ECLATE_STATUS
Return

$INFO_EVTINT
 EVT = "FASCCN"
 LPLN= 16
Return

