#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
# Etiquettes                                                            #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTAUTDOF   : Décalage automatique des OF                  #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
 When Default
Endcase
Return

#########################################################################
$INIT
# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

# FQ 48008 Ctrl autorisation avant execution
Local Char OFONCTION(10)
OFONCTION = GFONCTION
GFONCTION  = "FUNMAUTP"
Call AUTORIS From EXEFNC
If GNBAUZ=0
   Call ERREUR(GFONCTION-mess(1,123,1)) From GESECRAN  : # Fonction non autorisée
   GERR=1 : FIN=1  : # ne pas ouvrir la fenêtre
   Return
Endif
GFONCTION = OFONCTION

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub OUVRE


Return

#########################################################################
$INIT_DIA
Local Char    LFCY : LFCY = PARAM(1)
Local Integer LWOP : LWOP = val(PARAM(2))
Local Integer LWOF : LWOF = val(PARAM(3))
Local Integer LJAL : LJAL = val(PARAM(4))
Local Char    LNUM : LNUM = PARAM(5)
Local Integer LRET : LRET = 0

# titre de la boîte
TIT = mess(171,195,1)

Raz [M:DIA]
If LFCY <> "" : [M:DIA]MFGFCY = LFCY : Endif
If LWOP <> 0  : [M:DIA]WOPFLG = LWOP : Endif
If LWOF <> 0  : [M:DIA]WOFFLG = LWOF : Endif
If LJAL <> 0  : [M:DIA]JALFLG = LJAL : Endif
If LNUM <> ""
    [M:DIA]MFGNUMDEB = LNUM
    [M:DIA]MFGNUMFIN = LNUM
    [M:DIA]INDAUT    = 1
Endif

Return



#########################################################################
$CONTROLE
If !GSERVEUR             &
&  [M:DIA]MFGNUMDEB = "" &
&  [M:DIA]MFGNUMFIN = "" &
&  [M:DIA]PJTDEB    = "" &
&  [M:DIA]PJTFIN    = "" &
&  [M:DIA]BPCNUMDEB = "" &
&  [M:DIA]BPCNUMFIN = "" &
&  [M:DIA]VCRNUMDEB = "" &
&  [M:DIA]VCRNUMFIN = "" &
&  [M:DIA]ITMREFDEB = "" &
&  [M:DIA]ITMREFFIN = "" &
&  [M:DIA]STRDATDEB = [0/0/0] &
&  [M:DIA]STRDATFIN = [0/0/0] &
&  [M:DIA]FORMULE   = ""
   GERR = 3
   GMESSAGE = mess(64,190,1)
   FOK = 0
   Return
Endif
TIT=" "
TMP=1
Return

##########################################################################
$EXEC
If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MAUTPSP","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
    # lecture en cours
    Call TEMPON("") From GESECRAN
Endif

# préparation des critères de filtre
Gosub SEL_OF

# traitement des OF
Gosub TRT_OF
Return

##########################################################################
$TERMINE
If !GSERVEUR
    Call TEMPOFF From GESECRAN
    # fermeture trace
    Call FERME_TRACE From LECFIC
    # aucune suppression effectuee ou lecture trace
    If !NBOF
         GERR = 2 : GMESSAGE = mess(88,193,1)
    Endif
    # lecture trace
Endif
Return

########################################################################
$OUVRE
Local Integer  OK
Local Integer  NBOF
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char     CUSFLT(255)
#
Local Char     FORMULE1(255)
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Char     WITMREF(GLONITM)
Local Char     WMFGFCY(GLONFCY)
Local Char     WMFGNUM(GLONVCR)
Local Integer  WMFGLIN
Local Date     WSTRDAT
Local Date     WENDDAT
Local Integer  WSTA
Local Date     WORIDAT
Local Char     WORIFCY(GLONFCY)
Local Integer  WLTI
Local Char     WART(GLONITM)
Local Date     WMEMDAT
Local Integer  WRET
Local Integer  WMAX
Local Decimal  XLTI
Local Integer  ILTI
Local Decimal  WRMD
Local Decimal  WQTY
Local Integer  WPSP

Gosub CHARG_PARAM
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif

# --- Déclaration classes ecran --- #
Local Mask ORDK    [ORDK]
Local Mask MFGK    [MFGK]

Return

########################################################################
# Préparation du filtre sur la table article lancé                     #
########################################################################
$SEL_OF
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
If LNUM = ""
    If [M:DIA]WOPFLG = 2
        CRITERE  = "MFGSTA=2"
        Gosub LOAD_CRITERE
    Endif

    If [M:DIA]WOFFLG = 2
        CRITERE  = "MFGSTA=1"
        Gosub LOAD_CRITERE
    Endif

# fin de la première partie
    CRITERE1 += ")"
Else
    CRITERE1 = "1=1"
Endif


CRITERE  = "MFGFCY = [M:DIA]MFGFCY"     # site de production
Gosub LOAD_CRITERE2

If [M:DIA]MFGNUMDEB <> ""               # borne début OF
    CRITERE = "MFGNUM >= [M:DIA]MFGNUMDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]MFGNUMFIN <> ""               # borne fin   OF
    CRITERE = "MFGNUM <= [M:DIA]MFGNUMFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]PJTDEB <> ""                  # borne début affaire
    CRITERE = "PJT >= [M:DIA]PJTDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]PJTFIN <> ""                  # borne fin   affaire
    CRITERE = "PJT <= [M:DIA]PJTFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]BPCNUMDEB <> ""               # borne début destin.
    CRITERE = "BPCNUM >= [M:DIA]BPCNUMDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]BPCNUMFIN <> ""               # borne fin   destin.
    CRITERE = "BPCNUM <= [M:DIA]BPCNUMFIN"       # 40053 mm 03.07
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]VCRNUMDEB <> ""               # borne début pièce ori.
    CRITERE = "VCRNUMORI >= [M:DIA]VCRNUMDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]VCRNUMFIN <> ""               # borne fin   pièce ori.
    CRITERE = "VCRNUMORI <= [M:DIA]VCRNUMFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ITMREFDEB <> ""               # borne début article lancé
    CRITERE = "ITMREF >= [M:DIA]ITMREFDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ITMREFFIN <> ""               # borne fin   article lancé
    CRITERE = "ITMREF <= [M:DIA]ITMREFFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]STRDATDEB <> [0/0/0]          # borne début date
    CRITERE = "STRDAT >= [M:DIA]STRDATDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]STRDATFIN <> [0/0/0]          # borne fin   date
    CRITERE = "STRDAT <= [M:DIA]STRDATFIN"
    Gosub LOAD_CRITERE2
Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return

############################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return


#---------------------------------------------------------------------#
# Traitement des ordres                                               #
#---------------------------------------------------------------------#
$TRT_OF
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif
#
If CRITERE2 <> ""
    Filter [MFI] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&                Order By Key MFI0
Else
    Filter [MFI] Where evalue(CRITERE1) & evalue(CUSFLT) & evalue(FORMULE1)
&                Order By Key MFI0
Endif
# boucle de lecture
For  [MFI]
    WITMREF = [F:MFI]ITMREF
    WMFGFCY = [F:MFI]MFGFCY
    If [F:MFI]MFGNUM = WMFGNUM : Goto NXT1 : Endif
    WMFGNUM = [F:MFI]MFGNUM
    WMFGLIN = [F:MFI]MFGLIN
    WSTRDAT = [F:MFI]STRDAT
    WENDDAT = [F:MFI]ENDDAT
    WSTA    = [F:MFI]MFGSTA
    Read [MFG]MFG0=[F:MFI]MFGNUM
    If fstat : Goto NXT1 : Endif
    If [F:MFG]MFGTRKFLG > 2
        If [M:DIA]EDIFLG =1 : Goto NXT1 : Endif
    Endif
    If [F:MFG]OPTFLG    = 2  : Goto NXT1 : Endif
    If LNUM = ""
        Case [M:DIA]JALFLG
            When 1: If find([F:MFG]SCDFLG,2,4) : Goto NXT1 : Endif
            When 2: # on continue
        Endcase
    Endif
    Gosub TRTPSP
$NXT1
Next
#
Filter [MFI]
#
Return

#-----------------------------------------------------------------------#
# Traitement décalage                                                   #
#-----------------------------------------------------------------------#
$TRTPSP
# FQ 67806 GA 11/2010 PE BEFTRTLIG idem FUNMAUTO
Local Integer GPE : GPE=1
GPOINT = "BEFTRTLIG" : Gosub ENTREE From EXEFNC
If !GPE Return Endif

Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1
Gosub MAJPSP
Gosub DEVERROU
Return

#-----------------------------------------------------------------------#
# Décalage                                                              #
#-----------------------------------------------------------------------#
$MAJPSP
#
Trbegin [MFG]
    Raz [MFGK]
    [M:MFGK]CODMAJ = "M"
    [M:MFGK]CODTRS = 0
    [M:MFGK]CALCST = 1                 # GH 09/04/2014 bug 99047
    [M:MFGK]MFGNUM = [F:MFG]MFGNUM
    [M:MFGK]MFGLIN = [F:MFI]MFGLIN
    [M:MFGK]MFGFCY = [F:MFG]MFGFCY
    [M:MFGK]MFGSTA = [F:MFG]MFGSTA
    [M:MFGK]ITMREF = [F:MFI]ITMREF
    [M:MFGK]PRVQTY = [F:MFI]EXTQTY     # FQ 71041 GA 01/2011 avant [F:MFG]EXTQTY
    [M:MFGK]EXTQTY = [F:MFI]EXTQTY     # FQ 71041 GA 01/2011 avant [F:MFG]EXTQTY
    [M:MFGK]STRDAT = [F:MFG]STRDAT
    [M:MFGK]ENDDAT = [F:MFG]ENDDAT
    Case [F:MFG]SCDMOD
        When 1:    If [M:DIA]XTRT > 0
                       # révision calendriers (llc 06.00)
# Issue 104571 - 2015-02-05 by JUSYN : New procedure/treatment to calculate shift with calendar days.
#                      Call CALCUL_DATE_PLN([M:MFGK]ENDDAT, [M:DIA]XTRT, [M:MFGK]MFGFCY, 0,
#&                                 [M:MFGK]ENDDAT) From MFGLIB
                       Call CALC_DATE_SHIFT_CALENDAR([M:MFGK]ENDDAT, [M:DIA]XTRT, [M:MFGK]MFGFCY, 0, 0 ,
&                                     [M:MFGK]ENDDAT) From MFGLIB
                   Else
#                      WPSP = abs([M:DIA]XTRT)
#                      # révision calendriers (llc 06.00)
#                      Call CALCUL_DATE_PLN([M:MFGK]ENDDAT, WPSP, [M:MFGK]MFGFCY, 1,
#&                                 [M:MFGK]ENDDAT) From MFGLIB
                       Call CALC_DATE_SHIFT_CALENDAR([M:MFGK]ENDDAT, [M:DIA]XTRT, [M:MFGK]MFGFCY, 1, 1 ,
&                                     [M:MFGK]ENDDAT) From MFGLIB
                   Endif
                   WORIDAT = [M:MFGK]ENDDAT
                   WORIFCY = [M:MFGK]MFGFCY
                   WLTI=0
                   # lecture article site
                   Read [ITF]ITF0=[M:MFGK]ITMREF;[M:MFGK]MFGFCY
                   If fstat : Goto AB_TRTPSP : Endif
                   WQTY = [F:MFG]EXTQTY
                   Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
                   ILTI    = int(XLTI)
                   WRMD    = XLTI - ILTI
                   If WRMD <> 0 : ILTI += 1 : Endif
                   WLTI=ILTI
                   # calcul date
                   WMEMDAT = [M:MFGK]STRDAT
                   # révision calendriers (llc 06.00)
                   Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MFGK]STRDAT)
&                       From MFGLIB
                   Call CHECK_PAST([M:MFGK]STRDAT, 0) From MFGLIB
                   If mkstat
                       WMESS  = mess(156,197,1)-mess(WSTA,317,1)-WMFGNUM+":"
                       WMESS1 = "          "+mess(60,193,1)
                       Goto FIN_TRACE
                   Endif
        When 2:    If [M:DIA]XTRT > 0
                       # révision calendriers (llc 06.00)
# Issue 104571 - 2015-02-05 by JUSYN : New procedure/treatment to calculate shift with calendar days.
#                      Call CALCUL_DATE_PLN([M:MFGK]STRDAT, [M:DIA]XTRT, [M:MFGK]MFGFCY, 0,
#&                                 [M:MFGK]STRDAT) From MFGLIB
                       Call CALC_DATE_SHIFT_CALENDAR([M:MFGK]STRDAT, [M:DIA]XTRT, [M:MFGK]MFGFCY, 0, 0 ,
&                                     [M:MFGK]STRDAT) From MFGLIB
                   Else
#                      WPSP = abs([M:DIA]XTRT)
                       # révision calendriers (llc 06.00)
#                      Call CALCUL_DATE_PLN([M:MFGK]STRDAT, WPSP, [M:MFGK]MFGFCY, 1,
#&                                 [M:MFGK]STRDAT) From MFGLIB
                       Call CALC_DATE_SHIFT_CALENDAR([M:MFGK]STRDAT, [M:DIA]XTRT, [M:MFGK]MFGFCY, 1, 1 ,
&                                     [M:MFGK]STRDAT) From MFGLIB
                   Endif
                   # antériorité par rapport à la date du jour ?
                   Call CHECK_PAST([M:MFGK]STRDAT, 0)  From MFGLIB
                   If mkstat
                       WMESS  = mess(156,197,1)-mess(WSTA,317,1)-WMFGNUM+":"
                       WMESS1 = "          "+mess(60,193,1)
                       Goto FIN_TRACE
                   Endif
                   # révision calendriers (llc 06.00)
                   Call CONTROL_DATE_PLN([M:MFGK]STRDAT, [M:MFGK]MFGFCY) From MFGLIB
                   If mkstat = 2
                       If [M:DIA]XTRT > 0
                           # révision calendriers (llc 06.00)
                           Call CALCUL_DATE_PLN([M:MFGK]STRDAT, 1, [M:MFGK]MFGFCY, 0,
&                               [M:MFGK]STRDAT) From MFGLIB
                       Else
                           # révision calendriers (llc 06.00)
                           Call CALCUL_DATE_PLN([M:MFGK]STRDAT, 1, [M:MFGK]MFGFCY, 1,
&                               [M:MFGK]STRDAT) From MFGLIB
                       Endif
                       mkstat = 0
                   Endif
                   WORIDAT = [M:MFGK]STRDAT
                   WORIFCY = [M:MFGK]MFGFCY
                   WLTI=0
                   # lecture article site
                   Read [ITF]ITF0=[M:MFGK]ITMREF;[M:MFGK]MFGFCY
                   If fstat : Goto AB_TRTPSP : Endif
                   WQTY = [F:MFG]EXTQTY
                   Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
                   ILTI    = int(XLTI)
                   WRMD    = XLTI - ILTI
                   If WRMD <> 0 : ILTI += 1 : Endif
                   WLTI=ILTI
                   # calcul date
                   WMEMDAT = [M:MFGK]ENDDAT
                   # révision calendriers (llc 06.00)
                   Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MFGK]ENDDAT)
&                       From MFGLIB
    Endcase
    [M:MFGK]BOMALT = [F:MFI]BOMALT
    [M:MFGK]ROUNUM = [F:MFG]ROUNUM
    [M:MFGK]ROUALT = [F:MFG]ROUALT
    [M:MFGK]PJT    = [F:MFI]PJT
    [M:MFGK]LOT    = [F:MFI]LOT
    Call MAJ_OF From MFGAUTLIB
    If [M:MFGK]CODRET <> 0 : Goto AB_TRTPSP : Endif
    WMESS   = mess(156,197,1)-mess(WSTA,317,1)-WMFGNUM-mess(204,197,1)+"."
    WMESS1  = "          "+"("+mess(205,197,1)-"="-format$(GFMD,WSTRDAT)-mess(38,197,1)-
&             format$(GFMD,WENDDAT)-mess(206,197,1)-"="-format$(GFMD,[M:MFGK]STRDAT)-
&             mess(38,197,1)-format$(GFMD,[M:MFGK]ENDDAT)+")"
$FIN_TRACE
    Call ECR_TRACE(WMESS,0)  From GESECRAN
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    Raz WMESS, WMESS1, WMESS2
    NBOF += 1
Commit
Return


#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête OF                            #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "MFG"+[F:MFG]MFGNUM
Lock = SYMBOLE With lockwait = 0
OK = 1
If fstat
    Call ECR_TRACE([F:MFG]MFGNUM - mess(10,100,1),1) From GESECRAN
    OK = 0
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête OF                                 #
#-----------------------------------------------------------------------#
$DEVERROU
Unlock=SYMBOLE
Return

$ROL_TRTPSP
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJPSP : Endif
Return

$AB_TRTPSP
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

#######################################################################
#                     ETIQUETTES                                      #
#######################################################################

Subprog C_WOFFLG(VALEUR)
Variable Integer  VALEUR
If [M:DIA]WOPFLG = 1 & VALEUR = 1
    GERR = 1 : GMESSAGE = mess(359,199,1)
    mkstat = 2  : # une case au moins doit être cochée !
Endif
End

########################################
Subprog B1_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
# 06.03 WEB MM
If dim (GBPRSEL)>0  : Kill GBPRSEL : Endif
#
End

########################################
Subprog AS_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
GBOUT1=mess(72,198,1)
GBOUT2=mess(154,198,1)
End

########################################
Subprog B1_BPCNUMFIN(VALEUR)
Variable Char    VALEUR()
# 06.03 WEB MM
If dim (GBPRSEL)>0  : Kill GBPRSEL : Endif
#
End

########################################
Subprog AS_BPCNUMFIN(VALEUR)
Variable Char    VALEUR()
GBOUT1=mess(72,198,1)
GBOUT2=mess(154,198,1)
End


########################################
Subprog C_STRDATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:DIA]STRDATDEB
    GERR = 1 : GMESSAGE = mess(171,193,1)
    mkstat = 2
Endif
End

########################################
Subprog AM_MFGNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]MFGNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]PJTFIN = VALEUR : Endif
End

########################################
Subprog AM_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]BPCNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]VCRNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Endif
End

########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02
End

########################################
Subprog AM_XJAL(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    Actzo [M:DIA]25
    When 2:    Grizo [M:DIA]25
Endcase
End

##########################################################################
# pour les batchs                                                        #
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK)
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..)
Variable Integer OK

Gosub OUVRE

