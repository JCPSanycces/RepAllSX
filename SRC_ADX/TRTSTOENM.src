End

########################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()

#--- Issue 110327
Local Integer NOL : NOL=nolign-1
Local Integer OK  : OK=1
Local Integer LRET, PRET
Local Integer NBSER
Local Char    WSER(GLONSER)
Local Char    SERDEB(GLONSER)
Local Char    SERFIN(GLONSER)
Local Char    VALEURFIN(GLONSER)
Local Decimal WPCUDIS, WSTUACTDIS
If [F:ITM]SERMGTCOD=4
  If VALEUR=[M:ENM]SERNUM(NOL) : End : Endif
  If VALEUR=""      : mkstat=2 : End : Endif
  # Vérification de la disponibilité du stock
  If [M:ENM]STOCOU(NOL)<>0
    Read [STO]STO0=[M:ENM]STOFCY;[M:ENM]STOCOU(NOL)
    If fstat
      Raz [M:ENM]STUDIS(NOL),WSTUACTDIS
      mkstat=2 : GMESSAGE=mess(818,196,1)
      End
    Else
      Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,[M:ENM]STUDIS(NOL),WSTUACTDIS) From STKLIB
    Endif
    Affzo [M:ENM]STUDIS(NOL)
    If [M:ENM]QTYSTU(NOL)<[M:ENM]QTYSTUO(NOL)-[M:ENM]STUDIS(NOL)
      mkstat=2 : GMESSAGE=mess(818,196,1)
      End
    Endif
  Endif
  # Détermination du nombre et des no séries début et fin à contrôler
  Call PLUS_NB(VALEUR,[ENM]QTYSTU(NOL),VALEURFIN,LRET) From STKLIB
  If [M:ENM]SERNUMO(NOL)<>""
    # La séquence origine et la nouvelle séquence sont discontinues --> 2 boucles
    If VALEUR>[M:ENM]SERNUMFO(NOL) | VALEURFIN<[M:ENM]SERNUMO(NOL)
      SERDEB=""
      SERFIN=""
    # Les deux séquences se chevauchent --> 1 boucle
    Else
      SERDEB=min(VALEUR,[M:ENM]SERNUMO(NOL))
      SERFIN=max(VALEURFIN,[M:ENM]SERNUMFO(NOL))
    Endif
  # Pas de séquence origine --> 1 boucle
  Else
    SERDEB=VALEUR
    SERFIN=VALEURFIN
  Endif

  If SERDEB="" & SERFIN=""
    # Boucle de contrôle des no séries de la nouvelle séquence
    NBSER = [ENM]QTYSTU(NOL)
    WSER  = VALEUR
    Gosub LOOP_SERIE
    If OK=0
      Gosub ERROR_SERIE
      mkstat=2 : GERR=1
    Else
      # Boucle de contrôle des no séries de la séquence origine
      Call NB_SERIE([M:ENM]SERNUMO(NOL),[M:ENM]SERNUMFO(NOL),NBSER,LRET) From STKLIB
      WSER  = [M:ENM]SERNUMO(NOL)
      Gosub LOOP_SERIE
      If OK=0
        Gosub ERROR_SERIE
        mkstat=2 : GERR=1
      Else
        [M:ENM]SERNUMF(NOL)=VALEURFIN
      Endif
    Endif
  Else
    # Boucle de contrôle des no séries si séquences avec chevauchement
    Call NB_SERIE(SERDEB,SERFIN,NBSER,LRET) From STKLIB
    WSER=SERDEB
    Gosub LOOP_SERIE
    If OK=0
      Gosub ERROR_SERIE
      mkstat=2 : GERR=1
    Else
      [M:ENM]SERNUMF(NOL)=VALEURFIN
    Endif
  Endif
  End
Endif
#--- End issue 110327

If VALEUR<>[M:ENM]SERNUM(nolign-1)
   Gosub CTL_ALL
Endif

If VALEUR <> [M:ENM]SERNUMO(nolign-1)
    Call STKCTRSER( VALEUR, [M:ENM]ITMREF,
&                   nolign-1, [M:ENM]NBLIG,
&                   0, [M:ENM]TRSTYP,
&                   [M:ENM]VCRTYP,
&                   [M:ENM]VCRNUM,
&                   [M:ENM]VCRLIN,
&                   [M:ENM]VCRTYPORI,
&                   [M:ENM]VCRNUMORI,
&                   [M:ENM]VCRLINORI,
&                   [M:ENM]VCRSEQORI,
&                   [F:ITM]SERCOU="" & [F:TLO]LOCCAT<>2, "") From STKACT
Endif

End

#--- Issue 110327
$LOOP_SERIE
While NBSER>0 & OK=1
  # Lecture no série
  Call LECSER ([M:ENM]ITMREF,WSER,"",LRET) From STKLIB
  # Il s'agit d'une nouvelle ligne ou le no série sera entré par le document
  If [M:ENM]SERNUMO(NOL)="" | [M:ENM]SERNUMFO(NOL)="" | WSER<[M:ENM]SERNUMO(NOL) | WSER>[M:ENM]SERNUMFO(NOL)
    Gosub CONTROL_SERIE
  # Le no série était entré par le document et ne le sera plus,
  # ou était entrée par le document et le sera toujours
  # --> Il doit exister et ne pas être sorti ou alloué ou en cours de traitement
  Else
    If LRET=0
      OK=0
    Elsif [F:STS]ISSDAT<>[0/0/0] | [F:STS]SDHNUM<>"" | func STKLIB.REC_STOSERW_UID([M:ENM]ITMREF,WSER,adxuid(1))<>0
      OK=0
    Endif
  Endif
  NBSER-=1
  If NBSER>0 & OK=1
    Call PLUS_UN(WSER,WSER,LRET) From STKLIB
    If LRET<>0
      OK=0 : PRET=7
    Endif
  Endif
Wend
Return

$CONTROL_SERIE
Local Integer I

Case [M:ENM]TRSTYP
 When 1    : # Entrée diverse : le no série ne doit pas exister sauf s'il a été sorti par une sortie diverse
             If LRET=1 & ([F:STS]ISSDAT=[0/0/0] | !find([F:STS]SDHTYP,20,31,32))
               OK=0 : PRET=3
             Endif
 When 3,16 : # Réception : le no série doit exister si la pièce origine n'est pas une commande
             If LRET=0 & [M:ENM]VCRNUMORI<>"" & [M:ENM]VCRTYPORI<>14
               OK=0 : PRET=0
             # s'il existe, il doit avoir été sorti par la pièce origine
             Elsif LRET=1
               If [F:STS]ISSDAT=[0/0/0]
                 OK=0 : PRET=3
               Elsif [F:STS]SDHTYP<>[M:ENM]VCRTYPORI | [F:STS]SDHNUM<>[M:ENM]VCRNUMORI
                 OK=0 : PRET=8
               Elsif [F:STS]SDDLIN<>[M:ENM]VCRLINORI
                 OK=0 : PRET=9
               Endif
             Endif
 When 5    : # Declaration production : le no série ne doit pas exister
             If LRET=1
               OK=0 : PRET=1
             Endif
 When 12   : # Retour client : le no série doit exister et la date de sortie être renseignée
             If LRET=0
               OK=0 : PRET=0
             Elsif [F:STS]ISSDAT=[0/0/0]
               OK=0 : PRET=3
             Elsif [M:ENM]VCRNUMORI<>""
               If [F:STS]SDHTYP<>[M:ENM]VCRTYPORI | [F:STS]SDHNUM<>[M:ENM]VCRNUMORI
                 OK=0 : PRET=8
               Elsif [F:STS]SDDLIN<>[M:ENM]VCRLINORI
                 OK=0 : PRET=9
               Endif
             Endif
 When 18   : # Retour pret : le no série doit exister et être sorti par la pièce origine
             If LRET=0
               OK=0 : PRET=0
             Elsif [F:STS]SDHNUM=""
               OK=0 : PRET=3
             Elsif [F:STS]SDHTYP<>[M:ENM]VCRTYPORI | [F:STS]SDHNUM<>[M:ENM]VCRNUMORI
               OK=0 : PRET=8
             Elsif [F:STS]SDDLIN<>[M:ENM]VCRLINORI
               OK=0 : PRET=9
             Endif
             If OK=1 : [M:ENM]STOCOUORI(NOL)=[F:STS]STOCOU : Endif
 When 33   : # Retour matière sous-traitance : le no série doit exister
             If LRET=0
               OK=0 : PRET=0
             Elsif [F:STS]ISSDAT<>[0/0/0]
               OK=0 : PRET=6
             Else
               Read [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
               If fstat | [F:STO]LOCCAT<>4
                 OK=0 : PRET=10
               Endif
               If [F:STS]SDHNUM<>"" & [F:STS]SDHNUM<>[M:ENM]VCRNUMORI
                 OK=0 : PRET=8
               Endif
             Endif
             If OK=1 : [M:ENM]STOCOUORI(NOL)=[F:STS]STOCOU : Endif
 When Default : Wrnbox "Cas non traité"+chr$(13)+"TRSTYP="+num$(PTRS)
Endcase
If OK=0 : Return : Endif

# No série en cours de création
If func STKLIB.REC_STOSERW_UID([M:ENM]ITMREF,WSER,adxuid(1))<>0
  OK=0 : PRET=2 : Return
Endif
For I=0 To [M:ENM]NBLIG-1
  # Le no série est déjà présent dans une ligne
  If I<>NOL & WSER>=[M:ENM]SERNUM(I) & WSER<=[M:ENM]SERNUMF(I)
    OK=0 : PRET=2 : Break
  Endif
Next I
If OK=0 : Return : Endif

Return

$ERROR_SERIE
Case PRET
 When 0  : GMESSAGE = WSER-":"-mess(43,196,1)  # Numero de Série inexistant
 When 1  : GMESSAGE = WSER-":"-mess(3,187,1)   # Numero de Série existant
 When 2  : GMESSAGE = WSER-":"-mess(69,187,1)  # Numero de Série en cours de création
 When 3  : GMESSAGE = WSER-":"-mess(93,184,1)  # Numéro de série présent en stock
 When 4  : GMESSAGE = WSER-":"-mess(72,187,1)  # Document de sortie renseigné
 When 5  : GMESSAGE = WSER-":"-mess(73,187,1)  # Date de sortie renseignée
 When 6  : GMESSAGE = WSER-":"-mess(40,196,1)  # Saisie des numéros de série incorrecte
 When 7  : GMESSAGE = num$([ENM]QTYSTU(NOL))-":"-mess(130,194,1) # Nombre de no de série sélectionnés incorrect
 When 8  : GMESSAGE = WSER-":"-mess(37,184,1)  # N° de série sorti par une autre pièce
 When 9  : GMESSAGE = WSER-":"-mess(38,184,1)  # N° de série sorti sur une autre ligne de la pièce
 When 10 : GMESSAGE = WSER-":"-mess(494,184,1) # N° de série n'est pas dans un emplacement sous-traitant
Endcase
Return
#--- End issue 110327

########################################
Subprog IB_SERNUM
Gosub SET_NOL
# Compteur Série
Raz GBOUT1
#--- Issue 110327
If [F:ITM]SERMGTCOD<>4 | [M:ENM]SERNUM(NOL)=""
  If func STKLIB.SENSVCR([M:ENM]VCRTYP)=1 & [F:ITM]SERCOU <> ""
    GBOUT1 = mess(446,198,1)
  Endif
#--- Issue 110327
Endif

If find([M:ENM]VCRTYP,13,18)
    Raz GBOUT2
Else
    Raz GBOUT3
    If [M:ENM]VCRTYP <> 13
        Raz GBOUT2
    Endif
Endif
End

########################################
Subprog B1_SERNUM(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
Local Char    WSER(GLONSER) : WSER = ""
Local Integer WRET          : WRET = 0
Local Integer I

For I = 1 To [M:ENM]QTYSTU(NOL)
    Call NUMERO([F:ITM]SERCOU,[M:ENM]STOFCY,[M:ENM]IPTDAT(NOL),[F:ITM]ITMREF,WSER,WRET) From SUBANM

    If WRET = 1  mkstat = 2 :
       GMESSAGE= [F:ITM]SERCOU-":"-mess(816,196,1)
    Endif
    If WRET = 2  mkstat = 2 :
       GMESSAGE= [F:ITM]SERCOU-":"-mess(30,196,1)
    Endif

    If I = 1
       VALEUR= WSER
    Endif
    #--- Issue 110327
    #If I=[M:ENM]QTYSTU(NOL)
    #   [M:ENM]SERNUMF(NOL)=WSER
    #Endif
    #---
Next I

End

########################################
Subprog C_LBENBR(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
    Diszo [M:ENM]LBEFMT(nolign-1)
Else
    Actzo [M:ENM]LBEFMT(nolign-1)
    If [M:ENM]LBEFMT(nolign-1)=""
        Local Char    LUSCAV(5)
        Local Integer LMODIF
        Local Char    LLBEFMT(GLONARP)
        Local Decimal LCOEF
        Call CTLUOM ([M:ENM]ITMREF,3,[M:ENM]BPRNUM, [M:ENM]PCU(nolign-1), LCOEF, LUSCAV, LLBEFMT, LMODIF) From STKACT
        [M:ENM]LBEFMT(nolign-1) = LLBEFMT
    Endif
Endif

End

#############################################
Subprog C_PALNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M:ENM]PALNUM(nolign-1)
   Gosub CTL_ALL
Endif
End

#############################################
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M:ENM]CTRNUM(nolign-1)
   Gosub CTL_ALL
Endif
End

################################################################################
# Interdiction de changer les caractéristiques de la ligne de stock
# s'il y a des allocations et que la qté du mouvement est >= à la qté en stock
# (car suppression ligne de stock et perte du lien dans l'allocation)
################################################################################
$CTL_ALL
Local Integer I
Local Decimal WQTY
Local Char    WMSG(240)
Gosub SET_NOL
If [M:ENM]ORILIG (NOL) = 5
   Read [STO]STO0=[M:ENM]STOFCY;[M:ENM]STOCOU(NOL)
   If fstat Raz [F:STO] Endif
   # Qté mouvement >= qté ligne de stock
   If [M:ENM]QTYSTUO(NOL)>=[F:STO]QTYSTUACT
      For [STA]STA0 Where STOFCY=[M:ENM]STOFCY & ITMREF=[M:ENM]ITMREF & STOCOU=[M:ENM]STOCOU(NOL)
         # Il y a des allocations
         WQTY+=[F:STA]QTYSTUACT
         I+=1
         If I<=3
            If WMSG<>"" WMSG+="\" Endif
            WMSG+=mess([F:STA]VCRTYP,701,1)-[F:STA]VCRNUM-num$([F:STA]VCRLIN)-":"-mess(106,197,1)-num$([F:STA]QTYSTUACT)
         Endif
      Next
      If WQTY>0
         GMESSAGE=mess(90,192,1)+"\"+WMSG
         mkstat=2
      Endif
   Endif
Endif


Return

#                                                                            # hcb 110327 deb
Subprog AS_SERNUM(VALEUR)
Variable Char    VALEUR()
# si Article en serie global :
# si emplacement quai
#     saisie ok si plan de rangement  (VCRTYP = 27)
#     saisie ok si  retour client sur livraison   (vcrtyp = 13 et vcrnumori <> "")
If [M:ENM]VCRTYP = 13 & dim([M:ENM]LOCTYP) > 0 & [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2
   If [M:ENM]VCRNUMORI = ""
      mkstat = 2
      End
   Else
      End
   Endif
Endif

If dim([M:ENM]LOCTYP) > 0 & [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2 & [M:ENM]VCRTYP <> 27
   mkstat = 2
Endif
End
#                                                                            # hcb 110327 fin

