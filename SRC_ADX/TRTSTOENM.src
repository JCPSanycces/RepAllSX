#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################
# TRTSTOENM    Modifications mouvements entrées                         #
#########################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "INIT"        : Gosub INIT
 When "TITRE"       : Gosub TIT_TRT
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "ABA"         : Gosub ABA
 When "EXEC"        : Gosub EXEC   # Three way matching
 When "FINSAI"      : Gosub FINSAI
 When "FIN"         : Gosub FIN
Endcase
Return
#########################################################################

$INIT
If GOUVENT<2
    FIN=1
    Return
Endif

# X3-80367 - STWIL - Create a global flag so that we do not prompt for every stock line
Global Integer GNCSLINFLG : GNCSLINFLG = 0

#recuperation ecran généré de la saisie des entrées
Local Char       LBOI(GLONFEN) : LBOI  =      PARAM(3)

# ouverture de l ecran géneré
If LBOI <> ""
    BOITE = LBOI
Endif

Return
#########################################################################
$TIT_TRT
Local Char    WTAB
Local Char    WTRS(2)
Case LTYP
  When  6    : WTAB="PURTRS"   : WTRS="6"
  When 12    : WTAB="BENCHTRS" : WTRS="63"
  When 13    : WTAB="SALTRS"   : If LABR="SRH1"
                                    WTRS="6"
                                 Elsif LABR="SRL1"
                                    WTRS="7"
                                 Else
                                    WTRS="8"
                                 Endif
  When 15    : If LABR="PSTT"
                  WTAB="PURTRS"  : WTRS="6"
               Elsif LABR="MTK2"
                  WTAB="MFGTRS"  : WTRS="2"
               Elsif LABR="MBI"
                  WTAB="BENCHTRS": WTRS="62"
               Endif
  When 18    : WTAB="SALTRS" : WTRS="5"
  When 19    : WTAB="STKTRS" : WTRS="1"
  When 27    : WTAB="STKTRS" : WTRS="5"
  When 31,32 : WTAB="STKTRS" : WTRS="7"
Endcase
Call LECTEXTRA(TIT,WTAB,"DESAXX",WTRS,GFLAG) From ATEXTRA
If !clalev([F:AWI]) : Local File AWINDOW : Endif
Read [AWI]AWI0=BOITE
Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
TIT = GBIDC1-GFLAG-":"-TIT
Return

#########################################################################
$OUVRE_BOITE
#########################################################################
#recuperation parametre standard
#recuperation type de piece (m701)
Local Integer    LTYP : LTYP  = val(PARAM(1))
#recuperation code ecran
Local Char       LABR : LABR  =     PARAM(2)
#recuperation numero de ligne
Local Integer    LLIGDOC  : LLIGDOC = val(PARAM(4))

Local Char    LFCY(GLONFCY) : LFCY = PARAM(5)
Local Char    LBPR(GLONBPR) : LBPR = PARAM(6)
Local Integer LTRSTYP       : LTRSTYP = val(PARAM(7))
Local Char    LTRSCOD(5)    : LTRSCOD = PARAM(8)
Local Integer LTOOLIG       : Raz LTOOLIG    # Indique s'il y a plus de mouvements que de lignes dans le tableau (=gconsult+1)
#--- Issue 122875 remplacement LMSKCOU(7) par LMSKCOU(10)
Local Char    LMSKCOU(10)   : LMSKCOU = func STKLIB.MSKDEF
Global Char   GSAIFLG(15)   : GSAIFLG = "000000000000000"
Global Char   GCHPSTO(GLONAVA)(1..15)
GCHPSTO(1) = "PCU"
GCHPSTO(2) = "QTYPCU"
GCHPSTO(3) = "PCUSTUCOE"
GCHPSTO(4) = "STA"
GCHPSTO(5) = "LOCTYP"
GCHPSTO(6) = "LOC"
GCHPSTO(7) = "BPSLOTAFF"
GCHPSTO(8) = "LOTAFF"
GCHPSTO(10)= "SLOAFF"
GCHPSTO(11)= "SERNUM"

Default Mask "["+LABR+"]"
Call LECFICENT(LFCY,LBPR,"",LLIGDOC,LTRSTYP,LTRSCOD,0) From STKECR
Default Mask LMSKCOU


#########################################################################

Local Integer MAJLIGDOC    # Indique si la maj de la ligne de document est nécessaire
                           # =1 si modif mvtdes ou apres_nblig
Raz MAJLIGDOC

 Case LTYP
      When 6   : GBIDC1  = mess(6,701,1)        # reception
      When 13  : GBIDC1  = mess(13,701,1)       # retour client / retour pret
      When 18  : GBIDC1  = mess(18,701,1)       # avoir vente
      When 19  : GBIDC1  = mess(19,701,1)       # entree diverse
      When 15  : GBIDC1  = mess(15,701,1)       # declaration production
      When 23  : GBIDC1  = mess(23,701,1)       # reception transfert inter site
      When 25  : GBIDC1  = mess(25,701,1)       # reception sous traitance
      When 12  : GBIDC1  = mess(26,701,1)       # reintegration stock
      When 31  : GBIDC1  = mess(31,701,1)       # Assemblage
      When 32  : GBIDC1  = mess(32,701,1)       # Desassemblage

Endcase

If clalev([F:STL])=0 Local File STOLOT     [STL]  Endif
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM]  Endif
If clalev([F:ITP])=0 Local File ITMBPS     [ITP]  Endif
If clalev([F:TUN])=0 Local File TABUNIT    [TUN]  Endif
If clalev([F:STJ])=0 Local File STOJOU     [STJ]  Endif
If clalev([F:STO])=0 Local File STOCK      [STO]  Endif
If clalev([F:STS])=0 Local File STOSER     [STS]  Endif
If clalev([F:STA])=0 Local File STOALL     [STA]  Endif
If clalev([F:ITG])=0 Local File ITMCATEG   [ITG]  Endif
If clalev([F:SRU])=0 Local File TABSTORUL  [SRU]  Endif
If clalev([F:TST])=0 Local File TABSTASTO  [TST]  Endif
If clalev([F:STP])=0 Local File STOCOST    [STP]  Endif
If clalev([F:STC])=0 Local File STOLOC     [STC]  Endif
If clalev([F:TLO])=0 Local File TABLOCTYP  [TLO]  Endif
If clalev([F:SRT])=0 Local File STKTRS     [SRT]  Endif
If GWRHACT=2
   If clalev([M:ITW])=0  Local File ITMWRH    [ITW] Endif
   If clalev([F:WRH])=0  Local File WAREHOUSE [WRH] Endif
Endif

If clalev([M:ENTL])=0 Local Mask STOENTLOT [ENTL] Endif  #  ecran saisie complement lot
#--- X3-53322
If clalev([F:LPN])=0 Local File LPN        [LPN]  Endif
If clalev([F:ACV])=0 Local File ACTIV      [ACV]  Endif
#---
# C'est fait en automatique dans WINPROG
## ouverture et lecture du dictionnaire des fenetres pour recuperer l ecran generé
#If clalev([F:AWI])=0 Local File AWINDOW [AWI] : Endif
#Local Char WNOMMSK(10)
#Read [AWI] AWI0=BOITE
#If fstat
#   WNOMMSK="STOENT"
#Else
#   WNOMMSK=[F:AWI]NOMMSK(0)
#Endif
#If clalev([M:ENM])=0 Local Mask = WNOMMSK   [ENM] Endif  #  ecran stockage

#desactivation des rubriques ecrans suivant le contexte
Gosub FORMAT_INV     From STKLIB

# Choix traitement numéros de série
If find(LTYP,6,12,15,19,23)
  If [F:ITM]SERMGTCOD = 1 | [F:ITM]SERMGTCOD = 2
     Gosub FORMAT_INV_ENT From STKLIB
  Endif
Endif

#--- 110327
If [F:ITM]SERMGTCOD=3
   GWSINVSERF= "-"+GSINVSERF
   GWSINTSERF= ""
Endif
#---

Return

#########################################################################
$DEBUT
#########################################################################

Raz [M:ENM]
Raz [M:ENTL]

# X3-80367 - Reset the message flag for this change.
GNCSLINFLG = 0

[M:ENM]STOFCY = LFCY
[M:ENM]BPRNUM = LBPR
[M:ENM]TRSTYP = LTRSTYP
[M:ENM]TRSCOD = LTRSCOD

#--- X3-Issue 53322
#                                                             # hcb X3-96610 deb
#[M:ENM]LOTACT = 1
[M:ENM]LOTACT = 0
#Read [ACV] CODACT = "LOT"
#If !fstat [M:ENM]LOTACT=[F:ACV]FLACT Endif
[M:ENM]LOTACT     = func AFNC.ACTIV("LOT")    # Is LOT activated ?
[M:ENM]LOTACT  +=1
#                                                             # hcb X3-96610 fin
#---

# Chargement des blocs ENTETE / PARAMETRAGE  ecran STOENTM
Gosub CHARG_PARAM_STOENTM From TRTSTOENMA

#Call INIT_GOUVLOT([M:ENM]TABLE1) From STKENT

Default Mask "["+LABR+"]"
# Lecture ITMMASTER
# Lecture ITMMCATEG
# Lecture ITMBPS
# Lecture règle de gestion de stock

# Lecture emplacement
Default Mask "[ENM]"

# Dépôt obligatoire ou renseigné sur ligne document --> non modifiable
If [M:ENM]XWRH<>""
   [M:ENM]WRHOBY=2
Else
   [M:ENM]WRHOBY=1
Endif

Affzo [M:ENM]

[M:ENM]VCRTYP = LTYP
[M:ENM]STU    = [F:ITM]STU


# Chargement des lignes à partir des mouvements de stock du document origine
Gosub CHARG_LIGNE_STOENTM From TRTSTOENMA

If FIN=1 Return Endif

If [M:ENM]COETOENT = 0
   [M:ENM]COETOENT = 1
Endif

Gosub GESSELECTION From TRTSTOENTB

[M:ENM]COEFUCUS  = [M:ENM]PCUTOENT+"  ="+format$("N:5.4",[M:ENM]COETOENT)+"  "+[F:ITM]STU

#---------- Positionnement de la variable GSAIFLG --------#
If [F:SRU]DACLOT = 1
    GSAIFLG = left$(GSAIFLG,7) + "2" + right$(GSAIFLG,9)
Endif
#--- si article gére le numéro de serie en entrées sortie desactivation des rubriques
If dim([M:ENM]SERNUM(0))>0 & ([M:ENM]SERNUM(0)<>"" | mid$(GSAIFLG,11,1)<>"0" & [F:ITM]SERMGTCOD>1)
    GSAIFLG = "222" + right$(GSAIFLG,4)
Endif

Gosub CTL_MODIF From TRTSTOENMA

#---------- Positionnement du filtre type emplacement --------#
If  [M:ENM]SRGWAIFLG<>2
    If [M:ENM]FILLOCENT=""
        [M:ENM]FILLOCENT = "[F:TLO]LOCCAT<>2"
    Else
        [M:ENM]FILLOCENT += "&[F:TLO]LOCCAT<>2"
    Endif
Endif

#----- Autorisation de la modification -----#
If dim([V]GMODENM)<1  Global Integer GMODENM : Endif
[V]GMODENM=1
#----- Pas d'accés aux mouvements si avoir validé ou si ligne réception soldée/facturée
#                                                 ou si présence d'une facture
If (LABR="SIH4" & [M:SIH1]INVSTA=3) |
&  (LABR="PTH1" & ([M:PTH1]LININVFLG(LLIGDOC)=2 | [M:PTH1]INVQTYSTU(LLIGDOC)>0 | [M:PTH1]FACFLG(LLIGDOC)))
  Diszo [M:ENM]1-99 : [V]GMODENM=0
# Issue 121901 - 2017-03-31 by MUARN : pas de modification si facture complémentaire sur la réception
Elsif LABR ="PTH1"
  If [M:PTH1]WINVFLG > 1
    #----- "Ligne réception facturée.\Modification ou suppression impossible" -----#
    # recherche élément facturation réparti
    For I=0 To [M:PTH2]NBFAC-1
      Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
      If 1< [F:PFI]DSPLIN < 7
        Diszo [M:ENM]1-99
      Endif
    Next
  Else
    Look [PID] PID1(2)=2;[M:PTH0]PTHNUM
    [G:PID]currind=1 : [G:PID]currlen=0 : # Réinitialisation clé par défaut
#    If !fstat
#      Diszo [M:ENM]1-99
#    Endif
    If !fstat
      # recherche élément facturation réparti
      For I=0 To [M:PTH2]NBFAC-1
        Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
        If 1< [F:PFI]DSPLIN < 7
          Diszo [M:ENM]1-99
          Break
        Endif
      Next
    Endif
  Endif
Endif
#-----
If dim([M:ENM]WRH)>0
   If [F:FCY]WRHGES=2
      #--- Bug 60935
      #If [M:ENM]XWRH=""
      #   Actzo [M:ENM]WRH
      #Else
      #   If [M:ENM]WRHOBY=2
      #      Diszo [M:ENM]WRH
      #   Else
      #      Actzo [M:ENM]WRH
      #   Endif
      #Endif
   Else
      Grizo [M:ENM]WRH
   Endif
Endif

If !FIN
    Affzo [M:ENM]
Endif

Return

$SETBOUT
Return

#########################################################################
$APRES_MODIF
#----- Si modification non autorisée, pas de bouton enregistrer ou abandon -----#
If ![V]GMODENM  Return : Endif
REP="M" : GREP="M"

Call ENM_APRES_NBLIG(val(PARAM(4))) From TWMLIB   # Three way matching

Return

#########################################################################
$ENR
Local Decimal  LQTYSTU, LQTYSTUACT
Local Char     LPCU(GLONUOM), WQLYCTLDEM(GLONVCR)
Local Decimal  LCOEF
Local Integer  I, WCQ, WOK, LRET
Local Decimal WDISA, WDISQ, WDISR : Raz WDISA, WDISQ, WDISR
Local Decimal WGLOALL : Raz WGLOALL

Local Decimal  LQTYPCU    # hcb 150405 28512

Raz GOK
For I=0 To [M:ENM]NBLIG-1
  If [M:ENM]WFLG(I)=1
    Call APRESNBLIGM(I, LRET) From TRTSTOENTB
  Endif
Next
I=find(1,[M:ENM]WFLG)
If I
    Call ERREUR(mess(93,100,1)-num$(I)) From GESECRAN
    mkstat = 2
    GERR = 1    : # Issue X3-53322 (pour ne pas afficher 'Fiche modifiée')
    Return
Endif

#----- On recharge les info articles par sécurité -----#
Call LECITM([M:ENM]STOFCY,[M:ENM]ITMREF,[M:ENM]BPRNUM,0,"",LRET) From STKLIB
#----- Contrôle avec prise en compte alloué global -----#
Call STODISMOD("",1+4*find(4,[M:ENM]LOCCATO),7,"",WDISA,WDISQ,WDISR,WGLOALL) From STKLIB
WDISA += sigma(0,[M:ENM]NBLIG-1, [M:ENM]QTYSTU(indcum)*(left$([M:ENM]STA(indcum),1)="A")-[M:ENM]QTYSTUO(indcum)*(left$([M:ENM]STAO(indcum),1)="A"))
WDISQ += sigma(0,[M:ENM]NBLIG-1, [M:ENM]QTYSTU(indcum)*(left$([M:ENM]STA(indcum),1)="Q")-[M:ENM]QTYSTUO(indcum)*(left$([M:ENM]STAO(indcum),1)="Q"))
WDISR += sigma(0,[M:ENM]NBLIG-1, [M:ENM]QTYSTU(indcum)*(left$([M:ENM]STA(indcum),1)="R")-[M:ENM]QTYSTUO(indcum)*(left$([M:ENM]STAO(indcum),1)="R"))

If WDISA*([F:ITG]GLOAAAFLG=2)+WDISQ*([F:ITG]GLOQQQFLG=2)+WDISR*([F:ITG]GLORRRFLG=2)<WGLOALL
    Call ERREUR(mess(818,196,1)) From GESECRAN
    mkstat = 2
    GERR = 1    : # Issue X3-53322 (pour ne pas afficher 'Fiche modifiée')
    Return
Endif
#----- Y a-t-il un CQ pour ce numéro de pièce
For [STJ]STJ1 Where STOFCY=[M:ENM]STOFCY & VCRTYP=[M:ENM]VCRTYP
&                 & VCRNUM=[M:ENM]VCRNUM & VCRLIN=[M:ENM]VCRLIN
&                 & TRSTYP<>29                         : #--- Issue 115206
    If [F:STJ]QLYCTLDEM<>""
      WQLYCTLDEM=[F:STJ]QLYCTLDEM
      Break
    Endif
Next
If WQLYCTLDEM<>""
  #-- Y a t il eu réponse fiche technique ?
  If clalev([F:QLA])=0 : Local File QLYCRDASW  [QLA] : Endif
  For [QLA]QLA0 Where QLYCTLDEM=[F:STJ]QLYCTLDEM
     WCQ+=1 : Break
  Next
  If WCQ<>0
    GMESSAGE=mess(317,184,1)
    WOK=2 : Call AVERTIR(GMESSAGE,WOK)  From GESECRAN
    Raz GMESSAGE
    If WOK=1
       GERR = 1    : # Issue X3-53322 (pour ne pas afficher 'Fiche modifiée')
       mkstat=2 : Return
    Endif
  Endif
Endif

#--- Issue X3-53322
# Contrôle des no LPN saisis
If [F:ITF]LPNMGTCOD=[V]CST_AYES
  LRET=1
  Call CONTROL_LPN(LRET)
  If LRET=0
    GERR=1 : mkstat=2 : Return
  Endif
Endif
#---

Call ENRENT("ENM") From TRTSTOENTB
If mkstat
    GERR=1 : Raz GMESSAGE   : # Issue X3-53322 (pour ne pas afficher 'Fiche modifiée')
    Return
Endif

If [M:ENM]NBLIG>0
    LQTYSTUACT = sigma (I=0,[M:ENM]NBLIG-1,[M:ENM]QTYSTU(I)*(([M:ENM]NUMLIGLOT(I)<0)+sigma(abs([M:ENM]NUMLIGLOT(I)),[M:ENM]NUMLIGLOT(I),[M:ENM]POT(indcum)/100)))
    LQTYSTU = sigma (I=0,[M:ENM]NBLIG-1,[M:ENM]QTYSTU(I))
    LPCU    = string$( !!( sigma(I=0,[M:ENM]NBLIG-1,([M:ENM]PCU(0)=[M:ENM]PCU(I))) = [M:ENM]NBLIG), [M:ENM]PCU(0))
    LCOEF   = (!!( sigma(I=0,[M:ENM]NBLIG-1,([M:ENM]PCUSTUCOE(0)=[M:ENM]PCUSTUCOE(I))) = [M:ENM]NBLIG))* [M:ENM]PCUSTUCOE(0)
Else
    LQTYSTU = 0
    LPCU    = ""
    LCOEF   = 0
Endif

If LPCU <> "" & LCOEF <> 0                                    # hcb 150405 28512
    LQTYPCU    = sigma (I=0,[M:ENM]NBLIG-1,[M:ENM]QTYPCU(I))  # hcb 150405 28512
Endif                                                         # hcb 150405 28512


# Donne la main au document origine pour effectuer ses propres contrôles
Gosub CTL_LIGNE_DOCUMENT From TRTSTOENTB
If mkstat
    GERR=1 : Raz GMESSAGE   : # Issue X3-53322 (pour ne pas afficher 'Fiche modifiée')
    Return
Endif

# mise à jour document origine
Gosub MAJ_MODIFICATION_LIGNE From TRTSTOENMA

Return

#--- Issue X3-53322
# Contrôle des no LPN saisis
Subprog CONTROL_LPN(LRET)
Variable Integer LRET
Local    Integer I, J, K, L, IC

I=sigma(0,[M:ENM]NBLIG-1,1*[M:ENM]MVTSEQ(indcum)=0)
# Une nouvelle ligne
If I=1
  IC=sigma(0,[M:ENM]NBLIG-1,indcum*([M:ENM]MVTSEQ(indcum)=0))
  If IC>=0 &  [M:ENM]LPNNUM(IC)<>""
    Read [ITM]ITM0=[M:ENM]ITMREF
    Read [LPN]LPN0=[M:ENM]LPNNUM(IC)
    #--- Contrôle du mono-lot pour le LPN concerné
    If [F:LPN]MONLOTFLG=2 & [F:ITM]LOTMGTCOD>1
      Filter [STO] Where LPNNUM=[M:ENM]LPNNUM(IC) & (ITMREF<>[M:ENM]ITMREF | LOT<>[M:ENM]LOTAFF(IC))
      Look [STO]STO3 First
      If !fstat : LRET=0 : Endif
      Filter [STO]
      If LRET=0
        GMESSAGE = func AFNC.MES2(mess(516,184,1),[M:ENM]LPNNUM(IC),"")
        #Call ERREUR(func AFNC.MES2(mess(516,184,1),[M:ENM]LPNNUM(IC),"")) From GESECRAN
        End
      Endif
    #--- Contrôle du mono-article pour le LPN concerné
    Elsif [F:LPN]MONITMFLG=2
      Filter [STO] Where LPNNUM=[M:ENM]LPNNUM(IC) & ITMREF<>[M:ENM]ITMREF
      Look [STO]STO3 First
      If !fstat : LRET=0 : Endif
      Filter [STO]
      If LRET=0
        GMESSAGE = func AFNC.MES2(mess(517,184,1),[M:ENM]LPNNUM(IC),"")
        #Call ERREUR(func AFNC.MES2(mess(517,184,1),[M:ENM]LPNNUM(IC),"")) From GESECRAN
        End
      Endif
    Endif
  Endif
# Plusieurs nouvelles lignes
Elsif I>1
  For I=0 To [M:ENM]NBLIG-2
    If [M:ENM]LPNNUM(I)<>"" & [M:ENM]MVTSEQ(I)=0
      If [F:ITM]ITMREF<>[M:ENM]ITMREF
        Read [ITM]ITM0=[M:ENM]ITMREF
      Endif
      If [F:LPN]LPNNUM<>[M:ENM]LPNNUM(I)
        Read [LPN]LPN0=[M:ENM]LPNNUM(I)
      Endif
      J=0
      #--- Contrôle du mono-lot pour le LPN concerné
      If [F:LPN]MONLOTFLG=2 & [F:ITM]LOTMGTCOD>1
        J=sigma(I+1,[M:ENM]NBLIG-1,1*([M:ENM]LPNNUM(indcum)=[M:ENM]LPNNUM(I) & [M:ENM]MVTSEQ(indcum)=0
&            & [M:ENM]LOTAFF(indcum)<>[M:ENM]LOTAFF(I)))
        If J>=1
          LRET=0
        Else
          Filter [STO] Where LPNNUM=[M:ENM]LPNNUM(I) & (ITMREF<>[M:ENM]ITMREF | LOT<>[M:ENM]LOTAFF(I))
          Look [STO]STO3 First
          If !fstat : LRET=0 : Endif
          Filter [STO]
        Endif
        If LRET=0
          GMESSAGE = func AFNC.MES2(mess(516,184,1),[M:ENM]LPNNUM(I),"")
          #Call ERREUR(func AFNC.MES2(mess(516,184,1),[M:ENM]LPNNUM(I),"")) From GESECRAN
          Break
        Endif
      #--- Contrôle du mono-article pour le LPN concerné
      Elsif [F:LPN]MONITMFLG=2
        Filter [STO] Where LPNNUM=[M:ENM]LPNNUM(I) & ITMREF<>[M:ENM]ITMREF
        Look [STO]STO3 First
        If !fstat : LRET=0 : Endif
        Filter [STO]
        If LRET=0
          GMESSAGE = func AFNC.MES2(mess(517,184,1),[M:ENM]LPNNUM(I),"")
          #Call ERREUR(func AFNC.MES2(mess(517,184,1),[M:ENM]LPNNUM(I),"")) From GESECRAN
          Break
        Endif
      Endif
      #--- Contrôle du mono-emplacement par LPN
      K=sigma(I+1,[M:ENM]NBLIG-1,1*([M:ENM]LPNNUM(indcum)=[M:ENM]LPNNUM(I) & [M:ENM]MVTSEQ(indcum)=0))
      L=sigma(I+1,[M:ENM]NBLIG-1,1*([M:ENM]LPNNUM(indcum)=[M:ENM]LPNNUM(I) & [M:ENM]MVTSEQ(indcum)=0
&             & [M:ENM]LOC(indcum)=[M:ENM]LOC(I)))
      If K<>L
        GMESSAGE = func AFNC.MES2(mess(521,184,1),[M:ENM]LPNNUM(I),[M:ENM]LOC(I))
        #Call ERREUR(func AFNC.MES2(mess(521,184,1),[M:ENM]LPNNUM(I),[M:ENM]LOC(I))) From GESECRAN
        LRET=0 : Break
      Endif
    Endif
  Next I
Endif
End
#--- End issue X3-53322

$ABA

Local Integer LRET

Call STKDELRES( 0, [M:ENM]STOFCY, "", LRET) From STKLOC

Raz [M:ENM]
# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return

#########################################################################
$FINSAI

Return

#########################################################################
$FIN
GOUVENT = 0
# restitution ligne document  ou maintenant STJ ?
#????   Gosub LOAD_FROM_ENTW  From STKENT
FIN = 1
If LTOOLIG
    GCONSULT = LTOOLIG-1
Endif
Raz GREP
Return
##########################################################################
$EXEC
 Call ENM_APRES_NBLIG(val(PARAM(4))) From TWMLIB # Three way matching
Return
############################################################
# sous programmes des actions ecran
############################################################

$SET_NOL
Local Integer NOL : NOL = nolign-1
Return

############################################################
# Actions ecran
############################################################

########################################
Subprog C_NBLIG
Local Integer I, J, LRET
Local Decimal  WPCUDIS, WSTUDIS, WSTUACTDIS
Local Decimal WSTODISTOT
Local Integer WISTA, WILOC

# X3-80367 - STWIL - Before we delete or create the stock transaction line if it is a customer return, purchase receipt or
# production tracking check if this document is in any non-conformances
If find(status,73,65,68,83) & func AFNC.ACTIV ("NCS")
    Local Integer LDOCTYP
    Local Integer LOK
    Local Integer EXISTS
    Local Char NCSMESS(255)
    Case GFONCTION
        When "GESPTH" : LDOCTYP = 1
        When "GESSRH" : LDOCTYP = 2
        When "GESMTK" : LDOCTYP = 3
        When Default : LDOCTYP = 0
    Endcase
    If LDOCTYP > 0
        [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (LDOCTYP, [M:ENM]VCRNUM, [M:ENM]VCRLIN, [L]NCSMESS, 0)
        If [L]EXISTS > 0 & GNCSLINFLG = 0
            Call OUINON([L]NCSMESS,LOK) From GESECRAN
            GNCSLINFLG = 1
            If LOK = 1
                GMESSAGE = ""
                mkstat = 2
                End
            Endif
        Endif
    Endif
Endif

# annulation de ligne(s)
If find(status,65,68,83)

#                                                        # hcb 106905 deb
#Pas de traitement  Article bloqué pour inventaire
If [F:ITF]CUNFLG = 2
#CHECK IGNORE_BEGIN
   Raz GPE
   GPOINT = "CTRINVLIG"
   Gosub  ENTREE From EXEFNC
#CHECK IGNORE_END
   If GPE = 1
      GMESSAGE = mess(185,199,1)
      mkstat = 2
      End
   Else
      LRET  = 1
      Call AVERTIR(mess(185,199,1),LRET) From GESECRAN
      If LRET  = 1
         mkstat = 2
         End
      Endif
   Endif
Endif
#                                                        # hcb 106905 fin

    If status=65
        NOL1 = nolign-1
    Else
        NOL1 = nolign1-1
    Endif
    For I=nolign-1 To NOL1
        If [M:ENM]ORILIG (I) = 5
            Read [STJ]STJ0=[M:ENM]STOFCY;2;[M:ENM]ITMREF;[M:ENM]IPTDAT(I);[M:ENM]MVTSEQ(I);[M:ENM]MVTIND(I)
            If fstat
                GMESSAGE = mess(819,196,1)
                Raz [STJ]
                End
            Endif
            WISTA = (left$([M:ENM]STA(I),1)="A")+(left$([M:ENM]STA(I),1)="Q")*2+(left$([M:ENM]STA(I),1)="R")*4
            If [M:ENM]LOCCATO(I)=4
               WILOC = [M:ENM]LOCCATO(I)
            Else
               WILOC = [M:ENM]LOCCATO(I)-1
            Endif
            # Call STODISMOD("",WILOC,WISTA,"",WSTODISTOT) From STKLIB
            Read [STO]STO0=[M:ENM]STOFCY;[M:ENM]STOCOU(I)
            If fstat
               Raz [M:ENM]STUDIS(I),WSTUACTDIS
            Else
               Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,[M:ENM]STUDIS(I),WSTUACTDIS) From STKLIB
               # Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
               # [M:ENM]STUDIS(I) = min(WSTODISTOT,WSTUDIS)
            Endif
            Affzo [M:ENM]STUDIS(I)
            If [M:ENM]QTYSTUO(I) > [M:ENM]STUDIS(I)
                mkstat = 2
                GMESSAGE = mess(817,196,1)+"\"+mess(303,181,1)-":"-num$([F:STO]CUMALLQTA)-
&                          mess(304,181,1)-":"-num$([F:STO]CUMWIPQTA)
                End
            Endif
        Endif
        [M:ENM]QTYSTU (I) = 0
    Next
    For I=nolign-1 To NOL1
        If [M:ENM]LOCO(I)<>""
            If [M:ENM]WLOCSEQ(I)=0
                Call STKWLOCSEQ("ENM", I, LRET) From STKECR
            Endif
            Call STKMODREMP( [M:ENM]WLOCSEQ(I),
&                            [M:ENM]STOFCY,
&                            [M:ENM]ITMREF,
&                            [M:ENM]PCUO(I),
&                            [M:ENM]QTYPCUO(I),
&                            [M:ENM]STAO(I),
&                            [M:ENM]LOCO(I),
&                            [M:ENM]BPRNUM,
&                            mkstat,
&                            "") From STKLOC
            If mkstat<>0
                For J=nolign-1 To I-1
                    Call STKDELRES(-[M:ENM]WLOCSEQ(I),[M:ENM]STOFCY,"",LRET) From STKLOC
                Next
                mkstat = 2
                End
            Endif
        Endif
    Next
    Gosub GESSELECTION From TRTSTOENTB
    Affzo [M:ENM]PECQTY
Endif

End

########################################
Subprog AVANT_NBLIG

Gosub SET_NOL
# Issue 102226 - 2014-11-18 by SR
Local Integer WNEW



Gosub LECFIC_ALIG From TRTSTOENTB

If [M:ENM]WLOCSEQ(NOL)=0
    [M:ENM]WLOCSEQ(NOL) = 100000
Endif

If [M:ENM]WFLG(NOL)   > 1 | [M:ENM]PCU(NOL)<>""
   End
Endif

Raz [M:ENM]IPTDAT(NOL)
Raz [M:ENM]MVTSEQ(NOL)
Raz [M:ENM]MVTIND(NOL)
If GACTION="SAISTKSPL"
   If NOL = 0                                             # hcb 85013
        # Issue 102226 - 2014-11-18 by SR
        WNEW = 2
        Call COPYLINE(NOL, NOL) From TRTSTOENTB           # hcb 85013
   Else                                                   # hcb 85013
        # Issue 102226 - 2014-11-18 by SR
        WNEW = 1
        Call COPYLINE(NOL-1, NOL) From TRTSTOENTB
   Endif                                                  # hcb 85013
   # Issue 102226 - 2014-11-18 by SR
#   If mid$(GSAIFLG,8,1)="0"
   If mid$(GSAIFLG,8,1)="0" & WNEW = 2
        If [F:SRU]LOTSUPINH = 3
            [M:ENM]LOTAFF(NOL) = [M:ENM]VCRNUM
        Endif
    Endif
Else
    #type de tiers : 0=stock, 1=achat, 2=vente
    Call INIZONENT2("ENM",[M:ENM]ITMREF,[M:ENM]STOFCY,"",!([M:ENM]TYPBPR=3)*[M:ENM]TYPBPR,"",nolign-1,[M:ENM]TRSTYP,[M:ENM]TRSCOD,0,1) From TRTSTOENTB
    Call MAJPCU("ENM",[M:ENM]PCU(NOL), NOL) From TRTSTOENTB

    #----- Si lot = "", lot=n° piece  -----#
    If dim([M:ENM]LOTAFF(NOL))>0 & [M:ENM]LOTAFF(NOL) = ""
        If [F:SRU]LOTSUPINH = 3
            [M:ENM]LOTAFF(NOL) = [M:ENM]VCRNUM
        Endif
    Endif
    If dim([M]SLOAFF) > 0 & [M]SLOAFF(NOL)="" & [F:ITM]LOTMGTCOD = 4
        If !(dim(GSAIFLG)>0 & mid$(GSAIFLG,10,1)<>"0")
            Call RECLASTSLO([M]ITMREF, [M]LOTAFF(NOL), "ENM","", [M]SLOAFF(NOL)) From STKLIB
        Elsif NOL>0
            [M]SLOAFF(NOL)  = [M]SLOAFF(NOL-1)
        Elsif [M]SLOAFF(NOL+1)<>""
            [M]SLOAFF(NOL)  = [M]SLOAFF(NOL+1)
        Endif
    Endif
Endif

# si article suivi en série initialisation des rubriques
If [F:ITM]SERMGTCOD = 3
    [M:ENM]PCU       (NOL) = [M:ENM]STU
    [M:ENM]QTYPCU    (NOL) = 1
    [M:ENM]QTYSTU    (NOL) = 1
    [M:ENM]PCUSTUCOE (NOL) = 1
    #----- Initialisation des n° de série si pas de compteur ----#
    If dim([M:ENM]SERNUM)>0 & [M:ENM]SERNUM(NOL)="" & [F:ITM]SERCOU=""
        Call STKLASSER([M:ENM]SERNUM(NOL), [M:ENM]ITMREF) From STKACT
        [M:ENM]SERNUMF(NOL) = [M:ENM]SERNUM(NOL)
        Call STKCTRSER([M:ENM]SERNUM(NOL),[M]ITMREF,nolign-1,[M]NBLIG,nolign,[M:ENM]TRSTYP,[M:ENM]VCRTYP,[M:ENM]VCRNUM,
&                      [M:ENM]VCRLIN,[M:ENM]VCRTYPORI+(![M:ENM]VCRTYPORI)*4,
&                      [M:ENM]VCRNUMORI,[M:ENM]VCRLINORI,[M:ENM]VCRSEQORI,[F:ITM]SERCOU="" & [F:TLO]LOCCAT<>2,"") From STKACT
        If mkstat
            Raz mkstat
            Effzo [M:ENM]SERNUM(NOL)
        Else
            Affzo [M:ENM]SERNUM(NOL)
        Endif
    Endif
#--- Issue 110327 by TS
Elsif [F:ITM]SERMGTCOD=4
   # Voir s'il y a quelque chose à faire
#---
Endif

If NOL > 0
    [M:ENM]IPTDAT(NOL)   = [M:ENM]IPTDAT(0)
Else
    [M:ENM]IPTDAT(NOL)   = [M:ENM]IPTDAT1
Endif

End

########################################
Subprog APRES_NBLIG
Local Integer     LRET

Call APRESNBLIGM (nolign-1, LRET) From TRTSTOENTB
End


########################################
Subprog IB_NBLIG
Gosub SET_NOL

# Si modif non autorisée pas de bouton (avoir validé ou ligne réception soldée/facturée)
If ![V]GMODENM
   Raz GBOUT1, GBOUT2, GBOUT3
   End
Endif

# Gconsult est positionnée quand on arrive par tunnel sur le document d'entrée
If [F:ITM]LOTMGTCOD=1 | GCONSULT
    GBOUT1 = ""
    GBOUT2 = ""
Else
    If [M:ENM]GESLOTAFF(NOL)=""
        GBOUT1 = ""
    Endif
    If GOUVLOT>0
        GOUVENT = 1 # permet de passer le test de l'ouverture de la fenetre complément lot
    Else
        GBOUT2=""
    Endif
Endif

If [M:ENM]VCRNUMORI<>"" & (dim([M:ENM]SERNUM)>0 & [M:ENM]SERNUM(NOL)<>"") | GCONSULT
    GBOUT3 = ""
Endif

#--- Issue 110327
#--- Pas de split si no série en E/S globale
If [F:ITM]SERMGTCOD=4 Raz GBOUT3 Endif
#---

If GBOUT2<>""
    GOUVLOT = GOUVLOT-mod(GOUVLOT,2)    # Ouverture par clic du complément lot
    GOUVENT = 1    #
Endif

End

########################################
Subprog B1_NBLIG
    Call INFOLOT("ENM",nolign-1) From STKENT
End

########################################
Subprog C_PCU(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M:ENM]PCU(nolign-1)
   Gosub CTL_ALL
Endif
End

########################################
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()

Call MAJPCU("ENM",VALEUR, nolign-1) From TRTSTOENTB

End

########################################
Subprog IB_PCU
Gosub SET_NOL

If [M:ENM]WFLG(NOL) > 1
   GBOUT2 = ""
Else
   # Selection stocks
   GBOUT2 = mess(145,198,1)
Endif
End

########################################
Subprog AS_QTYPCU(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL

# si unite saisie = unite de la ligne de document qte =  ligne de document
If NOL = 0
   If  VALEUR = 0               &
&     [M:ENM]PCU(NOL) = [M:ENM]PCUTOENT
      VALEUR          = [M:ENM]QTYTOENT
   Endif
Endif


If VALEUR = 0
   If [M:ENM]PECQTY < [M:ENM]QTYTOENT
      If [M:ENM]PCU(NOL) = [M:ENM]STU
         VALEUR =  ([M:ENM]QTYTOENT-[M:ENM]PECQTY)*[M:ENM]COETOENT
         Call QTEARR(VALEUR,[M:ENM]STU) From TRTDIV
      Else
         VALEUR =  ([M:ENM]QTYTOENT-[M:ENM]PECQTY)*[M:ENM]COETOENT/[M:ENM]PCUSTUCOE(NOL)
         Call QTEARR(VALEUR,[M:ENM]PCU(NOL)) From TRTDIV
      Endif
   Endif
Else
    Call QTEARR(VALEUR,[M:ENM]PCU(NOL)) From TRTDIV
Endif
#--- Alimentation de la quantité en US : QTYstu
[M:ENM]QTYSTU(NOL) = (VALEUR * [M:ENM]PCUSTUCOE(NOL))
Call QTEARR([M:ENM]QTYSTU(NOL),[M:ENM]STU) From TRTDIV

End

########################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR

Local Integer I
Gosub SET_NOL
Call QTEARR(VALEUR,[M:ENM]PCU(NOL)) From TRTDIV
#--- Bug 63848
#If VALEUR = 0
If VALEUR <= 0
  mkstat = 2
Endif
#---
End

########################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
Local Decimal  WPCUDIS, WSTUDIS, WSTUACTDIS
Local Decimal WSTODISTOT
Local Integer WISTA, WILOC
#--- Issue 110327
Local Integer OK  : OK=1
Local Integer LRET, PRET
Local Integer NBSER
Local Char    WSER(GLONSER)
Local Char    SERDEB(GLONSER)
Local Char    SERFIN(GLONSER)
Local Char    VALEURFIN(GLONSER)
Local Decimal WPCUDIS, WSTUACTDIS
#---

#--- Contrôle si la quantité UC génère une qté US arrondie
Local Integer LRET
If [M:ENM]PCU(NOL)<>[M:ENM]STU
   Call STKCTRCOE(VALEUR,[M:ENM]PCUSTUCOE(NOL),[M:ENM]STU,LRET) From STKACT
   If LRET=0 : mkstat=2 : End : Endif
Endif

# test pour ne pas avoir une qte inferieure à qte initiale - disponible
#--- Issue 98049
#If [M:ENM]ORILIG(NOL) = 5
If [M:ENM]ORILIG(NOL)=5 & VALEUR<[M:ENM]QTYPCU(NOL)
#---
    WISTA = (left$([M:ENM]STA(NOL),1)="A")+(left$([M:ENM]STA(NOL),1)="Q")*2+(left$([M:ENM]STA(NOL),1)="R")*4
    If [M:ENM]LOCCATO(NOL)=4
       WILOC = [M:ENM]LOCCATO(NOL)
    Else
       WILOC = [M:ENM]LOCCATO(NOL)-1
    Endif
    # Le disponible ne doit tenir compte dans un premier temps que de la ligne de stock
    # Le disponible global ne doit être pris en compte qu'au moment de l'enregistrement
    # Call STODISMOD("",WILOC,WISTA,"",WSTODISTOT) From STKLIB
    Read [STO]STO0=[M:ENM]STOFCY;[M:ENM]STOCOU(NOL)
    If fstat
       Raz [M:ENM]STUDIS(NOL),WSTUACTDIS
       #--- Bug 89742
       mkstat = 2
       GMESSAGE = mess(818,196,1)
       End
       #---
    Else
       Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,[M:ENM]STUDIS(NOL),WSTUACTDIS) From STKLIB
       # Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
       # [M:ENM]STUDIS(NOL) = min(WSTODISTOT,WSTUDIS)
    Endif
    Affzo [M:ENM]STUDIS(NOL)
    If (VALEUR * [M:ENM]PCUSTUCOE(NOL))  < ([M:ENM]QTYSTUO(NOL) - [M:ENM]STUDIS(NOL) )
      mkstat = 2
      GMESSAGE = mess(818,196,1)
      End
    Endif
Endif

#--- Issue 110327
If [F:ITM]SERMGTCOD=4 & [M:ENM]SERNUM(NOL)<>""
  # Détermination du nombre et des no séries début et fin à contrôler
  Call PLUS_NB([M:ENM]SERNUM(NOL),VALEUR,VALEURFIN,LRET) From STKLIB
  #--- Issue X3-66323
  If VALEURFIN=""
    mkstat = 2
    GMESSAGE = mess(476,197,1)
    End
  Endif
  #---
  If [M:ENM]SERNUMO(NOL)<>""
    SERDEB=min([M:ENM]SERNUM(NOL),[M:ENM]SERNUMO(NOL))
    SERFIN=max(VALEURFIN,[M:ENM]SERNUMFO(NOL))
  Else
    SERDEB=[M:ENM]SERNUM(NOL)
    SERFIN=VALEURFIN
  Endif
  Call NB_SERIE(SERDEB,SERFIN,NBSER,LRET) From STKLIB
  # Boucle de contrôle des no séries
  WSER=SERDEB
  While NBSER>0 & OK=1
    # Le no série est à contrôler
    If (WSER>=[M:ENM]SERNUM(NOL) & WSER<=VALEURFIN) | (WSER>=[M:ENM]SERNUMO(NOL) & WSER<=[M:ENM]SERNUMFO(NOL))
      # Lecture no série
      Call LECSER ([M:ENM]ITMREF,WSER,"",LRET) From STKLIB

      # Il s'agit d'une nouvelle ligne ou le no série sera entré par le document
      If [M:ENM]SERNUMO(NOL)="" | [M:ENM]SERNUMFO(NOL)="" | WSER<[M:ENM]SERNUMO(NOL) | WSER>[M:ENM]SERNUMFO(NOL)
        Gosub CONTROL_SERIE
      # Le no série était entré par le document et ne le sera plus,
      # ou était entrée par le document et le sera toujours
      # --> Il doit exister et ne pas être sorti ou alloué ou en cours de traitement
      Else
        If LRET=0
          OK=0
        Elsif [F:STS]ISSDAT<>[0/0/0] | [F:STS]SDHNUM<>"" | func STKLIB.REC_STOSERW_UID([M:ENM]ITMREF,WSER,adxuid(1))<>0
          OK=0
        Endif
      Endif
      NBSER-=1
      If NBSER>0 & OK=1
        Call PLUS_UN(WSER,WSER,LRET) From STKLIB
        If LRET<>0
          OK=0 : PRET=7
        Endif
      Endif
    Endif
  Wend
  If OK=0
    Gosub ERROR_SERIE
    mkstat=2 : GERR=1
    End
  Else
    [M:ENM]SERNUMF(NOL)=VALEURFIN
  Endif

Endif
#--- End issue 110327

# X3-80367 - STWIL - Before we delete the stock transaction if it is a customer return, purchase receipt or production tracking
# check if this document is in any non-conformances
If func AFNC.ACTIV ("NCS")
    Local Integer LDOCTYP
    Local Integer EXISTS
    Local Char NCSMESS(255)
    Case GFONCTION
        When "GESPTH" : LDOCTYP = 1
        When "GESSRH" : LDOCTYP = 2
        When "GESMTK" : LDOCTYP = 3
        When Default : LDOCTYP = 0
    Endcase
    If LDOCTYP > 0
        [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (LDOCTYP, [M:ENM]VCRNUM, [M:ENM]VCRLIN, [L]NCSMESS, 0)
        If [L]EXISTS > 0 & GNCSLINFLG = 0
            Call OUINON([L]NCSMESS,OK) From GESECRAN
            GNCSLINFLG = 1
            If OK = 1
                GMESSAGE = ""
                GERR = 1
                mkstat = 2
                End
            Endif
        Endif
    Endif
Endif

#--- Alimentation de la quantité en US : ENTstu
[M:ENM]QTYSTU(NOL) = (VALEUR * [M:ENM]PCUSTUCOE(NOL))
Call QTEARR([M:ENM]QTYSTU(NOL),[M:ENM]STU) From TRTDIV

Affzo [M:ENM]QTYSTU(NOL)

#--- Alimentation du statut
If  [M:ENM]STA(NOL) = ""
    Call STKINISTA([M:ENM]STA(NOL),[M:ENM]BPRNUM,1) From STKACT
Endif

End

########################################
Subprog IB_QTYPCU
Gosub SET_NOL
# id ligne precedente
GBOUT2 = mess(33,198,1)
# solde
GBOUT4 = mess(101,106,1)
# qte initiale
GBOUT5 = mess(100,106,1)

If NOL = 0                        GBOUT2 = "" : Endif
If [M:ENM]QTYSTU(NOL) = 0         GBOUT3 = "" : Endif
If [M:ENM]ORILIG(NOL) <> 5        GBOUT5 = "" : Endif
End
########################################

Subprog B2_QTYPCU(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
If NOL = 0
  VALEUR = [M:ENM]QTYTOENT
Else
  If NOL > 0
    VALEUR = [M:ENM]QTYPCU(NOL-1)
  Endif
Endif

End

########################################
Subprog B4_QTYPCU(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
    Local Decimal LDIF
    LDIF = [M:ENM]QTYTOENT*[M:ENM]COETOENT - sigma(0,[M:ENM]NBLIG-1,[M:ENM]QTYSTU(indcum)*(indcum<>NOL))
    If LDIF>0
        Call QTEARR(LDIF,[M:ENM]STU) From TRTDIV
    Else
        LDIF = 0
    Endif
    VALEUR  = LDIF / [M:ENM]PCUSTUCOE(NOL)
End

########################################
Subprog B5_QTYPCU(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
VALEUR =  [M:ENM]QTYPCUO(NOL)

End

########################################
Subprog C_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
If VALEUR<>[M:ENM]PCUSTUCOE(nolign-1)
   Gosub CTL_ALL
Endif
End

########################################
Subprog AM_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
Local Decimal  WPCUDIS, WSTUDIS, WSTUACTDIS
Local Decimal WSTODISTOT
Local Integer WISTA, WILOC

#--- Contrôle si le coef UC/US génère une qté US arrondie
Local Integer LRET
If [M:ENM]PCU(NOL)<>[M:ENM]STU
   Call STKCTRCOE([M:ENM]QTYPCU(NOL),VALEUR,[M:ENM]STU,LRET) From STKACT
   If LRET=0 : mkstat=2 : End : Endif
Endif

# test pour ne pas avoir une qte inferieure à qte initiale - disponible
#--- Issue 98049
Local Decimal WQTYSTU
WQTYSTU = (VALEUR*[M:ENM]QTYPCU(NOL))
If [M:ENM]ORILIG(NOL)=5 & WQTYSTU<[M:ENM]QTYSTU(NOL)
#If [M:ENM]ORILIG(NOL) = 5
#---
   WISTA = (left$([M:ENM]STA(NOL),1)="A")+(left$([M:ENM]STA(NOL),1)="Q")*2+(left$([M:ENM]STA(NOL),1)="R")*4
   If [M:ENM]LOCCATO(NOL)=4
      WILOC = [M:ENM]LOCCATO(NOL)
   Else
      WILOC = [M:ENM]LOCCATO(NOL)-1
   Endif
   # Call STODISMOD("",WILOC,WISTA,"",WSTODISTOT) From STKLIB
   Read [STO]STO0=[M:ENM]STOFCY;[M:ENM]STOCOU(NOL)
   If fstat
      Raz [M:ENM]STUDIS(NOL),WSTUACTDIS
      #--- Bug 89742
      mkstat = 2
      GMESSAGE = mess(818,196,1)
      End
      #---
   Else
      Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,[M:ENM]STUDIS(NOL),WSTUACTDIS) From STKLIB
      # Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
      # [M:ENM]STUDIS(NOL) = min(WSTODISTOT,WSTUDIS)
   Endif
   Affzo [M:ENM]STUDIS(NOL)
   If (VALEUR * [M:ENM]QTYPCU(NOL))  < ([M:ENM]QTYSTUO(NOL) - [M:ENM]STUDIS(NOL))
      mkstat = 2
      GMESSAGE = mess(818,196,1)
      End
   Endif
Endif

#--- Alimentation de la quantité en US : QTYstu
[M:ENM]QTYSTU(NOL) = (VALEUR * [M:ENM]QTYPCU(NOL))
Call QTEARR([M:ENM]QTYSTU(NOL),[M:ENM]STU) From TRTDIV

End

########################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M:ENM]STA(nolign-1)
   Gosub CTL_ALL
Endif
End

#--- Bug 60553
########################################
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:ENM]WRH(nolign-1)<>""
   Raz [M:ENM]LOC(nolign-1)
Endif
#--- Bug 63949
# Contrôle existence article-dépôt
If [M]STOFCY<>[F:FCY]FCY
  Read [FCY]FCY0=[M]STOFCY
Endif
If [F:FCY]WRHGES=2
  Read [ITW]ITW0=[M]ITMREF;VALEUR
  If fstat
     GMESSAGE=[M]ITMREF-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
#---
End

########################################
Subprog C_LOCTYP(VALEUR)
Variable Char    VALEUR()
# Quand on passe ici, le premier contrôle était OK, on regarde donc juste si le type est un type quai
Read [TLO]TLO0=[M:ENM]STOFCY;VALEUR
If !fstat & [F:TLO]LOCCAT = 2 & [M:ENM]SRGWAIFLG <> 2
    GMESSAGE = mess(854,196,1)
    mkstat = 2
    End
Endif
#--- Bug 72649
If [M:ENM]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:ENM]LOC(nolign-1),[M:ENM]WLOCSEQ(nolign-1)) From STKACT
Endif
#---
#                                                                            # hcb 110327 deb
If dim([M:ENM]SERNUM) > 0 & [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2 & [M:ENM]VCRTYP <> 27
   Raz   [M:ENM]SERNUM (nolign-1)
   Raz   [M:ENM]SERNUMF(nolign-1)
   Affzo [M:ENM]SERNUM (nolign-1)
   Affzo [M:ENM]SERNUMF(nolign-1)
Endif
#                                                                            # hcb 110327 fin
End

########################################
Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
If VALEUR <> ""
    Read [TLO]TLO0=[M:ENM]STOFCY;[F:STC]LOCTYP
    # test si type quai autorisé
    If !fstat & [F:TLO]LOCCAT = 2 & [M:ENM]SRGWAIFLG <> 2
        GMESSAGE = mess(854,196,1)
        mkstat = 2
        End
    Endif
Endif

If VALEUR<>[M:ENM]LOC(nolign-1)
   Gosub CTL_ALL
Endif

Affzo [M:ENM]LOCTYP(NOL)
#--- Bug 60935
If dim([M:ENM]WRH)>0
   [M:ENM]WRH(nolign-1)=[F:STC]WRH
   Affzo [M:ENM]WRH(nolign-1)
Endif

End

##########################################################################
Subprog AM_BPSLOTAFF(VALEUR)
Variable Char    VALEUR()
If find([M:ENM]VCRTYP,13,18)
    If dim([M:ENM]SLO)>0
        Call STKCTRLOF(VALEUR, [M:ENM]ITMREF, [M:ENM]LOTAFF(nolign-1), [M:ENM]SLOAFF(nolign-1), 1, [M:ENM]GESLOTAFF(nolign-1) ) From STKACT
    Else
        Call STKCTRLOF(VALEUR, [M:ENM]ITMREF, [M:ENM]LOTAFF(nolign-1), "", 1, [M:ENM]GESLOTAFF(nolign-1) ) From STKACT
    Endif
Else
    Call STKAMLOF(VALEUR,"ENM",nolign-1,[M:ENM]ITMREF,[M:ENM]STOFCY,[M:ENM]BPSLOTAFF(nolign-1),"LOTAFF","SLOAFF",
&                 "LOCTYP",[M:ENM]GESLOTAFF(nolign-1)) From STKACT
Endif

End

########################################
Subprog IB_LOTAFF
Gosub SET_NOL

# Compteur lot
If [F:ITM]LOTCOU = ""             GBOUT2 = "" : Endif

# Lot blanc
If [M:ENM]GESLOT(NOL) = "B" | [F:ITM]LOTMGTCOD <> 2 : GBOUT3 = "" : Endif

# Info lot
If [F:ITM]LOTMGTCOD = 1           GBOUT4 = "" : Endif
If [M:ENM]LOTAFF(NOL) <> ""       GBOUT4 = "" : Endif

# id ligne precedente
If NOL = 0                        GBOUT7 = "" : Endif

End

