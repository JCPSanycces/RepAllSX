   Gosub CTL_ALL
Endif

If VALEUR <> "" & VALEUR <> [M:ENM]SLOO(NOL) & [M:ENM]LOTAFF(NOL) <> [M:ENM]LOTO(NOL)
    Call STKCTRSLO(VALEUR, 1, [M:ENM]LOTAFF(NOL),
&                  [M:ENM]ITMREF, [M:ENM]BPSLOTAFF(NOL), [M:ENM]GESLOTAFF(NOL),[M:ENM]VCRNUMORI, [M:ENM]VCRTYPORI, [M:ENM]VCRLINORI, [M:ENM]VCRSEQORI,
&                  [M:ENM]STOFCY, WSLOF) From STKACT
Endif

End

