#<AdxTL>@(#)6.0.0.0 $Revision$
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
#---------------------------------------------------------------------------#
# Actions Sous-traitance pour les outils d'approvisionnement/planification: #
# - SAICREEOX    Création nouvel ordre EOP/EOF                              #
# - SAIMODEOX    Modification ordre EOP/EOF et création par PEC             #
#---------------------------------------------------------------------------#
# GA pour mémo :
# - suppression de MTS, TRS (transaction OF),TRO,ROH (ctrl gamme/alt)
# - MFGK => SCOK
# - MBW1 (action SAIMODEOX, fenetre DMODEOX)          => SMW1 (modif EOX)
# - MBW2 (actions FDISPNEO(N), fenetres IDISPNEO(N) ) => SMW2 (dispo matières EO)
# - MBW3 (action SAICREEOX, fenetre DCREEOX)          => SMW3 (creation EOX)
# - MBW4 (pour fenetre DPECEOX)                       => SMW4 (pec EOX)
# - MBW5 (action FDISPPEO, fenetre IDISPPEO)          => SMW5 (dispo matières pln)
#   (code WO remplacé par EO dans les noms des actions/fenetres, sauf FDISPPEO=>FDISPPEO)
#
# - CONTMFGNOM => CONTSCONOM from SCOLIB
# - CONTMFGITM => CONTSCOITM from SCOLIB
#
# Différences avec les ordres relatifs aux OF dans BENCHLIB
#  VCRTYP = 10           devient    VCRTYP = 36
#  WIPTYP = 6 pour MW    devient    WIPTYP = 3  pour MS
#  WIPTYP = 5 pour WO    devient    WIPTYP = 13 pour EO
#  suppression des appels à COVER From TRTWIP
#---------------------------------------------------------------------------#
# !!! Le masque [M:SCOK] est ouvert dans FUNMPICK, FUNGBENCH, FUNDBENCH
#---------------------------------------------------------------------------#
# NB: [F:BTS] correspond au paramétrage des transactions "plan de travail"
#     WSCOHAB - correspond au code [M:MGB]SCOHAB ou [M:MGD]SCOHAB
#             - FLGSCO paramètre des actions SAICREEOX et SAIMODEOX
#             - combinaison calculée selon autorisations [F:BTS]SCOSUG,SCOPLN,SCOLAN
#---------------------------------------------------------------------------#

############################################################################
# 02/2007 dans SCOSRV CPNITMREF devient SRVITMREF                          #
############################################################################

$ACTION
Case ACTION
    When "OUVRE":        Gosub INIT : # Issue X3-4769 - 2017-06-14 by ALSHE : check reply from WIP exists message, close if NO
                         Case GACTION
                              When "SAICREEOX" : Gosub OUVRE_CREEOX
                              When "SAIMODEOX" : Gosub OUVRE_MODEOX
                              When "FDISPNEO"  : Gosub OUVRE_FDISPNEO
                              When "FDISPNEON" : Gosub OUVRE_FDISPNEON
                              When "FDISPPEO"  : Gosub OUVRE_FDISPPEO
                          Endcase
    When "TITRE":         If find(GACTION,"SAICREEOX","SAIMODEOX") : TIT = XTITLE : Endif
    When "DEBUT":         Case GACTION
                              When "SAICREEOX" : Gosub DEBUT_CREEOX
                              When "SAIMODEOX" : Gosub DEBUT_MODEOX
                              When "FDISPNEO"  : Gosub DEBUT_FDISPNEO
                              When "FDISPNEON" : Gosub DEBUT_FDISPNEON
                              When "FDISPPEO"  : Gosub DEBUT_FDISPPEO
                          Endcase
    When "SETBOUT":       Case GACTION
                              When "SAICREEOX" : Gosub SETBOUT_CREEOX
                              When "SAIMODEOX" : Gosub SETBOUT_MODEOX
                          Endcase
    When "AVANT_BOUTON":  Case GACTION
                              When "SAICREWOX" : Gosub AVANT_BOUTON_CREEOX
                          Endcase
    When "BOUTON":        Case GACTION
                              When "SAICREEOX" : Gosub BOUTON_CREEOX
                              When "SAIMODEOX" : Gosub BOUTON_MODEOX
                          Endcase
    When "ENR":           Case GACTION
                              When "SAIMODEOX":  Gosub ENR_MODEOX
                          Endcase
    When "SUP":           Case GACTION
                              When "SAIMODEOX":  Gosub SUP_MODEOX :
                          Endcase
    When "FIN":           Case GACTION
                              When "SAIMODEOX":    If val(PARAM(7)) = 2
                                                       Case GFONCTION
                                                           When "FUNGBENCH","FUNGBENCHA" :
                                                                If clalev ([M:MGD])=0
                                                                  [M:MGB]REACT = 2
                                                                  GLRET = 2
                                                                  Gosub SOUSTRAIT From FUNGBENCH
                                                                Else
                                                                  [M:MGD]REACT = 2
                                                                  GDLRET = 2
                                                                  Gosub SOUSTRAIT From FUNDBENCH
                                                                Endif
                                                           When "FUNDBENCH","FUNDBENCHA" :
                                                                If clalev ([M:MGB])=0
                                                                   [M:MGD]REACT = 2
                                                                   GDLRET = 2
                                                                   Gosub SOUSTRAIT From FUNDBENCH
                                                                Else
                                                                   [M:MGB]REACT = 2
                                                                   GLRET = 2
                                                                   Gosub SOUSTRAIT From FUNGBENCH
                                                                Endif
                                                           When "FUNMLINK","FUNMLINKA" :
                                                                [M:MLB]REACT = 2
                                                                Gosub SOUSTRAIT From FUNMLINK
                                                       Endcase
                                                   Endif
                          Endcase
    When Default
Endcase
Return

#---------------------------------------------------------------------------#
# Action INIT                                                               #
# Issue X3-4769 - 2017-06-14 by ALSHE : display message if WIP exists       #
#---------------------------------------------------------------------------#
$INIT
  If dim(GVALIDWIP) >= 0 and GVALIDWIP = [V]CST_ANO Then
    FIN = 1
    Return
  Endif
Return

#---------------------------------------------------------------------------#
# Action SAICREEOX                                                          #
#---------------------------------------------------------------------------#
###########################################################################
# ouverture
$OUVRE_CREEOX
Local    Char       WFCY(GLONFCY)
Local    Char       WITM(GLONITM)
Local    Char       WPLANNER(20)
Local    Char       WPJT(GLONPJT)
Local    Decimal    WQTYBES
Local    Char       WDATC(10)
Local    Date       WDATBES
Local    Integer    WFLGPEC
Local    Integer    WSCOHAB

Local    Char       XTITLE(250)
Local    Date       WORIDAT
Local    Char       WORIFCY(GLONFCY)
Local    Char       WART(GLONITM)
Local    Date       WMEMDAT
Local    Integer    WMAX
Local    Decimal    WRMD
Local    Decimal    WQTY, WAVAOFS, WQUALTI
Local    Char       MESS1(250)
Local    Date       TODAY : TODAY = date$
Local    Integer    WSTA
Local    Integer    WPJTLAUNCH : WPJTLAUNCH=0 # Issue 107498/108 - 2016-05-20 by BEEBE/ALSHE : flag for control possibility of launching PJT products/POx
Local    Char       WBTSNUM(5) # Issue X3-4775 - 2016-11-07 by ALSHE : Entry transaction for enterpirse planning
Local    Char       WORDCRE(4)

If clalev ([F:ORD1])<= 0 : Local File ORDERS     [ORD1]: Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:ITP]) <= 0 : Local File ITMBPS     [ITP] : Endif   # FQ 79916 GA 03/2012 (suite)
If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:TUV]) <= 0 : Local File TABUNAVAIL [TUV] : Endif
If clalev ([F:TBO]) <= 0 : Local File TABBOMALT  [TBO] : Endif
If clalev ([F:BOH]) <= 0 : Local File BOM        [BOH] : Endif
If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER [BPS] : Endif   # Issue 84572 GA 10/2012
#Gosub OPEN_FILES_MFG From MFGLIB
Gosub OPEN_FILES_SCO From SCOLIB
Gosub INIT_TARIF From SCOAUTLIB    # Issue 84277 GA 10/2012 pour TRTACHTAR1
If clalev ([M:SCOK])  <= 0 : Local Mask SCOK     [SCOK] : Endif

# chargement paramètres
WFCY     = PARAM(1)
WITM     = PARAM(2)
If PARAM(3) <> "" : WQTYBES = val(PARAM(3)) : Else : WQTYBES = 0 : Endif
WDATC    = PARAM(4)
If WDATC <> ""
    If instr(1,WDATC,"/")
        WDATBES = "["+WDATC+"]"
    Else
        WDATBES = WDATC
    Endif
Endif
If PARAM(8) <> "" : WPEC    = val(PARAM(8)) : Else : WPEC    = 0 : Endif
If PARAM(9) <> "" : WSCOHAB = val(PARAM(9)) : Else : WSCOHAB = 0 : Endif
WPLANNER  = PARAM(10)
WPJT      = PARAM(11)

# Issue X3-51935 - 2017-09-20 by ALSHE : allow to create EOF in material task line depending on user parameter PJMORDCRE
If func AFNC.ACTIV("PJM") & find(GFONCTION,"GESPJM")
    Call PARAMUTIL("PJMORDCRE",WORDCRE,GUSER,WFCY) From SUBAUS
    If WORDCRE = "2"
        WSCOHAB = 6
    Endif
Endif
# End issue X3-51935

# X3-110480 - extended find function to include PJMACTTAS
# Issue X3-4775 - 2016-11-07 by ALSHE : Read entry transaction from Parameter PJMPLNTRA
If find(GFONCTION,"GESPJM", "PJMACTTAS")
    If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif
    Call PARAMUTIL("PJMPLNTRA",WBTSNUM,GUSER,WFCY) From SUBAUS
    Read [BTS]BTS0=51;WBTSNUM
Endif
# End issue X3-4775


XTITLE = mess(3,343,1)

Return

###########################################################################
# chargement
$DEBUT_CREEOX
Gosub CHARGE_SMW3
Affzo [M:SMW3]
# Issue 104943 - 2015-08-04 by BEEBE : Implementing Versioning
If dim([M:SMW3]ECCVALMAJ)>0
    Call ECCAFF([M:SMW3]ITMREF,"SMW3") From MFGECCLIB
Endif
Return

###########################################################################
# état boutons
$SETBOUT_CREEOX
If WFLGPEC = 0 : ETABOU(GSPE1)= 1 : Else : ETABOU(GSPE1) = 0 : Endif
ETABOU(GSPE2)=1

# contrôle accès bouton suivant paramètre transaction
#GA Test à revoir quand les habilitations seront ok (sinon pas de bouton ...)
If !find(WSCOHAB,2,3,6,7) : ETABOU(GSPE1) = 0 : Endif : # Planifier (SCOSTA=2 P)
If !find(WSCOHAB,4,5,6,7) : ETABOU(GSPE2) = 0 : Endif : # Lancer    (SCOSTA=1 F)

ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
Return

########################################################################
## GH 15/05/2014 bug 99197
$AVANT_BOUTON_CREEOX
If find(GFONCTION,"FUNMPICK","FUNMPICKA") & find(BOUT,"1","2") & ([M:SMW3]STOFCY<>WFCY | [M:SMW3]ITMREF<>WITM)
   GMESSAGE = mess(298,193,1) # L'article-site ne correspond plus aux critères saisis
   FOK=0 : GERR=1
Endif
Return

########################################################################
$BOUTON_CREEOX
Case BOUT
    When "1"       :     # planifier
                         WSTA = 2
                         Gosub MAJ_CREEOX
                         Return
    When "2"       :     # lancer
                         WSTA = 1
                         Gosub MAJ_CREEOX
                         Return
Endcase
FIN=0
Return

########################################################################
$MAJ_CREEOX
Raz [M:SCOK]
# sr 10.04 demande 25525
GPE = 0
GPOINT="CUSCTL" : Gosub ENTREE From EXEFNC
If GPE : Return : Endif

[M:SCOK]CODMAJ = "C"
[M:SCOK]CODTRS = 2 : # inutilisé ???? ...
[M:SCOK]SCONUM = ""
[M:SCOK]SCILIN = 0
[M:SCOK]BPRNUM = [M:SMW3]BPRNUM2
[M:SCOK]STOFCY = [M:SMW3]PRHFCY # Issue 86437 GA 12/2012 before [M]POHFCY
[M:SCOK]POHFCY = [M:SMW3]POHFCY
[M:SCOK]PRHFCY = [M:SMW3]PRHFCY
[M:SCOK]SCOSTA = WSTA
[M:SCOK]ITMREF = [M:SMW3]ITMREF
[M:SCOK]PRVQTY = 0
[M:SCOK]EXTQTY = [M:SMW3]EXTQTY2
[M:SCOK]STRDAT = [M:SMW3]STRDAT2
[M:SCOK]ENDDAT = [M:SMW3]ENDDAT2
[M:SCOK]BOMALT = [M:SMW3]BOMALT2
[M:SCOK]FMI    = 1
[M:SCOK]PJT    = [M:SMW3]PJT
[M:SCOK]PIO    = 1
[M:SCOK]VCRTYPORI = 0
[M:SCOK]VCRNUMORI = ""
[M:SCOK]VCRLINORI = 0
[M:SCOK]VCRSEQORI = 0
[M:SCOK]WIPTYP = 0
[M:SCOK]WIPNUM = ""
# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:SCOK]ECCVALMAJ)>0
    [M:SCOK]ECCVALMAJ=[M:SMW3]ECCVALMAJ
    [M:SCOK]ECCVALMIN=[M:SMW3]ECCVALMIN
Endif

Call MAJ_SCO From SCOAUTLIB
If [M:SCOK]CODRET = 0  & GOK=1
    If [F:BTS]TRACE=2
        Call OUVRE_TRACE(mess(229,197,1)) From LECFIC
        MESS1 = mess(641,197,1)-"["-mess(WSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(233,197,1)
        Call ECR_TRACE(MESS1,0) From GESECRAN
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
    PARAM(12) = num$(2)
    Raz [M:SMW3]
    PARAM(5) = [M:SCOK]SCONUM
    PARAM(6) = num$(WSTA)
    PARAM(7) = num$(13)  : # num$(5) : # GH 15/05/2014 bug 99197
    # If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNMLINK") : # GH 15/05/2014 bug 99197
    If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA","FUNDBENCHA","FUNMPICK","FUNMPICKA","FUNMLINK")
        GVCR   = [M:SCOK]SCONUM
        GLIN   = 1000
        GSEQ   = 0
    Endif
    FIN = 1
Endif
Return

#---------------------------------------------------------------------------#
# Action SAIMODEOX                                                          #
#---------------------------------------------------------------------------#
###########################################################################
# ouverture
$OUVRE_MODEOX
Local    Char      WFCY(GLONFCY)
Local    Char      WITM(GLONITM),WCPN(GLONITM)
Local    Integer   WTYP, WSTA
Local    Char      WWIP(GLONVCR)
Local    Integer   WSCOHAB

Local    Integer    WSCOTRKFLG, WWIPSTA
Local    Integer    WALLSTA
Local    Integer    WRET
Local    Integer    OK
Local    Integer    WMULTI
Local    Char       XTITLE(250)
Local    Integer    WMODCRE
Local    Date       WORIDAT
Local    Char       WORIFCY(GLONFCY)
Local    Integer    WALT, WALTTYP
Local    Char       WART(GLONITM)
Local    Date       WMEMDAT
Local    Integer    WMAX
Local    Decimal    WRMD
Local    Decimal    WQTY, WAVAOFS, WQUALTI
Local    Char       MESS1(250)
Local    Decimal    WTOTPEC, WECART, WECART2, WTOTCOV, WTOTWOP, WTOTWOPC
Local    Date       WOBJ
Local    Date       WOBJDAT, WORDDAT
Local    Date       TODAY          : TODAY = date$
Local    Integer    WMODE            # (1 = Modification EOX, 2 = PEC)
Local    Integer    WSTA
Local    Decimal    C_QTY
Local    Integer    WNBITM           # 10.04 25477
Local    Integer    WPJTLAUNCH : WPJTLAUNCH=0 # Issue 107498/108 - 2016-05-20 by BEEBE/ALSHE : flag for control possibility of launching PJT products/POx

If clalev ([F:ORD1])<= 0 : Local File ORDERS     [ORD1]: Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:ITP]) <= 0 : Local File ITMBPS     [ITP] : Endif   # FQ 74168 GA 06/2011
If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER [BPS] : Endif   # Issue 84572 GA 09/2012
If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:TUV]) <= 0 : Local File TABUNAVAIL [TUV] : Endif
If clalev ([F:TBO]) <= 0 : Local File TABBOMALT  [TBO] : Endif
If clalev ([F:BOH]) <= 0 : Local File BOM        [BOH] : Endif
#Gosub OPEN_FILES_MFG From MFGLIB
Gosub OPEN_FILES_SCO From SCOLIB
Gosub INIT_TARIF From SCOAUTLIB    # Issue 84277 GA 10/2012 pour TRTACHTAR1
If clalev ([M:SCOK])  <= 0 : Local Mask SCOK     [SCOK] : Endif

# l'action SAIMODEOX a les mêmes paramètres que SAIMODPOX (<> de ceux de SAIMODWOX)
WFCY    = PARAM(1)
WTYP    = val(PARAM(2))
WSTA    = val(PARAM(3))
WWIP    = PARAM(4)
WITM    = PARAM(5)
WSCOHAB = val(PARAM(6))   : # Habilitation planificateur
WINTHAB = val(PARAM(7))   : # Habilitation intersite
WPLANNER = PARAM(8)
Raz PARAM(9)

Case WTYP
  When 13:           WMODE = 1
                     Case WSTA
                       When 1: XTITLE = mess(335,198,1)    # modifier
                       When 2: XTITLE = mess(334,198,1)    # modifier/lancer
                       When 3: XTITLE = mess(333,198,1)    # planifier/lancer
                     Endcase
  # X3-69678 - STWIL - Allow Project demands to use the same screen as sales orders.
  When 1,2,3,6,8,14: WMODE = 2 : # Issue 86810 GH 12/06/2018 - MWx (WTYP=6) added
                     # substitution fenêtre
                     BOITE     = "DPECEOX"
                     WMASQUE   = "SMBENCHW4"
                     Gosub CHANGE_AWI
                     XTITLE = mess(333,198,1)  # planifier/lancer
Endcase

Return

#-------------------------------------------------------------------------#
# >>>>> Fenêtre DMODEOX
#-------------------------------------------------------------------------#
###########################################################################
# chargement
$DEBUT_MODEOX
If WMODE = 2 : Gosub DEBUT_PECEOX : Return : Endif

Gosub CHARGE_SMW1
Diszo [M:SMW1]XWIPTYP
Diszo [M:SMW1]VCRLIN
Diszo [M:SMW1]VCRNUMORI
Actzo [M:SMW1]OBJDAT

Affzo [M:SMW1]

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:SMW1]ECCVALMAJ)>0
    Call ECCAFF([M:SMW1]ITMREF,"SMW1") From MFGECCLIB
    Call CTRECCPRD("SMW1") From MFGECCLIB
Endif

If WALLSTA > 1 | [M:SMW1]WIPSTA<3 : # Issue 107089 - 2015-12-17 by GH : BOM code not changeable to be consistent with GESSCO
  Diszo [M:SMW1]BOMALT2
Endif
Return

###########################################################################
# état boutons
$SETBOUT_MODEOX
If WMODE = 2 : Gosub SETBOUT_PECEOX : Return : Endif

Actzo [M:SMW1]PRHFCY
Actzo [M:SMW1]LOT

If WSCOTRKFLG > 3            : # si l'ordre est "en cours": pas de maj
    ETABOU(GENRE) = 0
    ETABOU(GSUPP) = 0
    Diszo [M:SMW1]QTYPUU2,STRDAT2,ENDDAT2,BPRNUM2
    Diszo [M:SMW1]PRHFCY,POHFCY
    Diszo [M:SMW1]LOT
    Diszo [M:SMW1]OBJDAT
    If dim([M:SMW1]ECCVALMAJ)  # Issue 107513/US10 by GA 08/2015
       Diszo [M:SMW1]ECCVALMAJ,ECCVALMIN
    Endif
Else
    If [M:SMW1]WIPSTA < 3  : # si l'encours est 1=Ferme ou 2=Planifié
        ETABOU(GENRE) = 1
    Else
        ETABOU(GENRE) = 0
    Endif
    ETABOU(GSUPP) = 1
Endif

Case [M:SMW1]WIPSTA
    When 1: If WALLSTA > 1 | WSCOTRKFLG > 3 | WMODCRE <> 0
                ETABOU(GSPE1)=0
            Else
                WTOTPEC  = 0
                WTOTWOP  = 0
                WTOTWOPC = 0
                Call CUM_PEC(36, [M:SMW1]VCRNUM, [M:SMW1]VCRLIN, 0, 1, WTOTPEC, WTOTWOP,
&                            WTOTWOPC) From TRTWIP
                If WTOTWOPC = 0
                    ETABOU(GSPE1) = 1
                Else
                    ETABOU(GSPE1) = 0
                Endif
            Endif
            ETABOU(GSPE2)=0
    When 2: ETABOU(GSPE1)=0
            ETABOU(GSPE2)=1
    When 3: ETABOU(GSPE1)=1
            ETABOU(GSPE2)=1
Endcase
# 10.04 25477 si multi-article pas de modification
If WNBITM > 1 : ETABOU(GSPE1) = 0 : ETABOU(GSPE2) = 0 : Endif

# Issue 107498/108 - 2016-05-20 by BEEBE/ALSHE : button only active when launching possible
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
If WPJTLAUNCH = 1 & func AFNC.ACTIV("PJM")
    GERR = 1
    GMESSAGE = [M:SMW1]PJT + " : " + mess(228,2260,1)
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
Endif

ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0

# contrôle accès bouton suivant paramètre transaction
Case [M:SMW1]WIPSTA
    When 1:    If !find(WSCOHAB,4,5,6,7)
                   ETABOU(GENRE) =  0
                   ETABOU(GSUPP) =  0
               Endif
               If !find(WSCOHAB,2,3,6,7) : ETABOU(GSPE1) = 0 : Endif
    When 2:    If !find(WSCOHAB,2,3,6,7)
                   ETABOU(GENRE) =  0
                   ETABOU(GSUPP) =  0
               Endif
               If !find(WSCOHAB,4,5,6,7) : ETABOU(GSPE2) = 0 : Endif
    When 3:    If !find(WSCOHAB,1,3,5,7)
                   ETABOU(GENRE) =  0
                   ETABOU(GSUPP) =  0
               Endif
               If !find(WSCOHAB,2,3,6,7) : ETABOU(GSPE1) = 0 : Endif
               If !find(WSCOHAB,4,5,6,7) : ETABOU(GSPE2) = 0 : Endif
Endcase

Return

########################################################################
$ENR_MODEOX
# Issue 86491 GA 02/2013 ctl à faire aussi si on est sur EOS ou WOS
# contrôle nomenclature
#If find([M:SMW1]WIPSTA,1,2)
    WALT    = [M:SMW1]BOMALT2
    WALTTYP = 3  : # Nomenclature de sous-traitance
    Call CONT_BOMALT([M:SMW1]PRHFCY, WALT, WALTTYP ,
&                    [M:SMW1]ITMREF, [M:SMW1]STRDAT2) From BENCHLIB
    If GMESSAGE <> "" : GERR = 1 : Return : Endif
#Endif

Raz [M:SCOK]
# Issue 90888 GA 07/2013 Cas particulier changt de fournisseur
If [M:SMW1]BPRNUM <> [M:SMW1]BPRNUM2 & [M:SMW1]WIPSTA<3
      # Contrôler si déjà commandé ou non
      Read [SCI]SCI0=[M:SMW1]VCRNUM;[M:SMW1]VCRLIN
      If fstat | [F:SCI]ITMSTA>2
        # "Changement de fournisseur impossible pour cet ordre de sous-traitance."
         GMESSAGE=mess(461,194,1)
         GERR = 1
         FIN = 1
         Return
      Endif
     # "Nouveau fournisseur: voulez-vous suprimer et recréer l'ordre de sous-traitance ?"
      Local    Integer  WRET : WRET = 2
      Call OUINON(mess(460,194,1),WRET) From GESECRAN
      If WRET=2
      # Delete previous EO
        [M:SCOK]CODMAJ = "A"
        [M:SCOK]SCONUM = [M:SMW1]VCRNUM
        [M:SCOK]SCILIN = [M:SMW1]VCRLIN
        [M:SCOK]POHFCY = [M:SMW1]POHFCY
        [M:SCOK]STOFCY = [M:SMW1]PRHFCY
        [M:SCOK]PRHFCY = [M:SMW1]PRHFCY
        [M:SCOK]SCOSTA = [M:SMW1]WIPSTA
        Call MAJ_SCO From SCOAUTLIB

      # Create new EO
         [M:SMW1]EXTQTY1 = 0
         [M:SCOK]CODMAJ  = "C"
       Else
         GERR = 1
         FIN = 1
         Return
       Endif
Else
       [M:SCOK]CODMAJ = "M"
Endif

#[M:SCOK]CODTRS = 2 : # inutilisé ...
[M:SCOK]SCONUM = [M:SMW1]VCRNUM
[M:SCOK]SCILIN = [M:SMW1]VCRLIN
[M:SCOK]BPRNUM = [M:SMW1]BPRNUM2
[M:SCOK]POHFCY = [M:SMW1]POHFCY
[M:SCOK]STOFCY = [M:SMW1]PRHFCY # Issue 86437 GA 12/2012 before [M]POHFCY
[M:SCOK]PRHFCY = [M:SMW1]PRHFCY
[M:SCOK]SCOSTA = [M:SMW1]WIPSTA
[M:SCOK]ITMREF = [M:SMW1]ITMREF
[M:SCOK]PUU    = [M:SMW1]PUU2
[M:SCOK]QTYPUU = [M:SMW1]QTYPUU2
[M:SCOK]EXTQTY = [M:SMW1]EXTQTY2
[M:SCOK]PRVQTY = [M:SMW1]EXTQTY1
[M:SCOK]STRDAT = [M:SMW1]STRDAT2
[M:SCOK]ENDDAT = [M:SMW1]ENDDAT2
[M:SCOK]BOMALT = [M:SMW1]BOMALT2
[M:SCOK]PJT    = [M:SMW1]PJT
[M:SCOK]SCODES = [M:SMW1]SCODES : # GH 09/01/2012 bug 78926
[M:SCOK]LOT    = [M:SMW1]LOT
[M:SCOK]FMI    = [M:SMW1]FMI
[M:SCOK]PIO    = [M:SMW1]PIO
[M:SCOK]VCRTYPORI = [M:SMW1]VCRTYPORI
[M:SCOK]VCRNUMORI = [M:SMW1]VCRNUMORI
[M:SCOK]VCRLINORI = [M:SMW1]VCRLINORI
[M:SCOK]VCRSEQORI = [M:SMW1]VCRSEQORI
[M:SCOK]WIPTYP = WTYP
[M:SCOK]WIPNUM = WWIP
[M:SCOK]OBJDAT = [M:SMW1]OBJDAT
# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:SCOK]ECCVALMAJ)>0
    [M:SCOK]ECCVALMAJ=[M:SMW1]ECCVALMAJ
    [M:SCOK]ECCVALMIN=[M:SMW1]ECCVALMIN
Endif
Call MAJ_SCO From SCOAUTLIB
If [M:SCOK]CODRET = 0  & GOK=1
    If [F:BTS]TRACE=2      # 18138 MM 01.05
        Call OUVRE_TRACE(mess(229,197,1)) From LECFIC
        MESS1 = mess(641,197,1)-"["-mess(WSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(232,197,1)
        Call ECR_TRACE(MESS1,0) From GESECRAN
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
    PARAM(7) = num$(2)
    Raz [M:SMW1]
    If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA","FUNDBENCHA","FUNMLINK")
        GVCR   = [M:SCOK]SCONUM
        GLIN   = 1000
        GSEQ   = 0
    Endif
    FIN = 1
Endif

Return

########################################################################
$SUP_MODEOX
OK = 1
Case [M:SMW1]WIPSTA
    When 1,2: Call OUINON(mess(246,190,1),OK) From GESECRAN
    When 3:   Call OUINON(mess(62,190,1),OK) From GESECRAN
Endcase
WSTA=[M:SMW1]WIPSTA
If OK = 2
    Raz [M:SCOK]
    [M:SCOK]CODMAJ = "A"
   #[M:SCOK]CODTRS = 2 : # inutilisé ...
    [M:SCOK]SCONUM = [M:SMW1]VCRNUM
    [M:SCOK]POHFCY = [M:SMW1]POHFCY
    [M:SCOK]STOFCY = [M:SMW1]PRHFCY # Issue 86437 GA 12/2012 before [M]POHFCY
    [M:SCOK]PRHFCY = [M:SMW1]PRHFCY
    [M:SCOK]SCOSTA = [M:SMW1]WIPSTA
    [M:SCOK]SCILIN = [M:SMW1]VCRLIN
    Call MAJ_SCO From SCOAUTLIB
    If [M:SCOK]CODRET = 0  & GOK=1
        If [F:BTS]TRACE=2      # 18138 MM 01.05
            Call OUVRE_TRACE(mess(229,197,1)) From LECFIC
            MESS1 = mess(641,197,1)-"["-mess(WSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(234,197,1)
            Call ECR_TRACE(MESS1,0) From GESECRAN
            Call FERME_TRACE From LECFIC
            Call LEC_TRACE From LECFIC
        Endif
        PARAM(7) = num$(2)
        Raz [M:SMW1]
       If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA","FUNDBENCHA","FUNMLINK")
           GVCR   = ""
           GLIN   = 0
           GSEQ   = 0
        Endif
        FIN = 1
   Endif
Endif
Return

########################################################################
$BOUTON_MODEOX
If WMODE = 2 : Gosub BOUTON_PECEOX : Return : Endif

Case BOUT
    When "1"       :     # planifier
                         Gosub MAJ_MODPLN
                         Return
    When "2"       :     # lancer
                         Gosub MAJ_MODLAN
                         Return
Endcase
FIN=0
Return

########################################################################
$MAJ_MODPLN
#
WSTA=2 : # bouton Planifier
# lecture article
If [F:ITM]ITMREF <> [M:SMW1]ITMREF
   Read [ITM]ITM0=[M:SMW1]ITMREF
   If fstat : Raz [F:ITM] : Endif
Endif

# contrôle article
Local Char WITMREF(GLONITM): WITMREF=[M:SMW1]ITMREF
Gosub READ_ITM From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(483,199,1)-WITMREF : Return : Endif

# contrôle article/site
Local Char WFCY   (GLONFCY) : WFCY=[M:SMW1]PRHFCY
Gosub READ_ITF From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : Return : Endif

Call CONTSCOITM([M:SMW1]PRHFCY, 1) From SCOLIB
If mkstat = 2 : mkstat = 0 : Return : Endif

# Issue 86491 GA 02/2013 ctl à faire aussi si on est sur EOS ou WOS
# contrôle nomenclature
#If find([M:SMW1]WIPSTA,1,2)
    WALT    = [M:SMW1]BOMALT2
    WALTTYP = 3  : # Nomenclature de sous-traitance
    # Issue 89383 GA 04/2013 site de réception plutôt que site d'achat
    Call CONT_BOMALT([M:SMW1]PRHFCY, WALT, WALTTYP,
&                    [M:SMW1]ITMREF, [M:SMW1]STRDAT2) From BENCHLIB
    If GMESSAGE <> "" : GERR = 1 : Return : Endif
#Endif

Raz [M:SCOK]
Case [M:SMW1]WIPSTA
    When 1,2 : [M:SCOK]CODMAJ = "M"
    When 3   : [M:SCOK]CODMAJ = "R"
Endcase
Case WMODCRE
    When 1  : [M:SCOK]CODMAJ = "C"
    When 2  : [M:SCOK]CODMAJ = "P"
Endcase

# Issue 90888 GA 07/2013 Cas particulier EOP/EOF
If [M:SMW1]BPRNUM <> [M:SMW1]BPRNUM2 & [M:SMW1]WIPSTA<3
      # Contrôler si déjà commandé ou non
      Read [SCI]SCI0=[M:SMW1]VCRNUM;[M:SMW1]VCRLIN
      If fstat | [F:SCI]ITMSTA>2
        # "Changement de fournisseur impossible pour cet ordre de sous-traitance."
         GMESSAGE=mess(461,194,1)
         GERR = 1
         FIN = 1
         Return
      Endif
     # "Nouveau fournisseur: voulez-vous suprimer et recréer l'ordre de sous-traitance ?"
      Local    Integer  WRET : WRET = 2
      Call OUINON(mess(460,194,1),WRET) From GESECRAN
      If WRET=2
      # Delete previous EO
        [M:SCOK]CODMAJ = "A"
        [M:SCOK]SCONUM = [M:SMW1]VCRNUM
        [M:SCOK]SCILIN = [M:SMW1]VCRLIN
        [M:SCOK]POHFCY = [M:SMW1]POHFCY
        [M:SCOK]STOFCY = [M:SMW1]PRHFCY
        [M:SCOK]PRHFCY = [M:SMW1]PRHFCY
        [M:SCOK]SCOSTA = [M:SMW1]WIPSTA
        Call MAJ_SCO From SCOAUTLIB

      # Create new EO
         [M:SMW1]EXTQTY1 = 0
         [M:SCOK]CODMAJ  = "C"
       Else
         GERR = 1
         FIN = 1
         Return
       Endif
Endif

#[M:SCOK]CODTRS = 2 : # inutilisé ...
[M:SCOK]SCONUM = [M:SMW1]VCRNUM
[M:SCOK]SCILIN = [M:SMW1]VCRLIN
[M:SCOK]BPRNUM = [M:SMW1]BPRNUM2
[M:SCOK]POHFCY = [M:SMW1]POHFCY
[M:SCOK]STOFCY = [M:SMW1]PRHFCY # Issue 86437 GA 12/2012 before [M]POHFCY
[M:SCOK]PRHFCY = [M:SMW1]PRHFCY
[M:SCOK]SCOSTA = WSTA
[M:SCOK]ITMREF = [M:SMW1]ITMREF
[M:SCOK]PUU    = [M:SMW1]PUU2
[M:SCOK]QTYPUU = [M:SMW1]QTYPUU2
[M:SCOK]EXTQTY = [M:SMW1]EXTQTY2
[M:SCOK]PRVQTY = [M:SMW1]EXTQTY1
[M:SCOK]STRDAT = [M:SMW1]STRDAT2
[M:SCOK]ENDDAT = [M:SMW1]ENDDAT2
[M:SCOK]BOMALT = [M:SMW1]BOMALT2
[M:SCOK]PJT    = [M:SMW1]PJT
[M:SCOK]SCODES = [M:SMW1]SCODES : # GH 09/01/2012 bug 78926
[M:SCOK]LOT    = [M:SMW1]LOT
[M:SCOK]FMI    = [M:SMW1]FMI
[M:SCOK]PIO    = [M:SMW1]PIO
[M:SCOK]VCRTYPORI = [M:SMW1]VCRTYPORI
[M:SCOK]VCRNUMORI = [M:SMW1]VCRNUMORI
[M:SCOK]VCRLINORI = [M:SMW1]VCRLINORI
[M:SCOK]VCRSEQORI = [M:SMW1]VCRSEQORI
[M:SCOK]WIPTYP = WTYP
[M:SCOK]WIPNUM = WWIP
[M:SCOK]OBJDAT = [M:SMW1]OBJDAT
# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:SCOK]ECCVALMAJ)>0
    [M:SCOK]ECCVALMAJ=[M:SMW1]ECCVALMAJ
    [M:SCOK]ECCVALMIN=[M:SMW1]ECCVALMIN
Endif
If [M:SCOK]CODMAJ = "R"
    Gosub CHECK_WIP
    If WRET
        GERR = 1
        FIN = 1
        PARAM(7) = num$(2)
        Return
    Endif
Endif
Call MAJ_SCO From SCOAUTLIB
If [M:SCOK]CODRET = 0  & GOK=1
    If [F:BTS]TRACE=2     # 18138 MM 01.05
        Call OUVRE_TRACE(mess(229,197,1)) From LECFIC
        MESS1 = mess(641,197,1)-"["-mess(WSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(233,197,1)
        Call ECR_TRACE(MESS1,0) From GESECRAN
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
    PARAM(7) = num$(2)
    Raz [M:SMW1]
    If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA","FUNDBENCHA","FUNMLINK")
        GVCR   = [M:SCOK]SCONUM
        GLIN   = 1000
        GSEQ   = 0
    Endif
    FIN = 1
Endif
WMODCRE = 0
Return

########################################################################
$MAJ_MODLAN
WSTA=1 : # bouton Lancer
Local Char WITMREF(GLONITM): WITMREF=[M:SMW1]ITMREF
Gosub READ_ITM From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(483,199,1)-WITMREF : Return : Endif

# contrôle article/site
Local Char WFCY   (GLONFCY) : WFCY=[M:SMW1]PRHFCY
Gosub READ_ITF From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : Return : Endif

# Issue 89383 GA 04/2013 site de réception plutôt que site d'achat
Call CONTSCOITM([M:SMW1]PRHFCY, 1) From SCOLIB
If mkstat = 2 : mkstat = 0 : Return : Endif

# Issue 86491 GA 02/2013 ctl à faire aussi si on est sur EOS ou WOS
# contrôle nomenclature
#If find([M:SMW1]WIPSTA,1,2)
    WALT    = [M:SMW1]BOMALT2
    WALTTYP = 3  : # Nomenclature de sous-traitance
    # Issue 89383 GA 04/2013 site de réception plutôt que site d'achat
    Call CONT_BOMALT([M:SMW1]PRHFCY, WALT, WALTTYP,
&                    [M:SMW1]ITMREF, [M:SMW1]STRDAT2) From BENCHLIB
    If GMESSAGE <> "" : GERR = 1 : Return : Endif
#Endif

Raz [M:SCOK]
Case [M:SMW1]WIPSTA
    When 1,2 : [M:SCOK]CODMAJ = "M"
    When 3   : [M:SCOK]CODMAJ = "R"
Endcase
Case WMODCRE
    When 1 : [M:SCOK]CODMAJ = "C"
    When 2 : [M:SCOK]CODMAJ = "P"
Endcase

# Issue 90888 GA 07/2013 Cas particulier EOP/EOF
If [M:SMW1]BPRNUM <> [M:SMW1]BPRNUM2 & [M:SMW1]WIPSTA<3
      # Contrôler si déjà commandé ou non
      Read [SCI]SCI0=[M:SMW1]VCRNUM;[M:SMW1]VCRLIN
      If fstat | [F:SCI]ITMSTA>2
        # "Changement de fournisseur impossible pour cet ordre de sous-traitance."
         GMESSAGE=mess(461,194,1)
         GERR = 1
         FIN = 1
         Return
      Endif
     # "Nouveau fournisseur: voulez-vous suprimer et recréer l'ordre de sous-traitance ?"
      Local    Integer  WRET : WRET = 2
      Call OUINON(mess(460,194,1),WRET) From GESECRAN
      If WRET=2
      # Delete previous EO
        [M:SCOK]CODMAJ = "A"
        [M:SCOK]SCONUM = [M:SMW1]VCRNUM
        [M:SCOK]SCILIN = [M:SMW1]VCRLIN
        [M:SCOK]POHFCY = [M:SMW1]POHFCY
        [M:SCOK]STOFCY = [M:SMW1]PRHFCY
        [M:SCOK]PRHFCY = [M:SMW1]PRHFCY
        [M:SCOK]SCOSTA = [M:SMW1]WIPSTA
        Call MAJ_SCO From SCOAUTLIB

      # Create new EO
         [M:SMW1]EXTQTY1 = 0
         [M:SCOK]CODMAJ  = "C"
       Else
         GERR = 1
         FIN = 1
         Return
       Endif
Endif

# -------------------------------------------------------
# 1er cas: EO existant et qté totale ou supérieure lancée
# -------------------------------------------------------
If [M:SMW1]EXTQTY1 <= [M:SMW1]EXTQTY2 | [M:SCOK]CODMAJ<>"M"

   #[M:SCOK]CODTRS = 2 : # inutilisé ...
    [M:SCOK]SCONUM = [M:SMW1]VCRNUM
    [M:SCOK]SCILIN = [M:SMW1]VCRLIN
    [M:SCOK]BPRNUM = [M:SMW1]BPRNUM2
    [M:SCOK]POHFCY = [M:SMW1]POHFCY
    [M:SCOK]STOFCY = [M:SMW1]PRHFCY # Issue 86437 GA 12/2012 before [M]POHFCY
    [M:SCOK]PRHFCY = [M:SMW1]PRHFCY
    [M:SCOK]SCOSTA = WSTA
    [M:SCOK]ITMREF = [M:SMW1]ITMREF
    [M:SCOK]PUU    = [M:SMW1]PUU2
    [M:SCOK]QTYPUU = [M:SMW1]QTYPUU2
    [M:SCOK]PRVQTY = [M:SMW1]EXTQTY1
    [M:SCOK]EXTQTY = [M:SMW1]EXTQTY2
    [M:SCOK]STRDAT = [M:SMW1]STRDAT2
    [M:SCOK]ENDDAT = [M:SMW1]ENDDAT2
    [M:SCOK]BOMALT = [M:SMW1]BOMALT2
    [M:SCOK]PJT    = [M:SMW1]PJT
    [M:SCOK]SCODES = [M:SMW1]SCODES : # GH 09/01/2012 bug 78926
    If dim([M:SCOK]MTOREF)>0 & dim([M:SMW1]MTOREF)>0
       [M:SCOK]MTOREF     = [M:SMW1]MTOREF   : # V6 Réseau MTO FQ 46650
    Endif
    [M:SCOK]LOT    = [M:SMW1]LOT
    [M:SCOK]FMI    = [M:SMW1]FMI
    [M:SCOK]PIO    = [M:SMW1]PIO
    [M:SCOK]VCRTYPORI = [M:SMW1]VCRTYPORI
    [M:SCOK]VCRNUMORI = [M:SMW1]VCRNUMORI
    [M:SCOK]VCRLINORI = [M:SMW1]VCRLINORI
    [M:SCOK]VCRSEQORI = [M:SMW1]VCRSEQORI
    [M:SCOK]WIPTYP = WTYP
    [M:SCOK]WIPNUM = WWIP
    [M:SCOK]MAJPEC = 9
    # Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
    If dim([M:SCOK]ECCVALMAJ)>0
        [M:SCOK]ECCVALMAJ=[M:SMW1]ECCVALMAJ
        [M:SCOK]ECCVALMIN=[M:SMW1]ECCVALMIN
    Endif
    If [M:SCOK]CODMAJ = "R"
        Gosub CHECK_WIP
        If WRET
            GERR = 1
            FIN = 1
            PARAM(7) = num$(2)
            Return
        Endif
    Endif
    Call MAJ_SCO From SCOAUTLIB
    If [M:SCOK]CODRET = 0  & GOK=1
        If [F:BTS]TRACE=2    # 18138 MM 01.05
            Call OUVRE_TRACE(mess(229,197,1)) From LECFIC
            MESS1 = mess(641,197,1)-"["-mess(WSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(233,197,1)
            Call ECR_TRACE(MESS1,0) From GESECRAN
            Call FERME_TRACE From LECFIC
            Call LEC_TRACE From LECFIC
        Endif
        PARAM(7) = num$(2)
        Raz [M:SMW1]
        If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA","FUNDBENCHA","FUNMLINK")
            GVCR   = [M:SCOK]SCONUM
            GLIN   = 1000
            GSEQ   = 0
        Endif
        FIN = 1
    Endif
    WMODCRE = 0
    Return
Else
    # -------------------------------------------------------
    # 2eme cas: on crée un nouvel EO
    # -------------------------------------------------------
    # création EOF
    [M:SCOK]CODMAJ = "C"
    #[M:SCOK]CODTRS = 2 : # inutilisé ...
    [M:SCOK]SCONUM = ""
    [M:SCOK]SCILIN = 0
    [M:SCOK]BPRNUM = [M:SMW1]BPRNUM2
    [M:SCOK]POHFCY = [M:SMW1]POHFCY
    [M:SCOK]STOFCY = [M:SMW1]PRHFCY # Issue 86437 GA 12/2012 before [M]POHFCY
    [M:SCOK]PRHFCY = [M:SMW1]PRHFCY
    [M:SCOK]SCOSTA = WSTA
    [M:SCOK]ITMREF = [M:SMW1]ITMREF
    [M:SCOK]PUU    = [M:SMW1]PUU2
    [M:SCOK]QTYPUU = [M:SMW1]QTYPUU2
    [M:SCOK]PRVQTY = [M:SMW1]EXTQTY1
    [M:SCOK]EXTQTY = [M:SMW1]EXTQTY2
    [M:SCOK]STRDAT = [M:SMW1]STRDAT2
    [M:SCOK]ENDDAT = [M:SMW1]ENDDAT2
    [M:SCOK]BOMALT = [M:SMW1]BOMALT2
    [M:SCOK]PJT    = [M:SMW1]PJT
    [M:SCOK]SCODES = [M:SMW1]SCODES : # GH 09/01/2012 bug 78926
    [M:SCOK]LOT    = [M:SMW1]LOT
    [M:SCOK]FMI    = [M:SMW1]FMI
    [M:SCOK]PIO    = [M:SMW1]PIO
    [M:SCOK]VCRTYPORI = [M:SMW1]VCRTYPORI
    [M:SCOK]VCRNUMORI = [M:SMW1]VCRNUMORI
    [M:SCOK]VCRLINORI = [M:SMW1]VCRLINORI
    [M:SCOK]VCRSEQORI = [M:SMW1]VCRSEQORI
    [M:SCOK]WIPTYP = WTYP
    [M:SCOK]WIPNUM = WWIP
    [M:SCOK]MAJPEC = 9
    # Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
    If dim([M:SCOK]ECCVALMAJ)>0
        [M:SCOK]ECCVALMAJ=[M:SMW1]ECCVALMAJ
        [M:SCOK]ECCVALMIN=[M:SMW1]ECCVALMIN
    Endif

    Call MAJ_SCO From SCOAUTLIB
    If [M:SCOK]CODRET <> 0 | GOK<1 : Return : Endif

    If [F:BTS]TRACE=2     # 18138 MM 01.05
        Call OUVRE_TRACE(mess(229,197,1)) From LECFIC
        MESS1 = mess(641,197,1)-"["-mess(WSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(233,197,1)
        Call ECR_TRACE(MESS1,0) From GESECRAN
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
    If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA","FUNDBENCHA","FUNMLINK")
        GVCR   = [M:SCOK]SCONUM
        GLIN   = 1000
        GSEQ   = 0
    Endif

    # ---------------------------------------------------------
    # 2eme cas: puis on diminue l'EO en partie lancé
    # ---------------------------------------------------------
    If WTYP=13
      # diminution EOP
      [M:SCOK]CODMAJ = "M"
      #[M:SCOK]CODTRS = 2 : # inutilisé ...
      [M:SCOK]SCONUM = [M:SMW1]VCRNUM
      [M:SCOK]SCILIN = [M:SMW1]VCRLIN
      [M:SCOK]BPRNUM = [M:SMW1]BPRNUM2
      [M:SCOK]POHFCY = [M:SMW1]POHFCY
      [M:SCOK]STOFCY = [M:SMW1]PRHFCY # Issue 86437 GA 12/2012 before [M]POHFCY
      [M:SCOK]PRHFCY = [M:SMW1]PRHFCY
      [M:SCOK]SCOSTA = [M:SMW1]WIPSTA
      [M:SCOK]ITMREF = [M:SMW1]ITMREF
      [M:SCOK]QTYPUU = 0                    : # pour recalcul dans SCOAUTLIB
      [M:SCOK]PRVQTY = [M:SMW1]EXTQTY1
      [M:SCOK]EXTQTY = [M:SMW1]EXTQTY1 - [M:SMW1]EXTQTY2
      [M:SCOK]STRDAT = [M:SMW1]STRDAT1
      [M:SCOK]ENDDAT = [M:SMW1]ENDDAT1
      [M:SCOK]BOMALT = [M:SMW1]BOMALT1
      [M:SCOK]PJT    = [M:SMW1]PJT
      [M:SCOK]SCODES = [M:SMW1]SCODES : # GH 09/01/2012 bug 78926
      [M:SCOK]LOT    = [M:SMW1]LOT
      [M:SCOK]WIPTYP = WTYP
      [M:SCOK]WIPNUM = WWIP
      [M:SCOK]MAJPEC = 9
      Call MAJ_SCO From SCOAUTLIB
      If [M:SCOK]CODRET = 0  & GOK=1
          PARAM(7) = num$(2)
          Raz [M:SMW1]
      Endif
    Endif
Endif
FIN = 1
WMODCRE = 0
Return

#-------------------------------------------------------------------------#
# >>>>> Fenêtre DPECEOX
#-------------------------------------------------------------------------#
###########################################################################
# chargement
$DEBUT_PECEOX
Gosub CHARGE_SMW4
Diszo [M:SMW4]5
Actzo [M:SMW4]POHFCY : ## GH 02/01/13 bug 86990
Diszo [M:SMW4]10
Diszo [M:SMW4]15
Diszo [M:SMW4]20
Affzo [M:SMW4]
Return

###########################################################################
# état boutons
$SETBOUT_PECEOX
ETABOU(GSPE1) = 1
ETABOU(GSPE2) = 1

# contrôle accès bouton suivant paramètre transaction
If !find(WSCOHAB,2,3,6,7) : ETABOU(GSPE1) = 0 : Endif
If !find(WSCOHAB,4,5,6,7) : ETABOU(GSPE2) = 0 : Endif

# Issue 107498/108 - 2016-05-20 by BEEBE/ALSHE : button only active when launching possible
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
If WPJTLAUNCH = 1 & func AFNC.ACTIV("PJM")
    GERR = 1
    GMESSAGE = [M:SMW4]PJT + " : " + mess(228,2260,1)
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
Endif

ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0

Return

########################################################################
$BOUTON_PECEOX
Case BOUT
    When "1"       :     # planifier
                         WSTA = 2
                         Gosub MAJ_PECEOX
                         Return
    When "2"       :     # lancer
                         WSTA = 1
                         Gosub MAJ_PECEOX
                         Return
Endcase
FIN=0
Return

########################################################################
$MAJ_PECEOX
Local Char WITMREF(GLONITM): WITMREF=[M:SMW4]ITMREF
Gosub READ_ITM From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(483,199,1)-WITMREF : Return : Endif

# contrôle article/site
Local Char WFCY   (GLONFCY) : WFCY=[M:SMW4]PRHFCY
Gosub READ_ITF From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : Return : Endif

# Issue 89383 GA 04/2013 site de réception plutôt que site d'achat
Call CONTSCOITM([M:SMW4]PRHFCY, 1) From SCOLIB
If mkstat = 2 : mkstat = 0 : Return : Endif

Raz [M:SCOK]
If WOBJ < [M:SMW4]ENDDAT2
    OK = 1
    Call OUINON(mess(94,190,1),OK) From GESECRAN
    If OK <> 2 : Return : Endif
Endif
[M:SCOK]CODMAJ = "P"
#[M:SCOK]CODTRS = 2 : # inutilisé ...
[M:SCOK]SCONUM = [M:SMW4]VCRNUM
[M:SCOK]SCILIN = [M:SMW4]VCRLIN
[M:SCOK]STOFCY = [M:SMW4]PRHFCY # Issue 86437 GA 12/2012 before [M]POHFCY
[M:SCOK]POHFCY = [M:SMW4]POHFCY
[M:SCOK]PRHFCY = [M:SMW4]PRHFCY
[M:SCOK]SCOSTA = WSTA
[M:SCOK]ITMREF = [M:SMW4]ITMREF
[M:SCOK]PRVQTY = [M:SMW4]EXTQTY1
[M:SCOK]EXTQTY = [M:SMW4]EXTQTY2
[M:SCOK]STRDAT = [M:SMW4]STRDAT2
[M:SCOK]ENDDAT = [M:SMW4]ENDDAT2
[M:SCOK]BOMALT = [M:SMW4]BOMALT2
[M:SCOK]PJT    = [M:SMW4]PJT
[M:SCOK]LOT    = [M:SMW4]LOT
[M:SCOK]FMI    = [M:SMW4]FMI
[M:SCOK]PIO    = [M:SMW4]PIO
[M:SCOK]BPRNUM = [M:SMW4]BPRNUM2
[M:SCOK]VCRTYPORI = [M:SMW4]VCRTYPORI
[M:SCOK]VCRNUMORI = [M:SMW4]VCRNUMORI
[M:SCOK]VCRLINORI = [M:SMW4]VCRLINORI
[M:SCOK]VCRSEQORI = [M:SMW4]VCRSEQORI
[M:SCOK]WIPTYP = WTYP
[M:SCOK]WIPNUM = WWIP
Gosub CHECK_WIP
If WRET
    GERR = 1
    FIN = 1
    PARAM(7) = num$(2)
    Return
Endif
Call MAJ_SCO From SCOAUTLIB
If [M:SCOK]CODRET = 0  & GOK=1
    If [F:BTS]TRACE=2     # 18138 MM 01.05
        Call OUVRE_TRACE(mess(229,197,1)) From LECFIC
        MESS1 = mess(641,197,1)-"["-mess(WSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(233,197,1)
        Call ECR_TRACE(MESS1,0) From GESECRAN
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
    If WTYP = 2 & WSTA = 3
        If [M:SMW4]EXTQTY2 >= [M:SMW4]EXTQTY1
            Raz [M:SCOK]
            [M:SCOK]CODMAJ = "A"
            #[M:SCOK]CODTRS = 2 : # inutilisé ...
            [M:SCOK]SCONUM = [M:SMW4]VCRNUMORI
            [M:SCOK]SCILIN = [M:SMW4]VCRLINORI
            [M:SCOK]STOFCY = [M:SMW4]PRHFCY # Issue 86437 GA 12/2012 before [M]POHFCY
            [M:SCOK]SCOSTA = 3
            [M:SCOK]ITMREF = [M:SMW4]ITMREF
            [M:SCOK]WIPTYP = WTYP
            [M:SCOK]WIPNUM = WWIP
            Call MAJ_SCO From SCOAUTLIB
        Else
            Raz [M:SCOK]
            [M:SCOK]CODMAJ = "D"
            #[M:SCOK]CODTRS = 2 : # inutilisé ...
            [M:SCOK]SCONUM = [M:SMW4]VCRNUMORI
            [M:SCOK]STOFCY = [M:SMW4]PRHFCY # Issue 86437 GA 12/2012 before [M]POHFCY
            [M:SCOK]SCOSTA = 3
            [M:SCOK]ITMREF = [M:SMW4]ITMREF
            [M:SCOK]PRVQTY = [M:SMW4]EXTQTY1
            [M:SCOK]EXTQTY = [M:SMW4]EXTQTY1 - [M:SMW4]EXTQTY2
            [M:SCOK]WIPNUM = WWIP
            [M:SCOK]WIPTYP = WTYP
            Call MAJ_SCO From SCOAUTLIB
        Endif
    Endif
    If WTYP = 5 & WSTA = 3
        If [M:SMW4]EXTQTY2 >= [M:SMW4]EXTQTY1
            Raz [M:MFGK]
            [M:MFGK]CODMAJ = "A"
            [M:MFGK]CODTRS = 2
            [M:MFGK]MFGNUM = [M:SMW4]VCRNUMORI
            [M:MFGK]MFGLIN = [M:SMW4]VCRLINORI
            [M:MFGK]MFGFCY = [M:SMW4]POHFCY
            [M:MFGK]MFGSTA = 3
            [M:MFGK]ITMREF = [M:SMW4]ITMREF
            [M:MFGK]WIPTYP = 5
            [M:MFGK]WIPNUM = WWIP
            Call MAJ_OF From MFGAUTLIB
        Else
            Raz [M:MFGK]
            [M:MFGK]CODMAJ = "D"
            [M:MFGK]CODTRS = 2
            [M:MFGK]MFGNUM = [M:SMW4]VCRNUMORI
            [M:MFGK]MFGFCY = [M:SMW4]POHFCY
            [M:MFGK]MFGSTA = 3
            [M:MFGK]ITMREF = [M:SMW4]ITMREF
            [M:MFGK]PRVQTY = [M:SMW4]EXTQTY1
            [M:MFGK]EXTQTY = [M:SMW4]EXTQTY1 - [M:SMW4]EXTQTY2
            [M:MFGK]WIPNUM = WWIP
            [M:MFGK]WIPTYP = 5
            Call MAJ_OF From MFGAUTLIB
        Endif
    Endif
    Raz [M:SMW4]
    PARAM(7) = num$(2)
    If find(GFONCTION,"FUNGBENCH","FUNDBENCH","FUNGBENCHA","FUNDBENCHA","FUNMLINK")
        GVCR   = [M:SCOK]SCONUM
        GLIN   = 1000
        GSEQ   = 0
    Endif
    FIN = 1
Endif
Return

#---------------------------------------------------------------------------#
# Action FDISPNEO affichage disponibilité instantanée de composants EO      #
# Action FDISPNOW affichage disponibilité instantanée de composants OW      #
#---------------------------------------------------------------------------#
# Cette étiquette est appelée aussi par BENCHLIB(FDISPNOW) si WIPTYP=13
###########################################################################
# ouverture
$OUVRE_FDISPNEO
Local    Char      WFCY(GLONFCY)
Local    Integer   WTYP
Local    Integer   WSTA
Local    Char      WVCR(GLONVCR)
Local    Char      WSTU(GLONUOM)
Local    Decimal   WQTYBES
Local    Decimal   WQTYDEM
Local    Decimal   WDIS
Local    Decimal   WBES, WWRK, WRATIO, WALL
Local    Integer   WRET

If clalev ([F:SCM]) <= 0 : Local File SCOMAT    [SCM] : Endif
If clalev ([F:ORD2])<= 0 : Local File ORDERS    [ORD2]: Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER [ITM] : Endif
If clalev ([F:ITV]) <= 0 : Local File ITMMVT    [ITV] : Endif

# chargement paramètres
WFCY     = PARAM(1)
WTYP     = val(PARAM(2))
WSTA     = val(PARAM(3))
WVCR     = PARAM(4)
WSTU     = PARAM(5)
WQTYBES  = val(PARAM(6))
WQTYDEM  = val(PARAM(7))
Return

########################################################################
# Cette étiquette est appelée aussi par BENCHLIB(FDISPNOW) si WIPTYP=13
$DEBUT_FDISPNEO
Gosub CHARGE_SMW2
Diszo [M:SMW2]5
Affzo [M:SMW2]
Return

#---------------------------------------------------------------------------#
# Action FDISPNEON affichage disponibilité instantanée de composants EO     #
# idem   FDISPNOWN affichage disponibilité instantanée de composants OF     #
# (sur données nomenclature)                                                #
#---------------------------------------------------------------------------#
# Cette étiquette est appelée aussi par BENCHLIB(FDISPNOWN) si WIPTYP=13
###########################################################################
# ouverture
$OUVRE_FDISPNEON
Local    Char      WFCY(GLONFCY)
Local    Char      WITM(GLONITM)
Local    Integer   WTYP
Local    Integer   WALT, WALTTYP
Local    Char      WSTU(GLONUOM)
Local    Date      WDATBES
Local    Char      WDATC(10)
Local    Decimal   WQTYDEM

Local    Decimal  WDIS
Local    Decimal  WWRK
Local    Decimal  WQTY, WAVAOFS, WQUALTI
Local    Decimal  WDIS, WQTYN, WQTYNA, WQTYB, WQTYBA, WLIEN
Local    Decimal  WBASQTY
Local    Integer  WLIKQTYCOD
Local    Decimal  WLIKQTY
Local    Integer  WQTYRND
Local    Decimal  WLSCA

Local    Integer  WRET

If clalev ([F:BOH]) <= 0 : Local File BOM    [BOM] : Endif
If clalev ([F:BOM]) <= 0 : Local File BOMD   [BOD] : Endif

# chargement paramètres
WFCY     = PARAM(1)
WTYP     = val(PARAM(2))
WITM     = PARAM(3)
WALT     = val(PARAM(4)) : WALTTYP=3 : # Nomenclature de sous-traitance
WSTU     = PARAM(5)
WDATC    = PARAM(6)
If WDATC <> ""
    If instr(1,WDATC,"/")
        WDATBES = "["+WDATC+"]"
    Else
        WDATBES = WDATC
    Endif
Endif
WQTYDEM  = val(PARAM(7))

Return

########################################################################
# Cette étiquette est appelée aussi par BENCHLIB(FDISPNOWN) si WIPTYP=13
$DEBUT_FDISPNEON
Gosub CHARGE_SMW2N
Diszo [M:SMW2]5
Affzo [M:SMW2]
Return

#---------------------------------------------------------------------------#
# Action FDISPPEO  affichage disponibilité à date des composants EO         #
# idem   FDISPPLN  affichage disponibilité à date des composants OF         #
#---------------------------------------------------------------------------#
# Cette étiquette est appelée aussi par BENCHLIB(FDISPPLN) si WIPTYP=13
###########################################################################
# ouverture
$OUVRE_FDISPPEO
Local    Char      WFCY(GLONFCY)
Local    Integer   WTYP
Local    Integer   WSTA
Local    Char      WVCR(GLONVCR)
Local    Char      WSTU(GLONUOM)
Local    Decimal   WQTYBES, WQTYDEM

Local    Char      WITM(GLONITM)
Local    Decimal   WDIS
Local    Decimal   WBES, WWRK, WRATIO
Local    Decimal   WPHY
Local    Decimal   WCTL
Local    Decimal   WREJ
Local    Decimal   WTRF
Local    Decimal   WTRA
Local    Decimal   WSTO
Local    Decimal   WALL
Local    Decimal   WRER
Local    Decimal   WWAI
Local    Decimal   WQTY, WAVAOFS, WQUALTI
Local    Decimal   WEXT, WEXT2
Local    Char      WSIG(1)
Local    Integer   STA, WRET
Local    Date      WFIRAVADAT
Local    Decimal   WFIRAVAQTY   # FQ 56283 GA 07/2009 qté 1ère disponibilité
Local    Date      WDISSTODAT   # FQ 56283 GA 07/2009 date dispo totale

Local    Date      TODAY : TODAY = date$

# chargement paramètres
WFCY     = PARAM(1)
WTYP     = val(PARAM(2))
WSTA     = val(PARAM(3))
WVCR     = PARAM(4)
WSTU     = PARAM(5)
WQTYBES  = val(PARAM(6))
WQTYDEM  = val(PARAM(7))

If clalev ([F:SCM]) <= 0 : Local File SCOMAT    [SCM] : Endif
If clalev ([F:ORD]) <= 0 : Local File ORDERS    [ORD] : Endif
If clalev ([F:ORD2])<= 0 : Local File ORDERS    [ORD2]: Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER [ITM] : Endif
If clalev ([F:ITV]) <= 0 : Local File ITMMVT    [ITV] : Endif


Return

########################################################################
# Cette étiquette est appelée aussi par BENCHLIB(FDISPPLN) si WIPTYP=13
$DEBUT_FDISPPEO
Gosub CHARGE_SMW5
# Diszo [M:SMW5]5   # FQ 56283 GA 07/2009
Affzo [M:SMW5]
Return



#---------------------------------------------------------------------------#
# Sous-programmes                                                           #
#---------------------------------------------------------------------------#

########################################################################
$CHANGE_AWI
Local Integer OK
If clalev([F:AWI])=0  : Local File AWINDOW [AWI] : Endif
Read [AWI]AWI0=BOITE
If fstat
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
    Return
Endif
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG

#If filinfo(filpath("TRT",WINPROG,"adx"),0)<0
Call EXISTE_ADX("","",WINPROG,OK) From ORDSYS
If OK < 1
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
Endif
Return

#########################################################################
#                                                                       #
# Traitements divers liés aux plans de travail - Achats sous-traitance  #
#                                                                       #
#########################################################################

#########################################################################
$CHARGE_SMW1
# traitement ordre existant
Read [ORD1]ORD0=WTYP;WWIP;WITM
If fstat : Return : Endif

# Issue 86810 GH 12/06/2018 - MWx managed by CHARGE_SMW4
# Issue 112896 - 2016-01-29 by BEEBE : When SMW1 has been called from a material requirement with subcontracting
#                                      the EOF will be searched when it has been assigned in MRP ("by order")
#If [F:ORD1]WIPTYP=6
#    If clalev ([F:ORD2])<= 0 : Local File ORDERS    [ORD2]: Endif
#    Filter [ORD2] Where [F:ORD2]VCRTYPORI=11 & [F:ORD2]VCRNUMORI=[F:ORD1]VCRNUM & [F:ORD2]ITMREF=WITM
#    For [ORD2]
#        Read [ORD1]ORD0=[F:ORD2]WIPTYP;[F:ORD2]WIPNUM;[F:ORD2]ITMREF
#        Break
#    Next
#    Filter [ORD2]
#Endif

If find([F:ORD1]WIPSTA,1,2)
    Read [SCO]SCO0=[F:ORD1]VCRNUM
    If fstat : Return : Endif
    If [F:SCO]ITMLINNBR > 1
        WNBITM = 0
        For [SCI]SCI0 Where SCONUM = [F:ORD1]VCRNUM
            # FQ 66830 GA 09/2010 ctrl des sources erreur [F:SCI]ITMTYP
            #pas de sous-produit dans les achats de sous-traitance
            #If [F:SCI]ITMTYP = 1 : WNBITM += 1 : Endif
            WNBITM += 1
        Next
    Endif
    If WNBITM > 1 : [M:SMW1]XMESS = mess(607,197,1) : Else : Raz [M:SMW1]XMESS : Endif

    Read [SCI]SCI0=[F:ORD1]VCRNUM;[F:ORD1]VCRLIN
    If fstat : Return : Endif
Endif

Raz [M:SMW1]
[M:SMW1]MODFLG = 1
[M:SMW1] = [F:ORD1]
[M:SMW1]POHFCY =WFCY
If [M:SMW1]PRHFCY=""
   [M:SMW1]PRHFCY =[F:ORD1]STOFCY     # FQ 68646 GA 11/2010
Endif
[M:SMW1]BPRNUM2=[M:SMW1]BPRNUM

[M:SMW1]XWIPTYP = mess([M:SMW1]WIPTYP,306,1)
If [M:SMW1]VCRTYPORI <> 0
    [M:SMW1]XVCRTYPORI = mess([M:SMW1]VCRTYPORI,701,1)
Endif
If [M:SMW1]WIPSTA <> 0
    [M:SMW1]XWIPSTA = mess([M:SMW1]WIPSTA,317,1)
Endif
#? If [M:SMW1]MRPMES <> 0
#?     [M:SMW1]XMRPMES = mess([M:SMW1]MRPMES,318,1)
#? Endif

# contrôle article
Local Char WITMREF(GLONITM): WITMREF=[M:SMW1]ITMREF
Gosub READ_ITM From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(483,199,1)-WITMREF : Return : Endif

# contrôle article/site
Local Char WFCY   (GLONFCY) : WFCY=[M:SMW1]PRHFCY
Gosub READ_ITF From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : Return : Endif

# FQ 74168 GA 06/2011 pour chargement de l'UA
# contrôle article/fournisseur
Local Char WBPRNUM   (GLONBPR) : WBPRNUM=[M:SMW1]BPRNUM
Gosub READ_ITP From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(23,198,1)-WITMREF-WBPRNUM : Return : Endif

[M:SMW1]STU1    = [F:ITM]STU
[M:SMW1]EXTQTY1 = [F:ORD1]RMNEXTQTY
[M:SMW1]STRDAT1 = [F:ORD1]STRDAT
[M:SMW1]ENDDAT1 = [F:ORD1]ENDDAT
[M:SMW1]BOMALT1 = [F:ORD1]BOMALT

# si EO, recherche du service associé à l'article lancé + délai sous-traitance SCOLTI
If [M:SMW1]WIPTYP = 13 & find([M:SMW1]WIPSTA,1,2)
    Gosub LEC_EOX
    [M:SMW1]SCOTRKFLG  = WSCOTRKFLG
    [M:SMW1]ALLSTA     = WALLSTA
    [M:SMW1]XSCOTRKFLG = mess([M:SMW1]SCOTRKFLG,339,1)
    [M:SMW1]XALLSTA    = mess([M:SMW1]ALLSTA,336,1)
    [M:SMW1]BPRNUM2    = [F:SCO]BPRNUM
    [M:SMW1]SCODES     = [F:SCO]SCODES    : # GH 09/01/2012 bug 78926
    [M:SMW1]PRHFCY     = [F:SCI]PRHFCY
    [M:SMW1]QTYPUU2    = [F:SCI]QTYPUU
    [M:SMW1]PUU2       = [F:SCI]PUU
    [M:SMW1]EXTQTY2    = [F:SCI]EXTQTY
    [M:SMW1]STU2       = [F:SCI]STU
    [M:SMW1]PUUSTUCOE  = [F:SCI]PUUSTUCOE
    [M:SMW1]BOMALT2    = [F:SCI]BOMALT
    [M:SMW1]ENDDAT2    = WOBJDAT
    [M:SMW1]STRDAT2    = WORDDAT
    If WSCOTRKFLG<3
      #GA recalcul délai + date de début ou réajustement date de fin
      Call CALCUL_OFS_DAT([M:SMW1]PRHFCY, [M:SMW1]EXTQTY2, WAVAOFS, WQUALTI, [M:SMW1]ENDDAT2, [M:SMW1]STRDAT2)
    Else
      Call CALCUL_DELAI([M:SMW1]EXTQTY2, WAVAOFS, WQUALTI) From SCOLIB
    Endif
    [M:SMW1]AVAOFS     = WAVAOFS
    [M:SMW1]OBJDAT     = WOBJDAT
    [M:SMW1]ELFLG      = WOBJDAT - [M:SMW1]ENDDAT2
    [M:SMW1]CPNITMREF  = WCPN
    If [F:SCI]LOT<>"" : [M:SMW1]LOT = [F:SCI]LOT : Endif
# Issue 86491 GA 01/2013
#Elsif [M:SMW1]WIPTYP = 13 & [M:SMW1]WIPSTA=3  # Cas particulier des EOS
Elsif [M:SMW1]WIPSTA=3  # Cas particulier des suggestions EOS/POS/WOS ...
    Gosub LEC_EOX
    [M:SMW1]SCOTRKFLG  = WSCOTRKFLG
    [M:SMW1]ALLSTA     = WALLSTA
    [M:SMW1]PRHFCY     = [F:ORD1]STOFCY
    [M:SMW1]BPRNUM2    = [F:ORD1]BPRNUM
    If [M:SMW1]BPRNUM2 = ""                   # Fournisseur par défaut ?
       Call FIND_BPRNUM([M:SMW1]ITMREF,[M:SMW1]BOMALT2,[M:SMW1]POHFCY,[M:SMW1]PRHFCY,[M:SMW1]BPRNUM2) From SCOLIB
    Endif
    # Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
    If dim([M:SMW1]ECCVALMAJ)>0
        [M:SMW1]ECCVALMAJ=[F:ORD1]ECCVALMAJ
        [M:SMW1]ECCVALMIN=[F:ORD1]ECCVALMIN
    Endif

    # Epic: 55934 (STLIG) default bom code (product supplier) - if possible
    [M:SMW1]BOMALT2 = 0
    Local Integer WBOMALT : WBOMALT=0
    Call FIND_BOMALT([M:SMW1]ITMREF,[M:SMW1]BPRNUM2,WBOMALT) From SCOLIB
    If (WBOMALT <> 0)
      # product ssupplier bom code <> blank
      [M:SMW1]BOMALT2 = WBOMALT
    Else
      # product supplier bom code = blank .. bom code on subcontract suggestion
      If ([F:ORD1]BOMALT <> 0 &
&         func SUBSMW1.VALBOMALT([F:ORD1]BOMALT,[M:SMW1]PRHFCY,[M:SMW1]ITMREF,[M:SMW1]STRDAT2,0) > 0)
        # subcontract suggestion bom code <> blank / is valid
        [M:SMW1]BOMALT2 = [F:ORD1]BOMALT
      Endif
    Endif

    # Issue 89383 GA 04/2013 site de réception plutôt que site d'achat
    # Issue 86491 GA 01/2013 alternative+nomenclature existantes pour la sous-traitance ?
    #Call RECH_NOM([M:SMW1]POHFCY, [M:SMW1]STRDAT1, [M:SMW1]BOMALT2,3) From BENCHLIB
    If [M:SMW1]BOMALT2=0 : # Issue 39637 GH 24/11/2017 - keep BOM code coming from suggested order if it is defined
       Call RECH_NOM([M:SMW1]PRHFCY, [M:SMW1]STRDAT1, [M:SMW1]BOMALT2,3) From BENCHLIB
    Endif

  # Quantité
    [M:SMW1]EXTQTY2    = [F:ORD1]RMNEXTQTY
    # FQ 74168 GA 06/2011 selon FQ 69609 GA 12/2010
    # => PUU lue dans [F:ITP] avec coeff saisi sur Article-Fournisseur
    # => PUU de l'article lancé
    If [F:ITP]PUU<>""
       [M:SMW1]PUU2      = [F:ITP]PUU
       [M:SMW1]PUUSTUCOE = [F:ITP]PUUSTUCOE
    Else
       [M:SMW1]PUU2      = [F:ITM]PUU
       [M:SMW1]PUUSTUCOE = [F:ITM]PUUSTUCOE
    Endif
    [M:SMW1]STU2       = [F:ITM]STU
    If [F:ITM]PUU = [F:ITM]STU
       [M:SMW1]QTYPUU2    = [M:SMW1]EXTQTY2
    Else
    # FQ 74168 GA 06/2011 sens de conversion erroné, on calcule QTYPUU2 à partir de EXTQTY2
#        # FQ 61095 revue de code FGR: paramètre inexistant [M:SMW1]PUU
#        #Call PCAL_QTY([M:SMW1]QTYPUU2,[M:SMW1]PUU,[M:SMW1]EXTQTY2,[M:SMW1]STU,
#        Call PCAL_QTY([M:SMW1]QTYPUU2,[M:SMW1]PUU2,[M:SMW1]EXTQTY2,[M:SMW1]STU2,
#&                     [M:SMW1]ITMREF,[M:SMW1]BPRNUM,1,GBIDD1)  From TRTACHQTE1
        Call PCAL_QTY([M:SMW1]EXTQTY2,[M:SMW1]STU2,[M:SMW1]QTYPUU2,[M:SMW1]PUU2,
&                     [M:SMW1]ITMREF,[M:SMW1]BPRNUM,1,GBIDD1)  From TRTACHQTE1
    Endif
    [M:SMW1]ENDDAT2    = WOBJDAT
    [M:SMW1]STRDAT2    = WORDDAT
    [M:SMW1]OBJDAT     = WOBJDAT  # FQ 77115 GA 12/2011
    If WSCOTRKFLG<3
      #GA recalcul délai + date de début ou réajustement date de fin
      Call CALCUL_OFS_DAT([M:SMW1]PRHFCY, [M:SMW1]EXTQTY2, WAVAOFS, WQUALTI, [M:SMW1]ENDDAT2, [M:SMW1]STRDAT2)
    Endif
Endif

# Issue 107498/108 - 2016-05-20 by BEEBE/ALSHE : validation product/site/PJT whether it may/can be launched
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
If func AFNC.ACTIV("PJM")
    Call VALIDPJT([M:SMW1]ITMREF,[M:SMW1]PRHFCY,[F:ITM]STDFLG,[M:SMW1]PJT,WPJTLAUNCH) From MFGLIB
Endif

Affzo [M:SMW1]

Return

#########################################################################
$LEC_EOX
WTRK       = 0
WSCOTRKFLG = 1
WALLSTA    = 1
If find([M:SMW1]WIPSTA, 1, 2)
    Read [SCO]SCO0=[M:SMW1]VCRNUM
    If fstat : Return : Endif
    WSCOTRKFLG = [F:SCO]SCOTRKFLG
    WALLSTA    = [F:SCO]ALLSTA
    WORDDAT    = [F:SCO]ORDDAT
    WOBJDAT    = [F:SCO]RETDAT
    Read [SCI]SCI0=[M:SMW1]VCRNUM;[M:SMW1]VCRLIN
    If fstat : Return : Endif
    Read [SCS]SCS0=[M:SMW1]VCRNUM;[M:SMW1]VCRLIN
    If fstat : Return : Endif
    WCPN = [F:SCS]SRVITMREF
Else
    WORDDAT    = [F:ORD1]STRDAT    # FQ 77115 GA 12/2011
    WOBJDAT    = [F:ORD1]ENDDAT
Endif
Return

#########################################################################
$CHARGE_SMW3

Raz [M:SMW3]
[M:SMW3]POHFCY  = WFCY
[M:SMW3]PRHFCY  = WFCY
[M:SMW3]ITMREF  = WITM
[M:SMW3]PLANNER = WPLANNER
[M:SMW3]PJT     = WPJT
# 05.05 30143
Case GFONCTION
   When "FUNGBENCH","FUNGBENCHA","GESPJM" : # Issue X3-3996 - 2016-09-26 by ALSHE : Initialisation of PJT number when comming from project management
         If clalev([M:MGB])        #SL Issue X3-4775 - 2016-10-03 by ALSHE : MGB not defined when comming from PJM material task line
                      [M:SMW3]ITMCAT = [M:MGB]ITMCAT
                      [M:SMW3]ITMFILTER = [M:MGB]ITMFILTER
                      # Issue 107498/18 - 2016-08-04 by ALSHE : load PJT Number
                      # Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
                      If func AFNC.ACTIV("PJM")
                          If [M:SMW3]PJT = "" : [M:SMW3]PJT = [M:MGB]PJTSTR :  Endif
                      Endif
         Endif
   When "FUNDBENCH","FUNDBENCHA" :
                      [M:SMW3]ITMCAT = [M:MGD]ITMCAT
                      [M:SMW3]ITMFILTER = [M:MGD]ITMFILTER
Endcase

# contrôle article
Local Char WITMREF(GLONITM): WITMREF=[M:SMW3]ITMREF
Gosub READ_ITM From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(483,199,1)-WITMREF : Return : Endif

# contrôle article/site
Local Char WFCY   (GLONFCY) : WFCY=[M:SMW3]PRHFCY
Gosub READ_ITF From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : Return : Endif

# peut-on proposer un fournisseur par défaut ?
Call FIND_BPRNUM ([M:SMW3]ITMREF,[M:SMW3]BOMALT2,[M:SMW3]POHFCY,[M:SMW3]PRHFCY,[M:SMW3]BPRNUM2) From SCOLIB

# Epic: 55934 (STLIG) default bom code (product supplier) - if possible
Local Integer WBOMALT : WBOMALT=0
Call FIND_BOMALT([M:SMW3]ITMREF,[M:SMW3]BPRNUM2,WBOMALT) From SCOLIB
If (WBOMALT <> 0)
  # product supplier bom code <> blank
  [M:SMW3]BOMALT2 = WBOMALT
Endif

If WQTYBES > 0
    [M:SMW3]EXTQTY2 = WQTYBES
    [M:SMW3]COVQTY  = WQTYBES
Else
    [M:SMW3]EXTQTY2 = [F:ITF]REOMINQTY
    [M:SMW3]COVQTY  = 0
Endif
# lecture article/fournisseur # Issue 79916 GA 02/2012
If [M:SMW3]BPRNUM2<>"" & [F:ITP]ITMREF <> [M:SMW3]ITMREF
    Read [ITP]ITP0=[M:SMW3]ITMREF;[M:SMW3]BPRNUM2
    If fstat : Raz [F:ITP]  : Endif
Endif
# Issue 79916 GA 02/2012 [F:ITP] en priorité
If [F:ITP]PUU<>"" & [F:ITP]PUU<>[F:ITM]PUU
  [M:SMW3]PUU2      = [F:ITP]PUU
  [M:SMW3]STU2      = [F:ITM]STU
  #[M:SMW3]PUUSTUCOE = [F:ITP]PUUSTUCOE
Else
  [M:SMW3]PUU2      = [F:ITM]PUU
  [M:SMW3]STU2      = [F:ITM]STU
  #[M:SMW3]PUUSTUCOE = [F:ITM]PUUSTUCOE
Endif

# Coefficient UA-US
# Issue 58162 11/01/2018 - same rule as in SUBSMW3.AM_BPRNAM to set the coefficient
If    [M:SMW3]PUU2=[F:ITP]PUU
      [M:SMW3]PUUSTUCOE=[F:ITP]PUUSTUCOE
Elsif [M:SMW3]PUU2=[F:ITM]PUU
      [M:SMW3]PUUSTUCOE=[F:ITM]PUUSTUCOE
Endif
# Issue 79916 GA 02/2012 - PUUSTUCOE Missing
If [M:SMW3]PUUSTUCOE=0
  Call CTLUOM([M:SMW3]ITMREF,1,[M:SMW3]BPRNUM2,[M:SMW3]PUU2,[M:SMW3]PUUSTUCOE,
&             GBIDC2,GBIDC3,GBIDI1) From STKACT
Endif

# Conversion en UA
# Issue 58162 11/01/2018 - take the upper rounding to calculate PUR qty (specially when there is a STK qty to cover)
#                          and consequently recalculate the STK qty
#Call PCAL_QTY([M:SMW3]EXTQTY2,[M:SMW3]STU2,[M:SMW3]QTYPUU2,[M:SMW3]PUU2,
#&             [M:SMW3]ITMREF,[M:SMW3]BPRNUM2,1,GBIDD1) From TRTACHQTE1
Call PCAL_QTY([M:SMW3]EXTQTY2,[M:SMW3]STU2,[M:SMW3]QTYPUU2,[M:SMW3]PUU2,
&             [M:SMW3]ITMREF,[M:SMW3]BPRNUM2,11,GBIDD1) From TRTACHQTE1
[M:SMW3]EXTQTY2 = [M:SMW3]QTYPUU2 * [M:SMW3]PUUSTUCOE
Call QTEARR([M:SMW3]EXTQTY2,[M:SMW3]STU2) From TRTDIV

# Issue number - 2015-08-04 by BEEBE : implementing versioning
If dim([M:SMW3]ECCVALMAJ)>0
    Local Integer LALT : LALT = [M:SMW3]BOMALT2

    If func ECCLIB.NBRCPN([M:SMW3]ITMREF)
        # ECC preload of major and minor version
        Raz [M:SMW3]ECCVALMAJ, ECCVALMIN, BOMALT2
        Call INIECCBOM([M:SMW3]ITMREF, [M:SMW3]PRHFCY, WDATBES, 3, [M:SMW3]ECCVALMAJ, [M:SMW3]ECCVALMIN, LALT) From MFGECCLIB
        [M:SMW3]BOMALT2 = LALT
        Affzo [M:SMW3]ECCVALMAJ, ECCVALMIN, BOMALT2
    Else
        Effzo [M:SMW3]ECCVALMAJ, ECCVALMIN
    Endif
Endif

If WDATBES = [0/0/0] : Return : Endif
[M:SMW3]ENDDAT2 = WDATBES

# Issue 89383 GA 04/2013 site de réception plutôt que site d'achat
#GA calcul délai + date de début ou date de fin
#Call CALCUL_OFS_DAT([M:SMW3]POHFCY, [M:SMW3]EXTQTY2, WAVAOFS, WQUALTI, [M:SMW3]ENDDAT2, [M:SMW3]STRDAT2)
Call CALCUL_OFS_DAT([M:SMW3]PRHFCY, [M:SMW3]EXTQTY2, WAVAOFS, WQUALTI, [M:SMW3]ENDDAT2, [M:SMW3]STRDAT2)
[M:SMW3]AVAOFS=num$(WAVAOFS)

# Issue 89383 GA 04/2013 site de réception plutôt que site d'achat
#Call RECH_NOM([M:SMW3]POHFCY, [M:SMW3]STRDAT2, [M:SMW3]BOMALT2,3) From BENCHLIB
Call RECH_NOM([M:SMW3]PRHFCY, [M:SMW3]STRDAT2, [M:SMW3]BOMALT2,3) From BENCHLIB

Affzo [M:SMW3]
Return

#########################################################################
$CHARGE_SMW4
# prise en compte SOF, TWF, MWF,POS, MTF
Read [ORD1]ORD0=WTYP;WWIP;WITM
If fstat : Return : Endif

WSTA = [F:ORD1]WIPSTA

Raz [M:SMW4]
[M:SMW4]MODFLG  = 1
[M:SMW4]WIPTYP  = 13
[M:SMW4]WIPSTA  = 1
[M:SMW4]XWIPTYP = mess([M:SMW4]WIPTYP,306,1)
[M:SMW4]POHFCY  = WFCY
[M:SMW4]PRHFCY  = WFCY
[M:SMW4]ITMREF  = WITM

# Issue 89383 GA 04/2013 site de réception plutôt que site d'achat
# Libellé MM 02.04
If [F:FCY]FCY<>[M:SMW4]PRHFCY
    Read [FCY]FCY0=[M:SMW4]PRHFCY
    If fstat : Raz [F:FCY] : Endif
Endif
If dim([M:SMW4]ZSTOFCY)>0 [M:SMW4]ZSTOFCY=[F:FCY]FCYNAM  Endif

# contrôle article
Local Char WITMREF(GLONITM): WITMREF=[M:SMW4]ITMREF
Gosub READ_ITM From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(483,199,1)-WITMREF : Return : Endif

# contrôle article/site
Local Char WFCY   (GLONFCY) : WFCY=[M:SMW4]PRHFCY
Gosub READ_ITF From ITMLIB
#If GOK=-1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : Return : Endif

[M:SMW4]VCRTYPORI = [F:ORD1]VCRTYP
[M:SMW4]VCRNUMORI = [F:ORD1]VCRNUM
[M:SMW4]VCRLINORI = [F:ORD1]VCRLIN
[M:SMW4]VCRSEQORI = [F:ORD1]VCRSEQ
[M:SMW4]XVCRTYPORI = mess([M:SMW4]VCRTYPORI,701,1)
Case [F:ORD1]WIPTYP
    When 1:   [M:SMW4]BPRNUM = [F:ORD1]BPRNUM
    When 2:   [M:SMW4]BPRNUM = [F:ORD1]BPRNUM   # Issue 84277 GA 10/2012 prise de POS
    When 8:   [M:SMW4]BPRNUM = [F:ORD1]ORIFCY
Endcase
[M:SMW4]BPRNUM2 = [M:SMW4]BPRNUM
# Issue 84572 GA 09/2012 # SOx Fournisseur par défaut
# X3-69678 - STWIL - Also get the default supplier for project demands
# Issue 86810 GH 12/06/2018 # MWx Fournisseur par défaut
If  find([F:ORD1]WIPTYP,1,6,14)
& | ([F:ORD1]WIPTYP=2 & [F:ORD1]WIPSTA=3 & [M:SMW4]BPRNUM2="" ) # Issue 84277 GA 10/2012 prise de POS
    Filter [ITP] Where ITMREF=[M:SMW4]ITMREF & DOUFLG = 1 Order By Key ITP1
    For [ITP]
      # lecture fournisseur
      Read [BPS]BPS0=[F:ITP]BPSNUM : If fstat : Raz [F:BPS] : Endif
      If [F:BPS]DOUFLG = 1
          [M:SMW4]BPRNUM2   = [F:ITP]BPSNUM
          [M:SMW4]PUU2      = [F:ITP]PUU
          [M:SMW4]PUUSTUCOE = [F:ITP]PUUSTUCOE
          [M:SMW4]BOMALT2   = [F:ITP]BOMALT
          Break
      Endif
    Next
    Filter [ITP]
Elsif [F:ORD1]WIPTYP = 7 # (si TRx, recherche fournisseur = ORIFCY)
    Filter [BPR] Where BETFCY = 2 & FCY = [F:ORD1]ORIFCY
&                Order By Key BPR2
    For [BPR]
        # lecture fournisseur
        Read [BPS]BPS0=[F:BPR]BPRNUM
        If fstat : Raz [F:BPS] : Endif
        [M:SMW4]BPRNUM2 = [F:BPR]BPRNUM
        Break
    Next
    Filter [BPR]
Endif

[M:SMW4]FMI     = [F:ORD1]FMI
[M:SMW4]PJT     = [F:ORD1]PJT
[M:SMW4]EXTQTY1 = [F:ORD1]RMNEXTQTY
[M:SMW4]STU1    = [F:ITM]STU
[M:SMW4]ENDDAT1 = [F:ORD1]ENDDAT
WOBJ            = [F:ORD1]ENDDAT
[M:SMW4]STRDAT1 = [F:ORD1]STRDAT
[M:SMW4]EXTQTY2 = [F:ORD1]RMNEXTQTY - [F:ORD1]MTOQTY - [F:ORD1]ALLQTY
# sr 04.05 demande 29846
If [M:SMW4]EXTQTY2 < 0 : [M:SMW4]EXTQTY2 = 0 : Endif

# Issue 84572 GA 09/2012
If [M:SMW4]PUUSTUCOE<>0
   [M:SMW4]QTYPUU2 = [M:SMW4]EXTQTY2 / [M:SMW4]PUUSTUCOE
   Call QTEARR([M:SMW4]QTYPUU2,[M:SMW4]PUU2) From TRTDIV
Else
   Call PCAL_QTY ([M:SMW4]EXTQTY2, [M:SMW4]STU1, [M:SMW4]QTYPUU2, [M:SMW4]PUU2,
&                 [M:SMW4]ITMREF , [M:SMW4]BPRNUM2, 1, [M:SMW4]PUUSTUCOE) From TRTACHQTE1
Endif
#

[M:SMW4]MTOQTY  = [F:ORD1]MTOQTY
[M:SMW4]STU2    = [F:ITM]STU

[M:SMW4]ENDDAT2 = [F:ORD1]ENDDAT
[M:SMW4]STRDAT2 = [F:ORD1]STRDAT # FQ 77115 GA 12/2011
WORIDAT= [M:SMW4]ENDDAT2
WORIFCY= [M:SMW4]POHFCY
WQTY   = [M:SMW4]EXTQTY2

#GA calcul délai + date de début ou date de fin
Call CALCUL_OFS_DAT([M:SMW4]PRHFCY, [M:SMW4]EXTQTY2, WAVAOFS, WQUALTI, [M:SMW4]ENDDAT2, [M:SMW4]STRDAT2)
[M:SMW4]AVAOFS=num$(WAVAOFS)

Call RECH_NOM([M:SMW4]PRHFCY, [M:SMW4]STRDAT2, [M:SMW4]BOMALT2,3) From BENCHLIB

# Issue 107498/108 - 2016-05-20 by BEEBE/ALSHE : validation product/site/PJT whether it may/can be launched
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
If func AFNC.ACTIV("PJM")
    Call VALIDPJT([M:SMW4]ITMREF,[M:SMW4]PRHFCY,[F:ITM]STDFLG,[M:SMW4]PJT,WPJTLAUNCH) From MFGLIB
Endif

#
Affzo [M:SMW4]
Return

#########################################################################
# calcul date début ordre
# [F:ITM] et [F:ITF] sont déjà ok
#########################################################################
Subprog CALCUL_OFS_DAT(LFCY, LQTY, LAVAOFS, LQUALTI, LENDDAT, LSTRDAT)
Value    Char       LFCY
Value    Decimal    LQTY
Variable Decimal    LAVAOFS
Variable Decimal    LQUALTI
Variable Date       LENDDAT
Variable Date       LSTRDAT

Local    Decimal    XOFS
Local    Integer    IOFS
Local    Decimal    XLTI
Local    Integer    ILTI
Local    Decimal    WRMD
Local    Date       WOPESTR
#
# FQ 77115 GA 12/2011 on garde les dates de l'encours si pas dépassées
If LSTRDAT >= date$
   LAVAOFS = LENDDAT - LSTRDAT
   End
Endif

Call CALCUL_DELAI(LQTY, LAVAOFS, LQUALTI) From SCOLIB

# le délai contrôle qualité n'intervient pas pour les EO
# puisque la date de fin correspond à la date de réception article sous-traité
# par contre à utiliser si on calcule cette date de réception
# en fonction d'une commande de vente: DateRcp = DateBesoinClient - LQUALTI

If LAVAOFS+LQUALTI=0 : End : Endif : # on laisse l'utilisateur saisir les dates ...

#  Calcul de la date de début de l'opération: LSTRDAT = LENDDAT - LAVAOFS
Call CALC_DAT_FCY(LENDDAT,LAVAOFS,LFCY,1,LSTRDAT) From TRTACHDAT

# si date début < date du jour, recalcul à partir du jour en aval
GMESSAGE = ""
Call CHECK_PAST(LSTRDAT, 3) From MFGLIB
If GMESSAGE <> ""
   GMESSAGE = ""
   LSTRDAT = date$
#  Calcul de la date de fin de l'opération: LENDDAT = LSTRDAT + LAVAOFS
   Call CALC_DAT_FCY(LSTRDAT,LAVAOFS,LFCY,0,LENDDAT) From TRTACHDAT
Endif
#
End

#########################################################################
$CHARGE_SMW2
[M:SMW2]MFGFCY = WFCY
[M:SMW2]MFGQTY = WQTYBES
[M:SMW2]MFGSTU = WSTU
#
nolign = 1
If !find(WSTA, 1, 2) : Goto CHARGE_SUG_SMW2 : Endif

#------------------------------------------------
$CHARGE_SCO_SMW2
For [SCM]SCM0 Where SCONUM = WVCR & MATSTA < 3 & SCOFLG<>3
    If [F:SCM]MATSTA =4 : Goto S1 : Endif
    Raz WBES, WRATIO, WDIS
    [M:SMW2]ITMREF(nolign-1) = [F:SCM]CPNITMREF
    [M:SMW2]USEQTY(nolign-1) = [F:SCM]USEQTY
    [M:SMW2]ALLQTY(nolign-1) = [F:SCM]ALLQTY
    [M:SMW2]SHTQTY(nolign-1) = [F:SCM]SHTQTY
    [M:SMW2]SCMTRKFLG(nolign-1) = [F:SCM]SCMTRKFLG : # flag suivi
    WBES = [F:SCM]RETQTY - [F:SCM]USEQTY
    If WBES < 0 : WBES = 0 : Endif
    WALL = [F:SCM]ALLQTY
    WITM = [F:SCM]CPNITMREF
    WFCY = [F:SCM]STOFCY
    Gosub CHARGE_TAB_SMW2
$S1
Next
Goto FIN_CHARGE_SMW2

#------------------------------------------------
$CHARGE_SUG_SMW2
# avant WIPTYP=6
For [ORD2]ORD0 Where VCRNUM = WVCR & WIPTYP = 3
    [M:SMW2]ITMREF(nolign-1) = [F:ORD2]ITMREF
    [M:SMW2]USEQTY(nolign-1) = [F:ORD2]CPLQTY
    [M:SMW2]ALLQTY(nolign-1) = [F:ORD2]ALLQTY
    [M:SMW2]SHTQTY(nolign-1) = [F:ORD2]SHTQTY
    [M:SMW2]SCMTRKFLG(nolign-1) = 1 : # flag suivi
    WBES = [F:ORD2]EXTQTY
    WALL = [F:ORD2]ALLQTY
    WITM = [F:ORD2]ITMREF
    WFCY = [F:ORD2]STOFCY
    Gosub CHARGE_TAB_SMW2
Next
##########################
$FIN_CHARGE_SMW2
[M:SMW2]NBLIG = nolign-1
Return

#########################################################################
$CHARGE_TAB_SMW2
Gosub LEC_ART
If WRET <> 0 : Return : Endif
[M:SMW2]STU(nolign-1)     = [F:ITM]STU
[M:SMW2]PHYSTO(nolign-1)  = [F:ITV]PHYSTO
[M:SMW2]CTLSTO(nolign-1)  = [F:ITV]CTLSTO
[M:SMW2]RERSTO(nolign-1)  = [F:ITV]GLOALL
[M:SMW2]ALLSTO(nolign-1)  = [F:ITV]PHYALL    + [F:ITV]CTLALL     + [F:ITV]REJALL
[M:SMW2]ORDSTO(nolign-1)  = [F:ITV]ORDSTO
[M:SMW2]WAISTO(nolign-1)  = [F:ITV]WAISTO
# recherche stock disponible
# 22443 05.04 MM : Point d'entrée pour choisir la formule de calcul du stock dispo
GPE = 0
GPOINT="CAL_STODIS" : Gosub ENTREE From EXEFNC
If !GPE
    #--- Issue 115110 : Added LECCVAL parameter in 10th position
    Call STODISALL(WFCY,WITM,10,1,2,1,2,"","","",WDIS,WRET) From STKALL
Endif
[M:SMW2]DISSTO(nolign-1)  = WDIS - [F:ITV]WAISTO

If WBES <> 0
    WRATIO                    = WBES / WQTYBES
    [M:SMW2]RETQTY(nolign-1)  = (WQTYDEM * WRATIO)
Else
    [M:SMW2]RETQTY(nolign-1)  = 0
Endif
[M:SMW2]DIFFSTO(nolign-1) = [M:SMW2]DISSTO(nolign-1) - [M:SMW2]RETQTY(nolign-1) + WALL
nolign += 1

Return

#########################################################################
$LEC_ART
Local Integer LRET
# lecture article
If [F:ITM]ITMREF <> WITM
    Read [ITM]ITM0=WITM
    If fstat : WRET = 1 : Return : Endif
Endif
# lecture cumuls stocks
Call LECITV2(WFCY, WITM, WRET) From MFGLIB

Return

#########################################################################
$CHARGE_SMW2N
Local Integer WSCATIA

[M:SMW2]MFGFCY = WFCY
[M:SMW2]MFGQTY = WQTYDEM
[M:SMW2]MFGSTU = WSTU
nolign = 1

# lecture entete nomenclature
Read [BOH]BOH0=WITM;WALT;WALTTYP
If fstat : Return : Endif

WSCATIA = 0
# lecture article/site composé
If [F:ITF]ITMREF <> WITM | [F:ITF]STOFCY <> WFCY
    Read [ITF]ITF0=WITM;WFCY
    If fstat : WSCATIA = 1 : Endif
Endif
If WSCATIA = 0
    If [F:ITF]RELSCATIA <> 1 : WSCATIA = 1 : Endif
Endif

For [BOD]BOD0 Where ITMREF = WITM & BOMALT = WALT & BOMALTTYP = WALTTYP &
&                   (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WDATBES)) &
&                   (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WDATBES))
    Raz WDIS
    [M:SMW2]ITMREF(nolign-1) = [F:BOD]CPNITMREF
    [M:SMW2]USEQTY(nolign-1) = 0
    [M:SMW2]ALLQTY(nolign-1) = 0
    [M:SMW2]SHTQTY(nolign-1) = 0
    [M:SMW2]SCMTRKFLG(nolign-1) = 1 : # flag suivi

    # lecture article
    Read [ITM]ITM0=[F:BOD]CPNITMREF
    If fstat : Goto SN : Endif

    # lecture article site
    Read [ITF]ITF0=[F:BOD]CPNITMREF;WFCY
    If fstat : Goto SN : Endif

    # lecture cumuls stocks
    Call LECITV2(WFCY,[F:BOD]CPNITMREF,WRET) From MFGLIB
    # Issue 72149 - 2011-03-08 by CCC : test du code retour de LECITV2
    #If GOK <> 1 : GOK = 0 : Goto SN : Endif
    If WRET : GOK = 0 : Goto SN : Endif

    # calcul quantité
    WQTY         = WQTYDEM
    WSTU         = [F:ITM]STU
    WBASQTY      = [F:BOH]BASQTY
    WLIKQTYCOD   = [F:BOD]LIKQTYCOD
    WLIKQTY      = [F:BOD]LIKQTY
    WQTYRND      = [F:BOD]QTYRND
    WSCA         = [F:BOD]SCA

    Call LIKQTY(WQTY,WSTU,WBASQTY,WLIKQTYCOD,WLIKQTY,WQTYRND,
&               WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
    If WSCATIA
        WLIEN = WQTYBA
    Else
        WLIEN = WQTYNA
    Endif
    [M:SMW2]STU(nolign-1)     = [F:ITM]STU
    [M:SMW2]PHYSTO(nolign-1)  = [F:ITV]PHYSTO
    [M:SMW2]CTLSTO(nolign-1)  = [F:ITV]CTLSTO
    [M:SMW2]RERSTO(nolign-1)  = [F:ITV]GLOALL
    [M:SMW2]ALLSTO(nolign-1)  = [F:ITV]PHYALL    + [F:ITV]CTLALL     + [F:ITV]REJALL
    [M:SMW2]WAISTO(nolign-1)  = [F:ITV]WAISTO
    [M:SMW2]ORDSTO(nolign-1)  = [F:ITV]ORDSTO
    # recherche stock disponible
    #--- Issue 115110 : Added LECCVAL parameter in 10th position
    Call STODISALL(WFCY,[F:BOD]CPNITMREF,10,1,2,1,2,"","","",WDIS,WRET) From STKALL
    [M:SMW2]DISSTO(nolign-1)  = WDIS - [F:ITV]WAISTO

    [M:SMW2]RETQTY(nolign-1)  = WLIEN
    [M:SMW2]DIFFSTO(nolign-1) = [M:SMW2]DISSTO(nolign-1) - [M:SMW2]RETQTY(nolign-1)
    nolign += 1
$SN
Next
[M:SMW2]NBLIG = nolign-1
Return


#########################################################################
$CHARGE_SMW5
# FQ 56283 GA 07/2009
If dim([M:SMW5]VCRNUM)>0 [M:SMW5]VCRNUM = WVCR Endif
If dim([M:SMW5]CTLCOD)>0 [M:SMW5]CTLCOD = 2    Endif
If dim([M:SMW5]SUGCOD)>0 [M:SMW5]SUGCOD = 2    Endif

[M:SMW5]MFGFCY = WFCY
[M:SMW5]MFGQTY = WQTYDEM
[M:SMW5]MFGSTU = WSTU

nolign = 1
If !find(WSTA, 1, 2) : Goto CHARGE_SUG_SMW5 : Endif

##########################
$CHARGE_SCO_SMW5
For [SCM]SCM0 Where SCONUM = WVCR & MATSTA < 3 & SCOFLG<>3
    Raz WBES, WRATIO, WDIS
    [M:SMW5]ITMREF   (nolign-1) = [F:SCM]CPNITMREF
    [M:SMW5]ALLQTY   (nolign-1) = [F:SCM]ALLQTY
    [M:SMW5]SHTQTY   (nolign-1) = [F:SCM]SHTQTY
    [M:SMW5]SCMTRKFLG(nolign-1) = [F:SCM]SCMTRKFLG : # flag suivi
    [M:SMW5]DLVDAT   (nolign-1) = [F:SCM]DLVDAT
    [M:SMW5]USEQTY   (nolign-1) = [F:SCM]USEQTY

    WBES = [F:SCM]RETQTY - [F:SCM]USEQTY
    If WBES < 0 : WBES = 0 : Endif

    WITM = [F:SCM]CPNITMREF
    Gosub CHARGE_TAB_SMW5
Next
Goto FIN_CHARGE_SMW5

##########################
$CHARGE_SUG_SMW5
# avant WIPTYP=6, on laisse VCRTYP=11 Suggestion
For [ORD]ORD3 Where VCRNUM = WVCR & WIPTYP = 3 & STOFCY = WFCY & VCRTYP = 11
    [M:SMW5]ITMREF(nolign-1) = [F:ORD]ITMREF
    [M:SMW5]DLVDAT(nolign-1) = [F:ORD]ENDDAT
    [M:SMW5]ALLQTY(nolign-1) = [F:ORD]ALLQTY
    [M:SMW5]SHTQTY(nolign-1) = [F:ORD]SHTQTY
    [M:SMW5]SCMTRKFLG(nolign-1) = 1
    WBES = [F:ORD]EXTQTY
    WITM = [F:ORD]ITMREF
    Gosub CHARGE_TAB_SMW5
Next

##########################
$FIN_CHARGE_SMW5
[M:SMW5]NBLIG = nolign-1
Return

#########################################################################
$CHARGE_TAB_SMW5
Gosub LEC_ART
If WRET <> 0 : Return : Endif
[M:SMW5]STU(nolign-1)     = [F:ITM]STU

If WBES <> 0
    WRATIO                    = WBES / WQTYBES
    [M:SMW5]RETQTY(nolign-1)  = (WQTYDEM * WRATIO)
Else
    [M:SMW5]RETQTY(nolign-1)  = 0
Endif
Gosub CHARGE_PREV5

If dim([M:SMW5]DISSTODAT)>0        # FQ 56283 GA 07/2009 date dispo totale
       [M:SMW5]DISSTODAT(nolign-1) = WDISSTODAT
Endif
[M:SMW5]DISSTO(nolign-1)  = WEXT
[M:SMW5]DIFFSTO(nolign-1) = [M:SMW5]DISSTO(nolign-1) - [M:SMW5]RETQTY(nolign-1) + [M:SMW5]ALLQTY(nolign-1)
[M:SMW5]FIRAVADAT(nolign-1) = WFIRAVADAT
If dim([M:SMW5]FIRAVAQTY)>0        # FQ 56283 GA 07/2009 qté 1ère disponibilité
       [M:SMW5]FIRAVAQTY(nolign-1) = WFIRAVAQTY
Endif
nolign += 1
#
Return

#########################################################################
$RECHARGE_TAB_SMW5  # FQ 56283 GA 07/2009 recharger si param changé
Local    Decimal   WPHY, WCTL, WREJ, WTRF, WTRA, WSTO, WALL, WRER, WWAI, WQTY
Local    Decimal   WEXT, WEXT2
Local    Char      WSIG(1),WFCY(GLONFCY) : WFCY=[M:SMW5]MFGFCY
Local    Integer   WRET, NOL
Local    Date      WFIRAVADAT
Local    Decimal   WFIRAVAQTY   # FQ 56283 GA 07/2009 qté 1ère disponibilité
Local    Date      WDISSTODAT   # FQ 56283 GA 07/2009 date dispo totale
Local    Date      TODAY : TODAY = date$

nolign = 1
For NOL=0 To [M:SMW5]NBLIG-1

    Gosub CHARGE_PREV5
    If !WRET
        [M:SMW5]DISSTO(nolign-1)  = WEXT
        If dim([M:SMW5]DISSTODAT)>0        # FQ 56283 GA 07/2009 date dispo totale
               [M:SMW5]DISSTODAT(nolign-1) = WDISSTODAT
        Endif
        [M:SMW5]DIFFSTO(nolign-1) = [M:SMW5]DISSTO(nolign-1) - [M:SMW5]RETQTY(nolign-1) + [M:SMW5]ALLQTY(nolign-1)
        [M:SMW5]FIRAVADAT(nolign-1) = WFIRAVADAT
        If dim([M:SMW5]FIRAVAQTY)>0        # FQ 56283 GA 07/2009 qté 1ère disponibilité
               [M:SMW5]FIRAVAQTY(nolign-1) = WFIRAVAQTY
        Endif
        nolign+=1
    Endif
Next
Affzo [M:SMW5]
Return
##########################
$CHARGE_PREV5
Local    Char      WITMREF(GLONITM) : WITMREF=[M:SMW5]ITMREF(nolign-1)
Local    Date      WRETDAT          : WRETDAT=[M:SMW5]DLVDAT(nolign-1)   # FQ 60087 avant RETDAT
Local    Char      WSTU(GLONUOM)    : WSTU   =[M:SMW5]STU(nolign-1)

Raz WPHY, WCTL,WREJ,WTRF,WTRA,WALL,WRER,WWAI
Raz WEXT, WEXT2
Call LECITV2(WFCY, [M:SMW5]ITMREF(nolign-1), WRET) From MFGLIB
If WRET <> 0 : Return : Endif

WPHY += [F:ITV]PHYSTO
WCTL += [F:ITV]CTLSTO    # FQ 56283 GA 07/2009 manquant dans les versions précédentes
WREJ += [F:ITV]REJSTO
WTRF += [F:ITV]TRFSTO
WTRA += [F:ITV]TRASTO
WALL += [F:ITV]PHYALL    + [F:ITV]CTLALL     + [F:ITV]REJALL
WRER += [F:ITV]GLOALL
WWAI += [F:ITV]WAISTO

If WPHY <> 0
  WSTO = WPHY
  WSIG = "+"
  Gosub LOA_INI
Endif

# FQ 56283 GA 07/2009 inclure stock sous ctrl
If WCTL <> 0 & [M:SMW5]CTLCOD=2
  WSTO = WCTL
  WSIG = "+"
  Gosub LOA_INI
Endif

If WTRF <> 0
  WSTO = WTRF
  WSIG = "+"
  Gosub LOA_INI
Endif

If WALL <> 0
  WSTO = WALL
  WSIG = "-"
  Gosub LOA_INI
Endif

If WRER <> 0
  WSTO = WRER
  WSIG = "-"
  Gosub LOA_INI
Endif

If WWAI <> 0
  WSTO = WWAI
  WSIG = "-"
  Gosub LOA_INI
Endif

# mm 04.07 demande 41102 Critere zone de filtres supplémentaires demande 41102
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
Local    Char      CUSFLT(255) : Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif    # mm 04.07 demande 41102

Filter [ORD2] Where STOFCY = WFCY     &
&                   ITMREF = WITMREF  &
&                   evalue(CUSFLT)
&                   Order By Key ORD1

WFIRAVADAT = [0/0/0]
Raz WFIRAVAQTY        # FQ 56283 GA 07/2009
WDISSTODAT = [0/0/0]  # FQ 56283 GA 07/2009

For [ORD2]
    If [F:ORD2]WIPTYP = 1 & [F:ORD2]WIPSTA = 3 : Goto SPREV : Endif
    #If find ([F:ORD2]WIPTYP,1,3,4,6,8)
    If (func CBNLIB.ISDEM([F:ORD2]WIPTYP))
        WSIG = "-"
    Else
        WSIG = "+"
    Endif
    # V6 qté affectée
    WQTY = ([F:ORD2]RMNEXTQTY - [F:ORD2]ALLQTY - [F:ORD2]MTOQTY)
    Case WSIG
        When "-":     If [F:ORD2]ENDDAT < [M:SMW5]DLVDAT(nolign-1)
                          WEXT  -= WQTY
                          WEXT2 -= WQTY
                      Else
                          WEXT2 -= WQTY
                      Endif
        When "+":     If [F:ORD2]ENDDAT < [M:SMW5]DLVDAT(nolign-1)
                          WEXT  += WQTY
                          WEXT2 += WQTY
                      Else
                          WEXT2 += WQTY
                      Endif
    Endcase
    If WFIRAVADAT = [0/0/0]
        If WEXT2 > 0
           WFIRAVADAT = [F:ORD2]ENDDAT
           WFIRAVAQTY = WQTY     # FQ 56283 GA 07/2009
        Endif
    Endif
    If WFIRAVADAT <> [0/0/0] & WFIRAVADAT < TODAY & [F:ORD2]ENDDAT < TODAY
        If WEXT2 <= 0
           WFIRAVADAT = [0/0/0]
           Raz WFIRAVAQTY        # FQ 56283 GA 07/2009
        Endif
    Endif
$SPREV
Next
If WFIRAVADAT <> [0/0/0] & WFIRAVADAT < TODAY : WFIRAVADAT = TODAY : Endif
Filter [ORD2]
Return

############################################################
$LOA_INI
Case WSIG
    When "-": WEXT  -= WSTO
              WEXT2 -= WSTO
    When "+": WEXT  += WSTO
              WEXT2 += WSTO
Endcase
Return

###########################################################
Subprog HAB_ACT(LFCY, LOPT, LRET)
Value     Char     LFCY
Value     Char     LOPT
Variable  Integer  LRET

LRET = 1
# Ctrl autorisation bouton allocation manuelle
GBIDC2=LOPT : GFCY=LFCY : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2 : LRET = 0  : Endif

End
########################################################################
# vérif encours
$CHECK_WIP
Call CHECK_WIP([M:SCOK]WIPTYP, [M:SCOK]ITMREF, [M:SCOK]WIPNUM, [M:SCOK]PRVQTY, C_QTY, WRET) From MFGLIB
If !WRET : Return : Endif

If [F:ITM]ITMREF  <> [M:SCOK]ITMREF
    Read [ITM]ITM0=[M:SCOK]ITMREF
    If fstat : Raz [F:ITM] : Endif
Endif
If find([M:SCOK]WIPTYP,2,13)
    GMESSAGE  = mess(220,193,1)
Else
    GMESSAGE  = mess(222,193,1)
Endif
GMESSAGE -= "("+num$(C_QTY)-[F:ITM]STU+")"+"\"+mess(221,193,1)

Return

