#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBRLT","FRELMT940",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "OUVRE_BATCH" : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$INIT
If clalev([F:RLT])=0  : Local File RELMT940     [RLT] : Endif : # Table de travail en-tête
If clalev([F:RLD])=0  : Local File RELMT940D    [RLD] : Endif : # Table de travail ligne
If clalev([F:CPY])=0  : Local File COMPANY      [CPY] : Endif : # Sociétés
If clalev([F:TCU])=0  : Local File TABCUR       [TCU] : Endif : # Devises
If clalev([F:ADI])=0  : Local File ATABDIV      [ADI] : Endif : # Tables diverses
TMP = 1
TRA = 1
Return


$INIT_DIA
Raz [M:DIA]
Local Char    DIR_FICBAN(GDIMFIC)
Local Char    MACHIN(GDIMFIC)                      : # Machine
Local Char    IRS(2)                               : # Séparateur
Local Char    OS(20)
Local Integer OK
Local Char    PARAM1(30)

Call SETPARAM(DIR_FICBAN,MACHIN,IRS,OS,OK) From PARFICBAN
If OK
 If MACHIN<>""
  [M:DIA]FILNAM = MACHIN+"@"
 Endif
 [M:DIA]FILNAM += DIR_FICBAN

 If OS="unix"
  [M:DIA]FILNAM += "/"+GDIRBQR
 Else
  [M:DIA]FILNAM += "\"+GDIRBQR
 Endif
Else
 [M:DIA]FILNAM = filpath(GDIRBQR,"","")
Endif


# Variables pour Poste Client
Local Char URL(GDIMFIC)
Local Integer STAT
Return


$SORTIE
Return


$EXEC
If [M]TYPEXP=1 : # Client
 Call SET_FICNAM([M:DIA]FILNAM,[M:DIA]FICDON,URL) From ORDSYS
 Call COPSRV([M:DIA]FILNAM,[M:DIA]FICDON,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN = 1 : TRA = 0 : Return
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN = 1 : TRA = 0 : Return
 Endif
Else
 [M:DIA]FICDON = [M:DIA]FILNAM
Endif

If !GSERVEUR
 # Importation du fichier
 Call OUVRE_TRACE(mess(12,120,1)-[M:DIA]FILNAM) From LECFIC
Endif

Call IMPMT940([M:DIA]FICDON) From SUBRLT2

Return


######################################################################################
## Etiquette masque RELFM940 [DIA]
######################################################################################
Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If left$([M]FILNAM ,1)="#" : [M]TYPEXP=1 Else [M]TYPEXP=2 : Endif
Call AM_TYPEXP([M]TYPEXP)
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 # Le poste client est inaccessible en batch
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Call SET_NAMCLI([M]FILNAM) From ORDSYS
 Grizo [M]FILNAM
 End
Else
 [M:DIA]FILNAM = filpath(GDIRBQR,"","")
 Actzo [M]FILNAM
Endif
End

Subprog C_FILNAM(VALEUR)
Variable Char    VALEUR()
Local Char NOMFIC(80)
[L]NOMFIC = VALEUR
Call C_FILNAM([L]NOMFIC) From SUBRBK
End
End
