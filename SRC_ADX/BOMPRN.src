#<AdxTL>@(#)12.0.0.0 $Revision$
###############################################################################
# Préparation à l'impression des nomenclatures
# alimentation du fichier BOMPRN
# Sélection pour impression nomenclatures
###############################################################################
$ACTION
Case ACTION
    When "INIT":        Gosub INIT
    When "CONTROLE":    Gosub CONTROLE
    When "EXEC":        Gosub EXEC
    When "TERMINE":     SAI = 1
    When "SORTIE":
    When "DEBUT":       Gosub DEBUT
    When "SUP":         Gosub EFFACE : SAI=1
    When "END":         PARAM(1) = "END"
Endcase
Return

###############################################################################
$INIT
Local    Integer TOK , OK
Local    Integer WREP
Local    Char TBPAR(10)(1..50)
Local    Char TBVAL(10)(1..50)

If clalev([F:TBO]) = 0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:ITB]) = 0 : Local File ITMBOM     [ITB] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITM1])= 0 : Local File ITMMASTER  [ITM1]: Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD       [BOD] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev([F:BOH1])= 0 : Local File BOM        [BOH1]: Endif
If clalev ([F:TFO])= 0 : Local File TABFOR     [TFO] : Endif

Local File BOMPRN [BOP]
Local Mask BOP0   [BOP0]
Return

###############################################################################
$DEBUT
Raz [M]
[M]DATREF = date$
Affzo [M:BOP0]
Return

###############################################################################
$CONTROLE
If PARAM(1) = "END"
    FIN = 1
Else
    Gosub EFFACE
Endif
Return

###############################################################################
$EXEC
# effacement des anciens enregistrements
# enreg du User antérieurs à aujourd'hui

Trbegin [BOP]
Delete [BOP] Where CREUSR = GUSER & CREDAT < date$
If fstat = 1 | fstat > 5
    Rollback
    Call MESSAGE(mess(155,197,1)) From GESECRAN
    Return
Else
    Commit
Endif

Call TEMPON("") From GESECRAN

Call FILTDERMUL(OK)
Call TEMPOFF From GESECRAN

If OK
     Call ETAT("BOMPRN",GFONCTION,TBPAR,TBVAL) From ETAT
Endif
Return

###################################################################################
$FILTRE

Default Mask [BOP0]

Raz XCRITERE
Raz XCRITERE1
Raz XCRITERE2

XCRITERE1 = "1=1"

If [M]ITMREFDEB <> ""
    XCRITERE = "[F:BOH]ITMREF >= [M]ITMREFDEB"
    Gosub LOAD_CRITERE
Endif

If [M]ITMREFFIN <> ""
    XCRITERE = "[F:BOH]ITMREF <= [M]ITMREFFIN"
    Gosub LOAD_CRITERE
Endif

If ([M]ALTTYPDEB <> 1 | [M]ALTTYPFIN <> 3)
    XCRITERE = "[F:BOH]BOMALTTYP >= [M]ALTTYPDEB & [F:BOH]BOMALTTYP <= [M]ALTTYPFIN"
    Gosub LOAD_CRITERE
Endif

If ([M]ALTDEB <> 0 | [M]ALTFIN <> 0)
    XCRITERE = "[F:BOH]BOMALT >= [M]ALTDEB & [F:BOH]BOMALT <= [M]ALTFIN"
    Gosub LOAD_CRITERE
Endif
Return


############################################################
$LOAD_CRITERE
If len(XCRITERE)+len(XCRITERE1)+1 < 250
  If XCRITERE1 <> ""
      XCRITERE1 += "&"
  Endif
  XCRITERE1 += XCRITERE
Else
  If XCRITERE2 <> ""
     XCRITERE2 += "&"
  Endif
  XCRITERE2 += XCRITERE
Endif
Return

###############################################################################
# Sous-pro filtrant BOD selon les sélections
###############################################################################
Subprog FILTDERMUL(OK)
Variable Integer OK
Local    Char    XCRITERE(255)
Local    Char    XCRITERE1(255)
Local    Char    XCRITERE2(255)
Local    Char    FORMULE1(255)
Local    Integer CURR_ALT
Local    Integer CURR_ALTTYP, IALT, IITM
Local    Char    CURR_ITMREF(GLONITM)
Local    Integer  FLGBOD
Local    Char    SAVFCY(GLONFCY)
Global Integer GINIV, GORD
Global Decimal GQTY, GBASQTY

If clalev([F:BOH]) = 0 : Local File BOM [BOH] : Endif
Gosub FILTRE
If XCRITERE2 = "" : XCRITERE2 = "1=1" : Endif

# FQ61561 - MABON 14/01/10 - Ouverture des tables en impression de nomenclature multi-niveaux
Gosub INIT

# analyse présence formule de sélection
If [M]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=31;[M]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

If !clalev([F:BOD]) Then
 Local File BOMD [BOD]
 FLGBOD =1
Endif

# GH 12/10/12 bug 85112 : # Where BOHSTRDAT <= [M:BOP0]DATREF &  (BOHENDDAT >= [M:BOP0]DATREF | BOHENDDAT=[0/0/0]) &

Link [BOH] With [TBO]TBO0=[F:BOH]BOMALTTYP;[F:BOH]BOMALT,[ITM]ITM0=[F:BOH]ITMREF  As [BODX]
&          Where (BOHSTRDAT <= [M:BOP0]DATREF | [M:BOP0]DATREF=[0/0/0]) &  (BOHENDDAT >= [M:BOP0]DATREF | BOHENDDAT=[0/0/0]) &
&               evalue(XCRITERE1) & evalue(XCRITERE2) & evalue(FORMULE1)

OK = 1
CURR_ALTTYP = 0
CURR_ALT    = 0
CURR_ITMREF = ""
SAVFCY      = [M:BOP0]STOFCY
For [BODX]
    If [F:TBO]FCY<>"" : [M:BOP0]STOFCY=[F:TBO]FCY : Else [M:BOP0]STOFCY=SAVFCY : Endif :  ## GH 07/03/2013 bug 88522
    IALT = 0
    IITM = 0
    If (CURR_ALTTYP = 0 | [F:TBO]BOMALTTYP <> CURR_ALTTYP)
        CURR_ALTTYP = [F:TBO]BOMALTTYP
        IALT = 1
    Endif
    If (CURR_ALT = 0 | [F:TBO]BOMALT <> CURR_ALT)
        CURR_ALT = [F:TBO]BOMALT
        IALT = 1
    Endif
    If (CURR_ITMREF = "" | [F:ITM]ITMREF <> CURR_ITMREF)
        CURR_ITMREF = [F:ITM]ITMREF
        IITM = 1
    Endif
    If IALT
        Call CTLVISALT([F:TBO]BOMALT,[F:TBO]BOMALTTYP) From TRTBOM # vérification des droits
        If mkstat : Goto NXT_BODX : Endif
    Endif
    If (IALT | IITM)
        Gosub HEADER
        If OK = 0 : Break : Endif
    Endif

    If [M]TRT < 2
        Call TRAITPREM(OK)
    Else
        GQTY = GBASQTY # pour avoir les qtés sur la référence du composé le + haut (11/12/01)
        Call TRAITMUL([F:ITM]ITMREF,[F:TBO]BOMALT,[F:TBO]BOMALTTYP,OK)
    Endif
    # If OK = 0 : Break 2 : Endif : # GH 03/10/12 bug 84801
    If OK = 0 : Break : Endif

    GORD = 0
$NXT_BODX
Next
[M:BOP0]STOFCY = SAVFCY

If FLGBOD : Close File [BOD] : Endif

Raz GINIV, GORD, GQTY, GBASQTY
End


###############################################################################
# Sous-pro pour impression premier niveau
###############################################################################

Subprog TRAITPREM(OK)
Variable Integer OK
Local    Integer I
Local    Char    CRITERE(250)

# FQ 71593 GA 02/2011 manque le filtre BOMALTTYP
# GA 11/2006 sauf les composants "Service" des nomenclatures de sous-traitance CPNTYP=7
#CRITERE = "ITMREF = [F:ITM]ITMREF & BOMALT = [F:TBO]BOMALT & CPNTYP<7 "
# GH 17/09/2013 bug 92595
#CRITERE = "ITMREF = [F:ITM]ITMREF & BOMALT = [F:TBO]BOMALT & BOMALTTYP = [F:TBO]BOMALTTYP & CPNTYP<7 "
CRITERE = "ITMREF = [F:ITM]ITMREF & BOMALT = [F:TBO]BOMALT & BOMALTTYP = [F:TBO]BOMALTTYP"
If [M]DATREF <> [0/0/0]
    CRITERE -= "& BOMSTRDAT <= [M]DATREF"
    CRITERE -= "& (BOMENDDAT >= [M]DATREF | BOMENDDAT = [0/0/0])"
Endif

GOK=1 : OK=1
Trbegin [BOP]
For [BOD] Where evalue(CRITERE)
    Raz [F:BOP]
    I += 1
    [F:BOP]LIG    = I
    [F:BOP]NIV    = 1
    [F:BOP]       = [F:BOD]
    [F:BOP]STOFCY = [M:BOP0]STOFCY   # GH 05/02/2013 bug 85993
    # [F:BOP]LIKQTY = [F:BOD]LIKQTY * (1 + [F:BOD]SCA/100) : # GH 09/11/2011 bug 77219
    [F:BOP]LIKQTY = [F:BOD]LIKQTY
    [F:BOP]BOPUID = adxuid(1)
    [F:BOP]CREDAT = date$
    [F:BOP]CREUSR = GUSER
    [F:BOP]BASQTY    = GBASQTY   # pour entête Crystal Report

    # sr 11.04 demande 26824
    GPOINT = "BEFWRIBOP" : Gosub  ENTREE From EXEFNC

    Write [BOP]
    If fstat : GOK=0 : Call FSTA("BOP") From GLOCK : Break : Endif
Next
If GOK<1
    Rollback : OK=0
Else
    Commit
Endif
End

###############################################################################
$HEADER
GOK=1 : OK=1
Trbegin [BOP]
Raz [F:BOP]
[F:BOP]BOPUID    = adxuid(1)
[F:BOP]          = [F:BOH]
[F:BOP]STOFCY    = [M:BOP0]STOFCY   # GH 05/02/2013 bug 85993
[F:BOP]BOMSTRDAT = [F:BOH]BOHSTRDAT
[F:BOP]BOMENDDAT = [F:BOH]BOHENDDAT
[F:BOP]BASQTY    = [F:BOH]BASQTY
GBASQTY          = [F:BOH]BASQTY    # pour reporter la qté base dans tous les enreg
[F:BOP]CREUSR    = GUSER
[F:BOP]CREDAT    = date$
[F:BOP]NIV       = 0    # niveau dans l'arborescence
[F:BOP]LIG       = 0    # ordre de parcours
[F:BOP]BOMALTTYP = [F:TBO]BOMALTTYP

# sr 11.04 demande 26824
GPOINT = "BEFWRIBOP" : Gosub  ENTREE From EXEFNC

Write [BOP]
If fstat : GOK=0 : Call FSTA("BOP") From GLOCK : Rollback : OK=0 : Return : Endif
Commit
Return

###############################################################################
$ECRBOPMUL
GOK=1 : OK=1
Trbegin [BOP]
Raz [F:BOP]
[F:BOP]BOPUID    = adxuid(1)
[F:BOP]          = [F:BOD]
[F:BOP]ITMREF    = [F:ITM]ITMREF        # le composé (sommet) pour rupture
[F:BOP]STOFCY    = [M:BOP0]STOFCY       # GH 05/02/2013 bug 85993
[F:BOP]CREUSR    = GUSER
[F:BOP]CREDAT    = date$
[F:BOP]NIV       = GINIV                # niveau dans l'arborescence
[F:BOP]LIG       = GORD                 # ordre de parcours
[F:BOP]LIKQTY    = GQTY                 # quantité calculée à l'éclatement
[F:BOP]BOMALTTYP = [F:TBO]BOMALTTYP
[F:BOP]BASQTY    = GBASQTY              # pour entête Crystal Report

# sr 11.04 demande 26824
GPOINT = "BEFWRIBOP" : Gosub  ENTREE From EXEFNC

Write [BOP]
If fstat : GOK=0 : Call FSTA("BOP") From GLOCK : Rollback : OK=0 : Return : Endif
Commit
Return

###############################################################################
# Sous-pro pour l'éclatement de l'arborescence (récursif)
###############################################################################
Subprog TRAITMUL(ITM,ALT,TYP,OK)
Value Char       ITM
Value Integer    ALT
Value Integer    TYP
Variable Integer OK
Local Integer J
Local Decimal SAVQTY     # pour sauvegarder la qté calculée à chaque noeud

Local Integer WLLCTYP : WLLCTYP = func LLCLIB.LLCTYP(TYP)
Local Decimal LQTN, LQTNA, LQTB, LQTBA
Local Integer LBOMALTTYP

OK=1
If [M]DATREF = [0/0/0]
    Local File BOMD [BOD] Where ITMREF=ITM & BOMALT=ALT & BOMALTTYP = TYP
Else
    Local File BOMD [BOD] Where ITMREF=ITM & BOMALT=ALT & BOMALTTYP = TYP
&            & BOMSTRDAT <= [M]DATREF & (BOMENDDAT >= [M]DATREF | BOMENDDAT = [0/0/0])
Endif

Read [BOD]BOD0 First
If !fstat
    GINIV += 1
    J = 1                 # il existe au moins un lien
Endif

While !fstat
    SAVQTY   = GQTY : # GH 03/132/2013 bug 94890

    Read [BOH1]BOH0 = [F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
    If fstat  : Goto NW : Endif

    #SAVQTY   = GQTY : # GH 03/132/2013 bug 94890

    # 41258 Gestion des liens forfait 08.07
    # Il faut tenir compte du code quantité de lien
    # Menu local 226
    # 1 Proportionnel
    # 2 Au Forfait
    # If [F:BOD]LIKQTYCOD = 1
    #  GQTY  = GQTY * [F:BOD]LIKQTY * (1 + [F:BOD]SCA/100) / [F:BOH]BASQTY
    # Else
    #  GQTY  = [F:BOD]LIKQTY
    # Endif

    # GH 09/11/11 bug 77219
    If [F:ITM1]ITMREF <> [F:BOD]CPNITMREF
       Read [ITM1]ITM0=[F:BOD]CPNITMREF
       If fstat : Raz [F:ITM1] : Endif
    Endif

    Call LIKQTY(GQTY,[F:ITM1]STU,[F:BOH1]BASQTY,[F:BOD]LIKQTYCOD,
&              [F:BOD]LIKQTY,[F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
    If LQTNA=0 : # GH 19/12/12 Bug 85968 si la qté avec arrondi rend 0, on refait le calcul sans arrondi
       GCLE=""
       Call LIKQTY(GQTY,GCLE,[F:BOH1]BASQTY,[F:BOD]LIKQTYCOD,
&                 [F:BOD]LIKQTY,[F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
    Endif
    GQTY = LQTNA

    GORD += 1                     # séquence de parcours
    Gosub ECRBOPMUL
    If OK = 0 : Break : Endif

    Read [ITB]ITB0 = [F:BOD]CPNITMREF;[F:BOD]BOMALT;WLLCTYP
    If !fstat & [F:ITB]BOMEXIFLG = 2 & [F:BOD]CPNTYP <> 4
      If [M:BOP0]STOFCY<>""
         # GH 05/02/2013 bug 85993 prise en ompte du type de suggestion de l'article-site
         If [F:ITF]ITMREF <> [F:BOD]CPNITMREF | [F:ITF]STOFCY <> [M:BOP0]STOFCY
            Read [ITF]ITF0=[F:BOD]CPNITMREF;[M:BOP0]STOFCY
            If fstat : Raz [F:ITF] : Endif
         Endif
         Case [F:ITF]REOCOD
           When 3  : LBOMALTTYP=2                      : # Production
           When 5  : LBOMALTTYP=3                      : # Sous-traitance
           When Default : LBOMALTTYP=[F:BOD]BOMALTTYP  : # Pas de suggestion
         Endcase
         # If [F:ITM1]PHAFLG <> 2 & !find([F:ITF]REOCOD,1,3,5) : Goto NW : Endif
         GPE =  ([F:ITM1]PHAFLG <> 2 & !find([F:ITF]REOCOD,1,3,5))
         # GPE can be changed to 0 for forcing BOM drill (in case suggestion = purchase per ex.)
         # GPE can be changed to 1 for cutting short BOM drill
         GPOINT = "BOMDRL" : Gosub ENTREE From EXEFNC : # Issue 43506 GH 04/07/2017 - Complement to issue 121175 - Entry point added
         # Possibility to change LBOMALTTYP (according if production or subcontracting BOM exists per ex.)
         If GPE : Goto NW : Endif
      Else
         LBOMALTTYP=[F:BOD]BOMALTTYP
      Endif
      Call TRAITMUL([F:BOD]CPNITMREF,[F:BOD]BOMALT,LBOMALTTYP,OK)
      #Call TRAITMUL([F:BOD]CPNITMREF,[F:BOD]BOMALT,[F:BOD]BOMALTTYP,OK)
      If OK = 0 : Break : Endif
    Endif
    #GQTY = SAVQTY : # GH 03/132/2013 bug 94890
$NW
    GQTY = SAVQTY : # GH 03/132/2013 bug 94890

    Read [BOD]BOD0 Next
Wend
If J = 1 : GINIV -= 1 : Endif
End

###############################################################################
$EFFACE
Trbegin [BOP]
Delete [BOP] Where CREUSR = GUSER & BOPUID = adxuid(1)     # les enreg du User avec son n° process
If fstat = 1 | fstat > 5
    Rollback
    Call MESSAGE(mess(155,197,1)) From GESECRAN
Else
    Commit
Endif

Return

###################################
# Etiquettes des zones de sélection
###################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]ITMREFFIN = VALEUR : Endif
End

Subprog AM_ALTTYPDEB(VALEUR)
Variable Integer VALEUR
If VALEUR <> 0 : [M]ALTTYPFIN = VALEUR : Endif
End

Subprog C_ALTTYPFIN(VALEUR)
Variable Integer VALEUR
If VALEUR < [M]ALTTYPDEB : mkstat = 2 : Endif
End

Subprog AV_ALTDEB(VALEUR)
Variable Decimal VALEUR
Local Integer WALTTYP

If [M]ALTTYPDEB <= 1 & [M]ALTTYPFIN >= 1  : WALTTYP += 1 : Endif
If [M]ALTTYPDEB <= 2 & [M]ALTTYPFIN >= 2  : WALTTYP += 2 : Endif
If [M]ALTTYPDEB <= 3 & [M]ALTTYPFIN >= 3  : WALTTYP += 4 : Endif

[M]ALTTYPS = WALTTYP
End

Subprog AM_ALTDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : [M]ALTFIN = VALEUR : Endif
End

Subprog C_ALTFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]ALTDEB : mkstat = 2 : Endif
End


######################################################################################

