#<AdxTL>@(#)7.0.0.0 $Revision$
######################################################################### 
## Programme de traitement de l'onglet document O.F                    ## 
######################################################################### 
## écrit en Novembre  1998 par LLC                                     ## 
######################################################################### 
######################################################################### 
$OUVRE
Return 

######################################################################## 
$FERME 
Return 

########################################################################
$APRES_MODIF
Return 

########################################################################### 
## Action technique de définition du filtre de lecture 
$DEFLIG 
FICLIG = "MFGPRN": ABLIG = "MFP" 
Return 
 
########################################################################### 
## Lecture des lignes 
######################################################################### 
$LIENS 
Local Integer I,J
Local Integer IMAX : IMAX = dim([F:MFP]PCU)    # llc 01.02 PCU
# 09.05 
Local Integer WWRK
Local Integer WPICLIS
Local Integer WROUSHE
Local Integer WLABTIK
Local Integer WMFGTIK
Local Integer WTECCRD


#
Read [MFP]MFP0=[M:MFG0]MFGNUM
If fstat : Return : Endif
#
[M:MFG4]PICLISFLG        = [F:MFP]PICLISFLG
[M:MFG4]ROUSHEFLG        = [F:MFP]ROUSHEFLG
[M:MFG4]LABTIKFLG        = [F:MFP]LABTIKFLG
[M:MFG4]MFGTIKFLG        = [F:MFP]MFGTIKFLG
[M:MFG4]TECCRDFLG        = [F:MFP]TECCRDFLG
[M:MFG4]LBEMOD           = [F:MFP]LBEMOD
Case [M:MFG4]LBEMOD
    When 1:    [M:MFG4]LBEMAN = 2
               [M:MFG4]LBEAUT = 1
    When 2:    [M:MFG4]LBEMAN = 1
               [M:MFG4]LBEAUT = 2
Endcase
[M:MFG4]MFGFDRFLG        = [F:MFP]MFGFDRFLG
#
J=0
For I=0 TO IMAX-1
    If [F:MFP]PCU(I) <> ""
        [M:MFG4]PCU(J)      = [F:MFP]PCU(I)
        [M:MFG4]PCUNBR(J)   = [F:MFP]PCUNBR(I)
        [M:MFG4]PCUSTUCOE(J)= [F:MFP]PCUSTUCOE(I)        
        [M:MFG4]LBEFMT(J)   = [F:MFP]LBEFMT(I)        
        J+=1
    Endif
Next I
#
[M:MFG4]NBLIG = J
#
Grizo [M:MFG4]PICLISFLG 
Grizo [M:MFG4]ROUSHEFLG 
Grizo [M:MFG4]LABTIKFLG 
Grizo [M:MFG4]MFGTIKFLG 
Grizo [M:MFG4]TECCRDFLG 
Grizo [M:MFG4]LBEMAN
Grizo [M:MFG4]LBEAUT

# 09.05
Raz [M:MFG4]TOEDIT1
Raz [M:MFG4]TOEDIT2
Raz [M:MFG4]TOEDIT3
Raz [M:MFG4]TOEDIT4
Raz [M:MFG4]TOEDIT5

WWRK = [F:MFP]EXTMFGFDR
If WWRK > 15 : WTECCRD = 2 : WWRK -= 16 : Endif
If WWRK >  7 : WMFGTIK = 2 : WWRK -=  8 : Endif
If WWRK >  3 : WLABTIK = 2 : WWRK -=  4 : Endif
If WWRK >  1 : WROUSHE = 2 : WWRK -=  2 : Endif
If WWRK >  0 : WPICLIS = 2 :            : Endif

If (WPICLIS = 2 & [F:MFP]PICLISFLG <> 2) : [M:MFG4]TOEDIT1 = mess(636,197,1) : Endif
If (WROUSHE = 2 & [F:MFP]ROUSHEFLG <> 2) : [M:MFG4]TOEDIT2 = mess(636,197,1) : Endif
If (WLABTIK = 2 & [F:MFP]LABTIKFLG <> 2) : [M:MFG4]TOEDIT3 = mess(636,197,1) : Endif
If (WMFGTIK = 2 & [F:MFP]MFGTIKFLG <> 2) : [M:MFG4]TOEDIT4 = mess(636,197,1) : Endif
If (WTECCRD = 2 & [F:MFP]TECCRDFLG <> 2) : [M:MFG4]TOEDIT5 = mess(636,197,1) : Endif

Return 
 
########################################################################### 
## Modification 
######################################################################### 
$MODIF 
Local Integer I
Local Integer J 
Local Integer IMAX : IMAX = dim([F:MFP]PCU)    # llc 01.02 PCU

# 
Gosub DEFLIG  
#
ReadLock [MFP]MFP0=[M:MFG0]MFGNUM
If fstat=1 : GOK=-1 : GLOCK="$"+FICLIG : Return : Endif 
#
[F:MFP]MFGFCY           = [M:MFG0]MFGFCY
[F:MFP]PICLISFLG        = [M:MFG4]PICLISFLG
[F:MFP]ROUSHEFLG        = [M:MFG4]ROUSHEFLG
[F:MFP]LABTIKFLG        = [M:MFG4]LABTIKFLG
[F:MFP]MFGTIKFLG        = [M:MFG4]MFGTIKFLG
[F:MFP]TECCRDFLG        = [M:MFG4]TECCRDFLG
[F:MFP]LBEMOD           = [M:MFG4]LBEMOD
[F:MFP]MFGFDRFLG        = [M:MFG4]MFGFDRFLG
#
J=0
For I=0 TO IMAX-1
    If [M:MFG4]PCU(I) <> ""
        [F:MFP]PCU(J)      = [M:MFG4]PCU(I)
        [F:MFP]PCUNBR(J)   = [M:MFG4]PCUNBR(I)
        [F:MFP]PCUSTUCOE(J)= [M:MFG4]PCUSTUCOE(I)        
        [F:MFP]LBEFMT(J)   = [M:MFG4]LBEFMT(I)        
        J+=1
    Endif
Next I
#
If    fstat=0 
    [F:MFP]UPDDAT = date$
    [F:MFP]UPDUSR = GUSER
    [F:MFP]EXPNUM = [C]EXPORT
    Rewrite [MFP]  
Elsif fstat=5 
    [F:MFP]MFGNUM        = [M:MFG0]MFGNUM  
    [F:MFP]PLNFCY        = [M:MFG0]PLNFCY
    [F:MFP]MFGFCY        = [M:MFG0]MFGFCY 
    [F:MFP]CREDAT = date$
    [F:MFP]CREUSR = GUSER
    [F:MFP]EXPNUM = [C]EXPORT
    Write [MFP]  
Endif 
#
Return 
 
########################################################################### 
## Création
######################################################################### 
$CREATION    
Local Integer I 
Local Integer J : J=0 
Local Integer IMAX : IMAX = dim([F:MFP]PCU)    # llc 01.02

#
[F:MFP]MFGNUM       = [M:MFG0]MFGNUM 
[F:MFP]PLNFCY       = [M:MFG0]PLNFCY 
[F:MFP]MFGFCY       = [M:MFG0]MFGFCY
# 
[F:MFP]MFGFCY           = [M:MFG0]MFGFCY
[F:MFP]PICLISFLG        = [M:MFG4]PICLISFLG
[F:MFP]ROUSHEFLG        = [M:MFG4]ROUSHEFLG
[F:MFP]LABTIKFLG        = [M:MFG4]LABTIKFLG
[F:MFP]MFGTIKFLG        = [M:MFG4]MFGTIKFLG
[F:MFP]TECCRDFLG        = [M:MFG4]TECCRDFLG
[F:MFP]LBEMOD           = [M:MFG4]LBEMOD
[F:MFP]MFGFDRFLG        = 1
#
For I=0 TO IMAX-1
    If [M:MFG4]PCU(I) <> ""
        [F:MFP]PCU(J)      = [M:MFG4]PCU(I)
        [F:MFP]PCUNBR(J)   = [M:MFG4]PCUNBR(I)
        [F:MFP]PCUSTUCOE(J)= [M:MFG4]PCUSTUCOE(I)        
        [F:MFP]LBEFMT(J)   = [M:MFG4]LBEFMT(I)        
        J+=1
    Endif
Next I
#
[F:MFP]STRDAT = [M:MFG1]STRDAT
[F:MFP]ENDDAT = [M:MFG1]ENDDAT
[F:MFP]ROUNUM = [M:MFG1]ROUNUM
#
[F:MFP]EXTMFGFDR = 0
If [F:MTS]PICLIS = 2 : [F:MFP]EXTMFGFDR += 1  : Endif
If [F:MTS]ROUSHE = 2 : [F:MFP]EXTMFGFDR += 2  : Endif
If [F:MTS]LABTIK = 2 : [F:MFP]EXTMFGFDR += 4  : Endif
If [F:MTS]MFGTIK = 2 : [F:MFP]EXTMFGFDR += 8  : Endif
If [F:MTS]TECCRD = 2 : [F:MFP]EXTMFGFDR += 16 : Endif
#
[F:MFP]LBEMOD =  [F:MTS]LBEMOD :#Stocker l'indicateur d'impression auto ou manuel des étiquettes
[F:MFP]CREDAT = date$
[F:MFP]CREUSR = GUSER
[F:MFP]EXPNUM = [C]EXPORT
Write [MFP]  
If fstat : GOK=0 : Call FSTA("MFP") From GLOCK : Return : Endif 
#
Return 
 
###########################################################################  
## Annulation
#########################################################################  
# purge des opérations
$ANNULE    
ReadLock [MFP]MFP0=[M:MFG0]MFGNUM
If fstat=1 : GOK=-1 : GLOCK="$"+FICLIG : Return : Endif 
if !fstat : delete [MFP] : endif 
Return 

########################################################################### 
########################################################################### 
## Etiquettes de l'écran 
########################################################################### 
#########################
########################################
Subprog AS_PCU(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End

########################################
Subprog D_DEFIMP(VALEUR)
Variable Char    VALEUR()
If clalev ([F:AUS]) <= 0 : Local File AUTILIS [F:AUS] : Endif
Read [F:AUS]CODUSR = GUSER
If fstat : Raz [F:AUS] : End : Endif
#VALEUR = [F:AUS]DEFIMP
End


########################################
Subprog S_DEFIMP(VALEUR)
Variable Char    VALEUR()
Local Char    PARAM(200)(1..10)
Local Integer I
Raz PARAM
If VALEUR<>""
 PARAM(1) = "_PrinterName="+chr$(1)+VALEUR
Endif
SELIMP PARAM = "" With PARAM
For I=1 To stat1
 If left$(toupper(PARAM(I)),13)="_PRINTERNAME="
  VALEUR = right$(PARAM(I),15) : Break
 Endif
Next I
End

########################################
Subprog AV_LBEMAN(VALEUR)
Variable Integer VALEUR
If GREP <> "C" : End : Endif
If [F:MTS]LBEMOD = 1 : VALEUR = 2 : Else : VALEUR = 1 : Endif
End

########################################
Subprog AV_LBEAUT(VALEUR)
Variable Integer VALEUR
If GREP <> "C" : End : Endif
If [F:MTS]LBEMOD = 2 : VALEUR = 2 : Else : VALEUR = 1 : Endif
End

