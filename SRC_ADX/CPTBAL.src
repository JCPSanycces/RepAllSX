#<AdxTL>@(#)7.0.0.0 $Revision$
End

#####################################################################################################
## Subprog VALPCE(SIGN,TYPPCE,PIECE)        # Validation d'une pièce comptable
## Subprog BALANCE(SIGN)                    # Mise à jour de la balance générale
## Subprog BALANA(SIGN)                     # Mise à jour de la balance analytique
## Subprog BALPRECSL(SIGN.....)             # Mise à jour de la balance pré-consolidée (## YYFIN_105932_8)
## Subprog INIBLA                           # Initialisation de la balance générale (via les budgets)
######################################################################################################

Subprog VALPCE(SIGN,TYPPCE,PIECE)
Value Integer SIGN
Value Char    TYPPCE
Value Char    PIECE

If dim(GUPDBALCUM)>0 & GUPDBALCUM=1
Call VALPCE(1,TYPPCE,PIECE) From CPTBALCUM : End
Endif

If !clalev([F:GTE]) : Local File GTYPACCENT       [GTE] : Endif
If !clalev([F:HAE]) : Local File GACCENTRY        [HAE] : Endif
If !clalev([F:DAE]) : Local File GACCENTRYD       [DAE] : Endif
If !clalev([F:DAA]) : Local File GACCENTRYA       [DAA] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT         [GAC] : Endif
If !clalev([F:JST]) : Local File GAJOUSTA         [JST] : Endif
If !clalev([F:LED]) : Local File =GTABCPT+"GLED"  [LED] : Endif

## <RUS>
Local Char LSTTYPLED(10) : # Liste des types référentiels flagués 'Double Entry Method'
## <Fin dev RUS>

Read [HAE]HAE0 = TYPPCE;PIECE
If fstat=0

 Call GETSOC([F:HAE]FCY) From DEVSUB
 Call LEC_GTE_LEG(GCURLEG,TYPPCE) From CPTLEC

 ## <RUS>
 Call LEDTYPDEM([F:HAE]CPY,LSTTYPLED) From CPTDIV
 ## <Fin dev RUS>

 For [DAE]DAE0 Where TYP=TYPPCE & NUM=PIECE
  If [F:LED]LED<>[F:DAE]LED
   Read [LED]LED0 = [F:DAE]LED
   If fstat  : Raz [LED] :  Endif
  Endif

  # General balance update &
  ## YYFIN_105932_8  Pre-consolidated balance update
  If [F:LED]GEN=2
   Call BALANCE(SIGN)
   If GOK<1 : Break : Endif
  Endif

  # Analytical balance update + Connection of operational budgets if activity code GDD
  ## YYFIN_105932_8  Pré-consolidated balance update
  If [F:LED]ANA=2
   For [DAA]DAA0 Where TYP=TYPPCE & NUM=PIECE & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
    Call BALANA(SIGN)
    If GOK<1 : Break 2 : Endif
    ## <RUS> Mise à jour Balance Russe si on est sur le référentiel Russe et sur une ligne éclatée
    If instr(1,LSTTYPLED,num$([F:DAE]LEDTYP)) & [F:DAE]ACCNUMDOE = 0 : # On est sur un référentiel Russe et une ligne éclatée
     Call BALDEM(SIGN)
     If GOK<1 : Break 2 : Endif
    Endif
    ## <Fin dev RUS>
   Next # [DAA]
  Endif

 Next # [DAE]

 If GOK<1 : End : Endif
Endif
End

########################################################
Subprog BALANCE(SIGN)
Value Integer SIGN

If !clalev([F:LED]) : Local File GLED [LED] : Endif
If !clalev([F:GTE]) : Local File GTYPACCENT [GTE] : Endif

Local Integer BALTYP
Local Integer EXE, PER
Local Char    BALSOC(GLONCPY), BALFCY(GLONFCY)
Local Char    BALACC(GLONGAC), BPR(GLONBPR)
Local Char    BALCUR(GLONCUR)
Local Char    BALCSLBPR(GLONBPR)
Local Char    CSLFLO(GLONADI)
Local Char    BALTYPLIN(3)
Local Char    BALLED (GLONLED)
Local Char    BALCURLED (GLONCUR)
Local Char    BALCOA (GLONCOA)
Local Char    BALFCYLIN(GLONFCY)
Local Char    TBALDIE(GLONDIE)(0..dim([F:LED]DIE)-1)
Local Char    TBALCCE(GLONCCE)(0..dim([F:LED]DIE)-1)
Local Decimal BALAMTCUR
Local Decimal BALAMTLED
Local Integer ISITE , ISOC , ERR
Local Integer BALSNS

Local Integer CLAS

If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
 ISITE = find([F:HAE]FCY,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 BALSOC = GSOCSITE(ISITE)
 ISOC = find(BALSOC,GSOC(1..GNBSOC))
 If !ISOC : End : Endif
 BALTYP    = [F:DAE]LEDTYP
 BALACC    = [F:DAE]ACC
 BPR       = [F:DAE]BPR
 BALCUR    = [F:DAE]CUR
 BALLED    = [F:DAE]LED
 BALCURLED = [F:DAE]CURLED
 BALCOA    = [F:DAE]COA
 BALFCYLIN = [F:DAE]FCYLIN
 BALCSLBPR = [F:DAE]CSLBPR
 CSLFLO    = [F:DAE]CSLFLO
 BALTYPLIN = "DAE"
 EXE       = [F:DAE]FIY
 PER       = [F:DAE]PER
 BALAMTCUR = [F:DAE]AMTCUR
 BALAMTLED = [F:DAE]AMTLED
 BALSNS   = [F:DAE]SNS

 # General balance update
 Call BALGENE(SIGN, BALTYP, BALSOC, ISOC, BALFCYLIN, EXE, PER, BALACC, BPR,
&                   BALCUR, BALLED, BALCURLED, BALCOA, BALSNS, BALAMTCUR, BALAMTLED)
 If GOK<1 : End : Endif

 # Pre-consolidation balance update
 # Conditions:
 #  - activity code PRCSL active
 #  - ledger flagged "Consolidation"
 #  - Journal entry category ="Actual"
 If func AFNC.ACTIV("PRCSL")
  Call LEC_GTE_LEG(GCURLEG,[F:HAE]TYP) From CPTLEC
  Call LEC_LED([F:DAE]LED) From CPTLEC
  If [F:LED]CSL=2 and [F:GTE]PER=1
   Raz TBALDIE, TBALCCE

   Call BALPRECSL(SIGN, BALTYPLIN, BALTYP, BALSOC, ISOC, BALFCYLIN, EXE, PER, BALACC,
&               BPR, CSLFLO, BALCSLBPR,
&               TBALDIE, TBALCCE,
&               BALCUR, BALLED, BALCURLED, BALCOA, BALSNS, BALAMTCUR, BALAMTLED)

   If GOK<1 : End : Endif

  Endif
 Endif
Endif

 # Updating of accounting balances only for the Main General ledger
If BPR<>""
  Call SETMAINREF(BALSOC,GTYPGEN,GTYPANA) From CPTDIV
  If BALTYP=GTYPGEN
    Gosub SOLDE : # Maj solde comptable
  Endif
Endif

End

#########################################
##  Updating General balance : BALANCE
#**
#*Balance générale
#*
#* @param SIGN         : Sign
#* @param BALTYP       : Ledger type (LEDTYP)
#* @param BALSOC       : Company
#* @param ISOC         : Company index
#* @param BALFCYLIN    : Site of the line
#* @param EXE          : Fiscal year
#* @param PER          : Period
#* @param BALACC       : Account
#* @param BPR          : Business Partner
#* @param BALCUR       : Line currency
#* @param BALLED       : Ledger
#* @param BALCURLED    : Ledger currency
#* @param BALCOA       : Chart code
#* @param BALSNS       : Line sign
#* @param BALAMTCUR    : Entry amount
#* @param BALAMTLED    : Ledger amount
#*!
Subprog BALGENE (SIGN, BALTYP, BALSOC, ISOC, BALFCYLIN, EXE, PER, ACC, BPR,
&                      BALCUR, BALLED, BALCURLED, BALCOA, BALSNS, BALAMTCUR, BALAMTLED)
Value Integer SIGN
Value Integer BALTYP
Value Char    BALSOC
Value Integer ISOC
Value Char    BALFCYLIN
Value Integer EXE
Value Integer PER
Value Char    ACC
Value Char    BPR
Value Char    BALCUR
Value Char    BALLED
Value Char    BALCURLED
Value Char    BALCOA
Value Integer BALSNS
Value Decimal BALAMTCUR
Value Decimal BALAMTLED

Local Char    BALFCY(GLONFCY)
Local Integer BALEXE
Local Integer BALPER
Local Char    BALBPR(GLONBPR)
Local Char    BALACC(GLONGAC)
Local Integer BALREP

BALEXE=EXE
BALPER=PER
BALBPR=BPR
BALFCY=BALFCYLIN
BALACC=ACC
BALREP=0

 Gosub BALCPT : # Balance compte+tiers
 If GOK<1 : End : Endif
 If BALBPR <> ""
  BALBPR = ""
  Gosub BALCPT : # Balance du collectif
  If GOK<1 : End : Endif
 Endif

 # (BY) Report à nouveau en temps réel... GEXEAN à désormais 2 indices
 ## <YYFIN 105753>
 If dim(GEXEAN)<0 : Call EXEAN From GLOBCPT : Endif
 ## <End YYFIN 105753>
 If GRAN=2 & GEXEAN(ISOC,BALTYP)=BALEXE
  BALREP = 1
  BALEXE += 1
  BALPER = 0
  BALBPR = BPR
  Gosub RAN_GEN
  If GOK<1 : End : Endif
  If RESULT
   Gosub BALCPT : # Report à nouveau compte
   If GOK<1 : End : Endif
   If BALBPR<>""
    BALBPR = ""
    Gosub BALCPT : # Report à nouveau collectif
    If GOK<1 : End : Endif
   Endif
  Endif
 Endif

End

#############
$BALCPT

# MAJ Société
 BALFCY = ""
 Gosub MAJBAL
 If GOK<1 : Return : Endif
# MAJ Site
 BALFCY = BALFCYLIN
 Gosub MAJBAL
 If GOK<1 : Return : Endif

Return
#########################################
## Compte de report à nouveau
#########################################
$RAN_GEN
Local Integer RESULT , IGCM , ILED , EQUILIBRE
Local Integer ERR
Local Char    REFER(GLONLED) , CLAS(GLONCLA)
IGCM  = find(GGCMSOC(ISOC),GGCM(1..GGCMNBR))
REFER = evalue("GLED"+num$(BALTYP)+"("+num$(IGCM)+")")
ILED  = find(REFER,GLED(1..GLEDNBR))
If !ILED : End : Endif
EQUILIBRE = (GLEDEQLRAN(ILED)=2)
RESULT = 0
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:COA])=0 : Local File GCOA     [COA] : Endif
If clalev([F:CLS])=0 : Local File GACCCLS  [CLS] : Endif
 Call LEC_GAC(BALACC,BALCOA) From CPTLEC
If !fstat
 CLAS = [F:GAC]CLSCOD
 Call LEC_COA(BALCOA) From CPTLEC
 Call LEC_CLS([F:COA]LEGCLS,CLAS) From CPTLEC
 If [F:CLS]ERA<>2 : # Classe remise à zéro => compte de résultat
  If EQUILIBRE
   If [F:COA]ACCMIS(10)=""
    GOK = 0 : Call ERREURT(mess(106,106,1)-"("+BALCOA+")",ERR) From GESECRAN : Return
    # Compte de résultat non défini
   Endif
   BALACC = [F:COA]ACCMIS(10)
   BALBPR = ""
   RESULT = 2
  Else
   RESULT = 0
  Endif
 Else  # Classe de compte à reporter
  RESULT = 1
 Endif
Endif
Return
#############
$MAJBAL
# Updating General Balance [BAL]
Readlock [BAL]BAL0 = BALTYP;BALSOC;BALFCY;BALEXE;BALACC;BALBPR;BALCUR
If fstat=1
 GOK = -1 : GLOCK = "$BALANCE"-num$(BALTYP)-BALSOC-BALFCY-num$(BALEXE)-BALACC-BALBPR-BALCUR : Return
Elsif fstat
 Raz [F:BAL]
 [F:BAL]LEDTYP = BALTYP
 [F:BAL]CPY    = BALSOC
 [F:BAL]FCY    = BALFCY
 [F:BAL]FIY    = BALEXE
 [F:BAL]ACC    = BALACC
 [F:BAL]BPR    = BALBPR
 [F:BAL]CUR    = BALCUR
 [F:BAL]ACCNUM = uniqid([F:BAL])
 [F:BAL]ACCNUM = uniqid([F:BAL])
 [F:BAL]LED    = BALLED
 [F:BAL]COA    = BALCOA
 [F:BAL]CURLED = BALCURLED
 Gosub CALBAL
 Write [BAL]
Else
 Gosub CALBAL
 Rewrite [BAL]
Endif
If fstat
 GOK=0 : Call FSTA("BAL") From GLOCK : Return
Endif
Return

#############
$CALBAL
If BALSNS=1
 [F:BAL]DEB(BALPER)    += SIGN*BALAMTCUR
 [F:BAL]DEBLED(BALPER) += SIGN*BALAMTLED
Else
 [F:BAL]CDT(BALPER)    += SIGN*BALAMTCUR
 [F:BAL]CDTLED(BALPER) += SIGN*BALAMTLED
Endif

If BALREP
 If [F:BAL]DEB(BALPER)>[F:BAL]CDT(BALPER)
  [F:BAL]DEB(BALPER) = [F:BAL]DEB(BALPER) - [F:BAL]CDT(BALPER)
  [F:BAL]CDT(BALPER) = 0
 Else
  [F:BAL]CDT(BALPER) = [F:BAL]CDT(BALPER) - [F:BAL]DEB(BALPER)
  [F:BAL]DEB(BALPER) = 0
 Endif
 If [F:BAL]DEBLED(BALPER)>[F:BAL]CDTLED(BALPER)
  [F:BAL]DEBLED(BALPER) = [F:BAL]DEBLED(BALPER) - [F:BAL]CDTLED(BALPER)
  [F:BAL]CDTLED(BALPER) = 0
 Else
  [F:BAL]CDTLED(BALPER) = [F:BAL]CDTLED(BALPER) - [F:BAL]DEBLED(BALPER)
  [F:BAL]DEBLED(BALPER) = 0
 Endif
Endif
GPOINT = "MAJ" : Gosub ENTREE From EXEFNC
Return


#############
$SOLDE
# Aucune mise à jour des soldes pour les mouvements clients et fournisseurs pour :
#    - pièces d'à-nouveau
#    - pièces de clôtures
If [F:HAE]FLGREP=2 & PER=0  : # à-nouveau
 Return
Elsif PER<>0   : # clôture
 If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
 Call GETSOC([F:HAE]FCY) From DEVSUB
 Call LEC_GTE_LEG(GCURLEG,[F:HAE]TYP) From CPTLEC
 If [F:GTE]PER=3 : Return : Endif
Endif
#
Call LEC_GAC(BALACC,BALCOA) From CPTLEC
If !fstat & [F:GAC]UPDBLC>1
 Local Decimal WBLCAMT  : # Montant en devise de transaction
 Local Decimal WBLCAMT1 : # Montant en devise de référentiel (possibilité d'un montant forcé)
 Local Char WSNS(1)
 Case [F:GAC]UPDBLC
  When 2 : # Solde client
   WBLCAMT  = BALSNS*BALAMTCUR : # Solde positif débiteur ?
   WBLCAMT1 = BALSNS*BALAMTLED
   If SIGN=-1 : WSNS="-" Else WSNS="+" : Endif
   Call MAJMVC(BPR,[F:HAE]CUR,[F:HAE]TYPRAT,0,[F:HAE]RATDAT,
&              [F:HAE]NUM,BALFCYLIN,WBLCAMT1,WBLCAMT,WSNS,"S","",0) From TRTBPMVT

  When 3 : # Solde fournisseur
   WBLCAMT  = -SIGN*BALSNS*BALAMTCUR : # Solde positif créditeur ?
   WBLCAMT1 = -SIGN*BALSNS*BALAMTLED
   Call MAJENC_BPS(BPR,0,BALFCYLIN,[F:HAE]CUR,[F:HAE]TYPRAT,[F:HAE]RATDAT,
&                  [F:HAE]NUM,WBLCAMT1,WBLCAMT,BALAMTCUR) From TRTBPMVT
  Endcase
Endif
Return
###################################################
Subprog BALANA(SIGN)
Value Integer SIGN

If !clalev([F:LED]) : Local File GLED [LED] : Endif

Local Integer CC , AXE
Local Integer BALSNS
Local Integer ISITE , ISOC , RANA , ERR
Local Integer I , J , K

Local Integer BALTYP
Local Integer EXE, PER
Local Char    BALSOC(GLONCPY), BALFCY(GLONFCY)
Local Char    BALCOA(GLONCOA), BALACC(GLONGAC)
Local Char    BALCUR(GLONCUR)
Local Char    BPR(GLONBPR)

Local Char    BALSEC1(GLONCCE) , BALSEC2(GLONCCE) , BALSEC3(GLONCCE)
Local Char    BALSEC4(GLONCCE) , BALSEC5(GLONCCE) , BALSEC6(GLONCCE)
Local Char    BALSEC7(GLONCCE) , BALSEC8(GLONCCE) , BALSEC9(GLONCCE)
Local Char    BALCSLBPR(GLONBPR)
Local Char    CSLFLO(GLONADI)
Local Char    BALTYPLIN(3)
Local Char    BALLED (GLONLED)
Local Char    BALCURLED (GLONCUR)
Local Char    BALFCYLIN(GLONFCY)
Local Char    TBALDIE(GLONDIE)(0..dim([F:LED]DIE)-1)
Local Char    TBALCCE(GLONCCE)(0..dim([F:LED]DIE)-1)
Local Decimal BALAMTCUR
Local Decimal BALAMTLED
Local Decimal BALQTY

Local Char    BUDCOD(GLONBUP)

If !clalev([F:DIE]) : Local File GDIE      [DIE] : Endif
If !clalev([F:GTE])  : Local File GTYPACCENT [GTE] : Endif #YYFIN_X3-40785_Impossible to run account. interface(FAS)

If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
 Call INDLED([F:DAA]LED,"",I,J) From CPTDIV
 If sigma(0,GLEDDIENBR(I)-1,[F:DAA]CCE(indcum))<>"" | GLEDDIEIPT(I)=2
  ISITE = find([F:HAE]FCY,GSITE(1..GNBSITE))
  If !ISITE : End : Endif
  BALSOC = GSOCSITE(ISITE)
  ISOC = find(BALSOC,GSOC(1..GNBSOC))
  If !ISOC : End : Endif
  BALTYP    = [F:DAA]LEDTYP
  BALCOA    = [F:DAA]COA
  BALACC    = [F:DAA]ACC
  BALCUR    = [F:DAA]CUR
  EXE       = [F:DAE]FIY
  PER       = [F:DAE]PER
  BPR       = [F:DAA]BPR
  BALSNS    = [F:DAA]SNS
  BALFCYLIN = [F:DAA]FCYLIN
  BALLED    = [F:DAA]LED
  BALCURLED = [F:DAA]CURLED
  BALCSLBPR = [F:DAE]CSLBPR
  CSLFLO    = [F:DAE]CSLFLO
  BALTYPLIN = "DAA"
  BALAMTCUR = [F:DAA]AMTCUR
  BALAMTLED = [F:DAA]AMTLED
  BALQTY    = [F:DAA]QTY
  Raz TBALDIE, TBALCCE
  For I=1 To dim([F:LED]DIE)
   Assign "TBALDIE("+num$(I-1)+")" With evalue("[F:DAA]DIE("+num$(I-1)+")")
   Assign "TBALCCE("+num$(I-1)+")" With evalue("[F:DAA]CCE("+num$(I-1)+")")
  Next

  # Updating Analytical balance
  Call BAL_DAA(SIGN, BALTYP, BALSOC, ISOC, BALFCYLIN, EXE, PER, BALACC, BPR,
&               TBALDIE, TBALCCE,
&               BALCUR , BALLED, BALCURLED, BALCOA, BALSNS,  BALAMTCUR, BALAMTLED, BALQTY)
  If GOK<1 : End : Endif

  # Updating of the Pre-consolidation balance
  # Conditions:
  #  - activity code PRCSL active
  #  - ledger flagged "Consolidation"
  #  - Journal entry category ="Actual"
  If func AFNC.ACTIV("PRCSL")
   Call LEC_GTE_LEG(GCURLEG,[F:HAE]TYP) From CPTLEC
   Call LEC_LED([F:DAE]LED) From CPTLEC
   If [F:LED]CSL=2 and [F:GTE]PER=1

   Call BALPRECSL(SIGN, BALTYPLIN, BALTYP, BALSOC, ISOC, BALFCYLIN, EXE, PER, BALACC,
&               BPR, CSLFLO, BALCSLBPR,
&               TBALDIE, TBALCCE,
&               BALCUR, BALLED, BALCURLED, BALCOA, BALSNS, BALAMTCUR, BALAMTLED)

    If GOK<1 : End : Endif
   Endif
  Endif
 Endif

Endif
#---------------------------------------#
# Budgets opérationnels & piste d'audit #
#---------------------------------------#
If func AFNC.ACTIV("GDD")
 If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
 If !clalev([F:LED]) : Local File GLED [LED] : Endif
 Local Char MODELE(GLONGCM)
 Call SETGCM([F:DAA]CPY,MODELE) From CPTDIV
 Call LEC_GCM(MODELE) From CPTLEC
 Call LEC_LED([F:GCM]LED([F:DAA]LEDTYP-1)) From CPTLEC
 # On ne travaillr  que sur les référentiels flagués budgets opérationnels
 If [F:LED]GDD=2
  Local Char ENTITY(GLONCCE),ENVELOP(GLONCCE),CCE3(GLONCCE)
  Local Integer INDENT, INDENV, INDCCE3, BUOFLG, YEAFLG
  Local Char BUDCOD(GLONBUP),FCYBUD(GLONFCY)

  Call GETBUOINF([F:DAA]DIE,[F:DAA]CCE,[F:DAA]FCYLIN,BUDCOD,ENTITY,INDENT,ENVELOP,INDENV,CCE3,INDCCE3,BUOFLG,YEAFLG,FCYBUD) From TRTGDD
  If BUOFLG
   #Contrôle pour validation de facture sur enveloppe pluriannuelle
   Gosub CTL_BUO
   If GOK<1 : End : Endif
   #Mise à jour montant réalisé sur lignes budgétaire correspondante
   Gosub MAJ_BUO
   If GOK<1 : End : Endif
   ## Piste d'audit
   # NB: Pour l'instant limitée au budget opérationnels car pour la clôture
   #     des budgets analytiques on n'a pas besoin des factures
   Gosub MAJ_BUA
   If GOK<1 : End : Endif
  Endif :#BUOFLG
 Endif :#[LED]GDD=2
Endif
#---------------------------------------#
End
#########################################
## YYFIN_105932_8
#**
#*  Updating Analytical balance : BALANA
#*
#* @param SIGN        : Sign
#* @param BALTYP      : Ledger type (LEDTYP)
#* @param BALSOC      : Company
#* @param ISOC        : Company index
#* @param BALFCYLIN   : Site of the line
#* @param EXE         : Fiscal year
#* @param PER         : Period
#* @param BALACC      : Account
#* @param BPR         : Business Partner
#* @param TBALDIE     : Dimension type codes
#* @param TBALCCE     : Analytical dimensions
#* @param BALCUR      : Line currency
#* @param BALLED      : Ledger
#* @param BALCURLED   : Ledger currency
#* @param BALCOA      : Chart code
#* @param BALSNS      : Sign of the line
#* @param BALAMTCUR   : Entry amount
#* @param BALAMTLED   : Ledger amount
#* @param BALQTY      : Quantity
#*
#*!
Subprog BAL_DAA(SIGN, BALTYP, BALSOC, ISOC, BALFCYLIN, EXE, PER, ACC, BPR,
&               TBALDIE, TBALCCE,
&               BALCUR,  BALLED, BALCURLED, BALCOA, BALSNS, BALAMTCUR, BALAMTLED, BALQTY)
Value Integer SIGN
Value Integer BALTYP
Value Char    BALSOC
Value Integer ISOC
Value Char    BALFCYLIN
Value Integer EXE
Value Integer PER
Value Char    ACC
Value Char    BPR
Value Char    TBALDIE()(0..)
Value Char    TBALCCE()(0..)
Value Char    BALCUR
Value Char    BALLED
Value Char    BALCURLED
Value Char    BALCOA
Value Integer BALSNS
Value Decimal BALAMTCUR
Value Decimal BALAMTLED
Value Decimal BALQTY

Local Integer BALEXE
Local Integer BALPER
Local Char    BALACC(GLONGAC)
Local Char    BALBPR(GLONBPR)
Local Char    BALFCY(GLONFCY)
Local Integer BALREP
Local Char    BALAXE(GLONDIE)
Local Char    SECTION(GLONCCE)
Local Char    BALSEC1(GLONCCE) , BALSEC2(GLONCCE) , BALSEC3(GLONCCE)
Local Char    BALSEC4(GLONCCE) , BALSEC5(GLONCCE) , BALSEC6(GLONCCE)
Local Char    BALSEC7(GLONCCE) , BALSEC8(GLONCCE) , BALSEC9(GLONCCE)

BALEXE = EXE
BALPER = PER
BALBPR = BPR
BALFCY = BALFCYLIN
BALACC = ACC
BALREP = 0

For AXE=1 To dim([F:LED]DIE)
 Assign "BALSEC"+num$(AXE) With TBALCCE(AXE-1)
Next

Gosub BAL_ANA : # Balance ana compte+tiers
If GOK<1 : End : Endif
If BALBPR<>""
 BALBPR = ""
 Gosub BAL_ANA : # Balance ana du collectif
 If GOK<1 : End : Endif
Endif

  # (BY) Mise à jour à nouveau temps réel
  ## <YYFIN 105753>
  If dim(GEXEAN)<0 : Call EXEAN From GLOBCPT : Endif
  ## <End YYFIN 105753>
  If GRANA=2 & GEXEAN(ISOC,BALTYP)=BALEXE
   BALBPR = BPR
   Gosub RAN_GEN
   If GOK<1 : End : Endif
   If RESULT
    If RESULT=2
     Raz BALSEC1,BALSEC2,BALSEC3,BALSEC4,BALSEC5,BALSEC6,BALSEC7,BALSEC8,BALSEC9
    Else
     Gosub RAN_ANA
    Endif
    If GOK<1 : End : Endif
    BALREP = 1
    BALPER = 0
    BALEXE += 1

    GPOINT = "ANAFRW" : Gosub ENTREE From EXEFNC

    Gosub BAL_ANA : # Balance ana compte+tiers
    If GOK<1 : End : Endif
    If BALBPR<>""
     BALBPR = ""
     Gosub BAL_ANA : # Balance ana du collectif
     If GOK<1 : End : Endif
    Endif
   Endif
  Endif

End
###########
$BAL_ANA

 # MAJ Société
 BALFCY = ""
 Gosub MAJBLA
 If GOK<1 : Return : Endif

 # MAJ Site
 BALFCY = BALFCYLIN
 Gosub MAJBLA
 If GOK<1 : Return : Endif

Return
###########
##############################
## Sections de report à nouveau
#########################################
$RAN_ANA

If clalev([F:CCE])=0 : Local File CACCE [CCE] : Endif

For AXE=1 To dim([F:LED]DIE)
 BALAXE  = TBALDIE(AXE-1)
 SECTION = TBALCCE(AXE-1)
 If BALAXE<>"" & SECTION<>""
  J = find(BALAXE,GDIECOD(1..GDIENBR))
  If GDIEPRJ(J)=2
   SECTION = ""
  Else
   Read [CCE]CCE0 = BALAXE;SECTION
   If [F:CCE]FRW<>2
    SECTION = ""
   Endif
  Endif
 Endif
 Assign "BALSEC"+num$(AXE) With SECTION
Next AXE

Return

###########
$MAJBLA
# Mise à jour de la balance analytique
Readlock [BLA]BLA0 = BALTYP;BALSOC;BALFCY;BALEXE;BALACC;BALBPR;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;BALCUR
If fstat=1
 GOK = -1 : GLOCK = "$BALANA"-num$(BALTYP)-BALACC-BALBPR : Return
Elsif fstat
 Raz [F:BLA]
 [F:BLA]LEDTYP = BALTYP
 [F:BLA]CPY    = BALSOC
 [F:BLA]FCY    = BALFCY
 [F:BLA]FIY    = BALEXE
 [F:BLA]ACC    = BALACC
 [F:BLA]BPR    = BALBPR
 [F:BLA]CCE1   = BALSEC1
 [F:BLA]CCE2   = BALSEC2
 [F:BLA]CCE3   = BALSEC3
 [F:BLA]CCE4   = BALSEC4
 [F:BLA]CCE5   = BALSEC5
 [F:BLA]CCE6   = BALSEC6
 [F:BLA]CCE7   = BALSEC7
 [F:BLA]CCE8   = BALSEC8
 [F:BLA]CCE9   = BALSEC9
 [F:BLA]CUR    = BALCUR
 [F:BLA]ACCNUM = uniqid([F:BLA])
 [F:BLA]LED    = BALLED
 [F:BLA]COA    = BALCOA
 [F:BLA]CURLED = BALCURLED
 For I=1 To dim([F:LED]DIE)
  Assign "[F:BLA]DIE("+num$(I-1)+")"  With evalue("TBALDIE("+num$(I-1)+")")
 Next

 Gosub CALBLA
 Write [BLA]
Else
 Gosub CALBLA
 Rewrite [BLA]
Endif
If fstat
 GOK=0 : Call FSTA("BLA") From GLOCK : Return
Endif
# Mise à jour de la balance analytique en quantité
If BALQTY<>0
 Readlock [BLQ]BLQ0 = BALTYP;BALSOC;BALFCY;BALEXE;BALACC;BALBPR;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;BALCUR
 If fstat=1
  GOK = -1 : GLOCK = "$BLAQTY"-num$(BALTYP)-BALACC-BALBPR : Return
 Elsif fstat
  Raz [F:BLQ]
  [F:BLQ]LEDTYP = BALTYP
  [F:BLQ]CPY    = BALSOC
  [F:BLQ]FCY    = BALFCY
  [F:BLQ]FIY    = BALEXE
  [F:BLQ]ACC    = BALACC
  [F:BLQ]BPR    = BALBPR
  [F:BLQ]CCE1   = BALSEC1
  [F:BLQ]CCE2   = BALSEC2
  [F:BLQ]CCE3   = BALSEC3
  [F:BLQ]CCE4   = BALSEC4
  [F:BLQ]CCE5   = BALSEC5
  [F:BLQ]CCE6   = BALSEC6
  [F:BLQ]CCE7   = BALSEC7
  [F:BLQ]CCE8   = BALSEC8
  [F:BLQ]CCE9   = BALSEC9
  [F:BLQ]CUR    = BALCUR
  [F:BLQ]ACCNUM = uniqid([F:BLQ])
  [F:BLQ]LED    = BALLED
  [F:BLQ]COA    = BALCOA
  For I = 1 To dim([F:LED]DIE)
   Assign "[F:BLQ]DIE("+num$(I-1)+")"  With evalue("TBALDIE("+num$(I-1)+")")
  Next
  [F:BLQ]UOM    = [F:DAA]UOM
  [F:BLQ]QTY(BALPER) += SIGN*BALSNS*BALQTY
  Write [BLQ]
 Else
  [F:BLQ]QTY(BALPER) += SIGN*BALSNS*BALQTY
  Rewrite [BLQ]
 Endif
 If fstat
  GOK=0 : Call FSTA("BLQ") From GLOCK : Return
 Endif
Endif
Return

$CALBLA
If BALSNS=1
 [F:BLA]DEB(BALPER)    += SIGN*BALAMTCUR
 [F:BLA]DEBLED(BALPER) += SIGN*BALAMTLED
Else
 [F:BLA]CDT(BALPER)    += SIGN*BALAMTCUR
 [F:BLA]CDTLED(BALPER) += SIGN*BALAMTLED
Endif
If BALREP
 If [F:BLA]DEB(0)>[F:BLA]CDT(0)
  [F:BLA]DEB(0) = [F:BLA]DEB(0) - [F:BLA]CDT(0)
  [F:BLA]CDT(0) = 0
 Else
  [F:BLA]CDT(0) = [F:BLA]CDT(0) - [F:BLA]DEB(0)
  [F:BLA]DEB(0) = 0
 Endif
 If [F:BLA]DEBLED(0)>[F:BLA]CDTLED(0)
  [F:BLA]DEBLED(0) = [F:BLA]DEBLED(0) - [F:BLA]CDTLED(0)
  [F:BLA]CDTLED(0) = 0
 Else
  [F:BLA]CDTLED(0) = [F:BLA]CDTLED(0) - [F:BLA]DEBLED(0)
  [F:BLA]DEBLED(0) = 0
 Endif
Endif
GPOINT = "BEFWRIBLA" : Gosub ENTREE From EXEFNC
Return

#####################################################
##       Contrôle des budgets opérationnels        ##
## =>Liés à la clotûre & la gestion des FAR et AAR ##
#####################################################
$CTL_BUO
# Cyrille a demandé à ce que ce blocage soit effectué par une variable cachée
# qui permettrait d’autoriser cette validation si cela devait être trop contraignant
# à l’usage et si besoin de mettre ce blocage sous forme de paramètre ensuite.
Local Integer BUOPURCTL
BUOPURCTL=1
If BUOPURCTL
  If YEAFLG=2
   If !clalev([F:PIH]) : Local File PINVOICE  [PIH] : Endif
   If !clalev([F:POH]) : Local File PORDER    [POH] : Endif
   If !clalev([F:PID]) : Local File PINVOICED [PID] : Endif
   If !clalev([F:BUD]) : Local File BUD       [BUD] : Endif
   If !clalev([F:ENV]) : Local File ENVELOPPE [ENV] : Endif
   If !clalev([F:BUA]) : Local File BUDPURAUD [BUA] : Endif
   Local Decimal FIYPOH, FIYHAE
   Local Char POHNUM(GLONVCR)
   Local Date ORDDAT
   Local Integer POPLIN,POQSEQ
   #
   Filter [PID] Where NUM=[F:HAE]NUM
   For [PID]PID0
    POHNUM=[F:PID]POHNUM
    POPLIN=[F:PID]POPLIN
    POQSEQ=[F:PID]POQSEQ
    Read [POH]POH0 = POHNUM
    If  !fstat
     ORDDAT=[F:POH]ORDDAT
     Call GETEXE([F:DAA]CPY,[F:DAA]LEDTYP,[F:HAE]ACCDAT,FIYHAE) From CPTSUB
     Call GETEXE([F:DAA]CPY,[F:DAA]LEDTYP,ORDDAT,FIYPOH) From CPTSUB
     If FIYPOH<FIYHAE
      #TYP+TYPPCE+NUM+LIN+SEQ+ANALIN+LEDTYP+FIY
      Read [BUA]BUA0 = 2;"";POHNUM;POPLIN;POQSEQ;0;FIYPOH
      #Read [BUA]BUA0 = 2;"";POHNUM;POPLIN;POQSEQ;0;[F:DAA]LEDTYP;FIYPOH
      #If !fstat & ([F:BUA]GRDPCE=4 | [F:BUA]GRDPCE=5)  & [F:BUA]CMM=0
       # Cas CMD/REC TOT/FAR : si la dernière action sur la commande était
       # la création de la FAR ou AAR, on doit pouvoir sur N+1 faire une facture
       # sur la REC de la CMD sur N
       # 02/02/2011
       # Cela ne semble pas suffire, peut-être faut -il simplement
       # veiller à ce qu'il n'y ait plus d'engagement sur la commande N
      If !fstat & [F:BUA]CMM=0
       Break
      Endif
      # LEDTYP+BUD+CPY+FCY+FIY+VER+ACC+CCE1+CCE2+CCE3
      Raz [F:BUD]
      If INDENT  : Assign "[F:BUD]CCE"+num$(INDENT)  With ENTITY  : Endif
      If INDENV  : Assign "[F:BUD]CCE"+num$(INDENV)  With ENVELOP : Endif
      If INDCCE3 : Assign "[F:BUD]CCE"+num$(INDCCE3) With CCE3    : Endif
      [F:BUD]LEDTYP = [F:DAA]LEDTYP
      [F:BUD]BUD    = BUDCOD
      [F:BUD]CPY    = [F:DAA]CPY
      [F:BUD]FCY    = FCYBUD
      [F:BUD]FIY    = FIYPOH
      [F:BUD]VER    = "1"
      [F:BUD]ACC    = [F:DAA]ACC
      Read [BUD]BUD0=
      If !fstat & [F:BUD]STA<>5 & [F:BUD]STA<>4
       # Engagement non reporté => on doit bloquer
       #* [F:BUD]STA<>4 pour cas CMD/REC Partielle/FAR/REPORT ENVP :
       #- Si la ligne est fermée, sans doute qu'un report de l'enveloppe a eu lieu
       #
       #* [F:BUD]STA<>5 pour cas suivant (d'origine à l'intervention ici) :
       #- Pour les enveloppes pluriannuelles, il faudrait interdire la validation
       # de la facture sur une commande de l’exercice précédent qui n’aurait pas
       # été reportée dans le cadre des budgets opérationnels, avec le même message
       # bloquant que celui-ci-dessus. Cyrille a demandé à ce que ce blocage soit
       # effectué par une variable cachée qui permettrait d’autoriser cette validation
       # si cela devait être trop contraignant à l’usage et si besoin de mettre ce
       # blocage sous forme de paramètre ensuite.
       #
       # 263,108 : Pièce d'achat non reportée sur l'exercice suivant
       Call ECR_TRACE(POHNUM+":"+mess(263,108,1),1) From GESECRAN
       GOK=0 : Break
      Endif
     Endif
    Endif
   Next
   Filter [PID]
   If GOK=0 : Return : Endif
  Endif
Endif
Return

########################################################
## Mise à jour de budgets opérationnels               ##
########################################################
$MAJ_BUO
If !clalev([F:BUD]) : Local File BUD [BUD] : Endif
# BUD0=LEDTYP+BUD+CPY+FCY+FIY+VER+ACC+CCE1+CCE2+CCE3
Raz [F:BUD]
If INDENT  : Assign "[F:BUD]CCE"+num$(INDENT) With ENTITY  : Endif
If INDENV  : Assign "[F:BUD]CCE"+num$(INDENV) With ENVELOP : Endif
If INDCCE3 : Assign "[F:BUD]CCE"+num$(INDCCE3) With CCE3   : Endif
[F:BUD]LEDTYP = [F:DAA]LEDTYP
[F:BUD]BUD    = BUDCOD
[F:BUD]CPY    = [F:DAA]CPY
[F:BUD]FCY    = FCYBUD
[F:BUD]FIY    = [F:DAE]FIY
[F:BUD]VER    = "1"
[F:BUD]ACC    = [F:DAA]ACC
Readlock [BUD]BUD0=
If fstat=1
 GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM : Return
Elsif !fstat
 ## En validation de pièce de type CCA/CAP
 # Récupération des paramètres pour GDD
 Local Char TYPCCA(GLONGTE),TYPCAP(GLONGTE)
 Call PARAM(BALSOC,"GDDGTECCA",TYPCCA) From ADOVAL
 Call PARAM(BALSOC,"GDDGTECAP",TYPCAP) From ADOVAL
 Case [F:DAA]TYP
  When TYPCCA
   If func AFNC.ACTIV("SVC")
    [F:BUD]AMTCCA += SIGN*[F:DAA]SNS*[F:DAA]AMTLED
   Endif
  When TYPCAP
   [F:BUD]AMTCAP += SIGN*[F:DAA]SNS*[F:DAA]AMTLED
 Endcase
 ## Pour les pieces dont les comptes sont flagués "suivi dans Abel"
 Call LEC_GAC([F:DAA]ACC,[F:DAA]COA) From CPTLEC
 If [F:GAC]FLGABL=2
  [F:BUD]AMTFAS += SIGN*[F:DAA]SNS*[F:DAA]AMTLED
 Endif
 #Montant réalisé
 [F:BUD]AMTREA += SIGN*[F:DAA]SNS*[F:DAA]AMTLED
 Rewrite [BUD]
 If fstat
  GOK=0 : Call FSTA("BUD") From GLOCK
 Endif
Endif
Return

#############################################################################
## Mise à jour/Création de la piste d'audit                                ##
##  *ici les montants facturés dans les lignes budgétaires sont mis à jour ##
#############################################################################
$MAJ_BUA
If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
If !clalev([F:LED]) : Local File GLED [LED] : Endif
Local Char MODELE(GLONGCM)
Call SETGCM([F:DAA]CPY,MODELE) From CPTDIV
Call LEC_GCM(MODELE) From CPTLEC
Call LEC_LED([F:GCM]LED([F:DAA]LEDTYP-1)) From CPTLEC

If [F:LED]CMM<>2 : Return : Endif

#Détermination du type de pièce :
#Si existe dans PIH alors 'Facture', sinon alors 'Pièce comptable'
Local Integer BUATYP
If !clalev([F:PIH]) : Local File PINVOICE [PIH] : Endif
Look [PIH]PIH0 = [F:HAE]NUM
If !fstat
 BUATYP=3 :#Facture
Else
 #ARV : il va falloir des paramètres pour définir le ou les types de pièces
 #      associées aux factures à recevoir et aux avoirs à recevoir.
 If [F:HAE]TYP="FAR"
  BUATYP=4 :#FAR
 Elsif [F:HAE]TYP="AVR"
  BUATYP=5 :#AAR
 Else
  BUATYP=8 :#Pièce comptable
 Endif
Endif
# MAJ Table d'audit
If !clalev([F:BUA]) : Local File BUDPURAUD [BUA] : Endif
#BUA0=TYP+TYPPCE+NUM+LIN+SEQ+ANALIN+FIY
Readlock [BUA]BUA0 = BUATYP;[F:HAE]TYP;[F:HAE]NUM;[F:DAE]LIN;0;[F:DAA]ANALIN;[F:DAE]FIY
If fstat=1
 GOK = -1 : GLOCK = "$BUA"-[F:BUA]BUANUM : Return
Elsif fstat=0
 #
 [F:BUA]BUD = BUDCOD
 [F:BUA]LEDTYP([F:DAA]LEDTYP-1) = [F:DAA]LEDTYP
 [F:BUA]COA([F:DAA]LEDTYP-1) = [F:DAA]COA
 [F:BUA]ACC([F:DAA]LEDTYP-1) = [F:DAA]ACC
 #
 [F:BUA]REA += SIGN*[F:DAA]SNS*[F:DAA]AMTCUR
 [F:BUA]REALED([F:DAA]LEDTYP-1) += SIGN*[F:DAA]SNS*[F:DAA]AMTLED
 [F:BUA]DAT = [F:HAE]ACCDAT
 [F:BUA]CPY = [F:DAA]CPY
 [F:BUA]FCY = [F:DAA]FCYLIN
 [F:BUA]FIY = [F:DAE]FIY
 [F:BUA]BPR = [F:DAA]BPR
 For I=1 To 9
  Assign "[F:BUA]DIE("+num$(I-1)+")" With evalue("[F:DAA]DIE("+num$(I-1)+")")
  Assign "[F:BUA]CCE("+num$(I-1)+")" With evalue("[F:DAA]CCE("+num$(I-1)+")")
 Next
 [F:BUA]UPDDAT = date$
 [F:BUA]UPDUSR = GUSER
 [F:BUA]GRDACT = 2
 [F:BUA]GRDPCE = BUATYP
 Rewrite [BUA]
 If fstat
  GOK = 0 : Call FSTA("BUA") From GLOCK : Return
 Endif
Elsif fstat=5
 Raz [BUA]
 #
 [F:BUA]BUD = BUDCOD
 [F:BUA]LEDTYP([F:DAA]LEDTYP-1) = [F:DAA]LEDTYP
 [F:BUA]COA([F:DAA]LEDTYP-1) = [F:DAA]COA
 [F:BUA]ACC([F:DAA]LEDTYP-1) = [F:DAA]ACC
 #
 [F:BUA]BUANUM = uniqid([F:BUA])
 [F:BUA]TYP = BUATYP :# Facture / Pièce comptable
 [F:BUA]TYPPCE = [F:HAE]TYP
 [F:BUA]NUM = [F:HAE]NUM
 [F:BUA]LIN = [F:DAE]LIN
 [F:BUA]SEQ = 0
 [F:BUA]ANALIN = [F:DAA]ANALIN
 [F:BUA]DAT = [F:HAE]ACCDAT
 [F:BUA]CPY = [F:DAA]CPY
 [F:BUA]FCY = [F:DAA]FCYLIN
 [F:BUA]FIY = [F:DAE]FIY
 [F:BUA]BPR = [F:DAA]BPR
 For I=1 To 9
  Assign "[F:BUA]DIE("+num$(I-1)+")" With evalue("[F:DAA]DIE("+num$(I-1)+")")
  Assign "[F:BUA]CCE("+num$(I-1)+")" With evalue("[F:DAA]CCE("+num$(I-1)+")")
 Next
 [F:BUA]REA    = SIGN*[F:DAA]SNS*[F:DAA]AMTCUR
 [F:BUA]CUR    = [F:DAA]CUR
 [F:BUA]REALED([F:DAA]LEDTYP-1) = SIGN*[F:DAA]SNS*[F:DAA]AMTLED
 [F:BUA]CURLED([F:DAA]LEDTYP-1) = [F:DAA]CURLED
 [F:BUA]CREDAT = date$
 [F:BUA]CREUSR = GUSER
 [F:BUA]GRDACT = 1
 [F:BUA]GRDPCE = BUATYP
 Write [BUA]
 If fstat
  GOK = 0 : Call FSTA("BUA") From GLOCK : Return
 Endif
Endif
Return


###############################################################
## Initialisation de BALANA en fonction de BUD               ##
###############################################################
Subprog INIBLA
#07/2010 : Encore utilisé depuis BUDCOP (la copie de budget)
Local File BALANA [BLA] : # Car ca peut être appelé depuis un for..where
If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
If !clalev([F:LED]) : Local File GLED [LED] : Endif
Local Char    BALSOC(GLONCPY) , BALSIT(GLONFCY), BALDEV(GLONCUR)
Local Char    ACC(GLONGAC), CCE1(GLONCCE), CCE2(GLONCCE), CCE3(GLONCCE), CCE4(GLONCCE), CCE5(GLONCCE), CCE6(GLONCCE), CCE7(GLONCCE), CCE8(GLONCCE), CCE9(GLONCCE)
Local Integer ISITE, ISOC
Local Char CCE(15)(9)
Local Char LED(3)

Call LECTURE("BUP",[F:BUD]BUD,"") From CONTOBJ
BALSIT = [F:BUD]FCY
BALSOC = [F:BUD]CPY
LED = [GCM]LED([F:BUD]LEDTYP-1)
ISOC = find(BALSOC,GSOC(1..GNBSOC))
If !ISOC : End : Endif

BALDEV = GDEVSOC(ISOC)
Gosub CRE_BLA
If GOK<1 : End : Endif
#If GDEVSOC(ISOC)<>GSYSCUR & GBALANARPT=2
# BALDEV = GSYSCUR
# Gosub CRE_BLA
# If GOK<1 : End : Endif
#Endif
End

$CRE_BLA
Call LEC_CPY(BALSOC) From CPTLEC
Call LEC_LED(LED) From CPTLEC
Call LECTURE("BUP",[F:BUD]BUD,"") From CONTOBJ

For I=0 To [F:LED]DIENBR-1
 If [F:LED]DIE(I) = [F:BUP]DIE(0)
  CCE(I) = [F:BUD]CCE1
 Elsif [F:LED]DIE(I) = [F:BUP]DIE(1)
  CCE(I) = [F:BUD]CCE2
 Elsif [F:LED]DIE(I) = [F:BUP]DIE(2)
  CCE(I) = [F:BUD]CCE3
 Elsif [F:LED]DIE(I) = [F:BUP]DIE(3)
  CCE(I) = [F:BUD]CCE4
 Elsif [F:LED]DIE(I) = [F:BUP]DIE(4)
  CCE(I) = [F:BUD]CCE5
 Elsif [F:LED]DIE(I) = [F:BUP]DIE(5)
  CCE(I) = [F:BUD]CCE6
 Elsif [F:LED]DIE(I) = [F:BUP]DIE(6)
  CCE(I) = [F:BUD]CCE7
 Elsif [F:LED]DIE(I) = [F:BUP]DIE(7)
  CCE(I) = [F:BUD]CCE8
 Elsif [F:LED]DIE(I) = [F:BUP]DIE(8)
  CCE(I) = [F:BUD]CCE9
 Else
  CCE(I) = ""
 Endif
Next

[L]ACC  = [F:BUD]ACC

If [L]ACC<>""
 # LS : Si le groupe section n'est composé que de sous-groupes mais pas de sections, on ne doit
 # pas refaire de Write à chaque fois qu'on enregistre le budget.
 # LEDTYP+CPY+FCY+FIY+ACC+BPR+CCE1+CCE2+CCE3+CCE4+CCE5+CCE6+CCE7+CCE8+CCE9+CUR
 Read [BLA]BLA0 = [F:BUD]LEDTYP;BALSOC;BALSIT;[F:BUD]FIY;[L]ACC;"";CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);CCE(6);CCE(7);CCE(8);[F:CPY]ACCCUR
 If fstat
  Raz [F:BLA]
  [F:BLA]LEDTYP = [F:BUD]LEDTYP
  [F:BLA]CPY    = BALSOC
  [F:BLA]FCY    = BALSIT
  [F:BLA]FIY    = [F:BUD]FIY
  [F:BLA]ACC    = [L]ACC
  [F:BLA]CCE1   = CCE(0)
  [F:BLA]CCE2   = CCE(1)
  [F:BLA]CCE3   = CCE(2)
  [F:BLA]CCE4   = CCE(3)
  [F:BLA]CCE5   = CCE(4)
  [F:BLA]CCE6   = CCE(5)
  [F:BLA]CCE7   = CCE(6)
  [F:BLA]CCE8   = CCE(7)
  [F:BLA]CCE9   = CCE(8)
  [F:BLA]CUR    = [F:CPY]ACCCUR
  [F:BLA]ACCNUM = uniqid([F:BLA])
  [F:BLA]LED    = [F:BUD]LED
  [F:BLA]COA    = [F:BUD]COA
  For I=0 To 8
   [F:BLA]DIE(I) = [F:LED]DIE(I)
  Next
  Write [BLA]
  If fstat
   GOK = 0 : Call FSTA("BLA") From GLOCK : Return
  Endif
 Endif
Endif
Return

#########################################
## YYFIN_105932_8
#**
#* Updating of the Pre-consolidation balance : BALPRECSL
#*
#* @param SIGN        : Sign
#* @param BALTYPLIN   : "DAE" or "DAA"
#* @param BALTYP      : Ledger type (LEDTYP)
#* @param BALSOC      : Company
#* @param ISOC        : Company index
#* @param BALFCYLIN   : Site of the line
#* @param EXE         : Fiscal year
#* @param PER         : Period
#* @param BALACC      : Account
#* @param BPR         : Business Partner
#* @param CSLFLO      : Flow
#* @param BALCSLBPR   : Partner
#* @param TBALDIE     : Dimension type codes
#* @param TBALCCE     : Analytical dimensions
#* @param BALCUR      : Line currency
#* @param BALLED      : Ledger
#* @param BALCURLED   : Ledger currency
#* @param BALCOA      : Chart code
#* @param BALSNS      : Sign of the line
#* @param BALAMTCUR   : Entry amount
#* @param BALAMTLED   : Ledger amount
#*!
Subprog BALPRECSL(SIGN, BALTYPLIN, BALTYP, BALSOC, ISOC, BALFCYLIN, EXE, PER, ACC, BPR, CSLFLO, CSLBPR,
&                TBALDIE, TBALCCE,
&                BALCUR, BALLED, BALCURLED, BALCOA, BALSNS, BALAMTCUR, BALAMTLED)
Value Integer  SIGN
Value Char     BALTYPLIN
Value Integer  BALTYP
Value Char     BALSOC
Value Integer  ISOC
Value Char     BALFCYLIN
Value Integer  EXE
Value Integer  PER
Value Char     ACC
Value Char     BPR
Value Char     CSLFLO
Value Char     CSLBPR
Value Char     TBALDIE()(0..)
Value Char     TBALCCE()(0..)
Value Char     BALCUR
Value Char     BALLED
Value Char     BALCURLED
Value Char     BALCOA
Value Integer  BALSNS
Value Decimal  BALAMTCUR
Value Decimal  BALAMTLED

Local Integer  BALREP
Local Integer  BALEXE
Local Integer  BALPER
Local Char     BALACC(GLONGAC)
Local Char     BALBPR(GLONBPR)
Local Char     TDIE(GLONDIE)(0..dim([F:LED]DIE)-1)
Local Char     TCCE(GLONCCE)(0..dim([F:LED]DIE)-1)
Local Char     BALAXE(GLONDIE)
Local Char     SECTION(GLONCCE)
Local Char     BALCSLFLO(GLONADI)
Local Char     BALCSLBPR(GLONBPR)

BALEXE    = EXE
BALPER    = PER
BALACC    = ACC
BALBPR    = BPR
BALCSLFLO = CSLFLO
BALCSLBPR = CSLBPR

Raz TDIE, TCCE
For I=1 To dim([F:LED]DIE)
 Assign "TDIE("+num$(I-1)+")" With evalue("TBALDIE("+num$(I-1)+")")
 Assign "TCCE("+num$(I-1)+")" With evalue("TBALCCE("+num$(I-1)+")")
Next

#*** Only if PRCSL is active
If func AFNC.ACTIV("PRCSL")=0 : End : Endif

If !clalev([F:BLP])   : Local File BALPRECSL    [BLP]   : Endif
If !clalev([F:IDTC])  : Local File IDTCCE       [IDTC]  : Endif

 Gosub BALPRCSL
 If GOK<1 : End : Endif

 # New call to BALPRCSL for the carry-forward entries
 If dim(GEXEAN)<0 : Call EXEAN From GLOBCPT : Endif
 ## General lines
 If BALTYPLIN ="DAE"
  If GRAN=2 & GEXEAN(ISOC,BALTYP)=BALEXE
   BALREP = 1
   BALEXE += 1
   BALPER = 0
   Gosub RAN_GEN
   If GOK<1 : End : Endif
    If RESULT
     # The flow is always initialized with the value of the parameter CSLFRWFLO, regardless the account class (RTZ or to be carry forward)
     BALCSLFLO = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY,BALSOC,"CSLFRWFLO")
     If RESULT=2
      # If result account with account class  "reset to zero", the Partner code must be RTZ
      BALCSLBPR = ""
     Endif
    Endif
    Gosub BALPRCSL
    If GOK<1 : End : Endif
   Endif
 ## Analytical lines
 Elsif BALTYPLIN="DAA"
  If GRANA=2 & GEXEAN(ISOC,BALTYP)=BALEXE
   Gosub RAN_GEN
   If GOK<1 : End : Endif
   If RESULT
    # The flow is always initialized with the value of the parameter CSLFRWFLO, regardless the account class (RTZ or to be carry forward)
    BALCSLFLO = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY,BALSOC,"CSLFRWFLO")
    If RESULT=2
     # If result account with account class "reset to zero", the Partner code must be RTZ
     BALCSLBPR = ""
     Raz TCCE
    Else
     Gosub RAN_CSL
    Endif
    If GOK<1 : End : Endif
    BALREP = 1
    BALEXE += 1
    BALPER = 0
    Gosub BALPRCSL
    If GOK<1 : End : Endif
   Endif
  Endif
 Endif


End
#############
#### YYFIN_105932_8  BALPRECSL Analytical dimensions for RAN
#############
$RAN_CSL

If clalev([F:CCE])=0 : Local File CACCE [CCE] : Endif

For AXE=1 To dim([F:LED]DIE)
 BALAXE  = TDIE(AXE-1)
 SECTION = TCCE(AXE-1)
 If BALAXE<>"" & SECTION<>""
  J = find(BALAXE,GDIECOD(1..GDIENBR))
  If GDIEPRJ(J)=2
   SECTION = ""
  Else
   Read [CCE]CCE0 = BALAXE;SECTION
   If [F:CCE]FRW<>2
    SECTION = ""
   Endif
  Endif
 Endif
 Assign "TCCE("+num$(AXE-1)+")" With SECTION
Next AXE

Return
#############
## YYFIN_105932_8
#############
$BALPRCSL
 Local Integer BALIDTCCE

 Raz BALIDTCCE

# Updating of the table IDTCCE when analytical ledger
If [F:LED]ANA=2 and BALTYPLIN = "DAA"
 Call GETIDTCCE(BALLED,TDIE,TCCE,BALIDTCCE)
 If GOK<1 : Return : Endif
Endif

# Updating of  BALPRECSL
Gosub MAJ_BALPRCSL
If GOK<1 : Return : Endif

Return

#############
## YYFIN_105932_8 Get Analytical dimensions index
#############
#**
#* Updating og  Analytical dimensions index : IDTCCE
#*
#* @param BALLED        # Ledger
#* @param TDIE          # Dimension type codes
#* @param TCCE          # Analytical dimension
#* @param BALIDTCCE     # Dimension single identifier
#*
#*!
Subprog GETIDTCCE (BALLED,TDIE,TCCE,BALIDTCCE)
Value  Char      BALLED
Value  Char      TDIE()(0..)
Value  Char      TCCE()(0..)
Variable Integer BALIDTCCE

Local Integer AXE

If !clalev([F:IDTC])  : Local File IDTCCE  [IDTC]  : Endif

 Readlock [IDTC]IDTC0 = BALLED;TCCE(0);TCCE(1);TCCE(2);TCCE(3);TCCE(4);TCCE(5);TCCE(6);TCCE(7);TCCE(8)
 If fstat=1
  GOK = -1 : GLOCK = "$IDTCCE"-num$(IDTCCE) : End
 Elsif fstat
  Raz [F:IDTC]
  [F:IDTC]LED= BALLED
  For AXE=1 To dim([IDTC]DIE)
   Assign "[F:IDTC]DIE("+num$(AXE-1)+")"  With evalue("TDIE("+num$(AXE-1)+")")
   Assign "[F:IDTC]CCE"+num$(AXE)         With evalue("TCCE("+num$(AXE-1)+")")
  Next
  [F:IDTC]IDTCCE = uniqid([F:IDTC])
  BALIDTCCE = [F:IDTC]IDTCCE
  Write [IDTC]
  If fstat
   GOK=0 : Call FSTA("IDTC") From GLOCK : End
  Endif
 Else  # if IDTC already exists
  BALIDTCCE = [F:IDTC]IDTCCE
 Endif

End

#############
## YYFIN_105932_8
#############
$MAJ_BALPRCSL
Readlock [BLP]BLP0 = BALTYP;BALSOC;BALFCYLIN;BALEXE;BALACC;BALBPR;BALCSLFLO;BALCSLBPR;BALIDTCCE;BALCUR
If fstat=1
 GOK = -1
 GLOCK = "$BALPRCSL"-num$(BALTYP)-BALSOC-BALFCYLIN-num$(BALEXE)-BALACC-BALBPR-BALCSLFLO-BALCSLBPR-BALIDTCCE-BALCUR
 Return
Elsif fstat
 Raz [F:BLP]
 [F:BLP]LEDTYP = BALTYP
 [F:BLP]CPY    = BALSOC
 [F:BLP]FCY    = BALFCYLIN
 [F:BLP]FIY    = BALEXE
 [F:BLP]ACC    = BALACC
 [F:BLP]BPR    = BALBPR
 [F:BLP]CUR    = BALCUR
 [F:BLP]ACCNUM = uniqid([F:BLP])
 [F:BLP]LED    = BALLED
 [F:BLP]COA    = BALCOA
 [F:BLP]CURLED = BALCURLED
 Raz [F:BLP]IDTCCE
 [F:BLP]CSLFLO = BALCSLFLO
 [F:BLP]CSLBPR = BALCSLBPR
 [F:BLP]IDTCCE = BALIDTCCE

 For AXE=1 To dim([F:LED]DIE)
  Assign "[F:BLP]DIE("+num$(AXE-1)+")"  With evalue("TDIE("+num$(AXE-1)+")")
  Assign "[F:BLP]CCE"+num$(AXE)         With evalue("TCCE("+num$(AXE-1)+")")
 Next
 Gosub CALBAL_PRCSL
 Write [BLP]
Else
 Gosub CALBAL_PRCSL
 Rewrite [BLP]
Endif
If fstat
 GOK=0 : Call FSTA("BLP") From GLOCK : Return
Endif

Return

#############
## YYFIN_105932_8
#############
$CALBAL_PRCSL
If BALSNS=1
 [F:BLP]DEB(BALPER)    += SIGN*BALAMTCUR
 [F:BLP]DEBLED(BALPER) += SIGN*BALAMTLED
Else
 [F:BLP]CDT(BALPER)    += SIGN*BALAMTCUR
 [F:BLP]CDTLED(BALPER) += SIGN*BALAMTLED
Endif

# if carry-forward entries : PER=0
If BALREP
 If [F:BLP]DEB(BALPER)>[F:BLP]CDT(BALPER)
  [F:BLP]DEB(BALPER) = [F:BLP]DEB(BALPER) - [F:BLP]CDT(BALPER)
  [F:BLP]CDT(BALPER) = 0
 Else
  [F:BLP]CDT(BALPER) = [F:BLP]CDT(BALPER) - [F:BLP]DEB(BALPER)
  [F:BLP]DEB(BALPER) = 0
 Endif
 If [F:BLP]DEBLED(BALPER)>[F:BLP]CDTLED(BALPER)
  [F:BLP]DEBLED(BALPER) = [F:BLP]DEBLED(BALPER) - [F:BLP]CDTLED(BALPER)
  [F:BLP]CDTLED(BALPER) = 0
 Else
  [F:BLP]CDTLED(BALPER) = [F:BLP]CDTLED(BALPER) - [F:BLP]DEBLED(BALPER)
  [F:BLP]DEBLED(BALPER) = 0
 Endif
Endif

Return

###################################################
## <RUS>
Subprog BALDEM(SIGN)
Value Integer SIGN
Local Integer FLSOC : FLSOC = 1
Local Integer FLSIT : FLSIT = 1
Goto MAJ_BALDEM

## Sous-programme BALDEM2 appelé par le programme de resynchronisation de la balance 'Double Entry Method'
Subprog BALDEM2(SIGN,FLSOC,FLSIT)
Value Integer SIGN
Value Integer FLSOC
Value Integer FLSIT
Goto MAJ_BALDEM


$MAJ_BALDEM
If filinfo(filpath("FIL","BALDEM","fde",0),0)<0 or filinfo(filpath("FIL","BALDEMIDT","fde",0),0)<0 : End : Endif

Local Integer AXE
Local Integer BALSNS
Local Integer ISITE, ISOC
Local Integer I, J, K
Local Integer IVSREC       # Inverse Record

Local Integer BALTYP, BALEXE, BALPER, BALREP
Local Char    BALSOC(GLONCPY), BALFCY(GLONFCY)
Local Char    BALDEBACC(GLONGAC), BALCDTACC(GLONGAC)
Local Char    BALCUR(GLONCUR)
Local Char    BALDEBBPR(GLONBPR), BALCDTBPR(GLONBPR)
Local Integer BALIDTDEBCCE, BALIDTCDTCCE

Local Char    BALDEBSEC1(GLONCCE), BALDEBSEC2(GLONCCE), BALDEBSEC3(GLONCCE)
Local Char    BALDEBSEC4(GLONCCE), BALDEBSEC5(GLONCCE), BALDEBSEC6(GLONCCE)
Local Char    BALDEBSEC7(GLONCCE), BALDEBSEC8(GLONCCE), BALDEBSEC9(GLONCCE)
Local Char    BALCDTSEC1(GLONCCE), BALCDTSEC2(GLONCCE), BALCDTSEC3(GLONCCE)
Local Char    BALCDTSEC4(GLONCCE), BALCDTSEC5(GLONCCE), BALCDTSEC6(GLONCCE)
Local Char    BALCDTSEC7(GLONCCE), BALCDTSEC8(GLONCCE), BALCDTSEC9(GLONCCE)

If !clalev([F:DIE])  : Local File GDIE       [DIE]  : Endif
If !clalev([F:DAA9]) : Local File GACCENTRYA [DAA9] : Endif
If !clalev([F:BAM])  : Local File BALDEM     [BAM]  : Endif
If !clalev([F:BAI])  : Local File BALDEMIDT  [BAI]  : Endif

Raz BALDEBSEC1,BALDEBSEC2,BALDEBSEC3,BALDEBSEC4,BALDEBSEC5,BALDEBSEC6,BALDEBSEC7,BALDEBSEC8,BALDEBSEC9
Raz BALCDTSEC1,BALCDTSEC2,BALCDTSEC3,BALCDTSEC4,BALCDTSEC5,BALCDTSEC6,BALCDTSEC7,BALCDTSEC8,BALCDTSEC9

If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
 ISITE = find([F:HAE]FCY,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 BALSOC = GSOCSITE(ISITE)
 ISOC = find(BALSOC,GSOC(1..GNBSOC))
 If !ISOC : End : Endif
 BALTYP    = [F:DAA]LEDTYP
 BALCUR    = [F:DAA]CUR
 BALEXE    = [F:HAE]FIY
 BALREP    = 0
 BALPER    = [F:HAE]PER
 BALSNS    = [F:DAA]SNS
 If BALSNS = 1 : # Débit
  BALDEBACC = [F:DAA]ACC
  BALDEBBPR = [F:DAA]BPR
  For AXE=1 To dim([F:LED]DIE)
   Assign "BALDEBSEC"+num$(AXE) With evalue("[F:DAA]CCE("+num$(AXE-1)+")")
  Next
 Else          : # Crédit
  BALCDTACC = [F:DAA]ACC
  BALCDTBPR = [F:DAA]BPR
  For AXE=1 To dim([F:LED]DIE)
   Assign "BALCDTSEC"+num$(AXE) With evalue("[F:DAA]CCE("+num$(AXE-1)+")")
  Next
 Endif
 ## Lecture écriture de contrepartie :
 ## Dans les écritures du référentiel russe (Flagué 'Double Entry Method'), il n'y a pas de répartitions analytiques
 ## sur les lignes non éclatées (lignes qui ont le champ ACCNUMDOE<>0 dans le référentiel Russe). En effet, s'il y a une répartition
 ## analytique dans l'écriture du reférentiel d'origine et pour une ligne non éclatée (<>0), alors le programme de génération de pièces
 ## crée autant de couples 'Ecritures origine/Contrepartie' qu'il y a de lignes de ventilations analytiques sur la ligne non
 ## éclatée.
 Read [DAA9]DAA3 = [F:DAA]ACCNUM
 If !fstat
  If BALSNS = 1 : # BALSNS = 1 (Débit), donc la contrepartie, c'est du crédit...
   BALCDTACC = [F:DAA9]ACC
   BALCDTBPR = [F:DAA9]BPR
   For AXE=1 To dim([F:LED]DIE)
    Assign "BALCDTSEC"+num$(AXE) With evalue("[F:DAA9]CCE("+num$(AXE-1)+")")
   Next
  Else
   BALDEBACC = [F:DAA9]ACC
   BALDEBBPR = [F:DAA9]BPR
   For AXE=1 To dim([F:LED]DIE)
    Assign "BALDEBSEC"+num$(AXE) With evalue("[F:DAA9]CCE("+num$(AXE-1)+")")
   Next
  Endif
 Else
  Read [DAA9]DAA0 = [F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIN;[F:DAA]LEDTYP;1
  If !fstat
   If BALSNS = 1 : # BALSNS = 1 (Débit), donc la contrepartie, c'est du crédit...
    BALCDTACC = [F:DAA9]ACC
    BALCDTBPR = [F:DAA9]BPR
    For AXE=1 To dim([F:LED]DIE)
     Assign "BALCDTSEC"+num$(AXE) With evalue("[F:DAA9]CCE("+num$(AXE-1)+")")
    Next
   Else
    BALDEBACC = [F:DAA9]ACC
    BALCDTBPR = [F:DAA9]BPR
    For AXE=1 To dim([F:LED]DIE)
     Assign "BALDEBSEC"+num$(AXE) With evalue("[F:DAA9]CCE("+num$(AXE-1)+")")
    Next
   Endif
  Endif
 Endif

 Gosub BAL_DEM
 If GOK<1 : End : Endif

Endif
End


$BAL_DEM
## Update of Double Entry Balance
Readlock [BAI]BAI0 = BALDEBSEC1;BALDEBSEC2;BALDEBSEC3;BALDEBSEC4;BALDEBSEC5;BALDEBSEC6;BALDEBSEC7;BALDEBSEC8;BALDEBSEC9
If fstat=1
 GOK = -1 : GLOCK = "$BALDEMIDT"-num$(IDTCCE) : Return
Elsif fstat
 Raz [F:BAI]
 For AXE=1 To dim([F:LED]DIE)
  Assign "[F:BAI]CCE"+num$(AXE) With evalue("BALDEBSEC"+num$(AXE))
 Next
 [F:BAI]IDTCCE = uniqid([F:BAI])
 Write [BAI]
 If fstat
  GOK=0 : Call FSTA("BAI") From GLOCK : Return
 Endif
 BALIDTDEBCCE = [F:BAI]IDTCCE
Else
 BALIDTDEBCCE = [F:BAI]IDTCCE
Endif
Readlock [BAI]BAI0 = BALCDTSEC1;BALCDTSEC2;BALCDTSEC3;BALCDTSEC4;BALCDTSEC5;BALCDTSEC6;BALCDTSEC7;BALCDTSEC8;BALCDTSEC9
If fstat=1
 GOK = -1 : GLOCK = "$BALDEMIDT"-num$(IDTCCE) : Return
Elsif fstat
 Raz [F:BAI]
 For AXE=1 To dim([F:LED]DIE)
  Assign "[F:BAI]CCE"+num$(AXE) With evalue("BALCDTSEC"+num$(AXE))
 Next
 [F:BAI]IDTCCE = uniqid([F:BAI])
 Write [BAI]
 If fstat
  GOK=0 : Call FSTA("BAI") From GLOCK : Return
 Endif
 BALIDTCDTCCE = [F:BAI]IDTCCE
Else
 BALIDTCDTCCE = [F:BAI]IDTCCE
Endif
# MAJ Société
If FLSOC
 BALFCY = ""
 Gosub MAJBALDEM
 If GOK<1 : Return : Endif
Endif
If FLSIT
 # MAJ Site
 BALFCY = [F:DAA]FCYLIN
 Gosub MAJBALDEM
 If GOK<1 : Return : Endif
Endif
Return

$MAJBALDEM
## Key = LEDTYP+CPY+FCY+FIY+DEBACC+DEBBPR+CDTACC+CDTBPR+IDTDEBCCE+IDTCDTCCE+CUR
Readlock [BAM]BAM0 = BALTYP;BALSOC;BALFCY;BALEXE;BALDEBACC;BALDEBBPR;BALCDTACC;BALCDTBPR;BALIDTDEBCCE;BALIDTCDTCCE;BALCUR
If fstat=1
 GOK = -1 : GLOCK = "$BALDEM"-num$(BALTYP)-BALSOC-BALFCY-num$(BALEXE)-BALDEBACC-BALDEBBPR-BALCDTACC-BALCDTBPR : Return
Elsif fstat
 Raz [F:BAM]
 [F:BAM]LEDTYP    = BALTYP
 [F:BAM]CPY       = BALSOC
 [F:BAM]FCY       = BALFCY
 [F:BAM]FIY       = BALEXE
 [F:BAM]DEBACC    = BALDEBACC
 [F:BAM]DEBBPR    = BALDEBBPR
 [F:BAM]CDTACC    = BALCDTACC
 [F:BAM]CDTBPR    = BALCDTBPR
 [F:BAM]IDTDEBCCE = BALIDTDEBCCE
 [F:BAM]IDTCDTCCE = BALIDTCDTCCE
 [F:BAM]CUR       = BALCUR
 For AXE=1 To dim([F:LED]DIE)
  Assign "[F:BAM]DEBDIE("+num$(AXE-1)+")"  With evalue("[F:DAA]DIE("+num$(AXE-1)+")")
 Next
 For AXE = 1 To dim([F:LED]DIE)
  Assign "[F:BAM]DEBCCE("+num$(AXE-1)+")" With evalue("BALDEBSEC"+num$(AXE))
 Next
 For AXE=1 To dim([F:LED]DIE)
  Assign "[F:BAM]CDTDIE("+num$(AXE-1)+")"  With evalue("[F:DAA]DIE("+num$(AXE-1)+")")
 Next
 For AXE = 1 To dim([F:LED]DIE)
  Assign "[F:BAM]CDTCCE("+num$(AXE-1)+")" With evalue("BALCDTSEC"+num$(AXE))
 Next
 [F:BAM]LED    = [F:DAA]LED
 [F:BAM]COA    = [F:DAA]COA
 [F:BAM]CURLED = [F:DAA]CURLED
 Gosub CALBALDEM
 Write [BAM]
Else
 Gosub CALBALDEM
 Rewrite [BAM]
Endif
If fstat
 GOK=0 : Call FSTA("BAM") From GLOCK : Return
Endif
Return


$CALBALDEM
[F:BAM]AMTCUR(BALPER) += SIGN*[F:DAA]AMTCUR
[F:BAM]AMTLED(BALPER) += SIGN*[F:DAA]AMTLED
GPOINT = "CALBALDEM" : Gosub ENTREE From EXEFNC
Return
## <Fin dev RUS>

