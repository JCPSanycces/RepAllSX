#<AdxTL>@(#)10.0.0.0 $Revision$
#  INTRUTILC                       CC   20/02/2003
# 
#        Utilitaires Web
#
#   $CREREP_PUB     Création des répertoires Web   (appelé par DOSAPL)

Subprog CREREPPUB(APPLI)
Value Char APPLI

#  Initialise les variables nécessaires à CREREP_PUB pour DOSAPL
Local Char    REPERT(GDIMFIC) , ORDSYS(250)
Local Char    MACHINE(GDIMFIC) , REP(GDIMFIC) , SREP(GDIMFIC), FICH(GDIMFIC)
Local Char    DIRSEP(1)
Local Integer STAT , K , LANCUR , ERREUR

MACHINE = adxmac(0)

Case GOS(1)
 When "unix"
  DIRSEP="/"
 When "dos"
  DIRSEP="\"
Endcase

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI

Local Char APPLI1(10) : APPLI1=APPLI     
Gosub CREREP_PUB

End

# Crée les répertoires de publication d'un dossier X3
$CREREP_PUB

# X3_PUB est livré et doit exister avec le répertoire XSL chargé

Local Char REPTEST(100)
REPTEST=filpath("","","","X3_PUB")
Local Char DOSREF(10)
#If REPTEST="" or REPTEST=adxdir+DIRSEP+"X3_PUB"
#  Call PARAM("","SUPDOS",DOSREF) From ADOVAL
#  REPERT = filpath("","","",DOSREF)
#  J=instr(1,REPERT,DOSREF)
#  DOSREF = "X3_PUB"
#  REPERT=left$(REPERT,J-1)+DOSREF
#  Gosub CREREP from DOSAPL
#  REPERT+=DIRSEP+".users"
#  Openo REPERT Using [A_WE]
#  Openo Using [A_WE]
#Endif


DOSREF="X3_PUB"


# Crée les répertoires publiés du dossier (DOSS)

REPERT = filpath("","","","X3_PUB")
REP = APPLI1
REPERT = filpath(REP,"","",DOSREF) 
Call CREREP(REPERT,ERREUR) From DOSAPL 

REP = APPLI1+DIRSEP+"GEN"
REPERT = filpath(REP,"","",DOSREF) 
Call CREREP(REPERT,ERREUR) From DOSAPL 

REP = APPLI1+DIRSEP+"TMP"
REPERT = filpath(REP,"","",DOSREF) 
Call CREREP(REPERT,ERREUR) From DOSAPL 

REP = APPLI1+DIRSEP+"RES"
REPERT = filpath(REP,"","",DOSREF) 
Call CREREP(REPERT,ERREUR) From DOSAPL 

REP = APPLI1+DIRSEP+"GEN"+DIRSEP+"ALL"
REPERT = filpath(REP,"","",DOSREF) 
Call CREREP(REPERT,ERREUR) From DOSAPL 

For SREP="WIND","SCRN","OBJT","STY","PAR","WEBS","OBJTJ","SCRNJ","WINDJ"
  REP = APPLI1+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+SREP
  REPERT = filpath(REP,"","",DOSREF) 
  Call CREREP(REPERT,ERREUR) From DOSAPL 
Next SREP

For LANCUR=0 To [F:ADS]NBRLAN-1
  REP = APPLI1+DIRSEP+"GEN"+DIRSEP+[F:ADS]LAN(LANCUR)
  REPERT = filpath(REP,"","",DOSREF) 
  Call CREREP(REPERT,ERREUR) From DOSAPL 
  For SREP="WINA","MENL","FENX","FENW","FENS","HTML","PROF","SRVL","FENT"
    REP = APPLI1+DIRSEP+"GEN"+DIRSEP+[F:ADS]LAN(LANCUR)+DIRSEP+SREP
    REPERT = filpath(REP,"","",DOSREF) 
    Call CREREP(REPERT,ERREUR) From DOSAPL 
  Next SREP
Next LANCUR

# Création des répertoires Syracuse
Call GLOBWEB(APPLI1) From INTRUTILA
REP = APPLI1+DIRSEP+"GEN"+DIRSEP+"SYR"
REPERT = filpath(REP,"","",DOSREF) 
Call CREREP(REPERT,ERREUR) From DOSAPL 
For I=1 To GI_NBLAN
    REP = APPLI1+DIRSEP+"GEN"+DIRSEP+"SYR"+DIRSEP+ISOLAN(I)
    REPERT = filpath(REP,"","",DOSREF) 
    Call CREREP(REPERT,ERREUR) From DOSAPL 
    REP = APPLI1+DIRSEP+"GEN"+DIRSEP+"SYR"+DIRSEP+ISOLAN(I)+DIRSEP+"FENJ"
    REPERT = filpath(REP,"","",DOSREF) 
    Call CREREP(REPERT,ERREUR) From DOSAPL 
Next I



### Création dossier X_TEND sous X3_PUB si code activité est activé.
If filinfo(filpath("FIL","ACTIV","fde",APPLI1),0)>0
 If !clalev([F:ADA]) : Local File ADOSACT [ADA] : Endif
 Local File =APPLI1+".ACTIV" [ACX] 
 Read [ACX]CODACT="AYT"
 If [F:ACX]FLACT<>2
  Read [ADA]ADA0 = APPLI1;[F:ACX]CODACT
  If !fstat & [F:ADA]FLACT=2
   REP = "X_TEND"
   REPERT = filpath(REP,"","","X3_PUB")
   Call CREREP(REPERT,ERREUR) From DOSAPL 
  Endif
 Endif
 Close Local File [ACX]
Endif

Return

# ------------------------------------------------------------------

Subprog CREX3ROOT

#             Création des répertoires d'X3_ROOT si ils n'existent pas

Local Integer NBLAN
Local Char TLAN(10)(1..50)

#  Charge la liste globale des langues de la solution
Call GLOBLANG(TLAN,NBLAN) From INTRUTILA
Gosub CREX3RLIBRE
End

$CREX3RLIBRE
Local Integer I, K, STAT
Local Char    REPERT(GDIMFIC) , ORDSYS(250), DIRSEP, RESULT(200)(1..10)
Local Char    MACHINE(GDIMFIC) , REP(GDIMFIC)

MACHINE = adxmac(0)

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
     
#  Crée les répertoires d'X3_ROOT si ils n'existent pas déjà

REP = "X3_ROOT"+DIRSEP+"GEN"
Gosub CREREP
REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"
Gosub CREREP
REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"
Gosub CREREP
For I=1 To NBLAN
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)
  Gosub CREREP
  REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+TLAN(I)+DIRSEP+"LIB"
  Gosub CREREP
Next I

REP = "X3_ROOT"+DIRSEP+"X3CLI"
Gosub CREREP

REP = "X3_ROOT"+DIRSEP+"RESSTD"
Gosub CREREP
REP = "X3_ROOT"+DIRSEP+"RESSTD"+DIRSEP+"IMG"
Gosub CREREP
REP = "X3_ROOT"+DIRSEP+"RESSTD"+DIRSEP+"DIV"
Gosub CREREP

REP = "X3_ROOT"+DIRSEP+"RESVER"
Gosub CREREP
REP = "X3_ROOT"+DIRSEP+"RESVER"+DIRSEP+"IMG"
Gosub CREREP
REP = "X3_ROOT"+DIRSEP+"RESVER"+DIRSEP+"DIV"
Gosub CREREP

REP = "X3_ROOT"+DIRSEP+"RESPER"
Gosub CREREP
REP = "X3_ROOT"+DIRSEP+"RESPER"+DIRSEP+"IMG"
Gosub CREREP
REP = "X3_ROOT"+DIRSEP+"RESPER"+DIRSEP+"DIV"
Gosub CREREP
Return

$CREREP
REPERT = filpath(REP,"","","X3_PUB") 
If filinfo(REPERT,0)<0
 K = instr(1,REPERT,"@")
 If K
  ORDSYS = 'ae_mkdir'-'"'+right$(REPERT,K+1)+'"'
 Else
  ORDSYS = 'ae_mkdir'-'"'+REPERT+'"'
 Endif
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 If filinfo(REPERT,0)<0
  Call ECR_TRACE(mess(184,124,1)+"\|"+ctrans(REPERT,"\","/")+"|",1) From GESECRAN
  Return
 Endif
Endif
Return

# ------------------------------------------------------------------------------

Subprog CRELIBWEBD(APPLI)

#             Création de la liste des langues du dossier

Value Char APPLI

Local Char VALL1(200)
Local Char NOMFIC(200)
Local Integer NBVAL,I,K,ER
Local Char    REPERT(GDIMFIC) , ORDSYS(250), DIRSEP, RESULT(200)(1..10)
Local Char    MACHINE(GDIMFIC) , REP(GDIMFIC)
Local Char    LANDES(GLONDES), SAVGLANG, LISO
Local Integer STAT
MACHINE = adxmac(0)

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

Call GLOBWEB(APPLI) From INTRUTILA

# Test d'ouverture et lecture de la table des langues
Onerrgo ERR

If clalev([F:TLA])=0  : Local File =APPLI+".TABLAN" [TLA]  : Endif        
If clalev([F:AST])=0  : Local File =APPLI+".APLSTD" [AST]  : Endif        

Read [TLA]TLA0 First
Onerrgo
If ER : Goto FIN : Endif
 
#     connectx3langs.xml  : table des langues du dossier

REP = GI_DOSS+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"PAR"
Gosub CREREP From INTRUTILC
REPERT = filpath(REP,"","","X3_PUB") 
If filinfo(REPERT,0)<0 : Goto FIN : Endif    :#  Bug 50505 - 25/11/2008 X3_PUB n'est pas encore là pour un dossier migré
Call NAMEFIC(GI_DOSS,"PAR","","connectx3langs",NOMFIC) From INTRUTILA
Openo NOMFIC,0 Using [CST_]
Iomode adxifs "" Using [CST_]
Iomode adxirs chr$(10) Using [CST_]
Iomode adxium GUTF8 Using [CST_]
VALL1='<?xml version="1.0" encoding="utf-8" ?>'
Wrseq VALL1 Using [CST_]
VALL1='<langues>'
Wrseq VALL1 Using [CST_]
For I=1 To GI_NBLAN
  Read [TLA]TLA0=GI_LLAN(I)
  VALL1='<langue num="'+format$("N0:##",I)+'" id="'+GI_LLAN(I)+'" locale="'
  Call LECTEXTRA(LANDES,"TABLAN","INTDES",GI_LLAN(I),"") From ATEXTRA
  If dim([F:TLA]LANISO)>0
    LISO=[F:TLA]LANISO
  Else
    LISO=GI_LLAN(I)+"_"+GI_LLAN(I)
  Endif
  VALL1+=LISO+'" lib="'+LANDES+'"'
  If GI_LLAN(I)=GI_LANDEF
    VALL1+=' def="yes"'
  Endif
  VALL1+="/>"
  Wrseq VALL1 Using [CST_]
Next I
VALL1='</langues>'
Wrseq VALL1 Using [CST_]
Openo Using [CST_]

$FIN
If clalev([F:TLA])>0 : Close Local File [TLA] : Endif
If clalev([F:AST])>0 : Close Local File [AST] : Endif
End

$ERR
ER = errn
Resume


