#<AdxTL>@(#)0.0.0.0 $Revision$ Library that manages the CSV f

#** #############################################################################################
#* Open file and write common data to the file
#*
#*  @param FILEN      Value Char          File directory
#*
#*  @param DCLTYPE    Value Integer       Type of declaration
#*  USTVA = 1
#*  DAU   = 2
#*  Recap. stat. = 3
#*
#*  @param CPY        Value Char          Company
#*
#*  @param DATEF      Value Date          Date from
#*
#*  @param DATET      Value Date          Date to
#*
#*  @param CORRECTED  Value Date          Corrected declaration 0 -> NO; 1 -> YES
#*
#*  @param CORRECTED  Value Date          Submission (only RST) 0 -> NO; 1 -> YES
#*
#*  @param CORRECTED  Value Date          Withdrawal (only RST) 0 -> NO; 1 -> YES
#*
#*! #############################################################################################
Subprog INITFILE(FILEN, DCLTYPE, GROUP, COMP, DATEF, DATET, CORRECTED, SUBMISS, WITHDRAWAL)
  Value Char FILEN
  Value Integer DCLTYPE         #Declaration type 1 = ustva, 2 = dau , 3 = zm
  Value Char GROUP
  Value Char COMP
  Value Date DATEF           #Startdate
  Value Date DATET           #Enddate
  Value Integer CORRECTED
  Value Integer SUBMISS
  Value Integer WITHDRAWAL

  Local Char TAXNO(255)
  Local Char EECNO(255)
  Local Char PTPNO(255)
  Local Char ELMA5NO(255)
  Local Char COUNTRY(255)
  Local Char FEDSTATE(255)
  #add additional year for dau
  Local Integer ADDYEAR : ADDYEAR = 1

  #setcompany related values (Taxnumber, EECNumber, participant number etc.)
  Call SETCPYVALUES(func GETCOMPORGROUP(GROUP, COMP), TAXNO, EECNO, PTPNO, ELMA5NO, COUNTRY, FEDSTATE)
  #open the file
  Gosub OPENFILE
  #Write common data to the file
  Gosub WRITECOMMONDATA
End

#** #############################################################################################################
#*
#* Sub chunk:  OPENFILE
#*
#* Purpose:    Opens the x3eft file for writing and sets the record seperator (adxirs) and the field
#*             seperator (adxifs)
#*
#*! #############################################################################################################
$OPENFILE
# 2014-05-16 DNE MODIF BEGIN (US #729)
  Openo FILEN, 0
# 2014-05-16 DNE MODIF
#  Openo FILEN + func GETFILENAME(DCLTYPE), 0
# 2014-05-16 DNE MODIF
  adxirs = chr$(13) + chr$(10)
  adxifs = ";"
Return


#** #############################################################################################################
#*
#* Sub chunk:  WRITECOMMONDATA
#*
#* Purpose:    Calls several chunks for writing the common data
#*             - ADDRESSQUERY -> generats the query for adressinformation of the company
#*             - WRITEHEADERANDINFO -> writes info line and headerinformation to the file
#*             - WRITEADDRESS -> writes addressdata to the file
#*             - WRITEX3DATA -> write additional information for the elster client to the file
#*
#*! #############################################################################################################
$WRITECOMMONDATA
  Gosub ADDRESSQUERY
  Gosub WRITEHEADERANDINFO
  Gosub WRITEADDRESS
  Gosub WRITEX3DATA
Return


#** #############################################################################################################
#*
#* Sub chunk:  WRITEHEADERANDINFO
#*
#* Purpose:    writes info line and headerinformation to the file
#*
#*! #############################################################################################################

$WRITEHEADERANDINFO
  Local Char DTYPEVAL(30)
  If DCLTYPE = 1
    DTYPEVAL = "UStVA"
  Elsif DCLTYPE = 2
    DTYPEVAL = "DAU"
  Elsif DCLTYPE = 3
    DTYPEVAL = "ZMDO"
  Endif
  Call WRITEFILELINE(7,9,"Index","Subkey","Value",0)
  Call WRITEFILELINE(1, 1,"0","Info", "Firma - " + [L]COMP - "Datum - " - func GETDATESTRING(date$,0),0)
  Call WRITEFILELINE(2, 8, "0", "", DTYPEVAL,0)
  For [LNKA]
    Call WRITEFILELINE(2, 2, "0", "", [F:CPY_]CPYNAM,0)
  Next
  Call WRITEFILELINE(2, 10,"0","", PTPNO,0)
  Call WRITEFILELINE(2, 11,"0","", ELMA5NO,0)

Return

#** #############################################################################################################
#*
#* Sub chunk:  ADDRESSQUERY
#*
#* Purpose:    generates the query for adressinformation of the company
#*
#*! #############################################################################################################
$ADDRESSQUERY

  Local Char ADDRCOMP(30)
  ADDRCOMP = func GETLECOMPANY(GROUP, COMP)
  If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
  If clalev([F:CPY_])=0 : Local File COMPANY    [CPY_] : Endif

  Link [F:CPY_] With
&  [F:BPA]BPA0 = 2;[F:CPY_]CPY ; [F:CPY_]BPAADD
&  As [LNKA]
&  Where [F:CPY_]CPY = [L]ADDRCOMP
& & [F:BPA]BPATYP = 2
& & [F:BPA]BPANUM = [L]ADDRCOMP

Columns [LNKA] ([F:CPY_]CPYNAM,[F:CPY_]CPY, [F:BPA]BPAADDLIG, [F:BPA]POSCOD, [F:BPA]TEL, [F:BPA]CTY, [F:BPA]BPANUM, [F:BPA]CRY, [F:BPA]CRYNAM)
Return


#** #############################################################################################################
#*
#* Sub chunk:  WRITEADDRESS
#*
#* Purpose:    writes adressinformation of the company to the file
#*
#*! #############################################################################################################

$WRITEADDRESS
  Local Integer I : I = 0
  Local Integer LTYP : LTYP = 4
  Local Integer LSCOPE : LSCOPE = 0
  For I=0 To 1 # muss mann abklären ob die typen durcheinander stehen können. falls ja, ist der zweite durchlauf nicht nötig
    If I = 0 : LSCOPE = 2: Elsif I = 1 : LSCOPE = 4 : Endif
    For [LNKA]
      Call WRITEFILELINE(LTYP, LSCOPE,"0","Name", [F:CPY_]CPYNAM,0)
        # SAM 90897-2 angre 26.03.14
       If I = 1 and DCLTYPE <> 3
          Call WRITEFILELINE(LTYP, LSCOPE,"0","Str", [F:BPA]BPAADDLIG,0)
          Call WRITEFILELINE(LTYP, LSCOPE,"0","Land", [F:BPA]CRYNAM,0)
        Else
          Call WRITEFILELINE(LTYP, LSCOPE,"0","Strasse", [F:BPA]BPAADDLIG,0)
          Call WRITEFILELINE(LTYP, LSCOPE,"0","Staat", [F:BPA]CRY,0)
        Endif
      Call WRITEFILELINE(LTYP, LSCOPE,"0","PLZ", [F:BPA]POSCOD,0)
      Call WRITEFILELINE(LTYP, LSCOPE,"0","Ort", [F:BPA]CTY,0)
      Call WRITEFILELINE(LTYP, LSCOPE,"0","Telefon", [F:BPA]TEL,0)
      Next
  Next

Return

#** #############################################################################################################
#*
#* Sub chunk:  WRITEX3DATA
#*
#* Purpose:    write additional information for the elster client to the file
#*
#*! #############################################################################################################
$WRITEX3DATA

  Call WRITEFILELINE(4, 6,"0","Erstellungsdatum", func GETDATESTRING(date$, 0),0)
  If DCLTYPE = 2
  Call WRITEFILELINE(4, 6,"0","Zeitraum_von", func GETDATESTRING(DATEF,1),0)
  Call WRITEFILELINE(4, 6,"0","Zeitraum_bis",func GETDATESTRING(DATET,1),0)
  Else
    Call WRITEFILELINE(4, 6,"0","Zeitraum_von", func GETDATESTRING(DATEF,0),0)
    Call WRITEFILELINE(4, 6,"0","Zeitraum_bis",func GETDATESTRING(DATET,0),0)
  Endif
  Call WRITEFILELINE(4, 6,"0","Steuernummer", TAXNO,0)
  Call WRITEFILELINE(4, 6,"0","UStId_DE ", EECNO,0)
  #Call WRITEFILELINE(4, 6,"0","Teilnehmernr", PTPNO)
  Call WRITEFILELINE(4, 6,"0","Bundesland", FEDSTATE,0)
  Call WRITEFILELINE(4, 6,"0","Berichtigte_meldung", num$(CORRECTED),0)
  Call WRITEFILELINE(4, 6,"0","Anzeige", num$(SUBMISS),0)
  Call WRITEFILELINE(4, 6,"0","Widerruf", num$(WITHDRAWAL),0)

Return

#** #############################################################################################################
#*
#* Subprog:  WRITEFILELINE
#* Subprogramm for writing a line to the file
#*
#* @param   Integer TYP    Number of the Linetype of the line to write
#* @param   Integer SCOPE  Number of the Scope (Key) of the line to write
#* @param   Char ITEM      Index of the line (of the same type, scope and subkey)
#* @param   Char VKEY      Subkey of the line
#* @param   Char VVALUE    Value of the line
#*
#*
#*! #############################################################################################################
Subprog WRITEFILELINE(TYP, SCOPE, ITEM, VKEY, VVALUE, VALUETYPE)
Value Integer TYP
Value Integer SCOPE
Value Char ITEM
Value Char VKEY
Value Char VVALUE
Value Integer VALUETYPE

  # if value not empty then write the line to the file
  If VVALUE <> "" Then
    Gosub WRITELINE
  Endif

End

#** #############################################################################################################
#*
#* Sub chunk:  WRITELINE
#*
#* Purpose:    write a line to the x3eft file
#*
#*! #############################################################################################################
$WRITELINE
  Case VALUETYPE
    When 1:  VVALUE = "D" + VVALUE #mark as decimal
    When 2:  VVALUE = "I" + VVALUE #mark as integer
  Endcase
  #If VALUETYPE = 1 : VVALUE = "D" + VVALUE : Endif #mark value as decimal
  Wrseq func GETTYPE(TYP), ITEM, func GETSCOPE(SCOPE), VKEY, '"' + VVALUE + '"'
Return

$CLOSEFILE
  Openo
  #Call WRITEDPVAL(1,0)
Return

#** #############################################################################################################
#*
#* Function:  GETTYPE
#* Function that returns the name of the type for a given type ID
#*    1 => "Info"
#*    2 => "TransferHeader"
#*    3 => "Nutdatenheader"
#*    4 => "Nutzdaten"
#*    5 => "Sonder"
#*    6 => "Zm"
#*    7 => "Type"
#*
#* @param   Integer TYP    Number of the Linetype of the line to write
#*
#*! #############################################################################################################
Funprog GETTYPE(TYP)
Value Integer TYP
Local Char RESULT(30)
  Case TYP
    When 1 : RESULT = "Info"
    When 2 : RESULT = "TransferHeader"
    When 3 : RESULT = "Nutdatenheader"
    When 4 : RESULT = "Nutzdaten"
    When 5 : RESULT = "Sonder"
    When 6 : RESULT = "Zm"
    When 7 : RESULT = "Type"
  Endcase
End RESULT


#** #############################################################################################################
#*
#* Function:  GETSCOPE
#* Function that returns the name of the scope for a given scope ID
#*    1 => "Info"
#*    2 => "DatenLieferant"
#*    3 => "Berater"
#*    4 => "Unternehmer"
#*    5 => "Kz"
#*    6 => "X3"
#*    7 => "Zeile"
#*    8 => "Steuerart"
#*    9 => "Key"
#*   10 => "RegId"
#*   11 => "Senderkennung"
#* @param   Integer TYP    Number of the Linetype of the line to write
#*
#*! #############################################################################################################
Funprog GETSCOPE(SCOPE)
Value Integer SCOPE
Local Char RESULT(30)
  Case SCOPE
    When 1 : RESULT = "Info"
    When 2 : RESULT = "DatenLieferant"
    When 3 : RESULT = "Berater"
    When 4 : RESULT = "Unternehmer"
    When 5 : RESULT = "Kz"
    When 6 : RESULT = "X3"
    When 7 : RESULT = "ZM"
    When 8 : RESULT = "Steuerart"
    When 9 : RESULT = "Key"
    When 10: RESULT = "RegId"
    When 11: RESULT = "Senderkennung"
    When 12: RESULT = "kennung"
  Endcase
End RESULT


#** #############################################################################################################
#*
#* Function:  GETDATESTRING
#* Function that returns the string for a given date in the following format dd.mm.yyyy
#*
#* @param   Date DAT    Date for wich the string is needed
#* @param   Date ADDYEAR    Count of years to add (needed for DAU)
#*
#*! #############################################################################################################
Funprog GETDATESTRING(DAT, ADDYEAR)
  Value Date DAT
  Value Integer ADDYEAR
  Local Char RESULT(30)
  #add 1 year if DAU
  RESULT = num$(day(DAT)) + "." + num$(month(DAT)) + "." + num$(year(DAT)+ADDYEAR)
End RESULT


#** #############################################################################################################
#*
#* Subprog:  SETCPYVALUES
#* Sets taxnumber, ustid, participant number and country for a given company
#*
#* @param   Char COMP       Company
#* @param   Char TAXNO      Taxnumber
#* @param   Char EECNO      UstId
#* @param   Char PTPNO      Paricipant number
#* @param   Char ElMA5NO    ELMA5 number
#* @param   Char COUNTRY    Country
#* @param   Char FEDSTATE   Federal state
#*
#*
#*! #############################################################################################################
Subprog SETCPYVALUES(COMP, TAXNO, EECNO, PTPNO, ELMA5NO, COUNTRY, FEDSTATE)
Value Char COMP
Variable Char TAXNO
Variable Char EECNO
Variable Char PTPNO
Variable Char ELMA5NO
Variable Char COUNTRY
Variable Char FEDSTATE

  If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
   Read [F:CPY]CPY0 = COMP
    If !fstat
      COUNTRY = [CPY]CRY
      PTPNO = [CPY]GERPTP
      FEDSTATE = func GETFEDSTATE([CPY]STAFED)
      For I = 0 To dim([CPY]GERTAXIDT) - 1
        If [CPY]GERDEFVAL(I) - 1
            TAXNO = [CPY]GERTAXIDT(I)
            EECNO = [CPY]GEREECNUM(I)
            ELMA5NO = [CPY]GERCODELMA5(I)
            Break
        Endif
      Next
    Endif
End


#** ########################################################################################################################
#*
#* Function:  GETFEDSTATE
#* Function that returns the abbriviation of a federal state of germany for a given codeId of the
#* corresponding line in  misc. table 80
#*
#* @param   Char FEDSTATEID  codeId of a line in the misc table for federal states of germany (80)

#*! ########################################################################################################################
Funprog GETFEDSTATE(FEDSTATEID)
Value Char FEDSTATEID
Local Char FEDSTATELONG(30)
Local Char RESULT(30)

  Call LECTEXTRA(FEDSTATELONG,"ATABDIV","LNGDES",num$(80),FEDSTATEID) From ATEXTRA
  RESULT = func GETFEDSTATEABB(FEDSTATELONG)

End RESULT


#** #############################################################################################################
#*
#* Function:  GETFEDSTATEABB
#* Function that returns the abbriviation for a given federal state of germany
#*
#* @param   Char FSLNG  Long description of a federal state of germany

#*! #############################################################################################################
Funprog GETFEDSTATEABB(FSLNG)
Value Char FSLNG
Local Char RESULT(3)
  Case FSLNG
    When "Schleswig-Holstein" : RESULT = "SH"
    When "Hamburg" : RESULT = "HH"
    When "Niedersachsen" : RESULT = "ND"
    When "Bremen" : RESULT = "HB"
    When "Nordrhein-Westfalen" : RESULT = "NW"
    When "Hessen" : RESULT = "HE"
    When "Rheinland-Pfalz" : RESULT = "RP"
    When "Baden-Württemberg" : RESULT = "BW"
    When "Bayern" : RESULT = "BY"
    When "Saarland" : RESULT = "SL"
    When "Berlin" : RESULT = "BE"
    When "Brandenburg" : RESULT = "BB"
    When "Mecklenburg-Vorpommern" : RESULT = "MV"
    When "Sachsen" : RESULT = "SN"
    When "Sachsen-Anhalt" : RESULT = "ST"
    When "Thüringen" : RESULT = "TH"
  Endcase
End RESULT

#** #############################################################################################################
#*
#* Function:  GETFILENAME
#* Function that returns filename for a given declaration type ID
#*
#* @param   Integer DCLTYPE  Index for the declaration type
#*    1 => "UStVA"
#*    2 => "Recapitulativ statement"
#*    3 => "Dauerfristverlängerung"
#*! #############################################################################################################
Funprog GETFILENAME(DCLTYPE)
Value Integer DCLTYPE
Local Char IDPART(30)
Local Char RESULT(30)

  Local Char DIRSEP(3) : DIRSEP = func GDPDU1.GETDIRSEPARATOR
  Case DCLTYPE
    When 1 : IDPART = DIRSEP + "DCLVAT_GER_"
    When 2 : IDPART = DIRSEP+ "DCLDAU_GER_"
    When 3 : IDPART = DIRSEP + "DCLRST_GER_"
  Endcase

  RESULT = IDPART + num$(year(date$)) + num$(month(date$)) + ".x3etf"
End RESULT


#** ########################################################################################################
#*
#* Function:      CHECKFILE
#*
#* Purpose:       Check if path and/or file already exists
#*
#* Return:        Value depending on Parameter PER
#*                1 -> Flag that indicates that discount was calculated with reduced accounting date
#*                2 -> DISCOUNT AMOUNT
#*                3 -> Discount rate
#*
#* Parameters:
#* @param Integer DIR       Directory
#* @param Integer DCLTYPE   Id for the declaration type
#*    1 => "UStVA"
#*    2 => "Dauerfristverlängerung"
#*    3 => "Recapitulativ statement"
#*
#*
#*! ########################################################################################################
Funprog CHECKFILE(DIR, DCLTYPE)
  Value Char DIR
  Value Integer DCLTYPE
  Local Integer RESULT : RESULT = 1
  Local Integer FILEEXISTS
  Local Char FILENAMERS(255)
  RESULT = func CHECK_PATH(DIR)
  If RESULT = 1
    FILENAMERS = DIR + func GETFILENAME(DCLTYPE)
    Call EXISTE( FILENAMERS, FILEEXISTS ) From ORDSYS
    If FILEEXISTS = 1
        Local Integer YESNO : YESNO = 1 # NO.
        Call OUINONT( mess(260,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMERS, "\", "/" ), YESNO ) From GESECRAN # "Data already exists.\Do you want to overwrite it?"
        If YESNO = 1 # No
            RESULT = 0
        Endif
    Endif
  Endif
End RESULT



#** #############################################################################################################
#*
#* Function that checks if the given Path exists or not
#*
#* @param Value Char PATH        Path to check
#* @return  Integer Result       1 -> exists; 2 -> exists not
#*! #############################################################################################################
Funprog CHECK_PATH(PATH)
Value Char PATH
Local Integer EXISTS
Local Integer RESULT : RESULT = 1

Call EXISTE( PATH, EXISTS ) From ORDSYS
  If !EXISTS
    Call ERREURT( mess(111,148,1), 1 ) From GESECRAN
    RESULT = 0
  Endif
End RESULT






#** #############################################################################################################
#*
#* Function that returns either the group or the company
#*
#* @param Value Char Group       Group of companys
#* @return  Value Char Company   Company
#*! ##############################################################################################
Funprog GETCOMPORGROUP(GROUP, COMPANY)
    Value Char GROUP
    Value Char COMPANY
    Local Char RESULT(8)
    If GROUP <> ""
        RESULT = GROUP
    Else
        RESULT = COMPANY
    Endif
End RESULT

#** #############################################################################################################
#*
#* Function that returns either the leading company of a group or the company itself
#*
#* @param Value Char Group       Group of companys
#* @return  Value Char Company   Company
#*! ##############################################################################################
Funprog GETLECOMPANY(GROUP, COMPANY)
    Value Char GROUP
    Value Char COMPANY
    Local Char RESULT(255)

   If GROUP = ""
    RESULT = COMPANY
   Else
    Call PARAM(GROUP,"VATLECMP",RESULT) From ADOVAL
   Endif

End RESULT




