#<AdxTL>@(#)6.0.0.0 $Revision$
# FGR 15/04/2009 : X3SUIVI54325
# Moulinette pour entretenir les status CLO de OMM/OMT/OMN
  Call MAJ_UTICRM006(nomap)
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  Call MAJ_UTICRM006(APPLI)
End

########################################################################
Subprog MAJ_UTICRM006(DOSSIER)
Value Char DOSSIER

Local Integer IERR
Local Integer B_OK

  If DOSSIER = "X3" Then
    End 
  Endif
  #------------------------------------------------------
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
  Call ECR_TIME("Initialisation des statuts CLOS pour les OMM/OMT/OMN") From DOSSUB
  #------------------------------------------------------
  IERR = 0
  Call ECR_TIME("DEBUT => Initialisation des statuts") From DOSSUB
  Call CRMSTEP6(DOSSIER, IERR) From CRMMAJ30
  Call ECR_TIME("FIN => Sur les correspondants") From DOSSUB
  #------------------------------------------------------
End
