Subprog S_LBEFMT(VALEUR)
Variable Char    VALEUR()
Call SELECT("ARP","",VALEUR,"") From SELOBJ
End

########################################
Subprog C_LBEFMT(VALEUR)
Variable Char    VALEUR()
Local Char AUTSIT(10)
Local Integer OK
If VALEUR = "" : End : Endif
Read [F:ARP]ARP0 = VALEUR
If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
Call VERF_DROIT(VALEUR,GUSER,OK,AUTSIT) From ETAT
If !OK 
 GMESSAGE = mess(3,135,1)  : # Vous n'avez pas accès à cet état
 mkstat = 1
 End      
Endif 
End

########################################
Subprog B2_NBLIG
Case [M:LBE1]LBEVCRTYP
  When 2 :
    Call OBJET("MFG",[M:LBE1]VCRNUM,"") From GOBJET
  When Default :
    Local Char PARAM(20)(1..8)
    PARAM(1) = "2"
    PARAM(2) = [M:LBE1]STOFCY
    PARAM(3) = [M:LBE1]ITMREF(nolign-1)
    PARAM(4) = ""
    PARAM(5) = ""
    Case [M:LBE1]LBEVCRTYP
      When 1 : PARAM(6) = "6"
      When 3 : PARAM(6) = "13"
      When 4 : PARAM(6) = "15"
      When 5 : PARAM(6) = "16"
    Endcase
    PARAM(7) = [M:LBE1]VCRNUM
    PARAM(8) = "[M:LBE1]FLT"
    [M:LBE1]FLT  = "[F:STJ]VCRNUM=[M:LBE1]VCRNUM"
    [M:LBE1]FLT += "&[F:STJ]UPDCOD=[M:LBE1]UPDCOD(nolign-1)"
    [M:LBE1]FLT += "&[F:STJ]MVTSEQ= [M:LBE1]MVTSEQ(nolign-1)"
    Call GCONSULT("SMV","",PARAM) From GCONSULT
Endcase
End
