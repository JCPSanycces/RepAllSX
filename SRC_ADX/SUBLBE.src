########################################
Subprog AM_LBEFMT(VALEUR)
Variable Char    VALEUR()
Local    Char    ETAT, ETAT2
Call TRADUC(1,VALEUR,ETAT) From SUBATC
# Choix de l'état en fonction du code interne
Call SAIETAT(ETAT,ETAT2) From ETAT
Read [F:ARP]ARP0 = ETAT2
If !fstat & [F:ARP]PRTNAM <> ""
    [M:LBE1]DEFIMP(nolign-1) = [F:ARP]PRTNAM
Endif
End

