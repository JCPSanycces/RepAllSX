#CHECK UNUSED_SOURCE
########################################
Subprog S_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
Case [M:LBE1]LBEVCRTYP :
     When 1  : Filter [F:PTH] Where PRHFCY = [M:LBE1]STOFCY 
               Call SELECT("PTH","",VALEUR,"") From SELOBJ
               Filter [F:PTH]
     When 2  : Filter [F:MFG] Where MFGFCY = [M:LBE1]STOFCY & MFGSTA = 1
               Call SELECT("MFG","",VALEUR,"") From SELOBJ
               Filter [F:MFG]
     When 3  : Filter [F:SRH] Where STOFCY = [M:LBE1]STOFCY 
               Call SELECT("SRH","",VALEUR,"") From SELOBJ
               Filter [F:SRH]
     When 4  : Filter [F:MTK] Where MFGFCY = [M:LBE1]STOFCY
               Call SELECT("MTK","",VALEUR,"") From SELOBJ
               Filter [F:MTK] 
     When 5  : Call SELMVT([M:LBE1]STOFCY,VALEUR, 16) From FUNLBEIMP      # réintégration 9727
     When 6  : Call SELMVT([M:LBE1]STOFCY,VALEUR, 12) From FUNLBEIMP      # réintégration 9727
Endcase
End

########################################
Subprog AM_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]VCRNUMEND = ""     : [M]VCRNUMEND = VALEUR : Affzo [M]VCRNUMEND : Endif    # 9727
If [M]VCRNUMEND < VALEUR : [M]VCRNUMEND = VALEUR : Affzo [M]VCRNUMEND : Endif    # 9727

End


########################################
Subprog S_VCRNUMEND(VALEUR)
Variable Char    VALEUR()
Case [M:LBE1]LBEVCRTYP :
     When 1  : Filter [F:PTH] Where PRHFCY = [M:LBE1]STOFCY 
               Call SELECT("PTH","",VALEUR,"") From SELOBJ
               Filter [F:PTH]
     When 2  : Filter [F:MFG] Where MFGFCY = [M:LBE1]STOFCY & MFGSTA = 1
               Call SELECT("MFG","",VALEUR,"") From SELOBJ
               Filter [F:MFG]
     When 3  : Filter [F:SRH] Where STOFCY = [M:LBE1]STOFCY 
               Call SELECT("SRH","",VALEUR,"") From SELOBJ
               Filter [F:SRH]
     When 4  : Filter [F:MTK] Where MFGFCY = [M:LBE1]STOFCY
               Call SELECT("MTK","",VALEUR,"") From SELOBJ
               Filter [F:MTK] 
     When 5  : Call SELMVT([M:LBE1]STOFCY,VALEUR, 16) From FUNLBEIMP      # réintégration 9727
     When 6  : Call SELMVT([M:LBE1]STOFCY,VALEUR, 12) From FUNLBEIMP      # réintégration 9727
Endcase
End


