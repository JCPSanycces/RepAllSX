########################################
Subprog AS_NBLIG
Raz GBOUT2
Case [M:LBE1]LBEVCRTYP
    When 2       :    GBOUT2 = mess(166,198,1)
    When Default :    GBOUT2 = mess(16,198,1)
Endcase
End
########################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
If GBOUTIMP = 2
   mkstat = 2
   End 
Endif 
End

