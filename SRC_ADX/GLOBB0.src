$AVANT_CALCULER_SOCIETE
Local Integer RTRN
  If (dim(G_CLCTRC)<0) Then : Global Integer G_CLCTRC    :  G_CLCTRC = 0 :  Endif
  Global Integer G_TIMD     : G_TIMD = time
  If clalev([M:DIV])=0  : Local Mask CALDIV     [DIV]  :  Endif             : # Infos diverses
  If clalev([M:DIV2])=0  : Local Mask CALDIV2    [DIV2]  :  Endif             : # Infos diverses  FQ77877
  [M:DIV]CSTLVLMAX = 11
  [M:DIV]CSTFIYMAX = func AFNC.ACTIV("NFIY") : # FQ59941
  [M:DIV]DATNUL    = [0/0/0]
  [M:DIV]MNTNUL    = 0
  [M:DIV]DATFMT    = "D:" + GFMDAT4
  [M:DIV]TRTLVL    = 0                    : # -- Niveau atteint dans le traitement
  [M:DIV]BDEBUG    = 2                    : # Debug
  [M:DIV]TRTDEM    = "CALSOC"             : # -- Traitement demandeur
  Onerrgo KO From GLOBB0
  Local Integer LNBF   : LNBF = 200
  Call CAL_LEC_CALDEP_FLD( LNBF, [M:DIV]TDFN, [M:DIV]NBF ) From GLOBB0
  If ([M:DIV]NBF > LNBF and GADONIX = 2) Then
    Call ECR_TRACE(mess(151,7774,1),1) From GLOBB0
    [M:DIV]NBF = 0
    Gosub APRES_CALCULER_SOCIETE From GLOBB0
    Return
  Endif
  Call CMP_CALDEP_DEPREC_EQ (RTRN) From GLOBB0
  [M:DIV]BLECMAJ = !(RTRN)
  If ( [M:DIV]BLECMAJ ) Then
    Call ECR_TRACE(mess(150,7774,1),1) From GLOBB0
    Gosub APRES_CALCULER_SOCIETE  From GLOBB0
    Return
  Endif
Return
$APRES_CALCULER_SOCIETE
  If ( !(GSERVEUR) and G_CLCTRC ) Then
    Call FERME_TRACE From LECFIC
  Endif
  If ( !( GSERVEUR) and G_CLCTRC  ) Then
    Call LEC_TRACE From LECFIC
  Endif
  If (clalev([M:DIV]))  Then : Close Local Mask [DIV]  : Endif : # Infos diverses
  If (clalev([M:DIV2]))  Then : Close Local Mask [DIV2]  : Endif : # Infos diverses FQ77877
  If (dim(G_TIMD)    >0) Then : Kill G_TIMD     : Endif
  If (dim(G_CLCTRC)  >0) Then : Kill G_CLCTRC   : Endif
Return
Subprog CAL_OPTIMISATION (PCPY, RERROR)
Value    Char    PCPY
Variable Integer RERROR
Local Integer LERR
Local Char    LOLDFAS
Local Integer LOLDCNX
  RERROR = 0
  Local File CONTEXT   [F:CNX]
  Local File FISCYEAR  [F:FIS]
  Local File FXDASSETS [F:FAS]
  Local File DEPREC    [F:DEP]
  Call ECR_TRACE(mess(164,7774,1),0) From GLOBB0
  Call ECR_TRACE("",0) From GLOBB0
  For [CNX] Where CPY=PCPY
    Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TECOURA
    For I_PLN=1 To [F:CNX]NBPLC
      Link [FAS] With  [DEP]DEP0=[F:FAS]AASREF;[F:CNX]PLNCAA(I_PLN-1);[F:FIS]DATENDFIY;[F:FIS]DATENDPER([F:FIS]INDCURPER-1) As [OPT]
&                Where CPY=[F:CNX]CPY and [F:FAS]FLGCNXCLC([F:CNX]CNX-1) <> GVML_RCOUI
&                                     and [F:FAS]FLGCNXCLC([F:CNX]CNX-1) <> GVML_RCCLO and [F:DEP]DEPSTA = GVML_SCNOCAL
&            Order By [F:FAS]AASREF;[F:DEP]CNX
      Trbegin [FAS]
      LERR = 0 : LOLDFAS = ""
        For [F:OPT]
          If ( [F:FAS]AASREF <> LOLDFAS ) Then
            LOLDFAS = [F:FAS]AASREF
            LOLDCNX = 0
          Endif
          If ( [F:DEP]CNX <> LOLDCNX ) Then
            LOLDCNX = [F:DEP]CNX
            [F:FAS]FLGCLC                  = G_OUI
            [F:FAS]FLGCNXCLC([F:CNX]CNX-1) = G_OUI
            Rewrite [FAS]
            If (fstat) Then : LERR = 1  : Break :   Endif
          Endif
        Next
        If (LERR) Then
          Rollback
        Else
          Commit
        Endif
      Link [FAS] With  [DEP]DEP0=[F:FAS]AASREF;[F:CNX]PLNCAA(I_PLN-1);[F:FIS]DATENDFIY;[F:FIS]DATENDPER([F:FIS]INDCURPER-1) As [OPT]
&            Where CPY=[F:CNX]CPY and [F:FAS]FLGCLC <> G_OUI and [F:DEP]DEPSTA = GVML_SCNOCAL
&            Order By [F:FAS]AASREF
      Trbegin [FAS]
      LERR = 0 : LOLDFAS = ""
      For [F:OPT]
        If ( [F:FAS]AASREF <> LOLDFAS ) Then
          LOLDFAS = [F:FAS]AASREF
          [F:FAS]FLGCLC = G_OUI
          Rewrite [FAS]
          If (fstat) Then : LERR = 1  : Break :   Endif
        Endif
      Next
      If (LERR) Then
        Rollback
      Else
        Commit
      Endif
    Next
  Next
  If ( [M:DIV]BACTCCN ) Then
     Trbegin [FAS]
       LERR = 0
       For [FAS]FAS1 Where CPY=[F:CNX]CPY and [F:FAS]FLGCNXCLC(G300CPFI-1) <> GVML_RCOUI
&                                         and [F:FAS]FLGCNXCLC(G300CPFI-1) <> GVML_RCCLO and [F:FAS]FLGRPRCLC = G_OUI With Stability
         [F:FAS]FLGCLC                = G_OUI
         [F:FAS]FLGCNXCLC(G300CPFI-1) = G_OUI
         Rewrite [FAS]
         If (fstat) Then : LERR = 1  : Break :   Endif
       Next
       If (LERR) Then
         Rollback
       Else
         Commit
       Endif
     Trbegin [FAS]
       LERR = 0
       For [FAS]FAS1 Where CPY=[F:CNX]CPY and [F:FAS]FLGCLC <> G_OUI and [F:FAS]FLGRPRCLC = G_OUI With Stability
         [F:FAS]FLGCLC                = G_OUI
         Rewrite [FAS]
         If (fstat) Then : LERR = 1  : Break :   Endif
       Next
       If (LERR) Then
         Rollback
       Else
         Commit
       Endif
  Endif
End
$TIMOVRFLW
Local Integer TIMEF
Local Integer ELAPSD
  TIMEF = time
  If ( TIMEF >= G_TIMD ) Then
    ELAPSD = TIMEF - G_TIMD
  Else
    ELAPSD = (86400 - G_TIMD) + TIMEF
  Endif
  If ( ELAPSD > G_TIMLIM ) Then
    [M:DIV]ERRID = 20 : Call ERRFND From   GLOBB0 : Return : # Dépilement suite à erreur logique
  Endif
Return
Subprog DUMP_HISTORIQUE_PATCHS
Local Integer RERR
Local Integer LFASCNT
  If clalev([F:APT])=0  : Local File APATCH     [APT]  :  Endif
  Local Char  L_SEP : L_SEP = "!"
  Local Char  L_FLD1( 8)  : L_FLD1 = "Numéro"
  Local Char  L_FLD2(30)  : L_FLD2 = "Fichier"
  Local Char  L_FLD3(10)  : L_FLD3 = "Date"
  Local Char  L_FLD4(50)  : L_FLD4 = "Commentaire"
  Local Char  L_FLD5(11)  : L_FLD5 = "Maintenance"
  Local Char  L_FLD6( 5)  : L_FLD6 = "Patch"
  Local Char  L_FLD7( 4)  : L_FLD7 = "Type"
  Local Char  L_LIG(147)
  Filter [APT] Where RELEASE = GVERSION
  L_LIG  = L_SEP+ space$( 1)+left$(L_FLD1, 8)  +space$(10-len(left$(L_FLD1, 8)))+
&          L_SEP+ space$( 1)+left$(L_FLD2,30)  +space$(32-len(left$(L_FLD2,30)))+
&          L_SEP+ space$( 1)+left$(L_FLD3,10)  +space$(12-len(left$(L_FLD3,10)))+
&          L_SEP+ space$( 1)+left$(L_FLD4,50)  +space$(52-len(left$(L_FLD4,50)))+
&          L_SEP+ space$( 1)+left$(L_FLD5,11)  +space$(13-len(left$(L_FLD5,11)))+
&          L_SEP+ space$( 1)+left$(L_FLD6, 5)  +space$(7 -len(left$(L_FLD5, 5)))+
&          L_SEP+ space$( 1)+left$(L_FLD7, 4)  +space$(6 -len(left$(L_FLD7, 4))) +L_SEP
  For [APT]APT0
    L_FLD1=num$([F:APT]NUM)
    L_FLD2=[F:APT]FIC
    L_FLD3=num$([F:APT]DAT)
    L_FLD4=[F:APT]COMMENT
    L_FLD5=num$([F:APT]NUMP)
    L_FLD6=num$([F:APT]PATNUM)
    L_FLD7=num$([F:APT]TYP)
  L_LIG  = L_SEP+ space$( 1)+left$(L_FLD1, 8)  +space$(10-len(left$(L_FLD1, 8)))+
&          L_SEP+ space$( 1)+left$(L_FLD2,30)  +space$(32-len(left$(L_FLD2,30)))+
&          L_SEP+ space$( 1)+left$(L_FLD3,10)  +space$(12-len(left$(L_FLD3,10)))+
&          L_SEP+ space$( 1)+left$(L_FLD4,50)  +space$(52-len(left$(L_FLD4,50)))+
&          L_SEP+ space$( 1)+left$(L_FLD5,11)  +space$(13-len(left$(L_FLD5,11)))+
&          L_SEP+ space$( 1)+left$(L_FLD6, 5)  +space$(7 -len(left$(L_FLD5, 5)))+
&          L_SEP+ space$( 1)+left$(L_FLD7, 4)  +space$(6 -len(left$(L_FLD7, 4))) +L_SEP
  Next
  Filter [APT]
  Close Local File [APT]
End
Subprog ECR_TRACE(TXT, ERR)
Value    Char    TXT() : # Texte du message
Value    Integer ERR
  If ( !(GIMPORT) and [M:DIV]TRTDEM <> "CALVNC" and (dim(G_CLCTRC)<0 or G_CLCTRC) ) Then
    Call ECR_TRACE(TXT, ERR) From GESECRAN
  Endif
End
Subprog OUVRE_FICH(PABR)
Value Char  PABR
  Case PABR
    When "FS1"
      If ( [M:DIV]NIVDET > 0 ) Then
        Openo  filpath("TRA", "CAL_"+[M:DIV]SOC+"_1","tra",0),0           Using [FS1]
        Iomode adxifs " "               Using [FS1]
        Iomode adxirs chr$(13)+chr$(10) Using [FS1]
        Iomode adxium GTRAFOR           Using [FS1]
        [M:DIV]BFS1OPN = 1
      Endif
    When "FS2"
      If ( [M:DIV]NIVDET > 0 ) Then
        Openo  filpath("TRA", "CAL_"+[M:DIV]SOC+"_2","tra",0),0           Using [FS2]
        Iomode adxifs " "               Using [FS2]
        Iomode adxirs chr$(13)+chr$(10) Using [FS2]
        Iomode adxium GTRAFOR           Using [FS2]
        [M:DIV]BFS2OPN = 1
      Endif
    When Default
  Endcase
End
Subprog ECR_FICH(PABR, PNIVMSG, PMSG)
Value Char      PABR
Value Integer   PNIVMSG
Value Char      PMSG
Local Char      WMSG(180)
  If ( PNIVMSG <= [M:DIV]NIVDET ) Then
    If (PABR = "FS1") Then
      WMSG = string$(((PNIVMSG-1)*5)+1,' ') + PMSG
    Else
      WMSG = PMSG
    Endif
    Case PABR
      When "FS1" : Wrseq WMSG Using [FS1]
      When "FS2" : Wrseq WMSG Using [FS2]
      When Default
    Endcase
  Endif
End
Subprog AFF_FICH(PABR)
  Value Char    PABR
  Local Integer LSTAT
  Local Char    LRET
  Local Char    LNOMDOC(GDIMFIC)
  Local Char TRACE_SAV(GLONTRA)
  TRACE_SAV = GTRACE
  If ( PABR = "FS1" )Then
    GTRACE = "CAL_"+[M:DIV]SOC+"_1"
  Endif
  If ( PABR = "FS2" )Then
    GTRACE = "CAL_"+[M:DIV]SOC+"_2"
  Endif
  Call LEC_TRACE From LECFIC
  GTRACE = TRACE_SAV
End
  If (GADONIX = 2) Then
    If ( PABR = "FS1" )Then
      LNOMDOC = "CAL_"+[M:DIV]SOC+"_1"
      Gosub SET_RPTSRV
      Call COPY_SRVTOCLI(1,LNOMDOC+".tra","TRA",REPSRV,APPSRV,LANRPT,LSTAT) From ORDSYS
    Elsif (PABR = "FS2" ) Then
      LNOMDOC = "CAL_"+[M:DIV]SOC+"_2"
      Gosub SET_RPTSRV
      Call COPY_SRVTOCLI(1,LNOMDOC+".tra","TRA",REPSRV,APPSRV,LANRPT,LSTAT) From ORDSYS
    Endif
    If ( (!LSTAT) and ( PABR="FS1" or PABR="FS2") )  Then
      Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
&                             "UILocalDir="+chr$(1)+"TRA",
&                             "UILocalFile="+chr$(1)+LNOMDOC+".tra"
    Endif
  Endif
End
$SET_RPTSRV
Local Char    REPSRV(GDIMFIC) , NAMSRV(GDIMFIC) , LANRPT(GLONLAN) , SEP(1) , APPSRV(GLONADS)
Local Integer I , K , J
  LANRPT = GLANGUE
  If filinfo(filpath("TRA/",LNOMDOC,"tra",""),0)>0
    NAMSRV = filpath("TRA/",LNOMDOC,"tra","")
    REPSRV = right$(NAMSRV,len(filpath("","","",""))+2)
    APPSRV = ""
  Else
    NAMSRV = filpath("TRA/",LNOMDOC,"tra")
    REPSRV = NAMSRV
    K = instr(1,NAMSRV,SEP+"tra"+SEP)
    If K
      J = 0
      For I=K-1 To 1 Step -1
        If mid$(NAMSRV,I,1)=SEP
          J = I : Break
        Endif
      Next I
      If J
        APPSRV = seg$(NAMSRV,J+1,K-1)
        REPSRV = right$(NAMSRV,K+1)
      Endif
    Endif
  Endif
Return
Subprog ECR_ENTETE_CONTEXTE()
Local    Integer COL1  : COL1  = 20 : # Contextes
Local    Integer COL2  : COL2  = 10 : # Exercice début
Local    Integer COL3  : COL3  = 10 : # Exercice fin
Local    Integer COL4  : COL4  = 10 : # Période début
Local    Integer COL5  : COL5  = 10 : # Période fin
Local    Integer COL6  : COL6  =  8 : # Exercices calculés
Local    Integer COL7  : COL7  =  8 : # Exercices périodiques
If ([M:DIV]TRTDEM = "CALDPS") Then
  Local    Integer COL8  : COL8  =  6 : # Détaillée
  Local    Integer LINE  : LINE  = COL1+COL2+COL3+COL4+COL5+COL6+COL7+COL8+25  : # +n = caractères entre champs
Else
  Local    Integer LINE  : LINE  = COL1+COL2+COL3+COL4+COL5+COL6+COL7+22       : # +n = caractères entre champs
Endif
Local    Char    LCR(LINE)    : # Chaine de compte rendu
  If ( [M:DIV]TRTDEM = "CALDPS" ) Then
    Call ECR_TRACE(mess(180,7774,1)+"\",0) From   GLOBB0
  Else
  Call ECR_TRACE(mess(138,7774,1)+"\",0) From   GLOBB0
  Endif
  LCR = string$(LINE, '*') : Call ECR_TRACE(LCR,0) From   GLOBB0
  LCR  = "! "+string$(COL1, ' ')+" ! "
  LCR += left$(mess(63,7774,1)+string$(COL2, ' '), COL2)+" ! "
  LCR += string$(COL3, ' ')+" ! "
  LCR += left$(mess(64,7774,1)+string$(COL4, ' '), COL4)+" ! "
  LCR += string$(COL5, ' ')+" !"
  LCR += left$(mess(184,7774,1)+string$(COL6, ' '), COL6)+" ! "
  LCR += left$(mess(184,7774,1)+string$(COL7, ' '), COL7)+" ! "
  If ([M:DIV]TRTDEM = "CALDPS") Then
  LCR += string$(COL8, ' ')+" !"
  Endif
  Call ECR_TRACE(LCR,0) From   GLOBB0
  LCR  = "! "
  LCR += left$(mess(66,7774,1)+string$(COL1, ' '), COL1)+" ! "
  LCR += left$(mess(68,7774,1)+string$(COL2, ' '), COL2)+" ! "
  LCR += left$(mess(69,7774,1)+string$(COL3, ' '), COL3)+" ! "
  LCR += left$(mess(68,7774,1)+string$(COL4, ' '), COL4)+" ! "
  LCR += left$(mess(69,7774,1)+string$(COL5, ' '), COL5)+" !"
  LCR += left$(mess(185,7774,1)+string$(COL6, ' '), COL6)+" ! "
  LCR += left$(mess(186,7774,1)+string$(COL7, ' '), COL7)+" ! "
  If ([M:DIV]TRTDEM = "CALDPS") Then
  LCR += left$(mess(187,7774,1)+string$(COL8, ' '), COL8)+" !"
  Endif
  Call ECR_TRACE(LCR,0) From   GLOBB0
  LCR = string$(LINE, '*') : Call ECR_TRACE(LCR,0) From   GLOBB0
End
Subprog ECR_LIGNE_CONTEXTE(PCNT)
Value Integer      PCNT
Local    Integer COL1  : COL1  = 20 : # Contextes
Local    Integer COL2  : COL2  = 10 : # Exercice début
Local    Integer COL3  : COL3  = 10 : # Exercice fin
Local    Integer COL4  : COL4  = 10 : # Période début
Local    Integer COL5  : COL5  = 10 : # Période fin
Local    Integer COL6  : COL6  =  8 : # Exercices calculés
Local    Integer COL7  : COL7  =  8 : # Exercices périodiques
If ([M:DIV]TRTDEM = "CALDPS") Then
Local    Integer COL8  : COL8  =  6 : # Détaillée
Local    Integer LINE  : LINE  = COL1+COL2+COL3+COL4+COL5+COL6+COL7+COL8+25  : # +n = caractères entre champs
Else
Local    Integer LINE  : LINE  = COL1+COL2+COL3+COL4+COL5+COL6+COL7+22       : # +n = caractères entre champs
Endif
Local    Char    LCR(LINE)    : # Chaine de compte rendu
Local    Integer IEC
Local    Integer IPC
  LCR  = "! "
  LCR += left$(mess(PCNT,GML_NCONTEXT,1)+string$(COL1, ' '), COL1)+" ! "
  Case PCNT
  When G300CPFI
      IEC = find(GVML_TECOURA,[M:EGCF]STAFIY)
      IPC = [M:EGCF]INDDEBPER(IEC-1) + [M:EGCF]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:EGCF]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:EGCF]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:EGCF]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:EGCF]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  When G300IAS
      IEC = find(GVML_TECOURA,[M:EIAS]STAFIY)
      IPC = [M:EIAS]INDDEBPER(IEC-1) + [M:EIAS]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:EIAS]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:EIAS]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:EIAS]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:EIAS]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  When G300TEC
      IEC = find(GVML_TECOURA,[M:ETEC]STAFIY)
      IPC = [M:ETEC]INDDEBPER(IEC-1) + [M:ETEC]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:ETEC]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ETEC]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ETEC]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ETEC]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  When G300RET
      IEC = find(GVML_TECOURA,[M:ERET]STAFIY)
      IPC = [M:ERET]INDDEBPER(IEC-1) + [M:ERET]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:ERET]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ERET]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ERET]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ERET]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  When G300SUB
      IEC = find(GVML_TECOURA,[M:ESUB]STAFIY)
      IPC = [M:ESUB]INDDEBPER(IEC-1) + [M:ESUB]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:ESUB]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ESUB]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ESUB]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ESUB]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  When G300LIB
      IEC = find(GVML_TECOURA,[M:ELI1]STAFIY)
      IPC = [M:ELI1]INDDEBPER(IEC-1) + [M:ELI1]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI1]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI1]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI1]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI1]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  When G300SU1
      IEC = find(GVML_TECOURA,[M:ELI2]STAFIY)
      IPC = [M:ELI2]INDDEBPER(IEC-1) + [M:ELI2]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI2]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI2]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI2]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI2]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  When G300SU2
      IEC = find(GVML_TECOURA,[M:ELI3]STAFIY)
      IPC = [M:ELI3]INDDEBPER(IEC-1) + [M:ELI3]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI3]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI3]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI3]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI3]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  When G300SU3
      IEC = find(GVML_TECOURA,[M:ELI4]STAFIY)
      IPC = [M:ELI4]INDDEBPER(IEC-1) + [M:ELI4]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI4]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI4]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI4]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI4]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  When G300SU4
      IEC = find(GVML_TECOURA,[M:ELI5]STAFIY)
      IPC = [M:ELI5]INDDEBPER(IEC-1) + [M:ELI5]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI5]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI5]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI5]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI5]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  When G300SU5
      IEC = find(GVML_TECOURA,[M:ELI6]STAFIY)
      IPC = [M:ELI6]INDDEBPER(IEC-1) + [M:ELI6]INDCURPER(IEC-1) - 1
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI6]DATSTRFIY(IEC-1)) +string$(COL2, ' '), COL2)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI6]DATENDFIY(IEC-1)) +string$(COL3, ' '), COL3)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI6]DATSTRPER(IPC-1)) +string$(COL4, ' '), COL4)+" ! "
      LCR += left$( format$("D:" + GFMDAT4, [M:ELI6]DATENDPER(IPC-1)) +string$(COL5, ' '), COL5)+" ! "
  Endcase
  LCR += left$( format$("N:5",[M:CNX]HRZEXE(find(PCNT,[M:CNX]CNX)-1))      +string$(COL6, ' '), COL6)+" ! "
  LCR += left$( format$("N:5",[M:CNX]HRZPER(find(PCNT,[M:CNX]CNX)-1))      +string$(COL7, ' '), COL7)+" ! "
  If ([M:DIV]TRTDEM = "CALDPS") Then
  LCR += left$( " "  + mess([M:CNX]FLGSIMDET(find(PCNT,[M:CNX]CNX)-1),1,1) +string$(COL8, ' '), COL8)+" ! "
  Endif
  Call ECR_TRACE(LCR,0) From   GLOBB0
End
Subprog ECR_ENTETE_PLAN()
Local    Integer COL1  : COL1  = 45 : # Plan
Local    Integer LINE  : LINE  = COL1+4
Local    Char    LCR(LINE)    : # Chaine de compte rendu
  LCR = string$(LINE, '*') : Call ECR_TRACE(LCR,0) From   GLOBB0
  LCR  = "! "
  LCR += left$(mess(183,7774,1)+string$(COL1, ' '), COL1)+" ! "
  Call ECR_TRACE(LCR,0) From   GLOBB0
  LCR = string$(LINE, '*') : Call ECR_TRACE(LCR,0) From   GLOBB0
    End
Subprog ECR_LIGNE_PLAN(PPLN)
Value Integer      PPLN
Local    Integer COL1  : COL1  = 45 : # Plan
Local    Integer LINE  : LINE  = COL1+4
Local    Char    LCR(LINE)    : # Chaine de compte rendu
  LCR  = "! "
  LCR += left$(mess(PPLN,GML_NPLAN,1)+string$(COL1, ' '), COL1)+" ! "
  Call ECR_TRACE(LCR,0) From   GLOBB0
End
Subprog CAL_EVALUE_ACTION_DEP( PTDFN, PNBF )
Value Char     PTDFN()
Value Decimal  PNBF
Local Integer N_D
Local Integer LRET
Local Integer N_F
Local Integer I_P
Local Integer LERROR
  LERROR = 0
  If ( [M:DIV]TRTDEM = "CALSIM" or [M:DIV]TRTDEM = "CALVNC" or [M:DIV]TRTDEM = "CALDPS") Then
    End
  Endif
  For N_D = 1 To [M:DEP]NB_DEP
    If ( N_D > [M:WDEP]NB_DEP ) Then
      [M:DEP]FLGACT(N_D-1) = "I"
    Else
      LRET = 0
      If ( N_D <= [M:DEP]NB_DEP and
&        ( ( [M:DEP]FIYSTRDAT(N_D-1) <> [M:WDEP]FIYSTRDAT(N_D-1) )  or
&          ( [M:DEP]FIYENDDAT(N_D-1) <> [M:WDEP]FIYENDDAT(N_D-1) )  or
&          ( [M:DEP]PERSTRDAT(N_D-1) <> [M:WDEP]PERSTRDAT(N_D-1) )  or
&          ( [M:DEP]PERENDDAT(N_D-1) <> [M:WDEP]PERENDDAT(N_D-1) )  )     ) Then
        LRET = -1
      Else
        I_P = find([M:DEP]PERSTRDAT(N_D-1),[M:FIY]DATSTRPER)
        If (I_P <> 0 and [M:FIY]STAPER (I_P-1) = GVML_SPCLOSE) Then
          LRET = 1
        Else
          If ([F:WFAS]FLGCNXCLC([M:DEP]CNX(N_D-1)-1) = GVML_RCCLO and [M:DEP]FIYENDDAT(N_D-1)=[M:FIY]DATENDFIY([M:DIV]FEC-1) )  Then
            LRET = 1
          Endif
        Endif
      Endif
      If ( LRET = 1 ) Then
        [M:DEP]FLGACT(N_D-1) = "N"
      Elsif ( LRET = 0 ) Then
        [M:DEP]FLGACT(N_D-1) = "U"
      Else
        [M:DEP]FLGACT(N_D-1) = "I"
        [M:WDEP]NB_DEP = N_D
        Delete [WDEP] Where   AASREF     = [F:WFAS]AASREF
&                       and   DPRPLN     = [M:WDEP]DPRPLN(N_D-1)
&                       and   FIYENDDAT >= [M:WDEP]FIYENDDAT(N_D-1)
&                       and   PERENDDAT >= [M:WDEP]PERENDDAT(N_D-1)
        If fstat Then
          LERROR = -1
          Call FSTA("WDEP") From GLOCK
          Call ECR_TRACE(mess(154,7774,1)-num$(DPRPLN)-AASREF,1) From   GLOBB0
          Break
        Endif
      Endif
    Endif
  Next N_D
  If ( LERROR ) Then
    [M:DIV]ERRID = 14 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
  Endif
End
Subprog CAL_LEC_CALDEP_FLD( PNBFMAX, RTDF, RNBF )
Value    Integer  PNBFMAX
Variable Char     RTDF()
Variable Decimal  RNBF
Local Integer N_F
Local Integer BCLOFIL : BCLOFIL = 0
  If clalev([F:AMZB])=0 : Local File AMSKZON [AMZB] : BCLOFIL = 1 : Endif
  N_F = 1
  For [AMZB]CODTYP Where CODMSK = "CALDEP" and CODTYP <> "ABS"
    If ( N_F <= PNBFMAX ) Then
     RTDF(N_F-1) =[F:AMZB]CODZON
    Endif
     N_F += 1
  Next
  RNBF = N_F-1
  If (BCLOFIL) Then
    Close Local File [AMZB]
  Endif
End
Subprog CMP_CALDEP_DEPREC_EQ(RTRN)
Variable Integer RTRN
Local Integer I_F
Local Integer N_M
Local Integer N_F
  RTRN= 1
  If clalev([F:DEP])=0  : Local File DEPREC     [DEP]  :  Endif             : # Infos diverses
  N_F = clanbs([F:DEP],1)
  N_F -=5
  If( [M:DIV]NBF-1 <> N_F ) Then
    RTRN = 0
  Else
    Local Char L_FLD
    For I_F = 1 To N_F
      L_FLD = clavar([F:DEP], I_F)
      If ( L_FLD <> "CREDATTIM" and L_FLD <> "UPDDATTIM" and L_FLD <> "AUUID" and
&          L_FLD <> "CREUSR"    and L_FLD <> "UPDUSR" and find (L_FLD, [M:DIV]TDFN) = 0 ) Then
        RTRN = 0
        Break
      Endif
    Next I_F
  Endif
End
$CAL_ADDLVL
  If ( [M:DIV]LVL = [M:DIV]CSTLVLMAX ) Then
    [M:DIV]ERRID = 9999 : Call ERRFND From   GLOBB0
  Else
    [M:DIV]LVL += 1
    [M:DIV]LVLID([M:DIV]LVL-1 ) = [M:DIV]LVLLIB
  Endif
Return
$CAL_RMVLVL
  If ( [M:DIV]LVL = 0 ) Then
    [M:DIV]ERRID = 9998 : Call ERRFND From   GLOBB0
  Else
    Raz [M:DIV]LVLID([M:DIV]LVL-1)
    [M:DIV]LVL -= 1
  Endif
Return
$KO
  If (G_DEJA) Then
    End
  Endif
  G_DEJA = 1
  Call CAL_ERREUR(errmes$(errn), errp, errl, errn) From   GLOBB0
  Call TEMPOFF From GESECRAN
  If (adxlog) Then
    Call ECR_TRACE(mess(48,7774,1),0) From   GLOBB0 : # Traitement annulé
    Rollback
  Endif
  Gosub UNSET_FIRST From TRTFIRST
  Call ECR_TRACE(mess(58,7774,1)-mess(60,7774,1),1) From   GLOBB0
  If ( [M:DIV]TRTLVL > 3 and ( [M:DIV]TRTDEM = "CALSOC" or [M:DIV]TRTDEM = "CALDPS") ) Then : # FQ79856
    Call FERME_BOITE From GESECRAN
  Endif
  If ( [M:DIV]TRTLVL > 2 ) Then
    Openo Using [FS1] : [M:DIV]BFS1OPN = 0
    Openo Using [FS2] : [M:DIV]BFS2OPN = 0
  Endif
  If ( [M:DIV]TRTLVL > 1 and ( [M:DIV]TRTDEM = "CALSOC" or [M:DIV]TRTDEM = "CALDPS") ) Then : # FQ79856
    If ( dim(GFILTRE_FAS) < 0 )  Then
      Call UNLOCK_SYMBOLE ("FAS", [M:DIV]SOC, "") From GLOBIENS
    Endif
  Endif
  If ( [M:DIV]TRTLVL > 0 and ( [M:DIV]TRTDEM = "CALSOC" or [M:DIV]TRTDEM = "CALDPS") ) Then : # FQ79856
    Call UNLOCK_SYMBOLE ("CNX", [M:DIV]SOC, "") From GLOBIENS
  Endif
  Call ECR_TRACE(string$(80, '-'),0) From   GLOBB0
  If ( !(GSERVEUR) ) Then
    Call FERME_TRACE From LECFIC
  Endif
  If ( !(GSERVEUR) ) Then  : Call LEC_TRACE From LECFIC : Endif
  If (dim(G_ETRPNT)>0) Then : Kill G_ETRPNT : Endif  : # Spécifique client
  If (dim(G_CLCSTD)>0) Then : Kill G_CLCSTD : Endif  : # Calcul Abel X3
  If ( [M:DIV]TRTDEM = "CALBCO" or [M:DIV]TRTDEM = "CALSIM") Then
    Local Integer LAFFTRACE2 : LAFFTRACE2=0
    If ( GDEBUG and dim(PBKPOINTLST)>0 ) Then
      Local Integer I_BKP : I_BKP = find("AFFTRACE2",PBKPOINTLST)
      If (I_BKP) Then
        If (PBKPOINTFLG(I_BKP) = G_OUI) Then : LAFFTRACE2 = 1 : Endif
      Endif
    Endif
    If ( LAFFTRACE2 ) Then : Call AFF_FICH ( "FS2" ) From   GLOBB0 : Endif
  Endif
  End
Subprog ERRFND ( )
    Local Integer I
  If ( [M:DIV]TRTDEM = "CALSOC" or [M:DIV]TRTDEM = "CALDPS" or [M:DIV]TRTDEM = "CALVNC" ) Then
    [M:DIV]ERROR = [M:DIV]ERRID
  Else
    I = I/0
  Endif
End
Subprog CAL_ERREUR ( PERRLIB, PERRP, PERRL, PERRN )
  Value Char    PERRLIB, PERRP
  Value Integer PERRL, PERRN
  If ( [M:DIV]ERRID = 0 or [M:DIV]ERRID = -1) Then
    [M:DIV]ERRID = -1 : # FQ101833
    Local Integer IC
    Local Integer DBD, FND, DBT, FNT, DBR, FNR
    For I = 1 To len(PERRP)
      If ( pat(left$(PERRP,I),"*@*") and DBD = 0 ) Then : DBD = I+1 : Endif
      If ( pat(left$(PERRP,I),"*.")  and FND = 0 ) Then : FND = I-1 : Endif
      If ( pat(left$(PERRP,I),"*/*") and DBT = 0 ) Then : DBT = I+1 : Endif
      If ( pat(left$(PERRP,I),"*$*") and FNT = 0 ) Then : FNT = I-1 : Endif
    Next I
    Call ECR_TRACE(string$(41, '='),0)   From   GLOBB0
    Call ECR_TRACE(mess(155,7774,1),0)   From   GLOBB0  : # Erreur système détectée
    Call ECR_TRACE(string$(41, '='),0)   From   GLOBB0
    Call ECR_TRACE(mess(156,7774,1)+seg$(PERRP, DBD, FND)       , 0)    From   GLOBB0  : # Dossier
    Call ECR_TRACE(mess(157,7774,1)+seg$(PERRP, DBT, FNT)       , 0)    From   GLOBB0  : # Traitement
    Call ECR_TRACE(mess(158,7774,1)+num$(PERRL)                 , 0)    From   GLOBB0  : # Ligne
    Call ECR_TRACE(mess(159,7774,1)+num$(PERRN)                 , 0)    From   GLOBB0  : # Erreur num.
    Call ECR_TRACE(mess(160,7774,1)+PERRLIB                   , 0)      From   GLOBB0  : # Erreur lib.
    If ( dim([M:DIV]BCO) <> -1 and [M:DIV]BCO <> "") Then
      Call ECR_TRACE(mess(161,7774,1)+[M:DIV]BCO              , 0)      From   GLOBB0  : # Bien
    Endif
    If ([M:DIV]BFS2OPN) Then
      For LNIV = 1 To [M:DIV]LVL
      Next LNIV
      If ( dim([M:DIV]BCO) <> -1 and [M:DIV]BCO <> "" ) Then
      Endif
    Endif
  Else
    Local Integer LNIV
    Call ECR_TRACE(string$(41, '='),0)   From   GLOBB0
    Call ECR_TRACE(mess(162,7774,1),0)   From   GLOBB0  : # Erreur logique détectée
    Call ECR_TRACE(string$(41, '='),0)   From   GLOBB0
    If ([M:DIV]BCO <> "" ) Then
      Call ECR_TRACE(mess(161,7774,1)+[M:DIV]BCO, 0) From   GLOBB0          : # Bien
    Endif
    If ( [M:DIV]ERRID = 5 ) Then
      Call ECR_TRACE(mess(195,7774,1), 0) From   GLOBB0  : # Mode d'amortissement inconnu
    Elsif ( [M:DIV]ERRID = 14 ) Then
      Call ECR_TRACE(mess(197,7774,1), 0) From   GLOBB0  : # Erreur lors de la suppression des DEPREC en trop par rapport à l'horizon
    Elsif ( [M:DIV]ERRID = 18 ) Then
      Call ECR_TRACE(mess(198,7774,1), 0) From   GLOBB0  : # Date passée à la fonction CAL_LOCALISE_DAT hors limite
    Elsif ( [M:DIV]ERRID = 20 ) Then
      Call ECR_TRACE(mess(163,7774,1), 0) From   GLOBB0  : # Dépassement du temps limite
    Elsif ( [M:DIV]ERRID = 22 ) Then
      Call ECR_TRACE(mess(165,7774,1), 0) From   GLOBB0  : # Aucun contexte pour le plan passé en paramètre
    Elsif ( [M:DIV]ERRID = 23 ) Then
      Call ECR_TRACE(mess(199,7774,1), 0) From   GLOBB0  : # CAL_EXERCICE_SELON_DATE, l'exercice d'appartenance [0/0/0] ne peut pas être déterminé
    Elsif ( [M:DIV]ERRID = 24 ) Then
      Call ECR_TRACE(mess(200,7774,1), 0) From   GLOBB0  : # Le type de prorata n'a pas pu être déterminé en fonction du mode d'amortissement
    Elsif ( [M:DIV]ERRID = 26 ) Then
      Call ECR_TRACE(mess(201,7774,1), 0) From   GLOBB0  : # Les dates passées en paramètres à CAL_DAT_BORNES sont inconsistantes
    Elsif ( [M:DIV]ERRID = 27 ) Then
      Call ECR_TRACE(mess(166,7774,1), 0) From   GLOBB0  : # Dépassement CALDEP
    Elsif ( [M:DIV]ERRID = 29 ) Then
      Call ECR_TRACE(mess(167,7774,1), 0) From   GLOBB0  : # Erreur chronologie des périodes
    Elsif ( [M:DIV]ERRID = 30 ) Then
      Call ECR_TRACE(mess(168,7774,1), 0) From   GLOBB0  : # Dépassement CALFIY
    Elsif ( [M:DIV]ERRID = 31 ) Then
      Call ECR_TRACE(mess(169,7774,1), 0) From   GLOBB0  : # Dépassement CALPPL
    Else
      Call ECR_TRACE(mess(153,7774,1)+num$([M:DIV]ERRID), 0) From   GLOBB0  : # Erreur
    Endif
    If ([M:DIV]BFS2OPN) Then
      For LNIV = 1 To [M:DIV]LVL
      Next LNIV
      If ( dim([M:DIV]BCO) <> -1 and [M:DIV]BCO <> "" ) Then
      Endif
    Endif
  Endif
End
$CAL_LEC_MODES
Local Integer INDMOD
Local Integer INDOPT
Local Integer INDRAT
  Raz [M:DPM]
  If clalev([F:WDPM])=0   : Local File DPRMOD     [WDPM]   :  Endif      : # Modes d'amortissement
  If clalev([F:WDMO])=0   : Local File DPRMODOPT  [WDMO]   :  Endif      : # Option Mode d'Amortissement
  If clalev([F:WDMR])=0   : Local File DPRMODRAT  [WDMR]   :  Endif      : # Taux Mode d'Amortissement
  INDMOD = 1
  INDOPT = 1
  INDRAT = 1
  For [WDPM]DPM0 Where ( [F:WDPM]CPY = [M:DIV]SOC or [F:WDPM]CPY = "" )
    [M:DPM]CPY      (INDMOD-1)= [F:WDPM]CPY
    [M:DPM]DPM      (INDMOD-1)= [F:WDPM]DPM
    [M:DPM]CRY      (INDMOD-1)= [F:WDPM]CRY
    [M:DPM]DPMRSD   (INDMOD-1)= [F:WDPM]RSDDPMTGR
    [M:DPM]PRODPMRSD(INDMOD-1)= [F:WDPM]PRATYPTGR
    [M:DPM]ENAFLG   (INDMOD-1)= [F:WDPM]ENAFLG
    [M:DPM]DES      (INDMOD-1)= [F:WDPM]DES
    [M:DPM]DPRMODTYP(INDMOD-1)= [F:WDPM]DPRMODTYP
    [M:DPM]STDDPM   (INDMOD-1)= [F:WDPM]STDDPM
    [M:DPM]STDDPMNUM(INDMOD-1)= [F:WDPM]STDDPMNUM
    [M:DPM]ETRDATTYP(INDMOD-1)= [F:WDPM]ETRDATTYP
    [M:DPM]ENDDPRTYP(INDMOD-1)= [F:WDPM]ENDDPRTYP
    [M:DPM]ENDDATTYP(INDMOD-1)= [F:WDPM]ENDDATTYP
    [M:DPM]PROTYP   (INDMOD-1)= [F:WDPM]PROTYP
    [M:DPM]BASTYP   (INDMOD-1)= [F:WDPM]BASTYP
    [M:DPM]RATNBR   (INDMOD-1)= [F:WDPM]RATNBR
    [M:DPM]FIRFIYFLG(INDMOD-1)= [F:WDPM]FIRFIYFLG
    [M:DPM]ANIDATFLG(INDMOD-1)= [F:WDPM]ANIDATFLG
    [M:DPM]MINDPRTYP(INDMOD-1)= [F:WDPM]MINDPRTYP
    [M:DPM]MINDPRRAT(INDMOD-1)= [F:WDPM]MINDPRRAT
    [M:DPM]MAXDPRTYP(INDMOD-1)= [F:WDPM]MAXDPRTYP
    [M:DPM]MAXDPRRAT(INDMOD-1)= [F:WDPM]MAXDPRRAT
    [M:DPM]RATCOETYP(INDMOD-1)= [F:WDPM]RATCOETYP
    [M:DPM]EXCDPRTYP(INDMOD-1)= [F:WDPM]EXCDPRTYP
    [M:DPM]EXCDPRRAT(INDMOD-1)= [F:WDPM]EXCDPRRAT
    [M:DPM]MINDPRLIF(INDMOD-1)= [F:WDPM]MINDPRLIF
    [M:DPM]DPRDISRUL(INDMOD-1)= [F:WDPM]DPRDISRUL : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
    NBROPT = 0
    For [WDMO]DMO0 Where STDDPM=[F:WDPM]STDDPM and ( OPTCPY=[M:DIV]SOC or OPTCPY="")
      [M:DPM]NUMDPM   (INDOPT-1) = [F:WDMO]NUMDPM
      [M:DPM]OPTTYP   (INDOPT-1) = [F:WDMO]OPTTYP
      [M:DPM]OPTCOD   (INDOPT-1) = [F:WDMO]OPTCOD
      [M:DPM]OPTRAT   (INDOPT-1) = [F:WDMO]OPTRAT
      [M:DPM]STRVLYDAT(INDOPT-1) = [F:WDMO]STRVLYDAT
      [M:DPM]ENDVLYDAT(INDOPT-1) = [F:WDMO]ENDVLYDAT
      [M:DPM]REFDATTYP(INDOPT-1) = [F:WDMO]REFDATTYP
      [M:DPM]OPTCPY   (INDOPT-1) = [F:WDMO]OPTCPY
      [M:DPM]DPRPLN   (INDOPT-1) = [F:WDMO]DPRPLN
      NBROPT += 1
      INDOPT += 1
    Next
    [M:DPM]OPTNBR (INDMOD-1) = NBROPT
    If (NBROPT = 0 ) Then
      [M:DPM]INDDEBOPT(INDMOD-1) = 0
      [M:DPM]INDFINOPT(INDMOD-1) = 0
    Else
      [M:DPM]INDDEBOPT(INDMOD-1) = INDOPT - NBROPT
      [M:DPM]INDFINOPT(INDMOD-1) = INDOPT - 1
    Endif
    NBRRAT = 0
    For [WDMR]DMR0 Where DPM=[F:WDPM]DPM and ( CPY=[M:DIV]SOC or CPY="")
      [M:DPM]NUM (INDRAT-1) = [F:WDMR]NUM
      [M:DPM]RAT (INDRAT-1) = [F:WDMR]RAT
      NBRRAT += 1
      INDRAT += 1
    Next
    [M:DPM]RATNBR (INDMOD-1) = NBRRAT
    If (NBRRAT = 0 ) Then
      [M:DPM]INDDEBRAT(INDMOD-1) = 0
      [M:DPM]INDFINRAT(INDMOD-1) = 0
    Else
      [M:DPM]INDDEBRAT(INDMOD-1) = INDRAT - NBRRAT
      [M:DPM]INDFINRAT(INDMOD-1) = INDRAT - 1
    Endif
    INDMOD += 1
  Next
  [M:DPM]NB_MOD = INDMOD-1
  [M:DPM]NB_OPT = INDOPT-1
  [M:DPM]NB_RAT = INDRAT-1
  [M:DIV]PROEXEINV = G_NON
  [M:DIV]PROEXESOR = G_NON
  INDMOD = find(G_DPMIT,[M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    For INDOPT = [M:DPM]INDDEBOPT(INDMOD-1) To [M:DPM]INDFINOPT(INDMOD-1)
      Case [M:DPM]OPTCOD(INDOPT-1)
        When GVML_COPRINV : [M:DIV]PROEXEINV = G_OUI
        When GVML_COPRDES : [M:DIV]PROEXESOR = G_OUI
      Endcase
    Next INDOPT
  Endif
  [M:DIV]PROEXEMDB = GVML_COPSANS
  INDMOD = find(G_DPMDB, [M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    [M:DIV]PROEXEMDB = [M:DPM]OPTCOD([M:DPM]INDFINOPT(INDMOD-1)-1)
  Endif
  [M:DIV]PROEXEMLB = GVML_COPSANS
  INDMOD = find(G_DPMLB, [M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    [M:DIV]PROEXEMLB = [M:DPM]OPTCOD([M:DPM]INDFINOPT(INDMOD-1)-1)
  Endif
  [M:DIV]RGLSIMPL = G_NON
  INDMOD = find(G_DPMDA, [M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    [M:DIV]RGLSIMPL = G_OUI
  Endif
  [M:DIV]FLGTXPRI = G_NON
  INDMOD = find(G_DPMLP, [M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    [M:DIV]FLGTXPRI = G_OUI
  Endif
  [M:DIV2]SLTXPRI = G_NON
  INDMOD = find(G_DPMSL, [M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    [M:DIV2]SLTXPRI = G_OUI
  Endif
Return
Subprog  CAL_LEC_CONTEXTES (PSOC, RERROR)
Value Char       PSOC
Variable Decimal RERROR
Local Integer I
Local Integer INDCNT
Local Integer INDPLN
  Local Integer BGESCCN : # Concessions gérée
  BGESCCN = func AFNC.ACTIV("CCN")
  [M:DIV]BACTCCN = BGESCCN
  Local Integer BACTKRU : # Russie
  BACTKRU = func AFNC.ACTIV("KRU")
  [M:DIV]BACTKRU = BACTKRU
  Local Integer BACTKPL : # Polonais
  BACTKPL = func AFNC.ACTIV("KPL")
  [M:DIV]BACTKPL = BACTKPL
  Raz [M:CNX]
  If clalev([F:WCNX]) =0 : Local File CONTEXT    [WCNX]  : Endif        : # Contextes
  [M:DIV]PLNCPT = 0
  [M:DIV]PLNFIS = 0
  [M:DIV]PLNMIN = 0
  [M:DIV]PLNORI = 0
  [M:DIV]PLNR76 = 0
  [M:DIV]PLNIAS = 0
  [M:DIV]PLNTEC = 0
  [M:DIV]PLNRET = 0
  [M:DIV]PLNSUB = 0
  [M:DIV]PLNLI1 = 0
  [M:DIV]PLNLI2 = 0
  [M:DIV]PLNLI3 = 0
  [M:DIV]PLNLI4 = 0
  [M:DIV]PLNLI5 = 0
  [M:DIV]PLNLI6 = 0
  [M:DIV]CNXUO  = 0
  INDCNT = 1
  INDPLN = 1
  For [WCNX]CNX0 Where [F:WCNX]CPY=PSOC
    If ([F:WCNX]HRZEXE = 0 or [F:WCNX]HRZPER = 0 ) Then : [F:WCNX]HRZEXE = 2 : [F:WCNX]HRZPER = 2 : Endif
    If ([F:WCNX]HRSEXE < 2 ) Then : [F:WCNX]HRSEXE = 2 : Endif
    If ([F:WCNX]HRSPER < 2 ) Then : [F:WCNX]HRSPER = 2 : Endif
    nolign = INDCNT
    [M:CNX]=[F:WCNX]
    If ([M:DIV]TRTDEM = "CALDPS") Then
      [M:CNX]HRZEXE(nolign-1) = [F:WCNX]HRSEXE
      [M:CNX]HRZPER(nolign-1) = [F:WCNX]HRSPER
    Endif
    INDCNT += 1
    If ( [F:WCNX]FLGCNXUO = G_OUI ) Then
      [M:DIV]CNXUO = [F:WCNX]CNX
    Endif
    For I = 1 To [F:WCNX]NBPLC
      If ( G_ACTCCN =  G_OUI ) and ( [F:WCNX]CNX = G300CPFI ) Then
        If ( BGESCCN ) Then
          Raz [M:DIV]CCNFLG     : [M:DIV]CCNFLG    = [F:WCNX]CCNFLG
          Raz [M:DIV]CCNMOD     : [M:DIV]CCNMOD    = [F:WCNX]CCNMOD
          Raz [M:DIV]CCNGRTFLG  : [M:DIV]CCNGRTFLG = [F:WCNX]CCNGRTFLG
          Raz [M:DIV]CCNRPRTYP  : [M:DIV]CCNRPRTYP = [F:WCNX]CCNRPRTYP
          Raz [M:DIV]CCNINDPLN  : [M:DIV]CCNINDPLN = [F:WCNX]CCNINDPLN
          Raz [M:DIV]CCNGRTPLN  : [M:DIV]CCNGRTPLN = [F:WCNX]CCNGRTPLN
          Raz [M:DIV]CCNCADPLN  : [M:DIV]CCNCADPLN = [F:WCNX]CCNCADPLN
        Else
          Raz [M:DIV]CCNFLG
          Raz [M:DIV]CCNMOD
          Raz [M:DIV]CCNGRTFLG
          Raz [M:DIV]CCNRPRTYP
          Raz [M:DIV]CCNINDPLN
          Raz [M:DIV]CCNGRTPLN
          Raz [M:DIV]CCNCADPLN
        Endif
      Endif
      [M:DIV]PLNCNT   (INDPLN-1) = [F:WCNX]CNX              : #  Code contexte
      [M:DIV]PLNCAA   (INDPLN-1) = [F:WCNX]PLNCAA   (I-1)   : #  Code plan
      [M:DIV]ORIBASDPR(INDPLN-1) = [F:WCNX]ORIBASDPR(I-1)   : #  Origine base amortissement
      [M:DIV]PLNSTD   (INDPLN-1) = [F:WCNX]PLNSTD   (I-1)   : #  Norme
      [M:DIV]FLUTRATXS(INDPLN-1) = [F:WCNX]FLUTRATXS(I-1)   : #  Suivi flux liasse
      [M:DIV]FLUTRAACC(INDPLN-1) = [F:WCNX]FLUTRAACC(I-1)   : #  Suivi flux compte
      [M:DIV]LNKPLN   (INDPLN-1) = [F:WCNX]LNKPLN   (I-1)   : #  Plan lié
      Case [F:WCNX]PLNCAA(I-1)
        When G301CPT  : [M:DIV]PLNCPT = 1
        When G301FIS  : [M:DIV]PLNFIS = 1
        When G301MIN  : [M:DIV]PLNMIN = 1
        When G301ORI  : [M:DIV]PLNORI = 1
        When G301R76  : [M:DIV]PLNR76 = 1
        When G301IAS  : [M:DIV]PLNIAS = 1
        When G301TEC  : [M:DIV]PLNTEC = 1
        When G301RET  : [M:DIV]PLNRET = 1
        When G301SUB  : [M:DIV]PLNSUB = 1
        When G301LI1  : [M:DIV]PLNLI1 = 1
        When G301LI2  : [M:DIV]PLNLI2 = 1
        When G301LI3  : [M:DIV]PLNLI3 = 1
        When G301LI4  : [M:DIV]PLNLI4 = 1
        When G301LI5  : [M:DIV]PLNLI5 = 1
        When G301LI6  : [M:DIV]PLNLI6 = 1
      Endcase
      INDPLN += 1
    Next I
 Next CNX0
  [M:CNX]NB_CNX = INDCNT-1
  [M:DIV]NB_PLN = INDPLN-1
End
Subprog  CAL_CNT_FROM_PLN (PSOC, PPLN, RCNT)
Value    Char    PSOC
Value    Integer PPLN
Variable Integer RCNT
Local  Integer I
  RCNT = 0
  If ( PPLN = G301CPT or PPLN = G301FIS or PPLN = G301MIN or PPLN = G301SUB ) Then
    RCNT = G300CPFI
  Else
    If clalev([F:WCNX]) =0 : Local File CONTEXT    [WCNX]  : Endif        : # Contextes
    For [WCNX]CNX0 Where [F:WCNX]CPY=PSOC
      For I = 1 To [F:WCNX]NBPLC
        If ( [F:WCNX]PLNCAA(I-1) = PPLN ) Then
          RCNT = [F:WCNX]CNX
          Break 2
        Endif
      Next I
    Next CNX0
  Endif
  If !(RCNT) Then
    [M:DIV]ERRID = 22 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
  Endif
End
Subprog  CAL_LEC_EXERCICES_PERIODES (PSOC, PCNT)
Value    Char    PSOC
Value    Integer PCNT
  If clalev([F:WFIS]) =0 : Local File FISCYEAR   [WFIS]  : Endif        : # Exercices/périodes
Local Integer I       : I = 0
Local Integer INDEXE  : INDEXE = 1  : # indice exercice
Local Integer INDPER  : INDPER = 1  : # indice période
Local Integer INDESS  : INDESS = 0  : # indice exercice suivant le Suivant
Local Integer INDCLO  : INDCLO = 0  : # indice exercice clos
Local Integer WPDS
Local Integer I_EXE
Local Date    LDTDB
Local Date    LDTDBEXE
Local Date    LDTFNEXE
Local Integer LINDEXE
Local Integer LNUMEXE : LNUMEXE = 0
Local Integer I_CNT : I_CNT = find(PCNT, [M:CNX]CNX)
  Raz [M:FIY]
  For [WFIS]FIY0 Where [F:WFIS]CPY=PSOC and [F:WFIS]CNX=PCNT
    If ( [F:WFIS]STAFIY = GVML_TECOURA ) Then
      INDESS = INDEXE + 2
      If ( [F:WFIS]CNX = G300CPFI ) Then
        [M:DIV]DIFTYP = [F:WFIS]DFDTYP
        [M:DIV]DIFRGL = [F:WFIS]DFDCOD
        [M:DIV]DIFRAT = [F:WFIS]DFDRAT
      Endif
    Endif
    [M:FIY]DATSTRFIY(INDEXE-1) = [F:WFIS]DATSTRFIY
    [M:FIY]DATENDFIY(INDEXE-1) = [F:WFIS]DATENDFIY
    [M:FIY]RAT39BIS (INDEXE-1) = [F:WFIS]RAT39BIS
    [M:FIY]STAFIY   (INDEXE-1) = [F:WFIS]STAFIY
    [M:FIY]EVTCREFLG(INDEXE-1) = [F:WFIS]EVTCREFLG
    [M:FIY]DFDTYP   (INDEXE-1) = [F:WFIS]DFDTYP     # FQ90432
    [M:FIY]INDCURPER(INDEXE-1) = [F:WFIS]INDCURPER
    [M:FIY]NBRPER   (INDEXE-1) = [F:WFIS]NBRPER
    If (   [F:WFIS]STAFIY = GVML_TEPREC ) Then
      INDCLO = INDCLO + 1
      [M:FIY]INDDEBPER(INDEXE-1) = INDPER
      [M:FIY]INDCURPER(INDEXE-1) = 1
      [M:FIY]NBRPER   (INDEXE-1) = 1
      [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRFIY
      [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDFIY
      [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "M"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRMONPER(INDPER-1) = WPDS
      [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "W"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRWEKPER(INDPER-1) = WPDS
      [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "D"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRDAYPER(INDPER-1) = WPDS
      INDPER += 1
    Elsif ( LNUMEXE < [M:CNX]HRZPER(I_CNT-1) or ( [M:DIV]TRTDEM = "CALSIM" ) ) Then : # FQ74517 FQ78670
      LNUMEXE += 1
      If ( [F:WFIS]NBRPER = 0 ) Then
        [M:FIY]INDDEBPER(INDEXE-1) = INDPER
        [M:FIY]INDCURPER(INDEXE-1) = 1
        [M:FIY]NBRPER   (INDEXE-1) = 1
        [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRFIY
        [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDFIY
        [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "M"
        Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
        [M:FIY]NBRMONPER(INDPER-1) = WPDS
        [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "W"
        Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
        [M:FIY]NBRWEKPER(INDPER-1) = WPDS
        [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
        [M:FIY]NBRDAYPER(INDPER-1) = WPDS
        INDPER += 1
      Else
        [M:FIY]INDDEBPER(INDEXE-1) = INDPER
        For I = 1 To [F:WFIS]NBRPER
          If (I>1 and [F:WFIS]DATSTRPER(I-1)<=[F:WFIS]DATENDPER(I-2) ) Then
            [M:DIV]ERRID = 29 : Call ERRFND From   GLOBB0
            Break
          Endif
          [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRPER(I-1)
          [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDPER(I-1)
          [M:FIY]NBRMONPER(INDPER-1) = [F:WFIS]NBRMONPER(I-1)
          [M:FIY]NBRWEKPER(INDPER-1) = [F:WFIS]NBRWEKPER(I-1)
          [M:FIY]NBRDAYPER(INDPER-1) = [F:WFIS]NBRDAYPER(I-1)
          [M:FIY]STAPER   (INDPER-1) = [F:WFIS]STAPER(I-1)
          INDPER += 1
        Next I
        If ([M:DIV]ERROR) Then : Break : Endif
      Endif
    Else
      [M:FIY]INDDEBPER(INDEXE-1) = INDPER
      [M:FIY]INDCURPER(INDEXE-1) = 1
      [M:FIY]NBRPER   (INDEXE-1) = 1
      [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRFIY
      [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDFIY
      [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "M"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRMONPER(INDPER-1) = WPDS
      [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "W"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRWEKPER(INDPER-1) = WPDS
      [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "D"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRDAYPER(INDPER-1) = WPDS
      INDPER += 1
    Endif
    INDEXE += 1
  Next
  If ([M:DIV]ERROR) Then : End : Endif
  [M:FIY]NB_EXE = INDEXE-1
  [M:FIY]NB_PER = INDPER-1
  Local Integer EXEMAX
  If ( [M:DIV]TRTDEM = "CALSIM" ) Then
    EXEMAX = [M:DIV]CSTFIYMAX - INDCLO
  Else
    EXEMAX = [M:CNX]HRZEXE(I_CNT-1) + INDCLO
    If ([M:CNX]HRZEXE(I_CNT-1) + INDCLO> [M:DIV]CSTFIYMAX ) Then
      [M:DIV]ERRID = 30 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
  For I_EXE = INDEXE To EXEMAX
    LDTDB  = func GLOBB9.CAL_DAT_PLUS( [M:FIY]DATENDFIY(I_EXE-2), 1, "D" )
    [M:DIV]PD(0)= LDTDB : [M:DIV]PV(0)= GVML_TPJOUR
    Gosub GSB_CAL_EXERCICE_SELON_DATE From   GLOBB8
    LDTDBEXE = [M:DIV]RD(1) : LDTFNEXE = [M:DIV]RD(2) : LINDEXE  = [M:DIV]RE(0)
    If ([M:DIV]ERROR) Then : Break : Endif
    [M:FIY]DATSTRFIY(I_EXE-1) = LDTDBEXE
    [M:FIY]DATENDFIY(I_EXE-1) = LDTFNEXE
    [M:FIY]RAT39BIS (I_EXE-1) = 0
    [M:FIY]STAFIY   (I_EXE-1) = 0
    [M:FIY]EVTCREFLG(I_EXE-1) = G_NON
    [M:FIY]INDDEBPER(I_EXE-1) = INDPER
    [M:FIY]INDCURPER(I_EXE-1) = 1
    [M:FIY]NBRPER   (I_EXE-1) = 1
    [M:FIY]DATSTRPER(INDPER-1) = LDTDBEXE
    [M:FIY]DATENDPER(INDPER-1) = LDTFNEXE
    [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "M"
    Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
    [M:FIY]NBRMONPER(INDPER-1) = WPDS
    [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "W"
    Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
    [M:FIY]NBRWEKPER(INDPER-1) = WPDS
    [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "D"
    Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
    [M:FIY]NBRDAYPER(INDPER-1) = WPDS
    INDPER += 1
    If (INDPER >= [M:DIV]DEPMAX ) Then : Break : Endif
  Next I_EXE
  If ([M:DIV]ERROR) Then : End : Endif
  [M:FIY]NB_EXE = I_EXE-1
  [M:FIY]NB_PER = INDPER-1
End
Subprog  CAL_LEC_TABLE ( PSOC )
Value    Char PSOC
  Raz [M:TAB]
  If clalev([F:WADI]) =0 : Local File ATABDIV    [WADI]  : Endif        : # Tables diverses
Local Integer INDVEH
  INDVEH = 1
  For [WADI]CODE Where NUMTAB = GTD_PLREINV
   [M:TAB]CODVEHPLF (INDVEH-1) = [F:WADI]CODE
   [M:TAB]VEHPLF (INDVEH-1) = [F:WADI]N1
   INDVEH +=1
  Next
  [M:TAB]NB_VEH = INDVEH-1
End
$CAL_LEC_SOCIETE
  If clalev([F:WCPY]) =0 : Local File COMPANY    [WCPY]  : Endif      : # Société
  Read [F:WCPY]CPY0= [M:DIV]SOC
  If (fstat) Then
    [M:DIV]ERROR = 8
    [M:DIV]ERRID = 8 : Call ERRFND From   GLOBB0 : Return : # Dépilement suite à erreur logique
  Endif
  [M:DIV]LEGSOC = [F:WCPY]LEG
Return
Subprog  CAL_LEC_BIEN ( PREFBCO )
Value    Char    PREFBCO
  Read [WFAS]FAS0= PREFBCO
  If (fstat) Then
    [M:DIV]ERRID = 11 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
  Endif
  If ([F:WFAS]ISSFIYPRE = G_OUI ) Then
    [M:DIV]ERRID = 36 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
  Endif
End
Subprog  CAL_LEC_PROPLN (PABR, PPROPLN )
Value Char       PABR
Value Char       PPROPLN
Local Date    CURFNEXE
Local Integer INDFIY
Local Integer INDPPL
Local Decimal LQTE
Local Integer NB_EXE
Local Integer BRDEXE
Local Date    DTFNEXE
  Local Integer I_CNXUO : I_CNXUO = find([M:DIV]CNXUO, [M:CNX]CNX)
  INDFIY  = evalue("find( GVML_TECOURA, "+PABR+"STAFIY )")
  CURFNEXE = evalue(PABR +"DATENDFIY (INDFIY - 1)")
  NB_EXE  = 0
  BFNEXE  = 0
  DTFNEXE = [0/0/0]
  Raz [M:PPL]
  If clalev([F:WPPH]) =0 : Local File PROPLNH    [WPPH]  : Endif
  Read [F:WPPH]PPH0=PPROPLN
  [M:PPL]UOM = [F:WPPH]UOM
  If([M:PPL]UOM = "") Then : [M:PPL]UOM = GDEFUOM : Endif
  If clalev([F:WPPL]) =0 : Local File PROPLN    [WPPL]  : Endif
  INDPPL = 1
  For [WPPL]PPL0 Where PROPLN = PPROPLN and FIYENDDAT >= CURFNEXE
    nolign = INDPPL
    If ( [F:WPPL]FIYENDDAT <> DTFNEXE ) Then
      NB_EXE += 1
      DTFNEXE  = [F:WPPL]FIYENDDAT
    Endif
    If ( NB_EXE <= [M:CNX]HRZPER(I_CNXUO-1) or [M:DIV]TRTDEM = "CALSIM" ) Then
      [M:PPL]=[F:WPPL]
      INDPPL +=1
    Else
      If ( [F:WPPL]PERENDDAT = [F:WPPL]FIYENDDAT ) Then
        [M:PPL]=[F:WPPL]
        [M:PPL]PERSTRDAT (nolign-1) = [M:PPL]FIYSTRDAT (nolign-1)
        [M:PPL]EXTQTY    (nolign-1) = [M:PPL]FIYQTY    (nolign-1)
        INDPPL +=1
      Endif
    Endif
  Next
  If (INDPPL = 1) Then : End : Endif
  [M:DIV]DTFNPPL = [F:WPPL]PPLENDDAT
  If ( [M:PPL]CPLQTY(INDPPL-2) <> 0 ) Then
    LQTE = [M:PPL]CPLQTY(INDPPL-2)
  Else
    LQTE = [M:PPL]EXTQTY(INDPPL-2)
  Endif
  While ( [M:PPL]RSDQTY(INDPPL-2)-LQTE > 0 )
    [M:PPL]FIYSTRDAT(INDPPL-1) = func GLOBB9.CAL_DAT_PLUS( [M:PPL]FIYENDDAT(INDPPL-2), 1, "D")
    [M:PPL]PERSTRDAT(INDPPL-1) = func GLOBB9.CAL_DAT_PLUS( [M:PPL]FIYENDDAT(INDPPL-2), 1, "D")
    [M:PPL]FIYENDDAT(INDPPL-1) = func GLOBB9.CAL_DAT_PLUS( [M:PPL]FIYENDDAT(INDPPL-2), 1, "Y")
    [M:PPL]PERENDDAT(INDPPL-1) = func GLOBB9.CAL_DAT_PLUS( [M:PPL]FIYENDDAT(INDPPL-2), 1, "Y")
    [M:PPL]EXTQTY(INDPPL-1)    = [M:PPL]FIYQTY(INDPPL-2)
    If ( ( [M:PPL]EXTQTY(INDPPL-1) > [M:PPL]RSDQTY(INDPPL-2)-LQTE ) or
&        ( [M:PPL]FIYQTY(INDPPL-2)=0 and [M:PPL]RSDQTY(INDPPL-2) <> 0 ) ) Then
      [M:PPL]EXTQTY(INDPPL-1) = [M:PPL]RSDQTY(INDPPL-2)-LQTE
    Endif
    If ( func GLOBB9.CAL_DAT_INSIDE([F:WPPL]PPLENDDAT,[M:PPL]PERSTRDAT(INDPPL-1),
&                                                     [M:PPL]PERENDDAT(INDPPL-1),"I") ) Then
      [M:PPL]EXTQTY(INDPPL-1) = [M:PPL]RSDQTY(INDPPL-2)-LQTE
   Endif
   [M:PPL]CPLQTY(INDPPL-1) = 0
   [M:PPL]RSDQTY(INDPPL-1) = [M:PPL]RSDQTY(INDPPL-2)-LQTE
   [M:PPL]FIYQTY(INDPPL-1) = [M:PPL]EXTQTY(INDPPL-1)
    INDPPL +=1
    If ( INDPPL > [M:DIV]PPLMAX ) Then : Break : Endif
    If ( [M:PPL]CPLQTY(INDPPL-2) <> 0 ) Then
      LQTE = [M:PPL]CPLQTY(INDPPL-2)
    Else
      LQTE = [M:PPL]EXTQTY(INDPPL-2)
    Endif
  Wend
  If ( INDPPL > [M:DIV]PPLMAX ) Then
    [M:DIV]ERRID = 31 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
  Endif
  [M:PPL]NB_PPL = INDPPL-1
End
Subprog  CAL_LEC_DEPREC (PBCO, PPLN, PCNT )
Value Char       PBCO
Value Integer    PPLN
Value Integer    PCNT
Local Char    WPERREF(22) : WPERREF = ""
Local Date    DTDBPER
Local Date    DTDBEXE
Local Date    DTFNEXE
Local Integer INDDEP
Local Integer LFPC      : # Indice de la période courante de l'exercice courant
  Case PCNT
    When G300CPFI
      DTDBEXE = [M:EGCF]DATSTRFIY(find( GVML_TECOURA, [M:EGCF]STAFIY ) - 1)
      DTFNEXE = [M:EGCF]DATENDFIY(find( GVML_TECOURA, [M:EGCF]STAFIY ) - 1)
      LFPC = [M:EGCF]INDDEBPER (find( GVML_TECOURA, [M:EGCF]STAFIY )-1) +
&            [M:EGCF]INDCURPER (find( GVML_TECOURA, [M:EGCF]STAFIY )-1) - 1
      DTDBPER = [M:EGCF]DATSTRPER (LFPC-1)
    When G300IAS
      DTDBEXE = [M:EIAS]DATSTRFIY(find( GVML_TECOURA, [M:EIAS]STAFIY ) - 1)
      DTFNEXE = [M:EIAS]DATENDFIY(find( GVML_TECOURA, [M:EIAS]STAFIY ) - 1)
      LFPC = [M:EIAS]INDDEBPER (find( GVML_TECOURA, [M:EIAS]STAFIY )-1) +
&            [M:EIAS]INDCURPER (find( GVML_TECOURA, [M:EIAS]STAFIY )-1) - 1
      DTDBPER = [M:EIAS]DATSTRPER (LFPC-1)
    When G300TEC
      DTDBEXE = [M:ETEC]DATSTRFIY(find( GVML_TECOURA, [M:ETEC]STAFIY ) - 1)
      DTFNEXE = [M:ETEC]DATENDFIY(find( GVML_TECOURA, [M:ETEC]STAFIY ) - 1)
      LFPC = [M:ETEC]INDDEBPER (find( GVML_TECOURA, [M:ETEC]STAFIY )-1) +
&            [M:ETEC]INDCURPER (find( GVML_TECOURA, [M:ETEC]STAFIY )-1) - 1
      DTDBPER = [M:ETEC]DATSTRPER (LFPC-1)
    When G300RET
      DTDBEXE = [M:ERET]DATSTRFIY(find( GVML_TECOURA, [M:ERET]STAFIY ) - 1)
      DTFNEXE = [M:ERET]DATENDFIY(find( GVML_TECOURA, [M:ERET]STAFIY ) - 1)
      LFPC = [M:ERET]INDDEBPER (find( GVML_TECOURA, [M:ERET]STAFIY )-1) +
&            [M:ERET]INDCURPER (find( GVML_TECOURA, [M:ERET]STAFIY )-1) - 1
      DTDBPER = [M:ERET]DATSTRPER (LFPC-1)
    When G300SUB
      DTFNEXE = [M:ESUB]DATSTRFIY(find( GVML_TECOURA, [M:ESUB]STAFIY ) - 1)
      DTFNEXE = [M:ESUB]DATENDFIY(find( GVML_TECOURA, [M:ESUB]STAFIY ) - 1)
      LFPC = [M:ESUB]INDDEBPER (find( GVML_TECOURA, [M:ESUB]STAFIY )-1) +
&            [M:ESUB]INDCURPER (find( GVML_TECOURA, [M:ESUB]STAFIY )-1) - 1
      DTDBPER = [M:EGCF]DATSTRPER (LFPC-1)
    When G300LIB
      DTDBEXE = [M:ELI1]DATSTRFIY(find( GVML_TECOURA, [M:ELI1]STAFIY ) - 1)
      DTFNEXE = [M:ELI1]DATENDFIY(find( GVML_TECOURA, [M:ELI1]STAFIY ) - 1)
      LFPC = [M:ELI1]INDDEBPER (find( GVML_TECOURA, [M:ELI1]STAFIY )-1) +
&            [M:ELI1]INDCURPER (find( GVML_TECOURA, [M:ELI1]STAFIY )-1) - 1
      DTDBPER = [M:ELI1]DATSTRPER (LFPC-1)
    When G300SU1
      DTDBEXE = [M:ELI2]DATSTRFIY(find( GVML_TECOURA, [M:ELI2]STAFIY ) - 1)
      DTFNEXE = [M:ELI2]DATENDFIY(find( GVML_TECOURA, [M:ELI2]STAFIY ) - 1)
      LFPC = [M:ELI2]INDDEBPER (find( GVML_TECOURA, [M:ELI2]STAFIY )-1) +
&            [M:ELI2]INDCURPER (find( GVML_TECOURA, [M:ELI2]STAFIY )-1) - 1
      DTDBPER = [M:ELI2]DATSTRPER (LFPC-1)
    When G300SU2
      DTDBEXE = [M:ELI3]DATSTRFIY(find( GVML_TECOURA, [M:ELI3]STAFIY ) - 1)
      DTFNEXE = [M:ELI3]DATENDFIY(find( GVML_TECOURA, [M:ELI3]STAFIY ) - 1)
      LFPC = [M:ELI3]INDDEBPER (find( GVML_TECOURA, [M:ELI3]STAFIY )-1) +
&            [M:ELI3]INDCURPER (find( GVML_TECOURA, [M:ELI3]STAFIY )-1) - 1
      DTDBPER = [M:ELI3]DATSTRPER (LFPC-1)
    When G300SU3
      DTDBEXE = [M:ELI4]DATSTRFIY(find( GVML_TECOURA, [M:ELI4]STAFIY ) - 1)
      DTFNEXE = [M:ELI4]DATENDFIY(find( GVML_TECOURA, [M:ELI4]STAFIY ) - 1)
      LFPC = [M:ELI4]INDDEBPER (find( GVML_TECOURA, [M:ELI4]STAFIY )-1) +
&            [M:ELI4]INDCURPER (find( GVML_TECOURA, [M:ELI4]STAFIY )-1) - 1
      DTDBPER = [M:ELI4]DATSTRPER (LFPC-1)
    When G300SU4
      DTDBEXE = [M:ELI5]DATSTRFIY(find( GVML_TECOURA, [M:ELI5]STAFIY ) - 1)
      DTFNEXE = [M:ELI5]DATENDFIY(find( GVML_TECOURA, [M:ELI5]STAFIY ) - 1)
      LFPC = [M:ELI5]INDDEBPER (find( GVML_TECOURA, [M:ELI5]STAFIY )-1) +
&            [M:ELI5]INDCURPER (find( GVML_TECOURA, [M:ELI5]STAFIY )-1) - 1
      DTDBPER = [M:ELI5]DATSTRPER (LFPC-1)
    When G300SU5
      DTDBEXE = [M:ELI6]DATSTRFIY(find( GVML_TECOURA, [M:ELI6]STAFIY ) - 1)
      DTFNEXE = [M:ELI6]DATENDFIY(find( GVML_TECOURA, [M:ELI6]STAFIY ) - 1)
      LFPC = [M:ELI6]INDDEBPER (find( GVML_TECOURA, [M:ELI6]STAFIY )-1) +
&            [M:ELI6]INDCURPER (find( GVML_TECOURA, [M:ELI6]STAFIY )-1) - 1
      DTDBPER = [M:ELI6]DATSTRPER (LFPC-1)
  Endcase
  Raz [M:DEP]
  INDDEP = 1
  Filter [WDEP] Where AASREF = PBCO and DPRPLN = PPLN and FIYENDDAT >= DTFNEXE
  For [WDEP]DEP0
    nolign = INDDEP
    [M:DEP]=[F:WDEP]
    [M:DEP]FLGACT(nolign-1) = "N"
    If ( [M:DEP]PERSTRDAT(nolign-1) = [0/0/0] ) Then
      [M:DEP]PERSTRDAT(nolign-1) = [M:DEP]FIYSTRDAT(nolign-1)
    Endif
    If ( [M:DEP]PERENDDAT(nolign-1) = [0/0/0] ) Then
      [M:DEP]PERENDDAT(nolign-1) = [M:DEP]FIYENDDAT(nolign-1)
    Endif
    If ( [M:DEP]PERREFCLC(nolign-1) = [0/0/0] ) Then
      [M:DEP]PERREFCLC (nolign-1) = [M:DEP]FIYSTRDAT(nolign-1)
      [M:DEP]PERREFCLCI(nolign-1) = [M:DEP]FIYSTRDAT(nolign-1)
      [M:DEP]PERREFCLCT(nolign-1) = [M:DEP]FIYSTRDAT(nolign-1)
    Endif
    If ([M:DEP]DPMT (nolign-1) = "") Then : [M:DEP]DPMT (nolign-1) = [F:WDEP]DPM : Endif
    If ([M:DEP]DPMI (nolign-1) = "") Then : [M:DEP]DPMI (nolign-1) = [F:WDEP]DPM : Endif
    If ([M:DEP]CNX (nolign-1) = 0 ) Then : [M:DEP]CNX (nolign-1) = PCNT          : Endif
    If ([M:DEP]FCY (nolign-1) = "") Then : [M:DEP]FCY (nolign-1) = [F:WFAS]FCY    : Endif
    If ( [M:DEP]PERSTRDAT(nolign-1) = DTDBPER)
      Gosub CAL_VERIF_PERREFCLC From   GLOBB7
      If (WPERREF <> "" and [M:DIV]TRTDEM <> "CALSOC" and (GADONIX = G_OUI or [M:DIV]NIVDET > 0)) Then : Break : Endif
    Endif
    INDDEP +=1
  Next
  If (WPERREF <> "" and [M:DIV]TRTDEM <> "CALSOC" and (GADONIX = G_OUI or [M:DIV]NIVDET > 0) ) Then
    [M:DIV]ERRID = 48 : Call ERRFND From   GLOBB0
    End
  Endif
  [M:DEP]NB_DEP = INDDEP-1
  Filter [WDEP]
End
Subprog CALCUL_MAJ_BIEN(PTABCNT)
Value    Integer PTABCNT()
Local Integer I_CNX
Local Integer FEC, FPC, DPC
  [F:WFAS]UPDUSR = GUSER
  [F:WFAS]UPDDAT = date$
  If ( [M:DIV]PLNSUB and find(G300CPFI, PTABCNT) <> 0) Then
    FEC = find(GVML_TECOURA,[M:EGCF]STAFIY)
    FPC = [M:EGCF]INDDEBPER(FEC-1) + [M:EGCF]INDCURPER(FEC-1) - 1
    DPC = find( [M:EGCF]DATENDFIY (FEC-1), [M:PSUB]PERENDDAT )
    [F:WFAS]CRBGRAAMT = [M:PSUB]ENDDPE (DPC-1) + [M:PSUB]EXCDPR (DPC-1)
  Endif
  For I_CNX = 1 To [M:CNX]NB_CNX
    If ( find([M:CNX]CNX(I_CNX-1), PTABCNT) ) Then
      If ( [M:DIV]TRTDEM = "CALBCO" or [F:WFAS]FLGCNXCLC([M:CNX]CNX(I_CNX-1)-1) <> GVML_RCNON ) Then
        [F:WFAS]FLGCNXCLC([M:CNX]CNX(I_CNX-1)-1) = GVML_RCNON
        If mid$([F:WFAS]FLGCNXFLX, [M:CNX]CNX(I_CNX-1), 1) = num$(GVML_FLXGENE)
          [F:WFAS]FLGCNXFLX = func GLOFUNC.SETRNGSTR([F:WFAS]FLGCNXFLX, [M:CNX]CNX(I_CNX-1), num$(GVML_FLXNOTG))
        Endif
      Endif
    Endif
  Next
  For I_CNX = 1 To G300MAX
    If ( find(I_CNX, [M:CNX]CNX) = 0 ) Then
      [F:WFAS]FLGCNXCLC(I_CNX-1) = 0
    Endif
  Next I_CNX
  If ([M:DIV]BACTCCN) Then
     If ( find(G300CPFI, PTABCNT) <> 0 ) Then
      [F:WFAS]FLGRPRCLC = G_NON
    Endif
    Endif
  If ( not find(GVML_RCOUI,[F:WFAS]FLGCNXCLC) and not find(GVML_RCCLO,[F:WFAS]FLGCNXCLC) and
&      ( not [M:DIV]BACTCCN or [F:WFAS]FLGRPRCLC = G_NON) ) Then
    [F:WFAS]FLGCLC = G_NON
  Endif
  Rewrite [F:WFAS]
  If ( fstat ) Then
    RERROR = -1
    Call FSTA("WFAS") From GLOCK
    Call ECR_TRACE(mess(28,7774,1)-[F:WFAS]AASREF,1) From   GLOBB0
    [M:DIV]ERRID = 15 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
    Endif
End
Subprog CALCUL_MAJ_CONTEXTES (PTABCNT)
Value    Integer PTABCNT()
Local Integer N_C, N_P
  For N_C = 1 To G300MAX
    If ( PTABCNT(N_C-1) <> 0 and ([M:DIV]TRTDEM = "CALBCO" or [F:WFAS]FLGCNXCLC(PTABCNT(N_C-1)-1) <> GVML_RCNON) ) Then
      DEB = find(PTABCNT(N_C-1), [M:DIV]PLNCNT)
      For N_P = DEB To [M:DIV]NB_PLN
        If ( [M:DIV]PLNCNT (N_P-1) <> PTABCNT(N_C-1) )  Then : Break : Endif
        If ( [M:DIV]TRTDEM = "CALBCO" or [F:WFAS]FLGCNXCLC(PTABCNT(N_C-1)-1) <> GVML_RCNON ) Then
          Call CALCUL_MAJ_PLAN ([M:DIV]PLNCAA(N_P-1)) From   GLOBB0
          If ([M:DIV]ERROR) Then : Break 2 : Endif
      Endif
      Next N_P
    Endif
  Next N_C
  If ([M:DIV]ERROR) Then : End : Endif
End
Subprog SIMUL_MAJ_CONTEXTES (PTABCNT, PTABPLN)
Value    Integer PTABCNT()
Value    Integer PTABPLN()
Local Integer N_C, N_P
  For N_C = 1 To G300MAX
    If ( PTABCNT(N_C-1) <> 0 ) Then
      DEB = find(PTABCNT(N_C-1), [M:DIV]PLNCNT)
      For N_P = DEB To [M:DIV]NB_PLN
        If ( [M:DIV]PLNCNT (N_P-1) <> PTABCNT(N_C-1) )  Then : Break : Endif
        If ( find([M:DIV]PLNCAA (N_P-1), PTABPLN ) > 0 ) Then
          Call SIMUL_MAJ_PLAN ([M:DIV]PLNCAA(N_P-1)) From   GLOBB0
          If ([M:DIV]ERROR) Then : Break 2 : Endif
    Endif
      Next N_P
    Endif
  Next N_C
  If ([M:DIV]ERROR) Then : End : Endif
End
Subprog CALCUL_MAJ_PLAN ( PPLN )
Value    Integer PPLN
Local    Integer LERROR
Local    Char    LACTION
LERROR = 0
  Raz [M:DEP]
  Case PPLN
    When G301CPT  : Transmask [M:PCPT] To [M:DEP]
    When G301FIS  : Transmask [M:PFIS] To [M:DEP]
    When G301MIN  : Transmask [M:PMIN] To [M:DEP]
    When G301ORI  : Transmask [M:PORI] To [M:DEP]
    When G301R76  : Transmask [M:PR76] To [M:DEP]
    When G301IAS  : Transmask [M:PIAS] To [M:DEP]
    When G301TEC  : Transmask [M:PTEC] To [M:DEP]
    When G301RET  : Transmask [M:PRET] To [M:DEP]
    When G301SUB  : Transmask [M:PSUB] To [M:DEP]
    When G301LI1  : Transmask [M:PLI1] To [M:DEP]
    When G301LI2  : Transmask [M:PLI2] To [M:DEP]
    When G301LI3  : Transmask [M:PLI3] To [M:DEP]
    When G301LI4  : Transmask [M:PLI4] To [M:DEP]
    When G301LI5  : Transmask [M:PLI5] To [M:DEP]
    When G301LI6  : Transmask [M:PLI6] To [M:DEP]
  Endcase
  For N_D = 1 To [M:DEP]NB_DEP
    If    ( [M:DEP]FLGACT (N_D-1) = "I" ) Then : LACTION = "Insert"
    Elsif ( [M:DEP]FLGACT (N_D-1) = "U" ) Then : LACTION = "Update"
    Else                                         LACTION = "No upd"
    Endif
    If ( [M:DEP]DPEDEV(N_D-1)    = 0 and [M:DEP]EXCDEV(N_D-1)   = 0 and
&        [M:DEP]DERDEV(N_D-1)    = 0 and [M:DEP]DERRVEDEV(N_D-1)= 0 and
&        [M:DEP]RVETRFDEV(N_D-1) = 0 and [M:DEP]RVACRBDEV(N_D-1)= 0     ) Then
      [M:DEP]FLGDEV(N_D-1)= G_NON
    Else
      [M:DEP]FLGDEV(N_D-1)= G_OUI
  Endif
    If ( G_ACTCCN =  G_OUI ) and ( [M:DEP]CADCRBDEV(N_D-1)<> 0 )
      [M:DEP]FLGDEV(N_D-1)= G_OUI
    Endif
    If ( [M:DEP]LNKDEV(N_D-1) = 0 ) Then
      [M:DEP]FLGLNKDEV(N_D-1)= G_NON
    Else
      [M:DEP]FLGLNKDEV(N_D-1)= G_OUI
    Endif
    Case [M:DEP]FLGACT (N_D-1)
      When "U"
        If ([M:DIV]BLECMAJ) Then
          Read [WDEP]
&           DEP0=[F:WFAS]AASREF;[M:DEP]DPRPLN(N_D-1);[M:DEP]FIYENDDAT(N_D-1);[M:DEP]PERENDDAT(N_D-1)
          If ( fstat ) Then
            LERROR = -1
            Call FSTA("WDEP") From GLOCK
            Call ECR_TRACE
&           ( "Read DEP"+num$([M:DEP]DPRPLN(N_D-1))-[F:WFAS]AASREF-'fstat='-num$(fstat),1) From   GLOBB0
    Endif
    Endif
        nolign = N_D : [F:WDEP] = [M:DEP]
        [F:WDEP]ETRPNT = G_ETRPNT
        If ( [F:WDEP]DEPSTA <> GVML_SCCLOS ) Then :  [F:WDEP]DEPSTA = GVML_SCCAL : Endif
        Rewrite [WDEP]
&         DEP0=[F:WFAS]AASREF;[M:DEP]DPRPLN(N_D-1);[M:DEP]FIYENDDAT(N_D-1);[M:DEP]PERENDDAT(N_D-1)
        If ( fstat ) Then
          LERROR = -1
          Call FSTA("WDEP") From GLOCK
          Call ECR_TRACE
&         ( "Rewrite DEP"-num$([M:DEP]DPRPLN(N_D-1))-[F:WFAS]AASREF-'fstat='-num$(fstat),1) From   GLOBB0
     Endif
      When "I"
        nolign = N_D : [F:WDEP] = [M:DEP]
        [F:WDEP]ETRPNT = G_ETRPNT
        [F:WDEP]DEPSTA = GVML_SCCAL
        If (adxwrb > 0) Then : WriteB [WDEP] : Else : Write [WDEP] : Endif : # FQ83206
        If ( fstat ) Then
          LERROR = -1
          Call FSTA("WDEP") From GLOCK
          Call ECR_TRACE
&              ("Write DEP"-num$([M:DEP]DPRPLN(N_D-1))-[F:WFAS]AASREF-'fstat='-num$(fstat),1) From   GLOBB0
  Endif
    Endcase
    If (LERROR) Then :  Break : Endif
  Next N_D
  If ( LERROR ) Then
      [M:DIV]ERRID = 16 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
  Else
    If ( [M:DEP]NB_DEP <> 0 ) Then
      Delete [WDEP] Where AASREF=[F:WFAS]AASREF and DPRPLN= [M:DEP]DPRPLN([M:DEP]NB_DEP-1)
&     and FIYENDDAT >= [M:DEP]FIYENDDAT([M:DEP]NB_DEP-1) and PERENDDAT > [M:DEP]PERENDDAT([M:DEP]NB_DEP-1)
  If ( fstat ) Then
        LERROR = -1
        Call FSTA("WDEP") From GLOCK
        Call ECR_TRACE(mess(154,7774,1)+num$(DPRPLN)-AASREF,1) From   GLOBB0
  Endif
        Endif
    Endif
  If ( LERROR ) Then
    [M:DIV]ERRID = 14 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
  Endif
End
Subprog SIMUL_MAJ_PLAN ( PPLN )
Value    Integer PPLN
Local    Integer LERROR
Local    Char    LACTION
LERROR = 0
  Raz [M:DEP]
  Case PPLN
    When G301CPT  : Transmask [M:PCPT] To [M:DEP]
    When G301FIS  : Transmask [M:PFIS] To [M:DEP]
    When G301MIN  : Transmask [M:PMIN] To [M:DEP]
    When G301ORI  : Transmask [M:PORI] To [M:DEP]
    When G301R76  : Transmask [M:PR76] To [M:DEP]
    When G301IAS  : Transmask [M:PIAS] To [M:DEP]
    When G301TEC  : Transmask [M:PTEC] To [M:DEP]
    When G301RET  : Transmask [M:PRET] To [M:DEP]
    When G301SUB  : Transmask [M:PSUB] To [M:DEP]
    When G301LI1  : Transmask [M:PLI1] To [M:DEP]
    When G301LI2  : Transmask [M:PLI2] To [M:DEP]
    When G301LI3  : Transmask [M:PLI3] To [M:DEP]
    When G301LI4  : Transmask [M:PLI4] To [M:DEP]
    When G301LI5  : Transmask [M:PLI5] To [M:DEP]
    When G301LI6  : Transmask [M:PLI6] To [M:DEP]
  Endcase
#CHECK IGNORE_BEGIN
    GOK = 1
    GPOINT = "BEFDPS"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9002 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
    Endif
#CHECK IGNORE_END
  If ([M:CNX]FLGSIMDET(find([M:DEP]CNX(0),[M:CNX]CNX)-1) <> G_OUI ) Then
    If ([M:DEP]NB_DEP > 0) Then
      nolign = [M:DEP]NB_DEP
      [F:DPS] = [F:WFAS]
      [F:DPS] = [M:DEP]
      Write [DPS]
          If ( fstat ) Then
            LERROR = -1
        Call FSTA("DPS") From GLOCK
            Call ECR_TRACE
&            ("Write DPS"-num$([M:DEP]DPRPLN(0))-[F:WFAS]AASREF-'fstat='-num$(fstat),1) From   GLOBB0
        Endif
        Endif
  Else
    For N_D = 1 To [M:DEP]NB_DEP
      nolign = N_D
      [F:DPS] = [F:WFAS]
      [F:DPS] = [M:DEP]
      Write [DPS]
        If ( fstat ) Then
          LERROR = -1
        Call FSTA("DPS") From GLOCK
          Call ECR_TRACE
&            ("Write DPS"-num$([M:DEP]DPRPLN(0))-[F:WFAS]AASREF-'fstat='-num$(fstat),1) From   GLOBB0
        Endif
    If (LERROR) Then :  Break : Endif
  Next N_D
  Endif
  If ( LERROR ) Then
    [M:DIV]ERRID = 45 : Call ERRFND From   GLOBB0 : End : # Dépilement suite à erreur logique
  Endif
End
Subprog CALCUL_MAJ_MASQUE_SIMULATION
Local Char     ABR1     : # Abréviation du plan  1
Local Char     ABR2     : # Abréviation du plan  2
Local Integer  BCHARGE  : # Ligne à écrire dans le masque simulation
Local Integer  N_S      : # Indice FVP1 masque simulation
Local Integer  N_I      : # Indice DEP courant
Local Integer  N_D1     : # Indice DEP masque plan 1
Local Integer  N_D2     : # Indice DEP masque plan 2
Local Integer  BPLN1    : # Informations plan 1 à afficher
Local Integer  BPLN2    : # Informations plan 2 à afficher
Local Integer  BBOTH    : # Informations des deux plans à afficher
  [M:FVP1]NBLIG = 0
  Call ACTION_BLOCK (ACB_EFFZO, "FASVISPLN1", "FIYENDDAT") From GLOBIENS
  Case [M:DIV]SIMPLN1
    When G301CPT  : ABR1 = "[M:PCPT]"
    When G301FIS  : ABR1 = "[M:PFIS]"
    When G301MIN  : ABR1 = "[M:PMIN]"
    When G301ORI  : ABR1 = "[M:PORI]"
    When G301R76  : ABR1 = "[M:PR76]"
    When G301IAS  : ABR1 = "[M:PIAS]"
    When G301TEC  : ABR1 = "[M:PTEC]"
    When G301RET  : ABR1 = "[M:PRET]"
    When G301SUB  : ABR1 = "[M:PSUB]"
    When G301LI1  : ABR1 = "[M:PLI1]"
    When G301LI2  : ABR1 = "[M:PLI2]"
    When G301LI3  : ABR1 = "[M:PLI3]"
    When G301LI4  : ABR1 = "[M:PLI4]"
    When G301LI5  : ABR1 = "[M:PLI5]"
    When G301LI6  : ABR1 = "[M:PLI6]"
  Endcase
  If ([M:DIV]SIMPLN2) Then
    Case [M:DIV]SIMPLN2
      When G301CPT  : ABR2 = "[M:PCPT]"
      When G301FIS  : ABR2 = "[M:PFIS]"
      When G301MIN  : ABR2 = "[M:PMIN]"
      When G301ORI  : ABR2 = "[M:PORI]"
      When G301R76  : ABR2 = "[M:PR76]"
      When G301IAS  : ABR2 = "[M:PIAS]"
      When G301TEC  : ABR2 = "[M:PTEC]"
      When G301RET  : ABR2 = "[M:PRET]"
      When G301SUB  : ABR2 = "[M:PSUB]"
      When G301LI1  : ABR2 = "[M:PLI1]"
      When G301LI2  : ABR2 = "[M:PLI2]"
      When G301LI3  : ABR2 = "[M:PLI3]"
      When G301LI4  : ABR2 = "[M:PLI4]"
      When G301LI5  : ABR2 = "[M:PLI5]"
      When G301LI6  : ABR2 = "[M:PLI6]"
    Endcase
  Endif
  LPERENDDAT1 = evalue(ABR1+"PERENDDAT(0)")
  LPERENDDAT2 = evalue(ABR2+"PERENDDAT(0)")
  N_S  = 0
  N_D1 = 0
  N_D2 = 0
  N_I  = 1
  While (  N_D1 < evalue(ABR1+"NB_DEP" ) or ( [M:DIV]SIMPLN2 and N_D2 < evalue(ABR2+"NB_DEP") )  )
    If ( [M:DIV]SIMEXEPER = GVML_EPPERIO                     and
&        evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")") = [0/0/0] and
&        evalue(ABR2+"PERENDDAT("+num$(N_I-1)+")") = [0/0/0]      ) Then
      Break
    Endif
    BBOTH  = 0
    BPLN1  = 0
    BPLN2  = 0
    If ( ( evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")") < evalue(ABR2+"PERENDDAT("+num$(N_I-1)+")") and
&          evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")") <> [0/0/0] ) or
&        ( [M:DIV]SIMPLN2 = 0 ) or ( N_D2 = evalue(ABR2+"NB_DEP"))  ) Then
      BPLN1 = 1 : N_D1 += 1
    Elsif    ( evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")") > evalue(ABR2+"PERENDDAT("+num$(N_I-1)+")")
&        or ( N_D1 = evalue(ABR1+"NB_DEP"))  ) Then
      BPLN2 = 1 : N_D2 += 1
    Else
      BBOTH = 1  : N_D1 += 1 : N_D2 += 1
    Endif
    BCHARGE = 1
    If ( BPLN1 and [M:DIV]SIMEXEPER = GVML_EPEXERC and
&     evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")") <> [0/0/0] and
&     evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")") <> evalue(ABR1+"FIYENDDAT("+num$(N_I-1)+")") ) Then
      BCHARGE = 0
    Endif
    If ( BPLN2 and [M:DIV]SIMEXEPER = GVML_EPEXERC and
&     evalue(ABR2+"PERENDDAT("+num$(N_I-1)+")") <> [0/0/0] and
&     evalue(ABR2+"PERENDDAT("+num$(N_I-1)+")") <> evalue(ABR2+"FIYENDDAT("+num$(N_I-1)+")") ) Then
      BCHARGE = 0
    Endif
    If ( BBOTH and [M:DIV]SIMEXEPER = GVML_EPEXERC and
&       ( ( evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")") <> [0/0/0] and
&          evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")") <> evalue(ABR1+"FIYENDDAT("+num$(N_I-1)+")") )
&        or
&        ( evalue(ABR2+"PERENDDAT("+num$(N_I-1)+")") <> [0/0/0] and
&          evalue(ABR2+"PERENDDAT("+num$(N_I-1)+")") <> evalue(ABR2+"FIYENDDAT("+num$(N_I-1)+")") )
&       )
&      ) Then
      BCHARGE = 0
    Endif
    If ( BCHARGE ) Then
      Gosub SIM_CHARGE_MASQUE  From   GLOBB0
    Endif
    N_I += 1
  Wend
  [M:FVP1]NBLIG = N_S
  Call ACTION_BLOCK (ACB_AFFZO, "FASVISPLN1", "FIYENDDAT") From GLOBIENS
  If ([M:DIV]SIMPLN2) Then
    For N_I = 1 To [M:FVP1]NBLIG
      If ( [M:FVP1]DEVDPE(N_I-1) < 0 ) Then
        Chgstl [M:FVP1]DEVDPE(N_I-1) With "NBNEGATIF"
      Else
        Chgstl [M:FVP1]DEVDPE(N_I-1) With ""
      Endif
    Next N_I
  Endif
End
$SIM_CHARGE_MASQUE
  N_S += 1
  If ( BPLN1 ) Then
    [M:FVP1]FIYENDDAT(N_S-1)  = evalue(ABR1+"FIYENDDAT("+num$(N_I-1)+")")
    [M:FVP1]BSEVAL1(N_S-1)    = evalue(ABR1+"DPRBAS("+num$(N_I-1)+")")
    [M:FVP1]IMLSLD1(N_S-1)    = evalue(ABR1+"IMLBLC("+num$(N_I-1)+")")
    [M:FVP1]IML1(N_S-1)       = evalue(ABR1+"IML("+num$(N_I-1)+")")
    [M:FVP1]IMLRVE1(N_S-1)    = evalue(ABR1+"IMLRVE("+num$(N_I-1)+")")
    [M:FVP1]VALNET1(N_S-1)    = evalue(ABR1+"NBV("+num$(N_I-1)+")")
    [M:FVP1]PERENDDAT(N_S-1)  = evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")")
    [M:FVP1]PERENDDATC(N_S-1) = format$("D:" + GFMDAT4, [M:FVP1]PERENDDAT(N_S-1))
    If ( [M:DIV]SIMEXEPER = GVML_EPEXERC ) Then
      [M:FVP1]DPRCUM1(N_S-1)   = evalue(ABR1+"DPRCUM("+num$(N_I-1)+")")
      [M:FVP1]ENDDPE1(N_S-1)   = evalue(ABR1+"ENDDPE("+num$(N_I-1)+")")
      [M:FVP1]EXCDPR1(N_S-1)   = evalue(ABR1+"EXCDPR("+num$(N_I-1)+")")
    Else
      [M:FVP1]DPRCUM1(N_S-1)   = evalue(ABR1+"DPRCUM("+num$(N_I-1)+")") +
&                                evalue(ABR1+"PERCLOCUM("+num$(N_I-1)+")") +
&                                evalue(ABR1+"PERCLOEXC("+num$(N_I-1)+")")
      [M:FVP1]ENDDPE1(N_S-1)   = evalue(ABR1+"PERENDDPE("+num$(N_I-1)+")")
      [M:FVP1]EXCDPR1(N_S-1)   = evalue(ABR1+"PEREXCDPR("+num$(N_I-1)+")")
    Endif
    [M:FVP1]BSEVAL2(N_S-1)   = 0
    [M:FVP1]DPRCUM2(N_S-1)   = 0
    [M:FVP1]ENDDPE2(N_S-1)   = 0
    [M:FVP1]IMLSLD2(N_S-1)   = 0
    [M:FVP1]IML2(N_S-1)      = 0
    [M:FVP1]IMLRVE2(N_S-1)   = 0
    [M:FVP1]VALNET2(N_S-1)   = 0
    [M:FVP1]EXCDPR2(N_S-1)   = 0
  Endif
  If ( BPLN2 ) Then
    [M:FVP1]FIYENDDAT(N_S-1) = evalue(ABR2+"FIYENDDAT("+num$(N_I-1)+")")
    [M:FVP1]BSEVAL1(N_S-1)   = 0
    [M:FVP1]DPRCUM1(N_S-1)   = 0
    [M:FVP1]ENDDPE1(N_S-1)   = 0
    [M:FVP1]IMLSLD1(N_S-1)   = 0
    [M:FVP1]IML1(N_S-1)      = 0
    [M:FVP1]IMLRVE1(N_S-1)   = 0
    [M:FVP1]VALNET1(N_S-1)   = 0
    [M:FVP1]EXCDPR1(N_S-1)   = 0
    [M:FVP1]BSEVAL2(N_S-1)   = evalue(ABR2+"DPRBAS("+num$(N_I-1)+")")
    [M:FVP1]IMLSLD2(N_S-1)   = evalue(ABR2+"IMLBLC("+num$(N_I-1)+")")
    [M:FVP1]IML2(N_S-1)      = evalue(ABR2+"IML("+num$(N_I-1)+")")
    [M:FVP1]IMLRVE2(N_S-1)   = evalue(ABR2+"IMLRVE("+num$(N_I-1)+")")
    [M:FVP1]VALNET2(N_S-1)   = evalue(ABR2+"NBV("+num$(N_I-1)+")")
    [M:FVP1]PERENDDAT(N_S-1)  = evalue(ABR2+"PERENDDAT("+num$(N_I-1)+")")
    [M:FVP1]PERENDDATC(N_S-1) = format$("D:" + GFMDAT4, [M:FVP1]PERENDDAT(N_S-1))
    If ( [M:DIV]SIMEXEPER = GVML_EPEXERC ) Then
      [M:FVP1]DPRCUM2(N_S-1)   = evalue(ABR2+"DPRCUM("+num$(N_I-1)+")")
      [M:FVP1]ENDDPE2(N_S-1)   = evalue(ABR2+"ENDDPE("+num$(N_I-1)+")")
      [M:FVP1]EXCDPR2(N_S-1)   = evalue(ABR2+"EXCDPR("+num$(N_I-1)+")")
    Else
      [M:FVP1]DPRCUM2(N_S-1)   = evalue(ABR2+"DPRCUM("+num$(N_I-1)+")")    +
&                                evalue(ABR2+"PERCLOCUM("+num$(N_I-1)+")") +
&                                evalue(ABR2+"PERCLOEXC("+num$(N_I-1)+")")
      [M:FVP1]ENDDPE2(N_S-1)   = evalue(ABR2+"PERENDDPE("+num$(N_I-1)+")")
      [M:FVP1]EXCDPR2(N_S-1)   = evalue(ABR2+"PEREXCDPR("+num$(N_I-1)+")")
    Endif
  Endif
  If ( BBOTH ) Then
    [M:FVP1]FIYENDDAT(N_S-1) = evalue(ABR1+"FIYENDDAT("+num$(N_I-1)+")")
    [M:FVP1]BSEVAL1(N_S-1)   = evalue(ABR1+"DPRBAS("+num$(N_I-1)+")")
    [M:FVP1]BSEVAL2(N_S-1)   = evalue(ABR2+"DPRBAS("+num$(N_I-1)+")")
    [M:FVP1]IMLSLD1(N_S-1)   = evalue(ABR1+"IMLBLC("+num$(N_I-1)+")")
    [M:FVP1]IMLSLD2(N_S-1)   = evalue(ABR2+"IMLBLC("+num$(N_I-1)+")")
    [M:FVP1]IML1(N_S-1)      = evalue(ABR1+"IML("+num$(N_I-1)+")")
    [M:FVP1]IML2(N_S-1)      = evalue(ABR2+"IML("+num$(N_I-1)+")")
    [M:FVP1]IMLRVE1(N_S-1)   = evalue(ABR1+"IMLRVE("+num$(N_I-1)+")")
    [M:FVP1]IMLRVE2(N_S-1)   = evalue(ABR2+"IMLRVE("+num$(N_I-1)+")")
    [M:FVP1]VALNET1(N_S-1)   = evalue(ABR1+"NBV("+num$(N_I-1)+")")
    [M:FVP1]VALNET2(N_S-1)   = evalue(ABR2+"NBV("+num$(N_I-1)+")")
    If ( evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")") <> [0/0/0] ) Then
      [M:FVP1]PERENDDAT(N_S-1) = evalue(ABR1+"PERENDDAT("+num$(N_I-1)+")")
    Else
      [M:FVP1]PERENDDAT(N_S-1) = evalue(ABR2+"PERENDDAT("+num$(N_I-1)+")")
    Endif
    [M:FVP1]PERENDDATC(N_S-1) = format$("D:" + GFMDAT4, [M:FVP1]PERENDDAT(N_S-1))
    If ( [M:DIV]SIMEXEPER = GVML_EPEXERC ) Then
      [M:FVP1]DPRCUM1(N_S-1)   = evalue(ABR1+"DPRCUM("+num$(N_I-1)+")")
      [M:FVP1]DPRCUM2(N_S-1)   = evalue(ABR2+"DPRCUM("+num$(N_I-1)+")")
      [M:FVP1]ENDDPE1(N_S-1)   = evalue(ABR1+"ENDDPE("+num$(N_I-1)+")")
      [M:FVP1]ENDDPE2(N_S-1)   = evalue(ABR2+"ENDDPE("+num$(N_I-1)+")")
      [M:FVP1]EXCDPR1(N_S-1)   = evalue(ABR1+"EXCDPR("+num$(N_I-1)+")")
      [M:FVP1]EXCDPR2(N_S-1)   = evalue(ABR2+"EXCDPR("+num$(N_I-1)+")")
    Else
      [M:FVP1]DPRCUM1(N_S-1)   = evalue(ABR1+"DPRCUM("+num$(N_I-1)+")") +
&                                evalue(ABR1+"PERCLOCUM("+num$(N_I-1)+")") +
&                                evalue(ABR1+"PERCLOEXC("+num$(N_I-1)+")")
      [M:FVP1]DPRCUM2(N_S-1)   = evalue(ABR2+"DPRCUM("+num$(N_I-1)+")") +
&                                evalue(ABR2+"PERCLOCUM("+num$(N_I-1)+")") +
&                                evalue(ABR2+"PERCLOEXC("+num$(N_I-1)+")")
      [M:FVP1]ENDDPE1(N_S-1)   = evalue(ABR1+"PERENDDPE("+num$(N_I-1)+")")
      [M:FVP1]ENDDPE2(N_S-1)   = evalue(ABR2+"PERENDDPE("+num$(N_I-1)+")")
      [M:FVP1]EXCDPR1(N_S-1)   = evalue(ABR1+"PEREXCDPR("+num$(N_I-1)+")")
      [M:FVP1]EXCDPR2(N_S-1)   = evalue(ABR2+"PEREXCDPR("+num$(N_I-1)+")")
    Endif
  Endif
  If ( [M:DIV]SIMPLN2 ) Then
    [M:FVP1]DEVDPE(N_S-1)  = ([M:FVP1]ENDDPE1(N_S-1) + [M:FVP1]EXCDPR1(N_S-1))
&                          - ([M:FVP1]ENDDPE2(N_S-1) + [M:FVP1]EXCDPR2(N_S-1))
  Endif
Return
Subprog  CAL_DATE_FIN_CONCESSION (E06SOC, E06CON, S06DTFNCON )
Value    Char     E06SOC
Value    Char     E06CON
Variable Date    S06DTFNCON
Local Shortint CALL_E06
Goto $DEB_CAL_DATE_FIN_CONCESSION
$GSB_CAL_DATE_FIN_CONCESSION
  Local Char      E06SOC        : E06SOC      = [M:DIV]PC(0)
  Local Char      E06CON        : E06CON      = [M:DIV]PC(1)
  Local Date      S06DTFNCON
$DEB_CAL_DATE_FIN_CONCESSION
  If clalev([F:WCCN]) =0 : Local File CONCESSION    [WCCN]  : Endif      : # Concession
  Read [WCCN]CCN1= E06SOC;E06CON
  If (fstat)  Then
    [M:DIV]ERRID = 12 : Call ERRFND From   GLOBB0
    If (dim(CALL_E06)<0) Then :  Return : Else : End : Endif : # Dépilement suite à erreur logique
  Else
    S06DTFNCON = [F:WCCN]ENDCCNDAT
  Endif
If (dim(CALL_E06)<0) Then
 [M:DIV]RD(0) = S06DTFNCON
 Return
Endif
End
Subprog CCN_LEC_CCNRPR_FLD( PNBFMAX, RTDF, RNBF )
Value    Integer  PNBFMAX
Variable Char     RTDF()
Variable Decimal  RNBF
Local Integer N_F
Local Integer BCLOFIL : BCLOFIL = 0
  If clalev([F:AMZB])=0 : Local File AMSKZON [AMZB] : BCLOFIL = 1 : Endif
  N_F = 1
  For [AMZB]CODTYP Where CODMSK = "CCNRPR" and CODTYP <> "ABS"
    If ( N_F <= PNBFMAX ) Then
     RTDF(N_F-1) =[F:AMZB]CODZON
    Endif
     N_F += 1
  Next
  RNBF = N_F-1
  If (BCLOFIL) Then
    Close Local File [AMZB]
  Endif
End
Subprog CMP_CCNRPR_CCNRPR_EQ(RTRN)
Variable Integer RTRN
Local Integer I_F
Local Integer N_M
Local Integer N_F
  RTRN= 1
  If clalev([F:RPR])=0  : Local File CCNRPR     [RPR]  :  Endif             : # Infos diverses
  N_F = clanbs([F:RPR],1)
  If( [M:DIV]NBF-1 <> N_F ) Then
    RTRN = 0
  Else
    For I_F = 1 To N_F
      If ( find (clavar([F:RPR], I_F), [M:DIV]TDFN) = 0 ) Then
        RTRN = 0
        Break
      Endif
    Next I_F
  Endif
End
Subprog  CCN_LEC_CCNRPR (PBCO, PFINEXE )
Value Char    PBCO
Value Date    PFINEXE
Local Integer INDRPR
  Raz [M:RPR]
  INDRPR = 1
  Filter [WRPR] Where AASREF = PBCO and FIYENDDAT >= PFINEXE
  For [WRPR]RPR0
    nolign = INDRPR
    [M:RPR]=[F:WRPR]
    [M:RPR]FLGACT(nolign-1) = "N"
    INDRPR +=1
  Next
  [M:RPR]NB_RPR = INDRPR-1
  Filter [WRPR]
  Local Integer I_ECOUR, I_PCOUR
  I_ECOUR = find( GVML_TECOURA, [M:EGCF]STAFIY )  : # Exercice courant [M:FIY]
  I_PCOUR = [M:FIY]INDDEBPER (I_ECOUR-1) + [M:FIY]INDCURPER (I_ECOUR-1) - 1  : # Période courante
  If (I_ECOUR < 1 or I_PCOUR < 1) Then
    [M:DIV]TRFCADCUM = 0
    End
  Endif
  Read [WDEP]DEP0=PBCO;[M:DIV]CCNCADPLN;[M:EGCF]DATENDFIY(I_ECOUR-1);[M:EGCF]DATENDPER(I_PCOUR-1)
  If (fstat) Then : [M:DIV]TRFCADCUM = 0 : Else : [M:DIV]TRFCADCUM = [F:WDEP]TRFCADCUM :   Endif
End
Subprog CCN_EVALUE_ACTION_RPR( PTDFN, PNBF )
Value Char     PTDFN()
Value Decimal  PNBF
Local Integer N_D
Local Integer LRET
Local Integer N_F
Local Integer I_P
Local Integer LERROR
  LERROR = 0
  If ( [M:DIV]TRTDEM = "CALSIM" or [M:DIV]TRTDEM = "CALVNC") Then
    End
  Endif
  For N_D = 1 To [M:RPR]NB_RPR
    If ( N_D > [M:WRPR]NB_RPR ) Then
      [M:RPR]FLGACT(N_D-1) = "I"
    Else
      LRET = 0
      If ( N_D <= [M:RPR]NB_RPR and
&        ( ( [M:RPR]FIYSTRDAT(N_D-1) <> [M:WRPR]FIYSTRDAT(N_D-1) )  or
&          ( [M:RPR]FIYENDDAT(N_D-1) <> [M:WRPR]FIYENDDAT(N_D-1) )  or
&          ( [M:RPR]PERSTRDAT(N_D-1) <> [M:WRPR]PERSTRDAT(N_D-1) )  or
&          ( [M:RPR]PERENDDAT(N_D-1) <> [M:WRPR]PERENDDAT(N_D-1) )  )     ) Then
        LRET = -1
      Else
        I_P = find([M:RPR]PERSTRDAT(N_D-1),[M:FIY]DATSTRPER)
        If (I_P <> 0 and [M:FIY]STAPER (I_P-1) = GVML_SPCLOSE) Then
          LRET = 1
        Else
          If ([F:WFAS]FLGCNXCLC([M:DEP]CNX(N_D-1)-1) = GVML_RCCLO and [M:RPR]FIYENDDAT(N_D-1)=[M:FIY]DATENDFIY([M:DIV]FEC-1) )  Then
            LRET = 1
          Endif
        Endif
      Endif
      If ( LRET = 1 ) Then
        [M:RPR]FLGACT(N_D-1) = "N"
      Elsif ( LRET = 0 ) Then
        [M:RPR]FLGACT(N_D-1) = "U"
      Else
        [M:RPR]FLGACT(N_D-1) = "I"
        [M:WRPR]NB_RPR = N_D
        Delete [WRPR] Where   AASREF     = [F:WFAS]AASREF
&                       and   FIYENDDAT >= [M:WRPR]FIYENDDAT(N_D-1)
&                       and   PERENDDAT >= [M:WRPR]PERENDDAT(N_D-1)
        If fstat Then
          LERROR = -1
          Call FSTA("WRPR") From GLOCK
          Call ECR_TRACE(mess(154,7774,1)-num$(DPRPLN)-AASREF,1) From   GLOBB0  : # FQ64478
          Break
        Endif
      Endif
    Endif
  Next N_D
  If ( LERROR ) Then
    [M:DIV]ERRID = 14 : Call ERRFND From   GLOBB0 : End
  Endif
End
Subprog CALCUL_MAJ_PROVISION
Local    Integer LERROR
Local    Char    LACTION
LERROR = 0
  Raz [M:RPR]
  Transmask [M:PRPR] To [M:RPR]
  For N_D = 1 To [M:RPR]NB_RPR
    If    ( [M:RPR]FLGACT (N_D-1) = "I" ) Then : LACTION = "Insert"
    Elsif ( [M:RPR]FLGACT (N_D-1) = "U" ) Then : LACTION = "Update"
    Else                                         LACTION = "No upd"
    Endif
    If ( [M:RPR]ACGRPRDEV(N_D-1) <> 0  or [M:RPR]FISRPRDEV(N_D-1) <> 0) Then
      [M:RPR]FLGDEV(N_D-1)= G_OUI
    Else
      [M:RPR]FLGDEV(N_D-1)= G_NON
    Endif
    Case [M:RPR]FLGACT (N_D-1)
      When "U"
        If ([M:DIV]BCCNLECMAJ) Then
          Read [WRPR]
&           RPR0=[F:WFAS]AASREF;[M:RPR]FIYENDDAT(N_D-1);[M:RPR]PERENDDAT(N_D-1)
          If ( fstat ) Then
            LERROR = -1
            Call FSTA("WRPR") From GLOCK
            Call ECR_TRACE
&           ( "Read RPR"-[F:WFAS]AASREF-'fstat='-num$(fstat),1) From   GLOBB0
          Endif
        Endif
        nolign = N_D : [F:WRPR] = [M:RPR]
        [F:WRPR]ETRPNT = G_ETRPNT
        Rewrite [WRPR]
&         RPR0=[F:WFAS]AASREF;[M:RPR]FIYENDDAT(N_D-1);[M:RPR]PERENDDAT(N_D-1)
        If ( fstat ) Then
          LERROR = -1
          Call FSTA("WRPR") From GLOCK
          Call ECR_TRACE
&         ( "Rewrite RPR"-[F:WFAS]AASREF-'fstat='-num$(fstat),1) From   GLOBB0
        Endif
      When "I"
        nolign = N_D : [F:WRPR] = [M:RPR]
        [F:WRPR]ETRPNT = G_ETRPNT
        Write [WRPR]
        If ( fstat ) Then
          LERROR = -1
          Call FSTA("WRPR") From GLOCK
          Call ECR_TRACE
&              ("Write RPR"-[F:WFAS]AASREF-'fstat='-num$(fstat),1) From   GLOBB0
        Endif
    Endcase
    If (LERROR) Then :  Break : Endif
  Next N_D
  If ( LERROR ) Then
      [M:DIV]ERRID = 16 : Call ERRFND From   GLOBB0 : End
  Else
    If ( [M:RPR]NB_RPR <> 0 ) Then
      Delete [WRPR] Where AASREF=[F:WFAS]AASREF and
&     FIYENDDAT >= [M:RPR]FIYENDDAT([M:RPR]NB_RPR-1) and PERENDDAT > [M:RPR]PERENDDAT([M:RPR]NB_RPR-1)
      If ( fstat ) Then
        LERROR = -1
        Call FSTA("WRPR") From GLOCK
        Call ECR_TRACE(mess(154,7774,1)-[F:WFAS]AASREF,1) From   GLOBB0
      Endif
    Endif
  Endif
  If ( LERROR ) Then
    [M:DIV]ERRID = 14 : Call ERRFND From   GLOBB0 : End
  Endif
End
