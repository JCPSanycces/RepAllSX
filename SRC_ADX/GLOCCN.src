#------------------------------------------------------
# Fonction permettant de savoir s'il existe des contrats dont
# la date de fin est dans l'exercice sans date de fin effective
#    1 - Non
#    2 - Oui
#------------------------------------------------------
Funprog IS_CCNEND_NOT_DONE(PCPY)
Value   Char PCPY
  Local Integer PNBE
End func GLOCCN.IS_CCNEND_NOT_DONE_NBE(PCPY, PNBE)

#------------------------------------------------------
# Fonction permettant de savoir s'il existe des contrats dont
# la date de fin est dans l'exercice sans date de fin effective
# et combien
#    1    - Non
#    2    - Oui
#    RNBE - nombre d'opération en cours
#------------------------------------------------------

Funprog IS_CCNEND_NOT_DONE_NBE(PCPY, RNBE)
Value    Char    PCPY
Variable Integer RNBE

  Local Shortint RETOUR

  If !clalev([F:WCCN]) : Local File CONCESSION [WCCN] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR   [WFIS] : Endif

  Read [WFIS]FIY1=PCPY;G300CPFI;GVML_TESUIV

  Filter [WCCN] Where CPY = PCPY and evalue(func GLOCCN.GET_CCNEND_NOT_DONE_FILTER())
  RNBE = rowcount([WCCN])
  Filter [WCCN]

  If RNBE > 0
    RETOUR = G_OUI
  Else
    RETOUR = G_NON
  Endif
End RETOUR

Funprog GET_CCNEND_NOT_DONE_FILTER()
End "ENDCCNDAT < [F:WFIS]DATSTRFIY and REAENDCCN = [0/0/0]"

#------------------------------------------------------
# S/P permettant de supprimer les opérations de
# renouvellement validées d'une société passée en
# paramétre.
#
#   PCPY    Société
#   RNBDEL  Nombre d'enregistrements supprimés
#   RCOD    1 à 5
#
#------------------------------------------------------
Subprog DEL_RNWPREP(PCPY,RNBDEL,RCOD)
Value    Char    PCPY
Variable Integer RNBDEL
Variable Integer RCOD
 If !clalev([F:RWP]) : Local File RNWPREP   [RWP] : Endif
 For [F:RWP]RWP0(3) Where CPY=PCPY & RNWDONFLG=G_OUI
  RNBDEL+=1
 Next
 Delete [F:RWP] Where CPY=PCPY & RNWDONFLG=G_OUI
 If fstat
  RCOD=20+fstat
  End
 Endif
End


#------------------------------------------------------
# S/P permettant de locker les biens
#   soit rattachés à une concession
#   soit faisant référence à un code actualisation
# passé en paramètre et ce de manière exclusive.
#
#   PCCNREF   Contrat de cvoncession
#   PACTCOD   Coefficient d'actualisation
#   RERR
#          -1 paramètre inconsistant
#           0 Tous les biens ont été lockés
#           1 Au moins un bien n'a pas pu être locké
#
#------------------------------------------------------
Subprog CCN_LOCK_FAS ( PCCNREF, PACTCOD, RERR)
Value    Char    PCCNREF
Value    Char    PACTCOD
Variable Integer RERR


  If (PCCNREF <> "" and PACTCOD <> "" ) Then : RERR = -1 : End : Endif
  If (PCCNREF =  "" and PACTCOD =  "" ) Then : RERR = -1 : End : Endif

  If clalev([F:FAS2])=0  : Local File FXDASSETS     [FAS2]  :  Endif

  # Verrouillage
  Local Char LLOCK (200)

  If ( PCCNREF <> "" ) Then
    For [FAS2]FAS8 Where CCNREF=PCCNREF
      If  ( func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:FAS2]CPY, [F:FAS2]AASREF, 0) = 0 ) Then
        RERR = 1
        Break
      Endif
    Next
  Endif
  If (PACTCOD <> "" ) Then
    For [FAS2]FAS9 Where CCNACTCOD=PACTCOD
      If  ( func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:FAS2]CPY, [F:FAS2]AASREF, 0) = 0 ) Then
        RERR = 1
        Break
      Endif
    Next
  Endif

  # Si tout n'a pas pu être locké, il faut dévérouiller les biens ayant déjà été lockés
  If ( RERR ) Then
    Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
  Endif

End
