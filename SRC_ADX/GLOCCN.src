#------------------------------------------------------
Funprog IS_RNWOP_NOT_DONE_FOR_CCN( PCCNREF)
Value   Char PCCNREF
  Local Integer PNBE
End func GLOCCN.IS_RNWOP_NOT_DONE_FOR_CCN_NBE(PCCNREF, PNBE)

#------------------------------------------------------
# Fonction permettant de savoir s'il existe des opérations
# de renouvellement en cours pour la concession
#    1 - Non
