# GLE - 24.04.2012 - FQ81741 : Correction/optimisation IS_RPR_POSTED_ISS_FUTURE_NBE
###############################################################################
#
# Fonctions disponibles
# ---------------------
#  IS_RPR_CALCULATE         : permet de savoir si des biens de la société ont des provisions à calculer
#  IS_RPR_CALCULATE_NBE     : permet de savoir si des biens de la société ont des provisions à calculer et combien
#  IS_CPY_RPR_POSTED        : permet de savoir si un contexte donné n'a pas de "A comptabiliser" en attente sur ses CCNRPR
#  IS_CPY_RPR_POSTED_NBE    : permet de savoir si un contexte donné n'a pas de "A comptabiliser" en attente sur ses CCNRPR
#                             et indique combien de biens sont concernés
#  IS_RPR_POSTED_ISS_FUTURE : permet de savoir s'il a des provisions "A comptabiliser" en compta définitive sur l'exercice suivant
#                             pour les biens sortis dans l'exercice
#  IS_RPR_POSTED_ISS_FUTURE_NBE
#                           : permet de savoir s'il a des provisions "A comptabiliser" en compta définitive sur l'exercice suivant
#                             pour les biens sortis dans l'exercice et combien
#  IS_RPR_DEJA_COMPTABILISE : permet de savoir des provisions ont déjà été comptabilisées pour la période donnée d'une société passée en paramètre.
#  RNW_ENCOURS              : permettant de savoir si le bien passé en référence est utilisé dans la préparation d'un renouvellement
#  IS_BCO_NOT_RNW           : permet de savoir s'il existe des biens fils en service sans renouvellement effectif
#  IS_BCO_NOT_RNW_NBE       : permet de savoir s'il existe des biens fils en service sans renouvellement effectif et combien
#  IS_RNWOP_NOT_DONE        : permet de savoir s'il existe des opérations de renouvellement en préparation sans date ou dans l'exercice courant
#  IS_RNWOP_NOT_DONE_NBE    : permet de savoir s'il existe des opérations de renouvellement en préparation sans date ou dans l'exercice courant et combien
#  IS_RNWOP_FOR_CCN         : permet de savoir s'il existe au moins une opération de renouvellement en préparation pour une concession donnée.
#  IS_RNWOP_NOT_DONE_FOR_CCN_NBE : Permet de savoir s'il existe des opérations de renouvellement non validées pour une concession donnée et combien.
#  IS_RNWOP_NOT_DONE_FOR_CCN : Permet de savoir s'il existe des opérations de renouvellement non validées pour une concession donnée.
#  IS_RNWOP_FOR_CCN_NBE     : permet de savoir s'il existe au moins une opération de renouvellement en préparation pour une concession donnée et combien.
#  IS_CCNFAS_NOT_RNW        : permet de savoir si dans une concession, il existe des biens fils en service sans renouvellement effectif.
#  IS_CCNFAS_NOT_RNW_NBE    : permet de savoir si dans une concession, il existe des biens fils en service sans renouvellement effectif et combien.
#  IS_CCNFAS_TO_RNW         : permet de savoir si dans une concession, il existe des biens restant à renouveler.
#  IS_CCNFAS_TO_RNW_NBE     : permet de savoir si dans une concession, il existe des biens restant à renouveler et combien.
#  IS_CCNEND_NOT_DONE       : permet de savoir s'il existe des contrats dont la date de fin est dans l'exercice sans date de fin effective
#  IS_CCNEND_NOT_DONE_NBE   : permet de savoir s'il existe des contrats dont la date de fin est dans l'exercice sans date de fin effective et combien
#  DEL_RNWPREP              : permet de supprimer les opérations de renouvellement validées à la clôture périodique ou exercice
#
###############################################################################
End


#------------------------------------------------------
# Permet de savoir si tous les biens d'une société n'ont pas de
# provisions à calculer
#
# Renvoie G_OUI si rien n'est à calculer, G_NON sinon
#------------------------------------------------------
Funprog IS_RPR_CALCULATE(PCPY)
Value Char          PCPY

  Local Integer RNBE

End func GLOCCN.IS_RPR_CALCULATE_NBE(PCPY, RNBE)

#------------------------------------------------------
# Permet de savoir si tous les biens d'une société n'ont pas de
# provisions à calculer
#
# Renvoie G_OUI si rien n'est à calculer, G_NON sinon
#------------------------------------------------------
Funprog IS_RPR_CALCULATE_NBE(PCPY, RNBE)
Value Char          PCPY
Variable Integer    RNBE

  Local Integer RRET    : RRET = G_OUI

  If !clalev([F:WCNX]) : Local File CONTEXT   [WCNX] : Endif
  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif

  # Le contexte a-t'il subit des modifications remettant en cause le calcul ?
  Read [WCNX]CNX0=PCPY;G300CPFI
  If [F:WCNX]UPDWAINBR>0 Then
    RRET=G_NON
    End RRET
  Endif

  # Y-a-t'il des biens en concession avec renouvellement dont les provisions sont à calculer ?
  If [F:WCNX]CCNMOD = GVML_GCRNW
    Filter [WFAS] Where CPY=PCPY and evalue(func GLOCCN.GET_RPR_CALCULATE_FILTER())
    RNBE = rowcount([F:WFAS])
    Filter [WFAS]

    If RNBE > 0
      RRET=G_NON
    Endif
  Endif
End RRET

#------------------------------------------------------
# Filtre des provisions à calculer pour les biens
#------------------------------------------------------
Funprog GET_RPR_CALCULATE_FILTER()
End "FLGRPRCLC=G_OUI and OWNTYP = GVML_TDCONCE"

#------------------------------------------------------
# Permet de savoir si un contexte donné n'a pas de "A comptabiliser"
# en attente sur ses CCNRPR
#
# Renvoie G_OUI si le contexte est comptabilisé, G_NON sinon
#------------------------------------------------------
Funprog IS_CPY_RPR_POSTED(PCPY, PDATENDFIY, PDATENDPER)
Value    Char       PCPY
Value    Date       PDATENDFIY
Value    Date       PDATENDPER

  Local Integer RNBE

End func GLOCCN.IS_CPY_RPR_POSTED_NBE(PCPY, PDATENDFIY, PDATENDPER, "", RNBE)

#------------------------------------------------------
# Permet de savoir si un contexte donné n'a pas de "A comptabiliser"
# en attente sur ses CCNRPR
#
# Renvoie G_OUI si le contexte est comptabilisé, G_NON sinon
#         RNBE contient le nombre d'enregistrements ayant du "A comptabiliser"
#------------------------------------------------------
Funprog IS_CPY_RPR_POSTED_NBE(PCPY, PDATENDFIY, PDATENDPER, PPNAME, RNBE)
Value    Char       PCPY
Value    Date       PDATENDFIY
Value    Date       PDATENDPER
Value    Char       PPNAME
Variable Integer    RNBE

  Local Char    CRITERE(255)
  Local Integer RRET    : RRET = G_OUI

  RNBE = 0

  If !clalev([F:WCNX]) : Local File CONTEXT  [WCNX] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR [WFIS] : Endif
  If !clalev([F:WRPR]) : Local File CCNRPR   [WRPR] : Endif

  Read [WCNX]CNX0=PCPY;G300CPFI
  If [F:WCNX]CCNFLG <> G_OUI : End RRET : Endif

  Read [WFIS]FIY2=PCPY;G300CPFI;PDATENDFIY

  If func SUBTPE.RPR_COMPTABILISE(PCPY, G_OUI) = G_OUI Then
    If [F:WFIS]TYPPST([F:WFIS]INDCURPER-1) = GVML_TPSTDEF or [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) = [F:WFIS]DATENDFIY Then
      If [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) = [F:WFIS]DATENDFIY Then
        # Sur la dernière période de l'exercice, on contrôle que toutes les dotations de l'exercice sont comptabilisées
        CRITERE="FLGDEV=G_OUI&CPY=PCPY&FIYENDDAT=[F:WFIS]DATENDFIY"
      Else
        # Sur une période lambda, seules la comptabilisation des dotations de la période est contrôlée.
        CRITERE="FLGDEV=G_OUI&CPY=PCPY&FIYENDDAT=[F:WFIS]DATENDFIY&PERENDDAT=[F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)"
      Endif

      Filter [WRPR] Where evalue(CRITERE)
      RNBE = rowcount([F:WRPR])

      If RNBE > 0
        RRET = G_NON
      Endif

      If PPNAME <> ""
        Gosub IS_CPY_RPR_POSTED_NBE From =PPNAME
      Endif

      Filter [WRPR]
    Endif
  Endif

End RRET

#------------------------------------------------------
# Vérification qu'il n'existe pas, pour les biens sortis dans l'exercice,
# du "A comptabiliser" sur des périodes futures en comptabilisation définitives
#
# Renvoie G_OUI si le contexte est comptabilisé pour ces biens, G_NON sinon
#------------------------------------------------------
Funprog IS_RPR_POSTED_ISS_FUTURE(PCPY)
Value Char    PCPY
  Local Integer NBE
End func GLOCCN.IS_RPR_POSTED_ISS_FUTURE_NBE(PCPY, NBE)
#------------------------------------------------------
# Vérification qu'il n'existe pas, pour les biens sortis dans l'exercice,
# du "A comptabiliser" sur des périodes futures en comptabilisation définitives
#
# Renvoie G_OUI si le contexte est comptabilisé pour ces biens, G_NON sinon
#------------------------------------------------------
Funprog IS_RPR_POSTED_ISS_FUTURE_NBE(PCPY, RNBE)
Value Char       PCPY
Variable Integer RNBE

  Local Integer RRET    : RRET = G_OUI
  Local Integer N_PLN

  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif
  If !clalev([F:WRPR]) : Local File CCNRPR    [WRPR] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR  [WFIS] : Endif
  If !clalev([F:WFI2]) : Local File FISCYEAR  [WFI2] : Endif

  Read [WFIS]FIY1=PCPY;G300CPFI;GVML_TECOURA
  Read [WFI2]FIY1=PCPY;G300CPFI;GVML_TESUIV

  RNBE = 0

  If find(GVML_TPSTDEF,[F:WFI2]TYPPST(0..[F:WFI2]NBRPER-1)) Then
      # Il y a de la comptabilisation définitive sur l'exercice suivant
      #For [WFAS] Where CPY=PCPY and ISSDAT>=[F:WFIS]DATSTRFIY and ISSDAT<=[F:WFIS]DATENDFIY and EXTISSFLG=G_NON
      #  Filter [F:WRPR] Where FLGDEV=G_OUI and CPY=PCPY and FIYSTRDAT=[F:WFI2]DATENDFIY+1
      #  RNBE += rowcount([F:WRPR])
      #  Filter  [F:WRPR]
      #Next
      # FQ81741
      Link [WRPR] With [WFAS]FAS0=[WRPR]AASREF As [LRPR]
&     Where [WFAS]CPY=PCPY and [WFAS]ISSDAT>=[F:WFIS]DATSTRFIY and [WFAS]ISSDAT<=[F:WFIS]DATENDFIY and [WFAS]EXTISSFLG=G_NON
&       and [WRPR]FLGDEV=G_OUI and [WRPR]FIYSTRDAT=[F:WFI2]DATSTRFIY
      RNBE = rowcount([F:LRPR])
  Endif

  If RNBE > 0
    RRET = G_NON
  Endif
End RRET

#------------------------------------------------------
# Permet de savoir si il y a déjà eu des provisions
# comptabilisées pour une période donnée du contexte
# comptable et fiscal de la société passée en paramétre
# Cette fonction est utilisée dans SUBCNX pour savoir si on peut ou non passer
# le type de comptabilisation de "Définitif" à "Provisoire"
#------------------------------------------------------
Funprog IS_RPR_DEJA_COMPTABILISE(PCPY, PDATSTR, PDATEND)
Value Char    PCPY
Value Date    PDATSTR
Value Date    PDATEND

Local Integer RRET    : RRET    = G_NON
Local Decimal WTOTPST : WTOTPST = 0

If !clalev([F:RPR]) : Local File CCNRPR [RPR] : Endif
Columns [RPR] (PSTACGRPR, PSTFISRPR)
For [F:RPR] Where CPY=PCPY & PERSTRDAT = PDATSTR & PERENDDAT = PDATEND
 WTOTPST =  [F:RPR]PSTACGRPR +  [F:RPR]PSTFISRPR
 If WTOTPST > 0
    RRET = G_OUI
    Break
 Endif
Next
Columns [RPR]

End RRET

#------------------------------------------------------
# Fonction permettant de savoir si le bien passé
# en référence est utilisé dans la préparation
# d'un renouvellement. Valeurs de retour
#    1 - Non
#    2 - Oui en tant que bien fils
#    3 - Oui en tant que bien père
#------------------------------------------------------
Funprog RNW_ENCOURS(PCPY,PFCY,PAASREF)
Value Char PCPY
Value Char PFCY
Value Char PAASREF

  Local Integer RETOUR

  If !clalev([F:RWP]) : Local File RNWPREP [RWP] : Endif

  #> Recherche du bien en tant que bien fils

  Read [RWP]RWP0(3)=PCPY;PFCY;PAASREF
  If !fstat
   RETOUR=2
   End RETOUR
  Endif

  #> Pas trouvé en tant que bien fils, recherche en tant que bien père.

  Read [RWP]RWP1(2)=PCPY;PAASREF
  If !fstat
   RETOUR=3
  Else
   RETOUR=1
  Endif

End RETOUR

#------------------------------------------------------
# Fonction permettant de savoir si le bien passé
# en référence est utilisé dans la préparation
# d'un renouvellement. Valeurs de retour
#    1 - Non
#    2 - Oui en tant que bien fils
#    3 - Oui en tant que bien père
#------------------------------------------------------
Funprog RNW_ENCOURS_NOT_DONE(PCPY,PFCY,PAASREF)
Value Char PCPY
Value Char PFCY
Value Char PAASREF

  Local Integer RETOUR

  If !clalev([F:RWP]) : Local File RNWPREP [RWP] : Endif

  #> Recherche du bien en tant que bien fils

  Read [RWP]RWP0(3)=PCPY;PFCY;PAASREF
  If !fstat
   If [F:RWP]RNWDONFLG<>G_OUI
    RETOUR=2
   Else
    RETOUR=1
   Endif
   End RETOUR
  Endif

  #> Pas trouvé en tant que bien fils, recherche en tant que bien père.

  Read [RWP]RWP1(2)=PCPY;PAASREF
  If !fstat
   If [F:RWP]RNWDONFLG<>G_OUI
    RETOUR=3
   Else
    RETOUR=1
   Endif
  Else
   RETOUR=1
  Endif

End RETOUR

#------------------------------------------------------
# Fonction permettant de savoir s'il existe des biens
# fils en service sans renouvellement effectif
#    1 - Non
#    2 - Oui
#------------------------------------------------------
Funprog IS_BCO_NOT_RNW(PCPY)
Value   Char PCPY
  Local Integer PNBE
End func GLOCCN.IS_BCO_NOT_RNW_NBE(PCPY, PNBE)

#------------------------------------------------------
# Fonction permettant de savoir s'il existe des biens
# fils en service sans renouvellement effectif et combien
#    1    - Non
#    2    - Oui
#    RNBE - nombre de biens
#------------------------------------------------------
Funprog IS_BCO_NOT_RNW_NBE(PCPY, RNBE)
Value   Char PCPY
Variable Integer RNBE

  Local Shortint RETOUR

  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif

  Filter [WFAS] Where CPY = PCPY and evalue(func GLOCCN.GET_BCO_NOT_RNW_FILTER())
  RNBE = rowcount([WFAS])
  Filter [WFAS]

  If RNBE > 0
    RETOUR = G_OUI
  Else
    RETOUR = G_NON
  Endif
End RETOUR

Funprog GET_BCO_NOT_RNW_FILTER()
End "OWNTYP = GVML_TDCONCE and CCNETRTYP = GVML_NARENEW and GACACN = GVML_NIENSER and RNWDONFLG <> G_OUI"

#------------------------------------------------------
# Fonction permettant de savoir s'il existe des opérations
# de renouvellement sans date ou dans l'exercice en préparation
#    1 - Non
#    2 - Oui
#------------------------------------------------------
Funprog IS_RNWOP_NOT_DONE(PCPY)
Value   Char PCPY
  Local Integer PNBE
End func GLOCCN.IS_RNWOP_NOT_DONE_NBE(PCPY, PNBE)

#------------------------------------------------------
# Fonction permettant de savoir s'il existe des opérations
# de renouvellement sans date ou dans l'exercice en préparation
# et combien
#    1    - Non
#    2    - Oui
#    RNBE - nombre d'opération en cours
#------------------------------------------------------

Funprog IS_RNWOP_NOT_DONE_NBE(PCPY, RNBE)
Value   Char PCPY
Variable Integer RNBE

  Local Shortint RETOUR

  If !clalev([F:WRWP]) : Local File RNWPREP [WRWP]   : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR  [WFIS] : Endif

  Read [WFIS]FIY1=PCPY;G300CPFI;GVML_TESUIV

  Filter [WRWP] Where CPY = PCPY and evalue(func GLOCCN.GET_RNWOP_NOT_DONE_FILTER())
  RNBE = rowcount([WRWP])
  Filter [WRWP]

  If RNBE > 0
    RETOUR = G_OUI
  Else
    RETOUR = G_NON
  Endif
End RETOUR

Funprog GET_RNWOP_NOT_DONE_FILTER()
End "( RNWDAT = [0/0/0] or RNWDAT < [F:WFIS]DATSTRFIY ) and RNWDONFLG <> G_OUI"

#------------------------------------------------------
# Fonction permettant de savoir s'il existe des opérations
# de renouvellement en cours pour la concession et combien
#    1    - Non
#    2    - Oui
#    RNBE - nombre d'opération en cours
#------------------------------------------------------

Funprog IS_RNWOP_FOR_CCN_NBE(PCCNREF, RNBE)
Value   Char PCCNREF
Variable Integer RNBE

  Local Shortint RETOUR

  If !clalev([F:WRWP]) : Local File RNWPREP [WRWP]   : Endif

  Filter [WRWP] Where CCNREF = PCCNREF
  RNBE = rowcount([WRWP])
  Filter [WRWP]

  If RNBE > 0
    RETOUR = G_OUI
  Else
    RETOUR = G_NON
  Endif
End RETOUR

#------------------------------------------------------
# Fonction permettant de savoir s'il existe des opérations
# de renouvellement non validées pour la concession
#    1    - Non
#    2    - Oui
#    RNBE - Nombre d'opérations non validées
#------------------------------------------------------

Funprog IS_RNWOP_NOT_DONE_FOR_CCN_NBE( PCCNREF, RNBE)
Value   Char PCCNREF
Variable Integer RNBE

  Local Integer RETOUR

  If !clalev([F:WRWP]) : Local File RNWPREP [WRWP]   : Endif

  Filter [WRWP] Where CCNREF = PCCNREF & RNWDONFLG<>G_OUI
  For [F:WRWP]RWP0(3)
   RNBE += 1
  Next
  Filter [WRWP]

  If RNBE > 0
    RETOUR = G_OUI
  Else
    RETOUR = G_NON
  Endif

End RETOUR

