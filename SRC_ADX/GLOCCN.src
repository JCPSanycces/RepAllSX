End func GLOCCN.IS_RNWOP_FOR_CCN_NBE(PCCNREF, PNBE)

#------------------------------------------------------
# Fonction permettant de savoir si dans une concession, il existe
# des biens fils en service sans renouvellement effectif et combien
#    1    - Non
#    2    - Oui
#    RNBE - nombre de biens
#------------------------------------------------------
Funprog IS_CCNFAS_NOT_RNW_NBE (PCCNREF, RNBE)
Value   Char PCCNREF
Variable Integer RNBE

  Local Shortint RETOUR

  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif

  Filter [WFAS] Where CCNREF = PCCNREF and GACACN = GVML_NIENSER and CCNETRTYP = GVML_NARENEW and RNWDONFLG <> G_OUI
  RNBE = rowcount([WFAS])
  Filter [WFAS]

  If RNBE > 0
    RETOUR = G_OUI
  Else
    RETOUR = G_NON
  Endif
End RETOUR

