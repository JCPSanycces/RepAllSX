###############################################################################
# TRTACHBI      Fonctions pour la Business Intelligence       Module Achats   #
# --------------------------------------------------------------------------- #
# GETPURDCA   : Détermination du mt total HT ligne des remises, frais ou brut #
# GETPFIDCA   : Détermination du mt total HT éléments fact. remises ou frais  #
# GETPIHFCY   : Détermination site achat ou stockage d'une ligne de facture   #
# GETPFIFCY   : Détermination site achat ou stockage des éléments facturation #
# GETPOHCPR   : Détermination du prix de revient prévisionnel d'une ligne cde #
# ROUNDAMOUNT : Arrondi d'un montant selon le paramètrage de la devise        #--CPO 83711
# CALC_AMTDED_PSH : Rends la somme des taxes déductibles,  										#--CPO 83711
# 									éventuellement proratisé par la qté passée en paramètres	#
# 									(par rapport à la quantité en US de la ligne de DA)  			#
# --------------------------------------------------------------------------- #
# Nota : Les globales ne sont pas forcément significatives                    #
#        Dans la déclaration des variables, les GLONxxx ont été remplacés     #
#        par des valeurs "en dures"                                           #
#        La globale GDOSSIER est significative, elle contient le nom du       #
#        dossier en cours de traitement et sert pour l'ouverture des tables   #
###############################################################################


#####################################################################
# GETPURDCA Détermination du mt total HT ligne des remises ou frais #
# Get purchase discount or charge amount                            #
#####################################################################
Funprog GETPURDCA(TYPDOC,NUMDOC,LINDOC,SEQDOC,DEVDES,TYPAMT)
Value    Integer  TYPDOC  : # Type document (1=Cde, 2=Réception, 3=Retour, 4=Facture, 5=DA)
Value    Char     NUMDOC  : # Numéro du document
Value    Integer  LINDOC  : # Numéro de la ligne du document
Value    Integer  SEQDOC  : # Numéro de séquence de la ligne du document (Si Cde)
Value    Char     DEVDES  : # Devise destination
Value    Integer  TYPAMT  : # Type de montant (1=Total frais, 2=Total remises, 3=Mt brut)
#-----
Local    Decimal  WAMTNOT       : # Mt total HT remises ou frais
Local    Decimal  WNETLIN       : # Mt HT net ligne
Local    Char     WBPSNUM(30)   : # Numéro du fournisseur (GLONBPS non significatif)
Local    Char     WCUR(20)      : # Devise origine (celle de la ligne du document)
Local    Char     WDEVSOC(20)   : # Devise de la société
Local    Integer  WCHGTYP       : # Type de cours (si cours = 0)
Local    Date     WCHGDAT       : # Date de cours (si cours = 0)
Local    Decimal  WCOURS        : # Cours
Local    Decimal  WQTY          : # Quantité de la ligne du document
Local    Decimal  WGROPRI       : # Prix unitaire brut
Local    Decimal  WDISCRGVAL(9) : # Frais/remises
Local    Decimal  WNETPRI       : # Prix unitaire net
Local    Decimal  WPUNET
Local    Decimal  WMT
Local    Integer  WSIGN
Local    Integer  WSTAT
Local    Integer  WI
#-----
If TYPDOC<1 | TYPDOC>5  TYPDOC=1 : Endif
If TYPAMT<1 | TYPAMT>3  TYPAMT=1 : Endif
#----- Signe +1 pour frais et -1 pour remise -----#
If TYPAMT=2  WSIGN=-1  Else  WSIGN=+1 : Endif
#-----
Case TYPDOC
  When 1 : #----- Commande
    If !clalev([F:POH])  Local File =GDOSSIER+".PORDER"   [POH] : Endif
    If !clalev([F:POQ])  Local File =GDOSSIER+".PORDERQ"  [POQ] : Endif
    If !clalev([F:POP])  Local File =GDOSSIER+".PORDERP"  [POP] : Endif
    #----- Lecture entête de commande si nécesaire -----#
    If [F:POH]POHNUM<>NUMDOC
      Read [POH] POH0=NUMDOC : If fstat  Raz [F:POH] : Endif
    Endif
    If [F:POH]POHTYP=1  SEQDOC=1 : Endif
    #----- Lecture ligne commande qté si nécessaire -----#
    If [F:POQ]POHNUM<>NUMDOC |
&      [F:POQ]POPLIN<>LINDOC |
&      [F:POQ]POQSEQ<>SEQDOC
      Read [POQ] POQ0=NUMDOC;LINDOC;SEQDOC : If fstat  Raz [F:POQ] : Endif
    Endif
    #----- Lecture ligne commande prix si nécessaire -----#
    If [F:POH]POHTYP<>2
      Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
      If fstat Raz  [F:POP] : Endif
    Else
      Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT
      Read [POP] POP1 First
      Filter [POP]
      If fstat  Raz [F:POP] : Endif
    Endif
    #-----
    WBPSNUM=[F:POH]BPSNUM
    WCUR   =[F:POH]CUR
    WDEVSOC=func TRTX3BI.GETCUR([F:POH]POHFCY)
    WCHGTYP=[F:POH]CHGTYP
    WCHGDAT=[F:POH]ORDDAT
    WCOURS =0
    WQTY   =[F:POQ]QTYUOM
    WGROPRI=[F:POP]GROPRI
    For WI=0 To 8 : WDISCRGVAL(WI)=evalue("[F:POP]DISCRGVAL"+num$(WI+1)) : Next WI
    WNETPRI=[F:POP]NETPRI
    WNETLIN=[F:POQ]LINAMT
    #-----
  When 2 : #----- Réception
    If !clalev([F:PTH])  Local File =GDOSSIER+".PRECEIPT"  [PTH] : Endif
    If !clalev([F:PTD])  Local File =GDOSSIER+".PRECEIPTD" [PTD] : Endif
    #----- Lecture entête de réception si nécesaire -----#
    If [F:PTH]PTHNUM<>NUMDOC
      Read [PTH] PTH0=NUMDOC : If fstat  Raz [F:PTH] : Endif
    Endif
    #----- Lecture ligne de réception si nécessaire -----#
    If [F:PTD]PTHNUM<>NUMDOC | [F:PTD]PTDLIN<>LINDOC
      Read [PTD] PTD0=NUMDOC;LINDOC : If fstat  Raz [F:PTD] : Endif
    Endif
    #-----
    WBPSNUM=[F:PTH]BPSNUM
    WCUR   =[F:PTD]NETCUR
    WDEVSOC=func TRTX3BI.GETCUR([F:PTH]PRHFCY)
    WCHGTYP=[F:PTH]CHGTYP
    WCHGDAT=[F:PTH]RCPDAT
    WCOURS =0
    WQTY   =[F:PTD]QTYUOM
    WGROPRI=[F:PTD]GROPRI
    For WI=0 To 8 : WDISCRGVAL(WI)=evalue("[F:PTD]DISCRGVAL"+num$(WI+1)) : Next WI
    WNETPRI=[F:PTD]NETPRI
    WNETLIN=[F:PTD]LINAMT
    #-----
  When 3 : #----- Retour
    If !clalev([F:PNH])  Local File =GDOSSIER+".PRETURN"    [PNH] : Endif
    If !clalev([F:PND])  Local File =GDOSSIER+".PRETURND"   [PND] : Endif
    If !clalev([F:BPS])  Local File =GDOSSIER+".BPSUPPLIER" [BPS] : Endif
    #----- Lecture entête de retour si nécesaire -----#
    If [F:PNH]PNHNUM<>NUMDOC
      Read [PNH] PNH0=NUMDOC : If fstat  Raz [F:PNH] : Endif
    Endif
    #----- Lecture ligne de retour si nécessaire -----#
    If [F:PND]PTHNUM<>NUMDOC | [F:PND]PNDLIN<>LINDOC
      Read [PND] PND0=NUMDOC;LINDOC : If fstat  Raz [F:PND] : Endif
    Endif
    #----- Lecture fournisseur si nécessaire -----#
    If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
      Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : Endif
    Endif
    #-----
    WBPSNUM=[F:PNH]BPSNUM
    WCUR   =[F:PND]NETCUR
    WDEVSOC=func TRTX3BI.GETCUR([F:PNH]PNHFCY)
    WCHGTYP=[F:BPS]CHGTYP
    WCHGDAT=[F:PNH]RTNDAT
    WCOURS =0
    WQTY   =[F:PND]QTYUOM
    WGROPRI=[F:PND]GROPRI
    For WI=0 To 8 : WDISCRGVAL(WI)=evalue("[F:PND]DISCRGVAL"+num$(WI+1)) : Next WI
    WNETPRI=[F:PND]NETPRI
    WNETLIN=[F:PND]LINAMT
    #-----
  When 4 : #----- Facture
    If !clalev([F:PIH])  Local File =GDOSSIER+".PINVOICE"  [PIH] : Endif
    If !clalev([F:PID])  Local File =GDOSSIER+".PINVOICED" [PID] : Endif
    #----- Lecture entête de facture si nécesaire -----#
    If [F:PIH]NUM<>NUMDOC
      Read [PIH] PIH0=NUMDOC : If fstat  Raz [F:PIH] : Endif
    Endif
    #----- Lecture ligne de facture si nécessaire -----#
    If [F:PID]NUM<>NUMDOC | [F:PID]PIDLIN<>LINDOC
      Read [PID] PID0=NUMDOC;LINDOC : If fstat  Raz [F:PID] : Endif
    Endif
    # -----
    WBPSNUM=[F:PIH]BPR
    WCUR   =[F:PIH]CUR
    WDEVSOC=func TRTX3BI.GETCUR([F:PIH]FCY)
    WCHGTYP=[F:PIH]CURTYP
    WCHGDAT=[F:PIH]RATDAT
    WCOURS=func TRTX3BI.GETRATCUR("PIH")
    WQTY   =[F:PID]QTYUOM
    WGROPRI=[F:PID]GROPRI
    For WI=0 To 8 : WDISCRGVAL(WI)=evalue("[F:PID]DISCRGVAL"+num$(WI+1)) : Next WI
    WNETPRI=[F:PID]NETPRI
    WNETLIN=[F:PID]AMTNOTLIN
    #-----
  When 5 : #----- Demandes d'achat
    If !clalev([F:PSH])  Local File =GDOSSIER+".PREQUIS"  [PSH] : Endif
    If !clalev([F:PSD])  Local File =GDOSSIER+".PREQUISD" [PSD] : Endif
    #----- Lecture entête de deamnde d'achat si nécesaire -----#
    If [F:PSH]PSHNUM<>NUMDOC
      Read [PSH] PSH0=NUMDOC : If fstat  Raz [F:PSH] : Endif
    Endif
    #----- Lecture ligne de demande d'achat si nécessaire -----#
    If [F:PSD]PSHNUM<>NUMDOC | [F:PSD]PSDLIN<>LINDOC
      Read [PSD] PSD0=NUMDOC;LINDOC : If fstat  Raz [F:PSD] : Endif
    Endif
    #-----
    WBPSNUM=[F:PSD]BPSNUM
    WCUR   =[F:PSD]CUR
    WDEVSOC=func TRTX3BI.GETCUR([F:PSH]PSHFCY)
    WCHGTYP=[F:PSD]CHGTYP
    WCHGDAT=[F:PSH]PRQDAT
    WCOURS =0
    WQTY   =[F:PSD]QTYPUU
    WGROPRI=[F:PSD]GROPRI
    For WI=0 To 8 : WDISCRGVAL(WI)=evalue("[F:PSD]DISCRGVAL"+num$(WI+1)) : Next WI
    WNETPRI=[F:PSD]NETPRI
    WNETLIN=[F:PSD]LINAMT
    #-----
Endcase
#-----
If !clalev([F:BPS])  Local File =GDOSSIER+".BPSUPPLIER" [BPS] : Endif
If !clalev([F:PRS])  Local File =GDOSSIER+".PRICSTRUCT" [PRS] : Endif
#----- Lecture fournisseur si nécessaire -----#
If [F:BPS]BPSNUM<>WBPSNUM
  Read [BPS] BPS0=WBPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#----- Lecture de la structure tarif si nécessaire -----#
If [F:PRS]BPCBPS<>2 | [F:PRS]PLISTC<>[F:BPS]PLISTC
  Read [PRS] PRS0=2;[F:BPS]PLISTC : If fstat  Raz [F:PRS] : Endif
Endif
#----- Calcul du montant HT en fonction du type -----#
Case TYPAMT
  When 1,2 : #----- Calcul du total frais ou remises HT -----#
    Raz WAMTNOT
    WPUNET=WGROPRI
    If WQTY=0  WQTY=1 : Endif
    For WI=0 To 8
      If [F:PRS]NPRNOTFLG(WI)=2 & [F:PRS]INCDCR=TYPAMT
        Case [F:PRS]VALTYP(WI)
          When 1 : #----- C'est un montant -----#
            If [F:PRS]CLCRUL(WI)=1
              #----- C'est un montant par unité -----#
              WAMTNOT+=WDISCRGVAL(WI)*WQTY
              WPUNET +=WDISCRGVAL(WI)*WSIGN
            Else
              #----- C'est un montant par ligne ou document -----#
              WAMTNOT+=WDISCRGVAL(WI)
              WPUNET +=WDISCRGVAL(WI)/WQTY*WSIGN
            Endif
          When 2 : #----- C'est un % en cumul -----#
            WAMTNOT+=WGROPRI*WDISCRGVAL(WI)/100*WQTY
            WPUNET +=WGROPRI*WDISCRGVAL(WI)/100*WSIGN
          When 3 : #----- C'est un % en cascade -----#
            WAMTNOT+=WPUNET*WDISCRGVAL(WI)/100*WQTY
            WPUNET +=WPUNET*WDISCRGVAL(WI)/100*WSIGN
        Endcase
     Endif
    Next WI
  When 3 :   #----- Calcul du montant brut ligne HT -----#
    WAMTNOT=WNETLIN
    WAMTNOT-=func GETPURDCA(TYPDOC,NUMDOC,LINDOC,SEQDOC,DEVDES,1)
    WAMTNOT+=func GETPURDCA(TYPDOC,NUMDOC,LINDOC,SEQDOC,DEVDES,2)
Endcase
#----- Conversion et arrondi du montant dans la devise destination -----#
If !clalev([F:TCU])  Local File =GDOSSIER+".TABCUR" [TCU] : Endif
If [F:TCU]CUR<>WCUR
  Read [TCU] TCU0=WCUR : If fstat  Raz [F:TCU] : Endif
Endif
#-----
If DEVDES=WCUR
  WAMTNOT=arr(WAMTNOT,[F:TCU]CURRND)
Else
  Gosub PREP_CONVERSION From TRTX3BI
  Call COURMNT(WCUR,DEVDES,WDEVSOC,WCHGTYP,WCHGDAT,1,WAMTNOT,WMT,WCOURS,WSTAT) From TRTDEV
  If !WSTAT  WAMTNOT=WMT : Endif
Endif
#-----
End WAMTNOT


#########################################################################
# GETPFIDCA Détermination du mt total HT éléments fact remises ou frais #
# Get purchase discount or charge amount                                #
#########################################################################
Funprog GETPFIDCA(TYPDOC,NUMDOC,LINDOC,SEQDOC,DEVDES,TYPAMT)
Value    Integer  TYPDOC  : # Type document (1=Cde, 2=Réception, 3=Retour, 4=Facture)
Value    Char     NUMDOC  : # Numéro du document
Value    Integer  LINDOC  : # Numéro de la ligne du document
Value    Integer  SEQDOC  : # Numéro de séquence de la ligne du document (Si Cde)
Value    Char     DEVDES  : # Devise destination
Value    Integer  TYPAMT  : # Type de montant (1=Total frais, 2=Total remises)
#-----
Local    Decimal  WAMTNOT       : # Mt total HT éléments remises ou frais
Local    Char     WBPSNUM(30)   : # Numéro du fournisseur (GLONBPS non significatif)
Local    Char     WCUR(20)      : # Devise origine (celle de la ligne du document)
Local    Char     WDEVSOC(20)   : # Devise de la société
Local    Integer  WCHGTYP       : # Type de cours (si cours = 0)
Local    Date     WCHGDAT       : # Date de cours (si cours = 0)
Local    Decimal  WCOURS        : # Cours
Local    Shortint WINVDTALIN(9) : # Codes éléments facturation répartis sur ligne
Local    Decimal  WDISCRGAMT(9) : # Frais/remises
Local    Decimal  WMT
Local    Integer  WSIGN
Local    Integer  WSTAT
Local    Integer  WI
#-----
If TYPDOC<1 | TYPDOC>4  TYPDOC=1 : Endif
If TYPAMT<1 | TYPAMT>2  TYPAMT=1 : Endif
#----- Signe +1 pour frais et -1 pour remise -----#
If TYPAMT=2  WSIGN=-1  Else  WSIGN=+1 : Endif
#-----
Case TYPDOC
  When 1 : #----- Commande
    If !clalev([F:POH])  Local File =GDOSSIER+".PORDER"   [POH] : Endif
    If !clalev([F:POQ])  Local File =GDOSSIER+".PORDERQ"  [POQ] : Endif
    #----- Lecture entête de commande si nécesaire -----#
    If [F:POH]POHNUM<>NUMDOC
      Read [POH] POH0=NUMDOC : If fstat  Raz [F:POH] : Endif
    Endif
    If [F:POH]POHTYP=1  SEQDOC=1 : Endif
    #----- Lecture ligne commande qté si nécessaire -----#
    If [F:POQ]POHNUM<>NUMDOC |
&      [F:POQ]POPLIN<>LINDOC |
&      [F:POQ]POQSEQ<>SEQDOC
      Read [POQ] POQ0=NUMDOC;LINDOC;SEQDOC : If fstat  Raz [F:POQ] : Endif
    Endif
    #-----
    WBPSNUM=[F:POH]BPSNUM
    WCUR   =[F:POH]CUR
    WDEVSOC=func TRTX3BI.GETCUR([F:POH]POHFCY)
    WCHGTYP=[F:POH]CHGTYP
    WCHGDAT=[F:POH]ORDDAT
    WCOURS =0
    For WI=0 To 8
      WINVDTALIN(WI)=[F:POH]INVDTALIN2(WI)
      WDISCRGAMT(WI)=evalue("[F:POQ]DISCRGAMT"+num$(WI+1))
    Next WI
    #-----
  When 2 : #----- Réception
    If !clalev([F:PTH])  Local File =GDOSSIER+".PRECEIPT"  [PTH] : Endif
    If !clalev([F:PTD])  Local File =GDOSSIER+".PRECEIPTD" [PTD] : Endif
    #----- Lecture entête de réception si nécesaire -----#
    If [F:PTH]PTHNUM<>NUMDOC
      Read [PTH] PTH0=NUMDOC : If fstat  Raz [F:PTH] : Endif
    Endif
    #----- Lecture ligne de réception si nécessaire -----#
    If [F:PTD]PTHNUM<>NUMDOC | [F:PTD]PTDLIN<>LINDOC
      Read [PTD] PTD0=NUMDOC;LINDOC : If fstat  Raz [F:PTD] : Endif
    Endif
    #-----
    WBPSNUM=[F:PTH]BPSNUM
    WCUR   =[F:PTD]NETCUR
    WDEVSOC=func TRTX3BI.GETCUR([F:PTH]PRHFCY)
    WCHGTYP=[F:PTH]CHGTYP
    WCHGDAT=[F:PTH]RCPDAT
    WCOURS =0
    For WI=0 To 8
      WINVDTALIN(WI)=[F:PTH]INVDTALIN2(WI)
      WDISCRGAMT(WI)=evalue("[F:PTD]DISCRGAMT"+num$(WI+1))
    Next WI
    #-----
  When 3 : #----- Retour
    If !clalev([F:PNH])  Local File =GDOSSIER+".PRETURN"    [PNH] : Endif
    If !clalev([F:PND])  Local File =GDOSSIER+".PRETURND"   [PND] : Endif
    If !clalev([F:BPS])  Local File =GDOSSIER+".BPSUPPLIER" [BPS] : Endif
    #----- Lecture entête de retour si nécesaire -----#
    If [F:PNH]PNHNUM<>NUMDOC
      Read [PNH] PNH0=NUMDOC : If fstat  Raz [F:PNH] : Endif
    Endif
    #----- Lecture ligne de retour si nécessaire -----#
    If [F:PND]PTHNUM<>NUMDOC | [F:PND]PNDLIN<>LINDOC
      Read [PND] PND0=NUMDOC;LINDOC : If fstat  Raz [F:PND] : Endif
    Endif
    #----- Lecture fournisseur si nécessaire -----#
    If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
      Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : Endif
    Endif
    #-----
    WBPSNUM=[F:PNH]BPSNUM
    WCUR   =[F:PND]NETCUR
    WDEVSOC=func TRTX3BI.GETCUR([F:PNH]PNHFCY)
    WCHGTYP=[F:BPS]CHGTYP
    WCHGDAT=[F:PNH]RTNDAT
    WCOURS =0
    For WI=0 To 8
      WINVDTALIN(WI)=0
      WDISCRGAMT(WI)=0
    Next WI
    #-----
  When 4 : #----- Facture
    If !clalev([F:PIH])  Local File =GDOSSIER+".PINVOICE"  [PIH] : Endif
    If !clalev([F:PIV])  Local File =GDOSSIER+".PINVOICEV" [PIV] : Endif
    If !clalev([F:PID])  Local File =GDOSSIER+".PINVOICED" [PID] : Endif
    #----- Lecture entête de facture si nécesaire -----#
    If [F:PIH]NUM<>NUMDOC
      Read [PIH] PIH0=NUMDOC : If fstat  Raz [F:PIH] : Endif
    Endif
    #----- Lecture complément entête de facture si nécesaire -----#
    If [F:PIV]NUM<>NUMDOC
      Read [PIV] PIV0=NUMDOC : If fstat  Raz [F:PIV] : Endif
    Endif
    #----- Lecture ligne de facture si nécessaire -----#
    If [F:PID]NUM<>NUMDOC | [F:PID]PIDLIN<>LINDOC
      Read [PID] PID0=NUMDOC;LINDOC : If fstat  Raz [F:PID] : Endif
    Endif
    #-----
    WBPSNUM=[F:PIH]BPR
    WCUR   =[F:PIH]CUR
    WDEVSOC=func TRTX3BI.GETCUR([F:PIH]FCY)
    WCHGTYP=[F:PIH]CURTYP
    WCHGDAT=[F:PIH]RATDAT
    WCOURS=func TRTX3BI.GETRATCUR("PIH")
    For WI=0 To 8
      WINVDTALIN(WI)=[F:PIV]INVDTALIN2(WI)
      WDISCRGAMT(WI)=evalue("[F:PID]DISCRGAMT"+num$(WI+1))
    Next WI
    #-----
Endcase
#-----
If !clalev([F:PFI])  Local File =GDOSSIER+".PFOOTINV"   [PFI] : Endif
#----- Calcul du total HT remises ou frais -----#
Raz WAMTNOT
For WI=0 To 8
  If WINVDTALIN(WI)<>0 & WDISCRGAMT(WI)<>0
    Read [PFI] PFI0=WINVDTALIN(WI)
    If !fstat & [F:PFI]INCDCR=TYPAMT
      WAMTNOT+=WDISCRGAMT(WI)*WSIGN
    Endif
  Endif
Next WI
#----- Conversion et arrondi du montant dans la devise destination -----#
If !clalev([F:TCU])  Local File =GDOSSIER+".TABCUR" [TCU] : Endif
If [F:TCU]CUR<>WCUR
  Read [TCU] TCU0=WCUR : If fstat  Raz [F:TCU] : Endif
Endif
#-----
If DEVDES=WCUR
  WAMTNOT=arr(WAMTNOT,[F:TCU]CURRND)
Else
  Gosub PREP_CONVERSION From TRTX3BI
  Call COURMNT(WCUR,DEVDES,WDEVSOC,WCHGTYP,WCHGDAT,1,WAMTNOT,WMT,WCOURS,WSTAT) From TRTDEV
  If !WSTAT  WAMTNOT=WMT : Endif
Endif
#-----
End WAMTNOT


#########################################################################
# GETPIHFCY Détermination site achat ou stockage d'une ligne de facture #
# Get purchase invoice facility                                         #
#########################################################################
Funprog GETPIHFCY(WINVNUM,WINVLIN,WFCYTYP)
Value    Char     WINVNUM : # Numéro de la facture d'achat
Value    Integer  WINVLIN : # Numéro de la ligne de facture
Value    Integer  WFCYTYP : # Type de site à récupérer (1=Achat, 2=Stockage)
#-----
Local    Char     WFCY   (GLONFCY) : # Site achat ou stockage retourné
Local    Char     WPURFCY(GLONFCY) : # Site d'achat
Local    Char     WWRHFCY(GLONFCY) : # Site de stockage
Local    Char     WFINFCY(GLONFCY) : # Site financier
#-----
If !clalev([F:PID])   Local File =GDOSSIER+".PINVOICED" [PID]  : Endif
If !clalev([F:PIDB])  Local File =GDOSSIER+".PINVOICED" [PIDB] : Endif
#-----
If WFCYTYP<1 | WFCYTYP>2  WFCYTYP=1 : Endif
#-----
If [F:PID]NUM<>WINVNUM | [F:PID]PIDLIN<>WINVLIN
  Read [PID] PID0=WINVNUM;WINVLIN : If fstat  Raz [F:PID] : Endif
Endif
#-----
Case [F:PID]TYPORI
  When 1 : #----- Origine commande
    If WFCYTYP=1
      WFCY=[F:PID]FCYLIN
    Else
      If !clalev([F:POQ])  Local File =GDOSSIER+".PORDERQ" [POQ] : Endif
      If [F:POQ]POHNUM<>[F:PID]NUMORI |
&        [F:POQ]POPLIN<>[F:PID]LINORI |
&        [F:POQ]POQSEQ<>[F:PID]SEQORI
        Read [POQ] POQ0=[F:PID]NUMORI;[F:PID]LINORI;[F:PID]SEQORI
        If fstat  Raz [F:POQ] : Endif
      Endif
      If [F:POQ]PRHFCY<>""
        WFCY=[F:POQ]PRHFCY
      Else
        WFCY=[F:PID]FCYLIN : Gosub RECH_WRHFCY : WFCY=WWRHFCY
      Endif
    Endif
  When 2 : #----- Origine réception
    If WFCYTYP=2
      WFCY=[F:PID]FCYLIN
    Else
      If !clalev([F:PTD])  Local File =GDOSSIER+".PRECEIPTD" [PTD] : Endif
      If [F:PTD]PTHNUM<>[F:PID]NUMORI | [F:PTD]PTDLIN<>[F:PID]LINORI
        Read [PTD] PTD0=[F:PID]NUMORI;[F:PID]LINORI : If fstat  Raz [F:PTD] : Endif
      Endif
      If [F:PTD]POHFCY<>""
        WFCY=[F:PTD]POHFCY
      Else
        WFCY=[F:PID]FCYLIN : Gosub RECH_PURFCY : WFCY=WPURFCY
      Endif
    Endif
  When 3 : #----- Origine retour
    If WFCYTYP=2
      WFCY=[F:PID]FCYLIN
    Else
      If !clalev([F:PND])  Local File =GDOSSIER+".PRETURND"  [PND] : Endif
      If [F:PND]PNHNUM<>[F:PID]NUMORI | [F:PND]PNDLIN<>[F:PID]LINORI
        Read [PND] PND0=[F:PID]NUMORI;[F:PID]LINORI : If fstat  Raz [F:PND] : Endif
      Endif
      If [F:PND]POHFCY<>""
        WFCY=[F:PND]POHFCY
      Else
        WFCY=[F:PID]FCYLIN : Gosub RECH_PURFCY : WFCY=WPURFCY
      Endif
    Endif
  When 4 : #----- Origine facture
    If !clalev([F:PID2])  Local File =GDOSSIER+".PINVOICED"  [PID2] : Endif
    If [F:PID2]NUM<>[F:PID]NUMORI | [F:PID2]PIDLIN<>[F:PID]LINORI
      Read [PID2] PID0=[F:PID]NUMORI;[F:PID]LINORI : If fstat  Raz [F:PID2] : Endif
    Endif
    Case [F:PID2]TYPORI
      When 1 : #----- Origine commande
        If WFCYTYP=1
          WFCY=[F:PID2]FCYLIN
        Else
          If !clalev([F:POQ])  Local File =GDOSSIER+".PORDERQ" [POQ] : Endif
          If [F:POQ]POHNUM<>[F:PID2]NUMORI |
&            [F:POQ]POPLIN<>[F:PID2]LINORI |
&            [F:POQ]POQSEQ<>[F:PID2]SEQORI
            Read [POQ] POQ0=[F:PID2]NUMORI;[F:PID2]LINORI;[F:PID2]SEQORI
            If fstat  Raz [F:POQ] : Endif
          Endif
          If [F:POQ]PRHFCY<>""
            WFCY=[F:POQ]PRHFCY
          Else
            WFCY=[F:PID2]FCYLIN : Gosub RECH_WRHFCY : WFCY=WWRHFCY
          Endif
        Endif
      When 2 : #----- Origine réception
        If WFCYTYP=2
          WFCY=[F:PID2]FCYLIN
        Else
          If !clalev([F:PTD])  Local File =GDOSSIER+".PRECEIPTD" [PTD] : Endif
          If [F:PTD]PTHNUM<>[F:PID2]NUMORI | [F:PTD]PTDLIN<>[F:PID2]LINORI
            Read [PTD] PTD0=[F:PID2]NUMORI;[F:PID2]LINORI : If fstat  Raz [F:PTD] : Endif
          Endif
          If [F:PTD]POHFCY<>""
            WFCY=[F:PTD]POHFCY
          Else
            WFCY=[F:PID2]FCYLIN : Gosub RECH_PURFCY : WFCY=WPURFCY
          Endif
        Endif
      When 3 : #----- Origine retour
        If WFCYTYP=2
          WFCY=[F:PID2]FCYLIN
        Else
          If !clalev([F:PND])  Local File =GDOSSIER+".PRETURND"  [PND] : Endif
          If [F:PND]PNHNUM<>[F:PID2]NUMORI | [F:PND]PNDLIN<>[F:PID2]LINORI
            Read [PND] PND0=[F:PID2]NUMORI;[F:PID2]LINORI : If fstat  Raz [F:PND] : Endif
          Endif
          If [F:PND]POHFCY<>""
            WFCY=[F:PND]POHFCY
          Else
            WFCY=[F:PID2]FCYLIN : Gosub RECH_PURFCY : WFCY=WPURFCY
          Endif
        Endif
      When 4,5 : #----- Origine facture ou divers
        If WFCYTYP=1
          WFCY=[F:PID2]FCYLIN : Gosub RECH_PURFCY : WFCY=WPURFCY
        Else
          WFCY=[F:PID2]FCYLIN : Gosub RECH_WRHFCY : WFCY=WWRHFCY
        Endif
    Endcase
  When 5 : #----- origine divers
    If WFCYTYP=1
      WFCY=[F:PID]FCYLIN : Gosub RECH_PURFCY : WFCY=WPURFCY
    Else
      WFCY=[F:PID]FCYLIN : Gosub RECH_WRHFCY : WFCY=WWRHFCY
    Endif
Endcase
#-----
End WFCY

#-------------------------------------#
# Recherche site d'achat du site WFCY #
#-------------------------------------#
$RECH_PURFCY
If !clalev([F:FCY2])  Local File =GDOSSIER+".FACILITY" [FCY2] : Endif
If [F:FCY2]FCY<>WFCY
  Read [FCY2] FCY0=WFCY : If fstat  Raz [FCY2] : Endif
Endif
Raz WPURFCY
If [F:FCY2]PURFLG=2
  WPURFCY=WFCY
Else
  WFINFCY=func TRTX3BI.GETFINRSP(WFCY)
  Filter [FCY2] Where FINRSPFCY=WFINFCY & PURFLG=2
  Read [FCY2] FCY0 First
  If !fstat  WPURFCY=[F:FCY2]FCY : Endif
  Filter [FCY2]
Endif
Return

#-----------------------------------------#
# Recherche site de stockage du site WFCY #
#-----------------------------------------#
$RECH_WRHFCY
If !clalev([F:FCY2])  Local File =GDOSSIER+".FACILITY" [FCY2] : Endif
If [F:FCY2]FCY<>WFCY
  Read [FCY2] FCY0=WFCY : If fstat  Raz [FCY2] : Endif
Endif
If [F:FCY2]WRHFLG=2
  WWRHFCY=WFCY
Else
  WWRHFCY=""
Endif
Return


##############################################################################
# GETPFIFCY Détermination site achat ou stockage des éléments de facturation #
# Get purchase foot invoice facility                                         #
##############################################################################
Funprog GETPFIFCY(WINVNUM,WFCYTYP)
Value    Char     WINVNUM : # Numéro de la facture d'achat
Value    Integer  WFCYTYP : # Type de site à récupérer (1=Achat, 2=Stockage)
#-----
Local    Char     WFCY (10) : # Site achat ou stockage retourné
Local    Char     WFCY2(10) : # Site pour contrôle
#-----
If !clalev([F:PID])   Local File =GDOSSIER+".PINVOICED" [PID]  : Endif
#-----
If WFCYTYP<1 | WFCYTYP>2  WFCYTYP=1 : Endif
Raz WFCY2
#-----
For [PID] PID0 Where NUM=WINVNUM
  WFCY=func GETPIHFCY(WINVNUM,[F:PID]PIDLIN,WFCYTYP)
  If WFCY2=""
    WFCY2=WFCY
  Elsif WFCY2<>WFCY
    WFCY="" : Break
  Endif
Next
#-----
End WFCY


#####################################################################
# GETPOHCPR Détermination du prix de revient prévisionnel ligne cde #
# Get purchase order amount cost price                              #
#####################################################################
Funprog GETPOHCPR(NUMCDE,LINCDE,SEQCDE,DEVDES)
Value    Char     NUMCDE  : # Numéro de la commande
Value    Integer  LINCDE  : # Numéro de la ligne de la commande
Value    Integer  SEQCDE  : # Numéro de séquence de la ligne de commande
Value    Char     DEVDES  : # Devise destination
#----
If !clalev([F:POH])  Local File =GDOSSIER+".PORDER"     [POH] : Endif
If !clalev([F:POQ])  Local File =GDOSSIER+".PORDERQ"    [POQ] : Endif
If !clalev([F:POP])  Local File =GDOSSIER+".PORDERP"    [POP] : Endif
If !clalev([F:BPS])  Local File =GDOSSIER+".BPSUPPLIER" [BPS] : Endif
If !clalev([F:PRS])  Local File =GDOSSIER+".PRICSTRUCT" [PRS] : Endif
If !clalev([F:PFI])  Local File =GDOSSIER+".PFOOTINV"   [PFI] : Endif
If !clalev([F:TCU])  Local File =GDOSSIER+".TABCUR"     [TCU] : Endif
#-----
Local Char     WDEVSOC(20)
Local Decimal  WBASE, WMT, WRND
Local Integer  STAT, I
#----- Lecture entête de commande si nécesaire -----#
If [F:POH]POHNUM<>NUMCDE
  Read [POH] POH0=NUMCDE : If fstat  Raz [F:POH] : Endif
Endif
If [F:POH]POHTYP=1  SEQCDE=1 : Endif
#----- Lecture ligne commande qté si nécessaire -----#
If [F:POQ]POHNUM<>NUMCDE |
&  [F:POQ]POPLIN<>LINCDE |
&  [F:POQ]POQSEQ<>SEQCDE
  Read [POQ] POQ0=NUMCDE;LINCDE;SEQCDE : If fstat  Raz [F:POQ] : Endif
Endif
#----- Si composant, pas de calcul prix de revient -----#
If [F:POQ]LINTYP>2  Goto FIN_GETPOHCPR : Endif
#----- Lecture ligne commande prix si nécessaire -----#
If [F:POH]POHTYP<>2
  If [F:POP]POHNUM<>NUMCDE |
&    [F:POP]POPLIN<>LINCDE |
&    [F:POP]POPSEQ<>1
    Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1 : If fstat Raz  [F:POP] : Endif
  Endif
Else
  Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT
  Read [POP] POP1 First
  Filter [POP]
  If fstat  Raz [F:POP] : Endif
Endif
#-----
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
  Read [BPS] BPS0=[F:POH]BPSNUM
  If fstat  Raz [F:BPS] : Endif
Endif
If [F:PRS]BPCBPS<>2 | [F:PRS]PLISTC<>[F:BPS]PLISTC
  Read [PRS] PRS0=2;[F:BPS]PLISTC : If fstat  Raz [F:PRS] : Endif
Endif
#-----
If [F:TCU]CUR<>DEVDES
  Read [TCU] TCU0=DEVDES
  If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
#----------------------------#
# Récupération montant ligne #
#----------------------------#
If [F:POQ]LINTYP=2
  #----- Si produit fini, lecture service et matières fournies -----#
  #--CPO 78609 Erreur synchro depuis console
  #If !clalev([F:POQ2])  Local File PORDERQ [POQ2] : Endif
  If clalev([F:POQ2])=0 :  Local File =GDOSSIER+".PORDERQ"  [POQ2] : Endif
  #If !clalev([F:POP2])  Local File PORDERP [POP2] : Endif
  If clalev([F:POP2])=0 :  Local File =GDOSSIER+".PORDERP"  [POP2] : Endif
  #--/CPO

  For [POQ2] POQ0 Where POHNUM=NUMCDE & POPLIN>[F:POQ]POPLIN
    If [F:POQ2]LINTYP>2
      If [F:POQ2]QTYUOM<>0
        If [F:POQ2]POHTYP<>2
          Read [POP2] POP0=[F:POQ2]POHNUM;[F:POQ2]POPLIN;1 : If fstat Raz  [F:POP2] : Endif
        Else
          Filter [POP2] Where POHNUM=[F:POQ2]POHNUM & POPLIN=[F:POQ2]POPLIN & POPDAT>=[F:POQ2]DEMRCPDAT
          Read [POP2] POP1 First
          Filter [POP2]
          If fstat  Raz [F:POP2] : Endif
        Endif
        WBASE+=[F:POP2]NETPRI*[F:POQ2]QTYUOM : # Mt ligne avec précision maxi
      Else
        WBASE+=[F:POQ2]LINAMT                : # Mt ligne arrondi suivant devise
      Endif
    Else
      Break
    Endif
  Next
Else
  #----- Si ligne classique -----#
  If [F:POQ]QTYUOM<>0
    WBASE=[F:POP]NETPRI*[F:POQ]QTYUOM : # Mt ligne avec précision maxi
  Else
    WBASE=[F:POQ]LINAMT               : # Mt ligne arrondi suivant devise
  Endif
Endif
#-----------------------------#
# Eléments provenant du tarif #
#-----------------------------#
If [F:POQ]LINTYP=2
  #----- Si produit fini, lecture service et matières fournies -----#
  For [POQ2] POQ0 Where POHNUM=NUMCDE & POPLIN>[F:POQ]POPLIN
    If [F:POQ2]LINTYP>2
      If [F:POQ2]POHTYP<>2
        Read [POP2] POP0=[F:POQ2]POHNUM;[F:POQ2]POPLIN;1 : If fstat Raz  [F:POP2] : Endif
      Else
        Filter [POP2] Where POHNUM=[F:POQ2]POHNUM & POPLIN=[F:POQ2]POPLIN & POPDAT>=[F:POQ2]DEMRCPDAT
        Read [POP2] POP1 First
        Filter [POP2]
        If fstat  Raz [F:POP2] : Endif
      Endif
      #-----
      For I=1 To 9
        If [F:PRS]NPRNOTFLG(I-1)=1 & [F:PRS]INVDTA(I-1)<>0 & evalue("[F:POP2]DISCRGVAL"+num$(I))<>0
          Read [PFI] PFI0=[F:PRS]INVDTA(I-1) : If fstat Raz [F:PFI] : Endif
          If [F:PFI]NPRVLT=2
            #----- C'est un montant -----#
            If [F:PRS]VALTYP(I-1)=1
              If [F:PRS]CLCRUL(I-1)=1 : # Par unité
                WMT=arr(evalue("[F:POP2]DISCRGVAL"+num$(I))*[F:POQ2]QTYUOM,WRND)
              Else                    : # Par ligne
                WMT=evalue("[F:POP2]DISCRGVAL"+num$(I))
              Endif
            #----- C'est un pourcentage -----#
            Else
              WMT=arr(evalue("[F:POQ2]LINAMT")*evalue("[F:POP2]DISCRGVAL"+num$(I))/100,WRND)
            Endif
            #----- Inversion du montant si minoration -----#
            If [F:PRS]INCDCR(I-1)=2  WBASE=-WMT  Else  WBASE+=WMT : Endif
          Endif
        Endif
      Next I
      #-----
    Else
      Break
    Endif
  Next
Else
  #----- Si ligne classique -----#
  For I=1 To 9
    If [F:PRS]NPRNOTFLG(I-1)=1 & [F:PRS]INVDTA(I-1)<>0 & evalue("[F:POP]DISCRGVAL"+num$(I))<>0
      Read [PFI] PFI0=[F:PRS]INVDTA(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        #----- C'est un montant -----#
        If evalue("[F:POP]DISCRGVAL"+num$(I))<>0
          If [F:PRS]VALTYP(I-1)=1
            If [F:PRS]CLCRUL(I-1)=1 : # Par unité
              WMT=arr(evalue("[F:POP]DISCRGVAL"+num$(I))*[F:POQ]QTYUOM,WRND)
            Else              : # Par ligne
              WMT=evalue("[F:POP]DISCRGVAL"+num$(I))
            Endif
          #----- C'est un pourcentage -----#
          Else
            WMT=arr(evalue("[F:POQ]LINAMT")*evalue("[F:POP]DISCRGVAL"+num$(I))/100,WRND)
          Endif
          #----- Inversion du montant si minoration -----#
          If [F:PRS]INCDCR(I-1)=2  WBASE=-WMT  Else  WBASE+=WMT : Endif
        Endif
      Endif
    Endif
  Next I
Endif
#----------------------------------------#
# Eléments provenant du pied de commande #
#----------------------------------------#
For I=1 To 9
  If [F:POH]INVDTALIN2(I-1)<>0
    Read [PFI] PFI0=[F:POH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
    If [F:PFI]NPRVLT=2
      WBASE+=evalue("[F:POQ]DISCRGAMT"+num$(I))
    Endif
  Endif
Next I
#-----
If [F:POQ]LINTYP=2
  For [POQ2] POQ0 Where POHNUM=NUMCDE & POPLIN>[F:POQ]POPLIN
    If [F:POQ2]LINTYP>2
      For I=1 To 9
        If [F:POH]INVDTALIN2(I-1)<>0
          Read [PFI] PFI0=[F:POH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
          If [F:PFI]NPRVLT=2
            WBASE+=evalue("[F:POQ2]DISCRGAMT"+num$(I))
          Endif
        Endif
      Next I
    Else
      Break
    Endif
  Next
Endif
#----- Conversion si nécessaire du montant en devise destination -----#
If [F:POH]CUR<>DEVDES
  WDEVSOC=func TRTX3BI.GETCUR([F:POH]POHFCY)
  WMT=WBASE
  Call CONVERT2([F:POH]CUR,WDEVSOC,WDEVSOC,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               WMT,WBASE,STAT) From TRTDEV
  WBASE=arr(WBASE,WRND)
Endif
#-----
$FIN_GETPOHCPR
End WBASE

#####################################################################
# ROUNDAMOUNT Arrondi d'un montant selon le paramètrage de la devise#
# Round an amount according the one from currency's setup						#
#####################################################################
#--CPO 83711
Funprog ROUNDAMOUNT(PAMOUNT,PCUR)
Value  Decimal PAMOUNT	 :# Amount
Value  Char    PCUR      :# Currency

Local Decimal AMOUNTARR
AMOUNTARR = PAMOUNT
If PAMOUNT=0 | PCUR="" Goto END_ROUNDAMOUNT Endif
#-----
If !clalev([F:TCU])  Local File =GDOSSIER+".TABCUR" [TCU] : Endif
If [F:TCU]CUR<>PCUR
  Read [TCU] TCU0=PCUR : If fstat  Raz [F:TCU] : Goto END_ROUNDAMOUNT : Endif
Endif
#-----

AMOUNTARR=arr(PAMOUNT,[F:TCU]CURRND)
$END_ROUNDAMOUNT
End AMOUNTARR
#####################################################################
# CALC_AMTDED_PSH Rends la somme des taxes déductibles,  						#
# éventuellement proratisé par la qté passée en paramètres					#
# (par rapport à la quantité en US de la ligne de DA)  							#
#####################################################################
Funprog CALC_AMTDED_PSH(PNUMDOC,PLINDOC,PCUR,PQTYPSH_US)
Value    Char     PNUMDOC    : # Numéro du document
Value    Integer  PLINDOC    : # Numéro de la ligne du document
Value    Char     PCUR       : # Devise document
Value    Integer  PQTYPSH_US : # Quantité en US

Local Decimal MONTANT

If !clalev([F:PSD])  Local File =GDOSSIER+".PREQUISD" [PSD] : Endif

#----- Lecture ligne de demande d'achat si nécessaire -----#
If [F:PSD]PSHNUM<>PNUMDOC | [F:PSD]PSDLIN<>PLINDOC
  Read [PSD] PSD0=PNUMDOC;PLINDOC : If fstat  Raz [F:PSD] : Endif
Endif
#-----
If PQTYPSH_US<[F:PSD]QTYSTU
  MONTANT  = func TRTACHBI.ROUNDAMOUNT(([F:PSD]DEDTAXLIN1*PQTYPSH_US)/[F:PSD]QTYSTU,PCUR)
  MONTANT += func TRTACHBI.ROUNDAMOUNT(([F:PSD]DEDTAXLIN2*PQTYPSH_US)/[F:PSD]QTYSTU,PCUR)
  MONTANT += func TRTACHBI.ROUNDAMOUNT(([F:PSD]DEDTAXLIN3*PQTYPSH_US)/[F:PSD]QTYSTU,PCUR)
  MONTANT += func TRTACHBI.ROUNDAMOUNT(([F:PSD]DEDTAXRCP *PQTYPSH_US)/[F:PSD]QTYSTU,PCUR)
  MONTANT += func TRTACHBI.ROUNDAMOUNT(([F:PSD]DEDTAXISS *PQTYPSH_US)/[F:PSD]QTYSTU,PCUR)
  MONTANT += func TRTACHBI.ROUNDAMOUNT(([F:PSD]DEDTAXOTH1*PQTYPSH_US)/[F:PSD]QTYSTU,PCUR)
  MONTANT += func TRTACHBI.ROUNDAMOUNT(([F:PSD]DEDTAXOTH2*PQTYPSH_US)/[F:PSD]QTYSTU,PCUR)
Else
  MONTANT = [F:PSD]DEDTAXLIN1+[F:PSD]DEDTAXLIN2+[F:PSD]DEDTAXLIN3+[F:PSD]DEDTAXRCP+
&           [F:PSD]DEDTAXISS +[F:PSD]DEDTAXOTH1+[F:PSD]DEDTAXOTH2
Endif

End MONTANT
#--/CPO
