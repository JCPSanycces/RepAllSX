#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TNH2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone LICPLATE
mkstat = 0
zoncou = "LICPLATE"
indice = 0
If varmode([M]LICPLATE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LICPLATE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TRLLICPLATE
mkstat = 0
zoncou = "TRLLICPLATE"
indice = 0
If varmode([M]TRLLICPLATE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TRLLICPLATE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DPEDAT
mkstat = 0
zoncou = "DPEDAT"
indice = 0
WDATE = [M]DPEDAT
If varmode([M]DPEDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DPEDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_DPEDAT([M]DPEDAT) From SUBTNH
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "DPEDAT" : GZNUM = 52763 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WDATE<>[M]DPEDAT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DPEDAT([M]DPEDAT) From SUBTNH
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DPEDAT" : GZNUM = 52763 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ETD
mkstat = 0
zoncou = "ETD"
indice = 0
If varmode([M]ETD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ARVDAT
mkstat = 0
zoncou = "ARVDAT"
indice = 0
If varmode([M]ARVDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ARVDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ARVDAT([M]ARVDAT) From SUBTNH
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ARVDAT" : GZNUM = 52762 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ETA
mkstat = 0
zoncou = "ETA"
indice = 0
If varmode([M]ETA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETA" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ETA([M]ETA) From SUBTNH
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ETA" : GZNUM = 13424 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone GLBDOC
mkstat = 0
zoncou = "GLBDOC"
indice = 0
IMPENT = [M]GLBDOC
WNUM = IMPENT
If varinit([M]GLBDOC,indice)=0
 IMPENT = 1
Endif
If varmode([M]GLBDOC,indice)=0
 [M]GLBDOC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "GLBDOC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]GLBDOC(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_GLBDOC(IMPENT) From SUBTNH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GLBDOC" : GZNUM = 52720 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]GLBDOC = IMPENT

## Zone GLBDOCTYP
mkstat = 0
zoncou = "GLBDOCTYP"
indice = 0
IMPENT = [M]GLBDOCTYP
If varinit([M]GLBDOCTYP,indice)=0
 IMPENT = 2
Endif
If varmode([M]GLBDOCTYP,indice)=0
 Call INICOMBO(2047) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_GLBDOCTYP(IMPENT) From SUBTNH
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,2047,1))))
 Endif
 [M]GLBDOCTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "GLBDOCTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]GLBDOCTYP(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "GLBDOCTYP" : GZNUM = 30216 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]GLBDOCTYP = IMPENT

## Zone GLBDOCNUM
mkstat = 0
zoncou = "GLBDOCNUM"
indice = 0
WCHAR = [M]GLBDOCNUM
If varmode([M]GLBDOCNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GLBDOCNUM" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]GLBDOCNUM or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_GLBDOCNUM([M]GLBDOCNUM) From SUBTNH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GLBDOCNUM" : GZNUM = 52721 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone GLBDOCDAT
mkstat = 0
zoncou = "GLBDOCDAT"
indice = 0
If varmode([M]GLBDOCDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GLBDOCDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone MANDOC
mkstat = 0
zoncou = "MANDOC"
indice = 0
If varmode([M]MANDOC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MANDOC" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_MANDOC([M]MANDOC) From SUBTNH
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MANDOC" : GZNUM = 52733 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone ATDTCOD
mkstat = 0
zoncou = "ATDTCOD"
indice = 0
If varmode([M]ATDTCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ATDTCOD" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TNH2"
Return

