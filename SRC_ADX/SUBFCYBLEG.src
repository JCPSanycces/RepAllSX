#call automatic show/hide
  If func DIVPAYE.EXISTE_KXX("WOFCYHIDE") Then Call HIDE_ACTIVITYFIELDS From WOFCYHIDE : Endif
  If func DIVPAYE.EXISTE_KXX("WOFCYSHOW") Then Call SHOW_LEGACTCALLS From WOFCYSHOW :Endif

#show all SPECIFIC fields
  Gosub SHOW_ALL_SPECIFIC

#hide SPECIFIC fields
  Gosub HIDE_SPECIFIC

End

$SHOW_ALL_SPECIFIC
#show fields
  If dim([M:FCY1]NAF)>0       : Chgfmt [M:FCY1]NAF        With "K:"+num$(GLONNAF)+"X" : Endif
  If dim([M:FCY1]CRN)>0       : Chgfmt [M:FCY1]CRN        With "K:"+num$(GLONCRT)+"X" : Endif
  If dim([M:BPF]XEXTNUM)>0    : Chgfmt [M:BPF]XEXTNUM     With "K:30X"                : Endif

  If dim([M:FCYP]BPASGE)>0    : Chgfmt [M:FCYP]BPASGE     With "K:"+num$(GLONADR)+"X" : Endif
  If dim([M:FCYP]BPADESSGE)>0 : Chgfmt [M:FCYP]BPADESSGE  With "K:20X"                : Endif
  If dim([M:FCYP]BPADCL)>0    : Chgfmt [M:FCYP]BPADCL     With "K:"+num$(GLONADR)+"X" : Endif
  If dim([M:FCYP]BPADESDCL)>0 : Chgfmt [M:FCYP]BPADESDCL  With "K:20X"                : Endif
  If dim([M:FCYP]CNTDDS)>0    : Chgfmt [M:FCYP]CNTDDS     With "K:"+num$(GLONAIN)+"X" : Endif

#JOJAC - 2016-08-30 - X3PEOP-1584  - START
  If dim([M:FCYP]REGPRH)>0 :  Chgfmt [M:FCYP]REGPRH      With "LA:10373" : Endif  #REGPRH  code Prud'homale
  If dim([M:FCYP]SECPRH)>0 :  Chgfmt [M:FCYP]SECPRH      With "LA:10373" : Endif #SECPRH  code derogation pooling sub
#JOJAC - 2016-08-30 - X3PEOP-1584  - END


#reset block titles
  If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
  Local Integer WNUMLIBEL
  Read [F:AMKW]CODMSK = "FCYPAY"

#JASMI - 2017-05-25 - START
#  WNUMLIBEL=[F:AMKW]TITBLOC(1)
  WNUMLIBEL=[F:AMKW]TITBLOC(0)
#JASMI - 2017-05-25 - END
  Chgtbk [M:FCYP]5  With func AFNC.TEXTE(WNUMLIBEL)

#JASMI - 2017-05-25 - START
#  WNUMLIBEL=[F:AMKW]TITBLOC(2)
  WNUMLIBEL=[F:AMKW]TITBLOC(1)
#JASMI - 2017-05-25 - END
  Chgtbk [M:FCYP]10 With func AFNC.TEXTE(WNUMLIBEL)

Return

$HIDE_SPECIFIC
#Saudi Arabia
  If func DIVPAYE.IS_KSA_LEG(GCURLEG) or
&    func DIVPAYE.IS_KAE_LEG(GCURLEG) or
&    func DIVPAYE.IS_KQA_LEG(GCURLEG) Then

  #set block titles
    Chgtbk [M:FCYP]5              With mess(22,11738,1)

  #hide fields
    If dim([M:FCY1]NAF)>0       : Chgfmt [M:FCY1]NAF        With "-K:"+num$(GLONNAF)+"X"  : Endif
    If dim([M:FCY1]CRN)>0       : Chgfmt [M:FCY1]CRN        With "-K:"+num$(GLONCRT)+"X"  : Endif
    If dim([M:BPF]XEXTNUM)>0    : Chgfmt [M:BPF]XEXTNUM     With "-K:30X"                 : Endif

  Endif

#Angola or Portugal
  If func DIVPAYE.IS_KAO_LEG(GCURLEG) | func DIVPAYE.IS_KPO_LEG(GCURLEG)
    Chgtbk [M:FCYP]10             With ""

  #hide fields
    If dim([M:FCYP]BPASGE)>0    : Chgfmt [M:FCYP]BPASGE     With "-K:"+num$(GLONADR)+"X"  : Endif
    If dim([M:FCYP]BPADESSGE)>0 : Chgfmt [M:FCYP]BPADESSGE  With "-K:20X"                 : Endif
    If dim([M:FCYP]BPADCL)>0    : Chgfmt [M:FCYP]BPADCL     With "-K:"+num$(GLONADR)+"X"  : Endif
    If dim([M:FCYP]BPADESDCL)>0 : Chgfmt [M:FCYP]BPADESDCL  With "-K:20X"                 : Endif
    If dim([M:FCYP]CNTDDS)>0    : Chgfmt [M:FCYP]CNTDDS     With "-K:"+num$(GLONAIN)+"X"  : Endif

  Endif

#JOJAC - 2016-08-30 - X3PEOP-1584  - START
  If func DIVPAYE.IS_KZA(GCURLEG)
    Chgfmt [M:FCYP]REGPRH      With "-LA:10373"  #REGPRH  code Prud'homale
    Chgfmt [M:FCYP]SECPRH      With "-LA:10373"  #SECPRH  code derogation pooling sub
  Endif
#JOJAC - 2016-08-30 - X3PEOP-1584  - END



Return
#JASMI - 2016-06-06 - REQ 114309 - END

