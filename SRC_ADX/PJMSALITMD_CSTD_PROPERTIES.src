#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMSALITMD
###################################################################################################
# PROPERTIES
###################################################################################################
$TCHACTION
  Case [L]ARULE
    When "CONTROL"   : Gosub TCHACTION_CONTROL
  Endcase
Return

$TCHACTION_CONTROL
  # Empty     : interactive (manually)
  # SOLD      : PJM_SPLD_AUTOMATION operation
  # SALES_DOC : PJM_SPLD_SOLD operation
  If this.TCHACTION <> AVOID.ACHAR and this.TCHACTION <> "SOLD" and this.TCHACTION <> "SALES_DOC" Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHACTION", func AFNC.MES1(mess(390,2260,1), this.TCHACTION), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$ORI
  Case [L]ARULE
    When "INIT"      : Gosub ORI_INIT
    When "CONTROL"   : Gosub ORI_CONTROL
    When "PROPAGATE" : Gosub ORI_PROPAGATE
  Endcase
Return

$ORI_INIT
  this.ORI = 1
Return

$ORI_CONTROL
  # Later we will probably add control to check when and how this property value can be changed.
  # But by default, its value is "manual"
  If this.ORI = 6 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORI", func AFNC.MES2(mess(966,2260,1), num$(this.ORI), mess(this.ORI,7713,1)), [V]CST_AERROR))
  Endif
  If this.TCHACTION = "" Then
    If this.ASTALIN = [V]CST_ANEW Then
      If this.ORI <> 1 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORI", mess(18,9804,1), [V]CST_AERROR))
      Endif
    Elsif this.ASTALIN = [V]CST_AUPD Then
      If this.ORI <> this.snapshot.ORI Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORI", mess(18,9804,1), [V]CST_AERROR))
      Endif
    Endif
  Elsif this.TCHACTION = "SOLD" Then
    # In automation, ORI is mandatory <> 1-Manual
    If this.ORI = 1 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORI", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Elsif this.TCHACTION = "SALES_DOC" Then
    If this.ORI <> this.snapshot.ORI Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ORI", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

$ORI_PROPAGATE
  If this.ORI = 1 Then       # manual lines only
    Raz this.EXTQTY          # must be empty for manually created lines
    Raz this.EXTUOM
  Endif
Return

###################################################################################################
$ITMREF
  Case [L]ARULE
    When "CONTROL"   : Gosub ITMREF_CONTROL
    When "PROPAGATE" : Gosub ITMREF_PROPAGATE
  Endcase
Return

$ITMREF_CONTROL
  Local File ITMSALES [ITS]
  # --------------------------
  If this.TCHACTION <> "SOLD" Then
    If fmet this.SALES_DOC_EXIST() = [V]CST_AYES and this.ITMREF <> this.snapshot.ITMREF Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMREF", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  # --------------------------
  Read [ITS]ITS0=this.ITMREF
  If fstat Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMREF", func AFNC.MES1(mess(392,2260,1), this.ITMREF), [V]CST_AERROR))
  Endif
Return

$ITMREF_PROPAGATE
Local Integer ISAUFOUND
Local Integer IRET
Local Char SMESSAGE(250)

  # --------------------------
  Local File ITMMASTER [ITM]
  Local File ITMSALES  [ITS]
  Local File ITMBPC    [ITU]
  # --------------------------
  # get description and base price
  Read [ITM]ITM0=this.ITMREF
  Read [ITS]ITS0=this.ITMREF
  # Because errors cases are managed before, you have to test [L]ASTATUS before doing that
  # Do not need to check snapshot in propogate. If the same, the propogate will not be called.
  # Can have one routine for both ANEW and AUPD
  Call CHARGE_DEFITMDES("DES1AXX", this.ACTX.LAN, [F:ITM]ITMREF, this.ITMDES, "") From TRTX3_SYRA
  # --------------------------
  ISAUFOUND = [V]CST_ANO
  If this.OPPCMP <> AVOID.ACHAR Then
    Read [F:ITU]ITU0=this.ITMREF;this.OPPCMP
    If !fstat Then
      If [F:ITU]SAU <> AVOID.ACHAR Then
        this.SAU = [F:ITU]SAU
        ISAUFOUND = [V]CST_AYES
      Endif
    Endif
  Endif
  # --------------------------
  If ISAUFOUND = [V]CST_ANO Then
    If [F:ITM]SAU <> AVOID.ACHAR Then
      this.SAU = [F:ITM]SAU
    Endif
  Endif
  this.BASPRI = [F:ITS]BASPRI
  If func ASYRFNC.ACTIV("ECC") = [V]CST_ATRUE Then
    Raz this.ECCVALMAJ
    Raz this.ECCVALMIN
    IRET = func PJMECCSTKTOOLS.STKINIECC(this.ACTX, this.ITMREF, 2, this.OPPCMP, this.ECCVALMAJ, SMESSAGE)
    If IRET <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMREF", SMESSAGE, IRET))
    Endif
    # --------------------------
  Endif
Return

###################################################################################################
$ECCVALMAJ
  Case [L]ARULE
    When "CONTROL"   : Gosub ECCVALMAJ_CONTROL
    When "PROPAGATE" : Gosub ECCVALMAJ_PROPAGATE
  Endcase
Return

$ECCVALMAJ_CONTROL
Local Char SMESSAGE(250)
Local Integer IRET
Local Integer IRET2

  If this.ITMREF = AVOID.ACHAR and this.ECCVALMAJ <> AVOID.ACHAR Then
    [L]ASTATUS = fmet this.SETERROR("ECCVALMAJ", mess(18,9804,1), [V]CST_AERROR)
  Else
    IRET = func STKSOR_SYRA.CTLECCVAL(this.ACTX, this.ECCVALMAJ, this.STOFCY, this.ITMREF, 4, AVOID.ACHAR, [0/0/0], IRET2, SMESSAGE)
    If IRET <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ECCVALMAJ", SMESSAGE, IRET))
    Endif
  Endif
Return

ECCVALMAJ_PROPAGATE
Local Char SMESSAGE(250)
Local Integer IRET

  If this.ITMREF <> AVOID.ACHAR and this.ECCVALMAJ <> AVOID.ACHAR Then
    IRET = func PJMECCSTKTOOLS.READECCMIN(this.ACTX, this.ITMREF, this.ECCVALMAJ, this.ECCVALMIN, SMESSAGE)
    If IRET <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ECCVALMAJ", SMESSAGE, IRET))
    Endif
  Endif
Return

###################################################################################################
$ITMDES
  Case [L]ARULE
    When "CONTROL"   : Gosub ITMDES_CONTROL
  Endcase
Return

$ITMDES_CONTROL
  If this.TCHACTION <> "SOLD" Then
    If fmet this.SALES_DOC_EXIST() = [V]CST_AYES and this.ITMDES <> this.snapshot.ITMDES Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMDES", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$QTY
  Case [L]ARULE
    When "INIT"        : Gosub QTY_INIT          # Issue X3-101321 - 2018-08-09 by FGR
    When "CONTROL"     : Gosub QTY_CONTROL
  Endcase
Return

$QTY_INIT
  # Issue X3-101321 - 2018-08-09 by FGR
  this.QTY = 1
Return

$QTY_CONTROL
  If this.TCHACTION <> "SOLD" and this.TCHACTION <> "SALES_DOC" Then
    If fmet this.SALES_DOC_EXIST() = [V]CST_AYES and this.QTY <> this.snapshot.QTY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("QTY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  If this.QTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("QTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$QTYSTU
  Case [L]ARULE
    When "CONTROL"   : Gosub QTYSTU_CONTROL
  Endcase
Return

$QTYSTU_CONTROL
  If this.TCHACTION <> "SOLD" Then
    If fmet this.SALES_DOC_EXIST() = [V]CST_AYES and this.QTYSTU <> this.snapshot.QTYSTU Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("QTYSTU", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  If this.QTYSTU < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("QTYSTU", mess(232,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$BASPRI
  Case [L]ARULE
    When "CONTROL"   : Gosub BASPRI_CONTROL
  Endcase
Return

$BASPRI_CONTROL
  If this.TCHACTION <> "SOLD" and this.TCHACTION <> "SALES_DOC" Then
    If fmet this.SALES_DOC_EXIST() = [V]CST_AYES and this.BASPRI <> this.snapshot.BASPRI Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("BASPRI", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  If this.BASPRI < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("BASPRI", mess(234,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$PRODGRPLVL
  Case [L]ARULE
    When "CONTROL"   : Gosub PRODGRPLVL_CONTROL
  Endcase
Return

$PRODGRPLVL_CONTROL
  # allow 1=not grouped;2=project
  # 3=budget, if line has a budget code
  # 4=task, if line has a task code
  If this.TCHACTION <> "SOLD" and this.TCHACTION <> "SALES_DOC" Then
    If fmet this.SALES_DOC_EXIST() = [V]CST_AYES and this.PRODGRPLVL <> this.snapshot.PRODGRPLVL Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PRODGRPLVL", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  Case this.PRODGRPLVL
    When 3
      If this.PBUCOD = AVOID.ACHAR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PRODGRPLVL", mess(380,2260,1), [V]CST_AERROR))  # add mess to local menu
      Endif
    When 4
      If this.TASCOD = AVOID.ACHAR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PRODGRPLVL", mess(381,2260,1), [V]CST_AERROR))  # add mess to local menu
      Endif
  Endcase
Return

###################################################################################################
$SAU
  Case [L]ARULE
    When "CONTROL"   : Gosub SAU_CONTROL
  Endcase
Return

$SAU_CONTROL
  If this.TCHACTION <> "SOLD" Then
    If fmet this.SALES_DOC_EXIST() = [V]CST_AYES and this.SAU <> this.snapshot.SAU Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SAU", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$STU
  Case [L]ARULE
    When "CONTROL"   : Gosub STU_CONTROL
  Endcase
Return

$STU_CONTROL
  If this.TCHACTION <> "SOLD" Then
    If fmet this.SALES_DOC_EXIST() = [V]CST_AYES and this.STU <> this.snapshot.STU Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STU", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$PSONUM
  Case [L]ARULE
    When "CONTROL"   : Gosub PSONUM_CONTROL
  Endcase
Return

$PSONUM_CONTROL
  If this.TCHACTION = "SALES_DOC" Then
    # See later if a control is necessary in this case
  Else
    # Modification not allowed excepted during sales document creation process
    If (this.ASTALIN = [V]CST_ANEW and this.PSONUM <> AVOID.ACHAR) or (this.ASTALIN = [V]CST_AUPD and this.PSONUM <> this.snapshot.PSONUM) Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PSONUM", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$PSOLIN
  Case [L]ARULE
    When "CONTROL"   : Gosub PSOLIN_CONTROL
  Endcase
Return

$PSOLIN_CONTROL
  If this.TCHACTION = "SALES_DOC" Then
    # See later if a control is necessary in this case
  Else
    # Modification not allowed excepted during sales document creation process
    If (this.ASTALIN = [V]CST_ANEW and this.PSOLIN <> 0) or (this.ASTALIN = [V]CST_AUPD and this.PSOLIN <> this.snapshot.PSOLIN) Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PSOLIN", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$KEYCONCAT
  Case [L]ARULE
    When "GET"       : Gosub KEYCONCAT_GET
  Endcase
Return

$KEYCONCAT_GET
  this.KEYCONCAT = fmet this.GET_SPLD_KEYCONCAT()
Return

