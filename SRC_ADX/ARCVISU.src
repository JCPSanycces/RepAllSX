#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GNBMASKOUV
Local Char PARAM(40)(1..3) , VALEUR(40)
PARAM(1) = ""
Call SAISIE_CHAR(VALEUR,PARAM,"ARCVISU","ARCVISU","") From GSAISIE
End

#----------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "RAF"         : Gosub RAF
 When "OK"          : Gosub OK
 When "FIN"         : Gosub FIN
Endcase
Return

#------------------------------#
$OUVRE
Local Char OACTION(20)
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif 
If clalev([F:ARU])=0 : Local File ARCHPARU [ARU] : Endif
If GARCROOT="" : FIN = 1 : Endif
Return

#------------------------------#
$DEBUT
Effzo 5
I = instr(1,PARAM(1),"~")
J = instr(I+1,PARAM(1),"~")
If I & J
 [M]CNT = left$(PARAM(1),I-1)
 [M]ID  = seg$(PARAM(1),I+1,J-1)
 [M]REV = right$(PARAM(1),J+1)
Else
 [M]CNT = PARAM(1)   : # Conteneur
 [M]ID  = PARAM(2)   : # Identifiant document
 [M]REV = PARAM(3)   : # Version du document
Endif
Affzo 5
If [M]ID<>""
 Gosub URL
Else
 [M]DOC = '""'
Endif
Return

#------------------------------#
$SETBOUT
If REP<>"M"
# Call VIREBOUT(CHBOU,"O") From GOBJET
Endif
If instr(1,CHBOU,"=")=0 : CHBOU += "="  : Endif : # Raf
Return

#------------------------------#
$APRES_MODIF
REP = "M"
Return

#------------------------------#
$OK
Gosub URL
REP = ""
FIN = 0
Return

#------------------------------#
$RAF
If [M]ID<>""
 Gosub URL
Else
 [M]DOC = '""'
Endif
Return

#------------------------------#
$URL
Gosub SET_USER
# Adresse url
If [M]ID="" : Return : Endif
If dim(GCLBURL)<=0
 Global Clbfile GCLBURL(1)
Endif
GCLBURL = evalue(GARCROOT)
If vireblc(GARCROOT2,2)<>""
 GCLBURL += evalue(GARCROOT2)
Endif
If vireblc(GARCURL,2)<>""
 GCLBURL += evalue(GARCURL)
Endif
Gosub SET_PRGSTD From SUBARC
OACTION = ACTION
ACTION = "GETURL" : Gosub ACTION From ARCHIVE
ACTION = OACTION
If !OK : FIN = 1 : Return : Endif
Effzo DOC
Affzo DOC
Inftxt GCLBURL At 1
Return

#---------------------------------------------------------------#
$SET_USER
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif 
If clalev([F:ARU])=0 : Local File ARCHPARU [ARU] : Endif
Read [AUS]CODUSR=GUSER
Read [ARU]ARU0=[F:AUS]ARCPRF
Return

#------------------------------#
$FIN
Inftxt "" At 1
Return

