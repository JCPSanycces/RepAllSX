#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation AOBJEXTR

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
      When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
      When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER

    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return



############################################################################################################

$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1
#TBPRO(NBPRO) = "NUMTAB" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AOR.NUMTAB" : TBFIL(NBPRO) = "[LNK_]NUMTAB"
TBPRO(NBPRO) = "NUMTAB" : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "AOR.NUMTAB" : TBFIL(NBPRO) = "[LNK_]NUMTAB" #### 3
NBPRO += 1
#TBPRO(NBPRO) = "INTIT" : TBTYP(NBPRO) = 7  : TBPTH(NBPRO) = "AOR.INTIT" : TBFIL(NBPRO) = "[LNK_]INTIT"
TBPRO(NBPRO) = "INTIT" : TBTYP(NBPRO) = 26  : TBPTH(NBPRO) = "AOR.INTIT" : TBFIL(NBPRO) = "[LNK_]INTIT" ####### 26
#TBPRO(NBPRO) = "INTIT" : TBTYP(NBPRO) = 7  : TBPTH(NBPRO) = "INTIT" : TBFIL(NBPRO) = "[LNK_]INTIT" ################

Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]NUMTAB"
Return

$AQUERY_OPEN_AFTER
Local File AOBJEXTR [QRY_AOR]
Local Integer MY_STATUS,NUMTAB(1..),I : I=0
Local Char INTIT(30)(1..)
Local Instance MY_AOBJEXTRD Using C_AOBJEXTRD

Local Instance MY_AOBJEXTR Using C_AOBJEXTR # 7/17/14

For [QRY_AOR]AOR0(1)
  MY_AOBJEXTR = NewInstance C_AOBJEXTR AllocGroup null # 7/17/14
  [L]MY_STATUS = fmet MY_AOBJEXTR.AREAD([F:QRY_AOR]NUMTAB) # 7/17/14

  MY_AOBJEXTRD = NewInstance C_AOBJEXTRD AllocGroup null
  [L]MY_STATUS = fmet MY_AOBJEXTRD.AREAD([F:QRY_AOR]NUMTAB,[F:QRY_AOR]NUMLIG)
  If [L]MY_STATUS = [V]CST_AOK
    I+=1
    [L]NUMTAB(I)       = [F:QRY_AOR]NUMTAB
    #[L]INTIT(I)       = fmet MY_AOBJEXTRD.INTIT.AGETTEXT
    [L]INTIT(I)        = fmet MY_AOBJEXTR.INTIT.AGETTEXT  # Will not work on interface class

    Local Instance MY_ATEXTRA Using C_ATEXTRA
    MY_ATEXTRA = NewInstance C_ATEXTRA AllocGroup null
    [L]MY_STATUS = fmet MY_ATEXTRA.AREAD("AOBJEXTR","INTIT",GACTX.LAN,num$([L]NUMTAB(I)),AVOID.ACHAR) #
    If [L]MY_STATUS = [V]CST_AOK
      [L]INTIT(I) = MY_ATEXTRA.TEXTE
    Endif
    FreeGroup MY_ATEXTRA
  Endif
  FreeGroup MY_AOBJEXTRD
  FreeGroup MY_AOBJEXTR # 7/17/14
Next

Local File (Integer NUMTAB, Char INTIT(30)) From Variable [L]NUMTAB,[L]INTIT As [LNK_]

Return

$AQUERY_TRANS_AFTER

this.AOR.NUMTAB     = [LNK_]NUMTAB
this.AOR.INTIT      = [LNK_]INTIT # AGETTEXT method on Interface class above does NOT work.
this.TITLE          = [LNK_]INTIT #

Return

$AQUERY_CLOSE_AFTER
Close Local File [QRY_AOR]
Return

