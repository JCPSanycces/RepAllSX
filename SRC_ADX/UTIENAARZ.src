#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour flag actif dans fiche paramètrage ZPL
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update ENAFLG field on AREPORTZ table") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub GESARZ
End

#-------------------#
$GESARZ

If filinfo(filpath("FIL","AREPORTZ","fde",DOSSIER),0)<=0
 Return
Endif

Local File =DOSSIER+".AREPORTZ"   [ARZ] 
If dim([F:ARZ]ENAFLG)>0
 # Mise à jour de la table AREPORTZ
 Call ECR_TRACE(mess(81,125,1)-"AREPORTZ:"-time$,0) From GESECRAN
 Trbegin [ARZ]
  For [ARZ]
   If [F:ARZ]ENAFLG=0
    [F:ARZ]ENAFLG=2
    Rewrite [ARZ]
    If fstat
     Call ERREUR("AREPORTZ"-[F:ARZ]CODPAR,2) From DOSDIC
    Endif 
   Endif
  Next ARZ
 Commit
Endif

Close Local File [ARZ]

Return
