#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTI2017R04 UTI process for 2017R4 of X3
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2017R4 - passage de R3 vers R4
#
#      correction utility to be done at the end of the patch - move from R3 to R4
#
##########################################################################
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2017R04 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
  #Infbox "only update folder by patch"

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2017R04 (APPLI)

End

###################################################
Subprog EXE_UTI2017R04(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2017R04-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#-------------------------------------------------------------#

  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTIPJM021              # Issue X3-33150 - 2017-06-21 by SINGC/FGR
  Endif

#  Call PATCH  (LDOSSIER) From UTIXXX
If [F:ADS]MODULE(6)=2
  # Transactions saisie
  Call PATCH(LDOSSIER) From SUBSPK     # colisage
Endif
# Issue 40504 - 2017-06-27 by MAE
If [F:ADS]MODULE(5)=2
  Call PATCH(LDOSSIER) From CNSSHIPDSTD
Endif


Call ECR_TRACE("END : UTI2017R04-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2017R04
End

