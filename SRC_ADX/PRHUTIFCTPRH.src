Funprog CONVMYDATE(STRDATE)
Value Char STRDATE
Local Date TMPDATE
If instr(0, STRDATE, "/")>0
TMPDATE=gdat$(val(left$(STRDATE,2)),val(mid$(STRDATE,4,2)),val(right$(STRDATE,7)))
Else

TMPDATE=gdat$(val(mid$(STRDATE,7,2)),val(mid$(STRDATE,5,2)),val(mid$(STRDATE,1,4)))
Endif
End TMPDATE

Subprog REPLACECHARSPE(VALLM)
Variable Char VALLM
Gosub INIVALREP 

End

Subprog REPLACECHARSEARCH(VALLM)
Variable Char VALLM
Gosub INIVALREPSEARCH 

End



$INIVALREPSEARCH:
Local Char WN_VAL(255)
Local Char WN_CAR,WN_REP,WN_REP1
Local Integer WN_RG,WN_DEB
WN_VAL=VALLM
WN_CAR='"' : WN_REP='?'   : WN_REP1="&#34;"  : Gosub VALREPLACE 
Return

$INIVALREP:
Local Char WN_VAL(255)
Local Char WN_CAR,WN_REP,WN_REP1
Local Integer WN_RG,WN_DEB
WN_VAL=VALLM
WN_CAR='"' : WN_REP='\"'   : WN_REP1="&#34;"  : Gosub VALREPLACE 
Return

$VALREPLACE
Repeat
   WN_RG=instr(WN_DEB,VALLM,WN_CAR)
   If WN_RG
     WN_VAL=left$(VALLM,WN_RG-1)+WN_REP+right$(VALLM,WN_RG+1)
     VALLM=WN_VAL
     WN_DEB=WN_RG+len(WN_REP)
   Else
     WN_DEB=WN_RG+1
   Endif
  Until WN_RG=0
Return


$INI_PARAM_PAGINATION
# GESTION DES RESULTATS par pagination : 
Local Integer WNBREAD  : WNBREAD=0         # Request: Number of read records
Local Integer WSTART   : WSTART=0          # Request: Rank of first row to be returned (standard mode)
Local Integer WMAXREC                      # Request: Maximun number of records to be returned
Local Integer WTOTALCOUNT                  # Request: Total number of rows returned by request
Local Integer WACCTYP                      # Type of access: 0-standard  1-random
Local Integer WROWPOS                      # Current row in returned data tables
Local Integer WHASNEXT : WHASNEXT=0        # Output: Has next row (0: no more)
Local Integer WNBREC   : WNBREC=0          # Output: Number of returned records
Local Integer WRNDNB                       # Output: Number of records in random access (=0: standard access mode) 
Return
