##########################################################
##  ContrûÇle du RIB                                    ###
##########################################################
Subprog RIB(RIB,SPSTAT)
Variable Char    RIB()
Variable Integer SPSTAT

SPSTAT=0
If RIB="" 
     End
Elsif len(RIB)<>21
     SPSTAT=2 
     End
Endif

If mod(val(RIB),97) <> 1
 SPSTAT=1
Endif

End


