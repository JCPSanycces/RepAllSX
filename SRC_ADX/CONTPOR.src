##########################################################
##  ContrûÇle du Numûˋro TVA                             ###
##########################################################
Subprog TVA(TVA,SPSTAT)
Value Char TVA()
Variable Integer SPSTAT

SPSTAT=0
Local Char NUMTVA(10)
Local Integer ITOTAL , ICOUNT , ICHECK , IDIGIT

If left$(TVA,1)="P"
 NUMTVA=right$(TVA,3)
Else
 NUMTVA=TVA
Endif

If NUMTVA="" : Goto F_TVA : Endif

If len(NUMTVA) <> 9    : SPSTAT=2 : Goto F_TVA
Elsif len(NUMTVA) <> 9 : SPSTAT=2 : Goto F_TVA
Elsif num$(val(NUMTVA))<>NUMTVA : SPSTAT=2 : Goto F_TVA
Endif

For ICOUNT=1 To 8
 IDIGIT=val(mid$(NUMTVA,ICOUNT,1))
 ITOTAL += (10-ICOUNT) * IDIGIT
Next ICOUNT

ICHECK =mod(ITOTAL,11)
If ICHECK=0 | ICHECK=1 : ICHECK=0
Else ICHECK = 11-ICHECK
Endif

If val(right$(NUMTVA,9))<>ICHECK
 SPSTAT=1
Endif

$F_TVA
End
