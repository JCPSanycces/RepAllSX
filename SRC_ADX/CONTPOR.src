#####################################
## Referûˆncia SIBS  #################
#####################################
Subprog SIBS (BPCNUM,REFER)
Variable Char REFER
Variable Char BPCNUM

Local Decimal CALC
Local Integer WI(17)
Local Integer AI (17)
Local Integer P(17)
Local Integer I
Local Char VALOR

#BPCNUM="999999"

VALOR=format$("N0:9#",BPCNUM)
WI(0)=1   : AI(0)=1
WI(1)=10  : AI(1)=1
WI(2)=3   : AI(2)=val(mid$(VALOR,9,1))
WI(3)=30  : AI(3)=val(mid$(VALOR,8,1))
WI(4)=9   : AI(4)=val(mid$(VALOR,7,1))
WI(5)=90  : AI(5)=val(mid$(VALOR,6,1))
WI(6)=27  : AI(6)=val(mid$(VALOR,5,1))
WI(7)=76  : AI(7)=val(mid$(VALOR,4,1))
WI(8)=81  : AI(8)=val(mid$(VALOR,3,1))
WI(9)=34  : AI(9)=val(mid$(VALOR,2,1))
WI(10)=49 : AI(10)=val(mid$(VALOR,1,1))
WI(11)=5  : AI(11)=8
WI(12)=50 : AI(12)=1
WI(13)=15 : AI(13)=0
WI(14)=53 : AI(14)=0
WI(15)=45 : AI(15)=0
WI(16)=62 : AI(16)=1

For I=16 To 2 Step -1
 P(I)=AI(I)*WI(I)
Next I

CALC=98-(mod(sum(P),97))
REFER="100018000"+BPCNUM+num$(CALC)
End

#######################################################################
##   Mise û  jour de l'enregistrement DEB : echanges CEE              ##
##     traitement des arrondis                                       ##
##-------------------------------------------------------------------##
##  Flux :  11 Introduction Achats     12 Introduction Ventes        ##
##          21 Expedition   Achats     22 Expedition   Ventes        ##
#######################################################################
Subprog DEB (FLUX, SPSTAT)
Value    Integer FLUX
Variable Integer SPSTAT

Call DEB (FLUX, SPSTAT) From CONTNUM

End

