Subprog C_WK1MH1(VALEUR)
Variable Integer VALEUR
If VALEUR <> [M:CTR5]WK1MH1
 If ([M:CTR5]TAXCOD = "D0" or [M:CTR5]TAXCOD = "D1" or [M:CTR5]TAXCOD = "NT") and VALEUR < 2
  GMESSAGE = mess(00040,11800,1)
  GERR = 2
 Endif
Endif
