  Endif
End

Subprog AP_LIVMOR(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 and [M:CTR5]LIVLES = 2
    [M:CTR5]LIVLES = 1
    Affzo [M:CTR5]LIVLES
  Endif
  If VALEUR = 2 and [M:CTR5]WRKIUKLIVABD = 2
    [M:CTR5]WRKIUKLIVABD = 1
    Affzo [M:CTR5]WRKIUKLIVABD
  Endif
End

Subprog AP_LIVLES(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 and [M:CTR5]LIVMOR = 2
    [M:CTR5]LIVMOR = 1
    Affzo [M:CTR5]LIVMOR
  Endif
  If VALEUR = 2 and [M:CTR5]WRKIUKLIVABD = 2
    [M:CTR5]WRKIUKLIVABD = 1
    Affzo [M:CTR5]WRKIUKLIVABD
  Endif
End

Subprog AP_WRKIUKLIVABD(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 and [M:CTR5]LIVMOR = 2
    [M:CTR5]LIVMOR = 1
    Affzo [M:CTR5]LIVMOR
  Endif
  If VALEUR = 2 and [M:CTR5]LIVLES = 2
    [M:CTR5]LIVLES = 1
    Affzo [M:CTR5]LIVLES
  Endif
End

Subprog C_OCCPEN(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2
    Actzo [M:CTR5]RECBEROCCPEN, ANNPENAMTOCC
  Else
    Grizo [M:CTR5]RECBEROCCPEN, ANNPENAMTOCC
  Endif

End


