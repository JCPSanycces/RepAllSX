#MASHI - 2017-05-26 - JIRA X3-42004 - START
Subprog C_PRVFRM(VALEUR)
Variable Integer VALEUR
Local Integer SHOW
[L]SHOW=0
Call SHOW_HIDE_P45(SHOW)
Call SHOW_HIDE_STARTER(SHOW)
Call SHOW_HIDE_SECONDED(SHOW)
Call SHOW_HIDE_PERSIONER(SHOW)
[L]SHOW=1
Case VALEUR
  When 1
#MASHI X3-45749 2017-07-03 - START
    Raz [M:CTR5]STRDLC,EEACIT,EPMSCH,LIVMOR,LIVLES,WRKIUKLIVABD,RECBEROCCPEN,ANNPENAMTOCC
    Affzo [M:CTR5]STRDLC,EEACIT,EPMSCH,LIVMOR,LIVLES,WRKIUKLIVABD,RECBEROCCPEN,ANNPENAMTOCC
#MASHI X3-45749 2017-07-03 - END
    #None existing: nothing to show?
  When 2
    Call SHOW_HIDE_P45(SHOW)
  When 3
    Call SHOW_HIDE_STARTER(SHOW)
  When 4
    Call SHOW_HIDE_SECONDED(SHOW)
  When 5
    Call SHOW_HIDE_PERSIONER(SHOW)
Endcase

#MASHI X3-71143 2018-01-12 - START
#CHSUL X3-68434 2017-12-14 - START
If VALEUR <> 4 # Starter Seconded
  Effzo [M:CTR5]EEACIT, EPMSCH,LIVMOR,LIVLES,WRKIUKLIVABD
Endif
#CHSUL X3-68434 2017-12-14 - START
If VALEUR <> 5 # Starter Seconded
  Effzo [M:CTR5]OCCPEN, RECBEROCCPEN, ANNPENAMTOCC
Endif
#MASHI X3-71143 2018-01-12 - END

End

#P45: Starting declaration
Subprog SHOW_HIDE_P45(SHOW)
Variable Integer SHOW
  If SHOW #show
    Actzo [M:CTR5]STRDLC
  Else #hide
    Grizo [M:CTR5]STRDLC
  Endif
End

