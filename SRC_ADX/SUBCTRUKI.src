#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION

  Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "LIENS"         : Gosub LIENS
  When "MODIF"         : Gosub MODIF
  When "CREATION"      : Gosub CREATION
  When "FILTRE"        : Gosub FILTRE
  When "ANNULE"        : Gosub ANNULE
  When "VERIF_MOD"     : Gosub VERIF_MOD
  When "VERIF_CRE"     : Gosub VERIF_CRE
  When "STYLE"         : Gosub STYLE
  When "INICRE"        : Gosub INICRE
  Endcase

Return

$OUVRE
  If clalev([F:CTRUKI]) = 0 : Local File EMPLOCTRUKI [CTRUKI] : Endif
  If clalev([F:CUCA])=0   : Local File HRCPYUKCAR [CUCA]      : Endif
  If clalev([F:CTCA])=0   : Local File HRUKCTRCAR [CTCA]      : Endif
  #ANCOA - X-39010 - 2017-20-09 - START
  If clalev([F:CTRPEN])=0 : Local File HRUKCTRPEN [CTRPEN]    : Endif
  #ANCOA - X-39010 - 2017-20-09 - END
  #MASHI - X3-48189 - 2017-09-22 - START
  If clalev([F:CTRSTA])=0 : Local File HRUKCTRSTA [CTRSTA]    : Endif
  #MASHI - X3-48189 - 2017-09-22 - END
#MASHI - 2018-01-19 - JIRA X3-72296 - START
  If clalev([F:VEP])=0      : Local File VALEMP       [VEP]    : Endif
  If clalev([F:HSP])=0      : Local File HISTOPAYE    [HSP]    : Endif
#MASHI - 2018-01-19 - JIRA X3-72296 - END
Return

$LIENS
  If GCURLEG<>"BRI" : Return : Endif

  Read [CTRUKI]CTRUKI0 = [M]REFNUM; [M]CTRNUM; [M]CTRDAT
  If fstat = 0
    [M:CTR5] = [F:CTRUKI]
    [M:CTR1] = [F:CTRUKI]
    [M:CTR4] = [F:CTRUKI]
    [M:CTR8] = [F:CTRUKI] #ANCOA - X3-32717 - 2017-04-18
    [M:CTRPEN] = [F:CTRUKI] #ANCOA - X3-39010 - 2017-09-19
  Endif
  If num$([M:CTR5]TAXYEASTR) = "00/00/0000"
    If num$([M:CTR1]DATANC) <> "00/00/0000"
      [M:CTR5]TAXYEASTR = [M:CTR1]DATANC
      Else
      [M:CTR5]TAXYEASTR = [M:CTR0]CTRDAT
    Endif
  Endif
   #HEGES - X3-36172 - 2017-05-11 - START
nolign = 0
For [CTCA]CTCA0 Where [F:CTCA]REFNUM = [M:CTR0]REFNUM and [F:CTCA]CTRNUM = [M:CTR0]CTRNUM and [F:CTCA]CTRDAT = [M:CTR0]CTRDAT

  For [CUCA]CUCA0 Where [F:CUCA]CARREG = [F:CTCA]CARREG
    [M:CTR4]CARREG(nolign) = [F:CUCA]CARREG
    [M:CTR4]MAKCAR(nolign) = [F:CUCA]CARMAK
    [M:CTR4]CARMOD(nolign) = [F:CUCA]CARMOD
    [M:CTR4]FUETYP(nolign) = [F:CUCA]FUETYP
    [M:CTR4]EMISSI(nolign) = [F:CUCA]EMISSI
    [M:CTR4]LISPRI(nolign) = [F:CUCA]LISPRI
    [M:CTR4]DATREG(nolign) = [F:CUCA]DATREG
#MASHI - 2017-06-09 - JIRA X3-44323 - START
    [M:CTR4]DATAVA(nolign)    = [CTCA]DATAVA
    [M:CTR4]DATAVAEND(nolign) = [CTCA]DATAVAEND
    [M:CTR4]CASEQU(nolign)    = [CTCA]CASEQU
    [M:CTR4]FUEPRO(nolign)    = [CTCA]FUEPRO
    [M:CTR4]FUECASEQU(nolign) = [CTCA]FUECASEQU
    [M:CTR4]FUEPRODAT(nolign) = [CTCA]FUEPRODAT
    [M:CTR4]FUEPROWTH(nolign) = [CTCA]FUEPROWTH
#MASHI - 2017-06-09 - JIRA X3-44323 - END
#ANCOA - 2017-10-06 - X3-59030 START
    [M:CTR4]CARAMD(nolign) = [CTCA]CARAMD
#MASHI - X3-59030 2017-10-06 - START
    [M:CTR4]DATNEW(nolign) = [CTCA]DATNEW
    [M:CTR4]DATAMD(nolign) = [CTCA]DATAMD
#MASHI - X3-59030 2017-10-06 - END
#ANCOA - 2017-10-06 - X3-59030 END
    nolign+=1
  Next

Next
Assign "[M:CTR4]NBCAR" With nolign

#ANCOA - X3-39010 - 2017-20-09 START
# Load the pension data
nolign=0
For [F:CTRPEN]CTRPEN0
& Where [F:CTRPEN]REFNUM = [M:CTR0]REFNUM
&   and [F:CTRPEN]CTRNUM = [M:CTR0]CTRNUM
&   and [F:CTRPEN]CTRDAT = [M:CTR0]CTRDAT
  [M:CTRPEN]ORG(nolign)           = [F:CTRPEN]ORG
  [M:CTRPEN]PENJONDAT(nolign)     = [F:CTRPEN]PENJONDAT
  [M:CTRPEN]PENXITDAT(nolign)     = [F:CTRPEN]PENXITDAT
  [M:CTRPEN]EMEPRC(nolign)        = [F:CTRPEN]EMEPRC
  [M:CTRPEN]EMRPRC(nolign)        = [F:CTRPEN]EMRPRC
  [M:CTRPEN]AUTENR(nolign)        = [F:CTRPEN]AUTENR
  [M:CTRPEN]REA(nolign)           = [F:CTRPEN]REA
  [M:CTRPEN]WRKPOSENDDAT(nolign)  = [F:CTRPEN]WRKPOSENDDAT
  [M:CTRPEN]EJHPOSENDDAT(nolign)  = [F:CTRPEN]EJHPOSENDDAT
  [M:CTRPEN]OPTNOTRCV(nolign)     = [F:CTRPEN]OPTNOTRCV
  [M:CTRPEN]INFGIVDAT(nolign)     = [F:CTRPEN]INFGIVDAT
  [M:CTRPEN]OPTOUTNOTEMR(nolign)  = [F:CTRPEN]OPTOUTNOTEMR
  [M:CTRPEN]AUTENROPTOUT(nolign)  = [F:CTRPEN]AUTENROPTOUT
  [M:CTRPEN]ENTOPT(nolign)        = [F:CTRPEN]ENTOPT
  [M:CTRPEN]ENTOPTOUT(nolign)     = [F:CTRPEN]ENTOPTOUT
  [M:CTRPEN]NONEJHOPT(nolign)     = [F:CTRPEN]NONEJHOPT
  [M:CTRPEN]NONEJHOPTOUT(nolign)  = [F:CTRPEN]NONEJHOPTOUT
  nolign+=1
Next
Assign "[M:CTRPEN]NBRPEN" With nolign
#ANCOA - X3-39010 - 2017-20-09 END

#MASHI - X3-48189 - 2017-09-22 START
# Load the status data
nolign=0
For [F:CTRSTA]CTRSTA0
& Where [F:CTRSTA]REFNUM = [M:CTR0]REFNUM
&   and [F:CTRSTA]CTRNUM = [M:CTR0]CTRNUM
&   and [F:CTRSTA]CTRDAT = [M:CTR0]CTRDAT
  [M:CTRPEN]PENSTADAT(nolign)     = [F:CTRSTA]PENSTADAT
  [M:CTRPEN]PENSTA(nolign)        = [F:CTRSTA]PENSTA
  nolign+=1
Next
Assign "[M:CTRPEN]NBRSTA" With nolign
#MASHI - X3-48189 - 2017-09-22 END

#HEGES - X3-47321 - 2017-07-05 - START
If [M:CTR4]NBCTD = 0
  Filter [CTRUKI] Where [F:CTRUKI]REFNUM = [M:CTR0]REFNUM and [F:CTRUKI]CTRNUM = [M:CTR0]CTRNUM and [F:CTRUKI]CTRDAT = [M:CTR0]CTRDAT
  Assign "[M:CTR4]NBCTD" With rowcount([CTRUKI])
  Filter [CTRUKI]
Endif
#HEGES - X3-47321 - 2017-07-05 - END
Affzo [M:CTR4]
#HEGES - X3-36172 - 2017-05-11 - END
Return

$MODIF
$CREATION
  If GCURLEG<>"BRI" : Return : Endif

#JASMI - 2018-01-10 - X3-68312 - START
  If find(2,[M:CTR4]SETDEF(0..2))>0
    If [M:CTR4]EML(find(2,[M:CTR4]SETDEF(0..2))-1)<>''
      If clalev([F:AD_T]) = 0 : Local File EMPLOAD [AD_T] : Endif
      Read [F:AD_T]AD0 = [M:CTR0]REFNUM
      If !fstat
        If [F:AD_T]PFLEML<>[M:CTR4]EML(find(2,[M:CTR4]SETDEF(0..2))-1)
          [F:AD_T]PFLEML=[M:CTR4]EML(find(2,[M:CTR4]SETDEF(0..2))-1)
          Rewrite [F:AD_T]
          If fstat : GOK = 0 : Return : Endif
        Endif
      Endif
    Endif
  Endif

#JASMI - 2018-01-10 - X3-68312 - END

#FRLAA 2018-09-20 - X3-91919 - START

  If find(2,[M:CTR4]SETDEF(0..2))>0
    If [M:CTR4]EML(find(2,[M:CTR4]SETDEF(0..2))-1)<>''
      If clalev([F:ID_1]) = 0 : Local File EMPLOID [ID_1] : Endif
      Read [F:ID_1]ID0 = [M:CTR0]REFNUM
      If !fstat
        If [F:ID_1]EML<>[M:CTR4]EML(find(2,[M:CTR4]SETDEF(0..2))-1)
          [F:ID_1]EML=[M:CTR4]EML(find(2,[M:CTR4]SETDEF(0..2))-1)
          Rewrite [F:ID_1]
          If fstat : GOK = 0 : Return : Endif
        Endif
      Endif
    Endif
  Endif
#FRLAA 2018-09-20 - X3-91919 - END


  Delete [CTRUKI] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM & CTRDAT = [M]CTRDAT
  If fstat = 1
    GOK = -1
    GLOCK = "$CTRUKI" - [M]CTRNUM - [M]REFNUM - [M]CTRDAT
    Return
  Elsif fstat>5
    GOK = 0
    Call RSTA("CTRUKI", [M]REFNUM - [M]CTRNUM - [M]CTRDAT) From GLOCK
    Return
  Endif

  [F:CTRUKI] = [M:CTR0]
  [F:CTRUKI] = [M:CTR5]
  [F:CTRUKI] = [M:CTR1]#FRLAA - 2015-03-25 - REQUIREMENT 104631 US 3195
  [F:CTRUKI] = [M:CTR4]
  [F:CTRUKI] = [M:CTR8] #ANCOA - X3-32717 - 2017-04-18
  [F:CTRUKI] = [M:CTRPEN] #ANCOA - X3-39010 - 2017-09-19
#MASHI 2017-12-08 X3-59665 START
  If [F:CTRUKI]RTIPAYIDT <> [M:CTR0]CTRNUM
    [F:CTRUKI]RTIPAYIDT = [M:CTR0]CTRNUM
#MASHI 2018-01-12 X3-68610 START
    [F:CTRUKI]NEWSTRDAT = [0/0/0]
    [F:CTRUKI]OLDPAYDAT = [0/0/0]
#MASHI 2018-01-12 X3-68610 END
    [F:CTRUKI]IRRDAT = [0/0/0]
    [F:CTRUKI]IRRFLG = 0
#MASHI 2018-01-12 X3-70780 END
#MASHI 2018-01-10 X3-70780 END
    [M:CTR5]RTIPAYIDT = [M:CTR0]CTRNUM
    Affzo [M:CTR5]RTIPAYIDT
  Endif
#MASHI 2017-12-08 X3-59665 END
  Write [CTRUKI]
  If fstat
    GOK = 0 : Return
  Endif

Return

$ANNULE
 Delete [CTRUKI] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM & CTRDAT = [M]CTRDAT
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("CTRUKI",[M:CTR0]CTRNUM-num$([M:CTR0]CTRDAT)) From GLOCK : Return
 Endif

Return

$FILTRE
  If GCURLEG<>"BRI" : Return : Endif

  If clalev([F:CTRUKI]) = 0 : Local File EMPLOCTRUKI [CTRUKI] : Endif
  If [F:HRCTR]REFNUM <> [F:CTRUKI]REFNUM or [F:HRCTR]CTRNUM <> [F:CTRUKI]CTRNUM or [F:HRCTR]CTRDAT <> [F:CTRUKI]CTRDAT
    If dim([M]CTRNUM)>0 & dim([M]REFNUM)>0 & dim([M]CTRDAT)>0 Then
      Read [CTRUKI]CTRUKI0 = [M]REFNUM; [M]CTRNUM; [M]CTRDAT
    Endif
  Endif

Return


$VERIF_CRE
$VERIF_MOD
#CHSUL - 2018-01-18 - X3-71635 - START
   GOK = func VALIDATE_DIRECTOR_STATUS_START_DATE([M:CTR5]DIRSTA, [M:CTR5]DIRSTASTR, [M:CTR5]TAXYEAEND)
   If GOK=0 Then: zonsui = "[M:CTR5]DIRSTASTR": Return: Endif
#CHSUL - 2018-01-18 - X3-71635 - END

 If func DIVPAYE.IS_BRI_LEG(GCURLEG)
  Local Integer ADDCNT
  Local Integer PSTADD, RESADD, WRKADD, DEFCNT
  [L]PSTADD=0 : [L]RESADD=0 : [L]WRKADD=0 : [L]DEFCNT=0

    For [L]ADDCNT=0 To dim([M:CTR4]PIO)-1
      Case [M:CTR4]TYP([L]ADDCNT)
       When 1 : [L]RESADD+=1
       When 2 : [L]PSTADD+=1
       When 3 : [L]WRKADD+=1
      Endcase
      If [M:CTR4]SETDEF([L]ADDCNT) = 2 Then
        [L]DEFCNT+=1
      Endif
    Next

    If ([L]RESADD>1) or ([L]PSTADD>1) or ([L]WRKADD>1) Then
      GMESSAGE = mess(27,11662,1)
      GOK=0
      #mkstat=2
      Return
    Endif

    If ([L]DEFCNT<>1) Then
      GMESSAGE = mess(28,11662,1)
      GOK=0
      #mkstat=2
      Return
    Endif
Endif

