Subprog C_DATAVA(VALEUR)
Variable Date    VALEUR
  If num$([M:CTR4]DATAVAEND) <> "00/00/0000"
    If VALEUR > [M:CTR4]DATAVAEND
      GMESSAGE = mess(00104,00119,1)
      mkstat = 2
    Endif
  Endif

  If func CAR_VALUE_AMENDED(num$(VALEUR), num$([M:CTR4]DATAVA(nolign-1)),nolign-1) :  Endif

End

Subprog C_DATAVAEND(VALEUR)
Variable Date    VALEUR
  If num$([M:CTR4]DATAVA) <> "00/00/0000"
    If VALEUR < [M:CTR4]DATAVA
      GMESSAGE = mess(00104,00119,1)
      mkstat = 2
    Endif
  Endif

  If func CAR_VALUE_AMENDED(num$(VALEUR), num$([M:CTR4]DATAVAEND(nolign-1)),nolign-1) :  Endif
End

Subprog C_FUEPRODAT(VALEUR)
Variable Date    VALEUR
  If num$([M:CTR4]FUEPROWTH) <> "00/00/0000"
    If VALEUR > [M:CTR4]FUEPROWTH
      GMESSAGE = mess(00104,00119,1)
      mkstat = 2
    Endif
  Endif
  If num$([M:CTR4]DATAVA) <> "00/00/0000" and num$([M:CTR4]DATAVAEND) <> "00/00/0000"
    If VALEUR < [M:CTR4]DATAVA or VALEUR > [M:CTR4]DATAVAEND
      GMESSAGE = mess(39,11800,1)
      mkstat = 2
    Endif
  Endif
  If func CAR_VALUE_AMENDED(num$(VALEUR), num$([M:CTR4]FUEPRODAT(nolign-1)),nolign-1) :  Endif
End

Subprog C_FUEPROWTH(VALEUR)
Variable Date    VALEUR
  If num$([M:CTR4]FUEPRODAT) <> "00/00/0000"
    If VALEUR < [M:CTR4]FUEPRODAT
      GMESSAGE = mess(00104,00119,1)
      mkstat = 2
    Endif
  Endif
  If num$([M:CTR4]DATAVA) <> "00/00/0000" and num$([M:CTR4]DATAVAEND) <> "00/00/0000"
    If VALEUR < [M:CTR4]DATAVA or VALEUR > [M:CTR4]DATAVAEND
      GMESSAGE = mess(39,11800,1)
      mkstat = 2
    Endif
  Endif
  If func CAR_VALUE_AMENDED(num$(VALEUR), num$([M:CTR4]FUEPROWTH(nolign-1)),nolign-1) :  Endif
End

