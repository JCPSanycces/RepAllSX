Subprog C_FUEPRO(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2
    Actzo [M:CTR4]FUECASEQU, FUEPRODAT, FUEPROWTH
  Else
    Grizo [M:CTR4]FUECASEQU, FUEPRODAT, FUEPROWTH
  Endif
  If func CAR_VALUE_AMENDED(num$(VALEUR), num$([M:CTR4]FUEPRO(nolign-1)),nolign-1) :  Endif
