#MASHI - 2017-06-21 - JIRA X3-35020 - START
Subprog C_NICAT(VALEUR)
Variable Char    VALEUR()
Read [ID]ID0 = [M:CTR0]REFNUM
Call NI_CATEGORY_VALIDATION([M:CTR1]PERCOD, [F:ID]DATBRN, [F:ID]SEX, VALEUR, [M:CTR5]NICAT)
End

Subprog NI_CATEGORY_VALIDATION(FREQUENCY, DOB, SEX, NICAT, OLDNICAT)
Value Char FREQUENCY, NICAT, OLDNICAT
Value Date DOB
Value Integer SEX

Local Date RUNDAT, RETDAT
Local Integer VALIDAGE, VALIDMOVE: VALIDAGE = 1: VALIDMOVE = 1

GMESSAGE = ""
RUNDAT=func UK_FUNCTIONS.GETNEXTPAYDATE(FREQUENCY, date$)
RETDAT=func RETIREMENTDATE(DOB, SEX)
If [L]RUNDAT >= [L]RETDAT and NICAT <> "C" Then
 VALIDAGE = 0
Else
  VALIDAGE = func SUBCTRUKI.NI_VALIDATE_AGE([L]RUNDAT, [L]RETDAT, DOB, SEX, NICAT)
Endif
VALIDMOVE = func SUBCTRUKI.NI_VALIDATE_MOVEMENT(OLDNICAT, NICAT)

If VALIDMOVE = 0 and VALIDAGE = 0 Then
  GMESSAGE = mess(00062,11800,1)
Else
  If VALIDAGE = 0 Then
    GMESSAGE = mess(00061,11800,1)
  Else
    If VALIDMOVE = 0 Then
      GMESSAGE = mess(00060,11800,1)
    Endif
  Endif
Endif
If GMESSAGE <> "" Then: GERR = 1: Endif

End

Funprog NI_VALIDATE_AGE(RUNDAT, RETDAT, DOB, SEX, NICAT)
Value Date RUNDAT, RETDAT, DOB
Value Integer SEX
Value Char NICAT
Local Integer RESULT
  If NICAT = "": End 1: Endif

  Case NICAT
    When "B" : RESULT = func SUBCTRUKI.NI_VALIDATE_CAT_B(RUNDAT, RETDAT, DOB, SEX)
    When "C" : RESULT = ([L]RUNDAT > [L]RETDAT)
    When "H" : RESULT = func CALCULATEAGE(DOB, RUNDAT) < 25
    When "J" : RESULT = func CALCULATEAGE(DOB, RUNDAT) >= 21
    When "M" : RESULT = func CALCULATEAGE(DOB, RUNDAT) < 21
    When "X" : RESULT = func CALCULATEAGE(DOB, RUNDAT) < 16
    When "Z" : RESULT = func CALCULATEAGE(DOB, RUNDAT) < 21
    When Default: RESULT = 1
  Endcase
End RESULT

Funprog NI_VALIDATE_CAT_B(RUNDAT, RETDAT, DOB, SEX)
Value Date RUNDAT, RETDAT, DOB
Value Integer SEX
Local Integer FEMALE : FEMALE = 2
Local Date REFDAT
  If SEX <> FEMALE Then
    GMESSAGE = mess(00060,11800,1)
    End 1
  Endif
  REFDAT = gdat$(06, 04, 1961)
End (DOB < REFDAT)

Funprog NI_VALIDATE_MOVEMENT(OLDNICAT, NEWNICAT)
Value Char OLDNICAT, NEWNICAT
Local Integer RESULT
  If OLDNICAT = NEWNICAT: End 1: Endif

  Case OLDNICAT
    When "A" : RESULT = instr(0, "BCMX", NEWNICAT) > 0
    When "B" : RESULT = instr(0, "ACMX", NEWNICAT) > 0
    When "C" : RESULT = 0
    When "H" : RESULT = instr(0, "ABMX", NEWNICAT) > 0
    When "J" : RESULT = instr(0, "Z", NEWNICAT) > 0
    When "M" : RESULT = instr(0, "ABX", NEWNICAT) > 0
    When "X" : RESULT = instr(0, "ABCHM", NEWNICAT) > 0
    When "Z" : RESULT = instr(0, "J", NEWNICAT) > 0
    When Default: RESULT = instr(0, "ABCHJMXZ", NEWNICAT) > 0
  Endcase
End RESULT

Funprog CALCULATEAGE(DATBRN, PAYDAT)
Value Date DATBRN
Value Date PAYDAT
Local Integer AGE
AGE = ((year(PAYDAT) * 12) - (year(DATBRN) * 12)) + (month(PAYDAT) - month(DATBRN))
If month(PAYDAT) = month(DATBRN)
 If  day(PAYDAT) < day(DATBRN)
      AGE = AGE - 1
 Endif
Endif
AGE  = fix(AGE / 12)
End AGE

Funprog RETIREMENTDATE(DATBRN, SEX)
Value Date DATBRN
Value Integer SEX # 1 Male 2 Female
Local Date RETDAT
Local Integer WKYEAR1, WKYEAR2, WKYEAR3, WKMON1, WKMON2, WKMON3

 If DATBRN <> [0/0/0]
  If SEX = 2 and DATBRN < [06/04/1950]
   RETDAT = gdat$(day(DATBRN),month(DATBRN),year(DATBRN) + 60)
  Else
   If SEX = 2 and DATBRN < [06/04/1953]
    WKYEAR2=0
    WKYEAR1=year(DATBRN) - 1950
    WKMON1=month(DATBRN)
    If day(DATBRN) < 6
     WKMON1=WKMON1 - 1
    Endif
    WKMON1=(WKMON1 - 3) + (WKYEAR1 * 12)
    WKMON2= (WKMON1 * 2) - 1
    If WKMON2 > 12
      WKYEAR2 = fix(WKMON2 / 12)
      WKMON2 = WKMON2 - (WKYEAR2 * 12)
    Endif
    WKYEAR3 = 2010 + WKYEAR2
    WKMON3 = WKMON2 + 4
    If WKMON3 > 12
     WKYEAR3 = WKYEAR3 + 1
     WKMON3 = WKMON3 - 12
    Endif
    RETDAT = gdat$(6,WKMON3,WKYEAR3)
   Else
    If SEX = 2 and DATBRN < [06/12/1953]
     WKYEAR2=0
     WKYEAR1=year(DATBRN) - 1952
     WKMON1=month(DATBRN)
     If day(DATBRN) < 6
      WKMON1=WKMON1 - 1
     Endif
     WKMON1=(WKMON1 - 3) + (WKYEAR1 * 12)
     WKMON2= (WKMON1 * 4) - 1
     If WKMON2 > 12
       WKYEAR2 = fix(WKMON2 / 12)
       WKMON2 = WKMON2 - (WKYEAR2 * 12)
     Endif
     WKYEAR3 = 2012 + WKYEAR2
     WKMON3 = WKMON2 + 4
     If WKMON3 > 12
      WKYEAR3 = WKYEAR3 + 1
      WKMON3 = WKMON3 - 12
     Endif
     RETDAT = gdat$(6,WKMON3,WKYEAR3)
    Else
     If SEX = 1 and DATBRN < [06/12/1953]
      RETDAT = gdat$(day(DATBRN),month(DATBRN),year(DATBRN) + 65)
     Else
      If DATBRN < [06/10/1954]
       WKYEAR2=0
       WKYEAR1=year(DATBRN) - 1952
       WKMON1=month(DATBRN)
       If day(DATBRN) < 6
        WKMON1=WKMON1 - 1
       Endif
       WKMON1=(WKMON1 - 11) + (WKYEAR1 * 12)
       WKMON2= (WKMON1 * 2) - 1
       If WKMON2 > 12
        WKYEAR2 = fix(WKMON2 / 12)
        WKMON2 = WKMON2 - (WKYEAR2 * 12)
       Endif
       WKYEAR3 = 2017 + WKYEAR2
       WKMON3 = WKMON2 + 2
       If WKMON3 > 12
        WKYEAR3 = WKYEAR3 + 1
        WKMON3 = WKMON3 - 12
       Endif
       RETDAT = gdat$(6,WKMON3,WKYEAR3)
      Else
       If SEX = 1 and DATBRN < [06/12/1960]
        RETDAT = gdat$(day(DATBRN),month(DATBRN),year(DATBRN) + 66)
       Else
        RETDAT = gdat$(day(DATBRN),month(DATBRN),year(DATBRN) + 66)
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
End RETDAT
#MASHI - 2017-06-21 - JIRA X3-35020 - END

#ANCOA - X3-39010 - 2017-20-09 - START
Subprog C_PENJONDAT(VALEUR)
Variable Date    VALEUR
  #Pension join date cannot be before the employee's date of birth
  If VALEUR < [F:ID]DATBRN
    GMESSAGE=mess(00048,11800,1)
    mkstat=2
  Endif
End

Subprog C_PENXITDAT(VALEUR)
Variable Date    VALEUR
  #Pension leave date cannot be before pension join date
  If VALEUR <> [0/0/0] & VALEUR < [M:CTRPEN]PENJONDAT(nolign-1)
    GMESSAGE=mess(00049,11800,1)
    mkstat=2
  Endif
End

Subprog C_ORG(VALEUR)
  Variable Char    VALEUR()
  Local Decimal DEFAULT_PERCENTAGES(2)

  # Make sure the employee is a member of the pension scheme
  If func EMPLOYEE_IS_A_MEMBER(VALEUR, [F:HRCTR]CTRNUM, [F:HRCTR]REFNUM, [F:ID]CPY) <> 1
    GMESSAGE=mess(00050,11800,1) : mkstat=2 : End
  Endif

  #Make sure the organisation is assigned to a contribution fund
  If func ISVALID_CONTRIBUTION_FUND(VALEUR,[F:HRCTR]CTRNUM,[F:ID]REFNUM,[F:HRCTR]ETRFCY,
&                                  [F:ID]CPY,GCURLEG,DEFAULT_PERCENTAGES(0),DEFAULT_PERCENTAGES(1)) <> ""
    #If organisation has changed then update the employee/employer percentages
    #  to the default for the new organisation
    If VALEUR <> [M:CTRPEN]ORG(nolign-1)
       Call SET_PENSION_DEFAULTS(nolign, DEFAULT_PERCENTAGES(0), DEFAULT_PERCENTAGES(1), [M:CTR1]PERCOD, [M:CTR0]CPY, [M:CTR1]DATANC)
    Endif
  Else
    GMESSAGE=mess(00051,11800,1) : mkstat=2 : End
  Endif
End

#**
#* Sets default values for pension record, employee/employer percentage and postponement end date
#*
#* @param LINE_NUMBER Grid line number
#* @param DEF_EME_PERCENT Default employee percentage
#* @param DEF_EMR_PERCENT Default employer percentage
#* @param PERIOD_CODE Pay/extraction Period code
#* @param COMPANY Company code
#* @param START_DATE Employee start date
#*!
Subprog SET_PENSION_DEFAULTS (LINE_NUMBER, DEF_EME_PERCENT, DEF_EMR_PERCENT, PERIOD_CODE, COMPANY, START_DATE)
  Value Integer LINE_NUMBER
  Value Char PERIOD_CODE, COMPANY
  Value Decimal DEF_EME_PERCENT, DEF_EMR_PERCENT
  Value Date START_DATE

  Local Integer POSTPONE_PERIODS, PAY_FREQUENCY

  [M:CTRPEN]EMEPRC(LINE_NUMBER-1) = DEF_EME_PERCENT
  [M:CTRPEN]EMRPRC(LINE_NUMBER-1) = DEF_EMR_PERCENT
  Affzo [M:CTRPEN]EMEPRC(LINE_NUMBER-1), EMRPRC(LINE_NUMBER-1)

  [L]PAY_FREQUENCY = func UK_FUNCTIONS.GET_PAY_FREQUENCY(PERIOD_CODE)
  [L]POSTPONE_PERIODS = func UK_FUNCTIONS_AE.GET_POSTPONEMENT_PERIODS([L]PAY_FREQUENCY,COMPANY)
  [M:CTRPEN]WRKPOSENDDAT(LINE_NUMBER-1) = func UK_FUNCTIONS_AE.CALC_DEFAULT_POSTPONEMENT_END(START_DATE, [L]POSTPONE_PERIODS,[L]POSTPONE_PERIODS,[L]PAY_FREQUENCY)
  Affzo [M:CTRPEN]WRKPOSENDDAT(LINE_NUMBER-1)

End

#**
#* Checks whether an employee is a member of the pension scheme
#*
#* @param ORGANISATION Organisation/Pension scheme code to check for membership
#* @param CONTRACT Contract number to use for checking
#* @param EMPLOYEE Employee reference to use for checking
#* @return Returns 1 If the employee is a member, 0 if they are not
#*!
Funprog EMPLOYEE_IS_A_MEMBER(ORGANISATION, CONTRACT, EMPLOYEE, COMPANY)
  Value Char ORGANISATION(), CONTRACT(), EMPLOYEE(), COMPANY()
  Local Integer RETVAL : RETVAL = 0

  #Check if employee is a member of the selected organization as the contract level
  If clalev([F:ORA]) = 0 : Local File ORGAFFIL [ORA] : Endif
  For [ORA]ORA0 Where [ORA]LEV=6 and [ORA]CTR=CONTRACT and [ORA]ORG=ORGANISATION
    RETVAL=1
  Next

  #Check if employee is a member of the selected organization as the employee level
  For [ORA]ORA0 Where [ORA]LEV=5 and [ORA]REFNUM=EMPLOYEE and [ORA]ORG=ORGANISATION
    RETVAL=1
  Next

  #Check if employee is a member of the selected organization at the company level
  For [ORA]ORA0 Where [ORA]LEV=3 and [ORA]CPY=COMPANY
    RETVAL=1
  Next
End RETVAL

#**
#* <pre>Checks whether the organisation is setup as a valid contribution fund.
#* The contribution fund can be defined at various different levels: Contract; Employee; Site; Company; Legislation</pre>
#* @param ORGANISATION Organisation code we are checking to decide if it is setup as a contribution fund
#* @param CONTRACT Contract number to use for checking
#* @param EMPLOYEE Employee reference to use for checking
#* @param SITE Site code to use for checking
#* @param COMPANY Company code to use for checking
#* @param LEGISLATION Legislation code to use for checking
#* @param EE_PERCENTAGE Output parameter for the employee percentage, 0.0 if the organisation is invalid
#* @param ER_PERCENTAGE Output parameter for the employer percentage 0.0 if the organsation is invalid
#* @return <pre>Empty string if organisation is not setup as a fund, or if setup then one of:
#* "Contract"; "Employee"; "Site"; "Company"; "Legislation"
#* Depending on which level the organisation is defined against</pre>
#*!
Funprog ISVALID_CONTRIBUTION_FUND(ORGANISATION, CONTRACT, EMPLOYEE, SITE, COMPANY, LEGISLATION, EE_PERCENTAGE, ER_PERCENTAGE)
  Value Char ORGANISATION(), CONTRACT(), EMPLOYEE(), SITE(), COMPANY(), LEGISLATION()
  Variable Decimal EE_PERCENTAGE, ER_PERCENTAGE
  Local Char LEVELFOUND(10)

  If clalev([F:PCA]) = 0 : Local File CAISSE [PCA] : Endif

  #find caisse [PCA] where lev=contract and leg=bri and ctr=CONTRACT
  For [PCA]PCA0 Where [F:PCA]LEV = 6 and [F:PCA]LEG = LEGISLATION and [F:PCA]CTR = CONTRACT
    If find(ORGANISATION,[F:PCA]ORG) > 0
      LEVELFOUND = "Contract"
      EE_PERCENTAGE = [F:PCA]DEFEMEPRC(find(ORGANISATION,[F:PCA]ORG)-1)
      ER_PERCENTAGE = [F:PCA]DEFEMRPRC(find(ORGANISATION,[F:PCA]ORG)-1)
    Endif
  Next

  #find caisse [PCA] where lev=employee and leg=bri and emp=EMPLOYEE
  If LEVELFOUND = ""
    For [PCA]PCA0 Where [F:PCA]LEV = 5 and [F:PCA]LEG = LEGISLATION and [F:PCA]EMP = EMPLOYEE
      If find(ORGANISATION,[F:PCA]ORG) > 0
        LEVELFOUND = "Employee"
        EE_PERCENTAGE = [F:PCA]DEFEMEPRC(find(ORGANISATION,[F:PCA]ORG)-1)
        ER_PERCENTAGE = [F:PCA]DEFEMRPRC(find(ORGANISATION,[F:PCA]ORG)-1)
      Endif
    Next
  Endif

  #find caisse [PCA] where lev=site and leg=bri and fcy=SITE
  If LEVELFOUND = ""
    For [PCA]PCA0 Where [F:PCA]LEV = 4 and [F:PCA]LEG = LEGISLATION and [F:PCA]FCY = SITE
      If find(ORGANISATION,[F:PCA]ORG) > 0
        LEVELFOUND = "Site"
        EE_PERCENTAGE = [F:PCA]DEFEMEPRC(find(ORGANISATION,[F:PCA]ORG)-1)
        ER_PERCENTAGE = [F:PCA]DEFEMRPRC(find(ORGANISATION,[F:PCA]ORG)-1)
      Endif
    Next
  Endif

  #find caisse [PCA] where lev=company and leg=bri and cpy=COMPANY
  If LEVELFOUND = ""
    For [PCA]PCA0 Where [F:PCA]LEV = 3 and [F:PCA]LEG = LEGISLATION and [F:PCA]CPY = COMPANY
      If find(ORGANISATION,[F:PCA]ORG) > 0
        LEVELFOUND = "Company"
        EE_PERCENTAGE = [F:PCA]DEFEMEPRC(find(ORGANISATION,[F:PCA]ORG)-1)
        ER_PERCENTAGE = [F:PCA]DEFEMRPRC(find(ORGANISATION,[F:PCA]ORG)-1)
      Endif
    Next
  Endif

  #find caisse [PCA] where lev=legislation and leg=bri
  If LEVELFOUND = ""
    For [PCA]PCA0 Where [F:PCA]LEV = 1 and [F:PCA]LEG = LEGISLATION
      If find(ORGANISATION,[F:PCA]ORG) > 0
        LEVELFOUND = "Legislation"
        EE_PERCENTAGE = [F:PCA]DEFEMEPRC(find(ORGANISATION,[F:PCA]ORG)-1)
        ER_PERCENTAGE = [F:PCA]DEFEMRPRC(find(ORGANISATION,[F:PCA]ORG)-1)
      Endif
    Next
  Endif
End LEVELFOUND
#ANCOA - X3-39010 - 2017-20-09 - END

#ANCOA - X3-59030 2017-10-06 - START
#If the values are not the same then car amended flag will be set to yes
Funprog CAR_VALUE_AMENDED (OLD_VALUE, NEW_VALUE,LINE_NUMBER)
  Value Char OLD_VALUE
  Value Char NEW_VALUE
  Value Integer LINE_NUMBER
  Local Integer RETVAL

  If OLD_VALUE <> NEW_VALUE
#MASHI - X3-59030 2017-10-06 - START
    If [M:CTR4]DATNEW = [0/0/0] or [M:CTR4]DATNEW = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
      [M:CTR4]CARAMD(LINE_NUMBER) = 1
      Affzo [M:CTR4]CARAMD(LINE_NUMBER)
    Else
      [M:CTR4]CARAMD(LINE_NUMBER) = 2
      [M:CTR4]DATAMD(LINE_NUMBER) = [0/0/0]
      Affzo [M:CTR4]DATAMD(LINE_NUMBER)
      Affzo [M:CTR4]CARAMD(LINE_NUMBER)
    Endif
#MASHI - X3-59030 2017-10-06 - END
  Endif
End RETVAL

Subprog C_FUECASEQU(VALEUR)
Variable Decimal VALEUR
  If func CAR_VALUE_AMENDED(num$(VALEUR), num$([M:CTR4]FUECASEQU(nolign-1)),nolign-1) :  Endif
End

Subprog C_CASEQU(VALEUR)
Variable Decimal VALEUR
  If func CAR_VALUE_AMENDED(num$(VALEUR), num$([M:CTR4]CASEQU(nolign-1)),nolign-1) :  Endif
End
#ANCOA - 2017-10-06 - X3-59030 END

#CHSUL - 2017-12-13 - X3-68434 START
Funprog VALIDATE_EMPLOYEE_PROVIDED(PROVIDED, LESS_THAN_183, MORE_THAN_183, WORKING_IN_OUT)
  Value Integer PROVIDED, LESS_THAN_183, MORE_THAN_183, WORKING_IN_OUT

  VALID = 1
  INVALID = 0

  # If not Starter Seconded then exit early (although values remain)
  If PROVIDED <> 4 Then
    End VALID
  Endif

  # Value of 1 is not checked, value of 2 is checked
  If LESS_THAN_183 = 1 and MORE_THAN_183 = 1 and WORKING_IN_OUT = 1 Then
    End INVALID
  Endif

End VALID
#CHSUL - 2017-12-13 - X3-68434 END

#CHSUL - 2018-01-18 - X3-71635 START
Funprog VALIDATE_DIRECTOR_STATUS_START_DATE(DIRECTOR_STATUS, DIRECTOR_START_DATE, TAX_YEAR_END)
  Value Integer DIRECTOR_STATUS
  Value Date DIRECTOR_START_DATE, TAX_YEAR_END
  VALID = 1
  INVALID = 0

  # Ignore if Non director
  If DIRECTOR_STATUS = 1: End VALID: Endif
  # Ignore if tax year end empty (new record)
  If num$(TAX_YEAR_END) = "00/00/0000": End VALID: Endif
  # Directors status start date cannot be empty
  If num$(DIRECTOR_START_DATE) = "00/00/0000"
    GMESSAGE=mess(00053,11800,1)
    End INVALID
  Endif
  # Directors status start date must be less than tax year end
  If DIRECTOR_START_DATE > TAX_YEAR_END
    GMESSAGE=mess(00054,11800,1)
    End INVALID
  Endif
End VALID
#CHSUL - 2018-01-18 - X3-71635 END

#ALHAR - 30/01/18 X3-74577 - start
Funprog SETVARIABLE(VCOD,VSTRDAT)
Value Char VCOD
Value Date VSTRDAT
Local Decimal RETVAL : RETVAL = 0
  If clalev([F:VLA1])=0 : Local File VALEUR     [VLA1]  : Endif
  Filter [VLA1] Where VARCOD = VCOD & DAT <= VSTRDAT & LEG = GCURLEG
Read [VLA1] Last
  Filter [VLA1]
  If !fstat
    RETVAL = [VLA1]VARVAL
  Endif
End RETVAL
#ALHAR - 30/01/18 X3-74577 - end

#CHSUL - 2018-01-27 - X3-77780 START
Funprog STUDENT_LOAN()
End [M:CTR5]STULOA = 2

Subprog C_STULOATYP(VALEUR)
  Variable Integer VALEUR
  If func VALIDATE_STUDENT_LOAN_TYPE(VALEUR) = 0: mkstat=2: Endif
End

Subprog C_STULOADATEND(VALEUR)
Variable Date VALEUR
  If func VALIDATE_STUDENT_LOAN_END_DATE([M:CTR5]STULOADAT, VALEUR) = 0: mkstat=2: Endif
End

Funprog VALIDATE_STUDENT_LOAN_TYPE(PLAN_TYPE)
  Value Integer PLAN_TYPE
  Local Integer PLAN_TYPE_NONE: PLAN_TYPE_NONE = 1
  VALID = 1
  INVALID = 0

  If func STUDENT_LOAN() <> 1: End VALID: Endif
  If PLAN_TYPE = PLAN_TYPE_NONE
    GERR=1
    GMESSAGE=mess(57,11800,1)
    End INVALID
  Endif
End VALID

Funprog VALIDATE_STUDENT_LOAN_END_DATE(START_DATE, END_DATE)
  Value Date START_DATE, END_DATE
  VALID = 1
  INVALID = 0

  If func STUDENT_LOAN() <> 1: End VALID: Endif
  If START_DATE = [0/0/0] Then: End VALID: Endif
  If END_DATE = [0/0/0] Then: End VALID: Endif

  If END_DATE < START_DATE
    GERR=1
    GMESSAGE=mess(59,11800,1)
    End INVALID
  Endif
End VALID
#CHSUL - 2018-01-27 - X3-77780 END

