#HEGES - X3-36172 - 2017-05-10 - START
Subprog C_CARREG(VALEUR)
Variable Char    VALEUR()
Local Integer FOUND
If [M:CTR4]CARREG(nolign-1) <> VALEUR
  FOUND = find(VALEUR,[M:CTR4]CARREG(0..[M:CTR4]NBCAR-1))
  If FOUND = 0
    If func CAR_VALUE_AMENDED(num$(VALEUR), num$([M:CTR4]CARREG(nolign-1)),nolign-1) :  Endif
    Filter [CUCA] Where [F:CUCA]CARREG = VALEUR
    Read  [CUCA]CUCA0 First
    [M:CTR4]CARREG(nolign-1) = [F:CUCA]CARREG
    [M:CTR4]MAKCAR(nolign-1) = [F:CUCA]CARMAK
    [M:CTR4]CARMOD(nolign-1) = [F:CUCA]CARMOD
    [M:CTR4]FUETYP(nolign-1) = [F:CUCA]FUETYP
    [M:CTR4]EMISSI(nolign-1) = [F:CUCA]EMISSI
    [M:CTR4]LISPRI(nolign-1) = [F:CUCA]LISPRI
#MASHI - 2017-06-09 - JIRA X3-44323 - START
#    [M:CTR4]CASEQU(nolign-1) = [F:CUCA]CASEQU
    [M:CTR4]DATREG(nolign-1) = [F:CUCA]DATREG
#    [M:CTR4]DATAVA(nolign-1) = [F:CUCA]DATAVA
#    [M:CTR4]FUEPRO(nolign-1) = [F:CUCA]FUEPRO
#    [M:CTR4]PVTPRO(nolign-1) = [F:CUCA]PVTPRO
#MASHI - 2017-06-09 - JIRA X3-44323 - END
    Filter [CUCA]
    Assign "[M:CTR4]NBCAR" With NBCAR

  Else
    Raz [M:CTR4]CARREG(nolign-1)
      GERR=1
      GMESSAGE = mess(24,123,1)-num$(FOUND)
      mkstat=2
  Endif
  Affzo [M:CTR4]
Endif
End
#HEGES - X3-36172 - 2017-05-10 - END

#ANCOA - X3-39010 - 2017-20-09 - START
$LINKEDTABLES
  Gosub LINKCARBEN
  Gosub LINKPENSION
#MASHI - X3-48189 - 2017-09-22 START
  Gosub LINKSTATUS
#MASHI - X3-48189 - 2017-09-22 End
Return

# Save the pension details, does this by deleting the current pension records and recreating them from the grid
$LINKPENSION

  #setup a transation and delete the current pension records
  Call DEBTRANS From GLOCK
  [V]GOK = 1

  Delete [F:CTRPEN]
&  Where [F:CTRPEN]REFNUM = [M:CTR0]REFNUM
&    and [F:CTRPEN]CTRNUM = [M:CTR0]CTRNUM
&    and [F:CTRPEN]CTRDAT = [M:CTR0]CTRDAT

  If fstat
    GOK=0 : Call FSTA("CTRPEN") From GLOCK
  Endif

  If !GOK
     Rollback
     Call ERREUR(mess (17,107,1)) From GESECRAN
   Return
  Endif

  #loop through the pension grid creating the pension records
  For I=0 To [M:CTRPEN]NBRPEN-1
    [F:CTRPEN]REFNUM        = [M:CTR0]REFNUM
    [F:CTRPEN]CTRDAT        = [M:CTR0]CTRDAT
    [F:CTRPEN]CTRNUM        = [M:CTR0]CTRNUM
    [F:CTRPEN]ORG           = [M:CTRPEN]ORG(I)
    [F:CTRPEN]PENJONDAT     = [M:CTRPEN]PENJONDAT(I)
    [F:CTRPEN]PENXITDAT     = [M:CTRPEN]PENXITDAT(I)
    [F:CTRPEN]EMEPRC        = [M:CTRPEN]EMEPRC(I)
    [F:CTRPEN]EMRPRC        = [M:CTRPEN]EMRPRC(I)
    [F:CTRPEN]AUTENR        = [M:CTRPEN]AUTENR(I)
    [F:CTRPEN]REA           = [M:CTRPEN]REA(I)
    [F:CTRPEN]WRKPOSENDDAT  = [M:CTRPEN]WRKPOSENDDAT(I)
    [F:CTRPEN]EJHPOSENDDAT  = [M:CTRPEN]EJHPOSENDDAT(I)
    [F:CTRPEN]OPTNOTRCV     = [M:CTRPEN]OPTNOTRCV(I)
    [F:CTRPEN]INFGIVDAT     = [M:CTRPEN]INFGIVDAT(I)
    [F:CTRPEN]OPTOUTNOTEMR  = [M:CTRPEN]OPTOUTNOTEMR(I)
    [F:CTRPEN]AUTENROPTOUT  = [M:CTRPEN]AUTENROPTOUT(I)
    [F:CTRPEN]ENTOPT        = [M:CTRPEN]ENTOPT(I)
    [F:CTRPEN]ENTOPTOUT     = [M:CTRPEN]ENTOPTOUT(I)
    [F:CTRPEN]NONEJHOPT     = [M:CTRPEN]NONEJHOPT(I)
    [F:CTRPEN]NONEJHOPTOUT  = [M:CTRPEN]NONEJHOPTOUT(I)
    Write [F:CTRPEN]
  Next I

  #If there's a problem raise an error
  If fstat
    GOK=0 : Call FSTA("CTRPEN") From GLOCK
  Endif

  If !GOK
    Rollback
    Call ERREUR(mess (17,107,1)) From GESECRAN
    Return
  Endif


Return
#ANCOA - X3-39010 - 2017-20-09 - END

#MASHI - X3-48189 - 2017-09-22 START
# Save the status details, does this by deleting the current status records and recreating them from the grid
$LINKSTATUS

  #setup a transation and delete the current pension records
  Call DEBTRANS From GLOCK
  [V]GOK = 1

  Delete [F:CTRSTA]
&  Where [F:CTRSTA]REFNUM = [M:CTR0]REFNUM
&    and [F:CTRSTA]CTRNUM = [M:CTR0]CTRNUM
&    and [F:CTRSTA]CTRDAT = [M:CTR0]CTRDAT

  If fstat
    GOK=0 : Call FSTA("CTRSTA") From GLOCK
  Endif

  If !GOK
     Rollback
     Call ERREUR(mess (17,107,1)) From GESECRAN
   Return
  Endif

  #loop through the pension grid creating the pension records
  For I=0 To [M:CTRPEN]NBRSTA-1
    [F:CTRSTA]REFNUM        = [M:CTR0]REFNUM
    [F:CTRSTA]CTRDAT        = [M:CTR0]CTRDAT
    [F:CTRSTA]CTRNUM        = [M:CTR0]CTRNUM
    [F:CTRSTA]PENSTADAT     = [M:CTRPEN]PENSTADAT(I)
    [F:CTRSTA]PENSTA        = [M:CTRPEN]PENSTA(I)
    Write [F:CTRSTA]
  Next I

  #If there's a problem raise an error
  If fstat
    GOK=0 : Call FSTA("CTRSTA") From GLOCK
  Endif

  If !GOK
    Rollback
    Call ERREUR(mess (17,107,1)) From GESECRAN
    Return
  Endif


Return
