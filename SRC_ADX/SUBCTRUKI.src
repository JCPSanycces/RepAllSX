Subprog C_SITFAMA(VALEUR)
Value Integer VALEUR

   If VALEUR=1
    Effzo PARTTL, PARSECNAM, PARINI,PARNIN
    Grizo PARTTL, PARSECNAM, PARINI,PARNIN
