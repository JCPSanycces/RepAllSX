#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILOBJ
#DIRAS - 27/02/2017 - JIRA X3-12007 - START
Call OBJET("HRSLD",GBIDC1,"") From GOBJET
#Call OBJET("SLD",GBIDC1,"") From GOBJET
#DIRAS - 27/02/2017 - JIRA X3-12007 - END
End

########################################
$ACTION
Case ACTION
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT
 When "FILTRE"       : Gosub FILTRE
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
Endcase
Return

$SETBOUT
If !instr(1,GUSRAUZ(1),"1")
 GCONSULT=1
Endif
#34847+45200 (ajout du dim)
If [M]BNC1<>0 | [M]BNC2<>0 | [M]BNC3<>0 | [M]BNC4<>0 | [M]BNC5<>0 | [M]BNCPOA<>0
&| [M]BNCPOA2<>0 | (dim([M]EXSPAY)>0 & [M]EXSPAY<>0) | (dim([M]EXSADV)>0 & [M]EXSADV<>0)
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
Return

$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find(SRV,GAUTSRV(1..GNBSERV))"
Else
 FILTSUP = "1=1"
Endif
Return

$LIENS
#Lecture infos salariés pour le nom et prénom
Read [ID]ID0=[M]EMP
If fstat=0
 [M]EMPNAM=[F:ID]NAM
 [M]EMPSRN=[F:ID]SRN

#DIRAS - 27/02/2017 - JIRA X3-12007 - START
 If [F:ID]FLGMULCTR= 2
  Actzo [M:HRSLD0]CTRNUM
 Else
  Grizo [M:HRSLD0]CTRNUM
 Endif
Endif

#If [F:ID]FLGMULCTR= 2
#  Actzo [SLD0]CTRNUM
# Else
#  Grizo [SLD0]CTRNUM
# Endif
#DIRAS - 27/02/2017 - JIRA X3-12007 - END

#Lecture infos société pour la devise
#DIRAS - 27/02/2017 - JIRA X3-12007 - START
Filter [HRCTR] Where REFNUM=[M]EMP & CTRNUM=[M]CTRNUM
Read [HRCTR]CTR0 Last
Filter [HRCTR]
#57036
#Read [FCY]FCY0=[F:CTR]ETRFCY
Read [FCY]FCY0=[F:HRSDP]FCY

#Filter [CTR] Where REFNUM=[M]EMP & CTRNUM=[M]CTRNUM
#Read [CTR]CTR0 Last
#Filter [CTR]
##57036
##Read [FCY]FCY0=[F:CTR]ETRFCY
#Read [FCY]FCY0=[F:SDP]FCY
#DIRAS - 27/02/2017 - JIRA X3-12007 - END
If fstat=0
 Read[CPY]CPY0=[F:FCY]LEGCPY
 If fstat=0
  #57036
  [M]CPY =[F:FCY]LEGCPY
  [M]CUR1=[F:CPY]ACCCUR
  [M]CUR2=[F:CPY]ACCCUR
  [M]CUR3=[F:CPY]ACCCUR
  [M]CUR4=[F:CPY]ACCCUR
  [M]CUR5=[F:CPY]ACCCUR
  [M]CUR6=[F:CPY]ACCCUR
  [M]CUR7=[F:CPY]ACCCUR
#DIRAS - 27/02/2017 - JIRA X3-12007 - START
  If dim([M:HRSLD0]CUR8)=1  : [M]CUR8 =[F:CPY]ACCCUR : Endif
  If dim([M:HRSLD0]CUR9)=1  : [M]CUR9 =[F:CPY]ACCCUR : Endif
  If dim([M:HRSLD0]CUR10)=1 : [M]CUR10=[F:CPY]ACCCUR : Endif

#  If dim([M:SLD0]CUR8)=1  : [M]CUR8 =[F:CPY]ACCCUR : Endif
#  If dim([M:SLD0]CUR9)=1  : [M]CUR9 =[F:CPY]ACCCUR : Endif
#  If dim([M:SLD0]CUR10)=1 : [M]CUR10=[F:CPY]ACCCUR : Endif
#DIRAS - 27/02/2017 - JIRA X3-12007 - END
#MIPEA - 2017-06-09- US X3-44144- START
GCURLEG = [F:CPY]LEG
#MIPEA - 2017-06-09- US X3-44144- END
 Endif
Endif
# Acomptes
# 27788 ;TYPPOA Desc Modification de l'index de la table HISPOA
#DIRAS - 27/02/2017 - JIRA X3-12007 - START
Filter [HIP] Where EMP=[F:HRSDP]EMP & CTRNUM=[F:HRSDP]CTRNUM
& Order By Key CLE=EMP Desc;DAT Desc;FRM Desc;TYPPOA Desc
nolign = 0

#Filter [HIP] Where EMP=[F:SDP]EMP & CTRNUM=[F:SDP]CTRNUM
#& Order By Key CLE=EMP Desc;DAT Desc;FRM Desc;TYPPOA Desc
#nolign = 0
#DIRAS - 27/02/2017 - JIRA X3-12007 - END
For [HIP]CLE
 nolign += 1
 [M] = [F:HIP]
Next
[M]NBRPOA = nolign
Filter [HIP]
#MIPEA - 2017-06-09- US X3-44144- START
Gosub DISP_TITLES
#MIPEA - 2017-06-09- US X3-44144- END
Return

$INICRE
$INIMOD
#DIRAS - 27/02/2017 - JIRA X3-12007 - START
Read [ID]ID0 = [F:HRSDP]EMP
[F:HRSDP] = [F:ID]
Filter [HRCTR] Where REFNUM=[F:HRSDP]EMP & CTRNUM=[F:HRSDP]CTRNUM
Read [HRCTR]CTR0 Last
Filter [HRCTR]
[F:HRSDP]FCY = [F:HRCTR]ETRFCY
[F:HRSDP]SRV = [F:HRCTR]ETRSRV
Return

#Read [ID]ID0 = [F:SDP]EMP
#[F:SDP] = [F:ID]
#Filter [CTR] Where REFNUM=[F:SDP]EMP & CTRNUM=[F:SDP]CTRNUM
#Read [CTR]CTR0 Last
#Filter [CTR]
#[F:SDP]FCY = [F:CTR]ETRFCY
#[F:SDP]SRV = [F:CTR]ETRSRV
#Return
#DIRAS - 27/02/2017 - JIRA X3-12007 - END

######################################################################################
Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
#DIRAS - 27/02/2017 - JIRA X3-12007 - START
If [M:HRSLD0]CTRNUM=""
 Call SELCTR([M:HRSLD0]EMP,datesyst,datesyst,VALEUR) From DIVPAYE
Endif

#If [M:SLD0]CTRNUM=""
# Call SELCTR([M:SLD0]EMP,datesyst,datesyst,VALEUR) From DIVPAYE
#Endif
#DIRAS - 27/02/2017 - JIRA X3-12007 - END
End


######################################################################################

Subprog AM_EMP(VALEUR)
Variable Char     VALEUR
#DIRAS - 27/02/2017 - JIRA X3-12007 - START
If [F:ID]FLGMULCTR<>2
 Call CHERCHE_CTR(VALEUR,datesyst,[M:HRSLD0]CTRNUM) From DIVPAYE
 Grizo [M:HRSLD0]CTRNUM
Else
 Raz [M:HRSLD0]CTRNUM
 Actzo [M:HRSLD0] CTRNUM
Endif
[M:HRSLD0]EMPNAM = [F:ID]NAM
[M:HRSLD0]EMPSRN = [F:ID]SRN
Raz [M:HRSLD0]FCY,CPY,SRV
Affzo [M:HRSLD0]CTRNUM, EMPNAM,EMPSRN, FCY, CPY
End

#If [F:ID]FLGMULCTR<>2
# Call CHERCHE_CTR(VALEUR,datesyst,[M:SLD0]CTRNUM) From DIVPAYE
# Grizo [SLD0]CTRNUM
#Else
# Raz [M:SLD0]CTRNUM
# Actzo [SLD0] CTRNUM
#Endif
#[M:SLD0]EMPNAM = [F:ID]NAM
#[M:SLD0]EMPSRN = [F:ID]SRN
#Raz [M:SLD0]FCY,CPY,SRV
#Affzo [SLD0]CTRNUM, EMPNAM,EMPSRN, FCY, CPY
#End
#DIRAS - 27/02/2017 - JIRA X3-12007 - END

########################################
Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If !instr(1,GUSRAUZ(1),"1")
 Grizo [M]10
Endif
End

########################################
Subprog D_DESTYP(VALEUR)
Variable Char    VALEUR()
#DIRAS - 27/02/2017 - JIRA X3-12007 - START
If [M]TYPPOA(nolign-1)=1
  VALEUR = func AFNC.TEXTRA("ATABDIV","LNGDES","10365","AC") : # Acompte
Else
 VALEUR = func AFNC.TEXTRA("ATABDIV","LNGDES","10365","AC2") : # Acompte 13ème mois
Endif

#If [M]TYPPOA(nolign-1)=1
#  VALEUR = func AFNC.TEXTRA("ATABDIV","LNGDES","365","AC") : # Acompte
#Else
# VALEUR = func AFNC.TEXTRA("ATABDIV","LNGDES","365","AC2") : # Acompte 13ème mois
#Endif
#DIRAS - 27/02/2017 - JIRA X3-12007 - END
End

################################################################################
Subprog ADDSOLDE(NUMERO,MONTANT)
Value Integer NUMERO
Value Decimal MONTANT

#DIRAS - 27/02/2017 - JIRA X3-12007 - START
Case [L]NUMERO
 When -1 : [F:HRSDP]BNCPOA2 += [L]MONTANT
 When  1 : [F:HRSDP]BNCPOA  += [L]MONTANT
 When  2 : [F:HRSDP]BNC1    += [L]MONTANT
 When  3 : [F:HRSDP]BNC2    += [L]MONTANT
 When  4 : [F:HRSDP]BNC3    += [L]MONTANT
 When  5 : [F:HRSDP]BNC4    += [L]MONTANT
 When  6 : [F:HRSDP]BNC5    += [L]MONTANT
 When  7 : [F:HRSDP]EXSPAY  += [L]MONTANT
 When  8 : [F:HRSDP]EXSADV  += [L]MONTANT
Endcase

#Case [L]NUMERO
# When -1 : [F:SDP]BNCPOA2 += [L]MONTANT
# When  1 : [F:SDP]BNCPOA  += [L]MONTANT
# When  2 : [F:SDP]BNC1    += [L]MONTANT
# When  3 : [F:SDP]BNC2    += [L]MONTANT
# When  4 : [F:SDP]BNC3    += [L]MONTANT
# When  5 : [F:SDP]BNC4    += [L]MONTANT
# When  6 : [F:SDP]BNC5    += [L]MONTANT
# When  7 : [F:SDP]EXSPAY  += [L]MONTANT
# When  8 : [F:SDP]EXSADV  += [L]MONTANT
#Endcase
#DIRAS - 27/02/2017 - JIRA X3-12007 - END
End

################################################################################
Funprog GETSOLDE(NUMERO)
Value Integer NUMERO

#DIRAS - 27/02/2017 - JIRA X3-12007 - START
Case [L]NUMERO
 When -1      : End [F:HRSDP]BNCPOA2
 When  1      : End [F:HRSDP]BNCPOA
 When  2      : End [F:HRSDP]BNC1
 When  3      : End [F:HRSDP]BNC2
 When  4      : End [F:HRSDP]BNC3
 When  5      : End [F:HRSDP]BNC4
 When  6      : End [F:HRSDP]BNC5
 When  7      : End [F:HRSDP]EXSPAY
 When  8      : End [F:HRSDP]EXSADV
 When Default : End 0
Endcase

#Case [L]NUMERO
# When -1      : End [F:SDP]BNCPOA2
# When  1      : End [F:SDP]BNCPOA
# When  2      : End [F:SDP]BNC1
# When  3      : End [F:SDP]BNC2
# When  4      : End [F:SDP]BNC3
# When  5      : End [F:SDP]BNC4
# When  6      : End [F:SDP]BNC5
# When  7      : End [F:SDP]EXSPAY
# When  8      : End [F:SDP]EXSADV
# When Default : End 0
#Endcase
#DIRAS - 27/02/2017 - JIRA X3-12007 - END
#MIPEA - 2017-06-09- US X3-44144- START
$DISP_TITLES
Local Integer SEQUENCE
Local Char LIBZON(80)

  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif

  Filter [ADI] Where NUMTAB=10365 & LEG=GCURLEG

      Chgtzn [M]BNCPOA2 With ""
      Chgtzn [M]BNCPOA  With ""
      Chgtzn [M]BNC1    With ""
      Chgtzn [M]BNC2    With ""
      Chgtzn [M]BNC3    With ""
      Chgtzn [M]BNC4    With ""
      Chgtzn [M]BNC5    With ""

  For [ADI]
    SEQUENCE = [F:ADI]N1
    Call LECTEXTRA(LIBZON,"ATABDIV","LNGDES","10365",[F:ADI]CODE) From ATEXTRA
    Case SEQUENCE
      When -1 : Chgtzn [M]BNCPOA2 With LIBZON
      When  1 : Chgtzn [M]BNCPOA  With LIBZON
      When  2 : Chgtzn [M]BNC1    With LIBZON
      When  3 : Chgtzn [M]BNC2    With LIBZON
      When  4 : Chgtzn [M]BNC3    With LIBZON
      When  5 : Chgtzn [M]BNC4    With LIBZON
      When  6 : Chgtzn [M]BNC5    With LIBZON
      When  7 : Chgtzn [M]EXSPAY  With LIBZON
    Endcase
  Next

  Filter [ADI]

Return
#MIPEA - 2017-06-09- US X3-44144- END

