#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMACOPY3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:43"
A_USER  = "DOC"
A_STAMP = "20181109230543"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMACOPY3 [PJMAC3]
Gosub HORODAT
Local Inpbox "PJMACOPY3" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJMAC3] As [SIM_]
Grizo [PJMAC3]10
Grizo [PJMAC3]15
Grizo [PJMAC3]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJMAC3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=81 : Y1(0)=1 : Y2(0)=5
X1(1)=1 : X2(1)=81 : Y1(1)=6 : Y2(1)=8
X1(2)=1 : X2(2)=81 : Y1(2)=9 : Y2(2)=25
Return

$ON_BTNTAC
Onevent BEFORE_INPUT Call AS_BTNTAC(zc) From W1PJMACOPY3
Onevent BEFORE_AREA Gosub AV_BTNTAC From W1PJMACOPY3
Return

$AV_BTNTAC
zc = 38
Gosub _AFF
Return

Subprog AS_BTNTAC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_BTNTAC(zc) From W1PJMACOPY3
Gosub _AFF
End

Subprog CL_BTNTAC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call CL_BTNTAC(VALEUR) From SUBPJMACOPY
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_TACLNK
Onevent INIT_AREA Call D_TACLNK(zc) From W1PJMACOPY3
Onevent BEFORE_INPUT Call AS_TACLNK(zc) From W1PJMACOPY3
Return

Subprog D_TACLNK(VALEUR)
Variable Integer VALEUR
If varinit([M]TACLNK,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TACLNK(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

