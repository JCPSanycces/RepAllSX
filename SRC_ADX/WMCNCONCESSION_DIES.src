#<AdxTL>@(#)0.0.0.0 $Revision$Class Concession
# Supervisor
## ACLA-CLASSE ## CONCESSION_DIES
# 2018-11-06 07:04:16 098

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0CONCESSION_DIES
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_DIE From WMC1CONCESSION_DIES : Gosub TESTALLSTAT
Gosub INIT_CCE From WMC1CONCESSION_DIES : Gosub TESTALLSTAT
Gosub AINIT From WMC0CONCESSION_DIES : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0CONCESSION_DIES
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0CONCESSION_DIES
Gosub LNKPRO_DIE From WMC1CONCESSION_DIES : Gosub TESTALLSTAT
Gosub LNKPRO_CCE From WMC1CONCESSION_DIES : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



