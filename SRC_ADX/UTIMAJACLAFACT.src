#    If fstat
#      Read [ATYX3]CODTYP=[F:ACLAF]CODTYP
#      If !fstat
#       Call CHANGE_CODTYP(1,[ATYX3]TYPTYP,[F:ACLAF]CODTYP,[F:ACLAF]LONG) From DOSDICDIV
#      Else
#       [F:ACLAF]CODTYP  = "A"
#       [F:ACLAF]LONG    = 1
#      Endif
#      [F:ACLAF]FLDGRP = ""
#      Rewrite [ACLAF]
#      If fstat
#       Call ERREUR("ACLAFLD"-[F:ACLAF]CODCLA-[F:ACLAF]FLDCLA,2) From DOSDIC
#      Endif
#    Endif
#   Elsif [F:ACLAF]LNKCLA<>""
#    Delete [ACLFP] Where CODCLA=[F:ACLAF]CODCLA & FLDCLA=[F:ACLAF]FLDCLA
