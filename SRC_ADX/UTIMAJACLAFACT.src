#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Update data of ACLAFLD table with activity code
#----------------------------------------------------------------------------------------#

# Update data of ACLAFLD table with activity code
Subprog GENE
Call OUVRE_TRACE("Update data of ACLAFLD table with activity code") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2] Where DOSSIER="TEST2"
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER

If DOSSIER=GDOSX3 : End : Endif

If DOSSIER=nomap
 Local File ACLAFLD    [ACLAF]
 Local File ACLAPARFLD [ACLFP]
 Local File ACLALNK [ACLAK]
 Local File ACLAMAP [ACLAKP]
 Local File ATYPE [ATY]
 Local File ACTIV [ACV]
Else
 Local File =DOSSIER+".ACLAFLD"    [ACLAF]
 Local File =DOSSIER+".ACLAPARFLD" [ACLFP]
 Local File =DOSSIER+".ACLALNK" [ACLAK]
 Local File =DOSSIER+".ACLAMAP" [ACLAKP]
 Local File =DOSSIER+".ATYPE" [ATY]
 Local File =DOSSIER+".ACTIV" [ACV]
Endif

Local File =GDOSX3+".ATYPE" [ATYX3]

Gosub MAJACLAF

Gosub MAJACLALNK

Close Local File [ACLAF],[ATY],[ATYX3],[ACV]
End

#----------------------------------------------------------------------------------------#
$MAJACLALNK
Trbegin [ACLAF],[ACLAK]
For [ACLAK]ACLAK0 Where ACVLNK<>""
  Read [ACV]CODACT = [F:ACLAK]ACVLNK
  If fstat or [ACV]FLACT<>2
   #Infbox "ACLAK"-[F:ACLAK]CODCLA-[F:ACLAK]REFLNK
   Delete [ACLAKP] Where CODCLA=[F:ACLAK]CODCLA & REFLNK=[F:ACLAK]REFLNK
   Delete [ACLFP] Where CODCLA=[F:ACLAK]CODCLA & FLDCLA=[F:ACLAK]REFLNK
   Delete [ACLAF] Where CODCLA=[F:ACLAK]CODCLA & FLDCLA=[F:ACLAK]REFLNK
   Delete [ACLAK] Curr
  Endif
Next
Commit
Return


#----------------------------------------------------------------------------------------#
$MAJACLAF
Trbegin [ACLAF]
 For [ACLAF]ACLAF0 Where [F:ACLAF]ACTFLD<>""
  Read [ACV]CODACT = [F:ACLAF]ACTFLD
  If fstat or [ACV]FLACT<>2
   #Infbox "ACLAF"-[F:ACLAF]CODCLA-[F:ACLAF]FLDCLA
#   If [F:ACLAF]CODTYP<>""
