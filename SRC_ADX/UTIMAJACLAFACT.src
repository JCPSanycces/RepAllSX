   Delete [ACLFP] Where CODCLA=[F:ACLAF]CODCLA & FLDCLA=[F:ACLAF]FLDCLA
   Delete [ACLAF] Curr
   If fstat
    Call ERREUR("ACLAFLD"-[F:ACLAF]CODCLA-[F:ACLAF]FLDCLA,3) From DOSDIC
   Endif
  Endif
 Next
Commit
Return
