#------------------------------------------------------
Subprog C_RNWAASREF(VALEUR)
Variable Char    VALEUR()
 Local Integer LRETOUR
 LRETOUR=func SUBRWP.IS_RNWAASREF_VALIDE(VALEUR)
 If LRETOUR<0
  GERR=1
  GMESSAGE="Error C_RNWAASREF / Func SUBRWP.IS_RNWAASREF_VALIDE"
  mkstat=2
  End
 Elsif LRETOUR>0
  GERR=1
  GMESSAGE=mess(LRETOUR,GML_MSGFAS,1)
  mkstat=2
  End
 Endif
End

#------------------------------------------------------
Subprog AP_RNWAASREF(VALEUR)
Variable Char    VALEUR()
 If !clalev([F:FAS]) : Local File FXDASSETS  [FAS] : Endif
 If !clalev([F:CCN]) : Local File CONCESSION [CCN] : Endif
 Read [F:FAS]FAS0=VALEUR
 If !fstat
  Read [F:CCN]CCN0=[F:FAS]CCNREF
  If !fstat
   # FQ93563 : en import le champ [M:RWP0]RNWAASREF est déjà alimenté, le transclasse [M:RWP0]=[F:FAS] fait perdre sa valeur. On la sauvegarde si import
   If GIMPORT
     Local Char SRNWAASREF(GLONVC9)
     SRNWAASREF = [M:RWP0]RNWAASREF
   Endif
   [M:RWP0]=[F:FAS]
   # FQ93563 : en import on restaure la valeur du champ [M:RWP0]RNWAASREF d'avant le transclasse
   If GIMPORT
     [M:RWP0]RNWAASREF = SRNWAASREF
   Endif
   [M:RWP0]=[F:CCN]
   If [F:RWP]RNWDONFLG<>G_OUI : Raz [RWP0]RNWDAT : Endif
   Affzo [M:RWP0]15
  Endif
 Endif

 Read [F:DEP]DEP0=VALEUR;G_CCNPLNCAD;GFINEXECPF;GFINPERCPF
 If fstat
  #RAF
 Endif
 [M:RWP0]DPRBASINI = [F:DEP]DPRBAS : Affzo [M:RWP0]DPRBASINI

End

#------------------------------------------------------
Subprog C_RNWDAT(VALEUR)
Variable Date    VALEUR

 If VALEUR<>[0/0/0] & VALEUR<GDEBEXECPF | VALEUR>GFINEXSCPF
  GERR=1
  GMESSAGE=mess(786,GML_MSGFAS,1)+":"-format$(GFMDAT4,GDEBEXECPF)-mess(95,100,1)-format$(GFMDAT4,GFINEXSCPF) #"La date de renouvellement doit se situer dans l'exercice courant ou suivant"
  mkstat=2
  End
 Endif

 If VALEUR<>[0/0/0] & VALEUR<[M:RWP0]PURDAT
  GERR=1
  GMESSAGE=mess(787,GML_MSGFAS,1) #"La date de renouvellement ne peut être antérieure à la date d'achat du bien fils"
  mkstat=2
  End
 Endif

 # La date de renouvellement doit être postérieure à la date d'achat de tout les biens pères.
 If VALEUR<>[0/0/0]
  Local Integer I_MOTH
  For I_MOTH=1 To [M:RWP0]NBMOTH
   If [M:RWP0]MOTHPURDAT(I_MOTH-1)>VALEUR
    GERR     = 1
    GMESSAGE = mess(798,GML_MSGFAS,1) #"La date de renouvellement est antérieure à la date d'achat d'au moins un bien renouvelé." #
    mkstat   = 2
    Break
   Endif
  Next I_MOTH
 Endif

End

#------------------------------------------------------
Subprog AM_RNWDAT(VALEUR)
Variable Date    VALEUR
 If VALEUR=[0/0/0]
  [M:RWP0]FLGCAL=G_NON
  Grizo [M:RWP0]FLGCAL
 Else
  Actzo [M:RWP0]FLGCAL
 Endif
 Affzo [M:RWP0]FLGCAL
 [M:RWP0]RNWDAT=VALEUR : Gosub CONDITIONNE_CCNINICAL
End

#------------------------------------------------------
Subprog AP_RNWDAT(VALEUR)
Variable Date    VALEUR
 If VALEUR<>[0/0/0] & [M:RWP0]FLGCAL=G_OUI
  [M:RWP0]RNWDAT=VALEUR
  Gosub CALCUL_FONDS
 Endif
End

#------------------------------------------------------
Subprog AM_ISSDATRUL(VALEUR)
Variable Integer    VALEUR
 If [M:RWP0]FLGCAL=G_OUI
  [M:RWP0]ISSDATRUL=VALEUR
  Gosub CALCUL_FONDS
 Endif
End

