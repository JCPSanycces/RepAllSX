#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
#
# GESTION DES CONCESSIONS - PREPARATION DU RENOUVELLEMENT
# =======================================================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
#
#
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
# $OUVRE
# $SETBOUT
#
#
#
########################################################################################################################
# Modifications :
# -------------
#
# - USR - xx.xx.xxxx - Fq yyyyy - Commentaire
#
# - GLE - 15.10.2013 - Fq 93563 - Possibilité d'importer des préparations de renouvellement
# - GBO - 09.11.2010 - Fq 68965 - Déplacement du PE CALCADDEV
# - GBO - 05.11.2010 - Fq 65873 - Remplacement des n° de chapitre par les variable GML_MSGxxx
# - GBO - 05.11.2010 - Fq 68897 - FILGAUSUP variable inexistante en suppression si liste gauche : biens à renouveler.
# - GBO - 30.09.2010 - Fq 67778 - Picking bien père après saisie RNWDAT : contrôle incorrect
# - GBO - 30.07.2010 - Fq 66375 - On ne doit pas pouvoir choisir un bien en cours comme bien renouvelant.
#
#
########################################################################################################################
End
 Local Char LMESSAGE(80)
 Case func GLOCCN.RNW_ENCOURS("CC1","S1C","ICC109099125")
  When 1 : LMESSAGE="Bien non référencé dans une opération de renouvellement"
  When 2 : LMESSAGE="Bien référencé dans une opération de renouvellement : bien fils"
  When 3 : LMESSAGE="Bien référencé dans une opération de renouvellement : bien père"
 Endcase
 Infbox LMESSAGE
End
  Raz GPILOBJ
  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM
  Call OBJET("RWP",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
 #If GUSER="GBO" : Infbox ACTION : Endif
 Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "SETBOUT"      : Gosub SETBOUT
  When "LIENS0"       : Gosub LIENS0
  When "LIENS"        : Gosub LIENS
  When "LIENS2"       : Gosub LIENS2
  When "VERROU"       : Gosub VERROU
  When "DEVERROU"     : Gosub DEVERROU
  When "FILGAUCHE"    : Gosub FILGAUCHE
  When "TIROIR"       : Gosub TIROIR
  When "DEB_PICK"     : Gosub DEB_PICK
  When "PICKE"        : Gosub PICKE
  When "DEPICK"       : Gosub DEPICK
  When "RAZCRE"       : Gosub RAZCRE
  When "RAZDUP"       : Gosub RAZDUP
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "INICRE"       : Gosub INICRE
  When "CREATION"     : Gosub CREATION
  When "MODIF"        : Gosub MODIF
  When "AV_ANNULE"    : Gosub AV_ANNULE
  When "AP_ANNULE"    : Gosub AP_ANNULE
  When "FIN_ACTION"   : Gosub FIN_ACTION
  When "FERME"        : Gosub FERME
  When Default
 Endcase
Return

#------------------------------------------------------
$OUVRE
 Gosub OUVRE_MASQUES_CALCUL
 Gosub OUVRE_TABLES
 Gosub DEF_GLOBALES
 Gosub DEF_CONSTANTES
Return

#------------------------------------------------------
$SETBOUT

 # Les boutons Valider et Annuler ne sont actifs qu'en consultation

 If GREP<>""
  Call VIREBOUT (CHAINE, "VU") From GOBJET
 Endif

 # Activation / désactivation des boutons en fonction du statut de validation de l'opération de renouvellement

 If [F:RWP]RNWDONFLG<>G_OUI
  If GREP="" : CHAINE+="A" : Endif # Activation du bouton "Supprimer"
  If currbox="GAU_CHE1" : Call VIREBOUT (CHAINE, "C") From GOBJET : Endif
  Gosub CONDITIONNE_CCNINICAL
  Call VIREBOUT (CHAINE, "U") From GOBJET
 Else
  Call VIREBOUT (CHAINE, "VMA") From GOBJET
 Endif

 # Le bouton valider est inactif tant que la date de renouvellement effective n'a pas été choisie.

 If [M:RWP0]RNWDAT=[0/0/0] | [F:RWP]RNWDAT=[0/0/0]
  Call VIREBOUT (CHAINE, "V") From GOBJET
 Endif

Return

#------------------------------------------------------
$LIENS0
 Actzo [M:RWP0]
Return

#------------------------------------------------------
$LIENS
 #> Alimentation des informations des biens pères
 Read [F:FAS]FAS0=[F:RWP]MOTHAASREF
 If !fstat
  [M:RWP0]MOTHAASDES(nolign-1)=[F:FAS]AASDES1
  [M:RWP0]MOTHRNWFLG(nolign-1)=[F:FAS]RNWFLG
  [M:RWP0]MOTHRNWVAL(nolign-1)=[F:FAS]RNWVAL
  [M:RWP0]MOTHRNWDAT(nolign-1)=[F:FAS]RNWDAT
  [M:RWP0]MOTHPURDAT(nolign-1)=[F:FAS]PURDAT
  If [F:RWP]RNWDONFLG=G_OUI
   [M:RWP0]MOTHCAD(nolign-1)=[F:FAS]CCNTRFCAD
   [M:RWP0]MOTHSUB(nolign-1)=[F:FAS]CCNTRFGRT
   [M:RWP0]MOTHRPR(nolign-1)=[F:FAS]CCNTRFRPR
  Endif
 Endif
 ###> PE - pour ajouter des colonnes en spé
Return

#------------------------------------------------------
# Après chargement du renouvellement en préparation
#    - Chargement des globables sociétés utiles
#    - Calcul et affichage des fonds transmis par les
#      pères
#    - Rechargement de la liste gauche de picking
#      contenant les pères utilisables et utilisés
#    - Désactivation du site
#------------------------------------------------------
$LIENS2
 # FQ93563 : Ccette étiquette est appellé par le traitement Superviseur de l'import en création, ce qui pose beaucoup de
 #           problèmes. On court-circuite cette étiquette en import
 If GIMPORT
   Return
 Endif

 #> Chargement du contexte société
 GSOCIETE = [M:RWP0]CPY
 Call CHARGE_ENVIRONNEMENT() From GLOFCYCPY

 #> Calcul des fonds à transmettre des biens pères
 If [M:RWP0]RNWDAT<>[0/0/0] & [M:RWP0]FLGCAL=G_OUI & [F:RWP]RNWDONFLG<>G_OUI
  Call TEMPON("Calcul des fonds. Patientez SVP.") From GESECRAN
  Gosub CALCUL_FONDS
  Call TEMPOFF From GESECRAN
 Endif
 #> Alimentation des informations du bien fils
 Read [F:FAS]FAS0=[F:RWP]RNWAASREF
 [M:RWP0]AASDES1    = [F:FAS]AASDES1
 [M:RWP0]AASDES2    = [F:FAS]AASDES2
 [M:RWP0]PURDAT     = [F:FAS]PURDAT
 [M:RWP0]ITSDAT     = [F:FAS]ITSDAT
 If [F:RWP]RNWDONFLG=G_OUI
  [M:RWP0]CCNINICUM = [F:FAS]CCNINICUM
  [M:RWP0]CCNCADDEV = [F:FAS]CCNCADDEV
  [M:RWP0]CCNCADEXC = [F:FAS]CCNCADEXC
  [M:RWP0]RVERPRVAL =[F:FAS]RVERPRVAL
  Read [F:DEP]DEP0=[M:RWP0]RNWAASREF;G_CCNPLNCAD;GFINEXECPF;GFINPERCPF
  If fstat
   #RAF
  Endif
  [M:RWP0]DPRBAS    = [F:DEP]DPRBAS
  [M:RWP0]DPRBASINI = [M:RWP0]DPRBAS-[M:RWP0]CCNCADEXC+[M:RWP0]CCNINICUM
 Else
  Read [F:DEP]DEP0=[M:RWP0]RNWAASREF;G_CCNPLNCAD;GFINEXECPF;GFINPERCPF
  If fstat
   #RAF
  Endif
  [M:RWP0]DPRBASINI = [F:DEP]DPRBAS
  Gosub ALIM_DPRBAS
 Endif
 #> Population de la liste des biens pères
 Gosub TIROIR
 #> Grisage du site
 Diszo [M:RWP0]FCY
 #> Affichage du bouton de simulation de calcul des fonds
 Gosub CONDITIONNE_CCNINICAL

 If [F:RWP]RNWDONFLG=G_OUI
  Diszo [M:RWP0]
  Actzo [M:RWP0]RNWAASREF
 Endif

Return

#------------------------------------------------------
$VERROU
Local Char SYMRWP(50)
SYMRWP="RWP~"+[F:RWP]RNWAASREF
Lock =SYMRWP
Return

#------------------------------------------------------
$DEVERROU
Local Char SYMRWP(50)
SYMRWP="RWP~"+[M:RWP0]RNWAASREF
Unlock =SYMRWP
Raz GFATHFILTRE
Return

#------------------------------------------------------
# Alimentation des critères pour remplissage de la
# liste gauche de picking des biens pères.
# Longueur FILGAUSUP(0) -> 188 car
#------------------------------------------------------
$FILGAUCHE
 If dim(FILGAUSUP)<0 : Return : Endif #Fq68897
 Case currbox
  When "GAU_CHE1"
   Raz FILGAUSUP
    #
    # Sélection des biens pères :
    # -------------------------
    # Bien en concession ET même contrat de concession que le bien fils ET Obligation contractuelle=oui
    # Référence du bien fils vide OU référence du bien fils sur le bien père = référence du bien fils ET
    # (Type d'apport = Renouvellement ET Renouvellement effectué) OU (Type d'apport différent de renouvellement)
    #
    FILGAUSUP(0) = "OWNTYP=GVML_TDCONCE&CCNREF=[M:RWP0]CCNREF&OBYRNWCON=2&"
&                 +"(RNWAASREF=''|RNWAASREF=[M:RWP0]RNWAASREF)&RNWDAT<>[0/0/0]&((CCNETRTYP=GVML_NARENEW&RNWDONFLG=2)|(CCNETRTYP<>GVML_NARENEW))"
    If [F:RWP]RNWDONFLG=G_OUI
     FILGAUSUP(0)+="&(ISSTYP=12|!ISSTYP)"
    Else
     FILGAUSUP(0)+="&ISSTYP=0"
    Endif
    If [M:RWP0]CPY<>""
     FILGAUSUP(0) += "&FCY=[M:RWP0]FCY"
    Endif
    If GFATHFILTRE<>""
     FILGAUSUP(1) +="&("+GFATHFILTRE+")"
    Endif
  When "GAU_CHE2"
   Raz FILGAUSUP
   FILGAUSUP(0) = "RNWDONFLG=G_OUI"
  When Default
 Endcase
Return

#------------------------------------------------------
$TIROIR
  Raz CRITERE
  Gosub FILGAUCHE
  If (dim(FILTREG) > 0) Then : FILTREG = 1 : Endif
  Gosub REMPLIT
  If currbox="GAU_CHE1"
   For nolign=1 To [M:RWP0]NBMOTH
    Read [F:FAS]FAS0=[M:RWP0]MOTHAASREF(nolign-1)
    Gosub REPICK From WGORWP
   Next nolign
  Endif
Return

#------------------------------------------------------
$DEB_PICK
  If [F:RWP]RNWDONFLG=G_OUI : OK=0 : Return : Endif
Return

#------------------------------------------------------
$PICKE
  If [F:RWP]RNWDONFLG=G_OUI : OK=0 : Return : Endif
  If func CTRL_VERROU_OK(VERROU)=G_NON : OK=0 : Return : Endif
  If currbox="GAU_CHE1"
   If !find([F:FAS]AASREF,[M:RWP0]MOTHAASREF)
    #fq67778
    If [M:RWP0]RNWDAT<>[0/0/0] & [F:FAS]PURDAT > [M:RWP0]RNWDAT
     #"La date d'achat de ce bien est postérieure à la date de renouvellement."
     MESSAGE = mess(812,GML_MSGFAS,1)-format$(GFMDAT4,[F:FAS]PURDAT)-"-"-format$(GFMDAT4,[M:RWP0]RNWDAT)
     Errbox MESSAGE
     OK = 0
    Else
     [M:RWP0]MOTHAASREF([M:RWP0]NBMOTH)=[F:FAS]AASREF
     [M:RWP0]MOTHAASDES([M:RWP0]NBMOTH)=[F:FAS]AASDES1
     [M:RWP0]MOTHRNWFLG([M:RWP0]NBMOTH)=[F:FAS]RNWFLG
     [M:RWP0]MOTHRNWVAL([M:RWP0]NBMOTH)=[F:FAS]RNWVAL
     [M:RWP0]MOTHRNWDAT([M:RWP0]NBMOTH)=[F:FAS]RNWDAT
     [M:RWP0]MOTHPURDAT([M:RWP0]NBMOTH)=[F:FAS]PURDAT
     [M:RWP0]NBMOTH+=1 : Affzo [M:RWP0]25
     If [M:RWP0]FLGCAL=G_OUI : Gosub CALCUL_FONDS : Endif
    Endif
   Endif
  Endif
Return

#------------------------------------------------------
$DEPICK
  If [F:RWP]RNWDONFLG=G_OUI : OK=0 : Return : Endif
  If func CTRL_VERROU_OK(VERROU)=G_NON : OK=0 : Return : Endif
  If currbox="GAU_CHE1"
   Local Integer IDX_MOTHREF : IDX_MOTHREF=find([F:FAS]AASREF,[M:RWP0]MOTHAASREF)
   If IDX_MOTHREF
    Trbegin [F:FAS]
    Raz [F:FAS]RNWAASREF
    Rewrite [F:FAS]
    If fstat
     Return
     Rollback
    Else
     Commit
    Endif
    Dela IDX_MOTHREF-1,1 [M:RWP0]NBMOTH : [M:RWP0]NBMOTH-=1 : Affzo [M:RWP0]25
   Endif
   If [M:RWP0]FLGCAL=G_OUI : Gosub CALCUL_FONDS : Endif
  Endif
Return

#------------------------------------------------------
$RAZCRE
 Effzo [M:RWP0]20
 Effzo [M:RWP0]25
 Gosub TIROIR
Return

#------------------------------------------------------
$RAZDUP
 Effzo [M:RWP0]20
 Effzo [M:RWP0]25
Return

#------------------------------------------------------
$APRES_MODIF
 Case zoncou
  When "NBMOTH"
   Case status
    When 65 : # Suppression ligne
     Read [F:FAS]FAS0=[M:RWP0]MOTHAASREF(nolign-1)
     Trbegin [F:FAS]
     Raz [F:FAS]RNWAASREF
     Rewrite [F:FAS]
     If fstat
      Return
      Rollback
     Else
      Commit
     Endif
     Gosub DEPICK From WGORWP
     If [M:RWP0]FLGCAL=G_OUI
      Local Integer LEXCLUSION : LEXCLUSION=nolign : Gosub CALCUL_FONDS : Kill LEXCLUSION
     Endif
    When Default
   Endcase
  When Default
 Endcase
Return

#------------------------------------------------------
$INICRE
 [F:RWP]RNWDONFLG=G_NON
Return

#------------------------------------------------------
$CREATION
 Gosub MODIF
Return

#------------------------------------------------------
$MODIF
 Read [F:FAS]FAS0=[F:RWP]MOTHAASREF
 If !fstat
  [F:FAS]RNWAASREF=[F:RWP]RNWAASREF
  Rewrite [F:FAS]
  If fstat
   GOK=0
  Endif
 Endif
Return

#------------------------------------------------------
$AV_ANNULE
 Local Integer I
 For I=1 To [M:RWP0]NBMOTH
  Read [F:FAS]FAS0=[M:RWP0]MOTHAASREF(I-1)
  If !fstat
   Raz [F:FAS]RNWAASREF
   Rewrite [F:FAS]
   If fstat
    GOK=0
   Endif
  Endif
 Next I
Return

#------------------------------------------------------
$AP_ANNULE
 Gosub TIROIR
Return

#------------------------------------------------------
$FIN_ACTION
  If dim(GRNWCAN)>0 | dim(GRNWACT)>0
   Gosub RELIT From GOBJSUB
  Endif
  If dim(GRNWCAN)>0 : Kill GRNWCAN : Endif
  If dim(GRNWACT)>0 : Kill GRNWACT : Endif
Return

#------------------------------------------------------
$FERME
 Gosub KILL_GLOBALES
Return

######################################################################################
# ROUTINES ET SOUS-PROGRAMMES COMMUNS
######################################################################################

#------------------------------------------------------
# Ouverture des masques nécessaire à la fonction de
# calcul permettant de calculer les fonds à
# transmettre par les pères.
#------------------------------------------------------
$OUVRE_MASQUES_CALCUL
 If !clalev([M:FASS]) : Local Mask FASISSP [FASS] : Endif
 If !clalev([M:PCPT]) : Local Mask CALDEP  [PCPT] : Endif
 If !clalev([M:PFIS]) : Local Mask CALDEP  [PFIS] : Endif
 If !clalev([M:PMIN]) : Local Mask CALDEP  [PMIN] : Endif
 If !clalev([M:PORI]) : Local Mask CALDEP  [PORI] : Endif
 If !clalev([M:PR76]) : Local Mask CALDEP  [PR76] : Endif
 If !clalev([M:PIAS]) : Local Mask CALDEP  [PIAS] : Endif
 If !clalev([M:PTEC]) : Local Mask CALDEP  [PTEC] : Endif
 If !clalev([M:PRET]) : Local Mask CALDEP  [PRET] : Endif
 If !clalev([M:PSUB]) : Local Mask CALDEP  [PSUB] : Endif
 If !clalev([M:PLI1]) : Local Mask CALDEP  [PLI1] : Endif
 If !clalev([M:PLI2]) : Local Mask CALDEP  [PLI2] : Endif
 If !clalev([M:PLI3]) : Local Mask CALDEP  [PLI3] : Endif
 If !clalev([M:PLI4]) : Local Mask CALDEP  [PLI4] : Endif
 If !clalev([M:PLI5]) : Local Mask CALDEP  [PLI5] : Endif
 If !clalev([M:PLI6]) : Local Mask CALDEP  [PLI6] : Endif
 If !clalev([M:DEP])  : Local Mask CALDEP  [DEP]  : Endif
 If !clalev([M:IND])  : Local Mask CALDEP  [IND]  : Endif
 If !clalev([M:CAD])  : Local Mask CALDEP  [CAD]  : Endif
 If !clalev([M:SUB])  : Local Mask CALDEP  [SUB]  : Endif
 If !clalev([M:PRPR]) : Local Mask CCNRPR [PRPR]  : Endif
Return

#------------------------------------------------------
$OUVRE_TABLES
 If !clalev([F:FAS]) : Local File FXDASSETS  [FAS] : Endif
 If !clalev([F:DEP]) : Local File DEPREC     [DEP] : Endif
 If !clalev([F:CCN]) : Local File CONCESSION [CCN] : Endif
Return

#------------------------------------------------------
$DEF_GLOBALES
 Global Char GFATHFILTRE
Return

#------------------------------------------------------
$DEF_CONSTANTES
 Global Char GICOCCNINICA : GICOCCNINICA="42"
Return

#------------------------------------------------------
$KILL_GLOBALES
 If dim(GFATHFILTRE)>0   : Kill GFATHFILTRE : Endif
 If dim(GICOCCNINICA)>0 : Kill GICOCCNINICA : Endif
Return

#------------------------------------------------------
# Remplissage des listes gauches
#------------------------------------------------------
$REMPLIT
 If dim(FILGAUSUP)<0 : Return : Endif #Fq68897
  Case currbox
    When "GAU_CHE1"  : Gosub REMPLIT_1 From WGORWP
    When Default
  Endcase
Return


#------------------------------------------------------
# Boucle sur les biens pères. Pour chacun d'entre eux
# appel de la fonction de calcul des fonds à transmettre
# Les fonds à transmettre calculés sont totalisés pour
# alimenter le fonds initial du bien fils.
#------------------------------------------------------
$CALCUL_FONDS

 If [M:RWP0]RNWDAT=[0/0/0] : Return : Endif

 Local Char    LAASREF
 Local Integer I, RCOD
 Local Decimal TMOTHCAD
 Local Decimal TMOTHSUB
 Local Decimal TMOTHRPR
 Local Decimal TMOTHCADDEV
 Local Decimal MMOTHCAD
 Local Decimal MMOTHSUB
 Local Decimal MMOTHRPR
 Local Decimal MMOTHCADDEV

 For I=1 To [M:RWP0]NBMOTH
  If dim(LEXCLUSION)<0 | dim(LEXCLUSION)>0 & I<>LEXCLUSION
   LAASREF=[M:RWP0]MOTHAASREF(I-1)
   Raz MMOTHCAD, MMOTHSUB, MMOTHRPR
   Call CAL_FONDS_TRANSMIS([M:RWP0]CPY, LAASREF, G_OUI, [M:RWP0]RNWDAT, [M:RWP0]ISSDATRUL, MMOTHCAD, MMOTHSUB, MMOTHRPR, MMOTHCADDEV, RCOD)
   [M:RWP0]MOTHCAD(I-1)=MMOTHCAD : Affzo [M:RWP0]MOTHCAD(I-1) : TMOTHCAD+=MMOTHCAD  # Fonds de caducité
   [M:RWP0]MOTHSUB(I-1)=MMOTHSUB : Affzo [M:RWP0]MOTHSUB(I-1) : TMOTHSUB+=MMOTHSUB  # Fonds de subvention
   [M:RWP0]MOTHRPR(I-1)=MMOTHRPR : Affzo [M:RWP0]MOTHRPR(I-1) : TMOTHRPR+=MMOTHRPR  # Fonds de provision
   TMOTHCADDEV+=MMOTHCADDEV
  Endif
 Next I

 [M:RWP0]CCNINICUM=TMOTHCAD+TMOTHSUB+TMOTHRPR : Affzo [M:RWP0]CCNINICUM # Fonds initial
 [M:RWP0]RVERPRVAL=TMOTHRPR                   : Affzo [M:RWP0]RVERPRVAL # Provision à reprendre

 Read [F:DEP]DEP0=[M:RWP0]RNWAASREF;G_CCNPLNIND;GFINEXECPF;GFINPERCPF
 If fstat
 Endif
 [M:RWP0]CCNCADDEV=[F:DEP]DPRBAS+TMOTHCADDEV  : Affzo [M:RWP0]CCNCADDEV # Ecart de caducité

 Gosub ALIM_DPRBAS

Return

#------------------------------------------------------
# Le fonds de caducité est égal à :
#    - TRFCADCUM : fonds de début de la période de
#                  renouvellement
#    - PERENDDPE : dotation de caducité de la période
#                  de renouvellement si OER = 1
#------------------------------------------------------
$ALIM_MOTHCAD
  Gosub SET_CADPLN_MSK
  Local Integer I_PER_SOR
  If PRNWDAT>GFINPERCPF
   Local Integer I_PER
   # Période de sortie
   For I_PER=1 To [M:CAD]NB_DEP
    If [M:CAD]PERSTRDAT(I_PER-1)<=PRNWDAT & PRNWDAT<=[M:CAD]PERENDDAT(I_PER-1) : I_PER_SOR=I_PER : Break : Endif
   Next I_PER
  Else
   # Période courante
   I_PER_SOR=find(GFINPERCPF,[M:CAD]PERENDDAT)
  Endif
  If I_PER_SOR
    RFNDCAD=[M:CAD]TRFCADCUM(I_PER_SOR-1)+
&           [M:CAD]PERENDDPE(I_PER_SOR-1)-
&           [M:CAD]PERCADCRB(I_PER_SOR-1)+
&           [M:CAD]PEREXCDPR(I_PER_SOR-1)                  # Fonds début - Prélévement - Reprise
   GPOINT = "CALFNDCAD" : Gosub ENTREE From EXEFNC
   If GOK<1 : Return : Endif
  Endif
Return

#------------------------------------------------------
# Le fonds de subvention est égal à :
#    - NBV : Valeur nette du plan de subvention à la
#            fin de la période de renouvellement.
#------------------------------------------------------
$ALIM_MOTHSUB
  Gosub SET_SUBPLN_MSK
  Local Integer I_PER_SOR
  If PRNWDAT>GFINPERCPF
   Local Integer I_PER
   # Période de sortie
   For I_PER=1 To [M:SUB]NB_DEP
    If [M:SUB]PERSTRDAT(I_PER-1)<=PRNWDAT & PRNWDAT<=[M:SUB]PERENDDAT(I_PER-1) : I_PER_SOR=I_PER : Break : Endif
   Next I_PER
  Else
   # Période courante
   I_PER_SOR=find(GFINPERCPF,[M:SUB]PERENDDAT)
  Endif
  If I_PER_SOR
   RFNDSUB=[M:SUB]DPRBAS(I_PER_SOR-1)
   GPOINT = "CALFNDSUB" : Gosub ENTREE From EXEFNC
   If GOK<1 : Return : Endif
  Endif
Return

#------------------------------------------------------
# Le fonds de provision pour renouvellement est égal à :
#   - E_1FISRPR : Cumul de PPR E-1
#   - P_1FISRPR : cumul de PPR P-1
#   - PERFISRPR : Montant de PPR de la période de
#                 renouvellement.
#------------------------------------------------------
$ALIM_MOTHRPR
  Local Integer I_PER_SOR
  If PRNWDAT>GFINPERCPF
   Local Integer I_PER
   # Période de sortie
   For I_PER=1 To [M:PRPR]NB_RPR
    If [M:PRPR]PERSTRDAT(I_PER-1)<=PRNWDAT & PRNWDAT<=[M:PRPR]PERENDDAT(I_PER-1) : I_PER_SOR=I_PER : Break : Endif
   Next I_PER
  Else
   # Période courante
   I_PER_SOR=find(GFINPERCPF,[M:PRPR]PERENDDAT)
  Endif
  If I_PER_SOR
   RFNDRPR=[M:PRPR]E_1FISRPR(I_PER_SOR-1)+[M:PRPR]P_1FISRPR(I_PER_SOR-1)+[M:PRPR]PERFISRPR(I_PER_SOR-1)
   LCCNCADEXC=[M:PRPR]E_1SUPCAD(I_PER_SOR-1)+[M:PRPR]P_1SUPCAD(I_PER_SOR-1)+[M:PRPR]PERSUPCAD(I_PER_SOR-1)
   GPOINT = "CALFNDRPR" : Gosub ENTREE From EXEFNC
   If GOK<1 : Return : Endif
  Endif
Return

#------------------------------------------------------
# Un écart de caducité doit être calculé sur le bien
# fils par différence entre la base Industrielle de
# celui-ci et un montant issu des pères :
#   - Somme base AI pères
#   + Somme ecart caducité pères
#   - Somme suppléments caducité E-1 pères
#   - Somme suppléments caducité E   pères
#------------------------------------------------------
$ALIM_MOTHCADDEV
  Gosub SET_INDPLN_MSK From SUBRWP
  Local Integer I_PER_SOR
  If PRNWDAT>GFINPERCPF
   Local Integer I_PER
   # Période de sortie
   For I_PER=1 To [M:IND]NB_DEP
    If [M:IND]PERSTRDAT(I_PER-1)<=PRNWDAT & PRNWDAT<=[M:IND]PERENDDAT(I_PER-1) : I_PER_SOR=I_PER : Break : Endif
   Next I_PER
  Else
   # Période courante
   I_PER_SOR=find(GFINPERCPF,[M:IND]PERENDDAT)
  Endif
  If I_PER_SOR
   RCADDEV = -1*[M:IND]DPRBAS(I_PER_SOR-1)+[F:FAS]CCNCADDEV-LCCNCADEXC
   GPOINT = "CALCADDEV" : Gosub ENTREE From EXEFNC
   If GOK<1 : Return : Endif
  Endif
Return

#------------------------------------------------------
$ALIM_DPRBAS
 If [M:RWP0]CCNINICUM>[M:RWP0]DPRBASINI
  [M:RWP0]DPRBAS    = 0
  [M:RWP0]CCNCADEXC = [M:RWP0]CCNINICUM-[M:RWP0]DPRBASINI
 Else
  [M:RWP0]DPRBAS    = [M:RWP0]DPRBASINI-[M:RWP0]CCNINICUM
  [M:RWP0]CCNCADEXC    = 0
 Endif
 Affzo [M:RWP0]DPRBAS
 Affzo [M:RWP0]CCNCADEXC
Return

#------------------------------------------------------
$SET_INDPLN_MSK
 Case G_CCNPLNIND
  When G301CPT : [M:IND]=[M:PCPT]
  When G301FIS : [M:IND]=[M:PFIS]
  When G301MIN : [M:IND]=[M:PMIN]
  When G301ORI : [M:IND]=[M:PORI]
  When G301R76 : [M:IND]=[M:PR76]
  When G301TEC : [M:IND]=[M:PTEC]
  When G301RET : [M:IND]=[M:PRET]
  When G301LI1 : [M:IND]=[M:PLI1]
  When G301LI2 : [M:IND]=[M:PLI2]
  When G301LI3 : [M:IND]=[M:PLI3]
  When G301LI4 : [M:IND]=[M:PLI4]
  When G301LI5 : [M:IND]=[M:PLI5]
  When G301LI6 : [M:IND]=[M:PLI6]
 Endcase
Return

#------------------------------------------------------
$SET_CADPLN_MSK
 Case G_CCNPLNCAD
  When G301FIS : [M:CAD]=[M:PFIS]
  When G301MIN : [M:CAD]=[M:PMIN]
  When G301ORI : [M:CAD]=[M:PORI]
  When G301R76 : [M:CAD]=[M:PR76]
  When G301TEC : [M:CAD]=[M:PTEC]
  When G301RET : [M:CAD]=[M:PRET]
  When G301LI1 : [M:CAD]=[M:PLI1]
  When G301LI2 : [M:CAD]=[M:PLI2]
  When G301LI3 : [M:CAD]=[M:PLI3]
  When G301LI4 : [M:CAD]=[M:PLI4]
  When G301LI5 : [M:CAD]=[M:PLI5]
  When G301LI6 : [M:CAD]=[M:PLI6]
 Endcase
Return

#------------------------------------------------------
$SET_SUBPLN_MSK
 Case G_CCNPLNSUB
  When G301FIS : [M:SUB]=[M:PFIS]
  When G301MIN : [M:SUB]=[M:PMIN]
  When G301ORI : [M:SUB]=[M:PORI]
  When G301R76 : [M:SUB]=[M:PR76]
  When G301TEC : [M:SUB]=[M:PTEC]
  When G301RET : [M:SUB]=[M:PRET]
  When G301LI1 : [M:SUB]=[M:PLI1]
  When G301LI2 : [M:SUB]=[M:PLI2]
  When G301LI3 : [M:SUB]=[M:PLI3]
  When G301LI4 : [M:SUB]=[M:PLI4]
  When G301LI5 : [M:SUB]=[M:PLI5]
  When G301LI6 : [M:SUB]=[M:PLI6]
 Endcase
Return

#------------------------------------------------------
$CONDITIONNE_CCNINICAL
 If [F:RWP]RNWDONFLG=G_OUI | [M:RWP0]FLGCAL=G_OUI | [M:RWP0]RNWDAT=[0/0/0]
  [M:RWP0]CCNINICAL=""
 Elsif [M:RWP0]FLGCAL<>G_OUI &  [M:RWP0]RNWDAT<>[0/0/0]
  [M:RWP0]CCNINICAL=GICOCCNINICA
 Endif
 Affzo [M:RWP0]CCNINICAL
Return

#------------------------------------------------------
# Sous-programme de calcul des fonds à transmettre
# à la date de renouvellement saisie par l'utilisateur
# pour un bien passé en paramètre
#------------------------------------------------------
Subprog CAL_FONDS_TRANSMIS(PCPY, PAASREF, PCALLCALFLG, PRNWDAT, PISSRUL, RFNDCAD, RFNDSUB, RFNDRPR, RCADDEV, RCOD)
Value    Char    PCPY          # Société
Value    Char    PAASREF       # Référence du bien dont on doit calculer les fonds à transmettre
Value    Integer PCALLCALFLG   #
Value    Date    PRNWDAT       # Date de renouvellement
Value    Integer PISSRUL       # Règle de sortie
Variable Decimal RFNDCAD       # Fonds de caducité à transmettre
Variable Decimal RFNDSUB       # Fonds de subvention à transmettre
Variable Decimal RFNDRPR       # Fonds de provision à transmettre
Variable Decimal RCADDEV       # Montants à déduire de la base AI du bien fils pour calcul de l'écart de caducité.
Variable Integer RCOD          # Code retour

If !clalev([F:FAS])  : Local File FXDASSETS  [FAS]  : Endif
If !clalev([M:FASS]) : Local Mask FASISSP   [FASS] : Endif

If GSOCIETE<>PCPY
 GSOCIETE = PCPY
 Call CHARGE_ENVIRONNEMENT() From GLOFCYCPY
Endif

Read [F:FAS]FAS0=PAASREF
If fstat

Endif

Local    Integer I_PER
Local    Decimal LCCNCADEXC             : # Supplément du caducité du bien père

If PCALLCALFLG=G_OUI
 Gosub OUVRE_MASQUES_CALCUL From SUBRWP
 Local    Decimal VALNETTE(1..G301MAX-1) : # Valeurs nettes pour chaque bien par plan
 Local    Date    SORREG  (0..G301MAX-1)
 Local    Date    SORREGT (0..G301MAX-1)
 Local    Date    SORREGI (0..G301MAX-1)
 Local    Integer CODERR
 [M:FASS]ISSDATRUL = PISSRUL
 Call CALCULER_VALEURS_SORTIE ("[F:FAS]", GVML_TSRENEW, PRNWDAT, VALNETTE, SORREG, SORREGT, SORREGI, CODERR) From TRTFASISS
Endif

Gosub ALIM_MOTHCAD
If G_CCNSUB=G_OUI
 Gosub ALIM_MOTHSUB
Endif
Gosub ALIM_MOTHRPR
Gosub ALIM_MOTHCADDEV

End

#------------------------------------------------------
# Interdiction de faire des modifications sur la
# fiche si elle est déjà vérouillée par un autre
# utilisateur
#------------------------------------------------------
Funprog CTRL_VERROU_OK(PVERROU)
Value Integer PVERROU
 Local Integer RCOD
 Raz RCOD
 RCOD=G_OUI

 If !PVERROU & GREP=""
  Call ERREUR(mess(789,GML_MSGFAS,1)) From GESECRAN #"Opération de renouvellement vérouillée par un autre utilisateur. Modification impossible."
  RCOD=G_NON
 Endif
End RCOD

#------------------------------------------------------
# Vérifie si un bien comptable peut être choisi
# comme bien renouvelant
#------------------------------------------------------
Funprog IS_RNWAASREF_VALIDE(PAASREF)
Value Char PAASREF
Local Integer RETOUR

 If !clalev([F:FAS]) : Local File FXDASSETS [F:FAS] : Endif

 If PAASREF<>[F:FAS]AASREF
  Read [F:FAS]FAS0=PAASREF
  If fstat & fstat<>5
    RETOUR=-1*fstat
   End RETOUR
  Endif

  If fstat=5
   RETOUR=262
  Endif

 Endif

 If [F:FAS]OWNTYP   <>GVML_TDCONCE : RETOUR=744 : End RETOUR : Endif
 If [F:FAS]CCNETRNAT<>GVML_NECONCS : RETOUR=784 : End RETOUR : Endif
 If [F:FAS]CCNETRTYP<>GVML_NARENEW : RETOUR=785 : End RETOUR : Endif
 #@fq66375
 If (G_ACTIAS<>G_NON & [F:FAS]GACACN<>GVML_NIENSER) | (G_ACTIAS=G_OUI & [F:FAS]GACACN<>GVML_NIENSER & [F:FAS]IASACN<>GVML_NIENSER)
  RETOUR=811 : End RETOUR
 Endif


End RETOUR


