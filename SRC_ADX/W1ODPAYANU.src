#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ODPAYANU 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:33"
A_USER  = "DOC"
A_STAMP = "20181109230533"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ODPAYANU [DIA]
Gosub HORODAT
Local Inpbox "ODPAYANU" From GFONCTION At A_STAMP With A_WINDPREV Mask [DIA] As [SIM_]
Grizo [DIA]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DIA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=22 : X2(0)=91 : Y1(0)=12 : Y2(0)=17
Return

$ON_ODPNUMDEB
Onevent CONTROL Call C_ODPNUMDEB(zc) From W1ODPAYANU
Onevent BEFORE_INPUT Call AS_ODPNUMDEB(zc) From W1ODPAYANU
Return

Subprog AS_ODPNUMDEB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_ODPNUMDEB(zc) From W1ODPAYANU
Gosub _AFF
End

Subprog C_ODPNUMDEB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "ODPNUMDEB" : GZNUM = 1001180 : Endif
Endif
Gosub _AFF
End

Subprog S_ODPNUMDEB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELODP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELODP"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELODP","ODPAYVAL","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_ODPNUMFIN
Onevent CONTROL Call C_ODPNUMFIN(zc) From W1ODPAYANU
Onevent BEFORE_INPUT Call AS_ODPNUMFIN(zc) From W1ODPAYANU
Return

Subprog AS_ODPNUMFIN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_ODPNUMFIN(zc) From W1ODPAYANU
Gosub _AFF
End

Subprog C_ODPNUMFIN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "ODPNUMFIN" : GZNUM = 1001181 : Endif
Endif
If !mkstat
 ## Action STD
 Call C_ODPNUMFIN(VALEUR) From ODPAYANU
 If mkstat : GERR = 1 : GZONE = "ODPNUMFIN" : GZNUM = 1001181 : Endif
Endif
Gosub _AFF
End

Subprog S_ODPNUMFIN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELODP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELODP"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELODP","ODPAYVAL","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_MATDEB
Onevent BEFORE_INPUT Call AS_MATDEB(zc) From W1ODPAYANU
Return

Subprog AS_MATDEB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_MATDEB(zc) From W1ODPAYANU
Gosub _AFF
End

Subprog S_MATDEB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = "1"
 PARMSK(6) = ""
 PARMSK(7) = ""
 PARMSK(8) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELEMP","SELMAT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_MATFIN
Onevent CONTROL Call C_MATFIN(zc) From W1ODPAYANU
Onevent BEFORE_INPUT Call AS_MATFIN(zc) From W1ODPAYANU
Return

Subprog AS_MATFIN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_MATFIN(zc) From W1ODPAYANU
Gosub _AFF
End

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_MATFIN(VALEUR) From ODPAYANU
If mkstat : GERR = 1 : GZONE = "MATFIN" : GZNUM = 45743 : Endif
Gosub _AFF
End

Subprog S_MATFIN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = "1"
 PARMSK(6) = ""
 PARMSK(7) = ""
 PARMSK(8) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELEMP","SELMAT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_DATDEB
Onevent BEFORE_AREA Gosub AV_DATDEB From W1ODPAYANU
Return

$AV_DATDEB
Chgfmt [M]DATDEB(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_DATFIN
Onevent CONTROL Call C_DATFIN(zc) From W1ODPAYANU
Onevent BEFORE_AREA Gosub AV_DATFIN From W1ODPAYANU
Return

$AV_DATFIN
Chgfmt [M]DATFIN(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_DATFIN(VALEUR) From ODPAYANU
If mkstat : GERR = 1 : GZONE = "DATFIN" : GZNUM = 44783 : Endif
Gosub _AFF
End

$ON_TRCFLG
Onevent INIT_AREA Call D_TRCFLG(zc) From W1ODPAYANU
Onevent BEFORE_INPUT Call AS_TRCFLG(zc) From W1ODPAYANU
Return

Subprog D_TRCFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]TRCFLG,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_TRCFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


