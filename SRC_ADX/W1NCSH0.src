Subprog IB_PRODUCT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action IBPRDINF
 Call IBPRDINF(VALEUR) From PRDINFLIB
Endif
Gosub _AFF
End

Subprog AS_PRODUCT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(2061,GBOUT1) From OBJDIV
Call TEXTE(12837,GBOUT13) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_PRODUCT(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_PRODUCT(zc) From W1NCSH0
Onkey 170 Titled GBOUT13 Call B13_PRODUCT(zc) From W1NCSH0
Onkey   2 Titled GBOUTS Call S_PRODUCT(zc) From W1NCSH0
Onkey 144 Titled GBOUTP Call P_PRODUCT(zc) From W1NCSH0
Onkey 146 Titled GBOUTA Call SA_PRODUCT(zc) From W1NCSH0
Gosub _AFF
End

Subprog C_PRODUCT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ITMCHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ITMCHOICE"
 Call S_TAB_CHAR(VALEUR,PARMSK,"ITMCHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PRODUCT" : GZNUM = 19528 : Endif
Endif
If !mkstat
 ## Action VXADCUPC
 Call ADCCTRUPC(VALEUR) From VXADCUPC
 If mkstat : GERR = 1 : GZONE = "PRODUCT" : GZNUM = 19528 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ITM","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "PRODUCT" : GZNUM = 19528 : Endif
  If !mkstat
   ## Action STD
   Call C_PRODUCT(VALEUR) From SUBNCSH
   If mkstat : GERR = 1 : GZONE = "PRODUCT" : GZNUM = 19528 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_PRODUCT
Call AM_PRODUCT(zc)
If !mkstat & GOBJET
 zoncou = "PRODUCT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

