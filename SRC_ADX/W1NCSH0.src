#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSH0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:29"
A_USER  = "DOC"
A_STAMP = "20181109230529"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask NCSH0 [NCSH0]
Gosub HORODAT
Local Inpbox "NCSH0" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSH0] As [SIM_]
Grizo [NCSH0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [NCSH0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=83 : Y1(0)=1 : Y2(0)=15
Return

$ON_SITE
Onevent CONTROL Call C_SITE(zc) From W1NCSH0
Onevent AFTER_CHANGE Gosub AMM_SITE From W1NCSH0
Onevent BEFORE_INPUT Call AS_SITE(zc) From W1NCSH0
Return

Subprog AS_SITE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1427,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SITE(zc) From W1NCSH0
Onkey   2 Titled GBOUTS Call S_SITE(zc) From W1NCSH0
Onkey 144 Titled GBOUTP Call P_SITE(zc) From W1NCSH0
Onkey 146 Titled GBOUTA Call SA_SITE(zc) From W1NCSH0
Gosub _AFF
End

Subprog C_SITE(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SITE" : GZNUM = 53310 : Endif
If !mkstat
 ## Action ACONTFCY
 Call CONTSITE(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "SITE" : GZNUM = 53310 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("FCY","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "SITE" : GZNUM = 53310 : Endif
  If !mkstat
   ## Action CTLFCYAUZ
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "CTLFCYAUZ"
   Call S_AFF_CHAR(VALEUR,PARMSK,"CTLFCYAUZ","CONTX3","") From GACTION
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "SITE" : GZNUM = 53310 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_SITE
Call AM_SITE(zc)
If !mkstat & GOBJET
 zoncou = "SITE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SITE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_SITE(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "SITE" : GZNUM = 53310 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZSITE)")>indice
 [M]SITE(indice) = VALEUR
 Affzo ZSITE(indice)
Endif
Gosub _AFF
End

Subprog S_SITE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FCY"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_SITE(VALEUR)
Variable Char    VALEUR()
Call OBJET("FCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_SITE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_SITE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZSITE
Onevent BEFORE_AREA Gosub AV_ZSITE From W1NCSH0
Return

$AV_ZSITE
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Call LECTURE("FCY",num$([M]SITE(indice)),"") From CONTOBJ
zc = [F:FCY]FCYNAM
Gosub _AFF
Return

