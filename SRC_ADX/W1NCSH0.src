$ON_NCSCATEGORY
Onevent BEFORE_INPUT Call AS_NCSCATEGORY(zc) From W1NCSH0
Onevent AFTER_CHANGE Gosub AMM_NCSCATEGORY From W1NCSH0
Onevent INIT_AREA Call D_NCSCATEGORY(zc) From W1NCSH0
Onevent CONTROL Call C_NCSCATEGORY(zc) From W1NCSH0
Return

Subprog D_NCSCATEGORY(VALEUR)
Variable Integer VALEUR
If varinit([M]NCSCATEGORY,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_NCSCATEGORY(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(3715) From COMBOS
## Action STD
Call AS_NCSCATEGORY(VALEUR) From SUBNCSH
If mkstat=2
 [M]NCSCATEGORY(INDIC) = VALEUR
 Affzo NCSCATEGORY(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,3715,1))))
Endif
If !mkstat
 Discombo 0 From NCSCATEGORY(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From NCSCATEGORY(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_NCSCATEGORY(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NCSCATEGORY" : GZNUM = 30282 : Endif
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$AMM_NCSCATEGORY
Call AM_NCSCATEGORY(zc)
If !mkstat & GOBJET
 zoncou = "NCSCATEGORY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NCSCATEGORY(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_NCSCATEGORY(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "NCSCATEGORY" : GZNUM = 30282 : Endif
Gosub _AFF
End

