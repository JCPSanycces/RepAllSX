Subprog AS_NCSBPS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1515,GBOUT1) From OBJDIV
Call TEXTE(20355,GBOUT11) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_NCSBPS(VALEUR) From SUBNCSH
If mkstat=2
 [M]NCSBPS(INDIC) = VALEUR
 Affzo NCSBPS(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_NCSBPS(zc) From W1NCSH0
Onkey 139 Titled GBOUT11 Call B11_NCSBPS(zc) From W1NCSH0
Onkey   2 Titled GBOUTS Call S_NCSBPS(zc) From W1NCSH0
Onkey 144 Titled GBOUTP Call P_NCSBPS(zc) From W1NCSH0
Onkey 146 Titled GBOUTA Call SA_NCSBPS(zc) From W1NCSH0
Gosub _AFF
End

Subprog C_NCSBPS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BPSCHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BPSCHOICE"
 Call S_TAB_CHAR(VALEUR,PARMSK,"BPSCHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NCSBPS" : GZNUM = 3680 : Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("BPS","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "NCSBPS" : GZNUM = 3680 : Endif
Endif
Gosub _AFF
End

