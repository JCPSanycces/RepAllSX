#<AdxTL>@(#)3.0.0.0 $Revision$
##########################
# Class PPRICFICH
##########################
# By BESPR

$ACTION
Case CURPRO
    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is an event called on properties
Endcase
Return

#######################################################################################
$METHODS
# CURPTH is the child class path if the method is called on a child class.
# If the method is called on the main class, CURPTH is empty.
Case CURPTH
  When ""
    Case ACTION
      When "AREAD_AFTER"             : Gosub AREAD_AFTER
    Endcase
  When "PPC"
    Case ACTION
      When "AREAD_AFTER"             : Gosub AREAD_AFTER_PPC
    Endcase
  When "PPL"
    Case ACTION
      When "AREAD_AFTER"             : Gosub AREAD_AFTER_PPL
#      When "AINSERT_CONTROL_AFTER"   : Gosub PPL_AINSERT_CONTROL_AFTER  # Standard CRUD operation on line
#      When "AUPDATE_CONTROL_AFTER"   : Gosub PPL_AUPDATE_CONTROL_AFTER  # Standard CRUD operation on line
#      When "AINSERT_BEFORE"          : Gosub PPL_AINSERT_BEFORE         # Standard CRUD operation on line
    Endcase
  When Default
Endcase
Return

#######################################################################################
$PROPERTIES
  Case CURPRO
    When Default
  Endcase
Return

#######################################################################################
# METHODS                                                                             #
#######################################################################################
$AREAD_AFTER
# Main class after read

Return

#######################################################################################
$AREAD_AFTER_PPC
# Child class PPC after read
# this = PPRICFICH.PPC(A_N2)

Local Integer TEMP
Local Char TEMPPRO

# Need to put the [F:PPC]CRIDES(0-4) descriptions into the column headings of {F:PPL]PLICRI1-5 properties
# this.CRIDES0=[F:PPC]CRIDES(0) - CRIDES0 is not defined in PPC, its in PPL

Return

#########################################################################################
$AREAD_AFTER_PPL
# Child class PPL after read
# this = PPRICFICH.PPL(A_N2)

Local File PPRICCONF [T_PPC]
Local Integer TEMP, TEMPNEW, TEMPAI
Local Char TEMPPRO, TEMPDES

Read [T_PPC]PPC0 = [F:PPL]PLI

#For TEMP=0 To 8
#  TEMPPRO = "this.PPL.DCCVAL"+num$(TEMP)
#  VIA(TEMPPRO) = [F:PPL]DCGVAL(TEMP)
#  this.PPL.DCGVAL+num$(TEMP)=[F:PPL]DCGVAL(TEMP)
#Next TEMP

# Need to put the DCGVALDES0-4 descriptions into the column headings of DCGVAL0-4 properties
# Need to put the values of [F:PPL]DCGVAL(0-4) into the properties DCGVAL0-4 because using DIM puts it in a separate tab
this.DCGVAL0=[F:PPL]DCGVAL(0)
this.DCGVAL1=[F:PPL]DCGVAL(1)
this.DCGVAL2=[F:PPL]DCGVAL(2)
this.DCGVAL2=[F:PPL]DCGVAL(3)
this.DCGVAL2=[F:PPL]DCGVAL(4)
this.DCGVAL2=[F:PPL]DCGVAL(5)
this.DCGVAL2=[F:PPL]DCGVAL(6)
this.DCGVAL2=[F:PPL]DCGVAL(7)
this.DCGVAL2=[F:PPL]DCGVAL(8)


# Need to put the [F:PPC]CRIDES(0-4) descriptions into the column headings of {F:PPL]PLICRI1-5 properties
# This is the --- Call CHARCRIDES([F:PPC]FIL(0),[F:PPC]FLD(0),WCRIDES) From TRTPARAM --- rouine
#this.CRIDES0=[F:T_PPC]CRIDES(0)
#this.CRIDES1=[F:T_PPC]CRIDES(1)
#this.CRIDES2=[F:T_PPC]CRIDES(2)
#this.CRIDES3=[F:T_PPC]CRIDES(3)
#this.CRIDES4=[F:T_PPC]CRIDES(4)

Local File ATABZON [T_ATZ]
Local File ATEXTE  [T_ATX]

For TEMP=0 To 4
  Read [T_ATZ] CODZONE=[F:T_PPC]FIL(TEMP);[F:T_PPC]FLD(TEMP)
  If !fstat
    Read [T_ATX] NUMERO=this.ACTX.LAN;[F:T_ATZ]NOLONG
    If !fstat
     Case TEMP
        When 0
          this.CRIDES0=[F:T_ATX]TEXTE
        When 1
          this.CRIDES1=[F:T_ATX]TEXTE
        When 2
          this.CRIDES2=[F:T_ATX]TEXTE
        When 3
          this.CRIDES3=[F:T_ATX]TEXTE
        When 4
          this.CRIDES4=[F:T_ATX]TEXTE
    Endcase
  Endif
Endif

Next TEMP

Close File [T_PPC],[T_ATZ],[T_ATX]

Return

#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
Case ACTION
  When Default
Endcase

Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

