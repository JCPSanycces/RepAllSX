#<AdxTL>@(#)0.0.0.0 $Revision$
End
## Actions appelûˋes pour faire le Zoom sur les engagements et prûˋ engagements
## Zoom û  partir de la consultation de la balance analytique et des budgets

$INIT
Local Integer SAVNOLIGN
SAVNOLIGN = nolign
Return


#####################################################################################
## Tunnel depuis ????
#####################################################################################

$SEL_LISTE
# le 08/12/09 : de part la dmd 60245 tunnel depuis consultation ana,
# il apparait que cette partie n'a pas ûˋtûˋ revu...
# NB: en commentaire #08/12: *** ce qui est devenu obselû´te

Local Char     CRIT(250)
Local Integer  LIN : # Ligne dans tableau critû´re qui correspond au budget/date/site/sociûˋtûˋ
If !clalev([F:CMM]) : Local File GCOMMIT  [CMM] : Endif
If !clalev([F:CMD]) : Local File GCOMMITD [CMD] : Endif
Case GACTION
 When "VISUCMM3" : # Prûˋ engagement
  TIT= mess(1,631,1)
  CRIT = "[CMM]TYP=1"
  Filter [TBU] Where BUDTYP=[M:BCR]BUDTYP & (COLTYP=7 | COLTYP=8)
 When "VISUCMM4" : # Engagement
  TIT= mess(2,631,1)
  CRIT = "[CMM]TYP=2"
  Filter [TBU] Where BUDTYP=[M:BCR]BUDTYP & (COLTYP=5 | COLTYP=6)
Endcase

Read [TBU]TBU1 First
Filter [TBU]
If fstat : Return : Endif
LIN = [F:TBU]LINSELCRI-1
Call LECTURE("BUP",[M:BCR]BUD(LIN),"") From CONTOBJ
Local Integer INDDIE
Local Integer I1, I2, I3, I4, I5, I6, I7, I8, I9
Gosub INDDIE From BUDGET3
#08/12: Call LECTURE("BPX",[F:BUP]PARAXI,"") From CONTOBJ

CRIT -= "& [CMM]CUR=[M:BCR]CUR(LIN) & [CMD]CPY=[M:BCR]CPY(LIN)"
If [M:BCR]FCY(LIN)<>""
 CRIT -= " & [CMD]FCYLIN=[M:BCR]FCY(LIN)"
Endif

#09/12/09
#Maintenant les fitres sur les sections sont passûˋ en tests dans la boucle
#de parcours des lignes d'engagements
#Filters on Center are now done into the For loop on Commitment lines
Case [M:BCR]BUDCAT
 When 1 : # Pûˋriode / Period
  CRIT -= "& [CMD]ACCDAT>=[M:BUD]PERSTR(nolign-1)"
  CRIT -= "& [CMD]ACCDAT<=[M:BUD]PEREND(nolign-1)"
  CRIT -= "& [CMD]ACC"+num$([M:BUD]LEDTYP)+"=[M:BUD]ACC"
 When 2 : # Nature / Analytics Account
  CRIT -= "& [CMD]ACCDAT>=[M:BCR]DATDEB(LIN) & [CMD]ACCDAT<=[M:BCR]DATFIN(LIN)"
  CRIT -= "& [CMD]ACC"+num$([M:BUD]LEDTYP)+"=[M:BUD]ACC"
 When 3 : # Section / Center
  CRIT -= "& [CMD]ACCDAT>=[M:BCR]DATDEB(LIN) & [CMD]ACCDAT<=[M:BCR]DATFIN(LIN)"
  CRIT -= "& [CMD]ACC"+num$([M:BUD]LEDTYP)+"=[M:BUD]CODACC(nolign-1)"
Endcase

Link [CMD] With [CMM]CMM0=NUM
& As [LNK]
& Where evalue(CRIT)

For [LNK]CMD0(1)
 DOIT=0
 I1 = find([M:BUD]DIE1,[CMD]DIE(0..dim([F:CMD]DIE)-1))
 I2 = find([M:BUD]DIE2,[CMD]DIE(0..dim([F:CMD]DIE)-1))
 I3 = find([M:BUD]DIE3,[CMD]DIE(0..dim([F:CMD]DIE)-1))
 I4 = find([M:BUD]DIE4,[CMD]DIE(0..dim([F:CMD]DIE)-1))
 I5 = find([M:BUD]DIE5,[CMD]DIE(0..dim([F:CMD]DIE)-1))
 I6 = find([M:BUD]DIE6,[CMD]DIE(0..dim([F:CMD]DIE)-1))
 I7 = find([M:BUD]DIE7,[CMD]DIE(0..dim([F:CMD]DIE)-1))
 I8 = find([M:BUD]DIE8,[CMD]DIE(0..dim([F:CMD]DIE)-1))
 I9 = find([M:BUD]DIE9,[CMD]DIE(0..dim([F:CMD]DIE)-1))

 Case [M:BCR]BUDCAT
  When 1, 3 : # Pûˋriode ou Section / Period or Center
   For J=1 To INDDIE
    K = evalue("I"+num$(J))
    If K & evalue("[F:CMD]CCE"+num$(K))=evalue("[M:BUD]CCE"+num$(J))
     DOIT = 1
    Else
     DOIT = 0
     Break
    Endif
   Next
  When 2 : # Nature / Account
   For J=1 To INDDIE
    K = evalue("I"+num$(J))
    If K
     If J=INDDIE & evalue("[F:CMD]CCE"+num$(K))=[M:BUD]CODCCE3(nolign-1)
      DOIT = 1
     Elsif evalue("[F:CMD]CCE"+num$(K))=evalue("[M:BUD]CCE"+num$(J))
      DOIT = 1
     Else
      DOIT = 0 : Break
     Endif
    Else
     DOIT = 0 :  Break
    Endif
   Next
 Endcase
#----------------------- Fin test Section / End of Centers tests ---------------#
 If DOIT
  NBTEX +=1
  TEXTE(NBTEX) = [F:CMM]NUM-[F:CMM]DESVCR-num$([F:CMD]ACCDAT)
  TEX(NBTEX)   = [F:CMM]NUM
 Endif
Next

If NBTEX=0
 GERR = 2 : GOK = 0
 Case GACTION
  When "VISUCMM3" : GMESSAGE = mess(87,108,1) :# Pas de prûˋ engagements qui constituent le solde
  When "VISUCMM4" : GMESSAGE = mess(88,108,1) :# Pas d'engagements qui constituent le solde
 Endcase
Endif
Return


#####################################################################################
## Tunnel depuis la consultation de balance analytique
#####################################################################################

$SEL_LISTEB
Local Char    CRIT(250)
Local Integer I , J , K
Local Integer P , PP(1..3)
Local Integer NBAXE
Local Char    TBAXE(GLONDIE)(1..9) , TBSEC(GLONCCE)(1..9)

If !clalev([F:CMM]) : Local File GCOMMIT  [CMM] : Endif
If !clalev([F:CMD]) : Local File GCOMMITD [CMD] : Endif

Case GACTION
 When "VISUCMM1" : TIT= mess(1,631,1) : CRIT = "[CMM]TYP=1" : # Prûˋ engagt
 When "VISUCMM2" : TIT= mess(2,631,1) : CRIT = "[CMM]TYP=2" : # Engagement
Endcase

#Dmd 65345
#CRIT -= '& [CMM]CUR="'+[M:BLA1]CUR+'"'
If [M:EDA]DEVORG<>""
 CRIT -= '& [CMM]CUR="'+[M:EDA]DEVORG+'"'
Endif
CRIT -= '& [CMD]CPY="'+[M:BLA1]CPY+'"'
If [M:EDA]DETSIT=2
 CRIT -= '& [CMD]FCYLIN="'+[M:BLA2]SITE(nolign-1)+'"'
Else
 If [M:BLA1]FCYDEB<>""
  CRIT -= '& [CMD]FCYLIN>="'+[M:BLA1]FCYDEB+'"'
 Endif
 If [M:BLA1]FCYFIN<>""
  CRIT -= '& [CMD]FCYLIN<="'+[M:BLA1]FCYFIN+'"'
 Endif
Endif

Raz PP
For P=0 To [M:EDA]NBCOL-1
 If (GACTION="VISUCMM1" & [M:EDA]TYPCOL(P)=7) or (GACTION="VISUCMM2" & [M:EDA]TYPCOL(P)=6)
  PP([M:EDA]PERCOL(P)) = 1
 Endif
Next P

If sum(PP)
 CRIT -= '& ('
 K = 0
 For P=1 To 3
  If PP(P)
   If K
    CRIT -= '|'
   Endif
   CRIT -= '([CMD]ACCDAT>=['+format$(GFMD,evalue("[M:BLA1]DATDEB"+num$(P)))+']'
   CRIT -= '& [CMD]ACCDAT<=['+format$(GFMD,evalue("[M:BLA1]DATFIN"+num$(P)))+'])'
   K = 1
  Endif
 Next P
 CRIT -= ')'
Endif

NBAXE = 0
For P=0 To [M:EDA]NBAXE-1
 Case [M:EDA]TYP(P)
  When 1
   If [M:EDA]PYRSEC(P)="" or [M:BLA1]DETAIL=2
    #Dmd 60245
    #CRIT -= '& [CMD]ACC="'+evalue("[M:BLA2]COMPTE"+num$(P+1)+"("+num$(nolign-1)+")")+'"'
    CRIT -= '& [CMD]ACC('+num$([M:EDA]LEDTYP-1)+')="'+evalue("[M:BLA2]COMPTE"+num$(P+1)+"("+num$(nolign-1)+")")+'"'
   Endif
  When 2
   If [M:EDA]PYRSEC(P)="" or [M:BLA1]DETAIL=2
    NBAXE += 1
    TBAXE(NBAXE) = [M:EDA]AXE(P)
    TBSEC(NBAXE) = evalue("[M:BLA2]COMPTE"+num$(P+1)+"("+num$(nolign-1)+")")
    If left$(TBSEC(NBAXE),1)="<" : # <vide>
     TBSEC(NBAXE) = ""
    Endif
   Endif
 Endcase
Next P

Link [CMD] With [CMM]CMM0=NUM
& As [LNK]
& Where evalue(CRIT)

Local Integer DIEOK, ALLOK, CCEOK

For [LNK]CMD0(1)
 K = 1
 DIEOK = 1
 CCEOK = 0
 # Dmd 64893
 # Plutot que de lire la premiû´re ligne uniquement,
 # On regarde si au moins une des lignes corresponds
 # Pour les axes si un axe diffû´re dans une des lignes, on est pas bon
 # Pour les sections, si toutes correspondent sur au moins une ligne, on est bon
  For [LNK]CMD0
   ALLOK=1
   For P=1 To NBAXE
    J = find(TBAXE(P),[F:CMD]DIE)
    If J
     If [F:CMD]CCE(J-1)<>TBSEC(P)
      ALLOK = 0 : Break
     Endif
    Else
     DIEOK = 0 : Break 2
    Endif
   Next P
   If ALLOK
    CCEOK = 1 : Break
   Endif
  Next
 If DIEOK & CCEOK
  NBTEX +=1
  TEXTE(NBTEX) = [F:CMM]NUM-[F:CMM]DESVCR-num$([F:CMD]ACCDAT)
  TEX(NBTEX)   = [F:CMM]NUM
 Endif
 If NBTEX>=dim(TEXTE)-1 : Break : Endif
Next
If NBTEX=0
 GERR = 2 : GSTATUT=GSTAESC
 Case GACTION
  When "VISUCMM1" : GMESSAGE = mess(87,108,1) : # Pas de prûˋ engagements qui constituent le solde
  When "VISUCMM2" : GMESSAGE = mess(88,108,1) : # Pas d'engagements qui constituent le solde
 Endcase
Endif
GOK = 1

#Sauvegarde avant bug 64893
#For [LNK]CMD0(1)
# K = 1
# For [LNK]CMD0
#  For P=1 To NBAXE
#   J = find(TBAXE(P),[F:CMD]DIE)
#   If J
#    If [F:CMD]CCE(J-1)<>TBSEC(P)
#     K = 0 : Break 2
#    Endif
#   Else
#    K = 0 : Break 2
#   Endif
#  Next P
# Next
# If K=1
#  NBTEX +=1
#  TEXTE(NBTEX) = [F:CMM]NUM-[F:CMM]DESVCR-num$([F:CMD]ACCDAT)
#  TEX(NBTEX)   = [F:CMM]NUM
# Endif
# If NBTEX>=dim(TEXTE)-1 : Break : Endif
#Next
Return


#####################################################################################
## Tunnel depuis ????
#####################################################################################

$SEL_LISTEC
Local Char    CRIT(250)
If !clalev([F:CMM]) : Local File GCOMMIT  [CMM] : Endif
If !clalev([F:CMD]) : Local File GCOMMITD [CMD] : Endif

Case GACTION
 When "VISUCMM5" : TIT= mess(1,631,1) : CRIT = "[CMM]TYP=1 & [CMM]CUR='"+[M]CUR+"'" : # Prûˋ engagt
 When "VISUCMM6" : TIT= mess(2,631,1) : CRIT = "[CMM]TYP=2 & [CMM]CUR='"+[M]CUR+"'" : # Engagement
Endcase
CRIT -= '& [CMD]CPY="'+[M]CPY+'"'
If [M]FCY<>""
 CRIT -= " & [CMD]FCYLIN='"+[M]FCY+"'"
Endif
CRIT -= '& [CMD]ACCDAT>=[M]DATDEB & [CMD]ACCDAT<=[M]DATFIN'
CRIT -= '& [CMD]CNA="'+[M]CNA(nolign-1)+'"'
For I=1 To GOPTCANA
#  CRIT -= '& [CMD]CCE'+num$(I)+'="'+evalue("[M]CCE"+num$(I)+"("+num$(nolign-1)+")")+'"'
Next
If dim([M:CBAX]FLG1)>0 & [M:CBAX]FLG1=2
  CRIT+= '& [CMD]CCE'+num$([M:CBAX]AXE1)+'="'+evalue("[M]CCE"+num$([M:CBAX]AXE1)+"("+num$(nolign-1)+")")+'"'
Endif
If dim([M:CBAX]FLG2)>0 & [M:CBAX]FLG2=2 :
  CRIT += '& [CMD]CCE'+num$([M:CBAX]AXE2)+'="'+evalue("[M]CCE"+num$([M:CBAX]AXE2)+"("+num$(nolign-1)+")")+'"'
Endif
If dim([M:CBAX]FLG3)>0 & [M:CBAX]FLG3=2
  CRIT += '& [CMD]CCE'+num$([M:CBAX]AXE3)+'="'+evalue("[M]CCE"+num$([M:CBAX]AXE3)+"("+num$(nolign-1)+")")+'"'
Endif
If dim([M:CBAX]FLG4)>0 & [M:CBAX]FLG4=2
  CRIT += '& [CMD]CCE'+num$([M:CBAX]AXE4)+'="'+evalue("[M]CCE"+num$([M:CBAX]AXE4)+"("+num$(nolign-1)+")")+'"'
Endif
If dim([M:CBAX]FLG5)>0 & [M:CBAX]FLG5=2
  CRIT += '& [CMD]CCE'+num$([M:CBAX]AXE5)+'="'+evalue("[M]CCE"+num$([M:CBAX]AXE5)+"("+num$(nolign-1)+")")+'"'
Endif
If dim([M:CBAX]FLG6)>0 & [M:CBAX]FLG6=2
  CRIT += '& [CMD]CCE'+num$([M:CBAX]AXE6)+'="'+evalue("[M]CCE"+num$([M:CBAX]AXE6)+"("+num$(nolign-1)+")")+'"'
Endif
If dim([M:CBAX]FLG7)>0 & [M:CBAX]FLG7=2
  CRIT += '& [CMD]CCE'+num$([M:CBAX]AXE7)+'="'+evalue("[M]CCE"+num$([M:CBAX]AXE7)+"("+num$(nolign-1)+")")+'"'
Endif
If dim([M:CBAX]FLG8)>0 & [M:CBAX]FLG8=2
  CRIT += '& [CMD]CCE'+num$([M:CBAX]AXE8)+'="'+evalue("[M]CCE"+num$([M:CBAX]AXE8)+"("+num$(nolign-1)+")")+'"'
Endif
If dim([M:CBAX]FLG9)>0 & [M:CBAX]FLG9=2
  CRIT += '& [CMD]CCE'+num$([M:CBAX]AXE9)+'="'+evalue("[M]CCE"+num$([M:CBAX]AXE9)+"("+num$(nolign-1)+")")+'"'
Endif

Link [CMD] With [CMM]CMM0=NUM
& As [LNK]
& Where evalue(CRIT)

For [LNK]CMD0(1)
 NBTEX +=1
 TEXTE(NBTEX) = [F:CMM]NUM-[F:CMM]DESVCR-num$([F:CMD]ACCDAT)
 TEX(NBTEX)   = [F:CMM]NUM
Next
If NBTEX=0
 GERR = 2 : GOK = 0
 Case GACTION
  When "VISUCMM5" : GMESSAGE = mess(87,108,1) : # Pas de prûˋ engagements qui constituent le solde
  When "VISUCMM6" : GMESSAGE = mess(88,108,1) : # Pas d'engagements qui constituent le solde
 Endcase
Endif
Return

######################################################################################

######################################################################################
$FIN_LISTE
# GBIDC1 contient la clûˋ de l'objet CMM qu'on passera en paramû´tre û  GOBJETC0
GBIDC1 = TEX(CHOIX)
GOK = 1
# Si 1 engagement, on affiche pas la liste => On boucle sur le zoom quand on fait FIN dans
# la fenûˆtre Gobjet du zoom des engagements. On positionne GOK pour ne pas boucler.
# On positionne GSTATUT pour que dans $CONTROLE on passe correctement
If NBTEX=1
 GSTATUT = 28
 GOK = 0
Endif
Return

$CONTROLE
If GSTATUT=GSTAESC : FIN=1 : Endif
Return

$EXEC
## Action GOBJETC0
Local Char    SAVACT(20)
Local Integer SAVGOK
SAVGOK = GOK
SAVACT = GACTION : GACTION = "GOBJETC0"
Call OBJET_CHAR(GBIDC1,"CMM","") From GOBJET
GACTION = SAVACT
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub AFF From GSAISIE
nolign = SAVNOLIGN
GOK = SAVGOK
If GOK=1 : SAI=1 : Endif
GOK = 1
Return

