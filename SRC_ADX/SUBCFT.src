#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management CFT
######################################################################################
## Section automatically added (Object CFT) 09/18/2013 16:52:57 (LUCUE)
## SAM # 87925 - Cash forecast Management - CFO Types / Company
######################################################################################
$ACTION
Case ACTION
 When "SETBOUT": Gosub SETBOUT
 When Default
Endcase
Return

#######################################################################################
$SETBOUT
  If GREP = "" Then
    CHAINE += "A"
  Endif
Return

#######################################################################################
#        ACTION CHAMPS
#######################################################################################

########################## FCY ####################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End

########################## CFOTYP ####################
Subprog C_CFOTYP(VALEUR)
Variable Integer VALEUR
Call UNICITE(VALEUR, [M]CFOTYP) From OBJDIV
End


Subprog AM_CFOTYP(VALEUR)
Variable Integer VALEUR

### DAYS
If VALEUR>4
   Raz [M:CFT]DAY1(nolign-1),[M:CFT]DAY2(nolign-1),[M:CFT]DAY3(nolign-1)
   Affzo [M:CFT]DAY1(nolign-1): Affzo [M:CFT]DAY2(nolign-1): Affzo [M:CFT]DAY3(nolign-1)
Endif

### SNS
If VALEUR<5 or VALEUR=10
   [M:CFT]SNS(nolign-1)=1
   Affzo [M:CFT]SNS(nolign-1)
Endif
If VALEUR<10 and VALEUR>4
   [M:CFT]SNS(nolign-1)=2
   Affzo [M:CFT]SNS(nolign-1)
Endif

### DAYINC
If VALEUR>4
   Raz [M:CFT]DAYINC(nolign-1)
   Affzo [M:CFT]DAYINC(nolign-1)
Endif

### TYPRAT
If VALEUR<20
   Raz [M:CFT]TYPRAT(nolign-1)
   Affzo [M:CFT]TYPRAT(nolign-1)
Endif
End

Subprog AS_CFOTYP(VALEUR)
Variable Integer VALEUR
For X=11 To 19
   GMENLOC(X)=1
Next
End

################# DAY1 ###############################
Subprog C_DAY1(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0
   If VALEUR > 30 and VALEUR<>99: mkstat=2 : End: Endif
Endif
End

Subprog AM_DAY1(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
   Raz [M:CFT]DAY2(nolign-1): Affzo [M:CFT]DAY2(nolign-1)
   Raz [M:CFT]DAY3(nolign-1): Affzo [M:CFT]DAY3(nolign-1)
Endif
End

Subprog AS_DAY1(VALEUR)
Variable Decimal VALEUR
If [M:CFT]CFOTYP(nolign-1)>9 or [M:CFT]CFOTYP(nolign-1)<5
   mkstat=2
Endif
End

################# DAY2 ###############################
Subprog C_DAY2(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0
   If VALEUR > 30 and VALEUR<>99: mkstat=2 : End: Endif
   If VALEUR <= [M:CFT]DAY1(nolign-1): mkstat=2: Endif
Endif
End

Subprog AM_DAY2(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
   Raz [M:CFT]DAY3(nolign-1): Affzo [M:CFT]DAY3(nolign-1)
Endif
End

################# DAY3 ################################
Subprog C_DAY3(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0
   If VALEUR > 30 and VALEUR<>99: mkstat=2 : End: Endif
    If VALEUR <= [M:CFT]DAY2(nolign-1): mkstat=2: Endif
Endif
End

####################### SNS ##############################
Subprog AS_SNS(VALEUR)
Variable Integer VALEUR
If [M:CFT]CFOTYP(nolign-1)<20
   mkstat=2
Endif
End

####################### DAYINC ##############################
Subprog AS_DAYINC(VALEUR)
Variable Decimal VALEUR
If [M:CFT]CFOTYP(nolign-1)>4
   mkstat=2
Endif
End
######################################################################################
## Section automatically added (screen CFOTYP) 01/20/2014 09:24:12 (LUCUE)
######################################################################################
Subprog AS_PASHOR(VALEUR)
Variable Decimal VALEUR
If [M:CFT]CFOTYP(nolign-1)>19
   mkstat=2
Endif
End


######################################################################################
