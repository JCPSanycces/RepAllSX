#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIACH36 : Utilitaire de Contrôle cohérence BPSNUM      Module Achats  #
##########################################################################
#   Achats de sous-traitance                Issue 95944                  #
##########################################################################

Call MAJ_UTIACH36
End

##################################
Subprog MAJ_UTIACH36
Local Char DOSSIER(30) : DOSSIER=nomap
#Call SAIDOS(DOSSIER,"") From SAIDOS
If [L]DOSSIER<>""
   If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

   Call EXE_UTIACH36([L]DOSSIER)
Endif
End

##################################
Subprog EXE_UTIACH36(DOSSIER)
Value Char DOSSIER

Local Integer LRET

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIACH36 : Subcontract Purchase Order Analysis") From LECFIC
Call ECR_TRACE("UTIACH36 : Start with folder"-DOSSIER,0) From GESECRAN

# Traitement des EO
If GMODU(6)=2 : # Module Achat actif
  Gosub TRT_POQ_EO
Endif


$FIN_UTIACH36
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End


##################################
$TRT_POQ_EO

Local File =DOSSIER+".SCOHEAD"    [SCO]
Local File =DOSSIER+".SCOITM"     [SCI]    # pour appel SCOLIB
Local File =DOSSIER+".SCOMAT"     [SCM]    # pour appel SCOLIB
Local File =DOSSIER+".SCOSRV"     [SCS]
Local File =DOSSIER+".ORDERS"     [ORD]

Local File =DOSSIER+".SCOITM"     [SCIW]
Local File =DOSSIER+".SCOMAT"     [SCMW]
Local File =DOSSIER+".SCOSRV"     [SCSW]
Local File =DOSSIER+".PORDERQ"    [POQW]
Local File =DOSSIER+".PORDER"     [POHW]

Local File =DOSSIER+".FACILITY"   [FCY]
Local File =DOSSIER+".ITMFACILIT" [ITF]
Local File =DOSSIER+".ITMMASTER"  [ITM]
Local File =DOSSIER+".ITMBPS"     [ITP]
Local File =DOSSIER+".BPARTNER"   [BPR]
Local File =DOSSIER+".BPSUPPLIER" [BPS]
Local File =DOSSIER+".BPDLVCUST"  [BPD]

Local Mask =DOSSIER+".ORDK"       [ORDK]

Local Char     WSCONUM(GLONVCR),WBPRNUM(GLONBPR)
Local Integer  WSIMFLG, IPOQ,IERR
Local Shortint STAT : STAT=0

WSIMFLG=2
If !GBATCH
   Call OUINON(mess(6,115,1)-"?"-nomap,WSIMFLG) From GESECRAN
Endif

Call ECR_TRACE(" ",0) From GESECRAN
If WSIMFLG=2
   Call ECR_TRACE("Analysis subcontract order on EO"-mess(6,115,1),0) From GESECRAN
Else
   Call ECR_TRACE("Analysis subcontract order on EO",0) From GESECRAN
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(" ",0) From GESECRAN

Gosub CTL_POQ_BPSNUM

Gosub CTL_ALL_SCI_BPAADD



$FIN_UTIACH36_EO
Close Local File [SCO]
Close Local File [SCM]
Close Local File [SCI]
Close Local File [SCS]
Close Local File [ORD]

Close Local File [SCIW]
Close Local File [SCMW]
Close Local File [SCSW]
Close Local File [POHW]
Close Local File [POQW]

Close Local File [FCY]
Close Local File [ITM]
Close Local File [ITF]
Close Local File [ITP]
Close Local File [BPR]
Close Local File [BPS]
Return

$CTL_POQ_BPSNUM
Call ECR_TRACE("--------------------------------------------------------------",0) From GESECRAN
Call ECR_TRACE("UTIACH36 : Purchase Order with different Supplier code/address",0) From GESECRAN
Call ECR_TRACE("--------------------------------------------------------------",0) From GESECRAN
Trbegin [POQW]
Raz IPOQ
Filter [POQW] Where VCRTYPORI=36 & LINTYP=2 & LINCLEFLG<>2 Order By POHFCY Asc; POHNUM Asc
For [POQW]
    If [F:POQW]POHFCY<>GFCY
       GFCY=[F:POQW]PRHFCY
       Gosub CHARG_PARAM    # charger GEOMLOC par exemple
    Endif
    Read [SCO]SCO0=[F:POQW]VCRNUMORI
    If fstat
       Call ECR_TRACE("Purchase order"-[F:POQW]POHNUM-num$([F:POQW]POPLIN)-"SCOHEAD Missing record: EO"-[F:POQW]VCRNUMORI,1) From GESECRAN
       IERR+=1
    Endif
    Read [POHW]POH0=[F:POQW]POHNUM
    If fstat
       Call ECR_TRACE("Purchase order"-[F:POQW]POHNUM-num$([F:POQW]POPLIN)-"PORDER Missing record: PO"-[F:POQW]POHNUM,1) From GESECRAN
       IERR+=1
    Endif
    If [F:SCO]BPRNUM<>[F:POHW]BPSNUM
       Call ECR_TRACE("Purchase order"-[F:POQW]POHNUM-num$([F:POQW]POPLIN)-"SCOHEAD/PORDERQ"-[F:POQW]VCRNUMORI
&                                        -"Supplier"-[F:SCO]BPRNUM-[F:POHW]BPSNUM,1) From GESECRAN
       IERR+=1
    Endif
    Read [SCIW]SCI0=[F:POQW]VCRNUMORI;[F:POQW]VCRLINORI
    If fstat
       Call ECR_TRACE("Purchase order"-[F:POQW]POHNUM-num$([F:POQW]POPLIN)-"SCOITM Missing record: EO"-[F:POQW]VCRNUMORI-num$([F:POQW]VCRLINORI),1) From GESECRAN
       IERR+=1
    Endif
    If [F:SCIW]BPRNUM<>[F:POHW]BPSNUM
       Call ECR_TRACE("Purchase order"-[F:POQW]POHNUM-num$([F:POQW]POPLIN)-"SCOITM/PORDERQ"-[F:POQW]VCRNUMORI
&                                        -"Supplier"-[F:SCIW]BPRNUM-[F:POHW]BPSNUM,1) From GESECRAN
       IERR+=1
    Endif
    If [F:SCIW]PRHFCY<>[F:POQW]PRHFCY
       Call ECR_TRACE("Purchase order"-[F:POQW]POHNUM-num$([F:POQW]POPLIN)-"SCOITM/PORDERQ"-[F:POQW]VCRNUMORI
&                                        -"Receiving site"-[F:SCIW]PRHFCY-[F:POQW]PRHFCY,1) From GESECRAN
       IERR+=1
    Endif
    If [F:SCIW]PRHADD<>[F:POQW]FCYADD
       Call ECR_TRACE("Purchase order"-[F:POQW]POHNUM-num$([F:POQW]POPLIN)-"SCOITM/PORDERQ"-[F:POQW]VCRNUMORI
&                                        -"Receiving site address"-[F:SCIW]PRHADD-[F:POQW]FCYADD,1) From GESECRAN
       IERR+=1
    Endif
    If ([F:SCIW]BPAADD="" | [F:SCIW]LOC="")
       Gosub CTL_SCI_BPAADD   # Maj SCIW si nécessaire
       Gosub CTL_POQ_SCOADD   # Maj POQW si nécessaire
       IERR+=1
    Endif
    If [F:SCIW]BPAADD<>[F:POQW]SCOADD
       Call ECR_TRACE("Purchase order"-[F:POQW]POHNUM-num$([F:POQW]POPLIN)-"SCOITM/PORDERQ"-[F:POQW]VCRNUMORI
&                                        -"Subcontract address"-[F:SCIW]BPAADD-[F:POQW]SCOADD,1) From GESECRAN
       IERR+=1
    Endif

$NEXT_POQ2
    IPOQ+=1
Next

Filter [POQW]
If IERR=0
   Call ECR_TRACE("PORDERQ No Purchase Order with different Supplier code/address",0) From GESECRAN
Else
   Call ECR_TRACE(num$(IERR)-"Errors Purchase Order with different Supplier code/address",0)  From GESECRAN
Endif
If WSIMFLG=2
   Rollback
   Call ECR_TRACE("Mode simulation: Rollback !!!",0) From GESECRAN
Else
   Commit
Endif

Return


#----------------------------------------------------------------------#
$CTL_ALL_SCI_BPAADD
Call ECR_TRACE("--------------------------------------------------------------",0) From GESECRAN
Call ECR_TRACE("UTIACH36 : External Order missing Supplier code/address       ",0) From GESECRAN
Call ECR_TRACE("--------------------------------------------------------------",0) From GESECRAN
Trbegin [SCIW]
Raz IERR
Filter [SCIW] Where ITMSTA<3
For [SCIW]
    Gosub CTL_SCI_BPAADD
Next

If IERR=0
   Call ECR_TRACE("SCOITM No External Order with error on Supplier code/address",0) From GESECRAN
Else
   Call ECR_TRACE(num$(IERR)-"Errors External Order with missing Supplier code/address",0)  From GESECRAN
Endif
If WSIMFLG=2
   Rollback
   Call ECR_TRACE("Mode simulation: Rollback !!!",0) From GESECRAN
Else
   Commit
Endif

Return

#----------------------------------------------------------------------#
$CTL_SCI_BPAADD
Local Char WBPRNUM(GLONBPR),WBPAADD(GLONBPD),WLOC(GLONLOC)
Local Shortint IUPD : IUPD=0
Local Shortint IUPDM: IUPDM=0
WBPRNUM=[F:SCIW]BPRNUM
WBPAADD=[F:SCIW]BPAADD
WLOC   =[F:SCIW]LOC

  #----- lecture client livré -----#
  Gosub READ_BPD From BPRLIB
  #----- Recherche de l'adresse du client livré -----#
  If [F:BPD]BPCNUM<>WBPRNUM | [F:BPD]BPAADD <> WBPAADD | [F:BPD]SCOLOC<>WLOC
     If [F:BPD]SCOLOC=""
       Call ECR_TRACE([F:SCIW]SCONUM-"Supplier"-WBPRNUM-"BPAADD/LOC ko"-WBPAADD-WLOC
&                     -"must be corrected",1) From GESECRAN
     Else
       Call ECR_TRACE([F:SCIW]SCONUM-"Supplier"-WBPRNUM-"BPAADD/LOC ko"-WBPAADD-WLOC
&                     -"should be"-[F:BPD]BPAADD-[F:BPD]SCOLOC,1) From GESECRAN
     Endif
     IERR+=1
     #If WSIMFLG<>2
        If [F:SCIW]BPAADD="" : [F:SCIW]BPAADD = [F:BPD]BPAADD : IUPD+=1 : Endif
        If [F:SCIW]LOC   ="" : [F:SCIW]LOC    = [F:BPD]SCOLOC : IUPD+=1 : Endif
        If [F:SCIW]BPAADD = [F:BPD]BPAADD & [F:BPD]SCOLOC<>"" [F:SCIW]LOC = [F:BPD]SCOLOC : IUPD+=1 : Endif
        If IUPD>0
           [F:SCIW]UPDUSR=GUSER
           [F:SCIW]UPDDAT=date$
           Rewrite [F:SCIW]
           Call ECR_TRACE("SCOITM"-[F:SCIW]SCONUM-"Subcontract address modified to"-[F:SCIW]BPAADD-[F:SCIW]LOC,-1) From GESECRAN

           For [SCMW] Where SCONUM=[F:SCIW]SCONUM & SCOFLG=2 & SCMTRKFLG<5 & USEQTY=0
               Gosub CTL_SCM_LOC
           Next
           If IUPDM
             # mise à jour entete
             Gosub MAJSCOHEAD From SCOLIB
             Rewrite [F:SCO]
           Endif
        Endif
     #Endif
  Endif

Return

#----------------------------------------------------------------------#
$CTL_SCM_LOC

If [F:SCMW]LOC = [F:SCIW]LOC | [F:SCIW]LOC="" Return Endif
IUPDM+=1
[F:SCMW]LOC    = [F:SCIW]LOC
[F:SCMW]UPDDAT = date$
[F:SCMW]UPDUSR = GUSER
Call ECR_TRACE("SCOMAT"-[F:SCMW]SCONUM-[F:SCMW]CPNITMREF-"Subcontract location modified to"-[F:SCMW]LOC,-1) From GESECRAN

[F:SCM]=[F:SCMW]
If [F:SCM]ALLSTA>1
  # mise à jour de l'encours et des allocations
  Call UPDATE_MSX("M", 0) From SCOLIB
Endif
# mise à jour matière
Rewrite [F:SCMW]

# v6 affectations
Gosub MAJ_MTO_SCM From SCOMTOLIB

Return


#----------------------------------------------------------------------#
$CTL_POQ_SCOADD
Local Char WBPRNUM(GLONBPR),WBPAADD(GLONBPD),WLOC(GLONLOC)
WBPRNUM=[F:POQW]BPSNUM
If [F:POQW]SCOADD<>""
   WBPAADD=[F:POQW]SCOADD
Else
   WBPAADD=[F:SCIW]BPAADD
Endif
WLOC   =[F:SCIW]LOC

  #----- lecture client livré -----#
  Gosub READ_BPD From BPRLIB
  #----- Recherche de l'adresse du client livré -----#
  If [F:BPD]BPCNUM<>WBPRNUM | [F:BPD]BPAADD <> WBPAADD | [F:BPD]SCOLOC<>WLOC
     IERR+=1
     #If WSIMFLG<>2
        If [F:POQW]SCOADD=""
           [F:POQW]SCOADD = [F:BPD]BPAADD
           [F:POQW]UPDUSR=GUSER
           [F:POQW]UPDDAT=date$
           Rewrite [F:POQW]
           Call ECR_TRACE("PORDERQ"-[F:POQW]POHNUM-num$([F:POQW]POPLIN)-"Subcontract address modified to"-[F:POQW]SCOADD,-1) From GESECRAN
        Endif
     #Endif
  Endif

Return

#----------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la commande            #
# -------------------------------------------------------------------- #
# Chargement GSOCIETE   : Société juridique                            #
#            GLOCALDEV  : Devise société juridique                     #
#----------------------------------------------------------------------#
$CHARG_PARAM
Local  Char     PARAM2(10)
If [F:ADS]MODULE(1) = 2  # Dossier avec module comptabilité
  Call GLOBVAR(GFCY)  From WWGLOBCPT
  #----- Chargement des globales référentiels, comptes et sections de la société -----#
  Call GETCPY(GFCY,"PTR",9,GSCOPTRNUM) From TRTX3CPT
Endif
Call GLOBVAR(GFCY)    From WWGLOBACH
Raz GMESSAGE
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTIACH36(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTIACH36(APPLI)
End

#######################################################################
