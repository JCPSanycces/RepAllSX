#<AdxTL>@(#)6.0.0.0 $Revision$
###############################################################################
# UTIVEN07 :                                                Module Vente      #
#            Utilitaire de maj des prix à 0 dans les livraisons de DL :       #
#            Maj prix ds les livraisons de DL dont la date fin de validité    #
#            de la dernière ligne de prix du contrat était erronée            #  
# --------------------------------------------------------------------------- #
# Problème à résoudre :  Bug 39216                                            #
#   La modification de la date de fin de validité d'une ligne article d'un    #
#      contrat n'était pas reportée sur la date de fin de validité de la      #
#      dernière ligne de prix                                                 #
#   Des lignes de DL de ces contrats ont été livrées, les lignes de livraison # 
#      ont été générées avec un prix brut à 0.                                #                                       
#   L'utilitaire a pour but :                                                 #
#        - De rechercher ttes les lignes de BL issues de DL ayant un prix à 0 # 
#          De rechercher la ligne de prix du contrat pour remettre à jour     #
#          les prix dans les lignes de BL                                     # 
#   NB : Cet utilitaire doit être lancé lorsque les dates de fin de validité  #
#        des lignes de prix sont correctes                                    #
#        (par lancement de l'utilitaire UTIVEN06 ou par modif manuelle)       #
###############################################################################

Call MAJ_UTIVEN07
End

##################################
Subprog MAJ_UTIVEN07
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
   Call EXE_UTIVEN07(DOSSIER)
Endif
End

##################################
Subprog EXE_UTIVEN07(DOSSIER)
Value Char DOSSIER

Local Integer WSIMFLG : WSIMFLG=2
Call OUINON(mess(6,115,1),WSIMFLG) From GESECRAN

#Local Char PARAM(30)(1..2)
#Local Date DATREF
#Call SAISIE_DAT(GBIDA1,PARAM,"UTIVEN07","UTIVEN07","XWUTIVEN07") From GSAISIE
#DATREF = PARAM(1)

Local Date    DATREF : DATREF=[01/01/2007]
Local Integer I, J
Local Decimal WDLVATI

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIVEN07 : Liste des livraisons mises à jour") From LECFIC  
Call ECR_TRACE("UTIVEN07 : Début traitement du dossier "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:SDH])=0  Local File =DOSSIER+".SDELIVERY"    [SDH]  Endif
If clalev([F:SDD])=0  Local File =DOSSIER+".SDELIVERYD"   [SDD]  Endif
If clalev([F:SOC])=0  Local File =DOSSIER+".SORDERC"      [SOC]  Endif
If clalev([F:SOP])=0  Local File =DOSSIER+".SORDERP"      [SOP]  Endif

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE("Mise à jour des prix à 0 dans les lignes de livraisons issues de DL",0) From GESECRAN 
If WSIMFLG=2 Call ECR_TRACE(mess(6,115,1),0) From GESECRAN Endif
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

Raz I

#Dbgaff

Call DEBTRANS From GLOCK
Trbegin [SDD]
# --> Lecture des livraisons non facturées
For [SDH]SDH0 Where LND=1 & SDHCAT=1 & INVFLG=1 & DLVDAT>=DATREF With Nohint
  
  WDLVATI=[F:SDH]DLVATI  
  # --> Recherche des lignes issues de DL sans prix 
  For [SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM & [F:SDD]SOHCAT=4 & [F:SDD]SOHNUM<>"" & [F:SDD]NETPRINOT=0

    Read [SOC]SOC0=[F:SDD]SOHNUM;[F:SDD]SOPLIN
    If fstat=0
      Raz [F:SOP] 
      If [F:SOC]PLI = ""
          Filter [SOP] Where SOHNUM = [F:SDD]SOHNUM & SOPLIN = [F:SDD]SOPLIN &
&                            STRDAT <= [F:SDD]SHIDAT & ENDDAT >= [F:SDD]SHIDAT
          Read [SOP]SOP0 First
          If fstat : Raz [F:SOP] : Endif
          Filter [SOP]
      Endif
        
      If [F:SOP]NETPRINOT<>0
          If WSIMFLG=1
              Readlock [SDD] Curr
              If fstat 
                  Call ECR_TRACE("File SDELIVERYD"-[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)+", Error ="-num$(fstat),1) From GESECRAN
              Endif
          Endif
          If fstat=0
              Call ECR_TRACE("*** Ligne livraison :"-[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)-[F:SDD]ITMREF-"Prix brut :"-format$("N3:15F[ ]",[F:SOP]GROPRI),0) From GESECRAN
           
              [F:SDD]GROPRI=[F:SOP]GROPRI
              [F:SDD]PRIREN=[F:SOP]PRIREN
              For  J = 1 To 9 
                  Assign "[F:SDD]DISCRGVAL"+num$(J) With evalue("[F:SOP]DISCRGVAL"+num$(J))
                  Assign "[F:SDD]DISCRGREN"+num$(J) With evalue("[F:SOP]DISCRGREN"+num$(J))
              Next 
              [F:SDD]NETPRI=[F:SOP]NETPRI
              [F:SDD]NETPRINOT=[F:SOP]NETPRINOT
              [F:SDD]NETPRIATI=[F:SOP]NETPRIATI
              # --> Calcul des montants de base calcul de taxe (peuvent être dépendant de la qté)
              Call ALICLCAMT([F:SDD]ITMREF, [F:SDD]QTY, -1, "SDD", [F:SDD]CLCAMT1, [F:SDD]CLCAMT2) From TRTX3
              # --> Calcul de la marge 
              [F:SDD]PFM = [F:SDD]NETPRINOT - [F:SDD]CPRPRI
              # --> Calcul des montants ht et ttc livraison 
              MNTCALC = [F:SDD]QTY * [F:SDD]NETPRINOT 
              Call ARRDEV (MNTCALC, [F:SDH]CUR) From TRTDIV 
              [F:SDH]DLVNOT += MNTCALC 

              MNTCALC = [F:SDD]QTY * [F:SDD]NETPRIATI 
              Call ARRDEV (MNTCALC, [F:SDH]CUR) From TRTDIV 
              [F:SDH]DLVATI += MNTCALC 
              If [F:SDH]CFMFLG<>2
                   # Incrémentation des mouvements client (en-cours livraison)
                   Call MAJMVC  ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY, 
&                                 0, WLIVTTC, "+", "O", "",[F:SDH]LND) From TRTBPMVT
              Else
                   # Incrémentation des mouvements client (livré)
                   Call  MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY, 
&                                 0, [F:SDH]DLVATI, "+", "D", "V", [F:SDH]LND) From TRTBPMVT   
              Endif

              If WSIMFLG=1
                  Rewrite [SDD]
                  If fstat
                      Call ECR_TRACE("File SDELIVERYD"-[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)+", Error ="-num$(fstat),1) From GESECRAN
                  Else
                      I+=1
                  Endif
              Else
                  I+=1
              Endif
          Endif                    
      Endif
    Endif           
  Next
  If WDLVATI<>[F:SDH]DLVATI
      If WSIMFLG=1      
          Readlock [SDH] Curr
          If fstat 
              Call ECR_TRACE("File SDELIVERY"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
          Else
              Call ECR_TRACE("*** Livraison :"-[F:SDH]SDHNUM-"Montant TTC :"-format$("N3:15F[ ]",[F:SDH]DLVATI),0) From GESECRAN
              Rewrite [SDH]
              If fstat
                  Call ECR_TRACE("File SDELIVERY"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
              Endif    
          Endif           
      Else
          Call ECR_TRACE("*** Livraison :"-[F:SDH]SDHNUM-"Montant TTC :"-format$("N3:15F[ ]",[F:SDH]DLVATI),0) From GESECRAN
      Endif
  Endif
Next
Commit 

If I>0
   Call ECR_TRACE("Nbre de lignes traitées : "-num$(I),0) From GESECRAN
Endif

$FIN_UTIVEN07
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End


