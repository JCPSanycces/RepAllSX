#<AdxTL>@(#)7.0.0.0 $Revision$
# ------------------------------------------------------------
# SUBAPSMES - Messages portail
# Version 0004
# ------------------------------------------------------------
$GETMESBYCODE        # En entrée: U_MESCODE, U_MESP1, U_MESP2 et retourne U_MES, U_MESIMG
U_MES="" : U_MESIMG="Alert.jpg"

Case U_MESCODE
When "X3ACTPAR"
    U_MES=U_MESP1
When "X3ACTUNKNOWN"
    # U_MES="Source de données: " + U_MESP2 + " - Action inconnue: " + U_MESP1 
    U_MES=mess(45,137,1) - U_MESP2 + " - " + mess(5,137,1) + " " + U_MESP1 
When "X3AGDTRTNOTFOUND"
    #U_MES="Traitement X3 non trouvé: Agenda" 
    U_MES=mess(57,137,1)-mess(58,137,1)
When "X3BLOBTOSMALL"
    #U_MES="Trop de données retournées:"- U_MESP1 -"Clob trop petit:" - U_MESP2
    U_MES=mess(62,137,1)-U_MESP1-mess(63,137,1)-U_MESP2
When "X3BRWUNKNOWN"
    #U_MES="Code browser inconnu: " + U_MESP1
    U_MES=mess(6,137,1) + " " + U_MESP1
When "X3CODACCNOTAUTHORIZE"
    #U_MES="Code accès: "
    U_MES=mess(65,137,1)-U_MESP1
    U_MESIMG="NotAuthorize.jpg"
When "X3DATATOOMANYREC"
    #U_MES="Trop de données retournées:"- U_MESP1 -"Nombre de lignes:" - U_MESP2
    U_MES=mess(62,137,1)-U_MESP1-mess(64,137,1)-U_MESP2
When "X3DATEVAERR"    # l'évaluation n'est pas une date
    U_MES=mess(46,137,1)-format$("KT:20X",U_MESP1)
    If len(U_MESP1) > 20 : U_MES+="..." : Endif
    If U_CTXFOR<>"" : U_MES-=" ("-mess(42,137,1)-U_CTXFOR-")" : Endif
When "X3DESTUNKNOWN"
    #U_MES=mess(1,137,1) + " Destination non prévue: " + U_MESP1
    U_MES=mess(1,137,1) + " " + mess(8,137,1) + " " + U_MESP1
When "X3FCTUNKNOWN"
    #U_MES="Fonction non supportée: " + U_MESP1
    U_MES=mess(9,137,1) + U_MESP1
When "X3FILEOPEN"
    #U_MES="Erreur ouverture fichier: " + U_MESP1
    U_MES=mess(10,137,1) + " " + U_MESP1
When "X3HTMLNOTFOUND"
    #U_MES="Description Html non trouvée dans le fichier SUBAPSHTML: " + U_MESP1
    U_MES=mess(36,137,1)-U_MESP2 -"("-U_MESP1-")"
When "X3FILTERROR"
    #U_MES="Erreur interne à l'évaluation du filtre - objet: " + U_MESP1 + " - Activer la trace X3 pour connaitre les filtres utilisés"
    U_MES=mess(11,137,1) + " " + U_MESP1 + " - " + mess(12,137,1) 
When "X3FNCNOTAUTHORIZE"
    #U_MES="Fonction non autorisée" - U_MESP1
    U_MES=mess(1,123,1) - U_MESP1
    U_MESIMG="NotAuthorize.jpg"
When "X3FORERR"
    #U_MES=U_MESP2-"Formule:"-U_MESP1        nota P2=errm-errmes$(errn)
    U_MES=U_MESP2-mess(39,137,1)-format$("KT:20X",U_MESP1)+")"
    If len(U_MESP2) > 20 : U_MES+="..." : Endif
    If U_CTXFOR<>"" : U_MES-=" ("-mess(42,137,1)-U_CTXFOR-")" : Endif
When "X3FRAMENBNUM"
    #U_MES="Numéro de cadre incorrect - Ligne : " + U_MESP1
    U_MES=mess(13,137,1)-U_MESP1
When "X3HTCPROVUNKNOWN"    # Type Provider inconnu
    U_MES=mess(48,137,1)-U_MESP1
When "X3LISTNUMBADVALUE"
    #U_MES="Numéro de liste incorrect: " + U_MESP1
    U_MES=mess(14,137,1)-U_MESP1
When "X3MAXMES"
    #U_MES="Nombre maximun de messages atteints. "
    U_MES=mess(15,137,1)
When "X3MAXTECH"
    #U_MES="Nombre maxi de zones techniques atteint" + U_MESP1
    U_MES=mess(16,137,1)-U_MESP1
When "X3NOTAUTHORIZE"
    #U_MES="Accès non autorisé"
    U_MES=mess(17,137,1)
    U_MESIMG="NotAuthorize.jpg"
When "X3OBJLKUNKNOWN"
    #U_MES="Objet X3 non trouvé pour la table: " + U_MESP1
    U_MES=mess(19,137,1) + " " + U_MESP1
When "X3OBJNOTBRW"
    #U_MES="Objet X3 ne gérant pas un browser: " + U_MESP1
    U_MES=mess(20,137,1) + " " + U_MESP1
When "X3OBJUNKNOWN"
    #U_MES="Objet X3 inconnu ou non généré: " + U_MESP1
    U_MES=mess(18,137,1) + " " + U_MESP1
When "X3PAGEUNKNOWN"
    #U_MES="Code page portail inconnu: " + U_MESP1
    U_MES=mess(21,137,1) + " " + U_MESP1
When "X3PARUNKNOWN"
    #U_MES="Fiche paramètrage portail non trouvée:"  
    U_MES=mess(7,137,1)-mess(val(U_MESP1), 2912,1)-U_MESP2
When "X3VIEWUNKNOWN"
    #U_MES="Code vue portail inconnu: " + U_MESP1
    U_MES=mess(37,137,1)-U_MESP1
When "X3VIEWSRCTYPUNKNOWN"
    #U_MES="Type de source de donnée non géré (vue): "
    U_MES=mess(38,137,1)-U_MESP2-"("-U_MESP1-")"
When "X3REQUNKNOWN"
    #U_MES="Code requête inconnu: " + U_MESP1
    U_MES=mess(22,137,1) + " " + U_MESP1
When "X3REQPRTUNKNOWN"
    #U_MES="Code requête portail inconnu: " + U_MESP1
    U_MES=mess(23,137,1) + " " + U_MESP1
When "X3REQTOOMUCHCOL"
    #U_MES="Code requête portail inconnu: " + U_MESP1
    U_MES=mess(67,137,1) - U_MESP1
When "X3QSENDFILE"
    #U_MES="Fichier Query - Nom complet du fichier fin non trouvé - Paramètre: " + U_MESP1
    U_MES=mess(24,137,1) + " " + U_MESP1
When "X3QSERRFILE"
    #U_MES="Fichier Query - Nom complet du fichier d'erreur non trouvé - Paramètre: " + U_MESP1
    U_MES=mess(25,137,1) + " " + U_MESP1
When "X3QSTOOPARMS"
    #U_MES="Trop de paramètres dans la query string - nb max=" + U_MESP1
    U_MES=mess(26,137,1) + " " + U_MESP1
When "X3QSDECERR"
    #U_MES="Anomalie de décodage query string: " + U_MESP1
    U_MES=mess(27,137,1) + " " + U_MESP1
When "X3QSTOOPARMS"
    #U_MES='Caractère de fin de chaîne (") non trouvé'
    U_MES=mess(28,137,1) 
When "X3QSDECEQ"
    #U_MES="Query string - Paramètre sans valeur - Il manque le signe = "
    U_MES=mess(29,137,1) 
When "X3QSCODEUNKNOWN"
    #U_MES="Query string - Paramètre non trouvé:"
    U_MES=mess(43,137,1)-U_MESP1
When "X3TYPEUNKNOWN"
    #U_MES=mess(1,137,1) + " Type de sortie non prévu: " + U_MESP1
    U_MES=mess(1,137,1) + " " + mess(30,137,1) + " " + U_MESP1
When "X3STAUNKNOWN"
    U_MES="Code statistique inconnu: " + U_MESP1
When "X3STAPRTUNKNOWN"
    #U_MES="Code statistique portail inconnu: " + U_MESP1
    U_MES=mess(49,137,1)-U_MESP1
When "X3STACRIFIXED"
    #U_MES="Critère fixé par paramétrage - numéro / valeur: " + U_MESP1 + " / " + U_MESP2
    U_MES=mess(54,137,1)-U_MESP1
When "X3STAFCYNOTAUTHO"
    #U_MES="Accès non autorisé au site:"-U_MESP1 
    U_MES=mess(63,133,1)-U_MESP1
When "X3STALEVELNOTNUMERIC"
    #U_MES="Niveau non numérique:"-U_MESP1 
    U_MES=mess(51,137,1)-U_MESP1
When "X3STALEVELNOTAUTHO"
    #U_MES="Niveau non autorisé: " + U_MESP1 
    U_MES=mess(53,137,1)-U_MESP1
When "X3STALEVELINVALID"
    #U_MES="Niveau non compris entre 1 et 9: " + U_MESP1 
    U_MES=mess(52,137,1)-U_MESP1
When "X3STALEVELTOOHIGHT"
    #U_MES="Niveau demandé supérieur au maximun: " + U_MESP1 + " / " + U_MESP2 
    U_MES=mess(50,137,1)-U_MESP1 + " / " + U_MESP2 
When "X3TRTERR"
    #U_MES="Anomalie en appel du traitement: " + U_MESP2 + " / " + U_MESP1 
    U_MES=mess(47,137,1)-U_MESP2-"/"-U_MESP1
When "X3TRTNOTFOUND"
    #U_MES="Traitement X3 non trouvé: " + U_MESP1 
    U_MES=mess(57,137,1)-U_MESP1
When "X3REQNOTECHRESULT"
    #U_MES="Requête sans enregistrement technique" + U_MESP1 
    U_MES=mess(66,137,1)-U_MESP1
When "X3CNSGETINFOS"        # Message formaté par PTLCNSGETINFOS
    U_MES=U_MESP1 
When "X3CNSGETDATA"         # Message formaté par PTLCNSGETINFOS
    U_MES=U_MESP1 
When "X3RESULTNOTALL"
    U_MES=mess(69,137,1)    
When "X3MES"
    U_MES=mess(71,137,1)-U_MESP1   
When Default
       Case [F:APV]SRCCODTYP
            When "AGD"
                Onerrgo TRT_ERR
                Gosub T_GETMESBYCODE From =MC_AGDTRT
                Onerrgo
            When "TRT"
                Onerrgo TRT_ERR
                Gosub T_GETMESBYCODE From =[F:APV]SRCCOD
                Onerrgo
        Endcase
        If U_MES="" # erreur non recensée par le traitement 
            #U_MES="Erreur non recensée ! : " + U_MESCODE
            $ERR_UNKNOWN
            U_MES=mess(31,137,1)-"Code"-U_MESCODE-"P1:"-U_MESP1-"P2:"-U_MESP2 
            U_MESIMG="Alert.jpg"
        Endif    
Endcase
U_HEXTOTXT=U_MES : Gosub U_TXTTOHEX From SUBAPSUTI : U_MES=U_TXTTOHEX
Return

$TRT_ERR    # Pb d'accès au traitement
U_MES=mess(31,137,1)-"Code"-U_MESCODE-"P1:"-U_MESP1-"P2:"-U_MESP2 
U_MESIMG="Alert.jpg"
Resume
Return
