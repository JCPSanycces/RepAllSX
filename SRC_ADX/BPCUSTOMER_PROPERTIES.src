#<AdxTL>@(#)0.0.0.0 $Revision$
# ----------------------- VACBPR --------------------------------------
$VACBPR_LEG
Case [L]ARULE
	When "GET" 			 : Gosub GET_VACBPR_LEG
	When Default 		 : Return
Endcase

Return
#--------------------------------------------------------------------------------------
$GET_VACBPR_LEG

Gosub LOAD_VACBPR_LEG

Return
# ----------------------- INVDTA --------------------------------------
$INVDTA
#--Attention this => BPC.C_INVDTAAMT
Case [L]ARULE
	When "PROPAGATE" : #Gosub PROPAGATE_INVDTA
	When Default 		 : Return
Endcase

Return

$PROPAGATE_INVDTA
If this.INVDTA=0 Return Endif

Return
# ----------------------- DEP --------------------------------------
$DEP_LEG
Case [L]ARULE
	When "GET" 			 : Gosub GET_DEP_LEG
	When Default 		 : Return
Endcase

Return
#---------------------------------
$GET_DEP_LEG

Gosub LOAD_DEP_LEG

Return
# ----------------------- PTE --------------------------------------
$PTE_LEG
Case [L]ARULE
	When "GET" 			 : Gosub GET_PTE_LEG
	When Default 		 : Return
Endcase

Return
#--------------------------------------------------------------------------------------
$GET_PTE_LEG

Gosub LOAD_PTE_LEG

Return
###################################################################################################
$LOAD_VACBPR_LEG
If this.VACBPR="" Return Endif

Local Integer IRET
Local Char LEG
If clalev([F:TVB])=0 : Local File TABVACBPR [TVB] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif

If func AFNC.ACTIV("LEG")=0
 [L]LEG = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"GDOSLEG")
Elsif LEG="" & dim(this.LEG)>0 : # LEG présent dans la classe
	If this.LEG<>"" : [L]LEG = this.LEG : Endif
Endif

If [L]LEG<>""
 Read [TVB]TVB0=this.VACBPR;[L]LEG
 If fstat
  Read [TVB]TVB0=this.VACBPR;""
 Endif
Else
 Read [TVB]TVB0(1)=this.VACBPR
Endif
If !fstat
  [L]LEG = [F:TVB]LEG
Endif

this.VACBPR_LEG = [L]LEG

Return
###################################################################################################
$LOAD_DEP_LEG
If this.DEP="" Return Endif

Local Integer IRET
Local Char LEG

If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif

If func AFNC.ACTIV("LEG")=0
 [L]LEG = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"GDOSLEG")
Elsif LEG="" & dim(this.LEG)>0 : # LEG présent dans la classe
	If this.LEG<>"" : [L]LEG = this.LEG : Endif
Endif

If [L]LEG<>""
 Read [TDA]TDA0=this.DEP;[L]LEG
 If fstat
  Read [TDA]TDA0=this.DEP;""
 Endif
Else
 Read [TDA]TDA0(1)=this.DEP
Endif
If !fstat
  [L]LEG = [F:TDA]LEG
Endif

this.DEP_LEG = [L]LEG

Return
###################################################################################################
$LOAD_PTE_LEG
If this.PTE="" Return Endif

Local Integer IRET
Local Char LEG

If clalev([F:TPT])=0 : Local File TABPAYTERM [TPT] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif

If func AFNC.ACTIV("LEG")=0
 [L]LEG = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"GDOSLEG")
Elsif LEG="" & dim(this.LEG)>0 : # LEG présent dans la classe
	If this.LEG<>"" : [L]LEG = this.LEG : Endif
Endif

If [L]LEG<>""
 Read [TPT]TPT0=this.PTE;[L]LEG;1
 If fstat
  Read [TPT]TPT0=this.PTE;"";1
 Endif
Else
 Read [TPT]TPT0(1)=this.PTE
Endif
If !fstat
  [L]LEG = [F:TPT]LEG
Endif

this.PTE_LEG = [L]LEG

Return
#######################################################################################

