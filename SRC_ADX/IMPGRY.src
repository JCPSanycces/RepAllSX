#<AdxTL>@(#)12.0.0.0 $Revision$

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
 When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
 When "IMP_CREATION"  : Gosub IMP_CREATION
 When "IMP_MODIF"     : Gosub IMP_MODIF
 When "IMP_FERME"     : Gosub IMP_FERME
Endcase
Return

$IMP_OUVRE
If clalev([COA]) = 0 : Local File GCOA       [COA]  : Endif
If clalev([GAC]) = 0 : Local File GACCOUNT   [GAC]  : Endif
If clalev([GYM]) = 0 : Local File GACCPYM    [GYM]  : Endif
If clalev([CLS]) = 0 : Local File GACCCLS    [CLS]  : Endif
If clalev([GRY0])= 0 : Local File GACCGRUPYM [GRY0] : Endif
If clalev([GRY2])= 0 : Local File GACCGRUPYM [GRY2] : Endif
If clalev([GRY3])= 0 : Local File GACCGRUPYM [GRY3] : Endif

Local Decimal LIVELLO
Local Integer NBRCOA
NBRCOA = nbrecord([COA])
Local Char COAIMP(GLONCOA)(1..NBRCOA)
Raz NBRCOA
Return

$IMP_VERIF_CRE
$IMP_VERIF_MOD

OK=1
Gosub CONTROLE
If OK
 I = find([F:GRY]COA,COAIMP(1..NBRCOA))
 If !I
  NBRCOA+=1
  COAIMP(NBRCOA)= [F:GRY]COA
 Endif
Endif
Return


$CONTROLE
#--------- Le champs PYM est obligatoire et existant
If [F:GRY]PYM=""
 GMESSAGE ="PYM"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [GYM]GYM0=[F:GRY]PYM
 If fstat
  GMESSAGE = "PYM"-mess(83,123,1)-[F:GRY]PYM  # Valeur incorrecte
  OK=0 : Return
 Endif
Endif

#--------- Le champs COA est obligatoire et existant/compatible
If [F:GRY]COA=""
 GMESSAGE ="COA"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [F:COA]COA0 = [F:GRY]COA
 If fstat
  GMESSAGE = "COA"-mess(83,123,1)-[F:GRY]COA  # Valeur incorrecte
  OK=0 : Return
 Endif
 If [F:GYM]COA<>[F:GRY]COA
  GMESSAGE = "COA"-mess(83,123,1)-[F:GRY]COA  # Valeur incorrecte
  OK=0 : Return
 Endif
Endif

#--------- Le champs LEV
LIVELLO = [F:GRY]LEV
Filter [GRY2] Where PYM=[F:GRY]PYM and SBBGRU=[F:GRY]GRU and LEV>=LIVELLO
Read [F:GRY2] First
If !fstat & [F:GRY2]GRU<>""
 GMESSAGE = (mess(32,113,1)-[F:GRY2]GRU-">"-num$([F:GRY2]LEV)) : # Regroupé dans
 OK=0 : Return
Endif
Filter [GRY2]
For [GRY2]GRY0 Where PYM=[F:GRY]PYM & GRU=[F:GRY]GRU & ACC=""
 Filter [GRY3] Where PYM=[F:GRY]PYM and GRU=[F:GRY2]SBBGRU
 Read   [GRY3]  First
 If !fstat
  If   LIVELLO>=[F:GRY3]LEV
   GMESSAGE = mess(40,113,1)-"(>"-num$([F:GRY3]LEV)-")" : # Niveau incompatible avec le groupe ...
   OK=0 : Break
  Endif
 Endif
 Filter [GRY3]
Next
If OK=0 : Return : Endif

#--------- Le champs CLSCOD
Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GRY]CLSCOD
If [F:CLS]TYP=3
 GMESSAGE = [F:GRY]CLSCOD-mess(5,113,1) : # Classe inutilisée
 OK=0 : Return
Endif

#--------- Le champs SBBGRU
If [F:GRY]SBBGRU<>""
 Read [GRY0]GRY0(2) = [F:GRY]PYM;[F:GRY]SBBGRU
 If !fstat & [F:GRY0]LEV<=[F:GRY]LEV
  GMESSAGE = [F:GRY]SBBGRU-mess(31,113,1)-num$([F:GRY0]LEV) : # Groupe de niveau ...
  OK=0 : Return
 Endif
Endif

#--------- Le champs ACC
Local Integer I , JOKER
[F:GRY]ACC= toupper([F:GRY]ACC)
If [F:GRY]ACC<>""
 JOKER  = 0
 For I=1 To len([F:GRY]ACC)
  If instr(1,"!#?*",mid$([F:GRY]ACC,I,1))
   JOKER = 1 : Break
  Endif
 Next I
 If !JOKER
  Read [GAC]GAC0 =[F:GRY]COA;[F:GRY]ACC
  If fstat
   GMESSAGE = [F:GRY]ACC-mess(44,102,1)  # Compte inexistant
   OK=0 : Return
  Endif
 Endif
Endif

Return


$IMP_MODIF
$IMP_CREATION

# Suppression des enregistrements en "trop" - F54934
If [F:GRY]LIN=1
 Delete [GRY2] Where PYM=[F:GRY]PYM and GRU=[F:GRY]GRU and LIN>1
 If fstat=1
  GOK = -1 : GLOCK="$GACCGRUPYM"-[F:GRY]PYM-[F:GRY]GRU : Return
 Endif
Endif
Return


$IMP_FERME
If NBRCOA
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 # Resynchronisation des pyramides comptes
 Call ECR_TRACE(mess(151,116,1),0) From GESECRAN
 For I=1 To NBRCOA
  Call MAJ_PLAN(COAIMP(I),nomap) From LIENPYRACC
 Next
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
Return

