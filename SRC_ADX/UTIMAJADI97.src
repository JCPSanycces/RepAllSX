#<AdxTL>@(#)4.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Delete ADI~97~AMIME
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Delete ADI~97~AMIME") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#

$MAJTAB

If DOSSIER=nomap
 Local File ATABDIV [ADI]
 Local File ATEXTRA [AXX]
Else
 Local File =DOSSIER+".ATABDIV" [ADI]
 Local File =DOSSIER+".ATEXTRA" [AXX]
Endif


Trbegin [ADI],[AXX]
     Delete [AXX] Where CODFIC="ATABDIV" & IDENT1="97" & IDENT2="AMIME"
     Delete [ADI] Where NUMTAB=97 & CODE="AMIME"
Commit

Close Local File [ADI],[AXX]

Return
