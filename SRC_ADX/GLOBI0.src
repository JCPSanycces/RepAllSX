$SET_RPTSRV
# Répertoire du serveur
Local Char    REPSRV(GDIMFIC) , NAMSRV(GDIMFIC) , LANRPT(GLONLAN) , SEP(1) , APPSRV(GLONADS)
Local Integer I , K , J
  #If ( GOS="dos" ) Then : SEP = "\" : Else : SEP = "/" : Endif : # FQ101833
  LANRPT = GLANGUE
  If filinfo(filpath("TRA/",LNOMDOC,"tra",""),0)>0
    NAMSRV = filpath("TRA/",LNOMDOC,"tra","")
    REPSRV = right$(NAMSRV,len(filpath("","","",""))+2)
    APPSRV = ""
  Else
    NAMSRV = filpath("TRA/",LNOMDOC,"tra")
    REPSRV = NAMSRV
    K = instr(1,NAMSRV,SEP+"tra"+SEP)
    If K
      J = 0
      For I=K-1 To 1 Step -1
        If mid$(NAMSRV,I,1)=SEP
          J = I : Break
        Endif
      Next I
      If J
        APPSRV = seg$(NAMSRV,J+1,K-1)
        REPSRV = right$(NAMSRV,K+1)
      Endif
    Endif
  Endif

