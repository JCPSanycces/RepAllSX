Subprog ECR_ENTETE_PLAN()
# - Objet  : Ecriture dans la trace de l'entête du tableau des plans calculés
#
#   FQ79856
#
# - Entrée :
#
# - Sortie :
#

# Déclaration des colonnes du tableau de compte rendu
Local    Integer COL1  : COL1  = 45 : # Plan

Local    Integer LINE  : LINE  = COL1+4
