#      When "FS1"
#        If ( [M:DIV]NIVDET > 0 ) Then
#          Openo  filpath(nomap+DS+"TMP", "CAL_"+[M:DIV]SOC+"_1","tmp","X3_PUB"),0           Using [FS1]
