#
#########################################################
Subprog ECR_FICH(PABR, PNIVMSG, PMSG)
#
# - Objet  : Ecriture d'un message dans un fichier
#            selon le niveau du message et
#            le niveau de détail demandé
#
# - Prérequis OUVRE_FICH()
#
# - Entrée :
#            Abéviation du fichier
#            Niveau du message
#            Contenu du message
#
# - Sortie :
#
#

Value Char      PABR
Value Integer   PNIVMSG
Value Char      PMSG

Local Char      WMSG(180)

  # Ecriture selon niveau de détail
  If ( PNIVMSG <= [M:DIV]NIVDET ) Then
    If (PABR = "FS1") Then
      WMSG = string$(((PNIVMSG-1)*5)+1,' ') + PMSG
    Else
      WMSG = PMSG
    Endif
    # écriture
    Case PABR
      When "FS1" : Wrseq WMSG Using [FS1]
      When "FS2" : Wrseq WMSG Using [FS2]
      When Default
    Endcase
  Endif
End



#
#########################################################
Subprog AFF_FICH(PABR)
#
# - Objet  : Affichage du contenu d'un fichier
#
# - Prérequis
#
# - Entrée :
#
# - Sortie :
#
#
  Value Char    PABR

  Local Integer LSTAT
  Local Char    LRET
  Local Char    LNOMDOC(GDIMFIC)

  Local Char TRACE_SAV(GLONTRA)
  TRACE_SAV = GTRACE

  If ( PABR = "FS1" )Then
    GTRACE = "CAL_"+[M:DIV]SOC+"_1"
  Endif
  If ( PABR = "FS2" )Then
    GTRACE = "CAL_"+[M:DIV]SOC+"_2"
  Endif
  Call LEC_TRACE From LECFIC

  GTRACE = TRACE_SAV
End


  If (GADONIX = 2) Then
    # Génération sur le serveur puis copie sur le client pour affichage
    # Serveur : /home1/adonix/dossier appli./tmp/CAL_sss_1.tmp
    # Client  : C:\Documents and Settings\All Users\Application Data\Sage\Sage X3 Client\V5\Temp\ CAL_sss_1.tmp
    # Exemple dossier appli. : ABELX3 Société : REF
    # Serveur : /home1/adonix/ABELX3/tmp/CAL_REF_1.tmp
    # Client  : C:\Documents and Settings\All Users\Application Data\Sage\Sage X3 Client\V5\Temp\ CAL_REF_1.tmp
    If ( PABR = "FS1" )Then
      LNOMDOC = "CAL_"+[M:DIV]SOC+"_1"
      Gosub SET_RPTSRV
      # Copie en local (Poste Client\RTS\temp)
      Call COPY_SRVTOCLI(1,LNOMDOC+".tra","TRA",REPSRV,APPSRV,LANRPT,LSTAT) From ORDSYS
    Elsif (PABR = "FS2" ) Then
      LNOMDOC = "CAL_"+[M:DIV]SOC+"_2"
      Gosub SET_RPTSRV
      # Copie en local
      Call COPY_SRVTOCLI(1,LNOMDOC+".tra","TRA",REPSRV,APPSRV,LANRPT,LSTAT) From ORDSYS
    Endif
    If ( (!LSTAT) and ( PABR="FS1" or PABR="FS2") )  Then
      Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
&                             "UILocalDir="+chr$(1)+"TRA",
