        Iomode adxirs chr$(13)+chr$(10) Using [FS2]
        Iomode adxium GTRAFOR           Using [FS2]
        [M:DIV]BFS2OPN = 1
      Endif
    When Default
  Endcase

#  If ( GVIRTDIR = "" ) Then
#    Case PABR
#      When "FS1"
#        If ( [M:DIV]NIVDET > 0 ) Then
#          Openo  filpath("tmp", "CAL_"+[M:DIV]SOC+"_1","tmp",0),0           Using [FS1]
#          Iomode adxifs " "               Using [FS1]
#          Iomode adxirs chr$(13)+chr$(10) Using [FS1]
#          Iomode adxium GASCII            Using [FS1]
#          [M:DIV]BFS1OPN = 1
#        Endif
#      When "FS2"
#        If ( [M:DIV]NIVDET > 0 ) Then
#          Openo  filpath("tmp", "CAL_"+[M:DIV]SOC+"_2","tmp",0),0           Using [FS2]
#          Iomode adxifs " "               Using [FS2]
#          Iomode adxirs chr$(13)+chr$(10) Using [FS2]
#          Iomode adxium GASCII            Using [FS2]
#          [M:DIV]BFS2OPN = 1
#        Endif
#      When Default
#    Endcase
#  Else
#    Local Char DS (1)
#    If (GOS(1)="dos") Then : DS="\" : Else : DS="/" : Endif
