#########################################################
Subprog CAL_EVALUE_ACTION_DEP( PTDFN, PNBF )
# - Objet  : Positionner le flag action dans [M:DEP]
#            Détecter et traiter une éventuelle désynchronisation
#
# - Entrée :
#
# - Sortie :
#
#
Value Char     PTDFN()
Value Decimal  PNBF

Local Integer N_D
Local Integer LRET

Local Integer N_F
Local Integer I_P
Local Integer LERROR


  LERROR = 0

  # Traitement inutile si la demande vient de la simulation  FQ79856
  If ( [M:DIV]TRTDEM = "CALSIM" or [M:DIV]TRTDEM = "CALVNC" or [M:DIV]TRTDEM = "CALDPS") Then
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  Endif

  # >>>>>>>>>>>>>>>>>
  For N_D = 1 To [M:DEP]NB_DEP
    #-1 --------------------------------
    If ( N_D > [M:WDEP]NB_DEP ) Then
      #-- Insert
      [M:DEP]FLGACT(N_D-1) = "I"
    #-1 --------------------------------
    Else
      #-- Commparaison (dates [M:DEP] & [M:nnn] pour détecter une éventuelle désynchronisation)
      LRET = 0
      # -- Désynchronisation clé
      If ( N_D <= [M:DEP]NB_DEP and
&        ( ( [M:DEP]FIYSTRDAT(N_D-1) <> [M:WDEP]FIYSTRDAT(N_D-1) )  or
&          ( [M:DEP]FIYENDDAT(N_D-1) <> [M:WDEP]FIYENDDAT(N_D-1) )  or
&          ( [M:DEP]PERSTRDAT(N_D-1) <> [M:WDEP]PERSTRDAT(N_D-1) )  or
&          ( [M:DEP]PERENDDAT(N_D-1) <> [M:WDEP]PERENDDAT(N_D-1) )  )     ) Then
        LRET = -1
      Else
        # -- Période soldée à ne pas mettre à jour
        I_P = find([M:DEP]PERSTRDAT(N_D-1),[M:FIY]DATSTRPER)
        If (I_P <> 0 and [M:FIY]STAPER (I_P-1) = GVML_SPCLOSE) Then
          LRET = 1
        Else
          #Calcul après clôture pas de mise à jour des DEPREC de l'exercice courant
          If ([F:WFAS]FLGCNXCLC([M:DEP]CNX(N_D-1)-1) = GVML_RCCLO and [M:DEP]FIYENDDAT(N_D-1)=[M:FIY]DATENDFIY([M:DIV]FEC-1) )  Then
            LRET = 1
          Endif
        Endif
      Endif

      #-2 --------------------------------
      If ( LRET = 1 ) Then
        #-- None
        [M:DEP]FLGACT(N_D-1) = "N"
      #-2 --------------------------------
      Elsif ( LRET = 0 ) Then
        #-- Update
        [M:DEP]FLGACT(N_D-1) = "U"
      #-2 --------------------------------
      Else
        #-- (-1) Désynchronisation (Suppression des enregistrements)
        [M:DEP]FLGACT(N_D-1) = "I"
        [M:WDEP]NB_DEP = N_D
        Delete [WDEP] Where   AASREF     = [F:WFAS]AASREF
&                       and   DPRPLN     = [M:WDEP]DPRPLN(N_D-1)
&                       and   FIYENDDAT >= [M:WDEP]FIYENDDAT(N_D-1)
&                       and   PERENDDAT >= [M:WDEP]PERENDDAT(N_D-1)
        #-3 ------------------------
        If fstat Then
          LERROR = -1
          Call FSTA("WDEP") From GLOCK
          # Erreur lors de la suppression DEPREC superflus
          Call ECR_TRACE(mess(154,7774,1)-num$(DPRPLN)-AASREF,1) From =G_GLOB0
          Break
        Endif
        Call ECR_FICH("FS2", 9,
&      "Desync. - Delete - [F:WDEP]"
&     -"Réf. ="-[F:WFAS]AASREF
&     -" & Plan ="- mess([M:WDEP]DPRPLN(N_D-1), GML_NPLAN,1)
&     -" & Fin Ex. > "-format$("D:" + GFMDAT4,  [M:WDEP]FIYENDDAT(N_D-1) )
&     -" & Fin Per >="-format$("D:" + GFMDAT4,  [M:WDEP]PERENDDAT(N_D-1) )
&     -" => adxdlrec ="-num$(adxdlrec)                                     ) From =G_GLOB0

        #-3 ------------------------
      Endif
      #-2 --------------------------------
    Endif
    #-1 --------------------------------
  Next N_D
  # <<<<<<<<<<<<<<<<<<

  # Gestion des erreurs
  If ( LERROR ) Then
    [M:DIV]ERRID = 14 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
  Endif

  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog CAL_LEC_CALDEP_FLD( PNBFMAX, RTDF, RNBF )
# - Objet  : Renvoie dans un tableau le nom des champs de l'écran CALDEP.
#
# - Entrée :
#
# - Sortie : Tableau des champs de l'écran CALDEP
#            Nombre de champs dans le tableau
#
#
Value    Integer  PNBFMAX
Variable Char     RTDF()
Variable Decimal  RNBF

Local Integer N_F
Local Integer BCLOFIL : BCLOFIL = 0

  If clalev([F:AMZB])=0 : Local File AMSKZON [AMZB] : BCLOFIL = 1 : Endif
  N_F = 1
  # >>>>>>
  For [AMZB]CODTYP Where CODMSK = "CALDEP" and CODTYP <> "ABS"
    If ( N_F <= PNBFMAX ) Then
     RTDF(N_F-1) =[F:AMZB]CODZON
    Endif
     N_F += 1
  Next
  # <<<<<<
  RNBF = N_F-1

  If (BCLOFIL) Then
    Close Local File [AMZB]
  Endif

End


#########################################################
Subprog CMP_CALDEP_DEPREC_EQ(RTRN)
#
# - Objet  : Compare structure CALDEP et DEPREC.
#
# - Entrée :
#
# - Sortie :
#
#   Prérequis : Le tableau des noms de CALDEP dans [M:DIV]
#
#
Variable Integer RTRN

Local Integer I_F
Local Integer N_M
Local Integer N_F

  RTRN= 1
  If clalev([F:DEP])=0  : Local File DEPREC     [DEP]  :  Endif             : # Infos diverses
  N_F = clanbs([F:DEP],1)

  # Déduction des 5 champs techniques
  N_F -=5


  If( [M:DIV]NBF-1 <> N_F ) Then
    # Le nombre de champs entre fichier & masque est différent
    RTRN = 0
  Else
    Local Char L_FLD
    For I_F = 1 To N_F
      L_FLD = clavar([F:DEP], I_F)
      If ( L_FLD <> "CREDATTIM" and L_FLD <> "UPDDATTIM" and L_FLD <> "AUUID" and
&          L_FLD <> "CREUSR"    and L_FLD <> "UPDUSR" and find (L_FLD, [M:DIV]TDFN) = 0 ) Then
        # Le nom d'un champ fichier ne se trouve pas dans le masque
        RTRN = 0
        Break
      Endif
    Next I_F
  Endif

End


#
#########################################################
$CAL_ADDLVL
#
# - Objet  : Gère l'entrée d'une fonction dans la gestion d'erreur
#
# - Entrée : Ecran CALDIV Masque [M:DIV]
#
# - Sortie :
#

  #--------------------------
  If ( [M:DIV]LVL = [M:DIV]CSTLVLMAX ) Then
    [M:DIV]ERRID = 9999 : Call ERRFND From =G_GLOB0
  Else
  #--------------------------
    [M:DIV]LVL += 1
    [M:DIV]LVLID([M:DIV]LVL-1 ) = [M:DIV]LVLLIB
  Endif
  #--------------------------

  #If (GUSER = "MWA" and [M:DIV]LVL < = 5 ) Then
  #  Local Char      WMSG(180)
  #  WMSG = string$(([M:DIV]LVL*4)+1,' ') + num$([M:DIV]LVL)-[M:DIV]LVLLIB
  #  Call ECR_TRACE(WMSG,0) From GLOBB0
  #Endif

Return

#
#########################################################
$CAL_RMVLVL
#
# - Objet  : Gère la sortie d'une fonction dans la gestion d'erreur
#
# - Entrée : Ecran CALDIV Masque [M:DIV]
#
# - Sortie :
#

  #If (GUSER = "MWA" and [M:DIV]LVL < = 2 and [M:DIV]LVL > 0) Then
  #  Local Char      WMSG(180)
  #  WMSG = string$(([M:DIV]LVL*4)+1,' ') + num$([M:DIV]LVL)-[M:DIV]LVLID([M:DIV]LVL-1)
  #  Call ECR_TRACE(WMSG,0) From GLOBB0
  #Endif

  #--------------------------
  If ( [M:DIV]LVL = 0 ) Then
    [M:DIV]ERRID = 9998 : Call ERRFND From =G_GLOB0
  Else
  #--------------------------
    Raz [M:DIV]LVLID([M:DIV]LVL-1)
    [M:DIV]LVL -= 1
  Endif
  #--------------------------
Return

#
#########################################################
$KO
#
# --------------------------------
# Gestionnaire d'erreurs
# --------------------------------
#

  # Un seul passage autorisé
  If (G_DEJA) Then
    End
  # ***
  Endif
  G_DEJA = 1

  Call CAL_ERREUR(errmes$(errn), errp, errl, errn) From =G_GLOB0
  #--
  Call TEMPOFF From GESECRAN


  If (adxlog) Then
    Call ECR_TRACE(mess(48,7774,1),0) From =G_GLOB0 : # Traitement annulé
    Rollback
  Endif

  # Fin mode first row  FQ79813
  Gosub UNSET_FIRST From TRTFIRST

  # Résultat du traitement : Echec
  Call ECR_TRACE(mess(58,7774,1)-mess(60,7774,1),1) From =G_GLOB0

  #-- Traitement selon le niveau d'avancement du traitement
  #------------------------------------
  If ( [M:DIV]TRTLVL > 3 and ( [M:DIV]TRTDEM = "CALSOC" or [M:DIV]TRTDEM = "CALDPS") ) Then : # FQ79856
    Call FERME_BOITE From GESECRAN
  Endif
  #--
  If ( [M:DIV]TRTLVL > 2 ) Then
    # Fermeture du fichier de suivi
    Openo Using [FS1] : [M:DIV]BFS1OPN = 0
    Openo Using [FS2] : [M:DIV]BFS2OPN = 0
  Endif
  #--
  If ( [M:DIV]TRTLVL > 1 and ( [M:DIV]TRTDEM = "CALSOC" or [M:DIV]TRTDEM = "CALDPS") ) Then : # FQ79856
    # Déverrouillage bien
    If ( dim(GFILTRE_FAS) < 0 )  Then
      Call UNLOCK_SYMBOLE ("FAS", [M:DIV]SOC, "") From GLOBIENS
    Endif
  Endif
  #--
  If ( [M:DIV]TRTLVL > 0 and ( [M:DIV]TRTDEM = "CALSOC" or [M:DIV]TRTDEM = "CALDPS") ) Then : # FQ79856
    # Déverrouillage Contexte
    Call UNLOCK_SYMBOLE ("CNX", [M:DIV]SOC, "") From GLOBIENS
  Endif
  #------------------------------------

  # Fermeture du Compte-rendu
  Call ECR_TRACE(string$(80, '-'),0) From =G_GLOB0
  If ( !(GSERVEUR) ) Then
    Call FERME_TRACE From LECFIC
  Endif
  # Visualisation du Compte-rendu
  If ( !(GSERVEUR) ) Then  : Call LEC_TRACE From LECFIC : Endif

  If (dim(G_ETRPNT)>0) Then : Kill G_ETRPNT : Endif  : # Spécifique client
  If (dim(G_CLCSTD)>0) Then : Kill G_CLCSTD : Endif  : # Calcul Abel X3

  If ( [M:DIV]TRTDEM = "CALBCO" or [M:DIV]TRTDEM = "CALSIM") Then
    # Affichage détail technique du calcul du bien (FS2)
    Local Integer LAFFTRACE2 : LAFFTRACE2=0
    If ( GDEBUG and dim(PBKPOINTLST)>0 ) Then
      Local Integer I_BKP : I_BKP = find("AFFTRACE2",PBKPOINTLST)
      If (I_BKP) Then
        If (PBKPOINTFLG(I_BKP) = G_OUI) Then : LAFFTRACE2 = 1 : Endif
      Endif
    Endif
    If ( LAFFTRACE2 ) Then : Call AFF_FICH ( "FS2" ) From =G_GLOB0 : Endif
  Endif


#****
  End
#****

#
#########################################################
Subprog ERRFND ( )
#
# - Objet  : Force le déranchement en erreur ( édition erreur dans la trace (CAL_ERREUR) et arrêt)
#            Pour le calcul société on arrête le calcul de la société mais on calcule la suivante
#            Pour le calcul VNC     on arrête le calcul du bien       mais on calcule le suivant
#
    Local Integer I
#


  # FQ79856
  If ( [M:DIV]TRTDEM = "CALSOC" or [M:DIV]TRTDEM = "CALDPS" or [M:DIV]TRTDEM = "CALVNC" ) Then
    [M:DIV]ERROR = [M:DIV]ERRID
  Else
    # Division par 0 pour [M:DIV]TRTDEM="CALBCO" ou "CALSIM")
    I = I/0
  Endif

End

#
#########################################################
Subprog CAL_ERREUR ( PERRLIB, PERRP, PERRL, PERRN )
#
# - Objet  : Gestionnaire d'erreurs
#
# - Entrée : Ecran CALDIV Masque [M:DIV]
#
# - Sortie :
#
  Value Char    PERRLIB, PERRP
  Value Integer PERRL, PERRN

  #-1 -------------------------
# If ( [M:DIV]ERRID = 0 ) Then  : # FQ101833
  If ( [M:DIV]ERRID = 0 or [M:DIV]ERRID = -1) Then
    # -- Erreur X3 standard
    [M:DIV]ERRID = -1 : # FQ101833
    Local Integer IC
    Local Integer DBD, FND, DBT, FNT, DBR, FNR
    For I = 1 To len(PERRP)
      If ( pat(left$(PERRP,I),"*@*") and DBD = 0 ) Then : DBD = I+1 : Endif
      If ( pat(left$(PERRP,I),"*.")  and FND = 0 ) Then : FND = I-1 : Endif
      If ( pat(left$(PERRP,I),"*/*") and DBT = 0 ) Then : DBT = I+1 : Endif
      If ( pat(left$(PERRP,I),"*$*") and FNT = 0 ) Then : FNT = I-1 : Endif
    Next I
    #
    #  Erreur système détectée
    #
    Call ECR_TRACE(string$(41, '='),0)   From =G_GLOB0
    Call ECR_TRACE(mess(155,7774,1),0)   From =G_GLOB0  : # Erreur système détectée
    Call ECR_TRACE(string$(41, '='),0)   From =G_GLOB0
    #
    Call ECR_TRACE(mess(156,7774,1)+seg$(PERRP, DBD, FND)       , 0)    From =G_GLOB0  : # Dossier
    Call ECR_TRACE(mess(157,7774,1)+seg$(PERRP, DBT, FNT)       , 0)    From =G_GLOB0  : # Traitement
    Call ECR_TRACE(mess(158,7774,1)+num$(PERRL)                 , 0)    From =G_GLOB0  : # Ligne
    Call ECR_TRACE(mess(159,7774,1)+num$(PERRN)                 , 0)    From =G_GLOB0  : # Erreur num.
    Call ECR_TRACE(mess(160,7774,1)+PERRLIB                   , 0)      From =G_GLOB0  : # Erreur lib.
    If ( dim([M:DIV]BCO) <> -1 and [M:DIV]BCO <> "") Then
      Call ECR_TRACE(mess(161,7774,1)+[M:DIV]BCO              , 0)      From =G_GLOB0  : # Bien
    Endif

    If ([M:DIV]BFS2OPN) Then
      Call ECR_FICH("FS2", 1, "=========================================" ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, "Sage Abel X3 - Erreur système détectée   " ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, "=========================================" ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, "Dossier     : "-seg$(PERRP, DBD, FND)        ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, "Traitement  : "-seg$(PERRP, DBT, FNT) ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, "Ligne       : "-num$(PERRL)                  ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, "Erreur num. : "-num$(PERRN)                   ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, "Erreur lib. : "-PERRLIB                    ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, " ") From =G_GLOB0
      Call ECR_FICH("FS2", 1, "============================"              ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, "ERREUR - Arborescence"                     ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, "============================"              ) From =G_GLOB0
      Call ECR_FICH("FS2", 1, " ") From =G_GLOB0
      For LNIV = 1 To [M:DIV]LVL
        Call ECR_FICH("FS2", 1, num$(LNIV) + "-" + [M:DIV]LVLID(LNIV-1)) From =G_GLOB0
      Next LNIV
      Call ECR_FICH("FS2", 1, " ") From =G_GLOB0
      If ( dim([M:DIV]BCO) <> -1 and [M:DIV]BCO <> "" ) Then
        Call ECR_FICH("FS2", 1, "Bien   :"-[M:DIV]BCO) From =G_GLOB0
      Endif
    Endif
  #-1 -------------------------
  Else
    # -- Erreur Logique Calcul
    Local Integer LNIV
    #
    #-- Erreur logique détectée
    #
    Call ECR_TRACE(string$(41, '='),0)   From =G_GLOB0
    Call ECR_TRACE(mess(162,7774,1),0)   From =G_GLOB0  : # Erreur logique détectée
    Call ECR_TRACE(string$(41, '='),0)   From =G_GLOB0
    If ([M:DIV]BCO <> "" ) Then
      Call ECR_TRACE(mess(161,7774,1)+[M:DIV]BCO, 0) From =G_GLOB0          : # Bien
    Endif
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # Si ajout d'un errid en clair il faut également mettre à jour CALCULER_SOCIETE_BIENS
    If ( [M:DIV]ERRID = 5 ) Then
      Call ECR_TRACE(mess(195,7774,1), 0) From =G_GLOB0  : # Mode d'amortissement inconnu
    Elsif ( [M:DIV]ERRID = 14 ) Then
      Call ECR_TRACE(mess(197,7774,1), 0) From =G_GLOB0  : # Erreur lors de la suppression des DEPREC en trop par rapport à l'horizon
    Elsif ( [M:DIV]ERRID = 18 ) Then
      Call ECR_TRACE(mess(198,7774,1), 0) From =G_GLOB0  : # Date passée à la fonction CAL_LOCALISE_DAT hors limite
    Elsif ( [M:DIV]ERRID = 20 ) Then
      Call ECR_TRACE(mess(163,7774,1), 0) From =G_GLOB0  : # Dépassement du temps limite
    Elsif ( [M:DIV]ERRID = 22 ) Then
      Call ECR_TRACE(mess(165,7774,1), 0) From =G_GLOB0  : # Aucun contexte pour le plan passé en paramètre
    Elsif ( [M:DIV]ERRID = 23 ) Then
      Call ECR_TRACE(mess(199,7774,1), 0) From =G_GLOB0  : # CAL_EXERCICE_SELON_DATE, l'exercice d'appartenance [0/0/0] ne peut pas être déterminé
    Elsif ( [M:DIV]ERRID = 24 ) Then
      Call ECR_TRACE(mess(200,7774,1), 0) From =G_GLOB0  : # Le type de prorata n'a pas pu être déterminé en fonction du mode d'amortissement
    Elsif ( [M:DIV]ERRID = 26 ) Then
      Call ECR_TRACE(mess(201,7774,1), 0) From =G_GLOB0  : # Les dates passées en paramètres à CAL_DAT_BORNES sont inconsistantes
    Elsif ( [M:DIV]ERRID = 27 ) Then
      Call ECR_TRACE(mess(166,7774,1), 0) From =G_GLOB0  : # Dépassement CALDEP
    Elsif ( [M:DIV]ERRID = 29 ) Then
      Call ECR_TRACE(mess(167,7774,1), 0) From =G_GLOB0  : # Erreur chronologie des périodes
    Elsif ( [M:DIV]ERRID = 30 ) Then
      Call ECR_TRACE(mess(168,7774,1), 0) From =G_GLOB0  : # Dépassement CALFIY
    Elsif ( [M:DIV]ERRID = 31 ) Then
      Call ECR_TRACE(mess(169,7774,1), 0) From =G_GLOB0  : # Dépassement CALPPL
    Else
      Call ECR_TRACE(mess(153,7774,1)+num$([M:DIV]ERRID), 0) From =G_GLOB0  : # Erreur
    Endif

    If ([M:DIV]BFS2OPN) Then
      Call ECR_FICH("FS2", 1, "============================") From =G_GLOB0
      Call ECR_FICH("FS2", 1, "ERREUR - Arborescence") From =G_GLOB0
      Call ECR_FICH("FS2", 1, "============================") From =G_GLOB0
      Call ECR_FICH("FS2", 1, " ") From =G_GLOB0
      For LNIV = 1 To [M:DIV]LVL
        Call ECR_FICH("FS2", 1, num$(LNIV) + "-" + [M:DIV]LVLID(LNIV-1)) From =G_GLOB0
      Next LNIV
      If ( dim([M:DIV]BCO) <> -1 and [M:DIV]BCO <> "" ) Then
        Call ECR_FICH("FS2", 1, "Bien   :"-[M:DIV]BCO) From =G_GLOB0
      Endif
      Call ECR_FICH("FS2", 1, "Erreur :"-num$([M:DIV]ERRID)) From =G_GLOB0

    Endif
  Endif
  #-1 -------------------------

End

#########################################################
$CAL_LEC_MODES
#
# - Objet  : Lecture de la table des mode d'amortissement
#                    de la table des options paramétrées
#                    de la table des taux
#
# - Entrée : Société
#
#
# - Sortie :
#   Boite noire
#

#   Optimisation possible ne charger
#   dans ces tableaux que les modes
#   rééllement utilisés par le calcul
#


Local Integer INDMOD
Local Integer INDOPT
Local Integer INDRAT


  Call ECR_FICH("FS1", 2, "CAL_LEC_MODES        - Acquisition - Modes") From =G_GLOB0

  Raz [M:DPM]
  #------------------------------------
  If clalev([F:WDPM])=0   : Local File DPRMOD     [WDPM]   :  Endif      : # Modes d'amortissement
  If clalev([F:WDMO])=0   : Local File DPRMODOPT  [WDMO]   :  Endif      : # Option Mode d'Amortissement
  If clalev([F:WDMR])=0   : Local File DPRMODRAT  [WDMR]   :  Endif      : # Taux Mode d'Amortissement
  #------------------------------------

  INDMOD = 1
  INDOPT = 1
  INDRAT = 1
  # >>>>>>>>>>>>>>>>>>>>>>>>>>>
  For [WDPM]DPM0 Where ( [F:WDPM]CPY = [M:DIV]SOC or [F:WDPM]CPY = "" )
    # -------------------------
    # --- Mode d'amortissement
    [M:DPM]CPY      (INDMOD-1)= [F:WDPM]CPY
    [M:DPM]DPM      (INDMOD-1)= [F:WDPM]DPM
    [M:DPM]CRY      (INDMOD-1)= [F:WDPM]CRY
    [M:DPM]DPMRSD   (INDMOD-1)= [F:WDPM]RSDDPMTGR
    [M:DPM]PRODPMRSD(INDMOD-1)= [F:WDPM]PRATYPTGR
    [M:DPM]ENAFLG   (INDMOD-1)= [F:WDPM]ENAFLG
    [M:DPM]DES      (INDMOD-1)= [F:WDPM]DES
    [M:DPM]DPRMODTYP(INDMOD-1)= [F:WDPM]DPRMODTYP
    [M:DPM]STDDPM   (INDMOD-1)= [F:WDPM]STDDPM
    [M:DPM]STDDPMNUM(INDMOD-1)= [F:WDPM]STDDPMNUM
    [M:DPM]ETRDATTYP(INDMOD-1)= [F:WDPM]ETRDATTYP
    [M:DPM]ENDDPRTYP(INDMOD-1)= [F:WDPM]ENDDPRTYP
    [M:DPM]ENDDATTYP(INDMOD-1)= [F:WDPM]ENDDATTYP
    [M:DPM]PROTYP   (INDMOD-1)= [F:WDPM]PROTYP
    [M:DPM]BASTYP   (INDMOD-1)= [F:WDPM]BASTYP
    [M:DPM]RATNBR   (INDMOD-1)= [F:WDPM]RATNBR
    [M:DPM]FIRFIYFLG(INDMOD-1)= [F:WDPM]FIRFIYFLG
    [M:DPM]ANIDATFLG(INDMOD-1)= [F:WDPM]ANIDATFLG
    [M:DPM]MINDPRTYP(INDMOD-1)= [F:WDPM]MINDPRTYP
    [M:DPM]MINDPRRAT(INDMOD-1)= [F:WDPM]MINDPRRAT
    [M:DPM]MAXDPRTYP(INDMOD-1)= [F:WDPM]MAXDPRTYP
    [M:DPM]MAXDPRRAT(INDMOD-1)= [F:WDPM]MAXDPRRAT
    [M:DPM]RATCOETYP(INDMOD-1)= [F:WDPM]RATCOETYP
    [M:DPM]EXCDPRTYP(INDMOD-1)= [F:WDPM]EXCDPRTYP
    [M:DPM]EXCDPRRAT(INDMOD-1)= [F:WDPM]EXCDPRRAT
    [M:DPM]MINDPRLIF(INDMOD-1)= [F:WDPM]MINDPRLIF
    [M:DPM]DPRDISRUL(INDMOD-1)= [F:WDPM]DPRDISRUL : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
    # -------------------------

    # --- Option d'amortissement
    NBROPT = 0
    # >>>>>>>>>>>>>>>>>>>>>>>>>>>
    For [WDMO]DMO0 Where STDDPM=[F:WDPM]STDDPM and ( OPTCPY=[M:DIV]SOC or OPTCPY="")
      # Options du mode
      [M:DPM]NUMDPM   (INDOPT-1) = [F:WDMO]NUMDPM
      [M:DPM]OPTTYP   (INDOPT-1) = [F:WDMO]OPTTYP
      [M:DPM]OPTCOD   (INDOPT-1) = [F:WDMO]OPTCOD
      [M:DPM]OPTRAT   (INDOPT-1) = [F:WDMO]OPTRAT
      [M:DPM]STRVLYDAT(INDOPT-1) = [F:WDMO]STRVLYDAT
      [M:DPM]ENDVLYDAT(INDOPT-1) = [F:WDMO]ENDVLYDAT
      [M:DPM]REFDATTYP(INDOPT-1) = [F:WDMO]REFDATTYP
      [M:DPM]OPTCPY   (INDOPT-1) = [F:WDMO]OPTCPY
      [M:DPM]DPRPLN   (INDOPT-1) = [F:WDMO]DPRPLN

      NBROPT += 1
      INDOPT += 1
    Next
    #<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<

    [M:DPM]OPTNBR (INDMOD-1) = NBROPT
    If (NBROPT = 0 ) Then
      [M:DPM]INDDEBOPT(INDMOD-1) = 0
      [M:DPM]INDFINOPT(INDMOD-1) = 0
    Else
      [M:DPM]INDDEBOPT(INDMOD-1) = INDOPT - NBROPT
      [M:DPM]INDFINOPT(INDMOD-1) = INDOPT - 1
    Endif


    # --- Taux d'amortissement
    NBRRAT = 0
    # >>>>>>>>>>>>>>>>>>>>>>>>>>>
    For [WDMR]DMR0 Where DPM=[F:WDPM]DPM and ( CPY=[M:DIV]SOC or CPY="")
      # Taux du mode
      [M:DPM]NUM (INDRAT-1) = [F:WDMR]NUM
      [M:DPM]RAT (INDRAT-1) = [F:WDMR]RAT
      NBRRAT += 1
      INDRAT += 1
    Next
    #<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<

    [M:DPM]RATNBR (INDMOD-1) = NBRRAT
    If (NBRRAT = 0 ) Then
      [M:DPM]INDDEBRAT(INDMOD-1) = 0
      [M:DPM]INDFINRAT(INDMOD-1) = 0
    Else
      [M:DPM]INDDEBRAT(INDMOD-1) = INDRAT - NBRRAT
      [M:DPM]INDFINRAT(INDMOD-1) = INDRAT - 1
    Endif

    INDMOD += 1
  Next
  #<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<

  [M:DPM]NB_MOD = INDMOD-1
  [M:DPM]NB_OPT = INDOPT-1
  [M:DPM]NB_RAT = INDRAT-1

  # Récupération du paramètrage relatif au mode "IT"
  # Prorata lors de l'exercice d'investissement
  # Prorata lors de l'exercice de désinvestissement
  [M:DIV]PROEXEINV = G_NON
  [M:DIV]PROEXESOR = G_NON
  INDMOD = find(G_DPMIT,[M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    For INDOPT = [M:DPM]INDDEBOPT(INDMOD-1) To [M:DPM]INDFINOPT(INDMOD-1)
      Case [M:DPM]OPTCOD(INDOPT-1)
        When GVML_COPRINV : [M:DIV]PROEXEINV = G_OUI
        When GVML_COPRDES : [M:DIV]PROEXESOR = G_OUI
      Endcase
    Next INDOPT
  Endif
  Call ECR_FICH("FS1", 9, "Mode *IT* Prorata exercice d'investissement. : "+mess([M:DIV]PROEXEINV,1,1)) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Mode *IT* Prorata exercice de sortie ....... : "+mess([M:DIV]PROEXESOR,1,1)) From =G_GLOB0

  # Récupération du paramètrage relatif au mode "DB"
  # Sans Prorata, Prorata jour, Prorata mois
  [M:DIV]PROEXEMDB = GVML_COPSANS
  INDMOD = find(G_DPMDB, [M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    [M:DIV]PROEXEMDB = [M:DPM]OPTCOD([M:DPM]INDFINOPT(INDMOD-1)-1)
  Endif

  # Récupération du paramètrage relatif au mode "LB"
  # Sans Prorata, Prorata jour, Prorata mois
  [M:DIV]PROEXEMLB = GVML_COPSANS
  INDMOD = find(G_DPMLB, [M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    [M:DIV]PROEXEMLB = [M:DPM]OPTCOD([M:DPM]INDFINOPT(INDMOD-1)-1)
  Endif
  Call ECR_FICH("FS1", 9, "Mode *LB* Prorata à appliquer .............. : "+mess([M:DIV]PROEXEMLB,3116,1)) From =G_GLOB0

  # Récupération du paramètrage relatif au mode "DA","DX"
  # Régle de simplification ( la règle associée au mode "DA" est appliquée au mode "DX" )
  [M:DIV]RGLSIMPL = G_NON
  INDMOD = find(G_DPMDA, [M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    [M:DIV]RGLSIMPL = G_OUI
  Endif
  Call ECR_FICH("FS1", 9, "Mode *DA* Règle de simplification    ....... : "+mess([M:DIV]RGLSIMPL,1,1)) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Mode *DX* Règle de simplification    ....... : "+mess([M:DIV]RGLSIMPL,1,1)) From =G_GLOB0

  # Récupération du paramétrage relatif au mode "LP"
  # Taux prioritaire
  [M:DIV]FLGTXPRI = G_NON
  INDMOD = find(G_DPMLP, [M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    # Le taux d'amortissement prime sur la date de  fin d'amortissement
    [M:DIV]FLGTXPRI = G_OUI
  Endif
  Call ECR_FICH("FS1", 9, "Mode *LP* Le taux prime sur la fin d'amort.  : "+mess([M:DIV]FLGTXPRI,1,1)) From =G_GLOB0

  # Récupération du paramétrage relatif au mode "SL"
  # Taux prioritaire FQ82075
  [M:DIV2]SLTXPRI = G_NON
  INDMOD = find(G_DPMSL, [M:DPM]DPM)
  If ( INDMOD <> 0 and [M:DPM]INDFINOPT(INDMOD-1) <> 0 ) Then
    # Le taux d'amortissement prime sur la date de  fin d'amortissement
    [M:DIV2]SLTXPRI = G_OUI
  Endif
  Call ECR_FICH("FS1", 9, "Mode *SL* Le taux prime sur la fin d'amort.  : "+mess([M:DIV2]SLTXPRI,1,1)) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

Return


#########################################################
Subprog  CAL_LEC_CONTEXTES (PSOC, RERROR)
#
# - Objet     : Lecture des contextes et des plans
#               à calculer pour la société
#
#               ***********************************************************
#   Attention : Sous programme également exploité dans le source TRTFASFLX
#               ***********************************************************
#
# - Entrée : Société
#
#
# - Sortie :
#   Boite noire
#

Value Char       PSOC
Variable Decimal RERROR

Local Integer I
Local Integer INDCNT
Local Integer INDPLN

  Call ECR_FICH("FS1", 2, "CAL_LEC_CONTEXTES    - Acquisition - Contextes") From =G_GLOB0

  # FQ54343
  Local Integer BGESCCN : # Concessions gérée
  BGESCCN = func AFNC.ACTIV("CCN")
  [M:DIV]BACTCCN = BGESCCN

  # FQ59941
  Local Integer BACTKRU : # Russie
  BACTKRU = func AFNC.ACTIV("KRU")
  [M:DIV]BACTKRU = BACTKRU

  # FQ67577
  Local Integer BACTKPL : # Polonais
  BACTKPL = func AFNC.ACTIV("KPL")
  [M:DIV]BACTKPL = BACTKPL

  Raz [M:CNX]

  #------------------------------------
  If clalev([F:WCNX]) =0 : Local File CONTEXT    [WCNX]  : Endif        : # Contextes
  #------------------------------------

  # Plan standard par défaut non géré
  [M:DIV]PLNCPT = 0
  [M:DIV]PLNFIS = 0
  [M:DIV]PLNMIN = 0
  [M:DIV]PLNORI = 0
  [M:DIV]PLNR76 = 0
  [M:DIV]PLNIAS = 0
  [M:DIV]PLNTEC = 0
  [M:DIV]PLNRET = 0
  [M:DIV]PLNSUB = 0
  [M:DIV]PLNLI1 = 0
  [M:DIV]PLNLI2 = 0
  [M:DIV]PLNLI3 = 0
  [M:DIV]PLNLI4 = 0
  [M:DIV]PLNLI5 = 0
  [M:DIV]PLNLI6 = 0

  [M:DIV]CNXUO  = 0

  INDCNT = 1
  INDPLN = 1
  # Contextes
  For [WCNX]CNX0 Where [F:WCNX]CPY=PSOC
    # FQ76652
    If ([F:WCNX]HRZEXE = 0 or [F:WCNX]HRZPER = 0 ) Then : [F:WCNX]HRZEXE = 2 : [F:WCNX]HRZPER = 2 : Endif
    # FQ79856
    If ([F:WCNX]HRSEXE < 2 ) Then : [F:WCNX]HRSEXE = 2 : Endif
    If ([F:WCNX]HRSPER < 2 ) Then : [F:WCNX]HRSPER = 2 : Endif
    nolign = INDCNT
    [M:CNX]=[F:WCNX]
    If ([M:DIV]TRTDEM = "CALDPS") Then
      # FQ79856 en simulation substitution de l'hrizon de calcul avec l'horizon de simulation
      [M:CNX]HRZEXE(nolign-1) = [F:WCNX]HRSEXE
      [M:CNX]HRZPER(nolign-1) = [F:WCNX]HRSPER
    Endif
    INDCNT += 1
    Call ECR_FICH("FS1", 9, "Contexte  ........................ : "+mess([F:WCNX]CNX,3100,1)) From =G_GLOB0
    If ( [F:WCNX]FLGCNXUO = G_OUI ) Then
      [M:DIV]CNXUO = [F:WCNX]CNX
      Call ECR_FICH("FS1", 10, "!!! Pilote les Unités d'Oeuvres !!!") From =G_GLOB0
    Endif
    # Plans du contexte
    For I = 1 To [F:WCNX]NBPLC
      Call ECR_FICH("FS1", 9, "     Plan .......... : "+mess([F:WCNX]PLNCAA(I-1),3101,1)+"   "+mess([F:WCNX]PLNSTD(I-1),392,1)) From =G_GLOB0

      # FQ54343
      If ( G_ACTCCN =  G_OUI ) and ( [F:WCNX]CNX = G300CPFI ) Then
        If ( BGESCCN ) Then
          Raz [M:DIV]CCNFLG     : [M:DIV]CCNFLG    = [F:WCNX]CCNFLG
          Raz [M:DIV]CCNMOD     : [M:DIV]CCNMOD    = [F:WCNX]CCNMOD
          Raz [M:DIV]CCNGRTFLG  : [M:DIV]CCNGRTFLG = [F:WCNX]CCNGRTFLG
          Raz [M:DIV]CCNRPRTYP  : [M:DIV]CCNRPRTYP = [F:WCNX]CCNRPRTYP
          Raz [M:DIV]CCNINDPLN  : [M:DIV]CCNINDPLN = [F:WCNX]CCNINDPLN
          Raz [M:DIV]CCNGRTPLN  : [M:DIV]CCNGRTPLN = [F:WCNX]CCNGRTPLN
          Raz [M:DIV]CCNCADPLN  : [M:DIV]CCNCADPLN = [F:WCNX]CCNCADPLN
        Else
          Raz [M:DIV]CCNFLG
          Raz [M:DIV]CCNMOD
          Raz [M:DIV]CCNGRTFLG
          Raz [M:DIV]CCNRPRTYP
          Raz [M:DIV]CCNINDPLN
          Raz [M:DIV]CCNGRTPLN
          Raz [M:DIV]CCNCADPLN
        Endif
      Endif

      [M:DIV]PLNCNT   (INDPLN-1) = [F:WCNX]CNX              : #  Code contexte
      [M:DIV]PLNCAA   (INDPLN-1) = [F:WCNX]PLNCAA   (I-1)   : #  Code plan
      [M:DIV]ORIBASDPR(INDPLN-1) = [F:WCNX]ORIBASDPR(I-1)   : #  Origine base amortissement
      [M:DIV]PLNSTD   (INDPLN-1) = [F:WCNX]PLNSTD   (I-1)   : #  Norme
      [M:DIV]FLUTRATXS(INDPLN-1) = [F:WCNX]FLUTRATXS(I-1)   : #  Suivi flux liasse
      [M:DIV]FLUTRAACC(INDPLN-1) = [F:WCNX]FLUTRAACC(I-1)   : #  Suivi flux compte
      [M:DIV]LNKPLN   (INDPLN-1) = [F:WCNX]LNKPLN   (I-1)   : #  Plan lié

      Case [F:WCNX]PLNCAA(I-1)
        When G301CPT  : [M:DIV]PLNCPT = 1
        When G301FIS  : [M:DIV]PLNFIS = 1
        When G301MIN  : [M:DIV]PLNMIN = 1
        When G301ORI  : [M:DIV]PLNORI = 1
        When G301R76  : [M:DIV]PLNR76 = 1
        When G301IAS  : [M:DIV]PLNIAS = 1
        When G301TEC  : [M:DIV]PLNTEC = 1
        When G301RET  : [M:DIV]PLNRET = 1
        When G301SUB  : [M:DIV]PLNSUB = 1
        When G301LI1  : [M:DIV]PLNLI1 = 1
        When G301LI2  : [M:DIV]PLNLI2 = 1
        When G301LI3  : [M:DIV]PLNLI3 = 1
        When G301LI4  : [M:DIV]PLNLI4 = 1
        When G301LI5  : [M:DIV]PLNLI5 = 1
        When G301LI6  : [M:DIV]PLNLI6 = 1
      Endcase
      INDPLN += 1
    Next I
 Next CNX0
  [M:CNX]NB_CNX = INDCNT-1
  [M:DIV]NB_PLN = INDPLN-1

  # Gestion des erreurs
  If ( [M:DIV]TRTDEM <> "" ) Then :  Gosub CAL_RMVLVL From =G_GLOB0 : Endif
End


#########################################################
Subprog  CAL_CNT_FROM_PLN (PSOC, PPLN, RCNT)
#
# - Objet  : Rend le contexte correspondant au plan passé
#            Rend -1 si erreur, 0 si plan=0, sinon rend le contexte
#
# - Entrée : Société
#            Plan
#
# - Sortie :
#
Value    Char    PSOC
Value    Integer PPLN
Variable Integer RCNT

Local  Integer I

  RCNT = 0
  If ( PPLN = G301CPT or PPLN = G301FIS or PPLN = G301MIN or PPLN = G301SUB ) Then
    RCNT = G300CPFI
  Else
    If clalev([F:WCNX]) =0 : Local File CONTEXT    [WCNX]  : Endif        : # Contextes
    #------------------------------------
    # Contextes
    For [WCNX]CNX0 Where [F:WCNX]CPY=PSOC
      # Plans du contexte
      For I = 1 To [F:WCNX]NBPLC
        If ( [F:WCNX]PLNCAA(I-1) = PPLN ) Then
          RCNT = [F:WCNX]CNX
          Break 2
        Endif
      Next I
    Next CNX0
  Endif

  If !(RCNT) Then
    [M:DIV]ERRID = 22 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_LEC_EXERCICES_PERIODES (PSOC, PCNT)
#
# - Objet  : Lecture de la table des exercices
#            et des périodes de l'exercice courant & suivant du contexte
#
#            Les périodes sont chargés en fonction de l'horizon HRZPER
#            Dans le cas d'une simulation périodique les périodes sont chargées
#            jusqu'à ce que l'on rencontre un exercice qui n'est pas découpé en période
#
#            rem : L'exploitation de HRZPER s'arrête à ce traitement.
#
# - Entrée :
#            Société
#            Contexte
#            Abréviation du fichier
#
# - Sortie :
#   Boite noire
#
Value    Char    PSOC
Value    Integer PCNT


  Call ECR_FICH("FS1", 2, "CAL_LEC_EXERCICES_PERIODES  - Contexte   "+ mess(PCNT,GML_NCONTEXT,1)) From =G_GLOB0

  #------------------------------------
  If clalev([F:WFIS]) =0 : Local File FISCYEAR   [WFIS]  : Endif        : # Exercices/périodes
  #------------------------------------

Local Integer I       : I = 0
Local Integer INDEXE  : INDEXE = 1  : # indice exercice
Local Integer INDPER  : INDPER = 1  : # indice période
Local Integer INDESS  : INDESS = 0  : # indice exercice suivant le Suivant
Local Integer INDCLO  : INDCLO = 0  : # indice exercice clos

Local Integer WPDS

Local Integer I_EXE
Local Date    LDTDB
Local Date    LDTDBEXE
Local Date    LDTFNEXE
Local Integer LINDEXE

#If ( GUSER = "MWA" and [M:DIV]BDEBUG and PCNT = 11 ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

# FQ74517
Local Integer LNUMEXE : LNUMEXE = 0
# FQ78670
Local Integer I_CNT : I_CNT = find(PCNT, [M:CNX]CNX)

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  Raz [M:FIY]
  # Boucle sur les exercices
  # < 1 <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
  For [WFIS]FIY0 Where [F:WFIS]CPY=PSOC and [F:WFIS]CNX=PCNT

    # Exercice courant
    If ( [F:WFIS]STAFIY = GVML_TECOURA ) Then
      # Indice de l'exercice suivant le suivant
      INDESS = INDEXE + 2
      # Paramétrage de différé
      If ( [F:WFIS]CNX = G300CPFI ) Then
        # Contexte fiscal & comptable
        [M:DIV]DIFTYP = [F:WFIS]DFDTYP
        [M:DIV]DIFRGL = [F:WFIS]DFDCOD
        [M:DIV]DIFRAT = [F:WFIS]DFDRAT
      Endif
    Endif

    # Exercice
    [M:FIY]DATSTRFIY(INDEXE-1) = [F:WFIS]DATSTRFIY
    [M:FIY]DATENDFIY(INDEXE-1) = [F:WFIS]DATENDFIY
    [M:FIY]RAT39BIS (INDEXE-1) = [F:WFIS]RAT39BIS
    [M:FIY]STAFIY   (INDEXE-1) = [F:WFIS]STAFIY
    [M:FIY]EVTCREFLG(INDEXE-1) = [F:WFIS]EVTCREFLG
    [M:FIY]DFDTYP   (INDEXE-1) = [F:WFIS]DFDTYP     # FQ90432
    [M:FIY]INDCURPER(INDEXE-1) = [F:WFIS]INDCURPER
    [M:FIY]NBRPER   (INDEXE-1) = [F:WFIS]NBRPER
    # 2 ---------------------------
    If (   [F:WFIS]STAFIY = GVML_TEPREC ) Then
      # Exercice clos ( 1 période )
      INDCLO = INDCLO + 1
      # Période
      [M:FIY]INDDEBPER(INDEXE-1) = INDPER
      [M:FIY]INDCURPER(INDEXE-1) = 1
      [M:FIY]NBRPER   (INDEXE-1) = 1
      [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRFIY
      [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDFIY
      #***************************
      #Call CAL_DAT_DIFF( LDTDBEXE, LDTFNEXE, "M" , WPDS ) From =G_GLOB9
      [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "M"
      Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
      #***************************
      [M:FIY]NBRMONPER(INDPER-1) = WPDS
      #***************************
      #Call CAL_DAT_DIFF( LDTDBEXE, LDTFNEXE, "W", WPDS ) From =G_GLOB9
      [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "W"
      Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
      #***************************
      [M:FIY]NBRWEKPER(INDPER-1) = WPDS
      #***************************
      #Call CAL_DAT_DIFF( LDTDBEXE, LDTFNEXE, "D", WPDS ) From =G_GLOB9
      [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "D"
      Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
      #***************************
      [M:FIY]NBRDAYPER(INDPER-1) = WPDS
      INDPER += 1

    # 2 ---------------------------
    Elsif ( LNUMEXE < [M:CNX]HRZPER(I_CNT-1) or ( [M:DIV]TRTDEM = "CALSIM" ) ) Then : # FQ74517 FQ78670
      # Périodes de l'exercice Courant/Suivant/Suivant du suivant selon horizon période
      LNUMEXE += 1
      # 3 ---------------------------
      If ( [F:WFIS]NBRPER = 0 ) Then
        # Si l'exercice n'est pas découpé en période, une période d'un exercice est auto générée
        [M:FIY]INDDEBPER(INDEXE-1) = INDPER
        [M:FIY]INDCURPER(INDEXE-1) = 1
        [M:FIY]NBRPER   (INDEXE-1) = 1

        [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRFIY
        [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDFIY
        #***************************
        #Call CAL_DAT_DIFF( [F:WFIS]DATSTRFIY, [F:WFIS]DATENDFIY, "M", WPDS ) From =G_GLOB9
        [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "M"
        Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
        #***************************
        [M:FIY]NBRMONPER(INDPER-1) = WPDS
        #***************************
        #Call CAL_DAT_DIFF( [F:WFIS]DATSTRFIY, [F:WFIS]DATENDFIY, "W", WPDS ) From =G_GLOB9
        [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "W"
        Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
        #***************************
        [M:FIY]NBRWEKPER(INDPER-1) = WPDS
        #***************************
        #Call CAL_DAT_DIFF( [F:WFIS]DATSTRFIY, [F:WFIS]DATENDFIY, "D", WPDS ) From =G_GLOB9
        [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
        #***************************
        [M:FIY]NBRDAYPER(INDPER-1) = WPDS
        INDPER += 1
      # 3 ---------------------------
      Else
        # Boucle sur les périodes
        # < 4 <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
        [M:FIY]INDDEBPER(INDEXE-1) = INDPER
        For I = 1 To [F:WFIS]NBRPER

           #> Contrôle de séquence des dates de période
          If (I>1 and [F:WFIS]DATSTRPER(I-1)<=[F:WFIS]DATENDPER(I-2) ) Then
            [M:DIV]ERRID = 29 : Call ERRFND From =G_GLOB0
            Break
          Endif

          [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRPER(I-1)
          [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDPER(I-1)
          [M:FIY]NBRMONPER(INDPER-1) = [F:WFIS]NBRMONPER(I-1)
          [M:FIY]NBRWEKPER(INDPER-1) = [F:WFIS]NBRWEKPER(I-1)
          [M:FIY]NBRDAYPER(INDPER-1) = [F:WFIS]NBRDAYPER(I-1)
          [M:FIY]STAPER   (INDPER-1) = [F:WFIS]STAPER(I-1)
          INDPER += 1
        Next I
        If ([M:DIV]ERROR) Then : Break : Endif
      Endif
      # 3 ---------------------------
    Else
    # 2 ---------------------------
      # Au delà de l'horizon période, quelquesoit le découpage une période d'un exercice est auto générée
      [M:FIY]INDDEBPER(INDEXE-1) = INDPER
      [M:FIY]INDCURPER(INDEXE-1) = 1
      [M:FIY]NBRPER   (INDEXE-1) = 1

      [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRFIY
      [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDFIY
      #***************************
      #Call CAL_DAT_DIFF( [F:WFIS]DATSTRFIY, [F:WFIS]DATENDFIY, "M", WPDS ) From =G_GLOB9
      [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "M"
      Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
      #***************************
      [M:FIY]NBRMONPER(INDPER-1) = WPDS
      #***************************
      #Call CAL_DAT_DIFF( [F:WFIS]DATSTRFIY, [F:WFIS]DATENDFIY, "W", WPDS ) From =G_GLOB9
      [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "W"
      Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
      #***************************
      [M:FIY]NBRWEKPER(INDPER-1) = WPDS
      #***************************
      #Call CAL_DAT_DIFF( [F:WFIS]DATSTRFIY, [F:WFIS]DATENDFIY, "D", WPDS ) From =G_GLOB9
      [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "D"
      Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
      #***************************
      [M:FIY]NBRDAYPER(INDPER-1) = WPDS
      INDPER += 1
    Endif
    # 2 ---------------------------

    INDEXE += 1
  Next
  # < 1 <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<

  If ([M:DIV]ERROR) Then : End : Endif

  # A conserver car utilisé par la génération automatique d'exercices selon l'horizon
  [M:FIY]NB_EXE = INDEXE-1
  [M:FIY]NB_PER = INDPER-1

  Local Integer EXEMAX
  If ( [M:DIV]TRTDEM = "CALSIM" ) Then
    # Simulation  FQ59941
    EXEMAX = [M:DIV]CSTFIYMAX - INDCLO
  Else
    # Cas standard FQ74517 FQ78670
    EXEMAX = [M:CNX]HRZEXE(I_CNT-1) + INDCLO
    If ([M:CNX]HRZEXE(I_CNT-1) + INDCLO> [M:DIV]CSTFIYMAX ) Then
      # Sécurité débordement [M:FIY]
      [M:DIV]ERRID = 30 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif

  # Génération automatique d'exercices selon l'horizon
  # < 1 <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
  For I_EXE = INDEXE To EXEMAX

    # Nouvel exercice
    LDTDB  = func GLOBB9.CAL_DAT_PLUS( [M:FIY]DATENDFIY(I_EXE-2), 1, "D" )

    # Début/Fin exercice
    #Call CAL_EXERCICE_SELON_DATE
    #& ( LDTDB, GVML_TPJOUR, LDTDBEXE, LDTFNEXE, LINDEXE ) From =G_GLOB8
    [M:DIV]PD(0)= LDTDB : [M:DIV]PV(0)= GVML_TPJOUR
    Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
    LDTDBEXE = [M:DIV]RD(1) : LDTFNEXE = [M:DIV]RD(2) : LINDEXE  = [M:DIV]RE(0)
    If ([M:DIV]ERROR) Then : Break : Endif

    # Au delà des exercices définis, un exercice avec une période est auto générée
    # Exercice
    [M:FIY]DATSTRFIY(I_EXE-1) = LDTDBEXE
    [M:FIY]DATENDFIY(I_EXE-1) = LDTFNEXE
    [M:FIY]RAT39BIS (I_EXE-1) = 0
    [M:FIY]STAFIY   (I_EXE-1) = 0
    [M:FIY]EVTCREFLG(I_EXE-1) = G_NON

    # Période
    [M:FIY]INDDEBPER(I_EXE-1) = INDPER
    [M:FIY]INDCURPER(I_EXE-1) = 1
    [M:FIY]NBRPER   (I_EXE-1) = 1
    [M:FIY]DATSTRPER(INDPER-1) = LDTDBEXE
    [M:FIY]DATENDPER(INDPER-1) = LDTFNEXE
    #***************************
    #Call CAL_DAT_DIFF( LDTDBEXE, LDTFNEXE, "M" , WPDS ) From =G_GLOB9
    [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "M"
    Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
    #***************************
    [M:FIY]NBRMONPER(INDPER-1) = WPDS
    #***************************
    #Call CAL_DAT_DIFF( LDTDBEXE, LDTFNEXE, "W", WPDS ) From =G_GLOB9
    [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "W"
    Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
    #***************************
    [M:FIY]NBRWEKPER(INDPER-1) = WPDS
    #***************************
    #Call CAL_DAT_DIFF( LDTDBEXE, LDTFNEXE, "D", WPDS ) From =G_GLOB9
    [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "D"
    Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WPDS = [M:DIV]RV(0)
    #***************************
    [M:FIY]NBRDAYPER(INDPER-1) = WPDS
    INDPER += 1

    # Sécurité débordement [M:FIY] FQ84281 avant = après >=
    If (INDPER >= [M:DIV]DEPMAX ) Then : Break : Endif

  Next I_EXE
  # < 1 <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<

  If ([M:DIV]ERROR) Then : End : Endif

  [M:FIY]NB_EXE = I_EXE-1
  [M:FIY]NB_PER = INDPER-1


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_LEC_TABLE ( PSOC )
#
# - Objet  : Lecture de la table des amortissements
#
# - Entrée : Société
#
#
# - Sortie :
#   Boite noire
#

Value    Char PSOC

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  Call ECR_FICH("FS1", 2, "CAL_LEC_TABLE        - Acquisition - Plafonds Véhicules") From =G_GLOB0

  Raz [M:TAB]
  #------------------------------------
  If clalev([F:WADI]) =0 : Local File ATABDIV    [WADI]  : Endif        : # Tables diverses
  #------------------------------------

  #-----------------------
  # PLAFONDS REINTEGRATION VEHICULE
  #-----------------------

Local Integer INDVEH

  INDVEH = 1
  # >>>>>>>>>>>>>>>>>
  For [WADI]CODE Where NUMTAB = GTD_PLREINV
   [M:TAB]CODVEHPLF (INDVEH-1) = [F:WADI]CODE
   [M:TAB]VEHPLF (INDVEH-1) = [F:WADI]N1
   INDVEH +=1
  Next
  # <<<<<<<<<<<<<<<<<
  [M:TAB]NB_VEH = INDVEH-1

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
$CAL_LEC_SOCIETE
#
# - Objet  : Lecture de la société
#
# - Entrée : Société
#
#
# - Sortie :
#   Boite noire
#


  If clalev([F:WCPY]) =0 : Local File COMPANY    [WCPY]  : Endif      : # Société

  Read [F:WCPY]CPY0= [M:DIV]SOC
  If (fstat) Then
    [M:DIV]ERROR = 8
    [M:DIV]ERRID = 8 : Call ERRFND From =G_GLOB0 : Return : # Dépilement suite à erreur logique
  Endif

  # -- Legislation de la société
  [M:DIV]LEGSOC = [F:WCPY]LEG


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

Return


#########################################################
Subprog  CAL_LEC_BIEN ( PREFBCO )
#
# - Objet  : Lecture du bien à calculer
#
# - Entrée : Référence
#
#
# - Sortie :
#   Boite noire
#

Value    Char    PREFBCO

  # FQ79813 If clalev([F:WFAS]) =0 : Local File FXDASSETS    [WFAS]  : Endif      : # Biens comptable

  Read [WFAS]FAS0= PREFBCO
  #------------------------------------
  If (fstat) Then
    [M:DIV]ERRID = 11 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
  Endif
  #------------------------------------
