  LCR = string$(LINE, '*') : Call ECR_TRACE(LCR,0) From =G_GLOB0
  LCR  = "! "
  LCR += left$(mess(183,7774,1)+string$(COL1, ' '), COL1)+" ! "
  Call ECR_TRACE(LCR,0) From =G_GLOB0
  LCR = string$(LINE, '*') : Call ECR_TRACE(LCR,0) From =G_GLOB0

  # Gestion des erreurs
    Gosub CAL_RMVLVL From =G_GLOB0
    End
