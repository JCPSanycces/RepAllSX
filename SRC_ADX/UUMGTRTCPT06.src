#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UUMGTRTCPT06                                      Module  Accounting   #
#                    Migration Process                                   #
#                                                                        #
#      Flow for Budget adjustments                                       #
#            BUDOD/BUDODS                                                #
#                                                                        #
##########################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTCPT06") From LECFIC
  Endif

  #Call RAZ_UUMGTRTCPT06(DOSSIER)
  Call MAJ_UUMGTRTCPT06(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


########################################################################
Subprog RAZ_UUMGTRTCPT06(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(1)<>2 : End : Endif

#----- File naming...  -----#
Local Char WNAMBDEM,WNAMBDOM
Call MIGTABNAME (DOSSIER,"BUDOD",WNAMBDEM,ERR) From TRTMIG  : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"BUDODS",WNAMBDOM,ERR) From TRTMIG : If ERR : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMBDEM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL",WNAMBDOM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif

#----- Starting process  -----#
Call MIGTABRAZ (DOSSIER,"BUDOD",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"BUDODS",ERR) From TRTMIG
Call MIGRAZKEY (DOSSIER,"UUMGTRTCPT06",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGTRTCPT06(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(1)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT06",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMBDEM,WNAMBDOM
Call MIGTABNAME (DOSSIER,"BUDOD",WNAMBDEM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT06",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"BUDODS",WNAMBDOM,ERR) From TRTMIG : If ERR : End : Endif
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT06",7,ERR) From TRTMIG : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMBDEM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT06",3,ERR) From TRTMIG : End
Endif
If filinfo(filpath("FIL",WNAMBDOM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT06",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT06",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT06",7,ERR) From TRTMIG : End : Endif

Call ECR_TIME("UUMGTRTCPT06 table BUDODS Process") From DOSSUB
Call ECR_TRACE("UUMGTRTCPT06 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"BUDOD",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"BUDODS",ERR) From TRTMIG

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:BDE])  = 0 : Local File =DOSSIER+".BUDOD"    [BDE]  : Endif :# OD Budgetaire (En-tête)
If clalev([F:BDO])  = 0 : Local File =DOSSIER+".BUDODS"   [BDO]  : Endif :# OD Budgétaire (Ligne)

# X3 Renamed File
If clalev([F:BDEM]) = 0 : Local File =DOSSIER+"."+WNAMBDEM  [BDEM] : Endif
If clalev([F:BDOM]) = 0 : Local File =DOSSIER+"."+WNAMBDOM  [BDOM] : Endif

# X3 Commun File
Gosub OPEN_FILE From UUMGTRTCPT00

If clalev([F:BUP])  = 0 : Local File =DOSSIER+".BUDPAR"   [BUP]  : Endif
If clalev([F:FCY])  = 0 : Local File =DOSSIER+".FACILITY" [FCY]  : Endif


#-----  Declaration of Variables
Gosub DECLARE From UUMGTRTCPT00

# Variables to manage Flush instruction
Local Char WTAB_BDO(30)(adxwrb), WTAB_BDE(30)(adxwrb)
Local Shortint WCPT_BDO, WCPT_BDE

Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTCPT06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

Link [BDOM] With [BUP]BUP0~=[F:BDOM]BUD, [F:FCY]FCY0=[F:BDOM]FCY, [F:BDEM]BDE0~=[F:BDOM]NUM
&    As [LNK]
&    Order By Key CLE=[F:BDOM]NUM;[F:BDOM]FCY

# EP to add a criteria in the "where"
FLUX="UUMGTRTCPT06" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CPT06
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = '[F:BDOM]NUM="'+TABMIGKEY(1)+'" & [F:BDOM]FCY>"'+TABMIGKEY(2)+'"'
Elsif STOP=2
 STOP = 0
 CRITERE = '[F:BDOM]NUM>"'+TABMIGKEY(1)+'"'
Else
 CRITERE = '1=1'
Endif

Trbegin [BDO], [BDE]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

 NBLUS +=1

 # EP to delete line
 If FILTRELIN
  FLUX="UUMGTRTCPT06" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
  If ISVALID=0 : Goto SUITE_BOUCLE : Endif
 Endif

 For [LNK]CLE(2)

  Case [F:BUP]LEV
   When 1 : COMPANY=[F:BDOM]FCY
   When 2 : COMPANY=[F:FCY]LEGCPY
  Endcase

  Gosub INI_CPY From UUMGTRTCPT00
  If !GOK : Break 2 : Endif

  For [LNK]CLE
   # To Update BUDOD table - Header of Budget adjustments (on LINNUM=1)
   Gosub MAJ30_BDE
   If !GOK : Break 3 : Endif
   # To Update BUDODS table - Lines of Budget adjustments
   Gosub MAJ30_BDO
   If !GOK : Break 3 : Endif
  Next
 Next

 NB+=1
 If NB>GMAXUPDTRS
  TABMIGKEY(1) = [F:BDOM]NUM
  TABMIGKEY(2) = [F:BDOM]FCY
  STOP=1
  Break
 Endif

$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT06",7,ERR) From TRTMIG
Else
 Flush [F:BDE]
 If fstat
  Call ECR_TRACE("File BUDOD, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub BDE_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:BDO]
 If fstat
  Call ECR_TRACE("File BUDODS, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub BDO_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(3)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY (DOSSIER,"UUMGTRTCPT06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTCPT06",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_CPT06
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [BDE], [BDO]
Close Local File [BDEM], [BDOM]
Close Local File [GCM], [LED], [CPY], [FCY]

#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"BUDOD",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"BUDODS",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTCPT06") From TRTMIG
Call ECR_TIME("UUMGTRTCPT06 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

End

################################################
$MAJ30_BDO
Raz [F:BDO]
[F:BDO] = [F:BDOM]

If [F:BUP]LEV=1
 Raz [F:BDO]FCY
Endif

#--- New fields's assignation
# Renamed field
[F:BDO]LIN    = [F:BDOM]LINNUM

# News fields
[F:BDO]CPY    = [F:CPY]CPY
[F:BDO]LEDTYP = [L]TYPANA
[F:BDO]LED    = [L]LEDANA
[F:BDO]COA    = [L]COAANA
[F:BDO]ACC    = [F:BDOM]CNA
#If [F:BDOM]AXI1>0 : [F:BDO]DIE1 = "AX"+num$([F:BDOM]AXI1) : Endif
#If [F:BDOM]AXI2>0 : [F:BDO]DIE2 = "AX"+num$([F:BDOM]AXI2) : Endif
#If [F:BDOM]AXI3>0 : [F:BDO]DIE3 = "AX"+num$([F:BDOM]AXI3) : Endif
#

If [F:BDOM]AXI1>0 : [F:BDO]DIE1   = [L]AXEA([F:BDOM]AXI1) : Endif
If [F:BDOM]AXI2>0 : [F:BDO]DIE2   = [L]AXEA([F:BDOM]AXI2) : Endif
If [F:BDOM]AXI3>0 : [F:BDO]DIE3   = [L]AXEA([F:BDOM]AXI3) : Endif

Gosub WRI_BDO
Return

################################################
$MAJ30_BDE
If [F:BDOM]LINNUM=1
 Raz [F:BDE]
 [F:BDE] = [F:BDEM]
 #
 [F:BDE]VER="1"
 [F:BDE]BUD=[F:BDOM]BUD
 #
 Gosub WRI_BDE
Endif
Return

################################################
$WRI_BDO
# To Save reference
Gosub BDO_STK
WriteB [F:BDO]
If fstat
 Call ECR_TRACE("File BDO, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub BDO_ERRTRA
 GOK=0 : Return
Endif
Return

################################################
$WRI_BDE
# To Save reference
Gosub BDE_STK
WriteB [F:BDE]
If fstat
 Call ECR_TRACE("File BDE, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub BDE_ERRTRA
 GOK=0 : Return
Endif
Return

################################################
$BDE_STK
Call STK (WTAB_BDE,WCPT_BDE,[F:BDE]NUM) From TRTMIG
Return

################################################
$BDO_STK
Call STK (WTAB_BDO,WCPT_BDO,[F:BDO]NUM-'/'-num$([F:BDO]LIN)) From TRTMIG
Return

#################################################
$BDE_ERRTRA
Call ERRTRA (WTAB_BDE,WCPT_BDE,"File BDE(NUM)=") From TRTMIG
Return

#################################################
$BDO_ERRTRA
Call ERRTRA (WTAB_BDO,WCPT_BDO,"File BDO(NUM/LIN)=") From TRTMIG
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTCPT06(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTCPT06(APPLI)
End

########################################################################

