#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des familles de compétences
# Gestion du tableau des collaborateurs compétents.
# RAZ_SZTAB_REP
# LOAD_SZTAB_REP
# LOAD_REP  : Remplit le tableaux des collaborateurs compétents
# SAVE_REP  : Sauvegarde le tableaux des collaborateurs compétents
# Gestion du tableau des queues concernées.
# RAZ_SZTAB_QUE
# LOAD_SZTAB_QUE
# LOAD_QUE  : Remplit le tableaux des queues concernées
# SAVE_QUE  : Sauvegarde le tableaux des queues concernées.
# SETPBLPAE : Réinitialisation du filtre client sur l'ensemble d'une branche de compétences
# CTLSHORTCUT : controle la saisie d'un raccourci
# LOAD_PIT : Charge le nombre de points à débiter
# SAVE_PIT : Enregistre le nombre de points à débiter#
# supprimer  LOAD_ARR     : Chargement des lignes de collaborateurs et de queues.
# supprimer    SAVE_ARR     : Création et mise à jour des lignes de collaborateur et de queues.
# supprimer  LOADPIT      : Charge le nombre de points à débiter
# supprimer  SAVEPIT      : Enregistre le nombre de points à débiter
# supprimer  DELREPLINE   : Effacement d'une ligne de collaborateur
# supprimer  DELQUELINE   : Effacement d'une ligne de queue
#
##########################################################################################################
##########################################################################################################
$RAZ_SZTAB_REP
  Raz SZTAB_REP
  Raz INBTAB_REP
Return

##########################################################################################################
$LOAD_SZTAB_REP
 Local Integer  IINDICE

  Gosub RAZ_SZTAB_REP
  ILIGNE = 0
  While ILIGNE< [M:PBL1]NBREP
    If[M:PBL1]REPNUM(ILIGNE) <> "" Then
      SZTAB_REP(INBTAB_REP) = [M:PBL1]REPNUM(ILIGNE)
      INBTAB_REP = INBTAB_REP + 1
    Endif
    ILIGNE = ILIGNE + 1
  Wend
Return

##########################################################################################################
$LOAD_REP
  #---------------------------------------------------#
  #  Remplit le tableaux des collaborateurs compétents
  #---------------------------------------------------#
Local Integer ILIGNE

  ILIGNE = 0
  Effzo [M:PBL1]10
  [M:PBL1]NBREP = 0
  Filter [PBR] Where [F:PBR]GRPPBLNUM = [M:PBL0]NUM and [F:PBR]STTFLG = 0
  For [PBR]
    [M:PBL1]REPNUM(ILIGNE) = [F:PBR]REPNUM
    [M:PBL1]SRECOU(ILIGNE) = [F:PBR]SRECOU
    ILIGNE = ILIGNE + 1
  Next
  Filter [PBR]
  [M:PBL1]NBREP = ILIGNE
Return

##########################################################################################################
#Gestion du tableau des collaborateurs compétents.
#####################################################################
$SAVE_REP
Local Integer IINDICE
Local Integer IINDICETAB
Local Integer IBTROUVE
Local Integer IBDELETE

  IINDICE = 0
  IBTROUVE = 0
  IBDELETE = 0
  #suppression des lignes supprimer
  If INBTAB_REP > 0 and [M:PBL0]NUM <> "" Then
    For IINDICETAB = 0 To INBTAB_REP-1
      IBDELETE = 0
      IBTROUVE = 0
      If SZTAB_REP(IINDICETAB) <> "" Then
        IINDICE = 0
        While IINDICE < [M:PBL1]NBREP
          If [M:PBL1]REPNUM(IINDICE) = SZTAB_REP(IINDICETAB) Then
            IBTROUVE = 1
            Break
          Endif
          IINDICE = IINDICE + 1
        Wend
      Endif
      If IBTROUVE = 0 Then
        IBDELETE = 1
      Endif
      If IBDELETE = 1 Then
        Read [PBR]PBR2=[M:PBL0]NUM;SZTAB_REP(IINDICETAB)
        If fstat = 0 Then
          If [F:PBR]SRECOU <= 0  Then
            Delete [PBR] Where [F:PBR]REPNUM=SZTAB_REP(IINDICETAB) and [F:PBR]GRPPBLNUM=[M:PBL0]NUM
            If fstat <> 0 Then
              #Erreur lors de la suppression du collaborateur.
              GMESSAGE = mess(731,182,1)
              GOK = 0
              Break
            Endif
          Else
            Readlock [PBR]PBR2=[M:PBL0]NUM;SZTAB_REP(IINDICETAB)
            If fstat <> 0 Then
              #Erreur lors de la suppression du collaborateur.
              GMESSAGE = mess(731,182,1)
              GOK = 0
              Break
            Else
              [F:PBR]STTFLG = 1
              Rewrite [PBR]
              If fstat <> 0 Then
                #Erreur lors de la suppression du collaborateur.
                GMESSAGE = mess(731,182,1)
                GOK = 0
                Break
              Endif
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  #Enregistrement des lignes saisies
  For IINDICE = 0 To [M:PBL1]NBREP-1
    If [M:PBL1]REPNUM(IINDICE) <> "" Then
      Read [PBR]PBR2=[M:PBL0]NUM;[M:PBL1]REPNUM(IINDICE)
      If fstat Then
        #Il s'agit d'un nouvel enregistrement
        [F:PBR]GRPPBLNUM = [M:PBL0]NUM
        [F:PBR]REPNUM = [M:PBL1]REPNUM(IINDICE)
        Read [AUS]CODUSR=[M:PBL1]REPNUM(IINDICE)
        If fstat Then
          [F:PBR]REPNAM = [M:PBL1]REPNUM(IINDICE)
        Else
          [F:PBR]REPNAM = [F:AUS]NOMUSR
        Endif
        [F:PBR]SRECOU = 0
        [F:PBR]STTFLG = 0
        Write [PBR]
        If fstat Then
          #L'enregistrement des collaborateurs a échoué.
          GMESSAGE = mess(727,182,1)
          GOK = 0
          Break
        Endif
      Else
        Readlock [PBR]PBR2=[M:PBL0]NUM;[M:PBL1]REPNUM(IINDICE)
        If fstat <> 0 Then
          #L'enregistrement des collaborateurs a échoué pour cause de verrouillage tiers.
          GMESSAGE = mess(728,182,1)
          GOK = 0
          Break
        Else
          [F:PBR]STTFLG = 0
          Rewrite [PBR]
          If fstat <> 0 Then
            #L'enregistrement des collaborateurs a échoué.
            GMESSAGE = mess(727,182,1)
            GOK = 0
            Break
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
$RAZ_SZTAB_QUE
  Raz SZTAB_QUE
  Raz INBTAB_QUE
Return

##########################################################################################################
$LOAD_SZTAB_QUE
Local Integer  IINDICE

  Gosub RAZ_SZTAB_QUE
  ILIGNE = 0
  While ILIGNE < [M:PBL2]NBQUE
    If [M:PBL2]QUENUM(ILIGNE) <> "" Then
      SZTAB_QUE(INBTAB_QUE) = [M:PBL2]QUENUM(ILIGNE)
      INBTAB_QUE = INBTAB_QUE + 1
    Endif
    ILIGNE = ILIGNE + 1
  Wend
Return

##########################################################################################################
$LOAD_QUE
#---------------------------------------------------#
#  Remplit le tableaux des queues concernées
#---------------------------------------------------#
Local Integer  ILIGNE

  ILIGNE = 0
  Effzo [M:PBL2]10
  [M:PBL2]NBQUE = 0
  Filter [PBQ] Where GRPPBLNUM = [M:PBL0]NUM and [F:PBR]STTFLG = 0
  For [PBQ]
    [M:PBL2]QUENUM(ILIGNE) = [F:PBQ]QUENUM
    [M:PBL2]SRECOU(ILIGNE) = [F:PBQ]SRECOU
    ILIGNE = ILIGNE + 1
  Next
  Filter [PBQ]
  [M:PBL2]NBQUE = ILIGNE
Return

##########################################################################################################
# Gestion du tableau des queues concernées.
#####################################################################
$SAVE_QUE
Local Integer IINDICE
Local Integer IINDICETAB
Local Integer IBTROUVE
Local Integer IBDELETE

  IINDICE = 0
  IBTROUVE = 0
  IBDELETE = 0
  # suppression des lignes supprimer
  If INBTAB_QUE > 0 and [M:PBL0]NUM <> "" Then
    For IINDICETAB = 0 To INBTAB_QUE-1
      IBDELETE = 0
      IBTROUVE = 0
      If SZTAB_QUE(IINDICETAB) <> "" Then
        IINDICE = 0
        While IINDICE < [M:PBL2]NBQUE
          If [M:PBL2]QUENUM(IINDICE) = SZTAB_QUE(IINDICETAB) Then
            IBTROUVE = 1
            Break
          Endif
          IINDICE = IINDICE + 1
        Wend
      Endif
      If IBTROUVE = 0 Then
        IBDELETE = 1
      Endif
      If IBDELETE = 1 Then
        Read[PBQ]PBQ2=[M:PBL0]NUM;SZTAB_QUE(IINDICETAB)
        If fstat = 0 Then
          If [F:PBQ]SRECOU <= 0 Then
            Delete [PBQ] Where [F:PBQ]QUENUM=SZTAB_QUE(IINDICETAB) and [F:PBQ]GRPPBLNUM=[M:PBL0]NUM  
            If fstat <> 0 Then
              #Erreur lors de la suppression de la queue.
              GMESSAGE = mess(733,182,1)
              GOK = 0
              Break
            Endif
          Else
            Readlock [PBQ]PBQ2=[M:PBL0]NUM;SZTAB_QUE(IINDICETAB)
            If fstat <> 0 Then
              #Erreur lors de la suppression de la queue.
              GMESSAGE = mess(733,182,1)
              GOK = 0
              Break
            Else
              [F:PBQ]STTFLG = 1
              Rewrite [PBQ]
              If fstat <> 0 Then
                #Erreur lors de la suppression de la queue.
                GMESSAGE = mess(733,182,1)
                GOK = 0
                Break
              Endif
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des lignes saisies
  For IINDICE = 0 To [M:PBL2]NBQUE-1
    If [M:PBL2]QUENUM(IINDICE) <> "" Then
      Read [PBQ]PBQ2=[M:PBL0]NUM;[M:PBL2]QUENUM(IINDICE)
      If fstat Then
        #Il s'agit d'un nouvel enregistrement
        [F:PBQ]GRPPBLNUM = [M:PBL0]NUM
        [F:PBQ]QUENUM = [M:PBL2]QUENUM(IINDICE)
        Read [QUE]QUE0=[M:PBL2]QUENUM(IINDICE)
        If fstat <> 0 Then
          [F:PBQ]QUENAM = [M:PBL2]QUENUM(IINDICE)
        Else
          # FGR 23/09/2009 : X3SUIVI58037
          #[F:PBQ]QUENAM = [F:QUE]TTR
          Call LECTEXTRA([F:PBQ]QUENAM,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
        Endif
        [F:PBQ]SRECOU = 0
        [F:PBQ]STTFLG = 0
        Write [PBQ]
        If fstat <> 0 Then
          #L'enregistrement des queues a échoué.
          GMESSAGE = mess(729,182,1)
          GOK = 0
          Break
        Endif
      Else
        Readlock [PBQ]PBQ2=[M:PBL0]NUM;[M:PBL2]QUENUM(IINDICE)
        If fstat <> 0 Then
          #L'enregistrement des queues a échoué pour cause de verrouillage tiers.
          # Transaction abandonnée
          GMESSAGE = mess(730,182,1)
          GOK = 0
          Break
        Else
          [F:PBQ]STTFLG = 0
          Rewrite [PBQ]
          If fstat <> 0 Then
            #L'enregistrement des queues a échoué.
            GMESSAGE = mess(729,182,1)
            GOK = 0
            Break
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
#  Réinitialisation du filtre client sur l'ensemble d'une branche de compétences
######################################################################
$SETPBLPAE
Local Char SZPAE

  #Réinitialisation en cours
  If !clalev([F:PBL2]) : Local File FAMPB [PBL2] : Endif
  If !clalev([F:PBL3]) : Local File FAMPB [PBL3] : Endif
  Raz SZPAE
  Filter [PBL2] Where [F:PBL2]NUM <> [M:PBL0]NUM and [F:PBL2]NUM <> [M:PBL0]PAEGRPNUM
  For [PBL2]
    #Contrôle si la compétence dépend de celle modifiée
    If [F:PBL2]PAEGRPNUM <> "" Then
      SZPAE = [F:PBL]PAEGRPNUM
      While 1    
        If SZPAE = [M:PBL0]NUM Then
          #Il s'agit d'une compétence dépendante de la compétence modifié
          [F:PBL2]PBLBPC = [M:PBL2]PBLBPC
          Rewrite [PBL2]
          If fstat Then
            #Erreur lors de la réinitialisation du filtre client sur les compétences dépendantes.
            GMESSAGE = mess(298,182,1)
            GOK = 0
          Endif
          Break
        Else
          Read [PBL3]PBL0=SZPAE
          If !fstat Then
            If [F:PBL3]PAEGRPNUM = "" Then
              Break
            Else
              SZPAE = [F:PBL3]PAEGRPNUM
            Endif
          Endif
        Endif
      Wend
    Endif
  Next
  Filter [PBL2]
Return

##########################################################################################################
# Traite la saisie d'un raccourci
########################################################
$CTLSHORTCUT
  If VALEUR <> "" Then
    If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
    If len(VALEUR) < 15 Then
      Filter [PBL] Where [F:PBL]SUT = VALEUR
      For [PBL] PBL2
        VALEUR = [F:PBL]NUM
      Next
      Filter [PBL]
    Endif
    Read [PBL]PBL0=VALEUR
    If fstat Then
      GMESSAGE = mess(83,123,1)
      GERR = 1
      mkstat = 2
    Endif
  Endif
Return

##########################################################################################################
# Charge le nombre de points à débiter
########################################################
$LOAD_PIT
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    [M:PBL2]PBLPITDEB = 0
    [M:PBL2]NULPIO = 1
    Filter [PDB] Where [F:PDB]BPR = "" and [F:PDB]ITMREF = "" and [F:PDB]PBL = [M:PBL0]NUM
    For [PDB]
      [M:PBL2]PBLPITDEB = [F:PDB]SGLNBRPIT
      [M:PBL2]NULPIO = [F:PDB]NULPIO
      Break
    Next
    Filter [PDB]
  Endif
Return

#########################################################################################################
# Enregistre le nombre de points à débiter
########################################################
$SAVE_PIT
  Read [PDB]PDB0="";"";[M:PBL0]NUM
  If fstat <> 0 Then
    [F:PDB]BPR = ""
    [F:PDB]ITMREF = ""
    [F:PDB]PBL = [M:PBL0]NUM
    If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
      # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
      [F:PDB]SGLNBRPIT = [M:PBL2]PBLPITDEB
      If [M:PBL2]NULPIO = 0 Then
        [F:PDB]NULPIO = 1
      Else
        [F:PDB]NULPIO = [M:PBL2]NULPIO
      Endif
    Endif
    [F:PDB]CREDAT = date$
    [F:PDB]CREUSR = GUSER
    Write [PDB]
    If fstat <> 0 Then
      #Erreur lors de l'enregistrement des points à débiter.
      GMESSAGE = mess(467,182,1)
      GOK = 0
    Endif
  Else
    Readlock [PDB]PDB0="";"";[M:PBL0]NUM
    If fstat <> 0 Then
      #Erreur lors de l'enregistrement des points à débiter.
      GMESSAGE = mess(467,182,1)
      GOK = 0
    Else
      If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
        # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
        [F:PDB]SGLNBRPIT = [M:PBL2]PBLPITDEB
        If [M:PBL2]NULPIO = 0 Then
          [F:PDB]NULPIO = 1
        Else
          [F:PDB]NULPIO = [M:PBL2]NULPIO
        Endif
      Endif
      [F:PDB]UPDDAT = date$
      [F:PDB]UPDUSR = GUSER
      Rewrite [PDB]
      If fstat Then
        #Erreur lors de l'enregistrement des points à débiter.
        GMESSAGE = mess(467,182,1)
        GOK = 0
      Endif
    Endif
  Endif
Return
