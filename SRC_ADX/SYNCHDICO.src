#<AdxTL>@(#)0.0.0.0 $Revision$
Call SYNCHDIC
End

Subprog SYNCHDIC
Local Char VALEUR(10), PARAM(10)(1.1)
Call TRAITE_CHAR(VALEUR,PARAM,"","SYNCHDICO","SYNCHDICO",3,"XYSYNCHDICO") From GTRAITE
End

#####################
$ACTION
Case ACTION
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#####################
$INIT_DIA
Raz [M:DIA]
Effzo TYPASS : Affzo TYPASS : Diszo TYPASS
Effzo TSTAMPD,TSTAMPH : Affzo TSTAMPD,TSTAMPH : Diszo TSTAMPD,TSTAMPH
Return

#####################
$EXEC
# Synchronisation fenetres
Local Integer TYPF   : # 1 : Invalides   2 : Horodatage inférieur à ...   3 : Toutes
Local Char TSTAMP(14)
Local Integer TYPTRT : # 1 : Liste    2 : Assemblage    3 : Validation
Local Integer TYPASS : # 1 : Tous types     2 : C/S    3 : Web
TYPF=[M]TYPFEN
If TYPF=2
  Local Integer Y1,Y2,Y3,Y4
  Y1=year([M]TSTAMPD)
  Y2=month([M]TSTAMPD)
  Y3=day([M]TSTAMPD)
  Y4=val([M]TSTAMPH)
  TSTAMP=format$("N0:####",Y1)+format$("N0:##",Y2)+format$("N0:##",Y3)
  TSTAMP+=format$("N0:####",Y4)+"00"
Endif
TYPTRT=[M]TYPTRT
TYPASS=[M]TYPASS
Call SYNCHDICO([M]APPLI,TYPF,TSTAMP,TYPTRT,TYPASS,[M]NBMAX)
Return

###############
$TERMINE
TRA = 1
Return

#####################
Subprog SYNCHDICO(APPLI1,TYPF1,TSTAMP,TYPTRT1,TYPASS1,NBMAXW)
Value Char APPLI1()
Value Integer TYPF1
Value Char TSTAMP()
Value Integer TYPTRT1,TYPASS1,NBMAXW


# Synchronisation fenetres
#
#     APPLI1  :    pour le dossier APPLI1
#     TYPF1   :    Type de fenêtres
#                 1 : Invalides   2 : Horodatage inférieur à ...   3 : Toutes   4 : En attente de validation
#     TSTAMP  :    Horodatage (si TYPF=2) sous la forme SSAAMMJJHHMMSS (exemple: 200040512123400)
#     TYPTRT1 :    Type de traitement
#                 1 : Liste    2 : Assemblage    3 : Validation
#     TYPASS1 :    Type d'assemblage (si TYPTRT=2)
#                 1 : Tous types     2 : C/S    3 : Web

Local Char FILTRE(200),APPLI(GLONADS),DESIG(30),DAT1(10),HEU1(8)

Local Integer NBTT,NBSCR,NBWIN,MOK,MAJLOC,I,INDT
Local Integer TYPF,TYPTRT,TYPASS,L

#  Variables nécessaires à l'assemblage des fenêtres
Local Char TYP(4),FIL1(200)
Local Char WK_LAN(50),WK_SEP(1)

Local Integer WOK


APPLI=APPLI1

TYPF=TYPF1
If TYPF<1 or TYPF>4 : TYPF=1 : Endif

TYPASS=TYPASS1
If TYPASS<1 or TYPASS>3 : TYPASS=1 : Endif

TYPTRT=TYPTRT1
If TYPTRT<1 or TYPTRT>3 : TYPTRT=1 : Endif

# 119695: si SCM, on valide tous
Local Integer USEETNA,USESCM,ERR_AGET
ERR_AGET = func ASYRFNC.AGET_ENDPOINT_PROPERTIES(USEETNA,USESCM)
#103571 CCL add filter to applu synchdico on X3 folder
Local Char CRITX3SCREEN(250),CRITX3WINDOW(250)
# 119695: si SCM, on valide tous
If GPRODUIT<>0 or APPLI<>GDOSX3 or [L]USESCM>0
 [L]CRITX3SCREEN = "1=1"
 [L]CRITX3WINDOW="1=1"
Else
 [L]CRITX3SCREEN = "find([F:AMK]MODULE,1,9,10)>0"
 [L]CRITX3WINDOW = "find([F:AW1]MODULE,1,9,10)>0"
Endif

If !GSERVEUR
 Call OUVRE_TRACE(mess(147,150,1)) From LECFIC
 Call TEMPON(mess(147,150,1)) From GESECRAN
Endif

Call ECR_TRACE(mess(147,150,1)-num$(date$)-num$(time$),0) From GESECRAN

Local File =APPLI+".AELT"     [AEW]
Local File =APPLI+".AELT"     [AEL1]
Local File =APPLI+".AWINDOW"  [AWI]
Local File =APPLI+".AWINDOW"  [AW1]
Local File =APPLI+".AMSK"     [AMK]
Local File =APPLI+".ACTIV"    [ACV]
# need for test module
Local File =GDOSX3+".ADOSSIER"  [ADS]

Read [F:ADS]DOSSIER = APPLI
If fstat <> 0
    Call ECR_TRACE(mess(7,125,1),1) From GESECRAN
    Goto FINSYNCH
Endif

L = type([F:AEW]ELT)-10
Local Integer NBMAXELT       : NBMAXELT=20000
Local Char ELTCOU(L) , FENETRE(L) , TTELT(L)(1..NBMAXELT)
Local Char TTTYP(4)(1..NBMAXELT)
L = type([F:AEW]ELTSTP)-10
Local Char WSTAMP(L) , LSTP(L)
Call GLOBWEB(APPLI) From INTRUTILA
Local Integer NBERR,OVERFLOW

#   Phase I - Recherche des entités

If TYPF=1      #     Recherche des éléments invalides

#  Recherche les écrans invalides
  Filter [AEW] Where ELTTYP="SCRN" and ELTINV="I"
  For [AEW]
    ELTCOU=[F:AEW]ELT
    LSTP=[F:AEW]ELTSTP
    Gosub ADDSCRN
    If NBTT>=dim(TTTYP)
      Call ECR_TRACE("More than"-num$(dim(TTTYP))-" elements to manage",1) From GESECRAN
      OVERFLOW=1
      Break 1
    Endif
  Next
  Filter [AEW]

#     Recherche les fenêtres invalides
  Case TYPASS
     When 1 : FILTRE="(ELTTYP='FENX' or ELTTYP='FENW') "
     When 2 : FILTRE="ELTTYP='FENX'"
     When 3 : FILTRE="ELTTYP='FENW'"
  Endcase
  FILTRE-="and ELTINV='I'"
  Filter [AEW] Where evalue(FILTRE)
  For [AEW]
    ELTCOU=[F:AEW]ELT
    LSTP=[F:AEW]ELTSTP
    If NBTT>=dim(TTTYP)
      If OVERFLOW=0
        Call ECR_TRACE("More than"-num$(dim(TTTYP))-" elements to manage",1) From GESECRAN
        OVERFLOW=1
      Endif
      Break 1
    Endif
    Gosub ADDWIND
  Next
  Filter [AEW]
Endif



If TYPF=2   : #  Recherche les fenetres dont l'horodatage est inférieur ou égal à TSTAMP
  Case TYPASS
     When 1 : FILTRE="(ELTTYP='FENX' or ELTTYP='FENW') "
     When 2 : FILTRE="ELTTYP='FENX'"
     When 3 : FILTRE="ELTTYP='FENW'"
  Endcase
  FILTRE-="and ELTSTP<=TSTAMP"
  Filter [AEW] Where evalue(FILTRE)
  For [AEW]
    ELTCOU=[F:AEW]ELT
    LSTP=[F:AEW]ELTSTP
    If NBTT>=dim(TTTYP)
      If OVERFLOW=0
        Call ECR_TRACE("More than"-num$(dim(TTTYP))-" elements to manage",1) From GESECRAN
        OVERFLOW=1
      Endif
      Break 1
    Endif
    Gosub ADDWIND
  Next
  Filter [AEW]
Endif

If TYPF=3   : #  Recherche de toutes les fenêtres
  Filter [AWI] Where MDL<>2
  For [AWI]
    ELTCOU=[F:AWI]WIN
    If NBTT>=dim(TTTYP)
      If OVERFLOW=0
        Call ECR_TRACE("More than"-num$(dim(TTTYP))-" elements to manage",1) From GESECRAN
        OVERFLOW=1
      Endif
      Break 1
    Endif
    Gosub ADDWIND
  Next
  Filter [AWI]
Endif

If TYPF=4   : #  Recherche de toutes les fenêtres en attente de validation
  Filter [AEW] Where ELTTYP="FENX" and ELTINV="G"
  For [AEW]
    ELTCOU=[F:AEW]ELT
    LSTP=[F:AEW]ELTSTP
    Gosub ADDWIND
    If NBTT>=dim(TTTYP)
      Call ECR_TRACE("More than"-num$(dim(TTTYP))-" elements to manage",1) From GESECRAN
      OVERFLOW=1
      Break 1
    Endif
  Next
  Filter [AEW]
Endif


Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

If TYPF=1
  If NBSCR=0
    Call ECR_TRACE(mess(127,150,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(128,150,1)-num$(NBSCR),0) From GESECRAN
  Endif
  If NBWIN=0
    Call ECR_TRACE(mess(138,150,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(137,150,1)-":"-num$(NBWIN),0) From GESECRAN
  Endif
Else
  If NBWIN=0
    Call ECR_TRACE(mess(135,150,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(69,150,1)-":"-num$(NBWIN),0) From GESECRAN
  Endif
Endif

#   Phase II - Traitement des entités collectées
If TYPTRT=1 : Goto FINSYNCH : Endif

Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

#  Déclararations nécessaires pour l'assemblage
If TYPTRT=2
  If adxlog=0 : Trbegin [AEL1] : MAJLOC=1 : Endif
  WK_LAN=GI_LLAN(1)
  For I=2 To GI_NBLAN
    WK_LAN-=GI_LLAN(I)
  Next I
  Call ENVVAR(WSTAMP) From INTRUTILA
  Case GOS(1)
    When "dos"   :  WK_SEP="\"
    When Default :  WK_SEP="/"
  Endcase
  Case TYPASS
     When 1 : TYP="ALL"
     When 2 : TYP="FENX"
     When 3 : TYP="FENW"
  Endcase

Endif

If TYPTRT=3 and TYPF=4
  If NBMAXW<>0 : NBTT=min(NBTT,NBMAXW) : Endif
  Raz NBSCR, NBWIN
Endif

For INDT=1 To NBTT
  If !GSERVEUR    : # On envoie un tempon controle d'avancement
     Call TEMPON(mess(147,150,1)-num$(INDT)+"/"-num$(NBTT)-TTELT(INDT)) From GESECRAN
  Endif
  If TYPTRT=2
     If TTTYP(INDT)="WIND"
       FENETRE=TTELT(INDT)
       Gosub ASSWIND
     Endif
  Elsif TYPTRT=3
     ELTCOU=TTELT(INDT)
     If TYPF<>4
       Case TTTYP(INDT)
         When "SCRN" : Gosub VALIDSCRN
         When "WIND" : Gosub VALIDWIND
       Endcase
     Else
       Gosub VALIDONEWIN
     Endif
  Endif
Next INDT

If MAJLOC=1 : Commit : Endif
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN
If TYPTRT=2
  Call ECR_TRACE(mess(139,150,1)-":"-num$(NBWIN),0) From GESECRAN
Elsif TYPTRT=3
  Call ECR_TRACE(mess(148,150,1)-":"-num$(NBSCR),0) From GESECRAN
  Call ECR_TRACE(mess(134,150,1)-":"-num$(NBWIN),0) From GESECRAN
Endif


$FINSYNCH:

Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call TEMPOFF From GESECRAN
Endif

End

$VALIDONEWIN
#  On valide les écrans et la fenêtre
Read [AWI]AWI0=ELTCOU
If fstat<>0 : Return : Endif
#
Local Integer IAK,MOK
If dim(GI_LLAN)<0 : Call GLOBWEB(APPLI) From INTRUTILA : Endif
If [F:AWI]MSKENT<>"" : Call VALID([F:AWI]MSKENT,APPLI,GI_NBLAN,GI_LLAN,0,MOK) From VALMSK : NBSCR+=1 : Endif
For IAK=0 To [F:AWI]NBMSK-1
  # 121394 - Check activity code on the window lines prior to validate request = start
  If [F:AWI]ACTMSK(IAK)<>""
    Read [F:ACV]=[F:AWI]ACTMSK(IAK)
    If fstat=0 & [F:ACV]FLACT=2
      Call VALID([F:AWI]NOMMSK(IAK),APPLI,GI_NBLAN,GI_LLAN,0,MOK) From VALMSK
      NBSCR+=1
    Endif
  Else
    Call VALID([F:AWI]NOMMSK(IAK),APPLI,GI_NBLAN,GI_LLAN,0,MOK) From VALMSK
    NBSCR+=1
  Endif
  # 121394 - Check activity code on the window lines prior to validate request = end
Next IAK
Call VALID(ELTCOU,APPLI,0,MOK) From VALWIN
NBWIN+=1
Return

$ADDSCRN
Read [AMK]CODMSK=ELTCOU
If fstat = 0
      # screen  with mdl = 2 .. on ne fait rien
        If  [F:AMK]MDL=2
            Return
        Elsif evalue([L]CRITX3SCREEN)=0 : #103571
            # attention sur gdosx3 ????
            Call SUPSCRN(APPLI,ELTCOU) From INTRUTILB
            #   Suppression écran
            Call ECR_TRACE(mess(54,125,1)-ELTCOU,0) From GESECRAN
            Return
        Endif
        #jira 100279 july 25 - 2018 add test of module (fct IS_VALIDATION_ENABLED moduel and activity code)
        # test module a ajouter car aelt peut contenir des elements desactivés par module
        # caution not on root folder  because we don't have to delete all screens....
        If APPLI<>GDOSX3
            WOK = func AFNC.IS_VALIDATION_ENABLED(APPLI,[F:AMK]CODACT,[F:AMK]MODULE)
            If WOK = 0
                Call SUPSCRN(APPLI,ELTCOU) From INTRUTILB
                #   Suppression écran ....   module/code activite  inactif
                If [F:AMK]CODACT = ""
                    Call ECR_TRACE(mess(54,125,1)-ELTCOU-mess(58,105,1)-num$([F:AMK]MODULE),0) From GESECRAN
                Else
                    Call ECR_TRACE(mess(54,125,1)-ELTCOU-mess(14,115,1)-[F:AMK]CODACT-mess(58,105,1)-num$([F:AMK]MODULE),0) From GESECRAN
                Endif
                Return
            Endif
        Endif
        NBTT+=1
        NBSCR+=1
        TTTYP(NBTT)="SCRN"
        TTELT(NBTT)=ELTCOU
        If TYPTRT=1
            Gosub CHLSTP
            Call ECR_TRACE("SCRN"-ELTCOU-DAT1-HEU1,0) From GESECRAN
        Endif
Endif
Return



$ADDWIND
If left$(ELTCOU,1)="_"
    If ELTCOU="_SELBOX"  : ELTCOU="AASELECT"  : Endif
    If ELTCOU="_CHOOSE"  : ELTCOU="AACHOOSE"  : Endif
    If ELTCOU="_FORMULA" : ELTCOU="AAFORMULA" : Endif
Endif
If TYPTRT1=1 and (TYPF=1 or TYPF=2) : Goto ADDWINDL : Endif
#
If !find(ELTCOU,TTELT(NBSCR+1..NBTT))
    Read [AW1]AWI0=ELTCOU
    If fstat = 0
        If [F:AW1]MDL=2
              Return
        Elsif evalue([L]CRITX3WINDOW)=0 #103571
              Call SUPWIND(APPLI,ELTCOU) From INTRUTILB
              #   Suppression fenêtre
              Call ECR_TRACE(mess(98,125,1)-ELTCOU,0) From GESECRAN
              Return
        Else
              #jira 100279 july 25 - 2018 add test of module (fct IS_VALIDATION_ENABLED moduel and activity code)
              # test module a ajouter car aelt peut contenir des elements desactivés par module
              # caution not on root folder  because we don't have to delete all screens....
              If APPLI<>GDOSX3
                  WOK = func AFNC.IS_VALIDATION_ENABLED(APPLI,[F:AW1]CODACT,[F:AW1]MODULE)
                  If WOK = 0
                        Call SUPWIND(APPLI,ELTCOU) From INTRUTILB
                        #   Suppression fenêtre ....   Code activité module
                        If [F:AW1]CODACT = ""
                            Call ECR_TRACE(mess(98,125,1)-ELTCOU-mess(58,105,1)-num$([F:AW1]MODULE),0) From GESECRAN
                        Else
                            Call ECR_TRACE(mess(98,125,1)-ELTCOU-mess(14,115,1)-[F:AW1]CODACT-mess(58,105,1)-num$([F:AW1]MODULE),0) From GESECRAN
                        Endif
                        Return
                  Endif
              Endif
              NBTT+=1
              NBWIN+=1
              TTTYP(NBTT)="WIND"
              TTELT(NBTT)=ELTCOU
              If TYPTRT=1
                      Gosub CHLSTP
                      Call ECR_TRACE("WIND"-ELTCOU-DAT1-HEU1,0) From GESECRAN
              Endif
        Endif
    Endif
Endif
Return


$ADDWINDL
If !find(ELTCOU,TTELT(NBSCR+1..NBTT))
    NBWIN+=1
    Read [AW1]AWI0=ELTCOU
    If fstat = 0
        If [F:AW1]MDL=2
                Return
        Elsif evalue([L]CRITX3WINDOW)=0 #103571
                Call SUPWIND(APPLI,ELTCOU) From INTRUTILB
                #   Suppression fenêtre
                Call ECR_TRACE(mess(98,125,1)-ELTCOU,0) From GESECRAN
                Return
        Else
                #jira 100279 july 25 - 2018 add test of module (fct IS_VALIDATION_ENABLED moduel and activity code)
                # test module a ajouter car aelt peut contenir des elements desactivés par module
                # caution not on root folder  because we don't have to delete all screens....
                If APPLI<>GDOSX3
                    WOK = func AFNC.IS_VALIDATION_ENABLED(APPLI,[F:AW1]CODACT,[F:AW1]MODULE)
                    If WOK = 0
                          Call SUPWIND(APPLI,ELTCOU) From INTRUTILB
                          #   Suppression fenêtre ....   Code activité moduel
                          If [F:AW1]CODACT = ""
                                Call ECR_TRACE(mess(98,125,1)-ELTCOU-mess(58,105,1)-num$([F:AW1]MODULE),0) From GESECRAN
                          Else
                                Call ECR_TRACE(mess(98,125,1)-ELTCOU-mess(14,115,1)-[F:AW1]CODACT-mess(58,105,1)-num$([F:AW1]MODULE),0) From GESECRAN
                          Endif
                          Return
                    Endif
                Endif
                NBTT+=1
                TTTYP(NBTT)="WIND"
                TTELT(NBTT)=ELTCOU
                Gosub CHLSTP
                Call ECR_TRACE([F:AEW]ELTTYP-[F:AEW]ELTLAN-ELTCOU-DAT1-HEU1,0) From GESECRAN
         Endif
     Endif
Endif
Return



$CHLSTP
 DAT1=num$(gdat$(val(mid$(LSTP,7,2)),val(mid$(LSTP,5,2)),val(left$(LSTP,4))))
 HEU1=mid$(LSTP,9,2)+":"+mid$(LSTP,11,2)+":"+right$(LSTP,13)
Return

# Validation masque
$VALIDSCRN
  Call VALID(ELTCOU,APPLI,1,GI_LLAN,0,MOK) From VALMSK
Return



# Validation fenêtre
$VALIDWIND
  Call VALID(ELTCOU,APPLI,1,MOK) From VALWIN
Return


# Assemblage fenêtre
$ASSWIND
    Gosub ISWINGEN
    If ISWINAP=0
      Call VALID(FENETRE,APPLI,1,MOK) From VALWIN
      Call ECR_TRACE(mess(28,126,1)-":"-FENETRE,0) From GESECRAN
    Else
      If FENETRE="AASELECT" : FENETRE="_SELBOX" : Endif
      If FENETRE="AACHOOSE" : FENETRE="_CHOOSE" : Endif
      If FENETRE="AAFORMULA" : FENETRE="_FORMULA" : Endif
      Gosub MSTAMPWIND From INTRUTILB
      Gosub WE_GENFENW  From VALWINWEB
      For I=1 To GI_NBLAN
        If TYP="FENX" or TYP="FENW"
          Readlock [AEL1]ELT0=TYP;FENETRE;GI_LLAN(I)
          [F:AEL1]ELTINV=""
          [F:AEL1]ELTSTP=WSTAMP
          Rewrite [AEL1]
        Else
          Readlock [AEL1]ELT0="FENW";FENETRE;GI_LLAN(I)
          [F:AEL1]ELTINV=""
          [F:AEL1]ELTSTP=WSTAMP
          Rewrite [AEL1]
          Readlock [AEL1]ELT0="FENX";FENETRE;GI_LLAN(I)
          [F:AEL1]ELTINV=""
          [F:AEL1]ELTSTP=WSTAMP
          Rewrite [AEL1]
        Endif
      Next I
      Call ECR_TRACE(mess(140,150,1)-":"-FENETRE,0) From GESECRAN
    Endif
Return

$ISWINGEN
  Local Integer ISWINAP
  Call NAMEFIC(APPLI,"WINA",GI_LLAN(1),FENETRE,FIL1) From INTRUTILA
  If filinfo(FIL1,0)>0 : ISWINAP=1 : Endif
Return


# Gestion du masque SYNCHDICO

##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 28-04-2004 12:02:56 (CCORA)
##########################################################################
Subprog AP_TYPFEN(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
  Effzo TSTAMPD,TSTAMPH : Diszo TSTAMPD,TSTAMPH
Else
  TSTAMPD=date$ : Affzo TSTAMPD
  Local Char HLOC(30)
  HLOC=num$(time$)
  TSTAMPH=left$(HLOC,2)+mid$(HLOC,4,2) : Affzo TSTAMPH
  Actzo TSTAMPD,TSTAMPH
Endif
End


##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 28-04-2004 15:02:14 (CCORA)
##########################################################################
Subprog AP_TYPTRT(VALEUR)
Variable Integer VALEUR

If VALEUR<>2
  Effzo TYPASS : Diszo TYPASS
Else
  [M]TYPASS=1 : Affzo TYPASS
  Actzo TYPASS
Endif
If [M]TYPFEN=4 and VALEUR=3
  If clalev ([F:AEW])=0 : Local File AELT [AEW] : Endif
  Local Integer NBW
  Filter [AEW] Where ELTTYP="FENX" and ELTINV="G"
  For [AEW]
    NBW+=1
  Next
  Filter [AEW]
  [M]NBMAX=NBW
  Actzo NBMAX
Else
  Diszo NBMAX
Endif
End


##########################################################################


######################################################################################
## Etiquette ajoutée par le superviseur (écran SYNCHDICO) 12/08/2011 14:54:51 (CCORA)
######################################################################################
Subprog AS_TYPTRT(VALEUR)
Variable Integer VALEUR
If [M]TYPFEN=4
  GMENLOC(2)=1
Else
  GMENLOC(4)=1
Endif
End

Subprog AV_NBMAX(VALEUR)
Variable Decimal VALEUR
If [M]TYPFEN<>4 or [M]TYPTRT<>3
  mkstat=1
Endif
End


######################################################################################

