#<AdxTL>@(#)11.0.0.0 $Revision$
###########################################################################
# FUNVENSPV : Visualisation des tarifs ventes appelée                     #
#             depuis les gestions articles, clients et commandes.         #
# ----------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                  #
#   - VISUSPVD   : Action associée au bouton détail tarif                 #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                    #
#   - VISUSPV    : Action associée au bouton visu tarif                   #
#   - VISUSPVD   : Action associée au bouton détail tarif                 #
###########################################################################
# Issue 122354 - 20170420 by LD : Selection inside sales Price for non intersite customer

$ACTION
#######################################################
# Actions sur le traitement standard (GTRAITE)        #
# --------------------------------------------------- #
# VISUSPVD   : Action associée au bouton détail tarif #
#######################################################
Case ACTION
 When "INIT"
  # --- Initialisations avant exécution du traitement -------
  #-----------------------------------------------#
  Case GACTION
   When "VISUSPVD"     : Gosub INIT_VISUSPVD
  Endcase
#######################################################
# Actions sur la saisie de fenêtre (GSAISIE)          #
# --------------------------------------------------- #
# VISUSPV    : Action associée au bouton visu tarif   #
# VISUSPVD   : Action associée au bouton détail tarif #
#######################################################
 When "OUVRE"
  # --- Avant déf. des boutons et ouverture de la fenêtre ---
  Case GACTION
   When "VISUSPV"      : Gosub OUVRE_VISUSPV
   When "VISUSPVD"     : Gosub OUVRE_VISUSPVD
  Endcase
 When "TITRE"
  # --- Modification du titre de la fenêtre --------------------------
  Case GACTION
   When "VISUSPVD"     : Gosub TITRE_VISUSPVD
  Endcase
 When "SETBOUT"
  # --- Positionnement des boutons --------------------------
  Case GACTION
   When "VISUSPV"      : Gosub SETBOUT_VISUSPV
   When "VISUSPVD"     : Gosub SETBOUT_VISUSPVD
  Endcase
 When "DEBUT"
  # --- Après l'ouverture de la fenêtre ---------------------
  Case GACTION
   When "VISUSPV"      : Gosub DEBUT_VISUSPV
   When "VISUSPVD"     : Gosub DEBUT_VISUSPVD
  Endcase
 When "APRES_MODIF"
  # --- Après chaque modification de champ ------------------
  Case GACTION
   When "VISUSPV"      : Gosub APRES_MODIF
   When "VISUSPVD"     : Gosub APRES_MODIF
  Endcase
 When "AVANT_BOUTON"
  # --- Avant bouton ----------------------------------------
  Case GACTION
   When "VISUSPV"      : Gosub AVBOUTON_VISUSPV
   When "VISUSPVD"     : Gosub AVBOUTON_VISUSPVD
  Endcase
 When "BOUTON"
  # ---Bouton -----------------------------------------------
  Case GACTION
   When "VISUSPVD"     : Gosub BOUTON_VISUSPVD
  Endcase
 When "FIN"
  # --- Avant de fermer la boite ----------------------------
  Case GACTION
   When "VISUSPV"      : Gosub FIN_VISUSPV
  Endcase
 When Default
Endcase
Return


#########################################################################
#    TRAITEMENT DE L'ECRAN DE VISUALISATION DES TARIFS                  #
#########################################################################
#########################################################################
$OUVRE_VISUSPV
Local    Date     WDAT      :    WDAT=PARAM(1)
Local    Char     ITMREF    :    ITMREF=PARAM(2)
Local    Char     BPCNUM    :    BPCNUM=PARAM(3)

Local    Integer  SNOLIGN   :    SNOLIGN=nolign

# --- Test pour savoir l'origine de l'appel -----------------
If ITMREF<>"" & BPCNUM<>""
  GVISUTAR=1      : # Origine commande
Elsif ITMREF<>""
  GVISUTAR=2      : # Origine article
Elsif BPCNUM<>""
  GVISUTAR=3      : # Origine client
Else
  GVISUTAR=0      : # Origine inconnue ?
Endif
# ---Chargement des filtres article et client ---------------
GFLTITM = ITMREF
GFLTBPC = BPCNUM
#-----
Local Char    WABB(3)           : # abb table   du critere
Local Char    WFLD(12)          : # champ table du critere
Local Integer WCRIIND
# Issue 122354
#Local Char    WCRISPC(50)
Local Char    WCRISPC(100)
# End Issue 122354Local Char    WWCRI1(200)
Local Char    WWCRI2(110)
Local Char    WCRITOT(250)
Local Integer WNONSEL           : # flag de non selection sur le critere

If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:PRS])=0 : Local File PRICSTRUCT [PRS] : Endif
If clalev([F:SPC])=0 : Local File SPRICCONF  [SPC] : Endif
If clalev([F:SPL])=0 : Local File SPRICLIST  [SPL] : Endif
If clalev([F:ITS])=0 : Local File ITMSALES   [ITS] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif

Read [CPY]CPY0=GSOCIETE
#--- chargement entête colonne frais/remise (1 seule fois pour les ventes)
#If !func AFNC.ACTIV("MUL")  GPLISTC=""  Else  GPLISTC=[F:CPY]PLISTC  Endif
Raz GPLISTC                            : # Bug 62428
If !fstat GPLISTC=[F:CPY]PLISTC Endif  : # Bug 62428
Read [F:PRS]PRS0=1;GPLISTC
Call COLREM("C",1,GPLISTC) From TRTPRICE

Default File [SPL]

If GFLTITM <> ""
    Call LECTURE("ITS",GFLTITM,"") From CONTOBJ
    Call LECTURE("ITM",GFLTITM,"") From CONTOBJ
Endif
If GFLTBPC <> ""
   Read [BPC]BPC0=GFLTBPC  : #Call LECTURE("BPC",GFLTBPC,"") From CONTOBJ
   Read [BPR]BPR0=GFLTBPC  : #Call LECTURE("BPR",GFLTBPC,"") From CONTOBJ
Endif

Return
#########################################################################
$DEBUT_VISUSPV

Raz [M:SPV1]
[M:SPV1]ITMREF    = GFLTITM
[M:SPV1]BPCNUM    = GFLTBPC
[M:SPV1]DAT       = WDAT
Gosub LIRE

Return
#########################################################################
$SETBOUT_VISUSPV

REP = ""
If nolign = 0 | [M:SPV1]NBTAR = 0
    Call VIREBOUT(CHMEN, "1") From GOBJET     : # bouton détail tarif
Endif

Return
#########################################################################
$AVBOUTON_VISUSPV

WWCRI2 = [M:SPV1]WCRI2(nolign-1)

Return
#########################################################################
$FIN_VISUSPV

GFLTITM = ""
GFLTBPC = ""
GVISUTAR = 0

Return
#########################################################################
#    TRAITEMENT DE L'ECRAN DETAIL DES TARIFS                            #
#########################################################################
$INIT_VISUSPVD
Local    Char     WPLI(6)       :    WPLI=PARAM(1)
Local    Integer  SNOL          :    SNOL=nolign

BOITE = "WB2"+WPLI

Return
#########################################################################
$OUVRE_VISUSPVD
Local    Char     WPLI(6)        :    WPLI=PARAM(1)
Local    Char     WWCRI1(200)    :    WWCRI1=PARAM(2)
Local    Char     WWCRI2(110)    :    WWCRI2=PARAM(3)

Local Char    WCRITOT(250)

WCRITOT = WWCRI1
If    WWCRI2 <> "" : WCRITOT += " & "+WWCRI2 : Endif

If clalev([F:TUN])=0 : Local File TABUNIT [TUN] : Endif
If clalev([F:TCU])=0 : Local File TABCUR  [TCU] : Endif

Call LECTURE("SPC",WPLI,"") From CONTOBJ
#If func AFNC.ACTIV("MUL")
Call COLREM("C",1,[F:SPC]PLISTC) From TRTPRICE
#Endif


Return

#########################################################################
$TITRE_VISUSPVD
Local Char TIT1(60)

Call TEXTE(7940,TIT) From OBJDIV
Call LECTEXTRA(TIT1,"SPRICCONF","DESAXX",[F:SPC]PLI,"") From ATEXTRA
TIT -= "-"-[F:SPC]PLI-":"-TIT1

Return
#########################################################################
$SETBOUT_VISUSPVD

REP = ""

ETABOU(GABAN)=1
ETABOU(GSPE1)=1
If [M]PLIDAT = [0/0/0]
  ETABOU(GSPE2)=0
  ETABOU(GSPE3)=0
Else
  ETABOU(GSPE2)=1
  ETABOU(GSPE3)=1
Endif

Return

#########################################################################
$DEBUT_VISUSPVD

Raz [M]
Call LECTEXTRA ([M]PLIDES,"SPRICCONF","DESAXX",[F:SPC]PLI,"") From ATEXTRA
[M]PLITYP = [F:SPC]PLITYP
[M]ITMREF = [M:SPV1]ITMREF
[M]BPCNUM = [M:SPV1]BPCNUM
[M]PLIDAT = [M:SPV1]DAT
Gosub LIREDET

Grizo PLI, ITMREF, BPCNUM

Return

#########################################################################
$AVBOUTON_VISUSPVD

Case BOUT
    When "A"
        GFLTPLI = [M]PLI
    When Default
Endcase

Return

#########################################################################
$BOUTON_VISUSPVD

Case BOUT
  When "A" : GFLTPLI = ""
             If [M:SPV1]ITMREF<>""
               Call LECTURE("ITM",[M]ITMREF,"") From CONTOBJ
               Call LECTURE("ITS",[M]ITMREF,"") From CONTOBJ
             Endif
             If [M:SPV1]BPCNUM<>""
               Call LECTURE("BPC",[M]BPCNUM,"") From CONTOBJ
               Call LECTURE("BPR",[M]BPCNUM,"") From CONTOBJ
             Endif
             Default File [SPL]
             Gosub LIREDET
  When "B" : Gosub DATINF : Gosub LIREDET
  When "C" : Gosub DATSUP : Gosub LIREDET
Endcase

Return

#########################################################################
#    ETIQUETTE APRES_MODIF
#########################################################################
# Attention : Cette étiquette doit s'appeler APRES_MODIF
#             car elle est appelée depuis les AUT.!
#########################################################################
$APRES_MODIF

# --- Modif faite pour la version Web (le test du dbgstrt(1) est pas terrible)
#     remplace le test du maskcou
Case dbgstr(1)
    When " [SPV1]" :
# --- Ecran de visu de tous les tarifs ----------------------
        Case COUZON
             When "ITMREF"
                  [M:SPV1]ITMREF = CZ
                  Gosub LIRE
             When "BPCNUM"
                  [M:SPV1]BPCNUM = CZ
                  Gosub LIRE
             When "DAT" :
                  [M:SPV1]DAT=CZ
                  Gosub LIRE
        Endcase
    When Default :
# --- Ecran de visu détail d'un tarif -----------------------
        Case COUZON
             When "PLIDAT"
                  [M:SPLV]PLIDAT=CZ
                  If [M:SPLV]PLIDAT = [0/0/0]
                     Disable GSTABOU+2
                     Disable GSTABOU+3
                  Else
                     Enable  GSTABOU+2
                     Enable  GSTABOU+3
                  Endif
                  Gosub DATDET
                  Gosub LIREDET
        Endcase
Endcase
Return

#########################################################################
$LIRE
Call TEMPON("L") From GESECRAN
Enable GSTABOU+1

nolign=0

WCRISPC="1=1"

If GVISUTAR=3                      : # visu origine client
  WCRISPC +=" & [F:SPC]CRIBPR<>0"
Elsif GVISUTAR=2
  WCRISPC +=" & [F:SPC]CRIITM<>0"  : # visu origine article
Endif

# Issue 122354
# If the customer is not intersite, the inside group price lists don't have to be selected
If [M:SPV1]BPCNUM <> ""
   Read [BPR]BPR0=[M:SPV1]BPCNUM
   If fstat Raz [F:BPR] Endif
   If [F:BPR]BETFCY<>2 WCRISPC += "& PLIBPRCNR<>2" Endif
Endif
# End issue 122354

# Bug 64697
#For [SPC]SPC1 Where PLISTC=GPLISTC & find(PLICPY,"",GSOCIETE) & PLIENAFLG=2 & evalue (WCRISPC)
For [SPC]SPC1 Where PLIENAFLG=2 & evalue (WCRISPC)
  Gosub PREPFILT
  Filter[SPL] Where evalue("PLI=[F:SPC]PLI"+WCRITOT)
  Look [SPL] First With Nohint #Gbo-Fq78022-Ajout du Nohint
  Filter[SPL]
  If fstat<=2
  # --- But du test CRIBPR et CRIITM : ( uniquement en visu depuis les commandes )
  #     pour ne pas exclure de la consultation un tarif sans donnée de la
  #     classe [F] de référence dans ses critères
  #     ( Exemple : présence uniquement du critère [F:SPK]SALFCY )
    If [M:SPV1]BPCNUM<>"" & !find("BPR",[F:SPC]ABB) & !find("BPC",[F:SPC]ABB)
&                         & [F:SPC]CRIBPR<>0
      Goto NOSELECT
    Endif
    If [M:SPV1]ITMREF<>"" & !find("ITM",[F:SPC]ABB)
&                         & [F:SPC]CRIITM<>0
      Goto NOSELECT
    Endif
    nolign += 1
    [M:SPV1] = [F:SPC]
    Call LECTEXTRA ([M:SPV1]PLIDES(nolign-1),"SPRICCONF","DESAXX",[F:SPC]PLI,"") From ATEXTRA
    [M:SPV1]WCRI1(nolign-1) = WWCRI1
    [M:SPV1]WCRI2(nolign-1) = WWCRI2
    If nolign>dim([M:SPV1]PLI)-1 GERR=2 : GMESSAGE=mess(26,100,1) : Break : Endif
    $NOSELECT
  Endif
Next
[M:SPV1]NBTAR = nolign
nolign=1

Call TEMPOFF From GESECRAN :
Affzo [SPV1]1-99
If [M:SPV1]NBTAR=0
   Infbox mess(99,100,1)
   Disable GSTABOU+1
Endif

Return

#########################################################################
$PREPFILT
WCRI    = ""
WWCRI1  = ""
WWCRI2  = ""
WCRITOT = ""
If [M:SPV1]ITMREF<>"" & [F:SPC]CRIITM <> 0
   ALPHA=num$([F:SPC]CRIITM)
   While ALPHA<>""
         I=val(left$(ALPHA,1)) : ALPHA=right$(ALPHA,2)
         Gosub CRITERE
   Wend
Endif

If [M:SPV1]BPCNUM <> "" & [F:SPC]CRIBPR <> 0
   ALPHA=num$([F:SPC]CRIBPR)
   While ALPHA<>""
         I=val(left$(ALPHA,1)) : ALPHA=right$(ALPHA,2)
         Gosub CRITERE
   Wend
Endif

WWCRI1 = WCRITOT
If [M:SPV1]DAT <> [0/0/0]
   WWCRI2 = '[M:SPV1]DAT >= [F:SPL]PLISTRDAT & [M:SPV1]DAT <= [F:SPL]PLIENDDAT'
   WCRITOT += " & " + WWCRI2
Endif
Return

#########################################################################
$CRITERE
Raz WNONSEL
WABB = [F:SPC]ABB(I-1)
If evalue("clalev([F:"+WABB+"])")=1
#     si critere sur table article/client ITMBPC, enr. doit etre garni
   If WABB="ITU"
      If [F:ITU]ITMREF<>ITMREF | [F:ITU]BPCNUM<>BPCNUM : WNONSEL=1 : Endif
   Endif
   If !WNONSEL
      WFLD     = [F:SPC]FLD(I-1)
      WCRIIND  = [F:SPC]CRIIND(I-1)
      WVAL     = "num$([F:"+WABB+"]"+WFLD+"("+num$(WCRIIND)+"))"
      WCRI     = 'PLICRI'+num$(I)+'='+WVAL
      WCRITOT += " & "+ WCRI
   Endif
Endif
Return


#########################################################################
$DATDET
WCRITOT = WWCRI1
If [M:SPLV]PLIDAT <> [0/0/0]
   WWCRI2 = '[M:SPLV]PLIDAT >= [F:SPL]PLISTRDAT & [M:SPLV]PLIDAT <= [F:SPL]PLIENDDAT'
   WCRITOT += " & "+WWCRI2
Endif
Return

#########################################################################
$DATSUP
# supérieur à date = Tarifs valides + Anciens tarifs
If [M:SPLV]PLIDAT <> [0/0/0]
   WCRITOT = WWCRI1
   WWCRI2 = '[M:SPLV]PLIDAT >= [F:SPL]PLISTRDAT'
   WCRITOT += " & "+WWCRI2
Endif
Return

#########################################################################
$DATINF
# inférieur à date = Tarifs valides + Futurs tarifs
If [M:SPLV]PLIDAT <> [0/0/0]
   WCRITOT = WWCRI1
   WWCRI2 = '[M:SPLV]PLIDAT <= [F:SPL]PLIENDDAT'
   WCRITOT += " & "+WWCRI2
Endif
Return

#########################################################################
$LIREDET
Call TEMPON("L") From GESECRAN
If [M:SPV1]ITMREF <> ""
   Call LECTURE("ITM",[M:SPV1]ITMREF,"") From CONTOBJ
   Call LECTURE("ITS",[M:SPV1]ITMREF,"") From CONTOBJ : Endif
If [M:SPV1]BPCNUM <> ""
   Call LECTURE("BPC",[M:SPV1]BPCNUM,"") From CONTOBJ
   Call LECTURE("BPR",[M:SPV1]BPCNUM,"") From CONTOBJ : Endif
[M]AFFLIB=""
nolign=0
Filter [SPL] Where evalue("PLI=[F:SPC]PLI"+WCRITOT)
For [SPL]SPL0
  nolign += 1
  [M:SPLV] = [F:SPL]
  Gosub LIENS_LIG
  If nolign>dim([M:SPLV]CRIT1)-1 GERR=2 : GMESSAGE=mess(26,100,1) : Break : Endif
Next
[M:SPLV]NBLIG = nolign
Filter [SPL]
Call TEMPOFF From GESECRAN
Affzo [M:SPLV]1-99
# Issue 104553 - 2014-12-11 by SR : Format GFORREM fait perdre le type "affiché" des frais/remises
Diszo [M:SPLV]10
# End issue 104553
Return

#########################################################################
$LIENS_LIG
# éclatement des critères
MANIP=[F:SPL]PLICRI
For RG=1 To dim([F:SPC]FLD)
 JK=instr(1,MANIP,"~")
 If JK
  Case [F:SPC]FLDTYP(RG-1)
   When "C","L","DCB","M","SFI","RAT","COE","WEI"
    Assign "[M]CRIT"+num$(RG)+"(nolign-1)" With val(left$(MANIP,JK-1))
   When Default
    Assign "[M]CRIT"+num$(RG)+"(nolign-1)" With left$(MANIP,JK-1)
  Endcase
  MANIP=(right$(MANIP,JK+1))
 Endif
Next RG
For RG=1 To 9
 Assign "[M]XFRAREM"+num$(RG)+"(nolign-1)" With [F:SPL]DCGVAL(RG-1)
Next RG
Return

#########################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If GVISUTAR=2 & VALEUR=""
  mkstat=2 : End
Endif
Call LECTURE("ITM",VALEUR,"") From CONTOBJ
Call LECTURE("ITS",VALEUR,"") From CONTOBJ
End

#########################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
End

#########################################################################
Subprog C_BPCNUM(VALEUR)
Variable Char    VALEUR()
If GVISUTAR=3 & VALEUR=""
  mkstat=2 : End
Endif
Call LECTURE("BPC",VALEUR,"") From CONTOBJ
Call LECTURE("BPR",VALEUR,"") From CONTOBJ
End

#########################################################################
Subprog AV_NBLIG
# --- Visu du libellé dans cadre du bas
[M]AFFLIB=""
If    [F:SPC]CRIITMNUM <> 0 & nolign > 0
      Call LECTURE("ITM",evalue("[M]CRIT"+num$([F:SPC]CRIITMNUM)+"(nolign-1)"),"") From CONTOBJ
      #If !fstat : [M]AFFLIB  = mess(14,195,1) + " : " + [F:ITM]ITMDES1 : Endif
      If !fstat
        Local Char WITMDES(GLONDES)                                                          # FGR 30/06/2009 : X3SUIVI56189
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        [M]AFFLIB  = mess(14,195,1) + " : " + WITMDES                                        # FGR 30/06/2009 : X3SUIVI56189
      Endif

Endif
If    [F:SPC]CRIBPCNUM <> 0 & nolign > 0
      Call LECTURE("BPR",evalue("[M]CRIT"+num$([F:SPC]CRIBPCNUM)+"(nolign-1)"),"") From CONTOBJ
      If !fstat
         If [M]AFFLIB <> "" : [M]AFFLIB += " / " : Endif
         [M]AFFLIB += mess(72,198,1) + " : " + [F:BPR]BPRNAM
      Endif
Endif
Affzo [M]AFFLIB
End






