Subprog AS_VAL5
If [M]FLD5="" : mkstat = 1 : End : Endif
End

Subprog AV_VAL5
Local Integer I
I = 5 : Goto AV_VAL

$AV_VAL
Local Char    CHAMP(10) , FORMA(30) , CAR(1) , OPTION(10)
Local Integer NOLIB , LONG
Case I
 When 1 : CHAMP = [M]FLD1
 When 2 : CHAMP = [M]FLD2
 When 3 : CHAMP = [M]FLD3
 When 4 : CHAMP = [M]FLD4
 When 5 : CHAMP = [M]FLD5
Endcase
If CHAMP=""
 FORMA = "Kf:15X"
Else
 Read [ATZ]CODZONE = [M]ATB;CHAMP
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 NOLIB = 0
 Case [F:ATY]TYPTYP
  When 1
   If [F:ATY]NOLIB<>0
    NOLIB = [F:ATY]NOLIB
   Else
    NOLIB = [F:ATZ]NOLIB
   Endif
   FORMA = "Nf:2#"
  When 7
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   If LONG>20 : LONG = 20 : Endif
   OPTION = [F:ATY]OPTION+[F:ATZ]OPTION
   If instr(1,OPTION,"C")
    CAR = "d"
   Elsif instr(1,OPTION,"A")
    CAR = "d"
   Else
    CAR = "X"
   Endif
   FORMA = "Kf:"+num$(LONG)+CAR
  When 8
   FORMA = "Df:"+GFMDAT
  When 2,3
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   FORMA = "Nf:"+num$(LONG)+"#"
  When 4
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   FORMA = "Nf:15F"
 Endcase
Endif
Case I
 When 1 : [M]FMT1 = FORMA : [M]NOLIB1 = NOLIB
 When 2 : [M]FMT2 = FORMA : [M]NOLIB2 = NOLIB
 When 3 : [M]FMT3 = FORMA : [M]NOLIB3 = NOLIB
 When 4 : [M]FMT4 = FORMA : [M]NOLIB4 = NOLIB
 When 5 : [M]FMT5 = FORMA : [M]NOLIB5 = NOLIB
Endcase
End

