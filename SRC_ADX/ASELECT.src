Goto C_FLD

Subprog S_FLD2(VALEUR)
Variable Char    VALEUR()
Goto S_FLD

Subprog C_FLD3(VALEUR)
Variable Char    VALEUR()
Goto C_FLD

Subprog S_FLD3(VALEUR)
Variable Char    VALEUR()
Goto S_FLD

Subprog C_FLD4(VALEUR)
Variable Char    VALEUR()
Goto C_FLD

Subprog S_FLD4(VALEUR)
Variable Char    VALEUR()
Goto S_FLD

Subprog C_FLD5(VALEUR)
Variable Char    VALEUR()
Goto C_FLD

Subprog S_FLD5(VALEUR)
Variable Char    VALEUR()
Goto S_FLD

$C_FLD
If VALEUR="" : End : Endif
VALEUR = toupper(VALEUR)
Local Integer K , DIME , DIMMAX
Local Char    ZONE(20)
K = instr(1,VALEUR,"(")
If K
 DIME = val(right$(VALEUR,K+1))
 ZONE = left$(VALEUR,K-1)
Else
 DIME = 0
 ZONE = VALEUR
Endif
Read [ATZ]CODZONE = [M]ATB;ZONE
If fstat
 GMESSAGE = mess(9,124,1) : # Champ inexistant
 mkstat = 2 : End
Endif
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 If !fstat & ([F:ACV]DIMFIL<>0 or [F:ACV]DIME<>0)
  DIMMAX = max([F:ACV]DIMFIL,[F:ACV]DIME)
 Endif
Else
 DIMMAX = [F:ATZ]DIME
Endif
If DIME>DIMMAX-1
 GMESSAGE = mess(46,105,1) : # Indice incorrect
 mkstat = 2 : End
Endif
VALEUR = ZONE
If DIME>0
 VALEUR += "("+num$(DIME)+")"
Endif
End

$S_FLD
Local Integer SAVMXL
SAVMXL = adxmxl
adxmxl = GNBSEL
Link [ATZ] With [ATX]NUMERO=GLANGUE;[F:ATZ]NOLONG
& As [LNK]
& Where [F:ATZ]CODFIC=[M]ATB
Choose [LNK] Using
&  [F:ATZ]CODZONE Titled mess(36,124,1)
& ,[F:ATX]TEXTE  Titled mess(82,123,1)
& Sized (80,240)
& Titled mess(4,124,1)
# Champ, Intitulé, Choix variable
If status<>7
 VALEUR = [F:ATZ]CODZONE
Endif
adxmxl = SAVMXL
End

