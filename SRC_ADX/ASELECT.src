#<AdxTL>@(#)226.0.0.0 $Revision$
Local Char    EXPR(250)
Local Integer OK
Call SELECT("PAYMENTH",EXPR,OK)
Infbox EXPR
End

Subprog SELECT(TABLE,EXPRESSION,OK)
Value    Char    TABLE()
Variable Char    EXPRESSION()
Variable Integer OK
Local Char TABETM(30)
TABETM = TABLE 
Goto P_SELECT

Subprog SELECT2(TABLE,TABETM,EXPRESSION,OK)
Value    Char    TABLE()
Value    Char    TABETM()
Variable Char    EXPRESSION()
Variable Integer OK
Goto P_SELECT

$P_SELECT
Local Integer REPONSE, ETABOU(1..GNBBOU), SAVOBJET, SAVNUMORD
If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
If clalev([F:AOS])=0 : Local File AOBJSEL   [AOS] : Endif
If clalev([F:AUS1])=0: Local File AUTILIS   [AUS1] : Endif

Call SAVBOUT From GESECRAN
SAVOBJET = GOBJET
Local Mask ASELECT [ASL]
Raz [M]
If filinfo(filpath("ETM",GUSER+"_"+TABETM+"_"+"STD","sel",0),0)>=0
    Call LECMEMO("STD","[M:ASL]",TABETM+"~"+"sel") From GMEMO
Endif
[M]FMT1 = "K:15X"
[M]FMT2 = "K:15X"
[M]FMT3 = "K:15X"
[M]FMT4 = "K:15X"
[M]FMT5 = "K:15X"
[M]ATB = TABLE
Read [ATB]CODFIC = TABLE
Call TEXTE([F:ATB]INTITFIC,[M]ATBNAM) From OBJDIV
Local Dlgbox Mask [ASL]
& Button mess(64,123,1),mess(13,109,1),mess(14,109,1),mess(38,109,1),mess(65,123,1)
& With left$(mess(64,123,1),1),left$(mess(13,109,1),1),left$(mess(14,109,1),1)
&     ,left$(mess(38,109,1),1),left$(mess(65,123,1),1)
& Coded GSTAOK,GSTABOU+1,GSTABOU2+2, GSTABOU2+3,GSTAFIN
& Titled mess(22,123,1)
& As [ASL]
Boxact [ASL]
Grizo ANDOR1
Affzo

$SAI
Raz ETABOU
ETABOU(GVALI) = 1 :# Ok
ETABOU(GABAN) = 1 :# Fin
ETABOU(GSPE1) = 1 :# Mémo
ETABOU(GSPE2) = 1 :# Rappel
ETABOU(GSPE3) = 1 :# Eff mémo
Call SETBOUT(ETABOU) From GESECRAN
GOBJET = 0

Boxinp [ASL] Using REPONSE
Case REPONSE
    When GSTAOK , GSTARET
        Gosub EXPRESSION
        OK = 1
    When GSTAFIN , GSTAESC
        EXPRESSION = ""
        OK = 0
    When GSTABOU+1
        Local Char PARBOUT(30)(1..3)
        Local Char VALBOUT(10)
        PARBOUT(1) = "[M:ASL]"
        PARBOUT(2) = TABETM+"~"+"sel"
        PARBOUT(3) = "1"
        #Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO2","GMEMO") From GSAISIE
        Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO2","GMEMO","") From GSAISIE  # FGR 21/12/2009 : X3SUIVI60986
        Affzo
        Goto SAI    
    When GSTABOU2+2
        Local Char PARBOUT(30)(1..3)
        Local Char VALBOUT(10)
        PARBOUT(1) = "[M:ASL]"
        PARBOUT(2) = TABETM+"~"+"sel"
        PARBOUT(3) = "2"
        #Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO2","GMEMO") From GSAISIE
        Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO2","GMEMO","") From GSAISIE  # FGR 21/12/2009 : X3SUIVI60986
        Affzo
        Goto SAI
    When GSTABOU2+3
        Local Char PARBOUT(30)(1..3)
        Local Char VALBOUT(10)
        PARBOUT(1) = "[M:ASL]"
        PARBOUT(2) = TABETM+"~"+"sel"
        PARBOUT(3) = "3"
        #Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO2","GMEMO") From GSAISIE
        Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO2","GMEMO","") From GSAISIE  # FGR 21/12/2009 : X3SUIVI60986
        Goto SAI
Endcase
Boxclr [ASL]
Close Local Mask [ASL]
Call RESTBOUT From GESECRAN
GOBJET = SAVOBJET
End

$EXPRESSION
EXPRESSION = ""
If [M]FLD1<>""
 Call ADDCRIT(EXPRESSION,TABLE,[M]FLD1,[M]OPE1,[M]VAL1)
 If [M]FLD2<>""
  Call ADDETOU(EXPRESSION,[M]ANDOR2,TABLE,[M]FLD2,[M]OPE2,[M]VAL2)
  If [M]FLD3<>""
   Call ADDETOU(EXPRESSION,[M]ANDOR3,TABLE,[M]FLD3,[M]OPE3,[M]VAL3)
   If [M]FLD4<>""
    Call ADDETOU(EXPRESSION,[M]ANDOR4,TABLE,[M]FLD4,[M]OPE4,[M]VAL4)
    If [M]FLD5<>""
     Call ADDETOU(EXPRESSION,[M]ANDOR5,TABLE,[M]FLD5,[M]OPE5,[M]VAL5)
     EXPRESSION += ")"
    Endif
    EXPRESSION += ")"
   Endif
   EXPRESSION += ")"
  Endif
  EXPRESSION += ")"
 Endif
Endif
If [M]EXP1<>""
 If EXPRESSION<>""
  EXPRESSION -= "&"
 Endif
 EXPRESSION -= "("+[M]EXP1+")"
Endif
Return

Subprog ADDETOU(EXPR,ETOU,TABLE,CHAMP,OPE,VALEUR)
Variable Char EXPR()
Value Integer ETOU # FGR 01/02/2010 : X3SUIVI60986
Value Char TABLE   # FGR 01/02/2010 : X3SUIVI60986
Value Char CHAMP   # FGR 01/02/2010 : X3SUIVI60986
Value Integer OPE  # FGR 01/02/2010 : X3SUIVI60986
Value Char VALEUR  # FGR 01/02/2010 : X3SUIVI60986

If EXPR<>""
 Case ETOU
  When 1 : EXPR -= "&"
  When 2 : EXPR -= "|"
 Endcase
Endif
EXPR -= "("
Call ADDCRIT(EXPR,TABLE,CHAMP,OPE,VALEUR)
End

Subprog ADDCRIT(EXPR,TABLE,CHAMP,OPE,VALEUR)
Variable Char EXPR()
Value Char TABLE   # FGR 01/02/2010 : X3SUIVI60986
Value Char CHAMP   # FGR 01/02/2010 : X3SUIVI60986
Value Integer OPE  # FGR 01/02/2010 : X3SUIVI60986
Value Char VALEUR  # FGR 01/02/2010 : X3SUIVI60986

Local Integer K , DIME
Local Char    ZONE(20)
K = instr(1,CHAMP,"(")
If K
 DIME = val(right$(CHAMP,K+1))
 ZONE = left$(CHAMP,K-1)
Else
 DIME = 0
 ZONE = CHAMP
Endif

If OPE<>1
 Read [ATZ]CODZONE = TABLE;ZONE
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If OPE=8
  EXPR += "pat("+CHAMP+","
 Else
  EXPR -= CHAMP
  Case OPE
   When 2 : EXPR += "="
   When 3 : EXPR += "<>"
   When 4 : EXPR += ">"
   When 5 : EXPR += ">="
   When 6 : EXPR += "<"
   When 7 : EXPR += "<="
  Endcase
 Endif
 Case [F:ATY]TYPTYP
  When 7
   EXPR += '"'+VALEUR+'"'
  When 8
   EXPR += '['+format$(GFMD,gdat$(VALEUR))+']'
  When Default
   EXPR += num$(VALEUR)
 Endcase
 If OPE=8
  EXPR += ")=1"
 Endif
Else
 EXPR += "1=1"
Endif
End

