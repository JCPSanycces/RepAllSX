Subprog C_VAL1
Local Integer I
I = 1 : Goto C_VAL

Subprog S_VAL1
Local Integer I
I = 1 : Goto S_VAL

Subprog C_VAL2
Local Integer I
I = 2 : Goto C_VAL

Subprog S_VAL2
Local Integer I
I = 2 : Goto S_VAL

Subprog C_VAL3
Local Integer I
I = 3 : Goto C_VAL

Subprog S_VAL3
Local Integer I
I = 3 : Goto S_VAL

Subprog C_VAL4
Local Integer I
I = 4 : Goto C_VAL

Subprog S_VAL4
Local Integer I
I = 4 : Goto S_VAL

Subprog C_VAL5
Local Integer I
I = 5 : Goto C_VAL

Subprog S_VAL5
Local Integer I
I = 5 : Goto S_VAL

$C_VAL
Local Char TYP(1)
Case I
 When 1 : TYP = left$([M]FMT1,1)
 When 2 : TYP = left$([M]FMT2,1)
 When 3 : TYP = left$([M]FMT3,1)
 When 4 : TYP = left$([M]FMT4,1)
 When 5 : TYP = left$([M]FMT5,1)
Endcase
If (TYP="N" & zc="") or (TYP="D" and len(zc)<>8)
 GMESSAGE = mess(10,123,1) : mkstat = 2 : End
# Zone obligatoire
Endif
Gosub SETNOLIB
If NOLIB
 If val(num$(zc))<1 | val(num$(zc))>len(mess(0,NOLIB,1))
  GMESSAGE = mess(83,123,1) : mkstat = 2 : End
# Valeur incorrecte
 Else
  Case I
   When 1 : [M]LIB1 = mess(val(num$(zc)),NOLIB,1) : Affzo LIB1
   When 2 : [M]LIB2 = mess(val(num$(zc)),NOLIB,1) : Affzo LIB2
   When 3 : [M]LIB3 = mess(val(num$(zc)),NOLIB,1) : Affzo LIB3
   When 4 : [M]LIB4 = mess(val(num$(zc)),NOLIB,1) : Affzo LIB4
   When 5 : [M]LIB5 = mess(val(num$(zc)),NOLIB,1) : Affzo LIB5
  Endcase
 Endif
Else
 If left$(evalue("[M]FMT"+num$(I)),1)="K"
  If instr(1,zc,'"')
   GMESSAGE = '" :'-mess(94,123,1) : mkstat = 2 : End
#  Caractère interdit
  Endif
 Endif
Endif
End

$S_VAL
Gosub SETNOLIB
If NOLIB
 Local Integer VALEUR
 VALEUR = val(num$(zc))
 Call SAILIB(NOLIB,VALEUR) From GESECRAN
 zc = num$(VALEUR)
Endif
End

$SETNOLIB
Case I
 When 1 : NOLIB = [M]NOLIB1
 When 2 : NOLIB = [M]NOLIB2
 When 3 : NOLIB = [M]NOLIB3
 When 4 : NOLIB = [M]NOLIB4
 When 5 : NOLIB = [M]NOLIB5
Endcase
Return

Subprog C_EXP1(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Integer ER
 Local Char    CHAINE(80)
 Local File =[M]ATB : # Pour l'avoir par défaut
 Default [F] , [V] , [L]
 Onerrgo ERREXP
 ER = 0
 CHAINE = num$(evalue(VALEUR))
 Onerrgo
 If ER
  mkstat = 2 : End
 Endif
Endif
End

$ERREXP
ER = errn
GMESSAGE = mess(37,124,1)+"\"+errmes$(ER)+"\"+errm
# Expression incorrecte
Resume

Subprog AS_EXP1(VALEUR)
Variable Char    VALEUR()
GBOUT4 = mess(40,124,1) : # Variables
End

Subprog B4_EXP1(VALEUR)
Variable Char VALEUR
Call SELECTAB([M]ATB,VALEUR,3) From FORMULE
End

Subprog FILTRE(TABLE,EXPRESSION)
Value    Char TABLE
Variable Char EXPRESSION()
Local Char TABETM(30)
TABETM = TABLE
Goto P_FILTRE

Subprog FILTRE2(TABLE,TABETM,EXPRESSION)
Value    Char TABLE
Value    Char TABETM
Variable Char EXPRESSION()
Goto P_FILTRE

$P_FILTRE
If filinfo(filpath("ETM",GUSER+"_"+TABETM+"_"+"STD","sel",0),0)>=0
    Local Mask ASELECT [ASL]
    Local File ATABZON [ATZ] , ATYPE [ATY]
    Raz [M]
    Call LECMEMO("STD","[M:ASL]",TABETM+"~"+"sel") From GMEMO
    Gosub EXPRESSION
Else
    EXPRESSION = ""
Endif
End

Subprog SEL_MEMO(TABLE,STAITO,MEMGLO,REPONSE,SEL_MEMO,EXPRESSION)
Value    Char    TABLE
Value    Integer STAITO
Value    Integer MEMGLO
Value    Integer REPONSE
Value    Char    SEL_MEMO()(1..)
Variable Char    EXPRESSION
Local    Char    TABETM(10)
TABETM = TABLE
Goto P_SEL_MEMO

Subprog SEL_MEMO2(TABLE,TABETM,STAITO,MEMGLO,REPONSE,SEL_MEMO,EXPRESSION)
Value    Char    TABLE
Value    Char    TABETM
Value    Integer STAITO
Value    Integer MEMGLO
Value    Integer REPONSE
Value    Char    SEL_MEMO()(1..)
Variable Char    EXPRESSION
Local    Char    TABLE(10)
Goto P_SEL_MEMO

$P_SEL_MEMO
Local    Integer NUMITM
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
Local Mask ASELECT [ASL]
Raz [M:ASL]
NUMITM = REPONSE-STAITO
If NUMITM<=MEMGLO
 Call LECMEMOPT(SEL_MEMO(NUMITM),"[M:ASL]",TABETM+"~"+"glo") From GMEMO
 Gosub EXPRESSION From ASELECT
Elsif SEL_MEMO(NUMITM)<>""
 Call LECMEMO(SEL_MEMO(NUMITM),"[M:ASL]",TABETM+"~"+"sel") From GMEMO
 Gosub EXPRESSION From ASELECT
Else
 EXPRESSION = "1=1"
Endif
Close Local Mask [ASL]
End
