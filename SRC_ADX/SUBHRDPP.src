#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################################
Raz GPILOBJ
GBIDC1="200800000272"
GBIDC2="2009~ASN999999~20090101~1~A1548901~1"
Call OBJET_CHAR(GBIDC1,"HRDPP",GBIDC2) From GOBJET
End


## Etiquette ajoutée par le superviseur (Objet HRDPP) 23/06/2009 17:34:23 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE From SUBDAP
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE 
 When "VERF_ANU"    : Gosub VERF_ANU
 When "DEFTRANS"    : Gosub DEFTRANS From SUBDAE
 When "STATUT"      : Gosub STATUT From SUBDAE
Endcase
Return


###################################
$SETBOUT    #pour désactiver le bouton nouveau & chgt clé
Call VIREBOUT (CHAINE,"CH") From GOBJET
If REP<>"" | [F:HRDAE]FLGNEWSAL=2
 Call VIREBOUT (CHAINE,"G") From GOBJET
Endif
#Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR & VERROU : CHAINE+="A" : Endif
If GREP=""
 CHMEN += "1"
Elsif GREP="M" | GREP="D"
 CHMEN=""
Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

###################################
$EXEBOUT
Case BOUT
 When "G"
  # Pas de lectcure si la création s'est mal passée...
  If !GOK : Return : Endif
  # Unlock la fiche qui était à l'écran quand on a fait "NOUVEAU"
  If VERROU  Gosub DEVERROU From GOBJET : Endif
 Gosub RAFFRAICHIR From GOBJSUB
 Gosub RELIT From GOBJSUB
Endcase
Return

###################################
$LIENS
#The read is in the object
[M:HRDPP1]NAM=[F:HRDAE]NAM
[M:HRDPP1]SRN=[F:HRDAE]SRN
Gosub CHARGE_SPE
Return

###################################
$CHARGE_SPE
nolign=0
For I=0 To dim([F:DPP]CODTYPBAS)-1
If [F:DPP]CODTYPBAS(I)=0 : Break : Endif
 nolign+=1
 [M:HRDPP1]CODTYPBAS(nolign-1)=[F:DPP]CODTYPBAS(I)
 [M:HRDPP1]AMTBAS(nolign-1)=[F:DPP]AMTBAS(I)
Next
[M:HRDPP1]NBLIG = nolign
Return

###################################
$INICRE
$INIMOD
Gosub SAUVE_SPE
[F:DPP]NBRPEO1=[F:DPP]NBRPEO2+[F:DPP]NBRPEO3+[F:DPP]NBRPEO4
Return

###################################
$SAUVE_SPE
For nolign=1 To [M:HRDPP1]NBLIG
 [F:DPP]CODTYPBAS(nolign-1)=[M:HRDPP1]CODTYPBAS(nolign-1)
 [F:DPP]AMTBAS(nolign-1)=[M:HRDPP1]AMTBAS(nolign-1)
Next
Return

###################################
$FILTRE
If find("DAE",GPILCOD(1..GPILOBJ)) | find("DAP",GPILCOD(1..GPILOBJ))
 If FILTSUP<>"" : FILTSUP += " & " : Endif
 FILTSUP -= "YEAEMPDDS='"+[F:DAP]YEAEMPDDS+"'"
 FILTSUP -= "& EMPDDS='"+[F:DAP]EMPDDS+"'"
 FILTSUP -= "& CTRNUM='"+[F:DAP]CTRNUM+"'"
 FILTSUP -= "& ETRDAT=["+format$("D:"+GFMDAT4,[F:DAP]ETRDAT)+"]"
 FILTSUP -= "& TYPDAE="+num$([F:DAP]TYPDAE)
 FILTSUP -= "& REFCTR='"+[F:DAP]REFCTR+"'"
Else
 If GUSRACS<>2
  If FILTSUP<>"" : FILTSUP += " & " : Endif
  FILTSUP -= '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
  FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
 Else
  FILTSUP ="1=1"
 Endif 
 If [L]ANCOUR<>""
  FILTSUP -= "& [F:DPP]YEAEMPDDS='"+[L]ANCOUR+"'"
 Endif
Endif
Return

###################################
$FILGAUCHE
If find("DAE",GPILCOD(1..GPILOBJ)) | find("DAP",GPILCOD(1..GPILOBJ))
 If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
 FILGAUSUP -= "YEAEMPDDS='"+[F:DAP]YEAEMPDDS+"'"
 FILGAUSUP -= "& EMPDDS='"+[F:DAP]EMPDDS+"'"
 FILGAUSUP -= "& CTRNUM='"+[F:DAP]CTRNUM+"'"
 FILGAUSUP -= "& ETRDAT=["+format$("D:"+GFMDAT4,[F:DAP]ETRDAT)+"]"
 FILGAUSUP -= "& TYPDAE="+num$([F:DAP]TYPDAE)
 FILGAUSUP -= "& REFCTR='"+[F:DAP]REFCTR+"'"
Else
 If [L]ANCOUR<>""
  If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
  FILGAUCHE = "[F:DPP]YEAEMPDDS='"+[L]ANCOUR+"'"
 Else
  FILGAUCHE = ""
 Endif
Endif
Return

###################################
$VERF_ANU
Trbegin [DPP]
 Delete [DPP] Where YEAEMPDDS=[M:HRDPP1]YEAEMPDDS & EMPDDS=[M:HRDPP1]EMPDDS
& & ETRDAT=[M:HRDPP1]ETRDAT & CTRNUM=[M:HRDPP1]CTRNUM & TYPDAE=[M:HRDPP1]TYPDAE
& & REFCTR=[M:HRDPP1]REFCTR & STRDATCTR=[M:HRDPP1]STRDATCTR
 If fstat = 1  : # enreg locké
  GLOCK = "$DADEMP32" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard 
Return

###################################
$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

###################################
$AB_ANN
Rollback
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran HRDPP1) 10/07/2009 15:28:43 (DBA)
######################################################################################
Subprog C_STRDATCTR(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR<[M]ETRDAT | VALEUR>[M]XITDAT
 #Valeur non autorisée
  GMESSAGE=mess(100,10703,1)
  mkstat=2 : End
Endif
If VALEUR<>[M]ETRDAT 
 #Un évènement salarié doit obligatoirement être renseigné pour justififier le décalage avec la période d'activité
 Call AVERTIR (mess(79,10705,1), OK) From GESECRAN
 If OK=1 : mkstat=2 : End : Endif
Endif
End

Subprog C_ENDDATCTR(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR<[M]ETRDAT | VALEUR>[M]XITDAT
 #Valeur non autorisée
  GMESSAGE=mess(100,10703,1)
  mkstat=2 : End
Endif
If VALEUR<>[M]XITDAT & [M]STRDATCTR=[M]ETRDAT
 #Un évènement salarié doit obligatoirement être renseigné pour justififier le décalage avec la période d'activité
 Call AVERTIR (mess(79,10705,1), OK) From GESECRAN
 If OK=1 : mkstat=2 : End : Endif
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran HRDPP1) 10/07/2009 18:21:15 (DBA)
######################################################################################
Subprog C_CODTYPBAS(VALEUR)
Variable Integer VALEUR
If VALEUR
 Call UNICITE(VALEUR,[M]CODTYPBAS(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End


