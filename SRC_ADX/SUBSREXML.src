#<AdxTL>@(#)8.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML d'une Demande de service                                                 Version 140
#   Module CRM                             
#
#   XXXINXML    : Objet unique avec ses tables liées en multi-niveaux.
#   XXXLISTXML  : Liste filtrée de la table objet.
#   
###############################################################################################################
###############################################################################################################
Subprog SREINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZRECNUM = "" Then
    End
  Endif
  Gosub XMLPART1 From CRMXML140
  Call TEXTE(14603, SZHTMLTITLE) From OBJDIV      #Demande de service
  SZSUBPROG = "SREINXML"
  SZAOBABREV = "SRE"
  Gosub XMLPART2 From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOCOREXML
  Gosub XMLPART3 From CRMXML140
End

#########################################################################################################################
Subprog SRELISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZCUSTFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFILTER
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZFILTER = "" Then
    SZFILTER = "1=1"
  Endif
  Gosub XMLPART1 From CRMXML140
  Call TEXTE(14508, SZHTMLTITLE) From OBJDIV      #Demandes de service
  SZSUBPROG = "SRELISTXML"
  SZAOBABREV = "SRE"
  Gosub XMLPART2B From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOLISTXML
  Gosub XMLPART3 From CRMXML140
End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOLISTXML
  Gosub SETSREEXCEPT From CRMEXCEPT
  #On extrait
  Filter [SRE] Where evalue(SZFILTER)
  For [SRE]
    SZCTAOB = "SRE"
    SZCTAOBNUM = [F:SRE]SRENUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLSRE From CRMEXCEPT
  Next
  Filter [SRE]
Return

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREXML
  Gosub SETSREEXCEPT From CRMEXCEPT
  Gosub SETBPREXCEPT From CRMEXCEPT
  Gosub SETBPCEXCEPT From CRMEXCEPT
  Gosub SETBPAEXCEPT From CRMEXCEPT
  Gosub SETSRMEXCEPT From CRMEXCEPT
  Gosub SETSRNEXCEPT From CRMEXCEPT
  Gosub SETMACEXCEPT From CRMEXCEPT
  Gosub SETHDTEXCEPT From CRMEXCEPT
  #On extrait
  Filter [SRE] Where [F:SRE]SRENUM = SZRECNUM
  For [SRE]
    SZCTAOB = "SRE"
    SZCTAOBNUM = [F:SRE]SRENUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLSRE From CRMEXCEPT
    #Parc concerné
    If IDISPLAYSRM Then
      Filter [SRM] Where [F:SRM]SRENUM = SZRECNUM
      For [SRM]SRM1
        SZCTAOB = "SRM"
        SZCTAOBNUM = [F:SRM]SRENUM + [F:SRM]MACNUM
        SZCTLEVEL = "1"
        SZCTPARENTAOB = "SRE"
        SZCTPARENTNUM = SZRECNUM
        Gosub XMLSRM From CRMEXCEPT
        #Détail parc client
        If IDISPLAYBPA Then
          Gosub ADDMAC
        Endif
        #Consommations
        If IDISPLAYHDT Then
          Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = [F:SRM]MACNUM and [F:HDT]HDTCPN = "" and [F:HDT]HDTDONDAT = [00/00/00]
&                   Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
          For [HDT] Hint Key HDT1
            SZCTAOB = "HDT"
            SZCTAOBNUM = [F:HDT]HDTNUM
            SZCTLEVEL = "2"
            SZCTPARENTAOB = "SRM"
            SZCTPARENTNUM = [F:SRM]SRENUM + [F:SRM]MACNUM
            Gosub XMLHDT From CRMEXCEPT
          Next
          Filter [HDT]
          If IHDTDON Then
            Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = [F:SRM]MACNUM and [F:HDT]HDTCPN = "" and [F:HDT]HDTDONDAT <> [00/00/00]
&                     Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
            For [HDT] Hint Key HDT1
              SZCTAOB = "HDT"
              SZCTAOBNUM = [F:HDT]HDTNUM
              SZCTLEVEL = "2"
              SZCTPARENTAOB = "SRM"
              SZCTPARENTNUM = [F:SRM]SRENUM + [F:SRM]MACNUM
              Gosub XMLHDT From CRMEXCEPT
            Next
            Filter [HDT]
          Endif
        Endif
        #Composants concernés
        If IDISPLAYSRN Then
          Filter [SRN] Where [F:SRN]SRENUM = SZRECNUM and [F:SRN]MACNUM = [F:SRM]MACNUM Order By [F:SRN]CPNITM Asc
          For [SRN]
            SZCTAOB = "SRN"
            SZCTAOBNUM = [F:HDT]HDTNUM
            SZCTLEVEL = "2"
            SZCTPARENTAOB = "SRM"
            SZCTPARENTNUM = [F:SRN]SRENUM + [F:SRN]MACNUM + [F:SRN]CPNITM
            Gosub XMLSRN From CRMEXCEPT
            #Consommations
            If IDISPLAYHDT Then
              Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = [F:SRM]MACNUM and [F:HDT]HDTCPN = [F:SRN]CPNITM and [F:HDT]HDTDONDAT = [00/00/00]
&                       Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
              For [HDT] Hint Key HDT1
                SZCTAOB = "HDT"
                SZCTAOBNUM = [F:HDT]HDTNUM
                SZCTLEVEL = "3"
                SZCTPARENTAOB = "SRN"
                SZCTPARENTNUM = [F:SRN]SRENUM + [F:SRN]MACNUM + [F:SRN]CPNITM
                Gosub XMLHDT From CRMEXCEPT
              Next
              Filter [HDT]
              If IHDTDON Then
                Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = [F:SRM]MACNUM and [F:HDT]HDTCPN = [F:SRN]CPNITM and [F:HDT]HDTDONDAT <> [00/00/00]
&                         Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
                For [HDT] Hint Key HDT1
                  SZCTAOB = "HDT"
                  SZCTAOBNUM = [F:HDT]HDTNUM
                  SZCTLEVEL = "3"
                  SZCTPARENTAOB = "SRN"
                  SZCTPARENTNUM = [F:SRN]SRENUM + [F:SRN]MACNUM + [F:SRN]CPNITM
                  Gosub XMLHDT From CRMEXCEPT
                Next
                Filter [HDT]
              Endif
            Endif
          Next
          Filter [SRN]
        Endif
      Next
      Filter [SRM]
    Endif
    #Consommations non associées à un parc
    If IDISPLAYHDT Then
      Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = "" and [F:HDT]HDTCPN = "" and [F:HDT]HDTDONDAT = [00/00/00]
&               Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
      For [HDT] Hint Key HDT1
        SZCTAOB = "HDT"
        SZCTAOBNUM = [F:HDT]HDTNUM
        SZCTLEVEL = "1"
        SZCTPARENTAOB = "SRE"
        SZCTPARENTNUM = [F:SRE]SRENUM
        Gosub XMLHDT From CRMEXCEPT
      Next
      Filter [HDT]
      If IHDTDON Then
        Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = "" and [F:HDT]HDTCPN = "" and [F:HDT]HDTDONDAT <> [00/00/00]
&                     Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
        For [HDT] Hint Key HDT1
          SZCTAOB = "HDT"
          SZCTAOBNUM = [F:HDT]HDTNUM
          SZCTLEVEL = "1"
          SZCTPARENTAOB = "SRE"
          SZCTPARENTNUM = [F:SRE]SRENUM
          Gosub XMLHDT From CRMEXCEPT
        Next
        Filter [HDT]
      Endif
    Endif
    #Tiers
    If IDISPLAYBPR Then
      Gosub ADDBPR
    Endif
    #Client
    If IDISPLAYBPC Then
      Gosub ADDBPC
    Endif
    #Adresse
    If IDISPLAYBPA Then
      Gosub ADDBPA
    Endif
  Next
  Filter [SRE]
Return

##########################################################
# Tiers
##########################################################
$ADDBPR
  Filter [BPR] Where [F:BPR]BPRNUM = [F:SRE]SREBPC
  For [BPR]
    SZCTAOB = "BPR"
    SZCTAOBNUM = [F:BPR]BPRNUM
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "SRE"
    SZCTPARENTNUM = [F:SRE]SRENUM
    Gosub XMLBPR From CRMEXCEPT
  Next
  Filter [BPR]
Return

##########################################################
# Client
##########################################################
$ADDBPC
  Filter [BPC] Where [F:BPC]BPCNUM = [F:SRE]SREBPC
  For [BPC]
    SZCTAOB = "BPC"
    SZCTAOBNUM = [F:BPC]BPCNUM
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "SRE"
    SZCTPARENTNUM = [F:SRE]SRENUM
    Gosub XMLBPC From CRMEXCEPT
  Next
  Filter [BPC]
Return

##########################################################
# Adresse
##########################################################
$ADDBPA
  If [F:SRE]SREBPAADD = "" Then
    Read [BPR]BPR0=[F:SRE]SREBPC
    If fstat Then
      Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:SRE]SREBPC
    Else
      Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:SRE]SREBPC and [F:BPA]BPAADD = [F:BPR]BPAADD
    Endif
  Else
    Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:SRE]SREBPC and [F:BPA]BPAADD = [F:SRE]SREBPAADD
  Endif
  For [BPA]
    SZCTAOB = "BPA"
    SZCTAOBNUM = num$([F:BPA]BPATYP) + [F:BPA]BPANUM + [F:BPA]BPAADD
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "SRE"
    SZCTPARENTNUM = [F:SRE]SRENUM
    Gosub XMLBPA From CRMEXCEPT
  Next
  Filter [BPA]
Return

##########################################################
# Parc client
##########################################################
$ADDMAC
  Filter [MAC] Where [F:MAC]MACNUM = [F:SRM]MACNUM
  For [MAC]
    SZCTAOB = "MAC"
    SZCTAOBNUM = [F:MAC]MACNUM
    SZCTLEVEL = "2"
    SZCTPARENTAOB = "SRM"
    SZCTPARENTNUM = [F:SRM]SRENUM + [F:SRM]MACNUM
    Gosub XMLMAC From CRMEXCEPT
  Next
  Filter [MAC]
Return
