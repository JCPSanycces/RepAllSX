####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : ADDLIN1 Address line 1 ( Field A 35)
####################################################################

$SET_ADDLIN1
If [L]_AOLDVAL<>this.ADDLIN1
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_ADDLIN1
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.ADDLIN1
 Gosub PROPAGATE_ADDLIN1
Endif
Return

$INIT_ADDLIN1
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI_UKADD
[L]CURPRO = "ADDLIN1"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_ADDLIN1
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI_UKADD
[L]CURPRO = "ADDLIN1"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_ADDLIN1               : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_ADDLIN1               : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_ADDLIN1
[L]CURPRO = "ADDLIN1"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.ADDLIN1,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_ADDLIN1
[L]CURPRO = "ADDLIN1"
Return

$_AOTHERS_ADDLIN1
[L]CURPRO = "ADDLIN1"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_ADDLIN1
[L]CURPRO = "ADDLIN1"
Return

$PROPAGATE_ADDLIN1
this.isReadonly = 0
[L]CURPRO = "ADDLIN1"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_ADDLIN1
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI_UKADD
[L]CURPRO = "ADDLIN1"
$_LNKPRO_ADDLIN1
Return


