[L]CURPRO = "TEL"
$_LNKPRO_TEL
Local Char AFORMAT(50)
[L]ASTATUS =  func ASYRTRTATY.GETFORMATTEL(this,"TEL",this.TEL,[L]AFORMAT,this.CRYCNT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]AFORMAT<>''
[L]AFORMAT='"'+[L]AFORMAT+'"'
[L]ASTATUS = fmet this.ASETATTRIBUTE("TEL","$x3Format",[L]AFORMAT)
Endif
Return


