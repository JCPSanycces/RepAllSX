If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.TYP=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_TYP
[L]CURPRO = "TYP"
If this.TYP<0 or this.TYP>len(mess(0,11807,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"11807 ->"-num$(this.TYP)-mess(99,123,1)):  Return : # Local menu "11807 -> Invalid option
Endif
Return

