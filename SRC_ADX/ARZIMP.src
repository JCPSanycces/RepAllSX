#<AdxTL>@(#)11.0.0.0 $Revision$
Raz GNBMASKOUV
Local Char PARAM(250)(1..4) , VALEUR(10)
Local Integer OK
PARAM(1) = "codposdeb=06000"
PARAM(2) = "codposfin=06000"
PARAM(3) = "version=8"
Call REPORT_ZPL("POSCOD",PARAM,3,GBIDC1) : If !OK : Call ERREUR(GMESSAGE) From GESECRAN : Endif
End

#-----------------------------------------------------------------#
Subprog REPORT_ZPL(ETAT,PARAMETRE,NBPAR,RETOUR)
Value Char       ETAT , PARAMETRE()(1..)
Value Integer    NBPAR
Variable Char    RETOUR

Local Integer  OK , I , J , K , L , SIMUL , VERSION , STAT , COP
Local Char     VALEUR(250) , SERVEUR(50) , IMPRIMANTE(250) , FICCLI(GDIMFIC)
Local Char     FICHIER(GDIMFIC) , SRVFIC(GDIMFIC) , REPERT(10) , NOMFIC(GDIMFIC) , EXT(10)
Local Char     ACTION(20) , STARET(250)(1..10) , ORDCLI(20) , JOBCLI(20)
Local Integer  ERN , TIMSTP , OKTRT , NBER , TYPPAT , ENVMSK
Local Char     ERM(250) , FORMULE(250) , CHAINE(250)
Local Char     NOMPRG(GLONADC) , CODPAR(GLONARZ)
Local Integer  DFR , FN , NBRETQ , OKSEL

If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif
If clalev([F:ARA])=0 : Local File AREPORTA [ARA] : Endif
If clalev([F:ARZ])=0 : Local File AREPORTZ [ARZ] : Endif
If clalev([F:ARG])=0 : Local File AREPORTG [ARG] : Endif

Call LECTURE("ARP",ETAT,"") From CONTOBJ
Gosub CHARGE_PAR

SIMUL      = val(func PARAM("simu"))      : # Simulation de l'impression
VERSION    = val(func PARAM("version"))   : # Forcer la version à imprimer
IMPRIMANTE = func PARAM("_PrinterName")   : # Imprimante (optionnel)
SERVEUR    = func PARAM("_PrinterServer") : # Serveur d'impression (optionnel)
FICCLI     = func PARAM("_ExportFile")    : # Nom du fichier final (optionnel)

NBRETQ     = val(func PARAM("_PrinterCopies"))

If SERVEUR<>"" & right$(SERVEUR,len(SERVEUR))<>"@"
 SERVEUR += "@"
Endif

# Nom du fichier généré sur le serveur d'appli
NOMFIC  = [L]ETAT+"_"+num$(adxuid(1))+"_"+timestamp$
EXT     = 'DATA'
REPERT  = 'PAT'
FICHIER = filpath(REPERT,NOMFIC,EXT)
If find(right$(FICCLI,len(FICCLI)),"\","/") : # C'est un répertoire
 FICCLI += NOMFIC+"."+EXT
Endif

OK = 1
ACTION = "REPORT_ZPL" : Gosub ACTINI From AIMP3
If !OK : Goto REPORT_END : Endif

Gosub CONT_REPORT
If !OK : Goto REPORT_END : Endif

Case [L]TYPPAT
 When 1 : Gosub GEN_REPORT_PAT : # Structuré (Parsing)
 When 2 : Gosub GEN_REPORT_MSK : # Masque
Endcase

If filinfo(FICHIER,0)<0
 ERM = "|"+FICHIER+"|\"+mess(101,100,1) : # Fichier inexistant
 Gosub AFF_ERR : OK = 0 : Goto REPORT_END
Endif

If FICCLI="" & IMPRIMANTE=""
 ERM = mess(35,143,1) : # Pour ce type de sortie, il faut au moins renseigner un fichier ou une imprimante
 Gosub AFF_ERR : OK = 0 : Goto REPORT_END
Endif

ERM = ""
If !SIMUL
 If GSERVEUR or instr(1,FICCLI,"@")
  COP = 1
  Call COPIE(FICHIER,FICCLI,STAT) From ORDSYS
  If STAT
   OK = 0
  Endif
 Else
  Gosub COPIE_CLIENT
 Endif
Endif

If COP & !OK
 ERM = "|"+FICHIER+"| ("+num$(COP)+")\"+mess(33,143,1)+"\"+ERM : # Erreur pendant la copie du fichier
 Gosub AFF_ERR
Endif

#------------------------------#
$REPORT_END
If dim(GNPAR_)>0
 Kill GAPAR_ , GNPAR_
Endif
End

#-----------------------------------------------------------------#
$CHARGE_PAR
Global Char    GAPAR_(type(PARAMETRE)-10)(1..dim(PARAMETRE))
Global Integer GNPAR_
For I=1 To NBPAR
 GAPAR_(I) = PARAMETRE(I)
Next I
GNPAR_ = NBPAR
Return

#------------------------------------------#
Funprog PARAM(CODPAR)
Value Char CODPAR
Local Char VALEUR(250)
If dim(GNPAR_)>0
 Call GETPARAM(CODPAR,GNPAR_,GAPAR_,VALEUR) From ETAT
 Gosub SET_VIDE From ETAT
 If VALEUR=VIDE
  VALEUR = ""
 Endif
Endif
End VALEUR

#------------------------------------------#
$COPIE_CLIENT

ORDCLI = "GetFileByCopy"
JOBCLI = "JobId"
SRVFIC = right$(FICHIER,len(filpath("","",""))+1)
If find(left$(SRVFIC,1),"\","/")
 SRVFIC = right$(SRVFIC,2)
Endif

If FICCLI<>""
 If SERVEUR=""
  COP = 2
  Callui STARET=""       With "UIAction="        +chr$(1)+ORDCLI,
&                             "UIRemoteFile="    +chr$(1)+SRVFIC,
&                             "UILocalDir="      +chr$(1)+"FullPath",
&                             "UILocalFile="     +chr$(1)+FICCLI
 Else
  COP = 3
  Callui STARET =SERVEUR With "SRVAction="       +chr$(1)+ORDCLI,
&                             "SRVRemoteSol="    +chr$(1)+GINSTID,
&                             "SRVRemoteFolder=" +chr$(1)+nomap,
&                             "SRVRemoteFile="   +chr$(1)+SRVFIC,
&                             "SRVLocalFile="    +chr$(1)+FICCLI
 Endif
Elsif IMPRIMANTE<>""
 If SERVEUR=""
  COP = 5
  Callui STARET=""       With "UIAction="        +chr$(1)+ORDCLI,
&                             "UIRemoteFile="    +chr$(1)+SRVFIC,
&                             "UILocalDir="      +chr$(1)+"FullPath",
&                             "UILocalFile="     +chr$(1)+IMPRIMANTE
 Else
  COP = 4
  Callui STARET =SERVEUR With "SRVAction="       +chr$(1)+ORDCLI,
&                             "SRVRemoteSol="    +chr$(1)+GINSTID,
&                             "SRVRemoteFolder=" +chr$(1)+nomap,
&                             "SRVRemoteFile="   +chr$(1)+SRVFIC,
&                             "SRVPrinterPath="  +chr$(1)+IMPRIMANTE
 Endif
Endif

# Tout s'est bien passé ?
OK = 1
For I=1 To dim(STARET)
 K = instr(1,STARET(I),ORDCLI)
 If K
  K = instr(1,STARET(I),"=")
  If K & right$(STARET(I),K+2)="1" : # Ca s'est bien passé
   OK = 1
  Endif
 Else
  K = instr(1,STARET(I),JOBCLI) : # No du job dans la file d'attente
  If K
   K = instr(1,STARET(I),"=")
   If K
    RETOUR = right$(STARET(I),K+2)
   Endif
  Else : # C'est forcémement une erreur
   K = instr(1,STARET(I),"=")
   If K
    ERM = STARET(I)
    OK = 0
   Endif
  Endif
 Endif
Next I
Return

#-------------------------------------#
$CONT_REPORT

[L]CODPAR = [F:ARP]CODZPL

Read [ARZ]ARZ0 = [L]CODPAR
If fstat
 ERM = mess(31,143,1) : # Paramétrage imprimante inexistant
 Gosub AFF_ERR : OK = 0 : Return
Elsif [F:ARZ]ENAFLG<>2
 ERM = mess(2,126,1) : # Fiche inactive
 Gosub AFF_ERR : OK = 0 : Return
Endif
[L]ENVMSK = [F:ARZ]ENVMSK

# Type de pattern
If [F:ARZ]PATNAM=""
 [L]TYPPAT = 0 : Return
Else
 Read [ARA]ARA0(1) = [F:ARZ]PATNAM
 If !fstat
  [L]TYPPAT = [F:ARA]TYPPAT
 Else
  [L]TYPPAT = 1
 Endif
Endif

# La dernière version du pattern stockée correspond-elle bien au pattern utilisé ?
Call VERIF_VERSION([F:ARZ]PATNAM,[L]TIMSTP,OK) From ARZVISU
If !OK
 If [L]TIMSTP>0
  Call ECLATEMENT([F:ARZ]PATNAM,[F:ARZ]CODPAR,[L]TYPPAT,[L]TIMSTP,ERM,OK) From ARZVISU
  If !OK : Gosub AFF_ERR : Return : Endif
 Else
  ERM = [F:ARZ]PATNAM-":"-mess(32,143,1) : # Fichier pattern inexistant
  Gosub AFF_ERR : OK = 0 : Return
 Endif
Endif

# On récupère le bon numéro de version à utiliser
# Si la version qui est passée en paramètre est à 0, on prend la version du paramétrage
If VERSION=0 : VERSION = [F:ARZ]VER : Endif
Read [ARA]ARA1=[F:ARZ]PATNAM;VERSION
If !fstat
 [L]TIMSTP = [F:ARA]TIMSTP
Else
 ERM = [F:ARZ]PATNAM-num$(VERSION)-":"-mess(28,143,1) : # Version inexistante
 Gosub AFF_ERR : OK = 0 : Return
Endif

Gosub SET_PREF From SUBARZ
NOMPRG = PREF+CODPAR
Call EXISTE_ADX("","",NOMPRG,OKTRT) From ORDSYS
If !OKTRT
 ERM = NOMPRG-":"-mess(90,123,1) : # Traitement inexistant
 Gosub AFF_ERR : OK = 0 : Return
Endif

Return

#-------------------------------------#
$GEN_REPORT_PAT

Onerrgo ER

# Ouverture du fichier data en ecriture
Openo FICHIER,0 Using [DATA]
Iomode adxifs "" Using [DATA]
Iomode adxirs chr$(13)+chr$(10) Using [DATA]
Iomode adxium GASCII Using [DATA]

# Ecriture de l'entête
For [ARA]ARA0 Where PATNAM=[F:ARZ]PATNAM & TIMSTP=[L]TIMSTP & TYP=1
 For I=0 To dim([F:ARA]LIG)-1
  If [F:ARA]LIG(I)="" : Break : Endif
  Wrseq [F:ARA]LIG(I) Using [DATA]
 Next I
Next ARA

# Ecriture des données
#109165
GPE=0 : GPOINT="FILE" : Gosub ENTREE From EXEFNC
If !GPE : Gosub OUVRE From =NOMPRG : Endif
NBER = 0

For [LNK]
 Gosub FILTRE From =NOMPRG
 If OKSEL
  For [ARA]ARA0 Where PATNAM=[F:ARZ]PATNAM & TIMSTP=[L]TIMSTP & TYP=2
   For I=0 To dim([F:ARA]LIG)-1
    If [F:ARA]LIG(I)="" : Break : Endif
    # Champ d'une table ?
    K = instr(1,[F:ARA]LIG(I),"X3F_")
    If K
     Wrseq seg$([F:ARA]LIG(I),1,K-2)+"D"+ evalue(seg$([F:ARA]LIG(I),K+4,instr(K,[F:ARA]LIG(I),"^F")-1))
&    + seg$([F:ARA]LIG(I),instr(K,[F:ARA]LIG(I),"^F"),len([F:ARA]LIG(I))) Using [DATA]
    Else
     # Expression ?
     K = instr(1,[F:ARA]LIG(I),"X3E_")
     If K
      For [F:ARG]ARG0 Where CODPAR=[F:ARZ]CODPAR & NUM=val(seg$([F:ARA]LIG(I),K+4,instr(K,[F:ARA]LIG(I),"^F")-1))
       If [F:ARG]CND=""
        OK = 1
       Else
        ERN = 0
        FORMULE = format$("KTv2:250X",[F:ARG]CND)
        OK = evalue([F:ARG]CND)
        FORMULE = ""
        If ERN : OK = 0 : Endif
       Endif
       If OK
        If [F:ARG]EXPLIG<>""
         ERN = 0
         FORMULE = format$("KTv2:250X",[F:ARG]EXPLIG)
         CHAINE = evalue([F:ARG]EXPLIG)
         FORMULE = ""
         If !ERN
          If seg$([F:ARA]LIG(I),K-3,K-1)="^PQ"
           Wrseq seg$([F:ARA]LIG(I),1,K-1)+CHAINE+seg$([F:ARA]LIG(I),instr(K,[F:ARA]LIG(I),"^F"),len([F:ARA]LIG(I))) Using [DATA]
          Else
           Wrseq seg$([F:ARA]LIG(I),1,K-2)+"D"+CHAINE+seg$([F:ARA]LIG(I),instr(K,[F:ARA]LIG(I),"^F"),len([F:ARA]LIG(I))) Using [DATA]
          Endif
         Endif
        Endif
        Break
       Endif
      Next ARG
     Else
      # Nombre d'étiquettes
      K = instr(1,[F:ARA]LIG(I),"^PQ")
      If K & NBRETQ<>0
       L = 0
       For J=K+3 To len([F:ARA]LIG(I))
        If mid$([F:ARA]LIG(I),J,1)>="0" & mid$([F:ARA]LIG(I),J,1)<="9"
         L += 1
        Else
         Break
        Endif
       Next J
       Wrseq left$([F:ARA]LIG(I),K+2)+num$(NBRETQ)+right$([F:ARA]LIG(I),K+3+L) Using [DATA]
      Else
       GPE = 0
       GPOINT = "NEWTYP" : Gosub ENTREE From EXEFNC : # Demande 74985 du 18.7.11
       If !GPE
        # Juste du code ZPL
        Wrseq [F:ARA]LIG(I) Using [DATA]
       Endif
      Endif
     Endif
    Endif
   Next I
  Next ARA
  If NBER : Break : Endif : # Pas la peine d'aller plus loin
 Endif
Next LNK

# Ecriture du pied
For [ARA]ARA0 Where PATNAM=[F:ARZ]PATNAM & TIMSTP=[L]TIMSTP & TYP=3
 For I=0 To dim([F:ARA]LIG)-1
  If [F:ARA]LIG(I)="" : Break : Endif
  Wrseq [F:ARA]LIG(I) Using [DATA]
 Next I
Next ARA

Openo Using [DATA]
Onerrgo

OK = (NBER=0)
Return

#-------------------------------------#
$GEN_REPORT_MSK

Onerrgo ER

# Ouverture du fichier data en ecriture
Openo FICHIER,0 Using [DATA]
Iomode adxifs "" Using [DATA]
Iomode adxirs chr$(13)+chr$(10) Using [DATA]
Iomode adxium GASCII Using [DATA]

# Recherche des balises ^DFR et ^FNx
Raz DFR , FN
For [ARA]ARA0 Where PATNAM=[F:ARZ]PATNAM & TIMSTP=[L]TIMSTP & TYP=1
 For I=0 To dim([F:ARA]LIG)-1
  If [F:ARA]LIG(I)="" : Break : Endif
  If instr(1,[F:ARA]LIG(I),"^DFR:")
   DFR = 1
  Endif
  K = instr(1,[F:ARA]LIG(I),"^FN")
  If K
   J = val(right$([F:ARA]LIG(I),K+3))
   FN = max(J,FN)
  Endif
 Next I
Next ARA

# Ecriture du masque
If ENVMSK=2
 If !DFR
  Wrseq "^XA" Using [DATA]
  Wrseq "^DFR:"+[F:ARZ]PATNAM+".GRF" Using [DATA]
 Endif
 For [ARA]ARA0 Where PATNAM=[F:ARZ]PATNAM & TIMSTP=[L]TIMSTP & TYP=1
  For I=0 To dim([F:ARA]LIG)-1
   If [F:ARA]LIG(I)="" : Break : Endif
   CHAINE = [F:ARA]LIG(I)
   J = instr(1,CHAINE,"^DFR:")
   If J
    CHAINE = "^DFR:"+[F:ARZ]PATNAM+".GRF"
   Endif
   Wrseq CHAINE Using [DATA]
  Next I
 Next ARA
 If !DFR
  Wrseq "^XZ" Using [DATA]
 Endif
Endif

# Ecriture des données
Gosub OUVRE From =NOMPRG
NBER = 0
For [LNK]
 Gosub FILTRE From =NOMPRG
 If OKSEL
  Wrseq "^XA" Using [DATA]
  Wrseq "^XFR:"+[F:ARZ]PATNAM+".GRF" Using [DATA]
  For I=1 To FN
   For [F:ARG]ARG0 Where CODPAR=[F:ARZ]CODPAR & NUM=I
    If [F:ARG]CND=""
     OK = 1
    Else
     ERN = 0
     FORMULE = format$("KTv2:250X",[F:ARG]CND)
     OK = evalue([F:ARG]CND)
     FORMULE = ""
     If ERN : OK = 0 : Endif
    Endif
    If OK
     If [F:ARG]EXPLIG<>""
      ERN = 0
      FORMULE = format$("KTv2:250X",[F:ARG]EXPLIG)
      CHAINE = evalue([F:ARG]EXPLIG)
      FORMULE = ""
      If !ERN
       Wrseq "^FN" + num$(I) + "^FD"+CHAINE+"^FS" Using [DATA]
      Endif
     Endif
     Break
    Endif
   Next ARG
  Next I
  If NBER : Break : Endif : # Pas la peine d'aller plus loin
  If NBRETQ<>0
   # Nombre d'étiquettes
   Wrseq "^PQ"+num$(NBRETQ) Using [DATA]
  Endif
  Wrseq "^XZ" Using [DATA]
 Endif
Next LNK

Openo Using [DATA]
Onerrgo
OK = (NBER=0)
Return

#------------------#
$ER
ERN = errn
ERM = "|"+errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(ERN)-errm+"|"
If FORMULE<>""
 ERM += mess(65,106,1)-FORMULE : # Erreur en évaluation de la formule
Endif
NBER += 1
Gosub AFF_ERR
Resume

#------------------#
$AFF_ERR
Call ECR_TRACE(ERM,1) From GESECRAN
Return

