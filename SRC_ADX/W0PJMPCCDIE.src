#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMPCCDIE 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone ACCCOD
mkstat = 0
zoncou = "ACCCOD"
indice = 0
WCHAR = [M]ACCCOD
If varmode([M]ACCCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACCCOD" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTCAC"
 Call CONTCAC([M]ACCCOD,"36") From SUBCAC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CAC","!",[M]ACCCOD,"36",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]ACCCOD or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_ACCCOD([M]ACCCOD) From SUBPJCC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRDIE
mkstat = 0
zoncou = "NBRDIE"
indice = 0
status = 1
zoncou = "NBRDIE"
If varmode([M]NBRDIE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRDIE" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRDIE
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRDIE = nolign
   status = 75
   Call SAI_NBRDIE(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRDIE(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRDIE
mkstat = 0
zoncou = "NBRDIE"

## Zone CHX
mkstat = 0
zoncou = "CHX"
IMPENT = [M]CHX(indice)
WNUM = IMPENT
If varinit([M]CHX,indice)=0
 IMPENT = 1
Endif
If varmode([M]CHX,indice)=0
 [M]CHX(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CHX" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CHX(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_CHX(IMPENT) From SUBPJCC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CHX" : GZNUM = 12414 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]CHX(indice) = IMPENT

## Zone CCE
mkstat = 0
zoncou = "CCE"
WCHAR = [M]CCE(indice)
SAVACT = GACTION : GACTION = "INICCEFMT"
Call INICCEFMT(num$([M:PJCD]DIE(nolign - 1))) From SETGLBDIE
GACTION = SAVACT
If mkstat=1 : Raz [M]CCE(indice) : Endif
If !mkstat
 If varmode([M]CCE,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CCE" : Gosub ACTION From =IMPTRT
  Endif
  Call CONTROLE("CCE","!",[M]CCE(indice),num$([M:PJCD]DIE(nolign - 1)),mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]CCE(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_CCE([M]CCE(indice)) From SUBPJCC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone NBRDIE
mkstat = 0
zoncou = "NBRDIE"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMPCCDIE"
Return

