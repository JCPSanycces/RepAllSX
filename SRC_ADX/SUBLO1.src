#<AdxTL>@(#)9.0.0.0 $Revision$
GSCHEMA = ""
Call OBJET("LOT",GBIDC2,GBIDC3) From GOBJET
End


$CONTJOU
Call LEC_FCY([M]FCY) From CPTLEC
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
Call LEC_JOU_LEG([F:CPY]LEG,[M]JOU) From CPTLEC
#--- Journal compatible avec le site/société.
Call VERIF([F:JOU]FCY,[M]FCY,[F:JOU]JOU) From CFYSUB
If mkstat : Return : Endif
#--- Code d'accès... Droit d'execution.
Call CONTEXE([F:JOU]ACS) From CPTSUB
If mkstat : GMESSAGE = [F:JOU]JOU-GMESSAGE : Return : Endif

#--- Compte interdit... (Même contrôle en CONTACC mais cdt sous GOMPTA<>3 ?)
If VALEUR<>[M]JOU
 Local Integer I, K, NOL,NBLED, IND
 Local Char BID,LED
 Case [M:HAEF]TYPENT
  When 1 : NBLED = [M:HAEF]NBRLED    # Saisie en colonne
  When 2 : NBLED = 1                 # Saisie en ligne
 Endcase
 For NOL=0 To [M]NBLIG-1
  For J=1 To [L]NBLED
   BID=evalue("[M]ACC"+num$(J)+"("+num$(NOL)+")")
   If BID<>""
    If [M:HAEF]TYPENT=1 : LED=[M:HAEF]LED(J-1) : Else LED=[M]LED(I) : Endif
    Call INDLED([L]LED,"",IND,K) From CPTDIV
    Call LEC_JCO_LEG([F:CPY]LEG,GLEDCOA(IND),[F:JOU]JOU) From CPTLEC
    If !find(BID,[F:JCO]ACC,[F:JCO]FRQACC(0..[F:JCO]FRQNBR-1))
     For I=0 To dim([F:JCO]FBDACC)-1
      If pat(BID,[F:JCO]FBDACC(I))
       # Ligne no NOL - ACC Compte interdit sur le journal JOU
       GMESSAGE = mess(47,106,1)-num$(NOL+1)-"\"+BID-mess(14,106,1)-[M]JOU-"("+GLEDCOA(IND)+")"
       mkstat = 2 : Break 3
      Endif
     Next I
    Endif
   Endif
  Next J
 Next NOL
Endif
Return


$CONTTYP
Call CONTEXE([F:GTE]ACS) From CPTSUB
If mkstat : Return : Endif
If [F:GDE]FLGLOT<>2
 GMESSAGE  = mess(43,106,1) : # Type de pièce non autorisée
 mkstat = 2 : Return
Endif
#--- Journal compatible avec les journaux liés au type de pièce
Call LEC_JOU_LEG(GCURLEG,[M]JOU) From CPTLEC
If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
 GMESSAGE = [F:JOU]JOU-mess(8,106,1)
 # Journal non autorisé sur ce type de pièce
 mkstat = 2 : Return
Endif
If [F:GTE]VCRREA<>2 & [F:GTE]VCRSIM<>2 : # Dans les lots, pas de pièces hors-bilan ni modèle
 GMESSAGE = [F:GTE]TYP-mess(43,106,1) : # Type de pièce non autorisée
 mkstat = 2 : Return
Endif
#--- Référentiel "Obligatoire" selon le type de pièce
For I=0 To len(mess(0,2644,1))-1
 If [F:GTE]AUZLED(I)=3 & ([F:GCM]LED(I)="" | !find(I+1,[F:GDE]LEDTYP(0..[F:GDE]NBRLED-1))) : mkstat = 2 : Break : Endif
Next
If mkstat
 STAT=43 : Gosub MESSAGE From CPTAUTO : GMESSAGE=MESSA : Return
Endif
Return

$CONTLIG
Local Char TBCCE(GLONCCE)(1..9)
Local Integer PRC

If [M]NBLIG=0
 GMESSAGE = mess(17,106,1) : # Il y a aucune ligne saisie
 mkstat = 2 : Return
Endif
For nolign=1 To [M]NBLIG
 TYD=[M:HAEF]NBRLED
 Gosub AVT_SAIACC From SUBGA0        # Initialise NOL

 Gosub SETFCY
 If [M]NEW(NOL)=2
  Gosub CONTPCE
  If mkstat : Break : Endif
 Endif
 For NBLED=1 To [M:HAEF]NBRLED
  WCOA = [M:HAEF]COA(NBLED-1)
  WACC = evalue("[M]ACC"+num$(NBLED)+"(NOL)")
  WSAC = evalue("[M]SAC"+num$(NBLED)+"(NOL)")
  If WACC<>""
   Call CONTACC(WACC,[M:HAEF]LEDTYP(NBLED-1),[M:HAEF]LED(NBLED-1),FCYREF,[M]CUR(NOL),[M]ACCDAT(NOL)) From SUBGA1
   If mkstat : Break 2 : Endif
  Endif
  Case [M]DSP(NOL)
   When "$"
    For I=[M]PTV(NOL) To [M]PTF(NOL)
     K=find([M:HAEF]LED(NBLED-1),GLED(1..GLEDNBR))
     For J=1 To GLEDDIENBR(K)
      PRC = find(evalue("GDIE"+num$(J)+"("+num$(K)+")"),[M:VT2]TBDIE(1..dim([M:VT2]TBDIE)-1))
      If PRC
       BID1 = evalue("[M:VT2]TBDIE("+num$(PRC)+")")
       BID2 = evalue("[M:VT2]TBCCE"+num$(PRC+1)+"("+num$(I)+")")
       Call CONTCCE(BID2,[M:HAEF]LED(J-1),BID1,FCYREF,[M]ACCDAT(NOL),WACC,[M:VT2]TBDIE,"[M:VT2]TBCCE#",I) From CPTCNT
       If mkstat : Break 4 : Endif
      Endif
     Next J
    Next I
   When ""
    I=find([M:HAEF]LED(NBLED-1),GLED(1..GLEDNBR))
    Raz TBCCE
    For J=1 To GLEDDIENBR(I)
     TBCCE(J)=evalue("GDIE"+num$(J)+"("+num$(I)+")")
    Next
    For J=1 To GLEDDIENBR(I)
     BID1 = TBCCE(J)
     K = find(TBCCE(J),[M:HAEF]DIE(0..20))
     BID2 = evalue("[M]CCE"+num$(K)+"("+num$(NOL)+")")
     Call CONTCCE(BID2,[M:HAEF]LED(NBLED-1),BID1,FCYREF,[M]ACCDAT(NOL),WACC,[M]DIE,"[M]CCE#",NOL) From CPTCNT
     If mkstat : Break 3 : Endif
    Next
   When Default
    Call CONTDSP([M]DSP(NOL),FCYREF,[M]ACCDAT(NOL))  From SUBGA1
    If mkstat : Break 2 : Endif
  Endcase
 Next
Next NOL
If mkstat
 GMESSAGE = mess(47,106,1)-num$(NOL+1)-":\"+GMESSAGE : # Ligne no
Endif
Return

$CONTPCE
#-- Ligne de création de pièce.
Call LEC_GTE_LEG(GCURLEG,[M]TYP(NOL)) From CPTLEC
Call CONTDAT([M]ACCDAT(NOL),[M]ACCDAT(NOL)) From SUBLO1
If mkstat : End : Endif

#--- Etat du journal compatible avec la société
Read [JST]JST0 = [M]CPY;[F:JOU]JOU
If fstat | [F:JST]OPGSTRDAT>[M]ACCDAT | ([F:JST]OPGENDDAT<>[0/0/0] and [F:JST]OPGENDDAT<[M]ACCDAT)
 GMESSAGE = [F:JOU]JOU-mess(92,104,1)-"("+format$("D:"+GFMDAT,[M]ACCDAT)+")"
 mkstat = 2 : Return :  # Journal non ouvert
Endif

Gosub CONTTYP : If mkstat : Return : Endif
Return

$SETFCY
Local Char FCYREF(GLONFCY)
If dim([M]FCYLIN)>0 & [M]FCYLIN(NOL)<>"" & [M]FCYLIN(NOL)<>[M]FCY
 FCYREF = [M]FCYLIN(NOL)
Else
 FCYREF = [M]FCY
Endif
Return

Subprog CONTDAT(VALEUR,DAT)
Variable Date VALEUR
Variable Date DAT

Local Char BID,BID1,BID2
Local Decimal OFIY

# Vérifie qu'un au moins des référentiels saisissable possède un exercice/période ouvert.
mkstat=0
For I=0 To [M:HAEF]NBRLED-1
 Call CONTPER(VALEUR,[M:HAEF]LEDTYP(I),[M]FCY) From CPTSUB
 If !mkstat : Break : Endif
Next
If mkstat
 GMESSAGE = mess(1,104,1)-"\"-GMESSAGE : # Date incorrecte
 mkstat = 2 : End
Endif

If GCOMPTA<>3  :# Compta
 Call CTLVLYDAT(VALEUR,[F:GDE]VLYSTR,[F:GDE]VLYEND) From CPTSUB
 If mkstat : GMESSAGE = [F:GDE]DIA-GMESSAGE : End : Endif
Endif
If dim([F:GTE]VLYSTR)>0
 Call CTLVLYDAT(VALEUR,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
 If mkstat : GMESSAGE = [F:GTE]TYP-GMESSAGE : End : Endif
Endif

If VALEUR<>DAT
 Gosub SETNOL
 For J=1 To [M:HAEF]NBRLED
   Call GETEXE([M]CPY,[M:HAEF]LEDTYP(J-1),VALEUR,OFIY) From CPTSUB
   If GREP<>"D" & dim([M]NEW(NOL+1))>0 & [M]NEW(NOL+1)=1 & [M:HAEF]FIY([M:HAEF]LEDTYP(J-1)-1)<>OFIY
    GMESSAGE = mess(5,106,1) : # Changement d'exercice interdit
    mkstat = 2 : Break
   Endif
   # Collectif / Compte
   BID1= evalue("[M]SAC"+num$(J)+"("+num$(NOL)+")")
   If BID1<>""
    BID2 = [M:HAEF]COA(J-1)
    Read [F:GAC]GAC1=BID2;BID1
    Call CTLVLYDAT(VALEUR,[F:GAC]VLYSTR,[F:GAC]VLYEND) From CPTSUB
    If mkstat : GMESSAGE=mess(3,603,1)-BID-GMESSAGE : Break 2: Endif : # Collectif
   Else
    BID1= evalue("[M]ACC"+num$(J)+"("+num$(NOL)+")")
    If BID1<>""
     BID2 = [M:HAEF]COA(J-1)
     Call LECTURE("GAC",BID1,BID2) From CONTOBJ
     Call CTLVLYDAT(VALEUR,[F:GAC]VLYSTR,[F:GAC]VLYEND) From CPTSUB
     If mkstat : GMESSAGE=mess(2,113,1)-BID-GMESSAGE : Break 2 : Endif : # Compte
    Endif
   Endif
   # Répartition
   Case [M]DSP(NOL)
    When ""
    When "$"
     For K=[M]PTV(NOL) To [M]PTF(NOL)
      For AXI=1 To 20
       BID = evalue("[M:VT2]TBCCE"+num$(AXI)+"("+num$(K)+")")
       If BID<>""
        Call LECTURE("CCE",BID,[M:HAEF]DIE(AXI-1)) From CONTOBJ
        Call CTLVLYDAT(VALEUR,[F:CCE]VLYSTR,[F:CCE]VLYEND) From CPTSUB
        If mkstat : GMESSAGE=mess(48,105,1)-BID-GMESSAGE : Break 2 : Endif : # Section
       Endif
      Next
     Next
    When Default
     Call LECTURE("DSP",[M]DSP(NOL),"1") From CONTOBJ
     Call CTLVLYDAT(VALEUR,[F:DSP]VLYSTR,[F:DSP]VLYEND) From CPTSUB
     If mkstat : GMESSAGE=mess(23,106,1)-[M]DSP(NOL)-GMESSAGE : Endif : # Répartition ana
   Endcase
   If mkstat : Break 2 : Endif
   # Sections
   For AXI=1 To 20
    BID=evalue("[M]CCE"+num$(AXI)+"("+num$(NOL)+")")
    If BID<>""
     Call LECTURE("CCE",BID,[M:HAEF]DIE(AXI-1)) From CONTOBJ
     Call CTLVLYDAT(VALEUR,[F:CCE]VLYSTR,[F:CCE]VLYEND) From CPTSUB
     If mkstat : GMESSAGE=mess(48,105,1)-BID-GMESSAGE : Break 2 : Endif : # Section
    Endif
   Next AXI
 Next J
 If mkstat : End : Endif
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

$SETQTY
Local Integer OK, I, STAT
Local Char WCOA(GLONCOA),WACC(GLONGAC)

Call DD_QTY(OK) From SUBLO0
If !OK : Return : Endif

Gosub SETNOL
Call LEC_GTE_LEG(GCURLEG,[M]TYP(NOL)) From CPTLEC
For I=1 To [M:HAEF]NBRLED
 WACC = evalue("[M:HAE1]ACC"+num$(I)+"(NOL)")
 If WACC<>""
  WCOA = [M:HAEF]COA(I-1)
  Call LEC_GAC(WACC,WCOA) From CPTLEC
  If [F:GAC]FLGUOM=2 & [F:GAC]VALUOM<>0
   Call CONVERT([M]CUR,GCURSHR,GCURSHR,[F:GTE]TYPRAT,[M]RATDAT(NOL)
&              ,[M]DEB(NOL)+[M]CDT(NOL),VALEUR,STAT) From TRTDEV
   VALEUR = VALEUR/[F:GAC]VALUOM
   Call AROQTE(VALEUR,[F:GAC]UOM) From CPTINI
  Endif
 Endif
Next
Return

$EQUIPCE
Local Integer I
Local Decimal SOLDE
If [M]NEW(NOL)<>2
 For I=NOL-1 To 0 Step -1
  [L]SOLDE += [M]DEB(I)-[M]CDT(I)
  If [M]NEW(I)=2 : Break : Endif
 Next I
Endif
If [M]NEW(NOL)
 For I=NOL+1 To [M]NBLIG-1
  If [M]NEW(I)=2 : Break : Endif
  [L]SOLDE += [M]DEB(I)-[M]CDT(I)
 Next I
Endif
Return

$SETSOL
Local Decimal SOLDE, COURS
Local Char    DEVAFF(GLONCUR),WSAC(GLONSAC),WACC(GLONGAC)
Local Integer STAT

Gosub SETNOL
Call LEC_GTE_LEG(GCURLEG,[M]TYP(NOL)) From CPTLEC
DEVAFF = [M]CUR(NOL)
Gosub SETFCY
For I=1 To 10
 WACC = evalue("[M:HAE1]ACC"+num$(I)+"("+num$(NOL)+")")
 WSAC = evalue("[M:HAE1]SAC"+num$(I)+"("+num$(NOL)+")")
 If evalue("[M]RATDIV"+num$(GTYPGEN)+"("+num$(NOL-1)+")")>0
  COURS =  evalue("[M]RATMLT"+num$(GTYPGEN)+"("+num$(NOL)+")")/evalue("[M]RATDIV"+num$(GTYPGEN)+"("+num$(NOL-1)+")")
 Endif
 If WSAC<>""
  Call SOLDAT("",WSAC,WACC,[M]BPR(NOL),[M:HAEF]LEDTYP(I-1),[M]CPY,[M]FCYLIN(NOL)
&          ,DEVAFF,COURS,[M]ACCDAT(NOL),SOLDE) From CNSCPTSTD
  Break
 Elsif WACC<>""
  Call SOLDAT("","",WACC,[M]BPR(nolign-1),[M:HAEF]LEDTYP(I-1),[M]CPY,[M]FCYLIN(NOL)
&          ,DEVAFF,COURS,[M]ACCDAT(NOL),SOLDE) From CNSCPTSTD
   Break
 Endif
Next
Return

$MODZON
Local Integer I, AFF
Local Char    ZON(20)
Gosub SETNOL
If [M]NEW(NOL)=2
 For I=NOL+1 To [M]NBLIG-1
  If [M]NEW(I)=2 : Break : Endif
  For ZON="TYP","ACCDAT","NUM","FIY","PER","CUR","RATDAT","REF"
&        ,"BPRVCR","BPRDATVCR","ENTDAT","DUDDAT","VALDAT","FLGDAS"
&        ,"FLGFUP","FLGPAZ","RVSDAT","BANCIB"
   If evalue("dim([M]"+ZON+")>0")
&   & evalue("[M]"+ZON+"("+num$(I)+")<>[M]"+ZON+"("+num$(NOL)+")")
    Assign "[M]"+ZON+"("+num$(I)+")" With
&   evalue("[M]"+ZON+"("+num$(NOL)+")")
    AFF = 1
   Endif
  Next ZON
 Next I
Endif
If AFF : Affzo : Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (Objet LO1) 20/06/2008 10:59:52 (GLE)
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return


