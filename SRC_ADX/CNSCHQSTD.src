#<AdxTL>@(#)1.0.0.0 $Revision$ Inquiry CHQ
Raz GTUNCPT 
Local Char PARAM(10)(1..12) : Raz PARAM
#PARAM(1) = "2204"
#PARAM(2) = "GAL"
#GFINRSP  = "HN"
Call GCONSULT("CHQ","",PARAM) From GCONSULT
End

Subprog PATCH(APPLI)
Value Char APPLI
If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(1)<>2 End Endif
Call VALGTC(APPLI,"CHQ") From SUBGTC
End


$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "SETBOUT"    : Gosub SETBOUT ###
Endcase
Return

############################################
$AUTORIS
Return


############################################
$OUVRE

# Filters
Local Char FILTCHQ(250)(4)
Local Char CHQDEBNUM(GLONVCR), CHQNUMFIN(GLONVCR),DEBNUM(GLONVCR),FINNUM(GLONVCR),FILTPAG(250)
Local Char BPRDEB(GLONBPR), BPRFIN(GLONBPR)
NAVIG="CONSCHQ"

If clalev ([F:CHN])=0 : Local File CHQNUM     [CHN] : Endif
If clalev ([F:PYH])=0 : Local File PAYMENTH   [PYH] : Endif
If clalev ([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev ([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif

#Raz [M:CHQ1]

Gosub DEFCRIT

Return


############################################
#Affectation des zones par les paramètres
$DEFCRIT
#Default Mask [CHQ1]

For I=1 To dim(PARAM)
 Case I
  When 1 :
   If PARAM(I)<>""
    [M:CHQ1]BAN = PARAM(I)
   Endif
  When 2 :
   If PARAM(I)<>""
    [M:CHQ1]CHQNUMDEB = PARAM(I)
   Endif
  When 3 :
   If PARAM(I)<>""
    [M:CHQ1]CHQNUMFIN = PARAM(I)
   Endif
  When 4 : # Type = Normal
   If PARAM(I)<>""
    [M:CHQ1]CHQTYPNOR = val(PARAM(I))
   Endif
  When 5 : # Type = Normal
   If PARAM(I)<>""
    [M:CHQ1]CHQTYPMAN = val(PARAM(I))
   Endif
  When 6 : # Status =  Issued
   If PARAM(I)<>""
    [M:CHQ1]STAISSUED = val(PARAM(I))
   Endif
  When 7 : # Status = Unissued
   If PARAM(I)<>""
    [M:CHQ1]STAISSUED = val(PARAM(I))
   Endif
  When 8 : # Status =  Voided
   If PARAM(I)<>""
    [M:CHQ1]STAISSUED = val(PARAM(I))
   Endif
  When 9 : # Status = Cleared
   If PARAM(I)<>""
    [M:CHQ1]STAISSUED = val(PARAM(I))
   Endif
  When 10 :
   If PARAM(I)<>""
    [M:CHQ1]BPRDEB = PARAM(I)
   Endif
  When 11 : 
   If PARAM(I)<>""
    [M:CHQ1]BPRFIN = PARAM(I)
   Endif
  When 12 : # Payment Date
   If PARAM(I)<>""    
    If instr(1,PARAM(I),"/")
     [M:CHQ1]PRNDAT = "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CHQ1]PRNDAT = PARAM(I)
    Endif
   Endif
  When 13 : Break
  Endcase
Next I

Default Mask [CHQ1]

If vireblc([M:CHQ1]BAN,2) = ""  : [M]BAN = GBANDEF      : Endif

If !find([M:CHQ1]STAISSUED,1,2) : [M:CHQ1]STAISSUED = 2 : Endif
If !find([M:CHQ1]STAUNISS ,1,2) : [M:CHQ1]STAUNISS  = 1 : Endif
If !find([M:CHQ1]STAVOID  ,1,2) : [M:CHQ1]STAVOID   = 1 : Endif
If !find([M:CHQ1]STACLEAR ,1,2) : [M:CHQ1]STACLEAR  = 1 : Endif

If !find([M:CHQ1]CHQTYPNOR,1,2) : [M:CHQ1]CHQTYPNOR = 2 : Endif
If !find([M:CHQ1]CHQTYPMAN,1,2) : [M:CHQ1]CHQTYPMAN = 2 : Endif

#Valeurs par défaut critère
If [M:CCHQ]MEMO=""
  [M:CCHQ]TRI=1
Endif

Gosub CRITENT From =PROGCNS
Return


############################################
#Chargement du tableau
$LECTURE

If [M:CHQ1]BAN="" :  NBLU=0 : Endif

Gosub CHANGE_MSK From GCONSULT 
If CHGPAG<0 : NOL = MAXLIG : Endif

If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif

# Filtres
Gosub FILTRE
If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [CHN] With [PYH]PYH0=[F:CHN]PAYNUM,
&                [BPR]BPR0=[F:PYH]BPR As [LNK] 

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres

# Parcours de page en page
If CHGPAG>0 # Next Page
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else         # Previous Page
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif

If CHGPAG<>2 & CHGPAG<>-2 : Effzo [M:CHQ2]5 : Endif

If  CHGPAG > 0
    Filter [LNK] Where evalue(FILTCHQ(0)) & evalue(FILTCHQ(1)) & evalue(FILTCHQ(2)) & evalue(FILTCHQ(3)) & evalue(FILTPAG)
&   Order By [CHN]CHQNUM Desc
#&   Order By Key CLE=format$('N0:15X',[CHN]CHQNUM) Desc
Else
    Filter [LNK] Where evalue(FILTCHQ(0)) & evalue(FILTCHQ(1)) & evalue(FILTCHQ(2)) & evalue(FILTCHQ(3)) & evalue(FILTPAG)
&   Order By [CHN]CHQNUM Asc
Endif


############################################
$BOUCLE

For [LNK] 
  Gosub CHARGE_CHQ
  If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2 
      Break
  Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2 
      Break 
  Endif
Next

Return

############################################
$CHARGE_CHQ
 If NBLU=1
  If CHGPAG=2 or CHGPAG=-2 : Effzo [M:CHQ2]5 : Endif
  NBLU=2
 Endif
 If CHGPAG>0
  If NOL>=MAXLIG-1 : SUITE=2 : Return : Endif
  NOL += 1
  If NOL = 0  
   DEBNUM = [F:CHN]CHQNUM
  Endif
  FINNUM = [F:CHN]CHQNUM
 Else
  If NOL<=0 : RETOUR=2 : Return : Endif
  NOL-=1
  If NOL = MAXLIG-1 
     If CHGPAG=-1
        If [F:CHN]CHQNUM=DEBNUM : NOL+=1 : Return : Endif
     Endif
     FINNUM = [F:CHN]CHQNUM
  Endif
  DEBNUM = [F:CHN]CHQNUM
 Endif
 nolign=NOL+1

 [M:CHQ2]=[F:PYH]
 [M:CHQ2]=[F:CHN]
 [M:CHQ2]BPRPAY(nolign-1)=[F:BPR]BPRNUM
 [M:CHQ2]BPRNAM(nolign-1)=[F:BPR]BPRNAM

 If [M:CHQ2]STA(nolign-1)<>3 & [M:CHQ2]STA(nolign-1)<>5
  [M:CHQ2]CLODAT(nolign-1)=[00/00/00]
 Endif

 [M:CHQ2]PAYSTA(nolign-1) = [F:PYH]STA

 If [M:CHQ2]STA(nolign-1)=1 | [M:CHQ2]STA(nolign-1)=3
  [M:CHQ2]CHQTYP(nolign-1)=0
  [M:CHQ2]PAYSTA(nolign-1)=0   
 Endif

Return

############################################
#Création de critère de selection 
$FILTRE
Raz FILTCHQ

FILTCHQ(0)= "1=1"

If [M:CHQ1]BAN<>""
 FILTCHQ(0)+= " & [F:CHN]BAN='"+[M:CHQ1]BAN+"'"
Endif

If [M:CHQ1]BPRDEB<>""
 FILTCHQ(0)+= " & [F:PYH]BPR>='"+[M:CHQ1]BPRDEB+"'"
Endif

If [M:CHQ1]BPRFIN<>""
 FILTCHQ(0)+= " & [F:PYH]BPR<='"+[M:CHQ1]BPRFIN+"'"
Endif

FILTCHQ(1) = "(1=1" 
If [M:CHQ1]CHQNUMDEB<>""
 FILTCHQ(1) += " & ((!instr(1,'0123456789',left$([F:CHN]CHQNUM,1)) & '"+[M:CHQ1]CHQNUMDEB+"'<=[F:CHN]CHQNUM)"
 FILTCHQ(1) += " | (instr(1,'0123456789',left$([F:CHN]CHQNUM,1)) & val('"+[M:CHQ1]CHQNUMDEB+"')<=val([F:CHN]CHQNUM)))"
Endif
FILTCHQ(1) += ")"

FILTCHQ(2) = "(1=1" 
If [M:CHQ1]CHQNUMFIN<>""
 FILTCHQ(2) += " & ((!instr(1,'0123456789',left$([F:CHN]CHQNUM,1)) & [F:CHN]CHQNUM<='"+[M:CHQ1]CHQNUMFIN+"')"
 FILTCHQ(2) += " | (instr(1,'0123456789',left$([F:CHN]CHQNUM,1)) & val([F:CHN]CHQNUM)<=val('"+[M:CHQ1]CHQNUMFIN+"')))" 
Endif
FILTCHQ(2) += ")"

# Cheque Status
FILTCHQ(3) = "(1=1" 
If [M:CHQ1]STAISSUED=1 
 FILTCHQ(3) += " & [F:CHN]STA<>2"
Endif

If [M:CHQ1]STAUNISS=1 
 FILTCHQ(3) += " & [F:CHN]STA<>1"
Endif

If [M:CHQ1]STAVOID=1 
 FILTCHQ(3) += " & [F:CHN]STA<>3"
Endif

If [M:CHQ1]STACLEAR=1 
 FILTCHQ(3) += " & [F:CHN]STA<>5"
Endif

If [M:CHQ1]PRNDAT<>[00/00/00]
 FILTCHQ(3) += " & [F:CHN]PRNDAT=[M:CHQ1]PRNDAT"
Endif

If [M:CHQ1]CHQTYPNOR=1
 FILTCHQ(3) += " & [F:CHN]CHQTYP<>2"
Endif

If [M:CHQ1]CHQTYPMAN=1
 FILTCHQ(3) += " & [F:CHN]CHQTYP<>1"
Endif
FILTCHQ(3) += ")"
FILTPAG = "1=1 "
# order descending
Case CHGPAG
  When 3 : # refresh 
           FILTPAG += "& [F:CHN]CHQNUM<=DEBNUM"
  When 2 : # Next
           FILTPAG += "& [F:CHN]CHQNUM<FINNUM" 
  When -2 : # Previous
           FILTPAG += "& [F:CHN]CHQNUM>DEBNUM"
Endcase
Return


############################################
#Tunnel sur les réglements
$SETBOUT
CHMEN += "1"
Return

############################################
$DEB_CRIT
Local Integer NBCOL
Affzo [M:CCHN]
Affzo [M:CCHQ]
Return

######################################################################################
Subprog AP_BPRDEB(VALEUR)
Variable Char    VALEUR()

If  VALEUR<>""
  If [M:CHQ1]BPRFIN=""
    [M:CHQ1]BPRFIN = VALEUR
  Endif
  If [M:CCHQ]BPRFIN=""
    [M:CCHQ]BPRFIN = VALEUR
  Endif
  [M:CHQ1]BPRDEB = VALEUR
Endif
Affzo [M:CHQ1]BPRFIN
Affzo [M:CCHQ]BPRFIN
Affzo [M:CHQ1]BPRDEB

End

######################################################################################
Subprog AS_STA(VALEUR)
Variable Integer VALEUR
GMENLOC(4)=1                            # Disable Post Option
End

######################################################################################
Subprog AM_ECRAN(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
Subprog AP_CHQNUMDEB(VALEUR)
Variable Char    VALEUR()
If  VALEUR<>""
 If [M:CHQ1]CHQNUMFIN=""
  [M:CHQ1]CHQNUMFIN = VALEUR
 Endif
 If [M:CCHQ]CHQNUMFIN=""
  [M:CCHQ]CHQNUMFIN = VALEUR
 Endif
 If [M:CCHQ]CHQNUMDEB=""
  [M:CCHQ]CHQNUMDEB = VALEUR
 Endif
 [M:CHQ1]CHQNUMDEB = VALEUR
Endif
Affzo [M:CHQ1]CHQNUMFIN
Affzo [M:CCHQ]CHQNUMFIN
Affzo [M:CHQ1]CHQNUMDEB
Affzo [M:CCHQ]CHQNUMDEB

End

######################################################################################
Subprog C_BAN(VALEUR)
Variable Char    VALEUR()
Local Char COALED(GLONCOA), CURLED(GLONCUR)

If [M:CHQ1]CPY<>"" & VALEUR=[M:CHQ1]BAN : End : Endif  
If VALEUR<>""
 Read[F:BAN]BAN0=VALEUR
 If !fstat
  Call SETMAINREF([F:BAN]CPY,GTYPGEN,GTYPANA) From CPTDIV
  Call LECLED([F:BAN]CPY,GTYPLED,[L]COALED,[L]CURLED) From CPTDIV
  [M:CHQ1]CPY=[F:BAN]CPY 
  [M:CCHQ]CPY=[F:BAN]CPY 
  Affzo [M:CHQ1] 
  Affzo [M:CCHQ]
 Endif
Endif

End

######################################################################################
Subprog AS_BPRDEB(VALEUR)
Variable Char    VALEUR()
If [M:CHQ1]CPY="" : Call C_BAN ([M:CHQ1]BAN) : Endif
End

######################################################################################
Subprog AP_BAN(VALEUR)
Variable Char    VALEUR()
 Call C_BAN(VALEUR)
 [M:CHQ1]BAN=VALEUR
 Affzo [M:CHQ1]BAN 
End

######################################################################################
Subprog AP_BPRFIN(VALEUR)
Variable Char    VALEUR()

If [M]BPRDEB <> "" & VALEUR <> ""
 If VALEUR < [M]BPRDEB   
  GMESSAGE = mess(757,196,1) : mkstat=2 : End
 Endif
Endif

If VALEUR<>""
 [M:CHQ1]BPRFIN = VALEUR
 [M:CCHQ]BPRFIN = VALEUR    
Endif
Affzo [M:CHQ1]BPRFIN
Affzo [M:CCHQ]BPRFIN
End
######################################################################################
Subprog AP_CHQNUMFIN(VALEUR)
Variable Char    VALEUR()
If [M]CHQNUMDEB <> "" & VALEUR <> ""
 If instr(1,"0123456789",left$(VALEUR,1)) # 1st char numeric, check values
   If val(VALEUR) < val([M]CHQNUMDEB)
    GMESSAGE = mess(757,196,1) : mkstat=2 : End
   Endif
 Else   
   If VALEUR < [M]CHQNUMDEB   # alpha check
    GMESSAGE = mess(757,196,1) : mkstat=2 : End
   Endif
 Endif
Endif

If  VALEUR<>""
  [M:CHQ1]CHQNUMFIN = VALEUR
  [M:CCHQ]CHQNUMFIN = VALEUR    
Endif
Affzo [M:CHQ1]CHQNUMFIN
Affzo [M:CCHQ]CHQNUMFIN

End


######################################################################################
Subprog AS_NBLIG

End

######################################################################################
Subprog IB_NBLIG
Local Integer NOL : NOL=nolign-1
Raz GBOUT1
If [M]PAYNUM(NOL)<>""
 GBOUT1 = mess(10,97,1)  #"Payments"
Endif 
End


