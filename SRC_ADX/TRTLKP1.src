#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Traitement de sélection d'une opération marketing                     Module CRM        29 avril 2004
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev([F:CMG]) : Local File CMARKETING [CMG] : Endif
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
  If !clalev([F:OMT]) : Local File TRADESHOW [OMT] : Endif
  If !clalev([F:OMN]) : Local File MEDIA [OMN] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If [M:LKP1]CXT = "CLL" Then
    If [M:CLL2]CLLCMGFLG > 0 Then
      ETABOU(GVALI) = 0
    Endif
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:LKP1]CRIFCY = ""
  [M:LKP1]CRIDATSTR = [00/00/00]
  [M:LKP1]CRIDATEND = [00/00/00]
  [M:LKP1]CRIDES = ""
  [M:LKP1]CRICLO = 2
  Gosub DEBUTSUITE
Return

##########################################################################################################
$DEBUTSUITE
  [M:LKP1]CXT = PARAM(1)
  # FGR 21/01/2009 : X3SUIVI33671 : on force le site s'il est renseigné
  If PARAM(2) <> "" Then
    [M:LKP1]CRIFCY =  PARAM(2)
    Grizo [M:LKP1]CRIFCY
  Endif
  [M:LKP1]PRECMGNOL = 0
  [M:LKP1]PREOPGNOL = 0
  #
  Gosub LOADLKP1
  Call LOADOPG([M:LKP1]PRECMGNOL)
  Gosub SETCXTVALUE
  Gosub LOADFORVALUE
  #
  Affzo [M:LKP1]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:LKP1]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  If BOUT = "1" Then
    If [M:LKP1]CRIDATSTR = [00/00/00] Then
      If [M:LKP1]CRIDATEND <> [00/00/00] Then
        #Les critères relatifs à la période de début de la campagne sont incorrects.
        GMESSAGE = mess(36,177,1)
        GERR = 2
        Return
      Endif
    Endif
    If [M:LKP1]CRIDATEND = [00/00/00] Then
      If [M:LKP1]CRIDATSTR <> [00/00/00] Then
        #Les critères relatifs à la période de début de la campagne sont incorrects.
        GMESSAGE = mess(36,177,1)
        GERR = 2    
        Return
      Endif
    Endif
    Gosub DEBUTSUITE
  Endif
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
##########################################################################################################
$ONOK
Local Integer IOKFLG

  IOKFLG = 4
  #On vérifie que tout va bien
  If [M:LKP1]SELCMG <> "" Then
    If [M:LKP1]SELOPG <> "" Then
      If [M:LKP1]SELOPGTYP > 0 Then
        If [M:LKP1]SELOPGTYP < 5 Then
          IOKFLG = 0
        Else
          IOKFLG = 3
        Endif
      Else
        IOKFLG = 3
      Endif
    Else
      IOKFLG = 2
    Endif
  Else
    IOKFLG = 1
  Endif
  If IOKFLG Then
    Case IOKFLG
      When 1
        #Une campagne marketing doit être sélectionnée.
        GMESSAGE = mess(164,182,1)
      When 2
        #Une opération marketing doit être sélectionnée.
        GMESSAGE = mess(165,182,1)
      When 3
        #Le type de l'opération marketing sélectionnée est incorrect.
        GMESSAGE = mess(166,182,1)
      When 4
        #La sélection effectuée est incorrecte.
        GMESSAGE = mess(167,182,1)
      When Default
    Endcase
    GERR = 2
    FIN = 0
  Endif
  If GERR Then
    Return
  Endif
