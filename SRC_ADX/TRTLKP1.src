    #  Affzo [M:TSK1]1-99
    # FGR 08/03/2010 : X3SUIVI62924 (fin)
  Case PARAM(1)
    When "OPP"
      Case [M:LKP1]SELOPGTYP
        When 1
          [M:OPP1]OPPOPGTYP = "OMM"
          [M:OPP1]OPPORITYP = "OMM"
          [M:OPP1]OPPORI = 2
        When 2
          [M:OPP1]OPPOPGTYP = "OMP"
          [M:OPP1]OPPORITYP = "OMP"
          [M:OPP1]OPPORI = 3
        When 3
          [M:OPP1]OPPOPGTYP = "OMT"
          [M:OPP1]OPPORITYP = "OMT"
          [M:OPP1]OPPORI = 4
        When 4
          [M:OPP1]OPPOPGTYP = "OMN"
          [M:OPP1]OPPORITYP = "OMN"
          [M:OPP1]OPPORI = 5
        When Default
      Endcase
      [M:OPP1]OPPCMGNUM = [M:LKP1]SELCMG
      [M:OPP1]OPPOPGNUM = [M:LKP1]SELOPG
      [M:OPP1]OPPORITXT = mess([M:OPP1]OPPORI,2995,1)
      [M:OPP1]OPPORIVCR = [M:LKP1]SELOPG
      [M:OPP1]OPPORIVCRL = 0
      If [M:OPP0]OPPNUM <> "" Then
        Call DEBTRANS From GLOCK
        Trbegin [OPP]
        Read [OPP]OPP0=[M:OPP0]OPPNUM
        If fstat Then
          #Erreur lors de l'association de l'affaire avec l'opération marketing sélectionnée.
          GMESSAGE = mess(163,182,1)
          GERR = 1
          Rollback
        Else
          [F:OPP]OPPOPGTYP = [M:OPP1]OPPOPGTYP
          [F:OPP]OPPCMGNUM = [M:OPP1]OPPCMGNUM
          [F:OPP]OPPOPGNUM = [M:OPP1]OPPOPGNUM
          [F:OPP]OPPORI = [M:OPP1]OPPORI
          [F:OPP]OPPORITYP = [M:OPP1]OPPORITYP
          [F:OPP]OPPORIVCR = [M:OPP1]OPPORIVCR
          [F:OPP]OPPORIVCRL = [M:OPP1]OPPORIVCRL
          Rewrite [OPP]
          If fstat Then
            #Erreur lors de l'association de l'affaire avec l'opération marketing sélectionnée.
            GMESSAGE = mess(163,182,1)
            GERR = 1
            Rollback
          Else
            Commit
          Endif
        Endif
      Endif
      Affzo [M:OPP1]1-99
    When "SOH"
      Case [M:LKP1]SELOPGTYP
        When 1
          [M:SOH1]OPGTYP = "OMM"
        When 2
          [M:SOH1]OPGTYP = "OMP"
        When 3
          [M:SOH1]OPGTYP = "OMT"
        When 4
          [M:SOH1]OPGTYP = "OMN"
        When Default
      Endcase
      [M:SOH1]CMGNUM = [M:LKP1]SELCMG
      [M:SOH1]OPGNUM = [M:LKP1]SELOPG
      If [M:SOH0]SOHNUM <> "" Then
        Read [SOH]SOH0=[M:SOH0]SOHNUM
        If !fstat Then
          Call DEBTRANS From GLOCK
          Trbegin [SOH]
          Readlock [SOH]SOH0=[M:SOH0]SOHNUM
          If fstat Then
            Rollback
            Unlock [SOH]
          Else
            [F:SOH]OPGTYP = [M:SOH1]OPGTYP
            [F:SOH]CMGNUM = [M:SOH1]CMGNUM
            [F:SOH]OPGNUM = [M:SOH1]OPGNUM
            Rewrite [SOH]
            If fstat Then
              #Erreur lors de l'enregistrement de l'origine marketing de cette commande.
              GMESSAGE = mess(578,182,1)
              GERR = 1
              Rollback
              Unlock [SOH]
            Else
              Commit
              Unlock [SOH]
            Endif
          Endif        
        Endif
      Endif
    When "SIH"
      Case [M:LKP1]SELOPGTYP
        When 1
          [M:SIH1]OPGTYP = "OMM"
        When 2
          [M:SIH1]OPGTYP = "OMP"
        When 3
          [M:SIH1]OPGTYP = "OMT"
        When 4
          [M:SIH1]OPGTYP = "OMN"
        When Default
      Endcase
      [M:SIH1]CMGNUM = [M:LKP1]SELCMG
      [M:SIH1]OPGNUM = [M:LKP1]SELOPG
      If [M:SIH0]NUM <> "" Then
        Read [SIV]SIV0=[M:SIH0]NUM
        If !fstat Then
          Call DEBTRANS From GLOCK
          Trbegin [SIV]
          Readlock [SIV]SIV0=[M:SIH0]NUM
          If fstat Then
            Rollback
            Unlock [SIV]
          Else
            [F:SIV]OPGTYP = [M:SIH1]OPGTYP
            [F:SIV]CMGNUM = [M:SIH1]CMGNUM
            [F:SIV]OPGNUM = [M:SIH1]OPGNUM
            Rewrite [SIV]
            If fstat Then
              #Erreur lors de l'enregistrement de l'origine marketing de cette facture directe.
              GMESSAGE = mess(579,182,1)
              GERR = 1
              Rollback
              Unlock [SIV]
            Else
              Commit
              Unlock [SIV]
            Endif
          Endif        
        Endif
      Endif
    When Default
  Endcase
Return

##########################################################################################################
# Chargement des campagnes
#########################################################
$LOADLKP1
Local Char SZUPPERTRANS(100)
Local Char SZUPPER2TRANS(100)
Local Char SZFILTER(250)
Local Char SZAND(6)
Local Integer ITAKECMG
Local Integer ITER

  ITER = 0
  SZFILTER = ""
  ITAKECMG = 0
  SZUPPERTRANS = ""
  SZUPPER2TRANS = ""
  SZAND = ""
  If [M:LKP1]CRIFCY <> "" Then
    SZFILTER = SZFILTER - SZAND - "[F:CMG]FCY = [M:LKP1]CRIFCY"
    SZAND = " and "
  Endif
  If [M:LKP1]CRIDATSTR <> [00/00/00] Then
    SZFILTER = SZFILTER - SZAND - "[F:CMG]DATSTR >= [M:LKP1]CRIDATSTR and [F:CMG]DATSTR <= [M:LKP1]CRIDATEND"
    SZAND = " and "
  Endif
  If [M:LKP1]CRICLO <> 2 Then
    SZFILTER = SZFILTER - SZAND - "[F:CMG]CLO <> 2"
    SZAND = " and "
  Endif
  #Chargement des campagnes
  If SZFILTER = "" Then
    Filter [CMG] Where [F:CMG]NUM <> "" Order By [F:CMG]DATSTR Desc
  Else
    Filter [CMG] Where evalue(SZFILTER) Order By [F:CMG]DATSTR Desc
  Endif
  For [CMG]
    If ITER >= dim([M:LKP1]NUM) Then
      Break
    Endif
    ITAKECMG = 0
    If [M:LKP1]CRIDES = "" Then
      ITAKECMG = 1
    Else
      SZUPPERTRANS = toupper(ctrans([M:LKP1]CRIDES))
      SZUPPER2TRANS = toupper(ctrans([F:CMG]TTR))
      ITAKECMG = instr(1, SZUPPER2TRANS, SZUPPERTRANS)
    Endif
    If ITAKECMG > 0 Then
      If ITER = 0 Then
        [M:LKP1]NBCMGSEL(ITER) = "->"
      Else
        [M:LKP1]NBCMGSEL(ITER) = ""
      Endif
      [M:LKP1]NUM(ITER) = [F:CMG]NUM
      [M:LKP1]TTR(ITER) = [F:CMG]TTR
      [M:LKP1]DATSTR(ITER) = [F:CMG]DATSTR
      [M:LKP1]DATEND(ITER) = [F:CMG]DATEND
      ITER += 1
    Endif
  Next
  Filter [CMG]
  [M:LKP1]NBCMG = ITER
Return

##########################################################################################################
# Chargement des campagnes
#########################################################
Subprog LOADOPG(ICMGNOL)
Value Integer ICMGNOL

Local Integer ITER

  Raz [M:LKP1]NBOPG
  Raz [M:LKP1]NBOPGSEL
  Raz [M:LKP1]DES
  Raz [M:LKP1]OPGTYP
  Raz [M:LKP1]OPGSTR
  Raz [M:LKP1]OPG
  Raz [M:LKP1]OPGTYPCLA
  If [M:LKP1]NBCMG <= 0 Then
    End
  Endif
  ITER = 0
  #Chargement des mailings
  Filter [OMM] Where [F:OMM]CMGNUM = [M:LKP1]NUM(ICMGNOL) Order By [F:OMM]SHIDAT Asc
  For [OMM] Hint Key OMM1
    If ITER >= dim([M:LKP1]OPG) Then
      Break
    Endif
    If ITER = 0 Then
      [M:LKP1]NBOPGSEL(ITER) = "->"
    Else
      [M:LKP1]NBOPGSEL(ITER) = ""
    Endif
    [M:LKP1]OPG(ITER) = [F:OMM]OMMNUM
    [M:LKP1]DES(ITER) = [F:OMM]DES
    [M:LKP1]OPGSTR(ITER) = [F:OMM]SHIDAT
    [M:LKP1]OPGTYP(ITER) = 1
    [M:LKP1]OPGTYPCLA(ITER) = "OMM"
    ITER += 1
  Next
  Filter [OMM]
  #Chargement des campagnes d'appels
  Filter [OMP] Where [F:OMP]CMGNUM = [M:LKP1]NUM(ICMGNOL) Order By [F:OMP]OMPSTR Asc
  For [OMP] Hint Key OMP1
    If ITER >= dim([M:LKP1]OPG) Then
      Break
    Endif
    If ITER = 0 Then
      [M:LKP1]NBOPGSEL(ITER) = "->"
    Else
      [M:LKP1]NBOPGSEL(ITER) = ""
    Endif
    [M:LKP1]OPG(ITER) = [F:OMP]OMPNUM
    [M:LKP1]DES(ITER) = [F:OMP]DES
    [M:LKP1]OPGSTR(ITER) = [F:OMP]OMPSTR
    [M:LKP1]OPGTYP(ITER) = 2
    [M:LKP1]OPGTYPCLA(ITER) = "OMP"
    ITER += 1
  Next
  Filter [OMP]
  #Chargement des salons professionnels
  Filter [OMT] Where [F:OMT]CMGNUM = [M:LKP1]NUM(ICMGNOL) Order By [F:OMT]OMTSTR Asc
  For [OMT] Hint Key OMT1
    If ITER >= dim([M:LKP1]OPG) Then
      Break
    Endif
    If ITER = 0 Then
      [M:LKP1]NBOPGSEL(ITER) = "->"
    Else
      [M:LKP1]NBOPGSEL(ITER) = ""
    Endif
    [M:LKP1]OPG(ITER) = [F:OMT]OMTNUM
    [M:LKP1]DES(ITER) = [F:OMT]DES
    [M:LKP1]OPGSTR(ITER) = [F:OMT]OMTSTR
    [M:LKP1]OPGTYP(ITER) = 3
    [M:LKP1]OPGTYPCLA(ITER) = "OMT"
    ITER += 1
  Next
  Filter [OMT]
  #Chargement des campagnes presse
  Filter [OMN] Where [F:OMN]CMGNUM = [M:LKP1]NUM(ICMGNOL) Order By [F:OMN]OMNSTR Asc
  For [OMN] Hint Key OMN1
    If ITER >= dim([M:LKP1]OPG) Then
      Break
    Endif
    If ITER = 0 Then
      [M:LKP1]NBOPGSEL(ITER) = "->"
    Else
      [M:LKP1]NBOPGSEL(ITER) = ""
    Endif
    [M:LKP1]OPG(ITER) = [F:OMN]OMNNUM
    [M:LKP1]DES(ITER) = [F:OMN]DES
    [M:LKP1]OPGSTR(ITER) = [F:OMN]OMNSTR
    [M:LKP1]OPGTYP(ITER) = 4
    [M:LKP1]OPGTYPCLA(ITER) = "OMN"
    ITER += 1
  Next
  Filter [OMN]
  [M:LKP1]NBOPG = ITER
  If [M:LKP1]NBOPG > 0 Then
    Call LOADMASK(ICMGNOL, 0)
  Else
    [M:LKP1]SELCMG = ""
    [M:LKP1]SELCMGDES = ""
    [M:LKP1]SELOPG = ""
    [M:LKP1]SELOPGDES = ""
    [M:LKP1]SELOPGTYP = 5
  Endif
End

##########################################################################################################
# Chargement de l'opération sélectionnée
#########################################################
Subprog LOADMASK(ICMGNOL, IOPGNOL)
Value Integer ICMGNOL
Value Integer IOPGNOL

  [M:LKP1]SELCMG = [M:LKP1]NUM(ICMGNOL)
  [M:LKP1]SELCMGDES = [M:LKP1]TTR(ICMGNOL)
  [M:LKP1]SELOPG = [M:LKP1]OPG(IOPGNOL)
  [M:LKP1]SELOPGDES = [M:LKP1]DES(IOPGNOL)
  [M:LKP1]SELOPGTYP = [M:LKP1]OPGTYP(IOPGNOL)
End

##########################################################################################################
# Affichage d'une campagne et d'une opération particulière en cas de chargement depuis une commande de vente.
##########################################################
$SETCXTVALUE
Local Char SZCMGNUM
Local Char SZOPGNUM
Local Char SZOPGTYP

  # FGR 11/03/2010 : X3SUIVI62924 (début)
  #Case [M:LKP1]CXT
  #  When "BAP"
  #    SZCMGNUM = [M:BAP1]APTCMGNUM
  #    SZOPGNUM = [M:BAP1]APTOPGNUM
  #    SZOPGTYP = [M:BAP1]APTOPGTYP
  #  When "CLL"
  #    SZCMGNUM = [M:CLL2]CLLCMGNUM
  #    SZOPGNUM = [M:CLL2]CLLOPGNUM
  #    SZOPGTYP = [M:CLL2]CLLOPGTYP
  #  When "TSK"
  #    SZCMGNUM = [M:TSK1]TSKCMGNUM
  #    SZOPGNUM = [M:TSK1]TSKOPGNUM
  #    SZOPGTYP = [M:TSK1]TSKOPGTYP
  # FGR 11/03/2010 : X3SUIVI62924 (fin)
  Case [M:LKP1]CXT
    When "OPP"
      SZCMGNUM = [M:OPP1]OPPCMGNUM
      SZOPGNUM = [M:OPP1]OPPOPGNUM
      SZOPGTYP = [M:OPP1]OPPOPGTYP
    When "SOH"
      SZCMGNUM = [M:SOH1]CMGNUM
      SZOPGNUM = [M:SOH1]OPGNUM
      SZOPGTYP = [M:SOH1]OPGTYP
    When "SIH"
      SZCMGNUM = [M:SIH1]CMGNUM
      SZOPGNUM = [M:SIH1]OPGNUM
      SZOPGTYP = [M:SIH1]OPGTYP
    When Default
      SZCMGNUM = ""
      SZOPGNUM = ""
      SZOPGTYP = ""
  Endcase
Return

##########################################################################################################
# Affichage d'une campagne et d'une opération particulière en cas de chargement depuis une commande de vente.
##########################################################
$LOADFORVALUE
Local Integer ITERCMG
Local Integer ITEROPG

  If SZCMGNUM = "" Then
    Return
  Endif
  If SZOPGNUM = "" Then
    Return
  Endif
  If SZOPGTYP = "" Then
    Return
  Endif
  For ITERCMG = 0 To [M:LKP1]NBCMG-1
    If [M:LKP1]NUM(ITERCMG) = SZCMGNUM Then
      Call LOADOPG(ITERCMG)
      [M:LKP1]NBCMGSEL([M:LKP1]PRECMGNOL) = ""
      [M:LKP1]NBCMGSEL(ITERCMG) = "->"
      [M:LKP1]PRECMGNOL = ITERCMG
      For ITEROPG = 0 To [M:LKP1]NBOPG-1
        If [M:LKP1]OPG(ITEROPG) = SZOPGNUM Then
          If [M:LKP1]OPGTYPCLA(ITEROPG) = SZOPGTYP Then
            Call LOADMASK([M:LKP1]PRECMGNOL, ITEROPG)
            [M:LKP1]NBOPGSEL([M:LKP1]PREOPGNOL) = ""
            [M:LKP1]NBOPGSEL(ITEROPG) = "->"
            [M:LKP1]PREOPGNOL = ITEROPG
            Break
          Endif
        Endif
      Next
      Break
    Endif
  Next
Return
