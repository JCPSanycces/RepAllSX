#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GBIDC1 = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","RECHTYP","RECHTYP",3,"XYRECHTYP") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return

$INIT
Local Integer I , J , K , INTE , OK , N , ER
Local Char    TYP(GLONATY) , TEXTE(80)
Local Char    FIC(GLONATB) , TIT(30) , TYPCOD(10)
Local Char    CLE(10)(1..16) , CHAINE(80) , MESSAGE(80)
Local Integer NBCLE
Local Integer NOLIB , TABDIV , LONG
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
If clalev([F:ATY])=0 : Local File ATYPE  [ATY] : Endif
Local Mask RECHTYP [DIA]
Raz [M:DIA]
TRA = 1
Return

$EXEC
TYP = toupper([M:DIA]TYP)
Read [ATY]CODTYP = TYP
Call OUVRE_BOITE(mess(18,115,1),100) From GESECRAN : # Recherche type de données
MESSAGE = mess(21,115,1)-TYP : # Type de données
If [F:ATY]TYPTYP=1
 NOLIB  = [M:DIA]MENLOC
Elsif [F:ATY]OBJLIEN="ADI"
 TABDIV = [M:DIA]TABDIV
Elsif find(TYP,"A","C","L","DCB")
 LONG   = [M:DIA]LNG
Endif
Gosub MESSAGE
Call OUVRE_TRACE(MESSAGE) From LECFIC
If [M:DIA]ATB=2   : Gosub TABLES  : Endif
If [M:DIA]ACLA=2  : Gosub CLASSES    : Endif
If [M:DIA]AMK=2   : Gosub ECRANS    : Endif
If [M:DIA]ASW=2   : Gosub REPRESENTATIONS : Endif
If [M:DIA]AUT=2
 Gosub AUTRES
 If [M:DIA]MENLOC<>0 : Gosub MENLOC : Endif
Endif
Call FERME_TRACE From LECFIC
Call FERME_BOITE From GESECRAN
Return

## Classes
$REPRESENTATIONS
Local File ASHW [ASW] , ASHWFLD [ASWF] , ASHWPAR [ASWP]
Call SET_BOITE(mess(23,140,1),nbrecord([F:ASW])) From GESECRAN : # Tables
Call ECR_TRACE(mess(23,140,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ASWF]ASWF1(1)
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [ASWF]ASWF1
  TABDIV = 0
  NOLIB  = 0
  LONG   = 0
  OK     = 0
  OK += (TYP="M" or TYP="MM") & find([F:ASWF]CODTYP,"M","MM")
  OK += pat([F:ASWF]CODTYP,TYP)
  If OK
   Read [ATY]CODTYP=[F:ASWF]CODTYP
   If [F:ATY]TYPTYP=1
    If [F:ASWF]NOLIB<>0
     NOLIB = [F:ASWF]NOLIB
    Endif
    If [M:DIA]MENLOC<>0 & NOLIB<>[M:DIA]MENLOC : OK = 0 : Endif
   Elsif [F:ATY]OBJLIEN="ADI"
    Read [ASWP] = [F:ASWF]CODREP;1;1;[ASWF]CODFLD;"";1;"NUMTAB"
    If !fstat
     Onerrgo RIEN
     TABDIV = val(num$(evalue([F:ASWP]VALEUR)))
     Onerrgo
    Endif
    If [M:DIA]TABDIV<>0 & TABDIV<>[M:DIA]TABDIV : OK = 0 : Endif
   Elsif find([F:ASWF]CODTYP,"A","C","L","DCB")
    LONG = [F:ASWF]LONG
    If [M:DIA]LNG<>0 & LONG<>[M:DIA]LNG : OK = 0 : Endif
   Endif
   If OK
    Call TEXTE([F:ASWF]INTFLD,TEXTE) From OBJDIV
    MESSAGE = [F:ASWF]CODTYP
    Gosub MESSAGE
    Call ECR_TRACE(MESSAGE-":"-[F:ASWF]CODREP-mess(34,140,1)-[F:ASWF]CODFLD-TEXTE,0) From GESECRAN
#   champ
   Endif
  Endif
 Next ASWF
Next ASWF(1)
Close Local File [ASW] , [ASWF] , [ASWP]
Call ECR_TRACE("",0) From GESECRAN
Return

## Classes
$CLASSES
Local File ACLASSE [ACLA] , ACLAFLD [ACLAF] , ACLAPARFLD [ACLFP]
Call SET_BOITE(mess(3,140,1),nbrecord([F:ACLA])) From GESECRAN : # Tables
Call ECR_TRACE(mess(3,140,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ACLAF]ACLAF1(1)
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [ACLAF]ACLAF1
  TABDIV = 0
  NOLIB  = 0
  LONG   = 0
  OK     = 0
  OK += (TYP="M" or TYP="MM") & find([F:ACLAF]CODTYP,"M","MM")
  OK += pat([F:ACLAF]CODTYP,TYP)
  If OK
   Read [ATY]CODTYP=[F:ACLAF]CODTYP
   If [F:ATY]TYPTYP=1
    If [F:ACLAF]NOLIB<>0
     NOLIB = [F:ACLAF]NOLIB
    Endif
    If [M:DIA]MENLOC<>0 & NOLIB<>[M:DIA]MENLOC : OK = 0 : Endif
   Elsif [F:ATY]OBJLIEN="ADI"
    Read [ACLFP]ACLFP0 = [F:ACLAF]CODCLA;1;1;[F:ACLAF]FLDCLA;"NUMTAB"
    If !fstat
     Onerrgo RIEN
     TABDIV = val(num$(evalue([F:ACLFP]VALEUR)))
     Onerrgo
    Endif
    If [M:DIA]TABDIV<>0 & TABDIV<>[M:DIA]TABDIV : OK = 0 : Endif
   Elsif find([F:ACLAF]CODTYP,"A","C","L","DCB")
    LONG = [F:ACLAF]LONG
    If [M:DIA]LNG<>0 & LONG<>[M:DIA]LNG : OK = 0 : Endif
   Endif
   If OK
    Call TEXTE([F:ACLAF]INTFLD,TEXTE) From OBJDIV
    MESSAGE = [F:ACLAF]CODTYP
    Gosub MESSAGE
    Call ECR_TRACE(MESSAGE-":"-[F:ACLAF]CODCLA-mess(34,140,1)-[F:ACLAF]FLDCLA-TEXTE,0) From GESECRAN
#   champ
   Endif
  Endif
 Next ACLAF
Next ACLAF(1)
Close Local File [ACLA] , [ACLAF] , [ACLFP]
Call ECR_TRACE("",0) From GESECRAN
Return

## Tables
$TABLES
Local File ATABLE [ATB] , ATABZON [ATZ]
Call SET_BOITE(mess(16,125,1),nbrecord([F:ATB])) From GESECRAN : # Tables
Call ECR_TRACE(mess(16,125,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ATZ]NUMLIG(1)
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [ATZ]NUMLIG
  TABDIV = 0
  NOLIB  = 0
  LONG   = 0
  OK     = 0
  OK += (TYP="M" or TYP="MM") & find([F:ATZ]CODTYP,"M","MM")
  OK += pat([F:ATZ]CODTYP,TYP)
  If OK
   Read [ATY]CODTYP=[F:ATZ]CODTYP
   If [F:ATY]TYPTYP=1
    If [F:ATZ]NOLIB<>0
     NOLIB = [F:ATZ]NOLIB
    Endif
    If [M:DIA]MENLOC<>0 & NOLIB<>[M:DIA]MENLOC : OK = 0 : Endif
   Elsif [F:ATY]OBJLIEN="ADI"
    J = instr(1,[F:ATZ]EXPLIEN,";")
    If J : TABDIV = val(left$([F:ATZ]EXPLIEN,J-1)) : Endif
    If [M:DIA]TABDIV<>0 & TABDIV<>[M:DIA]TABDIV : OK = 0 : Endif
   Elsif find([F:ATZ]CODTYP,"A","C","L","DCB")
    LONG = [F:ATZ]LONG
    If [M:DIA]LNG<>0 & LONG<>[M:DIA]LNG : OK = 0 : Endif
   Endif
   If OK
    Call TEXTE([F:ATZ]NOCOURT,TEXTE) From OBJDIV
    MESSAGE = [F:ATZ]CODTYP
    Gosub MESSAGE
    Call ECR_TRACE(MESSAGE-":"-[F:ATZ]CODFIC-mess(36,124,1)-[F:ATZ]CODZONE-TEXTE,0) From GESECRAN
#   champ
   Endif
  Endif
 Next ATZ
Next ATZ(1)
Close Local File [ATB] , [ATZ]
Call ECR_TRACE("",0) From GESECRAN
Return

$MESSAGE
If NOLIB<>0
 MESSAGE -= num$(NOLIB)
Endif
If TABDIV<>0
 MESSAGE -= num$(TABDIV)
Endif
If LONG<>0
 MESSAGE -= num$(LONG)
Endif
Return

$RIEN
Resume

## Ecrans
$ECRANS
Local File AMSK [AMK] , AMSKZON [AMZ] , AMSKPAR [AMP]
Call SET_BOITE(mess(17,125,1),nbrecord([AMK])) From GESECRAN : # Ecrans
Call ECR_TRACE(mess(17,125,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [AMZ]CODE(1)
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [AMZ]CODE
  TABDIV = 0
  NOLIB  = 0
  LONG   = 0
  OK     = 0
  OK += (TYP="M" or TYP="MM") & find([F:AMZ]CODTYP,"M","MM")
  OK += pat([F:AMZ]CODTYP,TYP)
  If OK
   Read [ATY]CODTYP=[F:AMZ]CODTYP
   If [F:ATY]TYPTYP=1
    If [F:AMZ]NOLIB<>0
     NOLIB = [F:AMZ]NOLIB
    Endif
    If [M:DIA]MENLOC<>0 & NOLIB<>[M:DIA]MENLOC : OK = 0 : Endif
   Elsif [F:ATY]OBJLIEN="ADI"
    Read [AMP]CODPAR = 1;[F:AMZ]CODMSK;[F:AMZ]CODZON;"ADI"
    If !fstat
     Onerrgo RIEN
     TABDIV = val(num$(evalue([F:AMP]VALPAR)))
     Onerrgo
    Endif
    If [M:DIA]TABDIV<>0 & TABDIV<>[M:DIA]TABDIV : OK = 0 : Endif
   Elsif find([F:AMZ]CODTYP,"A","C","L","DCB")
    LONG = [F:AMZ]LONG
    If [M:DIA]LNG<>0 & LONG<>[M:DIA]LNG : OK = 0 : Endif
   Endif
   If OK
    Call TEXTE([F:AMZ]INTIT,TEXTE) From OBJDIV
    MESSAGE = [F:AMZ]CODTYP
    Gosub MESSAGE
    Call ECR_TRACE(MESSAGE-":"-[F:AMZ]CODMSK-mess(17,115,1)-[F:AMZ]CODZON-TEXTE,0) From GESECRAN
#   Zone
   Endif
  Endif
 Next AMZ
Next AMZ(1)
Close Local File [AMK] , [AMZ] , [AMP]
Call ECR_TRACE("",0) From GESECRAN
Return

## Autres tables
$AUTRES
Local File ATABZON [ATZ] , ATABLE [ATB] , ATABIND [ATI]
For [ATZ]CODTYP(2) Where CODTYP="ATY"
 If !find([F:ATZ]CODFIC,"ATABZON","AMSKZON","ATYPE","ACLAFLD","ASHWFLD")
  If filinfo(filpath("FIL",[F:ATZ]CODFIC,"fde"),0)>0
   Onerrgo ERREUR
   Local File =[F:ATZ]CODFIC [FFF]
   Read [FFF] First
   Onerrgo
   If !ER
    Read [ATB]CODFIC = [F:ATZ]CODFIC
    Read [ATI]NUMLIG(2) = [F:ATZ]CODFIC;1
    CHAINE = [F:ATI]DESCRIPT
    NBCLE = 0
    While CHAINE<>""
     NBCLE += 1
     I = instr(1,CHAINE,"+")
     J = instr(1,CHAINE,"-")
     If    I & J  : I = min(I,J)
     Elsif J & !I : I = J
     Endif
     If I
      CLE(NBCLE) = left$(CHAINE,I-1) : CHAINE = right$(CHAINE,I+1)
     Else
      CLE(NBCLE) = CHAINE : CHAINE = ""
     Endif
    Wend
    Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
    Call SET_BOITE(TEXTE,nbrecord([FFF])) From GESECRAN
    K = 0 : N = 0
    For [FFF]
     NOLIB  = 0
     TABDIV = 0
     LONG   = 0
     K += 1
     Call AFF_BOITE("",K,INTE) From GESECRAN
     TYPCOD = evalue("[F:FFF]"+[F:ATZ]CODZONE)
     If TYPCOD<>"" & pat(TYPCOD,TYP)
      OK = 1
      Read [ATY]CODTYP=TYPCOD
      If [F:ATY]TYPTYP=1
       If dim([F:FFF]NOLIB)>0
        NOLIB = [F:FFF]NOLIB
       Elsif dim([F:FFF]PARNOLIB)>0
        NOLIB = [F:FFF]PARNOLIB
       Endif
       If [M:DIA]MENLOC<>0 & NOLIB<>[M:DIA]MENLOC : OK = 0 : Endif
      Elsif [F:ATY]OBJLIEN="ADI"
       If dim([F:FFF]NOLIB)>0
        TABDIV = [F:FFF]NOLIB
       Elsif dim([F:FFF]PARNOLIB)>0
        TABDIV = [F:FFF]PARNOLIB
       Endif
       If [M:DIA]TABDIV<>0 & TABDIV<>[M:DIA]TABDIV : OK = 0 : Endif
      Elsif find(TYPCOD,"A","C","L","DCB")
       If [M:DIA]LNG<>0
        If dim([F:FFF]LONG)>0
         LONG = [F:FFF]LONG
         If [F:FFF]LONG<>[M:DIA]LNG : OK = 0 : Endif
        Elsif dim([F:FFF]PARLNG)>0
         LONG = [F:FFF]PARLNG
         If [F:FFF]PARLNG<>[M:DIA]LNG : OK = 0 : Endif
        Endif
       Endif
      Endif
      If OK
       If N=0
        Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
        Call ECR_TRACE(TEXTE-"("+[F:ATB]CODFIC+")",0) From GESECRAN
        Call ECR_TRACE(string$(40,"-"),0) From GESECRAN
       Endif
       N += 1
       If [F:ATB]INTIT<>"" & evalue("type([F:FFF]"+[F:ATB]INTIT+")")>10
        TEXTE = evalue("[F:FFF]"+[F:ATB]INTIT)
       Else
        TEXTE = ""
       Endif
       GCLE = ""
       For I=1 To NBCLE
        GCLE -= num$(evalue("[F:FFF]"+CLE(I)))
       Next I
       MESSAGE = TYPCOD
       Gosub MESSAGE
       Call ECR_TRACE(MESSAGE-":"-GCLE-TEXTE,0) From GESECRAN
      Endif
     Endif
    Next FFF
    Close Local File [FFF]
    If N>0
     Call ECR_TRACE("",0) From GESECRAN
    Endif
   Endif
  Endif
 Endif
Next ATZ
Close Local File [ATB] , [ATZ] , [ATI]
Return

$MENLOC
Local File ATABLE [ATB]
For [ATB]CODFIC Where find(CODFIC,"ADOPAR","AMAINT")
 Local File =[F:ATB]CODFIC [FFF]
 N = 0
 Case [ATB]CODFIC
  When "ADOPAR"
   For [FFF] Where NOLIB=[M:DIA]MENLOC
    If N=0
     Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
     Call ECR_TRACE(TEXTE-"("+[F:ATB]CODFIC+")",0) From GESECRAN
     Call ECR_TRACE(string$(40,"-"),0) From GESECRAN
    Endif
    N += 1
    MESSAGE = [M:DIA]TYP-num$([M:DIA]MENLOC)
    GCLE = [F:FFF]CHAPITRE-[F:FFF]PARAM
    Call TEXTE([F:FFF]NAM,TEXTE) From OBJDIV
    Call ECR_TRACE(MESSAGE-":"-GCLE-TEXTE,0) From GESECRAN
   Next FFF
  When "AMAINT"
   For [FFF]
    Read [ATY]CODTYP = [F:FFF]VARTYP
    If [F:ATY]TYPTYP=1 & [F:FFF]VARMEN=[M:DIA]MENLOC
     If N=0
      Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
      Call ECR_TRACE(TEXTE-"("+[F:ATB]CODFIC+")",0) From GESECRAN
      Call ECR_TRACE(string$(40,"-"),0) From GESECRAN
     Endif
     N += 1
     MESSAGE = [M:DIA]TYP-num$([M:DIA]MENLOC)
     GCLE = [F:FFF]COD
     Call TEXTE([F:FFF]INTIT,TEXTE) From OBJDIV
     Call ECR_TRACE(MESSAGE-":"-GCLE-TEXTE,0) From GESECRAN
    Endif
   Next FFF
 Endcase
 Close Local File [FFF]
 If N>0
  Call ECR_TRACE("",0) From GESECRAN
 Endif
Next ATB
Close Local File [ATB]
Return

$ERREUR
ER = errn
Resume

########################################
Subprog AS_MENLOC(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]TYP,"") From CONTOBJ
If [F:ATY]TYPTYP<>1 : mkstat = 2 : Endif
End

Subprog AS_TABDIV(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]TYP,"") From CONTOBJ
If [F:ATY]OBJLIEN<>"ADI" : mkstat = 2 : Endif
End

Subprog AS_LNG(VALEUR)
Variable Decimal VALEUR
If !find([M]TYP,"A","C","L","DCB") : mkstat = 2 : Endif
End

Subprog AP_TYP(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
If [F:ATY]TYPTYP=1
 Actzo MENLOC : Grizo TABDIV, LNG
Elsif [F:ATY]OBJLIEN="ADI"
 Actzo TABDIV : Grizo MENLOC, LNG
Elsif find(VALEUR,"A","C","L","DCB")
 Actzo LNG    : Grizo MENLOC, TABDIV
Else
 Grizo TABDIV : Grizo MENLOC, LNG
Endif
End

########################################
Subprog S_TYP(VALEUR)
Variable Char    VALEUR()
Call SELECT("ATY","",VALEUR,"") From SELOBJ
End
