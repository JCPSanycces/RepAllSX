#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion objet ASL
Raz GPILOBJ
Call OBJET("ASL",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "INICRE"    : Gosub INICRE
 When "STYLE"     : Gosub STYLE
 When "APRES_MOD" : Gosub APRES_MOD
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
Endcase
Return

$INICRE
[F:ASL]LIG = nolign
Return

$STYLE
Chgstl [M]STY With ""
For nolign=1 To [M]NBLIG
 Chgstl [M]STY(nolign-1) With [M]STY(nolign-1)
Next
Return

$VERIF_CRE
$VERIF_MOD
If [M]NBLIG=0
 OK = 0
Elsif [M]NBLIG=1 & [M]CND(0)=""
 OK = 0
Else
 For I=0 To [M]NBLIG-2
  If [M]CND(I)=""
   OK = 0 : Break
  Endif
 Next I
Endif
If !OK
 GMESSAGE = mess(214,133,1) : # Paramétrage incorrect
Endif
Return

$APRES_MOD
OK = 2 : Call OUINON(mess(144,133,1),OK) From GESECRAN : # Revalidation des écrans
If OK<>2 : Return : Endif
Call OUVRE_TRACE(mess(144,133,1)) From LECFIC : # Revalidation des écrans
If clalev([F:A_MZ])=0 : Local File AMSKZON [A_MZ] : Endif
For [A_MZ]CODE(1) Where STYCND=CLECUR1
 Call VALID([F:A_MZ]CODMSK,nomap,1,GLANGUE,0,OK) From VALMSK
Next
Close Local File [A_MZ]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return

##########################################################################
## Ecran ASL1
##########################################################################
Subprog C_STY(VALEUR)
Variable Char    VALEUR()
Chgstl [M]STY(nolign-1) With VALEUR
End
