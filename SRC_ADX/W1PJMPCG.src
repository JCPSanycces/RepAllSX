#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMPCG 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:51"
A_USER  = "DOC"
A_STAMP = "20181109230551"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBPCG"
  If [M]NBPCG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMPCG [PJCC1]
Gosub HORODAT
Local Inpbox "PJMPCG" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJCC1] As [SIM_]
Grizo [PJCC1]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJCC1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=22
Return

$ON_NBPCG
Onevent CONTROL Call C_NBPCG From W1PJMPCG
Return

Subprog C_NBPCG
Local Decimal BASPAG
## Action STD
Call C_NBPCG From SUBPJCC
If mkstat : GERR = 1 : GZONE = "NBPCG" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_PCGTYP
Onevent AFTER_CHANGE Gosub AMM_PCGTYP From W1PJMPCG
Onevent INIT_AREA Call D_PCGTYP(zc) From W1PJMPCG
Onevent BEFORE_INPUT Call AS_PCGTYP(zc) From W1PJMPCG
Return

Subprog D_PCGTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]PCGTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PCGTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_PCGTYP
Call AM_PCGTYP(zc)
If !mkstat & GOBJET
 zoncou = "PCGTYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PCGTYP(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_PCGTYP(VALEUR) From SUBPJCC
If mkstat : GERR = 1 : GZONE = "PCGTYP" : GZNUM = 1001819 : Endif
Gosub _AFF
End

