#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DLA4 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CTTTYP
mkstat = 0
zoncou = "CTTTYP"
indice = 0
IMPENT = [M]CTTTYP
If varinit([M]CTTTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]CTTTYP,indice)=0
 [M]CTTTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTTTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CTTTYP(indice)
 Endif
Endif
[M]CTTTYP = IMPENT

## Zone CTTDAT
mkstat = 0
zoncou = "CTTDAT"
indice = 0
If varmode([M]CTTDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTTDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DATDEBFIN"
 Call DATDEBFIN([M]CTTDAT,[M:DLA0]DAT) From EXEFNC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CTTDAT" : GZNUM = 46360 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CTTHOU
mkstat = 0
zoncou = "CTTHOU"
indice = 0
If varmode([M]CTTHOU,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTTHOU" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CTTCNT
mkstat = 0
zoncou = "CTTCNT"
indice = 0
IMPENT = [M]CTTCNT
If varinit([M]CTTCNT,indice)=0
 IMPENT = 1
Endif
If varmode([M]CTTCNT,indice)=0
 [M]CTTCNT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTTCNT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CTTCNT(indice)
 Endif
Endif
[M]CTTCNT = IMPENT

## Zone CTTINS
mkstat = 0
zoncou = "CTTINS"
indice = 0
IMPENT = [M]CTTINS
WNUM = IMPENT
If varinit([M]CTTINS,indice)=0
 IMPENT = 1
 SAVACT = GACTION : GACTION = "STD"
 Call D_CTTINS(IMPENT) From SUBDLA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]CTTINS,indice)=0
  [M]CTTINS(indice) = IMPENT
  If !mkstat
   IMPMOD = 0 : IMPZON = "CTTINS" : Gosub ACTION From =IMPTRT
   IMPENT = [M]CTTINS(indice)
  Endif
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_CTTINS(IMPENT) From SUBDLA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CTTINS" : GZNUM = 47441 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]CTTINS = IMPENT

## Zone RGTDAT
mkstat = 0
zoncou = "RGTDAT"
indice = 0
If varmode([M]RGTDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RGTDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DATDEBFIN"
 Call DATDEBFIN([M]RGTDAT,[M:DLA0]DAT) From EXEFNC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "RGTDAT" : GZNUM = 47442 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone RGTNUM
mkstat = 0
zoncou = "RGTNUM"
indice = 0
If varmode([M]RGTNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RGTNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone TXT2
mkstat = 0
zoncou = "TXT2"
indice = 0
If varmode([M]TXT2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TXT2" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TXT3
mkstat = 0
zoncou = "TXT3"
indice = 0
If varmode([M]TXT3,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TXT3" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TXT4
mkstat = 0
zoncou = "TXT4"
indice = 0
If varmode([M]TXT4,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TXT4" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DTAWAC
mkstat = 0
zoncou = "DTAWAC"
indice = 0
IMPENT = [M]DTAWAC
If varinit([M]DTAWAC,indice)=0
 IMPENT = 1
Endif
If varmode([M]DTAWAC,indice)=0
 [M]DTAWAC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTAWAC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DTAWAC(indice)
 Endif
Endif
[M]DTAWAC = IMPENT

## Zone DECES
mkstat = 0
zoncou = "DECES"
indice = 0
IMPENT = [M]DECES
If varinit([M]DECES,indice)=0
 IMPENT = 1
Endif
If varmode([M]DECES,indice)=0
 [M]DECES(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DECES" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DECES(indice)
 Endif
Endif
[M]DECES = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "DLA4"
Return

