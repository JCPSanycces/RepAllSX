#########################################################################
Subprog INIVAR

# 7761 llc 01.01
Global Integer GMFIMAX
Global Integer GMFOMAX
Global Integer GMFMMAX

If clalev([F:ACV]) = 0 : Local File ACTIV     [ACV] : Endif

# nombre max articles lancés
Read [ACV]CODACT="MFI"
If !fstat GMFIMAX =[F:ACV]DIME : Endif

# nombre max composants
Read [ACV]CODACT="MFM"
If !fstat GMFMMAX =[F:ACV]DIME : Endif

# nombre max opérations
Read [ACV]CODACT="MFO"
If !fstat GMFOMAX =[F:ACV]DIME : Endif

# 09.06
# variable globale pour inhiber point d'entree CAPACITY si non utile (performances)
Global Integer GCAPACITY : GCAPACITY = 0
GCAPACITY = find("JALLIBB",GENTSTD(1..GNBENTREE))

#---------
# point d'entrée WORKLOAD 10.06
If dim(GCAPACITY) > 0
    If dim(GWKLACT) < 0 : Global Char GWKLACT(10)      : Endif
    If dim(GWKLMFG) < 0 : Global Char GWKLMFG(GLONVCR) : Endif
    If dim(GWKLOPE) < 0 : Global Integer GWKLOPE       : Endif
    If dim(GWKLSPL) < 0 : Global Integer GWKLSPL       : Endif
Endif

#--------
Global Char GSTRTEAM1(5) : GSTRTEAM1 = "08:00"
Global Char GSTRTEAM2(5) : GSTRTEAM2 = "04:00"


End

############################################################################################
# 06.05 31012
# Initialisation GSTRTEAM1/GSTRTEAM2 à partir de PARJAL
Subprog INIT_STARTHOUR
If [F:PJA]STRTEAM1 <> "" : Call CONVHOU2([F:PJA]STRTEAM1, GSTRTEAM1) From JALLIBB : Endif
If [F:PJA]STRTEAM2 <> "" : Call CONVHOU2([F:PJA]STRTEAM2, GSTRTEAM2) From JALLIBB : Endif
End

#########################################################################
# Contrôle de validité (pour prod) d'un article                         #
# ITM & ITF doivent être chargés ...                                    #
#-----------------------------------------------------------------------#
Subprog CONTMFGITM(LFCY, LMSG)
Variable Char     LFCY
Value    Integer  LMSG
Local    Integer  VS
#

If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> LFCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
   Read [ITF]ITF0 = [F:ITM]ITMREF;LFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif


Case [F:ITM]ITMSTA
    When 1:       #   Article actif = ok
    When 2,3:     #   Article non disponible (non bloquant)
              If LMSG=1
                  VS=1
                  Call AVERTIR(mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")",VS) From GESECRAN
                  If VS = 1 : mkstat = 2 : End : Endif
              Else
                  mkstat=2
                  End
              Endif
    When Default: #   Article non disponible (bloquant)
              If LMSG=1 : GMESSAGE = (mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")") : Endif
              mkstat = 2
              End
Endcase
#    Article non fabriqué
If [F:ITM]MFGFLG <> 2
    If LMSG=1 : GMESSAGE = mess(44,193,1) : Endif
    mkstat = 2
    End
Endif
#    Article non géré en stock
If !find([F:ITF]STOMGTCOD,2,3,4)
  If LMSG=1 : GMESSAGE = mess(147,199,1) : Endif
  mkstat = 2
  End
Endif
End

#########################################################################
# Contrôle de validité (pour prod) d'une alternative                    #
# [F:TBO] & [F:BOH] doivent être chargés ...                            #
#-----------------------------------------------------------------------#
Subprog CONTMFGNOM(LFCY, LALT, LDAT, LMSG)
Variable Char     LFCY
Variable Integer  LALT
Variable Date     LDAT
Value    Integer  LMSG
LALT=0

# Issue 105584 - 2015-05-05 by BEEBE : Entry Point to control the validations.
#                specially to deactivate the validation of USESTA by modify in GESMFG
#                5 Flags to Control the validation (0 = no validation, 1 = validation)
#                1. - [F:TBO]FCY
#                2. - [F:TBO]MFGUSE
#                3. - [F:BOH]USESTA
#                4. - [F:BOH]BOHSTRDAT
#                5. - [F:BOH]BOHENDDAT
#                Default-Value = "11011" for V9, "11111" for V6-V8

If GFONCTION="GESMFG" & GREP="M"
    GPE=11011
Else
    GPE=11111
Endif

GPOINT="CTLMFGBOM"
Gosub ENTREE From EXEFNC

Local Char CHECKEP(5) : CHECKEP=num$(GPE)

# setting fill-character "0" for the string field CHECKEP for further usage
If (len(CHECKEP) < 5)
    CHECKEP = string$(5-len(CHECKEP), "0") + CHECKEP
Endif

# Alternative de production ?
If [F:TBO]BOMALTTYP<>2
    If LMSG<>0 : GMESSAGE=mess(47,193,1) : Endif
    End
Endif
# Opérateur autorisé ?
If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC=GUSER;[F:TBO]ACSCOD
If (!fstat & [F:ACC]EXEC = 1)
    If LMSG<>0 : GMESSAGE=mess(46,193,1) : Endif
    End
Endif
# Site ?
If ([F:TBO]FCY<>"" & [F:TBO]FCY<>LFCY & mid$(CHECKEP,1,1)="1")
    If LMSG<>0 : GMESSAGE=mess(48,193,1) : Endif
    End
Endif
# Utilisable en production ?
If ([F:TBO]MFGUSE<>2 & mid$(CHECKEP,2,1)="1")
    If LMSG<>0 : GMESSAGE=mess(49,193,1) : Endif
    End
Endif
# Utilisable en exploitation ?
If ([F:BOH]USESTA<>2 & mid$(CHECKEP,3,1)="1")
    If LMSG<>0 : GMESSAGE=mess(51,193,1) : Endif
    End
Endif
# Nomenclature valide ?
If ([F:BOH]BOHSTRDAT <> [0/0/0] & LDAT < [F:BOH]BOHSTRDAT & mid$(CHECKEP,4,1)="1")
     If LMSG<>0 : GMESSAGE=mess(50,193,1) : Endif
     End
Endif
If ([F:BOH]BOHENDDAT <> [0/0/0] & LDAT > [F:BOH]BOHENDDAT & mid$(CHECKEP,5,1)="1")
     If LMSG<>0 : GMESSAGE=mess(50,193,1) : Endif
     End
Endif
#
LALT=[F:BOH]BOMALT
End


#######################################################################
# Sous programme d'accès au fichier BOM avec filtre sur nomenclatures
# propres au lancement
# LFCY = Site
# LITM = Article
# LRET = alternative sélectionnée ou 0
#---------------------------------------------------------#
Subprog SELMFGNOM(LFCY,LITM,LRET)
Variable Char    LFCY
Variable Char    LITM
Variable Integer LRET
#
Local    Char    WFILT(255)
Local    Char    WFILB(255)
Local    Char    WINT(20)(4)
#
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA    [AXX] : Endif  # FGR 16/09/2009 : X3SUIVI57824
#
Call TEXTFIC("BOM","ITMREF",1,WINT(0))        From OBJDIV
Call TEXTFIC("BOM","BOMALT",1,WINT(1))        From OBJDIV
#Call TEXTFIC("TBO","TBOSHO",1,WINT(2))       From OBJDIV
Call TEXTFIC("TABBOMALT","TBOSHOAXX",1,WINT(2))     From OBJDIV # FGR 16/09/2009 : X3SUIVI57824
Call TEXTFIC("BOM","BOHENDDAT",1,WINT(3))     From OBJDIV
#
# Filtre Alternative [TBO]
WFILT = '([F:TBO]FCY=LFCY | [F:TBO]FCY="") & [F:TBO]MFGUSE=2 & [F:TBO]BOMALTTYP=2'
#filtre nomenclature [BOH]
WFILB = "[F:BOH]ITMREF = LITM"

# FGR 16/09/2009 : X3SUIVI57824 (début)
#Link [BOH] With [TBO]TBO0=[F:BOH]BOMALTTYP;[F:BOH]BOMALT As [NOM]
#&            Where evalue(WFILT)&evalue(WFILB)
#&            Order By Key BOH0
#Choose [NOM]
#&  Using  [F:BOH]ITMREF  Titled WINT(0),
#&         [F:BOH]BOMALT  Titled WINT(1),
#&         [F:TBO]TBOSHO  Titled WINT(2),
#&         [F:BOH]BOHENDDAT Titled WINT(3)
#&  Sized(80,250)
#&  Titled mess(153,198,1)
Link [BOH] With [TBO]TBO0=[F:BOH]BOMALTTYP;[F:BOH]BOMALT,
&               [AXX]AXX0="TABBOMALT";"TBOSHOAXX";GLANGUE;num$([F:TBO]BOMALTTYP);num$([F:TBO]BOMALT)
&            As [NOM]
&            Where evalue(WFILT)&evalue(WFILB)
&            Order By Key BOH0
Choose [NOM]
&  Using  [F:BOH]ITMREF  Titled WINT(0),
&         [F:BOH]BOMALT  Titled WINT(1),
&         [F:AXX]TEXTE   Titled WINT(2),
&         [F:BOH]BOHENDDAT Titled WINT(3)
&  Sized(80,250)
&  Titled mess(153,198,1)
# FGR 16/09/2009 : X3SUIVI57824 (fin)
LRET = 0
If status = 7
   End
Else
   LRET = [F:BOH]BOMALT
Endif
End

###########################################################
# Contrôle de validité (pour prod) d'une alternative      #
# TRO & ROH doivent être chargés ...                      #
#---------------------------------------------------------#
Subprog CONTMFGGAM(LFCY, LALT, LDAT, LQTY, LSTU, LMSG)
Variable Char     LFCY
Variable Integer  LALT
Variable Date     LDAT
Value    Decimal  LQTY
Value    Char     LSTU
Value    Integer  LMSG
#
LALT=0

# Issue 105584 - 2015-05-05 by BEEBE : Entry Point to control the validations.
#                specially to deactivate the validation of USESTA by modify in GESMFG
#                5 Flags to Control the validation (0 = no validation, 1 = validation)
#                1. - [F:TRO]FCY
#                2. - [F:TRO]MFGUSE
#                3. - [F:ROH]USESTA
#                4. - [F:ROH]ROUSTRDAT
#                5. - [F:ROH]ROUENDDAT
#                6. - Value from Issue 103772
#                Default-Value = "110110" for V9, "111110" for V6-V8
#
# Issue 103772 - 2014-12-03 by CCC : Hidden entry point to avoid quantity control
#                                   This EP is hidden because the context is very difficult to find
# GPE = 0 : control of qty min and max
#     = 1 : no control of min qty
#     = 2 : no control of max qty
#     = 3 : no control of min & max qty

If GFONCTION="GESMFG" & GREP="M"
    GPE=110110
Else
    GPE=111110
Endif

GPOINT = "ROUQTYCTL"    #CHECK IGNORE_LINE
Gosub ENTREE From EXEFNC

# old EP from Issue 103772 has been used
If GPE < 10
    GPE = GPE + 111110
Endif

Local Char CHECKEP(6) : CHECKEP=num$(GPE)

# setting fill-character "0" for the String-Field CHECKEP for further Usage
If (len(CHECKEP) < 6)
    CHECKEP = string$(6-len(CHECKEP), "0") + CHECKEP
Endif

# Opérateur autorisé ?
If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC=GUSER;[F:TRO]ACSCOD
If (!fstat & [F:ACC]EXEC = 1)
    If LMSG<>0 : GMESSAGE=mess(46,193,1) : Endif
    End
Endif

# Site ?
If ([F:TRO]FCY<>"" & [F:TRO]FCY<>LFCY & mid$(CHECKEP,1,1)="1")
    If LMSG<>0 : GMESSAGE=mess(48,193,1) : Endif
    End
Endif

# Utilisable en production ?
If ([F:TRO]MFGUSE<>2 & mid$(CHECKEP,2,1)="1")
    If LMSG<>0 : GMESSAGE=mess(49,193,1) : Endif
    End
Endif

# Gamme existante sur le site de production ?
If [F:ROH]FCY<>LFCY
    If LMSG<>0 : GMESSAGE=mess(145,193,1) : Endif
    End
Endif

# Utilisable en exploitation ?
If ([F:ROH]USESTA<>2 & mid$(CHECKEP,3,1)="1")
    If LMSG<>0 : GMESSAGE=mess(54,193,1) : Endif
    End
Endif

# Nomenclature valide ?
If ([F:ROH]ROUSTRDAT <> [0/0/0] & LDAT < [F:ROH]ROUSTRDAT & mid$(CHECKEP,4,1)="1")
     If LMSG<>0 : GMESSAGE=mess(55,193,1) : Endif
     End
Endif
If ([F:ROH]ROUENDDAT <> [0/0/0] & LDAT > [F:ROH]ROUENDDAT & mid$(CHECKEP,5,1)="1")
     If LMSG<>0 : GMESSAGE=mess(55,193,1) : Endif
     End
Endif

# Gamme validée
If [F:ROH]CFMFLG<>2
    If LMSG<>0 : GMESSAGE=mess(56,193,1) : Endif
    End
Endif

# Issue 105584 - 2015-05-05 by BEEBE : Entry Point to control the validations.
# 6th position of GPE as single value
GPE = val(mid$(CHECKEP,6,1))

# Quantité mini/maxi
If [F:ROH]WORMINQTY <> 0 & LQTY < [F:ROH]WORMINQTY & mod(GPE,2)<1
    If LMSG<>0 : GMESSAGE=mess(57,193,1)-"("+num$([F:ROH]WORMINQTY)-LSTU+")": : Endif          # llc 05.03 18397
    End
Endif
If [F:ROH]WORMAXQTY <> 0 & LQTY > [F:ROH]WORMAXQTY & mod(GPE,4)<2
    If LMSG<>0 : GMESSAGE=mess(58,193,1)-"("+num$([F:ROH]WORMAXQTY)-LSTU+")" : Endif           # llc 05.03 18397
    End
Endif

# contrôle de cohérence de l'unité de stock
# ouverture forcée pour compatibilité planif. multi-niveaux
Local File ITMMASTER [ITM]

If [F:ITM]ITMREF <> [F:ROH]ITMREF
    Read [ITM]ITM0=[F:ROH]ITMREF
    If fstat
        If LMSG<>0 : GMESSAGE = mess(134,100,1) : Endif
        End
    Endif
Endif
If [F:ITM]STU <> LSTU
  If LMSG<>0 : GMESSAGE = mess(66,193,1) : Endif
  End
Endif

#
LALT=[F:ROH]ROUALT
End

###########################################################
# Contrôle de validité (pour prod) d'une alternative      #
# TRO & ROH doivent être chargés ...                      #
#---------------------------------------------------------#
Subprog CONTMFGGAMMOD(LFCY, LALT, LDAT, LQTY, LSTU, LMSG)
Variable Char     LFCY
Variable Integer  LALT
Variable Date     LDAT
Value    Decimal  LQTY
Value    Char     LSTU
Value    Integer  LMSG
#
LALT=0

# Site ?
If ([F:TRO]FCY<>"" & [F:TRO]FCY<>LFCY)
    If LMSG<>0 : GMESSAGE=mess(48,193,1) : Endif
    End
Endif

# Gamme existante sur le site de production ?
If [F:ROH]FCY<>LFCY
    If LMSG<>0 : GMESSAGE=mess(145,193,1) : Endif
    End
Endif

# Nomenclature valide ?
If ([F:ROH]ROUSTRDAT <> [0/0/0] & LDAT < [F:ROH]ROUSTRDAT)
     If LMSG<>0 : GMESSAGE=mess(55,193,1) : Endif
     End
Endif
If ([F:ROH]ROUENDDAT <> [0/0/0] & LDAT > [F:ROH]ROUENDDAT)
     If LMSG<>0 : GMESSAGE=mess(55,193,1) : Endif
     End
Endif

# Quantité mini/maxi
If [F:ROH]WORMINQTY <> 0 & LQTY < [F:ROH]WORMINQTY
    If LMSG<>0 : GMESSAGE=mess(57,193,1) : Endif
    End
Endif
If [F:ROH]WORMAXQTY <> 0 & LQTY > [F:ROH]WORMAXQTY
    If LMSG<>0 : GMESSAGE=mess(58,193,1) : Endif
    End
Endif

# contrôle de cohérence de l'unité de stock
# ouverture forcée pour compatibilité planif. multi-niveaux
Local File ITMMASTER [ITM]
If [F:ITM]ITMREF <> [F:ROH]ITMREF
    Read [ITM]ITM0=[F:ROH]ITMREF
    If fstat
        If LMSG<>0 : GMESSAGE = mess(134,100,1) : Endif
        End
    Endif
Endif
If [F:ITM]STU <> LSTU
  If LMSG<>0 : GMESSAGE = mess(66,193,1) : Endif
  End
Endif

#
LALT=[F:ROH]ROUALT
End

###########################################################
# Contrôle de validité (pour prod) d'une alternative      #
# TRO & ROH doivent être chargés ...                      #
#---------------------------------------------------------#
Subprog CONTRCCGAM(LFCY, LALT, LDAT, LQTY, LSTU, LMSG)
Variable Char     LFCY
Variable Integer  LALT
Variable Date     LDAT
Value    Decimal  LQTY
Value    Char     LSTU
Value    Integer  LMSG
#
LALT=0

# Opérateur autorisé ?
If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC=GUSER;[F:TRO]ACSCOD
If (!fstat & [F:ACC]EXEC = 1)
    If LMSG<>0 : GMESSAGE=mess(46,193,1) : Endif
    End
Endif

# Site ?
If ([F:TRO]FCY<>"" & [F:TRO]FCY<>LFCY)
    If LMSG<>0 : GMESSAGE=mess(48,193,1) : Endif
    End
Endif

# Utilisable en production ?
If [F:TRO]RCCUSE<>2
    If LMSG<>0 : GMESSAGE=mess(49,193,1) : Endif
    End
Endif

# Utilisable en exploitation ?
If [F:ROH]USESTA<>2
    If LMSG<>0 : GMESSAGE=mess(54,193,1) : Endif
    End
Endif

# Nomenclature valide ?
If ([F:ROH]ROUSTRDAT <> [0/0/0] & LDAT < [F:ROH]ROUSTRDAT)
     If LMSG<>0 : GMESSAGE=mess(55,193,1) : Endif
     End
Endif
If ([F:ROH]ROUENDDAT <> [0/0/0] & LDAT > [F:ROH]ROUENDDAT)
     If LMSG<>0 : GMESSAGE=mess(55,193,1) : Endif
     End
Endif

# Gamme validée
If [F:ROH]CFMFLG<>2
    If LMSG<>0 : GMESSAGE=mess(56,193,1) : Endif
    End
Endif

# llc 09.01 10670
# Quantité mini/maxi
If [F:ROH]WORMINQTY <> 0 & LQTY < [F:ROH]WORMINQTY
    If LMSG<>0 : GMESSAGE=mess(57,193,1) : Endif
    End
Endif
If [F:ROH]WORMAXQTY <> 0 & LQTY > [F:ROH]WORMAXQTY
    If LMSG<>0 : GMESSAGE=mess(58,193,1) : Endif
    End
Endif

# contrôle de cohérence de l'unité de stock
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif
If [F:ITM]ITMREF <> [F:ROH]ITMREF
    Read [ITM]ITM0=[F:ROH]ITMREF
    If fstat
        If LMSG<>0 : GMESSAGE = mess(134,100,1) : Endif
        End
    Endif
Endif
If [F:ITM]STU <> LSTU
  If LMSG<>0 : GMESSAGE = mess(66,193,1) : Endif
  End
Endif

#
LALT=[F:ROH]ROUALT
#
End


##################################################################
#----------------------------------------------------------------#
# Calcul d'une date avec une date et un delai                    #
#                        et ctrl jours et périodes indispo       #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         LTI      : Délai                                       #
#         UVYDAY   : Jours indisponibilités                      #
#         UVYCOD   : Code période indisponibilité                #
#         SENCAL   : Sens de calcul date                         #
#         SENDEC   : Sens décalage si jours indisponibilité      #
# Sortie  DSTDAT   : Date destination                            #
#----------------------------------------------------------------#
Subprog CALCUL_DATE(ORIDAT, LTI, UVYDAY, UVYCOD, SENCAL, SENDEC, DSTDAT)
Value    Date     ORIDAT
Value    Integer  LTI
Value    Libelle  UVYDAY
Value    Char     UVYCOD
Value    Integer  SENCAL
Value    Integer  SENDEC
Variable Date     DSTDAT
Local    Integer  LMSG
Local    Integer  I

I=LTI
LMSG=0
DSTDAT=ORIDAT

While (I>0)
    If SENCAL=0 : DSTDAT+=1
    Else        : DSTDAT-=1 : Endif
    Call CALCUL_JOUR(DSTDAT, UVYDAY, UVYCOD, SENDEC, LMSG)
    If mkstat=0 : I-=1 : LMSG=0 : Else : mkstat=0 : Endif
Wend

End

##################################################################
#----------------------------------------------------------------#
# Controle d'une date avec indispo.                              #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         UVYDAY   : Jours indisponibilités                      #
#         UVYCOD   : Code période indisponibilité                #
#----------------------------------------------------------------#
Subprog CONTROL_DATE(ORIDAT, UVYDAY, UVYCOD)
Value    Date     ORIDAT
Value    Libelle  UVYDAY
Value    Char     UVYCOD
Local    Integer  LMSG
Local    Integer  I

LMSG=1
Call CONTROL_JOUR(ORIDAT, UVYDAY, UVYCOD, LMSG)
End

########################################################################
Subprog CALCUL_JOUR(DATCTL,UVYDAY,UVYCOD,SENS,LMSG)
Variable Date    DATCTL
Value    Libelle UVYDAY
Value    Char    UVYCOD
Value    Integer SENS
Variable Integer LMSG
#--------------------------------------------------------#
# Controle presence d'une date dans les jours d'indispo. #
#--------------------------------------------------------#
Local    Integer JCOUR, I
Local    Integer JOUR

If mkstat=2: End : Endif
mkstat=0
JCOUR=dayn(DATCTL)
I=0

$TR1
JOUR = UVYDAY(JCOUR-1)
If JOUR <> 1 : Goto TR2 : Endif
I+=1
If I > 7   : Goto TR2 : Endif
If SENS=0  : JCOUR+=1 : Else : JCOUR-=1 : Endif
If JCOUR=8 : JCOUR=1  : Endif
If JCOUR=0 : JCOUR=7  : Endif
Goto TR1

$TR2
If I <> 0
   If SENS=0 : DATCTL+=I : Else : DATCTL-=I : Endif
Endif
Call CTL_PERIODE(DATCTL,UVYCOD, LMSG)

End

########################################################################
Subprog CONTROL_JOUR(DATCTL,UVYDAY,UVYCOD,LMSG)
Variable Date    DATCTL
Value    Libelle UVYDAY
Value    Char    UVYCOD
Variable Integer LMSG
Local    Integer JCOUR
Local    Integer JOUR
Local    Char    LIBMES(80)
#--------------------------------------------------------#
# Controle presence d'une date dans les jours d'indispo. #
#--------------------------------------------------------#


If mkstat=2: End : Endif
mkstat=0
JCOUR=dayn(DATCTL)
JOUR=UVYDAY(JCOUR-1)
If JOUR=1
    LIBMES = sum (day$(DATCTL), mess(59,193,1))
    GMESSAGE = LIBMES
    mkstat= 2
    End
Endif
Call CTL_PERIODE(DATCTL,UVYCOD, LMSG)
End

########################################################################
Subprog CTL_PERIODE(DATCTL,UVYCOD, LMSG)
Variable Date    DATCTL
Value    Char    UVYCOD
Variable Integer LMSG
Local    Char    LIBMES(80), DATE1(10), DATE2(10)
Local    Integer  I
#-----------------------------------------------------------#
# Controle presence d'une date dans les periodes d'indispo. #
#-----------------------------------------------------------#


mkstat=0
If clalev([F:TUV])=0      : Local File TABUNAVAIL [TUV] : Endif
If  [F:TUV]UVYCOD<>UVYCOD : Read [F:TUV]UVY0=UVYCOD     : Endif
If fstat <> 0 : End : Endif

For I=0 To dim([F:TUV]UVYSTRDAT)-1
    If (DATCTL >= [F:TUV]UVYSTRDAT (I) & DATCTL <= [F:TUV]UVYENDDAT (I))
        mkstat=2
        If LMSG=1
            # FQ 59827 V6 "DD2" devient "D:"+GFMDAT4
            DATE1 = format$("D:"+GFMDAT4, [F:TUV]UVYSTRDAT(I))
            DATE2 = format$("D:"+GFMDAT4, [F:TUV]UVYENDDAT(I))
            LIBMES = sum (mess(1,192,1),mess(1,191,1),DATE1,mess(2,191,1),DATE2)
            GMESSAGE = LIBMES
            End
        Else : End : Endif
    Endif
Next
End

##################################################################
#----------------------------------------------------------------#
# Calcul d'une date OF (début ou fin) avec une date et un délai  #
#                        et ctrl jours et périodes indispo site  #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         LTI      : Délai                                       #
#         ORIFCY   : Site production                             #
#         SENCAL   : Sens de calcul date                         #
#         SENDEC   : Sens décalage si jours indisponibilité      #
# Sortie  DSTDAT   : Date destination                            #
#----------------------------------------------------------------#
Subprog CALCUL_DATE_OF(ORIDAT, LTI, ORIFCY, SENCAL, SENDEC, DSTDAT)
Value    Date     ORIDAT
Value    Integer  LTI
Value    Char     ORIFCY
Value    Integer  SENCAL
Value    Integer  SENDEC
Variable Date     DSTDAT
Local    Integer  UVYDAY (0..6)

Call LECTURE ("FCY", ORIFCY, "") From CONTOBJ
Call CALCUL_DATE(ORIDAT, LTI, [F:FCY]UVYDAY, [F:FCY]UVYCOD, SENCAL, SENDEC, DSTDAT)
End


##################################################################
#----------------------------------------------------------------#
# Contrôle d'une date OF (début ou fin)                          #
# par rapport au jours dispo site et période indispo.            #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         ORIFCY   : Site production                             #
#----------------------------------------------------------------#
Subprog CONTROL_DATE_OF(ORIDAT, ORIFCY)
Value    Date     ORIDAT
Value    Char     ORIFCY
Local    Integer  UVYDAY (0..6)

Call LECTURE ("FCY", ORIFCY, "") From CONTOBJ
Call CONTROL_DATE(ORIDAT,[F:FCY]UVYDAY, [F:FCY]UVYCOD)
End

#################################################################################
#-------------------------------------------------------------------------------#
# Calcul du délai de réappro                                                    #
# A partir de: délai article,lot, coefficient dégr, quantité                    #
#-------------------------------------------------------------------------------#
# Entrée  ORIDEL   : Délai origine                                              #
#         DSTDEL   : Délai calculé                                              #
# La classe [ITF] doit être chargée avant l'appel                               #
#-------------------------------------------------------------------------------#
# Formule utilisée:                                                             #
# [((100-coeff)/100)*délai]+[((coeff/100)*délai)*(qté lancée/qté tech)]         #
# Le premier groupe correspond au temps fixe, le second au temps variable.      #
# Le coefficient de dégressivité est donc le pourcentage de temps variable dans #
# le délai de fabrication                                                       #
#-------------------------------------------------------------------------------#
Subprog CALCUL_DELAI(ORIDEL, WEXTQTY, DSTDEL)
Value    Decimal     ORIDEL
Value    Decimal     WEXTQTY
Variable Decimal     DSTDEL
Local    Decimal     WDEL
Local    Decimal     WCOEF
Local    Decimal     WLOT
Local    Decimal     WGROUP1
Local    Decimal     WDELD

WDEL=[F:ITF]MFGLTI
WCOEF=[F:ITF]MIC
If [F:ITF]MFGLOTQTY <> 0
  WLOT=[F:ITF]MFGLOTQTY
Else
  WLOT = [F:ITF]REOMINQTY
Endif

#---------
# PE si GPE = 1 pas de calcul standard 11.04 25930
GPE = 0
GPOINT = "LTICAL"
Gosub  ENTREE From EXEFNC
If GPE : End : Endif
#---------

# si lot de réappro=0
If WLOT = 0 : DSTDEL=ORIDEL : End : Endif

# calcul partie fixe
WGROUP1 = (((100 - WCOEF) / 100) * WDEL )

# calcul coeff/100 * délai
WDELD   = (WCOEF/100) * WDEL

# application de la formule
WDEL    = WGROUP1 + (WDELD * (WEXTQTY / WLOT))

# arrondi 1 décimale
DSTDEL  = arr(WDEL,0.1)
#
End

#-------------------------------------------------------------------------------#
# Vérification et message si date < date courante                               #
# - Si LMSG=0, blocage et pas de message                                        #
# - Si LMSG=1, blocage et message                                               #
# - Si LMSG=2, message de mise en garde uniquement                              #
# - Si LMSG=3, message et aucun blocage                                         #
#-------------------------------------------------------------------------------#
Subprog CHECK_PAST(LDAT, LMSG)
Value Date    LDAT
Value Integer LMSG
#
If LDAT>=date$ : End : Endif
If LMSG=0 : mkstat=2 : End : Endif
If LMSG=1 : GMESSAGE=mess(60,193,1) : mkstat=2 : End : Endif
If LMSG=3 : GMESSAGE=mess(60,193,1) : End : Endif
If !GIMPORT : Infbox mess(60,193,1) : Endif                        # 65704
#
End

#-------------------------------------------------------------------------------#
# Contrôle filtre planificateur/approvisionneur                                 #
#-------------------------------------------------------------------------------#
Subprog CTLPLNFLT(LFCY, LART, LUSR)
Value    Char     LFCY
Value    Char     LART
Value    Char     LUSR

# si filtre non positionné on sort
If GPLNFLT < 2 : End : Endif

# lecture article site
If [F:ITF]ITMREF<>LART | [F:ITF]STOFCY<>LFCY
   Read [ITF] ITF0=LART;LFCY
   If fstat : GMESSAGE = mess(260,199,1) : End : Endif
Endif

Case GPLNFLT
    When 2:    If [F:ITF]PLANNER <> LUSR & [F:ITF]PLANNER <> ""
                   Call MSG_ERR_FLT ([F:ITF]PLANNER)
                   mkstat=2
                   End
               Endif
    When 3:    If [F:ITF]PLANNER <> LUSR
                   Call MSG_ERR_FLT ([F:ITF]PLANNER)
                   mkstat=2
                   End
               Endif
Endcase
End

#-------------------------------------------------------------------------------#
# Contrôle filtre planificateur/appro/acheteur                                  #
#-------------------------------------------------------------------------------#
Subprog CTLPLNACH(LFCY, LART, LUSR)
Value    Char     LFCY
Value    Char     LART
Value    Char     LUSR


# lecture article site
If [F:ITF]ITMREF<>LART | [F:ITF]STOFCY<>LFCY
   Read [ITF] ITF0=LART;LFCY
   If fstat : GMESSAGE = mess(260,199,1) : End : Endif
Endif

Case GPLNFLT
    When 1:    If GBUYFLT = 2 & ([F:ITF]BUY <> LUSR & [F:ITF]BUY <> "")        # llc 08.03 19139
                   Call MSG_ERR_FLT ([F:ITF]PLANNER)
                   mkstat=2
                   End
               Endif
    When 2:    If GBUYFLT < 2
                   If [F:ITF]PLANNER <> LUSR & [F:ITF]PLANNER <> ""
                       Call MSG_ERR_FLT ([F:ITF]PLANNER)
                       mkstat=2
                       End
                   Endif
               Else
                   If [F:ITF]PLANNER <> LUSR & [F:ITF]PLANNER <> "" & ([F:ITF]BUY <> LUSR & [F:ITF]BUY <> "")     # llc 08.03 19139
                       Call MSG_ERR_FLT ([F:ITF]PLANNER)
                       mkstat=2
                       End
                   Endif
               Endif
    When 3:    If GBUYFLT < 2
                   If [F:ITF]PLANNER <> LUSR
                       Call MSG_ERR_FLT ([F:ITF]PLANNER)
                       mkstat=2
                       End
                   Endif
               Else
                   # GH 24/08/11 bug 75840
                   # If [F:ITF]PLANNER <> LUSR & [F:ITF]BUY <> LUSR
                   If [F:ITF]PLANNER <> LUSR & ([F:ITF]BUY <> LUSR & [F:ITF]BUY <> "")
                       Call MSG_ERR_FLT ([F:ITF]PLANNER)
                       mkstat=2
                       End
                   Endif
               Endif
Endcase
End

#-------------------------------------------------------------------------------#
# Formatage message pour filtre planificateur                                   #
#-------------------------------------------------------------------------------#
Subprog MSG_ERR_FLT(LUSR)
Value    Char     LUSR

GMESSAGE = mess(61,193,1) : # Article non autorisé pour ce gestionnaire
End

#-------------------------------------------------------------------------------#
# Formatage information pour filtre planificateur                               #
#-------------------------------------------------------------------------------#
Subprog INF_ERR_FLT(LUSR)
Value    Char     LUSR

If clalev([F:AUS])<=0 Local File AUTILIS  [AUS] : Endif
Read [AUS] CODUSR=LUSR
If fstat
    GMESSAGE = sum (LUSR, mess(61,193,1))
Else
    GMESSAGE = sum (LUSR, " (", [F:AUS]NOMUSR, ")", mess(61,193,1))
Endif
End


#**----------------------------------------------------------------<br/>
#* CONTMATITM : Control of a component for WO/EO<br/>
#* (!!! [F:ITM] & [F:ITF] are read !!!)
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM = component
#* @param PFCY = site
#* @param PABR = Origin of the call (optional)
#* @param PRET(return) = error code (0=OK, 1=Error to correct before tracking, 3=Warning, 4=Error can't create WO/EO)
#* @param LMSG(return) = error message
#**<br/>----------------------------------------------------------------
#* Check also CONTMATITMECC in SCOLIB wich is quite similar !
#*!
Subprog CONTMATITM(PITM, PFCY, PABR, PRET, PMSG)
Value Char       PITM
Value Char       PFCY
Value Char       PABR
Variable Integer PRET
Variable Char    PMSG

Local Char LCTLFLG(10)
Local Integer VS
Local Integer LCTL

# Default value : error for all except the case where item is not managed in stock and item is a phantom
LCTLFLG="1111111110"
Case PABR
    When "MFMW": # Add unexpected material
        # Default but error if item is not managed in stock and item is a phantom
        # JAMCC - X3-63645 permit products with status "on shortage" and "in developemtn" to be selected
        # LCTLFLG="1111111111"
        LCTLFLG="1122111111"

    #Issue X3-38531 16/10/2017 by GEBIL : Item in shortage
    #Add case "MFG2" and open controls to only have warnings on components
    When "MFG2":
        # Ask question during tracking if item is "On development" or "In shortage"
        LCTLFLG="1133111110"

    #Issue 60754 18/01/2018 by GH : by consistency with bug 38531 correction
    When "MFM":
        LCTLFLG="1133111110"

    When "MKM":
        # Ask question during tracking if item is "On development" or "In shortage"
        LCTLFLG="1133111000"
Endcase
If find(PABR, "MFG2", "MFM", "MFMW") & GCMPUSBCTR=2
    # General parameter CMPUSBCTR doesn't allow creation of WO if status of component is "not usable"
    # => blocking error for this control
    # LCTLFLG = xxxxxxYxxx --> xxxxxx4xxx
    LCTLFLG=left$(LCTLFLG,6)+"4"+right$(LCTLFLG,8)
Endif

# Entry point to change controls
GPE = 0
GPOINT = "CTLITMSTA"
Gosub  ENTREE From EXEFNC

# 1 - ITM exists
If [F:ITM]ITMREF<>PITM
    Read [ITM]ITM0=PITM
    If fstat
        Raz [F:ITM]
        LCTL=val(mid$(LCTLFLG,1,1))
        If LCTL
           Call ADDMSG(PRET, PMSG, LCTL, mess(212,199,1)) From ECCLIB
        Endif
        If find(PRET,1,4) : End : Endif
    Endif
Endif

# 2 - ITF exists
If [F:ITF]ITMREF<>PITM | [F:ITF]STOFCY<>PFCY
    Read [ITF]ITF0=PITM;PFCY
    If fstat
       Raz [F:ITF]
       LCTL=val(mid$(LCTLFLG,1,1))
       If LCTL
          Call ADDMSG(PRET, PMSG, LCTL, mess(260,199,1)) From ECCLIB
       Endif
       If find(PRET,1,4) : End : Endif
    Endif
Endif

# 3- In development
# 4- On shortage
# 5- Not renewed
# 6- Obsolete
# 7- Not usable
If [F:ITM]ITMSTA>=2 & [F:ITM]ITMSTA<=6
    LCTL = val(mid$(LCTLFLG,[F:ITM]ITMSTA+1,1))
    If LCTL
        Call ADDMSG(PRET, PMSG, LCTL, mess(46,200,1)-":"-mess([F:ITM]ITMSTA,246,1)) From ECCLIB
    Endif
    If find(PRET,1,4) : End : Endif
Endif

# 8- control of categorie
LCTL = val(mid$(LCTLFLG,8,1))
If LCTL & [F:ITM]PURFLG <> 2 & [F:ITM]MFGFLG <> 2 & [F:ITM]SCPFLG <> 2
    Call ADDMSG(PRET, PMSG, LCTL, mess(65,193,1)) From ECCLIB
Endif
If find(PRET,1,4) : End : Endif

# 9/10- if component not managed in stock and ...
If !find([F:ITF]STOMGTCOD,2,3,4)
    If [F:ITM]PHAFLG <> 2
        # it's not a phantom
        LCTL = val(mid$(LCTLFLG,9,1))
        If LCTL
            Call ADDMSG(PRET, PMSG, LCTL, mess(147,199,1)) From ECCLIB
        Endif
    Else
        # it's a phantom
        LCTL = val(mid$(LCTLFLG,10,1))
        If LCTL
            Call ADDMSG(PRET, PMSG, LCTL, mess(147,199,1)) From ECCLIB
        Endif
    Endif
Endif
If find(PRET,1,4) : End : Endif

End

###############################################################################
# Routine de calcul quantité lien
# en paramètre pour ne pas relire n fois BOM/BOMD)
# LQTY       = quantité multiplicatrice
# LSTU       = Unité stock
# LBASQTY    = quantité de base
# LLIKQTYCOD = code quantité lien
# LLIKQTY    = quantité lien
# LQTYRND    = code arrondi
# LSCA       = pourcentage de perte
# LQTN  = quantité nette calculée sans arrondi
# LQTNA = quantité nette calculée arrondie
# LQTB  = quantité brute calculée sans arrondi (avec pertes)
# LQTBA = quantité brute ccalculée arrondie    (avec pertes)
###############################################################################
Subprog LIKQTY(LQTY,LSTU,LBASQTY,LLIKQTYCOD,LLIKQTY,LQTYRND,LSCA,LQTN,LQTNA,LQTB,LQTBA)
Variable Decimal LQTY
Variable Char    LSTU
Value    Decimal LBASQTY
Value    Integer LLIKQTYCOD
Value    Decimal LLIKQTY
Value    Integer LQTYRND
Value    Decimal LSCA
Variable Decimal LQTN
Variable Decimal LQTNA
Variable Decimal LQTB
Variable Decimal LQTBA
Local    Decimal WQTY, WBAS, WRKN0, WRKN1, WRKB0, WRKB1

# ouverture table des unités si nécessaire
If clalev([F:TUN]) = 0 Local File TABUNIT [TUN] : Endif

#
If LQTY = 0     : WQTY = 1 : Else  : WQTY = LQTY     : Endif
If LBASQTY = 0  : WBAS = 1 : Else  : WBAS = LBASQTY  : Endif
Raz LQTN, LQTNA, LQTB, LQTBA

# calcul quantité nette et avec pertes selon code forfait ou proportionnel
Case LLIKQTYCOD
  When 1 :
    LQTN = (LLIKQTY * WQTY)/ WBAS
    LQTB = ((LLIKQTY * WQTY)/ WBAS) * ((100 + LSCA)/100)
  When 2 :
    LQTN  =  LLIKQTY
    LQTNA =  LQTN
    LQTB  =  LLIKQTY * ((100 + LSCA) / 100)
    LQTBA =  LQTB
# <MG> 06/02/01
    If WQTY < 0
      LQTN  *= -1
      LQTNA *= -1
      LQTB  *= -1
      LQTBA *= -1
    Endif
Endcase

# calcul arrondi (lecture unité pour décimales)
LQTNA = LQTN
LQTBA = LQTB

# llc 01.01 correction (test par rapport à 0.5 et pas 5 !!)
Read [TUN]TUN0=LSTU
If !fstat
    WRKN0 =  LQTN*10^[F:TUN]UOMDEC
    WRKN1 = (LQTN*10^[F:TUN]UOMDEC - int(WRKN0))
    WRKB0 =  LQTB*10^[F:TUN]UOMDEC
    WRKB1 = (LQTB*10^[F:TUN]UOMDEC - int(WRKB0))
    Case LQTYRND
      When 1 :
        If WRKN1 < 0.5
          LQTNA = (WRKN0 - WRKN1)*10^-[F:TUN]UOMDEC
        Else
          LQTNA = (WRKN0 - WRKN1 + 1)*10^-[F:TUN]UOMDEC
        Endif
        If WRKB1 < 0.5
          LQTBA = (WRKB0 - WRKB1)*10^-[F:TUN]UOMDEC
        Else
          LQTBA = (WRKB0 - WRKB1 + 1)*10^-[F:TUN]UOMDEC
        Endif
      When 2 :   # (supérieur) 2 et 3 étaient inversés         (TB 04/10/2000)
        If WRKN1 <> 0
            LQTNA = (WRKN0 - WRKN1 + 1)*10^-[F:TUN]UOMDEC
        Else
            LQTNA = (WRKN0 - WRKN1)*10^-[F:TUN]UOMDEC
        Endif
        If WRKB1 <> 0
            LQTBA = (WRKB0 - WRKB1 + 1)*10^-[F:TUN]UOMDEC
        Else
            LQTBA = (WRKB0 - WRKB1)*10^-[F:TUN]UOMDEC
        Endif
      When 3 :
        LQTNA = (WRKN0 - WRKN1)*10^-[F:TUN]UOMDEC
        LQTBA = (WRKB0 - WRKB1)*10^-[F:TUN]UOMDEC
    Endcase
Endif
End

#########################################################################
# Recherche d'un coefficient de conversion entre deux unités            #
#                                                                       #
#-----------------------------------------------------------------------#
Subprog RECH_COEFF(LUOM1, LUOM2, LCOEFF)
Value     Char     LUOM1
Value     Char     LUOM2
Variable  Decimal  LCOEFF
#
If LUOM1 = LUOM2 : LCOEFF = 1 : End : Endif
#
If clalev ([TCO])=0 : Local File TABCOEFF [TCO] : Endif
Read [TCO]TCO0=LUOM1;LUOM2
If fstat
    LCOEFF = 0
Else
    LCOEFF = [F:TCO]COEUOM
Endif
#
End

#######################################################################
# Sous programme de sélection d'une pièce d'origine
# LTYP = type de pièce
# LSTA = statut
# LITM = article
# LWIP = encours sélectionné
# LVCR = n° piece                 llc 02.02 12863
# LC1,LC2 = critères pré-renseignés sur types et statuts
#######################################################################
Subprog SELVCR(LTYP, LFCY, LSTA, LITM, LWIP, LVCR, LC1, LC2)
Variable Integer LTYP
Value    Char    LFCY
Value    Integer LSTA()
Variable Char    LITM
Variable Char    LWIP
Value    Char    LVCR
Value    Char    LC1()
Value    Char    LC2()
Local    Integer I,J
Local    Date    TODAY : TODAY = date$
#
Local    Char    CRITERE(255)
Local    Char    WINT(20)(9)
#
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
#
Call TEXTFIC("ORDERS","WIPTYP",1,WINT(0))        From OBJDIV
Call TEXTFIC("ORDERS","VCRNUM",1,WINT(1))        From OBJDIV
Call TEXTFIC("ORDERS","ORIFCY",1,WINT(2))        From OBJDIV
Call TEXTFIC("ORDERS","STOFCY",1,WINT(3))        From OBJDIV
Call TEXTFIC("ORDERS","ITMREF",1,WINT(4))        From OBJDIV
Call TEXTFIC("ORDERS","ENDDAT",1,WINT(5))        From OBJDIV
Call TEXTFIC("ORDERS","RMNEXTQTY",1,WINT(6))     From OBJDIV
Call TEXTFIC("ORDERS","BPRNUM",1,WINT(7))        From OBJDIV
Call TEXTFIC("ORDERS","WIPNUM",1,WINT(8))        From OBJDIV
#
# Filtre
If LC1 = ""
    If LTYP <> 0
        CRITERE = "[F:ORD]WIPTYP = LTYP"
    Else
        CRITERE  = "1=1"
    Endif
    If LSTA(0) <> 0
        CRITERE += "& ("
        For I=0 To dim(LSTA)-1
            If LSTA(I) = 0 : Break : Endif
            If I <> 0
                CRITERE += "|"
            Endif
            J = LSTA(I)
            Case J
                When 1:  CRITERE += "[F:ORD]WIPSTA = 1"
                When 2:  CRITERE += "[F:ORD]WIPSTA = 2"
                When 3:  CRITERE += "[F:ORD]WIPSTA = 3"
            Endcase
        Next I
        CRITERE += ")"
    Endif
Else
    CRITERE  = "1=1"
Endif


If LFCY <> ""
    CRITERE += " & [F:ORD]STOFCY = LFCY"
Endif

If LITM <> ""
    CRITERE += " & [F:ORD]ITMREF = LITM"
Endif

# llc 02.02 12863
If LVCR <> ""
    CRITERE += " & [F:ORD]VCRNUM >= LVCR"
Endif

#
# llc 04.02 14054 Performances
If LC1 = ""
    Filter [ORD] Where evalue(CRITERE)
&                          Order By Key CLE=ENDDAT
Else
    If LC2 = ""
        Filter [ORD] Where evalue(LC1)&evalue(CRITERE)
&                              Order By Key CLE=ENDDAT
    Else
        Filter [ORD] Where (evalue(LC1)|evalue(LC2))&evalue(CRITERE)
&                              Order By Key CLE=ENDDAT
    Endif
Endif

Choose [ORD]
&  Using  mess([F:ORD]WIPTYP,341,1) + mess([F:ORD]WIPSTA,342,1)  Titled WINT(0),
&         [F:ORD]VCRNUM          Titled WINT(1),
&         [F:ORD]ORIFCY          Titled WINT(2),
&         [F:ORD]STOFCY          Titled WINT(3),
&         [F:ORD]ITMREF          Titled WINT(4),
&         [F:ORD]ENDDAT          Titled WINT(5),
&         num$([F:ORD]RMNEXTQTY) Titled WINT(6),
&         [F:ORD]BPRNUM          Titled WINT(7),
&         [F:ORD]WIPNUM          Titled WINT(8),
&         [F:ORD]WIPTYP          Titled WINT(0)
&  Sized(80,250)
&  Titled mess(36,198,1)
#
If find (status,0,7)
   Filter [ORD]
   End
Else
   LTYP = [F:ORD]WIPTYP
   LWIP = [F:ORD]WIPNUM
   LITM = [F:ORD]ITMREF
Endif
Filter [ORD]
End

##################################################################
#Lecture avec creation eventuelle cumuls stock article sans lock !
# idem STKLIB mais sans lock
# lecture ITMMASTER ITMFACILIT ITMCATEG
##################################################################

Subprog LECITV2(LFCY,LITM,LRET)
Variable Char    LFCY
Variable Char    LITM
Variable Integer LRET

If clalev([F:ITG])<=0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif

LRET = 0
If LFCY = "" : LRET = 3 : End : Endif
If LITM = "" : LRET = 4 : End : Endif
#
LRET = 0
$LECITV20

# FQ 60012 & 61051 GA 12/2009 déplacé ici pour ne pas ecrire [F:ITV] si [F:ITF] inexistant

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> LFCY| [F:ITF]ITMREF <> LITM
   Read [ITF]ITF0 = LITM;LFCY
   If fstat : Raz [F:ITF] : LRET = 1 : End : Endif
Endif

Read [ITV]ITV0=LITM;LFCY
If fstat= 4 | fstat = 5
     Local Integer TRANS
     TRANS = adxlog
     If !TRANS : # Issue 119469 GH 04/11/16 - transaction management if necessary
        Trbegin [ITV]
     Endif
     Raz [F:ITV]
     [F:ITV]ITMREF = LITM
     [F:ITV]STOFCY = LFCY
     [F:ITV]CREDAT = date$
     [F:ITV]CREUSR = GUSER
     [F:ITV]EXPNUM = [C]EXPORT
     Write [ITV]
     If fstat
        GOK = 0 : Call FSTA("ITV") From GLOCK
        LRET = 1    # Issue 72149
     Endif
     If !TRANS
        If !LRET : Commit : Else Rollback : Endif
     Endif
     If LRET : End : Endif
     # Issue 72149 - 2011-03-08 by CCC : LRET doit être alimenté à 1 en cas d'erreur uniquement
     #LRET = 1
     # FQ 48988 GA 10/2008 la relecture ne servait qu'avec le lock
     # Goto LECITV20
Endif
#If fstat = 1 : LRET = 2 : End : Endif

# lecture ITMMASTER
If [F:ITM]ITMREF <>  LITM
   Read [F:ITM]ITM0 = LITM
   If fstat : Raz [F:ITM] : LRET = 1 : End : Endif
Endif

# lecture ITMCATEG
If [F:ITG]TCLCOD<>[F:ITM]TCLCOD
   Read [ITG]ITG0=LFCY;[F:ITM]TCLCOD
   If fstat
      Read [ITG]ITG1=[F:ITM]TCLCOD;""
      If fstat : Raz [F:ITG] : LRET = 1 : Endif
   Endif
Endif

End

#######################################################################
# Sous programme de sélection d'une pièce dans historique PEC
# LTYP = type de pièce
# LFCY = site de stockage
# LITM = article
# LWIP = encours sélectionné
#######################################################################
Subprog SELCOV(LTYP, LFCY, LITM, LVCR, LLIN, LSEQ, LSTA)
Value    Integer LTYP
Value    Char    LFCY
Variable Char    LITM
Variable Char    LVCR
Variable Integer LLIN
Variable Integer LSEQ
Variable Integer LSTA

#
Local    Char    CRITERE(255)
Local    Char    WINT(25)(9)
#
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ORC]) = 0 : Local File ORDCOV     [ORC] : Endif
#
Call TEXTFIC("ORDCOV","STOFCY",2,WINT(0))        From OBJDIV
Call TEXTFIC("ORDCOV","VCRTYP",2,WINT(1))        From OBJDIV
Call TEXTFIC("MFGHEAD","MFGSTA",2,WINT(2))       From OBJDIV
Call TEXTFIC("ORDCOV","VCRNUM",2,WINT(3))        From OBJDIV
Call TEXTFIC("ORDCOV","VCRLIN",2,WINT(4))        From OBJDIV
Call TEXTFIC("ORDCOV","VCRSEQ",2,WINT(5))        From OBJDIV
#
# Filtre
Case LTYP
    When 10,14:   CRITERE  = "[F:ORC]VCRTYPDST = LTYP"
    When Default: CRITERE  = "[F:ORC]VCRTYP = LTYP"
Endcase
If LFCY <> ""
    CRITERE += " & [F:ORC]STOFCY = LFCY"
Endif

If LITM <> ""
    CRITERE += " & [F:ORC]ITMREF = LITM"
Endif

#
Filter [ORC] Where evalue(CRITERE)


Case LTYP
    When 10,14:
        Choose [ORC]
&           Order By Key ORC0(5) Desc
&           Using  [F:ORC]STOFCY                      Titled WINT(0),
&                  mess([F:ORC]VCRTYPDST,701,1)       Titled WINT(1),
&                  mess([F:ORC]WIPSTADST,317,1)       Titled WINT(2),
&                  [F:ORC]VCRNUMDST                   Titled WINT(3),
&                  [F:ORC]VCRLINDST                   Titled WINT(4),
&                  [F:ORC]VCRSEQDST                   Titled WINT(5),
&                  [F:ORC]WIPSTADST                   Titled WINT(6)
&           Sized(100,233)
&           Titled mess(36,198,1)
    When Default:
        # Issue 105608 - 2015-01-20 by CCC : before "ORC0(5)"
        Choose [ORC]
&           Order By Key ORC1(4) Desc
&           Using  [F:ORC]STOFCY                      Titled WINT(0),
&                  mess([F:ORC]VCRTYP,701,1)          Titled WINT(1),
&                  mess([F:ORC]WIPSTA,317,1)          Titled WINT(2),
&                  [F:ORC]VCRNUM                      Titled WINT(3),
&                  [F:ORC]VCRLIN                      Titled WINT(4),
&                  [F:ORC]VCRSEQ                      Titled WINT(5),
&                  [F:ORC]WIPSTA                      Titled WINT(6)
&           Sized(100,233)
&           Titled mess(36,198,1)
Endcase

Filter [ORC]
#
LVCR = ""
LLIN = 0
LSEQ = 0
If find(status,0,7)
   End
Else
   Case LTYP
       When 10,14:
           LVCR = [F:ORC]VCRNUMDST
           LLIN = [F:ORC]VCRLINDST
           LSEQ = [F:ORC]VCRSEQDST
           LITM = [F:ORC]ITMREF
           LSTA = [F:ORC]WIPSTADST
       When Default:
           LVCR = [F:ORC]VCRNUM
           LLIN = [F:ORC]VCRLIN
           LSEQ = [F:ORC]VCRSEQ
           LITM = [F:ORC]ITMREF
           LSTA = [F:ORC]WIPSTA
   Endcase
Endif
End


##################################################################
#----------------------------------------------------------------#
# Calcul d'une date OF (début ou fin) avec une date et un délai  #
# basé sur indisponibilités et schéma de planification           #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         LTI      : Délai                                       #
#         ORIFCY   : Site production                             #
#         SENCAL   : Sens de calcul date                         #
# Sortie  DSTDAT   : Date destination                            #
#----------------------------------------------------------------#
Subprog CALCUL_DATE_PLN(ORIDAT, LTI, ORIFCY, SENCAL, DSTDAT)
Value    Date     ORIDAT
Value    Integer  LTI
Value    Char     ORIFCY
Value    Integer  SENCAL
Variable Date     DSTDAT

Local    Date     WDATREF
Local    Char     WTWD(GLONTWD)     : WTWD     = GPLNTWD
Local    Integer  I, J, K, IDISP

If clalev([F:TUV]) = 0      : Local File TABUNAVAIL [TUV] : Endif
If clalev([F:TWD]) = 0      : Local File TABWEEDIA  [TWD] : Endif

Call LECTURE ("FCY", ORIFCY, "") From CONTOBJ

# lecture indisponibilités
If  [F:TUV]UVYCOD <> [F:FCY]UVYCOD : Read [F:TUV]UVY0=[F:FCY]UVYCOD     : Endif
If fstat <> 0 : Raz [F:TUV] : Endif

# lecture schéma de référence
If  [F:TWD]TWD <> WTWD : Read [F:TWD]TWD0=WTWD     : Endif
If fstat <> 0 : End : Endif

# GA 04/2008
If ORIDAT=[0/0/0] : DSTDAT=ORIDAT : End : Endif

I       = LTI
WDATREF = ORIDAT

# calcul
While (I > 0)
    Case SENCAL
        When 0: WDATREF += 1
        When 1: WDATREF -= 1
    Endcase

    J = dayn(WDATREF) - 1

    # si capacité non nulle pour le jour
    If [F:TWD]DAYCAP(J) <> 0
        IDISP = 1

        If [F:TUV]UVYNBR <> 0
            # indisponibilité ?
            For K = 0 To [F:TUV]UVYNBR - 1
                If WDATREF >= [F:TUV]UVYSTRDAT(K) & WDATREF <= [F:TUV]UVYENDDAT(K)
                    IDISP = 0
                    Break
                Endif
            Next
        Endif

        # jour OK, décrémentation du délai à appliquer
        If IDISP : I -= 1 : Endif
    Endif
Wend
DSTDAT = WDATREF
End

########################################################################
#----------------------------------------------------------------------#
# Controle d'une date                                                  #
# basé sur indisponibilités et schéma de planification                 #
#----------------------------------------------------------------------#
########################################################################
Subprog CONTROL_DATE_PLN(DATCTL, ORIFCY)
Variable Date    DATCTL
Value    Char    ORIFCY

Local    Char    WTWD(GLONTWD) : WTWD     = GPLNTWD
Local    Integer IDISP, J, K
Local    Char    DATE1(10), DATE2(10)

If clalev([F:TUV]) = 0      : Local File TABUNAVAIL [TUV] : Endif
If clalev([F:TWD]) = 0      : Local File TABWEEDIA  [TWD] : Endif

Call LECTURE ("FCY", ORIFCY, "") From CONTOBJ

# lecture indisponibilités
If  [F:TUV]UVYCOD <> [F:FCY]UVYCOD : Read [F:TUV]UVY0=[F:FCY]UVYCOD     : Endif
If fstat <> 0 : Raz [TUV] : Endif

# lecture schéma de référence
If  [F:TWD]TWD <> WTWD : Read [F:TWD]TWD0=WTWD     : Endif
If fstat <> 0 : End : Endif

mkstat = 0

J = dayn(DATCTL) - 1

# si capacité non nulle pour le jour
If [F:TWD]DAYCAP(J) <> 0
    IDISP = 1
    If [F:TUV]UVYNBR > 0
        # indisponibilité ?
        For K = 0 To [F:TUV]UVYNBR - 1
            If DATCTL >= [F:TUV]UVYSTRDAT(K) & DATCTL <= [F:TUV]UVYENDDAT(K)
              # FQ 59827 V6 "DD2" devient "D:"+GFMDAT4
                DATE1 = format$("D:"+GFMDAT4, [F:TUV]UVYSTRDAT(K))
                DATE2 = format$("D:"+GFMDAT4, [F:TUV]UVYENDDAT(K))
                GMESSAGE = sum (mess(1,192,1),mess(1,191,1),DATE1,mess(2,191,1),DATE2)
                IDISP = 0
                Break
            Endif
        Next
    Endif
Else
    GMESSAGE = sum (day$(DATCTL), mess(59,193,1))
    IDISP    = 0
Endif

If !IDISP
    mkstat= 2
    End
Endif

End

#########################################################################
# (llc 08.00 v130) nouvelle gestion des capacités pour planif
# Chargement capacité
#   LTWD  : Numéro schéma hebdomadaire
#   LDATD : Date début (borne incluse)
#   LDATF : Date fin   (borne incluse)
#   LCAP  : Tableau des capacités en retour (heures)
#   LRET  : code retour
#   les classes FCY, TUV doivent être en ligne !
#   la table  TWD ouverte !
Subprog LOACAPPLN(LTWD, LDATD,LDATF,LCAP,LRET)
#
Value    Char    LTWD
Value    Date    LDATD
Value    Date    LDATF
Variable Decimal LCAP()
Variable Integer LRET
#
Local    Integer I, J, K, L,  IDISP
Local    Date WDATD : WDATD = LDATD
Local    Date WDATF : WDATF = LDATF
Local    Decimal  WTOT
#
Raz LCAP, LRET, I, WTOT
If WDATD = [0/0/0] | WDATF = [0/0/0] | WDATF < WDATD
  LRET = 1
  End
Endif

# lecture schéma de référence
If  [F:TWD]TWD <> LTWD : Read [F:TWD]TWD0=LTWD     : Endif
If fstat <> 0 : LRET = 1 : End : Endif

I = 0
While ((WDATD <= WDATF) & (I < dim(LCAP) -1))
    J = dayn(WDATD) - 1
    # si capacité non nulle pour le jour
    If [F:TWD]DAYCAP(J) <> 0
        IDISP = 1
        # indisponibilité ?
        If [F:TUV]UVYNBR > 0
            For L = 0 To [F:TUV]UVYNBR - 1
                If [F:TUV]UVYSTRDAT(L) > WDATD : Break : Endif
                If WDATD >= [F:TUV]UVYSTRDAT(L) & WDATD <= [F:TUV]UVYENDDAT(L)
                    LCAP(I) = 0
                    IDISP   = 0
                    Break
                Endif
            Next
        Endif
        If IDISP = 1
            LCAP(I) = [F:TWD]DAYCAP(J) / [F:TWD]DAYCAPNOM
        Endif
    Else
        LCAP(I) = 0
    Endif
$L_CAP
    WTOT  += LCAP(I)
    WDATD += 1
    I     += 1
Wend

If WTOT = 0 : LRET = 1 : Endif

End

#########################################################################
# Vérification encours inchangé     llc 02.01
#   LTYP  : Type encours
#   LITM  : Article
#   LNUM  : Numéro
#   LQAV  : Quantité restante avant
#   LQAP  : Quantité restante après
#   LRET  : Code retour    (0 = OK, 1 = quantité <>,  9 = encours inexistant)
Subprog CHECK_WIP(LTYP, LITM, LNUM, LQAV, LQAP, LRET)
Value     Integer LTYP
Value     Char    LITM
Value     Char    LNUM
Value     Decimal LQAV
Variable  Decimal LQAP
Variable  Integer LRET

LRET = 0

Read [ORD]ORD0=LTYP;LNUM;LITM
If fstat : LRET = 9 : End : Endif

LQAP = [F:ORD]RMNEXTQTY
If LQAP <> LQAV : LRET = 1 : Endif

End

#######################################################################
# Sous programme de sélection d'une gamme
# Lfcy = site
# LITM = article
# LALT = alternative
#######################################################################
Subprog SELROU(LFCY, LITM, LALT)
Value    Char       LFCY
Variable Char       LITM
Variable Integer    LALT

Local    Char    CRITERE(255)
Local    Char    WINT(20)(9)

If clalev ([F:ATZ]) <= 0 : Local File ATABZON    [ATZ] : Endif
If clalev ([F:ROHS])<= 0 : Local File ROUTING    [ROHS]: Endif
If clalev([F:AXX])<= 0   : Local File ATEXTRA    [AXX] : Endif  # FGR 02/10/2009 : X3SUIVI58337

Call TEXTFIC("ROUTING","ITMREF",2,WINT(0))       From OBJDIV
Call TEXTFIC("ROUTING","ROUALT",2,WINT(1))       From OBJDIV
# FGR 02/10/2009 : X3SUIVI58337
#Call TEXTFIC("ROUTING","ROUDES",2,WINT(2))       From OBJDIV
Call TEXTFIC("ROUTING","ROUDESAXX",2,WINT(2))       From OBJDIV

CRITERE = "[F:ROHS]FCY = LFCY & [F:ROHS]ITMREF >= LITM"
If LALT <> 0 : CRITERE += "& [F:ROHS]ROUALT >= LALT" : Endif

Filter [ROHS] Where evalue(CRITERE)
&            Order By Key ROH0

$R_CHOOSE
# FGR 02/10/2009 : X3SUIVI58337 (début)
#Choose [ROHS]
#&  Using  [F:ROHS]ITMREF          Titled WINT(0),
#&         [F:ROHS]ROUALT          Titled WINT(1),
#&         [F:ROHS]ROUDES          Titled WINT(2)
#&  Sized(100,333)
#&  Titled mess(36,198,1)
Link [ROHS] With [AXX]AXX0="ROUTING";"ROUDESAXX";GLANGUE;[F:ROHS]IDENT1;[F:ROHS]FCY As [LNK]
Choose [LNK]
&  Using  [F:ROHS]ITMREF          Titled WINT(0),
&         [F:ROHS]ROUALT          Titled WINT(1),
&         [F:AXX]TEXTE            Titled WINT(2)
&  Sized(100,333)
&  Titled mess(36,198,1)
# FGR 02/10/2009 : X3SUIVI58337 (fin)
#
If find (status,0,7)
   End
Else
   LITM = [F:ROHS]ITMREF
   LALT = [F:ROHS]ROUALT
Endif
End


