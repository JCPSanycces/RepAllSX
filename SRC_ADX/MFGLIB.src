End

############################################################################################
Subprog UPDATE_MFGTRKFLG(LMFGNUM, LRET)
Value     Char     LMFGNUM
Variable  Integer  LRET
Local     Date     TODAY
Local     Integer  WWIP
Local     Integer  WPRN
TODAY = date$

LRET = 0

Gosub OPEN_FILES_MFG From MFGLIB

# Issue 78667 GA & CCC 03/2012 tjs pb sur les boucles For
If clalev([F:MFGW]) = 0 : Local File MFGHEAD    [MFGW] : Endif  # ordre de fabrication
If clalev([F:MFIW]) = 0 : Local File MFGITM     [MFIW] : Endif  # articles lancés
If clalev([F:MFMW]) = 0 : Local File MFGMAT     [MFMW] : Endif  # matières OF
If clalev([F:MFOW]) = 0 : Local File MFGOPE     [MFOW] : Endif  # opérations OF
If clalev([F:MFPW]) = 0 : Local File MFGPRN     [MFPW] : Endif  # Documents de fabrication
If clalev([F:MTKW]) = 0 : Local File MFGHEADTRK [MTKW] : Endif  # suivi de fabrication

Readlock [MFGW]MFG0 = LMFGNUM
If fstat : LRET = 1 : Endif

WWIP = 0
WPRN = 0
# analyse de l'état d'avancement OF
For [MFIW]MFI0 Where MFGNUM = LMFGNUM
    If [F:MFIW]ITMSTA > 1 : WWIP += 1 : Endif
Next
For [MFMW]MFM0 Where MFGNUM = LMFGNUM
    If [F:MFMW]MATSTA > 1 & [F:MFMW]MATSTA <> 4 : WWIP += 1 : Endif
Next
For [MFOW]MFO0 Where MFGNUM = LMFGNUM
    # Issue 77589 - 2011-11-17 by CCC : Opération "Commandée" ne veut pas dire "En cours"
    #If [F:MFO]OPESTA > 3 & [F:MFO]OPESTA <> 6 : WWIP += 1 : Endif
    If [F:MFOW]OPESTA > 3 & !find([F:MFOW]OPESTA,6,7) : WWIP += 1 : Endif
Next
# attention il peut ne rester qu'un suivi sur matière ajoutée (au suivi)
For [MTKW]MTK1 Where MFGNUM = LMFGNUM
    WWIP += 1
    Break
Next

Read [MFPW]MFP0=LMFGNUM
If fstat : LRET = 1 : End : Endif
If [F:MFPW]MFGFDRFLG = 2 : WPRN += 1 : Endif

If WWIP <> 0
    [F:MFGW]MFGTRKFLG = 4         # OF toujours en cours
Else
    If WPRN <> 0
        [F:MFGW]MFGTRKFLG =  3    # OF édité
    Else
        [F:MFGW]MFGTRKFLG =  1    # OF en attente
    Endif
Endif

[F:MFGW]UPDUSR    = GUSER
[F:MFGW]UPDDAT    = TODAY
[F:MFGW]EXPNUM    = [C]EXPORT

Rewrite [MFGW]
If fstat : LRET = 1 : Endif

# CCC  : 02/03/12 : bug 78667 reproduit => nlle correction
Close Local File [MFIW],[MFMW],[MFOW],[MFGW],[MTKW],[MFPW]

End

########################################################################
Funprog CTRL_ALLMGT()             # extrait de TEST_DOSSIER de SUBMFGA/MTKLIB
Local Integer WOK : WOK=0
Local Integer WRET : WRET=0
Local Char    XMESS(110)
Gosub OPEN_FILES_MFG

# statut = ferme
If [F:MFG]MFGNUM="" | [F:MFG]MFGSTA <> 1 : End WOK : Endif

# l'ordre est-il alloué au moins en global(si OF non opé seules et selon GMTKALLMGT)
If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
   Call ALLOC_OF("C", 0, [F:MFG]MFGNUM, 1, 1, WRET ) From MFGALL
   If WRET <> 0
      # Ordre de fabrication XXXX : Allocation incomplète. Suivi impossible
      XMESS = mess(467,197,1)-[F:MFG]MFGNUM-":"-mess(18,190,1)
      Call MESSAGE(XMESS) From GESECRAN
      End WOK
   Endif
Endif
#
If clalev([F:MFMW]) = 0 : Local File MFGMAT     [MFMW] : Endif  # matières OF
# boucle d'analyse des matières bloquantes si rupture
For [MFMW] Where MFGNUM = [F:MFG]MFGNUM & MATSTA<>4
    If [F:MFMW]SHTQTY <> 0
        Read [ITF]ITF0=[F:MFMW]ITMREF;[F:MFMW]MFGFCY
        If fstat : WOK=-1 : Break : Endif   # FQ 69909 Ctrl des sources avant End WOK
        If [F:ITF]MFGSHTCOD = 1
            XMESS = mess(157,193,1)+" ("+[F:MFMW]ITMREF+"/"+[F:MFMW]MFGFCY+")"
            Call MESSAGE(XMESS) From GESECRAN
            WOK=-1 : Break                  # FQ 69909 Ctrl des sources avant End WOK
        Endif
    Endif
Next
If WOK=-1 WOK=0 : End WOK : Endif           # FQ 69909 Ctrl des sources Ligne ajoutée
WOK = 1
End WOK

###############################################
Subprog OPEN_FILES
###############################################
If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif  # ordre de fabrication
If clalev([F:MFI]) = 0 : Local File MFGITM     [MFI] : Endif  # articles lancés
If clalev([F:MFM]) = 0 : Local File MFGMAT     [MFM] : Endif  # matières OF
If clalev([F:MFO]) = 0 : Local File MFGOPE     [MFO] : Endif  # opérations OF
If clalev([F:MFP]) = 0 : Local File MFGPRN     [MFP] : Endif  # Documents de fabrication
#
If clalev([F:MTK]) = 0 : Local File MFGHEADTRK [MTK] : Endif  # suivi de fabrication
If clalev([F:MKO]) = 0 : Local File MFGOPETRK  [MKO] : Endif  # suivi opérations OF
If clalev([F:MKI]) = 0 : Local File MFGITMTRK  [MKI] : Endif  # suivi article
If clalev([F:MKM]) = 0 : Local File MFGMATTRK  [MKM] : Endif  # suivi composants OF
#
If clalev([F:MTS]) = 0 : Local File MFGTRS     [MTS] : Endif  # transactions saisie OF
If clalev([F:OPS]) = 0 : Local File OPERATIONS [OPS] : Endif
If clalev([F:SCH]) = 0 : Local File SCHEDULING [SCH] : Endif
If clalev([F:PJA]) = 0 : Local File PARJAL     [PJA] : Endif  # paramètres jalonnement
If clalev([F:MWS]) = 0 : Local File WORKSTATIO [MWS] : Endif  # poste de charge
If filinfo(filpath("FIL","CPTANALIN","fde",nomap),0)>0
   If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
Endif
End

###############################################
$OPEN_FILES_MFG
###############################################
If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif  # ordre de fabrication
If clalev([F:MFI]) = 0 : Local File MFGITM     [MFI] : Endif  # articles lancés
If clalev([F:MFM]) = 0 : Local File MFGMAT     [MFM] : Endif  # matières OF
If clalev([F:MFO]) = 0 : Local File MFGOPE     [MFO] : Endif  # opérations OF
If clalev([F:MFP]) = 0 : Local File MFGPRN     [MFP] : Endif  # Documents de fabrication
#
If clalev([F:MTK]) = 0 : Local File MFGHEADTRK [MTK] : Endif  # suivi de fabrication
If clalev([F:MKO]) = 0 : Local File MFGOPETRK  [MKO] : Endif  # suivi opérations OF
If clalev([F:MKI]) = 0 : Local File MFGITMTRK  [MKI] : Endif  # suivi article
If clalev([F:MKM]) = 0 : Local File MFGMATTRK  [MKM] : Endif  # suivi composants OF
#
If clalev([F:MTS]) = 0 : Local File MFGTRS     [MTS] : Endif  # transactions saisie OF
If clalev([F:OPS]) = 0 : Local File OPERATIONS [OPS] : Endif
If clalev([F:SCH]) = 0 : Local File SCHEDULING [SCH] : Endif
If clalev([F:PJA]) = 0 : Local File PARJAL     [PJA] : Endif  # paramètres jalonnement
If clalev([F:MWS]) = 0 : Local File WORKSTATIO [MWS] : Endif  # poste de charge
If filinfo(filpath("FIL","CPTANALIN","fde",nomap),0)>0
   If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
Endif
Return
###############################################################
# CHKMFGLOCK : Vérifie si un OF est déjà locké
###############################################################
# Paramètres E : PMFGNUM = N° d'OF
#                PLOCK   = mettre à 1 pour locker l'OF sinon 0
###############################################################
Funprog CHKMFGLOCK(PMFGNUM, PLOCK)
Value Char PMFGNUM
Value Integer PLOCK
If PMFGNUM="" : End 0 : Endif
If PLOCK
    Lock ="MFG"+PMFGNUM
    If fstat
        End 1
    Endif
Else
# Issue 90272 - 2013-06-13 by CCC : Vérif lock et session en cours
#    # Ne pas utiliser "Unlock" car on ne sait pas d'où on vient
#    If !clalev([F:ALK]) : Local File =adxtlk [ALK] : Endif
#    Filter [ALK] Where LCKSYM="MFG"+PMFGNUM
#&                    & LCKPID<>adxuid(2)
#    Look [ALK] First
#    Filter [ALK]
#    If !fstat
#        End 1
#    Endif

# GH 25/08/2014 bug 102207 il ne faut pas travailler sur la racine du symbole
#    Call VERFLOCK("MFG"+PMFGNUM) From GLOCKM
#    If GLOCK<>""
#        End 1
#    Else
#        End 0
#    Endif

  GLOCK=""
  Local File =adxtlk [ALK]
  For [ALK] Where LCKSYM="MFG"+PMFGNUM & LCKPID<>adxuid(2)
   If dim([L]NBUSR)<0
    Local Integer NBUSR
    Local Char SID(12) , SCLI(80) , SUSR(30) , SUID(12) , TBUSR(12)(1..2000) , PROCESS(20)
    Local File (SID,SCLI,SUSR,SUID) From System adxmac(0)+"@psadx -ig" As [SYS_]
    NBUSR = 0
    For [SYS_]
     NBUSR += 1 : TBUSR(NBUSR) = [F:SYS_]SUID
    Next SYS_
    Close Local File [SYS_]
   Endif
   PROCESS = num$([F:ALK]LCKPID)
   If sigma(1,NBUSR,TBUSR(indcum)=PROCESS)
      GLOCK="%"+[F:ALK]LCKSYM : Break
   Endif
  Next
  If GLOCK<>""
     End 1
  Endif
Endif
End 0

#-----------------------------------------------------------------------#
# Mise à jour de l'entete OF                      # FQ 70409 GA 01/2011 #
#-----------------------------------------------------------------------#
$MAJMFGHEAD                               # idem MAJSCOHEAD dans SCOLIB #
  Gosub OPEN_FILES_MFG

# Issue 78667 suite GA 15/03/2012 tjs pb sur les boucles For
# CCC  : 02/03/12 : bug 78667 reproduit => nlle correction
#Local File MFGITM     [MFI]
#Local File MFGMAT     [MFM]
#Local File MFGOPE     [MFO]
If clalev([F:MFIW]) = 0 : Local File MFGITM     [MFIW] : Endif  # articles lancés
If clalev([F:MFMW]) = 0 : Local File MFGMAT     [MFMW] : Endif  # matières OF
If clalev([F:MFOW]) = 0 : Local File MFGOPE     [MFOW] : Endif  # opérations OF

# Recomptage global des matières et metières allouées/ruptures
  [F:MFG]MATLINNBR=0
  [F:MFG]MATCLENBR=0
  [F:MFG]OVRALLNBR=0
  [F:MFG]DETALLNBR=0
  [F:MFG]SHTMATNBR=0
  # GA 05/2011 ajout [F:MFM]CPNTYP=1
  For [F:MFMW] Where MFGNUM=[F:MFG]MFGNUM & [F:MFMW]CPNTYP=1
  # on compte les matières qui ne sont pas exclues et mises à dispo du sous-traitant
  # Issue 98109 GA 04/2014 ne pas compter les matières dont le besoin est qté nulle
    If [F:MFMW]MATSTA <> 4 & [F:MFMW]RETQTY<>0
       [F:MFG]MATLINNBR+=1
       If [F:MFMW]MATSTA = 3       : # Menu local 2223 : statut => "Soldé"
        # on compte les matières soldées
          [F:MFG]MATCLENBR+=1
       Endif
       If find([F:MFMW]ALLSTA,2,3) : # Menu local 340
       # Allocation globale
         [F:MFG]OVRALLNBR += 1
       Endif
       If find([F:MFMW]ALLSTA,4,5) : # Menu local 340
       # Allocation détaillée
         [F:MFG]DETALLNBR += 1
       Endif
       If [F:MFMW]SHTQTY<>0
       # Rupture
         [F:MFG]SHTMATNBR += 1
       Endif
    Endif
  Next

  Gosub MAJSTATUT
  If dim(GAVAMFG) <= 0 : Global Decimal GAVAMFG : Endif
  GAVAMFG = 9999999999
  Call  MAJ_AVAMFGQTY("MFM") From MFGLIBM       # llc 06.04

# ----------------------------------------------------------
# on compte les opérations
# ----------------------------------------------------------
  [F:MFG]OPECLENBR = 0
  [F:MFG]OPELINNBR = 0
  For [MFOW]MFO0 Where MFGNUM=[F:MFG]MFGNUM
    # on compte les opérations qui ne sont pas exclues
    If [F:MFOW]OPESTA<>6    # Issue 89741 GA 09/2013
       [F:MFG]OPELINNBR+=1
       If [F:MFOW]OPESTA = 5   : # Menu 308: statut => "Soldé"  # FQ 70633 GA 01/2011
        # on compte les opérations soldées
          [F:MFG]OPECLENBR+=1
       Endif
    Endif
  Next

# ------------------------------------------------------
# on compte les articles
# ------------------------------------------------------
  [F:MFG]ITMCLENBR = 0
  [F:MFG]ITMLINNBR = 0
# Issue 78650 - 2012-02-02 by CCC : Les sous-produits doivent faire parti du compte de ITMLINNBR
#                                   sinon, la comparaison avec ITMCLENBR n'est pas correcte
#  # on compte les articles lancés (sauf sous-produits)
#  For [MFI]MFI0 Where MFGNUM=[F:MFG]MFGNUM & ITMTYP=1
  For [MFIW]MFI0 Where MFGNUM=[F:MFG]MFGNUM
       [F:MFG]ITMLINNBR+=1
       If [F:MFIW]ITMSTA = 3   :# Menu local 363  # FQ 70633 GA 01/2011
        # on compte les articles soldés
          [F:MFG]ITMCLENBR+=1
       Endif
  Next

#Maj de l'écran si nécessaire
  If clalev([M:MFG1])<> 0
     # Issue 38556 GH 05/10/17 - Expected STK qty field of the 1st ligne in screen MFG1 was erased
     #[M:MFG1] = [F:MFG]
     Local Decimal SAVEXTQTY_0
     SAVEXTQTY_0 = [M:MFG1]EXTQTY(0)
     nolign = 0
     [M:MFG1] = [F:MFG]
     [M:MFG1]EXTQTY(0) = SAVEXTQTY_0
     #
     Affzo [M:MFG1]
  Endif
  If clalev([M:MFG0])<> 0
     [M:MFG0] = [F:MFG]
     Affzo [M:MFG0]
  Endif
  If clalev([M:MFA1])<> 0
     [M:MFA1] = [F:MFG]
     Affzo [M:MFA1]
  Endif

# CCC  : 02/03/12 : bug 78667 reproduit => nlle correction
#Close Local File [MFIW],[MFMW],[MFOW]

Return

#-----------------------------------------------------------------------#
# Recalcul statut allocation                                            #
#-----------------------------------------------------------------------#
$MAJSTATUT
 Local Integer XTOT
# nouveau statut allocation (non alloué, partiel, complet)
XTOT = [F:MFG]OVRALLNBR + [F:MFG]DETALLNBR
If (XTOT = 0)
    [F:MFG]ALLSTA = 1
    Return   # FQ 71083 GA 01/2011 sinon [F:MFG]ALLSTA Remis à 3 + bas
Else
    If (XTOT < [F:MFG]MATLINNBR - [F:MFG]MATCLENBR)          # llc 04.02 14090
        [F:MFG]ALLSTA = 2
    Else
        # sr 07.02 demande 15130  tester >= au lieu de =
        If (XTOT >= [F:MFG]MATLINNBR - [F:MFG]MATCLENBR)      # llc 04.02 14090
            [F:MFG]ALLSTA = 3
        Endif
    Endif
Endif
# si des ruptures existent, statut allocation + 2
If [F:MFG]SHTMATNBR <> 0 : [F:MFG]ALLSTA += 2 : Endif
# si toutes les matières sont soldées, on force le statut à "complet" ...
If [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
    [F:MFG]ALLSTA = 3
Endif
Return

# Issue 104571 - 2015-02-05 by JUSYN : Calculating shift date according ordinary calendar
##################################################################
#----------------------------------------------------------------#
# Calculating a date back or forth according shift days using    #
# common calendar only checking working day status for the end   #
# date. When end date is a non working day according to the      #
# direction (back or forth) the next available working day       #
# will be taken for the end date.                                #
#----------------------------------------------------------------#
# Entry   ORIDAT   : original date                               #
#         LTI      : number of shift days (positive or negative) #
#         ORIFCY   : production site                             #
#         SENCAL   : calculation direction                       #
#         SENDEC   : shift direction when end day nonworking day #
# Return  DSTDAT   : end date destination                        #
#----------------------------------------------------------------#
Subprog CALC_DATE_SHIFT_CALENDAR(ORIDAT, LTI, ORIFCY, SENCAL, SENDEC, DSTDAT)
Value    Date     ORIDAT
Value    Integer  LTI
Value    Char     ORIFCY
Value    Integer  SENCAL
Value    Integer  SENDEC
Variable Date     DSTDAT
Local    Libelle  UVYDAY
Local    Char     UVYCOD(5)
Local    Integer  LMSG

DSTDAT=ORIDAT
LMSG=0

Call LECTURE ("FCY", ORIFCY, "") From CONTOBJ

# Calculate calender day directly
If SENCAL = 0 : DSTDAT += LTI
    Else      : DSTDAT += LTI : Endif

Repeat
    mkstat = 0
    Call CONTROL_JOUR(DSTDAT,[F:FCY]UVYDAY,[F:FCY]UVYCOD,LMSG)
    If mkstat <> 0
        If SENDEC=0
            DSTDAT+=1
        Else
            DSTDAT-=1
        Endif
    Endif
Until mkstat = 0

End

# Issue 103013 - 2015-03-05 by CCC
#**----------------------------------------------------------------<br/>
#* CTLMATISS : Control that a product has not been produced before to be issued on the same WO
#**<br/>----------------------------------------------------------------<br/>
#* @param PFCY    = Site
#* @param PMFGNUM = WO
#* @param PIPTDAT = Imputation date
#* @param PITMREF = Product
#* @param PMATFLG = 0:Product (look for existing component) 1:Component (look for existing product)
#* @param PERRMSG = Error message
#* @return 0:OK ; 1:Error
#**<br/>----------------------------------------------------------------
#*!
Funprog CTLMATISS(PFCY,PMFGNUM,PIPTDAT,PITMREF,PMATFLG, PERRMSG)
Value    Char    PFCY
Value    Char    PMFGNUM
Value    Date    PIPTDAT
Value    Char    PITMREF
Value    Integer PMATFLG
Variable Char    PERRMSG

Local File ITMFACILIT [ITF]
Local File ITMMASTER  [ITM]
Local File TABCOSTMET [TCM1]
Local File TABCOSTMET [TCM2]
Local File TABCOSTMET [TCM3]
Local File ITMCATEG   [ITG1]
Local File ITMCATEG   [ITG2]
If clalev([F:STJ])=0  : Local File STOJOU     [STJ] : Endif

# if valuation method doesn't activate issue price adjustment -> no error & exit
Link [ITM] With [ITG1]ITG0~="";[F:ITM]TCLCOD,
&               [ITG2]ITG0=PFCY;[F:ITM]TCLCOD,
&               [ITF]ITF0~=[F:ITM]ITMREF;PFCY,
&               [TCM1]TCM0=[F:ITG1]VLTCOD,
&               [TCM2]TCM0=[F:ITG2]VLTCOD,
&               [TCM3]TCM0=[F:ITF]VLTCOD
&          As [LNK]
&          Where [F:ITM]ITMREF=PITMREF
Columns [LNK] ([F:TCM1]PRIREGS, [F:TCM2]PRIREGS, [F:TCM3]PRIREGS)
LRET = 0
For [LNK]
    If [F:TCM3]PRIREGS>0    # ITF valuation method comes first
        LRET=([F:TCM3]PRIREGS=2)
    Elsif [F:TCM2]PRIREGS>0 # ITG with site comes second
        LRET=([F:TCM2]PRIREGS=2)
    Else                    # ITG without site comes last
        LRET=([F:TCM1]PRIREGS=2)
    Endif
    Break
Next
Columns [LNK]
If LRET=0
    End 0
Endif

GPE=0
GPOINT = "CTLMATISS"    #CHECK IGNORE_LINE
Gosub ENTREE From EXEFNC
If GPE=1
    End 0
Endif

If PMATFLG=1
    # Look for product produced before this component issue
    Filter [STJ] Where STOFCY    = PFCY
&                    & ITMREF    = PITMREF
&                    & VCRTYPORI = 10
&                    & VCRNUMORI = PMFGNUM
&                    & VCRTYP    = 15
&                    & IPTDAT   <= PIPTDAT
&                    & REGFLG    = 1
Else
    # Look for component issued after this product entry
    Filter [STJ] Where STOFCY    = PFCY
&                    & ITMREF    = PITMREF
&                    & VCRTYPORI = 10
&                    & VCRNUMORI = PMFGNUM
&                    & VCRTYP    = 12
&                    & IPTDAT    > PIPTDAT
&                    & REGFLG    = 1
Endif

Look [STJ] First
Filter [STJ]

Raz PERRMSG
# If a transaction already exists, this is an error
If !fstat
    If PMATFLG=1
        PERRMSG = func AFNC.MES1(mess(306,193,1),PITMREF)
    Else
        PERRMSG = func AFNC.MES2(mess(307,193,1),PITMREF,num$(PIPTDAT))
    Endif
Endif

End PERRMSG<>""


##############################################

#**----------------------------------------------------------------<br/>
#* ERRMSG : Display error of the line
#**<br/>----------------------------------------------------------------<br/>
#* @param PABR = abreviation of screen
#* @param PIND = line index
#**<br/>----------------------------------------------------------------
#*!
Subprog ERRMSG(PABR, PIND)
Value Char PABR
Value Integer PIND

Local Char LORI(3)

Case func ECCLIB.ERRCODORI(PABR, PIND, LORI)
    When 1,4 : Call ERREUR(evalue("[M:"+PABR+"]"+LORI+"ERRMSG(PIND)")) From GESECRAN
    When 3 : Call MESSAGE(evalue("[M:"+PABR+"]"+LORI+"ERRMSG(PIND)")) From GESECRAN
Endcase
End

#**----------------------------------------------------------------<br/>
#* ERRLOG : Write message in the log
#**<br/>----------------------------------------------------------------<br/>
#* @param PERRCOD = Error code (1=4=Error, 3=Warning, other values=normal message)
#* @param PERRMSG = Error message
#**<br/>----------------------------------------------------------------
#*!
Subprog ERRLOG(PERRCOD, PERRMSG)
Value Integer PERRCOD
Value Char    PERRMSG
    Call ERRLOG2(PERRCOD, PERRMSG, "", "")
End

#**----------------------------------------------------------------<br/>
#* ERRLOG2 : Write message in the log
#**<br/>----------------------------------------------------------------<br/>
#* @param PERRCOD = Error code (1=4=Error, 3=Warning, other values=normal message)
#* @param PERRMSG = Error message (if null => no log)
#* @param PHEAD   = To write befor the message (optional)
#* @param PFOOT   = To write after the message (optional)
#**<br/>----------------------------------------------------------------
#*!
Subprog ERRLOG2(PERRCOD, PERRMSG, PHEAD, PFOOT)
Value Integer PERRCOD
Value Char    PERRMSG
Value Char    PHEAD
Value Char    PFOOT

If PERRMSG="" | GTRACE="" : End : Endif

Case PERRCOD
    When 1,4     : LNIV=1
    When 3       : LNIV=-1
    When Default : LNIV=0
Endcase

# Header of the message
If PHEAD<>""
    Call ECR_TRACE(PHEAD,LNIV) From GESECRAN
Endif

Call ECR_TRACE(PERRMSG,LNIV) From GESECRAN

# After the message
If PFOOT<>""
    Call ECR_TRACE(PFOOT,LNIV) From GESECRAN
Endif

End

# Issue 107498/108 - 2016-05-19 by BEEBE : validation whether PJT can be launched
#**----------------------------------------------------------------<br/>
#* Subprog VALIDPJT : Returns Flag whether the conversion of Suggestions
#*                    to Plan or Firm comming from PJM is allowed
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM    = product
#* @param PFCY    = site (optional)
#* @param PSTDFLG = Management Mode product
#* @param PPJT    = Project Task
#* @param PLAUNCH = 0 - no project task
#*                  1 - launch not possible
#*                  2 - launch possible
#**<br/>----------------------------------------------------------------
#*!
Subprog VALIDPJT(PITM,PFCY,PSTDFLG,PPJT,PLAUNCH)

Value Char PITM
Value Char PFCY
Value Integer PSTDFLG
Value Char PPJT
Variable Integer PLAUNCH : PLAUNCH = 0

Local Char WREQ(255) : WREQ = ""
Local Integer PLAUNCHS : PLAUNCHCHT = 0
Local Char BUDGET(15)
Local Char TASK(15)
Local Char SMESSAGE(255)
# Issue Jira X3-3522 - 2016-09-13 by JUSYN : No check for CRM projects
If clalev([F:PIM]) = 0 : Local File PIMPL [PIM] : Endif

If PPJT = "" or PITM = "" # If no PJT-Number or ITM --> no Project task assignment possible
   End
Endif

# Project task exists or is launched

PLAUNCH = func PIMPL_CSTD_PROGS.GET_PIMSTA_VALUE(GACTX, PPJT, BUDGET, TASK, SMESSAGE)
PLAUNCHS = PLAUNCH

# Issue Jira X3-3522 - 2016-09-13 by JUSYN : No check for CRM projects
Read [PIM]PIM0=PPJT
If fstat : End : Endif

If [F:PIM]PIMTYP = 1
    PLAUNCH = 2
    End
Endif

# Project task for product site exists in table ORDERS
WREQ ="SELECT WIPSTA_0, ITMREF_0 From ORDERS"
WREQ -= " where "
WREQ -= " PJT_0    = '"+PPJT+"'"
WREQ -= " and WIPTYP_0 = 14"

For (Integer WWIPSTA, Char WITMREF(20)) From num$(GTYPDBA*2+1) Sql WREQ As [WORDERS]
#      PLAUNCH = [WORDERS]WWIPSTA
      If [WORDERS]WITMREF = PITM # Highest level in BOM
          PLAUNCH = PLAUNCHS
          Break
      Else
          # Management Mode 3: Available stock + BOM lower level --> launch possible
          If  PLAUNCH = 1 & PSTDFLG = 3 & [WORDERS]WITMREF <>""
              PLAUNCH = 2
          Endif
      Endif
Next

End

# Issue X3-7649 - 2017-06-08 by ALSHE : validation whether order exists for project material task
#**----------------------------------------------------------------<br/>
#* Subprog VALIDWIP : Returns Flag whether order exists for project material task
#*                    WO, PO, EO in status Plan or Firm
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM    = product
#* @param PFCY    = site (optional)
#* @param PPJT    = Project Task
#* @param PWIP    = 0 - no WIP
#* @return        [V]CST_ATRUE  : WIP available
#*                [V]CST_AFALSE : no WIP
#**<br/>----------------------------------------------------------------
#*!

Funprog VALIDWIP(PITM,PFCY,PPJT)

Value Char PITM
Value Char PFCY
Value Char PPJT

Local Integer PWIP

  PWIP = [V]CST_AFALSE
  Local File ORDERS [ORD]
  If PPJT <> AVOID.ACHAR and PITM <> AVOID.ACHAR # If no PJT-Number or ITM --> no Project task assignment possible
    For [ORD] Where ITMREF=PITM and STOFCY=PFCY and  PJT=PPJT and find(WIPTYP,2,5,13) and find(WIPSTA,1,2)
      If !fstat
        PWIP= [V]CST_ATRUE
        Break
      Endif
    Next
  Endif
End PWIP

