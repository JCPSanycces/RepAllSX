#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################
# IMPITM : Import / Export des Articles                              #
######################################################################
$ACTION

Case ACTION
 When "IMP_OUVRE"     : Gosub OUVRE
 When "IMPORT"        : Gosub IMPORT
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"       : Gosub IMP_ZONE
 When "EXP_OUVRE"     : Gosub EXP_OUVRE
 When "EXPORT"        : Gosub EXPORT
Endcase
Return

#######################################################################
#                        IMPORT
#######################################################################

$OUVRE
Local Char CORFIC (10)
CORFIC="ITMBPC" : Gosub IMP_CORRESP From TRTX3IMP
CORFIC="ITMBPS" : Gosub IMP_CORRESP From TRTX3IMP
Gosub OUVRE_TEXTE
# hcb debut  11 01 05  27474
# test presence rubrique conditionnement
# si presence on importe exclusivement le contenu du fichier d import sans tenir compte des
# conditionnements de la categorie ; si absence l article sera créé avec les conditionnements
# de la categorie
Gosub FLD_MODELE From TRTX3IMP
Global Integer  GSTK_PCUFLG                        : # Flag presence conditionnement 1 = presence
Raz GSTK_PCUFLG
#   si on n'importe pas le n° de session
If find("[F:ITM]PCU(0)",[M:AOE2]ZONMSK1)
   GSTK_PCUFLG = 1
Endif
# hcb fin    11 01 05  27474

Return

#---------------------------------------------------------------------
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
  When "IMP_OUVRE"    : G_IMPORT=1
  When "EXP_OUVRE"    : G_EXPORT=1
Endcase

#   textes ITMMASTER : articles              ( texte achat *71 ? *78   texte production *81 ? *88 )
TSTCHAMP(31)="ITM*71" : TSTCHAMP(32)="ITM*72" : TSTCHAMP(33)="ITM*73" : TSTCHAMP(34)="ITM*74"
TSTCHAMP(35)="ITM*75" : TSTCHAMP(36)="ITM*76" : TSTCHAMP(37)="ITM*77" : TSTCHAMP(38)="ITM*78"
TSTCHAMP(41)="ITM*81" : TSTCHAMP(42)="ITM*82" : TSTCHAMP(43)="ITM*83" : TSTCHAMP(44)="ITM*84"
TSTCHAMP(45)="ITM*85" : TSTCHAMP(46)="ITM*86" : TSTCHAMP(47)="ITM*87" : TSTCHAMP(58)="ITM*88"

#   textes ITMSALES  : articles-ventes       ( texte vente *71 ? *78   texte bon prepa  *81 ? *88 )
TSTCHAMP(61)="ITS*71" : TSTCHAMP(62)="ITS*72" : TSTCHAMP(63)="ITS*73" : TSTCHAMP(64)="ITS*74"
TSTCHAMP(65)="ITS*75" : TSTCHAMP(66)="ITS*76" : TSTCHAMP(67)="ITS*77" : TSTCHAMP(68)="ITS*78"
TSTCHAMP(71)="ITS*81" : TSTCHAMP(72)="ITS*82" : TSTCHAMP(73)="ITS*83" : TSTCHAMP(74)="ITS*84"
TSTCHAMP(75)="ITS*85" : TSTCHAMP(76)="ITS*86" : TSTCHAMP(77)="ITS*87" : TSTCHAMP(78)="ITS*88"

#   textes ITMBPS    : articles-fournisseurs ( texte       *71 ? *78 )
TSTCHAMP(91)="ITP*71" : TSTCHAMP(92)="ITP*72" : TSTCHAMP(93)="ITP*73" : TSTCHAMP(94)="ITP*74"
TSTCHAMP(95)="ITP*75" : TSTCHAMP(96)="ITP*76" : TSTCHAMP(97)="ITP*77" : TSTCHAMP(98)="ITP*78"

#   textes ITMBPC    : articles-clients      ( texte vente *71 ? *78   texte bon prepa  *81 ? *88 )
TSTCHAMP(121)="ITU*71" : TSTCHAMP(122)="ITU*72" : TSTCHAMP(123)="ITU*73" : TSTCHAMP(124)="ITU*74"
TSTCHAMP(125)="ITU*75" : TSTCHAMP(126)="ITU*76" : TSTCHAMP(127)="ITU*77" : TSTCHAMP(128)="ITU*78"
TSTCHAMP(131)="ITU*81" : TSTCHAMP(132)="ITU*82" : TSTCHAMP(133)="ITU*83" : TSTCHAMP(134)="ITU*84"
TSTCHAMP(135)="ITU*85" : TSTCHAMP(136)="ITU*86" : TSTCHAMP(137)="ITU*87" : TSTCHAMP(138)="ITU*88"

Gosub OUVRE_TEXTE From TRTX3IMP
Return

#######################################################################
# Utilisation de l'instruction setmode --> suppression affichage
# avant le call SAIMSK et SAI_NBLIG
# pour afficher des infbox dans IMP_ZONE et IMP_TAB
# utiliser Setmode_off Setmode_on
# ( pour afficher : Gosub SETMODE_OFF en debut de IMP_ZONE ou IMP_TAB )
#######################################################################
$SETMODE_OFF
Setmode
Return

$SETMODE_ON
Setmode GNBAFF, GAFFCOD, GAFFMASK, GAFFCHP, GAFFIND, GAFFTXT, GAFFRANG, GAFFOPT1, GAFFOPT2
Return

######################################################################

### Lecture d'un enregistrement
$IMPORT
Local Integer NOL
Gosub IMP_DECLARE From TRTX3IMP

Case IMPFIC

    When "ITM" :
# -----------------------------------------------------------  #
#     Articles                                                 #
# -----------------------------------------------------------  #
    Local Char    NOMCHAMP(30)
    Local Integer OKCHAMP, WNBELEMENT
    #--------------------------------#
    # Chargement de la designation 1 #
    #--------------------------------#
     Call TST_CHAMP("ITM","ITMDES1",OKCHAMP) From SUBIMPOBJ
     If OKCHAMP
       [M:ITM0]DES1AXX=[F:ITM]ITMDES1 # FGR 30/06/2009 : X3SUIVI56189 : Ca reste bien comme ça
     Endif
    #--------------------------------#
    # Chargement de la designation 2 #
    #--------------------------------#
     Call TST_CHAMP("ITM","ITMDES2",OKCHAMP) From SUBIMPOBJ
     If OKCHAMP
       [M:ITM1]DES2AXX=[F:ITM]ITMDES2 # FGR 30/06/2009 : X3SUIVI56189 : Ca reste bien comme ça
     Endif
    #--------------------------------#
    # Chargement de la designation 3 #
    #--------------------------------#
     Call TST_CHAMP("ITM","ITMDES3",OKCHAMP) From SUBIMPOBJ
     If OKCHAMP
       [M:ITM1]DES3AXX=[F:ITM]ITMDES3 # FGR 30/06/2009 : X3SUIVI56189 : Ca reste bien comme ça
     Endif
    # --------------------------------------  #
    # Traitement du tableau des coefficients  #
    # --------------------------------------  #
        For I=0 To dim([F:ITM]PCU)-1
            NOMCHAMP = "PCU("+num$(I)+")"
            Call TST_CHAMP("ITM",NOMCHAMP,OKCHAMP) From SUBIMPOBJ
            If OKCHAMP & evalue("[F:ITM]"+NOMCHAMP) <> ""
#               La ligne a été paramétrée
                WNBELEMENT +=1
            Elsif [M:ITM3]PCU(I) <> ""
                WNBELEMENT +=1
            Endif
        Next
        [M:ITM3]BASTAB = WNBELEMENT

    When "ITU" :
# -----------------------------------------------------------  #
#     Article client                                           #
# -----------------------------------------------------------  #
# Il faut déterminer s'il s'agit d'une nouvelle ligne ou pas
        If GREP = "M"
            ICLEPRIM (0) = "BPCNUM"
            NBASTAB = "NBITU"
            Gosub RECHERCHE_LIGNE From TRTX3IMP
        Endif
#       C'est une nouvelle ligne
        If nolign=0
            NOL=[M]NBITU
            [M]XLIGITU = NOL
            nolign = NOL + 1
            [M]NBITU+=1
        Else
            [M]XLIGITU=nolign-1
        Endif

    When "ITP" :
# -----------------------------------------------------------  #
#     Article fournisseur                                      #
# -----------------------------------------------------------  #
# Il faut déterminer s'il s'agit d'une nouvelle ligne ou pas
        Local Integer NOL
        If GREP = "M"
            ICLEPRIM (0) = "BPSNUM"
            NBASTAB = "NBITP"
            Gosub RECHERCHE_LIGNE From TRTX3IMP
        Endif
#       C'est une nouvelle ligne
        If nolign=0
            NOL=[M]NBITP
            [M]XNUMLIG = NOL
            nolign = NOL + 1
            [M]NBITP+=1

#           Ceci est normalement executé en AP_BPSNUM si [M]BPSNUM(nol) = ""
#            En import on y passe pas car [M]BPSNUM(nol) est déj? chargé en AP_
#           [M]ITPQUAFLG(NOL) = [M:ITM2]QUAFLG    # hcb 60585
            [M]ITPPUU(NOL)    = [M:ITM3]PUU
            [M]DOUFLG(NOL)    = 1
            [M]IPUUSTUCOE(NOL)= [M:ITM3]PUUSTUCOE :# rajouté le 22/12/99
            Gosub CHARGE_ITP From SUBITP
        Else
            [M]XNUMLIG=nolign-1
        Endif

Endcase

Gosub IMPORT_TEXTE

Return

#---------------------------------------------------------------------
$IMPORT_TEXTE
Case IMPFIC
     When "ITM"
          If G_TX11     : # --- Texte achat ---
             Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>"" : [M:ITM4]PURTEX=G_CLE_CLOB : [M:ITM4]WPURTEX=2 : Endif
          Endif
          If G_TX12     : # --- Texte production ---
             Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>"" : [M:ITM1]MFGTEX=G_CLE_CLOB : [M:ITM1]WMFGTEX=2 : Endif
          Endif
     When "ITS"
          If G_TX21     : # --- Texte vente ---
             Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>"" : [M:ITS]ITSTEX=G_CLE_CLOB : [M:ITS]WITSTEX=2 : Endif
         Endif
          If G_TX22     : # --- Texte preparation ---
             Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             #MAE, bg 77269
             #If G_CLE_CLOB<>"" : [M:ITS]ITPTEX=G_CLE_CLOB : [M:ITS]WITPTEX=2 : Endif
             If G_CLE_CLOB<>"" : [M:ITM1]ITPTEX=G_CLE_CLOB : [M:ITM1]WITPTEX=2 : Endif
          Endif
     When "ITP"
          If G_TX31     : # --- Texte achat ---
             Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>"" : [M:ITP]TEX(nolign-1)=G_CLE_CLOB : [M:ITP]WTEX=2 : Endif
          Endif
     When "ITU"
          If G_TX41     : # --- Texte vente ---
             Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>"" : [M:ITU]ITSTEX(nolign-1)=G_CLE_CLOB : [M:ITU]WITSTEX=2 : Endif
          Endif
          If G_TX42     : # --- Texte preparation ---
             Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>"" : [M:ITU]ITPTEX(nolign-1)=G_CLE_CLOB : [M:ITU]WITPTEX=2 : Endif
          Endif
Endcase

Return

######################################################################

$IMP_ZONE
Local Char     IMPZONFIC(30) : IMPZONFIC =""
Local Char     IMPZONMSK(30) : IMPZONMSK =""
Local Integer  IINDICE       : IINDICE=0
Local Integer  IXZ
# sr 09.02 demande 14777 importer les données configurateur
Case IMPFIC
    When "ITM":
# ---------------------------------------------------#
#     Article                                        #
# ---------------------------------------------------#
        # Issue 115743 - 2016-04-07 by MUARN : import zones landed cost
        #If IMPZON  = "CFGLIN"
        #    Gosub CHARGE_COMPLEMENT
        #Endif
        Case IMPZON
          When "CFGLIN" :
            Gosub CHARGE_COMPLEMENT
          When "ITMCPRCOE" :
            IMPZONFIC="CPRCOE"
            IMPZONMSK="[M]"+IMPZON
          When "ITMCPRAMT" :
            IMPZONFIC="CPRAMT"
            IMPZONMSK="[M]"+IMPZON
          When "ITMSTCNUM" :
            IMPZONFIC="STCNUM"
            IMPZONMSK="[M]"+IMPZON
        Endcase
    When "ITU":
# ---------------------------------------------------#
#     Article-Client                                 #
# ---------------------------------------------------#
        Case IMPZON
            When "NBITU" :
#                Traitement particulier sur la 1?re zone de l'écran
#                --> Recharger nolign et indice pour se positionner sur la bonne ligne
                indice = [M]XLIGITU
                nolign = indice + 1
            When "BPCNUM" :
#                Traitement particulier sur la 1?re zone de l'écran
#                --> Recharger nolign et indice pour se positionner sur la bonne ligne
                indice = [M]XLIGITU
                nolign = indice + 1

                IMPZONFIC= IMPZON
                IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
            When "XPCUSAUCO1":
                IMPZONFIC = "PCUSAUCOE1"
                IMPZONMSK=IMPZON
            When "XPCUSAUCO2":
                IMPZONFIC = "PCUSAUCOE2"
                IMPZONMSK=IMPZON
            When Default
                IXZ = find(IMPFIC-IMPZON,[M:AOE2]ZONMSK)
                If IXZ
                  IMPZONFIC=[M:AOE2]FLD(IXZ-1)
                  IMPZONMSK=IMPZON
                Endif
        Endcase

    When "ITP":
# ---------------------------------------------------#
#     Article-Fournisseur                            #
# ---------------------------------------------------#
        Case IMPZON
            When "NBITP" :
#                Traitement particulier sur la 1?re zone de l'écran
#                --> Recharger nolign et indice pour se positionner sur la bonne ligne
                indice = [M]XNUMLIG
                nolign = indice + 1
            When "BPSNUM" :
#                Traitement particulier sur la 1?re zone de l'écran
#                --> Recharger nolign et indice pour se positionner sur la bonne ligne
                indice = [M]XNUMLIG
                nolign = indice + 1

                IMPZONFIC= IMPZON
                IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
            When Default
                IXZ = find(IMPFIC-IMPZON,[M:AOE2]ZONMSK)
                If IXZ
                  IMPZONFIC=[M:AOE2]FLD(IXZ-1)
                  IMPZONMSK=IMPZON
                Endif
        Endcase
     #MAE, bg 75439, positionnement du flag de modification de ces zones suite au bg 71988
     When "ITS":
        If find(IMPZON,"THEPRI","MINPRI","BASPRI")
                [M:ITS]WMODPRI = 1
        Endif

Endcase

 If IMPZONFIC <> "" & IMPZONMSK <> ""
#       On recherche si la zone est paramétrée
        If IINDICE <> 0
#           Zone indicée
            I = find(IMPFIC-IMPZONFIC+"("+num$(indice)+")",[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
            If I <> 0 IMPZONFIC = IMPZONFIC + "("+num$(indice)+")" : Endif
        Endif
        If IINDICE = 0 | IINDICE = 1 & I = 0
#           Zone non indicée ou zone indicée de 0 non trouvée
            I = find(IMPFIC-IMPZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
        Endif

        If I <> 0
#           On charge la classe [M]
#           Cas spécial : Ecran article-client et article-fournisseur                   #
#           Il faut passer systématiquement en AM_ pour charger le tableau invisible    #
#           m?me si la zone n'a pas changé                                              #
            If find(IMPFIC, "ITP", "ITU") IMPMOD = 1 Endif
            If evalue (IMPZONMSK) <> evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
                IMPMOD=1
                Assign IMPZONMSK With evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
            Endif
        Endif
        OK=0
Endif

Return

#######################################################################
# sr 09.02 demande 14777 importer les données configurateur
$CHARGE_COMPLEMENT
Local Integer I,J
Local Integer WCFGFLDNUM
Local Char    WTCT,WCFGFLDALP
If clalev([F:TLP]) <= 0 : Local File TABLINCFG [TLP] : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL [TCT] : Endif

Read [F:TLP]TLP0 = [F:ITM]CFGLIN
If fstat : Raz [F:TLP] : Return : Endif

For I = 1 To 6
    If evalue("[F:TLP]CFGALP"+num$(I)) <> 1
       IMPZONFIC = "CFGFLDALP"+num$(I)
       J = find(IMPZONFIC,[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
       If J
           WTCT       = evalue("[F:TLP]CFGALPTCT"+num$(I))
           # si table de contrôle alors contrôle !!!
           If WTCT <> ""
               WCFGFLDALP = evalue("[F:ITM]CFGFLDALP"+num$(I))
               Read [TCT]TCT1=WTCT;WCFGFLDALP;0
               If !fstat
                   Assign "[M:ITM1]CFGFLDALP"+num$(I) With evalue("[F:ITM]CFGFLDALP"+num$(I))
               Endif
           Else
                   Assign "[M:ITM1]CFGFLDALP"+num$(I) With evalue("[F:ITM]CFGFLDALP"+num$(I))
           Endif
       Endif
    Endif
Next

For I = 1 To 6
    If evalue("[F:TLP]CFGNUM"+num$(I)) <> 1
       IMPZONFIC = "CFGFLDNUM"+num$(I)
       J = find(IMPZONFIC,[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
       If J
           WTCT       = evalue("[F:TLP]CFGNUMTCT"+num$(I))
           # si table de contrôle alors contrôle !!!
           If WTCT <> ""
               WCFGFLDNUM = evalue("[F:ITM]CFGFLDNUM"+num$(I))
               Read [TCT]TCT1=WTCT;"";WCFGFLDNUM
               If !fstat
                   Assign "[M:ITM1]CFGFLDNUM"+num$(I) With evalue("[F:ITM]CFGFLDNUM"+num$(I))
               Endif
           Else
                   Assign "[M:ITM1]CFGFLDNUM"+num$(I) With evalue("[F:ITM]CFGFLDNUM"+num$(I))
           Endif
       Endif
    Endif
Next

Return

#######################################################################
#                        EXPORT
#######################################################################

$EXP_OUVRE
Gosub OUVRE_TEXTE
Return

$EXPORT
Raz G_CLE_CLOB, G_ZON_CLOB

Case EXPFIC

  When "ITM"
    If G_TX11
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:ITM]PURTEX)>0 & [F:ITM]PURTEX<>""
          G_CLE_CLOB=[F:ITM]PURTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_TX12
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:ITM]MFGTEX)>0 & [F:ITM]MFGTEX<>""
          G_CLE_CLOB=[F:ITM]MFGTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif

  When "ITS"
    If G_TX21
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:ITS]ITSTEX)>0 & [F:ITS]ITSTEX<>""
          G_CLE_CLOB=[F:ITS]ITSTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_TX22
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:ITS]ITPTEX)>0 & [F:ITS]ITPTEX<>""
          G_CLE_CLOB=[F:ITS]ITPTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif

  When "ITP"
    If G_TX31
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:ITP]TEX)>0 & [F:ITP]TEX<>""
          G_CLE_CLOB=[F:ITP]TEX    : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif

  When "ITU"
    If G_TX41
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:ITU]ITSTEX)>0 & [F:ITU]ITSTEX<>""
          G_CLE_CLOB=[F:ITU]ITSTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_TX42
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:ITU]ITPTEX)>0 & [F:ITU]ITPTEX<>""
          G_CLE_CLOB=[F:ITU]ITPTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif

Endcase

Return
#######################################################################

