#<AdxTL>@(#)12.0.0.0 $Revision$
# Gestion du masque CCN6
##########################################################################################################
#   Recherche d'une personne                                   Module CRM         24 avril 2006
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  If PARAM(1) <> "" Then
    [M:CCN6]CCNLNA = PARAM(1)
    Affzo [M:CCN6]CCNLNA
  Endif
  If PARAM(2) <> "" Then
    [M:CCN6]CCNFNA = PARAM(2)
    Affzo [M:CCN6]CCNFNA
  Endif
  [M:CCN6]CRITPST = 1
  Affzo [M:CCN6]CRITPST
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:CCN6]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      If (nolign-1) >= 0 Then
        If [M:CCN6]CCNNUM(nolign-1) <> "" Then
          VALEUR = [M:CCN6]CCNNUM(nolign-1)
          FIN = 1
          mkstat = 99
        Endif
      Endif
    When "C"
      Gosub ONLOAD
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONLOAD
Local Char SZWHERE (250)
Local Char SZAND(6)
Local Char SZVALEUR (100)
Local Char SZRECHERCHE (100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL

  Raz SZWHERE
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL=0
  Effzo [M:CCN6]20
  [M:CCN6]NBREC=0
  If !clalev([F:AIN]) : Local File "CONTACTCRM" [AIN] : Endif
  If [M:CCN6]CCNLNA <> "" Then
    SZVALEUR = [M:CCN6]CCNLNA
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE = " pat(toupper([F:AIN]CNTLNA)," +SZRECHERCHE+" ) <> 0 "
    SZAND = " AND "
  Endif
  If [M:CCN6]CCNFNA <> "" Then
    SZVALEUR = [M:CCN6]CCNFNA
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE = SZWHERE + SZAND + " pat(toupper([F:AIN]CNTFNA)," +SZRECHERCHE+" ) <> 0 "
    SZAND = " AND "
  Endif
  If [M:CCN6]CRITPST = 2 Then
    SZWHERE = SZWHERE + SZAND + " [F:AIN]CNTTYP = 1 "
    SZAND = " AND "
  Endif
  If [M:CCN6]CRITPST = 3 Then
    SZWHERE = SZWHERE + SZAND + " [F:AIN]CNTTYP = 2 "
    SZAND = " AND "
  Endif
  If SZWHERE <> "" Then
    Filter [AIN] Where evalue(SZWHERE) Order By [F:AIN]CNTLNA Desc; [F:AIN]CNTFNA Desc
  Else
    Filter [AIN] Order By [F:AIN]CNTLNA Desc; [F:AIN]CNTFNA Desc
  Endif
  INBLIGNETOTAL = rowcount([AIN])
  For [AIN]
    If ILIGNE >= dim([M:CCN6]NAM)-1 Then
      Break
    Endif
    [M:CCN6]CNTTYP(ILIGNE) = [F:AIN]CNTTYP
    If [M:CCN6]CNTTYP(ILIGNE) = 2 Then
      [M:CCN6]OBJ(ILIGNE) = "LDS"
    Else
      [M:CCN6]OBJ(ILIGNE) = "AIN"
    Endif
    Call BUILDFULNAM("AIN", [M:CCN6]NAM(ILIGNE)) From CRMUTIL140
    [M:CCN6]CCNNUM(ILIGNE) = [F:AIN]CNTNUM
    [M:CCN6]ZIP(ILIGNE) = [F:AIN]ZIP
    [M:CCN6]CTY(ILIGNE) = [F:AIN]CTY
    [M:CCN6]TEL(ILIGNE) = [F:AIN]CNTETS
    [M:CCN6]CRY(ILIGNE) = [F:AIN]CRY
    ILIGNE += 1
  Next
  Filter [AIN]
  [M:CCN6]NBREC = ILIGNE
  Affzo [M:CCN6]1-99
  If ILIGNE < INBLIGNETOTAL Then
    #Tous les enregistrements n'ont pas pu être affichés, un critère plus discriminant doit être saisi.
    GMESSAGE = mess(963,182,1)
    GERR = 2
  Endif
Return
