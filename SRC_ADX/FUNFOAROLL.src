#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: FUNFOAROLL
# Description : Food allergens rollup
####################################################################################

$ACTION

Case ACTION
  When "INIT"         : Gosub INIT
  When "OUVRE_BATCH"  : Gosub INIT
  When "INIT_DIA"     : Gosub INIT_DIA
  When "EXEC"         : Gosub EXEC
  When "DEBUT"        : Gosub INIT_DIA #Gbn
  When "OK"           : Gosub OK
Endcase

Return

####################################################################################
$INIT
Local  Integer OK,BOMOK,LOGFILE
Local  Char    CRIT(250),WMESS(100)
Global Integer GOK

LOGFILE=1   # 106737.n - Default to allways logging

If !clalev([F:ITM])  : Local File ITMMASTER  [ITM]  : Endif
If !clalev([F:ITM2]) : Local File ITMMASTER  [ITM2] : Endif
If !clalev([F:BOH])  : Local File BOM        [BOH]  : Endif
If !clalev([F:ITB])  : Local File ITMBOM     [ITB]  : Endif

If !clalev([M:FROLL]) :  Local Mask FOAROLL [FROLL] : Endif #Gbn

Return


####################################################################################
$INIT_DIA

# display the trace and default the BOM criteria
If GFLAG="BOMP"
  [M:FROLL]ITMREFDEB = PARAM(1)
  [M:FROLL]ITMREFFIN = PARAM(1)
  [M:FROLL]BOMALT=val(PARAM(2))

  Grizo [M:FROLL]

Endif

Return

####################################################################################
$OK
GOK=1
Return

####################################################################################
$EXEC
Global Integer   ALGCNT
Global Char      SAVALG(1)(20)

If GOK<>1 : Return : Endif

TIT = mess(1,3501,1)

# Initialize Log File
If !GSERVEUR & LOGFILE  # 106737.n
  Call OUVRE_TRACE(TIT) From LECFIC
Endif

# Start Log Message
If LOGFILE  # 106737.n
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

Gosub MAIN_PROCESS

# End Log Message
If !GSERVEUR & LOGFILE  # 106737.n
  Call FERME_TRACE From LECFIC
Endif

Gosub FIN

Kill ALGCNT
Kill SAVALG

Raz GOK

Return


####################################################################################
$FIN

If !GSERVEUR
  TRA = 1
Else
  TRA = 0
Endif

If GFLAG="BOMP"
  # Re-read the item to refresh the buffer
  Read [F:ITM]ITM0=[M:FROLL]ITMREFDEB
  [M:BOH0]ALG    = [F:ITM]ALG
  [M:BOH0]ALGDAT = [F:ITM]ALGDAT
  [M:BOH0]ALGBOM = [F:ITM]ALGBOM

  Affzo [M:BOH0]ALG,ALGDAT,ALGBOM
Endif

Return


################################################################
$MAIN_PROCESS

Local Integer OK,I,J
Local Char    NEWALG(20),TEMPA(20)
Local Char    SITE(5)  # Product Categories may be stored by site

CRIT = "1=1"

If [M:FROLL]ITMREFDEB<>""
  CRIT -= '& ITMREF>="'+[M:FROLL]ITMREFDEB+'"'
Endif

If [M:FROLL]ITMREFFIN<>""
  CRIT -= '& ITMREF<="'+[M:FROLL]ITMREFFIN+'"'
Endif

Filter [ITM] Where evalue (CRIT) Order By Key ITM0
For [ITM] Hint Key ITM0

  Trbegin [ITM]

  Raz OK,ALGCNT,SAVALG,NEWALG

  # If NOT Manufactured get the next Item
  If [F:ITM]MFGFLG<>2 : Goto NXTITM: Endif

  # Retrieve the Allergens from all components
  Call TRAITMUL([F:ITM]ITMREF,[M:FROLL]BOMALT,OK)

  # Reorganize the Allergens
  For I=1 To ALGCNT
    For J=1 To ALGCNT-I
      If SAVALG(J+1)<SAVALG(J)
        TEMPA = SAVALG(J+1)
        SAVALG(J+1) = SAVALG(J)
        SAVALG(J) = TEMPA
      Endif
    Next J
  Next I

  For I=1 To ALGCNT
    NEWALG += SAVALG(I)
  Next

  # If the Allergens changed, update the Item
  If [F:ITM]ALG<>NEWALG
    [F:ITM]ALG    = NEWALG
    [F:ITM]ALGDAT = date$
    [F:ITM]ALGBOM = [M:FROLL]BOMALT
    Rewrite [ITM]
    If fstat
      GOK = 0 : Call FSTA("ITM") From GLOCK
      If LOGFILE  # 106737.n
        WMESS = func AFNC.MES1(mess(6,3501,1),[F:ITM]ITMREF)
        Call ECR_TRACE(WMESS,1) From GESECRAN
      Endif
    Else
      OK = 1
      If LOGFILE  # 106737.n
        Call ECR_TRACE(" ",0) From GESECRAN
        WMESS = mess(27,159,1)+":"-[F:ITM]ITMREF-"-"-mess(153,198,1)+":"-num$([M:FROLL]BOMALT)
        Call ECR_TRACE(WMESS,0) From GESECRAN
        If NEWALG="" : NEWALG='""' : Endif
        WMESS = string$(5," ")-mess(2,3501,1)-NEWALG
        Call ECR_TRACE(WMESS,0) From GESECRAN
      Endif
    Endif
  Endif

$NXTITM
  If OK
    Commit
  Else
    Rollback
  Endif
Next
Filter [ITM]

Return


###################################################################################
Subprog TRAITMUL(ITM,ALT,OK)
Value    Char    ITM
Value    Integer ALT
Variable Integer OK

Local Date    REFDTE
Local Char    TA(20)
Local Integer LA,I,J,FOUND

REFDTE = date$

Local File BOMD [BOD] Where ITMREF=ITM & BOMALT=ALT & BOMSTRDAT<=[L]REFDTE &
&                     (BOMENDDAT>=REFDTE | BOMENDDAT=[0/0/0]) & CPNTYP=1
For [BOD]

  # Retrieve the Item record
  Read [ITM2]ITM0=[F:BOD]CPNITMREF
  If fstat : Raz [F:ITM2] : Endif
  If !fstat
    LA = len([F:ITM2]ALG)
    For I=1 To LA
      FOUND = 0
      TA = mid$([F:ITM2]ALG, I, 1)
      For J=1 To ALGCNT
        If SAVALG(J)=TA : FOUND = 1 : Break : Endif
      Next
      If !FOUND : ALGCNT += 1 : SAVALG(ALGCNT) = TA : Endif
    Next
  Endif
  Read [ITB]ITB0=[F:BOD]CPNITMREF;[F:BOD]BOMALT
  If !fstat & [F:ITB]BOMEXIFLG=2
    Call TRAITMUL([F:BOD]CPNITMREF,[F:BOD]BOMALT,OK)
  Endif
Next

End

######################################################################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()

If [M:FROLL]ITMREFFIN="" | [M:FROLL]ITMREFFIN<VALEUR
   [M:FROLL]ITMREFFIN=VALEUR
Endif

End

######################################################################################
#  Called from Production BOMs to auto do roll-up when lines modified or new BOM created
######################################################################################
Subprog AUTOROLLUP
Local Char ORIGALG(20)
Local Char NEWALG(20)

# Save the allergens that are currently on the parent item
ORIGALG=[M:BOH0]ALG

# Open the appropriate tables and screens
Gosub INIT

LOGFILE=0  # 106737.n - When doing an AutoRollup - no logging

# Use the values from the BOM screen
[M:FROLL]ITMREFDEB=[M:BOH0]ITMREF
[M:FROLL]ITMREFFIN=[M:BOH0]ITMREF
[M:FROLL]BOMALT   =[M:BOH0]BOMALT

GOK=1

# Run the rollup
Gosub EXEC

If ORIGALG<>[M:BOH0]ALG
  #If the allergens have changed, display a message to the user
  [F:ITM]ALG=[L]NEWALG
  If [L]NEWALG="" : [L]NEWALG='""' : Endif
  Call MESSAGE(mess(2,3501,1)-[L]NEWALG) From GESECRAN
Endif

End
