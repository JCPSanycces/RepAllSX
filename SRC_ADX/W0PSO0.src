#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PSO0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone OPPNUM
mkstat = 0
zoncou = "OPPNUM"
indice = 0
WCHAR = [M]OPPNUM
If varmode([M]OPPNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPPNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]OPPNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("PIM","A",[M]OPPNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_OPPNUM([M]OPPNUM) From SUBPSO
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]OPPNUM or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_OPPNUM([M]OPPNUM) From SUBPSO
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone PSONUM
mkstat = 0
zoncou = "PSONUM"
indice = 0
If varmode([M]PSONUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PSONUM" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CTLNUM"
 PARAM(1) = "PSONUM"
 PARAM(2) = "PSOH"
 Local Char    VALEUR(250)
 VALEUR = [M]PSONUM
 Call S_AFF_CHAR(VALEUR,PARAM,"CTLNUM","TRTVENCTL","") From GACTION
 [M]PSONUM = VALEUR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PSONUM" : GZNUM = 56316 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone HDOCNUM
mkstat = 0
zoncou = "HDOCNUM"
indice = 0
If varmode([M]HDOCNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HDOCNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DOCTYP
mkstat = 0
zoncou = "DOCTYP"
indice = 0
IMPENT = [M]DOCTYP
If varinit([M]DOCTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]DOCTYP,indice)=0
 [M]DOCTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DOCTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DOCTYP(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DOCTYP" : GZNUM = 865 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]DOCTYP = IMPENT

## Zone DOCDAT
mkstat = 0
zoncou = "DOCDAT"
indice = 0
If varmode([M]DOCDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DOCDAT" : Gosub ACTION From =IMPTRT
 Endif
 If [M]DOCDAT=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DOCDAT" : GZNUM = 6517 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CHGFLG
mkstat = 0
zoncou = "CHGFLG"
indice = 0
IMPENT = [M]CHGFLG
If varinit([M]CHGFLG,indice)=0
 IMPENT = 1
Endif
[M]CHGFLG = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PSO0"
Return

