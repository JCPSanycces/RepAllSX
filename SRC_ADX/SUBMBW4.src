#<AdxTL>@(#)7.0.0.0 $Revision$
If [F:MFG]ALLSTA > 1 : mkstat = 2 : End : Endif            # 09.05 32041
If [F:MTS]MFGMODO = 2 : mkstat = 2 : End : Endif                         # 03.05 29111
If VALEUR = 0
    Call RECH_NOM([M:MBW1]STOFCY, [M:MBW1]STRDAT2, VALEUR,2) From BENCHLIB
Endif
########################################
Subprog AS_EXTQTY2(VALEUR)
Variable Decimal VALEUR
GBOUT1 = mess(151,198,1)
GBOUT2 = mess(150,198,1)
If ([M:MBW4]VCRNUM = "" & [M:MBW4]BOMALT2 = 0)
    GBOUT3 = ""
Else
    GBOUT3 = mess(282,198,1)
Endif
End

########################################
Subprog B1_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MBW4]ITMREF
    Read [ITF]ITF0=[M:MBW4]ITMREF;[M:MBW4]STOFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY
End

########################################
Subprog B2_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MBW4]ITMREF
    Read [ITF]ITF0=[M:MBW4]ITMREF;[M:MBW4]STOFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY
End

########################################
Subprog C_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
End

########################################
Subprog AM_EXTQTY2(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer WALT            # llc 05.03 18397

# llc 05.03 18397
WQTY = VALEUR
If [M:MBW4]ROUNUM <> "" & [M:MBW4]ROUALT <> 0 & [M:MBW4]STRDAT2 <> [0/0/0]
    Raz GMESSAGE
    If clalev([F:TRO]) = 0 : Local File TABROUALT [TRO] : Endif
    If clalev([F:ROH]) = 0 : Local File ROUTING   [ROH] : Endif
    #    Lecture ROUTING
    Read [TRO]TRO0=[M:MBW4]ROUALT
    If fstat
        GMESSAGE = mess(152,193,1)
    Else
        Read [ROH]ROH1=[M:MBW4]STOFCY;[M:MBW4]ROUNUM;[M:MBW4]ROUALT
        If fstat
            GMESSAGE = mess(152,193,1)
        Else
            Call CONTMFGGAM([M:MBW4]STOFCY,WALT,[M:MBW4]STRDAT2,WQTY, [M:MBW4]STU2, 1) From MFGLIB
        Endif
    Endif
    If GMESSAGE <> "" | WALT = 0 : mkstat = 2 : End : Endif
Endif

If [M:MBW4]STRDAT2 = [0/0/0] | [M:MBW4]ENDDAT2 = [0/0/0] : End : Endif

WORIFCY=[M:MBW4]STOFCY
WLTI=0

# lecture ITF
If [F:ITF]ITMREF<>[M:MBW4]ITMREF
    Read [ITF]ITF0=[M:MBW4]ITMREF;[M:MBW4]STOFCY
    If fstat : End : Endif
Endif

If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:MFG]EXTQTY - [M:MBW4]EXTQTY1 + VALEUR
Else
    WQTY = VALEUR
Endif
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# 05.08 47469
If [F:MTS]SCDMODSAI = 1
    # calcul date
    WORIDAT=[M:MBW4]ENDDAT2
    WMEMDAT=[M:MBW4]STRDAT2

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MBW4]STRDAT2) From MFGLIB

    Affzo [M:MBW4]STRDAT2
    Call CHECK_PAST([M:MBW4]STRDAT2, 2) From MFGLIB
Else
    # calcul date
    WORIDAT=[M:MBW4]STRDAT2
    WMEMDAT=[M:MBW4]ENDDAT2

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MBW4]ENDDAT2) From MFGLIB

    Affzo [M:MBW4]ENDDAT2
    Call CHECK_PAST([M:MBW4]ENDDAT2, 2) From MFGLIB
Endif

End

########################################
Subprog AS_STRDAT2(VALEUR)
Variable Date    VALEUR
# jalonnement amont, si nouvel ordre on saisit la date de fin
# llc 03.02 12520
If [F:MTS]SCDMODSAI = 1 & [M:MBW4]ENDDAT2=[0/0/0] : mkstat=2 : End : Endif
If find([F:ORD1]WIPSTA,1,2) & [F:MFG]MFGTRKFLG > 3 : mkstat = 2 : Endif
End

########################################
Subprog C_STRDAT2(VALEUR)
Variable Date    VALEUR

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MBW4]STOFCY) From MFGLIB

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:MBW4]ECCVALMAJ)>0
    Call C_STRDAT2(VALEUR, "MBW4") From SUBMBWECC
Endif

End

########################################
Subprog AM_STRDAT2(VALEUR)
Variable Date    VALEUR
Local    Integer WRET
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY

If [F:MTS]SCDMODSAI = 1 & VALEUR > [M:MBW4]ENDDAT2 : mkstat=2 : End : Endif

# OF jalonné ?
Call TEST_JAL(WRET) From MFGAUTLIB
If WRET = 1 : mkstat = 2 : End : Endif

# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2)  From MFGLIB

# llc 03.02 12520
If [F:MTS]SCDMODSAI = 1 : End : Endif

# recalcul date fin
WORIDAT=VALEUR
WORIFCY=[M:MBW4]STOFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M:MBW4]ITMREF;[M:MBW4]STOFCY
If fstat : End : Endif
If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:MFG]EXTQTY - [M:MBW4]EXTQTY1 + [M:MBW4]EXTQTY2
Else
    WQTY = [M:MBW4]EXTQTY2
Endif
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# calcul date
WMEMDAT = [M:MBW4]STRDAT2

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MBW4]ENDDAT2) From MFGLIB

Affzo [M:MBW4]ENDDAT2
#
End

########################################
Subprog C_ENDDAT2(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MBW4]STOFCY) From MFGLIB
If mkstat : End : Endif

If [M:MBW4]STRDAT2 = [0/0/0] : End : Endif

If [M:MBW4]BOMALT2 = 0
    Call RECH_NOM([M:MBW4]STOFCY, [M:MBW4]STRDAT2, [M:MBW4]BOMALT2,2) From BENCHLIB
Endif

If ([M:MBW4]ROUNUM = "" | [M:MBW4]ROUALT = 0) & ([F:MTS]MFGMODC = 2 | [F:MTS]MFGMODO = 2)
    If [F:ITF]MFGROU = ""
        [M:MBW4]ROUNUM = [M:MBW4]ITMREF
    Else
        [M:MBW4]ROUNUM = [F:ITF]MFGROU
    Endif

    Call RECH_GAM([M:MBW4]STOFCY, [M:MBW4]STRDAT2, [M:MBW4]ROUNUM, [M:MBW4]EXTQTY2,
&                 [M:MBW4]STU2, [M:MBW4]BOMALT2, [M:MBW4]ROUALT) From BENCHLIB
    If [M:MBW4]ROUALT = 0 & [F:MTS]MFGMODM = 2 : Raz [M:MBW4]ROUNUM : Endif                # llc 06.04 22880
Endif
Affzo [M:MBW4]40

End

########################################
Subprog AS_ENDDAT2(VALEUR)
Variable Date    VALEUR
# Si jalonnement aval et date début non renseignée, pas de saisie
If ([F:MTS]SCDMODSAI=2 & [M:MBW4]STRDAT2=[0/0/0]) : mkstat=2 : End : Endif
End

########################################
Subprog AM_ENDDAT2(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY

If [F:MTS]SCDMODSAI = 2 & VALEUR < [M:MBW4]STRDAT2 : mkstat = 2 : End : Endif

# OF jalonné ?
Call TEST_JAL(WRET) From MFGAUTLIB
If WRET = 1 : mkstat = 2 : End : Endif

Call CHECK_PAST(VALEUR, 2) From MFGLIB

# llc 03.02 12520
If [F:MTS]SCDMODSAI = 2 : End : Endif

If find([F:ORD1]WIPSTA,1,2) & [F:MFG]MFGTRKFLG > 3 : End : Endif

WORIDAT=VALEUR
WORIFCY=[M:MBW4]STOFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M:MBW4]ITMREF;[M:MBW4]STOFCY
If fstat : End : Endif
If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:MFG]EXTQTY - [M:MBW4]EXTQTY1 + [M:MBW4]EXTQTY2
Else
    WQTY = [M:MBW4]EXTQTY2
Endif
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# calcul date
WMEMDAT = [M:MBW4]STRDAT2

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MBW4]STRDAT2) From MFGLIB

Affzo [M:MBW4]STRDAT2
Call CHECK_PAST([M:MBW4]STRDAT2, 2) From MFGLIB

# Issue 104943 - 2015-07-27 by BEEBE : Implementing Versioning
If dim([M:MBW4]ECCVALMAJ)>0
    Call AM_ENDDAT2(VALEUR, "MBW4") From SUBMBWECC
Endif
#
zonsui="STRDAT2"
#
End

########################################
Subprog AS_BOMALT2(VALEUR)
Variable Decimal VALEUR
If [F:MTS]MFGMODO = 2 : mkstat = 2 : End : Endif                         # 03.05 29111
If VALEUR = 0
    Call RECH_NOM([M:MBW4]STOFCY, [M:MBW4]STRDAT2, VALEUR,2) From BENCHLIB
Endif
End

########################################
Subprog C_BOMALT2(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 & [F:MTS]MFGMODO <> 2  : mkstat = 2 : Endif    # llc 11.02 16545 + 02.05 28246
End

########################################
Subprog AM_BOMALT2(VALEUR)
Variable Decimal VALEUR
Local    Date    WDAT
Local    Char    WFCY
Local    Integer WALT

If [M:MBW4]STRDAT2=[0/0/0]
    WDAT=date$
Else
    WDAT=[M:MBW4]STRDAT2
Endif

If VALEUR = 0 & [F:MTS]MFGMODO = 2 :  End : Endif            # llc 11.02 16545 + 02.05 28246

WFCY=[M:MBW4]STOFCY
#    Lecture BOM
Read [TBO]TBO0=2;VALEUR
If fstat : mkstat=2 : End : Endif
Read [BOH]BOH0=[M:MBW4]ITMREF;VALEUR;2
If fstat : mkstat=2 : End : Endif
Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
If WALT=0 : mkstat=2 : End : Endif
End

########################################
Subprog AS_ROUNUM(VALEUR)
Variable Char    VALEUR()
# sr 211100 contrôle selon transaction
If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1
    Raz VALEUR,[M:MBW4]ROUNUM,ROUALT
    mkstat = 2
    End
Endif
End

########################################
Subprog C_ROUNUM(VALEUR)
Variable Char    VALEUR()
# sr 211100 contrôle selon transaction + 12.04 27137
If [F:MTS]MFGMODM = 1  & VALEUR = ""
    GMESSAGE = mess(31,190,1)
    mkstat = 2
Endif
End

########################################
Subprog AM_ROUNUM(VALEUR)
Variable Char    VALEUR()
# 12.03 27137
If VALEUR = ""
    [M:MBW4]ROUALT = 0
    Affzo [M:MBW4]ROUALT
Endif
End

########################################
Subprog AS_ROUALT(VALEUR)
Variable Decimal VALEUR
# sr 211100 contrôle selon transaction
If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1
    mkstat = 2
    End
Endif
End

########################################
Subprog C_ROUALT(VALEUR)
Variable Decimal VALEUR
Local    Char    WFCY
Local    Integer WALT
Local    Date    WDAT
Local    Integer NOL
Local    Integer TABTBO(3)
#
# sr 211100 test de la transaction de saisie
If VALEUR = 0
  If [F:MTS]MFGMODM = 2 & [M:MBW4]ROUNUM = ""
     End
  Else
    mkstat = 2
    End
  Endif
Endif
WDAT=[M:MBW4]STRDAT2
WFCY=[M:MBW4]STOFCY
#    Lecture ROUTING
Read [TRO]TRO0=VALEUR
If fstat : mkstat=2 : End : Endif
Read [ROH]ROH1=[M:MBW4]STOFCY;[M:MBW4]ROUNUM;VALEUR
If fstat : mkstat=2 : End : Endif
#
# GH 17/12/2013 bug 95339 pour afficher un message d'erreur
#Call CONTMFGGAM(WFCY,WALT,WDAT,[M:MBW4]EXTQTY2, [M:MBW4]STU2, 0) From MFGLIB
Call CONTMFGGAM(WFCY,WALT,WDAT,[M:MBW4]EXTQTY2, [M:MBW4]STU2,1) From MFGLIB
If WALT=0 : mkstat=2 : End : Endif
# Contrôle de cohérence des alternatives de nomenclature
If ([F:MTS]MFGMODO = 2 & [M:MBW4]BOMALT2 = 0) : End : Endif            # llc 16545 + 02.05 28246

TABTBO(0)=[F:TRO]BOMALT1
TABTBO(1)=[F:TRO]BOMALT2
TABTBO(2)=[F:TRO]BOMALT3
If !find([M:MBW4]BOMALT2, TABTBO)
   mkstat=2
   End
Endif
End

########################################
Subprog AM_ROUALT(VALEUR)
Variable Decimal VALEUR
End




