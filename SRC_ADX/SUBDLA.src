######################################################################################
## Etiquette ajoutée par le superviseur (écran DLA1) 26/06/2006 12:20:51 (LS)
######################################################################################

Subprog D_RPTFLG(VALEUR)
Variable Integer VALEUR
Call GRISE_RPTFLG(VALEUR)
End

Subprog AM_RPTFLG(VALEUR)
Variable Integer VALEUR
Call GRISE_RPTFLG(VALEUR)
End

Subprog GRISE_RPTFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [DLA1]RPTNAM
Else
 Effzo [DLA1]RPTNAM
 Grizo [DLA1]RPTNAM
Endif
End

Subprog D_BPRWAC(VALEUR)
Variable Integer VALEUR
Call GRISE_BPRWAC(VALEUR)
End

Subprog AM_BPRWAC(VALEUR)
Variable Integer VALEUR
Call GRISE_BPRWAC(VALEUR)
End

Subprog GRISE_BPRWAC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [DLA1]BPRNAM,BPRADD,BPRNSS
Else
 Effzo [DLA1]BPRNAM,BPRADD,BPRNSS
 Grizo [DLA1]BPRNAM,BPRADD,BPRNSS
Endif
End

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:DLA0]CTRNUM
Else
 Diszo [M:DLA0]CTRNUM
Endif
Affzo [M:DLA0]CTRNUM
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran DLA2) 23/06/2006 11:44:09 (LS)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Read [CPY]CPY0=VALEUR
If !fstat
 Read [BPA]BPA0=2;VALEUR;[F:CPY]BPAADD
 If !fstat
  [M:DLA2]CPYADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:DLA2]CPYADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:DLA2]CPYADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:DLA2]CPYPOSCOD    = [F:BPA]POSCOD
  [M:DLA2]CPYCTY       = [F:BPA]CTY
  [M:DLA2]CPYCRY       = [F:BPA]CRY
  Affzo [DLA2]5
 Endif
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Read [FCY]FCY0=VALEUR
If !fstat & [F:FCY]LEGCPY<>[M:DLA2]CPY
 #Site référencé dans la société
 GMESSAGE = mess(70,104,1)-[M:DLA2]CPY
 mkstat = 2 : End
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Read [FCY]FCY0=VALEUR
If !fstat
 [M:DLA2]FCYCRN = [F:FCY]CRN
 Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
 If !fstat
  [M:DLA2]FCYADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:DLA2]FCYADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:DLA2]FCYADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:DLA2]FCYPOSCOD    = [F:BPA]POSCOD
  [M:DLA2]FCYCTY       = [F:BPA]CTY
  [M:DLA2]FCYCRY       = [F:BPA]CRY
  [M:DLA2]FCYTEL       = [F:BPA]TEL
  Affzo [DLA2]10
 Endif
Endif
End

Subprog C_DATREF(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M:DLA0]DAT
 # La date de signature doit être supérieure au
 GMESSAGE = mess(26,10710,1)-num$([M:DLA0]DAT)
 mkstat = 2 : End
Endif
End


Subprog AM_FCYRPBFNC(VALEUR)
Variable Integer VALEUR
If VALEUR=10
 Actzo [M:DLA2]FCYRPBFNC2
Else
 Effzo [M:DLA2]FCYRPBFNC2
 Grizo [M:DLA2]FCYRPBFNC2
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran DLA4) 26/06/2006 12:21:16 (LS)
######################################################################################

Subprog D_CTTINS(VALEUR)
Variable Integer VALEUR
Call GRISE_CTTINS(VALEUR)
End

Subprog AM_CTTINS(VALEUR)
Variable Integer VALEUR
Call GRISE_CTTINS(VALEUR)
End

Subprog GRISE_CTTINS(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : # inscrit au registre
 Actzo [DLA4]RGTNUM, RGTDAT :#80107
Else
 Effzo [DLA4]RGTNUM, RGTDAT :#80107
 Grizo [DLA4]RGTNUM, RGTDAT :#80107
Endif
End


