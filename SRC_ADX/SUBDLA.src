#<AdxTL>@(#)11.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#
######################################################################################
# Modifications :
#     V8 SEGAY - FQ81085 - US 1553 02/05/13 - Civility LEG
######################################################################################

# Gestion du masque DLA0
Raz GPILOBJ
Call OBJET("DLA",GBIDC1,"") From GOBJET
End

########################################
$ACTION
#If GUSER = 'JOJAC' : Infbox ACTION : Endif
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "FILTRE"      : Gosub FILTRE
 When "FERME"       : Gosub FERME
 #86255
 When "AS_REFNUM"    : Gosub AS_REFNUM
 When "BS_REFNUM"    : Gosub BS_REFNUM
 #SEGAY US1840 US1933 81085 25/09/2013 ACTION ENVOYÉE DE SELEMPCTR
 When "BAS_CTRNUM"  : Gosub BAS_CTRNUM
 When "RAZCRE"      : Gosub RAZCRE
Endcase
Return

$OUVRE
Gosub OUVRE From WPDEFTABLE
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:CNT])=0 : Local File CONTACT    [CNT] : Endif
If clalev([F:AIN])=0 : Local File CONTACTCRM [AIN] : Endif
If clalev([F:WAC])=0 : Local File TRVACC     [WAC] : Endif

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If GTPS
#** If clalev([F:NAT])=0 : Local File NATACTIV   [NAT] : Endif
#**Endif
#*!

If GTPS
 If clalev([F:NAT])=0 : Local File NATACTIV   [NAT] : Endif
Endif
#LIPET - 2017-05-20 - END
Local Integer I1,I2,I3
Local Decimal D1(1..2),D2(1..2),D3(1..2)
Local Char    C1(30)
Local Char    C2(30)(1..9)
# FQ81085 - US 1553 02/05/13 - Civility LEG
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Local Char    WNUMLIB(30)
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#86255
$RAZCRE
If GLEGFIL<>""
 GCURLEG=GLEGFIL
Else
 GCURLEG=GDOSLEG
Endif
Return

#$ABANDON
#If GLEGFIL<>""
#  GCURLEG=GLEGFIL
#Else
#  GCURLEG=GDOSLEG
#Endif
#Return
#
#$AB_MODIF
#If [M:DLA0]REFNUM<>""
#  Call CHERCHE_CTR([M:DLA0]REFNUM,[M:DLA0]DAT,[M:DLA0]CTRNUM) From DIVPAYE
#  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
#  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#  If dim([M:DLA0]LEG)>0 : [M:DLA0]LEG=[F:CPY]LEG : Affzo [M:DLA0]LEG : Endif
#  GCURLEG=[F:CPY]LEG
#Endif
#Return
#

$LIENS
$GRISE
#86255
If GNBLEG = 1         :#=dossier mono-leg
 GCURLEG = GDOSLEG
Else                  :#=dossier multi-leg
 GCURLEG = [F:DLA]LEG
Endif
#

Call GRISE_CTTINS([M:DLA4]CTTINS) :#80107

If [M:DLA1]RPTFLG=2
 Actzo [DLA1]RPTNAM
Else
 Effzo [DLA1]RPTNAM
 Grizo [DLA1]RPTNAM
Endif

If [M:DLA1]BPRWAC=2
 Actzo [DLA1]BPRNAM,BPRADD,BPRNSS
Else
 Effzo [DLA1]BPRNAM,BPRADD,BPRNSS
 Grizo [DLA1]BPRNAM,BPRADD,BPRNSS
Endif

Call AM_FCYRPBFNC([M:DLA2]FCYRPBFNC)
Call GRISE_CTRNUM([F:ID]FLGMULCTR)

# FQ81085 - 23/04/13 - Lecture HRCTR pour les numéros de sécu
Filter [HRCTR] Where REFNUM=[M:DLA0]REFNUM & CTRNUM=[M:DLA0]CTRNUM & CTRDAT<=[M:DLA0]DAT
Read [HRCTR]CTR0 Last
If fstat Then Raz [F:HRCTR] : Endif
Filter [HRCTR]

# FQ81085 - US 1553 02/05/13 - Civility LEG
If !fstat
  Call PARAM([F:HRCTR]ETRFCY,"CIVIL",WNUMLIB) From ADOVAL
Else
  Call PARAM([F:ID]FCYORI,"CIVIL",WNUMLIB) From ADOVAL
Endif
[M:DLA0]NOLIB=val(WNUMLIB)
If [M:DLA0]CIV>0 Then [M:DLA0]CIVA=mess([M:DLA0]CIV,val(WNUMLIB),1) : Endif
# END FQ81085 - US 1553

#86255
GCURLEG=[M:DLA0]LEG
Grizo [M:DLA0]LEG
Return

$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Else
 FILTSUP ="1=1"
Endif
Return

$APRES_MODIF
# FQ81085 - US 1553 02/05/13 - Civility LEG
# Le test sur REP et GREP ne sert à rien car n'était fait que sur COUZON="CTRNUM"
# et REP et GREP ne sont pas encore alimentés car la clé n'est pas validée
#JOJAC - START
If COUZON="REFNUM" | COUZON="DAT" | COUZON="CTRNUM" & (REP="C" | GREP="C" | REP="D" | GREP="D")
#If (COUZON="REFNUM" | COUZON="DAT" | COUZON="CTRNUM")
#JOJAC - END
 Assign "[M:DLA0]"+COUZON With CZ
 GMODIF=1
 Gosub CHARGE
 Affzo[M:DLA0]
 Affzo[M:DLA1]
 Affzo[M:DLA2]
 Affzo[M:DLA3]
 Affzo[M:DLA4] :#80107
Endif
Return

$CHARGE
# Onglet Salarié
Read [F:ID]ID0=[M:DLA0]REFNUM
If !fstat
 [M:DLA0]=[F:ID]
 [M:DLA1]=[F:ID]
Endif

If [F:ID]NTT="FR"
 [M:DLA1]NTTTYP = 1
Else
 Read[TCY]TCY0=[F:ID]NTT
 If [F:TCY]EECFLG=2 : # Appartenance CEE
  [M:DLA1]NTTTYP = 2
 Else
  [M:DLA1]NTTTYP = 3
 Endif
Endif

Filter [HRCTR] Where REFNUM=[M:DLA0]REFNUM & CTRNUM=[M:DLA0]CTRNUM & CTRDAT<=[M:DLA0]DAT
Read [HRCTR]CTR1 Last
Filter [HRCTR]
If !fstat
 [M:DLA1]JOB    = [F:HRCTR]JOB
 [M:DLA1]DATANC = [F:HRCTR]DATANC
 [M:DLA1]QLF    = [F:HRCTR]QLF
 # FQ81085 - US 1553 02/05/13 - Civility LEG
 Call PARAM([F:HRCTR]ETRFCY,"CIVIL",WNUMLIB) From ADOVAL
 [M:DLA0]NOLIB=val(WNUMLIB)
 If [F:HRCTR]CIVCTR>0 Then
   [M:DLA0]CIVA=mess([F:HRCTR]CIVCTR,val(WNUMLIB),1)
   [M:DLA0]CIV=[F:HRCTR]CIVCTR
 Endif
 # END FQ81085 - US 1553
 Read[WAC]WAC0=[F:HRCTR]RSKWRK
 If !fstat
  [M:DLA1]CODRSK = [F:WAC]CODRSK
 Endif
 # FQ81085 - 23/04/13 - Les numéros de sécu arrivent du contrat, et plus du salarié
 [M:DLA1]NUMSSC  = [F:HRCTR]NUMSSCCTR
 [M:DLA1]NUMSSC2 = [F:HRCTR]NUMSSCCTR2

 [M:DLA1]ETRDAT = [F:HRCTR]CTRDAT
 Read [FCY]FCY0=[F:HRCTR]ETRFCY
 If !fstat
  [M:DLA2]FCY    = [F:FCY]FCY
  [M:DLA2]FCYCRN = [F:FCY]CRN
  Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
  If !fstat
   [M:DLA2]FCYADDLIG(0) = [F:BPA]BPAADDLIG(0)
   [M:DLA2]FCYADDLIG(1) = [F:BPA]BPAADDLIG(1)
   [M:DLA2]FCYADDLIG(2) = [F:BPA]BPAADDLIG(2)
   [M:DLA2]FCYPOSCOD    = [F:BPA]POSCOD
   [M:DLA2]FCYCTY       = [F:BPA]CTY
   [M:DLA2]FCYCRY       = [F:BPA]CRY
   [M:DLA2]FCYTEL       = [F:BPA]TEL
  Endif
  Read [CPY]CPY0=[F:FCY]LEGCPY
  If !fstat
   Read [BPA]BPA0=2;[F:CPY]CPY;[F:CPY]BPAADD
   If !fstat
    [M:DLA2]CPY          = [F:CPY]CPY
    [M:DLA2]CPYADDLIG(0) = [F:BPA]BPAADDLIG(0)
    [M:DLA2]CPYADDLIG(1) = [F:BPA]BPAADDLIG(1)
    [M:DLA2]CPYADDLIG(2) = [F:BPA]BPAADDLIG(2)
    [M:DLA2]CPYPOSCOD    = [F:BPA]POSCOD
    [M:DLA2]CPYCTY       = [F:BPA]CTY
    [M:DLA2]CPYCRY       = [F:BPA]CRY
   Endif
  Endif
  Read [F:CNT]CNT0=3;[F:FCY]FCY;[F:FCY]CNTNAM
  If !fstat
   Read [F:AIN]AIN0=[F:FCY]CNTNAM
   If !fstat
    [M:DLA2]FCYRPB    = [F:AIN]CNTLNA-[F:AIN]CNTFNA
    [M:DLA2]FCYRPBFNC = [F:CNT]CNTFNC
    Read [BPA]BPA0=3;[F:FCY]FCY;[F:CNT]BPAADD
    If !fstat
     [M:DLA2]PLCREF   = [F:BPA]CTY
    Endif
   Endif
  Endif
 Endif
Else
 # FQ81085 - US 1553 02/05/13 - Civility LEG
 Call PARAM([F:ID]FCYORI,"CIVIL",WNUMLIB) From ADOVAL
 [M:DLA0]NOLIB=val(WNUMLIB)
 If [F:ID]CIV>0 Then
    [M:DLA0]CIVA=mess([F:ID]CIV,val(WNUMLIB),1)
    [M:DLA0]CIV=[F:ID]CIV
 Endif
 # END FQ81085 - US 1553
Endif

[M:DLA2]DATREF = date$
#LIPET - 2017-05-20 - START
# Onglet accident
#** V7 : Waiting Time Mangement **#
#**If GTPS=1
#** If GNBHOR>0
#**  Call JOUR([M:DLA0]REFNUM,[M:DLA0]DAT,I1,D1,D2,I2,[M:DLA2]FCY,[M:DLA0]CTRNUM,1,[M:DLA3]HOUSTR(0),[M:DLA3]HOUEND(0),D3,C1,C2,I3) From SUBHRPLN
#**  Affzo [M:DLA3]HOUSTR(0),HOUEND(0)
#** Endif
#** If GNBHOR>1
#**  Call JOUR([M:DLA0]REFNUM,[M:DLA0]DAT,I1,D1,D2,I2,[M:DLA2]FCY,[M:DLA0]CTRNUM,2,[M:DLA3]HOUSTR(1),[M:DLA3]HOUEND(1),D3,C1,C2,I3) From SUBHRPLN
#**  Affzo [M:DLA3]HOUSTR(1),HOUEND(1)
#** Endif
#**Endif
#*!

If GTPS=1
 If GNBHOR>0
  Call JOUR([M:DLA0]REFNUM,[M:DLA0]DAT,I1,D1,D2,I2,[M:DLA2]FCY,[M:DLA0]CTRNUM,1,[M:DLA3]HOUSTR(0),[M:DLA3]HOUEND(0),D3,C1,C2,I3) From SUBPLN
  Affzo [M:DLA3]HOUSTR(0),HOUEND(0)
 Endif
 If GNBHOR>1
  Call JOUR([M:DLA0]REFNUM,[M:DLA0]DAT,I1,D1,D2,I2,[M:DLA2]FCY,[M:DLA0]CTRNUM,2,[M:DLA3]HOUSTR(1),[M:DLA3]HOUEND(1),D3,C1,C2,I3) From SUBPLN
  Affzo [M:DLA3]HOUSTR(1),HOUEND(1)
 Endif
Endif
#LIPET - 2017-05-20 - END
Return

$SETBOUT
Gosub SETBOUT From SUBMAL
Return

#86255
#Before selection on field REFNUM
#############
$AS_REFNUM
Raz GCURLEG
Return

#After selection on field REFNUM
############
$BS_REFNUM
# To do nothing if the user doesn't select a record
If mkstat>0
 If dim([M:DLA0]LEG)>=0
  GCURLEG=[M:DLA0]LEG
 Elsif GLEGFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif

Return
#
#SEGAY US1840 US1933 81085 25/09/2013
$BAS_CTRNUM
If status = 28
  If dim([M:DLA0]LEG)>0 : [M:DLA0]LEG=GCURLEG : Affzo [M:DLA0]LEG : Endif
Endif
Gosub BAS_CTRNUM From TOOLSHRLEG
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran DLA0) 23/06/2006 11:40:58 (LS)
######################################################################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
#If [F:ID]FLGMULCTR<>2
# Call CHERCHE_CTR(VALEUR,[M:DLA0]DAT,[M:DLA0]CTRNUM) From DIVPAYE
# Affzo [DLA0]CTRNUM
#Endif
#Call GRISE_CTRNUM([F:ID]FLGMULCTR)
#If GREP=""
# Filter [F:DLA] Where REFNUM=VALEUR
# Read [F:DLA]DLA0 Last
# Filter [DLA]
# If fstat<=2
#  [M:DLA0]=[F:DLA]
#  [M:DLA1]=[F:DLA]
#  [M:DLA2]=[F:DLA]
#  [M:DLA3]=[F:DLA]
#  Affzo [M:DLA0]
#  Affzo [M:DLA1]
#  Affzo [M:DLA2]
#  Affzo [M:DLA3]
#  mkstat = 4
# Else
#  GREP="D"
# Endif
#Endif
#JOJAC - START
Filter [F:DLA] Where REFNUM=VALEUR
Read [F:DLA]DLA0 Last
Filter [DLA]
If fstat<=2
#JOJAC - START
 #[M:DLA0]DAT = [F:DLA]DAT
 #[M:DLA0]CTRNUM = [F:DLA]CTRNUM
#JOJAC - END
Affzo [M:DLA0]DAT,CTRNUM
 #86255
 If dim([M:DLA0]LEG)>0 : [M:DLA0]LEG=[F:DLA]LEG : Affzo [M:DLA0]LEG : Endif
 GCURLEG=[F:DLA]LEG
Else
 Raz [M:DLA0]CTRNUM,DAT
 #86255
 If dim([M:DLA0]LEG)>0 : Raz [M:DLA0]LEG : Endif
 Raz GCURLEG
 mkstat=4
Endif
Call GRISE_CTRNUM([F:ID]FLGMULCTR)
#JOJAC - END
End


Subprog AM_DAT(VALEUR)
Variable Date    VALEUR
#Local Integer WOK
#If [F:ID]FLGMULCTR<>2
# Call CHERCHE_CTR([M:DLA0]REFNUM,VALEUR,[M:DLA0]CTRNUM) From DIVPAYE
# Affzo [DLA0]CTRNUM
# #MABOS-US 1553-
# Else
# WOK=0
# Call PRESEMPCTR([M:DLA0]REFNUM,VALEUR,VALEUR,[M:DLA0]CTRNUM,[L]WOK) From DIVPAYE
# If [L]WOK=0 Then  [M:DLA0]CTRNUM="" : Affzo [DLA0]CTRNUM: Endif
#Endif
# #end MABOS
Filter [F:DLA] Where REFNUM=[M:DLA0]REFNUM & DAT=VALEUR
Read [F:DLA]DLA0 Last
Filter [DLA]
If fstat<=2
 [M:DLA0]CTRNUM = [F:DLA]CTRNUM
 Affzo [M:DLA0]CTRNUM
 #86255
 If dim([M:DLA0]LEG)>0 : [M:DLA0]LEG=[F:DLA]LEG : Affzo [M:DLA0]LEG : Endif
 GCURLEG=[F:DLA]LEG
Else
 Raz [M:DLA0]CTRNUM
 #86255
 If dim([M:DLA0]LEG)>0 : Raz [M:DLA0]LEG : Endif
 Raz GCURLEG
 mkstat=4
 If [F:ID]FLGMULCTR<>2
  Call CHERCHE_CTR([M:DLA0]REFNUM,VALEUR,[M:DLA0]CTRNUM) From DIVPAYE
  If [M:DLA0]CTRNUM=""
   GMESSAGE=mess(158,10702,1) :#A créer
   mkstat=2 : End
  Endif
  #86255
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  If dim([M:DLA0]LEG)>0 : [M:DLA0]LEG=[F:CPY]LEG : Affzo [M:DLA0]LEG : Endif
  GCURLEG=[F:CPY]LEG
 Else
  GCURLEG=GLEGFIL
 Endif
 Affzo [M:DLA0]CTRNUM
Endif
End

