######################################################################################
## Etiquette ajoutée par le superviseur (écran DLA0) 23/05/2013 09:57:49 (LANEG)
######################################################################################
#86255
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End


######################################################################################

