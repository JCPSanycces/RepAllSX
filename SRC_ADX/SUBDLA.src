######################################################################################
#86255
Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
#Call CHERCHE_CTR([M:DLA0]REFNUM,[M:DLA0]DAT,VALEUR) From DIVPAYE
#If VALEUR=""
# GMESSAGE=mess(158,10702,1)
# mkstat=2 : End
#Endif
##86255
#Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
#Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#If dim([M:DLA0]LEG)>0 : [M:DLA0]LEG=[F:CPY]LEG : Affzo [M:DLA0]LEG : Endif
#GCURLEG=[F:CPY]LEG

Filter [HRCTR] Where REFNUM=[M:DLA0]REFNUM & CTRDAT<=[M:DLA0]DAT & CTRNUM=VALEUR
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If fstat<=2
 [M:DLA0]CTRNUM=VALEUR
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 If dim([M:DLA0]LEG)>0 : [M:DLA0]LEG=[F:CPY]LEG : Affzo [M:DLA0]LEG : Endif
 GCURLEG=[F:CPY]LEG
Else
 GCURLEG=GLEGFIL
 GMESSAGE=mess(158,10702,1)
 mkstat=2 : End
Endif

End
