#<AdxTL>@(#)0.0.0.0 $Revision$
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer   ERROR : ERROR = [V]CST_AOK

Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null

Local Char WDOSX3(GLONADS)
## Superviseur
Call PARAM("","SUPDOS",WDOSX3) From ADOVAL

If WDOSX3 <> ACTX.AFOLDER
 ASND.DATA='{}'
Else
 Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
 Call ADDFOLDER(NODES, ROOT, WDOSX3)
 Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO
Endif

$HANDLER_GET_EXIT
ASND.URL      = PSYR.PREFIX+'/foldersTree'
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+".foldersTree"
End ERROR

Subprog ADDFOLDER(NODES, NODE, NAME)
Variable Instance  NODES(1..)  Using C_ASYRJSO
Variable Instance  NODE          Using C_ASYRJSO
Value Char NAME

Local Instance  FOLDERS Using C_ASYRJSO  : FOLDERS=null
Local Instance  FOLD        Using C_ASYRJSO  : FOLD=null
Local Instance  HISTORY        Using C_ASYRJSO  : HISTORY=null

Local Char LEGS(250)

Local Char NAMES(20)(1..)
Local Char DOSHIS(20)(1..)
Local Integer I:I=0
Local Integer L
Local Integer ER


Onerrgo ERR
Local File ADOSSIER [ADS]
For [ADS]DOSSIER Where DOSREF=NAME and DOSSIER<>NAME
 Raz ER
 If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>=0
  Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW_]
  If !ER
   Read [ADW_]ADW0 = "";"";"TYPDOS"
   If !ER & !fstat & val([F:ADW_]VALEUR)-1=GPRODUIT
     I +=1 : NAMES(I) = [ADS]DOSSIER
     DOSHIS(I) = [ADS]DOSHIS
   Endif
  Endif
  Close Local File [ADW_]
 Endif
Next  ADS
Onerrgo

If maxtab(NAMES)
 Call JSON_ADDARRAY(NODES,NODE,"folders",FOLDERS) From ASYRJSO
 For I=1 To maxtab(NAMES)
  Call JSON_ADDOBJECT(NODES,FOLDERS,"",FOLD) From ASYRJSO
  If len(DOSHIS(I))
   Call JSON_ADDOBJECT(NODES,FOLD,"history",HISTORY) From ASYRJSO
   Call ADDFOLDER(NODES, HISTORY, DOSHIS(I))
  Endif
  Call JSON_ADDSTRING(NODES,FOLD,"name",NAMES(I))  From ASYRJSO

  Raz LEGS
  Read [ADS]DOSSIER = NAMES(I)
  For L=1 To [ADS]NBLEG
   If len(LEGS) : LEGS += ',' : Endif
   LEGS += [ADS]DOSLEG(L-1)
  Next L
  Call JSON_ADDSTRING(NODES,FOLD,"legislations",LEGS)  From ASYRJSO
  Call ADDFOLDER(NODES, FOLD, NAMES(I))
 Next I
Endif

Local File =NAME+".APATCH"   [APT]

Local Char VERX3,VERSUP,VERRUN,REL,NOP
Call ABOUT_X3(NAME,VERX3,VERSUP,VERRUN,REL,NOP)  From ABOUT_CSTD

#Get the date of the last maintenance :#SAM 120965
Read [APT]APT0 Last
Call JSON_ADDSTRING(NODES,NODE,'dat',num$([APT]DAT))  From ASYRJSO

#And then get the last type 'P' maintnenance :#SAM 120965
Filter [APT] Where TYP="P"
Read [APT]APT0 Last
Call JSON_ADDSTRING(NODES,NODE,'patnum',num$([APT]PATNUM))  From ASYRJSO
Call JSON_ADDSTRING(NODES,NODE,'nump',num$([APT]NUMP))  From ASYRJSO
Call JSON_ADDSTRING(NODES,NODE,'release',func ABOUT_CSTD.NEWVER(VERX3,NOP))  From ASYRJSO

Call JSON_ADDSTRING(NODES,NODE,'patch',num$([APT]NUM))  From ASYRJSO
Raz LEGS
Read [ADS]DOSSIER = NAME
For L=1 To [ADS]NBLEG
 If len(LEGS) : LEGS += ',' : Endif
 LEGS += [ADS]DOSLEG(L-1)
Next L
Call JSON_ADDSTRING(NODES,NODE,"legislations",LEGS)  From ASYRJSO
Call JSON_ADDSTRING(NODES,NODE,'name',[L]NAME)  From ASYRJSO

End


$ERR
ER = errn
Resume

