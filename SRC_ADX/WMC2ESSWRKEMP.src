####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 31 : JNTREFNUM Spouse's registration number ( Field EML 15)
####################################################################

$SET_JNTREFNUM
If [L]_AOLDVAL<>this.JNTREFNUM
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_JNTREFNUM
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.JNTREFNUM
 Gosub PROPAGATE_JNTREFNUM
Endif
Return

$INIT_JNTREFNUM
Gosub DECLARE_VAR From WMC0ESSWRKEMP
[L]CURPRO = "JNTREFNUM"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_JNTREFNUM
Gosub DECLARE_VAR From WMC0ESSWRKEMP
[L]CURPRO = "JNTREFNUM"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_JNTREFNUM             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_JNTREFNUM             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_JNTREFNUM
[L]CURPRO = "JNTREFNUM"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.JNTREFNUM,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_JNTREFNUM
[L]CURPRO = "JNTREFNUM"
If vireblc(this.JNTREFNUM,2)<>vireblc(format$("K:15c",this.JNTREFNUM),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_JNTREFNUM
[L]CURPRO = "JNTREFNUM"
If vireblc(this.JNTREFNUM,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPEML.ACTRLREF(this,"JNTREFNUM",this.JNTREFNUM,this.JNTREFNUM,2,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.JNTREFNUM<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_JNTREFNUM
[L]CURPRO = "JNTREFNUM"
Return

$PROPAGATE_JNTREFNUM
this.isReadonly = 0
[L]CURPRO = "JNTREFNUM"
Gosub _LNKPRO_JNTREFNUM
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_JNTREFNUM
Gosub DECLARE_VAR From WMC0ESSWRKEMP
[L]CURPRO = "JNTREFNUM"
$_LNKPRO_JNTREFNUM
If vireblc(this.JNTREFNUM,2)<>""
 # Link EMPLOID
 Local File EMPLOID [WID]
 Read [F:WID]ID0 = this.JNTREFNUM
 If !fstat
  [L]ASTATUS = fmet this.ASETATTRIBUTE("JNTREFNUM","$description",[F:WID]NAM)
 Endif
 LogicClose File [WID]
Endif
Return


