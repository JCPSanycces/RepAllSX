$PROPAGATE_SRV
this.isReadonly = 0
[L]CURPRO = "SRV"
Gosub _LNKPRO_SRV
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_SRV
Gosub DECLARE_VAR From WMC0ESSWRKEMP
[L]CURPRO = "SRV"
$_LNKPRO_SRV
If vireblc(this.SRV,2)<>""
 # Link SERVICE
 Local File SERVICE [WSRV]
 Read [F:WSRV]SRV0 = this.SRV
 If !fstat
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="SERVICE" & ZONE="DESSHO" & IDENT1=[F:WSRV]COD & IDENT2="" & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SRV","$title",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="SERVICE" & ZONE="DES" & IDENT1=[F:WSRV]COD & IDENT2="" & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SRV","$description",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
 Endif
 LogicClose File [WSRV]
Endif
Return


