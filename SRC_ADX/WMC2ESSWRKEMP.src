[L]CURPRO = "JNTTEL"
$_LNKPRO_JNTTEL
Local Char AFORMAT(50)
[L]ASTATUS =  func ASYRTRTATY.GETFORMATTEL(this,"JNTTEL",this.JNTTEL,[L]AFORMAT,this.CRY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]AFORMAT<>''
[L]AFORMAT='"'+[L]AFORMAT+'"'
[L]ASTATUS = fmet this.ASETATTRIBUTE("JNTTEL","$x3Format",[L]AFORMAT)
Endif
Return


