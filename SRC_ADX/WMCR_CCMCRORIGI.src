#<AdxTL>@(#)0.0.0.0 $Revision$Classe Initiateurs internes
# Superviseur
## CRUD-CLASSE ## CCMCRORIGI
# 2018-10-19 07:50:16 245


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File CCMCRORIGI [CCMCROI_]

If !SILENCE : Call TRACE("2 --> Local Instance C_CCMCRORIGI") From ASYRCOM : Endif
Local Instance CCMCRORIGI Using C_CCMCRORIGI

If !SILENCE : Call TRACE("3 --> New Instance C_CCMCRORIGI") From ASYRCOM : Endif
CCMCRORIGI = NewInstance C_CCMCRORIGI AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [CCMCROI_]CCMCROI0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of CCMCRORIGI") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.AREAD([CCMCROI_]CRID,[CCMCROI_]ORIGILN))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("CCMCRORIGI.CRID ="-num$(CCMCRORIGI.CRID)) From ASYRCOM
 Call TRACE("CCMCRORIGI.ORIGILN ="-num$(CCMCRORIGI.ORIGILN)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(CCMCRORIGI.AKEYS)
  Call TRACE("-"-num$(I)-":"-CCMCRORIGI.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [CCMCROI_]
FreeGroup CCMCRORIGI
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(CCMCRORIGI,ACLE,ASTATUS,_ETAG)
Variable Instance CCMCRORIGI Using C_CCMCRORIGI
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _CRID(20)
Local Shortint _ORIGILN
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_CRID = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_ORIGILN = val([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File CCMCRORIGI [CCMCROI]
Default File [F:CCMCROI]
Read [F:CCMCROI]CCMCROI0 = [L]_CRID;[L]_ORIGILN
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:CCMCROI]UPDTICK)>0
 [L]_ETAG = num$([F:CCMCROI]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(CCMCRORIGI,ACLE,ASTATUS)
Variable Instance CCMCRORIGI Using C_CCMCRORIGI
Value Char ACLE
Variable Integer ASTATUS
Local Char _CRID(20)
Local Shortint _ORIGILN
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_CRID = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_ORIGILN = val([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.AREAD([L]_CRID,[L]_ORIGILN))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(CCMCRORIGI,_CRID,_ORIGILN,ASTATUS)
Variable Instance CCMCRORIGI Using C_CCMCRORIGI
Value Char _CRID
Value Shortint _ORIGILN
Variable Integer ASTATUS

If CCMCRORIGI = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGI
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If CCMCRORIGI.APARENT=null
 [L]A_I = CCMCRORIGI.freeSnapshot
 CCMCRORIGI.snapshotEnabled = 0
 CCMCRORIGI.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & CCMCRORIGI.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If CCMCRORIGI.APARENT=null
 CCMCRORIGI.snapshotEnabled = 1
 CCMCRORIGI.setAccessorEnabled = 1
Endif
LogicClose File [CCMCROI]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI._ACTION_PARAM("AREAD_BEFORE",[L]_CRID,[L]_ORIGILN))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:CCMCROI]
Read [F:CCMCROI]CCMCROI0 = [L]_CRID;[L]_ORIGILN
If fstat
[L]A_ERROR = [L]_CRID+"~"+num$([L]_ORIGILN)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(CCMCRORIGI,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:CCMCROI]AUUID)>0 & [F:CCMCROI]AUUID=NullUuid
 [F:CCMCROI]AUUID = getUuid
Endif
SetInstance CCMCRORIGI With [F:CCMCROI]
CCMCRORIGI.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



