#################
# Class ALEGIS

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD"                  : Gosub AREAD
      When "AINSERT"                : Gosub AINSERT
      When "AUPDATE"                : Gosub AUPDATE
      When "ADELETE"                : Gosub ADELETE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return




#************************
#* CRUD for ALEGIS
#*!
$AREAD
Local File ATABDIV [ADI]
Read [ADI]CODE=909;CODE
If fstat = CST_AOK
  SetInstance this With [F:ADI]
  Local File ATEXTRA [AXX]
  For [AXX] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1="909" & IDENT2=CODE
    Call ASETTEXTRA(this.AXX,this.AllocGrp(),"LNGDES",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
    this.AXX(maxtab(this.AXX)).FLG = 0
  Next AXX
  For [AXX] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1="909" & IDENT2=CODE
    Call ASETTEXTRA(this.AXX,this.AllocGrp(),"SHODES",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
    this.AXX(maxtab(this.AXX)).FLG = 0
  Next AXX
Else
 ASTATUS= fmet this.ASETERROR("", mess(139,154,1), [V]CST_AERROR)
Endif

Return


###############################################################################################################################
$AINSERT
Return

###############################################################################################################################
$AUPDATE
Return

###############################################################################################################################
$ADELETE
Return

