#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UTIIND13 
# ---------------------------------------------------------------------- #
#      mise a jour du parametre champs VER dans APATCH
##########################################################################
Infbox "only update folder by patch"
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

# mettre a jour aussi le dossier X3
#If APPLI="X3" : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTIIND13 (APPLI)  
End



Subprog EXE_UTIIND13(LDOSSIER)
Value Char LDOSSIER

#----- Variables locales -----#
Local Char     WMSG(80)

#-----
Call ECR_TRACE("UTIIND13: Update APATCH for Folder "+LDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ZZZ]) =0  Local File =LDOSSIER+".APATCH"     [ZZZ] : Endif
If clalev([F:ZZR]) =0  Local File =LDOSSIER+".APATCH"     [ZZR] : Endif

#-----
$MISE_JOUR_APATCH
#-----------------------------#
#   mise a jour table APATCH  #
#-----------------------------#

Filter [ZZZ] Where TYP= "P" and VER <>160
# Changement du chmap ver dans patch : init par 160
Trbegin [ZZR] 
For [ZZZ]
 Read [ZZR]APT0 = [F:ZZZ]NUM
 If fstat = 0
         [F:ZZR]VER = 160
         Rewrite [ZZR] 
         If fstat 
              Call ERREUR("APATCH",2) From DOSDIC 
         Endif 
 Endif 
Next
Commit 
Filter [ZZZ]

#----- Fin du traitement -----#
$FIN_UTIIND13
WMSG ="UTIIND13: end of Update APATCH"
Call ECR_TRACE(WMSG,0) From GESECRAN

End



