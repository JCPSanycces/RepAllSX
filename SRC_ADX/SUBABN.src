#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion objet ABN
Raz GPILOBJ
Call OBJET("ABN",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_MODFIC"  : Gosub AVANT_MODFIC
 When "VERF_ANU"      : Gosub VERF_ANU
Endcase
Return

$OUVRE
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:BID])=0 : Local File BID        [BID] : Endif
Return

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

$AVANT_MODFIC
Local Integer RW
If [F:ABN]VLYSTR<>[M]VLYSTR or [F:ABN]VLYEND<>[M]VLYEND
 Call LECTURE("TCY",[M]CRY,"") From CONTOBJ
 For [BID] Where CRY=[M]CRY & left$([F:BID]BIDNUM,[F:TCY]BANLNG)=[F:ABN]BAN
  RW = 0
  If dim([BID]VLYSTR)>0 & [F:BID]VLYSTR<[M]VLYSTR
   [F:BID]VLYSTR = [M]VLYSTR
   RW = 1
  Endif
  If dim([BID]VLYEND)>0 & [M]VLYEND<>[0/0/0]
   If [F:BID]VLYEND=[0/0/0] or [F:BID]VLYEND>[M]VLYEND
    [F:BID]VLYEND = [M]VLYEND
    RW = 1
   Endif
  Endif
  If RW
   Rewrite [BID]
   If fstat
    GOK = 0 : Call FSTA("BID") From GLOCK : Break
   Endif
  Endif
 Next
Endif
Return

$VERF_ANU
Call LECTURE("TCY",[M:ABN1]CRY,"") From CONTOBJ
For [BID] Where CRY=[M:ABN1]CRY & left$([F:BID]BIDNUM,[F:TCY]BANLNG)=CODE
 OK = 0
 GMESSAGE = mess(174,133,1) : # Des RIB existent avec ce code guichet
 Break
Next
Return

Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("TCY",VALEUR,"") From CONTOBJ
If [F:TCY]BIDCTL<>2 or [F:TCY]BANLNG<1
 GMESSAGE = mess(172,133,1) : # Contrôle de banque non actif
 mkstat = 2 : End
Endif
End

Subprog C_BAN(VALEUR)
Variable Char    VALEUR()
Call LECTURE("TCY",[M]CRY,"") From CONTOBJ
If len(VALEUR)<>[F:TCY]BANLNG
 GMESSAGE = mess(111,123,1)-"("+num$([F:TCY]BANLNG)+")" : # Longueur incorrecte
 mkstat = 2 : End
Endif
End
