#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGTRTPUR09   Migration de la table TRANSPORT       Module Achat      #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif

If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR09") From LECFIC
  Endif
  #Call RAZ_UUMGTRTPUR09(DOSSIER)
  Call MAJ_UUMGTRTPUR09(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTPUR09(DOSSIER)
Value Char DOSSIER
Local Integer ERR   # Issue 99838 - 2018-07-27 by MAE


If [F:ADS]MODULE(5)<>2 : : # N= no module
  # Issue 119460 - 2016-10-27 by MAE : si le module n'existe pas, on sort
  # Issue X3-99838 - 2018-07-27 by MAE : on doit passer par le MIKSTKENDFLG pour passer la migration à terminée
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR09",3,ERR) From TRTMIG : #3=Terminée
  End
Endif


Local Char WNAMTRNPM
Call MIGTABNAME (DOSSIER,"TRANSPORT",WNAMTRNPM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR09",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMTRNPM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR09",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR09",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION (5)

Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR09",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

###################


Local Integer ERR, NBCOMMIT,NBLUS

Call ECR_TIME("UUMGTRTPUR09 tables TRANSPORT Process : Update TRANSPORT") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR09 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"TRANSPORT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:TRNP])  = 0 : Local File =DOSSIER+".TRANSPORT"    [TRNP]  : Endif   # Fichier X3 "Vide"

If clalev([F:TRNPM]) = 0 : Local File =DOSSIER+"."+WNAMTRNPM   [TRNPM] : Endif   # Fichier X3 renommé Avant Migration

If clalev([F:SHIPD]) = 0 : Local File =DOSSIER+".SHIPDOC"   [SHIPD] : Endif   # Documents logistiques

#-----  Déclaration des variables -----#
Local Char WTAB_TRNP (100) (adxwrb)
Local Shortint WCPT_TRNP
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=2
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz STOP, CRITERE, NBCOMMIT,NBLUS

# Déclaration des variables communes de travail
Local Integer I, J
Local Integer WNBLIN

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR09",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(2))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR09" : FILTRELIN=0 : Raz CRITERESPE : Raz HINTSPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_TRNP00
Raz NB

If STOP=1
 STOP = 0
 CRITERE = "[F:TRNPM]TRNNUM>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [TRNP]
GOK = 1

For [TRNPM] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  WNBLIN = 0
  NBLUS+=1
  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR09" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # version < V10, raz des champs v10
  If val(VERSION)<GMIGX3VER110
      #pas de raz de champs à faire
  Endif
  [F:TRNP] = [F:TRNPM]

  # Passage en V11
  If val(VERSION)<GMIGX3VER110
    Gosub MAJV11_TRNP
    If GOK<1 : Break : Endif
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  If GOK<1 : Break : Endif

  WriteB [F:TRNP]
  If fstat
    Call ECR_TRACE("File TRANSPORT, Error ="-num$(fstat),1) From GESECRAN
    Gosub TRNP_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  #---


  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:TRNPM]TRNNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR09",7,ERR) From TRTMIG : #7=Erreur
Else
  Flush [F:SHIPD]
    If fstat
        Call ECR_TRACE("File SHIPDOC, Error ="-num$(fstat),1) From GESECRAN
        Gosub TRNP_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  Flush [F:TRNP]
    If fstat
        Call ECR_TRACE("File TRANSPORT, Error ="-num$(fstat),1) From GESECRAN
        Gosub TRNP_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(2)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR09",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR09",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_TRNP00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [TRNP] #, [XXD]
Close Local File [TRNPM] #, [XXDM]
Close Local File [SHIPD]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"TRANSPORT",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTPUR09") From TRTMIG
Call ECR_TIME("UUMGTRTPUR09 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End
################################################
$MAJV11_TRNP

If [TRNP]MBOL <> AVOID.ACHAR
      Gosub CREATE_MBOL
    Endif
    If [TRNP]HBOL <> AVOID.ACHAR
      Gosub CREATE_HBOL
    Endif
    If [TRNP]AWB <> AVOID.ACHAR
      Gosub CREATE_AWB
    Endif
    If [TRNP]HAWB <> AVOID.ACHAR
      Gosub CREATE_HAWB
    Endif
    If [TRNP]CIM <> AVOID.ACHAR
      Gosub CREATE_CIM
    Endif
    If [TRNP]CMR <> AVOID.ACHAR
      Gosub CREATE_CMR
    Endif
    If [TRNP]CTBL <> AVOID.ACHAR
      Gosub CREATE_CTBL
    Endif
Return
################################################
$CREATE_MBOL
[F:SHIPD]VCRNUM = [F:TRNP]TRNNUM
[F:SHIPD]VCRTYP =  39
[F:SHIPD]SDLIN = WNBLIN + 1000
[F:SHIPD]SDTYPE = "MBOL"
[F:SHIPD]SDORI = 3
[F:SHIPD]SDREF1 = [F:TRNP]MBOL
[F:SHIPD]SDREF2 = [F:TRNP]VOYNUM
[F:SHIPD]SDBP = [F:TRNP]BPRNUM
[F:SHIPD]SDCMT = [F:TRNP]VESNAM +"/"+[F:TRNP]VESSEL
WNBLIN = [F:SHIPD]SDLIN
Gosub WRITE_SHIPD
Return
#########################################################################
$CREATE_HBOL
[F:SHIPD]VCRNUM = [F:TRNP]TRNNUM
[F:SHIPD]VCRTYP =  39
[F:SHIPD]SDLIN = WNBLIN + 1000
[F:SHIPD]SDTYPE = "BOL"
[F:SHIPD]SDORI = 3
[F:SHIPD]SDREF1 = [F:TRNP]HBOL
[F:SHIPD]SDREF2 = [F:TRNP]VOYNUM
[F:SHIPD]SDBP = [F:TRNP]BPRNUM
[F:SHIPD]SDCMT = [F:TRNP]VESNAM +"/"+[F:TRNP]VESSEL
WNBLIN = [F:SHIPD]SDLIN
Gosub WRITE_SHIPD
Return
#########################################################################
$CREATE_AWB
[F:SHIPD]VCRNUM = [F:TRNP]TRNNUM
[F:SHIPD]VCRTYP =  39
[F:SHIPD]SDLIN = WNBLIN + 1000
[F:SHIPD]SDTYPE = "AWB"
[F:SHIPD]SDORI = 2
[F:SHIPD]SDREF1 = [F:TRNP]AWB
[F:SHIPD]SDREF2 = [F:TRNP]FLINUM
[F:SHIPD]SDBP = [F:TRNP]BPRNUM
[F:SHIPD]SDCMT = [F:TRNP]FLYNAM
WNBLIN = [F:SHIPD]SDLIN
Gosub WRITE_SHIPD
Return
#########################################################################
$CREATE_HAWB
[F:SHIPD]VCRNUM = [F:TRNP]TRNNUM
[F:SHIPD]VCRTYP =  39
[F:SHIPD]SDLIN = WNBLIN + 1000
[F:SHIPD]SDTYPE = "HAWB"
[F:SHIPD]SDORI = 2
[F:SHIPD]SDREF1 = [F:TRNP]HAWB
[F:SHIPD]SDREF2 = [F:TRNP]FLINUM
[F:SHIPD]SDBP = [F:TRNP]BPRNUM
[F:SHIPD]SDCMT = [F:TRNP]FLYNAM
WNBLIN = [F:SHIPD]SDLIN
Gosub WRITE_SHIPD
Return
#########################################################################
$CREATE_CIM
[F:SHIPD]VCRNUM = [F:TRNP]TRNNUM
[F:SHIPD]VCRTYP =  39
[F:SHIPD]SDLIN = WNBLIN + 1000
[F:SHIPD]SDTYPE = "CIMCIV"
[F:SHIPD]SDORI = 5
[F:SHIPD]SDREF1 = [F:TRNP]CIM
[F:SHIPD]SDREF2 = [F:TRNP]WAGNUM
[F:SHIPD]SDBP = [F:TRNP]BPRNUM
[F:SHIPD]SDCMT = [F:TRNP]WAGNAM+"/"+[F:TRNP]TRANUM
WNBLIN = [F:SHIPD]SDLIN
Gosub WRITE_SHIPD
Return
#########################################################################
$CREATE_CMR
[F:SHIPD]VCRNUM = [F:TRNP]TRNNUM
[F:SHIPD]VCRTYP =  39
[F:SHIPD]SDLIN = WNBLIN + 1000
[F:SHIPD]SDTYPE = "CMR"
[F:SHIPD]SDORI = 4
[F:SHIPD]SDREF1 = [F:TRNP]CMR
[F:SHIPD]SDREF2 = [F:TRNP]REGNUM
[F:SHIPD]SDBP = [F:TRNP]BPRNUM
[F:SHIPD]SDCMT = [F:TRNP]ROANAM
WNBLIN = [F:SHIPD]SDLIN
Gosub WRITE_SHIPD
Return
#########################################################################
$CREATE_CTBL
[F:SHIPD]VCRNUM = [F:TRNP]TRNNUM
[F:SHIPD]VCRTYP =  39
[F:SHIPD]SDLIN = WNBLIN + 1000
[F:SHIPD]SDTYPE = "CTBL"
[F:SHIPD]SDORI = 1
[F:SHIPD]SDREF1 = [F:TRNP]CTBL
[F:SHIPD]SDREF2 = AVOID.ACHAR
[F:SHIPD]SDBP = AVOID.ACHAR
[F:SHIPD]SDCMT = AVOID.ACHAR
WNBLIN = [F:SHIPD]SDLIN
Gosub WRITE_SHIPD
Return
##############################################################################################
$WRITE_SHIPD
 WriteB [F:SHIPD]
  If fstat
    Call ECR_TRACE("File SHIPDOC, Error ="-num$(fstat)-" num ="-[F:SHIPD]VCRNUM,1) From GESECRAN
    Gosub TRNP_ERRTRA : # pour afficher les ref
    GOK=0 : Return
  Endif
Return
##############################################################################################
$TRNP_ERRTRA
Call ERRTRA (WTAB_TRNP,WCPT_TRNP,"File TRANSPORT(TRNNUM)=") From TRTMIG
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
Call MAJ_UUMGTRTPUR09(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR09(APPLI)
End

#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTPUR09(DOSSIER)
Value Char DOSSIER

Local Integer ERR
##1 - verifications
####################
If [F:ADS]MODULE(5)<>2 : End : Endif          : # N= no module

Local Char WNAMTRNPM
Call MIGTABNAME (DOSSIER,"TRANSPORT",WNAMTRNPM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMTRNPM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif

Call MIGTABRAZ (DOSSIER,"TRANSPORT",ERR) From TRTMIG

##2 - On vide les fichiers selon le cas
#######################################
Local Char VERSION(5)
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
   # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR08",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

If val(VERSION)<GMIGX3VER110
  #On vide la table SHIPDOC pour les transports
  Local File =DOSSIER+".SHIPDOC"  [SHIPD]
  Trbegin [SHIPD]
  Delete [SHIPD] Where VCRTYP=39
  Commit
Endif
  ##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR09",ERR) From TRTMIG

End

