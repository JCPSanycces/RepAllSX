         If !GIMPORT Affzo [PTX4]DISCRGSCR7 : Grizo [PTX4]DISCRGSCR7 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR7
       Endif
  When "DISCRGCOD8"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR8=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR8 : Grizo [PTX4]DISCRGSCR8 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR8
       Endif
  When "DISCRGCOD9"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR9=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR9 : Grizo [PTX4]DISCRGSCR9 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR9
       Endif

  # Issue 84129 - 2012-10-25 by MUARN : landed cost
  When "CPRCOECOD"
       If val(CZ)=3
         [M:PTX4]CPRCOESCR=1
         If !GIMPORT Affzo [PTX4]CPRCOESCR  : Grizo [PTX4]CPRCOESCR    : Endif
       Elsif !GIMPORT
