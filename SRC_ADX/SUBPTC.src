#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
  When "PRIFLG"
       If val(CZ)=1
         [M:PTC1]PRISCR=1
         If !GIMPORT Affzo [PTC1]PRISCR    : Grizo [PTC1]PRISCR    : Endif
       Elsif !GIMPORT
         Actzo [PTC1]PRISCR
       Endif
  When "LINAMTFLG"
       If val(CZ)=1
         [M:PTC1]LINAMTSCR=1
         If !GIMPORT Affzo [PTC1]LINAMTSCR : Grizo [PTC1]LINAMTSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC1]LINAMTSCR
       Endif
  When "OCNDATFLG"
       If val(CZ)=1
         [M:PTC1]OCNDATSCR=1
         If !GIMPORT Affzo [PTC1]OCNDATSCR : Grizo [PTC1]OCNDATSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC1]OCNDATSCR
       Endif
  When "OCNNUMFLG"
       If val(CZ)=1
         [M:PTC1]OCNNUMSCR=1
         If !GIMPORT Affzo [PTC1]OCNNUMSCR : Grizo [PTC1]OCNNUMSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC1]OCNNUMSCR
       Endif
  When "CLEFLG"
       If val(CZ)=1
         [M:PTC1]CLESCR=1
         If !GIMPORT Affzo [PTC1]CLESCR    : Grizo [PTC1]CLESCR    : Endif
       Elsif !GIMPORT
         Actzo [PTC1]CLESCR
       Endif
  When "REVFLG"
       If val(CZ)=1
         [M:PTC1]REVSCR=1
         If !GIMPORT Affzo [PTC1]REVSCR    : Grizo [PTC1]REVSCR    : Endif
       Elsif !GIMPORT
         Actzo [PTC1]REVSCR
       Endif
  When "SOHNUMFLG"
       If val(CZ)=1
         [M:PTC1]SOHNUMSCR=1
         If !GIMPORT Affzo [PTC1]SOHNUMSCR : Grizo [PTC1]SOHNUMSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC1]SOHNUMSCR
       Endif
  When "ORIFLG"
       If val(CZ)=1
         [M:PTC1]ORISCR=1
         If !GIMPORT Affzo [PTC1]ORISCR    : Grizo [PTC1]ORISCR    : Endif
       Elsif !GIMPORT
         Actzo [PTC1]ORISCR
       Endif
  When "LINTYPFLG"
       If val(CZ)=1
         [M:PTC1]LINTYPSCR=1
         If !GIMPORT Affzo [PTC1]LINTYPSCR : Grizo [PTC1]LINTYPSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC1]LINTYPSCR
       Endif
  When "ITMDESCOD"
       If val(CZ)=3
         [M:PTC3]ITMDESSCR=1
         If !GIMPORT Affzo [PTC3]ITMDESSCR : Grizo [PTC3]ITMDESSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC3]ITMDESSCR
       Endif
  When "ITMDES1COD"
       If val(CZ)=3
         [M:PTC3]ITMDES1SCR=1
         If !GIMPORT Affzo [PTC3]ITMDES1SCR : Grizo [PTC3]ITMDES1SCR : Endif
       Elsif !GIMPORT
         Actzo [PTC3]ITMDES1SCR
       Endif
  When "ITMKNDCOD"   # Issue 112754 - 2016-09-27 by SR : Services
       If val(CZ)=3
         [M:PTC3]ITMKNDSCR=1
         If !GIMPORT Affzo [PTC3]ITMKNDSCR : Grizo [PTC3]ITMKNDSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC3]ITMKNDSCR
       Endif
  When "ECCCOD"       # Issue 71276 - 2015-02-09 by SR : ECC
       If val(CZ) = 2 & [M:PTC3]ECCCODMIN=1
           [M:PTC3]ECCCODMIN = 2
           If !GIMPORT Affzo [PTC3]ECCCODMIN : Endif
       Endif
       If val(CZ)=3
         [M:PTC3]ECCSCR=1
         [M:PTC3]ECCCODMIN = 3
         [M:PTC3]ECCSCRMIN=1
         If !GIMPORT Affzo [PTC3]ECCSCR,ECCCODMIN,ECCSCRMIN : Grizo [PTC3]ECCSCR,ECCCODMIN,ECCSCRMIN : Endif
       Elsif !GIMPORT
         Actzo [PTC3]ECCSCR,ECCCODMIN,ECCSCRMIN
       Endif
   When "ECCCODMIN"       # Issue 71276 - 2015-02-09 by SR : ECC
       If val(CZ)=3
         [M:PTC3]ECCSCRMIN=1
         If !GIMPORT Affzo [PTC3]ECCSCRMIN : Grizo [PTC3]ECCSCRMIN : Endif
       Elsif !GIMPORT
         Actzo [PTC3]ECCSCRMIN
       Endif
  When "STOFCYCOD"
       If val(CZ)=3
         [M:PTC3]STOFCYSCR=1
         If !GIMPORT Affzo [PTC3]STOFCYSCR : Grizo [PTC3]STOFCYSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC3]STOFCYSCR
       Endif
  When "RCPFCYCOD"
       If val(CZ)=3
         [M:PTC3]RCPFCYSCR=1
         If !GIMPORT Affzo [PTC3]RCPFCYSCR : Grizo [PTC3]RCPFCYSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC3]RCPFCYSCR
       Endif
  When "RCPADDCOD"
       If val(CZ)=3
         [M:PTC3]RCPADDSCR=1
         If !GIMPORT Affzo [PTC3]RCPADDSCR : Grizo [PTC3]RCPADDSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC3]RCPADDSCR
       Endif
  When "USEPLCCOD"
       If val(CZ)=3
         [M:PTC3]USEPLCSCR=1
         If !GIMPORT Affzo [PTC3]USEPLCSCR : Grizo [PTC3]USEPLCSCR : Endif
       Elsif !GIMPORT
         Actzo [PTC3]USEPLCSCR
       Endif
  When "SCOADDCOD"
       If val(CZ)=3
