  If [M:PTX4]DISCRGSCR5=0 [M:PTX4]DISCRGSCR5=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR6)>0
  If [M:PTX4]DISCRGSCR6=0 [M:PTX4]DISCRGSCR6=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR7)>0
  If [M:PTX4]DISCRGSCR7=0 [M:PTX4]DISCRGSCR7=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR8)>0
  If [M:PTX4]DISCRGSCR8=0 [M:PTX4]DISCRGSCR8=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR9)>0
  If [M:PTX4]DISCRGSCR9=0 [M:PTX4]DISCRGSCR9=1 : Endif
Endif

# Issue 84129 - 2012-10-25 by MUARN : landed cost
If [M:PTX4]CPRCOECOD=0  [M:PTX4]CPRCOECOD=3  : Endif # Coeff approche et cout fixe unitaire (invisible)
If [M:PTX4]STCNUMCOD=0  [M:PTX4]STCNUMCOD=3  : Endif # structure (invisible)
If [M:PTX4]CSTPURCOD=0  [M:PTX4]CSTPURCOD=3  : Endif # coût achat (invisible)
If [M:PTX4]CPRCOD=0     [M:PTX4]CPRCOD=3     : Endif # cout stock (invisible)
# Issue 84130 - 2013-01-08 by MAE : landed cost
If [M:PTX4]REACSTPURCOD=0     [M:PTX4]REACSTPURCOD=3     : Endif # cout achat réalisé (invisible)
#MAE, landed cost
If [M:PTX4]QTYWEUCOD=0  [M:PTX4]QTYWEUCOD=3  : Endif # poids (invisible)
If [M:PTX4]QTYVOUCOD=0  [M:PTX4]QTYVOUCOD=3  : Endif # volume (invisible)


If [M:PTC1]PRIFLG=1     Grizo [PTC1]PRISCR     Else Actzo [PTC1]PRISCR     : Endif
If [M:PTC1]LINAMTFLG=1  Grizo [PTC1]LINAMTSCR  Else Actzo [PTC1]LINAMTSCR  : Endif
If [M:PTC1]OCNDATFLG=1  Grizo [PTC1]OCNDATSCR  Else Actzo [PTC1]OCNDATSCR  : Endif
If [M:PTC1]OCNNUMFLG=1  Grizo [PTC1]OCNNUMSCR  Else Actzo [PTC1]OCNNUMSCR  : Endif
If [M:PTC1]CLEFLG=1     Grizo [PTC1]CLESCR     Else Actzo [PTC1]CLESCR     : Endif
If [M:PTC1]REVFLG=1     Grizo [PTC1]REVSCR     Else Actzo [PTC1]REVSCR     : Endif
If [M:PTC1]SOHNUMFLG=1  Grizo [PTC1]SOHNUMSCR  Else Actzo [PTC1]SOHNUMSCR  : Endif
If [M:PTC1]ORIFLG=1     Grizo [PTC1]ORISCR     Else Actzo [PTC1]ORISCR     : Endif
If [M:PTC1]LINTYPFLG=1  Grizo [PTC1]LINTYPSCR  Else Actzo [PTC1]LINTYPSCR  : Endif
If [M:PTC3]ITMDESCOD=3  Grizo [PTC3]ITMDESSCR  Else Actzo [PTC3]ITMDESSCR  : Endif
If [M:PTC3]ITMDES1COD=3 Grizo [PTC3]ITMDES1SCR Else Actzo [PTC3]ITMDES1SCR : Endif
# Issue 112754 - 2016-09-27 by SR : Services
If [M:PTC3]ITMKNDCOD=3  Grizo [PTC3]ITMKNDSCR  Else Actzo [PTC3]ITMKNDSCR  : Endif
# Issue 71276 - 2015-02-09 by SR : ECC
If dim([M:PTC3]ECCCOD)>0
  If [M:PTC3]ECCCOD=3  Grizo [PTC3]ECCSCR  Else Actzo [PTC3]ECCSCR  : Endif
Endif
If dim([M:PTC3]ECCCODMIN)>0
