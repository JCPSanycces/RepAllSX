         If !GIMPORT Affzo [PTX4]DISCRGSCR2 : Grizo [PTX4]DISCRGSCR2 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR2
       Endif
  When "DISCRGCOD3"
       If val(CZ)=3
