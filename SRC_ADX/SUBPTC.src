$RAZCRE
[M:PTC0]PTRTYP=3
[M:PTC0]ENAFLG=2
#-----
[M:PTC1]LEDTYPSCR=1
If dim([M:PTC1]NBLEDTYP)>0
  [M:PTC1]NBLEDTYP=len(mess(0,2644,1)) : Affzo [PTC1]15
  For nolign=1 To [M:PTC1]NBLEDTYP
    [M:PTC1]LEDTYPINT(nolign-1)=nolign
    If func TRTX3CPT.TYPLEDAUTO(nolign)
      [M:PTC1]LEDTYPCOD(nolign-1)=3
      Grizo  [PTC1]LEDTYPCOD(nolign-1)
      Chgstl [PTC1]LEDTYPCOD(nolign-1) With "ITALIQUE"
    Else
      [M:PTC1]LEDTYPCOD(nolign-1)=1
    Endif
  Next nolign
Endif
