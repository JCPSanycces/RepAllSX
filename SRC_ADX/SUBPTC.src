         If !GIMPORT Affzo [PTC4]VAT2SCR   : Grizo [PTC4]VAT2SCR   : Endif
       Elsif !GIMPORT
         Actzo [PTC4]VAT2SCR
       Endif
  When "VAT3COD"
       If val(CZ)=3
