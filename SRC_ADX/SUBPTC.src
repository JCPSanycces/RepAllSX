         If !GIMPORT Affzo [PTX4]CSTPURSCR  : Grizo [PTX4]CSTPURSCR    : Endif
       Elsif !GIMPORT
         Actzo [PTX4]CSTPURSCR
       Endif
  When "CPRCOD"
       If val(CZ)=3
         [M:PTX4]CPRSCR=1
         If !GIMPORT Affzo [PTX4]CPRSCR  : Grizo [PTX4]CPRSCR    : Endif
       Elsif !GIMPORT
         Actzo [PTX4]CPRSCR
       Endif
# Issue 84130 - 2013-01-08 by MAE : landed cost
  When "REACSTPURCOD"
       If val(CZ)=3
         [M:PTX4]REACSTPURSCR=1
         If !GIMPORT Affzo [PTX4]REACSTPURSCR  : Grizo [PTX4]REACSTPURSCR    : Endif
       Elsif !GIMPORT
         Actzo [PTX4]REACSTPURSCR
       Endif
#MAE, landed cost
  When "QTYWEUCOD"
       If val(CZ)=3
         [M:PTX4]QTYWEUSCR=1
         If !GIMPORT Affzo [PTX4]QTYWEUSCR  : Grizo [PTX4]QTYWEUSCR    : Endif
       Elsif !GIMPORT
         Actzo [PTX4]QTYWEUSCR
       Endif

  When "QTYVOUCOD"
       If val(CZ)=3
         [M:PTX4]QTYVOUSCR=1
         If !GIMPORT Affzo [PTX4]QTYVOUSCR  : Grizo [PTX4]QTYVOUSCR    : Endif
       Elsif !GIMPORT
         Actzo [PTX4]QTYVOUSCR
       Endif


  When Default
       Gosub PE_PURTRS From SUBPTX
Endcase
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
Gosub CHARG_COMPLEMENT
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
Gosub CHARG_COMPLEMENT
Return

#---------------------------#
# Chargement complémentaire #
#---------------------------#
$CHARG_COMPLEMENT
[F:PTR]BPSCOD(1)   =[M:PTC2]BPSINVCOD
[F:PTR]BPSCOD(2)   =[M:PTC2]BPRPAYCOD
[F:PTR]ITMDESCOD(1)=[M:PTC3]ITMDES1COD
[F:PTR]ITMDESSCR(1)=[M:PTC3]ITMDES1SCR
[F:PTR]STOFCYCOD(1)=[M:PTC2]STOFCY1COD
[F:PTR]VATCOD(0)   =[M:PTC4]VAT1COD
[F:PTR]VATSCR(0)   =[M:PTC4]VAT1SCR
[F:PTR]VATCOD(1)   =[M:PTC4]VAT2COD
[F:PTR]VATSCR(1)   =[M:PTC4]VAT2SCR
[F:PTR]VATCOD(2)   =[M:PTC4]VAT3COD
[F:PTR]VATSCR(2)   =[M:PTC4]VAT3SCR
If dim([M:PTC4]TAXRCPCOD)>0
  [F:PTR]VATCOD(3)   =[M:PTC4]TAXRCPCOD
  [F:PTR]VATSCR(3)   =[M:PTC4]TAXRCPSCR
  [F:PTR]VATCOD(4)   =[M:PTC4]TAXISSCOD
  [F:PTR]VATSCR(4)   =[M:PTC4]TAXISSSCR
  [F:PTR]VATCOD(5)   =[M:PTC4]TAXOTH1COD
  [F:PTR]VATSCR(5)   =[M:PTC4]TAXOTH1SCR
  [F:PTR]VATCOD(6)   =[M:PTC4]TAXOTH2COD
  [F:PTR]VATSCR(6)   =[M:PTC4]TAXOTH2SCR
Endif
If dim([M:PTX4]DISCRGCOD1)>0
  [F:PTR]DISCRGCOD(0)=[M:PTX4]DISCRGCOD1
  [F:PTR]DISCRGSCR(0)=[M:PTX4]DISCRGSCR1
Endif
If dim([M:PTX4]DISCRGCOD2)>0
  [F:PTR]DISCRGCOD(1)=[M:PTX4]DISCRGCOD2
  [F:PTR]DISCRGSCR(1)=[M:PTX4]DISCRGSCR2
Endif
If dim([M:PTX4]DISCRGCOD3)>0
  [F:PTR]DISCRGCOD(2)=[M:PTX4]DISCRGCOD3
  [F:PTR]DISCRGSCR(2)=[M:PTX4]DISCRGSCR3
Endif
If dim([M:PTX4]DISCRGCOD4)>0
  [F:PTR]DISCRGCOD(3)=[M:PTX4]DISCRGCOD4
  [F:PTR]DISCRGSCR(3)=[M:PTX4]DISCRGSCR4
Endif
If dim([M:PTX4]DISCRGCOD5)>0
  [F:PTR]DISCRGCOD(4)=[M:PTX4]DISCRGCOD5
  [F:PTR]DISCRGSCR(4)=[M:PTX4]DISCRGSCR5
Endif
If dim([M:PTX4]DISCRGCOD6)>0
  [F:PTR]DISCRGCOD(5)=[M:PTX4]DISCRGCOD6
  [F:PTR]DISCRGSCR(5)=[M:PTX4]DISCRGSCR6
Endif
If dim([M:PTX4]DISCRGCOD7)>0
  [F:PTR]DISCRGCOD(6)=[M:PTX4]DISCRGCOD7
  [F:PTR]DISCRGSCR(6)=[M:PTX4]DISCRGSCR7
Endif
If dim([M:PTX4]DISCRGCOD8)>0
  [F:PTR]DISCRGCOD(7)=[M:PTX4]DISCRGCOD8
  [F:PTR]DISCRGSCR(7)=[M:PTX4]DISCRGSCR8
Endif
If dim([M:PTX4]DISCRGCOD9)>0
  [F:PTR]DISCRGCOD(8)=[M:PTX4]DISCRGCOD9
  [F:PTR]DISCRGSCR(8)=[M:PTX4]DISCRGSCR9
Endif
#-----
Gosub CHARGE_ATEXTRA From SUBPTC
Gosub PE_PURTRS      From SUBPTX
Return

#----------------------------------------#
# Création ou modif du texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA
Call MAJTEXTRA([M:PTC0]DESAXX,"PURTRS","DESAXX",num$([M:PTC0]PTRTYP),[M:PTC0]PTRNUM) From ATEXTRA
[F:PTR]PTRDES   =GLANGUE+"~"+[M:PTC0]DESAXX
[F:PTR]PTRTYPCAR=num$([F:PTR]PTRTYP)
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char    APPLI : Endif
If dim(OK)<0    Local Integer OK    : Endif
If APPLI="" APPLI=nomap : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO  (GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     WOPTION(15), WOPTION2(15)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK
# Issue 84130 - 2013-02-25 by SR : Pour écran CSTPOH
Local Char     MABREV(GLONABR)
#----- Noms fenêtres et traitement -----#
Local Char     WINREF1(GLONFEN)  : WINREF1="OPOH"
Local Char     NOMWIN1(GLONFEN)  : NOMWIN1="WOPOH"+[M:PTC0]PTRNUM
Local Char     WINREF2(GLONFEN)  : WINREF2="OPOI"
Local Char     NOMWIN2(GLONFEN)  : NOMWIN2="WOPOI"+[M:PTC0]PTRNUM
#----- Initialisation site d'expédition entête si besoin -----#
If [M:PTC2]STOFCY1COD=0
  If [M:PTC3]STOFCYCOD<>0
    [M:PTC2]STOFCY1COD=[M:PTC3]STOFCYCOD
  Else
    [M:PTC2]STOFCY1COD=3
  Endif
Endif
#----- 1er écran -----#
MFROM="POH1"
MTO="WE"+num$([M:PTC0]PTRTYP)+[M:PTC0]PTRNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:PTC2]BPSINVCOD>1 TZONE(IZON)="BPSINV"
                          TMOD(IZON) =[M:PTC2]BPSINVCOD
                          IZON+=1
                          TZONE(IZON)="BPAINV"
                          TMOD(IZON) =[M:PTC2]BPSINVCOD
                          IZON+=1
   Endif
   If [M:PTC2]BPRPAYCOD>1 TZONE(IZON)="BPRPAY"
                          TMOD(IZON) =[M:PTC2]BPRPAYCOD
                          IZON+=1
                          TZONE(IZON)="BPAPAY"
                          TMOD(IZON) =[M:PTC2]BPRPAYCOD
                          IZON+=1
   Endif
   If [M:PTC2]ORDREFCOD>1 TZONE(IZON)="ORDREF"
                          TMOD(IZON) =[M:PTC2]ORDREFCOD
                          IZON+=1
   Endif
   If [M:PTC2]PTECOD>1    TZONE(IZON)="PTE"
                          TMOD(IZON) =[M:PTC2]PTECOD
                          IZON+=1
   Endif
   If [M:PTC2]DEPCOD>1    TZONE(IZON)="DEP"
                          TMOD(IZON) =[M:PTC2]DEPCOD
                          IZON+=1
   Endif
   If [M:PTC2]BUYCOD>1    TZONE(IZON)="BUY"
                          TMOD(IZON) =[M:PTC2]BUYCOD
                          IZON+=1
   Endif
   If [M:PTC2]ORDREFCOD=2 &
&     [M:PTC2]PTECOD=2    &
&     [M:PTC2]DEPCOD=2    &
&     [M:PTC2]BUYCOD=2    TBLOC(1)=2
   Endif
   If [M:PTC2]ORDREFCOD=3 &
&     [M:PTC2]PTECOD=3    &
&     [M:PTC2]DEPCOD=3    &
&     [M:PTC2]BUYCOD=3    TBLOC(1)=1
   Endif
   If [M:PTC2]CURCOD>1    TZONE(IZON)="CUR"
                          TMOD(IZON) =[M:PTC2]CURCOD
                          IZON+=1
                          TZONE(IZON)="CHGTYP"
                          TMOD(IZON) =[M:PTC2]CURCOD
                          IZON+=1
                          TZONE(IZON)="CHGCOE"
                          TMOD(IZON) =[M:PTC2]CURCOD
                          IZON+=1
   Endif
   If [M:PTC2]CURCOD=2    TBLOC(2)=2
   Endif
   If [M:PTC2]CURCOD=3    TBLOC(2)=1
   Endif
   If [M:PTC2]VACBPRCOD>1 TZONE(IZON)="VACBPR"
                          TMOD(IZON) =[M:PTC2]VACBPRCOD
                          IZON+=1
   Endif
   If [M:PTC2]INVFCYCOD>1 TZONE(IZON)="INVFCY"
                          TMOD(IZON) =[M:PTC2]INVFCYCOD
                          IZON+=1
   Endif
   If [M:PTC2]STOFCY1COD>1 TZONE(IZON)="STOFCY"
                           TMOD(IZON) =[M:PTC2]STOFCY1COD
                           IZON+=1
   Endif
   If [M:PTC2]BPTCOD>1    TZONE(IZON)="BPTNUM"
                          TMOD(IZON) =[M:PTC2]BPTCOD
                          IZON+=1
   Endif
   If [M:PTC2]MDLCOD>1    TZONE(IZON)="MDL"
                          TMOD(IZON) =[M:PTC2]MDLCOD
                          IZON+=1
   Endif
   If [M:PTC2]EECICTCOD>1 TZONE(IZON)="EECICT2"
                          TMOD(IZON) =[M:PTC2]EECICTCOD
                          IZON+=1
                          TZONE(IZON)="ICTCTY2"
                          TMOD(IZON) =[M:PTC2]EECICTCOD
                          IZON+=1
   Endif
   # Issue 89502 - 2013-04-19 by MUARN : landed cost - code regroupement
   If [M:PTC2]GPGCODCOD>1 TZONE(IZON)="GPGCOD"
                          TMOD(IZON) =[M:PTC2]GPGCODCOD
                          IZON+=1
   Endif
   # Issue 71069 - 2013-07-29 by MAE : PJT en en-tête
   If [M:PTC2]PJTHCOD>1 TZONE(IZON)="PJTH"
                          TMOD(IZON) =[M:PTC2]PJTHCOD
                          IZON+=1
   Endif
   If [M:PTC2]RCPDAT1COD>1 TZONE(IZON)="EXTRCPDAT1"
                           TMOD(IZON) =[M:PTC2]RCPDAT1COD
                           IZON+=1
   Endif
   If [M:PTC2]VACBPRCOD=2  &
&     [M:PTC2]INVFCYCOD=2  &
&     [M:PTC2]STOFCY1COD=2 &
&     [M:PTC2]BPTCOD=2     &
&     [M:PTC2]MDLCOD=2     &
&     [M:PTC2]EECICTCOD=2  &
&     [M:PTC2]RCPDAT1COD=2 TBLOC(3)=2
   Endif
   If [M:PTC2]VACBPRCOD=3  &
&     [M:PTC2]INVFCYCOD=3  &
&     [M:PTC2]STOFCY1COD=3 &
&     [M:PTC2]BPTCOD=3     &
&     [M:PTC2]MDLCOD=3     &
&     [M:PTC2]EECICTCOD=3  &
&     [M:PTC2]RCPDAT1COD=3 TBLOC(3)=1
   Endif
   #----- Test si les sections d'entête sont affichées -----#
   If dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=2
      TBLOC(4)=2
      TZONE(IZON)="CCE"
      TMOD(IZON)=2
      IZON+=1
   Endif
   #----- Test si les sections d'entête sont invisibles -----#
   If (dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=3) | dim([M:DST]HEACCECOD)<1
      TBLOC(4)=1
      TZONE(IZON)="CCE"
      TMOD(IZON)=3
      IZON+=1
   Endif
   #----- Etat de la commande (signée-imprimée-soldée-recue-facturée) -----#
   If [M:PTC1]STAFLG=1    TZONE(IZON)="APPFLG"
                          TMOD(IZON) = 3
                          IZON+=1

                          TZONE(IZON)="PRNFLG"
                          TMOD(IZON) = 3
                          IZON+=1

                          TZONE(IZON)="CLEFLG"
                          TMOD(IZON) = 3
                          IZON+=1

                          TZONE(IZON)="RCPFLG"
                          TMOD(IZON) = 3
                          IZON+=1

                          TZONE(IZON)="INVFLG"
                          TMOD(IZON) = 3
                          IZON+=1
   Endif
   OPT1=2
   Gosub PE_PURTRS From SUBPTX
Else
   OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
