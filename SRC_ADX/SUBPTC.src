#<AdxTL>@(#)4.0.0.0 $Revision$ 
#######################################################################
# SUBPTC : Transactions de saisie des commandes std      MBT 10/11/97 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:PTR]PURTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWB]AWINBRO  Table des browsers            #
#                       [F:AWT]AWINBOUT Table des boutons             #
#                                                                     #
# Génération de 3 écrans de saisie à partir des écrans de base POH1   #
#                                                              POH2   #
#                                                              POH3   #
#                                                              POI1   #
# Nom des écrans générés : WExyyyyyz                                  #
#                            x = 1 pour appels d'offre                #
#                                2 pour demandes d'achat              #
#                                3 pour commandes std et par article  #
#                                5 pour commandes ouvertes            #
#                                8 pour factures / avoirs             #
#                                                                     #
#                        yyyyy = nom de la transaction (PTRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                0 et 1 pour appels d'offre           #
#                                1 pour demandes d'achat              #
#                                1 ,2 et 3 pour commandes standards   #
#                                9 pour commandes par article         #
#                                0, 1 et 2 pour commandes ouvertes    #
#                                0, 1, 2, 3 et 4 pour factures/avoirs #
#######################################################################

Call OBJET("PTC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="PTR"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=3
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:PTC0]PTRTYP=3
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="PURTRS" & IDENT1=num$([F:PTR]PTRTYP) & IDENT2=[F:PTR]PTRNUM
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="PTR"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "FERME"       : Call IMPSCR From ATRTX3
 When Default
Endcase
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
Local Char APPLI
APPLI=nomap
Return

#-----------------------------------------------------------#
# Ne traiter que les transactions de type commande standard #
#-----------------------------------------------------------#
$FILTRE
FILTSUP="PTRTYP=3"
Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
If GREP<>"" | !CLECUR | GHISTO
  Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
#----- Suppression de l'option "Changement de clé" -----#
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case REP
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#----------------------------------------#
# Après lecture de chaque enregistrement #
#----------------------------------------#
$LIENS
If [M:PTC1]LEDTYPSCR=0  [M:PTC1]LEDTYPSCR=1  : Endif
#-----
If dim([M:PTC1]NBLEDTYP)>0 & len(mess(0,2644,1))>0
  If [M:PTC1]NBLEDTYP=0  [M:PTC1]NBLEDTYP=len(mess(0,2644,1)) : Affzo [PTC1]15 : Endif
  For nolign=1 To [M:PTC1]NBLEDTYP
    If [M:PTC1]LEDTYPCOD(nolign-1)=0  [M:PTC1]LEDTYPCOD(nolign-1)=1 : Endif
    If func TRTX3CPT.TYPLEDAUTO(nolign)
      [M:PTC1]LEDTYPCOD(nolign-1)=3
      Grizo  [PTC1]LEDTYPCOD(nolign-1)
      Chgstl [PTC1]LEDTYPCOD(nolign-1) With "ITALIQUE"
    Endif
  Next nolign
Endif
#-----
[M:PTC2]BPSINVCOD =[F:PTR]BPSCOD(1)
[M:PTC2]BPRPAYCOD =[F:PTR]BPSCOD(2)
[M:PTC2]STOFCY1COD=[F:PTR]STOFCYCOD(1)
[M:PTC3]ITMDES1COD=[F:PTR]ITMDESCOD(1)
[M:PTC3]ITMDES1SCR=[F:PTR]ITMDESSCR(1)
[M:PTC4]VAT1COD   =[F:PTR]VATCOD(0)
[M:PTC4]VAT1SCR   =[F:PTR]VATSCR(0)
[M:PTC4]VAT2COD   =[F:PTR]VATCOD(1)
[M:PTC4]VAT2SCR   =[F:PTR]VATSCR(1)
[M:PTC4]VAT3COD   =[F:PTR]VATCOD(2)
[M:PTC4]VAT3SCR   =[F:PTR]VATSCR(2)
If dim([M:PTC4]TAXRCPCOD)>0
  [M:PTC4]TAXRCPCOD =[F:PTR]VATCOD(3)
  [M:PTC4]TAXRCPSCR =[F:PTR]VATSCR(3)
  [M:PTC4]TAXISSCOD =[F:PTR]VATCOD(4)
  [M:PTC4]TAXISSSCR =[F:PTR]VATSCR(4)
  [M:PTC4]TAXOTH1COD=[F:PTR]VATCOD(5)
  [M:PTC4]TAXOTH1SCR=[F:PTR]VATSCR(5)
  [M:PTC4]TAXOTH2COD=[F:PTR]VATCOD(6)
  [M:PTC4]TAXOTH2SCR=[F:PTR]VATSCR(6)
Endif
If dim([M:PTX4]DISCRGCOD1)>0
  [M:PTX4]DISCRGCOD1=[F:PTR]DISCRGCOD(0)
  [M:PTX4]DISCRGSCR1=[F:PTR]DISCRGSCR(0)
Endif
If dim([M:PTX4]DISCRGCOD2)>0
  [M:PTX4]DISCRGCOD2=[F:PTR]DISCRGCOD(1)
  [M:PTX4]DISCRGSCR2=[F:PTR]DISCRGSCR(1)
Endif
If dim([M:PTX4]DISCRGCOD3)>0
  [M:PTX4]DISCRGCOD3=[F:PTR]DISCRGCOD(2)
  [M:PTX4]DISCRGSCR3=[F:PTR]DISCRGSCR(2)
Endif
If dim([M:PTX4]DISCRGCOD4)>0
  [M:PTX4]DISCRGCOD4=[F:PTR]DISCRGCOD(3)
  [M:PTX4]DISCRGSCR4=[F:PTR]DISCRGSCR(3)
Endif
If dim([M:PTX4]DISCRGCOD5)>0
  [M:PTX4]DISCRGCOD5=[F:PTR]DISCRGCOD(4)
  [M:PTX4]DISCRGSCR5=[F:PTR]DISCRGSCR(4)
Endif
If dim([M:PTX4]DISCRGCOD6)>0
  [M:PTX4]DISCRGCOD6=[F:PTR]DISCRGCOD(5)
  [M:PTX4]DISCRGSCR6=[F:PTR]DISCRGSCR(5)
Endif
If dim([M:PTX4]DISCRGCOD7)>0
  [M:PTX4]DISCRGCOD7=[F:PTR]DISCRGCOD(6)
  [M:PTX4]DISCRGSCR7=[F:PTR]DISCRGSCR(6)
Endif
If dim([M:PTX4]DISCRGCOD8)>0
  [M:PTX4]DISCRGCOD8=[F:PTR]DISCRGCOD(7)
  [M:PTX4]DISCRGSCR8=[F:PTR]DISCRGSCR(7)
Endif
If dim([M:PTX4]DISCRGCOD9)>0
  [M:PTX4]DISCRGCOD9=[F:PTR]DISCRGCOD(8)
  [M:PTX4]DISCRGSCR9=[F:PTR]DISCRGSCR(8)
Endif
#-----
[M:PTC3]LABEL="("+mess(491,197,1)+")"
If [M:PTC0]ENAFLG=0     [M:PTC0]ENAFLG=2     : Endif
If [M:PTC1]INVDTACOD=0  [M:PTC1]INVDTACOD=1  : Endif : # Eléments facturation
# Issue 84130 - 2013-01-25 by MUARN : landed cost
If [M:PTC1]CSTCOD=0     [M:PTC1]CSTCOD=2  : Endif    : # Onglet coût
If [M:PTC2]BPSINVCOD=0  [M:PTC2]BPSINVCOD=3  : Endif : # Fournisseur facturant
If [M:PTC2]BPRPAYCOD=0  [M:PTC2]BPRPAYCOD=3  : Endif : # Tiers payé
If [M:PTC2]DEPCOD=0     [M:PTC2]DEPCOD=1     : Endif : # Escompte
If [M:PTC2]VACBPRCOD=0  [M:PTC2]VACBPRCOD=1  : Endif
If [M:PTC2]INVFCYCOD=0  [M:PTC2]INVFCYCOD=1  : Endif
If [M:PTC2]STOFCY1COD=0                              : # Site d'expédition entête
  If [M:PTC3]STOFCYCOD<>0
    [M:PTC2]STOFCY1COD=[M:PTC3]STOFCYCOD
  Else
    [M:PTC2]STOFCY1COD=3
  Endif
Endif
If [M:PTC2]EECICTCOD=0  [M:PTC2]EECICTCOD=3  : Endif : # Incoterm (code + ville)
If [M:PTC2]RCPDAT1COD=0 [M:PTC2]RCPDAT1COD=3 : Endif : # Date réception
If [M:PTC2]GPGCODCOD=0  [M:PTC2]GPGCODCOD=3  : Endif : # code regroupement issue 89502 landed cost

If [M:PTC2]PJTHCOD=0    [M:PTC2]PJTHCOD=3    : Endif : # Issue 71069 - 2013-07-29 by MAE : PJT en en-tête

If [M:PTC3]ITMDESCOD=0  [M:PTC3]ITMDESCOD=1  : Endif : # Désignation traduite
If [M:PTC3]ITMDES1COD=0 [M:PTC3]ITMDES1COD=3 : Endif : # Désignation standard
# Issue 112754 - 2016-09-27 by SR : Services
If [M:PTC3]ITMKNDCOD=0  [M:PTC3]ITMKNDCOD=1  : Endif : # Type d'article
# Issue 71276 - 2015-02-09 by SR : ECC
If dim([M:PTC3]ECCCOD)>0 &  [M:PTC3]ECCCOD=0
    [M:PTC3]ECCCOD=1
Endif
If dim([M:PTC3]ECCCODMIN)>0 &  [M:PTC3]ECCCODMIN=0
    [M:PTC3]ECCCODMIN=1
Endif
# End issue 71276
If [M:PTC3]STOFCYCOD=0  [M:PTC3]STOFCYCOD=3  : Endif : # Site d'expédition ligne
If [M:PTC3]RCPADDCOD=0  [M:PTC3]RCPADDCOD=3  : Endif : # Adresse site
If [M:PTC3]USEPLCCOD=0  [M:PTC3]USEPLCCOD=3  : Endif : # Lieu consommation
If [M:PTC3]SCOADDCOD=0  [M:PTC3]SCOADDCOD=3  : Endif : # Adresse sous-traitant
If [M:PTC3]UOMCOECOD=0  [M:PTC3]UOMCOECOD=1  : Endif : # Coefficient
If [M:PTC3]PURTYPCOD=0  [M:PTC3]PURTYPCOD=3  : Endif : # Type d'achat
If [M:PTC3]MATTOLCOD=0  [M:PTC3]MATTOLCOD=3  : Endif : # Match Explanation
If [M:PTC4]VAT1COD=0    [M:PTC4]VAT1COD=3    : Endif : # Code TVA 1
If [M:PTC4]VAT2COD=0    [M:PTC4]VAT2COD=3    : Endif : # Code TVA 2
If [M:PTC4]VAT3COD=0    [M:PTC4]VAT3COD=3    : Endif : # Code TVA 3
If dim([M:PTC4]TAXRCPCOD)>0
  If [M:PTC4]TAXRCPCOD=0  [M:PTC4]TAXRCPCOD=3  : Endif : # Taxe entrée
Endif
If dim([M:PTC4]TAXISSCOD)>0
  If [M:PTC4]TAXISSCOD=0  [M:PTC4]TAXISSCOD=3  : Endif : # Taxe sortie
Endif
If dim([M:PTC4]TAXOTH1COD)>0
  If [M:PTC4]TAXOTH1COD=0 [M:PTC4]TAXOTH1COD=3 : Endif : # Autre taxe 1
Endif
If dim([M:PTC4]TAXOTH2COD)>0
  If [M:PTC4]TAXOTH2COD=0 [M:PTC4]TAXOTH2COD=3 : Endif : # Autre taxe 2
Endif
If dim([M:PTX4]DISCRGCOD1)>0
  If [M:PTX4]DISCRGCOD1=0 [M:PTX4]DISCRGCOD1=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD2)>0
  If [M:PTX4]DISCRGCOD2=0 [M:PTX4]DISCRGCOD2=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD3)>0
  If [M:PTX4]DISCRGCOD3=0 [M:PTX4]DISCRGCOD3=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD4)>0
  If [M:PTX4]DISCRGCOD4=0 [M:PTX4]DISCRGCOD4=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD5)>0
  If [M:PTX4]DISCRGCOD5=0 [M:PTX4]DISCRGCOD5=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD6)>0
  If [M:PTX4]DISCRGCOD6=0 [M:PTX4]DISCRGCOD6=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD7)>0
  If [M:PTX4]DISCRGCOD7=0 [M:PTX4]DISCRGCOD7=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD8)>0
  If [M:PTX4]DISCRGCOD8=0 [M:PTX4]DISCRGCOD8=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD9)>0
  If [M:PTX4]DISCRGCOD9=0 [M:PTX4]DISCRGCOD9=1 : Endif
Endif
#-----
If [M:PTC1]STAFLG=0     [M:PTC1]STAFLG=2     : Endif
If [M:PTC1]LINAMTFLG=0  [M:PTC1]LINAMTFLG=1  : Endif
If [M:PTC1]LINTYPFLG=0  [M:PTC1]LINTYPFLG=1  : Endif
If [M:PTC1]PRISCR=0     [M:PTC1]PRISCR=1     : Endif
If [M:PTC1]LINAMTSCR=0  [M:PTC1]LINAMTSCR=1  : Endif
If [M:PTC1]OCNDATSCR=0  [M:PTC1]OCNDATSCR=1  : Endif
If [M:PTC1]OCNNUMSCR=0  [M:PTC1]OCNNUMSCR=1  : Endif
If [M:PTC1]CLESCR=0     [M:PTC1]CLESCR=1     : Endif
If [M:PTC1]REVSCR=0     [M:PTC1]REVSCR=1     : Endif
If [M:PTC1]SOHNUMSCR=0  [M:PTC1]SOHNUMSCR=1  : Endif
If [M:PTC1]ORISCR=0     [M:PTC1]ORISCR=1     : Endif
If [M:PTC1]LINTYPSCR=0  [M:PTC1]LINTYPSCR=1  : Endif
# Issue 42064 - 2011-12-26 by MUARN : PEC sur commande ajout contremarque
If [M:PTC1]PICRETFLG=0  [M:PTC1]PICRETFLG=2  : Endif
If [M:PTC3]ITMDESSCR=0  [M:PTC3]ITMDESSCR=1  : Endif
If [M:PTC3]ITMDES1SCR=0 [M:PTC3]ITMDES1SCR=1 : Endif
# Issue 112754 - 2016-09-27 by SR :Services
If [M:PTC3]ITMKNDSCR=0  [M:PTC3]ITMKNDSCR=1  : Endif
# Issue 71276 - 2015-02-09 by SR : ECC
If dim([M:PTC3]ECCSCR)>0 &  [M:PTC3]ECCSCR=0
    [M:PTC3]ECCSCR=1
Endif
If dim([M:PTC3]ECCSCRMIN)>0 &  [M:PTC3]ECCSCRMIN=0
    [M:PTC3]ECCSCRMIN=1
Endif
# End issue 71276
If [M:PTC3]STOFCYSCR=0  [M:PTC3]STOFCYSCR=1  : Endif
If [M:PTC3]RCPFCYSCR=0  [M:PTC3]RCPFCYSCR=1  : Endif
If [M:PTC3]RCPADDSCR=0  [M:PTC3]RCPADDSCR=1  : Endif
If [M:PTC3]USEPLCSCR=0  [M:PTC3]USEPLCSCR=1  : Endif
If [M:PTC3]SCOADDSCR=0  [M:PTC3]SCOADDSCR=1  : Endif
If [M:PTC3]PJTSCR=0     [M:PTC3]PJTSCR=1     : Endif
If [M:PTC3]QTYSTUSCR=0  [M:PTC3]QTYSTUSCR=1  : Endif
If [M:PTC3]UOMCOESCR=0  [M:PTC3]UOMCOESCR=1  : Endif
If [M:PTC3]PURTYPSCR=0  [M:PTC3]PURTYPSCR=1  : Endif
If [M:PTC3]MATTOLSCR=0  [M:PTC3]MATTOLSCR=1  : Endif
If [M:PTC4]QUAFLGSCR=0  [M:PTC4]QUAFLGSCR=1  : Endif
If GACTDEB=2 & dim([M:PTC4]EECINCSCR)>0
  If [M:PTC4]EECINCSCR=0  [M:PTC4]EECINCSCR=1  : Endif
Endif
If [M:PTC4]ORICRYSCR=0  [M:PTC4]ORICRYSCR=1  : Endif
If [M:PTC4]VAT1SCR=0    [M:PTC4]VAT1SCR=1    : Endif
If [M:PTC4]VAT2SCR=0    [M:PTC4]VAT2SCR=1    : Endif
If [M:PTC4]VAT3SCR=0    [M:PTC4]VAT3SCR=1    : Endif
If dim([M:PTC4]TAXRCPSCR)>0
  If [M:PTC4]TAXRCPSCR=0  [M:PTC4]TAXRCPSCR=1  : Endif
Endif
If dim([M:PTC4]TAXISSSCR)>0
  If [M:PTC4]TAXISSSCR=0  [M:PTC4]TAXISSSCR=1  : Endif
Endif
If dim([M:PTC4]TAXOTH1SCR)>0
  If [M:PTC4]TAXOTH1SCR=0 [M:PTC4]TAXOTH1SCR=1 : Endif
Endif
If dim([M:PTC4]TAXOTH2SCR)>0
  If [M:PTC4]TAXOTH2SCR=0 [M:PTC4]TAXOTH2SCR=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR1)>0
  If [M:PTX4]DISCRGSCR1=0 [M:PTX4]DISCRGSCR1=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR2)>0
  If [M:PTX4]DISCRGSCR2=0 [M:PTX4]DISCRGSCR2=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR3)>0
  If [M:PTX4]DISCRGSCR3=0 [M:PTX4]DISCRGSCR3=1 : Endif
Endif
