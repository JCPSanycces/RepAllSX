       Endif
  When "DISCRGCOD6"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR6=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR6 : Grizo [PTX4]DISCRGSCR6 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR6
       Endif
  When "DISCRGCOD7"
       If val(CZ)=3
