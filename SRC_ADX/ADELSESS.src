#<AdxTL>@(#)0.0.0.0 $Revision$
  Local Integer FIN: FIN=0
  Gosub INIT
  Gosub EXEC
  Call LEC_TRACE From LECFIC
End

##########################
$ACTION
  Case ACTION
    When "INIT"        : Gosub INIT
    When "INIT_DIA"    : Gosub INIT_DIA
    When "CONTROLE"    : Gosub CONTROLE
    When "CONT_BATCH"  : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "TITRE"       : Gosub TIT
  Endcase
Return


######################################################################################
# ACTION LABELS
######################################################################################
##########################
$INIT
  Local Mask    ADELSESS [DIA]

##########################
$INIT_DIA
  # FOLDER has to be a ROOT folder
  If !func ASESSIONS.IS_ROOT_FOLDER(nomap)
    GMESSAGE = nomap+" : "+mess(80,127,1) : # Vous devez être connecté sur le dossier racine
    GERR=1 : Return
  Endif

  Raz [M:DIA]
  [M:DIA]DOSSIER=nomap
  Affzo [M:DIA]DOSSIER
Return

##########################
$TIT
  TIT = mess(244,100,1) : # Suppression des sessions inactives
Return

##########################
$CONTROLE
  # FOLDER must exist
  If [M:DIA]DOSSIER="" : FIN = 1 : Return : Endif

  # FOLDER has to be a ROOT folder
  If !func ASESSIONS.IS_ROOT_FOLDER(nomap)
    GMESSAGE = [M:DIA]DOSSIER+" : "+mess(80,127,1) : # Vous devez être connecté sur le dossier racine
    GERR = 1 : Return
  Endif
Return

##########################
$EXEC
  Local Integer NBDEL_ASM3   : # Number of records deleted in ASYSSMDBASSO session table
  Local Integer NBDEL_ASM0   : # Number of records deleted in ASYSSMINTERN session table
  Local Integer NBDEL_ASM1   : # Number of records deleted in ASYSSMEXTERN session table
  Local Integer NBDEL_ASM2   : # Number of records deleted in ASYSSMPROCES session table
  Local Integer ASTATUS      : # Return_code returned by Funprog
  Local Char    MESSAGE(250) : # Message in case of error returned by Funprog

  # Calling the MAIN deletion procedure with the current folder as INPUT (must be a ROOT folder)
  [L]ASTATUS=func ASESSIONS.RAZ_DEAD_SESSION ([M:DIA]DOSSIER, [L]NBDEL_ASM3, [L]NBDEL_ASM0, [L]NBDEL_ASM1, [L]NBDEL_ASM2, [L]MESSAGE)

  # Processing results after calling the MAIN deletion procedure with the current folder as INPUT  (must be a ROOT folder)
  If [L]ASTATUS <> [V]CST_AOK
    [L]MESSAGE=mess(218,123,1)+" #"+num$([L]ASTATUS)+" : "+[L]MESSAGE : # Code retour global #n ...
    GMESSAGE=[L]MESSAGE
    GERR = 1 : Return
  Else
    Call ECR_TRACE(mess(246,100,1)+" :"+" ASYSSMDBASSO="+num$([L]NBDEL_ASM3) +
&                                       " ASYSSMINTERN="+num$([L]NBDEL_ASM0) +
&                                       " ASYSSMEXTERN="+num$([L]NBDEL_ASM1) +
&                                       " ASYSSMPROCES="+num$([L]NBDEL_ASM2),0) From GESECRAN
  Endif
Return


######################################################################################
# USER LABELS USED IN EXEC
######################################################################################
##########################


######################################################################################
# FUNCTIONS
######################################################################################
##########################

