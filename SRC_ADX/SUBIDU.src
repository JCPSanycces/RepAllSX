#<AdxTL>@(#)9.0.0.0 $Revision$
######################################################################################
Raz GPILOBJ
GBIDC1="200800000272"
GBIDC2="2009~ASN999999~20090101~1~1"
Call OBJET_CHAR(GBIDC1,"IDU",GBIDC2) From GOBJET
End


## Etiquette ajoutée par le superviseur (Objet IDU) 23/06/2009 17:34:23 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "VERF_ANU"    : Gosub VERF_ANU
Endcase
Return

$OUVRE
Gosub OUVRE From SUBIDA :#GCURLEG is already backed up in this treatment.
If clalev([F:IDA2])=0 : Local File IDADEMP    [IDA2] : Endif
If clalev([F:IDU2])=0 : Local File IDADEMP33  [IDU2] : Endif
If clalev([F:IDW2])=0 : Local File IDADEMP35  [IDW2] : Endif
Return

###################################
$SETBOUT    #pour désactiver le bouton nouveau & chgt clé
Call VIREBOUT (CHAINE,"CH") From GOBJET
If REP<>""| [F:IDA]FLGNEWSAL=2
 Call VIREBOUT (CHAINE,"G") From GOBJET
Endif
#Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR & VERROU : CHAINE+="A" : Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

###################################
$EXEBOUT
Case BOUT
 When "G"
  # Pas de lectcure si la création s'est mal passée...
  If !GOK : Return : Endif
  # Unlock la fiche qui était à l'écran quand on a fait "NOUVEAU"
  If VERROU : Gosub DEVERROU From GOBJET : Endif
 Gosub RAFFRAICHIR From GOBJSUB
 Gosub RELIT From GOBJSUB
Endcase
Return

###################################
$LIENS
# Multi_leg & multi_société
Call LECTURE("FCY",[M:IDU1]ETRFCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GSOCIETE=[F:CPY]CPY
GCURLEG=[F:CPY]LEG

#The read is in the object
[M:IDU1]NAM=[F:IDA]NAM
[M:IDU1]SRN=[F:IDA]SRN

Gosub CHARGE_EVT
Gosub CHARGE_PERIODE
Return

###################################
$CHARGE_EVT
# Tableau des evénements
nolign=0
For [IDV]IDV1 Where YEAEMPDDS=[M:IDU1]YEAEMPDDS & EMPDDS=[M:IDU1]EMPDDS
&  & ETRDAT=[M:IDU1]ETRDAT & CTRNUM=[M:IDU1]CTRNUM & TYPDAE=[M:IDU1]TYPDAE & REFCTR=[M:IDU1]REFCTR
 nolign += 1
 [M:IDU1]=[F:IDV]
Next
[M:IDU1]NBRDP1 = nolign
Return

###################################
$CHARGE_PERIODE
Effzo [M:IDU1]20
# Tableau des périodes
nolign=0
For [IDW]IDW0 Where YEAEMPDDS=[M:IDU1]YEAEMPDDS & EMPDDS=[M:IDU1]EMPDDS
&  & ETRDAT=[M:IDU1]ETRDAT & CTRNUM=[M:IDU1]CTRNUM & TYPDAE=[M:IDU1]TYPDAE & REFCTR=[M:IDU1]REFCTR
 nolign += 1
 [M:IDU1]STRDATCTR(nolign-1)=[F:IDW]STRDATCTR
 [M:IDU1]ENDDATCTR(nolign-1)=[F:IDW]ENDDATCTR
Next
[M:IDU1]NBRDP2 = nolign
Return

###################################
$INICRE
$INIMOD
Gosub SAUVE_EVT
Return

###################################
$SAUVE_EVT
Delete [IDV] Where YEAEMPDDS=[M:IDU1]YEAEMPDDS & EMPDDS=[M:IDU1]EMPDDS
&  & ETRDAT=[M:IDU1]ETRDAT & CTRNUM=[M:IDU1]CTRNUM & TYPDAE=[M:IDU1]TYPDAE
&  & REFCTR=[M:IDU1]REFCTR
If fstat=1
 GOK =-1 : GLOCK = "$IDADEMP34" : Return
Endif
For nolign=1 To [M:IDU1]NBRDP1
 [F:IDV]=[M:IDU1]
 [F:IDV]NUMLIG=nolign
 Write [IDV]
 If fstat<>0
  GOK = 0 : Call FSTA("IDV") From GLOCK : Break
 Endif
Next
Return

###################################
$FILTRE
If find("IDA",GPILCOD(1..GPILOBJ))
 If FILTSUP<>"" : FILTSUP += " & " : Endif
 FILTSUP -= "YEAEMPDDS='"+[F:IDA]YEAEMPDDS+"'"
 FILTSUP -= "& EMPDDS='"+[F:IDA]EMPDDS+"'"
 FILTSUP -= "& CTRNUM='"+[F:IDA]CTRNUM+"'"
 FILTSUP -= "& ETRDAT=["+format$("D:"+GFMDAT4,[F:IDA]ETRDAT)+"]"
 FILTSUP -= "& TYPDAE="+num$([F:IDA]TYPDAE)
Else
 If GUSRACS<>2
  If FILTSUP<>"" : FILTSUP += " & " : Endif
  FILTSUP -= '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
  FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
 Else
  FILTSUP ="1=1"
 Endif
Endif
Return

###################################
$FILGAUCHE
If find("IDA",GPILCOD(1..GPILOBJ))
 If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
 FILGAUSUP -= "YEAEMPDDS='"+[F:IDA]YEAEMPDDS+"'"
 FILGAUSUP -= "& EMPDDS='"+[F:IDA]EMPDDS+"'"
 FILGAUSUP -= "& CTRNUM='"+[F:IDA]CTRNUM+"'"
 FILGAUSUP -= "& ETRDAT=["+format$("D:"+GFMDAT4,[F:IDA]ETRDAT)+"]"
 FILGAUSUP -= "& TYPDAE="+num$([F:IDA]TYPDAE)
Endif
Return

###################################
$VERF_ANU
Trbegin [IDU],[IDV],[IDW]
 Delete [IDU] Where YEAEMPDDS=[M:IDU1]YEAEMPDDS & EMPDDS=[M:IDU1]EMPDDS
& & ETRDAT=[M:IDU1]ETRDAT & CTRNUM=[M:IDU1]CTRNUM & TYPDAE=[M:IDU1]TYPDAE
& & REFCTR=[M:IDU1]REFCTR
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP33" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDV] Where YEAEMPDDS=[M:IDU1]YEAEMPDDS & EMPDDS=[M:IDU1]EMPDDS
& & ETRDAT=[M:IDU1]ETRDAT & CTRNUM=[M:IDU1]CTRNUM & TYPDAE=[M:IDU1]TYPDAE
& & REFCTR=[M:IDU1]REFCTR
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP34" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDW] Where YEAEMPDDS=[M:IDU1]YEAEMPDDS & EMPDDS=[M:IDU1]EMPDDS
& & ETRDAT=[M:IDU1]ETRDAT & CTRNUM=[M:IDU1]CTRNUM & TYPDAE=[M:IDU1]TYPDAE
& & REFCTR=[M:IDU1]REFCTR
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP35" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard
Return

###################################
$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

###################################
$AB_ANN
Rollback
Return

###################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

######################################################################################
## Etiquettes écran
######################################################################################
Subprog IB_NBRDP2
If ![M]NBRDP2
 GBOUT1=""
Else
 GBOUT1=mess(12,101,1) :#"Périodes"
Endif
End

Subprog B1_NBRDP2
Local Char MATRI (GLONEML)
Local Char CLE2 (250)
MATRI=[M:IDU1]EMPDDS
CLE2=[M:IDU1]YEAEMPDDS+"~"+[M:IDU1]CTRNUM+"~"+num$([M:IDU1]ETRDAT)+"~"+num$([M:IDU1]TYPDAE)+"~"+[M:IDU1]REFCTR+"~"+num$([M]STRDATCTR(nolign-1))
Call OBJET_CHAR(MATRI,"IDW",CLE2) From GOBJET
Gosub CHARGE_PERIODE
Affzo [M:IDU1]20
End


Subprog C_EVECTRDAT(VALEUR)
Variable Date    VALEUR
#La date doit être comprise dans la période d'activité S41
If VALEUR<[M]ETRDAT | VALEUR>[M]XITDAT
 #Valeur non autorisée
 GMESSAGE=mess(100,10703,1)
 mkstat=2 : End
Endif
End
