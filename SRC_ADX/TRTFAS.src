#  [M:FAS5]FLD2C = mess(642,GML_MSGFAS,1)  : Affzo [M:FAS5]FLD2C
#  [M:FAS5]FLD2D = mess(643,GML_MSGFAS,1)  : Affzo [M:FAS5]FLD2D

