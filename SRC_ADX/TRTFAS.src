#--------------------------------------------------------------#
# S/P de contrôle de la date de sortie                         #
#--------------------------------------------------------------#
Subprog CONTROLE_DATE_SORTIE(PCPY, PISSDAT, PEXTISS, RERR )

  # Si la date de sortie est > à la date de fin de l'exercice courant du contexte fiscale & comptable
  # l'application doit demander confirmation à l'utilisateur

Value    Char    PCPY          # Société
Value    Date    PISSDAT       # Date de sortie
Value    Integer PEXTISS       # Sortie prévisionnelle ?
Variable Integer RERR          # Code retour

  RERR = 0
  If ( PISSDAT <> [0/0/0] and PEXTISS = G_NON ) Then
    If !clalev([F:CNX]) : Local File CONTEXT  [CNX] : Endif
    If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif
    Filter [CNX] Where CPY=PCPY and CNX=G300CPFI
    Read [CNX]CNX0 First
    Filter [CNX]
    Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
    Read [FIS]FIY0 Last
    Filter [FIS]
    If ( PISSDAT > [F:FIS]DATENDFIY ) Then : RERR = 1 :  Endif

    # Interdiction si sortie rétroactive (pour l'instant)
    If PISSDAT < [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
     RERR = 11
    Endif

  Endif

End
#--------------------------------------------------------------#
# S/P permettant de modifier l'intitulé des colonnes TVA déduc #
# PCG et IAS en fonction du taux de TVA de cession FQ27566     #
#--------------------------------------------------------------#
Funprog TVATITCOL(PTYP)
Value Char PTYP : # "PCG" ou "IAS"

Local Char LIBCOL (25)
  If ([M:FASS]ISSVATRAT = 0)
    If PTYP = "PCG"
      Call TEXTE(34941, LIBCOL) From OBJDIV : # "TVA reversement PCG"
    Else
      Call TEXTE(34942, LIBCOL) From OBJDIV : # "TVA reversement IFRS"
    Endif
  Else
    If PTYP = "PCG"
      Call TEXTE(35015, LIBCOL) From OBJDIV : # "TVA déduc compl PCG"
    Else
      Call TEXTE(35016, LIBCOL) From OBJDIV : # "TVA déduc cpl IAS/IFRS"
   Endif
  Endif

End LIBCOL
#--------------------------------------------------------------#
# S/P récupérant la devise de gestion d'un plan d'amortissement#
# passé en paramètre                                           #
#--------------------------------------------------------------#
Subprog GET_PLN_CUR(PCPY,PPLN,RCUR)
 Value    Char    PCPY    # Société
 Value    Integer PPLN    # Contexte
 Variable Char    RCUR    # Devise de la société

 Local Integer CNX
 If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif

 Call GET_CNX_FROM_PLAN(PCPY,PPLN,CNX) From GLOBIENS

 Read [CNX]CNX0=PCPY;CNX
 If fstat
  Raz RCUR
 Endif

 RCUR=[F:CNX]CUR

End
##########################################################################
Subprog CALCUL_MONTANTS_DEVISES(PMONTANT, PTAUX, PLIG)
Value Decimal PMONTANT
Value Decimal PTAUX
Value Integer PLIG

Local Integer STAT

  # Recalcul du montant en devises
  Call CONVERT3([M:FASS]CURCNX(0), [M:FASS]CURCNX(PLIG),    GCOUDEV, [M:FASS]CURTYPCNX(PLIG), [M:FASS]ISSDAT,
&               PMONTANT,          [M:FASS]ISSAMTCUR(PLIG), PTAUX,   STAT) From CPTSUB

  If STAT = 0 Then
    Call GET_MNT_ARRONDI ([M:FASS]ISSAMTCUR(PLIG), [M:FASS]CURCNX(PLIG), [M:FASS]ISSAMTCUR(PLIG)) From GLOBIENS
    Affzo [M:FASS]ISSAMTCUR(PLIG)
  Else
    GMESSAGE = mess(18,GML_MSGFAS,1)
    GERR=1
    mkstat = 2
  Endif
End

#=Fq-67621====================================================================
#--------------------------------------------------------------#
# Emission de la ligne  référence BCO / désignation dans la    #
# trace                                                        #
#--------------------------------------------------------------#
Subprog BCO_COMPTE_RENDU(PCPY,PREF,PDES,PSTATUS,PMES)
Value Char PCPY
Value Char PREF
Value Char PDES
Value Char PSTATUS
Value Char PMES

  If ACTSILENCE=G_OUI : End : Endif

  Local Char LIGNE(115)

  LIGNE ="  "
  LIGNE+=PREF
  LIGNE+=space$(20-len(PREF))
  LIGNE+=" ! "
  LIGNE+=PMES
  LIGNE+=space$(115-len(PMES))
  If    PSTATUS="Ok"
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  Elsif PSTATUS="Erreur"
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,1,1) From TRACEABX3
  Endif

  # FQ76400
  GPOINT="FASLOG" : Gosub ENTREE From EXEFNC
End

#--------------------------------------------------------------#
# Emission d'un séparateur dans la trace                       #
#--------------------------------------------------------------#
Subprog SEP_COMPTE_RENDU(PCPY)
Value Char PCPY

  If ACTSILENCE=G_OUI : End : Endif

  Local Char LIGNE(115)

  LIGNE="-------------------------------------------------------------------------------------------------------------------"
  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
End
#--------------------------------------------------------------#
# S/P récupérant la devise de gestion d'un contexte passé en   #
# paramètre                                                    #
#--------------------------------------------------------------#
Subprog GET_CNX_CUR(PCPY,PCNX,RCUR)
 Value    Char    PCPY    # Société
 Value    Integer PCNX    # Contexte
 Variable Char    RCUR    # Devise de la société

 If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif

 Read [CNX]CNX0=PCPY;PCNX
 If fstat
  Raz RCUR
 Endif

 RCUR=[F:CNX]CUR

End
