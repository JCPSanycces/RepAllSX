      GMENLOC(GVML_RPDRECH) = 1   : # Dédié à la récherche
      GMENLOC(GVML_RPALOGI) = 1   : # Logiciel 12 mois
      GMENLOC(GVML_RPCONCE) = 1   : # Regul/Reint Amortissement
      GMENLOC(GVML_RPABCON) = 1   : # Abandon caducité
      GMENLOC(GVML_RPPERIO) = 1   : # Basée sur période - PC,PD
      GMENLOC(GVML_RPEXERC) = 1   : # Basée sur exercice - PC, PD
      GMENLOC(GVML_RPBONUS) = 1   : # Bonus russe FQ59941
  Endcase

  If (evalue(G_COURPLN)) <> G301FIS
    # Les règles particulières générant de l'aide fiscale ne sont autorisées qu'au plan fiscal.
    GMENLOC(GVML_RPAID25) = 1   : # Aide 25 %
    GMENLOC(GVML_RPAID50) = 1   : # Aide 50 %
    GMENLOC(GVML_RPAID30) = 1   : # Majo. amort. de 30 % [17/10/01-31/03/02]
    GMENLOC(GVML_RPBOI30) = 1   : # Majo. taux 30 % bois [13/04/01-31/12/05]
    GMENLOC(GVML_RPENERG) = 1   : # Economie d'énergie
    GMENLOC(GVML_RPMAJ10) = 1   : # Majo. de 1 du coef. de dégressivité
    GMENLOC(GVML_RPPR39B) = 1   : # Presse (39 bis)
    GMENLOC(GVML_RPDRECH) = 1   : # Dédié à la récherche
  Endif

  If ( evalue(G_COURPLN) <> G301FIS or dim([M:FAS0]CPY) >= 0  and func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) <> "FRA")
    # FQ107988
    GMENLOC(GVML_RPDED40) = 1   : # Déduction 40 %
  Endif

  If (evalue(G_COURPLN)) <> G301FIS
    # Russie - FQ59941 La règle particulière "Bonus" n'est autorisée qu'au plan fiscal
    GMENLOC(GVML_RPBONUS) = 1   : # Bonus russe
  Endif

Return
#_________________________________________________________________________
#
#     C O N T R O L E
#_________________________________________________________________________


##########################################################################
Subprog CONTROLE_METHODE ( )
#
# Objet :   Ce sous programme contrôle la méthode d'amortissement applicable
#           au plan d'un bien d'une société
#
# Entrées : Mode d'amortissement
#           Contexte d'amortissement
#           Plan d'amortissement
#           Société
#           Type d'immobilisation (facultatif passer à 0 si non exploitation du paramètre)
#           Type de détention
#           Code forçage du Taux d'amortissement
#           Taux d'amortissement
#           Taux d'anticipato
#           Durée d'amortissement
#           Date de fin d'amortissement
#           Code véhicules
#           Règles particulières
#           Type de prorata
#           Coefficient accelérateur
#           Plan de production
#           Bien comptable en ligne
# Sorties : ERROR = 0  => OK

Local Integer LERROR
Local Integer SKIP_CTL : #*YYFIN-118207 Used for the SKPALWCTL Entry point

  [M:METH]MSGFIL = GML_MSGFAS
  [M:METH]MSGERR = 0

  #-- Contrôle au niveau du MODE
  Call CTRL_DPM ( [M:METH]DPM,
&                 [M:METH]CPY,
&                 [M:METH]CNX,
&                 [M:METH]DPRPLN,
&                 [M:METH]AASTYP,
&                 [M:METH]OWNTYP,
&                 [M:METH]PROPLN,
&                 [M:METH]FLGBCO,
&                 LERROR) From TRTFAS

  [M:METH]MSGERR = LERROR
  If ([M:METH]MSGERR) Then : End :  Endif

  # Contrôle mode UO
  If ( [M:METH]DPM = G_DPMUO or [M:METH]DPM = G_DPMUR) Then
    If ( [M:METH]DPRDUR = 0 and [M:METH]ENDDPRDAT = [0/0/0] ) Then
      Local File PROPLNH  [PPH]
      Read [PPH]PPH0=[M:METH]PROPLN
      If ( [F:PPH]PPLENDDAT0 <> [0/0/0] ) Then
        # La date de fin d'amortissement héritera de la date de fin du plan de production lors du calcul
      Else
        # Pour ce mode une date de fin d'amortissement ou une durée doit être renseignée
        [M:METH]MSGERR = 631 : End
      Endif
    Elsif ( [M:METH]STRDPRDAT <> [0/0/0] and [M:METH]ENDDPRDAT <> [0/0/0] and
&           [M:METH]STRDPRDAT >  [M:METH]ENDDPRDAT ) Then
      # La date de fin d'amortissement doit être postérieure à la date de début d'amortissement
      [M:METH]MSGERR = 635 : End
    Endif
  Endif

  # FQ82178 Contrôle fin amortissement forcée
  If ( [M:METH]ENDDPRFLG = G_OUI ) Then
     # Issue 116168 - If ( find([M:METH]DPM,  G_DPMRA, G_DPMRE) = 0 or  [M:METH]PRATYP <> GVML_TPJOUR ) Then
     # Issue 116168 - POR-idem for methods PC and PC
    If ( find([M:METH]DPM,  G_DPMRA, G_DPMRE, G_DPMPC, G_DPMPD) = 0 or
&      ( find([M:METH]DPM,   G_DPMRA, G_DPMRE) <>  0  ) and [M:METH]PRATYP <> GVML_TPJOUR )
      # Date de fin d'amortissement ne peut pas être forcée si le mode n'est pas RE ou RA ou PC ou PD et si le type de prorata n'est pas "Jour"
      [M:METH]MSGERR = 930 : End
    Endif
  Endif

  # Contrôle au niveau de la DUREE
  # FQ 54343
  Call CTRL_DPRDUR ([M:METH]DPRDUR, [M:METH]DPM, [M:METH]CPY, [M:METH]ALWCOD, [M:METH]ENDDPRFLG, LERROR )
  [M:METH]MSGERR = LERROR
  If ([M:METH]MSGERR) Then :  End :  Endif

  #-- Contrôle au niveau du TAUX
  # FQ55960 FQ59941 FQ77877 FQ84110 FQ84283, FQ84281, FQ105809
  # If ( [M:METH]DPRRATFLG = G_OUI and
  If ( [M:METH]DPRRATFLG = G_OUI and [M:METH]DPRRAT <> 0 and
&      find ([M:METH]DPM,  G_DPMUL, G_DPMCA, G_DPMDA, G_DPMUD, G_DPMTD, G_DPMDE, G_DPMDF, G_DPMDX, G_DPMDP,
&                   G_DPMDI, G_DPMRE, G_DPMFM, G_DPMLG, G_DPMPR, G_DPMSA, G_DPMSY, G_DPMUO,
&                   G_DPMRX, G_DPMRD, G_DPM1P, G_DPMAL, G_DPMAD, G_DPMHL,
&                   G_DPMDV, G_DPMRA, G_DPMDM, G_DPMLR, G_DPMCR, G_DPMDR, G_DPMSR, G_DPMUR ) <> 0 ) Then
    # Pour ce mode, le Taux ne doit pas être renseigné.
    [M:METH]MSGERR = 121 : End
  Endif

  If ( find([M:METH]DPM,  G_DPMIT, G_DPMLV  ) and  [M:METH]DPRRAT = 0 ) Then
    # Pour ce mode, le Taux doit être renseigné.
    [M:METH]MSGERR = 123 : End
  Endif
  If ( [M:METH]DPM = G_DPMDB and [M:METH]DPRRAT <> 0 and
&      [M:METH]DPRRAT <= (1/[M:METH]DPRDUR)          and
&      [M:METH]DPRRAT <= (1/[M:METH]DPRDUR) * 2 ) Then
    # Pour ce mode d'amortissement, si le taux est renseigné, il doit être > au taux linéaire
    # et < au double de ce même taux
    [M:METH]MSGERR = 572 : End
  Endif


  # -- Contrôle au niveau du TAUX2 FQ84283
  If ( find ([M:METH]DPM, G_DPMIT,  G_DPMLR, G_DPMCR, G_DPMAL, G_DPMAD ) = 0 ) Then
    If ( [M:METH]DPRRAT2 <> 0 ) Then
     # Dans cette configuration, le taux d'amortissement exceptionnel doit être à 0.
     [M:METH]MSGERR = 568 : End
    Endif
  Else
    If ( [M:METH]DPRRAT2 <> 0 ) Then
      If ([M:METH]DPM = G_DPMIT ) Then
        If not( func GLOBI8.TX_ANTICIPATO_PERMIS ( [M:METH]CPY, [M:METH]CNX, [M:METH]PURNAT,
&              [M:METH]STRDPRDAT, [M:METH]FIYSTRDAT, [M:METH]FIYENDDAT)  ) Then
          [M:METH]MSGERR = 568 : End
        Endif
      Endif
      # FQ59941
      If (find([M:METH]DPM, G_DPMLR, G_DPMCR ) > 0 and [M:METH]ALWCOD <> GVML_RPBONUS) Then
        [M:METH]MSGERR = 568 : End
      Endif
    Endif
    # FQ59941 FQ84283
    If ( find([M:METH]DPM, G_DPMLR, G_DPMCR, G_DPMAL, G_DPMAD) <> 0 and ( [M:METH]DPRRAT2 < 0 and [M:METH]DPRRAT2 > 1 ) )
      # "La valeur doit être comprise en 0 et 1"
      [M:METH]MSGERR = 253 : End
    Endif
  Endif

  #-- Contrôle au niveau de TAUX/DUREE
  If ( [M:METH]DPRRAT = 0 and [M:METH]DPRDUR = 0 and
&      find( [M:METH]DPM, G_DPMLE, G_DPMLP, G_DPMPC, G_DPMPD, G_DPMLB, G_DPMML, G_DPMMD, G_DPMRL, G_DPMHD, G_DPMTL) <> 0 ) Then
    # Pour ce mode, la Durée et/ou le Taux doivent être renseignés. FQ67577 FQ77877 FQ72372 FQ84281 FQ105809
    [M:METH]MSGERR = 440
    End
  Endif

  If ( [M:METH]DPM = G_DPMSA and ( [M:METH]DPRDUR <> 0 or ([M:METH]DPRRAT <> 0 and [M:METH]DPRRATFLG = G_OUI)) ) Then
    # Pour ce mode d'amortissement, les champs "Durée" et "Taux"  doivent être à 0.
    [M:METH]MSGERR = 120 : End
  Endif

  #-- Contrôle au niveau COEF ACCEL. FQ59941 FQ67577 FQ72372 FQ105809
  If ( [M:METH]ACLCOE <> 0 and
&      find([M:METH]DPM , G_DPMUD, G_DPMTD, G_DPMDB, G_DPMLR, G_DPMDR, G_DPMCR, G_DPMML, G_DPMMD) = 0  ) Then
    # Le coefficient d'accélération n'a pas lieu d'être précisé  pour ce mode
    [M:METH]MSGERR = 569 : End
  Endif
  If ( [M:METH]ACLCOE <> 0 and find([M:METH]DPM , G_DPMDB) <> 0 and ([M:METH]ACLCOE < 1. or [M:METH]ACLCOE > 2.) ) Then
    # Le coefficient d'accélération pour le dégressif belge  doit être > à 1 et <= 2.
    [M:METH]MSGERR = 575 : End
    mkstat = 2 : End
  Endif
  # FQ59941
  If ( [M:METH]ACLCOE <> 0 and find([M:METH]DPM , G_DPMLR, G_DPMDR, G_DPMCR) <> 0 and ([M:METH]ACLCOE < 0. or [M:METH]ACLCOE > 3.) ) Then
    # Le coefficient d'accélération pour les modes russes  doit être > à 0 et <= 3.
    [M:METH]MSGERR = 809 : End
    mkstat = 2 : End
  Endif

  #-- Contrôle au niveau TYPE PRORATA    FQ84281, FQ105809
  If ( find([M:METH]DPM , G_DPMUD, G_DPMTD, G_DPMUL, G_DPMRE, G_DPMHL, G_DPMHD, G_DPMTL ) <> 0 and [M:METH]PRATYP = 0 ) Then
    # Le type de prorata doit être saisi pour les modes ci-dessus.
    [M:METH]MSGERR = 571 : End
  Endif
  #- FQ84281 FQ105809
  If ( find([M:METH]DPM , G_DPMHL, G_DPMHD, G_DPMTL ) <> 0 and find([M:METH]PRATYP, GVML_TPJOUR, GVML_TPMOIS) = 0 ) Then
    # Pour ce mode, le prorata ne peut être que "Jour" ou "Mois"
    [M:METH]MSGERR = 901 : End
  Endif

  #-- Contrôle au niveau REGLE PARTIC.
  # FQ59941 FQ84281 FQ105809 FQ107988 X3-61112
  If ([M:METH]ALWCOD = GVML_RPDED40) Then
    # FQ107988
    #    If ([M:METH]DPRPLN <> G301FIS or func GLOFCYCPY.GET_SOC_LEG([M:METH]CPY) <> "FRA" or
    #&       not ([M:METH]PURDAT >= [15/04/2015] and [M:METH]PURDAT <= [14/04/2016]) ) Then
    # X3-61112
    #    If ([M:METH]DPRPLN <> G301FIS or func GLOFCYCPY.GET_SOC_LEG([M:METH]CPY) <> "FRA" or
    #&       not ([M:METH]PURDAT >= [15/04/2015] and [M:METH]PURDAT <= [14/04/2017]) ) Then
    #      # Cette règle particulière n'est pas valide
    #      [M:METH]MSGERR = 570 : End
    #    Endif

    #*X3-61112 the 40% deduction is now permitted if the date of purchase is after 14th April 2017
    If   ([M:METH]DPRPLN <> G301FIS or func GLOFCYCPY.GET_SOC_LEG([M:METH]CPY) <> "FRA"  or
&    not ([M:METH]PURDAT >= [15/04/2015]) )
      # This particular rule is invalid
      [M:METH]MSGERR = 570 :  End
    Else
      If ( dim (ACTTYPGES)< 0 )  # quand on ne passe pas par une action métier uniquement
        If ([M:METH]DPRPLN = G301FIS and func GLOFCYCPY.GET_SOC_LEG([M:METH]CPY) = "FRA"  and
&           [M:METH]PURDAT > [14/04/2017] )
          # Warning message: 942 & 943
          [M:METH]MSGERR = func TRTFAS.IS_MACRON_LAW_OK() :  End
        Endif
      Endif
    Endif
  Else
    If ( ( [M:METH]DPM = G_DPMCA and find([M:METH]ALWCOD, GVML_RPAUCUN, GVML_RPCONCE, GVML_RPABCON) = 0 ) or
&        ( [M:METH]DPM = G_DPMLB and find([M:METH]ALWCOD, GVML_RPAUCUN, GVML_RPLBDBL, GVML_RPLBABA) = 0 ) or
&        ( ( [M:METH]DPM = G_DPMPC or [M:METH]DPM = G_DPMPC ) and find([M:METH]ALWCOD,
&                                                         GVML_RPPERIO, GVML_RPEXERC) = 0 ) or
&        ( ( find([M:METH]DPM, G_DPMHL, G_DPMHD, G_DPMTL) > 0 ) and find([M:METH]ALWCOD,
&                                                         GVML_RPAUCUN, GVML_RPA1EXD) = 0 ) or
&        ( [M:METH]DPM = G_DPMLP and find([M:METH]ALWCOD, GVML_RPAUCUN, GVML_RPA1EXD, GVML_RPALOGI,
&                                                         GVML_RPAID25, GVML_RPAID50, GVML_RPPR39B) = 0 ) or
&        ( [M:METH]DPM = G_DPMLR and find([M:METH]ALWCOD, GVML_RPAUCUN, GVML_RPBONUS) = 0 ) or
&        ( [M:METH]DPM = G_DPMCR and find([M:METH]ALWCOD, GVML_RPAUCUN, GVML_RPBONUS) = 0 ) or
&        ( [M:METH]DPM = G_DPMDF and find([M:METH]ALWCOD, GVML_RPAID25, GVML_RPAID50, GVML_RPPR39B,
&                                                       GVML_RPAID30, GVML_RPBOI30, GVML_RPENERG,
&                                                       GVML_RPMAJ10, GVML_RPDRECH, GVML_RPAUCUN) = 0 )) Then
      # Cette règle particulière n'est pas valide FQ59941 FQ84281 FQ105809
      [M:METH]MSGERR = 570 : End
    Endif

    #*YYFIN-118207
    #GGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGG
    #G   Entry point    SKPALWCTL
    #GGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGG
    SKIP_CTL = G_NON
    GPOINT = "SKPALWCTL" :   Gosub ENTREE From EXEFNC
    If SKIP_CTL = G_NON
      If ( [M:METH]ALWCOD <> GVML_RPAUCUN and
&          ( (find([M:METH]DPM, G_DPMCA, G_DPMLB, G_DPMPC, G_DPMPD, G_DPMLP, G_DPMDF,
&                               G_DPMLR, G_DPMCR, G_DPMHL, G_DPMHD, G_DPMTL ) = 0 ) or
&            ( ([M:METH]DPM = G_DPMLP or [M:METH]DPM = G_DPMDF) and
&              ([M:METH]DPRPLN = G301IAS or func GLOFCYCPY.GET_SOC_PAYS([M:METH]CPY)<>"FR")      )   ) ) Then
        # Cette règle particulière n'est pas valide FQ59941 FQ84281
        [M:METH]MSGERR = 570 : End
      Endif
    Endif
    #*End YYFIN-118207

    If ( [M:METH]ALWCOD = GVML_RPAID30 and
&        ([M:METH]STRDPRDAT < [17/10/2001] or [M:METH]STRDPRDAT > [31/03/2002])   ) Then
      # Cette règle particulière n'est pas valide
      [M:METH]MSGERR = 570 : End
    Endif
    # FQ96004
  #  If ( [M:METH]ALWCOD = GVML_RPBOI30 and
  #&      ([M:METH]STRDPRDAT < [13/04/2001] or [M:METH]STRDPRDAT > [31/12/2005])   ) Then
    If ( [M:METH]ALWCOD = GVML_RPBOI30 and not
&       (([M:METH]PURDAT >= [13/04/2001] and [M:METH]PURDAT <= [31/12/2005]) or
&        ([M:METH]PURDAT >= [26/09/2008] and [M:METH]PURDAT <= [31/12/2011]) or
&        ([M:METH]PURDAT >= [13/11/2013] and [M:METH]PURDAT <= [31/12/2016]))      ) Then
      # Cette règle particulière n'est pas valide
      [M:METH]MSGERR = 570 : End
    Endif
  Endif

  #-- Contrôle au niveau VEHICULE
  If ( [M:METH]CRBVEHCOD <> "" and [M:METH]DPRPLN <> G301FIS ) Then
    # Code véhicule ne peut être renseigné que pour le plan FISCAL.
    [M:METH]MSGERR = 119 : End
  Endif

  # La valeur résiduelle pour le plan fiscal d'un bien d'une société française doit être nulle
  If (  [M:METH]RSDVAL <> 0 and [M:METH]DPRPLN = G301FIS and
&       (func GLOFCYCPY.GET_SOC_PAYS([M:METH]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:METH]CPY) = "FRA")  ) Then
    #GERR= 1: GMESSAGE = mess(586,GML_MSGFAS,1)
    [M:METH]MSGERR = 586
    mkstat = 2
    End
  Endif

  # La valeur résiduelle pour le mode CA doit être nulle
  If (  [M:METH]RSDVAL <> 0 and [M:METH]DPM = G_DPMCA ) Then
    GERR= 1: GMESSAGE = mess(609,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif

  # Un mode d'amortissement doit être renseignée pour chaque plan
  If (  [M:METH]DPM = "") Then
    [M:METH]MSGERR = 49 : End
  Endif

  # La date de début d'amortissement ne doit pas être nulle
  If (  [M:METH]STRDPRDAT = [0/0/0] ) Then
    [M:METH]MSGERR = 538 : End
  Endif

  # CBO 2012.01.23 FQ69691B : si le plan IAS n'existe pas, ne pas tester dessus
  # ajout de GCNXPROIAS = G_OUI and
  # Si la nature comptable PCG ou IAS est "En cours" le mode d'amortissement doit être "SA"
  If ( ([M:METH]GACACN = GVML_NIENCOU or (GCNXPROIAS = G_OUI and [M:METH]IASACN = GVML_NIENCOU)) ) Then
    # FQ119342
    If ([M:METH]DPM <> G_DPMSA) Then
      If find([M:METH]DPRPLN, G301LI1,G301LI2,G301LI3, G301LI4, G301LI5, G301LI6) > 0
        Local Char LPARAM
        Call PARAM([M:METH]CPY,"WIPDEP",LPARAM) From ADOVAL
        # Un autre mode que "SA" est autorisé sur un plan libre selon param. (WIPDEP)
        If (val(LPARAM) <> G_OUI ) Then
          [M:METH]MSGERR = 941 : End
        Endif
      Elsif ([M:METH]DPRPLN = G301FIS) Then
        Local Char LPARAM
        Call PARAM([M:METH]CPY,"DEROENCOUR",LPARAM) From ADOVAL
        # Un autre mode que "SA" est autorisé sur le fiscal pour générer du dérog. selon param. (DEROENCOUR)
        If ( val(LPARAM) <> G_OUI ) Then
          [M:METH]MSGERR = 587 : End
        Endif
      Else
        [M:METH]MSGERR = 587 : End
      Endif
    Endif
  Endif

  #Fq54343
  # Si gestion des concessions
  If G_ACTCCN=G_OUI
    # Par renouvellement
    If G_CCNRPR=G_OUI
      # Plan de caducité
      If [M:METH]DPRPLN=G_CCNPLNCAD
        # Bien de renouvellement pas encore associé à biens père : mode SA obligatoire
        If [M:METH]CCNETRNAT=GVML_NECONCS & [M:METH]CCNETRTYP=GVML_NARENEW & [M:METH]RNWDONFLG<>G_OUI
          If [M:METH]DPM<>G_DPMSA
            [M:METH]MSGERR = 741 : End
          Endif
        Endif
        # Bien apporté par concédant : mode SA obligatoire
        If [M:METH]CCNETRNAT=GVML_NECONCD
          If [M:METH]DPM<>G_DPMSA
            [M:METH]MSGERR = 779 : End
          Endif
        Endif
      Else
        # Autre que plan de caducité du contexte fiscal & comptable
        If [M:METH]CNX = G300CPFI
          # Bien apporté par concédant : mode RA invalide ( Pas de mise en oeuvre de l'IFRIC12 )
          If [M:METH]CCNETRNAT=GVML_NECONCD
            If [M:METH]DPM=G_DPMRA
              [M:METH]MSGERR = 780 : End
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif


   #Fq-87928 contrôle des durées des plans Fiscal et Subvention
   If ( dim (ACTTYPGES)> 0 ) and ( dim (ACTMETNAM)> 0 )
      If ( ACTTYPGES=GTAMMAS )  and ( ACTMETNAM = "FASTRFC" or ACTMETNAM = "FASTMTC" )
         If (dim(GFRADGI)> 0) and clalev([M:MET2])
            If GFRADGI=G_OUI
               #Fq-87928 contrôle des durées des plans Fiscal et Subvention
               If  [M:METH]DPRPLN=G301SUB and [M:MET2]DPRPLN=G301FIS
&                 [M:METH]DPRPLN=G301FIS and [M:MET2]DPRPLN=G301SUB
                  If  [M:METH]DPRDUR <> [M:MET2]DPRDUR
                     [M:METH]MSGERR = 819 : End
                  Endif
               Endif
            Endif
         Endif
      Endif
   Endif

  #-- Traitement point d'entrée

End


##########################################################################
Subprog CTRL_DPM (PDPM, PCPY, PCNX, PDPRPLN, PAASTYP, PTYPDET, PPROPLN, PFLGBCO, RERROR )
#
#  Objet   : Ce sous programme contrôle le mode d'amortissement d'un plan d'une société
#
#  Entrées : Mode d'amortissement
#            Société
#            Contexte d'amortissement
#            Plan d'amortissement
#            Type d'immobilisation (facultatif passer à 0 si non exploitation du paramètre)
#            Plan de production
#            Flag bien comptable en ligne
#
#   Sorties : RERROR = 0  => OK

Value    Char    PDPM        # Mode
Value    Char    PCPY        # Société
Value    Integer PCNX        # Contexte
Value    Integer PDPRPLN     # Plan d'amort.
Value    Integer PAASTYP     # Type d'immo.
Value    Integer PTYPDET     # Type de détention
Value    Char    PPROPLN     # Plan de production
Value    Integer PFLGBCO     # Flag bien comptable en ligne

Variable Integer RERROR      # Code retour


  If clalev([F:DPM]) =0     : Local File DPRMOD  [DPM]    : Endif
  If clalev([F:DPMD]) =0    : Local File DPRMOD  [DPMD]   : Endif # redéclaration sinon pb en 2nde lecture avec PCPY=""

  # Pays de la société
  Local    Char LCRY(GLONCRY)
  LCRY = func GLOFCYCPY.GET_SOC_PAYS(PCPY)
  # Legislation de la société
  Local    Char LLEG
  LLEG = func GLOFCYCPY.GET_SOC_LEG(PCPY)

  RERROR = 0
  Read [DPM]DPM0=PDPM;PCPY
  If (fstat) Then
    If (PCPY = "") Then
      # Mode d'amortissement invalide
      RERROR = 125 : End
    Else
      # Mode d'amortissement invalide
      Read [DPMD]DPM0=PDPM;""
      [F:DPM] = [F:DPMD]
      If (fstat) Then
        RERROR = 125: End
      Endif
    Endif
  Endif
  If ([F:DPM]ENAFLG <> G_OUI ) Then
    # Mode d'amortissement inactif
    RERROR = 259 : End
  Endif
  # Mode d'amortissement non autorisé au pays de la société
  If ( [F:DPM]CRY <> "" and LCRY <> "" and [F:DPM]CRY <> LCRY ) Then
    RERROR = 260 : End
  Endif
  # Mode d'amortissement non autorisé à la législation de la société
  If ( [F:DPM]LEG <> "" and LLEG <> "" and [F:DPM]LEG <> LLEG ) Then
    RERROR = 684 : End
  Endif
  # Mode d'amortissement  non autorisé pour ce plan
  If ([F:DPM]APLPLNFLG(PDPRPLN-1) <> G_OUI ) Then
    RERROR = 126 : End
  Endif

  # Issue 109391
  Local Shortint CTRLDPM_UO : CTRLDPM_UO = G_OUI
  GPOINT="CTRLDPM_UO" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE
  If CTRLDPM_UO = G_OUI
    # FQ54343
    If ( G_ACTCCN = G_OUI and PTYPDET = GVML_TDCONCE ) Then
      If clalev([F:WCNX])  = 0 : Local File CONTEXT     [WCNX]  : Endif : # Contextes
      Read [WCNX]CNX0=PCPY;G300CPFI
      If ( [F:WCNX]CCNFLG = G_OUI and PDPRPLN = [F:WCNX]CCNCADPLN ) Then
        If ( PDPM <> G_DPMSA and PDPM <> G_DPMRA  ) Then
         RERROR = 125: End
        Endif
      Endif
    Endif
  Endif
  # End issue 109391

  #*FQ-50471 si l'on est pas en saisie de valeur des association uniquement
  #*FQ-56351 ne pas faire ce test si paramètre PTYPDET = 0 (trt massif chgt méthode)
  #*FQ-56351 If !clalev([M:RVA1])
  If !clalev([M:RVA1]) and (PTYPDET <> 0)
     # Mode Caducité uniquement pour un bien dont le type de détention est "En concession" (hors plan Subvention)
     #FQ51532 n'appartenant pas au contexte fiscal & comptable.
     # If ( ( PDPM = G_DPMCA or PDPM = G_DPMRA  )  and ( PTYPDET <> GVML_TDCONCE or PDPRPLN = G301SUB ) ) Then
     If ( ( PDPM = G_DPMCA or PDPM = G_DPMRA  )  and ( PCNX <> G300CPFI or PTYPDET <> GVML_TDCONCE or PDPRPLN = G301SUB ) ) Then
       RERROR = 125: End
     Endif
  Endif

  # Possibility to bypass the standard control on UO and context by setting CTRLCNXUO at G_NON FQ95726
  # ---------------------------------------------
  Local Shortint CTRLCNXUO : CTRLCNXUO = G_OUI
  GPOINT="CTRLCNXUO" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE
  If CTRLCNXUO = G_OUI
    # Mode Unité d'oeuvre pour un contexte ne gérant pas le UO
    # FQ59941
    If ( PFLGBCO = G_OUI and ( PDPM = G_DPMUO or PDPM = G_DPMUR ) and PCNX <> GCNXUO ) Then
      # Le contexte du plan n'est pas désigné comme gérant les unités d'oeuvre, le mode UO est invalide.
      RERROR = 574 : End
    Endif
  Endif

  # Mode Unité d'oeuvre sans  PLAN de PRODUCTION
  # FQ59941
  If ( PFLGBCO = G_OUI and ( PDPM = G_DPMUO or PDPM = G_DPMUR ) and PPROPLN = "" ) Then
    # Le plan de production pour la gestion du mode UO doit être au préalable renseigné.
    RERROR = 573 : End
  Endif

End

##########################################################################
Subprog CTRL_DPRDUR (PDPRDUR, PDPM, PCPY, PALWCOD, PENDDPRFLG, PERROR )

#  Objet   : Ce sous programme contrôle la durée par rapport au mode d'amortissement
#            lorsque ce dernier est renseigné
#  Entrées :
#            PDPRDUR  Durée d'amort.
#            PDPM     Mode d'amort.
#            PCPY     Société
#
#  Sortie  : PERROR =  0  => OK
#                   <> 0  => erreur

Value Decimal    PDPRDUR
Value Char       PDPM
Value Char       PCPY
Value Integer    PALWCOD
Value Integer    PENDDPRFLG  : # FQ54343
Variable Integer PERROR

  PERROR = 0
  #-1 -------------------
  If (PDPM <> "") Then
    # FQ55960
    If ( PDPM = G_DPMDM and  ( PDPRDUR < 3 or PDPRDUR > 10 ) ) Then
      # Durée invalide pour ce mode d'amortissement.
      PERROR = 112 : End
    Endif

    If ( find (PDPM, G_DPMDE, G_DPMDF, G_DPMDP, G_DPMDI, G_DPMDV ) <> 0 and  PDPRDUR < 3 ) Then
      # Pour ce mode d'amortissement, la durée d'amortissement doit être au moins égale à 3 ans.
      PERROR = 78 : End
    Endif
    # FQ77877
    If ( find (PDPM, G_DPMRX, G_DPMRD ) <> 0 and  PDPRDUR < 2 ) Then
      # Pour ce mode d'amortissement, la durée d'amortissement doit être au moins égale à 2 ans.
      PERROR = 859 : End
    Endif
    # FQ55960 FQ54343 FQ59941 FQ84283 FQ84281 FQ105809
    If ( PDPRDUR = 0 and
&      find (PDPM,  G_DPMUL, G_DPMDA, G_DPMDB, G_DPMUD, G_DPMTD, G_DPMDX, G_DPMAD, G_DPMAL, G_DPMHL,
&                   G_DPMPR, G_DPMSY, G_DPMDM, G_DPMLR, G_DPMCR, G_DPMDR, G_DPMSR) <> 0 ) Then
      # Pour ce mode d'amortissement, une durée doit être renseignée
      PERROR = 116 : End
    Endif

    # FQ54343
    If ( PDPRDUR = 0 and PDPM = G_DPMRE and PENDDPRFLG <> G_OUI ) Then
      # Pour ce mode d'amortissement, une durée doit être renseignée si la date de fin d'amortissment n'a pas été forcée
      PERROR = 116 : End
    Endif
    If clalev([F:DPM]) =0    : Local File DPRMOD  [DPM]    : Endif
    Read [DPM]DPM0=PDPM;PCPY
    If (fstat) Then
      Read [DPM]DPM0=PDPM;""
    Endif
    If ( [F:DPM]DPRMODTYP = GVML_TMLIBRE and
&        PDPRDUR < [F:DPM]MINDPRLIF and [F:DPM]MINDPRLIF <> 0 ) Then
      # Une durée d'amortissement minimum est précisée pour le mode d'amortissement,
      # la durée d'amortissement saisie est en deça.
      PERROR = 79 : End
    Endif
    If ( PDPM = G_DPMFM and PDPRDUR <> 3 ) Then
      # Pour ce mode, la durée est de 3 ans
      PERROR = 584 : End
    Elsif ( PDPM = G_DPMLG and PDPRDUR <> 1.5 ) Then
      # Pour ce mode, la durée est de 1.5 an
      PERROR = 585 : End
    Elsif ( find (PDPM, G_DPMSA, G_DPMLV, G_DPMIT, G_DPM1P) <> 0 and PDPRDUR <> 0. ) Then
      # FQ59941 FQ84110 Pour ce mode, la durée doit être à 0.
      PERROR = 567 : End
    Endif
  Endif
  #-1 -------------------

End

##########################################################################
Subprog CTRL_RSDVAL (PRSDVAL, PAASREF, PDPRPLN, PFIYENDDAT, PPERENDDAT, PERROR )
#
# Objet   : Ce sous programme contrôle la valeur résiduelle
#
# Entrées : PRSDVAL    Valeur résiduelle à contrôler
#           PAASREF    Référence du bien
#           PFIYENDDAT Date de fin exercice
#           PPERENDDAT Date de fin période
# Sortie  : PERROR =  0  => OK
#           <> 0  => erreur

Value Decimal PRSDVAL
Value Integer PDPRPLN
Value Char    PAASREF
Value Date    PFIYENDDAT, PPERENDDAT
Variable Integer PERROR

Local Decimal LNBV

  PERROR = 0
  # -- Lecture DEPREC --
  If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif
  Read [DEPX] DEP0=PAASREF;PDPRPLN;PFIYENDDAT;PPERENDDAT
  If (fstat) Then :  Raz [F:DEPX] : Endif
  Filter [DEPX]


  # valeur nette début de période
  # Base réévaluée - cumul amt exer - cumul amt period - solde dépréciation
  # FQ83737
  LNBV =     [F:DEPX]DPRBAS
&         -  [F:DEPX]DPRCUM
&         -  [F:DEPX]PERCLOCUM
&         -  [F:DEPX]PERCLOEXC
&         - ([F:DEPX]EXEIMLCUM + [F:DEPX]PERIMLCUM )
&         + ([F:DEPX]EXERVECUM + [F:DEPX]PERRVECUM )



  # -- Valeur résiduelle non modifiable si le plan a été réévalué
  If ( [F:DEPX]RVAAMT <> 0 ) Then
    PERROR = 130 : End
  Endif
  # -- Valeur résiduelle non modifiable si le plan a été déprécié
  If ( [F:DEPX]IML <> 0 or [F:DEPX]IMLRVE <> 0) Then
    PERROR = 131 : End
  Endif
  # -- Valeur résiduelle ne doit pas être supérieure à la valeur nette début de période.
  If ( PRSDVAL > LNBV) Then
    PERROR = 132 : End
  Endif

End


