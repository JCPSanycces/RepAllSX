########################################################
#*! Syracused in class DPRMOD as operation GET_COUNTRY in DPRMOD_C_MPR
Funprog GET_MODE_PAYS( PCPY, PMOD )
#
# Objet : Retourne le pays auquel est limité le mode d'amortissement
#         passé en paramètre.
#
#
Value Char PCPY           : # société
Value Char PMOD           : # plan
Local Char PAYS(GLONCRY)  : # pays auquel est limité le mode ( "" si aucune limitation)

Local Integer  BMODLU     : # booleen mode lu

  BMODLU = 0

  If ( clalev([F:DPM]) = 0 ) Then : Local File DPRMOD [DPM] : Endif

  Read [DPM]DPM0= PMOD;PCPY
  If !(fstat) Then
    BMODLU = 1
  Elsif (PCPY <> "") Then
    # Si la société est renseignée, lecture mode par défaut
    Read [DPM]DPM0= PMOD;""
    If !(fstat) Then : BMODLU = 1 : Endif
  Endif
  If (BMODLU) Then :  PAYS = [DPM]CRY :  Else  : PAYS = "" :  Endif

End PAYS


#########################################################
#*! Syracused in class DPRMOD as operation GET_LEGISLATION in DPRMOD_C_MPR
Funprog GET_MODE_LEGISLATION( PCPY, PMOD )
#
# Objet : Retourne la legislation à laquelle est limitée le mode d'amortissement
#         passé en paramètre.
#
#
Value Char PCPY           : # société
Value Char PMOD           : # plan
Local Char LEGISLATION    : # législation à laquelle est limitée le mode ( "" si aucune limitation)

Local Integer  BMODLU     : # booleen mode lu

  BMODLU = 0

  If ( clalev([F:DPM]) = 0 ) Then : Local File DPRMOD [DPM] : Endif

  Read [DPM]DPM0= PMOD;PCPY
  If !(fstat) Then
    BMODLU = 1
  Elsif (PCPY <> "") Then
    # Si la société est renseignée, lecture mode par défaut
    Read [DPM]DPM0= PMOD;""
    If !(fstat) Then : BMODLU = 1 : Endif
  Endif
  If (BMODLU) Then :  LEGISLATION = [DPM]LEG :  Else  : LEGISLATION = "" :  Endif

End LEGISLATION


#########################################################
Funprog GET_DPRSTRDAT_TYP(PDPM, PCPY)
#
#  Objet  : Récupère à partir du mode d'amortissement
#           le type de date ( ML412) à utiliser pour
#           alimenter la date de début d'amort.
#
#  Sortie : Type de date (Achat, Mise en service, Comptabilisation)

Value Char PDPM                   # Mode
Value Char PCPY                   # Société (vide pour un mode libre)

Local Integer LDATTYP

  If !clalev([F:XDPM]) : Local File DPRMOD [XDPM] : Endif

  Read [XDPM]DPM0=PDPM;PCPY
  If ( fstat ) Then
    Read [XDPM]DPM0=PDPM;""
    If (fstat) Then
      LDATTYP = 0
    Else
      LDATTYP = [F:XDPM]STRDATTYP
    Endif
  Else
    LDATTYP = [F:XDPM]STRDATTYP
  Endif

End LDATTYP


#########################################################
Subprog DPM(STDDPMNUM,DPM)
Value    Shortint      STDDPMNUM  :  # N° mode d'amortissement standard
Variable Char          DPM        :  # Mode d'amt standard codé par l'utilisateur ("" si non codé)

  Raz DPM
  If clalev([F:DPM])=0  : Local File DPRMOD [DPM] : Endif

  Read [DPM]DPM1= STDDPMNUM
  If (fstat = 0 and [F:DPM]STDDPMNUM = STDDPMNUM ) Then
    DPM=[F:DPM]DPM
  Else
    DPM=""
  Endif

End


#########################################################
Funprog IS_CLOTURE_EXERCICE(PCPY, PREF, PDPRPLN )
#
# Objet : Contrôle si un bien a subi une clôture EXERCICE
#         - sur le plan PDPRPLN s'il est renseigné (différent de 0)
#         - sur au moins un de ses plans si PDPRPLN est à 0
#
#
#Value Char PSOC         # Société du bien
Value Char PCPY         # Société du bien
Value Char PREF         # Référence du bien
Value Integer PDPRPLN   # Plan à contrôler (optionnel)

Local Shortint RESCLOT  # Valeur de retour : 0 = aucune clôture
                        #                    1 = au moins une clôture

  If clalev([F:DEPA])=0  : Local File DEPREC [DEPA] : Endif
  If clalev([F:DEPB])=0  : Local File DEPREC [DEPB] : Endif

  Link  [DEPA] With [DEPB]DEP0=[DEPA]AASREF;[DEPA]DPRPLN;[DEPA]FIYENDDAT;[DEPA]PERENDDAT As [DEPX]
& Where [F:DEPA]PERENDDAT=[F:DEPB]FIYENDDAT

  If ( PDPRPLN = 0 ) Then
    Filter [DEPX] Where CPY = PCPY
&                   and AASREF = PREF
&                   and DEPSTA = GVML_SCCLOS
  Else
    Filter [DEPX] Where CPY = PCPY
&                   and AASREF = PREF
&                   and DPRPLN = PDPRPLN
&                   and DEPSTA = GVML_SCCLOS
  Endif

  Read [DEPX] First
  If ( fstat = 0 ) Then
    RESCLOT = 1 : # clôturé au moins une fois
  Else
    RESCLOT = 0 : # jamais clôturé
  Endif

  Filter [DEPX]
End RESCLOT

#########################################################
Funprog IS_CLOTURE(PCPY, PREF, PDPRPLN )
#
# Objet : Contrôle si un bien a subit une clôture
#         - sur le plan PDPRPLN s'il est renseigné (différent de 0)
#         - sur au moins un de ses plans si PDPRPLN est à 0
#
#
#Value Char PSOC         # Société du bien
Value Char PCPY         # Société du bien
Value Char PREF         # Référence du bien
Value Integer PDPRPLN   # Plan à contrôler (optionnel)

Local Shortint RESCLOT  # Valeur de retour : 0 = aucune clôture
                        #                    1 = au moins une clôture

  If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif

  If ( PDPRPLN = 0 )  Then
    Filter [DEPX] Where CPY = PCPY
&                   and AASREF = PREF
&                   and DEPSTA = GVML_SCCLOS
  Else
    Filter [DEPX] Where CPY = PCPY
&                   and AASREF = PREF
&                   and DPRPLN = PDPRPLN
&                   and DEPSTA = GVML_SCCLOS
  Endif

  Read [DEPX] First
  If ( fstat = 0 ) Then
    RESCLOT = 1 : # clôturé au moins une fois
  Else
    RESCLOT = 0 : # jamais clôturé
  Endif
  Filter [DEPX]

End RESCLOT

#########################################################
Funprog IS_SUPEG_EXC(PCPY, PDATE, PCNX )
#
# Objet : Contrôle si une date est supérieure ou égale
#         - à la date de début de l'exercice courant du contexte
#         PCNX s'il est renseigné (différent de 0)
#         - aux dates de début des exercices courants des contextes
#         du bien si PCNX est à 0
#
#
#Value Char PSOC         # Société du bien
Value Char PCPY         # Société du bien
Value Date PDATE        # Date à contrôler
Value Integer PCNX      # Contexte à contrôler (optionnel)

Local Shortint RESU     # Valeur de retour : 0 = inférieure
                        #                    1 = supérieure ou égale
                        #                    2 = date nulle

  If clalev([F:CNX])=0  : Local File CONTEXT  [CNX] : Endif
  If clalev([F:FIS])=0  : Local File FISCYEAR [FIS] : Endif

  If ( PDATE <> [0/0/0] ) Then
    RESU = 1
    If ( PCNX = 0 ) Then : # On regarde tous les contextes
      For [CNX]CNX0  Where CPY=PCPY
        If ([F:CNX]NBPLC) Then
          Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
          Read [FIS]FIY0 Last
          Filter [FIS]
          If ( PDATE < [F:FIS]DATSTRFIY ) Then
            RESU = 0
            Break
          Endif
        Endif
      Next
    Else
      Filter [FIS] Where CPY=PCPY and CNX=PCNX and STAFIY=GVML_TECOURA
      Read [FIS]FIY0 Last
      Filter [FIS]
      If ( PDATE < [F:FIS]DATSTRFIY ) Then
        RESU = 0
      Endif
    Endif
  Else
    RESU = 2
  Endif

End RESU

# CBO 2012.07.20 FQ82797
#########################################################
Funprog IS_INF_EXC(PCPY, PDATE, PCNX )
#
# Objet : Contrôle si une date est inférieure
#         - à la date de début de l'exercice courant du contexte
#         PCNX s'il est renseigné (différent de 0)
#         - aux dates de début des exercices courants des contextes
#         du bien si PCNX est à 0
#
#
Value Char PCPY         # Société du bien
Value Date PDATE        # Date à contrôler
Value Integer PCNX      # Contexte à contrôler (optionnel)

Local Shortint RESU     # Valeur de retour : 0 = supérieure ou égale
                        #                    1 = inférieure
                        #                    2 = date nulle

  If clalev([F:CNX])=0  : Local File CONTEXT  [CNX] : Endif
  If clalev([F:FIS])=0  : Local File FISCYEAR [FIS] : Endif

  If ( PDATE = [0/0/0] ) Then
    RESU = 2
    End RESU
  Endif

  RESU = 1
  If ( PCNX = 0 ) Then : # On regarde tous les contextes
    For [CNX]CNX0  Where CPY=PCPY
      If ([F:CNX]NBPLC) Then
        Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
        Read [FIS]FIY0 Last
        Filter [FIS]
        If ( PDATE >= [F:FIS]DATSTRFIY ) Then
          RESU = 0
          Break
        Endif
      Endif
    Next
  Else
    Filter [FIS] Where CPY=PCPY and CNX=PCNX and STAFIY=GVML_TECOURA
    Read [FIS]FIY0 Last
    Filter [FIS]
    If ( PDATE >= [F:FIS]DATSTRFIY ) Then
      RESU = 0
    Endif
  Endif

End RESU
#########################################################
Funprog GET_MODE_DPM( PCPY, PDPM )
#
# Objet : Retourne le type du mode d'amortissement
#         passé en paramètre, en le cherchant pour la société
#         indiquée et si non trouvé dans les modes par défaut.
#
#
Value Char PCPY       : # société (pour une recherche directement dans les modes par défaut, passer "")
Value Char PDPM       : # plan
Local Integer  RTRN   : # type retournée par la fonction : 0 si non trouvé, GVML_TMLIBRE, GVML_TMSTAND
Local Integer  LEC_OK : # indicateur de lecture

  LEC_OK = 0

  If ( clalev([F:DPM]) = 0 ) Then : Local File DPRMOD [DPM] : Endif

  Read [DPM]DPM0= PDPM;PCPY

  If ( fstat = 0 ) Then
    LEC_OK = 1
  Elsif PCPY <> ""
    # Si la société était renseignée, on regarde dans les modes par défaut
    Read [DPM]DPM0= PDPM;""
    If ( fstat = 0 ) Then : LEC_OK = 1 : Endif
  Endif

  If ( LEC_OK = 1 ) Then
    RTRN = [DPM]DPRMODTYP
  Else
    RTRN = 0
  Endif

End RTRN
#{FONCTION}#
#--------------------------------------------------------------#
# S/P de calcul de la valeur bilan d'un plan et d'un bien      #
# comptable passé en paramètre                                 #
#--------------------------------------------------------------#
Funprog GET_VAL_BILAN(PPLAN,PBCO)
Value Integer PPLAN
Value Char    PBCO

  Local Decimal VALBILAN

  If !clalev([F:DEP]) : Local File DEPREC [DEP] : Endif
  Filter [DEP] Where DPRPLN=PPLAN & AASREF=PBCO
  For [DEP]
    If !([F:DEP]DPRBAS=0)
      VALBILAN=[F:DEP]DPRBAS
    Else
      VALBILAN=[F:DEP]BSEVAL
    Endif
  Next
  Filter [DEP]

End VALBILAN

#########################################################
Subprog GET_DPM_RSD(PCPY, PDPM, RRSDDPM, RPRATYP)
# Objet : Récupère le mode résiduel correspondant si il existe.
#         Lecture de la table DPRMOD pour le mode passé en
#         paramétre. Si le mode résiduel correspondant n'est
#         pas alimenté, on renvoie RJ par défaut.

#
Value Char PCPY   # Société (vide pour les modes standards)
Value Char PDPM   # Mode d'amortissement

Variable Char    RRSDDPM       # Mode résiduel
Variable Integer RPRATYP       # Type de prorata

  RRSDDPM = "RE"
  RPRATYP= 1

  If !clalev([F:WDPM]) : Local File DPRMOD [WDPM] : Endif

  Read [WDPM]DPM0=PDPM;PCPY
  If !(fstat) Then
    RRSDDPM = [F:WDPM]RSDDPMTGR
    RPRATYP = [F:WDPM]PRATYPTGR
    End
  Endif
  If ( PCPY <> "" ) Then
    Read [WDPM]DPM0=PDPM;""
    If !(fstat) Then
      RRSDDPM = [F:WDPM]RSDDPMTGR
      RPRATYP = [F:WDPM]PRATYPTGR
      End
    Endif
  Endif
End

#======================================================
Subprog FASMTC_SA_RA (PFAS, PDEP, PDPM, PDEBAMT, PEVE, PDATE, RTRN)
#
# Objet : Ce sous-programme effectue un changement de méthode
#         vers SA si mode origine est RA
#         vers RA si mode origine est SA
#
# Prérequis :
#         L'appelant passe la classe FXDASSETS alimentée avec les infos du bien comptable concerné.
#         L'appelant passe la classe DEPREC    alimentée avec les infos de la période courante du plan concerné.
#
# Contrainte :
#         L'abréviation fichier "DPO" ne doit pas être déjà utilisée.
#

Value Char       PFAS    : # Abréviation fichier FXDASSETS
Value Char       PDEP    : # Abréviation fichier DEPREC
Value Char       PDPM    : # Mode cible
Value Date       PDEBAMT : # Début d'amortissement cible ( neutre si [0/0/0] )
Value Integer    PEVE    : # Génération des événements (G_OUI/G_NON)
Value Date       PDATE   : # Date d'effet de l'événement
Variable Integer RTRN    : #  0 = OK
                         : #  1 = La classe FXDASSETS n'existe pas
                         : #  2 = La classe DEPREC    n'existe pas
                         : #  3 = Mode d'amortissement source invalide
                         : #  4 = Mode source et cible identiques
                         : #  5 = Enregistrement non trouvé dans DEPREC
                         : #  6 = Classe [F:DPO] déjà ouverte
                         : #  >20 Erreur génération évenement FASMTCn

Local Integer L_MTCTIATYP

  RTRN = 0 : # OK

  If find(PFAS, fileabre(1..dim(fileabre))) =0 : RTRN= 1 : End  : Endif
  If find(PDEP, fileabre(1..dim(fileabre))) =0 : RTRN= 2 : End  : Endif
  If ( evalue("[F:"+PDEP+"]DPM") <> G_DPMSA and evalue("[F:"+PDEP+"]DPM") <> G_DPMRA ) Then : RTRN = 3 : End : Endif
  If ( evalue("[F:"+PDEP+"]DPM") = PDPM )   Then : RTRN = -1 : End :  Endif


  # Sauvegarde des globales ci-dessous si elle existe déjà
  If dim(GFAS)>0 : If dim(SV_GFAS)>0 : Kill SV_GFAS : Endif : Local Char SV_GFAS : SV_GFAS=GFAS : Else : Global Char GFAS : Endif
  If dim(GDPO)>0 : If dim(SV_GDPO)>0 : Kill SV_GDPO : Endif : Local Char SV_GDPO : SV_GDPO=GDPO : Else : Global Char GDPO : Endif
  If dim(GDPN)>0 : If dim(SV_GDPN)>0 : Kill SV_GDPN : Endif : Local Char SV_GDPN : SV_GDPN=GDPN : Else : Global Char GDPN : Endif

  GFAS = "[F:"+PFAS+"]"
  GDPO = "[F:DPO]"
  GDPN = "[F:"+PDEP+"]"

  If ( evalue(GFAS+"CCNETRNAT") = GVML_NECONCD ) Then
    # Si apport concédant - Pas de changement de méthode ( le mode doit toujours rester à "SA")
    End
  Endif

  #---------
  If !clalev([DPO]) Then
    # Vérification existence dans DEPREC et sauvegarde valeur avant dans [F:DPO]
    Local File DEPREC [DPO]
    Read [DPO]DEP0= evalue(GDPN+"AASREF");evalue(GDPN+"DPRPLN");evalue(GDPN+"FIYENDDAT");evalue(GDPN+"PERENDDAT")
    If (fstat) Then
      Close Local File [DPO]
      Kill GFAS, GDPO, GDPN
      RTRN = 5 : End
    Endif
  Else
    Kill GFAS, GDPO, GDPN
    RTRN = 6 : End
  Endif
  #---------

  # Affectation date de début d'amortissement
  If (PDEBAMT <> [0/0/0] ) Then
    Assign GDPN+"STRDPRDAT"  With PDEBAMT
  Endif

  # Affectation du nouveau mode et de son type de prorata
  Assign GDPN+"DPM"        With PDPM
  Assign GDPN+"PRATYP"     With 0
  Assign GDPN+"MTCDEVADJ"  With 0

  # "RA" vers "SA"
  If ( PDPM = G_DPMSA) Then
    If ( evalue(GDPN+"DPRCUM") <> 0 ) Then
      # S'il existe un cumul d'amortissement E-1 à rattraper
      # Prise d'effet ; Début d'amortissement
      Assign GDPN+"MTCTIATYP"  With GVML_PEDBAM
      # Rattrapage E-1 : Amt exceptionnel période
      Assign GDPN+"MTCDEVADJ"  With GVML_REXCPER
    Else
      # Si pas de cumul d'amortissement E-1
      # Prise d'effet ; Début d'amortissement
      Assign GDPN+"MTCTIATYP"  With GVML_PEDBEX
    Endif
  Endif

  # "SA" vers "RA"
  If ( PDPM = G_DPMRA) Then
    # Prise d'effet : Début de prériode
    Assign GDPN+"MTCTIATYP"  With GVML_PEDBPE
  Endif

  # Auto correction : Pise d'effet
  If ( evalue(GDPN+"STRDPRDAT") >= evalue(GDPN+"PERSTRDAT") and evalue(GDPN+"MTCTIATYP") <> GVML_PEDBAM  ) Then
    # Si le début d'amortissement se situe dans la période courante ou au delà alors le prise d'effet ne peut être que GVML_PEDBAM
    Assign GDPN+"MTCTIATYP"  With GVML_PEDBAM
  Endif

  # Affectation MTCTIADAT
  L_MTCTIATYP = evalue(GDPN+"MTCTIATYP")
  Case L_MTCTIATYP
     When GVML_PEDBAM
          Assign GDPN+"MTCTIADAT"    With  evalue(GDPN+"STRDPRDAT")
     When GVML_PEDBEX
          Assign GDPN+"MTCTIADAT"    With  max(evalue(GDPN+"STRDPRDAT"), evalue(GDPN+"FIYSTRDAT"))
     When GVML_PEDBPE
          Assign GDPN+"MTCTIADAT"    With  max(evalue(GDPN+"STRDPRDAT"), evalue(GDPN+"PERSTRDAT"))
     When Default
  Endcase


  # Génération d'un événement de changement de méthode si PEVE est à oui.
  If ( PEVE <> G_NON ) Then
    Local Integer LCDRET
    Local Char    LCDINT(10)
    LCDINT= "FASMTC"+num$(evalue(GDPN+"DPRPLN"))
    If (PDATE = [0/0/0]) Then : PDATE = date$ : Endif
    Call GENER_EVE
&   (GVML_OMBIEN, evalue(GFAS+"CPY"), evalue(GFAS+"FCY"), evalue(GFAS+"AASREF"),0,LCDINT,PDATE, [0/0/0],LCDRET)
&   From GENEVE
    If (LCDRET > 20) Then
      # Erreur technique
      Kill GFAS, GDPO, GDPN
      [F:DEP]= [F:DPO]
      Close Local File [DPO]
      RTRN = LCDRET
      End
    Endif
  Endif
  Close Local File [DPO]

  # Restoration des globales ci-dessous si elle existait auparavant
  If dim(SV_GFAS)>0 : GFAS=SV_GFAS : Else : Kill GFAS : Endif
  If dim(SV_GDPO)>0 : GFAS=SV_GDPO : Else : Kill GDPO : Endif
  If dim(SV_GDPN)>0 : GFAS=SV_GDPN : Else : Kill GDPN : Endif

End

#======================================================
Subprog MTC_NRSD_RSD(PFAS, PDEP, PEVE, PDATE, RTRN)
#
# Objet : Ce sous-programme ( si les conditions sont réunies )
#         effectue le passage d'un mode non résiduel à son mode résiduel
#         cible paramétré,
#         et dans ce dernier cas génère un événement de changement de méthode
#         si PEVE est à "OUI"
# Contraintes :
#         Les variables globales GFAS, GDPN, GDPO ne doivent pas exister
#         L'abréviation fichier "WWW" ne doit pas être déjà utilisée.
#
# Ne pas oublier d'affecter les champs mis à jour dans l'action TPF1_ALIM_MASK
# DPRMOD,...

Value Char       PFAS    : # Abréviation fichier FXDASSETS
Value Char       PDEP    : # Abréviation fichier DEPREC
Value Integer    PEVE    : # Génération des événements (G_OUI/G_NON)
Value Date       PDATE   : # Date de comptabilisation de l'événement
Variable Integer RTRN

Local Integer LCDRET
Local Char    LCDINT(10)
Local Char    L_RSDDPMTGR
Local Integer L_RSDPRATYP

  RTRN = 0 : # OK

  If find(PFAS, fileabre(1..dim(fileabre))) =0 : RTRN= 2 : End  : Endif  : # La classe FXDASSETS n'existe pas
  If find(PDEP, fileabre(1..dim(fileabre))) =0 : RTRN= 3 : End  : Endif  : # La classe DEPREC    n'existe pas

  # Lecture du mode et récupération du mode résiduel
  If !clalev([F:DPM]) : Local File DPRMOD [DPM] : Endif
  Read [DPM]DPM0=evalue("[F:"+PDEP+"]"+"DPM");""
  If !(fstat) Then
     L_RSDDPMTGR = [F:DPM]RSDDPMTGR
     L_RSDPRATYP = [F:DPM]PRATYPTGR
  Else
        RTRN = 8 : End  : # Mode d'amortissement inconnu
     Endif

  If evalue("[F:"+PDEP+"]DPM") = L_RSDDPMTGR
    RTRN = -1 : End  : # Le mode d'amortissement est déjà en résiduel. On ne fait rien, ce n'est pas une erreur
  Endif

  If dim(GFAS)>0 : If dim(SV_GFAS)>0 : Kill SV_GFAS : Endif : Local Char SV_GFAS : SV_GFAS=GFAS : Else : Global Char GFAS : Endif
  If dim(GDPO)>0 : If dim(SV_GDPO)>0 : Kill SV_GDPO : Endif : Local Char SV_GDPO : SV_GDPO=GDPO : Else : Global Char GDPO : Endif
  If dim(GDPN)>0 : If dim(SV_GDPN)>0 : Kill SV_GDPN : Endif : Local Char SV_GDPN : SV_GDPN=GDPN : Else : Global Char GDPN : Endif

  GFAS = "[F:"+PFAS+"]"
  GDPO = "[F:WWW]"
  GDPN = "[F:"+PDEP+"]"
  #---------
  If !clalev([WWW]) Then
    Local File DEPREC [WWW]
    Read [WWW]
&   DEP0= evalue(GDPN+"AASREF");evalue(GDPN+"DPRPLN");evalue(GDPN+"FIYENDDAT");evalue(GDPN+"PERENDDAT")
    If (fstat) Then
      Close Local File [WWW]
      Kill GFAS, GDPO, GDPN
      RTRN = 6 : End : # Paramètres incohérents
    Endif
  Else
    Kill GFAS, GDPO, GDPN
    RTRN = 7 : End : # Classe [F:WWW] déjà ouverte
  Endif
  #---------
  # Le mode non résiduel passe à résiduel cible et sauvegarde du mode origine
  Assign GDPN+"DPM"    With L_RSDDPMTGR
  # X3-77331
  If (L_RSDPRATYP > 0) Then
    Assign GDPN+"PRATYP" With L_RSDPRATYP
  Endif

  # Génération des événements uniquement si le paramètre PEVE est à oui.
  If ( PEVE <> G_NON ) Then
   LCDINT= "FASMTC"+num$(evalue(GDPN+"DPRPLN"))
   Call GENER_EVE
&  (GVML_OMBIEN, evalue(GFAS+"CPY"), evalue(GFAS+"FCY"), evalue(GFAS+"AASREF"),0,LCDINT,PDATE,PDATE,LCDRET)
&  From GENEVE
   If (LCDRET > 20) Then
      # Erreur technique
      Kill GFAS, GDPO, GDPN
      Close Local File [WWW]
      RTRN = LCDRET : End : # Erreur à la génération de l'événement
    Endif
  Endif
  Close Local File [WWW]

  If dim(SV_GFAS)>0 : GFAS=SV_GFAS : Else : Kill GFAS : Endif
  If dim(SV_GDPO)>0 : GFAS=SV_GDPO : Else : Kill GDPO : Endif
  If dim(SV_GDPN)>0 : GFAS=SV_GDPN : Else : Kill GDPN : Endif

End

#======================================================
Subprog MTC_RSD_NRSD(PFAS, PDEP, PEVE, PDATE, RTRN)
#
# Objet : Dans le cas d'une annulation de réévaluation, ce sous-programme
#         passe le mode de "RJ" à "LP"
#         et  génère un événement de changement de méthode selon paramétrage.
#         exemple : Call IASMTC_RJ_LP("FAS", "DEP", RTRN) from TRTFAS
# Contraintes :
#         Les variables globales GFAS, GDPN, GDPO ne doivent pas exister
#         L'abréviation fichier "WWW" ne doit pas être déjà utilisée.
#         (remarque: si jugé interessant l'abréviation www pourrait être passé en paramètre
#            si le paramètre n'était pas renseigné on prendrait www cela résoud le
#            cas où l'abréviation www serait utilisée, une autre abréviation pourrait être alors fournie)
#
# Ne pas oublier d'affecter les champs mis à jour dans l'action TPF1_ALIM_MASK
# DPRMOD,...

Value Char PFAS     : # Abréviation fichier FXDASSETS
Value Char PDEP     : # Abréviation fichier DEPREC
Value Integer PEVE  : # Génération des événements
Value Date    PDATE : # Date de comptabilisation de l'événement
Variable Integer RTRN

Local Integer LCDRET
Local Char    LCDINT(10)

  If !clalev([WMTC]) : Local File EFASMTC [WMTC] : Endif

  RTRN = 0 : # OK
  If find(PFAS, fileabre(1..dim(fileabre))) =0 : RTRN= 2 : End  : Endif  : # La classe FXDASSETS n'existe pas
  If find(PDEP, fileabre(1..dim(fileabre))) =0 : RTRN= 3 : End  : Endif  : # La classe DEPREC    n'existe pas

  # Lecture du dernier événement de changement de mode d'amortissement
  Filter [WMTC] Where REF=evalue("["+PDEP+"]AASREF") and DPRPLN=evalue("["+PDEP+"]DPRPLN")
  Read [WMTC]EVE0 Last
  Filter

  If fstat | [F:WMTC]DPMO=[F:WMTC]DPMD | [F:WMTC]DPMO=''
    End
  Endif

  If dim(GFAS)>0 : If dim(SV_GFAS)>0 : Kill SV_GFAS : Endif : Local Char SV_GFAS : SV_GFAS=GFAS : Else : Global Char GFAS : Endif
  If dim(GDPO)>0 : If dim(SV_GDPO)>0 : Kill SV_GDPO : Endif : Local Char SV_GDPO : SV_GDPO=GDPO : Else : Global Char GDPO : Endif
  If dim(GDPN)>0 : If dim(SV_GDPN)>0 : Kill SV_GDPN : Endif : Local Char SV_GDPN : SV_GDPN=GDPN : Else : Global Char GDPN : Endif

  GFAS = "[F:"+PFAS+"]"
  GDPO = "[F:WWW]"
  GDPN = "[F:"+PDEP+"]"

  #----------------
  If ( evalue(GDPN+"DPM")    = G_DPMRE and  evalue(GDPN+"PRATYP" = GVML_TPJOUR) ) Then
    # Classes anciennes et nouvelles  valeurs équivalentes
    #---------
    If !clalev([WWW]) Then
      Local File DEPREC [WWW]
      GDPO = "[F:WWW]"
      Read [WWW]
&     DEP0= evalue(GDPN+"AASREF");evalue(GDPN+"DPRPLN");evalue(GDPN+"FIYENDDAT");evalue(GDPN+"PERENDDAT")
      If (fstat) Then
        Kill GFAS, GDPO, GDPN
        RTRN = 6 : End : # Paramètres incohérents
      Endif
    Else
      Kill GFAS, GDPO, GDPN
      RTRN = 7 : End : # Classe [F:WWW] déjà ouverte
    Endif
    #---------
    # Le mode résiduel passe à non résiduel origine
    Assign GDPN+"DPM"    With [F:WMTC]DPMO
    # Génération d'un événement de changement de méthode selon le paramétrage.
    If ( PEVE=G_OUI ) Then
     LCDINT= "FASMTC"+num$(evalue(GDPN+"DPRPLN"))
     Call GENER_EVE
&    (GVML_OMBIEN, evalue(GFAS+"CPY"), evalue(GFAS+"FCY"), evalue(GFAS+"AASREF"),0,LCDINT,PDATE,PDATE,LCDRET)
&    From GENEVE
     If (LCDRET > 20) Then
       # Erreur technique
       Kill GFAS, GDPO, GDPN
       RTRN = LCDRET : End : # Erreur à la génération de l'événement
     Endif
    Endif
    Close Local File [WWW]
  Endif
  #----------------

  If dim(SV_GFAS)>0 : GFAS=SV_GFAS : Else : Kill GFAS : Endif
  If dim(SV_GDPO)>0 : GFAS=SV_GDPO : Else : Kill GDPO : Endif
  If dim(SV_GDPN)>0 : GFAS=SV_GDPN : Else : Kill GDPN : Endif
End

#_________________________________________________________________________
#
#     A V A N T _ S A I S I E
#_________________________________________________________________________

$RETRAIT_ALWCOD_DEGRESSIF
  # Les régles particulières suivantes sont réservées aux modes dégressifs
  GMENLOC(GVML_RPMAJ10) = 1 : # MAJORATION 1.0 COEF DEGRESSIVITE
  GMENLOC(GVML_RPAID30) = 1 : # AIDE 30 % DEGRESSIF FRANCAIS
Return
