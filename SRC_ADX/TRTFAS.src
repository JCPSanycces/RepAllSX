    Chgfmt [M:FAS5]ADMCOER With "N+:3.2#"
    Chgfmt [M:FAS5]DEDCOER With "N+:3.2#"
    Chgfmt [M:FAS5]ASJCOE2 With "N+:3.2#"
    Chgfmt [M:FAS5]TAXCOE2 With "N+:3.2#"
    Chgfmt [M:FAS5]ADMCOE2 With "N+:3.2#"
    Chgfmt [M:FAS5]DEDCOE2 With "N+:3.2#"
    Chgfmt [M:FAS5]ASJCOEF With "N+:3.2#"
    Chgfmt [M:FAS5]TAXCOEF With "N+:3.2#"
    Chgfmt [M:FAS5]ADMCOEF With "N+:3.2#"
    Chgfmt [M:FAS5]DEDCOEF With "N+:3.2#"
  Endif

  [M:FAS5]FLDA  = mess(638,GML_MSGFAS,1)  : Affzo [M:FAS5]FLDA
  [M:FAS5]FLDB  = mess(639,GML_MSGFAS,1)  : Affzo [M:FAS5]FLDB
