      Diszo  [M:LOF1]ZIASACCORI
    Endif
    Affzo [M:LOF1]35
  Else
    # Bloc Valorisation IAS/IFRS
    Chgfmt [M:LOF1]IASACN     With "-LO:1X"
    Chgfmt [M:LOF1]IASACC     With "-K:1X"
    Chgfmt [M:LOF1]ZIASACC    With "-K:30X"
    Chgfmt [M:LOF1]IASACCORI  With "-K:1X"
    Chgfmt [M:LOF1]ZIASACCORI With "-K:30X"
  Endif
Return

