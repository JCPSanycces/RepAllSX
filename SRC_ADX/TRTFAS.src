    Chgfmt [M:MFS0]IASACC With "-K:1X"
  #Else
    #If varmode([M:MFS0]IASACC)=3 : Chgfmt [M:MFS0]IASACC With "K:"+GFMTACC : Endif
  Endif
Return

##########################################################################
Subprog COND_DPRDUR (IFLD, IDPM, IABR, ISUFF, IFLGACT ) : # Conditionnement DPRRAT selon DPM
#      IFLD     Champ
#      IDPM     Mode d'amortissement
#      IABR     Abréviation
#      IFLGACT  Actzo
Value Char    IFLD, IDPM, IABR, ISUFF
Value Integer IFLGACT
Local Char    CHAMP
Local Char    SAUVE(255)

  Default Mask IABR
  CHAMP=IABR+IFLD+ISUFF+"(nolign-1)"
  If ( IFLGACT = G_OUI) Then : Actzo =CHAMP : Endif
  If (   ( IDPM = G_DPMSA   and G_DPMSA <> "" ) ) Then
    # Si mode d'amort = "SA"  alors durée non saisissable
    Assign CHAMP With 0
    Diszo =CHAMP
    Affzo =CHAMP
  Endif

End


##########################################################################
Subprog COND_DPRRATFLG (IDPM, IABR, ISUFF, IFLGACT, IRAZ ) : # Conditionnement DPRRATFLG selon DPM
#      IDPM     Mode d'amortissement
#      IABR     Abréviation
#      IFLGACT  Actzo
#      IRAZ     Remise à zéro
Value Char IDPM, IABR, ISUFF
Value Integer IFLGACT, IRAZ
Local Char    CHAMP, CHAMP2

  # FQ55960 FQ59941 FQ84281
  Default Mask IABR
  CHAMP= IABR+"DPRRATFLG"+ISUFF+"(nolign-1)"
  If ( IFLGACT = G_OUI) Then : Actzo =CHAMP : Endif
  If (   ( IDPM = G_DPMSA   and G_DPMSA <> "" )
&     or ( IDPM = G_DPMUO   and G_DPMUO <> "" )
&     or ( IDPM = G_DPMUR   and G_DPMUR <> "" )
&     or ( IDPM = G_DPMRE   and G_DPMRE <> "" )
&     or ( IDPM = G_DPMHL   and G_DPMHL <> "" )
&     or ( IDPM = G_DPMRA   and G_DPMRA <> "" )
&     or ( IDPM = G_DPMDM   and G_DPMDM <> "" )
&                                               ) Then
    # Si mode d'amort = "SA" "RE" ""DM" ou "UO"  alors taux non saisissable
    CHAMP2 = IABR+"DPRRAT"+ISUFF+"(nolign-1)"
    If (IRAZ = G_OUI) Then
      Assign CHAMP2 With 0
    Endif
    Assign CHAMP  With G_NON
    Diszo =CHAMP
    Affzo =CHAMP : Affzo =CHAMP2
  Endif
End
#Fq-54343#########################################################################
Subprog COND_ENDDPRFLG (IDPM, IABR, ISUFF, IFLGACT, IRAZ ) : # Conditionnement ENDDPRFLG selon DPM
#      IDPM     Mode d'amortissement
#      IABR     Abréviation
#      IFLGACT  Actzo
#      IRAZ     Remise à zéro
Value Char IDPM, IABR, ISUFF
#Value Date    IRAZ : # FQ68427 : mauvais type sur IRAZ
Value Integer IFLGACT
Value Integer IRAZ
Local Char    CHAMP, CHAMP2

  Default Mask IABR
  CHAMP  = IABR+"ENDDPRFLG"+ISUFF+"(nolign-1)"
  CHAMP2 = IABR+"ENDDPRDAT"+ISUFF+"(nolign-1)"

  If ( IFLGACT = G_OUI) : Actzo =CHAMP : Endif
  # Issue 116168   POR - idem for methods PC/PD
  # Issue 116168 If  ( IDPM <> G_DPMRE and IDPM <> G_DPMRA )
  If find(IDPM, G_DPMRE, G_DPMRA, G_DPMPC, G_DPMPD) = 0
    # Si mode d'amort <> "RE", "RA", "PC", "PD" :  date fin d'amortissement non saisissable
    CHAMP2 = IABR+"ENDDPRDAT"+ISUFF+"(nolign-1)"
    If (IRAZ = G_OUI) Then
      Assign CHAMP2 With [0/0/0]
    Endif
    Assign CHAMP  With G_NON
    Diszo =CHAMP
    Affzo =CHAMP : Affzo =CHAMP2
  Else
    # Si mode d'amort = "RE" ou "RA" ou "PC" ou "PD" : date fin d'amortissement  saisissable
    # Issue 116168   POR - idem for methods PC/PD
    Assign CHAMP  With G_OUI
    Actzo =CHAMP  :   Affzo =CHAMP
    Actzo =CHAMP2 :   Affzo =CHAMP2
  Endif

End

##########################################################################
Subprog COND_RSDQTY (IDPM, IABR, ISUFF, IFLGACT  ) : # Conditionnement RSDQTY selon DPM
#      IDPM     Mode d'amortissement
#      IABR     Abréviation
#      IFLGACT  Actzo
Value Char IDPM, IABR, ISUFF
Value Integer IFLGACT
Local Char    CHAMP, CHAMP2

  # FQ59941
  Default Mask IABR
  CHAMP = IABR+"RSDQTY"+ISUFF+"(nolign-1)"
  CHAMP2= IABR+"UOM"+ISUFF+"(nolign-1)"
  If ( (IDPM = G_DPMUO   and G_DPMUO <> "") or (IDPM = G_DPMUR   and G_DPMUR <> "")  ) Then
      # Si mode d'amort = "UO" or "UR" alors UO durée résiduelle, UO exercice, UO période saisissable
    If ( IFLGACT = G_OUI) Then
      Assign CHAMP2 With GDEFUOM
      Actzo =CHAMP
    Endif
  Else
    Assign CHAMP2 With ""
    Assign CHAMP With 0
    Diszo =CHAMP
    Affzo =CHAMP
  Endif
End

##########################################################################
Subprog COND_FIYQTY (IDPM, IABR, ISUFF, IFLGACT  ) : # Conditionnement FIYQTY selon DPM
#      IDPM     Mode d'amortissement
#      IABR     Abréviation
#      IFLGACT  Actzo
Value Char IDPM, IABR, ISUFF
Value Integer IFLGACT
Local Char    CHAMP

  # FQ59941
  Default Mask IABR
  CHAMP= IABR+"FIYQTY"+ISUFF+"(nolign-1)"
  If (   ( IDPM = G_DPMUO   and G_DPMUO <> "" ) or (IDPM = G_DPMUR   and G_DPMUR <> "") ) Then
      # Si mode d'amort = "UO" alors UO durée résiduelle, UO exercice, UO période saisissable
    If ( IFLGACT = G_OUI) Then : Actzo =CHAMP : Endif
  Else
    Assign CHAMP With 0
    Diszo =CHAMP
    Affzo =CHAMP
  Endif
End

##########################################################################
Subprog COND_PERQTY (IDPM, IABR, ISUFF, IPERENDDAT, IFLGACT ) : # Conditionnement PERQTY selon DPM
#      IDPM     Mode d'amortissement
#      IABR     Abréviation
#      IFLGACT  Actzo
Value Char    IDPM, IABR, ISUFF
Value Integer IFLGACT
Value Date    IPERENDDAT
Local Char    CHAMP, CHAMP2

  # FQ59941
  Default Mask IABR
  CHAMP  = IABR+"PERQTYFLG"+ISUFF+"(nolign-1)"
  CHAMP2 = IABR+"PERQTY"+ISUFF+"(nolign-1)"
  If (   ( ((IDPM = G_DPMUO   and G_DPMUO <> "") or (IDPM = G_DPMUR   and G_DPMUR <> "")) and IPERENDDAT <> [0/0/0] ) ) Then
      # Si mode d'amort = "UO" alors UO durée résiduelle, UO exercice, UO période saisissable
    If ( IFLGACT = G_OUI) Then : Actzo =CHAMP2 : Endif
  Else
    Assign CHAMP With G_NON
    Diszo =CHAMP2
    Assign CHAMP2  With 0
    Affzo =CHAMP : Affzo =CHAMP2
  Endif
End

##########################################################################
Subprog COND_CRBVEHCOD (IDPRPLN, IABR, ISUFF,  IFLGACT) : # Conditionnement CRBVEHCOD
#      IDPRPLN  Plan d'amortissement
#      IABR     Abréviation
#      IFLGACT  Actzo
Value Char    IABR, ISUFF
Value Integer IFLGACT, IDPRPLN
Local Char    CHAMP

  Default Mask IABR
  CHAMP= IABR+"CRBVEHCOD"+ISUFF+"(nolign-1)"
  If ( IFLGACT = G_OUI) Then : Actzo =CHAMP : Endif
  If ( IDPRPLN <> G301FIS ) Then
    # Le champ n'est pas saisissable pour un plan autre que le fiscal
    Assign CHAMP With ""
    Diszo =CHAMP
    Affzo =CHAMP
  Endif
End

#_________________________________________________________________________
#
#     A U T R E S
#_________________________________________________________________________




#########################################################
Funprog IS_SORTABLE( PCPY, PISSDAT, POWNTYP )

Value    Char      PCPY             : # société
Value    Date      PISSDAT          : # Date de sortie
Value    Integer   POWNTYP          : # Sortie prévisionnelle

Local    Integer   RTRN             : # Retour
Local    Integer   LRTRN            : # Retour

#
# Le bien comptable ne peut pas être sorti si
#   il s'agit d'un bien "modèle" ou "prévisionnel"
#   il a été annulé
#   il a été sorti dans un exercice antérieur
#

 RTRN    =  0
 If (POWNTYP = GVML_TDMODEL or POWNTYP = GVML_TDPREVU )Then
   RTRN = 1
 Else
   Call IS_SORTI_EX_ANTERIEUR(PCPY, PISSDAT, 1, LRTRN)
   If (LRTRN = 1 ) Then : RTRN= 2 : Endif
 Endif

End RTRN



#########################################################
Subprog IS_ANTERIEUR(ITSDAT,RTRN)
#
Value    Date         ITSDAT : # Date de mise en service
Variable Integer      RTRN   : # Retour (1 Non - 2 Oui)
#
# Le bien comptable est considéré comme antérieur
# si  sa date de mise en service est
# antérieure à la date de début de l'exercice courant
# du contexte fiscal et comptable
#
  RTRN = G_NON
  If ( ITSDAT <> [0/0/0]  and ITSDAT < GDEBEXECPF ) Then
     RTRN = G_OUI
  Endif
End


#########################################################
Subprog IS_SORTI_EX_ANTERIEUR(PCPY,PISSDAT,PTYPTEST,RTRN)

Value    Char      PCPY             : # Société
Value    Date      PISSDAT          : # Date de sortie
Value    Integer   PTYPTEST         : # Type de test.
Variable Integer   RTRN             : # Retour

Local Integer      NBPLAN         : # Nombre de plans gérés par un contexte

  If clalev([F:CNX])=0  : Local File CONTEXT  [CNX] : Endif
  If clalev([F:FIS])=0  : Local File FISCYEAR [FIS] : Endif

#
# Le bien comptable est considéré comme sorti dans les exercices antérieurs
# si sa date de sortie est antérieure à la date de début de l'exercice
# d'un des contextes de la société (PTYPTEST=1), de tous les contextes de
# la société (PTYPTEST=2)
#

  If ( PTYPTEST = 1 ) Then
   RTRN = 0
  Elsif ( PTYPTEST = 2 ) Then
   RTRN = 1
  Endif

  If ( PISSDAT = [0/0/0] ) Then : End : Endif

  # >>>>>>>>>>>>>
  For [CNX]CNX0  Where CPY=PCPY
      If ([F:CNX]NBPLC) Then
        Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
        Read [FIS]FIY0 Last
        Filter [FIS]
        If ( PTYPTEST = 1 ) Then
         If ( PISSDAT < [F:FIS]DATSTRFIY ) Then
          RTRN = 1
          Break
         Endif
        Elsif ( PTYPTEST = 2 ) Then
         If ( PISSDAT >= [F:FIS]DATSTRFIY ) Then
          RTRN = 0
          Break
         Endif
        Endif
      Endif
  Next
  # <<<<<<<<<<<<

End

#########################################################
Subprog IS_SORTI_COURSUIV(ISSDAT,EXTISSFLG,RTRN)

Value    Date      ISSDAT          : # Date de sortie
Value    Integer   EXTISSFLG       : # Sortie prévisionnelle
Variable Integer   RTRN            : # Retour (1 Non - 2 Oui)
#
# Le bien comptable est considéré comme sorti dans l'exercice courant ou suivant
# si sa date de sortie est comprise entre la date de début de l'exercice courant
# du contexte fiscal et comptable et la date de fin de l'exercice suivant du même contexte
#

  RTRN = G_NON
  If ( ISSDAT >= GDEBEXECPF and ISSDAT <= GFINEXSCPF  ) Then
     RTRN = G_OUI
  Endif

End


#########################################################
Subprog IS_SORTI_PREVISIONNELLE(ISSDAT,EXTISSFLG,RTRN)

Value    Date      ISSDAT          : # Date de sortie
Value    Integer   EXTISSFLG       : # Sortie prévisionnelle
Variable Integer   RTRN            : # Retour (1 Non - 2 Oui)
#
# Le bien comptable est sorti à une date > à la date de début de l'exerice courant
# du contexte fiscal et comptable et son flag sortie prévisionnelle est positionné
#

  RTRN = G_NON
  If ( ISSDAT >= GDEBEXECPF  and EXTISSFLG = G_OUI ) Then
     RTRN = G_OUI
  Endif

End

#########################################################
Subprog CTRL_SRA(PCPY, PAASREF, PISSDAT, RCOD)

Value    Char    PCPY
Value    Char    PAASREF
Value    Date    PISSDAT
Variable Integer RCOD
#
# Contrôle si une sortie rétroactive est possible c'est à dire si le bien n'a pas fait
# l'objet d'une dépréciation ou d'une réévaluation entre la date de sortie et le début
# de la période courante pour chaque plan géré.
#
# Codes retour :
#   0     Ni réévaluation, ni dépréciation
#   1     Réévaluation(s)
#   2     Dépréciation(s)
#   3     Réévaluation(s) et dépréciation(s).
#
#   90    Erreur d'accès à une table
#

  Local Integer TI_PLAN : TI_PLAN = 1
  Local Integer TI_RVA  : TI_RVA  = 2
  Local Integer TI_IML  : TI_IML  = 3
  Local Integer TI_MDR  : TI_MDR  = 4 #Fq67577
  Local Integer RESULT(1..G301MAX-1, 1..4) #Fq67577

  Local Integer L_NB_RVA(1..G301MAX)
  Local Integer L_NB_IML(1..G301MAX)
  Local Integer L_NB_MDR(1..G301MAX) #Fq67577

  Local Integer I_CNX
  Local Integer I_PLN
  Local Integer R_RVA
  Local Integer R_IML
  Local Integer R_MDR #Fq67577

  Local Char    L_REQUETE(255)(5)

  If !clalev([F:WCNX]) : Local File CONTEXT  [WCNX] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR [WFIS] : Endif
  If !clalev([F:WDEP]) : Local File DEPREC   [WDEP] : Endif

  # Par plan : boucle sur DEPREC à partir du DEPREC contenant la date de sortie jusqu'à la période
  #            précédent la période courante.

  # >>>>>>>>>>>
  For I_CNX=1 To G300MAX
    Read [WCNX]CNX0=PCPY;I_CNX
    If !fstat
      Read [WFIS]FIY1=PCPY;I_CNX;GVML_TECOURA
      If ( !fstat and PISSDAT<[F:WFIS]DATSTRPER([F:WFIS]INDCURPER-1) ) Then
        For I_PLN=1 To [F:WCNX]NBPLC
            Gosub TRAITE_PLANS
        Next I_PLN
      Endif
    Endif
  Next I_CNX
  # <<<<<<<<<
  RCOD = R_RVA + R_IML + R_MDR #Fq67577

End

#=========
$TRAITE_PLANS

 L_NB_RVA=0
 L_NB_IML=0
 L_NB_MDR=0 #Fq67577

 L_REQUETE(1)="AASREF=PAASREF & DPRPLN=[F:WCNX]PLNCAA(I_PLN-1)"
 L_REQUETE(2)="& PERENDDAT>=PISSDAT & PERENDDAT <= [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)"
 Filter [WDEP] Where evalue (L_REQUETE)
 For [WDEP]
  If [F:WDEP]RVAAMT<>0
   L_NB_RVA+=1
  Endif
  If [F:WDEP]IML<>0
   L_NB_IML+=1
  Endif
  #Fq67577-Pologne
  If G_ACTKPL=G_OUI
   If [F:WDEP]KMDRDEV<>0 & [F:WDEP]KMDRDAT>=[F:WDEP]PERSTRDAT & [F:WDEP]KMDRDAT<=[F:WDEP]PERENDDAT
    L_NB_MDR+=1
   Endif
  Endif
  #Fin-Pologne
 Next
 Filter [WDEP]

 If L_NB_RVA : RESULT(I_PLN, TI_RVA)=L_NB_RVA : Endif
 If L_NB_IML : RESULT(I_PLN, TI_IML)=L_NB_IML : Endif
 If L_NB_MDR : RESULT(I_PLN, TI_MDR)=L_NB_MDR : Endif #Fq67577

 If L_NB_RVA & R_RVA = 0 : R_RVA=1 : Endif
 If L_NB_IML & R_IML = 0 : R_IML=2 : Endif
 If L_NB_MDR & R_MDR = 0 : R_MDR=3 : Endif #Fq67577

Return

#########################################################
Funprog CTRL_IML(PCPY, PAASREF)

Value    Char    PCPY
Value    Char    PAASREF
#
# Contrôle si une réévaluation a été faite sur les périodes courantes des contextes du bien.
#
# Codes retour :
#   1     G_NON     pas de dépréciation
#   2     G_OUI     dépréciation
#
  Local Integer I_CNX
  Local Integer RET   : RET = G_NON

  If !clalev([F:WCNX]) : Local File CONTEXT  [WCNX] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR [WFIS] : Endif
  If !clalev([F:WDEP]) : Local File DEPREC   [WDEP] : Endif

  # >>>>>>>>>>>
  For I_CNX=1 To G300MAX
    Read [WCNX]CNX0=PCPY;I_CNX
    If !fstat
      Read [WFIS]FIY1=PCPY;I_CNX;GVML_TECOURA
      If !fstat Then
        Filter [WDEP] Where AASREF=PAASREF & CNX=[F:WCNX]CNX & PERENDDAT=[F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) & IML<>0
        If rowcount([F:WDEP]) > 0
          Filter [WDEP]
          RET=G_OUI
          Break
        Endif
        Filter [WDEP]
      Endif
    Endif
  Next I_CNX
End RET

# Issue120085
#########################################################
Funprog CTRL_IMLRVE(PCPY, PAASREF)

Value    Char    PCPY
Value    Char    PAASREF
#
# Contrôle si une réévaluation a été faite sur les périodes courantes des contextes du bien.
#
# Codes retour :
#   1     G_NON     pas de dépréciation
#   2     G_OUI     dépréciation
#
  Local Integer I_CNX
  Local Integer RET   : RET = G_NON

  If !clalev([F:WCNX]) : Local File CONTEXT  [WCNX] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR [WFIS] : Endif
  If !clalev([F:WDEP]) : Local File DEPREC   [WDEP] : Endif

  # >>>>>>>>>>>
  For I_CNX=1 To G300MAX
    Read [WCNX]CNX0=PCPY;I_CNX
    If !fstat
      Read [WFIS]FIY1=PCPY;I_CNX;GVML_TECOURA
      If fstat = 0 Then
        Filter [WDEP] Where AASREF=PAASREF & CNX=[F:WCNX]CNX & PERENDDAT=[F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) & IMLRVE<>0
        Look [WDEP]DEP0 First
        If fstat = 0
          Filter [WDEP]
          RET=G_OUI
          Break
        Endif
        Filter [WDEP]
      Endif
    Endif
  Next I_CNX
End RET
# End Issue120085

#####################################################################
Subprog BCO_CTRL_TRANSFERT_POST(PAASREF,PDATREF,RMESSAGE,RCDRET)
Value    Char    PAASREF
Value    Date    PDATREF
Variable Char    RMESSAGE
Variable Integer RCDRET
# S/p de contrôle pour savoir s'il y eu un transfert de secteur
# d'activité postérieur à une date passée en référence ayant donné
# lieu à régul de TVA et si ce transfert peut être annulé.

Local Integer TRANSFERE
Local Integer TRFCCL
Local Integer CDRET

CDRET=0

Call BCO_TRANSFERE(PAASREF,PDATREF,TRANSFERE,TRFCCL,CDRET) From TRTFASTRF

If CDRET=-1
 RCDRET=-1
 End
Endif

If TRANSFERE=G_OUI & TRFCCL=G_NON
 # "Action impossible. Présence d'un transfert postérieur non annulable de secteur d'activité avec régularisation de TVA."
 RMESSAGE=mess(409,GML_MSGFAS,1)+"."+mess(410,GML_MSGFAS,1)
 RCDRET=1
 End
Endif

If TRANSFERE=G_OUI & TRFCCL=G_OUI
 # "Présence d'un transfert postérieur de secteur d'activité avec régularisation de TVA. Action possible après annulation de celui-ci"
 RMESSAGE=mess(411,GML_MSGFAS,1)+"."+mess(412,GML_MSGFAS,1)
 RCDRET=2
 End
Endif

End

#======================================================
# Amortissement exceptionnel

#======================================================
Funprog GET_EXCDPR(PCLASSE, PISSDAT, PTYPTRT)
Value Char    PCLASSE    # Classe contenant l'enregistrement DEPREC contenant l'amortissement exceptionnel
Value Date    PISSDAT    # Date de sortie si le bien est sorti
Value Integer PTYPTRT    # Type de prise en compte de la date de sortie
                         #     1 - Si date de sortie dans la période -> EXCDPR = 0
                         #     2 - Si date de sortie dans la période -> ECXDPR = amortissement excep de l'exercice

Local Decimal REXCDPR

# Si pas de date de sortie ou date de sortie postérieure à l'exercice courant
If evalue ("PISSDAT=[0/0/0] | (PISSDAT<>[0/0/0] & PISSDAT>"+PCLASSE+"FIYENDDAT)")
 If evalue (PCLASSE+"PERENDDAT<>[0/0/0] & "+PCLASSE+"FIYENDDAT="+PCLASSE+"PERENDDAT")
  REXCDPR = evalue (PCLASSE+"EXCDPR")
 Else
  REXCDPR = 0
 Endif
Endif

# Si date de sortie dans l'exercice courant
If evalue("PISSDAT<>[0/0/0] & PISSDAT<="+PCLASSE+"FIYENDDAT & PISSDAT>="+PCLASSE+"FIYSTRDAT" )
 # Si date de sortie dans la période courante
 If evalue ("PISSDAT>="+PCLASSE+"PERSTRDAT & PISSDAT<="+PCLASSE+"PERENDDAT")
  Case PTYPTRT
   When 1
    REXCDPR = 0
   When 2
    REXCDPR = evalue (PCLASSE+"EXCDPR")
   When Default
  Endcase
 # Si date de sortie dans une période close de l'exercice
 Elsif evalue ("PISSDAT<"+PCLASSE+"PERSTRDAT")
  Case PTYPTRT
   When 1
    REXCDPR = 0
   When 2
    REXCDPR = evalue (PCLASSE+"EXCDPR")
   When Default
  Endcase
 Else
  REXCDPR = 0
 Endif
Endif

End REXCDPR

#******************************************************************************
#*              A M T    D E R O G A T O I R E                                *
#******************************************************************************

#======================================================
# Calcul du solde DEROGATOIRE pour la période

Funprog SOLDE_DEROG(PAASREF, PFIYENDDAT, PPERENDDAT, PDEBPER )
Value Char    PAASREF
Value Integer PDEBPER  # Oui - Non
Value Date    PFIYENDDAT, PPERENDDAT

Local Decimal DPRCUMF, PERDPRCUMF, PERENDDPEF, PEREXCDPRF
Local Decimal DPRCUMC, PERDPRCUMC, PERENDDPEC, PEREXCDPRC
Local Decimal LSLDDER, SLDDER

  If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif

  # -- Fiscal --
  Raz [F:DEPX]
  Read [DEPX] DEP0=PAASREF;G301FIS;PFIYENDDAT;PPERENDDAT
  If (fstat) Then
    # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
    Filter [DEPX] Where AASREF= PAASREF and DPRPLN= G301FIS
    Read [DEPX]DEP0 Last
    Filter [DEPX]
  Else
    # Le plan fiscal n'est pas géré, le solde dérogatoire à 0.
    SLDDER = 0
  Endif
  DPRCUMF    = [F:DEPX]DPRCUM
  PERDPRCUMF = [F:DEPX]PERCLOCUM
  If ([F:DEPX]PERENDDAT = [0/0/0] ) Then
    PERENDDPEF = [F:DEPX]ENDDPE
  Else
    PERENDDPEF = [F:DEPX]PERENDDPE
  Endif

  # -- Comptable --
  Raz [F:DEPX]
  Read [DEPX] DEP0=PAASREF;G301CPT;PFIYENDDAT;PPERENDDAT
  If (fstat) Then
    # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
    Filter [DEPX] Where AASREF= PAASREF and DPRPLN= G301CPT
    Read [DEPX]DEP0 Last
    Filter [DEPX]
  Endif
  DPRCUMC    = [F:DEPX]DPRCUM
  PERDPRCUMC = [F:DEPX]PERCLOCUM
  If ([F:DEPX]PERENDDAT = [0/0/0] ) Then
    PERENDDPEC = [F:DEPX]ENDDPE
  Else
    PERENDDPEC = [F:DEPX]PERENDDPE
  Endif

  # Calcul du solde dérogatoire

  If (PDEBPER = G_OUI) Then
    # Solde début de période
    LSLDDER     =    DPRCUMF     - DPRCUMC
&               +  ( PERDPRCUMF  - PERDPRCUMC )
    SLDDER = LSLDDER
  Else
    If (PDEBPER = G_NON) Then
      # Solde fin de période
      LSLDDER     =    DPRCUMF     - DPRCUMC
&                 +  ( PERDPRCUMF  - PERDPRCUMC )
&                 +  ( PERENDDPEF  - PERENDDPEC )
      SLDDER = LSLDDER
    Else
      # Solde début d'exercice
      LSLDDER     =    DPRCUMF     - DPRCUMC
    Endif
  Endif

End SLDDER


#======================================================
# Calcul de l'amortissement DEROGATOIRE de la période

Funprog AMT_DEROG(PAASREF, PFIYENDDAT, PPERENDDAT )
Value Char    PAASREF
Value Date    PFIYENDDAT, PPERENDDAT

Local Decimal PERENDDPEF, PEREXCDPRF
Local Decimal PERENDDPEC, PEREXCDPRC
Local Decimal LAMTDER

  If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif

  # -- Fiscal --
  Raz [F:DEPX]
  Read [DEPX] DEP0=PAASREF;G301FIS;PFIYENDDAT;PPERENDDAT
  If (fstat) Then
    # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
    Filter [DEPX] Where AASREF= PAASREF and DPRPLN= G301FIS
    Read [DEPX]DEP0 Last
    Filter [DEPX]
  Else
    # Le plan fiscal n'est pas géré, l'amortissement dérogatoire à 0.
    LAMTDER = 0
  Endif
  If ([F:DEPX]PERENDDAT = [0/0/0] ) Then
    PERENDDPEF = [F:DEPX]ENDDPE
  Else
    PERENDDPEF = [F:DEPX]PERENDDPE
  Endif

  # -- Comptable --
  Raz [F:DEPX]
  Read [DEPX] DEP0=PAASREF;G301CPT;PFIYENDDAT;PPERENDDAT
  If (fstat) Then
    # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
    Filter [DEPX] Where AASREF= PAASREF and DPRPLN= G301CPT
    Read [DEPX]DEP0 Last
    Filter [DEPX]
  Endif
  If ([F:DEPX]PERENDDAT = [0/0/0] ) Then
    PERENDDPEC = [F:DEPX]ENDDPE
  Else
    PERENDDPEC = [F:DEPX]PERENDDPE
  Endif

  # Calcul de l'amortissement dérogatoire au début de période de l'exercice
  LAMTDER     =  (PERENDDPEF - PERENDDPEC)
End LAMTDER

#======================================================
# Calcule et rend l'amortissement DEROGATOIRE de la période/exercice
# Si PPROV=G_OUI : rend une provision s'il y en a ou 0
# Si PPROV=G_NON : rend une reprise   s'il y en a ou 0

Funprog GET_PRV_REP_DEROG (PPROV, PAASREF, PFIYENDDAT, PPERENDDAT )
Value Integer PPROV
Value Char    PAASREF
Value Date    PFIYENDDAT, PPERENDDAT

Local Decimal LAMTDER

  LAMTDER = func TRTFAS.AMT_DEROG(PAASREF, PFIYENDDAT, PPERENDDAT )
  If PPROV = G_OUI Then
    # TRAITEMENT PROVISION DEROGATOIRE
    If LAMTDER < 0 Then
      LAMTDER = 0
    Endif
  Else
    # TRAITEMENT REPRISE   DEROGATOIRE
    If LAMTDER < 0 Then
      LAMTDER = abs(LAMTDER)
    Else
      LAMTDER = 0
    Endif
  Endif
End LAMTDER

#******************************************************************************
#*                      Type de données  R A T  : Taux                        *
#******************************************************************************

#======================================================
Subprog CONTRAT(VALEUR)
Variable Decimal VALEUR
  # Contrôle de la valeur du pourcentage
  If VALEUR > 100 Then
    GMESSAGE = mess(102,7770,1) : # La valeur du taux ne doit pas être supérieure à 100.
    mkstat = 2
  Endif
End

#gbn-FQ57157
#======================================================
Subprog CONTRA1(VALEUR)
Variable Decimal VALEUR
  # Contrôle de la valeur du pourcentage
  If VALEUR > 1 | VALEUR<0 Then
    GMESSAGE = mess(253,7770,1) : # La valeur doit être comprise en 0 et 1
    mkstat = 2
  Endif
End

#******************************************************************************
#*                     REGULARISATION  DE  T.V.A.                             *
#******************************************************************************



########################################
Subprog GET_ELEM_REG_TVA(PFCY)
#Global   Decimal     G_ECIMPBAS   : # Ecart imputation bases
#Global   Decimal     G_ECVARPRO   : # Ecart variation du prorata dans le temps
#Global   Integer     G_TENCOURS   : # Immobilisation En cours à régulariser
#Global   Integer     G_REGULIAS   : # Régularisation TVA applicable aux valorisations IAS/IFRS

# Alimente dans des globales  L'écart imputation bases, l'écart déclencheur suite à variation du taux dans le temps et si les
# biens de nature "Immobilisation en cours" peuvent faire l'objet d'une régularisation.
# Attention - La suppression des globales est à la charge du programmeur.


Value Char PFCY

  # Ecart imputation bases fixation définitif
  If ( dim(G_ECIMPBAS) < 0 ) Then :  Global Decimal  G_ECIMPBAS   :  Endif
  # Ecart variation du prorata dans le temps
  If ( dim(G_ECVARPRO) < 0 ) Then :  Global Decimal  G_ECVARPRO   :  Endif
  # Immobilisation En cours à régulariser
  If ( dim(G_TENCOURS) < 0 ) Then :  Global Decimal  G_TENCOURS   :  Endif
  # Régularisation TVA applicable aux valorisations IAS/IFRS
  If ( dim(G_REGULIAS) < 0 ) Then :  Global Decimal  G_REGULIAS   :  Endif
  # Indicateur imputation base si variation du prorata dans le temps
  If ( dim(G_IMPBASVT) < 0 ) Then :  Global Decimal  G_IMPBASVT   :  Endif


Local Char    LPARM(10)

  # Ecart imputation base d'amortissement
  Call PARAM(PFCY,"REGBASDEV",LPARM) From ADOVAL
  G_ECIMPBAS = val(LPARM)

  # Ecart variation dans le temps
  Call PARAM(PFCY,"REGVATDEV",LPARM) From ADOVAL
  G_ECVARPRO = val(LPARM)

  # Prise en compte des Immobilisations "En cours"
  Call PARAM(PFCY,"REGENCOURS",LPARM) From ADOVAL
  G_TENCOURS  = val(LPARM)

  # Prise en compte des valorisations IAS/IFRS
  Call PARAM(PFCY,"REGVATIAS",LPARM) From ADOVAL
  G_REGULIAS  = val(LPARM)

  # Indicateur imputation base si variation TVA dans le temps
  Call PARAM(PFCY,"REGMAJBAS",LPARM) From ADOVAL
  G_IMPBASVT = val(LPARM)

End


########################################
Subprog EVAL_PERIODE_REGUL_TVA(TAXTYP, DATREF, DUREE)
Value    Integer     TAXTYP   # Type de taxe foncière
Value    Date        DATREF   # Date de référence
Variable Decimal     DUREE    # Durée

# Rend la Période de régularisation exprimée en nombre d'année.

  # Si le type de taxe est "Foncière"
  # la durée est de 20 ans si la date de référence est antérieure à 96
  # la durée est de 10 ans dans le cas contraire
  # la durée est de 5 ans pour les autres types de taxe.
  If ( TAXTYP = GVML_TTFONCI ) Then
    If ( DATREF < [01/01/1996]) Then
      DUREE = 10
    Else
      DUREE = 20
    Endif
  Else
    DUREE = 5
  Endif
End


#########################################################
Funprog IS_HORS_PERIODE_REGUL( PPERREG, PVATREGDAT, PDATREF )
Value Integer PPERREG
Value Date    PVATREGDAT
Value Date    PDATREF
Local Integer RTRN

  # Est-on hors période de régularisation TVA ?
  If( func TRTFAS.TVA_GET_PERIODE_RESID( PPERREG, PVATREGDAT, PDATREF ) <= 0 ) Then
    RTRN = 1
  Else
    RTRN = 0
  Endif
End RTRN

#########################################################
Funprog TVA_GET_PERIODE_RESID( PPERREG, PVATREGDAT, PDATREF )
Value Integer PPERREG
Value Date    PVATREGDAT
Value Date    PDATREF
Local Integer RTRN

  If ( PPERREG <> 0 ) Then
    # Bien comptable
    RTRN  = PPERREG -(( year(PDATREF)- year(PVATREGDAT) )+1)
  Else
    # Dépense
    RTRN = 0
  Endif

  If ( RTRN < 0 ) Then : RTRN = 0 : Endif
End RTRN


#########################################################
Funprog FAS_IS_REGULARISABLE(PCLASSE)

# Prérequis : Le sous-programme GET_ELEM_REG_TVA doit être executé.

Value    Char      PCLASSE          : # Classe fichier FXDASSETS
Local    Integer   RTRN             : # Retour

Local Char    FC

#
# Le bien comptable est régularisable si
#     (    la nature PCG est "En service" ou "En cours" selon paramétrage
#       OU la nature IAS est "En service" ou "En cours" selon paramétrage )
#  ET le type de détention du bien n'est pas "En location", "En modéle", "En prévision"
#  ET le bien n'est pas sorti (sortie réelle)
#
#

  RTRN  = 0
  FC    = PCLASSE

  If ( ( evalue(FC+"GACACN")= GVML_NIENSER or (evalue(FC+"GACACN")= GVML_NIENCOU and G_TENCOURS= G_OUI)) or
&      ( G_REGULIAS = G_OUI and GCNXPROIAS = G_OUI and
&        (evalue(FC+"IASACN")= GVML_NIENSER or (evalue(FC+"IASACN")= GVML_NIENCOU and G_TENCOURS= G_OUI)) and
&        (not find(evalue(FC+"OWNTYP"), GVML_TDLOCAT, GVML_TDMODEL, GVML_TDPREVU)) and
&        (evalue(FC+"ISSDAT")= [0/0/0] or (evalue(FC+"ISSDAT")<> [0/0/0] and evalue(FC+"EXTISSFLG")= G_OUI))
&       ) ) Then
    RTRN = 1
  Endif

End RTRN

########################################
Subprog DETERM_TYPE_REGUL(PCLASSE, PDATREF, PDATTRT, PPERREG, RDURRES, RREGTYP, RREGTYPI  )
Value     Char        PCLASSE    : # Classe fichier FXDASSETS
Value     Date        PDATREF    : # Date référence
Value     Date        PDATTRT    : # Date traitement
Value     Decimal     PPERREG    : # Période de régularisation TVA
Variable  Integer     RDURRES    : # Durée résiduelle ( Si variation de prorata dans le temps)
Variable  Integer     RREGTYP    : # Type de régularisation PCG
Variable  Integer     RREGTYPI   : # Type de régularisation IAS

# Détermine le type de régularisation à appliquer.
#   0 pas de régularisation (hors période de régularisation)
#   1 Biens acquis dans l'exercice courant (ajustement des bases)
#   2 Biens acquis dans un exercice antérieur (variation récupération dans le temps)
#   3 Biens acquis dans un exercice au delà de l'exercice courant (ajustement des bases)

Local Integer LDURDET
Local Char    FC

  FC       = PCLASSE
  RREGTYP  = 0 : # Pas de régularisation PCG par défaut
  RREGTYPI = 0 : # Pas de régularisation IAS par défaut

  #--------------------------
  If (   ( evalue(FC+"GACACN") = GVML_NIENSER or
&         (evalue(FC+"GACACN") = GVML_NIENCOU and G_TENCOURS = G_OUI) ) ) Then
    If ( PDATREF >= GDEBEXECPF ) Then
      If ( PDATREF <= GFINEXECPF ) Then
        # Biens acquis dans l'exercice courant PCG
        RREGTYP  = 1
      Else
        # Biens acquis dans un exercice suivant l'exercice courant PCG
        RREGTYP  = 3
      Endif
    Else
      # Biens acquis dans un exercice antérieur
      RREGTYP  = 2
    Endif

    If PPERREG <> 0
      # Bien comptable
      LDURDET  = ( year(PDATTRT) - year(PDATREF) ) + 1
      RDURRES  = PPERREG - LDURDET
      If (RDURRES < 0 ) Then
        # Pas de régul PCG -> hors période de régularisation
        RREGTYP  = 0
      Endif
    Else
      # Dépense
      RDURRES = 0
    Endif
  Endif
  #--------------------------
  #--------------------------
  If (   G_REGULIAS = G_OUI and GCNXPROIAS = G_OUI and
&      ( evalue(FC+"IASACN") = GVML_NIENSER or
&       (evalue(FC+"IASACN") = GVML_NIENCOU and G_TENCOURS = G_OUI) ) ) Then
    If ( PDATREF >= GDEBEXECPF  ) Then
      # Biens acquis dans l'exercice courant IAS
      If ( PDATREF <= GFINEXECPF ) Then
        # Biens acquis dans l'exercice courant IAS
        RREGTYPI  = 1
      Else
        # Biens acquis dans un exercicie suivant l'exercice courant IAS
        RREGTYPI  = 3
      Endif
    Else
      # Biens acquis dans un exercice antérieur
      RREGTYPI  = 2
    Endif

    If PPERREG <> 0
      # Bien comptable
      LDURDET  = ( year(PDATTRT) - year(PDATREF) ) + 1
      RDURRES  = PPERREG - LDURDET
      If (RDURRES < 0 ) Then
        # Pas de régul IAS -> hors période de régularisation
        RREGTYPI  = 0
      Endif
    Else
      # Dépense
      RDURRES = 0
    Endif
  Endif
  #--------------------------
End

########################################
Subprog REGUL_TVA_TRANSFERT_SECTEUR ( PCLASSE, PDATTRF, PLASMFLG, RREGUL, RREGULI, RFORM, RFORMI, RPCGDEV, RIASDEV,  RTRN )

# Prérequis : Le sous-programme GET_ELEM_REG_TVA doit avoir été executé.

Value    Char      PCLASSE          : # Classe fichier FXDASSETS
Value    Date      PDATTRF          : # Date du transfert
Value    Integer   PLASMFLG         : # Indicateur livraison à soi-même FQ78968
Variable Decimal   RREGUL           : # Régularisation PCG
Variable Decimal   RREGULI          : # Régularisation IAS
Variable Char      RFORM            : # Formule PCG
Variable Char      RFORMI           : # Formule IAS
Variable Decimal   RPCGDEV          : # Ecart sur TVA récupérée PCG
Variable Decimal   RIASDEV          : # Ecart sur TVA récupérée IAS
Variable Integer   RTRN             : # Code retour

#                  = -1   Pas régularisable
#                  =  0   OK
#                  =  1   Erreur sur lecture du secteur d'activité

Local Decimal SDEDVATAMT, SDEDVATAMTI
Local Decimal LTAUXPRO,   LTAUXDEF   , LMONTANT, LTAUX
Local Decimal SIVCVATAMT, SIVCVATAMTI
Local Decimal SDEDVATRAT, SDEDVATRATI
Local Decimal SDEDCOE
Local Decimal LASJCOE
Local Integer LTAUXDEFFLG
Local Integer LERROR,     LREGTYP    , LREGTYPI
Local Integer LDURRES
Local Char    FC

  FC = PCLASSE
  RTRN = 0 : # OK

  RREGUL  = 0
  RREGULI = 0
  RFORM   = ""
  RFORMI  = ""
  RPCGDEV = 0
  RIASDEV = 0

  # Sauvegarde coefficient de déduction avant transfert
  SDEDCOE = evalue(FC+"DEDCOE")

  # Régularisation de TVA en cas de transfert.
  # ------------------
  If not (func TRTFAS.FAS_IS_REGULARISABLE(PCLASSE) ) Then
    RTRN = -1 : End : # Pas régularisable
  Endif
  # Récupération des taux provisoire, définitif de récupération pour le secteur
  Call GET_COE_SECTEUR
&      (evalue(FC+"CPY"), evalue(FC+"AASBUS"), LASJCOE, LTAUXPRO, LTAUXDEF, LTAUXDEFFLG,  LERROR) From TRTFAS
  # ----------------------
  If (LERROR) Then
    RTRN = 1 : End : # Erreur lecture secteur d'activite dans la table diverse 410
  Endif
  # Détermination des nouveaux coefficients de déduction et du nouveau taux de récupération
  Call TVA_COE_DEDUCTION ( evalue(FC+"ASJCOEF"), LTAUXPRO, evalue(FC+"ADMCOEF"), LTAUX ) From TRTFAS
  Assign FC+"TAXCOEF"  With LTAUXPRO
  Assign FC+"DEDCOEF"  With LTAUX
  Call TVA_COE_DEDUCTION ( evalue(FC+"ASJCOE"), LTAUXPRO, evalue(FC+"ADMCOE"), LTAUX ) From TRTFAS
  LTAUX = LTAUX * 100.
  Assign FC+"TAXCOE"  With LTAUXPRO
  Assign FC+"DEDCOE"  With LTAUX / 100

  # FQ78968 GLE : utilisation de la date de transfert plutôt que de la date de régularisation dans le cas de la LASM FQ78968
  If (PLASMFLG = G_OUI) Then : # FQ78968
    # Date de référence TVA
    Assign FC+"VATREGDAT" With PDATTRF
  Endif

  # Determination de type de régularisation 0-Aucune 1-Exercice acquisition 2-Exercice antérieur 3-Acquisition future.
  Call DETERM_TYPE_REGUL
&      (FC, evalue(FC+"VATREGDAT"), PDATTRF, evalue(FC+"THESLI"), LDURRES, LREGTYP, LREGTYPI) From TRTFAS
  # ----------------------
  # Il peut y avoir régularisation au delà de l'exercice d'acquisition dans la cas du transfert
  # d'un secteur assujetti total à un secteur assujetti partiel (de taux 0% à taux >0%)
  If ( LREGTYP = 0 and LREGTYPI = 0 ) Then
    RTRN = -1 : End : # Pas régularisable
  Endif

  # Régularisation - PCG -
  # ----
  If ( LREGTYP = 1 or LREGTYP = 3 ) Then
    # -------------        Exercice d'acquisition ou Acquisition future
    # Sauvegarde Ancienne TVA récupérée
    SIVCVATAMT    = evalue(FC+"IVCVATAMT")
    SDEDVATAMT    = evalue(FC+"DEDVATAMT")
    SDEDVATRAT    = evalue(FC+"DEDVATRAT")
    # Taux récup PCG hérite du taux du secteur
    Assign FC+"DEDVATRAT" With LTAUX
    # Nouvelle TVA récupérée
    LMONTANT = evalue(FC+"IVCVATAMT") * ( LTAUX / 100 )
    Call GET_MNT_ARRONDI(LMONTANT, GCOUDEV, LMONTANT) From GLOBIENS
    Assign FC+"DEDVATAMT" With LMONTANT
    Assign FC+"DEDVATFLG" With G_NON
    # Information régularisation de TVA pour événement de transfert
    RREGUL  = evalue(FC+"DEDVATAMT") - SDEDVATAMT
    RFORM  = "(" - format$('N:'+GFMT3, evalue(FC+"DEDVATAMT")) - "-" - format$('N:'+GFMT3, SDEDVATAMT) - ")"
    # Ecart sur valeur bilan PCG
    RPCGDEV = evalue(FC+"DEDVATAMT") - SDEDVATAMT
  Endif
  # ----

  # ----
  If ( LREGTYP = 2 ) Then
    # Sauvegarde Ancienne valeur
    SIVCVATAMT    = evalue(FC+"IVCVATAMT")
    SDEDVATAMT    = evalue(FC+"DEDVATAMT")
    SDEDVATRAT    = evalue(FC+"DEDVATRAT")
    # Taux récup PCG hérite du taux du secteur
    Assign FC+"DEDVATRAT" With LTAUX
    # Nouvelle TVA facturée
    LMONTANT = evalue(FC+"IVCVATAMT") * ( LDURRES / evalue(FC+"THESLI") )
    Call GET_MNT_ARRONDI(LMONTANT, GCOUDEV, LMONTANT) From GLOBIENS
    Assign FC+"IVCVATAMT" With LMONTANT
    Assign FC+"IVCVATFLG" With G_OUI
    # Nouvelle TVA récupérée
    LMONTANT = evalue(FC+"IVCVATAMT") * LTAUX/100
    Call GET_MNT_ARRONDI(LMONTANT, GCOUDEV, LMONTANT) From GLOBIENS
    Assign FC+"DEDVATAMT" With LMONTANT
    Assign FC+"DEDVATFLG" With G_NON
    # Date de référence TVA
    Assign FC+"VATREGDAT" With PDATTRF
    # Période TVA résiduelle
    Assign FC+"VATRSD" With  func TRTFAS.TVA_GET_PERIODE_RESID( evalue(FC+"THESLI"), evalue(FC+"VATREGDAT"), evalue(FC+"VATREGDAT"))
    # Information régularisation de TVA pour événement de transfert
    RREGUL = (0 - SDEDCOE) * SIVCVATAMT * (LDURRES / evalue(FC+"THESLI"))
    RFORM  = "(0 -" - format$('N:'+GFMT3, SDEDCOE) - ")*" - format$('N:'+GFMT3, SIVCVATAMT) -
&            "*(" - num$(LDURRES) - "/"  - num$(evalue(FC+"THESLI")) - ")"
    # Ecart sur valeur bilan PCG
    RPCGDEV = evalue(FC+"DEDVATAMT") - SDEDVATAMT
  Endif
  # ----
  # Régularisation - IAS -
  # ----
  If ( LREGTYPI = 1 or LREGTYPI = 3 )  Then
    # -------------      Exercice d'acquisition ou Acquisition future
    # Sauvegarde Ancienne TVA récupérée
    SIVCVATAMTI    = evalue(FC+"IVCVATAMTI")
    SDEDVATAMTI    = evalue(FC+"DEDVATAMTI")
    SDEDVATRATI    = evalue(FC+"DEDVATRATI")
    # Taux récup IAS hérite du taux provisoire du nouveau secteur
    Assign FC+"DEDVATRATI" With LTAUX
    # Nouvelle TVA récupérée
    LMONTANT = evalue(FC+"IVCVATAMTI") * ( LTAUX / 100 )
    Call GET_MNT_ARRONDI(LMONTANT, GCNXCURIAS, LMONTANT) From GLOBIENS
    Assign FC+"DEDVATAMTI" With LMONTANT
    Assign FC+"DEDVATFLGI" With G_NON
    # Information régularisation de TVA pour événement de transfert
    RREGULI  = evalue(FC+"DEDVATAMTI") - SDEDVATAMTI
    RFORMI   = "(" - format$('N:'+GFMT3, evalue(FC+"DEDVATAMTI")) - "-" - format$('N:'+GFMT3, SDEDVATAMTI) - ")"
    # Ecart sur valeur bilan IAS
    RIASDEV = evalue(FC+"DEDVATAMTI") - SDEDVATAMTI
  Endif
  # ----

  If (  LREGTYPI = 2 ) Then : # GLE FQ78968 LREGTYP -> LREGTYPI
    # -------------      Exercice d'acquisition ou Acquisition future
    # Sauvegarde Ancienne valeur
    SIVCVATAMTI   = evalue(FC+"IVCVATAMTI")
    SDEDVATAMTI   = evalue(FC+"DEDVATAMTI")
    SDEDVATRATI   = evalue(FC+"DEDVATRATI")
    # Taux récup IAS hérite du taux provisoire du nouveau secteur
    Assign FC+"DEDVATRATI" With LTAUX
    # Nouvelle TVA facturée
    LMONTANT = evalue(FC+"IVCVATAMTI") * ( LDURRES / evalue(FC+"THESLI") )
    Call GET_MNT_ARRONDI(LMONTANT, GCNXCURIAS, LMONTANT) From GLOBIENS
    Assign FC+"IVCVATAMTI" With LMONTANT
    Assign FC+"IVCVATFLGI" With G_OUI
    # Nouvelle TVA récupérée
    LMONTANT = evalue(FC+"IVCVATAMTI") * LTAUX/100
    Call GET_MNT_ARRONDI(LMONTANT, GCNXCURIAS, LMONTANT) From GLOBIENS
    Assign FC+"DEDVATAMTI" With LMONTANT
    Assign FC+"DEDVATFLGI" With G_NON
    # Information régularisation de TVA pour événement de transfert
    RREGULI  = (0 - SDEDCOE) * SIVCVATAMTI * (LDURRES / evalue(FC+"THESLI"))
    RFORMI   = "(0 -" - format$('N:'+GFMT3, SDEDCOE) - ")*" - format$('N:'+GFMT3, SIVCVATAMTI) -
&             "*(" - num$(LDURRES) - "/"  - num$(evalue(FC+"THESLI")) - ")"
    # Ecart sur valeur bilan IAS
    RIASDEV = evalue(FC+"DEDVATAMTI") - SDEDVATAMTI
  Endif
  # ----

End

########################################
Subprog TVA_REGUL_GLOBALE ( PCLASSE, PDATMVT, PDEDCOEFO, RREGUL, RREGULI, RFORM, RFORMI, RDURRES, RTRN )

# Prérequis : Le sous-programme GET_ELEM_REG_TVA doit avoir été executé.
#

Value    Char      PCLASSE          : # Classe fichier FXDASSETS
Value    Date      PDATMVT          : # Date de la regularisation
Value    Decimal   PDEDCOEFO        : # Ancien coefficient futur de déduction
Variable Decimal   RREGUL           : # Régularisation PCG
Variable Decimal   RREGULI          : # Régularisation IAS
Variable Char      RFORM            : # Formule PCG
Variable Char      RFORMI           : # Formule IAS
Variable Decimal   RDURRES          : # Durée résiduelle
Variable Integer   RTRN             : # Code retour

#                  = -1   Pas régularisable
#                  =  0   OK
#                  =  1   Erreur sur lecture du secteur d'activité

Local Integer LDURRES


  RTRN    = 0 :  # OK
  RREGUL  = 0
  RREGULI = 0
  Local Char FC : FC = PCLASSE

  # ----------------------
  # Période TVA résiduelle
  RDURRES = func TRTFAS.TVA_GET_PERIODE_RESID( evalue(FC+"THESLI"), evalue(FC+"VATREGDAT"), PDATMVT )

  # ----------------------
  # Régularisation - PCG -
  # ----
  RREGUL  = (evalue(FC+"DEDCOEF") - PDEDCOEFO ) * evalue(FC+"IVCVATAMT") * (RDURRES / evalue(FC+"THESLI"))
  RFORM  = "("- format$('N:'+GFMT3, evalue(FC+"DEDCOEF")) - "-"
&             - format$('N:'+GFMT3, PDEDCOEFO          ) - ")*" - format$('N:'+GFMT3, evalue(FC+"IVCVATAMT")) -
&          "*(" - num$(RDURRES) - "/"  - num$(evalue(FC+"THESLI")) - ")"

  # Régularisation - IAS -
  # ----
  RREGULI  = (evalue(FC+"DEDCOEF") - PDEDCOEFO ) * evalue(FC+"IVCVATAMTI") * (RDURRES / evalue(FC+"THESLI"))
  RFORMI  = "("- format$('N:'+GFMT3, evalue(FC+"DEDCOEF")) - "-"
&              - format$('N:'+GFMT3, PDEDCOEFO          ) - ")*" - format$('N:'+GFMT3, evalue(FC+"IVCVATAMTI")) -
&          "*(" - num$(RDURRES) - "/"  - num$(evalue(FC+"THESLI")) - ")"

End

#########################################################
Funprog LOF_IS_REGULARISABLE(PCLASSE)

# Prérequis : Le sous-programme GET_ELEM_REG_TVA doit être executé.

Value    Char      PCLASSE          : # Classe fichier FXDASSETS
Local    Integer   RTRN             : # Retour

Local Char    FC

#
# La dépense est régularisable si
#     elle n'est pas rattachée à un bien
#  ET (    la nature PCG est "En service" ou "En cours" selon paramétrage
#       OU la nature IAS est "En service" ou "En cours" selon paramétrage )
#
#
  FC    = PCLASSE
  # Non régularisable par défaut
  RTRN  = 0
  # Si la dépense est rattachée à un bien elle n'est pas régularisable
  If ( evalue(FC+"FLGLIKAAS") <> G_OUI ) Then
     If ( GCNXPROIAS = G_NON ) Then
       # Pas de gestion de l'IAS
       If ( (evalue(FC+"GACACN") = GVML_NIENSER or
&           (evalue(FC+"GACACN") = GVML_NIENCOU and G_TENCOURS = G_OUI))  ) Then
         RTRN = 1
       Endif
     Else
       # Gestion de l'IAS
       If ( G_REGULIAS = G_OUI ) Then
         # Gestion de régul pour le contexte IAS
         If ( (evalue(FC+"GACACN") = GVML_NIENSER or
&             (evalue(FC+"GACACN") = GVML_NIENCOU and G_TENCOURS = G_OUI))
&          and
&             (evalue(FC+"IASACN") = GVML_NIENSER or
&             (evalue(FC+"IASACN") = GVML_NIENCOU and G_TENCOURS = G_OUI)) ) Then
           RTRN = 1
         Endif
       Else
         # Pas de gestion de régul pour le contexte IAS
         If ( (evalue(FC+"GACACN") = GVML_NIENSER or
&             (evalue(FC+"GACACN") = GVML_NIENCOU and G_TENCOURS = G_OUI)) ) Then
           RTRN = 1
         Endif
       Endif
    Endif
  Endif

End RTRN

########################################
Subprog REGUL_TVA_DEPENSE ( PTRT, PCLASSE, PCPY, RREGUL, RTAUXPRO, RTVARECINI,  RTRN )

# Prérequis : Le sous-programme GET_ELEM_REG_TVA doit avoir été executé.

#

Value    Char      PTRT             : # Traitement : "FUNLOFLDAB" "TRTLOFVATREG"
Value    Char      PCLASSE          : # Classe fichier FXDASSETS
Value    Char      PCPY             : # Société
Variable Decimal   RREGUL           : # Regularisation
Variable Decimal   RTAUXPRO         : # Taux provisoire
Variable Decimal   RTVARECINI       : # Taux provisoire
Variable Integer   RTRN             : # Code retour

#                  = -1   Pas régularisable
#                  =  0   OK
#                  =  1   Erreur sur lecture du secteur d'activité
#                  =  2   Erreur sur conversion devise transaction vers devise société

Local Decimal SDEDVATAMT
Local Decimal LASJCOE,    LTAUXPRO, LTAUXDEF, LMONTANT, LTAUX
Local Integer LTAUXDEFFLG, LERROR,  LREGTYP , LREGTYPI, LDURRES,  STAT
Local Decimal MTDES
Local Char    FC

  FC = PCLASSE
  RTRN = 0 :  # OK
  RREGUL = 0
  # Régularisation de TVA en cas de transfert.
  # ------------------
  If not (func TRTFAS.LOF_IS_REGULARISABLE(PCLASSE) ) Then
    RTRN = -1 : End : # Pas régularisable
  Endif


  # ----------------------
  # Détermination taux de TVA récupérée
  If (PTRT = "FUNLOFLDAB") Then
    LTAUXDEF = evalue(FC+"TAXCOE")
  Else
    If (evalue(FC+"TAXCOEFLG") = G_OUI) Then
      LTAUXDEF = evalue(FC+"TAXCOE")
    Else
      If ( evalue(FC+"ACT") = "" ) Then
        LTAUXDEF = evalue(FC+"TAXCOE")
      Else
        # Récupération des taux provisoire, définitif de récupération pour le secteur
        Call GET_COE_SECTEUR
&       (evalue(FC+"CPY"), evalue(FC+"ACT"), LASJCOE, LTAUXPRO, LTAUXDEF, LTAUXDEFFLG,  LERROR) From TRTFAS
        # Si erreur lors de la lecture secteur d'activite
        If ( LERROR )               Then : RTRN = 1  : End  : Endif
        # Si le taux définitif n'est pas fixé pas de régularisation
        If ( LTAUXDEFFLG <> G_OUI ) Then : RTRN = -1 : End  : Endif
      Endif
    Endif
  Endif
  Call TVA_COE_DEDUCTION ( evalue(FC+"ASJCOE"), LTAUXDEF, evalue(FC+"ADMCOE"), LTAUX ) From TRTFAS
  LTAUX = LTAUX * 100.
  # ----------------------
  # Si taux de la dépense et taux définitif sont identiques pas de régularisation
  If ( evalue(FC+"RATVATREC") = LTAUX) Then
    RTRN = -1 : End : # Pas régularisable
  Endif
  # ----------------------
  # Determination de type de régularisation 0-Aucune 1-Exercice acquisition 2-Exercice antérieur.
  Call DETERM_TYPE_REGUL
& (PCLASSE, evalue(FC+"DATIMP"), evalue(FC+"DATIMP"), 0, LDURRES, LREGTYP, LREGTYPI) From TRTFAS
  # ----------------------
  If (LREGTYP <> 1 and LREGTYP <> 3) Then
    RTRN = -1 : End : # Pas régularisable
  Endif

  # Régularisation - PCG -
  # ----
  If ( LREGTYP = 1 or LREGTYP = 3 ) Then : # ---     Exercice d'acquisition et au delà
    # Sauvegarde ancien Taux TVA récupérée
    RTAUXPRO      = evalue(FC+"RATVATREC")
    # Sauvegarde Ancienne TVA récupérée
    SDEDVATAMT    = evalue(FC+"AMTVATRCPY")
    RTVARECINI    = evalue(FC+"AMTVATRCPY")
    # Taux récup hérite du taux définitif du secteur d'activité
    Assign FC+"RATVATREC" With LTAUX
    # Nouvelle TVA récupérée en devise transaction
    LMONTANT = evalue(FC+"AMTVATCUR") * ( LTAUX / 100 )
    Call GET_MNT_ARRONDI(LMONTANT, GCOUDEV, LMONTANT) From GLOBIENS
    Assign FC+"AMTVATRCUR" With LMONTANT
    Assign FC+"FLGRECFVR" With G_NON
    # Nouvelle TVA récupérée en devise société
    Call CONVERT3(
&        evalue(FC+"CUR"), GDEVSOC(find(PCPY,GSOC)), GDEVSOC(find(PCPY,GSOC)), evalue(FC+"CURTYP"),
&        evalue(FC+"DATVCR"), evalue(FC+"AMTVATRCUR"), MTDES, evalue(FC+"RATCUR"), STAT) From CPTSUB
    If (STAT = 0) Then
      Call GET_MNT_ARRONDI (MTDES, GCOUDEV, MTDES) From GLOBIENS
      #Fq-92566 Assign FC+"AMTVATRCPY" With LMONTANT
      Assign FC+"AMTVATRCPY" With MTDES
    Else
      RTRN = 2 : End : # Erreur conversion
    Endif
    # Information régularisation de TVA pour événement de transfert
    # Montant de la régularisation
    RREGUL = evalue(FC+"AMTVATRCPY") - SDEDVATAMT
    # Alimentation du coefficient de taxation
    Assign FC+"TAXCOE" With LTAUXDEF
  Endif
  # ----
  If (RREGUL = 0 ) Then
    RTRN = -1 : End : # Pas régularisable
  Endif
End

#===================================================================
# Récupération de la valeur du paramètre NBEXESTO du chapitre "AAS"
# utilisé dans l'état DEPSIMU
#
Funprog MAXHORI()
Local Char    L_PARAM
Local Integer I_PARAM

 Call PARAM("","NBEXESTO",L_PARAM) From ADOVAL
 I_PARAM=val(L_PARAM)
End I_PARAM

#FQ57157
#===============================================================================
# Contrôle la valeur des paramètres REGBASDEV et REGVATDEV
#===============================================================================
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value    Char    PARAM
Value    Char    VALEUR
Variable Integer OK
Local    Decimal LVALEUR

  # REGBASDEV et REGVATDEV
  LVALEUR = val(VALEUR)
  Call CONTRA1(LVALEUR) From TRTFAS
  If mkstat=2
    OK=0
  Endif
End

#******************************************************************************
#*                     REINTEGRATION VEHICULE                                 *
#******************************************************************************

#====================================================================
# Calcul du montant de réintégration fiscal véhicule
#====================================================================
Subprog CALC_CRBAMT(PENDDPE, PDPRBAS ,PCRBVEHCOD, RCRBAMT, RCOD)
#
# Objet : Calcule le montant de réintégration véhicule
#

Value    Decimal PENDDPE
Value    Decimal PDPRBAS
Value    Char    PCRBVEHCOD
Variable Decimal RCRBAMT
Variable Integer RCOD

Local Integer NUMTABVEHCOD : NUMTABVEHCOD = 531

Local Decimal L_CRBVEHPLF  # Plafond de réintégration véhicule
Local Decimal L_ECART      # Ecart entre la base et le plafond de réintégration
Local Decimal L_CRBAMT     # Montant de réintégration calculé

 If !clalev([F:ADV]) : Local File ATABDIV [ADV] : Endif
 Read [ADV]CODE=531;PCRBVEHCOD
 If fstat
  RCOD = 0+fstat
  End
 Endif
 L_CRBVEHPLF = [F:ADV]N1

 #> Base inférieure au plafond, pas de réintégration à calculer

 If PDPRBAS<=L_CRBVEHPLF
  RCRBAMT=0
  End
 Endif

 #> Base supérieure au plafond, on calcule l'écart :

 L_ECART = PDPRBAS - L_CRBVEHPLF

 #> Calcul de la réintégration

 L_CRBAMT = ar2(PENDDPE * (L_ECART / PDPRBAS))

 #> Fin

 RCRBAMT = L_CRBAMT

End



#########################################################
Subprog GET_COE_SECTEUR( PSOC, PACT, RASJCOE, RTAXCOEINI, RTAXCOEDEF, RTAXCOEFLG, RERROR )

Value    Char        PSOC         : # Société
Value    Char        PACT         : # Secteur d'activité
Variable Decimal     RASJCOE      : # Coefficent d'assujettisement
Variable Decimal     RTAXCOEINI   : # Coefficent taxation initial
Variable Decimal     RTAXCOEDEF   : # Coefficent taxation définitif
Variable Integer     RTAXCOEFLG   : # Indicateur taxation définitf forcé
Variable Integer     RERROR       : # Erreur


# Nouvelles règles TVA
#
Local Decimal LPRO, LDEF
Local Integer ERROR

#
  RERROR = 1
  RASJCOE    = 0.
  RTAXCOEINI = 0.
  RTAXCOEDEF = 0.

  Local File SECACT [SEA]
  Read [F:SEA]SEA0=PSOC;PACT
  If (fstat) Then : End : Endif

  RASJCOE    = [F:SEA]ASJCOE
  RTAXCOEINI = [F:SEA]TAXCOEINI
  RTAXCOEDEF = [F:SEA]TAXCOEDEF
  RTAXCOEFLG = [F:SEA]TAXCOEFLG
  RERROR = 0

  Close File [SEA]
End

#-------------------------------------------
Subprog TVA_COE_DEDUCTION ( PASJCOE, PTAXCOE, PADMCOE, RDEDCOE )
#
# - Objet  : Renvoie le coefficient de déduction de TVA.
#            Il est égal au produit des coefficients d'assuj., de taxation et d'admission
#            arrondi par excés à la deuxième décimale
#
# - Entrée : Coefficient d'assujetissement
#            Coefficient de Taxation
#            Coefficient d'admission
# - Sortie : Coefficient de déduction
#
#

Value    Decimal  PASJCOE
Value    Decimal  PTAXCOE
Value    Decimal  PADMCOE
Variable Decimal  RDEDCOE


  Local Decimal MNT1
  Local Decimal MNT2
  RDEDCOE = PTAXCOE * PASJCOE * PADMCOE
  If ( RDEDCOE <> 0 ) Then
    MNT1 = RDEDCOE*1000
    MNT2 = (int(RDEDCOE*100)*10)
    If (MNT1 <> MNT2 ) Then
      RDEDCOE = MNT2 + 10
    Else
      RDEDCOE = MNT2
    Endif
    RDEDCOE = RDEDCOE / 1000
  Endif
  # FQ85336
  #CHECK IGNORE_BEGIN
  GPOINT = "TVACOEDEDUC" : Gosub ENTREE From EXEFNC
  #CHECK IGNORE_END

End


#-------------------------------------------
Subprog TVA_ECR_HISTORIQUE ( PVATREGTYP, PPLAN, PBASAMTO, PBASAMT, PFORM, RERROR )
#
# - Objet  : Ecrit dans la table HISVAT historique TVA un mouvement du type passé en paramètre.
#
# - Entrée : Type de régularisation (ML469)
#            Plan d'amortissement   (ML301)
#            Base d'amortissement avant
#            Base d'amortissement après
#            Formule
# - Sortie : Erreur
#
# - Prérequis :
#               Utilise la classe HFAS devant contenir les informations après modif
#               à partir desquelles est générée l'historique
#               Utilise la classe HIS de la table VATHIS qui est considérée comme déjà ouverte
#
#   Nouvelles règles TVA

Value    Integer  PVATREGTYP
Value    Integer  PPLAN
Value    Decimal  PBASAMTO
Value    Decimal  PBASAMT
Value    Char     PFORM
Variable Integer  RERROR

Local Integer  B_REWRITE : B_REWRITE = 0
Local Integer  I_PLN


  If clalev([F:HIS])  =0         : RERROR = -2    : Endif  : # Table Historique TVA non ouverte
  If clalev([F:HFAS]) =0         : RERROR = -3    : Endif  : # Table FXDASSETS classe [HFAS]  non ouverte

  If ( dim(G_BASDEV) < 0 ) Then : Local Decimal G_BASDEV :  G_BASDEV = 0 : Endif
  If ( dim(G_REGUL)  < 0 ) Then : Local Decimal G_REGUL  :  G_REGUL  = 0 : Endif
  If ( dim(G_REGULI) < 0 ) Then : Local Decimal G_REGULI :  G_REGULI = 0 : Endif

  If ( PVATREGTYP = GVML_TRCREAT ) Then
    # Un seul enregistrement de type "Création apport" dans l'historique
    Filter [HIS] Where AASREF=[F:HFAS]AASREF and DPRPLN=PPLAN and VATREGTYP = GVML_TRCREAT
    Read [HIS] First
    If not (fstat) Then :  B_REWRITE = 1 : Endif
    Filter [HIS]
  Endif

  [F:HIS]=[F:HFAS]
  [F:HIS]VATREGTYP = PVATREGTYP
  [F:HIS]DPRPLN    = PPLAN
  [F:HIS]DPRBASO   = PBASAMTO
  [F:HIS]DPRBAS    = PBASAMT
  [F:HIS]FORMULE   = PFORM
  [F:HIS]TIMSTP    = func GENEVE.BUILD_TIMSTP(date$, time)
  If (G_REGUL < 0 ) Then
    [F:HIS]VATREGAMT = abs(G_REGUL)
    [F:HIS]VATREGDED = 0
  Else
    [F:HIS]VATREGAMT = 0
    [F:HIS]VATREGDED = G_REGUL
  Endif


  # IAS/IFRS
  If (PPLAN = G301IAS ) Then
    [F:HIS]ACGETRNOT = [F:HFAS]IASETRNOT
    If (G_REGULI < 0 ) Then
      [F:HIS]VATREGAMT = abs(G_REGULI)
      [F:HIS]VATREGDED = 0
    Else
      [F:HIS]VATREGAMT = 0
      [F:HIS]VATREGDED = G_REGULI
    Endif
    [F:HIS]VATREGCUM = [F:HFAS]IASREGCUM
    [F:HIS]IVCVATAMT = [F:HFAS]IVCVATAMTI
    [F:HIS]IVCVATRAT = [F:HFAS]IVCVATRATI
    [F:HIS]IVCVATFLG = [F:HFAS]IVCVATFLGI
    [F:HIS]DEDVATAMT = [F:HFAS]DEDVATAMTI
  Endif

  # Valeur coefficients avant opération
  If ( dim(G_AASBUSO)    < 0 ) Then : [F:HIS]AASBUSO     = [F:HFAS]AASBUS     : Else : [F:HIS]AASBUSO    = G_AASBUSO    : Endif
  If ( dim(G_ASJCOERO)   < 0 ) Then : [F:HIS]ASJCOERO    = [F:HFAS]ASJCOER    : Else : [F:HIS]ASJCOERO   = G_ASJCOERO   : Endif
  If ( dim(G_TAXCOERO)   < 0 ) Then : [F:HIS]TAXCOERO    = [F:HFAS]TAXCOER    : Else : [F:HIS]TAXCOERO   = G_TAXCOERO   : Endif
  If ( dim(G_ADMCOERO)   < 0 ) Then : [F:HIS]ADMCOERO    = [F:HFAS]ADMCOER    : Else : [F:HIS]ADMCOERO   = G_ADMCOERO   : Endif
  If ( dim(G_DEDCOERO)   < 0 ) Then : [F:HIS]DEDCOERO    = [F:HFAS]DEDCOER    : Else : [F:HIS]DEDCOERO   = G_DEDCOERO   : Endif
  If ( dim(G_ASJCOEO)    < 0 ) Then : [F:HIS]ASJCOEO     = [F:HFAS]ASJCOE     : Else : [F:HIS]ASJCOEO    = G_ASJCOEO    : Endif
  If ( dim(G_TAXCOEO)    < 0 ) Then : [F:HIS]TAXCOEO     = [F:HFAS]TAXCOE     : Else : [F:HIS]TAXCOEO    = G_TAXCOEO    : Endif
  If ( dim(G_TAXCOEFLGO) < 0 ) Then : [F:HIS]TAXCOEFLGO  = [F:HFAS]TAXCOEFLG  : Else : [F:HIS]TAXCOEFLGO = G_TAXCOEFLGO : Endif
  If ( dim(G_ADMCOEO)    < 0 ) Then : [F:HIS]ADMCOEO     = [F:HFAS]ADMCOE     : Else : [F:HIS]ADMCOEO    = G_ADMCOEO    : Endif
  If ( dim(G_DEDCOEO)    < 0 ) Then : [F:HIS]DEDCOEO     = [F:HFAS]DEDCOE     : Else : [F:HIS]DEDCOEO    = G_DEDCOEO    : Endif
  If ( dim(G_ASJCOEFO)   < 0 ) Then : [F:HIS]ASJCOEFO    = [F:HFAS]ASJCOEF    : Else : [F:HIS]ASJCOEFO   = G_ASJCOEFO   : Endif
  If ( dim(G_TAXCOEFO)   < 0 ) Then : [F:HIS]TAXCOEFO    = [F:HFAS]TAXCOEF    : Else : [F:HIS]TAXCOEFO   = G_TAXCOEFO   : Endif
  If ( dim(G_ADMCOEFO)   < 0 ) Then : [F:HIS]ADMCOEFO    = [F:HFAS]ADMCOEF    : Else : [F:HIS]ADMCOEFO   = G_ADMCOEFO   : Endif
  If ( dim(G_DEDCOEFO)   < 0 ) Then : [F:HIS]DEDCOEFO    = [F:HFAS]DEDCOEF    : Else : [F:HIS]DEDCOEFO   = G_DEDCOEFO   : Endif
  If ( dim(G_VATREGDATO) < 0 ) Then : [F:HIS]VATREGDATO  = [F:HFAS]VATREGDAT  : Else : [F:HIS]VATREGDATO = G_VATREGDATO : Endif

  If ( PPLAN = G301CPT ) Then
    If ( dim(G_IVCVATAMTO) < 0 ) Then : [F:HIS]IVCVATAMTO  = [F:HFAS]IVCVATAMT  : Else : [F:HIS]IVCVATAMTO = G_IVCVATAMTO : Endif
    If ( dim(G_DEDVATAMTO) < 0 ) Then : [F:HIS]DEDVATAMTO  = [F:HFAS]DEDVATAMT  : Else : [F:HIS]DEDVATAMTO = G_DEDVATAMTO : Endif
  Endif
  If ( PPLAN = G301IAS ) Then
    If ( dim(G_IVCVATIASO) < 0 ) Then : [F:HIS]IVCVATAMTO  = [F:HFAS]IVCVATAMTI : Else : [F:HIS]IVCVATAMTO = G_IVCVATIASO : Endif
    If ( dim(G_DEDVATIASO) < 0 ) Then : [F:HIS]DEDVATAMTO  = [F:HFAS]DEDVATAMTI : Else : [F:HIS]DEDVATAMTO = G_DEDVATIASO : Endif
  Endif


  If ( [F:HFAS]VATREGDAT = [0/0/0] ) Then
    [F:HIS]DATVATREG = date$
  Else
    [F:HIS]DATVATREG = [F:HFAS]VATREGDAT
  Endif

  Case PVATREGTYP
    When GVML_TRCREAT
      [F:HIS]BASDEV      = 0
      [F:HIS]VATREGAMT   = 0
      [F:HIS]VATREGDED   = 0
    When GVML_TRPRDEF, GVML_TRVARPR, GVML_TRSATRF, GVML_TRGLADM, GVML_TRGLOPN, GVML_TRGLCLS, GVML_TRGLDEF
      [F:HIS]BASDEV    = G_BASDEV
    When GVML_TRSORNT, GVML_TRSORST
      [F:HIS]BASDEV    = 0
      If (PPLAN = G301CPT ) Then
        If ([F:HFAS]ACGCPLDED <> 0 ) Then
          [F:HIS]VATREGAMT = 0
          [F:HIS]VATREGDED = [F:HFAS]ACGCPLDED
        Else
          [F:HIS]VATREGAMT = [F:HFAS]ACGREVVAT
          [F:HIS]VATREGDED = 0
        Endif
      Endif
      If (PPLAN = G301IAS ) Then
        If ([F:HFAS]IASCPLDED <> 0 ) Then
          [F:HIS]VATREGAMT = 0
          [F:HIS]VATREGDED = [F:HFAS]IASCPLDED
        Else
          [F:HIS]VATREGAMT = [F:HFAS]IASREVVAT
          [F:HIS]VATREGDED = 0
        Endif
      Endif
    When Default
      [F:HIS]BASDEV    = 0
  Endcase

  If (B_REWRITE) Then
    Rewrite [HIS]
    If (fstat) Then : RERROR = -1 : Endif
  Else
    Write [HIS]
    If (fstat) Then : RERROR = -1 : Endif
  Endif

End


#-------------------------------------------
Subprog TVA_ENV_REG_ANN_CHG ( PAASREF, PPLAN, PASJCOE, PTAXCOE, PADMCOE, RETOUR )
#
# - Objet  : Détecte un changement du contexte de calcul de la régul annuelle
#            pour un bien ayant déjà subi une regularisation annuelle
#
# - Entrée : Référence du bien
#            Plan d'amortissement   (ML301)
#
# - Sortie : 0 Aucun changement
#            1 Changement au niveau des coefficients
#            2 Mise à jour de base a été demandée
#            3 Non trouvée dans l'historique
#
# - Prérequis :
#
#   Nouvelles règles TVA

Value    Char     PAASREF
Value    Integer  PPLAN
Value    Decimal  PASJCOE
Value    Decimal  PTAXCOE
Value    Decimal  PADMCOE
Variable Integer  RETOUR

  RETOUR = 0

  If clalev([F:HIS]) =0    : Local File VATHIS        [HIS]    : Endif  : # historique Régul. TVA

  # Recherche du dernier enregistrement de type "Variation prorata" dans l'historique
  Filter [HIS] Where AASREF=PAASREF and DPRPLN=PPLAN and VATREGTYP = GVML_TRVARPR
  Read [HIS]VAT0 Last
  # Non trouvée dans l'historique
  If (fstat) Then : RETOUR = 3 : End : Endif
  Filter [HIS]

  # Changement au niveau des coefficients
  If ( [F:HIS]ASJCOE <> PASJCOE or [F:HIS]TAXCOE <> PTAXCOE or [F:HIS]ADMCOE <> ADMCOE ) Then
    RETOUR = 1
  Endif

End

#-------------------------------------------
Funprog IS_LEG_ACGGRP_OK(PLEG, PFAM)
#
# - Objet  : Contrôle la famille par rapport à la législation
#
# - Entrée : Legislation
#            Famille
#
# - Sortie : 0 Erreur
#            1 OK
#

Value Char    PLEG()
Value Char    PFAM()

Local Integer    BOK

  BOK = 1
#  If !clalev([F:ADV]) : Local File ATABDIV [ADV] : Endif
#  Read [ADV]CODE = GTD_FAMCPT;PFAM
#  If (fstat=0) Then
#    If ( [F:ADI]LEG <> "" and [F:ADI]LEG <> PLEG ) Then
  If !clalev([F:FAM]) : Local File FASFAM [FAM] : Endif
  Read [FAM]FAM0 = PFAM
  If (fstat=0) Then
    If ( [F:FAM]LEG <> "" and [F:FAM]LEG <> PLEG ) Then
      BOK = 0
    Endif
  Endif

End BOK


#-------------------------------------------
Funprog GET_ADI_LEG(PFIELD)
#
# - Objet  : Sur un dossier mono-législation, la législation est celle du dossier
#            en multi-législation et celle du champ passé en paramètre
#
# - Entrée : Champ contenant la législation si multi-législation active
#
# - Sortie : Renvoie la législation
#

Value Char PFIELD

Local Char L_LEG(3)

  If (GLEGACT = G_OUI)
    L_LEG = evalue(PFIELD)
  Else
    L_LEG = GDOSLEG(1)
  Endif
End L_LEG
########################################
########################################
# TRAITEMENT DE SUBFAS --> Déporté
########################################
########################################

#######################################################################################
$CALCUL_VALEUR_BILAN

Local Decimal MTDES, ACGBSESAV, IASBSESAV
Local Integer STAT
Local Integer I_PLN
Local Integer WBACG_CHG, WBIAS_CHG #FQ103751
  Raz WBACG_CHG, WBIAS_CHG

  ACGBSESAV = [M:FAS1]ACGBSEVAL
  IASBSESAV = [M:FAS1]IASBSEVAL

  # Valeur Entrée PCG = Montant achat HT + TVA facturée PCG - TVA récupérée PCG
  [M:FAS1]ACGBSEVAL = [M:FAS1]ACGETRNOT + [M:FAS1]IVCVATAMT - [M:FAS1]DEDVATAMT
  Affzo [M:FAS1]ACGBSEVAL
  #FQ103751
  If ACGBSESAV and ACGBSESAV <> [M:FAS1]ACGBSEVAL
    WBACG_CHG = 1
  Endif

  # Champs relatifs au plan IAS à ne traiter que si le plan IAS est géré
  If (G_PLNIAS) Then
    # ----------- Valeur bilan IAS = Valeur d'entrée HT PCG + TVA facturée PCG - TVA récupérée PCG
    [M:FAS1]IASBSEVAL = [M:FAS1]IASETRNOT + [M:FAS1]IVCVATAMTI - [M:FAS1]DEDVATAMTI
    Affzo [M:FAS1]IASBSEVAL
    #FQ103751
    If IASBSESAV and IASBSESAV <> [M:FAS1]IASBSEVAL
      WBIAS_CHG = 1
    Endif
  Endif

  # Valeur bilan PCG alimente base de taxe et base de référence de +/- value
  # Si Valeur bilan PCG = 0 et Valeur bilan IFRS > 0 alors Base Taxe = Valeur bilan IFRS
  # Prise en compte de la devise IAS
  If ( G_PLNIAS and [M:FAS1]ACGBSEVAL = 0 and [M:FAS1]IASBSEVAL > 0 ) Then
    [M:FAS2]TAXBAS  = [M:FAS1]IASBSEVAL / [M:FAS1]IASRATCUR
    Call GET_MNT_ARRONDI ([M:FAS2]TAXBAS, [M:FAS1]IASCUR, [M:FAS2]TAXBAS) From GLOBIENS
    Affzo [M:FAS2]TAXBAS
  Else
    [M:FAS2]TAXBAS  = [M:FAS1]ACGBSEVAL :   Affzo [M:FAS2]TAXBAS
  Endif
  [M:FAS4]GALREFBAS = [M:FAS1]ACGBSEVAL :   Affzo [M:FAS4]GALREFBAS

  #-1 ---------------------------
  If (IASBSESAV <> [M:FAS1]IASBSEVAL or ACGBSESAV <> [M:FAS1]ACGBSEVAL) Then
  #  Chargement des bases d'amortissement des plans d'amortissement

    #>>>>>>>>>>>>>>>>>>>>>>>>>>>
    For I_PLN = 1 To [M:FAS3]NBLIG1
     #Fq67577-Pologne
     If G_ACTKPL=G_OUI : Gosub MAJ_PLN From TRTFASMDR : Endif
     If [M:FPC]LEG<>"POL" | ([M:FPC]LEG="POL" & (GREP="C" | LMDRPLNFLG=G_OUI))
      If ( [M:FAS3]DPRPLN(I_PLN-1) = G301SUB ) Then
        Gosub MAJ_PLAN_SUBV
        [M:FAS3]DEVORG(I_PLN-1)   = [M:FAS1]ACGCUR
      Else
        # Alimentation de la base avec Valeur bilan PCG ou IAS selon paramétrage contextes
        If ( [M:FAS3]ORIBAS(I_PLN-1) = GVML_OBIAS ) Then
          [M:FAS3]DEVORG(I_PLN-1)    = [M:FAS1]IASCUR
          #FQ103751
          If WBIAS_CHG
            MTDES   = [M:FAS3]DPRBAS(I_PLN-1) + ([M:FAS1]IASBSEVAL - IASBSESAV)
          Else
            MTDES   = [M:FAS1]IASBSEVAL
          Endif
        Elsif ( [M:FAS3]ORIBAS(I_PLN-1) = GVML_OBSAI ) Then : # FQ51379
          [M:FAS3]DEVORG(I_PLN-1)    = [M:FAS3]CUR(I_PLN-1)
          MTDES   = [M:FAS3]DPRBAS(I_PLN-1)
        Else
          [M:FAS3]DEVORG(I_PLN-1)    = [M:FAS1]ACGCUR
          #FQ103751
          If WBACG_CHG
            MTDES   = [M:FAS3]DPRBAS(I_PLN-1) + ([M:FAS1]ACGBSEVAL - ACGBSESAV)
          Else
            MTDES   = [M:FAS1]ACGBSEVAL
          Endif
        Endif
      Endif
      # Détermination du taux
      Call CDVCAL( [M:FAS3]RATCUR(I_PLN-1), [M:FAS3]DEVORG(I_PLN-1), [M:FAS3]CUR(I_PLN-1),
&                  [M:FAS0]CPY, [M:FAS3]CURTYP(I_PLN-1), [M:FAS1]PURDAT  ) From TRTDIV
      # Conversion en devise plan
      Call CONVERT3([M:FAS3]DEVORG(I_PLN-1), [M:FAS3]CUR(I_PLN-1), GCOUDEV, [M:FAS3]CURTYP(I_PLN-1), [M:FAS1]PURDAT,
&                    MTDES, MTDES, [M:FAS3]RATCUR(I_PLN-1), STAT) From CPTSUB
      If ( STAT = 0 )  Then
         Call GET_MNT_ARRONDI (MTDES, [M:FAS3]CUR(I_PLN-1), MTDES) From GLOBIENS
         If G_ACTKPL=G_OUI & GREP<>"C" : Gosub MAJ_MDR_INF From TRTFASMDR : Endif #Fq67577-Pologne
         [M:FAS3]DPRBAS(I_PLN-1) = MTDES : Affzo [M:FAS3]DPRBAS(I_PLN-1)
         [M:FAS3]BSEVAL(I_PLN-1) = MTDES : Affzo [M:FAS3]BSEVAL(I_PLN-1)
      Else
         GERR= 1: GMESSAGE = mess(18,GML_MSGFAS,1)
         mkstat = 2 : End
      Endif
      [M:FAS3]DPRVAL(I_PLN-1) = [M:FAS3]DPRBAS(I_PLN-1) -[M:FAS3]RSDVAL(I_PLN-1)
      Affzo [M:FAS3]DPRVAL(I_PLN-1)
     Endif #Fq67577-Fin
    Next I_PLN
    #<<<<<<<<<<<<<<<<<<<<<<<<<<<<
    # FAS3
    Call ACTION_BLOCK (ACB_AFFZO, "FAS3", "NBLIG1") From GLOBIENS   # Plans d'amortissement
  Endif
  #-1 ---------------------------
Return

#######################################################################################
$MAJ_PLAN_SUBV
#
# Maj du plan de subvention avec le montant subventionné des dépenses rattachées
#

Local Integer I
Local Decimal WLAMTGRA
  WLAMTGRA=0
  # >>>>>>>>>>>>>>>>>>>
  For I = 1 To [M:LOF6]NBDEST
    Read [LOF]LOF0=[M:LOF6]CODLOF(I-1);[M:LOF6]LINLOF(I-1)
    If ( fstat = 0 and [F:LOF]FLGGRA = G_OUI ) Then
      WLAMTGRA+=[F:LOF]AMTGRA
    Endif
  Next I
  # >>>>>>>>>>>>>>>>>>>
  #FQ-92171 MTDES = WLAMTGRA
  MTDES = 0

Return

#**
#* Initialisation du flag FLGCNXFLX de génération des flux sur le bien.
#*
#* Le flag est initialisé pour chaque contexte à "2" si le contexte gère des flux, à "3" sinon
#*
#* @param PCLSFAS : classe de la table FXDASSETS à mettre à jour
#*!
Subprog INIFLGCNXFLX(PCLSFAS)
Value Char  PCLSFAS

  Local Char     CPY
  Local Shortint N_CNX

  Assign PCLSFAS+"FLGCNXFLX" With "33333333333"
  [L]CPY = evalue(PCLSFAS+"CPY")

  If !clalev([F:WCNX]) : Local File CONTEXT [WCNX] : Endif
  For [WCNX]CNX0 Where CPY=[L]CPY
    Call MAJFLGCNXFLX(PCLSFAS, "[WCNX]", [WCNX]CNX, num$(GVML_FLXNOTG))
  Next
End

#**
#* Gestion du flag FLGCNXFLX de génération des flux sur le bien.
#*
#* Permet de mettre à jour avec la valeur PVAL la classe PCLSFAS pour le contexte PCNX
#* si les flux sont gérés pour ce contexte. Le contrôle de gestion des flux dans le contexte
#* est fait soit à partir de la classe PCLSCNX si elle est indiquée, soit par lecture de la table
#* CONTEXT. Si les flux ne sont pas gérés pour le contexte la valeur "Flux non gérés" est utilisée
#*
#* @param PCLSFAS : classe de la table FXDASSETS à mettre à jour
#* @param PCLSCNX : classe de la table CONTEXT pour vérifier que le contexte gère des flux (optionnel)
#* @param PCNX    : contexte concerné
#* @param PVAL    : valeur à mettre à jour
#*!
Subprog MAJFLGCNXFLX(PCLSFAS, PCLSCNX, PCNX, PVAL)
Value Char    PCLSFAS
Value Char    PCLSCNX
Value Integer PCNX
Value Char    PVAL

  Local Char     CPY(GLONCPY)
  Local Shortint N_PLAN

  If PCLSCNX = ""
    If !clalev([F:WCNX]) : Local File CONTEXT [WCNX] : Endif
    PCLSCNX = "[F:WCNX]"
    [L]CPY = evalue(PCLSFAS+"CPY")
    Read [F:WCNX]CNX0=[L]CPY;PCNX
    If fstat : End : Endif
  Endif

  For N_PLAN = 0 To evalue(PCLSCNX+"NBPLC-1")
    If evalue(PCLSCNX+"FLUTRATXS("+num$(N_PLAN)+")<>''") or evalue(PCLSCNX+"FLUTRAACC("+num$(N_PLAN)+")=G_OUI")
      Assign PCLSFAS+"FLGCNXFLX" With evalue("func GLOFUNC.SETRNGSTR("+PCLSFAS+"FLGCNXFLX, PCNX, PVAL)")
      End
    Endif
  Next

  Assign PCLSFAS+"FLGCNXFLX" With evalue("func GLOFUNC.SETRNGSTR("+PCLSFAS+"FLGCNXFLX, PCNX, num$(GVML_FLXNO))")
End
