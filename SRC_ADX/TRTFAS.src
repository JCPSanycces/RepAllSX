    Chgfmt [M:FAS5]IASREGCUM  With "Nz3:13.2#"
    Chgfmt [M:FAS5]VATREGDEDI With "Nz3:13.2#"
    Chgfmt [M:FAS5]IASVATREG  With "Nz3:13.2#"
  Endif
  Affzo [M:FAS5]FLDB       : Diszo [M:FAS5]FLDB
