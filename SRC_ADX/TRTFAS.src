    Chgfmt [M:FAS1]IVCVATAMTI With "-Nz3F:11.2"
    Chgfmt [M:FAS1]DEDVATRATI With "-N+:3.2#"
    Chgfmt [M:FAS1]DEDVATAMTI With "-Nz3F:11.2"

    Chgtbk [M:FAS1]25        With ""
  Endif
Return

