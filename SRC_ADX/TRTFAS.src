#-#*X3-61112 MACRON LAW ---------------------------------#
Funprog IS_MACRON_LAW_OK()
Local Integer OK

  # "Si la date d'achat est > à la date de fin d'application de la règle particulière. Assurez-vous de votre droit à l'appliquer.
  # "Confirmez-vous?"
  # "If the  purchase date  is > at the end date of application of the particular rule, make sure you have the right to apply it.
  # You confirm?"
  Call OUINON(mess(942,GML_MSGFAS,1)- " "-mess(943,GML_MSGFAS,1),OK) From GESECRAN
  If OK=1  # answer = No
    [M:METH]MSGERR=942
  Endif

End [M:METH]MSGERR
#-------------------------------------------
#=Fq-67621====================================================================
# Unitaire / Massif : Création Lignes Facture de vente (Tiers client)
#=============================================================================
Subprog CRE_LINES_BIC(PABBREV)
 Value    Char    PABBREV    # Abbréviation classe
  # Si annulation de sortie
  If  ( [M:FASS]CCLISSFLG = G_OUI )
      End
  Endif

  If !clalev([F:WCAC]) : Local File GACCCODE     [WCAC] : Endif
  If !clalev([F:WBPR]) : Local File BPARTNER     [WBPR] : Endif
  If !clalev([F:WBPC]) : Local File BPCUSTOMER   [WBPC] : Endif
  If !clalev([F:WGAC]) : Local File GACCOUNT     [WGAC] : Endif
  If !clalev([F:WCNX]) : Local File CONTEXT      [WCNX] : Endif

 # Envoi des infos au traitement TRTINVCRE pour création d'une facture de vente (tables BPCINVLIG/BPCINVLIGA)
 Local  Char    WHEAFCY        #1  : Header facility
 Local  Char    WHEATYP        #2  : Invoice Type
 Local  Date    WHEADAT        #3  : Date comptable
 Local  Char    WHEAINVNUM     #4  : N° de Pièce
 Local  Char    WHEACUR        #5  : Devise du contexte
 Local  Char    WFCY           #6  : Line facility
 Local  Char    WCOA (3)(1..)  #7  : Liste des codes plans
 Local  Char    WACC (15)(1..) #8  : Liste des comptes pour le code comptable, par code plan
 Local  Char    WDES           #9  : Commentaire cession
 Local  Decimal WAMTNOTLIN     #10  : Montant HT
 Local  Char    WVAT           #11 : Code Taxe
 Local  Decimal WAMTVAT        #12 : Montant TVA
 Local  Char    WTAX1          #13
 Local  Decimal WAMTTAX1       #14
 Local  Char    WTAX2          #15
 Local  Decimal WAMTTAX2       #16
 Local  Char    WTAXRCP        #17
 Local  Decimal WAMTTAXRCP     #18
 Local  Char    WTAXISS        #19
 Local  Decimal WAMTTAXISS     #20
 Local  Char    WTAXOTH1       #21
 Local  Decimal WAMTTAXOTH1    #22
 Local  Char    WTAXOTH2       #23
 Local  Decimal WAMTTAXOTH2    #24
 Local  Char    WDSP           #25  : répartition analytique
 Local  Char    WDIE(3)(1..)   #26  : axes analytiques
 Local  Char    WCCE(15)(1..)  #27  : sections analytiques
 Local  Char    NUMBIC         #28
 Local  Integer OK             #29
 Local  Char    MESSA(250)     #30
 Local  Char    LPARAM

 Global Char G_WCOA
 Local Integer  WPLN

  WHEAFCY    =   evalue(PABBREV+"FCY")         #1
  WHEATYP    =   [M:FASS]SIVTYP       #2
  WHEADAT    =   [M:FASS]ISSDAT       #3
  WFCY       =   evalue(PABBREV+"FCY")            #5
  WHEAINVNUM =""

   For I=1 To [M:FPC]NBLED-1
    WCOA (I)     =  [M:FPC]COA(I-1)  #6
    Read [WCAC]CAC0=15;evalue(PABBREV+"ACCCOD");WCOA(I)
    If fstat=0
       #FQ96183 Account different for Portugal, Angola and Brazil
       For [CNX] Where CPY= evalue(PABBREV+"CPY")
          J= find ([M:FPC]LEDTYP(I-1), [F:CNX]LEDTYP(0..[F:CNX]NBPLC-1))
          If J > 0 : Break : Endif
       Next
       If J > 0 and ( find([M:FPC]LEG, "POR", "ANG", "BRA" )> 0 )
           WPLN = [F:CNX]PLNCAA(J-1)
           If evalue(PABBREV+"GAL(WPLN-1)") > 0
             WACC(I) = [F:WCAC]ACC(18)
          Else
              WACC(I) = [F:WCAC]ACC(19)
        Endif
       Else
          WACC(I) = [F:WCAC]ACC(10)      #7
      Endif
    Endif
    ### FQ-85984
       If evalue(PABBREV+"EXTSALAMT")<> 0
          If evalue(PABBREV+"EXTSALAMT")>evalue(PABBREV+"ISSAMT")
             WACC(I) = [F:WCAC]ACC(9)
          Endif
          If evalue(PABBREV+"EXTSALAMT")=evalue(PABBREV+"ISSAMT")
             WACC(I) = [F:WCAC]ACC(30)
          Endif
       Endif
    ### FQ-85984 (END)
  Next  I
  G_WCOA= WCOA(1)
  #CRI:24/01/2013 DES         = [M:FASS]COMMENT1    #8
  WDES      = evalue(PABBREV+"AASDES1")      #8
  WAMTNOTLIN   = evalue(PABBREV+"ISSAMT")         #9
  WVAT         = [M:FASS]VAT         #10
  WAMTVAT      = evalue(PABBREV+"ISSVATAMT")      #11
  WTAX1        = [M:FASS]TAX1
  WAMTTAX1     = [M:FASS]AMTTAX1
  WTAX2        = [M:FASS]TAX2
  WAMTTAX2     = [M:FASS]AMTTAX2
  WTAXRCP      = [M:FASS]TAXRCP
  WAMTTAXRCP   = [M:FASS]AMTTAXRCP
  WTAXISS      = [M:FASS]TAXISS
  WAMTTAXISS   = [M:FASS]AMTTAXISS
  WTAXOTH1     = [M:FASS]TAXOTH1
  WAMTTAXOTH1  = [M:FASS]AMTTAXOTH1
  WTAXOTH2     = [M:FASS]TAXOTH2
  WAMTTAXOTH2  = [M:FASS]AMTTAXOTH2
  WDSP         = evalue(PABBREV+"DSP")              #24

  For I_CCE=1 To GOPTCANA
   WDIE(I_CCE) =  evalue(PABBREV+"DIE(I_CCE-1)")    #25
   WCCE(I_CCE) =  evalue(PABBREV+"CCE(I_CCE-1)")   #26
  Next I_CCE

  ## FQ-85984
  If evalue(PABBREV+"EXTSALAMT")<>0 and evalue(PABBREV+"EXTSALAMT")<>evalue(PABBREV+"ISSAMT")
     WAMTNOTLIN =evalue(PABBREV+"ISSAMT")-evalue(PABBREV+"EXTSALAMT")
     WAMTVAT    =ar2(WAMTVAT*WAMTNOTLIN/evalue(PABBREV+"ISSAMT"))
  Endif
  ## FQ-85984 (end)

  Call LINES_BIC(WHEAFCY,WHEATYP,WHEADAT,WHEAINVNUM,[M:FASS]CURCNX(0),WFCY,WCOA,WACC,WDES,WAMTNOTLIN,
&              WVAT,WAMTVAT,WTAX1,WAMTTAX1,WTAX2,WAMTTAX2,WTAXRCP,WAMTTAXRCP,WTAXISS,WAMTTAXISS,WTAXOTH1,WAMTTAXOTH1,WTAXOTH2,WAMTTAXOTH2,
&              WDSP,WDIE,WCCE,"1",
&              G_WNUMBIC,OK,MESSA) From TRTINVCRE


  ## FQ-85984
  If evalue(PABBREV+"EXTSALAMT")<>0 and OK=0 and evalue(PABBREV+"EXTSALAMT")<>evalue(PABBREV+"ISSAMT")
    TOT_BICC +=WAMTNOTLIN
    WAMTNOTLIN = evalue(PABBREV+"EXTSALAMT")
    WAMTVAT    = evalue(PABBREV+"ISSVATAMT") -WAMTVAT

    For I=1 To [M:FPC]NBLED
      WCOA (I)     =  [M:FPC]COA(I-1)  #6
      Read [WCAC]CAC0=15;evalue(PABBREV+"ACCCOD");WCOA(I)
      If fstat=0
         WACC(I) = [F:WCAC]ACC(30)      #7
      Endif
    Next  I

    Call LINES_BIC(WHEAFCY,WHEATYP,WHEADAT,WHEAINVNUM,[M:FASS]CURCNX(0),WFCY,WCOA,WACC,WDES,WAMTNOTLIN,
&              WVAT,WAMTVAT,WTAX1,WAMTTAX1,WTAX2,WAMTTAX2,WTAXRCP,WAMTTAXRCP,WTAXISS,WAMTTAXISS,WTAXOTH1,WAMTTAXOTH1,WTAXOTH2,WAMTTAXOTH2,
&              WDSP,WDIE,WCCE,"1",
&              G_WNUMBIC,OK,MESSA) From TRTINVCRE

  Endif
  ## FQ-85984

  If OK=0
     TOT_BICC +=WAMTNOTLIN
     # pas de problème ==> en unitaire si le bien n'a pas de composants, et que le montant de vente est <> 0
     # on crée l'entête facture dans la foulée
     #YYFIN_119079 If ( ACTTYPGES =  GTAMUNI ) and ( TOT_BICC <> 0) and  ( evalue(PABBREV+"CMPSTA") =GVML_SBAUTON ) and (GSALINV=G_OUI)
     If ( ACTTYPGES =  GTAMUNI ) and ( TOT_BICC <> 0) and  ( evalue(PABBREV+"CMPSTA") =GVML_SBAUTON )
           Call CRE_HEADER_BIC (PABBREV)  From  TRTFAS
     Endif
  Else
     # si problème ==> pas de facture ==>  pas de cession
     GOK =  -1
     If ACTTYPGES =  GTAMMAS
        If PABBREV="[F:TMP1]"
           Call ECR_TRACE_ERREUR(evalue(PABBREV+"CPY") ,evalue(PABBREV+"OBJREF") ,0,G_OUI, num$(OK)-" "-MESSA) From TRCPROCOM
        Else
           If PABBREV="[F:MAS1]" or PABBREV="[F:MAS2]"
              Call ECR_TRACE_ERREUR(evalue(PABBREV+"CPY") ,evalue(PABBREV+"AASREF") ,0,G_OUI, num$(OK)-" "-MESSA) From TRCPROCOM
           Endif
        Endif
     Else
        Local Integer ROK
        [M:FAS4]IVCSALISS = ""
        Call AVERTIR (mess(907,GML_MSGFAS,1)+" : "+ MESSA ,ROK) From GESECRAN
        GOK =  -1 : End
     Endif
  Endif

End
#=Fq-67621====================================================================
# Unitaire / Massif : Création Entête Facture de vente (Tiers client) (tables SINVOICE)
Subprog CRE_HEADER_BIC(PABBREV)
 Value    Char    PABBREV    # Abbréviation classe
#=============================================================================
Local    Char    WHEAFCY            #1  : Header facility
Local    Char    WHEATYP            #2  : Invoice Type
Local    Char    WHEABPR            #3  : Client
Local    Char    WHEASAC            #4  : Collectif
Local    Date    WHEADAT            #5  : Ne pas alimenter
Local    Date    WHEABPRDAT         #6  : Date sortie
Local    Char    WHEABPRVCR         #7  : Ne pas alimenter
Local    Char    WHEACUR            #8  : Devise du client
Local    Char    WHEADES            #9  : Commentaires
Local    Char    WHEAINVNUM         #10 : N° de Pièce
Local    Char    NUMBIC            #11
Local    Integer OK                #12
Local    Char    MESSA             #13

 If !clalev([F:WCAC]) : Local File GACCCODE     [WCAC] : Endif
 If !clalev([F:WGAC]) : Local File GACCOUNT     [WGAC] : Endif
 If !clalev([F:WBPC]) : Local File BPCUSTOMER   [WBPC] : Endif
 If !clalev([F:WBPR]) : Local File BPARTNER     [WBPR] : Endif


 WHEAFCY      =    evalue(PABBREV+"FCY")       #1
 WHEATYP      =    [M:FASS]SIVTYP    #2
 WHEABPR      =    [M:FASS]BUY       #3
 If [M:FASS]BPRSAC = ""
   Read[WBPC]BPC0= [M:FASS]BUY
   If fstat=0
      Read [WCAC]CAC0=2;[F:WBPC]ACCCOD;G_WCOA # 2 TYP = 2 : "Client"
      If fstat=0
         If [F:WCAC]ACC(10)  <> ""
            Read[WGAC]GAC0= G_WCOA;[F:WCAC]ACC(10)
            If fstat = 0
              WHEASAC = [F:WGAC]ACCSHO      #7
            Endif
         Else
            Read[WGAC]GAC0= G_WCOA;[F:WCAC]ACC(0)
            If fstat = 0
              WHEASAC = [F:WGAC]ACCSHO      #7
            Endif
         Endif
      Endif
   Endif
 Else
    WHEASAC = [M:FASS]BPRSAC
 Endif

 WHEADAT      =    [M:FASS]ISSDAT     #5
 WHEABPRDAT =      [M:FASS]ISSDAT     #6
 WHEABPRVCR   =    ""                #7
# Read [WBPR]BPR0=[M:FASS]BUY
# If fstat=0
#   HEACUR    =    [F:WBPR]CUR        #8
# Endif
# La devise à passer est la devise du contexte social de la société et non pas celle du client
 WHEACUR      =    [M:FASS]CURCNX(0)        #8
 WHEADES      =    [M:FASS]COMMENT1  #9
 WHEAINVNUM =""

 Call HEADER_BIC(WHEAFCY,WHEATYP,WHEABPR,WHEASAC,WHEADAT,WHEABPRDAT,WHEABPRVCR,WHEACUR,WHEADES,WHEAINVNUM,"1",G_WNUMBIC,OK,MESSA)
&              From TRTINVCRE

If OK <> 0
   # FQ92057 test pour séparer le massif de l'unitaire
   If ACTTYPGES =  GTAMMAS
       GOK=-1
      Call ECR_TRACE_ERREUR(evalue(PABBREV+"CPY"),evalue(PABBREV+"AASREF"),0,G_OUI,MESSA) From TRCPROCOM
   Else
      Local Integer ROK
      Call AVERTIR (mess(907,GML_MSGFAS,1)+" : "+ MESSA ,ROK) From GESECRAN
      GOK =  -1
      End
   Endif
Else
   G_HBIC_OK = G_OUI
Endif

If ACTTYPGES =  GTAMMAS
# TOTAL_ISSAMT=0
Endif

End
#=Fq-67621 Tunnel sur n° facture de vente dans l'écran FAS4
Subprog TUNSIH(NUM)
Variable Char    NUM() : # Numéro de pièce

If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
If [L]NUM = "" : End : Endif
Call OBJET_CHAR(NUM,"BIC",NUM) From GOBJET

End
#=Fq-67621====================================================================

########################################################
Funprog IMPAIRED_ASSET_PLN
#
# Objet : Retourne si le plan du bien a été déprécié au moins une fois
#
# PREREQUIS :  La classe [F:DEPC] doit être ouverte et alimentée en conséquence
#
# FQ96840
#
Local Integer B_IML  : # Le bien a été déprecié

  If ( [F:DEPC]EXEIMLCUM = 0 and [F:DEPC]EXERVECUM = 0 and
&      [F:DEPC]PERIMLCUM = 0 and [F:DEPC]PERRVECUM = 0 and [F:DEPC]IMLBLC = 0 ) Then
    B_IML = 0
  Else
    B_IML = 1
  Endif
End B_IML

########################################################
Funprog REVALUED_ASSET_PLN
#
# Objet : Retourne si le plan du bien a été réévalué au moins une fois
#
# PREREQUIS :  La classe [F:DEPC] doit être ouverte et alimentée en conséquence
#
# FQ96840
#
Local Integer B_RVA  : # Le bien a été déprecié
  If ( [F:DEPC]BSEVAL = [F:DEPC]DPRBAS and [F:DEPC]EXERVADEV = 0 and [F:DEPC]PERRVADEV = 0 ) Then
    B_RVA = 0
  Else
    B_RVA = 1
  Endif
End B_RVA

