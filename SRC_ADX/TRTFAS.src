########################################################################## FQ57624
$CONDITIONNE_IAS_FAS1
  Local Char LIBZON(100)

  If [M:FPC]FLGIAS = G_OUI Then
    # Classé pour vente
    #If varmode([M:FAS1]SALCLSDAT)=3  : Chgfmt [M:FAS1]SALCLSDAT  With "+D:"+GFMDAT4    : Endif
    # Bloc Valorisation IAS/IFRS
    If varmode([M:FAS1]IASCUR)=3     : Chgfmt [M:FAS1]IASCUR     With "+KC:3"          : Endif
    # FQ84794
    If GNBDEPLIEES = 0
      If varmode([M:FAS1]IASCURTYP)=3  : Chgfmt [M:FAS1]IASCURTYP  With "+N:5.0"         : Endif
      If varmode([M:FAS1]IASRATCUR)=3  : Chgfmt [M:FAS1]IASRATCUR  With "+Nz+F:11"       : Endif
    Else
      Chgfmt [M:FAS1]IASCURTYP  With "-N:5.0"
