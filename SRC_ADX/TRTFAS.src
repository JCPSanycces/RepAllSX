    # Bloc Valorisation IAS/IFRS
    Chgfmt [M:FAS1]IASCUR     With "-KC:3"
    Chgfmt [M:FAS1]IASCURTYP  With "-N:5.0"
    Chgfmt [M:FAS1]IASRATCUR  With "-Nz+F:11"
    Chgfmt [M:FAS1]IASACN     With "-N:5.0"
    Chgfmt [M:FAS1]IASACC     With "-K:1X"
    Chgfmt [M:FAS1]ZIASACC    With "-K:30X"
    # Chgfmt [M:FAS1]DEC3       With "-K:1"
