#<AdxTL>@(#)7.0.0.0 $Revision$
##################################################################################
#   Import d'un objet de type combiné
##################################################################################

#CHECK UNUSED_BEGIN

$CHARGEMSK
Gosub SETCLE
If GPRODUIT=1 : ## GEODE GX
 Case [M:IMP2]TYPENV
  When 1
   Read [FCY]FCY0 = GFCY
   If fstat
    OK=0 : Call TRACE(2,GCLE-mess(1,310,1)-GFCY) From SUBIMPOBJ : # Site
   Endif
  When 2
   Read [DEP]DEP0 = GFCY;GDEP
   If fstat
    OK=0 : Call TRACE(2,GCLE-mess(2,310,1)-GFCY-GDEP) From SUBIMPOBJ : # Déposant
   Endif
 Endcase
 If !OK : Return : Endif
 Gosub VERROU
 If !OK : Return : Endif
Endif
[F:AAA_] = [F]
Gosub DEFAUT From =PROGOBJ
[G]currind = 1
Gosub CRITTAB
Filter [F] Where evalue(FILTSUP) & evalue(CRITTAB)
MA = 1
Gosub SETMASK From =WINPROG
Raz [M]
ACTION = "LIENS0"     : Gosub ACTIONG From SUBIMPOBJ
ACTION = "IMP_LIENS0" : Gosub ACTION From SUBIMPOBJ
nolign = 0
For [F]
 nolign += 1
 If nolign>MAXLIG
  MAXLIG*=-1 : Break
 Endif
 IMA = 1
 Gosub CHARGEMSK From =WINPROG
 ACTION = "LIENS"     : Gosub ACTIONG From SUBIMPOBJ
 ACTION = "IMP_LIENS" : Gosub ACTION From SUBIMPOBJ
Next
Assign "[M]"+BASPAG With nolign
If MAXLIG<0
 MAXLIG*=-1
 Call TRACE2(2,GCLE-mess(26,100,1),-1) From SUBIMPOBJ : # Tableau plein
 OK=0 : Return
Endif
ACTION = "LIENS2"     : Gosub ACTIONG From SUBIMPOBJ
ACTION = "IMP_LIENS2" : Gosub ACTION From SUBIMPOBJ
Filter [F]
If evalue("[M]"+BASPAG)=0
 CLECUR = 0
 CHAINE = "C"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 GREP = "C" : REP = "C"
 ACTION = "RAZCRE"      : Gosub ACTIONG From SUBIMPOBJ
 ACTION = "IMP_RAZCRE"  : Gosub ACTION From SUBIMPOBJ
 If instr(1,CHAINE,"C") & (dim([M:AOE1]OPTCRE)<0 | [M:AOE1]OPTCRE=2)
  #GREP = "C" : REP = "C"
  #ACTION = "RAZCRE"      : Gosub ACTIONG From SUBIMPOBJ
  #ACTION = "IMP_RAZCRE"  : Gosub ACTION From SUBIMPOBJ
 Elsif instr(1,CHAINE,"C")
  Call TRACE2(0,GCLE-mess(105,141,1),-1) From SUBIMPOBJ : # Opération non effectuée
  GREP = "" : REP = ""
 Else
  OK = 0 : Call TRACE2(2,GCLE-mess(7,123,1),-1) From SUBIMPOBJ : # Création impossible
  GREP = "" : REP = ""
 Endif
Else
 If GPRODUIT<>1
  Gosub SETCLE
  Gosub VERROU
  If !OK : Return : Endif
 Endif
 CLECUR = 1
 CHAINE = "M"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 If instr(1,CHAINE,"M") & [M:AOE1]OPTUPD=2
  GREP = "M" : REP = "M"
 Elsif instr(1,CHAINE,"M")
  Call TRACE2(1,GCLE-mess(105,141,1),-1) From SUBIMPOBJ : # Opération non effectuée
  GREP = "" : REP = ""
 Else
  OK = 0 : Call TRACE2(2,GCLE-mess(9,123,1),-1) From SUBIMPOBJ : # Modification impossible
  GREP = "" : REP = ""
 Endif
Endif
[F] = [F:AAA_]
Return

$CHARGE_LIG
Local Integer ILIG , NBLIG3 , LIG3
NBLIG3 = evalue("[M]"+BASPAG)
If GPRODUIT=1 : ## GEODE GX
 Gosub CHARGE_LIG2
Endif
LIG3  = 0
If evalue("dim([M]"+CLELIG+")")>0
 For ILIG=1 To NBLIG3
  If evalue("[F]"+CLELIG)=evalue("[M]"+CLELIG+"("+num$(ILIG-1)+")")
   LIG3 = ILIG : Break
  Endif
 Next ILIG
Endif
If (GREP="M" | GPRODUIT=1) and LIG3<>0
 nolign = LIG3
 status = 75
Elsif NBLIG3+1>MAXLIG
 Gosub SETMSG
 Call TRACE2(-2,GCLE-GMESSAGE-mess(26,100,1),-1) From SUBIMPOBJ : # Tableau plein
 GMESSAGE="" : nolign=0
Else
 NBLIG3 += 1
 nolign = NBLIG3
 status = 82
Endif
Assign "[M]"+BASPAG With NBLIG3
Return

$CHARGE_LIG2
# cas où CLELIG n'est pas dans le modéle (GH 03/08/06 cf. objet CTC, CAI)
# on cherche à affecter [F]CLELIG en fonction de [L]CLELIG2 à définir en action IMP_AVANT_OUVRE
If SEPNUM<>1 or find(ABFIC-CLELIG,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1)) or dim([L]CLELIG2)<1 : Return : Endif
For ILIG=1 To NBLIG3
 LIG3 = ILIG
 For CL=0 To dim([L]CLELIG2)-1
  If [L]CLELIG2(CL)<>"" &
&    (evalue("dim([M]"+CLELIG2(CL)+")")<ILIG |
&     evalue("[F]"+CLELIG2(CL))<>evalue("[M]"+CLELIG2(CL)+"("+num$(ILIG-1)+")"))
   LIG3 = 0 : Break
  Endif
 Next CL
 If LIG3<>0
  Assign "[F]"+CLELIG With evalue("[M]"+CLELIG+"("+num$(LIG3-1)+")")
  Break
 Endif
Next ILIG
Return

$SETMSG
GMESSAGE=""
If dim([L]CLELIG2)>0
 For CL=0 To dim(CLELIG2)-1
  If [L]CLELIG2(CL)<>""
   GMESSAGE+="\"+num$(evalue("[F]"+CLELIG2(CL)))
  Endif
 Next CL
 If GMESSAGE<>"" : GMESSAGE=right$(GMESSAGE,2) : Endif
Else
 GMESSAGE=num$(evalue("[F]"+CLELIG))
Endif
Return

$VERROU
OK = 1
ACTION = "VERROU"     : Gosub ACTIONG From SUBIMPOBJ
If !OK : Return : Endif
ACTION = "IMP_VERROU" : Gosub ACTION From SUBIMPOBJ
If !OK : Return : Endif
SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLECUR1)
For CL=0 To dim(CLESEC)-1
 If CLESEC(CL)=CLELIG : Break : Endif
 If CLESEC(CL)<>"" & evalue("dim([M]"+CLESEC(CL)+")")<2
  SYMBOLE += "\"+CLECUR2(CL)
 Endif
Next CL
Lock =SYMBOLE With lockwait = 0
If fstat
 Call TRACE2(2,GCLE-mess(61,141,1),-1) From SUBIMPOBJ : # Fiche en cours de modification
 OK = 0
Endif
Return

$DEVERROU
ACTION = "DEVERROU"     : Gosub ACTIONG From SUBIMPOBJ
ACTION = "IMP_DEVERROU" : Gosub ACTION From SUBIMPOBJ
Unlock =SYMBOLE
Return

$SETCLE
CLECUR1 = num$(evalue("[F]"+CLEPRIM))
GCLE = num$(evalue("[F]"+CLEPRIM))
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>""
  If CLESEC(I)=CLELIG : Break : Endif
  CLECUR2(I) = num$(evalue("[F]"+CLESEC(I)))
  GCLE += "\"+num$(evalue("[F]"+CLESEC(I)))
 Endif
Next I
Return

$VALID
OK = 1
If GPRODUIT=1 & [M:IMP2]TYPENV & find(GREP,"C","M") : ## GEODE GX
 GFCY = evalue("[F:AAA_]"+[L]CLEFCY)
 If [M:IMP2]TYPENV=2 : GDEP = evalue("[F:AAA_]"+[L]CLEDEP) : Endif
Endif
If GREP="C"
 ACTION = "VERIF_CRE"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ACTION = "IMP_VERIF_CRE" : Gosub ACTION From SUBIMPOBJ
 If dim(ANOWRITE)>0 and ANOWRITE>0 : Return : Endif # CRUD done by class
 If !OK : GREP = "" : Return : Endif
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK<1
  Call TRACE2(2,mess(100,141,1)-GCLE,-1) From SUBIMPOBJ : # Erreur création
 Else
  ACTION = "APRES_CRE"     : Gosub ACTIONG From SUBIMPOBJ
  ACTION = "IMP_APRES_CRE" : Gosub ACTION From SUBIMPOBJ
  Gosub SETCLE : Call TRACE2(0,GCLE,-1) From SUBIMPOBJ
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  If (dim([M:AOE1]ENAWRK)<0 | [M:AOE1]ENAWRK=2)
   Call WORKFLOW(2,ABREV,"C",IDENT) From AWRK
  Endif
 Endif
Elsif GREP="M"
 ACTION = "VERIF_MOD"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ACTION = "IMP_VERIF_MOD" : Gosub ACTION From SUBIMPOBJ
 If dim(ANOWRITE)>0 and ANOWRITE>0 : Return : Endif # CRUD done by class
 If !OK : GREP = "" : Return : Endif
 Call DEBTRANS From GLOCK
 Gosub TR2
 If GOK<1
  Call TRACE2(2,mess(101,141,1)-GCLE,-1) From SUBIMPOBJ : # Erreur modification
 Else
  ACTION = "APRES_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ACTION = "IMP_APRES_MOD" : Gosub ACTION From SUBIMPOBJ
  Call TRACE2(1,GCLE,-1) From SUBIMPOBJ
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  If (dim([M:AOE1]ENAWRK)<0 | [M:AOE1]ENAWRK=2)
   Call WORKFLOW(2,ABREV,"M",IDENT) From AWRK
  Endif
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 ACTION = "DEBUT_CRE" : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ACTION = "IMP_DEBUT_CRE" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 For nolign = 1 To evalue("[M]"+BASPAG)
  Raz [F]
  IMA = 1
  Gosub CHARGEFIC From =WINPROG
  Gosub INICRE From GOBJSUB
  ACTION = "INICRE" : Gosub ACTIONG From SUBIMPOBJ
  If GOK<1 : Break : Endif
  ACTION = "IMP_INICRE" : Gosub ACTION From SUBIMPOBJ
  If GOK<1 : Break : Endif
  Gosub INIEXP From SUBIMPOBJ
  If find(evalue("type([F]"+CLELIG+")"),1,2,4,5,6,7,8,9)
   Assign "[F]"+CLELIG With nolign
  Endif
  Write
  If fstat
   GOK=0 : Call FSTA(ABFIC) From GLOCK : Break
   Goto AB_TR1
  Endif
  ACTION = "CREATION" : Gosub ACTIONG From SUBIMPOBJ
  If GOK<1 : Break : Endif
  ACTION = "IMP_CREATION" : Gosub ACTION From SUBIMPOBJ
  If GOK<1 : Break : Endif
 Next nolign
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ACTION = "MODIF" : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ACTION = "IMP_MODIF" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GLOCK : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

$TR2
GOK=1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 ACTION = "DEBUT_MOD" : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ACTION = "IMP_DEBUT_MOD" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Gosub CRITTAB
 Delete [F] Where evalue(CRITTAB) & evalue(FILTSUP)
 If fstat=1 | fstat>5
  GOK=-1 : GLOCK="$"+NOMFIC-CLECUR1 : Goto ROLL_TR2
 Endif
 For nolign=1 To evalue("[M]"+BASPAG)
  Raz [F]
  IMA = 1
  Gosub CHARGEFIC From =WINPROG
  Gosub INIMOD From GOBJSUB
  ACTION = "INICRE" : Gosub ACTIONG From SUBIMPOBJ
  If GOK<1 : Break : Endif
  ACTION = "IMP_INICRE" : Gosub ACTION From SUBIMPOBJ
  If GOK<1 : Break : Endif
  Gosub INIEXP From SUBIMPOBJ
  If find(evalue("type([F]"+CLELIG+")"),1,2,4,5,6,7,8,9)
   Assign "[F]"+CLELIG With nolign
  Endif
  Write
  If fstat
   GOK=0 : Call FSTA(ABFIC) From GLOCK : Break
  Endif
  ACTION = "CREATION" : Gosub ACTIONG From SUBIMPOBJ
  If GOK<1 : Break : Endif
  ACTION = "IMP_CREATION" : Gosub ACTION From SUBIMPOBJ
  If GOK<1 : Break : Endif
 Next nolign
 If    GOK<0 : Goto ROLL_TR2
 Elsif GOK=0 : Goto AB_TR2
 Endif
 ACTION = "MODIF" : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ACTION = "IMP_MODIF" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GLOCK : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

$CRITTAB
CRITTAB = ""
If TPCLE1=1
 CRITTAB = CLEPRIM+"='"+CLECUR1+"'"
Else
 CRITTAB = CLEPRIM+"="+CLECUR1
Endif
For CL=0 To dim(CLESEC)-1
 If CLESEC(CL)=CLELIG : Break : Endif
 If CLESEC(CL)<>""
  If TPCLE2(CL)=1
   CRITTAB -= "&"-CLESEC(CL)+"='"+CLECUR2(CL)+"'"
  Else
   CRITTAB -= "&"-CLESEC(CL)+"="+CLECUR2(CL)
  Endif
 Endif
Next CL
If CRITTAB="" : CRITTAB="1=1" : Endif
Raz CRITERE, ICRITERE, FILTSUP
ACTION = "FILTRE" : Gosub ACTIONG From SUBIMPOBJ : # pour récupérer FILTSUP
Raz CRITERE, ICRITERE
If FILTSUP="" : FILTSUP="1=1" : Endif
Return

#CHECK UNUSED_END
