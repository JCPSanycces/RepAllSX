#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
# Programme de synchronisation des correspondants
#
# BAP_INIT      : Initialisation synchronisation des correspondants
#
# BAP_SET_DESC   : Description passage info Outlook/Adonix
# BAP_SET        : Mise à jour d'un rendez-vous depuis Outlook vers Adonix
# BAP_LOADSET    : Transformation des infos de Outlook en Adonix
# BAP_SET_OK     : Confirmation mise à jour Outlook vers Adonix
#
# BAP_GET_DESC   : Description passage info Adonix/Outlook
# BAP_GET        : Mise à jour d'un rendez-vous depuis Adonix vers Outlook
# BAP_GET_OK     : Confirmation mise à jour Adonix vers Outlook
##########################################################################################################
# FGR 21/07/2009 : X3SUIVI56584 : Remplacement de USERID(login X3) par GUSER(AUS) partout "où il faut"
##########################################################################################################
# Debut synchronisation rendez-vouss
# ------------------------------------------------------------
Subprog BAP_INIT(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, TBKINT, TBVINT)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Variable Char TBKINT()(1..)       # Paramètres caractères
Variable Integer TBVINT(1..)

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

#Variables globales indiquant les droits sur la synchro des rendez-vouss
Global Integer GIBBAPADXCRE       #Droit création rendez-vous dans Adonix
Global Integer GIBBAPADXUPD       #Droit modification rendez-vous dans Adonix
Global Integer GIBBAPADXDLT       #Droit suppression rendez-vous dans Adonix
Global Integer GIBBAPOTKCRE       #Droit création rendez-vous dans Outlook
Global Integer GIBBAPOTKUPD       #Droit modifcation rendez-vous dans Outlook
Global Integer GIBBAPOTKDLT       #Droit suppression rendez-vous dans Outlook
Global Integer GIBPOSSYNCBAP      #synchronisation rendez-vous possible
Global Integer GIBSYNCBAPGERECOR  #Gestion des correspondants pour synchronisation des rendez-vous
Global Integer GINUMETAPEGET      #Numéro de l'étape dans la partie GET

Global Integer IDX_FULDAY  # FGR 25/03/2009 : X3SUIVI53600

Local Integer IBPARAMCHRG
Local Integer INDICETAB
Local Char TEXTMESGLOB(250)
Local Char TEXTMESTMP(250)
Local Char TEXTMES(250)
Local Integer IBERROR
Local Integer INBMES

  Local File SYNCDATA [SYD]
  GINUMETAPEGET = 1
  GIBBAPADXCRE = MC_FALSE
  GIBBAPADXUPD = MC_FALSE
  GIBBAPADXDLT = MC_FALSE
  GIBBAPOTKCRE = MC_FALSE
  GIBBAPOTKUPD = MC_FALSE
  GIBBAPOTKDLT = MC_FALSE
  IBERROR = MC_FALSE
  IBPARAMCHRG = MC_FALSE
  INDICETAB = 1
  Raz TEXTMESGLOB
  Raz TEXTMESTMP
  Raz TEXTMES
  INBMES = 1
  # Statut
  RET = MC_OK
  #Initialisation synchronisation des rendez-vous
  Call ECR_TRACE(mess(288,177,1), 0) From GESECRAN
  If dim(MSGFLG) > 0 Then
    INBMES = 1
    While INBMES < dim(MSGFLG)+1
      If MSGTXT(INBMES) <> "" Then
        Call ECR_TRACE(MSGTXT(INBMES), 0) From GESECRAN
      Endif
      INBMES += 1
    Wend
    INBMES = 1
  Endif
  Raz MSGFLG
  Raz MSGTXT
  If GCRMSYNC <> 2 Then
    IBPARAMCHRG = MC_TRUE
  Endif
  If GCRMSYNCBAP <> 2 Then
    IBPARAMCHRG = MC_TRUE
  Endif
  If USERID = "" Then
    IBPARAMCHRG = MC_TRUE
  Endif
  If IBPARAMCHRG = MC_FALSE Then
    IBPARAMCHRG = MC_TRUE
    #On a un utilisateur On regarde son paramétrage
    Local File SYNCPAR [SYP]
    Read [SYP]SYP0=GUSER
    If fstat = 0 Then
      If [F:SYP]BAPADXCRE = 2 Then
        GIBBAPADXCRE = MC_TRUE
        GIBPOSSYNCBAP = MC_TRUE
      Endif
      If [F:SYP]BAPADXUPD = 2 Then
        GIBBAPADXUPD = MC_TRUE
        GIBPOSSYNCBAP = MC_TRUE
      Endif
      If [F:SYP]BAPADXDLT = 2 Then
        GIBBAPADXDLT = MC_TRUE
        GIBPOSSYNCBAP = MC_TRUE
      Endif
      If [F:SYP]BAPOTKCRE = 2 Then
        GIBBAPOTKCRE = MC_TRUE
        GIBPOSSYNCBAP = MC_TRUE
      Endif
      If [F:SYP]BAPOTKUPD = 2 Then
        GIBBAPOTKUPD = MC_TRUE
        GIBPOSSYNCBAP = MC_TRUE
      Endif
      If [F:SYP]BAPOTKDLT = 2 Then
        GIBBAPOTKDLT = MC_TRUE
        GIBPOSSYNCBAP = MC_TRUE
      Endif
    Endif
  Else
    GIBPOSSYNCBAP = MC_FALSE
  Endif
  GIBSYNCBAPGERECOR = GIBPOSSYNCCOR
  #On alimente le tableau de paramètre pour Retour à Outlook
  # Synchronisation possible sur les rendez-vouss
  TBKINT(INDICETAB) = MC_MD
  If GIBBAPADXCRE = MC_FALSE and GIBBAPADXUPD = MC_FALSE and GIBBAPADXDLT = MC_FALSE and GIBBAPOTKCRE = MC_FALSE and GIBBAPOTKUPD = MC_FALSE and GIBBAPOTKDLT = MC_FALSE Then
    TBVINT(INDICETAB) = MC_FALSE
  Else
    TBVINT(INDICETAB) = MC_TRUE
  Endif
  INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDADX_C : TBVINT(INDICETAB) = GIBBAPADXCRE : INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDADX_U : TBVINT(INDICETAB) = GIBBAPADXUPD : INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDADX_D : TBVINT(INDICETAB) = GIBBAPADXDLT : INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDAPL_C : TBVINT(INDICETAB) = GIBBAPOTKCRE : INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDAPL_U : TBVINT(INDICETAB) = GIBBAPOTKUPD : INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDAPL_D : TBVINT(INDICETAB) = GIBBAPOTKDLT : INDICETAB += 1
  #Initialisation synchronisation des rendez-vouss
  #Paramétrage synchronisation Outlook-Adonix
  Call ECR_TRACE(mess(226,177,1), 0) From GESECRAN
  #Création
  If GIBBAPADXCRE = MC_TRUE Then
    TEXTMES = mess(59,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(59,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESTMP = TEXTMES
  TEXTMESGLOB = TEXTMES
  #Modification
  If GIBBAPADXUPD = MC_TRUE Then
    TEXTMES = mess(60,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(60,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  TEXTMESTMP = TEXTMESGLOB
  #Suppression
  If GIBBAPADXDLT = MC_TRUE Then
    TEXTMES = mess(53,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(53,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  Call ECR_TRACE(TEXTMESGLOB, 0) From GESECRAN
  #Paramétrage synchronisation Adonix-Outlook
  Call ECR_TRACE(mess(227,177,1), 0) From GESECRAN
  #Création
  If GIBBAPOTKCRE = MC_TRUE Then
    TEXTMES = mess(59,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(59,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESTMP = TEXTMES
  TEXTMESGLOB = TEXTMES
  #Modification
  If GIBBAPOTKUPD = MC_TRUE Then
    TEXTMES = mess(60,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(60,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  TEXTMESTMP = TEXTMESGLOB
  #Suppression
  If GIBBAPOTKDLT = MC_TRUE Then
    TEXTMES = mess(53,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(53,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  Call ECR_TRACE(TEXTMESGLOB, 0) From GESECRAN
  #Nettoyage du aux traitements précédents
  #Suppression enregistrement généré par synchro
  Call DEBTRANS From GLOCK
  Trbegin [SYD]
  Delete [SYD] Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDGEN = 1
  If fstat = 0 Then
    Commit
  Else
    Rollback
    IBERROR = MC_TRUE
    MSGFLG(INBMES) = MC_ERROR
    #Erreur lors de l'initialisation des données de synchronisation (suppression données obsolètes)
    MSGTXT(INBMES) = mess(229,177,1)
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES += 1
  Endif
  If IBERROR = MC_FALSE Then
    #Aucun enregistrement n'a encore été modifié par la synchro
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and ([F:SYD]SYDUPD = 1 or [F:SYD]SYDOTKSTA = 0)
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDUPD = 0
        [F:SYD]SYDOTKSTA = 1
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        Break
      Endif
    Next
    If IBERROR = MC_FALSE Then
      Commit
    Else
      Rollback
      MSGFLG(INBMES) = MC_ERROR
      #Erreur lors de l'initialisation des données de synchronisation (Nettoyage données obsolètes)
      MSGTXT(INBMES) = mess(230,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
      RET = MC_KO
    Endif
  Endif
End

##########################################################################################################
# Description passage info Outlook/Adonix
Subprog BAP_SET_DESC(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, XMLDESC)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Variable Clbfile XMLDESC()        # Description structure dynamique

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer TC_MAX : SC_MAX = 100
Local Integer WI : WI = 0
Local Char WDSC(200)(1..SC_MAX)
Local Integer INBMES

  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  Gosub BAP_INISETDSC From SUBSYDBAPD
  Gosub BAP_LD_SETDESC From SUBSYDBAPD
  Setlob XMLDESC With [L]WDSC
  # Statut
  RET = MC_OK
End

##########################################################################################################
# subprog BAP_SET (MAJ dans Adonix)
##########################################################################################################
Subprog BAP_SET(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, VERDESC, BAPPOINTID, UPDFLG, TBKCHR, TBVCHR, TBKINT, TBVINT, TBKDEC, TBVDEC, TBKDATTIM, TBVDATTIM, TBKCLOB, TBVCLOB)
# <Par Techniques>
Variable Char RET()                    # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char VERDESC()
Variable Char BAPPOINTID()        # ID permettant de retrouver la rendez-vous (OL ou X3)
Value Char UPDFLG()
# <Tabl. Dynamiques>
Variable Char TBKCHR()(1..)       # Paramètres caractères
Variable Char TBVCHR()(1..)
Variable Char TBKINT()(1..)       # Paramètres entiers
Variable Integer TBVINT(1..)
Variable Char  TBKDEC()(1..)      # Paramètres décimaux
Variable Decimal TBVDEC(1..)
Variable Char TBKDATTIM()(1..)    # Paramètres Dates AAAAMMJJHHMMSS
Variable Char TBVDATTIM()(1..)
Variable Char TBKCLOB()(1..)      # Paramètres Textes riches
Variable Clbfile TBVCLOB()(1..)
# </TD>

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer LERRCOD
Local Integer ITRACE
Local Integer IOPENTRACE
Local Integer INBRECORD
Local Char SZMODE(GLONDES)
Local Integer IBERROR
Local Integer INBMES
Local Char SZOBJET(GLONAOB)
Local Char SZBAPUSROLD(GLONAUS)
Local Char SZAPTNUM(GLONBAP)
Local Char SZREPCONNECT(GLONREP)
Local Char SZSITECONNECT(GLONFCY)
Local Char SZMESSAGE(250)

  Raz SZBAPUSROLD
  Raz SZAPTNUM
  Raz SZREPCONNECT
  Raz SZSITECONNECT
  Raz SZMESSAGE
  LERRCOD = 0
  IBRETOUR = 1
  IBERROR = MC_FALSE
  INBMES = 1
  INBRECORD = 0
  RET = MC_OK
  Raz SZMODE
  Raz SZOBJET
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  #Traitement de l'identifiant rendez-vous
  Call DECOD_OTKID(BAPPOINTID, "BAP", SZAPTNUM, SZOBJET) From SUBSYDUTIL
  If GCRMSYNC <> 2 Then
    RET = MC_OK
    End
  Endif
  If GCRMSYNCBAP <> 2 Then
    RET = MC_OK
    End
  Endif
  If USERID = "" Then
    MSGFLG(INBMES) = MC_ERROR
    #Aucun utilisateur n'est défini pour la synchronisation.
    MSGTXT(INBMES) = mess(231,177,1)
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES += 1
    RET = MC_KO
    End
  Endif
  ITRACE = 1
  #Reinitialisation type conflit
  GITYPECONFLIT = 0
  GDTDATEMODIFOTK = [00/00/00]
  GDTDATEMODIFADX = [00/00/00]
  Local File BAPPOINT [BAP]
  Local File SYNCDATA [SYD]
  #"Traitement données outlook+ " BAPPOINTID= "  + SZAPTNUM + " " Type+" : " UPDFLG
  Call ECR_TRACE((mess(228,177,1) - "BAPPOINTID=" - BAPPOINTID - mess(115,123,1) - ":" - UPDFLG), 0) From GESECRAN
  If UPDFLG = MC_UPD_RES Then
    If SZAPTNUM = "" Then
      MSGFLG(INBMES) = MC_ERROR
      #Erreur, l'identifiant Adonix est vide et le rendez-vous a le mode restauration.
      MSGTXT(INBMES) = mess(289,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
      RET = MC_KO_NEXT
    Else
      #Deux cas soit la rendez-vous existe encore et on passe en modif
      #         soit la rendez-vous n'existe plus et on passe en création avec le code passé
      Read [BAP]APP0=SZAPTNUM
      If fstat <> 0 Then
        #If faut créer
        UPDFLG = MC_UPD_CRE
      Else
        UPDFLG = MC_UPD_MOD
      Endif
    Endif
  Else
    If UPDFLG = MC_UPD_CRE Then
      SZAPTNUM = ""
    Endif
  Endif
  If SZAPTNUM = "" Then
    If UPDFLG <> MC_UPD_CRE Then
      MSGFLG(INBMES) = MC_ERROR
      #Erreur, l'identifiant Adonix est vide et le rendez-vous n'est pas nouveau.
      MSGTXT(INBMES) = mess(290,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
      RET = MC_KO_NEXT
    Endif
  Endif
  If RET = MC_KO_NEXT or RET = MC_KO Then
    End    #On sort
  Endif
  Call GETREPFROMUTI(GUSER, SZREPCONNECT, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If SZREPCONNECT = "" Then
    #Erreur, aucun représentant n'est associé à cet utilisateur : GUSER
    MSGTXT(INBMES) = mess(301,177,1) - ":" - GUSER
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES += 1
    RET = MC_KO
  Endif
  Call SITECRMDEF("ACT", SZSITECONNECT) From CRM_UTIL
  If UPDFLG = MC_UPD_CRE Then
    #Cas d'une nouvelle rendez-vous
    If GIBBAPADXCRE = MC_TRUE Then
      #On a le droit de creer une rendez-vous donc on la creer
      SZMODE = MC_UPD_CRE
      Gosub BAP_LOADSET
      #Rq: transaction géré dans la fonction avec commit ou rollback
      Call CREBAP("SUBSYDBAP", ITRACE, 0, SZAPTNUM, LERRCOD) From SUBBAPCC
      If LERRCOD = 0 Then
        BAPPOINTID = "BAP" + SZAPTNUM
        Call DEBTRANS From GLOCK
        Read [BAP]APP0=SZAPTNUM
        If fstat = 0 Then
          Trbegin [SYD]
          #Si pas de problème lors de la création de la rendez-vous, on cree une info de synchro
          Call SYDWRITE(GUSER, [F:BAP]SALFCY, [F:BAP]APTNUM,"BAP", "M", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
          If IBRETOUR = 0 Then
            IBERROR = MC_TRUE
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de l'écriture des données de synchronisation pour le nouveau rendez-vous - ":" -  [F:BAP]APTNUM
            MSGTXT(INBMES) = mess(291,177,1) - ":" - [F:BAP]APTNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
            RET = MC_KO_NEXT
            Rollback
          Else
            Commit
          Endif
          #Traitement des zones à transcoder
          If IBERROR = MC_FALSE Then
            Gosub TRTERRORCODIF
          Endif
        Else
          RET = MC_KO_NEXT
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la lecture du rendez-vous - ":" - [F:BAP]APTNUM
          MSGTXT(INBMES) = mess(292,177,1) - ":" - [F:BAP]APTNUM
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          IBERROR = MC_TRUE
        Endif
      Else
        MSGFLG(INBMES) = MC_ERROR
        MSGTXT(INBMES) = GMESSIMP
        INBMES += 1
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de la création d'un nouveau rendez-vous.
        MSGTXT(INBMES) = mess(293,177,1)
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        RET = MC_KO_NEXT
        IBERROR = MC_TRUE
      Endif
    Endif
  Else
    #On est en modification ou en suppression
    #On vérifie que la rendez-vous existe
    Read [BAP]APP0=SZAPTNUM
    If fstat <> 0 Then
      #rendez-vous non trouve, elle a du être supprimé
      If UPDFLG <> MC_UPD_SUP Then
        #La rendez-vous existe dans Outlook
        #On vérifie que l'on a une trace pour l'utilisateur dans la synchro
        INBRECORD = 0
        Call DEBTRANS From GLOCK
        Trbegin [SYD]
        For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDKEY = SZAPTNUM
          INBRECORD += 1
          If [F:SYD]SYDATTTYP <> "A" Then
            Readlock [SYD]Curr
            If fstat = 0 Then
              [F:SYD]SYDATTTYP = "A"
              [F:SYD]SYDOTKSTA = 1
              [F:SYD]SYDUPD = 1
              [F:SYD]SYDDAT = date$
              [F:SYD]SYDHOU = time$
              [F:SYD]CREUSR= GUSER
              [F:SYD]CREDAT = date$
              Rewrite [SYD]
              If fstat <> 0 Then
                RET = MC_KO_NEXT
                IBERROR = MC_TRUE
                MSGFLG(INBMES) = MC_ERROR
                #Erreur lors de la modification des données de synchronisation pour le rendez-vous - ":" - [F:BAP]APTNUM
                MSGTXT(INBMES) = mess(294,177,1) - ":" - [F:BAP]APTNUM
                Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                INBMES += 1
                Break
              Endif
            Else
              RET = MC_KO_NEXT
              IBERROR = MC_TRUE
              MSGFLG(INBMES) = MC_ERROR
              #Impossible de locker les données de synchronisation pour le rendez-vous - ":" - [F:BAP]APTNUM
              MSGTXT(INBMES) = mess(295,177,1) - ":" - [F:BAP]APTNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
              Break
            Endif
          Endif
        Next
        If INBRECORD = 0 and IBERROR = MC_FALSE Then
          #On n'a pas de donné de synchronisation
          #On crée une donnée pour indiqué à OutLook de supprimé
          Call SYDWRITE(GUSER, [F:BAP]SALFCY, SZAPTNUM, "BAP", "A", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
          If IBRETOUR = 0 Then
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de l'écriture des données de synchronisation pour le rendez-vous +" : " + [F:BAP]APTNUM
            MSGTXT(INBMES) = mess(296,177,1) - ":" - [F:BAP]APTNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
            RET = MC_KO_NEXT
            IBERROR = MC_TRUE
          Endif
        Endif
        #On vérifie que l'on a une transaction en cours
        If adxlog Then
          If IBERROR = MC_TRUE Then
            Rollback
          Else
            Commit
          Endif
        Endif
      Endif
    Else
      #La rendez-vous existe
      If UPDFLG = MC_UPD_SUP Then
        #Il faut supprimer la rendez-vous
        If GIBBAPADXDLT = MC_TRUE Then
          SZMODE = MC_UPD_SUP
          Gosub BAP_LOADSET
          #Rq: transaction géré dans la fonction avec commit ou rollback
          Call DELBAP("SUBSYDBAP", ITRACE, IOPENTRACE, SZAPTNUM, LERRCOD) From SUBBAPCA
          If LERRCOD > 0 Then
            MSGFLG(INBMES) = MC_ERROR
            MSGTXT(INBMES) = GMESSIMP
            INBMES += 1
            RET = MC_KO_NEXT
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de la suppression du rendez-vous - ":" - [F:BAP]APTNUM
            MSGTXT(INBMES) = mess(297,177,1) - ":" - [F:BAP]APTNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
          Endif
          If LERRCOD = 0 Then
            #On a pu supprimer la rendez-vous et l'ordre vient de Outlook
            #On supprime les liens
            Call DEBTRANS From GLOCK
            Trbegin [SYD]
            Delete Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDKEY = SZAPTNUM
            If fstat <> 0 Then
              Rollback
              IBERROR = MC_TRUE
              #Problème car incohérence entre BAPPOINT ET SYNCDATA
              MSGFLG(INBMES) = MC_ERROR
              #Erreur lors de la suppression des données de synchronisation pour le rendez-vous - ":" - SZAPTNUM
              MSGTXT(INBMES) = mess(298,177,1) - ":" - SZAPTNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
            Else
              Commit
            Endif
          Endif
        Endif
      Else
        #On est en modif sur une rendez-vous qui existe
        #On vérifie que l'organisateur /propriétaire est le bon
        If SZREPCONNECT <> [F:BAP]ATPREPMNA Then
          #On a changé de propriétaire
          Call GETUTIFROMREP([F:BAP]ATPREPMNA, SZBAPUSROLD, IERRINF, ICHAPTER, IBRETOUR) From CRMUTIL150
          If IBRETOUR <> 0 Then
            #On a eu un changement de représentant
            #On vérifie dans les données de synchro pour l'ancien
            INBRECORD = 0
            Call DEBTRANS From GLOCK
            Trbegin [SYD]
            For [SYD]SYD1 Where [F:SYD]SYDUSR = SZBAPUSROLD and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDKEY = SZAPTNUM
              INBRECORD += 1
              If [F:SYD]SYDATTTYP <> "P" Then
                Readlock [SYD]Curr
                If fstat = 0 Then
                  [F:SYD]SYDATTTYP = "P"
                  [F:SYD]SYDOTKSTA = 1
                  [F:SYD]SYDUPD = 1
                  [F:SYD]SYDDAT = date$
                  [F:SYD]SYDHOU = time$
                  [F:SYD]CREUSR = GUSER
                  [F:SYD]CREDAT = date$
                  Rewrite [SYD]
                  If fstat <> 0 Then
                    RET = MC_KO_NEXT
                    MSGFLG(INBMES) = MC_ERROR
                    #Erreur lors de la modification des données de synchronisation pour le rendez-vous - ":" - [F:BAP]APTNUM
                    MSGTXT(INBMES) = mess(294,177,1) - ":" - [F:BAP]APTNUM
                    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                    INBMES += 1
                    IBERROR = MC_TRUE
                    Break
                  Endif
                Else
                  RET = MC_KO_NEXT
                  MSGFLG(INBMES) = MC_ERROR
                  #Impossible de locker les données de synchronisation pour le rendez-vous - ":" - [F:BAP]APTNUM
                  MSGTXT(INBMES) = mess(295,177,1) - ":" - [F:BAP]APTNUM
                  Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                  INBMES += 1
                  IBERROR = MC_TRUE
                  Break
                Endif
              Endif
            Next
            If INBRECORD = 0 and IBERROR = MC_FALSE Then
              #On crée une donnée pour indiqué à OutLook de supprimé pour l"utilisateur
              Call SYDWRITE(SZBAPUSROLD, [F:BAP]SALFCY, SZAPTNUM, "BAP", "P", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
              If IBRETOUR = 0 Then
                RET = MC_KO_NEXT
                MSGFLG(INBMES) = MC_ERROR
                #Erreur lors de l'écriture des données de synchronisation pour le rendez-vous - ":" - [F:BAP]APTNUM
                MSGTXT(INBMES) = mess(296,177,1) - ":" - [F:BAP]APTNUM
                Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                INBMES += 1
                IBERROR = MC_TRUE
              Endif
            Endif
            #On vérifie que l'on a une transaction en cours
            If adxlog Then
              If IBERROR = MC_TRUE Then
                Rollback
              Else
                Commit
              Endif
            Endif
          Endif
        Endif
        #On modifie la rendez-vous
        If GIBBAPADXUPD = MC_TRUE and IBERROR = MC_FALSE Then
          INBRECORD = 0
          For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDKEY = SZAPTNUM
            INBRECORD += 1
            Break
          Next
          If INBRECORD > 0 Then
            #rendez-vous aussi modifier dans X3 donc Conflit
            #On recherche le type de conflit
            Gosub GETTYPECONFLIT
          Endif
          SZMODE = MC_UPD_MOD
          Gosub BAP_LOADSET
          #Rq: transaction géré dans la fonction avec commit ou rollback
          Call UPDBAP("SUBSYDBAP", ITRACE, IOPENTRACE, SZAPTNUM, LERRCOD) From SUBBAPCM
          If LERRCOD = 0 Then
            #On vérifie que l'on a une donnée de synchro
            INBRECORD = 0
            Call DEBTRANS From GLOCK
            Trbegin [SYD]
            For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDKEY = SZAPTNUM
              INBRECORD += 1
              If [F:SYD]SYDATTTYP <> "M" Then
                Readlock [SYD]Curr
                If fstat = 0 Then
                  [F:SYD]SYDATTTYP = "M"
                  [F:SYD]SYDOTKSTA = 1
                  [F:SYD]SYDUPD = 1
                  [F:SYD]SYDDAT = date$
                  [F:SYD]SYDHOU = time$
                  [F:SYD]CREUSR= GUSER
                  [F:SYD]CREDAT = date$
                  Rewrite [SYD]
                  If fstat <> 0 Then
                    RET = MC_KO_NEXT
                    IBERROR = MC_TRUE
                    MSGFLG(INBMES) = MC_ERROR
                    #Erreur lors de la modification des données de synchronisation pour le rendez-vous - ":" - [F:BAP]APTNUM
                    MSGTXT(INBMES) = mess(294,177,1) - ":" - [F:BAP]APTNUM
                    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                    INBMES += 1
                    Break
                  Endif
                Else
                  RET = MC_KO_NEXT
                  IBERROR = MC_TRUE
                  MSGFLG(INBMES) = MC_ERROR
                  #Impossible de locker les données de synchronisation pour le rendez-vous - ":" - [F:BAP]APTNUM
                  MSGTXT(INBMES) = mess(295,177,1) - ":" - [F:BAP]APTNUM
                  Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                  INBMES += 1
                  Break
                Endif
              Endif
            Next
            If INBRECORD = 0 and IBERROR = MC_FALSE Then
              #On n'a pas de donné de synchronisation
              #On crée une donnée pour indiqué à OutLook d'en tenir compte
              Call SYDWRITE(GUSER, [F:BAP]SALFCY, SZAPTNUM, "BAP", "M", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
              If IBRETOUR = 0 Then
                RET = MC_KO_NEXT
                MSGFLG(INBMES) = MC_ERROR
                #Erreur lors de l'écriture des données de synchronisation pour le rendez-vous - ":" - [F:BAP]APTNUM
                MSGTXT(INBMES) = mess(296,177,1) - ":" - [F:BAP]APTNUM
                Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                INBMES += 1
                IBERROR = MC_TRUE
              Endif
            Endif
            #On vérifie que l'on a une transaction en cours
            If adxlog Then
              If IBERROR = MC_TRUE Then
                Rollback
              Else
                Commit
              Endif
            Endif
            #Traitement des zones à transcoder
            If IBERROR = MC_FALSE Then
              Gosub TRTERRORCODIF
            Endif
          Else
            MSGFLG(INBMES) = MC_ERROR
            MSGTXT(INBMES) = GMESSIMP
            INBMES += 1
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de la modification du rendez-vous - ":" - [F:BAP]APTNUM
            MSGTXT(INBMES) = mess(299,177,1) - ":" - [F:BAP]APTNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
            RET = MC_KO_NEXT
          Endif
        Else
          RET = MC_OK
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Recherche du type de conflit
##########################################################################################################
$GETTYPECONFLIT
Local Integer IOTK

  #date de modification dans Outlook
  IOTK = 1
  While IOTK < dim(TBKDATTIM)+1
    If  TBKDATTIM(IOTK) = "LastModificationTime" Then
      #Date de modification
      Call GETDATEFROMCHAR(TBVDATTIM(IOTK), GDTDATEMODIFOTK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
      Break
    Endif
    IOTK += 1
  Wend
  #date de modification dans Adonix
  GDTDATEMODIFADX = [F:BAP]UPDDAT
  If GDTDATEMODIFADX >= GDTDATEMODIFOTK Then
    GITYPECONFLIT = MC_RECENTADX
  Else
    GITYPECONFLIT = MC_RECENTOTK
  Endif
Return

##########################################################################################################
# Transfert des infos de Outlook vers Adonix
##########################################################################################################
$BAP_LOADSET
Local Integer ICHAR
Local Integer IINT
Local Integer IDEC
Local Integer IDATE
Local Integer ICLOB
Local Integer IOTK
Local Integer IVALEUR
Local Integer INBHOUR
Local Char SZREP(GLONREP)
Local Char SZSITE(GLONFCY)
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Date DTVALEUR
Local Char SZVALEUR(250)
Local Integer IBCONTINUE
Local Integer IFIND
Local Integer IINDICE_AIN
Local Integer IINDICE_REP
Local Integer IINDICE
Local Integer IINDICEMAX
Local Char SZCHAINE(250)
Local Char SZCORID(GLONCOR)
Local Char SZOBJET(GLONAOB)
Local Char SZBPRCOR(GLONCOR)  # FGR 10/12/2014 : X3SUIVI104243

  Raz SZREP
  Raz SZSITE
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = MC_TRUE
  DTVALEUR = [00/00/00]
  Raz SZVALEUR
  #Tableau de char
  Raz GTBKCHR
  Raz GTBVCHR
  #Tableau entiers
  Raz GTBKINT
  Raz GTBVINT
  #Tableau decimal
  Raz GTBKDEC
  Raz GTBVDEC
  #tableau date
  Raz GTBKDATTIM
  Raz GTBVDATTIM
  #tableau clob
  Raz GTBKCLOB
  Raz GTBVCLOB
  Raz GTBTRTFIE
  Raz GTBTRTVAL
  GNBTRT = 0
  ICHAR = 1
  IINT = 1
  IDEC = 1
  IDATE = 1
  ICLOB = 1
  #Traitement des zones spéciales
  #Le Représentant est propriétaire
  Call PARAMUTIL("AUSCRMF", SZREP, GUSER, SZSITE) From SUBAUS
  GTBKCHR(ICHAR) = "ATPREPMNA"
  GTBVCHR(ICHAR) = SZREP
  ICHAR += 1
  #Recherche du nombre de contact
  Local File CORRESPOND [COR]
  IINDICE_AIN = 0
  IINDICE_REP = 0
  IFIND = 0
  IBCONTINUE = 1
  Raz SZCHAINE
  GTBKCHR(ICHAR) = "APTREPNUM_" + num$(IINDICE_REP)
  GTBVCHR(ICHAR) = SZREP
  ICHAR += 1
  IINDICE_REP += 1
  IINDICEMAX = dim(TBKCHR)
  IINDICE = 1
  Raz SZBPRCOR  # FGR 10/12/2014 : X3SUIVI104243
  While IINDICE<= IINDICEMAX
    If GIBSYNCBAPGERECOR = MC_FALSE Then
      Break
    Endif
    SZCHAINE = "Lk_" + num$(IINDICE) + "_CtAdxId"
    #On recherche CtAdxId
    IFIND = find(SZCHAINE, TBKCHR)
    If IFIND > 0 Then
      If TBVCHR(IFIND) <> "" Then
        #Traitement de l'identifiant correspondant
        Call DECOD_OTKID(TBVCHR(IFIND), "COR", SZCORID, SZOBJET) From SUBSYDUTIL
        Read [COR]COR0=SZCORID
        If fstat = 0 Then
          If [F:COR]CORTYP="AIN" Then
            #Cas des correspondants classiques
            GTBKCHR(ICHAR) = "APTCOR_" + num$(IINDICE_AIN)
            GTBVCHR(ICHAR) = [F:COR]CORNUM
            ICHAR += 1
            If [F:COR]CNTNUM <> "" Then
              GTBKCHR(ICHAR) = "APTCCNNUM_" + num$(IINDICE_AIN)
              GTBVCHR(ICHAR) = [F:COR]CNTNUM
              ICHAR += 1
            Else
              GTBKCHR(ICHAR) = "APTCCNNUM_" + num$(IINDICE_AIN)
              GTBVCHR(ICHAR) = ""
              ICHAR += 1
            Endif
            # FGR 10/12/2014 : X3SUIVI104243 (début)
            If [F:COR]BPRNUM <> "" Then
              # S'il y a un tiers sur le correspondant
              If SZBPRCOR = "" Then
                # Si on n'a pas encore mémorisé de tiers, le tiers du correspondant devient le tiers courant
                SZBPRCOR = [F:COR]BPRNUM
              Elsif SZBPRCOR <> [F:COR]BPRNUM Then
                # Et comme il ne peut y avoir qu'un seul tiers sur le rendez-vous, si les correspondants sont multi-tiers le rdv sera sans tiers.
                # On ne considère pas l'absence de tiers sur le correspondant comme un cas de multi-tiers
                Raz SZBPRCOR
              Endif
            Endif
            # FGR 10/12/2014 : X3SUIVI104243 (fin)
            IINDICE_AIN += 1
          Else
            If [F:COR]CORTYP = "REP" Then
              If [F:COR]BPRNUM <> SZREP Then
                GTBKCHR(ICHAR) = "APTREPNUM_" + num$(IINDICE_REP)
                GTBVCHR(ICHAR) = [F:COR]BPRNUM
                ICHAR += 1
                IINDICE_REP += 1
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      Break
    Endif
    IINDICE += 1
  Wend
  # FGR 10/12/2014 : X3SUIVI104243 (début)
  If SZBPRCOR <> "" Then
    GTBKCHR(ICHAR) = "APTCMP"
    GTBVCHR(ICHAR) = SZBPRCOR
    ICHAR += 1
  Endif
  # FGR 10/12/2014 : X3SUIVI104243 (fin)
  GTBKINT(IINT) = "NBLIGCCN"
  GTBVINT(IINT) = IINDICE_AIN
  IINT += 1
  GTBKINT(IINT) = "NBLIGREP"
  GTBVINT(IINT) = IINDICE_REP
  IINT += 1
  #Traitement du tableau de char d'outlook
  IOTK = 1
  While IOTK < dim(TBKCHR)+1
    Case TBKCHR(IOTK)
      When "Location"
        #Description adresse
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "ATPADDCMT"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
    Endcase
    IOTK += 1
  Wend
  #Traitement du tableau entier d'outlook
  IDX_FULDAY = 0  # FGR 25/03/2009 : X3SUIVI53600
  IOTK = 1
  While IOTK < dim(TBKINT)+1
    Case TBKINT(IOTK)
      When "AllDayEvent"
        #Journée entière
        GTBKINT(IINT) = "FULDAY"
        If TBVINT(IOTK) = 0 Then
          GTBVINT(IINT) = 1
        Else
          GTBVINT(IINT) = 2
        Endif
        IDX_FULDAY = IINT # FGR 25/03/2009 : X3SUIVI53600
        IINT += 1
      When "Duration"
        #Durée rendez-vous
        GTBKINT(IINT) = "APTDUR"
        GTBVINT(IINT) = val(TBVCHR(IOTK))
        IINT += 1
    Endcase
    IOTK += 1
  Wend
  #Traitement du tableau de décimal d'outlook
  #  IOTK = 1
  #  While IOTK < dim(TBKDEC)+1
  #    Case TBKDEC(IOTK)
  #      When "test"
  #    Endcase
  #    IOTK += 1
  #  Wend
  #Traitement du tableau de date d'outlook
  Local Integer IDX_APTDAT             # FGR 03/06/2014 : X3SUIVI100199
  Local Integer IDX_APTDATEND          # FGR 03/06/2014 : X3SUIVI100199

  IDX_APTDAT = 0                       # FGR 03/06/2014 : X3SUIVI100199
  IDX_APTDATEND = 0                    # FGR 03/06/2014 : X3SUIVI100199

  IOTK = 1
  While IOTK < dim(TBKDATTIM)+1
    Case TBKDATTIM(IOTK)
      When "Start"
        #Date rendez-vous
        GTBKDATTIM(IDATE) = "APTDAT"
        Call GETDATEFROMCHAR(TBVDATTIM(IOTK), DTVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
        GTBVDATTIM(IDATE) = DTVALEUR
        IDX_APTDAT = IDATE             # FGR 03/06/2014 : X3SUIVI100199
        IDATE+= 1
        #Heure rendez-vous
        GTBKCHR(ICHAR) = "APTHOU"
        Call GETTIMEFROMCHAR(TBVDATTIM(IOTK), SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
        GTBVCHR(ICHAR) = SZVALEUR
        ICHAR += 1
      When "End"
        #Fin rendez-vous
        GTBKDATTIM(IDATE) = "APTDATEND"
        Call GETDATEFROMCHAR(TBVDATTIM(IOTK), DTVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
        GTBVDATTIM(IDATE) = DTVALEUR
        If GTBVINT(IDX_FULDAY) = 2 Then
          # FGR 25/03/2009 : X3SUIVI53600 : Rien à voir avec la fiche.
          #                  Mais dans Outlook, quand on coche "Full Day", la date de fin est au lendemain de
          #                  celle saisie, à 00h00 (soit le 26/03/2009 00:00 pour un full day sur le 25/03/2009)
          DTVALEUR = DTVALEUR - 1
        Endif
        GTBVDATTIM(IDATE) = DTVALEUR
        IDX_APTDATEND = IDATE          # FGR 03/06/2014 : X3SUIVI100199
        IDATE+= 1
        #Heure fin
        GTBKCHR(ICHAR) = "APTHOUEND"
        Call GETTIMEFROMCHAR(TBVDATTIM(IOTK), SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
        GTBVCHR(ICHAR) = SZVALEUR
        ICHAR += 1
    Endcase
    IOTK += 1
  Wend
  # FGR 03/06/2014 : X3SUIVI100199 (début)
  If IDX_APTDAT > 0 and IDX_APTDATEND > 0 Then
    # Si la date début est inférieure à la date de fin, on les mets à la même date (la date début)
    If GTBVDATTIM(IDX_APTDAT) > GTBVDATTIM(IDX_APTDATEND) Then
      GTBVDATTIM(IDX_APTDATEND) = GTBVDATTIM(IDX_APTDAT)
    Endif
  Endif
  # FGR 03/06/2014 : X3SUIVI100199 (fin)
  #Traitement du tableau de clob d'outlook
  IOTK = 1
  While IOTK < dim(TBKCLOB)+1
    Case TBKCLOB(IOTK)
      When "Subject"
        GTBKCLOB(ICLOB) = "FULOBJ"
        GTBVCLOB(ICLOB) = TBVCLOB(IOTK)
        ICLOB+= 1
      When "Body"
        GTBKCLOB(ICLOB) = "FULRPO"
        GTBVCLOB(ICLOB) = TBVCLOB(IOTK)
        ICLOB+= 1
    Endcase
    IOTK += 1
  Wend
  #Numéro de rendez-vous (cas particulier de la restauration)
  If SZAPTNUM <> "" Then
    GTBKCHR(ICHAR) = "APTNUM"
    GTBVCHR(ICHAR) = SZAPTNUM
    ICHAR += 1
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'un rendez-vous. (exemple)
#############################################################################
$BAP_SET_HEA_INFO
Local Integer INDEXE
Local Char SZREP(GLONREP)
Local Integer IBAFFECTE
Local Char SZRECHERCHE(250)

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  SZREP = ""
  INDEXE = 0
  IBAFFECTE = MC_FALSE
  Raz SZRECHERCHE
  Case IMPZON
    When "APTNUM"
      #Numéro de rendez-vous
      If GREP = "C" Then
        INDEXE = find("APTNUM", GTBKCHR)
        If INDEXE <> 0 Then
          [M:BAP0]APTNUM = GTBVCHR(INDEXE)
        Endif
      Endif
    When "NBLIGCCN"
      #Nombre de Correspondant/Personne à visiter
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("NBLIGCCN", GTBKINT)
          If INDEXE <> 0 Then
            [M:BAP1]NBLIGCCN = GTBVINT(INDEXE)
          Endif
        Endif
      Endif
    When "NBLIGREP"
      #Nombre de représentant
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("NBLIGREP", GTBKINT)
          If INDEXE <> 0 Then
            [M:BAP2]NBLIGREP = GTBVINT(INDEXE)
          Endif
        Endif
      Endif
    When "APTCMP"
      # Tiers
      # FGR 10/12/2014 : X3SUIVI104243 : on devient capable d'identifier le tiers sur un RDV
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("APTCMP", GTBKCHR)
          If INDEXE <> 0 Then
            [M:BAP0]APTCMP = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "ATPREPMNA"
      #Organisateur
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("ATPREPMNA", GTBKCHR)
          If INDEXE <> 0 Then
            [M:BAP2]ATPREPMNA = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "APTREPNUM"
      #Représentant
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          Raz SZRECHERCHE
          #On recherche par rapport à l'indice de dimensionnement du champs
          SZRECHERCHE = "APTREPNUM_" + num$(indice)
          INDEXE = find(SZRECHERCHE, GTBKCHR)
          If INDEXE <> 0 Then
            [M:BAP2]APTREPNUM(indice) = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "ATPADDCMT"
      #Description adresse
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("ATPADDCMT", GTBKCHR)
          If INDEXE <> 0 Then
            [M:BAP3]ATPADDCMT = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "FULDAY"
      #Journée entière
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("FULDAY", GTBKINT)
          If INDEXE <> 0 Then
            [M:BAP1]FULDAY = GTBVINT(INDEXE)
          Endif
        Endif
      Endif
    When "APTDUR"
      #Durée rendez-vous
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("APTDUR", GTBKINT)
          If INDEXE <> 0 Then
            If GTBVINT(INDEXE) <> 0 Then
              # FGR 25/03/2009 : X3SUIVI53600 : Si la durée est à 0 dans Outlook (ce qui est généralement le cas),
              #                  Je ne la prends pas et je laisse le traitement X3 faire le calcul
              [M:BAP1]APTDUR = num$(GTBVINT(INDEXE))
            Endif
          Endif
        Endif
      Endif
    When "APTDAT"
      #Date rendez-vous
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("APTDAT", GTBKDATTIM)
          If INDEXE <> 0 Then
            [M:BAP1]APTDAT = GTBVDATTIM(INDEXE)
          Endif
        Endif
      Endif
    When "APTHOU"
      #Heure rendez-vous
      If GREP <> MC_UPD_SUP Then        # FGR 08/12/2010 : X3SUIVI69749 : C'est la première chose à tester
        If GTBVINT(IDX_FULDAY) <> 2 Then
          # FGR 25/03/2009 : X3SUIVI53600 : Si on est en FULL_DAY, je ne prends pas les heures données par Outlook.
          #If GREP <> MC_UPD_SUP Then   # FGR 08/12/2010 : X3SUIVI69749 : c'est un peu tard quand on est en suppression
          If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
            IBAFFECTE = MC_TRUE
          Else
            IBAFFECTE = MC_FALSE
          Endif
          If IBAFFECTE = MC_TRUE Then
            INDEXE = find("APTHOU", GTBKCHR)
            If INDEXE <> 0 Then
              [M:BAP1]APTHOU = GTBVCHR(INDEXE)
            Endif
          Endif
        Endif
      Endif
    When "APTDATEND"
      #Fin rendez-vous
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("APTDATEND", GTBKDATTIM)
          If INDEXE <> 0 Then
            [M:BAP1]APTDATEND = GTBVDATTIM(INDEXE)
          Endif
        Endif
      Endif
    When "APTHOUEND"
      #Heure fin
      If GREP <> MC_UPD_SUP Then        # FGR 08/12/2010 : X3SUIVI69749 : C'est la première chose à tester
        If GTBVINT(IDX_FULDAY) <> 2 Then
          # FGR 25/03/2009 : X3SUIVI53600 : Si on est en FULL_DAY, je ne prends pas les heures données par Outlook.
          #If GREP <> MC_UPD_SUP Then   # FGR 08/12/2010 : X3SUIVI69749 : c'est un peu tard quand on est en suppression
          If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
            IBAFFECTE = MC_TRUE
          Else
            IBAFFECTE = MC_FALSE
          Endif
          If IBAFFECTE = MC_TRUE Then
            INDEXE = find("APTHOUEND", GTBKCHR)
            If INDEXE <> 0 Then
              [M:BAP1]APTHOUEND = GTBVCHR(INDEXE)
            Endif
          Endif
        Endif
      Endif
    When "FULOBJ"
      #sujet/Objectif
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("FULOBJ", GTBKCLOB)
          If INDEXE <> 0 Then
            [M:BAP1]FULOBJ = GTBVCLOB(INDEXE)
          Endif
        Endif
      Endif
    When "FULRPO"
      #Compte rendu
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("FULRPO", GTBKCLOB)
          If INDEXE <> 0 Then
            Local Clbfile LBCLOB(3)   # FGR 02/04/2013 : X3SUIVI88115 : clob taillé à 3

            LBCLOB = GTBVCLOB(INDEXE)
            Call CLEANCLOBBAP(LBCLOB) From SUBSYDUTIL
            [M:BAP4]FULRPO = LBCLOB
          Endif
        Endif
      Endif
    When "APTTYP"
      # FGR 25/03/2009 : X3SUIVI53600 : Lorsqu'il est renseigné, je prends le type de rendez-vous par défaut
      #                  défini en paramètre au niveau utilisateur.
      #                  S'il n'y en a pas, c'est celui au niveau de la table qui sera proposé automatiquement
      If GCRMSYNAPTYP <> "" Then
        [M:BAP1]APTTYP = GCRMSYNAPTYP
      Endif
  Endcase
Return

#############################################################################
#DETAIL
$BAP_SET_DET_INFO
Local Integer INDEXE
Local Integer IBAFFECTE
Local Char SZRECHERCHE(250)

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  INDEXE = 0
  IBAFFECTE = MC_FALSE
  Raz SZRECHERCHE
  Case IMPZON
    When "APTCOR"
      #Correspondant    Personne à visiter
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          Raz SZRECHERCHE
          #On recherche par rapport à l'indice de dimmensionnement du champs
          SZRECHERCHE = "APTCOR_" + num$(indice)
          INDEXE = find(SZRECHERCHE, GTBKCHR)
          If INDEXE <> 0 Then
            [M:BAP1]APTCOR(indice) = GTBVCHR(INDEXE)
          Endif
          Raz SZRECHERCHE
          SZRECHERCHE = "APTCCNNUM_" + num$(indice)
          INDEXE = find(SZRECHERCHE, GTBKCHR)
          If INDEXE <> 0 Then
            [M:BAP1]APTCCNNUM(indice) = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "APTREPNUM"
      #Représentant
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          Raz SZRECHERCHE
          #On recherche par rapport à l'indice de dimmensionnement du champs
          SZRECHERCHE = "APTREPNUM_" + num$(indice)
          INDEXE = find(SZRECHERCHE, GTBKCHR)
          If INDEXE <> 0 Then
            [M:BAP2]APTREPNUM(indice) = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
  Endcase
Return

##########################################################################################################
# Traitement de l'enregistrement des erreurs de transcodifications
$TRTERRORCODIF
Local Integer ITRT

  If !clalev([F:SYL]) : Local File SYNCLINK [SYL] : Endif
  ITRT = 0
  If GNBTRT > 0 Then
    #On a des données a sauvegarder
    Call DEBTRANS From GLOCK
    Trbegin [SYL]
    While ITRT < GNBTRT
      Call  SYLWRITE(GUSER, "BAP", SZAPTNUM, GTBTRTFIE(ITRT), GTBTRTVAL(ITRT), IERRINF, ICHAPTER, IBRETOUR) From SUBSYLB
      If IBRETOUR = MC_FALSE Then
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de l'écriture des traces de transcodifications. rendez-vous - ":" - [F:BAP]APTNUM + Champs +GTBTRTFIE(ITRT)
        MSGTXT(INBMES) = mess(300,177,1) - ":" - [F:BAP]APTNUM - mess(149,123,1) - GTBTRTFIE(ITRT)
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
      ITRT += 1
    Wend
    If IBRETOUR = MC_TRUE Then
      Commit
    Else
      Rollback
      RET = MC_KO_NEXT
    Endif
  Endif
Return

##########################################################################################################
# Confirmation Set (Outlook vers Adonix)
# ------------------------------------------------------------
Subprog BAP_SET_OK(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, BAPPOINTID)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char BAPPOINTID()           # ID permettant de retrouver la rendez-vous

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer IBERROR
Local Integer INBMES
Local Char SZAPTNUM(GLONBAP)
Local Char SZOBJET(GLONAOB)
Local Integer WI
Local Char SZRET(GLONDES)

  IBERROR = MC_FALSE
  Raz SZAPTNUM
  Raz SZOBJET
  # Analyse des messages si besoin
  WI = find(2,MSGFLG)
  #  If(WI!= 0) .....
  WI= find(1,MSGFLG)
  #  If(WI!= 0) .....
  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  #"Confirmation données outlook  BAPPOINTID = "  + BAPPOINTID + " " Status +" : " + RET
  Call ECR_TRACE((mess(258,177,1) - "BAPPOINTID =" - BAPPOINTID - mess(259,123,1) - ":" - RET), 0) From GESECRAN
  #Traitement de l'identifiant rendez-vous
  Call DECOD_OTKID(BAPPOINTID, "BAP", SZAPTNUM, SZOBJET) From SUBSYDUTIL
  Local File SYNCDATA [SYD]
  Raz SZRET
  If RET = MC_WRN Then
    SZRET = MC_OK
  Else
    SZRET = RET
  Endif
  IBERROR = MC_FALSE
  If SZRET <> MC_OK Then
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDKEY = SZAPTNUM
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDOTKSTA = 0
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la modification des données de synchronisation pour le rendez-vous - ":" - SZAPTNUM
          MSGTXT(INBMES) = mess(294,177,1) - ":" - SZAPTNUM
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        MSGFLG(INBMES) = MC_ERROR
        #Impossible de locker les données de synchronisation pour le rendez-vous - ":" - SZAPTNUM
        MSGTXT(INBMES) = mess(295,177,1) - ":" - SZAPTNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
    Next
    If IBERROR = MC_FALSE Then
      Commit
      RET = MC_OK
    Else
      Rollback
      RET = MC_KO_NEXT
    Endif
  Endif
End

##########################################################################################################
# Description passage info Adonix/Outlook
# ------------------------------------------------------------
Subprog BAP_GET_DESC(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, XMLDESC)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Variable Clbfile XMLDESC()        # Description structure dynamique

Local Integer INBMES

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN

Local Integer TC_MAX : SC_MAX = 100
Local Integer WI : WI= 0
Local Char WDSC(200)(1..SC_MAX)

  Gosub BAP_INIGETDSC From SUBSYDBAPD
  Gosub BAP_LD_GETDESC From SUBSYDBAPD
  Setlob XMLDESC With [L]WDSC
  # Statut
  RET = MC_OK
End

##########################################################################################################
# subprog BAP_GET (MAJ OutLook depuis Adonix)
# ------------------------------------------------------------
Subprog BAP_GET(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, VERDESC, BAPPOINTID, UPDFLG, TBKCHR, TBVCHR, TBKINT, TBVINT, TBKDEC, TBVDEC, TBKDATTIM, TBVDATTIM, TBKCLOB, TBVCLOB)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char VERDESC()
Variable Char BAPPOINTID()        # ID permettant de retrouver la rendez-vous (OL ou X3)
Variable Char UPDFLG()            # Type de mise à jour (C,M,S)
# <Tabl. Dynamiques>
Variable Char TBKCHR()(1..)       # Paramètres caractères
Variable Char TBVCHR()(1..)
Variable Char TBKINT()(1..)       # Paramètres entiers
Variable Integer TBVINT(1..)
Variable Char TBKDEC()(1..)       # Paramètres décimaux
Variable Decimal TBVDEC(1..)
Variable Char TBKDATTIM()(1..)    # Paramètres Dates AAAAMMJJHHMMSS
Variable Char TBVDATTIM()(1..)
Variable Char TBKCLOB()(1..)      # Paramètres Textes riches
Variable Clbfile TBVCLOB()(1..)
# </TD>

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  #Mise à vide des tableaux dynamiques
  Gosub RAZPARAMDYN From SUBSYDSYN

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer INBRECORD

Local Char SZSYDATTTYP(GLONDES)
Local Integer ISYDGEN
Local Integer ISYDUPD
Local Integer INBMES
Local Char SZAPTNUM(GLONBAP)
Local Char SZOBJET(GLONAOB)

Local Char SZMESSAGE(250)

  Raz SZMESSAGE
  IBRETOUR = 1
  INBRECORD = 0
  ISYDGEN = 0
  ISYDUPD = 0
  Raz SZSYDATTTYP
  INBMES = 1
  Raz SZAPTNUM
  Raz SZOBJET
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  RET = MC_OK
  Local File BAPPOINT [BAP]
  Local File SYNCDATA [SYD]
  Local File HD4CLOB [HD4]
  Local File HD6CLOB [HD6]
  Local File CORRESPOND [COR]
  Local File BPARTNER [BPR]
  Local File CONTACTCRM [AIN]
  If GIBBAPOTKCRE = MC_FALSE and GIBBAPOTKUPD = MC_FALSE and GIBBAPOTKDLT = MC_FALSE Then
    #Aucun droit synchronisation  dans Outlook on sort
    RET = MC_NOMORE
    End  # FGR 29/03/2010 : X3SUIVI62472 : et pas Return
  Endif
  #Ontraite les enregistrements par type
  #Rappel
  # "C" création,
  # "D" duplication,
  # "M" modification,
  # "A" annulation
  # "P" changement utilisateur (pour ancien)
  # "R" restauration ou forcage synchro
  INBRECORD = 0
  #Etape 1
  #Enregistrement à créer
  If GINUMETAPEGET = 1 Then
    If GIBBAPOTKCRE = MC_FALSE Then
      #Pas le droit de créer On passe à l'étape 2
      GINUMETAPEGET = 3
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDOTKSTA = 1 and ([F:SYD]SYDATTTYP = "C" or [F:SYD]SYDATTTYP = "D")
        INBRECORD += 1
        SZAPTNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 2
        GINUMETAPEGET = 2
      Endif
    Endif
  Endif
  #Etape 2
  #Enregistrement modifié
  If GINUMETAPEGET = 2 Then
    If GIBBAPOTKUPD = MC_FALSE Then
      #Pas le droit de créer On passe à l'étape 3
      GINUMETAPEGET = 3
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR=GUSER and [F:SYD]SYDTYP="BAP" and [F:SYD]SYDOTKSTA = 1 and [F:SYD]SYDATTTYP="M"
        INBRECORD += 1
        SZAPTNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 3
        GINUMETAPEGET = 3
      Endif
    Endif
  Endif
  #Etape 3
  #Enregistrement restauration ou forcage synchro
  If GINUMETAPEGET = 3 Then
    If GIBBAPOTKCRE = MC_FALSE and GIBBAPOTKUPD = MC_FALSE Then
      #Pas le droit de créer et de modifer  On passe à l'étape 4
      GINUMETAPEGET = 4
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDOTKSTA = 1 and [F:SYD]SYDATTTYP = "R"
        INBRECORD += 1
        SZAPTNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 4
        GINUMETAPEGET = 4
      Endif
    Endif
  Endif
  #Etape 4
  #suppression enregistrement non touché par synchro
  If GINUMETAPEGET = 4 Then
    If GIBBAPOTKDLT = MC_FALSE Then
      #Pas le droit de créer On passe à l'étape 5
      GINUMETAPEGET = 5
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDOTKSTA = 1 and ([F:SYD]SYDATTTYP = "A" or [F:SYD]SYDATTTYP = "P")
        INBRECORD += 1
        SZAPTNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 5
        GINUMETAPEGET = 5
      Endif
    Endif
  Endif
  If GINUMETAPEGET <> 5 Then
    #On a un enregistrement, il faut le traiter
    #Cas des enregistrements nouveaux ou modifiés (la rendez-vous existe dans Adonix)
    Call  CODE_OTKID(SZAPTNUM, "BAP", BAPPOINTID) From SUBSYDUTIL
    #"Traitement données Adonix" "BAPPOINTID = "  + BAPPOINTID+ " " Type+" : " SZSYDATTTYP
    Call ECR_TRACE((mess(260,177,1) - "BAPPOINTID =" - BAPPOINTID - mess(115,123,1) - ":" - SZSYDATTTYP), 0) From GESECRAN
    If SZSYDATTTYP = "P" Then
      UPDFLG = "A"
    Else
      UPDFLG = SZSYDATTTYP
    Endif
    If SZSYDATTTYP <> "A" Then
      Read [BAP]APP0=SZAPTNUM
      If fstat <> 0 Then
        #Problème car incohérence entre BAPPOINT ET SYNCDATA
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de la lecture du rendez-vous - ":" - SZAPTNUM
        MSGTXT(INBMES) = mess(292,177,1) - ":" - SZAPTNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        RET = MC_KO_NEXT
      Endif
    Endif
    If RET = MC_OK Then
      #On charge les tableaux dynamiques
      Gosub BAP_LOADGET
    Endif
  Else
    RET = MC_NOMORE
  Endif
End

##########################################################################################################
# Transfert des infos de Adonix vers Outlook
##########################################################################################################
$BAP_LOADGET
Local Integer ICHAR
Local Integer IINT
Local Integer IDEC
Local Integer IDATE
Local Integer ICLOB
Local Char SZVALEUR(250)     # FGR 25/02/2014 : X3SUIVI97224
Local Char SZVALEUR2(250)    # FGR 25/02/2014 : X3SUIVI97224
Local Char SZTEXTE(250)
Local Char SZTEXTE1(250)     # FGR 25/02/2014 : X3SUIVI97224
Local Char SZREPCONNECT(GLONREP)
Local Clbfile  LBCLOBENTETE
Local Integer IBVIDE
Local Integer IINDEXE
Local Integer IINDEXEOTK
Local Integer IINDEXEMAX
Local Date DTVALEUR1
Local Date DTVALEUR2
Local Integer IBFOUND
Local Clbfile  LBCLOBITI(12)

  Raz SZVALEUR
  Raz SZVALEUR2
  Raz SZTEXTE
  Raz SZREPCONNECT
  Raz LBCLOBENTETE
  ICHAR = 1
  IINT = 1
  IDEC = 1
  IDATE = 1
  ICLOB = 1
  IBVIDE = MC_FALSE
  Raz DTVALEUR1
  Raz DTVALEUR2
  IINDEXE = 0
  IINDEXEOTK = 0
  IINDEXEMAX = 0
  IBFOUND = 0
  If UPDFLG = "A" Then
    IBVIDE = MC_TRUE
  Endif
  Call GETREPFROMUTI(GUSER, SZREPCONNECT, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If SZREPCONNECT = "" Then
    #Erreur, aucun représentant n'est associé à cet utilisateur : GUSER
    MSGTXT(INBMES) = mess(301,177,1) - ":" - GUSER
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES += 1
    RET = MC_KO
  Endif
  #Traitement des contacts
  If SZREPCONNECT = [F:BAP]ATPREPMNA Then
    #Le représentant connecté est l'organisateur/propriétaire du rendez vous
    #On charge les contacts
    # Contacts liés aux personnes à visiter
    IINDEXEOTK = 1
    IINDEXE = 0
    IINDEXEMAX = 0
    IINDEXEMAX = dim([F:BAP]APTCCNNUM)
    While IINDEXE <IINDEXEMAX
      If GIBSYNCBAPGERECOR = MC_FALSE Then
        Break
      Endif
      If [F:BAP]APTCCNNUM(IINDEXE) <> "" Then
        If [F:BAP]APTCOR(IINDEXE) <> "" Then
          TBKCHR(ICHAR) = "Lk_" + num$(IINDEXEOTK) + "_CtAdxId"
          Call  CODE_OTKID([F:BAP]APTCOR(IINDEXE), "COR", TBVCHR(ICHAR)) From SUBSYDUTIL
          ICHAR += 1
          TBKCHR(ICHAR) = "Lk_" + num$(IINDEXEOTK) + "_Name"
          Read [COR]COR0=[F:BAP]APTCOR(IINDEXE)
          If fstat Then
            TBVCHR(ICHAR) = ""
          Else
            Call BUILDFULNAM("COR", TBVCHR(ICHAR)) From CRMUTIL140
          Endif
          ICHAR += 1
          IINDEXEOTK += 1
        Endif
      Else
        Break
      Endif
      IINDEXE += 1
    Wend
    # Contacts liés aux représentants
    IINDEXE = 0
    IINDEXEMAX = 0
    IINDEXEMAX = dim([F:BAP]APTREPNUM)
    While IINDEXE < IINDEXEMAX
      IBFOUND = 0
      Raz SZVALEUR
      If GIBSYNCBAPGERECOR = MC_FALSE Then
        Break
      Endif
      If [F:BAP]APTREPNUM(IINDEXE) <> "" Then
        #On recherche le code correspondant
        For [COR] Where [F:COR]BPRNUM = [F:BAP]APTREPNUM(IINDEXE) and [F:COR]CORTYP = "REP"
          IBFOUND = 1
          SZVALEUR = [F:COR]CORNUM
          Break
        Next
        If IBFOUND = 1 Then
          TBKCHR(ICHAR) = "Lk_" + num$(IINDEXEOTK) + "_CtAdxId"
          Call  CODE_OTKID(SZVALEUR, "COR", TBVCHR(ICHAR)) From SUBSYDUTIL
          ICHAR += 1
          TBKCHR(ICHAR) = "Lk_" + num$(IINDEXEOTK) + "_Name"
          TBVCHR(ICHAR) = [F:COR]LNA
          ICHAR += 1
          IINDEXEOTK += 1
        Endif
      Else
        Break
      Endif
      IINDEXE += 1
    Wend
  Endif
  # ------------------------
  # FGR 25/02/2014 : X3SUIVI97224 (début)
  # Entête
  Raz LBCLOBENTETE
  #
  LBCLOBENTETE += mess(681,177,1) - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:BAP]APTNUM, "GESBAP", [F:BAP]APTNUM)
  LBCLOBENTETE += chr$(13) + chr$(10) + string$(50, '-')
  #
  Read [BPR]BPR0=[F:BAP]ATPREPMNA
  If fstat = 0 Then
    If SZREPCONNECT <> [F:BAP]ATPREPMNA Then
      LBCLOBENTETE += chr$(13) + chr$(10) + mess(505,177,1) - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:BPR]BPRNAM, "GESREP", [F:BAP]ATPREPMNA)
    Else
      LBCLOBENTETE += chr$(13) + chr$(10) + mess(670,177,1) - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:BPR]BPRNAM, "GESREP", [F:BAP]ATPREPMNA)
    Endif
  Endif
  #
  If [F:BAP]APTCMP <> "" Then
    Call GETBPRTYP([F:BAP]APTCMP, SZTEXTE, SZTEXTE1) From CRM_UTIL
    Call SYN_SETBPR([F:BAP]APTCMP, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
    Read [BPR]BPR0=[F:BAP]APTCMP
    If SZTEXTE1 = "" Then
      LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - SZVALEUR
    Else
      LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:BPR]BPRNAM, "GES" + SZTEXTE1, [F:BAP]APTCMP) - SZVALEUR
    Endif
  Endif
  If [F:BAP]APTPJT <> "" Then
    Call TEXTE(18260, SZTEXTE) From OBJDIV
    Local File OPPOR [OPP]
    Read [OPP]OPP0=[F:BAP]APTPJT
    If !fstat Then
      If dim([F:OPP]OPPDES) >= 0 Then
        LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:OPP]OPPDES, "GESOPP", [F:BAP]APTPJT)
      Else
        Call LECTEXTRA(SZTEXTE1, "PIMPL", "PIMDESAXX", [F:BAP]APTPJT, "") From ATEXTRA
        LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK(SZTEXTE1, "GESOPP", [F:BAP]APTPJT)
      Endif
    Endif
  Endif
  # FGR 25/02/2014 : X3SUIVI97224 (fin)
  # ------------------------
  #Gestion du compte rendu si pas organisateur (pour avoir liste)
  #Construction entête
  #Personnes à visiter
  SZTEXTE = chr$(13) + chr$(10) + chr$(13) + chr$(10) + mess(506,177,1) - ":"
  LBCLOBENTETE += SZTEXTE
  IINDEXE = 0
  IINDEXEMAX = 0
  IINDEXEMAX = dim([F:BAP]APTCCNNUM)
  While IINDEXE < IINDEXEMAX
    If [F:BAP]APTCCNNUM(IINDEXE) <> "" Then
      Raz SZTEXTE
      Raz SZVALEUR
      Read [AIN]AIN0=[F:BAP]APTCCNNUM(IINDEXE)
      If fstat = 0 Then
        Call BUILDFULNAM("AIN", SZVALEUR) From CRMUTIL140
        If [F:AIN]CNTTYP = 1 Then
          LBCLOBENTETE += chr$(13) + chr$(10) + "   " + func SUBSYDUTIL.GET_HYPERLINK(SZVALEUR, "GESAIN", [F:BAP]APTCCNNUM(IINDEXE)) #- "(" + [F:BAP]APTCOR(IINDEXE) + ")"
        Else
          LBCLOBENTETE += chr$(13) + chr$(10) + "   " + func SUBSYDUTIL.GET_HYPERLINK(SZVALEUR, "GESLDS", [F:BAP]APTCCNNUM(IINDEXE)) #- "(" + [F:BAP]APTCOR(IINDEXE) + ")"
        Endif
      Endif
      # FGR 04/06/2015 : X3SUIVI108602 (début)
      If [F:BAP]APTCOR(IINDEXE) <> "" Then
        Call TEXTE(15307, SZTEXTE) From OBJDIV
        If !clalev([F:COR]) : Local File CORRESPOND [COR] : Endif
        Read [COR]COR0=[F:BAP]APTCOR(IINDEXE)
        If !fstat Then
          LBCLOBENTETE += " (" + func SUBSYDUTIL.GET_HYPERLINK(SZTEXTE, "GESCOR", [F:BAP]APTCOR(IINDEXE)) + ")"
        Endif
      Endif
      # FGR 04/06/2015 : X3SUIVI108602 (fin)
    Endif
    IINDEXE += 1
  Wend
  # Contacts liés aux représentants
  #Intervenants
  SZTEXTE = chr$(13) + chr$(10) + chr$(13) + chr$(10) + mess(507,177,1) - ":"
  LBCLOBENTETE += SZTEXTE
  IINDEXE = 0
  IINDEXEMAX = 0
  IINDEXEMAX = dim([F:BAP]APTREPNUM)
  While IINDEXE < IINDEXEMAX
    IBFOUND = 0
    Raz SZTEXTE
    If [F:BAP]APTREPNUM(IINDEXE) <> "" Then
      If [F:BAP]APTREPNUM(IINDEXE) <> [F:BAP]ATPREPMNA Then
        Read [BPR]BPR0=[F:BAP]APTREPNUM(IINDEXE)
        If fstat = 0 Then
          #SZTEXTE = chr$(13) + chr$(10) + "   " + [F:BPR]BPRNAM
          LBCLOBENTETE += chr$(13) + chr$(10) + "   " + func SUBSYDUTIL.GET_HYPERLINK([F:BPR]BPRNAM, "GESREP", [F:BAP]APTREPNUM(IINDEXE))
        Endif
      Endif
    Endif
    IINDEXE += 1
  Wend
  #Gestion du compte rendu pour info adresse
  #Lieu du rendez-vous
  Raz SZTEXTE
  If LBCLOBENTETE <> "" Then
    LBCLOBENTETE += chr$(13) + chr$(10)
  Endif
  # ----------------------------------------------------------
  Raz LBCLOBITI
  LBCLOBITI = func TRTITI.GET_REQUETE_HTTP("BAP", [F:BAP]APTNUM, "1", [F:BAP]APTCTY, [F:BAP]APTADD(0), [F:BAP]APTCRY, [F:BAP]APTZIP, [F:BAP]SALFCY, "")
  #
  LBCLOBENTETE += chr$(13) + chr$(10) + mess(508,177,1) - ":" - "{{" + mess([F:BAP]APTPLC,955,1) + "}{" + LBCLOBITI + "}}"
  # ----------------------------------------------------------
  If [F:BAP]ATPADDCMT <> "" Then
    LBCLOBENTETE += chr$(13) + chr$(10) + [F:BAP]ATPADDCMT
  Endif
  If [F:BAP]APTADD(0) <> "" Then
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + [F:BAP]APTADD(0)
  Endif
  If [F:BAP]APTADD(1) <> "" Then
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + [F:BAP]APTADD(1)
  Endif
  If [F:BAP]APTADD(2) <> "" Then
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + [F:BAP]APTADD(2)
  Endif
  If [F:BAP]APTZIP <> "" Then
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + [F:BAP]APTZIP
  Endif
  If [F:BAP]APTCTY <> "" Then
    If [F:BAP]APTZIP <> "" Then
      LBCLOBENTETE = LBCLOBENTETE - [F:BAP]APTCTY
    Else
      LBCLOBENTETE += chr$(13) + chr$(10) + "        " + [F:BAP]APTCTY
    Endif
  Endif
  If [F:BAP]APTCRY <> "" Then
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + [F:BAP]APTCRY
  Endif
  If dim([F:BAP]APTSAT) > 0 Then
    If [F:BAP]APTSAT <> "" Then
      LBCLOBENTETE = LBCLOBENTETE + chr$(13) + chr$(10) + "        " + [F:BAP]APTSAT
    Endif
  Endif
  If [F:BAP]APTTEL <> "" Then
    # Issue X3-42496 - 2017-06-15 by FGR : BEGIN
    #LBCLOBENTETE = LBCLOBENTETE + chr$(13) + chr$(10) + mess(509,177,1) - ":" - [F:BAP]APTTEL
    LBCLOBENTETE = LBCLOBENTETE + chr$(13) + chr$(10) + mess(509,177,1) - ":" - func SUBSYDUTIL.GET_FORMATTED_CRY_PHONE([F:BAP]APTCRY, [F:BAP]APTTEL)
    # Issue X3-42496 - 2017-06-15 by FGR : END
  Endif
  # FGR 15/01/2013 : X3SUIVI87223 (début)
  If [F:BAP]APTTYP <> "" Then
    LBCLOBENTETE = LBCLOBENTETE + chr$(13) + chr$(10) + chr$(13) + chr$(10) + mess(655,197,1) - ":" - [F:BAP]APTTYP - "(" + func CRM_UTIL.FGET_LIB(433, [F:BAP]APTTYP, "LNGDES") + ")"
  Else
    LBCLOBENTETE = LBCLOBENTETE + chr$(13) + chr$(10) + chr$(13) + chr$(10) + mess(655,197,1) - ": ***" + mess(962,182,1) + "***"
  Endif
  # FGR 15/01/2013 : X3SUIVI87223 (fin)
  If LBCLOBENTETE <> "" Then
    Call ADDBALISEBAP(LBCLOBENTETE) From SUBSYDUTIL
  Endif
  #Indication de propriétaire
  TBKINT(IINT) = "AdxRef"
  If SZREPCONNECT = [F:BAP]ATPREPMNA Then
    TBVINT(IINT) = MC_TRUE
  Else
    TBVINT(IINT) = MC_FALSE
  Endif
  IINT += 1
  #Description adresse
  TBKCHR(ICHAR) = "Location"
  TBVCHR(ICHAR) = [F:BAP]ATPADDCMT
  ICHAR += 1

  #Journée entière
  TBKINT(IINT) = "AllDayEvent"
  # FGR 25/03/2009 : X3SUIVI53600 : La transcodification de FULDAY n'était pas faite !
  If [F:BAP]FULDAY = 2 Then
    TBVINT(IINT) = 1
  Else
    TBVINT(IINT) = 0
  Endif
  IINT += 1
  #Durée rendez-vous
  TBKINT(IINT) = "Duration"
  TBVINT(IINT)=val([F:BAP]APTDUR)
  IINT += 1
  #Date rendez-vous
  TBKDATTIM(IDATE) = "Start"
  If IBVIDE = MC_FALSE Then
    If [F:BAP]APTDAT <> [00/00/00] Then
      Call SETDATETIMETOCHAR([F:BAP]APTDAT, [F:BAP]APTHOU, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
      TBVDATTIM(IDATE) = SZVALEUR
    Else
      Call SETDATETIMETOCHAR([F:BAP]APTDATX, [F:BAP]APTHOU, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
      TBVDATTIM(IDATE) = SZVALEUR
    Endif
  Endif
  IDATE += 1
  #Fin rendez-vous
  TBKDATTIM(IDATE) = "End"
  If IBVIDE = MC_FALSE Then
    If [F:BAP]APTDATEND <> [00/00/00] Then
      Call SETDATETIMETOCHAR([F:BAP]APTDATEND, [F:BAP]APTHOUEND, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
      TBVDATTIM(IDATE) = SZVALEUR
    Else
      If [F:BAP]APTDAT <> [00/00/00] Then
        DTVALEUR1 = [F:BAP]APTDAT
      Else
        DTVALEUR1 = [F:BAP]APTDATX
      Endif
      Call DAY_ADD_DURE(DTVALEUR1, [F:BAP]APTHOU, 0, val([F:BAP]APTDUR), 0, DTVALEUR2, SZVALEUR2, SZMESSAGE, IBRETOUR) From CRMUTIL150
      Call SETDATETIMETOCHAR(DTVALEUR2, SZVALEUR2, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
      TBVDATTIM(IDATE) = SZVALEUR
    Endif
  Endif
  IDATE += 1
  #Description
  TBKCLOB(ICLOB) = "Subject"
  If IBVIDE = MC_FALSE Then
    If [F:BAP]NUMFULOBJ <> "" and [F:BAP]TYPFULOBJ <> "" Then
      Read [HD6]HD60=[F:BAP]NUMFULOBJ;[F:BAP]TYPFULOBJ
      If fstat = 0 Then
        TBVCLOB(ICLOB) = [F:HD6]CLOB
      Endif
    Endif
  Endif
  ICLOB += 1
  #Compte rendu
  TBKCLOB(ICLOB) = "Body"
  # FGR 15/01/2013 : X3SUIVI87223 (début)
  If LBCLOBENTETE <> "" Then
    TBVCLOB(ICLOB) = LBCLOBENTETE
  Endif
  # FGR 15/01/2013 : X3SUIVI87223 (fin)
  If IBVIDE = MC_FALSE Then
    If [F:BAP]NUMFULRPO <> "" and [F:BAP]TYPFULRPO <> "" Then
      Read [HD4]HD40=[F:BAP]NUMFULRPO;[F:BAP]TYPFULRPO
      If fstat = 0 Then
        If LBCLOBENTETE <> "" Then
          TBVCLOB(ICLOB) += chr$(13) + chr$(10) + chr$(13) + chr$(10) + [F:HD4]CLOB
        Else
          TBVCLOB(ICLOB) = [F:HD4]CLOB
        Endif
      Endif
    Endif
  Endif
  ICLOB += 1
Return

##########################################################################################################
# Confirmation Get
# ------------------------------------------------------------
Subprog BAP_GET_OK(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, BAPPOINTID)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char BAPPOINTID()           # ID permettant de retrouver la rendez-vous

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Char SZAPTNUM(GLONBAP)
Local Char SZOBJET(GLONAOB)
Local Integer INBMES
Local Integer IBERROR
Local Char SZRET(GLONDES)

  Raz SZAPTNUM
  Raz SZOBJET
  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  #"Confirmation données Adonix BAPPOINTID = "  + BAPPOINTID + " " Status +" : " + RET
  Call ECR_TRACE(( mess(261,177,1) - "BAPPOINTID =" - BAPPOINTID - mess(259,123,1) - ":" - RET), 0) From GESECRAN
  IBERROR = MC_FALSE
  Raz SZRET
  If RET = MC_WRN Then
    SZRET = MC_OK
  Else
    SZRET = RET
  Endif
  Local File SYNCDATA [SYD]
  Call DECOD_OTKID(BAPPOINTID, "BAP", SZAPTNUM, SZOBJET) From SUBSYDUTIL
  Call DEBTRANS From GLOCK
  Trbegin [SYD]
  If SZRET = MC_OK Then
    #Tout s'est bien passé, on supprime les enregistrements de SYNCDATA
    Delete Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDKEY = SZAPTNUM
    If fstat <> 0 Then
      IBERROR = MC_TRUE
      #Problème car incohérence entre BAPPOINT ET SYNCDATA
      MSGFLG(INBMES) = MC_ERROR
      #Erreur lors de la suppression des données de synchronisation pour le rendez-vous - ":" - SZAPTNUM
      MSGTXT(INBMES) = mess(298,177,1) - ":" - SZAPTNUM
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
    Endif
  Else
    #Problème on met à jour le flag
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDKEY = SZAPTNUM
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDOTKSTA = 0
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la modification des données de synchronisation pour le rendez-vous - ":" - SZAPTNUM
          MSGTXT(INBMES) = mess(294,177,1) - ":" - SZAPTNUM
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        MSGFLG(INBMES) = MC_ERROR
        #Impossible de locker les données de synchronisation pour le rendez-vous - ":" - SZAPTNUM
        MSGTXT(INBMES) = mess(295,177,1) - ":" - SZAPTNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
    Next
  Endif
  If IBERROR = MC_FALSE Then
    Commit
    RET = MC_OK
  Else
    Rollback
    RET = MC_KO_NEXT
  Endif
End

