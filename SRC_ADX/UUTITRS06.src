#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################################################
# UUTITRS06                                                  Module Tiers                              #
# Ajout d'une condition d'en-tête dans les règles de workflow pour ignorer l'état FUP                  #                     
########################################################################################################

Local Char APPLI(30) : APPLI = nomap
Call SAIDOS(APPLI,"") From SAIDOS
If APPLI <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTITRS06: Workflow rules update") From LECFIC

 Call MAJ_UTITRS06(APPLI)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITRS06(APPLI)
Value Char APPLI
Local Integer STAT, N

# test du code activité
If func AFNC.ACTIV("FUP")=0 : End : Endif

Call ECR_TRACE("UUTITRS06: Process Start on: "+APPLI,0) From GESECRAN

Local File =APPLI+".AWRKPAR"  [AWA]
Local File =APPLI+".AWRKPAR"  [AWA2]
Local Char COND(250)
Local Integer D

[L]COND = '[F:ARP]RPTCOD<>"FUP"'

D = dim([F:AWA]CONDITION)

Trbegin [AWA]
 For [AWA] Where CODE<>"FUP" and CODEVT="ARP" and find([L]COND, CONDITION)=0 and NBCOND<[L]D
  # on ajoute la condition :
  # - si la règle de workflow ne s'appelle pas FUP
  # - si la règle se déclenche avec l'évènement ARP
  # - si le tableau des conditions n'est pas plein
  Update [AWA2] Where [AWA2]CODE=[AWA]CODE With [F:AWA2]CONDITION([F:AWA]NBCOND) = '[F:ARP]RPTCOD<>"FUP"', 
&                                               [F:AWA2]TYPCND([F:AWA]NBCOND)=2, [F:AWA2]NBCOND=[F:AWA2]NBCOND+1
  Call ECR_TRACE("Workflow rule updated:"-[F:AWA]CODE,0) From GESECRAN
 Next
Commit
Call ECR_TRACE("UUTITRS06: Process End on: "+APPLI,0) From GESECRAN
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS06(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI="X3" End : Endif
# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS06(APPLI)
End
