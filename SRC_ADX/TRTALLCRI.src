#<AdxTL>@(#)1.0.0.0 $Revision$
#CHECK UNUSED_BEGIN
Local Char PARAM(250)(1..20) , SAVACT(10)
PARAM(1) = "ALL"
Local Decimal VALEUR
#SAVACT = GACTION : GACTION = "SAISORCRI"
Call SAISIE_NUM(VALEUR,PARAM,"IALLCRI","TRTALLCRI") From GSAISIE
#GACTION = SAVACT
End
#CHECK UNUSED_END

#########################################################################
# TRTALLCRI    Saisie des filtres pour la liste de picking des alloc    #
#########################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "AVANT_ENR"   : Gosub AVANT_ENR
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
Endcase
Return

#########################################################################
$OUVRE_BOITE

Gosub FORMAT_INV From STKLIB

Return

#########################################################################
$DEBUT

Local Char    WABMSK
Local Integer I,J

Raz [M:ACR]
WABMSK           = PARAM(1)
[M:ACR]STOFCY    = evalue("[M:"+WABMSK+"]STOFCY")
[M:ACR]ITMREF    = evalue("[M:"+WABMSK+"]ITMREF")
[M:ACR]VCRNUM    = evalue("[M:"+WABMSK+"]VCRNUM")
[M:ACR]AAASTA    = evalue("[M:"+WABMSK+"]AAASTA")
[M:ACR]QQQSTA    = evalue("[M:"+WABMSK+"]QQQSTA")
[M:ACR]RRRSTA    = evalue("[M:"+WABMSK+"]RRRSTA")
[M:ACR]FLGSHLLOT = evalue("[M:"+WABMSK+"]FLGSHLLOT")            # hcb V6percri
[M:ACR]FLGDLULOT = evalue("[M:"+WABMSK+"]FLGDLULOT")            # hcb V6percri
[M:ACR]PECINTLOC = evalue("[M:"+WABMSK+"]PECINTLOC")
[M:ACR]PECPLFLOC = evalue("[M:"+WABMSK+"]PECPLFLOC")
[M:ACR]PECSCOLOC = evalue("[M:"+WABMSK+"]PECSCOLOC")
[M:ACR]STODISFLG = evalue("[M:"+WABMSK+"]STODISFLG")
[M:ACR]PCU       = evalue("[M:"+WABMSK+"]XPCUFIL")
[M:ACR]STA       = evalue("[M:"+WABMSK+"]XSTA")
#--- Issue 53322
If dim([M:ACR]LPNNUM)>0 [M:ACR]LPNNUM = evalue("[M:"+WABMSK+"]FLPNNUM") Endif
#---
If dim([M:ACR]PALNUM)>0 [M:ACR]PALNUM = evalue("[M:"+WABMSK+"]XPALNUM") Endif
If dim([M:ACR]CTRNUM)>0 [M:ACR]CTRNUM = evalue("[M:"+WABMSK+"]XCTRNUM") Endif
If dim([M:ACR]LOT)>0    [M:ACR]LOT    = evalue("[M:"+WABMSK+"]XLOT")    Endif
If evalue("dim([M:"+WABMSK+"]OWNFLG)")>0
   [M:ACR]OWNFLG    = evalue("[M:"+WABMSK+"]OWNFLG")
Endif
If evalue("dim([M:"+WABMSK+"]NOTOWNFLG)")>0
   [M:ACR]NOTOWNFLG = evalue("[M:"+WABMSK+"]NOTOWNFLG")
Endif
If evalue("dim([M:"+WABMSK+"]PECOWNER)")>0
   [M:ACR]PECOWNER  = evalue("[M:"+WABMSK+"]PECOWNER")
Endif
If evalue("dim([M:"+WABMSK+"]PECTRU)")>0
   [M:ACR]PECTRU    = evalue("[M:"+WABMSK+"]PECTRU")
Endif
#--- TS 106217
If dim([M:ACR]PECECC)>0 & evalue("dim([M:"+WABMSK+"]PECECC)")>0
   [M:ACR]PECECC    = evalue("[M:"+WABMSK+"]PECECC")
Endif
#---
# Filter dépôt
If dim([M:ACR]WRH)>0 [M:ACR]WRH = evalue("[M:"+WABMSK+"]XWRH") Endif

Affzo [M:ACR]

# Si Réception s-traitance, OF, Suivi matière, Retour liv pour s-traitance,
# Sortie diverse, EO
If find(evalue("[M:"+WABMSK+"]VCRTYP"),6,10,12,13,20,36)
   Actzo [M:ACR]PECSCOLOC
Else
   Diszo [M:ACR]PECSCOLOC
Endif

If !find([M:ACR]STA,"","*")
   Diszo [M:ACR]AAASTA
   Diszo [M:ACR]QQQSTA
   Diszo [M:ACR]RRRSTA
Endif

If [M:ACR]NOTOWNFLG=2
   Actzo [M:ACR]PECOWNER
Else
   Diszo [M:ACR]PECOWNER
Endif

If dim([M:ACR]WRH)>0
   If [F:FCY]FCY<>[M:ACR]STOFCY
      Read [FCY]FCY0=[M:ACR]STOFCY
      If fstat Raz [F:FCY] Endif
   Endif
   # Pas de gestion de dépôt sur le site
   If [F:FCY]WRHGES<>2
      [M:ACR]WRH=""
      Grizo [M:ACR]WRH
   # Si dépôt obligatoire (param transaction) --> non modifiable
   Elsif evalue("[M:"+WABMSK+"]WRHOBY")=2
      Diszo [M:ACR]WRH
   Else
      Actzo [M:ACR]WRH
   Endif
Endif

Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return

#########################################################################
$AVANT_ENR

If [M:ACR]OWNFLG<>2 & [M:ACR]NOTOWNFLG<>2
   GERR=1 : GMESSAGE=mess(259,184,1)
   FOK =0
Endif

Return

#########################################################################
$ENR

Assign "[M:"+WABMSK+"]AAASTA"    With [M:ACR]AAASTA
Assign "[M:"+WABMSK+"]QQQSTA"    With [M:ACR]QQQSTA
Assign "[M:"+WABMSK+"]RRRSTA"    With [M:ACR]RRRSTA
Assign "[M:"+WABMSK+"]FLGSHLLOT" With [M:ACR]FLGSHLLOT         # hcb V6percri
Assign "[M:"+WABMSK+"]FLGDLULOT" With [M:ACR]FLGDLULOT         # hcb V6percri
Assign "[M:"+WABMSK+"]PECINTLOC" With [M:ACR]PECINTLOC
Assign "[M:"+WABMSK+"]PECPLFLOC" With [M:ACR]PECPLFLOC
Assign "[M:"+WABMSK+"]PECSCOLOC" With [M:ACR]PECSCOLOC
Assign "[M:"+WABMSK+"]STODISFLG" With [M:ACR]STODISFLG
Assign "[M:"+WABMSK+"]XPCUFIL"   With [M:ACR]PCU
Assign "[M:"+WABMSK+"]XSTA"      With [M:ACR]STA
#--- Issue 53322
If dim([M:ACR]LPNNUM)>0 Assign "[M:"+WABMSK+"]FLPNNUM" With [M:ACR]LPNNUM Endif
#---
If dim([M:ACR]PALNUM)>0 Assign "[M:"+WABMSK+"]XPALNUM" With [M:ACR]PALNUM Endif
If dim([M:ACR]CTRNUM)>0 Assign "[M:"+WABMSK+"]XCTRNUM" With [M:ACR]CTRNUM Endif
If dim([M:ACR]LOT)>0    Assign "[M:"+WABMSK+"]XLOT"    With [M:ACR]LOT    Endif
If evalue("dim([M:"+WABMSK+"]OWNFLG)")>0
   Assign "[M:"+WABMSK+"]OWNFLG"    With [M:ACR]OWNFLG
Endif
If evalue("dim([M:"+WABMSK+"]NOTOWNFLG)")>0
   Assign "[M:"+WABMSK+"]NOTOWNFLG" With [M:ACR]NOTOWNFLG
Endif
If evalue("dim([M:"+WABMSK+"]PECOWNER)")>0
   Assign "[M:"+WABMSK+"]PECOWNER"  With [M:ACR]PECOWNER
Endif
If evalue("dim([M:"+WABMSK+"]PECTRU)")>0
   Assign "[M:"+WABMSK+"]PECTRU"    With [M:ACR]PECTRU
Endif
#--- TS 106217
If dim([M:ACR]PECECC)>0 & evalue("dim([M:"+WABMSK+"]PECECC)")>0
   Assign "[M:"+WABMSK+"]PECECC"    With [M:ACR]PECECC
Endif
#---
# Filter dépôt
If dim([M:ACR]WRH)>0 Assign "[M:"+WABMSK+"]XWRH" With [M:ACR]WRH Endif

GOK = 1
FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return

##########################################################################
## Etiquette ajoutée par le superviseur 26/09/2003 16:36:53 (TS)
##########################################################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()

Local Integer I,J
Local Char    WWSTA(12)
Local Char    WSTA(3)(6)
Local Char    WA(1), WQ(1), WR(1)

Raz WA,WQ,WR

If [M:ALL]AAASTA=2 WA="A" Endif
If [M:ALL]QQQSTA=2 WQ="Q" Endif
If [M:ALL]RRRSTA=2 WR="R" Endif

If !find(VALEUR,"","*")
   VALEUR=toupper(VALEUR)
   WWSTA=VALEUR
   J=instr(J,WWSTA,",")
   While J<>0
      WSTA(I)=left$ (WWSTA,J-1)
      WWSTA  =right$(WWSTA,J+1)
      J=instr(J,WWSTA,",")
      I+=1
   Wend
   J=I
   WSTA(I)=WWSTA
   For I=0 To J
      If !find(left$(WSTA(I),1),WA,WQ,WR)
         mkstat=2 : GMESSAGE=mess(387,199,1)
         Break
      Endif
   Next I
Endif

End

##########################################################################
Subprog AM_STA(VALEUR)
Variable Char    VALEUR()

If find(VALEUR,"","*")
   Actzo [M:ACR]AAASTA
   Actzo [M:ACR]QQQSTA
   Actzo [M:ACR]RRRSTA
Else
   Diszo [M:ACR]AAASTA
   Diszo [M:ACR]QQQSTA
   Diszo [M:ACR]RRRSTA
Endif
Affzo [M:ACR]AAASTA, QQQSTA, RRRSTA

End

##########################################################################
Subprog B1_STA(VALEUR)
Variable Char    VALEUR()

VALEUR = GXSTA
End


##########################################################################
Subprog AM_NOTOWNFLG(VALEUR)
Variable Integer VALEUR

If VALEUR=2
   Actzo [M:ACR]PECOWNER
Else
   Diszo [M:ACR]PECOWNER
   Raz   [M:ACR]PECOWNER
Endif
Affzo [M:ACR]PECOWNER

End

##########################################################################
Subprog C_PECOWNER(VALEUR)
Variable Char    VALEUR()
Local Char    WSUP
Local Integer WRET
If [M:ACR]NOTOWNFLG=2 & VALEUR=""
   mkstat=2 : GMESSAGE=mess(516,199,1) : End
Endif
Call STKOWNER("C",VALEUR,WSUP,WRET) From STKACT
End

#  Hcb V6percri deb
######################################################################################
Subprog AM_FLGSHLLOT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
   [M:ACR]FLGDLULOT = 2
Endif
Affzo [M:ACR]FLGDLULOT

End

Subprog AM_FLGDLULOT(VALEUR)
Variable Integer VALEUR
If VALEUR=1
   [M:ACR]FLGSHLLOT = 1
Endif
Affzo [M:ACR]FLGSHLLOT

End
#  Hcb V6percri fin

