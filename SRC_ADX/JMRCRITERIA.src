#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "INIT"     : Gosub INIT
    When "CONTROLE" : Gosub CONTROLE
    When "EXEC"     : Gosub EXEC
  Endcase
Return

$INIT
  #Declarar coses
  Local File GACCENTRY[CENTRY]
  Local File GACCENTRYD[CENTRYD]
Return

$CONTROLE
  #Check the fields in the screen
  Local Char SW_ERRORS(1) : SW_ERRORS = "N"

  Gosub SITE : Gosub ENTRY_TYPE : Gosub JOURNAL_TYPE : Gosub DOCUMENT_NUMBER : Gosub DATE_FROM_TO

  If SW_ERRORS = "S"
    Call ECR_TRACE("There are errors in the screen.",1) From GESECRAN
    SAI=1
  Endif

Return

$EXEC

Return

$SITE
  #Check if site belongs to company defined in field company

Return

$ENTRY_TYPE
  #Only entry types that exist for the legislation of the company or that are available for all legislation are allowed.

Return

$JOURNAL_TYPE
  #Only journal types that exist for the legislation of the company or that are available for all legislation are allowed.

Return

$DOCUMENT_NUMBER
  #Range of document numbers

Return

$DATE_FROM_TO
  #Restricts search to a date range

Return

