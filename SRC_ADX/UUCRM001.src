#<AdxTL>@(#)5.0.0.0 $Revision$
# FGR 17/02/2009 : X3SUIVI52520
# Moulinette pour créer les libellés traduisibles des cibles avancées.

  Call MAJ_UTICRM001(nomap)
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  Call MAJ_UTICRM001(APPLI)
End

########################################################################
Subprog MAJ_UTICRM001(DOSSIER)
Value Char DOSSIER

Local Integer IERR

  If DOSSIER = "X3" Then
    End 
  Endif
  #------------------------------------------------------
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
  Call ECR_TIME("Description des cibles deviennent traduisibles") From DOSSUB
  #------------------------------------------------------
  IERR = 0
  Call ECR_TIME("DEBUT => Cibles (TGL)(SSP)(FID)(FDF)(MST)(SPT)(TGP)") From DOSSUB
  Call CRMSTEP2(DOSSIER, IERR) From CRMMAJ30
  Call ECR_TIME("FIN => Cibles (TGL)(SSP)(FID)(FDF)(MST)(SPT)(TGP)") From DOSSUB
  #------------------------------------------------------
End
