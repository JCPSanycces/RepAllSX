#<AdxTL>@(#)0.0.0.0 $Revision$ objet GCM
#
# Account core model
# Modèle comptable
#
# CBO   05.12.17 X3-66254  Error NUMASS when change key
#

Raz GPILOBJ
Call OBJET("GCM",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "LIENS"      : Gosub LIENS
 When "RAZCRE"     : Gosub RAZCRE
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
 When "FERME"      : Gosub FERME
Endcase
Return

$OUVRE
If clalev([F:LED]) = 0 : Local File GLED [LED] : Endif
If clalev([F:DIE]) = 0 : Local File GDIE [DIE] : Endif
Local Integer I, J, K, L, X
Local Char CURTAB(GLONCUR)(dim([M]LED))
I = max(1,nbrecord([DIE]))
Local Char DIETAB(GLONDIE)(I)
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$RAZCRE
[M]NBRLED=len(mess(0,2644,1))
Affzo LEDTYP
# Dossier Mono législation
If func AFNC.ACTIV("LEG")=0
 [V]GCURLEG = GDOSLEG(1)
Endif
Return

$LIENS
Call LECTEXTRA([M]DESTRA,"GACM","DESTRA",[M]GCM,"") From ATEXTRA
Call LECTEXTRA([M]SHOTRA,"GACM","SHOTRA",[M]GCM,"") From ATEXTRA
Gosub TAB
If dim([M]FLGIAS)>0 & [M]FLGIAS = 2
 Actzo IASLEDTYP : Affzo IASLEDTYP
Elsif dim([M]IASLEDTYP)>0
 [M]IASLEDTYP = 0
 Grizo IASLEDTYP : Affzo IASLEDTYP
Endif
GCURLEG = [F:GCM]LEG
Return

$TAB
[M]NBRLED=len(mess(0,2644,1))
For I=0 To [M]NBRLED-1
 If [F:GCM]LED(I)<>""
  [M]LED(I) = [F:GCM]LED(I)
 Endif
Next I
Affzo NBRLED, LEDTYP, LED, CFMAUT, CUR, DACRAT, FLGVCRRAT, TYPRAT, RNDOPTBAL
For I=0 To [M]NBRLED-1
 If [M]CFMAUT(I)=2
  Grizo [M]LED(I)
  If dim([M]DOELED)>0
   If [M]DOELED(I)=2 :
    Grizo [M]CUR(I)
    Grizo [M]RNDOPTBAL(I)
   Else
    Actzo [M]CUR(I)
    Actzo [M]RNDOPTBAL(I)
   Endif
  Endif
 Else
  Actzo [M]LED(I)
  Actzo [M]CUR(I)
  Actzo [M]RNDOPTBAL(I)
 Endif
Next
Return

$VERIF_CRE
Gosub VERIF
Return

$VERIF_MOD
Read [GCM]GCM0 = CLECUR1
Gosub VERIF
If !OK : Return : Endif
#
# On ne peut pas modifier le réf principal général s'il existe des échéances
#
If [M:GCM1]GENLEDTYP<>[F:GCM]GENLEDTYP
 If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
 If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
 For [CPY] Where ACM=[F:GCM]GCM
  Filter [DUD] Where CPY=[F:CPY]CPY
  Read [DUD] First
  Filter [DUD]
  If fstat<=2
   GMESSAGE = mess(181,105,1)
   # On ne peut pas changer le référentiel principal
   OK = 0 : Break
  Endif
 Next
 If !OK
  [M:GCM1]GENLEDTYP = [F:GCM]GENLEDTYP : Affzo [GCM1]GENLEDTYP
  Return
 Endif
Endif
#
# On ne peut pas modifier le réf principal analytique s'il existe des engagements
#
If [M:GCM1]ANALEDTYP<>[F:GCM]ANALEDTYP
#JASMI - 2017-06-16 - X3-42325 - START
# If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
# If clalev([F:CMM])=0 : Local File GCOMMIT [CMM] : Endif
# For [CPY] Where ACM=[F:GCM]GCM
#  Filter [CMM] Where CPY=[F:CPY]CPY
#  Read [CMM] First
#  Filter [CMM]
#  If fstat<=2
#   GMESSAGE = mess(181,105,1)
#   # On ne peut pas changer le référentiel principal
#   OK = 0 : Break
#  Endif
# Next
# If !OK
#  [M:GCM1]ANALEDTYP = [F:GCM]ANALEDTYP : Affzo [GCM1]ANALEDTYP
#  Return
# Endif
  If GMODU(2)<>2 # Financials
   GMESSAGE = mess(181,105,1)
   # On ne peut pas changer le référentiel principal
   OK = 0
  Else
   If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
   If clalev([F:CMM])=0 : Local File GCOMMIT [CMM] : Endif
   For [CPY] Where ACM=[F:GCM]GCM
    Filter [CMM] Where CPY=[F:CPY]CPY
    Read [CMM] First
    Filter [CMM]
    If fstat<=2
     GMESSAGE = mess(181,105,1)
     # On ne peut pas changer le référentiel principal
     OK = 0 : Break
    Endif
   Next
   If !OK
    [M:GCM1]ANALEDTYP = [F:GCM]ANALEDTYP : Affzo [GCM1]ANALEDTYP
    Return
   Endif
  Endif
#JASMI - 2017-06-16 - X3-42325 - END
Endif
#
# On ne peut pas modifier le référentiel ni sa devise, s'il est mouvementé
# On autorise d'en ajouter un
#
For I=1 To len(mess(0,2644,1))
 If  [F:GCM]LED(I-1)<>""
& & ([M:GCM1]LED(I-1)<>[F:GCM]LED(I-1) or [M:GCM1]CUR(I-1)<>[F:GCM]CUR(I-1))
#JASMI - 2017-06-16 - X3-42325 - START
#  If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
  If GMODU(2)=2 # Financials
    If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
  Else
    If clalev([F:DAE])=0 : Local File GACCTMPD [DAE] : Endif
  Endif
#JASMI - 2017-06-16 - X3-42325 - END
  If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
  For [CPY] Where ACM=[F:GCM]GCM
   Filter [DAE] Where CPY=[F:CPY]CPY and LEDTYP=I
   Read [DAE] First
   Filter [DAE]
   If fstat<=2
    [M:GCM1]LED(I-1)       = [F:GCM]LED(I-1)
    [M:GCM1]CUR(I-1)       = [F:GCM]CUR(I-1)
    [M:GCM1]CFMAUT(I-1)    = [F:GCM]CFMAUT(I-1)
    [M:GCM1]ORILEDTYP(I-1) = [F:GCM]ORILEDTYP(I-1)
    # Changement de référentiel ou de devise impossible
    GMESSAGE = mess(182,105,1)
    OK = 0
    Break
   Endif
  Next
 Endif
Next I
If !OK
 Affzo [GCM1]
 Return
Endif
Return

$VERIF
[M]NBRLED = len(mess(0,2644,1))
J = 0
For I=0 To [M]NBRLED-1
 If [M:GCM1]LED(I)<>''
  J += 1 : Break
 Endif
Next I
If J=0
 # Vous devez définir au moins un référentiel
 GMESSAGE = mess(79,104,1)
 OK = 0 : Return
Endif

## contrôle qu'il n'y a un référetiel renseigné pour le référentiel général principal
If [M]LED([M]GENLEDTYP-1) = "" | [M]CFMAUT([M]GENLEDTYP-1)<>1
 # Vous devez saisir le référentiel général principal
 GMESSAGE = mess(117,104,1)
 OK = 0 : Return
Endif
## contrôle qu'il n'y a un référetiel renseigné pour le référentiel général analytique
If [M]LED([M]ANALEDTYP-1) = "" | [M]CFMAUT([M]ANALEDTYP-1)<>1
 # Vous devez saisir le référentiel analytique principal
 GMESSAGE = mess(118,104,1)
 OK = 0 : Return
Endif

## Contrôle qu'il n'y a pas plus de 5 devises de gestions différentes dans un modèle comptable
L=0 : Raz CURTAB
For I=0 To [M]NBRLED-1
 If !find([M]CUR(I),CURTAB(0..[M]NBRLED-1))
  CURTAB(I)=[M]CUR(I)
  L+=1
 Endif
Next
If L>5
 # Il ne doit pas y avoir plus de cinq devises de gestion différentes dans un modéle
 GMESSAGE = mess(86,104,1)
 OK = 0 : Return
Endif

## Contrôle que le nb d'axes saisissables est inférieur ou égal à GOPTCANA (nb d'axes max d'une
## société tous référentiels confondus)
X=0 : Raz DIETAB
For I=0 To [M]NBRLED-1
 Read [LED]LED0 = [M]LED(I)
 If !fstat
  For J=0 To [F:LED]DIENBR-1
   If !find([F:LED]DIE(J),DIETAB(0..X-1))
    DIETAB(X)=[F:LED]DIE(J)
    X+=1
   Endif
  Next
 Endif
Next
If X>GOPTCANA
 # nombre maximum d'axes dans un modèle
 GMESSAGE = num$(GOPTCANA)-":"-mess(87,104,1)
 OK = 0 : Return
Endif

If func AFNC.ACTIV("PJM")
 W=0
 If !clalev([LED2]) : Local File GLED [LED2] : Endif
 For I=0 To dim([M]LED)-1
  If  [M]CFMAUT(I)<>2
   Read [LED2]LED0 = [M]LED(I)
   # Exclure les référentiels automatiques
   If !fstat & [F:LED2]PJMFLG=2
    W+=1
   Endif
 Endif
 Next
 If W>1
  # Un seul référentiel peut être coché 'Gestion à l'affaire' par modèle.
  GMESSAGE = mess(173,104,1)
  OK=0 : Return
 Endif
Endif

Return

$INICRE
$INIMOD
If dim([F:GCM]DES)>0 : [F:GCM]DES = [M:GCM1]DESTRA : Endif
If func AFNC.ACTIV("LEG")=0 : [F:GCM]LEG = GDOSLEG(1) : Endif
If func AFNC.ACTIV("KRU")=0
 For I=0 To dim([F:GCM]DOELED)-1
  Raz [F:GCM]DOELED(I)
 Next
Endif
Return


$APRES_CRE
Call GLOBVAR From SETGLBGCM
Gosub RELIT From GOBJSUB
Return

$APRES_MOD
Call GLOBVAR From SETGLBGCM
Gosub RELIT From GOBJSUB
Return

$AP_CHANGE
#Class[M] à éviter car $AP_CHANGE peut être appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("GACM","DESTRA",[M]GCM,"",NCODE,"") From ATEXTRA
#Call CHGTEXTRA("GACM","SHOTRA",[M]GCM,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GACM","DESTRA",OCODE,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GACM","SHOTRA",OCODE,"",NCODE,"") From ATEXTRA
Call GLOBVAR From SETGLBGCM
Read [GCM]GCM0 = NCODE

# Issue X3-66254
   If GMODU(14) = [V]CST_AYES

    If clalev([F:RDE]) = 0 : Local File RUBASSDEF  [RDE] : Endif
    If clalev([F:RDP]) = 0 : Local File RUBASSDEFP [RDP] : Endif
    If clalev([F:RVA]) = 0 : Local File RUBASSVAL  [RVA] : Endif
    If clalev([F:RVP]) = 0 : Local File RUBASSVALP [RVP] : Endif

    Update [RDE] Where ACM = NCODE
&     With NUMASS = sum(num$([F:RDE]REFOBJ), num$([F:RDE]DETAAS), NCODE, [F:RDE]CPY)

    Update [RDP] Where ACM = NCODE
&     With NUMASS = sum(num$([F:RDP]REFOBJ), num$([F:RDP]DETAAS), NCODE, [F:RDP]CPY)

    Update [RVA] Where ACM = NCODE
&     With NUMASS = sum(num$([F:RVA]REFOBJ), num$([F:RVA]DETAAS), NCODE, [F:RVA]CPY)

    Update [RVP] Where ACM = NCODE
&     With NUMASS = sum(num$([F:RVP]REFOBJ), num$([F:RVP]DETAAS), NCODE, [F:RVP]CPY)

   Endif
# End Issue X3-66254

Return

$AP_ANNULE
Call GLOBVAR From SETGLBGCM
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GACM","DESTRA",CLECUR1,"","GACM","DESTRA",[M]GCM,"")  From ATEXTRA
 Call DUPTEXTRA("GACM","SHOTRA",CLECUR1,"","GACM","SHOTRA",[M]GCM,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GACM","DESTRA",[M]GCM,"") From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"GACM","SHOTRA",[M]GCM,"") From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("GACM","DESTRA",[M]GCM,"") From ATEXTRA
Call SUPTEXTRA("GACM","SHOTRA",[M]GCM,"") From ATEXTRA
Return


######################################################################################
## Etiquettes du mask GCM1
######################################################################################
Subprog AP_FLGIAS(VALEUR)
Variable Integer VALEUR
## Flag rajouté pour Abel : besoin de savoir pour Abel si l'IAS est géré et quel est le référentiel
## principal IAS
If VALEUR = 1
 If dim([M]IASLEDTYP)>0
  [M]IASLEDTYP = 0
  Grizo IASLEDTYP : Affzo IASLEDTYP
 Endif
Elsif dim([M]IASLEDTYP)>0
 Actzo IASLEDTYP
Endif
End

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG= VALEUR
End

Subprog D_CFMAUT(VALEUR)    # Référentiel auto. : les 2 types de référentiel principaux, l’initialiser à Non
Variable Integer VALEUR
Gosub SETNOL
If [M]GENLEDTYP=[M]LEDTYP(NOL) | [M]ANALEDTYP=[M]LEDTYP(NOL)
 VALEUR = 1
Else
 # Le référentiel d'origine n'est pas un référentiel automatique, donc si aucun ligne n'est renseignée comme "Référentiel auto" à Non,
 #  l'initialisation est automatique à "Non"
 For I=0 To dim([M]LEDTYP)-1
  If NOL<>I & [M:GCM1]CFMAUT(I)=1 & [M:GCM1]LED(I)<>""
   VALEUR = 2 : Break
  Else
   VALEUR = 1 : Break
  Endif
 Next
Endif
End

# Variable globale GLEDTYPAUT stock les référentiels dit 'Automatique'.
Subprog AS_CFMAUT(VALEUR)
Variable Integer VALEUR
Local Integer IND
# Gestion de la valeur 10
IND = instr(1,GLEDTYPAUT,"0")
If !IND
 If instr(1,GLEDTYPAUT,num$([M:GCM1]LEDTYP(nolign-1)))
  VALEUR = 2
 Endif
Else
 # Il y a un "0" dans le paramètre GLEDTYPAUT
 If [M:GCM1]LEDTYP(nolign-1)=10
  If mid$(GLEDTYPAUT,IND+1,1)="0" : VALEUR = 2 : Endif
 Elsif [M:GCM1]LEDTYP(nolign-1)=1
  # Possibilité, la valeur "1" qui précéde la valeur "10"... exemple : GLEDTYPAUT ="145610"
  If instr(1,left$(GLEDTYPAUT,IND-2),"1") : VALEUR = 2 : Endif
 Else
  If instr(1,GLEDTYPAUT,num$([M:GCM1]LEDTYP(nolign-1)))
   VALEUR = 2
  Endif
 Endif
Endif
End

Subprog AM_CFMAUT(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If VALEUR<>2
 Actzo [M]LED(NOL)
Endif
End

Subprog C_CFMAUT(VALEUR)
Variable Integer VALEUR
# Le référentiel d'origine n'est pas un référentiel automatique.
# L'utilisateur ne peut saisir "Référentiel auto" à Oui,  si c'est sa première saisie.
Gosub SETNOL
If VALEUR = 2
 ## Dem 55739 : Si 'Automatique', on vérifie que ce n'est pas un référentiel défini en tant que référentiel principal dans le modèle
 ## (général, analytique ou IAS).
 If [M]LEDTYP(NOL) = [M]GENLEDTYP
  ## Référentiel général principal
  GMESSAGE = (mess(143,104,1))
  mkstat = 2 : End
 Elsif [M]LEDTYP(NOL) = [M]ANALEDTYP
  ## Référentiel analytique principal
  GMESSAGE = (mess(144,104,1))
  mkstat = 2 : End
 Elsif dim([M]IASLEDTYP)>0 & [M]LEDTYP(NOL) = [M]IASLEDTYP
  ## Référentiel IAS principal
  GMESSAGE = (mess(145,104,1))
  mkstat = 2 : End
 Endif
 For I=0 To dim([M]LEDTYP)-1
  If NOL<>I & [M:GCM1]CFMAUT(I)=1
   Break
  Endif
 Next
 If I=dim([M]LEDTYP) : VALEUR=1 : mkstat=2 : Endif
Endif
End

Subprog AS_ORILEDTYP(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M:GCM1]CFMAUT(NOL)<>2
 mkstat = 1 : End
Endif
# Le référentiel d'origine n'est pas un référentiel automatique, FILTRE uniquement sur les réfétentiels flagués "Référentiel auto" à Non.
For I=0 To dim([M]LEDTYP)-1
 If [M:GCM1]CFMAUT(I)=2 | [M:GCM1]LED(I)=""
  GMENLOC([M]LEDTYP(I)) = 1
 Endif
Next
GMENLOC([M]LEDTYP(NOL)) = 1
End

Subprog C_ORILEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer VU
VU = find(VALEUR,[M]LEDTYP(0..[M]NBRLED-1))
If VU & [M]LED(VU-1) = ""
 # Pas de code référentiel saisi pour ce type de référentiel
 GMESSAGE = mess(97,104,1)
 mkstat = 2 : End
Endif
End

Subprog AM_ORILEDTYP(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
Local Integer VU
If [M]CFMAUT(NOL) = 2
 VU = find(VALEUR,[M]LEDTYP(0..[M]NBRLED-1))
 If VU
  [M]LED(NOL) = [M]LED(VU-1)
  Grizo [M]LED(NOL) : End
 Endif
Endif
End

Subprog AS_LED(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Integer VU
If [M]CFMAUT(NOL) = 2
 VU = find([M]ORILEDTYP(NOL),[M]LEDTYP(0..[M]NBRLED-1))
 If VU
  VALEUR = [M]LED(VU-1)
  Grizo [M]LED(NOL) : mkstat = 2 : End
 Endif
Elsif [M]CFMAUT(NOL) = 1
 Actzo [M]LED(NOL)
Else
 mkstat=1 : End
Endif

If [M]CFMAUT(NOL)<>2
 # Gestion de la valeur 10 sous le paramètre GLEDTYPAUT
 IND = instr(1,GLEDTYPAUT,"0")
 If !IND
  If instr(1,GLEDTYPAUT,num$(NOL+1))
   VALEUR = "" : mkstat = 1
  Endif
 Else
  # Il y a un "0" dans le paramètre GLEDTYPAUT
  If NOL+1=10
   If mid$(GLEDTYPAUT,IND-1,1)="1" :    VALEUR = "" : mkstat = 1 : Endif
  Elsif NOL+1=1
   # Possibilité, la valeur "1" qui précéde la valeur "10"... exemple : GLEDTYPAUT ="145610"
   If instr(1,left$(GLEDTYPAUT,IND-2),"1") :    VALEUR = "" : mkstat = 1 : Endif
  Else
    If instr(1,GLEDTYPAUT,num$(NOL+1))
     VALEUR = "" : mkstat = 1
    Endif
  Endif
 Endif
Endif
End

Subprog C_LED(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Integer VU
If clalev([F:LED]) = 0 : Local File GLED [LED] : Endif
If clalev([F:COA]) = 0 : Local File GCOA [COA] : Endif
If VALEUR=""
 If [M]GENLEDTYP = [M]LEDTYP(NOL)
  GMESSAGE = mess(117,104,1) : mkstat=2 : End
  # Vous devez saisir le référentiel général principal
 Endif
 If [M]ANALEDTYP = [M]LEDTYP(NOL)
  GMESSAGE = mess(118,104,1) : mkstat=2 : End
  # Vous devez saisir le référentiel analytique principal
 Endif
 If [M]CFMAUT(NOL)<>2 : [M]CFMAUT(NOL)=0 : Affzo  [M]CFMAUT(NOL) : Endif
Endif
Call LECTURE("LED",VALEUR,"") From CONTOBJ
## On bloque si le modèle comptable est multi-législations (GCURLEG="") et que le référentiel ou le plan
## de comptes (du référentiel) est associé à une législation pour éviter de se retrouver avec
## une société FRA, pointant sur un modèle comptable multi-législations et qui pointe sur un plan de compte
## BRI (pas cohérent et on ne peut pas contrôler dans la fiche société que chaque code plan et référentiel
## pointant sur le modèle comptable est associé à la bonne législation, ce serait lourd)
If GCURLEG = "" & [F:LED]LEG<>""
 ## Référentiel XXX : réservé à la législation
 GMESSAGE = mess(208,111,1)-VALEUR-"\"+mess(62,127,1)-":"-[F:LED]LEG
 mkstat = 2 : End
Endif
If [F:LED]LEG = ""
 Call LECTURE("COA",[F:LED]COA,"") From CONTOBJ
 If [F:COA]LEG<>"" & GCURLEG <> [F:COA]LEG
  ## Plan de comptes XXX : réservé à la législation
  GMESSAGE = mess(36,113,1)-[F:LED]COA-"\"+mess(62,127,1)-":"-[F:COA]LEG
  mkstat = 2 : End
 Endif
Endif
If [M]GENLEDTYP = [M]LEDTYP(NOL)
 If [F:LED]GEN<>2
  ## Le référentiel général principal doit être flagué 'Général'
  GMESSAGE = mess(109,104,1)
  mkstat = 2 : End
 Endif
 If [LED]BAL<>2 or [LED]FCYBAL<>2
  # Le référentiel général principal doit être flagué 'Equilibre' et 'Equilibre par sites'
  GMESSAGE = mess(128,104,1)
  mkstat = 2 : End
 Endif
 If [F:LED]MTCFLG<>2
  ## Le référentiel général principal doit être flagué 'Lettrage'
  GMESSAGE = mess(133,104,1)
  mkstat = 2 : End
 Endif
 Call LECTURE("COA",[F:LED]COA,"") From CONTOBJ
 If func AFNC.ACTIV("VAT") & [F:COA]TAXMGT<>2
  ## Le code plan du référentiel général principal doit être flagué 'Gestion de taxes'
  GMESSAGE = mess(110,104,1)
  mkstat = 2 : End
 Endif
 If [F:COA]AUX<>2
  ## Le code plan du référentiel général principal doit être flagué 'Auxiliarisation'
  GMESSAGE = mess(132,104,1)
  mkstat = 2 : End
 Endif
Endif
If [M]GENLEDTYP<>[M]ANALEDTYP and [M]ANALEDTYP = [M]LEDTYP(NOL)
 Call LECTURE("LED",VALEUR,"") From CONTOBJ
 If [F:LED]ANA<>2
  ## Le référentiel analytique principal doit être flagué 'Analytique'
  GMESSAGE = mess(119,104,1)
  mkstat = 2 : End
 Endif
Endif
If VALEUR<>""
 For I=0 To dim([M]LED)-1
  If I<>nolign-1 & [M]CFMAUT(I)<>2 & VALEUR=[M]LED(I)
   ## Déjà associé au type référentiel XXX ## Demande 55712
   GMESSAGE = VALEUR-":"-mess(142,104,1)-"'"+mess(I+1,2644,1)+"'"
   mkstat = 2 : Break
  Endif
 Next
Endif
If mkstat : End : Endif
# Dmd 64101 : Un seul Référentiel flagué Budget opérationnels par modèle
If func AFNC.ACTIV("GDD")
 If [F:LED]GDD=2
  For I=0 To dim([M]LED)-1
   If I<>NOL
    If !clalev([LED2]) : Local File GLED [LED2] : Endif
    Read [LED2]LED0 = [M]LED(I)
    # Exclure les référentiels automatiques
    If !fstat & [F:LED2]GDD=2 & [M]CFMAUT(I)<>2
     #Un seul référentiel gérant les budgets opérationnels par modèle
     GMESSAGE = mess(244,108,1)
     mkstat = 2 : Break
    Endif
   Endif
  Next
 Endif
Endif
If mkstat : End : Endif

If func AFNC.ACTIV("PJM")
 If [F:LED]PJMFLG=2
  If !clalev([LED2]) : Local File GLED [LED2] : Endif
  For I=0 To dim([M]LED)-1
   If I<>NOL & [M]CFMAUT(I)<>2
    Read [LED2]LED0 = [M]LED(I)
    # Exclure les référentiels automatiques
    If !fstat & [F:LED2]PJMFLG=2
     # Un seul référentiel peut être coché 'Gestion à l'affaire' par modèle.
     GMESSAGE = mess(173,104,1)
     mkstat = 2 : Break
    Endif
   Endif
  Next
 Endif
Endif
If mkstat : End : Endif

# En cas de modification... vérification des Référentiels Automatiques
If VALEUR <> [M]LED(NOL)
 For I=0 To dim([M]LED)-1
  If [M]CFMAUT(I) = 2  & [M]LEDTYP(NOL)=[M]ORILEDTYP(I)
   [M]LED(I)=VALEUR : Affzo [M]LED(I)
  Endif
 Next
Endif
End

Subprog AM_LED(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If VALEUR<>""
 Call REMPLACE([M]LED(NOL),VALEUR)
Elsif VALEUR = ""
 Call SUPP([M]LED(NOL))
Endif
End

Subprog REMPLACE(OLDLED,NEWLED)
Value Char OLDLED()
Value Char NEWLED()
Local Integer NOLI
For NOLI=0 To [M]NBRCTL-1
 If [M]LED1(NOLI) = OLDLED
  [M]LED1(NOLI) = NEWLED
 Elsif [M]LED2(NOLI) = OLDLED
  [M]LED2(NOLI) = NEWLED
 Endif
Next
Affzo LED1, LED2
End

Subprog SUPP(OLDLED)
Value Char OLDLED()
Local Integer NOLI
For NOLI=[M]NBRCTL To 0 Step-1
 If find(OLDLED,[M]LED1(NOLI),[M]LED2(NOLI))
  Dela NOLI, 1  LED1, LED2, CTLTYP
 Endif
Next
Affzo LED1, LED2, CTLTYP
End


Subprog AS_CUR(VALEUR)
Variable Char    VALEUR()
Gosub SAUTE_CHP
If mkstat : End : Endif

If dim([M]DOELED)>0 & [M]DOELED(NOL) = 2
 Local Integer VU
 VU = find([M]ORILEDTYP(NOL),[M]LEDTYP(0..[M]NBRLED-1))
 If VU
  VALEUR = [M]CUR(VU-1)
  Grizo [M]CUR(NOL) : mkstat = 2 : End
 Else
  Actzo [M]CUR(NOL)
 Endif
Endif
End

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Gosub SETNOL
If [M]CFMAUT(NOL) <> 2
 Call CONTDEV(VALEUR,date$) From TRTDEV
 If mkstat
  Raz GMESSAGE, mkstat
  OK = 2 : Call AVERTIR(mess(95,107,1),OK) From GESECRAN  :# Attention saisie en devise in
  If OK<>2 : mkstat = 2 : End : Endif
 Endif
Endif
End

Subprog AS_DOELED(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]CFMAUT(NOL)<>2
 mkstat = 1 : End
Endif
End

Subprog AM_DOELED(VALEUR)
Variable Integer VALEUR
Local Integer VU
Gosub SETNOL
If VALEUR = 2
 If clalev([F:LED]) = 0 : Local File GLED [LED] : Endif
 Call LECTURE("LED",[M]LED(NOL),"") From CONTOBJ
 # Le référentiel "Partie-Double" doit être coché "Stockage des imputations vide"
 If [F:LED]DIEIPT<>2
  # Le référentiel doit être flagué 'Stockage des impuatations vide'
  GMESSAGE = mess(155,104,1)
  mkstat = 2 : End
 Endif

 VU = find([M]ORILEDTYP(NOL),[M]LEDTYP(0..[M]NBRLED-1))
 If VU
  [M]CUR(NOL) = [M]CUR(VU-1)
  Affzo [M]CUR(NOL)
  Grizo [M]CUR(NOL)
 Else
  Actzo [M]CUR(NOL)
 Endif
 [M]RNDOPTBAL(NOL) = 2
 Affzo [M]RNDOPTBAL(NOL)
 Grizo [M]RNDOPTBAL(NOL)
Else
 Actzo [M]CUR(NOL)
 Actzo [M]RNDOPTBAL(NOL)
Endif
End

Subprog AS_DACRAT(VALEUR)
Variable Integer VALEUR
Gosub SAUTE_CHP

# Initialisation demandée liée au contrôle...
Gosub SETNOL
For I=0 To [M]NBRLED-1
 If I<>NOL
  If [M]LED(I)<>"" & [M]CUR(I)=[M]CUR(NOL) & [M]FLGVCRRAT(I)=[M]FLGVCRRAT(NOL)
   Break
  Endif
 Endif
Next
If I<dim([M]DACRAT) : VALEUR = [M]DACRAT(I) : Endif
End

Subprog C_DACRAT(VALEUR)
Variable Integer VALEUR
#### si X référentiels sont associés à la même devise de gestion et ont le flag 'Type cours pièce' à 'Oui'
#### alors ces X référentiels doivent avoir le même mode de saisie cours (car en saisie de pièce il y aura
### qu'une seule saisie du cours pour ces x référentiels, donc qu'un seul mode de saisie)
Gosub SETNOL
Local Integer I, OK, WDACRAT
OK  = 0
For I=0 To [M]NBRLED-1
 If I<>NOL
  If [M]CUR(I)=[M]CUR(NOL) & [M]FLGVCRRAT(I)=[M]FLGVCRRAT(NOL) & [M]DACRAT(I)<>VALEUR
   ## Mode de saisie cours incompatible avec le type de référentiel XXX. Modifier le mode de saisie cours ?
   WDACRAT = [M]DACRAT(I)
   OK = 2 : Call AVERTIR(mess(99,104,1)-mess([M]LEDTYP(I),2644,1)-"\"+mess(100,104,1),OK) From GESECRAN
   Break
  Endif
 Endif
Next
If OK
 If OK=2
  For I=0 To [M]NBRLED-1
   If [M]LED(I)<>"" & [M]CUR(I)=[M]CUR(NOL) & [M]FLGVCRRAT(I)=[M]FLGVCRRAT(NOL)
    [M]DACRAT(I)=VALEUR
    Affzo [M]DACRAT(I)
   Endif
  Next
 Elsif OK=1
  VALEUR = WDACRAT
  mkstat = 2 : End
 Endif
Endif
End

Subprog D_FLGVCRRAT(VALEUR)    # Type cours doc. : les 2 types de référentiel principaux, l’initialiser à Oui
Variable Integer VALEUR
Gosub SETNOL
If GENLEDTYP=[M]LEDTYP(NOL) | ANALEDTYP=[M]LEDTYP(NOL)
 VALEUR = 2
Endif
End

Subprog AS_FLGVCRRAT(VALEUR)
Variable Integer VALEUR
Gosub SAUTE_CHP
If mkstat : End : Endif
# Force le Type de cours doc. à oui sur le types de référentiel général principal (60281)
If GENLEDTYP=[M]LEDTYP(NOL)
 VALEUR = 2 : mkstat = 2 : End
Endif
End

Subprog AS_TYPRAT(VALEUR)
Variable Integer VALEUR
Gosub SAUTE_CHP
Gosub SAUTE_CHP2
End

Subprog D_RNDOPTBAL(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
# Option d'équilibrage : pour le référentiel général principal, proposer Ecarts d’arrondis plutôt que Saupoudrage
If GENLEDTYP=[M]LEDTYP(NOL)
 VALEUR = 2
Endif
End

Subprog AS_RNDOPTBAL(VALEUR)
Variable Integer VALEUR
Gosub SAUTE_CHP
If clalev([F:LED]) = 0 : Local File GLED [LED] : Endif
Call LECTURE("LED",[M]LED(nolign-1),"") From CONTOBJ
If [F:LED]BAL<>2 : mkstat = 1 : End : Endif
# Option d'équilibrage : pour le référentiel "Partie Double", force Ecarts d’arrondis
If dim([M]DOELED)>0 & [M]DOELED(nolign-1)=2
 VALEUR = 2 : mkstat=2 : End
Endif
End

################### Tableau Contrôle ########################
Subprog AS_LED2(VALEUR)
Variable Char    VALEUR()
Gosub SAUTE_CHP3
End

Subprog AS_CTLTYP(VALEUR)
Variable Char    VALEUR()
Gosub SAUTE_CHP3
End

Subprog C_LED1(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
 #  Zone obligatoire
 GMESSAGE = mess(00010,00123,1)
 mkstat = 2 : End
Else
 Call ISINMODELE(VALEUR)
Endif
End

Subprog C_LED2(VALEUR)
Variable Char    VALEUR()
Call ISINMODELE(VALEUR)
Gosub SETNOL
If [M]LED1(NOL)<>'' & VALEUR =''
 #  Zone obligatoire
 GMESSAGE = mess(00010,00123,1)
 mkstat = 2 : End
Elsif [M]LED1(NOL)<>'' & [M]LED1(NOL) = VALEUR
 # Le référentiel 2 doit être différent du référentiel 1
 GMESSAGE = mess(85,104,1)
 mkstat = 2 : End
Endif
End

Subprog C_CTLTYP(VALEUR)
Variable Char    VALEUR()
Local Char LET1(2),LET2(2)
Local Integer OK
Gosub SETNOL
If [M]LED1(NOL)<>'' & VALEUR =''
 #  Zone obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Endif
#-- La lettre doit correspondre à une valeur de contrôle (liste sous le menu 2235)
For I=1 To len(VALEUR)
 LET1 = mid$(VALEUR,I,1)
 Raz OK
 For J=1 To len(mess(0,2235,1))
  LET2 = mid$(mess(0,2235,1),J,1)
  If LET2 = LET1 : OK=1 : Break : Endif
 Next
 If !OK : Break : Endif
Next
If !OK
 #  Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Endif
#-- Pas de doublon
OK = 1
For I=1 To len(VALEUR)
 LET1 = mid$(VALEUR,I,1)
 For J=I+1 To len(VALEUR)
  LET2 = mid$(VALEUR,J,1)
  If LET2 = LET1 : Raz OK : Break 2 : Endif
 Next
Next
If !OK
 #  Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Endif
End

Subprog ISINMODELE(VALEUR)
Variable Char VALEUR()
If !find(VALEUR,[M:GCM1]LED(0..[M:GCM1]NBRLED-1))
 # Ce référentiel n'est pas défini dans le modèle
 GMESSAGE = mess(98,104,1)
 mkstat=2 : End
Endif
End

$SEL_LISTE
Case LISTE
 When "SELLEDGCM" : Gosub SEL_LED
 When "GCMSELOPT" : Gosub SEL_OPT
Endcase
Return

$SEL_LED
Local Char TEXTE(GLONDES)(1..10,1..2)
For I=0 To [M:GCM1]NBRLED-1
 If [M:GCM1]LED(I)<>"" &  [M:GCM1]CFMAUT(I)=1
  NBTEX += 1
  TEX(NBTEX) = [M:GCM1]LED(I)
  TEXTE(NBTEX,1) = [M:GCM1]LED(I)
  TEXTE(NBTEX,2) = mess([M:GCM1]LEDTYP(I),2644,1)
 Endif
 TIT(0) = mess(12,123,1)  # Choix
 Call TITOBJ("LED","",TIT(1)) From CONTOBJ
 TIT(0) -= TIT(1)
 TIT(2) = mess(82,123,1)  # Intitulé
Next
Return

$SEL_OPT
Local Char  OOPT(30) : OOPT = VALEUR
For I=1 To len(mess(0,2235,1))
 NBTEX += 1
 TEX(NBTEX) = chr$(64+NBTEX)
 TEXTE(NBTEX) = chr$(64+NBTEX)-mess(NBTEX,2235,1)
Next
TIT(0) = mess(12,123,1)  # Choix
Return

$VERF_LISTE
Case LISTE
 When "GCMSELOPT" : Gosub VERF_OPT
Endcase
Return

$VERF_OPT
If !instr(1,OOPT,VALEUR)
 OOPT += VALEUR
Endif
VALEUR = OOPT
Return

########################################
Subprog B3_CTLTYP(VALEUR)
Variable Char    VALEUR()
Local Char LST_CTL(250)
For I=1 To len(mess(0,2235,1))
 LST_CTL  += chr$(64+I)-mess(I,2235,1)-"\"
Next
Call MESSAGE(LST_CTL) From GESECRAN
End


########################################################
$SAUTE_CHP
Gosub SETNOL
If [M:GCM1]CFMAUT(NOL)<>2 & [M:GCM1]LED(NOL)="" : # signifie qu'on ne gère pas ce type de référentiel
 mkstat = 1 : End
Endif
Return

$SAUTE_CHP2
Gosub SETNOL
If [M:GCM1]FLGVCRRAT(NOL)=2
 mkstat = 1 : End
Endif
Return

$SAUTE_CHP3
Gosub SETNOL
If [M:GCM1]LED1(NOL)=""
 mkstat = 1 : End
Endif
Return

Subprog AS_GENLEDTYP(VALEUR)
Variable Integer VALEUR
Gosub LISTE
End

Subprog AS_ANALEDTYP(VALEUR)
Variable Integer VALEUR
Gosub LISTE
End

Subprog AS_IASLEDTYP(VALEUR)
Variable Integer VALEUR
Gosub LISTE
End

Subprog C_IASLEDTYP(VALEUR)
Variable Integer VALEUR
If VALEUR = [M]GENLEDTYP
 ## Le référentiel IAS principal doit être différent du référentiel général principal
 GMESSAGE = mess(146,104,1)
 mkstat = 2 : End
Elsif VALEUR = [M]ANALEDTYP
 ## Le référentiel IAS principal doit être différent du référentiel analytique principal
 GMESSAGE = mess(147,104,1)
 mkstat = 2 : End
Endif
End

$LISTE
Local Integer NBLED
Local Integer TYPREF
For NBLED=1 To len(GLEDTYPAUT)
 TYPREF = val(mid$(GLEDTYPAUT,NBLED,1))
 # Gestion de la valeur 10
 If TYPREF=1 &  mid$(GLEDTYPAUT,NBLED+1,1)="0"
  GMENLOC(10) = 1
 Else
  GMENLOC(TYPREF) = 1
 Endif
Next
Return

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

