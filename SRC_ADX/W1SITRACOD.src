Subprog AS_CAR1(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_CAR1(VALEUR) From SUBSITC
If mkstat=2
 [M]CAR1(INDIC) = VALEUR
 Affzo CAR1(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

