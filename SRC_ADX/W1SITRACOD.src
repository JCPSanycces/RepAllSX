$ON_TRAFLG
Onevent INIT_AREA Call D_TRAFLG(zc) From W1SITRACOD
Onevent BEFORE_INPUT Call AS_TRAFLG(zc) From W1SITRACOD
Return

Subprog D_TRAFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]TRAFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TRAFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$TIT_COL
Local Char TITCL(200)(1..1)
Raz TITCL
Case BASPAG
 When "NBCAR"
  TITCL(1) = mess(SI_PRODUIT,2902,1)
  If !GORITITCOL
   Titcol [M]NBCAR TITCL(1) For CAR2
  Else
   Titcol [M:SITC]NBCAR TITCL(1) For CAR2
  Endif
Endcase
Return

$CHG_STY
Return


