#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SITRACOD 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:28"
A_USER  = "DOC"
A_STAMP = "20181109230628"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
 When "NBCAR"
  If [M]NBCAR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask SITRACOD [SITC]
Gosub HORODAT
Local Inpbox "SITRACOD" From GFONCTION At A_STAMP With A_WINDPREV Mask [SITC] As [SIM_]
Grizo [SITC]5
Grizo [SITC]10
Grizo [SITC]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [SITC]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=84 : Y1(0)=1 : Y2(0)=28
X1(1)=85 : X2(1)=112 : Y1(1)=1 : Y2(1)=24
X1(2)=85 : X2(2)=112 : Y1(2)=25 : Y2(2)=28
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1SITRACOD
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(5562,GBOUT1) From OBJDIV
Call TEXTE(28988,GBOUT2) From OBJDIV
Call TEXTE(28989,GBOUT3) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1SITRACOD
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1SITRACOD
Onkey 131 Titled GBOUT3 Call B3_NBLIG From W1SITRACOD
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action SITRAFIL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SITRAFIL"
 PARMSK(1) = num$(nolign-1)
 PARMSK(2) = "1"
 Call SAISIE_NUM(BASPAG,PARMSK,"SITRAFIL","SUBSITF","SPESITF") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B2_NBLIG From SUBSITC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B3_NBLIG From SUBSITC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_EXIFLG
Onevent INIT_AREA Call D_EXIFLG(zc) From W1SITRACOD
Return

Subprog D_EXIFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]EXIFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_VALID
Onevent BEFORE_INPUT Call AS_VALID(zc) From W1SITRACOD
Onevent CONTROL Call C_VALID(zc) From W1SITRACOD
Onevent INIT_AREA Call D_VALID(zc) From W1SITRACOD
Return

Subprog D_VALID(VALEUR)
Variable Integer VALEUR
If varinit([M]VALID,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_VALID(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_VALID(VALEUR) From SUBSITC
If mkstat=2
 [M]VALID(INDIC) = VALEUR
 Affzo VALID(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_VALID(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_VALID(VALEUR) From SUBSITC
If mkstat : GERR = 1 : GZONE = "VALID" : GZNUM = 29119 : Endif
Gosub _AFF
End

$ON_INTCNDA
Onevent INIT_AREA Call D_INTCNDA(zc) From W1SITRACOD
Return

Subprog D_INTCNDA(VALEUR)
Variable Char    VALEUR()
If varinit([M]INTCNDA,indice)=0
 VALEUR = SI_MES([F:SIR]INTCND)
Endif
Gosub _AFF
End

