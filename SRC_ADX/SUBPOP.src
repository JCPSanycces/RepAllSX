Subprog AM_POP(VALEUR)
Variable Char    VALEUR()

  Read [F:HRPOP]POP0=VALEUR
  If !fstat Then
    [M:POP1]POPLEG(nolign-1)=[F:HRPOP]LEG
    Affzo [M:POP1]POPLEG(nolign-1)
  Endif
End


######################################################################################
#MABOS-11/12/12-US 1036
# Faire la liste des populations auquelles appartient la population courante

Funprog POP_HIERARCHIE(WPOP)
Value Char WPOP
Local Char LIST_HIERAR(250)
MAXNIV = 10
Local Char    TBLISTPOP(GLONPOP)(0..MAXNIV,1..50)
Local Char    POPUL2(GLONPOP)(0..MAXNIV)
Local Integer NB2(0..MAXNIV) , PT2(0..MAXNIV), NIV2

Local Integer WI      :# MABOS- 22/01/13 - FQ81085-US1215 - ADD HIERARCHY IN POPULATION
Local Char SEPAR(2)   :# MABOS- 22/01/13 - FQ81085-US1215 - ADD HIERARCHY IN POPULATION

  If clalev([F:POBW])=0    : Local File POPULB           [POBW]   : Endif
  LIST_HIERAR=""
  NIV2 = 1
  POPUL2(NIV2) = WPOP
  Gosub HIERAR2
  # garder ce code au cas où
  # In Case we want only a liste of populations without hierarchy
  #Local Char WLISTE(250)
  #Local Integer WLONG , WLON2
  #  WLONG2=0
  #  While WLONG<>WLONG2 & len(LIST_HIERAR) > 0 & instr(len(LIST_HIERAR)-1,LIST_HIERAR,"~")
  #    LIST_HIERAR=left$(LIST_HIERAR,instr(len(LIST_HIERAR)-1,LIST_HIERAR,"~")-1)
  #    WLONG2=len(LIST_HIERAR)
  #  Wend
Raz TBLISTPOP, POPUL2,NB2,PT2

End LIST_HIERAR


$HIERAR2
  NB2(NIV2) = 0
  For [F:POBW]POB1 Where POP=POPUL2(NIV2)
    NB2(NIV2) += 1
    TBLISTPOP(NIV2,NB2(NIV2)) = [F:POBW]COD
  Next
  PT2(NIV2) = 1
  While PT2(NIV2)<=NB2(NIV2)
  # garder ce code au cas où
  # In Case we want only a liste of populations without hierarchy
  #  WLISTE = "~"-LIST_HIERAR-"~"
  #  WCODE = "~"-TBLISTPOP(NIV2,PT2(NIV2))-"~"
  #  If LIST_HIERAR = "" | (LIST_HIERAR <>"" &  TBLISTPOP(NIV2,PT2(NIV2))<>""  & !instr(0, WLISTE,WCODE)) Then
  #    If LIST_HIERAR <>"" Then LIST_HIERAR    -= "~" :Endif
    # MABOS- 22/01/13 - FQ81085-US1215 - ADD HIERARCHY IN POPULATION
      If PT2(NIV2)=1 Then :[L]SEPAR ="<" :Else: [L]SEPAR ="~" :Endif
      If LIST_HIERAR <>"" Then LIST_HIERAR    -= [L]SEPAR :Endif
      If [L]SEPAR ="~" Then
          For [L]WI=1 To NIV2-1
          LIST_HIERAR -= TBLISTPOP([L]WI,PT2([L]WI))-"<"
          Next
      Endif
      LIST_HIERAR -= TBLISTPOP(NIV2,PT2(NIV2))
   # Endif
   # end MABOS- 22/01/13 - FQ81085-US1215 - ADD HIERARCHY IN POPULATION
    POPUL2(NIV2+1) = TBLISTPOP(NIV2,PT2(NIV2))
    NIV2 += 1
    Gosub HIERAR2
    If GOK<1 : Break : Endif
   # LIST_HIERAR -= "~" :# MABOS- 22/01/13 - FQ81085-US1215 - ADD HIERARCHY IN POPULATION
    NIV2 -= 1
    PT2(NIV2) += 1
  Wend
Return

