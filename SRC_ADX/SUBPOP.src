Subprog TUNPOP(COD)
Variable Char    COD()

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONSRV)
 TOKILL = 1
Endif
If clalev([F:HRPOP])=0 : Local File POPUL [HRPOP] : Endif
# To update the PRF code after the tunnel order
VCOD = COD
If VCOD="" & GLECOBJ=2
#If no code is specified, it's better to select one of the curent legislation
  Filter [HRPOP] Where LEG=GCURLEG
  Read [F:HRPOP] First
  Filter [HRPOP]
  If !fstat : VCOD=[F:HRPOP]COD : Endif
Else
  Read [HRPOP]POP0 = VCOD
Endif
Call OBJET("POP",VCOD,GCURLEG) From GOBJET
COD = VCOD
If TOKILL : Kill VCOD : Endif
End
#JOJAC - 2016-08-02 - X3PEOP-736 - END

