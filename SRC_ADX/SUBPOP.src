#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management POP
##############################################################################################
##            SUBPOP
##
##   MABOS - 22/01/13 - FQ81085-US1215 - ADD HIERARCHY IN POPULATION
##   MABOS - 08/03/13 - FQ81085-US1332 - generic rules in GENCEV
##   MABOS  -25/03/13 - Bug 88758 : do not active MAJPOP if other Mask DIA already opened
##   MABOS - 09/04/13 - FQ 88316 - US1528 - SEL_TABLE - on F12, select the code already in the field
##   MABOS - 11/04/13 - FQ81085 - US1536 - add controls in order to not allow populations
#                                          and sub populations with different legislations.
##############################################################################################
Raz GPILOBJ
Call OBJET("POP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "LIENS"       : Gosub LIENS
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "GAUCHE"      : Gosub GAUCHE
 When "TRT_DIV"     : Gosub TRT_DIV
 When "RAZCRE"      : Gosub RAZCRE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "EXEBOUT"     : Gosub EXEBOUT
 When "SETBOUT"     : Gosub SETBOUT
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
# When "APRES_MODIF" : Gosub APRES_MODIF
 #SEGAY US1840 81085 20/08/2013 action envoyée de SELEMPCTR
 When "BAS_CTRNUM"  : Gosub BAS_CTRNUM From TOOLSHRLEG
Endcase
Return

$LIENS
nolign = 0
For [HRPOA]POA0 Where COD=[F:HRPOP]COD & TYP=0
 nolign += 1
 [M]REFNUM(nolign-1) = [F:HRPOA]REFNUM
 Read [ID]ID0 = [F:HRPOA]REFNUM
 [M]NAM(nolign-1) = [F:ID]NAM-[F:ID]SRN
 # FQ81085 - US1915 - MABON 25/10/12 - Ajout contrat+date dans les populations
 [M]CTRNUM(nolign-1) = [F:HRPOA]CTRNUM
 [M]CTRDAT(nolign-1) = [F:HRPOA]CTRDAT
 [M]CTRLEG(nolign-1) = func TOOLSHRLEG.LEGHRCTRDAT([F:HRPOA]REFNUM,[F:HRPOA]CTRNUM,[F:HRPOA]CTRDAT)
 # Fin MABON
 # 46861
 [M]MAJTYP(nolign-1) = [F:HRPOA]MAJTYP
Next
[M]NBRMAT = nolign
nolign = 0
If clalev ([F:HRPOP2])=0 : Local File POPUL [HRPOP2] : Endif
For [POB]POB0 Where COD=[F:HRPOP]COD
 nolign += 1
 [M]POP(nolign-1) = [F:POB]POP
 # FQ81085 - MABON 30/10/12 - New field LEG in subpopulations
 Read [F:HRPOP2]POP0=[F:POB]POP
 [M]POPLEG(nolign-1) = [F:HRPOP2]LEG
 # End MABON
Next
[M]NBRPOP = nolign
# FQ81085 - MABON 25/06/12 - New field LEG
GCURLEG = [F:HRPOP]LEG
#If [M]NBRMAT>0 | [M]NBRPOP>0
#    Grizo [M]LEG
#  Else
#    Actzo [M]LEG
#Endif
# End MABON
Return

$OUVRE
Local Integer BROWMAT
Local Char    BOXMAT(10)
Gosub OUVRE From WPDEFTABLE
Gosub DEFPOP
Local Char CRITPOP(250)
# FQ81085 - MABON 25/06/12 - New field LEG
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
# End MABON
Return

$FERME
# FQ81085 - MABON 25/06/12 - New field LEG
Gosub SAVE_GLEGFIL From TOOLSHRLEG
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# End MABON
Return

$OUVRE_BOITE
#BROWMAT = find("EM2",OBJLIS(1..8)) : BOXMAT = "GAU_CHE"+num$(BROWMAT)
BROWMAT = find("CT2",OBJLIS(1..8)) : BOXMAT = "GAU_CHE"+num$(BROWMAT)
Return

$DEFPOP
Local Integer ERR
Local Integer MAXNIV
MAXNIV = 10
Local Integer NB(0..MAXNIV) , PT(0..MAXNIV)
Local Char    POPUL(GLONPOP)(0..MAXNIV) , CODPOP(GLONPOP)
Local Char    TBPOP(GLONPOP)(0..MAXNIV,1..50)
Local Integer NB2(0..MAXNIV) , PT2(0..MAXNIV)
Local Char    POPUL2(GLONPOP)(0..MAXNIV) , CODPOP2(GLONPOP)
Local Char    TBPOP2(GLONPOP)(0..MAXNIV,1..50)
Return

$MODIF
Delete [HRPOA] Where COD=[F:HRPOP]COD
If fstat=1
 GOK = -1 : GLOCK = "$POPULA"-[F:HRPOP]COD : Return
Endif
Delete [POB] Where COD=[F:HRPOP]COD
If fstat=1
 GOK = -1 : GLOCK = "$POPULB"-[F:HRPOP]COD : Return
Endif
Gosub CREATION
Return

$RAZCRE

  GCURLEG=""
Return

$CREATION
# Employés niveau 0
For nolign=1 To [M]NBRMAT
 [F:HRPOA]COD    = [F:HRPOP]COD
 [F:HRPOA]REFNUM = [M]REFNUM(nolign-1)
 # FQ81085 - US915 - MABON 25/10/12 - Ajout contrat+date dans les populations
 [F:HRPOA]CTRNUM = [M]CTRNUM(nolign-1)
 [F:HRPOA]CTRDAT = [M]CTRDAT(nolign-1)
 # Fin MABON
 [F:HRPOA]TYP    = 0
 # 46861
 # 29593
 #[F:POA]MAJTYP = 2 : # Manuelle
 [F:HRPOA]MAJTYP = [M]MAJTYP(nolign-1)
 If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
 If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
 If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
 Write [HRPOA]
 If fstat
  GOK = 0 : Call FSTA("HRPOA") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
# Sous-groupes
For nolign=1 To [M]NBRPOP
 [F:POB]COD = [F:HRPOP]COD
 [F:POB]POP = [M]POP(nolign-1)
 If dim([F:POB]CREDAT)>0 : [F:POB]CREDAT = date$ : Endif
 If dim([F:POB]CREUSR)>0 : [F:POB]CREUSR = GUSER : Endif
 If dim([F:POB]CRETIM)>0 : [F:POB]CRETIM = time  : Endif
 Write [POB]
 If fstat
  GOK = 0 : Call FSTA("POB") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
CODPOP = [F:HRPOP]COD
Gosub GENPOP
Return

$GENPOP
# FQ85451 US904 - MABON 08/11/12 - Manage only the employee concerned by the update, if it is the case
If dim(CRITERE_REF)<0 Then Local Char CRITERE_REF : Endif
If CRITERE_REF="" Then CRITERE_REF="1=1" : Endif
# End MABON
Gosub GENERE
If GOK<1 : Return : Endif
NIV2 = 0
POPUL2(NIV2) = CODPOP
Gosub CRENIV2
If GOK<1 : Return : Endif
Return

$CRENIV2
If GOK<1 : Return : Endif
If ERR or NIV2>=MAXNIV
 ERR = 1
 Return
Endif
NB2(NIV2) = 0
For [POB]POB1 Where POP=POPUL2(NIV2)
 NB2(NIV2) += 1
 TBPOP2(NIV2,NB2(NIV2)) = [F:POB]COD
Next
PT2(NIV2) = 1
While PT2(NIV2)<=NB2(NIV2)
 CODPOP = TBPOP2(NIV2,PT2(NIV2))
 Gosub GENERE
 If GOK<1 : Break : Endif
 POPUL2(NIV2+1) = CODPOP
 NIV2 += 1
 Gosub CRENIV2
 If GOK<1 : Break : Endif
 NIV2 -= 1
 PT2(NIV2) += 1
Wend
Return

$GENERE
# Employés des sous-groupes
# FQ85451 US904 - MABON 08/11/12 - Manage only the employee concerned by the update, if it is the case
If dim(CRITERE_REF)<0 Then Local Char CRITERE_REF : Endif
If CRITERE_REF="" Then CRITERE_REF="1=1" : Endif
#Delete [HRPOA] Where COD=CODPOP & TYP>0
Delete [HRPOA] Where COD=CODPOP & TYP>0 & evalue(CRITERE_REF)
# End MABON
If fstat=1
 GOK = -1 : GLOCK = "$POPULA"-CODPOP : Return
Endif
ERR = 0
NIV = 0
POPUL(NIV) = CODPOP
Gosub CRENIV
If ERR
 GMESSAGE = "Trop de niveaux imbriqués"
 GOK = 0 : Return
Endif
Return

$CRENIV
If GOK<1 : Return : Endif
If ERR or NIV>=MAXNIV
 ERR = 1
 Return
Endif
If NIV>0
 ## On crée 1 enreg. dans POPULA pour chaque salarié qui appartient à une sous-population de la population.
 ## Ces enregistrements ont dans TYP le niveau où se trouve la s/population et dans COD la population.
 # FQ85451 US904 - MABON 08/11/12 - Manage only the employee concerned by the update, if it is the case
 If dim(CRITERE_REF)<0 Then Local Char CRITERE_REF : Endif
 If CRITERE_REF="" Then CRITERE_REF="1=1" : Endif
# For [HRPOA]POA0 Where COD=POPUL(NIV) & TYP=0
 For [HRPOA]POA0 Where COD=POPUL(NIV) & TYP=0 & evalue(CRITERE_REF)
 # End MABON
  [F:HRPOA]COD    = CODPOP
  [F:HRPOA]REFNUM = [F:HRPOA]REFNUM
  # FQ81085 - US915 - MABON 25/10/12 - Ajout contrat+date dans les populations
  [F:HRPOA]CTRNUM = [F:HRPOA]CTRNUM
  [F:HRPOA]CTRDAT = [F:HRPOA]CTRDAT
  # Fin MABON
  [F:HRPOA]TYP    = NIV
  # 29593
  [F:HRPOA]MAJTYP = [F:HRPOA]MAJTYP
  If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
  If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
  If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
  Write [HRPOA]
  If fstat=3
#  C'est un doublon, on s'en fiche
  Elsif fstat
   GOK = 0 : Call FSTA("HRPOA") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Return : Endif
Endif
NB(NIV) = 0
For [POB]POB0 Where COD=POPUL(NIV)
 NB(NIV) += 1
 TBPOP(NIV,NB(NIV)) = [F:POB]POP
Next
PT(NIV) = 1
While PT(NIV)<=NB(NIV)
 POPUL(NIV+1) = TBPOP(NIV,PT(NIV))
 NIV += 1
 Gosub CRENIV
 NIV -= 1
 PT(NIV) += 1
Wend
Return

# FQ81085 - MABON 22/06/12 - Navigate in the records, taking GLEGFIL into account
$FILPOP

  CRITPOP="1=1"
  If GLEGFIL<>""
    If CRITPOP<>"" Then CRITPOP-="&" : Endif
    CRITPOP -= "(find([F:HRPOP]LEG,'"+GLEGFIL+"','')>0)"
  Endif
  Filter [HRPOP] Where evalue(CRITPOP)
Return

$APRES_CHOI

#  Case REPONSE
#    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
#      Gosub FILPOP
#      If REPONSE=GSTASUI Then Read [HRPOP]POP0 > [M:POP1]COD  : Endif
#      If REPONSE=GSTAPRE Then Read [HRPOP]POP0 < [M:POP1]COD  : Endif
#      If REPONSE=GSTAFIR Then Read [HRPOP]POP0 First          : Endif
#      If REPONSE=GSTALAS Then Read [HRPOP]POP0 Last           : Endif
#      Filter [HRPOP]
#      Gosub SUIVPREC From TOOLSHRLEG
#  Endcase
Return
# End MABON

# FQ81085 - MABON 22/06/12 - Filter left list
$FILGAUCHE

  If GLEGFIL<>""
    If FILGAUCHE<>"" :FILGAUCHE-="&" : Endif
    FILGAUCHE -= "(find([F:HRPOP]LEG,'"+GLEGFIL+"','')>0)"
    If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
    FILGAUSUP += "(find([F:HRPOP]LEG,'"+GLEGFIL+"','')>0)"
  Endif
Return
# End MABON

$GAUCHE
Local Integer EXISTLINE
Case currbox
 When BOXMAT
#  If [M]NBRMAT<dim([M]REFNUM) & !find([F:ID]REFNUM,[M]REFNUM(0..[M]NBRMAT-1))
#   Read [ID]ID0 =
#   OK = 0
#   Case REP
#    When "C","M","D"
#     OK = 1
#    When ""
#     If CLECUR & VERROU & ACTMOD & !GCONSULT
#      OK = 1
#     Endif
#   Endcase
#   If OK
#    mkstat = 0
#    nolign = [M]NBRMAT+1
#    [M]REFNUM([M]NBRMAT)    = [F:ID]REFNUM
#    [M]NAM([M]NBRMAT) = [F:ID]NAM-[F:ID]SRN
#    [M]NBRMAT += 1
#    Affzo REFNUM(nolign-1),NAM(nolign-1)
#    If REP=""
#     Gosub ENTRE_MODIF From GOBJSUB
#    Endif
#   Endif
#  Endif

  If [M]NBRMAT<dim([M]REFNUM) Then
    EXISTLINE=1
    For I=0 To [M]NBRMAT-1
      If [F:HRCTR]REFNUM=[M]REFNUM(I) & [F:HRCTR]CTRNUM=[M]CTRNUM(I) & [F:HRCTR]CTRDAT=[M]CTRDAT(I) Then
        EXISTLINE=2 : Break
      Endif
    Next
    If EXISTLINE=1 Then
      Read [HRCTR]CTR0 =
      OK = 0
      Case REP
        When "C","M","D"
          OK = 1
        When ""
          If CLECUR & VERROU & ACTMOD & !GCONSULT
            OK = 1
          Endif
      Endcase
      If OK
        mkstat = 0
        nolign = [M]NBRMAT+1
        [M]REFNUM([M]NBRMAT)  = [F:HRCTR]REFNUM
        Read [F:ID]ID0=[F:HRCTR]REFNUM
        [M]NAM([M]NBRMAT)     = [F:ID]NAM-[F:ID]SRN
        [M]CTRNUM([M]NBRMAT)  = [F:HRCTR]CTRNUM
        [M]CTRDAT([M]NBRMAT)  = [F:HRCTR]CTRDAT
        [M]MAJTYP([M]NBRMAT)  = 2 : # Manuelle
        [M]NBRMAT += 1
        Affzo REFNUM(nolign-1),NAM(nolign-1),CTRNUM(nolign-1),CTRDAT(nolign-1),MAJTYP(nolign-1)
        If REP=""
          Gosub ENTRE_MODIF From GOBJSUB
        Endif
      Endif
    Endif
  Endif
Endcase
Return


## Action SELEMPLO3 qui est l'action suite de SELEMPLO2 (Clic sur variable bas de tableau NBRMAT)

$TRT_DIV
If GSTATUT=7 : Return : Endif
Case PARAM(1)
 When "1" : # Avec remplissage du tableau des salariés
  ## mkstat=4 si on a fait OK dans la fenêtre de saisie du critère d'appartenance de la population.
  ## Il faut dégriser le bouton Enregistrer. Instruction Affzo fait raz de mkstat.
  Local Integer MODI
  If mkstat=4 : MODI = 1 : Endif
  If [M]CRISEL<>""
   Local Char MATRI (GLONEML)
   Local Date DATMAT
   For [ID]ID0 Where ENAFLG=2 :#on ne prend que les salariés actifs
    If !find([F:ID]REFNUM,[M]REFNUM(0..[M]NBRMAT-1))
     MATRI  = [F:ID]REFNUM
     DATMAT = date$
     For [HRCTR]CTR0(2) Where REFNUM=MATRI & CTRDAT<=DATMAT
      CTR = [F:HRCTR]CTRNUM
      Gosub LECEMP From WPDEFTABLE
      If evalue([M]CRISEL)
       [M]REFNUM([M]NBRMAT) = [F:ID]REFNUM
       [M]NAM([M]NBRMAT)    = [F:ID]NAM-[F:ID]SRN
       [M]NBRMAT += 1
       If [M]NBRMAT>=dim([M]REFNUM) : Break 2 : Endif
       Break
      Endif
     Next
    Endif
   Next
   Affzo 20,30
  Endif
  If MODI & !mkstat : mkstat = 4 : Endif
Endcase
Return

$EXEBOUT
If BOUT="2"
 Gosub RAFFRAICHIR From GOBJSUB
 Gosub RELIT From GOBJSUB
Endif
Return

$SETBOUT
#39925
#88758:MABOS-25/03/13-do not active MAJPOP if other Mask DIA already opened
If REP<>"" | GHISTO=1 | clalev([M:DIA])>0 Then
 Call VIREBOUT(CHAINE,"2") From GOBJET
Else
Endif
Return

########################################
#Subprog C_REFNUM(VALEUR)
#Variable Char    VALEUR()
#Call UNICITE(VALEUR,[M]REFNUM(0..[M]NBRMAT)) From OBJDIV
#If mkstat : End : Endif
#[M]NAM(nolign-1) = [F:ID]NAM-[F:ID]SRN
#End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
[M]NAM(nolign-1) = [F:ID]NAM-[F:ID]SRN
End

Subprog C_POP(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" :#MABOS-11/04/13-FQ81085-US1536
    If VALEUR=[M]COD : mkstat = 2 : End : Endif
    Call UNICITE(VALEUR,[M]POP(0..[M]NBRPOP)) From OBJDIV
    :#MABOS-11/04/13-FQ81085-US1536
    If mkstat=2 : End : Endif
    Read [F:HRPOP]POP0=VALEUR
      If !fstat Then
        If dim([V]GCURLEG)>0 & [V]GCURLEG <> "" & [F:HRPOP]LEG <> [V]GCURLEG
          GMESSAGE =func TOOLSHRLEG.LIB_FIELD(maskcou,zoncou)-":"-VALEUR+chr$(10)+chr$(13):
          If [F:HRPOP]LEG <> ""
            GMESSAGE+= mess(62,127,1)-":"-[F:HRPOP]LEG : # Réservé à la législation
          Else
            GMESSAGE+= mess(00091,00187,1) +chr$(10)+chr$(13)
            GMESSAGE+= mess(102,10720,1)-":"-[V]GCURLEG : # 'La législation doit être'
          Endif
          mkstat = 2 : GERR=1 : End
        Endif
      Endif
  Endif
  :#end MABOS-11/04/13-FQ81085-US1536
End

#**
#* FQ81085 - MABON 25/06/12 - Object POP selection
#*!
$SEL_TABLE
    # FQ81491 - US1752 SBA 27062013
    # sba 12/07/2012
    #Gosub SAVE_GLEGFIL From TOOLSHRLEG
    If maskcou="POP1" & zoncou = "COD" Then
      # FQ81491 - US1752 SBA 27062013
      Gosub SAVE_GCURLEG From TOOLSHRLEG
      GCURLEG=GLEGFIL
    Else
      # sba 12/07/2012
      Gosub SAVE_GLEGFIL From TOOLSHRLEG
    Endif
      # FQ81491 - US1752 fin
  Case TABLE
    When "SELPOP"
      If clalev ([F:HRPOP])=0 : Local File POPUL [HRPOP] : Endif
      Filter [F:HRPOP]
      OBJET     = "POP"
      START     = "[F:HRPOP]COD"
      EXPSTART  = "[F:HRPOP]COD>='"+VALEUR+"'"
      #MABOS-09/04/13-FQ 88316-US1528- on F12, select the code already in the field
#      If dim([M]LEG)>0 & !find(maskcou,"GENCSI")
#&       & !find(maskcou,"GENCEV")& !find(maskcou,"CEV0") Then
#81085-US1831
#      If func TOOLSHRLEG.ADDLEG_EXPSTART()
##        #MABOS-08/03/2013-FQ81085-US1332-generic rules in GENCEV
#        EXPSTART += '& [F:HRPOP]LEG="'+[M]LEG+'"'
#      Endif
#
      SUPP    = VALEUR
      #Filter based on code legislation
      If PARAM(1)<>""
        #MABOS-11/04/13-FQ81085-US1536
        If maskcou="POP1" & zoncou = "POP" Then
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRPOP]LEG="'+PARAM(1)+'"',"&") From GOBJSUB
        Else
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRPOP]LEG="'+PARAM(1)+'" | [F:HRPOP]LEG="")',"&") From GOBJSUB
        Endif
        #end MABOS-11/04/13-FQ81085-US1536
      Endif
      GLEGFIL=GCURLEG
  Endcase
Return

#**
#* FQ81085 - MABON 25/06/12 - Object POP selection
#*!
$FIN_TABLE
  # FQ81491 - US1752 SBA 27062013
  # Gosub RESTAURE_GLEGFIL From TOOLSHRLEG
  If maskcou="POP1" & zoncou = "COD" Then
    Gosub RESTAURE_GCURLEG From TOOLSHRLEG
  Else
    Gosub RESTAURE_GLEGFIL From TOOLSHRLEG
  Endif


  # FQ81085 - MABON 30/10/12 - New field LEG in subpopulations
  If dim([M]POPLEG)>0 & nolign>0 Then [M]POPLEG(nolign-1)=[F:HRPOP]LEG : Endif
  # End MABON
#  GLEGFIL=SAV_GLEGFIL
#  Kill SAV_GLEGFIL
Return

#**
#* FQ81085 - MABON 26/06/12 - Object POP control
#*!
Subprog CONTPOP(COD,LEG)
Value    Char    COD
Value    Char    LEG()
If clalev([F:HRPOP])=0 : Local File POPUL [HRPOP] : Endif

  If func AFNC.ACTIV("LEG")=0
    LEG = GDOSLEG
  Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
    LEG = GCURLEG
  Endif
  If LEG="" Then
    LEG=GLEGFIL
  Endif

  Read [F:HRPOP]POP0=[L]COD
  If !fstat
    Call CONTROLE("HRPOP","",LEG,COD,mkstat) From CONTOBJ
  Endif
End

# FQ81085 - MABON 25/06/12 - New field LEG
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#81085
Local Integer I, J
If VALEUR<>GCURLEG & VALEUR<>""
  For I=[M:POP1]NBRPOP-1 To 0 Step -1
    If [M:POP1]POPLEG(I)<>VALEUR & [M:POP1]POPLEG(I)<>""
      Supli [M:POP1]NBRPOP(I+1)
    Endif
  Next
  Affzo [M:POP1]NBRPOP
  For J=[M:POP1]NBRMAT-1 To 0 Step -1
   If [M:POP1]CTRLEG(J)<>VALEUR
    Supli [M:POP1]NBRMAT(J+1)
   Endif
  Next
  Affzo [M:POP1]NBRMAT
Endif
GCURLEG=VALEUR
End
# End 81085


######################################################################################
# FQ81085 - US915 - MABON 25/10/12 - Ajout contrat+date dans les populations, donc contrôle
# unicité sur REFNUM+CTRNUM+CTRDAT
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR
Local    Integer I

NOL = nolign-1
If [M:POP1]CTRDAT(NOL)=[0/0/0] Then End : Endif
Filter [F:HRCTR] Where REFNUM=[M:POP1]REFNUM(NOL) & CTRNUM=VALEUR Order By CTRDAT
If rowcount([F:HRCTR])>0 Then
  Read [F:HRCTR] Last
  [M:POP1]CTRDAT(NOL)=[F:HRCTR]CTRDAT
  [M:POP1]CTRLEG(NOL)=func TOOLSHRLEG.GETLEGFCY([F:HRCTR]ETRFCY):#MABOS-11/04/13-FQ81085-US1536
Endif
Filter [F:HRCTR]

# Contrôle des législations
If [M:POP1]LEG<>"" Then
  If [M:POP1]LEG<>(func TOOLSHRLEG.GETLEGFCY([F:HRCTR]ETRFCY)) Then
    GMESSAGE = mess(102,10720,1)-[M:POP1]LEG: # La législation doit être
    mkstat=2 : End
  Endif
Endif

# Contrôle unicité sur REFNUM+CTRNUM+CTRDAT
I=find([M:POP1]REFNUM(NOL),[M:POP1]REFNUM(0..NOL-1))
While I>0
  If [M:POP1]CTRNUM(I-1)=VALEUR & [M:POP1]CTRDAT(I-1)=[M:POP1]CTRDAT(NOL) Then
    GERR=1
    GMESSAGE = mess(24,123,1)-num$(I) : # Code déjà existant en ligne
    I=0
    mkstat=2 : End
  Else
    IS=I
#    I=find([M:POP1]REFNUM(NOL),[M:POP1]REFNUM(I+1..NOL-1))
    I=find([M:POP1]REFNUM(NOL),[M:POP1]REFNUM(I..NOL-1))
    If I>0 Then I+=IS : Endif
    If I<=IS Then I=0 : Endif
  Endif
Wend

I=find([M:POP1]REFNUM(NOL),[M:POP1]REFNUM(NOL+1..dim([M:POP1]REFNUM)-1))
If I>0 Then I += NOL : Endif
While I>0
#  I += NOL
  If [M:POP1]CTRNUM(I)=VALEUR & [M:POP1]CTRDAT(I)=[M:POP1]CTRDAT(NOL) Then
    GERR=1
    GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
    I=0
    mkstat=2 : End
  Else
    IS=I
    I=find([M:POP1]REFNUM(NOL),[M:POP1]REFNUM(I+1..dim([M:POP1]REFNUM)-1))
    If I>0 Then I+=IS : Endif
    If I<=IS Then I=0 : Endif
  Endif
Wend
End

######################################################################################
# FQ81085 - US915 - MABON 25/10/12 - Calcul date contrat si CTRNUM a été saisi directement,
# sans passer par le F12 (si F12, la date est rapatriée)
Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()

If [M:POP1]CTRDAT(nolign-1)<>[0/0/0] Then End : Endif
Filter [F:HRCTR] Where REFNUM=[M:POP1]REFNUM(nolign-1) & CTRNUM=VALEUR Order By CTRDAT
If rowcount([F:HRCTR])>0 Then
  Read [F:HRCTR] Last
  [M:POP1]CTRDAT(nolign-1)=[F:HRCTR]CTRDAT
  Call C_CTRNUM(VALEUR)
Endif
Filter [F:HRCTR]
End

