#JOJAC - 2016-08-02 - X3PEOP-736 - START
Subprog HRCONTPOP(COD)
Variable Char    COD()

If GFONCTION = "GESPOP" | COD="" : End : Endif

If clalev([F:HRPOP])=0 : Local File POPUL [HRPOP] : Endif

If COD <> ""
  Filter [F:HRPOP] Where COD=[L]COD
  Read [F:HRPOP] First
  If fstat
      GMESSAGE = COD-":"-mess(23,100,1)
      mkstat = 2 : End
  Else
      Filter [F:HRPOP]
      Filter [F:HRPOP] Where LEG = GCURLEG & COD = [L]COD
      Read [F:HRPOP] First
      If fstat
        Filter [F:HRPOP] Where COD=[L]COD
        Read [F:HRPOP] First
        GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:HRPOP]LEG
        mkstat = 2 : End
      Endif
  Endif
Endif
Filter [F:HRPOP]
End

