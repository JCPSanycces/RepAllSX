#<AdxTL>@(#)3.0.0.0 $Revision$
#############################################################################
# TRTX2FNC_SYRA      Traitement des fonctions X3 STD    Requêteur graphique #
# ------------------------------------------------------------------------- #
# EXISTS_ITF: Contrôle la présence d'un article-site pour un article donné  #
# EXISTS_ITC: Contrôle la présence d'un article-cout pour un article donné  #
# EXISTS_ITP: Contrôle la présence d'un fournisseur  pour un article donné  #
# EXISTS_CRY_CEE : Contrôle si le pays est de UE                            #
# EXISTS_CRY_BPA_CEE : Contrôle si le pays d'un adresse Tiers est de UE     #
# GET_CRY_BPA : Retourne le pays d'un adresse Tiers                         #
# EXISTS_F_ORI_AND_DES : Contrôle s'il existe un flux  si le pays d’origine et de destination sont des pays différents de l’UE
# EXISTS_F_ORI_OR_DES : Contrôle s'il existe un flux  si le pays d’origine ou de destination sont des pays différents de l’UE
# EXISTS_EECSH_EECNAF : Contrôle s'il existe un flux  si au moins un code régime ou un code nature est renseigné sur le flux
# EXISTS_FLUX : Contrôle s'il existe un flux avec en paramètre le pays d'origine, le pays de destination, le code tiers, et le code adresse                                #
# OSTCTLRSK Retourne le controle d'en-cours du client à risque              #
# OSTAUZRSK Retourne l'en-cours autorisé du client à risque                 #
#############################################################################
$TEST_GA
  Infbox "Résultat de EXISTS_ITP"-num$(func EXISTS_ITP("XYZ-GA"))-num$(func EXISTS_ITP("CD100"))
End

#########################
Funprog EXISTS_ITC(LITM)
Value Char LITM

Local Shortint IOK

  IOK = 1
  Local File ITMCOST [ITC]
  Filter [ITC] Where ITMREF = LITM
  Read [ITC]ITC0 First
  If fstat Then
    IOK = 0
  Endif
  Filter [ITC]
End IOK

#########################
Funprog EXISTS_ITF(LITM)
Value Char LITM

Local Shortint IOK

  IOK = 1
  Local File ITMFACILIT [ITF]
  Read [ITF]ITF0(1)=LITM
  If fstat Then
    IOK = 0
  Endif
End IOK

#########################
Funprog EXISTS_ITP(LITM)
Value Char LITM

Local Shortint IOK

  IOK = 1
  Local File ITMBPS [ITP]
  Read [ITP]ITP0(1)=LITM
  If fstat
    IOK = 0
  Endif
End IOK

###############################################################
# Retourne Oui si le pays est de UE
###############################################################
Funprog EXISTS_CRY_CEE(WCRYCOD)
Value Char WCRYCOD

Local Shortint IOK

  IOK = 0
  Local File TABCOUNTRY [TCY]
  Read [TCY]TCY0=WCRYCOD
  If !fstat Then
    If [TCY]EECFLG = 2
      IOK = 1
    Endif
  Endif
End IOK

###############################################################
# Retourne Oui si le pays d'un adresse Tiers est de UE
###############################################################
Funprog EXISTS_CRY_BPA_CEE(WNUM, WADD)
Value Char WNUM
Value Char WADD

Local Shortint IOK

  IOK = 0
  Local File BPADDRESS [BPA]
  Read [BPA]BPA0=1;WNUM;WADD
  If !fstat Then
    If func EXISTS_CRY_CEE([F:BPA]CRY) Then
      IOK = 1
    Endif
  Endif
End IOK

###############################################################
# Retourne le pays d'un adresse Tiers
###############################################################
Funprog GET_CRY_BPA(WNUM, WADD)
Value Char WNUM
Value Char WADD

Local Char WCRYCOD(GLONCRY)

  WGRYCOD = ""
  Local File BPADDRESS [BPA]
  Read [BPA]BPA0=1;WNUM;WADD
  If !fstat and dim([F:BPA]CRY) > 0 and [F:BPA]CRY <> "" Then
    WCRYCOD=[F:BPA]CRY
  Endif
End WCRYCOD

###############################################################
# Retourne Oui s'il existe un flux  si le pays d’origine et de destination sont des pays différents de l’UE
###############################################################
Funprog EXISTS_F_ORI_AND_DES(WCRYORI, WCRYDES)
Value Char WCRYORI
Value Char WCRYDES

Local Shortint IOK

  IOK = 0
  If func EXISTS_CRY_CEE(WCRYORI) and func EXISTS_CRY_CEE(WCRYDES) Then
    IOK = 1
  Endif
End IOK

###############################################################
# Retourne Oui s'il existe un flux  si le pays destination ou le pays d’origine hors UE et l'adresse transitaire pays de l’UE différent du pays UE destination ou origine
###############################################################
Funprog EXISTS_F_ORI_OR_DES(WCRYORI, WCRYDES, WNUM, WADD)
Value Char WCRYORI
Value Char WCRYDES
Value Char WNUM
Value Char WADD

Local Shortint IOK

  IOK = 0
  If  (!func EXISTS_CRY_CEE(WCRYORI) and func EXISTS_CRY_BPA_CEE (WNUM,WADD)) or (!func EXISTS_CRY_CEE(WCRYDES) and func EXISTS_CRY_BPA_CEE (WNUM,WADD)) Then
    IOK = 1
  Endif
End IOK

###############################################################
# Retourne Oui s'il existe un flux  si au moins un code régime ou un code nature est renseigné sur le flux
###############################################################
Funprog EXISTS_EECSH_EECNAF(CTX, SCURLEG, WEECSH, WEECNAT)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value Char SCURLEG
Value Char WEECSH
Value Char WEECNAT

Local Shortint IOK
Local Integer IRET

  IOK = 0
  Call LEC_TSC_LEG(CTX, SCURLEG, WEECSH, IRET) From TRTLECLEG_SYRA
  If !IRET Then
    IOK = 1
  Endif
  Call LEC_TEC_LEG(CTX, SCURLEG, WEECNAT, IRET) From TRTLECLEG_SYRA
  If !IRET Then
    IOK = 1
  Endif
End IOK

###############################################################
# Retourne Oui s'il existe un flux et que les 2 pays sont différents
# avec en paramètre le pays d'origine, le pays de destination, le code tiers, et le code adresse
###############################################################
Funprog EXISTS_FLUX(WCRYORI, WCRYDES, WNUM, WADD)
Value Char WCRYORI
Value Char WCRYDES
Value Char WNUM
Value Char WADD

Local Shortint IOK

  IOK = 0
  If WCRYORI <> WCRYDES Then
    If (func EXISTS_F_ORI_AND_DES(WCRYORI,WCRYDES) or func EXISTS_F_ORI_OR_DES(WCRYORI,WCRYDES,WNUM,WADD)) Then
      IOK = 1
    Endif
  Endif
End IOK

###############################################################
#**
#* Retourne le controle d'en-cours du client à risque
#* SEGAY
#* @since 05/03/10
#*!
Funprog OSTCTLRSK(WBPCRSK)
Value Char WBPCRSK

Local Integer WOSTCTL

  WOSTCTL = 0
  Local File BPCUSTOMER [BPC]
  Read [F:BPC]BPC0=WBPCRSK
  If !fstat Then
    WOSTCTL = [F:BPC]OSTCTL
  Endif
End WOSTCTL

###############################################################
#**
#* Retourne l'en-cours autorisé du client à risque
#* SEGAY
#* @since 05/03/10
#*!
Funprog OSTAUZRSK(WBPCRSK)
Value Char WBPCRSK

Local Decimal WOSTAUZ

  WOSTAUZ = 0
  Local File BPCUSTOMER [BPC]
  Read [F:BPC]BPC0=WBPCRSK
  If !fstat Then
    WOSTAUZ = [F:BPC]OSTAUZ
  Endif
End WOSTAUZ

###############################################################
Funprog GET_PARAM_NUM(CTX, ILEVEL, SLEVEL, SPARAM)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value Integer ILEVEL
Value Char SLEVEL
Value Char SPARAM

Local Integer IARENDRE

  #IARENDRE = fmet CTX.APARAM.AGETVALNUM(CST_ALEVCPY,[F:DUD]FCY,"LOKORD")
  IARENDRE = fmet CTX.APARAM.AGETVALNUM(ILEVEL, SLEVEL, SPARAM)
End IARENDRE

###############################################################
Funprog GET_PARAM_CHAR(CTX, ILEVEL, SLEVEL, SPARAM)
Value Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value Integer ILEVEL
Value Char SLEVEL
Value Char SPARAM

Local Char SARENDRE(250)

  #IARENDRE = fmet CTX.APARAM.AGETVALNUM(CST_ALEVCPY,[F:DUD]FCY,"LOKORD")
  SARENDRE = fmet CTX.APARAM.AGETVALCHAR(ILEVEL, SLEVEL, SPARAM)
End SARENDRE
