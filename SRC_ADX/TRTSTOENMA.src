#<AdxTL>@(#)11.0.0.0 $Revision$
#########################################################################
#          S T O E N T M
#########################################################################
#
#     Traitements liés à l'écran STOENTM
#
#########################################################################


#########################################################################
# Chargement Ecran STOENTM (partie parametrage) modifications des entrées
#########################################################################
$CHARG_PARAM_STOENTM
# [M:ENM]ORIDOC = 5
 [M:ENM]QUAFLG = [F:ITF]QUAFLG                     # hcb V6CQ
 Case LTYP
      When  6 : Call CHARG_PARAM_STOENTM(LLIGDOC) From SUBPTHB : # reception
      When 13 : If LABR="SRH1"
                    Call CHARG_PARAM_STOENTM(LLIGDOC) From SUBSRH  : # retour client
                Elsif LABR="SRS1"
                    Call CHARG_PARAM_STOENTM(LLIGDOC) From SUBSRS  : # retour matière sous traitance
                Else
                    Call CHARG_PARAM_STOENTM(LLIGDOC) From SUBSRL  : # retour pret
                Endif
      When 18 :    # Avoir
                Call CHARG_PARAM_STOENTM(LLIGDOC)          From SUBSIHB : # avoir
      When 19 : Call CHARG_PARAM_STOENTM(LLIGDOC)          From SUBSMRB : # entrées diverses
      When 15 : Call CHARG_PARAM_STOENTM(LLIGDOC,LTYP)     From MTKLIB  : # Déclaration de production
      When 31 : Call CHARG_PARAM_STOENTM(LLIGDOC)          From SUBBBYA : # Assemblage
      When 32 : Call CHARG_PARAM_STOENTM(LLIGDOC)          From SUBDBYA : # Desassemblage
      When 23 :    # reception transfert inter site
      When 25 :    # reception sous traitance    => INUTILISE
      When 12 : Call CHARG_PARAM_STOENTM(LLIGDOC,LTYP)     From MTKLIB  : # Réintégration en stock
      When Default :
 Endcase

 # Chargement de paramètres dans l'écran STOENTM
 GPOINT="CHG_STOENTM" : Gosub ENTREE From EXEFNC

 Return

#########################################################################
# Chargement Ecran STOENTM (Lignes) modifications  des entrées
#########################################################################
$CHARG_LIGNE_STOENTM
Local Decimal  WPCUDIS, WSTUDIS, WSTUACTDIS
Local Decimal  WSTOCOU

Local Integer WMAX
Local Integer LLIG
Local Integer LRET
Local Integer WISTA
Local Decimal WSTODISTOT
Local Char LSLO(GLONSLO)
Local Char LMAJ(GLONECS)
Local Char LMIN(GLONEVL)
Local Integer LECC
Local Integer I1, I2
Local Char MES(255)
Local Integer WPMPLOT
Local Decimal WAMTORD, WAMTVAL, WQTYSTU
Raz WPMPLOT, WAMTORD, WAMTVAL, WQTYSTU

WMAX = dim([M:ENM]PCU)-1     # mémorisation nombre de ligne maxi
LLIG = 0

#--- Issue 117545
Call ADDLOTBLANC( "ENM" ) From STKENTA
#Call ADDLOTBLANC( "ENM" ) From STKENT
#---

For [STJ]STJ1 Where STOFCY = [M:ENM]STOFCY   &
&                   VCRTYP = [M:ENM]VCRTYP   &
&                   VCRNUM = [M:ENM]VCRNUM   &
&                   VCRLIN = [M:ENM]VCRLIN   &
&                   ITMREF = [M:ENM]ITMREF   &
&                   UPDCOD = 2               &
&                   REGFLG <> 2              &
&                   TRSTYP <>29                : #--- Issue 115206
    If LLIG >= WMAX : Goto NEXTLLIG : Endif

    # Si retour de prêt : on alimente avec le mvt positif
    # Par contre on charge le chrono stock origine avec le mvt négatif (emplacement client)
    If find([F:STJ]TRSTYP,18,33)
       If [F:STJ]QTYSTU < 0
          #--- Issue X3-53322 : Ajout LPN
          Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                     [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                     [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                     [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB
          If WSTOCOU = 0
             Raz [M:ENM]STOCOUORI(LLIG)
          Else
             [M:ENM]STOCOUORI(LLIG) = [F:STO]STOCOU
          Endif
          Goto NEXTSTJ
       Endif
    Endif

    # si reception transfert inter sites on ne selectionne que les entrées donc les valeurs positives
    If [F:STJ]TRSTYP = 10 & [F:STJ]QTYSTU < 0
       Goto NEXTSTJ
    Endif

    [M:ENM]ORILIG       (LLIG)        = 5
    [M:ENM]WFLG         (LLIG)        = 2
    [M:ENM]PCU          (LLIG)        = [F:STJ]PCU
    [M:ENM]QTYPCU       (LLIG)        = [F:STJ]QTYPCU
    [M:ENM]QTYSTU       (LLIG)        = [F:STJ]QTYSTU
    [M:ENM]PCUSTUCOE    (LLIG)        = [F:STJ]PCUSTUCOE
    [M:ENM]BPSLOTO      (LLIG)        = [F:STJ]BPSLOT
    If dim([M:ENM]LOTAFF    (LLIG)) > 0
        [M:ENM]LOTAFF       (LLIG)    = [F:STJ]LOT
        [M:ENM]BPSLOTAFF    (LLIG)    = [F:STJ]BPSLOT
        If dim([M:ENM]SLOAFF(LLIG)) > 0
            [M:ENM]SLOAFF   (LLIG)    = [F:STJ]SLO
            LSLO = [F:STJ]SLO
        Else
            Raz LSLO
        Endif
        If [M:ENM]LOTAFF(LLIG)=""
            [M:ENM]GESLOTAFF(LLIG)="B"    # Utile dans le cas de LOTMGTCOD=2
        Else
            Raz [M:ENM]GESLOTAFF(LLIG)
        Endif
#                                                                    # hcb 71276 deb
        If dim([M:ENM]ECCVALMAJAFF)>0
          [M:ENM]ECCVALMAJAFF (LLIG)     = [F:STJ]ECCVALMAJ
          LMAJ                           = [F:STJ]ECCVALMAJ
        Endif
        If dim([M:ENM]ECCVALMINAFF)>0
          [M:ENM]ECCVALMINAFF (LLIG)     = [F:STJ]ECCVALMIN
          LMIN                           = [F:STJ]ECCVALMIN

        Endif
        If dim([M:ENM]ECCSAIFLG)>0
          [M:ENM]ECCSAIFLG (LLIG)     = 1
        Endif

        LECC = 0

        #--- Issue 118478
        Local Integer LNUMLIGLOT
        Call SEARCHLOTENM([F:STJ]LOT,[F:STJ]SLO,-1,LNUMLIGLOT) From STKENTA
        If LNUMLIGLOT>=0
          [M:ENM]NUMLIGLOT(LLIG)=LNUMLIGLOT
        Else
          Read [STL]STL0=[F:STJ]ITMREF;[F:STJ]LOT;[F:STJ]SLO
          If fstat Raz [F:STL] Endif
          Call SETCPTLOT("ENM", [M:ENM]NBLIGLOT, [F:STJ]LOT, [F:STJ]SLO, [F:STJ]BPSLOT, "",
&                        [F:STJ]POT, [F:STJ]ACT, [F:STL]REFPER, [F:STL]SHL, [F:STL]SHLDAT,
&                        [F:STL]SHLUOM, [F:STL]SHLLTI, [F:STL]SHLLTIUOM, [F:STJ]NEWLTIDAT,
&                        [F:STL]DLU, [F:STJ]DLUDAT, [F:STJ]USRFLD1, [F:STJ]USRFLD2,
&                        [F:STJ]USRFLD3, [F:STJ]USRFLD4, 1, LMAJ, LMIN, LECC, 2) From STKENT
          [M:ENM]NUMLIGLOT(LLIG)=[M:ENM]NBLIGLOT
          [M:ENM]NBLIGLOT+=1
        Endif
#        Call SETCPTLOTAUTO([M:ENM]ITMREF, "ENM", LLIG, [M:ENM]LOTAFF(LLIG), LSLO, [M:ENM]BPSLOTAFF(LLIG),
#&                          [M:ENM]GESLOTAFF(LLIG),LMAJ,LMIN,LECC, LRET ) From STKENT
        #--- End issue 118478

    Endif

    #[M:ENM]STOCOU       (LLIG)        = [F:STJ]STOCOU
    If dim([M:ENM]SERNUM(LLIG)) > 0
       #--- Issue 110327
       #[M:ENM]SERNUM    (LLIG)        = [F:STJ]SERNUM
       If [F:ITM]SERMGTCOD=4
          [M:ENM]SERNUM(LLIG) = [F:STJ]SERDEB
       Else
          [M:ENM]SERNUM(LLIG) = [F:STJ]SERNUM
       Endif
       #---
    Endif

    If dim([M:ENM]SERNUMF(LLIG)) > 0
       #--- Issue 110327
       #[M:ENM]SERNUMF   (LLIG)        = [F:STJ]SERNUM
       If [F:ITM]SERMGTCOD=4
          [M:ENM]SERNUMF(LLIG) = [F:STJ]SERFIN
       Else
          [M:ENM]SERNUMF(LLIG) = [F:STJ]SERNUM
       Endif
       #---
    Endif
    [M:ENM]STA          (LLIG)        = [F:STJ]STA
    If dim([M:ENM]LOC)>0
        [M:ENM]LOC          (LLIG)    = [F:STJ]LOC
    Endif
    If dim([M:ENM]WRH)>0
        [M:ENM]WRH          (LLIG)    = [F:STJ]WRH
    Endif

    [M:ENM]LBEFMT       (LLIG)        = [F:STJ]LBEFMT

    [M:ENM]LBENBR       (LLIG)        = [F:STJ]LBENBR

    If dim([M:ENM]PALNUM)>0                                     # hcb 27200
       [M:ENM]PALNUM       (LLIG)     = [F:STJ]PALNUM
    Endif                                                       # hcb 27200
    If dim([M:ENM]CTRNUM)>0                                     # hcb 27200
       [M:ENM]CTRNUM       (LLIG)     = [F:STJ]CTRNUM
    Endif                                                       # hcb 27200
    If dim([M:ENM]STOFLD1)>0
       [M:ENM]STOFLD1      (LLIG)     = [F:STJ]STOFLD1
    Endif
    If dim([M:ENM]STOFLD2)>0
       [M:ENM]STOFLD2      (LLIG)     = [F:STJ]STOFLD2
    Endif
    [M:ENM]MVTDES                     = [F:STJ]MVTDES
    #--- Issue X3-53322
    If dim([M:ENM]LPNNUM)>0
       [M:ENM]LPNNUM      (LLIG)      = [F:STJ]LPNNUM
    Endif
    #---
    [M:ENM]PRIORD       (LLIG)        = [F:STJ]PRIORD
    [M:ENM]PRIVAL       (LLIG)        = [F:STJ]PRIVAL
    [M:ENM]PRINATH                    = [F:STJ]PRINAT
    [M:ENM]PRIORDH                    = [F:STJ]PRIORD
    [M:ENM]PRIVALH                    = [F:STJ]PRIVAL

    # Cumul mnts et qtés mouvements pour calculer un prix moyen ligne document
    # qui sera utilisé pour valoriser les nouveaux mvts
    # Uniquement si la valo était en prix moyen lot (WPMPLOT=1)
    WAMTORD += abs([F:STJ]AMTORD)
    WAMTVAL += abs([F:STJ]AMTVAL)
    WQTYSTU += abs([F:STJ]QTYSTU)
    If [F:STJ]PRINAT=7 WPMPLOT=1 Endif

    [M:ENM]VCRTYPORI                  = [F:STJ]VCRTYPORI
    [M:ENM]VCRNUMORI                  = [F:STJ]VCRNUMORI
    [M:ENM]VCRLINORI                  = [F:STJ]VCRLINORI
    [M:ENM]CSTDAT       (LLIG)        = [F:STJ]CSTDAT
    [M:ENM]CSTTIM       (LLIG)        = [F:STJ]CSTTIM
    [M:ENM]CSTCOU       (LLIG)        = [F:STJ]CSTCOU

    [M:ENM]PCUO         (LLIG)        = [F:STJ]PCU
    [M:ENM]QTYPCUO      (LLIG)        = [F:STJ]QTYPCU
    [M:ENM]QTYSTUO      (LLIG)        = [F:STJ]QTYSTU
    [M:ENM]LOTO         (LLIG)        = [F:STJ]LOT
    #--- Issue 110327
    #[M:ENM]SERNUMO      (LLIG)        = [F:STJ]SERNUM
    If [F:ITM]SERMGTCOD=4
       [M:ENM]SERNUMO(LLIG) = [F:STJ]SERDEB
       [M:ENM]SERNUMFO(LLIG)= [F:STJ]SERFIN
    Else
       [M:ENM]SERNUMO(LLIG) = [F:STJ]SERNUM
       [M:ENM]SERNUMFO(LLIG)= [F:STJ]SERNUM
    Endif
    #---
    [M:ENM]STAO         (LLIG)        = [F:STJ]STA
    [M:ENM]SLOO         (LLIG)        = [F:STJ]SLO
    # On met ce n° en en-tête afin de pouvoir le conserver et l'utiliser sur les nlles lignes
    If [F:STJ]QLYCTLDEM<>""
        [M:ENM]QLYCTLDEM                  = [F:STJ]QLYCTLDEM
    Endif
    [M:ENM]LOCO         (LLIG)        = [F:STJ]LOC

    #---- Récupération de LOCTYP et LOCCAT dans STOLOC car la ligne de stock n'existe plus forcément(retour) ----#
    If !clalev([STC]) : Local File STOLOC [STC] : Endif
    If [M:ENM]STOFCY<>"" & [F:STJ]LOC<>""
        Read [STC]STC0=[M:ENM]STOFCY;[F:STJ]LOC
        If !fstat
            [M:ENM]LOCCATO(LLIG) = [F:STC]LOCCAT
            If dim([M:ENM]LOCTYP)>0 [M:ENM]LOCTYP(LLIG)=[F:STC]LOCTYP Endif
        Endif
    Endif

    # IPTDAT et MVTSEQ servent pour faire le lien avec le STOJOU au moment
    #        de la comparaison entre le STOJOU et STOENTM pour determiner :
    #        les nouvelles lignes  IPTDAT et MVTSEQ seront egales à 0
    #        les lignes supprimées IPTDAT et MVTSEQ seront absentes dans STOENTM
    #        les lignes modifiées  IPTDAT et MVTSEQ comparaisons de toutes les rubriques
    # IPTDAT est présent afin d'offrir une ouverture de modification.
    # Sa modification est d'ors et déjà testée au cas où...

    [M:ENM]IPTDAT       (LLIG)        = [F:STJ]IPTDAT
    [M:ENM]MVTSEQ       (LLIG)        = [F:STJ]MVTSEQ

    #--- Issue X3-53322 : Ajout LPN
    Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&               [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&               [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&               [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB

    If WSTOCOU = 0 Goto CHARG_STOENTM_SUIT : Endif

    [M:ENM]STOCOU       (LLIG)        = [F:STO]STOCOU


    #---- Récupération des sections analytiques ----#
    For I=1 To GNBDIE
        If dim([M:ENM]CCE(I-1))>0
            [M:ENM]CCE(I-1) = [F:STJ]CCE(I-1)
        Else
            Break
        Endif
    Next

# Le disponible ne doit tenir compte dans un premier temps que de la ligne de stock
# Le disponible global ne doit être pris en compte qu'au moment de l'enregistrement
#    # Disponible en global
#    WISTA = (left$([M:ENM]STA(LLIG),1)="A")+(left$([M:ENM]STA(LLIG),1)="Q")*2+(left$([M:ENM]STA(LLIG),1)="R")*4
#    Call STODISMOD("",[M:ENM]LOCCATO(LLIG),WISTA,"",WSTODISTOT) From STKLIB
#    # Disponible sur la ligne de stock
#    Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
#    [M:ENM]STUDIS        (LLIG)       = min(WSTUDIS,WSTODISTOT)

    Read [STO]STO0=[F:STJ]STOFCY;[L]WSTOCOU
    Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,[M:ENM]STUDIS(LLIG),WSTUACTDIS) From STKLIB

    $CHARG_STOENTM_SUIT

    # Transfert zones de la table STOJOU vers l'écran STOENM
    GPOINT="STJ_ENM" : Gosub ENTREE From EXEFNC

    [M:ENM]NBLIG        = LLIG+1

    Gosub DESACTIV_RUB_STOENTM
    #--- Bug 60935
    Affzo [M:ENM]NBLIG

    $NEXTLLIG
    LLIG += 1

$NEXTSTJ

Next

# Si la valo était en prix moyen lot, calcul du prix moyen (ordre et valo)
# qui servira à valoriser les nouveaux mouvements
If WPMPLOT = 1
   [M:ENM]PRIORDH = WAMTORD/WQTYSTU
   [M:ENM]PRIVALH = WAMTVAL/WQTYSTU
Endif

If LLIG>WMAX
    # Nombre mouvements à charger (LLIG) > Nombre de lignes maxi du tableau (WMAX)
    # Veuillez modifier le code activité SLE pour pouvoir modifier les mouvements
    #Diszo [M:ENM]1-99
    #LTOOLIG=GCONSULT+1
    #GCONSULT=1
    I1 = instr(1,mess(69,184,1),"%")
    I2 = instr(I1+1,mess(69,184,1),"%")
    MES=left$(mess(69,184,1),I1-1)+num$(LLIG)+mid$(mess(69,184,1),I1+1,I2-I1-1)+num$(WMAX)+right$(mess(69,184,1),I2+1)
    Call ERREUR(MES+chr$(13)+mess(70,184,1)) From GESECRAN
    Effzo [M:ENM]1-99
    FIN = 1
Endif
#iptdat1 est obligatoire car en cas de suppression de toutes les lignes iptdat est inconnue
[M:ENM]IPTDAT1      = [M:ENM]IPTDAT       (0)

#recuperation demande analyse du fichier SRU
[M:ENM]QLYCTLFLG = [F:SRU]QLYCTLFLG


# Si les lignes d'entrées ont un document d'origine (avec mouvement)
# il ne faut pas pouvoir saisir les lots et les n° série
# L'éclatement des lignes peut se faire via la fonction "Insertion de lignes" (qui se base sur la ligne en cours)
If [M:ENM]VCRNUMORI <> ""  & ([M:ENM]VCRTYP = 13 | [M:ENM]VCRTYP = 18 | [M:ENM]TRSTYP = 19)    # hcb 86524
   If dim([M:ENM]LOTAFF) > 0
      Grizo [M:ENM]LOTAFF
      If dim([M:ENM]BPSLOTAFF) > 0
         Grizo [M:ENM]BPSLOTAFF
      Endif
      If dim([M:ENM]SLOAFF) > 0
         Grizo [M:ENM]SLOAFF
      Endif
      If dim([M:ENM]ECCVALMAJAFF) > 0
         Grizo [M:ENM]ECCVALMAJAFF
      Endif
      If dim([M:ENM]ECCVALMINAFF) > 0
         Grizo [M:ENM]ECCVALMINAFF
      Endif
   Endif

   If dim([M:ENM]SERNUM) > 0
      If [M:ENM]SERNUM    <> ""
         #--- Issue 110327
         If [F:ITM]SERMGTCOD=4
            Grizo [M:ENM]PCU
            Grizo [M:ENM]PCUSTUCOE
         Else
         #---
            Grizo [M:ENM]SERNUM
            Grizo [M:ENM]PCU
            Grizo [M:ENM]QTYPCU
            Grizo [M:ENM]QTYSTU
            Grizo [M:ENM]PCUSTUCOE
         #--- Issue 110327
         Endif
         #---
      Endif
   Endif
Endif

Return

#########################################################################
# Desactivation des rubriques STOENTM
#########################################################################
# affzo avant diszo est necessaire pour mettre en italique les rubriques sur toutes les lignes
# desactivation des rubriques PCU QTYPCU QTYSTU PCUSTUCOE si série
# desactivation des rubriques SERNUM PCU QTYPCU QTYSTU PCUSTUCOE LOT SLO STA LOC
#                             si série et disponible à 0
$DESACTIV_RUB_STOENTM
Local Decimal LCOE
Local Char    LUSCAV(5)
Local Char    LLBEFMT(GLONARP)
Local Integer LMODIF

Call CTLUOM ([M:ENM]ITMREF,[M:ENM]TYPBPR,[M:ENM]BPRNUM, [M:ENM]PCU(LLIG),LCOE, LUSCAV, LLBEFMT, LMODIF) From STKACT
If LMODIF=2
    Actzo [M:ENM]PCUSTUCOE(LLIG)
Else
    Diszo [M:ENM]PCUSTUCOE(LLIG)
Endif

If dim([M:ENM]SERNUM(LLIG)) > 0
    If [M:ENM]SERNUM(LLIG) <> ""
# Apparemment inutile + Crée un problème de performance à cause du format
#        Affzo [M:ENM]SERNUM        (LLIG)
      #--- Issue 110327
      If [F:ITM]SERMGTCOD=4
         Grizo [M:ENM]PCU(LLIG)
         Grizo [M:ENM]PCUSTUCOE(LLIG)
      Else
      #---
         Grizo [M:ENM]PCU           (LLIG)
         Grizo [M:ENM]QTYPCU        (LLIG)
         Grizo [M:ENM]QTYSTU        (LLIG)
         Grizo [M:ENM]PCUSTUCOE     (LLIG)
         If [M:ENM]VCRNUMORI <> ""
            Grizo [M:ENM]SERNUM (LLIG)
         Endif
      #--- Issue 110327
      Endif
      #---
    Endif
Endif

#--- Bug 56470
#If [M:ENM]STUDIS(LLIG) = 0 | [M:ENM]STUDIS(LLIG)<[M:ENM]QTYSTU(LLIG)
#    Affzo [M:ENM]PCU      (LLIG)
#    Grizo [M:ENM]PCU      (LLIG)
#    Grizo [M:ENM]QTYSTU   (LLIG)
#    Grizo [M:ENM]PCUSTUCOE(LLIG)
#    Grizo [M:ENM]STA      (LLIG)
#    If dim([M:ENM]BPSLOTAFF(LLIG)) > 0
#        Grizo [M:ENM]BPSLOTAFF(LLIG)
#    Endif
#    If dim([M:ENM]LOTAFF(LLIG)) > 0
#        Grizo [M:ENM]LOTAFF   (LLIG)
#    Endif
#    If dim([M:ENM]SLOAFF(LLIG)) > 0
#        Grizo [M:ENM]SLOAFF   (LLIG)
#    Endif
#    If dim([M:ENM]LOCTYP(LLIG)) > 0
#         Grizo [M:ENM]LOCTYP  (LLIG)
#    Endif
#    If dim([M:ENM]LOC(LLIG)) > 0
#        Grizo [M:ENM]LOC      (LLIG)
#    Endif
#    If dim([M:ENM]WRH(LLIG)) > 0
#        Grizo [M:ENM]WRH      (LLIG)
#    Endif
#    If dim([M:ENM]SERNUM(LLIG)) > 0
#        Grizo [M:ENM]SERNUM   (LLIG)
#    Endif
#Endif
Diszo [M:ENM]PCU(LLIG)
Diszo [M:ENM]PCUSTUCOE(LLIG)
Diszo [M:ENM]STA(LLIG)
If dim([M:ENM]LOCTYP(LLIG))>0
   Diszo [M:ENM]LOCTYP(LLIG)
Endif
If dim([M:ENM]LOC(LLIG))>0
   Diszo [M:ENM]LOC(LLIG)
Endif
If dim([M:ENM]BPSLOTAFF(LLIG))>0
   Diszo [M:ENM]BPSLOTAFF(LLIG)
Endif
If dim([M:ENM]LOTAFF(LLIG))>0
   Diszo [M:ENM]LOTAFF(LLIG)
Endif
If dim([M:ENM]SLOAFF(LLIG))>0
   Diszo [M:ENM]SLOAFF(LLIG)
Endif
If dim([M:ENM]ECCVALMAJAFF) > 0
   Diszo [M:ENM]ECCVALMAJAFF
Endif
If dim([M:ENM]ECCVALMINAFF) > 0
   Diszo [M:ENM]ECCVALMINAFF
Endif
If dim([M:ENM]WRH(LLIG))>0
   Diszo [M:ENM]WRH(LLIG)
Endif
If dim([M:ENM]SERNUM(LLIG))>0
   #--- Issue 110327
   If [F:ITM]SERMGTCOD<>4
   #---
      Diszo [M:ENM]SERNUM(LLIG)
   #--- Issue 110327
   Endif
   #---
Endif
If dim([M:ENM]PALNUM(LLIG))>0
   Diszo [M:ENM]PALNUM(LLIG)
Endif
If dim([M:ENM]CTRNUM(LLIG))>0
   Diszo [M:ENM]CTRNUM(LLIG)
Endif
#---
If dim([M:ENM]STOFLD1(LLIG))>0
   Diszo [M:ENM]STOFLD1(LLIG)
Endif
If dim([M:ENM]STOFLD2(LLIG))>0
   Diszo [M:ENM]STOFLD2(LLIG)
Endif
If dim([M:ENM]ECCVALMAJAFF) > 0
   Diszo [M:ENM]ECCVALMAJAFF
Endif
If dim([M:ENM]ECCVALMINAFF) > 0
   Diszo [M:ENM]ECCVALMINAFF
Endif
#--- Issue X3-53322
If dim([M:ENM]LPNNUM(LLIG))>0
   Diszo [M:ENM]LPNNUM(LLIG)
Endif
#---
Return


#########################################################################
# Contrôle si la ligne peut être modifiée
# Si cela n'est pas possible le tableau est grisé
# Le contrôle est fait sur la date d'imputation.
# La main est aussi donnée aux documents, afin qu'ils effectuent leur propre test.
#########################################################################
$CTL_MODIF

If GCONSULT
    Diszo [M:ENM]
    Return
Endif

Call STKCTRIPT( [M:ENM]IPTDAT, [M:ENM]STOFCY, "1") From STKLIB
If GERR=1
    Call ERREUR(GMESSAGE) From GESECRAN
    Raz GERR
    Raz GMESSAGE
    FIN=1 : Return
Elsif GERR=2
    Call MESSAGE(GMESSAGE) From GESECRAN
    Raz GERR
    Raz GMESSAGE
    FIN=1 : Return
Endif

If [M:ENM]QLYCTLDEM<>""
   #-- Des mouvements ont-ils eu lieu ?
   For [STJ]STJ1  Where STOFCY=[M:ENM]STOFCY & VCRTYP=28 & VCRNUM=[M:ENM]QLYCTLDEM
&                     & VCRNUMORI=[M:ENM]VCRNUM & VCRLINORI=[M:ENM]VCRLIN & REGFLG<>2
       # Contrôle qualité partiellement réalisé ou terminé
       Call ERREUR(mess(9,123,1)-":\"+mess(316,184,1)) From GESECRAN
       FIN=1 : Break
   Next
Endif

If FIN=1
    Return
Else
    #initialisation rubrique (affiche / saisi) selon categorie article / SRU

    #--- Bug 56470
    #Default Mask [ENM]
    #For I=1 To 11
    #    If GCHPSTO(I)<>""
#&        & evalue("dim([M:ENM]"+GCHPSTO(I)+")") > 0
    #        If mid$(GSAIFLG,I,1)<>"0"
    #            Diszo =GCHPSTO(I)
    #        Else
    #           Actzo =GCHPSTO(I)
    #        Endif
    #    Endif
    #Next
Endif

Return


#########################################################################
# Mise à jour du document origine suite à modifications
# le masque du document origine est chargé avec les nouvelles valeurs
#########################################################################
$MAJ_MODIFICATION_LIGNE
Local Integer LRET

Call ENM_APRES_NBLIG(LLIGDOC) From TWMLIB   # Three way matching  for Cancel then save steps
Gosub PTH_VERIF From TWMLIB        # Three way matching
 If GERR : Return  : Endif         # Three way matching

LRET = 0

If !GIMPORT
   Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
Endif

# Transaction de traitement pour modification des mvts de stock
Call DEBTRANS From GLOCK

If dim(GDELDOC)<=0 | GDELDOC<>1
    Trbegin [STJ]
Endif

#--- Issue 84130
# Pour annuler les mvts stocks de régul des FCC de la commande réceptionnée
If dim(GDELDOC)<=0 | GDELDOC<>1
  # modification document origine
  If LTYP=6
    Gosub AVT_MAJ_DOCUMENT From SUBPTHB
    If LRET <> 0 | GOK < 1 : Goto AB_TRT : Endif
    Local Integer K
    #--- Issue X3-53322 : correction bug potenciel
    Local Char WLOT(GLONLOT)
    Local Char WSLO(GLONSLO)
    Local Char WSER(GLONSER)
    Local Char WLOC(GLONLOC)
    Local Char WPAL(GLONPAL)
    Local Char WCTR(GLONCTR)
    Local Char WLPN(GLONLPN)
    #---
    For K=0 To [M:ENM]NBLIG-1
      If [M:ENM]MVTSEQ(K)<>0
        Read [STJ]STJ0=[M:ENM]STOFCY;2;[M:ENM]ITMREF;[M:ENM]IPTDAT(K);
&                      [M:ENM]MVTSEQ(K);[M:ENM]MVTIND(K)
        If [F:STJ]REGFLG=2
          #--- Issue X3-53322 :  correction bug potenciel et ajout LPNNUM
          Raz WLOT, WSLO, WSER, WLOC, WPAL, WCTR, WLPN
          If dim([M:ENM]LOTAFF) : WLOT=[M:ENM]LOTAFF(K) : Endif
          If dim([M:ENM]SLOAFF) : WSLO=[M:ENM]SLOAFF(K) : Endif
          If dim([M:ENM]SERNUM) : WSER=[M:ENM]SERNUM(K) : Endif
          If dim([M:ENM]LOC)    : WLOC=[M:ENM]LOC(K)    : Endif
          If dim([M:ENM]PALNUM) : WPAL=[M:ENM]PALNUM(K) : Endif
          If dim([M:ENM]CTRNUM) : WCTR=[M:ENM]CTRNUM(K) : Endif
          If dim([M:ENM]LPNNUM) : WLPN=[M:ENM]LPNNUM(K) : Endif
          #---
          Filter [STJ] Where STOFCY=[M:ENM]STOFCY & VCRTYP=6 & VCRNUM=[M:ENM]VCRNUM
&                          & VCRLIN=[M:ENM]VCRLIN & UPDCOD=2 & ITMREF=[M:ENM]ITMREF
&                          & REGFLG=1 & LOT=WLOT & SLO=WSLO
&                          & STA=[M:ENM]STA(K) & LOC=WLOC & PCU=[M:ENM]PCU(K)
&                          & PCUSTUCOE=[M:ENM]PCUSTUCOE(K) & SERNUM=WSER
&                          & PALNUM=WPAL & CTRNUM=WCTR & LPNNUM=WLPN
&                          & TRSTYP<>29
&                      Order By Key STJ1       : #--- Issue 115206 ajout TRSTYP<>29
          Read [STJ]STJ1 First
          If !fstat
            [M:ENM]MVTSEQ(K) = [F:STJ]MVTSEQ
            [M:ENM]MVTIND(K) = [F:STJ]MVTIND
          Endif
          Filter [STJ]
        Endif
      Endif
    Next K
  Endif
Endif
#---

# mise à jour stock appel du composant
Local Decimal LQTA
Local Decimal LSHT
Local Integer LRET
Local Integer LNBR, LNBJ

# Initialisation de l'en-tête
[M:STW]STOFCY     = [M:ENM]STOFCY                               # Site
[M:STW]TRFFCY     = [M:ENM]TRFFCY                               # Site de transfert
[M:STW]BETCPY     = [M:ENM]BETCPY                               # Inter-société
[M:STW]TRSTYP     = [M:ENM]TRSTYP                               # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:ENM]VCRTYP                               # Type pièce (M.701)
[M:STW]VCRNUM     = [M:ENM]VCRNUM                               # Numéro pièce
[M:STW]VCRLIN     = [M:ENM]VCRLIN                               # Numero ligne pièce
[M:STW]ITMREF     = [M:ENM]ITMREF                               # Article
[M:STW]MVTDES     = [M:ENM]MVTDES                               # Désignation mouvement
[M:STW]PRIORDH    = [M:ENM]PRIORD                               # Prix mouvement
[M:STW]PJT        = [M:ENM]PJT                                  # Affaire
[M:STW]TRSFAM     = [M:ENM]TRSFAM                               # Famille mouvement
[M:STW]IPTDAT     = [M:ENM]IPTDAT1                              # Date imputation
[M:STW]BPRNUM     = [M:ENM]BPRNUM
[M:STW]VCRTYPORI  = [M:ENM]VCRTYPORI
[M:STW]VCRNUMORI  = [M:ENM]VCRNUMORI
[M:STW]VCRLINORI  = [M:ENM]VCRLINORI
[M:STW]TRSCOD     = [M:ENM]TRSCOD
[M:STW]ENTCOD     = [M:ENM]ENTCOD                               # Code pièce auto
[M:STW]UPDPRI     = [M:ENM]UPDPRI
#--- Bug 73121
# Si réception matière pour sous-traitance, alimentation propriétaire stock
If [M:ENM]VCRTYP=6 & [M:ENM]TRSTYP=16
   [M:STW]BPSFCY = [M:ENM]TRFFCY
Endif
#---

#alimentation de STOWORK avec STOENTM
Call ALISTOWORK( 4, 0, LQTA, LSHT, LNBR, LNBJ, LRET ) From STKINT

#Mise à jour des stock
If LRET=0  Call MAJ_STOCK From STKMAJ : Endif

If LRET <> 0 | GOK < 1 Goto AB_TRT Endif

# analyse ligne document modifiée + chargement et reaffichage ecran document
Gosub LOAD_FROM_ENTM  From STKENT

# CCC(04/10/06) DM 37826
If sum([M:ENM]QTYSTU)=0
    Call FUNSTKACC([M:ENM]STOFCY,[M:ENM]ITMREF,[M:ENM]VCRTYP, [M:ENM]VCRNUM, [M:ENM]VCRLIN) From STKLIB
    If GOK < 1
        Goto AB_TRT
    Endif
Endif

If dim(GDELDOC)<=0 | GDELDOC<>1
    # modification document origine
    GPOINT="BEF_MAJ_DOC" : Gosub ENTREE From EXEFNC    # hcb 80150
    Case LTYP

         When 6  : Gosub TRT_MAJ_DOCUMENT From SUBPTHB # reception
         When 13 : If LABR="SRH1"
                       Gosub TRT_MAJ_DOCUMENT From SUBSRH  # retour client
                   Elsif LABR="SRS1"
                       Gosub TRT_MAJ_DOCUMENT From SUBSRS  # retour matière sous traitance
                   Else
                       Gosub TRT_MAJ_DOCUMENT From SUBSRL  # retour prêt
                   Endif
         When 18 : # avoir vente
                   Gosub TRT_MAJ_DOCUMENT From SUBSIHB # avoir
         When 19 : Gosub TRT_MAJ_DOCUMENT From SUBSMRB # ENTREE diverse
         When 15 : Gosub TRT_MAJ_DOCUMENT From SUBMTKC # declaration production
         When 31 : Gosub TRT_MAJ_DOCUMENT From SUBBBYA # Assemblage
         When 32 : Gosub TRT_MAJ_DOCUMENT From SUBDBYA # Desassemblage
         When 23 : # reception transfert inter site
         When 25 : # reception sous traitance
         When 26 : Gosub TRT_MAJ_DOCUMENT From SUBMTKC # reintegration stock

         When 99 : # test
         When Default :
    Endcase
    GPOINT="AFT_MAJ_DOC" : Gosub ENTREE From EXEFNC    # hcb 80150
Endif

If LRET <> 0 | GOK < 1 Goto AB_TRT Endif

MAJLIGDOC = 1
If dim(GDELDOC)<=0 | GDELDOC<>1
    Commit
Endif
Call STKDELRES (0, "", "", LRET) From STKLOC

If [M:ENM]PRNCOD1>1 & [M:ENM]NBLIG>0
    Local Char WPARAM(GLONVCR)(1..3) , WVALEUR(10)
    WPARAM(1) = [M:ENM]STOFCY
    WPARAM(2) = num$([M:ENM]VCRTYP)
    WPARAM(3) = [M:ENM]VCRNUM
    Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
Endif

If !GIMPORT & GTRACE<>""
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif

FIN = 1
Return

#########################################################################
# Abandon transaction
#########################################################################
$AB_TRT
If dim(GDELDOC)<=0 | GDELDOC<>1
    Rollback
Endif
If LRET = 0 & GOK < 1
   LRET = 50
Endif

If !GIMPORT & GTRACE<>""
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif
FIN = 0
Return

