#**
#* CTL_VOLFIL
#*
#* @param _CLISRV : client=1 ; server=2
#* @param _PATH
#* @param _FULLPATH
#* @param _TYPE 0=read 1=write
#* @param _MESSAGE
#*!
Funprog CTL_VOLFIL(_CLISRV,_PATH,_FULLPATH,_TYPE,_MESSAGE)
Value Integer      _CLISRV
Value Char       _PATH
Variable Char _FULLPATH
Value Integer _TYPE
Variable Char _MESSAGE

Local Integer POS
Local Char VOLUME(250)
Local Char FILEKEY(250)
Local Integer ASTATUS

Raz _MESSAGE

If _CLISRV = 2
 If len(_PATH) & pat(_PATH,"[*]/*")
  [L]POS = instr(1,_PATH,']/')
  VOLUME =  mid$( _PATH,2, [L]POS-2)
  FILEKEY = right$(_PATH,[L]POS+2)
  _FULLPATH = func GETFULLPATH(VOLUME,FILEKEY)
  #112713 always check volume
  If _FULLPATH=""
   _MESSAGE = mess(47,149,1) : # Cet espace de stockage n'existe pas
   ASTATUS=  2
  Else
   ASTATUS = func ASYRSTO.CTL_PATH(_CLISRV, _FULLPATH, _TYPE,_MESSAGE)
  Endif
 Elsif len(_PATH) & pat(_PATH,"[*]")
  VOLUME =  mid$( _PATH,2, len(_PATH)-2)
  _FULLPATH = func GETFULLPATH(VOLUME,"")
   ASTATUS = func ASYRSTO.CTL_PATH(_CLISRV, _FULLPATH, _TYPE,_MESSAGE)
 Else
  _MESSAGE = mess(35,126,1) : # Nom de fichier incorrect
  ASTATUS=  2
 Endif
Endif

If ASTATUS
 Raz _FULLPATH
Endif
End ASTATUS

$ENUM_VOLFIL_TYPE
#E_TYPE_FILEREAD :  the file must exist
Local Integer E_TYPE_FILEREAD           : E_TYPE_FILEREAD=0
#E_TYPE_FILEWRITE : the path of the file has to be correct : prompt a dialog box if the file exists
Local Integer E_TYPE_FILEWRITE          : E_TYPE_FILEWRITE=E_TYPE_FILEREAD+1
#E_TYPE_FOLDER :  the folder must exist
Local Integer E_TYPE_FOLDER              : E_TYPE_FOLDER=E_TYPE_FILEWRITE+1
#E_TYPE_FILEOVERWRITE : the path of the file has to be correct : the file is overwritten if it already exits
Local Integer E_TYPE_FILEOVERWRITE : E_TYPE_FILEOVERWRITE=E_TYPE_FOLDER+1

Return


#**
#* FINDFILES
#*
#* @param PATTERN
#* @param EXIST
#*!
Subprog FINDFILES(PATTERN,EXIST)

Value    Char      PATTERN
Variable Integer EXIST

Local Char         MACHINE(GDIMFIC)
Local Char         PATH(GDIMFIC)
Local Char         FILENAM(250) ,DIRNAME(250) ,BASENAME(40) ,FILEEXT(30)
Local Integer     POS
Local Integer     NBFIC
Local Char         LISTEFIC(GDIMFIC)(1..1000)
Local Integer     ER

EXIST = 0
Call MACHINE(PATTERN,MACHINE,PATH) From ORDSYS
Call SETNAM(PATTERN,FILENAM,FILEEXT) From GOBJTXT

If MACHINE="#" & ((GBROWS & !GADXLOC) or GSERVEUR)
 EXIST = 0 : End
Endif

BASENAME = FILENAM

If len(FILEEXT)
 BASENAME += '.' + FILEEXT
Endif

DIRNAME = left$(PATTERN,len(PATTERN)-len(BASENAME))

POS = instr(1,BASENAME,'#')
If POS
# Issue X3-43015 - 2017-06-19 by CCC : This function must return EXIST=1 only if at least 1 file exists
#       It's up to the calling function to know what to do with the result
 BASENAME = ctrans(BASENAME,'#','*')
 Call SYSTEME2(MACHINE,"lsadx"-DIRNAME-'"'+BASENAME+'"',"",NBFIC,LISTEFIC) From ORDSYS
 NBFIC = min(NBFIC,dim(LISTEFIC))
 If NBFIC
  EXIST = 1
 Endif
##112713 when using #, the file may not exist (ex: recurring task)
#  EXIST = 1 : # Fichier normal
Else
 Local Integer INFO
 INFO = filinfo(PATTERN,0)

 If INFO<0
   EXIST = 0 : # Inexistant
 Elsif find(int(mod(INFO/2^12,16)),0,8)=0
  EXIST = 2 : # Répertoire
 Else
  EXIST = 1 : # Fichier normal
 Endif
Endif
End


#**
#* CTL_PATH
#*
#* @param _CLISRV : client=1 ; server=2
#* @param _PATH
#* @param _TYPE
#* @param _MESSAGE
#*!
Funprog CTL_PATH(_CLISRV,_PATH,_TYPE,_MESSAGE)
Value Integer _CLISRV
Value Char _PATH
Value Integer _TYPE
Variable Char _MESSAGE

Local Integer ER , K , STAT , OK
Local Char    REPERT(GDIMFIC) , FICHIER(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)
Local Char    NAM(GDIMFIC) , SUF(30) , PARAM(30)
Local Integer ASTATUS

Gosub ENUM_VOLFIL_TYPE
If _PATH=""
 _MESSAGE = mess(35,126,1) : # Nom de fichier incorrect
 ASTATUS=1 : End ASTATUS
Elsif _CLISRV=2 : # Serveur
 If left$(_PATH,1)="#"
  _MESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
  ASTATUS = 2 : End ASTATUS
 Endif
 Call MACHINE(_PATH,MACHINE,REPERT) From ORDSYS
 Call GET_OS(GACTX,MACHINE,OS) From ASYRSYS
 If OS=""
  _MESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
  ASTATUS = 2 : End ASTATUS
 Elsif OS="unix"
  If pat(left$(REPERT,3),"!:\")
   _MESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
   ASTATUS = 2 : End ASTATUS
  Elsif left$(REPERT,1)="\"
   _MESSAGE = mess(147,141,1) : # Répertoire inaccessible
   ASTATUS = 2 : End ASTATUS
  Endif
 Else
  If left$(REPERT,1)="/"
   _MESSAGE = mess(147,141,1) : # Répertoire inaccessible
   ASTATUS = 2 : End ASTATUS
  Endif
 Endif
 Raz ER
 #Call EXISTE(_PATH,ER) From ORDSYS
 Call FINDFILES(_PATH,ER)
 Case ER
  When 0 : # file or folder not found
   If find(_TYPE, E_TYPE_FILEREAD,E_TYPE_FOLDER)
    _MESSAGE = mess(159,141,1) : # Fichier ou répertoire inexistant
    ASTATUS   = 2
   Else
    ASTATUS   = 0
   Endif
  When 1 : # it is a file :
    Case  _TYPE
     When E_TYPE_FILEREAD,E_TYPE_FILEOVERWRITE :# read access or overwritte
      ASTATUS   = 0
     When E_TYPE_FILEWRITE
      # Fichier existant. Désirez-vous l'écraser ?
      #Call AVERTIR(mess(170,115,1),OK) From GESECRAN
      Call AVERTIR(_PATH +"\"+ mess(170,115,1),OK) From GESECRAN    # Issue X3-43015 - 2017-06-20 by CCC : add file path for sequence export
      If OK<>2
       ASTATUS = 2 : End ASTATUS
      Endif
     When E_TYPE_FOLDER
      _MESSAGE = mess(117,139,1) : # Ce fichier n'est pas un répertoire
      ASTATUS = 2
    Endcase
   When 2 : # it is a folder
    If find(_TYPE, E_TYPE_FILEREAD,E_TYPE_FILEWRITE,E_TYPE_FILEOVERWRITE)
     _MESSAGE = mess(55,141,1) : # Ce fichier est un répertoire
     ASTATUS = 2
    Else
     ASTATUS = 0
    Endif
 Endcase
Endif
End ASTATUS


