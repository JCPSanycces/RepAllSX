#* @param FILEKEY
#* @param BLOB
#*!
Funprog WRITEBLOB(VOLUME,FILEKEY,BLOB)
Value Char       VOLUME
Value Char       FILEKEY
Variable Blbfile BLOB

Local Integer  ASTATUS: ASTATUS=0
Local Instance IVOLUME Using C_AVOLUME

ASTATUS = func OPEN(VOLUME,IVOLUME)
If ASTATUS = CST_AOK
 ASTATUS = fmet IVOLUME.WRITEBLOB(FILEKEY,BLOB)
Endif
FreeGroup IVOLUME
End ASTATUS


#**
#* OPEN
#*
#* @param NAME
#* @param IVOLUME
#*!
Funprog OPEN(NAME,IVOLUME)
Value Char NAME
Variable Instance  IVOLUME Using C_AVOLUME

Local Integer ASTATUS

IVOLUME = NewInstance C_AVOLUME AllocGroup null
ASTATUS = fmet IVOLUME.AREAD(NAME)

If ASTATUS = CST_AERROR & find(NAME,"TRA","TMP")
 IVOLUME.VOLUME = NAME
 Case NAME
  When "TRA" :
   IVOLUME.ROOT = NAME
   IVOLUME.TITLE  = "Fichiers de trace"
  When "TMP" :
   IVOLUME.ROOT = tolower(NAME)
   IVOLUME.TITLE  = "Fichiers temporaires"
 Endcase
 IVOLUME.VOLTYP = 1
 ASTATUS = fmet IVOLUME.AINSERT()
Endif

End ASTATUS

#**
#* GETFULLPATH
#*
#* @param VOLUME
#* @param NAME
#*!
Funprog GETFULLPATH(VOLUME,FILEKEY)
Value Char VOLUME
Value Char FILEKEY
Local Char FULLPATH(250)

Local Instance IVOLUME Using C_AVOLUME
Local Char OS(20)

IVOLUME = NewInstance C_AVOLUME AllocGroup null
ASTATUS = fmet IVOLUME.AREAD(VOLUME)
If !ASTATUS
 FULLPATH = filpath(IVOLUME.ROOT,"","",IVOLUME.ACTX.AFOLDER)
 If len(FILEKEY)
  FULLPATH += "/" + FILEKEY
 Endif
 Call GET_OS(GACTX,adxmac(0),OS) From ASYRSYS
 If OS="unix"
  FULLPATH  = ctrans(FULLPATH,"\\","/")
 Else
  FULLPATH  = ctrans(FULLPATH,"/","\\")
 Endif
Endif
FreeGroup IVOLUME
End FULLPATH

#**
#* GETTEMPFILENAME
#*!
Funprog GETTEMPFILENAME()
End "U"+ timestamp$ + ".tmp"
#**
#* UPLOAD
#*
#* @param FNAME (out): name of the file created on the server by the upload operation
#* @param FULLPATH (out) : file's full path on the server
#*!
Funprog UPLOAD(FNAME,FULLPATH)
Variable Char FNAME
Variable Char FULLPATH

Local Integer ASTATUS
Local Char UIURL(250)
Local Char ENDPOINTL(250)
Local Char ASKUIRC(250)
Local Integer POS
Local Char MESSAGE(250)
Local Integer UIMAXLENGTH
Local Char TEMPPATH(250),SRVNAME(250),SRVPATH(250)
Local Integer STAT

Gosub ENUM_VOLFIL_TYPE

Raz FNAME

ENDPOINTL = baseUrl
While 1
 POS = instr(1,ENDPOINTL,"/")
 Break (POS=0)
 ENDPOINTL = right$(ENDPOINTL,POS+1)
Wend
If len(FNAME)
 UIURL = "/sdata/x3/erp/"+ENDPOINTL+"/$service/upload?fileName=" + FNAME
Else
 UIURL = "/sdata/x3/erp/"+ENDPOINTL+"/$service/upload"
Endif
#max length set to the max size of a BLOB(12) = 4M
UIMAXLENGTH =[V]CST_AUIMAXLENGTH

Askui ASKUIRC = ""  With   "UIAsk=" + chr$(1) + "upLoadFile",
& "UIUrl=" + chr$(1) + UIURL,
& "UIMaxLength=" + chr$(1) + num$(UIMAXLENGTH),
& "UIContentType=" + chr$(1) + "application/octet-stream"

ASTATUS = val(ASKUIRC)
If  ASTATUS = 1 :# upload OK
  # compute the file created on the server :
  FNAME = right$(ASKUIRC,instr(1,ASKUIRC,',')+1)
  SRVNAME =  '[TMP]/' + FNAME
  ASTATUS = func ASYRSTO.CTL_VOLFIL(2, SRVNAME,TEMPPATH,E_TYPE_FILEOVERWRITE,MESSAGE)
  If ASTATUS = 0
   ASTATUS = 1 : #upload OK
   If len(FULLPATH)
    # Move the file to the correct volume :
    STAT = func ASYRSTO.CTL_VOLFIL(2,FULLPATH,SRVPATH,E_TYPE_FOLDER,MESSAGE)
    If STAT<>0
     STAT = func ASYRSTO.CTL_VOLFIL(2,FULLPATH,SRVPATH,E_TYPE_FILEOVERWRITE,MESSAGE)
     If STAT <> 0
      SRVPATH = FULLPATH
      STAT = func ASYRSTO.CTL_PATH(2, SRVPATH, E_TYPE_FILEOVERWRITE,MESSAGE)
     Endif
    Endif
    If !STAT
     # let's move the file to the correct volume :
     Call MOVE(TEMPPATH,SRVPATH,STAT) From ORDSYS
     FULLPATH = SRVPATH
     If STAT : #101513 : check file copy
      ASTATUS = 0 : #error
     Endif
    Endif
   Else
    FULLPATH = TEMPPATH
   Endif
  Else
   ASTATUS = -1 : #error
  Endif
Endif
End ASTATUS


Funprog AGET_VOLFILURL(CTX,FULLURL,FULLNAME,WURL)
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT : # Context where the errors messages are stored
Value Integer FULLURL          :  # ful url true or false
Variable Clbfile FULLNAME
Variable Clbfile WURL

Local Integer ASTATUS,POS
Local Char VOLUME(250),FILEKEY(250)

#WURL = "http://sosyrsuperv:8124/sdata/x3/erp/superv/BDOC('C_AVOLFIL~%C2%A8~CONTENTS~%C2%A8~TMP~%C2%A8~000002.jpg')"
If len(FULLNAME) & pat(FULLNAME,"[*]/*")
 [L]POS = instr(1,FULLNAME,']/')
 VOLUME =  mid$( FULLNAME,2, [L]POS-2)
 FILEKEY = right$(FULLNAME,[L]POS+2)
Endif
WURL = baseUrl + "/BDOC('C_AVOLFIL~%C2%A8~CONTENTS~%C2%A8~"
WURL += VOLUME
WURL += "~%C2%A8~"
WURL += FILEKEY
WURL += "')"
End [L]ASTATUS


Funprog AGET_VOLFILPATH(VOLFILPATH)
Variable Char VOLFILPATH

Local Clbfile PATH

Local Integer POS
Local Char VOLUME(250),FILEKEY(250)

PATH=""
If len(VOLFILPATH) & pat(VOLFILPATH,"[*]/*")
 [L]POS = instr(1,VOLFILPATH,']/')
 VOLUME =  mid$( VOLFILPATH,2, [L]POS-2)
 FILEKEY = right$(VOLFILPATH,[L]POS+2)
 PATH = func GETFULLPATH(VOLUME,FILEKEY)
Endif
End PATH

