#**
#* READCLOB
#*
#* @param VOLUME
#* @param FILEKEY
#* @param CLOB
#*!
Funprog READCLOB(VOLUME,FILEKEY,IUM,CLOB)
Value Char       VOLUME
Value Char       FILEKEY
Value Integer    IUM
Variable Clbfile CLOB

Local Integer  ASTATUS: ASTATUS=0
Local Instance IVOLUME Using C_AVOLUME


IVOLUME = NewInstance C_AVOLUME AllocGroup null
ASTATUS = fmet IVOLUME.AREAD(VOLUME)
If !ASTATUS
 ASTATUS = fmet IVOLUME.READCLOB(FILEKEY,IUM,CLOB)
Endif
FreeGroup IVOLUME
End ASTATUS

