#######################  TRTPARAM  ########################################
#######################  SUBPROG ########################################
##Subprog CHXFIC()  Selection d'une table dans une liste
##Subprog CHARFIC() Récupération des informations libellé et abreviation
##                  du fichier précédemment sélectionné ou saisi
##Subprog CHXCRIT() Selection d'une rubrique fichier dans une fenêtre avec
##                  récupération du code et éventuellement de l'indice
##Subprog CHARCRIT()Récupération des informations code, libellé, longueur
##                  Type,Menu local ... d'une rubrique fichier précedemment
##                  selectionnée ou saisie
##Subprog SELVAR() : Sélection d'une rubrique dico dans une fenêtre.
##                   Reprise et modif de SELVAR From SELFIC car il faut
##                   pouvoir enlever certaines rubriques de la liste standard.
##
##Gosub SAIDIME    : Saisie éventuelle de l'indice pour les rubriques
##                   de dimension 1 dans le dico mais dont le type de
##                   donnée associé à un code activité sous-entend une
##                   rubrique occursée ( ex type de donnéé CCE ou REP.)
##                                                 sr Novembre 1997
#########################################################################
##Subprog CHXFIC()  Selection d'une table dans une liste
##EN ENTREE : Le code traitement qui permet de choisir ce que
## l'on veut voir dans la fenêtre et de savoir si l'on vient
##d'un tableau ou d'une fiche :
##      CODE = 1 à 3 : On vient d'un tableau
##      CODE = 1 : On ne veut que les codes fichiers
##      CODE = 2 : On veut le code fichier et le libellé
##      CODE = 3 : On ne veut que les libellés
##      CODE = 4 à 6 (idem 1 à 3 mais pour une fiche)
##      NBLIB  = nombre de postes du tableau
##      TBLIB  = tableau contenant les fichiers à afficher
##      VALEUR = valeur courante du code fichier
##EN SORTIE : On renseigne VALEUR
##Exemple d'appel :
##Call CHXFIC(1,NBLIB,FICFIC,VALEUR)
###########################################################################
Subprog CHXFIC(CODE,NBLIB,TBLIB,VALEUR)
Value Integer CODE,NBLIB
Value Char TBLIB()(0..)
Variable Char VALEUR()

Local Integer I,NO
Local Char TAB(50)(0..NBLIB)
If clalev ([F:ATB]) <= 0 : Local File ATABLE [ATB] : Endif
If clalev ([F:ATX]) <= 0 : Local File ATEXTE [ATX] : Endif
For I = 1 To NBLIB
 Read [F:ATB]CODFIC = TBLIB(I-1)
 Read [F:ATX]NUMERO =GLANGUE;[F:ATB]INTITFIC
 If CODE = 1 | CODE = 4 TAB(I) = TBLIB(I-1)
 Elsif CODE =2 | CODE = 5 TAB(I) = format$("K:12X",TBLIB(I-1))
&                                   + [F:ATX]TEXTE
 Else                     TAB(I) = [F:ATX]TEXTE
 Endif
Next
NO = find(VALEUR,TBLIB(0..NBLIB-1))
Call SAITEX(NBLIB,TAB,NO,mess(10,141,1)) From GESECRAN
If NO = 0 : End : Endif
VALEUR = TBLIB(NO-1)
End

#########################################################################
##Subprog CHARFIC() Récupération des informations libellé et abreviation
##du fichier précédemment sélectionné ou saisi
##EN ENTREE : Le CODE qui permet de savoir si on vient d'un tableau
##ou d'une fiche:
##           CODE < 4 : On vient d'un tableau
##           CODE > 3 : On vient d'une fiche
##           LIBFIC = la zone écran réceptrice du libellé du fichier
##           ABVFIC = la zone écran réceptrice de l'abréviation du fic
##           MASQ   = le nom du masque actif
##           VALEUR = La valeur courante
##EN SORTIE on renvoie les zones écrans libellé et abrev.
##Exemple d'appel :
##Call CHARFIC(1,"FILDES","ABB","PAC1",VALEUR)
######################################################################
Subprog CHARFIC(CODE,LIBFIC,ABVFIC,MASQ,VALEUR)
Value Integer CODE
Value Char LIBFIC,ABVFIC,MASQ
Variable Char VALEUR()

If clalev ([F:ATB]) <= 0 : Local File ATABLE [ATB] : Endif
If clalev ([F:ATX]) <= 0 : Local File ATEXTE [ATX] : Endif
Read [F:ATB]CODFIC = VALEUR
If fstat : mkstat = 1 : End : Endif
Read [F:ATX]NUMERO = GLANGUE;[F:ATB]INTITFIC
If fstat : mkstat = 1 : End : Endif
If CODE < 4
 Assign "[M:"+MASQ+"]"+LIBFIC+"(nolign-1)" With [F:ATX]TEXTE
 Assign "[M:"+MASQ+"]"+ABVFIC+"(nolign-1)" With [F:ATB]ABRFIC
Else
 Assign "[M:"+MASQ+"]"+LIBFIC With [F:ATX]TEXTE
 Assign "[M:"+MASQ+"]"+ABVFIC With [F:ATB]ABRFIC
Endif
End


###############################################################
# Recherche du libellé d'un champ d'une table suivant GLANGUE #
# ----------------------------------------------------------- #
# Paramètres à passer au sous-programme :                     #
#   - WNOMFIC   : Nom de la table                             #
#   - WNOMCHAMP : Nom du champ de la table                    #
# Chargement en sortie                                        #
#   - WLIBELLE  : Intitulé du champ dans la langue courante   #
###############################################################
Subprog CHARCRIDES(WNOMFIC,WNOMCHAMP,WLIBELLE)
Value    Char WNOMFIC()
Value    Char WNOMCHAMP
Variable Char WLIBELLE
#-----
If !clalev([F:ATZ])  Local File ATABZON [ATZ] : Endif
If !clalev([F:ATX])  Local File ATEXTE  [ATX] : Endif
#-----
Read [ATZ] CODZONE=WNOMFIC;WNOMCHAMP
If !fstat
  Read [ATX] NUMERO=GLANGUE;[F:ATZ]NOLONG
  If !fstat  WLIBELLE=[F:ATX]TEXTE : Endif
Endif
End


#########################################################################
##Subprog CHXCRIT() : Selection d'une rubrique fichier dans une fenêtre
##Avec récupération du code et éventuellement de l'indice
##et mise-à-jour automatique des zones du masque passé en paramètre
##EN ENTREE :Le code traitement qui permet de savoir si on vient d'un
##tableau ou d'une fiche:
##      CODE = 1 On vient d'un tableau
##      CODE = 2 On vient d'une fiche
##      NOMFIC = le code fichier
##      ABVFIC = l'abréviation du fichier
##
##      INDCRIT = le nom de la zone écran receptrice de l'indice de la rub
##      MASQ    = le nom du masque à mettre à jour
##      VALEUR  =  la valeur courante du critere
##EN SORTIE : On récupère VALEUR et éventuellement l'indice de la rub.
## exemple d'appel :
## Call CHXCRIT(1,[M:PAC1]FIL(NOL),[M:PAC1]ABB(NOL),"CRIIND","PAC1",VALEUR) from trtparam
############################################################################
Subprog CHXCRIT(CODE,NOMFIC,ABVFIC,INDCRIT,MASQ,VALEUR)
Value Char NOMFIC,ABVFIC,INDCRIT,MASQ
Value Integer CODE
Variable Char    VALEUR()
Local Char WVAL
Local Integer NOL, I

WVAL = VALEUR
NOL = nolign-1
Local File  = NOMFIC [XXX]

Call SELVAR(NOMFIC,ABVFIC,WVAL)
If mkstat : End : Endif


VALEUR = WVAL

#Recherche de la dimension REELLE de la rubrique dans le fichier(ex CCE)
#On autorise que certaines rubriques occursées
If evalue("dim("+WVAL+")") > 1
   If !find(WVAL,"CCE","TSICOD","TSSCOD","TSCCOD")
      Call MESSAGE(mess(66,196,1)) From GESECRAN
      mkstat = 1
      VALEUR = ""
   Endif
Endif

Close File [XXX]

End

#########################################################################
##Subprog CHARCRIT() : Récupération des informations code, libellé, longueur
##Type,Menu local ... d'une rubrique fichier précedemment selectionnée
##ou saisie
##EN ENTREE : Le CODE qui permet de savoir si on vient d'un tableau
##ou d'une fiche
##            CODE = 1 on vient d'un tableau
##            CODE = 2 on vient d'une fiche
##            NOMFIC = Le code fichier
##
##            LONG = Le nom de la zone receptrice de la longueur du critère
##            FLDTYP = Le nom de la zone receptrice du type de donnée du critère
##            NOLIB = Le nom de la zone receptrice du numéro de menu local
##            MASQ = Le nom du masque actif
##            VALEUR = La valeur courante
##EN SORTIE  on renvoie les zones écrans libellé, longueur, indice
##           Type de donnee, menu local
##Exemple d'appel :
##Call CHARCRIT(1,[M:PAC1]FIL(NOL),"CRIDES","LONG","FLDTYP","PPUMNU","PAC1",VALEUR)
###############################################################################
Subprog CHARCRIT(CODE,NOMFIC,LIBCRIT,LONG,FLDTYP,NOLIB,MASQ,VALEUR)
Value Char NOMFIC,LIBCRIT,LONG,FLDTYP,NOLIB,MASQ
Value Integer CODE
Variable Char VALEUR()

Local Integer I,NOL,NUMLIB,TOTLNG,J,TABDIV
Local Char WVAL,WTYPE

Local Char TYPNOK (5) (30) : # types de donnée non autorises
TYPNOK (0)="MC1" : TYPNOK (1)="MC2" : TYPNOK (2)="MC3" : TYPNOK (3)="MC4" : TYPNOK (4)="MC5"
TYPNOK (5)="MD0" : TYPNOK (6)="MD1" : TYPNOK (7)="MD2" : TYPNOK (8)="MD3" : TYPNOK (9)="MD4"
TYPNOK(10)="MD5" : TYPNOK(11)="MD6" : TYPNOK(12)="MD7" : TYPNOK(13)="MD8"
TYPNOK(14)="MS1" : TYPNOK(15)="MS2" : TYPNOK(16)="MS3" : TYPNOK(17)="MS4"
TYPNOK(18)="QTY"
TYPNOK(19)="QT1" : TYPNOK(20)="QT2" : TYPNOK(21)="QT3" : TYPNOK(22)="QT4" : TYPNOK(23)="QT5"

If clalev ([F:ATZ]) <= 0 : Local File ATABZON [ATZ] : Endif
If clalev ([F:ATY]) <= 0 : Local File ATYPE   [ATY] : Endif
NOL = nolign-1
Read [F:ATZ]CODZONE = NOMFIC;VALEUR
If fstat : mkstat = 1 : GMESSAGE = mess (41,100,1) : End : Endif
WTYPE = [F:ATZ]CODTYP
If find(WTYPE,TYPNOK)                 : # <jl> m.a.j. des interdictions
    Call MESSAGE(mess(66,196,1)) From GESECRAN
    mkstat = 1
    End
Endif
########################################
# Récupération du libellé de la rubrique
NUMLIB = [F:ATZ]NOLONG
Read [F:ATX]NUMERO = GLANGUE;NUMLIB
If CODE = 1 : Assign "[M:"+MASQ+"]"+LIBCRIT+"(nolign-1)"With [F:ATX]TEXTE
Else        : Assign "[M:"+MASQ+"]"+LIBCRIT With [F:ATX]TEXTE
Endif

############################################
# Récupération de la longueur de la rubrique
# Si la rubrique est de type alpha ou numerique
If [F:ATZ]CODTYP = "A" | [F:ATZ]CODTYP = "C" | [F:ATZ]CODTYP = "L"
 If CODE = 1
  Assign "[M:"+MASQ+"]"+LONG+"(nolign-1)"With [F:ATZ]LONG
 Else : Assign "[M:"+MASQ+"]"+LONG With [F:ATZ]LONG
 Endif
#Si la rubrique est de type menu local
Elsif [F:ATZ]CODTYP = "M"
 If CODE = 1 : Assign "[M:"+MASQ+"]"+LONG+"(nolign-1)" With 3
               Assign "[M:"+MASQ+"]"+NOLIB+"(nolign-1)" With [F:ATZ]NOLIB
 Else        : Assign "[M:"+MASQ+"]"+LONG With 3
               Assign "[M:"+MASQ+"]"+NOLIB With [F:ATZ]NOLIB
 Endif
#Si la rubrique est de type date
Elsif [F:ATZ]CODTYP = "D"
 If CODE = 1 : Assign "[M:"+MASQ+"]"+LONG+"(nolign-1)" With 8
 Else        : Assign "[M:"+MASQ+"]"+LONG With 8
 Endif
#Si la rubrique est de type DCB
Elsif [F:ATZ]CODTYP = "DCB"
 If CODE = 1 : Assign "[M:"+MASQ+"]"+LONG+"(nolign-1)" With evalue(ctrans(num$([F:ATZ]LONG),".","+"))
 Else        : Assign "[M:"+MASQ+"]"+LONG With evalue(ctrans(num$([F:ATZ]LONG),".","+"))
 Endif
#Si la rubrique est de type ADI : Table diverse
Elsif [F:ATZ]CODTYP = "ADI"
    J = instr(1,[F:ATZ]EXPLIEN,";")
    #----- Modification MBT le 29/11/2010 (longueur pour les codes statistiques -----#
   #If J : TABDIV = val(left$([F:ATZ]EXPLIEN,J-1)) : Endif
    If J
      Local Char WEXPLIEN(30)
      WEXPLIEN=left$([F:ATZ]EXPLIEN,J-1)
      J=instr(1,WEXPLIEN,"indice")
      If J
        TABDIV=val(right$(WEXPLIEN,J+6))
      Else
        TABDIV=val(WEXPLIEN)
      Endif
    Endif
    #-----
    If TABDIV<>0
        If clalev ([F:ADV]) <= 0 : Local File ATABTAB [ADV] : Endif
        Read [F:ADV]CODE = TABDIV
        If fstat Raz [F:ADV] Endif
        If CODE = 1 : Assign "[M:"+MASQ+"]"+LONG+"(nolign-1)" With evalue(ctrans(num$([F:ADV]LNG),".","+"))
        Else        : Assign "[M:"+MASQ+"]"+LONG With evalue(ctrans(num$([F:ADV]LNG),".","+"))
        Endif
    Endif
Else
#Si la rubrique est d'un autre type
  If [F:ATZ]CODTYP <>""
   Read [F:ATY]CODTYP = [F:ATZ]CODTYP
   Assign "[M:"+MASQ+"]"+LONG+"(nolign-1)" With evalue(ctrans(num$([F:ATY]LNGTYP),".","+"))
#Si le type de donnée n'est pas renseigné
  Else mkstat = 1
     Call MESSAGE(mess(4,176,1)) From GESECRAN
     End
  Endif
Endif

###############################
#Récupération du type de donnée
If CODE = 1
 Assign "[M:"+MASQ+"]"+FLDTYP+"(nolign-1)" With [F:ATZ]CODTYP
Else
 Assign "[M:"+MASQ+"]"+FLDTYP With [F:ATZ]CODTYP
Endif
End
####################################################
Subprog SELVAR(FICHIER,ABREV,VARIA)
####################################################
Variable Char FICHIER()
Variable Char ABREV()
Variable Char VARIA()
Onerrgo ERREUR From CONTROLE
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

$SELV
Call SAVBOUT From GESECRAN
Onerrgo ERREUR From CONTROLE
Local Mask SELVAR [SVAR]
Local Dlgbox Mask [SVAR]
& Button mess(64,123,1),mess(65,123,1)
& With left$(mess(64,123,1),1) , left$(mess(65,123,1),1)
& Coded GSTAOK , GSTAFIN
& Titled mess(109,124,1)
& As [SVAR]
# Choix d'un champ
Onerrgo
If GERREUR : GERREUR=0 : End : Endif
# Issue 108342  - 2015-11-06 by MAE : ABRFIC passage de 3 à 8
#Local Char    ABFIC(5)
Local Char    ABFIC(GLONABR)
Local Integer ETABOU(1..GNBBOU) , REPONSE
Local Integer SAVGOBJET

SAVGOBJET = GOBJET
GOBJET = 0
Boxact [SVAR]

Raz ETABOU
ETABOU(GABAN) = 1
ETABOU(GVALI) = 1
Call SETBOUT(ETABOU) From GESECRAN
Raz [M]
If FICHIER<>""
 [M]FICHIER = FICHIER
 Affzo FICHIER
 Gosub REMPLIT
 Grizo FICHIER
 zonsui = "NBLIG"
 [M]LIGNE = 1
Endif

$SAIFIC
Boxinp [SVAR] Using REPONSE
Case REPONSE
 When GSTARET
  Goto SAIFIC
 When GSTAOK
  FICHIER = [M]FICHIER
  ABREV   = [M]ABFIC
  VARIA   = [M]CODZONE([M]LIGNE-1)
 When Default : mkstat = 1
Endcase
Call RESTBOUT From GESECRAN
Boxclr [SVAR]
GOBJET = SAVGOBJET
End

$REMPLIT
Read [ATB]CODFIC = [M]FICHIER
[M]ABFIC = [F:ATB]ABRFIC
Call TEXTE([F:ATB]INTITFIC,[M]INTIT) From OBJDIV
Filter [F:ATZ] Where CODFIC = [M]FICHIER
&                    &!find(CODTYP,"QTY","MD1","MD2","MD3","MD4","MS1","MS2","MS3","MS4")
&                   & DIME < 2

nolign = 0
For [ATZ]CODTYP
 nolign += 1
 [M] = [F:ATZ]
 Call TEXTE([M]NOCOURT(nolign-1),[M]INTITZONE(nolign-1)) From OBJDIV
Next
Filter [F:ATZ]
[M]NBLIG = nolign
Affzo INTIT,30
Return

Subprog AM_FICHIER(VALEUR)
Variable Char VALEUR   # FGR 01/02/2010 : X3SUIVI60986 : Pas FICHIER()

[M]FICHIER = VALEUR
Gosub REMPLIT
[M]LIGNE = 0
End

Subprog C_NBLIG
[M]LIGNE = nolign-1
End

