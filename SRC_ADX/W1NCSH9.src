#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSH9 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:31"
A_USER  = "DOC"
A_STAMP = "20181109230531"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG9"
  If [M]NBLIG9=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask NCSH9 [NCSH9]
Gosub HORODAT
Local Inpbox "NCSH9" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSH9] As [SIM_]
Grizo [NCSH9]5
Grizo [NCSH9]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [NCSH9]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=138 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=138 : Y1(1)=3 : Y2(1)=28
Return

$ON_DOCNCSQTY
Onevent BEFORE_AREA Gosub AV_DOCNCSQTY From W1NCSH9
Return

$AV_DOCNCSQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]DOCNCSQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_DOCDOCQTY
Onevent BEFORE_AREA Gosub AV_DOCDOCQTY From W1NCSH9
Return

$AV_DOCDOCQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]DOCDOCQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_DOCSTU
Return

$ON_ZDOCSTU
Onevent BEFORE_AREA Gosub AV_ZDOCSTU From W1NCSH9
Return

$AV_ZDOCSTU
Call LECTEXTRA(zc,"TABUNIT","DES",num$([M]DOCSTU(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_NCSQTYSUM
Onevent BEFORE_AREA Gosub AV_NCSQTYSUM From W1NCSH9
Return

$AV_NCSQTYSUM
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Gosub _AFF
Return

$ON_SELLIN
Onevent AFTER_CHANGE Gosub AMM_SELLIN From W1NCSH9
Onevent INIT_AREA Call D_SELLIN(zc) From W1NCSH9
Onevent BEFORE_INPUT Call AS_SELLIN(zc) From W1NCSH9
Return

Subprog D_SELLIN(VALEUR)
Variable Integer VALEUR
If varinit([M]SELLIN,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SELLIN(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_SELLIN
Call AM_SELLIN(zc)
If !mkstat & GOBJET
 zoncou = "SELLIN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SELLIN(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_SELLIN(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "SELLIN" : GZNUM = 8255 : Endif
Gosub _AFF
End

$ON_NCSQTY
Onevent BEFORE_AREA Gosub AV_NCSQTY From W1NCSH9
Onevent CONTROL Call C_NCSQTY(zc) From W1NCSH9
Onevent AFTER_CHANGE Gosub AMM_NCSQTY From W1NCSH9
Return

$AV_NCSQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]NCSQTY(indice) With "N+z:"+GUNTFMT
Gosub _AFF
Return

Subprog C_NCSQTY(VALEUR)
Variable Decimal VALEUR
## Action STD
Call C_NCSQTY(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "NCSQTY" : GZNUM = 1004207 : Endif
Gosub _AFF
End

$AMM_NCSQTY
Call AM_NCSQTY(zc)
If !mkstat & GOBJET
 zoncou = "NCSQTY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NCSQTY(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_NCSQTY(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "NCSQTY" : GZNUM = 1004207 : Endif
Gosub _AFF
End

$ON_DOCQTY
Onevent BEFORE_AREA Gosub AV_DOCQTY From W1NCSH9
Return

$AV_DOCQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]DOCQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$CHG_STY
Return


