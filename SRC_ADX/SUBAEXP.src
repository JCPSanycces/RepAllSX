######################################################################################
Subprog AP_ALTERNAT(VALEUR)
Variable Integer VALEUR
End


Subprog AV_VISTIT(VALEUR)
Variable Char    VALEUR()
If [M:AEX4]STYTIT<>""
  Read [AS_Y]ASY0=[M:AEX4]STYTIT
  If fstat=0
    Call TEXTE([F:AS_Y]DES,VALEUR) From OBJDIV
    Chgstl [M:AEX4]VISTIT With [M:AEX4]STYTIT
  Endif
Else
  Raz VALEUR
  Chgstl [M:AEX4]VISTIT With ""
Endif
End


