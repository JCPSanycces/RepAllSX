#<AdxTL>@(#)12.0.0.0 $Revision$


$ACTION
Case ACTION
  When "DEBUT"  : Gosub DEBUT
  When "OK"     : Gosub OK
Endcase
Return


$OK
 Transmask [M:AEX1] To [M:AEY1]
 Transmask [M:AEX2] To [M:AEY2]
 Transmask [M:AEX4] To [M:AEY4]
 Transmask [M:AEX5] To [M:AEY5]
Return

$SAVMM
If filinfo(filpath("ETM",GUSER+"_"+GMASK+"_"+GZONE+"_"+"STD","aexp",0),0) >0 & 0
 Effzo [M:AEX0]
 Effzo [M:AEX1]
 Effzo [M:AEX2]
 Effzo [M:AEX4]
 Effzo [M:AEX5]
 Call LECMEMORET("STD","AEX1,AEX4,AEX2,AEX5,AEX8",GMASK+"_"+GZONE+"~aexp",1,GBIDI1) From GMEMO
Endif
Return


$DEBUT
Transmask [M:AEY1] To [M:AEX1]
Transmask [M:AEY2] To [M:AEX2]
Transmask [M:AEY4] To [M:AEX4]
Transmask [M:AEY5] To [M:AEX5]
[M:AEX0]TIT=[M:AEX8]ATIT
If clalev([F:ASB])=0 : Local File ABLBSYS [ASB]  : Endif
Local Integer NOIMAG : NOIMAG=[M:AEX1]DESIGN
Gosub AFFIMAG
Affzo [M:AEX0]
Affzo [M:AEX1]
Affzo [M:AEX2]
Affzo [M:AEX4]
Affzo [M:AEX5]
Return


$AFFIMAG
If [M:AEX1]TABDYN<>2 or NOIMAG=0 : Return : Endif
Local Char TIMAG
TIMAG="EXCDES"+FORMAT$("N0:##",NOIMAG)
Read [ASB]ASB0="SCR";TIMAG
If fstat=0
  [M:AEX1]IMAG=[F:ASB]BLOB
Else
  Raz [M:AEX1]IMAG
Endif
Return


# Gestion du masque AEXP0

