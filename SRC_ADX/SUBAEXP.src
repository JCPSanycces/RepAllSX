If VALEUR=2 : End : Endif
# On réinitialise les zones dans le tableau (à voir)

End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran AEXP2) 29/05/2008 14:41:49 (CCORA)
######################################################################################
Subprog C_ORDCH(VALEUR)
Variable Decimal VALEUR

Local Integer I
For I=0 To [M:AEX2]NBCH-1
  If I<>nolign-1 and [M:AEX2]ORDCH(I)=VALEUR
#    Code déjà existant en ligne nn
    GMESSAGE=mess(149,150,1)-num$(I+1)
    mkstat=2
    Break 1
  Endif
Next I

End


