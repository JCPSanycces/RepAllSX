######################################################################################
Subprog AS_DESIGN(VALEUR)
Variable Integer VALEUR
If [M:AEX1]TABDYN=1
  mkstat=1
Endif
End

Subprog AM_DESIGN(VALEUR)
Variable Integer VALEUR
NOIMAG=VALEUR
Gosub AFFIMAG
Affzo [M:AEX1]IMAG
End


Subprog C_DESIGN(VALEUR)
Variable Integer VALEUR
If VALEUR<0 or VALEUR>22
#  "Valeur incorrecte  (1 - 22)"
  GMESSAGE=mess(83,123,1)-" (1 - 22)"
  mkstat=2
Endif
End


