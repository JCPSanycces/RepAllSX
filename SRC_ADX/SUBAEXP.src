######################################################################################
## Etiquette ajoutée par le superviseur (écran AEXP1) 13/10/2006 10:04:19 (CCORA)
######################################################################################
Subprog AM_LIGCUM(VALEUR)
Variable Integer VALEUR
#  Traitements des cumuls
Local Integer NBL
For NBL=0 To [M:AEX2]NBCH-1
  If [M:AEX2]FORMCH(NBL)="N"
    [M:AEX2]CUMCH(NBL)=VALEUR 
  Else
    [M:AEX2]CUMCH(NBL)=1
  Endif
Next NBL
Affzo [M:AEX2]
End


