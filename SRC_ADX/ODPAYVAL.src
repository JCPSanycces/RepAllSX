#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA - 2017-02-18- X3-11491- START
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ODPAYVAL","DODPAYVAL",3,"") From GTRAITE
End

################################################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub OUVRE
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : TRA = 1
 When "EXEC"       : Gosub EXEC
 When "SEL_TABLE"  : Gosub SEL_TABLE
Endcase
Return

$OUVRE
Local Integer STAT, OKOD
Local Char    PCEAUTO(10), MESSA(250), CRIT(250), CRITERE(250), IDENT(30)(1.1)
Local Char    SYMBOLE(80) :#Attention car en réalité SYMBOLE limite superv à 50 caract !(Cf. table APLLCK)
If clalev([F:VEP])=0  : Local File VALEMP [VEP]  : Endif
If clalev([F:TB0])=0  : Local File ODPAYE [TB0]  : Endif
If clalev([F:TB1])=0  : Local File ODPAY  [TB1]  : Endif
If clalev([F:ODP1])=0 : Local File ODPAY  [ODP1] : Endif
If clalev([F:ODA])=0  : Local File ODPAYA [ODA]  : Endif
Local Char CRITPST (250)    : ##**108465
Return

$INIT_DIA
Raz [M:DIA]
Return

$EXEC
If GSERVEUR
 [M:DIA]TRCFLG = 2
Endif
If !GSERVEUR & [M:DIA]TRCFLG=2
#MIPEA - 2017-02-18- X3-11491- START
 Call OUVRE_TRACE(mess(69,10703,1)) From LECFIC : # Validation Od de paye
# Call OUVRE_TRACE(mess(69,703,1)) From LECFIC : # Validation Od de paye
#MIPEA - 2017-02-18- X3-11491- END
Endif
If [M:DIA]TRCFLG=2
#MIPEA - 2017-02-18- X3-11491- START
 Call ECR_TRACE(mess(69,10703,1),0) From GESECRAN
# Call ECR_TRACE(mess(69,703,1),0) From GESECRAN
#MIPEA - 2017-02-18- X3-11491- END
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

##**108465
#CRITERE = "[F:TB1]PST=1" #non validée
If [M:DIA]SIMFLG=2
 CRITPST="1=1"
Else
 CRITPST="[F:TB1]PST=1"
Endif
CRITERE = "1=1"
##**

If [M:DIA]ALLCPY<>2      #société
 CRITERE -= '& [F:TB1]CPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ODPNUMDEB<>""  #Numéro OD
 CRITERE -= '& [F:TB1]ODPNUM >= "'+[M:DIA]ODPNUMDEB+'"'
Endif
If [M:DIA]ODPNUMFIN<>""  #Numéro OD
 CRITERE -= '& [F:TB1]ODPNUM <= "'+[M:DIA]ODPNUMFIN+'"'
Endif

CRIT = "[F:TB0]PST=1"
If [M:DIA]ALLCPY<>2      #société
 CRIT -= '& [F:TB0]CPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2      #site
 CRIT -= '& [F:TB0]FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ODPNUMDEB<>""  #Numéro OD
 CRIT -= '& [F:TB0]ODPNUM >= "'+[M:DIA]ODPNUMDEB+'"'
Endif
If [M:DIA]ODPNUMFIN<>""  #Numéro OD
 CRIT -= '& [F:TB0]ODPNUM <= "'+[M:DIA]ODPNUMFIN+'"'
Endif
#MIPEA - 2017-02-18- X3-11491- START
Call TEMPON(mess(69,10703,1)) From GESECRAN : # Calcul Od de paye
#Call TEMPON(mess(69,703,1)) From GESECRAN : # Calcul Od de paye
#MIPEA - 2017-02-18- X3-11491- END
Call PARAM("","ODPAY",PCEAUTO) From ADOVAL
If [L]PCEAUTO="" : [L]PCEAUTO="ODPAY" : Endif
Call DEBTRANS From GLOCK
Gosub TR1
Gosub FIN    ##**108465
Return       ##**108465

$FIN
Call TEMPOFF From GESECRAN
If STAT : Call ECR_TRACE(MESSA,1) From GESECRAN : Endif
If !GSERVEUR & [M:DIA]TRCFLG=2
 Call FERME_TRACE From LECFIC
Endif
##**108465
If [M:DIA]SIMFLG=2
 CRITPST="1=1"
Else
 CRITPST="[F:TB1]PST>1"
Endif
#Filter [TB1] Where PST>1 | evalue(CRITERE)
#For [TB1]ODP1(2)
Filter [TB1] Where evalue(CRITERE) & evalue(CRITPST)
For [TB1]ODP3
##**
 Call VEPSYMBOLE (SYMBOLE, "TB1") From DIVPAYE
 Unlock =SYMBOLE
Next
Filter [TB1]
Return

$TR1
# Ne pas placer de lock dans la transaction
##**108465
#Filter [TB1] Where evalue(CRITERE)
#For [TB1]ODP1(2)
Filter [TB1] Where evalue(CRITERE) & evalue(CRITPST)
For [TB1]ODP3
 Call VEPSYMBOLE (SYMBOLE, "TB1") From DIVPAYE
 Lock =SYMBOLE
 If fstat
  STAT = 99
  MESSA = mess(30,100,1) : # Opération en cours sur autre poste
#MIPEA - 2017-02-18- X3-11491- START
  Call ECR_TRACE(mess(70,10703,1)-[F:TB1]ODPNUM-mess(61,100,1)-num$([F:TB1]ODPLIG),1) From GESECRAN
#  Call ECR_TRACE(mess(70,703,1)-[F:TB1]ODPNUM-mess(61,100,1)-num$([F:TB1]ODPLIG),1) From GESECRAN
#MIPEA - 2017-02-18- X3-11491- END
  # Ligne non validée de l'OD xxx ligne n°xxx
  GOK=0 : Break
 Endif
Next
##**
If GOK
 Trbegin [TB0],[TB1],[ODA],[VEP],[ODP1]
 OKOD = 0
 If !STAT
  Gosub OUVRE_CPTAUTO From DIVPAYE
  For [TB0] Where evalue(CRIT)
   IDENT = [F:TB0]ODPNUM
   If [M:DIA]SIMFLG=2 : # Simulation
    Call SIMPCE([L]PCEAUTO,IDENT,STAT,MESSA) From CPTAUTO
    If [M:DIA]TRCFLG=2 : Call TRACE_PIECE(1) From CPTBATCH : Endif
    If STAT : Break : Endif
    OKOD = 1
   Else
    Call VALPCE([L]PCEAUTO,IDENT,STAT,MESSA) From CPTAUTO
    If STAT : Break : Endif
#TODO - remove when done testing
#JASMI - START
    #MESSA=""
#JASMI - END
    If MESSA<>""
     Gosub TR2
     If GOK=0
      If [M:DIA]TRCFLG=2 : Call TRACE_PIECE(1) From CPTBATCH : Endif
      Break
     Endif
     # Création pièce TYP NUM
     Call ECR_TRACE(mess(40,107,1)-[M:HAE0]TYP-MESSA,0) From GESECRAN
     If [M:DIA]TRCFLG=2 : Call TRACE_PIECE(1) From CPTBATCH : Endif
     OKOD = 1
    Endif
   Endif
  Next
 Endif
 # Aucune pièce à générer
 If !OKOD : Call ECR_TRACE(mess(45,107,1),0) From GESECRAN : Endif
 Filter [TB1]
 If !GOK : Rollback : Return : Endif
 Commit
Endif
Return

$TR2
# Mise à jour du flag PST=2(Comptabilisé) dans les fichiers VALEMP,ODPAYE,ODPAY,ODPAYA
[F:TB0]PST = 2
Rewrite [TB0]
If fstat
 GOK = 0 : Call FSTA("ODE") From GLOCK : Return
Endif
Filter [ODP1] Where ODPNUM=[F:TB0]ODPNUM
For [ODP1]ODP0
 Readlock [VEP]VEP5=[F:ODP1]BUL
 If !fstat
  [F:VEP]PST = 3
  Rewrite [VEP]
  If fstat
   GOK = 0 : Call FSTA("VEP") From GLOCK : Break
  Endif
 Else
  # Erreur de lecture [VEP] :
  Call ECR_TRACE(mess(49,125,1)-"[VEP] : "-[F:ODP1]EMP-num$([F:ODP1]PYRDAT)-[F:VEP]BUL,1) From GESECRAN
  GOK = 0 : Break
 Endif
Next
If GOK
 For [ODP1]ODP0
  [F:ODP1]PST = 2
  Rewrite [ODP1]
  If fstat
   GOK = 0 : Call FSTA("ODP") From GLOCK : Break
  Endif
 Next
Endif
Filter [ODP1]
If GOK
 For [ODA]ODA0 Where ODPNUM=[F:TB0]ODPNUM
  [F:ODA]PST = 2
  Rewrite [ODA]
  If fstat
   GOK = 0 : Call FSTA("ODA") From GLOCK : Break
  Endif
 Next
Endif
Return

$SEL_TABLE
Case TABLE
 When "SELODP"    : Gosub SELODP
Endcase
Return

$SELODP
OBJET      = "ODP"
CRITERE(1) = "ODPLIG=1 & PST=1"
OPTIONS    = "|"
Return

################################################################################
## Etiquettes écran ODPAYVAL
################################################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From DIVPAYE
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From DIVPAYE
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Call AS_CPY(VALEUR) From DIVPAYE
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
Call AS_FCY(VALEUR) From DIVPAYE
End

Subprog C_ODPNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ODPNUMDEB
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2
Endif
End

Subprog AS_CAT(VALEUR)
Variable Integer VALEUR
# Pas de pièce hors bilan ou de pièce modèle
GMENLOC(4) = 1
GMENLOC(5) = 1
If GCOMPTA<>2
 GMENLOC(2) = 1
 GMENLOC(3) = 1
Endif
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
End

#MIPEA - 2017-02-18- X3-11491- END

