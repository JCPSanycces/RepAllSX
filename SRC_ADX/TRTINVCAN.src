#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# BRBAN #105200 US1 - Invoice cancellation rules for INVCAN field activation
######################################################################################
$ACTION
Case ACTION
  When "LIENS"      : Gosub LIENS
  When "INICRE"     : Gosub INICRE
  When "INIMOD"     : Gosub INICRE
Endcase
Return
######################################################################################
######################################################################################
$INICRE
If func AFNC.ACTIV("INVCA")>0
  If func AFNC.ACTIV("LEG")>0 : # Dossier mono-législation
    If func TRTINVCAN.INVCAN([M:TSV1]LEG, [M:TSV1]INVTYP) = 0
      [M:TSV1]INVCAN = 1
      [F:TSV]INVCAN  = 1
      Diszo [M:TSV1]INVCAN
      Affzo [M:TSV1]INVCAN
    Endif
  Else
    If func TRTINVCAN.INVCAN(GDOSLEG(1), [M:TSV1]INVTYP) = 0
      [M:TSV1]INVCAN = 1
      [F:TSV]INVCAN  = 1
      Diszo [M:TSV1]INVCAN
      Affzo [M:TSV1]INVCAN
    Endif
  Endif
Endif
# -
Return
######################################################################################
######################################################################################
$LIENS
# BRBAN #105200 US1
If func AFNC.ACTIV("INVCA")>0
  If func AFNC.ACTIV("LEG")>0 : # Dossier mono-législation
    If func TRTINVCAN.INVCAN([M:TSV1]LEG, [M:TSV1]INVTYP) = 1
      Actzo [M:TSV1]INVCAN
      Affzo [M:TSV1]INVCAN
    Else
      Diszo [M:TSV1]INVCAN
      [M:TSV1]INVCAN = 1
      Affzo [M:TSV1]INVCAN
    Endif
  Else
    If func TRTINVCAN.INVCAN(GDOSLEG(1), [M:TSV1]INVTYP) = 1
      Actzo [M:TSV1]INVCAN
      Affzo [M:TSV1]INVCAN
    Else
      Diszo [M:TSV1]INVCAN
      [M:TSV1]INVCAN = 1
      Affzo [M:TSV1]INVCAN
    Endif
  Endif
  # -

  If [M:TSV1]INVCAN = 2
    Diszo [M:TSV1]COD,COD2
    [M:TSV1]COD  = ''
    [M:TSV1]COD2 = ''
    Affzo [M:TSV1]COD,COD2
  Else
    Actzo [M:TSV1]COD,COD2
    Affzo [M:TSV1]COD,COD2
  Endif
Endif
Return


######################################################################################
######################################################################################
Subprog AM_INVTYP(VALEUR)
Variable Integer VALEUR
If func AFNC.ACTIV("INVCA")>0
  If func AFNC.ACTIV("LEG")>0  : # Dossier mono-législation
    If func TRTINVCAN.INVCAN([M:TSV1]LEG,VALEUR) = 1
      Actzo [M:TSV1]INVCAN
      Affzo [M:TSV1]INVCAN
    Else
      Diszo [M:TSV1]INVCAN
      [M:TSV1]INVCAN = 1
      Affzo [M:TSV1]INVCAN
    Endif
  Else
    If func TRTINVCAN.INVCAN(GDOSLEG(1),VALEUR) = 1
      Actzo [M:TSV1]INVCAN
      Affzo [M:TSV1]INVCAN
    Else
      Diszo [M:TSV1]INVCAN
      [M:TSV1]INVCAN = 1
      Affzo [M:TSV1]INVCAN
    Endif
  Endif
Endif
End


######################################################################################
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("INVCA")>0
  If func AFNC.ACTIV("LEG")>0   : # Dossier mono-législation
    If func TRTINVCAN.INVCAN(VALEUR,[M:TSV1]INVTYP) = 1
      Actzo [M:TSV1]INVCAN
      Affzo [M:TSV1]INVCAN
    Else
      Diszo [M:TSV1]INVCAN
      [M:TSV1]INVCAN = 1
      Affzo [M:TSV1]INVCAN
    Endif
  Endif

  If [M:TSV1]INVCAN = 2
    Diszo [M:TSV1]COD,COD2
    [M:TSV1]COD  = ''
    [M:TSV1]COD2 = ''
    Affzo [M:TSV1]COD,COD2
  Else
    Actzo [M:TSV1]COD,COD2
    Affzo [M:TSV1]COD,COD2
  Endif
Endif
End

######################################################################################
######################################################################################
Funprog INVCAN_CPY(WCPY)
Value Char WCPY
Local Integer INVCLT : [L]INVCLT = 0
Local Char WLEG   : [L]WLEG   = ""

Call GETLEG([L]WCPY,"",[L]WLEG) From TRTLECLEG
# Issue 110752 - 2015-09-02 by BRBAN : Problem on reading the parameter INVCAN with LEG
#Call PARAM([L]WLEG, "INVCAN", [L]INVCLT) From ADOVAL
[L]INVCLT = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVLEG,[L]WLEG,"INVCAN")

If [L]INVCLT=2
  End 1
Else
  End 0
Endif

End

######################################################################################
######################################################################################
Funprog INVCAN(WLEG,WINVTYP)
Value Char WLEG
Value Integer WINVTYP

Local Integer INVCLT : [L]INVCLT = 0
# Issue 110752 - 2015-09-02 by BRBAN : Problem on reading the parameter INVCAN with LEG
#Call PARAM([L]WLEG, "INVCAN", [L]INVCLT) From ADOVAL
[L]INVCLT = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVLEG,[L]WLEG, "INVCAN")

If [L]INVCLT=2 & find(WINVTYP,2,4)
  End 1
Else
  End 0
Endif

End


######################################################################################
######################################################################################
$HIDE_ENTER
If func AFNC.ACTIV("INVCA")>0
  If [M:SLA1]INVCAN=2
    Raz GMENLOC
    GMENLOC(1)=1
  Endif
Endif
Return
######################################################################################
######################################################################################
#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Subprog INVCAN_NOCREM(P_SDHNUM,P_RET)
Value Char P_SDHNUM
Variable Integer P_RET

#Local Char V_LEG(30)
#
#Call GETLEG(P_CPY,"",[L]V_LEG) From TRTLECLEG

#If func AFNC.ACTIV("INVCA") = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  [L]P_RET = 0
  If !clalev([F:SIH]) Local File SINVOICE  [SIH]  Endif
  If !clalev([F:SDH]) Local File SDELIVERY [SDH]  Endif

  #Search for the Delivery
  Read [F:SDH]SDH0 = [L]P_SDHNUM
  If !fstat
    #Search for the Invoice
    Read [F:SIH]SIH0=[F:SDH]SIHNUM
    #Check Invoice for its cancellation
    If !fstat & [F:SIH]REVCANSTA <> 0
      #Force the field as NO
      [L]P_RET = 1
    Endif
  Endif
#Endif
End
#105200 RICAR 2015/05/25 - Inv Cancelation - END
######################################################################################
######################################################################################

