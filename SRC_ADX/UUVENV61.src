#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UUVENV61     Utilitaire de migration du module ventes     Module VENTE #
#              d'une version 6.0 vers  une version 6.1                   #
##########################################################################


Call MAJ_UUVENV61
End


Subprog MAJ_UUVENV61
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UUVENV61 - Migration ventes Béryl 6.0 vers 6.1") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UUVENV61 : Utilitaire de migration ventes 6.0 vers 6.1") From LECFIC
  Call EXE_UUVENV61(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UUVENV61(DOSSIER)
Value Char    DOSSIER
#-----
Call ECR_TIME("UUVENV61 : Start folder's process"-DOSSIER) From DOSSUB
Call ECR_TRACE("---------- Update sales module release 6.0 to 6.1 ----------",0) From GESECRAN
#----- Chargement globale GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =DOSSIER+".ADOVAL" [ADW] 
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]
#----- Variable locales communes -----#
Local Integer  WNBR, WNBRCOR
#----- Début du traitement -----#
Gosub TRT_SQH    : # Traitement des devis
Gosub TRT_SOH    : # Traitement des commandes    
Gosub TRT_VOH    : # Traitement des historiques commandes
Gosub TRT_TXNCDE : # Traitement des transactions commande
Gosub TRT_TXNFAC : # Traitement des transactions factures
#----- Fin du traitement -----#
$FIN_UUVENV61
Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Call ECR_TIME("UUVENV61 : End folder's process"-DOSSIER) From DOSSUB
End


#----------------------------------------------------------------#
#   Alimentation des nouveaux champs dans les devis              #
# -------------------------------------------------------------- #
# Table SQUOTE   - Entête devis                                  #
#   APPFLG       Flag signée                                     #
#----------------------------------------------------------------#
$TRT_SQH
If filinfo(filpath("FIL","SQUOTE","fde",DOSSIER),0) < 0 : Return : Endif
Call ECR_TIME("UUVENV61 : Sales Quote Process : Update SQUOTE") From DOSSUB
Local File =DOSSIER+".SQUOTE"    [SQH]
WNBR=rowcount([SQH])
Trbegin [SQH]
Update [SQH] Where APPFLG=0 With APPFLG=4
If fstat
  Call ECR_TRACE("File SQUOTE, Error ="-num$(fstat),1) From GESECRAN
  WNBRCOR=0
  Rollback
Else
  WNBRCOR=adxuprec
  Commit
Endif
Close Local File [SQH]
Call ECR_TIME("UUVENV61 : Sales Quote Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return

#----------------------------------------------------------------#
#   Alimentation des nouveaux champs dans les commandes          #
# -------------------------------------------------------------- #
# Table SORDER   - Entête commandes                              #
#   APPFLG       Flag signée                                     #
#----------------------------------------------------------------#
$TRT_SOH
If filinfo(filpath("FIL","SORDER","fde",DOSSIER),0) < 0 : Return : Endif
Call ECR_TIME("UUVENV61 : Sales Order Process : Update SORDER") From DOSSUB
Local File =DOSSIER+".SORDER"    [SOH]
WNBR=rowcount([SOH])
Trbegin [SOH]
Update [SOH] Where APPFLG=0 With APPFLG=4
If fstat
  Call ECR_TRACE("File SORDER, Error ="-num$(fstat),1) From GESECRAN
  WNBRCOR=0
  Rollback
Else
  WNBRCOR=adxuprec
  Commit
Endif
Close Local File [SOH]
Call ECR_TIME("UUVENV61 : Sales Order Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return

#-------------------------------------------------------------------#
#   Alimentation des nouveaux champs dans les historiques commandes #
# ----------------------------------------------------------------- #
# Table VSORDER   - Entête historiques commandes                    #
#   APPFLG       Flag signée                                        #
#-------------------------------------------------------------------#
$TRT_VOH
If filinfo(filpath("FIL","VSORDER","fde",DOSSIER),0) < 0 : Return : Endif
Call ECR_TIME("UUVENV61 : Sales Order Process : Update VSORDER") From DOSSUB
Local File =DOSSIER+".VSORDER"    [VOH]
WNBR=rowcount([VOH])
Trbegin [VOH]
Update [VOH] Where APPFLG=0 With APPFLG=4
If fstat
  Call ECR_TRACE("File VSORDER, Error ="-num$(fstat),1) From GESECRAN
  WNBRCOR=0
  Rollback
Else
  WNBRCOR=adxuprec
  Commit
Endif
Close Local File [VOH]
Call ECR_TIME("UUVENV61 : Sales Order Process : Ended ("+num$(WNBRCOR)-"/"-num$(WNBR)+")") From DOSSUB
Return

#-------------------------------------------------------------------------------#
# Transaction pour les commandes                                                #
#-------------------------------------------------------------------------------#
$TRT_TXNCDE
Local Integer INDIC

If filinfo(filpath("FIL","SALTRS","fde",DOSSIER),0) < 0 : Return : Endif
Call ECR_TIME("UUVENV61 : Sales Transactions Process : Update SALTRS") From DOSSUB
Local File =DOSSIER+".SALTRS"    [SLT]
Raz WNBRCOR

Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=2
      Raz INDIC
      If dim([F:SLT]DRNCOD)>0
          If !find([F:SLT]DRNCOD,1,2,3)    INDIC=1 : [F:SLT]DRNCOD=3    : Endif   : # N°tournée (invisible)
          If !find([F:SLT]DRNCODD,1,2,3)   INDIC=1 : [F:SLT]DRNCODD=3   : Endif   : # N°tournée (invisible)
          If [F:SLT]DRNCODD<>0  & [F:SLT]DRNSCRD=0 INDIC=1 : [F:SLT]DRNSCRD=1  : Endif
      Endif
      If dim([F:SLT]PRECODCOD)>0
          If !find([F:SLT]PRECODCOD,1,2,3) INDIC=1 : [F:SLT]PRECODCOD=3 : Endif   : # Code prépa (invisible)
          If [F:SLT]PRECODCOD<>0  & [F:SLT]PRECODSCR=0 INDIC=1 : [F:SLT]PRECODSCR=1  : Endif
      Endif
      If INDIC=1
          Rewrite [SLT]
          If fstat
              Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
          Else
              WNBRCOR+=1
          Endif
      Endif
  Next
Commit
Close Local File [SLT]
Call ECR_TIME("UUVENV61 : Sales Transactions Process : Ended ("+num$(WNBRCOR)+")") From DOSSUB
Return

#-------------------------------------------------------------------------------#
# Transaction pour les factures                                                 #
#-------------------------------------------------------------------------------#
$TRT_TXNFAC
Local Integer INDIC

If filinfo(filpath("FIL","SALTRS","fde",DOSSIER),0) < 0 : Return : Endif
Call ECR_TIME("UUVENV61 : Sales Transactions Process : Update SALTRS") From DOSSUB
Local File =DOSSIER+".SALTRS"    [SLT]
Raz WNBRCOR

Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=5
    Raz INDIC
    If dim([F:SLT]SVCDATCODD)>0
        If !find([F:SLT]SVCDATCODD,1,2,3) [F:SLT]SVCDATCODD=3 : [F:SLT]SVCDATSCRD=1 : INDIC=1 Endif
        If [F:SLT]SVCDATCODD<>0   & [F:SLT]SVCDATSCRD=0  INDIC=1 : [F:SLT]SVCDATSCRD=1  : Endif
    Endif
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Else
            WNBRCOR=+1
        Endif
    Endif
  Next
Commit
Close Local File [SLT]
Call ECR_TIME("UUVENV61 : Sales Transactions Process : Ended ("+num$(WNBRCOR)+")") From DOSSUB
Return


Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

Call EXE_UUVENV61(APPLI)
End

Subprog UTI_MOUL(APPLI)
Value Char    APPLI

If [F:ADS]MODULE(4)<>2 
    End 
Endif
Call EXE_UUVENV61(APPLI)
End

