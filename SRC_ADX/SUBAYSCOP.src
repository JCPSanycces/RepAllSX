#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = "AYS"
PARBOUT(2) = "ZSITE1COP1"
PARBOUT(3) = ""
#FLGEXE = 1
GACTION = "AYSCOP"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","SUBAYSCOP","AYSCOP",3,"") From GTRAITE
End


######################################################################################
## Xtend: Copie de la fiche site
######################################################################################
#    GACTION    
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES
#        ELTCOD  
#    [F:AYS1] Site origine       Ouvert et lu 
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap 
 Local File ATEXTE  [ATX1] 
 Local File ATEXTRA [AXX1]
Else 
 Local File =[L]DOSORG+".ATEXTE"  [ATX1] 
 Local File =[L]DOSORG+".ATEXTRA" [AXX1]
Endif 
If [L]DOSDES=nomap 
 Local File ATEXTE  [ATX2] 
 Local File ATEXTRA [AXX2]
 Local File AYTFCY  [AYSS]         # Sauvegarde pour Données à reconduire
 # Verif
 Local File AYTPAG  [AYG2] 
 Local File TABLAN  [TLA2] 
Else 
 Local File =[L]DOSDES+".AYTFCY"  [AYSS]         # Sauvegarde pour Données à reconduire
 Local File =[L]DOSDES+".ATEXTE"  [ATX2]
 Local File =[L]DOSDES+".ATEXTRA" [AXX2] 
 Local File =[L]DOSDES+".AYTPAG"  [AYG2] 
 Local File =[L]DOSDES+".TABLAN"  [TLA2] 
Endif

If [F:AYS2]FCYCOD=[L]FCYDES
  If GACTION="AYTCOP"  # Verif en copie fiche par fiche
    OK=1 : Call AVERTIR([L]DOSDES-[L]FCYDES-mess(22,100,1),OK) From GESECRAN
    If OK<>2 : OK = 0 : Goto FINALLY : Endif
  Endif
  [F:AYSS]=[F:AYS2]
Endif

### Verifications 
# Langues
For WI=0 To [AYS1]LANNBR-1    
    Read [TLA2]TLA0=[F:AYS1]LANCOD(WI)
    If fstat 
        Call ECR_TRACE(mess(2,150,1)-[F:AYS1]LANCOD(WI)-mess(1,45,1)-[L]DOSDES,1) From GESECRAN
        OK=0
        Break
    Endif
    Read [TLA2]TLA0=[F:AYS1]LANADS(WI)
    If fstat 
        Call ECR_TRACE(mess(2,150,1)-[F:AYS1]LANADS(WI)-mess(1,45,1)-[L]DOSDES,1) From GESECRAN
        OK=0
        Break
    Endif
Next
If OK=0 : Goto FINALLY : Endif   

# Pages
Read [AYG2]AYG0=[L]FCYDES;[F:AYS1]PAGSTR
If fstat 
    Call ECR_TRACE(" "-mess(17,7900,1)-[F:AYS1]PAGSTR-mess(1,45,1)-[L]DOSDES,0) From GESECRAN
Endif
Read [AYG2]AYG0=[L]FCYDES;[F:AYS1]PAGERR
If fstat 
    Call ECR_TRACE(" "-mess(17,7900,1)-[F:AYS1]PAGERR-mess(1,45,1)-[L]DOSDES,0) From GESECRAN
Endif
Read [AYG2]AYG0=[L]FCYDES;[F:AYS1]PAGLOG
If fstat 
    Call ECR_TRACE(" "-mess(17,7900,1)-[F:AYS1]PAGLOG-mess(1,45,1)-[L]DOSDES,0) From GESECRAN
Endif
If [F:AYS1]MCEFLG=2
 Read [AYG2]AYG0=[L]FCYDES;[F:AYS1]PAGMCE
 If fstat 
    Call ECR_TRACE(" "-mess(17,7900,1)-[F:AYS1]PAGMCE-mess(1,45,1)-[L]DOSDES,0) From GESECRAN
 Endif
Endif

# Mises à jour
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif

$FINALLY
Close Local File [ATX1] , [AXX1]
&              , [ATX2], [AYG2],[TLA2] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AYS2] , [ATX2]
 Delete [AYS2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTFCY" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYS2","") From GLOCK : Goto AB_TR_COP
 Endif

 For [AYS1]AYS0 Where FCYCOD=[L]FCYORG
  [F:AYS2] = [F:AYS1]
  [F:AYS2]FCYCOD = [L]FCYDES
  Call COPTEXTRA("AYTFCY","INTIT",[F:AYS1]FCYCOD,"",[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  If dim([F:AYS2]UPDUSR)>0 : [F:AYS2]UPDUSR = GUSER : Endif
  If dim([F:AYS2]UPDDAT)>0 : [F:AYS2]UPDDAT = date$ : Endif
  If dim([F:AYS2]UPDTIM)>0 : [F:AYS2]UPDTIM = time  : Endif
  # Données reconduites
  If [AYSS]FCYCOD=[L]FCYDES
    [F:AYS2]MAICOD=[F:AYSS]MAICOD
    [F:AYS2]LNKNBR=[F:AYSS]LNKNBR
    For WI=0 To dim([F:AYSS]LNKADS)-1
     [F:AYS2]LNKADS(WI)=[F:AYSS]LNKADS(WI) 
     [F:AYS2]LNKADSDEF(WI)=[F:AYSS]LNKADSDEF(WI)
    Next
    [F:AYS2]BRWDEG=[F:AYSS]BRWDEG
    [F:AYS2]LOGMOD=[F:AYSS]LOGMOD
    [F:AYS2]TOOLMOD=[F:AYSS]TOOLMOD
    # modif SB ajout http cache expires, vérifier mise à jour et localisation
    [F:AYS2]LOCHTM=[F:AYSS]LOCHTM
    [F:AYS2]LOCFIL=[F:AYSS]LOCFIL
    [F:AYS2]LOCFLA=[F:AYSS]LOCFLA

    [F:AYS2]HCEDEF=[F:AYSS]HCEDEF
    [F:AYS2]HCEHTM=[F:AYSS]HCEHTM
    [F:AYS2]HCEFIL=[F:AYSS]HCEFIL
    [F:AYS2]HCEXTD=[F:AYSS]HCEXTD
    [F:AYS2]HCEAPP=[F:AYSS]HCEAPP
    [F:AYS2]HCEFLA=[F:AYSS]HCEFLA

    [F:AYS2]CTSDEF=[F:AYSS]CTSDEF
    [F:AYS2]CTSHTM=[F:AYSS]CTSHTM
    [F:AYS2]CTSDIC=[F:AYSS]CTSDIC
  
    For I=0 To [F:AYS2]PARNBR
     J=find([F:AYS2]PAR(I),[F:AYSS]PAR(0..[F:AYSS]PARNBR-1))
     If J
      [F:AYS2]PARVAL(I) = [F:AYSS]PARVAL(J-1)
     Endif
    Next I
      Endif
  Write [AYS2]
  If fstat
   GOK=0 : Call FSTA("AYS2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


 

