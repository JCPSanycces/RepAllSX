#<AdxTL>@(#)0.0.0.0 $Revision$ 
$TR1
If !clalev([F:AQCBPR]) : Local File AQCBPR [AQCBPR] : Endif
If !clalev([F:AQCBPRP]) : Local File AQCBPRP [AQCBPRP] : Endif
If !clalev([F:AQCBPRL]) : Local File AQCBPRL [AQCBPRL] : Endif
If !clalev([F:AQCPOS]) : Local File AQCPOS [AQCPOS] : Endif
If !clalev([F:AQCCNTP]) : Local File AQCCONTACTP [AQCCNTP] : Endif
If !clalev([F:AQCCNT]) : Local File AQCCONTACT [AQCCNT] : Endif
If !clalev([F:AQAIN])  : Local File AQCONTACTCRM [AQAIN] : Endif
If !clalev([F:AQCPROT1]) : Local File AQCPROT1 [AQCPROT1] : Endif
If !clalev([F:ATEXTRA]) : Local File ATEXTRA [AXX] : Endif
If !clalev([F:AQCPDAT]) : Local File AQCPOSDAT [AQCPDAT] : Endif
If !clalev([F:AQTINT]) : Local File AQTABINT [AQTINT] : Endif
If !clalev([F:AQPLM]) : Local File AQPOSLM [AQPLM] : Endif
#If !clalev([F:ACLOBPLM]) : Local File AQPOSLM [AQPLM] : Endif
If !clalev([F:ACLOB]) : Local File ACLOB [ACB] : Endif

Local File AQTABCOUNTRY [AQTCY]

Infbox "Must be logged in as user: AAAAA"

$CLEAN
Infbox "CLEAN"

Trbegin [AQCPROT1]
Delete [AQCPROT1] Where 1=1
Commit

Trbegin [AQCBPR]
Delete [AQCBPR] Where 1=1
Commit

Trbegin [AQCBPRP]
Delete [AQCBPRP] Where 1=1
Commit

Trbegin [AQCBPRL]
Delete [AQCBPRL] Where 1=1
Commit

Trbegin [AQCPOS]
Delete [AQCPOS] Where 1=1
Commit

Trbegin [AQTCY]
Delete [AQTCY] Where 1=1
Commit
Close Local File [AQTCY]

Trbegin [AQCCNT]
Delete [AQCCNT] Where 1=1
Commit

Trbegin [AQCCNTP]
Delete [AQCCNTP] Where 1=1
Commit


Trbegin [AQAIN]
Delete [AQAIN] Where 1=1
Commit

Trbegin [AQCPDAT]
Delete [AQCPDAT] Where 1=1
Commit

Trbegin [AQTINT]
Delete [AQTINT] Where 1=1
Commit

Trbegin [AQPLM]
Delete [AQPLM] Where 1=1
Commit

Trbegin [ACB]
Delete [ACB] Where left$([ACB]CODBLB,3)='BPR' and [ACB]IDENT1='AAAAA'
Commit

Trbegin [ACB]
Delete [ACB] Where [ACB]IDENT1='BBBBB' #left$([ACB]CODBLB,3)='BPR' and [ACB]IDENT1='BBBBB'
Commit

Trbegin [AXX]
Delete [AXX] Where left$(IDENT1,8)='AQCPROT1'
Commit

Trbegin [AXX]
Delete [AXX] Where CODFIC='AQCCONTACT' | CODFIC='AQCPOS'| CODFIC='AQTABCOUNTRY' | CODFIC="AQCPROT1" | CODFIC='AQCBPRL'
Commit


Close Local File [AXX]



####################################################################
$PROT1
Local Integer TMP_ADXLOG

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQCPROT1] : Endif
N=0
#Filter [BPR] Where   No DATA !!!!!!!!!!!!!!!!!!
For I = 0 To 25  #25
  N +=1
  J = 1+mod(I-1,10)
  [AQCPROT1]COD=num$(I)+num$(1)
  [AQCPROT1]BPRNUM = "BPR"+format$("N0:2",I+1)+format$("N0:2",J)
  [AQCPROT1]CONTACT="0000000000000" + string$(2,num$(N))
  If int(I/2) = (I/2)
    [AQCPROT1]FCY="ZUSA"
  Else
    [AQCPROT1]FCY="CAT"
  Endif
  [AQCPROT1]DAT=date$-I
  [AQCPROT1]SHOINT=I
  [AQCPROT1]TEL=string$(5,num$(N+1)) + string$(5,num$(N+1))
  If [AQCPROT1]FCY="ZUSA" : [AQCPROT1]MENL=2 : [AQCPROT1]CUR='USD': Else  [AQCPROT1]MENL=1 : [AQCPROT1]CUR='EUR' :  Endif
  [AQCPROT1]ATXTEXT=26789
  [AQCPROT1]VAL1=1234567890123.12  # MD1  13.2
  [AQCPROT1]VAL2=123456789012345   # MD0  15
  [AQCPROT1]QTY1=123456789012345   # QTY  15
  [AQCPROT1]COE1=12345.123456      # COE  5.6
  [AQCPROT1]DCB=1234567890.1234    # DCB used?
  [AQCPROT1]MD2=123456.12          #      6.2
  [AQCPROT1]MD3=1234567890123.12   #     13.2
  [AQCPROT1]MD4=123456789.12       #      9.2
  [AQCPROT1]MD5=12345678901.1234   #     11.4
  [AQCPROT1]RCU=123456789012345    #     15
  [AQCPROT1]UOM='EA'
  [AQCPROT1]MENL2=2  # Revenue
  [AQCPROT1]ALPHA(0)="ALPHA " + [AQCPROT1]COD
  [AQCPROT1]CONT="0000000000000" + string$(2,num$(N)) ##############
  [AQCPROT1]CLE='AQCPROT1'  + num$(N)  # + num$(N*2)
  ###### [AXX]IDENT1="AQCPROT1"+ num$(N)
  If [AQCPROT1]FCY="ZUSA"
   [AQCPROT1]LAN='ENG'
   [AQCPROT1]VAL1=123456.789
  Else [AQCPROT1]LAN='FRA'
  Endif
  [AQCPROT1]CREUSR="AAAAA"  #GACTX.USER
  [AQCPROT1]CREDATTIM=datetime$
  [AQCPROT1]UPDDATTIM=datetime$
  [AQCPROT1]UPDUSR="AAAAA" #GACTX.USER
  [AQCPROT1]AUUID = getUuid
  [AQCPROT1]UUID = getUuid
  Write [AQCPROT1]
Next I

If fstat
  GOK = 0 : Call FSTA("AQCPROT1") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

####Close Local File [AQCPROT1]

##################################################################
$BPR
Local Integer TMP_ADXLOG

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQCBPR] : Endif

#Filter [BPR] Where   No DATA !!!!!!!!!!!!!!!!!!
For I = 0 To 25  #25
  J = 1+mod(I-1,10)
  [AQCBPR]BPR="BPR"+format$("N0:2",I+1)+format$("N0:2",J)
  [AQCBPR]BPRNAM=func BPRNAM(I)
  If [AQCBPR]BPR="BPR2110"  : [AQCBPR]BPRNAM="12345678901234567890123456789012345" : Endif # GH 5922
  [AQCBPR]CRY=func CRYSET(I,0)
  [AQCBPR]EECNUM="EEC"+ [AQCBPR]BPR
  [AQCBPR]UOM='Kg'
  [AQCBPR]TCU='EUR'
  [AQCBPR]BPAADD=num$(I*2)
  [AQCBPR]DAT=date$
  [AQCBPR]DTIME=time$
  [AQCBPR]DCB=I
  [AQCBPR]LNGINT=I*555
  [AQCBPR]SHOINT=97  #I*5 # Change to Misc table
  [AQCBPR]ALPHA(0)=[AQCBPR]BPRNAM + " " + num$(0)
  [AQCBPR]ALPHA(1)=[AQCBPR]BPRNAM + " " + num$(1)
  [AQCBPR]ALPHA(2)=[AQCBPR]BPRNAM + " " + num$(2)
  [AQCBPR]ALPHA(3)=[AQCBPR]BPRNAM + " " + num$(3)
  [AQCBPR]MENL=1
  If [AQCBPR]CRY = 'FR' : [AQCBPR]LOCMEN=4 : Else [AQCBPR]LOCMEN=3 : Endif ################
  [AQCBPR]CREUSR="AAAAA"  #GACTX.USER
  [AQCBPR]CREDATTIM=datetime$
  [AQCBPR]UPDDATTIM=datetime$
  [AQCBPR]UPDUSR="AAAAA" #GACTX.USER
  [AQCBPR]AUUID = getUuid
  [AQCBPR]UUID = getUuid
  If [AQCBPR]BPR='BPR1908' : [AQCBPR]BPRNAM=' ' : Endif # GH 5833 test
  Write [AQCBPR]
Next I

If fstat
  GOK = 0 : Call FSTA("AQCBPR") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQCBPRP] : Endif

#Filter [BPR] Where   No DATA !!!!!!!!!!!!!!!!!!
I=0
For [AQCBPR] Where 1=1
  [AQCBPRP] = [AQCBPR]
  #[AQCBPRP]POSCOD=left$(string$(5,[AQCBPR]DCB),5) #
   #[AQCBPRP]POSCOD="55555"  #string$(5,[AQCBPR]DCB) #
   [AQCBPRP]POSCOD=left$(string$(5,num$(I+1)),5)
  If [AQCPOS]CRY = 'FR' : [AQPLM]LOCMEN=4 : Else [AQPLM]LOCMEN=3 : Endif
  #[AQCBPRP]LOCMEN=9
  Write [AQCBPRP]
  I+=1
Next

If fstat
  GOK = 0 : Call FSTA("AQCBPRP") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

Close Local File [AQCBPR]
Close Local File [AQCBPRP]

#Return
##########################################################
$ACLOB
#Local File ACLOB [ACB]
##############Goto SKIP4
Local File AQCBPR [AQCBPR]

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [ACB] : Endif

Local Integer I
I=1
N=1

For [AQCBPR] Where 1=1
N+=1
[ACB]=[AQCBPR]
[ACB]CODBLB=[AQCBPR]BPR
[ACB]IDENT1='AAAAA'  # BP
[ACB]CLOB="ACRTF text " + [AQCBPR]BPR #string$(2,num$(N))
[ACB]CNTTYP='ATYPE10-3'   # Or  ATYPE10-2
[ACB]TYPDOC='EXP'
[ACB]CREUSR="AAAAA"
[ACB]CREDAT=date$
[ACB]CREDATTIM=datetime$
[ACB]UPDDATTIM=datetime$
[ACB]UPDUSR="AAAAA"
[ACB]AUUID = getUuid
Write [ACB]
Next

If fstat
  GOK = 0 : Call FSTA("ACB") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

$ACLOB2

If !clalev([F:AQCPROT1]) : Local File AQCPROT1 [AQCPROT1] : Endif

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [ACB] : Endif

Local Integer I
I=1
N=1

For [AQCPROT1] Where 1=1 and [AQCPROT1]COD <> '241'
N+=1
[ACB]=[AQCPROT1]
[ACB]CODBLB=[AQCPROT1]COD
[ACB]IDENT1='BBBBB'  # BP
[ACB]CLOB="ACPLAIN text " + [AQCBPR]BPR #string$(2,num$(N))
[ACB]CNTTYP='ATYPE10-1'   # Or  ATYPE10-2
[ACB]TYPDOC='EXP'
[ACB]CREUSR="AAAAA"
[ACB]CREDAT=date$
[ACB]CREDATTIM=datetime$
[ACB]UPDDATTIM=datetime$
[ACB]UPDUSR="AAAAA"
[ACB]AUUID = getUuid
Write [ACB]
Next

If fstat
  GOK = 0 : Call FSTA("ACB") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

Close Local File [ACB]
Close Local File [AQCBPR]
Close Local File [AQCPROT1]

$SKIP4
###########################################################
$BPRL

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQCBPRL] : Endif
Local Integer K
For I = 0 To 25  #25
  J = 1+mod(I-1,10)
  [AQCBPRL]BPANUM="BPR"+format$("N0:2",I+1)+format$("N0:2",J)
  [AQCBPRL]BPRNAM=func BPRNAM(I)
  [AQCBPRL]BPAADDLIG(0)=string$(4,num$(I)) + " " + func ADDLIG(I)
  [AQCBPRL]BPAADDLIG(1)="Suite" + " " + num$(I*2)
  [AQCBPRL]BPAADDLIG(2)="Door " + num$(I+1)
  [AQCBPRL]POSCOD=left$(string$(5,num$(I+1)),5)
  [AQCBPRL]LNGINT=val(left$(string$(5,num$(I+2)),5))
  [AQCBPRL]CTY=func ADDCTY(I)
  [AQCBPRL]CRY=func CRYSET(I,0)
  [AQCBPRL]SAT=func ADDSAT(I)
  [AQCBPRL]BPADES=[AQCBPRL]BPANUM
  [AQCBPRL]CRYNAM=func CRYSET(I,1)
  [AQCBPRL]DAT=date$
  [AQCBPRL]ALPHA(0)=[AQCBPRL]BPRNAM + num$(0)
  [AQCBPRL]ALPHA(1)=[AQCBPRL]BPRNAM + num$(1)
  [AQCBPRL]ALPHA(2)=[AQCBPRL]BPRNAM + num$(2)
  [AQCBPRL]ALPHA(3)=[AQCBPRL]BPRNAM + num$(3)
  [AQCBPRL]SHOINT=I*5
  [AQCBPRL]CREUSR="AAAAA"  #GACTX.USER
  [AQCBPRL]CREDATTIM=datetime$
  [AQCBPRL]UPDDATTIM=datetime$
  [AQCBPRL]UPDUSR="AAAAA" #GACTX.USER
  [AQCBPRL]AUUID = getUuid
  [AQCBPRL]UUID = getUuid
  Write [AQCBPRL]
Next I

If fstat
  GOK = 0 : Call FSTA("AQCBPRL") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

Close Local File [AQCBPRL]

#################################################################
$POS

If !clalev([F:AQCBPRL]) : Local File AQCBPRL [AQCBPRL] : Endif
TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQCPOS] : Endif

Local Integer I
I=1
For [AQCBPRL]
[AQCPOS]=[AQCBPRL]
[AQCPOS]LNGINT=AVOID.AINT
If [AQCPOS]CRY = 'FR' : [AQCPOS]MENL=4 : Else [AQCPOS]MENL=3 : Endif
[AQCPOS]CREUSR="AAAAA"
[AQCPOS]CREDATTIM=datetime$
[AQCPOS]UPDDATTIM=datetime$
[AQCPOS]UPDUSR="AAAAA"
[AQCPOS]AUUID = getUuid
[AQCPOS]UUID = getUuid
Write [AQCPOS]
Next

If fstat
  GOK = 0 : Call FSTA("AQCPOS") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

Close Local File [AQCBPRL]


########################################################
$POSDAT

If !clalev([F:AQCPDAT]) : Local File AQCPOSDAT [AQCPDAT] : Endif
TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQCPDAT] : Endif

Local Integer I
I=1
For [AQCPOS]
[AQCPDAT]=[AQCPOS]
[AQCPDAT]DAT=date$
[AQCPDAT]CREUSR="AAAAA"
[AQCPDAT]CREDATTIM=datetime$
[AQCPDAT]UPDDATTIM=datetime$
[AQCPDAT]UPDUSR="AAAAA"
[AQCPDAT]AUUID = getUuid
[AQCPDAT]UUID = getUuid
Write [AQCPDAT]
Next

If fstat
  GOK = 0 : Call FSTA("AQCPDAT") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

Close Local File [AQCPDAT]


########################################################
$POSLM

If !clalev([F:AQPLM]) : Local File AQPOSLM [AQPLM] : Endif
TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQPLM] : Endif

Local Integer I
I=1
For [AQCPOS]
[AQPLM]=[AQCPOS]
If [AQCPOS]CRY = 'FR' : [AQPLM]LOCMEN=4 : Else [AQPLM]LOCMEN=3 : Endif
#If [AQCPOS]CRY="US" : [AQCPLM]LOCMEN=2 : Else  [AQCPLM]LOCMEN=1  :  Endif
#[AQPLM]LOCMEN=9 #################
[AQPLM]CREUSR="AAAAA"
[AQPLM]CREDATTIM=datetime$
[AQPLM]UPDDATTIM=datetime$
[AQPLM]UPDUSR="AAAAA"
[AQPLM]AUUID = getUuid
Write [AQPLM]
Next

If fstat
  GOK = 0 : Call FSTA("AQPLM") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

Close Local File [AQPLM]
Close Local File [AQCPOS]
####################################################################
$CRY

Local File TABCOUNTRY [TCY]
Local File AQTABCOUNTRY [AQTCY]

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQTCY] : Endif
Local Integer I
I=1
Local Integer K

Filter [F:TCY] Where [TCY]CRY="FR" or [TCY]CRY="US"

For [F:TCY]
[AQTCY]=[TCY]
If [AQTCY]CRY='US' : [AQTCY]EECFLG=2 : [AQTCY]MINZIP=79 : Else [AQTCY]EECFLG=1 : [AQTCY]MINZIP=85 : Endif
[AQTCY]CTYUPP=3
[AQTCY]CREUSR="AAAAA"
[AQTCY]CREDATTIM=datetime$
[AQTCY]UPDDATTIM=datetime$
[AQTCY]UPDUSR="AAAAA"
[AQTCY]AUUID = getUuid
[AQTCY]CCNCRM="000000000000016"
Write [AQTCY]
Next

If fstat
  GOK = 0 : Call FSTA("AQTCY") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif
Close Local File [TCY]
#Close Local File [AQTCY]

########################################################
$CRYINT

If !clalev([F:AQTINT]) : Local File AQTABINT [AQTINT] : Endif
TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQTINT] : Endif

Local Integer I
I=1
For [AQTCY]
[AQTINT]=[AQTCY]
[AQTINT]SHOINT=[AQTCY]MINZIP
[AQTINT]CREUSR="AAAAA"
[AQTINT]CREDATTIM=datetime$
[AQTINT]UPDDATTIM=datetime$
[AQTINT]UPDUSR="AAAAA"
[AQTINT]AUUID = getUuid
Write [AQTINT]
Next

If fstat
  GOK = 0 : Call FSTA("AQTINT") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

Close Local File [AQTCY]
Close Local File [AQTINT]

#####################################################################
$CNT

Local File CONTACT [CNT]
Local File AQCBPR [AQCBPR]
Local File AQCPROT1 [AQCPROT1]

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQCCNT] : Endif

Local Integer I
I=1
N=1

For [AQCBPR] Where 1=1
N+=1
#For I=0 To  num$(rowcount([F:AQCBPRL]))
[AQCCNT]=[AQCBPR]
[AQCCNT]BPANUM=[AQCBPR]BPR
[AQCCNT]BPATYP=1  # BP
[AQCCNT]CCNCRM="0000000000000" + string$(2,num$(N))
[AQCCNT]CNTFNC=1
[AQCCNT]CNTMSS='E1'
[AQCCNT]CREUSR="AAAAA"
[AQCCNT]CREDAT=date$
[AQCCNT]TEL=string$(5,num$(N)) + string$(5,num$(N+1))
[AQCCNT]CREDATTIM=datetime$
[AQCCNT]UPDDATTIM=datetime$
[AQCCNT]UPDUSR="AAAAA"
[AQCCNT]AUUID = getUuid
Write [AQCCNT]
 Filter [AQCPROT1] Where BPRNUM  = [AQCCNT]BPANUM
 Read [AQCPROT1] First
 If !fstat
   SAVGUSER = GUSER
      GUSER='AAAAA'
   [AQCPROT1]CREUSR="AAAAA"
   [AQCPROT1]UPDUSR="AAAAA"
   [AQCPROT1]CONTACT=[AQCCNT]CCNCRM
   [AQCPROT1]CONT=[AQCCNT]CCNCRM
   Rewrite [AQCPROT1]
    GUSER = SAVGUSER
 Endif
 Filter [AQCPROT1]
Next

If fstat
  GOK = 0 : Call FSTA("AQCCNT") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif


TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQCCNTP] : Endif

Local Integer I
I=1
N=1

For [AQCCNT] Where 1=1
  [AQCCNTP] = [AQCCNT]
  Write [AQCCNTP]
Next

If fstat
  GOK = 0 : Call FSTA("AQCCNT") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif


Close Local File [CNT]
Close Local File [AQCBPR]
Close Local File [AQCPROT1]

########################################################
$CNTCRM

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AQAIN] : Endif

Local Integer I
I=1
N=1

For [AQCCNT] Where 1=1
N+=1
[AQAIN]=[AQCCNT]
[AQAIN]CNTNUM=[AQCCNT]CCNCRM
[AQAIN]CNTFULNAM=func ADDCNT(N-1)
[AQAIN]ADD(0)=string$(4,num$(N)) + " " + func ADDLIG(N)
[AQAIN]ADD(1)="Suite" + " " + num$(N*2)
[AQAIN]ADD(2)="Door " + num$(N+1)
[AQAIN]CTY=func ADDCTY(N)
[AQAIN]CRY=func CRYSET(N,0)
[AQAIN]CRYNAM=func CRYSET(N,1)
[AQAIN]SAT=func ADDSAT(N)
[AQAIN]CREUSR="AAAAA"
[AQAIN]CREDAT=date$
[AQAIN]CREDATTIM=datetime$
[AQAIN]UPDDATTIM=datetime$
[AQAIN]UPDUSR="AAAAA"
[AQAIN]AUUID = getUuid
Write [AQAIN]
Next

If fstat
  GOK = 0 : Call FSTA("AQAIN") From GLOCK : Rollback : End
Endif

If !TMP_ADXLOG : Commit : Endif

Close Local File [AQAIN]
Close Local File [AQCCNT]

##########################################################
$TEXT
Local File ATEXTRA  [AXX]
Local File ATEXTRA  [AXX2]
Local File AQCPROT1 [AQCPROT1]
Local File AQCCONTACT [AQCCNT]
Local File AQCPOS   [AQCPOS]
Local File AQTABCOUNTRY [AQCTCY]
Local File AQCBPRL   [AQCBPRL]

#Goto SKIP1

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [AXX] : Endif

Local Integer I
I=1
N=1

#Infbox num$(fstat)
Filter [AQCPROT1] Where 1=1 Order By Key CLE = COD
For [AQCPROT1]
N+=1
[AXX]CODFIC="AQCPROT1"
[AXX]ZONE="TTEXT"
[AXX]LANGUE=[AQCPROT1]LAN
[AXX]IDENT1=[AQCPROT1]CLE
[AXX]IDENT2=[AQCPROT1]COD
[AXX]TEXTE="Text AXX " + num$(N*2)
[AXX]CREUSR="AAAAA"
[AXX]CREDAT=date$
[AXX]CREDATTIM=datetime$
[AXX]UPDDATTIM=datetime$
[AXX]UPDUSR="AAAAA"
[AXX]AUUID = getUuid
If [AQCPROT1]COD="101" : [AXX]TEXTE="Text AXX 11234567890123456789012345678901234657890" : Endif
Write [AXX]
Next

Filter [AQCPROT1] Where 1=1 Order By Key CLE = COD
For [AQCPROT1]
N+=1
[AXX]CODFIC="AQCPROT1"
[AXX]ZONE="INTDES"
[AXX]LANGUE=[AQCPROT1]LAN
[AXX]IDENT1=[AQCPROT1]COD
[AXX]IDENT2="AX3"
[AXX]TEXTE="Text AX3 1123456789012345678901"
[AXX]CREUSR="AAAAA"
[AXX]CREDAT=date$
[AXX]CREDATTIM=datetime$
[AXX]UPDDATTIM=datetime$
[AXX]UPDUSR="AAAAA"
[AXX]AUUID = getUuid
Write [AXX]
Next

Filter [AQCPROT1] Where 1=1 Order By Key CLE = COD
For [AQCPROT1]
N+=1
[AXX]CODFIC="AQCPROT1"
[AXX]ZONE="INTSHO"
[AXX]LANGUE=[AQCPROT1]LAN
[AXX]IDENT1=[AQCPROT1]COD
[AXX]IDENT2="AX1"
[AXX]TEXTE="Text AX190123"
[AXX]CREUSR="AAAAA"
[AXX]CREDAT=date$
[AXX]CREDATTIM=datetime$
[AXX]UPDDATTIM=datetime$
[AXX]UPDUSR="AAAAA"
[AXX]AUUID = getUuid
Write [AXX]
Next

For [AXX] Where [AXX]CODFIC='AQCPROT1'
[AXX2]=[AXX]
If [AXX2]LANGUE='ENG' : [AXX2]LANGUE='FRA' : Endif
If [AXX2]LANGUE='FRA' : [AXX2]LANGUE='ENG' : Endif
Write [AXX2]
Next

For [AQCCNT]
N+=1
[AXX]CODFIC="AQCCONTACT"
[AXX]ZONE="TEXT2"
[AXX]LANGUE='ENG'
[AXX]IDENT1=[AQCCNT]CCNCRM
[AXX]IDENT2=""
[AXX]TEXTE="Text " + num$(N*3)
[AXX]CREUSR="AAAAA"
[AXX]CREDAT=date$
[AXX]CREDATTIM=datetime$
[AXX]UPDDATTIM=datetime$
[AXX]UPDUSR="AAAAA"
[AXX]AUUID = getUuid
Write [AXX]
Next

For [AQCPOS]
N+=1
[AXX]CODFIC="AQCPOS"
[AXX]ZONE="TEXTPOS"
[AXX]LANGUE='ENG'
[AXX]IDENT1=[AQCPOS]POSCOD
[AXX]IDENT2=""
[AXX]TEXTE="POS Text " + num$(N*3)
[AXX]CREUSR="AAAAA"
[AXX]CREDAT=date$
[AXX]CREDATTIM=datetime$
[AXX]UPDDATTIM=datetime$
[AXX]UPDUSR="AAAAA"
[AXX]AUUID = getUuid
Write [AXX]
Next

For [AQCTCY]
N+=1
[AXX]CODFIC="AQTABCOUNTRY"
[AXX]ZONE="TEXTCRY"
[AXX]LANGUE='ENG'
[AXX]IDENT1=[AQCTCY]CRY
[AXX]IDENT2=""
[AXX]TEXTE="CRY Text " + num$(N*3)
[AXX]CREUSR="AAAAA"
[AXX]CREDAT=date$
[AXX]CREDATTIM=datetime$
[AXX]UPDDATTIM=datetime$
[AXX]UPDUSR="AAAAA"
[AXX]AUUID = getUuid
Write [AXX]
Next

For [AQCBPRL]
N+=1
[AXX]CODFIC="AQCBPRL"
[AXX]ZONE="TEXTBPRL"
[AXX]LANGUE='ENG'
[AXX]IDENT1=[AQCBPRL]BPANUM
[AXX]IDENT2="AXX"
[AXX]TEXTE="BPRL Text " + num$(N*3)
[AXX]CREUSR="AAAAA"
[AXX]CREDAT=date$
[AXX]CREDATTIM=datetime$
[AXX]UPDDATTIM=datetime$
[AXX]UPDUSR="AAAAA"
[AXX]AUUID = getUuid
Write [AXX]
Next

For [AQCBPRL]
N+=1
[AXX]CODFIC="AQCBPRL"
[AXX]ZONE="TTEXT"
[AXX]LANGUE='ENG'
[AXX]IDENT1=[AQCBPRL]BPANUM
[AXX]IDENT2="AX2"
[AXX]TEXTE="BPRL 6789012345678901"
[AXX]CREUSR="AAAAA"
[AXX]CREDAT=date$
[AXX]CREDATTIM=datetime$
[AXX]UPDDATTIM=datetime$
[AXX]UPDUSR="AAAAA"
[AXX]AUUID = getUuid
Write [AXX]
Next

For [AXX] Where [AXX]CODFIC='AQCCONTACT' | [AXX]CODFIC='AQCPOS' | [AXX]CODFIC='AQTABCCOUNTRY' | [AXX]CODFIC='AQCBPRL'
[AXX2]=[AXX]
If [AXX2]LANGUE='ENG' : [AXX2]LANGUE='FRA' : Endif
Write [AXX2]
Next

If fstat
  GOK = 0 : Call FSTA("AXX") From GLOCK : Rollback : End
Endif
#Infbox "GOK Check done"
If !TMP_ADXLOG : Commit : Endif

Close Local File [AXX]
Close Local File [AXX2]
Close Local File [AQCPROT1]
Close Local File [AQCCNT]
Close Local File [AQCPOS]
Close Local File [AQCTCY]
Close Local File [AQCBPRL]

$SKIP1
##########################################################
Funprog CRYSET(I,K)
Value Integer I
Value Integer K
Local Char RETCRY(30)

If K=0
  If int(I/2) = (I/2)
    RETCRY = "US"
    End RETCRY
  Else
    RETCRY = "FR"
    End RETCRY
  Endif
Else
If int(I/2) = (I/2)
  RETCRY = "United States"
  End RETCRY
Else
  RETCRY = "France"
  End RETCRY
Endif
Endif

End
