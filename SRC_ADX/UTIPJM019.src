#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIPJM019 Update PJMTSKITM.REQDAT
#
# Issue X3-34418 - 2017-05-02 by FGR
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM019(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM019(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE

  Call ECR_TRACE("UTIPJM019: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:JTT]) = 0 : Local File =DOSSIER + ".PJMTSKITM"  [JTT] : Endif
  If clalev([F:PJTA]) = 0 : Local File =DOSSIER + ".PJMTSK"  [PJTA] : Endif
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [JTT]
  Filter [JTT] Where [F:JTT]REQDAT = [0/0/0]
  For [JTT]
    Read [PJTA]PTA0=[F:JTT]OPPNUM;[F:JTT]TASCOD
    If !fstat Then
      # -----------------
      IUPDATE = 0
      If [F:PJTA]TASENDDT <> [0/0/0] Then
       [F:JTT]REQDAT = [F:PJTA]TASENDDT
       IUPDATE = 1
      Endif
      # -----------------
      If IUPDATE = 1 Then
        COMPTEUR += 1
        Rewrite [JTT]
        If fstat Then
          Call ECR_TRACE("File PJMTSKITM" - [F:JTT]OPPNUM - [F:JTT]TASCOD - num$([F:JTT]ITTSEQ) + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Endif
      Endif
      # -----------------
    Endif
  Next
  Filter [JTT]
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM019 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM019 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [JTT]
  Close Local File [PJTA]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"PJMTSKITM") : End : Endif
  Call MAJ_UTIPJM019(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If func DOSVUE.ISVIEW(APPLI,"PJMTSKITM") : End : Endif
  Call MAJ_UTIPJM019(APPLI)
End

