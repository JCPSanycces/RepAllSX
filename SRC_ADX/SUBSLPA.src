#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################
# Impression des étiquettes de stocks (suite)                          #
# -------------------------------------------------------------------- #
# Traitements sur champ "Call" de l'écran STOLBEIMP                    #
# Action  : STKLBEIMP (GTRAITE)                                        #
# Fenêtre : ISTOLBE                                                    #
# Traitement de l'action : SUBSLPA                                     #
# Gosub autres           : SUBSLPB                                     #
# -------------------------------------------------------------------- #
########################################################################
$OUVRE
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
Global Integer GWNUMREQ
If !clalev([F:STJ]) : Local File STOJOU    [STJ] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT[ITF] : Endif
If !clalev([F:ARP]) : Local File AREPORT   [ARP] : Endif
If !clalev([F:AIM]) : Local File APRINTER  [AIM] : Endif
If !clalev([F:AID]) : Local File APRINTDES [AID] : Endif
If !clalev([F:LBP]) : Local File LABELPRN  [LBP] : Endif
If !clalev([F:ACV]) : Local File ACTIV     [ACV] : Endif    : # hcb 41239
If !clalev([F:CUD]) : Local File CUNLISDET [CUD] : Endif    : # hcb 61166


If GMODU(8) = 2
        If clalev ([F:MTK]) <= 0 : Local File MFGHEADTRK [MTK] : Endif 
        If clalev ([F:MFG]) <= 0 : Local File MFGHEAD    [MFG] : Endif 
        If clalev ([F:MFI]) <= 0 : Local File MFGITM     [MFI] : Endif 
        If clalev ([F:MKI]) <= 0 : Local File MFGITMTRK  [MKI] : Endif :# sr 030200
Endif
If GMODU(6) = 2
       If clalev ([F:PTH]) <= 0 : Local File PRECEIPT   [PTH] : Endif 
Endif
If GMODU(5) = 2
        If clalev ([F:SRH]) <= 0 : Local File SRETURN    [SRH] : Endif 
Endif

Return

$DEBUT
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
    Raz [M:SLP]
    If PARAM(1)<>""
        [M:SLP]STOFCY = PARAM(1)
        Diszo [M:SLP]STOFCY
    Endif
    If PARAM(2)<>""
        [M:SLP]LBEVCRTYP = val(PARAM(2))
        Diszo [M:SLP]LBEVCRTYP 
    Endif
    If PARAM(3)<>""
        [M:SLP]VCRNUMSTR = PARAM(3)
        Diszo [M:SLP]VCRNUMSTR 
        [M:SLP]VCRNUMEND = [M:SLP]VCRNUMSTR
        Diszo [M:SLP]VCRNUMEND
        Diszo [M:SLP]IPTDATSTR,IPTDATEND
        #-- à la demande de SR:
        Diszo [M:SLP]TCLCODSTR,TCLCODEND
        Diszo [M:SLP]ITMREFSTR,ITMREFEND
    Endif
    If dim(PARAM)>3 & PARAM(4)<>""
        [M:SLP]VCRNUMEND = PARAM(4)
    Endif
    If dim(PARAM)>4 & PARAM(5)<>""
        Case PARAM(5)
            When "SSL1":
                [M:SLP]ABRDOC = PARAM(5)
                If !clalev([F:AMK]) : Local File AMSK [AMK] : Endif
                Read [AMK]CODMSK="SSL1"
                If !fstat
                    Call TEXTE([F:AMK]INTMSK,[M:SLP]TITDOC) From OBJDIV
                Endif
                Raz [M:SLP]LBEVCRTYP
                Diszo [M:SLP]LBEVCRTYP
                Diszo [M:SLP]VCRNUMSTR 
                Diszo [M:SLP]VCRNUMEND
                Diszo [M:SLP]IPTDATSTR,IPTDATEND
                Diszo [M:SLP]TCLCODSTR,TCLCODEND
                Diszo [M:SLP]ITMREFSTR,ITMREFEND
                # Charger les noms de champs dans les zones de [M:SLP]: WZONVCRTYP, WZONVCRNUM et WZONVCRLIN
                # Pour filtrer dans le masque, remplir [M:SLP]WMSKFIL en utilisant "I" comme indice
                Gosub CHARG_PARAM_SLP From TRTSSLA
        Endcase
    Endif
    Call RELOAD From SUBSLPB
    If [M:SLP]NBLIG=0 & GFONCTION<>"FUNLBEIMP"
        FIN=1
    Endif
Return

$SETBOUT
#-------------------------------#
# Grisage/dégrisage des boutons #
#-------------------------------#
If [M:SLP]NBLIG=0
    Call VIREBOUT(CHBOU,"2") From GOBJET
Endif
Return

$BOUTON
#------------------------#
# Traitement des boutons #
#------------------------#
Local Integer LRET
Case BOUT
    When "1" :  Call RELOAD From SUBSLPB
    When "2" :  Call PRINT(LRET)  From SUBSLPB
                Raz GPE                         # hcb 85722
                GPOINT = "RELOAD"               # hcb 85722
                Gosub  ENTREE From EXEFNC       # hcb 85722
                If GPE =  0                     # hcb 85722
                   Call RELOAD From SUBSLPB                 # hcb 61166
                Endif                           # hcb 85722
Endcase
Return

