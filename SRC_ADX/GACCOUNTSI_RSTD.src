#<AdxTL>@(#)0.0.0.0 $Revision$
# Class GACCOUNTSI

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

$AQUERY_TRANS_AFTER

  # Change to -1 or 1 instead of Expense or Revenue
  If [F:CLS]SNSANA=2  : this.GAC.ACCSGN=-1
  Else                : this.GAC.ACCSGN=1
  Endif

  # Income statement or balance sheet
  If [F:CLS]ERA=1     : this.GAC.ACCCAT="I"
  Else                : this.GAC.ACCCAT="B"
  Endif

  # Expand the array to individual fields
  this.GAC.RPTCODDEB0 = [F:GAC]RPTCODDEB(0)
  this.GAC.RPTCODDEB1 = [F:GAC]RPTCODDEB(1)
  this.GAC.RPTCODDEB2 = [F:GAC]RPTCODDEB(2)
  this.GAC.RPTCODDEB3 = [F:GAC]RPTCODDEB(3)
  this.GAC.RPTCODDEB4 = [F:GAC]RPTCODDEB(4)
  this.GAC.RPTCODDEB5 = [F:GAC]RPTCODDEB(5)
  this.GAC.RPTCODDEB6 = [F:GAC]RPTCODDEB(6)
  this.GAC.RPTCODDEB7 = [F:GAC]RPTCODDEB(7)
  this.GAC.RPTCODDEB8 = [F:GAC]RPTCODDEB(8)
  this.GAC.RPTCODDEB9 = [F:GAC]RPTCODDEB(9)

  this.GAC.RPTCODCDT0 = [F:GAC]RPTCODCDT(0)
  this.GAC.RPTCODCDT1 = [F:GAC]RPTCODCDT(1)
  this.GAC.RPTCODCDT2 = [F:GAC]RPTCODCDT(2)
  this.GAC.RPTCODCDT3 = [F:GAC]RPTCODCDT(3)
  this.GAC.RPTCODCDT4 = [F:GAC]RPTCODCDT(4)
  this.GAC.RPTCODCDT5 = [F:GAC]RPTCODCDT(5)
  this.GAC.RPTCODCDT6 = [F:GAC]RPTCODCDT(6)
  this.GAC.RPTCODCDT7 = [F:GAC]RPTCODCDT(7)
  this.GAC.RPTCODCDT8 = [F:GAC]RPTCODCDT(8)
  this.GAC.RPTCODCDT9 = [F:GAC]RPTCODCDT(9)

Return

