# Supervisor
## CRUD-CLASSE ## EMPLOEXM
# 2018-11-06 07:06:14 168

Gosub TEST From WMCR_EMPLOEXM : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,REFNUM,NUMLIG)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EMPLOEXM : EMPLOEXM
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EMPLOEXM._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EMPLOEXM.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EMPLOEXM.ACTX.AFOLDER,nomap,"")>0
 Local File EMPLOEXM [HREXM]
 Local File EMPLOEXM [AAA_]
Else
 Local File =EMPLOEXM.ACTX.AFOLDER+".EMPLOEXM" [HREXM]
 Local File =EMPLOEXM.ACTX.AFOLDER+".EMPLOEXM" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [HREXM] With
& [AAA_]EXM0 = REFNUM+NUMLIG
& As [LNK_]
Return

############################################################################################
### EMPLOEXM(WHREXM)
############################################################################################
Funprog  _MAJSQL_EMPLOEXM(WHREXM)
Variable Instance WHREXM Using C_EMPLOEXM
Local Integer ASTATUS,A_I,A_J
Default File [F:HREXM]
If WHREXM.ASTALIN=[V]CST_ANEW
 Call INICRE(WHREXM) From ASYRSUB
 SetInstance [F:HREXM] With WHREXM
 Write [F:HREXM]
 If fstat
  Call FSTA("HREXM",WHREXM,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WHREXM.updTick = [F:HREXM]updTick
Elsif WHREXM.ASTALIN=[V]CST_ALL or WHREXM.ASTALIN=[V]CST_AUPD
 Call INIUPD(WHREXM) From ASYRSUB
 SetInstance [F:HREXM] With WHREXM
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WHREXM,"EMPLOEXM")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:HREXM]EXM0 = [F:HREXM]REFNUM;[F:HREXM]NUMLIG
 If fstat
  Call FSTA("HREXM",WHREXM,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WHREXM.updTick = [F:HREXM]updTick
Elsif WHREXM.ASTALIN=[V]CST_ADEL
 SetInstance [F:HREXM] With WHREXM
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WHREXM,"EMPLOEXM")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:HREXM]EXM0 = [F:HREXM]REFNUM;[F:HREXM]NUMLIG
 If fstat
  Call FSTA("HREXM",WHREXM,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



