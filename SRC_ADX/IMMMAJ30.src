#<AdxTL>@(#)12.0.0.0 $Revision$
###################################################################################
# ------------------------------------------------------------------------------- #
# IMMMAJ30 : M.a.j à effectuer lors du passage à version 6  Module Immobilisation #
# ------------------------------------------------------------------------------- #
# Rectification du dictionnaire : AIMMMAJ30                                       #
#   - Tables remplacées avec même abréviation en V6                               #
#           [F:CDS] table V5 CDIADSPSCT => V6 [CD2]                               #
#           [F:FAS] table V5 FIXASSET   => V6 [FA2]                               #
#           [FAS]    Objet V5 FAS       => V6 [FAZ]                               #
#                                                                                 #
###################################################################################
End
 
Subprog AIMMMAJ30
   Call AV_CDS
   Call AV_FAS
End

#################################################################################
# Abréviation [F:CDS] table V5 CDIADSPSCT => [F:CD2]
#################################################################################
Subprog AV_CDS
If filinfo(filpath("FIL","CDIADSPSCT","fde",[F:ADS]DOSSIER),0) <=0   End   Endif

If clalev([F:ATB]) : Close Local File [ATB] : Endif
Local File =[F:ADS]DOSSIER+".ATABLE"  [ATB]
If clalev([F:ATZ]) : Close Local File [ATZ] : Endif
Local File =[F:ADS]DOSSIER+".ATABZON" [ATZ]
If clalev([F:ATI]) : Close Local File [ATI] : Endif
Local File =[F:ADS]DOSSIER+".ATABIND" [ATI]

Call ECR_TRACE("IMMMAJ30 Replacing abbreviation [CDS] for table CDIADSPSCT by [CD2]",0) From GESECRAN

#Readlock [F:ATB]CODFIC="CDIADSPSCT"  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
Read [F:ATB]CODFIC="CDIADSPSCT"  # FGR 11/03/2010 : X3SUIVI63191
If !fstat
   If [F:ATB]ABRFIC="CDS" : [F:ATB]ABRFIC = "CD2" : Endif
   Rewrite [F:ATB]
   If fstat # Erreur en cas d'abrév existante => on supprime
      Delete [F:ATZ] Where CODFIC="CDIADSPSCT"
      Delete [F:ATI] Where CODFIC="CDIADSPSCT"
      Delete [F:ATB] Where CODFIC="CDIADSPSCT"
   Endif
Endif

Close File [ATB]
Close File [ATZ]
Close File [ATI]
End

#################################################################################
# Abréviation [F:FAS] table V5 FIXASSET => [F:FA2]
#################################################################################
Subprog AV_FAS
If filinfo(filpath("FIL","FIXASSET","fde",[F:ADS]DOSSIER),0) <=0   End   Endif

If clalev([F:ATB]) : Close Local File [ATB] : Endif
Local File =[F:ADS]DOSSIER+".ATABLE"  [ATB]
If clalev([F:ATZ]) : Close Local File [ATZ] : Endif
Local File =[F:ADS]DOSSIER+".ATABZON" [ATZ]
If clalev([F:ATI]) : Close Local File [ATI] : Endif
Local File =[F:ADS]DOSSIER+".ATABIND" [ATI]

Call ECR_TRACE("IMMMAJ30 Replacing abbreviation [FAS] for table FIXASSET by [FA2]",0) From GESECRAN

#Readlock [F:ATB]CODFIC="FIXASSET"  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
Read [F:ATB]CODFIC="FIXASSET"  # FGR 11/03/2010 : X3SUIVI63191
If !fstat
   If [F:ATB]ABRFIC="FAS" : [F:ATB]ABRFIC = "FA2" : Endif
   Rewrite [F:ATB]
   If fstat # Erreur en cas d'abrév existante => on supprime
      Delete [F:ATZ] Where CODFIC="FIXASSET"
      Delete [F:ATI] Where CODFIC="FIXASSET"
      Delete [F:ATB] Where CODFIC="FIXASSET"
   Endif
Endif

Close File [ATB]
Close File [ATZ]
Close File [ATI]

#################################################################################
# Objet V5  [FAS]  =>  renommé en objet [FAz]
#################################################################################
If clalev([F:AOB5]) : Close Local File [AOB5] : Endif
Local File =[F:ADS]DOSSIER+".AOBJET"   [AOB5]
If clalev([F:AOT5]) : Close Local File [AOT5] : Endif
Local File =[F:ADS]DOSSIER+".AOBJTAB"  [AOT5]
If clalev([F:AOL5]) : Close Local File [AOL5] : Endif
Local File =[F:ADS]DOSSIER+".AOBJLST"  [AOL5]
If clalev([F:XAOB]) : Close Local File [XAOB] : Endif
Local File =[F:ADS]DOSSIER+".AOBJET"   [XAOB]
If clalev([F:XAOT]) : Close Local File [XAOT] : Endif
Local File =[F:ADS]DOSSIER+".AOBJTAB"  [XAOT]
If clalev([F:XAOL]) : Close Local File [XAOL] : Endif
Local File =[F:ADS]DOSSIER+".AOBJLST"  [XAOL]

Call ECR_TRACE("IMMMAJ30 Renaming object [FAS] by object [FAZ] ",0) From GESECRAN

#Readlock [F:AOB5]ABREV="FAS"  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
Read [F:AOB5]ABREV="FAS"  # FGR 11/03/2010 : X3SUIVI63191
If fstat = 0 
   [F:XAOB]      = [F:AOB5]
   [F:XAOB]ABREV = "FAZ" 
   Write [F:XAOB]
   If fstat= 0 # On a copié FAS dans FAZ
      # On supprime l'objet FAS
      Delete [F:AOB5] Where ABREV="FAS"
   Endif
Endif

#Readlock [F:AOL5]AOL0="FAS"  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
Read [F:AOL5]AOL0="FAS"  # FGR 11/03/2010 : X3SUIVI63191
If fstat = 0 
   [F:XAOL]      = [F:AOL5]
   [F:XAOL]ABREV = "FAZ" 
   Write [F:XAOL]
   If fstat= 0 # On a copié FAS dans FAZ
      # On supprime l'objet FAS
      Delete [F:AOL5] Where ABREV="FAS"
   Endif
Endif

For[F:AOT5] Where ABREV="FAS"
   #Readlock [F:AOT5]ABREV="FAS"  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
   If fstat = 0 
      [F:XAOT]      = [F:AOT5]
      [F:XAOT]ABREV = "FAZ" 
      Write [F:XAOT]
      If fstat= 0 # On a copié FAS dans FAZ
         # On supprime l'objet FAS
         Delete [F:AOT5] Where ABREV="FAS"
      Endif
   Endif
Next

Close File [AOB5]
Close File [AOL5]
Close File [AOT5]
Close File [XAOB]
Close File [XAOT]
Close File [XAOL]


End
