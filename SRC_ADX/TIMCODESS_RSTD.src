# Class TIMCODESS


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AQUERY_CRITERIA_AFTER"  : Gosub AQUERY_CRITERIA_AFTER
    Endcase
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

$AQUERY_CRITERIA_AFTER
#MIPEA - 2018-02-28- US X3-80413- START
#Local Char CURRENT_CTR(GLONHRCTR)
#
#CURRENT_CTR = 1##PARAM???
#MIPEA - 2018-02-28- US X3-80413- END

#MIPEA - 2018-02-28- US X3-80413- START
#If func AFNC.ACTIV("GLM")
#  If (PQRY.QWHERE <> "")
#    PQRY.QWHERE = "(" + PQRY.QWHERE + ") and (find(Func TIMCODESS_RSTD(CURRENT_CTR)))"
#  Else
#    PQRY.QWHERE = "(find(Func TIMCODESS_RSTD(CURRENT_CTR)))"
#  Endif
#Else
#  If (PQRY.QWHERE <> "")
#    PQRY.QWHERE = "(" + PQRY.QWHERE + ") and (CATTIM eq 3) and (ENAFLG eq 2) and (AUZPRH eq 2)"
#  Else
#    PQRY.QWHERE = "(CATTIM eq 3) and (ENAFLG eq 2) and (AUZPRH eq 2)"
#  Endif
#Endif


If func AFNC.ACTIV("GLM")>0
  If (PQRY.QWHERE <> "")
    PQRY.QWHERE = "(" + PQRY.QWHERE + ") and (CATTIM eq 3) and (ENAFLG eq 2) and (AUZPRH eq 2) and (LVEENHANCE eq 2)"
  Else
    PQRY.QWHERE = "(CATTIM eq 3) and (ENAFLG eq 2) and (AUZPRH eq 2) and (LVEENHANCE eq 2)"
  Endif
Else
  If (PQRY.QWHERE <> "")
    PQRY.QWHERE = "(" + PQRY.QWHERE + ") and (CATTIM eq 3) and (ENAFLG eq 2) and (AUZPRH eq 2)"
  Else
    PQRY.QWHERE = "(CATTIM eq 3) and (ENAFLG eq 2) and (AUZPRH eq 2)"
  Endif
Endif
#MIPEA - 2018-02-28- US X3-80413- END
Return

#MIPEA - 2018-02-28- US X3-80413- START
Funprog GET_TIM_SELECTION(CURRENT_CTR)
Local Char SOA_GCURLEG(GLONADI)
Value Char CURRENT_CTR

        If clalev([F:TIM2]) =0     : Local File TIMCOD [TIM2] Endif
        If clalev([HRLSTD]) = 0      : Local File HRLVESUBDET [HRLSTD] Endif
        If clalev([HRLSTH]) = 0      : Local File HRLVESUBHEA [HRLSTH] Endif
        #If clalev([HRLSTH1]) = 0      : Local File HRLVESUBHEA [HRLSTH1] Endif
        If clalev([HRCTR]) = 0    : Local File EMPLOCTR [HRCTR] Endif
        If clalev ([ID]) = 0      : Local File EMPLOID [ID] Endif
        If clalev ([FCY]) = 0     : Local File FACILITY [FCY] Endif
        If clalev ([CPY]) = 0     : Local File COMPANY [CPY] Endif
        If clalev ([HRPOA]) = 0   : Local File POPULA [HRPOA] Endif
        If clalev ([HRCLV]) = 0   : Local File HRCLLCVT [HRCLV] Endif
        If clalev ([SRV]) = 0   : Local File SERVICE [SRV] Endif
        If clalev ([PRF]) = 0   : Local File PROFIL [PRF] Endif

        Local Integer S, L
        Local Char CRITACC1(250),CRITACC2(250)
        Local Char LIS_TPS(GLONTPS)(0..100)
        Local Integer CRITCOUNT

        Filter [F:HRCTR] Where [F:HRCTR]CTRNUM = CURRENT_CTR
        Read [F:HRCTR] First
        Filter [F:HRCTR]
        SOA_GCURLEG = func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTR]REFNUM, [F:HRCTR]CTRNUM, [F:HRCTR]CTRDAT, 1)

        Filter [F:TIM2] Where ([F:TIM2]LVEENHANCE=2 & ([F:TIM2]CATTIM=3 | [F:TIM2]CATTIM=2)) and [F:TIM2]ENAFLG=2 and [F:TIM2]LEG = SOA_GCURLEG
        #Looping 1. HRTIM 2. HRLST 3.HRCTR/HRMAT
        For [TIM2]
          For S=1 To dim([F:TIM2]LVESUBTYP)
            CRITACC1 = "1=0"
            CRITACC2 = "1=0"
            If [F:TIM2]LVESUBTYP(S-1) <> ""
              CRITCOUNT=1
              For [HRLSTD] Where [HRLSTD]COD = [F:TIM2]LVESUBTYP(S-1)
                If len(CRITACC1)>=200 : CRITCOUNT=2 : Endif
                If CRITCOUNT=1
                  Case [HRLSTD]LEV
                    When 1  : CRITACC1 = CRITACC1 - " | 1=1"  #Folder
                    When 2  : CRITACC1 = CRITACC1 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                    When 3  : CRITACC1 = CRITACC1 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                    When 4  : CRITACC1 = CRITACC1 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                    When 5  : CRITACC1 = CRITACC1 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                    When 6  : CRITACC1 = CRITACC1 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                    When 7  : CRITACC1 = CRITACC1 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                    When 8  : CRITACC1 = CRITACC1 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                    When 9  : CRITACC1 = CRITACC1 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                    When 10 : CRITACC1 = CRITACC1 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                  Endcase
                Else
                  Case [HRLSTD]LEV
                    When 1  : CRITACC2 = CRITACC2 - " | 1=1"  #Folder
                    When 2  : CRITACC2 = CRITACC2 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                    When 3  : CRITACC2 = CRITACC2 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                    When 4  : CRITACC2 = CRITACC2 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                    When 5  : CRITACC2 = CRITACC2 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                    When 6  : CRITACC2 = CRITACC2 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                    When 7  : CRITACC2 = CRITACC2 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                    When 8  : CRITACC2 = CRITACC2 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                    When 9  : CRITACC2 = CRITACC2 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                    When 10 : CRITACC2 = CRITACC2 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                  Endcase
                Endif
              Next

            If [HRLSTD]LEV=3
              Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF,
&             [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&             As [LNK]
&             Where evalue(CRITACC1) or evalue(CRITACC2)
            Else
              Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF
&             As [LNK]
&             Where evalue(CRITACC1) or evalue(CRITACC2)
            Endif

          #Filter [LNK] Where CTRNUM=PARAM(1)
              Filter [LNK] Where CTRNUM=1##PARAM???
        #If rowcount([LNK])>0 & !find([TIM]LVESUBTYP(S-1),LIS_HRLST(0..100)) : LIS_HRLST(L) = [TIM]LVESUBTYP(S-1) : L+=1 : Endif
              If rowcount([LNK])>0 & !find([F:TIM2]COD,LIS_TPS(0..100))
                LIS_TPS(L) = [F:TIM2]COD
                L+=1
              Endif
              Filter [LNK]
            Endif
          Next
        Next
        Filter [F:TIM2]

End LIS_TPS
#MIPEA - 2018-02-28- US X3-80413- END

