##############################################################################
## DEMANDE 51635
##   L'utilitaire pour remplacé DAT par ACCDAT sous GDIAENTRYD
##############################################################################
Call PATCH(nomap)
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".GDIAENTRYD" [GDD]

Trbegin  [GDD]

Update [GDD] Where FLD="DAT" With FLD="ACCDAT"
If !fstat
 Commit
Else
 Rollback
Endif


Close Local File
End

