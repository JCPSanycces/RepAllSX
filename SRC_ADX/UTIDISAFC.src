#<AdxTL>@(#)8.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Désactivation de la fonction ADOSCOP (nouvelle fonction = ADOSCOPDAT)
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Deactivation function ADOSCOP") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DESCOP
End

#-------------------#
$DESCOP

Local Integer OFF

Local File =DOSSIER+".AFONCTION" [AFC]

Trbegin [AFC]
 Read [AFC]CODINT = "ADOSCOP"
 If !fstat & [F:AFC]MENU<>""
  [F:AFC]MENU = ""
  [F:AFC]RANG = 0
  [F:AFC]LIBMENU = 0
  Rewrite [AFC] 
  If fstat
   Call ERREUR("AFONCTION"-[F:AFC]CODINT,2) From DOSDIC
  Else
   OFF = 1
  Endif
 Endif
Commit

Close Local File [AFC]

If OFF
 Call ECR_TRACE("Deactivation function ADOSCOP:"-time$,0) From GESECRAN
Endif

Return
