#<AdxTL>@(#)9.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
##################################################################################
# DOSMAJ4 : Mises à jour à effectuer lors du passage à la version 120 (Release 4) 
##################################################################################
##  Avant mise à jour                                                             
#---------------------------------------------------------------------------------
#   Achats :                                                                       
#   Paramétrage tarifs achats (PPRICCONF) : remplacement de ENAFLG par PLIENAFLG  
#       - Stockage de ENAFLG dans le 1er caractère de PLIDES                            
#                                                                                 
#   Ventes :                                                                       
#   Paramétrage tarifs ventes (SPRICCONF) : remplacement de ENAFLG par PLIENAFLG  
#       - Stockage de ENAFLG dans le 1er caractère de PLIDES                       
##################################################################################
##  Après mise à jour                                                             
#---------------------------------------------------------------------------------
#   Achats :                                                                       
#   Dans transactions achats (PURTRS)                                             
#       - Initialisation du flag actif (ENAFLG)                                   
#       - Initialisation du flag affichage montant ligne (LINAMTFLG)              
#   Paramétrage tarifs achats (PPRICCONF) : remplacement de ENAFLG par PLIENAFLG  
#       - Recup de PLIENAFLG dans le 1er caractère de PLIDES                            
#   Dans Fichiers lignes appel d'offre, demande d'achat, commande, réception, retour
#                        et facture
#       - Initialisation ITMDES1 avec ITMDES
#   Dans Fichiers lignes de commande et historique (PORDERQ UPORDERQ)
#       - Initialisation de la nouvelle zone POQLNK par concaténation de POPLIN et POQSEQ
#                                                                                 
#   Ventes :                                                                       
#   Dans transactions ventes (SALTRS)                                              
#       - Initialisation du flag actif (ENAFLG)                                   
#       - Initialisation des zones traitement Tableau/Fiche                       
#       - Initialisation des nvlles zones ALLQTYCOD, SHTQTYCOD, WALLQTYCOD, VOLCOD
#   Paramétrage tarifs ventes (SPRICCONF) : remplacement de ENAFLG par PLIENAFLG  
#       - Recup de PLIENAFLG dans le 1er caractère de PLIDES                       
#   Dans Fichiers lignes de commande (SORDERQ SORDERP) et historiques (VSORDERQ VSORDERP)
#       - Recup de FMI POHNUM POPLIN POQSEQ ds SORDERP et bascule ds SORDERQ      
#   Dans Fichiers lignes de commande (SORDERQ) 
#       - Bascule qte facturée non validée (INVQTY(STU)) dans qte en cours de liv (ODLQTY(STU))
#         si cde à facturation directe (SOHCAT=3)
#       - Maj de l'en-cours (la qte est réalisée si la livraison (facture) est validée,
#                            sinon elle est allouée)
#   Dans Fichiers Livraisons (SDELIVERY SDELIVERYD) 
#       - Dans entête, raz type livraison (SDHCAT) et alimentation flag prêt (LND)
#       - Dans lignes, alimentation type commande (SOHCAT) si ligne issue d'une commande
#   Dans Fichiers lignes de retours  (SRETURND)                                   
#       - Initialisation RTNCNOFLG                      
#   Dans Fichiers lignes devis,commande(histo),livraison,facture et cde ouv article(histo)
#       - Initialisation ITMDES avec ITMDES1
#   Dans Fichiers factures (SINVOICEV)
#       - Chargement du type de facture utilisateur SIVTYP
#       - Transformation SIHTYP en INVTYP (1=facture / 2=avoir / 3=proforma)
#
#   STOCKS
#   Dans Fichier lignes de stocks STOCK
#       - Initialisation du flag de blocage inventaire 
#   Dans Fichier entête inventaire
#       - Initialisation nouveaux champs 
#   Dans Fichier mouvements stocks
#       - Correction zones non initialisées    
#                                                                                 
#   GPAO  :                                                      
#   Dans transactions GPAO   (MFGTRS)                                              
#       - Initialisation du flag actif     (ENAFLG)
#       - Flag stock manuel/auto           (MODTRSCOD)
#       - Mode étiquetage                  (LBEMOD)
#       - Flag transaction réservée auto.  (TRSAUTO)
#   Dans entête OF (MFGHEAD)
#       - flag optimisation                (OPTFLG)          
#   Dans déclarations de production (MFGITMTRK)
#       - Mode mise à jour stock           (WTRSCOD)
#   Dans documents OF    (MFGPRN)
#       - Mode étiquetage                  (LBEMOD)
#   Dans parmétrage jalonnement (PARJAL)
#       - Ajustement automatique           (WKLBUCCOR)
#       - Rejalonnement aval auto          (AUTFRWSCD)
#       - Rejalonnement forcé              (AUTFRCSCD)
#       - Nb périodes jour                 (WKLDAYNBR) forcé à 200
#                                                                 
#                                                                                 
#   Tronc commun :                                                                
#   Dans transactions stocks (STOTRS)                                             
#       - Initialisation du flag actif (ENAFLG)                                    
#       - Initialisation du parametre saisie rapide (TRSCOD)                      
#   Fichier article      (ITMMASTER)                                             
#       - Affectation des numéros pour les désignations traduisibles (ITMNUMx)
#       - et création des textes à traduire dans ATEXTRA  
#   Fichier article-site (ITMFACILIT)                                             
#       - Initialisation flag prise en compte emplacement de picking (TIAPICLOC)  
#   Traitements liés aux regroupements société-site
#       - Fichier site (FACILITY)                                             
#         Pour chaque site, création de l'enr regroupement de site s'il n'existe pas 
#       - Fichier regroupement de site (FACGROUP)                                             
#         Pour chaque enr, s'il s'agit d'une soc. juridique, vérif que cette soc. est bien 
#                          la soc. juridique du site. Si ce n'est pas le cas, suppres de l'enr
#   Fichier tiers (BPARTNER)                                         
#       - Initialisation du flag inter-site si le tiers est un client intra-société  
#                                                                                 
#   Achat :                                                                       
#       - Pour compta/tiers CPTMAJ4 (flags actifs)                                      
#                                                                                 
#   Superviseur :                                                                       
#       - Pour la messagerie SUPMAJ4, initialisation des nouvelles zones de AMESSAGE et AMESSAGED
#       - Initialisation dans AOBJET des zones SELZON, SELTREE, ... attribuées à l'utilisateur
#
##################################################################################

## Avant mise à jour
Subprog AMAJ

Call AACHMAJ4               : # Appel aux moulinettes Achat
Call AVENMAJ4               : # Appel aux moulinettes Vente

# Comme il y a eu beaucoup de changement dans le superviseur, on revalide tout

GVALIDE(1) = 2 : # les tables (changement des formats de zone pour SQL, DB2)
GVALIDE(2) = 2 : # les écrans
GVALIDE(3) = 2 : # les objets (zones en +)
GVALIDE(4) = 2 : # TRT générés superviseur
GVALIDE(5) = 2 : # TRT générés compta
GVALIDE(6) = 2 : # TRT générés tiers
GVALIDE(7) = 2 : # TRT générés ventes
GVALIDE(8) = 2 : # TRT générés achats
GVALIDE(9) = 2 : # TRT générés stocks
GVALIDE(10) = 2 : # TRT générés gpao

End

###################################################################################


## Après mise à jour
Subprog MAJ

Call ACHMAJ4                : # Appel aux moulinettes Achat
Call VENMAJ4                : # Appel aux moulinettes Vente
Call MFGMAJ4                : # Appel aux moulinettes GPAO
Call TRCMAJ4                : # Appel aux moulinettes Tronc commun
Call STKMAJ4                : # Appel aux moulinettes Stock
Call MAJ4 From CPTMAJ4      : # Appel aux moulinettes Compta
Call SUPMAJ4                : # Appel aux moulinettes Superviseur
End


###################################################################################

#---------------------------------------------------------------------------------#
#    Moulinette Avant mise à jour concernant le module Achat                      #
#---------------------------------------------------------------------------------#
Subprog AACHMAJ4

If filinfo(filpath("FIL","PPRICCONF","fde",[F:ADS]DOSSIER),0) < 0 End : Endif

#-----------------------------------------------------------------------#
# Paramétrage des tarifs achats (remplacement de ENAFLG par PLIENAFLG)  #
#  - stockage de ENAFLG dans 1er caractere de PLIDES                    #  
#-----------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".PPRICCONF" [PPC]
Call ECR_TRACE("DOSMAJ4 Purchases Pricing Parameters Process : Update PPRICCONF",0) From GESECRAN
Trbegin [PPC]
  For [PPC]
    If dim([F:PPC]ENAFLG)>0
      If left$([F:PPC]PLIDES,1)<>num$([F:PPC]ENAFLG)
        [F:PPC]PLIDES=num$([F:PPC]ENAFLG)+[F:PPC]PLIDES
        Rewrite [PPC]
        If fstat
          Call ECR_TRACE("File PPRICCONF, Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Endif
  Next
Commit
Close Local File [PPC]
End

#---------------------------------------------------------------------------------#
#    Moulinette Avant mise à jour concernant le module Vente                      #
#---------------------------------------------------------------------------------#
Subprog AVENMAJ4

If filinfo(filpath("FIL","SPRICCONF","fde",[F:ADS]DOSSIER),0) < 0 End Endif

#-----------------------------------------------------------------------#
# Paramétrage des tarifs ventes (remplacement de ENAFLG par PLIENAFLG)  #
#  - stockage de ENAFLG dans 1er caractere de PLIDES                    #  
#-----------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".SPRICCONF" [SPC]
Call ECR_TRACE("DOSMAJ4 Sales Pricing Parameters Process : Update SPRICCONF",0) From GESECRAN
Trbegin [SPC]
  For [SPC]
    If dim([F:SPC]ENAFLG) > 0
      If left$([F:SPC]PLIDES,1) <> num$([F:SPC]ENAFLG)
        [F:SPC]PLIDES=num$([F:SPC]ENAFLG)+[F:SPC]PLIDES
        Rewrite [SPC]
        If fstat
          Call ECR_TRACE("File SPRICCONF, Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Endif
  Next
Commit
Close Local File [SPC]
End

###################################################################################

#---------------------------------------------------------------------------------#
#    Moulinette Après mise à jour concernant le module Achat                      #
#---------------------------------------------------------------------------------#
Subprog ACHMAJ4

If filinfo(filpath("FIL","PURTRS","fde",[F:ADS]DOSSIER),0)    < 0 End : Endif
If filinfo(filpath("FIL","PPRICCONF","fde",[F:ADS]DOSSIER),0) < 0 End : Endif
If filinfo(filpath("FIL","TABPIVTYP","fde",[F:ADS]DOSSIER),0) < 0 End : Endif
If filinfo(filpath("FIL","PINVOICE","fde",[F:ADS]DOSSIER),0)  < 0 End : Endif
If filinfo(filpath("FIL","PINVOICEV","fde",[F:ADS]DOSSIER),0) < 0 End : Endif
If filinfo(filpath("FIL","PINVOICED","fde",[F:ADS]DOSSIER),0) < 0 End : Endif

#-----------------------------------------------------------------------#
# Initialisation transactions achats (code actif et affichage Mt ligne) #
#-----------------------------------------------------------------------#
Local Shortint INDIC, I
Local File =[F:ADS]DOSSIER+".PURTRS" [PTR]
Call ECR_TRACE("DOSMAJ4 Purchase Transactions Process : Update PURTRS",0) From GESECRAN
Trbegin [PTR]
  For [PTR]
    Raz INDIC
    If [F:PTR]ENAFLG<1 or [F:PTR]ENAFLG>2
      INDIC=1 : [F:PTR]ENAFLG=2
    Endif
    If [F:PTR]PTRTYP=3 & ([F:PTR]LINAMTFLG<1 or [F:PTR]LINAMTFLG>2)
      INDIC=1 : [F:PTR]LINAMTFLG=1
    Endif
    For I=0 To dim([F:PTR]CCECOD)-1
      If [F:PTR]CCECOD(I)>0 & [F:PTR]CCESCR(I)=0 INDIC=1 : [F:PTR]CCESCR(I)=1 : Endif
    Next I
    If [F:PTR]QTYSTUCOD>0 & [F:PTR]QTYSTUSCR=0 INDIC=1 : [F:PTR]QTYSTUSCR=1 : Endif
    If [F:PTR]BPSCOD>0    & [F:PTR]BPSSCR=0    INDIC=1 : [F:PTR]BPSSCR=1    : Endif
    If [F:PTR]PRICOD>0    & [F:PTR]PRISCR=0    INDIC=1 : [F:PTR]PRISCR=1    : Endif
    If [F:PTR]PRIFLG>0    & [F:PTR]PRISCR=0    INDIC=1 : [F:PTR]PRISCR=1    : Endif
    If [F:PTR]ORDDATCOD>0 & [F:PTR]ORDDATSCR=0 INDIC=1 : [F:PTR]ORDDATSCR=1 : Endif
    If [F:PTR]RCPFCYCOD>0 & [F:PTR]RCPFCYSCR=0 INDIC=1 : [F:PTR]RCPFCYSCR=1 : Endif
    If [F:PTR]PJTCOD>0    & [F:PTR]PJTSCR=0    INDIC=1 : [F:PTR]PJTSCR=1    : Endif
    If [F:PTR]EECINCCOD>0 & [F:PTR]EECINCSCR=0 INDIC=1 : [F:PTR]EECINCSCR=1 : Endif
    If [F:PTR]ORICRYCOD>0 & [F:PTR]ORICRYSCR=0 INDIC=1 : [F:PTR]ORICRYSCR=1 : Endif
    If [F:PTR]ACCCOD>0    & [F:PTR]ACCSCR=0    INDIC=1 : [F:PTR]ACCSCR=1    : Endif
    If [F:PTR]CNACOD>0    & [F:PTR]CNASCR=0    INDIC=1 : [F:PTR]CNASCR=1    : Endif
    If [F:PTR]PURTYPCOD>0 & [F:PTR]PURTYPSCR=0 INDIC=1 : [F:PTR]PURTYPSCR=1 : Endif
    If [F:PTR]VAT1COD>0   & [F:PTR]VAT1SCR=0   INDIC=1 : [F:PTR]VAT1SCR=1   : Endif
    If [F:PTR]VAT2COD>0   & [F:PTR]VAT2SCR=0   INDIC=1 : [F:PTR]VAT2SCR=1   : Endif
    If [F:PTR]VAT3COD>0   & [F:PTR]VAT3SCR=0   INDIC=1 : [F:PTR]VAT3SCR=1   : Endif
    If [F:PTR]QUAFLGCOD>0 & [F:PTR]QUAFLGSCR=0 INDIC=1 : [F:PTR]QUAFLGSCR=1 : Endif
    If [F:PTR]LINAMTFLG>0 & [F:PTR]LINAMTSCR=0 INDIC=1 : [F:PTR]LINAMTSCR=1 : Endif
    If [F:PTR]OCNDATFLG>0 & [F:PTR]OCNDATSCR=0 INDIC=1 : [F:PTR]OCNDATSCR=1 : Endif
    If [F:PTR]OCNNUMFLG>0 & [F:PTR]OCNNUMSCR=0 INDIC=1 : [F:PTR]OCNNUMSCR=1 : Endif
    If [F:PTR]CLEFLG>0    & [F:PTR]CLESCR=0    INDIC=1 : [F:PTR]CLESCR=1    : Endif
    If [F:PTR]REVFLG>0    & [F:PTR]REVSCR=0    INDIC=1 : [F:PTR]REVSCR=1    : Endif
    If [F:PTR]SOHNUMFLG>0 & [F:PTR]SOHNUMSCR=0 INDIC=1 : [F:PTR]SOHNUMSCR=1 : Endif
    If [F:PTR]ORIFLG>0    & [F:PTR]ORISCR=0    INDIC=1 : [F:PTR]ORISCR=1    : Endif
    If INDIC=1
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
Commit
Close Local File [PTR]

#-----------------------------------------------------------------------#
# Paramétrage des tarifs achats (remplacement de ENAFLG par PLIENAFLG)  #
#  - garnissage de PLIENAFLG avec le 1er caractere de PLIDES            #  
#-----------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".PPRICCONF" [PPC]
Call ECR_TRACE("DOSMAJ4 Purchases Pricing Parameters Process : Update PPRICCONF",0) From GESECRAN
Trbegin [PPC]
  For [PPC]
    If len([F:PPC]PLIDES)>0
      If left$([F:PPC]PLIDES,1)="1" | left$([F:PPC]PLIDES,1)="2"
        [F:PPC]PLIENAFLG=val(left$([F:PPC]PLIDES,1)) 
        [F:PPC]PLIDES=right$([F:PPC]PLIDES,2)
      Endif
    Endif
    If [F:PPC]PLIENAFLG<1 | [F:PPC]PLIENAFLG>2 [F:PPC]PLIENAFLG=1 : Endif
    Rewrite [PPC]
    If fstat
      Call ECR_TRACE("File PPRICCONF, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Next
Commit
Close Local File [PPC]

#----------------------------------------------#
# Initialisation zone type facture utilisateur #
#----------------------------------------------#
Local Shortint COMPTEUR, STOP
Local Char     WPIVTYP(3)(5), CLE1(15), CRITERE(50)
Local Integer  CLE2
#----- Traitement du fichier table des types facture -----#
Local File =[F:ADS]DOSSIER+".PINVOICE" [PIH]
Call ECR_TRACE("DOSMAJ4 Purchase Invoice table Process : Create TABPIVTYP",0) From GESECRAN
Local File =[F:ADS]DOSSIER+".TABPIVTYP" [TPV]
For [TPV]
  WPIVTYP([F:TPV]PIHTYP)=[F:TPV]PIVTYP
Next
Trbegin [TPV]
  Raz [F:TPV]
  [F:TPV]MANCOU=1
  [F:TPV]CREDAT=date$
  [F:TPV]CREUSR=GUSER
  If WPIVTYP(1)=""
    WPIVTYP(1)="FAC"
    [F:TPV]PIVTYP="FAC"
    [F:TPV]TPVDES="Facture"
    [F:TPV]TPVSHO="Facture"
    [F:TPV]PIHTYP=1
    Write [TPV]
    If fstat
      Call ECR_TRACE("File TABPIVTYP, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Endif
  If WPIVTYP(2)=""
    WPIVTYP(2)="FCC"
    [F:TPV]PIVTYP="FCC"
    [F:TPV]TPVDES="Facture complémentaire"
    [F:TPV]TPVSHO="Fac. compl"
    [F:TPV]PIHTYP=2
    Write [TPV]
    If fstat
      Call ECR_TRACE("File TABPIVTYP, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Endif
  If WPIVTYP(3)=""
    WPIVTYP(3)="AVO"
    [F:TPV]PIVTYP="AVO"
    [F:TPV]TPVDES="Avoir"
    [F:TPV]TPVSHO="Avoir"
    [F:TPV]PIHTYP=3
    Write [TPV]
    If fstat
      Call ECR_TRACE("File TABPIVTYP, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Endif
  If WPIVTYP(4)=""
    WPIVTYP(4)="AVR"
    [F:TPV]PIVTYP="AVR"
    [F:TPV]TPVDES="Avoir / Retour"
    [F:TPV]TPVSHO="Avoir/Ret."
    [F:TPV]PIHTYP=4
    Write [TPV]
    If fstat
      Call ECR_TRACE("File TABPIVTYP, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Endif
Commit
Close Local File [TPV] , [PIH]
#----- Traitement du fichier entêtes facture -----#
Local File =[F:ADS]DOSSIER+".PINVOICE" [PIH]
Call ECR_TRACE("DOSMAJ4 Purchase Invoices Process 1 : Update PINVOICE",0) From GESECRAN
Raz CLE1
$BOUCLE_PIH
Raz COMPTEUR, STOP
Trbegin [PIH]
  For [PIH] Where NUM>CLE1 & ORIMOD=6 
    Readlock [PIH] Curr
    If fstat
      Call ECR_TRACE("File PINVOICE, Error ="-num$(fstat),1) From GESECRAN
    Endif
    If [F:PIH]PIVTYP="" [F:PIH]PIVTYP=WPIVTYP([F:PIH]PIHTYP) : Endif
    Rewrite [PIH]
    If fstat
      Call ECR_TRACE("File PINVOICE, Error ="-num$(fstat),1) From GESECRAN
    Endif
    COMPTEUR+=1
    If COMPTEUR>499 CLE1=[F:PIH]NUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PIH : Endif
Close Local File [PIH]
#----- Traitement du fichier complément entêtes facture -----#
Local File =[F:ADS]DOSSIER+".PINVOICEV" [PIV]
Call ECR_TRACE("DOSMAJ4 Purchase Invoices Process 2 : Update PINVOICEV",0) From GESECRAN
Raz CLE1
$BOUCLE_PIV
Raz COMPTEUR, STOP
Trbegin [PIV]
  For [PIV] Where NUM>CLE1
    Readlock [PIV] Curr
    If fstat
      Call ECR_TRACE("File PINVOICEV, Error ="-num$(fstat),1) From GESECRAN
    Endif
    If [F:PIV]PIVTYP="" [F:PIV]PIVTYP=WPIVTYP([F:PIV]PIHTYP) : Endif
    Rewrite [PIV]
    If fstat
      Call ECR_TRACE("File PINVOICEV, Error ="-num$(fstat),1) From GESECRAN
    Endif
    COMPTEUR+=1
    If COMPTEUR>499 CLE1=[F:PIV]NUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PIV : Endif
Close Local File [PIV]
#----- Traitement du fichier lignes facture -----#
Local File =[F:ADS]DOSSIER+".PINVOICED" [PID]
Call ECR_TRACE("DOSMAJ4 Purchase Invoices Process 3 : Update PINVOICED",0) From GESECRAN
Raz CLE1, CLE2, STOP
$BOUCLE_PID
If STOP=1
  STOP=2 : CRITERE='NUM="'+CLE1+'"'+' & PIDLIN>'+num$(CLE2)
Elsif STOP=2
  STOP=0 : CRITERE='NUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [PID]
  For [PID] Where evalue(CRITERE)
    Readlock [PID] Curr
    If fstat
      Call ECR_TRACE("File PINVOICED, Error ="-num$(fstat),1) From GESECRAN
    Endif
    If [F:PID]PIVTYP="" [F:PID]PIVTYP=WPIVTYP([F:PID]PIHTYP) : Endif
    Rewrite [PID]
    If fstat
      Call ECR_TRACE("File PINVOICED, Error ="-num$(fstat),1) From GESECRAN
    Endif
    COMPTEUR+=1
    If COMPTEUR>499 CLE1=[F:PID]NUM : CLE2=[F:PID]PIDLIN : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PID : Endif
Close Local File [PID]

#------------------------------------#
# Initialisation ITMDES1 avec ITMDES # 
#------------------------------------#
Local Char FICHIER(10)
Call ECR_TRACE("DOSMAJ4 Purchase Process : Update Item Description",0) From GESECRAN
For FICHIER="PQUOTATD","PREQUISD","PORDITM","PORDERP","UPORDERP","PRECEIPTD","PRETURND","PINVOICED"
  Local File =[F:ADS]DOSSIER+"."+FICHIER [F1]
  Call ECR_TRACE(mess(81,125,1)-":"-FICHIER,0) From GESECRAN : # maj table
  Trbegin [F1]
    Update [F1] Where 1=1 With ITMDES1=ITMDES
    If fstat Call ERREUR(FICHIER,2) From DOSDIC Endif
  Commit
  Close Local File [F1]
Next

#-------------------------------------------#
# Initialisation de la nouvelle zone POQLNK #
#-------------------------------------------#
Local Shortint COMPTEUR, STOP
Local Char     CLE1(15), CRITERE(90)
Local Integer  CLE2, CLE3, CLE4
#----- Mise à jour lignes de commande -----#
Local File =[F:ADS]DOSSIER+".PORDERQ" [POQ]
Call ECR_TRACE("DOSMAJ4 Purchase Order Process 1 : Update PORDERQ",0) From GESECRAN
Raz CLE1, CLE2, CLE3, STOP
$BOUCLE_POQ
If STOP=1
  STOP=2 : CRITERE='POHNUM="'+CLE1+'"'+' & POPLIN='+num$(CLE2)+' & POQSEQ>'+num$(CLE3)
Elsif STOP=2
  STOP=3 : CRITERE='POHNUM="'+CLE1+'"'+' & POPLIN>'+num$(CLE2)
Elsif STOP=3
  STOP=0 : CRITERE='POHNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [POQ]
  For [POQ] Where evalue(CRITERE)
    Readlock [POQ] Curr
    If fstat
      Call ECR_TRACE("File PORDERQ, Error ="-num$(fstat),1) From GESECRAN
    Endif
    [F:POQ]POQLNK=mid$("00000000",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
&                +mid$("00000000",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
    Rewrite [POQ]
    If fstat
      Call ECR_TRACE("File PORDERQ, Error ="-num$(fstat),1) From GESECRAN
    Endif
    COMPTEUR+=1
    If COMPTEUR>499
      CLE1=[F:POQ]POHNUM : CLE2=[F:POQ]POPLIN : CLE3=[F:POQ]POQSEQ : STOP=1 : Break
    Endif
  Next
Commit
If STOP Goto BOUCLE_POQ : Endif
Close Local File [POQ]
#----- Mise à jour historique lignes de commande -----#
Local File =[F:ADS]DOSSIER+".UPORDERQ" [UOQ]
Call ECR_TRACE("DOSMAJ4 Purchase Order Process 2 : Update UPORDERQ",0) From GESECRAN
Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_UOQ
If STOP=1
  STOP=2 : CRITERE='POHNUM="'+CLE1+'"'+' & LINREVNUM='+num$(CLE2)+' & POPLIN='+num$(CLE3)+
&                                                                 ' & POQSEQ>'+num$(CLE4)
Elsif STOP=2
  STOP=3 : CRITERE='POHNUM="'+CLE1+'"'+' & LINREVNUM='+num$(CLE2)+' & POPLIN>'+num$(CLE3)
Elsif STOP=3
  STOP=4 : CRITERE='POHNUM="'+CLE1+'"'+' & LINREVNUM>'+num$(CLE2)
Elsif STOP=4
  STOP=0 : CRITERE='POHNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [UOQ]
  For [UOQ] Where evalue(CRITERE)
    Readlock [UOQ] Curr
    If fstat
      Call ECR_TRACE("File UPORDERQ, Error ="-num$(fstat),1) From GESECRAN
    Endif
    [F:UOQ]POQLNK=mid$("00000000",1,8-len(num$([F:UOQ]POPLIN)))+num$([F:UOQ]POPLIN)
&                +mid$("00000000",1,8-len(num$([F:UOQ]POQSEQ)))+num$([F:UOQ]POQSEQ)
    Rewrite [UOQ]
    If fstat
      Call ECR_TRACE("File UPORDERQ, Error ="-num$(fstat),1) From GESECRAN
    Endif
    COMPTEUR+=1
    If COMPTEUR>499
      CLE1=[F:UOQ]POHNUM : CLE2=[F:UOQ]LINREVNUM : CLE3=[F:UOQ]POPLIN : CLE4=[F:UOQ]POQSEQ
      STOP=1 : Break 
    Endif
  Next
Commit
If STOP Goto BOUCLE_UOQ : Endif
Close Local File [UOQ]

End

#---------------------------------------------------------------------------------#
#    Moulinette Après mise à jour concernant le module Vente                      #
#---------------------------------------------------------------------------------#
Subprog VENMAJ4

If filinfo(filpath("FIL","SALTRS","fde",[F:ADS]DOSSIER),0) < 0    End Endif
If filinfo(filpath("FIL","SPRICCONF","fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL","SORDER","fde",[F:ADS]DOSSIER),0) < 0    End Endif

Local Char     CLE1(15), CRITERE(90)
Local Shortint INDIC, IJ, STOP
Local Integer  I, ZENAFLG, CLE2, CLE3, CLE4, WOK

Local File =[F:ADS]DOSSIER+".SALTRS"     [SLT]
Local File =[F:ADS]DOSSIER+".SPRICCONF"  [SPC]
Local File =[F:ADS]DOSSIER+".SORDER"     [SOH]
Local File =[F:ADS]DOSSIER+".SORDERP"    [SOP]
Local File =[F:ADS]DOSSIER+".SORDERQ"    [SOQ]
Local File =[F:ADS]DOSSIER+".VSORDERP"   [VOP]
Local File =[F:ADS]DOSSIER+".VSORDERQ"   [VOQ]
Local File =[F:ADS]DOSSIER+".SINVOICE"   [SIH]
Local File =[F:ADS]DOSSIER+".SINVOICEV"  [SIV]
Local File =[F:ADS]DOSSIER+".SINVOICED"  [SID]
Local File =[F:ADS]DOSSIER+".ORDERS"     [ORD]
Local File =[F:ADS]DOSSIER+".SDELIVERY"  [SDH]
Local File =[F:ADS]DOSSIER+".SDELIVERYD" [SDD]
Local File =[F:ADS]DOSSIER+".SRETURND"   [SRD]

#-------------------------------------------------#
# Initialisation transactions ventes (code actif) #
#                                    (flags fiche)# 
#-------------------------------------------------#
Call ECR_TRACE("DOSMAJ4 Sales Transactions Process : Update SALTRS",0) From GESECRAN

Trbegin [SLT]
  For [SLT]
    Raz INDIC
    If [F:SLT]ENAFLG<1 or [F:SLT]ENAFLG>2
      INDIC=1 : [F:SLT]ENAFLG=2
    Endif
    If [F:SLT]BPAADDCODD<>0 & [F:SLT]BPAADDSCRD=0 : INDIC=1 : [F:SLT]BPAADDSCRD=1 : Endif
    If [F:SLT]BPTNUMCODD<>0 & [F:SLT]BPTNUMSCRD=0 : INDIC=1 : [F:SLT]BPTNUMSCRD=1 : Endif
    For IJ=0 To dim([F:SLT]CCECODD)-1
      If [F:SLT]CCECODD(IJ)<>0 & [F:SLT]CCESCRD(IJ)=0 : INDIC=1 : [F:SLT]CCESCRD(IJ)=1 : Endif
    Next IJ 
    If [F:SLT]CFMFLGCOD<>0  & [F:SLT]CFMFLGSCR=0  : INDIC=1 : [F:SLT]CFMFLGSCR=1  : Endif
    If [F:SLT]CPLAMTCOD<>0  & [F:SLT]CPLAMTSCR=0  : INDIC=1 : [F:SLT]CPLAMTSCR=1  : Endif
    If [F:SLT]DAYLTICODD<>0 & [F:SLT]DAYLTISCRD=0 : INDIC=1 : [F:SLT]DAYLTISCRD=1 : Endif
    If [F:SLT]DEMDLVCOD<>0  & [F:SLT]DEMDLVSCR=0  : INDIC=1 : [F:SLT]DEMDLVSCR=1  : Endif
    If [F:SLT]DEMSTACOD<>0  & [F:SLT]DEMSTASCR=0  : INDIC=1 : [F:SLT]DEMSTASCR=1  : Endif
    If [F:SLT]DISCRGCOD1<>0 & [F:SLT]DISCRGSCR1=0 : INDIC=1 : [F:SLT]DISCRGSCR1=1 : Endif
    If [F:SLT]DISCRGCOD2<>0 & [F:SLT]DISCRGSCR2=0 : INDIC=1 : [F:SLT]DISCRGSCR2=1 : Endif
    If [F:SLT]DISCRGCOD3<>0 & [F:SLT]DISCRGSCR3=0 : INDIC=1 : [F:SLT]DISCRGSCR3=1 : Endif
    If [F:SLT]DISCRGCOD4<>0 & [F:SLT]DISCRGSCR4=0 : INDIC=1 : [F:SLT]DISCRGSCR4=1 : Endif
    If [F:SLT]DISCRGCOD5<>0 & [F:SLT]DISCRGSCR5=0 : INDIC=1 : [F:SLT]DISCRGSCR5=1 : Endif
    If [F:SLT]DISCRGCOD6<>0 & [F:SLT]DISCRGSCR6=0 : INDIC=1 : [F:SLT]DISCRGSCR6=1 : Endif
    If [F:SLT]DISCRGCOD7<>0 & [F:SLT]DISCRGSCR7=0 : INDIC=1 : [F:SLT]DISCRGSCR7=1 : Endif
    If [F:SLT]DISCRGCOD8<>0 & [F:SLT]DISCRGSCR8=0 : INDIC=1 : [F:SLT]DISCRGSCR8=1 : Endif
    If [F:SLT]DISCRGCOD9<>0 & [F:SLT]DISCRGSCR9=0 : INDIC=1 : [F:SLT]DISCRGSCR9=1 : Endif
    If [F:SLT]DLVPIOCODD<>0 & [F:SLT]DLVPIOSCRD=0 : INDIC=1 : [F:SLT]DLVPIOSCRD=1 : Endif
    If [F:SLT]EXTAMTCOD<>0  & [F:SLT]EXTAMTSCR=0  : INDIC=1 : [F:SLT]EXTAMTSCR=1  : Endif
    If [F:SLT]EXTDLVCOD<>0  & [F:SLT]EXTDLVSCR=0  : INDIC=1 : [F:SLT]EXTDLVSCR=1  : Endif
    If [F:SLT]EXTQTYCOD<>0  & [F:SLT]EXTQTYSCR=0  : INDIC=1 : [F:SLT]EXTQTYSCR=1  : Endif
    If [F:SLT]FMICOD<>0     & [F:SLT]FMISCR=0     : INDIC=1 : [F:SLT]FMISCR=1     : Endif
    If [F:SLT]FOCFLGCOD<>0  & [F:SLT]FOCFLGSCR=0  : INDIC=1 : [F:SLT]FOCFLGSCR=1  : Endif
    If [F:SLT]LINTYPCOD<>0  & [F:SLT]LINTYPSCR=0  : INDIC=1 : [F:SLT]LINTYPSCR=1  : Endif
    If [F:SLT]MDLCODD<>0    & [F:SLT]MDLSCRD=0    : INDIC=1 : [F:SLT]MDLSCRD=1    : Endif
    If [F:SLT]ORDCOD<>0     & [F:SLT]ORDSCR=0     : INDIC=1 : [F:SLT]ORDSCR=1     : Endif
    If [F:SLT]ORDCODD<>0    & [F:SLT]ORDSCRD=0    : INDIC=1 : [F:SLT]ORDSCRD=1    : Endif
    If [F:SLT]ORDUPDCOD<>0  & [F:SLT]ORDUPDSCR=0  : INDIC=1 : [F:SLT]ORDUPDSCR=1  : Endif
    If [F:SLT]PCKCOD<>0     & [F:SLT]PCKSCR=0     : INDIC=1 : [F:SLT]PCKSCR=1     : Endif
    If [F:SLT]PFMCOD<>0     & [F:SLT]PFMSCR=0     : INDIC=1 : [F:SLT]PFMSCR=1     : Endif
    If [F:SLT]PLICOD<>0     & [F:SLT]PLISCR=0     : INDIC=1 : [F:SLT]PLISCR=1     : Endif
    If [F:SLT]POHNUMCOD<>0  & [F:SLT]POHNUMSCR=0  : INDIC=1 : [F:SLT]POHNUMSCR=1  : Endif
       [F:SLT]FMINUMCOD=[F:SLT]POHNUMCOD : [F:SLT]FMINUMSCR=[F:SLT]POHNUMSCR
    If [F:SLT]REPCODD<>0    & [F:SLT]REPSCRD=0    : INDIC=1 : [F:SLT]REPSCRD=1    : Endif
    If [F:SLT]RTNQTYCOD<>0  & [F:SLT]RTNQTYSCR=0  : INDIC=1 : [F:SLT]RTNQTYSCR=1  : Endif
    If [F:SLT]SHIDATCOD<>0  & [F:SLT]SHIDATSCR=0  : INDIC=1 : [F:SLT]SHIDATSCR=1  : Endif
    If [F:SLT]STOFCYCOD<>0  & [F:SLT]STOFCYSCR=0  : INDIC=1 : [F:SLT]STOFCYSCR=1  : Endif
    If [F:SLT]USEPLCCOD<>0  & [F:SLT]USEPLCSCR=0  : INDIC=1 : [F:SLT]USEPLCSCR=1  : Endif
    If [F:SLT]WEICODD<>0    & [F:SLT]WEISCRD=0    : INDIC=1 : [F:SLT]WEISCRD=1    : Endif
    If !find([F:SLT]ALLQTYCOD,1,2)    INDIC=1 : [F:SLT]ALLQTYCOD  = 1 : Endif
    If !find([F:SLT]SHTQTYCOD,1,2)    INDIC=1 : [F:SLT]SHTQTYCOD  = 1 : Endif
    If !find([F:SLT]WALLQTYCOD,1,2,3) INDIC=1 : [F:SLT]WALLQTYCOD = 1 : Endif
    If [F:SLT]ALLQTYCOD<>0  & [F:SLT]ALLQTYSCR=0  : INDIC=1 : [F:SLT]ALLQTYSCR=1  : Endif
    If [F:SLT]SHTQTYCOD<>0  & [F:SLT]SHTQTYSCR=0  : INDIC=1 : [F:SLT]SHTQTYSCR=1  : Endif
    If [F:SLT]WALLQTYCOD<>0 & [F:SLT]WALLQTYSCR=0 : INDIC=1 : [F:SLT]WALLQTYSCR=1 : Endif
    If [F:SLT]LICPLATCOD=0 INDIC=1 : [F:SLT]LICPLATCOD=1 Endif
    If [F:SLT]ETDCOD=0     INDIC=1 : [F:SLT]ETDCOD=1     Endif
    If [F:SLT]ETACOD=0     INDIC=1 : [F:SLT]ETACOD=1     Endif
    If [F:SLT]STRTYP = 4 & !find([F:SLT]VOLCOD,1,2)
       INDIC=1 : [F:SLT]VOLCOD = 1
    Endif
    If INDIC=1
      Rewrite [SLT]
      If fstat
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
Commit

#-----------------------------------------------------------------------#
# Paramétrage des tarifs ventes (remplacement de ENAFLG par PLIENAFLG)  #
#  - garnissage de PLIENAFLG avec le 1er caractere de PLIDES            #  
#-----------------------------------------------------------------------#
Call ECR_TRACE("DOSMAJ4 Sales Pricing Parameters Process : Update SPRICCONF",0) From GESECRAN

Trbegin [SPC]
  For [SPC]
    Raz ZENAFLG
    If len([F:SPC]PLIDES)>0
      ZENAFLG=val(left$([F:SPC]PLIDES,1)) 
      If find(ZENAFLG,1,2)
        [F:SPC]PLIDES=right$([F:SPC]PLIDES,2)
      Endif
    Endif
    If !find([F:SPC]PLIENAFLG,1,2)
      If !find(ZENAFLG,1,2)
        ZENAFLG=1
      Endif       
      [F:SPC]PLIENAFLG=ZENAFLG
    Endif  
    Rewrite [SPC]
    If fstat
      Call ECR_TRACE("File SPRICCONF, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Next
Commit

#----------------------------------------------------------------------------------#
#     Bascule de la zone FMI    de SORDERP vers la nouvelle zone FMI    de SORDERQ # 
#     Bascule de la zone POHNUM de SORDERP vers la nouvelle zone FMINUM de SORDERQ # 
#     Bascule de la zone POPLIN de SORDERP vers la nouvelle zone FMILIN de SORDERQ # 
#     Bascule de la zone POPSEQ de SORDERP vers la nouvelle zone FMISEQ de SORDERQ # 
#----------------------------------------------------------------------------------#
Call ECR_TRACE("DOSMAJ4 Sales Order Process 1 : Update SORDERQ,SORDERP",0) From GESECRAN
Raz CLE1, CLE2, CLE3, STOP
Trbegin [SOQ]
$BOUCLE_SOQ
  If STOP=1
    STOP=2 : CRITERE='SOHNUM="'+CLE1+'"'+' & SOPLIN='+num$(CLE2)+' & SOQSEQ>'+num$(CLE3)
  Elsif STOP=2
    STOP=3 : CRITERE='SOHNUM="'+CLE1+'"'+' & SOPLIN>'+num$(CLE2)
  Elsif STOP=3
    STOP=0 : CRITERE='SOHNUM>"'+CLE1+'"'
  Else
    CRITERE="1=1"
  Endif
  Raz I
  For [SOQ] Where evalue(CRITERE)
    Read [SOP] SOP0 = [F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
    If fstat
#       Call ECR_TRACE("File SORDERP, Error ="-num$(fstat),1) From GESECRAN
       [F:SOQ]FMI = 1
       WOK = 0 
    Else
       If [F:SOQ]FMI = 0
          If [F:SOP]FMI < 1 | [F:SOP]FMI > 5
             [F:SOQ]FMI = 1
          Else    
             [F:SOQ]FMI = [F:SOP]FMI
             [F:SOQ]FMINUM = [F:SOP]POHNUM
             [F:SOQ]FMILIN = [F:SOP]POPLIN
             [F:SOQ]FMISEQ = [F:SOP]POQSEQ
          Endif
       Endif
       WOK = 1
    Endif
    Rewrite [SOQ]
    I += 1
    If fstat
       Call ECR_TRACE("File SORDERQ, Error ="-num$(fstat),1) From GESECRAN
    Elsif WOK = 1
#      L'écriture de SORDERQ s'est bien passé : Raz des données dans SORDERP        
       Raz [F:SOP]FMI, [F:SOP]POHNUM, [F:SOP]POPLIN, [F:SOP]POQSEQ
       Rewrite [SOP]
       I += 1
       If fstat
          Call ECR_TRACE("File SORDERP, Error ="-num$(fstat),1) From GESECRAN
       Endif
    Endif
    If I > 499
       Commit
       Trbegin [SOQ]
       CLE1=[F:SOQ]SOHNUM : CLE2=[F:SOQ]SOPLIN : CLE3=[F:SOQ]SOQSEQ
       STOP=1 : Break
    Endif
  Next
  If STOP Goto BOUCLE_SOQ : Endif
Commit
Raz I

#------------------------------------------------------------------------------------#
#     Bascule de la zone FMI    de VSORDERP vers la nouvelle zone FMI    de VSORDERQ # 
#     Bascule de la zone POHNUM de VSORDERP vers la nouvelle zone FMINUM de VSORDERQ # 
#     Bascule de la zone POPLIN de VSORDERP vers la nouvelle zone FMILIN de VSORDERQ # 
#     Bascule de la zone POPSEQ de VSORDERP vers la nouvelle zone FMISEQ de VSORDERQ # 
#------------------------------------------------------------------------------------#
Call ECR_TRACE("DOSMAJ4 Sales Order Process 2 : Update VSORDERQ,VSORDERP ",0) From GESECRAN
Raz CLE1, CLE2, CLE3, CLE4, STOP
Trbegin [VOQ]
$BOUCLE_VOQ
  If STOP=1
    STOP=2 : CRITERE='SOHNUM="'+CLE1+'"'+' & LINREVNUM='+num$(CLE2)+' & SOPLIN='+num$(CLE3)+
&                                                                   ' & SOQSEQ>'+num$(CLE4)
  Elsif STOP=2
    STOP=3 : CRITERE='SOHNUM="'+CLE1+'"'+' & LINREVNUM='+num$(CLE2)+' & SOPLIN>'+num$(CLE3)
  Elsif STOP=3
    STOP=4 : CRITERE='SOHNUM="'+CLE1+'"'+' & LINREVNUM>'+num$(CLE2)
  Elsif STOP=4
    STOP=0 : CRITERE='SOHNUM>"'+CLE1+'"'
  Else
    CRITERE="1=1"
  Endif
  Raz I
  For [VOQ] Where evalue(CRITERE)
    Readlock [VOP] VOP0 = [F:VOQ]SOHNUM;[F:VOQ]LINREVNUM;[F:VOQ]SOPLIN;[F:VOQ]SOQSEQ
    If fstat
#       Call ECR_TRACE("File VSORDERP, Error ="-num$(fstat),1) From GESECRAN
       [F:VOQ]FMI = 1
       WOK = 0
    Else
       If [F:VOQ]FMI = 0
          If [F:VOP]FMI < 1 | [F:VOP]FMI > 5
             [F:VOQ]FMI = 1
          Else    
             [F:VOQ]FMI = [F:VOP]FMI
             [F:VOQ]FMINUM = [F:VOP]POHNUM
             [F:VOQ]FMILIN = [F:VOP]POPLIN
             [F:VOQ]FMISEQ = [F:VOP]POQSEQ
          Endif
       Endif
       WOK = 1
    Endif
    Rewrite [VOQ]
    I += 1
    If fstat
        Call ECR_TRACE("File VSORDERQ, Error ="-num$(fstat),1) From GESECRAN
    Elsif WOK = 1
#       L'écriture de VSORDERQ s'est bien passé : Raz des données dans VSORDERP        
        Raz [F:VOP]FMI, [F:VOP]POHNUM, [F:VOP]POPLIN, [F:VOP]POQSEQ
        Rewrite [VOP]
        I += 1
        If fstat
            Call ECR_TRACE("File VSORDERP, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
    If I > 499
       Commit
       Trbegin [VOQ]
       CLE1=[F:VOQ]SOHNUM : CLE2=[F:VOQ]LINREVNUM : CLE3=[F:VOQ]SOPLIN : CLE4=[F:VOQ]SOQSEQ
       STOP=1 : Break
    Endif
  Next
  If STOP Goto BOUCLE_VOQ : Endif
Commit
Raz I

#------------------------------------------------------------------------------------#
#     Commande à facturation directe (SOHCAT=3)                                      # 
#        Basculement de la qté facturé non validée de INVQTY(STU) vers ODLQTY(STU)   # 
#     Toutes commandes                                                               #
#        Maj de l'en-cours : la quantité est réalisée lorsque la livraison (facture) #
#                            est validée, sinon elle est allouée                     #
#------------------------------------------------------------------------------------#
Call ECR_TRACE("DOSMAJ4 Sales Order Process 3 : Update SORDERQ,ORDERS",0) From GESECRAN
Raz CLE1
Trbegin [SOH]
$BOUCLE_SOH
Raz I, STOP
For [SOH] Where ORDSTA=1 & SOHNUM>CLE1
   # Commandes à facturation directe 
   If [F:SOH]SOHCAT = 3
      For [SID] Where SOHNUM=[F:SOH]SOHNUM
         Read [SIH]SIH0=[F:SID]NUM
         If !fstat & [F:SIH]STA<>3
            Readlock [SOQ]SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
            If !fstat
               If [F:SOQ]ODLQTY = 0
                  [F:SOQ]INVQTY    -= [F:SID]QTY
                  [F:SOQ]INVQTYSTU -= [F:SID]QTYSTU
                  [F:SOQ]ODLQTY    += [F:SID]QTY
                  [F:SOQ]ODLQTYSTU += [F:SID]QTYSTU
                  Rewrite [SOQ]
                  If fstat 
                     Call ECR_TRACE("File SORDERQ, Error ="-num$(fstat),1) From GESECRAN
                  Else
                     I += 1
                  Endif
                  # Maj de l'en cours correspondant
                  Readlock [ORD]ORD3=[F:SOQ]STOFCY;2;[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
                  If !fstat
                     [F:ORD]CPLQTY = [F:SOQ]INVQTYSTU 
                     [F:ORD]ALLQTY = [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU 
                     [F:ORD]RMNEXTQTY  = [F:ORD]EXTQTY
                     [F:ORD]RMNEXTQTY -= [F:ORD]CPLQTY
                     If [F:ORD]RMNEXTQTY < 0 : [F:ORD]RMNEXTQTY = 0 : Endif
                     Rewrite [ORD]
                     If fstat 
                        Call ECR_TRACE("File ORDERS, Error ="-num$(fstat),1) From GESECRAN
                     Else
                        I += 1
                     Endif
                  Endif
               Else
                  Unlock [SOQ]
               Endif
            Endif 
         Endif   
      Next
   # Autres commandes (avec livraison)
   Else
      For [SOQ] Where SOHNUM=[F:SOH]SOHNUM & SOQSTA<>3
         # Maj de l'en cours correspondant
         Readlock [ORD]ORD3=[F:SOQ]STOFCY;2;[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
         If !fstat
            [F:ORD]CPLQTY = [F:SOQ]DLVQTYSTU 
            [F:ORD]ALLQTY = [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU 
            [F:ORD]RMNEXTQTY  = [F:ORD]EXTQTY
            [F:ORD]RMNEXTQTY -= [F:ORD]CPLQTY
            If [F:ORD]RMNEXTQTY < 0 : [F:ORD]RMNEXTQTY = 0 : Endif
            Rewrite [ORD]
            If fstat 
               Call ECR_TRACE("File ORDERS, Error ="-num$(fstat),1) From GESECRAN
            Else
               I += 1
            Endif
         Endif
      Next
   Endif 
   If I > 499
      Commit
      Trbegin [SOH]
      CLE1=[F:SOH]SOHNUM : STOP=1 : Break
   Endif 
Next  
If STOP Goto BOUCLE_SOH : Endif
Commit
Raz I

#------------------------------------------------------------------------------------#
#     Entête livraison                                                               # 
#        Maj flag prêt (LND), raz type de livraison (SDHCAT)                         # 
#     Détail livraison                                                               #
#        Alimentation type de commande (SOHCAT) si ligne issue d'une commande        #
#------------------------------------------------------------------------------------#
Call ECR_TRACE("DOSMAJ4 Sales Delivery Process : Update SDELIVERYD,SDELIVERY",0) From GESECRAN
Raz CLE1
Trbegin [SDH]
$BOUCLE_SDH
Raz I, STOP
For [SDH] Where SDHNUM>CLE1
 If [F:SDH]LND=0 
   [F:SDH]LND = 1
   If find([F:SDH]SDHCAT,2,5) [F:SDH]LND = 2 Endif
   If [F:SDH]SDHCAT < 4
      For [SDD] Where SDHNUM=[F:SDH]SDHNUM
         If [F:SDD]SOHNUM <> ""
            Read [SOH]SOH0=[F:SDD]SOHNUM
            If !fstat
               [F:SDD]SOHCAT = [F:SOH]SOHCAT
               Rewrite [SDD]
               If fstat 
                  Call ECR_TRACE("File SDELIVERYD, Error ="-num$(fstat),1) From GESECRAN
               Else
                  I += 1
               Endif
            Endif
         Endif
      Next
   Endif
   Raz [F:SDH]SDHCAT
   Rewrite [SDH] 
   If fstat 
      Call ECR_TRACE("File SDELIVERY, Error ="-num$(fstat),1) From GESECRAN
   Else
      I += 1
   Endif
   If I > 499
      Commit
      Trbegin [SDH]
      CLE1=[F:SDH]SDHNUM : STOP=1 : Break
   Endif 
 Endif
Next  
If STOP Goto BOUCLE_SDH : Endif
Commit
Raz I

#----------------------------------------------------------------------------------#
#     Initialisation RTNCNOFLG                                                     # 
#----------------------------------------------------------------------------------#
Call ECR_TRACE("DOSMAJ4 Sales Return Process : Update SRETURND",0) From GESECRAN

Trbegin [SRD]  
# --> traitement des retours
For [SRD]
   If !find([F:SRD]RTNCNOFLG,1,2) 
      [F:SRD]RTNCNOFLG = 1 
      Rewrite [SRD]  
      If fstat Call ECR_TRACE("File SRETURND, Error ="-num$(fstat),1) From GESECRAN Endif 
   Endif
Next
Commit

#----------------------------------------------------------------------------------#
#     Initialisation SIVTYP et INVTYP dans Facture SINVOICEV                       # 
#     ( les types de facture utilisateurs standards FAC, AVO, PRF                  # 
#       sont fournis en standard à l'instal dans la table TABSIVTYP)               #    
#----------------------------------------------------------------------------------#
Call ECR_TRACE("DOSMAJ4 Sales Invoices Process : Update SINVOICEV",0) From GESECRAN

Local File =[F:ADS]DOSSIER+".TABSIVTYP"     [TSV]
Local File =[F:ADS]DOSSIER+".TABCOUAFF"     [TCA]

# Création des types de factures
Trbegin [TSV]
   Read [TCA]TCA0=5
   If !fstat
      Read [TSV]TSV0="FAC"
      If fstat
         Raz [TSV]
         [F:TSV]SIVTYP="FAC"
         [F:TSV]TSVDES="Facture"
         [F:TSV]TSVSHO="Facture"
         [F:TSV]INVTYP=1
         [F:TSV]CODNUM=[F:TCA]CODNUM(3)
         [F:TSV]MANCOU=[F:TCA]MANCOU(3)
         Write [TSV]
      Endif
      Read [TSV]TSV0="AVO"
      If fstat
         Raz [TSV]
         [F:TSV]SIVTYP="AVO"
         [F:TSV]TSVDES="Avoir"
         [F:TSV]TSVSHO="Avoir"
         [F:TSV]INVTYP=2
         [F:TSV]CODNUM=[F:TCA]CODNUM(4)
         [F:TSV]MANCOU=[F:TCA]MANCOU(4)
         Write [TSV]
      Endif
      Read [TSV]TSV0="PRF"
      If fstat
         Raz [TSV]
         [F:TSV]SIVTYP="PRF"
         [F:TSV]TSVDES="Proforma"
         [F:TSV]TSVSHO="Proforma"
         [F:TSV]INVTYP=5
         [F:TSV]CODNUM=[F:TCA]CODNUM(5)
         [F:TSV]MANCOU=[F:TCA]MANCOU(5)
         Write [TSV]
      Endif
   Endif
Commit

Close Local File [TSV]
Close Local File [TCA]

#-------------------------------------------------
Trbegin [SIV]  
# --> traitement des factures
For [SIV]
   Read [SIH]SIH0=[F:SIV]NUM
   If !fstat 
      [F:SIV]INVTYP = [F:SIH]INVTYP 
      If [F:SIV]SIVTYP=""
        If [F:SIH]INVTYP=1 : [F:SIV]SIVTYP="FAC" : Endif
        If [F:SIH]INVTYP=2 : [F:SIV]SIVTYP="AVO" : Endif
        If [F:SIH]INVTYP=5 : [F:SIV]SIVTYP="PRF" : Endif
      Endif
      Rewrite [SIV]  
      If fstat Call ECR_TRACE("File SINVOICEV, Error ="-num$(fstat),1) From GESECRAN Endif 
   Endif
Next
Commit

Close Local File [SLT]
Close Local File [SPC]
Close Local File [SOH]
Close Local File [SOP]
Close Local File [SOQ]
Close Local File [VOP]
Close Local File [VOQ]
Close Local File [SIH]
Close Local File [SIV]
Close Local File [SID]
Close Local File [ORD]
Close Local File [SDH]
Close Local File [SDD]
Close Local File [SRD]

#----------------------------------------------------------------------------------#
#     Initialisation ITMDES avec ITMDES1                                           # 
#----------------------------------------------------------------------------------#
Local Char FICHIER(10)

Call ECR_TRACE("DOSMAJ4 Sales Process : Update Item Description",0) From GESECRAN

For FICHIER="SQUOTED","SORDERP","SORDERC","VSORDERP","VSORDERC","SDELIVERYD","SINVOICED"
   Local File =[F:ADS]DOSSIER+"."+FICHIER [F1]
   Call ECR_TRACE(mess(81,125,1)-":"-FICHIER,0) From GESECRAN : # maj table

   Trbegin [F1]
   Update [F1] Where 1=1 With ITMDES=ITMDES1
   If fstat Call ERREUR(FICHIER,2) From DOSDIC Endif
   Commit

   Close Local File [F1]
Next

End

#---------------------------------------------------------------------------------#
#    Moulinette Après mise à jour concernant le module GPAO                       #
#---------------------------------------------------------------------------------#
Subprog MFGMAJ4

If filinfo(filpath("FIL","MFGTRS","fde",[F:ADS]DOSSIER),0) < 0    : End : Endif
If filinfo(filpath("FIL","MFGHEAD","fde",[F:ADS]DOSSIER),0) < 0   : End : Endif
If filinfo(filpath("FIL","MFGITMTRK","fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL","MFGPRN","fde",[F:ADS]DOSSIER),0) < 0    : End : Endif
If filinfo(filpath("FIL","PARJAL","fde",[F:ADS]DOSSIER),0) < 0    : End : Endif

#-------------------------------------------------#
# Initialisation transactions GPAO                #
#-------------------------------------------------#
Local File =[F:ADS]DOSSIER+".MFGTRS" [MTS]
Call ECR_TRACE("DOSMAJ4 : Manufacturing Transactions Process",0) From GESECRAN
Trbegin [MTS]
  For [MTS]
    If !find([F:MTS]ENAFLG,1,2)
        [F:MTS]ENAFLG=2
    Endif
    If !find([F:MTS]MODTRSCOD,1,2) 
        [F:MTS]MODTRSCOD=1    
    Endif
    If !find([F:MTS]LBEMOD,1,2) 
        [F:MTS]LBEMOD=1    
    Endif
    If !find([F:MTS]TRSAUTO,1,2) 
        [F:MTS]TRSAUTO=1    
    Endif
    Rewrite [MTS]
    If fstat
        Call ECR_TRACE("File MFGTRS, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Next
Commit
Close Local File [MTS]

#-------------------------------------------------#
# Initialisation Entête OF                        #
#-------------------------------------------------#
Local Shortint COMPTEUR, STOP : # pour éviter erreur snapshot (TB 30/03/00)
Local Char     CLE1(15), CRITERE(80)
Local Integer  CLE2
Local File =[F:ADS]DOSSIER+".MFGHEAD" [MFG]
Call ECR_TRACE("DOSMAJ4 : Manufacturing Orders Process",0) From GESECRAN
Raz CLE1

$BOUCLEMFG
Raz COMPTEUR, STOP
Trbegin [MFG]
  For [MFG] Where MFGNUM > CLE1
    If !find([F:MFG]OPTFLG,1,2) 
        [F:MFG]OPTFLG=1    
    Endif
    Rewrite [MFG]
    If fstat
        Call ECR_TRACE("File MFGHEAD, Error ="-num$(fstat),1) From GESECRAN
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 CLE1 = [F:MFG]MFGNUM : STOP = 1 : Break Endif
  Next
Commit
If STOP : Goto BOUCLEMFG : Endif
Close Local File [MFG]

#-------------------------------------------------#
# Initialisation déclaration de production        #
#-------------------------------------------------#
Local File =[F:ADS]DOSSIER+".MFGITMTRK" [MKI]
Call ECR_TRACE("DOSMAJ4 : Manufacturing Tracking Process",0) From GESECRAN

Raz CLE1,CLE2,STOP
$BOUCLEMKI
If STOP = 1
  CRITERE = 'MFGTRKNUM="'+ CLE1 + '"'+'& ITMTRKLIN>' +num$(CLE2)
  STOP    = 2
Elsif STOP = 2
  CRITERE = 'MFGTRKNUM>"'+ CLE1 +'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif
Raz COMPTEUR
Trbegin [MKI]
  For [MKI] Where evalue(CRITERE)
    If !find([F:MKI]WTRSCOD,1,2)
        [F:MKI]WTRSCOD=1
    Endif
    Rewrite [MKI]
    If fstat
        Call ECR_TRACE("File MFGITMTRK, Error ="-num$(fstat),1) From GESECRAN
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 : CLE1=[F:MKI]MFGTRKNUM : CLE2=[F:MKI]ITMTRKLIN : STOP = 1 : Break : Endif
  Next
Commit
If STOP : Goto BOUCLEMKI : Endif
Close Local File [MKI]

#-------------------------------------------------#
# Initialisation documents OF                     #
#-------------------------------------------------#
Local File =[F:ADS]DOSSIER+".MFGPRN" [MFP]
Call ECR_TRACE("DOSMAJ4 : Manufacturing Documents Process",0) From GESECRAN
Raz CLE1

$BOUCLEMFP
Raz COMPTEUR, STOP
Trbegin [MFP]
  For [MFP] Where MFGNUM > CLE1
    If !find([F:MFP]LBEMOD,1,2)
        [F:MFP]LBEMOD=1
    Endif
    Rewrite [MFP]
    If fstat
        Call ECR_TRACE("File MFGPRN, Error ="-num$(fstat),1) From GESECRAN
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 : CLE1=[F:MFP]MFGNUM : STOP = 1 : Break : Endif
  Next
Commit
If STOP : Goto BOUCLEMFP : Endif
Close Local File [MFP]

#-------------------------------------------------#
# Initialisation paramètres jalonnement           #
#-------------------------------------------------#
Local File =[F:ADS]DOSSIER+".PARJAL" [PJA]
Call ECR_TRACE("DOSMAJ4 : Scheduling parameters Process",0) From GESECRAN
Trbegin [PJA]
  For [PJA]
    If !find([F:PJA]WKLBUCCOR,1,2)
        [F:PJA]WKLBUCCOR=2
    Endif
    If !find([F:PJA]AUTFRWSCD,1,2)
        [F:PJA]AUTFRWSCD=2
    Endif
    If !find([F:PJA]AUTFRCSCD,1,2)
        [F:PJA]AUTFRCSCD=2
    Endif
    If [F:PJA]WKLDAYNBR = 0 &
&      [F:PJA]WKLWEENBR = 0 &
&      [F:PJA]WKLMONNBR = 0
       [F:PJA]WKLDAYNBR = 200
    Endif
    Rewrite [PJA]
    If fstat
        Call ECR_TRACE("File PARJAL, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Next
Commit
Close Local File [PJA]

End


#---------------------------------------------------------------------------------#
#    Moulinette Après mise à jour concernant le module Tronc commnun              #
#---------------------------------------------------------------------------------#
Subprog TRCMAJ4

If filinfo(filpath("FIL","STOTRS","fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL","ITMFACILIT","fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL","ITMMASTER","fde",[F:ADS]DOSSIER),0) < 0 End Endif

#-------------------------------------------------#
# Initialisation transactions stocks (code actif) #
#-------------------------------------------------#
Local File =[F:ADS]DOSSIER+".STOTRS" [STT]
Call ECR_TRACE("DOSMAJ4 : Inventory Transactions Process",0) From GESECRAN
Trbegin [STT]  
# --> traitement des transaction de stock : initialisation flag actif
  For [STT]
    If [F:STT]ENAFLG<1 or [F:STT]ENAFLG>2 
      [F:STT]ENAFLG    = 2
      [F:STT]TRSCOD    = 1 
      [F:STT]TRKCOD    = 1
      Rewrite [STT]  
      If fstat 
        Call ECR_TRACE("File STOTRS, Error ="-num$(fstat),1) From GESECRAN 
      Endif
    Endif 
  Next
Commit
Close Local File [STT]

#------------------------------------------------------------------------------#
# Initialisation article (création des désignations à traduire (ATEXTRA))      #
#------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".ITMMASTER" [ITM]
Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX]
Local Integer I
Local Decimal NUM : # numéro du texte
Local Char DESIG
Local Shortint COMPTEUR, STOP : # pour éviter erreur snapshot (TB 30/03/00)
Local Char     CLE1(20), CRITERE(50)
Local Char     CLE2(3)

Call ECR_TRACE("DOSMAJ4 : Item Process",0) From GESECRAN
Filter [AXX] Where LANGUE = [F:ADS]LAN(0)    :# GLANGUE n'est pas chargé !
Read [AXX] Last
If fstat NUM = 1 Else NUM = [F:AXX]NUMERO+1 Endif

Raz CLE1
$BOUCLEITM
Raz COMPTEUR,STOP
Trbegin [ITM]
  For [ITM] Where ITMREF > CLE1
    If [F:ITM]ITMDES1 <> "" & [F:ITM]ITMNUM1=0
        # CREER le texte dans ATEXTRA
        DESIG = [F:ITM]ITMDES1
        Gosub CRE_TEX
        [F:ITM]ITMNUM1 = NUM
        NUM += 1
    Endif
    If [F:ITM]ITMDES2 <> "" & [F:ITM]ITMNUM2=0
        [F:ITM]ITMNUM2 = NUM
        DESIG = [F:ITM]ITMDES2
        Gosub CRE_TEX
        NUM += 1
    Endif
    If [F:ITM]ITMDES3 <> "" & [F:ITM]ITMNUM3=0
        [F:ITM]ITMNUM3 = NUM
        DESIG = [F:ITM]ITMDES3
        Gosub CRE_TEX
        NUM += 1
    Endif
    If [F:ITM]STOMGTCOD>1 [F:ITM]RCPFLG=2 : Endif : # Ajout le 14/12/99 par MBT
    Rewrite [ITM]
    If fstat 
       Call ECR_TRACE("File ITMMASTER, Error ="-num$(fstat),1) From GESECRAN
    Else
       COMPTEUR += 1
    Endif
    If COMPTEUR > 499 CLE1=[F:ITM]ITMREF : STOP=1 : Break Endif
  Next
Commit
If STOP Goto BOUCLEITM Endif
Goto FIN_MAJITM

$CRE_TEX  :# création de textes traduisibles
[F:AXX]NUMERO = NUM
[F:AXX]LANGUE = [F:ADS]LAN(0) :# si GLANGUE n'est pas chargé !?
[F:AXX]CHAP   = "ITEM"
[F:AXX]TEXTE  = DESIG
[F:AXX]LNG    = 30
Write [AXX]
If fstat
   Call ECR_TRACE("File ATEXTRA, Error ="-num$(fstat),1) From GESECRAN
Endif
Return

$FIN_MAJITM
Close Local File [ITM]
Close Local File [AXX]

#------------------------------------------------------------------------------#
# Initialisation article-site (flag prise en compte empl de picking TIAPICLOC) #
#------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".ITMFACILIT" [ITF]
Call ECR_TRACE("DOSMAJ4 : Item Facility Process",0) From GESECRAN
Raz CLE1
$BOUCLEITF
If STOP = 1
    CRITERE = 'ITMREF="'+ CLE1 +'"'+'& STOFCY>"'+CLE2+'"'
    STOP = 2
Elsif STOP = 2
    CRITERE = 'ITMREF>"'+ CLE1 +'"'
    STOP = 0
Else
    CRITERE = "1=1"
Endif
Raz COMPTEUR
Trbegin [ITF]
  For [ITF] Where evalue(CRITERE)
    If [F:ITF]TIAPICLOC <1 or [F:ITF]TIAPICLOC >3
#     Si gestion des emplacements et emplacement de picking renseigné
#     ---> Prise en compte initialisée à emplacement picking prioritaire
      If [F:ITF]LOCMGTCOD = 2 & [F:ITF]PICLOC <> ""
          [F:ITF]TIAPICLOC = 1
      Endif
      Rewrite [ITF]
      If fstat
        Call ECR_TRACE("File ITMFACILIT, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 CLE1=[F:ITF]ITMREF : CLE2=[F:ITF]STOFCY : STOP=1 : Break Endif
  Next
Commit
If STOP Goto BOUCLEITF Endif
Close Local File [ITF]


#----------------------------------------------------------------------------------#
#     Traitements liés aux regroupements société-site                              #
#       - Fichier site (FACILITY)                                                  #
#         Pour chaque site, création de l'enr regroupement site s'il n'existe pas  #
#       - Fichier regroupement de site (FACGROUP)                                  #           
#         Pour chaque enr, s'il s'agit d'une soc. juridique,                       #
#              Vérif que cette société est bien la société juridique du site       # 
#                    Si ce n'est pas le cas, suppression de l'enr                  #
#----------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".FACILITY" [FCY] 
Local File =[F:ADS]DOSSIER+".FACGROUP" [FGR] 
Local File =[F:ADS]DOSSIER+".COMPANY"  [CPY] 
Call ECR_TRACE("DOSMAJ4 : Facility Process 1 ",0) From GESECRAN
Trbegin [FCY]
  For [FCY]
      Look [FGR]FGR0 = [F:FCY]LEGCPY;[F:FCY]FCY
      If fstat
          Raz [F:FGR]
          [F:FGR]CPY    = [F:FCY]LEGCPY
          [F:FGR]FCY    = [F:FCY]FCY
          [F:FGR]GRPDES = [F:FCY]FCYNAM
          [F:FGR]GRPSHO = [F:FCY]FCYSHO
          [F:FGR]CREDAT = date$
          [F:FGR]CREUSR = GUSER
          Write [FGR]
          If fstat
              Call ECR_TRACE("File FACGROUP, Error ="-num$(fstat),1) From GESECRAN
          Endif
      Endif
  Next
Commit

Call ECR_TRACE("DOSMAJ4 : Facility Process 2 ",0) From GESECRAN
Trbegin [FGR]
  For [FGR] 
      If [F:CPY]CPY <> [F:FGR]CPY
          Read [CPY]CPY0 = [F:FGR]CPY
          If fstat 
#             La société de regroupement n'existe pas : Suppression de l'enr regroupement
              Raz [F:CPY] : [F:CPY]CPYLEGFLG = 1
              Delete [FGR]
              If fstat
                  Call ECR_TRACE("File FACGROUP, Error ="-num$(fstat),1) From GESECRAN
              Endif
          Endif    
      Endif
      If [F:CPY]CPYLEGFLG = 2 
          Read [FCY]FCY0 = [F:FGR]FCY
          If fstat Raz [F:FCY] Endif    
          If [F:FCY]LEGCPY <> [F:FGR]CPY          
              Delete [FGR]
              If fstat
                  Call ECR_TRACE("File FACGROUP, Error ="-num$(fstat),1) From GESECRAN
              Endif
          Endif
      Endif
  Next
Commit

Close Local File [FCY]
Close Local File [CPY]
Close Local File [FGR]


#------------------------------------------------------------------------------#
# Initialisation flag inter-site BETFCY pour les clients intra-société         #
#------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".BPCUSTOMER" [BPC]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Call ECR_TRACE("DOSMAJ4 Business Partner process : Update BPARTNER",0) From GESECRAN
Trbegin [BPR]
  For [BPR] Where BETFCY = 0 
     [F:BPR]BETFCY = 1
     Rewrite [BPR]
     If fstat 
        Call ECR_TRACE("File BPARTNER, Error ="-num$(fstat),1) From GESECRAN
     Endif
  Next
Commit
Trbegin [BPC]
  For [BPC] Where BPCTYP=3 
    Readlock [BPR]BPR0=[F:BPC]BPCNUM
    If !fstat
        [F:BPR]BETFCY = 2
        Rewrite [BPR]
        If fstat 
            Call ECR_TRACE("File BPARTNER, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Close Local File [BPC]
Close Local File [BPR]

End

#---------------------------------------------------------------------------------#
#    Moulinette Après mise à jour concernant le module Stock                      #
#---------------------------------------------------------------------------------#
Subprog STKMAJ4
#
If filinfo(filpath("FIL","STOCK","fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL","CUNLISHEA","fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL","CUNLISDET","fde",[F:ADS]DOSSIER),0) < 0 End Endif
#-------------------------------------------------#
# Initialisation flags inventaires                #
#-------------------------------------------------#
Local File =[F:ADS]DOSSIER+".STOCK"     [STO]
Local File =[F:ADS]DOSSIER+".CUNLISHEA" [CUH]
Local File =[F:ADS]DOSSIER+".CUNLISDET" [CUD]

Call ECR_TRACE("DOSMAJ4 : Inventory Process",0) From GESECRAN
Trbegin [STO]  
Update [STO]  With CUNLOKFLG = 1
If fstat 
   Call ECR_TRACE("File STOCK, Error ="-num$(fstat),1) From GESECRAN 
Endif
Commit
#
Trbegin [CUH]
Update [CUH] With RCPLOCFLG = 2, STOLOCFLG = 2, PICLOCFLG = 2
If fstat 
   Call ECR_TRACE("File CUNLISHEA, Error ="-num$(fstat),1) From GESECRAN 
Endif
Commit
#
Filter [CUD] Where LINUPDFLG <> 2 
&            Order By Key CUD1
For [CUD]
  Trbegin [STO]
  Update [STO]  Where ITMREF = [F:CUD]ITMREF &
&                     STOFCY = [F:CUD]STOFCY 
&               With  CUNLOKFLG = 2
  If fstat 
    Call ECR_TRACE("File STOCK, Error ="-num$(fstat),1) From GESECRAN 
  Endif
  Commit
Next
Close Local File [STO]
Close Local File [CUD]

#-------------------------------------------------#
# Correction champs mouvements de stock          #
#-------------------------------------------------#

Local File =[F:ADS]DOSSIER+".STOJOU"     [STJ]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]
#

Local Shortint COMPTEUR, STOP
Local Char     CLE1
Raz CLE1
$BOUCLESTO
Raz COMPTEUR,STOP
Trbegin [STJ]
For [ITM] Where ITMREF > CLE1
  Filter [STJ] Where ITMREF = [F:ITM]ITMREF &
&                    TRSTYP <> 13           &
&                    UPDCOD  =  2
&              Order By Key STJ0
  For [STJ]
    If [F:STJ]PCU = [F:ITM]STU 
      If [F:STJ]QTYPCU <> [F:STJ]QTYSTU | [F:STJ]PCUSTUCOE <> 1
       [F:STJ]QTYPCU    = [F:STJ]QTYSTU
       [F:STJ]PCUSTUCOE = 1
       Rewrite [STJ]
       If fstat 
         Call ECR_TRACE("File STOJOU, Error ="-num$(fstat),1) From GESECRAN 
       Endif
     Endif
   Endif
  Next
  Filter [STJ]
  COMPTEUR += 1
  If COMPTEUR > 99 
    CLE1=[F:ITM]ITMREF 
    STOP=1 
    Break
  Endif
Next
Commit 
If STOP Goto BOUCLESTO Endif
End
#---------------------------------------------------------------------------------#
#    Moulinette Après mise à jour concernant le module SUPERVISEUR                #
#---------------------------------------------------------------------------------#
Subprog SUPMAJ4
Local Char DOSSIER_WRK(80)
Local Integer I_WRK

DOSSIER_WRK=[F:ADS]DOSSIER    # "GX3APP"   [F:ADS]DOSSIER
If filinfo(filpath("FIL","AMESSAGE","fde",DOSSIER_WRK),0) < 0    : End : Endif
If filinfo(filpath("FIL","AMESSAGED","fde",DOSSIER_WRK),0) < 0    : End : Endif

#-------------------------------------------------#
# Entête de messagerie                            #
#-------------------------------------------------#
Local File =DOSSIER_WRK +".AMESSAGE" [AWH]
Call ECR_TRACE("DOSMAJ4 : Workflow header file (AMESSAGE) ",0) From GESECRAN
Trbegin [AWH]
  For [AWH]
    If [F:AWH]CATEGORIE = ""
        [F:AWH]CATEGORIE = "DEF"
    Endif
    If !find([F:AWH]DEBUG,1,2)
        [F:AWH]DEBUG=1
    Endif
    If !find([F:AWH]ENALOG,1,2)
        [F:AWH]ENALOG=1
    Endif
    If !find([F:AWH]ENAMES,1,2)
        [F:AWH]ENAMES=2
    Endif
    If !find([F:AWH]INTERV,1,2)
        [F:AWH]INTERV=1
    Endif
    For I_WRK=0 To 9
        If [F:AWH]DESTIN(I_WRK) <> ""
            If !find([F:AWH]TYPDES(I_WRK),1,2)
                [F:AWH]TYPDES(I_WRK)=1
            Endif
        Endif
    Next
    Rewrite [AWH]
    If fstat
        Call ECR_TRACE("File AMESSAGE, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Next
Commit
Close Local File [AWH]

#-------------------------------------------------#
# Textes messagerie                               #
#-------------------------------------------------#
Local File =DOSSIER_WRK +".AMESSAGED" [AWM]
Call ECR_TRACE("DOSMAJ4 : Workflow header file (AMESSAGED) ",0) From GESECRAN
Trbegin [AWM]
  For [AWM]
    If !find([F:AWM]SAUTLG,1,2)
        [F:AWM]SAUTLG=1
    Endif
    Rewrite [AWM]
    If fstat
        Call ECR_TRACE("File AMESSAGED, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Next
Commit
Close Local File [AWM]

#---------------------------------------------------------------------#
# Mise à jour zones attribuées aux utilisateurs dans AOBJET           #
#---------------------------------------------------------------------#
Local Char OBJET(5)
Local File =[F:ADS]DOSSIER+".AOBJET" [ZAOB]
Local File =GDOSREF+".AOBJET"        [AOB] 
Call ECR_TRACE("DOSMAJ4 : Update reserved area file AOBJET ",0) From GESECRAN
Trbegin [ZAOB]
  For [ZAOB]
    Read [AOB]ABREV = [F:ZAOB]ABREV
    If !fstat
      For I_WRK=0 To [F:AOB]NBSEL-1
       [F:ZAOB]SELZON(I_WRK) = [F:AOB]SELZON(I_WRK)
      Next I_WRK
      [F:ZAOB]NBSEL   = [F:AOB]NBSEL
      [F:ZAOB]SELCLE  = [F:AOB]SELCLE
      [F:ZAOB]SELORD  = [F:AOB]SELORD
      [F:ZAOB]SELTREE = [F:AOB]SELTREE
      [F:ZAOB]SELCAR  = [F:AOB]SELCAR
      [F:ZAOB]UPDFLG  = 1  
      [F:ZAOB]UPDDAT  = date$ 
      Rewrite [ZAOB]
      If fstat
          Call ECR_TRACE("File AOBJET "+[F:ZAOB]ABREV+", error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
Commit
Close Local File [ZAOB] , [AOB]

Local File =[F:ADS]DOSSIER+".AOBJET"   [AOB]
&        , =[F:ADS]DOSSIER+".ACTIV"    [ACV]
&        , =[F:ADS]DOSSIER+".ATABLE"   [ATB]
&        , =[F:ADS]DOSSIER+".ATABLE"   [AT2] 
&        , =[F:ADS]DOSSIER+".ATABIND"  [ATI]
&        , =[F:ADS]DOSSIER+".ATABZON"  [ATZ]
&        , =[F:ADS]DOSSIER+".ATYPE"    [ATY]
&        , =[F:ADS]DOSSIER+".ATEXTE"   [ATX]
&        , =[F:ADS]DOSSIER+".AMSK"     [AMK]
&        , =[F:ADS]DOSSIER+".AMSKZON"  [AMZ]
&        , =[F:ADS]DOSSIER+".AWINDOW"  [AWI]

For [AOB]ABREV Where UPDFLG=1
 OBJET = [F:AOB]ABREV  
 Call ECR_TRACE(mess(43,125,1)-OBJET,0) From GESECRAN
 # Validation de l'objet
 Call GENTRTSIL([F:ADS]DOSSIER,OBJET) From OBJTRT
 Trbegin [AOB] 
  Update [AOB] Where ABREV=OBJET With UPDFLG = 0
 Commit
Next
Close Local File [AOB], [ACV], [ATB], [AT2], [ATI], [ATZ], [ATY], [ATX], [AMK], [AMZ], [AWI]

End
