#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)3.0.0.0 $Revision$
###########################################################
## Génération de l'écran de saisie employé
###########################################################
Subprog GENECR(APPLI,LEG,COD)
Value Char APPLI
Value Char LEG
Value Char COD

If clalev([F:AMK])=0  : Local File =APPLI+".AMSK"       [AMK]  : Endif
If clalev([F:AMZ])=0  : Local File =APPLI+".AMSKZON"    [AMZ]  : Endif
If clalev([F:AMA])=0  : Local File =APPLI+".AMSKACT"    [AMA]  : Endif
If clalev([F:AMP])=0  : Local File =APPLI+".AMSKPAR"    [AMP]  : Endif
If clalev([F:AMK2])=0 : Local File =APPLI+".AMSK"       [AMK2] : Endif
If clalev([F:AMZ2])=0 : Local File =APPLI+".AMSKZON"    [AMZ2] : Endif
If clalev([F:AMA2])=0 : Local File =APPLI+".AMSKACT"    [AMA2] : Endif
If clalev([F:AMP2])=0 : Local File =APPLI+".AMSKPAR"    [AMP2] : Endif
#If clalev([F:AWI])=0  : Local File =APPLI+".AWINDOW"    [AWI]  : Endif
Local File =APPLI+".AWINDOW"    [AWI]
If clalev([F:AWP])=0  : Local File =APPLI+".AWINPAR"    [AWP]  : Endif
If clalev([F:AWT])=0  : Local File =APPLI+".AWINBOUT"   [AWT]  : Endif
If clalev([F:AWI2])=0 : Local File =APPLI+".AWINDOW"    [AWI2] : Endif
If clalev([F:AWP2])=0 : Local File =APPLI+".AWINPAR"    [AWP2] : Endif
If clalev([F:AWT2])=0 : Local File =APPLI+".AWINBOUT"   [AWT2] : Endif
If clalev([F:ATZ])=0  : Local File =APPLI+".ATABZON"    [ATZ]  : Endif
If clalev([F:ATY])=0  : Local File =APPLI+".ATYPE"      [ATY]  : Endif
If clalev([F:DIC])=0  : Local File =APPLI+".DICOEMP"    [DIC]  : Endif
If clalev([F:HRSMH])=0  : Local File =APPLI+".SCREMPH"    [HRSMH]  : Endif
If clalev([F:HRSMD])=0  : Local File =APPLI+".SCREMPD"    [HRSMD]  : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER   [ADS]  : Endif

Local Integer I , J , K , P, OK, VOK
Local Integer NUMTEXTE,NUMTEXTE2
Local Char    MASKDES(GLONAMK) , MASKREF(GLONAMK) , SAVLAN(GLONLAN)
Local Char    WINREF(GLONFEN) , WINDES(GLONFEN)
Local Integer NBRFLD
#80893 Replace (10) by GLONAVA and GLONATB
Local Char    FLD(GLONAVA)(1..300) , FLDTBL(GLONATB)(1..300) , FLDTIT(30)(1..300) , FLDTYP(3)(1..300)
Local Integer FLDMNL(1..300) , FLDOPT(1..300) , FLDFRM(1..300)
Local Decimal FLDLNG(1..300)
Local Integer IND(1..300)
Local Integer FIELD_DIMENSION
Local Shortint FLDTITFLG(1..300) #79017
Local Char LIBADI(GLONAX3)

NBRFLD = 0
VOK=1
For [HRSMD]SMD0 Where COD=[L]COD & LEG=[L]LEG
 NBRFLD += 1
 FLD(NBRFLD)    = [F:HRSMD]FLD
 IND(NBRFLD)    = [F:HRSMD]IND
 If [F:HRSMD]FLD = "FORMULE"
  FLD(NBRFLD) = toupper(mess(59,10709,1))
 Endif
 FLDTBL(NBRFLD) = [F:HRSMD]TBL
 FLDOPT(NBRFLD) = [F:HRSMD]OPT
 FLDTIT(NBRFLD) = [F:HRSMD]TIT
 FLDTITFLG(NBRFLD) = [F:HRSMD]TITFLG #79017
 FLDMNL(NBRFLD) = [F:HRSMD]MNL
 FLDLNG(NBRFLD) = [F:HRSMD]LNG
 FLDTYP(NBRFLD) = [F:HRSMD]TYP
 FLDFRM(NBRFLD) = [F:HRSMD]TYPFRM
 #60451: A vérifier sauf si c'est une formule
 If FLD(NBRFLD) <> toupper(mess(59,10709,1))
  #Pour ne pas avoir d'erreur dans la trace sur des écrans incorrects (avec champ obsolètes)
  Read [ATZ]CODZONE = FLDTBL(NBRFLD);FLD(NBRFLD)
  If fstat
   If GTRACE<>""
    # Erreur en validation du masque XXX : YYY Champ inexistant sur la table ZZZ
    Call ECR_TRACE(mess(21,123,1)-[L]LEG-[L]COD-":"-FLD(NBRFLD)-mess(13,133,1)-FLDTBL(NBRFLD) ,-1) From GESECRAN
   Endif
   VOK=0 : Break
  Endif
 Endif
Next
If !VOK : End : Endif

MASKREF = "GENEMP2"
MASKDES = "WMEM"+LEG+COD
WINREF  = "OGENEMP2"
WINDES  = "WFEM"+LEG+COD

Call TR_DELMSK(MASKDES,APPLI) From MSKDIV
If GOK=0 : End : Endif
Call TR_DELWIN(WINDES,APPLI) From MSKDIV
If GOK=0 : End : Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=0 : End : Endif

## Validation des écrans
Read [ADS]DOSSIER = APPLI
Call VALID(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
If !OK : GOK=0 : End : Endif

## Validation fenêtre
Call VALID(WINDES,APPLI,0,OK) From VALWIN
If !OK : GOK=0 : End : Endif
End

$TR1
GOK = 1
Read [AMA]TYPAFF = 1;MASKREF;"NAM";10;1
If !fstat
 NUMTEXTE = [F:AMA]INTITACT
Endif
If clalev([F:ACT])=0 : Local File ACTION [ACT] : Endif
Read [F:ACT]ACTION="ASELCOD"
If !fstat Then NUMTEXTE2=[F:ACT]INTITA : Endif
Trbegin [AMK]
 Read [AMK2]CODMSK = MASKREF
 [F:AMK] = [F:AMK2]
 [F:AMK]CODMSK = MASKDES
 [F:AMK]MDL    = 1
 [F:AMK]INTMSK = 0
 Write [AMK]
 If fstat : GOK=0 : Call FSTA("AMK") From GLOCK : Goto AB_TR1 : Endif
 I = 0
# On conserve les 4 premiers champs (bas de page + REFNUM + CTRNUM + CTRDAT) + les champs invisibles
 For [AMZ2]CODZON Where CODMSK=MASKREF
  If [F:AMZ2]SAIAFF<3 : I += 1 : Endif
  If I<=4 or [F:AMZ2]SAIAFF=3
   [F:AMZ] = [F:AMZ2]
   [F:AMZ]CODMSK = MASKDES
   Write [AMZ]
   If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
   Gosub COPIE_ACTION
   If GOK<1 : Break : Endif
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
# Ajout des champs sélectionnés
 K = 4
 F = 0
 For I=1 To NBRFLD

  If FLD(I)<>"REFNUM" & FLD(I)<>"CTRNUM" & FLD(I)<>"CTRDAT"
   K += 1
   Raz [F:AMZ]
   [F:AMZ]CODMSK  = MASKDES
   If toupper(FLD(I))=toupper(mess(59,10709,1)) #A formula?
    F += 1
    [F:AMZ]CODZON  = "F0"+num$(F)
    If FLDFRM(I)=1
     [F:AMZ]CODTYP  = FLDTYP(I)
     [F:AMZ]NOLIB   = FLDMNL(I)
     [F:AMZ]LONG    = FLDLNG(I)
    Elsif FLDFRM(I)=2
     If FLDTYP(I)=""
      [F:AMZ]CODTYP  = "DCB"
     Else
      [F:AMZ]CODTYP  = FLDTYP(I)
     Endif
     If FLDLNG(I)=0
      [F:AMZ]LONG    = 11.2
     Else
      [F:AMZ]LONG    = FLDLNG(I)
     Endif
     [F:AMZ]OPTSAI  = "3z"
    Elsif FLDFRM(I)=5
     If FLDTYP(I)<>""
      [F:AMZ]CODTYP  = FLDTYP(I)
      [F:AMZ]LONG    = FLDLNG(I)
     Else
      [F:AMZ]CODTYP  = "DCB"
      [F:AMZ]LONG    = 11.2
      [F:AMZ]OPTSAI  = "3z"
     Endif
    Else
     [F:AMZ]CODTYP  = "DCB"
     [F:AMZ]LONG    = 5.2
     [F:AMZ]OPTSAI  = "3z"
    Endif
    [F:AMZ]INTIT   = 0
    [F:AMZ]INTEVAL = '"'+FLDTIT(I)+'"'
   Else
    FIELD_DIMENSION = func TRTEMP1.EMP_FIELD_DIMENSION(FLDTBL(I), FLD(I))
    If IND(I) > 0 #if the index is greater than 0 add _INDEX to the field name
      [F:AMZ]CODZON = FLD(I) + "_" + num$(IND(I))
    Elsif FIELD_DIMENSION > 1
      [F:AMZ]CODZON = FLD(I) + "_0"
    Else #just use the field name
      [F:AMZ]CODZON  = FLD(I)
    Endif
    Read [ATZ]CODZONE = FLDTBL(I);FLD(I)
    Read [DIC]DIC0 = FLD(I)
    [F:AMZ]CODTYP = [F:ATZ]CODTYP
    [F:AMZ]NOLIB  = [F:ATZ]NOLIB
    [F:AMZ]LONG   = [F:ATZ]LONG
    [F:AMZ]OBLIG  = [F:ATZ]OBLIG
    [F:AMZ]CODACT = [F:ATZ]CODACT
    [F:AMZ]OPTSAI = [F:ATZ]OPTION
    WOK = 0
    For [AMZ2]DICO Where CODZON="W"+FLD(I)#use FLD instead of [F:AMZ]CODZON as might have _IND at the end
     If left$([F:AMZ2]CODMSK,3)="MAT"
      [F:AMZ]OPTSAI = [F:AMZ2]OPTSAI
      If left$([F:AMZ2]OPTFOR,1)<>"="
       [F:AMZ]OPTFOR = [F:AMZ2]OPTFOR
      Endif
      [F:AMZ]OPTLNG = [F:AMZ2]OPTLNG
      WOK = 1 : Break
     Endif
    Next
    If !WOK
     For [AMZ2]DICO Where CODZON= FLD(I)#use FLD instead of [F:AMZ]CODZON as might have _IND at the end
      If left$([F:AMZ2]CODMSK,3)="MAT"
       [F:AMZ]OPTSAI = [F:AMZ2]OPTSAI
       If left$([F:AMZ2]OPTFOR,1)<>"="
        [F:AMZ]OPTFOR = [F:AMZ2]OPTFOR
       Endif
       [F:AMZ]OPTLNG = [F:AMZ2]OPTLNG
       WOK = 1 : Break
      Endif
     Next
    Endif
    Case [F:AMZ]CODZON
     When "CCE1","CCE2","CCE3","CCE4","CCE5","CCE6","CCE7","CCE8","CCE9"
      [F:AMZ]INTIT   = 0
      [F:AMZ]INTEVAL = '"'+mess(val(right$([F:AMZ]CODZON,4)),601,1)+'"'
     When "INICCE1","INICCE2","INICCE3","INICCE4","INICCE5","INICCE6","INICCE7","INICCE8","INICCE9"
      [F:AMZ]INTIT   = 0
      [F:AMZ]INTEVAL = '"'+mess(80,10702,1)-mess(val(right$([F:AMZ]CODZON,7)),601,1)+'"'
     When "CUM1","CUM2","CUM3","CUM4","CUM5","CUM6","CUM7","CUM8","CUM9"
      [F:AMZ]INTIT   = 0
      Call LECTEXTRA(LIBADI,"ATABDIV","LNGDES","10349","00"+right$([F:AMZ]CODZON,4)) From ATEXTRA
      If LIBADI = "" : LIBADI = FLDTIT(I-1) : Endif
      [F:AMZ]INTEVAL = '"'+LIBADI+'"'
     When Default
      [F:AMZ]INTIT   = [F:DIC]DES
      If FLDTITFLG(I) = 2 #79017
        [F:AMZ]INTIT   = 0
        [F:AMZ]INTEVAL   = '"'+FLDTIT(I)+'"'
      Endif #79017
    Endcase
   Endif
   #If [F:AMZ]CODZON="CTRNUM" : # On ne modifie pas le no de contrat
   # [F:AMZ]SAIAFF = 2
   #Else
   # [F:AMZ]SAIAFF = FLDOPT(I)
   #Endif
   [F:AMZ]SAIAFF  = FLDOPT(I)
   [F:AMZ]MODE    = 1
   [F:AMZ]NUMBLOC = 1
   [F:AMZ]NOZONE  = K
   Read [ATY]CODTYP = [F:AMZ]CODTYP
   If [F:ATY]OBJLIEN<>""
    [F:AMZ]TUNNEL = 2
   Endif
   # FQ81085 - 17/12/13 - La civilité et la situation familiale sont des menus locaux variant selon la leg
   If find([F:AMZ]CODZON,"CIV","CIVCTR","SITFAM") Then
    [F:AMZ]SAIAFF  = 3
   Endif
   Write [AMZ]
   If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Break : Endif
    # FQ81085 - 17/12/13 - La civilité et la situation familiale sont des menus locaux variant selon la leg
    If find([F:AMZ]CODZON,"CIV","CIVCTR","SITFAM") Then
      Raz [F:AMZ]
      K+=1
      [F:AMZ]CODMSK  = MASKDES
      [F:AMZ]CODZON  = FLD(I)+"A"
      Read [ATZ]CODZONE = FLDTBL(I);FLD(I)
      Read [DIC]DIC0 = FLD(I)
      [F:AMZ]CODTYP = "A"
      [F:AMZ]NOLIB  = [F:ATZ]NOLIB
      [F:AMZ]LONG   = 25
      [F:AMZ]OBLIG  = [F:ATZ]OBLIG
      [F:AMZ]CODACT = [F:ATZ]CODACT
      [F:AMZ]OPTSAI = [F:ATZ]OPTION
      [F:AMZ]INTIT   = [F:DIC]DES
      If FLDTITFLG(I) = 2 #79017
        [F:AMZ]INTIT   = 0
        [F:AMZ]INTEVAL   = '"'+FLDTIT(I)+'"'
      Endif #79017
      [F:AMZ]SAIAFF  = FLDOPT(I)
      [F:AMZ]MODE    = 1
      [F:AMZ]NUMBLOC = 1
      [F:AMZ]NOZONE  = K
      Read [ATY]CODTYP = [F:AMZ]CODTYP
      If [F:ATY]OBJLIEN<>""
       [F:AMZ]TUNNEL = 2
      Endif
      Write [AMZ]
      If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Break : Endif
    Endif
    # Fin FQ81085
#  Paramètres du dictionnaire
   If toupper(FLD(I))<>toupper(mess(59,10709,1))
    Read [F:DIC]DIC0 = FLD(I)#use FLD instead of [F:AMZ]CODZON as might have _IND at the end
    If !fstat
     For P=0 To [F:DIC]NBRPAR-1
      [F:AMP]CODAFF = MASKDES
      [F:AMP]CODPAR = [F:DIC]PARCOD(P)
      [F:AMP]CODZON = [F:AMZ]CODZON
      [F:AMP]TYPAFF = 1
      [F:AMP]VALPAR = [F:DIC]PARVAL(P)
      Write [AMP]
      If fstat
       GOK = 0 : Call FSTA("AMP") From GLOCK : Break
      Endif
     Next P
    Endif
   Endif
# Ajout d'une action de contrôle
   If [F:AMZ]SAIAFF=1
    Case [F:ATY]TYPTYP
     When 1       : [F:AMA]ACTION = "CONTEMPI"
     When 7       : [F:AMA]ACTION = "CONTEMPC"
     When 8       : [F:AMA]ACTION = "CONTEMPD"
     When Default : [F:AMA]ACTION = "CONTEMPB"
    Endcase
    [F:AMA]TYPAFF   = 1
    [F:AMA]CODAFF   = [F:AMZ]CODMSK
    [F:AMA]CODZON   = [F:AMZ]CODZON
    [F:AMA]NOACT    = 1
    [F:AMA]TYPACT   = 5 : # Contrôle
    [F:AMA]EXEACT   = 3
    Write [AMA]
    If fstat
     GOK = 0 : Call FSTA("AMA") From GLOCK : Break
    Endif
# Action de sélection pour les champs dates
    If find([F:AMZ]CODZON,"MEDDAT","CTRDAT","SALDAT")
     [F:AMA]ACTION   = "SELEMPD"
     [F:AMA]TYPAFF   = 1
     [F:AMA]CODAFF   = [F:AMZ]CODMSK
     [F:AMA]CODZON   = [F:AMZ]CODZON
     [F:AMA]NOACT    = 2
     [F:AMA]TYPACT   = 8 : # Sélection
     [F:AMA]EXEACT   = 1
     Write [AMA]
     If fstat
      GOK = 0 : Call FSTA("AMA") From GLOCK : Break
     Endif
    Endif

#88174-US2223 Ajout d'une action d'avant saisie
    Case [F:ATY]TYPTYP
     When 1       : [F:AMA]ACTION = "BSEMPI"
     When 7       : [F:AMA]ACTION = "BSEMPC"
     When 8       : [F:AMA]ACTION = "BSEMPD"
     When Default : [F:AMA]ACTION = "BSEMPB"
    Endcase
    [F:AMA]TYPAFF   = 1
    [F:AMA]CODAFF   = [F:AMZ]CODMSK
    [F:AMA]CODZON   = [F:AMZ]CODZON
    [F:AMA]NOACT    = 5
    [F:AMA]TYPACT   = 4 : # Avant saisie
    [F:AMA]EXEACT   = 3
    Write [AMA]
    If fstat
     GOK = 0 : Call FSTA("AMA") From GLOCK : Break
    Endif
#end 88174

# Ajout des boutons tri et affectation
    Case [F:ATY]TYPTYP
     When 1       : [F:AMA]ACTION = "AFFEMPI"
     When 7       : [F:AMA]ACTION = "AFFEMPC"
     When 8       : [F:AMA]ACTION = "AFFEMPD"
     When Default : [F:AMA]ACTION = "AFFEMPB"
    Endcase
    [F:AMA]NOACT  = 3
    [F:AMA]TYPACT = 10 : # Bouton 2
    [F:AMA]INTITACT = NUMTEXTE
    Write [AMA]
    If fstat
     GOK = 0 : Call FSTA("AMA") From GLOCK : Break
    Endif
# Action augmentation
    If find([F:ATY]TYPTYP,2,3,4,5,6)
     Read [AMA]TYPAFF = 1;MASKREF;"NAM";11;2
     If !fstat
      [F:AMA]CODAFF = [F:AMZ]CODMSK
      [F:AMA]CODZON = [F:AMZ]CODZON
      [F:AMA]NOACT  = 4
      [F:AMA]TYPACT = 11 : # Bouton 3
      Write [AMA]
      If fstat
       GOK = 0 : Call FSTA("AMA") From GLOCK : Break
      Endif
     Endif
    Endif
    [F:AMP]CODAFF = MASKDES
    [F:AMP]CODPAR = "LIG"
    [F:AMP]CODZON = [F:AMZ]CODZON
    [F:AMP]TYPAFF = 1
    [F:AMP]VALPAR = "num$(nolign)"
    Write [AMP]
    If fstat
     GOK = 0 : Call FSTA("AMP") From GLOCK : Break
    Endif
# Paramètre du code de la zone
    [F:AMP]CODAFF = MASKDES
    [F:AMP]CODPAR = "CODZON"
    [F:AMP]CODZON = [F:AMZ]CODZON
    [F:AMP]TYPAFF = 1
    [F:AMP]VALPAR = '"'+[F:AMZ]CODZON+'"'
    Write [AMP]
    If fstat
     GOK = 0 : Call FSTA("AMP") From GLOCK : Break
    Endif

    # FQ81085 - 17/12/13 - La civilité et la situation familiale sont des menus locaux variant selon la leg
    If find([F:AMZ]CODZON,"CIVA","CIVCTRA","SITFAMA")
     # Action de sélection du menu local
     [F:AMA]ACTION   = "SELMNLEMP"
     [F:AMA]TYPAFF   = 1
     [F:AMA]CODAFF   = [F:AMZ]CODMSK
     [F:AMA]CODZON   = [F:AMZ]CODZON
     [F:AMA]NOACT    = 2
     [F:AMA]TYPACT   = 8 : # Sélection
     [F:AMA]EXEACT   = 1
     [F:AMA]INTITACT = NUMTEXTE2
     Write [AMA]
     If fstat
      GOK = 0 : Call FSTA("AMA") From GLOCK : Break
     Endif
     [F:AMP]CODAFF = [F:AMZ]CODMSK
     [F:AMP]CODPAR = "NOLIB"
     [F:AMP]CODZON = [F:AMZ]CODZON
     [F:AMP]TYPAFF = 1
     [F:AMP]VALPAR = "GNOLIB"
     Write [AMP]
     If fstat
      GOK = 0 : Call FSTA("AMP") From GLOCK : Break
     Endif
     # Action Avant_Saisie pour calculer le numéro de menu local
     [F:AMA]ACTION   = "INIMNL"
     [F:AMA]TYPAFF   = 1
     [F:AMA]CODAFF   = [F:AMZ]CODMSK
     [F:AMA]CODZON   = [F:AMZ]CODZON
     [F:AMA]NOACT    = 2
     [F:AMA]TYPACT   = 4 : # Avant_Saisie
     [F:AMA]EXEACT   = 1
     Write [AMA]
     If fstat
      GOK = 0 : Call FSTA("AMA") From GLOCK : Break
     Endif
     [F:AMP]CODAFF = [F:AMZ]CODMSK
     [F:AMP]CODPAR = "ZONE"
     [F:AMP]CODZON = [F:AMZ]CODZON
     [F:AMP]TYPAFF = 1
     [F:AMP]VALPAR = '"'+[F:AMZ]CODZON+'"'
     Write [AMP]
     If fstat
      GOK = 0 : Call FSTA("AMP") From GLOCK : Break
     Endif
     [F:AMP]CODAFF = [F:AMZ]CODMSK
     [F:AMP]CODPAR = "PARAM"
     [F:AMP]CODZON = [F:AMZ]CODZON
     [F:AMP]TYPAFF = 1
     # FQ81085 - 17/12/13 - Les paramètres pour CIVA et SITFAMA
     If [F:AMZ]CODZON="CIVA" | [F:AMZ]CODZON="CIVCTRA"  Then [F:AMP]VALPAR = '"CIVIL"' : Endif
     If [F:AMZ]CODZON="SITFAMA"                         Then [F:AMP]VALPAR = '"SITFAM"' : Endif
     # Fin FQ81085
     Write [AMP]
     If fstat
      GOK = 0 : Call FSTA("AMP") From GLOCK : Break
     Endif
     # Action Contrôle pour le contrôle de saisie sur le menu local
     [F:AMA]ACTION   = "CONTSAIMNL"
     [F:AMA]TYPAFF   = 1
     [F:AMA]CODAFF   = [F:AMZ]CODMSK
     [F:AMA]CODZON   = [F:AMZ]CODZON
     [F:AMA]NOACT    = 2
     [F:AMA]TYPACT   = 5 : # Contrôle
     [F:AMA]EXEACT   = 1
     Write [AMA]
     If fstat
      GOK = 0 : Call FSTA("AMA") From GLOCK : Break
     Endif
    Endif
    # Fin FQ81085
   Endif
  Endif
 Next I
 If GOK<1 : Goto AB_TR1 : Endif
# Création de la fenêtre de saisie
 Read [AWI2]AWI0 = WINREF
 [F:AWI] = [F:AWI2]
 [F:AWI]WIN       = WINDES
 [F:AWI]NOMMSK(0) = MASKDES
 [F:AWI]ENAFLG    = 2
 [F:AWI]MDL       = 1
 Write [AWI]
 If fstat
  GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TR1
 Endif
 For [AWP2]AWP0 Where WIN=WINREF
  [F:AWP] = [F:AWP2]
  [F:AWP]WIN = WINDES
  Write [AWP]
  If fstat
   GOK = 0 : Call FSTA("AWP") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
 For [AWT2]AWT0 Where WIN=WINREF
  [F:AWT] = [F:AWT2]
  [F:AWT]WIN = WINDES
  Write [AWT]
  If fstat
   GOK = 0 : Call FSTA("AWT") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$COPIE_ACTION
For [AMA2] Where TYPAFF=1 & CODAFF=MASKREF & CODZON=[F:AMZ]CODZON
 [F:AMA] = [F:AMA2]
 [F:AMA]CODAFF = MASKDES
 [F:AMA]CODZON = [F:AMZ]CODZON #set to correct value
 Write [AMA]
 If fstat
  GOK=0 : Call FSTA("AMA") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif
For [AMP2] Where TYPAFF=1 & CODAFF=MASKREF & CODZON=[F:AMZ]CODZON
 [F:AMP] = [F:AMP2]
 [F:AMP]CODAFF = MASKDES
 [F:AMP]CODZON = [F:AMZ]CODZON #set to correct value
 Write [AMP]
 If fstat
  GOK=0 : Call FSTA("AMP") From GLOCK : Break
 Endif
Next
If   GOK<1 : Return : Endif
Return

$AB_TR1
Rollback
Return

