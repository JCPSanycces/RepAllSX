Subprog AS_WETRFCY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_WETRFCY(VALEUR) From SUBHRENT
If mkstat=2
 [M]WETRFCY(INDIC) = VALEUR
 Affzo WETRFCY(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_WETRFCY(zc) From W1ENTSAL2
Onkey 144 Titled GBOUTP Call P_WETRFCY(zc) From W1ENTSAL2
Onkey 146 Titled GBOUTA Call SA_WETRFCY(zc) From W1ENTSAL2
Gosub _AFF
End

Subprog C_WETRFCY(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
If !mkstat
 ## Action ACONTFCY
 Call CONTSITE(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("FCY","P",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
  If !mkstat
   ## Action STD
   Call C_WETRFCY(VALEUR) From SUBHRENT
   If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
   If !mkstat
    ## Action CTLFCYAUZ
    Local Char    PARMSK(250)(1..20) , SAVACT(20)
    SAVACT = GACTION : GACTION = "CTLFCYAUZ"
    Call S_AFF_CHAR(VALEUR,PARMSK,"CTLFCYAUZ","CONTX3","") From GACTION
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
   Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_WETRFCY
Call AM_WETRFCY(zc)
If !mkstat & GOBJET
 zoncou = "WETRFCY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WETRFCY(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WETRFCY(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWETRFCY)")>indice
 [M]WETRFCY(indice) = VALEUR
 Affzo ZWETRFCY(indice)
Endif
Gosub _AFF
End

