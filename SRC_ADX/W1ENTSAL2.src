Subprog B1_WAGNMIDWRK(VALEUR)
Variable Char    VALEUR()
Call OBJET("ORG",VALEUR,num$(GCURLEG)) From GOBJET
Gosub _AFF
End

Subprog SA_WAGNMIDWRK(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ORG"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WAGNMIDWRK(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("ORG",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZWAGNMIDWRK
Onevent BEFORE_AREA Gosub AV_ZWAGNMIDWRK From W1ENTSAL2
Return

$AV_ZWAGNMIDWRK
Call LECTEXTRA(zc,"ORGANISME","DES",num$(GCURLEG),num$([M]WAGNMIDWRK(indice))) From ATEXTRA
Gosub _AFF
Return

