If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "WMATREMP" : GZNUM = 46590 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","!$",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "WMATREMP" : GZNUM = 46590 : Endif
