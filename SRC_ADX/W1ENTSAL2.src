 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WPROPRF" : GZNUM = 8750 : Endif
 If !mkstat
  ## Action STD
  Call C_WPROPRF(VALEUR) From SUBHRENT
  If mkstat : GERR = 1 : GZONE = "WPROPRF" : GZNUM = 8750 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_WPROPRF
Call AM_WPROPRF(zc)
If !mkstat & GOBJET
 zoncou = "WPROPRF" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WPROPRF(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WPROPRF(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "WPROPRF" : GZNUM = 8750 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWPROPRF)")>indice
 [M]WPROPRF(indice) = VALEUR
 Affzo ZWPROPRF(indice)
Endif
Gosub _AFF
End

Subprog S_WPROPRF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPRF
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPRF"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPRF","SUBPRF","SPEPRF") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WPROPRF(VALEUR)
Variable Char    VALEUR()
Call OBJET("PRF",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog B2_WPROPRF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call B2_WPROPRF(VALEUR) From SUBHRENT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_WPROPRF(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PRF"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WPROPRF(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("PRF",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZWPROPRF
Onevent BEFORE_AREA Gosub AV_ZWPROPRF From W1ENTSAL2
Return

$AV_ZWPROPRF
Call LECTEXTRA(zc,"PROFIL","PRFDES","",num$([M]WPROPRF(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_WJOB
Onevent AFTER_CHANGE Gosub AMM_WJOB From W1ENTSAL2
Onevent BEFORE_INPUT Call AS_WJOB(zc) From W1ENTSAL2
Onevent CONTROL Call C_WJOB(zc) From W1ENTSAL2
Return

Subprog AS_WJOB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47278,GBOUT1) From OBJDIV
Call TEXTE(22321,GBOUT2) From OBJDIV
Call TEXTE(45853,GBOUT3) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WJOB(zc) From W1ENTSAL2
Onkey 130 Titled GBOUT2 Call B2_WJOB(zc) From W1ENTSAL2
Onkey 131 Titled GBOUT3 Call B3_WJOB(zc) From W1ENTSAL2
Onkey   2 Titled GBOUTS Call S_WJOB(zc) From W1ENTSAL2
Gosub _AFF
End

Subprog C_WJOB(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WJOB" : GZNUM = 45897 : Endif
Gosub _AFF
End

$AMM_WJOB
Call AM_WJOB(zc)
If !mkstat & GOBJET
 zoncou = "WJOB" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

