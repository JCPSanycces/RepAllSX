Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELORGLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELORGLEG"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELORGLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
