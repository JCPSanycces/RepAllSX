Subprog CL_WCLCDOC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CTRDOC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CTRDOC"
 PARMSK(1) = [M]REFNUM
 PARMSK(2) = [M]WCTRNUM
 PARMSK(3) = [M]WCTRDAT
 PARMSK(4) = [M]LEGORI
 PARMSK(5) = num$([M]WFLGCRE1)
 PARMSK(6) = num$([M]WFLGOKDOC)
 Call SAISIE_CHAR(VALEUR,PARMSK,"CTRDOC","CTRDOC","SPECTRDOC") From GSAISIE
 [M]WFLGCRE1 = val(PARMSK(5))
 [M]WFLGOKDOC = val(PARMSK(6))
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action STD
 Call CL_WCLCDOC(VALEUR) From SUBHRENT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

