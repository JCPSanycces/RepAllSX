$ON_WAGNMIDWRK
Onevent CONTROL Call C_WAGNMIDWRK(zc) From W1ENTSAL2
Onevent AFTER_CHANGE Gosub AMM_WAGNMIDWRK From W1ENTSAL2
Onevent BEFORE_INPUT Call AS_WAGNMIDWRK(zc) From W1ENTSAL2
Return

Subprog AS_WAGNMIDWRK(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(46228,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WAGNMIDWRK(zc) From W1ENTSAL2
Onkey   2 Titled GBOUTS Call S_WAGNMIDWRK(zc) From W1ENTSAL2
Onkey 144 Titled GBOUTP Call P_WAGNMIDWRK(zc) From W1ENTSAL2
Onkey 146 Titled GBOUTA Call SA_WAGNMIDWRK(zc) From W1ENTSAL2
Gosub _AFF
End

Subprog C_WAGNMIDWRK(VALEUR)
Variable Char    VALEUR()
## Action CONTOBJN
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CONTOBJN"
Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "WAGNMIDWRK" : GZNUM = 47301 : Endif
If !mkstat
 ## Action CONTORG
 Call CONTORG(VALEUR) From SUBORG
 If mkstat : GERR = 1 : GZONE = "WAGNMIDWRK" : GZNUM = 47301 : Endif
Endif
Gosub _AFF
End

$AMM_WAGNMIDWRK
Call AM_WAGNMIDWRK(zc)
If !mkstat & GOBJET
 zoncou = "WAGNMIDWRK" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WAGNMIDWRK(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WAGNMIDWRK(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "WAGNMIDWRK" : GZNUM = 47301 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWAGNMIDWRK)")>indice
 [M]WAGNMIDWRK(indice) = VALEUR
 Affzo ZWAGNMIDWRK(indice)
Endif
Gosub _AFF
End

